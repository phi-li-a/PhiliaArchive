{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 11", "volume_uuid": "a122562b-d4de-4936-ab60-486f42d8a498", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [83, 1403, 623, 1558], "vertical": false, "font_size": 157, "lines_coords": [[[232.0, 1389.0], [623.0, 1389.0], [623.0, 1560.0], [232.0, 1560.0]]], "lines": ["本タツキ"]}, {"box": [85, 1591, 442, 1636], "vertical": false, "font_size": 35, "lines_coords": [[[89.0, 1593.0], [433.0, 1593.0], [433.0, 1631.0], [89.0, 1631.0]]], "lines": ["Ｆｏｒｓｙ．ｃｏｊｉｎｎｏｋｏ"]}, {"box": [4, 2276, 508, 2385], "vertical": false, "font_size": 53, "lines_coords": [[[264.0, 2283.0], [464.0, 2288.0], [464.0, 2345.0], [264.0, 2340.0]]], "lines": ["ＣｏｌｌｌｏＳ"]}, {"box": [1035, 2267, 1499, 2340], "vertical": false, "font_size": 53, "lines_coords": [[[1042.0, 2274.0], [1373.0, 2274.0], [1373.0, 2331.0], [1042.0, 2331.0]]], "lines": ["がんばれチェンソ"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [131, 2167, 1394, 2271], "vertical": false, "font_size": 40.0, "lines_coords": [[[131.0, 2167.0], [1394.0, 2167.0], [1394.0, 2207.0], [131.0, 2207.0]], [[131.0, 2231.0], [1389.0, 2231.0], [1389.0, 2271.0], [131.0, 2271.0]]], "lines": ["★この作品はフィクションです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [40, 38, 584, 128], "vertical": false, "font_size": 79, "lines_coords": [[[56.0, 32.0], [571.0, 42.0], [571.0, 128.0], [56.0, 119.0]]], "lines": ["ＪＵＭＰ．ＣＯＭＩＣＳで"]}, {"box": [546, 2088, 930, 2142], "vertical": false, "font_size": 50, "lines_coords": [[[546.0, 2092.0], [930.0, 2088.0], [930.0, 2137.0], [546.0, 2142.0]]], "lines": ["【がんばれチェンソーマン】"]}, {"box": [536, 2163, 946, 2296], "vertical": false, "font_size": 133, "lines_coords": [[[536.0, 2163.0], [946.0, 2163.0], [946.0, 2296.0], [536.0, 2296.0]]], "lines": ["藤本タツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [707, 124, 1413, 194], "vertical": false, "font_size": 70, "lines_coords": [[[707.0, 124.0], [1413.0, 124.0], [1413.0, 194.0], [707.0, 194.0]]], "lines": ["ＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [124, 384, 299, 454], "vertical": false, "font_size": 70, "lines_coords": [[[124.0, 384.0], [299.0, 384.0], [299.0, 454.0], [124.0, 454.0]]], "lines": ["デンジ"]}, {"box": [105, 501, 744, 702], "vertical": false, "font_size": 50, "lines_coords": [[[105.0, 501.0], [606.0, 501.0], [606.0, 597.0], [105.0, 597.0]], [[114.0, 590.0], [714.0, 578.0], [714.0, 642.0], [114.0, 653.0]], [[124.0, 658.0], [642.0, 653.0], [642.0, 693.0], [124.0, 698.0]], [[187.0, 642.0], [260.0, 642.0], [260.0, 658.0], [187.0, 658.0]], [[574.0, 539.0], [731.0, 539.0], [731.0, 571.0], [574.0, 571.0]]], "lines": ["秋神のボチタをその身に宿す、「。", "の悪魔』の少年。自分の欲望に正直。", "めて人並扱いしてくれたマキマが好き", "．．．", "『チェンツー"]}, {"box": [1227, 2003, 1415, 2087], "vertical": false, "font_size": 75, "lines_coords": [[[1230.0, 2006.0], [1413.0, 2010.0], [1410.0, 2085.0], [1228.0, 2081.0]]], "lines": ["ポチタ"]}, {"box": [864, 2127, 1421, 2271], "vertical": false, "font_size": 56, "lines_coords": [[[1103.0, 2149.0], [1415.0, 2156.0], [1415.0, 2212.0], [1103.0, 2205.0]], [[864.0, 2207.0], [1415.0, 2214.0], [1415.0, 2271.0], [864.0, 2264.0]]], "lines": ["『チェンソーの悪魔』。", "デンジに心臓を与え、体の一部となる。"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [355, 618, 503, 682], "vertical": false, "font_size": 59, "lines_coords": [[[358.0, 618.0], [496.0, 618.0], [496.0, 677.0], [358.0, 677.0]]], "lines": ["マキマ"]}, {"box": [124, 710, 728, 836], "vertical": false, "font_size": 60, "lines_coords": [[[124.0, 710.0], [728.0, 710.0], [728.0, 796.0], [124.0, 796.0]], [[135.0, 796.0], [454.0, 796.0], [454.0, 829.0], [135.0, 829.0]]], "lines": ["公式対策事業員等を取り上げるミステリアスポーツアスは、", "その正体は「支配の悪職」"]}, {"box": [1029, 612, 1183, 685], "vertical": false, "font_size": 73, "lines_coords": [[[1029.0, 612.0], [1183.0, 612.0], [1183.0, 685.0], [1029.0, 685.0]]], "lines": ["パワー"]}, {"box": [808, 722, 1415, 846], "vertical": false, "font_size": 60, "lines_coords": [[[820.0, 733.0], [1415.0, 742.0], [1415.0, 789.0], [820.0, 780.0]], [[808.0, 768.0], [1122.0, 773.0], [1122.0, 846.0], [808.0, 841.0]]], "lines": ["Ｉ血の悪魔」の魔人。自分勝手で暴走しがち。", "「皿のぶぬ」数のニャーコが唯一の友達。"]}, {"box": [383, 1391, 479, 1484], "vertical": false, "font_size": 93, "lines_coords": [[[383.0, 1391.0], [479.0, 1391.0], [479.0, 1484.0], [383.0, 1484.0]]], "lines": ["岸辺"]}, {"box": [122, 1525, 735, 1639], "vertical": false, "font_size": 48, "lines_coords": [[[131.0, 1525.0], [735.0, 1525.0], [735.0, 1589.0], [131.0, 1589.0]], [[138.0, 1600.0], [471.0, 1600.0], [471.0, 1633.0], [138.0, 1633.0]]], "lines": ["並外れた戦闘力を持つつ特異課最強のデビルハンターの", "マキマのことを警戒しているう"]}, {"box": [140, 1753, 426, 1816], "vertical": false, "font_size": 56, "lines_coords": [[[140.0, 1760.0], [426.0, 1753.0], [426.0, 1809.0], [140.0, 1816.0]]], "lines": ["ＳＴＯＲＹ－"]}, {"box": [956, 1364, 1249, 1502], "vertical": false, "font_size": 151, "lines_coords": [[[956.0, 1351.0], [1249.0, 1351.0], [1249.0, 1515.0], [956.0, 1515.0]]], "lines": ["東山コベニ"]}, {"box": [806, 1518, 1410, 1639], "vertical": false, "font_size": 53, "lines_coords": [[[806.0, 1518.0], [1399.0, 1518.0], [1399.0, 1591.0], [806.0, 1591.0]], [[810.0, 1598.0], [1087.0, 1598.0], [1087.0, 1631.0], [810.0, 1631.0]]], "lines": ["元公安対療特異４課のデビルハンター。現在はハン", "パーガーンヨップの店員"]}, {"box": [131, 1872, 733, 1966], "vertical": false, "font_size": 45.0, "lines_coords": [[[157.0, 1872.0], [733.0, 1872.0], [733.0, 1912.0], [157.0, 1912.0]], [[131.0, 1917.0], [724.0, 1914.0], [724.0, 1964.0], [131.0, 1966.0]]], "lines": ["悪魔のボチタと共にデビルハンターとして暮らす少年・デンジ。", "２０１７年１２／１４／１９（土）第２４回全国の大丈夫ですから１０万円以上を使用していましたのですが、"]}, {"box": [135, 1980, 719, 2165], "vertical": false, "font_size": 33.0, "lines_coords": [[[135.0, 1980.0], [719.0, 1980.0], [719.0, 2013.0], [135.0, 2013.0]], [[140.0, 2029.0], [710.0, 2029.0], [710.0, 2062.0], [140.0, 2062.0]], [[135.0, 2081.0], [714.0, 2078.0], [714.0, 2111.0], [135.0, 2114.0]], [[138.0, 2132.0], [260.0, 2132.0], [260.0, 2165.0], [138.0, 2165.0]]], "lines": ["を、裏切りに合い残されてしまう。ただが、ボチタがその命と引", "き換えにデンジを【チェンツこの悪魔」として蘇らせる！敵を", "皆殺しにしたデンジは、マキマに拾われ公安のデビルハンターと", "なるのだった。"]}, {"box": [154, 2170, 719, 2219], "vertical": false, "font_size": 49, "lines_coords": [[[154.0, 2170.0], [719.0, 2170.0], [719.0, 2219.0], [154.0, 2219.0]]], "lines": ["このように、自分でやればいけー、緊張しましたが、これからもう少し最後の"]}, {"box": [135, 2233, 773, 2266], "vertical": false, "font_size": 33, "lines_coords": [[[135.0, 2233.0], [773.0, 2233.0], [773.0, 2266.0], [135.0, 2266.0]]], "lines": ["になったデンジは「マキマさんの犬になりたいいと告げるが、マート・"]}, {"box": [766, 1855, 1409, 2269], "vertical": false, "font_size": 44, "lines_coords": [[[808.0, 1866.0], [1408.0, 1859.0], [1408.0, 1916.0], [808.0, 1923.0]], [[815.0, 1922.0], [1406.0, 1922.0], [1406.0, 1970.0], [815.0, 1970.0]], [[815.0, 1974.0], [1399.0, 1974.0], [1399.0, 2014.0], [815.0, 2014.0]], [[813.0, 2016.0], [1401.0, 2013.0], [1401.0, 2071.0], [813.0, 2073.0]], [[815.0, 2072.0], [1392.0, 2072.0], [1392.0, 2120.0], [815.0, 2120.0]], [[820.0, 2128.0], [1406.0, 2128.0], [1406.0, 2169.0], [820.0, 2169.0]], [[817.0, 2178.0], [1399.0, 2171.0], [1399.0, 2218.0], [817.0, 2225.0]], [[766.0, 2222.0], [1246.0, 2224.0], [1246.0, 2272.0], [766.0, 2270.0]]], "lines": ["キスは２０００周年の１００７を使ってキャラクラックに住宅したことを", "与えた後で全て尊うことで、記憶の扉を開いたのだった。心を失っ", "たデンジは・チェンソーマン・として覚醒。マキマの真の狙いは", "このクレジットンしていただきますので、「チンツーツ」の特徴にも関係しており、その価値はありませんから", "あるいですね．．．おまえは、おそらくあるんですかあればありがとうございますよね〜〜〜", "岸辺はその計画を阻止すべくマキマを殺害しようとするも失敗。", "７人の悪魔を従え、チェンいや、いいじゃないんじゃんのスタッフーマンを倒し支配しようと目論むて", "．．．ハッハッドはハッシングループの中で、それで、素晴らしい時間がかかったのです。"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [549, 1449, 949, 1506], "vertical": false, "font_size": 51, "lines_coords": [[[550.0, 1446.0], [935.0, 1451.0], [935.0, 1506.0], [550.0, 1501.0]]], "lines": ["ＣＯＮＴＥＮＴＳ"]}, {"box": [539, 1495, 1417, 2287], "vertical": false, "font_size": 233, "lines_coords": [[[681.0, 1544.0], [1291.0, 1544.0], [1291.0, 1626.0], [681.0, 1626.0]], [[799.0, 1614.0], [1047.0, 1614.0], [1047.0, 1715.0], [799.0, 1715.0]], [[543.0, 1607.0], [560.0, 1607.0], [560.0, 1823.0], [543.0, 1823.0]], [[796.0, 1704.0], [1298.0, 1704.0], [1298.0, 1802.0], [796.0, 1802.0]], [[621.0, 1539.0], [651.0, 1539.0], [651.0, 1968.0], [621.0, 1968.0]], [[752.0, 1718.0], [780.0, 1718.0], [780.0, 1802.0], [752.0, 1802.0]], [[824.0, 1795.0], [1117.0, 1786.0], [1120.0, 1879.0], [827.0, 1888.0]], [[616.0, 1579.0], [766.0, 1561.0], [834.0, 2156.0], [684.0, 2174.0]], [[749.0, 1746.0], [780.0, 1746.0], [775.0, 1996.0], [745.0, 1996.0]], [[649.0, 1537.0], [698.0, 1537.0], [700.0, 2226.0], [651.0, 2226.0]], [[799.0, 1800.0], [841.0, 1800.0], [841.0, 1996.0], [799.0, 1996.0]], [[571.0, 1525.0], [602.0, 1525.0], [602.0, 2303.0], [571.0, 2303.0]], [[817.0, 1858.0], [1089.0, 1851.0], [1092.0, 1975.0], [820.0, 1982.0]], [[1078.0, 1945.0], [1242.0, 1945.0], [1242.0, 2013.0], [1078.0, 2013.0]], [[778.0, 1905.0], [1406.0, 1947.0], [1396.0, 2118.0], [768.0, 2076.0]], [[539.0, 1781.0], [562.0, 1781.0], [562.0, 2301.0], [539.0, 2301.0]], [[621.0, 1919.0], [653.0, 1919.0], [653.0, 2221.0], [621.0, 2221.0]], [[796.0, 2036.0], [1417.0, 2036.0], [1417.0, 2142.0], [796.0, 2142.0]], [[674.0, 2135.0], [1035.0, 2123.0], [1038.0, 2219.0], [677.0, 2231.0]], [[604.0, 2219.0], [1244.0, 2219.0], [1244.0, 2308.0], [604.0, 2308.0]]], "lines": ["これでもありがとうございますが、なんばれチェッシーマンのいいも、モバワー．．．", "話しかんばれチェンソー話し、翌バワー．．．。お前、パワー・バリー・", "とても、そのお気になっちゃって", "結婚相手ー．．．ｗｅｂサーバウー・パワー・バワーバルの話しがニラスカイ．．ｕｘ", "いやいや．．．そうだな", "つまり１話１パワ２話ーバー", "ーパワー・バワードパワ〜リバニラスカイ．．．。君と黄脱菌・の＂", "それにしても．．．", "いいかねえ．．．", "いやいやこっちゃって言ってるからっていいでしょうか", "１００７年１１月２４日とチェン５１", "つぼこんでぶっちゃったのかわかった．．．？", "「バニラスカイ．．．。君と覚謝事．．！チェンリーマン対策を", "『．．．マン対武器人間ズ", "それについては、あります。最後の２０１８年１０月２１日、チェンリーマンガ試験教えていただけますのです。", "．．．", "あのね．．．お父さんはいる！！こういうことだけじゃあの", "同じチェンソーマン対成株人間ズーツ・チェックニアン（１３）支配の登録」の際にこんな様子が", "９６５年１、チェンソーマンＶＯＳＯＧ言ーこんな味、１９７３．要ラブ・チェッツ", "手ありがとうございますのですが、要。要ラブ・チェンジーの"]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [452, 98, 1047, 152], "vertical": false, "font_size": 54, "lines_coords": [[[452.0, 98.0], [1047.0, 98.0], [1047.0, 152.0], [452.0, 152.0]]], "lines": ["がんばれチェンツーマン"]}, {"box": [714, 295, 820, 428], "vertical": true, "font_size": 56, "lines_coords": [[[756.0, 295.0], [820.0, 295.0], [820.0, 396.0], [756.0, 396.0]], [[714.0, 297.0], [763.0, 297.0], [763.0, 428.0], [714.0, 428.0]]], "lines": ["たん", "たたん"]}, {"box": [72, 281, 140, 494], "vertical": true, "font_size": 68, "lines_coords": [[[72.0, 281.0], [140.0, 281.0], [140.0, 494.0], [72.0, 494.0]]], "lines": ["らん！"]}, {"box": [726, 630, 829, 761], "vertical": true, "font_size": 54, "lines_coords": [[[773.0, 630.0], [829.0, 630.0], [829.0, 726.0], [773.0, 726.0]], [[726.0, 630.0], [778.0, 630.0], [778.0, 761.0], [726.0, 761.0]]], "lines": ["たん", "たたん"]}, {"box": [749, 991, 935, 1205], "vertical": true, "font_size": 54, "lines_coords": [[[883.0, 1000.0], [932.0, 1000.0], [932.0, 1204.0], [883.0, 1204.0]], [[817.0, 998.0], [869.0, 998.0], [869.0, 1155.0], [817.0, 1155.0]], [[749.0, 991.0], [810.0, 991.0], [810.0, 1108.0], [749.0, 1108.0]]], "lines": ["だららら", "ららら", "らら"]}, {"box": [728, 2013, 888, 2186], "vertical": true, "font_size": 56, "lines_coords": [[[822.0, 2013.0], [888.0, 2013.0], [888.0, 2111.0], [822.0, 2111.0]], [[782.0, 2015.0], [831.0, 2015.0], [827.0, 2186.0], [778.0, 2186.0]], [[728.0, 2015.0], [782.0, 2015.0], [782.0, 2107.0], [728.0, 2107.0]]], "lines": ["パー", "フェクト", "．．．！"]}], "img_path": "00007.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [189, 867, 365, 1075], "vertical": true, "font_size": 41, "lines_coords": [[[302.0, 867.0], [344.0, 867.0], [344.0, 1033.0], [302.0, 1033.0]], [[2