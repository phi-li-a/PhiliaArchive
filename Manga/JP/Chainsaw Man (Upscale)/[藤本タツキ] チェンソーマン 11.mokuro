, 989.0], [224.0, 1034.0]], [[213.0, 1029.0], [500.0, 982.0], [507.0, 1038.0], [220.0, 1085.0]]], "lines": ["家で購入できる！！", "定期購読なら、買い出しなく", "いつでもどこでも", "いつでもここでもジャンプが読める！"]}, {"box": [814, 675, 1366, 973], "vertical": false, "font_size": 53, "lines_coords": [[[899.0, 741.0], [1112.0, 708.0], [1119.0, 764.0], [906.0, 797.0]], [[892.0, 790.0], [1339.0, 710.0], [1348.0, 774.0], [902.0, 853.0]], [[850.0, 872.0], [1062.0, 837.0], [1070.0, 884.0], [857.0, 919.0]], [[846.0, 912.0], [1248.0, 849.0], [1255.0, 905.0], [853.0, 968.0]]], "lines": ["カラーだっ", "特別開切パスクが読める！", "ジャンプ作品の", "シャンプ作品のカラー版マンガが楽しめる"]}, {"box": [899, 979, 1321, 1106], "vertical": false, "font_size": 57, "lines_coords": [[[899.0, 1050.0], [1312.0, 979.0], [1321.0, 1035.0], [909.0, 1106.0]]], "lines": ["応募者全員サービスに"]}, {"box": [190, 1119, 700, 1346], "vertical": false, "font_size": 49, "lines_coords": [[[269.0, 1158.0], [495.0, 1123.0], [502.0, 1181.0], [276.0, 1217.0]], [[215.0, 1247.0], [673.0, 1165.0], [680.0, 1214.0], [222.0, 1296.0]], [[213.0, 1294.0], [598.0, 1228.0], [603.0, 1275.0], [217.0, 1341.0]]], "lines": ["お得な価格！", "定期開読なら、月額４３５０円で１０万で", "定期開かることが悪い毎週ジャンプが楽しめる！！"]}, {"box": [181, 1376, 597, 1656], "vertical": false, "font_size": 49, "lines_coords": [[[264.0, 1416.0], [493.0, 1383.0], [500.0, 1446.0], [271.0, 1479.0]], [[222.0, 1505.0], [573.0, 1444.0], [577.0, 1491.0], [227.0, 1552.0]], [[215.0, 1554.0], [439.0, 1514.0], [446.0, 1563.0], [222.0, 1603.0]], [[213.0, 1599.0], [434.0, 1559.0], [441.0, 1608.0], [220.0, 1648.0]]], "lines": ["最速で配信／", "定期購読なら、発売日に", "最初号が配信／", "１５７１３００万最速で読める！"]}, {"box": [799, 1058, 1291, 1415], "vertical": false, "font_size": 46, "lines_coords": [[[890.0, 1095.0], [1121.0, 1055.0], [1130.0, 1123.0], [899.0, 1163.0]], [[853.0, 1184.0], [1201.0, 1125.0], [1205.0, 1172.0], [857.0, 1231.0]], [[848.0, 1231.0], [1219.0, 1167.0], [1227.0, 1217.0], [855.0, 1280.0]], [[848.0, 1282.0], [1212.0, 1214.0], [1219.0, 1261.0], [855.0, 1329.0]], [[848.0, 1331.0], [1203.0, 1268.0], [1210.0, 1308.0], [855.0, 1371.0]], [[841.0, 1376.0], [1250.0, 1301.0], [1257.0, 1341.0], [848.0, 1416.0]]], "lines": ["応募できる！", "紙版ジャンプと同様に、", "施術後、ここでしか手に入らない", "一瞬定オリジナルグッズに", "申し込むことができる！", "☆紙版破定での企画の場合もございます。"]}, {"box": [850, 1420, 1349, 1797], "vertical": false, "font_size": 47.5, "lines_coords": [[[906.0, 1488.0], [1342.0, 1420.0], [1349.0, 1469.0], [913.0, 1537.0]], [[892.0, 1539.0], [1195.0, 1488.0], [1204.0, 1539.0], [902.0, 1591.0]], [[895.0, 1591.0], [1028.0, 1567.0], [1038.0, 1619.0], [904.0, 1642.0]], [[850.0, 1668.0], [1239.0, 1598.0], [1249.0, 1647.0], [860.0, 1717.0]], [[853.0, 1715.0], [1085.0, 1675.0], [1092.0, 1715.0], [860.0, 1755.0]], [[853.0, 1757.0], [1220.0, 1694.0], [1228.0, 1734.0], [860.0, 1797.0]]], "lines": ["デジタル版定期購読者限定", "スレゼント企画も", "実施中", "毎月更新「ジャンプ作品のＷｉ－Ｆｉ－", "激しアグッズが、", "応募すると被害で当たる！"]}, {"box": [172, 1650, 714, 1952], "vertical": false, "font_size": 49, "lines_coords": [[[257.0, 1723.0], [704.0, 1646.0], [713.0, 1709.0], [267.0, 1786.0]], [[222.0, 1805.0], [455.0, 1767.0], [463.0, 1817.0], [229.0, 1854.0]], [[220.0, 1856.0], [545.0, 1800.0], [552.0, 1847.0], [227.0, 1903.0]], [[213.0, 1906.0], [561.0, 1845.0], [568.0, 1889.0], [220.0, 1950.0]]], "lines": ["ジャンプ６ＣＡも読める！", "特別編集増刊の", "・やがたまた少年ジャンプＧＵＧＡも", "追加料金なしで読める！"]}, {"box": [503, 1980, 712, 2343], "vertical": true, "font_size": 105, "lines_coords": [[[621.0, 2006.0], [712.0, 2008.0], [700.0, 2339.0], [609.0, 2336.0]], [[510.0, 1980.0], [628.0, 1982.0], [621.0, 2343.0], [503.0, 2341.0]]], "lines": ["始めよう", "定期購読"]}, {"box": [939, 1804, 1352, 1959], "vertical": false, "font_size": 54.5, "lines_coords": [[[939.0, 1867.0], [1345.0, 1804.0], [1352.0, 1853.0], [946.0, 1917.0]], [[988.0, 1900.0], [1310.0, 1856.0], [1319.0, 1914.0], [996.0, 1959.0]]], "lines": ["デジタル版定期購読者限定", "者全員サニビス企画"]}, {"box": [820, 1942, 1349, 2207], "vertical": false, "font_size": 49, "lines_coords": [[[850.0, 2058.0], [1152.0, 2004.0], [1159.0, 2051.0], [857.0, 2105.0]], [[843.0, 2098.0], [1285.0, 2023.0], [1294.0, 2084.0], [853.0, 2159.0]], [[846.0, 2156.0], [1198.0, 2096.0], [1205.0, 2142.0], [853.0, 2203.0]]], "lines": ["デジタル版のみでの、", "テンプルなので、限定オリジナルグッズ企画もあります。", "実施中「要チェックだ！"]}, {"box": [794, 2221, 1373, 2377], "vertical": false, "font_size": 51, "lines_coords": [[[803.0, 2257.0], [985.0, 2234.0], [992.0, 2283.0], [810.0, 2306.0]], [[1162.0, 2246.0], [1358.0, 2222.0], [1365.0, 2281.0], [1169.0, 2304.0]]], "lines": ["そのほか、", "っだくさん！！"]}], "img_path": "00194.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [76, 154, 492, 322], "vertical": false, "font_size": 45, "lines_coords": [[[89.0, 161.0], [316.0, 154.0], [318.0, 203.0], [91.0, 210.0]], [[79.0, 215.0], [492.0, 215.0], [492.0, 262.0], [79.0, 262.0]], [[222.0, 278.0], [346.0, 278.0], [346.0, 318.0], [222.0, 318.0]]], "lines": ["少年、一にて", "あっ．．．結局、三人間", "配信"]}, {"box": [58, 96, 749, 119], "vertical": false, "font_size": 23, "lines_coords": [[[58.0, 96.0], [749.0, 96.0], [749.0, 119.0], [58.0, 119.0]]], "lines": ["Ｘ：掲載している情報は、２０２０年１２月現在のものとなります。"]}, {"box": [521, 187, 761, 293], "vertical": false, "font_size": 46, "lines_coords": [[[524.0, 185.0], [749.0, 192.0], [749.0, 243.0], [524.0, 236.0]], [[527.0, 239.0], [754.0, 239.0], [754.0, 289.0], [527.0, 289.0]]], "lines": ["定期購読者", "限定特典も！"]}, {"box": [449, 365, 1476, 595], "vertical": false, "font_size": 106, "lines_coords": [[[1148.0, 380.0], [1295.0, 373.0], [1298.0, 433.0], [1150.0, 440.0]], [[510.0, 358.0], [1476.0, 356.0], [1476.0, 512.0], [510.0, 515.0]], [[478.0, 394.0], [560.0, 394.0], [560.0, 501.0], [478.0, 501.0]], [[449.0, 455.0], [1469.0, 466.0], [1469.0, 604.0], [449.0, 592.0]]], "lines": ["．．．", "テシタル版を超ド銀の物語。", "デュー", "アンタリアを超ド級の物語を一逃すな！"]}, {"box": [843, 65, 1475, 331], "vertical": false, "font_size": 94, "lines_coords": [[[853.0, 57.0], [1420.0, 57.0], [1420.0, 136.0], [853.0, 136.0]], [[998.0, 116.0], [1204.0, 104.0], [1211.0, 228.0], [1005.0, 240.0]]], "lines": ["いつの時代も、何度は", "．．．"]}, {"box": [107, 337, 449, 1270],