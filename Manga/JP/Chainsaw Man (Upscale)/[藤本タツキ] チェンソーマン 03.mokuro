{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 03", "volume_uuid": "56067c95-77ad-49fb-a4b5-38ef15552a0a", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [154, 96, 571, 426], "vertical": false, "font_size": 303, "lines_coords": [[[175.0, 96.0], [571.0, 124.0], [550.0, 426.0], [154.0, 398.0]]], "lines": ["．．．"]}, {"box": [39, 731, 621, 996], "vertical": false, "font_size": 132, "lines_coords": [[[109.0, 719.0], [621.0, 768.0], [602.0, 983.0], [90.0, 934.0]], [[48.0, 934.0], [407.0, 934.0], [407.0, 1004.0], [48.0, 1004.0]]], "lines": ["．．．", "そんなことのようになるので、"]}, {"box": [114, 1382, 461, 2135], "vertical": false, "font_size": 87, "lines_coords": [[[121.0, 2081.0], [379.0, 1382.0], [461.0, 1413.0], [203.0, 2111.0]]], "lines": ["ひんっ、んもしかして、"]}, {"box": [1061, 1204, 1523, 2259], "vertical": true, "font_size": 438, "lines_coords": [[[1061.0, 1214.0], [1499.0, 1204.0], [1523.0, 2250.0], [1085.0, 2259.0]]], "lines": ["．．．"]}, {"box": [51, 2261, 470, 2350], "vertical": false, "font_size": 88, "lines_coords": [[[58.0, 2253.0], [468.0, 2253.0], [468.0, 2349.0], [58.0, 2349.0]]], "lines": ["ＪＵＭＰ．ＣＯＭＩＣＳ"]}, {"box": [1197, 2264, 1483, 2337], "vertical": false, "font_size": 66, "lines_coords": [[[1197.0, 2264.0], [1467.0, 2268.0], [1467.0, 2334.0], [1197.0, 2329.0]]], "lines": ["データときに"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [131, 2167, 1394, 2271], "vertical": false, "font_size": 40.0, "lines_coords": [[[131.0, 2167.0], [1394.0, 2167.0], [1394.0, 2207.0], [131.0, 2207.0]], [[131.0, 2231.0], [1389.0, 2231.0], [1389.0, 2271.0], [131.0, 2271.0]]], "lines": ["★この作品はフィクションです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [41, 39, 586, 127], "vertical": false, "font_size": 80, "lines_coords": [[[58.0, 32.0], [569.0, 39.0], [569.0, 126.0], [58.0, 119.0]]], "lines": ["ＪＵＭＰ．ＣＯＭＩＣＳ《"]}, {"box": [623, 2088, 857, 2137], "vertical": false, "font_size": 49, "lines_coords": [[[623.0, 2088.0], [857.0, 2088.0], [857.0, 2137.0], [623.0, 2137.0]]], "lines": ["【デンジを殺せ】"]}, {"box": [543, 2163, 935, 2292], "vertical": false, "font_size": 120, "lines_coords": [[[543.0, 2172.0], [932.0, 2163.0], [935.0, 2282.0], [546.0, 2292.0]]], "lines": ["藤本ダツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [703, 119, 1415, 194], "vertical": false, "font_size": 70, "lines_coords": [[[703.0, 119.0], [1415.0, 124.0], [1415.0, 194.0], [703.0, 189.0]]], "lines": ["ＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [119, 375, 302, 457], "vertical": false, "font_size": 78, "lines_coords": [[[119.0, 379.0], [299.0, 375.0], [302.0, 452.0], [121.0, 457.0]]], "lines": ["デンジ"]}, {"box": [119, 508, 743, 701], "vertical": false, "font_size": 55, "lines_coords": [[[166.0, 517.0], [742.0, 517.0], [742.0, 588.0], [166.0, 588.0]], [[147.0, 508.0], [201.0, 520.0], [182.0, 597.0], [128.0, 585.0]], [[119.0, 595.0], [700.0, 595.0], [700.0, 635.0], [119.0, 635.0]], [[128.0, 660.0], [642.0, 660.0], [642.0, 693.0], [128.0, 693.0]]], "lines": ["森のポチタをその身に宿す、『チェンソー", "はっはっ", "の悪魔』の少年。自分の欲望に正直。", "めて人並扱いしてくわたマキマが好き"]}, {"box": [1226, 2003, 1416, 2087], "vertical": false, "font_size": 77, "lines_coords": [[[1230.0, 2008.0], [1413.0, 2008.0], [1413.0, 2085.0], [1230.0, 2085.0]]], "lines": ["ポチタ"]}, {"box": [864, 2127, 1419, 2270], "vertical": false, "font_size": 58, "lines_coords": [[[1103.0, 2144.0], [1413.0, 2151.0], [1413.0, 2214.0], [1103.0, 2207.0]], [[864.0, 2210.0], [1415.0, 2214.0], [1415.0, 2268.0], [864.0, 2264.0]]], "lines": ["『チェンソーの悪魔』。", "デンジに心臓を与え、体の一部となる。"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1198, 227, 1416, 447], "vertical": false, "font_size": 33, "lines_coords": [[[1218.0, 248.0], [1401.0, 248.0], [1401.0, 281.0], [1218.0, 281.0]], [[1204.0, 295.0], [1403.0, 300.0], [1403.0, 342.0], [1204.0, 337.0]], [[1202.0, 353.0], [1396.0, 356.0], [1396.0, 389.0], [1202.0, 386.0]], [[1206.0, 417.0], [1406.0, 417.0], [1406.0, 440.0], [1206.0, 440.0]]], "lines": ["アキマの忠実な部", "下。テンジの３", "年先輩で、お目", "すみにみ命される"]}, {"box": [808, 110, 1052, 210], "vertical": false, "font_size": 53.5, "lines_coords": [[[827.0, 110.0], [862.0, 110.0], [862.0, 140.0], [827.0, 140.0]], [[808.0, 133.0], [1047.0, 117.0], [1052.0, 194.0], [813.0, 210.0]]], "lines": ["はや", "早川アキ"]}, {"box": [642, 288, 719, 450], "vertical": true, "font_size": 87, "lines_coords": [[[686.0, 288.0], [719.0, 288.0], [719.0, 442.0], [686.0, 442.0]], [[642.0, 419.0], [679.0, 400.0], [693.0, 433.0], [653.0, 450.0]]], "lines": ["ミぴ女ヵ嗅", "は"]}, {"box": [508, 222, 567, 344], "vertical": true, "font_size": 87, "lines_coords": [[[527.0, 222.0], [562.0, 222.0], [567.0, 344.0], [531.0, 344.0]], [[508.0, 225.0], [541.0, 225.0], [541.0, 342.0], [508.0, 342.0]]], "lines": ["お安く取り", "少しを"]}, {"box": [496, 339, 703, 508], "vertical": true, "font_size": 87, "lines_coords": [[[524.0, 398.0], [663.0, 393.0], [665.0, 447.0], [527.0, 452.0]], [[496.0, 344.0], [700.0, 339.0], [703.0, 419.0], [499.0, 424.0]], [[503.0, 431.0], [630.0, 435.0], [628.0, 508.0], [501.0, 503.0]]], "lines": ["馬鹿の匂い", "ステリアスなど", "ぎ分ける。"]}, {"box": [154, 145, 285, 196], "vertical": false, "font_size": 51, "lines_coords": [[[154.0, 145.0], [285.0, 145.0], [285.0, 196.0], [154.0, 196.0]]], "lines": ["マキマ"]}, {"box": [1200, 752, 1415, 971], "vertical": false, "font_size": 33, "lines_coords": [[[1206.0, 825.0], [1399.0, 825.0], [1399.0, 864.0], [1206.0, 864.0]], [[1206.0, 881.0], [1394.0, 881.0], [1394.0, 914.0], [1206.0, 914.0]], [[1209.0, 939.0], [1373.0, 939.0], [1373.0, 965.0], [1209.0, 965.0]]], "lines": ["自分勝手で暴走し", "がち。猫のニャー", "口が唯一の友達"]}, {"box": [468, 714, 735, 1014], "vertical": false, "font_size": 158, "lines_coords": [[[478.0, 714.0], [674.0, 726.0], [665.0, 902.0], [468.0, 890.0]], [[468.0, 853.0], [719.0, 827.0], [735.0, 989.0], [485.0, 1014.0]], [[689.0, 775.0], [721.0, 778.0], [714.0, 914.0], [681.0, 911.0]]], "lines": ["後輩の早川とディを組んでナスト障害", "オイを悩んで行動する。「憎霊の表魔」と契約。", "ハ○動火悪"]}, {"box": [1148, 1239, 1460, 1554], "vertical": true, "font_size": 96, "lines_coords": [[[1378.0, 1279.0], [1403.0, 1279.0], [1403.0, 1410.0], [1378.0, 1410.0]], [[1265.0, 1291.0], [1298.0, 1286.0], [1314.0, 1392.0], [1281.0, 1396.0]], [[1195.0, 1279.0], [1228.0, 1279.0], [1235.0, 1462.0], [1202.0, 1462.0]], [[1148.0, 1239.0], [1460.0, 1239.0], [1460.0, 1551.0], [1148.0, 1551.0]], [[1206.0, 1518.0], [1284.0, 1518.0], [1284.0, 1544.0], [1206.0, 1544.0]]], "lines": ["新い", "みぃ神", "３１人が、", "もっ私の思春何番人、野郎のお願いで、上司の気持ちをわかる。という", "ている"]}, {"box": [867, 1195, 979, 1246], "vertical": false, "font_size": 51, "lines_coords": [[[867.0, 1195.0], [979.0, 1195.0], [979.0, 1246.0], [867.0, 1246.0]]], "lines": ["Ｉべニ"]}, {"box": [424, 1230, 721, 1499], "vertical": false, "font_size": 66, "lines_coords": [[[670.0, 1270.0], [721.0, 1310.0], [689.0, 1352.0], [637.0, 1312.0]], [[606.0, 1284.0], [642.0, 1286.0], [637.0, 1361.0], [602.0, 1359.0]], [[660.0, 1350.0], [710.0, 1350.0], [710.0, 1394.0], [660.0, 1394.0]], [[508.0, 1230.0], [696.0, 1359.0], [611.0, 1485.0], [424.0, 1357.0]], [[513.0, 1401.0], [714.0, 1401.0], [714.0, 1441.0], [513.0, 1441.0]], [[510.0, 1441.0], [539.0, 1441.0], [539.0, 1492.0], [510.0, 1492.0]]], "lines": ["それは", "熱い", "テン", "残念なのかな？", "ジとパワーに不信", "見"]}, {"box": [128, 1153, 237, 1260], "vertical": true, "font_size": 48, "lines_coords": [[[185.0, 1153.0], [236.0, 1153.0], [236.0, 1258.0], [185.0, 1258.0]], [[128.0, 1155.0], [173.0, 1155.0], [173.0, 1253.0], [128.0, 1253.0]]], "lines": ["井", "芒ル"]}, {"box": [140, 1753, 445, 1816], "vertical": false, "font_size": 56, "lines_coords": [[[140.0, 1760.0], [445.0, 1753.0], [445.0, 1809.0], [140.0, 1816.0]]], "lines": ["ＳＴＯＲＹ＿"]}, {"box": [810, 1858, 1411, 2269], "vertical": false, "font_size": 40, "lines_coords": [[[916.0, 1876.0], [1399.0, 1876.0], [1399.0, 1913.0], [916.0, 1913.0]], [[813.0, 1918.0], [1403.0, 1918.0], [1403.0, 1964.0], [813.0, 1964.0]], [[815.0, 1972.0], [1401.0, 1972.0], [1401.0, 2018.0], [815.0, 2018.0]], [[817.0, 2026.0], [1406.0, 2026.0], [1406.0, 2065.0], [817.0, 2065.0]], [[810.0, 2073.0], [1399.0, 2071.0], [1399.0, 2117.0], [810.0, 2119.0]], [[817.0, 2125.0], [1401.0, 2125.0], [1401.0, 2170.0], [817.0, 2170.0]], [[817.0, 2176.0], [1403.0, 2179.0], [1403.0, 2220.0], [817.0, 2217.0]], [[817.0, 2225.0], [1335.0, 2225.0], [1335.0, 2271.0], [817.0, 2271.0]]], "lines": ["芝生氏のランジはマキマから、「方不明爆発の", "「悪魔・悪魔の悪魔」について聞かされる。「「銃の悪魔」を殺した", "ら何でも１つ願いを叶えてあげる！！と言われ、一転やる気十分", "のデンジ！！そんな中１旅の最新！の内片を食べた悪魔が現れる。", "特異４．妻メンバーと現場へ向かったデータハンジは、姫野と「悪魔を", "倒したらパロ入りキスしの射束をする！！だが、悪魔の能力でホテルの", "ルの８階に閉じ込められてしまう。種根状況下で消耗する面々に、", "素敵なデジタを動かせなければ報告することができませんが、"]}, {"box": [131, 1872, 726, 1966], "vertical": false, "font_size": 45.0, "lines_coords": [[[157.0, 1872.0], [726.0, 1872.0], [726.0, 1912.0], [157.0, 1912.0]], [[131.0, 1917.0], [724.0, 1914.0], [724.0, 1964.0], [131.0, 1966.0]]], "lines": ["「悪魔のボチタと共にデビルハンターとして暮らす少年・テンジ。", "２０１７年１２／１４／１９（水）オークス製品の大丈夫ですから１０万円以上ではございませんでしていました。"]}, {"box": [135, 1980, 717, 2163], "vertical": false, "font_size": 30.5, "lines_coords": [[[135.0, 1980.0], [717.0, 1980.0], [717.0, 2010.0], [135.0, 2010.0]], [[140.0, 2029.0], [712.0, 2029.0], [712.0, 2062.0], [140.0, 2062.0]], [[135.0, 2081.0], [714.0, 2078.0], [714.0, 2111.0], [135.0, 2114.0]], [[142.0, 2137.0], [257.0, 2137.0], [257.0, 2163.0], [142.0, 2163.0]]], "lines": ["を、裏切りに合い残されてしまう。たが、ボチタがその命と引", "き換えにデンジを【チェンツこの悪魔」として蘇らせる！敵を", "皆殺しにしたデンジは、マキマに拾われ公安のデビルハンターと", "なるのだった。"]}, {"box": [138, 2177, 768, 2266], "vertical": false, "font_size": 36.5, "lines_coords": [[[159.0, 2177.0], [721.0, 2177.0], [721.0, 2217.0], [159.0, 2217.0]], [[138.0, 2233.0], [768.0, 2233.0], [768.0, 2266.0], [138.0, 2266.0]]], "lines": ["「コウモリの悪魔」を倒しパワーそれ出したデンジは、約束通", "り胸を揉ませてもらうことに！！だが、初揉みの愚痴は薄く、激しく"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [621, 1457, 998, 1497], "vertical": false, "font_size": 40, "lines_coords": [[[621.0, 1457.0], [998.0, 1457.0], [998.0, 1497.0], [621.0, 1497.0]]], "lines": ["ＣＯＮＴＥＮＴＳ"]}, {"box": [456, 1221, 1413, 2294], "vertical": false, "font_size": 251, "lines_coords": [[[458.0, 1569.0], [1105.0, 1199.0], [1337.0, 1649.0], [691.0, 2020.0]], [[1164.0, 1599.0], [1194.0, 1599.0], [1194.0, 1710.0], [1164.0, 1710.0]], [[681.0, 1541.0], [716.0, 1541.0], [716.0, 1968.0], [681.0, 1968.0]], [[925.0, 1717.0], [1046.0, 1660.0], [1084.0, 1788.0], [962.0, 1844.0]], [[808.0, 1628.0], [835.0, 1628.0], [838.0, 1959.0], [810.0, 1959.0]], [[908.0, 1717.0], [936.0, 1717.0], [936.0, 1856.0], [908.0, 1856.0]], [[730.0, 1817.0], [749.0, 1817.0], [749.0, 1961.0], [730.0, 1961.0]], [[634.0, 1522.0], [662.0, 1522.0], [664.0, 2306.0], [637.0, 2306.0]], [[773.0, 1592.0], [798.0, 1592.0], [800.0, 2219.0], [775.0, 2219.0]], [[740.0, 1475.0], [1285.0, 1468.0], [1295.0, 2308.0], [749.0, 2315.0]], [[915.0, 1942.0], [929.0, 1942.0], [929.0, 2017.0], [915.0, 2017.0]], [[894.0, 1967.0], [1323.0, 1965.0], [1323.0, 2050.0], [894.0, 2053.0]], [[723.0, 1918.0], [751.0, 1918.0], [751.0, 2221.0], [723.0, 2221.0]], [[683.0, 1939.0], [711.0, 1939.0], [714.0, 2224.0], [686.0, 2224.0]], [[1312.0, 1970.0], [1398.0, 1965.0], [1400.0, 2041.0], [1314.0, 2046.0]], [[904.0, 2000.0], [934.0, 2000.0], [934.0, 2135.0], [904.0, 2135.0]], [[951.0, 2061.0], [1023.0, 2061.0], [1023.0, 2128.0], [951.0, 2128.0]], [[878.0, 2148.0], [1030.0, 2148.0], [1030.0, 2214.0], [878.0, 2214.0]], [[683.0, 2223.0], [1410.0, 2223.0], [1410.0, 2306.0], [683.0, 2306.0]]], "lines": ["そのため、これからもう少しでもないかもしれませんが、それではないのでしょうか", "せっかい小此原の！？", "あったかなぁ．．．", "チェンソー１９３ノーバル賞．．．！？", "それじゃないんだろうかなぁ．．．！！", "チェンゾ・ノーベル飲みキスのお", "なーかそのお兄さんもこういうことは", "いいのか．．．", "いや．．．はいはい", "．．．", "キスのおチュッパ統売", "キスのお嬢。«．．．チュッパチャブスコーラ様．．！！？", "ああ、そうだね．．．", "それは．．．なんですか？", "一ラ味．．．", "そんなチコツの説明書いて", "チュッパチャプ飲声．．．２ッ吸いは！？", "もー、教育．．．？もし呪いじゃないけど、ゴースト・ヘビ", "はっとまず「暑い」の手足である。ゴーストールにチェンソール"]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [801, 9, 1434, 192], "vertical": false, "font_size": 120.5, "lines_coords": [[[801.0, 9.0], [1434.0, 9.0], [1434.0, 192.0], [801.0, 192.0]], [[1375.0, 89.0], [1431.0, 89.0], [1431.0, 147.0], [1375.0, 147.0]]], "lines": ["第１７話」デンジを殺せ", "殺せ"]}, {"box": [515, 100, 691, 466], "vertical": true, "font_size": 88, "lines_coords": [[[592.0, 103.0], [684.0, 100.0], [691.0, 464.0], [599.0, 466.0]], [[515.0, 110.0], [599.0, 110.0], [599.0, 328.0], [515.0, 328.0]]], "lines": ["きゃエエエ", "エエ！！"]}, {"box": [153, 1631, 349, 1816], "vertical": true, "font_size": 110, "lines_coords": [[[210.0, 1631.0], [349.0, 1631.0], [349.0, 1816.0], [210.0, 1816.0]], [[159.0, 1706.0], [239.0, 1706.0], [239.0, 1807.0], [159.0, 1807.0]]], "lines": ["げへ", "ッ"]}, {"box": [1085, 1753, 1146, 1921], "vertical": true, "font_size": 61, "lines_coords": [[[1085.0, 1753.0], [1146.0, 1753.0], [1146.0, 1921.0], [1085.0, 1921.0]]], "lines": ["ふん！"]}], "img_path": "00007.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [271, 67, 323, 173], "vertical": true, "font_size": 52, "lines_coords": [[[271.0, 67.0], [323.0, 67.0], [323.0, 173.0], [271.0, 173.0]]], "lines": ["うッ"]}, {"box": [909, 675, 981, 808], "vertical": true, "font_size": 72, "lines_coords": [[[909.0, 675.0], [981.0, 675.0], [981.0, 808.0], [909.0, 808.0]]], "lines": ["あは"]}, {"box": [667, 808, 738, 937], "vertical": true, "font_size": 71, "lines_coords": [[[667.0, 808.0], [738.0, 808.0], [738.0, 937.0], [667.0, 937.0]]], "lines": ["はは"]}, {"box": [164, 757, 289, 918], "vertical": true, "font_size": 61, "lines_coords": [[[236.0, 761.0], [288.0, 761.0], [288.0, 918.0], [236.0, 918.0]], [[164.0, 757.0], [234.0, 757.0], [234.0, 878.0], [164.0, 878.0]]], "lines": ["あはは", "はは"]}, {"box": [885, 1265,