{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 02", "volume_uuid": "23575380-2a8d-4216-8fc3-0e0af1c36e90", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [50, 1483, 455, 1675], "vertical": false, "font_size": 51, "lines_coords": [[[63.0, 1620.0], [431.0, 1624.0], [431.0, 1679.0], [63.0, 1675.0]]], "lines": ["Ｔｏｆｓｏｒｋは、エリナＩｎｏｒｅ"]}, {"box": [63, 1632, 439, 1678], "vertical": false, "font_size": 50, "lines_coords": [[[63.0, 1628.0], [439.0, 1628.0], [439.0, 1682.0], [63.0, 1682.0]]], "lines": ["Ｔｏｒｓｕｒｋｉｇｉｔｈｏｎｅの"]}, {"box": [54, 2261, 483, 2352], "vertical": false, "font_size": 63, "lines_coords": [[[269.0, 2273.0], [461.0, 2273.0], [461.0, 2341.0], [269.0, 2341.0]]], "lines": ["ＣＯＭＩＣＳ"]}, {"box": [1013, 2265, 1501, 2345], "vertical": false, "font_size": 53, "lines_coords": [[[1019.0, 2274.0], [1492.0, 2274.0], [1492.0, 2331.0], [1019.0, 2331.0]]], "lines": ["チェンソーＶＳコウモリ"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [131, 2167, 1394, 2271], "vertical": false, "font_size": 40.0, "lines_coords": [[[131.0, 2167.0], [1394.0, 2167.0], [1394.0, 2207.0], [131.0, 2207.0]], [[131.0, 2231.0], [1389.0, 2231.0], [1389.0, 2271.0], [131.0, 2271.0]]], "lines": ["★この作品はフィクションです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [54, 52, 600, 143], "vertical": false, "font_size": 80, "lines_coords": [[[79.0, 46.0], [583.0, 58.0], [581.0, 145.0], [77.0, 133.0]]], "lines": ["ＪＵＭＰＣＯＭＩＣＳで"]}, {"box": [304, 501, 337, 574], "vertical": true, "font_size": 28, "lines_coords": [[[309.0, 501.0], [337.0, 503.0], [332.0, 574.0], [304.0, 571.0]]], "lines": ["ドー"]}, {"box": [381, 482, 585, 707], "vertical": true, "font_size": 41.666666666666664, "lines_coords": [[[539.0, 522.0], [581.0, 522.0], [585.0, 703.0], [543.0, 703.0]], [[468.0, 520.0], [508.0, 520.0], [508.0, 707.0], [468.0, 707.0]], [[393.0, 482.0], [435.0, 485.0], [424.0, 705.0], [381.0, 703.0]]], "lines": ["アジプライ", "さば定食", "さんま開きを"]}, {"box": [674, 295, 775, 447], "vertical": true, "font_size": 34.0, "lines_coords": [[[740.0, 295.0], [775.0, 295.0], [775.0, 400.0], [740.0, 400.0]], [[674.0, 346.0], [707.0, 346.0], [707.0, 447.0], [674.0, 447.0]]], "lines": ["塩ラーメ", "メンズへの"]}, {"box": [865, 296, 900, 456], "vertical": true, "font_size": 35, "lines_coords": [[[865.0, 296.0], [900.0, 296.0], [900.0, 456.0], [865.0, 456.0]]], "lines": ["タンタンＫａｅ"]}, {"box": [921, 295, 947, 448], "vertical": true, "font_size": 25, "lines_coords": [[[921.0, 295.0], [946.0, 295.0], [946.0, 440.0], [921.0, 440.0]]], "lines": ["もゃしそば五百"]}, {"box": [972, 299, 1006, 449], "vertical": true, "font_size": 33, "lines_coords": [[[972.0, 300.0], [1005.0, 300.0], [1005.0, 447.0], [972.0, 447.0]]], "lines": ["話をはェェェ"]}, {"box": [1028, 302, 1068, 455], "vertical": true, "font_size": 33, "lines_coords": [[[1028.0, 304.0], [1061.0, 302.0], [1068.0, 450.0], [1035.0, 452.0]]], "lines": ["チャーハン玉君の"]}, {"box": [1160, 312, 1213, 455], "vertical": true, "font_size": 53, "lines_coords": [[[1160.0, 312.0], [1213.0, 312.0], [1213.0, 455.0], [1160.0, 455.0]]], "lines": ["かっ押しているんだよ"]}, {"box": [1194, 314, 1220, 452], "vertical": true, "font_size": 25, "lines_coords": [[[1195.0, 314.0], [1220.0, 314.0], [1220.0, 447.0], [1195.0, 447.0]]], "lines": ["かっ＃～～～"]}, {"box": [349, 1750, 738, 1931], "vertical": false, "font_size": 137, "lines_coords": [[[349.0, 1795.0], [721.0, 1750.0], [738.0, 1886.0], [365.0, 1931.0]]], "lines": ["チェンソ"]}, {"box": [557, 2090, 916, 2156], "vertical": false, "font_size": 66, "lines_coords": [[[557.0, 2090.0], [916.0, 2090.0], [916.0, 2156.0], [557.0, 2156.0]]], "lines": ["【チェンソーＶＳコウモリ】☆＊＊＊"]}, {"box": [592, 2165, 942, 2289], "vertical": false, "font_size": 117, "lines_coords": [[[592.0, 2172.0], [939.0, 2165.0], [942.0, 2282.0], [595.0, 2289.0]]], "lines": ["藤本タツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [705, 119, 1413, 194], "vertical": false, "font_size": 70, "lines_coords": [[[705.0, 119.0], [1413.0, 124.0], [1413.0, 194.0], [705.0, 189.0]]], "lines": ["ＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [124, 384, 299, 454], "vertical": false, "font_size": 70, "lines_coords": [[[124.0, 384.0], [299.0, 384.0], [299.0, 454.0], [124.0, 454.0]]], "lines": ["デンジ"]}, {"box": [110, 506, 747, 701], "vertical": false, "font_size": 54, "lines_coords": [[[110.0, 506.0], [747.0, 506.0], [747.0, 595.0], [110.0, 595.0]], [[121.0, 595.0], [700.0, 595.0], [700.0, 635.0], [121.0, 635.0]], [[131.0, 660.0], [642.0, 660.0], [642.0, 693.0], [131.0, 693.0]]], "lines": ["納庫のボチタをその身に廊下、「チェンノー", "の悪魔」の少年。自分の欲望に正直。", "めて人並扱いしてくわたマキマが好き"]}, {"box": [1226, 2003, 1415, 2087], "vertical": false, "font_size": 78, "lines_coords": [[[1230.0, 2003.0], [1413.0, 2008.0], [1410.0, 2085.0], [1228.0, 2081.0]]], "lines": ["ポチタ"]}, {"box": [864, 2127, 1420, 2271], "vertical": false, "font_size": 58, "lines_coords": [[[1103.0, 2146.0], [1413.0, 2153.0], [1413.0, 2212.0], [1103.0, 2205.0]], [[864.0, 2207.0], [1415.0, 2214.0], [1415.0, 2271.0], [864.0, 2264.0]]], "lines": ["『チェンソーの悪魔』。", "デンジに心臓を与え、体の一部となる。"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [154, 217, 252, 404], "vertical": true, "font_size": 38, "lines_coords": [[[201.0, 217.0], [243.0, 217.0], [243.0, 372.0], [201.0, 372.0]], [[154.0, 222.0], [187.0, 222.0], [187.0, 403.0], [154.0, 403.0]]], "lines": ["デンジ君", "みたいな人"]}, {"box": [355, 617, 503, 683], "vertical": false, "font_size": 52, "lines_coords": [[[360.0, 623.0], [492.0, 623.0], [492.0, 675.0], [360.0, 675.0]]], "lines": ["マキマ"]}, {"box": [128, 723, 731, 838], "vertical": false, "font_size": 32, "lines_coords": [[[142.0, 728.0], [302.0, 728.0], [302.0, 752.0], [142.0, 752.0]], [[128.0, 742.0], [731.0, 740.0], [731.0, 780.0], [128.0, 782.0]], [[133.0, 801.0], [421.0, 801.0], [421.0, 834.0], [133.0, 834.0]]], "lines": ["うあんたいなとくい、", "公安対億特異４課を取り仕切るミステリアスな女", "悪魔の匂いを嗅ぎ分ける。"]}, {"box": [991, 591, 1224, 685], "vertical": false, "font_size": 35, "lines_coords": [[[1054.0, 595.0], [1078.0, 595.0], [1078.0, 616.0], [1054.0, 616.0]], [[1000.0, 595.0], [1026.0, 595.0], [1026.0, 618.0], [1000.0, 618.0]], [[991.0, 616.0], [1220.0, 621.0], [1220.0, 682.0], [991.0, 677.0]]], "lines": ["かと", "はや", "早川アキ"]}, {"box": [813, 723, 1382, 837], "vertical": false, "font_size": 36, "lines_coords": [[[916.0, 726.0], [996.0, 726.0], [996.0, 750.0], [916.0, 750.0]], [[813.0, 735.0], [1359.0, 735.0], [1359.0, 785.0], [813.0, 785.0]], [[817.0, 796.0], [1021.0, 801.0], [1021.0, 836.0], [817.0, 832.0]]], "lines": ["そうじっ", "マキマの忠実な部下。テンジの３年先輩で、、", "対役に任命される。"]}, {"box": [245, 1387, 619, 1483], "vertical": false, "font_size": 37, "lines_coords": [[[513.0, 1399.0], [536.0, 1387.0], [546.0, 1408.0], [522.0, 1420.0]], [[253.0, 1425.0], [599.0, 1422.0], [599.0, 1474.0], [253.0, 1476.0]]], "lines": ["あて", "コウモリの悪魔"]}, {"box": [128, 1530, 719, 1638], "vertical": false, "font_size": 52.5, "lines_coords": [[[133.0, 1530.0], [719.0, 1530.0], [719.0, 1586.0], [133.0, 1586.0]], [[128.0, 1584.0], [396.0, 1589.0], [396.0, 1638.0], [128.0, 1633.0]]], "lines": ["人間が負担させられ、激快していた。人気をある", "人間に良かったなど卑劣な手段を使う。"]}, {"box": [140, 1753, 442, 1816], "vertical": false, "font_size": 56, "lines_coords": [[[140.0, 1760.0], [442.0, 1753.0], [442.0, 1809.0], [140.0, 1816.0]]], "lines": ["ＳＴＯＲＹ－"]}, {"box": [810, 1525, 1424, 1640], "vertical": false, "font_size": 55, "lines_coords": [[[822.0, 1530.0], [1408.0, 1530.0], [1408.0, 1584.0], [822.0, 1584.0]], [[810.0, 1584.0], [1113.0, 1584.0], [1113.0, 1640.0], [810.0, 1640.0]]], "lines": ["「血の悪魔」の魔人。自分勝手で暴走しがち", "猫のニャーコが唯一の友達"]}, {"box": [138, 2137, 314, 2163], "vertical": false, "font_size": 26, "lines_coords": [[[138.0, 2137.0], [314.0, 2137.0], [314.0, 2163.0], [138.0, 2163.0]]], "lines": ["ターとなるのだった。"]}, {"box": [154, 1877, 735, 1910], "vertical": false, "font_size": 33, "lines_coords": [[[154.0, 1877.0], [735.0, 1877.0], [735.0, 1910.0], [154.0, 1910.0]]], "lines": ["悪魔のボチタと共にデビルハンターとして暮らす少年・デンジ。"]}, {"box": [133, 1919, 719, 1966], "vertical": false, "font_size": 47, "lines_coords": [[[133.0, 1919.0], [719.0, 1919.0], [719.0, 1966.0], [133.0, 1966.0]]], "lines": ["お客様からございますので、お客さまのために支払われる商品のご連絡がお願いできましていましたのでご"]}, {"box": [131, 1980, 714, 2116], "vertical": false, "font_size": 35.333333333333336, "lines_coords": [[[133.0, 1980.0], [714.0, 1980.0], [714.0, 2013.0], [133.0, 2013.0]], [[131.0, 2027.0], [714.0, 2025.0], [714.0, 2064.0], [131.0, 2067.0]], [[131.0, 2078.0], [712.0, 2083.0], [712.0, 2116.0], [131.0, 2111.0]]], "lines": ["を、裏切りに合い残されてしまう。だが、ポチタがその命と", "引き換えにデンジを「チェンソ」」の悪魔」として蘇らせる！", "敵を皆殺しにしたデンジは、マキマに拾われ公安のデビルハン"]}, {"box": [135, 2172, 763, 2268], "vertical": false, "font_size": 43.5, "lines_coords": [[[152.0, 2172.0], [717.0, 2172.0], [717.0, 2219.0], [152.0, 2219.0]], [[135.0, 2228.0], [763.0, 2228.0], [763.0, 2268.0], [135.0, 2268.0]]], "lines": ["おまえが．．．お父さんはその頃で、早期休みに来たらなくなってき", "対立。悪魔を殺すことに強い信念を持たつ早川に対し、何もなかった"]}, {"box": [808, 1856, 1410, 2275], "vertical": false, "font_size": 37, "lines_coords": [[[808.0, 1872.0], [1410.0, 1867.0], [1410.0, 1920.0], [808.0, 1924.0]], [[813.0, 1921.0], [1408.0, 1921.0], [1408.0, 1967.0], [813.0, 1967.0]], [[817.0, 1977.0], [1399.0, 1977.0], [1399.0, 2016.0], [817.0, 2016.0]], [[815.0, 2026.0], [1396.0, 2026.0], [1396.0, 2072.0], [815.0, 2072.0]], [[820.0, 2078.0], [1401.0, 2078.0], [1401.0, 2117.0], [820.0, 2117.0]], [[820.0, 2129.0], [1399.0, 2129.0], [1399.0, 2168.0], [820.0, 2168.0]], [[1366.0, 2167.0], [1396.0, 2167.0], [1396.0, 2189.0], [1366.0, 2189.0]], [[820.0, 2181.0], [1399.0, 2181.0], [1399.0, 2220.0], [820.0, 2220.0]], [[820.0, 2230.0], [1387.0, 2230.0], [1387.0, 2269.0], [820.0, 2269.0]]], "lines": ["たデンジに生まれた新たな夢、こんなそれは「女の命を挟む」だった．．．", "そんな折、「血の悪魔」の滅人ではパワーとパティを組むことに。", "接若黒人なパワーに振り回されるが「大切な猫を悪魔から救い", "出してくれたら、胸を揉ませてもる！！と言われ、協力を即決！", "早速「コウモリの悪魔」が待つ現場へ向かうが、それはパワー", "と悪魔が結話した罠だった。デンジの血を飲み復活したコウモ", "といっ", "リの悪魔は、滅だけでなくパワー一さえも喰らってしまう。大切", "な術棒を失ったパワーの悲しみを思い、デンジが立ち向かう！"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [700, 1455, 1085, 1502], "vertical": false, "font_size": 47, "lines_coords": [[[700.0, 1455.0], [1085.0, 1455.0], [1085.0, 1502.0], [700.0, 1502.0]]], "lines": ["ＣＯＮＴＥＮＴＳ"]}, {"box": [688, 1507, 1464, 2294], "vertical": true, "font_size": 134, "lines_coords": [[[761.0, 1507.0], [1464.0, 1507.0], [1464.0, 1750.0], [761.0, 1750.0]], [[768.0, 1565.0], [801.0, 1565.0], [801.0, 1778.0], [768.0, 1778.0]], [[717.0, 1546.0], [747.0, 1546.0], [747.0, 2289.0], [717.0, 2289.0]], [[691.0, 1645.0], [707.0, 1645.0], [707.0, 1809.0], [691.0, 1809.0]], [[848.0, 1654.0], [895.0, 1654.0], [881.0, 2175.0], [834.0, 2175.0]], [[921.0, 1626.0], [960.0, 1628.0], [956.0, 1694.0], [916.0, 1692.0]], [[939.0, 1614.0], [1010.0, 1617.0], [988.0, 2137.0], [918.0, 2135.0]], [[970.0, 1654.0], [1078.0, 1626.0], [1094.0, 1689.0], [986.0, 1717.0]], [[984.0, 1739.0], [1017.0, 1739.0], [1019.0, 1952.0], [986.0, 1952.0]], [[1056.0, 1739.0], [1113.0, 1739.0], [1103.0, 2078.0], [1047.0, 2078.0]], [[1028.0, 1919.0], [1061.0, 1919.0], [1056.0, 2088.0], [1024.0, 2088.0]], [[991.0, 1942.0], [1017.0, 1942.0], [1017.0, 2083.0], [991.0, 2083.0]], [[890.0, 2039.0], [906.0, 2039.0], [906.0, 2085.0], [890.0, 2085.0]], [[965.0, 2083.0], [1178.0, 2083.0], [1178.0, 2116.0], [965.0, 2116.0]], [[853.0, 2167.0], [956.0, 2167.0], [956.0, 2200.0], [853.0, 2200.0]], [[944.0, 2151.0], [1202.0, 2158.0], [1202.0, 2207.0], [944.0, 2200.0]], [[771.0, 2247.0], [1256.0, 2247.0], [1256.0, 2287.0], [771.0, 2287.0]]], "lines": ["そういうわけじゃなくてもいいけどな。", "８９１", "患第『第二第一第一ふ第な第二第三第六第", "［［", "１．話．話。話、話し話を", "おお！！", "出コ妥揉銃エ", "！？", "ン．．．。お、", "．．．！ｏｅァｏｅ？京魔", "悪Ｌ", "この", "．．．", "エロキス．．．っ", "話ーーー", "エンドレスＧ情", "いや、いいんですよ．．．"]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [93, 236, 180, 417], "vertical": true, "font_size": 61, "lines_coords": [[[93.0, 239.0], [154.0, 236.0], [159.0, 414.0], [98.0, 417.0]]], "lines": ["悪魔！？"]}, {"box": [400, 2261, 599, 2303], "vertical": false, "font_size": 42, "lines_coords": [[[400.0, 2261.0], [599.0, 2261.0], [599.0, 2303.0], [400.0, 2303.0]]], "lines": ["チェンソ"]}], "img_path": "00007.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1312, 106, 1478, 475], "vertical": true, "font_size": 166, "lines_coords": [[[1312.0, 107.0], [1478.0, 107.0], [1478.0, 475.0], [1312.0, 475.0]]], "lines": ["アが！？"]}, {"box": [792, 963, 993, 1045], "vertical": false, "font_size": 78, "lines_coords": [[[792.0, 967.0], [991.0, 963.0], [993.0, 1040.0], [794.0, 1045.0]]], "lines": ["うあ！！"]}], "img_path": "00008.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1310, 178, 1359, 311], "vertical": true, "font_size": 49, "lines_coords": [[[1310.0, 178.0], [1359.0, 178.0], [1359.0, 311.0], [1310.0, 311.0]]], "lines": ["イテテ"]}, {"box": [105, 300, 203, 426], "vertical": true, "font_size": 52, "lines_coords": [[[149.0, 300.0], [203.0, 300.0], [203.0, 393.0], [149.0, 393.0]], [[105.0, 302.0], [154.0, 302.0], [154.0, 426.0], [105.0, 426.0]]], "lines": ["う．．．", "ううう"]}, {"box": [782, 942, 895, 1045], "vertical": true, "font_size": 65, "lines_coords": [[[829.0, 942.0], [895.0, 942.0], [895.0, 1045.0], [829.0, 1045.0]], [[782.0, 944.0], [846.0, 944.0], [846.0, 1045.0], [782.0, 1045.0]]], "lines": ["バカ", "が．．．"]}, {"box": [1003, 1192, 1115, 1342], "vertical": true, "font_size": 60, "lines_coords": [[[1054.0, 1192.0], [1115.0, 1192.0], [1115.0, 1340.0], [1054.0, 1340.0]], [[1003.0, 1195.0], [1061.0, 1195.0], [1061.0, 1342.0], [1003.0, 1342.0]]], "lines": ["あっ．．．", "あっ．．．"]}, {"box": [766, 1211, 883, 1394], "vertical": true, "font_size": 55, "lines_coords": [[[817.0, 