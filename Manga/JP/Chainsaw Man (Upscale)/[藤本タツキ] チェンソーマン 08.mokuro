, 1879.0], [1211.0, 1912.0], [323.0, 1912.0]]], "lines": ["この作品は、デジタル配信用に再編集を行うったものです"]}, {"box": [314, 1985, 1218, 2224], "vertical": false, "font_size": 34, "lines_coords": [[[314.0, 1985.0], [1218.0, 1985.0], [1218.0, 2017.0], [314.0, 2017.0]], [[316.0, 2036.0], [1211.0, 2036.0], [1211.0, 2069.0], [316.0, 2069.0]], [[318.0, 2083.0], [1213.0, 2083.0], [1213.0, 2123.0], [318.0, 2123.0]], [[318.0, 2139.0], [1209.0, 2139.0], [1209.0, 2172.0], [318.0, 2172.0]], [[321.0, 2191.0], [1148.0, 2191.0], [1148.0, 2224.0], [321.0, 2224.0]]], "lines": ["本作品の内容あるいはデー夕を、全部・一部にかかわらず、", "無断で複製、改竄、公衆送信（インターネット上への掲載", "を含む）することは、法律で禁じられていいます。また、個人", "的な使用を目的とする複製であっても、コピーガードなど", "の著作権保護技術を解除して行うことはできません。"]}], "img_path": "00196.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [4, 124, 238, 174], "vertical": false, "font_size": 36, "lines_coords": [[[18.0, 128.0], [222.0, 128.0], [222.0, 167.0], [18.0, 167.0]]], "lines": ["ＦＸＴＲＡ＿ＰＡＧＥＳ"]}, {"box": [40, 427, 147, 523], "vertical": false, "font_size": 105, "lines_coords": [[[40.0, 418.0], [147.0, 418.0], [147.0, 532.0], [40.0, 532.0]]], "lines": ["は"]}, {"box": [674, 466, 779, 996], "vertical": true, "font_size": 40, "lines_coords": [[[735.0, 468.0], [775.0, 468.0], [768.0, 989.0], [728.0, 989.0]], [[674.0, 466.0], [714.0, 466.0], [714.0, 815.0], [674.0, 815.0]]], "lines": ["・デュラーメンターコンス", "ＴａｒｓｕｋＦｒｕｉｍｏｔｏ"]}, {"box": [1033, 1181, 1272, 1276], "vertical": false, "font_size": 44, "lines_coords": [[[1066.0, 1181.0], [1253.0, 1181.0], [1253.0, 1246.0], [1066.0, 1246.0]], [[1035.0, 1251.0], [1270.0, 1251.0], [1270.0, 1275.0], [1035.0, 1275.0]]], "lines": ["藤本タツキ", "『ａｙｓｕｋｊＦｕｊｌｍｏｒｃ"]}, {"box": [1096, 1347, 1229, 1373], "vertical": false, "font_size": 26, "lines_coords": [[[1096.0, 1347.0], [1223.0, 1347.0], [1223.0, 1373.0], [1096.0, 1373.0]]], "lines": ["降霊大好きく"]}, {"box": [42, 1489, 137, 1528], "vertical": false, "font_size": 42, "lines_coords": [[[42.0, 1486.0], [137.0, 1486.0], [137.0, 1531.0], [42.0, 