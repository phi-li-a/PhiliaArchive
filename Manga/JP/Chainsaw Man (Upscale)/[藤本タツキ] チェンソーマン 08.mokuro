{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 08", "volume_uuid": "a73841a0-737b-4037-92fa-612e0cdab94d", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [379, 67, 707, 396], "vertical": false, "font_size": 232, "lines_coords": [[[379.0, 227.0], [548.0, 67.0], [707.0, 236.0], [539.0, 396.0]]], "lines": ["．．．"]}, {"box": [271, 1005, 1267, 1617], "vertical": false, "font_size": 438, "lines_coords": [[[358.0, 1005.0], [1267.0, 1188.0], [1181.0, 1617.0], [271.0, 1434.0]]], "lines": ["．．．"]}, {"box": [22, 2247, 504, 2365], "vertical": false, "font_size": 61, "lines_coords": [[[105.0, 2280.0], [468.0, 2280.0], [468.0, 2346.0], [105.0, 2346.0]]], "lines": ["ＵＭＰＣＯＭＩＣＳ"]}, {"box": [1142, 2272, 1519, 2341], "vertical": false, "font_size": 50, "lines_coords": [[[1150.0, 2275.0], [1502.0, 2280.0], [1502.0, 2329.0], [1150.0, 2325.0]]], "lines": ["ちょうめちょくちょ"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [131, 2167, 1394, 2271], "vertical": false, "font_size": 40.0, "lines_coords": [[[131.0, 2167.0], [1394.0, 2167.0], [1394.0, 2207.0], [131.0, 2207.0]], [[131.0, 2231.0], [1389.0, 2231.0], [1389.0, 2271.0], [131.0, 2271.0]]], "lines": ["★この作品はフィクションです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [42, 35, 591, 131], "vertical": false, "font_size": 90, "lines_coords": [[[58.0, 27.0], [588.0, 41.0], [585.0, 139.0], [56.0, 125.0]]], "lines": ["ＪＵＭＰ．ＣＯＭＩＥＳで、"]}, {"box": [332, 1762, 735, 1921], "vertical": false, "font_size": 134, "lines_coords": [[[332.0, 1788.0], [726.0, 1762.0], [735.0, 1896.0], [342.0, 1921.0]]], "lines": ["チェンソ"]}, {"box": [689, 1921, 806, 2069], "vertical": false, "font_size": 73.0, "lines_coords": [[[712.0, 1921.0], [806.0, 1947.0], [785.0, 2029.0], [689.0, 2003.0]], [[705.0, 2008.0], [780.0, 2008.0], [780.0, 2069.0], [705.0, 2069.0]]], "lines": ["【】", "８"]}, {"box": [574, 2095, 902, 2142], "vertical": false, "font_size": 47, "lines_coords": [[[574.0, 2095.0], [902.0, 2095.0], [902.0, 2142.0], [574.0, 2142.0]]], "lines": ["【ちょうめちゃくちゃ】"]}, {"box": [581, 2153, 949, 2296], "vertical": false, "font_size": 118, "lines_coords": [[[581.0, 2179.0], [939.0, 2153.0], [949.0, 2271.0], [590.0, 2296.0]]], "lines": ["藤本タツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [124, 382, 304, 459], "vertical": false, "font_size": 77, "lines_coords": [[[124.0, 382.0], [304.0, 382.0], [304.0, 459.0], [124.0, 459.0]]], "lines": ["デンジ"]}, {"box": [710, 124, 1417, 194], "vertical": false, "font_size": 70, "lines_coords": [[[710.0, 124.0], [1417.0, 124.0], [1417.0, 194.0], [710.0, 194.0]]], "lines": ["ＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [121, 514, 753, 705], "vertical": false, "font_size": 52, "lines_coords": [[[121.0, 525.0], [726.0, 525.0], [726.0, 587.0], [121.0, 587.0]], [[124.0, 588.0], [681.0, 586.0], [681.0, 643.0], [124.0, 646.0]], [[131.0, 654.0], [644.0, 654.0], [644.0, 702.0], [131.0, 702.0]]], "lines": ["秋華のボデタをその身に定す、「チェンソー", "の悪魔”の少女。自分の欲望に正直。", "めて人達扱いしてくれたマキマが好き。"]}, {"box": [134, 516, 747, 706], "vertical": false, "font_size": 190, "lines_coords": [[[134.0, 516.0], [747.0, 516.0], [747.0, 706.0], [134.0, 706.0]]], "lines": ["沖縄のボデタをその身に隠す、「チェンノー」が発表しの少年。自分の欲望に正直。あので人並びいしてくれたマキスが好き。"]}, {"box": [869, 1671, 1417, 1722], "vertical": false, "font_size": 46, "lines_coords": [[[869.0, 1671.0], [1417.0, 1675.0], [1417.0, 1722.0], [869.0, 1717.0]]], "lines": ["デンジに心臓を与え、体の一部となる。"]}, {"box": [1230, 1460, 1417, 1546], "vertical": false, "font_size": 86, "lines_coords": [[[1230.0, 1460.0], [1417.0, 1460.0], [1417.0, 1546.0], [1230.0, 1546.0]]], "lines": ["ポチタ"]}, {"box": [1113, 1612, 1410, 1661], "vertical": false, "font_size": 49, "lines_coords": [[[1113.0, 1612.0], [1410.0, 1612.0], [1410.0, 1661.0], [1113.0, 1661.0]]], "lines": ["『チェンソーの悪魔』。"]}, {"box": [154, 1835, 276, 1886], "vertical": false, "font_size": 51, "lines_coords": [[[154.0, 1835.0], [276.0, 1835.0], [276.0, 1886.0], [154.0, 1886.0]]], "lines": ["マキマ"]}, {"box": [487, 1915, 723, 2193], "vertical": false, "font_size": 91, "lines_coords": [[[510.0, 1931.0], [686.0, 1931.0], [686.0, 1982.0], [510.0, 1982.0]], [[503.0, 2025.0], [644.0, 2025.0], [644.0, 2167.0], [503.0, 2167.0]], [[487.0, 2032.0], [527.0, 2029.0], [539.0, 2186.0], [499.0, 2189.0]], [[614.0, 2041.0], [686.0, 2041.0], [686.0, 2097.0], [614.0, 2097.0]], [[548.0, 2095.0], [686.0, 2095.0], [686.0, 2144.0], [548.0, 2144.0]]], "lines": ["公安対属特異４", "スア匂いテ！魔”ス表", "スジ悪ぎぎ", "スな", "僕の匂いを"]}, {"box": [809, 1797, 1049, 1903], "vertical": false, "font_size": 65, "lines_coords": [[[813.0, 1828.0], [1040.0, 1828.0], [1040.0, 1893.0], [813.0, 1893.0]]], "lines": ["早川アキ"]}, {"box": [1191, 1919, 1401, 2195], "vertical": false, "font_size": 26, "lines_coords": [[[1197.0, 2158.0], [1363.0, 2160.0], [1363.0, 2186.0], [1197.0, 2184.0]]], "lines": ["と契約している"]}, {"box": [1103, 1837, 1572, 2306], "vertical": false, "font_size": 267, "lines_coords": [[[1103.0, 2114.0], [1385.0, 1837.0], [1572.0, 2027.0], [1288.0, 2306.0]]], "lines": ["．．．"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1202, 230, 1418, 450], "vertical": false, "font_size": 47, "lines_coords": [[[1209.0, 239.0], [1408.0, 234.0], [1408.0, 283.0], [1209.0, 288.0]], [[1211.0, 292.0], [1408.0, 292.0], [1408.0, 342.0], [1211.0, 342.0]], [[1209.0, 353.0], [1406.0, 353.0], [1406.0, 393.0], [1209.0, 393.0]], [[1206.0, 393.0], [1389.0, 400.0], [1387.0, 450.0], [1204.0, 442.0]]], "lines": ["『血の悪魔』の職人", "自分勝手で暴走し", "がち。猫のニャー", "コが唯一の友達。"]}, {"box": [562, 290, 735, 503], "vertical": true, "font_size": 82, "lines_coords": [[[611.0, 328.0], [735.0, 328.0], [735.0, 468.0], [611.0, 468.0]], [[609.0, 337.0], [646.0, 372.0], [611.0, 410.0], [574.0, 377.0]], [[562.0, 290.0], [597.0, 290.0], [597.0, 405.0], [562.0, 405.0]], [[578.0, 403.0], [623.0, 400.0], [628.0, 501.0], [583.0, 503.0]]], "lines": ["いい取られ特異４時", "いや", "歳を", "うッ！！"]}, {"box": [482, 222, 719, 520], "vertical": true, "font_size": 82, "lines_coords": [[[567.0, 246.0], [719.0, 241.0], [719.0, 281.0], [567.0, 285.0]], [[492.0, 222.0], [592.0, 227.0], [581.0, 520.0], [482.0, 515.0]]], "lines": ["敵意はないが", "敵に接続を人直。命をしまして．．．の"]}, {"box": [124, 106, 432, 213], "vertical": false, "font_size": 85, "lines_coords": [[[124.0, 128.0], [431.0, 128.0], [431.0, 213.0], [124.0, 213.0]]], "lines": ["天使の悪魔"]}, {"box": [1199, 747, 1380, 951], "vertical": true, "font_size": 84, "lines_coords": [[[1263.0, 792.0], [1380.0, 799.0], [1370.0, 951.0], [1253.0, 944.0]], [[1225.0, 747.0], [1265.0, 750.0], [1258.0, 928.0], [1218.0, 925.0]], [[1199.0, 752.0], [1225.0, 752.0], [1230.0, 925.0], [1204.0, 925.0]]], "lines": ["の元バティ最強とも", "国の辺が類っていた", "中岸人"]}, {"box": [1202, 935, 1396, 1028], "vertical": true, "font_size": 84, "lines_coords": [[[1295.0, 935.0], [1354.0, 935.0], [1354.0, 970.0], [1295.0, 970.0]], [[1204.0, 935.0], [1270.0, 935.0], [1270.0, 970.0], [1204.0, 970.0]], [[1202.0, 972.0], [1396.0, 972.0], [1396.0, 1028.0], [1202.0, 1028.0]]], "lines": ["４人", "れる。", "の購入を従える。"]}, {"box": [881, 672, 1031, 724], "vertical": false, "font_size": 52, "lines_coords": [[[881.0, 672.0], [1031.0, 672.0], [1031.0, 724.0], [881.0, 724.0]]], "lines": ["ァンシ"]}, {"box": [564, 745, 712, 1028], "vertical": true, "font_size": 41, "lines_coords": [[[667.0, 750.0], [712.0, 750.0], [712.0, 817.0], [667.0, 817.0]], [[621.0, 745.0], [667.0, 745.0], [667.0, 986.0], [621.0, 986.0]], [[599.0, 771.0], [632.0, 771.0], [632.0, 850.0], [599.0, 850.0]], [[564.0, 747.0], [599.0, 747.0], [602.0, 965.0], [567.0, 965.0]], [[583.0, 864.0], [635.0, 864.0], [635.0, 1028.0], [583.0, 1028.0]]], "lines": ["．．．", "«悪る。にれ", "のォ", "形役人に", "．．．形態に同"]}, {"box": [653, 930, 696, 1026], "vertical": true, "font_size": 41, "lines_coords": [[[653.0, 932.0], [689.0, 930.0], [696.0, 1024.0], [660.0, 1026.0]]], "lines": ["らの金曜"]}, {"box": [501, 752, 581, 1028], "vertical": true, "font_size": 41, "lines_coords": [[[524.0, 752.0], [560.0, 752.0], [560.0, 813.0], [524.0, 813.0]], [[531.0, 808.0], [581.0, 808.0], [576.0, 1028.0], [527.0, 1028.0]], [[501.0, 822.0], [541.0, 820.0], [550.0, 1026.0], [510.0, 1028.0]]], "lines": ["「人", "使を．．．形。者", "を間人た"]}, {"box": [131, 628, 371, 735], "vertical": false, "font_size": 56, "lines_coords": [[[185.0, 628.0], [246.0, 628.0], [246.0, 663.0], [185.0, 663.0]], [[131.0, 658.0], [358.0, 658.0], [358.0, 735.0], [131.0, 735.0]]], "lines": ["きょう", "人形使い"]}, {"box": [1198, 1235, 1467, 1608], "vertical": true, "font_size": 226, "lines_coords": [[[1213.0, 1256.0], [1438.0, 1235.0], [1467.0, 1532.0], [1242.0, 1553.0]]], "lines": ["買いの要素と契約するデビルンター、美容師と半年しかなトーリカの"]}, {"box": [506, 1272, 724, 1558], "vertical": true, "font_size": 108, "lines_coords": [[[642.0, 1385.0], [724.0, 1408.0], [707.0, 1464.0], [625.0, 1441.0]], [[581.0, 1286.0], [660.0, 1286.0], [660.0, 1455.0], [581.0, 1455.0]], [[543.0, 1462.0], [717.0, 1448.0], [721.0, 1495.0], [548.0, 1509.0]], [[524.0, 1272.0], [621.0, 1282.0], [602.0, 1471.0], [506.0, 1462.0]]], "lines": ["を奪うこ", "でもと年。金を奪い合いを", "たためらいが無", "師匠の小青年生物物"]}, {"box": [133, 1184, 356, 1260], "vertical": false, "font_size": 59, "lines_coords": [[[189.0, 1188.0], [349.0, 1192.0], [346.0, 1251.0], [187.0, 1246.0]]], "lines": ["ーリカ"]}, {"box": [145, 1762, 433, 1811], "vertical": false, "font_size": 49, "lines_coords": [[[145.0, 1762.0], [433.0, 1762.0], [433.0, 1811.0], [145.0, 1811.0]]], "lines": ["ＳＴＯＲＹ－"]}, {"box": [814, 1863, 1410, 2276], "vertical": false, "font_size": 44, "lines_coords": [[[817.0, 1866.0], [1406.0, 1866.0], [1406.0, 1921.0], [817.0, 1921.0]], [[820.0, 1924.0], [1399.0, 1924.0], [1399.0, 1965.0], [820.0, 1965.0]], [[815.0, 1969.0], [1406.0, 1967.0], [1406.0, 2021.0], [815.0, 2024.0]], [[817.0, 2016.0], [1410.0, 2021.0], [1410.0, 2075.0], [817.0, 2071.0]], [[817.0, 2072.0], [1408.0, 2074.0], [1408.0, 2122.0], [817.0, 2120.0]], [[822.0, 2131.0], [1408.0, 2131.0], [1408.0, 2171.0], [822.0, 2171.0]], [[822.0, 2180.0], [1396.0, 2180.0], [1396.0, 2221.0], [822.0, 2221.0]], [[822.0, 2227.0], [1403.0, 2227.0], [1403.0, 2275.0], [822.0, 2275.0]]], "lines": ["要する者を手に入れられる中国のクック、ドイツのツクツ", "ロース、アメリカのデビルハンター三兄弟など各国からの刺客", "これからのスケットカードルスペースには、お天気に来た時間は気になってしまうのがありません。", "あれはまだ．．．気持ちよくわかったんですよね。くあ、日の時間、できますようにしてください。ですから、その時期には大きくなってくれるのですね。", "まぁ、いいんじゃないんですけど、デバートの中へ追い詰められてしまう。ああったんだってさらにクァンジも参戦しない", "し絵体絶命のピンチとなるが、岸辺の登場により形勢が逆転。", "岸辺はクァンジの仲間を人質に取り「マキマを殺すために協", "カストを入れているのですが、カメラが入ってきたのであれば、一部隊をつけてみていた"]}, {"box": [130, 1857, 733, 2279], "vertical": false, "font_size": 42, "lines_coords": [[[157.0, 1867.0], [733.0, 1872.0], [733.0, 1917.0], [157.0, 1913.0]], [[138.0, 1921.0], [721.0, 1921.0], [721.0, 1967.0], [138.0, 1967.0]], [[138.0, 1972.0], [724.0, 1972.0], [724.0, 2018.0], [138.0, 2018.0]], [[140.0, 2024.0], [717.0, 2024.0], [717.0, 2070.0], [140.0, 2070.0]], [[142.0, 2080.0], [717.0, 2080.0], [717.0, 2119.0], [142.0, 2119.0]], [[140.0, 2132.0], [260.0, 2132.0], [260.0, 2170.0], [140.0, 2170.0]], [[154.0, 2172.0], [724.0, 2172.0], [724.0, 2224.0], [154.0, 2224.0]], [[138.0, 2228.0], [719.0, 2228.0], [719.0, 2274.0], [138.0, 2274.0]]], "lines": ["悪魔のボチタと共にデビルハンターとして暮らす少年・デンジ。", "借金返済のためこき使われるお店の日々を過ごしていたところ。", "おまえがここまでのお客さまを、裏切りに合い残されてしまう。ちょっとだが、ボチタがその命と引", "きゃぁ．．．き換えにデンジを「チェンソ一の悪魔」として蘇らせる〈敵を", "皆殺しにしたデンジは、マキマに拾われ公安のデビルハンターと", "なるのだった。", "そのため、その学校が「デノコ悪」として「実装され、世界的に", "デンジが日本にいることが知れまっていまったーー．．．こんなった。デンジという重"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [663, 1448, 1045, 1504], "vertical": false, "font_size": 49, "lines_coords": [[[663.0, 1448.0], [1045.0, 1455.0], [1045.0, 1504.0], [663.0, 1497.0]]], "lines": ["ＣＯＮＴＥＮＴＳ"]}, {"box": [555, 1518, 1418, 2289], "vertical": false, "font_size": 179, "lines_coords": [[[923.0, 1598.0], [1047.0, 1605.0], [1045.0, 1670.0], [921.0, 1663.0]], [[904.0, 1624.0], [1155.0, 1629.0], [1155.0, 1710.0], [904.0, 1705.0]], [[911.0, 1725.0], [1403.0, 1725.0], [1403.0, 1790.0], [911.0, 1790.0]], [[902.0, 1788.0], [1160.0, 1784.0], [1160.0, 1879.0], [902.0, 1883.0]], [[733.0, 1514.0], [1014.0, 1596.0], [836.0, 2240.0], [555.0, 2158.0]], [[899.0, 1891.0], [1099.0, 1891.0], [1099.0, 1966.0], [899.0, 1966.0]], [[806.0, 1704.0], [878.0, 1709.0], [855.0, 2146.0], [782.0, 2141.0]], [[724.0, 1624.0], [763.0, 1624.0], [768.0, 2221.0], [728.0, 2221.0]], [[885.0, 1915.0], [1403.0, 1950.0], [1394.0, 2113.0], [876.0, 2078.0]], [[906.0, 2055.0], [1230.0, 2055.0], [1230.0, 2137.0], [906.0, 2137.0]], [[906.0, 2149.0], [1352.0, 2144.0], [1352.0, 2214.0], [906.0, 2219.0]], [[813.0, 2147.0], [925.0, 2151.0], [925.0, 2216.0], [813.0, 2212.0]], [[724.0, 2217.0], [1073.0, 2217.0], [1073.0, 2305.0], [724.0, 2305.0]]], "lines": ["ちょうめちゃ地獄旅行", "うちょうめちゃくち地獄旅行ルーウォルカトゥー", "「地球旅行」の「ウェルカムトゥーザへルーのご興の悪魔」の", "１．ウェルカムトゥーも１１間の悪魔．ｃｏ！ワン！", "いやいや．．．いいの", "時間の悪魔のの！！ワン！？", "いつま．．．！そんなこと言ってたけれど", "．．．いいじゃないですけど、そんなことだったの", "第一、フンド．．．！！長い最初のデビルハンターハッキーグークバワーバの", "１最初のデビルハンター１ダークパワー．．．！シャイニングバワー", "「タークパワー」２０１シャイニング「バワーバル」が", "まーダー話！シャまー", "現役の話」シャイニング第７０話１編む．．．？"]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [105, 72, 932, 171], "vertical": false, "font_size": 84.5, "lines_coords": [[[105.0, 82.0], [389.0, 72.0], [391.0, 145.0], [107.0, 154.0]], [[384.0, 75.0], [932.0, 75.0], [932.0, 171.0], [384.0, 171.0]]], "lines": ["［第６２話］", "」ちょうめちゃくちゃ"]}], "img_path": "00007.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [883, 2164, 1236, 2324], "vertical": false, "font_size": 20, "lines_coords": [[[1068.0, 2194.0], [1114.0, 2168.0], [1121.0, 2180.0], [1075.0, 2206.0]], [[930.0, 2273.0], [1055.0, 2210.0], [1065.0, 2229.0], [939.0, 2293.0]], [[1078.0, 2210.0], [1130.0, 2180.0], [1135.0, 2192.0], [1