 30.4, "lines_coords": [[[808.0, 267.0], [838.0, 267.0], [838.0, 766.0], [808.0, 766.0]], [[768.0, 267.0], [799.0, 267.0], [799.0, 789.0], [768.0, 789.0]], [[728.0, 264.0], [759.0, 264.0], [759.0, 829.0], [728.0, 829.0]], [[691.0, 267.0], [721.0, 267.0], [721.0, 794.0], [691.0, 794.0]], [[651.0, 271.0], [681.0, 271.0], [681.0, 785.0], [651.0, 785.0]]], "lines": ["といった人が２０２８年２月は＆隊ワ三言雪薬暑喜差", "だいたいた瞬間の内容は、侍戌パ度罠蟇畠莒首募", "「ただしたら大人になってもらえたえにひらまきましました", "それだけではあるのは、践愁餞戌珍□盲詈爾量憲愚", "月日日といえば、映画館内には商店区：当事業員の"]}, {"box": [846, 269, 869, 742], "vertical": true, "font_size": 23, "lines_coords": [[[846.0, 269.0], [869.0, 269.0], [869.0, 742.0], [846.0, 742.0]]], "lines": ["とにかくＬＩＮＥＮＥ２０１８年８月２８日土・"]}], "img_path": "00161.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [], "img_path": "00162.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [], "img_path": "00163.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [], "img_path": "00164.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [], "img_path": "00165.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [], "img_path": "00166.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [34, 890, 252, 965], "vertical": false, "font_size": 37, "lines_coords": [[[48.0, 887.0], [171.0, 908.0], [164.0, 946.0], [41.0, 925.0]]], "lines": ["おまえがないと"]}, {"box": [618, 813, 794, 930], "vertical": false, "font_size": 33, "lines_coords": [[[619.0, 901.0], [773.0, 810.0], [787.0, 841.0], [633.0, 932.0]]], "lines": ["それはそれぞれ"]}], "img_path": "00167.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [], "img_path": "00168.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [98, 159, 461, 206], "vertical": false, "font_size": 47, "lines_coords": [[[98.0, 159.0], [461.0, 159.0], [461.0, 206.0], [98.0, 206.0]]], "lines": ["チェ