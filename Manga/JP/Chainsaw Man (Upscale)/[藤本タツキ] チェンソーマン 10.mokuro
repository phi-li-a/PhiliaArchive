{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 10", "volume_uuid": "a2ceccc6-20f8-46f7-9efb-99eb612b268d", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [203, 602, 269, 1218], "vertical": true, "font_size": 50, "lines_coords": [[[203.0, 602.0], [253.0, 602.0], [269.0, 1218.0], [220.0, 1218.0]]], "lines": ["オーラーメンテーニングを"]}, {"box": [42, 989, 206, 1672], "vertical": true, "font_size": 81, "lines_coords": [[[84.0, 1047.0], [206.0, 1054.0], [178.0, 1657.0], [56.0, 1650.0]], [[42.0, 1298.0], [82.0, 1298.0], [84.0, 1666.0], [44.0, 1666.0]]], "lines": ["お客さんのサイトに", "ＴａｒｓｕｋｉＦｕｌｉｍｏｒｏ"]}, {"box": [48, 2273, 584, 2380], "vertical": false, "font_size": 62, "lines_coords": [[[264.0, 2277.0], [581.0, 2287.0], [578.0, 2353.0], [262.0, 2344.0]]], "lines": ["ＣＯＭＩＳよ"]}, {"box": [660, 1535, 1483, 2400], "vertical": false, "font_size": 700, "lines_coords": [[[660.0, 1797.0], [1146.0, 1535.0], [1483.0, 2158.0], [998.0, 2400.0]]], "lines": ["＞＞"]}, {"box": [1217, 2268, 1446, 2338], "vertical": false, "font_size": 62, "lines_coords": [[[1235.0, 2270.0], [1436.0, 2270.0], [1436.0, 2337.0], [1235.0, 2337.0]]], "lines": ["その気持ち"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [131, 2167, 1394, 2271], "vertical": false, "font_size": 40.0, "lines_coords": [[[131.0, 2167.0], [1394.0, 2167.0], [1394.0, 2207.0], [131.0, 2207.0]], [[131.0, 2231.0], [1389.0, 2231.0], [1389.0, 2271.0], [131.0, 2271.0]]], "lines": ["★この作品はフィクションです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [45, 39, 585, 129], "vertical": false, "font_size": 82, "lines_coords": [[[58.0, 32.0], [581.0, 42.0], [581.0, 131.0], [58.0, 121.0]]], "lines": ["ＪＵＭＰ．ＣＯＭＩＣＳで、"]}, {"box": [531, 2081, 953, 2313], "vertical": false, "font_size": 117.0, "lines_coords": [[[632.0, 2081.0], [853.0, 2081.0], [853.0, 2146.0], [632.0, 2146.0]], [[531.0, 2144.0], [953.0, 2144.0], [953.0, 2313.0], [531.0, 2313.0]]], "lines": ["【犬の気持ち】じゃ", "藤本タツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [119, 382, 304, 459], "vertical": false, "font_size": 77, "lines_coords": [[[119.0, 382.0], [304.0, 382.0], [304.0, 459.0], [119.0, 459.0]]], "lines": ["デンジ"]}, {"box": [686, 114, 1417, 201], "vertical": false, "font_size": 80, "lines_coords": [[[686.0, 114.0], [1417.0, 121.0], [1417.0, 201.0], [686.0, 194.0]]], "lines": ["・○ＨＡＲＡＣＴＥＲＳ"]}, {"box": [105, 503, 749, 704], "vertical": false, "font_size": 67, "lines_coords": [[[105.0, 503.0], [749.0, 503.0], [749.0, 600.0], [105.0, 600.0]], [[110.0, 588.0], [747.0, 574.0], [749.0, 646.0], [112.0, 660.0]], [[128.0, 660.0], [639.0, 660.0], [639.0, 693.0], [128.0, 693.0]]], "lines": ["納庫のボチタをその身に応え、「チェント」", "の悪魔男の生。自分の欲望に正直。初", "めて人並扱いしてくわたマキマが好き"]}, {"box": [862, 2125, 1415, 2275], "vertical": false, "font_size": 60, "lines_coords": [[[1103.0, 2146.0], [1415.0, 2153.0], [1415.0, 2217.0], [1103.0, 2210.0]], [[862.0, 2212.0], [1415.0, 2214.0], [1415.0, 2271.0], [862.0, 2268.0]]], "lines": ["『チェンソーの悪魔』。", "デンジに心臓を与え、体の一部となる。"]}, {"box": [1232, 2013, 1408, 2083], "vertical": false, "font_size": 70, "lines_coords": [[[1232.0, 2013.0], [1408.0, 2013.0], [1408.0, 2083.0], [1232.0, 2083.0]]], "lines": ["ポチタ"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [993, 588, 1218, 679], "vertical": false, "font_size": 41.5, "lines_coords": [[[993.0, 621.0], [1218.0, 621.0], [1218.0, 679.0], [993.0, 679.0]], [[996.0, 600.0], [1021.0, 588.0], [1033.0, 611.0], [1005.0, 623.0]]], "lines": ["早川アキ", "はや"]}, {"box": [808, 720, 1395, 842], "vertical": false, "font_size": 39, "lines_coords": [[[1131.0, 728.0], [1202.0, 728.0], [1202.0, 752.0], [1131.0, 752.0]], [[810.0, 745.0], [1392.0, 733.0], [1392.0, 780.0], [810.0, 792.0]], [[808.0, 792.0], [1171.0, 794.0], [1171.0, 841.0], [808.0, 839.0]]], "lines": ["わんせんしい", "マキマの部下。デンジの３年先輩でお目付け役だ。", "たが、「銃の魔人」と化した。"]}, {"box": [356, 619, 502, 686], "vertical": false, "font_size": 50, "lines_coords": [[[363.0, 625.0], [492.0, 625.0], [492.0, 675.0], [363.0, 675.0]]], "lines": ["マキマ"]}, {"box": [126, 724, 726, 839], "vertical": false, "font_size": 32, "lines_coords": [[[145.0, 728.0], [285.0, 728.0], [285.0, 752.0], [145.0, 752.0]], [[138.0, 747.0], [726.0, 747.0], [726.0, 780.0], [138.0, 780.0]], [[133.0, 799.0], [454.0, 799.0], [454.0, 839.0], [133.0, 839.0]]], "lines": ["うあんたい．．．とくい", "公安対職特異４課を取り仕切るミステリアスな女", "その正体は「支配の悪魔」。"]}, {"box": [803, 1527, 1422, 1647], "vertical": false, "font_size": 69, "lines_coords": [[[817.0, 1528.0], [1413.0, 1528.0], [1413.0, 1591.0], [817.0, 1591.0]], [[803.0, 1572.0], [1122.0, 1572.0], [1122.0, 1647.0], [803.0, 1647.0]]], "lines": ["「血の悪魔」の魔人。自分勝手で暴走しがち。", "猫のニャーコが唯一の友達。"]}, {"box": [383, 1393, 478, 1486], "vertical": false, "font_size": 93, "lines_coords": [[[383.0, 1393.0], [478.0, 1393.0], [478.0, 1486.0], [383.0, 1486.0]]], "lines": ["岸辺"]}, {"box": [123, 1523, 719, 1638], "vertical": false, "font_size": 48, "lines_coords": [[[126.0, 1528.0], [719.0, 1523.0], [719.0, 1586.0], [126.0, 1591.0]], [[135.0, 1603.0], [473.0, 1603.0], [473.0, 1635.0], [135.0, 1635.0]]], "lines": ["並外れた戦闘力を持つつ特異課最強のデビルハンター", "マキマのことを警戒している？"]}, {"box": [142, 1762, 424, 1811], "vertical": false, "font_size": 49, "lines_coords": [[[142.0, 1762.0], [424.0, 1762.0], [424.0, 1811.0], [142.0, 1811.0]]], "lines": ["ＳＴＯＲＹ："]}, {"box": [808, 1860, 1408, 2276], "vertical": false, "font_size": 41, "lines_coords": [[[813.0, 1869.0], [1392.0, 1869.0], [1392.0, 1915.0], [813.0, 1915.0]], [[817.0, 1925.0], [1396.0, 1925.0], [1396.0, 1964.0], [817.0, 1964.0]], [[813.0, 1975.0], [1408.0, 1972.0], [1408.0, 2018.0], [813.0, 2020.0]], [[813.0, 2017.0], [1408.0, 2019.0], [1408.0, 2074.0], [813.0, 2072.0]], [[817.0, 2075.0], [1403.0, 2075.0], [1403.0, 2121.0], [817.0, 2121.0]], [[815.0, 2125.0], [1399.0, 2127.0], [1399.0, 2173.0], [815.0, 2170.0]], [[817.0, 2181.0], [1396.0, 2181.0], [1396.0, 2220.0], [817.0, 2220.0]], [[817.0, 2235.0], [1366.0, 2235.0], [1366.0, 2271.0], [817.0, 2271.0]]], "lines": ["不参加を決めたアキに「すでに銃の愛情は倒され持束されてい", "る」と告げるマキマ。さおに未来の長期はアキとパワーガテンジ", "に殺されるという、最悪の未来を見せる。．．．。心伝れるアキの前で、", "これからのレッスンのみんながらもしかしていますので、ママガリに対象としての対応もありませんが、アイテムを見つけてください。", "の悪魔を差し向けマキマを止めようとさするが、失敗。銃の魔人", "そんなことは．．．と化したアキがデンジの前に現れる。デンジは心を失い破壊と", "殺戮を続けるアキを正気に戻そうとするが、叶わず。どこまで", "も深い抱望の中、デンジはアキの命を絶つしかなかったー。"]}, {"box": [127, 1853, 752, 2278], "vertical": false, "font_size": 39, "lines_coords": [[[157.0, 1869.0], [728.0, 1869.0], [728.0, 1915.0], [157.0, 1915.0]], [[145.0, 1911.0], [215.0, 1911.0], [215.0, 1934.0], [145.0, 1934.0]], [[135.0, 1921.0], [721.0, 1921.0], [721.0, 1967.0], [135.0, 1967.0]], [[138.0, 1977.0], [719.0, 1977.0], [719.0, 2016.0], [138.0, 2016.0]], [[140.0, 2029.0], [712.0, 2029.0], [712.0, 2067.0], [140.0, 2067.0]], [[140.0, 2080.0], [714.0, 2080.0], [714.0, 2119.0], [140.0, 2119.0]], [[138.0, 2132.0], [260.0, 2132.0], [260.0, 2170.0], [138.0, 2170.0]], [[145.0, 2155.0], [728.0, 2155.0], [728.0, 2231.0], [145.0, 2231.0]], [[131.0, 2228.0], [721.0, 2218.0], [721.0, 2271.0], [131.0, 2281.0]], [[707.0, 2239.0], [752.0, 2239.0], [752.0, 2264.0], [707.0, 2264.0]]], "lines": ["悪魔のボチタと共にデビルハンターとして暮らす少年・デンジ。", "けっともへんこいなんだ", "借金返済のためこき使われる！お店の日々を過ごしていたところ。", "を、裏切りに合い残されてしまう。だが、ボチタがその命と引", "き換えにデンジを【チェンツ一の悪魔」として蘇らせる！敵を", "皆殺しにしたデンジは、マキマに拾われ公安のデビルハンターと", "なるのだった。", "２０１６年１１月１６日東京都市の研究室内に、アルバムスタッフレッチングレーシャンプレット", "そのため、今回は一人、いくつかのインターネットの表情が完全でした。納得を予定されることの", "の"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [475, 1450, 857, 1504], "vertical": false, "font_size": 50, "lines_coords": [[[475.0, 1450.0], [857.0, 1455.0], [857.0, 1504.0], [475.0, 1500.0]]], "lines": ["ＣＯＮＴＥＮＴＳ"]}, {"box": [0, 1110, 1417, 2400], "vertical": false, "font_size": 282, "lines_coords": [[[669.0, 1660.0], [883.0, 1512.0], [983.0, 1713.0], [770.0, 1861.0]], [[4.0, 2063.0], [630.0, 1085.0], [1255.0, 1554.0], [613.0, 2399.0]], [[676.0, 1625.0], [698.0, 1625.0], [698.0, 2058.0], [676.0, 2058.0]], [[554.0, 1885.0], [913.0, 1472.0], [1192.0, 1770.0], [833.0, 2182.0]], [[828.0, 1744.0], [871.0, 1737.0], [890.0, 1936.0], [847.0, 1943.0]], [[500.0, 1521.0], [524.0, 1521.0], [524.0, 2309.0], [500.0, 2309.0]], [[634.0, 1594.0], [662.0, 1594.0], [667.0, 2187.0], [639.0, 2187.0]], [[585.0, 1575.0], [609.0, 1575.0], [611.0, 2229.0], [587.0, 2229.0]], [[873.0, 1800.0], [1180.0, 1796.0], [1180.0, 1882.0], [873.0, 1887.0]], [[770.0, 1744.0], [794.0, 1744.0], [796.0, 2058.0], [772.0, 2058.0]], [[770.0, 1435.0], [1288.0, 2093.0], [848.0, 2399.0], [329.0, 1838.0]], [[468.0, 1700.0], [482.0, 1700.0], [482.0, 2306.0], [468.0, 2306.0]], [[845.0, 1882.0], [1070.0, 1882.0], [1070.0, 1971.0], [845.0, 1971.0]], [[835.0, 1969.0], [1110.0, 1969.0], [1110.0, 2058.0], [835.0, 2058.0]], [[784.0, 2014.0], [791.0, 2014.0], [791.0, 2091.0], [784.0, 2091.0]], [[627.0, 2119.0], [1412.0, 2117.0], [1412.0, 2231.0], [627.0, 2234.0]], [[1199.0, 2117.0], [1312.0, 2117.0], [1312.0, 2182.0], [1199.0, 2182.0]], [[550.0, 2217.0], [1094.0, 2220.0], [1094.0, 2311.0], [550.0, 2309.0]]], "lines": ["もう、その名前も言ってるですか。高年なんっかりそう言えましょう", "．．．", "それは．．．なんですよね。そういうわけじゃない", "．．．", "おでてベッツ買取りしっかりあって頂き、ティオのヒーロ出張。", "．．．", "．．．そんなことはありませんでしょうかなかったんですけどね。", "お父さんのお母さんはそんなの", "僕はしっかり．．．。世話・チェンソール・緑のヒーロー．．ｃｒ．", "いってなんだな．．．そっからありがとうございませんでしょう", "．．．", "ああ．．．", "ま、変活・チェンソーの登録のヒーローのご連絡長・月号研止・の", "本日のヒーローのお世話は．．．月日土・デートチェンソーハッ", "電気のと超部長・デートチェーン", "このようになるのは今日も、テーブルカーが好きで、チェックーマックは無料で活躍してみる。スターテンツーーの", "俺の武装人間。。", "「本来アルコ・チェンソーマン作業情のする場合は、「スターチェッソー」の"]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [539, 264, 904, 344], "vertical": false, "font_size": 73, "lines_coords": [[[539.0, 271.0], [904.0, 26