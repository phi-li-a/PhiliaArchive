{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 07", "volume_uuid": "8db76665-6b6c-43ea-9350-415aa3dab300", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [54, 1277, 609, 1428], "vertical": false, "font_size": 149, "lines_coords": [[[201.0, 1273.0], [606.0, 1264.0], [609.0, 1426.0], [203.0, 1435.0]]], "lines": ["．．．"]}, {"box": [49, 1461, 424, 1502], "vertical": false, "font_size": 44, "lines_coords": [[[49.0, 1458.0], [405.0, 1458.0], [405.0, 1506.0], [49.0, 1506.0]]], "lines": ["そうなのに、何かないのね"]}, {"box": [660, 1305, 1488, 2254], "vertical": false, "font_size": 806, "lines_coords": [[[660.0, 1481.0], [1260.0, 1305.0], [1488.0, 2078.0], [888.0, 2254.0]]], "lines": ["ひ"]}, {"box": [37, 2258, 481, 2365], "vertical": false, "font_size": 62, "lines_coords": [[[65.0, 2277.0], [461.0, 2277.0], [461.0, 2344.0], [65.0, 2344.0]]], "lines": ["ＪｕＭＰ．ｃｏＭｌＣＳ"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [131, 2167, 1394, 2271], "vertical": false, "font_size": 40.0, "lines_coords": [[[131.0, 2167.0], [1394.0, 2167.0], [1394.0, 2207.0], [131.0, 2207.0]], [[131.0, 2231.0], [1389.0, 2231.0], [1389.0, 2271.0], [131.0, 2271.0]]], "lines": ["★この作品はフィクションです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [44, 39, 584, 130], "vertical": false, "font_size": 79, "lines_coords": [[[58.0, 35.0], [581.0, 42.0], [581.0, 128.0], [58.0, 121.0]]], "lines": ["ＪＵＭＰ．ＣＯＭＩＣＳで、"]}, {"box": [663, 2085, 822, 2137], "vertical": false, "font_size": 52, "lines_coords": [[[663.0, 2085.0], [822.0, 2085.0], [822.0, 2137.0], [663.0, 2137.0]]], "lines": ["【夢の中】"]}, {"box": [543, 2165, 944, 2301], "vertical": false, "font_size": 136, "lines_coords": [[[543.0, 2165.0], [944.0, 2165.0], [944.0, 2301.0], [543.0, 2301.0]]], "lines": ["藤本タツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [124, 384, 299, 454], "vertical": false, "font_size": 70, "lines_coords": [[[124.0, 384.0], [299.0, 384.0], [299.0, 454.0], [124.0, 454.0]]], "lines": ["デンジ"]}, {"box": [703, 119, 1413, 194], "vertical": false, "font_size": 70, "lines_coords": [[[703.0, 119.0], [1413.0, 124.0], [1413.0, 194.0], [703.0, 189.0]]], "lines": ["ＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [112, 510, 745, 702], "vertical": false, "font_size": 56, "lines_coords": [[[112.0, 510.0], [745.0, 510.0], [745.0, 590.0], [112.0, 590.0]], [[121.0, 590.0], [707.0, 590.0], [707.0, 637.0], [121.0, 637.0]], [[128.0, 656.0], [639.0, 656.0], [639.0, 696.0], [128.0, 696.0]]], "lines": ["相棒のボチケをその身に廊下、「チェンリー", "の悪魔」の少年。自分の欲望に正直。", "めて人並扱いしてくれたマキマが好き"]}, {"box": [860, 1600, 1420, 1727], "vertical": false, "font_size": 61.0, "lines_coords": [[[1101.0, 1605.0], [1413.0, 1600.0], [1413.0, 1659.0], [1101.0, 1664.0]], [[860.0, 1659.0], [1420.0, 1664.0], [1420.0, 1727.0], [860.0, 1722.0]]], "lines": ["『チェンソーの悪魔』。", "デンジに心臓を与え、体の一部となる。"]}, {"box": [1228, 1455, 1410, 1539], "vertical": false, "font_size": 80, "lines_coords": [[[1228.0, 1460.0], [1408.0, 1455.0], [1410.0, 1535.0], [1230.0, 1539.0]]], "lines": ["ポチタ"]}, {"box": [154, 1832, 276, 1886], "vertical": false, "font_size": 54, "lines_coords": [[[154.0, 1832.0], [276.0, 1832.0], [276.0, 1886.0], [154.0, 1886.0]]], "lines": ["マキマ"]}, {"box": [452, 1903, 721, 2207], "vertical": true, "font_size": 99, "lines_coords": [[[543.0, 2083.0], [684.0, 2076.0], [686.0, 2139.0], [546.0, 2146.0]], [[524.0, 2043.0], [557.0, 2043.0], [557.0, 2137.0], [524.0, 2137.0]], [[492.0, 1964.0], [576.0, 1978.0], [536.0, 2207.0], [452.0, 2193.0]], [[534.0, 1903.0], [672.0, 1903.0], [672.0, 1987.0], [534.0, 1987.0]]], "lines": ["俺の匂いを", "ティ魔", "取引を入居してくれていた", "安対魔特異４"]}, {"box": [803, 1794, 1046, 1900], "vertical": false, "font_size": 75, "lines_coords": [[[803.0, 1821.0], [1040.0, 1821.0], [1040.0, 1896.0], [803.0, 1896.0]]], "lines": ["早川アキ"]}, {"box": [1235, 1912, 1403, 2142], "vertical": true, "font_size": 104, "lines_coords": [[[1335.0, 1912.0], [1403.0, 1912.0], [1403.0, 2142.0], [1335.0, 2142.0]], [[1235.0, 1926.0], [1317.0, 1926.0], [1317.0, 2053.0], [1235.0, 2053.0]]], "lines": ["なっなんで年生の悪魔！！", "マの忠デンジ"]}, {"box": [1197, 2158, 1359, 2184], "vertical": true, "font_size": 104, "lines_coords": [[[1197.0, 2158.0], [1359.0, 2158.0], [1359.0, 2184.0], [1197.0, 2184.0]]], "lines": ["「契約している"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1199, 229, 1414, 447], "vertical": false, "font_size": 52, "lines_coords": [[[1242.0, 269.0], [1408.0, 292.0], [1399.0, 363.0], [1232.0, 339.0]], [[1202.0, 351.0], [1406.0, 351.0], [1406.0, 391.0], [1202.0, 391.0]], [[1202.0, 396.0], [1385.0, 400.0], [1385.0, 447.0], [1202.0, 442.0]]], "lines": ["分勝手で暴走し", "がち。觜のニャー", "コが唯一の友達。"]}, {"box": [480, 213, 719, 571], "vertical": true, "font_size": 62, "lines_coords": [[[689.0, 243.0], [719.0, 243.0], [719.0, 445.0], [689.0, 445.0]], [[646.0, 213.0], [719.0, 220.0], [696.0, 508.0], [623.0, 501.0]], [[618.0, 232.0], [663.0, 227.0], [679.0, 382.0], [635.0, 386.0]], [[562.0, 227.0], [658.0, 227.0], [658.0, 464.0], [562.0, 464.0]], [[560.0, 236.0], [597.0, 236.0], [597.0, 288.0], [560.0, 288.0]], [[480.0, 217.0], [590.0, 213.0], [606.0, 567.0], [496.0, 571.0]], [[569.0, 464.0], [614.0, 464.0], [614.0, 494.0], [569.0, 494.0]]], "lines": ["の脆野価", "実的に姫野郎の姫野”人を", "思的の", "思神のみ精一司力を込めるように、上手の", "込", "引っ込新人。いが、はその男していた姉妹。", "いた"]}, {"box": [96, 67, 435, 236], "vertical": false, "font_size": 169, "lines_coords": [[[96.0, 67.0], [435.0, 67.0], [435.0, 236.0], [96.0, 236.0]]], "lines": ["東山コベニ"]}, {"box": [1141, 738, 1436, 1078], "vertical": false, "font_size": 177, "lines_coords": [[[1204.0, 764.0], [1408.0, 764.0], [1408.0, 813.0], [1204.0, 813.0]], [[1246.0, 789.0], [1436.0, 789.0], [1436.0, 1000.0], [1246.0, 1000.0]], [[1141.0, 740.0], [1420.0, 738.0], [1424.0, 1075.0], [1146.0, 1078.0]], [[1265.0, 916.0], [1317.0, 916.0], [1317.0, 1028.0], [1265.0, 1028.0]]], "lines": ["人に敵意はないが", "最悪はないが、離れられるとを吸い取られまう。物理４成長", "人も多々ないので、男性から女性と言えない気ものでしまう。今度は", "う．．．"]}, {"box": [796, 625, 1129, 754], "vertical": false, "font_size": 119, "lines_coords": [[[796.0, 635.0], [1129.0, 635.0], [1129.0, 754.0], [796.0, 754.0]]], "lines": ["天使の悪魔"]}, {"box": [464, 751, 761, 1029], "vertical": false, "font_size": 142, "lines_coords": [[[534.0, 757.0], [569.0, 759.0], [564.0, 869.0], [529.0, 867.0]], [[501.0, 752.0], [534.0, 752.0], [541.0, 921.0], [508.0, 921.0]], [[464.0, 775.0], [761.0, 775.0], [761.0, 1014.0], [464.0, 1014.0]], [[508.0, 970.0], [728.0, 975.0], [728.0, 1026.0], [508.0, 1021.0]]], "lines": ["異や", "〈特に星〉な", "結果、最高の素敵などとか女優秀でも泳ぐことができ、短時間おらず、", "なら悪魔の姿にも。"]}, {"box": [192, 670, 468, 719], "vertical": false, "font_size": 49, "lines_coords": [[[192.0, 670.0], [468.0, 670.0], [468.0, 719.0], [192.0, 719.0]]], "lines": ["一ム（サメの魔人）"]}, {"box": [1134, 1232, 1525, 1586], "vertical": false, "font_size": 109, "lines_coords": [[[1230.0, 1279.0], [1256.0, 1279.0], [1256.0, 1387.0], [1230.0, 1387.0]], [[1256.0, 1275.0], [1291.0, 1277.0], [1286.0, 1389.0], [1251.0, 1387.0]], [[1199.0, 1279.0], [1225.0, 1279.0], [1225.0, 1410.0], [1199.0, 1410.0]], [[1277.0, 1289.0], [1319.0, 1289.0], [1319.0, 1415.0], [1277.0, 1415.0]], [[1317.0, 1284.0], [1349.0, 1284.0], [1349.0, 1389.0], [1317.0, 1389.0]], [[1134.0, 1396.0], [1413.0, 1232.0], [1525.0, 1422.0], [1244.0, 1586.0]], [[1202.0, 1448.0], [1406.0, 1448.0], [1406.0, 1497.0], [1202.0, 1497.0]], [[1202.0, 1507.0], [1413.0, 1507.0], [1413.0, 1549.0], [1202.0, 1549.0]]], "lines": ["異外", "課れ", "結菜", "にた．．．", "所戦", "そんなことをしちゃってくれないんじゃないでしょう", "ルハンター。デン", "ジとパワーの先生。"]}, {"box": [803, 1143, 928, 1263], "vertical": true, "font_size": 64, "lines_coords": [[[803.0, 1150.0], [867.0, 1143.0], [878.0, 1256.0], [815.0, 1263.0]]], "lines": ["岸"]}, {"box": [489, 1253, 754, 1584], "vertical": false, "font_size": 134, "lines_coords": [[[564.0, 1263.0], [742.0, 1253.0], [754.0, 1476.0], [576.0, 1485.0]], [[501.0, 1321.0], [595.0, 1326.0], [583.0, 1523.0], [489.0, 1518.0]], [[553.0, 1455.0], [714.0, 1455.0], [714.0, 1495.0], [553.0, 1495.0]], [[506.0, 1471.0], [693.0, 1507.0], [679.0, 1584.0], [492.0, 1549.0]]], "lines": ["４歳の影景。わた愛すぎる言葉は誰のつけさせて", "あまりため、仮面を", "何をつけさせて", "制御している。"]}, {"box": [132, 1151, 424, 1260], "vertical": false, "font_size": 84, "lines_coords": [[[168.0, 1176.0], [417.0, 1176.0], [417.0, 1260.0], [168.0, 1260.0]]], "lines": ["カの魔人"]}, {"box": [126, 1148, 427, 1260], "vertical": true, "font_size": 54, "lines_coords": [[[126.0, 1148.0], [180.0, 1148.0], [180.0, 1260.0], [126.0, 1260.0]]], "lines": ["暴"]}, {"box": [142, 1760, 442, 1809], "vertical": false, "font_size": 49, "lines_coords": [[[142.0, 1760.0], [442.0, 1760.0], [442.0, 1809.0], [142.0, 1809.0]]], "lines": ["ＳＴＯＲＹ－"]}, {"box": [775, 1858, 1409, 2271], "vertical": false, "font_size": 44, "lines_coords": [[[951.0, 1868.0], [1408.0, 1868.0], [1408.0, 1916.0], [951.0, 1916.0]], [[892.0, 1889.0], [918.0, 1863.0], [942.0, 1895.0], [916.0, 1921.0]], [[829.0, 1859.0], [862.0, 1892.0], [831.0, 1930.0], [799.0, 1897.0]], [[808.0, 1906.0], [1408.0, 1906.0], [1408.0, 1970.0], [808.0, 1970.0]], [[815.0, 1969.0], [1401.0, 1969.0], [1401.0, 2017.0], [815.0, 2017.0]], [[813.0, 2018.0], [1408.0, 2016.0], [1408.0, 2071.0], [813.0, 2073.0]], [[817.0, 2072.0], [1401.0, 2072.0], [1401.0, 2120.0], [817.0, 2120.0]], [[815.0, 2124.0], [1401.0, 2124.0], [1401.0, 2171.0], [815.0, 2171.0]], [[810.0, 2168.0], [1408.0, 2171.0], [1408.0, 2225.0], [810.0, 2223.0]], [[775.0, 2224.0], [1389.0, 2224.0], [1389.0, 2272.0], [775.0, 2272.0]]], "lines": ["「東京の高橋」だった「デンジが必要と思います。", "多分、", "いいい", "ありがとうございますが、おまえの特集の場合、お気に入れておりませんでしょうか", "あの時は、ここ数年ですかったのですが、２０時までも同じ事は自分を考えることが出来ましたが．．．", "このように、私のおかげさんとは思いませんでしたが、最後はランカリと交通されています。ですが、", "また、最後のシステムについては、まるである。私は使ってもいいかもしれないようにして", "ここで、ジュージは「一緒に遊びよう」と提案する。答えることなく姿を消し", "うふ。私も知らんじゃないんだというわけではないかもしれないので、いつの原因ですがおまえになったのかな。", "．．．ここで、「天使の悪魔」の手には、マネマと一天候の意識」の子により、その命を殺えていた．．．。その前を終えてした．．。"]}, {"box": [127, 1855, 735, 2270], "vertical": false, "font_size": 41, "lines_coords": [[[157.0, 1867.0], [735.0, 1869.0], [735.0, 1915.0], [157.0, 1913.0]], [[138.0, 1918.0], [719.0, 1918.0], [719.0, 1964.0], [138.0, 1964.0]], [[135.0, 1970.0], [721.0, 1970.0], [721.0, 2016.0], [135.0, 2016.0]], [[138.0, 2022.0], [714.0, 2022.0], [714.0, 2067.0], [138.0, 2067.0]], [[138.0, 2078.0], [712.0, 2075.0], [712.0, 2114.0], [138.0, 2117.0]], [[138.0, 2129.0], [260.0, 2129.0], [260.0, 2168.0], [138.0, 2168.0]], [[157.0, 2167.0], [717.0, 2162.0], [717.0, 2217.0], [157.0, 2222.0]], [[138.0, 2228.0], [717.0, 2228.0], [717.0, 2267.0], [138.0, 2267.0]]], "lines": ["悪魔のボチタと共にデビルハンターとして暮らす少年・デンジ。", "借金返済のためこき使われるお風呂の日々を指ごしていたところ、", "第二条、裏切りに合い残されてしまう。だが、ボチタがその命と引", "き換えにデンジを【チェンツ一つ悪魔」として取らせる！敵を", "皆殺しにしたデンジは、マキマに拾われ公安のデビルハンターと", "なるのだった。", "３００．２．１１年末年始の、一緒に来てくださっちゃうーーーんなんだから", "がけない言葉に、心揺れるテンジ。だがレゼの正体は「技の悪"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [550, 1450, 951, 1506], "vertical": false, "font_size": 51, "lines_coords": [[[555.0, 1451.0], [937.0, 1451.0], [937.0, 1506.0], [555.0, 1506.0]]], "lines": ["ＣＯＮＴＥＮＴＳ"]}, {"box": [506, 1417, 1410, 2355], "vertical": false, "font_size": 313, "lines_coords": [[[799.0, 1619.0], [1195.0, 1617.0], [1195.0, 1720.0], [799.0, 1722.0]], [[838.0, 1711.0], [1078.0, 1706.0], [1078.0, 1802.0], [838.0, 1806.0]], [[867.0, 1790.0], [1117.0, 1795.0], [1117.0, 1891.0], [867.0, 1886.0]], [[506.0, 1389.0], [1150.0, 1389.0], [1150.0, 2383.0], [506.0, 2383.0]], [[618.0, 1535.0], [658.0, 1535.0], [658.0, 2240.0], [618.0, 2240.0]], [[710.0, 1600.0], [742.0, 1600.0], [735.0, 2200.0], [703.0, 2200.0]], [[571.0, 1518.0], [604.0, 1518.0], [604.0, 2313.0], [571.0, 2313.0]], [[747.0, 1701.0], [778.0, 1701.0], [778.0, 2149.0], [747.0, 2149.0]], [[923.0, 1886.0], [963.0, 1886.0], [963.0, 1968.0], [923.0, 1968.0]], [[696.0, 1603.0], [1220.0, 1603.0], [1220.0, 2254.0], [696.0, 2254.0]], [[843.0, 1797.0], [876.0, 1797.0], [876.0, 2104.0], [843.0, 2104.0]], [[539.0, 1605.0], [562.0, 1605.0], [562.0, 2313.0], [539.0, 2313.0]], [[1061.0, 1968.0], [1148.0, 1968.0], [1148.0, 2050.0], [1061.0, 2050.0]], [[869.0, 1968.0], [1063.0, 1964.0], [1063.0, 2053.0], [869.0, 2057.0]], [[1033.0, 2104.0], [1272.0, 2104.0], [1272.0, 2191.0], [1033.0, 2191.0]], [[705.0, 2125.0], [1410.0, 2130.0], [1410.0, 2235.0], [705.0, 2231.0]], [[628.0, 2222.0], [665.0, 2222.0], [665.0, 2308.0], [628.0, 2308.0]], [[710.0, 2219.0], [1220.0, 2219.0], [1220.0, 2315.0], [710.0, 2315.0]]], "lines": ["Ｑ．「夢の中心」ということの話にいくには、ののキーレッツゴールのことでしたが、", "２０１０年にいくには、レッツゴール・買いと初めてのの", "はい。ここで、このレッツゴー取りと勧めていい笑話。．．．", "その時間は、このようになっているのですが、そんなことはありませんでしょうか。それでもいいですけど．．．そういうことではないと思います。", "バカバカのおかげなのだから．．．そういうことですか", "いや．．．あああんっ、うんうううっすっごーっ", "いまいだいたいないのですか", "いやいや．．．はいってくれないですか？", "良いと辞めて実務．．．。事業ユウタロウ", "．．．", "ショッコーネットですが、大丈夫ですよねーからちょっと", "はいはい！！", "「タロウ．．．。ちゃーい。", "実装コウタロウロウィルのあちゃくちゃいい", "ウタロウ．．．！？くちゃい！！！なんと食人達日十九人暮りしてましボーター．！！", "このようなサービスのスマホですが、６００カードクラウンと開催日間以降のお申し上げます。", "「おはいあってあげる」", "このようですが、２０１６年１０月１０日（月）日）の６月１１日－コースレポーター："]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [62, 2240, 639, 2346], "vertical": false, "font_size": 72, "lines_coords": [[[452.0, 2245.0], [492.0, 2245.0], [492.0, 2275.0], [452.0, 2275.0]], [[560.0, 2240.0], [604.0, 2240.0], [604.0, 2329.0], [560.0, 2329.0]], [[166.0, 2271.0], [372.0, 2271.0], [372.0, 2339.0], [166.0, 2339.0]], [[98.0, 2247.0], [152.0, 2247.0], [152.0, 2346.0], [98.0, 2346.0]]], "lines": ["．．．", "昨日", "５３話", "第"]}], "img_path": "00007.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [461, 864, 604, 1073], "vertical": true, "font_size": 59, "lines_coords": [[[531.0, 864.0], [588.0, 864.0], [588.0, 1073.0], [531.0