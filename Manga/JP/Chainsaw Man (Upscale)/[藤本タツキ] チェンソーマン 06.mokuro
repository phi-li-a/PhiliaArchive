{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 06", "volume_uuid": "0bb9d052-73d1-4edd-a0f6-52132358b485", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [121, 23, 1106, 466], "vertical": false, "font_size": 401, "lines_coords": [[[121.0, 65.0], [1089.0, 23.0], [1106.0, 424.0], [138.0, 466.0]]], "lines": ["．．．"]}, {"box": [9, 848, 216, 1512], "vertical": true, "font_size": 99, "lines_coords": [[[168.0, 878.0], [208.0, 878.0], [208.0, 1251.0], [168.0, 1251.0]], [[35.0, 848.0], [192.0, 855.0], [166.0, 1375.0], [9.0, 1368.0]]], "lines": ["ＴａｒｓｕｋｉＦｕｍｍｏｒｏ", "藤本タッ"]}, {"box": [60, 2274, 477, 2358], "vertical": false, "font_size": 59, "lines_coords": [[[77.0, 2282.0], [466.0, 2277.0], [466.0, 2341.0], [77.0, 2346.0]]], "lines": ["ＪＵＭＰ．ＣＯＭＩＣＳ"]}, {"box": [82, 2015, 817, 2303], "vertical": false, "font_size": 91, "lines_coords": [[[102.0, 2007.0], [819.0, 2216.0], [796.0, 2310.0], [79.0, 2102.0]]], "lines": ["Ｃｈａｉｎｓｏｗｍａｎ"]}, {"box": [1200, 2264, 1504, 2337], "vertical": false, "font_size": 55, "lines_coords": [[[1211.0, 2270.0], [1485.0, 2270.0], [1485.0, 2330.0], [1211.0, 2330.0]]], "lines": ["パンパンバン"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [131, 2167, 1394, 2271], "vertical": false, "font_size": 40.0, "lines_coords": [[[131.0, 2167.0], [1394.0, 2167.0], [1394.0, 2207.0], [131.0, 2207.0]], [[131.0, 2231.0], [1389.0, 2231.0], [1389.0, 2271.0], [131.0, 2271.0]]], "lines": ["★この作品はフィクションです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [41, 34, 591, 128], "vertical": false, "font_size": 80, "lines_coords": [[[60.0, 30.0], [569.0, 42.0], [567.0, 128.0], [58.0, 117.0]]], "lines": ["ＪｕＭＰ．ＣＯＭＩＣＳで"]}, {"box": [360, 1776, 656, 1905], "vertical": false, "font_size": 113, "lines_coords": [[[360.0, 1792.0], [649.0, 1776.0], [656.0, 1889.0], [367.0, 1905.0]]], "lines": ["チェン"]}, {"box": [618, 2090, 862, 2139], "vertical": false, "font_size": 49, "lines_coords": [[[618.0, 2090.0], [862.0, 2090.0], [862.0, 2139.0], [618.0, 2139.0]]], "lines": ["【パンパンバン】"]}, {"box": [541, 2163, 942, 2294], "vertical": false, "font_size": 127, "lines_coords": [[[541.0, 2167.0], [939.0, 2163.0], [942.0, 2289.0], [543.0, 2294.0]]], "lines": ["藤本タツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [705, 119, 1413, 194], "vertical": false, "font_size": 70, "lines_coords": [[[705.0, 119.0], [1413.0, 124.0], [1413.0, 194.0], [705.0, 189.0]]], "lines": ["ＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [119, 382, 302, 457], "vertical": false, "font_size": 75, "lines_coords": [[[119.0, 382.0], [302.0, 382.0], [302.0, 457.0], [119.0, 457.0]]], "lines": ["デンジ"]}, {"box": [112, 510, 743, 702], "vertical": false, "font_size": 53, "lines_coords": [[[112.0, 515.0], [742.0, 510.0], [742.0, 583.0], [112.0, 588.0]], [[121.0, 592.0], [707.0, 592.0], [707.0, 639.0], [121.0, 639.0]], [[126.0, 658.0], [642.0, 653.0], [642.0, 693.0], [126.0, 698.0]]], "lines": ["相棒のポチタをそのの身に宿す、「チェンソー", "の悪魔」の少年。自分の欲望に正直。", "めて人並扱いしてくれたマキマが好き"]}, {"box": [1225, 1455, 1410, 1539], "vertical": false, "font_size": 80, "lines_coords": [[[1225.0, 1460.0], [1408.0, 1455.0], [1410.0, 1535.0], [1228.0, 1539.0]]], "lines": ["ポチタ"]}, {"box": [860, 1600, 1420, 1727], "vertical": false, "font_size": 61.0, "lines_coords": [[[1101.0, 1605.0], [1413.0, 1600.0], [1413.0, 1659.0], [1101.0, 1664.0]], [[860.0, 1659.0], [1420.0, 1664.0], [1420.0, 1727.0], [860.0, 1722.0]]], "lines": ["『チェンソーの悪魔』。", "デンジに心臓を与え、体の一部となる。"]}, {"box": [1232, 1910, 1408, 2144], "vertical": true, "font_size": 110, "lines_coords": [[[1333.0, 1910.0], [1408.0, 1910.0], [1408.0, 2144.0], [1333.0, 2144.0]], [[1232.0, 1924.0], [1326.0, 1924.0], [1326.0, 2055.0], [1232.0, 2055.0]]], "lines": ["．．．部・年生後の３の悪魔」", "マの忠デンジ"]}, {"box": [1197, 2158, 1359, 2184], "vertical": true, "font_size": 110, "lines_coords": [[[1197.0, 2158.0], [1359.0, 2158.0], [1359.0, 2184.0], [1197.0, 2184.0]]], "lines": ["「契約している"]}, {"box": [803, 1795, 1047, 1900], "vertical": false, "font_size": 75, "lines_coords": [[[803.0, 1821.0], [1040.0, 1821.0], [1040.0, 1896.0], [803.0, 1896.0]]], "lines": ["早川アキ"]}, {"box": [449, 1903, 724, 2207], "vertical": true, "font_size": 116, "lines_coords": [[[508.0, 1966.0], [712.0, 1954.0], [724.0, 2165.0], [520.0, 2177.0]], [[489.0, 1964.0], [576.0, 1980.0], [536.0, 2207.0], [449.0, 2191.0]], [[534.0, 1903.0], [672.0, 1903.0], [672.0, 1987.0], [534.0, 1987.0]]], "lines": ["取り仕切るミテリアスな女。髪の匂いを腕", "取引を入ることができました。", "安対魔特異４"]}, {"box": [524, 2043, 557, 2137], "vertical": true, "font_size": 116, "lines_coords": [[[524.0, 2043.0], [557.0, 2043.0], [557.0, 2137.0], [524.0, 2137.0]]], "lines": ["ティ魔"]}, {"box": [133, 1830, 278, 1889], "vertical": false, "font_size": 59, "lines_coords": [[[133.0, 1830.0], [278.0, 1830.0], [278.0, 1889.0], [133.0, 1889.0]]], "lines": ["マキマ"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1199, 228, 1414, 447], "vertical": false, "font_size": 55, "lines_coords": [[[1235.0, 271.0], [1408.0, 271.0], [1408.0, 349.0], [1235.0, 349.0]], [[1202.0, 351.0], [1403.0, 351.0], [1403.0, 391.0], [1202.0, 391.0]], [[1202.0, 396.0], [1385.0, 400.0], [1385.0, 447.0], [1202.0, 442.0]]], "lines": ["分勝手で暴走し", "がち。猫のニャー", "コが唯一の友達。"]}, {"box": [480, 213, 719, 571], "vertical": true, "font_size": 62, "lines_coords": [[[689.0, 243.0], [719.0, 243.0], [719.0, 445.0], [689.0, 445.0]], [[644.0, 213.0], [719.0, 220.0], [698.0, 508.0], [623.0, 501.0]], [[618.0, 232.0], [663.0, 227.0], [679.0, 382.0], [635.0, 386.0]], [[562.0, 225.0], [656.0, 225.0], [656.0, 464.0], [562.0, 464.0]], [[553.0, 241.0], [590.0, 232.0], [602.0, 283.0], [564.0, 292.0]], [[480.0, 220.0], [590.0, 213.0], [609.0, 564.0], [499.0, 571.0]], [[574.0, 464.0], [616.0, 464.0], [616.0, 494.0], [574.0, 494.0]]], "lines": ["の脆野価", "男の家的に姫野郎の姫野”人を", "思的の", "思われるお精同力を込むようにしているの", "え", "引っ込新人。いが、はその男していた姉妹。", "いた"]}, {"box": [96, 67, 435, 236], "vertical": false, "font_size": 169, "lines_coords": [[[96.0, 67.0], [435.0, 67.0], [435.0, 236.0], [96.0, 236.0]]], "lines": ["東山コベニ"]}, {"box": [1141, 735, 1492, 1057], "vertical": false, "font_size": 114, "lines_coords": [[[1204.0, 764.0], [1410.0, 764.0], [1410.0, 813.0], [1204.0, 813.0]], [[1242.0, 735.0], [1492.0, 883.0], [1392.0, 1057.0], [1141.0, 909.0]], [[1169.0, 806.0], [1230.0, 789.0], [1265.0, 925.0], [1204.0, 942.0]], [[1279.0, 789.0], [1415.0, 822.0], [1399.0, 892.0], [1263.0, 860.0]], [[1185.0, 902.0], [1298.0, 902.0], [1298.0, 1038.0], [1185.0, 1038.0]], [[1263.0, 916.0], [1317.0, 916.0], [1317.0, 1028.0], [1263.0, 1028.0]]], "lines": ["人に敵意はないが", "いや．．．なんですからないのか？？", "．．．なんの直い声", "おれられると", "そしまう緑の隊員", "まう以外の"]}, {"box": [796, 626, 1129, 754], "vertical": false, "font_size": 119, "lines_coords": [[[796.0, 635.0], [1129.0, 635.0], [1129.0, 754.0], [796.0, 754.0]]], "lines": ["天使の悪魔"]}, {"box": [501, 751, 740, 1031], "vertical": false, "font_size": 109, "lines_coords": [[[536.0, 754.0], [571.0, 759.0], [562.0, 825.0], [527.0, 817.0]], [[501.0, 752.0], [534.0, 752.0], [541.0, 918.0], [508.0, 918.0]], [[592.0, 796.0], [740.0, 796.0], [740.0, 993.0], [592.0, 993.0]], [[506.0, 921.0], [630.0, 925.0], [628.0, 977.0], [503.0, 972.0]], [[506.0, 960.0], [731.0, 965.0], [731.0, 1031.0], [506.0, 1026.0]]], "lines": ["異", "．．．特に重要な", "耳などとんでも泳ぐこさ、短時間さい", "とかでき、", "なら悪魔の姿にも。"]}, {"box": [192, 670, 468, 719], "vertical": false, "font_size": 49, "lines_coords": [[[192.0, 670.0], [468.0, 670.0], [468.0, 719.0], [192.0, 719.0]]], "lines": ["一ム（サメの魔人）"]}, {"box": [1188, 1218, 1457, 1554], "vertical": true, "font_size": 116, "lines_coords": [[[1263.0, 1450.0], [1399.0, 1450.0], [1399.0, 1492.0], [1263.0, 1492.0]], [[1209.0, 1406.0], [1251.0, 1399.0], [1265.0, 1490.0], [1223.0, 1497.0]], [[1195.0, 1275.0], [1235.0, 1275.0], [1235.0, 1497.0], [1195.0, 1497.0]], [[1188.0, 1242.0], [1434.0, 1218.0], [1457.0, 1476.0], [1211.0, 1500.0]]], "lines": ["上票がりがあ", "具．．．", "と思っている、によく悪い。", "映画でバイトする、何かとデンジに興味深々な少女。髪と繋がりがあ"]}, {"box": [838, 1190, 916, 1242], "vertical": false, "font_size": 47, "lines_coords": [[[838.0, 1195.0], [913.0, 1190.0], [916.0, 1237.0], [841.0, 1242.0]]], "lines": ["レゼ"]}, {"box": [459, 1253, 754, 1598], "vertical": false, "font_size": 153, "lines_coords": [[[508.0, 1284.0], [539.0, 1284.0], [539.0, 1328.0], [508.0, 1328.0]], [[459.0, 1293.0], [726.0, 1293.0], [726.0, 1598.0], [459.0, 1598.0]], [[564.0, 1263.0], [742.0, 1253.0], [754.0, 1476.0], [576.0, 1485.0]], [[553.0, 1455.0], [714.0, 1455.0], [714.0, 1495.0], [553.0, 1495.0]]], "lines": ["特", "片足はまひるのおまりに俺をぶるたま、お母は海の影響をつけさせて頑張している。", "４歳の影景。わた愛すぎる言葉は誰のつけさせて", "肩をつけさせて"]}, {"box": [112, 1141, 425, 1265], "vertical": false, "font_size": 101, "lines_coords": [[[112.0, 1148.0], [173.0, 1141.0], [187.0, 1258.0], [126.0, 1265.0]], [[166.0, 1176.0], [417.0, 1176.0], [417.0, 1260.0], [166.0, 1260.0]]], "lines": ["暴", "人力の魔人"]}, {"box": [142, 1760, 442, 1809], "vertical": false, "font_size": 49, "lines_coords": [[[142.0, 1760.0], [442.0, 1760.0], [442.0, 1809.0], [142.0, 1809.0]]], "lines": ["ＳＴＯＲＹ－"]}, {"box": [138, 1858, 1408, 2271], "vertical": false, "font_size": 42, "lines_coords": [[[806.0, 1867.0], [1408.0, 1860.0], [1408.0, 1915.0], [806.0, 1922.0]], [[817.0, 1923.0], [1396.0, 1923.0], [1396.0, 1962.0], [817.0, 1962.0]], [[820.0, 1975.0], [1235.0, 1975.0], [1235.0, 2013.0], [820.0, 2013.0]], [[836.0, 2019.0], [1399.0, 2019.0], [1399.0, 2065.0], [836.0, 2065.0]], [[817.0, 2073.0], [1401.0, 2073.0], [1401.0, 2119.0], [817.0, 2119.0]], [[817.0, 2122.0], [1401.0, 2122.0], [1401.0, 2168.0], [817.0, 2168.0]], [[815.0, 2174.0], [1396.0, 2174.0], [1396.0, 2220.0], [815.0, 2220.0]], [[138.0, 2225.0], [1387.0, 2225.0], [1387.0, 2271.0], [138.0, 2271.0]]], "lines": ["だけど誰も話してるんだ奴からの言い捨てるので、", "勝利を収める。一方のデートシンはサムライソードと再乗人移行の", "成果を発揮し、リペンジを果たすのだったけど、", "お客様の人というのは、特別の場合、以前の状況についておりましたが、", "向け動き始める。そんな中、．．．えっと、デンジはミステリアスな少女しせ", "いいよ．．．こんなと出会う。２人で夜の学校に忍び込み、ドキドキが止まらない", "こちらのデータベースでは、デンジだが、レゼには悪魔との繋がりしかし．．．追いつかった迫る危機を知る", "だ姫野が終復していた「静霊の悪魔」２０１８年の出現に怒りを燃やす。こ、出せなく、「以前でやめて私に満たう」と言われましたが、"]}, {"box": [135, 1870, 724, 2224], "vertical": false, "font_size": 41.285714285714285, "lines_coords": [[[157.0, 1870.0], [724.0, 1872.0], [724.0, 1912.0], [157.0, 1910.0]], [[138.0, 1921.0], [721.0, 1921.0], [721.0, 1961.0], [138.0, 1961.0]], [[135.0, 1973.0], [721.0, 1973.0], [721.0, 2013.0], [135.0, 2013.0]], [[138.0, 2025.0], [714.0, 2025.0], [714.0, 2064.0], [138.0, 2064.0]], [[140.0, 2081.0], [712.0, 2081.0], [712.0, 2114.0], [140.0, 2114.0]], [[140.0, 2132.0], [260.0, 2132.0], [260.0, 2165.0], [140.0, 2165.0]], [[149.0, 2160.0], [721.0, 2160.0], [721.0, 2224.0], [149.0, 2224.0]]], "lines": ["悪魔のボチタと共にデビルハンターとして暮らす少年・テンジ。", "借金返済のためこき使われる「海辺の日々を皆ごしていたところ、", "を、裏切りに合い残されてしまう。だが、ボチタがその命と引", "き換えにデンジを【チェンツこの悪魔」として蘇らせる！敵を", "皆殺しにしたデンジは、ごマキマに拾われ公安のデビルハンターと", "なるのだった。", "２０１６年３月、カラノリーや「新潟市東京都市北区北海道学院で会員は、ありません。"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [719, 1448, 1121, 1504], "vertical": false, "font_size": 53, "lines_coords": [[[719.0, 1444.0], [1103.0, 1449.0], [1103.0, 1506.0], [719.0, 1501.0]]], "lines": ["ＣＯＮＴＥＮＴＳ"]}, {"box": [711, 1539, 1413, 2287], "vertical": false, "font_size": 189, "lines_coords": [[[902.0, 1553.0], [937.0, 1546.0], [946.0, 1615.0], [911.0, 1624.0]], [[998.0, 1546.0], [1324.0, 1541.0], [1324.0, 1624.0], [998.0, 1629.0]], [[822.0, 1543.0], [862.0, 1543.0], [862.0, 1793.0], [822.0, 1793.0]], [[1033.0, 1618.0], [1216.0, 1618.0], [1216.0, 1720.0], [1033.0, 1720.0]], [[874.0, 1536.0], [906.0, 1536.0], [906.0, 1971.0], [874.0, 1971.0]], [[1047.0, 1717.0], [1349.0, 1712.0], [1349.0, 1788.0], [1047.0, 1793.0]], [[1005.0, 1597.0], [1045.0, 1597.0], [1042.0, 1922.0], [1003.0, 1922.0]], [[960.0, 1541.0], [1007.0, 1541.0], [1007.0, 2016.0], [960.0, 2016.0]], [[1087.0, 1811.0], [1131.0, 1811.0], [1131.0, 1870.0], [1087.0, 1870.0]], [[735.0, 1529.0], [766.0, 1529.0], [766.0, 2299.0], [735.0, 2299.0]], [[984.0, 1893.0], [1281.0, 1893.0], [1281.0, 1959.0], [984.0, 1959.0]], [[820.0, 1754.0], [853.0, 1754.0], [855.0, 2199.0], [822.0, 2199.0]], [[967.0, 1970.0], [1310.0, 1970.0], [1310.0, 2051.0], [967.0, 2051.0]], [[862.0, 1918.0], [911.0, 1916.0], [923.0, 2133.0], [874.0, 2135.0]], [[967.0, 2059.0], [1314.0, 2057.0], [1314.0, 2131.0], [967.0, 2133.0]], [[775.0, 2052.0], [820.0, 2047.0], [834.0, 2220.0], [789.0, 2224.0]], [[871.0, 2141.0], [1349.0, 2139.0], [1349.0, 2215.0], [871.0, 2217.0]], [[799.0, 2230.0], [864.0, 2230.0], [864.0, 2295.0], [799.0, 2295.0]], [[848.0, 2223.0], [1413.0, 2223.0], [1413.0, 2304.0], [848.0, 2304.0]]], "lines": ["ありがとうございます", "「．．．パンバンパン」の模発目測．．．", "いいよいようによねえ", "パンパン１パン担美日和店殺しのメロディ", "いや．．．なんですかわからないのか？", "最発日和『ｅｒ皆殺しのメロディ』のご家標。ｏｘ", "けっこうなった事だったんだなあああっ", "．．．オンションはこんなことだった！！", "愛しのメロ軍”のｅ？イボンボン", "．．．！！", "「女連．．．。」ボンボンがンポン。。。い、サメバリケーン、バンスの", "こうしているのですけど、それではないですよ", "ポンポンボンｏｐや１サメハリケーン．．．シャークネード", "ほら．．．はいはいっ", "「サメハリケーン・ｐｏ」シャークネード「ダークダイビング」", "そよりそういえらえええ", "６月２１：シャークネード，０００円前、ダークダイビング・お客様、ポーツメールのご", "第５１話第５２話！", "Ｓｌａｍダークダイセング．．．５２コ南に共演・花・テェンツーーの"]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [452, 82, 754, 135], "vertical": false, "font_size": 49, "lines_coords": [[[452.0, 82.0], [754.0, 86.0], [754.0, 135.0], [452.0, 131.0]]], "lines": ["バンバンパン"]}, {"box": [203, 215, 360, 389], "vertical": true, "font_size": 50, "lines_coords": [[[297.0, 215.0], [360.0, 220.0], [356.0, 314.0], [292.0, 311.0]], [[255.0, 225.0], [297.0, 225.0], [297.0, 389.0], [255.0, 389.0]], [[203.0, 220.0], [248.0, 220.0], [248.0, 309.0], [203.0, 309.0]]], "lines": ["そこ", "だったら", "．．．．．．"]}, {"box": [1160, 543, 1334, 752], "vertical": true, "font_size": 44, "lines_coords": [[[12