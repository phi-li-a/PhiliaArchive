.0], [843.0, 1497.0], [843.0, 1825.0], [803.0, 1825.0]], [[740.0, 1500.0], [780.0, 1500.0], [780.0, 1905.0], [740.0, 1905.0]], [[681.0, 1497.0], [724.0, 1497.0], [721.0, 1989.0], [679.0, 1989.0]], [[630.0, 1502.0], [670.0, 1502.0], [670.0, 1950.0], [630.0, 1950.0]], [[569.0, 1497.0], [609.0, 1497.0], [609.0, 2025.0], [569.0, 2025.0]]], "lines": ["ヒトデは海のほとんどの", "生き物を食べる事ができて", "胃袋を吐き出して", "口の代わりにして食べるんだよ", "ちなみに熊本県の", "一部地域ではヒトデが", "食べられていてウニの仲間", "だけあってウニみたいに", "皮膚を剥いて食べるんだって"]}], "img_path": "00012.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1052, 189, 1294, 461], "vertical": true, "font_size": 49, "lines_coords": [[[1230.0, 194.0], [1277.0, 194.0], [1277.0, 461.0], [1230.0, 461.0]], [[1167.0, 189.0], [1216.0, 189.0], [1220.0, 419.0], [1171.0, 419.0]], [[1117.0, 196.0], [1169.0, 196.0], [1169.0, 372.0], [1117.0, 372.0]], [[1052.0, 189.0], [1101.0, 189.0], [1101.0, 417.0], [1052.0, 417.0]]], "lines": ["ヒトデの話は", "もういいよ", "ペンギン", "見てえよ俺"]}, {"box": [51, 133, 531, 491], "vertical": true, "font_size": 52, "lines_coords": [[[475.0, 138.0], [524.0, 138.0], [524.0, 339.0], [475.0, 339.0]], [[396.0, 133.0], [454.0, 133.0], [449.0, 346.0], [391.0, 346.0]], [[330.0, 135.0], [386.0, 135.0], [386.0, 342.0], [330.0, 342.0]], [[253.0, 135.0], [299.0, 135.0], [304.0, 445.0], [257.0, 445.0]], [[192.0, 142.0], [239.0, 142.0], [239.0, 489.0], [192.0, 489.0]], [[110.0, 138.0], [171.0, 138.0], [171.0, 292.0], [110.0, 292.0]], [[51.0, 140.0], [98.0, 140.0], [98.0, 440.0], [51.0, 440.0]]], "lines": ["ヒトデは", "海外でも", "だいたい", "星系の名前を", "つけられていて", "例えば", "フランスでは"]}, {"box": [742, 635, 841, 799], "vertical": true, "font_size": 64, "lines_coords": [[[742.0, 635.0], [841.0, 635.0], [841.0, 799.0], [742.0, 799.0]]], "lines": ["駄目"]}, {"box": [646, 890, 923, 1101], "vertical": true, "font_size": 64, "lines_coords": [[[867.0, 892.0], [923.0, 892.0], [923.0, 1101.0], [867.0, 1101.0]], [[789.0, 890.0], [846.0, 890.0], [846.0, 1101.0], [789.0, 1101.0]], [[7