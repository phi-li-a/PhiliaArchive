{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 14", "volume_uuid": "357b47ed-9c62-4377-9cf3-2bf65b56c3e1", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [187, 44, 677, 426], "vertical": false, "font_size": 307, "lines_coords": [[[187.0, 124.0], [621.0, 44.0], [677.0, 346.0], [243.0, 426.0]]], "lines": ["．．．"]}, {"box": [114, 466, 489, 522], "vertical": false, "font_size": 56, "lines_coords": [[[114.0, 466.0], [489.0, 466.0], [489.0, 522.0], [114.0, 522.0]]], "lines": ["マンギンが見たのに"]}, {"box": [262, 719, 304, 878], "vertical": true, "font_size": 42, "lines_coords": [[[262.0, 719.0], [304.0, 719.0], [304.0, 878.0], [262.0, 878.0]]], "lines": ["．．．"]}, {"box": [264, 1059, 297, 1399], "vertical": true, "font_size": 33, "lines_coords": [[[264.0, 1059.0], [297.0, 1059.0], [297.0, 1399.0], [264.0, 1399.0]]], "lines": ["そういうのは、"]}, {"box": [18, 1450, 609, 1612], "vertical": false, "font_size": 167, "lines_coords": [[[145.0, 1445.0], [609.0, 1445.0], [609.0, 1627.0], [145.0, 1627.0]]], "lines": ["．．．"]}, {"box": [52, 1614, 427, 1666], "vertical": false, "font_size": 55, "lines_coords": [[[53.0, 1609.0], [414.0, 1609.0], [414.0, 1669.0], [53.0, 1669.0]]], "lines": ["４０１ｓｕｋｉＦｕｊｉｍｏｒｏ"]}, {"box": [40, 2268, 581, 2351], "vertical": false, "font_size": 68, "lines_coords": [[[63.0, 2269.0], [478.0, 2265.0], [478.0, 2342.0], [63.0, 2347.0]], [[452.0, 2274.0], [581.0, 2274.0], [581.0, 2345.0], [452.0, 2345.0]]], "lines": ["ＪＵＭＰ．ＣＯＭＩＣＳ", "；Ｓ"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [135, 2172, 1389, 2268], "vertical": false, "font_size": 33.0, "lines_coords": [[[138.0, 2172.0], [1385.0, 2172.0], [1385.0, 2205.0], [138.0, 2205.0]], [[135.0, 2235.0], [1389.0, 2235.0], [1389.0, 2268.0], [135.0, 2268.0]]], "lines": ["★この作品はフィクシヨンです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [45, 39, 587, 128], "vertical": false, "font_size": 79, "lines_coords": [[[60.0, 42.0], [581.0, 42.0], [581.0, 128.0], [60.0, 128.0]]], "lines": ["ＪＵＭＰ．ＣＯＭＩＣＳで、"]}, {"box": [567, 2085, 892, 2139], "vertical": false, "font_size": 50, "lines_coords": [[[567.0, 2090.0], [892.0, 2085.0], [892.0, 2135.0], [567.0, 2139.0]]], "lines": ["【ペンギンが見たい！】"]}, {"box": [541, 2163, 946, 2296], "vertical": false, "font_size": 133, "lines_coords": [[[541.0, 2163.0], [946.0, 2163.0], [946.0, 2296.0], [541.0, 2296.0]]], "lines": ["藤本タツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [707, 121, 1417, 194], "vertical": false, "font_size": 73, "lines_coords": [[[707.0, 121.0], [1417.0, 121.0], [1417.0, 194.0], [707.0, 194.0]]], "lines": ["ＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [956, 412, 1272, 595], "vertical": false, "font_size": 183, "lines_coords": [[[956.0, 412.0], [1272.0, 412.0], [1272.0, 595.0], [956.0, 595.0]]], "lines": ["三鷹アサ"]}, {"box": [890, 501, 1743, 1350], "vertical": false, "font_size": 489, "lines_coords": [[[890.0, 998.0], [1403.0, 501.0], [1743.0, 853.0], [1230.0, 1350.0]]], "lines": ["．．．そうですか．．"]}, {"box": [1014, 621, 1307, 963], "vertical": true, "font_size": 95, "lines_coords": [[[1253.0, 621.0], [1307.0, 635.0], [1274.0, 771.0], [1220.0, 757.0]], [[1197.0, 703.0], [1232.0, 703.0], [1232.0, 766.0], [1197.0, 766.0]], [[1160.0, 693.0], [1209.0, 700.0], [1188.0, 839.0], [1138.0, 832.0]], [[1176.0, 761.0], [1242.0, 754.0], [1265.0, 956.0], [1199.0, 963.0]], [[1120.0, 710.0], [1162.0, 710.0], [1162.0, 825.0], [1120.0, 825.0]], [[1080.0, 703.0], [1129.0, 700.0], [1136.0, 911.0], [1087.0, 914.0]], [[1040.0, 642.0], [1089.0, 639.0], [1101.0, 953.0], [1052.0, 956.0]], [[1014.0, 625.0], [1056.0, 625.0], [1056.0, 766.0], [1014.0, 766.0]]], "lines": ["陰いな", "独", "孤襲", "われ悪魔生き", "るに", "け魔”争", "に受悪戦っ", "校を"]}, {"box": [981, 623, 1199, 1019], "vertical": true, "font_size": 95, "lines_coords": [[[1169.0, 848.0], [1192.0, 843.0], [1199.0, 890.0], [1176.0, 895.0]], [[981.0, 623.0], [1021.0, 623.0], [1021.0, 1019.0], [981.0, 1019.0]]], "lines": ["悪", "学め義がを．．．"]}, {"box": [953, 885, 1441, 1235], "vertical": true, "font_size": 95, "lines_coords": [[[1239.0, 907.0], [1277.0, 907.0], [1277.0, 963.0], [1239.0, 963.0]], [[1167.0, 921.0], [1206.0, 904.0], [1225.0, 956.0], [1185.0, 972.0]], [[1134.0, 928.0], [1167.0, 907.0], [1192.0, 946.0], [1160.0, 967.0]], [[1078.0, 914.0], [1141.0, 909.0], [1143.0, 946.0], [1080.0, 951.0]], [[1007.0, 892.0], [1042.0, 885.0], [1059.0, 984.0], [1024.0, 991.0]], [[1017.0, 977.0], [1049.0, 977.0], [1049.0, 1014.0], [1017.0, 1014.0]], [[953.0, 1024.0], [1431.0, 984.0], [1441.0, 1106.0], [963.0, 1146.0]], [[974.0, 1101.0], [1420.0, 1089.0], [1422.0, 1155.0], [977.0, 1167.0]], [[970.0, 1129.0], [1162.0, 1129.0], [1162.0, 1235.0], [970.0, 1235.0]]], "lines": ["返", "ま", "え", "取ら", "天井", "を", "アンターファンストラップアップデートは、", "遅れていると、これだけに", "思っていない苦戦中！！！"]}, {"box": [155, 1642, 556, 1730], "vertical": false, "font_size": 49, "lines_coords": [[[346.0, 1642.0], [496.0, 1642.0], [496.0, 1675.0], [346.0, 1675.0]], [[157.0, 1664.0], [543.0, 1659.0], [543.0, 1725.0], [157.0, 1729.0]]], "lines": ["んそうああく", "ヨル（戦争の悪魔"]}, {"box": [431, 1867, 553, 1954], "vertical": true, "font_size": 90, "lines_coords": [[[492.0, 1867.0], [553.0, 1898.0], [524.0, 1954.0], [464.0, 1924.0]], [[431.0, 1912.0], [471.0, 1877.0], [499.0, 1907.0], [459.0, 1942.0]]], "lines": ["エン", "メ"]}, {"box": [410, 1818, 550, 2064], "vertical": true, "font_size": 90, "lines_coords": [[[410.0, 2017.0], [449.0, 2017.0], [449.0, 2064.0], [410.0, 2064.0]], [[480.0, 1818.0], [550.0, 1818.0], [550.0, 1867.0], [480.0, 1867.0]]], "lines": ["の", "姿を"]}, {"box": [440, 1947, 553, 2203], "vertical": true, "font_size": 90, "lines_coords": [[[513.0, 1947.0], [553.0, 1947.0], [553.0, 2196.0], [513.0, 2196.0]], [[480.0, 1947.0], [520.0, 1947.0], [520.0, 2196.0], [480.0, 2196.0]], [[445.0, 1973.0], [487.0, 1973.0], [482.0, 2203.0], [440.0, 2203.0]]], "lines": ["サを器は社", "ア分武間", "半を一人"]}, {"box": [283, 1814, 492, 2146], "vertical": true, "font_size": 90, "lines_coords": [[[360.0, 1821.0], [489.0, 1814.0], [492.0, 1865.0], [363.0, 1872.0]], [[323.0, 1867.0], [372.0, 1865.0], [377.0, 2006.0], [328.0, 2008.0]], [[288.0, 1882.0], [330.0, 1882.0], [325.0, 2146.0], [283.0, 2146.0]], [[321.0, 2088.0], [419.0, 2088.0], [419.0, 2130.0], [321.0, 2130.0]]], "lines": ["のような", "悪す", "の殺”取霊殺", "したも"]}, {"box": [332, 2017, 449, 2125], "vertical": true, "font_size": 90, "lines_coords": [[[414.0, 2092.0], [449.0, 2092.0], [449.0, 2125.0], [414.0, 2125.0]], [[332.0, 2017.0], [419.0, 2017.0], [419.0, 2074.0], [332.0, 2074.0]]], "lines": ["の", "って脳"]}, {"box": [171, 1814, 264, 2069], "vertical": true, "font_size": 90, "lines_coords": [[[185.0, 2008.0], [222.0, 2008.0], [222.0, 2069.0], [185.0, 2069.0]], [[173.0, 1814.0], [264.0, 1818.0], [262.0, 1872.0], [171.0, 1867.0]]], "lines": ["を", "はフ！"]}, {"box": [168, 1814, 335, 2151], "vertical": true, "font_size": 90, "lines_coords": [[[262.0, 1935.0], [299.0, 1942.0], [288.0, 2003.0], [250.0, 1996.0]], [[217.0, 1912.0], [295.0, 1928.0], [246.0, 2151.0], [168.0, 2135.0]], [[241.0, 1814.0], [335.0, 1814.0], [335.0, 1954.0], [241.0, 1954.0]], [[220.0, 1863.0], [262.0, 1863.0], [262.0, 1945.0], [220.0, 1945.0]]], "lines": ["を", "マンをを乗っした", "クロのクロ争の", "戦"]}, {"box": [56, 1785, 496, 2339], "vertical": true, "font_size": 90, "lines_coords": [[[128.0, 2003.0], [496.0, 2139.0], [424.0, 2339.0], [56.0, 2203.0]], [[105.0, 1785.0], [203.0, 1785.0], [203.0, 1964.0], [105.0, 1964.0]]], "lines": ["おいおいしいですから．．．あの、これからもいいの", "本来にした、"]}, {"box": [140, 2224, 503, 2257], "vertical": true, "font_size": 90, "lines_coords": [[[140.0, 2224.0], [503.0, 2224.0], [503.0, 2257.0], [140.0, 2257.0]]], "lines": ["それでも、どうしてい"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [386, 278, 681, 447], "vertical": true, "font_size": 95, "lines_coords": [[[414.0, 330.0], [681.0, 330.0], [681.0, 386.0], [414.0, 386.0]], [[389.0, 309.0], [438.0, 309.0], [438.0, 447.0], [389.0, 447.0]], [[386.0, 278.0], [677.0, 278.0], [677.0, 318.0], [386.0, 318.0]]], "lines": ["彼女として生みしく", "高戦", "その後誰に言う、チェ"]}, {"box": [224, 119, 681, 203], "vertical": false, "font_size": 73, "lines_coords": [[[224.0, 131.0], [679.0, 119.0], [681.0, 192.0], [227.0, 203.0]]], "lines": ["デンジ（ァェンソーマン）"]}, {"box": [325, 375, 459, 550], "vertical": true, "font_size": 95, "lines_coords": [[[337.0, 375.0], [372.0, 377.0], [360.0, 550.0], [325.0, 548.0]], [[419.0, 426.0], [440.0, 405.0], [459.0, 424.0], [438.0, 445.0]]], "lines": ["．．．魔の", "＞"]}, {"box": [199, 246, 428, 569], "vertical": true, "font_size": 95, "lines_coords": [[[311.0, 255.0], [398.0, 246.0], [428.0, 510.0], [342.0, 520.0]], [[292.0, 262.0], [342.0, 262.0], [342.0, 569.0], [292.0, 569.0]], [[264.0, 440.0], [297.0, 440.0], [297.0, 567.0], [264.0, 567.0]], [[199.0, 328.0], [309.0, 328.0], [309.0, 464.0], [199.0, 464.0]]], "lines": ["それを魔法は「というのは魔族としての", "悪普悪安心配", "『ハムレ支", "マン。密かに"]}, {"box": [112, 330, 316, 689], "vertical": true, "font_size": 95, "lines_coords": [[[185.0, 492.0], [241.0, 492.0], [241.0, 567.0], [185.0, 567.0]], [[128.0, 330.0], [187.0, 332.0], [171.0, 689.0], [112.0, 686.0]], [[164.0, 583.0], [192.0, 583.0], [192.0, 621.0], [164.0, 621.0]], [[164.0, 651.0], [316.0, 651.0], [316.0, 677.0], [164.0, 677.0]]], "lines": ["ら、", "ソらいカップがて～辺～悪～託", "麻鹿", "さわたか．．．。"]}, {"box": [951, 1396, 1258, 1481], "vertical": false, "font_size": 73, "lines_coords": [[[951.0, 1408.0], [1256.0, 1396.0], [1258.0, 1469.0], [953.0, 1481.0]]], "lines": ["吉田ヒロフミ"]}, {"box": [813, 1521, 1401, 1639], "vertical": false, "font_size": 40, "lines_coords": [[[815.0, 1537.0], [1401.0, 1532.0], [1401.0, 1572.0], [815.0, 1577.0]], [[813.0, 1593.0], [1047.0, 1598.0], [1047.0, 1638.0], [813.0, 1633.0]]], "lines": ["とある組織に所属するデビルハンター。デンジ", "の正体を隠したい。"]}, {"box": [275, 1357, 609, 1497], "vertical": false, "font_size": 140, "lines_coords": [[[302.0, 1357.0], [609.0, 1357.0], [609.0, 1497.0], [302.0, 1497.0]]], "lines": ["俺の女子生徒"]}, {"box": [137, 1519, 717, 1639], "vertical": false, "font_size": 44, "lines_coords": [[[138.0, 1535.0], [717.0, 1535.0], [717.0, 1575.0], [138.0, 1575.0]], [[138.0, 1589.0], [314.0, 1589.0], [314.0, 1638.0], [138.0, 1638.0]]], "lines": ["デビルハンター部に所属。アサのことを「妹」", "と呼ぶ謎の女。"]}, {"box": [142, 1757, 424, 1814], "vertical": false, "font_size": 57, "lines_coords": [[[142.0, 1757.0], [424.0, 1757.0], [424.0, 1814.0], [142.0, 1814.0]]], "lines": ["ＳＴＯＲＹ－"]}, {"box": [820, 1854, 1406, 2263], "vertical": false, "font_size": 46, "lines_coords": [[[836.0, 1877.0], [1401.0, 1870.0], [1401.0, 1917.0], [836.0, 1924.0]], [[885.0, 1933.0], [1403.0, 1933.0], [1403.0, 1980.0], [885.0, 1980.0]], [[867.0, 1985.0], [1110.0, 1957.0], [1120.0, 2043.0], [876.0, 2071.0]], [[831.0, 2043.0], [991.0, 2043.0], [991.0, 2095.0], [831.0, 2095.0]], [[984.0, 2055.0], [1403.0, 2055.0], [1403.0, 2088.0], [984.0, 2088.0]], [[822.0, 2114.0], [1399.0, 2114.0], [1399.0, 2146.0], [822.0, 2146.0]], [[820.0, 2165.0], [1401.0, 2167.0], [1401.0, 2207.0], [820.0, 2205.0]], [[822.0, 2228.0], [1375.0, 2228.0], [1375.0, 2261.0], [822.0, 2261.0]]], "lines": ["できず、チェンソーマンの登場で事態はどうに", "まする。だが、逃亡したユウコは人知れず何", "に殺されてしまう．．．。", "アサの前に、", "チェンソーマンだと自称するデビ", "ルハンター部部長長が現れる。チェンソーマンを殺", "すための強い武器を作れとヨルに迫られ、アサは", "デンジをデートに誘い武器化しようと企むが．．．！？"]}, {"box": [522, 1872, 740, 1924], "vertical": false, "font_size": 44.0, "lines_coords": [[[663.0, 1872.0], [740.0, 1879.0], [735.0, 1924.0], [660.0, 1919.0]], [[522.0, 1877.0], [667.0, 1872.0], [667.0, 1914.0], [522.0, 1919.0]]], "lines": ["を受け、", "校でいじめを"]}, {"box": [135, 1872, 738, 2167], "vertical": false, "font_size": 40.0, "lines_coords": [[[159.0, 1872.0], [543.0, 1872.0], [543.0, 1919.0], [159.0, 1919.0]], [[135.0, 1926.0], [738.0, 1926.0], [738.0, 1982.0], [135.0, 1982.0]], [[138.0, 1994.0], [721.0, 1994.0], [721.0, 2034.0], [138.0, 2034.0]], [[135.0, 2053.0], [672.0, 2053.0], [672.0, 2092.0], [135.0, 2092.0]], [[135.0, 2109.0], [667.0, 2109.0], [667.0, 2149.0], [135.0, 2149.0]], [[639.0, 2149.0], [691.0, 2149.0], [691.0, 2167.0], [639.0, 2167.0]]], "lines": ["孤独な少女・三鷹アサは学校で", "さらに正義の言葉を実納した委員長の部分を買い、", "殺されてしまう。だが、戦争の悪魔・ヨルに体", "を奪われ復活！！チェンソーマンを探し出し、", "すことができれば体を返すとと言うヨルだが．．．！？", "．．．けいやく"]}, {"box": [140, 2172, 717, 2261], "vertical": false, "font_size": 33.0, "lines_coords": [[[161.0, 2172.0], [714.0, 2172.0], [714.0, 2205.0], [161.0, 2205.0]], [[140.0, 2228.0], [717.0, 2228.0], [717.0, 2261.0], [140.0, 2261.0]]], "lines": ["初めての友達・コウコが、正義の悪魔と契約し", "学校を襲撃。アサは暴走したコウコを止めること"]}, {"box": [267, 2151, 314, 2167], "vertical": false, "font_size": 16, "lines_coords": [[[267.0, 2151.0], [314.0, 2151.0], [314.0, 2167.0], [267.0, 2167.0]]], "lines": ["ともだち"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [696, 1368, 1080, 1415], "vertical": false, "font_size": 47, "lines_coords": [[[696.0, 1368.0], [1080.0, 1368.0], [1080.0, 1415.0], [696.0, 1415.0]]], "lines": ["ＣＯＮＴＥＮＴＳ"]}, {"box": [464, 1310, 1614, 2400], "vertical": false, "font_size": 165, "lines_coords": [[[721.0, 1447.0], [742.0, 1447.0], [742.0, 1498.0], [721.0, 1498.0]], [[705.0, 1449.0], [1422.0, 1445.0], [1422.0, 1538.0], [705.0, 1543.0]], [[981.0, 1606.0], [1066.0, 1606.0], [1066.0, 1669.0], [981.0, 1669.0]], [[1096.0, 1606.0], [1176.0, 1606.0], [1176.0, 1672.0], [1096.0, 1672.0]], [[831.0, 1618.0], [888.0, 1625.0], [874.0, 1758.0], [817.0, 1751.0]], [[831.0, 1576.0], [1359.0, 1576.0], [1359.0, 1838.0], [831.0, 1838.0]], [[843.0, 1702.0], [883.0, 1714.0], [869.0, 1793.0], [829.0, 1782.0]], [[1213.0, 1731.0], [1256.0, 1731.0], [1256.0, 1779.0], [1213.0, 1779.0]], [[878.0, 1799.0], [1345.0, 1801.0], [1345.0, 1878.0], [878.0, 1875.0]], [[478.0, 1295.0], [1527.0, 1309.0], [1527.0, 2399.0], [464.0, 2399.0]], [[689.0, 1913.0], [1199.0, 1627.0], [1375.0, 1972.0], [864.0, 2257.0]], [[838.0, 1876.0], [881.0, 1876.0], [876.0, 2131.0], [834.0, 2131.0]], [[1019.0, 1888.0], [1178.0, 1981.0], [1113.0, 2124.0], [953.0, 2030.0]], [[935.0, 1831.0], [1431.0, 1963.0], [1349.0, 2304.0], [853.0, 2173.0]], [[763.0, 2136.0], [902.0, 2136.0], [902.0, 2215.0], [763.0, 2215.0]], [[881.0, 2145.0], [1185.0, 2145.0], [1185.0, 2222.0], [881.0, 2222.0]], [[986.0, 2206.0], [1085.0, 2206.0], [1085.0, 2262.0], [986.0, 2262.0]], [[778.0, 2230.0], [939.0, 2230.0], [939.0, 2293.0], [778.0, 2293.0]], [[928.0, 2232.0], [1183.0, 2232.0], [1183.0, 2302.0], [928.0, 2302.0]]], "lines": ["「第」", "「第３１３話」ペンギンが見たい！！", "１エンドレ１今時の高", "ドレス水族の高校生", "１１３４８１１５８２１６８", "ありませーエンドレスを食べるときは、今年の東京では「ヒトテの事」の中国でバレベンギンとは違っています。", "１５８１１６話", "．．．", "そう言っとトラの味。２０１７年１ペンギンと武器．．．２年、電力の世界一の", "そのため、この時期には、", "それは．．．", "１７７２０１８年１１月１９日２０日土", "それのまま飛んでいい。トライアング", "そういうことで、今日は本当に自分の会員ではない会員には付き合っていただけました。それで、実際に", "第１３０話第１２１話１９９９年", "その割りトライアンの２１話１０年福島・の２つまり大予言", "幸福論美大予言", "第１２１話１２２話」７", "話Ｊ幸福田話】大予言．ｃｏ"]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [353, 99, 472, 353], "vertical": true, "font_size": 50, "lines_coords": [[[419.0, 105.0], [468.0, 105.0], [468.0, 353.0], [419.0, 353.0]], [[353.0, 100.0], [403.0, 100.0], [403.0, 307.0], [353.0, 307.0]]], "lines": ["ヘアピンは", "やめよ．．．"]}, {"box": [609, 1532, 850, 1591], "vertical": false, "font_size": 59, "lines_coords": [[[609.0, 1532.0], [850.0, 1532.0], [850.0, 1591.0], [609.0, 1591.0]]], "lines": ["第１１３話」"]}, {"box": [841, 1769, 918, 1942], "vertical": true, "font_size": 54, "lines_coords": [[[841.0, 1769.0], [918.0, 1769.0], [918.0, 1942.0], [841.0, 1942.0]]], "lines": ["地味な"]}, {"box": [773, 1774, 831, 1935], "vertical": true, "font_size": 54, "lines_coords": [[[773.0, 1774.0], [831.0, 1774.0], [831.0, 1935.0], [773.0, 1935.0]]], "lines": ["奴だな"]}, {"box": [714, 2039, 977, 2301], "vertical": true, "font_size": 54, "lines_coords": [[[928.0, 2039.0], [977.0, 2039.0], [977.0, 2200.0], [928.0, 2200.0]], [[846.0, 2039.0], [895.0, 2039.0], [895.0, 2250.0], [846.0, 2250.0]], [[782.0, 2039.0], [831.0, 2039.0], [831.0, 2301.0], [782.0, 2301.0]], [[714.0, 2041.0], [766.0, 2041.0], [766.0, 2196.0], [714.0, 2196.0]]], "lines": ["もっと", "花とかを", "ちりばめた", "ほうが"]}, {"box": [642, 2039, 707, 2301], "vertical": true, "font_size": 54, "lines_coords": [[[642.0, 2041.0], [698.0, 2039.0], [707.0, 2299.0], [651.0, 2301.0]]], "lines": ["いいんじゃ"]}, {"box": [588, 2046, 630, 2247], "vertical": true, "font_size": 54, "lines_coords": [[[588.0, 2046.0], [630.0, 2046.0], [630.0, 2247.0], [588.0, 2247.0]]], "lines": ["ないか？"]}, {"box": [222, 2104, 405, 2307], "vertical": true, "font_size": 53, "lines_coords": [[[360.0, 2107.0], [400.0, 2107.0], [400.0, 2303.0], [360.0, 2303.0]], [[283.0, 2107.0], [342.0, 2104.0], [349.0, 2261.0], [290.0, 2264.0]], [[222.0, 2109.0], [283.0, 2109.0], [283.0, 2264.0], [222.0, 2264.0]]], "lines": ["うるさい", "これで", "いいの"]}], "img_path": "00007.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1096, 96, 1434, 360], "vertical": true, "font_size": 53, "lines_coords": [[[1385.0, 100.0], [1434.0, 100.0], [1434.0, 353.0], [1385.0, 353.0]], [[1319.0, 103.0], [1368.0, 103.0], [1368.0, 356.0], [1319.0, 356.0]], [[1237.0, 96.0], [1293.0, 96.0], [1293.0, 360.0], [1237.0, 360.0]], [[1157.0, 98.0], [1216.0, 98.0], [1216.0, 257.0], [1157.0, 257.0]], [[1096.0, 100.0], [1146.0, 100.0], [1146.0, 360.0], [1096.0, 360.0]]], "lines": ["確かにあの", "チンピラに", "好かれれば", "武器に", "できるが．．．"]}, {"box": [396, 79, 589, 303], "vertical": true, "font_size": 62, "lines_coords": [[[539.0, 93.0], [588.0, 93.0], [588.0, 297.0], [539.0, 297.0]], [[454.0, 79.0], [539.0, 91.0], [522.0, 220.0], [438.0, 208.0]], [[400.0, 96.0], [452.0, 96.0], [447.0, 302.0], [396.0, 302.0]]], "lines": ["そんなの", "簡単", "でしょ？"]}, {"box": [180, 487, 258, 649], "vertical": true, "font_size": 59, "lines_coords": [[[180.0, 487.0], [239.0, 487.0], [239.0, 649.0], [180.0, 649.0]]], "lines": ["簡単？"]}, {"box": [1026, 442, 1223, 766], "vertical": true, "font_size": 53, "lines_coords": [[[1164.0, 445.0], [1223.0, 445.0], [1223.0, 611.0], [1164.0, 611.0]], [[1085.0, 442.0], [1141.0, 442.0], [1146.0, 663.0], [1089.0, 663.0]], [[1026.0, 447.0], [1075.0, 447.0], [1075.0, 766.0], [1026.0, 766.0]]], "lines": ["アサに", "惚れさせ", "られるのか？"]}, {"box": [126, 967, 486, 1291], "vertical": true, "font_size": 58, "lines_coords": [[[417.0, 972.0], [473.0, 972.0], [473.0, 1188.0], [417.0, 1188.0]], [[349.0, 967.0], [405.0, 967.0], [410.0, 1188.0], [353.0, 1188.0]], [[269.0, 972.0], [325.0, 972.0], [325.0, 1289.0], [269.0, 1289.0]], [[192.0, 975.0], [248.0, 975.0], [248.0, 1291.0], [192.0, 1291.0]], [[126.0, 977.0], [189.0, 977.0], [189.0, 1085.0], [126.0, 1085.0]]], "lines": ["男なんて", "ちょっと", "楽しませれば", "すぐ惚れるん", "だよ"]}, {"box": [885, 1516, 1007, 1729], "vertical": true, "font_size": 56, "lines_coords": [[[944.0, 1516.0], [1007.0, 1516.0], [1007.0, 1635.0], [944.0, 1635.0]], [[885.0, 1521.0], [935.0, 1521.0], [935.0, 1729.0], [885.0, 1729.0]]], "lines": ["そう", "なのか？"]}, {"box": [841, 1884, 1110, 2156], "vertical": true, "font_size": 54, "lines_coords": [[[1049.0, 1891.0], [1110.0, 1891.0], [1110.0, 2053.0], [1049.0, 2053.0]], [[977.0, 1884.0], [1035.0, 1884.0], [1031.0, 2156.0], [972.0, 2156.0]], [[911.0, 1891.0], [960.0, 1891.0], [960.0, 2149.0], [911.0, 2149.0]], [[848.0, 1889.0], [897.0, 1891.0], [890.0, 2097.0], [841.0, 2095.0]]], "lines": ["ヨルは", "悪魔だから", "わかんない", "だろうね"]}, {"box": [585, 2106, 641, 2280], "vertical": true, "font_size": 52, "lines_coords": [[[585.0, 2111.0], [637.0, 2111.0], [637.0, 2275.0], [585.0, 2275.0]]], "lines": ["ふうん"]}, {"box": [207, 2111, 325, 2289], "vertical": true, "font_size": 59, "lines_coords": [[[262.0, 2114.0], [321.0, 2111.0], [325.0, 2287.0], [267.0, 2289.0]]], "lines": ["それに"]}], "img_path": "00008.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [869, 203, 1151, 571], "vertical": true, "font_size": 80, "lines_coords": [[[1045.0, 206.0], [1141.0, 203.0], [1146.0, 438.0], [1049.0, 440.0]], [[974.0, 215.0], [1040.0, 215.0], [1040.0, 503.0], [974.0, 503.0]], [[869.0, 215.0], [946.0, 215.0], [946.0, 571.0], [869.0, 571.0]]], "lines": ["私って", "そこそこ", "可愛いから"]}, {"box": [824, 1710, 1230, 2142], "vertical": true, "font_size": 101, "lines_coords": [[[1141.0, 1717.0], [1230.0, 1717.0], [1230.0, 2053.0], [1141.0, 2053.0]], [[1014.0, 1713.0], [1129.0, 1710.0], [1134.0, 1978.0], [1019.0, 1980.0]], [[911.0, 1710.0], [1017.0, 1710.0], [1012.0, 2142.0], [906.0, 2142.0]], [[824.0, 1720.0], [916.0, 1720.0], [916.0, 1973.0], [824.0, 1973.0]]], "lines": ["ちょっと", "遊べば", "すぐ惚れる", "でしょ"]}, {"box": [164, 1856, 372, 1905], "vertical": false, "font_size": 33, "lines_coords": [[[164.0, 1872.0], [370.0, 1856.0], [372.0, 1889.0], [166.0, 1905.0]]], "lines": ["ＴａｎａｓｈｉＡｃｕａｒｌｉｎ"]}], "img_path": "00009.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [599, 199, 970, 578], "vertical": true, "font_size": 38, "lines_coords": [[[930.0, 203.0], [970.0, 203.0], [970.0, 501.0], [930.0, 501.0]], [[871.0, 201.0], [913.0, 201.0], [918.0, 466.0], [876.0, 466.0]], [[817.0, 201.0], [857.0, 201.0], [860.0, 574.0], [820.0, 574.0]], [[763.0, 201.0], [803.0, 201.0], [803.0, 464.0], [763.0, 464.0]], [[712.0, 206.0], [745.0, 206.0], [745.0, 574.0], [712.0, 574.0]], [[653.0, 201.0], [693.0, 201.0], [693.0, 391.0], [653.0, 391.0]], [[602.0, 206.0], [635.0, 206.0], [635.0, 536.0], [602.0, 536.0]]], "lines": ["イソギンチャクは", "クラゲの仲間で", "生えている細かい毛で", "魚とかエビとか", "動物性プランクトンを", "痺れさせて", "食べているんだって"]}, {"box": [562, 789, 991, 1166], "vertical": true, "font_size": 38, "lines_coords": [[[932.0, 794.0], [972.0, 794.0], [972.0, 1164.0], [932.0, 1164.0]], [[874.0, 794.0], [913.0, 794.0], [913.0, 1089.0], [874.0, 1089.0]], [[831.0, 796.0], [864.0, 796.0], [864.0, 1162.0], [831.0, 1162.0]], [[773.0, 794.0], [813.0, 794.0], [813.0, 979.0], [773.0, 979.0]], [[717.0, 789.0], [759.0, 789.0], [756.0, 1127.0], [714.0, 1127.0]], [[660.0, 794.0], [700.0, 794.0], [700.0, 982.0], [660.0, 982.0]], [[602.0, 789.0], [642.0, 789.0], [642.0, 1017.0], [602.0, 1017.0]], [[564.0, 796.0], [597.0, 796.0], [597.0, 1014.0], [564.0, 1014.0]]], "lines": ["でも何も食べなくても", "何年も生きる事が", "できてそこはクラゲと", "一緒だよね", "ちゃんと世話すれば", "７０年以上も", "生きた個体も", "いるんだって"]}, {"box": [557, 1530, 1095, 2028], "vertical": true, "font_size": 46, "lines_coords": [[[1033.0, 1530.0], [1080.0, 1530.0], [1078.0, 1907.0], [1031.0, 1907.0]], [[974.0, 1535.0], [1014.0, 1535.0], [1014.0, 2025.0], [974.0, 2025.0]], [[904.0, 1530.0], [953.0, 1530.0], [958.0, 1863.0], [909.0, 1863.0]], [[848.0, 1532.0], [895.0, 1532.0], [895.0, 1945.0], [848.0, 1945.0]], [[785.0, 1530.0], [831.0, 1530.0], [831.0, 1940.0], [785.0, 1940.0]], [[728.0, 1532.0], [775.0, 1532.0], [775.0, 1867.0], [728.0, 1867.0]], [[665.0, 1532.0], [712.0, 1532.0], [712.0, 2027.0], [665.0, 2027.0]], [[606.0, 1535.0], [653.0, 1535.0], [653.0, 1865.0], [606.0, 1865.0]], [[557.0, 1537.0], [597.0, 1537.0], [597.0, 1903.0], [557.0, 1903.0]]], "lines": ["世界中どこの海にも", "生息していてゆっくり体を", "動かす事もできて", "イソギンチャクの中に", "住んでいる魚もいるの", "クマノミって魚で", "外敵から守ってもらったり", "食べ残しを分けて", "もらってるんだって"]}], "img_path": "00010.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1120, 260, 1413, 442], "vertical": true, "font_size": 48, "lines_coords": [[[1356.0, 262.0], [1413.0, 262.0], [1413.0, 358.0], [1356.0, 358.0]], [[1303.0, 262.0], [1352.0, 262.0], [1352.0, 442.0], [1303.0, 442.0]], [[1249.0, 260.0], [1298.0, 260.0], [1293.0, 442.0], [1244.0, 442.0]], [[1183.0, 264.0], [1225.0, 264.0], [1225.0, 442.0], [1183.0, 442.0]], [[1124.0, 264.0], [1174.0, 264.0], [1169.0, 442.0], [1120.0, 442.0]]], "lines": ["なぁ", "イソギン", "チャクの", "話はもう", "いいよ．．．"]}, {"box": [874, 243, 1045, 510], "vertical": true, "font_size": 48, "lines_coords": [[[996.0, 243.0], [1045.0, 243.0], [1038.0, 510.0], [988.0, 510.0]], [[930.0, 243.0], [972.0, 243.0], [972.0, 468.0], [930.0, 468.0]], [[874.0, 243.0], [923.0, 243.0], [923.0, 382.0], [874.0, 382.0]]], "lines": ["ペンギン見に", "行きたいん", "だけど"]}, {"box": [81, 119, 445, 483], "vertical": true, "font_size": 51, "lines_coords": [[[391.0, 126.0], [440.0, 126.0], [440.0, 332.0], [391.0, 332.0]], [[309.0, 119.0], [365.0, 119.0], [370.0, 386.0], [314.0, 386.0]], [[232.0, 121.0], [288.0, 121.0], [288.0, 339.0], [232.0, 339.0]], [[157.0, 126.0], [206.0, 126.0], [206.0, 431.0], [157.0, 431.0]], [[84.0, 126.0], [131.0, 126.0], [131.0, 482.0], [84.0, 482.0]]], "lines": ["あのさ．．．", "私キチンと", "水族館を", "楽しめる計画", "立ててきてるの"]}, {"box": [745, 639, 860, 813], "vertical": true, "font_size": 65, "lines_coords": [[[745.0, 646.0], [850.0, 639.0], [860.0, 808.0], [754.0, 813.0]]], "lines": ["駄目"]}, {"box": [628, 900, 895, 1120], "vertical": true, "font_size": 65, "lines_coords": [[[846.0, 907.0], [895.0, 907.0], [895.0, 1059.0], [846.0, 1059.0]], [[761.0, 904.0], [820.0, 902.0], [827.0, 1117.0], [768.0, 1120.0]], [[684.0, 902.0], [742.0, 900.0], [749.0, 1115.0], [691.0, 1117.0]], [[628.0, 909.0], [679.0, 909.0], [679.0, 1064.0], [628.0, 1064.0]]], "lines": ["ここは", "あと１０分", "見る予定", "だから"]}, {"box": [700, 1263, 799, 1448], "vertical": true, "font_size": 91, "lines_coords": [[[700.0, 1267.0], [789.0, 1263.0], [799.0, 1443.0], [707.0, 1448.0]]], "lines": ["え！？"]}, {"box": [131, 1064, 380, 1366], "vertical": true, "font_size": 67, "lines_coords": [[[285.0, 1064.0], [353.0, 1064.0], [358.0, 1310.0], [290.0, 1310.0]], [[208.0, 1073.0], [269.0, 1073.0], [269.0, 1366.0], [208.0, 1366.0]], [[131.0, 1071.0], [203.0, 1071.0], [203.0, 1200.0], [131.0, 1200.0]]], "lines": ["計画外の", "事はしない", "から"]}, {"box": [1003, 2060, 1117, 2175], "vertical": true, "font_size": 72, "lines_coords": [[[1003.0, 2060.0], [1075.0, 2060.0], [1075.0, 2175.0], [1003.0, 2175.0]]], "lines": ["はい"]}, {"box": [63, 1736, 336, 2160], "vertical": true, "font_size": 55, "lines_coords": [[[283.0, 1736.0], [332.0, 1736.0], [332.0, 2151.0], [283.