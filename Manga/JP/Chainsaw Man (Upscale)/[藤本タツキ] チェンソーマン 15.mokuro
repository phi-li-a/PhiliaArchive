{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 15", "volume_uuid": "0b64e176-cb28-4dbb-9cdc-13045adf946b", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1101, 660, 1149, 1033], "vertical": true, "font_size": 40, "lines_coords": [[[1103.0, 660.0], [1143.0, 660.0], [1141.0, 1028.0], [1101.0, 1028.0]]], "lines": ["Ｐｏｒｓｅｋｉｒｕｌｉｎｄｏ"]}, {"box": [508, 1558, 1279, 2400], "vertical": false, "font_size": 780, "lines_coords": [[[508.0, 1635.0], [1190.0, 1558.0], [1279.0, 2343.0], [597.0, 2400.0]]], "lines": ["．．．"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [135, 2172, 1389, 2268], "vertical": false, "font_size": 33.0, "lines_coords": [[[138.0, 2172.0], [1385.0, 2172.0], [1385.0, 2205.0], [138.0, 2205.0]], [[135.0, 2235.0], [1389.0, 2235.0], [1389.0, 2268.0], [135.0, 2268.0]]], "lines": ["★この作品はフィクシヨンです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [40, 36, 588, 127], "vertical": false, "font_size": 88, "lines_coords": [[[58.0, 38.0], [585.0, 34.0], [585.0, 129.0], [58.0, 134.0]]], "lines": ["ＪＵＭＰ．ＣＯＭＩＣＳで、"]}, {"box": [224, 1736, 806, 1945], "vertical": false, "font_size": 185, "lines_coords": [[[232.0, 1736.0], [806.0, 1760.0], [799.0, 1945.0], [224.0, 1921.0]]], "lines": ["チェンソン"]}, {"box": [534, 2153, 946, 2306], "vertical": false, "font_size": 136, "lines_coords": [[[534.0, 2170.0], [939.0, 2153.0], [946.0, 2289.0], [541.0, 2306.0]]], "lines": ["藤本タツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [670, 117, 1415, 194], "vertical": false, "font_size": 72, "lines_coords": [[[670.0, 117.0], [1415.0, 121.0], [1415.0, 194.0], [670.0, 189.0]]], "lines": ["ＦＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [953, 405, 1270, 595], "vertical": false, "font_size": 190, "lines_coords": [[[953.0, 405.0], [1270.0, 405.0], [1270.0, 595.0], [953.0, 595.0]]], "lines": ["三鷹アサ"]}, {"box": [1115, 630, 1424, 1031], "vertical": true, "font_size": 114, "lines_coords": [[[1368.0, 658.0], [1417.0, 658.0], [1424.0, 1031.0], [1375.0, 1031.0]], [[1305.0, 707.0], [1347.0, 712.0], [1340.0, 768.0], [1298.0, 764.0]], [[1288.0, 637.0], [1317.0, 637.0], [1317.0, 698.0], [1288.0, 698.0]], [[1246.0, 630.0], [1288.0, 630.0], [1288.0, 724.0], [1246.0, 724.0]], [[1197.0, 696.0], [1235.0, 700.0], [1225.0, 780.0], [1188.0, 775.0]], [[1228.0, 778.0], [1312.0, 742.0], [1373.0, 885.0], [1288.0, 921.0]], [[1155.0, 700.0], [1197.0, 703.0], [1188.0, 843.0], [1146.0, 841.0]], [[1115.0, 707.0], [1164.0, 707.0], [1164.0, 829.0], [1115.0, 829.0]]], "lines": ["じゃ正だな体に向けてしまった。", "女", "湿", "陰し", "独", "一度そんな", "孤襲", "るに"]}, {"box": [1164, 834, 1349, 956], "vertical": true, "font_size": 114, "lines_coords": [[[1281.0, 907.0], [1349.0, 907.0], [1349.0, 956.0], [1281.0, 956.0]], [[1164.0, 834.0], [1199.0, 834.0], [1199.0, 895.0], [1164.0, 895.0]]], "lines": ["った。", "悪"]}, {"box": [1080, 705, 1162, 900], "vertical": true, "font_size": 114, "lines_coords": [[[1080.0, 705.0], [1122.0, 705.0], [1129.0, 900.0], [1087.0, 900.0]], [[1127.0, 834.0], [1162.0, 834.0], [1162.0, 890.0], [1127.0, 890.0]]], "lines": ["け魔術争", "の"]}, {"box": [906, 602, 1474, 1317], "vertical": true, "font_size": 114, "lines_coords": [[[1075.0, 883.0], [1293.0, 902.0], [1286.0, 977.0], [1068.0, 958.0]], [[960.0, 602.0], [1078.0, 604.0], [1066.0, 1040.0], [949.0, 1038.0]], [[1005.0, 907.0], [1040.0, 897.0], [1054.0, 956.0], [1019.0, 965.0]], [[1042.0, 972.0], [1394.0, 972.0], [1394.0, 1021.0], [1042.0, 1021.0]], [[1028.0, 970.0], [1056.0, 998.0], [1033.0, 1024.0], [1005.0, 996.0]], [[981.0, 1045.0], [1415.0, 1045.0], [1415.0, 1085.0], [981.0, 1085.0]], [[930.0, 1010.0], [1474.0, 1061.0], [1450.0, 1317.0], [906.0, 1265.0]], [[1005.0, 1174.0], [1141.0, 1174.0], [1141.0, 1216.0], [1005.0, 1216.0]]], "lines": ["取られ生き返っ", "学校を悪のが、を乗って親", "粟", "苦しい情報を作んでお", "それ", "．．．クリアンチャンス", "ここで、ここまで来てください．．．この場所に来た", "戦中．．．！！"]}, {"box": [1017, 642, 1096, 970], "vertical": true, "font_size": 114, "lines_coords": [[[1040.0, 642.0], [1089.0, 642.0], [1096.0, 970.0], [1047.0, 970.0]], [[1017.0, 761.0], [1045.0, 761.0], [1045.0, 815.0], [1017.0, 815.0]]], "lines": ["にっ受悪戦ってっ", "の"]}, {"box": [138, 1612, 557, 1743], "vertical": false, "font_size": 127, "lines_coords": [[[138.0, 1617.0], [555.0, 1612.0], [557.0, 1739.0], [140.0, 1743.0]]], "lines": ["ヨル（戦争の悪魔）"]}, {"box": [316, 1783, 576, 2191], "vertical": true, "font_size": 109, "lines_coords": [[[515.0, 1933.0], [548.0, 1933.0], [543.0, 2191.0], [510.0, 2191.0]], [[442.0, 1938.0], [482.0, 1938.0], [482.0, 2146.0], [442.0, 2146.0]], [[424.0, 1879.0], [543.0, 1853.0], [560.0, 1928.0], [440.0, 1954.0]], [[489.0, 1783.0], [576.0, 1825.0], [541.0, 1898.0], [454.0, 1856.0]], [[339.0, 1856.0], [381.0, 1870.0], [358.0, 1952.0], [316.0, 1938.0]], [[358.0, 1811.0], [492.0, 1811.0], [492.0, 1882.0], [358.0, 1882.0]]], "lines": ["サを器材", "半を", "チェン", "ただ今は", "悪悪", "のような"]}, {"box": [243, 1889, 454, 2100], "vertical": true, "font_size": 109, "lines_coords": [[[325.0, 2017.0], [454.0, 2017.0], [454.0, 2069.0], [325.0, 2069.0]], [[290.0, 1889.0], [330.0, 1889.0], [330.0, 1938.0], [290.0, 1938.0]], [[285.0, 1931.0], [328.0, 1933.0], [321.0, 2100.0], [278.0, 2097.0]], [[262.0, 1942.0], [295.0, 1952.0], [276.0, 2013.0], [243.0, 2003.0]]], "lines": ["って脳の", "の", "お殺と取るぞ", "を"]}, {"box": [114, 1804, 269, 1945], "vertical": true, "font_size": 109, "lines_coords": [[[201.0, 1814.0], [257.0, 1809.0], [269.0, 1940.0], [213.0, 1945.0]], [[178.0, 1816.0], [217.0, 1816.0], [217.0, 1870.0], [178.0, 1870.0]], [[114.0, 1804.0], [140.0, 1804.0], [140.0, 1863.0], [114.0, 1863.0]]], "lines": ["フッ戦", "は", "本"]}, {"box": [159, 1917, 456, 2146], "vertical": true, "font_size": 109, "lines_coords": [[[281.0, 2083.0], [456.0, 2078.0], [456.0, 2128.0], [281.0, 2132.0]], [[199.0, 1917.0], [276.0, 1926.0], [248.0, 2146.0], [171.0, 2137.0]], [[194.0, 2001.0], [234.0, 2029.0], [199.0, 2076.0], [159.0, 2048.0]]], "lines": ["殺したもの", "マンガを乗っした", "たし"]}, {"box": [35, 1811, 618, 2299], "vertical": true, "font_size": 109, "lines_coords": [[[135.0, 2214.0], [506.0, 2214.0], [506.0, 2261.0], [135.0, 2261.0]], [[35.0, 1823.0], [609.0, 1811.0], [618.0, 2287.0], [44.0, 2299.0]]], "lines": ["このこともよくわからない。", "なんかこんなわけじゃないけど．．．ありがとうございませんでしょうかもしれないのだろうかどうか思ってるんだけど．．．そんなことなんだからなんですね"]}, {"box": [107, 1785, 192, 2257], "vertical": true, "font_size": 109, "lines_coords": [[[107.0, 2050.0], [140.0, 2050.0], [145.0, 2257.0], [112.0, 2257.0]], [[112.0, 1785.0], [192.0, 1788.0], [187.0, 1942.0], [107.0, 1940.0]]], "lines": ["あー支になる", "本来した"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [229, 131, 674, 196], "vertical": false, "font_size": 65, "lines_coords": [[[229.0, 131.0], [674.0, 131.0], [674.0, 196.0], [229.0, 196.0]]], "lines": ["デンジ（ァェンッーマン）"]}, {"box": [119, 328, 393, 684], "vertical": true, "font_size": 80, "lines_coords": [[[358.0, 391.0], [393.0, 393.0], [389.0, 501.0], [353.0, 499.0]], [[339.0, 389.0], [365.0, 389.0], [365.0, 442.0], [339.0, 442.0]], [[332.0, 459.0], [358.0, 459.0], [358.0, 499.0], [332.0, 499.0]], [[255.0, 450.0], [290.0, 447.0], [297.0, 562.0], [262.0, 564.0]], [[208.0, 386.0], [299.0, 386.0], [299.0, 452.0], [208.0, 452.0]], [[121.0, 328.0], [187.0, 328.0], [187.0, 522.0], [121.0, 522.0]], [[180.0, 492.0], [241.0, 492.0], [241.0, 567.0], [180.0, 567.0]], [[119.0, 492.0], [161.0, 492.0], [166.0, 684.0], [124.0, 684.0]], [[164.0, 567.0], [189.0, 567.0], [189.0, 623.0], [164.0, 623.0]]], "lines": ["とした", "魔", "の", "『ハムレ支", "密かに", "ソソがらてい", "いら、", "この辺が悪い話", "魔"]}, {"box": [290, 309, 421, 564], "vertical": true, "font_size": 80, "lines_coords": [[[393.0, 379.0], [421.0, 379.0], [421.0, 440.0], [393.0, 440.0]], [[299.0, 309.0], [339.0, 309.0], [330.0, 564.0], [290.0, 564.0]]], "lines": ["戦戦", "普悪安心配"]}, {"box": [330, 264, 689, 393], "vertical": true, "font_size": 80, "lines_coords": [[[426.0, 276.0], [679.0, 276.0], [679.0, 325.0], [426.0, 325.0]], [[400.0, 309.0], [689.0, 309.0], [689.0, 393.0], [400.0, 393.0]], [[330.0, 264.0], [360.0, 264.0], [360.0, 330.0], [330.0, 330.0]]], "lines": ["９．５歳に戻す、チェ", "警戒士として生活した", "魔"]}, {"box": [157, 653, 316, 679], "vertical": true, "font_size": 80, "lines_coords": [[[157.0, 653.0], [316.0, 653.0], [316.0, 679.0], [157.0, 679.0]]], "lines": ["されたか．．．"]}, {"box": [250, 1391, 592, 1469], "vertical": false, "font_size": 56, "lines_coords": [[[255.0, 1408.0], [578.0, 1408.0], [578.0, 1464.0], [255.0, 1464.0]]], "lines": ["キガ（飢餓の悪魔）"]}, {"box": [126, 1516, 721, 1638], "vertical": false, "font_size": 48, "lines_coords": [[[131.0, 1530.0], [721.0, 1530.0], [721.0, 1577.0], [131.0, 1577.0]], [[128.0, 1589.0], [524.0, 1584.0], [524.0, 1633.0], [128.0, 1638.0]]], "lines": ["アサの高校のデビルハンタ一部に所属する女子", "生徒。正体は戦争の悪魔の姉。"]}, {"box": [140, 1755, 424, 1811], "vertical": false, "font_size": 49, "lines_coords": [[[140.0, 1762.0], [424.0, 1755.0], [424.0, 1804.0], [140.0, 1811.0]]], "lines": ["ＳＴＯＲＹ－"]}, {"box": [956, 1406, 1251, 1471], "vertical": false, "font_size": 58, "lines_coords": [[[956.0, 1413.0], [1251.0, 1406.0], [1251.0, 1464.0], [956.0, 1471.0]]], "lines": ["吉田ヒロフミ"]}, {"box": [809, 1514, 1422, 1637], "vertical": false, "font_size": 36, "lines_coords": [[[1007.0, 1514.0], [1042.0, 1518.0], [1040.0, 1537.0], [1005.0, 1532.0]], [[810.0, 1530.0], [1415.0, 1530.0], [1415.0, 1577.0], [810.0, 1577.0]], [[813.0, 1591.0], [1129.0, 1593.0], [1129.0, 1635.0], [813.0, 1633.0]]], "lines": ["う", "民間を経て、公安に所属するデビルハンター。", "デンジの正体を隠したい。"]}, {"box": [135, 2048, 726, 2259], "vertical": false, "font_size": 34.75, "lines_coords": [[[135.0, 2048.0], [681.0, 2053.0], [681.0, 2092.0], [135.0, 2088.0]], [[142.0, 2111.0], [677.0, 2111.0], [677.0, 2144.0], [142.0, 2144.0]], [[161.0, 2170.0], [726.0, 2170.0], [726.0, 2203.0], [161.0, 2203.0]], [[140.0, 2226.0], [714.0, 2226.0], [714.0, 2259.0], [140.0, 2259.0]]], "lines": ["を奪われ復活！！チェンソーマンを探し出し、", "すことができれば体を返すと言うヨルだが．．．！？", "デンジを武器化するべく計画された水族館デート。", "だが、キガの差し向けた永遠の悪魔の力によりデン"]}, {"box": [445, 2151, 485, 2167], "vertical": false, "font_size": 16, "lines_coords": [[[445.0, 2151.0], [485.0, 2151.0], [485.0, 2167.0], [445.0, 2167.0]]], "lines": ["けいかく"]}, {"box": [808, 1872, 899, 1931], "vertical": false, "font_size": 48, "lines_coords": [[[815.0, 1872.0], [899.0, 1884.0], [892.0, 1931.0], [808.0, 1919.0]]], "lines": ["ジとアサ"]}, {"box": [110, 1781, 1537, 2336], "vertical": false, "font_size": 161.83333333333334, "lines_coords": [[[667.0, 1863.0], [742.0, 1882.0], [728.0, 1935.0], [653.0, 1919.0]], [[117.0, 1818.0], [771.0, 1837.0], [763.0, 2034.0], [110.0, 2015.0]], [[131.0, 1921.0], [539.0, 1921.0], [539.0, 1985.0], [131.0, 1985.0]], [[135.0, 1985.0], [724.0, 1989.0], [724.0, 2036.0], [135.0, 2032.0]], [[689.0, 1785.0], [1535.0, 1781.0], [1537.0, 2332.0], [691.0, 2336.0]], [[810.0, 2046.0], [1359.0, 2046.0], [1359.0, 2102.0], [810.0, 2102.0]]], "lines": ["メを受け、．．．おを買い、．．", "最初の大人に関わりますのですが、どうしてもいいのかもしれませんでしょうか。それでもないと思っていました。", "孤独な女女・二原アサは学校で、さらには妻の悪魔と実対した姿長の殺されてしまう。だが、朝食の農陰", "その正義の見積を実現した委員長があると思われてしまう。だが、素晴らしいお客さんがお客様が必要になりました。", "そういうことですから．．．", "ですが世界中に青汁隊、デジジアナルの部屋を近づきかけるといわず、人と周りになるのかもしれないと思いますが、"]}, {"box": [813, 2107, 937, 2149], "vertical": false, "font_size": 42, "lines_coords": [[[813.0, 2107.0], [937.0, 2107.0], [937.0, 2149.0], [813.0, 2149.0]]], "lines": ["するアサ．．．。"]}, {"box": [913, 1837, 1436, 2015], "vertical": false, "font_size": 178, "lines_coords": [[[913.0, 1837.0], [1436.0, 1837.0], [1436.0, 2015.0], [913.0, 2015.0]]], "lines": ["アプリとしては大変な人になってしまったのでしょうか。それではないですね。これはありませんでしたが、"]}, {"box": [972, 2146, 1124, 2179], "vertical": false, "font_size": 26.0, "lines_coords": [[[972.0, 2149.0], [1012.0, 2149.0], [1012.0, 2175.0], [972.0, 2175.0]], [[1003.0, 2153.0], [1124.0, 2146.0], [1124.0, 2172.0], [1003.0, 2179.0]]], "lines": ["げんーよっ", "どこまでここでん"]}, {"box": [822, 2203, 1293, 2259], "vertical": false, "font_size": 28.0, "lines_coords": [[[1174.0, 2203.0], [1237.0, 2203.0], [1237.0, 2228.0], [1174.0, 2228.0]], [[822.0, 2228.0], [1293.0, 2228.0], [1293.0, 2259.0], [822.0, 2259.0]]], "lines": ["ハピいはっせい", "人間が次々落下する異常現象が発生し！？"]}, {"box": [1052, 2205, 1171, 2228], "vertical": false, "font_size": 23, "lines_coords": [[[1052.0, 2205.0], [1171.0, 2205.0], [1171.0, 2228.0], [1052.0, 2228.0]]], "lines": ["いじょうけんしょう"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [681, 1286, 1054, 1326], "vertical": false, "font_size": 40, "lines_coords": [[[681.0, 1286.0], [1054.0, 1286.0], [1054.0, 1326.0], [681.0, 1326.0]]], "lines": ["ＧＯＮＴＥＮＴＳ"]}, {"box": [640, 1322, 1549, 2308], "vertical": false, "font_size": 205, "lines_coords": [[[711.0, 1350.0], [1040.0, 1350.0], [1040.0, 1458.0], [711.0, 1458.0]], [[914.0, 1458.0], [1155.0, 1453.0], [1155.0, 1535.0], [914.0, 1540.0]], [[835.0, 1399.0], [904.0, 1392.0], [933.0, 1709.0], [863.0, 1716.0]], [[729.0, 1439.0], [829.0, 1442.0], [825.0, 1749.0], [725.0, 1746.0]], [[959.0, 1524.0], [1282.0, 1528.0], [1282.0, 1629.0], [959.0, 1624.0]], [[907.0, 1632.0], [1298.0, 1632.0], [1298.0, 1706.0], [907.0, 1706.0]], [[1280.0, 1636.0], [1383.0, 1627.0], [1385.0, 1695.0], [1285.0, 1704.0]], [[865.0, 1683.0], [890.0, 1678.0], [902.0, 1786.0], [877.0, 1791.0]], [[816.0, 1392.0], [853.0, 1392.0], [846.0, 2133.0], [809.0, 2133.0]], [[675.0, 1360.0], [736.0, 1360.0], [736.0, 2224.0], [675.0, 2224.0]], [[903.0, 1716.0], [1268.0, 1709.0], [1268.0, 1793.0], [903.0, 1800.0]], [[952.0, 1800.0], [1338.0, 1800.0], [1338.0, 1882.0], [952.0, 1882.0]], [[753.0, 1871.0], [771.0, 1871.0], [771.0, 1964.0], [753.0, 1964.0]], [[781.0, 1695.0], [811.0, 1695.0], [808.0, 2184.0], [779.0, 2184.0]], [[872.0, 1749.0], [900.0, 1749.0], [900.0, 2215.0], [872.0, 2215.0]], [[760.0, 1929.0], [1329.0, 1582.0], [1527.0, 1