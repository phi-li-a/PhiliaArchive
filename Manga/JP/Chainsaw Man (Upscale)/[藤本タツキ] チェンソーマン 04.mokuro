{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 04", "volume_uuid": "2c7a1e90-b0e7-4dab-b1e7-73a518d0b895", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [39, 112, 271, 389], "vertical": false, "font_size": 277, "lines_coords": [[[39.0, 112.0], [271.0, 112.0], [271.0, 389.0], [39.0, 389.0]]], "lines": ["３"]}, {"box": [745, 121, 778, 250], "vertical": true, "font_size": 33, "lines_coords": [[[745.0, 121.0], [778.0, 121.0], [778.0, 250.0], [745.0, 250.0]]], "lines": ["．．"]}, {"box": [35, 442, 235, 1260], "vertical": true, "font_size": 105, "lines_coords": [[[192.0, 585.0], [232.0, 585.0], [224.0, 850.0], [185.0, 850.0]], [[39.0, 442.0], [210.0, 442.0], [206.0, 1260.0], [35.0, 1260.0]]], "lines": ["それで、そこまで", "藤本タツキ"]}, {"box": [691, 1146, 761, 1190], "vertical": false, "font_size": 26, "lines_coords": [[[691.0, 1164.0], [754.0, 1146.0], [761.0, 1171.0], [698.0, 1190.0]]], "lines": ["！"]}, {"box": [45, 2263, 543, 2347], "vertical": false, "font_size": 71, "lines_coords": [[[63.0, 2265.0], [461.0, 2265.0], [461.0, 2342.0], [63.0, 2342.0]]], "lines": ["ＪＵＭＰ，ＣＯＭＩＣＳ"]}, {"box": [1255, 2264, 1431, 2336], "vertical": false, "font_size": 67, "lines_coords": [[[1260.0, 2265.0], [1382.0, 2265.0], [1382.0, 2338.0], [1260.0, 2338.0]]], "lines": ["銃は蹴"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [131, 2167, 1394, 2271], "vertical": false, "font_size": 40.0, "lines_coords": [[[131.0, 2167.0], [1394.0, 2167.0], [1394.0, 2207.0], [131.0, 2207.0]], [[131.0, 2231.0], [1389.0, 2231.0], [1389.0, 2271.0], [131.0, 2271.0]]], "lines": ["★この作品はフィクションです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [47, 35, 590, 129], "vertical": false, "font_size": 90, "lines_coords": [[[56.0, 27.0], [583.0, 38.0], [581.0, 136.0], [53.0, 125.0]]], "lines": ["ＪＵＭＰ．ＣＯＭＩＣＳへの"]}, {"box": [660, 2083, 827, 2144], "vertical": false, "font_size": 52, "lines_coords": [[[663.0, 2083.0], [827.0, 2092.0], [824.0, 2144.0], [660.0, 2135.0]]], "lines": ["【銃は強い】"]}, {"box": [583, 2160, 939, 2292], "vertical": false, "font_size": 111, "lines_coords": [[[583.0, 2182.0], [932.0, 2160.0], [939.0, 2271.0], [590.0, 2292.0]]], "lines": ["藤本タツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [119, 382, 304, 459], "vertical": false, "font_size": 77, "lines_coords": [[[119.0, 382.0], [304.0, 382.0], [304.0, 459.0], [119.0, 459.0]]], "lines": ["デンジ"]}, {"box": [93, 494, 756, 705], "vertical": false, "font_size": 68, "lines_coords": [[[98.0, 494.0], [756.0, 522.0], [752.0, 637.0], [93.0, 609.0]], [[112.0, 595.0], [742.0, 583.0], [742.0, 639.0], [112.0, 651.0]], [[128.0, 663.0], [639.0, 663.0], [639.0, 696.0], [128.0, 696.0]]], "lines": ["秋春のボデンをその男に彼女、「チェンジー", "の悪魔』の少年。自分の欲望に正直。初", "めて人並扱いしてくわたマキマが好き"]}, {"box": [691, 124, 1415, 196], "vertical": false, "font_size": 72, "lines_coords": [[[691.0, 124.0], [1415.0, 124.0], [1415.0, 196.0], [691.0, 196.0]]], "lines": ["ＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [862, 1668, 1420, 1727], "vertical": false, "font_size": 56, "lines_coords": [[[862.0, 1668.0], [1420.0, 1671.0], [1420.0, 1727.0], [862.0, 1725.0]]], "lines": ["デンジに心臓を与え、体の一部となる。"]}, {"box": [1230, 1462, 1410, 1542], "vertical": false, "font_size": 80, "lines_coords": [[[1230.0, 1462.0], [1410.0, 1462.0], [1410.0, 1542.0], [1230.0, 1542.0]]], "lines": ["ポチタ"]}, {"box": [1106, 1607, 1415, 1664], "vertical": false, "font_size": 57, "lines_coords": [[[1106.0, 1607.0], [1415.0, 1607.0], [1415.0, 1664.0], [1106.0, 1664.0]]], "lines": ["『チェンソーの悪魔』。"]}, {"box": [135, 1835, 276, 1886], "vertical": false, "font_size": 51, "lines_coords": [[[135.0, 1835.0], [276.0, 1835.0], [276.0, 1886.0], [135.0, 1886.0]]], "lines": ["マキマ"]}, {"box": [412, 1910, 721, 2226], "vertical": false, "font_size": 103, "lines_coords": [[[539.0, 1910.0], [665.0, 1910.0], [665.0, 1985.0], [539.0, 1985.0]], [[496.0, 1938.0], [623.0, 1982.0], [539.0, 2226.0], [412.0, 2182.0]], [[597.0, 1989.0], [621.0, 2013.0], [599.0, 2034.0], [576.0, 2010.0]], [[543.0, 2088.0], [686.0, 2088.0], [686.0, 2146.0], [543.0, 2146.0]]], "lines": ["安対魔特異", "なんでもないのかもしれないですか", "«", "俺の匂いを！"]}, {"box": [803, 1796, 1046, 1903], "vertical": false, "font_size": 75, "lines_coords": [[[803.0, 1823.0], [1040.0, 1823.0], [1040.0, 1898.0], [803.0, 1898.0]]], "lines": ["早川アキ"]}, {"box": [1246, 1938, 1284, 1999], "vertical": true, "font_size": 41, "lines_coords": [[[1246.0, 1938.0], [1284.0, 1938.0], [1284.0, 1999.0], [1246.0, 1999.0]]], "lines": ["マの"]}, {"box": [1349, 1966, 1399, 2137], "vertical": true, "font_size": 41, "lines_coords": [[[1356.0, 1966.0], [1399.0, 1968.0], [1392.0, 2137.0], [1349.0, 2135.0]]], "lines": ["５年間と"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [175, 138, 227, 199], "vertical": false, "font_size": 61, "lines_coords": [[[175.0, 138.0], [227.0, 138.0], [227.0, 199.0], [175.0, 199.0]]], "lines": ["日野"]}, {"box": [454, 231, 763, 480], "vertical": false, "font_size": 97, "lines_coords": [[[510.0, 297.0], [623.0, 297.0], [623.0, 342.0], [510.0, 342.0]], [[454.0, 337.0], [721.0, 257.0], [763.0, 403.0], [496.0, 480.0]]], "lines": ["ティを組ん", "アイを組んで行動していた。問題の悪いと契約。"]}, {"box": [1199, 229, 1415, 446], "vertical": false, "font_size": 43, "lines_coords": [[[1251.0, 243.0], [1401.0, 239.0], [1401.0, 281.0], [1251.0, 285.0]], [[1199.0, 285.0], [1401.0, 290.0], [1401.0, 346.0], [1199.0, 342.0]], [[1204.0, 351.0], [1399.0, 351.0], [1399.0, 391.0], [1204.0, 391.0]], [[1206.0, 410.0], [1378.0, 410.0], [1378.0, 442.0], [1206.0, 442.0]]], "lines": ["の悪魔』の職人", "自分勝手で暴走し", "がち。菊のニャー", "口が唯一の友達。"]}, {"box": [124, 625, 472, 747], "vertical": false, "font_size": 115, "lines_coords": [[[124.0, 618.0], [171.0, 615.0], [175.0, 736.0], [128.0, 738.0]], [[154.0, 627.0], [461.0, 627.0], [461.0, 757.0], [154.0, 757.0]]], "lines": ["荒", "荒井ヒロカズー"]}, {"box": [508, 752, 721, 1032], "vertical": true, "font_size": 44, "lines_coords": [[[674.0, 766.0], [721.0, 768.0], [714.0, 946.0], [667.0, 944.0]], [[585.0, 761.0], [642.0, 754.0], [672.0, 975.0], [616.0, 982.0]], [[550.0, 792.0], [597.0, 789.0], [606.0, 975.0], [560.0, 977.0]], [[536.0, 764.0], [562.0, 764.0], [562.0, 869.0], [536.0, 869.0]]], "lines": ["な狐し．．．", "熱下。ということだと", "その魔力る。", "苦野"]}, {"box": [794, 618, 1108, 752], "vertical": false, "font_size": 76, "lines_coords": [[[827.0, 618.0], [867.0, 642.0], [848.0, 675.0], [808.0, 651.0]], [[794.0, 635.0], [1108.0, 635.0], [1108.0, 752.0], [794.0, 752.0]]], "lines": ["ひゃっ", "東山コベニ"]}, {"box": [1198, 754, 1415, 1085], "vertical": true, "font_size": 40, "lines_coords": [[[1375.0, 754.0], [1415.0, 754.0], [1406.0, 1026.0], [1366.0, 1026.0]], [[1317.0, 757.0], [1359.0, 757.0], [1352.0, 970.0], [1310.0, 970.0]], [[1284.0, 757.0], [1331.0, 757.0], [1324.0, 984.0], [1277.0, 984.0]], [[1258.0, 796.0], [1291.0, 796.0], [1291.0, 869.0], [1258.0, 869.0]]], "lines": ["新臨姫３評火", "案的・司力", "思い得たように、みんなの", "一緒"]}, {"box": [130, 1183, 510, 1260], "vertical": false, "font_size": 61, "lines_coords": [[[131.0, 1190.0], [405.0, 1185.0], [405.0, 1251.0], [131.0, 1256.0]]], "lines": ["サムライソー"]}, {"box": [142, 1762, 435, 1811], "vertical": false, "font_size": 49, "lines_coords": [[[142.0, 1762.0], [435.0, 1762.0], [435.0, 1811.0], [142.0, 1811.0]]], "lines": ["ＳＴＯＲＹ－"]}, {"box": [464, 1235, 763, 1502], "vertical": false, "font_size": 120, "lines_coords": [[[513.0, 1291.0], [599.0, 1296.0], [597.0, 1338.0], [510.0, 1333.0]], [[464.0, 1235.0], [763.0, 1235.0], [763.0, 1502.0], [464.0, 1502.0]], [[506.0, 1450.0], [714.0, 1446.0], [714.0, 1495.0], [506.0, 1500.0]]], "lines": ["テンジ", "アンジを観念は君に追い込んだやクザの事。嬉しでも死なないっ？", "ても死なない．．．？"]}, {"box": [818, 1167, 1144, 1257], "vertical": false, "font_size": 72, "lines_coords": [[[834.0, 1182.0], [1143.0, 1177.0], [1143.0, 1255.0], [834.0, 1259.0]]], "lines": ["パーカーの女"]}, {"box": [1190, 1297, 1424, 1497], "vertical": false, "font_size": 44, "lines_coords": [[[1220.0, 1298.0], [1399.0, 1298.0], [1399.0, 1340.0], [1220.0, 1340.0]], [[1190.0, 1333.0], [1424.0, 1328.0], [1424.0, 1394.0], [1190.0, 1399.0]], [[1206.0, 1408.0], [1410.0, 1408.0], [1410.0, 1441.0], [1206.0, 1441.0]], [[1204.0, 1462.0], [1408.0, 1462.0], [1408.0, 1495.0], [1204.0, 1495.0]]], "lines": ["「ムライソードと", "行動を共にする。", "ヘビのような姿の", "強力な悪魔を使役"]}, {"box": [135, 1865, 766, 2271], "vertical": false, "font_size": 39.75, "lines_coords": [[[152.0, 1865.0], [728.0, 1867.0], [728.0, 1917.0], [152.0, 1914.0]], [[138.0, 1924.0], [721.0, 1924.0], [721.0, 1964.0], [138.0, 1964.0]], [[135.0, 1975.0], [721.0, 1975.0], [721.0, 2015.0], [135.0, 2015.0]], [[135.0, 2027.0], [712.0, 2025.0], [712.0, 2064.0], [135.0, 2067.0]], [[140.0, 2083.0], [714.0, 2083.0], [714.0, 2116.0], [140.0, 2116.0]], [[140.0, 2128.0], [260.0, 2135.0], [257.0, 2170.0], [138.0, 2163.0]], [[166.0, 2179.0], [717.0, 2179.0], [717.0, 2219.0], [166.0, 2219.0]], [[135.0, 2231.0], [766.0, 2231.0], [766.0, 2271.0], [135.0, 2271.0]]], "lines": ["最初のチケックスプレイルハウーセース事ですが、ランション", "借金返済のためこき使われるお風呂の日々を過ごしていたところ、", "を、要切りに合い残されてしまう。たが、ボチタがその命と引", "き換えにデンジを【チェンツこの悪魔」として蘇らせる！敵を", "皆殺しにしたデンジは、ごマキマに拾われ公安のデビルハンターと", "なるのだった。", "「永遠の悪魔」との事件で、デンジに居された秘密を疑う早", "肌と姫野だが、マキマは多くを語ろうとしたない。一方、デンジ．．．"]}, {"box": [808, 1862, 1408, 2271], "vertical": false, "font_size": 41, "lines_coords": [[[813.0, 1874.0], [1366.0, 1867.0], [1366.0, 1913.0], [813.0, 1920.0]], [[831.0, 1923.0], [1399.0, 1921.0], [1399.0, 1967.0], [831.0, 1969.0]], [[817.0, 1977.0], [1399.0, 1977.0], [1399.0, 2016.0], [817.0, 2016.0]], [[808.0, 2014.0], [1408.0, 2012.0], [1408.0, 2074.0], [808.0, 2077.0]], [[815.0, 2078.0], [1394.0, 2078.0], [1394.0, 2117.0], [815.0, 2117.0]], [[815.0, 2125.0], [1399.0, 2125.0], [1399.0, 2170.0], [815.0, 2170.0]], [[820.0, 2181.0], [1406.0, 2181.0], [1406.0, 2220.0], [820.0, 2220.0]], [[820.0, 2230.0], [1342.0, 2230.0], [1342.0, 2269.0], [820.0, 2269.0]]], "lines": ["ｎｏｏさま、最初のパロネットコスコスに接続されていた", "そんな中、京都出張！向かう新幹線でマキマが銃で得者かに", "畏われ、他の特異４長メンバーこも次々と銃撃される緊急事態が", "また、おまえがメーカーではなく、本当にテクションの時には１００万円以上の取引の取り扱うのがありませんが、", "を狙う、謎のソードマンと女が現れる。圧倒的な強さのとに", "対し早川は「呪いの悪魔」そんなこの力で対抗するも失敗。さらに絶", "野は早川を守るため「漁豊の悪魔」に自らの全てを捧げ、消失する。", "大ピンチの中、チェンソー一化して立ち向かうデンジだが！？"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1024, 1530, 1291, 1804], "vertical": true, "font_size": 114, "lines_coords": [[[1218.0, 1570.0], [1260.0, 1570.0], [1256.0, 1727.0], [1213.0, 1727.0]], [[1026.0, 1647.0], [1291.0, 1647.0], [1291.0, 1804.0], [1026.0, 1804.0]], [[1127.0, 1565.0], [1176.0, 1565.0], [1176.0, 1755.0], [1127.0, 1755.0]], [[1056.0, 1556.0], [1106.0, 1556.0], [1106.0, 1694.0], [1056.0, 1694.0]], [[1094.0, 1530.0], [1174.0, 1542.0], [1148.0, 1708.0], [1071.0, 1696.0]], [[1024.0, 1542.0], [1054.0, 1542.0], [1054.0, 1774.0], [1024.0, 1774.0]]], "lines": ["００７０２７", "京都より．．．電源と話の", "しりぇ", "は。都", "は強し部よ！", "銃京萩"]}, {"box": [778, 1455, 1157, 1502], "vertical": false, "font_size": 47, "lines_coords": [[[778.0, 1455.0], [1157.0, 1455.0], [1157.0, 1502.0], [778.0, 1502.0]]], "lines": ["ＣｏＭＴＥＮＴＳ"]}, {"box": [1012, 1828, 1385, 2296], "vertical": true, "font_size": 114, "lines_coords": [[[1242.0, 1828.0], [1310.0, 1828.0], [1310.0, 1853.0], [1242.0, 1853.0]], [[1141.0, 1966.0], [1188.0, 1978.0], [1174.0, 2041.0], [1127.0, 2029.0]], [[1115.0, 1971.0], [1385.0, 2055.0], [1307.0, 2296.0], [1040.0, 2212.0]], [[1099.0, 1968.0], [1138.0, 1968.0], [1138.0, 2184.0], [1099.0, 2184.0]], [[1059.0, 1964.0], [1099.0, 1964.0], [1099.0, 2186.0], [1059.0, 2186.0]], [[1012.0, 1905.0], [1375.0, 1905.0], [1375.0, 1961.0], [1012.0, 1961.0]], [[1021.0, 1952.0], [1054.0, 1952.0], [1054.0, 2210.0], [1021.0, 2210.0]]], "lines": ["．", "吉岡", "俺もいいでも繰り返している場所だけ", "最返期", "来り継", "もっとまいちょっと", "°未＜繰＜作"]}, {"box": [881, 17