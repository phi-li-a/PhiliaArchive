{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 09", "volume_uuid": "99b91592-f5f3-4652-a71a-41099d2dceae", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [90, 1572, 629, 1710], "vertical": false, "font_size": 62, "lines_coords": [[[127.0, 1567.0], [332.0, 1591.0], [325.0, 1658.0], [120.0, 1635.0]], [[116.0, 1602.0], [274.0, 1607.0], [271.0, 1686.0], [113.0, 1682.0]], [[111.0, 1661.0], [234.0, 1661.0], [234.0, 1712.0], [111.0, 1712.0]]], "lines": ["藤井", "．．．", "膝«"]}, {"box": [103, 1732, 469, 1781], "vertical": false, "font_size": 50, "lines_coords": [[[103.0, 1728.0], [461.0, 1728.0], [461.0, 1782.0], [103.0, 1782.0]]], "lines": ["Ｔｏｒｓｕｋｉ．Ｆｕｊｉｍｏｌｅ"]}, {"box": [37, 2277, 581, 2360], "vertical": false, "font_size": 66, "lines_coords": [[[452.0, 2276.0], [581.0, 2276.0], [581.0, 2352.0], [452.0, 2352.0]], [[74.0, 2281.0], [478.0, 2281.0], [478.0, 2349.0], [74.0, 2349.0]]], "lines": ["«", "ＪＵＭＰ．ＣＯＭＩＣＳ"]}, {"box": [1267, 2271, 1409, 2367], "vertical": false, "font_size": 70, "lines_coords": [[[1267.0, 2271.0], [1408.0, 2271.0], [1408.0, 2341.0], [1267.0, 2341.0]]], "lines": ["お風呂"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [131, 2167, 1394, 2271], "vertical": false, "font_size": 40.0, "lines_coords": [[[131.0, 2167.0], [1394.0, 2167.0], [1394.0, 2207.0], [131.0, 2207.0]], [[131.0, 2231.0], [1389.0, 2231.0], [1389.0, 2271.0], [131.0, 2271.0]]], "lines": ["★この作品はフィクションです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [39, 36, 589, 128], "vertical": false, "font_size": 79, "lines_coords": [[[58.0, 32.0], [581.0, 42.0], [581.0, 128.0], [58.0, 119.0]]], "lines": ["ＪＵＭＰ－ＣＯＭＩＣＳで、"]}, {"box": [541, 1774, 1085, 2294], "vertical": false, "font_size": 105, "lines_coords": [[[541.0, 2170.0], [937.0, 2163.0], [939.0, 2287.0], [543.0, 2294.0]], [[867.0, 1778.0], [1082.0, 1774.0], [1085.0, 1891.0], [869.0, 1896.0]]], "lines": ["藤本タツキ", "ーー"]}, {"box": [356, 1771, 815, 2139], "vertical": false, "font_size": 105, "lines_coords": [[[356.0, 1790.0], [653.0, 1771.0], [660.0, 1893.0], [363.0, 1912.0]], [[660.0, 2081.0], [815.0, 2081.0], [815.0, 2139.0], [660.0, 2139.0]]], "lines": ["．．．", "【お風呂】"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [703, 119, 1413, 194], "vertical": false, "font_size": 70, "lines_coords": [[[703.0, 119.0], [1413.0, 124.0], [1413.0, 194.0], [703.0, 189.0]]], "lines": ["ＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [119, 379, 302, 457], "vertical": false, "font_size": 78, "lines_coords": [[[119.0, 379.0], [302.0, 379.0], [302.0, 457.0], [119.0, 457.0]]], "lines": ["デンジ"]}, {"box": [107, 503, 754, 701], "vertical": false, "font_size": 70, "lines_coords": [[[110.0, 503.0], [735.0, 503.0], [735.0, 592.0], [110.0, 592.0]], [[107.0, 585.0], [752.0, 567.0], [754.0, 646.0], [110.0, 665.0]], [[126.0, 656.0], [642.0, 656.0], [642.0, 696.0], [126.0, 696.0]]], "lines": ["納庫のボチオをその身に宿す、「チェンソー", "年。少年の原爆の悪い自分の欲望に正直。初", "めて人並扱いしてくれたマキマが好き"]}, {"box": [1225, 2003, 1416, 2087], "vertical": false, "font_size": 78, "lines_coords": [[[1228.0, 2003.0], [1413.0, 2008.0], [1410.0, 2085.0], [1225.0, 2081.0]]], "lines": ["ポチタ"]}, {"box": [864, 2126, 1419, 2270], "vertical": false, "font_size": 55, "lines_coords": [[[1103.0, 2149.0], [1413.0, 2156.0], [1413.0, 2212.0], [1103.0, 2205.0]], [[864.0, 2210.0], [1415.0, 2214.0], [1415.0, 2268.0], [864.0, 2264.0]]], "lines": ["『チェンソーの悪魔』。", "デンジに心臓を与え、体の一部となる。"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1148, 194, 1450, 505], "vertical": false, "font_size": 66, "lines_coords": [[[1249.0, 300.0], [1401.0, 300.0], [1401.0, 332.0], [1249.0, 332.0]], [[1204.0, 410.0], [1401.0, 410.0], [1401.0, 440.0], [1204.0, 440.0]], [[1148.0, 203.0], [1443.0, 194.0], [1450.0, 431.0], [1155.0, 440.0]], [[1228.0, 450.0], [1256.0, 450.0], [1256.0, 459.0], [1228.0, 459.0]], [[1211.0, 468.0], [1373.0, 468.0], [1373.0, 492.0], [1211.0, 492.0]]], "lines": ["テンジの３年", "競！「呪いの悪魔」", "マキの結果なのです。デンジの３名前。「未来のお願い", "．．．", "一契約している。"]}, {"box": [815, 131, 1049, 206], "vertical": false, "font_size": 75, "lines_coords": [[[815.0, 131.0], [1049.0, 131.0], [1049.0, 206.0], [815.0, 206.0]]], "lines": ["早川アキ"]}, {"box": [672, 239, 721, 445], "vertical": true, "font_size": 70, "lines_coords": [[[681.0, 285.0], [721.0, 285.0], [721.0, 445.0], [681.0, 445.0]], [[696.0, 239.0], [719.0, 262.0], [696.0, 285.0], [672.0, 262.0]]], "lines": ["ミェ女？嗅", "．．．"]}, {"box": [531, 220, 691, 393], "vertical": true, "font_size": 70, "lines_coords": [[[595.0, 349.0], [691.0, 349.0], [691.0, 393.0], [595.0, 393.0]], [[581.0, 222.0], [618.0, 220.0], [623.0, 290.0], [585.0, 292.0]], [[531.0, 225.0], [564.0, 225.0], [564.0, 295.0], [531.0, 295.0]]], "lines": ["アスな", "魔", "安"]}, {"box": [494, 349, 693, 513], "vertical": true, "font_size": 70, "lines_coords": [[[508.0, 349.0], [541.0, 349.0], [541.0, 447.0], [508.0, 447.0]], [[527.0, 396.0], [693.0, 396.0], [693.0, 447.0], [527.0, 447.0]], [[501.0, 417.0], [635.0, 428.0], [628.0, 513.0], [494.0, 501.0]]], "lines": ["ス談悪", "腸の匂いを", "悪魔のも苦分ける。"]}, {"box": [145, 142, 288, 194], "vertical": false, "font_size": 52, "lines_coords": [[[145.0, 142.0], [288.0, 142.0], [288.0, 194.0], [145.0, 194.0]]], "lines": ["マキマ"]}, {"box": [1201, 752, 1413, 972], "vertical": false, "font_size": 40, "lines_coords": [[[1204.0, 878.0], [1403.0, 878.0], [1403.0, 911.0], [1204.0, 911.0]], [[1202.0, 921.0], [1380.0, 925.0], [1380.0, 972.0], [1202.0, 967.0]]], "lines": ["がち。猫のニャー", "コが唯一の友達。"]}, {"box": [576, 829, 742, 1024], "vertical": true, "font_size": 74, "lines_coords": [[[663.0, 918.0], [717.0, 918.0], [717.0, 972.0], [663.0, 972.0]], [[576.0, 930.0], [621.0, 928.0], [625.0, 1021.0], [581.0, 1024.0]], [[642.0, 829.0], [742.0, 878.0], [679.0, 1007.0], [578.0, 958.0]]], "lines": ["異４", "ういう", "いられない結果っ。"]}, {"box": [499, 735, 724, 1033], "vertical": true, "font_size": 74, "lines_coords": [[[569.0, 967.0], [604.0, 996.0], [571.0, 1033.0], [539.0, 1007.0]], [[541.0, 757.0], [714.0, 735.0], [724.0, 806.0], [550.0, 827.0]], [[499.0, 780.0], [557.0, 780.0], [562.0, 1028.0], [503.0, 1028.0]], [[508.0, 768.0], [560.0, 761.0], [583.0, 914.0], [531.0, 921.0]]], "lines": ["ああ", "ごめませないが、", "に接命しの人直。寿って！課", "にゅ接続命人道。"]}, {"box": [121, 623, 430, 735], "vertical": false, "font_size": 97, "lines_coords": [[[121.0, 623.0], [182.0, 623.0], [182.0, 735.0], [121.0, 735.0]], [[164.0, 649.0], [424.0, 649.0], [424.0, 731.0], [164.0, 731.0]]], "lines": ["天", "実使の悪魔"]}, {"box": [1195, 1277, 1422, 1554], "vertical": false, "font_size": 82, "lines_coords": [[[1258.0, 1282.0], [1288.0, 1282.0], [1288.0, 1347.0], [1258.0, 1347.0]], [[1277.0, 1289.0], [1319.0, 1289.0], [1319.0, 1415.0], [1277.0, 1415.0]], [[1230.0, 1279.0], [1256.0, 1279.0], [1256.0, 1387.0], [1230.0, 1387.0]], [[1317.0, 1282.0], [1349.0, 1282.0], [1349.0, 1389.0], [1317.0, 1389.0]], [[1195.0, 1277.0], [1220.0, 1277.0], [1225.0, 1389.0], [1199.0, 1389.0]], [[1352.0, 1282.0], [1378.0, 1282.0], [1378.0, 1378.0], [1352.0, 1378.0]], [[1286.0, 1403.0], [1401.0, 1373.0], [1422.0, 1450.0], [1307.0, 1481.0]], [[1202.0, 1399.0], [1319.0, 1403.0], [1317.0, 1443.0], [1199.0, 1439.0]], [[1204.0, 1453.0], [1403.0, 1453.0], [1403.0, 1495.0], [1204.0, 1495.0]], [[1202.0, 1507.0], [1410.0, 1507.0], [1410.0, 1549.0], [1202.0, 1549.0]]], "lines": ["課", "にた．．．", "異い外", "所戦", "特化並", "最後の", "逆のテピ", "を持つ最終", "ルハンター。デン", "ジとパワーの先生"]}, {"box": [796, 1141, 928, 1267], "vertical": true, "font_size": 62, "lines_coords": [[[867.0, 1176.0], [925.0, 1176.0], [925.0, 1249.0], [867.0, 1249.0]], [[796.0, 1150.0], [862.0, 1141.0], [878.0, 1258.0], [813.0, 1267.0]]], "lines": ["辺", "岸"]}, {"box": [644, 1326, 731, 1504], "vertical": true, "font_size": 45, "lines_coords": [[[644.0, 1326.0], [731.0, 1326.0], [731.0, 1504.0], [644.0, 1504.0]], [[649.0, 1335.0], [684.0, 1335.0], [684.0, 1396.0], [649.0, 1396.0]]], "lines": ["が実な！！とっないキネス", "ん"]}, {"box": [574, 1272, 642, 1436], "vertical": true, "font_size": 45, "lines_coords": [[[595.0, 1272.0], [637.0, 1279.0], [616.0, 1396.0], [574.0, 1389.0]], [[614.0, 1401.0], [642.0, 1401.0], [642.0, 1436.0], [614.0, 1436.0]]], "lines": ["第三最", "ァ"]}, {"box": [550, 1270, 667, 1544], "vertical": true, "font_size": 45, "lines_coords": [[[564.0, 1270.0], [602.0, 1275.0], [588.0, 1417.0], [550.0, 1413.0]], [[642.0, 1436.0], [667.0, 1436.0], [667.0, 1492.0], [642.0, 1492.0]], [[581.0, 1443.0], [614.0, 1443.0], [614.0, 1544.0], [581.0, 1544.0]], [[611.0, 1483.0], [637.0, 1483.0], [637.0, 1544.0], [611.0, 1544.0]]], "lines": ["言い来", "不", "際．．．予", "は言って"]}, {"box": [489, 1260, 583, 1467], "vertical": true, "font_size": 45, "lines_coords": [[[489.0, 1260.0], [583.0, 1260.0], [583.0, 1467.0], [489.0, 1467.0]]], "lines": ["最初は女の子の友人と一人ではないわね"]}, {"box": [119, 1122, 449, 1282], "vertical": false, "font_size": 140, "lines_coords": [[[145.0, 1122.0], [449.0, 1122.0], [449.0, 1282.0], [145.0, 1282.0]], [[119.0, 1146.0], [192.0, 1146.0], [192.0, 1267.0], [119.0, 1267.0]]], "lines": ["未来の悪魔", "未"]}, {"box": [145, 1760, 442, 1809], "vertical": false, "font_size": 49, "lines_coords": [[[145.0, 1760.0], [442.0, 1760.0], [442.0, 1809.0], [145.0, 1809.0]]], "lines": ["ＳＴＯＲＹ－"]}, {"box": [801, 1853, 1410, 2268], "vertical": false, "font_size": 45, "lines_coords": [[[801.0, 1853.0], [888.0, 1853.0], [888.0, 1926.0], [801.0, 1926.0]], [[810.0, 1924.0], [1401.0, 1924.0], [1401.0, 1964.0], [810.0, 1964.0]], [[892.0, 1877.0], [1396.0, 1877.0], [1396.0, 1910.0], [892.0, 1910.0]], [[813.0, 1968.0], [1403.0, 1966.0], [1403.0, 2015.0], [813.0, 2017.0]], [[815.0, 2020.0], [1399.0, 2020.0], [1399.0, 2067.0], [815.0, 2067.0]], [[815.0, 2081.0], [1399.0, 2081.0], [1399.0, 2114.0], [815.0, 2114.0]], [[817.0, 2130.0], [1399.0, 2130.0], [1399.0, 2163.0], [817.0, 2163.0]], [[810.0, 2167.0], [1406.0, 2167.0], [1406.0, 2221.0], [810.0, 2221.0]], [[813.0, 2226.0], [1410.0, 2228.0], [1410.0, 2268.0], [813.0, 2266.0]]], "lines": ["続く中、", "刺客もろとも地獄へと召喚され壊滅状態に。サンタクロースの", "ドイツの刺客・サンタクロ一スにより、デンジたちは", "真の目的は、服の悪魔と契約しマキマを殺すことだった．．．！", "マキマの出現により辛くも地上へと鼎還するが、デンジの前に", "は間の力を得たサシタクロースが立ちはだからる！その不死身の", "力に苦戦を強いられるテソジだったが、間の力を凌駕するほど", "の「頭の悪い＂戦い方で緊張に成功する。戦闘を終え、刺客", "たちは投降するが、マキマは容赦なくその命を奪うのだった．．．"]}, {"box": [128, 1847, 725, 2276], "vertical": false, "font_size": 41, "lines_coords": [[[157.0, 1872.0], [724.0, 1872.0], [724.0, 1910.0], [157.0, 1910.0]], [[138.0, 1918.0], [721.0, 1918.0], [721.0, 1964.0], [138.0, 1964.0]], [[133.0, 1968.0], [721.0, 1972.0], [721.0, 2018.0], [133.0, 2013.0]], [[138.0, 2022.0], [714.0, 2022.0], [714.0, 2067.0], [138.0, 2067.0]], [[133.0, 2075.0], [714.0, 2071.0], [714.0, 2114.0], [133.0, 2119.0]], [[142.0, 2134.0], [257.0, 2134.0], [257.0, 2166.0], [142.0, 2166.0]], [[149.0, 2174.0], [717.0, 2164.0], [717.0, 2220.0], [149.0, 2229.0]], [[135.0, 2223.0], [717.0, 2223.0], [717.0, 2269.0], [135.0, 2269.0]]], "lines": ["悪魔のポチタと共にデビルハンターとして暮らす少年・デンジ。", "借金返済のためこき使われる【海辺の日々を過ごしていたところ、", "はぁ〜ん．．．ここへん．。を、裏切りに合い残されてしまう。だが、ポチタがその命と引", "き換えにデンジを【チェンツ一つ悪魔」として蘇らせる！敵を", "皆殺しにしたデンジは、マキスに拾われ公安のデビルハンターと", "なるのだった。", "このように、テンツの内容は「アンパロ環」として使用されることができます。", "ことで、各国からの刺客が東京に集まり、い、にィーにぺんなったテンジをめぐる攻防が"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [646, 1453, 1026, 1500], "vertical": false, "font_size": 47, "lines_coords": [[[646.0, 1453.0], [1026.0, 1453.0], [1026.0, 1500.0], [646.0, 1500.0]]], "lines": ["ＣｏＭＴＥＮＴＳ"]}, {"box": [627, 1429, 1328, 2304], "vertical": false, "font_size": 258, "lines_coords": [[[834.0, 1547.0], [869.0, 1547.0], [869.0, 1621.0], [834.0, 1621.0]], [[906.0, 1516.0], [1117.0, 1528.0], [1110.0, 1680.0], [899.0, 1668.0]], [[1049.0, 1601.0], [1087.0, 1601.0], [1087.0, 1717.0], [1049.0, 1717.0]], [[1