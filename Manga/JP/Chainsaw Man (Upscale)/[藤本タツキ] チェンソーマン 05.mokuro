{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 05", "volume_uuid": "041aabc4-0631-44bb-aa6f-b110772e07f3", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [42, 1565, 635, 1875], "vertical": false, "font_size": 272, "lines_coords": [[[121.0, 1541.0], [637.0, 1604.0], [606.0, 1898.0], [90.0, 1834.0]]], "lines": ["藤本タツキー"]}, {"box": [53, 1820, 409, 1862], "vertical": false, "font_size": 35, "lines_coords": [[[53.0, 1818.0], [400.0, 1818.0], [400.0, 1856.0], [53.0, 1856.0]]], "lines": ["Ｔａｔｓｕｒ．ｉｎｉｔｉｏｎの"]}, {"box": [37, 2273, 585, 2362], "vertical": false, "font_size": 72, "lines_coords": [[[449.0, 2274.0], [585.0, 2274.0], [585.0, 2356.0], [449.0, 2356.0]], [[84.0, 2274.0], [475.0, 2279.0], [475.0, 2354.0], [84.0, 2349.0]]], "lines": ["＊", "ＪＵＭＰ．ＣＯＭＩＣＳ"]}, {"box": [869, 1942, 1516, 2214], "vertical": false, "font_size": 83, "lines_coords": [[[878.0, 2135.0], [1489.0, 1935.0], [1513.0, 2021.0], [901.0, 2220.0]]], "lines": ["Ｃｈａｉｎｓａｗ．ｍａｎ"]}, {"box": [1277, 2271, 1422, 2341], "vertical": false, "font_size": 77, "lines_coords": [[[1277.0, 2264.0], [1422.0, 2264.0], [1422.0, 2348.0], [1277.0, 2348.0]]], "lines": ["未成年"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [131, 2167, 1394, 2271], "vertical": false, "font_size": 40.0, "lines_coords": [[[131.0, 2167.0], [1394.0, 2167.0], [1394.0, 2207.0], [131.0, 2207.0]], [[131.0, 2231.0], [1389.0, 2231.0], [1389.0, 2271.0], [131.0, 2271.0]]], "lines": ["★この作品はフィクションです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [40, 35, 587, 128], "vertical": false, "font_size": 80, "lines_coords": [[[56.0, 32.0], [569.0, 39.0], [569.0, 126.0], [56.0, 119.0]]], "lines": ["ＪＵＭＰ．ＣＯＭＩＣＳで"]}, {"box": [356, 1771, 653, 1912], "vertical": false, "font_size": 122, "lines_coords": [[[356.0, 1790.0], [646.0, 1771.0], [653.0, 1893.0], [363.0, 1912.0]]], "lines": ["チェン"]}, {"box": [672, 2081, 808, 2139], "vertical": false, "font_size": 58, "lines_coords": [[[672.0, 2081.0], [808.0, 2081.0], [808.0, 2139.0], [672.0, 2139.0]]], "lines": ["【未成年】"]}, {"box": [536, 2160, 942, 2303], "vertical": false, "font_size": 134, "lines_coords": [[[536.0, 2170.0], [939.0, 2160.0], [942.0, 2294.0], [539.0, 2303.0]]], "lines": ["藤本タツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [124, 384, 299, 454], "vertical": false, "font_size": 70, "lines_coords": [[[124.0, 384.0], [299.0, 384.0], [299.0, 454.0], [124.0, 454.0]]], "lines": ["デンジ"]}, {"box": [703, 119, 1413, 194], "vertical": false, "font_size": 70, "lines_coords": [[[703.0, 119.0], [1413.0, 124.0], [1413.0, 194.0], [703.0, 189.0]]], "lines": ["ＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [114, 515, 742, 702], "vertical": false, "font_size": 53, "lines_coords": [[[114.0, 515.0], [742.0, 515.0], [742.0, 588.0], [114.0, 588.0]], [[121.0, 592.0], [710.0, 592.0], [710.0, 639.0], [121.0, 639.0]], [[128.0, 656.0], [639.0, 656.0], [639.0, 696.0], [128.0, 696.0]]], "lines": ["相棒のポチタをその身に宿す、「チェンソー", "の悪魔」の少年。自分の欲望に正直。", "めて人並扱いしてくれたマキマが好き"]}, {"box": [860, 1603, 1420, 1727], "vertical": false, "font_size": 63.0, "lines_coords": [[[1101.0, 1603.0], [1415.0, 1603.0], [1415.0, 1666.0], [1101.0, 1666.0]], [[860.0, 1659.0], [1420.0, 1664.0], [1420.0, 1727.0], [860.0, 1722.0]]], "lines": ["『チェンソーの悪魔』。", "デンジに心臓を与え、体の一部となる。"]}, {"box": [1228, 1460, 1410, 1539], "vertical": false, "font_size": 79, "lines_coords": [[[1228.0, 1460.0], [1410.0, 1460.0], [1410.0, 1539.0], [1228.0, 1539.0]]], "lines": ["ポチタ"]}, {"box": [152, 1828, 276, 1886], "vertical": false, "font_size": 51, "lines_coords": [[[154.0, 1828.0], [276.0, 1835.0], [274.0, 1886.0], [152.0, 1879.0]]], "lines": ["マキマ"]}, {"box": [452, 1903, 724, 2233], "vertical": true, "font_size": 144, "lines_coords": [[[508.0, 1966.0], [712.0, 1954.0], [724.0, 2165.0], [520.0, 2177.0]], [[461.0, 1942.0], [663.0, 1950.0], [653.0, 2233.0], [452.0, 2226.0]], [[534.0, 1903.0], [672.0, 1903.0], [672.0, 1987.0], [534.0, 1987.0]], [[524.0, 2043.0], [557.0, 2043.0], [557.0, 2137.0], [524.0, 2137.0]]], "lines": ["取り仕切るミテリアスな女。髪の匂いを腕", "公致対随給のを取り止めるステリア・スが悪魔の匂いさ分ける。", "安対魔特異４", "ティ魔"]}, {"box": [803, 1794, 1046, 1900], "vertical": false, "font_size": 75, "lines_coords": [[[803.0, 1821.0], [1040.0, 1821.0], [1040.0, 1896.0], [803.0, 1896.0]]], "lines": ["早川アキ"]}, {"box": [1235, 1910, 1408, 2144], "vertical": true, "font_size": 108, "lines_coords": [[[1333.0, 1910.0], [1408.0, 1910.0], [1408.0, 2144.0], [1333.0, 2144.0]], [[1235.0, 1926.0], [1321.0, 1926.0], [1321.0, 2053.0], [1235.0, 2053.0]]], "lines": ["．．．部・年生の３の悪魔！！", "マの忠テンジ"]}, {"box": [1197, 2158, 1359, 2184], "vertical": true, "font_size": 108, "lines_coords": [[[1197.0, 2158.0], [1359.0, 2158.0], [1359.0, 2184.0], [1197.0, 2184.0]]], "lines": ["「契約している"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1199, 228, 1414, 447], "vertical": false, "font_size": 55, "lines_coords": [[[1244.0, 262.0], [1413.0, 292.0], [1399.0, 370.0], [1230.0, 339.0]], [[1202.0, 351.0], [1403.0, 351.0], [1403.0, 391.0], [1202.0, 391.0]], [[1202.0, 396.0], [1382.0, 400.0], [1382.0, 447.0], [1202.0, 442.0]]], "lines": ["分勝手で暴走し", "がち。觜のニャー", "コが暁ーの友達。"]}, {"box": [480, 213, 719, 571], "vertical": true, "font_size": 63, "lines_coords": [[[689.0, 243.0], [719.0, 243.0], [719.0, 445.0], [689.0, 445.0]], [[646.0, 213.0], [719.0, 220.0], [696.0, 508.0], [623.0, 501.0]], [[618.0, 232.0], [663.0, 227.0], [679.0, 382.0], [635.0, 386.0]], [[576.0, 222.0], [670.0, 229.0], [651.0, 466.0], [557.0, 459.0]], [[555.0, 241.0], [592.0, 234.0], [602.0, 283.0], [564.0, 290.0]], [[480.0, 217.0], [590.0, 213.0], [606.0, 567.0], [496.0, 571.0]], [[567.0, 464.0], [616.0, 464.0], [616.0, 496.0], [567.0, 496.0]]], "lines": ["の脆野価", "実的に姫野郎を評人っ！！", "思的の", "思い物のみ．．．お精一司の力を込めないの", "え", "引っ込新人。いが、はその男していた姉妹。", "いた"]}, {"box": [89, 49, 438, 239], "vertical": false, "font_size": 169, "lines_coords": [[[89.0, 70.0], [428.0, 49.0], [438.0, 217.0], [98.0, 239.0]]], "lines": ["東山コベニ"]}, {"box": [1136, 731, 1495, 1059], "vertical": false, "font_size": 111, "lines_coords": [[[1199.0, 764.0], [1410.0, 752.0], [1413.0, 808.0], [1202.0, 820.0]], [[1169.0, 806.0], [1230.0, 789.0], [1263.0, 918.0], [1202.0, 935.0]], [[1239.0, 731.0], [1495.0, 878.0], [1392.0, 1059.0], [1136.0, 911.0]], [[1279.0, 789.0], [1415.0, 822.0], [1399.0, 892.0], [1263.0, 860.0]], [[1195.0, 911.0], [1263.0, 911.0], [1263.0, 1028.0], [1195.0, 1028.0]], [[1239.0, 918.0], [1281.0, 918.0], [1281.0, 1024.0], [1239.0, 1024.0]], [[1265.0, 916.0], [1317.0, 916.0], [1317.0, 1028.0], [1265.0, 1028.0]]], "lines": ["人に敵意はないが、", "．．．ああ", "あなたはお客様からいながら年齢を経てるのですが", "なんられると", "てしまうの", "まい隊", "う．．．"]}, {"box": [796, 626, 1129, 754], "vertical": false, "font_size": 119, "lines_coords": [[[796.0, 635.0], [1129.0, 635.0], [1129.0, 754.0], [796.0, 754.0]]], "lines": ["天使の悪魔"]}, {"box": [464, 752, 761, 1029], "vertical": false, "font_size": 144, "lines_coords": [[[536.0, 759.0], [569.0, 759.0], [569.0, 869.0], [536.0, 869.0]], [[501.0, 752.0], [534.0, 752.0], [541.0, 921.0], [508.0, 921.0]], [[464.0, 775.0], [761.0, 775.0], [761.0, 1014.0], [464.0, 1014.0]], [[508.0, 972.0], [731.0, 972.0], [731.0, 1028.0], [508.0, 1028.0]]], "lines": ["異や", "〈特に星〉な", "結果、最高の素敵などとも女優死でも近ぐことができ、短時間立ち、", "なら悪魔の姿にも。"]}, {"box": [128, 627, 439, 736], "vertical": false, "font_size": 82, "lines_coords": [[[147.0, 644.0], [414.0, 644.0], [414.0, 733.0], [147.0, 733.0]]], "lines": ["サメの魔人"]}, {"box": [1195, 1295, 1420, 1495], "vertical": false, "font_size": 45, "lines_coords": [[[1195.0, 1335.0], [1420.0, 1335.0], [1420.0, 1392.0], [1195.0, 1392.0]], [[1204.0, 1396.0], [1413.0, 1401.0], [1413.0, 1441.0], [1204.0, 1436.0]], [[1206.0, 1453.0], [1410.0, 1453.0], [1410.0, 1492.0], [1206.0, 1492.0]]], "lines": ["行動を共にする。", "へどのような姿の、", "強力な悪魔を使役"]}, {"box": [478, 1253, 745, 1502], "vertical": false, "font_size": 97, "lines_coords": [[[656.0, 1279.0], [691.0, 1279.0], [691.0, 1338.0], [656.0, 1338.0]], [[513.0, 1340.0], [597.0, 1340.0], [597.0, 1387.0], [513.0, 1387.0]], [[482.0, 1317.0], [745.0, 1317.0], [745.0, 1483.0], [482.0, 1483.0]], [[478.0, 1270.0], [686.0, 1253.0], [700.0, 1410.0], [492.0, 1427.0]], [[506.0, 1446.0], [714.0, 1446.0], [714.0, 1502.0], [506.0, 1502.0]]], "lines": ["金", "獄に追い", "最に追い込んだヤクザの孫。殺しても死ない．．．？", "テンジを借金額に追い込んだケザのを", "ても死なない．．．？"]}, {"box": [128, 1183, 452, 1253], "vertical": false, "font_size": 63, "lines_coords": [[[128.0, 1190.0], [452.0, 1183.0], [452.0, 1246.0], [128.0, 1253.0]]], "lines": ["サムライソー"]}, {"box": [140, 1755, 442, 1811], "vertical": false, "font_size": 49, "lines_coords": [[[140.0, 1762.0], [442.0, 1755.0], [442.0, 1804.0], [140.0, 1811.0]]], "lines": ["ＳＴＯＲＹ－"]}, {"box": [763, 1856, 1417, 2273], "vertical": false, "font_size": 44, "lines_coords": [[[817.0, 1875.0], [1408.0, 1871.0], [1408.0, 1911.0], [817.0, 1916.0]], [[831.0, 1922.0], [1399.0, 1922.0], [1399.0, 1963.0], [831.0, 1963.0]], [[817.0, 1974.0], [1392.0, 1974.0], [1392.0, 2014.0], [817.0, 2014.0]], [[815.0, 2016.0], [1399.0, 2016.0], [1399.0, 2071.0], [815.0, 2071.0]], [[815.0, 2070.0], [1298.0, 2072.0], [1298.0, 2120.0], [815.0, 2118.0]], [[834.0, 2121.0], [1396.0, 2121.0], [1396.0, 2169.0], [834.0, 2169.0]], [[813.0, 2163.0], [1410.0, 2163.0], [1410.0, 2225.0], [813.0, 2225.0]], [[763.0, 2222.0], [1321.0, 2224.0], [1321.0, 2272.0], [763.0, 2270.0]]], "lines": ["マキマによる京都からの救援で辛いじゃないそも敵一味を退けるのだった。", "多くの機質を失い大打撃を受けと特異４課には、不現な空気", "が景う。そんな中、デンジとパワ一は最強のデビルハンター・", "お兄ちゃんは、インターネットカードの手間の切れが出来るけど、一人に、一大規模の残されているのですが、", "早期は「未来の時間を早期に「未熟の疑問」と実問し、新たな発見して実現し、親だからです。", "ああ、あのね．．．あの日の日本であれば気になってしまってるのだろうか！？", "今回はそんなことになっているのですが、全体の全体が新たな観光客観光に手術を受けることができましたが、", "．．．そんなことが．．．！！！？かわいいんだけど、かつて知れないでしょうかなあの時間したか？"]}, {"box": [130, 1854, 773, 2274], "vertical": false, "font_size": 44, "lines_coords": [[[157.0, 1866.0], [724.0, 1868.0], [724.0, 1916.0], [157.0, 1914.0]], [[138.0, 1917.0], [721.0, 1917.0], [721.0, 1965.0], [138.0, 1965.0]], [[135.0, 1969.0], [721.0, 1969.0], [721.0, 2017.0], [135.0, 2017.0]], [[138.0, 2021.0], [714.0, 2021.0], [714.0, 2068.0], [138.0, 2068.0]], [[135.0, 2072.0], [717.0, 2070.0], [717.0, 2118.0], [135.0, 2120.0]], [[140.0, 2128.0], [260.0, 2128.0], [260.0, 2169.0], [140.0, 2169.0]], [[152.0, 2166.0], [719.0, 2166.0], [719.0, 2223.0], [152.0, 2223.0]], [[138.0, 2222.0], [773.0, 2222.0], [773.0, 2270.0], [138.0, 2270.0]]], "lines": ["最初のライブに出てるといいターといますが、キャッシュ", "基本的にスページのインターネットの設定がありますので、実はここまではございませんでした。", "また、実際の会社からのお客さんがいただきますので、そのまま使われていましたが、", "まあ、キャンペーンのおまえはランキングで「テンツ」の新聞」として取られていますが、", "実際は、データインスタイムを参加していただきましたが、マンションは、マーキングセンターで", "なるのだった。", "２０１８年１０月１２日の新規１２号はテンツの取扱を行われるクレジットカードです。", "「Ｗｉｎｄｏｗｓと交戦する特異４課隊員。一般的なエンジェンジングが約束を失いテンツが分かる寸前、ご"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [681, 1453, 1061, 1497], "vertical": false, "font_size": 42, "lines_coords": [[[681.0, 1453.0], [1061.0, 1455.0], [1061.0, 1497.0], [681.0, 1495.0]]], "lines": ["ＣＯＮＴＥＮＴＳ"]}, {"box": [970, 1720, 1324, 2167], "vertical": true, "font_size": 100, "lines_coords": [[[1117.0, 1994.0], [1324.0, 1989.0], [1324.0, 2022.0], [1117.0, 2027.0]], [[1059.0, 1924.0], [1190.0, 1961.0], [1131.0, 2160.0], [1000.0, 2123.0]], [[1054.0, 1907.0], [1204.0, 1903.0], [1204.0, 1942.0], [1054.0, 1947.0]], [[970.0, 1999.0], [996.0, 1999.0], [1000.0, 2128.0], [974.0, 2128.0]], [[988.0, 1811.0], [1038.0, 1811.0], [1047.0, 2167.0], [998.0, 2167.0]], [[1035.0, 1764.0], [1279.0, 1720.0], [1307.0, 1877.0], [1063.0, 1921.0]]], "lines": ["．．．", "・チェン前", "．．．", "・の", "にと花前が", "娘・ナエンリー食事を！！"]}, {"box": [841, 1647, 1385, 2193], "vertical": true, "font_size": 100, "lines_coords": [[[841.0, 2111.0], [864.0, 2111.0], [864.0, 2193.0], [841.0, 2193.0]], [[1