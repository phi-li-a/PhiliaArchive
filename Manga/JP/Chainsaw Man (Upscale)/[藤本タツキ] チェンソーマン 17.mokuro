故の若手学の決勝ってきたアイテム", "１．夢の次．ｎｏ＊日揃ってきたチェンソーマン・Ｉマッサージ・＂２", "１５１３１５２３", "第１３１話第１５２３１年１５３話", "５０１５年１月ってきたチェンツ３０年１、マッサージ．．．２５３３号「チエンソーマンハン"]}, {"box": [672, 2245, 1375, 2285], "vertical": false, "font_size": 40, "lines_coords": [[[672.0, 2245.0], [1375.0, 2245.0], [1375.0, 2285.0], [672.0, 2285.0]]], "lines": ["１５３話」チェンリーマンハンター．．．"]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [904, 1699, 1033, 1853], "vertical": true, "font_size": 64, "lines_coords": [[[972.0, 1699.0], [1033.0, 1699.0], [1033.0, 1853.0], [972.0, 1853.0]], [[904.0, 1699.0], [972.0, 1699.0], [972.0, 1816.0], [904.0, 1816.0]]], "lines": ["じゅっ", "．．．！"]}, {"box": [393, 1921, 663, 2191], "vertical": true, "font_size": 63, "lines_coords": [[[569.0, 1921.0], [663.0, 1921.0], [663.0, 2053.0], [569.0, 2053.0]], [[524.0, 1940.0], [574.0, 1940.0], [574.0, 2142.0], [524.0, 2142.0]], [[456.0, 1935.0], [515.0, 1935.0], [515.0, 2095.0], [456.0, 2095.0]], [[393.0, 1938.0], [442.0, 1938.0], [442.0, 2191.0], [393.0, 2191.0]]], "lines": ["銃が", "こんなに", "あった", "なんて．．．！"]}], "img_path": "00007.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1174, 121, 1464, 590], "vertical": true, "font_size": 59, "lines_coords": [[[1392.0, 121.0], [1457.0, 121.0], [1457.0, 335.0], [1392.0, 335.0]], [[1331.0, 124.0], [1387.0, 124.0], [1387.0, 590.0], [1331.0, 590.0]], [[1253.0, 121.0], [1312.0, 121.0], [1307.0, 389.0], [1249.0, 389.0]], [[1178.0, 121.0], [1235.0, 121.0], [1230.0, 536.0], [1174.0, 536.0]]], "lines": ["この銃は", "チェンソーマンから", "譲り受けた", "光の武器である！"]}, {"box": [213, 220, 578, 637], "vertical": true, "font_size": 56, "lines_coords": [[[508.0, 220.0], [564.0, 220.0], [564.0, 588.0], [508.0, 588.0]], [[431.0, 227.0], [487.0, 227.0], [487.0, 492.0], [431.0, 492.0]], [[351.0, 225.0], [407.0, 225.0], [407.0, 539.0], [351.0, 539.0]], [[283.0, 220.0], [346.0, 220.0], [351.0, 637.0], [288.0, 637.0]], [[217.0, 222.0], [267.0, 222.0], [262.0, 532.0], [213.0, 532.0]]], "lines": ["光を以ってして", "国家の闇を", "晴らす事こそ", "チェンソーマンの", "意思である！"]}, {"box": [1031, 932, 1188, 1239], "vertical": true, "font_size": 74, "lines_coords": [[[1115.0, 932.0], [1188.0, 932.0], [1183.0, 1239.0], [1110.0, 1239.0]], [[1031.0, 935.0], [1106.0, 935.0], [1106.0, 1183.0], [1031.0, 1183.0]]], "lines": ["チェンソー", "マン最高"]}, {"box": [1040, 1368, 1195, 1673], "vertical": true, "font_size": 73, "lines_coords": [[[1122.0, 1368.0], [1195.0, 1368.0], [1195.0, 1673.0], [1122.0, 1673.0]], [[1040.0, 1368.0], [1113.0, 1368.0], [1113.0, 1668.0], [1040.0, 1668.0]]], "lines": ["チェンソー", "マン最高！"]}, {"box": [1197, 1931, 1463, 2306], "vertical": true, "font_size": 83, "lines_coords": [[[1368.0, 1933.0], [1450.0, 1933.0], [1457.0, 2303.0], [1375.0, 2306.0]], [[1295.0, 1945.0], [1356.0, 1945.0], [1356.0, 2238.0], [1295.0, 2238.0]], [[1197.0, 1931.0], [1303.0, 1931.0], [1303.0, 2076.0], [1197.0, 2076.0]]], "lines": ["特異７課１名", "正面玄関に", "投入"]}, {"box": [681, 2017, 977, 2233], "vertical": true, "font_size": 81, "lines_coords": [[[860.0, 2095.0], [942.0, 2064.0], [977.0, 2160.0], [895.0, 2191.0]], [[789.0, 2022.0], [864.0, 2022.0], [864.0, 2233.0], [789.0, 2233.0]], [[686.0, 2017.0], [771.0, 2020.0], [766.0, 2167.0], [681.0, 2165.0]]], "lines": ["さっ", "裏口に", "投入"]}], "img_path": "00008.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [517, 1040, 814, 1432], "vertical": true, "font_size": 146, "lines_coords": [[[646.0, 1040.0], [810.0, 1040.0], [810.0, 1432.0], [646.0, 1432.0]], [[517.0, 1059.0], [644.0, 1057.0], [651.0, 1408.0], [524.0, 1410.0]]], "lines": ["撃ち方", "用意！"]}], "img_path": "00009.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1267, 113, 1467, 574], "vertical": true, "font_size": 86, "lines_coords": [[[1373.0, 117.0], [1462.0, 117.0], [1467.0, 492.0], [1378.0, 492.0]], [[1267.0, 117.0], [1349.0, 117.0], [1349.0, 571.0], [1267.0, 571.0]]], "lines": ["あらあら", "あらあら！"]}, {"box": [240