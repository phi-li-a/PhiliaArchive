["【普通の幸せ】"]}, {"box": [539, 2156, 944, 2299], "vertical": false, "font_size": 136, "lines_coords": [[[539.0, 2163.0], [942.0, 2156.0], [944.0, 2292.0], [541.0, 2299.0]]], "lines": ["藤本タツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [656, 121, 1415, 192], "vertical": false, "font_size": 71, "lines_coords": [[[656.0, 121.0], [1415.0, 121.0], [1415.0, 192.0], [656.0, 192.0]]], "lines": ["－－ＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [921, 307, 956, 330], "vertical": false, "font_size": 23, "lines_coords": [[[921.0, 307.0], [956.0, 307.0], [956.0, 330.0], [921.0, 330.0]]], "lines": ["たか"]}, {"box": [831, 410, 1410, 865], "vertical": false, "font_size": 104, "lines_coords": [[[1117.0, 473.0], [1150.0, 473.0], [1150.0, 557.0], [1117.0, 557.0]], [[1134.0, 480.0], [1312.0, 475.0], [1314.0, 562.0], [1136.0, 567.0]], [[1082.0, 480.0], [1117.0, 480.0], [1117.0, 553.0], [1082.0, 553.0]], [[1021.0, 494.0], [1066.0, 492.0], [1071.0, 604.0], [1026.0, 607.0]], [[993.0, 410.0], [1410.0, 424.0], [1399.0, 761.0], [981.0, 747.0]], [[1049.0, 616.0], [1307.0, 621.0], [1307.0, 670.0], [1049.0, 665.0]], [[1096.0, 670.0], [1141.0, 670.0], [1141.0, 689.0], [1096.0, 689.0]], [[904.0, 487.0], [998.0, 464.0], [1049.0, 670.0], [956.0, 693.0]], [[1352.0, 494.0], [1392.0, 494.0], [1392.0, 738.0], [1352.0, 738.0]], [[867.0, 466.0], [906.0, 466.0], [902.0, 609.0], [862.0, 609.0]], [[897.0, 614.0], [935.0, 614.0], [935.0, 682.0], [897.0, 682.0]], [[838.0, 471.0], [871.0, 471.0], [871.0, 585.0], [838.0, 585.0]], [[848.0, 618.0], [892.0, 618.0], [892.0, 660.0], [848.0, 660.0]], [[1230.0, 796.0], [1312.0, 796.0], [1312.0, 822.0], [1230.0, 822.0]], [[836.0, 670.0], [1373.0, 682.0], [1373.0, 745.0], [836.0, 733.0]], [[862.0, 745.0], [1385.0, 747.0], [1385.0, 796.0], [862.0, 794.0]], [[838.0, 745.0], [881.0, 747.0], [874.0, 860.0], [831.0, 857.0]], [[867.0, 817.0], [1363.0, 817.0], [1363.0, 857.0], [867.0, 857.0]]], "lines": ["いつ足を", "嘘ないじめをも", "陰", "ず、正", "めず、設定といじめを受けることの問題に使われる内容は事実．．．これにはただった。実際に話した言葉を開くことが", "２悪魔・ヨルに体を", "ょうし", "じゃないですか？", "る．．．死にもいる", "ご校舎", "が、", "お学この", "んだ", "くせんちゅう", "られ生き返った。両親を殺した悪魔を", "しでおり、チェンソーマンのことも良く", "んお思", "っていない。ヨルの扱いに苦戦中．．．！！"]}, {"box": [299, 1000, 692, 1090], "vertical": false, "font_size": 42, "lines_coords": [[[534.0, 1000.0], [642.0, 1005.0], [642.0, 1031.0], [534.0, 1026.0]], [[302.0, 1026.0], [681.0, 1019.0], [681.0, 1078.0], [302.0, 1085.0]]], "lines": ["あくまで、", "コル（戦争の悪魔"]}, {"box": [842, 1706, 1305, 1782], "vertical": false, "font_size": 66, "lines_coords": [[[843.0, 1708.0], [1295.0, 1708.0], [1295.0, 1774.0], [843.0, 1774.0]]], "lines": ["デンジ（チェッツーマン）"]}, {"box": [70, 953, 780, 1537], "vertical": false, "font_size": 128, "lines_coords": [[[70.0, 1132.0], [693.0, 953.0], [780.0, 1256.0], [157.0, 1434.0]], [[166.0, 1148.0], [206.0, 1148.0], [206.0, 1293.0], [166.0, 1293.0]], [[257.0, 1221.0], [674.0, 1221.0], [674.0, 1300.0], [257.0, 1300.0]], [[222.0, 1289.0], [264.0, 1289.0], [264.0, 1420.0], [222.0, 1420.0]], [[250.0, 1270.0], [616.0, 1270.0], [616.0, 1361.0], [250.0, 1361.0]], [[283.0, 1324.0], [588.0, 1324.0], [588.0, 1422.0], [283.0, 1422.0]], [[145.0, 1490.0], [417.0, 1495.0], [417.0, 1537.0], [145.0, 1532.0]]], "lines": ["まあそういうことで今回の番号であってもコンピューションとしてしまいました。あなたが、", "来悪", "チェンソーマンを殺すため、", "体た", "体を乗っ取って脳の半分を", "．．．ネフ取って悩みする殺したものを武器に", "とはよく分からない。"]}, {"box": [0, 982, 733, 1821], "vertical": false, "font_size": 450, "lines_coords": [[[124.0, 982.0], [733.0, 1420.0], [445.0, 1821.0], [0.0, 1382.0]]], "lines": ["．．．"]}, {"box": [1141, 1816, 1399, 2118], "vertical": true, "font_size": 132, "lines_coords": [[[1359.0, 1851.0], [1399.0, 1851.0], [1392.0, 2097.0], [1352.0, 2097.0]], [[1288.0, 1846.0], [1324.0, 1846.0], [1328.0, 1971.0], [1293.0, 1971.0]], [[1267.0, 1816.0], [1378.0, 1816.0], [1378.0, 2118.0], [1267.0, 2118.0]], [[1251.0, 1832.0], [1298.0, 1832.0], [1298.0, 2097.0], [1251.0, 2097.0]], [[1211.0, 1835.0], [1253.0, 1832.0], [1260.0, 1966.0], [1218.0, 1968.0]], [[1174.0, 1856.0], [1220.0, 1851.0], [1232.0, 1971.0], [1185.0, 1975.0]], [[1141.0, 1851.0], [1192.0, 1849.0], [1199.0, 1978.0], [1148.0, 1980.0]]], "lines": ["すと«悪«辺", "にっ校", "ちょっと宿校生とかに悪いので、", "臓高密安", "心は", "のん段", "その普"]}, {"box": [876, 1910, 1387, 2235], "vertical": true, "font_size": 132, "lines_coords": [[[1286.0, 2104.0], [1387.0, 2104.0], [1387.0, 2156.0], [1286.0, 2156.0]], [[1061.0, 2041.0], [1202.0, 2053.0], [1197.0, 2104.0], [1056.0, 2092.0]], [[1021.0, 2043.0], [1061.0, 2043.0], [1061.0, 2095.0], [1021.0, 2095.0]], [[890.0, 1910.0], [1328.0, 1931.0], [1314.0, 2235.0], [876.0, 2214.0]], [[883.0, 1919.0], [1049.0, 1919.0], [1049.0, 1968.0], [883.0, 1968.0]]], "lines": ["ナユタ", "っている。", "戦", "それは．．．お兄ちゃんのおおっちゃったんだろうかなあってあげようかもしれ", "チェンツー"]}, {"box": [820, 1814, 1195, 2224], "vertical": true, "font_size": 132, "lines_coords": [[[958.0, 2175.0], [1195.0, 2175.0], [1195.0, 2224.0], [958.0, 2224.0]], [[822.0, 1814.0], [1171.0, 1821.0], [1169.0, 1921.0], [820.0, 1914.0]]], "lines": ["を託されたが．．．？", "ラニングーが重点をく"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [250, 601, 580, 680], "vertical": false, "font_size": 58, "lines_coords": [[[250.0, 618.0], [576.0, 614.0], [576.0, 672.0], [250.0, 677.0]]], "lines": ["キガ（飢餓の悪魔"]}, {"box": [131, 724, 714, 848], "vertical": false, "font_size": 44, "lines_coords": [[[135.0, 738.0], [714.0, 738.0], [714.0, 785.0], [135.0, 785.0]], [[138.0, 803.0], [522.0, 803.0], [522.0, 843.0], [138.0, 843.0]]], "lines": ["アサの高校のデビルハンター部に所属する女子", "生徒。正体は戦争。の悪魔の姉。"]}, {"box": [956, 616, 1253, 682], "vertical": false, "font_size": 66, "lines_coords": [[[956.0, 616.0], [1253.0, 616.0], [1253.0, 682.0], [956.0, 682.0]]], "lines": ["吉田ヒロフミ"]}, {"box": [815, 723, 1417, 849], "vertical": false, "font_size": 44, "lines_coords": [[[815.0, 740.0], [1417.0, 740.0], [1417.0, 787.0], [815.0, 787.0]], [[815.0, 801.0], [1124.0, 806.0], [1124.0, 846.0], [815.0, 841.0]]], "lines": ["民間を経て、公安に所属するデビルハンター。", "デンジの正体を隠したい。"]}, {"box": [270, 1390, 584, 1483], "vertical": false, "font_size": 57, "lines_coords": [[[283.0, 1417.0], [569.0, 1417.0], [569.0, 1474.0], [283.0, 1474.0]]], "lines": ["伊勢海ハルカ"]}, {"box": [128, 1523, 700, 1647], "vertical": false, "font_size": 55, "lines_coords": [[[128.0, 1523.0], [700.0, 1523.0], [700.0, 1593.0], [128.0, 1593.0]], [[133.0, 1603.0], [560.0, 1607.0], [560.0, 1647.0], [133.0, 1642.0]]], "lines": ["デンジの高校のデビルハンター部部長。チ", "ンソーマン教会の広告塔でもある。"]}, {"box": [142, 1760, 424, 1809], "vertical": false, "font_size": 49, "lines_coords": [[[142.0, 1760.0], [424.0, 1760.0], [424.0, 1809.0], [142.0, 1809.0]]], "lines": ["ＳＴＯＲＹ－"]}, {"box": [909, 1404, 1284, 1479], "vertical": false, "font_size": 56, "lines_coords": [[[909.0, 1420.0], [1281.0, 1413.0], [1281.0, 1469.0], [909.0, 1476.0]]], "lines": ["ナユタ（支配の悪魔"]}, {"box": [810, 1521, 1401, 1647], "vertical": false, "font_size": 48, "lines_coords": [[[810.0, 1532.0], [1401.0, 1532.0], [1401.0, 1589.0], [810.0, 1589.0]], [[813.0, 1605.0], [1258.0, 1605.0], [1258.0, 1645.0], [813.0, 1645.0]]], "lines": ["支配の悪魔・マキマが生まれ変わった姿。デ", "ンジと犬と猫と一緒に暮らしている。"]}, {"box": [117, 1832, 766, 2043], "vertical": false, "font_size": 91.25, "lines_coords": [[[663.0, 1875.0], [735.0, 1875.0], [735.0, 1919.0], [663.0, 1919.0]], [[117.0, 1832.0], [766.0, 1832.0], [766.0, 2025.0], [117.0, 2025.0]], [[131.0, 1919.0], [515.0, 1926.0], [515.0, 1982.0], [131.0, 1975.0]], [[126.0, 1966.0], [731.0, 1971.0], [731.0, 2043.0], [126.0, 2039.0]]], "lines": ["．．．を受け、大田い", "これからも、一部アップサービスをしているのですが、この日の時間はどれだけではないのかもしれませんが、できます。", "北海道は少女・二原作りは子校さらに正義の悪魔を契約した委員に対することが", "さらに正直な風景を突破した気長もあるが、殺されてしまう。だが、事情が悪いコルになっていますが、その時期には"]}, {"box": [241, 2149, 309, 2172], "vertical": false, "font_size": 23, "lines_coords": [[[241.0, 2149.0], [309.0, 2149.0], [309.0, 2172.0], [241.0, 2172.0]]], "lines": ["よけんどーよー"]}, {"box": [138, 2046, 703, 2207], "vertical": false, "font_size": 40.0, "lines_coords": [[[323.0, 2046.0], [684.0, 2053.0], [684.0, 2092.0], [323.0, 2085.0]], [[138.0, 2050.0], [344.0, 2050.0], [344.0, 2090.0], [138.0, 2090.0]], [[138.0, 2107.0], [681.0, 2107.0], [681.0, 2146.0], [138.0, 2146.0]], [[161.0, 2165.0], [703.0, 2163.0], [703.0, 2205.0], [161.0, 2207.0]]], "lines": ["！チェンソーマンを探し出し、", "を奪われ復活！！", "すことができれば体を返すと言うヨルだが．．．！？", "キガの予言通り、根源的恐怖の名を持つ。落下"]}, {"box": [370, 2149, 510, 2172], "vertical": false, "font_size": 23, "lines_coords": [[[370.0, 2149.0], [510.0, 2149.0], [510.0, 2172.0], [370.0, 2172.0]]], "lines": ["こんげんできまようかお口になって"]}, {"box": [131, 2212, 724, 2266], "vertical": false, "font_size": 54, "lines_coords": [[[131.0, 2212.0], [724.0, 2212.0], [724.0, 2266.0], [131.0, 2266.0]]], "lines": ["２０１８年１１月２４日の馬鹿「小山駅」アプリを撮ったリーチェンリーマンと"]}, {"box": [689, 2046, 719, 2090], "vertical": false, "font_size": 44, "lines_coords": [[[689.0, 2046.0], [719.0, 2046.0], [719.0, 2090.0], [689.0, 2090.0]]], "lines": ["ごれ叔"]}, {"box": [817, 1931, 1267, 1975], "vertical": false, "font_size": 40, "lines_coords": [[[817.0, 1931.0], [1267.0, 1935.0], [1267.0, 1975.0], [817.0, 1971.0]]], "lines": ["ンの助けを得るも絶体絶命の状況に、"]}, {"box": [738, 1788, 1497, 2175], "vertical": false, "font_size": 179.0, "lines_coords": [[[773.0, 1788.0], [1497.0, 1875.0], [1462.0, 2175.0], [738.0, 2088.0]], [[806.0, 1870.0], [1281.0, 1863.0], [1281.0, 1919.0], [806.0, 1926.0]]], "lines": ["これからは、これは", "．．．してお別にアサを学ぶデジジは、第チェンの周りを売る予想機構的に、最後のお"]}, {"box": [815, 2046, 1399, 2259], "vertical": false, "font_size": 39.75, "lines_coords": [[[815.0, 2046.0], [1387.0, 2046.0], [1387.0, 2092.0], [815.0, 2092.0]], [[820.0, 2109.0], [1399.0, 2109.0], [1399.0, 2149.0], [820.0, 2149.0]], [[815.0, 2165.0], [1396.0, 2165.0], [1396.0, 2205.0], [815.0, 2205.0]], [[822.0, 2226.0], [1382.0, 2226.0], [1382.0, 2259.0], [822.0, 2259.0]]], "lines": ["のだった。だが安心したのも束の間、公安の吉田", "はナユタの命を盾に「二度とチェンソーマンになら", "ないでほしい」とデンジに迫る。チヤホヤされた", "い欲求と、ナコタの安全の間で揺れるデンジは！？"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [410, 1371, 789, 1410], "vertical": false, "font_size": 39, "lines_coords": [[[410.0, 1371.0], [789.0, 1371.0], [789.0, 1410.0], [410.0, 1410.0]]], "lines": ["ＣＯＮＴＥＮＴＳ"]}, {"box": [480, 1563, 541, 1689], "vertical": true, "font_size": 26.0, "lines_coords": [[[515.0, 1563.0], [541.0, 1563.0], [541.0, 1689.0], [515.0, 1689.0]], [[480.0, 1565.0], [506.0, 1565.0], [506.0, 1687.0], [480.0, 1687.0]]], "lines": ["．．．", "１１"]}, {"box": [548, 1556, 585, 1776], "vertical": true, "font_size": 32, "lines_coords": [[[553.0, 1556.0], [585.0, 1556.0], [581.0, 1776.0], [548.0, 1776.0]]], "lines": ["５６７"]}, {"box": [459, 1464, 979, 1523], "vertical": false, "font_size": 56, "lines_coords": [[[459.0, 1464.0], [979.0, 1467.0], [979.0, 1523.0], [459.0, 1521.0]]], "lines": ["第１３４話「普通の幸せのっ"]}, {"box": [677, 1619, 988, 1706], "vertical": false, "font_size": 87, "lines_coords": [[[677.0, 1619.0], [988.0, 1619.0], [988.0, 1706.0], [677.0, 1706.0]]], "lines": ["「ピノノハンル」普通の日々の"]}, {"box": [621, 1556, 1192, 1610], "vertical": false, "font_size": 50, "lines_coords": [[[621.0, 1560.0], [1192.0, 1556.0], [1192.0, 1605.0], [621.0, 1610.0]]], "lines": ["話」センチメンタルドライブーの"]}, {"box": [421, 1457, 461, 2285], "vertical": true, "font_size": 40, "lines_coords": [[[421.0, 1457.0], [461.0, 1457.0], [461.0, 2285.0], [421.0, 2285.0]]], "lines": ["な第５第３第１２第二第第２５第第三第六第"]}, {"box": [595, 1535, 646, 2118], "vertical": true, "font_size": 47, "lines_coords": [[[595.0, 1535.0], [642.0, 1535.0], [646.0, 2118.0], [599.0, 2118.0]]], "lines": ["話．話。話、話し話し訳。話して"]}, {"box": [548, 1865, 581, 1947], "vertical": true, "font_size": 33, "lines_coords": [[[548.0, 1865.0], [581.0, 1865.0], [581.0, 1947.0], [548.0, 1947.0]]], "lines": ["９"]}, {"box": [480, 2247, 888, 2280], "vertical": false, "font_size": 33, "lines_coords": [[[480.0, 2247.0], [888.0, 2247.0], [888.0, 2280.0], [480.0, 2280.0]]], "lines": ["１４３話」がおールの"]}, {"box": [508, 2160, 1101, 2196], "vertical": false, "font_size": 29.5, "lines_coords": [[[508.0, 2163.0], [1026.0, 2163.0], [1026.0, 2196.0], [508.0, 2196.0]], [[1012.0, 2165.0], [1101.0, 2160.0], [1101.0, 2186.0], [1012.0, 2191.0]]], "lines": ["Ｌ４２話］デンジファンクラブ", "ブｒｓａ"]}, {"box": [599, 1722, 1413, 2210], "vertical": false, "font_size": 257.6666666666667, "lines_coords": [[[686.0, 1729.0], [1413.0, 1727.0], [1413.0, 1776.0], [686.0, 1778.0]], [[599.0, 1722.0], [1092.0, 1722.0], [1092.0, 2210.0], [599.0, 2210.0]], [[665.0, 1863.0], [1042.0, 1825.0], [1066.0, 2060.0], [689.0, 2097.0]]], "lines": ["２０１普通の日々、１００万円・チューチェーラブリームニュースプレーシードマンツの", "いいじゃないですから、ありがとうございませんでしょうかもしれないと思うけど．．．", "いつでもオープンしてるのですが、インスの発見られない女性の人生プラスに"]}, {"box": [981, 2074, 1078, 2111], "vertical": false, "font_size": 33, "lines_coords": [[[981.0, 2078.0], [1075.0, 2074.0], [1078.0, 2107.0], [984.0, 2111.0]]], "lines": ["．．．"]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [399, 519, 638, 742], "vertical": false, "font_size": 223, "lines_coords": [[[399.0, 519.0], [638.0, 519.0], [638.0, 742.0], [399.0, 742.0]]], "lines": ["チェンソーマンの戦い方は酷い！"]}, {"box": [393, 513, 637, 742], "vertical": true, "font_size": 54, "lines_coords": [[[588.0, 520.0], [637.0, 520.0], [637.0, 742.0], [588.0, 742.0]], [[527.0, 517.0], [588.0, 517.0], [588.0, 658.0], [527.0, 658.0]], [[454.0, 515.0], [513.0, 513.0], [520.0, 700.0], [461.0, 703.0]], [[393.0, 515.0], [454.0, 515.0], [454.0, 656.0], [393.0, 656.0]]], "lines": ["チェンソー", "マンの", "戦い方は", "酷い！"]}, {"box": [332, 820, 646, 1092], "vertical": true, "font_size": 54, "lines_coords": [[[588.0, 820.0], [646.0, 820.0], [646.0, 970.0], [588.0, 970.0]], [[520.0, 820.0], [576.0, 820.0], [581.0, 1092.0], [524.0, 1092.0]], [[456.0, 822.0], [508.0, 822.0], [508.0, 965.0], [456.0, 965.0]], [[396.0, 825.0], [435.0, 825.0], [435.0, 1045.0], [396.0, 1045.0]], [[337.0, 820.0], [384.0, 820.0], [379.0, 1092.0], [332.0, 1092.0]]], "lines": ["建物を", "壊して戦って", "悪魔と", "変わらない", "じゃないか！"]}, {"box": [510, 1162, 707, 1476], "vertical": true, "font_size"