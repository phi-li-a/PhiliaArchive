.0], [1143.0, 147.0], [1143.0, 564.0], [1087.0, 564.0]]], "lines": ["まだ", "社会に出ていない", "学生を集めて", "デモ隊と戦って．．．"]}, {"box": [79, 344, 509, 660], "vertical": true, "font_size": 48, "lines_coords": [[[435.0, 346.0], [492.0, 346.0], [492.0, 534.0], [435.0, 534.0]], [[377.0, 349.0], [424.0, 349.0], [424.0, 614.0], [377.0, 614.0]], [[321.0, 344.0], [370.0, 344.0], [365.0, 660.0], [316.0, 660.0]], [[264.0, 346.0], [314.0, 346.0], [314.0, 616.0], [264.0, 616.0]], [[199.0, 349.0], [248.0, 349.0], [248.0, 571.0], [199.0, 571.0]], [[138.0, 351.0], [178.0, 351.0], [178.0, 569.0], [138.0, 569.0]], [[79.0, 351.0], [121.0, 351.0], [121.0, 520.0], [79.0, 520.0]]], "lines": ["夜な夜な", "悪魔を殺して", "デビルハンター", "ごっこしてる", "なんて話も", "聞いてるん", "ですよ！"]}, {"box": [1053, 815, 1397, 1179], "vertical": true, "font_size": 54, "lines_coords": [[[1314.0, 815.0], [1370.0, 815.0], [1378.0, 1129.0], [1321.0, 1129.0]], [[1256.0, 815.0], [1312.0, 815.0], [1312.0, 1026.0], [1256.0, 1026.0]], [[1176.0, 820.0], [1232.0, 820.0], [1237.0, 1178.0], [1181.0, 1178.0]], [[1117.0, 822.0], [1167.0, 822.0], [1167.0, 1127.0], [1117.0, 1127.0]], [[1054.0, 825.0], [1103.0, 825.0], [1103.0, 1026.0], [1054.0, 1026.0]]], "lines": ["親御さん達を", "どれだけ", "心配させてるか", "わかってるん", "ですか！？"]}, {"box": [60, 850, 485, 1221], "vertical": true, "font_size": 56, "lines_coords": [[[421.0, 850.0], [485.0, 850.0], [478.0, 1221.0], [414.0, 1221.0]], [[360.0, 857.0], [410.0, 857.0], [410.0, 1162.0], [360.0, 1162.0]], [[276.0, 853.0], [339.0, 853.0], [339.0, 1167.0], [276.0, 1167.0]], [[203.0, 850.0], [260.0, 850.0], [255.0, 1113.0], [199.0, 1113.0]], [[128.0, 857.0], [178.0, 857.0], [178.0, 1110.0], [128.0, 1110.0]], [[65.0, 855.0], [114.0, 855.0], [110.0, 1162.0], [60.0, 1162.0]]], "lines": ["チェンソーマン", "ごっこをして", "死んだ人達に", "どう責任を", "取るつもり", "なんですか！？"]}, {"box": [651, 1403, 958, 1762], "vertical": true, "font_size": 47, "lines_coords": [[[909.0, 1403.0], [958.0, 1403.0], [953.0, 1760.0], [904.0, 1760.0]], [[838.0, 1403.0], [888.0, 1403.0], [892.0, 1720.