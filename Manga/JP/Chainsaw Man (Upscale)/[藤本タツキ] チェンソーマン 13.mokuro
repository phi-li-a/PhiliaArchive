{"version": "0.2.1", "title": "Chainsaw Man (Upscale)", "title_uuid": "eaf1d805-0f0f-4e40-99d9-251919a6f8f7", "volume": "[藤本タツキ] チェンソーマン 13", "volume_uuid": "37250251-98e3-474e-9311-32bcc188484c", "pages": [{"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [897, 1621, 1169, 1682], "vertical": false, "font_size": 56, "lines_coords": [[[897.0, 1621.0], [1169.0, 1626.0], [1169.0, 1682.0], [897.0, 1678.0]]], "lines": ["ネタバレ"]}], "img_path": "00001.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [135, 2172, 1389, 2268], "vertical": false, "font_size": 33.0, "lines_coords": [[[138.0, 2172.0], [1385.0, 2172.0], [1385.0, 2205.0], [138.0, 2205.0]], [[135.0, 2235.0], [1389.0, 2235.0], [1389.0, 2268.0], [135.0, 2268.0]]], "lines": ["★この作品はフィクシヨンです。実在の人物・団体・事件などには、", "いっさい関係ありません。デジタル配信用に再編集を行っています。"]}], "img_path": "00002.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [36, 35, 582, 128], "vertical": false, "font_size": 79, "lines_coords": [[[60.0, 42.0], [581.0, 42.0], [581.0, 128.0], [60.0, 128.0]]], "lines": ["ＪＵＭＰＣＯＭＩＣＳで、"]}, {"box": [664, 261, 819, 301], "vertical": false, "font_size": 40, "lines_coords": [[[664.0, 261.0], [819.0, 261.0], [819.0, 301.0], [664.0, 301.0]]], "lines": ["しかし、お"]}, {"box": [234, 1757, 738, 1919], "vertical": false, "font_size": 157, "lines_coords": [[[234.0, 1762.0], [735.0, 1757.0], [738.0, 1914.0], [236.0, 1919.0]]], "lines": ["チェンソ"]}, {"box": [539, 1919, 944, 2301], "vertical": false, "font_size": 126.66666666666667, "lines_coords": [[[649.0, 1919.0], [848.0, 1938.0], [831.0, 2102.0], [632.0, 2083.0]], [[639.0, 2069.0], [836.0, 2069.0], [836.0, 2146.0], [639.0, 2146.0]], [[539.0, 2165.0], [942.0, 2153.0], [944.0, 2292.0], [541.0, 2301.0]]], "lines": ["１３", "【ネタバレ】私と", "藤本タツキ"]}], "img_path": "00003.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [670, 117, 1413, 194], "vertical": false, "font_size": 72, "lines_coords": [[[670.0, 117.0], [1413.0, 121.0], [1413.0, 194.0], [670.0, 189.0]]], "lines": ["ＦＣＨＡＲＡＣＴＥＲＳ"]}, {"box": [953, 405, 1272, 597], "vertical": false, "font_size": 192, "lines_coords": [[[953.0, 405.0], [1272.0, 405.0], [1272.0, 597.0], [953.0, 597.0]]], "lines": ["三鷹アサ"]}, {"box": [1106, 632, 1422, 1033], "vertical": true, "font_size": 120, "lines_coords": [[[1373.0, 660.0], [1420.0, 660.0], [1422.0, 1033.0], [1375.0, 1033.0]], [[1288.0, 632.0], [1321.0, 637.0], [1317.0, 698.0], [1281.0, 696.0]], [[1249.0, 635.0], [1288.0, 635.0], [1288.0, 712.0], [1249.0, 712.0]], [[1197.0, 693.0], [1239.0, 700.0], [1225.0, 787.0], [1183.0, 780.0]], [[1138.0, 700.0], [1197.0, 698.0], [1206.0, 900.0], [1148.0, 902.0]], [[1117.0, 705.0], [1164.0, 710.0], [1153.0, 827.0], [1106.0, 822.0]]], "lines": ["花正だ体両り．．．", "湿", "陰", "独", "孤襲悪の", "るに"]}, {"box": [1080, 705, 1349, 956], "vertical": true, "font_size": 120, "lines_coords": [[[1279.0, 907.0], [1349.0, 907.0], [1349.0, 956.0], [1279.0, 956.0]], [[1080.0, 705.0], [1122.0, 705.0], [1129.0, 900.0], [1087.0, 900.0]], [[1127.0, 834.0], [1162.0, 834.0], [1162.0, 890.0], [1127.0, 890.0]]], "lines": ["った。", "け魔術争", "の"]}, {"box": [1014, 642, 1094, 918], "vertical": true, "font_size": 120, "lines_coords": [[[1040.0, 642.0], [1089.0, 642.0], [1094.0, 918.0], [1045.0, 918.0]], [[1014.0, 684.0], [1049.0, 684.0], [1049.0, 764.0], [1014.0, 764.0]], [[1017.0, 761.0], [1045.0, 761.0], [1045.0, 815.0], [1017.0, 815.0]]], "lines": ["にっ受悪化戦", "．．．", "の"]}, {"box": [904, 600, 1476, 1324], "vertical": true, "font_size": 120, "lines_coords": [[[1071.0, 897.0], [1293.0, 897.0], [1293.0, 982.0], [1071.0, 982.0]], [[960.0, 600.0], [1078.0, 602.0], [1066.0, 1040.0], [949.0, 1038.0]], [[1005.0, 911.0], [1040.0, 902.0], [1054.0, 956.0], [1019.0, 965.0]], [[1042.0, 972.0], [1394.0, 972.0], [1394.0, 1021.0], [1042.0, 1021.0]], [[1031.0, 972.0], [1054.0, 996.0], [1031.0, 1019.0], [1007.0, 996.0]], [[984.0, 1050.0], [1413.0, 1050.0], [1413.0, 1082.0], [984.0, 1082.0]], [[932.0, 1003.0], [1476.0, 1059.0], [1448.0, 1324.0], [904.0, 1267.0]], [[1003.0, 1169.0], [1143.0, 1169.0], [1143.0, 1218.0], [1003.0, 1218.0]]], "lines": ["取られ生き返っ", "学校を夢のが、を乗っ発", "粟", "苦しい情報を作んでお", "それ", "ああ、そうだけど", "それは．．．これまで", "青戦中．．．！！"]}, {"box": [138, 1612, 557, 1743], "vertical": false, "font_size": 127, "lines_coords": [[[138.0, 1617.0], [555.0, 1612.0], [557.0, 1739.0], [140.0, 1743.0]]], "lines": ["ヨル（戦争の悪魔）"]}, {"box": [445, 1792, 550, 2078], "vertical": true, "font_size": 95, "lines_coords": [[[445.0, 1985.0], [480.0, 1985.0], [480.0, 2078.0], [445.0, 2078.0]], [[506.0, 1814.0], [550.0, 1814.0], [550.0, 1884.0], [506.0, 1884.0]], [[461.0, 1809.0], [510.0, 1792.0], [531.0, 1860.0], [482.0, 1877.0]]], "lines": ["半", "を", "ジャマ"]}, {"box": [424, 1870, 550, 2191], "vertical": true, "font_size": 95, "lines_coords": [[[510.0, 1928.0], [550.0, 1928.0], [546.0, 2191.0], [506.0, 2191.0]], [[475.0, 1886.0], [548.0, 1886.0], [548.0, 1931.0], [475.0, 1931.0]], [[454.0, 1870.0], [499.0, 1896.0], [468.0, 1950.0], [424.0, 1924.0]]], "lines": ["サを器は", "ェン", "キ"]}, {"box": [311, 1811, 492, 2135], "vertical": true, "font_size": 95, "lines_coords": [[[445.0, 2067.0], [480.0, 2067.0], [480.0, 2135.0], [445.0, 2135.0]], [[365.0, 1870.0], [419.0, 1870.0], [419.0, 1961.0], [365.0, 1961.0]], [[358.0, 1811.0], [492.0, 1811.0], [492.0, 1882.0], [358.0, 1882.0]], [[311.0, 1875.0], [363.0, 1858.0], [384.0, 1926.0], [332.0, 1942.0]]], "lines": ["を", "魔", "のような", "悪悪"]}, {"box": [239, 1935, 456, 2100], "vertical": true, "font_size": 95, "lines_coords": [[[323.0, 2017.0], [456.0, 2017.0], [456.0, 2069.0], [323.0, 2069.0]], [[285.0, 1935.0], [328.0, 1938.0], [318.0, 2100.0], [276.0, 2097.0]], [[264.0, 1940.0], [299.0, 1954.0], [274.0, 2015.0], [239.0, 2001.0]]], "lines": ["って脳の", "殺と取る", "た"]}, {"box": [178, 1811, 264, 1942], "vertical": true, "font_size": 95, "lines_coords": [[[206.0, 1814.0], [257.0, 1811.0], [264.0, 1940.0], [213.0, 1942.0]], [[178.0, 1816.0], [217.0, 1816.0], [217.0, 1870.0], [178.0, 1870.0]]], "lines": ["フッ戦", "は"]}, {"box": [32, 1809, 623, 2301], "vertical": true, "font_size": 95, "lines_coords": [[[138.0, 2217.0], [506.0, 2214.0], [506.0, 2257.0], [138.0, 2259.0]], [[32.0, 1821.0], [614.0, 1809.0], [623.0, 2289.0], [42.0, 2301.0]]], "lines": ["．．．そんなことないですよ", "そんなことはありませんでしょう。お前．．．ここまではないですからここで何度も知らないのかもしれないようにしかったんだろうね。"]}, {"box": [159, 1919, 456, 2149], "vertical": true, "font_size": 95, "lines_coords": [[[278.0, 2083.0], [456.0, 2078.0], [456.0, 2128.0], [278.0, 2132.0]], [[215.0, 1919.0], [290.0, 1935.0], [243.0, 2149.0], [168.0, 2132.0]], [[194.0, 2001.0], [234.0, 2029.0], [199.0, 2078.0], [159.0, 2053.0]]], "lines": ["殺したもの", "スンをを乗っした", "たし"]}, {"box": [103, 1804, 154, 2071], "vertical": true, "font_size": 95, "lines_coords": [[[114.0, 1945.0], [154.0, 1950.0], [142.0, 2071.0], [103.0, 2067.0]], [[114.0, 1804.0], [140.0, 1804.0], [140.0, 1860.0], [114.0, 1860.0]]], "lines": ["ソの", "本"]}, {"box": [107, 1788, 192, 2257], "vertical": true, "font_size": 95, "lines_coords": [[[107.0, 2050.0], [140.0, 2050.0], [145.0, 2257.0], [112.0, 2257.0]], [[110.0, 1788.0], [192.0, 1788.0], [192.0, 1945.0], [110.0, 1945.0]]], "lines": ["あー支になる", "本来！した、"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [229, 131, 674, 196], "vertical": false, "font_size": 65, "lines_coords": [[[229.0, 131.0], [674.0, 131.0], [674.0, 196.0], [229.0, 196.0]]], "lines": ["デンジ（ァェンッーマン）"]}, {"box": [51, 262, 424, 754], "vertical": true, "font_size": 104, "lines_coords": [[[389.0, 377.0], [424.0, 377.0], [424.0, 440.0], [389.0, 440.0]], [[360.0, 391.0], [393.0, 391.0], [389.0, 501.0], [356.0, 501.0]], [[339.0, 393.0], [367.0, 393.0], [367.0, 440.0], [339.0, 440.0]], [[302.0, 318.0], [342.0, 318.0], [332.0, 562.0], [292.0, 562.0]], [[257.0, 447.0], [290.0, 447.0], [295.0, 562.0], [262.0, 562.0]], [[210.0, 389.0], [297.0, 389.0], [297.0, 447.0], [210.0, 447.0]], [[208.0, 487.0], [257.0, 510.0], [227.0, 576.0], [178.0, 555.0]], [[194.0, 583.0], [255.0, 583.0], [255.0, 618.0], [194.0, 618.0]], [[164.0, 567.0], [189.0, 567.0], [189.0, 623.0], [164.0, 623.0]], [[51.0, 262.0], [391.0, 262.0], [391.0, 754.0], [51.0, 754.0]]], "lines": ["戦戦", "とル岸", "魔", "普悪安心配", "うんムレ支", "密かに", "ら", "・ナ", "魔", "チェックース要素はシンーマン。最近２０１５年に発売されている女の子たちに、それら、そういうことを、テコラを作るわけですから"]}, {"box": [358, 271, 684, 403], "vertical": true, "font_size": 104, "lines_coords": [[[400.0, 318.0], [684.0, 318.0], [684.0, 391.0], [400.0, 391.0]], [[358.0, 321.0], [400.0, 321.0], [400.0, 403.0], [358.0, 403.0]], [[384.0, 271.0], [679.0, 276.0], [679.0, 325.0], [384.0, 321.0]]], "lines": ["事情をさして生活して", "は", "その後話できました。"]}, {"box": [353, 1408, 500, 1471], "vertical": false, "font_size": 33, "lines_coords": [[[377.0, 1422.0], [480.0, 1422.0], [480.0, 1455.0], [377.0, 1455.0]]], "lines": ["．．．"]}, {"box": [122, 1516, 721, 1638], "vertical": false, "font_size": 40, "lines_coords": [[[135.0, 1535.0], [721.0, 1532.0], [721.0, 1572.0], [135.0, 1575.0]], [[133.0, 1593.0], [389.0, 1596.0], [389.0, 1635.0], [133.0, 1633.0]]], "lines": ["アサの友達。親を悪魔に殺されたため、デビ", "ルハンターに憧れる。"]}, {"box": [142, 1760, 424, 1809], "vertical": false, "font_size": 49, "lines_coords": [[[142.0, 1760.0], [424.0, 1760.0], [424.0, 1809.0], [142.0, 1809.0]]], "lines": ["ＳＴＯＲＹ－"]}, {"box": [953, 1410, 1253, 1474], "vertical": false, "font_size": 64, "lines_coords": [[[953.0, 1410.0], [1253.0, 1410.0], [1253.0, 1474.0], [953.0, 1474.0]]], "lines": ["吉田ヒロフミ"]}, {"box": [813, 1521, 1399, 1636], "vertical": false, "font_size": 36, "lines_coords": [[[813.0, 1535.0], [1399.0, 1532.0], [1399.0, 1572.0], [813.0, 1575.0]], [[813.0, 1598.0], [1038.0, 1598.0], [1038.0, 1631.0], [813.0, 1631.0]]], "lines": ["とある組織に所属するデビルハンター。デンジ", "の正体を隠したい。"]}, {"box": [133, 1980, 159, 2092], "vertical": true, "font_size": 26, "lines_coords": [[[133.0, 1980.0], [159.0, 1980.0], [159.0, 2092.0], [133.0, 2092.0]]], "lines": ["の争"]}, {"box": [140, 1875, 724, 2034], "vertical": false, "font_size": 40.0, "lines_coords": [[[157.0, 1875.0], [651.0, 1877.0], [651.0, 1917.0], [157.0, 1914.0]], [[140.0, 1938.0], [719.0, 1938.0], [719.0, 1971.0], [140.0, 1971.0]], [[152.0, 1987.0], [724.0, 1985.0], [724.0, 2032.0], [152.0, 2034.0]]], "lines": ["学校になじめない風俗なら女・三鷹アサ。", "スでも孤立する中、正義の悪魔と契約した委員長", "の恨みを買い、アサは死んでしまう。だが、戦"]}, {"box": [152, 2041, 726, 2097], "vertical": false, "font_size": 56, "lines_coords": [[[152.0, 2041.0], [726.0, 2041.0], [726.0, 2097.0], [152.0, 2097.0]]], "lines": ["今回の記事へインターネットのお申し訳ございます。申し点書一日に本を集めれば保証リーチェントで"]}, {"box": [133, 2109, 719, 2261], "vertical": false, "font_size": 37.666666666666664, "lines_coords": [[[133.0, 2109.0], [719.0, 2109.0], [719.0, 2149.0], [133.0, 2149.0]], [[140.0, 2170.0], [323.0, 2170.0], [323.0, 2203.0], [140.0, 2203.0]], [[166.0, 2221.0], [717.0, 2221.0], [717.0, 2261.0], [166.0, 2261.0]]], "lines": ["ンを探し出し、殺すことができれば、体を返すと", "言うヨルだが．．．？", "ヨルの命令でデビルハンタ一部の入部試験を受け"]}, {"box": [766, 1823, 1441, 2100], "vertical": false, "font_size": 79.0, "lines_coords": [[[766.0, 1835.0], [1438.0, 1823.0], [1441.0, 2013.0], [768.0, 2025.0]], [[815.0, 1989.0], [1401.0, 1989.0], [1401.0, 2036.0], [815.0, 2036.0]], [[1232.0, 2034.0], [1328.0, 2034.0], [1328.0, 2057.0], [1232.0, 2057.0]], [[808.0, 2036.0], [1408.0, 2043.0], [1408.0, 2100.0], [808.0, 2092.0]]], "lines": ["このようなものですが、自分のことで、コミュニケーションに関わっていました。お客様へのご相談をございます。", "いいから、ユーザーのみんなので、を差し伸べ、ついは成長に、お前を見ているようになってしまいました。", "よるか今のうちの人たちは大抵統を", "できるから、こんなはきゃいませんでしたからなったならば、こうものの事態が変えてしまいましょうかと"]}, {"box": [810, 2104, 1410, 2205], "vertical": false, "font_size": 43.0, "lines_coords": [[[810.0, 2104.0], [1410.0, 2107.0], [1410.0, 2153.0], [810.0, 2151.0]], [[815.0, 2163.0], [1406.0, 2165.0], [1406.0, 2205.0], [815.0, 2203.0]]], "lines": ["ろをチェンソーマン「に救われるのだった。一方、", "デンジに接近し正体を隠すよう警告する吉田。だが、"]}, {"box": [820, 2228, 1394, 2259], "vertical": false, "font_size": 31, "lines_coords": [[[820.0, 2228.0], [1394.0, 2228.0], [1394.0, 2259.0], [820.0, 2259.0]]], "lines": ["正体をバラしてモテたいデンジは聞く耳を持たず！？"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [602, 1450, 977, 1500], "vertical": false, "font_size": 50, "lines_coords": [[[602.0, 1450.0], [977.0, 1450.0], [977.0, 1500.0], [602.0, 1500.0]]], "lines": ["ＣｏＮＴＥＮＴＳ"]}, {"box": [217, 1164, 1403, 2357], "vertical": false, "font_size": 212, "lines_coords": [[[737.0, 1607.0], [780.0, 1607.0], [775.0, 1796.0], [732.0, 1796.0]], [[1002.0, 1724.0], [1045.0, 1724.0], [1045.0, 1792.0], [1002.0, 1792.0]], [[552.0, 1145.0], [1354.0, 1445.0], [1019.0, 2375.0], [216.0, 2075.0]], [[922.0, 1790.0], [1075.0, 1706.0], [1150.0, 1878.0], [997.0, 1960.0]], [[1093.0, 1809.0], [1202.0, 1804.0], [1202.0, 1874.0], [1093.0, 1878.0]], [[922.0, 1602.0], [956.0, 1602.0], [956.0, 2075.0], [922.0, 2075.0]], [[962.0, 1811.0], [991.0, 1811.0], [991.0, 1902.0], [962.0, 1902.0]], [[980.0, 1888.0], [1274.0, 1886.0], [1274.0, 1958.0], [980.0, 1960.0]], [[788.0, 1598.0], [822.0, 1598.0], [822.0, 2216.0], [788.0, 2216.0]], [[952.0, 1907.0], [979.0, 1884.0], [1003.0, 1944.0], [976.0, 1968.0]], [[613.0, 1577.0], [660.0, 1577.0], [656.0, 2303.0], [608.0, 2303.0]], [[1320.0, 1977.0], [1401.0, 1973.0], [1403.0, 2035.0], [1323.0, 2040.0]], [[955.0, 1966.0], [1338.0, 1961.0], [1338.0, 2047.0], [955.0, 2052.0]], [[905.0, 2057.0], [1181.0, 2057.0], [1181.0, 2134.0], [905.0, 2134.0]], [[1060.0, 2148.0], [1153.0, 2148.0], [1153.0, 2211.0], [1060.0, 2211.0]], [[819.0, 2146.0], [1073.0, 2146.0], [1073.0, 2214.0], [819.0, 2214.0]], [[716.0, 2221.0], [1235.0, 2226.0], [1235.0, 2303.0], [716.0, 2298.0]]], "lines": ["２０１４．３１０５６１１０６６年１２０７３", "Ａｎｄｏｏｋｏｗｓの製撃者", "．．．", "我々学校の事業者の大切なもの", "．．．要者知なもの。", "そうだなあ．．．あそこにちょっとこのファミもありましたね", "東北学校の関野アサの大坂", "枝の襲撃者。ｗｅｂサの大切なもの．．．単なイジメのなくしかた", "それは．．．", "学校の要望アサの大切有単なイジ", "．．．", "«かた．．．。", "アサの大切なもの．．．簡単なイジメのなくしかたね。夜のチャイム．ｎｏ", "簡単なイジメのなくし夜のチャイム．．．！アパハハハ！！", "ヤイム．．．。ハハ．．メッ罪者の間", "の話」夜のチャイム１話１アハハハ八２話」類と報罪者の", "１１月１７日（月）１１：２０１２年１月２月前までは"]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [44, 1335, 1415, 1483], "vertical": false, "font_size": 120, "lines_coords": [[[44.0, 1364.0], [1413.0, 1335.0], [1415.0, 1455.0], [46.0, 1483.0]]], "lines": ["あぁあああぁぁぁんぁぁふぁぁあ！！"]}, {"box": [788, 2231, 1403, 2318], "vertical": false, "font_size": 60, "lines_coords": [[[822.0, 2247.0], [1157.0, 2247.0], [1157.0, 2310.0], [822.0, 2310.0]], [[1129.0, 2252.0], [1352.0, 2252.0], [1352.0, 2310.0], [1129.0, 2310.0]]], "lines": ["第１０４話」", "レネタバ"]}], "img_path": "00007.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1157, 103, 1352, 517], "vertical": true, "font_size": 51, "lines_coords": [[[1295.0, 103.0], [1352.0, 103.0], [1347.0, 517.0], [1291.0, 517.0]], [[1218.0, 105.0], [1277.0, 105.0], [1277.0, 363.0], [1218.0, 363.0]], [[1157.0, 105.0], [1204.0, 105.0], [1204.0, 372.0], [1157.0, 372.0]]], "lines": ["チェンソーマンに", "助っ．．．けっ", "られたあ～"]}, {"box": [1096, 175, 1138, 257], "vertical": true, "font_size": 51, "lines_coords": [[[1096.0, 175.0], [1138.0, 175.0], [1138.0, 257.0], [1096.0, 257.0]]], "lines": ["．．．"]}, {"box": [623, 562, 792, 787], "vertical": true, "font_size": 46, "lines_coords": [[[735.0, 562.0], [792.0, 562.0], [792.0, 750.0], [735.0, 750.0]], [[677.0, 569.0], [719.0, 569.0], [719.0, 787.0], [677.0, 787.0]], [[623.0, 569.0], [663.0, 569.0], [663.0, 787.0], [623.0, 787.0]]], "lines": ["ウザくて", "眠れないん", "だけど．．．！"]}, {"box": [236, 979, 428, 1146], "vertical": true, "font_size": 63, "lines_coords": [[[360.0, 979.0], [428.0, 979.0], [428.0, 1139.0], [360.0, 1139.0]], [[302.0, 982.0], [360.0, 982.0], [360.0, 1146.0], [302.0, 1146.0]], [[236.0, 982.0], [299.0, 982.0], [299.0, 1092.0], [236.0, 1092.0]]], "lines": ["チキっ", "ショ〰", "．．．！"]}, {"box": [834, 1516, 1061, 1825], "vertical": true, "font_size": 48, "lines_coords": [[[1007.0, 1516.0], [1056.0, 1516.0], [1061.0, 1701.0], [1012.0, 1701.0]], [[958.0, 1521.0], [1000.0, 1521.0], [1000.0, 1701.0], [958.0, 1701.0]], [[899.0, 1518.0], [949.0, 1518.0], [949.0, 1825.0], [899.0, 1825.0]], [[834.0, 1518.0], [883.0, 1518.0], [883.0, 1746.0], [834.0, 1746.0]]], "lines": ["．．．なんで", "そんなに", "チェンソーマン", "嫌いなの？"]}, {"box": [510, 1537, 701, 1846], "vertical": true, "font_size": 50, "lines_coords": [[[625.0, 1537.0], [684.0, 1537.0], [684.0, 1729.0], [625.0, 1729.0]], [[574.0, 1537.0], [623.0, 1537.0], [623.0, 1846.0], [574.0, 1846.0]], [[510.0, 1537.0], [553.0, 1537.0], [553.0, 1760.0], [510.0, 1760.0]]], "lines": ["．．．私は昔", "チェンソーマン", "と戦った！"]}], "img_path": "00008.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1124, 93, 1376, 447], "vertical": true, "font_size": 48, "lines_coords": [[[1307.0, 96.0], [1354.0, 96.0], [1354.0, 358.0], [1307.0, 358.0]], [[1246.0, 96.0], [1293.0, 96.0], [1293.0, 447.0], [1246.0, 447.0]], [[1190.0, 96.0], [1239.0, 96.0], [1239.0, 447.0], [1190.0, 447.0]], [[1124.0, 93.0], [1171.0, 93.0], [1171.0, 400.0], [1124.0, 400.0]]], "lines": ["何度殺しても", "立ち上がってくる", "チェンソーマンに", "私は負けて．．．"]}, {"box": [506, 89, 853, 400], "vertical": true, "font_size": 53, "lines_coords": [[[796.0, 93.0], [853.0, 93.0], [853.0, 351.0], [796.0, 351.0]], [[714.0, 89.0], [773.0, 89.0], [778.0, 353.0], [719.0, 353.0]], [[646.0, 96.0], [696.0, 96.0], [696.0, 400.0], [646.0, 400.0]], [[571.0, 96.0], [621.0, 96.0], [621.0, 349.0], [571.0, 349.0]], [[506.0, 93.0], [560.0, 93.0], [560.0, 199.0], [506.0, 199.0]]], "lines": ["そのせいか", "世界大戦後", "戦争が一度も", "起こらなく", "なり"]}, {"box": [972, 960, 1291, 1260], "vertical": true, "font_size": 59, "lines_coords": [[[1216.0, 963.0], [1279.0, 963.0], [1279.0, 1260.0], [1216.0, 1260.0]], [[1136.0, 965.0], [1185.0, 965.0], [1185.0, 1253.0], [1136.0, 1253.0]], [[1042.0, 960.0], [1106.0, 960.0], [1106.0, 1260.0], [1042.0, 1260.0]], [[972.0, 972.0], [1031.0, 972.0], [1031.0, 1200.0], [972.0, 1200.0]]], "lines": ["気がつくと", "体を食われ", "弱くなって", "いた．．．！"]}, {"box": [602, 485, 808, 841], "vertica