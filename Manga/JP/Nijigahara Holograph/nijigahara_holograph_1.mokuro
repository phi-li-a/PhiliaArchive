{"version": "0.2.0-beta.6", "title": "Nijigahara Holograph", "title_uuid": "91fea91b-20e7-4d84-8c70-694f9ef4bcf5", "volume": "nijigahara_holograph_1", "volume_uuid": "fcc08ad0-a66b-4251-a48b-ec8bd4083485", "pages": [{"version": "0.1.6", "img_width": 980, "img_height": 400, "blocks": [{"box": [378, 30, 437, 134], "vertical": true, "font_size": 14.0, "lines": ["．．．", "なんですか", "大変だとなったら"]}, {"box": [636, 42, 692, 52], "vertical": false, "font_size": 12.0, "lines": ["ＣＤ９７９－４７６２Ｅ"]}, {"box": [635, 23, 724, 35], "vertical": false, "font_size": 12.0, "lines": ["１５時４９７８－４－７７８１－２０２０１７"]}, {"box": [635, 74, 712, 99], "vertical": false, "font_size": 12.0, "lines": ["定価「本体７６２円・税」", "大田山は"]}, {"box": [478, 107, 503, 248], "vertical": true, "font_size": 12.0, "lines": ["．．．", "うんううんだ", "．．．"]}], "img_path": "001.png"}, {"version": "0.1.6", "img_width": 979, "img_height": 128, "blocks": [{"box": [713, 18, 776, 109], "vertical": true, "font_size": 14.0, "lines": ["「強い意志を", "持ちな。", "もっともつと", "強い意志を」"]}, {"box": [674, 24, 701, 103], "vertical": true, "font_size": 12.0, "lines": ["「犯々直」という大地を提供", "女に、小学校の対象", "のぬるとりが女席で"]}, {"box": [644, 24, 653, 78], "vertical": true, "font_size": 12.0, "lines": ["空、城の奥太先生"]}, {"box": [624, 23, 637, 67], "vertical": true, "font_size": 13.0, "lines": ["お世紀数かは、"]}, {"box": [497, 19, 510, 95], "vertical": true, "font_size": 12.0, "lines": ["「おまえはいらん"]}, {"box": [575, 23, 607, 112], "vertical": true, "font_size": 12.0, "lines": ["こんな物品は", "もう描けないと思います", "逃げしにお"]}, {"box": [259, 24, 466, 116], "vertical": false, "font_size": 14.0, "lines": ["．．．長編連載作品", "出来ないです、怠け者の君へ、", "いつもの間へ、臆病者の君へ", "「ひゃいのまちょっ！！リラニンとの言動いた私が", "ウォハラリの人数連続に", "．．．神星の乗り車の"]}], "img_path": "002.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 641, "blocks": [{"box": [638, 126, 709, 176], "vertical": false, "font_size": 21.5, "lines": ["．．．", "．．．"]}, {"box": [484, 343, 497, 426], "vertical": true, "font_size": 12.0, "lines": ["決戦いにお"]}, {"box": [473, 616, 511, 624], "vertical": false, "font_size": 12.0, "lines": ["．．．"]}, {"box": [470, 214, 509, 299], "vertical": true, "font_size": 14.0, "lines": ["虹ケーターの", "ホログラフ"]}, {"box": [103, 503, 115, 595], "vertical": true, "font_size": 13.0, "lines": ["！！"]}, {"box": [76, 505, 89, 594], "vertical": true, "font_size": 13.0, "lines": ["ホログラフ"]}, {"box": [49, 505, 64, 596], "vertical": true, "font_size": 13.0, "lines": ["浅野いにお"]}], "img_path": "003.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1398, "blocks": [{"box": [338, 393, 361, 585], "vertical": true, "font_size": 22.0, "lines": ["私は、ケーターに"]}, {"box": [282, 391, 305, 582], "vertical": true, "font_size": 22.0, "lines": ["ホログラフ"]}, {"box": [229, 393, 248, 584], "vertical": true, "font_size": 22.0, "lines": ["そういえば、"]}], "img_path": "004.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1398, "blocks": [], "img_path": "005.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "006.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [181, 1197, 205, 1283], "vertical": true, "font_size": 21.0, "lines": ["お", "い"]}], "img_path": "007.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "008.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "009.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [226, 64, 244, 181], "vertical": true, "font_size": 21.0, "lines": ["どうですか？"]}, {"box": [133, 248, 185, 351], "vertical": true, "font_size": 21.0, "lines": ["お父さんの", "容体は？"]}, {"box": [841, 747, 867, 810], "vertical": true, "font_size": 26.0, "lines": ["あ．．．"]}, {"box": [422, 796, 476, 979], "vertical": true, "font_size": 23.0, "lines": ["親父の事", "知ってるんですか？"]}, {"box": [99, 748, 216, 892], "vertical": true, "font_size": 24.0, "lines": ["．．．．．親父は", "手術後の経過が", "あまり良く", "なくて、"]}, {"box": [425, 1202, 449, 1274], "vertical": true, "font_size": 24.0, "lines": ["．．．ええ。"]}, {"box": [69, 1189, 154, 1314], "vertical": true, "font_size": 23.0, "lines": ["もうこの数日", "眠ったまま", "ですよ。"]}], "img_path": "010.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [824, 60, 910, 206], "vertical": true, "font_size": 24.0, "lines": ["これでも一応", "感謝はしてるん", "です。"]}, {"box": [431, 401, 546, 527], "vertical": true, "font_size": 22.0, "lines": ["血の繋がりの", "ない僕を", "育ててくれた", "訳ですから。"]}, {"box": [124, 214, 242, 594], "vertical": true, "font_size": 20.0, "lines": ["．．．こんなの", "いっそのこと", "不謹慎かも", "目覚めないほうが", "しれないけど、", "いいんじゃないか", "って気がします。"]}, {"box": [872, 653, 922, 784], "vertical": true, "font_size": 20.0, "lines": ["時折口元が", "笑うんですよ。"]}, {"box": [747, 759, 825, 930], "vertical": true, "font_size": 20.0, "lines": ["そしてうわ言の", "ように誰かの名前", "を呼んでるんです。"]}, {"box": [802, 1073, 881, 1195], "vertical": true, "font_size": 19.0, "lines": ["でもそれは", "きっと僕じゃ", "ないんだ．．．"]}, {"box": [647, 1162, 757, 1326], "vertical": true, "font_size": 19.0, "lines": ["父はいつも", "もういない誰かに", "想いを馳せて", "いましたからね。"]}], "img_path": "011.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [777, 689, 861, 815], "vertical": true, "font_size": 24.0, "lines": ["この頃．．．", "僕もよく夢を", "見るんです。"]}, {"box": [441, 892, 595, 1281], "vertical": true, "font_size": 22.0, "lines": ["今僕が見てる", "景色が夢", "なんじゃないかと", "日増しに", "思うくらい。", "夢の現実味が", "増していて．．．"]}, {"box": [98, 1159, 124, 1292], "vertical": true, "font_size": 23.0, "lines": ["それでも"]}], "img_path": "012.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [895, 88, 913, 209], "vertical": true, "font_size": 20.0, "lines": ["それでも結局"]}, {"box": [712, 170, 821, 334], "vertical": true, "font_size": 20.0, "lines": ["目が覚めれば", "やっぱり自分。", "本来そういうもの", "でしょう？"]}, {"box": [135, 157, 285, 550], "vertical": true, "font_size": 20.0, "lines": ["人間生きている", "からには何かしら", "役目があるはず", "ただそれに", "なんです。", "気付かない", "だけで。"]}, {"box": [766, 725, 822, 827], "vertical": true, "font_size": 23.0, "lines": ["．．．あなた", "誰ですか？"]}], "img_path": "013.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [772, 72, 854, 194], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．車椅子、", "押してもらえ", "ませんか？"]}, {"box": [135, 133, 231, 497], "vertical": true, "font_size": 24.0, "lines": ["．．．ほら", "泣いている", "そこにいる、", "少年のところ", "まで．．．"]}, {"box": [690, 470, 714, 534], "vertical": true, "font_size": 24.0, "lines": ["．．．え？"]}], "img_path": "014.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "015.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [128, 4, 191, 56], "vertical": false, "font_size": 16.0, "lines": ["素敵な", "！ギ回"]}, {"box": [83, 42, 179, 109], "vertical": false, "font_size": 20.5, "lines": ["ドイツかぼり", "満足ん"]}, {"box": [226, 919, 262, 968], "vertical": true, "font_size": 29.0, "lines": ["フッ"]}, {"box": [76, 1266, 103, 1311], "vertical": true, "font_size": 27.0, "lines": ["フッ"]}], "img_path": "016.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [899, 58, 923, 124], "vertical": true, "font_size": 24.0, "lines": ["フッ．．．"]}, {"box": [453, 140, 479, 207], "vertical": true, "font_size": 26.0, "lines": ["フッ．．．"]}, {"box": [393, 435, 419, 501], "vertical": true, "font_size": 26.0, "lines": ["フッ．．．"]}, {"box": [129, 545, 154, 609], "vertical": true, "font_size": 25.0, "lines": ["フッ．．．"]}, {"box": [847, 735, 867, 845], "vertical": true, "font_size": 19.0, "lines": ["こんばんわ"]}, {"box": [705, 1185, 758, 1289], "vertical": true, "font_size": 23.0, "lines": ["今夜は月が", "綺麗だね。"]}, {"box": [550, 1114, 574, 1198], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．さぁ"]}, {"box": [101, 1224, 188, 1367], "vertical": true, "font_size": 25.0, "lines": ["今日も話の", "続きを聞かせて", "おくれ。"]}], "img_path": "017.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [307, 50, 326, 159], "vertical": true, "font_size": 23.0, "lines": ["．．．まぁいい"]}, {"box": [161, 116, 248, 222], "vertical": true, "font_size": 23.0, "lines": ["時間は", "いくらでも", "あるんだ。"]}, {"box": [455, 169, 557, 573], "vertical": true, "font_size": 22.0, "lines": ["今日は随分", "落ちつきがない", "．．．", "じゃないか", "どうしたんだい？"]}, {"box": [79, 437, 193, 579], "vertical": true, "font_size": 19.0, "lines": ["たまには話を", "ふり返ってみる", "のもいいかも", "しれないね。"]}, {"box": [731, 918, 758, 994], "vertical": true, "font_size": 25.0, "lines": ["．．．さぁ、"]}, {"box": [211, 1004, 266, 1147], "vertical": true, "font_size": 22.0, "lines": ["どこまで", "逆のほろうか？"]}], "img_path": "018.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [419, 206, 605, 228], "vertical": false, "font_size": 20.0, "lines": ["．．．．．．"]}, {"box": [477, 258, 539, 278], "vertical": false, "font_size": 20.0, "lines": ["日本"]}, {"box": [705, 610, 724, 621], "vertical": false, "font_size": 12.0, "lines": ["．．．"]}, {"box": [543, 489, 564, 1148], "vertical": true, "font_size": 18.0, "lines": ["ああ、一話ーーーっっ話、話し話して話した話、一話一話ーーー話"]}], "img_path": "019.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [472, 406, 509, 531], "vertical": true, "font_size": 24.0, "lines": ["１１年前"]}], "img_path": "020.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "021.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "022.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [194, 644, 247, 788], "vertical": true, "font_size": 22.0, "lines": ["間違い", "ありませんか？"]}, {"box": [200, 915, 251, 1047], "vertical": true, "font_size": 22.0, "lines": ["６年前に", "別れた妻です。"]}, {"box": [876, 1194, 897, 1286], "vertical": true, "font_size": 19.0, "lines": ["ははい。"]}, {"box": [367, 1184, 484, 1347], "vertical": true, "font_size": 22.0, "lines": ["遺体の状況から", "見て死後数ヶ月は", "経っていると", "思います。"]}], "img_path": "023.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [820, 69, 902, 194], "vertical": true, "font_size": 21.0, "lines": ["．．．妻は私と", "別れた後すぐ", "別の男と．．．"]}, {"box": [509, 102, 595, 210], "vertical": true, "font_size": 25.0, "lines": ["別の男性と", "再婚し", "埼玉へ、"]}, {"box": [371, 192, 482, 364], "vertical": true, "font_size": 25.0, "lines": ["しかしその", "翌年に失踪して", "捜索願いが", "出されていました。"]}, {"box": [884, 385, 910, 498], "vertical": true, "font_size": 21.0, "lines": ["．．．木村さん、"]}, {"box": [777, 471, 859, 595], "vertical": true, "font_size": 21.0, "lines": ["これは", "私自身の興味", "ですかね"]}, {"box": [354, 495, 467, 638], "vertical": true, "font_size": 19.0, "lines": ["失踪中この方は", "５年もどこで", "何をしていたん", "でしょうか？"]}, {"box": [69, 420, 180, 585], "vertical": true, "font_size": 20.0, "lines": ["．．．このトンネルの", "中にね、人が生活", "していた形跡が", "あるんですよ。"]}, {"box": [822, 791, 844, 933], "vertical": true, "font_size": 18.0, "lines": ["知りませんよ．．"]}, {"box": [230, 721, 281, 845], "vertical": true, "font_size": 21.0, "lines": ["放っておいて", "ください。"]}, {"box": [86, 871, 195, 994], "vertical": true, "font_size": 21.0, "lines": ["今はもう私は", "娘と二人で", "幸せに暮らし", "てるんだ．．．"]}, {"box": [761, 1118, 873, 1280], "vertical": true, "font_size": 20.0, "lines": ["そういえば、", "ここらの小学生の", "間で変な噂が", "流行ってますな。"]}, {"box": [105, 1202, 156, 1353], "vertical": true, "font_size": 22.0, "lines": ["たしか、", "トンネルの"]}], "img_path": "024.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [811, 86, 870, 250], "vertical": true, "font_size": 22.0, "lines": ["トンネルの中の", "化け物が、"]}, {"box": [724, 292, 776, 394], "vertical": true, "font_size": 22.0, "lines": ["怪物じゃ", "ないっけ？"]}, {"box": [315, 121, 398, 223], "vertical": true, "font_size": 21.0, "lines": ["世界を", "終わらせる", "ってさ。"]}, {"box": [267, 297, 295, 383], "vertical": true, "font_size": 24.0, "lines": ["．．．．．なぁ、"]}, {"box": [856, 582, 908, 763], "vertical": true, "font_size": 22.0, "lines": ["そんなのウソに", "決まってんじゃん！！"]}, {"box": [481, 628, 504, 714], "vertical": true, "font_size": 23.0, "lines": ["．．．呪い？"]}, {"box": [144, 356, 237, 524], "vertical": true, "font_size": 24.0, "lines": ["それって", "ホントに", "ホントかなぁ！？"]}, {"box": [683, 680, 796, 821], "vertical": true, "font_size": 20.0, "lines": ["でもこの前、", "先生が顔にケガ", "したのも呪いの", "せいだって．．．"]}, {"box": [252, 633, 335, 817], "vertical": true, "font_size": 20.0, "lines": ["怪物にイケニエ", "をささければ", "助かるって聞いた？"]}, {"box": [158, 736, 181, 818], "vertical": true, "font_size": 23.0, "lines": ["何それ？"]}, {"box": [742, 1004, 853, 1126], "vertical": true, "font_size": 19.0, "lines": ["．．．でもさ、", "本当に世界が", "終ったら", "どうする？"]}, {"box": [518, 1165, 542, 1259], "vertical": true, "font_size": 23.0, "lines": ["バーカ！！"]}, {"box": [114, 1222, 210, 1390], "vertical": true, "font_size": 26.0, "lines": ["お前", "びびってんじゃ", "ねーよ！！"]}], "img_path": "025.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [702, 32, 795, 224], "vertical": true, "font_size": 25.0, "lines": ["そんなの元は", "木村が言いだした", "作り話だよ！！"]}, {"box": [569, 128, 631, 224], "vertical": true, "font_size": 25.0, "lines": ["あの女", "頭おか．．"]}, {"box": [794, 703, 826, 762], "vertical": true, "font_size": 30.0, "lines": ["．．．な、"]}, {"box": [148, 773, 202, 876], "vertical": true, "font_size": 24.0, "lines": ["なんだよ", "小松崎．．．"]}, {"box": [140, 1179, 192, 1290], "vertical": true, "font_size": 21.0, "lines": ["有江のこと", "悪く言うな。"]}], "img_path": "026.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [164, 532, 184, 622], "vertical": true, "font_size": 19.0, "lines": ["お父さん"]}, {"box": [181, 829, 234, 991], "vertical": true, "font_size": 19.0, "lines": ["お母さんは", "死んじゃったの？"]}, {"box": [847, 1155, 877, 1211], "vertical": true, "font_size": 30.0, "lines": ["．．．え"]}, {"box": [147, 1189, 229, 1312], "vertical": true, "font_size": 22.0, "lines": ["向かいの", "おばちゃんが", "言ってたよ。"]}], "img_path": "027.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [809, 109, 832, 199], "vertical": true, "font_size": 23.0, "lines": ["それでね、"]}, {"box": [162, 169, 279, 323], "vertical": true, "font_size": 25.0, "lines": ["「あんたら一家を", "みてるとこっち", "まで不幸になる」", "って。"]}, {"box": [852, 551, 878, 601], "vertical": true, "font_size": 26.0, "lines": ["．．．そ、"]}, {"box": [725, 632, 809, 718], "vertical": true, "font_size": 26.0, "lines": ["そんな事", "ないさ", "有江！！"]}, {"box": [123, 602, 237, 745], "vertical": true, "font_size": 22.0, "lines": ["あぁ！！", "母さんだって", "きっと見守って", "くれてる"]}, {"box": [784, 877, 897, 1020], "vertical": true, "font_size": 22.0, "lines": ["．．．確かに", "すこし前に", "母さんは死んだ", "けれど．．．"]}, {"box": [116, 923, 138, 1016], "vertical": true, "font_size": 20.0, "lines": ["．．．うん"]}, {"box": [571, 1157, 685, 1310], "vertical": true, "font_size": 22.0, "lines": ["きっと魂が", "蝶になって", "父さん達の側に", "いてくれるよ．．．。"]}, {"box": [187, 1138, 302, 1282], "vertical": true, "font_size": 22.0, "lines": ["．．．ほら、", "夕飯までまだ", "時間があるから", "遊んでおいで。"]}, {"box": [102, 1262, 131, 1334], "vertical": true, "font_size": 25.0, "lines": ["．．．うん。"]}], "img_path": "028.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [337, 145, 370, 296], "vertical": true, "font_size": 32.0, "lines": ["リーン"]}, {"box": [627, 771, 683, 915], "vertical": true, "font_size": 23.0, "lines": ["．．．あ、あぁ．．．", "小松崎くんか．．．"]}, {"box": [336, 1144, 419, 1291], "vertical": true, "font_size": 23.0, "lines": ["有江なら", "遊びに出かけた", "よ．．．"]}], "img_path": "029.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [173, 285, 197, 372], "vertical": true, "font_size": 21.0, "lines": ["．．．ん？"]}], "img_path": "030.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [451, 106, 582, 221], "vertical": true, "font_size": 26.0, "lines": ["かーって", "うれしい", "はないち", "もんめ"]}, {"box": [445, 956, 541, 1121], "vertical": true, "font_size": 27.0, "lines": ["まけーって", "くやしい", "はないちもんめ"]}], "img_path": "031.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "032.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "033.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "034.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "035.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [402, 73, 566, 280], "vertical": true, "font_size": 21.0, "lines": ["「見えるの", "見えるの", "あたしには見えるの", "この世の中の", "全てのできごとが」"]}, {"box": [688, 371, 747, 439], "vertical": true, "font_size": 30.0, "lines": ["君は", "神様？"]}, {"box": [824, 980, 847, 1092], "vertical": true, "font_size": 20.0, "lines": ["なら奇遇だ。"]}, {"box": [405, 760, 571, 905], "vertical": true, "font_size": 24.0, "lines": ["ちがうわ", "でも", "会ったことは", "あるのかも", "しれない"]}, {"box": [132, 1173, 216, 1297], "vertical": true, "font_size": 21.0, "lines": ["僕も一度だけ", "会ったことが", "あるよ。"]}], "img_path": "036.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [824, 98, 907, 209], "vertical": true, "font_size": 23.0, "lines": ["この前僕が", "ケガで入院", "してた時、"]}, {"box": [682, 191, 798, 396], "vertical": true, "font_size": 23.0, "lines": ["神様が", "僕の不幸を嘆いて", "プレゼントを持ってきた", "たんだ。"]}, {"box": [199, 297, 250, 420], "vertical": true, "font_size": 22.0, "lines": ["この小さな", "プリキの箱を"]}, {"box": [735, 780, 754, 859], "vertical": true, "font_size": 23.0, "lines": ["箱の中は"]}, {"box": [584, 857, 698, 1034], "vertical": true, "font_size": 23.0, "lines": ["どんな願いでも", "かなう一度きりの", "魔法が入っている", "らしい。"]}, {"box": [285, 781, 310, 883], "vertical": true, "font_size": 24.0, "lines": ["おーい！"]}, {"box": [166, 827, 222, 934], "vertical": true, "font_size": 24.0, "lines": ["鈴木", "く", "ん！？"]}], "img_path": "037.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [655, 100, 747, 262], "vertical": true, "font_size": 19.0, "lines": ["はじめての転校", "はじめての街。"]}, {"box": [619, 99, 642, 265], "vertical": true, "font_size": 23.0, "lines": ["それがどうした"]}, {"box": [442, 99, 538, 322], "vertical": true, "font_size": 22.0, "lines": ["景色も人も", "どこだって同じような", "もんだろ？"]}, {"box": [338, 101, 362, 245], "vertical": true, "font_size": 24.0, "lines": ["小学５年の春。"]}, {"box": [232, 97, 347, 254], "vertical": true, "font_size": 21.0, "lines": ["僕はどうしてか", "今日も僕だ。"]}, {"box": [787, 470, 808, 582], "vertical": true, "font_size": 15.0, "lines": ["今なら僕は"]}, {"box": [138, 605, 220, 766], "vertical": true, "font_size": 19.0, "lines": ["世界を終わらせる", "ことだって", "できるんだ。"]}, {"box": [504, 948, 560, 1009], "vertical": true, "font_size": 32.0, "lines": ["話"]}, {"box": [391, 948, 571, 1015], "vertical": false, "font_size": 32.0, "lines": ["話"]}, {"box": [252, 1065, 307, 1150], "vertical": true, "font_size": 24.0, "lines": ["じゃあ", "鈴木くん"]}, {"box": [144, 1154, 226, 1325], "vertical": true, "font_size": 24.0, "lines": ["そこの", "空いている席に", "座ってくれるかな。"]}], "img_path": "038.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [740, 73, 822, 235], "vertical": true, "font_size": 22.0, "lines": ["．．．", "ふたつ席が", "空いてますけど？"]}, {"box": [186, 271, 277, 638], "vertical": true, "font_size": 23.0, "lines": ["鈴木くんの机は", "その手前の", "あっ", "新品の机ね", "ごめんなさい、"]}, {"box": [444, 1213, 467, 1304], "vertical": true, "font_size": 23.0, "lines": ["よろしく。"]}], "img_path": "039.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [534, 76, 631, 220], "vertical": true, "font_size": 25.0, "lines": ["？？", "こら", "廊下を", "走るな"]}, {"box": [102, 161, 127, 281], "vertical": true, "font_size": 24.0, "lines": ["はー", "い！"]}, {"box": [805, 766, 895, 907], "vertical": true, "font_size": 23.0, "lines": ["榊先生、", "ずいぶん難しい", "顔してますね"]}, {"box": [507, 758, 589, 892], "vertical": true, "font_size": 24.0, "lines": ["いや．．．", "この絵", "なんですけど。"]}, {"box": [95, 807, 127, 859], "vertical": true, "font_size": 32.0, "lines": ["絵？"]}, {"box": [437, 1082, 552, 1277], "vertical": true, "font_size": 22.0, "lines": ["「未来のじぶん」って", "テーマで子供達に", "描かせたんです", "けど．．．"]}], "img_path": "040.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [846, 60, 897, 181], "vertical": true, "font_size": 19.0, "lines": ["コレなんだか", "わかります？"]}, {"box": [528, 43, 608, 195], "vertical": true, "font_size": 21.0, "lines": ["うーん．．．", "真っ赤．．．．実に", "真っ赤ですねぇ。"]}, {"box": [94, 8, 182, 383], "vertical": true, "font_size": 22.0, "lines": ["どういう意味", "そりゃ見れば", "なのかっていう．．．", "わかりますけど、"]}, {"box": [468, 441, 580, 605], "vertical": true, "font_size": 21.0, "lines": ["別にいいんじゃ", "ないスか？", "子供の自由な感性", "ってことで。"]}, {"box": [832, 743, 914, 925], "vertical": true, "font_size": 19.0, "lines": ["東京から転校して", "きた鈴木くんがコレ", "描いたんですけど、"]}, {"box": [463, 718, 520, 845], "vertical": true, "font_size": 27.0, "lines": ["入院？", "病気ですか？"]}, {"box": [576, 926, 694, 1280], "vertical": true, "font_size": 22.0, "lines": ["ちょっと雰囲気", "変わってるって", "長い入院生活で", "いうか．．．", "勉強も遅れがち", "らしいし．．．"]}, {"box": [90, 1146, 172, 1310], "vertical": true, "font_size": 22.0, "lines": ["いえ、前の学校で", "屋上から落ちた", "らしいです。"]}], "img_path": "041.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [863, 61, 887, 144], "vertical": true, "font_size": 24.0, "lines": ["落ちた？"]}, {"box": [690, 311, 716, 434], "vertical": true, "font_size": 24.0, "lines": ["もしくは．．．"]}, {"box": [795, 636, 818, 736], "vertical": true, "font_size": 22.0, "lines": ["．．．．．ホント"]}, {"box": [593, 460, 646, 564], "vertical": true, "font_size": 24.0, "lines": ["飛び降り", "．．．．．．た？"]}, {"box": [108, 293, 164, 583], "vertical": true, "font_size": 22.0, "lines": ["に", "なー", "ははは。", "言ってんスか？"]}, {"box": [680, 706, 732, 848], "vertical": true, "font_size": 22.0, "lines": ["何言ってんだろ", "あたし。"]}, {"box": [841, 972, 867, 1117], "vertical": true, "font_size": 23.0, "lines": ["とーべっ！！"]}, {"box": [259, 990, 285, 1132], "vertical": true, "font_size": 20.0, "lines": ["とー", "べっ！！"]}, {"box": [155, 1192, 184, 1338], "vertical": true, "font_size": 29.0, "lines": ["とーべっ！！"]}], "img_path": "042.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [620, 109, 675, 214], "vertical": true, "font_size": 26.0, "lines": ["つーか早く", "飛べって。"]}, {"box": [86, 218, 171, 362], "vertical": true, "font_size": 20.0, "lines": ["飛べないデブは", "ただのデブ", "．．．", "だぜ"]}, {"box": [566, 437, 619, 582], "vertical": true, "font_size": 21.0, "lines": ["ちょっと男子！！", "危ないでしょ！！"]}, {"box": [835, 693, 916, 854], "vertical": true, "font_size": 19.0, "lines": ["ねえ、このクラス", "いつもこんな", "感じなの？"]}, {"box": [312, 721, 366, 864], "vertical": true, "font_size": 22.0, "lines": ["．．．もういいよ", "そういうの。"]}, {"box": [865, 1036, 921, 1183], "vertical": true, "font_size": 26.0, "lines": ["ああ、", "小松崎くん達？"]}, {"box": [476, 1183, 527, 1332], "vertical": true, "font_size": 20.0, "lines": ["ホント男子って", "バカだよね。"]}, {"box": [114, 1218, 146, 1267], "vertical": true, "font_size": 32.0, "lines": ["え？"]}], "img_path": "043.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [542, 86, 563, 194], "vertical": true, "font_size": 19.0, "lines": ["もういいよ。"]}, {"box": [791, 587, 812, 714], "vertical": true, "font_size": 18.0, "lines": ["なにおまえ？"]}, {"box": [179, 859, 233, 968], "vertical": true, "font_size": 23.0, "lines": ["飛べば気が", "すむの？"]}], "img_path": "044.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [792, 752, 820, 803], "vertical": true, "font_size": 28.0, "lines": ["僕が"]}, {"box": [653, 752, 750, 894], "vertical": true, "font_size": 23.0, "lines": ["前の学校の", "屋上から", "飛び下りた時"]}, {"box": [472, 748, 573, 909], "vertical": true, "font_size": 27.0, "lines": ["これですべてが", "スッキリすると", "思った。"]}, {"box": [197, 748, 330, 927], "vertical": true, "font_size": 26.0, "lines": ["でも", "神様のきまぐれで", "僕はまだ", "生きている。"]}], "img_path": "045.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [835, 36, 891, 221], "vertical": true, "font_size": 24.0, "lines": ["おまえ", "バッカじゃないの？"]}, {"box": [259, 110, 392, 266], "vertical": true, "font_size": 26.0, "lines": ["それが", "僕にとって", "どういう意味が", "あるのか"]}, {"box": [631, 360, 652, 522], "vertical": true, "font_size": 19.0, "lines": ["何やってんだよ！！"]}, {"box": [92, 360, 150, 535], "vertical": true, "font_size": 23.0, "lines": ["いいよ、ほっとこ。", "行こうぜ？"]}, {"box": [480, 762, 503, 883], "vertical": true, "font_size": 19.0, "lines": ["わからない。"]}, {"box": [121, 1156, 145, 1258], "vertical": true, "font_size": 19.0, "lines": ["鈴木くん！？"]}], "img_path": "046.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [302, 120, 340, 247], "vertical": true, "font_size": 29.0, "lines": ["おーい！！"]}, {"box": [822, 474, 876, 658], "vertical": true, "font_size": 24.0, "lines": ["先生、あれ", "鈴木くんじゃない？"]}, {"box": [226, 285, 255, 453], "vertical": true, "font_size": 29.0, "lines": ["鈴木く", "ん！？"]}, {"box": [158, 588, 181, 671], "vertical": true, "font_size": 23.0, "lines": ["ホント？"]}, {"box": [837, 752, 918, 916], "vertical": true, "font_size": 22.0, "lines": ["君が神様の", "使いだかなんだか", "知らないけど、"]}, {"box": [552, 882, 578, 995], "vertical": true, "font_size": 24.0, "lines": ["なんとなく、"]}, {"box": [131, 1143, 182, 1274], "vertical": true, "font_size": 19.0, "lines": ["君とはまた", "会う気がする。"]}], "img_path": "047.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [293, 77, 318, 183], "vertical": true, "font_size": 24.0, "lines": ["じゃあね。"]}, {"box": [169, 909, 192, 991], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．あっ"]}], "img_path": "048.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "049.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [136, 200, 256, 592], "vertical": true, "font_size": 22.0, "lines": ["前に住んでた所じゃ", "鈴木くん、", "こんな夕日", "見れなかったんじゃ", "ない？"]}, {"box": [867, 844, 888, 946], "vertical": true, "font_size": 20.0, "lines": ["．．．どう？"]}, {"box": [561, 853, 644, 977], "vertical": true, "font_size": 20.0, "lines": ["新しい学校", "うまくやって", "いけそう？"]}], "img_path": "050.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [397, 110, 419, 200], "vertical": true, "font_size": 19.0, "lines": ["がんばろ。"]}, {"box": [724, 685, 785, 851], "vertical": true, "font_size": 32.0, "lines": ["僕は小さな声ではい、と言った。"]}, {"box": [725, 691, 779, 845], "vertical": true, "font_size": 22.0, "lines": ["僕は小さな声で", "はい、と言った"]}, {"box": [584, 687, 677, 866], "vertical": true, "font_size": 22.0, "lines": ["僕はちょっと", "嘘をついたような", "気分になった"]}, {"box": [442, 683, 505, 868], "vertical": true, "font_size": 32.0, "lines": ["でも、そんなことあんな．．．"]}, {"box": [444, 685, 498, 864], "vertical": true, "font_size": 24.0, "lines": ["でも、そんなこと", "あんなこと"]}, {"box": [330, 684, 397, 885], "vertical": true, "font_size": 24.0, "lines": ["忘れてしまいそうな", "くらい"]}, {"box": [233, 688, 289, 845], "vertical": true, "font_size": 24.0, "lines": ["目に染みる", "夕日だったんだ"]}, {"box": [230, 684, 290, 855], "vertical": true, "font_size": 32.0, "lines": ["目に染みる夕日だったんだ。"]}, {"box": [243, 916, 291, 1188], "vertical": true, "font_size": 24.0, "lines": ["さ、", "教室戻ろう？"]}], "img_path": "051.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "052.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "053.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [781, 482, 840, 620], "vertical": true, "font_size": 21.0, "lines": ["今日もまた", "あの夢を見た"]}, {"box": [677, 482, 732, 685], "vertical": true, "font_size": 21.0, "lines": ["蝶が子供の俺に", "何か話しかけてくる。"]}, {"box": [572, 480, 628, 684], "vertical": true, "font_size": 21.0, "lines": ["導かれるように", "俺はトンネルに入る"]}, {"box": [427, 478, 489, 680], "vertical": true, "font_size": 26.0, "lines": ["このトンネルは．．．", "確か小学校の裏の："]}, {"box": [322, 480, 349, 657], "vertical": true, "font_size": 24.0, "lines": ["何回繰り返した？"]}, {"box": [209, 478, 295, 642], "vertical": true, "font_size": 26.0, "lines": ["忘れた頃に見る", "この夢。"]}, {"box": [148, 483, 173, 644], "vertical": true, "font_size": 19.0, "lines": ["１０歳の頃からだ。"]}, {"box": [168, 1191, 194, 1252], "vertical": true, "font_size": 26.0, "lines": ["．．．誰？"]}], "img_path": "054.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [735, 275, 784, 377], "vertical": true, "font_size": 32.0, "lines": ["店を曲切"]}, {"box": [519, 90, 625, 278], "vertical": true, "font_size": 26.0, "lines": ["おい。", "そこの二人", "休憩入れ。"]}, {"box": [747, 375, 818, 431], "vertical": false, "font_size": 32.0, "lines": ["１６８．"]}, {"box": [755, 631, 931, 945], "vertical": true, "font_size": 21.0, "lines": ["あの．．．小松崎くん。", "どうです？", "たまには外で", "食べませんか？", "今日は私が", "もちますけど。"]}, {"box": [456, 954, 575, 1140], "vertical": true, "font_size": 21.0, "lines": ["いやぁ、実は", "来月から正社員に", "なることが決まった", "もんで、"]}, {"box": [185, 677, 239, 808], "vertical": true, "font_size": 24.0, "lines": ["．．．不村さん", "珍しいですね。"]}, {"box": [103, 827, 157, 931], "vertical": true, "font_size": 24.0, "lines": ["どうしたん", "ですか？"]}, {"box": [91, 1129, 173, 1292], "vertical": true, "font_size": 21.0, "lines": ["なんか、ちょっと", "気分がいいん", "ですよね、私。"]}], "img_path": "055.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [848, 60, 901, 164], "vertical": true, "font_size": 24.0, "lines": ["．．．僕、弁当", "あるんで．．．"]}, {"box": [503, 241, 535, 523], "vertical": true, "font_size": 24.0, "lines": ["あ．．．", "そうですか．．．"]}, {"box": [494, 695, 575, 770], "vertical": false, "font_size": 32.0, "lines": ["話"]}], "img_path": "056.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [892, 84, 925, 127], "vertical": true, "font_size": 28.0, "lines": ["あ。"]}, {"box": [565, 69, 588, 222], "vertical": true, "font_size": 19.0, "lines": ["おかえりなさい。"]}, {"box": [105, 47, 238, 360], "vertical": true, "font_size": 22.0, "lines": ["ごめんね、", "部屋でまったり", "させてもらってた。", "もう", "帰ります。"]}, {"box": [254, 407, 281, 498], "vertical": true, "font_size": 25.0, "lines": ["．．．ごめん"]}, {"box": [169, 525, 224, 632], "vertical": true, "font_size": 25.0, "lines": ["君", "誰だっけ？"]}, {"box": [855, 729, 880, 793], "vertical": true, "font_size": 25.0, "lines": ["えっ？"]}, {"box": [474, 807, 587, 1176], "vertical": true, "font_size": 22.0, "lines": ["ホラ、ゆうべ", "小学校の", "西武の近くで", "同級生の", "ほったり会って", "荒川だよ。", "飲んだんじゃん。"]}, {"box": [310, 763, 392, 936], "vertical": true, "font_size": 22.0, "lines": ["ホラホラ、", "おかっぱで", "背ぇちっちゃくて。"]}, {"box": [92, 1146, 179, 1291], "vertical": true, "font_size": 22.0, "lines": ["．．．って、きのう", "何度も、説明", "したけど．．．。"]}], "img_path": "057.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [826, 50, 901, 315], "vertical": true, "font_size": 21.0, "lines": ["．．．ごめん俺", "物忘れが", "多くて．．．"]}, {"box": [140, 69, 164, 164], "vertical": true, "font_size": 24.0, "lines": ["．．．ふうん。"]}, {"box": [545, 371, 599, 516], "vertical": true, "font_size": 23.0, "lines": ["じゃ、帰るけど", "一応コレ。"]}, {"box": [800, 658, 885, 801], "vertical": true, "font_size": 24.0, "lines": ["ここのカフェで", "バイトしてる", "からさ。"]}, {"box": [412, 672, 554, 780], "vertical": false, "font_size": 25.0, "lines": ["ｐｒｉｓｈ．ｃａｆｅ"]}, {"box": [192, 679, 246, 801], "vertical": true, "font_size": 21.0, "lines": ["ヒマだったら", "来なよ。"]}, {"box": [107, 791, 157, 912], "vertical": true, "font_size": 21.0, "lines": ["ビールくらい", "出すから。"]}], "img_path": "058.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "059.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [420, 61, 449, 137], "vertical": true, "font_size": 23.0, "lines": ["．．．店長、"]}, {"box": [329, 121, 381, 266], "vertical": true, "font_size": 23.0, "lines": ["もう一度言って", "頂けますか？"]}, {"box": [824, 642, 847, 733], "vertical": true, "font_size": 20.0, "lines": ["だからね。"]}, {"box": [102, 359, 157, 543], "vertical": true, "font_size": 21.0, "lines": ["私にはちょっと訳が", "わからなくて．．．"]}, {"box": [698, 729, 781, 832], "vertical": true, "font_size": 20.0, "lines": ["木村さん", "あなたには", "来月から"]}, {"box": [338, 967, 392, 1077], "vertical": true, "font_size": 22.0, "lines": ["いや、店長、", "あの．．．"]}, {"box": [151, 709, 264, 874], "vertical": true, "font_size": 23.0, "lines": ["ちゃんと社員契約", "して、肉売場の", "加工にまわって", "もらうから。"]}, {"box": [262, 1123, 284, 1245], "vertical": true, "font_size": 22.0, "lines": ["その先です"]}], "img_path": "060.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [837, 53, 919, 245], "vertical": true, "font_size": 19.0, "lines": ["肉を薄切りする", "機械があるんだわ。", "スライサーってやつ。"]}, {"box": [433, 49, 453, 180], "vertical": true, "font_size": 22.0, "lines": ["木村さんさぁ。"]}, {"box": [291, 73, 374, 319], "vertical": true, "font_size": 22.0, "lines": ["元々ウチの親父に", "借金あるからって事で", "ここで働いてる訳でしょ？"]}, {"box": [592, 408, 735, 635], "vertical": true, "font_size": 22.0, "lines": ["もし、事故で指が", "ふっ飛んじゃった場合、", "１本につき２００万入るよう", "保険かけるの。", "社員には。"]}, {"box": [112, 398, 194, 592], "vertical": true, "font_size": 22.0, "lines": ["でもやっぱ", "今のベースじゃ返し", "きれないと思うのよ。"]}, {"box": [850, 706, 903, 868], "vertical": true, "font_size": 23.0, "lines": ["指、何本で足りる", "かな？７本？"]}, {"box": [746, 848, 799, 952], "vertical": true, "font_size": 23.0, "lines": ["利子つけて", "８本かな。"]}, {"box": [142, 685, 239, 976], "vertical": true, "font_size": 22.0, "lines": ["簡単じゃない？", "すごーく", "簡単じゃない？"]}, {"box": [850, 1064, 874, 1188], "vertical": true, "font_size": 23.0, "lines": ["．．．で、でも．．．"]}, {"box": [172, 1118, 224, 1240], "vertical": true, "font_size": 21.0, "lines": ["その後、私", "どうしたら．．．"]}], "img_path": "061.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [783, 101, 896, 425], "vertical": true, "font_size": 21.0, "lines": ["さぁ？", "自分の頭も", "ついでに", "ふっ飛ばしてみる？"]}, {"box": [321, 176, 435, 463], "vertical": true, "font_size": 21.0, "lines": ["お？", "．．．なんだお前、", "休憩時間もう", "過ぎてるだろ？"]}], "img_path": "062.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [894, 88, 915, 218], "vertical": true, "font_size": 19.0, "lines": ["いらっしゃい。"]}, {"box": [123, 251, 178, 364], "vertical": true, "font_size": 22.0, "lines": ["どうぞ？", "中のほうに"]}, {"box": [511, 568, 534, 639], "vertical": true, "font_size": 23.0, "lines": ["あ"]}, {"box": [847, 937, 870, 1071], "vertical": true, "font_size": 23.0, "lines": ["．．．いや、いい。"]}, {"box": [196, 726, 332, 1034], "vertical": true, "font_size": 22.0, "lines": ["びっくり！", "来たんだぁ。", "好きな席", "座りなよ、", "今ガラガラだし。"]}, {"box": [799, 1124, 822, 1259], "vertical": true, "font_size": 23.0, "lines": ["すぐ出るから。"]}, {"box": [177, 1174, 259, 1299], "vertical": true, "font_size": 21.0, "lines": ["え？じゃあ", "あたしに用か", "なんか？"]}], "img_path": "063.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [590, 104, 612, 191], "vertical": true, "font_size": 20.0, "lines": ["．．．え？"]}, {"box": [99, 241, 203, 568], "vertical": true, "font_size": 22.0, "lines": ["虹ヶ原の", "土手に来て", "ほしい．．．。", "．．．明日の朝、"]}, {"box": [429, 659, 545, 954], "vertical": true, "font_size": 21.0, "lines": ["虹ヶ原って．．．", "あたしらの", "小学校の裏に", "あった？"]}, {"box": [770, 1128, 852, 1321], "vertical": true, "font_size": 27.0, "lines": ["へえ。", "同級生？"]}, {"box": [196, 1129, 278, 1322], "vertical": true, "font_size": 20.0, "lines": ["不良っていうか、", "もう男子は誰も", "逆らえないカンジの。"]}, {"box": [87, 1191, 136, 1359], "vertical": true, "font_size": 20.0, "lines": ["いるじゃないスか。", "クラスに一人は。"]}], "img_path": "064.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [891, 127, 943, 229], "vertical": true, "font_size": 22.0, "lines": ["もしかして", "初恋の人？"]}, {"box": [635, 102, 660, 168], "vertical": true, "font_size": 24.0, "lines": ["あれ？"]}, {"box": [556, 139, 582, 284], "vertical": true, "font_size": 24.0, "lines": ["当てちゃった？"]}, {"box": [107, 219, 162, 303], "vertical": true, "font_size": 26.0, "lines": ["いやぁ、", "はは．．．"]}, {"box": [713, 440, 733, 501], "vertical": true, "font_size": 20.0, "lines": ["．．．え？"]}, {"box": [519, 434, 578, 519], "vertical": true, "font_size": 26.0, "lines": ["．．．でも", "なんか．．．"]}, {"box": [467, 586, 490, 669], "vertical": true, "font_size": 26.0, "lines": ["ねえ．．．．．"]}], "img_path": "065.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "066.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [785, 1036, 813, 1123], "vertical": true, "font_size": 22.0, "lines": ["ちょっ．．．"]}, {"box": [744, 1164, 764, 1285], "vertical": true, "font_size": 22.0, "lines": ["ちょっと．．．"]}, {"box": [281, 1151, 304, 1233], "vertical": true, "font_size": 24.0, "lines": ["やめて．．．"]}, {"box": [200, 1200, 224, 1306], "vertical": true, "font_size": 24.0, "lines": ["やめてよ！！"]}], "img_path": "067.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [821, 81, 916, 401], "vertical": true, "font_size": 21.0, "lines": ["．．．変だよ", "小松崎くん．．．", "なんか", "変わったよ．．"]}, {"box": [504, 114, 548, 383], "vertical": true, "font_size": 24.0, "lines": ["何してんの？", "．．．ねぇ、"]}, {"box": [263, 372, 319, 538], "vertical": true, "font_size": 24.0, "lines": ["なんでさっきから", "笑ってんの？"]}, {"box": [755, 752, 777, 883], "vertical": true, "font_size": 22.0, "lines": ["．．．寒そうだよ。"]}, {"box": [639, 862, 692, 989], "vertical": true, "font_size": 22.0, "lines": ["早くあがって", "きなよ。"]}], "img_path": "068.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [846, 66, 872, 131], "vertical": true, "font_size": 23.0, "lines": ["．．．ねぇ"]}, {"box": [799, 168, 822, 293], "vertical": true, "font_size": 23.0, "lines": ["どこ行くの？"]}, {"box": [148, 240, 200, 362], "vertical": true, "font_size": 20.0, "lines": ["そっちには", "何もないよ！？"]}, {"box": [189, 669, 213, 853], "vertical": true, "font_size": 20.0, "lines": ["．．．バカじゃないの？"]}, {"box": [645, 1054, 706, 1239], "vertical": true, "font_size": 20.0, "lines": ["すぐに俺の体を", "暗闇が包み込んだ"]}, {"box": [401, 1053, 563, 1295], "vertical": true, "font_size": 22.0, "lines": ["一瞬、これで", "よかったのだろうかとも", "思ったが、", "暗闇は俺を", "離そうとしなかった"]}, {"box": [329, 1053, 352, 1187], "vertical": true, "font_size": 22.0, "lines": ["：そして俺は"]}, {"box": [291, 1049, 352, 1262], "vertical": true, "font_size": 27.0, "lines": ["蝶の声を聞いたんだ。"]}], "img_path": "069.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "070.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "071.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [832, 67, 852, 191], "vertical": true, "font_size": 19.0, "lines": ["．．．これっ！！"]}, {"box": [138, 151, 198, 258], "vertical": true, "font_size": 27.0, "lines": ["読んで", "ください！！"]}, {"box": [826, 844, 907, 1170], "vertical": true, "font_size": 21.0, "lines": ["受け取っても", "たぶん．．．", "しょうがないと", "思うよ。"]}, {"box": [206, 1215, 225, 1336], "vertical": true, "font_size": 26.0, "lines": ["ちょっ．．．ちょ"]}, {"box": [58, 1243, 154, 1386], "vertical": true, "font_size": 26.0, "lines": ["ちょっと", "待って", "小松崎くん！！"]}], "img_path": "072.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [777, 35, 936, 401], "vertical": true, "font_size": 26.0, "lines": ["まだ", "木村さんの事が", "ずっと入院", "好きなの！？", "したまま", "じゃん！！"]}, {"box": [292, 91, 407, 233], "vertical": true, "font_size": 22.0, "lines": ["．．．もう俺は", "誰も好きに", "なんかならない", "よ。"]}, {"box": [413, 413, 508, 555], "vertical": true, "font_size": 24.0, "lines": ["さっさと", "忘れちゃえば", "いいのに！！"]}, {"box": [114, 453, 199, 594], "vertical": true, "font_size": 21.0, "lines": ["俺は誰一人", "守ってやれない", "んだから"]}, {"box": [844, 691, 863, 791], "vertical": true, "font_size": 15.0, "lines": ["なにそれ．．．"]}, {"box": [210, 863, 283, 1133], "vertical": true, "font_size": 25.0, "lines": ["バカじゃ", "ないの？"]}], "img_path": "073.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [671, 79, 767, 304], "vertical": true, "font_size": 22.0, "lines": ["春だった風も", "なまあたたかい", "嫌な風に変わってきた"]}, {"box": [496, 76, 591, 239], "vertical": true, "font_size": 22.0, "lines": ["僕がこの学校に", "転校してきて", "そろそろ２ヶ月"]}, {"box": [354, 75, 447, 255], "vertical": true, "font_size": 22.0, "lines": ["僕は僕ができると", "思っていた以上に", "小学生していた。"]}, {"box": [213, 73, 308, 297], "vertical": true, "font_size": 25.0, "lines": ["僕は少し", "大人に近づいたのかも", "しれない"]}, {"box": [440, 519, 523, 569], "vertical": false, "font_size": 27.0, "lines": ["だとだと"]}, {"box": [819, 817, 879, 1066], "vertical": true, "font_size": 24.0, "lines": ["マンガの回し読みとか"]}, {"box": [817, 819, 844, 1067], "vertical": true, "font_size": 24.0, "lines": ["５時間目の体育の話とか"]}, {"box": [691, 1073, 785, 1230], "vertical": true, "font_size": 24.0, "lines": ["当たり障りなく", "こなして、", "みんなが笑う時"]}, {"box": [657, 1073, 680, 1169], "vertical": true, "font_size": 23.0, "lines": ["僕も笑う。"]}, {"box": [151, 952, 249, 1153], "vertical": true, "font_size": 26.0, "lines": ["なんだ", "生きるって簡単じゃ", "ないか。"]}], "img_path": "074.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [680, 53, 840, 316], "vertical": true, "font_size": 22.0, "lines": ["先生が僕に言った", "「がんばろう」は", "下手にがんばらないように", "がんばることで", "果たされている"]}, {"box": [536, 64, 630, 243], "vertical": true, "font_size": 27.0, "lines": ["クラスの", "不良とされている", "人たちとか、"]}, {"box": [103, 64, 195, 312], "vertical": true, "font_size": 25.0, "lines": ["毎日放課後", "どこかに連れられてゆく", "いじめられっこだとか"]}, {"box": [556, 409, 615, 614], "vertical": true, "font_size": 24.0, "lines": ["生真面目な", "学級委員の女の子は"]}, {"box": [99, 411, 295, 657], "vertical": true, "font_size": 27.0, "lines": ["先週から", "給食の班にした時", "ひとりだけわずかに", "すき間ができていること", "気付いているだろうか", "とか。"]}, {"box": [682, 771, 876, 1000], "vertical": true, "font_size": 24.0, "lines": ["みんなから影で", "なぜだか「魔法瓶」と", "呼ばれている、", "ずっとノートに何かを", "書いているあの女子の", "将来についてだとか。"]}], "img_path": "075.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [198, 178, 223, 262], "vertical": true, "font_size": 24.0, "lines": ["あはは。"]}, {"box": [513, 438, 536, 560], "vertical": true, "font_size": 23.0, "lines": ["気にしない。"]}, {"box": [509, 437, 535, 558], "vertical": true, "font_size": 23.0, "lines": ["気にしない。"]}, {"box": [441, 438, 464, 551], "vertical": true, "font_size": 23.0, "lines": ["気にしない"]}, {"box": [441, 437, 465, 557], "vertical": true, "font_size": 24.0, "lines": ["気にしない。"]}, {"box": [876, 888, 925, 1039], "vertical": true, "font_size": 18.0, "lines": ["せんせ", "ぎよーなら"]}, {"box": [498, 696, 578, 769], "vertical": false, "font_size": 32.0, "lines": ["話"]}, {"box": [564, 875, 620, 1032], "vertical": true, "font_size": 24.0, "lines": ["はい、", "さようなら"]}, {"box": [347, 894, 462, 1040], "vertical": true, "font_size": 19.0, "lines": ["鈴木くん、今日", "みんなで俺んち", "来るんだけど", "どーする？"]}, {"box": [60, 1008, 146, 1348], "vertical": true, "font_size": 23.0, "lines": ["ごめん、お母さんに", "また今度", "早く帰って来いって", "呼んでよ。", "言われてて、"]}], "img_path": "076.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [670, 40, 693, 255], "vertical": true, "font_size": 19.0, "lines": ["．．．ウソだけど。"]}, {"box": [103, 140, 217, 489], "vertical": true, "font_size": 20.0, "lines": ["俺は後から", "．．．．．．じゃあ", "行くから。", "いつもん所な。", "逃げんなよ。", "．．．逃げねーか。"]}, {"box": [475, 491, 556, 684], "vertical": true, "font_size": 21.0, "lines": ["．．．．．．だってよ", "今日もがんばるかぁ、", "．．．なぁ、高浜ぁ。"]}, {"box": [176, 784, 227, 896], "vertical": true, "font_size": 21.0, "lines": ["気にしない", "気にしない。"]}], "img_path": "077.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [825, 92, 887, 238], "vertical": true, "font_size": 22.0, "lines": ["神センセ", "さようなら"]}, {"box": [642, 252, 694, 425], "vertical": true, "font_size": 20.0, "lines": ["はーい", "気をつけてね"]}, {"box": [109, 62, 133, 153], "vertical": true, "font_size": 23.0, "lines": ["鈴木くん。"]}, {"box": [68, 398, 164, 715], "vertical": true, "font_size": 21.0, "lines": ["途中まで", "先生と一緒に", "今日もひとりで", "帰ろうか？", "帰るの？"]}, {"box": [853, 819, 904, 953], "vertical": true, "font_size": 21.0, "lines": ["．．．ひとりで", "帰れますから。"]}], "img_path": "078.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [895, 404, 914, 485], "vertical": true, "font_size": 19.0, "lines": ["大丈夫？"]}, {"box": [818, 485, 840, 635], "vertical": true, "font_size": 19.0, "lines": ["無理してない？"]}, {"box": [601, 909, 627, 1044], "vertical": true, "font_size": 23.0, "lines": ["あ、日暮さん。"]}, {"box": [127, 1162, 181, 1253], "vertical": true, "font_size": 23.0, "lines": ["ちょうど", "よかった。"]}], "img_path": "079.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [834, 62, 915, 226], "vertical": true, "font_size": 21.0, "lines": ["鈴木くんと", "日暮さん、おウチ", "方向一緒だよね。"]}, {"box": [79, 100, 167, 372], "vertical": true, "font_size": 22.0, "lines": ["恥ずかし", "がってちゃ", "．．．．．．ホラ？", "ダメだよ。"]}, {"box": [446, 565, 507, 696], "vertical": true, "font_size": 24.0, "lines": ["．．．そうじゃ", "ないよ先生。"]}, {"box": [336, 565, 366, 638], "vertical": true, "font_size": 30.0, "lines": ["．．．でも"]}, {"box": [303, 565, 329, 707], "vertical": true, "font_size": 23.0, "lines": ["仕方ないのか。"]}, {"box": [166, 565, 311, 743], "vertical": true, "font_size": 23.0, "lines": ["大人と子供じゃ", "住んでいる世界が", "違うんだから。"]}, {"box": [61, 907, 146, 1030], "vertical": true, "font_size": 24.0, "lines": ["お兄ちゃんの", "スーファミが", "あるよ。"]}, {"box": [781, 1107, 800, 1233], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．鈴木くん"]}, {"box": [687, 1207, 706, 1348], "vertical": true, "font_size": 19.0, "lines": ["あたしんち．．．"]}], "img_path": "080.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [822, 107, 937, 230], "vertical": true, "font_size": 23.0, "lines": ["どうですか", "お父さん、", "有江ちゃんの", "様子は？"]}, {"box": [661, 62, 714, 211], "vertical": true, "font_size": 21.0, "lines": ["はは．．．", "変わりなしです。"]}, {"box": [553, 137, 634, 331], "vertical": true, "font_size": 21.0, "lines": ["ケガも完治してるし、", "意識も戻ってる", "はずなんですけど。"]}, {"box": [277, 94, 357, 285], "vertical": true, "font_size": 21.0, "lines": ["やりきれないですよ。", "話しかけても反応", "ないっていうのは。"]}, {"box": [870, 654, 919, 679], "vertical": false, "font_size": 25.0, "lines": ["診療"]}, {"box": [90, 392, 218, 710], "vertical": true, "font_size": 25.0, "lines": ["私、夜勤なんで", "先に失礼", "します。", "．．．．．それじゃ", "先生、"]}, {"box": [792, 691, 918, 741], "vertical": false, "font_size": 18.0, "lines": ["内科呼吸器科", "理学診療科（リノ"]}, {"box": [373, 893, 486, 941], "vertical": false, "font_size": 32.0, "lines": ["木村有江様"]}], "img_path": "081.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [877, 65, 898, 186], "vertical": true, "font_size": 19.0, "lines": ["小松崎くん？"]}, {"box": [114, 135, 166, 398], "vertical": true, "font_size": 22.0, "lines": ["あ．．．", "ちょっと？"]}], "img_path": "082.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [388, 1017, 411, 1106], "vertical": true, "font_size": 21.0, "lines": ["鈴木くん"]}, {"box": [289, 1120, 370, 1263], "vertical": true, "font_size": 21.0, "lines": ["今日ずっと", "あたしのこと", "見てたでしょ？"]}], "img_path": "083.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [900, 91, 920, 194], "vertical": true, "font_size": 19.0, "lines": ["．．．えっ？"]}, {"box": [475, 102, 591, 404], "vertical": true, "font_size": 23.0, "lines": ["あたし紅茶", "入れてくる。", "鈴木くん", "クッキーも", "何か飲む？", "あるし。"]}, {"box": [874, 530, 897, 621], "vertical": true, "font_size": 23.0, "lines": ["うふふふ。"]}, {"box": [80, 259, 185, 568], "vertical": true, "font_size": 24.0, "lines": ["．．．帰ろう。", "なんで", "来ちゃったん", "だろう．．．"]}], "img_path": "084.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [344, 68, 627, 226], "vertical": false, "font_size": 32.0, "lines": ["一世界が終わり、"]}, {"box": [654, 724, 684, 782], "vertical": true, "font_size": 23.0, "lines": ["おい。"]}, {"box": [565, 763, 615, 913], "vertical": true, "font_size": 23.0, "lines": ["おまえら甘いよ。", "かしてみ。"]}, {"box": [110, 805, 132, 915], "vertical": true, "font_size": 19.0, "lines": ["お．．．おう。"]}], "img_path": "085.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [486, 64, 539, 224], "vertical": true, "font_size": 24.0, "lines": ["痛いか？", "痛いよなそりゃ。"]}, {"box": [263, 28, 377, 212], "vertical": true, "font_size": 21.0, "lines": ["だけど", "世の中にはもっと", "苦しんでる人が", "たくさんいるだろ？"]}, {"box": [758, 519, 911, 830], "vertical": true, "font_size": 22.0, "lines": ["なんか．．．最近", "あぶねぇよ", "もうカネとかじゃ", "小松崎は。", "なくて、とにかく", "人を殴りたい", "だけじゃん。"]}, {"box": [47, 377, 132, 521], "vertical": true, "font_size": 24.0, "lines": ["それに比べりゃ", "お前、まだまだ", "幸せだよ。"]}, {"box": [806, 953, 887, 1104], "vertical": true, "font_size": 19.0, "lines": ["それは．．．だって", "それはしょーが", "ねぇじゃん．．．．．．"]}, {"box": [371, 765, 453, 896], "vertical": true, "font_size": 21.0, "lines": ["やっぱ木村が", "入院してから", "だよなぁ．．．。"]}, {"box": [91, 696, 190, 889], "vertical": true, "font_size": 27.0, "lines": ["それはマジで", "シャレんなんねー", "だろ？"]}, {"box": [661, 1172, 691, 1239], "vertical": true, "font_size": 24.0, "lines": ["あ．．．"]}, {"box": [589, 1224, 608, 1323], "vertical": true, "font_size": 24.0, "lines": ["オイオイ！！"]}, {"box": [76, 1133, 208, 1333], "vertical": true, "font_size": 24.0, "lines": ["なんでだよ！？", "高浜だってもう", "全然抵抗しねぇし、", "もういいじゃん！！"]}], "img_path": "086.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [218, 441, 270, 572], "vertical": true, "font_size": 22.0, "lines": ["じゃあ", "お前でいいよ。"]}, {"box": [877, 717, 932, 841], "vertical": true, "font_size": 24.0, "lines": ["．．．俺．．．", "もうやだよ．．．"]}, {"box": [497, 818, 582, 923], "vertical": true, "font_size": 22.0, "lines": ["そんなに", "木村が好き", "なら．．．"]}, {"box": [79, 844, 174, 1148], "vertical": true, "font_size": 22.0, "lines": ["あっち側に", "いっちゃえば", "お前も．．．", "いいじゃん！！"]}, {"box": [661, 1133, 713, 1277], "vertical": true, "font_size": 21.0, "lines": ["俺、お前のこと", "キライだよ．．．"]}], "img_path": "087.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [416, 605, 442, 707], "vertical": true, "font_size": 24.0, "lines": ["．．．そうだ。"]}, {"box": [278, 606, 337, 675], "vertical": true, "font_size": 32.0, "lines": ["きっと僕らは"]}, {"box": [68, 329, 131, 479], "vertical": true, "font_size": 32.0, "lines": ["林宗止"]}, {"box": [173, 603, 352, 761], "vertical": true, "font_size": 30.0, "lines": ["きっと", "僕らは"]}, {"box": [170, 607, 233, 760], "vertical": true, "font_size": 24.0, "lines": ["おかしな世界に", "住んでいる。"]}, {"box": [698, 774, 719, 886], "vertical": true, "font_size": 19.0, "lines": ["雨がくるよ。"]}, {"box": [224, 832, 250, 946], "vertical": true, "font_size": 20.0, "lines": ["雨がくるよ。"]}, {"box": [551, 1007, 573, 1118], "vertical": true, "font_size": 19.0, "lines": ["雨がくるよ。"]}], "img_path": "088.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [341, 112, 371, 188], "vertical": true, "font_size": 30.0, "lines": ["えいっ。"]}, {"box": [645, 501, 739, 662], "vertical": true, "font_size": 25.0, "lines": ["例えば僕が", "蝶の声を聞いて", "でしまったり、"]}, {"box": [391, 495, 551, 709], "vertical": true, "font_size": 26.0, "lines": ["きっと神様が", "どこからか見ていて", "僕の願いを", "叶えてくれると", "思っていたり、"]}, {"box": [757, 735, 788, 806], "vertical": true, "font_size": 29.0, "lines": ["うっ．．．"]}, {"box": [852, 864, 933, 1047], "vertical": true, "font_size": 19.0, "lines": ["な．．．なぁ．．．．．", "死んだのか？", "死んじゃったのか？"]}, {"box": [593, 818, 665, 924], "vertical": true, "font_size": 26.0, "lines": ["うっ", "うっ．．．"]}, {"box": [595, 985, 619, 1067], "vertical": true, "font_size": 22.0, "lines": ["．．．なぁ．．"]}, {"box": [332, 786, 358, 847], "vertical": true, "font_size": 26.0, "lines": ["方で"]}, {"box": [99, 771, 341, 951], "vertical": true, "font_size": 23.0, "lines": ["当然そんなことは", "なくて、", "きっと１０年後には", "つまらないただの", "大人になっている", "だろうと", "思っていたり。"]}, {"box": [522, 1015, 541, 1176], "vertical": true, "font_size": 22.0, "lines": ["これでいいのか？"]}, {"box": [88, 1222, 141, 1345], "vertical": true, "font_size": 21.0, "lines": ["本当にこれで", "いいのか？"]}], "img_path": "089.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [685, 170, 816, 441], "vertical": true, "font_size": 23.0, "lines": ["僕は一日に、こんなことを", "だいたい１０回くらい考えて、", "だいたい１０回くらい", "考えるのを諦める。"]}, {"box": [92, 211, 224, 431], "vertical": true, "font_size": 23.0, "lines": ["．．．そうさ。", "きっとそのうち", "どうでもよく", "なるんだ"]}], "img_path": "090.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [733, 65, 757, 158], "vertical": true, "font_size": 21.0, "lines": ["鈴木くん。"]}, {"box": [598, 83, 647, 226], "vertical": true, "font_size": 21.0, "lines": ["．．．なんで勝手に", "帰っちゃうの？"]}, {"box": [728, 550, 780, 672], "vertical": true, "font_size": 20.0, "lines": ["．．．鈴木くんの", "ことが．．．"]}, {"box": [374, 306, 400, 417], "vertical": true, "font_size": 23.0, "lines": ["．．．君こそ、"]}, {"box": [118, 409, 170, 551], "vertical": true, "font_size": 22.0, "lines": ["なんで", "追ってくるの？"]}, {"box": [653, 698, 672, 807], "vertical": true, "font_size": 20.0, "lines": ["好きだから。"]}, {"box": [125, 1102, 229, 1318], "vertical": true, "font_size": 32.0, "lines": ["気持ち悪い", "んだよっ！！"]}], "img_path": "091.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [873, 685, 896, 788], "vertical": true, "font_size": 24.0, "lines": ["ひどい．．．"]}, {"box": [781, 791, 835, 894], "vertical": true, "font_size": 24.0, "lines": ["ひどいよ", "鈴木くん．．．"]}, {"box": [353, 741, 449, 882], "vertical": true, "font_size": 22.0, "lines": ["なぜだか僕は", "彼女のことを", "許せなかった。"]}, {"box": [177, 740, 310, 940], "vertical": true, "font_size": 24.0, "lines": ["二度と立ち直れない", "くらいに", "言い潰してしまえば", "よかったと思った。"]}, {"box": [520, 922, 607, 1312], "vertical": true, "font_size": 20.0, "lines": ["．．．言ってやる．．．", "みんなにお前のこと", "言いふらしてやる！！"]}, {"box": [86, 993, 215, 1261], "vertical": true, "font_size": 22.0, "lines": ["．．．この子が", "誰にもこの話を", "することができないことも", "僕は知っている。"]}], "img_path": "092.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [897, 103, 923, 236], "vertical": true, "font_size": 23.0, "lines": ["っ。", "あァー"]}, {"box": [194, 75, 211, 101], "vertical": true, "font_size": 20.0, "lines": ["ア"]}, {"box": [107, 187, 131, 330], "vertical": true, "font_size": 20.0, "lines": ["ーっ！！", "あァー"]}, {"box": [180, 572, 206, 739], "vertical": true, "font_size": 22.0, "lines": ["っ！！", "あァ"]}, {"box": [739, 1146, 800, 1310], "vertical": true, "font_size": 24.0, "lines": ["突然、激しく", "雨が降り出した。"]}, {"box": [632, 1144, 694, 1333], "vertical": true, "font_size": 23.0, "lines": ["体に当たると", "痛いくらいの雨が。"]}, {"box": [423, 1144, 587, 1349], "vertical": true, "font_size": 24.0, "lines": ["僕や彼女や", "みんなの、", "汚いところすべてを", "洗い流してしまえば", "いいと思った。"]}, {"box": [207, 1140, 344, 1341], "vertical": true, "font_size": 26.0, "lines": ["でも、すぐに止んで", "街には嫌な", "むし暑さだけが", "残った。"]}], "img_path": "093.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "094.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "095.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [867, 814, 887, 905], "vertical": true, "font_size": 19.0, "lines": ["荒川さぁ。"]}, {"box": [735, 954, 844, 1098], "vertical": true, "font_size": 19.0, "lines": ["卒業したら", "このまま油彩で", "院に行くつもり", "なんだろ？"]}, {"box": [125, 890, 337, 1151], "vertical": true, "font_size": 22.0, "lines": ["お前が", "おとなしく企業の", "ＯＬになってくれるん", "だったら、", "課題さえ出せば", "可をくれて", "やるよ。"]}], "img_path": "096.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [833, 72, 938, 288], "vertical": true, "font_size": 21.0, "lines": ["お前の絵、", "小手先の技術", "ばっかでぜんぜん", "伝わってこねぇんだよ。"]}, {"box": [750, 239, 806, 364], "vertical": true, "font_size": 21.0, "lines": ["つまんねぇん", "だよ。"]}, {"box": [194, 105, 243, 245], "vertical": true, "font_size": 19.0, "lines": ["お前の感動とか", "情熱とか"]}, {"box": [102, 241, 150, 444], "vertical": true, "font_size": 19.0, "lines": ["そういう気持ちを俺に", "見せてみろ！！"]}, {"box": [741, 569, 766, 723], "vertical": true, "font_size": 20.0, "lines": ["．．．すいません。"]}, {"box": [558, 827, 654, 955], "vertical": true, "font_size": 24.0, "lines": ["荒川あ", "へコまない", "へコまない"]}, {"box": [269, 754, 293, 846], "vertical": true, "font_size": 24.0, "lines": ["んん"]}, {"box": [76, 937, 217, 1360], "vertical": true, "font_size": 21.0, "lines": ["給料もらってる以上", "「感情をキャンパスに", "サラリーマンの", "ぶっけろぉぉっ」って", "戯言じゃんねぇ？", "大学講師が", "芸術家ぶってさぁ。"]}], "img_path": "097.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [814, 40, 926, 206], "vertical": true, "font_size": 21.0, "lines": ["ホラ、さっきから", "廊下で彼氏くん", "待ってるよ。", "慰めてもらえば？"]}, {"box": [562, 60, 705, 237], "vertical": true, "font_size": 21.0, "lines": ["今、アイツの", "性欲まみれの頭で", "「ガンバレ」なんて", "言われたら", "プン殴りそうだ。"]}, {"box": [95, 114, 201, 489], "vertical": true, "font_size": 21.0, "lines": ["うへっ、冷めんの", "年下で金持ちの", "相変わらず", "男子なんて", "はやーーっ。", "しっ", "もったいな"]}, {"box": [404, 446, 466, 614], "vertical": true, "font_size": 26.0, "lines": ["もう帰ったって", "言っといて。"]}, {"box": [166, 519, 189, 671], "vertical": true, "font_size": 19.0, "lines": ["じゃあ、あげる。"]}], "img_path": "098.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [803, 28, 826, 181], "vertical": true, "font_size": 23.0, "lines": ["元気ないねぇ。"]}, {"box": [712, 118, 738, 263], "vertical": true, "font_size": 23.0, "lines": ["どうしたの？"]}, {"box": [501, 20, 602, 285], "vertical": true, "font_size": 27.0, "lines": ["へっ？", "すいません", "元気ですよぉー。"]}, {"box": [75, 14, 222, 321], "vertical": true, "font_size": 22.0, "lines": ["ただちょっと", "学校の課題で", "へコんでて、", "かつ、ちょっと", "今朝、早起き", "だったもんで。"]}, {"box": [502, 408, 616, 551], "vertical": true, "font_size": 21.0, "lines": ["マキちゃん", "疲れてるんなら", "店、早終いに", "しちゃおうか？"]}, {"box": [91, 463, 188, 584], "vertical": true, "font_size": 25.0, "lines": ["どうせもう", "客来ない", "だろうし"]}, {"box": [795, 672, 896, 897], "vertical": true, "font_size": 24.0, "lines": ["うぅ", "スイマセン", "―．．．", "店長ぉ"]}, {"box": [451, 718, 590, 744], "vertical": false, "font_size": 23.0, "lines": ["ｕｔｉｎｇｌｅ"]}, {"box": [154, 918, 178, 1001], "vertical": true, "font_size": 23.0, "lines": ["ははは。"]}, {"box": [872, 1147, 896, 1275], "vertical": true, "font_size": 19.0, "lines": ["こんばんは。"]}], "img_path": "099.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [829, 66, 944, 250], "vertical": true, "font_size": 21.0, "lines": ["いやぁ、", "暑いですねぇ、", "きのうまてあんなに", "寒かったのに。"]}, {"box": [680, 129, 787, 323], "vertical": true, "font_size": 21.0, "lines": ["異常気象なんて", "毎年のことですけど", "今年ばかりは", "普通じゃないですな。"]}, {"box": [556, 66, 580, 209], "vertical": true, "font_size": 23.0, "lines": ["あの．．．何か？"]}, {"box": [71, 47, 151, 282], "vertical": true, "font_size": 26.0, "lines": ["失礼。", "我々、警察の", "者でして。"]}, {"box": [94, 446, 155, 616], "vertical": true, "font_size": 25.0, "lines": ["この男、見覚え", "ありません？"]}, {"box": [835, 717, 916, 881], "vertical": true, "font_size": 21.0, "lines": ["ゆうべ、この店に", "来ているよう", "なんですが、"]}, {"box": [609, 1121, 692, 1305], "vertical": true, "font_size": 21.0, "lines": ["小松崎航太。", "殺人と傷害の容疑で", "現在捜索中です。"]}, {"box": [76, 1118, 171, 1284], "vertical": true, "font_size": 23.0, "lines": ["．．．あ、あの．．．", "偶然街で久々に", "会って．．．"]}], "img_path": "100.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [803, 46, 915, 252], "vertical": true, "font_size": 21.0, "lines": ["小学校の同級生", "なんですけど、", "よかったら店に来ない", "かって誘ったんで．．．"]}, {"box": [68, 200, 165, 329], "vertical": true, "font_size": 24.0, "lines": ["その後の事、", "何か知りま", "せんか？"]}, {"box": [586, 397, 638, 589], "vertical": true, "font_size": 21.0, "lines": ["でもすぐ", "帰っちゃいましたよ。"]}, {"box": [198, 729, 223, 882], "vertical": true, "font_size": 23.0, "lines": ["．．．知りません。"]}, {"box": [889, 1169, 919, 1347], "vertical": true, "font_size": 28.0, "lines": ["．．．そうですか。"]}, {"box": [508, 998, 608, 1192], "vertical": true, "font_size": 27.0, "lines": ["じゃ、とりあえず", "今日のところは", "このへんで．．．"]}, {"box": [79, 1162, 172, 1306], "vertical": true, "font_size": 22.0, "lines": ["また伺うので", "ご協力お願い", "しますよ"]}], "img_path": "101.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [136, 385, 162, 483], "vertical": true, "font_size": 25.0, "lines": ["．．．ん？"]}, {"box": [780, 694, 809, 791], "vertical": true, "font_size": 29.0, "lines": ["あの．．．"]}, {"box": [176, 808, 229, 994], "vertical": true, "font_size": 22.0, "lines": ["店長のウチ", "行っていいですか？"]}], "img_path": "102.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [154, 125, 215, 245], "vertical": true, "font_size": 26.0, "lines": ["マキちゃん", "大丈夫？"]}, {"box": [844, 360, 914, 508], "vertical": true, "font_size": 31.0, "lines": ["．．．すいません", "店長。"]}, {"box": [179, 426, 260, 598], "vertical": true, "font_size": 19.0, "lines": ["ははは、僕こそ", "ちょっと飲ませ", "過ぎちゃったかな。"]}, {"box": [828, 702, 945, 864], "vertical": true, "font_size": 21.0, "lines": ["ごめんね、勝手に", "絵、見させて", "もらったよ。", "上手なんだねぇ。"]}, {"box": [587, 669, 669, 801], "vertical": true, "font_size": 22.0, "lines": ["練習すれば", "誰でも上手に", "描けるんです。"]}, {"box": [343, 886, 424, 1070], "vertical": true, "font_size": 19.0, "lines": ["アタシはそれ以前に", "ココロ的な問題が", "あるらしいスよ？"]}, {"box": [646, 1136, 759, 1301], "vertical": true, "font_size": 21.0, "lines": ["僕、芸術ってよく", "わからないけれど", "マキちゃんの絵", "好きだなぁ。"]}, {"box": [82, 1161, 142, 1303], "vertical": true, "font_size": 24.0, "lines": ["うーん．．．", "僕はねぇ、"]}], "img_path": "103.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [720, 20, 833, 205], "vertical": true, "font_size": 20.0, "lines": ["マキちゃんみたいな", "明るく振舞えるコ", "には裏を感じ", "ちゃうんだよなぁ。"]}, {"box": [334, 187, 421, 393], "vertical": true, "font_size": 21.0, "lines": ["例えば人に言えない", "ようなものを心の奥に", "持っているとか．．"]}, {"box": [56, 263, 139, 406], "vertical": true, "font_size": 22.0, "lines": ["．．．僕でよければ", "聞いてあげる", "けど．．．"]}, {"box": [148, 769, 267, 1031], "vertical": true, "font_size": 23.0, "lines": ["．．．あたし、", "子供の頃、", "友達を殺そうと", "したんです。"]}, {"box": [824, 1099, 903, 1241], "vertical": true, "font_size": 21.0, "lines": ["．．．．．正確には", "クラスのみんな", "で．．．．．"]}, {"box": [713, 1200, 792, 1342], "vertical": true, "font_size": 21.0, "lines": ["その子を井戸に", "突き落とし", "たんです。"]}, {"box": [83, 1182, 167, 1344], "vertical": true, "font_size": 19.0, "lines": ["真っ白い肌で", "髪が長くて", "綺麗な子だった．．．"]}], "img_path": "104.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [653, 69, 866, 499], "vertical": true, "font_size": 23.0, "lines": ["「トンネルの中の怪物が」", "「いつか世界を終わらせるよ」", "．．．って。", "いつごろからか", "その子、凄い剣幕で", "そんなこと言うように", "なって。"]}, {"box": [113, 84, 275, 432], "vertical": true, "font_size": 20.0, "lines": ["今にしてみれば", "子供の空想のお話で", "片付けられるけど、", "あの頃はみんな", "本気で怖がって", "たんですよ。"]}, {"box": [833, 582, 915, 754], "vertical": true, "font_size": 20.0, "lines": ["．．．で、みんな", "こんな風に考え", "ちゃったんですね。"]}, {"box": [627, 883, 687, 1086], "vertical": true, "font_size": 23.0, "lines": ["「世界は救われるん", "じゃないか」って。"]}, {"box": [131, 662, 215, 807], "vertical": true, "font_size": 22.0, "lines": ["もしかしたら", "この子がいなく", "なれば」"]}, {"box": [79, 1125, 160, 1296], "vertical": true, "font_size": 20.0, "lines": ["．．．でも少なくとも", "あたしだけは", "違うこと考えてた。"]}], "img_path": "105.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [853, 69, 934, 274], "vertical": true, "font_size": 20.0, "lines": ["あたしの好きな", "男の子と仲良くしてる", "そのコが妬ましくて、"]}, {"box": [153, 260, 213, 426], "vertical": true, "font_size": 24.0, "lines": ["．．．それは", "昨日の彼かい？"]}, {"box": [635, 404, 689, 576], "vertical": true, "font_size": 22.0, "lines": ["死んでしまえば", "いいと思ってた．．．。"]}, {"box": [724, 721, 807, 935], "vertical": true, "font_size": 20.0, "lines": ["君はまだちゃんと", "人を好きになった事が", "ないのかもしれないね。"]}, {"box": [568, 1051, 595, 1123], "vertical": true, "font_size": 25.0, "lines": ["．．．あ．．．"]}, {"box": [429, 1095, 524, 1265], "vertical": true, "font_size": 25.0, "lines": ["す．．．すいません", "なにしてるん", "でしょうね！？"]}, {"box": [84, 1132, 146, 1299], "vertical": true, "font_size": 24.0, "lines": ["ごめんなさい！！", "私、帰ります！！"]}], "img_path": "106.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [800, 706, 936, 1158], "vertical": true, "font_size": 24.0, "lines": ["．．．あんまり", "やさしくしないで", "．．．店長、", "ください。", "いいですよ、送って", "くれなくても。"]}, {"box": [490, 961, 575, 1124], "vertical": true, "font_size": 21.0, "lines": ["いや．．．一人で", "帰すのはちょっと", "心配．．．"]}, {"box": [620, 1172, 683, 1337], "vertical": true, "font_size": 25.0, "lines": ["甘えちゃうじゃ", "ないですか．．．"]}, {"box": [69, 1176, 213, 1321], "vertical": true, "font_size": 23.0, "lines": ["．．．ていうか", "謝らなきゃ。", "なんか変な事", "言わせちゃった", "かなぁ．．．って。"]}], "img_path": "107.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [820, 77, 936, 300], "vertical": true, "font_size": 24.0, "lines": ["いいんです。", "昔の事ですし、", "今、酔っ払ってますから", "アタシ。"]}, {"box": [528, 73, 643, 307], "vertical": true, "font_size": 22.0, "lines": ["ただ", "あの話、忘れてたんです。", "小松崎くんに会って", "久々に思い出して。"]}, {"box": [72, 65, 253, 486], "vertical": true, "font_size": 20.0, "lines": ["だから、彼の変わり", "ぶりだとか、", "過去を水に流して", "今はそういう", "のうのうと大人に", "時間の流れに", "なってる自分とか、", "ちょっとウンザリ", "なんです。"]}, {"box": [744, 819, 800, 996], "vertical": true, "font_size": 20.0, "lines": ["そんなもんだよ。"]}, {"box": [833, 1157, 858, 1230], "vertical": true, "font_size": 25.0, "lines": ["えっ？"]}, {"box": [79, 1202, 105, 1255], "vertical": true, "font_size": 26.0, "lines": ["ん？"]}], "img_path": "108.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [877, 974, 939, 1116], "vertical": true, "font_size": 26.0, "lines": ["なんですか．．", "コレ．．．．．．"]}, {"box": [444, 1168, 558, 1357], "vertical": true, "font_size": 22.0, "lines": ["．．．なんだろう？", "近頃の異常気象で", "大量発生しちゃった", "とか？"]}, {"box": [281, 979, 401, 1252], "vertical": true, "font_size": 20.0, "lines": ["．．．．．でも．．．", "このチョウチョ、", "ほんやり光って", "ませんか？"]}, {"box": [53, 1215, 107, 1328], "vertical": true, "font_size": 23.0, "lines": ["．．．すごく", "きれい．．．"]}], "img_path": "109.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [833, 911, 925, 1263], "vertical": true, "font_size": 19.0, "lines": ["はは、まさか", "月明かりが", "反射してるだけ", "だろう？"]}, {"box": [60, 1068, 269, 1342], "vertical": true, "font_size": 23.0, "lines": ["．．．わかった。", "じゃあさ", "マキちゃん。", "この光景を", "絵にしてみれば", "いいんじゃない", "かな？"]}], "img_path": "110.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [244, 194, 270, 323], "vertical": true, "font_size": 23.0, "lines": ["無理ですよ。"]}, {"box": [817, 468, 842, 622], "vertical": true, "font_size": 23.0, "lines": ["綺麗過ぎです。"]}], "img_path": "111.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "112.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "113.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [711, 90, 793, 254], "vertical": true, "font_size": 20.0, "lines": ["はい、では", "明日から夏休みに", "なりますが、"]}, {"box": [254, 106, 337, 278], "vertical": true, "font_size": 22.0, "lines": ["今配った", "夏休みのしおりに", "書かれてるように、"]}, {"box": [144, 194, 226, 401], "vertical": true, "font_size": 22.0, "lines": ["登校日とブールの日を", "みんな忘れないように", "してください。"]}, {"box": [575, 565, 706, 788], "vertical": true, "font_size": 24.0, "lines": ["小松崎くんが転んで", "怪我をしてから", "急にクラスの雰囲気が", "よくなった気がした。"]}, {"box": [366, 565, 528, 789], "vertical": true, "font_size": 24.0, "lines": ["僕は外から来た", "人間だから", "みんなの深い事情は", "知らないし", "どうでもいいのだけど"]}, {"box": [258, 566, 317, 763], "vertical": true, "font_size": 24.0, "lines": ["クラスが平和なのは", "いい事だ。"]}, {"box": [810, 810, 891, 993], "vertical": true, "font_size": 19.0, "lines": ["暑いからって怠けて", "宿題を後回しに", "しないようにね。"]}, {"box": [523, 823, 575, 1006], "vertical": true, "font_size": 18.0, "lines": ["それじゃ、みなさん", "さようなら。"]}, {"box": [69, 1157, 154, 1301], "vertical": true, "font_size": 22.0, "lines": ["っ", "鈴木", "帰りゲーセン", "寄ってかねぇ？"]}], "img_path": "114.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [863, 60, 944, 203], "vertical": true, "font_size": 22.0, "lines": ["あ、ゴメン。", "僕、先生に話が", "あってさ。"]}, {"box": [653, 461, 734, 615], "vertical": true, "font_size": 21.0, "lines": ["そうなの？", "じゃあ俺ら", "先に行ってるわ。"]}, {"box": [268, 423, 460, 601], "vertical": true, "font_size": 22.0, "lines": ["こんなクラスに", "割合馴染めて", "しまう自分を", "僕はちょっとだけ", "嫌だと思う。"]}, {"box": [845, 944, 925, 1137], "vertical": true, "font_size": 22.0, "lines": ["僕、胸のココん", "ところがへこんでて、", "肺と心臓が弱いので、"]}, {"box": [241, 688, 295, 812], "vertical": true, "font_size": 23.0, "lines": ["ブールの日は", "休みたい？"]}, {"box": [158, 785, 213, 892], "vertical": true, "font_size": 23.0, "lines": ["どうして", "鈴木くん？"]}, {"box": [429, 1142, 481, 1347], "vertical": true, "font_size": 21.0, "lines": ["激しい運動はあんまり", "ダメなんです。"]}], "img_path": "115.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [647, 86, 667, 161], "vertical": true, "font_size": 19.0, "lines": ["ん．．．"]}, {"box": [530, 88, 608, 292], "vertical": true, "font_size": 19.0, "lines": ["鈴木くんが入らない", "ほうがいいと思うなら、", "仕方ないけれど、"]}, {"box": [77, 217, 161, 403], "vertical": true, "font_size": 21.0, "lines": ["見学でもいいから", "できるだけ学校には", "来てほしいな。"]}, {"box": [501, 985, 565, 1051], "vertical": true, "font_size": 32.0, "lines": ["まあ"]}, {"box": [378, 990, 433, 1050], "vertical": true, "font_size": 32.0, "lines": ["っ"]}, {"box": [179, 759, 209, 834], "vertical": true, "font_size": 30.0, "lines": ["．．．ハイ。"]}, {"box": [853, 1140, 912, 1269], "vertical": true, "font_size": 32.0, "lines": ["．．．"]}, {"box": [370, 1185, 685, 1330], "vertical": false, "font_size": 32.0, "lines": ["着がえたら", "ゴールに集合"]}], "img_path": "116.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [713, 90, 921, 355], "vertical": true, "font_size": 22.0, "lines": ["じゃあ見学の者は", "各々自主的に", "校舎の清掃を", "すること。", "暑いから", "無理はしない", "ように。"]}, {"box": [151, 409, 175, 502], "vertical": true, "font_size": 23.0, "lines": ["はーい"]}, {"box": [836, 827, 917, 1053], "vertical": true, "font_size": 20.0, "lines": ["競泳じゃないんだから", "プールの中を歩いたって", "かまわないんだぞ。"]}, {"box": [225, 670, 284, 744], "vertical": true, "font_size": 30.0, "lines": ["あ", "鈴木。"]}, {"box": [572, 1162, 687, 1365], "vertical": true, "font_size": 21.0, "lines": ["もし体を見られたく", "ないなら、エシャツを", "着たまま入っても", "いいし。"]}, {"box": [120, 1207, 174, 1299], "vertical": true, "font_size": 25.0, "lines": ["あれ？", "おーい。"]}], "img_path": "117.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [755, 94, 779, 169], "vertical": true, "font_size": 21.0, "lines": ["荒川ぁ"]}, {"box": [595, 146, 708, 331], "vertical": true, "font_size": 21.0, "lines": ["夏休みなんだから", "掃除とかだるいこと", "やってないでお前も", "サボれよ。"]}, {"box": [343, 80, 424, 202], "vertical": true, "font_size": 19.0, "lines": ["あたしは", "隼人たちとは", "違うもん"]}, {"box": [549, 614, 575, 680], "vertical": true, "font_size": 26.0, "lines": ["飲む？"]}, {"box": [90, 398, 145, 523], "vertical": true, "font_size": 24.0, "lines": ["へっへ。何よ", "今さら？"]}, {"box": [681, 778, 834, 1022], "vertical": true, "font_size": 20.0, "lines": ["いらない。", "どーせ高浜くん", "からカツアゲした", "おカネでしょ？", "最低だよ。"]}, {"box": [192, 1067, 307, 1233], "vertical": true, "font_size": 22.0, "lines": ["あんたたち、", "小松崎くんを無視", "するのももう", "やめなよ。"]}, {"box": [88, 1166, 171, 1316], "vertical": true, "font_size": 19.0, "lines": ["そんなの女子", "だって余裕で", "やってんじゃん。"]}], "img_path": "118.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [899, 172, 923, 243], "vertical": true, "font_size": 24.0, "lines": ["いてっ。"]}, {"box": [497, 312, 609, 457], "vertical": true, "font_size": 23.0, "lines": ["小松崎くんの", "ケガって本当は", "隼人がやったん", "でしょ？"]}, {"box": [60, 452, 175, 633], "vertical": true, "font_size": 22.0, "lines": ["．．．いいんだよ", "あいつはシカトで。", "頭悪いんだもん", "あいつ。"]}, {"box": [848, 700, 928, 863], "vertical": true, "font_size": 19.0, "lines": ["俺だってクラスの", "雰囲気を悪くする", "つもりはねぇし"]}, {"box": [735, 804, 813, 1010], "vertical": true, "font_size": 19.0, "lines": ["要は誰がトップに", "なって、どうバランス", "とるかってことだろ？"]}, {"box": [76, 779, 287, 1087], "vertical": true, "font_size": 22.0, "lines": ["小松崎は殴るばっかで", "何も考えちゃいねぇん", "だもん", "木村のことで俺たち", "気ぃつかってたけど、", "もうやめた", "ダメだよあいつは。"]}, {"box": [899, 1118, 922, 1265], "vertical": true, "font_size": 24.0, "lines": ["．．．バカみたい。"]}, {"box": [799, 1189, 858, 1318], "vertical": true, "font_size": 24.0, "lines": ["もういいよ", "その話は。"]}, {"box": [153, 1210, 177, 1355], "vertical": true, "font_size": 23.0, "lines": ["早く帰れば？"]}], "img_path": "119.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [862, 765, 919, 1037], "vertical": true, "font_size": 24.0, "lines": ["ホウキ。", "鈴木くん。"]}, {"box": [382, 937, 407, 1057], "vertical": true, "font_size": 25.0, "lines": ["ブース！！"]}, {"box": [61, 1139, 173, 1282], "vertical": true, "font_size": 19.0, "lines": ["ついて来ないで", "ください！！", "しつこいですよ", "羽鳥先生！"]}], "img_path": "120.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [831, 60, 926, 250], "vertical": true, "font_size": 23.0, "lines": ["いやっでも！！", "どうして僕を", "避けるんですか！？"]}, {"box": [107, 180, 202, 370], "vertical": true, "font_size": 24.0, "lines": ["僕は恭子ちゃんを", "本気で真剣に", "好きなのに！？"]}, {"box": [858, 393, 938, 577], "vertical": true, "font_size": 21.0, "lines": ["．．．．．．失遇の", "飲み会の時は私、", "すごく酔ってたし．．．"]}, {"box": [779, 489, 826, 661], "vertical": true, "font_size": 21.0, "lines": ["あなたがとても", "強引だったから．．．"]}, {"box": [158, 483, 209, 614], "vertical": true, "font_size": 19.0, "lines": ["全部忘れて", "ください．．．"]}, {"box": [866, 748, 918, 919], "vertical": true, "font_size": 18.0, "lines": ["それに学校では", "名前で呼ばないで。"]}, {"box": [441, 718, 643, 993], "vertical": true, "font_size": 23.0, "lines": ["私だって真剣に", "考えてみた", "けれど．．．", "やっぱりあなた", "みたいな純粋な人と", "おつき合いは", "できません。"]}, {"box": [87, 896, 107, 942], "vertical": true, "font_size": 21.0, "lines": ["．．．ど、"]}, {"box": [130, 1019, 183, 1152], "vertical": true, "font_size": 32.0, "lines": ["どういう意味ですか榊先生。"]}, {"box": [127, 1020, 183, 1151], "vertical": true, "font_size": 21.0, "lines": ["どういう意味", "ですか榊先生。"]}], "img_path": "121.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [836, 58, 948, 240], "vertical": true, "font_size": 19.0, "lines": ["あなたの子供たちに", "対する真っ直ぐな", "気持ちが私には", "辛いんです。"]}, {"box": [660, 50, 714, 236], "vertical": true, "font_size": 22.0, "lines": ["教育方針の", "違いって事ですか？"]}, {"box": [569, 159, 620, 285], "vertical": true, "font_size": 22.0, "lines": ["そんなの関係", "ないですよ！！"]}, {"box": [57, 30, 210, 313], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．それと", "あなたはやさしいから", "この顔の傷のこと", "何も聞かないで", "くれたけど．．．"]}, {"box": [179, 482, 230, 614], "vertical": true, "font_size": 22.0, "lines": ["言わせて、", "この傷のこと。"]}, {"box": [761, 771, 917, 1218], "vertical": true, "font_size": 20.0, "lines": ["学校裏の虹ヶ原で", "私のクラスの女子が", "男に襲われている所を", "あなたが赴任する", "見つけてしまったの。", "前、去年の", "春の終わりごろ、"]}, {"box": [82, 1060, 196, 1241], "vertical": true, "font_size": 21.0, "lines": ["当然助けようと", "したわ。私の", "受け持ったクラスの", "子だもの。"]}], "img_path": "122.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [714, 88, 925, 413], "vertical": true, "font_size": 22.0, "lines": ["男がブロックで．．．", "きっと私の目を", "潰そうとしたのね。", "逃げた男は今も", "どこかで平然と", "暮らし続けてるん", "だわ．．．"]}, {"box": [181, 139, 264, 301], "vertical": true, "font_size": 21.0, "lines": ["それは恐ろしい", "ことだし、とても", "悔しいけれど．．．"]}, {"box": [282, 479, 306, 591], "vertical": true, "font_size": 23.0, "lines": ["それ以上に、"]}, {"box": [153, 546, 233, 740], "vertical": true, "font_size": 23.0, "lines": ["私を事件に", "巻き込んだその子が", "憎くて仕方がなくて、"]}, {"box": [756, 816, 845, 1030], "vertical": true, "font_size": 19.0, "lines": ["白い肌の華奢な", "彼女の姿を見る度", "吐き気がしたものです。"]}, {"box": [563, 822, 675, 1015], "vertical": true, "font_size": 22.0, "lines": ["その子、しばらく", "してから井戸に", "転落して。", "．．．まだ入院中です。"]}, {"box": [65, 853, 209, 1058], "vertical": true, "font_size": 21.0, "lines": ["事故で片付けられ", "ましたけど、", "いじめの延長で", "突き落とされたのかも", "しれないですね。"]}, {"box": [203, 1116, 287, 1320], "vertical": true, "font_size": 21.0, "lines": ["いじめられているのを", "気付いてて", "放っていたんですか？"]}, {"box": [124, 1292, 150, 1344], "vertical": true, "font_size": 26.0, "lines": ["そう。"]}], "img_path": "123.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [791, 68, 903, 273], "vertical": true, "font_size": 22.0, "lines": ["今だって", "私のクラス、いじめの", "対象の子、いるんで", "しょうけど。"]}, {"box": [567, 106, 590, 191], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．恭．．"]}, {"box": [226, 86, 306, 535], "vertical": true, "font_size": 21.0, "lines": ["背負うなんて", "バカげてる", "．．．だって！！", "じゃない！！"]}, {"box": [73, 184, 185, 367], "vertical": true, "font_size": 21.0, "lines": ["バカな子供の", "いざこざにいちいち", "つき合ってたら", "体がもたないし！！"]}, {"box": [638, 375, 691, 547], "vertical": true, "font_size": 23.0, "lines": ["なんか、もう", "どうでもよくって。"]}, {"box": [312, 409, 338, 556], "vertical": true, "font_size": 24.0, "lines": ["他人の不幸まで"]}, {"box": [788, 1148, 869, 1292], "vertical": true, "font_size": 20.0, "lines": ["恭子ちゃん．．．", "君は真面目", "すぎるよ。"]}, {"box": [195, 1155, 276, 1259], "vertical": true, "font_size": 22.0, "lines": ["僕は教師と", "しての君", "じゃなくて"]}, {"box": [97, 1248, 148, 1359], "vertical": true, "font_size": 22.0, "lines": ["君自身が", "好きなんだ。"]}], "img_path": "124.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [727, 107, 786, 228], "vertical": true, "font_size": 24.0, "lines": ["僕は君を", "愛してる！！"]}, {"box": [326, 973, 351, 1097], "vertical": true, "font_size": 22.0, "lines": ["．．．やめろ。"]}, {"box": [515, 1200, 542, 1296], "vertical": true, "font_size": 24.0, "lines": ["恭子．．．"]}, {"box": [98, 1250, 123, 1359], "vertical": true, "font_size": 23.0, "lines": ["．．．．．あっ。"]}], "img_path": "125.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [821, 62, 934, 276], "vertical": true, "font_size": 26.0, "lines": ["だめ．．．", "誰かに", "見られたら．．．"]}, {"box": [687, 91, 714, 133], "vertical": true, "font_size": 27.0, "lines": ["ハァ"]}, {"box": [520, 23, 549, 121], "vertical": true, "font_size": 29.0, "lines": ["恭子．．．．．"]}, {"box": [537, 228, 564, 270], "vertical": true, "font_size": 27.0, "lines": ["ハァ"]}, {"box": [373, 262, 466, 396], "vertical": true, "font_size": 24.0, "lines": ["榊先生、至急", "プールまで", "来てください。"]}, {"box": [97, 73, 120, 158], "vertical": true, "font_size": 23.0, "lines": ["んっ．．．"]}, {"box": [628, 363, 657, 409], "vertical": true, "font_size": 26.0, "lines": ["ハァ"]}, {"box": [209, 369, 231, 534], "vertical": true, "font_size": 19.0, "lines": ["．．．やめてくれ。"]}, {"box": [821, 1162, 843, 1284], "vertical": true, "font_size": 19.0, "lines": ["．．．目暮さんは"]}, {"box": [705, 1221, 754, 1363], "vertical": true, "font_size": 19.0, "lines": ["僕を裏切ったり", "しないよね？"]}], "img_path": "126.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [534, 1203, 586, 1327], "vertical": true, "font_size": 21.0, "lines": ["ふざけんじゃ", "ないよ！！"]}, {"box": [246, 1218, 411, 1330], "vertical": true, "font_size": 28.0, "lines": ["この日、", "気温は", "今年最高の", "３９度を", "記録した。"]}], "img_path": "127.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [705, 150, 790, 293], "vertical": true, "font_size": 23.0, "lines": ["お？鈴木、", "入る気になった", "のか？"]}, {"box": [221, 306, 307, 431], "vertical": true, "font_size": 22.0, "lines": ["よし、じゃあ", "みんな位置に", "ついて！！"]}, {"box": [868, 786, 919, 928], "vertical": true, "font_size": 18.0, "lines": ["荒川ぁ、俺と", "つき合おうぜ？"]}, {"box": [539, 829, 559, 920], "vertical": true, "font_size": 20.0, "lines": ["うるさい。"]}, {"box": [45, 803, 165, 1078], "vertical": true, "font_size": 20.0, "lines": ["先生。", "もし僕が", "このまま", "溺れて死んだら", "どうしますか？"]}, {"box": [872, 1148, 895, 1266], "vertical": true, "font_size": 20.0, "lines": ["しっ！！", "よ"]}, {"box": [65, 1258, 103, 1317], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}], "img_path": "128.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [870, 90, 930, 242], "vertical": true, "font_size": 23.0, "lines": ["ん", "鈴木く", "がんばって！！"]}, {"box": [377, 56, 508, 211], "vertical": true, "font_size": 22.0, "lines": ["蝉の声と", "あまりの暑さに", "なんだか頭が", "ほうっとして"]}, {"box": [199, 53, 334, 232], "vertical": true, "font_size": 26.0, "lines": ["プールの水面の", "揺れるきらきらに", "吸い込まれそう", "だった。"]}, {"box": [650, 1116, 675, 1154], "vertical": true, "font_size": 25.0, "lines": ["瞬、"]}, {"box": [508, 1097, 603, 1296], "vertical": true, "font_size": 22.0, "lines": ["僕はどこまでも", "泳いでゆけるんじゃ", "ないかと思えた。"]}, {"box": [333, 1098, 465, 1283], "vertical": true, "font_size": 24.0, "lines": ["けど僕は", "バタ足も", "息つぎも", "まだ何も知らない。"]}], "img_path": "129.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "130.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "131.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [672, 62, 699, 251], "vertical": true, "font_size": 27.0, "lines": ["この頃、夢を見る。"]}, {"box": [568, 61, 630, 261], "vertical": true, "font_size": 23.0, "lines": ["私が教師をしていた", "頃の夢だ。"]}, {"box": [427, 62, 520, 192], "vertical": true, "font_size": 23.666666666666668, "lines": ["楽しい記憶や", "辛い記憶を", "思い出すも"]}, {"box": [287, 60, 382, 283], "vertical": true, "font_size": 23.0, "lines": ["子供たちの顔や名前は", "霧がかかったように", "おぼろげだ。"]}, {"box": [854, 823, 885, 970], "vertical": true, "font_size": 28.0, "lines": ["おい、恭子？"]}, {"box": [289, 885, 382, 1127], "vertical": true, "font_size": 22.0, "lines": ["日曜日の朝に", "気持ちよく起きるなんて", "もう何年もない"]}, {"box": [159, 883, 297, 1173], "vertical": true, "font_size": 24.0, "lines": ["けど、晴れた日の朝は好き。", "何かすべてが許されたような", "気分になるから"]}, {"box": [59, 1087, 142, 1320], "vertical": true, "font_size": 20.0, "lines": ["市役所職員、痴漢で逮捕", "今年は冷夏の予想で", "夏野菜に影響．．．"]}], "img_path": "132.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [742, 76, 826, 262], "vertical": true, "font_size": 22.0, "lines": ["スーパーの駐車場で", "店長が刺殺、", "従業員重体。"]}, {"box": [636, 206, 718, 348], "vertical": true, "font_size": 22.0, "lines": ["市内各地で", "蝶の大量発生の", "報告．．．"]}, {"box": [344, 351, 428, 535], "vertical": true, "font_size": 22.0, "lines": ["相変わらず地方欄は", "退屈なニュース", "ばかりだな。"]}, {"box": [872, 816, 923, 947], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．なんだよ", "ジロジロ見て。"]}, {"box": [619, 873, 645, 938], "vertical": true, "font_size": 23.0, "lines": ["別に．．．"]}, {"box": [497, 870, 580, 1075], "vertical": true, "font_size": 23.0, "lines": ["こんな日でも", "いつもと変わらないん", "だなって。"]}, {"box": [94, 1180, 119, 1325], "vertical": true, "font_size": 23.0, "lines": ["．．．そうか？"]}], "img_path": "133.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [810, 73, 923, 244], "vertical": true, "font_size": 20.0, "lines": ["ほら、そうやって", "今日もあなたは", "ごちそうさまも", "言わないんだから。"]}, {"box": [434, 513, 517, 676], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．離婚届", "出したら少し", "散歩でもしない？"]}, {"box": [118, 363, 205, 669], "vertical": true, "font_size": 22.0, "lines": ["あたし、", "最後だし。", "行きたい所が", "あるの。"]}, {"box": [493, 786, 571, 863], "vertical": false, "font_size": 32.0, "lines": ["話"]}, {"box": [97, 1118, 148, 1243], "vertical": true, "font_size": 21.0, "lines": ["ちょっと休憩", "しましょう？"]}], "img_path": "134.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [813, 228, 895, 252], "vertical": false, "font_size": 24.0, "lines": ["．．．"]}, {"box": [520, 65, 602, 219], "vertical": true, "font_size": 22.0, "lines": ["こちらの皿", "お下げして", "よろしいですか。"]}, {"box": [94, 64, 118, 158], "vertical": true, "font_size": 23.0, "lines": ["．．．どうぞ。"]}, {"box": [174, 407, 229, 531], "vertical": true, "font_size": 25.0, "lines": ["お子様", "双子ですか？"]}, {"box": [91, 547, 144, 631], "vertical": true, "font_size": 25.0, "lines": ["かわいい", "ですね。"]}, {"box": [888, 961, 911, 1113], "vertical": true, "font_size": 19.0, "lines": ["こんにちは"]}, {"box": [343, 728, 425, 860], "vertical": true, "font_size": 20.0, "lines": ["どうしたの", "今日は休みで", "よかったのに。"]}, {"box": [479, 1166, 533, 1290], "vertical": true, "font_size": 24.0, "lines": ["．．．あれ、", "マキちゃん？"]}, {"box": [80, 1088, 164, 1232], "vertical": true, "font_size": 24.0, "lines": ["えへへ", "店長に渡したい", "ものがあって。"]}], "img_path": "135.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [844, 75, 896, 239], "vertical": true, "font_size": 20.0, "lines": ["マキちゃんなんか", "眠そうな顔だよ？"]}, {"box": [598, 286, 679, 489], "vertical": true, "font_size": 18.0, "lines": ["そーなんですよ。", "実はあれからあんまり", "．．．", "寝てなくて"]}, {"box": [90, 282, 143, 476], "vertical": true, "font_size": 21.0, "lines": ["．．．．．あっ．．．", "いらっしゃいませ．．．。"]}, {"box": [188, 801, 240, 945], "vertical": true, "font_size": 19.0, "lines": ["そろそろ", "行きましょう？"]}, {"box": [790, 1059, 843, 1229], "vertical": true, "font_size": 20.0, "lines": ["君が行きたい場所、", "ここだったの？"]}, {"box": [295, 1064, 352, 1232], "vertical": true, "font_size": 23.0, "lines": ["そう、", "懐かしいでしょ？"]}, {"box": [173, 1124, 251, 1295], "vertical": true, "font_size": 23.0, "lines": ["私とあなたが", "出会った場所。", "もう１０年以上前ね。"]}], "img_path": "136.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [761, 125, 934, 430], "vertical": true, "font_size": 24.0, "lines": ["おい、勝手に", "入っちゃまずい", "だろ。", "最近の小学校は", "そういうトコ", "厳しくなってるから、"]}, {"box": [90, 363, 144, 495], "vertical": true, "font_size": 22.0, "lines": ["いいじゃない。", "平気よ。"]}], "img_path": "137.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [837, 137, 858, 243], "vertical": true, "font_size": 21.0, "lines": ["え？"]}, {"box": [312, 151, 394, 282], "vertical": true, "font_size": 21.0, "lines": ["ううん．．．", "なんでもない、", "気のせい"]}, {"box": [603, 374, 626, 478], "vertical": true, "font_size": 19.0, "lines": ["なんだよ。"]}, {"box": [61, 457, 173, 602], "vertical": true, "font_size": 22.0, "lines": ["それより", "校舎の中に誰か", "いた気がするん", "だけど。"]}, {"box": [833, 690, 915, 832], "vertical": true, "font_size": 19.0, "lines": ["．．．不審者？", "通報したほうが", "いいのかしら？"]}, {"box": [554, 735, 583, 803], "vertical": true, "font_size": 22.0, "lines": ["さぁ？"]}, {"box": [449, 767, 528, 961], "vertical": true, "font_size": 22.0, "lines": ["いいんじゃないか？", "俺はもうこの学校の", "教師じゃないんだし。"]}, {"box": [842, 975, 893, 1166], "vertical": true, "font_size": 19.0, "lines": ["変わったのね", "あなたもこの１０年で。"]}, {"box": [444, 1151, 497, 1293], "vertical": true, "font_size": 22.0, "lines": ["人が変わるのに", "十分な時間さ。"]}, {"box": [64, 846, 243, 1255], "vertical": true, "font_size": 20.0, "lines": ["そういえばさっきの", "喫茶店の女の子、", "私が昔担任してた", "きっともう憶えて", "子だわ。", "いないのだろうけど。", "月日ってそんなもの", "なのかしらね。"]}], "img_path": "138.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [802, 79, 825, 159], "vertical": true, "font_size": 23.0, "lines": ["みんな．．．"]}, {"box": [203, 220, 258, 342], "vertical": true, "font_size": 21.0, "lines": ["今どうしてる", "のかしら"]}, {"box": [862, 964, 887, 1046], "vertical": true, "font_size": 25.0, "lines": ["．．．ぶふぅ"]}, {"box": [459, 1173, 483, 1256], "vertical": true, "font_size": 23.0, "lines": ["．．．ぶふぅ"]}, {"box": [404, 1265, 427, 1348], "vertical": true, "font_size": 23.0, "lines": ["．．．ぶふぅ"]}], "img_path": "139.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [850, 740, 876, 804], "vertical": true, "font_size": 26.0, "lines": ["ぶふっ"]}, {"box": [766, 948, 792, 1012], "vertical": true, "font_size": 26.0, "lines": ["ぶぅ．．．"]}, {"box": [183, 726, 263, 885], "vertical": true, "font_size": 27.0, "lines": ["ぶふっ", "ぶふっ"]}, {"box": [168, 1035, 198, 1103], "vertical": true, "font_size": 30.0, "lines": ["ぶぅ．．．"]}], "img_path": "140.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [807, 45, 941, 444], "vertical": true, "font_size": 22.0, "lines": ["でもびっくりしたぁ。", "さっきの人、きっと", "あたしの事、", "小学生の時の", "気付いてなかった", "先生ですよ！", "みたいだけど。"]}, {"box": [505, 81, 618, 247], "vertical": true, "font_size": 20.0, "lines": ["いい先生だったと", "思うけどなんか", "印象薄いなぁ．．．", "確かサカキ先生。"]}, {"box": [72, 254, 202, 632], "vertical": true, "font_size": 23.0, "lines": ["まぁ、", "あれ？でも、", "いいですけどね、", "片目を怪我して", "どうでも。", "包帯してたはず", "だけど．．．"]}, {"box": [847, 687, 930, 878], "vertical": true, "font_size": 19.0, "lines": ["ところでマキちゃん、", "本当にこの絵", "もらっていいの？"]}, {"box": [481, 774, 505, 938], "vertical": true, "font_size": 19.0, "lines": ["もちろんです！！"]}, {"box": [703, 1036, 937, 1376], "vertical": true, "font_size": 23.0, "lines": ["店長にもらって", "ほしくて描いたん", "ですから。", "．．．なんていうか", "はじめてですよ、", "はっきり目的があって", "絵を描こうと思った", "なんて。"]}, {"box": [263, 1124, 347, 1337], "vertical": true, "font_size": 22.0, "lines": ["あぁ、もう行かなきゃ。", "明日までの課題が", "残ってるんですよー。"]}], "img_path": "141.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [788, 103, 869, 234], "vertical": true, "font_size": 19.0, "lines": ["．．．マキちゃん", "明日って何か", "予定ある？"]}, {"box": [546, 72, 664, 258], "vertical": true, "font_size": 24.0, "lines": ["へっ？", "．．．いや、授業", "終わったら特に", "ヒマですよ。"]}, {"box": [65, 176, 147, 318], "vertical": true, "font_size": 19.0, "lines": ["じゃあさ、明日", "僕のウチで", "ご飯食べない？"]}, {"box": [191, 456, 217, 483], "vertical": true, "font_size": 26.0, "lines": ["は"]}, {"box": [139, 535, 164, 635], "vertical": true, "font_size": 26.0, "lines": ["はいっ！！"]}, {"box": [844, 666, 904, 837], "vertical": true, "font_size": 25.0, "lines": ["それじゃ、お先", "失礼します！！"]}, {"box": [146, 821, 205, 987], "vertical": true, "font_size": 24.0, "lines": ["明日の夕方", "連絡しますね！！"]}], "img_path": "142.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [877, 572, 929, 735], "vertical": true, "font_size": 22.0, "lines": ["よくよく考えると", "おそろしいわね。"]}, {"box": [761, 710, 844, 897], "vertical": true, "font_size": 22.0, "lines": ["あの頃の子供たちが", "今どうしているのか", "知らないけれど、"]}, {"box": [146, 698, 227, 904], "vertical": true, "font_size": 22.0, "lines": ["何気ない私の行動が", "多少なりあの子たちに", "影響してると思うと。"]}, {"box": [892, 971, 943, 1140], "vertical": true, "font_size": 18.0, "lines": ["忘れられてるなら", "まだ救われるけど、"]}, {"box": [621, 995, 674, 1168], "vertical": true, "font_size": 19.0, "lines": ["きっと何人かには", "恨まれてたわよね"]}, {"box": [195, 1005, 215, 1136], "vertical": true, "font_size": 20.0, "lines": ["変わらないな。"]}, {"box": [90, 1138, 170, 1321], "vertical": true, "font_size": 20.0, "lines": ["君のそういう", "自分の中に溜めこむ", "考え方。"]}], "img_path": "143.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [684, 77, 739, 208], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．久々だわ", "虹ヶ原も。"]}, {"box": [205, 81, 228, 183], "vertical": true, "font_size": 22.0, "lines": ["いいのか？"]}, {"box": [86, 139, 168, 307], "vertical": true, "font_size": 22.0, "lines": ["あまり、", "いい思い出のない", "場所だろ？"]}, {"box": [400, 411, 426, 460], "vertical": true, "font_size": 23.0, "lines": ["．．．あ"]}, {"box": [310, 452, 362, 648], "vertical": true, "font_size": 23.0, "lines": ["ここももう", "なくなっちゃうのね。"]}, {"box": [69, 383, 273, 687], "vertical": true, "font_size": 32.0, "lines": ["キッ", "二児ヶ原公園は市の", "事のため８月上旬、", "を行います。近隣", "ご理解とご協力を"]}, {"box": [200, 762, 254, 868], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．あれ？", "二児ヶ原？"]}, {"box": [824, 1000, 902, 1203], "vertical": true, "font_size": 20.0, "lines": ["．．．この土地には昔から", "待っていう化け物の", "言い伝えがあってな。"]}, {"box": [668, 1124, 780, 1288], "vertical": true, "font_size": 20.0, "lines": ["ここの人間は", "死んだ件を川に", "流す風習があった", "らしいんだ。"]}, {"box": [196, 1038, 280, 1139], "vertical": true, "font_size": 23.0, "lines": ["件って．．．", "人の頭に", "牛の体の？"]}, {"box": [84, 1121, 168, 1273], "vertical": true, "font_size": 21.0, "lines": ["そう、疫病や", "凶作を予言して", "死んでゆく獣だ。"]}], "img_path": "144.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [718, 86, 927, 460], "vertical": true, "font_size": 19.0, "lines": ["件をそこの川に", "流すとこの場所で", "必ず双子の件が", "見つかるらしい", "それで正式には", "二児ヶ原。", "あとあと虹に当て", "換えたんだろ。"]}, {"box": [440, 424, 526, 569], "vertical": true, "font_size": 25.0, "lines": ["あまり気持ちの", "いい話じゃない", "わね。"]}, {"box": [132, 183, 293, 524], "vertical": true, "font_size": 20.0, "lines": ["長年ここで", "教師やってると", "変な知識が", "．．．まぁ、", "身についてな、", "くだらない", "作り話だろ。"]}, {"box": [172, 1110, 284, 1314], "vertical": true, "font_size": 20.0, "lines": ["何度も忘れようと", "したわ。虹ヶ原で", "児童を助けようとして", "男に襲われた事。"]}], "img_path": "145.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [826, 45, 906, 228], "vertical": true, "font_size": 21.0, "lines": ["あなたと結婚しても", "男性への恐怖心が", "消えなくて．．．"]}, {"box": [709, 144, 794, 349], "vertical": true, "font_size": 21.0, "lines": ["顔の傷を整形したって", "本質的なことは何も", "変わらないわ。"]}, {"box": [534, 83, 615, 207], "vertical": true, "font_size": 19.0, "lines": ["困るわよね、", "こんな事を今", "言われても。"]}, {"box": [97, 130, 148, 254], "vertical": true, "font_size": 19.0, "lines": ["掘り返すなよ", "辛い記憶を。"]}, {"box": [131, 456, 152, 567], "vertical": true, "font_size": 19.0, "lines": ["．．．なんかね"]}, {"box": [727, 624, 884, 1012], "vertical": true, "font_size": 20.0, "lines": ["汚れた下水の上に", "人が暮らしてるのと", "どんなに忘れよう。", "同じじゃない？", "隠そうとしても", "奥の奥に存在", "してるの。"]}, {"box": [60, 717, 172, 881], "vertical": true, "font_size": 22.0, "lines": ["だから私は", "いつまでたっても", "心がふらふら", "するのよ。"]}, {"box": [72, 1106, 158, 1270], "vertical": true, "font_size": 22.0, "lines": ["あなたは器用な人", "だから．．．", "なんだか悔しい。"]}], "img_path": "146.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [841, 121, 924, 224], "vertical": true, "font_size": 22.0, "lines": ["．．．君、いつ", "家を出て", "いくんだ？"]}, {"box": [139, 132, 222, 318], "vertical": true, "font_size": 22.0, "lines": ["明日荷物を", "送って、明後日には", "出ていくわ。"]}, {"box": [165, 467, 217, 650], "vertical": true, "font_size": 19.0, "lines": ["あなたと子供たちを", "殺してからね。"]}, {"box": [840, 1097, 862, 1199], "vertical": true, "font_size": 19.0, "lines": ["冗談だろ？"]}, {"box": [113, 1159, 136, 1293], "vertical": true, "font_size": 19.0, "lines": ["．．．そうよね。"]}], "img_path": "147.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [660, 139, 741, 281], "vertical": true, "font_size": 21.0, "lines": ["：君、本当に", "ひとりでやって", "いけるのか？"]}, {"box": [97, 65, 205, 427], "vertical": true, "font_size": 24.0, "lines": ["ごめん、先に", "帰ってくれる", "私、もうしばらく", "かな。", "ここにいるから。"]}, {"box": [825, 806, 909, 991], "vertical": true, "font_size": 24.0, "lines": ["夕方から雨が降る", "らしいから、早めに", "戻れよ。"]}], "img_path": "148.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [780, 86, 886, 376], "vertical": true, "font_size": 23.0, "lines": ["：：：この十何年かの出来事が", "昔の私が見ている夢だったら", "どんなに幸せだろう。"]}, {"box": [720, 87, 746, 361], "vertical": true, "font_size": 23.0, "lines": ["でもきっとそんな事はない。"]}, {"box": [739, 739, 761, 850], "vertical": true, "font_size": 19.0, "lines": ["．．．ごめんね"]}], "img_path": "149.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "150.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "151.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [680, 497, 710, 607], "vertical": true, "font_size": 26.0, "lines": ["い", "おー"]}, {"box": [803, 905, 900, 1082], "vertical": true, "font_size": 24.0, "lines": ["そう、そこの君、", "何をして", "るんだい？"]}, {"box": [470, 911, 498, 1018], "vertical": true, "font_size": 28.0, "lines": ["．．．探し物"]}, {"box": [515, 1166, 540, 1262], "vertical": true, "font_size": 23.0, "lines": ["探し物？"]}, {"box": [140, 1217, 201, 1359], "vertical": true, "font_size": 24.0, "lines": ["じゃあ僕も", "手伝おうか？"]}], "img_path": "152.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [841, 146, 866, 275], "vertical": true, "font_size": 24.0, "lines": ["小野田くん、"]}, {"box": [255, 273, 280, 379], "vertical": true, "font_size": 23.0, "lines": ["加藤くん、"]}, {"box": [774, 318, 805, 385], "vertical": true, "font_size": 31.0, "lines": ["はい。"]}, {"box": [610, 506, 707, 663], "vertical": true, "font_size": 24.0, "lines": ["夏が終わり", "緑に繁っていた", "葉は落ち、"]}, {"box": [541, 508, 565, 600], "vertical": true, "font_size": 24.0, "lines": ["秋が過ぎ"]}, {"box": [401, 505, 494, 660], "vertical": true, "font_size": 22.0, "lines": ["落ちつきを", "取り戻した", "僕とその日々は"]}, {"box": [296, 504, 356, 629], "vertical": true, "font_size": 25.0, "lines": ["淡々と", "過ぎてゆく。"]}, {"box": [182, 372, 210, 480], "vertical": true, "font_size": 23.0, "lines": ["は"]}, {"box": [854, 766, 916, 957], "vertical": true, "font_size": 23.0, "lines": ["小松崎くんは．．．", "今日もお休みね"]}, {"box": [619, 780, 644, 887], "vertical": true, "font_size": 23.0, "lines": ["斉藤くん、"]}, {"box": [545, 881, 576, 945], "vertical": true, "font_size": 31.0, "lines": ["はい。"]}, {"box": [389, 1017, 416, 1125], "vertical": true, "font_size": 25.0, "lines": ["鈴木くん"]}, {"box": [229, 1079, 323, 1259], "vertical": true, "font_size": 23.0, "lines": ["．．．というより", "淡々と過ぎるべく", "生きている。"]}, {"box": [144, 1036, 174, 1123], "vertical": true, "font_size": 30.0, "lines": ["．．．はい。"]}, {"box": [78, 1189, 174, 1344], "vertical": true, "font_size": 24.0, "lines": ["鈴木くん", "返事はもっと", "大きな声でね。"]}], "img_path": "153.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [442, 98, 527, 435], "vertical": true, "font_size": 26.0, "lines": ["榊先生、", "あ", "失礼します。", "若松隼人。"]}, {"box": [738, 356, 868, 555], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．でないと", "ちょっとした油断で", "何かがはじけて", "しまいそうで"]}, {"box": [412, 583, 444, 639], "vertical": true, "font_size": 32.0, "lines": ["え？"]}, {"box": [94, 503, 190, 646], "vertical": true, "font_size": 24.0, "lines": ["給食のあと", "職員室に来る", "ように。"]}, {"box": [397, 781, 580, 851], "vertical": false, "font_size": 32.0, "lines": ["話"]}, {"box": [873, 1005, 932, 1183], "vertical": true, "font_size": 24.0, "lines": ["給食の後片付けは", "終わりましたか？"]}, {"box": [339, 1155, 468, 1320], "vertical": true, "font_size": 22.0, "lines": ["清掃時間です。", "今日もすみずみ", "までしっかり", "掃除しましょう。"]}], "img_path": "154.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [753, 61, 848, 262], "vertical": true, "font_size": 25.0, "lines": ["．．．．．じゃあ", "放課後も教室で", "待機してるように。"]}, {"box": [138, 194, 166, 293], "vertical": true, "font_size": 28.0, "lines": ["．．．隼人？"]}, {"box": [311, 390, 373, 509], "vertical": true, "font_size": 26.0, "lines": ["いやぁ．．．", "あの先生、"]}, {"box": [47, 523, 161, 833], "vertical": true, "font_size": 25.0, "lines": ["手加減なしで", "怒ると", "殴りやがんの", "マジで怖い", "のな。"]}, {"box": [799, 748, 822, 915], "vertical": true, "font_size": 20.0, "lines": ["．．．どうしたの？"]}, {"box": [820, 994, 918, 1220], "vertical": true, "font_size": 22.0, "lines": ["高浜が俺達から", "金とられてる事、", "先生と親にチクッた。"]}, {"box": [360, 1127, 454, 1304], "vertical": true, "font_size": 22.0, "lines": ["放課後に", "俺のかーちゃん", "呼ばれるってさ。"]}, {"box": [80, 1144, 181, 1321], "vertical": true, "font_size": 27.0, "lines": ["．．．．．親は", "関係ねーじゃん、", "なぁ？"]}], "img_path": "155.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [791, 102, 873, 286], "vertical": true, "font_size": 20.0, "lines": ["．．．なんで", "こうなっちゃったん", "だろうなぁ．．"]}, {"box": [97, 207, 209, 391], "vertical": true, "font_size": 20.0, "lines": ["ていうか俺は", "最初はそこまで", "するつもりなかった", "はずなんだ。"]}, {"box": [794, 554, 909, 927], "vertical": true, "font_size": 21.0, "lines": ["はじめは高浜くん", "みんなと仲良く", "．．．あたし", "なりたくてお金", "知ってる．．", "配ってたこと。"]}, {"box": [848, 995, 910, 1151], "vertical": true, "font_size": 23.0, "lines": ["はは．．．．まぁ", "きっかけはな。"]}, {"box": [404, 1154, 499, 1297], "vertical": true, "font_size": 25.0, "lines": ["．．．まぁ俺が", "調子乗りすぎ", "たってとこ？"]}, {"box": [78, 954, 235, 1325], "vertical": true, "font_size": 25.0, "lines": ["でもなんつーか", "いつのまにか", "歯止め", "流れで．．．", "きかなくなって", "さぁ．．．"]}], "img_path": "156.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [664, 84, 884, 452], "vertical": true, "font_size": 25.0, "lines": ["小松崎の奴．．．", "よく高浜呼び出して", "ボコボコにしてた", "けど、", "金は取らなかった", "理由がなんとなく", "わかったよ。"]}, {"box": [232, 245, 345, 573], "vertical": true, "font_size": 22.0, "lines": ["みなさん", "仲良く遊び", "お昼休みの", "ましょう。", "時間です。"]}, {"box": [816, 648, 919, 974], "vertical": true, "font_size": 27.0, "lines": ["鈴木くん", "おーい．．．", "．．．ねぇ", "鈴木くん．．．"]}, {"box": [94, 1023, 240, 1356], "vertical": true, "font_size": 28.0, "lines": ["．．．ねぇ", "高浜くん", "もしかして", "勝ったつもりで", "いる？"]}], "img_path": "157.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [822, 364, 902, 547], "vertical": true, "font_size": 20.0, "lines": ["相手が抵抗", "できないくらい", "大きな力を使って？"]}, {"box": [739, 505, 788, 646], "vertical": true, "font_size": 20.0, "lines": ["そんな解決しか", "できないの？"]}, {"box": [386, 523, 467, 685], "vertical": true, "font_size": 20.0, "lines": ["君はもう", "被害者じゃなくて", "加害者だね。"]}, {"box": [56, 256, 170, 653], "vertical": true, "font_size": 21.0, "lines": ["ねぇ、高浜くん、", "君はこのまま", "僕は思うよ。", "だときっと", "ろくでもない人間に", "なるって。"]}, {"box": [779, 808, 892, 1220], "vertical": true, "font_size": 21.0, "lines": ["なんならここから", "．．．ねぇ高浜くん、", "突き落として", "いつまで黙って", "やろうか？", "るの？"]}, {"box": [109, 1162, 169, 1329], "vertical": true, "font_size": 25.0, "lines": ["ちょっとアンタ", "何してんのッ！？"]}], "img_path": "158.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [874, 114, 931, 232], "vertical": true, "font_size": 21.0, "lines": ["ホラどきな", "さいよッ！！"]}, {"box": [590, 441, 650, 561], "vertical": true, "font_size": 23.0, "lines": ["どうしたの", "鈴木くん！？"]}, {"box": [366, 452, 389, 582], "vertical": true, "font_size": 23.0, "lines": ["ママ．．．"]}, {"box": [877, 627, 941, 795], "vertical": true, "font_size": 24.0, "lines": ["どーゆう事", "なのこれはッ！？"]}, {"box": [750, 714, 841, 904], "vertical": true, "font_size": 24.0, "lines": ["どんな教育", "してらっしゃるの", "この学校は！？"]}, {"box": [503, 930, 562, 1094], "vertical": true, "font_size": 23.0, "lines": ["この子は今年", "転校してきて．．．"]}, {"box": [154, 736, 214, 924], "vertical": true, "font_size": 24.0, "lines": ["ほらっ：鈴木くん", "早く謝って．．．"]}, {"box": [836, 975, 943, 1187], "vertical": true, "font_size": 26.0, "lines": ["．．．鈴木？", "知らない", "子ね．．．"]}, {"box": [395, 1164, 542, 1329], "vertical": true, "font_size": 23.0, "lines": ["親の顔が", "見てみたいわ！", "どうせロクな教育", "されてないんで", "しょうけど！"]}, {"box": [73, 1196, 169, 1318], "vertical": true, "font_size": 25.0, "lines": ["あんたに", "言われたく", "ないよ。"]}], "img_path": "159.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [817, 61, 911, 393], "vertical": true, "font_size": 23.0, "lines": ["こんな不快な", "ちょっ．．．", "気持ち私", "はじめてだわ！！"]}, {"box": [498, 95, 595, 218], "vertical": true, "font_size": 26.0, "lines": ["高浜さん、", "落ちついて", "ください！！"]}, {"box": [74, 128, 229, 565], "vertical": true, "font_size": 24.0, "lines": ["アンタら頭", "ふざけないでよ", "オカシイんじゃ", "こんな所にウチの", "ないのッ！？", "カワイイ子供を", "預けてたなんて！！"]}, {"box": [777, 612, 802, 754], "vertical": true, "font_size": 23.0, "lines": ["馬鹿共がっ！！"]}, {"box": [631, 411, 665, 490], "vertical": true, "font_size": 31.0, "lines": ["・エェ！？"]}, {"box": [453, 836, 478, 979], "vertical": true, "font_size": 24.0, "lines": ["馬鹿共がァ！！"]}, {"box": [791, 1077, 810, 1147], "vertical": true, "font_size": 19.0, "lines": ["．．．バーカ"]}], "img_path": "160.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [343, 1009, 366, 1106], "vertical": true, "font_size": 26.0, "lines": ["．．．なんで"]}, {"box": [221, 1154, 317, 1252], "vertical": true, "font_size": 26.0, "lines": ["お前が", "かばうん", "だよ．．．"]}], "img_path": "161.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [770, 112, 917, 305], "vertical": true, "font_size": 25.0, "lines": ["鈴木くん．．．", "ダメだよ", "こんな事", "しちゃ．．．"]}, {"box": [147, 132, 176, 207], "vertical": true, "font_size": 24.0, "lines": ["卑怯者"]}, {"box": [95, 243, 114, 338], "vertical": true, "font_size": 24.0, "lines": ["怠け者．．．"]}, {"box": [759, 437, 899, 654], "vertical": true, "font_size": 26.0, "lines": ["あ、", "アッタマ", "おかしいんじゃ", "ないのこの子！！"]}, {"box": [150, 461, 174, 558], "vertical": true, "font_size": 22.0, "lines": ["嘘つき．．．"]}, {"box": [200, 586, 220, 680], "vertical": true, "font_size": 22.0, "lines": ["臆病者．．．"]}, {"box": [500, 650, 560, 826], "vertical": true, "font_size": 21.0, "lines": ["ここには", "まともな奴なんか"]}, {"box": [431, 650, 455, 770], "vertical": true, "font_size": 24.0, "lines": ["いやしない"]}, {"box": [755, 945, 856, 1166], "vertical": true, "font_size": 28.0, "lines": ["．．．結局", "見つからなかったね", "探し物。"]}, {"box": [657, 1058, 718, 1202], "vertical": true, "font_size": 28.0, "lines": ["一体どんな", "箱だったの？"]}, {"box": [289, 1013, 347, 1179], "vertical": true, "font_size": 23.0, "lines": ["．．．その小さな", "プリキの箱は"]}, {"box": [169, 1147, 262, 1318], "vertical": true, "font_size": 23.0, "lines": ["どんな願いでも", "かなう魔法が", "入ってるんだ。"]}], "img_path": "162.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [861, 79, 917, 265], "vertical": true, "font_size": 23.0, "lines": ["．．．神様かくれた", "その箱さえあれば"]}, {"box": [720, 157, 815, 322], "vertical": true, "font_size": 23.0, "lines": ["僕はなんだって", "できるはず", "なんだ。"]}, {"box": [541, 508, 635, 674], "vertical": true, "font_size": 22.0, "lines": ["ははは、それは", "おまじないの", "ようなもの？"]}, {"box": [120, 444, 276, 724], "vertical": true, "font_size": 26.0, "lines": ["．．．いや、", "こめんごめん、", "きっと", "大切なもの", "なんだね。"]}, {"box": [800, 730, 929, 885], "vertical": true, "font_size": 24.0, "lines": ["僕も以前に", "この場所で", "大切なものを", "失くしたんだ。"]}, {"box": [416, 774, 623, 1043], "vertical": true, "font_size": 24.0, "lines": ["．．．でもなんか", "そうやって色んな", "物を失って、", "みんな大人に", "なってゆくような", "気がするよ。"]}, {"box": [73, 990, 174, 1313], "vertical": true, "font_size": 24.0, "lines": ["．．．きっと、", "理想さえ", "捨てなければ", "大丈夫さ。"]}], "img_path": "163.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [839, 143, 907, 464], "vertical": true, "font_size": 23.0, "lines": ["．．．そうだ", "君にコレを", "あげるよ。"]}, {"box": [539, 113, 635, 234], "vertical": true, "font_size": 24.0, "lines": ["僕の大切な", "物のひとつ", "なんだ。"]}, {"box": [34, 70, 213, 404], "vertical": true, "font_size": 23.0, "lines": ["物質に縛られる", "なんて愚かな気が", "してきたよ。", "元はそこの", "ドブ川で拾った", "物だけど。"]}, {"box": [97, 404, 207, 694], "vertical": true, "font_size": 23.0, "lines": ["鈴木く", "ん．．．", "やっぱり", "無いよそんな", "箱．．．．．．．"]}, {"box": [777, 840, 806, 874], "vertical": true, "font_size": 26.0, "lines": ["あ"]}, {"box": [717, 923, 740, 1067], "vertical": true, "font_size": 26.0, "lines": ["お兄ちゃん？"]}, {"box": [113, 1076, 297, 1367], "vertical": true, "font_size": 25.0, "lines": ["お前に男友達が", "いるなんてな。", "不思議な子だよ", "あの鈴木くんて", "子は。"]}], "img_path": "164.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [797, 75, 927, 295], "vertical": true, "font_size": 21.0, "lines": ["ところでお前、", "お兄ちゃんの日記帳", "勝手に何度も", "のぞいたろ？"]}, {"box": [545, 78, 570, 174], "vertical": true, "font_size": 24.0, "lines": ["本当か？"]}, {"box": [97, 254, 122, 408], "vertical": true, "font_size": 23.0, "lines": ["．．．ホントだよ。"]}, {"box": [595, 291, 660, 410], "vertical": true, "font_size": 28.0, "lines": ["．．．見てない", "よ．．．"]}, {"box": [890, 769, 913, 886], "vertical": true, "font_size": 19.0, "lines": ["ウソだろ？"]}, {"box": [512, 840, 537, 984], "vertical": true, "font_size": 23.0, "lines": ["．．．ウソです．．．"]}], "img_path": "165.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [623, 372, 682, 534], "vertical": true, "font_size": 24.0, "lines": ["冷たい風に", "吹かれていると"]}, {"box": [549, 370, 579, 444], "vertical": true, "font_size": 30.0, "lines": ["神様も、"]}, {"box": [482, 371, 541, 485], "vertical": true, "font_size": 23.0, "lines": ["魔法の箱も", "喋る蝶も"]}, {"box": [307, 370, 440, 532], "vertical": true, "font_size": 24.0, "lines": ["そんなものは", "はじめから", "なかったんじゃ", "ないかと思えた。"]}, {"box": [552, 1129, 571, 1236], "vertical": true, "font_size": 21.0, "lines": ["だとしたら"]}, {"box": [551, 1127, 572, 1239], "vertical": true, "font_size": 21.0, "lines": ["だとしたら"]}, {"box": [411, 1128, 502, 1281], "vertical": true, "font_size": 21.0, "lines": ["この世界は", "なんてからっぽ", "なんだろう。"]}], "img_path": "166.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [509, 53, 574, 174], "vertical": true, "font_size": 28.0, "lines": ["．．．ちょっと", "君．．．．．？"]}, {"box": [520, 1090, 613, 1221], "vertical": true, "font_size": 25.0, "lines": ["黒い何かが", "溢れだすのを", "感じながら、"]}, {"box": [382, 1084, 479, 1266], "vertical": true, "font_size": 25.0, "lines": ["僕は", "からっぽな世界を", "歩き出した。"]}], "img_path": "167.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "168.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "169.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [582, 90, 678, 334], "vertical": true, "font_size": 24.0, "lines": ["ゆうべから", "降り続いた雨は", "ようやくあがったものの"]}, {"box": [442, 92, 535, 245], "vertical": true, "font_size": 20.333333333333332, "lines": ["低い鉛色の空は", "今にもまた雨を", "降らせそうで"]}, {"box": [300, 88, 397, 265], "vertical": true, "font_size": 24.0, "lines": ["こんな湿度の日は", "あの頃の事を", "思い出す。"]}, {"box": [180, 330, 241, 530], "vertical": true, "font_size": 25.0, "lines": ["．．．いや、正確には", "より、思い出す。"]}, {"box": [791, 725, 923, 909], "vertical": true, "font_size": 22.0, "lines": ["毎日のように", "反芻した記憶", "思い出すのは", "難しい事じゃない"]}, {"box": [79, 795, 208, 929], "vertical": true, "font_size": 24.0, "lines": ["ただ今日は", "いつもよりも", "色濃く蘇って", "くる"]}, {"box": [70, 1056, 152, 1358], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．", "こんにちは！", "荒川です。"]}], "img_path": "170.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [808, 63, 868, 217], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．なんだ", "今日は休みか。"]}, {"box": [89, 43, 237, 424], "vertical": true, "font_size": 26.0, "lines": ["あの荒川って", "バイトの女なぁ、", "なんか", "知ってるような", "気がするんだよ。"]}, {"box": [780, 721, 874, 873], "vertical": true, "font_size": 23.0, "lines": ["どうしたお前", "さっきから上", "ばかり見て。"]}, {"box": [566, 892, 662, 1084], "vertical": true, "font_size": 26.0, "lines": ["．．．いや、なんか", "２階で人が動いた", "気がしたんです。"]}, {"box": [77, 1112, 175, 1258], "vertical": true, "font_size": 26.0, "lines": ["おい、勝手に", "敷地に入る", "なよ。"]}], "img_path": "171.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [676, 65, 735, 168], "vertical": true, "font_size": 24.0, "lines": ["．．．なんだ", "この裏口、"]}, {"box": [583, 140, 642, 282], "vertical": true, "font_size": 24.0, "lines": ["直接２階に", "入れるのか？"]}, {"box": [96, 439, 119, 526], "vertical": true, "font_size": 23.0, "lines": ["．．．う。"]}, {"box": [766, 747, 825, 854], "vertical": true, "font_size": 24.0, "lines": ["なんだよ", "この部屋。"]}, {"box": [500, 975, 580, 1050], "vertical": false, "font_size": 32.0, "lines": ["話"]}, {"box": [98, 1222, 196, 1365], "vertical": true, "font_size": 24.0, "lines": ["店長やっぱ", "料理上手", "なんですね！！"]}], "img_path": "172.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [906, 98, 936, 162], "vertical": true, "font_size": 23.0, "lines": ["はは。"]}, {"box": [764, 170, 874, 337], "vertical": true, "font_size": 23.0, "lines": ["これでも喫茶店", "やってるんだよ？", "そりゃある程度は", "作れるよ。"]}, {"box": [395, 101, 604, 349], "vertical": true, "font_size": 22.0, "lines": ["へへ．．．．．でも", "前から思ってたん", "ですけど、", "２０代でお店", "もってるなんて", "店長すごい", "ですよね。"]}, {"box": [108, 413, 296, 624], "vertical": true, "font_size": 22.0, "lines": ["．．．まぁ、", "親の遺産とか", "いろいろね", "たいした", "金額じゃ", "なかったけど。"]}, {"box": [826, 831, 934, 1139], "vertical": true, "font_size": 23.0, "lines": ["気にしないで、", "たいした事じゃ", "．．．え？", "ないんだからさ。", "ああ！"]}, {"box": [466, 668, 490, 751], "vertical": true, "font_size": 24.0, "lines": ["あ．．．．．．"]}, {"box": [347, 1080, 448, 1371], "vertical": true, "font_size": 21.0, "lines": ["．．．あの、", "店長って", "恋人いないん", "．．．ですよね？"]}, {"box": [93, 970, 188, 1338], "vertical": true, "font_size": 20.0, "lines": ["．．．いないねぇ、", "欲しいとは", "思ってるんだけど。"]}], "img_path": "173.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [708, 289, 728, 399], "vertical": true, "font_size": 19.0, "lines": ["．．．日暮さん。"]}, {"box": [185, 579, 269, 704], "vertical": true, "font_size": 24.0, "lines": ["．．．それ、", "あたしじゃ", "ダメですか？"]}, {"box": [441, 815, 539, 971], "vertical": true, "font_size": 24.0, "lines": ["今にして思えば", "ずいぶんと遅い", "初恋だった。"]}, {"box": [731, 1041, 882, 1224], "vertical": true, "font_size": 26.0, "lines": ["その頃", "僕は中学３年で", "部活をさぼっては", "虹ヶ原で本を読む", "のが常だった。"]}, {"box": [135, 1176, 268, 1362], "vertical": true, "font_size": 24.0, "lines": ["初めてその少女と", "虹ヶ原で", "出会った時、", "彼女は泣いていた。"]}], "img_path": "174.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [769, 73, 900, 296], "vertical": true, "font_size": 24.0, "lines": ["すぐ近くの", "ドブ川で拾ったという", "蝶のペンダントを", "胸にあて泣いていた"]}, {"box": [155, 213, 288, 415], "vertical": true, "font_size": 25.0, "lines": ["なぜ泣いていたのか", "わからないが、", "僕はそれを", "美しいと思った。"]}, {"box": [739, 561, 870, 746], "vertical": true, "font_size": 26.0, "lines": ["その頃の僕は", "醜く、つつましく", "生きようとする", "両親と妹に囲まれ"]}, {"box": [214, 587, 311, 765], "vertical": true, "font_size": 25.0, "lines": ["世の中との距離や", "違和感を", "強く感じていた。"]}, {"box": [536, 1105, 667, 1312], "vertical": true, "font_size": 21.0, "lines": ["けれど彼女の", "白い手足は", "まるで別の世界の", "人間のように思えた。"]}, {"box": [119, 909, 330, 1341], "vertical": true, "font_size": 24.0, "lines": ["彼女は二つあった", "蝶のペンダントの", "片方を僕にくれた", "それから僕たちは", "毎日のように", "虹ヶ原で会った。"]}], "img_path": "175.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [727, 65, 858, 308], "vertical": true, "font_size": 21.0, "lines": ["いつからか僕たちは", "〝この世界とは別の", "どこがの空想の物語。を", "話すようになった。"]}, {"box": [113, 42, 338, 364], "vertical": true, "font_size": 25.0, "lines": ["なぜ、", "そうなったかは", "憶えていないが、", "二人で話し合いながら", "進むその物語は", "徐々に世界観を", "築いていった。"]}, {"box": [133, 469, 300, 671], "vertical": true, "font_size": 24.0, "lines": ["僕が使わなくなった", "日記帳を渡すと", "彼女は夢中で", "その物語を日々", "書き綴った。"]}, {"box": [672, 827, 769, 920], "vertical": true, "font_size": 26.0, "lines": ["それは", "こんな話", "だった。"]}, {"box": [297, 1068, 427, 1226], "vertical": true, "font_size": 23.0, "lines": ["＂ある少女と", "７人の村人と", "トンネルに住む", "怪物の物語。"]}], "img_path": "176.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [777, 42, 910, 198], "vertical": true, "font_size": 25.0, "lines": ["ある日村に", "未来を予言する", "美しい少女が", "やってくる"]}, {"box": [609, 218, 765, 402], "vertical": true, "font_size": 26.0, "lines": ["やがてその少女は", "トンネルの中の", "怪物が厄災を", "もたらすと予言", "した。"]}, {"box": [254, 386, 388, 524], "vertical": true, "font_size": 27.0, "lines": ["少女は", "神様が送った", "使いだった", "のだが、"]}, {"box": [131, 563, 267, 729], "vertical": true, "font_size": 24.0, "lines": ["村人達は少女の", "存在自体を怖れ", "首を切り怪物に", "捧げてしまった。"]}, {"box": [906, 827, 923, 975], "vertical": true, "font_size": 17.0, "lines": ["んっ、ふぁっ、はぁぁぁっ"]}, {"box": [698, 810, 910, 1189], "vertical": true, "font_size": 23.0, "lines": ["すると今度は", "その少女の生まれ", "村人達はまた", "変わりがやって", "同じように", "くるのだが", "怪物に捧げて", "しまう。"]}, {"box": [470, 822, 600, 1001], "vertical": true, "font_size": 22.0, "lines": ["しかしまた", "少女が現われ．．．", "悲劇は不毛に", "くり返される"]}, {"box": [101, 903, 237, 1061], "vertical": true, "font_size": 25.0, "lines": ["少女で腹を", "満たした怪物は", "際限なく大きく", "なってゆく。"]}, {"box": [98, 1189, 193, 1283], "vertical": true, "font_size": 24.0, "lines": ["．．．たしか", "そんな話", "だった"]}], "img_path": "177.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [761, 120, 907, 276], "vertical": true, "font_size": 23.0, "lines": ["彼女はつたない", "語彙で物語を", "描き続けたか", "その後の展開を", "僕は知らない"]}, {"box": [83, 236, 211, 416], "vertical": true, "font_size": 23.0, "lines": ["なぜなら僕は", "その時すでに", "その物語に興味を", "失っていたし、"]}, {"box": [248, 730, 311, 823], "vertical": true, "font_size": 29.0, "lines": ["僕は", "もう．．．"]}], "img_path": "178.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [705, 103, 788, 232], "vertical": true, "font_size": 19.0, "lines": ["すいません、", "．．．．．．なんか", "ダメでしたね。"]}, {"box": [595, 206, 675, 336], "vertical": true, "font_size": 19.0, "lines": ["あたしが下手", "なのかな", "なんて．．．はは。"]}, {"box": [110, 232, 135, 314], "vertical": true, "font_size": 25.0, "lines": ["いや．．．"]}, {"box": [878, 949, 906, 997], "vertical": true, "font_size": 28.0, "lines": ["え？"]}, {"box": [494, 662, 611, 848], "vertical": true, "font_size": 25.0, "lines": ["．．．店長、あたしが", "昨日あげた絵、", "飾ってくれてないん", "ですね。"]}, {"box": [401, 726, 456, 860], "vertical": true, "font_size": 24.0, "lines": ["．．．ああ、", "破って捨てた。"]}, {"box": [362, 985, 531, 1315], "vertical": true, "font_size": 20.0, "lines": ["虹ヶ原は", "あんな陳腐な", "景色じゃないよ。", "君は美しさが", "どういうものか", "わかってないんだろ。"]}, {"box": [99, 1200, 153, 1331], "vertical": true, "font_size": 24.0, "lines": ["君はつくづく", "悲しい奴だな。"]}], "img_path": "179.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [790, 81, 886, 236], "vertical": true, "font_size": 24.0, "lines": ["．．．君にこんな", "長い髪は", "似合わないな。"]}, {"box": [82, 318, 212, 686], "vertical": true, "font_size": 20.0, "lines": ["．．．その横にある", "ホクロも．．．", "君のその", "いらないなぁ．．．", "くどい化粧も", "黒いマンコも"]}, {"box": [831, 755, 880, 1015], "vertical": true, "font_size": 24.0, "lines": ["いやっ！！", "．．．いい．．．！"]}, {"box": [73, 1133, 134, 1277], "vertical": true, "font_size": 24.0, "lines": ["．．．．店長、", "変ですよ．．．"]}], "img_path": "180.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [650, 117, 675, 213], "vertical": true, "font_size": 25.0, "lines": ["どこが？"]}, {"box": [230, 647, 254, 741], "vertical": true, "font_size": 24.0, "lines": ["はぁっ！！"]}, {"box": [889, 901, 909, 993], "vertical": true, "font_size": 19.0, "lines": ["はぁっ！！"]}, {"box": [423, 964, 456, 1017], "vertical": true, "font_size": 28.0, "lines": ["うっ"]}, {"box": [366, 1056, 389, 1151], "vertical": true, "font_size": 28.0, "lines": ["うあっ．．．"]}], "img_path": "181.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [410, 98, 459, 220], "vertical": true, "font_size": 19.0, "lines": ["．．．こんなに", "おびえて．．．"]}, {"box": [636, 415, 717, 569], "vertical": true, "font_size": 21.0, "lines": ["．．．そんなに", "慌てて帰ること", "ないじゃないか。"]}, {"box": [89, 394, 176, 713], "vertical": true, "font_size": 24.0, "lines": ["醜い顔だ．．．", "“彼女”とは", "程遠い．．．"]}, {"box": [431, 1165, 492, 1298], "vertical": true, "font_size": 22.0, "lines": ["．．．あの時の", "彼女の表情は"]}], "img_path": "182.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [810, 807, 904, 951], "vertical": true, "font_size": 22.0, "lines": ["．．．僕は", "たまらなく", "なって逃げた"]}, {"box": [89, 1186, 184, 1357], "vertical": true, "font_size": 24.0, "lines": ["それ以来", "彼女は姿を", "現さなくなった。"]}], "img_path": "183.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [530, 571, 698, 796], "vertical": true, "font_size": 24.0, "lines": ["その後、", "近所の子供たちの間に", "あの日記帳の物語が", "広まっている事を", "偶然知る"]}, {"box": [283, 571, 496, 795], "vertical": true, "font_size": 24.0, "lines": ["彼女はいくら探しても", "もういないのに、", "彼女が作り出した", "物語が脈々と", "生きているのだと", "思うと．．．"]}, {"box": [95, 310, 158, 422], "vertical": true, "font_size": 27.0, "lines": ["激しく後悔", "している"]}, {"box": [293, 1203, 317, 1316], "vertical": true, "font_size": 24.0, "lines": ["．．．．．星空？"]}], "img_path": "184.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [153, 444, 181, 541], "vertical": true, "font_size": 24.0, "lines": ["いや違う。"]}, {"box": [615, 901, 708, 1045], "vertical": true, "font_size": 22.0, "lines": ["そうだこれは", "あの日見た", "ものと同じだ。"]}, {"box": [191, 969, 251, 1103], "vertical": true, "font_size": 24.0, "lines": ["彼女が消えて", "１年近く後、"]}, {"box": [93, 1174, 189, 1296], "vertical": true, "font_size": 25.0, "lines": ["僕は", "彼女の声を", "聞いたんだ"]}], "img_path": "185.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [400, 76, 564, 283], "vertical": true, "font_size": 21.0, "lines": ["「見えるの", "見えるの", "あたしには見えるの", "この世の中の", "全てのできことが」"]}, {"box": [184, 602, 283, 737], "vertical": true, "font_size": 26.0, "lines": ["僕はあの日も", "光る蝶を", "見た。"]}, {"box": [610, 1036, 850, 1324], "vertical": true, "font_size": 24.0, "lines": ["．．．なぜだろう、", "今日は昔の記憶が", "ついさっきの事のように", "蘇ってくる。", "まるで", "過去と今が", "混ざってゆく", "ように。"]}, {"box": [132, 1180, 266, 1358], "vertical": true, "font_size": 25.0, "lines": ["あの日の蝶が", "今、僕の目の前で", "夜空一面を", "埋めつくす。"]}], "img_path": "186.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [620, 71, 744, 183], "vertical": true, "font_size": 25.0, "lines": ["．．．．．さぁ、", "そろそろ", "あの部屋に", "戻ろう。"]}, {"box": [230, 311, 350, 487], "vertical": true, "font_size": 23.0, "lines": ["今日も僕は彼女と", "物語のつづきを", "作らなくちゃ", "ならない。"]}, {"box": [411, 870, 545, 1113], "vertical": true, "font_size": 22.0, "lines": ["おはよう", "ございます。", "．．．今日も", "あのカフェ行って", "みるんですか？"]}, {"box": [103, 1129, 186, 1312], "vertical": true, "font_size": 21.0, "lines": ["いや、どうも今日は", "それどころじゃ", "ないみたいだな。"]}], "img_path": "187.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [840, 101, 865, 166], "vertical": true, "font_size": 25.0, "lines": ["．．．は？"]}, {"box": [590, 89, 726, 275], "vertical": true, "font_size": 19.0, "lines": ["スーパー店長殺しの", "容疑者の小松崎と", "カフェのバイトの女は", "お前の同級生", "なんだってな。"]}, {"box": [198, 81, 252, 213], "vertical": true, "font_size": 24.0, "lines": ["．．．はい、", "そうですけど、"]}, {"box": [102, 172, 155, 256], "vertical": true, "font_size": 24.0, "lines": ["小学生の", "頃の．．．"]}, {"box": [195, 437, 278, 582], "vertical": true, "font_size": 21.0, "lines": ["．．．今朝、その", "小学校で児童が", "男に刺された。"]}, {"box": [791, 766, 930, 1165], "vertical": true, "font_size": 21.0, "lines": ["聞き覚え", "あるだろ？", "職員に", "こいつもお前らの", "取りおさえられた", "同級生だ。", "高浜って男．．．"]}, {"box": [86, 1187, 169, 1349], "vertical": true, "font_size": 20.0, "lines": ["取り調べで", "わけのわからん事", "言ってるらしい。"]}], "img_path": "188.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [777, 107, 830, 241], "vertical": true, "font_size": 19.0, "lines": ["蝶が僕たちを", "さらいに来る。"]}, {"box": [317, 575, 603, 669], "vertical": false, "font_size": 27.0, "lines": ["はなぁばなぁになった", "ひとつになっ"]}, {"box": [169, 388, 254, 532], "vertical": true, "font_size": 22.0, "lines": ["永遠の中に", "連れていこうと", "してるって。"]}], "img_path": "189.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "190.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "191.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [362, 198, 399, 256], "vertical": true, "font_size": 32.0, "lines": ["．．．"]}, {"box": [215, 60, 266, 161], "vertical": true, "font_size": 22.0, "lines": ["この間の", "事だけど．．．"]}, {"box": [292, 255, 322, 293], "vertical": true, "font_size": 30.0, "lines": ["ン"]}, {"box": [743, 407, 828, 550], "vertical": true, "font_size": 21.0, "lines": ["やっぱり", "引っ越すことに", "なりそうなの"]}, {"box": [518, 791, 576, 877], "vertical": true, "font_size": 25.5, "lines": ["．．．", "トン"]}, {"box": [433, 764, 462, 836], "vertical": true, "font_size": 28.0, "lines": ["トン"]}, {"box": [777, 1180, 865, 1322], "vertical": true, "font_size": 21.0, "lines": ["あなただって", "こんなドブ臭い", "田舎嫌でしょ？"]}, {"box": [113, 1221, 194, 1362], "vertical": true, "font_size": 20.0, "lines": ["母さん達", "よく話し合った", "結果なのよ。"]}], "img_path": "192.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [818, 60, 930, 202], "vertical": true, "font_size": 21.0, "lines": ["母さんは", "お父さんに", "愛されてるから", "平気だけど、"]}, {"box": [692, 168, 770, 312], "vertical": true, "font_size": 21.0, "lines": ["あなたは", "ひとりほっちで", "可哀想でしょ？"]}, {"box": [540, 69, 623, 193], "vertical": true, "font_size": 22.0, "lines": ["だから", "もっともつと", "遠い場所で"]}, {"box": [332, 127, 401, 198], "vertical": true, "font_size": 28.0, "lines": ["トン", "．．．"]}, {"box": [254, 252, 344, 379], "vertical": true, "font_size": 25.0, "lines": ["私達", "やり直そうと", "思うの。"]}, {"box": [774, 856, 790, 956], "vertical": true, "font_size": 21.0, "lines": ["．．．．．．"]}, {"box": [463, 654, 546, 745], "vertical": true, "font_size": 22.0, "lines": ["その時は", "あなたは", "死んでね。"]}, {"box": [630, 1041, 713, 1165], "vertical": true, "font_size": 21.0, "lines": ["お父さん", "どこ行ったの", "かしら．．．"]}], "img_path": "193.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [723, 97, 806, 240], "vertical": true, "font_size": 21.0, "lines": ["今日も", "こんな早朝から", "熱心ですね。"]}, {"box": [124, 513, 236, 696], "vertical": true, "font_size": 21.0, "lines": ["あなただって", "毎朝そこから", "じっと見ていたじゃ", "ないですか"]}, {"box": [846, 796, 868, 907], "vertical": true, "font_size": 19.0, "lines": ["．．．鈴木さん、"]}, {"box": [116, 869, 228, 991], "vertical": true, "font_size": 19.0, "lines": ["家庭の都合で", "この街から", "出なきゃなら", "なくなった。"]}, {"box": [635, 1173, 718, 1305], "vertical": true, "font_size": 23.0, "lines": ["やっと", "話しかけて", "くれましたね。"]}, {"box": [135, 1173, 219, 1296], "vertical": true, "font_size": 22.0, "lines": ["．．．息子は", "元気でやって", "ますか？"]}], "img_path": "194.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [722, 184, 777, 307], "vertical": true, "font_size": 32.0, "lines": ["．．．"]}, {"box": [625, 53, 653, 196], "vertical": true, "font_size": 24.0, "lines": ["憶えておけ！！"]}, {"box": [92, 129, 237, 295], "vertical": true, "font_size": 24.0, "lines": ["僕がここから", "離れたって", "あいつはあんたの", "ものじゃないって", "事を！！"]}, {"box": [121, 420, 232, 564], "vertical": true, "font_size": 22.0, "lines": ["あいつは", "いつだって誰の", "ものでもありま", "せんでしたよ。"]}, {"box": [779, 676, 876, 844], "vertical": true, "font_size": 25.0, "lines": ["あいつはいつも", "遠い遠い所を", "見ていて．．．"]}, {"box": [109, 744, 343, 1041], "vertical": true, "font_size": 25.0, "lines": ["あなたに", "私のさみしさ", "なんてわから", "ないんだ", "私はいつだって", "裁かれるのを", "待ってる。"]}, {"box": [814, 1123, 840, 1187], "vertical": true, "font_size": 26.0, "lines": ["．．．ほら"]}, {"box": [150, 1170, 261, 1313], "vertical": true, "font_size": 22.0, "lines": ["きっと今も", "あいつは", "どこからか私を", "見ているんだ。"]}], "img_path": "195.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [783, 73, 852, 304], "vertical": true, "font_size": 32.0, "lines": ["昔者、そしゃう", "荘周夢に胡蝶と為る。"]}, {"box": [140, 176, 210, 344], "vertical": true, "font_size": 26.0, "lines": ["栩栩然として", "胡蝶なり。．．．"]}, {"box": [785, 428, 869, 598], "vertical": true, "font_size": 20.0, "lines": ["夢で蝶になった", "荘子はひらひらと", "舞っているうちに、"]}, {"box": [680, 576, 759, 737], "vertical": true, "font_size": 20.0, "lines": ["いつしか自分が", "自分であることを", "忘れてしまう。"]}, {"box": [103, 467, 298, 776], "vertical": true, "font_size": 21.0, "lines": ["でも目覚めると", "やはり荘子", "なのだけど、", "夢で蝶になったのか", "蝶の夢で自分に", "なったのか", "わからない。"]}, {"box": [794, 857, 906, 1072], "vertical": true, "font_size": 20.0, "lines": ["色々解釈できる", "けれど、みんな", "高校生になったら", "ちゃんと習うと思うわ。"]}, {"box": [232, 1035, 259, 1098], "vertical": true, "font_size": 23.0, "lines": ["かと"]}, {"box": [143, 987, 233, 1154], "vertical": true, "font_size": 32.0, "lines": ["あなた", "無視します"]}], "img_path": "196.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [727, 91, 755, 177], "vertical": true, "font_size": 23.0, "lines": ["榊先生、"]}, {"box": [591, 191, 701, 342], "vertical": true, "font_size": 23.0, "lines": ["校長から", "聞きましたよ。", "今年度で", "退職されるとか。"]}, {"box": [340, 101, 370, 166], "vertical": true, "font_size": 30.0, "lines": ["ええ。"]}, {"box": [90, 416, 202, 589], "vertical": true, "font_size": 22.0, "lines": ["実は私も", "なんですよ。", "親父の仕事を", "手伝う事になって。"]}, {"box": [869, 633, 922, 780], "vertical": true, "font_size": 21.0, "lines": ["．．．どうですか、", "今晩食事でも？"]}, {"box": [419, 735, 474, 840], "vertical": true, "font_size": 24.0, "lines": ["いえ今日は", "用が．．．"]}, {"box": [284, 709, 305, 827], "vertical": true, "font_size": 19.0, "lines": ["．．．．．あら？"]}, {"box": [857, 997, 930, 1328], "vertical": true, "font_size": 20.0, "lines": ["．．．榊先生、", "近頃ますます", "綺麗になられた。"]}], "img_path": "197.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [281, 61, 407, 337], "vertical": true, "font_size": 21.0, "lines": ["．．．．．日誌？", "だめじゃない", "ちゃんと一日の事", "書かなきゃ。", "まだお昼休みよ？"]}, {"box": [796, 586, 850, 698], "vertical": true, "font_size": 24.0, "lines": ["ちゃんと", "書いたって、"]}, {"box": [121, 617, 206, 760], "vertical": true, "font_size": 21.0, "lines": ["先生はちゃんと", "読まないじゃ", "ないか。"]}, {"box": [501, 894, 576, 963], "vertical": false, "font_size": 32.0, "lines": ["話"]}], "img_path": "198.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [656, 654, 716, 813], "vertical": true, "font_size": 24.0, "lines": ["僕がこの学校に", "転校してきた時"]}, {"box": [695, 945, 714, 1071], "vertical": true, "font_size": 21.0, "lines": ["．．．ねぇみんな、"]}, {"box": [478, 654, 576, 766], "vertical": true, "font_size": 27.0, "lines": ["僕の中に", "淡い期待が", "あった。"]}, {"box": [304, 654, 399, 855], "vertical": true, "font_size": 25.0, "lines": ["次こそは", "うまくやれるんじゃ", "ないかって。"]}, {"box": [590, 1015, 641, 1120], "vertical": true, "font_size": 21.0, "lines": ["やめようよ", "こんな事"]}, {"box": [477, 1187, 498, 1320], "vertical": true, "font_size": 19.0, "lines": ["でもやっぱり"]}, {"box": [308, 1186, 450, 1352], "vertical": true, "font_size": 24.0, "lines": ["ここでも", "同じような事が", "繰り返されてて。"]}, {"box": [192, 1185, 289, 1343], "vertical": true, "font_size": 23.0, "lines": ["どうにかそれを", "やりすごそうと", "決めたんだ。"]}], "img_path": "199.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [795, 217, 858, 352], "vertical": true, "font_size": 23.0, "lines": ["でも僕は少し", "不器用だから"]}, {"box": [693, 218, 751, 373], "vertical": true, "font_size": 20.0, "lines": ["許せないものは", "許せないから"]}, {"box": [183, 80, 207, 150], "vertical": true, "font_size": 21.0, "lines": ["みんな、"]}, {"box": [103, 196, 154, 300], "vertical": true, "font_size": 21.0, "lines": ["やめようよ", "こんな事"]}, {"box": [415, 475, 445, 530], "vertical": true, "font_size": 30.0, "lines": ["ほら、"]}, {"box": [344, 474, 375, 531], "vertical": true, "font_size": 31.0, "lines": ["また、"]}, {"box": [280, 476, 301, 573], "vertical": true, "font_size": 19.0, "lines": ["同じ景色"]}, {"box": [487, 1155, 546, 1348], "vertical": true, "font_size": 22.0, "lines": ["「かーってうれしい", "はないちもんめ」"]}, {"box": [379, 1172, 438, 1348], "vertical": true, "font_size": 22.0, "lines": ["まけーてくやしい", "はないちもんめ」"]}], "img_path": "200.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [503, 886, 526, 1058], "vertical": true, "font_size": 19.0, "lines": ["「おまえはいらん"]}], "img_path": "201.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "202.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [710, 1092, 804, 1256], "vertical": true, "font_size": 22.0, "lines": ["でも僕は", "こうして", "まだ生きている"]}], "img_path": "203.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [802, 150, 862, 349], "vertical": true, "font_size": 19.0, "lines": ["神様のきまぐれだが", "運が良かったのか"]}, {"box": [697, 148, 871, 349], "vertical": true, "font_size": 24.0, "lines": ["なぜか僕は"]}, {"box": [697, 150, 754, 271], "vertical": true, "font_size": 23.0, "lines": ["生かされた。"]}, {"box": [664, 687, 722, 961], "vertical": true, "font_size": 19.0, "lines": ["これ以上僕に", "どうしろっていうんだろう。"]}], "img_path": "204.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [832, 32, 855, 153], "vertical": true, "font_size": 23.0, "lines": ["．．．ごめん！！"]}, {"box": [749, 168, 800, 273], "vertical": true, "font_size": 23.0, "lines": ["．．．ごめんね", "鈴木くん。"]}, {"box": [164, 184, 220, 310], "vertical": true, "font_size": 27.0, "lines": ["．．．だからもう", "やめて。"]}, {"box": [360, 551, 379, 653], "vertical": true, "font_size": 21.0, "lines": ["あたしは．．．"]}, {"box": [239, 602, 312, 713], "vertical": true, "font_size": 21.0, "lines": ["鈴木くんを", "裏切ったり", "しないから。"]}, {"box": [796, 797, 822, 929], "vertical": true, "font_size": 23.0, "lines": ["．．．日暮さん、"]}, {"box": [695, 874, 718, 1000], "vertical": true, "font_size": 23.0, "lines": ["．．．どうして？"]}], "img_path": "205.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [481, 55, 540, 184], "vertical": true, "font_size": 22.0, "lines": ["鈴木くんが", "好きだから"]}, {"box": [755, 788, 869, 1072], "vertical": true, "font_size": 21.0, "lines": ["．．．日暮さん、", "僕は", "何もない場所へ", "行きたい。"]}, {"box": [474, 832, 527, 924], "vertical": true, "font_size": 23.0, "lines": ["．．．ないよ。", "そんな所。"]}, {"box": [121, 840, 196, 982], "vertical": true, "font_size": 21.0, "lines": ["でも僕はここに", "もういたく", "ないんだ"]}, {"box": [463, 1092, 590, 1382], "vertical": true, "font_size": 20.0, "lines": ["ここじゃない", "どこか遠い", "ところに、", "僕といっしょに", "行かないか？"]}, {"box": [114, 1237, 138, 1327], "vertical": true, "font_size": 24.0, "lines": ["．．．いいよ。"]}], "img_path": "206.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [749, 142, 776, 249], "vertical": true, "font_size": 24.0, "lines": ["今日の夜、"]}, {"box": [262, 250, 351, 359], "vertical": true, "font_size": 28.0, "lines": ["虹ヶ原の", "土手で", "待ってる。"]}, {"box": [862, 874, 882, 963], "vertical": true, "font_size": 19.0, "lines": ["おかえり"]}, {"box": [107, 1020, 242, 1330], "vertical": true, "font_size": 21.0, "lines": ["この間の", "話だけど．．．", "やっぱり", "引っ越すことに", "なりそうなの。"]}], "img_path": "207.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [650, 20, 732, 165], "vertical": true, "font_size": 20.0, "lines": ["だから今年の", "４月からはまた", "別の学校に．．．"]}, {"box": [388, 30, 470, 192], "vertical": true, "font_size": 20.0, "lines": ["．．．ごめんね", "いつも母さん達の", "都合ばかりで．．．"]}, {"box": [824, 426, 874, 546], "vertical": true, "font_size": 19.0, "lines": ["．．．返事くらい", "しなさいよ。"]}], "img_path": "208.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [826, 549, 846, 661], "vertical": true, "font_size": 20.0, "lines": ["．．．火事だね。"]}, {"box": [170, 624, 228, 699], "vertical": true, "font_size": 28.0, "lines": ["綺麗な", "もんだ。"]}, {"box": [625, 825, 761, 1078], "vertical": true, "font_size": 24.0, "lines": ["やぁ。", "こんな時間に", "もしかして", "誰かを待ってる", "のかい？"]}, {"box": [508, 840, 565, 948], "vertical": true, "font_size": 24.0, "lines": ["ちなみに", "あの火事、"]}, {"box": [448, 915, 471, 1023], "vertical": true, "font_size": 24.0, "lines": ["僕の家だ。"]}, {"box": [98, 1174, 187, 1318], "vertical": true, "font_size": 24.0, "lines": ["これでやっと", "僕の人生が", "始まる。"]}], "img_path": "209.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [494, 95, 548, 199], "vertical": true, "font_size": 24.0, "lines": ["．．．あんたが", "やったの？"]}, {"box": [354, 39, 375, 161], "vertical": true, "font_size": 19.0, "lines": ["．．．．．あはっ．．．"]}, {"box": [118, 136, 140, 277], "vertical": true, "font_size": 20.0, "lines": ["あはははっ！！"]}, {"box": [776, 756, 837, 900], "vertical": true, "font_size": 27.0, "lines": ["．．．強い意志を", "持ちな。"]}, {"box": [144, 892, 201, 1034], "vertical": true, "font_size": 24.0, "lines": ["もっともつと", "強い意志を。"]}], "img_path": "210.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [542, 938, 618, 1049], "vertical": true, "font_size": 20.0, "lines": ["．．．それでも", "君はまだ", "生きるんだ。"]}], "img_path": "211.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "212.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "213.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [840, 90, 863, 214], "vertical": true, "font_size": 19.0, "lines": ["．．．驚いたろ？"]}, {"box": [241, 69, 291, 189], "vertical": true, "font_size": 20.0, "lines": ["悪ガキだった", "若松隼人も"]}, {"box": [151, 217, 203, 338], "vertical": true, "font_size": 20.0, "lines": ["今じゃ市井の", "警察官だ。"]}, {"box": [747, 486, 829, 658], "vertical": true, "font_size": 19.0, "lines": ["まったく月日が", "経つのなんて", "あっという間だな。"]}, {"box": [542, 780, 656, 982], "vertical": true, "font_size": 21.0, "lines": ["スーパーの", "店長殺しと", "ゆうべのカフェ店長の", "傷害事件．．．"]}, {"box": [392, 879, 501, 1004], "vertical": true, "font_size": 21.0, "lines": ["二人の事件で", "お前はじきに", "参考人として", "呼ばれるよ。"]}, {"box": [75, 1000, 187, 1345], "vertical": true, "font_size": 22.0, "lines": ["お前がとんな", "．．．荒川、", "事件に巻き込ま", "れてるか知らない", "けどさ、"]}], "img_path": "214.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [187, 105, 247, 296], "vertical": true, "font_size": 24.0, "lines": ["お前は俺が", "守ってやるから！！"]}, {"box": [871, 833, 892, 928], "vertical": true, "font_size": 19.0, "lines": ["．．．えっ！？"]}, {"box": [128, 976, 255, 1307], "vertical": true, "font_size": 28.0, "lines": ["．．．おっ", "おいっ！！", "待てよ", "勝手に．．．"]}], "img_path": "215.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [813, 71, 903, 176], "vertical": true, "font_size": 26.0, "lines": ["．．．今", "この部屋に", "人が．．．"]}, {"box": [677, 69, 701, 153], "vertical": true, "font_size": 24.0, "lines": ["おい．．．"]}, {"box": [550, 95, 634, 221], "vertical": true, "font_size": 24.0, "lines": ["誰も", "入っていかな", "かったぜ？"]}, {"box": [308, 334, 363, 456], "vertical": true, "font_size": 22.0, "lines": ["大体お前", "この病室．．．"]}, {"box": [271, 539, 434, 601], "vertical": false, "font_size": 32.0, "lines": ["木村有江樹"]}, {"box": [810, 759, 863, 850], "vertical": true, "font_size": 22.0, "lines": ["．．．そう、", "木村だよ"]}, {"box": [98, 908, 216, 1307], "vertical": true, "font_size": 20.0, "lines": ["こいつまだ", "存在すら", "眠ったまま", "忘れられても", "なんだぜ？", "あの日からずっと", "ここにいるんだ。"]}], "img_path": "216.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [796, 90, 911, 234], "vertical": true, "font_size": 23.0, "lines": ["こいつは", "この１０年、一体", "どんな夢を", "見てたのかな．．"]}, {"box": [183, 495, 265, 669], "vertical": true, "font_size": 19.0, "lines": ["俺はこの１０年", "ずっと心の底で", "ひっかかってたぜ。"]}, {"box": [885, 781, 904, 879], "vertical": true, "font_size": 19.0, "lines": ["なんで．．．"]}, {"box": [754, 852, 833, 975], "vertical": true, "font_size": 19.0, "lines": ["あんな事", "しちまったん", "だろうなぁ。"]}, {"box": [567, 850, 587, 933], "vertical": true, "font_size": 20.0, "lines": ["．．．ん？"]}, {"box": [153, 1225, 181, 1310], "vertical": true, "font_size": 28.0, "lines": ["．．．花？"]}], "img_path": "217.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [583, 83, 681, 260], "vertical": true, "font_size": 26.0, "lines": ["先日の雨のせいで", "水かさが増して", "歩き辛い。"]}, {"box": [517, 81, 539, 196], "vertical": true, "font_size": 19.0, "lines": ["俺は今日も"]}, {"box": [334, 78, 468, 287], "vertical": true, "font_size": 21.0, "lines": ["光る蝶に", "導かれるようにして"]}, {"box": [304, 79, 375, 258], "vertical": true, "font_size": 22.0, "lines": ["トンネルの中を", "さまよっている"]}, {"box": [632, 1148, 763, 1324], "vertical": true, "font_size": 22.0, "lines": ["ふと、その光が", "蝶ではなく", "何かの目のような", "気がして、"]}, {"box": [415, 1146, 440, 1259], "vertical": true, "font_size": 23.0, "lines": ["小学生の頃"]}, {"box": [381, 1143, 442, 1345], "vertical": true, "font_size": 23.0, "lines": ["あの子が言っていた"]}, {"box": [243, 1144, 334, 1299], "vertical": true, "font_size": 23.0, "lines": ["トンネルの中の", "怪物の話を", "思い出した。"]}, {"box": [241, 1142, 334, 1299], "vertical": true, "font_size": 32.0, "lines": ["トンネルの中の怪物の話を思い出した。"]}], "img_path": "218.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [546, 627, 606, 758], "vertical": true, "font_size": 32.0, "lines": ["この一つ目の怪物は、"]}, {"box": [542, 625, 604, 758], "vertical": true, "font_size": 24.0, "lines": ["この一つ目の", "怪物は、"]}, {"box": [405, 628, 497, 758], "vertical": true, "font_size": 24.0, "lines": ["俺に何かを", "伝えたい", "のだろうか？"]}], "img_path": "219.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [493, 939, 579, 1019], "vertical": false, "font_size": 32.0, "lines": ["話"]}], "img_path": "220.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [103, 110, 200, 310], "vertical": true, "font_size": 24.0, "lines": ["あのカフェの店長、", "この２、３時間が", "山場らしい。"]}, {"box": [848, 602, 933, 748], "vertical": true, "font_size": 21.0, "lines": ["．．．ま、どのみち", "命をとりとめた", "ところで、"]}, {"box": [226, 627, 276, 748], "vertical": true, "font_size": 22.0, "lines": ["家族もいない", "ようだし．．．"]}, {"box": [717, 669, 831, 834], "vertical": true, "font_size": 21.0, "lines": ["目も耳も、", "五感のほとんどが", "使いもんにならん", "だろうけどな。"]}, {"box": [154, 718, 177, 852], "vertical": true, "font_size": 22.0, "lines": ["不幸な男だよ。"]}, {"box": [635, 1168, 733, 1323], "vertical": true, "font_size": 29.0, "lines": ["．．．．．案外", "幸せかも", "しれませんよ。"]}, {"box": [128, 956, 240, 1290], "vertical": true, "font_size": 21.0, "lines": ["なんせもう", "おまたせして", "１０年以上も", "すみません、", "前のもの", "ですから．．．"]}], "img_path": "221.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [758, 40, 888, 226], "vertical": true, "font_size": 22.0, "lines": ["小松崎さんは", "１１歳の時の", "転落事故から", "長い間通院していた", "ようです。"]}, {"box": [132, 39, 310, 372], "vertical": true, "font_size": 20.0, "lines": ["怪我自体は", "軽い打撲で済んで", "いますか．．．", "．．．その、精神的に", "激しい自己の喪失が", "見られたようです。"]}, {"box": [746, 495, 877, 719], "vertical": true, "font_size": 22.0, "lines": ["例えば自分が", "誰だかわからなく", "なったり、いつの間にか", "遠い場所に行って", "しまったり．．．"]}, {"box": [166, 768, 327, 1068], "vertical": true, "font_size": 23.0, "lines": ["．．．時には、", "妄想をまるで", "現実のことの", "ように話し", "だしたり。"]}], "img_path": "222.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [738, 97, 833, 286], "vertical": true, "font_size": 24.0, "lines": ["．．．この場所に", "隠れていても", "すぐに捕まるよ．．．"]}, {"box": [721, 487, 806, 652], "vertical": true, "font_size": 23.0, "lines": ["それを", "わざわざ言いに", "戻ってきたのか？"]}, {"box": [833, 837, 891, 980], "vertical": true, "font_size": 24.0, "lines": ["．．．きのうは", "ありがとう．．"]}, {"box": [575, 922, 604, 1019], "vertical": true, "font_size": 29.0, "lines": ["でも．．．"]}, {"box": [140, 904, 243, 1283], "vertical": true, "font_size": 23.0, "lines": ["もうじきこれを", "．．．やっと", "持つべき人が", "探し物が", "やってくる。", "見つかったんだ。"]}], "img_path": "223.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [497, 84, 523, 231], "vertical": true, "font_size": 23.0, "lines": ["なにそれ．．．！？"]}, {"box": [813, 528, 873, 657], "vertical": true, "font_size": 24.0, "lines": ["君がコレを", "渡すんだよ。"]}, {"box": [106, 258, 168, 449], "vertical": true, "font_size": 24.0, "lines": ["約束の日は", "もうすぐだから．．．"]}, {"box": [731, 756, 805, 1140], "vertical": true, "font_size": 23.0, "lines": ["離ればなれに", "．．．運命によって", "なった蝶が"]}, {"box": [154, 1124, 184, 1312], "vertical": true, "font_size": 27.0, "lines": ["ひとつになって"]}], "img_path": "224.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [751, 97, 822, 262], "vertical": true, "font_size": 29.0, "lines": ["幸せで平穏な", "時間の流れに"]}, {"box": [262, 205, 289, 325], "vertical": true, "font_size": 25.0, "lines": ["人は還る。"]}, {"box": [300, 538, 352, 691], "vertical": true, "font_size": 22.0, "lines": ["彼の両親とは", "昔からの友人で、"]}, {"box": [153, 618, 263, 743], "vertical": true, "font_size": 22.0, "lines": ["．．．まぁ、", "家族ぐるみの", "付き合い", "でしたから。"]}, {"box": [811, 853, 923, 1022], "vertical": true, "font_size": 20.0, "lines": ["中学生の時ですか", "両親とも悲しい", "亡くなり方を", "しましたからね。"]}, {"box": [550, 864, 631, 1016], "vertical": true, "font_size": 19.0, "lines": ["私としてはもう", "息子みたいな", "気持ちでしたよ。"]}, {"box": [94, 901, 202, 1314], "vertical": true, "font_size": 22.0, "lines": ["これもきっと", "あの子のやさしさ", "小松崎くんは", "なんです．．．", "やさしい子です。"]}], "img_path": "225.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [732, 47, 832, 192], "vertical": true, "font_size": 26.0, "lines": ["．．．木村さんも", "かわいそうな", "人だな。"]}, {"box": [157, 143, 268, 349], "vertical": true, "font_size": 20.0, "lines": ["娘さんも", "もう１０年以上も", "植物人間状態でここに", "入院してんだろ？"]}, {"box": [781, 461, 895, 625], "vertical": true, "font_size": 20.0, "lines": ["反応の無い娘の", "看病を続けてきた", "人生なんて想像が", "つかないな。"]}, {"box": [835, 833, 921, 950], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．おい", "相槌くらい", "うてよ。"]}, {"box": [600, 1142, 681, 1282], "vertical": true, "font_size": 21.0, "lines": ["こちらが", "木村有江さんの", "病室です。"]}], "img_path": "226.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [303, 640, 328, 722], "vertical": true, "font_size": 23.0, "lines": ["お．．．おい"]}, {"box": [185, 714, 240, 838], "vertical": true, "font_size": 23.0, "lines": ["立ってんじゃ", "ねぇかよ．．．"]}, {"box": [124, 910, 156, 1124], "vertical": true, "font_size": 29.0, "lines": ["娘さんが．．．．！！"]}, {"box": [825, 970, 899, 1296], "vertical": true, "font_size": 27.0, "lines": ["親父さんに", "伝えてやれ！！", "早くっ"]}, {"box": [434, 1170, 458, 1289], "vertical": true, "font_size": 23.0, "lines": ["木村さん！！"]}], "img_path": "227.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [855, 696, 887, 758], "vertical": true, "font_size": 30.0, "lines": ["ど．．．"]}, {"box": [757, 769, 784, 907], "vertical": true, "font_size": 30.0, "lines": ["どうして！？"]}, {"box": [142, 836, 172, 909], "vertical": true, "font_size": 30.0, "lines": ["あ．．．"]}], "img_path": "228.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "229.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [472, 956, 535, 983], "vertical": false, "font_size": 21.0, "lines": ["お"]}, {"box": [791, 1083, 881, 1153], "vertical": false, "font_size": 25.0, "lines": ["．．．"]}], "img_path": "230.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [602, 72, 708, 297], "vertical": true, "font_size": 24.0, "lines": ["一瞬、これで", "よかったのだろうかと", "思ったが、"]}, {"box": [500, 70, 566, 303], "vertical": true, "font_size": 22.0, "lines": ["暗闇は何も", "答えてはくれなかった。"]}, {"box": [363, 72, 461, 274], "vertical": true, "font_size": 23.0, "lines": ["起きてしまった事は", "起きてしまった事。"]}, {"box": [333, 72, 355, 193], "vertical": true, "font_size": 19.0, "lines": ["それだけだ"]}, {"box": [769, 810, 828, 944], "vertical": true, "font_size": 24.0, "lines": ["俺が足を一歩", "踏み進める度"]}, {"box": [664, 806, 727, 941], "vertical": true, "font_size": 24.0, "lines": ["決定は", "積み重なって"]}, {"box": [559, 808, 615, 924], "vertical": true, "font_size": 24.0, "lines": ["また新たな", "決定を生む。"]}, {"box": [205, 995, 335, 1173], "vertical": true, "font_size": 24.0, "lines": ["役目を終えた俺は", "いつもよりも", "深く、深く。", "トンネルを進む"]}], "img_path": "231.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [770, 329, 826, 487], "vertical": true, "font_size": 24.0, "lines": ["子供の頃から", "気になっていた。"]}, {"box": [768, 325, 828, 494], "vertical": true, "font_size": 32.0, "lines": ["子供の頃から気になっていた。"]}, {"box": [662, 326, 721, 504], "vertical": true, "font_size": 24.0, "lines": ["この迷路のような", "トンネルの先は"]}, {"box": [522, 327, 614, 503], "vertical": true, "font_size": 32.0, "lines": ["一体どこにつながっているのだろう、と。"]}, {"box": [516, 323, 615, 504], "vertical": true, "font_size": 24.0, "lines": ["一体どこに", "つながっているの", "だろう、と。"]}], "img_path": "232.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [176, 1180, 201, 1278], "vertical": true, "font_size": 24.0, "lines": ["．．．誰？"]}], "img_path": "233.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [872, 17, 891, 62], "vertical": true, "font_size": 22.0, "lines": ["．．．ん"]}, {"box": [796, 168, 820, 285], "vertical": true, "font_size": 22.0, "lines": ["誰って．．．"]}, {"box": [502, 64, 586, 189], "vertical": true, "font_size": 21.0, "lines": ["今日から君の", "彼女になった", "荒川です！"]}, {"box": [65, 300, 149, 429], "vertical": true, "font_size": 20.0, "lines": ["もしかして君、", "お酒で記憶", "失くすヒト？"]}, {"box": [564, 643, 656, 969], "vertical": true, "font_size": 27.0, "lines": ["全部憶えてるよ。", "つい今さっきの", "．．．いや、", "事のように。"]}, {"box": [400, 1067, 415, 1148], "vertical": true, "font_size": 20.0, "lines": ["．．．じゃあ"]}, {"box": [221, 1120, 351, 1266], "vertical": true, "font_size": 20.0, "lines": ["明日、", "木村さんを", "お見舞いしよう", "って話も", "憶えてるよね？"]}], "img_path": "234.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [828, 6, 849, 148], "vertical": true, "font_size": 19.0, "lines": ["．．．どうしたの？"]}, {"box": [512, 71, 643, 252], "vertical": true, "font_size": 21.0, "lines": ["．．．いや、どうせ", "明日休むなら", "今日の仕事", "サボっちゃおうかな", "．．．って。"]}, {"box": [121, 142, 256, 489], "vertical": true, "font_size": 24.0, "lines": ["じゃあ今日は", "二人どこか", "遊びに行く？", "あはは。", "いいじゃん！？"]}, {"box": [777, 993, 840, 1114], "vertical": true, "font_size": 27.0, "lines": ["花を買いに", "行こう。"]}, {"box": [184, 1028, 278, 1153], "vertical": true, "font_size": 27.0, "lines": ["有江は", "花が大好き", "なんだ。"]}], "img_path": "235.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "236.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "237.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [813, 68, 864, 219], "vertical": true, "font_size": 18.0, "lines": ["．．．見ましたか", "あの子の体の傷、"]}, {"box": [635, 200, 719, 382], "vertical": true, "font_size": 19.0, "lines": ["事故の傷跡？", "どうもそれだけじゃ", "ない気が．．．"]}, {"box": [378, 73, 460, 295], "vertical": true, "font_size": 21.0, "lines": ["母親が今", "手が離せないから", "迎えには来れないと．．．"]}, {"box": [260, 181, 308, 324], "vertical": true, "font_size": 18.0, "lines": ["なんて", "無責任な親だ！！"]}, {"box": [606, 445, 658, 569], "vertical": true, "font_size": 20.0, "lines": ["．．．ところで", "家に連絡は？"]}, {"box": [124, 500, 205, 624], "vertical": true, "font_size": 19.0, "lines": ["どうも複雑な", "事情の家庭", "らしくて．．．"]}, {"box": [774, 807, 867, 1000], "vertical": true, "font_size": 25.0, "lines": ["その事を", "あの子は知って", "るんでしょうか？"]}, {"box": [157, 1064, 181, 1172], "vertical": true, "font_size": 24.0, "lines": ["さぁ．．．"]}], "img_path": "238.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [557, 86, 620, 265], "vertical": true, "font_size": 27.0, "lines": ["あぁ、", "ちょっと待って。"]}, {"box": [824, 546, 918, 561], "vertical": false, "font_size": 15.0, "lines": ["理学診療科（"]}, {"box": [140, 366, 205, 499], "vertical": true, "font_size": 30.0, "lines": ["これ、", "忘れ物だよ。"]}, {"box": [759, 657, 891, 823], "vertical": true, "font_size": 24.0, "lines": ["君がここに", "運び込まれた時", "大事そうに", "抱えてたんだ。"]}, {"box": [153, 780, 210, 949], "vertical": true, "font_size": 21.0, "lines": ["よっぽど大切な", "ものなんだろ？"]}], "img_path": "239.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "240.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [866, 767, 891, 874], "vertical": true, "font_size": 23.0, "lines": ["まだだよ。"]}, {"box": [501, 838, 560, 1004], "vertical": true, "font_size": 22.0, "lines": ["目を覚ますのは", "まだ先の話"]}, {"box": [116, 1194, 175, 1346], "vertical": true, "font_size": 24.0, "lines": ["その時まで", "しばらくの間、"]}], "img_path": "241.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [225, 109, 247, 240], "vertical": true, "font_size": 20.0, "lines": ["さようなら。"]}], "img_path": "242.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [787, 562, 870, 726], "vertical": true, "font_size": 21.0, "lines": ["私ね、今日付けで", "教師辞めるん", "ですよ。"]}, {"box": [132, 614, 245, 776], "vertical": true, "font_size": 19.0, "lines": ["父親のスーパーの", "店舗をひとつ", "任されることに", "なっちゃって。"]}, {"box": [580, 859, 662, 1009], "vertical": true, "font_size": 21.0, "lines": ["木村さん、", "あんたも随分", "苦労してるんだ。"]}, {"box": [430, 908, 538, 1056], "vertical": true, "font_size": 21.0, "lines": ["今の仕事だって", "体の事考えたら", "長くは続けられ", "ないでしょう？"]}, {"box": [198, 959, 364, 1109], "vertical": false, "font_size": 21.8, "lines": ["修了証書", "大村有江殿", "たは本年度をもっ", "次の課程を修了した", "こに証します。"]}, {"box": [135, 1155, 217, 1301], "vertical": true, "font_size": 20.0, "lines": ["どうです？", "ウチの店で", "働きませんか？"]}], "img_path": "243.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [619, 57, 676, 97], "vertical": true, "font_size": 23.0, "lines": ["ま", "まー"]}, {"box": [513, 91, 591, 252], "vertical": true, "font_size": 23.0, "lines": ["これからは", "お互い助け合って", "いきましょうよ。"]}, {"box": [101, 189, 155, 316], "vertical": true, "font_size": 24.0, "lines": ["．．．ありがとう", "ございます。"]}, {"box": [144, 444, 170, 548], "vertical": true, "font_size": 24.0, "lines": ["鈴木くん"]}, {"box": [653, 691, 713, 862], "vertical": true, "font_size": 24.0, "lines": ["さぁ、教室に", "入りましょう？"]}, {"box": [822, 1129, 846, 1157], "vertical": true, "font_size": 23.0, "lines": ["え"]}, {"box": [687, 1191, 772, 1337], "vertical": true, "font_size": 23.0, "lines": ["今日の終業式を", "もって今学年は", "終わりです。"]}, {"box": [170, 1224, 252, 1345], "vertical": true, "font_size": 21.0, "lines": ["みんなも", "来学期からは", "６年生です。"]}], "img_path": "244.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [766, 73, 879, 236], "vertical": true, "font_size": 19.0, "lines": ["先生は事情により", "今年度て先生を", "辞めることに", "なりました。"]}, {"box": [147, 174, 229, 379], "vertical": true, "font_size": 21.0, "lines": ["４年、５年と、", "このクラスのみんなと", "過ごした２年間は．．．"]}, {"box": [835, 860, 895, 991], "vertical": true, "font_size": 25.0, "lines": ["とてもいい", "思い出です。"]}, {"box": [482, 847, 563, 1010], "vertical": true, "font_size": 20.0, "lines": ["卒業までみんなと", "いられないのは", "残念だけど、"]}, {"box": [166, 1006, 246, 1366], "vertical": true, "font_size": 21.0, "lines": ["みんな", "明るく元気よく", "これからも", "過ごしてください。"]}], "img_path": "245.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [736, 57, 872, 324], "vertical": true, "font_size": 23.0, "lines": ["それと．．．", "鈴木くんが", "転校することに", "なりました。"]}, {"box": [407, 251, 468, 418], "vertical": true, "font_size": 24.0, "lines": ["じゃあ鈴木くん", "前に．．．！！"]}], "img_path": "246.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [438, 565, 569, 701], "vertical": true, "font_size": 24.0, "lines": ["ここで", "僕はなにを", "思えばいいん", "だろう？"]}, {"box": [493, 1189, 518, 1309], "vertical": true, "font_size": 23.0, "lines": ["からっぽだ。"]}], "img_path": "247.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [671, 526, 728, 621], "vertical": true, "font_size": 23.0, "lines": ["その日の"]}, {"box": [669, 528, 694, 618], "vertical": true, "font_size": 28.0, "lines": ["夕焼けは"]}, {"box": [565, 527, 623, 638], "vertical": true, "font_size": 32.0, "lines": ["いつもより赤かった。"]}, {"box": [561, 527, 624, 639], "vertical": true, "font_size": 28.0, "lines": ["いつもより", "赤かった。"]}, {"box": [634, 1150, 766, 1335], "vertical": true, "font_size": 23.0, "lines": ["この箱の中は", "どんな願いでも", "かなう一度きりの", "魔法が入っている"]}, {"box": [355, 1150, 376, 1262], "vertical": true, "font_size": 19.0, "lines": ["今なら僕は"]}, {"box": [210, 1146, 307, 1325], "vertical": true, "font_size": 24.0, "lines": ["世界を終わらせる", "ことだって", "できるんだ。"]}], "img_path": "248.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "249.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "250.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [748, 230, 844, 386], "vertical": true, "font_size": 25.0, "lines": ["これが", "僕の１０歳の頃の", "記憶だ。"]}, {"box": [564, 449, 696, 694], "vertical": true, "font_size": 22.0, "lines": ["あのブリキの箱を", "あの時僕はどうしたのか", "今は行方すら", "わからずじまいだ。"]}, {"box": [390, 683, 450, 930], "vertical": true, "font_size": 23.0, "lines": ["少なくとも", "世界は終わっていないし"]}, {"box": [158, 991, 289, 1180], "vertical": true, "font_size": 23.0, "lines": ["不毛な世界は", "今も昔も", "そうたいして", "変わってやしない"]}], "img_path": "251.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [745, 178, 834, 366], "vertical": true, "font_size": 24.0, "lines": ["ただ気付いたら", "大人になっていた。"]}, {"box": [707, 177, 729, 299], "vertical": true, "font_size": 19.0, "lines": ["それだけだ。"]}, {"box": [420, 80, 515, 295], "vertical": true, "font_size": 22.0, "lines": ["僕が１８歳の時に母が、", "そして半年前に父が", "他界した"]}, {"box": [172, 82, 337, 261], "vertical": true, "font_size": 23.0, "lines": ["その父は", "死ぬ直前に病室で", "僕が父の前妻の", "連れ子だった事を", "告げた。"]}, {"box": [717, 687, 814, 800], "vertical": true, "font_size": 26.0, "lines": ["僕は", "導かれる", "ようにして"]}, {"box": [500, 971, 574, 1047], "vertical": true, "font_size": 32.0, "lines": ["手口ミロ"]}, {"box": [203, 691, 298, 812], "vertical": true, "font_size": 24.0, "lines": ["１０年振りに", "この町に", "戻ってきた"]}], "img_path": "252.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [736, 91, 861, 399], "vertical": true, "font_size": 22.0, "lines": ["．．．へえ", "お客さんそんな", "遠くから来たの？", "もの好きだねぇ。"]}, {"box": [205, 446, 346, 801], "vertical": true, "font_size": 19.0, "lines": ["あそこらは", "観光地じゃないし", "何もないよ？", "狭くて小さな", "つまんない町だよ。"]}, {"box": [789, 866, 883, 1067], "vertical": true, "font_size": 22.0, "lines": ["僕の産みの", "母親の墓が", "あるらしいんです。"]}], "img_path": "253.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [575, 87, 637, 209], "vertical": true, "font_size": 26.0, "lines": ["．．．ちょっと", "君．．．．．？"]}, {"box": [839, 722, 860, 836], "vertical": true, "font_size": 19.0, "lines": ["そうだ．．．．．．"]}, {"box": [573, 779, 704, 987], "vertical": true, "font_size": 24.0, "lines": ["あの時僕は", "魔法の箱を", "知らない大人に", "渡してしまったんだ。"]}, {"box": [92, 1213, 151, 1323], "vertical": true, "font_size": 24.0, "lines": ["こんな風に", "して．．．"]}], "img_path": "254.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "255.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [480, 1173, 501, 1271], "vertical": true, "font_size": 19.0, "lines": ["．．．そうだ"]}], "img_path": "256.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [287, 162, 382, 318], "vertical": true, "font_size": 22.0, "lines": ["もっと以前に", "僕はこの景色を", "見ていた。"]}, {"box": [180, 161, 244, 284], "vertical": true, "font_size": 28.0, "lines": ["家族と", "赤い夕日と"]}, {"box": [111, 163, 137, 392], "vertical": true, "font_size": 19.0, "lines": ["僕は確かにここにいた"]}], "img_path": "257.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "258.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "259.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [660, 101, 720, 300], "vertical": true, "font_size": 23.0, "lines": ["自然とその墓の前で", "足が止まった。"]}, {"box": [464, 98, 562, 275], "vertical": true, "font_size": 22.0, "lines": ["それが母親の", "ものである確信は", "なかったか"]}, {"box": [274, 97, 370, 254], "vertical": true, "font_size": 22.0, "lines": ["どうしても", "違和感を覚えて", "ならなかった。"]}, {"box": [699, 944, 829, 1123], "vertical": true, "font_size": 23.0, "lines": ["その墓石は", "右上の角が取れて", "不自然に丸みを", "おびていた。"]}, {"box": [105, 1200, 132, 1336], "vertical": true, "font_size": 24.0, "lines": ["．．．あの．．．．．"]}], "img_path": "260.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [781, 69, 843, 199], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．", "すいません、"]}, {"box": [159, 245, 255, 412], "vertical": true, "font_size": 24.0, "lines": ["突然こんな事", "聞いて失礼", "なんですけど．．"]}, {"box": [262, 545, 328, 740], "vertical": true, "font_size": 28.0, "lines": ["これに見覚え", "ありませんか？"]}, {"box": [884, 829, 914, 941], "vertical": true, "font_size": 30.0, "lines": ["あ．．．．．．"]}, {"box": [545, 823, 564, 944], "vertical": true, "font_size": 23.0, "lines": ["．．．やっぱり．．．"]}, {"box": [446, 908, 504, 1013], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．．．あの", "コレ．．．"]}, {"box": [121, 904, 230, 1250], "vertical": true, "font_size": 24.0, "lines": ["よく", "たぶんあなたが", "わからない", "持つべきものの", "けど．．．", "はずだから．．．"]}], "img_path": "261.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [777, 19, 843, 184], "vertical": true, "font_size": 28.0, "lines": ["．．．これ", "どこで．．．？？"]}, {"box": [471, 42, 568, 221], "vertical": true, "font_size": 25.0, "lines": ["あたしは", "何も知らないし", "わからないから。"]}, {"box": [93, 136, 177, 494], "vertical": true, "font_size": 28.0, "lines": ["．．．なんて", "君もずいぶん", "言うか．．．", "変わったのね．．"]}, {"box": [623, 424, 698, 579], "vertical": true, "font_size": 32.0, "lines": ["何も", "聞かないで。"]}, {"box": [343, 1009, 591, 1094], "vertical": false, "font_size": 32.0, "lines": ["話"]}], "img_path": "262.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [837, 125, 862, 239], "vertical": true, "font_size": 24.0, "lines": ["例えば．．．"]}, {"box": [654, 260, 819, 449], "vertical": true, "font_size": 22.0, "lines": ["今の僕なら", "あの女を犯そうが", "ここで自分の", "首を切ろうが", "できたはずなんだ。"]}, {"box": [459, 385, 483, 540], "vertical": true, "font_size": 20.0, "lines": ["こうやって僕は"]}, {"box": [299, 383, 396, 518], "vertical": true, "font_size": 23.0, "lines": ["これからも", "世間に醜態を", "曝しながら"]}, {"box": [179, 386, 240, 517], "vertical": true, "font_size": 23.0, "lines": ["生きてゆくの", "だろうか"]}, {"box": [744, 632, 865, 840], "vertical": true, "font_size": 30.0, "lines": ["．．．．．．ふん、", "何を", "いまさら。"]}, {"box": [173, 793, 269, 961], "vertical": true, "font_size": 23.0, "lines": ["都合の悪い事は", "次々と忘れて", "いくくせに。"]}], "img_path": "263.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [725, 148, 824, 327], "vertical": true, "font_size": 26.0, "lines": ["いっそ", "世界なんて終って", "しまえばいい"]}, {"box": [251, 96, 310, 238], "vertical": true, "font_size": 29.0, "lines": ["今まで"]}, {"box": [250, 98, 273, 237], "vertical": true, "font_size": 23.0, "lines": ["何度も思った。"]}, {"box": [143, 293, 202, 414], "vertical": true, "font_size": 23.0, "lines": ["でも世界は"]}, {"box": [142, 295, 165, 411], "vertical": true, "font_size": 23.0, "lines": ["終わらない。"]}, {"box": [640, 1102, 663, 1270], "vertical": true, "font_size": 19.0, "lines": ["そら見たことか"]}, {"box": [326, 1152, 421, 1317], "vertical": true, "font_size": 24.0, "lines": ["神様なんて", "どこにも", "いやしなかった。"]}], "img_path": "264.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "265.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [198, 719, 360, 965], "vertical": false, "font_size": 22.333333333333332, "lines": ["ぐしゅん", "１１月曜より１週間、２０１７年１２月１２日土に", "なにご協力・点数も加速に", "第６火５０００匹以上は、地位でもないのでしょ", "外国や戦争圏が拒否を掴んで、", "１００４年のお"]}], "img_path": "266.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [470, 965, 541, 1114], "vertical": true, "font_size": 30.0, "lines": ["やっと", "会えたわね。"]}], "img_path": "267.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [830, 56, 887, 174], "vertical": true, "font_size": 22.0, "lines": ["あたしには", "見えるの、"]}, {"box": [99, 21, 209, 427], "vertical": true, "font_size": 27.0, "lines": ["．．．．．でももう", "苦しまなくて", "みんな", "いいの。", "許されるから。"]}, {"box": [606, 300, 667, 500], "vertical": true, "font_size": 26.0, "lines": ["この世の", "全てのできごとが。"]}], "img_path": "268.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [512, 207, 542, 281], "vertical": true, "font_size": 30.0, "lines": ["．．．ハァ"]}, {"box": [105, 388, 143, 439], "vertical": true, "font_size": 32.0, "lines": ["ハァ"]}, {"box": [630, 700, 658, 774], "vertical": true, "font_size": 28.0, "lines": ["ハァ．．．"]}], "img_path": "269.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [833, 28, 869, 109], "vertical": true, "font_size": 32.0, "lines": ["ハァッ"]}, {"box": [467, 140, 501, 225], "vertical": true, "font_size": 32.0, "lines": ["ハァッ"]}, {"box": [427, 308, 461, 388], "vertical": true, "font_size": 32.0, "lines": ["ハァッ"]}, {"box": [80, 345, 105, 438], "vertical": true, "font_size": 25.0, "lines": ["ハッ．．．"]}, {"box": [738, 718, 769, 788], "vertical": true, "font_size": 31.0, "lines": ["ほら。"]}, {"box": [105, 751, 205, 904], "vertical": true, "font_size": 31.0, "lines": ["お母さんの", "声が", "聞こえるわ"]}, {"box": [706, 1090, 738, 1270], "vertical": true, "font_size": 29.0, "lines": ["お兄ちゃん。"]}], "img_path": "270.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [395, 1088, 456, 1286], "vertical": true, "font_size": 22.0, "lines": ["お、", "お母さん．．．"]}], "img_path": "271.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "272.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "273.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [348, 523, 369, 541], "vertical": false, "font_size": 14.0, "lines": ["いや"]}], "img_path": "274.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "275.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "276.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "277.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [817, 862, 843, 926], "vertical": true, "font_size": 26.0, "lines": ["．．．おい"]}, {"box": [166, 1102, 191, 1196], "vertical": true, "font_size": 25.0, "lines": ["．．．おい！！"]}], "img_path": "278.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [814, 61, 839, 109], "vertical": true, "font_size": 22.0, "lines": ["．．．あ、"]}, {"box": [758, 192, 777, 326], "vertical": true, "font_size": 22.0, "lines": ["ごめんなさい。"]}, {"box": [789, 523, 840, 665], "vertical": true, "font_size": 19.0, "lines": ["．．．またあの夢を", "見てたのか？"]}, {"box": [139, 336, 221, 460], "vertical": true, "font_size": 20.0, "lines": ["気持ち良くて", "ついうとうと", "しちゃった"]}, {"box": [757, 851, 869, 975], "vertical": true, "font_size": 23.0, "lines": ["あたしはもう", "肉体を捨てて", "魂だけの存在", "だけど、"]}, {"box": [211, 666, 239, 750], "vertical": true, "font_size": 26.0, "lines": ["．．．ええ。"]}, {"box": [516, 1098, 574, 1200], "vertical": true, "font_size": 23.0, "lines": ["蝶に存在を", "かえて、"]}, {"box": [366, 1157, 449, 1319], "vertical": true, "font_size": 23.0, "lines": ["同年も何年も", "この世の出来事を", "見ていたわ。"]}], "img_path": "279.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [806, 62, 891, 248], "vertical": true, "font_size": 22.0, "lines": ["ずっとずつと", "深い所へおりてくと", "声が聞こえたの。"]}, {"box": [110, 75, 224, 226], "vertical": true, "font_size": 20.0, "lines": ["神様は言ったわ。", "こんな世の中は", "もううんざり", "だってね。"]}, {"box": [676, 420, 729, 545], "vertical": true, "font_size": 22.0, "lines": ["あれはきっと", "神様ね。"]}, {"box": [505, 368, 561, 442], "vertical": true, "font_size": 28.0, "lines": ["だから", "いずれ、"]}, {"box": [154, 431, 208, 555], "vertical": true, "font_size": 20.0, "lines": ["みんな消えて", "なくなるわ"]}, {"box": [772, 655, 793, 757], "vertical": true, "font_size": 19.0, "lines": ["それは．．．"]}, {"box": [188, 726, 240, 849], "vertical": true, "font_size": 19.0, "lines": ["世界の終わり", "なのかい？"]}, {"box": [619, 1019, 642, 1194], "vertical": true, "font_size": 23.0, "lines": ["終わりじゃないわ。"]}, {"box": [189, 1101, 243, 1225], "vertical": true, "font_size": 22.0, "lines": ["だってそれは", "永遠だもの。"]}], "img_path": "280.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [833, 60, 882, 203], "vertical": true, "font_size": 21.0, "lines": ["．．．な、何を", "言ってるんだ？"]}, {"box": [661, 155, 774, 340], "vertical": true, "font_size": 21.0, "lines": ["それじゃ僕は", "永遠に苦しみ", "続けるってことじゃ", "ないか．．．"]}, {"box": [185, 294, 321, 688], "vertical": true, "font_size": 25.0, "lines": ["神様なんて", "いないんだ！！", "違うと", "言ってくれ"]}], "img_path": "281.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [795, 534, 822, 691], "vertical": true, "font_size": 27.0, "lines": ["怖がらないで。"]}, {"box": [189, 774, 248, 930], "vertical": true, "font_size": 24.0, "lines": ["すべては", "あなた次第よ。"]}], "img_path": "282.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [819, 80, 931, 230], "vertical": true, "font_size": 21.0, "lines": ["．．．地方各地で", "大量発生した", "蝶は今もなお", "増え続けており、"]}, {"box": [191, 394, 273, 518], "vertical": true, "font_size": 20.0, "lines": ["農村部では", "農作物への", "．．．", "影響が"]}, {"box": [802, 665, 909, 1016], "vertical": true, "font_size": 24.0, "lines": ["小松崎も", "荒川って女も。", "消えたなぁ", "完全に。"]}, {"box": [504, 852, 589, 982], "vertical": true, "font_size": 22.0, "lines": ["．．．しかし", "この蝶ほんと", "目障りだな．．．"]}, {"box": [153, 1139, 266, 1301], "vertical": true, "font_size": 19.0, "lines": ["そういやきのう、", "虹ヶ原の近くの", "トンネルで女の", "自殺体が出たろ？"]}], "img_path": "283.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [792, 81, 905, 246], "vertical": true, "font_size": 19.0, "lines": ["専門家によると", "これほど大規模な", "繁殖は生態系にも", "深刻な影響か．．．"]}, {"box": [293, 50, 405, 192], "vertical": true, "font_size": 20.0, "lines": ["もし神様が", "いるんだったら", "俺は聞いて", "やりたいね"]}, {"box": [826, 597, 846, 699], "vertical": true, "font_size": 20.0, "lines": ["きっと．．．"]}, {"box": [434, 363, 546, 508], "vertical": true, "font_size": 21.0, "lines": ["１０年前にも", "同じ場所で女が", "自分の首切って", "死んでたよ。"]}, {"box": [77, 383, 192, 526], "vertical": true, "font_size": 22.0, "lines": ["なんで人間を", "こんなふうに", "作っちまったの", "かってよ。"]}, {"box": [144, 755, 229, 859], "vertical": true, "font_size": 22.0, "lines": ["あの怪物が", "動きだした", "んだ．．．"]}, {"box": [792, 1109, 848, 1221], "vertical": true, "font_size": 26.0, "lines": ["続いて", "お天気です。"]}, {"box": [170, 1209, 221, 1350], "vertical": true, "font_size": 21.0, "lines": ["お前．．．．．", "何言ってんだ？"]}], "img_path": "284.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [844, 23, 877, 77], "vertical": true, "font_size": 32.0, "lines": ["う"]}, {"box": [768, 618, 821, 750], "vertical": true, "font_size": 24.0, "lines": ["今日は", "全国的に晴れ。"]}, {"box": [258, 418, 315, 521], "vertical": true, "font_size": 32.0, "lines": ["あっ"]}, {"box": [146, 866, 259, 1008], "vertical": true, "font_size": 22.0, "lines": ["平年より気温は", "２、３度高く", "お洗濯日和", "でしょう。"]}], "img_path": "285.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "286.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [855, 896, 907, 1069], "vertical": true, "font_size": 21.0, "lines": ["ごめんね", "遅くなっちゃって。"]}, {"box": [224, 677, 245, 788], "vertical": true, "font_size": 19.0, "lines": ["ただいまぁ。"]}, {"box": [153, 1041, 203, 1172], "vertical": true, "font_size": 20.0, "lines": ["すぐに夕飯の", "準備するから。"]}], "img_path": "287.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [497, 53, 581, 195], "vertical": true, "font_size": 23.0, "lines": ["．．．今日もずっと", "外を見て", "いたの？"]}, {"box": [62, 127, 153, 478], "vertical": true, "font_size": 22.0, "lines": ["君はもう", "一生ここから", "懲りない", "出られないのに。", "のね。"]}, {"box": [105, 1218, 127, 1350], "vertical": true, "font_size": 19.0, "lines": ["．．．こんばんわ。"]}], "img_path": "288.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [723, 215, 872, 251], "vertical": false, "font_size": 29.0, "lines": ["リトローナムは"]}, {"box": [528, 98, 583, 201], "vertical": true, "font_size": 21.0, "lines": ["今夜も月が", "綺麗だね。"]}, {"box": [154, 459, 287, 845], "vertical": true, "font_size": 24.0, "lines": ["さらに", "しかし", "例えようもなく", "月明かりに", "美しい。", "照らされた", "君の姿は"]}, {"box": [802, 1091, 885, 1214], "vertical": true, "font_size": 22.0, "lines": ["その美しさが", "永遠である", "ことを、"]}, {"box": [180, 1168, 230, 1279], "vertical": true, "font_size": 19.0, "lines": ["何よりも", "僕は願うよ。"]}], "img_path": "289.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [236, 134, 258, 226], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．さあ。"]}, {"box": [166, 549, 219, 701], "vertical": true, "font_size": 16.0, "lines": ["話の続きを", "聞かせておくれ。"]}], "img_path": "290.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [210, 195, 230, 292], "vertical": true, "font_size": 15.0, "lines": ["．．．．．．っ"]}, {"box": [770, 536, 791, 605], "vertical": true, "font_size": 21.0, "lines": ["．．．ほら"]}, {"box": [696, 536, 793, 776], "vertical": true, "font_size": 24.0, "lines": ["．．．ほら"]}, {"box": [694, 554, 723, 780], "vertical": true, "font_size": 27.0, "lines": ["いつまで寝ているの？"]}, {"box": [239, 1064, 262, 1226], "vertical": true, "font_size": 19.0, "lines": ["もう起きなさい"]}], "img_path": "291.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [428, 603, 556, 780], "vertical": true, "font_size": 21.0, "lines": ["いつまでも", "お前の寝たふりが", "通用すると", "思うなよ"]}], "img_path": "292.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [839, 907, 922, 1031], "vertical": true, "font_size": 23.0, "lines": ["さぁ", "鈴木くん", "がんばって！！"]}, {"box": [516, 924, 602, 1030], "vertical": true, "font_size": 24.0, "lines": ["．．．ほら、", "もう立てる", "でしょ？"]}, {"box": [121, 1144, 236, 1307], "vertical": true, "font_size": 22.0, "lines": ["そんなんじゃ", "いつまで経っても", "良くならない", "わよ？"]}], "img_path": "293.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [817, 103, 837, 161], "vertical": true, "font_size": 22.0, "lines": ["．．．もう"]}, {"box": [736, 214, 788, 306], "vertical": true, "font_size": 22.0, "lines": ["勝手に", "しなさい。"]}, {"box": [101, 1193, 125, 1267], "vertical": true, "font_size": 24.0, "lines": ["．．．君、"]}], "img_path": "294.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [800, 77, 851, 207], "vertical": true, "font_size": 20.0, "lines": ["もう泣くのは", "おやめなさい。"]}, {"box": [807, 543, 858, 644], "vertical": true, "font_size": 19.0, "lines": ["君にこれを", "あげよう。"]}, {"box": [183, 679, 234, 841], "vertical": true, "font_size": 19.0, "lines": ["ひとつとじ込めた", "魔法の箱だ。"]}, {"box": [784, 948, 893, 1296], "vertical": true, "font_size": 18.0, "lines": ["この箱の蓋を", "開けるかどうか", "それは", "君の自由だ。"]}, {"box": [154, 1222, 180, 1313], "vertical": true, "font_size": 25.0, "lines": ["．．．ただし、"]}], "img_path": "295.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [766, 105, 848, 246], "vertical": true, "font_size": 20.0, "lines": ["たとえ世の中が", "どんなに不毛", "だとしても、"]}, {"box": [139, 206, 194, 318], "vertical": true, "font_size": 22.0, "lines": ["強い意志を", "持ちなさい。"]}, {"box": [783, 502, 837, 606], "vertical": true, "font_size": 22.0, "lines": ["君の人生の", "行く先は、"]}, {"box": [437, 967, 518, 1091], "vertical": true, "font_size": 23.0, "lines": ["．．．名前を", "聞かせて", "くれるかい？"]}, {"box": [158, 659, 210, 769], "vertical": true, "font_size": 21.0, "lines": ["君が決めて", "いいんだよ。"]}, {"box": [820, 1213, 840, 1323], "vertical": true, "font_size": 19.0, "lines": ["．．．アマヒコ。"]}, {"box": [143, 1244, 167, 1347], "vertical": true, "font_size": 23.0, "lines": ["そうか．．．"]}], "img_path": "296.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [829, 95, 852, 180], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．私も"]}, {"box": [172, 177, 194, 311], "vertical": true, "font_size": 19.0, "lines": ["同じ名前だよ。"]}], "img_path": "297.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "298.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [458, 1216, 910, 1261], "vertical": false, "font_size": 15.0, "lines": ["この作品は、雑誌『Ｇｕｉｃｋｄａｐａｎｄ（小社）５１〜５３、５５〜６３号までに", "連載された全１２話に、加筆訂正を加えたものです。"]}], "img_path": "299.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [179, 281, 370, 299], "vertical": false, "font_size": 16.5, "lines": ["著者", "浅野いにお"]}, {"box": [259, 143, 518, 162], "vertical": false, "font_size": 19.0, "lines": ["虹ヶ原ホログラフ"]}, {"box": [255, 187, 501, 221], "vertical": false, "font_size": 15.5, "lines": ["２００６年８月２２日第１版第１刷発行", "２００８年１１月５日第１版第１５劇発行"]}, {"box": [147, 347, 210, 366], "vertical": false, "font_size": 19.0, "lines": ["デザイン"]}, {"box": [158, 479, 211, 504], "vertical": false, "font_size": 25.0, "lines": ["発行所"]}, {"box": [255, 405, 314, 420], "vertical": false, "font_size": 15.0, "lines": ["森山裕之"]}, {"box": [251, 345, 505, 371], "vertical": false, "font_size": 18.0, "lines": ["前川期鏡（Ｈｉｓａ２ｕｍｉｄｅｓｉｇｎＩｎｃ．）"]}, {"box": [252, 457, 574, 721], "vertical": false, "font_size": 18.7, "lines": ["じゃあ", "株式会社太田出版", "〒１６０－８５７１", "東京都新宿区売木町２２工．．．プコットビルに", "ＴＥＬ：０３－３３５９－６２６２", "ＦＡＸ：０３－３３５９－００４０", "振替：００１２０－６－１６２１６６", "ホームページｈｔｔｐ：／／ｗｗｗ．ｏｈｔａｂｏｏｋｓ．ｃｏｍ／", "営業部メールアドレスｓａｌｅｓｅｒｔｉｔａｂｏｏｋｓ．ｃｏｍ", "編集部メールアドレスａｊｅｏｎｔａｂｏｏｋｓ．ｃｏｍ"]}, {"box": [133, 755, 205, 769], "vertical": false, "font_size": 14.0, "lines": ["印刷・製本"]}, {"box": [251, 754, 352, 775], "vertical": false, "font_size": 15.0, "lines": ["株式会社光邦"]}, {"box": [249, 827, 603, 964], "vertical": false, "font_size": 19.0, "lines": ["＠ＡＳＡＮＯ．Ｉｎｉｏ２００６．Ｐｒｉｎｔｅｄｉｎｇｏａｎｔ", "乱丁・落丁本はお取替えします。", "本書の無断複写・複製・転職・引用を禁じます", "定価はカバーに表記してあります。"]}, {"box": [255, 965, 561, 983], "vertical": false, "font_size": 18.0, "lines": ["ＩＳＢＭ９７８－４－７７８３．２０２０－１－ＣＤ９７９"]}], "img_path": "300.png"}, {"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [], "img_path": "301.png"}]}