{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [660, 101, 720, 300], "vertical": true, "font_size": 23.0, "lines": ["自然とその墓の前で", "足が止まった。"]}, {"box": [464, 98, 562, 275], "vertical": true, "font_size": 22.0, "lines": ["それが母親の", "ものである確信は", "なかったか"]}, {"box": [274, 97, 370, 254], "vertical": true, "font_size": 22.0, "lines": ["どうしても", "違和感を覚えて", "ならなかった。"]}, {"box": [699, 944, 829, 1123], "vertical": true, "font_size": 23.0, "lines": ["その墓石は", "右上の角が取れて", "不自然に丸みを", "おびていた。"]}, {"box": [105, 1200, 132, 1336], "vertical": true, "font_size": 24.0, "lines": ["．．．あの．．．．．"]}]}