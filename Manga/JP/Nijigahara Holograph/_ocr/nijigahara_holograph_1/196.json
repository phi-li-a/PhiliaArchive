{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [783, 73, 852, 304], "vertical": true, "font_size": 32.0, "lines": ["昔者、そしゃう", "荘周夢に胡蝶と為る。"]}, {"box": [140, 176, 210, 344], "vertical": true, "font_size": 26.0, "lines": ["栩栩然として", "胡蝶なり。．．．"]}, {"box": [785, 428, 869, 598], "vertical": true, "font_size": 20.0, "lines": ["夢で蝶になった", "荘子はひらひらと", "舞っているうちに、"]}, {"box": [680, 576, 759, 737], "vertical": true, "font_size": 20.0, "lines": ["いつしか自分が", "自分であることを", "忘れてしまう。"]}, {"box": [103, 467, 298, 776], "vertical": true, "font_size": 21.0, "lines": ["でも目覚めると", "やはり荘子", "なのだけど、", "夢で蝶になったのか", "蝶の夢で自分に", "なったのか", "わからない。"]}, {"box": [794, 857, 906, 1072], "vertical": true, "font_size": 20.0, "lines": ["色々解釈できる", "けれど、みんな", "高校生になったら", "ちゃんと習うと思うわ。"]}, {"box": [232, 1035, 259, 1098], "vertical": true, "font_size": 23.0, "lines": ["かと"]}, {"box": [143, 987, 233, 1154], "vertical": true, "font_size": 32.0, "lines": ["あなた", "無視します"]}]}