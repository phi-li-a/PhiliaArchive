{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [877, 572, 929, 735], "vertical": true, "font_size": 22.0, "lines": ["よくよく考えると", "おそろしいわね。"]}, {"box": [761, 710, 844, 897], "vertical": true, "font_size": 22.0, "lines": ["あの頃の子供たちが", "今どうしているのか", "知らないけれど、"]}, {"box": [146, 698, 227, 904], "vertical": true, "font_size": 22.0, "lines": ["何気ない私の行動が", "多少なりあの子たちに", "影響してると思うと。"]}, {"box": [892, 971, 943, 1140], "vertical": true, "font_size": 18.0, "lines": ["忘れられてるなら", "まだ救われるけど、"]}, {"box": [621, 995, 674, 1168], "vertical": true, "font_size": 19.0, "lines": ["きっと何人かには", "恨まれてたわよね"]}, {"box": [195, 1005, 215, 1136], "vertical": true, "font_size": 20.0, "lines": ["変わらないな。"]}, {"box": [90, 1138, 170, 1321], "vertical": true, "font_size": 20.0, "lines": ["君のそういう", "自分の中に溜めこむ", "考え方。"]}]}