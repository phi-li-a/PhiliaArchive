{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [807, 45, 941, 444], "vertical": true, "font_size": 22.0, "lines": ["でもびっくりしたぁ。", "さっきの人、きっと", "あたしの事、", "小学生の時の", "気付いてなかった", "先生ですよ！", "みたいだけど。"]}, {"box": [505, 81, 618, 247], "vertical": true, "font_size": 20.0, "lines": ["いい先生だったと", "思うけどなんか", "印象薄いなぁ．．．", "確かサカキ先生。"]}, {"box": [72, 254, 202, 632], "vertical": true, "font_size": 23.0, "lines": ["まぁ、", "あれ？でも、", "いいですけどね、", "片目を怪我して", "どうでも。", "包帯してたはず", "だけど．．．"]}, {"box": [847, 687, 930, 878], "vertical": true, "font_size": 19.0, "lines": ["ところでマキちゃん、", "本当にこの絵", "もらっていいの？"]}, {"box": [481, 774, 505, 938], "vertical": true, "font_size": 19.0, "lines": ["もちろんです！！"]}, {"box": [703, 1036, 937, 1376], "vertical": true, "font_size": 23.0, "lines": ["店長にもらって", "ほしくて描いたん", "ですから。", "．．．なんていうか", "はじめてですよ、", "はっきり目的があって", "絵を描こうと思った", "なんて。"]}, {"box": [263, 1124, 347, 1337], "vertical": true, "font_size": 22.0, "lines": ["あぁ、もう行かなきゃ。", "明日までの課題が", "残ってるんですよー。"]}]}