{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [745, 178, 834, 366], "vertical": true, "font_size": 24.0, "lines": ["ただ気付いたら", "大人になっていた。"]}, {"box": [707, 177, 729, 299], "vertical": true, "font_size": 19.0, "lines": ["それだけだ。"]}, {"box": [420, 80, 515, 295], "vertical": true, "font_size": 22.0, "lines": ["僕が１８歳の時に母が、", "そして半年前に父が", "他界した"]}, {"box": [172, 82, 337, 261], "vertical": true, "font_size": 23.0, "lines": ["その父は", "死ぬ直前に病室で", "僕が父の前妻の", "連れ子だった事を", "告げた。"]}, {"box": [717, 687, 814, 800], "vertical": true, "font_size": 26.0, "lines": ["僕は", "導かれる", "ようにして"]}, {"box": [500, 971, 574, 1047], "vertical": true, "font_size": 32.0, "lines": ["手口ミロ"]}, {"box": [203, 691, 298, 812], "vertical": true, "font_size": 24.0, "lines": ["１０年振りに", "この町に", "戻ってきた"]}]}