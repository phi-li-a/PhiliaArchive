{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [814, 40, 926, 206], "vertical": true, "font_size": 21.0, "lines": ["ホラ、さっきから", "廊下で彼氏くん", "待ってるよ。", "慰めてもらえば？"]}, {"box": [562, 60, 705, 237], "vertical": true, "font_size": 21.0, "lines": ["今、アイツの", "性欲まみれの頭で", "「ガンバレ」なんて", "言われたら", "プン殴りそうだ。"]}, {"box": [95, 114, 201, 489], "vertical": true, "font_size": 21.0, "lines": ["うへっ、冷めんの", "年下で金持ちの", "相変わらず", "男子なんて", "はやーーっ。", "しっ", "もったいな"]}, {"box": [404, 446, 466, 614], "vertical": true, "font_size": 26.0, "lines": ["もう帰ったって", "言っといて。"]}, {"box": [166, 519, 189, 671], "vertical": true, "font_size": 19.0, "lines": ["じゃあ、あげる。"]}]}