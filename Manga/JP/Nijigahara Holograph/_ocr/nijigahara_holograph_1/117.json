{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [713, 90, 921, 355], "vertical": true, "font_size": 22.0, "lines": ["じゃあ見学の者は", "各々自主的に", "校舎の清掃を", "すること。", "暑いから", "無理はしない", "ように。"]}, {"box": [151, 409, 175, 502], "vertical": true, "font_size": 23.0, "lines": ["はーい"]}, {"box": [836, 827, 917, 1053], "vertical": true, "font_size": 20.0, "lines": ["競泳じゃないんだから", "プールの中を歩いたって", "かまわないんだぞ。"]}, {"box": [225, 670, 284, 744], "vertical": true, "font_size": 30.0, "lines": ["あ", "鈴木。"]}, {"box": [572, 1162, 687, 1365], "vertical": true, "font_size": 21.0, "lines": ["もし体を見られたく", "ないなら、エシャツを", "着たまま入っても", "いいし。"]}, {"box": [120, 1207, 174, 1299], "vertical": true, "font_size": 25.0, "lines": ["あれ？", "おーい。"]}]}