{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [766, 73, 879, 236], "vertical": true, "font_size": 19.0, "lines": ["先生は事情により", "今年度て先生を", "辞めることに", "なりました。"]}, {"box": [147, 174, 229, 379], "vertical": true, "font_size": 21.0, "lines": ["４年、５年と、", "このクラスのみんなと", "過ごした２年間は．．．"]}, {"box": [835, 860, 895, 991], "vertical": true, "font_size": 25.0, "lines": ["とてもいい", "思い出です。"]}, {"box": [482, 847, 563, 1010], "vertical": true, "font_size": 20.0, "lines": ["卒業までみんなと", "いられないのは", "残念だけど、"]}, {"box": [166, 1006, 246, 1366], "vertical": true, "font_size": 21.0, "lines": ["みんな", "明るく元気よく", "これからも", "過ごしてください。"]}]}