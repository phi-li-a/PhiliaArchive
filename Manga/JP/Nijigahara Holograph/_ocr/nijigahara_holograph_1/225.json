{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [751, 97, 822, 262], "vertical": true, "font_size": 29.0, "lines": ["幸せで平穏な", "時間の流れに"]}, {"box": [262, 205, 289, 325], "vertical": true, "font_size": 25.0, "lines": ["人は還る。"]}, {"box": [300, 538, 352, 691], "vertical": true, "font_size": 22.0, "lines": ["彼の両親とは", "昔からの友人で、"]}, {"box": [153, 618, 263, 743], "vertical": true, "font_size": 22.0, "lines": ["．．．まぁ、", "家族ぐるみの", "付き合い", "でしたから。"]}, {"box": [811, 853, 923, 1022], "vertical": true, "font_size": 20.0, "lines": ["中学生の時ですか", "両親とも悲しい", "亡くなり方を", "しましたからね。"]}, {"box": [550, 864, 631, 1016], "vertical": true, "font_size": 19.0, "lines": ["私としてはもう", "息子みたいな", "気持ちでしたよ。"]}, {"box": [94, 901, 202, 1314], "vertical": true, "font_size": 22.0, "lines": ["これもきっと", "あの子のやさしさ", "小松崎くんは", "なんです．．．", "やさしい子です。"]}]}