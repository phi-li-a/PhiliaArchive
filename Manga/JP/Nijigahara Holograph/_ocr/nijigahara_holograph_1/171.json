{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [808, 63, 868, 217], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．なんだ", "今日は休みか。"]}, {"box": [89, 43, 237, 424], "vertical": true, "font_size": 26.0, "lines": ["あの荒川って", "バイトの女なぁ、", "なんか", "知ってるような", "気がするんだよ。"]}, {"box": [780, 721, 874, 873], "vertical": true, "font_size": 23.0, "lines": ["どうしたお前", "さっきから上", "ばかり見て。"]}, {"box": [566, 892, 662, 1084], "vertical": true, "font_size": 26.0, "lines": ["．．．いや、なんか", "２階で人が動いた", "気がしたんです。"]}, {"box": [77, 1112, 175, 1258], "vertical": true, "font_size": 26.0, "lines": ["おい、勝手に", "敷地に入る", "なよ。"]}]}