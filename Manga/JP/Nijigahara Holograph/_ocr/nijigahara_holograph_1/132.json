{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [672, 62, 699, 251], "vertical": true, "font_size": 27.0, "lines": ["この頃、夢を見る。"]}, {"box": [568, 61, 630, 261], "vertical": true, "font_size": 23.0, "lines": ["私が教師をしていた", "頃の夢だ。"]}, {"box": [427, 62, 520, 192], "vertical": true, "font_size": 23.666666666666668, "lines": ["楽しい記憶や", "辛い記憶を", "思い出すも"]}, {"box": [287, 60, 382, 283], "vertical": true, "font_size": 23.0, "lines": ["子供たちの顔や名前は", "霧がかかったように", "おぼろげだ。"]}, {"box": [854, 823, 885, 970], "vertical": true, "font_size": 28.0, "lines": ["おい、恭子？"]}, {"box": [289, 885, 382, 1127], "vertical": true, "font_size": 22.0, "lines": ["日曜日の朝に", "気持ちよく起きるなんて", "もう何年もない"]}, {"box": [159, 883, 297, 1173], "vertical": true, "font_size": 24.0, "lines": ["けど、晴れた日の朝は好き。", "何かすべてが許されたような", "気分になるから"]}, {"box": [59, 1087, 142, 1320], "vertical": true, "font_size": 20.0, "lines": ["市役所職員、痴漢で逮捕", "今年は冷夏の予想で", "夏野菜に影響．．．"]}]}