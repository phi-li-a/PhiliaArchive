{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [400, 76, 564, 283], "vertical": true, "font_size": 21.0, "lines": ["「見えるの", "見えるの", "あたしには見えるの", "この世の中の", "全てのできことが」"]}, {"box": [184, 602, 283, 737], "vertical": true, "font_size": 26.0, "lines": ["僕はあの日も", "光る蝶を", "見た。"]}, {"box": [610, 1036, 850, 1324], "vertical": true, "font_size": 24.0, "lines": ["．．．なぜだろう、", "今日は昔の記憶が", "ついさっきの事のように", "蘇ってくる。", "まるで", "過去と今が", "混ざってゆく", "ように。"]}, {"box": [132, 1180, 266, 1358], "vertical": true, "font_size": 25.0, "lines": ["あの日の蝶が", "今、僕の目の前で", "夜空一面を", "埋めつくす。"]}]}