{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [720, 20, 833, 205], "vertical": true, "font_size": 20.0, "lines": ["マキちゃんみたいな", "明るく振舞えるコ", "には裏を感じ", "ちゃうんだよなぁ。"]}, {"box": [334, 187, 421, 393], "vertical": true, "font_size": 21.0, "lines": ["例えば人に言えない", "ようなものを心の奥に", "持っているとか．．"]}, {"box": [56, 263, 139, 406], "vertical": true, "font_size": 22.0, "lines": ["．．．僕でよければ", "聞いてあげる", "けど．．．"]}, {"box": [148, 769, 267, 1031], "vertical": true, "font_size": 23.0, "lines": ["．．．あたし、", "子供の頃、", "友達を殺そうと", "したんです。"]}, {"box": [824, 1099, 903, 1241], "vertical": true, "font_size": 21.0, "lines": ["．．．．．正確には", "クラスのみんな", "で．．．．．"]}, {"box": [713, 1200, 792, 1342], "vertical": true, "font_size": 21.0, "lines": ["その子を井戸に", "突き落とし", "たんです。"]}, {"box": [83, 1182, 167, 1344], "vertical": true, "font_size": 19.0, "lines": ["真っ白い肌で", "髪が長くて", "綺麗な子だった．．．"]}]}