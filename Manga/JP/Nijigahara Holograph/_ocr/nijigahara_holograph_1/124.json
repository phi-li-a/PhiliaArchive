{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [791, 68, 903, 273], "vertical": true, "font_size": 22.0, "lines": ["今だって", "私のクラス、いじめの", "対象の子、いるんで", "しょうけど。"]}, {"box": [567, 106, 590, 191], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．恭．．"]}, {"box": [226, 86, 306, 535], "vertical": true, "font_size": 21.0, "lines": ["背負うなんて", "バカげてる", "．．．だって！！", "じゃない！！"]}, {"box": [73, 184, 185, 367], "vertical": true, "font_size": 21.0, "lines": ["バカな子供の", "いざこざにいちいち", "つき合ってたら", "体がもたないし！！"]}, {"box": [638, 375, 691, 547], "vertical": true, "font_size": 23.0, "lines": ["なんか、もう", "どうでもよくって。"]}, {"box": [312, 409, 338, 556], "vertical": true, "font_size": 24.0, "lines": ["他人の不幸まで"]}, {"box": [788, 1148, 869, 1292], "vertical": true, "font_size": 20.0, "lines": ["恭子ちゃん．．．", "君は真面目", "すぎるよ。"]}, {"box": [195, 1155, 276, 1259], "vertical": true, "font_size": 22.0, "lines": ["僕は教師と", "しての君", "じゃなくて"]}, {"box": [97, 1248, 148, 1359], "vertical": true, "font_size": 22.0, "lines": ["君自身が", "好きなんだ。"]}]}