{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [853, 69, 934, 274], "vertical": true, "font_size": 20.0, "lines": ["あたしの好きな", "男の子と仲良くしてる", "そのコが妬ましくて、"]}, {"box": [153, 260, 213, 426], "vertical": true, "font_size": 24.0, "lines": ["．．．それは", "昨日の彼かい？"]}, {"box": [635, 404, 689, 576], "vertical": true, "font_size": 22.0, "lines": ["死んでしまえば", "いいと思ってた．．．。"]}, {"box": [724, 721, 807, 935], "vertical": true, "font_size": 20.0, "lines": ["君はまだちゃんと", "人を好きになった事が", "ないのかもしれないね。"]}, {"box": [568, 1051, 595, 1123], "vertical": true, "font_size": 25.0, "lines": ["．．．あ．．．"]}, {"box": [429, 1095, 524, 1265], "vertical": true, "font_size": 25.0, "lines": ["す．．．すいません", "なにしてるん", "でしょうね！？"]}, {"box": [84, 1132, 146, 1299], "vertical": true, "font_size": 24.0, "lines": ["ごめんなさい！！", "私、帰ります！！"]}]}