{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [656, 654, 716, 813], "vertical": true, "font_size": 24.0, "lines": ["僕がこの学校に", "転校してきた時"]}, {"box": [695, 945, 714, 1071], "vertical": true, "font_size": 21.0, "lines": ["．．．ねぇみんな、"]}, {"box": [478, 654, 576, 766], "vertical": true, "font_size": 27.0, "lines": ["僕の中に", "淡い期待が", "あった。"]}, {"box": [304, 654, 399, 855], "vertical": true, "font_size": 25.0, "lines": ["次こそは", "うまくやれるんじゃ", "ないかって。"]}, {"box": [590, 1015, 641, 1120], "vertical": true, "font_size": 21.0, "lines": ["やめようよ", "こんな事"]}, {"box": [477, 1187, 498, 1320], "vertical": true, "font_size": 19.0, "lines": ["でもやっぱり"]}, {"box": [308, 1186, 450, 1352], "vertical": true, "font_size": 24.0, "lines": ["ここでも", "同じような事が", "繰り返されてて。"]}, {"box": [192, 1185, 289, 1343], "vertical": true, "font_size": 23.0, "lines": ["どうにかそれを", "やりすごそうと", "決めたんだ。"]}]}