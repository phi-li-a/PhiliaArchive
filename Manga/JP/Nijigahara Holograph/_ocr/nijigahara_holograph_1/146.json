{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [826, 45, 906, 228], "vertical": true, "font_size": 21.0, "lines": ["あなたと結婚しても", "男性への恐怖心が", "消えなくて．．．"]}, {"box": [709, 144, 794, 349], "vertical": true, "font_size": 21.0, "lines": ["顔の傷を整形したって", "本質的なことは何も", "変わらないわ。"]}, {"box": [534, 83, 615, 207], "vertical": true, "font_size": 19.0, "lines": ["困るわよね、", "こんな事を今", "言われても。"]}, {"box": [97, 130, 148, 254], "vertical": true, "font_size": 19.0, "lines": ["掘り返すなよ", "辛い記憶を。"]}, {"box": [131, 456, 152, 567], "vertical": true, "font_size": 19.0, "lines": ["．．．なんかね"]}, {"box": [727, 624, 884, 1012], "vertical": true, "font_size": 20.0, "lines": ["汚れた下水の上に", "人が暮らしてるのと", "どんなに忘れよう。", "同じじゃない？", "隠そうとしても", "奥の奥に存在", "してるの。"]}, {"box": [60, 717, 172, 881], "vertical": true, "font_size": 22.0, "lines": ["だから私は", "いつまでたっても", "心がふらふら", "するのよ。"]}, {"box": [72, 1106, 158, 1270], "vertical": true, "font_size": 22.0, "lines": ["あなたは器用な人", "だから．．．", "なんだか悔しい。"]}]}