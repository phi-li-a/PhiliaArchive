{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [836, 58, 948, 240], "vertical": true, "font_size": 19.0, "lines": ["あなたの子供たちに", "対する真っ直ぐな", "気持ちが私には", "辛いんです。"]}, {"box": [660, 50, 714, 236], "vertical": true, "font_size": 22.0, "lines": ["教育方針の", "違いって事ですか？"]}, {"box": [569, 159, 620, 285], "vertical": true, "font_size": 22.0, "lines": ["そんなの関係", "ないですよ！！"]}, {"box": [57, 30, 210, 313], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．それと", "あなたはやさしいから", "この顔の傷のこと", "何も聞かないで", "くれたけど．．．"]}, {"box": [179, 482, 230, 614], "vertical": true, "font_size": 22.0, "lines": ["言わせて、", "この傷のこと。"]}, {"box": [761, 771, 917, 1218], "vertical": true, "font_size": 20.0, "lines": ["学校裏の虹ヶ原で", "私のクラスの女子が", "男に襲われている所を", "あなたが赴任する", "見つけてしまったの。", "前、去年の", "春の終わりごろ、"]}, {"box": [82, 1060, 196, 1241], "vertical": true, "font_size": 21.0, "lines": ["当然助けようと", "したわ。私の", "受け持ったクラスの", "子だもの。"]}]}