{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [899, 172, 923, 243], "vertical": true, "font_size": 24.0, "lines": ["いてっ。"]}, {"box": [497, 312, 609, 457], "vertical": true, "font_size": 23.0, "lines": ["小松崎くんの", "ケガって本当は", "隼人がやったん", "でしょ？"]}, {"box": [60, 452, 175, 633], "vertical": true, "font_size": 22.0, "lines": ["．．．いいんだよ", "あいつはシカトで。", "頭悪いんだもん", "あいつ。"]}, {"box": [848, 700, 928, 863], "vertical": true, "font_size": 19.0, "lines": ["俺だってクラスの", "雰囲気を悪くする", "つもりはねぇし"]}, {"box": [735, 804, 813, 1010], "vertical": true, "font_size": 19.0, "lines": ["要は誰がトップに", "なって、どうバランス", "とるかってことだろ？"]}, {"box": [76, 779, 287, 1087], "vertical": true, "font_size": 22.0, "lines": ["小松崎は殴るばっかで", "何も考えちゃいねぇん", "だもん", "木村のことで俺たち", "気ぃつかってたけど、", "もうやめた", "ダメだよあいつは。"]}, {"box": [899, 1118, 922, 1265], "vertical": true, "font_size": 24.0, "lines": ["．．．バカみたい。"]}, {"box": [799, 1189, 858, 1318], "vertical": true, "font_size": 24.0, "lines": ["もういいよ", "その話は。"]}, {"box": [153, 1210, 177, 1355], "vertical": true, "font_size": 23.0, "lines": ["早く帰れば？"]}]}