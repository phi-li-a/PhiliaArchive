{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [809, 109, 832, 199], "vertical": true, "font_size": 23.0, "lines": ["それでね、"]}, {"box": [162, 169, 279, 323], "vertical": true, "font_size": 25.0, "lines": ["「あんたら一家を", "みてるとこっち", "まで不幸になる」", "って。"]}, {"box": [852, 551, 878, 601], "vertical": true, "font_size": 26.0, "lines": ["．．．そ、"]}, {"box": [725, 632, 809, 718], "vertical": true, "font_size": 26.0, "lines": ["そんな事", "ないさ", "有江！！"]}, {"box": [123, 602, 237, 745], "vertical": true, "font_size": 22.0, "lines": ["あぁ！！", "母さんだって", "きっと見守って", "くれてる"]}, {"box": [784, 877, 897, 1020], "vertical": true, "font_size": 22.0, "lines": ["．．．確かに", "すこし前に", "母さんは死んだ", "けれど．．．"]}, {"box": [116, 923, 138, 1016], "vertical": true, "font_size": 20.0, "lines": ["．．．うん"]}, {"box": [571, 1157, 685, 1310], "vertical": true, "font_size": 22.0, "lines": ["きっと魂が", "蝶になって", "父さん達の側に", "いてくれるよ．．．。"]}, {"box": [187, 1138, 302, 1282], "vertical": true, "font_size": 22.0, "lines": ["．．．ほら、", "夕飯までまだ", "時間があるから", "遊んでおいで。"]}, {"box": [102, 1262, 131, 1334], "vertical": true, "font_size": 25.0, "lines": ["．．．うん。"]}]}