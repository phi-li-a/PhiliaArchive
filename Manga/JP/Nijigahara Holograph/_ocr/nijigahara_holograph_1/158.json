{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [822, 364, 902, 547], "vertical": true, "font_size": 20.0, "lines": ["相手が抵抗", "できないくらい", "大きな力を使って？"]}, {"box": [739, 505, 788, 646], "vertical": true, "font_size": 20.0, "lines": ["そんな解決しか", "できないの？"]}, {"box": [386, 523, 467, 685], "vertical": true, "font_size": 20.0, "lines": ["君はもう", "被害者じゃなくて", "加害者だね。"]}, {"box": [56, 256, 170, 653], "vertical": true, "font_size": 21.0, "lines": ["ねぇ、高浜くん、", "君はこのまま", "僕は思うよ。", "だときっと", "ろくでもない人間に", "なるって。"]}, {"box": [779, 808, 892, 1220], "vertical": true, "font_size": 21.0, "lines": ["なんならここから", "．．．ねぇ高浜くん、", "突き落として", "いつまで黙って", "やろうか？", "るの？"]}, {"box": [109, 1162, 169, 1329], "vertical": true, "font_size": 25.0, "lines": ["ちょっとアンタ", "何してんのッ！？"]}]}