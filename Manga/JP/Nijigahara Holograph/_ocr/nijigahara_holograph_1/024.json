{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [820, 69, 902, 194], "vertical": true, "font_size": 21.0, "lines": ["．．．妻は私と", "別れた後すぐ", "別の男と．．．"]}, {"box": [509, 102, 595, 210], "vertical": true, "font_size": 25.0, "lines": ["別の男性と", "再婚し", "埼玉へ、"]}, {"box": [371, 192, 482, 364], "vertical": true, "font_size": 25.0, "lines": ["しかしその", "翌年に失踪して", "捜索願いが", "出されていました。"]}, {"box": [884, 385, 910, 498], "vertical": true, "font_size": 21.0, "lines": ["．．．木村さん、"]}, {"box": [777, 471, 859, 595], "vertical": true, "font_size": 21.0, "lines": ["これは", "私自身の興味", "ですかね"]}, {"box": [354, 495, 467, 638], "vertical": true, "font_size": 19.0, "lines": ["失踪中この方は", "５年もどこで", "何をしていたん", "でしょうか？"]}, {"box": [69, 420, 180, 585], "vertical": true, "font_size": 20.0, "lines": ["．．．このトンネルの", "中にね、人が生活", "していた形跡が", "あるんですよ。"]}, {"box": [822, 791, 844, 933], "vertical": true, "font_size": 18.0, "lines": ["知りませんよ．．"]}, {"box": [230, 721, 281, 845], "vertical": true, "font_size": 21.0, "lines": ["放っておいて", "ください。"]}, {"box": [86, 871, 195, 994], "vertical": true, "font_size": 21.0, "lines": ["今はもう私は", "娘と二人で", "幸せに暮らし", "てるんだ．．．"]}, {"box": [761, 1118, 873, 1280], "vertical": true, "font_size": 20.0, "lines": ["そういえば、", "ここらの小学生の", "間で変な噂が", "流行ってますな。"]}, {"box": [105, 1202, 156, 1353], "vertical": true, "font_size": 22.0, "lines": ["たしか、", "トンネルの"]}]}