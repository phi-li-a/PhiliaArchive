{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [777, 42, 910, 198], "vertical": true, "font_size": 25.0, "lines": ["ある日村に", "未来を予言する", "美しい少女が", "やってくる"]}, {"box": [609, 218, 765, 402], "vertical": true, "font_size": 26.0, "lines": ["やがてその少女は", "トンネルの中の", "怪物が厄災を", "もたらすと予言", "した。"]}, {"box": [254, 386, 388, 524], "vertical": true, "font_size": 27.0, "lines": ["少女は", "神様が送った", "使いだった", "のだが、"]}, {"box": [131, 563, 267, 729], "vertical": true, "font_size": 24.0, "lines": ["村人達は少女の", "存在自体を怖れ", "首を切り怪物に", "捧げてしまった。"]}, {"box": [906, 827, 923, 975], "vertical": true, "font_size": 17.0, "lines": ["んっ、ふぁっ、はぁぁぁっ"]}, {"box": [698, 810, 910, 1189], "vertical": true, "font_size": 23.0, "lines": ["すると今度は", "その少女の生まれ", "村人達はまた", "変わりがやって", "同じように", "くるのだが", "怪物に捧げて", "しまう。"]}, {"box": [470, 822, 600, 1001], "vertical": true, "font_size": 22.0, "lines": ["しかしまた", "少女が現われ．．．", "悲劇は不毛に", "くり返される"]}, {"box": [101, 903, 237, 1061], "vertical": true, "font_size": 25.0, "lines": ["少女で腹を", "満たした怪物は", "際限なく大きく", "なってゆく。"]}, {"box": [98, 1189, 193, 1283], "vertical": true, "font_size": 24.0, "lines": ["．．．たしか", "そんな話", "だった"]}]}