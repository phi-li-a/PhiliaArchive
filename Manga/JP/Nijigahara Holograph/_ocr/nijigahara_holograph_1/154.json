{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [442, 98, 527, 435], "vertical": true, "font_size": 26.0, "lines": ["榊先生、", "あ", "失礼します。", "若松隼人。"]}, {"box": [738, 356, 868, 555], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．でないと", "ちょっとした油断で", "何かがはじけて", "しまいそうで"]}, {"box": [412, 583, 444, 639], "vertical": true, "font_size": 32.0, "lines": ["え？"]}, {"box": [94, 503, 190, 646], "vertical": true, "font_size": 24.0, "lines": ["給食のあと", "職員室に来る", "ように。"]}, {"box": [397, 781, 580, 851], "vertical": false, "font_size": 32.0, "lines": ["話"]}, {"box": [873, 1005, 932, 1183], "vertical": true, "font_size": 24.0, "lines": ["給食の後片付けは", "終わりましたか？"]}, {"box": [339, 1155, 468, 1320], "vertical": true, "font_size": 22.0, "lines": ["清掃時間です。", "今日もすみずみ", "までしっかり", "掃除しましょう。"]}]}