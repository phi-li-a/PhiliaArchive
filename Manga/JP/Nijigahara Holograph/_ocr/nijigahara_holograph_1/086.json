{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [486, 64, 539, 224], "vertical": true, "font_size": 24.0, "lines": ["痛いか？", "痛いよなそりゃ。"]}, {"box": [263, 28, 377, 212], "vertical": true, "font_size": 21.0, "lines": ["だけど", "世の中にはもっと", "苦しんでる人が", "たくさんいるだろ？"]}, {"box": [758, 519, 911, 830], "vertical": true, "font_size": 22.0, "lines": ["なんか．．．最近", "あぶねぇよ", "もうカネとかじゃ", "小松崎は。", "なくて、とにかく", "人を殴りたい", "だけじゃん。"]}, {"box": [47, 377, 132, 521], "vertical": true, "font_size": 24.0, "lines": ["それに比べりゃ", "お前、まだまだ", "幸せだよ。"]}, {"box": [806, 953, 887, 1104], "vertical": true, "font_size": 19.0, "lines": ["それは．．．だって", "それはしょーが", "ねぇじゃん．．．．．．"]}, {"box": [371, 765, 453, 896], "vertical": true, "font_size": 21.0, "lines": ["やっぱ木村が", "入院してから", "だよなぁ．．．。"]}, {"box": [91, 696, 190, 889], "vertical": true, "font_size": 27.0, "lines": ["それはマジで", "シャレんなんねー", "だろ？"]}, {"box": [661, 1172, 691, 1239], "vertical": true, "font_size": 24.0, "lines": ["あ．．．"]}, {"box": [589, 1224, 608, 1323], "vertical": true, "font_size": 24.0, "lines": ["オイオイ！！"]}, {"box": [76, 1133, 208, 1333], "vertical": true, "font_size": 24.0, "lines": ["なんでだよ！？", "高浜だってもう", "全然抵抗しねぇし、", "もういいじゃん！！"]}]}