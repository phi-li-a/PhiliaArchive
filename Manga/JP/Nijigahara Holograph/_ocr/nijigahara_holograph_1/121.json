{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [831, 60, 926, 250], "vertical": true, "font_size": 23.0, "lines": ["いやっでも！！", "どうして僕を", "避けるんですか！？"]}, {"box": [107, 180, 202, 370], "vertical": true, "font_size": 24.0, "lines": ["僕は恭子ちゃんを", "本気で真剣に", "好きなのに！？"]}, {"box": [858, 393, 938, 577], "vertical": true, "font_size": 21.0, "lines": ["．．．．．．失遇の", "飲み会の時は私、", "すごく酔ってたし．．．"]}, {"box": [779, 489, 826, 661], "vertical": true, "font_size": 21.0, "lines": ["あなたがとても", "強引だったから．．．"]}, {"box": [158, 483, 209, 614], "vertical": true, "font_size": 19.0, "lines": ["全部忘れて", "ください．．．"]}, {"box": [866, 748, 918, 919], "vertical": true, "font_size": 18.0, "lines": ["それに学校では", "名前で呼ばないで。"]}, {"box": [441, 718, 643, 993], "vertical": true, "font_size": 23.0, "lines": ["私だって真剣に", "考えてみた", "けれど．．．", "やっぱりあなた", "みたいな純粋な人と", "おつき合いは", "できません。"]}, {"box": [87, 896, 107, 942], "vertical": true, "font_size": 21.0, "lines": ["．．．ど、"]}, {"box": [130, 1019, 183, 1152], "vertical": true, "font_size": 32.0, "lines": ["どういう意味ですか榊先生。"]}, {"box": [127, 1020, 183, 1151], "vertical": true, "font_size": 21.0, "lines": ["どういう意味", "ですか榊先生。"]}]}