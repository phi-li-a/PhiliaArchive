{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [582, 90, 678, 334], "vertical": true, "font_size": 24.0, "lines": ["ゆうべから", "降り続いた雨は", "ようやくあがったものの"]}, {"box": [442, 92, 535, 245], "vertical": true, "font_size": 20.333333333333332, "lines": ["低い鉛色の空は", "今にもまた雨を", "降らせそうで"]}, {"box": [300, 88, 397, 265], "vertical": true, "font_size": 24.0, "lines": ["こんな湿度の日は", "あの頃の事を", "思い出す。"]}, {"box": [180, 330, 241, 530], "vertical": true, "font_size": 25.0, "lines": ["．．．いや、正確には", "より、思い出す。"]}, {"box": [791, 725, 923, 909], "vertical": true, "font_size": 22.0, "lines": ["毎日のように", "反芻した記憶", "思い出すのは", "難しい事じゃない"]}, {"box": [79, 795, 208, 929], "vertical": true, "font_size": 24.0, "lines": ["ただ今日は", "いつもよりも", "色濃く蘇って", "くる"]}, {"box": [70, 1056, 152, 1358], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．", "こんにちは！", "荒川です。"]}]}