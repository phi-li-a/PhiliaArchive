{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [792, 81, 905, 246], "vertical": true, "font_size": 19.0, "lines": ["専門家によると", "これほど大規模な", "繁殖は生態系にも", "深刻な影響か．．．"]}, {"box": [293, 50, 405, 192], "vertical": true, "font_size": 20.0, "lines": ["もし神様が", "いるんだったら", "俺は聞いて", "やりたいね"]}, {"box": [826, 597, 846, 699], "vertical": true, "font_size": 20.0, "lines": ["きっと．．．"]}, {"box": [434, 363, 546, 508], "vertical": true, "font_size": 21.0, "lines": ["１０年前にも", "同じ場所で女が", "自分の首切って", "死んでたよ。"]}, {"box": [77, 383, 192, 526], "vertical": true, "font_size": 22.0, "lines": ["なんで人間を", "こんなふうに", "作っちまったの", "かってよ。"]}, {"box": [144, 755, 229, 859], "vertical": true, "font_size": 22.0, "lines": ["あの怪物が", "動きだした", "んだ．．．"]}, {"box": [792, 1109, 848, 1221], "vertical": true, "font_size": 26.0, "lines": ["続いて", "お天気です。"]}, {"box": [170, 1209, 221, 1350], "vertical": true, "font_size": 21.0, "lines": ["お前．．．．．", "何言ってんだ？"]}]}