{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [781, 482, 840, 620], "vertical": true, "font_size": 21.0, "lines": ["今日もまた", "あの夢を見た"]}, {"box": [677, 482, 732, 685], "vertical": true, "font_size": 21.0, "lines": ["蝶が子供の俺に", "何か話しかけてくる。"]}, {"box": [572, 480, 628, 684], "vertical": true, "font_size": 21.0, "lines": ["導かれるように", "俺はトンネルに入る"]}, {"box": [427, 478, 489, 680], "vertical": true, "font_size": 26.0, "lines": ["このトンネルは．．．", "確か小学校の裏の："]}, {"box": [322, 480, 349, 657], "vertical": true, "font_size": 24.0, "lines": ["何回繰り返した？"]}, {"box": [209, 478, 295, 642], "vertical": true, "font_size": 26.0, "lines": ["忘れた頃に見る", "この夢。"]}, {"box": [148, 483, 173, 644], "vertical": true, "font_size": 19.0, "lines": ["１０歳の頃からだ。"]}, {"box": [168, 1191, 194, 1252], "vertical": true, "font_size": 26.0, "lines": ["．．．誰？"]}]}