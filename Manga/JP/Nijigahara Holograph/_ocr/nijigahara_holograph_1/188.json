{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [840, 101, 865, 166], "vertical": true, "font_size": 25.0, "lines": ["．．．は？"]}, {"box": [590, 89, 726, 275], "vertical": true, "font_size": 19.0, "lines": ["スーパー店長殺しの", "容疑者の小松崎と", "カフェのバイトの女は", "お前の同級生", "なんだってな。"]}, {"box": [198, 81, 252, 213], "vertical": true, "font_size": 24.0, "lines": ["．．．はい、", "そうですけど、"]}, {"box": [102, 172, 155, 256], "vertical": true, "font_size": 24.0, "lines": ["小学生の", "頃の．．．"]}, {"box": [195, 437, 278, 582], "vertical": true, "font_size": 21.0, "lines": ["．．．今朝、その", "小学校で児童が", "男に刺された。"]}, {"box": [791, 766, 930, 1165], "vertical": true, "font_size": 21.0, "lines": ["聞き覚え", "あるだろ？", "職員に", "こいつもお前らの", "取りおさえられた", "同級生だ。", "高浜って男．．．"]}, {"box": [86, 1187, 169, 1349], "vertical": true, "font_size": 20.0, "lines": ["取り調べで", "わけのわからん事", "言ってるらしい。"]}]}