{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [846, 60, 897, 181], "vertical": true, "font_size": 19.0, "lines": ["コレなんだか", "わかります？"]}, {"box": [528, 43, 608, 195], "vertical": true, "font_size": 21.0, "lines": ["うーん．．．", "真っ赤．．．．実に", "真っ赤ですねぇ。"]}, {"box": [94, 8, 182, 383], "vertical": true, "font_size": 22.0, "lines": ["どういう意味", "そりゃ見れば", "なのかっていう．．．", "わかりますけど、"]}, {"box": [468, 441, 580, 605], "vertical": true, "font_size": 21.0, "lines": ["別にいいんじゃ", "ないスか？", "子供の自由な感性", "ってことで。"]}, {"box": [832, 743, 914, 925], "vertical": true, "font_size": 19.0, "lines": ["東京から転校して", "きた鈴木くんがコレ", "描いたんですけど、"]}, {"box": [463, 718, 520, 845], "vertical": true, "font_size": 27.0, "lines": ["入院？", "病気ですか？"]}, {"box": [576, 926, 694, 1280], "vertical": true, "font_size": 22.0, "lines": ["ちょっと雰囲気", "変わってるって", "長い入院生活で", "いうか．．．", "勉強も遅れがち", "らしいし．．．"]}, {"box": [90, 1146, 172, 1310], "vertical": true, "font_size": 22.0, "lines": ["いえ、前の学校で", "屋上から落ちた", "らしいです。"]}]}