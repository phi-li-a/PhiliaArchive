{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [590, 104, 612, 191], "vertical": true, "font_size": 20.0, "lines": ["．．．え？"]}, {"box": [99, 241, 203, 568], "vertical": true, "font_size": 22.0, "lines": ["虹ヶ原の", "土手に来て", "ほしい．．．。", "．．．明日の朝、"]}, {"box": [429, 659, 545, 954], "vertical": true, "font_size": 21.0, "lines": ["虹ヶ原って．．．", "あたしらの", "小学校の裏に", "あった？"]}, {"box": [770, 1128, 852, 1321], "vertical": true, "font_size": 27.0, "lines": ["へえ。", "同級生？"]}, {"box": [196, 1129, 278, 1322], "vertical": true, "font_size": 20.0, "lines": ["不良っていうか、", "もう男子は誰も", "逆らえないカンジの。"]}, {"box": [87, 1191, 136, 1359], "vertical": true, "font_size": 20.0, "lines": ["いるじゃないスか。", "クラスに一人は。"]}]}