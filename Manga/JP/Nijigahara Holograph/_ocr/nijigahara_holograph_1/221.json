{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [103, 110, 200, 310], "vertical": true, "font_size": 24.0, "lines": ["あのカフェの店長、", "この２、３時間が", "山場らしい。"]}, {"box": [848, 602, 933, 748], "vertical": true, "font_size": 21.0, "lines": ["．．．ま、どのみち", "命をとりとめた", "ところで、"]}, {"box": [226, 627, 276, 748], "vertical": true, "font_size": 22.0, "lines": ["家族もいない", "ようだし．．．"]}, {"box": [717, 669, 831, 834], "vertical": true, "font_size": 21.0, "lines": ["目も耳も、", "五感のほとんどが", "使いもんにならん", "だろうけどな。"]}, {"box": [154, 718, 177, 852], "vertical": true, "font_size": 22.0, "lines": ["不幸な男だよ。"]}, {"box": [635, 1168, 733, 1323], "vertical": true, "font_size": 29.0, "lines": ["．．．．．案外", "幸せかも", "しれませんよ。"]}, {"box": [128, 956, 240, 1290], "vertical": true, "font_size": 21.0, "lines": ["なんせもう", "おまたせして", "１０年以上も", "すみません、", "前のもの", "ですから．．．"]}]}