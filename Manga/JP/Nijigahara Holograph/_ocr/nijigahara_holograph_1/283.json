{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [819, 80, 931, 230], "vertical": true, "font_size": 21.0, "lines": ["．．．地方各地で", "大量発生した", "蝶は今もなお", "増え続けており、"]}, {"box": [191, 394, 273, 518], "vertical": true, "font_size": 20.0, "lines": ["農村部では", "農作物への", "．．．", "影響が"]}, {"box": [802, 665, 909, 1016], "vertical": true, "font_size": 24.0, "lines": ["小松崎も", "荒川って女も。", "消えたなぁ", "完全に。"]}, {"box": [504, 852, 589, 982], "vertical": true, "font_size": 22.0, "lines": ["．．．しかし", "この蝶ほんと", "目障りだな．．．"]}, {"box": [153, 1139, 266, 1301], "vertical": true, "font_size": 19.0, "lines": ["そういやきのう、", "虹ヶ原の近くの", "トンネルで女の", "自殺体が出たろ？"]}]}