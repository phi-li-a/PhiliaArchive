{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [705, 103, 788, 232], "vertical": true, "font_size": 19.0, "lines": ["すいません、", "．．．．．．なんか", "ダメでしたね。"]}, {"box": [595, 206, 675, 336], "vertical": true, "font_size": 19.0, "lines": ["あたしが下手", "なのかな", "なんて．．．はは。"]}, {"box": [110, 232, 135, 314], "vertical": true, "font_size": 25.0, "lines": ["いや．．．"]}, {"box": [878, 949, 906, 997], "vertical": true, "font_size": 28.0, "lines": ["え？"]}, {"box": [494, 662, 611, 848], "vertical": true, "font_size": 25.0, "lines": ["．．．店長、あたしが", "昨日あげた絵、", "飾ってくれてないん", "ですね。"]}, {"box": [401, 726, 456, 860], "vertical": true, "font_size": 24.0, "lines": ["．．．ああ、", "破って捨てた。"]}, {"box": [362, 985, 531, 1315], "vertical": true, "font_size": 20.0, "lines": ["虹ヶ原は", "あんな陳腐な", "景色じゃないよ。", "君は美しさが", "どういうものか", "わかってないんだろ。"]}, {"box": [99, 1200, 153, 1331], "vertical": true, "font_size": 24.0, "lines": ["君はつくづく", "悲しい奴だな。"]}]}