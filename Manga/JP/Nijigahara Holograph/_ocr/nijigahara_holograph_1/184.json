{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [530, 571, 698, 796], "vertical": true, "font_size": 24.0, "lines": ["その後、", "近所の子供たちの間に", "あの日記帳の物語が", "広まっている事を", "偶然知る"]}, {"box": [283, 571, 496, 795], "vertical": true, "font_size": 24.0, "lines": ["彼女はいくら探しても", "もういないのに、", "彼女が作り出した", "物語が脈々と", "生きているのだと", "思うと．．．"]}, {"box": [95, 310, 158, 422], "vertical": true, "font_size": 27.0, "lines": ["激しく後悔", "している"]}, {"box": [293, 1203, 317, 1316], "vertical": true, "font_size": 24.0, "lines": ["．．．．．星空？"]}]}