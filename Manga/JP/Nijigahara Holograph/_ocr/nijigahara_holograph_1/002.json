{"version": "0.1.6", "img_width": 979, "img_height": 128, "blocks": [{"box": [713, 18, 776, 109], "vertical": true, "font_size": 14.0, "lines": ["「強い意志を", "持ちな。", "もっともつと", "強い意志を」"]}, {"box": [674, 24, 701, 103], "vertical": true, "font_size": 12.0, "lines": ["「犯々直」という大地を提供", "女に、小学校の対象", "のぬるとりが女席で"]}, {"box": [644, 24, 653, 78], "vertical": true, "font_size": 12.0, "lines": ["空、城の奥太先生"]}, {"box": [624, 23, 637, 67], "vertical": true, "font_size": 13.0, "lines": ["お世紀数かは、"]}, {"box": [497, 19, 510, 95], "vertical": true, "font_size": 12.0, "lines": ["「おまえはいらん"]}, {"box": [575, 23, 607, 112], "vertical": true, "font_size": 12.0, "lines": ["こんな物品は", "もう描けないと思います", "逃げしにお"]}, {"box": [259, 24, 466, 116], "vertical": false, "font_size": 14.0, "lines": ["．．．長編連載作品", "出来ないです、怠け者の君へ、", "いつもの間へ、臆病者の君へ", "「ひゃいのまちょっ！！リラニンとの言動いた私が", "ウォハラリの人数連続に", "．．．神星の乗り車の"]}]}