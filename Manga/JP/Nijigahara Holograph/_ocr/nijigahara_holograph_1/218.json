{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [583, 83, 681, 260], "vertical": true, "font_size": 26.0, "lines": ["先日の雨のせいで", "水かさが増して", "歩き辛い。"]}, {"box": [517, 81, 539, 196], "vertical": true, "font_size": 19.0, "lines": ["俺は今日も"]}, {"box": [334, 78, 468, 287], "vertical": true, "font_size": 21.0, "lines": ["光る蝶に", "導かれるようにして"]}, {"box": [304, 79, 375, 258], "vertical": true, "font_size": 22.0, "lines": ["トンネルの中を", "さまよっている"]}, {"box": [632, 1148, 763, 1324], "vertical": true, "font_size": 22.0, "lines": ["ふと、その光が", "蝶ではなく", "何かの目のような", "気がして、"]}, {"box": [415, 1146, 440, 1259], "vertical": true, "font_size": 23.0, "lines": ["小学生の頃"]}, {"box": [381, 1143, 442, 1345], "vertical": true, "font_size": 23.0, "lines": ["あの子が言っていた"]}, {"box": [243, 1144, 334, 1299], "vertical": true, "font_size": 23.0, "lines": ["トンネルの中の", "怪物の話を", "思い出した。"]}, {"box": [241, 1142, 334, 1299], "vertical": true, "font_size": 32.0, "lines": ["トンネルの中の怪物の話を思い出した。"]}]}