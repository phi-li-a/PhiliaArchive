{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [840, 90, 863, 214], "vertical": true, "font_size": 19.0, "lines": ["．．．驚いたろ？"]}, {"box": [241, 69, 291, 189], "vertical": true, "font_size": 20.0, "lines": ["悪ガキだった", "若松隼人も"]}, {"box": [151, 217, 203, 338], "vertical": true, "font_size": 20.0, "lines": ["今じゃ市井の", "警察官だ。"]}, {"box": [747, 486, 829, 658], "vertical": true, "font_size": 19.0, "lines": ["まったく月日が", "経つのなんて", "あっという間だな。"]}, {"box": [542, 780, 656, 982], "vertical": true, "font_size": 21.0, "lines": ["スーパーの", "店長殺しと", "ゆうべのカフェ店長の", "傷害事件．．．"]}, {"box": [392, 879, 501, 1004], "vertical": true, "font_size": 21.0, "lines": ["二人の事件で", "お前はじきに", "参考人として", "呼ばれるよ。"]}, {"box": [75, 1000, 187, 1345], "vertical": true, "font_size": 22.0, "lines": ["お前がとんな", "．．．荒川、", "事件に巻き込ま", "れてるか知らない", "けどさ、"]}]}