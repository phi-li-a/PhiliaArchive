{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [906, 98, 936, 162], "vertical": true, "font_size": 23.0, "lines": ["はは。"]}, {"box": [764, 170, 874, 337], "vertical": true, "font_size": 23.0, "lines": ["これでも喫茶店", "やってるんだよ？", "そりゃある程度は", "作れるよ。"]}, {"box": [395, 101, 604, 349], "vertical": true, "font_size": 22.0, "lines": ["へへ．．．．．でも", "前から思ってたん", "ですけど、", "２０代でお店", "もってるなんて", "店長すごい", "ですよね。"]}, {"box": [108, 413, 296, 624], "vertical": true, "font_size": 22.0, "lines": ["．．．まぁ、", "親の遺産とか", "いろいろね", "たいした", "金額じゃ", "なかったけど。"]}, {"box": [826, 831, 934, 1139], "vertical": true, "font_size": 23.0, "lines": ["気にしないで、", "たいした事じゃ", "．．．え？", "ないんだからさ。", "ああ！"]}, {"box": [466, 668, 490, 751], "vertical": true, "font_size": 24.0, "lines": ["あ．．．．．．"]}, {"box": [347, 1080, 448, 1371], "vertical": true, "font_size": 21.0, "lines": ["．．．あの、", "店長って", "恋人いないん", "．．．ですよね？"]}, {"box": [93, 970, 188, 1338], "vertical": true, "font_size": 20.0, "lines": ["．．．いないねぇ、", "欲しいとは", "思ってるんだけど。"]}]}