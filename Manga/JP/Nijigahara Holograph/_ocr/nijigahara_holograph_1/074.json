{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [671, 79, 767, 304], "vertical": true, "font_size": 22.0, "lines": ["春だった風も", "なまあたたかい", "嫌な風に変わってきた"]}, {"box": [496, 76, 591, 239], "vertical": true, "font_size": 22.0, "lines": ["僕がこの学校に", "転校してきて", "そろそろ２ヶ月"]}, {"box": [354, 75, 447, 255], "vertical": true, "font_size": 22.0, "lines": ["僕は僕ができると", "思っていた以上に", "小学生していた。"]}, {"box": [213, 73, 308, 297], "vertical": true, "font_size": 25.0, "lines": ["僕は少し", "大人に近づいたのかも", "しれない"]}, {"box": [440, 519, 523, 569], "vertical": false, "font_size": 27.0, "lines": ["だとだと"]}, {"box": [819, 817, 879, 1066], "vertical": true, "font_size": 24.0, "lines": ["マンガの回し読みとか"]}, {"box": [817, 819, 844, 1067], "vertical": true, "font_size": 24.0, "lines": ["５時間目の体育の話とか"]}, {"box": [691, 1073, 785, 1230], "vertical": true, "font_size": 24.0, "lines": ["当たり障りなく", "こなして、", "みんなが笑う時"]}, {"box": [657, 1073, 680, 1169], "vertical": true, "font_size": 23.0, "lines": ["僕も笑う。"]}, {"box": [151, 952, 249, 1153], "vertical": true, "font_size": 26.0, "lines": ["なんだ", "生きるって簡単じゃ", "ないか。"]}]}