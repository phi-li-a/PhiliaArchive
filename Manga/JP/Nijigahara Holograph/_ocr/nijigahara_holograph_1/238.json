{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [813, 68, 864, 219], "vertical": true, "font_size": 18.0, "lines": ["．．．見ましたか", "あの子の体の傷、"]}, {"box": [635, 200, 719, 382], "vertical": true, "font_size": 19.0, "lines": ["事故の傷跡？", "どうもそれだけじゃ", "ない気が．．．"]}, {"box": [378, 73, 460, 295], "vertical": true, "font_size": 21.0, "lines": ["母親が今", "手が離せないから", "迎えには来れないと．．．"]}, {"box": [260, 181, 308, 324], "vertical": true, "font_size": 18.0, "lines": ["なんて", "無責任な親だ！！"]}, {"box": [606, 445, 658, 569], "vertical": true, "font_size": 20.0, "lines": ["．．．ところで", "家に連絡は？"]}, {"box": [124, 500, 205, 624], "vertical": true, "font_size": 19.0, "lines": ["どうも複雑な", "事情の家庭", "らしくて．．．"]}, {"box": [774, 807, 867, 1000], "vertical": true, "font_size": 25.0, "lines": ["その事を", "あの子は知って", "るんでしょうか？"]}, {"box": [157, 1064, 181, 1172], "vertical": true, "font_size": 24.0, "lines": ["さぁ．．．"]}]}