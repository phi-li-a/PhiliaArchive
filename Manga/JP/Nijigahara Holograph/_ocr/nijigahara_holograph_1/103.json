{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [154, 125, 215, 245], "vertical": true, "font_size": 26.0, "lines": ["マキちゃん", "大丈夫？"]}, {"box": [844, 360, 914, 508], "vertical": true, "font_size": 31.0, "lines": ["．．．すいません", "店長。"]}, {"box": [179, 426, 260, 598], "vertical": true, "font_size": 19.0, "lines": ["ははは、僕こそ", "ちょっと飲ませ", "過ぎちゃったかな。"]}, {"box": [828, 702, 945, 864], "vertical": true, "font_size": 21.0, "lines": ["ごめんね、勝手に", "絵、見させて", "もらったよ。", "上手なんだねぇ。"]}, {"box": [587, 669, 669, 801], "vertical": true, "font_size": 22.0, "lines": ["練習すれば", "誰でも上手に", "描けるんです。"]}, {"box": [343, 886, 424, 1070], "vertical": true, "font_size": 19.0, "lines": ["アタシはそれ以前に", "ココロ的な問題が", "あるらしいスよ？"]}, {"box": [646, 1136, 759, 1301], "vertical": true, "font_size": 21.0, "lines": ["僕、芸術ってよく", "わからないけれど", "マキちゃんの絵", "好きだなぁ。"]}, {"box": [82, 1161, 142, 1303], "vertical": true, "font_size": 24.0, "lines": ["うーん．．．", "僕はねぇ、"]}]}