{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [753, 61, 848, 262], "vertical": true, "font_size": 25.0, "lines": ["．．．．．じゃあ", "放課後も教室で", "待機してるように。"]}, {"box": [138, 194, 166, 293], "vertical": true, "font_size": 28.0, "lines": ["．．．隼人？"]}, {"box": [311, 390, 373, 509], "vertical": true, "font_size": 26.0, "lines": ["いやぁ．．．", "あの先生、"]}, {"box": [47, 523, 161, 833], "vertical": true, "font_size": 25.0, "lines": ["手加減なしで", "怒ると", "殴りやがんの", "マジで怖い", "のな。"]}, {"box": [799, 748, 822, 915], "vertical": true, "font_size": 20.0, "lines": ["．．．どうしたの？"]}, {"box": [820, 994, 918, 1220], "vertical": true, "font_size": 22.0, "lines": ["高浜が俺達から", "金とられてる事、", "先生と親にチクッた。"]}, {"box": [360, 1127, 454, 1304], "vertical": true, "font_size": 22.0, "lines": ["放課後に", "俺のかーちゃん", "呼ばれるってさ。"]}, {"box": [80, 1144, 181, 1321], "vertical": true, "font_size": 27.0, "lines": ["．．．．．親は", "関係ねーじゃん、", "なぁ？"]}]}