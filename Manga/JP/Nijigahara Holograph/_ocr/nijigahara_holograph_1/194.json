{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [723, 97, 806, 240], "vertical": true, "font_size": 21.0, "lines": ["今日も", "こんな早朝から", "熱心ですね。"]}, {"box": [124, 513, 236, 696], "vertical": true, "font_size": 21.0, "lines": ["あなただって", "毎朝そこから", "じっと見ていたじゃ", "ないですか"]}, {"box": [846, 796, 868, 907], "vertical": true, "font_size": 19.0, "lines": ["．．．鈴木さん、"]}, {"box": [116, 869, 228, 991], "vertical": true, "font_size": 19.0, "lines": ["家庭の都合で", "この街から", "出なきゃなら", "なくなった。"]}, {"box": [635, 1173, 718, 1305], "vertical": true, "font_size": 23.0, "lines": ["やっと", "話しかけて", "くれましたね。"]}, {"box": [135, 1173, 219, 1296], "vertical": true, "font_size": 22.0, "lines": ["．．．息子は", "元気でやって", "ますか？"]}]}