{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [837, 137, 858, 243], "vertical": true, "font_size": 21.0, "lines": ["え？"]}, {"box": [312, 151, 394, 282], "vertical": true, "font_size": 21.0, "lines": ["ううん．．．", "なんでもない、", "気のせい"]}, {"box": [603, 374, 626, 478], "vertical": true, "font_size": 19.0, "lines": ["なんだよ。"]}, {"box": [61, 457, 173, 602], "vertical": true, "font_size": 22.0, "lines": ["それより", "校舎の中に誰か", "いた気がするん", "だけど。"]}, {"box": [833, 690, 915, 832], "vertical": true, "font_size": 19.0, "lines": ["．．．不審者？", "通報したほうが", "いいのかしら？"]}, {"box": [554, 735, 583, 803], "vertical": true, "font_size": 22.0, "lines": ["さぁ？"]}, {"box": [449, 767, 528, 961], "vertical": true, "font_size": 22.0, "lines": ["いいんじゃないか？", "俺はもうこの学校の", "教師じゃないんだし。"]}, {"box": [842, 975, 893, 1166], "vertical": true, "font_size": 19.0, "lines": ["変わったのね", "あなたもこの１０年で。"]}, {"box": [444, 1151, 497, 1293], "vertical": true, "font_size": 22.0, "lines": ["人が変わるのに", "十分な時間さ。"]}, {"box": [64, 846, 243, 1255], "vertical": true, "font_size": 20.0, "lines": ["そういえばさっきの", "喫茶店の女の子、", "私が昔担任してた", "きっともう憶えて", "子だわ。", "いないのだろうけど。", "月日ってそんなもの", "なのかしらね。"]}]}