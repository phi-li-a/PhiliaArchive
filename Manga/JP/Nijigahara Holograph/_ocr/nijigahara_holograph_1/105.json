{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [653, 69, 866, 499], "vertical": true, "font_size": 23.0, "lines": ["「トンネルの中の怪物が」", "「いつか世界を終わらせるよ」", "．．．って。", "いつごろからか", "その子、凄い剣幕で", "そんなこと言うように", "なって。"]}, {"box": [113, 84, 275, 432], "vertical": true, "font_size": 20.0, "lines": ["今にしてみれば", "子供の空想のお話で", "片付けられるけど、", "あの頃はみんな", "本気で怖がって", "たんですよ。"]}, {"box": [833, 582, 915, 754], "vertical": true, "font_size": 20.0, "lines": ["．．．で、みんな", "こんな風に考え", "ちゃったんですね。"]}, {"box": [627, 883, 687, 1086], "vertical": true, "font_size": 23.0, "lines": ["「世界は救われるん", "じゃないか」って。"]}, {"box": [131, 662, 215, 807], "vertical": true, "font_size": 22.0, "lines": ["もしかしたら", "この子がいなく", "なれば」"]}, {"box": [79, 1125, 160, 1296], "vertical": true, "font_size": 20.0, "lines": ["．．．でも少なくとも", "あたしだけは", "違うこと考えてた。"]}]}