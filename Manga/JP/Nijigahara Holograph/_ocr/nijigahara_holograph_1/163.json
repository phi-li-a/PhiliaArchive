{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [861, 79, 917, 265], "vertical": true, "font_size": 23.0, "lines": ["．．．神様かくれた", "その箱さえあれば"]}, {"box": [720, 157, 815, 322], "vertical": true, "font_size": 23.0, "lines": ["僕はなんだって", "できるはず", "なんだ。"]}, {"box": [541, 508, 635, 674], "vertical": true, "font_size": 22.0, "lines": ["ははは、それは", "おまじないの", "ようなもの？"]}, {"box": [120, 444, 276, 724], "vertical": true, "font_size": 26.0, "lines": ["．．．いや、", "こめんごめん、", "きっと", "大切なもの", "なんだね。"]}, {"box": [800, 730, 929, 885], "vertical": true, "font_size": 24.0, "lines": ["僕も以前に", "この場所で", "大切なものを", "失くしたんだ。"]}, {"box": [416, 774, 623, 1043], "vertical": true, "font_size": 24.0, "lines": ["．．．でもなんか", "そうやって色んな", "物を失って、", "みんな大人に", "なってゆくような", "気がするよ。"]}, {"box": [73, 990, 174, 1313], "vertical": true, "font_size": 24.0, "lines": ["．．．きっと、", "理想さえ", "捨てなければ", "大丈夫さ。"]}]}