{"version": "0.1.6", "img_width": 980, "img_height": 1399, "blocks": [{"box": [742, 76, 826, 262], "vertical": true, "font_size": 22.0, "lines": ["スーパーの駐車場で", "店長が刺殺、", "従業員重体。"]}, {"box": [636, 206, 718, 348], "vertical": true, "font_size": 22.0, "lines": ["市内各地で", "蝶の大量発生の", "報告．．．"]}, {"box": [344, 351, 428, 535], "vertical": true, "font_size": 22.0, "lines": ["相変わらず地方欄は", "退屈なニュース", "ばかりだな。"]}, {"box": [872, 816, 923, 947], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．なんだよ", "ジロジロ見て。"]}, {"box": [619, 873, 645, 938], "vertical": true, "font_size": 23.0, "lines": ["別に．．．"]}, {"box": [497, 870, 580, 1075], "vertical": true, "font_size": 23.0, "lines": ["こんな日でも", "いつもと変わらないん", "だなって。"]}, {"box": [94, 1180, 119, 1325], "vertical": true, "font_size": 23.0, "lines": ["．．．そうか？"]}]}