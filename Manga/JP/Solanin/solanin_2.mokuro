], [357.0, 230.0]]], "lines": ["あはは、", "何言ってんの", "平気だよ。"]}, {"box": [71, 124, 164, 346], "vertical": true, "font_size": 18, "lines_coords": [[[142.0, 135.0], [160.0, 135.0], [160.0, 191.0], [142.0, 191.0]], [[124.0, 248.0], [145.0, 248.0], [145.0, 314.0], [124.0, 314.0]], [[98.0, 249.0], [114.0, 249.0], [114.0, 346.0], [98.0, 346.0]], [[71.0, 250.0], [87.0, 250.0], [87.0, 326.0], [71.0, 326.0]]], "lines": ["．．．うん", "じゃあ、", "今日はもう", "切るね？"]}, {"box": [635, 362, 683, 500], "vertical": true, "font_size": 20, "lines_coords": [[[662.0, 362.0], [683.0, 362.0], [681.0, 500.0], [660.0, 500.0]], [[635.0, 364.0], [655.0, 364.0], [655.0, 481.0], [635.0, 481.0]]], "lines": ["．．．って、あたし", "もう１８だよ？"]}, {"box": [511, 398, 601, 554], "vertical": true, "font_size": 20, "lines_coords": [[[582.0, 398.0], [601.0, 398.0], [601.0, 534.0], [582.0, 534.0]], [[558.0, 398.0], [578.0, 398.0], [578.0, 516.0], [558.0, 516.0]], [[535.0, 399.0], [555.0, 399.0], [555.0, 554.0], [535.0, 554.0]], [[511.0, 398.0], [531.0, 398.0], [531.0, 495.0], [511.0, 495.0]]], "lines": ["多分お母さんが", "思ってるほど", "東京悪いトコじゃ", "ないから！！"]}, {"box": [686, 600, 706, 726], "vertical": true, "font_size": 20, "lines_coords": [[[686.0, 603.0], [706.0, 603.0], [706.0, 726.0], [686.0, 726.0]]], "lines": ["．．．寂しくない。"]}, {"box": [380, 933, 429, 1053], "vertical": true, "font_size": 22, "lines_coords": [[[405.0, 933.0], [429.0, 933.0], [429.0, 1016.0], [405.0, 1016.0]], [[380.0, 935.0], [401.0, 935.0], [401.0, 1045.0], [380.0, 1045.0]]], "lines": ["．．．訳ない", "よねーー．．．"]}], "img_path": "194.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [211, 514, 666, 671], "vertical": false, "font_size": 157, "lines_coords": [[[211.0, 514.0], [666.0, 514.0], [666.0, 671.0], [211.0, 671.0]]], "lines": ["キ全音サークと"]}, {"box": [468, 742, 487, 850], "vertical": true, "font_size": 16, "lines_coords": [[[468.0, 742.0], [484.0, 742.0], [484.0, 848.0], [468.0, 848.0]]], "lines": ["こんにちは。"]}, {"box": [621, 935, 654, 946], "vertical": false, "font_size": 11, "lines_coords": [[[621.0, 935.0], [654.0, 935.0], [654.0, 946.0], [621.0, 946.0]]], "lines": ["．．．"]}, {"box": [117, 1027, 168, 1117], "vertical": true, "font_size": 24, "lines_coords": [[[139.0, 1027.0], [168.0, 1027.0], [168.0, 1064.0], [139.0, 1064.0]], [[117.0, 1030.0], [137.0, 1030.0], [137.0, 1115.0], [117.0, 1115.0]]], "lines": ["おー", "井上さん。"]}], "img_path": "195.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [715, 94, 732, 195], "vertical": true, "font_size": 16, "lines_coords": [[[715.0, 134.0], [731.0, 134.0], [731.0, 193.0], [715.0, 193.0]], [[715.0, 94.0], [731.0, 94.0], [731.0, 130.0], [715.0, 130.0]]], "lines": ["と．．．", "えー"]}, {"box": [470, 126, 530, 223], "vertical": true, "font_size": 26, "lines_coords": [[[505.0, 126.0], [530.0, 126.0], [530.0, 221.0], [505.0, 221.0]], [[470.0, 126.0], [498.0, 126.0], [498.0, 223.0], [470.0, 223.0]]], "lines": ["何も聞か", "ないで！！"]}, {"box": [670, 789, 752, 868], "vertical": true, "font_size": 21, "lines_coords": [[[733.0, 792.0], [750.0, 792.0], [750.0, 843.0], [733.0, 843.0]], [[709.0, 791.0], [731.0, 789.0], [735.0, 842.0], [713.0, 843.0]], [[693.0, 791.0], [715.0, 789.0], [719.0, 848.0], [696.0, 849.0]], [[675.0, 792.0], [696.0, 792.0], [696.0, 868.0], [675.0, 868.0]]], "lines": ["おまえ", "まったく", "たいした", "予報だぜ"]}, {"box": [648, 792, 672, 833], "vertical": true, "font_size": 19, "lines_coords": [[[648.0, 794.0], [667.0, 792.0], [672.0, 830.0], [653.0, 833.0]]], "lines": ["ハッ！！"]}, {"box": [245, 591, 267, 700], "vertical": true, "font_size": 20, "lines_coords": [[[245.0, 591.0], [265.0, 591.0], [265.0, 700.0], [245.0, 700.0]]], "lines": ["．．．井上さん。"]}, {"box": [162, 699, 214, 780], "vertical": true, "font_size": 26, "lines_coords": [[[188.0, 699.0], [214.0, 699.0], [214.0, 780.0], [188.0, 780.0]], [[162.0, 700.0], [188.0, 700.0], [188.0, 769.0], [162.0, 769.0]]], "lines": ["芽衣子で", "いいよ。"]}, {"box": [52, 957, 157, 1075], "vertical": true, "font_size": 20, "lines_coords": [[[134.0, 958.0], [154.0, 958.0], [154.0, 1058.0], [134.0, 1058.0]], [[107.0, 958.0], [127.0, 958.0], [127.0, 1057.0], [107.0, 1057.0]], [[79.0, 958.0], [99.0, 958.0], [99.0, 1075.0], [79.0, 1075.0]], [[52.0, 957.0], [72.0, 957.0], [72.0, 1037.0], [52.0, 1037.0]]], "lines": ["芽衣子さん", "そこらへん", "ちょっと散歩", "しない？"]}], "img_path": "196.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [693, 70, 770, 255], "vertical": true, "font_size": 22, "lines_coords": [[[745.0, 70.0], [770.0, 70.0], [770.0, 255.0], [745.0, 255.0]], [[720.0, 70.0], [743.0, 70.0], [741.0, 208.0], [717.0, 208.0]], [[693.0, 71.0], [709.0, 71.0], [709.0, 213.0], [693.0, 213.0]]], "lines": ["おーーーガチャガナヤ、", "俺、こーいうの", "好きな人だよね。"]}, {"box": [415, 104, 468, 185], "vertical": true, "font_size": 26, "lines_coords": [[[442.0, 104.0], [468.0, 104.0], [468.0, 167.0], [442.0, 167.0]], [[415.0, 104.0], [441.0, 104.0], [441.0, 155.0], [415.0, 155.0]]], "lines": ["あはは", "子供"]}, {"box": [379, 424, 433, 496], "vertical": true, "font_size": 28, "lines_coords": [[[401.0, 424.0], [433.0, 424.0], [433.0, 474.0], [401.0, 474.0]], [[379.0, 425.0], [404.0, 425.0], [404.0, 496.0], [379.0, 496.0]]], "lines": ["子供", "だもん。"]}, {"box": [692, 567, 711, 701], "vertical": true, "font_size": 16, "lines_coords": [[[692.0, 567.0], [708.0, 567.0], [708.0, 701.0], [692.0, 701.0]]], "lines": ["．．．なんだコレ？"]}, {"box": [213, 566, 294, 732], "vertical": true, "font_size": 22, "lines_coords": [[[271.0, 567.0], [291.0, 567.0], [291.0, 648.0], [271.0, 648.0]], [[242.0, 566.0], [262.0, 566.0], [264.0, 685.0], [244.0, 685.0]], [[213.0, 567.0], [237.0, 567.0], [240.0, 732.0], [215.0, 732.0]]], "lines": ["高校の時", "好きになった", "バンドがあってさ。"]}, {"box": [326, 849, 439, 1101], "vertical": true, "font_size": 20, "lines_coords": [[[395.0, 849.0], [415.0, 849.0], [415.0, 953.0], [395.0, 953.0]], [[381.0, 983.0], [401.0, 983.0], [401.0, 1081.0], [381.0, 1081.0]], [[353.0, 983.0], [373.0, 983.0], [373.0, 1101.0], [353.0, 1101.0]], [[326.0, 983.0], [346.0, 983.0], [346.0, 1081.0], [326.0, 1081.0]]], "lines": ["そういえば、", "種田君って", "なんでギター", "始めたの？"]}, {"box": [94, 965, 224, 1121], "vertical": true, "font_size": 21, "lines_coords": [[[202.0, 969.0], [223.0, 969.0], [223.0, 1072.0], [202.0, 1072.0]], [[174.0, 967.0], [197.0, 967.0], [197.0, 1086.0], [174.0, 1086.0]], [[146.0, 967.0], [169.0, 967.0], [169.0, 1086.0], [146.0, 1086.0]], [[121.0, 965.0], [141.0, 965.0], [140.0, 1121.0], [120.0, 1121.0]], [[94.0, 967.0], [111.0, 967.0], [111.0, 1092.0], [94.0, 1092.0]]], "lines": ["その頃の俺、", "ホント毎日が", "退屈で憂鬱で", "どーしようもない", "奴だったけど。"]}], "img_path": "197.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [606, 94, 712, 234], "vertical": true, "font_size": 22, "lines_coords": [[[690.0, 99.0], [712.0, 99.0], [712.0, 196.0], [690.0, 196.0]], [[664.0, 96.0], [687.0, 96.0], [685.0, 234.0], [661.0, 234.0]], [[637.0, 98.0], [656.0, 98.0], [656.0, 234.0], [637.0, 234.0]], [[606.0, 96.0], [632.0, 94.0], [634.0, 164.0], [608.0, 165.0]]], "lines": ["触発されて", "ヴィンテージの", "たっかいギター", "買って、"]}, {"box": [387, 101, 464, 220], "vertical": true, "font_size": 22, "lines_coords": [[[437.0, 101.0], [462.0, 101.0], [464.0, 185.0], [440.0, 185.0]], [[414.0, 103.0], [435.0, 103.0], [436.0, 220.0], [415.0, 220.0]], [[387.0, 101.0], [408.0, 101.0], [409.0, 191.0], [388.0, 191.0]]], "lines": ["そしたら", "もうすっげー", "楽しくて、"]}, {"box": [563, 255, 640, 401], "vertical": true, "font_size": 22, "lines_coords": [[[614.0, 255.0], [640.0, 255.0], [640.0, 302.0], [614.0, 302.0]], [[590.0, 257.0], [610.0, 257.0], [610.0, 375.0], [590.0, 375.0]], [[563.0, 257.0], [583.0, 257.0], [583.0, 401.0], [563.0, 401.0]]], "lines": ["毎日", "アホみたいに", "弾きまくってた。"]}, {"box": [638, 485, 714, 660], "vertical": true, "font_size": 21, "lines_coords": [[[690.0, 485.0], [714.0, 485.0], [714.0, 624.0], [690.0, 624.0]], [[662.0, 485.0], [686.0, 485.0], [686.0, 660.0], [662.0, 660.0]], [[638.0, 486.0], [658.0, 486.0], [658.0, 570.0], [638.0, 570.0]]], "lines": ["人間、生きてく", "だけでもけっこー", "大変だし、"]}, {"box": [80, 263, 183, 423], "vertical": true, "font_size": 22, "lines_coords": [[[158.0, 263.0], [181.0, 263.0], [183.0, 401.0], [160.0, 401.0]], [[132.0, 264.0], [155.0, 264.0], [155.0, 423.0], [132.0, 423.0]], [[107.0, 266.0], [127.0, 266.0], [127.0, 383.0], [107.0, 383.0]], [[80.0, 264.0], [100.0, 264.0], [100.0, 362.0], [80.0, 362.0]]], "lines": ["ギター弾いてる", "時だけは、なんか", "無敵になった", "気分でさ！！"]}, {"box": [521, 617, 624, 792], "vertical": true, "font_size": 21, "lines_coords": [[[604.0, 617.0], [624.0, 617.0], [621.0, 757.0], [601.0, 757.0]], [[577.0, 618.0], [597.0, 618.0], [597.0, 792.0], [577.0, 792.0]], [[549.0, 617.0], [569.0, 617.0], [569.0, 765.0], [549.0, 765.0]], [[521.0, 617.0], [542.0, 617.0], [543.0, 762.0], [522.0, 762.0]]], "lines": ["世の中いろんな", "もんがコチャゴチャ", "しすぎててょく", "わかんないけど、"]}, {"box": [185, 623, 257, 758], "vertical": true, "font_size": 17, "lines_coords": [[[241.0, 624.0], [257.0, 624.0], [257.0, 758.0], [241.0, 758.0]], [[213.0, 624.0], [229.0, 624.0], [229.0, 740.0], [213.0, 740.0]], [[185.0, 623.0], [204.0, 623.0], [204.0, 710.0], [185.0, 710.0]]], "lines": ["大切な何かって", "きっとあると", "思うんだ。"]}, {"box": [105, 730, 149, 855], "vertical": true, "font_size": 17, "lines_coords": [[[129.0, 730.0], [149.0, 730.0], [149.0, 829.0], [129.0, 829.0]], [[105.0, 731.0], [121.0, 731.0], [121.0, 855.0], [105.0, 855.0]]], "lines": ["．．．ていうか", "そう信じたい。"]}, {"box": [628, 935, 703, 1053], "vertical": true, "font_size": 20, "lines_coords": [[[682.0, 936.0], [702.0, 936.0], [702.0, 1053.0], [682.0, 1053.0]], [[655.0, 936.0], [675.0, 936.0], [675.0, 1035.0], [655.0, 1035.0]], [[628.0, 935.0], [648.0, 935.0], [648.0, 1021.0], [628.0, 1021.0]]], "lines": ["それを信じて", "音楽をやり", "続ければ、"]}, {"box": [80, 986, 183, 1163], "vertical": true, "font_size": 20, "lines_coords": [[[160.0, 987.0], [180.0, 987.0], [182.0, 1105.0], [162.0, 1105.0]], [[134.0, 986.0], [154.0, 986.0], [153.0, 1163.0], [133.0, 1163.0]], [[106.0, 987.0], [126.0, 987.0], [126.0, 1125.0], [106.0, 1125.0]], [[80.0, 987.0], [100.0, 987.0], [100.0, 1055.0], [80.0, 1055.0]]], "lines": ["こんな俺でも", "ちょっとは世の中を", "変えられる気が", "してさ。"]}], "img_path": "198.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [686, 86, 736, 175], "vertical": true, "font_size": 22, "lines_coords": [[[712.0, 86.0], [736.0, 86.0], [736.0, 152.0], [712.0, 152.0]], [[688.0, 86.0], [709.0, 86.0], [707.0, 173.0], [686.0, 173.0]]], "lines": ["．．．とか", "言いつつ。"]}, {"box": [403, 65, 534, 222], "vertical": true, "font_size": 19, "lines_coords": [[[512.0, 65.0], [532.0, 65.0], [531.0, 222.0], [511.0, 222.0]], [[486.0, 65.0], [505.0, 65.0], [503.0, 222.0], [483.0, 222.0]], [[457.0, 66.0], [477.0, 66.0], [477.0, 203.0], [457.0, 203.0]], [[432.0, 66.0], [449.0, 66.0], [447.0, 164.0], [429.0, 164.0]], [[405.0, 67.0], [421.0, 67.0], [421.0, 188.0], [405.0, 188.0]]], "lines": ["昔は俺も青かった", "なんて思いながら", "死んだ目をして", "通勤電車に", "揺られてたら、"]}, {"box": [120, 139, 196, 246], "vertical": true, "font_size": 21, "lines_coords": [[[173.0, 140.0], [193.0, 140.0], [193.0, 229.0], [173.0, 229.0]], [[145.0, 139.0], [169.0, 139.0], [169.0, 240.0], [145.0, 240.0]], [[120.0, 139.0], [140.0, 139.0], [140.0, 243.0], [120.0, 243.0]]], "lines": ["．．．笑える。", "いや、全然", "笑えねーか。"]}, {"box": [552, 403, 607, 474], "vertical": true, "font_size": 28, "lines_coords": [[[578.0, 403.0], [607.0, 403.0], [607.0, 468.0], [578.0, 468.0]], [[552.0, 405.0], [578.0, 405.0], [578.0, 474.0], [552.0, 474.0]]], "lines": ["５年後", "１０年後。"]}, {"box": [461, 298, 483, 454], "vertical": true, "font_size": 20, "lines_coords": [[[461.0, 298.0], [481.0, 298.0], [483.0, 454.0], [463.0, 454.0]]], "lines": ["．．．芽衣子さんは？"]}, {"box": [361, 342, 409, 496], "vertical": true, "font_size": 20, "lines_coords": [[[386.0, 342.0], [409.0, 342.0], [409.0, 460.0], [386.0, 460.0]], [[361.0, 344.0], [378.0, 344.0], [378.0, 496.0], [361.0, 496.0]]], "lines": ["バンドやって", "みたいんでしょ？"]}, {"box": [151, 386, 173, 486], "vertical": true, "font_size": 20, "lines_coords": [[[153.0, 386.0], [173.0, 386.0], [170.0, 486.0], [151.0, 486.0]]], "lines": ["あたしは．．"]}, {"box": [699, 542, 774, 707], "vertical": true, "font_size": 21, "lines_coords": [[[754.0, 544.0], [774.0, 544.0], [774.0, 642.0], [754.0, 642.0]], [[726.0, 544.0], [745.0, 544.0], [745.0, 642.0], [726.0, 642.0]], [[699.0, 542.0], [719.0, 542.0], [721.0, 707.0], [701.0, 707.0]]], "lines": ["なんとなく", "新しいこと", "始めようと思って。"]}, {"box": [599, 678, 678, 795], "vertical": true, "font_size": 21, "lines_coords": [[[658.0, 678.0], [678.0, 678.0], [678.0, 795.0], [658.0, 795.0]], [[630.0, 679.0], [651.0, 679.0], [651.0, 774.0], [630.0, 774.0]], [[599.0, 678.0], [624.0, 678.0], [624.0, 746.0], [599.0, 746.0]]], "lines": ["．．．でもやっぱ", "向いてない", "みたい。"]}, {"box": [124, 691, 199, 848], "vertical": true, "font_size": 20, "lines_coords": [[[178.0, 691.0], [197.0, 691.0], [197.0, 829.0], [178.0, 829.0]], [[149.0, 691.0], [170.0, 691.0], [172.0, 848.0], [151.0, 848.0]], [[124.0, 691.0], [144.0, 691.0], [145.0, 820.0], [125.0, 820.0]]], "lines": ["あたしって何を", "やっても中途半端", "なんだよなぁ。"]}, {"box": [626, 952, 700, 1129], "vertical": true, "font_size": 19, "lines_coords": [[[679.0, 952.0], [699.0, 952.0], [699.0, 1072.0], [679.0, 1072.0]], [[652.0, 952.0], [672.0, 952.0], [672.0, 1129.0], [652.0, 1129.0]], [[626.0, 952.0], [642.0, 952.0], [642.0, 1059.0], [626.0, 1059.0]]], "lines": ["．．．だからもう", "サークルは辞めよう", "と思うんだ。"]}, {"box": [199, 1034, 228, 1122], "vertical": true, "font_size": 29, "lines_coords": [[[199.0, 1034.0], [228.0, 1034.0], [228.0, 1122.0], [199.0, 1122.0]]], "lines": ["えっ！？"]}], "img_path": "199.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [682, 107, 699, 148], "vertical": true, "font_size": 22, "lines_coords": [[[682.0, 107.0], [699.0, 107.0], [699.0, 148.0], [682.0, 148.0]]], "lines": ["ん．．．"]}, {"box": [578, 86, 632, 206], "vertical": true, "font_size": 22, "lines_coords": [[[603.0, 86.0], [632.0, 86.0], [632.0, 153.0], [603.0, 153.0]], [[580.0, 89.0], [600.0, 89.0], [598.0, 206.0], [578.0, 206.0]]], "lines": ["そ．．．．．", "そうかぁ．．．"]}, {"box": [421, 71, 469, 159], "vertical": true, "font_size": 21, "lines_coords": [[[448.0, 71.0], [469.0, 71.0], [469.0, 151.0], [448.0, 151.0]], [[421.0, 72.0], [442.0, 72.0], [442.0, 158.0], [421.0, 158.0]]], "lines": ["．．．なんか", "不安だな。"]}, {"box": [85, 134, 159, 271], "vertical": true, "font_size": 19, "lines_coords": [[[137.0, 134.0], [158.0, 134.0], [158.0, 215.0], [137.0, 215.0]], [[111.0, 134.0], [131.0, 134.0], [131.0, 270.0], [111.0, 270.0]], [[85.0, 137.0], [101.0, 137.0], [101.0, 270.0], [85.0, 270.0]]], "lines": ["これから", "ちゃんとやって", "いけるのかな？"]}, {"box": [559, 591, 611, 711], "vertical": true, "font_size": 21, "lines_coords": [[[584.0, 591.0], [611.0, 591.0], [611.0, 644.0], [584.0, 644.0]], [[559.0, 591.0], [579.0, 591.0], [582.0, 711.0], [562.0, 711.0]]], "lines": ["．．．さ、", "きっとさぁ！！"]}, {"box": [411, 653, 511, 772], "vertical": true, "font_size": 21, "lines_coords": [[[490.0, 653.0], [511.0, 653.0], [509.0, 752.0], [488.0, 752.0]], [[463.0, 653.0], [484.0, 653.0], [482.0, 734.0], [461.0, 734.0]], [[435.0, 655.0], [455.0, 655.0], [455.0, 772.0], [435.0, 772.0]], [[411.0, 655.0], [427.0, 655.0], [427.0, 751.0], [411.0, 751.0]]], "lines": ["２人でなら", "どうにか", "やってけると", "思うんだ！！"]}, {"box": [93, 959, 140, 1076], "vertical": true, "font_size": 18, "lines_coords": [[[119.0, 959.0], [139.0, 959.0], [139.0, 1058.0], [119.0, 1058.0]], [[94.0, 962.0], [110.0, 962.0], [110.0, 1075.0], [94.0, 1075.0]]], "lines": ["．．．ってのは", "駄目かしら？"]}], "img_path": "200.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [694, 165, 716, 247], "vertical": true, "font_size": 21, "lines_coords": [[[694.0, 167.0], [715.0, 167.0], [715.0, 247.0], [694.0, 247.0]]], "lines": ["．．．．．ぜ．．．"]}, {"box": [166, 376, 189, 494], "vertical": true, "font_size": 20, "lines_coords": [[[166.0, 376.0], [186.0, 376.0], [186.0, 493.0], [166.0, 493.0]]], "lines": ["ぜったいに！！"]}, {"box": [502, 783, 578, 902], "vertical": true, "font_size": 22, "lines_coords": [[[557.0, 783.0], [577.0, 783.0], [577.0, 902.0], [557.0, 902.0]], [[526.0, 783.0], [551.0, 783.0], [551.0, 863.0], [526.0, 863.0]], [[502.0, 783.0], [522.0, 783.0], [522.0, 882.0], [502.0, 882.0]]], "lines": ["．．．ぜったいに", "離しちゃ", "ダメだよ？"]}], "img_path": "201.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "202.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "203.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [71, 467, 129, 494], "vertical": false, "font_size": 27, "lines_coords": [[[71.0, 467.0], [129.0, 467.0], [129.0, 494.0], [71.0, 494.0]]], "lines": ["あぶないからないで"]}], "img_path": "204.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "205.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [90, 100, 178, 285], "vertical": true, "font_size": 38, "lines_coords": [[[138.0, 103.0], [178.0, 103.0], [178.0, 285.0], [138.0, 285.0]], [[90.0, 100.0], [122.0, 100.0], [122.0, 285.0], [90.0, 285.0]]], "lines": ["ニュウウウ", "ウゥウウ．．．"]}, {"box": [124, 357, 166, 506], "vertical": true, "font_size": 38, "lines_coords": [[[124.0, 357.0], [166.0, 357.0], [166.0, 506.0], [124.0, 506.0]]], "lines": ["バイク！！"]}], "img_path": "206.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [640, 270, 715, 427], "vertical": true, "font_size": 19, "lines_coords": [[[668.0, 273.0], [688.0, 273.0], [688.0, 427.0], [668.0, 427.0]], [[693.0, 270.0], [713.0, 270.0], [715.0, 427.0], [695.0, 427.0]], [[640.0, 271.0], [660.0, 271.0], [660.0, 355.0], [640.0, 355.0]]], "lines": ["会社に居づらいっ", "なんかビミョーに", "ていうか。"]}, {"box": [666, 452, 716, 632], "vertical": true, "font_size": 19, "lines_coords": [[[695.0, 473.0], [716.0, 473.0], [714.0, 594.0], [693.0, 594.0]], [[668.0, 452.0], [687.0, 452.0], [685.0, 632.0], [666.0, 632.0]]], "lines": ["やっぱ素直に", "「仙台でＯＬやれば"]}, {"box": [641, 478, 658, 646], "vertical": true, "font_size": 19, "lines_coords": [[[641.0, 478.0], [658.0, 478.0], [658.0, 608.0], [641.0, 608.0]], [[642.0, 607.0], [655.0, 607.0], [655.0, 646.0], [642.0, 646.0]]], "lines": ["よかったかなー", "ーっ"]}, {"box": [673, 739, 748, 875], "vertical": true, "font_size": 20, "lines_coords": [[[727.0, 739.0], [748.0, 739.0], [748.0, 819.0], [727.0, 819.0]], [[700.0, 739.0], [720.0, 739.0], [720.0, 856.0], [700.0, 856.0]], [[673.0, 740.0], [693.0, 740.0], [693.0, 875.0], [673.0, 875.0]]], "lines": ["でも一番", "むかつくのは", "加藤の自惚れ！"]}, {"box": [416, 719, 493, 904], "vertical": true, "font_size": 20, "lines_coords": [[[473.0, 720.0], [493.0, 720.0], [493.0, 803.0], [473.0, 803.0]], [[446.0, 719.0], [466.0, 719.0], [466.0, 904.0], [446.0, 904.0]], [[416.0, 719.0], [436.0, 719.0], [440.0, 863.0], [420.0, 863.0]]], "lines": ["「仕方ねー", "結婚してやろうか？」", "なんて言ってさ、"]}, {"box": [128, 554, 174, 659], "vertical": true, "font_size": 19, "lines_coords": [[[152.0, 554.0], [173.0, 554.0], [174.0, 652.0], [153.0, 652.0]], [[128.0, 555.0], [145.0, 555.0], [145.0, 657.0], [128.0, 657.0]]], "lines": ["辞めちゃえ", "辞めちゃえ。"]}, {"box": [81, 742, 110, 844], "vertical": true, "font_size": 20, "lines_coords": [[[81.0, 745.0], [101.0, 742.0], [106.0, 781.0], [86.0, 783.0]]], "lines": ["また、"]}, {"box": [359, 904, 433, 1061], "vertical": true, "font_size": 20, "lines_coords": [[[412.0, 904.0], [432.0, 904.0], [433.0, 1060.0], [413.0, 1060.0]], [[386.0, 905.0], [406.0, 905.0], [406.0, 1061.0], [386.0, 1061.0]], [[359.0, 905.0], [379.0, 905.0], [379.0, 1023.0], [359.0, 1023.0]]], "lines": ["別に加藤のために", "東京残ったんじゃ", "ないっつの！！"]}, {"box": [103, 964, 175, 1082], "vertical": true, "font_size": 19, "lines_coords": [[[154.0, 964.0], [174.0, 964.0], [174.0, 1047.0], [154.0, 1047.0]], [[127.0, 965.0], [147.0, 965.0], [147.0, 1081.0], [127.0, 1081.0]], [[103.0, 965.0], [119.0, 965.0], [119.0, 1067.0], [103.0, 1067.0]]], "lines": ["なにそれ", "超愛されてん", "じゃーーん。"]}], "img_path": "207.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [664, 134, 714, 222], "vertical": true, "font_size": 22, "lines_coords": [[[689.0, 134.0], [714.0, 134.0], [714.0, 221.0], [689.0, 221.0]], [[664.0, 135.0], [683.0, 135.0], [683.0, 222.0], [664.0, 222.0]]], "lines": ["ダメダメ、", "あんな奴。"]}, {"box": [339, 161, 445, 324], "vertical": true, "font_size": 22, "lines_coords": [[[423.0, 162.0], [443.0, 162.0], [443.0, 300.0], [423.0, 300.0]], [[395.0, 161.0], [415.0, 161.0], [415.0, 323.0], [395.0, 323.0]], [[368.0, 164.0], [388.0, 164.0], [388.0, 300.0], [368.0, 300.0]], [[339.0, 161.0], [365.0, 161.0], [365.0, 223.0], [339.0, 223.0]]], "lines": ["会社の月間最多", "遅刻記録作ってさ、", "いまにクビだよ", "クビ！！"]}, {"box": [114, 72, 160, 173], "vertical": true, "font_size": 20, "lines_coords": [[[139.0, 72.0], [160.0, 72.0], [160.0, 152.0], [139.0, 152.0]], [[114.0, 73.0], [131.0, 73.0], [131.0, 173.0], [114.0, 173.0]]], "lines": ["そういや", "芽衣子先輩"]}, {"box": [343, 369, 365, 478], "vertical": true, "font_size": 20, "lines_coords": [[[343.0, 369.0], [363.0, 369.0], [365.0, 478.0], [345.0, 478.0]]], "lines": ["ありゃりゃ。"]}, {"box": [52, 237, 154, 413], "vertical": true, "font_size": 20, "lines_coords": [[[134.0, 237.0], [154.0, 237.0], [153.0, 413.0], [133.0, 413.0]], [[105.0, 239.0], [125.0, 239.0], [127.0, 382.0], [107.0, 382.0]], [[79.0, 239.0], [100.0, 239.0], [101.0, 396.0], [80.0, 396.0]], [[52.0, 237.0], [72.0, 237.0], [73.0, 385.0], [53.0, 385.0]]], "lines": ["きのうも冴木さんに", "聞かれましたよ、", "ロッチは最近活動", "してんの？って。"]}, {"box": [628, 558, 731, 716], "vertical": true, "font_size": 20, "lines_coords": [[[708.0, 558.0], [731.0, 558.0], [731.0, 716.0], [708.0, 716.0]], [[682.0, 560.0], [702.0, 560.0], [702.0, 677.0], [682.0, 677.0]], [[655.0, 560.0], [675.0, 560.0], [675.0, 677.0], [655.0, 677.0]], [[628.0, 561.0], [645.0, 561.0], [645.0, 675.0], [628.0, 675.0]]], "lines": ["あの人、けっこー", "先輩達のこと", "気になってる", "みたいスよ？"]}, {"box": [530, 816, 556, 868], "vertical": true, "font_size": 20, "lines_coords": [[[530.0, 816.0], [556.0, 816.0], [556.0, 868.0], [530.0, 868.0]]], "lines": ["いやー"]}, {"box": [156, 603, 234, 741], "vertical": true, "font_size": 20, "lines_coords": [[[210.0, 603.0], [231.0, 603.0], [233.0, 707.0], [211.0, 707.0]], [[185.0, 604.0], [204.0, 604.0], [204.0, 741.0], [185.0, 741.0]], [[158.0, 603.0], [178.0, 603.0], [176.0, 741.0], [156.0, 741.0]]], "lines": ["．．．井上さん、", "もうライブやら", "ないんですか？"]}, {"box": [503, 989, 604, 1125], "vertical": true, "font_size": 20, "lines_coords": [[[584.0, 990.0], [604.0, 990.0], [604.0, 1069.0], [584.0, 1069.0]], [[557.0, 990.0], [577.0, 990.0], [577.0, 1088.0], [557.0, 1088.0]], [[529.0, 989.0], [550.0, 989.0], [548.0, 1125.0], [526.0, 1125.0]], [[503.0, 989.0], [523.0, 989.0], [523.0, 1068.0], [503.0, 1068.0]], [[505.0, 1065.0], [518.0, 1065.0], [518.0, 1103.0], [505.0, 1103.0]]], "lines": ["あたしは", "初心者だし", "曲とか作れない", "でしょー", "―？"]}, {"box": [299, 991, 372, 1129], "vertical": true, "font_size": 20, "lines_coords": [[[351.0, 992.0], [372.0, 992.0], [372.0, 1073.0], [351.0, 1073.0]], [[323.0, 991.0], [344.0, 991.0], [345.0, 1092.0], [324.0, 1092.0]], [[299.0, 993.0], [316.0, 993.0], [316.0, 1128.0], [299.0, 1128.0]]], "lines": ["それなら", "僕が教えて", "あげるのに．．．"]}, {"box": [77, 926, 154, 1067], "vertical": true, "font_size": 20, "lines_coords": [[[132.0, 926.0], [154.0, 930.0], [148.0, 970.0], [126.0, 966.0]], [[103.0, 929.0], [122.0, 929.0], [122.0, 1046.0], [103.0, 1046.0]], [[79.0, 930.0], [97.0, 930.0], [94.0, 1039.0], [77.0, 1039.0]]], "lines": ["んー", "そのうち気が", "向いたらねー"]}], "img_path": "208.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [597, 110, 675, 247], "vertical": true, "font_size": 22, "lines_coords": [[[654.0, 111.0], [675.0, 111.0], [673.0, 247.0], [652.0, 247.0]], [[627.0, 111.0], [647.0, 111.0], [647.0, 229.0], [627.0, 229.0]], [[597.0, 111.0], [623.0, 111.0], [623.0, 178.0], [597.0, 178.0]]], "lines": ["あのライフから", "半年も経った", "なんて、"]}, {"box": [501, 110, 552, 254], "vertical": true, "font_size": 23, "lines_coords": [[[528.0, 111.0], [551.0, 111.0], [551.0, 247.0], [528.0, 247.0]], [[501.0, 111.0], [524.0, 111.0], [524.0, 254.0], [501.0, 254.0]]], "lines": ["思えないくらい", "あっというまで、"]}, {"box": [332, 109, 354, 196], "vertical": true, "font_size": 21, "lines_coords": [[[332.0, 112.0], [353.0, 112.0], [353.0, 196.0], [332.0, 196.0]]], "lines": ["外はもう、"]}, {"box": [270, 111, 299, 198], "vertical": true, "font_size": 26, "lines_coords": [[[270.0, 112.0], [296.0, 111.0], [299.0, 196.0], [274.0, 198.0]]], "lines": ["少しずつ、"]}, {"box": [186, 110, 236, 235], "vertical": true, "font_size": 20, "lines_coords": [[[214.0, 111.0], [234.0, 111.0], [234.0, 209.0], [214.0, 209.0]], [[187.0, 111.0], [207.0, 111.0], [207.0, 234.0], [187.0, 234.0]]], "lines": ["夏の匂いが", "し始めている。"]}, {"box": [675, 318, 726, 440], "vertical": true, "font_size": 20, "lines_coords": [[[705.0, 319.0], [726.0, 319.0], [726.0, 398.0], [705.0, 398.0]], [[675.0, 318.0], [699.0, 318.0], [699.0, 440.0], [675.0, 440.0]]], "lines": ["やべーよ", "芽衣子ちゃん、"]}, {"box": [585, 447, 658, 583], "vertical": true, "font_size": 20, "lines_coords": [[[638.0, 447.0], [658.0, 447.0], [658.0, 564.0], [638.0, 564.0]], [[610.0, 448.0], [630.0, 448.0], [630.0, 576.0], [610.0, 576.0]], [[585.0, 450.0], [601.0, 450.0], [601.0, 583.0], [585.0, 583.0]]], "lines": ["引っ越し屋の", "トラック、もう", "来ちゃったよ！！"]}, {"box": [699, 794, 721, 956], "vertical": true, "font_size": 20, "lines_coords": [[[699.0, 795.0], [719.0, 795.0], [719.0, 950.0], [699.0, 950.0]]], "lines": ["みんなはというと"]}, {"box": [470, 738, 543, 835], "vertical": true, "font_size": 23, "lines_coords": [[[495.0, 738.0], [521.0, 738.0], [521.0, 807.0], [495.0, 807.0]], [[470.0, 739.0], [490.0, 739.0], [490.0, 835.0], [470.0, 835.0]]], "lines": ["芽衣子、", "大丈夫か？"]}, {"box": [218, 798, 241, 960], "vertical": true, "font_size": 20, "lines_coords": [[[220.0, 800.0], [240.0, 800.0], [240.0, 957.0], [220.0, 957.0]]], "lines": ["バンドはというと"]}, {"box": [586, 829, 661, 997], "vertical": true, "font_size": 21, "lines_coords": [[[640.0, 835.0], [661.0, 835.0], [661.0, 932.0], [640.0, 932.0]], [[613.0, 833.0], [634.0, 833.0], [632.0, 970.0], [611.0, 970.0]], [[586.0, 833.0], [606.0, 833.0], [606.0, 993.0], [586.0, 993.0]]], "lines": ["前より少し", "忙しそうだけど", "割と相変わらずで、"]}, {"box": [333, 1041, 354, 1120], "vertical": true, "font_size": 20, "lines_coords": [[[333.0, 1041.0], [353.0, 1041.0], [353.0, 1120.0], [333.0, 1120.0]]], "lines": ["なにが？"]}, {"box": [107, 856, 182, 1040], "vertical": true, "font_size": 21, "lines_coords": [[[160.0, 857.0], [181.0, 857.0], [182.0, 955.0], [161.0, 955.0]], [[132.0, 856.0], [155.0, 856.0], [155.0, 1014.0], [132.0, 1014.0]], [[107.0, 856.0], [125.0, 856.0], [126.0, 1039.0], [108.0, 1039.0]]], "lines": ["月に２回の", "スタジオの練習を", "どうにか続けている。"]}], "img_path": "209.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [699, 79, 719, 165], "vertical": true, "font_size": 20, "lines_coords": [[[699.0, 82.0], [719.0, 82.0], [719.0, 165.0], [699.0, 165.0]]], "lines": ["．．．仕事、"]}, {"box": [330, 114, 425, 270], "vertical": true, "font_size": 20, "lines_coords": [[[404.0, 114.0], [425.0, 114.0], [425.0, 175.0], [404.0, 175.0]], [[379.0, 114.0], [400.0, 114.0], [400.0, 215.0], [379.0, 215.0]], [[354.0, 116.0], [374.0, 116.0], [374.0, 270.0], [354.0, 270.0]], [[330.0, 116.0], [350.0, 116.0], [350.0, 194.0], [330.0, 194.0]]], "lines": ["まーた", "辛くなって", "辞めちゃうんじゃ", "ねーの？"]}, {"box": [639, 308, 688, 390], "vertical": true, "font_size": 21, "lines_coords": [[[666.0, 309.0], [687.0, 309.0], [687.0, 386.0], [666.0, 386.0]], [[639.0, 308.0], [660.0, 308.0], [660.0, 390.0], [639.0, 390.0]]], "lines": ["あたしは", "というと、"]}, {"box": [543, 308, 592, 444], "vertical": true, "font_size": 21, "lines_coords": [[[570.0, 308.0], [591.0, 308.0], [589.0, 444.0], [567.0, 444.0]], [[543.0, 309.0], [563.0, 309.0], [563.0, 425.0], [543.0, 425.0]]], "lines": ["来月から都内の", "小さな会社に"]}, {"box": [674, 512, 693, 611], "vertical": true, "font_size": 16, "lines_coords": [[[675.0, 557.0], [692.0, 557.0], [692.0, 610.0], [675.0, 610.0]], [[676.0, 514.0], [690.0, 514.0], [690.0, 536.0], [676.0, 536.0]]], "lines": ["ん．．．", "う"]}, {"box": [446, 307, 495, 427], "vertical": true, "font_size": 22, "lines_coords": [[[473.0, 308.0], [493.0, 308.0], [495.0, 425.0], [475.0, 425.0]], [[446.0, 308.0], [470.0, 308.0], [470.0, 397.0], [446.0, 397.0]]], "lines": ["勤めることが", "決まった。"]}, {"box": [142, 574, 193, 643], "vertical": true, "font_size": 23, "lines_coords": [[[168.0, 574.0], [193.0, 574.0], [193.0, 643.0], [168.0, 643.0]], [[142.0, 574.0], [163.0, 574.0], [163.0, 642.0], [142.0, 642.0]]], "lines": ["．．．ま、", "きっと、"]}, {"box": [115, 734, 165, 815], "vertical": true, "font_size": 23, "lines_coords": [[[140.0, 734.0], [165.0, 734.0], [165.0, 815.0], [140.0, 815.0]], [[115.0, 735.0], [137.0, 735.0], [137.0, 802.0], [115.0, 802.0]]], "lines": ["どーにか", "やるさ。"]}, {"box": [168, 983, 189, 1071], "vertical": true, "font_size": 20, "lines_coords": [[[168.0, 985.0], [188.0, 985.0], [188.0, 1069.0], [168.0, 1069.0]]], "lines": ["．．．そうか"]}], "img_path": "210.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [695, 79, 772, 255], "vertical": true, "font_size": 20, "lines_coords": [[[749.0, 79.0], [769.0, 79.0], [771.0, 178.0], [751.0, 178.0]], [[722.0, 79.0], [743.0, 79.0], [744.0, 255.0], [723.0, 255.0]], [[695.0, 79.0], [715.0, 79.0], [717.0, 223.0], [697.0, 223.0]]], "lines": ["この部屋は", "ひとりだとやっぱり", "手持ち無沙汰で、"]}, {"box": [126, 295, 231, 434], "vertical": true, "font_size": 22, "lines_coords": [[[211.0, 297.0], [231.0, 297.0], [229.0, 394.0], [209.0, 394.0]], [[183.0, 297.0], [204.0, 297.0], [204.0, 377.0], [183.0, 377.0]], [[156.0, 296.0], [176.0, 296.0], [176.0, 434.0], [156.0, 434.0]], [[126.0, 295.0], [153.0, 295.0], [153.0, 349.0], [126.0, 349.0]]], "lines": ["向こう岸の", "１ＤＫに", "引っ越すことに", "した。"]}, {"box": [633, 735, 734, 892], "vertical": true, "font_size": 20, "lines_coords": [[[713.0, 737.0], [733.0, 737.0], [733.0, 854.0], [713.0, 854.0]], [[687.0, 738.0], [707.0, 738.0], [707.0, 874.0], [687.0, 874.0]], [[659.0, 735.0], [679.0, 735.0], [679.0, 892.0], [659.0, 892.0]], [[633.0, 738.0], [653.0, 738.0], [653.0, 881.0], [633.0, 881.0]]], "lines": ["決めた理由は", "急行が止まって", "ちょっと便利かも", "とかその程度で、"]}, {"box": [133, 957, 240, 1115], "vertical": true, "font_size": 23, "lines_coords": [[[218.0, 960.0], [238.0, 960.0], [238.0, 1040.0], [218.0, 1040.0]], [[190.0, 960.0], [211.0, 960.0], [211.0, 1057.0], [190.0, 1057.0]], [[163.0, 959.0], [185.0, 959.0], [183.0, 1115.0], [162.0, 1115.0]], [[133.0, 957.0], [163.0, 957.0], [163.0, 1013.0], [133.0, 1013.0]]], "lines": ["土地勘も", "なにもない", "まったく知らない", "街だ。"]}], "img_path": "211.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [644, 96, 693, 203], "vertical": true, "font_size": 20, "lines_coords": [[[668.0, 96.0], [693.0, 96.0], [693.0, 178.0], [668.0, 178.0]], [[645.0, 98.0], [661.0, 98.0], [661.0, 199.0], [645.0, 199.0]]], "lines": ["心細くて", "不安だけど、"]}, {"box": [112, 196, 213, 315], "vertical": true, "font_size": 21, "lines_coords": [[[192.0, 199.0], [213.0, 199.0], [213.0, 276.0], [192.0, 276.0]], [[163.0, 196.0], [188.0, 196.0], [188.0, 277.0], [163.0, 277.0]], [[137.0, 199.0], [158.0, 199.0], [158.0, 296.0], [137.0, 296.0]], [[112.0, 199.0], [128.0, 199.0], [128.0, 312.0], [112.0, 312.0]]], "lines": ["なんだか", "ちょっと", "わくわくも", "したりして．．．"]}], "img_path": "212.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [200, 616, 275, 757], "vertical": true, "font_size": 20, "lines_coords": [[[256.0, 618.0], [272.0, 618.0], [272.0, 754.0], [256.0, 754.0]], [[223.0, 616.0], [247.0, 616.0], [249.0, 757.0], [226.0, 757.0]], [[200.0, 618.0], [220.0, 618.0], [220.0, 720.0], [200.0, 720.0]]], "lines": ["：今日はみんな", "手伝ってくれて", "ありがとね。"]}], "img_path": "213.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [101, 266, 126, 335], "vertical": true, "font_size": 25, "lines_coords": [[[101.0, 266.0], [126.0, 266.0], [126.0, 335.0], [101.0, 335.0]]], "lines": ["１億円。"]}, {"box": [600, 960, 622, 1046], "vertical": true, "font_size": 20, "lines_coords": [[[600.0, 960.0], [620.0, 960.0], [620.0, 1046.0], [600.0, 1046.0]]], "lines": ["ありがと。"]}, {"box": [168, 1000, 219, 1108], "vertical": true, "font_size": 20, "lines_coords": [[[197.0, 1000.0], [217.0, 1000.0], [217.0, 1099.0], [197.0, 1099.0]], [[170.0, 1000.0], [190.0, 1000.0], [188.0, 1106.0], [168.0, 1106.0]]], "lines": ["なんで２回", "言うんだよ"]}], "img_path": "214.png"}, {"version": "0.2.0-beta.6", "img_width": 1626, "img_height": 1200, "blocks": [], "img_path": "215.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [558, 64, 608, 247], "vertical": true, "font_size": 22, "lines_coords": [[[586.0, 65.0], [606.0, 65.0], [606.0, 164.0], [586.0, 164.0]], [[558.0, 64.0], [582.0, 64.0], [582.0, 244.0], [558.0, 244.0]]], "lines": ["東京は今日", "ちょっといい天気で、"]}, {"box": [425, 64, 475, 247], "vertical": true, "font_size": 23, "lines_coords": [[[452.0, 65.0], [475.0, 65.0], [475.0, 202.0], [452.0, 202.0]], [[425.0, 64.0], [448.0, 64.0], [448.0, 246.0], [425.0, 246.0]]], "lines": ["いつものように", "小田急線が走ってて、"]}, {"box": [272, 63, 348, 248], "vertical": true, "font_size": 22, "lines_coords": [[[326.0, 66.0], [347.0, 66.0], [347.0, 162.0], [326.0, 162.0]], [[295.0, 64.0], [324.0, 64.0], [324.0, 147.0], [295.0, 147.0]], [[274.0, 66.0], [290.0, 66.0], [290.0, 243.0], [274.0, 243.0]]], "lines": ["多摩川では", "恋人達が", "ボートをこいていた"]}, {"box": [648, 919, 697, 1079], "vertical": true, "font_size": 20, "lines_coords": [[[675.0, 919.0], [696.0, 919.0], [694.0, 1057.0], [673.0, 1057.0]], [[648.0, 921.0], [668.0, 921.0], [668.0, 1076.0], [648.0, 1076.0]]], "lines": ["今日もどこかで", "戦争をしてるとか"]}, {"box": [538, 918, 589, 1056], "vertical": true, "font_size": 24, "lines_coords": [[[565.0, 919.0], [589.0, 919.0], [589.0, 1055.0], [565.0, 1055.0]], [[538.0, 918.0], [562.0, 918.0], [562.0, 1038.0], [538.0, 1038.0]]], "lines": ["たくさんの人が", "死んでるとか"]}, {"box": [384, 916, 489, 1094], "vertical": true, "font_size": 23, "lines_coords": [[[467.0, 918.0], [488.0, 918.0], [488.0, 998.0], [467.0, 998.0]], [[440.0, 918.0], [461.0, 918.0], [460.0, 1093.0], [439.0, 1093.0]], [[406.0, 917.0], [433.0, 916.0], [436.0, 980.0], [409.0, 982.0]], [[384.0, 918.0], [405.0, 918.0], [407.0, 1044.0], [386.0, 1044.0]]], "lines": ["そんなの", "信じられないくらい", "それは", "平和な景色で、"]}, {"box": [251, 918, 328, 1075], "vertical": true, "font_size": 21, "lines_coords": [[[305.0, 919.0], [326.0, 919.0], [326.0, 1017.0], [305.0, 1017.0]], [[277.0, 918.0], [298.0, 918.0], [299.0, 1074.0], [278.0, 1074.0]], [[251.0, 919.0], [271.0, 919.0], [271.0, 1024.0], [251.0, 1024.0]]], "lines": ["この景色が", "いつまでも続けば", "いいのにな。"]}, {"box": [174, 919, 198, 1124], "vertical": true, "font_size": 20, "lines_coords": [[[175.0, 921.0], [195.0, 921.0], [195.0, 1119.0], [175.0, 1119.0]]], "lines": ["なんて考えてしまった。"]}], "img_path": "216.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [666, 84, 715, 203], "vertical": true, "font_size": 20, "lines_coords": [[[695.0, 86.0], [715.0, 86.0], [715.0, 203.0], [695.0, 203.0]], [[666.0, 84.0], [686.0, 84.0], [686.0, 164.0], [666.0, 164.0]]], "lines": ["つーか、もう", "夏だよ！！"]}, {"box": [415, 75, 493, 234], "vertical": true, "font_size": 20, "lines_coords": [[[471.0, 75.0], [493.0, 75.0], [491.0, 233.0], [470.0, 233.0]], [[445.0, 76.0], [464.0, 76.0], [464.0, 230.0], [445.0, 230.0]], [[418.0, 77.0], [437.0, 77.0], [435.0, 203.0], [415.0, 203.0]]], "lines": ["そうやって俺達は", "確実に年をとって", "いくんだあぁー"]}, {"box": [80, 180, 102, 280], "vertical": true, "font_size": 20, "lines_coords": [[[80.0, 180.0], [100.0, 180.0], [100.0, 248.0], [80.0, 248.0]]], "lines": ["うえぇ"]}, {"box": [519, 353, 596, 509], "vertical": true, "font_size": 21, "lines_coords": [[[572.0, 353.0], [596.0, 353.0], [596.0, 509.0], [572.0, 509.0]], [[546.0, 355.0], [566.0, 355.0], [566.0, 455.0], [546.0, 455.0]], [[519.0, 353.0], [539.0, 353.0], [539.0, 492.0], [519.0, 492.0]]], "lines": ["今年はちょっぴり", "勇み足だぜ、", "夏さんよぉー！！"]}, {"box": [395, 326, 444, 445], "vertical": true, "font_size": 21, "lines_coords": [[[422.0, 326.0], [443.0, 326.0], [441.0, 442.0], [420.0, 442.0]], [[395.0, 329.0], [416.0, 329.0], [416.0, 411.0], [395.0, 411.0]]], "lines": ["．．．こんなこと", "言ったら、"]}, {"box": [300, 327, 349, 473], "vertical": true, "font_size": 20, "lines_coords": [[[326.0, 329.0], [347.0, 329.0], [347.0, 407.0], [326.0, 407.0]], [[300.0, 328.0], [320.0, 328.0], [320.0, 468.0], [300.0, 468.0]]], "lines": ["あの人は", "どう思うのかな。"]}, {"box": [162, 326, 240, 473], "vertical": true, "font_size": 22, "lines_coords": [[[215.0, 326.0], [240.0, 326.0], [240.0, 407.0], [215.0, 407.0]], [[192.0, 326.0], [213.0, 326.0], [210.0, 445.0], [189.0, 445.0]], [[163.0, 326.0], [183.0, 326.0], [182.0, 468.0], [162.0, 468.0]]], "lines": ["あたしは", "ちょっとだけ", "ごめんって思う。"]}, {"box": [651, 959, 672, 1026], "vertical": true, "font_size": 21, "lines_coords": [[[651.0, 960.0], [672.0, 960.0], [672.0, 1024.0], [651.0, 1024.0]]], "lines": ["．．．でも、"]}, {"box": [458, 958, 565, 1137], "vertical": true, "font_size": 25, "lines_coords": [[[536.0, 959.0], [565.0, 959.0], [565.0, 1028.0], [536.0, 1028.0]], [[509.0, 958.0], [539.0, 958.0], [539.0, 1028.0], [509.0, 1028.0]], [[484.0, 960.0], [505.0, 960.0], [507.0, 1135.0], [486.0, 1135.0]], [[460.0, 962.0], [480.0, 962.0], [480.0, 1099.0], [460.0, 1099.0]]], "lines": ["たとえ、", "いつか、", "この景色が見れなく", "なる時が来ても"]}, {"box": [271, 959, 377, 1135], "vertical": true, "font_size": 21, "lines_coords": [[[354.0, 959.0], [375.0, 959.0], [375.0, 1060.0], [354.0, 1060.0]], [[326.0, 960.0], [347.0, 960.0], [348.0, 1134.0], [327.0, 1134.0]], [[300.0, 960.0], [322.0, 960.0], [322.0, 1059.0], [300.0, 1059.0]], [[271.0, 959.0], [292.0, 959.0], [295.0, 1068.0], [274.0, 1068.0]]], "lines": ["その時まで", "みんなといっしょに", "いられれば", "それでいい。"]}, {"box": [170, 959, 192, 1106], "vertical": true, "font_size": 16, "lines_coords": [[[172.0, 964.0], [188.0, 964.0], [188.0, 1102.0], [172.0, 1102.0]]], "lines": ["今日はそう思う。"]}], "img_path": "217.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [637, 58, 740, 215], "vertical": true, "font_size": 19, "lines_coords": [[[720.0, 58.0], [740.0, 58.0], [740.0, 215.0], [720.0, 215.0]], [[694.0, 62.0], [710.0, 62.0], [710.0, 213.0], [694.0, 213.0]], [[665.0, 59.0], [685.0, 59.0], [685.0, 158.0], [665.0, 158.0]], [[637.0, 59.0], [656.0, 59.0], [656.0, 147.0], [637.0, 147.0]]], "lines": ["：じゃあそろそろ", "加藤のボーナスの", "使い道でも", "決めるか。"]}, {"box": [526, 113, 603, 230], "vertical": true, "font_size": 21, "lines_coords": [[[577.0, 113.0], [603.0, 113.0], [603.0, 176.0], [577.0, 176.0]], [[552.0, 114.0], [573.0, 114.0], [573.0, 193.0], [552.0, 193.0]], [[528.0, 116.0], [543.0, 116.0], [543.0, 230.0], [528.0, 230.0]]], "lines": ["なんで", "オメーが", "決めんだよ！！"]}, {"box": [152, 83, 227, 278], "vertical": true, "font_size": 20, "lines_coords": [[[206.0, 84.0], [226.0, 84.0], [226.0, 221.0], [206.0, 221.0]], [[179.0, 85.0], [199.0, 85.0], [199.0, 278.0], [179.0, 278.0]], [[152.0, 83.0], [172.0, 83.0], [172.0, 210.0], [152.0, 210.0]]], "lines": ["ライブやったら", "いいんじゃないすか？", "でかいトコで。"]}, {"box": [141, 328, 188, 433], "vertical": true, "font_size": 19, "lines_coords": [[[166.0, 328.0], [187.0, 328.0], [187.0, 423.0], [166.0, 423.0]], [[141.0, 329.0], [158.0, 329.0], [158.0, 430.0], [141.0, 430.0]]], "lines": ["あーーーソレ", "いいかもね"]}, {"box": [634, 557, 736, 676], "vertical": true, "font_size": 20, "lines_coords": [[[715.0, 558.0], [736.0, 558.0], [736.0, 637.0], [715.0, 637.0]], [[689.0, 560.0], [709.0, 560.0], [709.0, 657.0], [689.0, 657.0]], [[660.0, 557.0], [680.0, 557.0], [682.0, 676.0], [662.0, 676.0]], [[634.0, 558.0], [654.0, 558.0], [654.0, 676.0], [634.0, 676.0]]], "lines": ["．．．やる？", "久々に俺の", "超絶ベースが", "火を吹くよ？"]}, {"box": [215, 608, 289, 725], "vertical": true, "font_size": 19, "lines_coords": [[[268.0, 608.0], [288.0, 608.0], [288.0, 725.0], [268.0, 725.0]], [[241.0, 609.0], [261.0, 609.0], [261.0, 707.0], [241.0, 707.0]], [[216.0, 609.0], [233.0, 609.0], [233.0, 725.0], [216.0, 725.0]]], "lines": ["だったら俺の", "鬼ドラムが", "嵐を呼ぶぜ！？"]}, {"box": [144, 788, 197, 857], "vertical": true, "font_size": 24, "lines_coords": [[[172.0, 788.0], [197.0, 788.0], [197.0, 851.0], [172.0, 851.0]], [[144.0, 788.0], [168.0, 788.0], [168.0, 857.0], [144.0, 857.0]]], "lines": ["あはは", "バーカ。"]}, {"box": [381, 987, 476, 1024], "vertical": false, "font_size": 33, "lines_coords": [[[381.0, 991.0], [475.0, 987.0], [476.0, 1020.0], [382.0, 1024.0]]], "lines": ["おゎり"]}, {"box": [330, 1122, 510, 1146], "vertical": false, "font_size": 24, "lines_coords": [[[330.0, 1122.0], [510.0, 1122.0], [510.0, 1146.0], [330.0, 1146.0]]], "lines": ["一ソラニン・完一"]}], "img_path": "218.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [173, 745, 331, 769], "vertical": false, "font_size": 24, "lines_coords": [[[173.0, 745.0], [331.0, 745.0], [331.0, 769.0], [173.0, 769.0]]], "lines": ["作画アンスタントラブ"]}, {"box": [326, 767, 351, 861], "vertical": true, "font_size": 25, "lines_coords": [[[326.0, 767.0], [351.0, 767.0], [351.0, 861.0], [326.0, 861.0]]], "lines": ["近山"]}, {"box": [292, 676, 590, 1007], "vertical": false, "font_size": 91.6, "lines_coords": [[[293.0, 676.0], [440.0, 680.0], [439.0, 723.0], [292.0, 718.0]], [[296.0, 723.0], [437.0, 717.0], [445.0, 884.0], [303.0, 890.0]], [[323.0, 767.0], [378.0, 757.0], [398.0, 863.0], [344.0, 874.0]], [[313.0, 885.0], [590.0, 885.0], [590.0, 1001.0], [313.0, 1001.0]], [[366.0, 983.0], [531.0, 978.0], [531.0, 1003.0], [366.0, 1007.0]]], "lines": ["浅野いにお", "おいお姉ちゃんは大丈夫だよねえね", "私達は現在は２００", "いや、それはどうだったんだけど．．．お兄ちゃんに対応してくれるんじゃない", "岩田君、純一君、のんさんベッキー、チャーリー"]}, {"box": [183, 902, 288, 929], "vertical": false, "font_size": 24, "lines_coords": [[[183.0, 904.0], [288.0, 902.0], [288.0, 926.0], [183.0, 929.0]]], "lines": ["スペシャルサンクス"]}, {"box": [356, 903, 616, 936], "vertical": false, "font_size": 28, "lines_coords": [[[356.0, 908.0], [616.0, 903.0], [616.0, 931.0], [356.0, 936.0]]], "lines": ["まっと、ジケル・サ上未来、みさし"]}], "img_path": "219.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [140, 82, 323, 114], "vertical": false, "font_size": 32, "lines_coords": [[[140.0, 82.0], [323.0, 82.0], [323.0, 114.0], [140.0, 114.0]]], "lines": ["ソラニン図"]}, {"box": [128, 164, 386, 187], "vertical": false, "font_size": 23, "lines_coords": [[[128.0, 164.0], [386.0, 164.0], [386.0, 187.0], [128.0, 187.0]]], "lines": ["ヤングサンデーコミックス"]}, {"box": [193, 490, 500, 540], "vertical": false, "font_size": 20, "lines_coords": [[[193.0, 493.0], [495.0, 493.0], [495.0, 513.0], [193.0, 513.0]], [[195.0, 519.0], [341.0, 519.0], [341.0, 535.0], [195.0, 535.0]], [[339.0, 515.0], [497.0, 515.0], [497.0, 539.0], [339.0, 539.0]]], "lines": ["２００６年６月５日初版第１制発行", "２００６年１１月１０日", "．．．第４刷発行"]}, {"box": [481, 446, 754, 466], "vertical": false, "font_size": 20, "lines_coords": [[[481.0, 446.0], [754.0, 446.0], [754.0, 466.0], [481.0, 466.0]]], "lines": ["ＩＳＢＮ４－Ｏ９－１５１０７６－０"]}, {"box": [675, 494, 753, 510], "vertical": false, "font_size": 16, "lines_coords": [[[675.0, 494.0], [753.0, 494.0], [753.0, 510.0], [675.0, 510.0]]], "lines": ["（検印廃止）"]}, {"box": [192, 595, 257, 622], "vertical": false, "font_size": 24.5, "lines_coords": [[[192.0, 597.0], [215.0, 597.0], [215.0, 619.0], [192.0, 619.0]], [[230.0, 595.0], [257.0, 595.0], [257.0, 622.0], [230.0, 622.0]]], "lines": ["著", "者"]}, {"box": [188, 670, 258, 699], "vertical": false, "font_size": 29, "lines_coords": [[[188.0, 670.0], [258.0, 670.0], [258.0, 699.0], [188.0, 699.0]]], "lines": ["発行者"]}, {"box": [192, 712, 256, 733], "vertical": false, "font_size": 21, "lines_coords": [[[192.0, 712.0], [256.0, 712.0], [256.0, 733.0], [192.0, 733.0]]], "lines": ["印刷所"]}, {"box": [367, 583, 603, 691], "vertical": false, "font_size": 57.0, "lines_coords": [[[384.0, 594.0], [565.0, 594.0], [565.0, 626.0], [384.0, 626.0]], [[367.0, 610.0], [593.0, 583.0], [603.0, 664.0], [377.0, 691.0]]], "lines": ["浅野いにお手伝いの", "浅野いにおＣｈｉｏ．ｄａｍ。２０１６年、原"]}, {"box": [387, 671, 582, 733], "vertical": false, "font_size": 21.0, "lines_coords": [[[389.0, 671.0], [414.0, 671.0], [414.0, 692.0], [389.0, 692.0]], [[413.0, 672.0], [462.0, 672.0], [462.0, 694.0], [413.0, 694.0]], [[387.0, 713.0], [582.0, 713.0], [582.0, 733.0], [387.0, 733.0]]], "lines": ["笹", "原．．．", "大田本印刷株式会社"]}, {"box": [137, 771, 720, 787], "vertical": false, "font_size": 16, "lines_coords": [[[137.0, 771.0], [720.0, 771.0], [720.0, 787.0], [137.0, 787.0]]], "lines": ["「週刊ヤングサンデー」２００５年第１８号、２０１６年第２号〜第４５合併号、"]}, {"box": [125, 823, 623, 897], "vertical": false, "font_size": 22.0, "lines_coords": [[[125.0, 823.0], [305.0, 823.0], [305.0, 843.0], [125.0, 843.0]], [[126.0, 847.0], [367.0, 847.0], [367.0, 870.0], [126.0, 870.0]], [[125.0, 874.0], [623.0, 874.0], [623.0, 897.0], [125.0, 897.0]]], "lines": ["連載担当ノ荻野克展", "単行本編集責任ノ安達健給", "単行本編集ノ鉄野克展ノこの〈立川久美子（アイブログクション）"]}, {"box": [537, 673, 563, 693], "vertical": false, "font_size": 20, "lines_coords": [[[537.0, 673.0], [563.0, 673.0], [563.0, 693.0], [537.0, 693.0]]], "lines": ["博"]}, {"box": [338, 795, 709, 815], "vertical": false, "font_size": 20, "lines_coords": [[[338.0, 795.0], [709.0, 795.0], [709.0, 815.0], [338.0, 815.0]]], "lines": ["第８号一第１９号、第１６号一第１９号掲載作品"]}, {"box": [630, 735, 757, 754], "vertical": false, "font_size": 16, "lines_coords": [[[630.0, 735.0], [757.0, 738.0], [757.0, 754.0], [630.0, 752.0]]], "lines": ["ＰｒｉｎｔｅｄｉｎＪａｐａｎ"]}, {"box": [125, 926, 223, 959], "vertical": false, "font_size": 33, "lines_coords": [[[125.0, 926.0], [223.0, 926.0], [223.0, 959.0], [125.0, 959.0]]], "lines": ["発行所"]}, {"box": [265, 915, 724, 996], "vertical": false, "font_size": 43.5, "lines_coords": [[[265.0, 916.0], [592.0, 915.0], [592.0, 930.0], [265.0, 931.0]], [[381.0, 921.0], [724.0, 923.0], [724.0, 996.0], [381.0, 993.0]]], "lines": ["（〒１０１，８００１）東京都千代田区一ツ橋二の三の一姫様。Ｇｏｏｇｌｅｓ", "実際に代目を一度一切三つ一口の場所ではないのですが、数十万円以上の安全に対しております。"]}, {"box": [125, 986, 755, 1159], "vertical": false, "font_size": 16, "lines_coords": [[[126.0, 997.0], [753.0, 997.0], [753.0, 1013.0], [126.0, 1013.0]], [[125.0, 1016.0], [755.0, 1016.0], [755.0, 1032.0], [125.0, 1032.0]], [[129.0, 1038.0], [231.0, 1038.0], [231.0, 1050.0], [129.0, 1050.0]], [[125.0, 1054.0], [750.0, 1055.0], [750.0, 1072.0], [125.0, 1071.0]], [[126.0, 1075.0], [665.0, 1076.0], [665.0, 1092.0], [126.0, 1091.0]], [[126.0, 1096.0], [336.0, 1096.0], [336.0, 1112.0], [126.0, 1112.0]], [[126.0, 1116.0], [745.0, 1116.0], [745.0, 1132.0], [126.0, 1132.0]], [[126.0, 1136.0], [654.0, 1136.0], [654.0, 1151.0], [126.0, 1151.0]], [[572.0, 1035.0], [751.0, 1035.0], [751.0, 1051.0], [572.0, 1051.0]]], "lines": ["●遺本には十分注意しておりますが、落丁・乱丁（本のページの抜け落ちや順序の間違いの場合はお取り", "杏えいたします。購入された書店名を明記して「制作局」あでにお送りください。送料小社負担にてお取", "リ替えいたじゃあ", "●本書の一部あるい今は全部を無断で複製転載・上演・放送等をすることは、法律で認められた場合を除き", "著作者および出版者の権利の役割となります。あらかじめ小社あて許諾をお求めください。", "Ｒ［：日本複写権センター委託出版物", "本書の一部または全部を無制で複写（コピー＞＞することは、著作権法上での例外を除き禁じられています。", "複写を希望される場合は、日本被写権センター（ＴＥＢ）０３．３４０Ｌ－２３８２）にご連絡ください。", "制作局（ＴＥＬ０１２０．３３６－０８２"]}], "img_path": "220.png"}]}