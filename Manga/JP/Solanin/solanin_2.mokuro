{"version": "0.2.0-beta.6", "title": "Solanin", "title_uuid": "633566b0-bcd9-40c9-a837-f5672af937d5", "volume": "solanin_2", "volume_uuid": "433a9a24-5780-4bf5-825f-6666c7955bd0", "pages": [{"version": "0.2.0-beta.6", "img_width": 2900, "img_height": 1200, "blocks": [{"box": [1403, 24, 1486, 82], "vertical": false, "font_size": 34, "lines_coords": [[[1407.0, 36.0], [1481.0, 36.0], [1481.0, 73.0], [1407.0, 73.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹＣＯＭＩＣＳ"]}, {"box": [856, 995, 1079, 1043], "vertical": false, "font_size": 29, "lines_coords": [[[863.0, 1004.0], [1070.0, 1004.0], [1070.0, 1033.0], [863.0, 1033.0]]], "lines": ["洋服してお"]}, {"box": [1419, 900, 1474, 1135], "vertical": true, "font_size": 31, "lines_coords": [[[1433.0, 911.0], [1464.0, 911.0], [1464.0, 1120.0], [1433.0, 1120.0]]], "lines": ["浅野、こお"]}, {"box": [1570, 131, 1782, 163], "vertical": false, "font_size": 35, "lines_coords": [[[1570.0, 128.0], [1782.0, 128.0], [1782.0, 166.0], [1570.0, 166.0]]], "lines": ["９７．１１月２０日（土）、９７８４０９１５１０７６１"]}, {"box": [1573, 277, 1793, 308], "vertical": false, "font_size": 34, "lines_coords": [[[1573.0, 274.0], [1793.0, 274.0], [1793.0, 311.0], [1573.0, 311.0]]], "lines": ["１９２９９９７９年９月１９日"]}, {"box": [1857, 56, 2115, 138], "vertical": false, "font_size": 29, "lines_coords": [[[1857.0, 59.0], [2115.0, 56.0], [2115.0, 87.0], [1857.0, 90.0]], [[1860.0, 118.0], [2019.0, 118.0], [2019.0, 138.0], [1860.0, 138.0]]], "lines": ["ＩＳＢＮ４－０９－１５１０７６－０", "この９７９４５０５に"]}, {"box": [1857, 203, 2121, 285], "vertical": false, "font_size": 29, "lines_coords": [[[1857.0, 203.0], [2121.0, 203.0], [2121.0, 240.0], [1857.0, 240.0]], [[1860.0, 257.0], [2107.0, 257.0], [2107.0, 285.0], [1860.0, 285.0]]], "lines": ["定価：「本体，５０５円十税", "雑誌，４５３６０－７６小学館"]}, {"box": [2511, 124, 2774, 288], "vertical": false, "font_size": 31, "lines_coords": [[[2517.0, 122.0], [2758.0, 125.0], [2758.0, 149.0], [2517.0, 146.0]], [[2574.0, 153.0], [2707.0, 153.0], [2707.0, 177.0], [2574.0, 177.0]], [[2562.0, 187.0], [2721.0, 187.0], [2721.0, 219.0], [2562.0, 219.0]], [[2526.0, 215.0], [2755.0, 215.0], [2755.0, 239.0], [2526.0, 239.0]], [[2514.0, 227.0], [2764.0, 227.0], [2764.0, 290.0], [2514.0, 290.0]]], "lines": ["「Ｗｉｎｄｏｗｓ４」の", "浅野Ｎにお", "１９５０年生まれ、大阪県出身、金曜日はシェートで", "２０１８年１１月２０日、第１１サンデーの新人賞人賞、第３回サービスの", "２０１６年第回サンテービスですが、当然事件に関するのは「専門」のかりがちょっという仕事がある。"]}, {"box": [1859, 418, 2301, 622], "vertical": false, "font_size": 224, "lines_coords": [[[1859.0, 398.0], [2301.0, 398.0], [2301.0, 642.0], [1859.0, 642.0]]], "lines": ["そういうことで、これから一番あっていたのですが、"]}, {"box": [2473, 806, 2531, 1025], "vertical": true, "font_size": 31, "lines_coords": [[[2489.0, 806.0], [2520.0, 806.0], [2520.0, 990.0], [2489.0, 990.0]]], "lines": ["．．．"]}], "img_path": "001.png"}, {"version": "0.2.0-beta.6", "img_width": 1785, "img_height": 1200, "blocks": [{"box": [869, 884, 919, 1143], "vertical": true, "font_size": 49, "lines_coords": [[[869.0, 884.0], [918.0, 884.0], [918.0, 1098.0], [869.0, 1098.0]]], "lines": ["浅野いにお"]}, {"box": [846, 29, 936, 86], "vertical": false, "font_size": 62, "lines_coords": [[[846.0, 24.0], [936.0, 24.0], [936.0, 91.0], [846.0, 91.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹＣＯＭｉｃａ"]}, {"box": [846, 28, 935, 88], "vertical": false, "font_size": 22, "lines_coords": [[[864.0, 29.0], [923.0, 29.0], [923.0, 47.0], [864.0, 47.0]], [[861.0, 45.0], [929.0, 45.0], [929.0, 69.0], [861.0, 69.0]], [[850.0, 64.0], [930.0, 64.0], [930.0, 88.0], [850.0, 88.0]]], "lines": ["．．．", "ＵＮＤＡＹ", "ｃｏｍｌｃｓ"]}, {"box": [495, 52, 631, 73], "vertical": false, "font_size": 18, "lines_coords": [[[495.0, 52.0], [631.0, 55.0], [631.0, 73.0], [495.0, 69.0]]], "lines": ["ｃｏｍｉｃｓ"]}, {"box": [310, 1004, 528, 1050], "vertical": false, "font_size": 42, "lines_coords": [[[310.0, 1006.0], [528.0, 1006.0], [528.0, 1048.0], [310.0, 1048.0]]], "lines": ["浅野いにお"]}], "img_path": "002.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [300, 951, 527, 994], "vertical": false, "font_size": 41, "lines_coords": [[[302.0, 951.0], [