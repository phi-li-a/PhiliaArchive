.0, 720.0]]], "lines": ["なーていたらなお？"]}, {"box": [614, 848, 661, 864], "vertical": false, "font_size": 16, "lines_coords": [[[614.0, 848.0], [661.0, 848.0], [661.0, 864.0], [614.0, 864.0]]], "lines": ["おなじ"]}, {"box": [655, 891, 731, 1010], "vertical": true, "font_size": 20, "lines_coords": [[[709.0, 892.0], [729.0, 892.0], [731.0, 977.0], [712.0, 977.0]], [[682.0, 891.0], [702.0, 891.0], [705.0, 1010.0], [685.0, 1010.0]], [[659.0, 891.0], [679.0, 892.0], [675.0, 980.0], [655.0, 979.0]]], "lines": ["なーんだ、", "あたしと同じ", "じゃーん。"]}, {"box": [348, 863, 454, 1020], "vertical": true, "font_size": 20, "lines_coords": [[[434.0, 866.0], [450.0, 866.0], [450.0, 1018.0], [434.0, 1018.0]], [[405.0, 866.0], [425.0, 866.0], [425.0, 1000.0], [405.0, 1000.0]], [[375.0, 863.0], [397.0, 863.0], [398.0, 982.0], [377.0, 982.0]], [[348.0, 863.0], [370.0, 863.0], [372.0, 990.0], [351.0, 990.0]]], "lines": ["今になってみると", "夏の暑さなんて", "まるで忘れて", "しまっていて、"]}, {"box": [74, 971, 175, 1108], "vertical": true, "font_size": 20, "lines_coords": [[[154.0, 973.0], [174.0, 973.0], [174.0, 1108.0], [154.0, 1108.0]], [[127.0, 972.0], [147.0, 972.0], [147.0, 1089.0], [127.0, 1089.0]], [[97.0, 971.0], [120.0, 971.0], [120.0, 1091.0], [97.0, 1091.0]], [[74.0, 973.0], [91.0, 973.0], [91.0, 1096.0], [74.0, 1096.0]]], "lines": ["今年もこうして", "あたりまえの", "ように、冬に", "なるんだなぁ。"]}], "img_path": "105.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [125, 64, 304, 130], "vertical": false, "font_size": 41, "lines_coords": [[[125.0, 90.0], [298.0, 64.0], [304.0, 105.0], [131.0, 130.0]]], "lines": ["ジＳｅｐｔｅｍｂｅｔ"]}, {"box": [149, 139, 281, 180], "vertical": false, "font_size": 28, "lines_coords": [[[149.0, 152.0], [277.0, 139.0], [281.0, 167.0], [153.0, 180.0]]], "lines": ["ｌｒｈｕｒｓｄａｙ"]}, {"box": [324, 172, 427, 220], "vertical": false, "font_size": 29, "lines_coords": [[[324.0, 192.0], [420.0, 172.0], [427.0, 200.0], [331.0, 220.0]]], "lines": ["気がした。"]}, {"box": [419, 114, 558, 166], "verti