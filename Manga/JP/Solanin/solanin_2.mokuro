e, "font_size": 20, "lines_coords": [[[627.0, 628.0], [644.0, 628.0], [644.0, 706.0], [627.0, 706.0]]], "lines": ["どうよ？"]}, {"box": [654, 785, 730, 921], "vertical": true, "font_size": 21, "lines_coords": [[[706.0, 786.0], [730.0, 786.0], [730.0, 868.0], [706.0, 868.0]], [[681.0, 785.0], [702.0, 785.0], [700.0, 921.0], [679.0, 921.0]], [[655.0, 788.0], [672.0, 788.0], [672.0, 884.0], [655.0, 884.0]]], "lines": ["いや～～～", "さすがにそりゃ", "無理だろ．．．"]}, {"box": [144, 646, 167, 738], "vertical": true, "font_size": 21, "lines_coords": [[[144.0, 646.0], [165.0, 646.0], [165.0, 738.0], [144.0, 738.0]]], "lines": ["１か月！？"]}, {"box": [377, 994, 429, 1075], "vertical": true, "font_size": 24, "lines_coords": [[[404.0, 994.0], [429.0, 994.0], [429.0, 1064.0], [404.0, 1064.0]], [[377.0, 994.0], [401.0, 994.0], [401.0, 1075.0], [377.0, 1075.0]]], "lines": ["．．．なぁ、", "芽衣子？"]}], "img_path": "114.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [639, 129, 661, 198], "vertical": true, "font_size": 22, "lines_coords": [[[639.0, 153.0], [661.0, 153.0], [661.0, 198.0], [639.0, 198.0]]], "lines": ["．．．や、"]}, {"box": [166, 109, 210, 226], "vertical": true, "font_size": 22, "lines_coords": [[[188.0, 110.0], [210.0, 110.0], [210.0, 226.0], [188.0, 226.0]]], "lines": ["やってみたい"]}, {"box": [460, 833, 480, 929], "vertical": true, "font_size": 20, "lines_coords": [[[460.0, 833.0], [480.0, 833.0], [480.0, 929.0], [460.0, 929.0]]], "lines": ["ソラニンを"]}, {"box": [368, 910, 388, 1038], "vertical": true, "font_size": 20, "lines_coords": [[[368.0, 910.0], [388.0, 910.0], [388.0, 1038.0], [368.0, 1038.0]]], "lines": ["歌ってみたい。"]}], "img_path": "115.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [727, 106, 749, 146], "vertical": true, "font_size": 23, "lines_coords": [[[727.0, 106.0], [749.0, 106.0], [749.0, 146.0], [727.0, 146.0]]], "lines": ["．．と、"]}, {"box": [671, 79, 722, 219], "vertical": true, "font_size": 23, "lines_coords": [[[699.0, 80.0], [722.0, 80.0], [722.0, 219.0], [699.0, 219.0]], [[671.0, 79.0], [695.0, 79.0], [695.0, 147.0], [671.0, 147.0]]], "lines": ["言ってしまった", "ものの、"]}, {"box": [179, 176, 281, 332], "vertical": true, "font_size": 19, "lines_coords": [[[261.0, 176.0], [281.0, 176.0], [281.0, 314.0], [261.0, 314.0]], [[233.0, 176.0], [252.0, 176.0], [252.0, 332.0], [233.0, 332.0]], [[206.0, 178.0], [226.0, 178.0], [226.0, 315.0], [206.0, 315.0]], [[179.0, 176.0], [195.0, 176.0], [195.0, 261.0], [179.0, 261.0]]], "lines": ["こんな初心者の", "あたしに、ライブ", "なんてできるん", "だろうか"]}, {"box": [603, 571, 712, 778], "vertical": true, "font_size": 25, "lines_coords": [[[687.0, 574.0], [708.0, 574.0], [709.0, 712.0], [688.0, 712.0]], [[656.0, 573.0], [681.0, 573.0], [685.0, 778.0], [660.0, 778.0]], [[628.0, 571.0], [653.0, 571.0], [658.0, 752.0], [633.0, 752.0]], [[603.0, 573.0], [632.0, 573.0], [632.0, 646.0], [603.0, 646.0]]], "lines": ["もともと人前に", "出るタイプじゃないし、", "まじでステージの上", "なんて、"]}, {"box": [122, 574, 201, 734], "vertical": true, "font_size": 24, "lines_coords": [[[173.0, 574.0], [197.0, 574.0], [201.0, 696.0], [176.0, 696.0]], [[146.0, 575.0], [170.0, 575.0], [173.0, 733.0], [148.0, 733.0]], [[122.0, 577.0], [144.0, 577.0], [144.0, 665.0], [122.0, 665.0]]], "lines": ["．．．半年前には", "考えもしなかった", "コトだな。"]}, {"box": [683, 912, 714, 973], "vertical": true, "font_size": 31, "lines_coords": [[[683.0, 912.0], [714.0, 912.0], [714.0, 973.0], [683.0, 973.0]]], "lines": ["うわ。"]}, {"box": [103, 1014, 195, 1122], "vertical": true, "font_size": 27, "lines_coords": [[[162.0, 1016.0], [195.0, 1016.0], [195.0, 1069.0], [162.0, 1069.0]], [[134.0, 1014.0], [162.0, 1014.0], [160.0, 1114.0], [132.0, 1114.0]], [[103.0, 1019.0], [124.0, 1019.0], [124.0, 1122.0], [103.0, 1122.0]]], "lines": ["もう", "ドキドキ", "してきた。"]}], "img_path": "116.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [406, 614, 431, 760], "vertical": true, "font_size": 24, "lines_coords": [[[406.0, 615.0], [430.0, 615.0], [430.0, 719.0], [406.0, 719.0]]], "lines": ["きゃ〜〜〜"]}, {"box": [208, 901, 285, 998], "vertical": true, "font_size": 20, "lines_coords": [[[263.0, 903.0], [283.0, 903.0], [283.0, 984.0], [263.0, 984.0]], [[235.0, 903.0], [255.0, 903.0], [255.0, 998.0], [235.0, 998.0]], [[208.0, 901.0], [229.0, 901.0], [229.0, 945.0], [208.0, 945.0]], [[209.0, 937.0], [227.0, 937.0], [227.0, 987.0], [209.0, 987.0]]], "lines": ["井上さん、", "お届けもの", "てー", "す"]}], "img_path": "117.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [567, 65, 591, 180], "vertical": true, "font_size": 19, "lines_coords": [[[567.0, 65.0], [591.0, 65.0], [591.0, 106.0], [567.0, 106.0]], [[567.0, 107.0], [589.0, 107.0], [589.0, 180.0], [567.0, 180.0]]], "lines": ["ぬー", "ーん．．．"]}, {"box": [463, 123, 508, 220], "vertical": true, "font_size": 19, "lines_coords": [[[488.0, 123.0], [508.0, 123.0], [508.0, 220.0], [488.0, 220.0]], [[463.0, 123.0], [480.0, 123.0], [480.0, 219.0], [463.0, 219.0]]], "lines": ["また腐らせ", "ちゃうよー"]}, {"box": [464, 221, 477, 257], "vertical": true, "font_size": 19, "lines_coords": [[[464.0, 221.0], [477.0, 221.0], [477.0, 257.0], [464.0, 257.0]]], "lines": ["．．．"]}, {"box": [418, 337, 504, 480], "vertical": false, "font_size": 15, "lines_coords": [[[445.0, 418.0], [474.0, 473.0], [460.0, 480.0], [432.0, 425.0]], [[437.0, 351.0], [491.0, 439.0], [478.0, 447.0], [425.0, 359.0]], [[457.0, 341.0], [504.0, 428.0], [491.0, 435.0], [445.0, 348.0]]], "lines": ["けれど", "その．．．だから", "わかったかんな"]}, {"box": [131, 223, 151, 473], "vertical": true, "font_size": 19, "lines_coords": [[[135.0, 438.0], [148.0, 438.0], [148.0, 473.0], [135.0, 473.0]], [[133.0, 223.0], [151.0, 223.0], [148.0, 319.0], [131.0, 319.0]]], "lines": ["――？", "お母さん．．．"]}, {"box": [133, 355, 234, 495], "vertical": true, "font_size": 19, "lines_coords": [[[214.0, 357.0], [234.0, 357.0], [234.0, 493.0], [214.0, 493.0]], [[186.0, 358.0], [208.0, 358.0], [208.0, 474.0], [186.0, 474.0]], [[158.0, 355.0], [181.0, 355.0], [179.0, 495.0], [155.0, 495.0]], [[133.0, 357.0], [153.0, 357.0], [153.0, 432.0], [133.0, 432.0]]], "lines": ["コレ、ひとりで", "食べきれない", "くらい、わかる", "でしょー"]}, {"box": [699, 605, 716, 644], "vertical": true, "font_size": 19, "lines_coords": [[[699.0, 605.0], [716.0, 605.0], [716.0, 644.0], [699.0, 644.0]]], "lines": ["あ"]}, {"box": [668, 561, 693, 660], "vertical": true, "font_size": 19, "lines_coords": [[[672.0, 561.0], [693.0, 561.0], [689.0, 660.0], [668.0, 660.0]]], "lines": ["そっか．．．"]}, {"box": [114, 698, 189, 835], "vertical": true, "font_size": 20, "lines_coords": [[[167.0, 698.0], [187.0, 698.0], [187.0, 814.0], [167.0, 814.0]], [[141.0, 699.0], [161.0, 699.0], [161.0, 796.0], [141.0, 796.0]], [[114.0, 699.0], [134.0, 699.0], [134.0, 835.0], [114.0, 835.0]]], "lines": ["お母さんには", "まだ言って", "ないんだっけ．．"]}], "img_path": "118.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [611, 106, 688, 228], "vertical": true, "font_size": 22, "lines_coords": [[[665.0, 110.0], [688.0, 110.0], [688.0, 228.0], [665.0, 228.0]], [[640.0, 108.0], [660.0, 108.0], [660.0, 208.0], [640.0, 208.0]], [[611.0, 106.0], [638.0, 106.0], [638.0, 147.0], [611.0, 147.0]]], "lines": ["つーか、随分", "急な話です", "ねー"]}, {"box": [531, 167, 606, 324], "vertical": true, "font_size": 22, "lines_coords": [[[586.0, 167.0], [606.0, 167.0], [606.0, 247.0], [586.0, 247.0]], [[560.0, 167.0], [580.0, 167.0], [580.0, 324.0], [560.0, 324.0]], [[532.0, 168.0], [552.0, 168.0], [551.0, 304.0], [531.0, 304.0]]], "lines": ["いきなり", "ギターボーカルで", "ライブですか？"]}, {"box": [348, 105, 423, 264], "vertical": true, "font_size": 19, "lines_coords": [[[404.0, 105.0], [423.0, 105.0], [423.0, 203.0], [404.0, 203.0]], [[375.0, 105.0], [395.0, 105.0], [395.0, 221.0], [375.0, 221.0]], [[348.0, 105.0], [368.0, 105.0], [368.0, 264.0], [348.0, 264.0]]], "lines": ["俺、その日", "大学の課題の", "中間発表ですけど、"]}, {"box": [252, 155, 296, 309], "vertical": true, "font_size": 19, "lines_coords": [[[279.0, 155.0], [296.0, 155.0], [296.0, 309.0], [279.0, 309.0]], [[252.0, 157.0], [269.0, 157.0], [269.0, 301.0], [252.0, 301.0]]], "lines": ["単位落としてでも", "観に行きますよ。"]}, {"box": [70, 49, 173, 65], "vertical": false, "font_size": 16, "lines_coords": [[[70.0, 49.0], [173.0, 49.0], [173.0, 65.0], [70.0, 65.0]]], "lines": ["ソラニンに"]}, {"box": [63, 408, 166, 548], "vertical": true, "font_size": 22, "lines_coords": [[[142.0, 410.0], [166.0, 410.0], [166.0, 547.0], [142.0, 547.0]], [[115.0, 408.0], [139.0, 408.0], [135.0, 548.0], [112.0, 548.0]], [[90.0, 411.0], [110.0, 411.0], [110.0, 547.0], [90.0, 547.0]], [[63.0, 408.0], [83.0, 408.0], [83.0, 498.0], [63.0, 498.0]]], "lines": ["いやー、だから", "大橋君にギター", "教えてもらおう", "と思って。"]}, {"box": [649, 580, 722, 718], "vertical": true, "font_size": 19, "lines_coords": [[[702.0, 580.0], [722.0, 580.0], [720.0, 718.0], [700.0, 718.0]], [[674.0, 581.0], [694.0, 581.0], [694.0, 697.0], [674.0, 697.0]], [[649.0, 582.0], [666.0, 582.0], [666.0, 659.0], [649.0, 659.0]]], "lines": ["俺だってそんな", "うまくはない", "けど．．．"]}, {"box": [93, 612, 214, 847], "vertical": true, "font_size": 21, "lines_coords": [[[190.0, 612.0], [211.0, 612.0], [211.0, 693.0], [190.0, 693.0]], [[172.0, 707.0], [196.0, 707.0], [196.0, 791.0], [172.0, 791.0]], [[146.0, 708.0], [167.0, 708.0], [168.0, 847.0], [147.0, 847.0]], [[120.0, 710.0], [140.0, 710.0], [140.0, 828.0], [120.0, 828.0]], [[93.0, 710.0], [113.0, 710.0], [113.0, 815.0], [93.0, 815.0]]], "lines": ["．．．やっぱ、", "ギターは", "カッコよく弾く", "のが一番だと", "思いますよ。"]}, {"box": [637, 869, 712, 1045], "vertical": true, "font_size": 20, "lines_coords": [[[689.0, 869.0], [709.0, 869.0], [712.0, 1012.0], [692.0, 1012.0]], [[664.0, 869.0], [683.0, 869.0], [683.0, 1007.0], [664.0, 1007.0]], [[637.0, 870.0], [656.0, 870.0], [656.0, 1045.0], [637.0, 1045.0]]], "lines": ["たとえ下手でも、", "まして音楽理論", "なんて知らなくても"]}, {"box": [494, 930, 600, 1115], "vertical": true, "font_size": 20, "lines_coords": [[[578.0, 930.0], [598.0, 930.0], [600.0, 1050.0], [580.0, 1050.0]], [[549.0, 931.0], [570.0, 931.0], [572.0, 1031.0], [551.0, 1031.0]], [[525.0, 932.0], [545.0, 932.0], [545.0, 1115.0], [525.0, 1115.0]], [[496.0, 930.0], [519.0, 930.0], [517.0, 1079.0], [494.0, 1079.0]]], "lines": ["きれいな音も", "歪んだ音も", "凄い音が出るんです、", "ギターってのは。"]}, {"box": [214, 936, 263, 1040], "vertical": true, "font_size": 21, "lines_coords": [[[238.0, 936.0], [263.0, 936.0], [263.0, 999.0], [238.0, 999.0]], [[214.0, 937.0], [234.0, 937.0], [234.0, 1040.0], [214.0, 1040.0]]], "lines": ["あとは", "その人次第。"]}, {"box": [81, 992, 182, 1129], "vertical": true, "font_size": 21, "lines_coords": [[[162.0, 992.0], [182.0, 992.0], [182.0, 1129.0], [162.0, 1129.0]], [[135.0, 993.0], [155.0, 993.0], [155.0, 1093.0], [135.0, 1093.0]], [[108.0, 993.0], [128.0, 993.0], [128.0, 1110.0], [108.0, 1110.0]], [[81.0, 994.0], [101.0, 994.0], [101.0, 1100.0], [81.0, 1100.0]]], "lines": ["あとは思いきり", "気持ちよく", "弾いちゃえば", "いいんです。"]}], "img_path": "119.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [671, 73, 767, 227], "vertical": true, "font_size": 20, "lines_coords": [[[750.0, 73.0], [767.0, 73.0], [767.0, 227.0], [750.0, 227.0]], [[722.0, 73.0], [742.0, 73.0], [742.0, 192.0], [722.0, 192.0]], [[695.0, 75.0], [715.0, 75.0], [715.0, 191.0], [695.0, 191.0]], [[671.0, 75.0], [687.0, 75.0], [687.0, 178.0], [671.0, 178.0]]], "lines": ["弾く人の気持ちを", "弦とコイルと", "アンプで増幅", "させる楽器。"]}, {"box": [599, 225, 674, 344], "vertical": true, "font_size": 20, "lines_coords": [[[654.0, 225.0], [674.0, 225.0], [672.0, 344.0], [652.0, 344.0]], [[625.0, 227.0], [649.0, 227.0], [649.0, 290.0], [625.0, 290.0]], [[599.0, 226.0], [619.0, 226.0], [619.0, 316.0], [599.0, 316.0]]], "lines": ["．．．ってなんか", "大袈裟", "ですけど。"]}, {"box": [126, 130, 229, 246], "vertical": true, "font_size": 21, "lines_coords": [[[206.0, 130.0], [228.0, 130.0], [226.0, 208.0], [203.0, 208.0]], [[180.0, 130.0], [200.0, 130.0], [200.0, 246.0], [180.0, 246.0]], [[152.0, 131.0], [172.0, 131.0], [172.0, 209.0], [152.0, 209.0]], [[126.0, 130.0], [146.0, 130.0], [146.0, 216.0], [126.0, 216.0]]], "lines": ["ギターの", "そういうトコ", "俺は好き", "なんです。"]}, {"box": [707, 738, 783, 864], "vertical": true, "font_size": 21, "lines_coords": [[[758.0, 738.0], [783.0, 738.0], [783.0, 819.0], [758.0, 819.0]], [[733.0, 739.0], [754.0, 739.0], [754.0, 843.0], [733.0, 843.0]], [[708.0, 739.0], [726.0, 739.0], [724.0, 860.0], [707.0, 860.0]]], "lines": ["さーすが", "ギター少年、", "語るじゃーん。"]}, {"box": [448, 724, 467, 821], "vertical": true, "font_size": 16, "lines_coords": [[[448.0, 724.0], [464.0, 724.0], [464.0, 820.0], [448.0, 820.0]]], "lines": ["とにかく！！"]}, {"box": [94, 732, 197, 870], "vertical": true, "font_size": 20, "lines_coords": [[[176.0, 732.0], [196.0, 732.0], [194.0, 870.0], [174.0, 870.0]], [[149.0, 732.0], [169.0, 732.0], [167.0, 870.0], [147.0, 870.0]], [[121.0, 733.0], [141.0, 733.0], [141.0, 850.0], [121.0, 850.0]], [[94.0, 733.0], [115.0, 733.0], [115.0, 793.0], [94.0, 793.0]]], "lines": ["ギター好きなら", "誰だってギター", "弾いていいん", "です！！"]}, {"box": [495, 878, 590, 1094], "vertical": true, "font_size": 24, "lines_coords": [[[565.0, 878.0], [590.0, 878.0], [590.0, 942.0], [565.0, 942.0]], [[550.0, 952.0], [573.0, 952.0], [571.0, 1094.0], [548.0, 1094.0]], [[519.0, 953.0], [549.0, 953.0], [549.0, 1021.0], [519.0, 1021.0]], [[497.0, 956.0], [517.0, 956.0], [515.0, 1092.0], [495.0, 1092.0]]], "lines": ["えっ！？", "語ってました？", "すげー", "はずかしい．．．"]}, {"box": [420, 959, 440, 1061], "vertical": true, "font_size": 21, "lines_coords": [[[420.0, 959.0], [440.0, 959.0], [440.0, 1061.0], [420.0, 1061.0]]], "lines": ["．．．ところで、"]}, {"box": [324, 993, 399, 1114], "vertical": true, "font_size": 21, "lines_coords": [[[378.0, 994.0], [399.0, 994.0], [399.0, 1082.0], [378.0, 1082.0]], [[351.0, 993.0], [374.0, 993.0], [374.0, 1114.0], [351.0, 1114.0]], [[324.0, 996.0], [344.0, 996.0], [344.0, 1112.0], [324.0, 1112.0]]], "lines": ["井上さん、", "習いごとって", "してました？"]}, {"box": [161, 982, 238, 1098], "vertical": true, "font_size": 22, "lines_coords": [[[217.0, 984.0], [238.0, 984.0], [238.0, 1064.0], [217.0, 1064.0]], [[190.0, 984.0], [211.0, 984.0], [209.0, 1098.0], [188.0, 1098.0]], [[161.0, 982.0], [187.0, 982.0], [187.0, 1046.0], [161.0, 1046.0]]], "lines": ["５歳まで", "エレクトーン", "を．．．．．．"]}, {"box": [101, 1014, 149, 1143], "vertical": true, "font_size": 22, "lines_coords": [[[128.0, 1014.0], [149.0, 1014.0], [147.0, 1096.0], [126.0, 1096.0]], [[101.0, 1016.0], [121.0, 1016.0], [121.0, 1143.0], [101.0, 1143.0]]], "lines": ["もう全然", "できないけど。"]}], "img_path": "120.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [632, 77, 727, 285], "vertical": true, "font_size": 20, "lines_coords": [[[702.0, 77.0], [727.0, 77.0], [727.0, 150.0], [702.0, 150.0]], [[686.0, 162.0], [706.0, 162.0], [706.0, 243.0], [686.0, 243.0]], [[658.0, 162.0], [678.0, 162.0], [678.0, 281.0], [658.0, 281.0]], [[633.0, 164.0], [649.0, 164.0], [649.0, 282.0], [633.0, 282.0]]], "lines": ["俺も．．．", "中学まで", "なんの特技も", "目標もなくて"]}, {"box": [327, 133, 429, 289], "vertical": true, "font_size": 18, "lines_coords": [[[409.0, 135.0], [426.0, 135.0], [426.0, 269.0], [409.0, 269.0]], [[380.0, 133.0], [400.0, 133.0], [400.0, 271.0], [380.0, 271.0]], [[352.0, 133.0], [372.0, 133.0], [373.0, 289.0], [353.0, 289.0]], [[327.0, 135.0], [344.0, 135.0], [344.0, 254.0], [327.0, 254.0]]], "lines": ["でも同じような", "冴えない友達と", "初めて楽器持って", "集まったとき、"]}, {"box": [206, 116, 228, 182], "vertical": true, "font_size": 21, "lines_coords": [[[206.0, 116.0], [227.0, 116.0], [227.0, 180.0], [206.0, 180.0]]], "lines": ["ゼロと"]}, {"box": [631, 385, 708, 503], "vertical": true, "font_size": 21, "lines_coords": [[[689.0, 389.0], [706.0, 389.0], [706.0, 502.0], [689.0, 502.0]], [[660.0, 387.0], [680.0, 387.0], [680.0, 486.0], [660.0, 486.0]], [[631.0, 385.0], [656.0, 385.0], [656.0, 438.0], [631.0, 438.0]]], "lines": ["世界が開けた", "気がしたん", "です。"]}, {"box": [359, 408, 409, 506], "vertical": true, "font_size": 22, "lines_coords": [[[388.0, 408.0], [408.0, 408.0], [408.0, 506.0], [388.0, 506.0]], [[359.0, 410.0], [384.0, 410.0], [384.0, 488.0], [359.0, 488.0]]], "lines": ["そのカンジ", "って．．．"]}, {"box": [350, 605, 402, 704], "vertical": true, "font_size": 22, "lines_coords": [[[377.0, 605.0], [402.0, 605.0], [402.0, 669.0], [377.0, 669.0]], [[350.0, 607.0], [370.0, 607.0], [370.0, 703.0], [350.0, 703.0]]], "lines": ["ゼロを", "合わせて．．．"]}, {"box": [122, 1039, 152, 1093], "vertical": true, "font_size": 27, "lines_coords": [[[122.0, 1040.0], [149.0, 1039.0], [152.0, 1092.0], [125.0, 1093.0]]], "lines": ["無限。"]}], "img_path": "121.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [695, 38, 753, 200], "vertical": true, "font_size": 24, "lines_coords": [[[728.0, 38.0], [753.0, 38.0], [753.0, 113.0], [728.0, 113.0]], [[695.0, 39.0], [719.0, 39.0], [719.0, 200.0], [695.0, 200.0]]], "lines": ["どどど", "どひゃーーっ！！"]}, {"box": [575, 72, 653, 212], "vertical": true, "font_size": 24, "lines_coords": [[[628.0, 73.0], [653.0, 73.0], [653.0, 142.0], [628.0, 142.0]], [[601.0, 75.0], [625.0, 75.0], [625.0, 212.0], [601.0, 212.0]], [[575.0, 72.0], [596.0, 72.0], [597.0, 154.0], [576.0, 154.0]]], "lines": ["また俺、", "寒いこと言って", "ました！？"]}, {"box": [432, 69, 454, 207], "vertical": true, "font_size": 20, "lines_coords": [[[432.0, 142.0], [452.0, 142.0], [452.0, 206.0], [432.0, 206.0]]], "lines": ["ん．．．"]}, {"box": [114, 187, 160, 285], "vertical": true, "font_size": 18, "lines_coords": [[[138.0, 187.0], [158.0, 187.0], [158.0, 267.0], [138.0, 267.0]], [[114.0, 189.0], [131.0, 189.0], [131.0, 284.0], [114.0, 284.0]]], "lines": ["こんな子", "だっけ．．．？"]}, {"box": [526, 394, 602, 514], "vertical": true, "font_size": 20, "lines_coords": [[[579.0, 394.0], [599.0, 394.0], [601.0, 513.0], [582.0, 513.0]], [[555.0, 396.0], [575.0, 396.0], [575.0, 514.0], [555.0, 514.0]], [[526.0, 397.0], [546.0, 397.0], [546.0, 475.0], [526.0, 475.0]]], "lines": ["なんだキミは", "自分で言って", "おいて？"]}, {"box": [414, 351, 437, 478], "vertical": true, "font_size": 23, "lines_coords": [[[414.0, 351.0], [437.0, 351.0], [437.0, 478.0], [414.0, 478.0]]], "lines": ["あ～～ダメだ。"]}, {"box": [117, 397, 165, 511], "vertical": true, "font_size": 20, "lines_coords": [[[144.0, 397.0], [163.0, 397.0], [163.0, 510.0], [144.0, 510.0]], [[117.0, 399.0], [137.0, 399.0], [137.0, 501.0], [117.0, 501.0]]], "lines": ["我慢できない", "みたいです。"]}, {"box": [683, 578, 716, 737], "vertical": true, "font_size": 33, "lines_coords": [[[683.0, 578.0], [716.0, 578.0], [716.0, 737.0], [683.0, 737.0]]], "lines": ["井上さん！！"]}, {"box": [119, 727, 153, 782], "vertical": true, "font_size": 32, "lines_coords": [[[121.0, 727.0], [153.0, 728.0], [151.0, 782.0], [119.0, 781.0]]], "lines": ["何！？"]}, {"box": [632, 932, 726, 1053], "vertical": true, "font_size": 28, "lines_coords": [[[695.0, 932.0], [726.0, 932.0], [726.0, 1007.0], [695.0, 1007.0]], [[664.0, 932.0], [692.0, 932.0], [692.0, 1053.0], [664.0, 1053.0]], [[632.0, 935.0], [656.0, 935.0], [656.0, 1040.0], [632.0, 1040.0]]], "lines": ["．．．僕は", "井上さんが", "好きです。"]}], "img_path": "122.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [624, 189, 701, 287], "vertical": true, "font_size": 22, "lines_coords": [[[676.0, 189.0], [701.0, 189.0], [701.0, 250.0], [676.0, 250.0]], [[652.0, 191.0], [672.0, 191.0], [672.0, 287.0], [652.0, 287.0]], [[624.0, 191.0], [645.0, 191.0], [645.0, 274.0], [624.0, 274.0]]], "lines": ["．．．僕は", "井上さんが", "好きです"]}, {"box": [671, 645, 716, 751], "vertical": true, "font_size": 21, "lines_coords": [[[695.0, 645.0], [716.0, 645.0], [716.0, 731.0], [695.0, 731.0]], [[671.0, 645.0], [690.0, 645.0], [690.0, 751.0], [671.0, 751.0]]], "lines": ["あの．．．す", "すいません。"]}, {"box": [624, 803, 728, 963], "vertical": true, "font_size": 21, "lines_coords": [[[708.0, 807.0], [728.0, 807.0], [728.0, 924.0], [708.0, 924.0]], [[681.0, 806.0], [701.0, 806.0], [701.0, 963.0], [681.0, 963.0]], [[653.0, 805.0], [676.0, 805.0], [676.0, 944.0], [653.0, 944.0]], [[626.0, 803.0], [649.0, 803.0], [647.0, 963.0], [624.0, 963.0]]], "lines": ["急に言いたく", "なったというか．．", "でも、告白って", "訳でもなくて．．．"]}, {"box": [398, 857, 420, 901], "vertical": true, "font_size": 19, "lines_coords": [[[398.0, 857.0], [420.0, 857.0], [420.0, 901.0], [398.0, 901.0]]], "lines": ["．．．あ"]}, {"box": [497, 949, 574, 1108], "vertical": true, "font_size": 20, "lines_coords": [[[550.0, 949.0], [573.0, 949.0], [573.0, 1091.0], [550.0, 1091.0]], [[524.0, 951.0], [544.0, 951.0], [544.0, 1106.0], [524.0, 1106.0]], [[497.0, 951.0], [515.0, 951.0], [516.0, 1107.0], [498.0, 1107.0]]], "lines": ["第一、井上さん。", "彼氏いるかどうか", "すら知らないし．．．"]}, {"box": [372, 976, 391, 1073], "vertical": true, "font_size": 19, "lines_coords": [[[372.0, 976.0], [388.0, 976.0], [391.0, 1073.0], [374.0, 1073.0]]], "lines": ["あははは．．．"]}, {"box": [176, 930, 223, 1087], "vertical": true, "font_size": 23, "lines_coords": [[[203.0, 930.0], [223.0, 930.0], [223.0, 1087.0], [203.0, 1087.0]], [[176.0, 931.0], [196.0, 931.0], [196.0, 1068.0], [176.0, 1068.0]]], "lines": ["ちょっと、なんで", "笑うんですか！？"]}, {"box": [74, 1003, 128, 1126], "vertical": true, "font_size": 23, "lines_coords": [[[100.0, 1003.0], [128.0, 1003.0], [126.0, 1109.0], [98.0, 1109.0]], [[74.0, 1007.0], [98.0, 1007.0], [98.0, 1126.0], [74.0, 1126.0]]], "lines": ["でも、一応", "真剣ですよ！？"]}], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [710, 94, 727, 192], "vertical": true, "font_size": 19, "lines_coords": [[[710.0, 94.0], [727.0, 94.0], [727.0, 192.0], [710.0, 192.0]]], "lines": ["ごめん．．．"]}, {"box": [611, 205, 685, 343], "vertical": true, "font_size": 19, "lines_coords": [[[665.0, 205.0], [685.0, 205.0], [685.0, 328.0], [665.0, 328.0]], [[638.0, 206.0], [658.0, 206.0], [658.0, 324.0], [638.0, 324.0]], [[611.0, 206.0], [631.0, 206.0], [631.0, 343.0], [611.0, 343.0]]], "lines": ["だって大橋君、", "若いなぁって", "思っちゃって．．"]}, {"box": [374, 248, 484, 306], "vertical": false, "font_size": 26, "lines_coords": [[[379.0, 255.0], [455.0, 255.0], [455.0, 290.0], [379.0, 290.0]], [[381.0, 288.0], [420.0, 288.0], [420.0, 305.0], [381.0, 305.0]]], "lines": ["むっ", "い"]}, {"box": [669, 482, 720, 590], "vertical": true, "font_size": 22, "lines_coords": [[[695.0, 482.0], [720.0, 482.0], [720.0, 564.0], [695.0, 564.0]], [[669.0, 485.0], [690.0, 485.0], [692.0, 590.0], [671.0, 590.0]]], "lines": ["．．．彼氏は", "いないけど、"]}, {"box": [134, 270, 208, 430], "vertical": true, "font_size": 21, "lines_coords": [[[183.0, 270.0], [207.0, 270.0], [207.0, 428.0], [183.0, 428.0]], [[158.0, 271.0], [181.0, 271.0], [181.0, 430.0], [158.0, 430.0]], [[134.0, 273.0], [151.0, 273.0], [151.0, 418.0], [134.0, 418.0]]], "lines": ["そして、あたしは", "随分、年とったん", "だなーと思って。"]}, {"box": [565, 551, 641, 708], "vertical": true, "font_size": 22, "lines_coords": [[[621.0, 553.0], [641.0, 553.0], [641.0, 651.0], [621.0, 651.0]], [[594.0, 554.0], [614.0, 554.0], [614.0, 708.0], [594.0, 708.0]], [[567.0, 551.0], [589.0, 551.0], [586.0, 638.0], [565.0, 638.0]]], "lines": ["今は誰とも", "つき合う感じじゃ", "ないんだ"]}, {"box": [701, 731, 748, 864], "vertical": true, "font_size": 19, "lines_coords": [[[727.0, 731.0], [748.0, 731.0], [748.0, 792.0], [727.0, 792.0]], [[701.0, 731.0], [717.0, 731.0], [717.0, 864.0], [701.0, 864.0]]], "lines": ["．．．．．．", "なんててすか？"]}, {"box": [423, 817, 441, 847], "vertical": true, "font_size": 18, "lines_coords": [[[423.0, 817.0], [441.0, 817.0], [441.0, 847.0], [423.0, 847.0]]], "lines": ["んー"]}, {"box": [423, 860, 442, 894], "vertical": true, "font_size": 18, "lines_coords": [[[423.0, 860.0], [442.0, 860.0], [442.0, 894.0], [423.0, 894.0]]], "lines": ["．．．"]}, {"box": [135, 598, 158, 686], "vertical": true, "font_size": 21, "lines_coords": [[[135.0, 600.0], [156.0, 600.0], [156.0, 683.0], [135.0, 683.0]]], "lines": ["．．．ごめん"]}, {"box": [675, 925, 748, 1061], "vertical": true, "font_size": 19, "lines_coords": [[[731.0, 928.0], [748.0, 928.0], [748.0, 1061.0], [731.0, 1061.0]], [[702.0, 926.0], [723.0, 926.0], [723.0, 1006.0], [702.0, 1006.0]], [[675.0, 925.0], [696.0, 925.0], [697.0, 1014.0], [676.0, 1014.0]]], "lines": ["もし、よければ", "聞かせて", "ください。"]}, {"box": [388, 958, 487, 1115], "vertical": true, "font_size": 18, "lines_coords": [[[470.0, 962.0], [487.0, 962.0], [487.0, 1115.0], [470.0, 1115.0]], [[441.0, 958.0], [461.0, 958.0], [461.0, 1114.0], [441.0, 1114.0]], [[414.0, 959.0], [434.0, 959.0], [434.0, 1058.0], [414.0, 1058.0]], [[388.0, 960.0], [405.0, 960.0], [405.0, 1113.0], [388.0, 1113.0]]], "lines": ["っていうか大橋君", "そろそろバンドの", "練習の時間", "なんじゃないの？"]}, {"box": [106, 1050, 139, 1162], "vertical": true, "font_size": 33, "lines_coords": [[[106.0, 1050.0], [139.0, 1050.0], [139.0, 1162.0], [106.0, 1162.0]]], "lines": ["やべっ！！"]}], "img_path": "126.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [630, 92, 704, 268], "vertical": true, "font_size": 19, "lines_coords": [[[683.0, 92.0], [703.0, 92.0], [703.0, 230.0], [683.0, 230.0]], [[655.0, 93.0], [675.0, 93.0], [675.0, 268.0], [655.0, 268.0]], [[631.0, 93.0], [647.0, 93.0], [647.0, 228.0], [631.0, 228.0]]], "lines": ["井上さん、今度", "メシでも食いながら", "話しましょう！？"]}, {"box": [488, 78, 515, 165], "vertical": true, "font_size": 20, "lines_coords": [[[490.0, 78.0], [515.0, 78.0], [512.0, 165.0], [488.0, 165.0]]], "lines": ["あ、あと、"]}, {"box": [367, 116, 467, 253], "vertical": true, "font_size": 20, "lines_coords": [[[450.0, 116.0], [467.0, 116.0], [467.0, 214.0], [450.0, 214.0]], [[421.0, 116.0], [441.0, 116.0], [441.0, 253.0], [421.0, 253.0]], [[393.0, 117.0], [413.0, 117.0], [413.0, 253.0], [393.0, 253.0]], [[367.0, 118.0], [385.0, 118.0], [386.0, 221.0], [368.0, 221.0]]], "lines": ["駅前とかて", "弾き語りすると", "人前で歌う度胸", "つきますよ。"]}, {"box": [79, 207, 126, 295], "vertical": true, "font_size": 21, "lines_coords": [[[101.0, 207.0], [126.0, 207.0], [126.0, 239.0], [101.0, 239.0]], [[79.0, 209.0], [96.0, 209.0], [96.0, 294.0], [79.0, 294.0]]], "lines": ["あー", "なるほど。"]}, {"box": [597, 318, 651, 392], "vertical": true, "font_size": 26, "lines_coords": [[[620.0, 318.0], [651.0, 319.0], [648.0, 377.0], [618.0, 376.0]], [[597.0, 323.0], [618.0, 323.0], [618.0, 392.0], [597.0, 392.0]]], "lines": ["うん、", "そだね。"]}, {"box": [394, 349, 442, 494], "vertical": true, "font_size": 20, "lines_coords": [[[421.0, 349.0], [441.0, 349.0], [441.0, 438.0], [421.0, 438.0]], [[394.0, 349.0], [414.0, 349.0], [414.0, 494.0], [394.0, 494.0]]], "lines": ["ほんじゃー", "おつかれ様です。"]}, {"box": [113, 420, 166, 512], "vertical": true, "font_size": 26, "lines_coords": [[[134.0, 420.0], [166.0, 420.0], [166.0, 475.0], [134.0, 475.0]], [[113.0, 426.0], [134.0, 426.0], [134.0, 512.0], [113.0, 512.0]]], "lines": ["うん、", "おつかれ。"]}, {"box": [633, 556, 709, 731], "vertical": true, "font_size": 20, "lines_coords": [[[687.0, 556.0], [707.0, 556.0], [707.0, 731.0], [687.0, 731.0]], [[660.0, 556.0], [680.0, 556.0], [680.0, 673.0], [660.0, 673.0]], [[633.0, 557.0], [653.0, 557.0], [653.0, 660.0], [633.0, 660.0]]], "lines": ["．．．なんて、あたしも", "平静を装って", "いたけれど、"]}, {"box": [110, 708, 213, 868], "vertical": true, "font_size": 22, "lines_coords": [[[193.0, 711.0], [213.0, 711.0], [213.0, 807.0], [193.0, 807.0]], [[163.0, 708.0], [187.0, 708.0], [187.0, 849.0], [163.0, 849.0]], [[134.0, 710.0], [159.0, 710.0], [159.0, 868.0], [134.0, 868.0]], [[110.0, 711.0], [129.0, 711.0], [129.0, 817.0], [110.0, 817.0]]], "lines": ["本当は彼の", "真っすぐな視線", "から、逃げるのに", "必死だった。"]}, {"box": [620, 939, 723, 1116], "vertical": true, "font_size": 20, "lines_coords": [[[702.0, 941.0], [722.0, 941.0], [722.0, 1078.0], [702.0, 1078.0]], [[672.0, 939.0], [695.0, 939.0], [695.0, 1116.0], [672.0, 1116.0]], [[647.0, 941.0], [665.0, 941.0], [666.0, 1114.0], [648.0, 1114.0]], [[620.0, 942.0], [640.0, 942.0], [640.0, 1101.0], [620.0, 1101.0]]], "lines": ["１８歳の彼を見て", "いると、どうしても", "出会った頃の種田と", "重なってしまって、"]}, {"box": [93, 1047, 114, 1132], "vertical": true, "font_size": 20, "lines_coords": [[[93.0, 1047.0], [113.0, 1047.0], [113.0, 1132.0], [93.0, 1132.0]]], "lines": ["そのたび、"]}], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [649, 111, 728, 210], "vertical": true, "font_size": 21, "lines_coords": [[[708.0, 113.0], [728.0, 113.0], [728.0, 210.0], [708.0, 210.0]], [[680.0, 112.0], [700.0, 112.0], [700.0, 210.0], [680.0, 210.0]], [[649.0, 112.0], [672.0, 111.0], [675.0, 179.0], [653.0, 180.0]]], "lines": ["あの頃には", "戻れないん", "だなぁ、"]}, {"box": [601, 235, 623, 318], "vertical": true, "font_size": 21, "lines_coords": [[[601.0, 235.0], [623.0, 235.0], [623.0, 318.0], [601.0, 318.0]]], "lines": ["．．．なんて"]}, {"box": [144, 216, 194, 343], "vertical": true, "font_size": 20, "lines_coords": [[[173.0, 217.0], [194.0, 217.0], [194.0, 296.0], [173.0, 296.0]], [[144.0, 216.0], [163.0, 216.0], [166.0, 342.0], [146.0, 342.0]]], "lines": ["ぼんやり", "考えてしまう。"]}], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [69, 50, 181, 66], "vertical": false, "font_size": 16, "lines_coords": [[[69.0, 50.0], [181.0, 50.0], [181.0, 66.0], [69.0, 66.0]]], "lines": ["ソラニン２"]}, {"box": [509, 794, 559, 920], "vertical": true, "font_size": 20, "lines_coords": [[[537.0, 795.0], [557.0, 795.0], [557.0, 891.0], [537.0, 891.0]], [[509.0, 794.0], [529.0, 794.0], [531.0, 917.0], [511.0, 917.0]]], "lines": ["新宿行きの", "電車に乗った。"]}, {"box": [613, 792, 747, 1028], "vertical": true, "font_size": 24, "lines_coords": [[[719.0, 792.0], [747.0, 792.0], [747.0, 839.0], [719.0, 839.0]], [[693.0, 792.0], [717.0, 792.0], [715.0, 912.0], [690.0, 912.0]], [[666.0, 793.0], [689.0, 793.0], [689.0, 914.0], [666.0, 914.0]], [[640.0, 794.0], [664.0, 794.0], [664.0, 1027.0], [640.0, 1027.0]], [[613.0, 794.0], [634.0, 794.0], [635.0, 935.0], [614.0, 935.0]]], "lines": ["翌日、", "押し入れから", "埃のかぶった", "アコースティックギターを", "ひきずり出して、"]}], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [623, 400, 671, 580], "vertical": true, "font_size": 20, "lines_coords": [[[645.0, 400.0], [668.0, 400.0], [671.0, 519.0], [647.0, 519.0]], [[624.0, 401.0], [640.0, 401.0], [640.0, 577.0], [624.0, 577.0]]], "lines": ["昼間の電車は", "ガラガラだったけど"]}, {"box": [499, 400, 576, 576], "vertical": true, "font_size": 20, "lines_coords": [[[556.0, 404.0], [572.0, 404.0], [572.0, 575.0], [556.0, 575.0]], [[522.0, 400.0], [546.0, 400.0], [550.0, 540.0], [525.0, 540.0]], [[500.0, 403.0], [521.0, 403.0], [521.0, 507.0], [500.0, 507.0]]], "lines": ["都心に近づくにつれ", "少しずつ乗客が", "増えてゆく。"]}, {"box": [432, 402, 453, 504], "vertical": true, "font_size": 20, "lines_coords": [[[432.0, 404.0], [452.0, 404.0], [452.0, 499.0], [432.0, 499.0]]], "lines": ["駅を出ると"]}, {"box": [272, 399, 384, 558], "vertical": true, "font_size": 27, "lines_coords": [[[354.0, 399.0], [384.0, 399.0], [384.0, 465.0], [354.0, 465.0]], [[331.0, 400.0], [354.0, 400.0], [354.0, 558.0], [331.0, 558.0]], [[303.0, 401.0], [326.0, 401.0], [326.0, 539.0], [303.0, 539.0]], [[272.0, 399.0], [304.0, 399.0], [304.0, 455.0], [272.0, 455.0]]], "lines": ["改めて", "人とモノと情報の", "多さにびっくり", "して、"]}, {"box": [155, 402, 205, 527], "vertical": true, "font_size": 18, "lines_coords": [[[181.0, 403.0], [201.0, 403.0], [201.0, 520.0], [181.0, 520.0]], [[156.0, 405.0], [173.0, 405.0], [173.0, 525.0], [156.0, 525.0]]], "lines": ["あたしは少し", "立ちくらんだ。"]}, {"box": [689, 962, 709, 1080], "vertical": true, "font_size": 20, "lines_coords": [[[689.0, 962.0], [709.0, 962.0], [709.0, 1080.0], [689.0, 1080.0]]], "lines": ["ビルがあって"]}, {"box": [625, 960, 708, 1083], "vertical": true, "font_size": 20, "lines_coords": [[[687.0, 963.0], [707.0, 963.0], [707.0, 1080.0], [687.0, 1080.0]]], "lines": ["ビルがあって"]}, {"box": [624, 963, 645, 1081], "vertical": true, "font_size": 20, "lines_coords": [[[625.0, 964.0], [645.0, 964.0], [645.0, 1079.0], [625.0, 1079.0]]], "lines": ["道路があって"]}, {"box": [552, 965, 574, 1061], "vertical": true, "font_size": 20, "lines_coords": [[[552.0, 966.0], [572.0, 966.0], [572.0, 1061.0], [552.0, 1061.0]]], "lines": ["車が走って"]}, {"box": [478, 964, 500, 1050], "vertical": true, "font_size": 22, "lines_coords": [[[478.0, 967.0], [500.0, 967.0], [500.0, 1042.0], [478.0, 1042.0]]], "lines": ["人がいて"]}, {"box": [351, 965, 399, 1101], "vertical": true, "font_size": 18, "lines_coords": [[[378.0, 965.0], [398.0, 965.0], [398.0, 1100.0], [378.0, 1100.0]], [[352.0, 966.0], [368.0, 966.0], [368.0, 1100.0], [352.0, 1100.0]]], "lines": ["うれしいことも", "かなしいことも"]}, {"box": [155, 964, 235, 1120], "vertical": true, "font_size": 25, "lines_coords": [[[209.0, 965.0], [235.0, 965.0], [235.0, 1046.0], [209.0, 1046.0]], [[182.0, 965.0], [207.0, 965.0], [207.0, 1120.0], [182.0, 1120.0]], [[155.0, 964.0], [179.0, 964.0], [179.0, 1107.0], [155.0, 1107.0]]], "lines": ["すべてが", "奇跡のバランスで", "成り立っていて、"]}], "img_path": "130.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [507, 372, 639, 510], "vertical": true, "font_size": 20, "lines_coords": [[[617.0, 375.0], [637.0, 375.0], [637.0, 509.0], [617.0, 509.0]], [[589.0, 375.0], [608.0, 375.0], [608.0, 508.0], [589.0, 508.0]], [[560.0, 372.0], [584.0, 372.0], [584.0, 509.0], [560.0, 509.0]], [[534.0, 373.0], [553.0, 373.0], [553.0, 491.0], [534.0, 491.0]], [[507.0, 373.0], [526.0, 373.0], [526.0, 494.0], [507.0, 494.0]]], "lines": ["街のエネルギー", "みたいなものに", "今の私は簡単に", "呑み込まれて", "しまいそうで、"]}, {"box": [166, 376, 277, 555], "vertical": true, "font_size": 26, "lines_coords": [[[251.0, 379.0], [277.0, 379.0], [277.0, 440.0], [251.0, 440.0]], [[226.0, 379.0], [249.0, 379.0], [249.0, 500.0], [226.0, 500.0]], [[197.0, 378.0], [221.0, 378.0], [222.0, 555.0], [199.0, 555.0]], [[168.0, 376.0], [199.0, 377.0], [196.0, 450.0], [166.0, 448.0]]], "lines": ["自分が", "前よりも随分", "弱くなってることに", "気付く。"]}, {"box": [607, 934, 685, 1072], "vertical": true, "font_size": 24, "lines_coords": [[[664.0, 936.0], [685.0, 936.0], [685.0, 1014.0], [664.0, 1014.0]], [[635.0, 935.0], [659.0, 935.0], [659.0, 1072.0], [635.0, 1072.0]], [[607.0, 935.0], [633.0, 935.0], [633.0, 1008.0], [607.0, 1008.0]]], "lines": ["誰だって", "生きていくのは", "大変だ。"]}, {"box": [522, 934, 545, 1098], "vertical": true, "font_size": 20, "lines_coords": [[[523.0, 936.0], [543.0, 936.0], [543.0, 1098.0], [523.0, 1098.0]]], "lines": ["それはわかってる。"]}, {"box": [332, 935, 355, 1055], "vertical": true, "font_size": 17, "lines_coords": [[[334.0, 938.0], [351.0, 938.0], [351.0, 1052.0], [334.0, 1052.0]]], "lines": ["でも今の私は"]}, {"box": [248, 936, 271, 1042], "vertical": true, "font_size": 21, "lines_coords": [[[248.0, 937.0], [269.0, 937.0], [270.0, 1037.0], [249.0, 1037.0]]], "lines": ["今この街で"]}, {"box": [164, 937, 185, 1062], "vertical": true, "font_size": 16, "lines_coords": [[[166.0, 938.0], [182.0, 938.0], [182.0, 1059.0], [166.0, 1059.0]]], "lines": ["まるで無力だ。"]}], "img_path": "131.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [632, 59, 655, 224], "vertical": true, "font_size": 21, "lines_coords": [[[632.0, 60.0], [653.0, 60.0], [654.0, 222.0], [633.0, 222.0]]], "lines": ["今になって思うと、"]}, {"box": [519, 61, 568, 177], "vertical": true, "font_size": 20, "lines_coords": [[[546.0, 62.0], [566.0, 62.0], [566.0, 175.0], [546.0, 175.0]], [[519.0, 62.0], [539.0, 62.0], [539.0, 144.0], [519.0, 144.0]]], "lines": ["半年前までの", "あたしは、"]}, {"box": [416, 59, 441, 128], "vertical": true, "font_size": 25, "lines_coords": [[[416.0, 59.0], [441.0, 59.0], [441.0, 127.0], [416.0, 127.0]]], "lines": ["東京で、"]}, {"box": [280, 60, 328, 179], "vertical": true, "font_size": 18, "lines_coords": [[[306.0, 60.0], [326.0, 60.0], [326.0, 140.0], [306.0, 140.0]], [[281.0, 63.0], [297.0, 63.0], [297.0, 178.0], [281.0, 178.0]]], "lines": ["どうにか", "生き抜こうと"]}, {"box": [187, 60, 237, 160], "vertical": true, "font_size": 22, "lines_coords": [[[216.0, 63.0], [236.0, 63.0], [236.0, 159.0], [216.0, 159.0]], [[187.0, 60.0], [211.0, 60.0], [211.0, 132.0], [187.0, 132.0]]], "lines": ["していたん", "だなぁ。"]}, {"box": [646, 610, 723, 727], "vertical": true, "font_size": 22, "lines_coords": [[[703.0, 612.0], [723.0, 612.0], [723.0, 710.0], [703.0, 710.0]], [[674.0, 611.0], [695.0, 611.0], [696.0, 727.0], [675.0, 727.0]], [[646.0, 610.0], [671.0, 610.0], [671.0, 673.0], [646.0, 673.0]]], "lines": ["いつまでも", "このままって", "訳には"]}, {"box": [164, 678, 183, 781], "vertical": true, "font_size": 16, "lines_coords": [[[165.0, 678.0], [181.0, 678.0], [181.0, 779.0], [165.0, 779.0]]], "lines": ["いかないな。"]}, {"box": [721, 859, 740, 945], "vertical": true, "font_size": 17, "lines_coords": [[[723.0, 862.0], [740.0, 862.0], [740.0, 935.0], [723.0, 935.0]]], "lines": ["．．．"]}], "img_path": "132.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [692, 70, 721, 139], "vertical": true, "font_size": 21, "lines_coords": [[[692.0, 70.0], [721.0, 70.0], [721.0, 139.0], [692.0, 139.0]]], "lines": ["．．．結局、"]}, {"box": [575, 98, 674, 235], "vertical": true, "font_size": 21, "lines_coords": [[[653.0, 98.0], [674.0, 98.0], [674.0, 178.0], [653.0, 178.0]], [[626.0, 98.0], [646.0, 98.0], [646.0, 235.0], [626.0, 235.0]], [[601.0, 100.0], [618.0, 100.0], [618.0, 233.0], [601.0, 233.0]], [[575.0, 99.0], [591.0, 99.0], [591.0, 221.0], [575.0, 221.0]]], "lines": ["ギターを", "ケースから出す", "ことなく帰って", "きてしまった。"]}, {"box": [443, 59, 533, 223], "vertical": true, "font_size": 24, "lines_coords": [[[508.0, 60.0], [532.0, 60.0], [532.0, 161.0], [508.0, 161.0]], [[476.0, 60.0], [501.0, 60.0], [501.0, 223.0], [476.0, 223.0]], [[443.0, 59.0], [467.0, 59.0], [467.0, 201.0], [443.0, 201.0]]], "lines": ["．．．つーか", "いきなり路上で", "歌えないよ！！"]}, {"box": [648, 617, 722, 754], "vertical": true, "font_size": 20, "lines_coords": [[[703.0, 679.0], [722.0, 679.0], [722.0, 716.0], [703.0, 716.0]], [[701.0, 617.0], [722.0, 617.0], [722.0, 673.0], [701.0, 673.0]], [[675.0, 618.0], [695.0, 618.0], [695.0, 754.0], [675.0, 754.0]], [[648.0, 618.0], [668.0, 618.0], [668.0, 735.0], [648.0, 735.0]]], "lines": ["ー？", "．．．ん", "君、こんな所で", "何してんの？"]}, {"box": [207, 597, 256, 751], "vertical": true, "font_size": 22, "lines_coords": [[[236.0, 597.0], [256.0, 597.0], [256.0, 712.0], [236.0, 712.0]], [[209.0, 597.0], [229.0, 597.0], [227.0, 751.0], [207.0, 751.0]]], "lines": ["お母さんとか", "一緒じゃないの？"]}, {"box": [99, 673, 148, 773], "vertical": true, "font_size": 22, "lines_coords": [[[128.0, 673.0], [148.0, 673.0], [148.0, 773.0], [128.0, 773.0]], [[99.0, 673.0], [125.0, 673.0], [125.0, 735.0], [99.0, 735.0]]], "lines": ["もしかして", "迷子？"]}, {"box": [690, 858, 710, 943], "vertical": true, "font_size": 22, "lines_coords": [[[690.0, 858.0], [710.0, 858.0], [710.0, 943.0], [690.0, 943.0]]], "lines": ["ちがうよ、"]}, {"box": [594, 984, 672, 1086], "vertical": true, "font_size": 22, "lines_coords": [[[649.0, 986.0], [671.0, 986.0], [672.0, 1086.0], [651.0, 1086.0]], [[623.0, 987.0], [644.0, 987.0], [644.0, 1085.0], [623.0, 1085.0]], [[594.0, 984.0], [620.0, 984.0], [620.0, 1038.0], [594.0, 1038.0]]], "lines": ["僕はずっと", "ここにいた", "もん。"]}, {"box": [174, 868, 250, 1004], "vertical": true, "font_size": 22, "lines_coords": [[[230.0, 868.0], [250.0, 868.0], [250.0, 1004.0], [230.0, 1004.0]], [[203.0, 869.0], [223.0, 869.0], [223.0, 966.0], [203.0, 966.0]], [[176.0, 868.0], [196.0, 868.0], [194.0, 983.0], [174.0, 983.0]]], "lines": ["おねーさんこそ", "こんな所で", "何してんの？"]}, {"box": [115, 1027, 141, 1089], "vertical": true, "font_size": 22, "lines_coords": [[[115.0, 1027.0], [141.0, 1027.0], [141.0, 1089.0], [115.0, 1089.0]]], "lines": ["迷子？"]}], "img_path": "133.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [686, 87, 707, 196], "vertical": true, "font_size": 20, "lines_coords": [[[686.0, 87.0], [707.0, 87.0], [707.0, 196.0], [686.0, 196.0]]], "lines": ["いや、．．．んー"]}, {"box": [605, 171, 625, 257], "vertical": true, "font_size": 20, "lines_coords": [[[605.0, 171.0], [625.0, 171.0], [625.0, 257.0], [605.0, 257.0]]], "lines": ["ははは。"]}, {"box": [241, 75, 263, 145], "vertical": true, "font_size": 21, "lines_coords": [[[241.0, 75.0], [262.0, 75.0], [263.0, 145.0], [242.0, 145.0]]], "lines": ["．．．まぁ、"]}, {"box": [140, 210, 187, 328], "vertical": true, "font_size": 18, "lines_coords": [[[165.0, 210.0], [185.0, 210.0], [185.0, 328.0], [165.0, 328.0]], [[140.0, 210.0], [156.0, 210.0], [156.0, 295.0], [140.0, 295.0]]], "lines": ["迷子みたいな", "もんだよ"]}, {"box": [671, 495, 721, 638], "vertical": true, "font_size": 22, "lines_coords": [[[700.0, 498.0], [720.0, 498.0], [720.0, 638.0], [700.0, 638.0]], [[671.0, 495.0], [695.0, 495.0], [695.0, 576.0], [671.0, 576.0]]], "lines": ["おねーさんソレ、", "ギター？"]}, {"box": [594, 580, 617, 668], "vertical": true, "font_size": 20, "lines_coords": [[[594.0, 580.0], [614.0, 580.0], [617.0, 667.0], [597.0, 667.0]]], "lines": ["そうだよ。"]}, {"box": [726, 750, 743, 810], "vertical": true, "font_size": 15, "lines_coords": [[[727.0, 752.0], [742.0, 752.0], [742.0, 774.0], [727.0, 774.0]]], "lines": ["う"]}, {"box": [270, 759, 293, 840], "vertical": true, "font_size": 23, "lines_coords": [[[270.0, 759.0], [293.0, 759.0], [293.0, 802.0], [270.0, 802.0]]], "lines": ["すげ"]}, {"box": [120, 568, 223, 672], "vertical": true, "font_size": 20, "lines_coords": [[[201.0, 570.0], [221.0, 570.0], [221.0, 671.0], [201.0, 671.0]], [[174.0, 569.0], [195.0, 569.0], [195.0, 667.0], [174.0, 667.0]], [[147.0, 569.0], [168.0, 569.0], [168.0, 667.0], [147.0, 667.0]], [[120.0, 568.0], [140.0, 568.0], [140.0, 648.0], [120.0, 648.0]]], "lines": ["おねーさん、", "もしかして", "コレひいて", "歌うの？"]}, {"box": [542, 1037, 619, 1134], "vertical": true, "font_size": 22, "lines_coords": [[[597.0, 1037.0], [619.0, 1037.0], [619.0, 1072.0], [597.0, 1072.0]], [[571.0, 1038.0], [591.0, 1038.0], [591.0, 1134.0], [571.0, 1134.0]], [[542.0, 1037.0], [566.0, 1037.0], [566.0, 1108.0], [542.0, 1108.0]]], "lines": ["まー", "そんなトコ", "ですな。"]}, {"box": [364, 806, 496, 1001], "vertical": true, "font_size": 21, "lines_coords": [[[475.0, 807.0], [495.0, 807.0], [495.0, 904.0], [475.0, 904.0]], [[445.0, 806.0], [468.0, 806.0], [468.0, 949.0], [445.0, 949.0]], [[418.0, 806.0], [441.0, 806.0], [441.0, 946.0], [418.0, 946.0]], [[389.0, 807.0], [411.0, 807.0], [412.0, 1001.0], [391.0, 1001.0]], [[366.0, 809.0], [382.0, 809.0], [382.0, 990.0], [366.0, 990.0]]], "lines": ["きっとこの", "小さな男の子も、", "あっという間に", "知らす知らずのうちに", "大人になるんだろう。"]}, {"box": [138, 1020, 158, 1117], "vertical": true, "font_size": 16, "lines_coords": [[[139.0, 1023.0], [155.0, 1023.0], [155.0, 1116.0], [139.0, 1116.0]]], "lines": ["歌ってよ！！"]}], "img_path": "134.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [672, 72, 720, 273], "vertical": true, "font_size": 20, "lines_coords": [[[672.0, 173.0], [692.0, 173.0], [692.0, 239.0], [672.0, 239.0]]], "lines": ["いいよ"]}, {"box": [537, 194, 612, 294], "vertical": true, "font_size": 19, "lines_coords": [[[591.0, 195.0], [611.0, 195.0], [611.0, 294.0], [591.0, 294.0]], [[564.0, 194.0], [584.0, 194.0], [584.0, 274.0], [564.0, 274.0]], [[538.0, 196.0], [555.0, 196.0], [555.0, 291.0], [538.0, 291.0]]], "lines": ["そのかわり", "ちゃんと", "聴いてよ！？"]}, {"box": [443, 94, 491, 226], "vertical": true, "font_size": 20, "lines_coords": [[[471.0, 94.0], [491.0, 94.0], [491.0, 226.0], [471.0, 226.0]], [[443.0, 94.0], [464.0, 94.0], [464.0, 199.0], [443.0, 199.0]]], "lines": ["ただなんとなく", "大人になる。"]}, {"box": [373, 93, 419, 268], "vertical": true, "font_size": 20, "lines_coords": [[[399.0, 93.0], [419.0, 93.0], [419.0, 267.0], [399.0, 267.0]], [[373.0, 94.0], [389.0, 94.0], [389.0, 268.0], [373.0, 268.0]]], "lines": ["それを受け入れるか", "最後まで抵抗するか"]}, {"box": [304, 93, 351, 314], "vertical": true, "font_size": 20, "lines_coords": [[[331.0, 93.0], [351.0, 93.0], [351.0, 288.0], [331.0, 288.0]], [[304.0, 94.0], [324.0, 94.0], [324.0, 314.0], [304.0, 314.0]]], "lines": ["それがその人の人生の", "大きな分かれ道なのかな。"]}, {"box": [503, 343, 539, 430], "vertical": true, "font_size": 31, "lines_coords": [[[509.0, 343.0], [539.0, 346.0], [534.0, 401.0], [503.0, 398.0]]], "lines": ["すげー"]}, {"box": [616, 908, 691, 1053], "vertical": true, "font_size": 20, "lines_coords": [[[669.0, 909.0], [690.0, 909.0], [690.0, 987.0], [669.0, 987.0]], [[641.0, 908.0], [661.0, 908.0], [661.0, 987.0], [641.0, 987.0]], [[616.0, 909.0], [635.0, 909.0], [635.0, 1051.0], [616.0, 1051.0]]], "lines": ["あたしは", "まだまだ", "迷ってばかりだ。"]}, {"box": [119, 1020, 139, 1117], "vertical": true, "font_size": 20, "lines_coords": [[[119.0, 1020.0], [139.0, 1020.0], [139.0, 1116.0], [119.0, 1116.0]]], "lines": ["だけど．．．"]}], "img_path": "135.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [712, 55, 734, 182], "vertical": true, "font_size": 21, "lines_coords": [[[712.0, 55.0], [733.0, 55.0], [734.0, 182.0], [713.0, 182.0]]], "lines": ["芽ー衣ー子っ。"]}, {"box": [597, 82, 673, 220], "vertical": true, "font_size": 21, "lines_coords": [[[652.0, 82.0], [673.0, 82.0], [673.0, 171.0], [652.0, 171.0]], [[625.0, 82.0], [646.0, 82.0], [644.0, 202.0], [623.0, 202.0]], [[598.0, 83.0], [618.0, 83.0], [617.0, 220.0], [597.0, 220.0]]], "lines": ["びっくり、", "すごい上手く", "なったじゃん！！"]}, {"box": [445, 69, 518, 172], "vertical": true, "font_size": 20, "lines_coords": [[[496.0, 69.0], [516.0, 69.0], [518.0, 171.0], [498.0, 171.0]], [[468.0, 71.0], [489.0, 71.0], [491.0, 168.0], [470.0, 168.0]], [[445.0, 79.0], [463.0, 79.0], [463.0, 111.0], [445.0, 111.0]]], "lines": ["アイちゃん、", "いつの間に", "．．．"]}, {"box": [105, 107, 207, 255], "vertical": true, "font_size": 21, "lines_coords": [[[187.0, 110.0], [207.0, 110.0], [207.0, 208.0], [187.0, 208.0]], [[158.0, 107.0], [181.0, 107.0], [181.0, 229.0], [158.0, 229.0]], [[132.0, 111.0], [152.0, 111.0], [152.0, 247.0], [132.0, 247.0]], [[105.0, 111.0], [125.0, 111.0], [125.0, 254.0], [105.0, 254.0]]], "lines": ["あんたんち", "寄ってこうと", "思ったら、音が", "聴こえてきてさ。"]}, {"box": [696, 500, 721, 589], "vertical": true, "font_size": 23, "lines_coords": [[[696.0, 500.0], [721.0, 500.0], [721.0, 589.0], [696.0, 589.0]]], "lines": ["．．．芽衣子、"]}, {"box": [429, 289, 510, 430], "vertical": true, "font_size": 26, "lines_coords": [[[484.0, 289.0], [510.0, 289.0], [510.0, 358.0], [484.0, 358.0]], [[459.0, 290.0], [482.0, 290.0], [480.0, 430.0], [456.0, 430.0]], [[429.0, 289.0], [457.0, 289.0], [457.0, 335.0], [429.0, 335.0]]], "lines": ["．．．あれ、", "メガネの男の子", "は？"]}, {"box": [119, 339, 165, 454], "vertical": true, "font_size": 18, "lines_coords": [[[144.0, 339.0], [165.0, 339.0], [165.0, 419.0], [144.0, 419.0]], [[119.0, 341.0], [135.0, 341.0], [135.0, 454.0], [119.0, 454.0]]], "lines": ["誰もいな", "かったけど？"]}, {"box": [600, 608, 680, 717], "vertical": true, "font_size": 23, "lines_coords": [[[655.0, 608.0], [680.0, 608.0], [680.0, 691.0], [655.0, 691.0]], [[631.0, 610.0], [651.0, 610.0], [651.0, 691.0], [631.0, 691.0]], [[603.0, 611.0], [624.0, 611.0], [621.0, 717.0], [600.0, 717.0]]], "lines": ["もう一回", "ちゃんと", "聴かせてよ。"]}, {"box": [162, 757, 190, 812], "vertical": true, "font_size": 26, "lines_coords": [[[162.0, 758.0], [188.0, 757.0], [190.0, 810.0], [165.0, 812.0]]], "lines": ["うん。"]}, {"box": [621, 932, 644, 1019], "vertical": true, "font_size": 20, "lines_coords": [[[621.0, 932.0], [641.0, 932.0], [641.0, 1014.0], [621.0, 1014.0]]], "lines": ["．．．だけど"]}, {"box": [454, 932, 558, 1071], "vertical": true, "font_size": 20, "lines_coords": [[[536.0, 932.0], [557.0, 932.0], [555.0, 1031.0], [534.0, 1031.0]], [[508.0, 933.0], [529.0, 933.0], [529.0, 1014.0], [508.0, 1014.0]], [[482.0, 933.0], [502.0, 933.0], [502.0, 1069.0], [482.0, 1069.0]], [[454.0, 935.0], [474.0, 935.0], [474.0, 1014.0], [454.0, 1014.0]]], "lines": ["２週間後の", "ライフを", "やりきることが", "できれば"]}, {"box": [338, 935, 386, 1050], "vertical": true, "font_size": 23, "lines_coords": [[[366.0, 935.0], [386.0, 935.0], [386.0, 1012.0], [366.0, 1012.0]], [[338.0, 935.0], [358.0, 935.0], [358.0, 1050.0], [338.0, 1050.0]]], "lines": ["あたしは", "何か変われる"]}, {"box": [256, 933, 302, 1035], "vertical": true, "font_size": 46, "lines_coords": [[[256.0, 933.0], [302.0, 933.0], [302.0, 1035.0], [256.0, 1035.0]]], "lines": ["そんな気がする。"]}, {"box": [249, 930, 303, 1031], "vertical": true, "font_size": 23, "lines_coords": [[[282.0, 935.0], [303.0, 935.0], [303.0, 1031.0], [282.0, 1031.0]], [[249.0, 930.0], [281.0, 930.0], [281.0, 989.0], [249.0, 989.0]]], "lines": ["そんな気が", "する。"]}], "img_path": "136.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "137.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "138.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [616, 856, 719, 1035], "vertical": true, "font_size": 23, "lines_coords": [[[696.0, 858.0], [716.0, 858.0], [716.0, 937.0], [696.0, 937.0]], [[669.0, 857.0], [693.0, 857.0], [693.0, 1035.0], [669.0, 1035.0]], [[639.0, 856.0], [667.0, 856.0], [667.0, 1000.0], [639.0, 1000.0]], [[616.0, 858.0], [635.0, 858.0], [635.0, 984.0], [616.0, 984.0]]], "lines": ["たとえば", "カート・コパーンは", "２７歳で自殺して", "伝説になった。"]}, {"box": [535, 1058, 617, 1122], "vertical": false, "font_size": 43, "lines_coords": [[[535.0, 1081.0], [603.0, 1058.0], [617.0, 1099.0], [549.0, 1122.0]]], "lines": ["＃２"]}, {"box": [111, 950, 188, 1100], "vertical": true, "font_size": 23, "lines_coords": [[[163.0, 950.0], [188.0, 950.0], [188.0, 1072.0], [163.0, 1072.0]], [[137.0, 950.0], [161.0, 950.0], [159.0, 1100.0], [134.0, 1100.0]], [[111.0, 952.0], [131.0, 952.0], [131.0, 1059.0], [111.0, 1059.0]]], "lines": ["でも、そんな", "人間はごくごく", "稀じゃんが。"]}], "img_path": "139.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [689, 92, 740, 216], "vertical": true, "font_size": 23, "lines_coords": [[[715.0, 92.0], [740.0, 92.0], [740.0, 183.0], [715.0, 183.0]], [[689.0, 92.0], [713.0, 92.0], [713.0, 216.0], [689.0, 216.0]]], "lines": ["結局僕は", "平凡な人間で、"]}, {"box": [170, 141, 276, 300], "vertical": true, "font_size": 22, "lines_coords": [[[255.0, 142.0], [276.0, 142.0], [272.0, 300.0], [251.0, 300.0]], [[227.0, 142.0], [248.0, 142.0], [247.0, 298.0], [226.0, 298.0]], [[200.0, 144.0], [220.0, 144.0], [220.0, 298.0], [200.0, 298.0]], [[170.0, 141.0], [197.0, 141.0], [197.0, 193.0], [170.0, 193.0]]], "lines": ["人はいつか死んで", "何もなかったかの", "ように消えてゆく", "けど、"]}, {"box": [606, 225, 700, 385], "vertical": true, "font_size": 23, "lines_coords": [[[673.0, 225.0], [697.0, 225.0], [700.0, 310.0], [675.0, 310.0]], [[653.0, 227.0], [673.0, 227.0], [673.0, 370.0], [653.0, 370.0]], [[627.0, 225.0], [652.0, 225.0], [655.0, 385.0], [631.0, 385.0]], [[606.0, 228.0], [627.0, 228.0], [627.0, 315.0], [606.0, 315.0]]], "lines": ["そのくせ", "悩んで苦しんで、", "でもしょっちゅう", "笑ってて。"]}, {"box": [124, 288, 173, 446], "vertical": true, "font_size": 22, "lines_coords": [[[152.0, 289.0], [173.0, 289.0], [173.0, 398.0], [152.0, 398.0]], [[125.0, 288.0], [146.0, 288.0], [145.0, 446.0], [124.0, 446.0]]], "lines": ["それはまー", "自然なことなんだ。"]}, {"box": [656, 551, 734, 708], "vertical": true, "font_size": 23, "lines_coords": [[[710.0, 551.0], [734.0, 551.0], [734.0, 671.0], [710.0, 671.0]], [[683.0, 551.0], [707.0, 551.0], [707.0, 708.0], [683.0, 708.0]], [[656.0, 553.0], [676.0, 553.0], [676.0, 637.0], [656.0, 637.0]]], "lines": ["僕は死ぬこと", "なんて怖くないと", "思ってた"]}, {"box": [695, 774, 771, 958], "vertical": true, "font_size": 20, "lines_coords": [[[750.0, 774.0], [770.0, 774.0], [770.0, 931.0], [750.0, 931.0]], [[722.0, 775.0], [742.0, 775.0], [742.0, 912.0], [722.0, 912.0]], [[695.0, 775.0], [715.0, 775.0], [715.0, 957.0], [695.0, 957.0]]], "lines": ["．．．いや、誰だって", "死ぬこと自体は", "怖くなんてないんだ。"]}, {"box": [379, 804, 454, 942], "vertical": true, "font_size": 20, "lines_coords": [[[433.0, 805.0], [454.0, 805.0], [452.0, 924.0], [430.0, 924.0]], [[406.0, 806.0], [426.0, 806.0], [426.0, 941.0], [406.0, 941.0]], [[379.0, 805.0], [399.0, 805.0], [399.0, 871.0], [379.0, 871.0]]], "lines": ["自分の痛みも", "苦しみも一瞬の", "ことさ。"]}, {"box": [106, 1000, 155, 1103], "vertical": true, "font_size": 20, "lines_coords": [[[133.0, 1001.0], [154.0, 1001.0], [154.0, 1098.0], [133.0, 1098.0]], [[106.0, 1000.0], [126.0, 1000.0], [126.0, 1100.0], [106.0, 1100.0]]], "lines": ["僕が本当に", "苦しいのは"]}], "img_path": "140.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [614, 130, 692, 253], "vertical": true, "font_size": 23, "lines_coords": [[[667.0, 132.0], [692.0, 132.0], [692.0, 212.0], [667.0, 212.0]], [[641.0, 130.0], [665.0, 130.0], [665.0, 249.0], [641.0, 249.0]], [[614.0, 130.0], [635.0, 130.0], [637.0, 253.0], [616.0, 253.0]]], "lines": ["真っ暗な", "銀河の果ての", "果てから想う、"]}, {"box": [118, 283, 199, 367], "vertical": true, "font_size": 27, "lines_coords": [[[167.0, 283.0], [199.0, 283.0], [199.0, 332.0], [167.0, 332.0]], [[144.0, 285.0], [169.0, 285.0], [169.0, 367.0], [144.0, 367.0]], [[118.0, 285.0], [142.0, 285.0], [142.0, 319.0], [118.0, 319.0]]], "lines": ["君の", "泣いてる", "姿。"]}, {"box": [665, 686, 685, 793], "vertical": true, "font_size": 21, "lines_coords": [[[665.0, 686.0], [685.0, 686.0], [685.0, 793.0], [665.0, 793.0]]], "lines": ["．．．ごめんよ。"]}, {"box": [582, 833, 658, 951], "vertical": true, "font_size": 21, "lines_coords": [[[638.0, 833.0], [658.0, 833.0], [658.0, 951.0], [638.0, 951.0]], [[610.0, 833.0], [631.0, 833.0], [631.0, 914.0], [610.0, 914.0]], [[582.0, 833.0], [604.0, 833.0], [605.0, 919.0], [583.0, 919.0]]], "lines": ["お願いだから", "そんな顔", "しないで。"]}, {"box": [124, 971, 233, 1112], "vertical": true, "font_size": 24, "lines_coords": [[[201.0, 971.0], [233.0, 971.0], [233.0, 1019.0], [201.0, 1019.0]], [[179.0, 975.0], [200.0, 975.0], [200.0, 1073.0], [179.0, 1073.0]], [[152.0, 976.0], [173.0, 976.0], [170.0, 1112.0], [149.0, 1112.0]], [[124.0, 973.0], [148.0, 973.0], [148.0, 1045.0], [124.0, 1045.0]]], "lines": ["君は", "笑った顔が", "一番かわいいん", "だから。"]}], "img_path": "141.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": 