, 91.0], [705.0, 91.0], [705.0, 172.0], [685.0, 172.0]], [[661.0, 94.0], [678.0, 94.0], [678.0, 229.0], [661.0, 229.0]]], "lines": ["ちゃんと", "できるかなぁ？"]}, {"box": [443, 90, 521, 230], "vertical": true, "font_size": 22, "lines_coords": [[[497.0, 90.0], [521.0, 90.0], [521.0, 209.0], [497.0, 209.0]], [[470.0, 93.0], [491.0, 93.0], [491.0, 189.0], [470.0, 189.0]], [[443.0, 92.0], [463.0, 92.0], [463.0, 194.0], [443.0, 194.0]]], "lines": ["俺もボーカル", "やったこと", "ないからな"]}, {"box": [111, 208, 188, 300], "vertical": true, "font_size": 25, "lines_coords": [[[163.0, 209.0], [188.0, 209.0], [188.0, 241.0], [163.0, 241.0]], [[134.0, 208.0], [163.0, 208.0], [163.0, 275.0], [134.0, 275.0]], [[111.0, 210.0], [132.0, 210.0], [133.0, 300.0], [112.0, 300.0]]], "lines": ["すみー", "楽しく", "やろーよ。"]}, {"box": [491, 326, 539, 482], "vertical": true, "font_size": 21, "lines_coords": [[[517.0, 326.0], [538.0, 326.0], [539.0, 482.0], [518.0, 482.0]], [[491.0, 328.0], [511.0, 328.0], [511.0, 452.0], [491.0, 452.0]]], "lines": ["俺らもテキトーに", "演奏すっから、"]}, {"box": [404, 365, 473, 543], "vertical": true, "font_size": 21, "lines_coords": [[[453.0, 365.0], [473.0, 365.0], [473.0, 468.0], [453.0, 468.0]], [[429.0, 371.0], [449.0, 371.0], [449.0, 543.0], [429.0, 543.0]], [[404.0, 370.0], [427.0, 370.0], [427.0, 507.0], [404.0, 507.0]]], "lines": ["テキトーに", "ニャーニャＩ歌えば", "いいんじゃね？"]}, {"box": [118, 445, 142, 541], "vertical": true, "font_size": 24, "lines_coords": [[[118.0, 445.0], [142.0, 445.0], [142.0, 508.0], [118.0, 508.0]]], "lines": ["ニャー"]}], "img_path": "191.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [652, 730, 676, 873], "vertical": true, "font_size": 23, "lines_coords": [[[652.0, 731.0], [675.0, 731.0], [675.0, 873.0], [652.0, 873.0]]], "lines": ["歌ってみる？"]}, {"box": [391, 551, 417, 655], "vertical": true, "font_size": 24, "lines_coords": [[[391.0, 551.0], [415.0, 551.0], [415.0, 652.0], [391.0, 652.0]]], "lines": ["：種田君、"]}], "img_path": "192.png"}, {"ver