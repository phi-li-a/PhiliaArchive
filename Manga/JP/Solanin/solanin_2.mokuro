21, 444, 992], "vertical": true, "font_size": 23, "lines_coords": [[[420.0, 725.0], [440.0, 725.0], [440.0, 808.0], [420.0, 808.0]], [[415.0, 895.0], [441.0, 895.0], [441.0, 976.0], [415.0, 976.0]], [[389.0, 895.0], [412.0, 894.0], [414.0, 946.0], [392.0, 948.0]]], "lines": ["．．．．．お前、", "．．．すごい", "なあー"]}, {"box": [170, 881, 249, 979], "vertical": true, "font_size": 22, "lines_coords": [[[224.0, 881.0], [249.0, 881.0], [249.0, 944.0], [224.0, 944.0]], [[200.0, 883.0], [216.0, 883.0], [216.0, 979.0], [200.0, 979.0]], [[170.0, 881.0], [192.0, 881.0], [192.0, 943.0], [170.0, 943.0]]], "lines": ["ええ？", "先輩泣いて", "ます！？"]}, {"box": [108, 1010, 188, 1132], "vertical": true, "font_size": 22, "lines_coords": [[[160.0, 1010.0], [188.0, 1010.0], [188.0, 1058.0], [160.0, 1058.0]], [[135.0, 1012.0], [156.0, 1012.0], [158.0, 1132.0], [137.0, 1132.0]], [[108.0, 1012.0], [128.0, 1012.0], [131.0, 1130.0], [111.0, 1130.0]]], "lines": ["別に", "泣くトコじゃ", "ないでしょ！？"]}], "img_path": "102.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [664, 70, 716, 189], "vertical": true, "font_size": 23, "lines_coords": [[[693.0, 72.0], [714.0, 72.0], [716.0, 189.0], [695.0, 189.0]], [[664.0, 71.0], [688.0, 70.0], [690.0, 141.0], [666.0, 142.0]]], "lines": ["別にすごくも", "ないし。"]}, {"box": [487, 57, 592, 213], "vertical": true, "font_size": 21, "lines_coords": [[[566.0, 57.0], [592.0, 57.0], [592.0, 139.0], [566.0, 139.0]], [[542.0, 58.0], [562.0, 58.0], [562.0, 195.0], [542.0, 195.0]], [[515.0, 58.0], [535.0, 58.0], [535.0, 213.0], [515.0, 213.0]], [[487.0, 57.0], [508.0, 57.0], [508.0, 147.0], [487.0, 147.0]]], "lines": ["やるだけ", "やってみろって", "言ったの先輩じゃ", "ないすか。"]}, {"box": [381, 135, 459, 295], "vertical": true, "font_size": 21, "lines_coords": [[[435.0, 135.0], [459.0, 135.0], [456.0, 295.0], [433.0, 295.0]], [[412.0, 139.0], [428.0, 139.0], [428.0, 255.0], [412.0, 255.0]], [[381.0, 137.0], [402.0, 137.0], [402.0, 207.0], [381.0, 207.0]]], "lines": ["だから、あたしは", "そうしただけ", "ですよ。"]}, {"box": [129, 387, 159, 472], "vertical": true, "font_size": 30, "lines_coords": [[[129.0, 389.0], [159.0, 389.0], [159.0, 472.0], [129.0, 472.0]]], "lines": ["．．．．．あ。"]}, {"box": [669, 578, 692, 672], "vertical": true, "font_size": 21, "lines_coords": [[[669.0, 578.0], [690.0, 578.0], [690.0, 672.0], [669.0, 672.0]]], "lines": ["そうだ！！"]}, {"box": [100, 630, 194, 774], "vertical": true, "font_size": 24, "lines_coords": [[[166.0, 631.0], [194.0, 631.0], [194.0, 773.0], [166.0, 773.0]], [[134.0, 632.0], [158.0, 632.0], [158.0, 774.0], [134.0, 774.0]], [[103.0, 630.0], [124.0, 630.0], [121.0, 748.0], [100.0, 748.0]]], "lines": ["先輩、ひとつ", "頼まれてくれ", "ませんか！？"]}, {"box": [637, 943, 689, 1006], "vertical": true, "font_size": 26, "lines_coords": [[[661.0, 943.0], [689.0, 943.0], [689.0, 989.0], [661.0, 989.0]], [[637.0, 944.0], [661.0, 944.0], [661.0, 1006.0], [637.0, 1006.0]]], "lines": ["お？", "おう！！"]}, {"box": [88, 994, 135, 1129], "vertical": true, "font_size": 18, "lines_coords": [[[113.0, 994.0], [133.0, 994.0], [133.0, 1129.0], [113.0, 1129.0]], [[89.0, 994.0], [105.0, 994.0], [105.0, 1128.0], [89.0, 1128.0]]], "lines": ["エロいことなら", "なんでもこい！！"]}], "img_path": "103.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [694, 101, 718, 271], "vertical": true, "font_size": 20, "lines_coords": [[[695.0, 101.0], [716.0, 101.0], [716.0, 164.0], [695.0, 164.0]], [[695.0, 221.0], [713.0, 221.0], [713.0, 270.0], [695.0, 270.0]]], "lines": ["うぅ", "ん．．．"]}, {"box": [569, 501, 674, 658], "vertical": true, "font_size": 22, "lines_coords": [[[648.0, 501.0], [674.0, 501.0], [674.0, 564.0], [648.0, 564.0]], [[623.0, 502.0], [642.0, 502.0], [642.0, 658.0], [623.0, 658.0]], [[596.0, 501.0], [617.0, 501.0], [614.0, 601.0], [593.0, 601.0]], [[569.0, 502.0], [589.0, 502.0], [589.0, 600.0], [569.0, 600.0]]], "lines": ["なんて", "ギターの楽譜って", "見づらいん", "だろう．．．"]}, {"box": [618, 742, 745, 891], "vertical": true, "font_size": 24, "lines_coords": [[[70