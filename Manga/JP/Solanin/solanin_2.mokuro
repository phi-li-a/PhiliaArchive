], [[357.0, 185.0], [377.0, 185.0], [377.0, 283.0], [357.0, 283.0]], [[331.0, 185.0], [352.0, 185.0], [352.0, 250.0], [331.0, 250.0]]], "lines": ["今日のために", "新しく作り", "ました。"]}, {"box": [77, 49, 182, 65], "vertical": false, "font_size": 16, "lines_coords": [[[77.0, 49.0], [182.0, 49.0], [182.0, 65.0], [77.0, 65.0]]], "lines": ["ソラニンに"]}, {"box": [103, 168, 151, 304], "vertical": true, "font_size": 27, "lines_coords": [[[131.0, 169.0], [151.0, 169.0], [151.0, 304.0], [131.0, 304.0]], [[103.0, 168.0], [124.0, 168.0], [124.0, 254.0], [103.0, 254.0]]], "lines": ["聴いてください", "．．．つーか、"]}, {"box": [519, 425, 569, 525], "vertical": true, "font_size": 22, "lines_coords": [[[549.0, 427.0], [569.0, 427.0], [569.0, 525.0], [549.0, 525.0]], [[519.0, 425.0], [544.0, 425.0], [544.0, 515.0], [519.0, 515.0]]], "lines": ["．．．．．．そ？", "あ、おう。"]}, {"box": [84, 342, 161, 536], "vertical": true, "font_size": 27, "lines_coords": [[[125.0, 342.0], [161.0, 342.0], [161.0, 501.0], [125.0, 501.0]], [[84.0, 348.0], [115.0, 348.0], [115.0, 536.0], [84.0, 536.0]]], "lines": ["聴けっつっ", "てんだろっ！！"]}, {"box": [215, 997, 238, 1129], "vertical": true, "font_size": 20, "lines_coords": [[[216.0, 1001.0], [236.0, 1001.0], [236.0, 1125.0], [216.0, 1125.0]]], "lines": ["．．．．．．．あっ。"]}], "img_path": "017.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [202, 144, 275, 323], "vertical": true, "font_size": 33, "lines_coords": [[[238.0, 144.0], [275.0, 144.0], [275.0, 206.0], [238.0, 206.0]], [[202.0, 144.0], [231.0, 144.0], [234.0, 321.0], [204.0, 321.0]]], "lines": ["歌詞", "飛んじゃった。"]}, {"box": [182, 533, 208, 597], "vertical": true, "font_size": 26, "lines_coords": [[[182.0, 533.0], [208.0, 533.0], [208.0, 597.0], [182.0, 597.0]]], "lines": ["あ．．．"]}, {"box": [707, 768, 753, 848], "vertical": true, "font_size": 20, "lines_coords": [[[707.0, 768.0], [727.0, 768.0], [727.0, 848.0], [707.0, 848.0]]], "lines": ["えーと．．．"]}, {"box": [437, 772, 539, 914], "vertical": true, "font_size": 28, "lines_coords": [[[507.0, 772.0], [539.0, 772.0], [539.0, 815.0], [507.0, 815.0]], [[473.0, 775.0], [502.0, 775.0], [502.0, 914.0], [473.0, 914.0]], [[437.0, 778.0], [463.0, 778.0], [466.0, 911.0], [440.0, 911.0]]], "lines": ["あー", "歌詞なんて", "いらねぇ！！"]}, {"box": [228, 616, 254, 680], "vertical": true, "font_size": 26, "lines_coords": [[[228.0, 616.0], [254.0, 616.0], [254.0, 680.0], [228.0, 680.0]]], "lines": ["あー．．．"]}, {"box": [705, 1018, 733, 1129], "vertical": true, "font_size": 28, "lines_coords": [[[705.0, 1018.0], [733.0, 1018.0], [733.0, 1129.0], [705.0, 1129.0]]], "lines": ["種田っ！！"]}, {"box": [510, 874, 535, 942], "vertical": true, "font_size": 28, "lines_coords": [[[510.0, 874.0], [535.0, 874.0], [535.0, 942.0], [510.0, 942.0]]], "lines": ["もう"]}, {"box": [103, 983, 172, 1149], "vertical": true, "font_size": 29, "lines_coords": [[[135.0, 983.0], [169.0, 983.0], [172.0, 1114.0], [138.0, 1114.0]], [[103.0, 986.0], [127.0, 986.0], [127.0, 1149.0], [103.0, 1149.0]]], "lines": ["直接全部", "言ってやる！！"]}], "img_path": "018.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [647, 101, 754, 324], "vertical": true, "font_size": 30, "lines_coords": [[[726.0, 106.0], [754.0, 106.0], [754.0, 269.0], [726.0, 269.0]], [[687.0, 103.0], [719.0, 103.0], [719.0, 298.0], [687.0, 298.0]], [[649.0, 101.0], [678.0, 101.0], [675.0, 324.0], [647.0, 324.0]]], "lines": ["いいっスか！？", "超不謹慎なこと", "言っていいスか！？"]}, {"box": [202, 69, 319, 318], "vertical": true, "font_size": 25, "lines_coords": [[[295.0, 70.0], [319.0, 70.0], [319.0, 235.0], [295.0, 235.0]], [[265.0, 70.0], [293.0, 70.0], [291.0, 318.0], [263.0, 318.0]], [[235.0, 71.0], [258.0, 71.0], [258.0, 283.0], [235.0, 283.0]], [[202.0, 69.0], [235.0, 69.0], [235.0, 123.0], [202.0, 123.0]]], "lines": ["飛行機がビルに", "突っ込んだりどっかで", "戦争始まったりした", "時！！"]}, {"box": [69, 166, 206, 355], "vertical": true, "font_size": 25, "lines_coords": [[[182.0, 167.0], [206.0, 167.0], [206.0, 331.0], [182.0, 331.0]], [[154.0, 166.0], [178.0, 166.0], [178.0, 355.0], [154.0, 355.0]], [[125.0, 166.0], [146.0, 166.0], [147.0, 330.0], [126.0, 330.0]], [[96.0, 166.0], [121.0, 166.0], [119.0, 287.0], [93.0, 287.0]], [[69.0, 166.0], [92.0, 166.0], [92.0, 353.0], [69.0, 353.0]]], "lines": ["ヤな気分なのに", "どこかでちょっと", "わくわくしてる", "スゲー嫌な", "自分がいるんだ！！"]}, {"box": [497, 373, 617, 563], "vertical": true, "font_size": 24, "lines_coords": [[[592.0, 375.0], [617.0, 375.0], [614.0, 515.0], [590.0, 515.0]], [[560.0, 373.0], [584.0, 373.0], [584.0, 516.0], [560.0, 516.0]], [[530.0, 375.0], [553.0, 375.0], [553.0, 494.0], [530.0, 494.0]], [[500.0, 373.0], [524.0, 373.0], [522.0, 563.0], [497.0, 563.0]]], "lines": ["だって俺らの", "未来には全然", "希望の光は", "見えてこなくて！！"]}, {"box": [364, 439, 478, 582], "vertical": true, "font_size": 24, "lines_coords": [[[454.0, 440.0], [478.0, 440.0], [478.0, 582.0], [454.0, 582.0]], [[425.0, 439.0], [448.0, 439.0], [448.0, 582.0], [425.0, 582.0]], [[394.0, 440.0], [418.0, 440.0], [418.0, 581.0], [394.0, 581.0]], [[364.0, 440.0], [388.0, 440.0], [388.0, 558.0], [364.0, 558.0]]], "lines": ["劇的な変化も", "きっとなくて", "退屈な毎日が", "続くんだ！！"]}, {"box": [671, 615, 755, 803], "vertical": true, "font_size": 23, "lines_coords": [[[729.0, 615.0], [753.0, 615.0], [755.0, 754.0], [731.0, 754.0]], [[702.0, 615.0], [726.0, 615.0], [726.0, 780.0], [702.0, 780.0]], [[671.0, 615.0], [695.0, 615.0], [695.0, 803.0], [671.0, 803.0]]], "lines": ["たとえゆるい", "幸せがだらっと", "続いたとしても！！"]}, {"box": [543, 719, 654, 910], "vertical": true, "font_size": 23, "lines_coords": [[[631.0, 719.0], [654.0, 719.0], [654.0, 910.0], [631.0, 910.0]], [[600.0, 719.0], [625.0, 719.0], [623.0, 909.0], [598.0, 909.0]], [[571.0, 721.0], [594.0, 721.0], [594.0, 910.0], [571.0, 910.0]], [[543.0, 721.0], [563.0, 721.0], [563.0, 861.0], [543.0, 861.0]]], "lines": ["それで満たされた", "ふうな格好だけの", "大人になんかには", "ならねぇぞ！！"]}, {"box": [151, 744, 255, 910], "vertical": true, "font_size": 27, "lines_coords": [[[227.0, 745.0], [252.0, 745.0], [255.0, 909.0], [229.0, 909.0]], [[183.0, 744.0], [216.0, 744.0], [218.0, 861.0], [186.0, 861.0]], [[151.0, 747.0], [175.0, 747.0], [175.0, 910.0], [151.0, 910.0]]], "lines": ["みなさんっ！！", "人間卒業", "おめでとう！！"]}, {"box": [137, 957, 201, 1126], "vertical": true, "font_size": 27, "lines_coords": [[[170.0, 957.0], [199.0, 957.0], [201.0, 1126.0], [173.0, 1126.0]], [[137.0, 959.0], [161.0, 959.0], [161.0, 1126.0], [137.0, 1126.0]]], "lines": ["でも俺はっ！！", "俺にはっ．．．"]}], "img_path": "019.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [631, 139, 678, 284], "vertical": true, "font_size": 20, "lines_coords": [[[658.0, 139.0], [678.0, 139.0], [678.0, 237.0], [658.0, 237.0]], [[631.0, 139.0], [651.0, 139.0], [651.0, 278.0], [631.0, 278.0]]], "lines": ["．．．もう少し", "時間をください。"]}, {"box": [157, 364, 204, 508], "vertical": true, "font_size": 18, "lines_coords": [[[182.0, 364.0], [202.0, 364.0], [202.0, 462.0], [182.0, 462.0]], [[158.0, 365.0], [174.0, 365.0], [174.0, 506.0], [158.0, 506.0]]], "lines": ["何か答えが", "見つかるまでは。"]}, {"box": [687, 558, 734, 683], "vertical": true, "font_size": 19, "lines_coords": [[[714.0, 558.0], [734.0, 558.0], [734.0, 683.0], [714.0, 683.0]], [[687.0, 558.0], [708.0, 558.0], [708.0, 659.0], [687.0, 659.0]]], "lines": ["たとえそれが", "険しい道で、"]}, {"box": [601, 638, 669, 776], "vertical": true, "font_size": 19, "lines_coords": [[[653.0, 638.0], [669.0, 638.0], [669.0, 754.0], [653.0, 754.0]], [[626.0, 638.0], [646.0, 638.0], [646.0, 719.0], [626.0, 719.0]], [[601.0, 641.0], [621.0, 641.0], [621.0, 776.0], [601.0, 776.0]]], "lines": ["世界の果ての", "果てまて", "続いていても．．"]}, {"box": [188, 667, 237, 793], "vertical": true, "font_size": 20, "lines_coords": [[[215.0, 667.0], [235.0, 667.0], [235.0, 745.0], [215.0, 745.0]], [[188.0, 669.0], [208.0, 669.0], [208.0, 793.0], [188.0, 793.0]]], "lines": ["僕は僕の", "道をゆくんだ。"]}, {"box": [241, 878, 262, 966], "vertical": true, "font_size": 20, "lines_coords": [[[241.0, 878.0], [262.0, 878.0], [262.0, 966.0], [241.0, 966.0]]], "lines": ["．．．種田っ。"]}, {"box": [149, 973, 223, 1113], "vertical": true, "font_size": 20, "lines_coords": [[[202.0, 973.0], [223.0, 973.0], [223.0, 1055.0], [202.0, 1055.0]], [[175.0, 975.0], [195.0, 975.0], [195.0, 1113.0], [175.0, 1113.0]], [[149.0, 975.0], [169.0, 975.0], [169.0, 1076.0], [149.0, 1076.0]]], "lines": ["ずいぶん", "思い切ったこと", "言ってたね"]}], "img_path": "020.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [699, 46, 720, 151], "vertical": true, "font_size": 22, "lines_coords": [[[699.0, 46.0], [720.0, 46.0], [720.0, 151.0], [699.0, 151.0]]], "lines": ["そーですよ。"]}, {"box": [614, 144, 694, 284], "vertical": true, "font_size": 22, "lines_coords": [[[674.0, 147.0], [694.0, 147.0], [694.0, 264.0], [674.0, 264.0]], [[646.0, 147.0], [666.0, 147.0], [666.0, 284.0], [646.0, 284.0]], [[614.0, 145.0], [641.0, 144.0], [644.0, 199.0], [617.0, 200.0]]], "lines": ["強がったこと", "言っちゃったよ", "俺は。"]}, {"box": [494, 70, 568, 196], "vertical": true, "font_size": 18, "lines_coords": [[[548.0, 70.0], [567.0, 70.0], [567.0, 196.0], [548.0, 196.0]], [[522.0, 72.0], [538.0, 72.0], [538.0, 187.0], [522.0, 187.0]], [[494.0, 72.0], [514.0, 72.0], [514.0, 196.0], [494.0, 196.0]]], "lines": ["ちょーっとぉ、", "なんて勝手に", "へコんでんの。"]}, {"box": [159, 59, 235, 175], "vertical": true, "font_size": 20, "lines_coords": [[[214.0, 60.0], [235.0, 60.0], [235.0, 144.0], [214.0, 144.0]], [[186.0, 62.0], [206.0, 62.0], [206.0, 175.0], [186.0, 175.0]], [[159.0, 59.0], [183.0, 59.0], [183.0, 141.0], [159.0, 141.0]]], "lines": ["．．．でもさ", "スッキリした", "でしょ？"]}, {"box": [74, 126, 146, 262], "vertical": true, "font_size": 20, "lines_coords": [[[129.0, 126.0], [146.0, 126.0], [146.0, 244.0], [129.0, 244.0]], [[100.0, 126.0], [120.0, 126.0], [120.0, 244.0], [100.0, 244.0]], [[74.0, 128.0], [91.0, 128.0], [91.0, 262.0], [74.0, 262.0]]], "lines": ["思ってること", "全部吐き出せ", "たんじゃない？"]}, {"box": [162, 387, 180, 416], "vertical": true, "font_size": 19, "lines_coords": [[[162.0, 387.0], [180.0, 387.0], [180.0, 416.0], [162.0, 416.0]]], "lines": ["ん"]}, {"box": [176, 539, 249, 644], "vertical": true, "font_size": 19, "lines_coords": [[[229.0, 539.0], [249.0, 539.0], [249.0, 637.0], [229.0, 637.0]], [[201.0, 539.0], [221.0, 539.0], [221.0, 636.0], [201.0, 636.0]], [[176.0, 540.0], [193.0, 540.0], [193.0, 644.0], [176.0, 644.0]]], "lines": ["ひとつだけ", "言えてない", "ことがある。"]}, {"box": [277, 656, 309, 708], "vertical": true, "font_size": 32, "lines_coords": [[[277.0, 656.0], [309.0, 656.0], [309.0, 708.0], [277.0, 708.0]]], "lines": ["何？"]}, {"box": [132, 951, 185, 1072], "vertical": true, "font_size": 22, "lines_coords": [[[160.0, 951.0], [185.0, 951.0], [182.0, 1040.0], [158.0, 1040.0]], [[132.0, 953.0], [152.0, 953.0], [152.0, 1072.0], [132.0, 1072.0]]], "lines": ["僕は君が", "好きなんだ。"]}], "img_path": "021.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [484, 91, 510, 146], "vertical": true, "font_size": 24, "lines_coords": [[[484.0, 91.0], [510.0, 91.0], [510.0, 146.0], [484.0, 146.0]]], "lines": ["うん。"]}, {"box": [429, 131, 450, 219], "vertical": true, "font_size": 24, "lines_coords": [[[429.0, 131.0], [450.0, 131.0], [450.0, 219.0], [429.0, 219.0]]], "lines": ["知ってた。"]}, {"box": [614, 351, 651, 362], "vertical": false, "font_size": 10, "lines_coords": [[[614.0, 351.0], [651.0, 352.0], [651.0, 362.0], [614.0, 360.0]]], "lines": ["門部門からのお"]}, {"box": [598, 365, 645, 378], "vertical": false, "font_size": 13, "lines_coords": [[[598.0, 365.0], [645.0, 365.0], [645.0, 378.0], [598.0, 378.0]]], "lines": ["．．．"]}, {"box": [598, 392, 645, 404], "vertical": false, "font_size": 12, "lines_coords": [[[598.0, 392.0], [645.0, 392.0], [645.0, 404.0], [598.0, 404.0]]], "lines": ["．．．それからおまえは何かの問題だけ"]}, {"box": [639, 542, 719, 700], "vertical": true, "font_size": 20, "lines_coords": [[[692.0, 542.0], [716.0, 542.0], [719.0, 629.0], [694.0, 629.0]], [[669.0, 544.0], [689.0, 544.0], [689.0, 700.0], [669.0, 700.0]], [[641.0, 543.0], [662.0, 543.0], [660.0, 667.0], [639.0, 667.0]]], "lines": ["．．．あのね、", "あたし、この街に", "引っ越すから。"]}, {"box": [545, 644, 618, 768], "vertical": true, "font_size": 20, "lines_coords": [[[596.0, 644.0], [617.0, 644.0], [618.0, 744.0], [597.0, 744.0]], [[570.0, 645.0], [590.0, 645.0], [590.0, 764.0], [570.0, 764.0]], [[545.0, 645.0], [560.0, 645.0], [560.0, 768.0], [545.0, 768.0]]], "lines": ["がんばって", "広めの部屋に", "決めちゃった。"]}, {"box": [199, 656, 221, 743], "vertical": true, "font_size": 20, "lines_coords": [[[199.0, 656.0], [218.0, 656.0], [221.0, 742.0], [201.0, 742.0]]], "lines": ["そうかぁ。"]}, {"box": [546, 860, 641, 1036], "vertical": true, "font_size": 24, "lines_coords": [[[616.0, 860.0], [640.0, 860.0], [637.0, 1035.0], [612.0, 1035.0]], [[583.0, 860.0], [606.0, 860.0], [606.0, 1014.0], [583.0, 1014.0]], [[549.0, 861.0], [573.0, 861.0], [571.0, 994.0], [546.0, 994.0]]], "lines": ["漠然とした将来の", "不安はまだ全然", "あるのだけど"]}, {"box": [404, 861, 496, 1047], "vertical": true, "font_size": 24, "lines_coords": [[[471.0, 861.0], [496.0, 861.0], [494.0, 1013.0], [469.0, 1013.0]], [[437.0, 863.0], [462.0, 863.0], [462.0, 994.0], [437.0, 994.0]], [[404.0, 861.0], [426.0, 861.0], [429.0, 1044.0], [407.0, 1044.0]]], "lines": ["暖かい日差しと", "彼女の存在が", "妙に気持ちよくて。"]}, {"box": [195, 860, 353, 1017], "vertical": true, "font_size": 25, "lines_coords": [[[326.0, 862.0], [351.0, 862.0], [351.0, 996.0], [326.0, 996.0]], [[292.0, 860.0], [320.0, 860.0], [318.0, 1017.0], [290.0, 1017.0]], [[262.0, 861.0], [285.0, 861.0], [285.0, 1000.0], [262.0, 1000.0]], [[228.0, 860.0], [251.0, 860.0], [251.0, 1013.0], [228.0, 1013.0]], [[195.0, 862.0], [220.0, 862.0], [220.0, 932.0], [195.0, 932.0]]], "lines": ["家に帰ったら", "ラブソングでも", "作ってみよう、", "そんな気持ちに", "なった"]}], "img_path": "022.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [145, 87, 165, 166], "vertical": true, "font_size": 20, "lines_coords": [[[145.0, 87.0], [165.0, 87.0], [165.0, 166.0], [145.0, 166.0]]], "lines": ["ーそんな"]}, {"box": [63, 49, 138, 223], "vertical": true, "font_size": 20, "lines_coords": [[[118.0, 51.0], [138.0, 51.0], [138.0, 223.0], [118.0, 223.0]], [[90.0, 50.0], [110.0, 50.0], [110.0, 157.0], [90.0, 157.0]], [[63.0, 49.0], [83.0, 49.0], [83.0, 154.0], [63.0, 154.0]]], "lines": ["一年半も前のことを", "なぜかふと", "思い出した。"]}, {"box": [536, 745, 612, 871], "vertical": true, "font_size": 21, "lines_coords": [[[590.0, 746.0], [610.0, 746.0], [610.0, 863.0], [590.0, 863.0]], [[562.0, 745.0], [585.0, 745.0], [585.0, 863.0], [562.0, 863.0]], [[537.0, 746.0], [557.0, 746.0], [557.0, 871.0], [537.0, 871.0]]], "lines": ["．．．あの日から", "もうずいぶん", "経ってんだな。"]}, {"box": [418, 746, 469, 874], "vertical": true, "font_size": 22, "lines_coords": [[[443.0, 747.0], [469.0, 747.0], [469.0, 828.0], [443.0, 828.0]], [[418.0, 746.0], [437.0, 746.0], [437.0, 868.0], [418.0, 868.0]]], "lines": ["いろいろ", "あったような。"]}, {"box": [328, 746, 352, 894], "vertical": true, "font_size": 19, "lines_coords": [[[329.0, 750.0], [348.0, 750.0], [348.0, 889.0], [329.0, 889.0]]], "lines": ["なかったような。"]}, {"box": [210, 745, 261, 865], "vertical": true, "font_size": 20, "lines_coords": [[[238.0, 747.0], [258.0, 747.0], [258.0, 863.0], [238.0, 863.0]], [[210.0, 747.0], [231.0, 747.0], [231.0, 851.0], [210.0, 851.0]]], "lines": ["そんなもんか", "人生なんて。"]}], "img_path": "023.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [590, 77, 641, 207], "vertical": true, "font_size": 20, "lines_coords": [[[619.0, 79.0], [639.0, 79.0], [639.0, 206.0], [619.0, 206.0]], [[590.0, 79.0], [611.0, 79.0], [612.0, 199.0], [591.0, 199.0]]], "lines": ["あの日作った", "ラブソングは、"]}, {"box": [445, 76, 526, 245], "vertical": true, "font_size": 26, "lines_coords": [[[493.0, 76.0], [526.0, 76.0], [526.0, 125.0], [493.0, 125.0]], [[469.0, 78.0], [493.0, 78.0], [495.0, 236.0], [471.0, 236.0]], [[446.0, 80.0], [466.0, 80.0], [466.0, 244.0], [446.0, 244.0]]], "lines": ["結局", "恥ずかしくなって", "聴かせてないけど。"]}, {"box": [355, 78, 377, 167], "vertical": true, "font_size": 16, "lines_coords": [[[357.0, 78.0], [373.0, 78.0], [373.0, 164.0], [357.0, 164.0]]], "lines": ["．．．そうだ。"]}, {"box": [208, 79, 286, 227], "vertical": true, "font_size": 21, "lines_coords": [[[262.0, 79.0], [286.0, 79.0], [286.0, 160.0], [262.0, 160.0]], [[237.0, 79.0], [257.0, 79.0], [257.0, 196.0], [237.0, 196.0]], [[208.0, 80.0], [228.0, 80.0], [230.0, 225.0], [210.0, 225.0]]], "lines": ["帰ったら", "芽衣子さんに", "聴かせてみよう。"]}, {"box": [669, 341, 694, 422], "vertical": true, "font_size": 25, "lines_coords": [[[669.0, 342.0], [694.0, 342.0], [694.0, 420.0], [669.0, 420.0]]], "lines": ["帰ろう。"]}, {"box": [170, 696, 236, 828], "vertical": true, "font_size": 31, "lines_coords": [[[199.0, 696.0], [236.0, 696.0], [236.0, 755.0], [199.0, 755.0]], [[170.0, 699.0], [195.0, 699.0], [197.0, 826.0], [173.0, 826.0]]], "lines": ["早く", "家に帰ろう。"]}], "img_path": "024.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "025.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "026.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [340, 76, 480, 157], "vertical": false, "font_size": 66, "lines_coords": [[[340.0, 91.0], [473.0, 76.0], [480.0, 141.0], [347.0, 157.0]]], "lines": ["＃１６"]}, {"box": [352, 85, 472, 154], "vertical": false, "font_size": 75, "lines_coords": [[[352.0, 79.0], [472.0, 79.0], [472.0, 160.0], [352.0, 160.0]]], "lines": ["＃１６"]}, {"box": [152, 786, 204, 864], "vertical": true, "font_size": 22, "lines_coords": [[[179.0, 786.0], [204.0, 786.0], [204.0, 856.0], [179.0, 856.0]], [[152.0, 787.0], [178.0, 787.0], [178.0, 864.0], [152.0, 864.0]]], "lines": ["いやあー", "マジで！！"]}, {"box": [84, 912, 156, 1047], "vertical": true, "font_size": 22, "lines_coords": [[[135.0, 912.0], [156.0, 912.0], [156.0, 1010.0], [135.0, 1010.0]], [[108.0, 912.0], [128.0, 912.0], [128.0, 1010.0], [108.0, 1010.0]], [[84.0, 912.0], [100.0, 912.0], [100.0, 1047.0], [84.0, 1047.0]]], "lines": ["奇跡としか", "言いようが", "ないっすもん！！"]}], "img_path": "027.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [654, 182, 714, 292], "vertical": true, "font_size": 26, "lines_coords": [[[682.0, 182.0], [714.0, 182.0], [714.0, 241.0], [682.0, 241.0]], [[655.0, 188.0], [676.0, 188.0], [676.0, 291.0], [655.0, 291.0]]], "lines": ["んな", "大袈裟な。"]}, {"box": [687, 410, 762, 574], "vertical": true, "font_size": 21, "lines_coords": [[[740.0, 410.0], [761.0, 410.0], [762.0, 529.0], [741.0, 529.0]], [[713.0, 411.0], [736.0, 411.0], [736.0, 548.0], [713.0, 548.0]], [[687.0, 411.0], [707.0, 411.0], [707.0, 574.0], [687.0, 574.0]]], "lines": ["でも、だって", "こんなショボい", "商店街の花屋じゃ、"]}, {"box": [565, 501, 668, 629], "vertical": true, "font_size": 21, "lines_coords": [[[647.0, 501.0], [668.0, 501.0], [666.0, 600.0], [645.0, 600.0]], [[619.0, 503.0], [639.0, 503.0], [639.0, 619.0], [619.0, 619.0]], [[590.0, 501.0], [614.0, 501.0], [614.0, 602.0], [590.0, 602.0]], [[565.0, 502.0], [585.0, 502.0], [585.0, 629.0], [565.0, 629.0]]], "lines": ["やべー絶対", "出会いなんて", "ねーって", "思いつつ半年。"]}, {"box": [119, 494, 196, 635], "vertical": true, "font_size": 22, "lines_coords": [[[173.0, 495.0], [196.0, 495.0], [196.0, 615.0], [173.0, 615.0]], [[146.0, 494.0], [169.0, 494.0], [167.0, 635.0], [144.0, 635.0]], [[119.0, 494.0], [140.0, 494.0], [141.0, 602.0], [120.0, 602.0]]], "lines": ["やっと入った", "バイトの新人が", "井上さんで、"]}, {"box": [701, 669, 778, 814], "vertical": true, "font_size": 20, "lines_coords": [[[757.0, 672.0], [777.0, 672.0], [777.0, 767.0], [757.0, 767.0]], [[729.0, 670.0], [749.0, 670.0], [749.0, 758.0], [729.0, 758.0]], [[701.0, 669.0], [721.0, 669.0], [721.0, 814.0], [701.0, 814.0]]], "lines": ["マジで感動", "しました。", "震えましたもん。"]}, {"box": [498, 684, 543, 828], "vertical": true, "font_size": 20, "lines_coords": [[[523.0, 684.0], [543.0, 684.0], [543.0, 764.0], [523.0, 764.0]], [[498.0, 685.0], [515.0, 685.0], [515.0, 828.0], [498.0, 828.0]]], "lines": ["だーから", "大袈裟だってば。"]}, {"box": [407, 733, 457, 871], "vertical": true, "font_size": 20, "lines_coords": [[[436.0, 733.0], [457.0, 733.0], [457.0, 833.0], [436.0, 833.0]], [[407.0, 733.0], [430.0, 733.0], [430.0, 871.0], [407.0, 871.0]]], "lines": ["．．．大橋君て", "今いくつなの？"]}, {"box": [341, 823, 367, 892], "vertical": true, "font_size": 26, "lines_coords": [[[341.0, 823.0], [367.0, 823.0], [367.0, 892.0], [341.0, 892.0]]], "lines": ["１８です。"]}, {"box": [117, 868, 144, 923], "vertical": true, "font_size": 21, "lines_coords": [[[117.0, 868.0], [144.0, 868.0], [144.0, 923.0], [117.0, 923.0]]], "lines": ["若っ。"]}, {"box": [100, 994, 173, 1112], "vertical": true, "font_size": 21, "lines_coords": [[[153.0, 994.0], [173.0, 994.0], [173.0, 1112.0], [153.0, 1112.0]], [[126.0, 994.0], [146.0, 994.0], [146.0, 1092.0], [126.0, 1092.0]], [[100.0, 994.0], [117.0, 994.0], [117.0, 1110.0], [100.0, 1110.0]]], "lines": ["出会いなんて", "大学に沢山", "あるじゃん？"]}], "img_path": "028.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [655, 98, 732, 236], "vertical": true, "font_size": 21, "lines_coords": [[[708.0, 98.0], [729.0, 98.0], [731.0, 235.0], [710.0, 235.0]], [[685.0, 100.0], [705.0, 100.0], [705.0, 216.0], [685.0, 216.0]], [[655.0, 99.0], [676.0, 99.0], [678.0, 196.0], [656.0, 196.0]]], "lines": ["なんか学生って", "ナャラチャラ", "してて．．．"]}, {"box": [388, 64, 459, 210], "vertical": true, "font_size": 20, "lines_coords": [[[439.0, 64.0], [459.0, 64.0], [459.0, 144.0], [439.0, 144.0]], [[413.0, 64.0], [436.0, 64.0], [436.0, 183.0], [413.0, 183.0]], [[388.0, 64.0], [413.0, 64.0], [413.0, 210.0], [388.0, 210.0]]], "lines": ["井上さん", "落ちついてて", "大人って感じで、"]}, {"box": [317, 193, 384, 308], "vertical": true, "font_size": 20, "lines_coords": [[[367.0, 193.0], [384.0, 193.0], [384.0, 308.0], [367.0, 308.0]], [[343.0, 193.0], [360.0, 193.0], [358.0, 290.0], [340.0, 290.0]], [[317.0, 193.0], [337.0, 193.0], [339.0, 298.0], [319.0, 298.0]]], "lines": ["年上のヒトの", "ほうが全然", "いいっすよ。"]}, {"box": [140, 79, 189, 158], "vertical": true, "font_size": 21, "lines_coords": [[[168.0, 121.0], [186.0, 120.0], [188.0, 157.0], [170.0, 158.0]], [[169.0, 82.0], [189.0, 82.0], [189.0, 120.0], [169.0, 120.0]], [[140.0, 79.0], [165.0, 79.0], [165.0, 146.0], [140.0, 146.0]]], "lines": ["．．．", "んー", "大橋君、"]}, {"box": [694, 364, 714, 462], "vertical": true, "font_size": 20, "lines_coords": [[[694.0, 366.0], [714.0, 366.0], [714.0, 461.0], [694.0, 461.0]]], "lines": ["．．．．．．アレ？"]}, {"box": [501, 417, 563, 566], "vertical": true, "font_size": 25, "lines_coords": [[[514.0, 424.0], [542.0, 417.0], [563.0, 516.0], [535.0, 523.0]], [[501.0, 458.0], [523.0, 455.0], [536.0, 563.0], [514.0, 566.0]]], "lines": ["なんかセレ弱", "ふみました？"]}, {"box": [96, 242, 199, 364], "vertical": true, "font_size": 21, "lines_coords": [[[173.0, 242.0], [199.0, 242.0], [199.0, 307.0], [173.0, 307.0]], [[147.0, 243.0], [170.0, 243.0], [170.0, 364.0], [147.0, 364.0]], [[121.0, 244.0], [141.0, 244.0], [141.0, 362.0], [121.0, 362.0]], [[96.0, 246.0], [112.0, 246.0], [112.0, 350.0], [96.0, 350.0]]], "lines": ["あたし", "落ちついてる", "なんて初めて", "言われたよ。"]}, {"box": [679, 602, 703, 707], "vertical": true, "font_size": 20, "lines_coords": [[[679.0, 602.0], [703.0, 602.0], [703.0, 707.0], [679.0, 707.0]]], "lines": ["井上さーん、"]}, {"box": [586, 699, 658, 816], "vertical": true, "font_size": 20, "lines_coords": [[[638.0, 699.0], [658.0, 699.0], [658.0, 816.0], [638.0, 816.0]], [[610.0, 699.0], [630.0, 699.0], [630.0, 796.0], [610.0, 796.0]], [[586.0, 699.0], [603.0, 699.0], [603.0, 785.0], [586.0, 785.0]]], "lines": ["値段のつけ方", "教えるから", "ちょっと。"]}, {"box": [120, 730, 176, 802], "vertical": true, "font_size": 28, "lines_coords": [[[145.0, 730.0], [176.0, 730.0], [176.0, 766.0], [145.0, 766.0]], [[120.0, 733.0], [146.0, 733.0], [146.0, 802.0], [120.0, 802.0]]], "lines": ["あ、", "ハーイ。"]}, {"box": [230, 958, 306, 1075], "vertical": true, "font_size": 21, "lines_coords": [[[281.0, 958.0], [306.0, 958.0], [306.0, 1021.0], [281.0, 1021.0]], [[255.0, 959.0], [275.0, 959.0], [275.0, 1075.0], [255.0, 1075.0]], [[230.0, 960.0], [247.0, 960.0], [247.0, 1062.0], [230.0, 1062.0]]], "lines": ["やっぱ", "夕方になると", "冷えますね。"]}, {"box": [159, 1059, 187, 1113], "vertical": true, "font_size": 26, "lines_coords": [[[159.0, 1060.0], [185.0, 1059.0], [187.0, 1112.0], [161.0, 1113.0]]], "lines": ["ねえ。"]}], "img_path": "029.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [649, 108, 730, 229], "vertical": true, "font_size": 25, "lines_coords": [[[705.0, 110.0], [730.0, 110.0], [730.0, 179.0], [705.0, 179.0]], [[678.0, 111.0], [702.0, 111.0], [702.0, 229.0], [678.0, 229.0]], [[649.0, 108.0], [675.0, 108.0], [675.0, 172.0], [649.0, 172.0]]], "lines": ["大橋君、", "バンドやって", "るの？"]}, {"box": [368, 118, 468, 369], "vertical": true, "font_size": 24, "lines_coords": [[[437.0, 118.0], [468.0, 118.0], [468.0, 191.0], [437.0, 191.0]], [[421.0, 209.0], [442.0, 209.0], [443.0, 348.0], [422.0, 348.0]], [[394.0, 209.0], [418.0, 209.0], [418.0, 369.0], [394.0, 369.0]], [[368.0, 212.0], [388.0, 212.0], [388.0, 356.0], [368.0, 356.0]]], "lines": ["．．．へへ。", "まだメンバーも", "ちゃんと集まって", "ないですけどね。"]}, {"box": [267, 222, 317, 358], "vertical": true, "font_size": 23, "lines_coords": [[[293.0, 222.0], [317.0, 222.0], [315.0, 358.0], [291.0, 358.0]], [[267.0, 223.0], [288.0, 223.0], [288.0, 323.0], [267.0, 323.0]]], "lines": ["花屋でバイトを", "始めたのは、"]}, {"box": [145, 223, 165, 360], "vertical": true, "font_size": 20, "lines_coords": [[[145.0, 223.0], [165.0, 223.0], [165.0, 360.0], [145.0, 360.0]]], "lines": ["たまたま場所が"]}, {"box": [113, 221, 140, 363], "vertical": true, "font_size": 23, "lines_coords": [[[115.0, 221.0], [140.0, 221.0], [138.0, 363.0], [113.0, 363.0]]], "lines": ["近所だったから"]}, {"box": [192, 221, 243, 397], "vertical": true, "font_size": 23, "lines_coords": [[[220.0, 223.0], [240.0, 223.0], [243.0, 397.0], [223.0, 397.0]], [[192.0, 221.0], [215.0, 221.0], [217.0, 350.0], [194.0, 350.0]]], "lines": ["たまたま求人雑誌で", "目がとまって、"]}, {"box": [90, 222, 111, 428], "vertical": true, "font_size": 20, "lines_coords": [[[90.0, 222.0], [110.0, 222.0], [111.0, 428.0], [91.0, 428.0]]], "lines": ["だというのもあるけど、"]}, {"box": [621, 600, 699, 718], "vertical": true, "font_size": 22, "lines_coords": [[[673.0, 600.0], [699.0, 600.0], [699.0, 663.0], [673.0, 663.0]], [[648.0, 601.0], [668.0, 601.0], [668.0, 718.0], [648.0, 718.0]], [[621.0, 601.0], [641.0, 601.0], [641.0, 704.0], [621.0, 704.0]]], "lines": ["やっぱ", "夕方になると", "冷えますね。"]}, {"box": [185, 657, 206, 726], "vertical": true, "font_size": 22, "lines_coords": [[[185.0, 657.0], [206.0, 657.0], [206.0, 726.0], [185.0, 726.0]]], "lines": ["あはは。"]}, {"box": [142, 775, 220, 868], "vertical": true, "font_size": 22, "lines_coords": [[[189.0, 775.0], [220.0, 775.0], [220.0, 830.0], [189.0, 830.0]], [[167.0, 780.0], [188.0, 780.0], [188.0, 860.0], [167.0, 860.0]], [[142.0, 781.0], [159.0, 781.0], [159.0, 868.0], [142.0, 868.0]]], "lines": ["それ、", "さっきも", "言ったし。"]}, {"box": [701, 935, 724, 1018], "vertical": true, "font_size": 21, "lines_coords": [[[701.0, 935.0], [722.0, 935.0], [724.0, 1016.0], [703.0, 1016.0]]], "lines": ["小さい頃"]}, {"box": [582, 935, 631, 1090], "vertical": true, "font_size": 20, "lines_coords": [[[610.0, 937.0], [630.0, 937.0], [630.0, 1089.0], [610.0, 1089.0]], [[582.0, 936.0], [601.0, 936.0], [601.0, 1016.0], [582.0, 1016.0]]], "lines": ["無邪気だった頃の", "あたしは"]}, {"box": [419, 935, 525, 1112], "vertical": true, "font_size": 22, "lines_coords": [[[502.0, 936.0], [525.0, 936.0], [523.0, 1074.0], [500.0, 1074.0]], [[473.0, 936.0], [496.0, 936.0], [496.0, 1112.0], [473.0, 1112.0]], [[447.0, 937.0], [468.0, 937.0], [468.0, 1034.0], [447.0, 1034.0]], [[419.0, 935.0], [442.0, 935.0], [442.0, 1092.0], [419.0, 1092.0]]], "lines": ["お花屋さんとか", "ケーキ屋さんとかに", "なりたいと", "思っていたことを"]}, {"box": [313, 936, 366, 1093], "vertical": true, "font_size": 23, "lines_coords": [[[343.0, 937.0], [363.0, 937.0], [363.0, 1091.0], [343.0, 1091.0]], [[313.0, 936.0], [339.0, 936.0], [339.0, 1004.0], [313.0, 1004.0]]], "lines": ["ふいに思い出した", "からだ。"]}, {"box": [119, 991, 197, 1147], "vertical": true, "font_size": 21, "lines_coords": [[[174.0, 992.0], [195.0, 992.0], [195.0, 1078.0], [174.0, 1078.0]], [[147.0, 991.0], [170.0, 991.0], [170.0, 1112.0], [147.0, 1112.0]], [[121.0, 992.0], [141.0, 992.0], [139.0, 1147.0], [119.0, 1147.0]]], "lines": ["井上さん、", "家まで送って", "いきましょうか？"]}], "img_path": "030.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [559, 69, 634, 215], "vertical": true, "font_size": 20, "lines_coords": [[[613.0, 69.0], [633.0, 69.0], [634.0, 215.0], [614.0, 215.0]], [[586.0, 70.0], [606.0, 70.0], [606.0, 187.0], [586.0, 187.0]], [[559.0, 69.0], [580.0, 69.0], [580.0, 167.0], [559.0, 167.0]]], "lines": ["たしか、ここから", "歩いて１０分位", "ですよね？"]}, {"box": [467, 125, 514, 261], "vertical": true, "font_size": 20, "lines_coords": [[[494.0, 125.0], [514.0, 125.0], [514.0, 261.0], [494.0, 261.0]], [[467.0, 126.0], [487.0, 126.0], [487.0, 230.0], [467.0, 230.0]]], "lines": ["ニケツしてけば", "一瞬ですよ。"]}, {"box": [649, 423, 734, 603], "vertical": true, "font_size": 27, "lines_coords": [[[706.0, 423.0], [734.0, 423.0], [734.0, 603.0], [706.0, 603.0]], [[680.0, 426.0], [703.0, 426.0], [703.0, 564.0], [680.0, 564.0]], [[649.0, 425.0], [680.0, 425.0], [680.0, 494.0], [649.0, 494.0]]], "lines": ["でも、今のあたしは", "花に興味なんて", "無いし、"]}, {"box": [484, 425, 566, 545], "vertical": true, "font_size": 24, "lines_coords": [[[542.0, 426.0], [563.0, 426.0], [564.0, 543.0], [543.0, 543.0]], [[517.0, 427.0], [537.0, 427.0], [537.0, 543.0], [517.0, 543.0]], [[484.0, 425.0], [514.0, 425.0], [514.0, 493.0], [484.0, 493.0]]], "lines": ["時給の低さは", "やっぱり気に", "なるし、"]}, {"box": [291, 268, 367, 374], "vertical": true, "font_size": 20, "lines_coords": [[[346.0, 268.0], [366.0, 268.0], [366.0, 369.0], [346.0, 369.0]], [[318.0, 269.0], [339.0, 269.0], [339.0, 366.0], [318.0, 366.0]], [[291.0, 269.0], [311.0, 269.0], [311.0, 373.0], [291.0, 373.0]]], "lines": ["．．．ありがと", "ても買い物", "してくから"]}, {"box": [324, 424, 405, 554], "vertical": true, "font_size": 25, "lines_coords": [[[372.0, 424.0], [405.0, 424.0], [405.0, 478.0], [372.0, 478.0]], [[351.0, 428.0], [372.0, 428.0], [372.0, 527.0], [351.0, 527.0]], [[324.0, 427.0], [344.0, 427.0], [344.0, 553.0], [324.0, 553.0]]], "lines": ["結局、", "気晴らしに", "働いてるだけ。"]}, {"box": [669, 661, 690, 784], "vertical": true, "font_size": 16, "lines_coords": [[[671.0, 665.0], [687.0, 665.0], [687.0, 779.0], [671.0, 779.0]]], "lines": ["．．．こめんね"]}, {"box": [385, 663, 464, 800], "vertical": true, "font_size": 23, "lines_coords": [[[442.0, 664.0], [462.0, 664.0], [462.0, 800.0], [442.0, 800.0]], [[413.0, 664.0], [436.0, 664.0], [436.0, 782.0], [413.0, 782.0]], [[385.0, 663.0], [411.0, 663.0], [411.0, 727.0], [385.0, 727.0]]], "lines": ["きっとあたしは", "君が期待する", "ような、"]}, {"box": [144, 664, 225, 781], "vertical": true, "font_size": 23, "lines_coords": [[[203.0, 666.0], [223.0, 666.0], [223.0, 764.0], [203.0, 764.0]], [[174.0, 666.0], [195.0, 666.0], [195.0, 779.0], [174.0, 779.0]], [[144.0, 664.0], [173.0, 664.0], [173.0, 738.0], [144.0, 738.0]]], "lines": ["落ちついた", "大人な人じゃ", "ないよ。"]}, {"box": [675, 918, 694, 1014], "vertical": true, "font_size": 17, "lines_coords": [[[675.0, 918.0], [692.0, 918.0], [692.0, 1014.0], [675.0, 1014.0]]], "lines": ["．．．あのっ！！"]}, {"box": [109, 1006, 183, 1123], "vertical": true, "font_size": 19, "lines_coords": [[[161.0, 1006.0], [182.0, 1006.0], [182.0, 1105.0], [161.0, 1105.0]], [[134.0, 1008.0], [154.0, 1008.0], [154.0, 1106.0], [134.0, 1106.0]], [[110.0, 1008.0], [126.0, 1008.0], [126.0, 1122.0], [110.0, 1122.0]]], "lines": ["今度２人で", "メシ食いに", "行きません？"]}], "img_path": "031.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [539, 101, 560, 179], "vertical": true, "font_size": 21, "lines_coords": [[[539.0, 101.0], [560.0, 101.0], [560.0, 179.0], [539.0, 179.0]]], "lines": ["あれっ？"]}], "img_path": "032.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [681, 930, 703, 1032], "vertical": true, "font_size": 20, "lines_coords": [[[682.0, 933.0], [702.0, 933.0], [702.0, 1028.0], [682.0, 1028.0]]], "lines": ["冷たい風が"]}, {"box": [551, 930, 630, 1070], "vertical": true, "font_size": 23, "lines_coords": [[[608.0, 931.0], [628.0, 931.0], [628.0, 1030.0], [608.0, 1030.0]], [[582.0, 932.0], [601.0, 932.0], [601.0, 1067.0], [582.0, 1067.0]], [[551.0, 930.0], [580.0, 930.0], [580.0, 1000.0], [551.0, 1000.0]]], "lines": ["昨年よりも", "ずっと無意味に", "吹いて、"]}, {"box": [356, 931, 405, 1069], "vertical": true, "font_size": 22, "lines_coords": [[[381.0, 931.0], [405.0, 931.0], [405.0, 1068.0], [381.0, 1068.0]], [[356.0, 933.0], [377.0, 933.0], [377.0, 1014.0], [356.0, 1014.0]]], "lines": ["とりとめのない", "おもいが"]}, {"box": [238, 932, 289, 1038], "vertical": true, "font_size": 21, "lines_coords": [[[267.0, 932.0], [288.0, 932.0], [285.0, 1031.0], [264.0, 1031.0]], [[238.0, 933.0], [259.0, 933.0], [259.0, 1038.0], [238.0, 1038.0]]], "lines": ["浮かんでは", "消えてゆく。"]}, {"box": [103, 967, 126, 1109], "vertical": true, "font_size": 21, "lines_coords": [[[103.0, 967.0], [124.0, 967.0], [124.0, 1066.0], [103.0, 1066.0]]], "lines": ["おかえり"]}], "img_path": "033.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [678, 71, 782, 246], "vertical": true, "font_size": 20, "lines_coords": [[[760.0, 71.0], [781.0, 71.0], [779.0, 228.0], [758.0, 228.0]], [[733.0, 71.0], [754.0, 71.0], [753.0, 246.0], [731.0, 246.0]], [[706.0, 71.0], [726.0, 71.0], [726.0, 172.0], [706.0, 172.0]], [[678.0, 71.0], [697.0, 71.0], [697.0, 157.0], [678.0, 157.0]]], "lines": ["うおぉーーー、弁当", "何個買ってんのよ？", "自炊する気", "ゼロだな。"]}, {"box": [529, 119, 580, 199], "vertical": true, "font_size": 24, "lines_coords": [[[558.0, 121.0], [579.0, 121.0], [579.0, 199.0], [558.0, 199.0]], [[529.0, 119.0], [555.0, 119.0], [555.0, 191.0], [529.0, 191.0]]], "lines": ["おかえり", "芽衣子。"]}, {"box": [101, 217, 150, 335], "vertical": true, "font_size": 20, "lines_coords": [[[128.0, 217.0], [148.0, 217.0], [148.0, 317.0], [128.0, 317.0]], [[101.0, 217.0], [121.0, 217.0], [121.0, 335.0], [101.0, 335.0]]], "lines": ["どーだった", "初バイトは？"]}, {"box": [534, 479, 554, 566], "vertical": true, "font_size": 19, "lines_coords": [[[534.0, 479.0], [553.0, 479.0], [553.0, 566.0], [534.0, 566.0]]], "lines": ["ただいま。"]}, {"box": [318, 418, 422, 578], "vertical": true, "font_size": 21, "lines_coords": [[[402.0, 418.0], [422.0, 418.0], [422.0, 515.0], [402.0, 515.0]], [[373.0, 418.0], [397.0, 418.0], [397.0, 556.0], [373.0, 556.0]], [[346.0, 418.0], [370.0, 418.0], [370.0, 555.0], [346.0, 555.0]], [[318.0, 418.0], [341.0, 418.0], [341.0, 578.0], [318.0, 578.0]]], "lines": ["もう１人の", "バイトの子が．．．", "いや、すっごい", "いい子なんだけど、"]}, {"box": [318, 630, 393, 747], "vertical": true, "font_size": 20, "lines_coords": [[[371.0, 630.0], [391.0, 630.0], [391.0, 747.0], [371.0, 747.0]]], "lines": ["なんか長続き"]}, {"box": [317, 629, 364, 728], "vertical": true, "font_size": 21, "lines_coords": [[[344.0, 629.0], [364.0, 629.0], [364.0, 728.0], [344.0, 728.0]], [[317.0, 629.0], [334.0, 629.0], [336.0, 718.0], [318.0, 718.0]]], "lines": ["しない気が", "するなぁ。"]}, {"box": [695, 904, 771, 1041], "vertical": true, "font_size": 21, "lines_coords": [[[750.0, 904.0], [771.0, 904.0], [771.0, 956.0], [750.0, 956.0]], [[723.0, 905.0], [743.0, 905.0], [743.0, 1041.0], [723.0, 1041.0]], [[696.0, 904.0], [716.0, 904.0], [715.0, 1031.0], [695.0, 1031.0]]], "lines": ["もおー", "少しは、やる気", "出しなさいよ。"]}, {"box": [601, 1037, 705, 1157], "vertical": true, "font_size": 21, "lines_coords": [[[685.0, 1038.0], [705.0, 1038.0], [705.0, 1137.0], [685.0, 1137.0]], [[655.0, 1037.0], [679.0, 1037.0], [679.0, 1157.0], [655.0, 1157.0]], [[628.0, 1039.0], [648.0, 1039.0], [648.0, 1117.0], [628.0, 1117.0]], [[601.0, 1040.0], [623.0, 1040.0], [623.0, 1125.0], [601.0, 1125.0]]], "lines": ["ホント無理", "なら、その時", "考えれば", "いいから。"]}, {"box": [325, 1047, 350, 1120], "vertical": true, "font_size": 25, "lines_coords": [[[325.0, 1047.0], [350.0, 1047.0], [350.0, 1120.0], [325.0, 1120.0]]], "lines": ["ふぁい。"]}, {"box": [103, 1055, 120, 1141], "vertical": true, "font_size": 16, "lines_coords": [[[103.0, 1055.0], [119.0, 1055.0], [119.0, 1139.0], [103.0, 1139.0]]], "lines": ["そうそう。"]}], "img_path": "034.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [666, 377, 717, 458], "vertical": true, "font_size": 26, "lines_coords": [[[693.0, 377.0], [717.0, 377.0], [717.0, 458.0], [693.0, 458.0]], [[666.0, 377.0], [693.0, 377.0], [693.0, 438.0], [666.0, 438.0]]], "lines": ["．．．芽衣子", "眠い？"]}, {"box": [338, 435, 363, 468], "vertical": true, "font_size": 25, "lines_coords": [[[338.0, 435.0], [363.0, 435.0], [363.0, 468.0], [338.0, 468.0]]], "lines": ["ん。"]}, {"box": [114, 721, 161, 847], "vertical": true, "font_size": 18, "lines_coords": [[[141.0, 721.0], [159.0, 721.0], [159.0, 772.0], [141.0, 772.0]], [[114.0, 721.0], [131.0, 721.0], [131.0, 844.0], [114.0, 844.0]]], "lines": ["じゃー", "また来るから。"]}, {"box": [645, 929, 722, 1065], "vertical": true, "font_size": 20, "lines_coords": [[[696.0, 929.0], [722.0, 929.0], [722.0, 999.0], [696.0, 999.0]], [[671.0, 930.0], [690.0, 930.0], [690.0, 1065.0], [671.0, 1065.0]], [[645.0, 930.0], [661.0, 930.0], [661.0, 1034.0], [645.0, 1034.0]]], "lines": ["．．．じゃ、", "あたし達今日は", "もう帰るね"]}], "img_path": "035.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [656, 475, 679, 576], "vertical": true, "font_size": 23, "lines_coords": [[[656.0, 475.0], [679.0, 475.0], [679.0, 525.0], [656.0, 525.0]]], "lines": ["ひゃー"]}, {"box": [135, 549, 186, 657], "vertical": true, "font_size": 24, "lines_coords": [[[158.0, 549.0], [186.0, 549.0], [186.0, 595.0], [158.0, 595.0]], [[135.0, 551.0], [155.0, 551.0], [155.0, 655.0], [135.0, 655.0]]], "lines": ["急に", "降ってきた。"]}, {"box": [388, 985, 467, 1125], "vertical": true, "font_size": 25, "lines_coords": [[[446.0, 986.0], [467.0, 986.0], [464.0, 1107.0], [443.0, 1107.0]], [[413.0, 985.0], [441.0, 985.0], [441.0, 1125.0], [413.0, 1125.0]], [[388.0, 986.0], [413.0, 986.0], [413.0, 1050.0], [388.0, 1050.0]]], "lines": ["ちょっと加藤", "なに、つっ立っ", "て．．．．．"]}], "img_path": "036.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [614, 176, 663, 257], "vertical": true, "font_size": 20, "lines_coords": [[[642.0, 178.0], [662.0, 178.0], [662.0, 256.0], [642.0, 256.0]], [[614.0, 176.0], [634.0, 176.0], [634.0, 256.0], [614.0, 256.0]]], "lines": ["．．．そりゃ", "そーか．．．"]}, {"box": [139, 308, 214, 444], "vertical": true, "font_size": 18, "lines_coords": [[[195.0, 309.0], [211.0, 309.0], [211.0, 444.0], [195.0, 444.0]], [[168.0, 310.0], [185.0, 310.0], [185.0, 425.0], [168.0, 425.0]], [[139.0, 308.0], [159.0, 308.0], [159.0, 397.0], [139.0, 397.0]]], "lines": ["まだ２か月しか", "経ってないん", "だもんな。"]}, {"box": [87, 1021, 114, 1103], "vertical": true, "font_size": 26, "lines_coords": [[[87.0, 1021.0], [113.0, 1021.0], [113.0, 1102.0], [87.0, 1102.0]]], "lines": ["．．．種田。"]}], "img_path": "037.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [708, 70, 732, 231], "vertical": true, "font_size": 23, "lines_coords": [[[708.0, 72.0], [731.0, 72.0], [731.0, 230.0], [708.0, 230.0]]], "lines": ["死んじゃうなんて"]}, {"box": [553, 323, 576, 414], "vertical": true, "font_size": 22, "lines_coords": [[[553.0, 324.0], [575.0, 324.0], [576.0, 411.0], [555.0, 411.0]]], "lines": ["ずるいよ。"]}, {"box": [124, 327, 144, 394], "vertical": true, "font_size": 19, "lines_coords": [[[125.0, 330.0], [144.0, 330.0], [144.0, 390.0], [125.0, 390.0]]], "lines": ["．．．バカ。"]}], "img_path": "038.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "039.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "040.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_hei