 [153.0, 534.0]], [[126.0, 454.0], [147.0, 454.0], [147.0, 551.0], [126.0, 551.0]], [[99.0, 454.0], [119.0, 454.0], [119.0, 551.0], [99.0, 551.0]]], "lines": ["ただ、俺は今", "神聖なる", "罰ゲームの", "最中で．．．"]}, {"box": [689, 649, 710, 735], "vertical": true, "font_size": 20, "lines_coords": [[[689.0, 649.0], [709.0, 649.0], [709.0, 735.0], [689.0, 735.0]]], "lines": ["．．．なんか"]}, {"box": [536, 677, 586, 758], "vertical": true, "font_size": 24, "lines_coords": [[[565.0, 679.0], [586.0, 679.0], [586.0, 758.0], [565.0, 758.0]], [[536.0, 677.0], [562.0, 677.0], [562.0, 746.0], [536.0, 746.0]]], "lines": ["この間は", "ごめん。"]}, {"box": [388, 654, 408, 741], "vertical": true, "font_size": 20, "lines_coords": [[[388.0, 655.0], [408.0, 655.0], [408.0, 741.0], [388.0, 741.0]]], "lines": ["．．．．．．おう。"]}, {"box": [60, 799, 137, 915], "vertical": true, "font_size": 22, "lines_coords": [[[111.0, 799.0], [137.0, 799.0], [137.0, 862.0], [111.0, 862.0]], [[87.0, 800.0], [107.0, 800.0], [107.0, 915.0], [87.0, 915.0]], [[60.0, 802.0], [80.0, 802.0], [80.0, 897.0], [60.0, 897.0]]], "lines": ["あの時", "パーを出して", "いれば．．．"]}, {"box": [340, 941, 416, 1096], "vertical": true, "font_size": 21, "lines_coords": [[[392.0, 941.0], [416.0, 941.0], [416.0, 1008.0], [392.0, 1008.0]], [[367.0, 942.0], [387.0, 942.0], [387.0, 1096.0], [367.0, 1096.0]], [[340.0, 943.0], [360.0, 943.0], [360.0, 1065.0], [340.0, 1065.0]]], "lines": ["芽衣子、", "ヒマならメシでも", "食いに来いよ。"]}, {"box": [139, 971, 214, 1088], "vertical": true, "font_size": 20, "lines_coords": [[[192.0, 972.0], [211.0, 972.0], [211.0, 1088.0], [192.0, 1088.0]], [[166.0, 972.0], [186.0, 972.0], [186.0, 1069.0], [166.0, 1069.0]], [[139.0, 971.0], [159.0, 971.0], [159.0, 1059.0], [139.0, 1059.0]]], "lines": ["実はこれから", "ウチに人が", "来るんだ。"]}, {"box": [72, 1078, 97, 1141], "vertical": true, "font_size": 25, "lines_coords": [[[72.0, 1078.0], [97.0, 1078.0], [97.0, 1141.0], [72.0, 1141.0]]], "lines": ["誰よ？"]}], "img_path": "055.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "im