": ["．．．"]}, {"box": [63, 45, 174, 67], "vertical": false, "font_size": 20, "lines_coords": [[[63.0, 48.0], [174.0, 45.0], [174.0, 65.0], [63.0, 67.0]]], "lines": ["ソラニンに"]}, {"box": [573, 292, 724, 350], "vertical": false, "font_size": 47, "lines_coords": [[[573.0, 303.0], [721.0, 292.0], [724.0, 339.0], [577.0, 350.0]]], "lines": ["明太子"]}, {"box": [448, 327, 468, 443], "vertical": true, "font_size": 17, "lines_coords": [[[449.0, 328.0], [466.0, 328.0], [466.0, 441.0], [449.0, 441.0]]], "lines": ["．．．食べます？"]}, {"box": [693, 850, 717, 932], "vertical": true, "font_size": 24, "lines_coords": [[[693.0, 850.0], [717.0, 850.0], [717.0, 932.0], [693.0, 932.0]]], "lines": ["でも．．．．．．"]}, {"box": [358, 591, 442, 753], "vertical": true, "font_size": 26, "lines_coords": [[[414.0, 591.0], [442.0, 591.0], [442.0, 753.0], [414.0, 753.0]], [[389.0, 594.0], [413.0, 594.0], [413.0, 714.0], [389.0, 714.0]], [[358.0, 592.0], [385.0, 591.0], [387.0, 645.0], [360.0, 646.0]]], "lines": ["ああ、いいですよ", "僕がやります", "から。"]}, {"box": [357, 1013, 436, 1086], "vertical": true, "font_size": 28, "lines_coords": [[[412.0, 1013.0], [436.0, 1013.0], [436.0, 1080.0], [412.0, 1080.0]], [[384.0, 1013.0], [414.0, 1013.0], [414.0, 1076.0], [384.0, 1076.0]], [[357.0, 1013.0], [386.0, 1013.0], [386.0, 1086.0], [357.0, 1086.0]]], "lines": ["ははは、", "任せて", "任せて。"]}], "img_path": "057.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [416, 107, 498, 252], "vertical": true, "font_size": 24, "lines_coords": [[[474.0, 108.0], [498.0, 108.0], [498.0, 169.0], [474.0, 169.0]], [[447.0, 108.0], [471.0, 108.0], [471.0, 208.0], [447.0, 208.0]], [[420.0, 107.0], [445.0, 107.0], [441.0, 247.0], [416.0, 247.0]]], "lines": ["種品の", "お父さんと", "ゴハン食べてる"]}, {"box": [329, 109, 352, 217], "vertical": true, "font_size": 20, "lines_coords": [[[330.0, 110.0], [350.0, 110.0], [350.0, 214.0], [330.0, 214.0]]], "lines": ["．．．変な感じ。"]}, {"box": [108, 107, 244, 228], "vertical": true, "font_size": 25, "lines_coords": [[[213.0, 107.0], [244.0, 107.0], [244.0, 161.0], [213.0, 161.0]], [[190.0, 111.0], [211.0, 111.0], [211.0, 188.0], [190.0, 188.0]], [[161.0, 110.0], [185.0, 110.0], [185.0, 228.0], [161.0, 228.0]], [[133.0, 110.0], [159.0, 110.0], [159.0, 191.0], [133.0, 191.0]], [[108.0, 111.0], [129.0, 111.0], [129.0, 215.0], [108.0, 215.0]]], "lines": ["でも、", "会ったの", "二度目なのに", "不思議と", "落ちつくな。"]}, {"box": [129, 332, 179, 452], "vertical": true, "font_size": 21, "lines_coords": [[[158.0, 332.0], [178.0, 332.0], [175.0, 452.0], [155.0, 452.0]], [[129.0, 333.0], [151.0, 333.0], [151.0, 401.0], [129.0, 401.0]]], "lines": ["料理されるん", "ですね。"]}, {"box": [644, 567, 746, 708], "vertical": true, "font_size": 21, "lines_coords": [[[726.0, 623.0], [745.0, 623.0], [745.0, 690.0], [726.0, 690.0]], [[724.0, 570.0], [745.0, 570.0], [745.0, 630.0], [724.0, 630.0]], [[696.0, 567.0], [721.0, 567.0], [719.0, 707.0], [694.0, 707.0]], [[669.0, 569.0], [693.0, 569.0], [693.0, 708.0], [669.0, 708.0]], [[644.0, 571.0], [660.0, 571.0], [660.0, 631.0], [644.0, 631.0]]], "lines": ["―今", "いやー", "母さん、心労で", "弱っちゃってる", "からわ"]}, {"box": [230, 574, 283, 721], "vertical": true, "font_size": 22, "lines_coords": [[[251.0, 574.0], [283.0, 574.0], [283.0, 624.0], [251.0, 624.0]], [[230.0, 578.0], [250.0, 578.0], [250.0, 721.0], [230.0, 721.0]]], "lines": ["僕は", "仕事人間だから、"]}, {"box": [106, 689, 208, 835], "vertical": true, "font_size": 22, "lines_coords": [[[186.0, 689.0], [206.0, 689.0], [208.0, 808.0], [188.0, 808.0]], [[162.0, 691.0], [179.0, 691.0], [179.0, 823.0], [162.0, 823.0]], [[133.0, 690.0], [153.0, 690.0], [153.0, 808.0], [133.0, 808.0]], [[106.0, 690.0], [126.0, 690.0], [127.0, 835.0], [107.0, 835.0]]], "lines": ["ふた月前まで", "自分の湯飲みの", "場所も知らな", "かったくらいで。"]}, {"box": [154, 951, 258, 1117], "vertical": true, "font_size": 22, "lines_coords": [[[234.0, 951.0], [258.0, 951.0], [258.0, 1018.0], [234.0, 1018.0]], [[207.0, 951.0], [228.0, 951.0], [229.0, 1117.0], [208.0, 1117.0]], [[181.0, 951.0], [202.0, 951.0], [200.0, 1051.0], [179.0, 1051.0]], [[154.0, 952.0], [174.0, 952.0], [174.0, 1038.0], [154.0, 1038.0]]], "lines": ["変な話、", "今になってやっと", "家族らしく", "なったよ。"]}], "img_path": "058.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [666, 110, 710, 250], "vertical": true, "font_size": 19, "lines_coords": [[[694.0, 111.0], [710.0, 111.0], [710.0, 228.0], [694.0, 228.0]], [[666.0, 110.0], [686.0, 110.0], [686.0, 250.0], [666.0, 250.0]]], "lines": ["昔から冷めた", "家庭だったから、"]}, {"box": [578, 201, 625, 366], "vertical": true, "font_size": 19, "lines_coords": [[[605.0, 201.0], [625.0, 201.0], [625.0, 300.0], [605.0, 300.0]], [[578.0, 201.0], [598.0, 201.0], [599.0, 366.0], [579.0, 366.0]]], "lines": ["僕はあまり", "家にいなかったし。"]}, {"box": [91, 185, 193, 375], "vertical": true, "font_size": 20, "lines_coords": [[[172.0, 186.0], [192.0, 186.0], [192.0, 303.0], [172.0, 303.0]], [[144.0, 185.0], [163.0, 185.0], [163.0, 308.0], [144.0, 308.0]], [[117.0, 186.0], [137.0, 186.0], [137.0, 343.0], [117.0, 343.0]], [[91.0, 186.0], [111.0, 186.0], [111.0, 375.0], [91.0, 375.0]]], "lines": ["だから久々に", "成男の顔見て、", "悲しいというより", "びっくりしちゃってね。"]}, {"box": [211, 455, 236, 598], "vertical": true, "font_size": 21, "lines_coords": [[[213.0, 455.0], [236.0, 455.0], [236.0, 491.0], [213.0, 491.0]], [[211.0, 493.0], [236.0, 493.0], [236.0, 598.0], [211.0, 598.0]]], "lines": ["あー", "ーこいつ、"]}, {"box": [593, 759, 666, 897], "vertical": true, "font_size": 19, "lines_coords": [[[644.0, 759.0], [666.0, 759.0], [666.0, 794.0], [644.0, 794.0]], [[618.0, 761.0], [638.0, 761.0], [637.0, 897.0], [617.0, 897.0]], [[593.0, 761.0], [608.0, 761.0], [608.0, 868.0], [593.0, 868.0]]], "lines": ["まー", "当たり前のこと", "なんだけど。"]}, {"box": [493, 747, 559, 866], "vertical": true, "font_size": 23, "lines_coords": [[[525.0, 751.0], [551.0, 750.0], [556.0, 833.0], [530.0, 834.0]], [[505.0, 751.0], [531.0, 747.0], [538.0, 801.0], [512.0, 805.0]], [[493.0, 752.0], [510.0, 751.0], [514.0, 823.0], [496.0, 825.0]]], "lines": ["女になって", "もっと", "びっくりだ"]}, {"box": [104, 530, 178, 673], "vertical": true, "font_size": 21, "lines_coords": [[[158.0, 530.0], [178.0, 530.0], [178.0, 648.0], [158.0, 648.0]], [[129.0, 530.0], [151.0, 530.0], [151.0, 629.0], [129.0, 629.0]], [[104.0, 530.0], [121.0, 530.0], [122.0, 673.0], [105.0, 673.0]]], "lines": ["いつのまにか", "大人の男に", "なってるよって。"]}, {"box": [118, 846, 141, 910], "vertical": true, "font_size": 21, "lines_coords": [[[118.0, 847.0], [139.0, 846.0], [141.0, 909.0], [120.0, 910.0]]], "lines": ["あぁ、"]}, {"box": [92, 823, 113, 890], "vertical": true, "font_size": 21, "lines_coords": [[[92.0, 823.0], [113.0, 823.0], [113.0, 890.0], [92.0, 890.0]]], "lines": ["そうか。"]}, {"box": [345, 998, 423, 1105], "vertical": true, "font_size": 25, "lines_coords": [[[394.0, 998.0], [423.0, 998.0], [423.0, 1062.0], [394.0, 1062.0]], [[368.0, 999.0], [394.0, 999.0], [394.0, 1081.0], [368.0, 1081.0]], [[345.0, 1000.0], [365.0, 1000.0], [365.0, 1105.0], [345.0, 1105.0]]], "lines": ["種田と", "雰囲気が", "似てるんだ。"]}, {"box": [76, 1012, 152, 1148], "vertical": true, "font_size": 20, "lines_coords": [[[127.0, 1012.0], [152.0, 1012.0], [152.0, 1080.0], [127.0, 1080.0]], [[101.0, 1014.0], [121.0, 1014.0], [121.0, 1112.0], [101.0, 1112.0]], [[77.0, 1017.0], [93.0, 1017.0], [93.0, 1148.0], [77.0, 1148.0]]], "lines": ["．．．あれ、", "芽衣子さん", "ギターやるの？"]}], "img_path": "059.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [560, 64, 608, 171], "vertical": true, "font_size": 20, "lines_coords": [[[587.0, 64.0], [607.0, 64.0], [607.0, 164.0], [587.0, 164.0]], [[560.0, 65.0], [580.0, 65.0], [580.0, 171.0], [560.0, 171.0]]], "lines": ["．．．あ、それ", "種田のです。"]}, {"box": [153, 86, 201, 213], "vertical": true, "font_size": 20, "lines_coords": [[[181.0, 87.0], [201.0, 87.0], [201.0, 172.0], [181.0, 172.0]], [[153.0, 86.0], [173.0, 86.0], [174.0, 213.0], [154.0, 213.0]]], "lines": ["．．．ははは、", "思い出すなぁ。"]}, {"box": [680, 509, 784, 685], "vertical": true, "font_size": 21, "lines_coords": [[[761.0, 509.0], [784.0, 509.0], [784.0, 666.0], [761.0, 666.0]], [[734.0, 509.0], [757.0, 509.0], [757.0, 649.0], [734.0, 649.0]], [[707.0, 509.0], [727.0, 509.0], [729.0, 685.0], [709.0, 685.0]], [[680.0, 510.0], [701.0, 510.0], [701.0, 611.0], [680.0, 611.0]]], "lines": ["あいつ、東京出て", "バイトしながら", "音楽やるって言って", "きかなくて、"]}, {"box": [113, 277, 216, 423], "vertical": true, "font_size": 20, "lines_coords": [[[194.0, 277.0], [215.0, 277.0], [216.0, 420.0], [195.0, 420.0]], [[167.0, 281.0], [188.0, 281.0], [188.0, 359.0], [167.0, 359.0]], [[142.0, 280.0], [159.0, 280.0], [159.0, 396.0], [142.0, 396.0]], [[113.0, 278.0], [133.0, 278.0], [133.0, 423.0], [113.0, 423.0]]], "lines": ["成男が高３の時、", "一度だけ", "進路のことで", "大ゲンカしてね。"]}, {"box": [567, 631, 669, 827], "vertical": true, "font_size": 21, "lines_coords": [[[649.0, 632.0], [669.0, 632.0], [669.0, 768.0], [649.0, 768.0]], [[621.0, 633.0], [641.0, 633.0], [641.0, 827.0], [621.0, 827.0]], [[591.0, 631.0], [614.0, 631.0], [614.0, 789.0], [591.0, 789.0]], [[567.0, 633.0], [587.0, 633.0], [587.0, 778.0], [567.0, 778.0]]], "lines": ["僕自身は中卒の", "コンブレックスがある", "から、大学行って", "ほしかったんだ。"]}, {"box": [194, 556, 267, 663], "vertical": true, "font_size": 21, "lines_coords": [[[250.0, 558.0], [267.0, 558.0], [267.0, 655.0], [250.0, 655.0]], [[216.0, 556.0], [245.0, 556.0], [245.0, 621.0], [216.0, 621.0]], [[194.0, 557.0], [214.0, 557.0], [214.0, 663.0], [194.0, 663.0]]], "lines": ["そりゃもう", "一晩中", "殴り合って、"]}, {"box": [114, 707, 216, 847], "vertical": true, "font_size": 21, "lines_coords": [[[196.0, 707.0], [216.0, 707.0], [216.0, 788.0], [196.0, 788.0]], [[170.0, 710.0], [190.0, 710.0], [190.0, 827.0], [170.0, 827.0]], [[144.0, 710.0], [163.0, 710.0], [163.0, 847.0], [144.0, 847.0]], [[114.0, 708.0], [134.0, 708.0], [137.0, 795.0], [117.0, 795.0]]], "lines": ["．．．明け方", "僕の卍固めが", "完全にきまった", "時かなぁ、"]}, {"box": [727, 875, 776, 999], "vertical": true, "font_size": 19, "lines_coords": [[[750.0, 875.0], [776.0, 875.0], [776.0, 938.0], [750.0, 938.0]], [[727.0, 878.0], [743.0, 878.0], [743.0, 999.0], [727.0, 999.0]]], "lines": ["言って", "やったんだよ。"]}, {"box": [587, 967, 690, 1114], "vertical": true, "font_size": 19, "lines_coords": [[[671.0, 969.0], [690.0, 969.0], [690.0, 1086.0], [671.0, 1086.0]], [[642.0, 967.0], [662.0, 967.0], [662.0, 1088.0], [642.0, 1088.0]], [[617.0, 970.0], [633.0, 970.0], [633.0, 1106.0], [617.0, 1106.0]], [[587.0, 967.0], [607.0, 967.0], [608.0, 1114.0], [589.0, 1114.0]]], "lines": ["大学卒業して", "それでも音楽", "やりたいんなら", "勝手にしろって。"]}, {"box": [152, 1006, 173, 1131], "vertical": true, "font_size": 20, "lines_coords": [[[152.0, 1006.0], [172.0, 1006.0], [172.0, 1129.0], [152.0, 1129.0]]], "lines": ["．．．そのかわり、"]}], "img_path": "060.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [653, 84, 672, 207], "vertical": true, "font_size": 16, "lines_coords": [[[653.0, 85.0], [669.0, 85.0], [669.0, 203.0], [653.0, 203.0]]], "lines": ["やるからには"]}, {"box": [105, 117, 183, 256], "vertical": true, "font_size": 22, "lines_coords": [[[152.0, 117.0], [183.0, 117.0], [183.0, 166.0], [152.0, 166.0]], [[131.0, 120.0], [151.0, 120.0], [151.0, 256.0], [131.0, 256.0]], [[105.0, 121.0], [121.0, 121.0], [121.0, 247.0], [105.0, 247.0]]], "lines": ["絶対", "逃げ出すんじゃ", "ないぞってね。"]}, {"box": [626, 454, 726, 631], "vertical": true, "font_size": 19, "lines_coords": [[[703.0, 454.0], [724.0, 454.0], [726.0, 574.0], [705.0, 574.0]], [[680.0, 458.0], [696.0, 458.0], [696.0, 591.0], [680.0, 591.0]], [[651.0, 455.0], [671.0, 455.0], [672.0, 631.0], [652.0, 631.0]], [[626.0, 458.0], [642.0, 458.0], [642.0, 560.0], [626.0, 560.0]]], "lines": ["．．．父親らしい", "そんなセリフに", "僕自身酔っちゃって", "たんだけど、"]}, {"box": [700, 696, 720, 793], "vertical": true, "font_size": 21, "lines_coords": [[[700.0, 696.0], [720.0, 696.0], [720.0, 793.0], [700.0, 793.0]]], "lines": ["．．．．．あの．．．"]}, {"box": [526, 551, 601, 649], "vertical": true, "font_size": 19, "lines_coords": [[[582.0, 551.0], [601.0, 551.0], [601.0, 637.0], [582.0, 637.0]], [[553.0, 551.0], [575.0, 551.0], [575.0, 649.0], [553.0, 649.0]], [[526.0, 551.0], [546.0, 551.0], [546.0, 637.0], [526.0, 637.0]]], "lines": ["．．．アイツ、", "真に受けて", "たのかな。"]}, {"box": [598, 761, 673, 902], "vertical": true, "font_size": 21, "lines_coords": [[[653.0, 762.0], [673.0, 762.0], [673.0, 862.0], [653.0, 862.0]], [[624.0, 761.0], [647.0, 761.0], [647.0, 902.0], [624.0, 902.0]], [[598.0, 764.0], [618.0, 764.0], [618.0, 850.0], [598.0, 850.0]]], "lines": ["お父さんと", "種田は似てると", "思います。"]}, {"box": [106, 540, 182, 664], "vertical": true, "font_size": 19, "lines_coords": [[[162.0, 542.0], [179.0, 542.0], [179.0, 662.0], [162.0, 662.0]], [[133.0, 541.0], [153.0, 541.0], [153.0, 639.0], [133.0, 639.0]], [[106.0, 541.0], [126.0, 541.0], [126.0, 646.0], [106.0, 646.0]]], "lines": ["あれでアイツ。", "馬鹿正直な", "奴だからね。"]}, {"box": [141, 820, 217, 939], "vertical": true, "font_size": 20, "lines_coords": [[[194.0, 820.0], [217.0, 820.0], [217.0, 939.0], [194.0, 939.0]], [[168.0, 822.0], [188.0, 822.0], [188.0, 939.0], [168.0, 939.0]], [[141.0, 821.0], [161.0, 821.0], [161.0, 909.0], [141.0, 909.0]]], "lines": ["きっと、頭の", "作りが不器用", "なんだよ。"]}, {"box": [712, 958, 728, 978], "vertical": true, "font_size": 18, "lines_coords": [[[712.0, 958.0], [728.0, 958.0], [728.0, 978.0], [712.0, 978.0]]], "lines": ["ん"]}, {"box": [654, 1030, 675, 1100], "vertical": true, "font_size": 18, "lines_coords": [[[654.0, 1030.0], [675.0, 1030.0], [675.0, 1100.0], [654.0, 1100.0]]], "lines": ["そうね。"]}, {"box": [348, 1004, 426, 1141], "vertical": true, "font_size": 22, "lines_coords": [[[405.0, 1008.0], [425.0, 1008.0], [425.0, 1141.0], [405.0, 1141.0]], [[378.0, 1006.0], [398.0, 1006.0], [398.0, 1122.0], [378.0, 1122.0]], [[348.0, 1004.0], [373.0, 1004.0], [373.0, 1073.0], [348.0, 1073.0]]], "lines": ["一つのことしか", "てきない感じ", "とかね。"]}, {"box": [134, 1013, 151, 1119], "vertical": true, "font_size": 20, "lines_coords": [[[134.0, 1013.0], [151.0, 1013.0], [151.0, 1119.0], [134.0, 1119.0]]], "lines": ["僕も成男も。"]}], "img_path": "061.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [651, 78, 727, 224], "vertical": true, "font_size": 20, "lines_coords": [[[705.0, 78.0], [724.0, 78.0], [727.0, 196.0], [707.0, 196.0]], [[678.0, 79.0], [699.0, 79.0], [699.0, 159.0], [678.0, 159.0]], [[651.0, 80.0], [671.0, 80.0], [671.0, 223.0], [651.0, 223.0]]], "lines": ["．．．じゃ、僕は", "そろそろ", "おいとまします。"]}, {"box": [485, 75, 536, 174], "vertical": true, "font_size": 22, "lines_coords": [[[507.0, 75.0], [536.0, 75.0], [536.0, 139.0], [507.0, 139.0]], [[486.0, 79.0], [502.0, 79.0], [502.0, 173.0], [486.0, 173.0]]], "lines": ["種田の", "荷物は．．．"]}, {"box": [92, 39, 245, 166], "vertical": true, "font_size": 21, "lines_coords": [[[215.0, 46.0], [245.0, 46.0], [245.0, 100.0], [215.0, 100.0]], [[193.0, 50.0], [214.0, 50.0], [214.0, 147.0], [193.0, 147.0]], [[166.0, 49.0], [186.0, 49.0], [186.0, 166.0], [166.0, 166.0]], [[141.0, 49.0], [158.0, 49.0], [158.0, 153.0], [141.0, 153.0]], [[92.0, 42.0], [110.0, 39.0], [120.0, 118.0], [103.0, 120.0]]], "lines": ["いやー", "おいそれと", "持ち帰れる量", "じゃないし、", "いらなきゃ"]}, {"box": [73, 191, 175, 348], "vertical": true, "font_size": 21, "lines_coords": [[[155.0, 192.0], [175.0, 192.0], [175.0, 330.0], [155.0, 330.0]], [[129.0, 193.0], [146.0, 193.0], [146.0, 348.0], [129.0, 348.0]], [[99.0, 191.0], [122.0, 191.0], [122.0, 309.0], [99.0, 309.0]], [[73.0, 193.0], [93.0, 193.0], [93.0, 278.0], [73.0, 278.0]]], "lines": ["この部屋の物は", "まだ芽衣子さんと", "一緒にいたい", "みたいだ"]}, {"box": [448, 369, 491, 476], "vertical": true, "font_size": 17, "lines_coords": [[[449.0, 370.0], [466.0, 370.0], [466.0, 475.0], [449.0, 475.0]]], "lines": ["すみません。"]}, {"box": [120, 404, 170, 521], "vertical": true, "font_size": 23, "lines_coords": [[[141.0, 404.0], [170.0, 404.0], [170.0, 471.0], [141.0, 471.0]], [[120.0, 406.0], [137.0, 406.0], [137.0, 521.0], [120.0, 521.0]]], "lines": ["なんで", "あやまるの？"]}, {"box": [715, 808, 731, 944], "vertical": true, "font_size": 17, "lines_coords": [[[715.0, 808.0], [731.0, 808.0], [731.0, 944.0], [715.0, 944.0]]], "lines": ["．．．なんていうか"]}, {"box": [639, 929, 683, 1031], "vertical": true, "font_size": 17, "lines_coords": [[[664.0, 929.0], [683.0, 929.0], [683.0, 1028.0], [664.0, 1028.0]], [[639.0, 931.0], [655.0, 931.0], [655.0, 1031.0], [639.0, 1031.0]]], "lines": ["あたしさえ", "いなければ"]}, {"box": [123, 937, 200, 1132], "vertical": true, "font_size": 21, "lines_coords": [[[174.0, 937.0], [200.0, 937.0], [200.0, 999.0], [174.0, 999.0]], [[149.0, 937.0], [169.0, 937.0], [169.0, 1132.0], [149.0, 1132.0]], [[125.0, 938.0], [141.0, 938.0], [141.0, 1113.0], [125.0, 1113.0]]], "lines": ["種田は", "こんなことにならずに", "済んだのかなって．．．"]}], "img_path": "062.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [682, 89, 702, 179], "vertical": true, "font_size": 20, "lines_coords": [[[682.0, 89.0], [702.0, 89.0], [702.0, 179.0], [682.0, 179.0]]], "lines": ["．．．違うよ。"]}, {"box": [380, 80, 484, 257], "vertical": true, "font_size": 21, "lines_coords": [[[463.0, 82.0], [483.0, 82.0], [483.0, 257.0], [463.0, 257.0]], [[436.0, 82.0], [456.0, 82.0], [456.0, 200.0], [436.0, 200.0]], [[408.0, 80.0], [428.0, 80.0], [428.0, 217.0], [408.0, 217.0]], [[380.0, 80.0], [405.0, 80.0], [405.0, 151.0], [380.0, 151.0]]], "lines": ["．．．：８月の終わり頃", "成男が珍しく", "電話をよこして", "きてね、"]}, {"box": [72, 158, 147, 284], "vertical": true, "font_size": 19, "lines_coords": [[[124.0, 158.0], [147.0, 158.0], [147.0, 277.0], [124.0, 277.0]], [[98.0, 159.0], [118.0, 159.0], [118.0, 277.0], [98.0, 277.0]], [[72.0, 159.0], [87.0, 159.0], [87.0, 280.0], [72.0, 280.0]]], "lines": ["突然、福岡に", "戻るなんて話", "したしたんだ"]}, {"box": [543, 446, 590, 570], "vertical": true, "font_size": 20, "lines_coords": [[[570.0, 446.0], [590.0, 446.0], [590.0, 569.0], [570.0, 569.0]], [[543.0, 446.0], [563.0, 446.0], [563.0, 550.0], [543.0, 550.0]]], "lines": ["それは違うよ、", "芽衣子さん。"]}, {"box": [165, 337, 241, 493], "vertical": true, "font_size": 22, "lines_coords": [[[221.0, 337.0], [241.0, 337.0], [241.0, 438.0], [221.0, 438.0]], [[193.0, 337.0], [216.0, 337.0], [216.0, 493.0], [193.0, 493.0]], [[165.0, 337.0], [189.0, 337.0], [189.0, 406.0], [165.0, 406.0]]], "lines": ["．．．そしたら", "事故の５日くらい", "前かな、"]}, {"box": [46, 406, 149, 547], "vertical": true, "font_size": 22, "lines_coords": [[[129.0, 406.0], [149.0, 406.0], [149.0, 547.0], [129.0, 547.0]], [[101.0, 407.0], [125.0, 407.0], [125.0, 546.0], [101.0, 546.0]], [[76.0, 407.0], [96.0, 407.0], [96.0, 543.0], [76.0, 543.0]], [[49.0, 406.0], [69.0, 406.0], [66.0, 513.0], [46.0, 513.0]]], "lines": ["また電話あって、", "やっぱりその話", "忘れてくれって", "言うんだよ。"]}, {"box": [133, 623, 232, 813], "vertical": true, "font_size": 24, "lines_coords": [[[200.0, 623.0], [223.0, 623.0], [223.0, 778.0], [200.0, 778.0]], [[168.0, 624.0], [192.0, 624.0], [192.0, 813.0], [168.0, 813.0]], [[133.0, 624.0], [156.0, 624.0], [159.0, 741.0], [135.0, 741.0]]], "lines": ["「東京で大切な", "ものが見つかった", "から」って。"]}, {"box": [623, 929, 697, 1103], "vertical": true, "font_size": 18, "lines_coords": [[[678.0, 930.0], [697.0, 930.0], [697.0, 1103.0], [678.0, 1103.0]], [[651.0, 930.0], [671.0, 930.0], [671.0, 1058.0], [651.0, 1058.0]], [[624.0, 929.0], [644.0, 929.0], [642.0, 1092.0], [623.0, 1092.0]]], "lines": ["あーそうかいって", "適当に僕電話", "切っちゃったけど、"]}, {"box": [490, 997, 591, 1154], "vertical": true, "font_size": 18, "lines_coords": [[[570.0, 997.0], [591.0, 997.0], [591.0, 1078.0], [570.0, 1078.0]], [[544.0, 999.0], [560.0, 999.0], [560.0, 1154.0], [544.0, 1154.0]], [[517.0, 999.0], [534.0, 999.0], [534.0, 1134.0], [517.0, 1134.0]], [[490.0, 999.0], [507.0, 999.0], [507.0, 1142.0], [490.0, 1142.0]]], "lines": ["ずいぶん", "格好いいこと言う", "男になったんだ", "なって思ったな。"]}, {"box": [66, 999, 168, 1134], "vertical": true, "font_size": 19, "lines_coords": [[[149.0, 999.0], [166.0, 999.0], [166.0, 1134.0], [149.0, 1134.0]], [[120.0, 999.0], [140.0, 999.0], [140.0, 1115.0], [120.0, 1115.0]], [[94.0, 1000.0], [111.0, 1000.0], [111.0, 1115.0], [94.0, 1115.0]], [[66.0, 1000.0], [87.0, 1000.0], [87.0, 1078.0], [66.0, 1078.0]]], "lines": ["．．．きっとそれは", "芽衣子さんの", "おかげなんて", "しょう？"]}], "img_path": "063.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [658, 87, 680, 192], "vertical": true, "font_size": 20, "lines_coords": [[[658.0, 89.0], [678.0, 89.0], [680.0, 189.0], [660.0, 189.0]]], "lines": ["．．．．．．でもね、"]}, {"box": [142, 111, 246, 229], "vertical": true, "font_size": 20, "lines_coords": [[[224.0, 111.0], [245.0, 111.0], [245.0, 192.0], [224.0, 192.0]], [[197.0, 111.0], [217.0, 111.0], [217.0, 228.0], [197.0, 228.0]], [[170.0, 112.0], [190.0, 112.0], [190.0, 229.0], [170.0, 229.0]], [[142.0, 112.0], [163.0, 112.0], [163.0, 175.0], [142.0, 175.0]]], "lines": ["それでも", "芽衣子さんが", "責任を感じて", "るなら"]}, {"box": [644, 341, 718, 487], "vertical": true, "font_size": 20, "lines_coords": [[[697.0, 341.0], [717.0, 341.0], [717.0, 459.0], [697.0, 459.0]], [[671.0, 342.0], [690.0, 342.0], [690.0, 441.0], [671.0, 441.0]], [[644.0, 342.0], [664.0, 342.0], [664.0, 486.0], [644.0, 486.0]]], "lines": ["どうか成男を", "忘れないで", "やってください。"]}, {"box": [690, 698, 765, 862], "vertical": true, "font_size": 19, "lines_coords": [[[744.0, 699.0], [764.0, 699.0], [764.0, 816.0], [744.0, 816.0]], [[717.0, 698.0], [737.0, 698.0], [737.0, 816.0], [717.0, 816.0]], [[690.0, 699.0], [707.0, 699.0], [707.0, 856.0], [690.0, 856.0]]], "lines": ["アイツがいた", "ということを", "証明し続けるのが"]}, {"box": [373, 1005, 449, 1126], "vertical": true, "font_size": 20, "lines_coords": [[[429.0, 1007.0], [449.0, 1007.0], [449.0, 1086.0], [429.0, 1086.0]], [[401.0, 1007.0], [421.0, 1007.0], [421.0, 1126.0], [401.0, 1126.0]], [[373.0, 1005.0], [393.0, 1005.0], [395.0, 1095.0], [375.0, 1095.0]]], "lines": ["あなたの", "役割なのかも", "しれない。"]}, {"box": [92, 1004, 196, 1121], "vertical": true, "font_size": 21, "lines_coords": [[[174.0, 1004.0], [194.0, 1004.0], [194.0, 1083.0], [174.0, 1083.0]], [[148.0, 1004.0], [168.0, 1004.0], [168.0, 1121.0], [148.0, 1121.0]], [[121.0, 1004.0], [141.0, 1004.0], [141.0, 1121.0], [121.0, 1121.0]], [[92.0, 1004.0], [117.0, 1004.0], [117.0, 1075.0], [92.0, 1075.0]]], "lines": ["．．．今度は", "芽衣子さんが", "ウチに遊びに", "おいで。"]}], "img_path": "064.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [134, 228, 193, 444], "vertical": true, "font_size": 24, "lines_coords": [[[168.0, 229.0], [193.0, 229.0], [189.0, 439.0], [165.0, 439.0]], [[134.0, 230.0], [158.0, 230.0], [158.0, 442.0], [134.0, 442.0]]], "lines": ["：種田がいたことを", "証明し続けること："]}], "img_path": "065.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [617, 896, 678, 1110], "vertical": true, "font_size": 27, "lines_coords": [[[647.0, 896.0], [678.0, 896.0], [678.0, 972.0], [647.0, 972.0]], [[618.0, 897.0], [641.0, 897.0], [641.0, 1110.0], [618.0, 1110.0]]], "lines": ["それが", "あたしの役割：：：？"]}, {"box": [92, 1006, 166, 1106], "vertical": true, "font_size": 21, "lines_coords": [[[146.0, 1008.0], [166.0, 1008.0], [166.0, 1087.0], [146.0, 1087.0]], [[117.0, 1006.0], [141.0, 1006.0], [141.0, 1072.0], [117.0, 1072.0]], [[92.0, 1008.0], [112.0, 1008.0], [112.0, 1106.0], [92.0, 1106.0]]], "lines": ["宇宙を．．．", "宇宙を", "感じるよ！！"]}], "img_path": "066.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "067.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [], "img_path": "068.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [185, 67, 204, 148], "vertical": true, "font_size": 19, "lines_coords": [[[185.0, 67.0], [202.0, 67.0], [204.0, 148.0], [187.0, 148.0]]], "lines": ["小谷さん"]}, {"box": [137, 214, 185, 332], "vertical": true, "font_size": 19, "lines_coords": [[[163.0, 214.0], [185.0, 214.0], [185.0, 295.0], [163.0, 295.0]], [[137.0, 215.0], [156.0, 215.0], [156.0, 332.0], [137.0, 332.0]]], "lines": ["ちょっと", "いいかしら？"]}, {"box": [658, 405, 709, 522], "vertical": true, "font_size": 24, "lines_coords": [[[689.0, 406.0], [709.0, 406.0], [709.0, 522.0], [689.0, 522.0]], [[658.0, 405.0], [685.0, 405.0], [685.0, 455.0], [658.0, 455.0]]], "lines": ["．．．なんですか", "店長。"]}, {"box": [398, 506, 415, 537], "vertical": false, "font_size": 31, "lines_coords": [[[398.0, 506.0], [415.0, 506.0], [415.0, 537.0], [398.0, 537.0]]], "lines": ["乳首む"]}, {"box": [375, 499, 402, 592], "vertical": true, "font_size": 22, "lines_coords": [[[375.0, 500.0], [397.0, 499.0], [402.0, 591.0], [381.0, 592.0]]], "lines": ["出てます"]}, {"box": [604, 693, 736, 898], "vertical": true, "font_size": 21, "lines_coords": [[[715.0, 694.0], [735.0, 694.0], [735.0, 829.0], [715.0, 829.0]], [[687.0, 696.0], [708.0, 696.0], [708.0, 793.0], [687.0, 793.0]], [[659.0, 693.0], [680.0, 693.0], [681.0, 889.0], [660.0, 889.0]], [[632.0, 694.0], [655.0, 694.0], [655.0, 853.0], [632.0, 853.0]], [[604.0, 693.0], [624.0, 693.0], [627.0, 898.0], [607.0, 898.0]]], "lines": ["ひらたく言うと", "来年春から", "現場の販売員じゃなく", "仙台の本社に異動", "してみないかって話で。"]}, {"box": [445, 708, 519, 834], "vertical": true, "font_size": 19, "lines_coords": [[[498.0, 708.0], [518.0, 708.0], [518.0, 807.0], [498.0, 807.0]], [[470.0, 708.0], [490.0, 708.0], [490.0, 827.0], [470.0, 827.0]], [[446.0, 710.0], [462.0, 710.0], [462.0, 833.0], [446.0, 833.0]]], "lines": ["遠まわしに", "リストラ宣告", "だったりして。"]}, {"box": [76, 778, 177, 936], "vertical": true, "font_size": 21, "lines_coords": [[[154.0, 778.0], [175.0, 778.0], [176.0, 878.0], [155.0, 878.0]], [[122.0, 780.0], [147.0, 779.0], [152.0, 885.0], [127.0, 887.0]], [[100.0, 780.0], [120.0, 780.0], [121.0, 935.0], [101.0, 935.0]], [[77.0, 782.0], [93.0, 782.0], [93.0, 914.0], [77.0, 914.0]]], "lines": ["確かにもう", "いい年だし、", "いつまでも販売員", "って訳にも．．．"]}, {"box": [546, 962, 648, 1115], "vertical": true, "font_size": 18, "lines_coords": [[[626.0, 962.0], [647.0, 962.0], [647.0, 1040.0], [626.0, 1040.0]], [[601.0, 963.0], [618.0, 963.0], [618.0, 1096.0], [601.0, 1096.0]], [[575.0, 963.0], [591.0, 963.0], [591.0, 1115.0], [575.0, 1115.0]], [[548.0, 963.0], [564.0, 963.0], [564.0, 1098.0], [548.0, 1098.0]]], "lines": ["あたしに", "デスクワークと", "遠恋の両立なんて", "できるかしら．．．"]}], "img_path": "069.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [651, 117, 727, 263], "vertical": true, "font_size": 20, "lines_coords": [[[707.0, 119.0], [727.0, 119.0], [727.0, 236.0], [707.0, 236.0]], [[678.0, 117.0], [702.0, 117.0], [700.0, 200.0], [675.0, 200.0]], [[651.0, 119.0], [671.0, 119.0], [673.0, 263.0], [653.0, 263.0]]], "lines": ["こんなに街は", "人で溢れ", "かえってるのに、"]}, {"box": [110, 208, 214, 367], "vertical": true, "font_size": 22, "lines_coords": [[[190.0, 209.0], [214.0, 209.0], [214.0, 349.0], [190.0, 349.0]], [[163.0, 209.0], [187.0, 209.0], [187.0, 330.0], [163.0, 330.0]], [[138.0, 208.0], [158.0, 208.0], [158.0, 366.0], [138.0, 366.0]], [[110.0, 210.0], [131.0, 210.0], [131.0, 280.0], [110.0, 280.0]]], "lines": ["心から幸せって", "言える人って", "どれくらいいるん", "だろう。"]}, {"box": [582, 269, 653, 425], "vertical": true, "font_size": 20, "lines_coords": [[[633.0, 270.0], [653.0, 270.0], [653.0, 386.0], [633.0, 386.0]], [[607.0, 269.0], [627.0, 269.0], [627.0, 425.0], [607.0, 425.0]], [[582.0, 271.0], [598.0, 271.0], [598.0, 406.0], [582.0, 406.0]]], "lines": ["大なり小なり", "みんな悩み抱えて", "るんだろうな．．"]}, {"box": [713, 516, 734, 614], "vertical": true, "font_size": 18, "lines_coords": [[[713.0, 516.0], [730.0, 516.0], [733.0, 614.0], [715.0, 614.0]]], "lines": ["あたしは．．"]}, {"box": [121, 550, 202, 710], "vertical": true, "font_size": 23, "lines_coords": [[[172.0, 551.0], [200.0, 550.0], [202.0, 596.0], [174.0, 597.0]], [[151.0, 554.0], [170.0, 554.0], [170.0, 710.0], [151.0, 710.0]], [[124.0, 553.0], [145.0, 553.0], [142.0, 699.0], [121.0, 699.0]]], "lines": ["まぁ", "幸せではないけど", "不幸でもないか。"]}, {"box": [126, 826, 173, 933], "vertical": true, "font_size": 21, "lines_coords": [[[151.0, 826.0], [173.0, 826.0], [173.0, 881.0], [151.0, 881.0]], [[126.0, 827.0], [146.0, 827.0], [146.0, 933.0], [126.0, 933.0]]], "lines": ["わりー", "遅くなった。"]}, {"box": [513, 966, 589, 1129], "vertical": true, "font_size": 17, "lines_coords": [[[567.0, 966.0], [587.0, 966.0], [587.0, 1102.0], [567.0, 1102.0]], [[542.0, 966.0], [558.0, 966.0], [558.0, 1121.0], [542.0, 1121.0]], [[515.0, 966.0], [531.0, 966.0], [531.0, 1127.0], [515.0, 1127.0]]], "lines": ["別に加藤呼んで", "相談する程のこと", "じゃなかったかな。"]}], "img_path": "070.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [450, 50, 479, 214], "vertical": true, "font_size": 24, "lines_coords": [[[450.0, 50.0], [475.0, 50.0], [477.0, 214.0], [453.0, 214.0]]], "lines": ["気持ち悪っ！！"]}, {"box": [387, 26, 408, 120], "vertical": true, "font_size": 21, "lines_coords": [[[387.0, 29.0], [408.0, 29.0], [408.0, 120.0], [387.0, 120.0]]], "lines": ["掛けて！！"]}, {"box": [83, 135, 133, 235], "vertical": true, "font_size": 20, "lines_coords": [[[112.0, 137.0], [132.0, 137.0], [132.0, 235.0], [112.0, 235.0]], [[83.0, 135.0], [103.0, 135.0], [105.0, 222.0], [85.0, 222.0]]], "lines": ["悲しいこと", "言うなよ。"]}, {"box": [413, 287, 490, 424], "vertical": true, "font_size": 21, "lines_coords": [[[469.0, 287.0], [489.0, 287.0], [487.0, 405.0], [467.0, 405.0]], [[441.0, 288.0], [461.0, 288.0], [461.0, 424.0], [441.0, 424.0]], [[413.0, 287.0], [435.0, 287.0], [435.0, 323.0], [413.0, 323.0]]], "lines": ["面接会場から", "走ってきたのに", "よー"]}, {"box": [91, 471, 168, 589], "vertical": true, "font_size": 22, "lines_coords": [[[142.0, 471.0], [168.0, 471.0], [168.0, 534.0], [142.0, 534.0]], [[118.0, 472.0], [138.0, 472.0], [138.0, 589.0], [118.0, 589.0]], [[91.0, 472.0], [111.0, 472.0], [111.0, 569.0], [91.0, 569.0]]], "lines": ["あ．．．", "そうか今日は", "就活で．．．"]}, {"box": [616, 663, 663, 780], "vertical": true, "font_size": 18, "lines_coords": [[[645.0, 664.0], [661.0, 664.0], [661.0, 780.0], [645.0, 780.0]], [[616.0, 663.0], [635.0, 663.0], [635.0, 780.0], [616.0, 780.0]]], "lines": ["．．．どうだった", "手ごたえは？"]}, {"box": [575, 839, 630, 858], "ve