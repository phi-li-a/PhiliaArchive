0]]], "lines": ["が"]}, {"box": [210, 939, 244, 963], "vertical": false, "font_size": 24, "lines_coords": [[[210.0, 939.0], [244.0, 939.0], [244.0, 963.0], [210.0, 963.0]]], "lines": ["２５"]}, {"box": [255, 1119, 337, 1143], "vertical": false, "font_size": 20.0, "lines_coords": [[[303.0, 1121.0], [337.0, 1121.0], [337.0, 1143.0], [303.0, 1143.0]], [[255.0, 1125.0], [302.0, 1119.0], [304.0, 1137.0], [257.0, 1143.0]]], "lines": ["２８", "＃"]}], "img_path": "004.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [370, 74, 461, 240], "vertical": true, "font_size": 25, "lines_coords": [[[437.0, 75.0], [461.0, 75.0], [461.0, 193.0], [437.0, 193.0]], [[405.0, 75.0], [429.0, 75.0], [429.0, 239.0], [405.0, 239.0]], [[370.0, 75.0], [398.0, 75.0], [398.0, 195.0], [370.0, 195.0]]], "lines": ["２００Ｘ年", "世界は核の炎に", "包まれた！"]}, {"box": [142, 294, 175, 471], "vertical": true, "font_size": 24, "lines_coords": [[[151.0, 294.0], [175.0, 294.0], [175.0, 364.0], [151.0, 364.0]], [[142.0, 399.0], [167.0, 399.0], [167.0, 471.0], [142.0, 471.0]]], "lines": ["おっ！？", "おっ！？"]}, {"box": [731, 747, 753, 853], "vertical": true, "font_size": 20, "lines_coords": [[[731.0, 747.0], [753.0, 747.0], [753.0, 801.0], [731.0, 801.0]], [[731.0, 813.0], [749.0, 813.0], [749.0, 853.0], [731.0, 853.0]]], "lines": ["ずどー", "ん"]}, {"box": [194, 554, 218, 669], "vertical": true, "font_size": 21, "lines_coords": [[[195.0, 555.0], [216.0, 555.0], [216.0, 669.0], [195.0, 669.0]]], "lines": ["おおおっ！？"]}, {"box": [145, 815, 270, 979], "vertical": true, "font_size": 24, "lines_coords": [[[243.0, 817.0], [268.0, 817.0], [268.0, 956.0], [243.0, 956.0]], [[210.0, 817.0], [235.0, 817.0], [235.0, 933.0], [210.0, 933.0]], [[178.0, 815.0], [201.0, 815.0], [201.0, 979.0], [178.0, 979.0]], [[145.0, 815.0], [168.0, 815.0], [168.0, 966.0], [145.0, 966.0]]], "lines": ["なんてことは", "全然なくて", "今日もおおむね", "日本は平和だ。"]}, {"box": [679, 858, 726, 965], "vertical": true, "font_size": 20, "lines_coords": [[[705.0, 858.0], [726.0, 858.0], [726.0, 944.0], [705.0, 944.0]], [[679.0, 861.0], [699.0, 861.0], [699.0, 965.0], [679.0, 965.0]]], "lines": ["ほい占領、", "４面クリア。"]}, {"box": [366, 887, 413, 968], "vertical": true, "font_size": 21, "lines_coords": [[[392.0, 887.0], [413.0, 887.0], [413.0, 966.0], [392.0, 966.0]]], "lines": ["ちょっと"]}, {"box": [361, 885, 389, 957], "vertical": true, "font_size": 20, "lines_coords": [[[361.0, 887.0], [386.0, 885.0], [389.0, 956.0], [365.0, 957.0]]], "lines": ["種田ぁ。"]}, {"box": [326, 1011, 399, 1115], "vertical": true, "font_size": 20, "lines_coords": [[[379.0, 1011.0], [399.0, 1011.0], [399.0, 1113.0], [379.0, 1113.0]], [[351.0, 1011.0], [371.0, 1011.0], [371.0, 1110.0], [351.0, 1110.0]], [[326.0, 1012.0], [343.0, 1012.0], [343.0, 1115.0], [326.0, 1115.0]]], "lines": ["そのゲーム、", "見てて退屈", "なんだけど。"]}, {"box": [55, 1001, 152, 1127], "vertical": true, "font_size": 21, "lines_coords": [[[126.0, 1001.0], [152.0, 1001.0], [152.0, 1089.0], [126.0, 1089.0]], [[103.0, 1001.0], [124.0, 1001.0], [124.0, 1081.0], [103.0, 1081.0]], [[78.0, 1003.0], [98.0, 1003.0], [98.0, 1100.0], [78.0, 1100.0]], [[56.0, 1004.0], [72.0, 1004.0], [72.0, 1126.0], [56.0, 1126.0]]], "lines": ["あ、やべ、", "そろそろ", "スタジオに", "行かなきゃだ。"]}], "img_path": "005.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [368, 80, 489, 130], "vertical": false, "font_size": 47, "lines_coords": [[[368.0, 83.0], [488.0, 80.0], [489.0, 127.0], [370.0, 130.0]]], "lines": ["＃１５"]}, {"box": [537, 562, 648, 741], "vertical": true, "font_size": 24, "lines_coords": [[[625.0, 568.0], [645.0, 568.0], [645.0, 741.0], [625.0, 741.0]], [[596.0, 567.0], [619.0, 567.0], [619.0, 704.0], [596.0, 704.0]], [[570.0, 568.0], [590.0, 568.0], [590.0, 741.0], [570.0, 741.0]], [[537.0, 562.0], [571.0, 562.0], [571.0, 621.0], [537.0, 621.0]]], "lines": ["放射能で汚染された", "荒廃した大地に", "救世主が現れたりは", "なく、"]}, {"box": [707, 788, 754, 926], "vertical": true, "font_size": 18, "lines_coords": [[[731.0, 788.0], [751.0, 788.0], [754.0, 907.0], [734.0, 907.0]], [[708.0, 791.0], [724.0, 791.0], [724.0, 924.0], [708.0, 924.0]]], "lines": ["こんな２１世紀", "こんな現実～～"]}, {"box": [367, 566, 473, 761], "vertical": true, "font_size": 23, "lines_coords": [[[449.0, 567.0], [473.0, 567.0], [473.0, 761.0], [449.0, 761.0]], [[422.0, 567.0], [446.0, 567.0], [446.0, 724.0], [422.0, 724.0]], [[397.0, 567.0], [418.0, 567.0], [416.0, 723.0], [395.0, 723.0]], [[367.0, 566.0], [392.0, 566.0], [394.0, 671.0], [370.0, 671.0]]], "lines": ["ましてやエアカーとか", "コロニーだとかの", "未来的な雰囲気も", "全然なくて、"]}, {"box": [463, 822, 539, 959], "vertical": true, "font_size": 20, "lines_coords": [[[518.0, 823.0], [538.0, 823.0], [538.0, 921.0], [518.0, 921.0]], [[490.0, 822.0], [510.0, 822.0], [510.0, 959.0], [490.0, 959.0]], [[463.0, 822.0], [484.0, 822.0], [484.0, 921.0], [463.0, 921.0]]], "lines": ["僕らは何を", "思えばいいんだ", "ろぉ～～～"]}, {"box": [167, 564, 301, 742], "vertical": true, "font_size": 22, "lines_coords": [[[279.0, 568.0], [299.0, 568.0], [299.0, 684.0], [279.0, 684.0]], [[251.0, 568.0], [271.0, 568.0], [271.0, 723.0], [251.0, 723.0]], [[220.0, 564.0], [249.0, 564.0], [249.0, 630.0], [220.0, 630.0]], [[196.0, 566.0], [216.0, 566.0], [217.0, 741.0], [197.0, 741.0]], [[167.0, 566.0], [190.0, 566.0], [190.0, 728.0], [167.0, 728.0]]], "lines": ["災害もテロも", "運良くまぬがれた", "僕らは", "思ったよりも地味な", "未来を生きている。"]}, {"box": [121, 841, 144, 948], "vertical": true, "font_size": 20, "lines_coords": [[[121.0, 841.0], [141.0, 841.0], [144.0, 948.0], [124.0, 948.0]]], "lines": ["おい、種田！！"]}, {"box": [440, 1146, 464, 1160], "vertical": false, "font_size": 14, "lines_coords": [[[440.0, 1146.0], [464.0, 1146.0], [464.0, 1160.0], [440.0, 1160.0]]], "lines": ["．．．"]}, {"box": [76, 969, 151, 1136], "vertical": true, "font_size": 20, "lines_coords": [[[129.0, 969.0], [151.0, 969.0], [151.0, 1050.0], [129.0, 1050.0]], [[105.0, 970.0], [121.0, 970.0], [121.0, 1087.0], [105.0, 1087.0]], [[77.0, 969.0], [97.0, 969.0], [96.0, 1136.0], [76.0, 1136.0]]], "lines": ["追加料金", "とられるから", "早く片付けろって。"]}], "img_path": "006.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [648, 132, 697, 251], "vertical": true, "font_size": 22, "lines_coords": [[[672.0, 132.0], [697.0, 132.0], [697.0, 198.0], [672.0, 198.0]], [[648.0, 133.0], [668.0, 133.0], [668.0, 222.0], [648.0, 222.0]]], "lines": ["みんな、", "おつかれー"]}, {"box": [480, 84, 538, 258], "vertical": true, "font_size": 20, "lines_coords": [[[510.0, 84.0], [530.0, 84.0], [530.0, 258.0], [510.0, 258.0]], [[482.0, 84.0], [503.0, 84.0], [501.0, 189.0], [480.0, 189.0]]], "lines": ["よー、芽衣子ちゃん", "来てたんだ。"]}, {"box": [105, 93, 185, 232], "vertical": true, "font_size": 22, "lines_coords": [[[154.0, 93.0], [185.0, 93.0], [185.0, 160.0], [154.0, 160.0]], [[132.0, 97.0], [152.0, 97.0], [152.0, 232.0], [132.0, 232.0]], [[105.0, 97.0], [125.0, 97.0], [125.0, 182.0], [105.0, 182.0]]], "lines": ["ついに", "追い出しライブ", "明日だね。"]}, {"box": [53, 228, 128, 351], "vertical": true, "font_size": 22, "lines_coords": [[[107.0, 228.0], [128.0, 228.0], [128.0, 321.0], [107.0, 321.0]], [[80.0, 235.0], [100.0, 235.0], [100.0, 351.0], [80.0, 351.0]], [[53.0, 236.0], [73.0, 236.0], [73.0, 315.0], [53.0, 315.0]]], "lines": ["どうなの、", "演奏のデキの", "ほうは？"]}, {"box": [463, 378, 531, 554], "vertical": true, "font_size": 18, "lines_coords": [[[511.0, 378.0], [531.0, 378.0], [531.0, 534.0], [511.0, 534.0]], [[487.0, 379.0], [507.0, 379.0], [507.0, 554.0], [487.0, 554.0]], [[463.0, 379.0], [480.0, 379.0], [480.0, 548.0], [463.0, 548.0]]], "lines": ["まー、俺ら地味に", "３年もやってるから", "そこらへんはＯＫよ。"]}, {"box": [373, 446, 439, 610], "vertical": true, "font_size": 18, "lines_coords": [[[422.0, 446.0], [439.0, 446.0], [439.0, 561.0], [422.0, 561.0]], [[395.0, 446.0], [415.0, 446.0], [415.0, 564.0], [395.0, 564.0]], [[373.0, 447.0], [389.0, 447.0], [389.0, 610.0], [373.0, 610.0]]], "lines": ["あとは新曲に", "種田が歌詞を", "ちゃんとつければ"]}, {"box": [651, 622, 728, 778], "vertical": true, "font_size": 23, "lines_coords": [[[706.0, 675.0], [726.0, 675.0], [726.0, 778.0], [706.0, 778.0]], [[701.0, 622.0], [728.0, 623.0], [726.0, 683.0], [699.0, 682.0]], [[675.0, 622.0], [699.0, 622.0], [699.0, 750.0], [675.0, 750.0]], [[651.0, 623.0], [671.0, 623.0], [671.0, 740.0], [651.0, 740.0]]], "lines": ["ーしかし", "いやー", "ついにみんな", "卒業ですわ！！"]}, {"box": [631, 788, 686, 907], "vertical": true, "font_size": 20, "lines_coords": [[[659.0, 788.0], [679.0, 788.0], [679.0, 868.0], [659.0, 868.0]], [[631.0, 789.0], [651.0, 789.0], [653.0, 907.0], [633.0, 907.0]]], "lines": ["加藤君は", "留年でしょ？"]}, {"box": [176, 632, 270, 760], "vertical": true, "font_size": 16, "lines_coords": [[[254.0, 636.0], [270.0, 636.0], [270.0, 723.0], [254.0, 723.0]], [[229.0, 635.0], [245.0, 635.0], [245.0, 760.0], [229.0, 760.0]], [[204.0, 636.0], [221.0, 636.0], [221.0, 725.0], [204.0, 725.0]], [[176.0, 632.0], [196.0, 632.0], [199.0, 730.0], [179.0, 730.0]]], "lines": ["まぁ俺らは", "フリーターとか", "似たような", "もんだけど、"]}, {"box": [89, 734, 176, 860], "vertical": true, "font_size": 16, "lines_coords": [[[160.0, 734.0], [176.0, 734.0], [176.0, 857.0], [160.0, 857.0]], [[137.0, 734.0], [153.0, 734.0], [153.0, 857.0], [137.0, 857.0]], [[112.0, 737.0], [128.0, 737.0], [128.0, 860.0], [112.0, 860.0]], [[89.0, 737.0], [101.0, 737.0], [101.0, 814.0], [89.0, 814.0]]], "lines": ["芽衣子ちゃんは", "４月から都心で", "バリバリのＯＬ", "たもんなー"]}, {"box": [611, 967, 712, 1107], "vertical": true, "font_size": 18, "lines_coords": [[[692.0, 970.0], [708.0, 970.0], [708.0, 1107.0], [692.0, 1107.0]], [[665.0, 967.0], [685.0, 967.0], [685.0, 1103.0], [665.0, 1103.0]], [[639.0, 970.0], [655.0, 970.0], [655.0, 1102.0], [639.0, 1102.0]], [[611.0, 967.0], [631.0, 967.0], [631.0, 1046.0], [611.0, 1046.0]]], "lines": ["んて実際どうよ。", "仕事のほうは？", "研修始まってん", "でしょ？"]}, {"box": [517, 1023, 591, 1166], "vertical": true, "font_size": 19, "lines_coords": [[[570.0, 1023.0], [591.0, 1023.0], [591.0, 1092.0], [570.0, 1092.0]], [[543.0, 1024.0], [563.0, 1024.0], [563.0, 1102.0], [543.0, 1102.0]], [[518.0, 1025.0], [535.0, 1025.0], [535.0, 1163.0], [518.0, 1163.0]]], "lines": ["ははは", "ホント超", "つまんないよー。"]}], "img_path": "007.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [627, 125, 703, 281], "vertical": true, "font_size": 20, "lines_coords": [[[681.0, 125.0], [702.0, 125.0], [702.0, 228.0], [681.0, 228.0]], [[654.0, 125.0], [675.0, 125.0], [674.0, 281.0], [653.0, 281.0]], [[630.0, 125.0], [646.0, 125.0], [644.0, 260.0], [627.0, 260.0]]], "lines": ["芽衣子さん、", "ホントに会社員に", "なっちゃうの？"]}, {"box": [97, 141, 124, 243], "vertical": true, "font_size": 24, "lines_coords": [[[99.0, 141.0], [124.0, 141.0], [121.0, 243.0], [97.0, 243.0]]], "lines": ["．．．へっ？"]}, {"box": [727, 519, 775, 653], "vertical": true, "font_size": 17, "lines_coords": [[[755.0, 519.0], [775.0, 519.0], [775.0, 632.0], [755.0, 632.0]], [[729.0, 520.0], [747.0, 520.0], [744.0, 653.0], [727.0, 653.0]]], "lines": ["ちょっとぉー", "何言ってんの？"]}, {"box": [624, 600, 705, 747], "vertical": true, "font_size": 17, "lines_coords": [[[688.0, 600.0], [705.0, 600.0], [705.0, 742.0], [688.0, 742.0]], [[667.0, 602.0], [683.0, 602.0], [683.0, 678.0], [667.0, 678.0]], [[645.0, 603.0], [661.0, 603.0], [661.0, 735.0], [645.0, 735.0]], [[624.0, 603.0], [640.0, 603.0], [640.0, 747.0], [624.0, 747.0]]], "lines": ["なるに決まってる", "じゃんか", "明日引っ越し先", "決めてきちゃうし。"]}, {"box": [210, 574, 257, 689], "vertical": true, "font_size": 18, "lines_coords": [[[234.0, 574.0], [255.0, 574.0], [257.0, 671.0], [236.0, 671.0]], [[210.0, 574.0], [230.0, 574.0], [233.0, 689.0], [213.0, 689.0]]], "lines": ["．．．でもさぁ、", "てゆーかさぁ、"]}, {"box": [103, 673, 195, 798], "vertical": true, "font_size": 18, "lines_coords": [[[173.0, 673.0], [193.0, 673.0], [195.0, 771.0], [175.0, 771.0]], [[152.0, 677.0], [168.0, 677.0], [168.0, 780.0], [152.0, 780.0]], [[127.0, 676.0], [144.0, 676.0], [144.0, 781.0], [127.0, 781.0]], [[103.0, 676.0], [119.0, 676.0], [120.0, 798.0], [104.0, 798.0]]], "lines": ["芽衣子さん、", "全然興味ない", "職種就こうと", "してるっしょ？"]}, {"box": [662, 834, 784, 1010], "vertical": true, "font_size": 19, "lines_coords": [[[763.0, 834.0], [783.0, 834.0], [781.0, 993.0], [761.0, 993.0]], [[737.0, 836.0], [757.0, 836.0], [757.0, 953.0], [737.0, 953.0]], [[712.0, 835.0], [731.0, 835.0], [730.0, 1010.0], [710.0, 1010.0]], [[686.0, 835.0], [706.0, 835.0], [707.0, 1008.0], [687.0, 1008.0]], [[664.0, 837.0], [680.0, 837.0], [680.0, 993.0], [664.0, 993.0]]], "lines": ["だって芽衣子さん、", "お茶汲んだり", "顧客管理するために", "生まれてきた訳じゃ", "絶対ないじゃんか、"]}, {"box": [318, 999, 421, 1116], "vertical": true, "font_size": 19, "lines_coords": [[[401.0, 1000.0], [421.0, 1000.0], [421.0, 1096.0], [401.0, 1096.0]], [[373.0, 999.0], [393.0, 999.0], [393.0, 1116.0], [373.0, 1116.0]], [[346.0, 999.0], [366.0, 999.0], [366.0, 1096.0], [346.0, 1096.0]], [[318.0, 1000.0], [338.0, 1000.0], [338.0, 1073.0], [318.0, 1073.0]]], "lines": ["いくら就職", "しづらい時代", "だからとは", "いえさー"]}, {"box": [324, 1088, 337, 1113], "vertical": true, "font_size": 19, "lines_coords": [[[324.0, 1088.0], [337.0, 1088.0], [337.0, 1113.0], [324.0, 1113.0]]], "lines": ["．．．"]}, {"box": [94, 990, 169, 1163], "vertical": true, "font_size": 20, "lines_coords": [[[148.0, 990.0], [168.0, 990.0], [168.0, 1136.0], [148.0, 1136.0]], [[121.0, 990.0], [141.0, 990.0], [141.0, 1163.0], [121.0, 1163.0]], [[94.0, 990.0], [114.0, 990.0], [114.0, 1146.0], [94.0, 1146.0]]], "lines": ["なんかそういう", "生き急ぎ方が、今の", "俺にはちょっと．．．"]}], "img_path": "008.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [733, 119, 760, 221], "vertical": true, "font_size": 21, "lines_coords": [[[735.0, 119.0], [760.0, 119.0], [757.0, 221.0], [733.0, 221.0]]], "lines": ["バーカ！！"]}, {"box": [620, 158, 696, 335], "vertical": true, "font_size": 21, "lines_coords": [[[676.0, 159.0], [696.0, 159.0], [696.0, 315.0], [676.0, 315.0]], [[649.0, 159.0], [669.0, 159.0], [669.0, 335.0], [649.0, 335.0]], [[620.0, 158.0], [640.0, 158.0], [642.0, 276.0], [623.0, 276.0]]], "lines": ["なんでギリギリに", "なってそーゆうこと", "言うかなぁ！？"]}, {"box": [189, 108, 262, 232], "vertical": true, "font_size": 19, "lines_coords": [[[242.0, 108.0], [262.0, 108.0], [262.0, 207.0], [242.0, 207.0]], [[216.0, 111.0], [233.0, 111.0], [233.0, 226.0], [216.0, 226.0]], [[189.0, 111.0], [206.0, 111.0], [206.0, 232.0], [189.0, 232.0]]], "lines": ["．．．あんまり", "あたしに自分", "重ねないでよ。"]}, {"box": [96, 140, 166, 278], "vertical": true, "font_size": 19, "lines_coords": [[[144.0, 140.0], [163.0, 140.0], [166.0, 258.0], [146.0, 258.0]], [[120.0, 141.0], [140.0, 141.0], [140.0, 278.0], [120.0, 278.0]], [[96.0, 141.0], [115.0, 141.0], [115.0, 210.0], [96.0, 210.0]]], "lines": ["．．．今日はもう", "あたし、自分ち", "帰るね。"]}, {"box": [337, 294, 440, 447], "vertical": true, "font_size": 20, "lines_coords": [[[418.0, 294.0], [437.0, 294.0], [437.0, 412.0], [418.0, 412.0]], [[389.0, 294.0], [413.0, 294.0], [413.0, 432.0], [389.0, 432.0]], [[364.0, 294.0], [384.0, 294.0], [384.0, 447.0], [364.0, 447.0]], [[338.0, 294.0], [354.0, 294.0], [354.0, 391.0], [338.0, 391.0]]], "lines": ["彼氏だったら", "「ガンバレ」って", "言ってくれるトコ", "じゃんか！！"]}, {"box": [79, 366, 128, 471], "vertical": true, "font_size": 20, "lines_coords": [[[107.0, 367.0], [128.0, 367.0], [128.0, 445.0], [107.0, 445.0]], [[79.0, 366.0], [99.0, 366.0], [99.0, 469.0], [79.0, 469.0]]], "lines": ["．．．でもさ", "芽衣子さん。"]}, {"box": [645, 558, 747, 723], "vertical": true, "font_size": 19, "lines_coords": [[[728.0, 558.0], [744.0, 558.0], [744.0, 673.0], [728.0, 673.0]], [[699.0, 558.0], [719.0, 558.0], [719.0, 694.0], [699.0, 694.0]], [[671.0, 558.0], [690.0, 558.0], [690.0, 723.0], [671.0, 723.0]], [[645.0, 558.0], [665.0, 558.0], [665.0, 673.0], [645.0, 673.0]]], "lines": ["そんな未来が", "予想できる生活", "なんて、つまんなく", "ないですか？"]}, {"box": [89, 581, 219, 776], "vertical": true, "font_size": 19, "lines_coords": [[[199.0, 581.0], [218.0, 581.0], [218.0, 747.0], [199.0, 747.0]], [[170.0, 583.0], [190.0, 583.0], [190.0, 776.0], [170.0, 776.0]], [[144.0, 582.0], [163.0, 582.0], [163.0, 775.0], [144.0, 775.0]], [[117.0, 583.0], [137.0, 583.0], [137.0, 719.0], [117.0, 719.0]], [[89.0, 582.0], [108.0, 582.0], [108.0, 745.0], [89.0, 745.0]]], "lines": ["．．．だって俺は、まだ", "心のどこかで、自分は", "すごいことができるん", "じゃないかって", "思っちゃうんだよ。"]}, {"box": [702, 843, 723, 1020], "vertical": true, "font_size": 17, "lines_coords": [[[703.0, 844.0], [720.0, 844.0], [720.0, 1018.0], [703.0, 1018.0]]], "lines": ["高校で始めたギター"]}, {"box": [623, 843, 672, 999], "vertical": true, "font_size": 22, "lines_coords": [[[652.0, 844.0], [672.0, 844.0], [672.0, 999.0], [652.0, 999.0]], [[623.0, 843.0], [646.0, 843.0], [646.0, 962.0], [623.0, 962.0]]], "lines": ["大学で知り合った", "気の合う仲間"]}, {"box": [545, 842, 594, 1115], "vertical": true, "font_size": 22, "lines_coords": [[[571.0, 842.0], [594.0, 842.0], [593.0, 1020.0], [570.0, 1020.0]], [[545.0, 846.0], [565.0, 846.0], [565.0, 1115.0], [545.0, 1115.0]]], "lines": ["インディーズを経て", "いつかメジャーでデビューして"]}, {"box": [545, 849, 593, 1116], "vertical": true, "font_size": 48, "lines_coords": [[[545.0, 849.0], [593.0, 849.0], [593.0, 1116.0], [545.0, 1116.0]]], "lines": ["インディーズを経ていつかメジャーでデビューして"]}, {"box": [115, 843, 193, 1098], "vertical": true, "font_size": 24, "lines_coords": [[[167.0, 843.0], [190.0, 843.0], [193.0, 1098.0], [169.0, 1098.0]], [[140.0, 843.0], [163.0, 843.0], [166.0, 1041.0], [142.0, 1041.0]]], "lines": ["ファーストがじわじわ売れて", "セカンドで人がついて"]}, {"box": [93, 844, 114, 1021], "vertical": true, "font_size": 20, "lines_coords": [[[93.0, 844.0], [113.0, 844.0], [114.0, 1021.0], [94.0, 1021.0]]], "lines": ["即完満員の武道館で"]}], "img_path": "009.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [699, 80, 715, 292], "vertical": true, "font_size": 19, "lines_coords": [[[699.0, 80.0], [715.0, 80.0], [715.0, 292.0], [699.0, 292.0]]], "lines": ["ラストの曲が終わっても"]}, {"box": [585, 79, 660, 333], "vertical": true, "font_size": 19, "lines_coords": [[[638.0, 79.0], [659.0, 79.0], [660.0, 236.0], [639.0, 236.0]], [[611.0, 79.0], [631.0, 79.0], [632.0, 333.0], [612.0, 333.0]], [[585.0, 80.0], [605.0, 80.0], [605.0, 314.0], [585.0, 314.0]]], "lines": ["俺はムスタングで", "Ａメジャーセブンのコードを", "これでもかと掻き鳴らして"]}, {"box": [147, 83, 197, 256], "vertical": true, "font_size": 18, "lines_coords": [[[176.0, 84.0], [193.0, 84.0], [193.0, 256.0], [176.0, 256.0]], [[147.0, 83.0], [167.0, 83.0], [167.0, 239.0], [147.0, 239.0]]], "lines": ["右手の握りこぶしを", "高々と掲げるんだ"]}, {"box": [175, 411, 193, 500], "vertical": true, "font_size": 17, "lines_coords": [[[175.0, 414.0], [192.0, 414.0], [192.0, 496.0], [175.0, 496.0]]], "lines": ["．．．．．．まぁ"]}, {"box": [688, 638, 763, 801], "vertical": true, "font_size": 19, "lines_coords": [[[741.0, 638.0], [761.0, 638.0], [761.0, 773.0], [741.0, 773.0]], [[714.0, 638.0], [734.0, 638.0], [734.0, 793.0], [714.0, 793.0]], [[688.0, 638.0], [705.0, 638.0], [705.0, 799.0], [688.0, 799.0]]], "lines": ["現実は六畳間の", "寂しい妄想ひとり", "ライフなんだけど。"]}, {"box": [514, 775, 560, 916], "vertical": true, "font_size": 20, "lines_coords": [[[541.0, 775.0], [560.0, 775.0], [560.0, 916.0], [541.0, 916.0]], [[514.0, 775.0], [534.0, 775.0], [534.0, 912.0], [514.0, 912.0]]], "lines": ["やっぱ無理かな、", "俺の才能じゃ．．"]}, {"box": [608, 975, 668, 1017], "vertical": false, "font_size": 14.0, "lines_coords": [[[619.0, 975.0], [668.0, 992.0], [665.0, 1004.0], [616.0, 986.0]], [[613.0, 985.0], [664.0, 1001.0], [659.0, 1017.0], [608.0, 1000.0]]], "lines": ["Ａｍａｚｏｎ", "バカッ！！！"]}, {"box": [538, 955, 601, 998], "vertical": false, "font_size": 16.0, "lines_coords": [[[551.0, 955.0], [600.0, 969.0], [597.0, 980.0], [548.0, 966.0]], [[545.0, 962.0], [601.0, 978.0], [594.0, 998.0], [538.0, 982.0]]], "lines": ["やびやすい", "やっぱりわかりませんね"]}, {"box": [536, 982, 649, 1060], "vertical": false, "font_size": 18.0, "lines_coords": [[[543.0, 1016.0], [619.0, 1044.0], [612.0, 1060.0], [536.0, 1032.0]], [[543.0, 982.0], [649.0, 1016.0], [642.0, 1034.0], [536.0, 1000.0]]], "lines": ["２０１６年１１月", "ｍｇｉｔａｌＤｅｌｏｕ"]}, {"box": [423, 862, 498, 984], "vertical": true, "font_size": 20, "lines_coords": [[[477.0, 862.0], [498.0, 862.0], [498.0, 930.0], [477.0, 930.0]], [[450.0, 864.0], [470.0, 864.0], [470.0, 984.0], [450.0, 984.0]], [[423.0, 866.0], [441.0, 866.0], [442.0, 971.0], [425.0, 971.0]]], "lines": ["．．．さて、", "さっさと歌詞", "作っちゃお。"]}, {"box": [121, 840, 168, 975], "vertical": true, "font_size": 19, "lines_coords": [[[148.0, 840.0], [168.0, 840.0], [168.0, 975.0], [148.0, 975.0]], [[121.0, 840.0], [141.0, 840.0], [141.0, 925.0], [121.0, 925.0]]], "lines": ["．．．恋愛の歌詞は", "ナシだな。"]}, {"box": [73, 1006, 146, 1122], "vertical": true, "font_size": 19, "lines_coords": [[[126.0, 1006.0], [146.0, 1006.0], [146.0, 1083.0], [126.0, 1083.0]], [[99.0, 1006.0], [119.0, 1006.0], [119.0, 1122.0], [99.0, 1122.0]], [[73.0, 1007.0], [90.0, 1007.0], [90.0, 1109.0], [73.0, 1109.0]]], "lines": ["誰も俺の", "恋愛観なんて", "興味ねーし"]}], "img_path": "010.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [682, 73, 730, 230], "vertical": true, "font_size": 20, "lines_coords": [[[710.0, 76.0], [730.0, 76.0], [730.0, 230.0], [710.0, 230.0]], [[682.0, 73.0], [702.0, 73.0], [702.0, 230.0], [682.0, 230.0]]], "lines": ["．．．なんかもっと", "こう反体制げな．．．"]}, {"box": [590, 173, 665, 271], "vertical": true, "font_size": 20, "lines_coords": [[[639.0, 173.0], [665.0, 173.0], [665.0, 235.0], [639.0, 235.0]], [[616.0, 174.0], [635.0, 174.0], [635.0, 271.0], [616.0, 271.0]], [[590.0, 175.0], [606.0, 175.0], [606.0, 251.0], [590.0, 251.0]]], "lines": ["つーか", "反体制って", "なんだ？"]}, {"box": [351, 137, 455, 255], "vertical": true, "font_size": 19, "lines_coords": [[[436.0, 138.0], [453.0, 138.0], [453.0, 253.0], [436.0, 253.0]], [[407.0, 138.0], [427.0, 138.0], [427.0, 255.0], [407.0, 255.0]], [[378.0, 137.0], [398.0, 137.0], [400.0, 255.0], [380.0, 255.0]], [[351.0, 138.0], [371.0, 138.0], [373.0, 255.0], [353.0, 255.0]]], "lines": ["今の日本じゃ", "中指立てても", "むなしく宙を", "舞うしなぁ．．．"]}, {"box": [58, 114, 164, 250], "vertical": true, "font_size": 21, "lines_coords": [[[144.0, 117.0], [160.0, 117.0], [160.0, 229.0], [144.0, 229.0]], [[113.0, 116.0], [134.0, 116.0], [135.0, 219.0], [114.0, 219.0]], [[86.0, 116.0], [107.0, 116.0], [108.0, 250.0], [87.0, 250.0]], [[58.0, 114.0], [84.0, 114.0], [84.0, 165.0], [58.0, 165.0]]], "lines": ["芽衣子んちの", "お前の荷物、", "頼まれて持って", "きた。"]}, {"box": [652, 321, 730, 476], "vertical": true, "font_size": 21, "lines_coords": [[[709.0, 323.0], [727.0, 323.0], [728.0, 476.0], [710.0, 476.0]], [[682.0, 323.0], [702.0, 323.0], [702.0, 464.0], [682.0, 464.0]], [[652.0, 321.0], [678.0, 321.0], [678.0, 375.0], [652.0, 375.0]]], "lines": ["ブツブツひとりで", "気持ちわりぃよ、", "種田。"]}, {"box": [357, 457, 385, 551], "vertical": true, "font_size": 26, "lines_coords": [[[357.0, 457.0], [382.0, 457.0], [385.0, 551.0], [359.0, 551.0]]], "lines": ["やんっ！！"]}, {"box": [59, 411, 135, 528], "vertical": true, "font_size": 20, "lines_coords": [[[113.0, 413.0], [133.0, 413.0], [133.0, 495.0], [113.0, 495.0]], [[85.0, 411.0], [106.0, 411.0], [107.0, 528.0], [86.0, 528.0]], [[59.0, 413.0], [79.0, 413.0], [79.0, 510.0], [59.0, 510.0]]], "lines": ["いやいや、", "君達ドアって", "知ってる？"]}, {"box": [679, 595, 755, 731], "vertical": true, "font_size": 20, "lines_coords": [[[733.0, 595.0], [753.0, 595.0], [755.0, 712.0], [735.0, 712.0]], [[707.0, 596.0], [727.0, 596.0], [727.0, 731.0], [707.0, 731.0]], [[679.0, 595.0], [700.0, 595.0], [700.0, 663.0], [679.0, 663.0]]], "lines": ["てか芽衣子も", "ついに引っ越し", "なのな"]}, {"box": [606, 696, 680, 833], "vertical": true, "font_size": 20, "lines_coords": [[[658.0, 696.0], [678.0, 696.0], [680.0, 833.0], [660.0, 833.0]], [[633.0, 698.0], [653.0, 698.0], [653.0, 801.0], [633.0, 801.0]], [[606.0, 699.0], [626.0, 699.0], [626.0, 776.0], [606.0, 776.0]]], "lines": ["家離れちゃって", "大丈夫なの、", "お前ら？"]}, {"box": [452, 741, 553, 885], "vertical": false, "font_size": 40.333333333333336, "lines_coords": [[[480.0, 750.0], [523.0, 875.0], [494.0, 885.0], [452.0, 760.0]], [[504.0, 758.0], [529.0, 829.0], [507.0, 836.0], [483.0, 765.0]], [[501.0, 751.0], [535.0, 741.0], [553.0, 807.0], [519.0, 816.0]]], "lines": ["おーんだろ", "．．．", "あああ"]}, {"box": [249, 596, 269, 673], "vertical": true, "font_size": 20, "lines_coords": [[[249.0, 596.0], [269.0, 596.0], [269.0, 673.0], [249.0, 673.0]]], "lines": ["何がよ？"]}, {"box": [133, 629, 199, 747], "vertical": true, "font_size": 19, "lines_coords": [[[182.0, 631.0], [199.0, 631.0], [199.0, 746.0], [182.0, 746.0]], [[159.0, 631.0], [175.0, 631.0], [175.0, 747.0], [159.0, 747.0]], [[133.0, 629.0], [154.0, 629.0], [154.0, 691.0], [133.0, 691.0]]], "lines": ["どーせ今日も", "ケンカしたん", "だろ？"]}, {"box": [59, 738, 148, 878], "vertical": true, "font_size": 19, "lines_coords": [[[128.0, 738.0], [148.0, 738.0], [148.0, 840.0], [128.0, 840.0]], [[105.0, 741.0], [125.0, 741.0], [125.0, 878.0], [105.0, 878.0]], [[80.0, 741.0], [100.0, 741.0], [100.0, 858.0], [80.0, 858.0]], [[59.0, 742.0], [76.0, 742.0], [76.0, 828.0], [59.0, 828.0]]], "lines": ["ま、４年も", "付き合ってれば", "色々とあんだ", "ろうけど。"]}, {"box": [254, 919, 326, 1075], "vertical": true, "font_size": 19, "lines_coords": [[[305.0, 919.0], [326.0, 919.0], [326.0, 1020.0], [305.0, 1020.0]], [[278.0, 919.0], [298.0, 919.0], [298.0, 1075.0], [278.0, 1075.0]], [[254.0, 922.0], [270.0, 922.0], [270.0, 1055.0], [254.0, 1055.0]]], "lines": ["今みたいな", "季節の変わり目は", "気をつけろよ？"]}, {"box": [111, 973, 213, 1149], "vertical": true, "font_size": 19, "lines_coords": [[[190.0, 973.0], [211.0, 973.0], [213.0, 1115.0], [192.0, 1115.0]], [[162.0, 973.0], [182.0, 973.0], [186.0, 1129.0], [166.0, 1129.0]], [[138.0, 976.0], [158.0, 976.0], [158.0, 1149.0], [138.0, 1149.0]], [[111.0, 976.0], [128.0, 976.0], [131.0, 1081.0], [113.0, 1081.0]]], "lines": ["ただでさえお前、", "芽衣子がいなきゃ", "けっこうなダメ人間", "なんだから。"]}], "img_path": "011.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [573, 182, 593, 325], "vertical": true, "font_size": 23, "lines_coords": [[[573.0, 182.0], [593.0, 182.0], [593.0, 325.0], [573.0, 325.0]]], "lines": ["．．．わかってるさ。"]}, {"box": [461, 271, 542, 413], "vertical": true, "font_size": 23, "lines_coords": [[[521.0, 273.0], [542.0, 273.0], [539.0, 391.0], [518.0, 391.0]], [[490.0, 274.0], [514.0, 274.0], [514.0, 413.0], [490.0, 413.0]], [[461.0, 273.0], [486.0, 271.0], [488.0, 344.0], [463.0, 345.0]]], "lines": ["ホントは何が", "大切かってこと", "くらい。"]}, {"box": [345, 521, 518, 644], "vertical": false, "font_size": 30.0, "lines_coords": [[[357.0, 521.0], [505.0, 577.0], [494.0, 607.0], [345.0, 550.0]], [[372.0, 568.0], [518.0, 617.0], [509.0, 644.0], [363.0, 595.0]]], "lines": ["軽音サークル", "遅い出しライブ"]}, {"box": [651, 623, 706, 664], "vertical": true, "font_size": 24, "lines_coords": [[[681.0, 626.0], [706.0, 626.0], [706.0, 659.0], [681.0, 659.0]], [[655.0, 623.0], [683.0, 626.0], [679.0, 664.0], [651.0, 660.0]]], "lines": ["よー", "よー"]}, {"box": [683, 762, 731, 898], "vertical": true, "font_size": 24, "lines_coords": [[[712.0, 764.0], [731.0, 764.0], [731.0, 898.0], [712.0, 898.0]], [[683.0, 762.0], [708.0, 762.0], [708.0, 833.0], [683.0, 833.0]]], "lines": ["久しぶりじゃん", "種田達。"]}, {"box": [331, 602, 493, 719], "vertical": false, "font_size": 23.666666666666668, "lines_coords": [[[338.0, 602.0], [493.0, 655.0], [486.0, 677.0], [331.0, 623.0]], [[360.0, 639.0], [470.0, 676.0], [462.0, 700.0], [351.0, 664.0]], [[360.0, 664.0], [466.0, 698.0], [459.0, 719.0], [353.0, 684.0]]], "lines": ["キャット１ＤＲＩＮＫＩＩＳＯ", "ＯＰＥＮＩ３．３０Ｃｍｐｌｉ", "ＳＴＲＴ１４－１４：００"]}, {"box": [516, 750, 538, 856], "vertical": true, "font_size": 20, "lines_coords": [[[519.0, 810.0], [537.0, 810.0], [537.0, 856.0], [519.0, 856.0]], [[516.0, 750.0], [538.0, 750.0], [538.0, 792.0], [516.0, 792.0]]], "lines": ["ース。", "オー"]}, {"box": [144, 717, 220, 843], "vertical": true, "font_size": 20, "lines_coords": [[[201.0, 782.0], [217.0, 782.0], [217.0, 834.0], [201.0, 834.0]], [[197.0, 717.0], [220.0, 717.0], [220.0, 754.0], [197.0, 754.0]], [[170.0, 718.0], [190.0, 718.0], [190.0, 835.0], [170.0, 835.0]], [[144.0, 718.0], [163.0, 718.0], [163.0, 843.0], [144.0, 843.0]]], "lines": ["っ？", "えー", "始まる前から", "酒飲んでるよ。"]}, {"box": [74, 783, 122, 931], "vertical": true, "font_size": 20, "lines_coords": [[[100.0, 783.0], [121.0, 783.0], [122.0, 931.0], [101.0, 931.0]], [[74.0, 785.0], [96.0, 785.0], [96.0, 849.0], [74.0, 849.0]]], "lines": ["お前ら、変わって", "ないね"]}, {"box": [457, 969, 542, 1101], "vertical": true, "font_size": 21, "lines_coords": [[[525.0, 970.0], [542.0, 970.0], [542.0, 1058.0], [525.0, 1058.0]], [[502.0, 969.0], [522.0, 969.0], [522.0, 1093.0], [502.0, 1093.0]], [[480.0, 970.0], [500.0, 970.0], [500.0, 1041.0], [480.0, 1041.0]], [[457.0, 971.0], [477.0, 971.0], [477.0, 1101.0], [457.0, 1101.0]]], "lines": ["お前らこそ", "なんだよ、その", "無個性な", "ヘアスタイルは。"]}, {"box": [389, 1038, 439, 1123], "vertical": true, "font_size": 21, "lines_coords": [[[411.0, 1038.0], [439.0, 1038.0], [439.0, 1083.0], [411.0, 1083.0]], [[389.0, 1041.0], [411.0, 1041.0], [411.0, 1123.0], [389.0, 1123.0]]], "lines": ["逆に", "目立つぞ。"]}, {"box": [93, 1004, 173, 1126], "vertical": true, "font_size": 25, "lines_coords": [[[144.0, 1004.0], [173.0, 1004.0], [173.0, 1071.0], [144.0, 1071.0]], [[119.0, 1005.0], [144.0, 1005.0], [144.0, 1126.0], [119.0, 1126.0]], [[93.0, 1006.0], [113.0, 1006.0], [113.0, 1125.0], [93.0, 1125.0]]], "lines": ["だって", "俺ら、春から", "営業マンよ？"]}], "img_path": "012.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [667, 110, 743, 246], "vertical": true, "font_size": 20, "lines_coords": [[[722.0, 111.0], [742.0, 111.0], [742.0, 246.0], [722.0, 246.0]], [[695.0, 110.0], [715.0, 110.0], [715.0, 246.0], [695.0, 246.0]], [[667.0, 111.0], [687.0, 111.0], [687.0, 188.0], [667.0, 188.0]]], "lines": ["種田は卒業して", "どーするつもり", "なのよ？"]}, {"box": [483, 113, 503, 196], "vertical": true, "font_size": 22, "lines_coords": [[[483.0, 113.0], [503.0, 113.0], [503.0, 196.0], [483.0, 196.0]]], "lines": ["．．．ふぅん"]}, {"box": [428, 220, 456, 254], "vertical": true, "font_size": 22, "lines_coords": [[[433.0, 220.0], [456.0, 223.0], [452.0, 254.0], [428.0, 250.0]]], "lines": ["そ。"]}, {"box": [69, 93, 166, 250], "vertical": true, "font_size": 20, "lines_coords": [[[145.0, 93.0], [166.0, 93.0], [163.0, 213.0], [142.0, 213.0]], [[119.0, 96.0], [139.0, 96.0], [139.0, 250.0], [119.0, 250.0]], [[92.0, 94.0], [112.0, 94.0], [112.0, 249.0], [92.0, 249.0]], [[69.0, 94.0], [89.0, 94.0], [89.0, 182.0], [69.0, 182.0]]], "lines": ["まぁ、それも", "いいんじゃない？", "青春先延ばしって", "カンジで。"]}, {"box": [504, 337, 590, 501], "vertical": true, "font_size": 19, "lines_coords": [[[569.0, 337.0], [590.0, 337.0], [590.0, 389.0], [569.0, 389.0]], [[546.0, 337.0], [566.0, 337.0], [566.0, 479.0], [546.0, 479.0]], [[526.0, 338.0], [543.0, 338.0], [543.0, 501.0], [526.0, 501.0]], [[504.0, 338.0], [521.0, 338.0], [521.0, 444.0], [504.0, 444.0]]], "lines": ["さぁー", "今のバイト続けて", "フリーターまっしぐら", "じゃないの？"]}, {"box": [165, 517, 269, 673], "vertical": true, "font_size": 21, "lines_coords": [[[248.0, 519.0], [268.0, 519.0], [268.0, 673.0], [248.0, 673.0]], [[221.0, 517.0], [242.0, 517.0], [240.0, 636.0], [218.0, 636.0]], [[192.0, 519.0], [215.0, 519.0], [215.0, 656.0], [192.0, 656.0]], [[166.0, 517.0], [186.0, 517.0], [185.0, 655.0], [165.0, 655.0]]], "lines": ["もしくはアレか！？", "体のどこかに", "大人スイッチが", "付いてんのか！？"]}, {"box": [669, 514, 768, 692], "vertical": true, "font_size": 20, "lines_coords": [[[748.0, 517.0], [768.0, 517.0], [768.0, 641.0], [748.0, 641.0]], [[721.0, 516.0], [741.0, 516.0], [741.0, 692.0], [721.0, 692.0]], [[699.0, 517.0], [715.0, 517.0], [715.0, 670.0], [699.0, 670.0]], [[669.0, 514.0], [696.0, 514.0], [696.0, 561.0], [669.0, 561.0]]], "lines": ["おっまえ、今、", "すげえ上のほうから", "もの言ったよね！？", "ね！？"]}, {"box": [580, 568, 653, 753], "vertical": true, "font_size": 20, "lines_coords": [[[633.0, 568.0], [653.0, 568.0], [653.0, 735.0], [633.0, 735.0]], [[606.0, 569.0], [626.0, 569.0], [626.0, 753.0], [606.0, 753.0]], [[580.0, 569.0], [597.0, 569.0], [597.0, 723.0], [580.0, 723.0]]], "lines": ["髪黒く染めて、内定", "取れたら、すぐ大人に", "なれちゃうんだ！？"]}, {"box": [467, 552, 506, 675], "vertical": true, "font_size": 30, "lines_coords": [[[471.0, 558.0], [501.0, 558.0], [501.0, 675.0], [471.0, 675.0]]], "lines": ["ズえっ！？"]}, {"box": [70, 611, 145, 728], "vertical": true, "font_size": 20, "lines_coords": [[[122.0, 611.0], [145.0, 611.0], [145.0, 727.0], [122.0, 727.0]], [[94.0, 612.0], [115.0, 612.0], [115.0, 708.0], [94.0, 708.0]], [[70.0, 612.0], [86.0, 612.0], [86.0, 716.0], [70.0, 716.0]]], "lines": ["ワリィ。今日", "種田、狐が", "憑いてんだ。"]}, {"box": [671, 836, 768, 999], "vertical": true, "font_size": 21, "lines_coords": [[[742.0, 836.0], [768.0, 836.0], [768.0, 889.0], [742.0, 889.0]], [[720.0, 837.0], [740.0, 837.0], [740.0, 996.0], [720.0, 996.0]], [[695.0, 839.0], [715.0, 839.0], [715.0, 956.0], [695.0, 956.0]], [[671.0, 837.0], [690.0, 837.0], [690.0, 964.0], [671.0, 964.0]]], "lines": ["種田！", "俺達もう２２なんだ、", "こんなことで", "熱くなんなよ。"]}, {"box": [344, 962, 448, 1117], "vertical": true, "font_size": 20, "lines_coords": [[[427.0, 963.0], [447.0, 963.0], [447.0, 1117.0], [427.0, 1117.0]], [[399.0, 964.0], [419.0, 964.0], [419.0, 1100.0], [399.0, 1100.0]], [[372.0, 963.0], [392.0, 963.0], [392.0, 1100.0], [372.0, 1100.0]], [[344.0, 962.0], [365.0, 962.0], [366.0, 1080.0], [345.0, 1080.0]]], "lines": ["そのかわり俺達の", "熱いステージを", "観せてやるから", "前座頼むぜ。"]}, {"box": [60, 1012, 136, 1166], "vertical": true, "font_size": 20, "lines_coords": [[[113.0, 1012.0], [133.0, 1012.0], [134.0, 1166.0], [114.0, 1166.0]], [[87.0, 1013.0], [107.0, 1013.0], [107.0, 1129.0], [87.0, 1129.0]], [[60.0, 1012.0], [80.0, 1012.0], [80.0, 1079.0], [60.0, 1079.0]]], "lines": ["聴きたかねーやい", "お前らの音楽", "なんて。"]}], "img_path": "013.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [618, 79, 640, 253], "vertical": true, "font_size": 17, "lines_coords": [[[620.0, 80.0], [637.0, 80.0], [637.0, 249.0], [620.0, 249.0]]], "lines": ["．．．ちょっと待て、俺。"]}, {"box": [473, 78, 582, 235], "vertical": true, "font_size": 22, "lines_coords": [[[556.0, 78.0], [582.0, 78.0], [582.0, 141.0], [556.0, 141.0]], [[529.0, 79.0], [552.0, 79.0], [552.0, 199.0], [529.0, 199.0]], [[501.0, 79.0], [521.0, 79.0], [523.0, 235.0], [503.0, 235.0]], [[475.0, 80.0], [496.0, 80.0], [494.0, 178.0], [473.0, 178.0]]], "lines": ["じゃあ", "俺らの音楽を", "聴きたい奴なんて", "いんのか？"]}, {"box": [207, 79, 257, 184], "vertical": true, "font_size": 23, "lines_coords": [[[236.0, 80.0], [256.0, 80.0], [256.0, 181.0], [236.0, 181.0]], [[207.0, 79.0], [233.0, 79.0], [233.0, 150.0], [207.0, 150.0]]], "lines": ["いねーよな、", "きっと。"]}, {"box": [209, 357, 286, 478], "vertical": true, "font_size": 23, "lines_coords": [[[259.0, 357.0], [284.0, 357.0], [286.0, 446.0], [262.0, 446.0]], [[234.0, 358.0], [259.0, 358.0], [259.0, 423.0], [234.0, 423.0]], [[209.0, 359.0], [229.0, 359.0], [229.0, 444.0], [209.0, 444.0]]], "lines": ["おーい、", "みんな", "差し入れ"]}, {"box": [604, 779, 710, 938], "vertical": true, "font_size": 26, "lines_coords": [[[687.0, 781.0], [709.0, 781.0], [707.0, 860.0], [685.0, 860.0]], [[652.0, 779.0], [690.0, 779.0], [690.0, 830.0], [652.0, 830.0]], [[632.0, 785.0], [653.0, 785.0], [653.0, 882.0], [632.0, 882.0]], [[604.0, 783.0], [625.0, 783.0], [626.0, 937.0], [605.0, 937.0]]], "lines": ["それじゃ", "俺が", "俺の音楽を", "聴かせたい人は？"]}, {"box": [541, 694, 567, 740], "vertical": true, "font_size": 21, "lines_coords": [[[541.0, 694.0], [567.0, 694.0], [567.0, 740.0], [541.0, 740.0]]], "lines": ["ん？"]}, {"box": [469, 741, 515, 841], "vertical": true, "font_size": 21, "lines_coords": [[[495.0, 741.0], [515.0, 741.0], [515.0, 841.0], [495.0, 841.0]], [[469.0, 744.0], [486.0, 744.0], [486.0, 839.0], [469.0, 839.0]]], "lines": ["何してんの", "あんた達？"]}, {"box": [103, 800, 178, 929], "vertical": true, "font_size": 23, "lines_coords": [[[156.0, 802.0], [176.0, 802.0], [178.0, 929.0], [158.0, 929.0]], [[127.0, 800.0], [154.0, 801.0], [152.0, 864.0], [125.0, 863.0]], [[103.0, 802.0], [124.0, 802.0], [124.0, 882.0], [103.0, 882.0]]], "lines": ["いやちょっと", "種田が", "狐に．．．！！"]}, {"box": [419, 962, 520, 1108], "vertical": true, "font_size": 19, "lines_coords": [[[502.0, 963.0], [518.0, 963.0], [518.0, 1079.0], [502.0, 1079.0]], [[474.0, 962.0], [494.0, 962.0], [494.0, 1108.0], [474.0, 1108.0]], [[446.0, 962.0], [466.0, 962.0], [466.0, 1099.0], [446.0, 1099.0]], [[419.0, 963.0], [439.0, 963.0], [439.0, 1106.0], [419.0, 1106.0]]], "lines": ["あ．．．そういや", "さっき、芽衣子が", "こっそり会場に", "入っていったよ。"]}], "img_path": "014.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [663, 67, 738, 222], "vertical": true, "font_size": 19, "lines_coords": [[[716.0, 67.0], [736.0, 67.0], [736.0, 195.0], [716.0, 195.0]], [[689.0, 67.0], [709.0, 67.0], [709.0, 166.0], [689.0, 166.0]], [[665.0, 69.0], [681.0, 69.0], [681.0, 221.0], [665.0, 221.0]]], "lines": ["種田、あんた達", "またケンカ", "してるんだって？"]}, {"box": [408, 81, 431, 275], "vertical": true, "font_size": 16, "lines_coords": [[[411.0, 84.0], [427.0, 84.0], [427.0, 274.0], [411.0, 274.0]]], "lines": ["芽衣子さん．．．．かな？"]}, {"box": [485, 309, 585, 454], "vertical": true, "font_size": 19, "lines_coords": [[[565.0, 309.0], [585.0, 309.0], [585.0, 389.0], [565.0, 389.0]], [[537.0, 310.0], [558.0, 310.0], [556.0, 445.0], [535.0, 445.0]], [[510.0, 311.0], [530.0, 311.0], [530.0, 408.0], [510.0, 408.0]], [[486.0, 310.0], [502.0, 310.0], [502.0, 452.0], [486.0, 452.0]]], "lines": ["それでも", "こそこそライブ", "来るなんて", "超けなげじゃん。"]}, {"box": [57, 294, 161, 451], "vertical": true, "font_size": 21, "lines_coords": [[[139.0, 295.0], [159.0, 295.0], [159.0, 451.0], [139.0, 451.0]], [[110.0, 294.0], [133.0, 294.0], [133.0, 433.0], [110.0, 433.0]], [[83.0, 294.0], [103.0, 294.0], [105.0, 421.0], [85.0, 421.0]], [[57.0, 294.0], [77.0, 294.0], [78.0, 450.0], [58.0, 450.0]]], "lines": ["意地張ってないで", "さっさと仲直り", "しちゃってよ。", "あー、めんどくさ。"]}, {"box": [610, 564, 686, 745], "vertical": true, "font_size": 19, "lines_coords": [[[665.0, 564.0], [685.0, 564.0], [685.0, 644.0], [665.0, 644.0]], [[639.0, 566.0], [655.0, 566.0], [655.0, 738.0], [639.0, 738.0]], [[610.0, 564.0], [630.0, 564.0], [631.0, 741.0], [611.0, 741.0]]], "lines": ["いちばん", "近くにいる人にすら", "素直に