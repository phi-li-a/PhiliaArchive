104.0], [471.0, 104.0], [471.0, 239.0], [452.0, 239.0]], [[426.0, 105.0], [442.0, 105.0], [442.0, 221.0], [426.0, 221.0]], [[399.0, 104.0], [415.0, 104.0], [415.0, 248.0], [399.0, 248.0]]], "lines": ["あんなに働くの", "渋ってたのに", "なんか急だしさ。"]}, {"box": [110, 390, 186, 479], "vertical": true, "font_size": 21, "lines_coords": [[[162.0, 390.0], [186.0, 390.0], [186.0, 426.0], [162.0, 426.0]], [[135.0, 391.0], [156.0, 391.0], [156.0, 471.0], [135.0, 471.0]], [[110.0, 390.0], [129.0, 390.0], [129.0, 479.0], [110.0, 479.0]]], "lines": ["んー", "不思議な", "もんでな。"]}, {"box": [597, 638, 703, 776], "vertical": true, "font_size": 21, "lines_coords": [[[682.0, 639.0], [702.0, 639.0], [702.0, 776.0], [682.0, 776.0]], [[654.0, 639.0], [674.0, 639.0], [674.0, 739.0], [654.0, 739.0]], [[627.0, 641.0], [644.0, 641.0], [644.0, 773.0], [627.0, 773.0]], [[597.0, 638.0], [624.0, 638.0], [624.0, 692.0], [597.0, 692.0]]], "lines": ["何かが欠けると", "別のもんで", "埋めたくなるの", "かね。"]}, {"box": [181, 779, 229, 877], "vertical": true, "font_size": 23, "lines_coords": [[[208.0, 779.0], [229.0, 779.0], [229.0, 877.0], [208.0, 877.0]], [[181.0, 779.0], [201.0, 779.0], [201.0, 863.0], [181.0, 863.0]]], "lines": ["まー俺も", "そろそろ、"]}, {"box": [163, 948, 216, 1076], "vertical": true, "font_size": 23, "lines_coords": [[[185.0, 948.0], [216.0, 948.0], [216.0, 996.0], [185.0, 996.0]], [[163.0, 951.0], [183.0, 951.0], [183.0, 1076.0], [163.0, 1076.0]]], "lines": ["先に", "進まねーとな。"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [160, 91, 262, 251], "vertical": true, "font_size": 19, "lines_coords": [[[241.0, 91.0], [262.0, 91.0], [261.0, 249.0], [240.0, 249.0]], [[215.0, 93.0], [231.0, 93.0], [231.0, 209.0], [215.0, 209.0]], [[185.0, 91.0], [208.0, 91.0], [208.0, 232.0], [185.0, 232.0]], [[160.0, 92.0], [176.0, 92.0], [176.0, 251.0], [160.0, 251.0]]], "lines": ["信号無視してまで", "むこうがわに", "行こうとした奴", "目の当たりにして、"]}, {"box": [140, 317, 187, 439], "vertical": true, "font_size": 19, "lines_coords": [[[167.0, 317.0], [187.0, 317.0], [187.0, 434.0], [167.0, 434.0]], [[140.0, 317.0], [156.0, 317.0], [156.0, 439.0], [140.0, 439.0]]], "lines": ["何もせずには", "いられねーよ。"]}, {"box": [126, 515, 203, 671], "vertical": true, "font_size": 20, "lines_coords": [[[180.0, 516.0], [200.0, 516.0], [200.0, 671.0], [180.0, 671.0]], [[153.0, 515.0], [173.0, 515.0], [173.0, 671.0], [153.0, 671.0]], [[126.0, 515.0], [147.0, 515.0], [147.0, 584.0], [126.0, 584.0]]], "lines": ["．．．ま、そいつは", "渡りきれなかった", "けどな。"]}, {"box": [667, 765, 743, 882], "vertical": true, "font_size": 22, "lines_coords": [[[717.0, 765.0], [743.0, 765.0], [743.0, 828.0], [717.0, 828.0]], [[694.0, 767.0], [714.0, 767.0], [714.0, 864.0], [694.0, 864.0]], [[667.0, 767.0], [687.0, 767.0], [687.0, 882.0], [667.0, 882.0]]], "lines": ["つーか", "お前、時間", "大丈夫なの？"]}, {"box": [163, 760, 241, 878], "vertical": true, "font_size": 22, "lines_coords": [[[217.0, 760.0], [241.0, 760.0], [241.0, 878.0], [217.0, 878.0]], [[188.0, 760.0], [213.0, 760.0], [213.0, 841.0], [188.0, 841.0]], [[163.0, 761.0], [183.0, 761.0], [183.0, 860.0], [163.0, 860.0]]], "lines": ["やべーじゃん", "別の道で", "行こうぜ！？"]}, {"box": [94, 850, 141, 939], "vertical": true, "font_size": 22, "lines_coords": [[[120.0, 850.0], [141.0, 850.0], [141.0, 932.0], [120.0, 932.0]], [[94.0, 851.0], [114.0, 851.0], [114.0, 939.0], [94.0, 939.0]]], "lines": ["この信号", "なげーよ。"]}, {"box": [503, 998, 579, 1136], "vertical": true, "font_size": 21, "lines_coords": [[[555.0, 998.0], [579.0, 998.0], [579.0, 1062.0], [555.0, 1062.0]], [[529.0, 1000.0], [550.0, 1000.0], [550.0, 1099.0], [529.0, 1099.0]], [[504.0, 1001.0], [521.0, 1001.0], [521.0, 1135.0], [504.0, 1135.0]]], "lines": ["うう．．．", "あと５分で", "昼休み終わり．．．"]}, {"box": [352, 1000, 456, 1119], "vertical": true, "font_size": 22, "lines_coords": [[[435.0, 1001.0], [455.0, 1001.0], [455.0, 1098.0], [435.0, 1098.0]], [[405.0, 1000.0], [429.0, 1000.0], [429.0, 1081.0], [405.0, 1081.0]], [[379.0, 1000.0], [402.0, 1000.0], [402.0, 1119.0], [379.0, 1119.0]], [[352.0, 1000.0], [373.0, 1000.0], [374.0, 1106.0], [353.0, 1106.0]]], "lines": ["これからは", "芽衣子に", "偉そうなこと", "言えないな。"]}, {"box": [211, 1000, 289, 1139], "vertical": true, "font_size": 20, "lines_coords": [[[265.0, 1001.0], [285.0, 1001.0], [285.0, 1137.0], [265.0, 1137.0]], [[238.0, 1003.0], [258.0, 1003.0], [258.0, 1137.0], [238.0, 1137.0]], [[211.0, 1004.0], [231.0, 1004.0], [231.0, 1100.0], [211.0, 1100.0]]], "lines": ["あたしも加藤が", "無理してるのが", "わかっても"]}, {"box": [100, 1000, 152, 1099], "vertical": true, "font_size": 23, "lines_coords": [[[128.0, 1001.0], [149.0, 1001.0], [152.0, 1099.0], [131.0, 1099.0]], [[100.0, 1000.0], [125.0, 1000.0], [125.0, 1071.0], [100.0, 1071.0]]], "lines": ["何も言えな", "いんだ。"]}], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [703, 85, 750, 165], "vertical": true, "font_size": 21, "lines_coords": [[[730.0, 85.0], [750.0, 85.0], [750.0, 165.0], [730.0, 165.0]], [[703.0, 87.0], [724.0, 87.0], [724.0, 147.0], [703.0, 147.0]]], "lines": ["ちょっと", "加藤！！"]}, {"box": [634, 202, 710, 324], "vertical": true, "font_size": 21, "lines_coords": [[[685.0, 202.0], [710.0, 202.0], [710.0, 268.0], [685.0, 268.0]], [[660.0, 206.0], [680.0, 206.0], [680.0, 324.0], [660.0, 324.0]], [[634.0, 206.0], [651.0, 206.0], [651.0, 322.0], [634.0, 322.0]]], "lines": ["この道", "逆に遠まわり", "じゃないの！？"]}, {"box": [278, 121, 327, 267], "vertical": true, "font_size": 21, "lines_coords": [[[302.0, 121.0], [326.0, 121.0], [326.0, 203.0], [302.0, 203.0]], [[278.0, 124.0], [296.0, 124.0], [297.0, 266.0], [279.0, 266.0]]], "lines": ["４年間も", "口説がれ続けて、"]}, {"box": [182, 122, 232, 305], "vertical": true, "font_size": 20, "lines_coords": [[[208.0, 123.0], [229.0, 123.0], [230.0, 261.0], [209.0, 261.0]], [[182.0, 123.0], [202.0, 123.0], [202.0, 302.0], [182.0, 302.0]]], "lines": ["押し負けて結局", "付き合い出したけど、"]}, {"box": [90, 123, 139, 290], "vertical": true, "font_size": 22, "lines_coords": [[[115.0, 124.0], [139.0, 124.0], [139.0, 244.0], [115.0, 244.0]], [[90.0, 125.0], [110.0, 125.0], [110.0, 288.0], [90.0, 288.0]]], "lines": ["はじめは全然", "好きじゃなかった。"]}, {"box": [712, 519, 765, 582], "vertical": true, "font_size": 24, "lines_coords": [[[737.0, 519.0], [765.0, 519.0], [765.0, 558.0], [737.0, 558.0]], [[712.0, 520.0], [737.0, 520.0], [737.0, 582.0], [712.0, 582.0]]], "lines": ["ねー", "加藤！！"]}, {"box": [385, 318, 433, 425], "vertical": true, "font_size": 20, "lines_coords": [[[411.0, 359.0], [433.0, 359.0], [433.0, 399.0], [411.0, 399.0]], [[411.0, 318.0], [432.0, 318.0], [432.0, 360.0], [411.0, 360.0]], [[386.0, 321.0], [402.0, 321.0], [402.0, 424.0], [386.0, 424.0]]], "lines": ["．．．", "うー", "かもしれん"]}, {"box": [230, 513, 252, 612], "vertical": true, "font_size": 20, "lines_coords": [[[230.0, 513.0], [250.0, 513.0], [250.0, 611.0], [230.0, 611.0]]], "lines": ["だーから．．．"]}, {"box": [638, 601, 686, 680], "vertical": true, "font_size": 24, "lines_coords": [[[665.0, 601.0], [686.0, 601.0], [686.0, 680.0], [665.0, 680.0]], [[638.0, 603.0], [658.0, 603.0], [658.0, 680.0], [638.0, 680.0]]], "lines": ["ホントに", "いいの！？"]}, {"box": [727, 819, 747, 901], "vertical": true, "font_size": 21, "lines_coords": [[[727.0, 819.0], [747.0, 819.0], [747.0, 901.0], [727.0, 901.0]]], "lines": ["時折思う"]}, {"box": [133, 616, 180, 734], "vertical": true, "font_size": 18, "lines_coords": [[[158.0, 617.0], [179.0, 617.0], [179.0, 697.0], [158.0, 697.0]], [[133.0, 617.0], [149.0, 617.0], [149.0, 734.0], [133.0, 734.0]]], "lines": ["道のこと", "じゃなくて！！"]}, {"box": [566, 943, 642, 1101], "vertical": true, "font_size": 21, "lines_coords": [[[619.0, 943.0], [642.0, 943.0], [642.0, 1101.0], [619.0, 1101.0]], [[593.0, 943.0], [613.0, 943.0], [613.0, 1041.0], [593.0, 1041.0]], [[566.0, 944.0], [586.0, 944.0], [586.0, 1050.0], [566.0, 1050.0]]], "lines": ["いいかげんな男の", "どこが好き", "なんだろう。"]}, {"box": [566, 941, 672, 1139], "vertical": true, "font_size": 24, "lines_coords": [[[646.0, 941.0], [669.0, 941.0], [671.0, 1139.0], [647.0, 1139.0]]], "lines": ["あたしは、この太った"]}, {"box": [300, 1037, 320, 1152], "vertical": true, "font_size": 17, "lines_coords": [[[300.0, 1037.0], [317.0, 1037.0], [317.0, 1151.0], [300.0, 1151.0]]], "lines": ["．．．なんだよ？"]}, {"box": [218, 835, 268, 971], "vertical": true, "font_size": 20, "lines_coords": [[[243.0, 835.0], [264.0, 835.0], [265.0, 971.0], [244.0, 971.0]], [[218.0, 837.0], [238.0, 837.0], [238.0, 944.0], [218.0, 944.0]]], "lines": ["加藤はいつでも", "加藤だった。"]}, {"box": [107, 841, 267, 1142], "vertical": true, "font_size": 16, "lines_coords": [[[133.0, 979.0], [149.0, 979.0], [149.0, 1130.0], [133.0, 1130.0]]], "lines": ["きっとそれだけの"]}, {"box": [104, 975, 154, 1134], "vertical": true, "font_size": 20, "lines_coords": [[[104.0, 978.0], [124.0, 978.0], [124.0, 1082.0], [104.0, 1082.0]]], "lines": ["ことなんだ。"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [651, 99, 728, 236], "vertical": true, "font_size": 22, "lines_coords": [[[703.0, 99.0], [728.0, 99.0], [728.0, 180.0], [703.0, 180.0]], [[676.0, 99.0], [700.0, 99.0], [700.0, 236.0], [676.0, 236.0]], [[651.0, 101.0], [672.0, 101.0], [672.0, 186.0], [651.0, 186.0]]], "lines": ["バンドが", "できなくなった", "からって、"]}, {"box": [613, 295, 688, 412], "vertical": true, "font_size": 22, "lines_coords": [[[668.0, 295.0], [688.0, 295.0], [688.0, 412.0], [668.0, 412.0]], [[640.0, 296.0], [661.0, 296.0], [661.0, 393.0], [640.0, 393.0]], [[613.0, 295.0], [633.0, 295.0], [633.0, 392.0], [613.0, 392.0]]], "lines": ["埋め合わせに", "働くのって", "なんか．．．"]}, {"box": [122, 274, 224, 414], "vertical": true, "font_size": 20, "lines_coords": [[[204.0, 276.0], [224.0, 276.0], [224.0, 412.0], [204.0, 412.0]], [[175.0, 274.0], [199.0, 274.0], [199.0, 414.0], [175.0, 414.0]], [[149.0, 276.0], [169.0, 276.0], [169.0, 392.0], [149.0, 392.0]], [[122.0, 276.0], [142.0, 276.0], [142.0, 356.0], [122.0, 356.0]]], "lines": ["やっぱり種田が", "いないとバンド", "成立しないの", "かな．．．"]}, {"box": [126, 495, 199, 611], "vertical": true,