]], [[648.0, 70.0], [668.0, 70.0], [668.0, 187.0], [648.0, 187.0]], [[621.0, 71.0], [641.0, 71.0], [641.0, 196.0], [621.0, 196.0]]], "lines": ["そりゃそーだ。", "芽衣子、ステージに", "立つのなんて", "初めてだもん。"]}, {"box": [89, 48, 181, 64], "vertical": false, "font_size": 16, "lines_coords": [[[89.0, 48.0], [181.0, 48.0], [181.0, 64.0], [89.0, 64.0]]], "lines": ["ラニン２"]}, {"box": [94, 195, 172, 312], "vertical": true, "font_size": 21, "lines_coords": [[[147.0, 195.0], [172.0, 195.0], [172.0, 277.0], [147.0, 277.0]], [[121.0, 196.0], [141.0, 196.0], [139.0, 312.0], [119.0, 312.0]], [[94.0, 195.0], [111.0, 195.0], [111.0, 302.0], [94.0, 302.0]]], "lines": ["．．．おっと", "俺もそろそろ", "行かねーと。"]}, {"box": [512, 416, 588, 552], "vertical": true, "font_size": 19, "lines_coords": [[[567.0, 416.0], [587.0, 416.0], [587.0, 515.0], [567.0, 515.0]], [[542.0, 418.0], [558.0, 418.0], [558.0, 551.0], [542.0, 551.0]], [[512.0, 416.0], [534.0, 416.0], [534.0, 503.0], [512.0, 503.0]]], "lines": ["トイレから", "全然出てこねー", "でやんの。"]}, {"box": [393, 382, 449, 453], "vertical": true, "font_size": 29, "lines_coords": [[[420.0, 382.0], [449.0, 382.0], [449.0, 453.0], [420.0, 453.0]], [[393.0, 382.0], [422.0, 382.0], [422.0, 447.0], [393.0, 447.0]]], "lines": ["．．．あっ、", "加藤！！"]}, {"box": [111, 488, 135, 561], "vertical": true, "font_size": 24, "lines_coords": [[[111.0, 488.0], [135.0, 488.0], [135.0, 561.0], [111.0, 561.0]]], "lines": ["んぁ？"]}, {"box": [646, 663, 672, 791], "vertical": true, "font_size": 24, "lines_coords": [[[646.0, 663.0], [669.0, 663.0], [672.0, 789.0], [648.0, 789.0]]], "lines": ["がんばって。"]}, {"box": [115, 1031, 146, 1093], "vertical": true, "font_size": 31, "lines_coords": [[[115.0, 1031.0], [146.0, 1031.0], [146.0, 1093.0], [115.0, 1093.0]]], "lines": ["おう。"]}], "img_path": "155.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [587, 52, 614, 167], "vertical": true, "font_size": 22, "lines_coords": [[[587.0, 52.0], [612.0, 52.0], [614.0, 167.0], [590.0, 167.0]]], "lines": ["芽衣子ぉー"]}, {"box": [494, 111, 543, 209], "vertical": true, "font_size": 22, "lines_coords": [[[523.0, 111.0], [543.0, 111.0], [543.0, 191.0], [523.0, 191.0]], [[494.0, 111.0], [515.0, 111.0], [516.0, 209.0], [495.0, 209.0]]], "lines": ["そろそろ", "始まるぜぇ"]}, {"box": [135, 401, 162, 501], "vertical": true, "font_size": 27, "lines_coords": [[[135.0, 401.0], [162.0, 401.0], [162.0, 430.0], [135.0, 430.0]]], "lines": ["う"]}, {"box": [696, 543, 770, 662], "vertical": true, "font_size": 21, "lines_coords": [[[750.0, 544.0], [770.0, 544.0], [770.0, 662.0], [750.0, 662.0]], [[722.0, 543.0], [743.0, 543.0], [744.0, 662.0], [723.0, 662.0]], [[696.0, 544.0], [716.0, 544.0], [716.0, 662.0], [696.0, 662.0]]], "lines": ["会場見たか？", "けっこー、人", "入ってるぜ？"]}, {"box": [565, 626, 669, 775], "vertical": true, "font_size": 21, "lines_coords": [[[649.0, 629.0], [669.0, 629.0], [667.0, 748.0], [647.0, 748.0]], [[618.0, 626.0], [641.0, 626.0], [644.0, 775.0], [620.0, 775.0]], [[593.0, 630.0], [613.0, 630.0], [613.0, 751.0], [593.0, 751.0]], [[565.0, 628.0], [586.0, 628.0], [587.0, 735.0], [566.0, 735.0]]], "lines": ["つっても全部", "鮎川ちゃんの客。", "ほとんど学生", "超アウェー。"]}, {"box": [160, 701, 187, 799], "vertical": true, "font_size": 24, "lines_coords": [[[163.0, 701.0], [187.0, 703.0], [183.0, 798.0], [160.0, 796.0]]], "lines": ["ひ～～～"]}, {"box": [664, 902, 740, 1060], "vertical": true, "font_size": 21, "lines_coords": [[[716.0, 902.0], [740.0, 902.0], [740.0, 1025.0], [716.0, 1025.0]], [[690.0, 905.0], [710.0, 905.0], [710.0, 1060.0], [690.0, 1060.0]], [[664.0, 905.0], [683.0, 905.0], [683.0, 992.0], [664.0, 992.0]]], "lines": ["．．．まー、俺も", "緊張しない訳じゃ", "ねーけど。"]}, {"box": [124, 963, 227, 1101], "vertical": true, "font_size": 20, "lines_coords": [[[202.0, 963.0], [227.0, 963.0], [227.0, 1025.0], [202.0, 1025.0]], [[175.0, 964.0], [195.0, 964.0], [195.0, 1082.0], [175.0, 1082.0]], [[149.0, 964.0], [169.0, 964.0], [169.0, 1101.0], [149.0, 1101.0]], [[124.0, 965.0], [140.0, 965.0], [140.0, 1053.0], [124.0, 1053.0]]], "lines": ["なんせ", "２年近く前の", "卒業ライブ以来", "だからよー"]}], "img_path": "156.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [620, 73, 725, 250], "vertical": true, "font_size": 20, "lines_coords": [[[701.0, 73.0], [722.0, 73.0], [723.0, 179.0], [702.0, 179.0]], [[674.0, 75.0], [694.0, 75.0], [694.0, 230.0], [674.0, 230.0]], [[649.0, 77.0], [666.0, 77.0], [666.0, 249.0], [649.0, 249.0]], [[621.0, 75.0], [641.0, 75.0], [640.0, 220.0], [620.0, 220.0]]], "lines": ["あの時、俺、", "正直もうライブは", "やんねーんだろうと", "思ってたけどな。"]}, {"box": [503, 59, 549, 180], "vertical": true, "font_size": 20, "lines_coords": [[[528.0, 59.0], [549.0, 59.0], [549.0, 158.0], [528.0, 158.0]], [[503.0, 62.0], [519.0, 62.0], [519.0, 180.0], [503.0, 180.0]]], "lines": ["ホラ、よく", "スタジオにさ、"]}, {"box": [366, 78, 470, 280], "vertical": true, "font_size": 20, "lines_coords": [[[449.0, 78.0], [470.0, 78.0], [468.0, 215.0], [447.0, 215.0]], [[421.0, 79.0], [442.0, 79.0], [442.0, 178.0], [421.0, 178.0]], [[394.0, 80.0], [414.0, 80.0], [414.0, 255.0], [394.0, 255.0]], [[367.0, 78.0], [387.0, 78.0], [386.0, 280.0], [366.0, 280.0]]], "lines": ["高い楽器持って", "集まってる", "ロック玄人みたいな", "オッサン違いるじゃん？"]}, {"box": [105, 182, 179, 321], "vertical": true, "font_size": 20, "lines_coords": [[[155.0, 182.0], [179.0, 182.0], [179.0, 321.0], [155.0, 321.0]], [[129.0, 183.0], [149.0, 183.0], [149.0, 301.0], [129.0, 301.0]], [[105.0, 183.0], [121.0, 183.0], [121.0, 308.0], [105.0, 308.0]]], "lines": ["中年になっても", "夢捨てきれて", "ねーのかよー。"]}, {"box": [72, 389, 174, 506], "vertical": true, "font_size": 20, "lines_coords": [[[153.0, 389.0], [174.0, 389.0], [174.0, 468.0], [153.0, 468.0]], [[127.0, 389.0], [147.0, 389.0], [147.0, 487.0], [127.0, 487.0]], [[99.0, 390.0], [119.0, 390.0], [119.0, 506.0], [99.0, 506.0]], [[72.0, 390.0], [93.0, 390.0], [93.0, 458.0], [72.0, 458.0]]], "lines": ["．．．なんて", "昔は３人で", "馬鹿にしてた", "けどさ。"]}, {"box": [672, 611, 719, 717], "vertical": true, "font_size": 19, "lines_coords": [[[697.0, 611.0], [719.0, 611.0], [719.0, 691.0], [697.0, 691.0]], [[673.0, 612.0], [689.0, 612.0], [689.0, 712.0], [673.0, 712.0]]], "lines": ["もう何も", "言えねーな。"]}, {"box": [110, 706, 183, 822], "vertical": true, "font_size": 19, "lines_coords": [[[163.0, 706.0], [183.0, 706.0], [183.0, 786.0], [163.0, 786.0]], [[135.0, 706.0], [155.0, 706.0], [155.0, 822.0], [135.0, 822.0]], [[111.0, 707.0], [127.0, 707.0], [127.0, 812.0], [111.0, 812.0]]], "lines": ["まんまと", "そんな奴らの", "仲間入りだ。"]}, {"box": [672, 938, 721, 1055], "vertical": true, "font_size": 21, "lines_coords": [[[695.0, 938.0], [721.0, 938.0], [721.0, 1001.0], [695.0, 1001.0]], [[673.0, 941.0], [689.0, 941.0], [689.0, 1054.0], [673.0, 1054.0]]], "lines": ["芽衣子", "憶えてるか？"]}, {"box": [604, 1073, 624, 1113], "vertical": true, "font_size": 20, "lines_coords": [[[604.0, 1074.0], [624.0, 1074.0], [624.0, 1113.0], [604.0, 1113.0]]], "lines": ["ん？"]}, {"box": [208, 931, 282, 1075], "vertical": true, "font_size": 20, "lines_coords": [[[262.0, 931.0], [282.0, 931.0], [282.0, 1068.0], [262.0, 1068.0]], [[235.0, 932.0], [255.0, 932.0], [255.0, 1040.0], [235.0, 1040.0]], [[208.0, 932.0], [224.0, 932.0], [224.0, 1075.0], [208.0, 1075.0]]], "lines": ["前にウチの店で", "「今の生活で", "満たされてる？"]}, {"box": [111, 979, 161, 1137], "vertical": true, "font_size": 20, "lines_coords": [[[138.0, 979.0], [161.0, 979.0], [161.0, 1137.0], [138.0, 1137.0]], [[112.0, 982.0], [132.0, 982.0], [131.0, 1116.0], [111.0, 1116.0]]], "lines": ["「人生は何？」って", "俺に聞いたろ？"]}], "img_path": "157.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [674, 77, 747, 193], "vertical": true, "font_size": 20, "lines_coords": [[[730.0, 78.0], [747.0, 78.0], [747.0, 193.0], [730.0, 193.0]], [[701.0, 77.0], [721.0, 77.0], [721.0, 157.0], [701.0, 157.0]], [[674.0, 78.0], [692.0, 78.0], [693.0, 182.0], [675.0, 182.0]]], "lines": ["そりゃ不満を", "言ったら", "キリないさ。"]}, {"box": [148, 225, 197, 330], "vertical": true, "font_size": 22, "lines_coords": [[[172.0, 225.0], [197.0, 225.0], [197.0, 288.0], [172.0, 288.0]], [[148.0, 225.0], [168.0, 225.0], [168.0, 330.0], [148.0, 330.0]]], "lines": ["たぶん", "俺にとって、"]}, {"box": [637, 258, 713, 405], "vertical": true, "font_size": 20, "lines_coords": [[[688.0, 258.0], [713.0, 258.0], [713.0, 329.0], [688.0, 329.0]], [[664.0, 260.0], [683.0, 260.0], [683.0, 379.0], [664.0, 379.0]], [[637.0, 260.0], [656.0, 260.0], [656.0, 405.0], [637.0, 405.0]]], "lines": ["でも俺、", "今日はなんか", "すげー楽しくて。"]}, {"box": [106, 382, 210, 539], "vertical": true, "font_size": 22, "lines_coords": [[[188.0, 382.0], [209.0, 382.0], [210.0, 500.0], [189.0, 500.0]], [[161.0, 382.0], [182.0, 382.0], [183.0, 539.0], [162.0, 539.0]], [[133.0, 382.0], [156.0, 382.0], [156.0, 501.0], [133.0, 501.0]], [[106.0, 382.0], [131.0, 382.0], [131.0, 454.0], [106.0, 454.0]]], "lines": ["人生ってのは", "ただ生きてくって", "ことでいいの", "かもな。"]}, {"box": [388, 882, 411, 962], "vertical": true, "font_size": 22, "lines_coords": [[[388.0, 882.0], [409.0, 882.0], [411.0, 962.0], [389.0, 962.0]]], "lines": ["．．．あっ！！"]}, {"box": [295, 935, 370, 1055], "vertical": true, "font_size": 22, "lines_coords": [[[348.0, 935.0], [370.0, 935.0], [370.0, 1021.0], [348.0, 1021.0]], [[318.0, 936.0], [344.0, 936.0], [344.0, 999.0], [318.0, 999.0]], [[295.0, 938.0], [315.0, 938.0], [315.0, 1055.0], [295.0, 1055.0]]], "lines": ["何アンタ、", "ビール", "飲んでんの！？"]}, {"box": [114, 1000, 188, 1118], "vertical": true, "font_size": 19, "lines_coords": [[[167.0, 1000.0], [187.0, 1000.0], [187.0, 1117.0], [167.0, 1117.0]], [[140.0, 1000.0], [160.0, 1000.0], [160.0, 1098.0], [140.0, 1098.0]], [[114.0, 1001.0], [131.0, 1001.0], [131.0, 1081.0], [114.0, 1081.0]]], "lines": ["．．．まー、俺も", "緊張しない", "訳じゃね"]}], "img_path": "158.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [668, 48, 718, 223], "vertical": true, "font_size": 20, "lines_coords": [[[696.0, 49.0], [716.0, 49.0], [716.0, 169.0], [696.0, 169.0]], [[669.0, 48.0], [689.0, 48.0], [688.0, 223.0], [668.0, 223.0]]], "lines": ["せんぱーい", "ちょっといいスか？"]}, {"box": [435, 117, 456, 222], "vertical": true, "font_size": 20, "lines_coords": [[[435.0, 117.0], [455.0, 117.0], [455.0, 221.0], [435.0, 221.0]]], "lines": ["紹介します。"]}, {"box": [72, 46, 181, 62], "vertical": false, "font_size": 16, "lines_coords": [[[72.0, 46.0], [181.0, 46.0], [181.0, 62.0], [72.0, 62.0]]], "lines": ["ソラニン２"]}, {"box": [94, 330, 187, 485], "vertical": true, "font_size": 20, "lines_coords": [[[166.0, 330.0], [187.0, 330.0], [187.0, 408.0], [166.0, 408.0]], [[140.0, 330.0], [161.0, 330.0], [161.0, 410.0], [140.0, 410.0]], [[117.0, 330.0], [137.0, 330.0], [137.0, 430.0], [117.0, 430.0]], [[94.0, 332.0], [111.0, 332.0], [111.0, 485.0], [94.0, 485.0]]], "lines": ["この人が", "声かけて", "もらってる", "レコード会社の．．．"]}, {"box": [548, 761, 576, 881], "vertical": true, "font_size": 24, "lines_coords": [[[548.0, 765.0], [572.0, 765.0], [576.0, 881.0], [551.0, 881.0]]], "lines": ["．．．あぁ！"]}, {"box": [108, 803, 188, 905], "vertical": true, "font_size": 26, "lines_coords": [[[155.0, 803.0], [188.0, 803.0], [188.0, 860.0], [155.0, 860.0]], [[134.0, 805.0], [159.0, 805.0], [156.0, 888.0], [132.0, 888.0]], [[108.0, 809.0], [128.0, 809.0], [128.0, 905.0], [108.0, 905.0]]], "lines": ["あれ、えっ", "冴木さん", "知り合い？"]}], "img_path": "159.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [753, 91, 772, 169], "vertical": true, "font_size": 20, "lines_coords": [[[753.0, 91.0], [772.0, 91.0], [772.0, 169.0], [753.0, 169.0]]], "lines": ["あんた．．．"]}, {"box": [649, 124, 724, 281], "vertical": true, "font_size": 20, "lines_coords": [[[702.0, 124.0], [723.0, 124.0], [724.0, 280.0], [703.0, 280.0]], [[676.0, 125.0], [696.0, 125.0], [696.0, 263.0], [676.0, 263.0]], [[649.0, 125.0], [669.0, 125.0], [669.0, 281.0], [649.0, 281.0]]], "lines": ["アイドルバンドの", "プロデューサー", "なんじゃねーの？"]}, {"box": [186, 91, 211, 144], "vertical": true, "font_size": 21, "lines_coords": [[[186.0, 91.0], [211.0, 91.0], [211.0, 144.0], [186.0, 144.0]]], "lines": ["あぁ、"]}, {"box": [117, 167, 163, 268], "vertical": true, "font_size": 21, "lines_coords": [[[144.0, 168.0], [163.0, 168.0], [163.0, 268.0], [144.0, 268.0]], [[117.0, 167.0], [137.0, 167.0], [137.0, 253.0], [117.0, 253.0]]], "lines": ["あれはもう", "降りたよ。"]}, {"box": [398, 326, 473, 464], "vertical": true, "font_size": 19, "lines_coords": [[[454.0, 329.0], [470.0, 329.0], [470.0, 425.0], [454.0, 425.0]], [[423.0, 326.0], [443.0, 326.0], [443.0, 444.0], [423.0, 444.0]], [[398.0, 329.0], [418.0, 329.0], [418.0, 464.0], [398.0, 464.0]]], "lines": ["．．．ところで", "メガネの彼は", "いないのかい？"]}, {"box": [685, 546, 731, 680], "vertical": true, "font_size": 20, "lines_coords": [[[712.0, 546.0], [731.0, 546.0], [731.0, 680.0], [712.0, 680.0]], [[685.0, 547.0], [705.0, 547.0], [705.0, 653.0], [685.0, 653.0]]], "lines": ["いや、いいんだ", "いないなら。"]}, {"box": [623, 683, 669, 779], "vertical": true, "font_size": 20, "lines_coords": [[[649.0, 683.0], [669.0, 683.0], [669.0, 779.0], [649.0, 779.0]], [[623.0, 683.0], [644.0, 683.0], [644.0, 750.0], [623.0, 750.0]]], "lines": ["聞かないで", "おくよ。"]}, {"box": [97, 703, 199, 807], "vertical": true, "font_size": 18, "lines_coords": [[[178.0, 704.0], [197.0, 704.0], [197.0, 800.0], [178.0, 800.0]], [[151.0, 703.0], [170.0, 703.0], [170.0, 781.0], [151.0, 781.0]], [[125.0, 704.0], [141.0, 704.0], [141.0, 800.0], [125.0, 800.0]], [[98.0, 704.0], [114.0, 704.0], [114.0, 806.0], [98.0, 806.0]]], "lines": ["バンドには", "それぞれ", "事情がある", "だろうから。"]}, {"box": [654, 902, 728, 1038], "vertical": true, "font_size": 17, "lines_coords": [[[709.0, 904.0], [726.0, 904.0], [726.0, 1038.0], [709.0, 1038.0]], [[682.0, 903.0], [699.0, 903.0], [699.0, 1018.0], [682.0, 1018.0]], [[655.0, 904.0], [672.0, 904.0], [672.0, 987.0], [655.0, 987.0]]], "lines": ["あれから色々と", "思うところが", "あってね。"]}, {"box": [128, 949, 229, 1125], "vertical": true, "font_size": 20, "lines_coords": [[[208.0, 949.0], [228.0, 949.0], [228.0, 1067.0], [208.0, 1067.0]], [[181.0, 950.0], [201.0, 950.0], [201.0, 1125.0], [181.0, 1125.0]], [[152.0, 949.0], [175.0, 949.0], [175.0, 1088.0], [152.0, 1088.0]], [[128.0, 951.0], [145.0, 951.0], [145.0, 1114.0], [128.0, 1114.0]]], "lines": ["今はこうして", "本当にいいバンドを", "探して、全国を", "歩きまわってるよ。"]}], "img_path": "160.png"}, {"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [637, 64, 709, 203], "vertical": true, "font_size": 18, "lines_coords": [[[687.0, 64.0], [707.0, 64.0], [709.0, 183.0], [689.0, 183.0]], [[661.0, 65.0], [681.0, 65.0], [681.0, 203.0], [661.0, 203.0]], [[637.0, 66.0], [652.0, 66.0], [652.0, 202.0], [637.0, 202.0]]], "lines": ["本当はもっと", "割のいい仕事も", "あるんだか．．．"]}, {"box": [421, 94, 439, 163], "vertical": true, "font_size": 18, "lines_coords": [[[421.0, 126.0], [439.0, 126.0], [439.0, 161.0], [421.0, 161.0]]], "lines": ["ま、"]}, {"box": [583, 236, 655, 373], "vertical": true, "font_size": 18, "lines_coords": [[[635.0, 236.0], [655.0, 236.0], [655.0, 355.0], [635.0, 355.0]], [[607.0, 236.0], [627.0, 236.0], [627.0, 373.0], [607.0, 373.0]], [[583.0, 239.0], [599.0, 239.0], [599.0, 343.0], [583.0, 343.0]]], "lines": ["おかげで僕の", "会社での評判は", "ガタ落ちだ。"]}, {"box": [703, 507, 730, 597], "vertical": true, "font_size": 22, "lines_coords": [[[703.0, 507.0], [728.0, 507.0], [730.0, 597.0], [706.0, 597.0]]], "lines": ["．．．それと、"]}, {"box": [80, 277, 155, 442], "vertical": true, "font_size": 20, "lines_coords": [[[134.0, 277.0], [154.0, 277.0], [154.0, 394.0], [134.0, 394.0]], [[107.0, 278.0], [127.0, 278.0], [127.0, 414.0], [107.0, 414.0]], [[80.0, 277.0], [100.0, 277.0], [100.0, 440.0], [80.0, 440.0]]], "lines": ["今日は君達の", "演奏もゆっくり", "観させてもらうよ。"]}, {"box": [638, 556, 685, 678], "vertical": true, "font_size": 22, "lines_coords": [[[665.0, 556.0], [685.0, 556.0], [685.0, 678.0], [665.0, 678.0]], [[638.0, 561.0], [658.0, 561.0], [658.0, 667.0], [638.0, 667.0]]], "lines": ["メガネの彼に", "伝えてくれ。"]}, {"box": [400, 816, 421, 915], "vertical": true, "font_size": 20, "lines_coords": [[[400.0, 816.0], [420.0, 816.0], [420