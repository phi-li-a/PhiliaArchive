{"version": "0.2.0-beta.6", "img_width": 835, "img_height": 1200, "blocks": [{"box": [689, 92, 740, 216], "vertical": true, "font_size": 23, "lines_coords": [[[715.0, 92.0], [740.0, 92.0], [740.0, 183.0], [715.0, 183.0]], [[689.0, 92.0], [713.0, 92.0], [713.0, 216.0], [689.0, 216.0]]], "lines": ["結局僕は", "平凡な人間で、"]}, {"box": [170, 141, 276, 300], "vertical": true, "font_size": 22, "lines_coords": [[[255.0, 142.0], [276.0, 142.0], [272.0, 300.0], [251.0, 300.0]], [[227.0, 142.0], [248.0, 142.0], [247.0, 298.0], [226.0, 298.0]], [[200.0, 144.0], [220.0, 144.0], [220.0, 298.0], [200.0, 298.0]], [[170.0, 141.0], [197.0, 141.0], [197.0, 193.0], [170.0, 193.0]]], "lines": ["人はいつか死んで", "何もなかったかの", "ように消えてゆく", "けど、"]}, {"box": [606, 225, 700, 385], "vertical": true, "font_size": 23, "lines_coords": [[[673.0, 225.0], [697.0, 225.0], [700.0, 310.0], [675.0, 310.0]], [[653.0, 227.0], [673.0, 227.0], [673.0, 370.0], [653.0, 370.0]], [[627.0, 225.0], [652.0, 225.0], [655.0, 385.0], [631.0, 385.0]], [[606.0, 228.0], [627.0, 228.0], [627.0, 315.0], [606.0, 315.0]]], "lines": ["そのくせ", "悩んで苦しんで、", "でもしょっちゅう", "笑ってて。"]}, {"box": [124, 288, 173, 446], "vertical": true, "font_size": 22, "lines_coords": [[[152.0, 289.0], [173.0, 289.0], [173.0, 398.0], [152.0, 398.0]], [[125.0, 288.0], [146.0, 288.0], [145.0, 446.0], [124.0, 446.0]]], "lines": ["それはまー", "自然なことなんだ。"]}, {"box": [656, 551, 734, 708], "vertical": true, "font_size": 23, "lines_coords": [[[710.0, 551.0], [734.0, 551.0], [734.0, 671.0], [710.0, 671.0]], [[683.0, 551.0], [707.0, 551.0], [707.0, 708.0], [683.0, 708.0]], [[656.0, 553.0], [676.0, 553.0], [676.0, 637.0], [656.0, 637.0]]], "lines": ["僕は死ぬこと", "なんて怖くないと", "思ってた"]}, {"box": [695, 774, 771, 958], "vertical": true, "font_size": 20, "lines_coords": [[[750.0, 774.0], [770.0, 774.0], [770.0, 931.0], [750.0, 931.0]], [[722.0, 775.0], [742.0, 775.0], [742.0, 912.0], [722.0, 912.0]], [[695.0, 775.0], [715.0, 775.0], [715.0, 957.0], [695.0, 957.0]]], "lines": ["．．．いや、誰だって", "死ぬ