 612.0], [689.0, 712.0], [673.0, 712.0]]], "lines": ["もう何も", "言えねーな。"]}, {"box": [110, 706, 183, 822], "vertical": true, "font_size": 19, "lines_coords": [[[163.0, 706.0], [183.0, 706.0], [183.0, 786.0], [163.0, 786.0]], [[135.0, 706.0], [155.0, 706.0], [155.0, 822.0], [135.0, 822.0]], [[111.0, 707.0], [127.0, 707.0], [127.0, 812.0], [111.0, 812.0]]], "lines": ["まんまと", "そんな奴らの", "仲間入りだ。"]}, {"box": [672, 938, 721, 1055], "vertical": true, "font_size": 21, "lines_coords": [[[695.0, 938.0], [721.0, 938.0], [721.0, 1001.0], [695.0, 1001.0]], [[673.0, 941.0], [689.0, 941.0], [689.0, 1054.0], [673.0, 1054.0]]], "lines": ["芽衣子", "憶えてるか？"]}, {"box": [604, 1073, 624, 1113], "vertical": true, "font_size": 20, "lines_coords": [[[604.0, 1074.0], [624.0, 1074.0], [624.0, 1113.0], [604.0, 1113.0]]], "lines": ["ん？"]}, {"box": [208, 931, 282, 1075], "vertical": true, "font_size": 20, "lines_coords": [[[262.0, 931.0], [282.0, 931.0], [282.0, 1068.0], [262.0, 1068.0]], [[235.0, 932.0], [255.0, 932.0], [255.0, 1040.0], [235.0, 1040.0]], [[208.0, 932.0], [224.0, 932.0], [224.0, 1075.0], [208.0, 1075.0]]], "lines": ["前にウチの店で", "「今の生活で", "満たされてる？"]}, {"box": [111, 979, 161, 1137], "vertical": true, "font_size": 20, "lines_coords": [[[138.0, 979.0], [161.0, 979.0], [161.0, 1137.0], [138.0, 1137.0]], [[112.0, 982.0], [132.0, 982.0], [131.0, 1116.0], [111.0, 1116.0]]], "lines": ["「人生は何？」って", "俺に聞いたろ？"]}]}