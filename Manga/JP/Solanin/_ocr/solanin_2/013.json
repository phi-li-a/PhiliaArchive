es_coords": [[[748.0, 517.0], [768.0, 517.0], [768.0, 641.0], [748.0, 641.0]], [[721.0, 516.0], [741.0, 516.0], [741.0, 692.0], [721.0, 692.0]], [[699.0, 517.0], [715.0, 517.0], [715.0, 670.0], [699.0, 670.0]], [[669.0, 514.0], [696.0, 514.0], [696.0, 561.0], [669.0, 561.0]]], "lines": ["おっまえ、今、", "すげえ上のほうから", "もの言ったよね！？", "ね！？"]}, {"box": [580, 568, 653, 753], "vertical": true, "font_size": 20, "lines_coords": [[[633.0, 568.0], [653.0, 568.0], [653.0, 735.0], [633.0, 735.0]], [[606.0, 569.0], [626.0, 569.0], [626.0, 753.0], [606.0, 753.0]], [[580.0, 569.0], [597.0, 569.0], [597.0, 723.0], [580.0, 723.0]]], "lines": ["髪黒く染めて、内定", "取れたら、すぐ大人に", "なれちゃうんだ！？"]}, {"box": [467, 552, 506, 675], "vertical": true, "font_size": 30, "lines_coords": [[[471.0, 558.0], [501.0, 558.0], [501.0, 675.0], [471.0, 675.0]]], "lines": ["ズえっ！？"]}, {"box": [70, 611, 145, 728], "vertical": true, "font_size": 20, "lines_coords": [[[122.0, 611.0], [145.0, 611.0], [145.0, 727.0], [122.0, 727.0]], [[94.0, 612.0], [115.0, 612.0], [115.0, 708.0], [94.0, 708.0]], [[70.0, 612.0], [86.0, 612.0], [86.0, 716.0], [70.0, 716.0]]], "lines": ["ワリィ。今日", "種田、狐が", "憑いてんだ。"]}, {"box": [671, 836, 768, 999], "vertical": true, "font_size": 21, "lines_coords": [[[742.0, 836.0], [768.0, 836.0], [768.0, 889.0], [742.0, 889.0]], [[720.0, 837.0], [740.0, 837.0], [740.0, 996.0], [720.0, 996.0]], [[695.0, 839.0], [715.0, 839.0], [715.0, 956.0], [695.0, 956.0]], [[671.0, 837.0], [690.0, 837.0], [690.0, 964.0], [671.0, 964.0]]], "lines": ["種田！", "俺達もう２２なんだ、", "こんなことで", "熱くなんなよ。"]}, {"box": [344, 962, 448, 1117], "vertical": true, "font_size": 20, "lines_coords": [[[427.0, 963.0], [447.0, 963.0], [447.0, 1117.0], [427.0, 1117.0]], [[399.0, 964.0], [419.0, 964.0], [419.0, 1100.0], [399.0, 1100.0]], [[372.0, 963.0], [392.0, 963.0], [392.0, 1100.0], [372.0, 1100.0]], [[344.0, 962.0], [365.0, 962.0], [366.0, 1080.0], [345.0, 1080.0]]], "lines": ["そのかわり俺達の", "熱いステージを", "観せてやるから", "前座頼むぜ。"]}, {"box": [60, 1012, 136, 1166], "ver