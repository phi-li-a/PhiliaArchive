, 576, 1103], "vertical": true, "font_size": 20, "lines_coords": [[[552.0, 937.0], [575.0, 937.0], [575.0, 1022.0], [552.0, 1022.0]], [[524.0, 936.0], [544.0, 936.0], [544.0, 1101.0], [524.0, 1101.0]], [[496.0, 937.0], [515.0, 937.0], [515.0, 1062.0], [496.0, 1062.0]], [[468.0, 936.0], [488.0, 936.0], [488.0, 1028.0], [468.0, 1028.0]]], "lines": ["バンドが", "やりたかっただけ", "なんじゃん？", "．．．ってさ。"]}, {"box": [143, 905, 205, 1056], "vertical": true, "font_size": 24, "lines_coords": [[[177.0, 906.0], [202.0, 906.0], [205.0, 1055.0], [180.0, 1055.0]], [[143.0, 905.0], [170.0, 905.0], [174.0, 1056.0], [147.0, 1056.0]]], "lines": ["みんながいて、", "芽衣子がいて、"]}, {"box": [101, 1137, 187, 1298], "vertical": true, "font_size": 24, "lines_coords": [[[164.0, 1137.0], [187.0, 1137.0], [187.0, 1298.0], [164.0, 1298.0]], [[132.0, 1138.0], [155.0, 1138.0], [155.0, 1253.0], [132.0, 1253.0]], [[101.0, 1140.0], [124.0, 1140.0], [124.0, 1242.0], [101.0, 1242.0]]], "lines": ["きっとホントは", "それだけで", "いいんだ。"]}]}