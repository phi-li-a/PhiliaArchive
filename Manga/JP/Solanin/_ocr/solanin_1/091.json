{"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [804, 88, 929, 252], "vertical": true, "font_size": 25, "lines_coords": [[[894.0, 88.0], [929.0, 88.0], [929.0, 153.0], [894.0, 153.0]], [[868.0, 92.0], [891.0, 92.0], [891.0, 231.0], [868.0, 231.0]], [[835.0, 92.0], [858.0, 92.0], [857.0, 252.0], [833.0, 252.0]], [[805.0, 92.0], [824.0, 92.0], [824.0, 237.0], [805.0, 237.0]]], "lines": ["ただ、", "見た目なんて", "ある程度簡単に", "変わるんスよ。"]}, {"box": [581, 92, 606, 184], "vertical": true, "font_size": 24, "lines_coords": [[[581.0, 92.0], [605.0, 92.0], [605.0, 184.0], [581.0, 184.0]]], "lines": ["本質ぅ？"]}, {"box": [340, 87, 365, 169], "vertical": true, "font_size": 25, "lines_coords": [[[340.0, 87.0], [365.0, 87.0], [365.0, 169.0], [340.0, 169.0]]], "lines": ["そうス。"]}, {"box": [617, 453, 706, 624], "vertical": true, "font_size": 24, "lines_coords": [[[680.0, 453.0], [704.0, 453.0], [704.0, 591.0], [680.0, 591.0]], [[649.0, 455.0], [672.0, 455.0], [672.0, 571.0], [649.0, 571.0]], [[617.0, 453.0], [641.0, 453.0], [641.0, 623.0], [617.0, 623.0]]], "lines": ["でも本質的な", "ことは何も", "変わらなかった。"]}, {"box": [94, 339, 212, 525], "vertical": true, "font_size": 23, "lines_coords": [[[185.0, 341.0], [209.0, 341.0], [209.0, 525.0], [185.0, 525.0]], [[155.0, 340.0], [180.0, 340.0], [177.0, 481.0], [153.0, 481.0]], [[121.0, 339.0], [146.0, 339.0], [147.0, 523.0], [123.0, 523.0]], [[94.0, 343.0], [113.0, 343.0], [113.0, 500.0], [94.0, 500.0]]], "lines": ["人に聴いてもらう", "以上、詞には", "強いメッセージが", "必要なんスよ！！"]}, {"box": [802, 661, 857, 809], "vertical": true, "font_size": 23, "lines_coords": [[[833.0, 661.0], [857.0, 661.0], [857.0, 777.0], [833.0, 777.0]], [[802.0, 663.0], [825.0, 663.0], [825.0, 809.0], [802.0, 809.0]]], "lines": ["でもある日", "気づいたんス。"]}, {"box": [672, 782, 790, 969], "vertical": true, "font_size": 23, "lines_coords": [[[765.0, 782.0], [788.0, 782.0], [790.0, 969.0], [766.0, 969.0]], [[735.0, 786.0], [758.0, 786.0], [758.0, 967.0], [735.0, 967.0]], [[704.0, 787.0], [727.0, 787.0], [727.0, 924.0], [704.0, 924.0]], [[672.0, 786.0], [695.0, 786.0], [695.0, 907.0], [672.0, 907.0]]], "lines": ["あたしの詞なんて", "歌うため無理矢理", "ひねり出した", "作りモノで、"]}, {"box": [250, 672, 369, 836], "vertical": true, "font_size": 24, "lines_coords": [[[341.0, 672.0], [369.0, 672.0], [369.0, 812.0], [341.0, 812.0]], [[314.0, 672.0], [337.0, 672.0], [337.0, 812.0], [314.0, 812.0]], [[284.0, 675.0], [303.0, 675.0], [303.0, 832.0], [284.0, 832.0]], [[250.0, 672.0], [270.0, 672.0], [272.0, 836.0], [251.0, 836.0]]], "lines": ["こんな平坦で", "退屈で曖昧な", "日常に生きてる", "あたし達からは"]}, {"box": [129, 828, 244, 1017], "vertical": true, "font_size": 24, "lines_coords": [[[221.0, 829.0], [244.0, 829.0], [244.0, 1014.0], [221.0, 1014.0]], [[188.0, 828.0], [216.0, 828.0], [216.0, 1017.0], [188.0, 1017.0]], [[158.0, 829.0], [181.0, 829.0], [181.0, 992.0], [158.0, 992.0]], [[129.0, 831.0], [153.0, 831.0], [153.0, 933.0], [129.0, 933.0]]], "lines": ["悩むために悩んで", "こねくりまわした", "贋物しか産まれ", "ないって。"]}, {"box": [777, 1050, 833, 1221], "vertical": true, "font_size": 24, "lines_coords": [[[809.0, 1051.0], [832.0, 1051.0], [832.0, 1211.0], [809.0, 1211.0]], [[777.0, 1050.0], [801.0, 1050.0], [801.0, 1220.0], [777.0, 1220.0]]], "lines": ["．．．時代のせいに", "すんじゃねいよ。"]}, {"box": [259, 1063, 314, 1252], "vertical": true, "font_size": 21, "lines_coords": [[[291.0, 1063.0], [314.0, 1063.0], [311.0, 1248.0], [288.0, 1248.0]], [[259.0, 1066.0], [278.0, 1066.0], [278.0, 1252.0], [259.0, 1252.0]]], "lines": ["伝えるべきものが", "見つからないとか。"]}, {"box": [127, 1163, 210, 1323], "vertical": true, "font_size": 21, "lines_coords": [[[187.0, 1163.0], [210.0, 1163.0], [210.0, 1323.0], [187.0, 1323.0]], [[157.0, 1164.0], [176.0, 1164.0], [176.0, 1275.0], [157.0, 1275.0]], [[127.0, 1164.0], [146.0, 1164.0], [146.0, 1311.0], [127.0, 1311.0]]], "lines": ["．．．種田って奴も", "たまにソレ", "言ってたなぁ。"]}]}