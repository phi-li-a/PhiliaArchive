{"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [782, 113, 839, 451], "vertical": true, "font_size": 24, "lines_coords": [[[816.0, 114.0], [839.0, 114.0], [839.0, 254.0], [816.0, 254.0]], [[782.0, 113.0], [805.0, 113.0], [805.0, 451.0], [782.0, 451.0]]], "lines": ["だって加藤は", "普通の奴だもん。これから長くて"]}, {"box": [131, 233, 254, 441], "vertical": true, "font_size": 25, "lines_coords": [[[224.0, 235.0], [254.0, 235.0], [254.0, 308.0], [224.0, 308.0]], [[196.0, 236.0], [220.0, 236.0], [220.0, 374.0], [196.0, 374.0]], [[165.0, 233.0], [188.0, 233.0], [187.0, 441.0], [164.0, 441.0]], [[133.0, 233.0], [157.0, 233.0], [154.0, 427.0], [131.0, 427.0]]], "lines": ["だから", "ギリギリまで", "遊ばせてやろうとは", "思ってるんだよね。"]}, {"box": [686, 289, 775, 496], "vertical": true, "font_size": 24, "lines_coords": [[[747.0, 289.0], [775.0, 289.0], [775.0, 432.0], [747.0, 432.0]], [[719.0, 292.0], [742.0, 292.0], [742.0, 496.0], [719.0, 496.0]], [[686.0, 291.0], [709.0, 291.0], [710.0, 440.0], [687.0, 440.0]]], "lines": ["退屈な人生が", "待ってるってアイツ", "わかってるし。"]}, {"box": [273, 533, 360, 671], "vertical": true, "font_size": 23, "lines_coords": [[[337.0, 533.0], [360.0, 533.0], [360.0, 671.0], [337.0, 671.0]], [[306.0, 534.0], [329.0, 534.0], [329.0, 669.0], [306.0, 669.0]], [[273.0, 534.0], [298.0, 534.0], [298.0, 613.0], [273.0, 613.0]]], "lines": ["ま、それでも", "あたしも甘い", "けどね。"]}, {"box": [176, 575, 262, 765], "vertical": true, "font_size": 23, "lines_coords": [[[239.0, 575.0], [262.0, 575.0], [262.0, 721.0], [239.0, 721.0]], [[207.0, 576.0], [231.0, 576.0], [231.0, 715.0], [207.0, 715.0]], [[176.0, 578.0], [195.0, 578.0], [195.0, 765.0], [176.0, 765.0]]], "lines": ["働いて食べる、", "コレ人として", "当然のことだもん。"]}, {"box": [803, 638, 851, 764], "vertical": true, "font_size": 29, "lines_coords": [[[823.0, 638.0], [851.0, 642.0], [832.0, 764.0], [803.0, 760.0]]], "lines": ["風がでてきた"]}, {"box": [817, 809, 875, 925], "vertical": true, "font_size": 24, "lines_coords": [[[850.0, 809.0], [874.0, 809.0], [874.0, 925.0], [850.0, 925.0]], [[817.0, 809.0], [840.0, 809.0], [840.0, 900.0], [817.0, 900.0]]], "lines": ["．．．で、今日", "種田は？"]}, {"box": [833, 961, 875, 1059], "vertical": true, "font_size": 20, "lines_coords": [[[854.0, 962.0], [874.0, 962.0], [874.0, 1007.0], [854.0, 1007.0]], [[833.0, 967.0], [853.0, 967.0], [853.0, 1055.0], [833.0, 1055.0]]], "lines": ["また", "いますよ。"]}, {"box": [578, 947, 664, 1127], "vertical": true, "font_size": 24, "lines_coords": [[[641.0, 947.0], [664.0, 947.0], [664.0, 1085.0], [641.0, 1085.0]], [[611.0, 947.0], [630.0, 947.0], [630.0, 1127.0], [611.0, 1127.0]], [[578.0, 948.0], [601.0, 948.0], [601.0, 1119.0], [578.0, 1119.0]]], "lines": ["あー、なんか", "仕事たてこんでて", "３日帰ってない。"]}, {"box": [486, 858, 530, 975], "vertical": true, "font_size": 21, "lines_coords": [[[508.0, 891.0], [530.0, 891.0], [530.0, 925.0], [508.0, 925.0]], [[486.0, 902.0], [507.0, 902.0], [509.0, 974.0], [489.0, 974.0]]], "lines": ["な", "いこうか"]}, {"box": [112, 926, 226, 1145], "vertical": true, "font_size": 23, "lines_coords": [[[203.0, 928.0], [226.0, 928.0], [226.0, 1067.0], [203.0, 1067.0]], [[172.0, 926.0], [195.0, 926.0], [195.0, 1111.0], [172.0, 1111.0]], [[142.0, 928.0], [165.0, 928.0], [165.0, 1134.0], [142.0, 1134.0]], [[112.0, 928.0], [131.0, 928.0], [131.0, 1145.0], [112.0, 1145.0]]], "lines": ["．．．ねぇ芽衣子", "あんたから、仕事", "辞めたって聞いた時", "ちょっと思ったんだ。"]}, {"box": [467, 1041, 559, 1227], "vertical": true, "font_size": 24, "lines_coords": [[[531.0, 1041.0], [559.0, 1041.0], [556.0, 1207.0], [529.0, 1207.0]], [[500.0, 1044.0], [523.0, 1044.0], [523.0, 1227.0], [500.0, 1227.0]], [[467.0, 1043.0], [496.0, 1043.0], [496.0, 1126.0], [467.0, 1126.0]]], "lines": ["バイトのくせに", "変に頑張ってんだ", "あの人。"]}, {"box": [66, 1156, 187, 1363], "vertical": true, "font_size": 23, "lines_coords": [[[164.0, 1158.0], [187.0, 1158.0], [187.0, 1249.0], [164.0, 1249.0]], [[132.0, 1158.0], [155.0, 1158.0], [155.0, 1319.0], [132.0, 1319.0]], [[101.0, 1158.0], [124.0, 1158.0], [124.0, 1363.0], [101.0, 1363.0]], [[66.0, 1156.0], [90.0, 1156.0], [92.0, 1307.0], [69.0, 1307.0]]], "lines": ["無意識に", "芽衣子は種田を", "追い込んでるんじゃ", "ないかってさ。"]}]}