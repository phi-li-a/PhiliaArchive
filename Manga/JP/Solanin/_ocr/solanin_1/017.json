{"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [656, 103, 763, 337], "vertical": true, "font_size": 31, "lines_coords": [[[732.0, 106.0], [761.0, 106.0], [761.0, 329.0], [732.0, 329.0]], [[691.0, 103.0], [728.0, 103.0], [724.0, 337.0], [687.0, 337.0]], [[656.0, 106.0], [684.0, 106.0], [684.0, 231.0], [656.0, 231.0]]], "lines": ["．．．きっと社会人に", "向いてないのだよ、", "あたしは。"]}, {"box": [315, 155, 403, 303], "vertical": true, "font_size": 23, "lines_coords": [[[380.0, 155.0], [403.0, 155.0], [403.0, 295.0], [380.0, 295.0]], [[349.0, 158.0], [369.0, 158.0], [369.0, 293.0], [349.0, 293.0]], [[315.0, 157.0], [339.0, 157.0], [339.0, 303.0], [315.0, 303.0]]], "lines": ["入社した頃は", "これでも努力", "してみたんだ。"]}, {"box": [771, 499, 858, 663], "vertical": true, "font_size": 24, "lines_coords": [[[833.0, 500.0], [858.0, 500.0], [858.0, 571.0], [833.0, 571.0]], [[802.0, 499.0], [827.0, 499.0], [827.0, 591.0], [802.0, 591.0]], [[772.0, 499.0], [792.0, 499.0], [791.0, 663.0], [771.0, 663.0]]], "lines": ["１日中", "塀の中に", "閉じ込められて、"]}, {"box": [637, 582, 727, 734], "vertical": true, "font_size": 24, "lines_coords": [[[704.0, 585.0], [727.0, 585.0], [727.0, 734.0], [704.0, 734.0]], [[672.0, 583.0], [695.0, 583.0], [695.0, 723.0], [672.0, 723.0]], [[639.0, 582.0], [668.0, 583.0], [665.0, 665.0], [637.0, 664.0]]], "lines": ["毎日我慢大会", "してるよーな", "カンジ。"]}, {"box": [177, 277, 299, 462], "vertical": true, "font_size": 23, "lines_coords": [[[276.0, 277.0], [299.0, 277.0], [299.0, 440.0], [276.0, 440.0]], [[241.0, 277.0], [266.0, 277.0], [265.0, 462.0], [240.0, 462.0]], [[210.0, 278.0], [233.0, 278.0], [233.0, 437.0], [210.0, 437.0]], [[177.0, 277.0], [203.0, 277.0], [205.0, 358.0], [179.0, 358.0]]], "lines": ["でもどーしても", "仕事つまんないし", "みんなと馴染め", "ないの。"]}, {"box": [814, 787, 903, 977], "vertical": true, "font_size": 24, "lines_coords": [[[880.0, 788.0], [903.0, 788.0], [903.0, 925.0], [880.0, 925.0]], [[847.0, 787.0], [872.0, 787.0], [869.0, 903.0], [844.0, 903.0]], [[814.0, 787.0], [839.0, 787.0], [840.0, 977.0], [816.0, 977.0]]], "lines": ["１年も経てば", "頭おかしく", "なれるかなーって、"]}, {"box": [689, 851, 777, 991], "vertical": true, "font_size": 24, "lines_coords": [[[754.0, 851.0], [777.0, 851.0], [777.0, 991.0], [754.0, 991.0]], [[723.0, 853.0], [746.0, 853.0], [746.0, 969.0], [723.0, 969.0]], [[689.0, 851.0], [712.0, 851.0], [715.0, 978.0], [691.0, 978.0]]], "lines": ["思ってたけど", "案外ならな", "かったりで。"]}, {"box": [375, 836, 438, 933], "vertical": true, "font_size": 31, "lines_coords": [[[408.0, 838.0], [438.0, 838.0], [438.0, 905.0], [408.0, 905.0]], [[375.0, 836.0], [407.0, 836.0], [407.0, 903.0], [375.0, 903.0]]], "lines": ["．．．ねー", "平八"]}, {"box": [80, 859, 217, 1066], "vertical": true, "font_size": 24, "lines_coords": [[[185.0, 859.0], [214.0, 859.0], [217.0, 957.0], [188.0, 957.0]], [[164.0, 861.0], [187.0, 861.0], [187.0, 1003.0], [164.0, 1003.0]], [[136.0, 861.0], [159.0, 861.0], [159.0, 1004.0], [136.0, 1004.0]], [[110.0, 859.0], [133.0, 859.0], [131.0, 1010.0], [108.0, 1010.0]], [[83.0, 859.0], [106.0, 859.0], [103.0, 1063.0], [80.0, 1063.0]]], "lines": ["とにかく", "平八と過ごす", "この昼休みが、", "仕事中唯一の", "癒やしダイムなのよ。"]}, {"box": [561, 1142, 648, 1282], "vertical": true, "font_size": 23, "lines_coords": [[[623.0, 1142.0], [648.0, 1142.0], [645.0, 1264.0], [620.0, 1264.0]], [[591.0, 1144.0], [615.0, 1144.0], [615.0, 1282.0], [591.0, 1282.0]], [[563.0, 1145.0], [582.0, 1145.0], [582.0, 1266.0], [563.0, 1266.0]]], "lines": ["．．．いやーん", "なんかこの話", "超重たーい。"]}]}