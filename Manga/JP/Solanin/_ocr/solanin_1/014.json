": [307, 605, 365, 753], "vertical": true, "font_size": 24, "lines_coords": [[[336.0, 605.0], [365.0, 605.0], [365.0, 701.0], [336.0, 701.0]], [[307.0, 605.0], [330.0, 605.0], [330.0, 753.0], [307.0, 753.0]]], "lines": ["あ、ホラ", "直ったじゃん。"]}, {"box": [165, 437, 226, 525], "vertical": true, "font_size": 29, "lines_coords": [[[191.0, 441.0], [226.0, 441.0], [226.0, 522.0], [191.0, 522.0]], [[165.0, 437.0], [188.0, 437.0], [188.0, 525.0], [165.0, 525.0]]], "lines": ["へえ。", "すごいね。"]}, {"box": [721, 643, 838, 854], "vertical": true, "font_size": 23, "lines_coords": [[[818.0, 645.0], [838.0, 645.0], [838.0, 777.0], [818.0, 777.0]], [[786.0, 643.0], [809.0, 643.0], [809.0, 766.0], [786.0, 766.0]], [[753.0, 645.0], [776.0, 645.0], [776.0, 803.0], [753.0, 803.0]], [[721.0, 643.0], [745.0, 643.0], [745.0, 854.0], [721.0, 854.0]]], "lines": ["ウチの会社は", "二流だけど、", "地味さは一流の", "ＯＡ機器メーカーで、"]}, {"box": [717, 866, 855, 1178], "vertical": true, "font_size": 26, "lines_coords": [[[813.0, 869.0], [847.0, 866.0], [855.0, 954.0], [821.0, 957.0]], [[813.0, 983.0], [836.0, 983.0], [836.0, 1097.0], [813.0, 1097.0]], [[782.0, 981.0], [806.0, 981.0], [803.0, 1103.0], [779.0, 1103.0]], [[749.0, 983.0], [772.0, 983.0], [772.0, 1142.0], [749.0, 1142.0]], [[717.0, 981.0], [741.0, 981.0], [742.0, 1178.0], [719.0, 1178.0]]], "lines": ["えへっ。", "でも先輩の", "修理する姿、", "なかなかサマに", "なってましたよォ。"]}, {"box": [617, 645, 672, 846], "vertical": true, "font_size": 23, "lines_coords": [[[649.0, 645.0], [672.0, 645.0], [672.0, 846.0], [649.0, 846.0]], [[617.0, 645.0], [641.0, 645.0], [641.0, 787.0], [617.0, 787.0]]], "lines": ["あたしはつつましく", "社員している。"]}, {"box": [150, 663, 267, 853], "vertical": true, "font_size": 24, "lines_coords": [[[244.0, 663.0], [267.0, 663.0], [267.0, 821.0], [244.0, 821.0]], [[213.0, 663.0], [236.0, 663.0], [236.0, 823.0], [213.0, 823.0]], [[181.0, 664.0], [205.0, 664.0], [205.0, 821.0], [181.0, 821.0]], [[153.0, 663.0], [172.0, 663.0], [169.0, 853.0], [150.0, 853.0]]], "lines": ["あんたもウチの", "社員なんだから