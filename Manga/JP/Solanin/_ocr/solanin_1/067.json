{"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [764, 139, 851, 388], "vertical": true, "font_size": 24, "lines_coords": [[[823.0, 143.0], [851.0, 143.0], [851.0, 246.0], [823.0, 246.0]], [[791.0, 139.0], [823.0, 140.0], [814.0, 388.0], [783.0, 386.0]], [[764.0, 144.0], [783.0, 144.0], [783.0, 244.0], [764.0, 244.0]]], "lines": ["．．．ふふ、", "変わらないわね昔から", "芽衣子は。"]}, {"box": [506, 239, 561, 361], "vertical": true, "font_size": 21, "lines_coords": [[[535.0, 239.0], [559.0, 239.0], [561.0, 355.0], [538.0, 355.0]], [[507.0, 241.0], [526.0, 241.0], [526.0, 356.0], [507.0, 356.0]]], "lines": ["親としては", "心配だけど"]}, {"box": [116, 228, 203, 393], "vertical": true, "font_size": 23, "lines_coords": [[[180.0, 228.0], [203.0, 228.0], [203.0, 393.0], [180.0, 393.0]], [[149.0, 229.0], [172.0, 229.0], [172.0, 367.0], [149.0, 367.0]], [[116.0, 228.0], [139.0, 228.0], [142.0, 355.0], [118.0, 355.0]]], "lines": ["大丈夫よ種田君", "そんなに緊張", "しなくても。"]}, {"box": [724, 315, 777, 518], "vertical": true, "font_size": 24, "lines_coords": [[[758.0, 317.0], [777.0, 317.0], [777.0, 518.0], [758.0, 518.0]], [[725.0, 315.0], [746.0, 315.0], [745.0, 462.0], [724.0, 462.0]]], "lines": ["向こう見ずというか", "単純というか。"]}, {"box": [150, 436, 236, 645], "vertical": true, "font_size": 23, "lines_coords": [[[210.0, 438.0], [233.0, 438.0], [236.0, 538.0], [213.0, 538.0]], [[181.0, 437.0], [205.0, 437.0], [205.0, 645.0], [181.0, 645.0]], [[150.0, 436.0], [173.0, 436.0], [173.0, 541.0], [150.0, 541.0]]], "lines": ["あなた達、", "うまくやっていける", "気がする。"]}, {"box": [776, 695, 894, 880], "vertical": true, "font_size": 22, "lines_coords": [[[870.0, 698.0], [894.0, 698.0], [894.0, 791.0], [870.0, 791.0]], [[838.0, 695.0], [861.0, 695.0], [861.0, 880.0], [838.0, 880.0]], [[808.0, 698.0], [831.0, 698.0], [831.0, 836.0], [808.0, 836.0]], [[776.0, 698.0], [799.0, 698.0], [799.0, 790.0], [776.0, 790.0]]], "lines": ["私も昔は", "東京の大学を出て", "東京の会社に", "勤めて．．．"]}, {"box": [697, 801, 780, 996], "vertical": true, "font_size": 22, "lines_coords": [[[757.0, 801.0], [780.0, 801.0], [780.0, 987.0], [757.0, 987.0]], [[728.0, 805.0], [747.0, 805.0], [747.0, 996.0], [728.0, 996.0]], [[697.0, 803.0], [716.0, 803.0], [716.0, 951.0], [697.0, 951.0]]], "lines": ["あの時代だったし", "結局、秋田に戻って", "しまったけど。"]}, {"box": [142, 869, 250, 1081], "vertical": true, "font_size": 23, "lines_coords": [[[224.0, 870.0], [248.0, 870.0], [250.0, 1024.0], [225.0, 1024.0]], [[196.0, 872.0], [220.0, 872.0], [220.0, 1081.0], [196.0, 1081.0]], [[172.0, 873.0], [191.0, 873.0], [191.0, 1055.0], [172.0, 1055.0]], [[142.0, 869.0], [165.0, 869.0], [168.0, 993.0], [144.0, 993.0]]], "lines": ["私だって、もし", "あの時ああしてれば、", "なんて思ったりも", "するけれど、"]}, {"box": [375, 1019, 529, 1256], "vertical": true, "font_size": 22, "lines_coords": [[[504.0, 1022.0], [524.0, 1022.0], [526.0, 1208.0], [505.0, 1208.0]], [[471.0, 1022.0], [494.0, 1022.0], [494.0, 1160.0], [471.0, 1160.0]], [[440.0, 1022.0], [463.0, 1022.0], [463.0, 1253.0], [440.0, 1253.0]], [[410.0, 1024.0], [429.0, 1024.0], [429.0, 1226.0], [410.0, 1226.0]], [[375.0, 1019.0], [399.0, 1019.0], [400.0, 1238.0], [377.0, 1238.0]]], "lines": ["無意識だろうけど、", "芽衣子は私を", "反面教師にしてるから、", "実家に戻ることには", "抵抗あるんでしょう。"]}, {"box": [98, 1111, 187, 1296], "vertical": true, "font_size": 23, "lines_coords": [[[164.0, 1112.0], [187.0, 1112.0], [187.0, 1296.0], [164.0, 1296.0]], [[132.0, 1112.0], [155.0, 1112.0], [155.0, 1252.0], [132.0, 1252.0]], [[98.0, 1111.0], [123.0, 1111.0], [125.0, 1215.0], [101.0, 1215.0]]], "lines": ["今も幸せといえば", "とっても幸せ", "なのよね。"]}]}