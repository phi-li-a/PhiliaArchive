nes_coords": [[[550.0, 745.0], [579.0, 745.0], [579.0, 827.0], [550.0, 827.0]], [[522.0, 745.0], [545.0, 745.0], [545.0, 905.0], [522.0, 905.0]]], "lines": ["あんた、", "悲しくないの？"]}, {"box": [311, 829, 335, 946], "vertical": true, "font_size": 23, "lines_coords": [[[311.0, 829.0], [334.0, 829.0], [334.0, 944.0], [311.0, 944.0]]], "lines": ["だって．．．"]}, {"box": [561, 1039, 587, 1203], "vertical": true, "font_size": 24, "lines_coords": [[[561.0, 1039.0], [585.0, 1039.0], [587.0, 1203.0], [564.0, 1203.0]]], "lines": ["ふられて当然だ。"]}, {"box": [463, 1036, 520, 1220], "vertical": true, "font_size": 24, "lines_coords": [[[493.0, 1036.0], [520.0, 1036.0], [520.0, 1220.0], [493.0, 1220.0]], [[463.0, 1039.0], [486.0, 1039.0], [486.0, 1177.0], [463.0, 1177.0]]], "lines": ["だって、あたしは", "この数か月間"]}, {"box": [365, 1037, 418, 1252], "vertical": true, "font_size": 24, "lines_coords": [[[395.0, 1037.0], [418.0, 1037.0], [418.0, 1173.0], [395.0, 1173.0]], [[365.0, 1039.0], [388.0, 1039.0], [388.0, 1252.0], [365.0, 1252.0]]], "lines": ["種田を苦しめ", "続けてきたんだから。"]}]}