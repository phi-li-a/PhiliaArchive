lines_coords": [[[449.0, 716.0], [660.0, 712.0], [660.0, 739.0], [449.0, 743.0]], [[650.0, 734.0], [782.0, 728.0], [783.0, 761.0], [652.0, 766.0]]], "lines": ["もうさよならなんだ", "友人が返り"]}, {"box": [415, 779, 757, 998], "vertical": false, "font_size": 119, "lines_coords": [[[415.0, 794.0], [747.0, 779.0], [757.0, 983.0], [425.0, 998.0]], [[466.0, 948.0], [566.0, 951.0], [564.0, 985.0], [464.0, 983.0]]], "lines": ["そんなこともわからなかった方法ですね。僕もどこにかかるとこれは", "おれよ"]}, {"box": [355, 1057, 427, 1281], "vertical": true, "font_size": 29, "lines_coords": [[[396.0, 1059.0], [425.0, 1059.0], [425.0, 1173.0], [396.0, 1173.0]], [[355.0, 1059.0], [384.0, 1059.0], [386.0, 1281.0], [358.0, 1281.0]]], "lines": ["これって", "別れの曲じゃん？"]}, {"box": [560, 1064, 588, 1173], "vertical": true, "font_size": 24, "lines_coords": [[[561.0, 1065.0], [585.0, 1065.0], [585.0, 1167.0], [561.0, 1167.0]]], "lines": ["．．種田あ"]}]}