.0, 836.0], [563.0, 1052.0], [540.0, 1052.0]]], "lines": ["仕事が無いなら", "無いで、毎日に", "ハリが無いというか。"]}, {"box": [435, 1029, 520, 1220], "vertical": true, "font_size": 85, "lines_coords": [[[435.0, 1029.0], [520.0, 1029.0], [520.0, 1220.0], [435.0, 1220.0]]], "lines": ["公共料金の支払いすらおっくうというか。"]}, {"box": [434, 1028, 519, 1222], "vertical": true, "font_size": 23, "lines_coords": [[[500.0, 1028.0], [519.0, 1028.0], [519.0, 1141.0], [500.0, 1141.0]], [[466.0, 1029.0], [489.0, 1029.0], [489.0, 1144.0], [466.0, 1144.0]], [[434.0, 1029.0], [458.0, 1029.0], [458.0, 1222.0], [434.0, 1222.0]]], "lines": ["公共料金の", "支払いすら", "おっくうというか。"]}, {"box": [127, 1151, 215, 1322], "vertical": true, "font_size": 23, "lines_coords": [[[191.0, 1153.0], [214.0, 1153.0], [214.0, 1290.0], [191.0, 1290.0]], [[159.0, 1153.0], [183.0, 1153.0], [183.0, 1291.0], [159.0, 1291.0]], [[128.0, 1151.0], [151.0, 1151.0], [150.0, 1322.0], [127.0, 1322.0]]], "lines": ["今のゆるーい", "幸せな感じは", "気持ちいいけど、"]}]}