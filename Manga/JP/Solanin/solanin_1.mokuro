, [165.0, 406.0], [168.0, 635.0], [139.0, 635.0]]], "lines": ["評価されて", "はじめて価値が", "出るんじゃん！？"]}, {"box": [787, 842, 872, 1004], "vertical": true, "font_size": 22, "lines_coords": [[[847.0, 842.0], [870.0, 842.0], [870.0, 958.0], [847.0, 958.0]], [[817.0, 844.0], [840.0, 844.0], [840.0, 1004.0], [817.0, 1004.0]], [[788.0, 846.0], [808.0, 846.0], [808.0, 958.0], [788.0, 958.0]]], "lines": ["．．．それで．．．", "ホントダメだと", "思ったら．．"]}, {"box": [490, 864, 514, 963], "vertical": true, "font_size": 22, "lines_coords": [[[490.0, 864.0], [514.0, 864.0], [514.0, 963.0], [490.0, 963.0]]], "lines": ["．．．その時、"]}, {"box": [396, 931, 451, 1052], "vertical": true, "font_size": 22, "lines_coords": [[[425.0, 931.0], [448.0, 931.0], [451.0, 1030.0], [427.0, 1030.0]], [[396.0, 939.0], [415.0, 939.0], [415.0, 1052.0], [396.0, 1052.0]]], "lines": ["どうして", "くれるの？"]}, {"box": [567, 1183, 656, 1302], "vertical": true, "font_size": 28, "lines_coords": [[[631.0, 1186.0], [656.0, 1186.0], [656.0, 1279.0], [631.0, 1279.0]], [[594.0, 1183.0], [628.0, 1183.0], [628.0, 1260.0], [594.0, 1260.0]], [[567.0, 1183.0], [591.0, 1183.0], [593.0, 1301.0], [568.0, 1301.0]]], "lines": ["その時は", "その時", "だけど．．．"]}, {"box": [129, 1077, 183, 1212], "vertical": true, "font_size": 22, "lines_coords": [[[158.0, 1077.0], [181.0, 1077.0], [181.0, 1211.0], [158.0, 1211.0]], [[129.0, 1077.0], [149.0, 1077.0], [149.0, 1189.0], [129.0, 1189.0]]], "lines": ["一緒に死んで", "くれるの？"]}], "img_path": "120.png"}, {"version": "0.2.0-beta.6", "img_width": 971, "img_height": 1400, "blocks": [{"box": [783, 131, 806, 229], "vertical": true, "font_size": 22, "lines_coords": [[[783.0, 131.0], [806.0, 131.0], [806.0, 229.0], [783.0, 229.0]]], "lines": ["．．．ごめん"]}, {"box": [697, 233, 754, 299], "vertical": true, "font_size": 22, "lines_coords": [[[722.0, 233.0], [754.0, 233.0], [754.0, 291.0], [722.0, 291.0]], [[697.0, 239.0], [717.0, 239.0], [717.0, 299.0], [697.0, 299.0]]], "lines": ["冗談", "だよ"]}, {"box": [700, 324, 715, 356], "vertical": true, "font_size": 22, "lines_coords": [[[700.0, 324.0], [715.0, 324.0], [715.0, 356.0], [700.0, 356.0]]], "lines": ["！"]}, {"box": [749, 570, 838, 709], "vertical": true, "font_size": 24, "lines_coords": [[[815.0, 572.0], [838.0, 572.0], [838.0, 706.0], [815.0, 706.0]], [[783.0, 571.0], [806.0, 571.0], [806.0, 708.0], [783.0, 708.0]], [[749.0, 570.0], [772.0, 570.0], [775.0, 709.0], [752.0, 709.0]]], "lines": ["ゆうべの喧嘩", "久々にヘビー", "だったなぁ．．．"]}, {"box": [169, 299, 226, 448], "vertical": true, "font_size": 23, "lines_coords": [[[201.0, 299.0], [224.0, 299.0], [221.0, 438.0], [198.0, 438.0]], [[169.0, 300.0], [192.0, 300.0], [192.0, 447.0], [169.0, 447.0]]], "lines": ["ちょっと散歩", "行ってくるよ。"]}, {"box": [663, 674, 719, 790], "vertical": true, "font_size": 24, "lines_coords": [[[696.0, 676.0], [719.0, 676.0], [719.0, 790.0], [696.0, 790.0]], [[663.0, 675.0], [690.0, 674.0], [693.0, 725.0], [666.0, 727.0]]], "lines": ["帰りづらい", "．．．．．．"]}, {"box": [764, 877, 886, 1017], "vertical": true, "font_size": 26, "lines_coords": [[[862.0, 879.0], [886.0, 879.0], [886.0, 1017.0], [862.0, 1017.0]], [[828.0, 879.0], [853.0, 879.0], [854.0, 1017.0], [830.0, 1017.0]], [[798.0, 880.0], [821.0, 880.0], [821.0, 1017.0], [798.0, 1017.0]], [[764.0, 877.0], [795.0, 877.0], [795.0, 936.0], [764.0, 936.0]]], "lines": ["どーしようも", "ないことかも", "しれないけど", "正直、"]}, {"box": [195, 620, 251, 780], "vertical": true, "font_size": 22, "lines_coords": [[[227.0, 620.0], [250.0, 620.0], [250.0, 758.0], [227.0, 758.0]], [[196.0, 620.0], [217.0, 620.0], [216.0, 780.0], [195.0, 780.0]]], "lines": ["今日は加藤ん", "トコ泊まるか．．．"]}, {"box": [404, 1116, 525, 1302], "vertical": true, "font_size": 24, "lines_coords": [[[499.0, 1118.0], [522.0, 1118.0], [522.0, 1302.0], [499.0, 1302.0]], [[467.0, 1118.0], [490.0, 1118.0], [490.0, 1301.0], [467.0, 1301.0]], [[433.0, 1116.0], [458.0, 1116.0], [460.0, 1234.0], [436.0, 1234.0]], [[404.0, 1118.0], [429.0, 1118.0], [429.0, 1200.0], [404.0, 1200.0]]], "lines": ["他人と比べないと", "自分がわからない", "というのは", "悲しい。"]}, {"box": [95, 1148, 215, 1308], "vertical": true, "font_size": 22, "lines_coords": [[[192.0, 1149.0], [211.0, 1149.0], [211.0, 1307.0], [192.0, 1307.0]], [[158.0, 1148.0], [181.0, 1148.0], [181.0, 1287.0], [158.0, 1287.0]], [[127.0, 1148.0], [150.0, 1148.0], [150.0, 1264.0], [127.0, 1264.0]], [[95.0, 1148.0], [118.0, 1148.0], [118.0, 1274.0], [95.0, 1274.0]]], "lines": ["とはいえ自分で", "自分を全肯定", "できるほど", "自信も無い。"]}], "img_path": "121.png"}, {"version": "0.2.0-beta.6", "img_width": 975, "img_height": 1400, "blocks": [{"box": [758, 113, 845, 306], "vertical": true, "font_size": 22, "lines_coords": [[[823.0, 114.0], [842.0, 114.0], [842.0, 273.0], [823.0, 273.0]], [[789.0, 113.0], [812.0, 113.0], [812.0, 306.0], [789.0, 306.0]], [[758.0, 114.0], [782.0, 114.0], [782.0, 216.0], [758.0, 216.0]]], "lines": ["フリーター生活", "というぬるま湯の", "心地好さ。"]}, {"box": [388, 94, 474, 232], "vertical": true, "font_size": 27, "lines_coords": [[[451.0, 94.0], [474.0, 94.0], [471.0, 232.0], [448.0, 232.0]], [[418.0, 95.0], [443.0, 95.0], [443.0, 188.0], [418.0, 188.0]], [[388.0, 97.0], [411.0, 97.0], [411.0, 218.0], [388.0, 218.0]]], "lines": ["真剣に何かを", "する時に", "つきまとう、"]}, {"box": [332, 233, 362, 307], "vertical": true, "font_size": 27, "lines_coords": [[[332.0, 233.0], [362.0, 233.0], [362.0, 307.0], [332.0, 307.0]]], "lines": ["後戻り"]}, {"box": [266, 231, 302, 296], "vertical": true, "font_size": 27, "lines_coords": [[[266.0, 231.0], [302.0, 231.0], [302.0, 296.0], [266.0, 296.0]]], "lines": ["恐怖。"]}, {"box": [274, 233, 357, 373], "vertical": true, "font_size": 24, "lines_coords": [[[304.0, 235.0], [328.0, 235.0], [328.0, 373.0], [304.0, 373.0]]], "lines": ["できなくなる"]}, {"box": [95, 445, 185, 629], "vertical": true, "font_size": 23, "lines_coords": [[[159.0, 447.0], [183.0, 447.0], [183.0, 628.0], [159.0, 628.0]], [[129.0, 447.0], [149.0, 447.0], [149.0, 626.0], [129.0, 626.0]], [[95.0, 445.0], [120.0, 445.0], [120.0, 525.0], [95.0, 525.0]]], "lines": ["時間が経つにつれ", "確実に減ってゆく", "選択肢。"]}, {"box": [201,