[[701.0, 1132.0], [724.0, 1132.0], [724.0, 1231.0], [701.0, 1231.0]]], "lines": ["たとえどんなに", "相性がよかった", "としても"]}, {"box": [274, 1129, 392, 1322], "vertical": true, "font_size": 22, "lines_coords": [[[366.0, 1130.0], [389.0, 1130.0], [389.0, 1311.0], [366.0, 1311.0]], [[336.0, 1129.0], [359.0, 1129.0], [359.0, 1274.0], [336.0, 1274.0]], [[304.0, 1129.0], [328.0, 1129.0], [328.0, 1267.0], [304.0, 1267.0]], [[274.0, 1129.0], [293.0, 1129.0], [293.0, 1322.0], [274.0, 1322.0]]], "lines": ["逆にたった一つの", "小さなひびが、", "致命的な傷に", "なったりするしね。"]}], "img_path": "195.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [634, 60, 653, 218], "vertical": true, "font_size": 22, "lines_coords": [[[634.0, 60.0], [653.0, 60.0], [653.0, 218.0], [634.0, 218.0]]], "lines": ["．．．でも芽衣子！！"]}, {"box": [477, 102, 594, 307], "vertical": true, "font_size": 22, "lines_coords": [[[571.0, 105.0], [594.0, 105.0], [594.0, 263.0], [571.0, 263.0]], [[540.0, 103.0], [563.0, 103.0], [563.0, 288.0], [540.0, 288.0]], [[507.0, 102.0], [531.0, 102.0], [530.0, 307.0], [505.0, 307.0]], [[477.0, 103.0], [500.0, 103.0], [500.0, 241.0], [477.0, 241.0]]], "lines": ["種田とあんたが", "出会ったってこと", "だけで、ものすごい", "確率でしょ？"]}, {"box": [91, 43, 216, 68], "vertical": false, "font_size": 22, "lines_coords": [[[91.0, 46.0], [216.0, 43.0], [216.0, 65.0], [91.0, 68.0]]], "lines": ["ソラニン［"]}, {"box": [739, 553, 846, 775], "vertical": true, "font_size": 28, "lines_coords": [[[816.0, 553.0], [846.0, 553.0], [846.0, 639.0], [816.0, 639.0]], [[779.0, 553.0], [806.0, 553.0], [806.0, 775.0], [779.0, 775.0]], [[739.0, 553.0], [766.0, 553.0], [766.0, 757.0], [739.0, 757.0]]], "lines": ["恋愛は", "自分達で起こした", "奇跡なんだから、"]}, {"box": [109, 283, 194, 467], "vertical": true, "font_size": 24, "lines_coords": [[[170.0, 284.0], [194.0, 284.0], [194.0, 421.0], [170.0, 421.0]], [[136.0, 284.0], [164.0, 284.0], [164.0, 467.0], [136.0, 467.0]], [[109.0, 283.0], [128.0, 283.0], [128.0, 463.0], [109.0, 463.0]]], "lines": ["こんなに長く"