0], [1345.0, 259.0], [1081.0, 259.0]], [[1078.0, 267.0], [1557.0, 267.0], [1557.0, 289.0], [1078.0, 289.0]], [[1076.0, 297.0], [1205.0, 297.0], [1205.0, 318.0], [1076.0, 318.0]], [[1080.0, 327.0], [1174.0, 327.0], [1174.0, 345.0], [1080.0, 345.0]], [[1080.0, 353.0], [1186.0, 353.0], [1186.0, 375.0], [1080.0, 375.0]]], "lines": ["ソラニン・全２巻", "おやすみプンプン「一日巻", "ロｒコトー診療所「１－２２巻", "ＦＡＭＥＣＤＶ－ニキスプの七人－１～２０巻＿安部譲二ノ柿崎正澄", "鉄腕パーティー", "都立水商！", "クロサギ・"]}, {"box": [1253, 299, 1352, 318], "vertical": false, "font_size": 18, "lines_coords": [[[1253.0, 299.0], [1352.0, 300.0], [1352.0, 318.0], [1253.0, 316.0]]], "lines": ["Ｉ～ＩＯ巻－－"]}, {"box": [1457, 176, 1559, 230], "vertical": false, "font_size": 22.0, "lines_coords": [[[1457.0, 208.0], [1559.0, 208.0], [1559.0, 230.0], [1457.0, 230.0]], [[1457.0, 179.0], [1557.0, 176.0], [1557.0, 198.0], [1457.0, 202.0]]], "lines": ["浅野いにお", "浅野いにお"]}, {"box": [1465, 237, 1560, 259], "vertical": false, "font_size": 22, "lines_coords": [[[1465.0, 237.0], [1560.0, 237.0], [1560.0, 259.0], [1465.0, 259.0]]], "lines": ["＿山田貴敏"]}, {"box": [1368, 326, 1560, 346], "vertical": false, "font_size": 20, "lines_coords": [[[1368.0, 326.0], [1560.0, 326.0], [1560.0, 346.0], [1368.0, 346.0]]], "lines": ["室積光ノ猫熊しのぶ"]}, {"box": [1431, 297, 1557, 318], "vertical": false, "font_size": 21, "lines_coords": [[[1431.0, 297.0], [1557.0, 297.0], [1557.0, 318.0], [1431.0, 318.0]]], "lines": ["ゆうきまさみ"]}, {"box": [1204, 357, 1264, 375], "vertical": false, "font_size": 18, "lines_coords": [[[1204.0, 357.0], [1264.0, 357.0], [1264.0, 375.0], [1204.0, 375.0]]], "lines": ["〜２０巻"]}, {"box": [1075, 335, 1600, 501], "vertical": false, "font_size": 47.0, "lines_coords": [[[1401.0, 335.0], [1568.0, 351.0], [1563.0, 396.0], [1396.0, 380.0]], [[1463.0, 354.0], [1600.0, 418.0], [1562.0, 501.0], [1425.0, 437.0]], [[1081.0, 381.0], [1563.0, 378.0], [1563.0, 410.0], [1081.0, 413.0]], [[1075.0, 412.0], [1347.0, 412.0], [1347.0, 432.0], [1075.0, 432.0]]], "lines": ["積光ノ塔熊しの一黒丸ノ夏原・武戸巻一間瀬元朗", "それでは、それがまるためませんが、", "クレジットカールをイキカミーＴｉＰｈｏｎｄｉｎｔ－Ｔｗｉｔ生グランの間、メールの黒丸／星原：武５巻一間瀬元朗", "イギリュールしていたときに、土竜（モグラ）の唄・１〜１４巻～～！！"]}, {"box": [1076, 442, 1560, 614], "vertical": false, "font_size": 24.666666666666668, "lines_coords": [[[1078.0, 442.0], [1479.0, 442.0], [1479.0, 464.0], [1078.0, 464.0]], [[1076.0, 469.0], [1333.0, 467.0], [1333.0, 496.0], [1076.0, 497.0]], [[1076.0, 501.0], [1559.0, 501.0], [1559.0, 523.0], [1076.0, 523.0]], [[1078.0, 528.0], [1264.0, 531.0], [1264.0, 553.0], [1078.0, 550.0]], [[1076.0, 556.0], [1560.0, 558.0], [1560.0, 585.0], [1076.0, 583.0]], [[1110.0, 587.0], [1264.0, 583.0], [1264.0, 610.0], [1110.0, 614.0]]], "lines": ["超無気力戦隊ジャパファイブーー日巻・佐藤", "Ｑ．ｃｏｍａｚｏｎ．Ｏｄｈｓ＿オッポ．．．１～９巻", "さらんぼうドロームクビの悪戯．．．１〜日巻ー北崎拓", "タナトスもしけるの拳・１", "どのはねっ！！絶望的だな。「一日巻、河合克服", "テスターズ・"]}, {"box": [1298, 521, 1565, 566], "vertical": false, "font_size": 45, "lines_coords": [[[1298.0, 521.0], [1565.0, 521.0], [1565.0, 566.0], [1298.0, 566.0]]], "lines": ["この所属は、「で日巻一北崎拓ブ寄」「竹原間二人落合裕介管理」「こち巻」内合克服"]}, {"box": [1492, 466, 1562, 501], "vertical": false, "font_size": 35, "lines_coords": [[[1492.0, 466.0], [1562.0, 466.0], [1562.0, 501.0], [1492.0, 501.0]]], "lines": ["撫まとさ石渡治北崎拓"]}, {"box": [1496, 591, 1557, 609], "vertical": false, "font_size": 18, "lines_coords": [[[1496.0, 591.0], [1557.0, 591.0], [1557.0, 609.0], [1496.0, 609.0]]], "lines": ["，尾正博"]}, {"box": [1476, 676, 1555, 698], "vertical": false, "font_size": 22, "lines_coords": [[[1476.0, 676.0], [1555.0, 676.0], [1555.0, 698.0], [1476.0, 698.0]]], "lines": ["喜国雅彦"]}, {"box": [1073, 677, 1350, 844], "vertical": false, "font_size": 22.833333333333332, "lines_coords": [[[1076.0, 677.0], [1263.0, 677.0], [1263.0, 700.0], [1076.0, 700.0]], [[1075.0, 706.0], [1350.0, 703.0], [1350.0, 725.0], [1075.0, 728.0]], [[1073.0, 733.0], [1312.0, 731.0], [1312.0, 758.0], [1073.0, 760.0]], [[1073.0, 765.0], [1266.0, 763.0], [1266.0, 785.0], [1073.0, 787.0]], [[1078.0, 795.0], [1337.0, 795.0], [1337.0, 816.0], [1078.0, 816.0]], [[1081.0, 822.0], [1282.0, 822.0], [1282.0, 844.0], [1081.0, 844.0]]], "lines": ["魔口ケン・１～２巻", "美晴♥ライシング・１〜４巻", "暁のイージス、１〜４巻", "アオイホノオ「巻", "あんころ。沖縄若松丁目は駅長を", "ＧＯ－ＯＮ・Ｔ〜２巻"]}, {"box": [1061, 604, 1601, 865], "vertical": false, "font_size": 73.33333333333333, "lines_coords": [[[1302.0, 626.0], [1601.0, 717.0], [1557.0, 865.0], [1256.0, 774.0]], [[1061.0, 614.0], [1565.0, 604.0], [1565.0, 642.0], [1061.0, 652.0]], [[1073.0, 644.0], [1559.0, 644.0], [1559.0, 671.0], [1073.0, 671.0]]], "lines": ["それでも、", "というのは、スーパーです。お客様にお願いしておりますので、お問い合わせくださいますね。", "２０１７年１１月２０日（月）に「第二十四四四八くらいます。もうちょっと新しく知っていましたが、"]}, {"box": [1088, 981, 1224, 1000], "vertical": false, "font_size": 18, "lines_coords": [[[1088.0, 981.0], [1224.0, 983.0], [1224.0, 1000.0], [1088.0, 999.0]]], "lines": ["にアクセスすると、"]}, {"box": [1080, 1003, 1212, 1022], "vertical": false, "font_size": 18, "lines_coords": [[[1080.0, 1005.0], [1212.0, 1003.0], [1212.0, 1021.0], [1080.0, 1022.0]]], "lines": ["ＹＳＤをオンラ"]}, {"box": [1076, 906, 1559, 976], "vertical": false, "font_size": 24.5, "lines_coords": [[[1076.0, 910.0], [1559.0, 906.0], [1559.0, 933.0], [1076.0, 937.0]], [[1113.0, 954.0], [1525.0, 954.0], [1525.0, 976.0], [1113.0, 976.0]]], "lines": ["絶望に効くクスリーロＮＥＯＮＯＥ－１〜４巻山田玲司", "わざわざ！／／ｗｗｗ．ｙｏｕｎｇｓｕｎｄａｙＣｏｍ"]}, {"box": [1539, 703, 1562, 838], "vertical": true, "font_size": 23, "lines_coords": [[[1539.0, 703.0], [1562.0, 703.0], [1562.0, 838.0], [1539.0, 838.0]]], "lines": ["う秀彦智学"]}, {"box": [1385, 981, 1543, 1002], "vertical": false, "font_size": 21, "lines_coords": [[[1385.0, 981.0], [1543.0, 981.0], [1543.0, 1002.0], [1385.0, 1002.0]]], "lines": ["情報が詳しくわかり、"]}, {"box": [1363, 1007, 1535, 1022], "vertical": false, "font_size": 15, "lines_coords": [[[1363.0, 1007.0], [1535.0, 1007.0], [1535.0, 1022.0], [1363.0, 1022.0]]], "lines": ["入することもできます。"]}, {"box": [1239, 1239, 1401, 1263], "vertical": false, "font_size": 22, "lines_coords": [[[1239.0, 1240.0], [1401.0, 1239.0], [1401.0, 1261.0], [1239.0, 1263.0]]], "lines": ["浅野いにお"]}, {"box": [1177, 1290, 1494, 1385], "vertical": false, "font_size": 19, "lines_coords": [[[1226.0, 1293.0], [1422.0, 1293.0], [1422.0, 1312.0], [1226.0, 1312.0]], [[1183.0, 1315.0], [1476.0, 1315.0], [1476.0, 1335.0], [1183.0, 1335.0]], [[1183.0, 1334.0], [1454.0, 1335.0], [1454.0, 1360.0], [1183.0, 1359.0]], [[1186.0, 1361.0], [1442.0, 1361.0], [1442.0, 1381.0], [1186.0, 1381.0]]], "lines": ["１８８０年生まれ。茨城県出身。", "２００１年、第１回サンデ一〇Ｘ新人賞入賞：", "２０１７年１１月２０日、主な業界に「素晴らしい世界」", "「ひかりのまち（ともに小社刊がある"]}], "img_path": "003.png"}, {"version": "0.2.0-beta.6", "img_width": 2091, "img_height": 1400, "blocks": [{"box": [1009, 24, 1103, 90], "vertical": false, "font_size": 66, "lines_coords": [[[1009.0, 24.0], [1103.0, 24.0], [1103.0, 90.0], [1009.0, 90.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹＣＯＭＩＣＳ"]}, {"box": [1027, 1025, 1082, 1276], "vertical": true, "font_size": 51, "lines_coords": [[[1029.0, 1028.0], [1080.0, 1028.0], [1080.0, 1273.0], [1029.0, 1273.0]]], "lines": ["浅野いにお"]}, {"box": [363, 1157, 633, 1220], "vertical": false, "font_size": 63, "lines_coords": [[[363.0, 1157.0], [633.0, 1157.0], [633.0, 1220.0], [363.0, 1220.0]]], "lines": ["浅野いにお"]}], "img_path": "004.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "005.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [401, 235, 464, 244], "vertical": false, "font_size": 9, "lines_coords": [[[401.0, 235.0], [464.0, 235.0], [464.0, 244.0], [401.0, 244.0]]], "lines": ["．．．"]}, {"box": [607, 865, 668, 896], "vertical": false, "font_size": 17.0, "lines_coords": [[[609.0, 865.0], [661.0, 865.0], [661.0, 880.0], [609.0, 880.0]], [[607.0, 877.0], [668.0, 877.0], [668.0, 896.0], [607.0, 896.0]]], "lines": ["．．．はあははは！！お兄ちゃんはいけないのですか？", "この時期は１０年１０月１０日には、１２月１１日より１１月１２日（土）においておりますのですが．．．お母さんの日本人では"]}, {"box": [349, 1115, 612, 1171], "vertical": false, "font_size": 56, "lines_coords": [[[349.0, 1115.0], [611.0, 1115.0], [611.0, 1171.0], [349.0, 1171.0]]], "lines": ["浅野いにお"]}], "img_path":