75.0, 1194.0]], [[646.0, 1036.0], [669.0, 1036.0], [669.0, 1151.0], [646.0, 1151.0]], [[619.0, 1034.0], [642.0, 1034.0], [642.0, 1182.0], [619.0, 1182.0]]], "lines": ["．．．なんか種田達は", "バンドがあって", "いいなって", "思っちゃった。"]}, {"box": [497, 1142, 585, 1315], "vertical": true, "font_size": 23, "lines_coords": [[[561.0, 1142.0], [585.0, 1142.0], [585.0, 1282.0], [561.0, 1282.0]], [[529.0, 1142.0], [552.0, 1142.0], [552.0, 1282.0], [529.0, 1282.0]], [[497.0, 1144.0], [520.0, 1144.0], [520.0, 1315.0], [497.0, 1315.0]]], "lines": ["あたし、仕事", "辞めたら何も", "残ってないしさ。"]}, {"box": [149, 1118, 237, 1324], "vertical": true, "font_size": 54, "lines_coords": [[[184.0, 1118.0], [237.0, 1127.0], [202.0, 1324.0], [149.0, 1315.0]]], "lines": ["有馬整形美容外科"]}], "img_path": "039.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [825, 62, 883, 255], "vertical": true, "font_size": 24, "lines_coords": [[[855.0, 62.0], [883.0, 62.0], [883.0, 202.0], [855.0, 202.0]], [[825.0, 62.0], [849.0, 62.0], [849.0, 255.0], [825.0, 255.0]]], "lines": ["バンドなんて", "ただの趣味じゃん。"]}, {"box": [732, 191, 809, 339], "vertical": true, "font_size": 24, "lines_coords": [[[786.0, 191.0], [809.0, 191.0], [809.0, 307.0], [786.0, 307.0]], [[758.0, 191.0], [782.0, 191.0], [782.0, 328.0], [758.0, 328.0]], [[732.0, 192.0], [751.0, 192.0], [751.0, 339.0], [732.0, 339.0]]], "lines": ["趣味の音楽", "なんて一銭の", "得にもならん。"]}, {"box": [99, 129, 157, 246], "vertical": true, "font_size": 24, "lines_coords": [[[132.0, 131.0], [157.0, 131.0], [157.0, 224.0], [132.0, 224.0]], [[102.0, 129.0], [125.0, 129.0], [123.0, 246.0], [99.0, 246.0]]], "lines": ["．．．なんか", "怒ってる？"]}, {"box": [617, 492, 679, 633], "vertical": true, "font_size": 27, "lines_coords": [[[649.0, 492.0], [679.0, 492.0], [679.0, 567.0], [649.0, 567.0]], [[620.0, 493.0], [643.0, 493.0], [641.0, 633.0], [617.0, 633.0]]], "lines": ["そりゃ", "そうだけど．．．"]}, {"box": [92, 541, 127, 669], "vertical": true, "font_size": 35, "lines_coords": [[[92.0, 541.0], [127.0, 541.0], [127.0, 669.0], [92.0, 669.0]]], "lines": ["ひいっ！！"]}, {"box": [412, 720, 471, 861], "vertical": true, "font_size": 25, "lines_coords": [[[447.0, 720.0], [471.0, 720.0], [468.0, 861.0], [444.0, 861.0]], [[412.0, 723.0], [440.0, 723.0], [440.0, 861.0], [412.0, 861.0]]], "lines": ["ちょっと種田", "大丈夫――！？"]}, {"box": [330, 838, 385, 978], "vertical": true, "font_size": 25, "lines_coords": [[[356.0, 838.0], [385.0, 838.0], [385.0, 916.0], [356.0, 916.0]], [[330.0, 843.0], [349.0, 843.0], [349.0, 978.0], [330.0, 978.0]]], "lines": ["そんな", "酔ってたの！？"]}, {"box": [812, 1060, 835, 1200], "vertical": true, "font_size": 29, "lines_coords": [[[812.0, 1060.0], [835.0, 1060.0], [835.0, 1200.0], [812.0, 1200.0]]], "lines": ["．．．芽衣子さん"]}, {"box": [706, 1144, 769, 1253], "vertical": true, "font_size": 29, "lines_coords": [[[741.0, 1147.0], [769.0, 1147.0], [769.0, 1253.0], [741.0, 1253.0]], [[706.0, 1144.0], [742.0, 1144.0], [742.0, 1211.0], [706.0, 1211.0]]], "lines": ["俺、すげー", "怖い。"]}, {"box": [88, 1152, 183, 1323], "vertical": true, "font_size": 28, "lines_coords": [[[150.0, 1152.0], [183.0, 1152.0], [183.0, 1208.0], [150.0, 1208.0]], [[121.0, 1152.0], [146.0, 1152.0], [147.0, 1322.0], [123.0, 1322.0]], [[91.0, 1152.0], [116.0, 1152.0], [113.0, 1276.0], [88.0, 1276.0]]], "lines": ["正直", "これからの生活、", "すげー心配。"]}], "img_path": "040.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [758, 54, 846, 236], "vertical": true, "font_size": 23, "lines_coords": [[[823.0, 54.0], [846.0, 54.0], [846.0, 170.0], [823.0, 170.0]], [[790.0, 54.0], [813.0, 54.0], [813.0, 236.0], [790.0, 236.0]], [[758.0, 56.0], [783.0, 56.0], [783.0, 177.0], [758.0, 177.0]]], "lines": ["芽衣子さん", "今まで一番忙しく", "働いてたし、"]}, {"box": [620, 118, 738, 258], "vertical": true, "font_size": 23, "lines_coords": [[[712.0, 118.0], [736.0, 118.0], [738.0, 213.0], [713.0, 213.0]], [[682.0, 121.0], [705.0, 121.0], [705.0, 258.0], [682.0, 258.0]], [[649.0, 120.0], [672.0, 120.0], [672.0, 258.0], [649.0, 258.0]], [[620.0, 120.0], [639.0, 120.0], [639.0, 217.0], [620.0, 217.0]]], "lines": ["ゆっくり", "やりたいこと", "探せばいいと", "思うけど、"]}, {"box": [444, 66, 564, 248], "vertical": true, "font_size": 25, "lines_coords": [[[534.0, 66.0], [564.0, 66.0], [564.0, 139.0], [534.0, 139.0]], [[507.0, 69.0], [530.0, 69.0], [530.0, 248.0], [507.0, 248.0]], [[474.0, 68.0], [497.0, 68.0], [497.0, 228.0], [474.0, 228.0]], [[444.0, 66.0], [467.0, 66.0], [467.0, 229.0], [444.0, 229.0]]], "lines": ["現実に", "いつまでもそりゃ", "続けらんねーよ", "なー、なんて．．．"]}, {"box": [83, 407, 136, 503], "vertical": true, "font_size": 21, "lines_coords": [[[116.0, 410.0], [136.0, 410.0], [136.0, 445.0], [116.0, 445.0]], [[83.0, 407.0], [106.0, 407.0], [106.0, 503.0], [83.0, 503.0]]], "lines": ["うー", "ごめん．．．"]}, {"box": [116, 455, 135, 500], "vertical": true, "font_size": 21, "lines_coords": [[[116.0, 455.0], [135.0, 455.0], [135.0, 500.0], [116.0, 500.0]]], "lines": ["．．．"]}, {"box": [669, 650, 758, 824], "vertical": true, "font_size": 23, "lines_coords": [[[735.0, 654.0], [758.0, 654.0], [758.0, 814.0], [735.0, 814.0]], [[704.0, 654.0], [727.0, 654.0], [727.0, 813.0], [704.0, 813.0]], [[669.0, 650.0], [694.0, 650.0], [697.0, 824.0], [672.0, 824.0]]], "lines": ["明日からあたし", "無駄な日のない", "ようにするから、"]}, {"box": [570, 792, 657, 910], "vertical": true, "font_size": 23, "lines_coords": [[[628.0, 792.0], [657.0, 792.0], [657.0, 866.0], [628.0, 866.0]], [[600.0, 794.0], [623.0, 794.0], [623.0, 910.0], [600.0, 910.0]], [[570.0, 797.0], [590.0, 797.0], [590.0, 857.0], [570.0, 857.0]]], "lines": ["だから", "泣かないで", "種田―"]}, {"box": [572, 876, 589, 906], "vertical": true, "font_size": 23, "lines_coords": [[[572.0, 876.0], [589.0, 876.0], [589.0, 906.0], [572.0, 906.0]]], "lines": ["．．．"]}, {"box": [187, 776, 283, 894], "vertical": true, "font_size": 26, "lines_coords": [[[254.0, 779.0], [277.0, 779.0], [277.0, 894.0], [254.0, 894.0]], [[221.0, 780.0], [244.0, 780.0], [244.0, 894.0], [221.0, 894.0]], [[187.0, 776.0], [218.0, 776.0], [218.0, 839.0], [187.0, 839.0]]], "lines": ["ゲロが喉に", "超染みるん", "です。"]}, {"box": [717, 1015, 859, 1231], "vertical": true, "font_size": 21, "lines_coords": [[[835.0, 1015.0], [858.0, 1015.0], [858.0, 1153.0], [835.0, 1153.0]], [[808.0, 1017.0], [827.0, 1017.0], [827.0, 1229.0], [808.0, 1229.0]], [[776.0, 1015.0], [799.0, 1015.0], [799.0, 1199.0], [776.0, 1199.0]], [[749.0, 1017.0], [768.0, 1017.0], [768.0, 1152.0], [749.0, 1152.0]], [[717.0, 1015.0], [738.0, 1015.0], [739.0, 1230.0], [719.0, 1230.0]]], "lines": ["翌日、種田は", "日記帳を買ってきた。", "あたし用の派手な", "原色のやつと", "種田用の地味なやつ。"]}, {"box": [157, 1106, 277, 1292], "vertical": true, "font_size": 23, "lines_coords": [[[252.0, 1107.0], [276.0, 1107.0], [276.0, 1245.0], [252.0, 1245.0]], [[220.0, 1107.0], [243.0, 1107.0], [243.0, 1289.0], [220.0, 1289.0]], [[188.0, 1107.0], [211.0, 1107.0], [211.0, 1263.0], [188.0, 1263.0]], [[157.0, 1106.0], [180.0, 1106.0], [180.0, 1209.0], [157.0, 1209.0]]], "lines": ["やっぱ種田は", "あたしのことよく", "わかってんなー", "と思った。"]}], "img_path": "041.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "042.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "043.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [725, 121, 847, 304], "vertical": true, "font_size": 24, "lines_coords": [[[821.0, 121.0], [846.0, 121.0], [847.0, 304.0], [823.0, 304.0]], [[791.0, 124.0], [814.0, 124.0], [814.0, 259.0], [791.0, 259.0]], [[757.0, 123.0], [780.0, 123.0], [783.0, 304.0], [760.0, 304.0]], [[725.0, 121.0], [749.0, 121.0], [751.0, 222.0], [728.0, 222.0]]], "lines": ["私達は付き合って", "もう６年目で", "同棲して１年でも", "ある訳で、"]}, {"box": [129, 232, 281, 441], "vertical": true, "font_size": 24, "lines_coords": [[[257.0, 235.0], [280.0, 235.0], [280.0, 369.0], [257.0, 369.0]], [[221.0, 232.0], [248.0, 232.0], [251.0, 403.0], [224.0, 403.0]], [[195.0, 235.0], [214.0, 235.0], [214.0, 369.0], [195.0, 369.0]], [[159.0, 232.0], [187.0, 232.0], [187.0, 441.0], [159.0, 441.0]], [[129.0, 233.0], [153.0, 233.0], [153.0, 403.0], [129.0, 403.0]]], "lines": ["朝起きた時の", "部屋の雰囲気で、", "相手の体調や", "気分くらいは容易に", "わかってしまう。"]}, {"box": [170, 605, 194, 744], "vertical": true, "font_size": 20, "lines_coords": [[[170.0, 605.0], [191.0, 605.0], [192.0, 742.0], [172.0, 742.0]]], "lines": ["．．．おはよー．．．"]}, {"box": [806, 816, 830, 931], "vertical": true, "font_size": 23, "lines_coords": [[[806.0, 818.0], [829.0, 818.0], [829.0, 931.0], [806.0, 931.0]]], "lines": ["．．．．．．種田？"]}, {"box": [297, 846, 416, 1075], "vertical": true, "font_size": 26, "lines_coords": [[[389.0, 847.0], [416.0, 847.0], [416.0, 1008.0], [389.0, 1008.0]], [[356.0, 846.0], [384.0, 846.0], [384.0, 1075.0], [356.0, 1075.0]], [[326.0, 847.0], [349.0, 847.0], [349.0, 987.0], [326.0, 987.0]]], "lines": ["たとえば、朝の", "ワイドショーで流れる", "陰惨な事件を"]}, {"box": [295, 846, 318, 1037], "vertical": true, "font_size": 25, "lines_coords": [[[295.0, 846.0], [318.0, 846.0], [318.0, 1037.0], [295.0, 1037.0]]], "lines": ["見てしまうだけで、"]}, {"box": [725, 1136, 846, 1328], "vertical": true, "font_size": 23, "lines_coords": [[[824.0, 1138.0], [843.0, 1138.0], [843.0, 1296.0], [824.0, 1296.0]], [[788.0, 1137.0], [813.0, 1137.0], [814.0, 1253.0], [790.0, 1253.0]], [[757.0, 1136.0], [782.0, 1136.0], [783.0, 1320.0], [758.0, 1320.0]], [[725.0, 1136.0], [750.0, 1136.0], [751.0, 1328.0], [727.0, 1328.0]]], "lines": ["こと、この種田", "という人は", "そこら辺とっても", "わかりやすい人で、"]}, {"box": [210, 1071, 236, 1185], "vertical": true, "font_size": 25, "lines_coords": [[[210.0, 1071.0], [235.0, 1071.0], [236.0, 1185.0], [211.0, 1185.0]]], "lines": ["地の底まで"]}, {"box": [114, 1068, 240, 1277], "vertical": true, "font_size": 26, "lines_coords": [[[176.0, 1070.0], [205.0, 1070.0], [209.0, 1276.0], [180.0, 1276.0]], [[149.0, 1070.0], [172.0, 1070.0], [172.0, 1276.0], [149.0, 1276.0]]], "lines": ["テンションが落ちる", "やっかいな感受性を"]}, {"box": [114, 1069, 142, 1242], "vertical": true, "font_size": 25, "lines_coords": [[[114.0, 1069.0], [142.0, 1069.0], [142.0, 1242.0], [114.0, 1242.0]]], "lines": ["持った人なのだ。"]}], "img_path": "044.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [818, 71, 859, 285], "vertical": true, "font_size": 38, "lines_coords": [[[818.0, 71.0], [857.0, 71.0], [859.0, 285.0], [821.0, 285.0]]], "lines": ["おはよっ！！"]}, {"box": [559, 94, 615, 209], "vertical": true, "font_size": 22, "lines_coords": [[[590.0, 94.0], [615.0, 94.0], [615.0, 209.0], [590.0, 209.0]], [[559.0, 94.0], [582.0, 94.0], [582.0, 184.0], [559.0, 184.0]]], "lines": ["．．．びっくり", "したぁー"]}, {"box": [560, 191, 581, 231], "vertical": true, "font_size": 22, "lines_coords": [[[560.0, 191.0], [581.0, 191.0], [581.0, 231.0], [560.0, 231.0]]], "lines": ["．．．"]}, {"box": [441, 175, 524, 356], "vertical": true, "font_size": 22, "lines_coords": [[[505.0, 177.0], [524.0, 177.0], [524.0, 311.0], [505.0, 311.0]], [[471.0, 177.0], [494.0, 177.0], [494.0, 356.0], [471.0, 356.0]], [[441.0, 175.0], [464.0, 175.0], [464.0, 277.0], [441.0, 277.0]]], "lines": ["おどかす時は", "一言かけてからに", "しようよ。"]}, {"box": [106, 191, 163, 328], "vertical": true, "font_size": 20, "lines_coords": [[[140.0, 192.0], [159.0, 192.0], [159.0, 328.0], [140.0, 328.0]], [[108.0, 191.0], [128.0, 191.0], [127.0, 326.0], [106.0, 326.0]]], "lines": ["それじゃ意味", "無いだろう？"]}, {"box": [626, 460, 668, 638], "vertical": true, "font_size": 38, "lines_coords": [[[628.0, 460.0], [667.0, 460.0], [664.0, 638.0], [626.0, 638.0]]], "lines": ["ぎゃあ！！"]}, {"box": [441, 400, 561, 585], "vertical": true, "font_size": 24, "lines_coords": [[[533.0, 400.0], [561.0, 400.0], [561.0, 497.0], [533.0, 497.0]], [[504.0, 401.0], [527.0, 401.0], [527.0, 563.0], [504.0, 563.0]], [[473.0, 401.0], [496.0, 401.0], [496.0, 585.0], [473.0, 585.0]], [[441.0, 400.0], [464.0, 400.0], [464.0, 541.0], [441.0, 541.0]]], "lines": ["あたしが", "働いていた時は", "忙しさにかまけて", "放ってたけど"]}, {"box": [116, 403, 300, 612], "vertical": true, "font_size": 25, "lines_coords": [[[274.0, 407.0], [298.0, 407.0], [298.0, 541.0], [274.0, 541.0]], [[241.0, 406.0], [265.0, 406.0], [265.0, 567.0], [241.0, 567.0]], [[210.0, 403.0], [235.0, 403.0], [233.0, 587.0], [209.0, 587.0]], [[179.0, 406.0], [202.0, 406.0], [202.0, 609.0], [179.0, 609.0]], [[144.0, 403.0], [173.0, 403.0], [173.0, 500.0], [144.0, 500.0]], [[116.0, 403.0], [139.0, 403.0], [139.0, 574.0], [116.0, 574.0]]], "lines": ["無職ヒマ人の", "現在のあたしは", "彼氏の沈んだ心を", "引き上げるくらいの", "甲斐性は", "あるってもんで。"]}, {"box": [771, 691, 860, 855], "vertical": true, "font_size": 26, "lines_coords": [[[836.0, 694.0], [859.0, 694.0], [859.0, 854.0], [836.0, 854.0]], [[805.0, 695.0], [828.0, 695.0], [828.0, 855.0], [805.0, 855.0]], [[771.0, 691.0], [802.0, 691.0], [802.0, 756.0], [771.0, 756.0]]], "lines": ["．．．つづきまして", "各地のレポート", "です。"]}, {"box": [82, 835, 248, 1021], "vertical": true, "font_size": 23, "lines_coords": [[[224.0, 836.0], [247.0, 836.0], [247.0, 974.0], [224.0, 974.0]], [[194.0, 838.0], [217.0, 838.0], [217.0, 996.0], [194.0, 996.0]], [[168.0, 838.0], [188.0, 838.0], [187.0, 1018.0], [166.0, 1018.0]], [[136.0, 835.0], [164.0, 835.0], [164.0, 1021.0], [136.0, 1021.0]], [[109.0, 836.0], [132.0, 836.0], [132.0, 996.0], [109.0, 996.0]], [[83.0, 836.0], [103.0, 836.0], [102.0, 995.0], [82.0, 995.0]]], "lines": ["本日、Ｔ市の", "○○動物園では", "ホッキョクグマが", "逃げ出した場合を", "想定した訓練が", "おこなわれ．．．"]}, {"box": [287, 1096, 371, 1242], "vertical": true, "font_size": 23, "lines_coords": [[[348.0, 1097.0], [371.0, 1097.0], [371.0, 1218.0], [348.0, 1218.0]], [[315.0, 1096.0], [340.0, 1096.0], [337.0, 1223.0], [313.0, 1223.0]], [[287.0, 1097.0], [306.0, 1097.0], [306.0, 1242.0], [287.0, 1242.0]]], "lines": ["あっはっは、", "全然訓練に", "なってないし。"]}, {"box": [157, 1153, 243, 1350], "vertical": true, "font_size": 23, "lines_coords": [[[216.0, 1153.0], [243.0, 1153.0], [243.0, 1316.0], [216.0, 1316.0]], [[185.0, 1153.0], [209.0, 1153.0], [209.0, 1350.0], [185.0, 1350.0]], [[157.0, 1155.0], [176.0, 1155.0], [176.0, 1293.0], [157.0, 1293.0]]], "lines": ["みんなニコニコ", "しながらやってん", "じゃんねぇ？"]}], "img_path": "045.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [818, 102, 842, 203], "vertical": true, "font_size": 24, "lines_coords": [[[818.0, 102.0], [842.0, 102.0], [842.0, 203.0], [818.0, 203.0]]], "lines": ["．．．そうだ。"]}, {"box": [679, 150, 788, 317], "vertical": true, "font_size": 24, "lines_coords": [[[764.0, 150.0], [788.0, 150.0], [786.0, 317.0], [761.0, 317.0]], [[734.0, 150.0], [761.0, 150.0], [761.0, 298.0], [734.0, 298.0]], [[705.0, 153.0], [728.0, 153.0], [728.0, 267.0], [705.0, 267.0]], [[679.0, 153.0], [698.0, 153.0], [698.0, 288.0], [679.0, 288.0]]], "lines": ["種田、休みだし、", "天気もいいし、", "動物園とか", "行っちゃう？"]}, {"box": [497, 110, 555, 183], "vertical": true, "font_size": 24, "lines_coords": [[[522.0, 112.0], [552.0, 110.0], [555.0, 181.0], [524.0, 183.0]], [[497.0, 113.0], [518.0, 113.0], [518.0, 179.0], [497.0, 179.0]]], "lines": ["動物園", "かぁー"]}, {"box": [499, 181, 518, 225], "vertical": true, "font_size": 24, "lines_coords": [[[499.0, 181.0], [518.0, 181.0], [518.0, 225.0], [499.0, 225.0]]], "lines": ["．．．"]}, {"box": [86, 149, 174, 345], "vertical": true, "font_size": 25, "lines_coords": [[[147.0, 151.0], [174.0, 151.0], [172.0, 313.0], [144.0, 313.0]], [[116.0, 149.0], [143.0, 149.0], [143.0, 345.0], [116.0, 345.0]], [[86.0, 150.0], [106.0, 150.0], [108.0, 277.0], [87.0, 277.0]]], "lines": ["いったい、もう", "何年行ってないん", "だろうなぁ。"]}, {"box": [645, 497, 669, 590], "vertical": true, "font_size": 20, "lines_coords": [[[645.0, 497.0], [669.0, 497.0], [669.0, 590.0], [645.0, 590.0]]], "lines": ["動物園ー"]}, {"box": [617, 553, 634, 585], "vertical": true, "font_size": 20, "lines_coords": [[[617.0, 553.0], [634.0, 553.0], [634.0, 585.0], [617.0, 585.0]]], "lines": ["！？"]}, {"box": [464, 514, 492, 650], "vertical": true, "font_size": 25, "lines_coords": [[[467.0, 514.0], [492.0, 514.0], [489.0, 650.0], [464.0, 650.0]]], "lines": ["ＲＲＡＲＲ"]}, {"box": [159, 380, 215, 541], "vertical": true, "font_size": 23, "lines_coords": [[[191.0, 381.0], [214.0, 381.0], [214.0, 519.0], [191.0, 519.0]], [[159.0, 380.0], [183.0, 380.0], [184.0, 541.0], [161.0, 541.0]]], "lines": ["よし、じゃあ", "決まりでしょ！"]}, {"box": [354, 711, 374, 845], "vertical": true, "font_size": 20, "lines_coords": [[[354.0, 711.0], [374.0, 711.0], [374.0, 845.0], [354.0, 845.0]]], "lines": ["ＲＲＰＲＲ"]}, {"box": [348, 710, 375, 844], "vertical": true, "font_size": 24, "lines_coords": [[[351.0, 710.0], [375.0, 710.0], [373.0, 844.0], [348.0, 844.0]]], "lines": ["ＲＲＲＡＲ"]}, {"box": [300, 884, 322, 1019], "vertical": true, "font_size": 22, "lines_coords": [[[300.0, 884.0], [322.0, 884.0], [322.0, 1019.0], [300.0, 1019.0]]], "lines": ["ＲＡＲＲＲ"]}, {"box": [299, 887, 322, 1021], "vertical": true, "font_size": 24, "lines_coords": [[[299.0, 887.0], [322.0, 887.0], [322.0, 1021.0], [299.0, 1021.0]]], "lines": ["ＲＲＲＰＲ"]}, {"box": [420, 1220, 539, 1289], "vertical": false, "font_size": 69, "lines_coords": [[[420.0, 1220.0], [539.0, 1220.0], [539.0, 1289.0], [420.0, 1289.0]]], "lines": ["．．．"]}, {"box": [109, 1215, 130, 1352], "vertical": true, "font_size": 19, "lines_coords": [[[109.0, 1216.0], [128.0, 1216.0], [128.0, 1352.0], [109.0, 1352.0]]], "lines": ["．．．もしもし？"]}], "img_path": "046.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [375, 328, 497, 351], "vertical": false, "font_size": 19, "lines_coords": [[[375.0, 332.0], [497.0, 328.0], [497.0, 347.0], [375.0, 351.0]]], "lines": ["ヤーサイド商店街"]}, {"box": [257, 329, 283, 449], "vertical": true, "font_size": 25, "lines_coords": [[[257.0, 329.0], [281.0, 329.0], [283.0, 449.0], [258.0, 449.0]]], "lines": ["．．．久しぶり、"]}, {"box": [232, 529, 257, 645], "vertical": true, "font_size": 25, "lines_coords": [[[232.0, 529.0], [257.0, 529.0], [257.0, 645.0], [232.0, 645.0]]], "lines": ["お母さん。"]}, {"box": [795, 821, 905, 1007], "vertical": true, "font_size": 22, "lines_coords": [[[881.0, 824.0], [905.0, 824.0], [905.0, 984.0], [881.0, 984.0]], [[853.0, 823.0], [876.0, 823.0], [876.0, 1007.0], [853.0, 1007.0]], [[824.0, 824.0], [847.0, 824.0], [847.0, 985.0], [824.0, 985.0]], [[795.0, 821.0], [818.0, 821.0], [818.0, 916.0], [795.0, 916.0]]], "lines": ["社会人になって", "どんな騒々しい所", "住んでるのかと", "思えば．．．"]}, {"box": [702, 909, 787, 1070], "vertical": true, "font_size": 22, "lines_coords": [[[768.0, 910.0], [787.0, 910.0], [787.0, 1024.0], [768.0, 1024.0]], [[734.0, 909.0], [757.0, 909.0], [757.0, 1070.0], [734.0, 1070.0]], [[702.0, 909.0], [721.0, 909.0], [721.0, 1055.0], [702.0, 1055.0]]], "lines": ["東京も都心", "離れれば秋田と", "変わらないわ。"]}, {"box": [529, 872, 609, 1056], "vertical": true, "font_size": 22, "lines_coords": [[[586.0, 873.0], [609.0, 873.0], [609.0, 1056.0], [586.0, 1056.0]], [[557.0, 873.0], [581.0, 873.0], [581.0, 989.0], [557.0, 989.0]], [[529.0, 872.0], [552.0, 872.0], [552.0, 1017.0], [529.0, 1017.0]]], "lines": ["．．．ていうかなんで", "来る直前に", "電話するかな。"]}, {"box": [90, 916, 206, 1080], "vertical": true, "font_size": 22, "lines_coords": [[[183.0, 918.0], [206.0, 918.0], [206.0, 1080.0], [183.0, 1080.0]], [[151.0, 918.0], [174.0, 918.0], [174.0, 1044.0], [151.0, 1044.0]], [[118.0, 916.0], [142.0, 916.0], [142.0, 1010.0], [118.0, 1010.0]], [[90.0, 920.0], [109.0, 920.0], [109.0, 1066.0], [90.0, 1066.0]]], "lines": ["都会のホテルは", "豪華過ぎて、", "あたしに", "合わなくてね。"]}, {"box": [407, 985, 514, 1125], "vertical": true, "font_size": 22, "lines_coords": [[[493.0, 987.0], [514.0, 987.0], [512.0, 1122.0], [492.0, 1122.0]], [[463.0, 985.0], [486.0, 985.0], [486.0, 1125.0], [463.0, 1125.0]], [[434.0, 985.0], [458.0, 985.0], [458.0, 1125.0], [434.0, 1125.0]], [[407.0, 987.0], [430.0, 987.0], [430.0, 1077.0], [407.0, 1077.0]]], "lines": ["同窓会なんて", "ずっと前から", "決まってたん", "てしょー"]}, {"box": [411, 1078, 426, 1121], "vertical": true, "font_size": 22, "lines_coords": [[[411.0, 1078.0], [426.0, 1078.0], [426.0, 1121.0], [411.0, 1121.0]]], "lines": ["ー？"]}, {"box": [214, 1088, 299, 1230], "vertical": true, "font_size": 22, "lines_coords": [[[280.0, 1091.0], [299.0, 1091.0], [299.0, 1230.0], [280.0, 1230.0]], [[246.0, 1089.0], [269.0, 1089.0], [269.0, 1205.0], [246.0, 1205.0]], [[214.0, 1088.0], [237.0, 1088.0], [237.0, 1225.0], [214.0, 1225.0]]], "lines": ["それにあんた、", "会社は土日", "休みでしょ？"]}, {"box": [103, 1204, 191, 1354], "vertical": true, "font_size": 24, "lines_coords": [[[162.0, 1204.0], [191.0, 1204.0], [191.0, 1287.0], [162.0, 1287.0]], [[133.0, 1205.0], [157.0, 1205.0], [157.0, 1354.0], [133.0, 1354.0]], [[103.0, 1205.0], [123.0, 1205.0], [123.0, 1298.0], [103.0, 1298.0]]], "lines": ["．．．．．．あ、", "まぁそうなん", "だけど．．．"]}], "img_path": "047.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [702, 80, 790, 284], "vertical": true, "font_size": 22, "lines_coords": [[[768.0, 82.0], [787.0, 82.0], [787.0, 217.0], [768.0, 217.0]], [[734.0, 82.0], [757.0, 82.0], [757.0, 241.0], [734.0, 241.0]], [[702.0, 80.0], [725.0, 80.0], [725.0, 284.0], [702.0, 284.0]]], "lines": ["．．．お母さんて", "コーヒーに砂糖", "入れない派だっけ？"]}, {"box": [494, 125, 585, 289], "vertical": true, "font_size": 26, "lines_coords": [[[560.0, 127.0], [585.0, 127.0], [585.0, 205.0], [560.0, 205.0]], [[526.0, 125.0], [553.0, 125.0], [553.0, 289.0], [526.0, 289.0]], [[494.0, 125.0], [519.0, 125.0], [520.0, 229.0], [496.0, 229.0]]], "lines": ["そうよ、", "それでミルクは", "多めでね。"]}, {"box": [142, 92, 210, 231], "vertical": true, "font_size": 27, "lines_coords": [[[176.0, 92.0], [210.0, 92.0], [210.0, 206.0], [176.0, 206.0]], [[142.0, 94.0], [170.0, 94.0], [170.0, 231.0], [142.0, 231.0]]], "lines": ["．．．．．って", "ギャー！！"]}, {"box": [75, 263, 176, 429], "vertical": true, "font_size": 27, "lines_coords": [[[153.0, 265.0], [176.0, 265.0], [176.0, 381.0], [153.0, 381.0]], [[112.0, 265.0], [139.0, 265.0], [139.0, 429.0], [112.0, 429.0]], [[75.0, 263.0], [99.0, 263.0], [99.0, 374.0], [75.0, 374.0]]], "lines": ["人の目記", "勝手に読むか", "フツー！？"]}, {"box": [438, 411, 535, 600], "vertical": true, "font_size": 24, "lines_coords": [[[503.0, 414.0], [527.0, 414.0], [527.0, 533.0], [503.0, 533.0]], [[471.0, 412.0], [494.0, 412.0], [494.0, 530.0], [471.0, 530.0]], [[438.0, 411.0], [462.0, 411.0], [462.0, 598.0], [438.0, 598.0]]], "lines": ["大袈裟だね、", "三日坊主で", "終わってるじゃない。"]}, {"box": [751, 694, 858, 852], "vertical": true, "font_size": 19, "lines_coords": [[[836.0, 695.0], [855.0, 695.0], [855.0, 851.0], [836.0, 851.0]], [[809.0, 694.0], [828.0, 694.0], [828.0, 829.0], [809.0, 829.0]], [[780.0, 695.0], [799.0, 695.0], [799.0, 851.0], [780.0, 851.0]], [[753.0, 694.0], [772.0, 694.0], [772.0, 851.0], [753.0, 851.0]]], "lines": ["あんたは昔から", "出来ないって", "わかってるのに", "無駄遣いして．．．"]}, {"box": [833, 995, 868, 1075], "vertical": true, "font_size": 25, "lines_coords": [[[833.0, 995.0], [868.0, 995.0], [868.0, 1075.0], [833.0, 1075.0]]], "lines": ["．．．で、"]}, {"box": [377, 792, 465, 932], "vertical": true, "font_size": 23, "lines_coords": [[[441.0, 794.0], [464.0, 794.0], [464.0, 931.0], [441.0, 931.0]], [[410.0, 794.0], [433.0, 794.0], [433.0, 932.0], [410.0, 932.0]], [[377.0, 792.0], [401.0, 792.0], [401.0, 918.0], [377.0, 918.0]]], "lines": ["それは彼氏が", "買ってきたん", "だもーーん。"]}, {"box": [110, 712, 167, 881], "vertical": true, "font_size": 23, "lines_coords": [[[143.0, 713.0], [166.0, 713.0], [166.0, 881.0], [143.0, 881.0]], [[110.0, 712.0], [133.0, 712.0], [133.0, 858.0], [110.0, 858.0]]], "lines": ["べつにいいわよ。", "隠さなくても。"]}, {"box": [760, 1164, 877, 1324], "vertical": true, "font_size": 25, "lines_coords": [[[853.0, 1166.0], [877.0, 1166.0], [877.0, 1241.0], [853.0, 1241.0]], [[823.0, 1164.0], [846.0, 1164.0], [846.0, 1282.0], [823.0, 1282.0]], [[790.0, 1166.0], [813.0, 1166.0], [813.0, 1324.0], [790.0, 1324.0]], [[760.0, 1166.0], [779.0, 1166.0], [779.0, 1256.0], [760.0, 1256.0]]], "lines": ["あんた、", "その彼氏と", "２人で暮らして", "るんだ？"]}, {"box": [374, 1170, 433, 1311], "vertical": true, "font_size": 26, "lines_coords": [[[403.0, 1170.0], [433.0, 1170.0], [433.0, 1253.0], [403.0, 1253.0]], [[374.0, 1173.0], [397.0, 1173.0], [397.0, 1311.0], [374.0, 1311.0]]], "lines": ["．．．し、", "してないよ？"]}, {"box": [79, 1167, 197, 1361], "vertical": true, "font_size": 22, "lines_coords": [[[176.0, 1168.0], [195.0, 1168.0], [195.0, 1326.0], [176.0, 1326.0]], [[143.0, 1167.0], [166.0, 1167.0], [166.0, 1290.0], [143.0, 1290.0]], [[110.0, 1168.0], [133.0, 1168.0], [133.0, 1307.0], [110.0, 1307.0]], [[79.0, 1168.0], [102.0, 1168.0], [102.0, 1356.0], [79.0, 1356.0]]], "lines": ["もうそれなりの", "年なんだし、", "自分で稼いで", "やってるんだから。"]}], "img_path": "048.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [777, 162, 801, 281], "vertical": true, "font_size": 24, "lines_coords": [[[777.0, 162.0], [801.0, 162.0], [801.0, 281.0], [777.0, 281.0]]], "lines": ["．．．お母さん、"]}, {"box": [697, 277, 721, 370], "vertical": true, "font_size": 24, "lines_coords": [[[697.0, 277.0], [721.0, 277.0], [721.0, 370.0], [697.0, 370.0]]], "lines": ["実は．．．"]}, {"box": [780, 619, 838, 734], "vertical": true, "font_size": 26, "lines_coords": [[[809.0, 619.0], [838.0, 619.0], [838.0, 693.0], [809.0, 693.0]], [[780.0, 620.0], [803.0, 620.0], [803.0, 734.0], [780.0, 734.0]]], "lines": ["事情は", "わかった！！"]}, {"box": [140, 287, 231, 448], "vertical": true, "font_size": 24, "lines_coords": [[[205.0, 288.0], [228.0, 288.0], [228.0, 438.0], [205.0, 438.0]], [[177.0, 289.0], [196.0, 289.0], [196.0, 448.0], [177.0, 448.0]], [[140.0, 287.0], [169.0, 287.0], [169.0, 359.0], [140.0, 359.0]]], "lines": ["あたしもっと", "重大な隠しごと", "が．．．"]}, {"box": [799, 872, 887, 1040], "vertical": true, "font_size": 24, "lines_coords": [[[861.0, 873.0], [885.0, 873.0], [887.0, 1024.0], [862.0, 1024.0]], [[829.0, 872.0], [857.0, 872.0], [857.0, 1040.0], [829.0, 1040.0]], [[799.0, 873.0], [824.0, 873.0], [824.0, 989.0], [799.0, 989.0]]], "lines": ["しかしなんで", "動物園で男２人、", "酒飲んで。"]}, {"box": [708, 965, 761, 1081], "vertical": true, "font_size": 24, "lines_coords": [[[738.0, 965.0], [761.0, 965.0], [761.0, 1078.0], [738.0, 1078.0]], [[708.0, 965.0], [727.0, 965.0], [727.0, 1081.0], [708.0, 1081.0]]], "lines": ["ついてくる", "俺も俺だが"]}, {"box": [438, 916, 470, 1019], "vertical": true, "font_size": 24, "lines_coords": [[[438.0, 916.0], [467.0, 916.0], [470.0, 1019.0], [441.0, 1019.0]]], "lines": ["だってさ、"]}, {"box": [114, 646, 250, 861], "vertical": true, "font_size": 24, "lines_coords": [[[222.0, 646.0], [250.0, 646.0], [250.0, 808.0], [222.0, 808.0]], [[198.0, 648.0], [221.0, 648.0], [218.0, 809.0], [195.0, 809.0]], [[170.0, 648.0], [194.0, 648.0], [194.0, 861.0], [170.0, 861.0]], [[143.0, 648.0], [166.0, 648.0], [166.0, 797.0], [143.0, 797.0]], [[116.0, 648.0], [139.0, 648.0], [138.0, 808.0], [114.0, 808.0]]], "lines": ["芽衣子ちゃんの", "母親が突然来て", "デートはキャンセル、", "今晩宿無しの", "２連コンボと！！"]}, {"box": [267, 952, 388, 1114], "vertical": true, "font_size": 24, "lines_coords": [[[365.0, 954.0], [388.0, 954.0], [388.0, 1092.0], [365.0, 1092.0]], [[332.0, 955.0], [355.0, 955.0], [355.0, 1114.0], [332.0, 1114.0]], [[300.0, 954.0], [324.0, 954.0], [324.0, 1114.0], [300.0, 1114.0]], [[270.0, 952.0], [293.0, 952.0], [291.0, 1100.0], [267.0, 1100.0]]], "lines": ["行けないって", "わかると無性に", "行きたくなって", "しまうもので。"]}, {"box": [102, 1194, 158, 1320], "vertical": true, "font_size": 24, "lines_coords": [[[133.0, 1196.0], [157.0, 1196.0], [157.0, 1320.0], [133.0, 1320.0]], [[102.0, 1194.0], [125.0, 1194.0], [125.0, 1296.0], [102.0, 1296.0]]], "lines": ["なんだその", "俺様理論。"]}], "img_path": "049.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [799, 112, 892, 251], "vertical": true, "font_size": 26, "lines_coords": [[[857.0, 112.0], [892.0, 112.0], [892.0, 195.0], [857.0, 195.0]], [[829.0, 114.0], [854.0, 114.0], [854.0, 207.0], [829.0, 207.0]], [[801.0, 116.0], [820.0, 116.0], [820.0, 250.0], [801.0, 250.0]]], "lines": ["．．．で、", "ビリーは", "今日も仕事？"]}, {"box": [618, 53, 736, 161], "vertical": true, "font_size": 73, "lines_coords": [[[650.0, 77.0], [723.0, 65.0], [736.0, 149.0], [664.0, 161.0]]], "lines": ["山田仕事中"]}, {"box": [98, 87, 186, 248], "vertical": true, "font_size": 23, "lines_coords": [[[161.0, 87.0], [184.0, 87.0], [181.0, 232.0], [158.0, 232.0]], [[129.0, 90.0], [153.0, 90.0], [153.0, 214.0], [129.0, 214.0]], [[98.0, 91.0], [121.0, 91.0], [121.0, 248.0], [98.0, 248.0]]], "lines": ["ところで加藤", "お前今朝の", "ニュース見た？"]}, {"box": [558, 348, 613, 509], "vertical": true, "font_size": 23, "lines_coords": [[[586.0, 348.0], [613.0, 348.0], [613.0, 509.0], [586.0, 509.0]], [[559.0, 350.0], [578.0, 350.0], [578.0, 493.0], [559.0, 493.0]]], "lines": ["いや、あいつは", "風になったよ。"]}, {"box": [374, 374, 433, 500], "vertical": true, "font_size": 24, "lines_coords": [[[406.0, 374.0], [430.0, 374.0], [433.0, 477.0], [408.0, 477.0]], [[374.0, 375.0], [397.0, 375.0], [400.0, 500.0], [377.0, 500.0]]], "lines": ["見てねぇ、", "何かあった。"]}, {"box": [73, 400, 211, 634], "vertical": true, "font_size": 25, "lines_coords": [[[187.0, 403.0], [210.0, 403.0], [210.0, 576.0], [187.0, 576.0]], [[157.0, 403.0], [184.0, 403.0], [184.0, 570.0], [157.0, 570.0]], [[132.0, 403.0], [155.0, 403.0], [155.0, 634.0], [132.0, 634.0]], [[102.0, 403.0], [125.0, 403.0], [125.0, 586.0], [102.0, 586.0]], [[75.0, 400.0], [102.0, 400.0], [101.0, 617.0], [73.0, 617.0]]], "lines": ["まぁいつも通り", "株価が上下して", "どっかで殺人があって", "旬の魚がおいしい", "ですね、なんだけど、"]}, {"box": [721, 686, 840, 895], "vertical": true, "font_size": 25, "lines_coords": [[[816.0, 689.0], [839.0, 689.0], [839.0, 870.0], [816.0, 870.0]], [[783.0, 687.0], [810.0, 687.0], [810.0, 895.0], [783.0, 895.0]], [[750.0, 686.0], [777.0, 686.0], [775.0, 881.0], [747.0, 881.0]], [[721.0, 689.0], [745.0, 689.0], [745.0, 838.0], [721.0, 838.0]]], "lines": ["やっぱ世の中って", "紙一重のバランスで", "成り立ってんのな、", "って思ってさ。"]}, {"box": [628, 704, 657, 788], "vertical": true, "font_size": 29, "lines_coords": [[[628.0, 704.0], [657.0, 704.0], [657.0, 788.0], [628.0, 788.0]]], "lines": ["はぁ？"]}, {"box": [169, 693, 285, 898], "vertical": true, "font_size": 25, "lines_coords": [[[262.0, 693.0], [285.0, 693.0], [285.0, 792.0], [262.0, 792.0]], [[231.0, 693.0], [254.0, 693.0], [254.0, 898.0], [231.0, 898.0]], [[199.0, 693.0], [222.0, 693.0], [222.0, 853.0], [199.0, 853.0]], [[169.0, 694.0], [188.0, 694.0], [188.0, 814.0], [169.0, 814.0]]], "lines": ["そんな中、", "だらりとフリーター", "やってる俺って", "なんだろう。"]}, {"box": [136, 891, 198, 980], "vertical": true, "font_size": 25, "lines_coords": [[[166.0, 891.0], [198.0, 891.0], [198.0, 948.0], [166.0, 948.0]], [[136.0, 895.0], [165.0, 895.0], [165.0, 980.0], [136.0, 980.0]]], "lines": ["とか", "思って。"]}, {"box": [746, 1101, 836, 1294], "vertical": true, "font_size": 25, "lines_coords": [[[808.0, 1101.0], [836.0, 1101.0], [836.0, 1183.0], [808.0, 1183.0]], [[776.0, 1104.0], [799.0, 1104.0], [799.0, 1287.0], [776.0, 1287.0]], [[746.0, 1104.0], [769.0, 1104.0], [769.0, 1293.0], [746.0, 1293.0]]], "lines": ["俺は今、", "のんびり動物見て", "癒やされ中だけど、"]}, {"box": [187, 1089, 311, 1297], "vertical": true, "font_size": 25, "lines_coords": [[[288.0, 1092.0], [311.0, 1092.0], [311.0, 1230.0], [288.0, 1230.0]], [[258.0, 1093.0], [277.0, 1093.0], [277.0, 1297.0], [258.0, 1297.0]], [[224.0, 1092.0], [247.0, 1092.0], [247.0, 1231.0], [224.0, 1231.0]], [[187.0, 1089.0], [221.0, 1089.0], [221.0, 1174.0], [187.0, 1174.0]]], "lines": ["実はココって", "世界中の動物がいる", "かなり異常な", "環境で、"]}, {"box": [84, 1199, 172, 1349], "vertical": true, "font_size": 25, "lines_coords": [[[147.0, 1199.0], [172.0, 1199.0], [172.0, 1294.0], [147.0, 1294.0]], [[114.0, 1199.0], [138.0, 1199.0], [138.0, 1349.0], [114.0, 1349.0]], [[84.0, 1199.0], [108.0, 1199.0], [108.0, 1338.0], [84.0, 1338.0]]], "lines": ["その中に", "俺らはいたり", "してさーー！！"]}], "img_path": "050.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [720, 123, 809, 291], "vertical": true, "font_size": 23, "lines_coords": [[[786.0, 125.0], [809.0, 125.0], [809.0, 217.0], [786.0, 217.0]], [[756.0, 124.0], [779.0, 124.0], [776.0, 262.0], [753.0, 262.0]], [[720.0, 123.0], [743.0, 123.0], [745.0, 291.0], [721.0, 291.0]]], "lines": ["ひいては", "虚構と異常に", "溢れた世の中と、"]}, {"box": [211, 165, 298, 289], "vertical": true, "font_size": 24, "lines_coords": [[[269.0, 165.0], [298.0, 165.0], [298.0, 259.0], [269.0, 259.0]], [[243.0, 165.0], [262.0, 165.0], [262.0, 278.0], [243.0, 278.0]], [[211.0, 165.0], [231.0, 165.0], [231.0, 289.0], [211.0, 289.0]]], "lines": ["ハイハイ", "もういいよ", "そうゆうの。"]}, {"box": [661, 326, 749, 488], "vertical": true, "font_size": 23, "lines_coords": [[[730.0, 328.0], [749.0, 328.0], [749.0, 488.0], [730.0, 488.0]], [[695.0, 328.0], [719.0, 328.0], [719.0, 467.0], [695.0, 467.0]], [[664.0, 326.0], [689.0, 326.0], [686.0, 444.0], [661.0, 444.0]]], "lines": ["それに順応して", "むしろ退屈な", "俺達って！？"]}, {"box": [161, 347, 251, 488], "vertical": true, "font_size": 24, "lines_coords": [[[222.0, 347.0], [251.0, 347.0], [248.0, 478.0], [220.0, 478.0]], [[192.0, 348.0], [216.0, 348.0], [216.0, 466.0], [192.0, 466.0]], [[161.0, 348.0], [184.0, 348.0], [184.0, 488.0], [161.0, 488.0]]], "lines": ["お前未だに", "そんなこと", "考えてんの？"]}, {"box": [788, 622, 842, 794], "vertical": true, "font_size": 24, "lines_coords": [[[818.0, 622.0], [842.0, 622.0], [842.0, 784.0], [818.0, 784.0]], [[788.0, 626.0], [808.0, 626.0], [808.0, 794.0], [788.0, 794.0]]], "lines": ["まーーアレだ。", "溜まってんだよ。"]}, {"box": [646, 687, 753, 1000], "vertical": true, "font_size": 24, "lines_coords": [[[724.0, 687.0], [753.0, 687.0], [753.0, 851.0], [724.0, 851.0]], [[698.0, 690.0], [721.0, 690.0], [721.0, 829.0], [698.0, 829.0]], [[667.0, 687.0], [694.0, 687.0], [698.0, 1000.0], [671.0, 1000.0]], [[646.0, 693.0], [665.0, 693.0], [665.0, 849.0], [646.0, 849.0]]], "lines": ["種田、そろそろ", "真剣にバンド", "再開したほうが．．．によっ！？", "いいんじゃねー"]}, {"box": [136, 928, 244, 1119], "vertical": true, "font_size": 23, "lines_coords": [[[221.0, 928.0], [244.0, 928.0], [244.0, 1119.0], [221.0, 1119.0]], [[192.0, 928.0], [216.0, 928.0], [216.0, 1044.0], [192.0, 1044.0]], [[164.0, 928.0], [187.0, 928.0], [187.0, 1089.0], [164.0, 1089.0]], [[136.0, 928.0], [159.0, 928.0], [159.0, 1029.0], [136.0, 1029.0]]], "lines": ["じゃあナニですか？", "俺が本気で", "音楽やるよって", "言ったら、"]}, {"box": [345, 1225, 391, 1245], "vertical": false, "font_size": 20, "lines_coords": [[[345.0, 1225.0], [391.0, 1225.0], [391.0, 1245.0], [345.0, 1245.0]]], "lines": ["カバ"]}, {"box": [329, 1261, 490, 1378], "vertical": false, "font_size": 17.333333333333332, "lines_coords": [[[343.0, 1261.0], [489.0, 1279.0], [486.0, 1302.0], [340.0, 1285.0]], [[339.0, 1289.0], [410.0, 1300.0], [407.0, 1320.0], [336.0, 1309.0]], [[339.0, 1307.0], [392.0, 1312.0], [391.0, 1327.0], [337.0, 1322.0]], [[337.0, 1319.0], [407.0, 1326.0], [406.0, 1341.0], [336.0, 1334.0]], [[330.0, 1342.0], [490.0, 1363.0], [489.0, 1378.0], [329.0, 1357.0]], [[333.0, 1356.0], [377.0, 1360.0], [375.0, 1375.0], [332.0, 1371.0]]], "lines": ["．．．キャンセルでいたとき「ワクワクするわけではなく、スカットになりません」", "・分布アフリカ・体長？", "．．．体長３．５．", "．．．食べ物主に草ほとんどの時間", "ほとんどの時間を永中ですとすたの服、鼻、耳は水面に出るように並んでいます", "でいます。"]}, {"box": [330, 1330, 489, 1364], "vertical": false, "font_size": 14, "lines_coords": [[[332.0, 1330.0], [489.0, 1350.0], [488.0, 1364.0], [330.0, 1343.0]]], "lines": ["一度、前半に早ほとんどの時間を大中ですごすため、"]}, {"box": [88, 1160, 239, 1323], "vertical": true, "font_size": 23, "lines_coords": [[[214.0, 1162.0], [239.0, 1162.0], [236.0, 1276.0], [211.0, 1276.0]], [[180.0, 1163.0], [205.0, 1163.0], [205.0, 1256.0], [180.0, 1256.0]], [[150.0, 1160.0], [173.0, 1160.0], [173.0, 1323.0], [150.0, 1323.0]], [[118.0, 1162.0], [142.0, 1162.0], [142.0, 1323.0], [118.0, 1323.0]], [[88.0, 1162.0], [108.0, 1162.0], [108.0, 1276.0], [88.0, 1276.0]]], "lines": ["大学６年の", "加藤君は", "すべてを捨てて", "俺についてきて", "くれんの？"]}], "img_path": "051.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [771, 65, 891, 272], "vertical": true, "font_size": 24, "lines_coords": [[[864.0, 66.0], [891.0, 66.0], [891.0, 252.0], [864.0, 252.0]], [[832.0, 65.0], [859.0, 65.0], [859.0, 262.0], [832.0, 262.0]], [[802.0, 66.0], [825.0, 66.0], [825.0, 205.0], [802.0, 205.0]], [[772.0, 65.0], [792.0, 65.0], [791.0, 272.0], [771.0, 272.0]]], "lines": ["つーか、お前こそ", "世の中、曇う以前に", "現実的な問題", "盛りだくさんだろ！？"]}, {"box": [633, 108, 717, 274], "vertical": true, "font_size": 24, "lines_coords": [[[694.0, 108.0], [717.0, 108.0], [717.0, 274.0], [694.0, 274.0]], [[664.0, 108.0], [687.0, 108.0], [687.0, 246.0], [664.0, 246.0]], [[633.0, 108.0], [656.0, 108.0], [656.0, 246.0], [633.0, 246.0]]], "lines": ["お前ヒモじゃん、", "なのに彼女は", "無職じゃん！！"]}, {"box": [92, 46, 214, 65], "vertical": false, "font_size": 19, "lines_coords": [[[92.0, 46.0], [214.0, 46.0], [214.0, 65.0], [92.0, 65.0]]], "lines": ["ソラニン［"]}, {"box": [579, 501, 605, 625], "vertical": true, "font_size": 23, "lines_coords": [[[579.0, 501.0], [602.0, 501.0], [605.0, 624.0], [582.0, 624.0]]], "lines": ["ふほははは。"]}, {"box": [441, 382, 465, 507], "vertical": true, "font_size": 23, "lines_coords": [[[441.0, 382.0], [464.0, 382.0], [464.0, 507.0], [441.0, 507.0]]], "lines": ["仲良しです。"]}, {"box": [746, 736, 812, 832], "vertical": true, "font_size": 28, "lines_coords": [[[776.0, 736.0], [812.0, 736.0], [812.0, 812.0], [776.0, 812.0]], [[749.0, 736.0], [777.0, 736.0], [775.0, 832.0], [746.0, 832.0]]], "lines": ["やばい", "やばい！！"]}, {"box": [646, 803, 736, 947], "vertical": true, "font_size": 28, "lines_coords": [[[701.0, 803.0], [736.0, 805.0], [734.0, 870.0], [698.0, 869.0]], [[678.0, 812.0], [697.0, 812.0], [697.0, 947.0], [678.0, 947.0]], [[646.0, 812.0], [665.0, 812.0], [665.0, 902.0], [646.0, 902.0]]], "lines": ["加藤、", "場をなごませ", "るんだ！！"]}, {"box": [458, 806, 577, 944], "vertical": true, "font_size": 24, "lines_coords": [[[553.0, 809.0], [576.0, 809.0], [576.0, 940.0], [553.0, 940.0]], [[520.0, 806.0], [544.0, 806.0], [544.0, 900.0], [520.0, 900.0]], [[488.0, 808.0], [512.0, 808.0], [512.0, 925.0], [488.0, 925.0]], [[458.0, 808.0], [481.0, 808.0], [481.0, 944.0], [458.0, 944.0]]], "lines": ["えっ、えーと、", "じゃあ僕", "カバのマネ", "やりまーす！！"]}, {"box": [222, 1096, 252, 1193], "vertical": true, "font_size": 36, "lines_coords": [[[222.0, 1096.0], [252.0, 1096.0], [252.0, 1193.0], [222.0, 1193.0]]], "lines": ["えっ！？"]}, {"box": [138, 1201, 224, 1337], "vertical": true, "font_size": 36, "lines_coords": [[[177.0, 1201.0], [224.0, 1201.0], [224.0, 1279.0], [177.0, 1279.0]], [[138.0, 1204.0], [170.0, 1204.0], [173.0, 1337.0], [140.0, 1337.0]]], "lines": ["会社", "辞めた！？"]}], "img_path": "052.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [851, 127, 885, 210], "vertical": true, "font_size": 34, "lines_coords": [[[851.0, 127.0], [885.0, 127.0], [885.0, 210.0], [851.0, 210.0]]], "lines": ["．．．です。"]}, {"box": [474, 118, 594, 303], "vertical": true, "font_size": 22, "lines_coords": [[[570.0, 118.0], [593.0, 118.0], [593.0, 269.0], [570.0, 269.0]], [[540.0, 121.0], [559.0, 121.0], [559.0, 257.0], [540.0, 257.0]], [[505.0, 120.0], [529.0, 120.0], [529.0, 303.0], [505.0, 303.0]], [[474.0, 121.0], [497.0, 121.0], [497.0, 278.0], [474.0, 278.0]]], "lines": ["なんでそんな", "大事なこと！！", "相談してくれても", "いいじゃない！！"]}, {"box": [109, 172, 198, 334], "vertical": true, "font_size": 25, "lines_coords": [[[170.0, 172.0], [198.0, 172.0], [198.0, 334.0], [170.0, 334.0]], [[140.0, 172.0], [164.0, 172.0], [164.0, 311.0], [140.0, 311.0]], [[109.0, 172.0], [132.0, 172.0], [132.0, 334.0], [109.0, 334.0]]], "lines": ["いやぁ、なんか", "勢いみたいな", "トコもあって．．．"]}, {"box": [657, 494, 712, 631], "vertical": true, "font_size": 24, "lines_coords": [[[682.0, 494.0], [712.0, 494.0], [712.0, 575.0], [682.0, 575.0]], [[657.0, 494.0], [676.0, 494.0], [676.0, 631.0], [657.0, 631.0]]], "lines": ["芽衣子、", "ちょっとぉ．．．"]}, {"box": [243, 396, 304, 566], "vertical": true, "font_size": 25, "lines_coords": [[[270.0, 396.0], [304.0, 396.0], [304.0, 438.0], [270.0, 438.0]], [[243.0, 399.0], [266.0, 399.0], [267.0, 566.0], [244.0, 566.0]]], "lines": ["あー", "やんなっちゃう。"]}, {"box": [109, 474, 217, 648], "vertical": true, "font_size": 25, "lines_coords": [[[194.0, 474.0], [217.0, 474.0], [217.0, 568.0], [194.0, 568.0]], [[165.0, 475.0], [188.0, 475.0], [188.0, 648.0], [165.0, 648.0]], [[136.0, 474.0], [161.0, 474.0], [158.0, 635.0], [133.0, 635.0]], [[109.0, 475.0], [132.0, 475.0], [132.0, 578.0], [109.0, 578.0]]], "lines": ["やっぱり", "母さんあんたを", "１人にしとくの", "不安だわ。"]}, {"box": [831, 717, 859, 798], "vertical": true, "font_size": 24, "lines_coords": [[[831.0, 717.0], [859.0, 717.0], [859.0, 798.0], [831.0, 798.0]]], "lines": ["芽衣子。"]}, {"box": [746, 840, 833, 981], "vertical": true, "font_size": 24, "lines_coords": [[[808.0, 842.0], [831.0, 842.0], [833.0, 981.0], [810.0, 981.0]], [[776.0, 842.0], [799.0, 842.0], [802.0, 980.0], [779.0, 980.0]], [[746.0, 840.0], [769.0, 840.0], [769.0, 937.0], [746.0, 937.0]]], "lines": ["これを機会に", "秋田に帰って", "きなさい"]}, {"box": [222, 1119, 250, 1170], "vertical": true, "font_size": 26, "lines_coords": [[[222.0, 1119.0], [250.0, 1119.0], [250.0, 1170.0], [222.0, 1170.0]]], "lines": ["．．．や、"]}, {"box": [159, 1170, 183, 1289], "vertical": true, "font_size": 26, "lines_coords": [[[159.0, 1170.0], [183.0, 1170.0], [183.0, 1289.0], [159.0, 1289.0]]], "lines": ["やだよ．．．"]}], "img_path": "053.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [719, 131, 839, 339], "vertical": true, "font_size": 24, "lines_coords": [[[814.0, 133.0], [838.0, 133.0], [838.0, 299.0], [814.0, 299.0]], [[783.0, 133.0], [806.0, 133.0], [806.0, 339.0], [783.0, 339.0]], [[751.0, 131.0], [775.0, 131.0], [773.0, 292.0], [750.0, 292.0]], [[719.0, 132.0], [743.0, 132.0], [743.0, 202.0], [719.0, 202.0]]], "lines": ["．．．じゃあ芽衣子、", "このまま東京にいて", "どうするつもり", "なの？"]}, {"box": [251, 176, 280, 280], "vertical": true, "font_size": 24, "lines_coords": [[[251.0, 177.0], [276.0, 176.0], [280.0, 278.0], [255.0, 280.0]]], "lines": ["それはっ、"]}, {"box": [642, 541, 836, 749], "vertical": true, "font_size": 28, "lines_coords": [[[802.0, 541.0], [831.0, 541.0], [833.0, 676.0], [805.0, 676.0]], [[768.0, 541.0], [798.0, 541.0], [795.0, 653.0], [765.0, 653.0]], [[719.0, 566.0], [747.0, 566.0], [747.0, 702.0], [719.0, 702.0]], [[680.0, 563.0], [708.0, 563.0], [708.0, 749.0], [680.0, 749.0]], [[645.0, 563.0], [669.0, 563.0], [667.0, 728.0], [642.0, 728.0]]], "lines": ["わかんない", "って．．．", "何、あんた", "子供じみたこと", "言ってんの！！"]}, {"box": [149, 284, 236, 442], "vertical": true, "font_size": 24, "lines_coords": [[[211.0, 285.0], [236.0, 285.0], [236.0, 377.0], [211.0, 377.0]], [[180.0, 284.0], [203.0, 284.0], [203.0, 442.0], [180.0, 442.0]], [[149.0, 284.0], [173.0, 284.0], [173.0, 377.0], [149.0, 377.0]]], "lines": ["．．．．．まだ", "よくわかんない", "けど．．．"]}, {"box": [809, 850, 839, 913], "vertical": true, "font_size": 29, "lines_coords": [[[809.0, 850.0], [839.0, 850.0], [839.0, 913.0], [809.0, 913.0]]], "lines": ["う．．．"]}, {"box": [266, 812, 333, 1007], "vertical": true, "font_size": 28, "lines_coords": [[[304.0, 813.0], [333.0, 813.0], [333.0, 1007.0], [304.0, 1007.0]], [[266.0, 812.0], [293.0, 812.0], [293.0, 980.0], [266.0, 980.0]]], "lines": ["お母さんだって", "ズルイよっ！！"]}, {"box": [188, 917, 257, 1085], "vertical": true, "font_size": 28, "lines_coords": [[[228.0, 920.0], [257.0, 920.0], [257.0, 1085.0], [228.0, 1085.0]], [[188.0, 917.0], [216.0, 917.0], [218.0, 1085.0], [191.0, 1085.0]]], "lines": ["いきなり来て", "色々言って！！"]}, {"box": [798, 992, 870, 1125], "vertical": true, "font_size": 29, "lines_coords": [[[842.0, 992.0], [870.0, 992.0], [870.0, 1123.0], [842.0, 1123.0]], [[798.0, 996.0], [827.0, 996.0], [827.0, 1125.0], [798.0, 1125.0]]], "lines": ["うるさい", "なぁっ！！"]}, {"box": [537, 992, 619, 1158], "vertical": true, "font_size": 33, "lines_coords": [[[581.0, 993.0], [615.0, 992.0], [619.0, 1123.0], [585.0, 1125.0]], [[540.0, 992.0], [572.0, 992.0], [570.0, 1158.0], [537.0, 1158.0]]], "lines": ["子供じゃ", "ないもん！！"]}, {"box": [58, 1138, 191, 1363], "vertical": true, "font_size": 28, "lines_coords": [[[159.0, 1138.0], [188.0, 1138.0], [191.0, 1291.0], [162.0, 1291.0]], [[125.0, 1140.0], [153.0, 1140.0], [153.0, 1363.0], [125.0, 1363.0]], [[88.0, 1140.0], [117.0, 1140.0], [117.0, 1283.0], [88.0, 1283.0]], [[58.0, 1141.0], [82.0, 1141.0], [82.0, 1305.0], [58.0, 1305.0]]], "lines": ["平気だよっ、", "あたし達のことは", "あたし達で", "決めるもん！！"]}], "img_path": "054.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [768, 98, 835, 269], "vertical": true, "font_size": 28, "lines_coords": [[[802.0, 98.0], [835.0, 98.0], [835.0, 269.0], [802.0, 269.0]], [[771.0, 98.0], [795.0, 98.0], [792.0, 263.0], [768.0, 263.0]]], "lines": ["あ〜〜〜～～", "〜〜〜もう！！"]}, {"box": [143, 277, 213, 447], "vertical": true, "font_size": 31, "lines_coords": [[[174.0, 277.0], [213.0, 277.0], [213.0, 343.0], [174.0, 343.0]], [[143.0, 278.0], [170.0, 278.0], [170.0, 447.0], [143.0, 447.0]]], "lines": ["全然", "ダメじゃん！！"]}, {"box": [205, 470, 311, 609], "vertical": true, "font_size": 31, "lines_coords": [[[274.0, 470.0], [311.0, 470.0], [311.0, 533.0], [274.0, 533.0]], [[240.0, 471.0], [267.0, 471.0], [267.0, 609.0], [240.0, 609.0]], [[205.0, 471.0], [229.0, 471.0], [229.0, 582.0], [205.0, 582.0]]], "lines": ["全然", "あたし子供", "じゃん！！"]}, {"box": [205, 471, 310, 609], "vertical": true, "font_size": 105, "lines_coords": [[[205.0, 471.0], [310.0, 471.0], [310.0, 609.0], [205.0, 609.0]]], "lines": ["全然あたし子供じゃん！！"]}, {"box": [699, 754, 732, 854], "vertical": true, "font_size": 31, "lines_coords": [[[699.0, 756.0], [730.0, 754.0], [732.0, 853.0], [702.0, 854.0]]], "lines": ["．．．ふぅ。"]}, {"box": [157, 955, 303, 1018], "vertical": false, "font_size": 51, "lines_coords": [[[157.0, 967.0], [298.0, 955.0], [303.0, 1006.0], [162.0, 1018.0]]], "lines": ["ええぇえ"]}, {"box": [777, 977, 847, 1145], "vertical": true, "font_size": 29, "lines_coords": [[[809.0, 978.0], [843.0, 977.0], [847.0, 1075.0], [813.0, 1077.0]], [[777.0, 980.0], [805.0, 980.0], [805.0, 1145.0], [777.0, 1145.0]]], "lines": ["ホラッ、", "ゾウのマネ！！"]}, {"box": [698, 1075, 764, 1215], "vertical": true, "font_size": 29, "lines_coords": [[[734.0, 1075.0], [764.0, 1075.0], [764.0, 1163.0], [734.0, 1163.0]], [[698.0, 1078.0], [721.0, 1078.0], [721.0, 1215.0], [698.0, 1215.0]]], "lines": ["これで", "どうだっ！？"]}], "img_path": "055.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "056.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "057.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [799, 65, 859, 194], "vertical": true, "font_size": 23, "lines_coords": [[[831.0, 65.0], [859.0, 65.0], [857.0, 164.0], [828.0, 164.0]], [[799.0, 69.0], [823.0, 69.0], [823.0, 194.0], [799.0, 194.0]]], "lines": ["じゃ、鍵", "借りてくわ。"]}, {"box": [664, 218, 813, 380], "vertical": true, "font_size": 23, "lines_coords": [[[794.0, 221.0], [813.0, 221.0], [813.0, 356.0], [794.0, 356.0]], [[760.0, 220.0], [783.0, 220.0], [783.0, 343.0], [760.0, 343.0]], [[727.0, 220.0], [750.0, 220.0], [750.0, 358.0], [727.0, 358.0]], [[694.0, 218.0], [717.0, 218.0], [720.0, 380.0], [697.0, 380.0]], [[664.0, 218.0], [687.0, 218.0], [687.0, 321.0], [664.0, 321.0]]], "lines": ["お前がバイト", "終わるまで、", "部屋で勝手に", "ダラダラさせて", "もらうわ。"]}, {"box": [416, 184, 638, 318], "vertical": false, "font_size": 26.0, "lines_coords": [[[422.0, 243.0], [612.0, 184.0], [620.0, 211.0], [430.0, 270.0]], [[419.0, 269.0], [613.0, 218.0], [620.0, 244.0], [425.0, 293.0]], [[416.0, 295.0], [633.0, 240.0], [638.0, 263.0], [422.0, 318.0]]], "lines": ["小田原・箱根湯本誌『ルーーム』", "藤沢片瀬江ノ島", "藤沢「「．．．一刀」の問題は「ねえないですね。"]}, {"box": [209, 231, 233, 311], "vertical": true, "font_size": 23, "lines_coords": [[[209.0, 231.0], [233.0, 231.0], [233.0, 311.0], [209.0, 311.0]]], "lines": ["おうよ。"]}, {"box": [827, 556, 850, 720], "vertical": true, "font_size": 24, "lines_coords": [[[827.0, 556.0], [850.0, 556.0], [850.0, 720.0], [827.0, 720.0]]], "lines": ["さっきの話って、"]}, {"box": [121, 365, 207, 509], "vertical": true, "font_size": 23, "lines_coords": [[[184.0, 365.0], [207.0, 365.0], [207.0, 509.0], [184.0, 509.0]], [[153.0, 366.0], [176.0, 366.0], [176.0, 483.0], [153.0, 483.0]], [[123.0, 366.0], [143.0, 366.0], [142.0, 501.0], [121.0, 501.0]]], "lines": ["ところで種田", "さっきの話", "だけどよ．．．"]}, {"box": [259, 596, 278, 717], "vertical": true, "font_size": 22, "lines_coords": [[[259.0, 596.0], [278.0, 596.0], [278.0, 717.0], [259.0, 717.0]]], "lines": ["ちげーよ。"]}, {"box": [710, 642, 791, 825], "vertical": true, "font_size": 24, "lines_coords": [[[766.0, 642.0], [791.0, 642.0], [787.0, 803.0], [762.0, 803.0]], [[739.0, 643.0], [762.0, 643.0], [761.0, 825.0], [738.0, 825.0]], [[713.0, 643.0], [736.0, 643.0], [734.0, 758.0], [710.0, 758.0]]], "lines": ["お前が子供の時", "ＵＦＯにさらわれ", "たって話？"]}, {"box": [827, 865, 853, 947], "vertical": true, "font_size": 26, "lines_coords": [[[827.0, 891.0], [853.0, 891.0], [853.0, 947.0], [827.0, 947.0]]], "lines": ["．．．あ。"]}, {"box": [571, 898, 659, 1025], "vertical": true, "font_size": 24, "lines_coords": [[[634.0, 898.0], [658.0, 898.0], [658.0, 1022.0], [634.0, 1022.0]], [[602.0, 898.0], [626.0, 898.0], [626.0, 1025.0], [602.0, 1025.0]], [[571.0, 898.0], [596.0, 898.0], [596.0, 980.0], [571.0, 980.0]]], "lines": ["ま、いいや。", "じゃあまた", "夜にな。"]}, {"box": [103, 643, 220, 805], "vertical": true, "font_size": 22, "lines_coords": [[[194.0, 643.0], [218.0, 643.0], [220.0, 771.0], [195.0, 771.0]], [[165.0, 646.0], [188.0, 646.0], [188.0, 786.0], [165.0, 786.0]], [[132.0, 646.0], [155.0, 646.0], [155.0, 805.0], [132.0, 805.0]], [[103.0, 648.0], [123.0, 648.0], [123.0, 805.0], [103.0, 805.0]]], "lines": ["あーホラ、", "真剣にバンド", "やりてえんじゃ", "ねぇのって話！！"]}, {"box": [173, 1040, 267, 1231], "vertical": true, "font_size": 29, "lines_coords": [[[240.0, 1045.0], [267.0, 1045.0], [267.0, 1199.0], [240.0, 1199.0]], [[207.0, 1045.0], [235.0, 1045.0], [235.0, 1231.0], [207.0, 1231.0]], [[173.0, 1040.0], [209.0, 1040.0], [209.0, 1106.0], [173.0, 1106.0]]], "lines": ["．．．俺はお前に", "ついていくつもり", "だぜ。"]}, {"box": [154, 1194, 179, 1264], "vertical": true, "font_size": 29, "lines_coords": [[[154.0, 1194.0], [179.0, 1194.0], [179.0, 1264.0], [154.0, 1264.0]]], "lines": ["お前が"]}, {"box": [90, 1192, 177, 1354], "vertical": true, "font_size": 23, "lines_coords": [[[123.0, 1194.0], [146.0, 1194.0], [146.0, 1354.0], [123.0, 1354.0]], [[91.0, 1192.0], [114.0, 1192.0], [113.0, 1354.0], [90.0, 1354.0]]], "lines": ["本気になるのを", "待ってんだ．．．"]}], "img_path": "058.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [807, 138, 834, 239], "vertical": true, "font_size": 24, "lines_coords": [[[808.0, 140.0], [832.0, 140.0], [832.0, 235.0], [808.0, 235.0]]], "lines": ["今、現在、"]}, {"box": [755, 535, 843, 684], "vertical": true, "font_size": 24, "lines_coords": [[[818.0, 537.0], [842.0, 537.0], [842.0, 672.0], [818.0, 672.0]], [[784.0, 535.0], [813.0, 535.0], [813.0, 684.0], [784.0, 684.0]], [[756.0, 537.0], [775.0, 537.0], [775.0, 635.0], [756.0, 635.0]]], "lines": ["素直に言えば", "恋人がここに", "いるから。"]}, {"box": [450, 534, 541, 723], "vertical": true, "font_size": 25, "lines_coords": [[[515.0, 535.0], [540.0, 535.0], [540.0, 661.0], [515.0, 661.0]], [[482.0, 534.0], [509.0, 534.0], [509.0, 694.0], [482.0, 694.0]], [[451.0, 535.0], [474.0, 535.0], [474.0, 720.0], [451.0, 720.0]]], "lines": ["でもそれは", "理由というより", "言い逃れであって、"]}, {"box": [128, 306, 219, 423], "vertical": true, "font_size": 25, "lines_coords": [[[194.0, 308.0], [217.0, 308.0], [217.0, 400.0], [194.0, 400.0]], [[162.0, 308.0], [185.0, 308.0], [185.0, 423.0], [162.0, 423.0]], [[128.0, 306.0], [158.0, 306.0], [158.0, 369.0], [128.0, 369.0]]], "lines": ["あたしが", "東京にいる", "理由。"]}, {"box": [142, 533, 297, 693], "vertical": true, "font_size": 25, "lines_coords": [[[272.0, 535.0], [295.0, 535.0], [295.0, 671.0], [272.0, 671.0]], [[240.0, 535.0], [263.0, 535.0], [263.0, 648.0], [240.0, 648.0]], [[207.0, 534.0], [231.0, 534.0], [231.0, 693.0], [207.0, 693.0]], [[173.0, 534.0], [200.0, 534.0], [200.0, 672.0], [173.0, 672.0]], [[142.0, 533.0], [170.0, 533.0], [170.0, 613.0], [142.0, 613.0]]], "lines": ["さらに言えば", "今の生活は", "貯金残高という", "時間制限付き", "なんだ。"]}, {"box": [772, 801, 859, 983], "vertical": true, "font_size": 20, "lines_coords": [[[835.0, 801.0], [858.0, 801.0], [858.0, 940.0], [835.0, 940.0]], [[805.0, 803.0], [824.0, 803.0], [824.0, 961.0], [805.0, 961.0]], [[772.0, 802.0], [791.0, 802.0], [791.0, 980.0], [772.0, 980.0]]], "lines": ["その時までに", "あたしは何かを", "見つけられるか？"]}, {"box": [593, 804, 622, 904], "vertical": true, "font_size": 26, "lines_coords": [[[596.0, 808.0], [622.0, 808.0], [619.0, 902.0], [593.0, 902.0]]], "lines": ["Ｈタン"]}, {"box": [133, 1174, 225, 1312], "vertical": true, "font_size": 24, "lines_coords": [[[199.0, 1175.0], [222.0, 1175.0], [222.0, 1296.0], [199.0, 1296.0]], [[166.0, 1174.0], [191.0, 1174.0], [192.0, 1290.0], [168.0, 1290.0]], [[136.0, 1174.0], [159.0, 1174.0], [157.0, 1312.0], [133.0, 1312.0]]], "lines": ["芽衣子さん、", "禁煙中じゃ", "なかったの？"]}], "img_path": "059.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [849, 112, 872, 224], "vertical": true, "font_size": 25, "lines_coords": [[[849.0, 112.0], [872.0, 112.0], [872.0, 224.0], [849.0, 224.0]]], "lines": ["．．．．．．種田！？"]}, {"box": [717, 158, 808, 324], "vertical": true, "font_size": 25, "lines_coords": [[[780.0, 158.0], [808.0, 158.0], [808.0, 324.0], [780.0, 324.0]], [[747.0, 158.0], [771.0, 158.0], [773.0, 298.0], [750.0, 298.0]], [[717.0, 161.0], [742.0, 161.0], [742.0, 252.0], [717.0, 252.0]]], "lines": ["あれ、加藤君ち", "泊まるんじゃ", "ないの？"]}, {"box": [483, 143, 574, 261], "vertical": true, "font_size": 26, "lines_coords": [[[545.0, 144.0], [574.0, 144.0], [574.0, 261.0], [545.0, 261.0]], [[515.0, 144.0], [540.0, 144.0], [540.0, 259.0], [515.0, 259.0]], [[483.0, 143.0], [508.0, 143.0], [508.0, 225.0], [483.0, 225.0]]], "lines": ["いや、一応", "そのつもり", "だけど。"]}, {"box": [88, 51, 211, 71], "vertical": false, "font_size": 20, "lines_coords": [[[88.0, 51.0], [211.0, 51.0], [211.0, 71.0], [88.0, 71.0]]], "lines": ["ソラニン［"]}, {"box": [95, 224, 213, 430], "vertical": true, "font_size": 23, "lines_coords": [[[188.0, 224.0], [213.0, 224.0], [213.0, 317.0], [188.0, 317.0]], [[157.0, 224.0], [180.0, 224.0], [180.0, 430.0], [157.0, 430.0]], [[128.0, 225.0], [147.0, 225.0], [147.0, 427.0], [128.0, 427.0]], [[95.0, 224.0], [118.0, 224.0], [118.0, 326.0], [95.0, 326.0]]], "lines": ["その前に", "芽衣子のお母さんに", "軽く挨拶しとくかぁ", "と思って。"]}, {"box": [180, 434, 267, 598], "vertical": true, "font_size": 23, "lines_coords": [[[243.0, 438.0], [267.0, 438.0], [267.0, 533.0], [243.0, 533.0]], [[213.0, 437.0], [236.0, 437.0], [236.0, 555.0], [213.0, 555.0]], [[181.0, 434.0], [205.0, 434.0], [203.0, 598.0], [180.0, 598.0]]], "lines": ["．．．つーか", "そっちこそ", "何やってんの？"]}, {"box": [754, 1075, 780, 1216], "vertical": true, "font_size": 26, "lines_coords": [[[754.0, 1075.0], [780.0, 1075.0], [780.0, 1137.0], [754.0, 1137.0]]], "lines": ["．．．んー"]}, {"box": [267, 1152, 293, 1233], "vertical": true, "font_size": 24, "lines_coords": [[[267.0, 1152.0], [292.0, 1152.0], [293.0, 1233.0], [269.0, 1233.0]]], "lines": ["わはは。"]}, {"box": [166, 1196, 222, 1335], "vertical": true, "font_size": 24, "lines_coords": [[[199.0, 1199.0], [222.0, 1199.0], [222.0, 1297.0], [199.0, 1297.0]], [[169.0, 1196.0], [192.0, 1196.0], [190.0, 1335.0], [166.0, 1335.0]]], "lines": ["なになに、", "どーしたの？"]}], "img_path": "060.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [597, 88, 616, 198], "vertical": true, "font_size": 21, "lines_coords": [[[597.0, 88.0], [616.0, 88.0], [616.0, 198.0], [597.0, 198.0]]], "lines": ["．．．．．．あら？"]}, {"box": [467, 132, 553, 293], "vertical": true, "font_size": 21, "lines_coords": [[[530.0, 132.0], [553.0, 132.0], [553.0, 251.0], [530.0, 251.0]], [[500.0, 133.0], [519.0, 133.0], [519.0, 247.0], [500.0, 247.0]], [[467.0, 135.0], [490.0, 135.0], [490.0, 293.0], [467.0, 293.0]]], "lines": ["芽衣子さん、", "部屋の電気", "ついてないよ？"]}, {"box": [224, 299, 247, 389], "vertical": true, "font_size": 24, "lines_coords": [[[224.0, 299.0], [247.0, 299.0], [247.0, 389.0], [224.0, 389.0]]], "lines": ["．．．んん？"]}, {"box": [103, 343, 157, 482], "vertical": true, "font_size": 24, "lines_coords": [[[133.0, 344.0], [157.0, 344.0], [157.0, 482.0], [133.0, 482.0]], [[103.0, 343.0], [127.0, 343.0], [127.0, 437.0], [103.0, 437.0]]], "lines": ["なんかカレー", "くさっ！！"]}, {"box": [244, 727, 367, 981], "vertical": true, "font_size": 25, "lines_coords": [[[343.0, 728.0], [367.0, 728.0], [365.0, 828.0], [340.0, 828.0]], [[311.0, 727.0], [336.0, 727.0], [332.0, 918.0], [307.0, 918.0]], [[278.0, 727.0], [303.0, 727.0], [302.0, 922.0], [277.0, 922.0]], [[246.0, 727.0], [270.0, 727.0], [269.0, 981.0], [244.0, 981.0]]], "lines": ["「芽衣子へ", "さっきはごめんね。", "びっくりしてつい", "怒鳴ってしまいました。」"]}, {"box": [404, 1136, 568, 1389], "vertical": false, "font_size": 30, "lines_coords": [[[488.0, 1136.0], [545.0, 1237.0], [520.0, 1250.0], [463.0, 1149.0]], [[447.0, 1144.0], [553.0, 1334.0], [518.0, 1354.0], [411.0, 1164.0]], [[432.0, 1177.0], [481.0, 1311.0], [453.0, 1320.0], [404.0, 1186.0]], [[432.0, 1290.0], [459.0, 1352.0], [438.0, 1360.0], [412.0, 1298.0]]], "lines": ["拡張休く", "キャッピングさんの", "ハッコードから", "これもー"]}, {"box": [79, 1138, 231, 1334], "vertical": true, "font_size": 22, "lines_coords": [[[206.0, 1140.0], [229.0, 1140.0], [229.0, 1334.0], [206.0, 1334.0]], [[173.0, 1140.0], [196.0, 1140.0], [196.0, 1324.0], [173.0, 1324.0]], [[142.0, 1138.0], [165.0, 1138.0], [165.0, 1256.0], [142.0, 1256.0]], [[110.0, 1138.0], [133.0, 1138.0], [133.0, 1300.0], [110.0, 1300.0]], [[80.0, 1141.0], [99.0, 1141.0], [99.0, 1253.0], [80.0, 1253.0]]], "lines": ["「やっぱり母さんも", "あなた達のことは", "あなた達で", "考えるといいと", "思います。」"]}], "img_path": "061.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [760, 99, 846, 292], "vertical": true, "font_size": 25, "lines_coords": [[[823.0, 99.0], [846.0, 99.0], [846.0, 292.0], [823.0, 292.0]], [[790.0, 99.0], [817.0, 99.0], [817.0, 262.0], [790.0, 262.0]], [[760.0, 99.0], [783.0, 99.0], [783.0, 269.0], [760.0, 269.0]]], "lines": ["「あたしは予定通り", "ホテルに泊まる", "ことにしました。"]}, {"box": [237, 218, 362, 426], "vertical": true, "font_size": 24, "lines_coords": [[[330.0, 220.0], [362.0, 220.0], [362.0, 283.0], [330.0, 283.0]], [[302.0, 221.0], [325.0, 221.0], [325.0, 381.0], [302.0, 381.0]], [[270.0, 220.0], [293.0, 220.0], [293.0, 426.0], [270.0, 426.0]], [[240.0, 218.0], [263.0, 218.0], [261.0, 367.0], [237.0, 367.0]]], "lines": ["「ＰＳ", "ポストの名札を", "見れば同棲してるの", "バレバレだよ。"]}, {"box": [645, 281, 768, 421], "vertical": true, "font_size": 25, "lines_coords": [[[742.0, 281.0], [766.0, 281.0], [768.0, 377.0], [743.0, 377.0]], [[712.0, 283.0], [735.0, 283.0], [735.0, 397.0], [712.0, 397.0]], [[676.0, 281.0], [706.0, 281.0], [706.0, 355.0], [676.0, 355.0]], [[648.0, 281.0], [675.0, 281.0], [672.0, 421.0], [645.0, 421.0]]], "lines": ["カレーを", "作ったので", "温めて", "食べなさい。」"]}, {"box": [133, 423, 251, 675], "vertical": true, "font_size": 24, "lines_coords": [[[228.0, 423.0], [251.0, 423.0], [251.0, 561.0], [228.0, 561.0]], [[196.0, 423.0], [220.0, 423.0], [220.0, 586.0], [196.0, 586.0]], [[166.0, 425.0], [185.0, 425.0], [185.0, 652.0], [166.0, 652.0]], [[133.0, 423.0], [157.0, 423.0], [157.0, 675.0], [133.0, 675.0]]], "lines": ["お父さんには", "黙っておくけど", "芽衣子も嘘をつくなら、", "もっと上手につきなさい。」"]}, {"box": [132, 924, 187, 1026], "vertical": true, "font_size": 24, "lines_coords": [[[158.0, 924.0], [187.0, 924.0], [187.0, 1019.0], [158.0, 1019.0]], [[132.0, 925.0], [151.0, 925.0], [151.0, 1024.0], [132.0, 1024.0]]], "lines": ["．．．．．．種田", "ごめんね"]}, {"box": [95, 1209, 124, 1282], "vertical": true, "font_size": 29, "lines_coords": [[[95.0, 1209.0], [124.0, 1209.0], [124.0, 1282.0], [95.0, 1282.0]]], "lines": ["何が？"]}], "img_path": "062.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [780, 162, 865, 281], "vertical": true, "font_size": 22, "lines_coords": [[[846.0, 165.0], [865.0, 165.0], [865.0, 274.0], [846.0, 274.0]], [[812.0, 162.0], [836.0, 162.0], [833.0, 277.0], [809.0, 277.0]], [[780.0, 162.0], [803.0, 162.0], [803.0, 281.0], [780.0, 281.0]]], "lines": ["お母さんに", "同棲のこと", "聞かれた時、"]}, {"box": [668, 220, 754, 391], "vertical": true, "font_size": 22, "lines_coords": [[[731.0, 220.0], [754.0, 220.0], [754.0, 381.0], [731.0, 381.0]], [[701.0, 222.0], [720.0, 222.0], [720.0, 380.0], [701.0, 380.0]], [[668.0, 221.0], [691.0, 221.0], [691.0, 391.0], [668.0, 391.0]]], "lines": ["怒られるんじゃ", "ないかと思って", "嘘ついちゃって。"]}, {"box": [217, 132, 274, 274], "vertical": true, "font_size": 23, "lines_coords": [[[247.0, 132.0], [274.0, 132.0], [274.0, 274.0], [247.0, 274.0]], [[217.0, 135.0], [240.0, 135.0], [240.0, 261.0], [217.0, 261.0]]], "lines": ["まぁ、そんな", "もんでしょ。"]}, {"box": [149, 272, 200, 419], "vertical": true, "font_size": 23, "lines_coords": [[[177.0, 272.0], [200.0, 272.0], [200.0, 414.0], [177.0, 414.0]], [[149.0, 273.0], [168.0, 273.0], [168.0, 419.0], [149.0, 419.0]]], "lines": ["言いづらいよ、", "そういうこと。"]}, {"box": [149, 512, 269, 674], "vertical": true, "font_size": 26, "lines_coords": [[[240.0, 514.0], [269.0, 514.0], [269.0, 613.0], [240.0, 613.0]], [[209.0, 515.0], [236.0, 515.0], [236.0, 653.0], [209.0, 653.0]], [[179.0, 515.0], [202.0, 515.0], [202.0, 674.0], [179.0, 674.0]], [[149.0, 512.0], [172.0, 512.0], [172.0, 628.0], [149.0, 628.0]]], "lines": ["俺、結局、", "ホント久々の", "動物園だったん", "だけど．．．"]}, {"box": [723, 772, 864, 1011], "vertical": true, "font_size": 23, "lines_coords": [[[839.0, 773.0], [864.0, 773.0], [861.0, 935.0], [836.0, 935.0]], [[809.0, 773.0], [832.0, 773.0], [832.0, 935.0], [809.0, 935.0]], [[782.0, 775.0], [801.0, 775.0], [801.0, 1002.0], [782.0, 1002.0]], [[747.0, 772.0], [772.0, 772.0], [773.0, 980.0], [749.0, 980.0]], [[723.0, 775.0], [742.0, 775.0], [742.0, 1011.0], [723.0, 1011.0]]], "lines": ["ホラ、俺の両親", "昔から共働きで", "仲も悪かったから．．．", "家族で出かけるって", "減多になかったからさ。"]}, {"box": [596, 839, 710, 1025], "vertical": true, "font_size": 23, "lines_coords": [[[680.0, 839.0], [710.0, 839.0], [710.0, 896.0], [680.0, 896.0]], [[654.0, 844.0], [678.0, 844.0], [678.0, 984.0], [654.0, 984.0]], [[627.0, 843.0], [646.0, 843.0], [646.0, 1025.0], [627.0, 1025.0]], [[596.0, 844.0], [619.0, 844.0], [619.0, 989.0], [596.0, 989.0]]], "lines": ["今も", "ほとんど連絡", "しないし、冷めた", "家庭じゃんか。"]}, {"box": [151, 823, 272, 985], "vertical": true, "font_size": 24, "lines_coords": [[[243.0, 823.0], [272.0, 823.0], [272.0, 896.0], [243.0, 896.0]], [[214.0, 824.0], [237.0, 824.0], [237.0, 984.0], [214.0, 984.0]], [[183.0, 824.0], [206.0, 824.0], [206.0, 985.0], [183.0, 985.0]], [[151.0, 824.0], [174.0, 824.0], [174.0, 924.0], [151.0, 924.0]]], "lines": ["だから", "芽衣子んトコの", "「親子」っていう", "カンジは、"]}, {"box": [144, 1030, 229, 1193], "vertical": true, "font_size": 24, "lines_coords": [[[206.0, 1030.0], [229.0, 1030.0], [229.0, 1193.0], [206.0, 1193.0]], [[173.0, 1032.0], [198.0, 1032.0], [198.0, 1112.0], [173.0, 1112.0]], [[144.0, 1032.0], [164.0, 1032.0], [164.0, 1133.0], [144.0, 1133.0]]], "lines": ["すごくいいこと", "だよなー", "と思うよ。"]}], "img_path": "063.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [810, 155, 840, 247], "vertical": true, "font_size": 32, "lines_coords": [[[810.0, 155.0], [840.0, 155.0], [840.0, 247.0], [810.0, 247.0]]], "lines": ["．．．でも、"]}, {"box": [745, 272, 780, 313], "vertical": true, "font_size": 32, "lines_coords": [[[745.0, 272.0], [780.0, 272.0], [780.0, 313.0], [745.0, 313.0]]], "lines": ["俺、"]}, {"box": [114, 202, 207, 322], "vertical": true, "font_size": 26, "lines_coords": [[[183.0, 205.0], [207.0, 205.0], [207.0, 300.0], [183.0, 300.0]], [[150.0, 206.0], [174.0, 206.0], [174.0, 322.0], [150.0, 322.0]], [[114.0, 203.0], [144.0, 202.0], [147.0, 266.0], [117.0, 267.0]]], "lines": ["ちょっと", "寂しかった", "かも。"]}, {"box": [343, 485, 366, 599], "vertical": true, "font_size": 23, "lines_coords": [[[343.0, 485.0], [366.0, 485.0], [366.0, 598.0], [343.0, 598.0]]], "lines": ["．．．ごめん！！"]}, {"box": [735, 724, 764, 821], "vertical": true, "font_size": 28, "lines_coords": [[[735.0, 724.0], [764.0, 724.0], [764.0, 821.0], [735.0, 821.0]]], "lines": ["．．．．．．種田、"]}, {"box": [844, 987, 872, 1081], "vertical": true, "font_size": 25, "lines_coords": [[[847.0, 987.0], [872.0, 987.0], [869.0, 1081.0], [844.0, 1081.0]]], "lines": ["種田．．．．．"]}, {"box": [593, 792, 683, 888], "vertical": true, "font_size": 28, "lines_coords": [[[657.0, 794.0], [682.0, 794.0], [683.0, 888.0], [658.0, 888.0]], [[623.0, 794.0], [653.0, 794.0], [653.0, 866.0], [623.0, 866.0]], [[593.0, 792.0], [623.0, 792.0], [623.0, 866.0], [593.0, 866.0]]], "lines": ["また今度", "動物園", "行こ？"]}, {"box": [207, 836, 240, 902], "vertical": true, "font_size": 30, "lines_coords": [[[207.0, 838.0], [237.0, 836.0], [240.0, 900.0], [210.0, 902.0]]], "lines": ["うん。"]}, {"box": [129, 1168, 161, 1329], "vertical": true, "font_size": 29, "lines_coords": [[[129.0, 1170.0], [158.0, 1170.0], [158.0, 1328.0], [129.0, 1328.0]]], "lines": ["ぶっ殺す！！"]}], "img_path": "064.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [199, 289, 291, 624], "vertical": true, "font_size": 29, "lines_coords": [[[259.0, 289.0], [283.0, 289.0], [283.0, 464.0], [259.0, 464.0]], [[239.0, 515.0], [267.0, 515.0], [267.0, 623.0], [239.0, 623.0]], [[199.0, 514.0], [233.0, 514.0], [233.0, 612.0], [199.0, 612.0]]], "lines": ["はじめまして。", "芽衣子の", "母です。"]}, {"box": [792, 799, 880, 962], "vertical": true, "font_size": 25, "lines_coords": [[[855.0, 799.0], [879.0, 799.0], [879.0, 962.0], [855.0, 962.0]], [[821.0, 799.0], [849.0, 799.0], [849.0, 961.0], [821.0, 961.0]], [[792.0, 799.0], [816.0, 799.0], [816.0, 961.0], [792.0, 961.0]]], "lines": ["．．．あっ、今日は", "お忙しいところ", "すいません．．．"]}, {"box": [429, 870, 549, 1015], "vertical": true, "font_size": 22, "lines_coords": [[[527.0, 873.0], [546.0, 873.0], [546.0, 1013.0], [527.0, 1013.0]], [[493.0, 872.0], [516.0, 872.0], [516.0, 988.0], [493.0, 988.0]], [[460.0, 872.0], [483.0, 872.0], [483.0, 1008.0], [460.0, 1008.0]], [[429.0, 870.0], [452.0, 870.0], [452.0, 963.0], [429.0, 963.0]]], "lines": ["．．．芽衣子さん、", "俺の想像と", "だいぶ違うん", "だけど？"]}, {"box": [266, 1278, 281, 1343], "vertical": true, "font_size": 15, "lines_coords": [[[266.0, 1278.0], [281.0, 1278.0], [281.0, 1343.0], [266.0, 1343.0]]], "lines": ["それ間って"]}, {"box": [87, 1086, 206, 1307], "vertical": true, "font_size": 20, "lines_coords": [[[180.0, 1086.0], [205.0, 1086.0], [202.0, 1261.0], [177.0, 1261.0]], [[151.0, 1091.0], [170.0, 1091.0], [170.0, 1237.0], [151.0, 1237.0]], [[120.0, 1089.0], [139.0, 1089.0], [139.0, 1307.0], [120.0, 1307.0]], [[87.0, 1091.0], [106.0, 1091.0], [106.0, 1257.0], [87.0, 1257.0]]], "lines": ["きっとこれから", "同窓会だから、", "間違ったはりきり方", "したんだと思う。"]}], "img_path": "065.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [797, 84, 879, 267], "vertical": true, "font_size": 23, "lines_coords": [[[854.0, 86.0], [877.0, 86.0], [877.0, 267.0], [854.0, 267.0]], [[825.0, 84.0], [849.0, 84.0], [849.0, 224.0], [825.0, 224.0]], [[797.0, 84.0], [820.0, 84.0], [820.0, 176.0], [797.0, 176.0]]], "lines": ["２人は付き合って", "どれくらいに", "なるの？"]}, {"box": [448, 43, 481, 168], "vertical": true, "font_size": 25, "lines_coords": [[[448.0, 43.0], [481.0, 43.0], [481.0, 168.0], [448.0, 168.0]]], "lines": ["．．．あ、ハイ、"]}, {"box": [321, 109, 406, 248], "vertical": true, "font_size": 25, "lines_coords": [[[382.0, 109.0], [406.0, 109.0], [406.0, 248.0], [382.0, 248.0]], [[349.0, 110.0], [373.0, 110.0], [373.0, 225.0], [349.0, 225.0]], [[321.0, 110.0], [340.0, 110.0], [340.0, 246.0], [321.0, 246.0]]], "lines": ["大学１年の時", "からなんで", "六年目です．．．"]}, {"box": [805, 546, 862, 663], "vertical": true, "font_size": 26, "lines_coords": [[[833.0, 546.0], [862.0, 546.0], [862.0, 626.0], [833.0, 626.0]], [[805.0, 549.0], [828.0, 549.0], [828.0, 663.0], [805.0, 663.0]]], "lines": ["種田君、", "お仕事は？"]}, {"box": [77, 292, 167, 455], "vertical": true, "font_size": 24, "lines_coords": [[[142.0, 292.0], [166.0, 292.0], [164.0, 437.0], [139.0, 437.0]], [[109.0, 293.0], [132.0, 293.0], [132.0, 455.0], [109.0, 455.0]], [[77.0, 293.0], [101.0, 293.0], [101.0, 386.0], [77.0, 386.0]]], "lines": ["ちょっと種田、", "割りバシさかさ", "さかさ！！"]}, {"box": [247, 538, 337, 753], "vertical": true, "font_size": 23, "lines_coords": [[[310.0, 538.0], [337.0, 538.0], [337.0, 745.0], [310.0, 745.0]], [[280.0, 538.0], [303.0, 538.0], [303.0, 753.0], [280.0, 753.0]], [[247.0, 541.0], [270.0, 541.0], [270.0, 721.0], [247.0, 721.0]]], "lines": ["スポーツ新聞とかで", "ちっちゃいイラストを", "ナョコチョコと．．．"]}, {"box": [797, 895, 883, 1034], "vertical": true, "font_size": 24, "lines_coords": [[[858.0, 895.0], [883.0, 895.0], [883.0, 1013.0], [858.0, 1013.0]], [[828.0, 896.0], [851.0, 896.0], [851.0, 1033.0], [828.0, 1033.0]], [[797.0, 896.0], [820.0, 896.0], [820.0, 1034.0], [797.0, 1034.0]]], "lines": ["うあ～～～", "思った以上に", "気まずいよ．．"]}, {"box": [494, 884, 552, 1046], "vertical": true, "font_size": 24, "lines_coords": [[[526.0, 885.0], [550.0, 885.0], [552.0, 1045.0], [527.0, 1045.0]], [[494.0, 884.0], [518.0, 884.0], [518.0, 1000.0], [494.0, 1000.0]]], "lines": ["ゴメンちょっと", "トイレ．．．"]}, {"box": [135, 669, 220, 831], "vertical": true, "font_size": 23, "lines_coords": [[[196.0, 669.0], [220.0, 669.0], [220.0, 810.0], [196.0, 810.0]], [[165.0, 671.0], [188.0, 671.0], [188.0, 788.0], [165.0, 788.0]], [[135.0, 672.0], [154.0, 672.0], [154.0, 831.0], [135.0, 831.0]]], "lines": ["．．．と言っても", "まだバイト", "なんですけど．．．"]}, {"box": [615, 1197, 679, 1296], "vertical": true, "font_size": 32, "lines_coords": [[[642.0, 1197.0], [679.0, 1197.0], [679.0, 1255.0], [642.0, 1255.0]], [[615.0, 1200.0], [643.0, 1200.0], [643.0, 1296.0], [615.0, 1296.0]]], "lines": ["お腹", "痛い．．．．．"]}], "img_path": "066.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [764, 139, 851, 388], "vertical": true, "font_size": 24, "lines_coords": [[[823.0, 143.0], [851.0, 143.0], [851.0, 246.0], [823.0, 246.0]], [[791.0, 139.0], [823.0, 140.0], [814.0, 388.0], [783.0, 386.0]], [[764.0, 144.0], [783.0, 144.0], [783.0, 244.0], [764.0, 244.0]]], "lines": ["．．．ふふ、", "変わらないわね昔から", "芽衣子は。"]}, {"box": [506, 239, 561, 361], "vertical": true, "font_size": 21, "lines_coords": [[[535.0, 239.0], [559.0, 239.0], [561.0, 355.0], [538.0, 355.0]], [[507.0, 241.0], [526.0, 241.0], [526.0, 356.0], [507.0, 356.0]]], "lines": ["親としては", "心配だけど"]}, {"box": [116, 228, 203, 393], "vertical": true, "font_size": 23, "lines_coords": [[[180.0, 228.0], [203.0, 228.0], [203.0, 393.0], [180.0, 393.0]], [[149.0, 229.0], [172.0, 229.0], [172.0, 367.0], [149.0, 367.0]], [[116.0, 228.0], [139.0, 228.0], [142.0, 355.0], [118.0, 355.0]]], "lines": ["大丈夫よ種田君", "そんなに緊張", "しなくても。"]}, {"box": [724, 315, 777, 518], "vertical": true, "font_size": 24, "lines_coords": [[[758.0, 317.0], [777.0, 317.0], [777.0, 518.0], [758.0, 518.0]], [[725.0, 315.0], [746.0, 315.0], [745.0, 462.0], [724.0, 462.0]]], "lines": ["向こう見ずというか", "単純というか。"]}, {"box": [150, 436, 236, 645], "vertical": true, "font_size": 23, "lines_coords": [[[210.0, 438.0], [233.0, 438.0], [236.0, 538.0], [213.0, 538.0]], [[181.0, 437.0], [205.0, 437.0], [205.0, 645.0], [181.0, 645.0]], [[150.0, 436.0], [173.0, 436.0], [173.0, 541.0], [150.0, 541.0]]], "lines": ["あなた達、", "うまくやっていける", "気がする。"]}, {"box": [776, 695, 894, 880], "vertical": true, "font_size": 22, "lines_coords": [[[870.0, 698.0], [894.0, 698.0], [894.0, 791.0], [870.0, 791.0]], [[838.0, 695.0], [861.0, 695.0], [861.0, 880.0], [838.0, 880.0]], [[808.0, 698.0], [831.0, 698.0], [831.0, 836.0], [808.0, 836.0]], [[776.0, 698.0], [799.0, 698.0], [799.0, 790.0], [776.0, 790.0]]], "lines": ["私も昔は", "東京の大学を出て", "東京の会社に", "勤めて．．．"]}, {"box": [697, 801, 780, 996], "vertical": true, "font_size": 22, "lines_coords": [[[757.0, 801.0], [780.0, 801.0], [780.0, 987.0], [757.0, 987.0]], [[728.0, 805.0], [747.0, 805.0], [747.0, 996.0], [728.0, 996.0]], [[697.0, 803.0], [716.0, 803.0], [716.0, 951.0], [697.0, 951.0]]], "lines": ["あの時代だったし", "結局、秋田に戻って", "しまったけど。"]}, {"box": [142, 869, 250, 1081], "vertical": true, "font_size": 23, "lines_coords": [[[224.0, 870.0], [248.0, 870.0], [250.0, 1024.0], [225.0, 1024.0]], [[196.0, 872.0], [220.0, 872.0], [220.0, 1081.0], [196.0, 1081.0]], [[172.0, 873.0], [191.0, 873.0], [191.0, 1055.0], [172.0, 1055.0]], [[142.0, 869.0], [165.0, 869.0], [168.0, 993.0], [144.0, 993.0]]], "lines": ["私だって、もし", "あの時ああしてれば、", "なんて思ったりも", "するけれど、"]}, {"box": [375, 1019, 529, 1256], "vertical": true, "font_size": 22, "lines_coords": [[[504.0, 1022.0], [524.0, 1022.0], [526.0, 1208.0], [505.0, 1208.0]], [[471.0, 1022.0], [494.0, 1022.0], [494.0, 1160.0], [471.0, 1160.0]], [[440.0, 1022.0], [463.0, 1022.0], [463.0, 1253.0], [440.0, 1253.0]], [[410.0, 1024.0], [429.0, 1024.0], [429.0, 1226.0], [410.0, 1226.0]], [[375.0, 1019.0], [399.0, 1019.0], [400.0, 1238.0], [377.0, 1238.0]]], "lines": ["無意識だろうけど、", "芽衣子は私を", "反面教師にしてるから、", "実家に戻ることには", "抵抗あるんでしょう。"]}, {"box": [98, 1111, 187, 1296], "vertical": true, "font_size": 23, "lines_coords": [[[164.0, 1112.0], [187.0, 1112.0], [187.0, 1296.0], [164.0, 1296.0]], [[132.0, 1112.0], [155.0, 1112.0], [155.0, 1252.0], [132.0, 1252.0]], [[98.0, 1111.0], [123.0, 1111.0], [125.0, 1215.0], [101.0, 1215.0]]], "lines": ["今も幸せといえば", "とっても幸せ", "なのよね。"]}], "img_path": "067.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [816, 113, 840, 216], "vertical": true, "font_size": 23, "lines_coords": [[[816.0, 113.0], [840.0, 113.0], [840.0, 216.0], [816.0, 216.0]]], "lines": ["とにかく、"]}, {"box": [668, 166, 787, 354], "vertical": true, "font_size": 23, "lines_coords": [[[762.0, 166.0], [787.0, 166.0], [784.0, 330.0], [760.0, 330.0]], [[727.0, 166.0], [754.0, 166.0], [754.0, 354.0], [727.0, 354.0]], [[699.0, 170.0], [719.0, 170.0], [719.0, 307.0], [699.0, 307.0]], [[668.0, 172.0], [687.0, 172.0], [687.0, 292.0], [668.0, 292.0]]], "lines": ["今、あなた達は", "自由にいろいろと", "やってみたら", "いいと思う。"]}, {"box": [239, 106, 389, 314], "vertical": true, "font_size": 23, "lines_coords": [[[366.0, 109.0], [389.0, 109.0], [389.0, 224.0], [366.0, 224.0]], [[332.0, 106.0], [359.0, 106.0], [355.0, 314.0], [328.0, 314.0]], [[300.0, 106.0], [328.0, 106.0], [324.0, 292.0], [296.0, 292.0]], [[270.0, 108.0], [293.0, 108.0], [293.0, 270.0], [270.0, 270.0]], [[239.0, 106.0], [259.0, 106.0], [261.0, 277.0], [240.0, 277.0]]], "lines": ["若い頃って", "幸せになるためには", "困難な一つの方法", "しか無いなんて", "思いがちだけど、"]}, {"box": [158, 210, 211, 329], "vertical": true, "font_size": 23, "lines_coords": [[[192.0, 213.0], [211.0, 213.0], [211.0, 326.0], [192.0, 326.0]], [[158.0, 210.0], [181.0, 210.0], [181.0, 329.0], [158.0, 329.0]]], "lines": ["実はもっと", "単純なこと"]}, {"box": [127, 213, 210, 334], "vertical": true, "font_size": 19, "lines_coords": [[[128.0, 213.0], [147.0, 213.0], [147.0, 334.0], [128.0, 334.0]]], "lines": ["なんだから"]}, {"box": [548, 466, 571, 589], "vertical": true, "font_size": 24, "lines_coords": [[[548.0, 466.0], [571.0, 466.0], [571.0, 589.0], [548.0, 589.0]]], "lines": ["．．．．．．種田君。"]}, {"box": [422, 561, 508, 720], "vertical": true, "font_size": 24, "lines_coords": [[[483.0, 561.0], [508.0, 561.0], [508.0, 656.0], [483.0, 656.0]], [[452.0, 561.0], [475.0, 561.0], [475.0, 720.0], [452.0, 720.0]], [[422.0, 561.0], [445.0, 561.0], [445.0, 641.0], [422.0, 641.0]]], "lines": ["芽衣子を", "よろしくお願い", "します。"]}, {"box": [108, 1149, 146, 1249], "vertical": true, "font_size": 36, "lines_coords": [[[108.0, 1151.0], [143.0, 1149.0], [146.0, 1248.0], [110.0, 1249.0]]], "lines": ["はい！"]}], "img_path": "068.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [795, 90, 885, 259], "vertical": true, "font_size": 25, "lines_coords": [[[862.0, 92.0], [881.0, 92.0], [881.0, 257.0], [862.0, 257.0]], [[828.0, 91.0], [855.0, 91.0], [855.0, 232.0], [828.0, 232.0]], [[795.0, 90.0], [825.0, 90.0], [825.0, 153.0], [795.0, 153.0]]], "lines": ["．．．じゃあ２人共、", "体に気をつけ", "てね。"]}, {"box": [598, 88, 689, 272], "vertical": true, "font_size": 24, "lines_coords": [[[664.0, 91.0], [689.0, 91.0], [689.0, 207.0], [664.0, 207.0]], [[633.0, 88.0], [656.0, 88.0], [656.0, 272.0], [633.0, 272.0]], [[601.0, 90.0], [624.0, 90.0], [622.0, 235.0], [598.0, 235.0]]], "lines": ["お母さんも", "むやみに野菜とか", "送らないでね。"]}, {"box": [388, 308, 434, 344], "vertical": false, "font_size": 20.5, "lines_coords": [[[388.0, 308.0], [434.0, 308.0], [434.0, 329.0], [388.0, 329.0]], [[389.0, 324.0], [427.0, 324.0], [427.0, 344.0], [389.0, 344.0]]], "lines": ["タクシー", "タクシーのりは"]}, {"box": [492, 329, 594, 582], "vertical": true, "font_size": 22, "lines_coords": [[[571.0, 329.0], [590.0, 329.0], [590.0, 423.0], [571.0, 423.0]], [[555.0, 442.0], [579.0, 442.0], [579.0, 538.0], [555.0, 538.0]], [[522.0, 445.0], [546.0, 445.0], [546.0, 540.0], [522.0, 540.0]], [[492.0, 445.0], [515.0, 445.0], [515.0, 541.0], [492.0, 541.0]]], "lines": ["．．．なんか", "すっごく", "ドキドキ", "したぁー"]}, {"box": [97, 425, 185, 597], "vertical": true, "font_size": 23, "lines_coords": [[[157.0, 425.0], [185.0, 425.0], [185.0, 522.0], [157.0, 522.0]], [[128.0, 426.0], [151.0, 426.0], [151.0, 564.0], [128.0, 564.0]], [[97.0, 427.0], [116.0, 427.0], [118.0, 597.0], [99.0, 597.0]]], "lines": ["．．．俺も何", "食べてんだか", "わかんなかった。"]}, {"box": [745, 699, 769, 825], "vertical": true, "font_size": 24, "lines_coords": [[[745.0, 700.0], [769.0, 700.0], [769.0, 825.0], [745.0, 825.0]]], "lines": ["．．．ね、種田。"]}, {"box": [652, 798, 680, 869], "vertical": true, "font_size": 28, "lines_coords": [[[652.0, 798.0], [680.0, 798.0], [680.0, 869.0], [652.0, 869.0]]], "lines": ["んん？"]}, {"box": [254, 715, 342, 831], "vertical": true, "font_size": 23, "lines_coords": [[[317.0, 716.0], [341.0, 716.0], [341.0, 831.0], [317.0, 831.0]], [[285.0, 716.0], [308.0, 716.0], [308.0, 810.0], [285.0, 810.0]], [[254.0, 715.0], [277.0, 715.0], [277.0, 818.0], [254.0, 818.0]]], "lines": ["お母さんと", "どんな話", "してたの。"]}, {"box": [181, 865, 205, 943], "vertical": true, "font_size": 24, "lines_coords": [[[181.0, 865.0], [205.0, 865.0], [205.0, 943.0], [181.0, 943.0]]], "lines": ["ヒミツ。"]}, {"box": [682, 1050, 738, 1173], "vertical": true, "font_size": 23, "lines_coords": [[[713.0, 1050.0], [738.0, 1050.0], [738.0, 1141.0], [713.0, 1141.0]], [[682.0, 1050.0], [705.0, 1050.0], [705.0, 1173.0], [682.0, 1173.0]]], "lines": ["．．．．．．なぁ", "芽衣子さん。"]}, {"box": [537, 1111, 656, 1287], "vertical": true, "font_size": 23, "lines_coords": [[[630.0, 1111.0], [653.0, 1111.0], [656.0, 1253.0], [633.0, 1253.0]], [[600.0, 1115.0], [623.0, 1115.0], [623.0, 1276.0], [600.0, 1276.0]], [[568.0, 1114.0], [591.0, 1114.0], [591.0, 1287.0], [568.0, 1287.0]], [[537.0, 1115.0], [560.0, 1115.0], [560.0, 1241.0], [537.0, 1241.0]]], "lines": ["もし金持ちに", "なったら、また", "さっきのうなぎ", "食べような。"]}, {"box": [226, 1147, 258, 1209], "vertical": true, "font_size": 32, "lines_coords": [[[226.0, 1147.0], [258.0, 1147.0], [258.0, 1209.0], [226.0, 1209.0]]], "lines": ["うん。"]}], "img_path": "069.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "070.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "071.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [765, 205, 829, 288], "vertical": true, "font_size": 31, "lines_coords": [[[797.0, 206.0], [829.0, 206.0], [829.0, 261.0], [797.0, 261.0]], [[765.0, 206.0], [794.0, 205.0], [797.0, 287.0], [768.0, 288.0]]], "lines": ["俺は", "ビリー。"]}, {"box": [140, 194, 229, 364], "vertical": true, "font_size": 23, "lines_coords": [[[205.0, 194.0], [228.0, 194.0], [228.0, 333.0], [205.0, 333.0]], [[173.0, 194.0], [196.0, 194.0], [196.0, 333.0], [173.0, 333.0]], [[142.0, 195.0], [165.0, 195.0], [164.0, 360.0], [140.0, 360.0]]], "lines": ["正確に言うと", "俺はビリーと", "呼ばれている男。"]}, {"box": [751, 483, 817, 653], "vertical": true, "font_size": 27, "lines_coords": [[[782.0, 483.0], [812.0, 483.0], [814.0, 650.0], [784.0, 650.0]], [[751.0, 483.0], [775.0, 483.0], [775.0, 583.0], [751.0, 583.0]]], "lines": ["本名は山田二郎。", "薬局店員。"]}, {"box": [131, 570, 250, 753], "vertical": true, "font_size": 22, "lines_coords": [[[225.0, 570.0], [248.0, 570.0], [248.0, 684.0], [225.0, 684.0]], [[194.0, 571.0], [217.0, 571.0], [217.0, 709.0], [194.0, 709.0]], [[161.0, 570.0], [184.0, 570.0], [184.0, 753.0], [161.0, 753.0]], [[132.0, 571.0], [151.0, 571.0], [151.0, 694.0], [132.0, 694.0]]], "lines": ["ごく普通の", "商店街にある", "ごく普通の薬局が", "俺の生家だ。"]}, {"box": [747, 839, 867, 1023], "vertical": true, "font_size": 24, "lines_coords": [[[842.0, 840.0], [865.0, 840.0], [865.0, 977.0], [842.0, 977.0]], [[810.0, 842.0], [833.0, 842.0], [833.0, 977.0], [810.0, 977.0]], [[777.0, 839.0], [801.0, 839.0], [801.0, 1022.0], [777.0, 1022.0]], [[747.0, 840.0], [771.0, 840.0], [771.0, 958.0], [747.0, 958.0]]], "lines": ["俺の呼び名は", "小学生時代の", "ある些細な事件に", "由来するが、"]}, {"box": [591, 864, 630, 926], "vertical": false, "font_size": 62, "lines_coords": [[[591.0, 864.0], [630.0, 864.0], [630.0, 926.0], [591.0, 926.0]]], "lines": ["あぅ"]}, {"box": [105, 906, 227, 1115], "vertical": true, "font_size": 24, "lines_coords": [[[199.0, 907.0], [226.0, 907.0], [226.0, 1115.0], [199.0, 1115.0]], [[169.0, 907.0], [192.0, 907.0], [192.0, 1047.0], [169.0, 1047.0]], [[138.0, 907.0], [161.0, 907.0], [161.0, 1114.0], [138.0, 1114.0]], [[105.0, 906.0], [128.0, 906.0], [128.0, 1055.0], [105.0, 1055.0]]], "lines": ["未だにその出来事が", "自分に影響を", "与えていると思うと", "人生って妙だ。"]}, {"box": [483, 1119, 537, 1235], "vertical": true, "font_size": 22, "lines_coords": [[[514.0, 1119.0], [537.0, 1119.0], [537.0, 1234.0], [514.0, 1234.0]], [[483.0, 1122.0], [503.0, 1122.0], [503.0, 1233.0], [483.0, 1233.0]]], "lines": ["オイ二郎！！", "お客さん！！"]}, {"box": [82, 1174, 137, 1358], "vertical": true, "font_size": 23, "lines_coords": [[[113.0, 1175.0], [136.0, 1175.0], [136.0, 1358.0], [113.0, 1358.0]], [[82.0, 1174.0], [105.0, 1174.0], [105.0, 1259.0], [82.0, 1259.0]]], "lines": ["あ、いらっしゃい", "ませぇー"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [783, 641, 808, 758], "vertical": true, "font_size": 25, "lines_coords": [[[783.0, 646.0], [808.0, 646.0], [808.0, 758.0], [783.0, 758.0]]], "lines": ["．．．．．おい！！"]}, {"box": [169, 511, 349, 591], "vertical": false, "font_size": 29, "lines_coords": [[[169.0, 511.0], [349.0, 511.0], [349.0, 555.0], [169.0, 555.0]], [[177.0, 553.0], [333.0, 553.0], [333.0, 567.0], [177.0, 567.0]], [[173.0, 563.0], [337.0, 563.0], [337.0, 591.0], [173.0, 591.0]]], "lines": ["パイの置かないでください", "置いてある白転車椅は散去します", "ありがとうございますが、この時点ではないのでしょうか。あなたは自分の意味がありませんが、"]}, {"box": [792, 884, 911, 1067], "vertical": true, "font_size": 22, "lines_coords": [[[887.0, 885.0], [911.0, 885.0], [911.0, 1000.0], [887.0, 1000.0]], [[857.0, 887.0], [876.0, 887.0], [876.0, 1044.0], [857.0, 1044.0]], [[823.0, 884.0], [846.0, 884.0], [846.0, 1067.0], [823.0, 1067.0]], [[792.0, 884.0], [816.0, 884.0], [816.0, 1045.0], [792.0, 1045.0]]], "lines": ["いやぁ～～～", "最近のボストは", "むつかしいことに", "なっとんの～～"]}, {"box": [479, 903, 598, 1088], "vertical": true, "font_size": 22, "lines_coords": [[[574.0, 906.0], [597.0, 906.0], [597.0, 1065.0], [574.0, 1065.0]], [[541.0, 905.0], [564.0, 905.0], [564.0, 1051.0], [541.0, 1051.0]], [[509.0, 903.0], [534.0, 903.0], [533.0, 1088.0], [508.0, 1088.0]], [[481.0, 906.0], [500.0, 906.0], [500.0, 1075.0], [481.0, 1075.0]]], "lines": ["いやいや、それ", "置き物だから。", "ちょっと先行くと", "ポストあるから。"]}, {"box": [179, 689, 265, 805], "vertical": true, "font_size": 24, "lines_coords": [[[240.0, 691.0], [265.0, 691.0], [265.0, 784.0], [240.0, 784.0]], [[205.0, 689.0], [233.0, 689.0], [233.0, 761.0], [205.0, 761.0]], [[179.0, 691.0], [198.0, 691.0], [198.0, 805.0], [179.0, 805.0]]], "lines": ["ちょっと", "そこの", "じーさん！！"]}, {"box": [113, 955, 222, 1248], "vertical": true, "font_size": 22, "lines_coords": [[[196.0, 957.0], [217.0, 957.0], [217.0, 1024.0], [196.0, 1024.0]], [[174.0, 1100.0], [198.0, 1100.0], [198.0, 1194.0], [174.0, 1194.0]], [[143.0, 1101.0], [166.0, 1101.0], [166.0, 1240.0], [143.0, 1240.0]], [[113.0, 1104.0], [131.0, 1104.0], [131.0, 1248.0], [113.0, 1248.0]]], "lines": ["ほぉー", "どなたか", "存じませんが", "親切にどうも。"]}], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [528, 89, 551, 235], "vertical": true, "font_size": 19, "lines_coords": [[[529.0, 95.0], [548.0, 95.0], [548.0, 235.0], [529.0, 235.0]]], "lines": ["．．．カエルよ。"]}, {"box": [91, 46, 213, 69], "vertical": false, "font_size": 23, "lines_coords": [[[91.0, 46.0], [213.0, 46.0], [213.0, 69.0], [91.0, 69.0]]], "lines": ["ソラニンの"]}, {"box": [771, 494, 865, 734], "vertical": true, "font_size": 29, "lines_coords": [[[832.0, 494.0], [865.0, 494.0], [865.0, 732.0], [832.0, 732.0]], [[802.0, 499.0], [829.0, 499.0], [829.0, 727.0], [802.0, 727.0]], [[771.0, 499.0], [798.0, 499.0], [798.0, 734.0], [771.0, 734.0]]], "lines": ["年中、雨風にさらされ、", "でも店の売り上げには", "あまり貢献してなくて、"]}, {"box": [105, 274, 194, 434], "vertical": true, "font_size": 26, "lines_coords": [[[169.0, 274.0], [194.0, 274.0], [191.0, 433.0], [166.0, 433.0]], [[133.0, 276.0], [162.0, 276.0], [162.0, 369.0], [133.0, 369.0]], [[105.0, 276.0], [128.0, 276.0], [128.0, 411.0], [105.0, 411.0]]], "lines": ["じゃあ、お前の", "人生って", "なんなんだ？"]}, {"box": [117, 494, 272, 801], "vertical": true, "font_size": 25, "lines_coords": [[[246.0, 497.0], [270.0, 497.0], [267.0, 634.0], [243.0, 634.0]], [[211.0, 494.0], [240.0, 494.0], [237.0, 801.0], [209.0, 801.0]], [[180.0, 496.0], [203.0, 496.0], [203.0, 679.0], [180.0, 679.0]], [[147.0, 494.0], [172.0, 494.0], [173.0, 702.0], [149.0, 702.0]], [[117.0, 494.0], [140.0, 494.0], [140.0, 676.0], [117.0, 676.0]]], "lines": ["陽気に笑顔で", "こぉーんなポーズしてるけど、", "挙げ句の果てには", "ポストに間違われる", "お前の役割って！？"]}, {"box": [817, 981, 872, 1118], "vertical": true, "font_size": 22, "lines_coords": [[[846.0, 981.0], [870.0, 981.0], [872.0, 1103.0], [847.0, 1103.0]], [[818.0, 983.0], [838.0, 983.0], [838.0, 1116.0], [818.0, 1116.0]]], "lines": ["．．．．．ビリー", "何してんの？"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [868, 90, 895, 257], "vertical": true, "font_size": 28, "lines_coords": [[[868.0, 90.0], [895.0, 90.0], [895.0, 257.0], [868.0, 257.0]]], "lines": ["だっはっは！！"]}, {"box": [816, 295, 846, 380], "vertical": true, "font_size": 28, "lines_coords": [[[816.0, 295.0], [846.0, 295.0], [846.0, 380.0], [816.0, 380.0]]], "lines": ["種田と"]}, {"box": [619, 90, 676, 248], "vertical": true, "font_size": 25, "lines_coords": [[[652.0, 90.0], [676.0, 90.0], [674.0, 248.0], [649.0, 248.0]], [[619.0, 91.0], [643.0, 91.0], [643.0, 183.0], [619.0, 183.0]]], "lines": ["大将、瓶ビール", "追加ね！！"]}, {"box": [571, 240, 628, 362], "vertical": true, "font_size": 25, "lines_coords": [[[597.0, 240.0], [628.0, 240.0], [628.0, 299.0], [597.0, 299.0]], [[571.0, 250.0], [590.0, 250.0], [590.0, 362.0], [571.0, 362.0]]], "lines": ["って", "寝てるし！！"]}, {"box": [356, 103, 412, 241], "vertical": true, "font_size": 24, "lines_coords": [[[388.0, 103.0], [411.0, 103.0], [411.0, 241.0], [388.0, 241.0]], [[356.0, 103.0], [380.0, 103.0], [380.0, 241.0], [356.0, 241.0]]], "lines": ["笑いごとじゃ", "ないっつの！！"]}, {"box": [779, 295, 846, 406], "vertical": true, "font_size": 29, "lines_coords": [[[779.0, 296.0], [808.0, 296.0], [808.0, 406.0], [779.0, 406.0]]], "lines": ["ケンカ！？"]}, {"box": [508, 638, 576, 756], "vertical": true, "font_size": 68, "lines_coords": [[[508.0, 638.0], [576.0, 638.0], [576.0, 756.0], [508.0, 756.0]]], "lines": ["あーはっはっ"]}, {"box": [365, 632, 466, 743], "vertical": true, "font_size": 101, "lines_coords": [[[365.0, 632.0], [466.0, 632.0], [466.0, 743.0], [365.0, 743.0]]], "lines": ["いくらやっても人がいいの"]}, {"box": [84, 397, 203, 560], "vertical": true, "font_size": 25, "lines_coords": [[[176.0, 399.0], [203.0, 399.0], [203.0, 538.0], [176.0, 538.0]], [[146.0, 397.0], [170.0, 397.0], [168.0, 560.0], [143.0, 560.0]], [[113.0, 397.0], [136.0, 397.0], [136.0, 535.0], [113.0, 535.0]], [[84.0, 397.0], [108.0, 397.0], [108.0, 525.0], [84.0, 525.0]]], "lines": ["ホラ、あたし", "部屋で１人だと", "時間もて余し", "ちゃってさ。"]}, {"box": [827, 608, 911, 792], "vertical": true, "font_size": 23, "lines_coords": [[[888.0, 609.0], [911.0, 609.0], [911.0, 791.0], [888.0, 791.0]], [[857.0, 609.0], [880.0, 609.0], [880.0, 792.0], [857.0, 792.0]], [[827.0, 608.0], [851.0, 608.0], [851.0, 710.0], [827.0, 710.0]]], "lines": ["今までやったこと", "ないことをしよう", "と思って、"]}, {"box": [702, 691, 820, 850], "vertical": true, "font_size": 23, "lines_coords": [[[797.0, 691.0], [820.0, 691.0], [820.0, 829.0], [797.0, 829.0]], [[764.0, 691.0], [787.0, 691.0], [787.0, 831.0], [764.0, 831.0]], [[732.0, 691.0], [756.0, 691.0], [756.0, 850.0], [732.0, 850.0]], [[702.0, 693.0], [725.0, 693.0], [725.0, 839.0], [702.0, 839.0]]], "lines": ["種田が買った", "格闘ゲームを", "ここ３日くらい", "やってたワケ。"]}, {"box": [801, 944, 906, 1058], "vertical": true, "font_size": 43, "lines_coords": [[[847.0, 946.0], [900.0, 944.0], [906.0, 1056.0], [853.0, 1058.0]], [[801.0, 957.0], [838.0, 957.0], [838.0, 1000.0], [801.0, 1000.0]]], "lines": ["超どー", "いー"]}, {"box": [347, 935, 425, 1107], "vertical": true, "font_size": 22, "lines_coords": [[[401.0, 937.0], [425.0, 937.0], [425.0, 1107.0], [401.0, 1107.0]], [[375.0, 937.0], [395.0, 937.0], [395.0, 1071.0], [375.0, 1071.0]], [[347.0, 935.0], [370.0, 935.0], [370.0, 1028.0], [347.0, 1028.0]]], "lines": ["いやぁ、あたしも", "意外なことに", "才能が？"]}, {"box": [235, 635, 344, 851], "vertical": true, "font_size": 22, "lines_coords": [[[321.0, 637.0], [344.0, 637.0], [344.0, 788.0], [321.0, 788.0]], [[289.0, 635.0], [313.0, 635.0], [314.0, 829.0], [291.0, 829.0]], [[261.0, 637.0], [284.0, 637.0], [284.0, 775.0], [261.0, 775.0]], [[235.0, 638.0], [254.0, 638.0], [254.0, 851.0], [235.0, 851.0]]], "lines": ["それできのう", "種田と対戦したら、", "俄然あたしが", "強くなっちゃってて。"]}, {"box": [153, 758, 206, 903], "vertical": true, "font_size": 22, "lines_coords": [[[181.0, 758.0], [206.0, 758.0], [203.0, 896.0], [179.0, 896.0]], [[153.0, 758.0], [172.0, 758.0], [172.0, 903.0], [153.0, 903.0]]], "lines": ["２０連勝したら", "種田がキレた。"]}, {"box": [151, 756, 206, 907], "vertical": true, "font_size": 55, "lines_coords": [[[151.0, 756.0], [206.0, 756.0], [206.0, 907.0], [151.0, 907.0]]], "lines": ["２０連勝したら種田がキレた。"]}, {"box": [801, 1115, 898, 1264], "vertical": true, "font_size": 43, "lines_coords": [[[857.0, 1115.0], [898.0, 1115.0], [898.0, 1211.0], [857.0, 1211.0]], [[801.0, 1152.0], [840.0, 1152.0], [840.0, 1264.0], [801.0, 1264.0]]], "lines": ["でも", "っ！！"]}, {"box": [329, 1341, 473, 1372], "vertical": false, "font_size": 28, "lines_coords": [[[329.0, 1343.0], [473.0, 1341.0], [473.0, 1369.0], [329.0, 1372.0]]], "lines": ["河童捕獲"]}, {"box": [87, 1108, 207, 1271], "vertical": true, "font_size": 23, "lines_coords": [[[181.0, 1108.0], [206.0, 1108.0], [203.0, 1271.0], [179.0, 1271.0]], [[151.0, 1110.0], [174.0, 1110.0], [172.0, 1271.0], [149.0, 1271.0]], [[118.0, 1110.0], [142.0, 1110.0], [142.0, 1249.0], [118.0, 1249.0]], [[87.0, 1111.0], [108.0, 1111.0], [109.0, 1246.0], [88.0, 1246.0]]], "lines": ["でも、そういう", "些細なケンカが", "破局に繋がる", "かもでしょ？"]}], "img_path": "075.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [756, 87, 843, 250], "vertical": true, "font_size": 25, "lines_coords": [[[818.0, 87.0], [842.0, 87.0], [842.0, 232.0], [818.0, 232.0]], [[784.0, 87.0], [812.0, 87.0], [812.0, 250.0], [784.0, 250.0]], [[756.0, 87.0], [779.0, 87.0], [779.0, 180.0], [756.0, 180.0]]], "lines": ["じゃあ芽衣子、", "ゲーマーにでも", "なれば？"]}, {"box": [445, 102, 473, 139], "vertical": true, "font_size": 22, "lines_coords": [[[445.0, 105.0], [467.0, 102.0], [473.0, 136.0], [451.0, 139.0]]], "lines": ["ま、"]}, {"box": [296, 49, 397, 232], "vertical": true, "font_size": 22, "lines_coords": [[[374.0, 49.0], [397.0, 49.0], [397.0, 232.0], [374.0, 232.0]], [[349.0, 49.0], [373.0, 49.0], [373.0, 185.0], [349.0, 185.0]], [[326.0, 50.0], [345.0, 50.0], [345.0, 207.0], [326.0, 207.0]], [[296.0, 49.0], [319.0, 49.0], [322.0, 190.0], [299.0, 190.0]]], "lines": ["ゲームはともかく", "今、芽衣子は", "色々試してみる", "時期だろうし、"]}, {"box": [72, 241, 193, 429], "vertical": true, "font_size": 24, "lines_coords": [[[169.0, 244.0], [192.0, 244.0], [192.0, 360.0], [169.0, 360.0]], [[133.0, 241.0], [161.0, 241.0], [164.0, 429.0], [136.0, 429.0]], [[105.0, 246.0], [128.0, 246.0], [128.0, 407.0], [105.0, 407.0]], [[72.0, 244.0], [95.0, 244.0], [98.0, 427.0], [75.0, 427.0]]], "lines": ["よっぽどな", "きっかけがなきゃ", "今さら、お前ら", "別れないっしょ？"]}, {"box": [624, 422, 745, 608], "vertical": true, "font_size": 22, "lines_coords": [[[720.0, 423.0], [743.0, 423.0], [743.0, 585.0], [720.0, 585.0]], [[684.0, 422.0], [708.0, 422.0], [710.0, 563.0], [687.0, 563.0]], [[656.0, 426.0], [679.0, 426.0], [679.0, 608.0], [656.0, 608.0]], [[624.0, 425.0], [645.0, 425.0], [646.0, 572.0], [626.0, 572.0]]], "lines": ["それがなかなか", "才能と興味が", "一致するとは限ら", "ないらしいス。"]}, {"box": [150, 538, 209, 635], "vertical": true, "font_size": 24, "lines_coords": [[[184.0, 541.0], [209.0, 541.0], [209.0, 634.0], [184.0, 634.0]], [[150.0, 538.0], [179.0, 538.0], [181.0, 635.0], [153.0, 635.0]]], "lines": ["きっかけ", "ねぇ．．．．．．"]}, {"box": [184, 709, 269, 891], "vertical": true, "font_size": 24, "lines_coords": [[[246.0, 709.0], [269.0, 709.0], [269.0, 847.0], [246.0, 847.0]], [[214.0, 709.0], [237.0, 709.0], [237.0, 891.0], [214.0, 891.0]], [[184.0, 710.0], [203.0, 710.0], [203.0, 847.0], [184.0, 847.0]]], "lines": ["ちょっとずつ", "「その時」に近づい", "てるよね．．．"]}, {"box": [98, 1208, 143, 1267], "vertical": true, "font_size": 45, "lines_coords": [[[98.0, 1208.0], [143.0, 1208.0], [143.0, 1267.0], [98.0, 1267.0]]], "lines": ["あ。"]}], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [511, 116, 598, 278], "vertical": true, "font_size": 24, "lines_coords": [[[574.0, 117.0], [597.0, 117.0], [597.0, 236.0], [574.0, 236.0]], [[542.0, 116.0], [567.0, 116.0], [564.0, 278.0], [540.0, 278.0]], [[511.0, 118.0], [534.0, 118.0], [534.0, 278.0], [511.0, 278.0]]], "lines": ["．．．おーい", "今日２回目だよ", "このじいさん．．．"]}, {"box": [129, 251, 153, 344], "vertical": true, "font_size": 24, "lines_coords": [[[129.0, 251.0], [153.0, 251.0], [153.0, 344.0], [129.0, 344.0]]], "lines": ["．．．誰？"]}, {"box": [255, 393, 343, 575], "vertical": true, "font_size": 22, "lines_coords": [[[318.0, 395.0], [343.0, 395.0], [343.0, 522.0], [318.0, 522.0]], [[287.0, 393.0], [310.0, 393.0], [310.0, 575.0], [287.0, 575.0]], [[255.0, 393.0], [276.0, 393.0], [277.0, 518.0], [257.0, 518.0]]], "lines": ["多分近所に", "住んでるじいさん", "なんだけど、"]}, {"box": [124, 471, 232, 678], "vertical": true, "font_size": 22, "lines_coords": [[[209.0, 471.0], [232.0, 471.0], [232.0, 634.0], [209.0, 634.0]], [[180.0, 471.0], [203.0, 471.0], [203.0, 678.0], [180.0, 678.0]], [[153.0, 471.0], [172.0, 471.0], [169.0, 628.0], [150.0, 628.0]], [[124.0, 473.0], [143.0, 473.0], [143.0, 596.0], [124.0, 596.0]]], "lines": ["ボケてるらしく", "ウチのゲロちゃんを", "ボストと勘違い", "してんだよ。"]}, {"box": [844, 717, 899, 832], "vertical": true, "font_size": 23, "lines_coords": [[[874.0, 719.0], [899.0, 719.0], [899.0, 832.0], [874.0, 832.0]], [[844.0, 717.0], [868.0, 717.0], [868.0, 813.0], [844.0, 813.0]]], "lines": ["少なくとも", "週に１回"]}, {"box": [762, 858, 814, 983], "vertical": true, "font_size": 23, "lines_coords": [[[790.0, 858.0], [814.0, 858.0], [814.0, 952.0], [790.0, 952.0]], [[762.0, 864.0], [782.0, 864.0], [782.0, 983.0], [762.0, 983.0]]], "lines": ["多い時は", "１日何回も。"]}, {"box": [581, 881, 668, 1019], "vertical": true, "font_size": 24, "lines_coords": [[[643.0, 881.0], [668.0, 881.0], [668.0, 974.0], [643.0, 974.0]], [[612.0, 881.0], [635.0, 881.0], [635.0, 1019.0], [612.0, 1019.0]], [[581.0, 881.0], [604.0, 881.0], [604.0, 1003.0], [581.0, 1003.0]]], "lines": ["どこ宛の", "手紙なんだか", "しらないが、"]}, {"box": [429, 753, 490, 916], "vertical": true, "font_size": 25, "lines_coords": [[[463.0, 753.0], [490.0, 753.0], [488.0, 916.0], [460.0, 916.0]], [[433.0, 754.0], [458.0, 754.0], [453.0, 892.0], [429.0, 892.0]]], "lines": ["オイ、じーさん", "ポストなら．．．"]}, {"box": [427, 1008, 455, 1058], "vertical": true, "font_size": 25, "lines_coords": [[[427.0, 1011.0], [449.0, 1008.0], [455.0, 1055.0], [433.0, 1058.0]]], "lines": ["．．あ。"]}, {"box": [548, 1041, 637, 1225], "vertical": true, "font_size": 24, "lines_coords": [[[609.0, 1041.0], [637.0, 1041.0], [637.0, 1192.0], [609.0, 1192.0]], [[579.0, 1063.0], [602.0, 1063.0], [602.0, 1203.0], [579.0, 1203.0]], [[548.0, 1065.0], [571.0, 1065.0], [571.0, 1225.0], [548.0, 1225.0]]], "lines": ["その度俺が", "ポストの場所", "教えてんだぜ？"]}, {"box": [139, 1209, 199, 1244], "vertical": false, "font_size": 15, "lines_coords": [[[143.0, 1209.0], [199.0, 1230.0], [195.0, 1244.0], [139.0, 1223.0]]], "lines": ["ダイエットのかわかりやりやすい"]}, {"box": [114, 1208, 240, 1289], "vertical": false, "font_size": 22.0, "lines_coords": [[[123.0, 1227.0], [221.0, 1272.0], [213.0, 1289.0], [116.0, 1244.0]], [[184.0, 1246.0], [229.0, 1266.0], [225.0, 1276.0], [180.0, 1257.0]], [[128.0, 1208.0], [240.0, 1253.0], [226.0, 1286.0], [114.0, 1241.0]]], "lines": ["だから、ありがとうございますからなければならなかったのですが、", "いいやいや．．．やめやがなんだから", "やっぱりあったんですが．．．"]}, {"box": [109, 1250, 135, 1270], "vertical": false, "font_size": 12, "lines_coords": [[[113.0, 1250.0], [135.0, 1259.0], [131.0, 1270.0], [109.0, 1261.0]]], "lines": ["．．．"]}], "img_path": "077.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [847, 86, 872, 247], "vertical": true, "font_size": 23, "lines_coords": [[[847.0, 86.0], [870.0, 86.0], [870.0, 244.0], [847.0, 244.0]]], "lines": ["おっとっと．．．"]}, {"box": [607, 135, 630, 228], "vertical": true, "font_size": 22, "lines_coords": [[[607.0, 135.0], [630.0, 135.0], [630.0, 228.0], [607.0, 228.0]]], "lines": ["．．．んん？"]}, {"box": [462, 183, 578, 396], "vertical": true, "font_size": 22, "lines_coords": [[[555.0, 183.0], [578.0, 183.0], [578.0, 396.0], [555.0, 396.0]], [[522.0, 184.0], [545.0, 184.0], [545.0, 369.0], [522.0, 369.0]], [[490.0, 187.0], [514.0, 187.0], [514.0, 302.0], [490.0, 302.0]], [[462.0, 188.0], [481.0, 188.0], [481.0, 322.0], [462.0, 322.0]]], "lines": ["じーさん、この手紙", "宛先と差し出しが", "同じ住所に", "なってるぜ？"]}, {"box": [121, 123, 176, 261], "vertical": true, "font_size": 21, "lines_coords": [[[151.0, 123.0], [174.0, 123.0], [174.0, 261.0], [151.0, 261.0]], [[123.0, 124.0], [142.0, 124.0], [142.0, 236.0], [123.0, 236.0]]], "lines": ["これ、なんの", "手紙だよ？"]}, {"box": [828, 545, 855, 624], "vertical": true, "font_size": 24, "lines_coords": [[[828.0, 545.0], [854.0, 545.0], [855.0, 624.0], [829.0, 624.0]]], "lines": ["．．．あぁ、"]}, {"box": [732, 631, 818, 782], "vertical": true, "font_size": 24, "lines_coords": [[[795.0, 631.0], [818.0, 631.0], [818.0, 773.0], [795.0, 773.0]], [[764.0, 634.0], [788.0, 634.0], [786.0, 772.0], [761.0, 772.0]], [[732.0, 635.0], [756.0, 635.0], [756.0, 782.0], [732.0, 782.0]]], "lines": ["それはウチの", "ばあさん宛の", "手紙ですから。"]}, {"box": [809, 880, 888, 994], "vertical": true, "font_size": 22, "lines_coords": [[[864.0, 880.0], [888.0, 880.0], [888.0, 952.0], [864.0, 952.0]], [[833.0, 880.0], [857.0, 880.0], [857.0, 987.0], [833.0, 987.0]], [[809.0, 883.0], [828.0, 883.0], [828.0, 992.0], [809.0, 992.0]]], "lines": ["．．．．．．な", "やっぱ相当", "キてるだろ"]}, {"box": [479, 875, 504, 967], "vertical": true, "font_size": 23, "lines_coords": [[[479.0, 875.0], [504.0, 875.0], [504.0, 967.0], [479.0, 967.0]]], "lines": ["．．．あの．．．"]}, {"box": [373, 932, 458, 1096], "vertical": true, "font_size": 23, "lines_coords": [[[432.0, 932.0], [456.0, 932.0], [458.0, 1096.0], [433.0, 1096.0]], [[401.0, 935.0], [425.0, 935.0], [425.0, 1052.0], [401.0, 1052.0]], [[373.0, 939.0], [393.0, 939.0], [393.0, 983.0], [373.0, 983.0]]], "lines": ["その奥さんって", "もしかして", "．．．"]}, {"box": [117, 618, 237, 805], "vertical": true, "font_size": 23, "lines_coords": [[[211.0, 619.0], [235.0, 619.0], [235.0, 732.0], [211.0, 732.0]], [[180.0, 619.0], [205.0, 619.0], [205.0, 751.0], [180.0, 751.0]], [[149.0, 619.0], [172.0, 619.0], [172.0, 805.0], [149.0, 805.0]], [[118.0, 623.0], [138.0, 623.0], [138.0, 788.0], [118.0, 788.0]]], "lines": ["私の今日の", "出来事を逐一", "報告してやらんと", "いかんですから。"]}, {"box": [777, 1178, 865, 1324], "vertical": true, "font_size": 24, "lines_coords": [[[840.0, 1178.0], [865.0, 1178.0], [865.0, 1294.0], [840.0, 1294.0]], [[810.0, 1178.0], [833.0, 1178.0], [833.0, 1294.0], [810.0, 1294.0]], [[777.0, 1178.0], [802.0, 1178.0], [803.0, 1324.0], [779.0, 1324.0]]], "lines": ["えぇ、もう", "とうの昔に", "死んどります。"]}, {"box": [658, 1164, 746, 1371], "vertical": true, "font_size": 24, "lines_coords": [[[723.0, 1164.0], [746.0, 1164.0], [746.0, 1285.0], [723.0, 1285.0]], [[691.0, 1164.0], [715.0, 1164.0], [715.0, 1326.0], [691.0, 1326.0]], [[658.0, 1164.0], [682.0, 1164.0], [683.0, 1371.0], [660.0, 1371.0]]], "lines": ["まだ若い頃、", "この辺は空襲が", "ひどかったものでね。"]}, {"box": [150, 991, 241, 1133], "vertical": true, "font_size": 24, "lines_coords": [[[218.0, 993.0], [241.0, 993.0], [241.0, 1132.0], [218.0, 1132.0]], [[187.0, 993.0], [210.0, 993.0], [210.0, 1133.0], [187.0, 1133.0]], [[150.0, 992.0], [179.0, 991.0], [181.0, 1074.0], [153.0, 1075.0]]], "lines": ["もう何十年も", "待たせてます", "もんで。"]}, {"box": [129, 1179, 216, 1365], "vertical": true, "font_size": 24, "lines_coords": [[[191.0, 1179.0], [216.0, 1179.0], [216.0, 1275.0], [191.0, 1275.0]], [[161.0, 1179.0], [184.0, 1179.0], [184.0, 1365.0], [161.0, 1365.0]], [[129.0, 1181.0], [153.0, 1181.0], [153.0, 1331.0], [129.0, 1331.0]]], "lines": ["むこうで", "きっと退屈してる", "でしょうから。"]}], "img_path": "078.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [760, 169, 779, 262], "vertical": true, "font_size": 20, "lines_coords": [[[760.0, 169.0], [779.0, 169.0], [779.0, 262.0], [760.0, 262.0]]], "lines": ["．．．それに"]}, {"box": [622, 229, 701, 404], "vertical": true, "font_size": 20, "lines_coords": [[[674.0, 229.0], [701.0, 229.0], [701.0, 370.0], [674.0, 370.0]], [[649.0, 231.0], [668.0, 231.0], [668.0, 375.0], [649.0, 375.0]], [[622.0, 232.0], [639.0, 232.0], [639.0, 404.0], [622.0, 404.0]]], "lines": ["私ももう年で", "きのうのことも", "よく憶えてません。"]}, {"box": [340, 637, 363, 738], "vertical": true, "font_size": 22, "lines_coords": [[[340.0, 637.0], [363.0, 637.0], [363.0, 738.0], [340.0, 738.0]]], "lines": ["．．．．．．まぁ、"]}, {"box": [211, 276, 323, 486], "vertical": true, "font_size": 23, "lines_coords": [[[299.0, 277.0], [322.0, 277.0], [322.0, 403.0], [299.0, 403.0]], [[270.0, 276.0], [293.0, 276.0], [293.0, 486.0], [270.0, 486.0]], [[240.0, 277.0], [263.0, 277.0], [263.0, 445.0], [240.0, 445.0]], [[211.0, 276.0], [235.0, 276.0], [237.0, 453.0], [214.0, 453.0]]], "lines": ["手紙が届くと", "ぱあさんが私のことを", "憶えてくれている", "気持ちになります。"]}, {"box": [814, 896, 902, 1103], "vertical": true, "font_size": 24, "lines_coords": [[[880.0, 899.0], [899.0, 899.0], [899.0, 1103.0], [880.0, 1103.0]], [[844.0, 896.0], [872.0, 896.0], [872.0, 1060.0], [844.0, 1060.0]], [[814.0, 899.0], [839.0, 899.0], [839.0, 991.0], [814.0, 991.0]]], "lines": ["あのおじいちゃんは", "今、幸せなんだ", "ろーか？"]}, {"box": [633, 924, 652, 1002], "vertical": true, "font_size": 23, "lines_coords": [[[633.0, 924.0], [652.0, 924.0], [652.0, 1002.0], [633.0, 1002.0]]], "lines": ["さあな。"]}, {"box": [503, 958, 591, 1119], "vertical": true, "font_size": 23, "lines_coords": [[[568.0, 958.0], [591.0, 958.0], [591.0, 1119.0], [568.0, 1119.0]], [[534.0, 958.0], [561.0, 958.0], [561.0, 1099.0], [534.0, 1099.0]], [[503.0, 958.0], [527.0, 958.0], [529.0, 1059.0], [504.0, 1059.0]]], "lines": ["そればっかりは", "本人に聞いて", "みないと。"]}, {"box": [209, 687, 293, 850], "vertical": true, "font_size": 22, "lines_coords": [[[270.0, 687.0], [293.0, 687.0], [293.0, 850.0], [270.0, 850.0]], [[239.0, 689.0], [262.0, 689.0], [262.0, 827.0], [239.0, 827.0]], [[209.0, 690.0], [228.0, 690.0], [228.0, 836.0], [209.0, 836.0]]], "lines": ["まだらボケって", "言っちゃえば", "それまでだが。"]}, {"box": [187, 1065, 306, 1270], "vertical": true, "font_size": 22, "lines_coords": [[[283.0, 1065.0], [306.0, 1065.0], [306.0, 1259.0], [283.0, 1259.0]], [[250.0, 1066.0], [273.0, 1066.0], [273.0, 1248.0], [250.0, 1248.0]], [[220.0, 1066.0], [239.0, 1066.0], [239.0, 1270.0], [220.0, 1270.0]], [[187.0, 1065.0], [210.0, 1065.0], [210.0, 1259.0], [187.0, 1259.0]]], "lines": ["でもあんなふうに", "いつまでも大切に", "想える人がいるって", "すごいことだよね。"]}, {"box": [113, 1231, 139, 1316], "vertical": true, "font_size": 23, "lines_coords": [[[113.0, 1231.0], [136.0, 1231.0], [136.0, 1312.0], [113.0, 1312.0]]], "lines": ["そうな。"]}], "img_path": "079.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [747, 91, 865, 298], "vertical": true, "font_size": 22, "lines_coords": [[[842.0, 91.0], [865.0, 91.0], [865.0, 259.0], [842.0, 259.0]], [[810.0, 92.0], [833.0, 92.0], [833.0, 298.0], [810.0, 298.0]], [[779.0, 92.0], [802.0, 92.0], [802.0, 298.0], [779.0, 298.0]], [[747.0, 91.0], [771.0, 91.0], [771.0, 231.0], [747.0, 231.0]]], "lines": ["ところで芽衣子、", "わざわざこっちまで", "飯食いに来た訳じゃ", "ないんだろ？"]}, {"box": [702, 206, 720, 363], "vertical": true, "font_size": 22, "lines_coords": [[[702.0, 206.0], [720.0, 206.0], [720.0, 363.0], [702.0, 363.0]]], "lines": ["なんの用だよ？"]}, {"box": [508, 73, 627, 216], "vertical": true, "font_size": 28, "lines_coords": [[[600.0, 73.0], [627.0, 73.0], [627.0, 216.0], [600.0, 216.0]], [[570.0, 77.0], [593.0, 77.0], [593.0, 192.0], [570.0, 192.0]], [[538.0, 76.0], [561.0, 76.0], [559.0, 216.0], [535.0, 216.0]], [[508.0, 79.0], [527.0, 79.0], [527.0, 192.0], [508.0, 192.0]]], "lines": ["今朝、種田が", "頭痛いって", "言ってたから", "頭痛薬を．．．"]}, {"box": [459, 214, 509, 356], "vertical": true, "font_size": 28, "lines_coords": [[[459.0, 216.0], [507.0, 214.0], [509.0, 355.0], [462.0, 356.0]]], "lines": ["くれ！！"]}, {"box": [92, 54, 218, 73], "vertical": false, "font_size": 19, "lines_coords": [[[92.0, 54.0], [218.0, 54.0], [218.0, 73.0], [92.0, 73.0]]], "lines": ["ソラニン［"]}, {"box": [814, 634, 839, 728], "vertical": true, "font_size": 24, "lines_coords": [[[814.0, 634.0], [839.0, 634.0], [839.0, 728.0], [814.0, 728.0]]], "lines": ["それと．．．"]}, {"box": [64, 355, 181, 493], "vertical": true, "font_size": 23, "lines_coords": [[[157.0, 355.0], [180.0, 355.0], [180.0, 470.0], [157.0, 470.0]], [[124.0, 355.0], [149.0, 355.0], [146.0, 493.0], [121.0, 493.0]], [[92.0, 355.0], [116.0, 355.0], [116.0, 493.0], [92.0, 493.0]], [[64.0, 356.0], [83.0, 356.0], [83.0, 478.0], [64.0, 478.0]]], "lines": ["お前らって", "ホント昔から", "ケンカ長続き", "しないよな。"]}, {"box": [805, 799, 859, 916], "vertical": true, "font_size": 24, "lines_coords": [[[835.0, 799.0], [859.0, 799.0], [859.0, 892.0], [835.0, 892.0]], [[805.0, 802.0], [829.0, 802.0], [829.0, 916.0], [805.0, 916.0]]], "lines": ["ビリーは", "今、幸せ？"]}, {"box": [140, 916, 233, 1067], "vertical": true, "font_size": 25, "lines_coords": [[[199.0, 916.0], [233.0, 916.0], [233.0, 993.0], [199.0, 993.0]], [[173.0, 918.0], [196.0, 918.0], [196.0, 1058.0], [173.0, 1058.0]], [[140.0, 918.0], [164.0, 918.0], [165.0, 1067.0], [142.0, 1067.0]]], "lines": ["．．．今が", "どーかなんて", "わかんねぇよ。"]}, {"box": [608, 1136, 699, 1233], "vertical": true, "font_size": 27, "lines_coords": [[[671.0, 1137.0], [699.0, 1137.0], [699.0, 1233.0], [671.0, 1233.0]], [[641.0, 1137.0], [665.0, 1137.0], [665.0, 1230.0], [641.0, 1230.0]], [[608.0, 1136.0], [637.0, 1136.0], [637.0, 1220.0], [608.0, 1220.0]]], "lines": ["．．．．．って", "聞こうと", "思って。"]}, {"box": [112, 1115, 202, 1298], "vertical": true, "font_size": 25, "lines_coords": [[[179.0, 1115.0], [202.0, 1115.0], [202.0, 1275.0], [179.0, 1275.0]], [[146.0, 1115.0], [170.0, 1115.0], [170.0, 1208.0], [146.0, 1208.0]], [[112.0, 1115.0], [135.0, 1115.0], [135.0, 1298.0], [112.0, 1298.0]]], "lines": ["そういうのって", "死ぬ時に", "わかるんじゃん？"]}], "img_path": "080.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [772, 79, 891, 240], "vertical": true, "font_size": 23, "lines_coords": [[[868.0, 79.0], [891.0, 79.0], [890.0, 240.0], [866.0, 240.0]], [[835.0, 80.0], [859.0, 80.0], [859.0, 206.0], [835.0, 206.0]], [[803.0, 80.0], [827.0, 80.0], [827.0, 217.0], [803.0, 217.0]], [[773.0, 80.0], [794.0, 80.0], [792.0, 216.0], [772.0, 216.0]]], "lines": ["じゃあビリーは", "今死んだら", "自分の人生に", "納得できる？"]}, {"box": [717, 229, 773, 391], "vertical": true, "font_size": 23, "lines_coords": [[[750.0, 229.0], [773.0, 229.0], [773.0, 391.0], [750.0, 391.0]], [[717.0, 231.0], [741.0, 231.0], [741.0, 347.0], [717.0, 347.0]]], "lines": ["ビリーにとって", "人生は何？"]}, {"box": [198, 270, 221, 384], "vertical": true, "font_size": 23, "lines_coords": [[[198.0, 270.0], [221.0, 270.0], [221.0, 384.0], [198.0, 384.0]]], "lines": ["お前なぁ．．．"]}, {"box": [114, 447, 233, 628], "vertical": true, "font_size": 23, "lines_coords": [[[209.0, 447.0], [233.0, 447.0], [233.0, 541.0], [209.0, 541.0]], [[177.0, 448.0], [202.0, 448.0], [202.0, 564.0], [177.0, 564.0]], [[144.0, 447.0], [168.0, 447.0], [169.0, 628.0], [146.0, 628.0]], [[116.0, 447.0], [136.0, 447.0], [135.0, 583.0], [114.0, 583.0]]], "lines": ["ビリーは", "今の生活で", "満たされてるって", "言いきれる！？"]}, {"box": [803, 776, 891, 902], "vertical": true, "font_size": 24, "lines_coords": [[[866.0, 777.0], [891.0, 777.0], [891.0, 890.0], [866.0, 890.0]], [[836.0, 779.0], [861.0, 779.0], [861.0, 891.0], [836.0, 891.0]], [[803.0, 776.0], [827.0, 776.0], [829.0, 902.0], [806.0, 902.0]]], "lines": ["．．．芽衣子の", "今の俺への", "質問ってさ、"]}, {"box": [792, 961, 879, 1088], "vertical": true, "font_size": 24, "lines_coords": [[[855.0, 961.0], [879.0, 961.0], [876.0, 1075.0], [853.0, 1075.0]], [[824.0, 961.0], [847.0, 961.0], [847.0, 1088.0], [824.0, 1088.0]], [[792.0, 962.0], [816.0, 962.0], [816.0, 1077.0], [792.0, 1077.0]]], "lines": ["お前自身が", "今抱えてる", "疑問だろ？"]}, {"box": [538, 865, 593, 1025], "vertical": true, "font_size": 19, "lines_coords": [[[571.0, 866.0], [590.0, 866.0], [590.0, 1024.0], [571.0, 1024.0]], [[540.0, 866.0], [559.0, 866.0], [559.0, 1013.0], [540.0, 1013.0]]], "lines": ["んな難しいこと", "俺に聞くなよ。"]}, {"box": [220, 849, 244, 969], "vertical": true, "font_size": 24, "lines_coords": [[[220.0, 849.0], [244.0, 849.0], [244.0, 969.0], [220.0, 969.0]]], "lines": ["少なくとも、"]}, {"box": [103, 896, 191, 1060], "vertical": true, "font_size": 24, "lines_coords": [[[168.0, 896.0], [191.0, 896.0], [191.0, 1036.0], [168.0, 1036.0]], [[133.0, 896.0], [157.0, 896.0], [159.0, 1060.0], [136.0, 1060.0]], [[103.0, 896.0], [127.0, 896.0], [128.0, 1058.0], [105.0, 1058.0]]], "lines": ["俺じゃなくて", "種田と話すべき", "なんじゃねぇ？"]}, {"box": [542, 1110, 568, 1239], "vertical": true, "font_size": 24, "lines_coords": [[[542.0, 1110.0], [567.0, 1110.0], [568.0, 1238.0], [544.0, 1238.0]]], "lines": ["．．．だよねー。"]}, {"box": [80, 1186, 166, 1326], "vertical": true, "font_size": 21, "lines_coords": [[[140.0, 1186.0], [166.0, 1186.0], [166.0, 1230.0], [140.0, 1230.0]], [[110.0, 1188.0], [133.0, 1188.0], [133.0, 1326.0], [110.0, 1326.0]], [[80.0, 1188.0], [103.0, 1188.0], [103.0, 1304.0], [80.0, 1304.0]]], "lines": ["おー", "芽衣子ちゃん", "久しぶりー"]}, {"box": [83, 1263, 166, 1343], "vertical": true, "font_size": 21, "lines_coords": [[[146.0, 1263.0], [166.0, 1263.0], [166.0, 1298.0], [146.0, 1298.0]], [[83.0, 1297.0], [98.0, 1297.0], [98.0, 1343.0], [83.0, 1343.0]]], "lines": ["ーっ", "！！"]}], "img_path": "081.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [472, 98, 589, 236], "vertical": true, "font_size": 21, "lines_coords": [[[564.0, 101.0], [589.0, 101.0], [589.0, 216.0], [564.0, 216.0]], [[534.0, 98.0], [557.0, 98.0], [557.0, 235.0], [534.0, 235.0]], [[501.0, 98.0], [524.0, 98.0], [524.0, 235.0], [501.0, 235.0]], [[474.0, 99.0], [493.0, 99.0], [493.0, 183.0], [474.0, 183.0]], [[475.0, 183.0], [490.0, 183.0], [490.0, 232.0], [475.0, 232.0]]], "lines": ["いやぁ～～", "見ないうちに", "またキレイに", "なってー", "！！"]}, {"box": [295, 41, 402, 200], "vertical": true, "font_size": 23, "lines_coords": [[[377.0, 41.0], [401.0, 41.0], [399.0, 184.0], [374.0, 184.0]], [[351.0, 42.0], [371.0, 42.0], [370.0, 177.0], [349.0, 177.0]], [[322.0, 42.0], [345.0, 42.0], [345.0, 179.0], [322.0, 179.0]], [[295.0, 42.0], [318.0, 42.0], [318.0, 200.0], [295.0, 200.0]]], "lines": ["芽衣子ちゃん、", "早くコイツに", "彼女紹介して", "やってよー！！"]}, {"box": [92, 246, 246, 407], "vertical": true, "font_size": 23, "lines_coords": [[[222.0, 247.0], [246.0, 247.0], [246.0, 340.0], [222.0, 340.0]], [[191.0, 247.0], [214.0, 247.0], [214.0, 407.0], [191.0, 407.0]], [[158.0, 247.0], [181.0, 247.0], [181.0, 385.0], [158.0, 385.0]], [[127.0, 247.0], [150.0, 247.0], [150.0, 363.0], [127.0, 363.0]], [[92.0, 246.0], [116.0, 246.0], [118.0, 373.0], [95.0, 373.0]]], "lines": ["もちろん", "芽衣子ちゃんが", "嫁に来るなら", "俺、万万歳", "なんだけど。"]}, {"box": [823, 358, 902, 499], "vertical": true, "font_size": 22, "lines_coords": [[[873.0, 358.0], [902.0, 358.0], [902.0, 447.0], [873.0, 447.0]], [[850.0, 359.0], [873.0, 359.0], [873.0, 499.0], [850.0, 499.0]], [[823.0, 359.0], [846.0, 359.0], [846.0, 477.0], [823.0, 477.0]]], "lines": ["やだもー", "もっと言って", "ください！！"]}, {"box": [788, 434, 896, 550], "vertical": true, "font_size": 22, "lines_coords": [[[881.0, 455.0], [896.0, 455.0], [896.0, 490.0], [881.0, 490.0]], [[791.0, 434.0], [812.0, 434.0], [809.0, 550.0], [788.0, 550.0]]], "lines": ["ー", "オジさんも"]}, {"box": [735, 436, 783, 596], "vertical": true, "font_size": 22, "lines_coords": [[[764.0, 437.0], [783.0, 437.0], [783.0, 550.0], [764.0, 550.0]], [[735.0, 436.0], [758.0, 436.0], [758.0, 596.0], [735.0, 596.0]]], "lines": ["相変わらず", "輝いてますよ！！"]}, {"box": [452, 376, 494, 540], "vertical": true, "font_size": 38, "lines_coords": [[[456.0, 378.0], [494.0, 380.0], [490.0, 540.0], [452.0, 538.0]]], "lines": ["あぁっはっは"]}, {"box": [79, 458, 200, 625], "vertical": true, "font_size": 24, "lines_coords": [[[174.0, 462.0], [198.0, 462.0], [200.0, 624.0], [177.0, 624.0]], [[144.0, 460.0], [168.0, 460.0], [168.0, 574.0], [144.0, 574.0]], [[112.0, 462.0], [136.0, 462.0], [136.0, 563.0], [112.0, 563.0]], [[79.0, 458.0], [103.0, 458.0], [105.0, 585.0], [80.0, 585.0]]], "lines": ["いやぁ無理っす、", "こんなエセ", "ロッカー。", "体毛濃いし。"]}, {"box": [710, 700, 818, 826], "vertical": true, "font_size": 32, "lines_coords": [[[782.0, 701.0], [818.0, 701.0], [818.0, 775.0], [782.0, 775.0]], [[742.0, 701.0], [779.0, 700.0], [782.0, 773.0], [745.0, 775.0]], [[712.0, 706.0], [736.0, 706.0], [736.0, 825.0], [712.0, 825.0]]], "lines": ["人生、", "生活、", "俺の役割。"]}, {"box": [241, 812, 319, 887], "vertical": true, "font_size": 40, "lines_coords": [[[277.0, 812.0], [319.0, 812.0], [319.0, 864.0], [277.0, 864.0]], [[241.0, 813.0], [