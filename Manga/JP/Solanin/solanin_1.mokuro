]], [[743.0, 1177.0], [772.0, 1177.0], [772.0, 1338.0], [743.0, 1338.0]]], "lines": ["そっち", "行ったぜ！！"]}, {"box": [378, 1203, 403, 1310], "vertical": true, "font_size": 23, "lines_coords": [[[378.0, 1203.0], [401.0, 1203.0], [401.0, 1309.0], [378.0, 1309.0]]], "lines": ["おうよ！！"]}, {"box": [139, 991, 225, 1171], "vertical": true, "font_size": 23, "lines_coords": [[[202.0, 991.0], [225.0, 991.0], [225.0, 1129.0], [202.0, 1129.0]], [[170.0, 991.0], [194.0, 991.0], [194.0, 1171.0], [170.0, 1171.0]], [[139.0, 991.0], [162.0, 991.0], [162.0, 1127.0], [139.0, 1127.0]]], "lines": ["こんな幸せを", "あたしはあと何回", "感じることが"]}, {"box": [108, 984, 228, 1173], "vertical": true, "font_size": 23, "lines_coords": [[[108.0, 989.0], [131.0, 989.0], [131.0, 1173.0], [108.0, 1173.0]]], "lines": ["できるんだろう？"]}], "img_path": "150.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [721, 515, 780, 707], "vertical": true, "font_size": 24, "lines_coords": [[[753.0, 515.0], [777.0, 515.0], [780.0, 631.0], [756.0, 631.0]], [[721.0, 515.0], [745.0, 515.0], [747.0, 706.0], [724.0, 706.0]]], "lines": ["種田だって", "わかってるはずだ。"]}, {"box": [509, 514, 631, 710], "vertical": true, "font_size": 24, "lines_coords": [[[604.0, 515.0], [627.0, 515.0], [631.0, 676.0], [608.0, 676.0]], [[572.0, 516.0], [597.0, 516.0], [598.0, 700.0], [574.0, 700.0]], [[541.0, 515.0], [568.0, 515.0], [568.0, 678.0], [541.0, 678.0]], [[509.0, 516.0], [533.0, 516.0], [534.0, 710.0], [511.0, 710.0]]], "lines": ["今、この瞬間は", "いろんな現実から", "目を背けた上に", "なりたってること。"]}, {"box": [209, 515, 362, 687], "vertical": true, "font_size": 24, "lines_coords": [[[337.0, 515.0], [360.0, 515.0], [360.0, 630.0], [337.0, 630.0]], [[306.0, 515.0], [329.0, 515.0], [329.0, 653.0], [306.0, 653.0]], [[273.0, 515.0], [298.0, 515.0], [298.0, 631.0], [273.0, 631.0]], [[239.0, 516.0], [266.0, 516.0], [266.0, 657.0], [239.0, 657.0]], [[209.0, 515.0], [232.0, 515.0], [233.0, 686.0], [210.0, 686.0]]], "lines": ["これからは", "どんな些細な", "チャンスも", "決して