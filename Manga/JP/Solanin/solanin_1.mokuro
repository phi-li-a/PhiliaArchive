.0, 273.0], [808.0, 273.0]], [[772.0, 90.0], [799.0, 90.0], [802.0, 254.0], [775.0, 254.0]], [[743.0, 94.0], [766.0, 94.0], [766.0, 252.0], [743.0, 252.0]], [[712.0, 94.0], [735.0, 94.0], [735.0, 216.0], [712.0, 216.0]]], "lines": ["そして、やっぱり", "あたしも夢とは", "気づかなかった", "のだけれど。"]}, {"box": [532, 177, 551, 288], "vertical": true, "font_size": 17, "lines_coords": [[[533.0, 177.0], [550.0, 177.0], [550.0, 288.0], [533.0, 288.0]]], "lines": ["ＲＲＲＰＲ"]}, {"box": [176, 224, 204, 381], "vertical": true, "font_size": 27, "lines_coords": [[[176.0, 224.0], [203.0, 224.0], [203.0, 381.0], [176.0, 381.0]]], "lines": ["ＲＲＲＰＲ"]}, {"box": [798, 471, 820, 596], "vertical": true, "font_size": 19, "lines_coords": [[[798.0, 512.0], [817.0, 512.0], [817.0, 591.0], [798.0, 591.0]]], "lines": ["．．．うん"]}, {"box": [639, 329, 658, 393], "vertical": true, "font_size": 19, "lines_coords": [[[639.0, 329.0], [658.0, 329.0], [658.0, 393.0], [639.0, 393.0]]], "lines": ["ＲＲＲＰ"]}, {"box": [782, 803, 838, 940], "vertical": true, "font_size": 26, "lines_coords": [[[813.0, 803.0], [838.0, 803.0], [838.0, 896.0], [813.0, 896.0]], [[782.0, 803.0], [805.0, 803.0], [805.0, 940.0], [782.0, 940.0]]], "lines": ["どんだけ", "心配したか？"]}, {"box": [649, 880, 739, 1022], "vertical": true, "font_size": 26, "lines_coords": [[[709.0, 880.0], [739.0, 880.0], [739.0, 963.0], [709.0, 963.0]], [[679.0, 880.0], [706.0, 880.0], [706.0, 1022.0], [679.0, 1022.0]], [[649.0, 884.0], [672.0, 884.0], [672.0, 977.0], [649.0, 977.0]]], "lines": ["．．．いや、", "「へへへ」じゃ", "なくて！！"]}, {"box": [535, 806, 568, 911], "vertical": true, "font_size": 26, "lines_coords": [[[535.0, 806.0], [566.0, 806.0], [568.0, 911.0], [538.0, 911.0]]], "lines": ["あ、ホラ、"]}, {"box": [422, 876, 507, 995], "vertical": true, "font_size": 26, "lines_coords": [[[482.0, 876.0], [507.0, 876.0], [507.0, 973.0], [482.0, 973.0]], [[448.0, 880.0], [478.0, 880.0], [478.0, 955.0], [448.0, 955.0]], [[422.0, 883.0], [441.0, 883.0], [441.0, 995.0], [422.0, 995.0]]], "lines": ["ちょうど", "芽衣