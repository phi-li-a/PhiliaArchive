[113.0, 609.0]]], "lines": ["なかなか", "生意気じゃ", "ねーか！！"]}, {"box": [760, 720, 850, 862], "vertical": true, "font_size": 27, "lines_coords": [[[827.0, 727.0], [850.0, 727.0], [850.0, 862.0], [827.0, 862.0]], [[792.0, 724.0], [820.0, 724.0], [820.0, 862.0], [792.0, 862.0]], [[760.0, 720.0], [791.0, 720.0], [791.0, 786.0], [760.0, 786.0]]], "lines": ["コレ、入部届", "持ってきたん", "です。"]}, {"box": [628, 802, 749, 963], "vertical": true, "font_size": 24, "lines_coords": [[[721.0, 802.0], [747.0, 802.0], [749.0, 913.0], [723.0, 913.0]], [[691.0, 803.0], [715.0, 803.0], [715.0, 940.0], [691.0, 940.0]], [[660.0, 803.0], [683.0, 803.0], [683.0, 963.0], [660.0, 963.0]], [[628.0, 803.0], [653.0, 803.0], [653.0, 883.0], [628.0, 883.0]]], "lines": ["あーー俺、", "もうＯＢ扱い", "だから他の奴に", "渡して。"]}, {"box": [224, 762, 281, 921], "vertical": true, "font_size": 24, "lines_coords": [[[255.0, 762.0], [280.0, 762.0], [280.0, 879.0], [255.0, 879.0]], [[224.0, 762.0], [247.0, 762.0], [247.0, 921.0], [224.0, 921.0]]], "lines": ["．．．先輩、今", "何年なんすか？"]}, {"box": [147, 885, 171, 988], "vertical": true, "font_size": 23, "lines_coords": [[[147.0, 888.0], [170.0, 888.0], [170.0, 987.0], [147.0, 987.0]]], "lines": ["．．．．．．６年。"]}, {"box": [163, 1144, 217, 1268], "vertical": true, "font_size": 22, "lines_coords": [[[192.0, 1144.0], [217.0, 1144.0], [217.0, 1215.0], [192.0, 1215.0]], [[164.0, 1145.0], [183.0, 1145.0], [183.0, 1267.0], [164.0, 1267.0]]], "lines": ["あはは", "終わってる。"]}], "img_path": "088.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [735, 57, 865, 428], "vertical": true, "font_size": 80, "lines_coords": [[[756.0, 113.0], [835.0, 114.0], [831.0, 315.0], [751.0, 314.0]]], "lines": ["ぐふっ"]}, {"box": [764, 631, 857, 776], "vertical": true, "font_size": 26, "lines_coords": [[[764.0, 682.0], [788.0, 682.0], [788.0, 738.0], [764.0, 738.0]], [[820.0, 631.0], [857.0, 631.0], [857.0, 691.0], [820.0, 691.0]], [[794.0, 635.0], [821.0, 635.0], [821.0, 776.0], [794.0, 776.0]], [[765.0, 637.0], [788.0, 637.0], [788.0, 682.0], [765.0, 682.0]]], "lines": ["す。", "先輩", "おつかれさん", "てー"]}, {"box": [812, 829, 898, 967], "vertical": true, "font_size": 26, "lines_coords": [[[874.0, 832.0], [898.0, 832.0], [898.0, 924.0], [874.0, 924.0]], [[843.0, 829.0], [866.0, 829.0], [866.0, 967.0], [843.0, 967.0]], [[812.0, 829.0], [835.0, 829.0], [835.0, 967.0], [812.0, 967.0]]], "lines": ["みんなで", "飲み行くけど", "どーします？"]}, {"box": [533, 1166, 624, 1302], "vertical": true, "font_size": 25, "lines_coords": [[[600.0, 1167.0], [623.0, 1167.0], [623.0, 1302.0], [600.0, 1302.0]], [[567.0, 1168.0], [590.0, 1168.0], [590.0, 1281.0], [567.0, 1281.0]], [[533.0, 1166.0], [563.0, 1166.0], [563.0, 1249.0], [533.0, 1249.0]]], "lines": ["あはは、ソレ", "おもしろい", "ですね。"]}, {"box": [120, 1158, 148, 1263], "vertical": true, "font_size": 24, "lines_coords": [[[120.0, 1160.0], [144.0, 1160.0], [147.0, 1263.0], [123.0, 1263.0]]], "lines": ["．．．．．．先輩。"]}], "img_path": "089.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [776, 82, 834, 246], "vertical": true, "font_size": 24, "lines_coords": [[[810.0, 84.0], [833.0, 84.0], [833.0, 246.0], [810.0, 246.0]], [[779.0, 82.0], [803.0, 82.0], [801.0, 207.0], [776.0, 207.0]]], "lines": ["飲み連れてって", "くださいよ。"]}, {"box": [519, 102, 573, 220], "vertical": true, "font_size": 23, "lines_coords": [[[549.0, 105.0], [572.0, 105.0], [572.0, 220.0], [549.0, 220.0]], [[519.0, 102.0], [542.0, 102.0], [542.0, 194.0], [519.0, 194.0]]], "lines": ["．．．みんなと", "行けば？"]}, {"box": [91, 109, 148, 235], "vertical": true, "font_size": 23, "lines_coords": [[[123.0, 110.0], [146.0, 110.0], [146.0, 235.0], [123.0, 235.0]], [[91.0, 109.0], [114.0, 109.0], [114.0, 235.0], [91.0, 235.0]]], "lines": ["私群れるの", "苦手なんで。"]}, {"box": [520, 365, 579, 459], "vertical": true, "font_size": 24, "lines_coords": [[[555.0, 365.0], [579.0, 365.0], [576.0, 459.0], [552.0, 459.0]], [[523.0, 365.0], [548.0, 365.0], [545.0, 459.0], [520.0, 459.0]]], "lines": ["しょうが", "ねぇな！！"]}, {"box": [97, 462, 185, 576], "vertical": true, "font_size": 25, "lines_coords": [[[155.0, 462.0], [185.0, 462.0], [185.0, 535.0], [155.0, 535.0]], [[128.0, 463.0], [151.0, 463.0], [151.0, 576.0], [128.0, 576.0]], [[97.0, 462.0], [120.0, 462.0], [120.0, 576.0], [97.0, 576.0]]], "lines": ["この女", "俺に惚れや", "がったか！？"]}, {"box": [775, 702, 857, 922], "vertical": true, "font_size": 38, "lines_coords": [[[810.0, 702.0], [857.0, 702.0], [857.0, 764.0], [810.0, 764.0]], [[776.0, 708.0], [805.0, 708.0], [805.0, 922.0], [776.0, 922.0]]], "lines": ["だー", "ひやひゃひゃ！！"]}, {"box": [523, 906, 628, 1071], "vertical": true, "font_size": 23, "lines_coords": [[[605.0, 907.0], [628.0, 907.0], [628.0, 1071.0], [605.0, 1071.0]], [[578.0, 906.0], [601.0, 906.0], [601.0, 1044.0], [578.0, 1044.0]], [[552.0, 907.0], [571.0, 907.0], [571.0, 1066.0], [552.0, 1066.0]], [[523.0, 906.0], [546.0, 906.0], [546.0, 1022.0], [523.0, 1022.0]]], "lines": ["コリャやばいよ、", "悲しい未来が", "手にとるように", "見えるよ！！"]}, {"box": [378, 892, 416, 910], "vertical": false, "font_size": 18, "lines_coords": [[[378.0, 892.0], [416.0, 892.0], [416.0, 910.0], [378.0, 910.0]]], "lines": ["第１学"]}, {"box": [406, 1025, 516, 1186], "vertical": true, "font_size": 23, "lines_coords": [[[489.0, 1025.0], [516.0, 1025.0], [516.0, 1168.0], [489.0, 1168.0]], [[459.0, 1026.0], [486.0, 1026.0], [486.0, 1166.0], [459.0, 1166.0]], [[432.0, 1026.0], [456.0, 1026.0], [456.0, 1130.0], [432.0, 1130.0]], [[406.0, 1028.0], [425.0, 1028.0], [425.0, 1186.0], [406.0, 1186.0]]], "lines": ["サバ川、お前", "かなりマシに", "なったな、", "ケバイけどな！！"]}, {"box": [392, 1274, 500, 1363], "vertical": false, "font_size": 23.666666666666668, "lines_coords": [[[408.0, 1290.0], [500.0, 1326.0], [492.0, 1349.0], [400.0, 1313.0]], [[418.0, 1274.0], [459.0, 1287.0], [452.0, 1307.0], [412.0, 1294.0]], [[400.0, 1315.0], [467.0, 1338.0], [459.0, 1363.0], [392.0, 1339.0]]], "lines": ["豚キムチ天．．．", "藤王", "広島風ぅ"]}, {"box": [252, 1110, 340, 1134], "vertical": false, "font_size": 15, "lines_coords": [[[252.0, 1119.0], [339.0, 1110.0], [340.0, 1125.0], [254.0, 1134.0]]], "lines": ["上記の者は本大手"]}, {"box": [147, 991, 172, 1112], "vertical": true, "font_size": 22, "lines_coords": [[[147.0, 991.0], [172.0, 991.0], [172.0, 1112.0], [147.0, 1112.0]]], "lines": ["アユ川です。"]}, {"box": [86, 1171, 195, 1339], "vertical": true, "font_size": 22, "lines_coords": [[[176.0, 1171.0], [195.0, 1171.0], [195.0, 1305.0], [176.0, 1305.0]], [[144.0, 1173.0], [168.0, 1173.0], [168.0, 1331.0], [144.0, 1331.0]], [[117.0, 1171.0], [136.0, 1171.0], [136.0, 1308.0], [117.0, 1308.0]], [[86.0, 1171.0], [109.0, 1171.0], [109.0, 1339.0], [86.0, 1339.0]]], "lines": ["このままじゃ", "マズイと思って", "上京してから", "頑張ったんです。"]}], "img_path": "090.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [804, 88, 929, 252], "vertical": true, "font_size": 25, "lines_coords": [[[894.0, 88.0], [929.0, 88.0], [929.0, 153.0], [894.0, 153.0]], [[868.0, 92.0], [891.0, 92.0], [891.0, 231.0], [868.0, 231.0]], [[835.0, 92.0], [858.0, 92.0], [857.0, 252.0], [833.0, 252.0]], [[805.0, 92.0], [824.0, 92.0], [824.0, 237.0], [805.0, 237.0]]], "lines": ["ただ、", "見た目なんて", "ある程度簡単に", "変わるんスよ。"]}, {"box": [581, 92, 606, 184], "vertical": true, "font_size": 24, "lines_coords": [[[581.0, 92.0], [605.0, 92.0], [605.0, 184.0], [581.0, 184.0]]], "lines": ["本質ぅ？"]}, {"box": [340, 87, 365, 169], "vertical": true, "font_size": 25, "lines_coords": [[[340.0, 87.0], [365.0, 87.0], [365.0, 169.0], [340.0, 169.0]]], "lines": ["そうス。"]}, {"box": [617, 453, 706, 624], "vertical": true, "font_size": 24, "lines_coords": [[[680.0, 453.0], [704.0, 453.0], [704.0, 591.0], [680.0, 591.0]], [[649.0, 455.0], [672.0, 455.0], [672.0, 571.0], [649.0, 571.0]], [[617.0, 453.0], [641.0, 453.0], [641.0, 623.0], [617.0, 623.0]]], "lines": ["でも本質的な", "ことは何も", "変わらなかった。"]}, {"box": [94, 339, 212, 525], "vertical": true, "font_size": 23, "lines_coords": [[[185.0, 341.0], [209.0, 341.0], [209.0, 525.0], [185.0, 525.0]], [[155.0, 340.0], [180.0, 340.0], [177.0, 481.0], [153.0, 481.0]], [[121.0, 339.0], [146.0, 339.0], [147.0, 523.0], [123.0, 523.0]], [[94.0, 343.0], [113.0, 343.0], [113.0, 500.0], [94.0, 500.0]]], "lines": ["人に聴いてもらう", "以上、詞には", "強いメッセージが", "必要なんスよ！！"]}, {"box": [802, 661, 857, 809], "vertical": true, "font_size": 23, "lines_coords": [[[833.0, 661.0], [857.0, 661.0], [857.0, 777.0], [833.0, 777.0]], [[802.0, 663.0], [825.0, 663.0], [825.0, 809.0], [802.0, 809.0]]], "lines": ["でもある日", "気づいたんス。"]}, {"box": [672, 782, 790, 969], "vertical": true, "font_size": 23, "lines_coords": [[[765.0, 782.0], [788.0, 782.0], [790.0, 969.0], [766.0, 969.0]], [[735.0, 786.0], [758.0, 786.0], [758.0, 967.0], [735.0, 967.0]], [[704.0, 787.0], [727.0, 787.0], [727.0, 924.0], [704.0, 924.0]], [[672.0, 786.0], [695.0, 786.0], [695.0, 907.0], [672.0, 907.0]]], "lines": ["あたしの詞なんて", "歌うため無理矢理", "ひねり出した", "作りモノで、"]}, {"box": [250, 672, 369, 836], "vertical": true, "font_size": 24, "lines_coords": [[[341.0, 672.0], [369.0, 672.0], [369.0, 812.0], [341.0, 812.0]], [[314.0, 672.0], [337.0, 672.0], [337.0, 812.0], [314.0, 812.0]], [[284.0, 675.0], [303.0, 675.0], [303.0, 832.0], [284.0, 832.0]], [[250.0, 672.0], [270.0, 672.0], [272.0, 836.0], [251.0, 836.0]]], "lines": ["こんな平坦で", "退屈で曖昧な", "日常に生きてる", "あたし達からは"]}, {"box": [129, 828, 244, 1017], "vertical": true, "font_size": 24, "lines_coords": [[[221.0, 829.0], [244.0, 829.0], [244.0, 1014.0], [221.0, 1014.0]], [[188.0, 828.0], [216.0, 828.0], [216.0, 1017.0], [188.0, 1017.0]], [[158.0, 829.0], [181.0, 829.0], [181.0, 992.0], [158.0, 992.0]], [[129.0, 831.0], [153.0, 831.0], [153.0, 933.0], [129.0, 933.0]]], "lines": ["悩むために悩んで", "こねくりまわした", "贋物しか産まれ", "ないって。"]}, {"box": [777, 1050, 833, 1221], "vertical": true, "font_size": 24, "lines_coords": [[[809.0, 1051.0], [832.0, 1051.0], [832.0, 1211.0], [809.0, 1211.0]], [[777.0, 1050.0], [801.0, 1050.0], [801.0, 1220.0], [777.0, 1220.0]]], "lines": ["．．．時代のせいに", "すんじゃねいよ。"]}, {"box": [259, 1063, 314, 1252], "vertical": true, "font_size": 21, "lines_coords": [[[291.0, 1063.0], [314.0, 1063.0], [311.0, 1248.0], [288.0, 1248.0]], [[259.0, 1066.0], [278.0, 1066.0], [278.0, 1252.0], [259.0, 1252.0]]], "lines": ["伝えるべきものが", "見つからないとか。"]}, {"box": [127, 1163, 210, 1323], "vertical": true, "font_size": 21, "lines_coords": [[[187.0, 1163.0], [210.0, 1163.0], [210.0, 1323.0], [187.0, 1323.0]], [[157.0, 1164.0], [176.0, 1164.0], [176.0, 1275.0], [157.0, 1275.0]], [[127.0, 1164.0], [146.0, 1164.0], [146.0, 1311.0], [127.0, 1311.0]]], "lines": ["．．．種田って奴も", "たまにソレ", "言ってたなぁ。"]}], "img_path": "091.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [771, 112, 892, 299], "vertical": true, "font_size": 23, "lines_coords": [[[869.0, 113.0], [892.0, 113.0], [892.0, 191.0], [869.0, 191.0]], [[833.0, 112.0], [857.0, 112.0], [857.0, 299.0], [833.0, 299.0]], [[803.0, 114.0], [827.0, 114.0], [827.0, 296.0], [803.0, 296.0]], [[771.0, 113.0], [794.0, 113.0], [794.0, 278.0], [771.0, 278.0]]], "lines": ["．．．まぁ、", "もういいんすけど、", "サークル入るのも", "バカバカしいし、"]}, {"box": [665, 211, 750, 369], "vertical": true, "font_size": 23, "lines_coords": [[[727.0, 213.0], [750.0, 213.0], [750.0, 350.0], [727.0, 350.0]], [[698.0, 214.0], [717.0, 214.0], [717.0, 369.0], [698.0, 369.0]], [[665.0, 211.0], [689.0, 211.0], [689.0, 334.0], [665.0, 334.0]]], "lines": ["元々あたしは", "ただの音楽オタ", "だった訳で、"]}, {"box": [639, 108, 664, 180], "vertical": true, "font_size": 25, "lines_coords": [[[639.0, 108.0], [664.0, 108.0], [664.0, 180.0], [639.0, 180.0]]], "lines": ["本当！！"]}, {"box": [483, 95, 604, 234], "vertical": true, "font_size": 22, "lines_coords": [[[581.0, 98.0], [600.0, 98.0], [600.0, 232.0], [581.0, 232.0]], [[546.0, 97.0], [570.0, 97.0], [570.0, 233.0], [546.0, 233.0]], [[515.0, 97.0], [538.0, 97.0], [538.0, 232.0], [515.0, 232.0]], [[483.0, 95.0], [507.0, 95.0], [507.0, 199.0], [483.0, 199.0]]], "lines": ["表現する側に", "なろうなんて", "おこがましい", "ですよね。"]}, {"box": [98, 91, 217, 239], "vertical": true, "font_size": 24, "lines_coords": [[[191.0, 92.0], [214.0, 92.0], [214.0, 229.0], [191.0, 229.0]], [[161.0, 92.0], [184.0, 92.0], [184.0, 210.0], [161.0, 210.0]], [[127.0, 91.0], [154.0, 91.0], [154.0, 232.0], [127.0, 232.0]], [[98.0, 92.0], [121.0, 92.0], [121.0, 239.0], [98.0, 239.0]]], "lines": ["べつに最初は", "軽い憧れで", "ギター持った", "だけっすから。"]}, {"box": [394, 319, 416, 432], "vertical": true, "font_size": 19, "lines_coords": [[[395.0, 319.0], [414.0, 319.0], [414.0, 430.0], [395.0, 430.0]]], "lines": ["ホントに？"]}, {"box": [114, 358, 139, 494], "vertical": true, "font_size": 24, "lines_coords": [[[114.0, 358.0], [138.0, 358.0], [138.0, 493.0], [114.0, 493.0]]], "lines": ["ホントにぃ？"]}, {"box": [780, 725, 868, 909], "vertical": true, "font_size": 23, "lines_coords": [[[842.0, 725.0], [866.0, 725.0], [868.0, 885.0], [843.0, 885.0]], [[812.0, 727.0], [835.0, 727.0], [835.0, 909.0], [812.0, 909.0]], [[782.0, 727.0], [802.0, 727.0], [801.0, 887.0], [780.0, 887.0]]], "lines": ["．．．メチャメナャ", "本気に決まってる", "じゃないスか！！"]}, {"box": [386, 780, 473, 925], "vertical": true, "font_size": 22, "lines_coords": [[[449.0, 780.0], [473.0, 780.0], [473.0, 895.0], [449.0, 895.0]], [[416.0, 782.0], [440.0, 782.0], [440.0, 895.0], [416.0, 895.0]], [[386.0, 782.0], [406.0, 782.0], [406.0, 925.0], [386.0, 925.0]]], "lines": ["．．．．．．何事も", "積み重ねが", "大事だからな。"]}, {"box": [250, 802, 356, 974], "vertical": true, "font_size": 22, "lines_coords": [[[337.0, 803.0], [356.0, 803.0], [356.0, 917.0], [337.0, 917.0]], [[306.0, 803.0], [329.0, 803.0], [329.0, 940.0], [306.0, 940.0]], [[276.0, 802.0], [300.0, 802.0], [300.0, 895.0], [276.0, 895.0]], [[250.0, 805.0], [269.0, 805.0], [269.0, 974.0], [250.0, 974.0]]], "lines": ["とりあえず", "今はどんどん", "曲書いて", "歌ってみろって。"]}, {"box": [618, 1130, 704, 1313], "vertical": true, "font_size": 22, "lines_coords": [[[679.0, 1130.0], [702.0, 1130.0], [704.0, 1290.0], [680.0, 1290.0]], [[649.0, 1132.0], [672.0, 1132.0], [672.0, 1270.0], [649.0, 1270.0]], [[619.0, 1132.0], [638.0, 1132.0], [638.0, 1312.0], [619.0, 1312.0]]], "lines": ["たくさんの人に", "あたしの曲を", "聴いてほしいよ！！"]}, {"box": [120, 978, 211, 1141], "vertical": true, "font_size": 23, "lines_coords": [[[184.0, 978.0], [211.0, 978.0], [211.0, 1141.0], [184.0, 1141.0]], [[153.0, 980.0], [180.0, 980.0], [180.0, 1119.0], [153.0, 1119.0]], [[123.0, 978.0], [147.0, 978.0], [144.0, 1121.0], [120.0, 1121.0]]], "lines": ["「べつにー」とか", "「でもー」とか", "「まぁー」とか、"]}, {"box": [87, 1194, 174, 1335], "vertical": true, "font_size": 23, "lines_coords": [[[155.0, 1199.0], [174.0, 1199.0], [174.0, 1289.0], [155.0, 1289.0]], [[124.0, 1199.0], [143.0, 1199.0], [143.0, 1312.0], [124.0, 1312.0]], [[90.0, 1194.0], [113.0, 1194.0], [110.0, 1335.0], [87.0, 1335.0]]], "lines": ["あんまり", "理屈こねて", "ばかりだと．．．"]}], "img_path": "092.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [672, 125, 739, 345], "vertical": true, "font_size": 28, "lines_coords": [[[710.0, 125.0], [738.0, 125.0], [738.0, 291.0], [710.0, 291.0]], [[672.0, 125.0], [699.0, 125.0], [699.0, 345.0], [672.0, 345.0]]], "lines": ["俺らみたいに", "なっちまうぜ．．．．．"]}, {"box": [812, 579, 833, 720], "vertical": true, "font_size": 22, "lines_coords": [[[812.0, 579.0], [831.0, 579.0], [833.0, 720.0], [814.0, 720.0]]], "lines": ["あたしはぁ！！"]}, {"box": [679, 693, 795, 831], "vertical": true, "font_size": 22, "lines_coords": [[[771.0, 693.0], [795.0, 693.0], [795.0, 765.0], [771.0, 765.0]], [[736.0, 693.0], [760.0, 693.0], [762.0, 831.0], [739.0, 831.0]], [[706.0, 695.0], [730.0, 695.0], [730.0, 831.0], [706.0, 831.0]], [[679.0, 697.0], [698.0, 697.0], [698.0, 791.0], [679.0, 791.0]]], "lines": ["世界は", "変えらんない", "かもしれない", "けどっ！！"]}, {"box": [781, 918, 899, 1056], "vertical": true, "font_size": 21, "lines_coords": [[[877.0, 920.0], [896.0, 920.0], [896.0, 1055.0], [877.0, 1055.0]], [[843.0, 918.0], [866.0, 918.0], [866.0, 1034.0], [843.0, 1034.0]], [[812.0, 918.0], [835.0, 918.0], [835.0, 1034.0], [812.0, 1034.0]], [[783.0, 918.0], [802.0, 918.0], [802.0, 1054.0], [783.0, 1054.0]]], "lines": ["あたしの目が", "黒いうちは", "あんなもん", "認めねーぞ！！"]}, {"box": [185, 600, 308, 803], "vertical": true, "font_size": 24, "lines_coords": [[[278.0, 601.0], [302.0, 601.0], [302.0, 761.0], [278.0, 761.0]], [[247.0, 600.0], [270.0, 600.0], [270.0, 803.0], [247.0, 803.0]], [[214.0, 600.0], [241.0, 600.0], [241.0, 786.0], [214.0, 786.0]], [[185.0, 601.0], [205.0, 601.0], [205.0, 787.0], [185.0, 787.0]]], "lines": ["日本の腑抜けた", "音楽チャートくらい", "ひっくり返せると", "思ったんすよっ！！"]}, {"box": [236, 896, 265, 1000], "vertical": true, "font_size": 24, "lines_coords": [[[236.0, 896.0], [265.0, 896.0], [265.0, 1000.0], [236.0, 1000.0]]], "lines": ["．．．サバ子、"]}, {"box": [101, 937, 184, 1041], "vertical": true, "font_size": 24, "lines_coords": [[[161.0, 937.0], [184.0, 937.0], [184.0, 1034.0], [161.0, 1034.0]], [[128.0, 939.0], [153.0, 939.0], [153.0, 1032.0], [128.0, 1032.0]], [[101.0, 941.0], [120.0, 941.0], [120.0, 1041.0], [101.0, 1041.0]]], "lines": ["とにかく", "やるだけ", "やってみ。"]}, {"box": [576, 1199, 662, 1337], "vertical": true, "font_size": 22, "lines_coords": [[[638.0, 1201.0], [661.0, 1201.0], [661.0, 1337.0], [638.0, 1337.0]], [[607.0, 1199.0], [630.0, 1199.0], [630.0, 1315.0], [607.0, 1315.0]], [[576.0, 1201.0], [596.0, 1201.0], [596.0, 1323.0], [576.0, 1323.0]]], "lines": ["白目のヒトに", "そんなこと", "言われても。"]}, {"box": [192, 1134, 222, 1216], "vertical": true, "font_size": 24, "lines_coords": [[[192.0, 1134.0], [222.0, 1134.0], [222.0, 1216.0], [192.0, 1216.0]]], "lines": ["．．．先輩"]}, {"box": [88, 1204, 173, 1346], "vertical": true, "font_size": 24, "lines_coords": [[[150.0, 1204.0], [173.0, 1204.0], [173.0, 1345.0], [150.0, 1345.0]], [[117.0, 1205.0], [140.0, 1205.0], [140.0, 1346.0], [117.0, 1346.0]], [[88.0, 1205.0], [108.0, 1205.0], [108.0, 1343.0], [88.0, 1343.0]]], "lines": ["それでホント", "駄目だったら", "どーしよう？"]}], "img_path": "093.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [172, 202, 230, 328], "vertical": true, "font_size": 23,