: [[[232.0, 902.0], [257.0, 902.0], [257.0, 999.0], [232.0, 999.0]], [[202.0, 902.0], [225.0, 902.0], [225.0, 1040.0], [202.0, 1040.0]], [[173.0, 903.0], [192.0, 903.0], [192.0, 1026.0], [173.0, 1026.0]]], "lines": ["いやいや、", "そんな一度に", "聞かれても。"]}, {"box": [133, 1086, 218, 1260], "vertical": true, "font_size": 22, "lines_coords": [[[195.0, 1086.0], [218.0, 1086.0], [218.0, 1235.0], [195.0, 1235.0]], [[162.0, 1088.0], [185.0, 1088.0], [185.0, 1229.0], [162.0, 1229.0]], [[133.0, 1089.0], [153.0, 1089.0], [153.0, 1260.0], [133.0, 1260.0]]], "lines": ["とりあえず今、", "ようやく携帯", "買い換えたとこ。"]}], "img_path": "200.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [801, 91, 888, 225], "vertical": true, "font_size": 23, "lines_coords": [[[864.0, 91.0], [888.0, 91.0], [888.0, 181.0], [864.0, 181.0]], [[832.0, 92.0], [857.0, 92.0], [857.0, 225.0], [832.0, 225.0]], [[801.0, 91.0], [825.0, 91.0], [825.0, 194.0], [801.0, 194.0]]], "lines": ["なかなか", "ハードな日々", "だったよ。"]}, {"box": [648, 116, 764, 299], "vertical": true, "font_size": 23, "lines_coords": [[[745.0, 120.0], [764.0, 120.0], [764.0, 236.0], [745.0, 236.0]], [[712.0, 118.0], [735.0, 118.0], [735.0, 278.0], [712.0, 278.0]], [[679.0, 116.0], [702.0, 116.0], [702.0, 299.0], [679.0, 299.0]], [[648.0, 117.0], [671.0, 117.0], [671.0, 266.0], [648.0, 266.0]]], "lines": ["この５日間、", "ほぼ不眠不休で", "会社泊まり込んで", "作業しててさ。"]}, {"box": [527, 114, 550, 228], "vertical": true, "font_size": 23, "lines_coords": [[[527.0, 114.0], [550.0, 114.0], [550.0, 228.0], [527.0, 228.0]]], "lines": ["会社って？"]}, {"box": [136, 166, 229, 338], "vertical": true, "font_size": 24, "lines_coords": [[[198.0, 166.0], [229.0, 166.0], [229.0, 229.0], [198.0, 229.0]], [[172.0, 169.0], [191.0, 169.0], [191.0, 326.0], [172.0, 326.0]], [[138.0, 166.0], [161.0, 166.0], [159.0, 336.0], [136.0, 336.0]]], "lines": ["ホラ、", "辞めたばっかの", "デザイン事務所。"]}, {"box": [127, 458, 248, 642], "vertical": true, "font_size": 24, "lines_coords": [[[222.0, 460.0], [246.0, 460.0], [246.0, 597.0], [222.0, 597.0]], [[190.0, 460.0], [214.0, 460.0], [214.0, 561.0], [190.0, 561.0]], [[158.0, 458.0], [181.0, 458.0], [183.0, 642.0], [159.0, 642.0]], [[128.0, 460.0], [151.0, 460.0], [150.0, 628.0], [127.0, 628.0]]], "lines": ["社長にすげー", "頭下げて、", "また働かせてくれ", "って頼んだのさ。"]}, {"box": [773, 710, 857, 928], "vertical": true, "font_size": 22, "lines_coords": [[[833.0, 712.0], [857.0, 712.0], [857.0, 892.0], [833.0, 892.0]], [[802.0, 710.0], [825.0, 710.0], [825.0, 872.0], [802.0, 872.0]], [[773.0, 712.0], [792.0, 712.0], [792.0, 928.0], [773.0, 928.0]]], "lines": ["おかげで来週から", "契約社員として", "雇ってくれるってさ。"]}, {"box": [677, 871, 732, 984], "vertical": true, "font_size": 55, "lines_coords": [[[677.0, 871.0], [732.0, 871.0], [732.0, 984.0], [677.0, 984.0]]], "lines": ["やってみるもんだね。"]}, {"box": [678, 870, 731, 987], "vertical": true, "font_size": 22, "lines_coords": [[[708.0, 870.0], [731.0, 870.0], [731.0, 987.0], [708.0, 987.0]], [[678.0, 870.0], [697.0, 870.0], [697.0, 970.0], [678.0, 970.0]]], "lines": ["やってみる", "もんだね"]}, {"box": [133, 831, 255, 1036], "vertical": true, "font_size": 23, "lines_coords": [[[226.0, 831.0], [255.0, 831.0], [255.0, 933.0], [226.0, 933.0]], [[199.0, 832.0], [218.0, 832.0], [218.0, 991.0], [199.0, 991.0]], [[166.0, 831.0], [185.0, 831.0], [185.0, 1033.0], [166.0, 1033.0]], [[133.0, 831.0], [157.0, 831.0], [157.0, 935.0], [133.0, 935.0]]], "lines": ["つー訳で、", "漫画的に言えば", "次号から社会人編に", "突入だぁ。"]}, {"box": [823, 1108, 847, 1194], "vertical": true, "font_size": 24, "lines_coords": [[[823.0, 1108.0], [847.0, 1108.0], [847.0, 1194.0], [823.0, 1194.0]]], "lines": ["．．．：種田、"]}, {"box": [735, 1163, 758, 1302], "vertical": true, "font_size": 24, "lines_coords": [[[735.0, 1163.0], [758.0, 1163.0], [758.0, 1302.0], [735.0, 1302.0]]], "lines": ["また働くの？"]}], "img_path": "201.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [805, 125, 827, 164], "vertical": false, "font_size": 39, "lines_coords": [[[805.0, 125.0], [827.0, 125.0], [827.0, 164.0], [805.0, 164.0]]], "lines": ["．．．"]}, {"box": [705, 95, 734, 223], "vertical": true, "font_size": 23, "lines_coords": [[[705.0, 135.0], [728.0, 133.0], [732.0, 220.0], [709.0, 221.0]]], "lines": ["．．．うん"]}, {"box": [235, 144, 323, 318], "vertical": true, "font_size": 25, "lines_coords": [[[299.0, 146.0], [322.0, 146.0], [322.0, 267.0], [299.0, 267.0]], [[262.0, 146.0], [292.0, 144.0], [295.0, 241.0], [265.0, 243.0]], [[235.0, 149.0], [258.0, 149.0], [258.0, 317.0], [235.0, 317.0]]], "lines": ["でもやっぱ、", "働いても", "バンドは続ける。"]}, {"box": [808, 421, 831, 542], "vertical": true, "font_size": 23, "lines_coords": [[[808.0, 421.0], [831.0, 421.0], [831.0, 542.0], [808.0, 542.0]]], "lines": ["芽衣子さん、"]}, {"box": [687, 526, 773, 712], "vertical": true, "font_size": 23, "lines_coords": [[[750.0, 527.0], [773.0, 527.0], [773.0, 643.0], [750.0, 643.0]], [[717.0, 526.0], [741.0, 526.0], [741.0, 712.0], [717.0, 712.0]], [[687.0, 527.0], [710.0, 527.0], [710.0, 697.0], [687.0, 697.0]]], "lines": ["俺は音楽で", "世界を変えようと", "本気で思ってた。"]}, {"box": [138, 559, 256, 753], "vertical": true, "font_size": 23, "lines_coords": [[[229.0, 560.0], [252.0, 560.0], [255.0, 704.0], [232.0, 704.0]], [[199.0, 559.0], [222.0, 559.0], [224.0, 723.0], [200.0, 723.0]], [[164.0, 560.0], [191.0, 560.0], [195.0, 724.0], [168.0, 724.0]], [[139.0, 563.0], [158.0, 563.0], [158.0, 753.0], [139.0, 753.0]]], "lines": ["夢のためなら、", "どんな困難でも", "立ち向かうべき", "なんだと思ってた。"]}, {"box": [768, 844, 846, 1061], "vertical": true, "font_size": 19, "lines_coords": [[[825.0, 844.0], [844.0, 844.0], [844.0, 1015.0], [825.0, 1015.0]], [[797.0, 846.0], [816.0, 846.0], [816.0, 1052.0], [797.0, 1052.0]], [[768.0, 846.0], [787.0, 846.0], [787.0, 1059.0], [768.0, 1059.0]]], "lines": ["．．．でもこの頃は、", "俺はミュージシャンに", "なりたいんじゃなくて、"]}, {"box": [468, 936, 576, 1103], "vertical": true, "font_size": 20, "lines_coords": [[[552.0, 937.0], [575.0, 937.0], [575.0, 1022.0], [552.0, 1022.0]], [[524.0, 936.0], [544.0, 936.0], 