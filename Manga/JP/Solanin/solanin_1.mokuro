, "lines": ["すぎてて、僕しか", "気づいてなかった", "みたいだけど。"]}, {"box": [788, 1024, 874, 1207], "vertical": true, "font_size": 20, "lines_coords": [[[851.0, 1024.0], [870.0, 1024.0], [870.0, 1204.0], [851.0, 1204.0]], [[820.0, 1024.0], [843.0, 1024.0], [843.0, 1163.0], [820.0, 1163.0]], [[790.0, 1025.0], [809.0, 1025.0], [809.0, 1148.0], [790.0, 1148.0]]], "lines": ["．．．今日はわざわざ", "来てもらって", "悪かったね。"]}], "img_path": "163.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [799, 73, 884, 232], "vertical": true, "font_size": 22, "lines_coords": [[[859.0, 73.0], [884.0, 73.0], [884.0, 166.0], [859.0, 166.0]], [[831.0, 75.0], [850.0, 75.0], [850.0, 232.0], [831.0, 232.0]], [[799.0, 77.0], [818.0, 77.0], [818.0, 198.0], [799.0, 198.0]]], "lines": ["．．．．．まだ", "憶えてる人間が", "いたんだな。"]}, {"box": [678, 117, 764, 280], "vertical": true, "font_size": 22, "lines_coords": [[[745.0, 118.0], [764.0, 118.0], [764.0, 232.0], [745.0, 232.0]], [[710.0, 117.0], [735.0, 117.0], [735.0, 211.0], [710.0, 211.0]], [[680.0, 117.0], [704.0, 117.0], [701.0, 280.0], [678.0, 280.0]]], "lines": ["５年も前に", "解散した", "バンドなんか．．．"]}, {"box": [460, 73, 516, 224], "vertical": true, "font_size": 23, "lines_coords": [[[490.0, 73.0], [514.0, 73.0], [516.0, 190.0], [493.0, 190.0]], [[460.0, 75.0], [483.0, 75.0], [483.0, 224.0], [460.0, 224.0]]], "lines": ["．．．ＣＤ全部", "持ってますよ。"]}, {"box": [351, 139, 408, 283], "vertical": true, "font_size": 23, "lines_coords": [[[385.0, 139.0], [408.0, 139.0], [408.0, 276.0], [385.0, 276.0]], [[354.0, 139.0], [377.0, 139.0], [374.0, 283.0], [351.0, 283.0]]], "lines": ["今でもたまに", "聴きますから。"]}, {"box": [89, 378, 207, 537], "vertical": true, "font_size": 20, "lines_coords": [[[184.0, 378.0], [203.0, 378.0], [203.0, 490.0], [184.0, 490.0]], [[153.0, 378.0], [172.0, 378.0], [172.0, 537.0], [153.0, 537.0]], [[118.0, 378.0], [142.0, 378.0], [142.0, 492.0], [118.0, 492.0]], [[90.0, 378.0], [109.0, 378.0], [109.0, 500.0], [90.0, 500.0]]], "lines": ["大衆に適応", "しきれなかった", "マイナーな", "バンドだよ。"]}, {"box": [299, 616, 322, 758], "vertical": true, "font_size": 22, "lines_coords": [[[299.0, 616.0], [322.0, 616.0], [322.0, 758.0], [299.0, 758.0]]], "lines": ["くやしいけど、"]}, {"box": [758, 612, 865, 818], "vertical": true, "font_size": 24, "lines_coords": [[[839.0, 612.0], [862.0, 612.0], [865.0, 751.0], [842.0, 751.0]], [[813.0, 615.0], [836.0, 615.0], [836.0, 773.0], [813.0, 773.0]], [[787.0, 617.0], [806.0, 617.0], [806.0, 818.0], [787.0, 818.0]], [[758.0, 615.0], [782.0, 615.0], [782.0, 753.0], [758.0, 753.0]]], "lines": ["．．．確かに洋楽", "かぶれで絶対に", "一般ウケしなそうな", "曲ばっかで．．．"]}, {"box": [626, 697, 746, 906], "vertical": true, "font_size": 24, "lines_coords": [[[723.0, 697.0], [746.0, 697.0], [746.0, 817.0], [723.0, 817.0]], [[691.0, 700.0], [715.0, 700.0], [715.0, 838.0], [691.0, 838.0]], [[658.0, 700.0], [686.0, 700.0], [686.0, 906.0], [658.0, 906.0]], [[626.0, 697.0], [654.0, 697.0], [654.0, 779.0], [626.0, 779.0]]], "lines": ["でもなんか", "それがすげー", "カッコいいとかって", "思って、"]}, {"box": [127, 720, 244, 903], "vertical": true, "font_size": 22, "lines_coords": [[[225.0, 723.0], [244.0, 723.0], [244.0, 858.0], [225.0, 858.0]], [[190.0, 720.0], [213.0, 720.0], [213.0, 903.0], [190.0, 903.0]], [[159.0, 721.0], [183.0, 721.0], [183.0, 859.0], [159.0, 859.0]], [[127.0, 721.0], [150.0, 721.0], [153.0, 847.0], [129.0, 847.0]]], "lines": ["高校生の俺を", "音楽に駆り立てた", "要因の一つは", "アンタです。"]}, {"box": [231, 969, 292, 1107], "vertical": true, "font_size": 28, "lines_coords": [[[259.0, 969.0], [292.0, 969.0], [292.0, 1022.0], [259.0, 1022.0]], [[233.0, 972.0], [258.0, 972.0], [255.0, 1107.0], [231.0, 1107.0]]], "lines": ["その", "アンタが．．．"]}, {"box": [760, 991, 848, 1151], "vertical": true, "font_size": 22, "lines_coords": [[[824.0, 991.0], [847.0, 991.0], [847.0, 1129.0], [824.0, 1129.0]], [[794.0, 992.0], [813.0, 992.0], [813.0, 1149.0], [794.0, 1149.0]], [[760.0, 993.0], [783.0, 993.0], [783.0, 1149.0], [760.0, 1149.0]]], "lines": ["こんな俺にも", "熱心なファンが", "いたんだな．．．"]}, {"box": [88, 1112, 232, 1309], "vertical": true, "font_size": 28, "lines_coords": [[[202.0, 1112.0], [229.0, 1112.0], [232.0, 1282.0], [205.0, 1282.0]], [[165.0, 1114.0], [192.0, 1114.0], [192.0, 1281.0], [165.0, 1281.0]], [[127.0, 1115.0], [154.0, 1115.0], [154.0, 1283.0], [127.0, 1283.0]], [[88.0, 1115.0], [116.0, 1115.0], [116.0, 1309.0], [88.0, 1309.0]]], "lines": ["なんでそんな", "ビジネスマン", "みたいなこと", "やってんだよ！！"]}], "img_path": "164.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [689, 127, 807, 273], "vertical": true, "font_size": 22, "lines_coords": [[[786.0, 127.0], [805.0, 127.0], [803.0, 262.0], [784.0, 262.0]], [[751.0, 127.0], [775.0, 127.0], [775.0, 241.0], [751.0, 241.0]], [[719.0, 127.0], [743.0, 127.0], [743.0, 218.0], [719.0, 218.0]], [[690.0, 127.0], [709.0, 127.0], [709.0, 272.0], [690.0, 272.0]]], "lines": ["僕は表舞台に", "立つような", "人間じゃ", "なかったんだ。"]}, {"box": [125, 207, 274, 440], "vertical": true, "font_size": 23, "lines_coords": [[[250.0, 211.0], [273.0, 211.0], [273.0, 371.0], [250.0, 371.0]], [[217.0, 210.0], [244.0, 210.0], [244.0, 440.0], [217.0, 440.0]], [[187.0, 207.0], [211.0, 207.0], [209.0, 371.0], [184.0, 371.0]], [[154.0, 207.0], [177.0, 207.0], [177.0, 393.0], [154.0, 393.0]], [[125.0, 210.0], [144.0, 210.0], [144.0, 355.0], [125.0, 355.0]]], "lines": ["レコード会社に", "パッケージングされた", "ＣＤやライブに", "リアルを感じなく", "なったんだよ。"]}, {"box": [731, 516, 798, 709], "vertical": true, "font_size": 27, "lines_coords": [[[769.0, 516.0], [798.0, 516.0], [795.0, 709.0], [766.0, 709.0]], [[732.0, 516.0], [757.0, 516.0], [756.0, 709.0], [731.0, 709.0]]], "lines": ["じゃあアンタの", "リアルは金か！！"]}, {"box": [806, 808, 861, 955], "vertical": true, "font_size": 21, "lines_coords": [[[836.0, 808.0], [859.0, 808.0], [859.0, 946.0], [836.0, 946.0]], [[808.0, 809.0], [827.0, 809.0], [827.0, 952.0], [808.0, 952.0]]], "lines": ["．．．守るものが", "変わったんだ。"]}, {"box": [626, 809, 684, 972], "vertical": true, "font_size": 25, "lines_coords": [[[661.0, 813.0], [684.0, 813.0], [684.0, 972.0], [661.0, 972.0]], [[626.0, 809.0], [657.0, 809.0], [657.0, 872.0], [626.0, 872.0]]], "lines": ["自分のプライド", "から、"]}, {"box": [545, 944, 600, 1086], "vertical": true, "font_size": 25, "lines_coords": [[[576.0, 944.0], [600.0, 944.0], [597.0, 1086.0], [574.0, 1086.0]], [[545.0, 947.0], [568.0, 947.0], [568.0, 1051.0], [545.0, 1051.0]]], "lines": ["もっと大切な", "ものにね。"]}, {"box": [137, 1149, 223, 1266], "vertical": true, "font_size": 22, "lines_coords": [[[198.0, 1149.0], [222.0, 1149.0], [222.0, 1266.0], [198.0, 1266.0]], [[168.0, 1149.0], [192.0, 1149.0], [192.0, 1244.0], [168.0, 1244.0]], [[138.0, 1151.0], [157.0, 1151.0], [157.0, 1250.0], [138.0, 1250.0]]], "lines": ["．．．君と僕は", "ちょっと", "似てるな。"]}], "img_path": "165.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [757, 149, 844, 332], "vertical": true, "font_size": 23, "lines_coords": [[[821.0, 149.0], [844.0, 149.0], [844.0, 263.0], [821.0, 263.0]], [[791.0, 150.0], [810.0, 150.0], [810.0, 307.0], [791.0, 307.0]], [[757.0, 149.0], [780.0, 149.0], [780.0, 332.0], [757.0, 332.0]]], "lines": ["君には僕が", "負け犬に見える", "かもしれないが．．"]}, {"box": [272, 146, 358, 308], "vertical": true, "font_size": 23, "lines_coords": [[[334.0, 149.0], [358.0, 149.0], [358.0, 287.0], [334.0, 287.0]], [[303.0, 147.0], [326.0, 147.0], [326.0, 308.0], [303.0, 308.0]], [[272.0, 146.0], [295.0, 146.0], [295.0, 250.0], [272.0, 250.0]]], "lines": ["華々しい場所", "だけが戦場じゃ", "ないんだ。"]}, {"box": [646, 311, 734, 412], "vertical": true, "font_size": 23, "lines_coords": [[[709.0, 311.0], [734.0, 311.0], [734.0, 404.0], [709.0, 404.0]], [[678.0, 313.0], [702.0, 313.0], [702.0, 404.0], [678.0, 404.0]], [[646.0, 313.0], [669.0, 313.0], [669.0, 412.0], [646.0, 412.0]]], "lines": ["僕はまだ", "戦ってる", "つもりさ。"]}, {"box": [174, 284, 228, 455], "vertical": true, "font_size": 23, "lines_coords": [[[205.0, 284.0], [228.0, 284.0], [228.0, 400.0], [205.0, 400.0]], [[174.0, 287.0], [194.0, 287.0], [194.0, 455.0], [174.0, 455.0]]], "lines": ["君もいずれ", "わかるだろうよ。"]}, {"box": [220, 808, 287, 839], "vertical": false, "font_size": 14.0, "lines_coords": [[[220.0, 808.0], [287.0, 808.0], [287.0, 821.0], [220.0, 821.0]], [[226.0, 824.0], [265.0, 824.0], [265.0, 839.0], [226.0, 839.0]]], "lines": ["ポケットタオルの", "３００円"]}], "img_path": "166.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [701, 477, 727, 571], "vertical": true, "font_size": 24, "lines_coords": [[[701.0, 477.0], [725.0, 477.0], [727.0, 571.0], [702.0, 571.0]]], "lines": ["あたしは"]}, {"box": [703, 477, 727, 574], "vertical": true, "font_size": 24, "lines_coords": [[[703.0, 477.0], [727.0, 477.0], [727.0, 574.0], [703.0, 574.0]]], "lines": ["あたしは、"]}, {"box": [641, 478, 664, 615], "vertical": true, "font_size": 24, "lines_coords": [[[641.0, 478.0], [664.0, 478.0], [664.0, 615.0], [641.0, 615.0]]], "lines": ["なんというか"]}, {"box": [538, 475, 594, 638], "vertical": true, "font_size": 25, "lines_coords": [[[567.0, 477.0], [594.0, 477.0], [594.0, 638.0], [567.0, 638.0]], [[538.0, 475.0], [561.0, 475.0], [561.0, 593.0], [538.0, 593.0]]], "lines": ["チャンスの神様", "というのは"]}, {"box": [434, 477, 461, 598], "vertical": true, "font_size": 24, "lines_coords": [[[434.0, 477.0], [458.0, 477.0], [460.0, 596.0], [437.0, 596.0]]], "lines": ["こんな時に、"]}, {"box": [262, 474, 397, 687], "vertical": true, "font_size": 23, "lines_coords": [[[370.0, 478.0], [393.0, 478.0], [393.0, 683.0], [370.0, 683.0]], [[339.0, 478.0], [362.0, 478.0], [362.0, 637.0], [339.0, 637.0]], [[307.0, 479.0], [330.0, 479.0], [330.0, 591.0], [307.0, 591.0]]], "lines": ["けっこうな変化球を", "投げてくるもの", "なんだなぁ"]}, {"box": [246, 477, 271, 602], "vertical": true, "font_size": 23, "lines_coords": [[[246.0, 477.0], [269.0, 477.0], [269.0, 598.0], [246.0, 598.0]]], "lines": ["そう思った。"]}, {"box": [796, 702, 874, 928], "vertical": true, "font_size": 30, "lines_coords": [[[842.0, 702.0], [874.0, 702.0], [874.0, 866.0], [842.0, 866.0]], [[798.0, 704.0], [827.0, 704.0], [827.0, 928.0], [798.0, 928.0]]], "lines": ["どわあっ！！", "何か飛んでる！！"]}, {"box": [423, 764, 448, 883], "vertical": true, "font_size": 24, "lines_coords": [[[423.0, 765.0], [447.0, 765.0], [447.0, 877.0], [423.0, 877.0]]], "lines": ["もしあの時"]}, {"box": [322, 765, 377, 928], "vertical": true, "font_size": 23, "lines_coords": [[[354.0, 766.0], [377.0, 766.0], [377.0, 902.0], [354.0, 902.0]], [[322.0, 765.0], [345.0, 765.0], [345.0, 928.0], [322.0, 928.0]]], "lines": ["あたしが何も", "言わなかったら"]}, {"box": [217, 764, 241, 858], "vertical": true, "font_size": 23, "lines_coords": [[[217.0, 764.0], [241.0, 764.0], [241.0, 858.0], [217.0, 858.0]]], "lines": ["だろう？"]}, {"box": [219, 764, 277, 949], "vertical": true, "font_size": 23, "lines_coords": [[[250.0, 764.0], [273.0, 764.0], [273.0, 948.0], [250.0, 948.0]]], "lines": ["どうなっていたん"]}, {"box": [628, 1148, 657, 1309], "vertical": true, "font_size": 28, "lines_coords": [[[628.0, 1148.0], [656.0, 1148.0], [656.0, 1309.0], [628.0, 1309.0]]], "lines": ["どこどこ！？"]}, {"box": [458, 1008, 545, 1168], "vertical": true, "font_size": 22, "lines_coords": [[[519.0, 1008.0], [542.0, 1008.0], [545.0, 1130.0], [522.0, 1130.0]], [[489.0, 1008.0], [508.0, 1008.0], [508.0, 1166.0], [489.0, 1166.0]], [[458.0, 1008.0], [481.0, 1008.0], [481.0, 1111.0], [458.0, 1111.0]]], "lines": ["．．．なーんだ、", "ただの小ぶりな", "ＵＦＯか。"]}, {"box": [218, 1058, 247, 1133], "vertical": true, "font_size": 26, "lines_coords": [[[218.0, 1058.0], [247.0, 1058.0], [247.0, 1133.0], [218.0, 1133.0]]], "lines": ["ビリー"]}, {"box": [90, 1125, 179, 1335], "vertical": true, "font_size": 26, "lines_coords": [[[153.0, 1127.0], [176.0, 1127.0], [179.0, 1309.0], [155.0, 1309.0]], [[120.0, 1125.0], [147.0, 1125.0], [149.0, 1335.0], [121.0, 1335.0]], [[92.0, 1129.0], [116.0, 1129.0], [113.0, 1266.0], [90.0, 1266.0]]], "lines": ["素直にオモチャの", "パラシュートでした", "って言えば？"]}], "img_path": "167.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [747, 86, 868, 255], "vertical": true, "font_size": 24, "lines_coords": [[[843.0, 88.0], [868.0, 88.0], [868.0, 162.0], [843.0, 162.0]], [[812.0, 88.0], [836.0, 88.0], [836.0, 183.0], [812.0, 183.0]], [[780.0, 88.0], [803.0, 88.0], [803.0, 247.0], [780.0, 247.0]], [[747.0, 86.0], [771.0, 86.0], [771.0, 252.0], [747.0, 252.0]]], "lines": ["今日は、", "なぜだか、", "なんでだかよく", "わからないけど、"]}, {"box": [516, 170, 605, 333], "vertical": true, "font_size": 24, "lines_coords": [[[578.0, 170.0], [602.0, 170.0], [604.0, 311.0], [579.0, 311.0]], [[548.0, 173.0], [571.0, 173.0], [571.0, 333.0], [548.0, 333.0]], [[516.0, 172.0], [541.0, 172.0], [541.0, 247.0], [516.0, 247.0]]], "lines": ["私達の何かが", "完全に終わった", "ような、"]}, {"box": [101, 650, 156, 820], "vertical": true, "font_size": 23, "lines_coords": [[[132.0, 650.0], [155.0, 650.0], [155.0, 790.0], [132.0, 790.0]], [[101.0, 650.0], [124.0, 650.0], [124.0, 820.0], [101.0, 820.0]]], "lines": ["そんな寂しい", "気持ちになった。"]}], "img_path": "168.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [803, 61, 874, 229], "vertical": true, "font_size": 34, "lines_coords": [[[836.0, 61.0], [874.0, 61.0], [874.0, 124.0], [836.0, 124.0]], [[803.0, 64.0], [832.0, 64.0], [832.0, 229.0], [803.0, 229.0]]], "lines": ["種田", "おそーい！！"]}, {"box": [549, 80, 646, 220], "vertical": true, "font_size": 29, "lines_coords": [[[613.0, 80.0], [642.0, 80.0], [646.0, 220.0], [617.0, 220.0]], [[583.0, 82.0], [613.0, 82.0], [613.0, 168.0], [583.0, 168.0]], [[552.0, 80.0], [581.0, 80.0], [578.0, 194.0], [549.0, 194.0]]], "lines": ["んよしっ！！", "じゃあ", "帰るぜ！！"]}, {"box": [333, 243, 422, 357], "vertical": true, "font_size": 25, "lines_coords": [[[393.0, 243.0], [422.0, 243.0], [422.0, 317.0], [393.0, 317.0]], [[363.0, 244.0], [386.0, 244.0], [386.0, 355.0], [363.0, 355.0]], [[333.0, 246.0], [356.0, 246.0], [356.0, 336.0], [333.0, 336.0]]], "lines": ["なんで", "テンション", "上がる？"]}, {"box": [140, 222, 168, 401], "vertical": true, "font_size": 28, "lines_coords": [[[140.0, 222.0], [168.0, 222.0], [168.0, 401.0], [140.0, 401.0]]], "lines": ["．．．芽衣子さん。"]}, {"box": [187, 426, 217, 575], "vertical": true, "font_size": 28, "lines_coords": [[[187.0, 426.0], [214.0, 426.0], [217.0, 575.0], [190.0, 575.0]]], "lines": ["ありがとう。"]}, {"box": [620, 1031, 678, 1196], "vertical": true, "font_size": 23, "lines_coords": [[[653.0, 1033.0], [676.0, 1033.0], [676.0, 1192.0], [653.0, 1192.0]], [[622.0, 1033.0], [645.0, 1033.0], [645.0, 1194.0], [622.0, 1194.0]]], "lines": ["明るく振る舞う", "種田を見ながら"]}, {"box": [485, 1031, 546, 1218], "vertical": true, "font_size": 24, "lines_coords": [[[522.0, 1033.0], [546.0, 1033.0], [544.0, 1193.0], [519.0, 1193.0]], [[489.0, 1032.0], [514.0, 1032.0], [509.0, 1216.0], [485.0, 1216.0]]], "lines": ["今日、この日を", "軽く笑いとばせる"]}, {"box": [391, 1029, 444, 1171], "vertical": true, "font_size": 24, "lines_coords": [[[421.0, 1029.0], [444.0, 1029.0], [444.0, 1145.0], [421.0, 1145.0]], [[391.0, 1033.0], [410.0, 1033.0], [410.0, 1171.0], [391.0, 1171.0]]], "lines": ["そんな日が", "来るようにと"]}, {"box": [289, 1030, 318, 1112], "vertical": true, "font_size": 24, "lines_coords": [[[289.0, 1030.0], [318.0, 1030.0], [318.0, 1112.0], [289.0, 1112.0]]], "lines": ["祈った。"]}, {"box": [292, 1030, 349, 1239], "vertical": true, "font_size": 23, "lines_coords": [[[322.0, 1032.0], [345.0, 1032.0], [345.0, 1237.0], [322.0, 1237.0]]], "lines": ["あたしはこっそりと"]}], "img_path": "169.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [153, 1164, 216, 1183], "vertical": false, "font_size": 19, "lines_coords": [[[153.0, 1164.0], [216.0, 1164.0], [216.0, 1183.0], [153.0, 1183.0]]], "lines": ["なんじりにはなんと"]}], "img_path": "170.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "171.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [710, 82, 750, 188], "vertical": true, "font_size": 37, "lines_coords": [[[710.0, 82.0], [750.0, 82.0], [750.0, 188.0], [710.0, 188.0]]], "lines": ["ひゃっ"]}, {"box": [650, 191, 687, 340], "vertical": true, "font_size": 37, "lines_coords": [[[650.0, 191.0], [684.0, 191.0], [687.0, 340.0], [653.0, 340.0]]], "lines": ["ひゃっ！！"]}, {"box": [221, 127, 256, 306], "vertical": true, "font_size": 33, "lines_coords": [[[221.0, 127.0], [254.0, 127.0], [254.0, 306.0], [221.0, 306.0]]], "lines": ["ひゃおぅ！！"]}, {"box": [774, 429, 853, 554], "vertical": true, "font_size": 22, "lines_coords": [[[825.0, 429.0], [850.0, 429.0], [853.0, 530.0], [828.0, 530.0]], [[801.0, 430.0], [824.0, 430.0], [824.0, 522.0], [801.0, 522.0]], [[775.0, 430.0], [794.0, 430.0], [794.0, 553.0], [775.0, 553.0]]], "lines": ["こらこら、", "もう大人", "なんだから。"]}, {"box": [150, 474, 243, 787], "vertical": true, "font_size": 26, "lines_coords": [[[216.0, 474.0], [239.0, 474.0], [239.0, 612.0], [216.0, 612.0]], [[200.0, 668.0], [233.0, 668.0], [233.0, 723.0], [200.0, 723.0]], [[177.0, 671.0], [202.0, 671.0], [202.0, 787.0], [177.0, 787.0]], [[150.0, 671.0], [173.0, 671.0], [173.0, 787.0], [150.0, 787.0]]], "lines": ["．．．もしかして", "ガス", "止められて", "ないスか？"]}, {"box": [824, 877, 854, 936], "vertical": true, "font_size": 31, "lines_coords": [[[824.0, 877.0], [854.0, 877.0], [854.0, 936.0], [824.0, 936.0]]], "lines": ["．．．あ、"]}, {"box": [766, 932, 798, 967], "vertical": true, "font_size": 31, "lines_coords": [[[766.0, 932.0], [798.0, 932.0], [798.0, 967.0], [766.0, 967.0]]], "lines": ["あ"]}, {"box": [416, 906, 499, 1056], "vertical": true, "font_size": 24, "lines_coords": [[[474.0, 907.0], [499.0, 907.0], [499.0, 1000.0], [474.0, 1000.0]], [[445.0, 906.0], [470.0, 906.0], [471.0, 1056.0], [447.0, 1056.0]], [[416.0, 906.0], [440.0, 906.0], [440.0, 1007.0], [416.0, 1007.0]]], "lines": ["そういや", "ガス代、払って", "ないかも"]}, {"box": [775, 1127, 855, 1275], "vertical": true, "font_size": 23, "lines_coords": [[[831.0, 1127.0], [854.0, 1127.0], [854.0, 1250.0], [831.0, 1250.0]], [[801.0, 1130.0], [827.0, 1130.0], [827.0, 1266.0], [801.0, 1266.0]], [[775.0, 1129.0], [794.0, 1129.0], [794.0, 1274.0], [775.0, 1274.0]]], "lines": ["頼みますよ、", "一瞬、修行の", "ようでしたよ。"]}, {"box": [429, 1183, 482, 1320], "vertical": true, "font_size": 21, "lines_coords": [[[460.0, 1185.0], [479.0, 1185.0], [479.0, 1319.0], [460.0, 1319.0]], [[429.0, 1183.0], [452.0, 1183.0], [452.0, 1320.0], [429.0, 1320.0]]], "lines": ["あたしだけの", "責任かーい！！"]}, {"box": [191, 1000, 312, 1183], "vertical": true, "font_size": 25, "lines_coords": [[[287.0, 1002.0], [310.0, 1002.0], [310.0, 1138.0], [287.0, 1138.0]], [[252.0, 1000.0], [280.0, 1000.0], [280.0, 1183.0], [252.0, 1183.0]], [[221.0, 1000.0], [248.0, 1000.0], [248.0, 1163.0], [221.0, 1163.0]], [[191.0, 1000.0], [214.0, 1000.0], [214.0, 1159.0], [191.0, 1159.0]]], "lines": ["唯一の救いは", "思いのほか種田が", "平然としている", "ことだろうか？"]}], "img_path": "172.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [422, 94, 586, 144], "vertical": false, "font_size": 48, "lines_coords": [[[422.0, 97.0], [586.0, 94.0], [586.0, 142.0], [422.0, 144.0]]], "lines": ["キス"]}, {"box": [654, 591, 810, 779], "vertical": true, "font_size": 28, "lines_coords": [[[777.0, 593.0], [810.0, 593.0], [810.0, 652.0], [777.0, 652.0]], [[749.0, 594.0], [773.0, 594.0], [773.0, 709.0], [749.0, 709.0]], [[716.0, 591.0], [745.0, 591.0], [742.0, 734.0], [713.0, 734.0]], [[684.0, 593.0], [712.0, 593.0], [712.0, 779.0], [684.0, 779.0]], [[654.0, 594.0], [679.0, 594.0], [679.0, 700.0], [654.0, 700.0]]], "lines": ["結局、", "あの日以降", "種田バンドの", "デモＣＤの反応は", "無かった。"]}, {"box": [468, 593, 525, 752], "vertical": true, "font_size": 24, "lines_coords": [[[500.0, 593.0], [523.0, 593.0], [523.0, 751.0], [500.0, 751.0]], [[468.0, 593.0], [492.0, 593.0], [492.0, 716.0], [468.0, 716.0]]], "lines": ["さらりと８月は", "過ぎ去って、"]}, {"box": [200, 589, 320, 774], "vertical": true, "font_size": 24, "lines_coords": [[[296.0, 591.0], [319.0, 591.0], [319.0, 772.0], [296.0, 772.0]], [[262.0, 589.0], [291.0, 589.0], [288.0, 708.0], [259.0, 708.0]], [[231.0, 591.0], [254.0, 591.0], [254.0, 728.0], [231.0, 728.0]], [[200.0, 591.0], [220.0, 591.0], [220.0, 736.0], [200.0, 736.0]]], "lines": ["盛りを過ぎた夏は", "ゆっくりと", "秋の雰囲気に", "染まってゆく。"]}, {"box": [771, 828, 892, 999], "vertical": true, "font_size": 24, "lines_coords": [[[868.0, 832.0], [891.0, 832.0], [891.0, 967.0], [868.0, 967.0]], [[835.0, 831.0], [859.0, 831.0], [859.0, 929.0], [835.0, 929.0]], [[803.0, 829.0], [828.0, 829.0], [825.0, 991.0], [801.0, 991.0]], [[772.0, 828.0], [795.0, 828.0], [794.0, 999.0], [771.0, 999.0]]], "lines": ["会社を辞めて", "２か月半、", "人生でもっとも", "非生産的な期間。"]}, {"box": [540, 833, 626, 1052], "vertical": true, "font_size": 23, "lines_coords": [[[602.0, 833.0], [626.0, 833.0], [624.0, 995.0], [601.0, 995.0]], [[570.0, 833.0], [597.0, 833.0], [597.0, 996.0], [570.0, 996.0]], [[540.0, 836.0], [563.0, 836.0], [563.0, 1052.0], [540.0, 1052.0]]], "lines": ["仕事が無いなら", "無いで、毎日に", "ハリが無いというか。"]}, {"box": [435, 1029, 520, 1220], "vertical": true, "font_size": 85, "lines_coords": [[[435.0, 1029.0], [520.0, 1029.0], [520.0, 1220.0], [435.0, 1220.0]]], "lines": ["公共料金の支払いすらおっくうというか。"]}, {"box": [434, 1028, 519, 1222], "vertical": true, "font_size": 23, "lines_coords": [[[500.0, 1028.0], [519.0, 1028.0], [519.0, 1141.0], [500.0, 1141.0]], [[466.0, 1029.0], [489.0, 1029.0], [489.0, 1144.0], [466.0, 1144.0]], [[434.0, 1029.0], [458.0, 1029.0], [458.0, 1222.0], [434.0, 1222.0]]], "lines": ["公共料金の", "支払いすら", "おっくうというか。"]}, {"box": [127, 1151, 215, 1322], "vertical": true, "font_size": 23, "lines_coords": [[[191.0, 1153.0], [214.0, 1153.0], [214.0, 1290.0], [191.0, 1290.0]], [[159.0, 1153.0], [183.0, 1153.0], [183.0, 1291.0], [159.0, 1291.0]], [[128.0, 1151.0], [151.0, 1151.0], [150.0, 1322.0], [127.0, 1322.0]]], "lines": ["今のゆるーい", "幸せな感じは", "気持ちいいけど、"]}], "img_path": "173.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [766, 92, 887, 278], "vertical": true, "font_size": 24, "lines_coords": [[[858.0, 92.0], [887.0, 92.0], [887.0, 235.0], [858.0, 235.0]], [[829.0, 95.0], [853.0, 95.0], [853.0, 233.0], [829.0, 233.0]], [[798.0, 95.0], [821.0, 95.0], [821.0, 278.0], [798.0, 278.0]], [[768.0, 97.0], [787.0, 97.0], [787.0, 216.0], [768.0, 216.0]]], "lines": ["時折、自分が", "社会にまるで", "貢献してないのを", "思い出して、"]}, {"box": [391, 237, 508, 400], "vertical": true, "font_size": 22, "lines_coords": [[[489.0, 243.0], [508.0, 243.0], [508.0, 400.0], [489.0, 400.0]], [[453.0, 240.0], [478.0, 240.0], [478.0, 366.0], [453.0, 366.0]], [[422.0, 241.0], [445.0, 241.0], [445.0, 380.0], [422.0, 380.0]], [[391.0, 237.0], [414.0, 237.0], [415.0, 388.0], [392.0, 388.0]]], "lines": ["まるでこの世に", "存在しない、", "死人のような", "気分になって、"]}, {"box": [310, 122, 337, 294], "vertical": true, "font_size": 23, "lines_coords": [[[310.0, 144.0], [333.0, 144.0], [336.0, 289.0], [313.0, 289.0]]], "lines": ["．．．おかしいな。"]}, {"box": [660, 461, 707, 568], "vertical": true, "font_size": 47, "lines_coords": [[[660.0, 461.0], [707.0, 461.0], [707.0, 568.0], [660.0, 568.0]]], "lines": ["ひえぇ．．．"]}, {"box": [462, 448, 550, 622], "vertical": true, "font_size": 24, "lines_coords": [[[523.0, 448.0], [546.0, 448.0], [548.0, 622.0], [524.0, 622.0]]], "lines": ["すごく怖くなる。"]}, {"box": [462, 449, 515, 597], "vertical": true, "font_size": 22, "lines_coords": [[[492.0, 449.0], [515.0, 449.0], [515.0, 566.0], [492.0, 566.0]], [[462.0, 451.0], [481.0, 451.0], [481.0, 597.0], [462.0, 597.0]]], "lines": ["実はそんな", "夜もあるんだ。"]}, {"box": [145, 459, 265, 619], "vertical": true, "font_size": 22, "lines_coords": [[[239.0, 459.0], [262.0, 459.0], [262.0, 597.0], [239.0, 597.0]], [[207.0, 459.0], [231.0, 459.0], [231.0, 619.0], [207.0, 619.0]], [[174.0, 460.0], [198.0, 460.0], [198.0, 597.0], [174.0, 597.0]], [[146.0, 463.0], [165.0, 463.0], [165.0, 596.0], [146.0, 596.0]]], "lines": ["死んだように", "生きるのがヤで", "会社を辞めた", "ハスなのに？"]}, {"box": [720, 751, 841, 969], "vertical": true, "font_size": 24, "lines_coords": [[[816.0, 751.0], [839.0, 751.0], [839.0, 969.0], [816.0, 969.0]], [[782.0, 751.0], [809.0, 751.0], [809.0, 892.0], [782.0, 892.0]], [[750.0, 751.0], [775.0, 751.0], [775.0, 868.0], [750.0, 868.0]], [[720.0, 751.0], [743.0, 751.0], [743.0, 916.0], [720.0, 916.0]]], "lines": ["「自由になっちゃえば", "いいじゃん。」", "そう囁いた", "あの時の魔物が、"]}, {"box": [128, 747, 220, 888], "vertical": true, "font_size": 26, "lines_coords": [[[184.0, 747.0], [220.0, 747.0], [220.0, 810.0], [184.0, 810.0]], [[157.0, 751.0], [181.0, 751.0], [179.0, 888.0], [154.0, 888.0]], [[128.0, 754.0], [147.0, 754.0], [147.0, 887.0], [128.0, 887.0]]], "lines": ["実は、", "自由そのもの", "だとしたら？"]}, {"box": [777, 1060, 803, 1188], "vertical": true, "font_size": 24, "lines_coords": [[[777.0, 1063.0], [801.0, 1063.0], [803.0, 1188.0], [780.0, 1188.0]]], "lines": ["．．．くそっ。"]}, {"box": [142, 1159, 229, 1308], "vertical": true, "font_size": 26, "lines_coords": [[[203.0, 1160.0], [228.0, 1160.0], [228.0, 1275.0], [203.0, 1275.0]], [[169.0, 1159.0], [198.0, 1159.0], [198.0, 1242.0], [169.0, 1242.0]], [[142.0, 1160.0], [165.0, 1160.0], [165.0, 1308.0], [142.0, 1308.0]]], "lines": ["むずかしい", "もんだ。", "人生ってのは。"]}], "img_path": "174.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [766, 64, 823, 185], "vertical": true, "font_size": 25, "lines_coords": [[[799.0, 65.0], [823.0, 65.0], [823.0, 180.0], [799.0, 180.0]], [[766.0, 64.0], [791.0, 64.0], [792.0, 185.0], [768.0, 185.0]]], "lines": ["東京、東京", "と言っても、"]}, {"box": [639, 159, 730, 324], "vertical": true, "font_size": 25, "lines_coords": [[[706.0, 162.0], [730.0, 162.0], [730.0, 324.0], [706.0, 324.0]], [[674.0, 162.0], [697.0, 162.0], [697.0, 300.0], [674.0, 300.0]], [[639.0, 159.0], [669.0, 159.0], [669.0, 224.0], [639.0, 224.0]]], "lines": ["向こう岸はもう", "神奈川なんだ", "よね。"]}, {"box": [185, 185, 276, 373], "vertical": true, "font_size": 24, "lines_coords": [[[250.0, 185.0], [274.0, 185.0], [273.0, 371.0], [248.0, 371.0]], [[220.0, 187.0], [243.0, 187.0], [243.0, 333.0], [220.0, 333.0]], [[188.0, 188.0], [213.0, 188.0], [210.0, 347.0], [185.0, 347.0]]], "lines": ["じゃあ、この川は", "どこなんだぁー", "って思わない？"]}, {"box": [743, 671, 835, 829], "vertical": true, "font_size": 24, "lines_coords": [[[805.0, 671.0], [835.0, 672.0], [832.0, 750.0], [802.0, 749.0]], [[777.0, 671.0], [797.0, 671.0], [797.0, 829.0], [777.0, 829.0]], [[743.0, 671.0], [766.0, 671.0], [766.0, 795.0], [743.0, 795.0]]], "lines": ["つーか、", "なにげに初めて", "乗るよ、俺。"]}, {"box": [146, 691, 232, 874], "vertical": true, "font_size": 22, "lines_coords": [[[210.0, 694.0], [229.0, 694.0], [229.0, 805.0], [210.0, 805.0]], [[176.0, 691.0], [199.0, 691.0], [199.0, 873.0], [176.0, 873.0]], [[146.0, 691.0], [169.0, 691.0], [169.0, 839.0], [146.0, 839.0]]], "lines": ["後ろ向きに", "進むのってなんか", "不思議な感じ。"]}, {"box": [694, 1037, 753, 1153], "vertical": true, "font_size": 26, "lines_coords": [[[728.0, 1039.0], [751.0, 1039.0], [751.0, 1153.0], [728.0, 1153.0]], [[694.0, 1037.0], [723.0, 1037.0], [723.0, 1121.0], [694.0, 1121.0]]], "lines": ["風が気持ち", "いいな。"]}, {"box": [326, 1013, 352, 1106], "vertical": true, "font_size": 23, "lines_coords": [[[329.0, 1013.0], [352.0, 1013.0], [349.0, 1106.0], [326.0, 1106.0]]], "lines": ["なんだか"]}, {"box": [206, 1100, 293, 1225], "vertical": true, "font_size": 23, "lines_coords": [[[270.0, 1100.0], [293.0, 1100.0], [291.0, 1225.0], [267.0, 1225.0]], [[239.0, 1108.0], [262.0, 1108.0], [262.0, 1225.0], [239.0, 1225.0]], [[206.0, 1108.0], [229.0, 1108.0], [229.0, 1212.0], [206.0, 1212.0]]], "lines": ["どこまでも", "行けそうな", "気がする。"]}], "img_path": "175.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [691, 507, 715, 632], "vertical": true, "font_size": 19, "lines_coords": [[[693.0, 508.0], [712.0, 508.0], [712.0, 630.0], [693.0, 630.0]]], "lines": ["芽衣子さん。"]}, {"box": [261, 620, 292, 680], "vertical": true, "font_size": 31, "lines_coords": [[[261.0, 620.0], [292.0, 620.0], [292.0, 680.0], [261.0, 680.0]]], "lines": ["ん？"]}, {"box": [499, 855, 560, 962], "vertical": true, "font_size": 30, "lines_coords": [[[523.0, 855.0], [560.0, 855.0], [560.0, 913.0], [523.0, 913.0]], [[499.0, 859.0], [522.0, 859.0], [522.0, 962.0], [499.0, 962.0]]], "lines": ["俺達", "別れよう。"]}], "img_path": "176.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [505, 344, 530, 437], "vertical": true, "font_size": 24, "lines_coords": [[[505.0, 344.0], [530.0, 344.0], [530.0, 437.0], [505.0, 437.0]]], "lines": ["．．．なんで"]}, {"box": [429, 408, 482, 509], "vertical": true, "font_size": 24, "lines_coords": [[[458.0, 408.0], [482.0, 408.0], [482.0, 488.0], [458.0, 488.0]], [[429.0, 416.0], [452.0, 416.0], [452.0, 509.0], [429.0, 509.0]]], "lines": ["そんな", "急に．．．"]}, {"box": [170, 397, 203, 449], "vertical": true, "font_size": 29, "lines_coords": [[[170.0, 397.0], [203.0, 397.0], [203.0, 449.0], [170.0, 449.0]]], "lines": ["や．．．"]}, {"box": [144, 512, 169, 620], "vertical": true, "font_size": 29, "lines_coords": [[[144.0, 512.0], [169.0, 512.0], [169.0, 620.0], [144.0, 620.0]]], "lines": ["やだよ！？"]}, {"box": [764, 676, 884, 839], "vertical": true, "font_size": 24, "lines_coords": [[[861.0, 676.0], [884.0, 676.0], [881.0, 816.0], [858.0, 816.0]], [[828.0, 676.0], [853.0, 676.0], [850.0, 839.0], [825.0, 839.0]], [[795.0, 678.0], [820.0, 678.0], [820.0, 794.0], [795.0, 794.0]], [[764.0, 678.0], [787.0, 678.0], [787.0, 771.0], [764.0, 771.0]]], "lines": ["じゃあ２人で", "俺の実家行って", "親父の仕事", "手伝う？"]}, {"box": [838, 925, 894, 1108], "vertical": true, "font_size": 21, "lines_coords": [[[872.0, 926.0], [891.0, 926.0], [891.0, 1040.0], [872.0, 1040.0]], [[838.0, 926.0], [861.0, 926.0], [861.0, 1108.0], [838.0, 1108.0]]], "lines": ["種田：福岡", "帰るつもりなの？"]}, {"box": [386, 735, 472, 898], "vertical": true, "font_size": 22, "lines_coords": [[[448.0, 735.0], [471.0, 735.0], [468.0, 898.0], [445.0, 898.0]], [[415.0, 736.0], [438.0, 736.0], [437.0, 898.0], [414.0, 898.0]], [[386.0, 738.0], [406.0, 738.0], [406.0, 851.0], [386.0, 851.0]]], "lines": ["でも芽衣子さん", "東京離れるのも", "嫌でしょ？"]}, {"box": [170, 909, 225, 1055], "vertical": true, "font_size": 24, "lines_coords": [[[198.0, 909.0], [225.0, 909.0], [225.0, 959.0], [198.0, 959.0]], [[170.0, 910.0], [190.0, 910.0], [190.0, 1055.0], [170.0, 1055.0]]], "lines": ["前に", "言ったじゃん。"]}, {"box": [660, 1193, 716, 1342], "vertical": true, "font_size": 24, "lines_coords": [[[691.0, 1193.0], [716.0, 1193.0], [713.0, 1311.0], [689.0, 1311.0]], [[660.0, 1194.0], [683.0, 1194.0], [683.0, 1342.0], [660.0, 1342.0]]], "lines": ["それもアリ", "かなーって。"]}, {"box": [396, 1138, 452, 1300], "vertical": true, "font_size": 24, "lines_coords": [[[427.0, 1138.0], [452.0, 1138.0], [449.0, 1300.0], [425.0, 1300.0]], [[396.0, 1141.0], [419.0, 1141.0], [419.0, 1255.0], [396.0, 1255.0]]], "lines": ["だって．．．じゃあ", "バンドは？"]}, {"box": [127, 1136, 181, 1235], "vertical": true, "font_size": 24, "lines_coords": [[[157.0, 1138.0], [181.0, 1138.0], [181.0, 1230.0], [157.0, 1230.0]], [[127.0, 1136.0], [150.0, 1136.0], [150.0, 1235.0], [127.0, 1235.0]]], "lines": ["バンドは", "解散だよ。"]}], "img_path": "177.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [816, 95, 844, 199], "vertical": true, "font_size": 24, "lines_coords": [[[816.0, 95.0], [844.0, 95.0], [844.0, 199.0], [816.0, 199.0]]], "lines": ["．．．だって、"]}, {"box": [708, 179, 794, 303], "vertical": true, "font_size": 24, "lines_coords": [[[771.0, 179.0], [794.0, 179.0], [794.0, 281.0], [771.0, 281.0]], [[739.0, 187.0], [762.0, 187.0], [762.0, 303.0], [739.0, 303.0]], [[708.0, 188.0], [731.0, 188.0], [731.0, 302.0], [708.0, 302.0]]], "lines": ["そんなん", "種田らしく", "ないよ．．．"]}, {"box": [155, 162, 226, 303], "vertical": true, "font_size": 33, "lines_coords": [[[191.0, 162.0], [224.0, 162.0], [226.0, 303.0], [194.0, 303.0]], [[155.0, 165.0], [188.0, 165.0], [188.0, 276.0], [155.0, 276.0]]], "lines": ["．．．俺らしい", "って何？"]}, {"box": [768, 468, 855, 582], "vertical": true, "font_size": 22, "lines_coords": [[[832.0, 468.0], [855.0, 468.0], [855.0, 563.0], [832.0, 563.0]], [[801.0, 468.0], [824.0, 468.0], [824.0, 582.0], [801.0, 582.