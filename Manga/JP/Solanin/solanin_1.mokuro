739.0], [743.0, 921.0], [720.0, 921.0]], [[691.0, 738.0], [721.0, 738.0], [721.0, 823.0], [691.0, 823.0]]], "lines": ["君達はこの子の", "バックバンドとして", "ユニットを組んで", "ほしい。"]}, {"box": [145, 810, 262, 935], "vertical": true, "font_size": 23, "lines_coords": [[[237.0, 810.0], [262.0, 810.0], [259.0, 928.0], [235.0, 928.0]], [[206.0, 812.0], [231.0, 812.0], [231.0, 926.0], [206.0, 926.0]], [[174.0, 810.0], [198.0, 810.0], [198.0, 926.0], [174.0, 926.0]], [[146.0, 813.0], [165.0, 813.0], [165.0, 935.0], [146.0, 935.0]]], "lines": ["今年中には", "イベントや", "ＴＶ出演も", "あるだろう。"]}, {"box": [797, 1060, 816, 1174], "vertical": true, "font_size": 21, "lines_coords": [[[797.0, 1060.0], [816.0, 1060.0], [816.0, 1174.0], [797.0, 1174.0]]], "lines": ["どうだい？"]}, {"box": [634, 1110, 751, 1317], "vertical": true, "font_size": 21, "lines_coords": [[[727.0, 1110.0], [751.0, 1110.0], [749.0, 1249.0], [724.0, 1249.0]], [[698.0, 1112.0], [717.0, 1112.0], [717.0, 1225.0], [698.0, 1225.0]], [[664.0, 1111.0], [687.0, 1111.0], [687.0, 1317.0], [664.0, 1317.0]], [[634.0, 1112.0], [653.0, 1112.0], [653.0, 1226.0], [634.0, 1226.0]]], "lines": ["君達の人生で", "またとない", "最高のチャンスだと", "思うけど？"]}], "img_path": "159.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [768, 433, 869, 616], "vertical": true, "font_size": 23, "lines_coords": [[[850.0, 436.0], [869.0, 436.0], [869.0, 575.0], [850.0, 575.0]], [[823.0, 434.0], [842.0, 434.0], [842.0, 570.0], [823.0, 570.0]], [[792.0, 433.0], [816.0, 433.0], [816.0, 616.0], [792.0, 616.0]], [[768.0, 436.0], [787.0, 436.0], [787.0, 556.0], [768.0, 556.0]]], "lines": ["安心してくれ。", "よくある痛い", "アイドル歌手には", "しないから"]}, {"box": [661, 542, 750, 728], "vertical": true, "font_size": 23, "lines_coords": [[[725.0, 544.0], [750.0, 544.0], [750.0, 634.0], [725.0, 634.0]], [[694.0, 542.0], [721.0, 542.0], [721.0, 728.0], [694.0, 728.0]], [[664.0, 542.0], [689.0, 542.0], [686.0, 690.0], [661.0, 690.0]]], "lines": ["生っぽい", "バンドサウンドが", "彼女の希望だ。"]}, {"box": [248, 464, 367, 626], "vertical": true, "font_size": 23, "lines_coords": [[[348.0, 468.0], [367.0, 468.0], [367.0, 587.0], [348.0, 587.0]], [[314.0, 466.0], [337.0, 466.0], [337.0, 626.0], [314.0, 626.0]], [[283.0, 467.0], [306.0, 467.0], [306.0, 626.0], [283.0, 626.0]], [[248.0, 464.0], [277.0, 464.0], [277.0, 546.0], [248.0, 546.0]]], "lines": ["ひとみ自身、", "高校の文化祭で", "バンドの経験が", "あるし、"]}, {"box": [102, 537, 218, 742], "vertical": true, "font_size": 23, "lines_coords": [[[195.0, 537.0], [218.0, 537.0], [218.0, 720.0], [195.0, 720.0]], [[164.0, 538.0], [187.0, 538.0], [187.0, 742.0], [164.0, 742.0]], [[131.0, 537.0], [154.0, 537.0], [154.0, 720.0], [131.0, 720.0]], [[102.0, 538.0], [121.0, 538.0], [121.0, 683.0], [102.0, 683.0]]], "lines": ["歌詞はライターを", "つけず彼女に書かせ", "アーティスト的な", "売り方をする。"]}, {"box": [759, 785, 844, 932], "vertical": true, "font_size": 20, "lines_coords": [[[820.0, 786.0], [844.0, 786.0], [844.0, 877.0], [820.0, 877.0]], [[791.0, 787.0], [810.0, 787.0], [810.0, 922.0], [791.0, 922.0]], [[760.0, 787.0], [777.0, 787.0], [777.0, 926.0], [760.0, 926.0]]], "lines": ["．．．じゃあ", "５分で決めて", "もらえるかな"]}, {"box": [375, 985, 404, 1081], "vertical": true, "font_size": 29, "lines_coords": [[[375.0, 985.0], [404.0, 985.0], [404.0, 1081.0], [375.0, 1081.0]]], "lines": ["種田．．．"]}, {"box": [824, 1003, 880, 1163], "vertical": true, "font_size": 23, "lines_coords": [[[857.0, 1006.0], [880.0, 1006.0], [880.0, 1121.0], [857.0, 1121.0]], [[825.0, 1003.0], [849.0, 1003.0], [847.0, 1162.0], [824.0, 1162.0]]], "lines": ["．．．ところで", "君もメンバー？"]}, {"box": [601, 1203, 661, 1297], "vertical": true, "font_size": 26, "lines_coords": [[[633.0, 1203.0], [661.0, 1203.0], [661.0, 1285.0], [633.0, 1285.0]], [[601.0, 1203.0], [626.0, 1203.0], [628.0, 1297.0], [604.0, 1297.0]]], "lines": ["．．．いや、", "あの．．．"]}], "img_path": "160.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [445, 49, 473, 241], "vertical": true, "font_size": 28, "lines_coords": [[[445.0, 49.0], [47