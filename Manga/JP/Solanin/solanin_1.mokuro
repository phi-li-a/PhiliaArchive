[140.0, 200.0]], [[116.0, 139.0], [139.0, 139.0], [139.0, 252.0], [116.0, 252.0]]], "lines": ["いや、", "日記を．．．．．"]}, {"box": [356, 326, 412, 448], "vertical": true, "font_size": 24, "lines_coords": [[[388.0, 326.0], [412.0, 326.0], [412.0, 419.0], [388.0, 419.0]], [[356.0, 326.0], [380.0, 326.0], [380.0, 448.0], [356.0, 448.0]]], "lines": ["それよか", "芽衣子さん、"]}, {"box": [285, 403, 308, 541], "vertical": true, "font_size": 24, "lines_coords": [[[285.0, 403.0], [308.0, 403.0], [308.0, 541.0], [285.0, 541.0]]], "lines": ["ちょっと．．．"]}], "img_path": "182.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [701, 76, 724, 191], "vertical": true, "font_size": 21, "lines_coords": [[[701.0, 76.0], [724.0, 76.0], [724.0, 191.0], [701.0, 191.0]]], "lines": ["．．．えぇー？"]}, {"box": [604, 116, 656, 224], "vertical": true, "font_size": 21, "lines_coords": [[[633.0, 116.0], [656.0, 116.0], [656.0, 207.0], [633.0, 207.0]], [[604.0, 117.0], [623.0, 117.0], [623.0, 224.0], [604.0, 224.0]]], "lines": ["なになに", "とつぜんー"]}, {"box": [605, 236, 623, 274], "vertical": true, "font_size": 21, "lines_coords": [[[605.0, 236.0], [623.0, 236.0], [623.0, 274.0], [605.0, 274.0]]], "lines": ["ー？"]}, {"box": [392, 69, 415, 153], "vertical": true, "font_size": 22, "lines_coords": [[[392.0, 69.0], [415.0, 69.0], [415.0, 153.0], [392.0, 153.0]]], "lines": ["べつにー"]}, {"box": [298, 114, 351, 263], "vertical": true, "font_size": 22, "lines_coords": [[[328.0, 114.0], [351.0, 114.0], [351.0, 232.0], [328.0, 232.0]], [[298.0, 118.0], [317.0, 118.0], [317.0, 263.0], [298.0, 263.0]]], "lines": ["．．．ちょっと", "散歩してくる。"]}, {"box": [149, 361, 256, 565], "vertical": true, "font_size": 22, "lines_coords": [[[177.0, 445.0], [202.0, 445.0], [203.0, 564.0], [179.0, 564.0]], [[149.0, 449.0], [168.0, 449.0], [168.0, 563.0], [149.0, 563.0]]], "lines": ["すぐ帰って", "くるよね？"]}, {"box": [680, 674, 710, 772], "vertical": true, "font_size": 30, "lines_coords": [[[680.0, 674.0], [710.0, 674.0], [710.0, 712.0], [680.0, 712.0]]], "lines": ["んー"]}, {"box": [772, 1024, 837, 1199], "vertical": true, "font_size": 27, "lines_coords": [[[809.0, 1024.0], [836.0, 1024.0], [836.0, 1162.0], [809.0, 1162.0]], [[772.0, 1024.0], [799.0, 1024.0], [799.0, 1197.0], [772.0, 1197.0]]], "lines": ["．．．と言って", "出かけたきり、"]}, {"box": [161, 1086, 228, 1252], "vertical": true, "font_size": 27, "lines_coords": [[[196.0, 1086.0], [224.0, 1086.0], [226.0, 1250.0], [199.0, 1250.0]], [[161.0, 1086.0], [188.0, 1086.0], [188.0, 1235.0], [161.0, 1235.0]]], "lines": ["種田は帰って", "こなかった。"]}], "img_path": "183.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "184.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "185.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [714, 165, 835, 350], "vertical": true, "font_size": 26, "lines_coords": [[[806.0, 166.0], [835.0, 166.0], [835.0, 237.0], [806.0, 237.0]], [[772.0, 165.0], [801.0, 165.0], [803.0, 350.0], [775.0, 350.0]], [[745.0, 166.0], [768.0, 166.0], [768.0, 281.0], [745.0, 281.0]], [[715.0, 168.0], [738.0, 168.0], [738.0, 288.0], [715.0, 288.0]]], "lines": ["種田が", "「んー」と言って", "散歩に出て", "いってから、"]}, {"box": [207, 353, 265, 489], "vertical": true, "font_size": 24, "lines_coords": [[[239.0, 354.0], [262.0, 354.0], [262.0, 489.0], [239.0, 489.0]], [[207.0, 354.0], [232.0, 354.0], [232.0, 433.0], [207.0, 433.0]]], "lines": ["今日で５日が", "過ぎた。"]}, {"box": [715, 688, 802, 848], "vertical": true, "font_size": 22, "lines_coords": [[[779.0, 690.0], [799.0, 690.0], [798.0, 847.0], [777.0, 847.0]], [[746.0, 689.0], [769.0, 689.0], [769.0, 825.0], [746.0, 825.0]], [[715.0, 689.0], [738.0, 689.0], [738.0, 831.0], [715.0, 831.0]]], "lines": ["川に落ちた時に", "携帯は壊れて", "繋がらないし、"]}, {"box": [288, 868, 409, 1059], "vertical": true, "font_size": 23, "lines_coords": [[[386.0, 869.0], [406.0, 869.0], [406.0, 1004.0], [386.0, 1004.0]], [[352.0, 868.0], [377.0, 868.0], [374.0, 1006.0], [349.0, 1006.0]], [[321.0, 868.0], [344.0, 868.0], [344.0, 1028.0], [321.0, 1028.0]], [[288.0, 868.0], [311.0, 868.0], [313.0, 1059.0], [289.0, 1059.0]]], "lines": ["こんなことは", "初めてだけど", "意外となんとも", "思わなかったりで、"]}, {"box": [107, 1151, 158, 1287], "vertical": true, "font_size": 20, "lines_coords": [[[138.0, 1164.0], [158.0, 1164.0], [158.0, 1220.0], [138.0, 1220.0]], [[108.0, 1153.0], [127.0, 1153.0], [127.0, 1287.0], [108.0, 1287.0]]], "lines": ["．．．？？", "なんでだろ？"]}], "img_path": "186.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [449, 526, 508, 710], "vertical": true, "font_size": 26, "lines_coords": [[[479.0, 526.0], [507.0, 526.0], [507.0, 710.0], [479.0, 710.0]], [[449.0, 527.0], [474.0, 527.0], [475.0, 674.0], [451.0, 674.0]]], "lines": ["そして、あたしは", "風邪をひいた。"]}, {"box": [255, 786, 377, 1040], "vertical": true, "font_size": 24, "lines_coords": [[[351.0, 786.0], [374.0, 786.0], [374.0, 903.0], [351.0, 903.0]], [[317.0, 786.0], [344.0, 786.0], [344.0, 950.0], [317.0, 950.0]], [[287.0, 787.0], [310.0, 787.0], [310.0, 948.0], [287.0, 948.0]], [[257.0, 787.0], [280.0, 787.0], [280.0, 1040.0], [257.0, 1040.0]]], "lines": ["この数日間", "夢の中に何度か", "出てきた種田は", "いつも通りのあの感じで"]}, {"box": [110, 797, 374, 1277], "vertical": true, "font_size": 27, "lines_coords": [[[200.0, 1091.0], [228.0, 1091.0], [228.0, 1276.0], [200.0, 1276.0]], [[169.0, 1091.0], [198.0, 1091.0], [194.0, 1256.0], [165.0, 1256.0]], [[138.0, 1092.0], [162.0, 1092.0], [164.0, 1253.0], [139.0, 1253.0]]], "lines": ["その間、あたしも", "夢とは気づかず", "いつものように"]}, {"box": [107, 1089, 230, 1277], "vertical": true, "font_size": 23, "lines_coords": [[[108.0, 1092.0], [131.0, 1092.0], [131.0, 1194.0], [108.0, 1194.0]]], "lines": ["していた。"]}], "img_path": "187.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [769, 583, 792, 695], "vertical": true, "font_size": 23, "lines_coords": [[[769.0, 585.0], [792.0, 585.0], [792.0, 695.0], [769.0, 695.0]]], "lines": ["．．．あれ？"]}, {"box": [196, 909, 285, 1069], "vertical": true, "font_size": 22, "lines_coords": [[[261.0, 910.0], [284.0, 910.0], [284.0, 1047.0], [261.0, 1047.0]], [[228.0, 909.0], [252.0, 909.0], [252.0, 1003.0], [228.0, 1003.0]], [[198.0, 909.0], [218.0, 909.0], [217.0, 1069.0], [196.0, 1069.0]]], "lines": ["この部屋って", "こんなに", "広かったっけ？"]}], "img_path": "188.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [797, 91, 890, 207], "vertical": true, "font_size": 28, "lines_coords": [[[865.0, 95.0], [888.0, 95.0], [888.0, 196.0], [865.0, 196.0]], [[833.0, 94.0], [858.0, 94.0], [855.0, 207.0], [831.0, 207.0]], [[797.0, 91.0], [832.0, 91.0], [832.0, 155.0], [797.0, 155.0]]], "lines": ["種田さん、", "お届けもの", "です。"]}, {"box": [397, 458, 455, 583], "vertical": false, "font_size": 16.666666666666668, "lines_coords": [[[397.0, 525.0], [415.0, 458.0], [430.0, 462.0], [412.0, 529.0]], [[399.0, 574.0], [427.0, 462.0], [445.0, 466.0], [416.0, 578.0]], [[414.0, 579.0], [440.0, 471.0], [455.0, 475.0], [429.0, 583.0]]], "lines": ["．．．", "はっ、はあ、はい、", "いーい、いいですから！"]}, {"box": [395, 829, 519, 991], "vertical": true, "font_size": 24, "lines_coords": [[[492.0, 829.0], [516.0, 829.0], [519.0, 967.0], [494.0, 967.0]], [[460.0, 829.0], [483.0, 829.0], [483.0, 922.0], [460.0, 922.0]], [[430.0, 829.0], [453.0, 829.0], [453.0, 991.0], [430.0, 991.0]], [[399.0, 829.0], [423.0, 829.0], [419.0, 954.0], [395.0, 954.0]]], "lines": ["私は種田達の", "曲をまだ", "ちゃんと聴いて", "いなかった。"]}, {"box": [824, 642, 847, 787], "vertical": true, "font_size": 23, "lines_coords": [[[824.0, 642.0], [847.0, 642.0], [847.0, 783.0], [824.0, 783.0]]], "lines": ["．．．そういえば、"]}, {"box": [425, 1142, 496, 1168], "vertical": false, "font_size": 18, "lines_coords": [[[425.0, 1151.0], [493.0, 1142.0], [496.0, 1160.0], [427.0, 1168.0]]], "lines": ["ソラニン"]}, {"box": [425, 1162, 507, 1204], "vertical": false, "font_size": 14.5, "lines_coords": [[[440.0, 1173.0], [504.0, 1162.0], [507.0, 1177.0], [442.0, 1188.0]], [[425.0, 1190.0], [479.0, 1177.0], [483.0, 1190.0], [429.0, 1204.0]]], "lines": ["悪い思いがなかった。", "それが誰にも言わなかったかわから"]}, {"box": [486, 1179, 518, 1199], "vertical": false, "font_size": 13, "lines_coords": [[[486.0, 1186.0], [515.0, 1179.0], [518.0, 1192.0], [489.0, 1199.0]]], "lines": ["お見えちゃんと"]}, {"box": [418, 1208, 533, 1297], "vertical": false, "font_size": 26.25, "lines_coords": [[[418.0, 1216.0], [500.0, 1208.0], [504.0, 1245.0], [422.0, 1253.0]], [[442.0, 1241.0], [522.0, 1227.0], [529.0, 1264.0], [449.0, 1278.0]], [[456.0, 1268.0], [530.0, 1253.0], [533.0, 1268.0], [459.0, 1283.0]], [[458.0, 1282.0], [529.0, 1267.0], [531.0, 1282.0], [462.0, 1297.0]]], "lines": ["なんでもなかったんですか分からないけどなんかわかりましたね", "あの時か何かのところから言われてもいいのかも知れないかもしれませんでしたね．．．そんなこと言わ", "今はほんぶんとんだ言ってるんだって言葉も無かった。", "そんなんだっていう事も無駄だなよいけど．．．"]}], "img_path": "189.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [164, 72, 434, 214], "vertical": false, "font_size": 31.5, "lines_coords": [[[209.0, 72.0], [425.0, 75.0], [425.0, 112.0], [209.0, 109.0]], [[164.0, 117.0], [358.0, 112.0], [359.0, 144.0], [165.0, 150.0]], [[164.0, 155.0], [434.0, 150.0], [434.0, 179.0], [164.0, 184.0]], [[169.0, 187.0], [317.0, 187.0], [317.0, 214.0], [169.0, 214.0]]], "lines": ["思い違いは空の手だ", "さよならだけの人生が", "ほんの少しの未来は見えたのに", "さよならなんだ"]}, {"box": [132, 211, 512, 292], "vertical": false, "font_size": 40.0, "lines_coords": [[[132.0, 218.0], [512.0, 211.0], [512.0, 258.0], [132.0, 265.0]], [[133.0, 259.0], [478.0, 259.0], [478.0, 292.0], [133.0, 292.0]]], "lines": ["ここからなんだあの時こうしてお休みのみんながったら、", "であの頃の僕にはお尻かよいと"]}, {"box": [344, 302, 849, 391], "vertical": false, "font_size": 44.0, "lines_coords": [[[366.0, 310.0], [842.0, 302.0], [842.0, 343.0], [366.0, 351.0]], [[344.0, 344.0], [849.0, 344.0], [849.0, 391.0], [344.0, 391.0]]], "lines": ["お申込みにいた説明は今かれていただいたので、", "それでもいいじゃないでしょうかいですからねえっていう事も無駄にないんですね"]}, {"box": [436, 396, 710, 440], "vertical": false, "font_size": 37, "lines_coords": [[[436.0, 403.0], [710.0, 396.0], [710.0, 433.0], [436.0, 440.0]]], "lines": ["寒い冬のうえた右コーヒーとあたり"]}, {"box": [440, 440, 764, 605], "vertical": false, "font_size": 30.75, "lines_coords": [[[440.0, 440.0], [667.0, 440.0], [667.0, 468.0], [440.0, 468.0]], [[462.0, 478.0], [764.0, 471.0], [764.0, 504.0], [462.0, 511.0]], [[473.0, 520.0], [615.0, 520.0], [615.0, 549.0], [473.0, 549.0]], [[515.0, 572.0], [627.0, 572.0], [627.0, 605.0], [515.0, 605.0]]], "lines": ["お色が長いマフラーと", "小走りだ路地裏事を採けて", "思い出してみる", "また、返り"]}, {"box": [442, 616, 838, 713], "vertical": false, "font_size": 39.5, "lines_coords": [[[442.0, 631.0], [836.0, 616.0], [838.0, 653.0], [444.0, 668.0]], [[447.0, 671.0], [699.0, 660.0], [701.0, 702.0], [448.0, 713.0]]], "lines": ["ただ、何か幸せがだらい続いたわね", "きゃ悪い俺の事を出してもらった"]}, {"box": [449, 712, 783, 766], "vertical": false, "font_size": 30.0, "lines_coords": [[[449.0, 716.0], [660.0, 712.0], [660.0, 739.0], [449.0, 743.0]], [[650.0, 734.0], [782.0, 728.0], [783.0, 761.0], [652.0, 766.0]]], "lines": ["もうさよならなんだ", "友人が返り"]}, {"box": [415, 779, 757, 998], "vertical": false, "font_size": 119, "lines_coords": [[[415.0, 794.0], [747.0, 779.0], [757.0, 983.0], [425.0, 998.0]], [[466.0, 948.0], [566.0, 951.0], [564.0, 985.0], [464.0, 983.0]]], "lines": ["そんなこともわからなかった方法ですね。僕もどこにかかるとこれは", "おれよ"]}, {"box": [355, 1057, 427, 1281], "vertical": true, "font_size": 29, "lines_coords": [[[396.0, 1059.0], [425.0, 1059.0], [425.0, 1173.0], [396.0, 1173.0]], [[355.0, 1059.0], [384.0, 1059.0], [386.0, 1281.0], [358.0, 1281.0]]], "lines": ["これって", "別れの曲じゃん？"]}, {"box": [560, 1064, 588, 1173], "vertical": true, "font_size": 24, "lines_coords": [[[561.0, 1065.0], [585.0, 1065.0], [585.0, 1167.0], [561.0, 1167.0]]], "lines": ["．．種田あ"]}], "img_path": "190.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [822, 71, 866, 333], "vertical": true, "font_size": 42, "lines_coords": [[[823.0, 71.0], [865.0, 71.0], [865.0, 333.0], [823.0, 333.0]]], "lines": ["ほがががっ！！"]}, {"box": [783, 518, 888, 712], "vertical": true, "font_size": 26, "lines_coords": [[[857.0, 518.0], [885.0, 518.0], [888.0, 658.0], [859.0, 658.0]], [[823.0, 520.0], [846.0, 520.0], [846.0, 709.0], [823.0, 709.0]], [[783.0, 519.0], [810.0, 519.0], [810.0, 712.0], [783.0, 712.0]]], "lines": ["芽衣子っ！！", "台所の野菜達が", "大変なことに！！"]}, {"box": [326, 515, 432, 683], "vertical": true, "font_size": 26, "lines_coords": [[[403.0, 516.0], [430.0, 516.0], [427.0, 683.0], [400.0, 683.0]], [[365.0, 515.0], [392.0, 515.0], [389.0, 683.0], [362.0, 683.0]], [[326.0, 519.0], [351.0, 519.0], [351.0, 627.0], [326.0, 627.0]]], "lines": ["ジャガイモが", "ちょっとした", "妖怪に！！"]}, {"box": [165, 296, 209, 404], "vertical": true, "font_size": 44, "lines_coords": [[[165.0, 296.0], [209.0, 296.0], [209.0, 404.0], [165.0, 404.0]]], "lines": ["うわー"]}, {"box": [106, 356, 158, 475], "vertical": true, "font_size": 44, "lines_coords": [[[114.0, 356.0], [158.0, 360.0], [150.0, 475.0], [106.0, 471.0]]], "lines": ["ーっ！！"]}, {"box": [799, 820, 888, 980], "vertical": true, "font_size": 21, "lines_coords": [[[866.0, 821.0], [885.0, 821.0], [885.0, 940.0], [866.0, 940.0]], [[833.0, 820.0], [853.0, 820.0], [853.0, 978.0], [833.0, 978.0]], [[801.0, 820.0], [824.0, 820.0], [823.0, 980.0], [799.0, 980.0]]], "lines": ["種田のやつ、", "こんな時にどこ", "行ってんだか．．"]}, {"box": [552, 869, 572, 900], "vertical": true, "font_size": 22, "lines_coords": [[[552.0, 869.0], [572.0, 869.0], [572.0, 900.0], [552.0, 900.0]]], "lines": ["．．．"]}, {"box": [519, 827, 544, 974], "vertical": true, "font_size": 22, "lines_coords": [[[520.0, 827.0], [544.0, 827.0], [542.0, 974.0], [519.0, 974.0]]], "lines": ["もしかしたら、"]}, {"box": [140, 656, 164, 778], "vertical": true, "font_size": 24, "lines_coords": [[[140.0, 656.0], [164.0, 656.0], [164.0, 777.0], [140.0, 777.0]]], "lines": ["うるさい。"]}, {"box": [125, 891, 214, 1063], "vertical": true, "font_size": 23, "lines_coords": [[[190.0, 894.0], [213.0, 894.0], [211.0, 1055.0], [188.0, 1055.0]], [[158.0, 894.0], [181.0, 894.0], [181.0, 1032.0], [158.0, 1032.0]], [[127.0, 891.0], [150.0, 891.0], [149.0, 1062.0], [125.0, 1062.0]]], "lines": ["種田は前々から", "別れるつもり", "だったのかもね。"]}, {"box": [609, 1151, 697, 1334], "vertical": true, "font_size": 24, "lines_coords": [[[667.0, 1151.0], [697.0, 1151.0], [697.0, 1231.0], [667.0, 1231.0]], [[638.0, 1151.0], [661.0, 1151.0], [663.0, 1334.0], [639.0, 1334.0]], [[609.0, 1153.0], [628.0, 1153.0], [628.0, 1309.0], [609.0, 1309.0]]], "lines": ["芽衣子、", "なんか食べなきゃ", "死んじゃうよ？"]}, {"box": [153, 1177, 178, 1315], "vertical": true, "font_size": 20, "lines_coords": [[[153.0, 1177.0], [177.0, 1177.0], [177.0, 1252.0], [153.0, 1252.0]], [[155.0, 1275.0], [172.0, 1275.0], [172.0, 1311.0], [155.0, 1311.0]]], "lines": ["はぁー", "！？"]}], "img_path": "191.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [814, 92, 833, 195], "vertical": true, "font_size": 23, "lines_coords": [[[814.0, 92.0], [833.0, 92.0], [833.0, 195.0], [814.0, 195.0]]], "lines": ["まさかぁー"]}, {"box": [671, 203, 788, 400], "vertical": true, "font_size": 23, "lines_coords": [[[769.0, 206.0], [788.0, 206.0], [788.0, 296.0], [769.0, 296.0]], [[734.0, 203.0], [758.0, 203.0], [760.0, 344.0], [735.0, 344.0]], [[704.0, 205.0], [727.0, 205.0], [727.0, 400.0], [704.0, 400.0]], [[671.0, 205.0], [699.0, 205.0], [699.0, 363.0], [671.0, 363.0]]], "lines": ["こんなに", "荷物残して？", "ていうか、他に行く", "所無いじゃん。"]}, {"box": [83, 90, 203, 277], "vertical": true, "font_size": 24, "lines_coords": [[[179.0, 90.0], [202.0, 90.0], [199.0, 257.0], [176.0, 257.0]], [[147.0, 91.0], [172.0, 91.0], [169.0, 252.0], [144.0, 252.0]], [[112.0, 91.0], [139.0, 91.0], [139.0, 277.0], [112.0, 277.0]], [[83.0, 94.0], [106.0, 94.0], [106.0, 195.0], [83.0, 195.0]]], "lines": ["でもこの５日間", "不思議なくらい", "あたし、気持ちが", "楽なんだ。"]}, {"box": [499, 381, 552, 572], "vertical": true, "font_size": 21, "lines_coords": [[[527.0, 381.0], [550.0, 381.0], [550.0, 568.0], [527.0, 568.0]], [[499.0, 384.0], [518.0, 384.0], [518.0, 529.0], [499.0, 529.0]]], "lines": ["なんでそんなこと", "さらっと言う。"]}, {"box": [112, 455, 200, 594], "vertical": true, "font_size": 23, "lines_coords": [[[174.0, 456.0], [198.0, 456.0], [198.0, 553.0], [174.0, 553.0]], [[143.0, 455.0], [166.0, 455.0], [166.0, 593.0], [143.0, 593.0]], [[112.0, 456.0], [135.0, 456.0], [135.0, 594.0], [112.0, 594.0]]], "lines": ["あんた達、", "今さら別れる", "なんてさぁ．．．"]}, {"box": [619, 678, 706, 838], "vertical": true, "font_size": 24, "lines_coords": [[[683.0, 678.0], [706.0, 678.0], [706.0, 814.0], [683.0, 814.0]], [[652.0, 678.0], [675.0, 678.0], [675.0, 838.0], [652.0, 838.0]], [[619.0, 678.0], [642.0, 678.0], [642.0, 792.0], [619.0, 792.0]]], "lines": ["大体これじゃ", "捨てられたって", "ことだよ？"]}, {"box": [522, 745, 579, 905], "vertical": true, "font_size": 24, "lines_coords": [[[550.0, 745.0], [579.0, 745.0], [579.0, 827.0], [550.0, 827.0]], [[522.0, 745.0], [545.0, 745.0], [545.0, 905.0], [522.0, 905.0]]], "lines": ["あんた、", "悲しくないの？"]}, {"box": [311, 829, 335, 946], "vertical": true, "font_size": 23, "lines_coords": [[[311.0, 829.0], [334.0, 829.0], [334.0, 944.0], [311.0, 944.0]]], "lines": ["だって．．．"]}, {"box": [561, 1039, 587, 1203], "vertical": true, "font_size": 24, "lines_coords": [[[561.0, 1039.0], [585.0, 1039.0], [587.0, 1203.0], [564.0, 1203.0]]], "lines": ["ふられて当然だ。"]}, {"box": [463, 1036, 520, 1220], "vertical": true, "font_size": 24, "lines_coords": [[[493.0, 1036.0], [520.0, 1036.0], [520.0, 1220.0], [493.0, 1220.0]], [[463.0, 1039.0], [486.0, 1039.0], [486.0, 1177.0], [463.0, 1177.0]]], "lines": ["だって、あたしは", "この数か月間"]}, {"box": [365, 1037, 418, 1252], "vertical": true, "font_size": 24, "lines_coords": [[[395.0, 1037.0], [418.0, 1037.0], [418.0, 1173.0], [395.0, 1173.0]], [[365.0, 1039.0], [388.0, 1039.0], [388.0, 1252.0], [365.0, 1252.0]]], "lines": ["種田を苦しめ", "続けてきたんだから。"]}], "img_path": "192.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [695, 133, 812, 317], "vertical": true, "font_size": 20, "lines_coords": [[[790.0, 136.0], [809.0, 136.0], [809.0, 293.0], [790.0, 293.0]], [[758.0, 136.0], [777.0, 136.0], [777.0, 293.0], [758.0, 293.0]], [[724.0, 133.0], [747.0, 133.0], [747.0, 250.0], [724.0, 250.0]], [[695.0, 135.0], [715.0, 135.0], [715.0, 315.0], [695.0, 315.0]]], "lines": ["あたしが会社を", "辞めたいと思う", "ようになる", "ちょっと前から："]}, {"box": [697, 488, 755, 677], "vertical": true, "font_size": 23, "lines_coords": [[[730.0, 490.0], [753.0, 490.0], [753.0, 671.0], [730.0, 671.0]], [[697.0, 490.0], [720.0, 490.0], [720.0, 676.0], [697.0, 676.0]]], "lines": ["２人のずっと先の", "未来が見えてきて、"]}, {"box": [423, 489, 578, 657], "vertical": true, "font_size": 24, "lines_coords": [[[552.0, 489.0], [575.0, 489.0], [575.0, 626.0], [552.0, 626.0]], [[518.0, 489.0], [542.0, 489.0], [544.0, 626.0], [519.0, 626.0]], [[488.0, 492.0], [511.0, 492.0], [511.0, 607.0], [488.0, 607.0]], [[455.0, 489.0], [482.0, 489.0], [482.0, 628.0], [455.0, 628.0]], [[423.0, 490.0], [447.0, 490.0], [447.0, 653.0], [423.0, 653.0]]], "lines": ["それは決して", "悪いものでは", "なかったし", "決して嫌では", "ないはずなのに"]}, {"box": [244, 487, 302, 681], "vertical": true, "font_size": 23, "lines_coords": [[[277.0, 489.0], [300.0, 489.0], [300.0, 605.0], [277.0, 605.0]], [[244.0, 490.0], [267.0, 490.0], [267.0, 678.0], [244.0, 678.0]]], "lines": ["その未来に", "確信が持てなくて、"]}, {"box": [760, 761, 788, 865], "vertical": true, "font_size": 24, "lines_coords": [[[760.0, 761.0], [783.0, 761.0], [786.0, 864.0], [762.0, 864.0]]], "lines": ["．．．毎日が、"]}, {"box": [174, 868, 232, 973], "vertical": true, "font_size": 26, "lines_coords": [[[203.0, 868.0], [232.0, 868.0], [232.0, 944.0], [203.0, 944.0]], [[174.0, 870.0], [198.0, 870.0], [198.0, 972.0], [174.0, 972.0]]], "lines": ["すごく", "怖かった。"]}, {"box": [679, 1088, 770, 1296], "vertical": true, "font_size": 23, "lines_coords": [[[743.0, 1092.0], [766.0, 1092.0], [766.0, 1294.0], [743.0, 1294.0]], [[710.0, 1091.0], [734.0, 1091.0], [734.0, 1229.0], [710.0, 1229.0]], [[679.0, 1092.0], [702.0, 1092.0], [702.0, 1188.0], [679.0, 1188.0]]], "lines": ["二度とその場所から", "抜け出せない", "気がして、"]}, {"box": [483, 1089, 575, 1273], "vertical": true, "font_size": 27, "lines_coords": [[[546.0, 1091.0], [575.0, 1091.0], [575.0, 1185.0], [546.0, 1185.0]], [[518.0, 1089.0], [542.0, 1089.0], [541.0, 1272.0], [516.0, 1272.0]], [[483.0, 1089.0], [511.0, 1089.0], [511.0, 1235.0], [483.0, 1235.0]]], "lines": ["お互いに", "やり残した何かが", "ある気もして、"]}, {"box": [235, 1088, 358, 1319], "vertical": true, "font_size": 27, "lines_coords": [[[332.0, 1089.0], [358.0, 1089.0], [355.0, 1182.0], [329.0, 1182.0]], [[299.0, 1089.0], [326.0, 1089.0], [326.0, 1253.0], [299.0, 1253.0]], [[267.0, 1089.0], [295.0, 1089.0], [295.0, 1319.0], [267.0, 1319.0]], [[235.0, 1088.0], [263.0, 1088.0], [263.0, 1171.0], [235.0, 1171.0]]], "lines": ["それなら", "不安を一つ一つ", "消していってやろうと", "思った。"]}], "img_path": "193.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [768, 101, 793, 216], "vertical": true, "font_size": 20, "lines_coords": [[[771.0, 101.0], [791.0, 101.0], [788.0, 216.0], [768.0, 216.0]]], "lines": ["どうにか．．"]}, {"box": [177, 173, 264, 336], "vertical": true, "font_size": 22, "lines_coords": [[[239.0, 177.0], [262.0, 177.0], [262.0, 289.0], [239.0, 289.0]], [[207.0, 173.0], [231.0, 173.0], [231.0, 336.0], [207.0, 336.0]], [[177.0, 176.0], [196.0, 176.0], [196.0, 291.0], [177.0, 291.0]]], "lines": ["いい方向に", "もっていこうと", "したけど．．．"]}, {"box": [710, 411, 769, 596], "vertical": true, "font_size": 26, "lines_coords": [[[741.0, 411.0], [769.0, 411.0], [769.0, 507.0], [741.0, 507.0]], [[710.0, 411.0], [734.0, 411.0], [734.0, 594.0], [710.0, 594.0]]], "lines": ["夢の中で", "走ってるみたいに"]}, {"box": [575, 411, 633, 583], "vertical": true, "font_size": 26, "lines_coords": [[[608.0, 412.0], [633.0, 412.0], [633.0, 527.0], [608.0, 527.0]], [[575.0, 411.0], [602.0, 411.0], [602.0, 583.0], [575.0, 583.0]]], "lines": ["思うように", "前に進めなくて、"]}, {"box": [416, 412, 440, 529], "vertical": true, "font_size": 19, "lines_coords": [[[418.0, 412.0], [437.0, 412.0], [437.0, 526.0], [418.0, 526.0]]], "lines": ["その間にも"]}, {"box": [261, 410, 349, 601], "vertical": true, "font_size": 26, "lines_coords": [[[319.0, 411.0], [347.0, 411.0], [349.0, 572.0], [322.0, 572.0]], [[289.0, 410.0], [317.0, 410.0], [317.0, 596.0], [289.0, 596.0]], [[261.0, 412.0], [284.0, 412.0], [284.0, 601.0], [261.0, 601.0]]], "lines": ["あたしと種田の", "心のちょっとした", "ズレを感じてきて、"]}, {"box": [272, 704, 291, 839], "vertical": true, "font_size": 22, "lines_coords": [[[272.0, 704.0], [291.0, 704.0], [291.0, 839.0], [272.0, 839.0]]], "lines": ["もうなんか．．"]}, {"box": [136, 783, 224, 946], "vertical": true, "font_size": 22, "lines_coords": [[[200.0, 783.0], [224.0, 783.0], [224.0, 899.0], [200.0, 899.0]], [[168.0, 786.0], [192.0, 786.0], [192.0, 877.0], [168.0, 877.0]], [[136.0, 784.0], [159.0, 784.0], [159.0, 946.0], [136.0, 946.0]]], "lines": ["どうしたら", "いいのか", "わからなくて．．"]}, {"box": [693, 1064, 751, 1201], "vertical": true, "font_size": 26, "lines_coords": [[[721.0, 1065.0], [749.0, 1065.0], [751.0, 1200.0], [724.0, 1200.0]], [[693.0, 1065.0], [717.0, 1065.0], [719.0, 1200.0], [694.0, 1200.0]]], "lines": ["いい意味でも", "悪い意味でも"]}, {"box": [426, 1064, 549, 1226], "vertical": true, "font_size": 26, "lines_coords": [[[519.0, 1065.0], [549.0, 1065.0], [549.0, 1138.0], [519.0, 1138.0]], [[488.0, 1065.0], [515.0, 1065.0], [515.0, 1226.0], [488.0, 1226.0]], [[456.0, 1065.0], [483.0, 1065.0], [483.0, 1204.0], [456.0, 1204.0]], [[429.0, 1066.0], [448.0, 1066.0], [448.0, 1182.0], [429.0, 1182.0]]], "lines": ["種田は", "あたしにとって", "空気みたいな", "存在だから"]}, {"box": [213, 1063, 339, 1272], "vertical": true, "font_size": 27, "lines_coords": [[[308.0, 1063.0], [339.0, 1063.0], [339.0, 1122.0], [308.0, 1122.0]], [[276.0, 1063.0], [303.0, 1063.0], [306.0, 1272.0], [278.0, 1272.0]], [[244.0, 1065.0], [269.0, 1065.0], [272.0, 1204.0], [247.0, 1204.0]], [[213.0, 1066.0], [236.0, 1066.0], [239.0, 1211.0], [216.0, 1211.0]]], "lines": ["もし、", "いつかいなくなって", "し