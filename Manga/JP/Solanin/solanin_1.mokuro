": 22, "lines_coords": [[[213.0, 241.0], [237.0, 241.0], [240.0, 382.0], [216.0, 382.0]], [[187.0, 247.0], [206.0, 247.0], [206.0, 366.0], [187.0, 366.0]]], "lines": ["それだけでも", "今決めよう。"]}, {"box": [812, 574, 905, 736], "vertical": true, "font_size": 26, "lines_coords": [[[871.0, 574.0], [905.0, 574.0], [905.0, 650.0], [871.0, 650.0]], [[845.0, 576.0], [868.0, 576.0], [868.0, 736.0], [845.0, 736.0]], [[812.0, 575.0], [835.0, 575.0], [835.0, 735.0], [812.0, 735.0]]], "lines": ["つーか", "冷静に考えても", "うまくいくか？"]}, {"box": [466, 404, 586, 567], "vertical": true, "font_size": 24, "lines_coords": [[[564.0, 406.0], [583.0, 406.0], [583.0, 542.0], [564.0, 542.0]], [[530.0, 404.0], [555.0, 404.0], [551.0, 566.0], [526.0, 566.0]], [[496.0, 406.0], [525.0, 406.0], [525.0, 567.0], [496.0, 567.0]], [[466.0, 406.0], [489.0, 406.0], [489.0, 526.0], [466.0, 526.0]]], "lines": ["行動する前に", "結論出したがる", "のは、俺の悪い", "クセだよね。"]}, {"box": [712, 658, 768, 773], "vertical": true, "font_size": 26, "lines_coords": [[[743.0, 658.0], [768.0, 658.0], [768.0, 773.0], [743.0, 773.0]], [[712.0, 658.0], [735.0, 658.0], [735.0, 750.0], [712.0, 750.0]]], "lines": ["バンドぉ？", "音楽ぅ？"]}, {"box": [771, 865, 892, 1033], "vertical": true, "font_size": 25, "lines_coords": [[[866.0, 865.0], [890.0, 865.0], [888.0, 1029.0], [865.0, 1029.0]], [[835.0, 866.0], [858.0, 866.0], [858.0, 1026.0], [835.0, 1026.0]], [[804.0, 868.0], [827.0, 868.0], [827.0, 1025.0], [804.0, 1025.0]], [[771.0, 866.0], [801.0, 866.0], [801.0, 928.0], [771.0, 928.0]]], "lines": ["そもそもこの話", "芽衣子の言葉に", "流されただけっ", "しょ。"]}, {"box": [504, 857, 598, 1021], "vertical": true, "font_size": 26, "lines_coords": [[[570.0, 859.0], [598.0, 859.0], [598.0, 958.0], [570.0, 958.0]], [[541.0, 859.0], [564.0, 859.0], [564.0, 1021.0], [541.0, 1021.0]], [[504.0, 857.0], [540.0, 857.0], [540.0, 922.0], [504.0, 922.0]]], "lines": ["．．．たとえ", "うまくいかなく", "ても、"]}, {"box": [402, 937, 489, 1099], "vertical": true, "font_size": 26, "lines_coords": [[[464.0, 937.0], [489.0, 937.0], [489.0, 1032.0], [464.0, 1032.0]], [[433.0, 937.0], [456.0, 937.0], [456.0, 1099.0], [433.0, 1099.0]], [[402.0, 939.0], [426.0, 939.0], [426.0, 1062.0], [402.0, 1062.0]]], "lines": ["芽衣子が", "それで満足なら", "いいと思う。"]}, {"box": [155, 609, 217, 795], "vertical": true, "font_size": 26, "lines_coords": [[[192.0, 613.0], [216.0, 613.0], [216.0, 794.0], [192.0, 794.0]], [[158.0, 609.0], [185.0, 609.0], [183.0, 795.0], [155.0, 795.0]]], "lines": ["やってみなくちゃ", "わかんないって！！"]}, {"box": [616, 1168, 708, 1307], "vertical": true, "font_size": 25, "lines_coords": [[[683.0, 1171.0], [708.0, 1171.0], [708.0, 1286.0], [683.0, 1286.0]], [[650.0, 1170.0], [675.0, 1170.0], [675.0, 1264.0], [650.0, 1264.0]], [[619.0, 1168.0], [644.0, 1168.0], [641.0, 1307.0], [616.0, 1307.0]]], "lines": ["いや、でも", "芽衣子は", "本気だった！！"]}, {"box": [362, 1285, 505, 1330], "vertical": false, "font_size": 39, "lines_coords": [[[363.0, 1285.0], [505.0, 1291.0], [504.0, 1330.0], [362.0, 1323.0]]], "lines": ["待疑ハ"]}, {"box": [239, 1044, 265, 1158], "vertical": true, "font_size": 24, "lines_coords": [[[239.0, 1044.0], [265.0, 1044.0], [265.0, 1091.0], [239.0, 1091.0]], [[240.0, 1088.0], [262.0, 1088.0], [262.0, 1158.0], [240.0, 1158.0]]], "lines": ["バー", "ーカ！！"]}, {"box": [117, 1168, 237, 1354], "vertical": true, "font_size": 24, "lines_coords": [[[213.0, 1171.0], [237.0, 1171.0], [237.0, 1266.0], [213.0, 1266.0]], [[181.0, 1170.0], [206.0, 1170.0], [203.0, 1311.0], [179.0, 1311.0]], [[147.0, 1168.0], [170.0, 1168.0], [173.0, 1354.0], [150.0, 1354.0]], [[117.0, 1171.0], [142.0, 1171.0], [142.0, 1263.0], [117.0, 1263.0]]], "lines": ["女なんて", "いつ裏切るか", "わかったもんじゃ", "ねーぞ！！"]}], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 971, "img_height": 1400, "blocks": [{"box": [759, 129, 878, 317], "vertical": true, "font_size": 25, "lines_coords": [[[854.0, 131.0], [878.0, 131.0], [878.0, 269.0], [854.0, 269.0]], [[820.0, 129.0], [845.0, 129.0], [847.0, 248.0], [823.0, 248.0]], [[789.0, 132.0], [816.0, 132.0], [816.0, 317.0], [789.0, 317.0]], [[759.0, 133.0], [782.0, 133.0], [782.0, 246.0], [759.0, 246.0]]], "lines": ["それよか俺と", "芽衣子って", "いつまで付き合う", "のかなぁ？"]}, {"box": [613, 40, 629, 114], "vertical": true, "font_size": 16, "lines_coords": [[[613.0, 40.0], [629.0, 40.0], [629.0, 114.0], [613.0, 114.0]]], "lines": ["うーん"]}, {"box": [544, 119, 565, 202], "vertical": true, "font_size": 21, "lines_coords": [[[544.0, 119.0], [565.0, 119.0], [565.0, 202.0], [544.0, 202.0]]], "lines": ["うーん"]}, {"box": [343, 246, 433, 406], "vertical": true, "font_size": 26, "lines_coords": [[[406.0, 246.0], [430.0, 246.0], [432.0, 385.0], [407.0, 385.0]], [[376.0, 246.0], [400.0, 246.0], [397.0, 406.0], [373.0, 406.0]], [[343.0, 246.0], [371.0, 246.0], [371.0, 328.0], [343.0, 328.0]]], "lines": ["芽衣子さんて", "基本的にマグロ", "だよね。"]}, {"box": [147, 73, 211, 269], "vertical": true, "font_size": 27, "lines_coords": [[[184.0, 73.0], [211.0, 73.0], [211.0, 240.0], [184.0, 240.0]], [[147.0, 73.0], [175.0, 73.0], [175.0, 269.0], [147.0, 269.0]]], "lines": ["うぎゃああっ", "ラチがあかん！！"]}, {"box": [769, 474, 860, 568], "vertical": true, "font_size": 28, "lines_coords": [[[831.0, 474.0], [860.0, 474.0], [860.0, 546.0], [831.0, 546.0]], [[801.0, 474.0], [826.0, 474.0], [826.0, 567.0], [801.0, 567.0]], [[769.0, 474.0], [798.0, 474.0], [798.0, 568.0], [769.0, 568.0]]], "lines": ["なんか", "どーでも", "よくね？"]}, {"box": [347, 453, 460, 662], "vertical": true, "font_size": 24, "lines_coords": [[[433.0, 453.0], [458.0, 453.0], [459.0, 638.0], [434.0, 638.0]], [[404.0, 456.0], [429.0, 456.0], [429.0, 552.0], [404.0, 552.0]], [[373.0, 456.0], [396.0, 456.0], [400.0, 661.0], [377.0, 661.0]], [[347.0, 456.0], [370.0, 456.0], [370.0, 581.0], [347.0, 581.0]]], "lines": ["どーせ日本経済は", "破綻して", "ロクでもない未来が", "待ってんだ。"]}, {"box": [82, 298, 149, 500], "vertical": true, "font_size": 27, "lines_coords": [[[121.0, 299.0], [147.0, 299.0], [149.0, 411.0], [123.0, 411.0]], [[82.0, 298.0], [110.0, 298.0], [113.0, 500.0], [84.0, 500.0]]], "lines": ["強行採決", "じゃあ～～っ！！"]}, {"box": [626, 671, 882, 965], "vertical": true, "font_size": 256, "lines_coords": [[[626.0, 671.0], [882.0, 671.0], [882.0, 965.0], [626.0, 965.0]]], "lines": ["わぁあぁ"]}, {"box": [456, 695, 493, 784], "vertical": true, "font_size": 33, "lines_coords": [[[456.0, 697.0], [490.0, 695.0], [493.0, 783.0], [459.0, 784.0]]], "lines": ["牛歩！！"]}, {"box": [374, 765, 443, 853], "vertical": true, "font_size": 33, "lines_coords": [[[413.0, 765.0], [443.0, 765.0], [443.0, 849.0], [413.0, 849.0]], [[374.0, 765.0], [408.0, 765.0], [408.0, 853.0], [374.0, 853.0]]], "lines": ["牛歩！！", "牛歩！！"]}, {"box": [116, 847, 206, 987], "vertical": true, "font_size": 46, "lines_coords": [[[157.0, 847.0], [206.0, 847.0], [206.0, 987.0], [157.0, 987.0]], [[116.0, 850.0], [160.0, 850.0], [160.0, 984.0], [116.0, 984.0]]], "lines": ["ギャハハ", "ハハハ！！"]}, {"box": [810, 1151, 843, 1205], "vertical": true, "font_size": 31, "lines_coords": [[[810.0, 1151.0], [843.0, 1151.0], [843.0, 1205.0], [810.0, 1205.0]]], "lines": ["牛歩"]}, {"box": [775, 1193, 804, 1271], "vertical": true, "font_size": 31, "lines_coords": [[[775.0, 1193.0], [804.0, 1193.0], [804.0, 1271.0], [775.0, 1271.0]]], "lines": ["牛歩．．．"]}, {"box": [98, 1153, 168, 1305], "vertical": true, "font_size": 29, "lines_coords": [[[139.0, 1156.0], [168.0, 1156.0], [168.0, 1267.0], [139.0, 1267.0]], [[98.0, 1153.0], [127.0, 1153.0], [131.0, 1305.0], [102.0, 1305.0]]], "lines": ["．．．．．．考え", "まとまらず。"]}], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [818, 82, 907, 265], "vertical": true, "font_size": 24, "lines_coords": [[[880.0, 82.0], [907.0, 82.0], [907.0, 232.0], [880.0, 232.0]], [[850.0, 82.0], [873.0, 82.0], [873.0, 263.0], [850.0, 263.0]], [[821.0, 83.0], [842.0, 83.0], [839.0, 207.0], [818.0, 207.0]]], "lines": ["わかってるさ、", "正しい答えなんて", "無いことは。"]}, {"box": [518, 60, 608, 247], "vertical": true, "font_size": 24, "lines_coords": [[[585.0, 62.0], [608.0, 62.0], [607.0, 221.0], [583.0, 221.0]], [[552.0, 60.0], [579.0, 60.0], [579.0, 247.0], [552.0, 247.0]], [[518.0, 60.0], [545.0, 60.0], [548.0, 210.0], [520.0, 210.0]]], "lines": ["ただ確実なのは", "川のように着々と", "時間は流れて、"]}, {"box": [377, 169, 462, 307], "vertical": true, "font_size": 24, "lines_coords": [[[438.0, 169.0], [462.0, 169.0], [462.0, 263.0], [438.0, 263.0]], [[407.0, 169.0], [430.0, 169.0], [430.0, 307.0], [407.0, 307.0]], [[377.0, 172.0], [396.0, 172.0], [396.0, 293.0], [377.0, 293.0]]], "lines": ["どのみち", "行きつく先は", "海だけれど。"]}, {"box": [139, 187, 292, 304], "vertical": false, "font_size": 18.833333333333332, "lines_coords": [[[139.0, 203.0], [161.0, 190.0], [170.0, 205.0], [147.0, 218.0]], [[140.0, 213.0], [224.0, 187.0], [232.0, 211.0], [149.0, 237.0]], [[150.0, 236.0], [248.0, 205.0], [254.0, 224.0], [155.0, 255.0]], [[158.0, 259.0], [267.0, 220.0], [274.0, 237.0], [165.0, 277.0]], [[168.0, 274.0], [287.0, 235.0], [292.0, 250.0], [173.0, 289.0]], [[173.0, 289.0], [202.0, 281.0], [206.0, 296.0], [177.0, 304.0]]], "lines": ["．．．", "００日井上芽衣子", "は、〈ｎｏｎｔｉｔｌｅ〉", "固きのうはゴメン。", "泣きのつはーへン。ごはんつくってまって", "るよ。"]}, {"box": [699, 579, 755, 694], "vertical": true, "font_size": 24, "lines_coords": [[[731.0, 579.0], [754.0, 579.0], [754.0, 694.0], [731.0, 694.0]], [[699.0, 579.0], [723.0, 579.0], [723.0, 684.0], [699.0, 684.0]]], "lines": ["．．．逆らって", "みるかぁ。"]}, {"box": [261, 617, 289, 701], "vertical": true, "font_size": 28, "lines_coords": [[[261.0, 617.0], [289.0, 617.0], [289.0, 701.0], [261.0, 701.0]]], "lines": ["流れに。"]}, {"box": [471, 1037, 497, 1158], "vertical": true, "font_size": 26, "lines_coords": [[[471.0, 1037.0], [496.0, 1037.0], [497.0, 1158.0], [473.0, 1158.0]]], "lines": ["．．．でももう、"]}, {"box": [359, 1096, 418, 1223], "vertical": true, "font_size": 26, "lines_coords": [[[388.0, 1096.0], [418.0, 1096.0], [418.0, 1173.0], [388.0, 1173.0]], [[359.0, 1100.0], [384.0, 1100.0], [384.0, 1223.0], [359.0, 1223.0]]], "lines": ["「次」は", "無いぞ、俺。"]}], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "126.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [738, 118, 846, 322], "vertical": true, "font_size": 23, "lines_coords": [[[820.0, 118.0], [843.0, 118.0], [846.0, 202.0], [823.0, 202.0]], [[794.0, 118.0], [817.0, 118.0], [817.0, 300.0], [794.0, 300.0]], [[765.0, 118.0], [788.0, 118.0], [788.0, 322.0], [765.0, 322.0]], [[738.0, 118.0], [762.0, 118.0], [762.0, 200.0], [738.0, 200.0]]], "lines": ["んじゃー", "２回目のサビ前は", "プレイク入れるって", "ことで。"]}, {"box": [607, 239, 716, 422], "vertical": true, "font_size": 24, "lines_coords": [[[693.0, 243.0], [716.0, 243.0], [716.0, 422.0], [693.0, 422.0]], [[663.0, 240.0], [690.0, 240.0], [690.0, 378.0], [663.0, 378.0]], [[637.0, 241.0], [660.0, 241.0], [660.0, 356.0], [637.0, 356.0]], [[607.0, 239.0], [630.0, 239.0], [633.0, 366.0], [609.0, 366.0]]], "lines": ["Ａメロギターは", "アルペジオと", "ミュートで", "緩急つけて。"]}, {"box": [214, 113, 324, 293], "vertical": true, "font_size": 24, "lines_coords": [[[299.0, 116.0], [322.0, 116.0], [322.0, 231.0], [299.0, 231.0]], [[270.0, 114.0], [295.0, 114.0], [296.0, 257.0], [272.0, 257.0]], [[241.0, 113.0], [266.0, 113.0], [267.0, 293.0], [243.0, 293.0]], [[214.0, 113.0], [237.0, 113.0], [240.0, 250.0], [217.0, 250.0]]], "lines": ["つーか種田、", "この曲長いし、", "ソロ削っちゃって", "いんじゃね？"]}, {"box": [133, 277, 218, 415], "vertical": true, "font_size": 28, "lines_coords": [[[181.0, 277.0], [218.0, 277.0], [218.0, 337.0], [181.0, 337.0]], [[161.0, 278.0], [184.0, 278.0], [184.0, 393.0], [161.0, 393.0]], [[133.0, 280.0], [157.0, 280.0], [157.0, 415.0], [133.0, 415.0]]], "lines": ["いや、", "そーすると", "バランスが．．．"]}, {"box": [734, 482, 862, 725], "vertical": true, "font_size": 28, "lines_coords": [[[835.0, 483.0], [862.0, 483.0], [862.0, 698.0], [835.0, 698.0]], [[802.0, 483.0], [829.0, 483.0], [829.0, 725.0], [802.0, 725.0]], [[764.0, 482.0], [794.0, 482.0], [797.0, 648.0], [766.0, 648.0]], [[734.0, 482.0], [761.0, 482.0], [761.0, 672.0], [734.0, 672.0]]], "lines": ["オメーはギターで", "気持ちいいだろうが", "俺はベースで", "激暇なんだよ！！"]}, {"box": [155, 585, 188, 731], "vertical": true, "font_size": 33, "lines_coords": [[[155.0, 585.0], [188.0, 585.0], [188.0, 731.0], [155.0, 731.0]]], "lines": ["うっせ！！"]}, {"box": [601, 773, 657, 912], "vertical": true, "font_size": 26, "lines_coords": [[[628.0, 773.0], [657.0, 773.0], [657.0, 846.0], [628.0, 846.0]], [[601.0, 775.0], [624.0, 775.0], [628.0, 911.0], [605.0, 911.0]]], "lines": ["ビール", "もらうぜ～～～"]}, {"box": [475, 932, 508, 985], "vertical": true, "font_size": 27, "lines_coords": [[[475.0, 932.0], [508.0, 932.0], [508.0, 985.0], [475.0, 985.0]]], "lines": ["ん？"]}, {"box": [483, 1055, 537, 1214], "vertical": true, "font_size": 27, "lines_coords": [[[512.0, 1055.0], [537.0, 1056.0], [533.0, 1170.0], [508.0, 1168.0]], [[483.0, 1058.0], [507.0, 1058.0], [507.0, 1214.0], [483.0, 1214.0]]], "lines": ["何、お前ら", "ニヤニヤして？"]}, {"box": [110, 1199, 134, 1314], "vertical": true, "font_size": 23, "lines_coords": [[[110.0, 1199.0], [133.0, 1199.0], [133.0, 1279.0], [110.0, 1279.0]]], "lines": ["べつに！"]}], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [433, 89, 540, 164], "vertical": false, "font_size": 75, "lines_coords": [[[433.0, 89.0], [540.0, 89.0], [540.0, 164.0], [433.0, 164.0]]], "lines": ["キ９"]}, {"box": [754, 564, 831, 687], "vertical": true, "font_size": 22, "lines_coords": [[[808.0, 564.0], [831.0, 564.0], [831.0, 646.0], [808.0, 646.0]], [[780.0, 564.0], [803.0, 564.0], [803.0, 654.0], [780.0, 654.0]], [[754.0, 564.0], [773.0, 564.0], [773.0, 684.0], [754.0, 684.0]]], "lines": ["でもさー", "びっくり", "しちゃった。"]}, {"box": [155, 542, 265, 757], "vertical": true, "font_size": 27, "lines_coords": [[[237.0, 544.0], [265.0, 544.0], [265.0, 693.0], [237.0, 693.0]], [[209.0, 542.0], [236.0, 542.0], [236.0, 715.0], [209.0, 715.0]], [[181.0, 542.0], [209.0, 542.0], [209.0, 706.0], [181.0, 706.0]], [[155.0, 544.0], [179.0, 544.0], [179.0, 757.0], [155.0, 757.0]]], "lines": ["突然土下座で", "「レコーディング", "するから、俺に", "時間をくれ」でしょ？"]}, {"box": [803, 817, 880, 952], "vertical": true, "font_size": 24, "lines_coords": [[[861.0, 820.0], [880.0, 820.0], [880.0, 929.0], [861.0, 929.0]], [[832.0, 817.0], [855.0, 817.0], [855.0, 952.0], [832.0, 952.0]], [[803.0, 817.0], [831.0, 817.0], [831.0, 862.0], [803.0, 862.0]]], "lines": ["アイツか可", "下げるなんて", "ねー"]}, {"box": [684, 851, 776, 1034], "vertical": true, "font_size": 24, "lines_coords": [[[749.0, 851.0], [776.0, 851.0], [776.0, 1034.0], [749.0, 1034.0]], [[717.0, 853.0], [741.0, 853.0], [741.0, 967.0], [717.0, 967.0]], [[684.0, 851.0], [709.0, 851.0], [712.0, 977.0], [687.0, 977.0]]], "lines": ["種田って基本的に", "頭が高い男", "なのにさぁ。"]}, {"box": [503, 825, 587, 984], "vertical": true, "font_size": 23, "lines_coords": [[[559.0, 825.0], [587.0, 825.0], [587.0, 903.0], [559.0, 903.0]], [[535.0, 828.0], [555.0, 828.0], [555.0, 984.0], [535.0, 984.0]], [[505.0, 825.0], [529.0, 825.0], [526.0, 969.0], [503.0, 969.0]]], "lines": ["芽衣子、", "種田にちゃんと", "言ったんだね。"]}, {"box": [464, 1029, 545, 1188], "vertical": true, "font_size": 23, "lines_coords": [[[516.0, 1029.0], [545.0, 1029.0], [545.0, 1125.0], [516.0, 1125.0]], [[492.0, 1032.0], [511.0, 1032.0], [511.0, 1188.0], [492.0, 1188.0]], [[464.0, 1032.0], [485.0, 1032.0], [485.0, 1099.0], [464.0, 1099.0]]], "lines": ["．．．．．って", "顔ひきつってる", "けど？"]}, {"box": [146, 1142, 170, 1303], "vertical": true, "font_size": 23, "lines_coords": [[[146.0, 1142.0], [169.0, 1142.0], [169.0, 1298.0], [146.0, 1298.0]]], "lines": ["だってぇ〜〜．．．"]}], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [791, 73, 874, 277], "vertical": true, "font_size": 22, "lines_coords": [[[855.0, 73.0], [874.0, 73.0], [874.0, 231.0], [855.0, 231.0]], [[824.0, 73.0], [847.0, 73.0], [847.0, 277.0], [824.0, 277.0]], [[791.0, 73.0], [814.0, 73.0], [814.0, 187.0], [791.0, 187.0]]], "lines": ["なんか無責任に", "ハッパかけちゃった", "からさぁ！！"]}, {"box": [680, 108, 739, 224], "vertical": true, "font_size": 22, "lines_coords": [[[715.0, 109.0], [739.0, 109.0], [739.0, 209.0], [715.0, 209.0]], [[683.0, 108.0], [706.0, 108.0], [704.0, 224.0], [680.0, 224.0]]], "lines": ["もし仮に、", "仮にだよ！？"]}, {"box": [392, 112, 540, 269], "vertical": true, "font_size": 22, "lines_coords": [[[516.0, 113.0], [540.0, 113.0], [540.0, 251.0], [516.0, 251.0]], [[483.0, 112.0], [511.0, 112.0], [511.0, 258.0], [483.0, 258.0]], [[452.0, 112.0], [477.0, 112.0], [478.0, 258.0], [453.0, 258.0]], [[423.0, 113.0], [442.0, 113.0], [442.0, 269.0], [423.0, 269.0]], [[392.0, 113.0], [411.0, 113.0], [411.0, 257.0], [392.0, 257.0]]], "lines": ["種田が完全に", "自信喪失して、", "引きこもって、", "ネットの世界の", "住人になって、"]}, {"box": [117, 129, 172, 244], "vertical": true, "font_size": 21, "lines_coords": [[[147.0, 129.0], [170.0, 129.0], [170.0, 222.0], [147.0, 222.0]], [[117.0, 131.0], [136.0, 131.0], [136.0, 244.0], [117.0, 244.0]]], "lines": ["変な心配", "しないの！！"]}, {"box": [345, 310, 492, 530], "vertical": true, "font_size": 22, "lines_coords": [[[473.0, 313.0], [492.0, 313.0], [492.0, 449.0], [473.0, 449.0]], [[438.0, 311.0], [462.0, 311.0], [462.0, 471.0], [438.0, 471.0]], [[408.0, 313.0], [427.0, 313.0], [427.0, 473.0], [408.0, 473.0]], [[375.0, 310.0], [399.0, 310.0], [396.0, 530.0], [373.0, 530.0]], [[345.0, 313.0], [363.0, 313.0], [363.0, 493.0], [345.0, 493.0]]], "lines": ["そこで異常な", "性癖が開花して", "連続幼女暴行魔", "３０歳・自称詩人とかに", "なっちゃったら！？"]}, {"box": [109, 410, 162, 529], "vertical": true, "font_size": 21, "lines_coords": [[[139.0, 410.0], [162.0, 410.0], [162.0, 525.0], [139.0, 525.0]], [[109.0, 410.0], [128.0, 410.0], [128.0, 529.0], [109.0, 529.0]]], "lines": ["人が真剣に", "なった時は、"]}, {"box": [192, 589, 246, 725], "vertical": true, "font_size": 21, "lines_coords": [[[222.0, 589.0], [246.0, 589.0], [246.0, 725.0], [222.0, 725.0]], [[192.0, 590.0], [211.0, 590.0], [211.0, 710.0], [192.0, 710.0]]], "lines": ["黙って見てて", "あげようよ。"]}, {"box": [310, 1071, 333, 1168], "vertical": true, "font_size": 24, "lines_coords": [[[310.0, 1071.0], [333.0, 1071.0], [333.0, 1168.0], [310.0, 1168.0]]], "lines": ["なぁ種田。"]}, {"box": [161, 1141, 250, 1316], "vertical": true, "font_size": 24, "lines_coords": [[[222.0, 1141.0], [250.0, 1141.0], [250.0, 1316.0], [222.0, 1316.0]], [[192.0, 1145.0], [216.0, 1145.0], [216.0, 1304.0], [192.0, 1304.0]], [[161.0, 1144.0], [184.0, 1144.0], [184.0, 1235.0], [161.0, 1235.0]]], "lines": ["なんでいきなり", "レコーディング", "なんだ？"]}], "img_path": "130.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [775, 87, 895, 306], "vertical": true, "font_size": 22, "lines_coords": [[[872.0, 88.0], [891.0, 88.0], [891.0, 269.0], [872.0, 269.0]], [[839.0, 88.0], [862.0, 88.0], [862.0, 250.0], [839.0, 250.0]], [[806.0, 87.0], [829.0, 87.0], [829.0, 272.0], [806.0, 272.0]], [[775.0, 87.0], [798.0, 87.0], [798.0, 306.0], [775.0, 306.0]]], "lines": ["ＣＤ作るにしても", "フツーだったら", "ライブやって勘を", "取り戻してからとか。"]}, {"box": [542, 103, 597, 273], "vertical": true, "font_size": 22, "lines_coords": [[[572.0, 103.0], [597.0, 103.0], [597.0, 231.0], [572.0, 231.0]], [[544.0, 105.0], [563.0, 105.0], [563.0, 269.0], [544.0, 269.0]]], "lines": ["まーーー多々", "理由はあるけど、"]}, {"box": [108, 154, 225, 339], "vertical": true, "font_size": 24, "lines_coords": [[[202.0, 155.0], [225.0, 155.0], [225.0, 272.0], [202.0, 272.0]], [[169.0, 157.0], [192.0, 157.0], [192.0, 339.0], [169.0, 339.0]], [[139.0, 155.0], [162.0, 155.0], [162.0, 326.0], [139.0, 326.0]], [[108.0, 154.0], [131.0, 154.0], [131.0, 248.0], [108.0, 248.0]]], "lines": ["俺ら、もう", "大学ん時の人脈で", "人集めらんない", "だろう？"]}, {"box": [177, 369, 269, 579], "vertical": true, "font_size": 24, "lines_coords": [[[244.0, 371.0], [269.0, 371.0], [266.0, 534.0], [241.0, 534.0]], [[209.0, 369.0], [236.0, 369.0], [236.0, 579.0], [209.0, 579.0]], [[180.0, 369.0], [203.0, 369.0], [200.0, 557.0], [177.0, 557.0]]], "lines": ["せっかく１年も", "悶々とっため続けた", "俺らの気力をな．．．"]}, {"box": [751, 601, 877, 926], "vertical": true, "font_size": 30, "lines_coords": [[[814.0, 604.0], [870.0, 601.0], [877.0, 717.0], [821.0, 720.0]], [[816.0, 766.0], [835.0, 766.0], [835.0, 925.0], [816.0, 925.0]], [[782.0, 765.0], [805.0, 765.0], [805.0, 926.0], [782.0, 926.0]], [[751.0, 765.0], [771.0, 765.0], [771.0, 865.0], [751.0, 865.0]]], "lines": ["ガッ", "．．．と出せんのは", "最初の１回だと", "思うのな。"]}, {"box": [124, 698, 257, 992], "vertical": true, "font_size": 23, "lines_coords": [[[229.0, 704.0], [257.0, 704.0], [257.0, 741.0], [229.0, 741.0]], [[220.0, 828.0], [243.0, 828.0], [240.0, 969.0], [217.0, 969.0]], [[187.0, 832.0], [210.0, 832.0], [210.0, 970.0], [187.0, 970.0]], [[157.0, 831.0], [176.0, 831.0], [176.0, 991.0], [157.0, 991.0]], [[124.0, 832.0], [147.0, 832.0], [147.0, 909.0], [124.0, 909.0]]], "lines": ["んー", "じゃー、その", "瞬間をＣＤに", "しましょうって", "ことね。"]}, {"box": [701, 1044, 833, 1227], "vertical": true, "font_size": 22, "lines_coords": [[[809.0, 1044.0], [833.0, 1044.0], [831.0, 1160.0], [806.0, 1160.0]], [[783.0, 1045.0], [802.0, 1045.0], [802.0, 1159.0], [783.0, 1159.0]], [[753.0, 1044.0], [776.0, 1044.0], [776.0, 1227.0], [753.0, 1227.0]], [[725.0, 1045.0], [749.0, 1045.0], [749.0, 1205.0], [725.0, 1205.0]], [[701.0, 1045.0], [720.0, 1045.0], [720.0, 1188.0], [701.0, 1188.0]]], "lines": ["デモＣＤを", "募集してる", "ライブハウスとか", "レコード会社に", "それを送って、"]}, {"box": [604, 1134, 658, 1257], "vertical": true, "font_size": 22, "lines_coords": [[[639.0, 1136.0], [658.0, 1136.0], [658.0, 1249.0], [639.0, 1249.0]], [[607.0, 1134.0], [630.0, 1134.0], [627.0, 1257.0], [604.0, 1257.0]]], "lines": ["とりあえず", "反応を見る。"]}, {"box": [170, 1147, 192, 1249], "vertical": true, "font_size": 20, "lines_coords": [[[170.0, 1148.0], [190.0, 1148.0], [190.0, 1245.0], [170.0, 1245.0]]], "lines": ["なるほど。"]}], "img_path": "131.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [724, 84, 843, 244], "vertical": true, "font_size": 22, "lines_coords": [[[820.0, 86.0], [843.0, 86.0], [843.0, 244.0], [820.0, 244.0]], [[787.0, 86.0], [810.0, 86.0], [810.0, 232.0], [787.0, 232.0]], [[756.0, 84.0], [779.0, 84.0], [779.0, 228.0], [756.0, 228.0]], [[727.0, 84.0], [746.0, 84.0], [743.0, 198.0], [724.0, 198.0]]], "lines": ["これから週４で", "スタジオかぁ。", "久々じゃねえ、", "こんなの？"]}, {"box": [545, 90, 601, 273], "vertical": true, "font_size": 22, "lines_coords": [[[576.0, 90.0], [600.0, 90.0], [600.0, 273.0], [576.0, 273.0]], [[546.0, 91.0], [566.0, 91.0], [566.0, 270.0], [546.0, 270.0]]], "lines": ["お前ら、ちゃんと", "練習してこいよ！？"]}, {"box": [198, 87, 253, 203], "vertical": true, "font_size": 21, "lines_coords": [[[228.0, 88.0], [251.0, 88.0], [251.0, 202.0], [228.0, 202.0]], [[198.0, 87.0], [217.0, 87.0], [217.0, 177.0], [198.0, 177.0]]], "lines": ["わーかって", "るって！！"]}, {"box": [133, 412, 158, 517], "vertical": true, "font_size": 25, "lines_coords": [[[133.0, 412.0], [158.0, 412.0], [158.0, 515.0], [133.0, 515.0]]], "lines": ["．．．種田っ。"]}, {"box": [753, 678, 823, 846], "vertical": true, "font_size": 31, "lines_coords": [[[794.0, 680.0], [821.0, 680.0], [821.0, 846.0], [794.0, 846.0]], [[753.0, 678.0], [788.0, 678.0], [788.0, 751.0], [753.0, 751.0]]], "lines": ["やるからには", "俺ら、"]}, {"box": [225, 840, 295, 992], "vertical": true, "font_size": 28, "lines_coords": [[[265.0, 842.0], [293.0, 842.0], [293.0, 955.0], [265.0, 955.0]], [[225.0, 840.0], [252.0, 840.0], [252.0, 991.0], [225.0, 991.0]]], "lines": ["超本気で", "やるからな。"]}, {"box": [110, 1155, 178, 1267], "vertical": true, "font_size": 27, "lines_coords": [[[150.0, 1156.0], [174.0, 1156.0], [174.0, 1267.0], [150.0, 1267.0]], [[110.0, 1155.0], [140.0, 1155.0], [140.0, 1240.0], [110.0, 1240.0]]], "lines": ["あたり前", "だろ？"]}], "img_path": "132.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [255, 188, 322, 330], "vertical": true, "font_size": 28, "lines_coords": [[[293.0, 190.0], [318.0, 190.0], [321.0, 300.0], [296.0, 300.0]], [[255.0, 188.0], [285.0, 188.0], [285.0, 263.0], [255.0, 263.0]]], "lines": ["ただいま", "種田―"]}, {"box": [594, 600, 652, 713], "vertical": true, "font_size": 24, "lines_coords": [[[624.0, 600.0], [649.0, 600.0], [650.0, 713.0], [626.0, 713.0]], [[594.0, 600.0], [617.0, 600.0], [617.0, 694.0], [594.0, 694.0]]], "lines": ["気がつけば", "もう８月"]}, {"box": [246, 597, 306, 780], "vertical": true, "font_size": 28, "lines_coords": [[[278.0, 598.0], [306.0, 598.0], [306.0, 780.0], [278.0, 780.0]], [[246.0, 597.0], [273.0, 597.0], [273.0, 766.0], [246.0, 766.0]]], "lines": ["つい、かき氷機を", "買ってしまった。"]}, {"box": [716, 601, 838, 807], "vertical": true, "font_size": 26, "lines_coords": [[[808.0, 601.0], [838.0, 601.0], [838.0, 674.0], [808.0, 674.0]], [[780.0, 602.0], [803.0, 602.0], [803.0, 806.0], [780.0, 806.0]], [[746.0, 601.0], [773.0, 601.0], [773.0, 742.0], [746.0, 742.0]], [[717.0, 601.0], [741.0, 601.0], [741.0, 727.0], [717.0, 727.0]]], "lines": ["思えば", "大学を卒業してから", "日が経つのが", "早くなった。"]}, {"box": [808, 851, 899, 1015], "vertical": true, "font_size": 26, "lines_coords": [[[870.0, 851.0], [899.0, 851.0], [899.0, 948.0], [870.0, 948.0]], [[840.0, 851.0], [868.0, 851.0], [868.0, 1015.0], [840.0, 1015.0]], [[808.0, 854.0], [838.0, 854.0], [838.0, 925.0], [808.0, 925.0]]], "lines": ["見て見て", "これ、フリマで", "８００円"]}, {"box": [813, 946, 832, 1014], "vertical": true, "font_size": 26, "lines_coords": [[[813.0, 946.0], [832.0, 946.0], [832.0, 1014.0], [813.0, 1014.0]]], "lines": ["ーっ！"]}, {"box": [690, 863, 753, 940], "vertical": true, "font_size": 63, "lines_coords": [[[690.0, 863.0], [753.0, 863.0], [753.0, 940.0], [690.0, 940.0]]], "lines": ["キンヤあきゃあ"]}, {"box": [354, 598, 536, 804], "vertical": true, "font_size": 23, "lines_coords": [[[515.0, 601.0], [534.0, 601.0], [534.0, 757.0], [515.0, 757.0]], [[482.0, 600.0], [505.0, 600.0], [505.0, 780.0], [482.0, 780.0]], [[449.0, 600.0], [473.0, 600.0], [473.0, 736.0], [449.0, 736.0]], [[415.0, 600.0], [438.0, 600.0], [438.0, 783.0], [415.0, 783.0]], [[384.0, 598.0], [408.0, 598.0], [410.0, 803.0], [385.0, 803.0]], [[354.0, 600.0], [378.0, 600.0], [378.0, 697.0], [354.0, 697.0]]], "lines": ["日々更新される", "今年の最高気温と", "これでもかと", "降りそそく太陽に", "あたしは、まいって", "しまって、"]}, {"box": [533, 868, 623, 985], "vertical": true, "font_size": 25, "lines_coords": [[[594.0, 868.0], [623.0, 868.0], [623.0, 963.0], [594.0, 963.0]], [[563.0, 868.0], [591.0, 868.0], [591.0, 985.0], [563.0, 985.0]], [[533.0, 869.0], [557.0, 869.0], [557.0, 962.0], [533.0, 962.0]]], "lines": ["あ、何？", "歌詞「書い", "てんの？"]}, {"box": [451, 940, 505, 1056], "vertical": true, "font_size": 25, "lines_coords": [[[481.0, 940.0], [505.0, 940.0], [505.0, 1036.0], [481.0, 1036.0]], [[451.0, 943.0], [470.0, 943.0], [470.0, 1056.0], [451.0, 1056.0]]], "lines": ["ちょっと", "見せてみ？"]}, {"box": [106, 941, 161, 1025], "vertical": true, "font_size": 24, "lines_coords": [[[140.0, 944.0], [161.0, 944.0], [161.0, 983.0], [140.0, 983.0]], [[106.0, 941.0], [135.0, 941.0], [135.0, 1025.0], [106.0, 1025.0]]], "lines": ["ター", "だって。"]}, {"box": [139, 1000, 161, 1034], "vertical": true, "font_size": 24, "lines_coords": [[[139.0, 1000.0], [161.0, 1000.0], [161.0, 1034.0], [139.0, 1034.0]]], "lines": ["ーメ"]}, {"box": [607, 1181, 634, 1320], "vertical": true, "font_size": 27, "lines_coords": [[[607.0, 1182.0], [634.0, 1182.0], [634.0, 1218.0], [607.0, 1218.0]]], "lines": ["んー"]}, {"box": [388, 1134, 509, 1304], "vertical": true, "font_size": 26, "lines_coords": [[[481.0, 1134.0], [509.0, 1134.0], [509.0, 1229.0], [481.0, 1229.0]], [[449.0, 1136.0], [477.0, 1136.0], [477.0, 1296.0], [449.0, 1296.0]], [[419.0, 1134.0], [444.0, 1134.0], [444.0, 1229.0], [419.0, 1229.0]], [[388.0, 1134.0], [411.0, 1134.0], [412.0, 1304.0], [389.0, 1304.0]]], "lines": ["あたしの", "一時期の焦りは", "どこかに", "消えてしまった。"]}, {"box": [307, 1136, 330, 1277], "vertical": true, "font_size": 23, "lines_coords": [[[307.0, 1136.0], [330.0, 1136.0], [330.0, 1275.0], [307.0, 1275.0]]], "lines": ["それもこれも"]}, {"box": [110, 1132, 232, 1272], "vertical": true, "font_size": 26, "lines_coords": [[[207.0, 1133.0], [231.0, 1133.0], [231.0, 1270.0], [207.0, 1270.0]], [[176.0, 1133.0], [199.0, 1133.0], [199.0, 1271.0], [176.0, 1271.0]], [[142.0, 1132.0], [169.0, 1132.0], [169.0, 1271.0], [142.0, 1271.0]], [[110.0, 1132.0], [139.0, 1132.0], [139.0, 1212.0], [110.0, 1212.0]]], "lines": ["近頃の種田の", "妙に生き生き", "どした表情の", "せいだ。"]}], "img_path": "133.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [768, 72, 889, 257], "vertical": true, "font_size": 23, "lines_coords": [[[865.0, 75.0], [888.0, 75.0], [888.0, 237.0], [865.0, 237.0]], [[831.0, 73.0], [855.0, 73.0], [857.0, 237.0], [832.0, 237.0]], [[801.0, 75.0], [824.0, 75.0], [824.0, 257.0], [801.0, 257.0]], [[771.0, 72.0], [794.0, 72.0], [791.0, 218.0], [768.0, 218.0]]], "lines": ["そーやって種田", "昔から作っても", "照れてあたしに", "見せないよね。"]}, {"box": [399, 133, 517, 295], "vertical": true, "font_size": 22, "lines_coords": [[[493.0, 133.0], [516.0, 133.0], [516.0, 295.0], [493.0, 295.0]], [[459.0, 135.0], [482.0, 135.0], [482.0, 250.0], [459.0, 250.0]], [[427.0, 133.0], [451.0, 133.0], [451.0, 228.0], [427.0, 228.0]], [[400.0, 136.0], [419.0, 136.0], [419.0, 293.0], [400.0, 293.0]]], "lines": ["今度はちゃんと", "完成したら", "見せるし", "聴かせるって！！"]}, {"box": [124, 112, 183, 230], "vertical": true, "font_size": 28, "lines_coords": [[[146.0, 112.0], [183.0, 112.0], [183.0, 168.0], [146.0, 168.0]], [[124.0, 117.0], [143.0, 117.0], [143.0, 228.0], [124.0, 228.0]]], "lines": ["絶対", "だよー！！"]}, {"box": [781, 363, 869, 553], "vertical": true, "font_size": 24, "lines_coords": [[[843.0, 363.0], [866.0, 363.0], [869.0, 548.0], [846.0, 548.0]], [[810.0, 365.0], [839.0, 365.0], [839.0, 460.0], [810.0, 460.0]], [[783.0, 367.0], [802.0, 367.0], [802.0, 552.0], [783.0, 552.0]]], "lines": ["あたし達の状況は", "特に何も", "変わってないけど、"]}, {"box": [674, 366, 701, 487], "vertical": true, "font_size": 24, "lines_coords": [[[674.0, 366.0], [698.0, 366.0], [701.0, 483.0], [676.0, 483.0]]], "lines": ["少なくとも"]}, {"box": [709, 622, 828, 741], "vertical": true, "font_size": 24, "lines_coords": [[[805.0, 623.0], [828.0, 623.0], [828.0, 739.0], [805.0, 739.0]], [[771.0, 622.0], [799.0, 622.0], [799.0, 741.0], [771.0, 741.0]], [[742.0, 623.0], [765.0, 623.0], [765.0, 738.0], [742.0, 738.0]], [[709.0, 623.0], [734.0, 623.0], [734.0, 724.0], [709.0, 724.0]]], "lines": ["そういえば", "最近、種田", "仕事行って", "ないけど、"]}, {"box": [515, 362, 604, 556], "vertical": true, "font_size": 25, "lines_coords": [[[574.0, 362.0], [601.0, 362.0], [604.0, 548.0], [576.0, 548.0]], [[542.0, 363.0], [570.0, 363.0], [570.0, 505.0], [542.0, 505.0]], [[515.0, 365.0], [535.0, 365.0], [537.0, 556.0], [516.0, 556.0]]], "lines": ["種田達のバンドは", "順調に練習を", "重ねているようだ。"]}, {"box": [136, 376, 160, 523], "vertical": true, "font_size": 23, "lines_coords": [[[136.0, 397.0], [159.0, 397.0], [159.0, 520.0], [136.0, 520.0]]], "lines": ["．．．よかった。"]}, {"box": [827, 903, 854, 940], "vertical": true, "font_size": 25, "lines_coords": [[[827.0, 903.0], [854.0, 903.0], [854.0, 940.0], [827.0, 940.0]]], "lines": ["あー"]}, {"box": [627, 687, 680, 869], "vertical": true, "font_size": 24, "lines_coords": [[[656.0, 687.0], [680.0, 687.0], [680.0, 782.0], [656.0, 782.0]], [[627.0, 687.0], [646.0, 687.0], [646.0, 869.0], [627.0, 869.0]]], "lines": ["．．．シフト", "どうなってんの？"]}, {"box": [761, 1000, 784, 1103], "vertical": true, "font_size": 25, "lines_coords": [[[761.0, 1000.0], [784.0, 1000.0], [784.0, 1103.0], [761.0, 1103.0]]], "lines": ["辞めたよ。"]}], "img_path": "134.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [825, 64, 885, 205], "vertical": true, "font_size": 26, "lines_coords": [[[862.0, 65.0], [885.0, 65.0], [883.0, 205.0], [859.0, 205.0]], [[825.0, 64.0], [853.0, 64.0], [855.0, 161.0], [828.0, 161.0]]], "lines": ["．．．．．．ちょっと", "種田．．．．．"]}, {"box": [646, 88, 767, 296], "vertical": true, "font_size": 24, "lines_coords": [[[743.0, 90.0], [766.0, 90.0], [766.0, 273.0], [743.0, 273.0]], [[710.0, 90.0], [735.0, 90.0], [734.0, 296.0], [709.0, 296.0]], [[679.0, 90.0], [702.0, 90.0], [702.0, 295.0], [679.0, 295.0]], [[646.0, 88.0], [669.0, 88.0], [671.0, 278.0], [648.0, 278.0]]], "lines": ["だいじょーぶ！！", "絶対バンドで喰える", "なんて思い上がった", "こと考えてないよ。"]}, {"box": [168, 98, 250, 258], "vertical": true, "font_size": 20, "lines_coords": [[[231.0, 98.0], [250.0, 98.0], [247.0, 258.0], [228.0, 258.0]], [[198.0, 99.0], [217.0, 99.0], [217.0, 213.0], [198.0, 213.0]], [[168.0, 99.0], [187.0, 99.0], [187.0, 246.0], [168.0, 246.0]]], "lines": ["どのみち仕事は", "辞めようか", "迷ってたんだ。"]}, {"box": [750, 509, 840, 693], "vertical": true, "font_size": 25, "lines_coords": [[[810.0, 509.0], [840.0, 509.0], [840.0, 583.0], [810.0, 583.0]], [[782.0, 512.0], [805.0, 512.0], [805.0, 693.0], [782.0, 693.0]], [[750.0, 511.0], [773.0, 511.0], [773.0, 678.0], [750.0, 678.0]]], "lines": ["今度の", "レコーディングに", "全てを懸けるよ。"]}, {"box": [138, 314, 220, 482], "vertical": true, "font_size": 20, "lines_coords": [[[200.0, 315.0], [220.0, 315.0], [220.0, 429.0], [200.0, 429.0]], [[168.0, 314.0], [191.0, 314.0], [191.0, 408.0], [168.0, 408.0]], [[138.0, 317.0], [157.0, 317.0], [157.0, 482.0], [138.0, 482.0]]], "lines": ["どうしても", "今は集中", "したかったしさ。"]}, {"box": [185, 542, 270, 708], "vertical": true, "font_size": 22, "lines_coords": [[[247.0, 542.0], [270.0, 542.0], [270.0, 702.0], [247.0, 702.0]], [[216.0, 542.0], [239.0, 542.0], [239.0, 679.0], [216.0, 679.0]], [[185.0, 544.0], [205.0, 544.0], [205.0, 708.0], [185.0, 708.0]]], "lines": ["加藤とビリーに", "はっきりとは", "言ってないけど、"]}, {"box": [798, 969, 825, 1109], "vertical": true, "font_size": 25, "lines_coords": [[[798.0, 969.0], [823.0, 969.0], [824.0, 1104.0], [799.0, 1104.0]]], "lines": ["てもっ．．．"]}, {"box": [276, 708, 392, 911], "vertical": true, "font_size": 22, "lines_coords": [[[373.0, 710.0], [392.0, 710.0], [392.0, 911.0], [373.0, 911.0]], [[339.0, 708.0], [362.0, 708.0], [362.0, 824.0], [339.0, 824.0]], [[307.0, 708.0], [330.0, 708.0], [330.0, 891.0], [307.0, 891.0]], [[276.0, 709.0], [299.0, 709.0], [299.0, 880.0], [276.0, 880.0]]], "lines": ["今月中に何かしらの", "きっかけが", "つかめなかったら", "バンドは解散だ。"]}, {"box": [139, 1183, 168, 1264], "vertical": true, "font_size": 29, "lines_coords": [[[139.0, 1183.0], [168.0, 1183.0], [168.0, 1264.0], [139.0, 1264.0]]], "lines": ["芽衣子。"]}], "img_path": "135.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [808, 206, 835, 356], "vertical": true, "font_size": 27, "lines_coords": [[[808.0, 206.0], [835.0, 206.0], [835.0, 351.0], [808.0, 351.0]]], "lines": ["．．．その時は、"]}, {"box": [173, 332, 209, 458], "vertical": true, "font_size": 30, "lines_coords": [[[173.0, 333.0], [203.0, 332.0], [209.0, 456.0], [179.0, 458.0]]], "lines": ["その時だ。"]}, {"box": [430, 992, 468, 1025], "vertical": false, "font_size": 17.5, "lines_coords": [[[430.0, 992.0], [468.0, 992.0], [468.0, 1010.0], [430.0, 1010.0]], [[444.0, 1008.0], [464.0, 1008.0], [464.0, 1025.0], [444.0, 1025.0]]], "lines": ["おいおいしいですか！！", "いや．．．！？"]}, {"box": [319, 977, 356, 991], "vertical": false, "font_size": 14, "lines_coords": [[[319.0, 977.0], [356.0, 977.0], [356.0, 991.0], [319.0, 991.0]]], "lines": ["．．．朝鮮から来るのはあんかもしれないんですけど"]}, {"box": [624, 983, 682, 1125], "vertical": true, "font_size": 24, "lines_coords": [[[654.0, 984.0], [682.0, 984.0], [682.0, 1125.0], [654.0, 1125.0]], [[624.0, 983.0], [648.0, 983.0], [648.0, 1086.0], [624.0, 1086.0]]], "lines": ["おー、芽衣子", "来たのか。"]}, {"box": [530, 1047, 587, 1208], "vertical": true, "font_size": 24, "lines_coords": [[[564.0, 1048.0], [587.0, 1048.0], [587.0, 1141.0], [564.0, 1141.0]], [[533.0, 1047.0], [556.0, 1047.0], [553.0, 1208.0], [530.0, 1208.0]]], "lines": ["ゆるーく", "パーマかけた？"]}, {"box": [101, 1166, 188, 1350], "vertical": true, "font_size": 22, "lines_coords": [[[162.0, 1167.0], [185.0, 1167.0], [185.0, 1304.0], [162.0, 1304.0]], [[129.0, 1166.0], [154.0, 1166.0], [155.0, 1350.0], [131.0, 1350.0]], [[102.0, 1168.0], [121.0, 1168.0], [121.0, 1289.0], [102.0, 1289.0]]], "lines": ["今日が最後の", "リハだから、俺が", "連れてきた。"]}], "img_path": "136.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [678, 76, 761, 213], "vertical": true, "font_size": 21, "lines_coords": [[[738.0, 77.0], [761.0, 77.0], [761.0, 169.0], [738.0, 169.0]], [[708.0, 76.0], [731.0, 76.0], [731.0, 192.0], [708.0, 192.0]], [[678.0, 76.0], [697.0, 76.0], [697.0, 188.0], [678.0, 188.0]], [[679.0, 188.0], [695.0, 188.0], [695.0, 213.0], [679.0, 213.0]]], "lines": ["いよいよ", "明日が本番", "だからなー", "．．．"]}, {"box": [602, 179, 654, 296], "vertical": true, "font_size": 21, "lines_coords": [[[628.0, 179.0], [652.0, 179.0], [654.0, 296.0], [631.0, 296.0]], [[602.0, 180.0], [622.0, 180.0], [622.0, 277.0], [602.0, 277.0]]], "lines": ["芽衣子には", "悪いけど、"]}, {"box": [375, 64, 452, 94], "vertical": false, "font_size": 30, "lines_coords": [[[375.0, 64.0], [452.0, 64.0], [452.0, 94.0], [375.0, 94.0]]], "lines": ["２２：００"]}, {"box": [269, 64, 349, 92], "vertical": false, "font_size": 25, "lines_coords": [[[272.0, 66.0], [345.0, 66.0], [345.0, 91.0], [272.0, 91.0]]], "lines": ["２１：００"]}, {"box": [161, 65, 236, 88], "vertical": false, "font_size": 23, "lines_coords": [[[161.0, 65.0], [236.0, 65.0], [236.0, 88.0], [161.0, 88.0]]], "lines": ["２０：００"]}, {"box": [328, 438, 416, 578], "vertical": true, "font_size": 23, "lines_coords": [[[391.0, 438.0], [414.0, 438.0], [414.0, 533.0], [391.0, 533.0]], [[359.0, 441.0], [382.0, 441.0], [382.0, 578.0], [359.0, 578.0]], [[328.0, 441.0], [352.0, 441.0], [352.0, 533.0], [328.0, 533.0]]], "lines": ["今日は俺", "８割くらいで", "叩くぜ？"]}, {"box": [821, 639, 878, 777], "vertical": true, "font_size": 20, "lines_coords": [[[855.0, 641.0], [874.0, 641.0], [874.0, 776.0], [855.0, 776.0]], [[824.0, 639.0], [844.0, 639.0], [842.0, 762.0], [821.0, 762.0]]], "lines": ["なんだ芽衣子", "元気無いな。"]}, {"box": [127, 703, 214, 820], "vertical": true, "font_size": 25, "lines_coords": [[[188.0, 704.0], [214.0, 704.0], [214.0, 771.0], [188.0, 771.0]], [[158.0, 704.0], [183.0, 704.0], [183.0, 795.0], [158.0, 795.0]], [[127.0, 704.0], [150.0, 704.0], [150.0, 794.0], [127.0, 794.0]]], "lines": ["種田―", "曲、まず", "何やる？"]}, {"box": [179, 1133, 213, 1278], "vertical": true, "font_size": 34, "lines_coords": [[[179.0, 1133.0], [213.0, 1133.0], [213.0, 1278.0], [179.0, 1278.0]]], "lines": ["ソラニン。"]}], "img_path": "137.png"}, {"version": "0.2.0-beta.6", "img_width": 975, "img_height": 1400, "blocks": [], "img_path": "138.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "139.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [460, 536, 484, 675], "vertical": true, "font_size": 23, "lines_coords": [[[460.0, 540.0], [483.0, 540.0], [483.0, 672.0], [460.0, 672.0]]], "lines": ["．．．あ．．．．．．"]}, {"box": [658, 1134, 715, 1255], "vertical": true, "font_size": 24, "lines_coords": [[[689.0, 1136.0], [713.0, 1136.0], [713.0, 1227.0], [689.0, 1227.0]], [[658.0, 1136.0], [682.0, 1136.0], [682.0, 1252.0], [658.0, 1252.0]]], "lines": ["なんだよ", "種田のやつ、"]}, {"box": [339, 1134, 462, 1306], "vertical": true, "font_size": 24, "lines_coords": [[[434.0, 1134.0], [462.0, 1134.0], [462.0, 1275.0], [434.0, 1275.0]], [[404.0, 1137.0], [427.0, 1137.0], [427.0, 1274.0], [404.0, 1274.0]], [[371.0, 1138.0], [395.0, 1138.0], [395.0, 1230.0], [371.0, 1230.0]], [[339.0, 1136.0], [362.0, 1136.0], [366.0, 1305.0], [343.0, 1305.0]]], "lines": ["子供みたいに", "あんなに目を", "キラキラ", "させちゃってさ。"]}], "img_path": "140.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [624, 1052, 679, 1153], "vertical": true, "font_size": 24, "lines_coords": [[[656.0, 1054.0], [679.0, 1054.0], [679.0, 1148.0], [656.0, 1148.0]], [[624.0, 1054.0], [648.0, 1054.0], [648.0, 1149.0], [624.0, 1149.0]]], "lines": ["うん．．．うん", "そうだね。"]}, {"box": [348, 1047, 408, 1196], "vertical": true, "font_size": 26, "lines_coords": [[[378.0, 1047.0], [408.0, 1047.0], [408.0, 1122.0], [378.0, 1122.0]], [[348.0, 1050.0], [371.0, 1050.0], [374.0, 1190.0], [351.0, 1190.0]]], "lines": ["これで", "いいんだよね"]}], "img_path": "141.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [320, 736, 489, 827], "vertical": false, "font_size": 34, "lines_coords": [[[330.0, 743.0], [481.0, 743.0], [481.0, 777.0], [330.0, 777.0]], [[329.0, 788.0], [481.0, 788.0], [481.0, 821.0], [329.0, 821.0]]], "lines": ["もしかして", "いや、それは"]}], "img_path": "142.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "143.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [777, 128, 842, 172], "vertical": false, "font_size": 23, "lines_coords": [[[786.0, 128.0], [842.0, 151.0], [833.0, 172.0], [777.0, 149.0]]], "lines": ["．．．"]}, {"box": [458, 118, 490, 269], "vertical": true, "font_size": 29, "lines_coords": [[[458.0, 181.0], [486.0, 180.0], [489.0, 267.0], [460.0, 269.0]]], "lines": ["ーんで。"]}, {"box": [742, 821, 877, 1138], "vertical": true, "font_size": 23, "lines_coords": [[[854.0, 821.0], [877.0, 821.0], [877.0, 1004.0], [854.0, 1004.0]], [[828.0, 824.0], [847.0, 824.0], [847.0, 937.0], [828.0, 937.0]], [[799.0, 823.0], [823.0, 823.0], [823.0, 1073.0], [799.0, 1073.0]], [[768.0, 824.0], [795.0, 824.0], [795.0, 1138.0], [768.0, 1138.0]], [[742.0, 823.0], [766.0, 823.0], [766.0, 921.0], [742.0, 921.0]]], "lines": ["どうにか完成した", "デモＣＤは", "それぞれ封筒に包まれて", "レコード会社やライブハウスに", "送られた。"]}, {"box": [637, 821, 713, 1002], "vertical": true, "font_size": 23, "lines_coords": [[[687.0, 821.0], [710.0, 821.0], [713.0, 1002.0], [690.0, 1002.0]], [[660.0, 823.0], [684.0, 823.0], [686.0, 984.0], [661.0, 984.0]], [[637.0, 823.0], [656.0, 823.0], [656.0, 967.0], [637.0, 967.0]]], "lines": ["あとは何かしらの", "リアクションを", "祈るばかりだ。"]}, {"box": [488, 844, 591, 1003], "vertical": true, "font_size": 21, "lines_coords": [[[568.0, 844.0], [591.0, 844.0], [591.0, 959.0], [568.0, 959.0]], [[541.0, 844.0], [564.0, 844.0], [564.0, 1003.0], [541.0, 1003.0]], [[515.0, 846.0], [534.0, 846.0], [534.0, 980.0], [515.0, 980.0]], [[488.0, 846.0], [507.0, 846.0], [507.0, 958.0], [488.0, 958.0]]], "lines": ["．．．とはいえ", "焚きつけたのは", "確かにあたし", "だけど．．．"]}, {"box": [136, 924, 186, 1103], "vertical": true, "font_size": 21, "lines_coords": [[[159.0, 924.0], [183.0, 924.0], [185.0, 1103.0], [162.0, 1103.0]], [[136.0, 925.0], [155.0, 925.0], [155.0, 1034.0], [136.0, 1034.0]]], "lines": ["ついでに５円玉も", "入れとく？"]}, {"box": [458, 1034, 538, 1152], "vertical": true, "font_size": 21, "lines_coords": [[[515.0, 1034.0], [538.0, 1034.0], [538.0, 1129.0], [515.0, 1129.0]], [[490.0, 1037.0], [509.0, 1037.0], [509.0, 1151.0], [490.0, 1151.0]], [[460.0, 1036.0], [483.0, 1036.0], [481.0, 1152.0], [458.0, 1152.0]]], "lines": ["そんなに", "うまくいく", "だろうか？"]}, {"box": [129, 1207, 154, 1327], "vertical": true, "font_size": 24, "lines_coords": [[[129.0, 1207.0], [153.0, 1207.0], [153.0, 1323.0], [129.0, 1323.0]]], "lines": ["．．．ていうか"]}], "img_path": "144.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [776, 153, 855, 289], "vertical": true, "font_size": 23, "lines_coords": [[[832.0, 153.0], [855.0, 153.0], [855.0, 289.0], [832.0, 289.0]], [[803.0, 154.0], [827.0, 154.0], [827.0, 267.0], [803.0, 267.0]], [[776.0, 154.0], [799.0, 154.0], [799.0, 267.0], [776.0, 267.0]]], "lines": ["うまくいって", "くれなきゃ", "困るんだ！！"]}, {"box": [423, 42, 555, 98], "vertical": false, "font_size": 56, "lines_coords": [[[423.0, 42.0], [555.0, 42.0], [555.0, 98.0], [423.0, 98.0]]], "lines": ["＃ｖｅ"]}, {"box": [120, 399, 203, 542], "vertical": true, "font_size": 25, "lines_coords": [[[176.0, 440.0], [199.0, 440.0], [199.0, 542.0], [176.0, 542.0]], [[177.0, 401.0], [203.0, 401.0], [203.0, 445.0], [177.0, 445.0]], [[150.0, 400.0], [173.0, 400.0], [173.0, 535.0], [150.0, 535.0]], [[120.0, 399.0], [151.0, 399.0], [151.0, 455.0], [120.0, 455.0]]], "lines": ["―ココ、", "あー", "このＡメロの", "入り、"]}, {"box": [191, 597, 243, 756], "vertical": true, "font_size": 25, "lines_coords": [[[216.0, 597.0], [243.0, 597.0], [243.0, 756.0], [216.0, 756.0]], [[191.0, 598.0], [210.0, 598.0], [210.0, 717.0], [191.0, 717.0]]], "lines": ["一瞬、リズムが", "走るんだよ。"]}, {"box": [795, 808, 880, 969], "vertical": true, "font_size": 23, "lines_coords": [[[854.0, 812.0], [877.0, 812.0], [874.0, 967.0], [851.0, 967.0]], [[827.0, 809.0], [850.0, 809.0], [847.0, 944.0], [824.0, 944.0]], [[799.0, 808.0], [823.0, 808.0], [818.0, 941.0], [795.0, 941.0]]], "lines": ["一発録りだから", "やっぱアラが", "目立つわなー"]}, {"box": [523, 846, 601, 993], "vertical": true, "font_size": 23, "lines_coords": [[[576.0, 846.0], [601.0, 846.0], [598.0, 962.0], [574.0, 962.0]], [[548.0, 846.0], [572.0, 846.0], [570.0, 962.0], [545.0, 962.0]], [[523.0, 849.0], [542.0, 849.0], [542.0, 992.0], [523.0, 992.0]]], "lines": ["ま、完璧な", "もんなんて", "求めてないさ。"]}, {"box": [98, 890, 203, 1050], "vertical": true, "font_size": 23, "lines_coords": [[[180.0, 892.0], [203.0, 892.0], [203.0, 1029.0], [180.0, 1029.0]], [[153.0, 892.0], [176.0, 892.0], [176.0, 1007.0], [153.0, 1007.0]], [[123.0, 890.0], [147.0, 890.0], [149.0, 1050.0], [124.0, 1050.0]], [[98.0, 892.0], [121.0, 892.0], [121.0, 1015.0], [98.0, 1015.0]]], "lines": ["あの日あの時", "あの瞬間を", "録るってコトが", "大事なんだ。"]}, {"box": [142, 1099, 218, 1279], "vertical": true, "font_size": 23, "lines_coords": [[[199.0, 1101.0], [218.0, 1101.0], [218.0, 1279.0], [199.0, 1279.0]], [[169.0, 1100.0], [192.0, 1100.0], [192.0, 1260.0], [169.0, 1260.0]], [[142.0, 1099.0], [165.0, 1099.0], [165.0, 1192.0], [142.0, 1192.0]]], "lines": ["そーゆう意味じゃ", "うまくいったん", "じゃん？"]}], "img_path": "145.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [822, 94, 876, 244], "vertical": true, "font_size": 21, "lines_coords": [[[850.0, 94.0], [873.0, 94.0], [873.0, 195.0], [850.0, 195.0]], [[823.0, 97.0], [842.0, 97.0], [842.0, 241.0], [823.0, 241.0]]], "lines": ["それよか、", "ビリ山さんよ。"]}, {"box": [151, 138, 243, 302], "vertical": true, "font_size": 25, "lines_coords": [[[211.0, 138.0], [240.0, 138.0], [243.0, 243.0], [214.0, 243.0]], [[183.0, 139.0], [206.0, 139.0], [206.0, 277.0], [183.0, 277.0]], [[153.0, 138.0], [176.0, 138.0], [174.0, 302.0], [151.0, 302.0]]], "lines": ["．．．．．．むぅ、", "この渋滞だと", "キビしいかも．．．"]}, {"box": [541, 434, 692, 626], "vertical": true, "font_size": 23, "lines_coords": [[[668.0, 436.0], [691.0, 436.0], [691.0, 626.0], [668.0, 626.0]], [[634.0, 434.0], [661.0, 434.0], [661.0, 575.0], [634.0, 575.0]], [[605.0, 436.0], [628.0, 436.0], [628.0, 619.0], [605.0, 619.0]], [[572.0, 434.0], [596.0, 434.0], [596.0, 574.0], [572.0, 574.0]], [[542.0, 436.0], [561.0, 436.0], [561.0, 571.0], [542.0, 571.0]]], "lines": ["キメキメのグラサン", "には、あえて", "つっこまないけど", "花火大会には", "間に合うの？"]}, {"box": [131, 359, 159, 496], "vertical": true, "font_size": 23, "lines_coords": [[[136.0, 455.0], [154.0, 455.0], [154.0, 493.0], [136.0, 493.0]], [[131.0, 359.0], [159.0, 359.0], [159.0, 438.0], [131.0, 438.0]]], "lines": ["ー？", "マジで"]}, {"box": [813, 637, 879, 783], "vertical": true, "font_size": 24, "lines_coords": [[[853.0, 637.0], [876.0, 637.0], [876.0, 777.0], [853.0, 777.0]], [[813.0, 639.0], [839.0, 639.0], [839.0, 775.0], [813.0, 775.0]]], "lines": ["ふざけんな", "この剛毛！！"]}, {"box": [390, 648, 493, 794], "vertical": true, "font_size": 27, "lines_coords": [[[464.0, 648.0], [493.0, 648.0], [493.0, 786.0], [464.0, 786.0]], [[423.0, 648.0], [452.0, 648.0], [455.0, 794.0], [426.0, 794.0]], [[391.0, 648.0], [414.0, 648.0], [414.0, 784.0], [391.0, 784.0]]], "lines": ["サングラス", "かち割るぞ、", "この野郎！！"]}, {"box": [505, 974, 561, 1092], "vertical": true, "font_size": 24, "lines_coords": [[[537.0, 974.0], [561.0, 974.0], [561.0, 1047.0], [537.0, 1047.0]], [[505.0, 976.0], [529.0, 976.0], [529.0, 1092.0], [505.0, 1092.0]]], "lines": ["．．．．．．", "仕方ねぇ．．．"]}, {"box": [215, 675, 321, 896], "vertical": true, "font_size": 28, "lines_coords": [[[287.0, 675.0], [321.0, 675.0], [321.0, 762.0], [287.0, 762.0]], [[252.0, 678.0], [280.0, 678.0], [280.0, 816.0], [252.0, 816.0]], [[217.0, 676.0], [240.0, 676.0], [240.0, 895.0], [217.0, 895.0]]], "lines": ["抜け道", "フル活用で", "穴場に直行じゃ！！"]}, {"box": [396, 1155, 515, 1294], "vertical": true, "font_size": 24, "lines_coords": [[[490.0, 1155.0], [515.0, 1155.0], [512.0, 1271.0], [488.0, 1271.0]], [[459.0, 1155.0], [482.0, 1155.0], [479.0, 1271.0], [456.0, 1271.0]], [[427.0, 1156.0], [451.0, 1156.0], [451.0, 1294.0], [427.0, 1294.0]], [[396.0, 1158.0], [419.0, 1158.0], [419.0, 1271.0], [396.0, 1271.0]]], "lines": ["東京生まれ", "東京育ちの", "本気を見せて", "やるぜ．．．"]}, {"box": [109, 1140, 138, 1307], "vertical": true, "font_size": 29, "lines_coords": [[[109.0, 1140.0], [138.0, 1140.0], [138.0, 1307.0], [109.0, 1307.0]]], "lines": ["おぉーーっ！！"]}], "img_path": "146.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [775, 195, 806, 313], "vertical": true, "font_size": 25, "lines_coords": [[[777.0, 195.0], [806.0, 195.0], [803.0, 313.0], [775.0, 313.0]]], "lines": ["．．．遠い．．．"]}, {"box": [690, 284, 745, 444], "vertical": true, "font_size": 25, "lines_coords": [[[721.0, 284.0], [745.0, 284.0], [745.0, 404.0], [721.0, 404.0]], [[690.0, 285.0], [713.0, 285.0], [713.0, 444.0], [690.0, 444.0]]], "lines": ["ビリーさん、", "メチャ遠いよ？"]}, {"box": [240, 477, 330, 616], "vertical": true, "font_size": 24, "lines_coords": [[[303.0, 477.0], [330.0, 477.0], [330.0, 616.0], [303.0, 616.0]], [[269.0, 477.0], [299.0, 477.0], [299.0, 571.0], [269.0, 571.0]], [[240.0, 477.0], [266.0, 477.0], [266.0, 541.0], [240.0, 541.0]]], "lines": ["あ、あれぇ？", "おかしい", "ナァー"]}, {"box": [165, 553, 261, 803], "vertical": true, "font_size": 24, "lines_coords": [[[244.0, 553.0], [261.0, 553.0], [261.0, 589.0], [244.0, 589.0]], [[228.0, 642.0], [251.0, 642.0], [251.0, 760.0], [228.0, 760.0]], [[196.0, 643.0], [220.0, 643.0], [220.0, 803.0], [196.0, 803.0]], [[165.0, 643.0], [188.0, 643.0], [188.0, 760.0], [165.0, 760.0]]], "lines": ["ー？", "きっと町田", "あたりで次元の", "歪みが．．．"]}, {"box": [547, 882, 693, 912], "vertical": false, "font_size": 27, "lines_coords": [[[549.0, 883.0], [691.0, 883.0], [691.0, 910.0], [549.0, 910.0]]], "lines": ["Ｘ危険です"]}, {"box": [161, 963, 180, 1060], "vertical": true, "font_size": 22, "lines_coords": [[[161.0, 963.0], [180.0, 963.0], [180.0, 1060.0], [161.0, 1060.0]]], "lines": ["．．．．．．まぁ"]}, {"box": [112, 1119, 231, 1312], "vertical": true, "font_size": 22, "lines_coords": [[[211.0, 1122.0], [231.0, 1122.0], [231.0, 1234.0], [211.0, 1234.0]], [[177.0, 1121.0], [200.0, 1121.0], [200.0, 1235.0], [177.0, 1235.0]], [[144.0, 1121.0], [168.0, 1121.0], [168.0, 1282.0], [144.0, 1282.0]], [[112.0, 1119.0], [135.0, 1119.0], [135.0, 1312.0], [112.0, 1312.0]]], "lines": ["大きくても", "小さくても", "花火はキレイに", "変わり無しってね。"]}], "img_path": "147.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [511, 474, 568, 635], "vertical": true, "font_size": 27, "lines_coords": [[[545.0, 477.0], [568.0, 477.0], [568.0, 613.0], [545.0, 613.0]], [[511.0, 474.0], [538.0, 474.0], [538.0, 635.0], [511.0, 635.0]]], "lines": ["何、ボーッと", "してんのー？"]}, {"box": [407, 585, 500, 750], "vertical": true, "font_size": 27, "lines_coords": [[[467.0, 585.0], [500.0, 585.0], [500.0, 641.0], [467.0, 641.0]], [[437.0, 589.0], [462.0, 589.0], [463.0, 750.0], [438.0, 750.0]], [[407.0, 589.0], [432.0, 589.0], [432.0, 682.0], [407.0, 682.0]]], "lines": ["花火", "無くなっちゃう", "よーー？"]}, {"box": [810, 801, 840, 895], "vertical": true, "font_size": 28, "lines_coords": [[[810.0, 801.0], [840.0, 801.0], [840.0, 895.0], [810.0, 895.0]]], "lines": ["いや．．．"]}, {"box": [750, 918, 775, 996], "vertical": true, "font_size": 28, "lines_coords": [[[750.0, 918.0], [775.0, 918.0], [775.0, 996.0], [750.0, 996.0]]], "lines": ["なんか"]}, {"box": [125, 862, 213, 1012], "vertical": true, "font_size": 25, "lines_coords": [[[188.0, 862.0], [213.0, 862.0], [213.0, 958.0], [188.0, 958.0]], [[154.0, 864.0], [179.0, 864.0], [180.0, 980.0], [155.0, 980.0]], [[125.0, 862.0], [149.0, 862.0], [149.0, 1011.0], [125.0, 1011.0]]], "lines": ["ちょっと", "いいなって", "思っちゃった。"]}], "img_path": "148.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [818, 732, 872, 900], "vertical": true, "font_size": 23, "lines_coords": [[[849.0, 732.0], [872.0, 732.0], [872.0, 868.0], [849.0, 868.0]], [[818.0, 732.0], [842.0, 732.0], [842.0, 900.0], [818.0, 900.0]]], "lines": ["いいトシして", "みんなそろって、"]}, {"box": [731, 835, 784, 959], "vertical": true, "font_size": 23, "lines_coords": [[[761.0, 835.0], [784.0, 835.0], [784.0, 950.0], [761.0, 950.0]], [[731.0, 835.0], [754.0, 835.0], [754.0, 959.0], [731.0, 959.0]]], "lines": ["花火なんか", "しちゃって。"]}, {"box": [403, 775, 455, 936], "vertical": true, "font_size": 23, "lines_coords": [[[432.0, 775.0], [455.0, 775.0], [455.0, 936.0], [432.0, 936.0]], [[403.0, 776.0], [422.0, 776.0], [422.0, 896.0], [403.0, 896.0]]], "lines": ["花火はあんなに", "綺麗だけど、"]}, {"box": [265, 823, 355, 983], "vertical": true, "font_size": 23, "lines_coords": [[[330.0, 824.0], [355.0, 824.0], [355.0, 940.0], [330.0, 940.0]], [[299.0, 824.0], [322.0, 824.0], [322.0, 983.0], [299.0, 983.0]], [[267.0, 823.0], [291.0, 823.0], [288.0, 947.0], [265.0, 947.0]]], "lines": ["火薬で人を", "殺すことだって", "できるんだ。"]}, {"box": [590, 1155, 681, 1304], "vertical": true, "font_size": 22, "lines_coords": [[[656.0, 1156.0], [679.0, 1156.0], [679.0, 1291.0], [656.0, 1291.0]], [[626.0, 1156.0], [645.0, 1156.0], [645.0, 1293.0], [626.0, 1293.0]], [[590.0, 1155.0], [613.0, 1155.0], [616.0, 1304.0], [593.0, 1304.0]]], "lines": ["全然フツーの", "ことなのかも", "しれないけど。"]}, {"box": [101, 1171, 190, 1334], "vertical": true, "font_size": 23, "lines_coords": [[[165.0, 1173.0], [188.0, 1173.0], [188.0, 1312.0], [165.0, 1312.0]], [[132.0, 1174.0], [155.0, 1174.0], [155.0, 1334.0], [132.0, 1334.0]], [[101.0, 1171.0], [125.0, 1171.0], [125.0, 1253.0], [101.0, 1253.0]]], "lines": ["平和な日本で", "みんなで花火を", "見てる。"]}], "img_path": "149.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [712, 125, 775, 273], "verti