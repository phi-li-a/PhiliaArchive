0], [604.0, 1025.0]], [[572.0, 888.0], [591.0, 888.0], [591.0, 1050.0], [572.0, 1050.0]]], "lines": ["たとえ誰かに", "馬鹿にされたり"]}, {"box": [153, 943, 239, 1126], "vertical": true, "font_size": 21, "lines_coords": [[[216.0, 946.0], [239.0, 946.0], [239.0, 1082.0], [216.0, 1082.0]], [[183.0, 943.0], [206.0, 943.0], [206.0, 1126.0], [183.0, 1126.0]], [[153.0, 943.0], [176.0, 943.0], [176.0, 1110.0], [153.0, 1110.0]]], "lines": ["行きつく先が", "世界の果ての巣て", "だったとしても、"]}, {"box": [462, 963, 516, 1155], "vertical": true, "font_size": 21, "lines_coords": [[[489.0, 963.0], [516.0, 963.0], [516.0, 1127.0], [489.0, 1127.0]], [[462.0, 966.0], [481.0, 966.0], [481.0, 1155.0], [462.0, 1155.0]]], "lines": ["将来が真っ暗で", "見えなくなったり、"]}, {"box": [123, 1181, 174, 1349], "vertical": true, "font_size": 21, "lines_coords": [[[155.0, 1181.0], [174.0, 1181.0], [174.0, 1316.0], [155.0, 1316.0]], [[123.0, 1181.0], [142.0, 1181.0], [142.0, 1349.0], [123.0, 1349.0]]], "lines": ["芽衣子と俺は", "一緒なんだから。"]}], "img_path": "023.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [791, 414, 819, 563], "vertical": true, "font_size": 27, "lines_coords": [[[791.0, 415.0], [818.0, 415.0], [818.0, 556.0], [791.0, 556.0]]], "lines": ["．．．てゆーか"]}, {"box": [143, 530, 213, 697], "vertical": true, "font_size": 29, "lines_coords": [[[183.0, 531.0], [210.0, 531.0], [210.0, 697.0], [183.0, 697.0]], [[143.0, 530.0], [174.0, 530.0], [174.0, 601.0], [143.0, 601.0]]], "lines": ["俺がどーにか", "する。"]}, {"box": [784, 821, 816, 907], "vertical": true, "font_size": 29, "lines_coords": [[[784.0, 823.0], [813.0, 821.0], [816.0, 906.0], [787.0, 907.0]]], "lines": ["．．．ふぁ。"]}, {"box": [267, 827, 302, 1149], "vertical": true, "font_size": 19, "lines_coords": [[[273.0, 870.0], [292.0, 870.0], [292.0, 913.0], [273.0, 913.0]]], "lines": ["．．．"]}, {"box": [799, 1093, 831, 1171], "vertical": true, "font_size": 30, "lines_coords": [[[799.0, 1095.0], [825.0, 1093.0], [831.0, 1170.0], [805.0, 1171.0]]], "lines": ["．．．ちょ、"]}, {"box": [728, 1141, 762, 1218], "vertical": true, "font_size": 30, "lines_coords": [[[728.0, 1141.0], [762.0, 1141.0], [762.0, 1218.0], [728.0, 1218.0]]], "lines": ["ギブ．．．"]}, {"box": [408, 1173, 430, 1311], "vertical": true, "font_size": 19, "lines_coords": [[[408.0, 1175.0], [427.0, 1175.0], [427.0, 1311.0], [408.0, 1311.0]]], "lines": ["死んじゃう．．"]}, {"box": [195, 1085, 219, 1191], "vertical": true, "font_size": 23, "lines_coords": [[[195.0, 1085.0], [218.0, 1085.0], [218.0, 1189.0], [195.0, 1189.0]]], "lines": ["なんか．．．"]}], "img_path": "024.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [442, 175, 512, 287], "vertical": true, "font_size": 30, "lines_coords": [[[483.0, 177.0], [512.0, 177.0], [512.0, 285.0], [483.0, 285.0]], [[442.0, 176.0], [473.0, 176.0], [473.0, 261.0], [442.0, 261.0]]], "lines": ["すっごい", "好き！！"]}], "img_path": "025.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [122, 90, 208, 272], "vertical": true, "font_size": 22, "lines_coords": [[[184.0, 90.0], [207.0, 90.0], [207.0, 263.0], [184.0, 263.0]], [[153.0, 91.0], [177.0, 91.0], [177.0, 185.0], [153.0, 185.0]], [[123.0, 92.0], [142.0, 92.0], [142.0, 272.0], [123.0, 272.0]]], "lines": ["．．．種田、ちゃんと", "顔洗って", "出かけたのかな？"]}, {"box": [629, 319, 881, 501], "vertical": false, "font_size": 42, "lines_coords": [[[638.0, 347.0], [876.0, 319.0], [881.0, 369.0], [643.0, 396.0]], [[630.0, 395.0], [866.0, 358.0], [872.0, 400.0], [635.0, 436.0]], [[637.0, 429.0], [868.0, 401.0], [872.0, 438.0], [641.0, 466.0]], [[658.0, 462.0], [795.0, 447.0], [799.0, 486.0], [663.0, 501.0]]], "lines": ["ヤバーです、「ちょくてす」", "なかで朝メシはきゅうの", "カレーでカンバンして", "ください！！"]}, {"box": [796, 680, 819, 789], "vertical": true, "font_size": 19, "lines_coords": [[[797.0, 682.0], [816.0, 682.0], [816.0, 788.0], [797.0, 788.0]]], "lines": ["あらら？"]}, {"box": [151, 772, 220, 883], "vertical": true, "font_size": 30, "lines_coords": [[[185.0, 772.0], [220.0, 772.0], [220.0, 861.0], [185.0, 861.0]], [[151.0, 776.0], [176.0, 776.0], [176.0, 883.0], [151.0, 883.0]]], "lines": ["なんで", "風船が？"]}], "img_path": "026.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [401, 1015, 508, 1212], "vertical": true, "font_size": 28, "lines_coords": [[[478.0, 1015.0], [505.0, 1015.0], [505.0, 1183.0], [478.0, 1183.0]], [[440.0, 1019.0], [468.0, 1019.0], [468.0, 1212.0], [440.0, 1212.0]], [[401.0, 1018.0], [430.0, 1018.0], [430.0, 1147.0], [401.0, 1147.0]]], "lines": ["その日付けで", "あたしは辞表を", "提出した。"]}], "img_path": "027.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "028.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "029.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [786, 306, 810, 377], "vertical": true, "font_size": 24, "lines_coords": [[[786.0, 306.0], [810.0, 306.0], [810.0, 377.0], [786.0, 377.0]]], "lines": ["ほぉ．．．"]}, {"box": [735, 462, 825, 600], "vertical": true, "font_size": 24, "lines_coords": [[[797.0, 462.0], [825.0, 462.0], [825.0, 556.0], [797.0, 556.0]], [[768.0, 462.0], [791.0, 462.0], [788.0, 600.0], [765.0, 600.0]], [[735.0, 463.0], [758.0, 463.0], [758.0, 556.0], [735.0, 556.0]]], "lines": ["カレーの", "トッピングに", "焼き魚．．．"]}, {"box": [144, 537, 261, 698], "vertical": true, "font_size": 23, "lines_coords": [[[237.0, 540.0], [261.0, 540.0], [261.0, 634.0], [237.0, 634.0]], [[205.0, 538.0], [228.0, 538.0], [228.0, 675.0], [205.0, 675.0]], [[174.0, 537.0], [198.0, 537.0], [195.0, 698.0], [172.0, 698.0]], [[144.0, 540.0], [164.0, 540.0], [164.0, 675.0], [144.0, 675.0]]], "lines": ["この場合", "箸とスプーン", "どっち使うのか", "なーなんて．．．"]}, {"box": [807, 735, 894, 917], "vertical": true, "font_size": 22, "lines_coords": [[[869.0, 735.0], [892.0, 735.0], [894.0, 902.0], [870.0, 902.0]], [[839.0, 738.0], [862.0, 738.0], [862.0, 872.0], [839.0, 872.0]], [[809.0, 739.0], [828.0, 739.0], [828.0, 917.0], [809.0, 917.0]]], "lines": ["．．．芽衣子さん、", "これは新しい", "いやがらせかい？"]}, {"box": [251, 786, 313, 961], "vertical": true, "font_size": 30, "lines_coords": [[[276.0, 786.0], [313.0, 786.0], [313.0, 844.0], [276.0, 844.0]], [[251.0, 791.0], [274.0, 791.0], [274.0, 961.0], [251.0, 961.0]]], "lines": ["仕事", "行ってくるダス。"]}, {"box": [136, 862, 194, 1045], "vertical": true, "font_size": 25, "lines_coords": [[[166.0, 862.0], [191.0, 862.0], [192.0, 1044.0], [168.0, 1044.0]], [[136.0, 864.0], [161.0, 864.0], [161.0, 944.0], [136.0, 944.0]]], "lines": ["行ってらっしゃい", "ザンス。"]}, {"box": [642, 995, 746, 1153], "vertical": true, "font_size": 22, "lines_coords": [[[723.0, 995.0], [746.0, 995.0], [746.0, 1152.0], [723.0, 1152.0]], [[695.0, 995.0], [719.0, 995.0], [719.0, 1153.0], [695.0, 1153.0]], [[669.0, 995.0], [689.0, 995.0], [689.0, 1130.0], [669.0, 1130.0]], [[642.0, 995.0], [661.0, 995.0], [661.0, 1092.0], [642.0, 1092.0]]], "lines": ["いや、フツーに", "日本人なら朝は", "やっぱ焼き魚", "だろうと。"]}, {"box": [605, 1186, 691, 1326], "vertical": true, "font_size": 22, "lines_coords": [[[668.0, 1186.0], [691.0, 1186.0], [691.0, 1326.0], [668.0, 1326.0]], [[637.0, 1188.0], [660.0, 1188.0], [660.0, 1324.0], [637.0, 1324.0]], [[605.0, 1188.0], [628.0, 1188.0], [628.0, 1290.0], [605.0, 1290.0]]], "lines": ["でもカレーも", "余ってたから", "折衷案で。"]}, {"box": [83, 1145, 168, 1330], "vertical": true, "font_size": 22, "lines_coords": [[[144.0, 1145.0], [168.0, 1145.0], [168.0, 1330.0], [144.0, 1330.0]], [[113.0, 1147.0], [136.0, 1147.0], [136.0, 1307.0], [113.0, 1307.0]], [[83.0, 1149.0], [102.0, 1149.0], [102.0, 1260.0], [83.0, 1260.0]]], "lines": ["．．．明日はカレーに", "トースト乗せて", "みよう．．．"]}], "img_path": "030.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [658, 653, 746, 884], "vertical": true, "font_size": 25, "lines_coords": [[[719.0, 654.0], [746.0, 654.0], [746.0, 794.0], [719.0, 794.0]], [[690.0, 654.0], [713.0, 654.0], [713.0, 884.0], [690.0, 884.0]], [[658.0, 654.0], [682.0, 654.0], [682.0, 814.0], [658.0, 814.0]]], "lines": ["残務整理とか", "仕事の引き継ぎとかを", "どうにか片付け"]}, {"box": [531, 654, 591, 816], "vertical": true, "font_size": 28, "lines_coords": [[[564.0, 654.0], [591.0, 654.0], [591.0, 816.0], [564.0, 816.0]], [[531.0, 654.0], [560.0, 654.0], [560.0, 739.0], [531.0, 739.0]]], "lines": ["あたしは会社を", "辞めた。"]}, {"box": [345, 653, 466, 865], "vertical": true, "font_size": 25, "lines_coords": [[[441.0, 658.0], [464.0, 658.0], [464.0, 825.0], [441.0, 825.0]], [[407.0, 654.0], [434.0, 654.0], [434.0, 794.0], [407.0, 794.0]], [[375.0, 653.0], [403.0, 653.0], [400.0, 829.0], [373.0, 829.0]], [[345.0, 654.0], [369.0, 654.0], [369.0, 865.0], [345.0, 865.0]]], "lines": ["「君みたいな奴は", "何をやっても", "長続きはしない」", "という上司の言葉や、"]}, {"box": [187, 653, 279, 836], "vertical": true, "font_size": 26, "lines_coords": [[[255.0, 657.0], [274.0, 657.0], [274.0, 835.0], [255.0, 835.0]], [[216.0, 653.0], [244.0, 653.0], [247.0, 794.0], [218.0, 794.0]], [[187.0, 653.0], [216.0, 653.0], [216.0, 750.0], [187.0, 750.0]]], "lines": ["同僚の白い目には", "心が痛かった", "けど．．．"]}, {"box": [769, 1017, 843, 1310], "vertical": true, "font_size": 34, "lines_coords": [[[809.0, 1024.0], [843.0, 1024.0], [843.0, 1110.0], [809.0, 1110.0]], [[777.0, 1185.0], [810.0, 1185.0], [810.0, 1300.0], [777.0, 1300.0]]], "lines": ["んっ．．．", "ぷはぁ。"]}, {"box": [167, 985, 248, 1181], "vertical": true, "font_size": 32, "lines_coords": [[[209.0, 987.0], [243.0, 985.0], [248.0, 1127.0], [214.0, 1129.0]], [[169.0, 989.0], [198.0, 989.0], [198.0, 1179.0], [169.0, 1179.0]]], "lines": ["．．．あぁっ、", "なんて自由！！"]}], "img_path": "031.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [776, 108, 868, 226], "vertical": true, "font_size": 24, "lines_coords": [[[840.0, 109.0], [864.0, 109.0], [866.0, 225.0], [843.0, 225.0]], [[813.0, 113.0], [832.0, 113.0], [832.0, 225.0], [813.0, 225.0]], [[776.0, 108.0], [806.0, 108.0], [806.0, 170.0], [776.0, 170.0]]], "lines": ["気が向けば", "ふらふらと", "散歩。"]}, {"box": [509, 95, 573, 259], "vertical": true, "font_size": 28, "lines_coords": [[[548.0, 99.0], [571.0, 99.0], [571.0, 259.0], [548.0, 259.0]], [[509.0, 97.0], [541.0, 95.0], [544.0, 158.0], [512.0, 159.0]]], "lines": ["天気がよければ", "洗濯。"]}, {"box": [68, 39, 192, 65], "vertical": false, "font_size": 23, "lines_coords": [[[68.0, 42.0], [192.0, 39.0], [192.0, 62.0], [68.0, 65.0]]], "lines": ["ソラニンの"]}, {"box": [56, 306, 144, 475], "vertical": true, "font_size": 23, "lines_coords": [[[118.0, 306.0], [143.0, 306.0], [143.0, 422.0], [118.0, 422.0]], [[87.0, 306.0], [110.0, 306.0], [110.0, 445.0], [87.0, 445.0]], [[56.0, 307.0], [76.0, 307.0], [77.0, 474.0], [57.0, 474.0]]], "lines": ["下手なりに", "凝った料理に", "挑戦したりして、"]}, {"box": [124, 563, 154, 643], "vertical": true, "font_size": 27, "lines_coords": [[[124.0, 563.0], [154.0, 563.0], [154.0, 643.0], [124.0, 643.0]]], "lines": ["それと、"]}, {"box": [185, 654, 209, 769], "vertical": true, "font_size": 27, "lines_coords": [[[185.0, 654.0], [209.0, 654.0], [209.0, 769.0], [185.0, 769.0]]], "lines": ["それと．．．"]}, {"box": [149, 954, 179, 1095], "vertical": true, "font_size": 28, "lines_coords": [[[149.0, 954.0], [179.0, 954.0], [179.0, 1013.0], [149.0, 1013.0]], [[151.0, 1021.0], [176.0, 1021.0], [176.0, 1095.0], [151.0, 1095.0]]], "lines": ["むー", "ん．．．"]}, {"box": [608, 1116, 683, 1302], "vertical": true, "font_size": 24, "lines_coords": [[[641.0, 1116.0], [664.0, 1116.0], [667.0, 1300.0], [643.0, 1300.0]], [[608.0, 1116.0], [633.0, 1116.0], [637.0, 1263.0], [612.0, 1263.0]]], "lines": ["目的の無い自由は", "まるで退屈で、"]}, {"box": [330, 1112, 518, 1325], "vertical": true, "font_size": 29, "lines_coords": [[[490.0, 1118.0], [518.0, 1118.0], [518.0, 1324.0], [490.0, 1324.0]], [[451.0, 1112.0], [493.0, 1112.0], [493.0, 1177.0], [451.0, 1177.0]], [[429.0, 1119.0], [452.0, 1119.0], [452.0, 1257.0], [429.0, 1257.0]], [[397.0, 1118.0], [421.0, 1118.0], [421.0, 1324.0], [397.0, 1324.0]], [[363.0, 1115.0], [392.0, 1115.0], [392.0, 1211.0], [363.0, 1211.0]], [[330.0, 1116.0], [359.0, 1116.0], [362.0, 1220.0], [333.0, 1220.0]]], "lines": ["なんのひっかかりも", "なく、", "流れるように", "日々が過ぎることを", "１週間で", "思い知る。"]}], "img_path": "032.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [679, 58, 712, 255], "vertical": true, "font_size": 27, "lines_coords": [[[679.0, 58.0], [712.0, 58.0], [712.0, 255.0], [679.0, 255.0]]], "lines": ["うえーーっ！？"]}, {"box": [516, 144, 623, 330], "vertical": true, "font_size": 27, "lines_coords": [[[600.0, 147.0], [623.0, 147.0], [623.0, 330.0], [600.0, 330.0]], [[572.0, 147.0], [596.0, 147.0], [596.0, 308.0], [572.0, 308.0]], [[542.0, 146.0], [567.0, 146.0], [568.0, 308.0], [544.0, 308.0]], [[516.0, 144.0], [546.0, 144.0], [546.0, 203.0], [516.0, 203.0]]], "lines": ["あんたがスタジオ", "見に来るなんて", "珍しいと思った", "けど、"]}, {"box": [109, 95, 199, 233], "vertical": true, "font_size": 23, "lines_coords": [[[173.0, 95.0], [196.0, 95.0], [196.0, 233.0], [173.0, 233.0]], [[142.0, 95.0], [165.0, 95.0], [165.0, 233.0], [142.0, 233.0]], [[109.0, 95.0], [133.0, 95.0], [133.0, 185.0], [109.0, 185.0]]], "lines": ["ホントに会社", "辞めちゃった", "のー！？"]}, {"box": [566, 689, 591, 700], "vertical": false, "font_size": 11, "lines_coords": [[[566.0, 689.0], [591.0, 689.0], [591.0, 700.0], [566.0, 700.0]]], "lines": ["でもお話の申し込みたらそんで負けてきた"]}, {"box": [125, 411, 219, 553], "vertical": true, "font_size": 24, "lines_coords": [[[194.0, 415.0], [218.0, 415.0], [218.0, 508.0], [194.0, 508.0]], [[161.0, 412.0], [188.0, 412.0], [188.0, 553.0], [161.0, 553.0]], [[132.0, 411.0], [157.0, 414.0], [150.0, 466.0], [125.0, 463.0]], [[133.0, 464.0], [153.0, 464.0], [153.0, 516.0], [133.0, 516.0]]], "lines": ["ホントに", "辞めちゃった", "のー", "ーん"]}, {"box": [793, 650, 911, 817], "vertical": true, "font_size": 22, "lines_coords": [[[888.0, 650.0], [911.0, 650.0], [911.0, 810.0], [888.0, 810.0]], [[854.0, 650.0], [877.0, 650.0], [877.0, 817.0], [854.0, 817.0]], [[824.0, 652.0], [847.0, 652.0], [847.0, 813.0], [824.0, 813.0]], [[794.0, 652.0], [813.0, 652.0], [813.0, 810.0], [794.0, 810.0]]], "lines": ["．．．まぁーー散々", "グチ聞いてたし、", "時間の問題だと", "思ってたけど．．"]}, {"box": [733, 659, 912, 974], "vertical": true, "font_size": 23, "lines_coords": [[[769.0, 853.0], [792.0, 853.0], [792.0, 972.0], [769.0, 972.0]], [[738.0, 851.0], [761.0, 851.0], [761.0, 944.0], [738.0, 944.0]]], "lines": ["大丈夫なの、", "芽衣子？"]}, {"box": [737, 852, 793, 976], "vertical": true, "font_size": 56, "lines_coords": [[[737.0, 852.0], [793.0, 852.0], [793.0, 976.0], [737.0, 976.0]]], "lines": ["大丈夫なの、芽衣子？"]}, {"box": [623, 700, 663, 747], "vertical": false, "font_size": 17.0, "lines_coords": [[[623.0, 700.0], [663.0, 700.0], [663.0, 720.0], [623.0, 720.0]], [[628.0, 716.0], [658.0, 716.0], [658.0, 732.0], [628.0, 732.0]], [[626.0, 732.0], [658.0, 732.0], [658.0, 747.0], [626.0, 747.0]]], "lines": ["Ｄｒ．．．", "素人", "ありがとうございません"]}, {"box": [512, 715, 601, 732], "vertical": false, "font_size": 15, "lines_coords": [[[512.0, 715.0], [601.0, 717.0], [601.0, 732.0], [512.0, 730.0]]], "lines": ["新年は現場でもお勧めの場合でしたが、私以外に連れて行われ、無事でもありますが、"]}, {"box": [254, 682, 340, 868], "vertical": true, "font_size": 23, "lines_coords": [[[315.0, 684.0], [339.0, 684.0], [339.0, 868.0], [315.0, 868.0]], [[280.0, 682.0], [307.0, 682.0], [311.0, 859.0], [284.0, 859.0]], [[254.0, 686.0], [273.0, 686.0], [273.0, 828.0], [254.0, 828.0]]], "lines": ["あら、アイちゃん", "あたしけっこー", "貯金あるのよ。"]}, {"box": [124, 849, 247, 988], "vertical": true, "font_size": 25, "lines_coords": [[[218.0, 851.0], [247.0, 851.0], [247.0, 924.0], [218.0, 924.0]], [[190.0, 851.0], [213.0, 851.0], [213.0, 972.0], [190.0, 972.0]], [[157.0, 850.0], [181.0, 850.0], [179.0, 944.0], [154.0, 944.0]], [[127.0, 849.0], [150.0, 849.0], [147.0, 988.0], [124.0, 988.0]]], "lines": ["お金も", "そうだけど、", "これから", "どーすんの？"]}, {"box": [802, 1069, 917, 1209], "vertical": true, "font_size": 23, "lines_coords": [[[895.0, 1147.0], [914.0, 1147.0], [914.0, 1192.0], [895.0, 1192.0]], [[890.0, 1070.0], [917.0, 1070.0], [917.0, 1121.0], [890.0, 1121.0]], [[862.0, 1070.0], [885.0, 1070.0], [885.0, 1188.0], [862.0, 1188.0]], [[835.0, 1073.0], [854.0, 1073.0], [854.0, 1209.0], [835.0, 1209.0]], [[802.0, 1069.0], [827.0, 1069.0], [829.0, 1158.0], [805.0, 1158.0]]], "lines": ["ーと", "んー", "とりあえず", "夏物の服買う", "でしょー"]}, {"box": [686, 1132, 797, 1297], "vertical": true, "font_size": 23, "lines_coords": [[[773.0, 1132.0], [797.0, 1132.0], [795.0, 1297.0], [772.0, 1297.0]], [[743.0, 1134.0], [766.0, 1134.0], [766.0, 1246.0], [743.0, 1246.0]], [[715.0, 1134.0], [738.0, 1134.0], [738.0, 1229.0], [715.0, 1229.0]], [[686.0, 1134.0], [709.0, 1134.0], [709.0, 1233.0], [686.0, 1233.0]]], "lines": ["そんで車の免許", "とってぇー", "海外旅行", "行ってぇ"]}, {"box": [266, 1112, 324, 1234], "vertical": true, "font_size": 24, "lines_coords": [[[299.0, 1112.0], [324.0, 1112.0], [324.0, 1233.0], [299.0, 1233.0]], [[266.0, 1112.0], [295.0, 1112.0], [295.0, 1234.0], [266.0, 1234.0]]], "lines": ["うわーーん、", "コワーーい。"]}, {"box": [139, 1147, 222, 1330], "vertical": true, "font_size": 24, "lines_coords": [[[203.0, 1148.0], [222.0, 1148.0], [222.0, 1330.0], [203.0, 1330.0]], [[169.0, 1147.0], [192.0, 1147.0], [192.0, 1241.0], [169.0, 1241.0]], [[139.0, 1147.0], [162.0, 1147.0], [162.0, 1244.0], [139.0, 1244.0]]], "lines": ["もうすぐ２％なのに", "思考が超", "非建設的"]}], "img_path": "033.png"}, {"version": "0.2.0-beta.6", "img_width": 952, "img_height": 1400, "blocks": [{"box": [774, 90, 874, 386], "vertical": true, "font_size": 24, "lines_coords": [[[848.0, 94.0], [871.0, 94.0], [874.0, 232.0], [850.0, 232.0]], [[817.0, 92.0], [841.0, 92.0], [841.0, 241.0], [817.0, 241.0]], [[785.0, 90.0], [816.0, 91.0], [805.0, 386.0], [774.0, 385.0]]], "lines": ["．．．とか言って", "毎日家周辺で", "ダラダラしててなんか何を"]}, {"box": [659, 105, 689, 159], "vertical": false, "font_size": 54, "lines_coords": [[[659.0, 105.0], [689.0, 105.0], [689.0, 159.0], [659.0, 159.0]]], "lines": ["むぅ"]}, {"box": [369, 92, 477, 298], "vertical": true, "font_size": 23, "lines_coords": [[[454.0, 92.0], [477.0, 92.0], [477.0, 218.0], [454.0, 218.0]], [[425.0, 94.0], [448.0, 94.0], [448.0, 254.0], [425.0, 254.0]], [[396.0, 92.0], [419.0, 92.0], [419.0, 298.0], [396.0, 298.0]], [[369.0, 92.0], [393.0, 92.0], [393.0, 172.0], [369.0, 172.0]]], "lines": ["なーんだ。", "せっかくの自由", "持て余しちゃってん", "じゃん。"]}, {"box": [683, 266, 768, 434], "vertical": true, "font_size": 24, "lines_coords": [[[749.0, 269.0], [768.0, 269.0], [768.0, 403.0], [749.0, 403.0]], [[714.0, 266.0], [737.0, 266.0], [737.0, 434.0], [714.0, 434.0]], [[683.0, 267.0], [707.0, 267.0], [707.0, 412.0], [683.0, 412.0]]], "lines": ["やるにしても", "気が乗らないし、", "腰が重いんス。"]}, {"box": [363, 555, 389, 658], "vertical": true, "font_size": 21, "lines_coords": [[[363.0, 555.0], [387.0, 555.0], [389.0, 658.0], [366.0, 658.0]]], "lines": ["．．．種田ぁ。"]}, {"box": [79, 313, 136, 519], "vertical": true, "font_size": 26, "lines_coords": [[[108.0, 314.0], [136.0, 314.0], [136.0, 453.0], [108.0, 453.0]], [[79.0, 314.0], [102.0, 314.0], [102.0, 519.0], [79.0, 519.0]]], "lines": ["．．．で、種田は", "なんて言ってんの？"]}, {"box": [221, 601, 306, 719], "vertical": true, "font_size": 21, "lines_coords": [[[287.0, 602.0], [306.0, 602.0], [306.0, 719.0], [287.0, 719.0]], [[255.0, 604.0], [274.0, 604.0], [274.0, 715.0], [255.0, 715.0]], [[221.0, 601.0], [244.0, 601.0], [244.0, 683.0], [221.0, 683.0]]], "lines": ["あたし今日", "辞表出して", "きたよ。"]}, {"box": [798, 730, 858, 833], "vertical": true, "font_size": 25, "lines_coords": [[[828.0, 730.0], [858.0, 730.0], [858.0, 768.0], [828.0, 768.0]], [[801.0, 731.0], [824.0, 731.0], [822.0, 833.0], [798.0, 833.0]]], "lines": ["おー", "マジすか。"]}, {"box": [723, 838, 809, 962], "vertical": true, "font_size": 25, "lines_coords": [[[785.0, 838.0], [809.0, 838.0], [807.0, 932.0], [782.0, 932.0]], [[750.0, 839.0], [779.0, 839.0], [779.0, 936.0], [750.0, 936.0]], [[723.0, 842.0], [742.0, 842.0], [742.0, 962.0], [723.0, 962.0]]], "lines": ["あ、この", "肉じゃが", "おいしいね。"]}, {"box": [467, 880, 491, 1020], "vertical": true, "font_size": 24, "lines_coords": [[[467.0, 880.0], [491.0, 880.0], [491.0, 962.0], [467.0, 962.0]]], "lines": ["でしょー"]}, {"box": [331, 798, 357, 913], "vertical": true, "font_size": 24, "lines_coords": [[[331.0, 798.0], [354.0, 798.0], [357.0, 913.0], [333.0, 913.0]]], "lines": ["ほぶぁっ！！"]}, {"box": [69, 827, 141, 965], "vertical": true, "font_size": 27, "lines_coords": [[[114.0, 829.0], [138.0, 829.0], [138.0, 963.0], [114.0, 963.0]], [[72.0, 827.0], [102.0, 828.0], [99.0, 911.0], [69.0, 910.0]]], "lines": ["出したって", "何を！？"]}, {"box": [57, 1021, 119, 1096], "vertical": true, "font_size": 31, "lines_coords": [[[88.0, 1021.0], [119.0, 1021.0], [119.0, 1096.0], [88.0, 1096.0]], [[57.0, 1021.0], [88.0, 1021.0], [88.0, 1081.0], [57.0, 1081.0]]], "lines": ["だから", "辞表。"]}, {"box": [81, 1223, 103, 1326], "vertical": true, "font_size": 19, "lines_coords": [[[82.0, 1225.0], [101.0, 1225.0], [101.0, 1324.0], [82.0, 1324.0]]], "lines": ["反応おそ。"]}], "img_path": "034.png"}, {"version": "0.2.0-beta.6", "img_width": 975, "img_height": 1400, "blocks": [{"box": [799, 98, 888, 278], "vertical": true, "font_size": 24, "lines_coords": [[[861.0, 98.0], [888.0, 98.0], [888.0, 266.0], [861.0, 266.0]], [[828.0, 98.0], [853.0, 98.0], [854.0, 226.0], [830.0, 226.0]], [[799.0, 99.0], [819.0, 99.0], [819.0, 278.0], [799.0, 278.0]]], "lines": ["やっぱいじゃん、", "それかなり", "やっぱいじゃん！！"]}, {"box": [705, 229, 760, 393], "vertical": true, "font_size": 24, "lines_coords": [[[737.0, 231.0], [760.0, 231.0], [760.0, 378.0], [737.0, 378.0]], [[706.0, 229.0], [730.0, 229.0], [728.0, 393.0], [705.0, 393.0]]], "lines": ["俺らこれから", "どーすんのさ！？"]}, {"box": [305, 129, 424, 293], "vertical": true, "font_size": 22, "lines_coords": [[[399.0, 132.0], [422.0, 132.0], [422.0, 246.0], [399.0, 246.0]], [[367.0, 129.0], [391.0, 129.0], [391.0, 280.0], [367.0, 280.0]], [[335.0, 129.0], [359.0, 129.0], [359.0, 236.0], [335.0, 236.0]], [[307.0, 132.0], [326.0, 132.0], [326.0, 291.0], [307.0, 291.0]]], "lines": ["いや種田が", "「俺がどーにか", "する」って", "言ったじゃん！！"]}, {"box": [195, 251, 281, 434], 