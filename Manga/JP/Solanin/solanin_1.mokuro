, "ですね。"]}, {"box": [425, 181, 512, 364], "vertical": true, "font_size": 22, "lines_coords": [[[489.0, 183.0], [509.0, 183.0], [511.0, 362.0], [490.0, 362.0]], [[458.0, 181.0], [481.0, 181.0], [481.0, 318.0], [458.0, 318.0]], [[425.0, 181.0], [448.0, 181.0], [448.0, 296.0], [425.0, 296.0]]], "lines": ["そろそろフォース", "使えるんじゃ", "ないスか？"]}, {"box": [142, 23, 168, 103], "vertical": true, "font_size": 21, "lines_coords": [[[142.0, 24.0], [162.0, 23.0], [168.0, 102.0], [147.0, 103.0]]], "lines": ["長老か"]}, {"box": [98, 177, 187, 337], "vertical": true, "font_size": 23, "lines_coords": [[[162.0, 177.0], [187.0, 177.0], [184.0, 317.0], [159.0, 317.0]], [[129.0, 179.0], [153.0, 179.0], [153.0, 337.0], [129.0, 337.0]], [[99.0, 179.0], [120.0, 179.0], [118.0, 314.0], [98.0, 314.0]]], "lines": ["俺はどっかの", "緑色の妖怪じゃ", "ねーんだよ！！"]}, {"box": [172, 488, 202, 582], "vertical": true, "font_size": 30, "lines_coords": [[[172.0, 488.0], [202.0, 488.0], [202.0, 582.0], [172.0, 582.0]]], "lines": ["チッ．．．"]}, {"box": [779, 952, 835, 1089], "vertical": true, "font_size": 23, "lines_coords": [[[812.0, 952.0], [835.0, 952.0], [835.0, 1089.0], [812.0, 1089.0]], [[780.0, 952.0], [803.0, 952.0], [803.0, 1080.0], [780.0, 1080.0]]], "lines": ["先輩、ベース", "上手っすね。"]}, {"box": [347, 1142, 437, 1305], "vertical": true, "font_size": 24, "lines_coords": [[[414.0, 1142.0], [437.0, 1142.0], [434.0, 1282.0], [411.0, 1282.0]], [[381.0, 1145.0], [404.0, 1145.0], [404.0, 1305.0], [381.0, 1305.0]], [[347.0, 1145.0], [371.0, 1144.0], [374.0, 1223.0], [349.0, 1225.0]]], "lines": ["まぁ、たまに", "運指が乱れてる", "けれど。"]}, {"box": [69, 1170, 161, 1333], "vertical": true, "font_size": 25, "lines_coords": [[[133.0, 1173.0], [161.0, 1173.0], [161.0, 1311.0], [133.0, 1311.0]], [[103.0, 1173.0], [127.0, 1173.0], [127.0, 1333.0], [103.0, 1333.0]], [[72.0, 1170.0], [95.0, 1170.0], [92.0, 1308.0], [69.0, 1308.0]]], "lines": ["つーか１人で", "弾いてて寂しく", "ないっすか？"]}], "img_path": "087.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1