, 695.0], [261.0, 810.0], [237.0, 810.0]]], "lines": ["よー", "考えてみ？"]}, {"box": [612, 1023, 636, 1138], "vertical": true, "font_size": 23, "lines_coords": [[[612.0, 1026.0], [635.0, 1026.0], [635.0, 1137.0], [612.0, 1137.0]]], "lines": ["．．．ハイ！！"]}, {"box": [354, 1084, 412, 1199], "vertical": true, "font_size": 26, "lines_coords": [[[382.0, 1084.0], [412.0, 1084.0], [412.0, 1156.0], [382.0, 1156.0]], [[354.0, 1085.0], [377.0, 1085.0], [377.0, 1199.0], [354.0, 1199.0]]], "lines": ["走って", "帰ります！！"]}], "img_path": "097.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "098.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "099.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [661, 200, 812, 429], "vertical": true, "font_size": 23, "lines_coords": [[[790.0, 205.0], [809.0, 205.0], [809.0, 406.0], [790.0, 406.0]], [[754.0, 200.0], [783.0, 200.0], [783.0, 285.0], [754.0, 285.0]], [[724.0, 202.0], [747.0, 202.0], [747.0, 429.0], [724.0, 429.0]], [[694.0, 203.0], [713.0, 203.0], [713.0, 359.0], [694.0, 359.0]], [[661.0, 200.0], [684.0, 200.0], [684.0, 322.0], [661.0, 322.0]]], "lines": ["あたしのアパートは", "築２５年。", "リフォームを繰り返し", "だましたましの", "ボロイ部屋。"]}, {"box": [163, 272, 283, 479], "vertical": true, "font_size": 23, "lines_coords": [[[258.0, 274.0], [281.0, 274.0], [281.0, 393.0], [258.0, 393.0]], [[225.0, 273.0], [248.0, 273.0], [248.0, 479.0], [225.0, 479.0]], [[192.0, 272.0], [220.0, 272.0], [220.0, 412.0], [192.0, 412.0]], [[165.0, 274.0], [184.0, 274.0], [184.0, 397.0], [165.0, 397.0]]], "lines": ["ついに先日、", "ウチのエアコン君が", "お亡くなりに", "なりました。"]}, {"box": [778, 624, 834, 807], "vertical": true, "font_size": 21, "lines_coords": [[[810.0, 626.0], [833.0, 626.0], [833.0, 806.0], [810.0, 806.0]], [[780.0, 626.0], [799.0, 626.0], [799.0, 782.0], [780.0, 782.0]]], "lines": ["電気屋に行こうと", "外に出たものの"]}, {"box": [591, 623, 712, 829], "vertical": true, "font_size": 26, "lines_coords": [[[683.0, 623.0], [712.0, 623.0], [712.0, 808.0], [683.0, 808.0]], [[652.0, 623.0], [679.0, 623.0], [679.0, 808.0], [652.0, 808.0]], [[623.0, 624.0], [646.0, 624.0], [646.0, 828.0], [623.0, 828.0]], [[591.0, 624.0], [615.0, 624.0], [615.0, 792.0], [591.0, 792.0]]], "lines": ["本来、私は今ごろ", "冷え過ぎの職場で", "キーボードを叩いて", "いたハズな訳で、"]}, {"box": [324, 620, 444, 806], "vertical": true, "font_size": 25, "lines_coords": [[[416.0, 620.0], [444.0, 620.0], [444.0, 760.0], [416.0, 760.0]], [[386.0, 622.0], [411.0, 622.0], [408.0, 760.0], [384.0, 760.0]], [[355.0, 624.0], [378.0, 624.0], [378.0, 803.0], [355.0, 803.0]], [[324.0, 623.0], [347.0, 623.0], [347.0, 806.0], [324.0, 806.0]]], "lines": ["平日の昼間に", "真夏の太陽を", "全身で感じられる", "よろこびについて"]}, {"box": [206, 619, 231, 835], "vertical": true, "font_size": 19, "lines_coords": [[[209.0, 623.0], [228.0, 623.0], [228.0, 828.0], [209.0, 828.0]]], "lines": ["ちょっと考えてみる"]}, {"box": [503, 1151, 527, 1268], "vertical": true, "font_size": 23, "lines_coords": [[[503.0, 1151.0], [526.0, 1151.0], [526.0, 1267.0], [503.0, 1267.0]]], "lines": ["．．．いいね！"]}, {"box": [407, 1151, 466, 1343], "vertical": true, "font_size": 28, "lines_coords": [[[437.0, 1151.0], [466.0, 1151.0], [466.0, 1268.0], [437.0, 1268.0]], [[407.0, 1151.0], [434.0, 1151.0], [434.0, 1343.0], [407.0, 1343.0]]], "lines": ["いいね夏！！", "すっげー暑いけど。"]}, {"box": [313, 1151, 369, 1290], "vertical": true, "font_size": 23, "lines_coords": [[[344.0, 1152.0], [367.0, 1152.0], [367.0, 1290.0], [344.0, 1290.0]], [[313.0, 1151.0], [336.0, 1151.0], [336.0, 1289.0], [313.0, 1289.0]]], "lines": ["なんつーの？", "この解放感？"]}, {"box": [136, 1149, 195, 1333], "vertical": true, "font_size": 25, "lines_coords": [[[166.0, 1149.0], [191.0, 1149.0], [194.0, 1333.0], [169.0, 1333.0]], [[136.0, 1149.0], [161.0, 1149.0], [161.0, 1264.0], [136.0, 1264.0]]], "lines": ["いただきましょう", "この感じ！"]}], "img_path": "100.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [799, 109, 888, 261], "vertical": true, "font_size": 24, "lines_coords": [[[859.0, 109.0], [888.0, 110.0], [885.0, 187.0], [857.0, 185.0]], [[829.0, 114.0], [854.0, 114.0], [854.0, 231.0], [829.0, 231.0]], [[801.0, 114.0], [820.0, 114.0], [820.0, 259.0], [801.0, 259.0]]], "lines": ["ご利用", "ありがとう", "ございました。"]}, {"box": [258, 113, 346, 251], "vertical": true, "font_size": 23, "lines_coords": [[[321.0, 114.0], [344.0, 114.0], [344.0, 229.0], [321.0, 229.0]], [[288.0, 114.0], [311.0, 114.0], [311.0, 251.0], [288.0, 251.0]]], "lines": ["残高を見て", "気分がたいぶ"]}, {"box": [257, 116, 280, 235], "vertical": true, "font_size": 27, "lines_coords": [[[257.0, 116.0], [280.0, 116.0], [280.0, 235.0], [257.0, 235.0]]], "lines": ["盛り下がる。"]}, {"box": [173, 277, 206, 354], "vertical": true, "font_size": 27, "lines_coords": [[[173.0, 278.0], [203.0, 277.0], [206.0, 352.0], [176.0, 354.0]]], "lines": ["着々と"]}, {"box": [754, 576, 844, 715], "vertical": true, "font_size": 23, "lines_coords": [[[820.0, 576.0], [843.0, 576.0], [843.0, 691.0], [820.0, 691.0]], [[788.0, 576.0], [812.0, 576.0], [812.0, 715.0], [788.0, 715.0]], [[754.0, 576.0], [777.0, 576.0], [780.0, 695.0], [757.0, 695.0]]], "lines": ["．．．さすがに", "この夏は越え", "られるけど、"]}, {"box": [115, 278, 201, 498], "vertical": true, "font_size": 26, "lines_coords": [[[142.0, 278.0], [170.0, 278.0], [173.0, 466.0], [144.0, 466.0]], [[116.0, 280.0], [139.0, 280.0], [139.0, 493.0], [116.0, 493.0]]], "lines": ["タイムリミットは", "近づいているようだ。"]}, {"box": [118, 763, 259, 1051], "vertical": true, "font_size": 26, "lines_coords": [[[232.0, 764.0], [259.0, 764.0], [259.0, 905.0], [232.0, 905.0]], [[210.0, 911.0], [241.0, 911.0], [241.0, 973.0], [210.0, 973.0]], [[180.0, 911.0], [205.0, 911.0], [206.0, 1051.0], [181.0, 1051.0]], [[150.0, 913.0], [173.0, 913.0], [173.0, 1028.0], [150.0, 1028.0]], [[118.0, 913.0], [142.0, 913.0], [142.0, 1006.0], [118.0, 1006.0]]], "lines": ["あと１年．．．", "いや、", "節約しなきゃ", "半年くらい", "かも．．．"]}, {"box": [741, 1100, 828, 1283], "vertical": true, "font_size": 23, "lines_coords": [[[802.0, 1100.0], [825.0, 1100.0], [828.0, 1261.0], [805.0, 1261.0]], [[772.0, 1100.0], [795.0, 1100.0], [795.0, 1283.0], [772.0, 1283.0]], [[741.0, 1100.0], [765.0, 1100.0], [765.0, 1194.0], [741.0, 1194.0]]], "lines": ["クーラー購入は", "ちょっと見合わせ", "よう．．．"]}], "img_path": "101.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [824, 90, 880, 205], "vertical": true, "font_size": 25, "lines_coords": [[[855.0, 91.0], [880.0, 91.0], [880.0, 180.0], [855.0, 180.0]], [[824.0, 90.0], [847.0, 90.0], [847.0, 205.0], [824.0, 205.0]]], "lines": ["．．．．．あっ", "井上先輩！！"]}, {"box": [706, 129, 795, 292], "vertical": true, "font_size": 25, "lines_coords": [[[772.0, 129.0], [795.0, 129.0], [795.0, 269.0], [772.0, 269.0]], [[734.0, 131.0], [762.0, 129.0], [766.0, 235.0], [738.0, 236.0]], [[708.0, 129.0], [731.0, 129.0], [730.0, 292.0], [706.0, 292.0]]], "lines": ["何やってるん", "ですかぁ、", "こんなトコで？"]}, {"box": [602, 88, 627, 184], "vertical": true, "font_size": 25, "lines_coords": [[[602.0, 88.0], [627.0, 88.0], [627.0, 181.0], [602.0, 181.0]]], "lines": ["うっ．．．"]}, {"box": [349, 87, 408, 272], "vertical": true, "font_size": 25, "lines_coords": [[[382.0, 87.0], [407.0, 87.0], [408.0, 272.0], [384.0, 272.0]], [[352.0, 88.0], [377.0, 88.0], [374.0, 228.0], [349.0, 228.0]]], "lines": ["あたしはちょっと", "買いもの．．．"]}, {"box": [248, 210, 337, 363], "vertical": true, "font_size": 25, "lines_coords": [[[314.0, 211.0], [337.0, 211.0], [337.0, 306.0], [314.0, 306.0]], [[280.0, 210.0], [307.0, 210.0], [307.0, 363.0], [280.0, 363.0]], [[248.0, 210.0], [273.0, 210.0], [273.0, 303.0], [248.0, 303.0]]], "lines": ["部長達は", "これからお昼", "ですか？"]}, {"box": [98, 270, 151, 407], "vertical": true, "font_size": 23, "lines_coords": [[[128.0, 270.0], [151.0, 270.0], [151.0, 407.0], [128.0, 407.0]], [[98.0, 270.0], [121.0, 270.0], [121.0, 385.0], [98.0, 385.0]]], "lines": ["そーなんです", "よぉーー！！"]}, {"box": [116, 452, 221, 643], "vertical": true, "font_size": 23, "lines_coords": [[[198.0, 452.0], [221.0, 452.0], [221.0, 612.0], [198.0, 612.0]], [[170.0, 452.0], [194.0, 452.0], [194.0, 576.0], [170.0, 576.0]], [[143.0, 452.0], [166.0, 452.0], [166.0, 568.0], [143.0, 568.0]], [[117.0, 452.0], [138.0, 452.0], [136.0, 643.0], [116.0, 643.0]]], "lines": ["．．．あっ、じゃあ", "失礼します、", "井上先輩も", "頑張ってください！！"]}, {"box": [779, 701, 859, 894], "vertical": true, "font_size": 22, "lines_coords": [[[832.0, 701.0], [857.0, 701.0], [859.0, 817.0], [835.0, 817.0]], [[805.0, 701.0], [828.0, 701.0], [831.0, 842.0], [808.0, 842.0]], [[780.0, 705.0], [799.0, 705.0], [799.0, 894.0], [780.0, 894.0]]], "lines": ["頑張れって", "何をだよ．．．", "適当なこと言って。"]}, {"box": [269, 769, 359, 909], "vertical": true, "font_size": 23, "lines_coords": [[[329.0, 769.0], [359.0, 769.0], [359.0, 843.0], [329.0, 843.0]], [[300.0, 772.0], [324.0, 772.0], [324.0, 909.0], [300.0, 909.0]], [[269.0, 769.0], [292.0, 769.0], [292.0, 868.0], [269.0, 868.0]]], "lines": ["そして", "部長（ヅラ）は", "完全無視、"]}, {"box": [109, 794, 237, 1013], "vertical": true, "font_size": 23, "lines_coords": [[[218.0, 795.0], [237.0, 795.0], [237.0, 955.0], [218.0, 955.0]], [[191.0, 797.0], [214.0, 797.0], [214.0, 957.0], [191.0, 957.0]], [[164.0, 795.0], [187.0, 795.0], [187.0, 1013.0], [164.0, 1013.0]], [[135.0, 794.0], [158.0, 794.0], [158.0, 978.0], [135.0, 978.0]], [[109.0, 795.0], [128.0, 795.0], [128.0, 943.0], [109.0, 943.0]]], "lines": ["そりゃそーか．．．", "大人の目からは", "あたしなんて、今時の", "ダメな若者でしか", "ないんだから。"]}, {"box": [751, 1060, 858, 1287], "vertical": true, "font_size": 32, "lines_coords": [[[825.0, 1060.0], [858.0, 1060.0], [858.0, 1175.0], [825.0, 1175.0]], [[787.0, 1060.0], [824.0, 1060.0], [824.0, 1261.0], [787.0, 1261.0]], [[751.0, 1060.0], [780.0, 1060.0], [780.0, 1287.0], [751.0, 1287.0]]], "lines": ["．．．つーか", "あいつら、手ぇ", "繋いでなかった！？"]}, {"box": [709, 1212, 736, 1354], "vertical": true, "font_size": 32, "lines_coords": [[[709.0, 1212.0], [736.0, 1212.0], [736.0, 1354.0], [709.0, 1354.0]]], "lines": ["不倫かよ！！"]}, {"box": [307, 1111, 377, 1308], "vertical": true, "font_size": 31, "lines_coords": [[[343.0, 1111.0], [377.0, 1111.0], [377.0, 1201.0], [343.0, 1201.0]], [[308.0, 1114.0], [336.0, 1114.0], [336.0, 1308.0], [308.0, 1308.0]]], "lines": ["くそう", "汚いぜ大人は！！"]}], "img_path": "102.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [802, 76, 891, 258], "vertical": true, "font_size": 24, "lines_coords": [[[862.0, 77.0], [891.0, 77.0], [891.0, 151.0], [862.0, 151.0]], [[832.0, 76.0], [855.0, 76.0], [855.0, 258.0], [832.0, 258.0]], [[802.0, 76.0], [825.0, 76.0], [825.0, 194.0], [802.0, 194.0]]], "lines": ["お客様", "とってもお似合い", "ですよー"]}, {"box": [530, 108, 618, 269], "vertical": true, "font_size": 22, "lines_coords": [[[594.0, 108.0], [617.0, 108.0], [617.0, 269.0], [594.0, 269.0]], [[563.0, 108.0], [586.0, 108.0], [586.0, 244.0], [563.0, 244.0]], [[533.0, 109.0], [553.0, 109.0], [550.0, 222.0], [530.0, 222.0]]], "lines": ["よろしかったら", "サイズお出し", "しますよ？"]}, {"box": [123, 177, 210, 373], "vertical": true, "font_size": 23, "lines_coords": [[[180.0, 177.0], [210.0, 177.0], [210.0, 259.0], [180.0, 259.0]], [[150.0, 179.0], [173.0, 179.0], [174.0, 373.0], [151.0, 373.0]], [[123.0, 180.0], [142.0, 180.0], [142.0, 339.0], [123.0, 339.0]]], "lines": ["いやぁ、", "あたしにはちょっと", "高すぎかなぁ．．．"]}, {"box": [728, 283, 849, 429], "vertical": true, "font_size": 24, "lines_coords": [[[825.0, 283.0], [849.0, 283.0], [849.0, 378.0], [825.0, 378.0]], [[794.0, 284.0], [817.0, 284.0], [817.0, 400.0], [794.0, 400.0]], [[761.0, 284.0], [784.0, 284.0], [784.0, 400.0], [761.0, 400.0]], [[728.0, 284.0], [751.0, 284.0], [754.0, 429.0], [731.0, 429.0]]], "lines": ["こちらは", "夏の新作で", "五色展開に", "なってまして、"]}, {"box": [155, 378, 239, 581], "vertical": true, "font_size": 23, "lines_coords": [[[216.0, 397.0], [239.0, 397.0], [239.0, 581.0], [216.0, 581.0]], [[185.0, 399.0], [210.0, 399.0], [207.0, 516.0], [183.0, 516.0]], [[155.0, 378.0], [174.0, 378.0], [174.0, 541.0], [155.0, 541.0]]], "lines": ["．．．ってアイちゃん", "ホント接客", "こなれてるね"]}, {"box": [792, 719, 879, 857], "vertical": true, "font_size": 22, "lines_coords": [[[854.0, 719.0], [879.0, 719.0], [879.0, 820.0], [854.0, 820.0]], [[824.0, 720.0], [847.0, 720.0], [847.0, 857.0], [824.0, 857.0]], [[794.0, 721.0], [813.0, 721.0], [813.0, 840.0], [794.0, 840.0]]], "lines": ["．．．へっへ。", "もう無意識に", "出てるから。"]}, {"box": [388, 730, 478, 891], "vertical": true, "font_size": 22, "lines_coords": [[[456.0, 734.0], [475.0, 734.0], [475.0, 891.0], [456.0, 891.0]], [[419.0, 730.0], [442.0, 730.0], [445.0, 849.0], [422.0, 849.0]], [[388.0, 731.0], [412.0, 731.0], [415.0, 857.0], [391.0, 857.0]]], "lines": ["客なら犬にでも", "接客できる", "境地だもん。"]}, {"box": [121, 981, 270, 1019], "vertical": false, "font_size": 29, "lines_coords": [[[123.0, 981.0], [270.0, 991.0], [269.0, 1019.0], [121.0, 1010.0]]], "lines": ["どちらかの"]}, {"box": [794, 970, 876, 1155], "vertical": true, "font_size": 22, "lines_coords": [[[857.0, 972.0], [876.0, 972.0], [876.0, 1134.0], [857.0, 1134.0]], [[824.0, 970.0], [849.0, 970.0], [847.0, 1155.0], [823.0, 1155.0]], [[794.0, 972.0], [817.0, 972.0], [817.0, 1136.0], [794.0, 1136.0]]], "lines": ["ところで芽衣子、", "この時間にウチに", "来るってことは、"]}, {"box": [706, 1144, 790, 1305], "vertical": true, "font_size": 22, "lines_coords": [[[766.0, 1144.0], [790.0, 1144.0], [790.0, 1260.0], [766.0, 1260.0]], [[736.0, 1145.0], [760.0, 1145.0], [760.0, 1305.0], [736.0, 1305.0]], [[706.0, 1147.0], [725.0, 1147.0], [725.0, 1259.0], [706.0, 1259.0]]], "lines": ["もしかして", "お昼おごられに", "来たとか？"]}, {"box": [459, 1007, 515, 1146], "vertical": true, "font_size": 22, "lines_coords": [[[490.0, 1008.0], [514.0, 1008.0], [514.0, 1125.0], [490.0, 1125.0]], [[462.0, 1007.0], [481.0, 1007.0], [478.0, 1144.0], [459.0, 1144.0]]], "lines": ["ありがとう", "ございます！！"]}, {"box": [371, 1152, 425, 1302], "vertical": true, "font_size": 22, "lines_coords": [[[401.0, 1152.0], [425.0, 1152.0], [425.0, 1248.0], [401.0, 1248.0]], [[371.0, 1155.0], [391.0, 1155.0], [391.0, 1300.0], [371.0, 1300.0]]], "lines": ["まだ何も", "言ってないし。"]}], "img_path": "103.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [787, 91, 876, 298], "vertical": true, "font_size": 22, "lines_coords": [[[851.0, 91.0], [874.0, 91.0], [874.0, 229.0], [851.0, 229.0]], [[820.0, 91.0], [843.0, 91.0], [840.0, 298.0], [817.0, 298.0]], [[790.0, 91.0], [809.0, 91.0], [806.0, 296.0], [787.0, 296.0]]], "lines": ["．．．で、どう？", "これからどうするか", "見当くらいついた？"]}, {"box": [591, 150, 630, 224], "vertical": true, "font_size": 36, "lines_coords": [[[591.0, 151.0], [627.0, 150.0], [630.0, 222.0], [594.0, 224.0]]], "lines": ["えへ。"]}, {"box": [174, 82, 232, 162], "vertical": true, "font_size": 26, "lines_coords": [[[207.0, 83.0], [232.0, 83.0], [232.0, 162.0], [207.0, 162.0]], [[174.0, 82.0], [203.0, 82.0], [203.0, 155.0], [174.0, 155.0]]], "lines": ["うわぁ", "怖い！！"]}, {"box": [71, 187, 162, 328], "vertical": true, "font_size": 26, "lines_coords": [[[133.0, 187.0], [162.0, 187.0], [162.0, 263.0], [133.0, 263.0]], [[105.0, 190.0], [128.0, 190.0], [128.0, 328.0], [105.0, 328.0]], [[73.0, 188.0], [97.0, 188.0], [94.0, 328.0], [71.0, 328.0]]], "lines": ["あたし", "すごく不安に", "なってきた！！"]}, {"box": [429, 424, 485, 591], "vertical": true, "font_size": 22, "lines_coords": [[[463.0, 426.0], [482.0, 426.0], [482.0, 586.0], [463.0, 586.0]], [[429.0, 425.0], [453.0, 425.0], [453.0, 526.0], [429.0, 526.0]]], "lines": ["えへじゃねーよ", "えへじゃ。"]}, {"box": [801, 674, 859, 812], "vertical": true, "font_size": 24, "lines_coords": [[[831.0, 674.0], [859.0, 674.0], [859.0, 747.0], [831.0, 747.0]], [[801.0, 675.0], [824.0, 675.0], [824.0, 812.0], [801.0, 812.0]]], "lines": ["やっぱ", "種田がなぁ．．．"]}, {"box": [702, 750, 757, 918], "vertical": true, "font_size": 24, "lines_coords": [[[734.0, 750.0], [757.0, 750.0], [757.0, 910.0], [734.0, 910.0]], [[702.0, 750.0], [725.0, 750.0], [725.0, 918.0], [702.0, 918.0]]], "lines": ["種田は芽衣子に", "甘すぎるんだよ。"]}, {"box": [296, 664, 351, 836], "vertical": true, "font_size": 23, "lines_coords": [[[328.0, 664.0], [351.0, 664.0], [351.0, 836.0], [328.0, 836.0]], [[296.0, 665.0], [319.0, 665.0], [319.0, 825.0], [296.0, 825.0]]], "lines": ["そして、あんたは", "流されやすい！"]}, {"box": [139, 725, 258, 909], "vertical": true, "font_size": 23, "lines_coords": [[[235.0, 725.0], [258.0, 725.0], [258.0, 865.0], [235.0, 865.0]], [[202.0, 725.0], [225.0, 725.0], [225.0, 887.0], [202.0, 887.0]], [[170.0, 727.0], [194.0, 727.0], [194.0, 909.0], [170.0, 909.0]], [[139.0, 727.0], [162.0, 727.0], [162.0, 885.0], [139.0, 885.0]]], "lines": ["言っとくけど", "種田は頭ん中が", "青っくさい１０代の", "めでたい奴よ？"]}, {"box": [765, 969, 850, 1152], "vertical": true, "font_size": 23, "lines_coords": [[[827.0, 972.0], [850.0, 972.0], [850.0, 1152.0], [827.0, 1152.0]], [[795.0, 969.0], [818.0, 969.0], [818.0, 1151.0], [795.0, 1151.0]], [[765.0, 970.0], [784.0, 970.0], [784.0, 1075.0], [765.0, 1075.0]]], "lines": ["ホントは芽衣子が", "しっかりしなきゃ", "なんだよー"]}, {"box": [715, 1136, 772, 1286], "vertical": true, "font_size": 23, "lines_coords": [[[743.0, 1136.0], [772.0, 1136.0], [772.0, 1209.0], [743.0, 1209.0]], [[715.0, 1136.0], [738.0, 1136.0], [738.0, 1286.0], [715.0, 1286.0]]], "lines": ["現実を", "もっと見てさ。"]}, {"box": [228, 1040, 251, 1137], "vertical": true, "font_size": 24, "lines_coords": [[[228.0, 1040.0], [251.0, 1040.0], [251.0, 1137.0], [228.0, 1137.0]]], "lines": ["あんた達、"]}, {"box": [77, 1122, 199, 1331], "vertical": true, "font_size": 24, "lines_coords": [[[174.0, 1122.0], [199.0, 1122.0], [196.0, 1240.0], [172.0, 1240.0]], [[142.0, 1122.0], [166.0, 1122.0], [165.0, 1331.0], [140.0, 1331.0]], [[109.0, 1123.0], [132.0, 1123.0], [132.0, 1223.0], [109.0, 1223.0]], [[77.0, 1122.0], [101.0, 1122.0], [102.0, 1307.0], [79.0, 1307.0]]], "lines": ["２人の間が", "気まずくなるような", "真剣な話、", "してないでしょ？"]}], "img_path": "104.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [823, 99, 877, 203], "vertical": true, "font_size": 24, "lines_coords": [[[853.0, 101.0], [877.0, 101.0], [877.0, 170.0], [853.0, 170.0]], [[823.0, 99.0], [846.0, 99.0], [846.0, 203.0], [823.0, 203.0]]], "lines": ["．．．", "そーかも。"]}, {"box": [557, 106, 708, 291], "vertical": true, "font_size": 24, "lines_coords": [[[683.0, 109.0], [706.0, 109.0], [706.0, 247.0], [683.0, 247.0]], [[652.0, 108.0], [675.0, 108.0], [675.0, 269.0], [652.0, 269.0]], [[620.0, 108.0], [643.0, 108.0], [643.0, 247.0], [620.0, 247.0]], [[589.0, 106.0], [613.0, 106.0], [611.0, 225.0], [586.0, 225.0]], [[557.0, 108.0], [581.0, 108.0], [581.0, 289.0], [557.0, 289.0]]], "lines": ["あんた、仮に", "種田が浮気して", "勘づいてても", "怖くて携帯", "覗けないでしょ？"]}, {"box": [133, 162, 219, 325], "vertical": true, "font_size": 22, "lines_coords": [[[194.0, 162.0], [217.0, 162.0], [217.0, 325.0], [194.0, 325.0]], [[162.0, 162.0], [185.0, 162.0], [185.0, 322.0], [162.0, 322.0]], [[133.0, 164.0], [153.0, 164.0], [153.0, 310.0], [133.0, 310.0]]], "lines": ["芽衣子は人一倍", "自分が傷つくの", "避けてるもの。"]}, {"box": [473, 380, 559, 585], "vertical": true, "font_size": 20, "lines_coords": [[[537.0, 381.0], [556.0, 381.0], [556.0, 585.0], [537.0, 585.0]], [[501.0, 380.0], [524.0, 380.0], [524.0, 564.0], [501.0, 564.0]], [[474.0, 381.0], [493.0, 381.0], [493.0, 572.0], [474.0, 572.0]]], "lines": ["じゃあアイちゃんは", "加藤くんと、どう", "付き合ってるのさ。"]}, {"box": [365, 384, 433, 635], "vertical": true, "font_size": 31, "lines_coords": [[[393.0, 389.0], [423.0, 388.0], [433.0, 576.0], [403.0, 578.0]], [[365.0, 384.0], [397.0, 384.0], [403.0, 635.0], [370.0, 635.0]]], "lines": ["もし宝くじで", "３億円当たったら．．．"]}, {"box": [129, 386, 192, 611], "vertical": true, "font_size": 29, "lines_coords": [[[158.0, 391.0], [187.0, 389.0], [192.0, 503.0], [164.0, 504.0]], [[129.0, 386.0], [158.0, 386.0], [162.0, 611.0], [133.0, 611.0]]], "lines": ["と思うと", "夜も眠れません"]}, {"box": [775, 649, 894, 832], "vertical": true, "font_size": 23, "lines_coords": [[[870.0, 649.0], [894.0, 649.0], [891.0, 766.0], [868.0, 766.0]], [[836.0, 649.0], [864.0, 649.0], [864.0, 832.0], [836.0, 832.0]], [[809.0, 652.0], [828.0, 652.0], [828.0, 765.0], [809.0, 765.0]], [[775.0, 649.0], [798.0, 649.0], [799.0, 798.0], [776.0, 798.0]]], "lines": ["携帯見たら", "大学の女とメール", "してたから", "殴ってやった。"]}, {"box": [552, 853, 798, 892], "vertical": false, "font_size": 28, "lines_coords": [[[553.0, 853.0], [798.0, 864.0], [797.0, 892.0], [552.0, 881.0]]], "lines": ["「ＴＡＲＢＡＣＫＳ"]}, {"box": [505, 693, 531, 785], "vertical": true, "font_size": 24, "lines_coords": [[[505.0, 693.0], [529.0, 693.0], [529.0, 784.0], [505.0, 784.0]]], "lines": ["さすが！！"]}, {"box": [463, 993, 493, 1054], "vertical": true, "font_size": 24, "lines_coords": [[[463.0, 993.0], [493.0, 993.0], [493.0, 1054.0], [463.0, 1054.0]]], "lines": ["はは。"]}, {"box": [110, 751, 196, 935], "vertical": true, "font_size": 22, "lines_coords": [[[172.0, 751.0], [196.0, 751.0], [196.0, 853.0], [172.0, 853.0]], [[140.0, 751.0], [164.0, 751.0], [164.0, 935.0], [140.0, 935.0]], [[110.0, 751.0], [129.0, 751.0], [129.0, 898.0], [110.0, 898.0]]], "lines": ["まーね、", "しつけはちゃんと", "しとかないと。"]}, {"box": [605, 1022, 723, 1182], "vertical": true, "font_size": 23, "lines_coords": [[[699.0, 1024.0], [723.0, 1024.0], [723.0, 1138.0], [699.0, 1138.0]], [[668.0, 1022.0], [691.0, 1022.0], [691.0, 1182.0], [668.0, 1182.0]], [[637.0, 1024.0], [660.0, 1024.0], [660.0, 1162.0], [637.0, 1162.0]], [[605.0, 1024.0], [628.0, 1024.0], [628.0, 1173.0], [605.0, 1173.0]]], "lines": ["サイフから", "風俗の会員証が", "出てきたから", "殴ってやった。"]}, {"box": [593, 1178, 616, 1308], "vertical": true, "font_size": 23, "lines_coords": [[[593.0, 1178.0], [616.0, 1178.0], [616.0, 1308.0], [593.0, 1308.0]]], "lines": ["ビール瓶で。"]}, {"box": [343, 1080, 459, 1242], "vertical": true, "font_size": 24, "lines_coords": [[[436.0, 1080.0], [459.0, 1080.0], [459.0, 1242.0], [436.0, 1242.0]], [[404.0, 1080.0], [427.0, 1080.0], [427.0, 1219.0], [404.0, 1219.0]], [[373.0, 1080.0], [396.0, 1080.0], [396.0, 1242.0], [373.0, 1242.0]], [[343.0, 1082.0], [362.0, 1082.0], [362.0, 1229.0], [343.0, 1229.0]]], "lines": ["でもいつまでも", "学生やってる", "ことには、文句", "言わないんだ。"]}], "img_path": "105.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [782, 113, 839, 451], "vertical": true, "font_size": 24, "lines_coords": [[[816.0, 114.0], [839.0, 114.0], [839.0, 254.0], [816.0, 254.0]], [[782.0, 113.0], [805.0, 113.0], [805.0, 451.0], [782.0, 451.0]]], "lines": ["だって加藤は", "普通の奴だもん。これから長くて"]}, {"box": [131, 233, 254, 441], "vertical": true, "font_size": 25, "lines_coords": [[[224.0, 235.0], [254.0, 235.0], [254.0, 308.0], [224.0, 308.0]], [[196.0, 236.0], [220.0, 236.0], [220.0, 374.0], [196.0, 374.0]], [[165.0, 233.0], [188.0, 233.0], [187.0, 441.0], [164.0, 441.0]], [[133.0, 233.0], [157.0, 233.0], [154.0, 427.0], [131.0, 427.0]]], "lines": ["だから", "ギリギリまで", "遊ばせてやろうとは", "思ってるんだよね。"]}, {"box": [686, 289, 775, 496], "vertical": true, "font_size": 24, "lines_coords": [[[747.0, 289.0], [775.0, 289.0], [775.0, 432.0], [747.0, 432.0]], [[719.0, 292.0], [742.0, 292.0], [742.0, 496.0], [719.0, 496.0]], [[686.0, 291.0], [709.0, 291.0], [710.0, 440.0], [687.0, 440.0]]], "lines": ["退屈な人生が", "待ってるってアイツ", "わかってるし。"]}, {"box": [273, 533, 360, 671], "vertical": true, "font_size": 23, "lines_coords": [[[337.0, 533.0], [360.0, 533.0], [360.0, 671.0], [337.0, 671.0]], [[306.0, 534.0], [329.0, 534.0], [329.0, 669.0], [306.0, 669.0]], [[273.0, 534.0], [298.0, 534.0], [298.0, 613.0], [273.0, 613.0]]], "lines": ["ま、それでも", "あたしも甘い", "けどね。"]}, {"box": [176, 575, 262, 765], "vertical": true, "font_size": 23, "lines_coords": [[[239.0, 575.0], [262.0, 575.0], [262.0, 721.0], [239.0, 721.0]], [[207.0, 576.0], [231.0, 576.0], [231.0, 715.0], [207.0, 715.0]], [[176.0, 578.0], [195.0, 578.0], [195.0, 765.0], [176.0, 765.0]]], "lines": ["働いて食べる、", "コレ人として", "当然のことだもん。"]}, {"box": [803, 638, 851, 764], "vertical": true, "font_size": 29, "lines_coords": [[[823.0, 638.0], [851.0, 642.0], [832.0, 764.0], [803.0, 760.0]]], "lines": ["風がでてきた"]}, {"box": [817, 809, 875, 925], "vertical": true, "font_size": 24, "lines_coords": [[[850.0, 809.0], [874.0, 809.0], [874.0, 925.0], [850.0, 925.0]], [[817.0, 809.0], [840.0, 809.0], [840.0, 900.0], [817.0, 900.0]]], "lines": ["．．．で、今日", "種田は？"]}, {"box": [833, 961, 875, 1059], "vertical": true, "font_size": 20, "lines_coords": [[[854.0, 962.0], [874.0, 962.0], [874.0, 1007.0], [854.0, 1007.0]], [[833.0, 967.0], [853.0, 967.0], [853.0, 1055.0], [833.0, 1055.0]]], "lines": ["また", "いますよ。"]}, {"box": [578, 947, 664, 1127], "vertical": true, "font_size": 24, "lines_coords": [[[641.0, 947.0], [664.0, 947.0], [664.0, 1085.0], [641.0, 1085.0]], [[611.0, 947.0], [630.0, 947.0], [630.0, 1127.0], [611.0, 1127.0]], [[578.0, 948.0], [601.0, 948.0], [601.0, 1119.0], [578.0, 1119.0]]], "lines": ["あー、なんか", "仕事たてこんでて", "３日帰ってない。"]}, {"box": [486, 858, 530, 975], "vertical": true, "font_size": 21, "lines_coords": [[[508.0, 891.0], [530.0, 891.0], [530.0, 925.0], [508.0, 925.0]], [[486.0, 902.0], [507.0, 902.0], [509.0, 974.0], [489.0, 974.0]]], "lines": ["な", "いこうか"]}, {"box": [112, 926, 226, 1145], "vertical": true, "font_size": 23, "lines_coords": [[[203.0, 928.0], [226.0, 928.0], [226.0, 1067.0], [203.0, 1067.0]], [[172.0, 926.0], [195.0, 926.0], [195.0, 1111.0], [172.0, 1111.0]], [[142.0, 928.0], [165.0, 928.0], [165.0, 1134.0], [142.0, 1134.0]], [[112.0, 928.0], [131.0, 928.0], [131.0, 1145.0], [112.0, 1145.0]]], "lines": ["．．．ねぇ芽衣子", "あんたから、仕事", "辞めたって聞いた時", "ちょっと思ったんだ。"]}, {"box": [467, 1041, 559, 1227], "vertical": true, "font_size": 24, "lines_coords": [[[531.0, 1041.0], [559.0, 1041.0], [556.0, 1207.0], [529.0, 1207.0]], [[500.0, 1044.0], [523.0, 1044.0], [523.0, 1227.0], [500.0, 1227.0]], [[467.0, 1043.0], [496.0, 1043.0], [496.0, 1126.0], [467.0, 1126.0]]], "lines": ["バイトのくせに", "変に頑張ってんだ", "あの人。"]}, {"box": [66, 1156, 187, 1363], "vertical": true, "font_size": 23, "lines_coords": [[[164.0, 1158.0], [187.0, 1158.0], [187.0, 1249.0], [164.0, 1249.0]], [[132.0, 1158.0], [155.0, 1158.0], [155.0, 1319.0], [132.0, 1319.0]], [[101.0, 1158.0], [124.0, 1158.0], [124.0, 1363.0], [101.0, 1363.0]], [[66.0, 1156.0], [90.0, 1156.0], [92.0, 1307.0], [69.0, 1307.0]]], "lines": ["無意識に", "芽衣子は種田を", "追い込んでるんじゃ", "ないかってさ。"]}], "img_path": "106.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [762, 128, 844, 272], "vertical": true, "font_size": 21, "lines_coords": [[[825.0, 129.0], [844.0, 129.0], [844.0, 265.0], [825.0, 265.0]], [[791.0, 128.0], [814.0, 128.0], [814.0, 244.0], [791.0, 244.0]], [[762.0, 129.0], [782.0, 129.0], [782.0, 272.0], [762.0, 272.0]]], "lines": ["もしそうなら", "早く素直に", "言っちゃいな。"]}, {"box": [426, 206, 585, 236], "vertical": false, "font_size": 25, "lines_coords": [[[426.0, 206.0], [585.0, 211.0], [585.0, 236.0], [426.0, 231.0]]], "lines": ["ほとほんでいても"]}, {"box": [295, 146, 385, 318], "vertical": true, "font_size": 22, "lines_coords": [[[356.0, 146.0], [385.0, 146.0], [385.0, 220.0], [356.0, 220.0]], [[328.0, 147.0], [351.0, 147.0], [348.0, 287.0], [325.0, 287.0]], [[296.0, 146.0], [319.0, 146.0], [318.0, 318.0], [295.0, 318.0]]], "lines": ["種田が", "間違った方向", "行っちゃう前に。"]}, {"box": [165, 190, 247, 393], "vertical": true, "font_size": 22, "lines_coords": [[[228.0, 191.0], [247.0, 191.0], [247.0, 348.0], [228.0, 348.0]], [[196.0, 190.0], [216.0, 190.0], [216.0, 393.0], [196.0, 393.0]], [[165.0, 190.0], [184.0, 190.0], [184.0, 313.0], [165.0, 313.0]]], "lines": ["タイミング的に", "今が最後のチャンス", "だと思うな。"]}, {"box": [706, 320, 793, 487], "vertical": true, "font_size": 87, "lines_coords": [[[706.0, 320.0], [793.0, 320.0], [793.0, 487.0], [706.0, 487.0]]], "lines": ["あんたが種田にどうして欲しいのかってことを。"]}, {"box": [705, 318, 788, 488], "vertical": true, "font_size": 21, "lines_coords": [[[769.0, 319.0], [788.0, 319.0], [788.0, 478.0], [769.0, 478.0]], [[736.0, 318.0], [760.0, 318.0], [760.0, 478.0], [736.0, 478.0]], [[705.0, 321.0], [724.0, 321.0], [724.0, 488.0], [705.0, 488.0]]], "lines": ["あんたが種田に", "どうして欲しい", "のかってことを。"]}, {"box": [769, 603, 857, 741], "vertical": true, "font_size": 23, "lines_coords": [[[832.0, 604.0], [855.0, 604.0], [855.0, 741.0], [832.0, 741.0]], [[801.0, 604.0], [824.0, 604.0], [824.0, 719.0], [801.0, 719.0]], [[769.0, 604.0], [792.0, 604.0], [792.0, 728.0], [769.0, 728.0]]], "lines": ["悩んでる間は", "物事は何も", "進まないよ。"]}, {"box": [244, 590, 299, 756], "vertical": true, "font_size": 23, "lines_coords": [[[276.0, 590.0], [299.0, 590.0], [299.0, 683.0], [276.0, 683.0]], [[244.0, 590.0], [267.0, 590.0], [267.0, 756.0], [244.0, 756.0]]], "lines": ["そもそも", "人の悩みなんて、"]}, {"box": [127, 674, 214, 835], "vertical": true, "font_size": 23, "lines_coords": [[[191.0, 675.0], [214.0, 675.0], [214.0, 835.0], [191.0, 835.0]], [[159.0, 674.0], [183.0, 674.0], [183.0, 813.0], [159.0, 813.0]], [[127.0, 674.0], [151.0, 674.0], [151.0, 754.0], [127.0, 754.0]]], "lines": ["いくら考えても", "答えは無いん", "だから。"]}, {"box": [724, 963, 846, 1171], "vertical": true, "font_size": 25, "lines_coords": [[[821.0, 966.0], [844.0, 966.0], [844.0, 1171.0], [821.0, 1171.0]], [[788.0, 965.0], [812.0, 965.0], [812.0, 1147.0], [788.0, 1147.0]], [[758.0, 966.0], [782.0, 966.0], [782.0, 1149.0], [758.0, 1149.0]], [[724.0, 963.0], [754.0, 963.0], [754.0, 1025.0], [724.0, 1025.0]]], "lines": ["もし芽衣子の理想が", "夢みたく現実味が", "無くて躊躇してる", "なら、"]}, {"box": [152, 1010, 240, 1237], "vertical": true, "font_size": 23, "lines_coords": [[[214.0, 1013.0], [237.0, 1013.0], [237.0, 1204.0], [214.0, 1204.0]], [[181.0, 1010.0], [209.0, 1010.0], [209.0, 1218.0], [181.0, 1218.0]], [[154.0, 1014.0], [173.0, 1014.0], [173.0, 1237.0], [154.0, 1237.0]]], "lines": ["やらない後悔より、", "やって後悔のほうが", "気持ちいいんじゃん？"]}], "img_path": "107.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [776, 91, 798, 229], "vertical": true, "font_size": 22, "lines_coords": [[[776.0, 91.0], [797.0, 91.0], [798.0, 229.0], [777.0, 229.0]]], "lines": ["というよりは"]}, {"box": [777, 90, 866, 365], "vertical": true, "font_size": 25, "lines_coords": [[[838.0, 91.0], [862.0, 91.0], [864.0, 365.0], [839.0, 365.0]], [[806.0, 91.0], [831.0, 91.0], [831.0, 209.0], [806.0, 209.0]]], "lines": ["あたしが仕事を辞めたのは", "仕事に不満"]}, {"box": [252, 163, 310, 392], "vertical": true, "font_size": 19, "lines_coords": [[[285.0, 165.0], [304.0, 165.0], [304.0, 324.0], [285.0, 324.0]], [[254.0, 165.0], [273.0, 165.0], [273.0, 392.0], [254.0, 392.0]]], "lines": ["種田と具体的な", "将来の話をしないのは"]}, {"box": [102, 162, 317, 395], "vertical": true, "font_size": 30, "lines_coords": [[[102.0, 162.0], [132.0, 162.0], [132.0, 247.0], [102.0, 247.0]]], "lines": ["だから。"]}, {"box": [108, 163, 196, 349], "vertical": true, "font_size": 24, "lines_coords": [[[170.0, 164.0], [194.0, 164.0], [194.0, 302.0], [170.0, 302.0]], [[138.0, 164.0], [161.0, 164.0], [161.0, 347.0], [138.0, 347.0]]], "lines": ["２人の関係が", "崩れてしまいそう"]}, {"box": [642, 293, 736, 508], "vertical": true, "font_size": 28, "lines_coords": [[[701.0, 293.0], [735.0, 293.0], [735.0, 391.0], [701.0, 391.0]], [[674.0, 296.0], [697.0, 296.0], [697.0, 453.0], [674.0, 453.0]]], "lines": ["疲弊して", "くたびれてゆく"]}, {"box": [717, 572, 838, 757], "vertical": true, "font_size": 22, "lines_coords": [[[816.0, 575.0], [835.0, 575.0], [835.0, 732.0], [816.0, 732.0]], [[783.0, 574.0], [806.0, 574.0], [803.0, 690.0], [780.0, 690.0]], [[749.0, 574.0], [772.0, 574.0], [772.0, 757.0], [749.0, 757.0]], [[717.0, 572.0], [741.0, 572.0], [743.0, 700.0], [720.0, 700.0]]], "lines": ["夢を追いかける", "ほど自分は", "純粋じゃないのも", "知っている。"]}, {"box": [642, 295, 665, 509], "vertical": true, "font_size": 22, "lines_coords": [[[642.0, 295.0], [665.0, 295.0], [665.0, 509.0], [642.0, 509.0]]], "lines": ["自分が嫌だったから。"]}, {"box": [769, 895, 857, 1064], "vertical": true, "font_size": 23, "lines_coords": [[[833.0, 895.0], [857.0, 895.0], [857.0, 1033.0], [833.0, 1033.0]], [[802.0, 899.0], [825.0, 899.0], [825.0, 1011.0], [802.0, 1011.0]], [[771.0, 895.0], [794.0, 895.0], [792.0, 1060.0], [769.0, 1060.0]]], "lines": ["でもあたしが", "一番不満に", "思っていたのは、"]}, {"box": [150, 672, 271, 877], "vertical": true, "font_size": 23, "lines_coords": [[[246.0, 674.0], [269.0, 674.0], [269.0, 787.0], [246.0, 787.0]], [[213.0, 672.0], [236.0, 672.0], [236.0, 877.0], [213.0, 877.0]], [[183.0, 674.0], [206.0, 674.0], [206.0, 833.0], [183.0, 833.0]], [[150.0, 672.0], [173.0, 672.0], [174.0, 865.0], [151.0, 865.0]]], "lines": ["なあなあに", "平凡に生きることが", "実はとても困難", "なのもわかってる。"]}, {"box": [105, 939, 131, 1046], "vertical": true, "font_size": 20, "lines_coords": [[[105.0, 989.0], [125.0, 988.0], [128.0, 1041.0], [108.0, 1043.0]]], "lines": ["．．．あ"]}, {"box": [397, 1127, 516, 1288], "vertical": true, "font_size": 22, "lines_coords": [[[492.0, 1127.0], [516.0, 1127.0], [516.0, 1220.0], [492.0, 1220.0]], [[462.0, 1129.0], [481.0, 1129.0], [481.0, 1286.0], [462.0, 1286.0]], [[427.0, 1127.0], [451.0, 1127.0], [451.0, 1242.0], [427.0, 1242.0]], [[399.0, 1127.0], [418.0, 1127.0], [418.0, 1286.0], [399.0, 1286.0]]], "lines": ["頑張って", "大人になろうと", "してる種田", "だとしたら．．．"]}], "img_path": "108.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [803, 82, 861, 185], "vertical": true, "font_size": 25, "lines_coords": [[[832.0, 82.0], [861.0, 82.0], [861.0, 120.0], [832.0, 120.0]], [[803.0, 84.0], [827.0, 84.0], [827.0, 185.0], [803.0, 185.0]]], "lines": ["あー", "おかえり"]}, {"box": [721, 185, 777, 325], "vertical": true, "font_size": 25, "lines_coords": [[[753.0, 185.0], [777.0, 185.0], [777.0, 258.0], [753.0, 258.0]], [[721.0, 188.0], [745.0, 188.0], [745.0, 325.0], [721.0, 325.0]]], "lines": ["仕事は", "山越えたの？"]}, {"box": [232, 136, 287, 236], "vertical": true, "font_size": 25, "lines_coords": [[[259.0, 136.0], [287.0, 136.0], [287.0, 179.0], [259.0, 179.0]], [[232.0, 136.0], [251.0, 136.0], [251.0, 236.0], [232.0, 236.0]]], "lines": ["おー", "どうにか"]}, {"box": [132, 243, 225, 426], "vertical": true, "font_size": 25, "lines_coords": [[[194.0, 243.0], [225.0, 243.0], [225.0, 303.0], [194.0, 303.0]], [[165.0, 244.0], [188.0, 244.0], [188.0, 384.0], [165.0, 384.0]], [[133.0, 243.0], [157.0, 243.0], [155.0, 426.0], [132.0, 426.0]]], "lines": ["．．．で、", "芽衣子さんは", "どこ行ってたの？"]}, {"box": [806, 579, 859, 761], "vertical": true, "font_size": 22, "lines_coords": [[[836.0, 579.0], [859.0, 579.0], [859.0, 761.0], [836.0, 761.0]], [[806.0, 579.0], [829.0, 579.0], [829.0, 727.0], [806.0, 727.0]]], "lines": ["アイちゃんトコの", "店で靴買った。"]}, {"box": [118, 636, 236, 751], "vertical": true, "font_size": 22, "lines_coords": [[[211.0, 637.0], [235.0, 637.0], [235.0, 730.0], [211.0, 730.0]], [[179.0, 637.0], [202.0, 637.0], [202.0, 751.0], [179.0, 751.0]], [[147.0, 637.0], [170.0, 637.0], [170.0, 751.0], [147.0, 751.0]], [[118.0, 638.0], [138.0, 638.0], [138.0, 732.0], [118.0, 732.0]]], "lines": ["気持ちは", "わかるけど", "部屋ん中で", "はくなよ"]}, {"box": [687, 649, 772, 831], "vertical": true, "font_size": 22, "lines_coords": [[[753.0, 650.0], [772.0, 650.0], [772.0, 831.0], [753.0, 831.0]], [[720.0, 649.0], [743.0, 649.0], [743.0, 790.0], [720.0, 790.0]], [[687.0, 649.0], [710.0, 649.0], [710.0, 775.0], [687.0, 775.0]]], "lines": ["もちろんこっそり", "社割りだけど", "ちょい高め。"]}, {"box": [849, 866, 873, 958], "vertical": true, "font_size": 24, "lines_coords": [[[849.0, 866.0], [873.0, 866.0], [873.0, 958.0], [849.0, 958.0]]], "lines": ["．．．あれ？"]}, {"box": [132, 879, 252, 1041], "vertical": true, "font_size": 24, "lines_coords": [[[228.0, 881.0], [251.0, 881.0], [251.0, 998.0], [228.0, 998.0]], [[195.0, 880.0], [218.0, 880.0], [217.0, 1041.0], [194.0, 1041.0]], [[162.0, 881.0], [185.0, 881.0], [185.0, 1041.0], [162.0, 1041.0]], [[132.0, 879.0], [158.0, 879.0], [158.0, 940.0], [132.0, 940.0]]], "lines": ["機械も人も", "使い捨てなんて", "あんまりだもん", "なあ。"]}, {"box": [761, 984, 847, 1122], "vertical": true, "font_size": 24, "lines_coords": [[[824.0, 987.0], [847.0, 987.0], [847.0, 1099.0], [824.0, 1099.0]], [[792.0, 984.0], [816.0, 984.0], [816.0, 1078.0], [792.0, 1078.0]], [[761.0, 984.0], [784.0, 984.0], [784.0, 1122.0], [761.0, 1122.0]]], "lines": ["ってゆうか", "クーラー", "直ってるし！！"]}, {"box": [588, 1153, 675, 1335], "vertical": true, "font_size": 22, "lines_coords": [[[650.0, 1153.0], [674.0, 1153.0], [674.0, 1335.0], [650.0, 1335.0]], [[619.0, 1153.0], [642.0, 1153.0], [642.0, 1313.0], [619.0, 1313.0]], [[590.0, 1153.0], [609.0, 1153.0], [609.0, 1297.0], [590.0, 1297.0]]], "lines": ["わかんないなりに", "いじってみたら", "意外と直った。"]}, {"box": [199, 1134, 233, 1216], "vertical": true, "font_size": 28, "lines_coords": [[[199.0, 1134.0], [233.0, 1134.0], [233.0, 1216.0], [199.0, 1216.0]]], "lines": ["．．．種田"]}, {"box": [108, 1207, 196, 1326], "vertical": true, "font_size": 28, "lines_coords": [[[172.0, 1207.0], [196.0, 1207.0], [196.0, 1326.0], [172.0, 1326.0]], [[140.0, 1209.0], [165.0, 1209.0], [165.0, 1304.0], [140.0, 1304.0]], [[108.0, 1208.0], [136.0, 1208.0], [136.0, 1282.0], [108.0, 1282.0]]], "lines": ["もしかして", "今の仕事", "辛い？"]}], "img_path": "109.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [773, 91, 797, 209], "vertical": true, "font_size": 21, "lines_coords": [[[775.0, 94.0], [795.0, 94.0], [795.0, 139.0], [775.0, 139.0]], [[773.0, 147.0], [794.0, 146.0], [797.0, 203.0], [776.0, 205.0]]], "lines": ["んー", "．．．．．．"]}, {"box": [170, 205, 199, 267], "vertical": true, "font_size": 28, "lines_coords": [[[170.0, 206.0], [196.0, 205.0], [199.0, 266.0], [173.0, 267.0]]], "lines": ["まぁ、"]}, {"box": [117, 340, 210, 482], "vertical": true, "font_size": 28, "lines_coords": [[[180.0, 341.0], [210.0, 341.0], [210.0, 416.0], [180.0, 416.0]], [[150.0, 343.0], [177.0, 343.0], [177.0, 482.0], [150.0, 482.0]], [[117.0, 340.0], [147.0, 340.0], [147.0, 406.0], [117.0, 406.0]]], "lines": ["決して", "楽しくはない", "よね。"]}, {"box": [150, 877, 174, 970], "vertical": true, "font_size": 23, "lines_coords": [[[150.0, 877.0], [173.0, 877.0], [173.0, 970.0], [150.0, 970.0]]], "lines": ["なんで？"]}], "img_path": "110.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [712, 46, 795, 244], "vertical": true, "font_size": 24, "lines_coords": [[[771.0, 47.0], [794.0, 47.0], [794.0, 209.0], [771.0, 209.0]], [[739.0, 46.0], [766.0, 46.0], [766.0, 188.0], [739.0, 188.0]], [[712.0, 47.0], [735.0, 47.0], [735.0, 244.0], [712.0, 244.0]]], "lines": ["種田、ホントは", "ちゃんと音楽", "やりたいんでしょ？"]}, {"box": [786, 764, 841, 968], "vertical": true, "font_size": 23, "lines_coords": [[[817.0, 764.0], [840.0, 764.0], [840.0, 880.0], [817.0, 880.0]], [[786.0, 765.0], [809.0, 765.0], [809.0, 967.0], [786.0, 967.0]]], "lines": ["．．．だったら", "やればいいじゃん．．．"]}, {"box": [225, 827, 252, 943], "vertical": true, "font_size": 26, "lines_coords": [[[228.0, 827.0], [252.0, 827.0], [250.0, 943.0], [225.0, 943.0]]], "lines": ["てゆうか．．"]}, {"box": [132, 879, 191, 995], "vertical": true, "font_size": 26, "lines_coords": [[[161.0, 879.0], [191.0, 879.0], [191.0, 952.0], [161.0, 952.0]], [[132.0, 880.0], [155.0, 880.0], [155.0, 995.0], [132.0, 995.0]]], "lines": ["バンド", "やってよ！"]}, {"box": [632, 1052, 752, 1222], "vertical": true, "font_size": 23, "lines_coords": [[[727.0, 1054.0], [750.0, 1054.0], [750.0, 1215.0], [727.0, 1215.0]], [[695.0, 1054.0], [719.0, 1054.0], [719.0, 1170.0], [695.0, 1170.0]], [[664.0, 1054.0], [687.0, 1054.0], [687.0, 1215.0], [664.0, 1215.0]], [[633.0, 1054.0], [656.0, 1054.0], [656.0, 1222.0], [633.0, 1222.0]]], "lines": ["あたしが買った", "新品の靴は", "ちょっと固くて", "靴ズレしそうで、"]}, {"box": [466, 1050, 589, 1260], "vertical": true, "font_size": 28, "lines_coords": [[[563.0, 1052.0], [586.0, 1052.0], [586.0, 1212.0], [563.0, 1212.0]], [[526.0, 1050.0], [560.0, 1050.0], [560.0, 1134.0], [526.0, 1134.0]], [[496.0, 1051.0], [523.0, 1051.0], [524.0, 1260.0], [497.0, 1260.0]], [[466.0, 1052.0], [494.0, 1052.0], [494.0, 1134.0], [466.0, 1134.0]]], "lines": ["でもお気に入り", "だから、", "きっと履きつぶして", "やろう。"]}, {"box": [330, 1052, 384, 1189], "vertical": true, "font_size": 24, "lines_coords": [[[365.0, 1054.0], [384.0, 1054.0], [384.0, 1189.0], [365.0, 1189.0]], [[330.0, 1052.0], [354.0, 1052.0], [354.0, 1175.0], [330.0, 1175.0]]], "lines": ["おそるおそろ", "歩きだして、"]}, {"box": [237, 1050, 295, 1256], "vertical": true, "font_size": 24, "lines_coords": [[[272.0, 1052.0], [295.0, 1052.0], [295.0, 1256.0], [272.0, 1256.0]], [[237.0, 1050.0], [266.0, 1050.0], [266.0, 1133.0], [237.0, 1133.0]]], "lines": ["今日は新しい日々の", "第一歩。"]}], "img_path": "111.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "112.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "113.png"}, {"version": "0.2.0-beta.6", "img_width": 975, "img_height": 1400, "blocks": [{"box": [817, 118, 851, 185], "vertical": true, "font_size": 26, "lines_coords": [[[817.0, 120.0], [849.0, 118.0], [851.0, 184.0], [820.0, 185.0]]], "lines": ["社長。"]}, {"box": [727, 203, 815, 412], "vertical": true, "font_size": 26, "lines_coords": [[[789.0, 205.0], [813.0, 205.0], [815.0, 344.0], [790.0, 344.0]], [[757.0, 203.0], [780.0, 203.0], [780.0, 371.0], [757.0, 371.0]], [[727.0, 206.0], [750.0, 206.0], [750.0, 412.0], [727.0, 412.0]]], "lines": ["きのう渡した", "イラストのラフ、", "あれでＯＫですか？"]}, {"box": [232, 112, 288, 262], "vertical": true, "font_size": 24, "lines_coords": [[[263.0, 114.0], [288.0, 114.0], [288.0, 240.0], [263.0, 240.0]], [[232.0, 112.0], [255.0, 112.0], [257.0, 262.0], [233.0, 262.0]]], "lines": ["あーーーＯＫ", "進めちゃって。"]}, {"box": [287, 531, 374, 691], "vertical": true, "font_size": 23, "lines_coords": [[[350.0, 531.0], [374.0, 531.0], [374.0, 624.0], [350.0, 624.0]], [[318.0, 531.0], [341.0, 531.0], [341.0, 691.0], [318.0, 691.0]], [[287.0, 533.0], [310.0, 533.0], [310.0, 675.0], [287.0, 675.0]]], "lines": ["ところで", "種田、すっごく", "眠そうだけど、"]}, {"box": [127, 277, 246, 483], "vertical": true, "font_size": 24, "lines_coords": [[[222.0, 277.0], [246.0, 277.0], [246.0, 483.0], [222.0, 483.0]], [[188.0, 278.0], [211.0, 278.0], [211.0, 422.0], [188.0, 422.0]], [[158.0, 280.0], [183.0, 280.0], [180.0, 395.0], [155.0, 395.0]], [[127.0, 281.0], [150.0, 281.0], [150.0, 382.0], [127.0, 382.0]]], "lines": ["あとグラビア写真の", "仕上げデータ、", "１４時までに", "ヨロシク。"]}, {"box": [138, 605, 255, 765], "vertical": true, "font_size": 23, "lines_coords": [[[232.0, 605.0], [255.0, 605.0], [255.0, 730.0], [232.0, 730.0]], [[199.0, 605.0], [222.0, 605.0], [222.0, 742.0], [199.0, 742.0]], [[166.0, 605.0], [191.0, 605.0], [194.0, 743.0], [169.0, 743.0]], [[138.0, 608.0], [161.0, 608.0], [161.0, 765.0], [138.0, 765.0]]], "lines": ["最近仕事の", "能率悪いよ？", "やる気無しの", "マニフェスト？"]}, {"box": [680, 913, 700, 967], "vertical": true, "font_size": 23, "lines_coords": [[[680.0, 913.0], [700.0, 913.0], [700.0, 967.0], [680.0, 967.0]]], "lines": ["ーん"]}, {"box": [612, 847, 704, 1029], "vertical": true, "font_size": 23, "lines_coords": [[[679.0, 847.0], [704.0, 847.0], [704.0, 917.0], [679.0, 917.0]], [[648.0, 847.0], [671.0, 847.0], [671.0, 1029.0], [648.0, 1029.0]], [[615.0, 847.0], [639.0, 847.0], [637.0, 1010.0], [612.0, 1010.0]]], "lines": ["．．．うー", "今日も単純作業の", "おでましだ．．．"]}, {"box": [496, 909, 581, 1071], "vertical": true, "font_size": 23, "lines_coords": [[[557.0, 909.0], [581.0, 909.0], [581.0, 1050.0], [557.0, 1050.0]], [[525.0, 910.0], [548.0, 910.0], [548.0, 1071.0], [525.0, 1071.0]], [[496.0, 911.0], [515.0, 911.0], [515.0, 1070.0], [496.0, 1070.0]]], "lines": ["量こなしても", "時給分しか給料", "出ないのに．．．"]}, {"box": [138, 879, 225, 1041], "vertical": true, "font_size": 24, "lines_coords": [[[201.0, 879.0], [225.0, 879.0], [225.0, 957.0], [201.0, 957.0]], [[169.0, 880.0], [192.0, 880.0], [192.0, 996.0], [169.0, 996.0]], [[138.0, 880.0], [161.0, 880.0], [161.0, 1041.0], [138.0, 1041.0]]], "lines": ["くそう、", "正直辛いぜ", "仕事ってのは："]}, {"box": [228, 1059, 255, 1121], "vertical": true, "font_size": 24, "lines_coords": [[[228.0, 1060.0], [252.0, 1059.0], [255.0, 1119.0], [231.0, 1121.0]]], "lines": ["ふう。"]}, {"box": [95, 1256, 127, 1320], "vertical": true, "font_size": 32, "lines_coords": [[[95.0, 1256.0], [127.0, 1256.0], [127.0, 1320.0], [95.0, 1320.0]]], "lines": ["ふぅ。"]}], "img_path": "114.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [710, 99, 864, 296], "vertical": true, "font_size": 23, "lines_coords": [[[839.0, 101.0], [862.0, 101.0], [862.0, 296.0], [839.0, 296.0]], [[806.0, 101.0], [829.0, 101.0], [829.0, 292.0], [806.0, 292.0]], [[775.0, 101.0], [798.0, 101.0], [798.0, 217.0], [775.0, 217.0]], [[743.0, 101.0], [766.0, 101.0], [766.0, 262.0], [743.0, 262.0]], [[712.0, 99.0], [735.0, 99.0], [734.0, 250.0], [710.0, 250.0]]], "lines": ["いったいいつから", "歩き続けてるのか、", "もう何年も", "さまよっている", "気さえもする。"]}, {"box": [326, 131, 356, 195], "vertical": true, "font_size": 30, "lines_coords": [[[326.0, 131.0], [356.0, 131.0], [356.0, 195.0], [326.0, 195.0]]], "lines": ["ふぅ。"]}, {"box": [460, 313, 497, 378], "vertical": true, "font_size": 30, "lines_coords": [[[460.0, 315.0], [490.0, 313.0], [497.0, 375.0], [467.0, 378.0]]], "lines": ["ふぅ。"]}, {"box": [109, 202, 261, 410], "vertical": true, "font_size": 23, "lines_coords": [[[236.0, 206.0], [259.0, 206.0], [259.0, 410.0], [236.0, 410.0]], [[202.0, 202.0], [225.0, 202.0], [225.0, 385.0], [202.0, 385.0]], [[172.0, 202.0], [195.0, 202.0], [195.0, 385.0], [172.0, 385.0]], [[139.0, 202.0], [162.0, 202.0], [165.0, 365.0], [142.0, 365.0]], [[109.0, 202.0], [132.0, 202.0], [132.0, 284.0], [109.0, 284.0]]], "lines": ["一つわかったことは", "この森が恐ろしく", "高い壁に囲まれて", "出口が無いって", "ことだ。"]}, {"box": [308, 481, 368, 597], "vertical": true, "font_size": 26, "lines_coords": [[[343.0, 482.0], [366.0, 482.0], [366.0, 597.0], [343.0, 597.0]], [[308.0, 481.0], [337.0, 481.0], [337.0, 597.0], [308.0, 597.0]]], "lines": ["行き止まり", "かーい！！"]}, {"box": [727, 913, 880, 1108], "vertical": true, "font_size": 24, "lines_coords": [[[855.0, 916.0], [879.0, 916.0], [879.0, 1075.0], [855.0, 1075.0]], [[824.0, 914.0], [849.0, 914.0], [844.0, 1054.0], [820.0, 1054.0]], [[791.0, 914.0], [816.0, 914.0], [813.0, 1059.0], [788.0, 1059.0]], [[760.0, 914.0], [784.0, 914.0], [782.0, 1032.0], [757.0, 1032.0]], [[727.0, 913.0], [750.0, 913.0], [750.0, 1104.0], [727.0, 1104.0]]], "lines": ["背中に背負った", "何かは徐々に", "重みを増して、", "僕の体力は", "すでに限界だった。"]}, {"box": [591, 892, 611, 1028], "vertical": true, "font_size": 26, "lines_coords": [[[591.0, 892.0], [611.0, 892.0], [611.0, 1028.0], [591.0, 1028.0]]], "lines": ["おっおっ．．．．．"]}, {"box": [487, 960, 520, 1122], "vertical": true, "font_size": 33, "lines_coords": [[[487.0, 960.0], [520.0, 960.0], [520.0, 1122.0], [487.0, 1122.0]]], "lines": ["おわわっ！！"]}, {"box": [486, 961, 519, 1123], "vertical": true, "font_size": 26, "lines_coords": [[[486.0, 961.0], [519.0, 961.0], [519.0, 1123.0], [486.0, 1123.0]]], "lines": ["おわわっ！！"]}], "img_path": "115.png"}, {"version": "0.2.0-beta.6", "img_width": 971, "img_height": 1400, "blocks": [{"box": [791, 113, 880, 258], "vertical": true, "font_size": 24, "lines_coords": [[[854.0, 113.0], [880.0, 113.0], [880.0, 179.0], [854.0, 179.0]], [[824.0, 113.0], [847.0, 113.0], [847.0, 237.0], [824.0, 237.0]], [[791.0, 113.0], [815.0, 113.0], [815.0, 255.0], [791.0, 255.0]]], "lines": ["へロー", "メガネくん。", "私は泉の妖精。"]}, {"box": [415, 79, 538, 271], "vertical": true, "font_size": 24, "lines_coords": [[[512.0, 80.0], [536.0, 80.0], [536.0, 269.0], [512.0, 269.0]], [[480.0, 80.0], [503.0, 80.0], [503.0, 262.0], [480.0, 262.0]], [[447.0, 80.0], [474.0, 80.0], [474.0, 218.0], [447.0, 218.0]], [[418.0, 79.0], [441.0, 79.0], [439.0, 217.0], [415.0, 217.0]]], "lines": ["君が落としたのは、", "華々しく理想的な", "金の未来への", "きっかけか？"]}, {"box": [237, 74, 256, 201], "vertical": true, "font_size": 19, "lines_coords": [[[237.0, 74.0], [256.0, 74.0], [256.0, 201.0], [237.0, 201.0]]], "lines": ["ＳＭＬＳｎｇ．ｃｏｐｅｒ"]}, {"box": [730, 623, 765, 686], "vertical": true, "font_size": 29, "lines_coords": [[[730.0, 623.0], [765.0, 623.0], [765.0, 686.0], [730.0, 686.0]]], "lines": ["いや、"]}, {"box": [577, 391, 634, 578], "vertical": true, "font_size": 25, "lines_coords": [[[607.0, 392.0], [634.0, 392.0], [634.0, 578.0], [607.0, 578.0]], [[577.0, 391.0], [600.0, 391.0], [600.0, 574.0], [577.0, 574.0]]], "lines": ["いんや、アンタは", "ビリーの親父だ！！"]}, {"box": [75, 354, 196, 540], "vertical": true, "font_size": 24, "lines_coords": [[[169.0, 354.0], [194.0, 354.0], [194.0, 453.0], [169.0, 453.0]], [[138.0, 354.0], [162.0, 354.0], [161.0, 540.0], [136.0, 540.0]], [[108.0, 355.0], [131.0, 355.0], [131.0, 493.0], [108.0, 493.0]], [[75.0, 354.0], [99.0, 354.0], [99.0, 447.0], [75.0, 447.0]]], "lines": ["それとも、", "平凡だが安定した", "銀の未来への", "決心か？"]}, {"box": [656, 704, 713, 820], "vertical": true, "font_size": 29, "lines_coords": [[[683.0, 704.0], [713.0, 704.0], [713.0, 779.0], [683.0, 779.0]], [[656.0, 706.0], [679.0, 706.0], [679.0, 820.0], [656.0, 820.0]]], "lines": ["なんか", "もっと．．．"]}, {"box": [786, 943, 845, 1103], "vertical": true, "font_size": 29, "lines_coords": [[[810.0, 943.0], [845.0, 943.0], [845.0, 1018.0], [810.0, 1018.0]], [[786.0, 946.0], [809.0, 946.0], [809.0, 1103.0], [786.0, 1103.0]]], "lines": ["ハイ！！", "時間切れ～～！！"]}, {"box": [464, 924, 488, 1063], "vertical": true, "font_size": 24, "lines_coords": [[[464.0, 924.0], [488.0, 924.0], [488.0, 1062.0], [464.0, 1062.0]]], "lines": ["ではでは～～"]}, {"box": [155, 660, 214, 799], "vertical": true, "font_size": 24, "lines_coords": [[[188.0, 663.0], [211.0, 663.0], [211.0, 797.0], [188.0, 797.0]], [[158.0, 660.0], [183.0, 660.0], [180.0, 799.0], [155.0, 799.0]]], "lines": ["大切なモノの", "ような気が．．"]}, {"box": [808, 1145, 835, 1168], "vertical": false, "font_size": 19, "lines_coords": [[[812.0, 1145.0], [835.0, 1149.0], [831.0, 1168.0], [808.0, 1164.0]]], "lines": ["はっ"]}, {"box": [765, 1123, 809, 1185], "vertical": false, "font_size": 56, "lines_coords": [[[765.0, 1130.0], [798.0, 1123.0], [809.0, 1178.0], [776.0, 1185.0]]], "lines": ["はっ"]}, {"box": [77, 1138, 227, 1337], "vertical": true, "font_size": 31, "lines_coords": [[[194.0, 1138.0], [227.0, 1138.0], [227.0, 1283.0], [194.0, 1283.0]], [[153.0, 1138.0], [185.0, 1138.0], [188.0, 1337.0], [155.0, 1337.0]], [[116.0, 1140.0], [144.0, 1140.0], [147.0, 1311.0], [118.0, 1311.0]], [[77.0, 1140.0], [106.0, 1140.0], [109.0, 1279.0], [80.0, 1279.0]]], "lines": ["うぉーーい", "ちょっと待て！！", "時間切れって", "なんだよ！？"]}], "img_path": "116.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [853, 94, 917, 258], "vertical": true, "font_size": 24, "lines_coords": [[[890.0, 95.0], [914.0, 95.0], [916.0, 233.0], [891.0, 233.0]], [[853.0, 94.0], [876.0, 94.0], [876.0, 258.0], [853.0, 258.0]]], "lines": ["．．．そうか！？", "そうなのか！？"]}, {"box": [555, 408, 687, 605], "vertical": true, "font_size": 29, "lines_coords": [[[663.0, 412.0], [686.0, 412.0], [686.0, 605.0], [663.0, 605.0]], [[620.0, 408.0], [658.0, 408.0], [658.0, 544.0], [620.0, 544.0]], [[589.0, 412.0], [616.0, 412.0], [616.0, 579.0], [589.0, 579.0]], [[555.0, 411.0], [582.0, 411.0], [582.0, 552.0], [555.0, 552.0]]], "lines": ["そうやって俺は", "結局何も", "手に入れられ", "ないのか！？"]}, {"box": [293, 393, 330, 468], "vertical": true, "font_size": 37, "lines_coords": [[[293.0, 393.0], [330.0, 393.0], [330.0, 468.0], [293.0, 468.0]]], "lines": ["減給。"]}, {"box": [746, 661, 834, 844], "vertical": true, "font_size": 23, "lines_coords": [[[810.0, 663.0], [833.0, 663.0], [833.0, 756.0], [810.0, 756.0]], [[776.0, 661.0], [799.0, 661.0], [799.0, 844.0], [776.0, 844.0]], [[746.0, 663.0], [769.0, 663.0], [769.0, 776.0], [746.0, 776.0]]], "lines": ["種田って", "なんでウチの会社", "入ったの？"]}, {"box": [252, 721, 340, 883], "vertical": true, "font_size": 23, "lines_coords": [[[315.0, 723.0], [340.0, 723.0], [340.0, 839.0], [315.0, 839.0]], [[284.0, 723.0], [307.0, 723.0], [307.0, 883.0], [284.0, 883.0]], [[252.0, 721.0], [276.0, 721.0], [276.0, 846.0], [252.0, 846.0]]], "lines": ["大学で一応", "デザインの授業", "取ってたし、"]}, {"box": [125, 858, 229, 996], "vertical": true, "font_size": 23, "lines_coords": [[[206.0, 861.0], [229.0, 861.0], [229.0, 976.0], [206.0, 976.0]], [[179.0, 858.0], [202.0, 858.0], [202.0, 996.0], [179.0, 996.0]], [[151.0, 859.0], [174.0, 859.0], [174.0, 943.0], [151.0, 943.0]], [[125.0, 859.0], [149.0, 859.0], [149.0, 973.0], [125.0, 973.0]]], "lines": ["何かを作る", "仕事っていい", "かもなー", "思って．．．"]}, {"box": [154, 958, 172, 996], "vertical": true, "font_size": 23, "lines_coords": [[[154.0, 958.0], [172.0, 958.0], [172.0, 996.0], [154.0, 996.0]]], "lines": ["と"]}, {"box": [859, 1037, 884, 1116], "vertical": true, "font_size": 22, "lines_coords": [[[859.0, 1037.0], [884.0, 1037.0], [884.0, 1116.0], [859.0, 1116.0]]], "lines": ["お前さ。"]}, {"box": [712, 1110, 825, 1293], "vertical": true, "font_size": 22, "lines_coords": [[[806.0, 1110.0], [825.0, 1110.0], [825.0, 1272.0], [806.0, 1272.0]], [[773.0, 1112.0], [797.0, 1112.0], [797.0, 1248.0], [773.0, 1248.0]], [[741.0, 1111.0], [764.0, 1111.0], [764.0, 1293.0], [741.0, 1293.0]], [[712.0, 1111.0], [731.0, 1111.0], [731.0, 1212.0], [712.0, 1212.0]]], "lines": ["その言い方だと", "一番やりたい", "仕事ではないって", "感じだな。"]}, {"box": [131, 1136, 250, 1367], "vertical": true, "font_size": 22, "lines_coords": [[[226.0, 1138.0], [246.0, 1138.0], [246.0, 1367.0], [226.0, 1367.0]], [[192.0, 1137.0], [216.0, 1137.0], [216.0, 1252.0], [192.0, 1252.0]], [[158.0, 1136.0], [183.0, 1136.0], [184.0, 1278.0], [159.0, 1278.0]], [[132.0, 1140.0], [151.0, 1140.0], [151.0, 1343.0], [132.0, 1343.0]]], "lines": ["まぁ自分のプライドが", "傷つかない", "程度の職場に", "収まったってとこ？"]}], "img_path": "117.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [772, 54, 885, 261], "vertical": true, "font_size": 25, "lines_coords": [[[861.0, 54.0], [884.0, 54.0], [884.0, 147.0], [861.0, 147.0]], [[831.0, 56.0], [858.0, 56.0], [858.0, 195.0], [831.0, 195.0]], [[803.0, 58.0], [827.0, 58.0], [827.0, 261.0], [803.0, 261.0]], [[772.0, 57.0], [797.0, 57.0], [799.0, 158.0], [775.0, 158.0]]], "lines": ["でも理想", "高くしすぎて", "ニートしちゃうよか", "マシかぁ。"]}, {"box": [451, 80, 574, 222], "vertical": true, "font_size": 25, "lines_coords": [[[548.0, 83.0], [572.0, 83.0], [572.0, 195.0], [548.0, 195.0]], [[516.0, 83.0], [540.0, 83.0], [540.0, 199.0], [516.0, 199.0]], [[485.0, 83.0], [508.0, 83.0], [508.0, 222.0], [485.0, 222.0]], [[451.0, 80.0], [479.0, 80.0], [479.0, 164.0], [451.0, 164.0]]], "lines": ["先輩、ソレ", "後ろ向きで", "前向きな考え", "ですね。"]}, {"box": [146, 120, 231, 246], "vertical": true, "font_size": 22, "lines_coords": [[[207.0, 121.0], [231.0, 121.0], [231.0, 237.0], [207.0, 237.0]], [[174.0, 120.0], [199.0, 120.0], [196.0, 236.0], [172.0, 236.0]], [[146.0, 124.0], [165.0, 124.0], [165.0, 246.0], [146.0, 246.0]]], "lines": ["上には上が", "下には下が", "いるってな。"]}, {"box": [742, 578, 859, 806], "vertical": true, "font_size": 23, "lines_coords": [[[836.0, 581.0], [859.0, 581.0], [859.0, 695.0], [836.0, 695.0]], [[806.0, 579.0], [829.0, 579.0], [829.0, 741.0], [806.0, 741.0]], [[775.0, 578.0], [798.0, 578.0], [795.0, 806.0], [772.0, 806.0]], [[743.0, 578.0], [766.0, 578.0], [765.0, 794.0], [742.0, 794.0]]], "lines": ["．．．そういや", "社長が９月から", "ＷＥＢやら週刊誌やら", "仕事の幅広げるって。"]}, {"box": [585, 363, 668, 548], "vertical": true, "font_size": 25, "lines_coords": [[[645.0, 363.0], [668.0, 363.0], [667.0, 526.0], [643.0, 526.0]], [[615.0, 363.0], [639.0, 363.0], [638.0, 548.0], [613.0, 548.0]], [[585.0, 363.0], [613.0, 363.0], [613.0, 538.0], [585.0, 538.0]]], "lines": ["生きるためには", "仕事選べない奴も", "沢山いる訳だし。"]}, {"box": [87, 326, 232, 512], "vertical": true, "font_size": 22, "lines_coords": [[[213.0, 332.0], [232.0, 332.0], [232.0, 464.0], [213.0, 464.0]], [[179.0, 330.0], [202.0, 330.0], [202.0, 493.0], [179.0, 493.0]], [[146.0, 326.0], [170.0, 326.0], [169.0, 512.0], [144.0, 512.0]], [[116.0, 329.0], [139.0, 329.0], [139.0, 490.0], [116.0, 490.0]], [[87.0, 330.0], [106.0, 330.0], [106.0, 474.0], [87.0, 474.0]]], "lines": ["このキビしい", "時代なんだもの", "下を向いて歩こう", "精神で切り抜け", "ようじゃない。"]}, {"box": [235, 616, 262, 730], "vertical": true, "font_size": 24, "lines_coords": [[[237.0, 616.0], [262.0, 616.0], [259.0, 730.0], [235.0, 730.0]]], "lines": ["マジすか？"]}, {"box": [768, 909, 885, 1138], "vertical": true, "font_size": 23, "lines_coords": [[[862.0, 909.0], [885.0, 909.0], [885.0, 1036.0], [862.0, 1036.0]], [[831.0, 910.0], [855.0, 910.0], [853.0, 1050.0], [828.0, 1050.0]], [[798.0, 913.0], [821.0, 913.0], [821.0, 1138.0], [798.0, 1138.0]], [[768.0, 910.0], [787.0, 910.0], [787.0, 1056.0], [768.0, 1056.0]]], "lines": ["まー社長が", "生活習慣病で", "ヨロッと逝ってくれる", "ことを願って。"]}, {"box": [594, 669, 710, 854], "vertical": true, "font_size": 23, "lines_coords": [[[687.0, 671.0], [710.0, 671.0], [710.0, 817.0], [687.0, 817.0]], [[654.0, 671.0], [678.0, 671.0], [678.0, 823.0], [654.0, 823.0]], [[623.0, 669.0], [646.0, 669.0], [645.0, 854.0], [622.0, 854.0]], [[594.0, 672.0], [613.0, 672.0], [613.0, 839.0], [594.0, 839.0]]], "lines": ["あのバカチン、", "その仕事全部", "俺らに押しつける", "気だぜ、きっと。"]}, {"box": [133, 715, 220, 890], "vertical": true, "font_size": 24, "lines_coords": [[[196.0, 715.0], [220.0, 715.0], [220.0, 888.0], [196.0, 888.0]], [[165.0, 716.0], [188.0, 716.0], [188.0, 890.0], [165.0, 890.0]], [[133.0, 719.0], [157.0, 719.0], [157.0, 877.0], [133.0, 877.0]]], "lines": ["じゃあのんびり", "できんのもあと", "１か月弱かぁ．．．"]}, {"box": [675, 1091, 761, 1252], "vertical": true, "font_size": 23, "lines_coords": [[[738.0, 1091.0], [761.0, 1091.0], [761.0, 1186.0], [738.0, 1186.0]], [[705.0, 1091.0], [732.0, 1091.0], [732.0, 1233.0], [705.0, 1233.0]], [[675.0, 1092.0], [698.0, 1092.0], [698.0, 1252.0], [675.0, 1252.0]]], "lines": ["そしたら", "俺らで事務所", "乗っ取ろうぜ？"]}, {"box": [388, 1185, 411, 1263], "vertical": true, "font_size": 23, "lines_coords": [[[388.0, 1185.0], [411.0, 1185.0], [411.0, 1263.0], [388.0, 1263.0]]], "lines": ["ははは。"]}, {"box": [99, 1028, 176, 1281], "vertical": true, "font_size": 28, "lines_coords": [[[150.0, 1028.0], [174.0, 1028.0], [174.0, 1096.0], [150.0, 1096.0]], [[125.0, 1163.0], [161.0, 1163.0], [161.0, 1241.0], [125.0, 1241.0]], [[99.0, 1167.0], [123.0, 1167.0], [123.0, 1281.0], [99.0, 1281.0]]], "lines": ["．．．種田", "バンド", "やってよ！！"]}], "img_path": "118.png"}, {"version": "0.2.0-beta.6", "img_width": 975, "img_height": 1400, "blocks": [{"box": [767, 159, 794, 267], "vertical": true, "font_size": 23, "lines_coords": [[[767.0, 159.0], [790.0, 159.0], [794.0, 267.0], [771.0, 267.0]]], "lines": ["．．．ははは。"]}, {"box": [205, 299, 291, 459], "vertical": true, "font_size": 21, "lines_coords": [[[265.0, 299.0], [289.0, 299.0], [289.0, 395.0], [265.0, 395.0]], [[236.0, 300.0], [255.0, 300.0], [255.0, 459.0], [236.0, 459.0]], [[205.0, 300.0], [224.0, 300.0], [224.0, 422.0], [205.0, 422.0]]], "lines": ["どしたの", "急にそんなこと", "言い出して。"]}, {"box": [789, 812, 875, 974], "vertical": true, "font_size": 22, "lines_coords": [[[851.0, 813.0], [875.0, 813.0], [875.0, 948.0], [851.0, 948.0]], [[819.0, 812.0], [843.0, 812.0], [843.0, 903.0], [819.0, 903.0]], [[790.0, 813.0], [809.0, 813.0], [809.0, 936.0], [790.0, 936.0]]], "lines": ["ソンナ怖イ顔", "サレテモ", "困チャウヨ！"]}, {"box": [466, 826, 565, 1040], "vertical": true, "font_size": 24, "lines_coords": [[[496.0, 900.0], [519.0, 900.0], [522.0, 1040.0], [499.0, 1040.0]], [[466.0, 902.0], [490.0, 902.0], [490.0, 995.0], [466.0, 995.0]]], "lines": ["俺の才能って", "平凡よ？"]}, {"box": [114, 888, 203, 1060], "vertical": true, "font_size": 22, "lines_coords": [[[180.0, 890.0], [199.0, 890.0], [199.0, 1024.0], [180.0, 1024.0]], [[146.0, 888.0], [169.0, 888.0], [169.0, 1050.0], [146.0, 1050.0]], [[114.0, 888.0], [138.0, 888.0], [138.0, 1059.0], [114.0, 1059.0]]], "lines": ["今さら本気で", "やってる奴らに", "かなわないって。"]}, {"box": [761, 1168, 880, 1328], "vertical": true, "font_size": 24, "lines_coords": [[[856.0, 1170.0], [880.0, 1170.0], [880.0, 1263.0], [856.0, 1263.0]], [[824.0, 1168.0], [847.0, 1168.0], [847.0, 1285.0], [824.0, 1285.0]], [[793.0, 1170.0], [816.0, 1170.0], [816.0, 1328.0], [793.0, 1328.0]], [[761.0, 1168.0], [789.0, 1168.0], [789.0, 1208.0], [761.0, 1208.0]]], "lines": ["．．．今日は", "そんなんで", "ゴマかされない", "よ。"]}, {"box": [531, 1115, 593, 1230], "vertical": true, "font_size": 25, "lines_coords": [[[557.0, 1115.0], [593.0, 1115.0], [593.0, 1193.0], [557.0, 1193.0]], [[531.0, 1116.0], [556.0, 1116.0], [556.0, 1230.0], [531.0, 1230.0]]], "lines": ["．．．才能", "ないから"]}, {"box": [534, 1241, 552, 1274], "vertical": true, "font_size": 25, "lines_coords": [[[534.0, 1242.0], [549.0, 1241.0], [552.0, 