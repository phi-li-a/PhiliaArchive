00.0], [772.0, 600.0], [772.0, 695.0], [743.0, 695.0]]], "lines": ["先輩も", "頑張れ。"]}, {"box": [853, 836, 885, 983], "vertical": true, "font_size": 33, "lines_coords": [[[853.0, 836.0], [885.0, 836.0], [885.0, 983.0], [853.0, 983.0]]], "lines": ["なにそれ！"]}, {"box": [808, 940, 844, 1034], "vertical": true, "font_size": 33, "lines_coords": [[[808.0, 941.0], [842.0, 940.0], [844.0, 1033.0], [810.0, 1034.0]]], "lines": ["ーっ！！"]}, {"box": [511, 847, 578, 1015], "vertical": true, "font_size": 28, "lines_coords": [[[549.0, 847.0], [576.0, 847.0], [576.0, 1014.0], [549.0, 1014.0]], [[511.0, 849.0], [540.0, 849.0], [540.0, 1015.0], [511.0, 1015.0]]], "lines": ["ちょっとヤダ", "もぉーーっ！！"]}, {"box": [423, 933, 467, 1099], "vertical": true, "font_size": 37, "lines_coords": [[[423.0, 935.0], [460.0, 933.0], [467.0, 1097.0], [430.0, 1099.0]]], "lines": ["さやあああ"]}, {"box": [90, 962, 233, 1130], "vertical": true, "font_size": 28, "lines_coords": [[[203.0, 963.0], [231.0, 963.0], [231.0, 1103.0], [203.0, 1103.0]], [[164.0, 963.0], [191.0, 963.0], [191.0, 1129.0], [164.0, 1129.0]], [[128.0, 963.0], [155.0, 963.0], [155.0, 1130.0], [128.0, 1130.0]], [[90.0, 962.0], [118.0, 962.0], [118.0, 1101.0], [90.0, 1101.0]]], "lines": ["あんな女に", "心かき乱され", "ちゃってるし", "俺ーーっ！！"]}], "img_path": "095.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [753, 76, 892, 250], "vertical": true, "font_size": 30, "lines_coords": [[[855.0, 76.0], [892.0, 76.0], [892.0, 250.0], [855.0, 250.0]], [[825.0, 82.0], [854.0, 82.0], [854.0, 220.0], [825.0, 220.0]], [[790.0, 80.0], [817.0, 80.0], [817.0, 220.0], [790.0, 220.0]], [[753.0, 79.0], [782.0, 79.0], [782.0, 162.0], [753.0, 162.0]]], "lines": ["あっ、やっと", "繋がった！！", "どこ行って", "たの！？"]}, {"box": [503, 121, 561, 272], "vertical": true, "font_size": 26, "lines_coords": [[[531.0, 121.0], [561.0, 121.0], [561.0, 196.0], [531.0, 196.0]], [[503.0, 123.0], [526.0, 123.0], [527.0, 272.0], [504.0, 272.0]]], "lines": ["どした", "芽衣子ちゃん。"]}, {"box": [106, 129, 212, 326], "vertical": true, "font_size": 31, "lines_coords": [[[179.0, 129.0], [211.0, 129.0], [211.0, 299.0], [179.0, 299.0]], [[142.0, 129.0], [174.0, 129.0], [174.0, 326.0], [142.0, 326.0]], [[106.0, 131.0], [135.0, 131.0], [135.0, 298.0], [106.0, 298.0]]], "lines": ["なんでもいい", "から、今すぐに", "帰ってきて！！"]}, {"box": [515, 382, 544, 460], "vertical": true, "font_size": 29, "lines_coords": [[[515.0, 382.0], [544.0, 382.0], [544.0, 460.0], [515.0, 460.0]]], "lines": ["．．．殺す"]}, {"box": [758, 617, 865, 869], "vertical": true, "font_size": 29, "lines_coords": [[[836.0, 619.0], [864.0, 619.0], [864.0, 869.0], [836.0, 869.0]], [[798.0, 617.0], [827.0, 617.0], [827.0, 816.0], [798.0, 816.0]], [[758.0, 617.0], [787.0, 617.0], [790.0, 849.0], [761.0, 849.0]]], "lines": ["今夜はアイちゃんと", "ご飯食べる約束", "だったんでしょ！？"]}, {"box": [710, 838, 731, 930], "vertical": true, "font_size": 20, "lines_coords": [[[710.0, 838.0], [730.0, 838.0], [730.0, 929.0], [710.0, 929.0]]], "lines": ["首を折る。"]}, {"box": [239, 869, 300, 980], "vertical": true, "font_size": 28, "lines_coords": [[[270.0, 872.0], [295.0, 872.0], [295.0, 980.0], [270.0, 980.0]], [[239.0, 869.0], [269.0, 869.0], [269.0, 929.0], [239.0, 929.0]]], "lines": ["すり潰して", "殺す。"]}, {"box": [109, 694, 216, 924], "vertical": true, "font_size": 28, "lines_coords": [[[187.0, 695.0], [216.0, 695.0], [216.0, 861.0], [187.0, 861.0]], [[149.0, 695.0], [177.0, 695.0], [177.0, 864.0], [149.0, 864.0]], [[109.0, 694.0], [136.0, 694.0], [139.0, 924.0], [112.0, 924.0]]], "lines": ["今、かわりに", "あたしが相手", "してるけどさぁ！！"]}, {"box": [728, 1044, 832, 1308], "vertical": true, "font_size": 26, "lines_coords": [[[802.0, 1044.0], [829.0, 1044.0], [832.0, 1240.0], [805.0, 1240.0]], [[766.0, 1047.0], [794.0, 1047.0], [794.0, 1308.0], [766.0, 1308.0]], [[730.0, 1047.0], [753.0, 1047.0], [753.0, 1183.0], [730.0, 1183.0]]], "lines": ["もう限界です！！", "アイちゃん、はち切れ", "そうです！！"]}, {"box": [127, 1173, 218, 1290], "vertical": true, "font_size": 27, "lines_coords": [[[185.0, 1173.0], [