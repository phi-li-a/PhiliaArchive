164.0, 902.0]], [[129.0, 784.0], [154.0, 784.0], [157.0, 925.0], [132.0, 925.0]], [[99.0, 786.0], [124.0, 786.0], [127.0, 913.0], [102.0, 913.0]]], "lines": ["新しい曲？", "譜面もらって", "ねぇよ、俺。"]}, {"box": [557, 1147, 599, 1198], "vertical": true, "font_size": 42, "lines_coords": [[[557.0, 1147.0], [599.0, 1147.0], [599.0, 1198.0], [557.0, 1198.0]]], "lines": ["この上に置かないだよー！！"]}, {"box": [168, 1003, 272, 1142], "vertical": true, "font_size": 27, "lines_coords": [[[244.0, 1003.0], [272.0, 1003.0], [272.0, 1142.0], [244.0, 1142.0]], [[206.0, 1003.0], [233.0, 1003.0], [233.0, 1142.0], [206.0, 1142.0]], [[168.0, 1006.0], [191.0, 1006.0], [194.0, 1141.0], [170.0, 1141.0]]], "lines": ["今日はもう", "譜面なんて", "いらねー！！"]}, {"box": [109, 1149, 176, 1345], "vertical": true, "font_size": 27, "lines_coords": [[[147.0, 1149.0], [176.0, 1149.0], [176.0, 1264.0], [147.0, 1264.0]], [[109.0, 1149.0], [136.0, 1149.0], [136.0, 1345.0], [109.0, 1345.0]]], "lines": ["魂で演奏", "するんじゃい！！"]}], "img_path": "035.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [669, 79, 756, 265], "vertical": true, "font_size": 24, "lines_coords": [[[732.0, 79.0], [756.0, 79.0], [754.0, 265.0], [731.0, 265.0]], [[701.0, 82.0], [724.0, 82.0], [724.0, 241.0], [701.0, 241.0]], [[669.0, 82.0], [693.0, 82.0], [693.0, 206.0], [669.0, 206.0]]], "lines": ["：リアルに考えて", "貯金がもっても", "１年くらい。"]}, {"box": [540, 101, 626, 296], "vertical": true, "font_size": 24, "lines_coords": [[[602.0, 102.0], [626.0, 102.0], [626.0, 218.0], [602.0, 218.0]], [[570.0, 101.0], [594.0, 101.0], [591.0, 240.0], [567.0, 240.0]], [[540.0, 101.0], [563.0, 101.0], [563.0, 296.0], [540.0, 296.0]]], "lines": ["それまでに", "あたしも何か", "見つけないとなぁ。"]}, {"box": [185, 57, 272, 239], "vertical": true, "font_size": 23, "lines_coords": [[[248.0, 60.0], [272.0, 60.0], [272.0, 176.0], [248.0, 176.0]], [[217.0, 57.0], [240.0, 57.0], [237.0, 239.0], [214.0, 239.0]], [[185.0, 58.0], [209.0, 58.0], [209.0, 203.0], [185.0, 203.0]]], "lines": ["種田も強く", "働けとは言えない", "だろうしねぇ、"]}, {"box": [108, 194, 161, 343], "vertical": true, "font_size": 23, "lines_coords": [[[140.0, 194.0], [161.0, 194.0], [159.0, 332.0], [139.0, 332.0]], [[108.0, 195.0], [131.0, 195.0], [131.0, 343.0], [108.0, 343.0]]], "lines": ["ほとんどヒモ", "だった訳だし。"]}, {"box": [273, 430, 295, 462], "vertical": true, "font_size": 23, "lines_coords": [[[273.0, 430.0], [295.0, 430.0], [295.0, 462.0], [273.0, 462.0]]], "lines": ["ま、"]}, {"box": [140, 488, 257, 650], "vertical": true, "font_size": 23, "lines_coords": [[[233.0, 488.0], [257.0, 488.0], [257.0, 649.0], [233.0, 649.0]], [[203.0, 490.0], [226.0, 490.0], [226.0, 650.0], [203.0, 650.0]], [[172.0, 488.0], [195.0, 488.0], [192.0, 626.0], [169.0, 626.0]], [[140.0, 489.0], [165.0, 489.0], [165.0, 616.0], [140.0, 616.0]]], "lines": ["学生の頃みたく", "みんなが揃って", "．．．．．なんだか", "楽しいよね。"]}, {"box": [828, 693, 881, 795], "vertical": true, "font_size": 23, "lines_coords": [[[858.0, 693.0], [881.0, 693.0], [881.0, 786.0], [858.0, 786.0]], [[828.0, 695.0], [851.0, 695.0], [851.0, 795.0], [828.0, 795.0]]], "lines": ["てもさぁ", "種田の奴、"]}, {"box": [723, 784, 809, 1007], "vertical": true, "font_size": 23, "lines_coords": [[[786.0, 784.0], [809.0, 784.0], [809.0, 917.0], [786.0, 917.0]], [[754.0, 790.0], [777.0, 790.0], [777.0, 1007.0], [754.0, 1007.0]], [[723.0, 790.0], [746.0, 790.0], [746.0, 939.0], [723.0, 939.0]]], "lines": ["「スタジオ！？", "来なくていいって！！」", "とか言うのさ。"]}, {"box": [452, 738, 489, 851], "vertical": true, "font_size": 20, "lines_coords": [[[467.0, 738.0], [489.0, 738.0], [489.0, 780.0], [467.0, 780.0]], [[452.0, 754.0], [471.0, 754.0], [475.0, 847.0], [456.0, 847.0]]], "lines": ["無理", "無理みたいな"]}, {"box": [482, 932, 505, 1013], "vertical": true, "font_size": 23, "lines_coords": [[[482.0, 932.0], [505.0, 932.0], [505.0, 1013.0], [482.0, 1013.0]]], "lines": ["ははは。"]}, {"box": [567, 1104, 694, 1175], "vertical": false, "font_size": 29.0, "lines_coords": [[[571.0, 1133.0], [694.0, 1147.0], [690.0, 1175.0], [567.0, 1162.0]], [[591.0, 1104.0], [674.0, 1108.0], [672.0, 1137.0], [590.0, 1133.0]]], "lines": ["ＲＯＭＡＮＴＩＣ", "ｓＴｕａｌｏ"]}, {"box": [564, 1168, 699, 1201], "vertical": false, "font_size": 24, "lines_coords": [[[566.0, 1168.0], [699.0, 1178.0], [698.0, 1201.0], [564.0, 1192.0]]], "lines": ["月１恒例ＬＶＥ"]}, {"box": [602, 1214, 665, 1234], "vertical": false, "font_size": 15, "lines_coords": [[[604.0, 1214.0], [665.0, 1219.0], [664.0, 1234.0], [602.0, 1229.0]]], "lines": ["お下げの記事はＷｉｎｄｏｗｓでは専用家に利用者目とタイプを"]}, {"box": [563, 1294, 697, 1313], "vertical": false, "font_size": 17, "lines_coords": [[[568.0, 1292.0], [657.0, 1295.0], [657.0, 1314.0], [568.0, 1311.0]]], "lines": ["カウンターにてデモテー"]}, {"box": [421, 1065, 509, 1294], "vertical": true, "font_size": 23, "lines_coords": [[[486.0, 1066.0], [509.0, 1066.0], [509.0, 1193.0], [486.0, 1193.0]], [[455.0, 1065.0], [479.0, 1065.0], [477.0, 1229.0], [452.0, 1229.0]], [[422.0, 1065.0], [445.0, 1065.0], [444.0, 1294.0], [421.0, 1294.0]]], "lines": ["最近人前で", "歌ってないから", "照れてんだよアイツ。"]}, {"box": [83, 981, 174, 1310], "vertical": true, "font_size": 23, "lines_coords": [[[147.0, 1215.0], [172.0, 1215.0], [172.0, 1309.0], [147.0, 1309.0]], [[146.0, 981.0], [169.0, 981.0], [168.0, 1142.0], [144.0, 1142.0]], [[114.0, 981.0], [139.0, 981.0], [136.0, 1121.0], [112.0, 1121.0]], [[84.0, 984.0], [103.0, 984.0], [103.0, 1095.0], [84.0, 1095.0]]], "lines": ["ほら．．．", "でも相変わらず", "種田はいい曲", "作るんだ．．．"]}], "img_path": "036.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [699, 83, 891, 423], "vertical": true, "font_size": 42, "lines_coords": [[[849.0, 84.0], [891.0, 86.0], [887.0, 273.0], [844.0, 272.0]], [[799.0, 83.0], [842.0, 84.0], [838.0, 273.0], [795.0, 272.0]], [[753.0, 231.0], [799.0, 233.0], [791.0, 354.0], [746.0, 351.0]], [[704.0, 236.0], [742.0, 236.0], [738.0, 423.0], [699.0, 423.0]]], "lines": ["ウォンビン", "ウォンビン", "ウォン", "ビンビン！！"]}, {"box": [179, 98, 276, 247], "vertical": true, "font_size": 46, "lines_coords": [[[222.0, 98.0], [276.0, 98.0], [276.0, 183.0], [222.0, 183.0]], [[181.0, 102.0], [220.0, 102.0], [217.0, 247.0], [179.0, 247.0]]], "lines": ["俺の", "チンポコ"]}, {"box": [716, 631, 745, 712], "vertical": true, "font_size": 29, "lines_coords": [[[716.0, 631.0], [745.0, 631.0], [745.0, 712.0], [716.0, 712.0]]], "lines": ["．．．いや、"]}, {"box": [114, 369, 210, 593], "vertical": true, "font_size": 48, "lines_coords": [[[157.0, 369.0], [210.0, 369.0], [210.0, 452.0], [157.0, 452.0]], [[117.0, 370.0], [161.0, 370.0], [158.0, 593.0], [114.0, 593.0]]], "lines": ["マジ", "ウォンビン！！"]}, {"box": [758, 887, 848, 1165], "vertical": true, "font_size": 24, "lines_coords": [[[823.0, 887.0], [846.0, 887.0], [846.0, 1051.0], [823.0, 1051.0]], [[790.0, 888.0], [817.0, 888.0], [817.0, 1163.0], [790.0, 1163.0]], [[761.0, 890.0], [784.0, 890.0], [784.0, 1011.0], [761.0, 1011.0]]], "lines": ["私達は大学時代", "軽音サークルで知り合った", "友人同士で、"]}, {"box": [572, 884, 780, 1159], "vertical": true, "font_size": 26, "lines_coords": [[[698.0, 887.0], [725.0, 887.0], [725.0, 1118.0], [698.0, 1118.0]], [[668.0, 890.0], [691.0, 890.0], [691.0, 1096.0], [668.0, 1096.0]], [[634.0, 888.0], [661.0, 888.0], [661.0, 1118.0], [634.0, 1118.0]], [[602.0, 888.0], [630.0, 888.0], [630.0, 1138.0], [602.0, 1138.0]], [[572.0, 888.0], [596.0, 888.0], [596.0, 1148.0], [572.0, 1148.0]]], "lines": ["私はすぐにサークルを", "辞めてしまったけど", "種田が始めたバンドを", "冷やかすため、昔はよく", "スタジオに出入りしてた。"]}, {"box": [221, 658, 309, 817], "vertical": true, "font_size": 22, "lines_coords": [[[285.0, 660.0], [308.0, 660.0], [308.0, 751.0], [285.0, 751.0]], [[255.0, 660.0], [274.0, 660.0], [274.0, 816.0], [255.0, 816.0]], [[221.0, 658.0], [246.0, 658.0], [246.0, 751.0], [221.0, 751.0]]], "lines": ["いつもは", "ちゃんとしてん", "のよ．．．．．"]}, {"box": [153, 862, 180, 1024], "vertical": true, "font_size": 23, "lines_coords": [[[153.0, 862.0], [176.0, 862.0], [177.0, 1024.0], [154.0, 1024.0]]], "lines": ["かんばーい！！"]}, {"box": [434, 1115, 492, 1351], "vertical": true, "font_size": 29, "lines_coords": [[[463.0, 1115.0], [492.0, 1115.0], [492.0, 1211.0], [463.0, 1211.0]]], "lines": ["卒業して"]}, {"box": [296, 1112, 489, 1358], "vertical": true, "font_size": 23, "lines_coords": [[[433.0, 1115.0], [456.0, 1115.0], [456.0, 1350.0], [433.0, 1350.0]]], "lines": ["みんな揃いづらくなり、"]}, {"box": [306, 1114, 399, 1302], "vertical": true, "font_size": 26, "lines_coords": [[[363.0, 1115.0], [395.0, 1114.0], [399.0, 1186.0], [367.0, 1188.0]], [[337.0, 1115.0], [360.0, 1115.0], [360.0, 1298.0], [337.0, 1298.0]], [[306.0, 1115.0], [329.0, 1115.0], [329.0, 1302.0], [306.0, 1302.0]]], "lines": ["種田も", "ライブをしようと", "しなくなったけど"]}, {"box": [112, 1114, 262, 1252], "vertical": true, "font_size": 24, "lines_coords": [[[239.0, 1116.0], [262.0, 1116.0], [262.0, 1230.0], [239.0, 1230.0]], [[206.0, 1115.0], [231.0, 1115.0], [228.0, 1252.0], [203.0, 1252.0]], [[174.0, 1115.0], [198.0, 1115.0], [198.0, 1231.0], [174.0, 1231.0]], [[140.0, 1114.0], [165.0, 1114.0], [166.0, 1231.0], [142.0, 1231.0]]], "lines": ["月に２回の", "バンド練習の", "習慣だけが", "かろうじて"]}, {"box": [109, 1114, 136, 1235], "vertical": true, "font_size": 26, "lines_coords": [[[109.0, 1114.0], [133.0, 1114.0], [136.0, 1235.0], [112.0, 1235.0]]], "lines": ["残っている。"]}], "img_path": "037.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [805, 83, 894, 199], "vertical": true, "font_size": 24, "lines_coords": [[[869.0, 84.0], [894.0, 84.0], [891.0, 198.0], [866.0, 198.0]], [[836.0, 84.0], [861.0, 84.0], [861.0, 177.0], [836.0, 177.0]], [[805.0, 83.0], [828.0, 83.0], [828.0, 199.0], [805.0, 199.0]]], "lines": ["いやマジで", "芽衣子は", "正しいよ！！"]}, {"box": [691, 101, 777, 306], "vertical": true, "font_size": 24, "lines_coords": [[[754.0, 101.0], [777.0, 101.0], [777.0, 237.0], [754.0, 237.0]], [[723.0, 101.0], [746.0, 101.0], [746.0, 306.0], [723.0, 306.0]], [[691.0, 101.0], [715.0, 101.0], [715.0, 306.0], [691.0, 306.0]]], "lines": ["やっぱ企業の", "犬になり下がっちゃ", "人間終わりだって！！"]}, {"box": [504, 80, 593, 300], "vertical": true, "font_size": 24, "lines_coords": [[[567.0, 82.0], [591.0, 82.0], [590.0, 265.0], [566.0, 265.0]], [[535.0, 80.0], [559.0, 80.0], [559.0, 266.0], [535.0, 266.0]], [[504.0, 82.0], [527.0, 82.0], [527.0, 300.0], [504.0, 300.0]]], "lines": ["バァッカ、実家の", "薬屋継いだお前も", "相当日和ったって！！"]}, {"box": [92, 183, 156, 324], "vertical": true, "font_size": 24, "lines_coords": [[[125.0, 183.0], [150.0, 183.0], [147.0, 324.0], [123.0, 324.0]], [[92.0, 184.0], [116.0, 184.0], [116.0, 300.0], [92.0, 300.0]]], "lines": ["ちょっと加藤", "中年臭い！！"]}, {"box": [790, 572, 896, 747], "vertical": true, "font_size": 24, "lines_coords": [[[870.0, 616.0], [894.0, 616.0], [894.0, 713.0], [870.0, 713.0]], [[865.0, 572.0], [896.0, 572.0], [896.0, 623.0], [865.0, 623.0]], [[842.0, 575.0], [865.0, 575.0], [865.0, 747.0], [842.0, 747.0]], [[814.0, 575.0], [838.0, 575.0], [838.0, 736.0], [814.0, 736.0]], [[790.0, 575.0], [809.0, 575.0], [809.0, 712.0], [790.0, 712.0]]], "lines": ["―俺は", "あー", "お前の１０倍役に", "立たない人間に", "なってやる！！"]}, {"box": [397, 337, 518, 520], "vertical": true, "font_size": 22, "lines_coords": [[[496.0, 339.0], [515.0, 339.0], [515.0, 430.0], [496.0, 430.0]], [[462.0, 340.0], [486.0, 340.0], [486.0, 453.0], [462.0, 453.0]], [[430.0, 339.0], [453.0, 339.0], [453.0, 520.0], [430.0, 520.0]], [[397.0, 337.0], [421.0, 337.0], [421.0, 432.0], [397.0, 432.0]]], "lines": ["言うか！？", "大学６年で", "かつデブのお前が", "言うか！？"]}, {"box": [149, 418, 203, 564], "vertical": true, "font_size": 23, "lines_coords": [[[180.0, 418.0], [203.0, 418.0], [203.0, 534.0], [180.0, 534.0]], [[149.0, 419.0], [172.0, 419.0], [172.0, 564.0], [149.0, 564.0]]], "lines": ["でも久々に", "集まってみて、"]}, {"box": [149, 418, 203, 564], "vertical": true, "font_size": 54, "lines_coords": [[[149.0, 418.0], [203.0, 418.0], [203.0, 564.0], [149.0, 564.0]]], "lines": ["でも久々に集まってみて、"]}, {"box": [217, 579, 302, 776], "vertical": true, "font_size": 23, "lines_coords": [[[278.0, 581.0], [302.0, 581.0], [302.0, 719.0], [278.0, 719.0]], [[244.0, 579.0], [272.0, 579.0], [272.0, 776.0], [244.0, 776.0]], [[217.0, 583.0], [236.0, 583.0], [236.0, 725.0], [217.0, 725.0]]], "lines": ["あまりノリが", "変わってないことが", "少しうれしい。"]}, {"box": [215, 582, 305, 775], "vertical": true, "font_size": 90, "lines_coords": [[[215.0, 582.0], [305.0, 582.0], [305.0, 775.0], [215.0, 775.0]]], "lines": ["あまりノリが変わってないことが少しうれしい。"]}, {"box": [715, 787, 801, 903], "vertical": true, "font_size": 24, "lines_coords": [[[777.0, 787.0], [801.0, 787.0], [801.0, 902.0], [777.0, 902.0]], [[743.0, 787.0], [768.0, 787.0], [769.0, 881.0], [745.0, 881.0]], [[715.0, 787.0], [738.0, 787.0], [738.0, 903.0], [715.0, 903.0]]], "lines": ["じゃあ俺は", "その１００倍", "じゃー！！"]}, {"box": [791, 988, 879, 1170], "vertical": true, "font_size": 23, "lines_coords": [[[854.0, 988.0], [877.0, 988.0], [877.0, 1125.0], [854.0, 1125.0]], [[821.0, 988.0], [844.0, 988.0], [846.0, 1168.0], [823.0, 1168.0]], [[791.0, 988.0], [814.0, 988.0], [814.0, 1170.0], [791.0, 1170.0]]], "lines": ["オイ、種田！！", "おめーはそこら辺", "どう考えてんだ！？"]}, {"box": [346, 993, 479, 1166], "vertical": true, "font_size": 22, "lines_coords": [[[407.0, 1045.0], [432.0, 1045.0], [432.0, 1142.0], [407.0, 1142.0]], [[377.0, 1048.0], [400.0, 1048.0], [400.0, 1164.0], [377.0, 1164.0]], [[347.0, 1050.0], [366.0, 1050.0], [366.0, 1148.0], [347.0, 1148.0]]], "lines": ["なんとも", "言えねー", "問題だな。"]}, {"box": [113, 1194, 142, 1331], "vertical": true, "font_size": 24, "lines_coords": [[[116.0, 1194.0], [140.0, 1194.0], [138.0, 1331.0], [113.0, 1331.0]]], "lines": ["．．．．．あれ？"]}], "img_path": "038.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [812, 97, 870, 240], "vertical": true, "font_size": 27, "lines_coords": [[[840.0, 97.0], [870.0, 98.0], [868.0, 175.0], [838.0, 173.0]], [[812.0, 102.0], [835.0, 102.0], [835.0, 202.0], [812.0, 202.0]]], "lines": ["じゃあ", "おつかれ"]}, {"box": [109, 90, 198, 252], "vertical": true, "font_size": 22, "lines_coords": [[[174.0, 92.0], [198.0, 92.0], [198.0, 232.0], [174.0, 232.0]], [[143.0, 92.0], [166.0, 92.0], [166.0, 