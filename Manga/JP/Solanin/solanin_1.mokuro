1.0, 1291.0], [229.0, 1287.0]], [[250.0, 1291.0], [365.0, 1289.0], [365.0, 1323.0], [250.0, 1326.0]]], "lines": ["井上芽夜子", "権田成男"]}], "img_path": "008.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [416, 82, 543, 153], "vertical": false, "font_size": 71, "lines_coords": [[[416.0, 82.0], [543.0, 82.0], [543.0, 153.0], [416.0, 153.0]]], "lines": ["井１"]}], "img_path": "009.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [735, 101, 856, 309], "vertical": true, "font_size": 25, "lines_coords": [[[829.0, 103.0], [853.0, 103.0], [855.0, 263.0], [832.0, 263.0]], [[794.0, 101.0], [823.0, 101.0], [825.0, 228.0], [797.0, 228.0]], [[766.0, 105.0], [790.0, 105.0], [790.0, 308.0], [766.0, 308.0]], [[735.0, 102.0], [758.0, 102.0], [758.0, 293.0], [735.0, 293.0]]], "lines": ["あたしの実家は", "農家なので、", "親が山盛りの野菜を", "送ってきたりする。"]}, {"box": [553, 213, 579, 255], "vertical": true, "font_size": 23, "lines_coords": [[[553.0, 216.0], [574.0, 213.0], [579.0, 251.0], [559.0, 255.0]]], "lines": ["．．．"]}, {"box": [497, 138, 581, 329], "vertical": true, "font_size": 23, "lines_coords": [[[556.0, 138.0], [581.0, 138.0], [581.0, 202.0], [556.0, 202.0]], [[527.0, 138.0], [550.0, 138.0], [550.0, 276.0], [527.0, 276.0]], [[497.0, 138.0], [518.0, 138.0], [519.0, 329.0], [499.0, 329.0]]], "lines": ["うへー", "どーせ余って", "腐らせちゃうよって"]}, {"box": [467, 136, 559, 511], "vertical": true, "font_size": 23, "lines_coords": [[[468.0, 136.0], [492.0, 136.0], [490.0, 287.0], [467.0, 287.0]], [[535.0, 370.0], [559.0, 370.0], [559.0, 511.0], [535.0, 511.0]], [[501.0, 369.0], [526.0, 369.0], [527.0, 488.0], [503.0, 488.0]], [[473.0, 370.0], [496.0, 370.0], [496.0, 466.0], [473.0, 466.0]]], "lines": ["言ってんのに。", "今日からまた", "カレー地獄", "だよ．．．"]}, {"box": [101, 45, 202, 71], "vertical": false, "font_size": 24, "lines_coords": [[[101.0, 47.0], [202.0, 45.0], [202.0, 68.0], [101.0, 71.0]]], "lines": ["ソラニンの"]}, {"box": [594, 470, 749, 700], "vertical": true, "font_size": 25, "lines_coords": [[[725.0, 471.0], [749.0, 471.0], [746.0, 631.0], [723.0, 631.0]], [[690.0, 471.0], [717.0, 471.0], [717.0, 679.0], [690.0, 679.0]], [[660.0, 473.0], [684.0, 473.0], [683.0, 678.0], [658.0, 678.0]], [[627.0, 471.0], [654.0, 471.0], [653.0, 700.0], [626.0, 700.0]], [[597.0, 470.0], [622.0, 470.0], [619.0, 596.0], [594.0, 596.0]]], "lines": ["でも、あたしは", "消費社会の人だから", "コンビニのバンとか", "チョコレートのほうが", "好きなのだ。"]}, {"box": [87, 583, 113, 708], "vertical": true, "font_size": 23, "lines_coords": [[[87.0, 583.0], [110.0, 583.0], [113.0, 706.0], [90.0, 706.0]]], "lines": ["ただいまぁ。"]}, {"box": [762, 736, 855, 879], "vertical": true, "font_size": 26, "lines_coords": [[[821.0, 736.0], [855.0, 736.0], [855.0, 879.0], [821.0, 879.0]], [[795.0, 739.0], [818.0, 739.0], [818.0, 833.0], [795.0, 833.0]], [[762.0, 741.0], [787.0, 741.0], [787.0, 832.0], [762.0, 832.0]]], "lines": ["おー何？", "また野菜", "届いた？"]}, {"box": [654, 825, 745, 965], "vertical": true, "font_size": 26, "lines_coords": [[[721.0, 827.0], [745.0, 827.0], [745.0, 965.0], [721.0, 965.0]], [[690.0, 828.0], [713.0, 828.0], [713.0, 943.0], [690.0, 943.0]], [[654.0, 827.0], [683.0, 825.0], [686.0, 898.0], [657.0, 899.0]]], "lines": ["てことはまた", "カレー祭り", "かぁ？"]}, {"box": [370, 944, 489, 1082], "vertical": true, "font_size": 25, "lines_coords": [[[464.0, 944.0], [489.0, 944.0], [486.0, 1081.0], [462.0, 1081.0]], [[432.0, 946.0], [455.0, 946.0], [455.0, 1082.0], [432.0, 1082.0]], [[400.0, 944.0], [425.0, 944.0], [422.0, 1082.0], [397.0, 1082.0]], [[370.0, 947.0], [389.0, 947.0], [389.0, 1078.0], [370.0, 1078.0]]], "lines": ["おっそいよ！", "今日は種田が", "朝ごはん作る", "番じゃんか！"]}, {"box": [229, 797, 254, 880], "vertical": true, "font_size": 23, "lines_coords": [[[229.0, 797.0], [252.0, 797.0], [252.0, 880.0], [229.0, 880.0]]], "lines": ["ごめん。"]}, {"box": [348, 1152, 440, 1316], "vertical": true, "font_size": 25, "lines_coords": [[[408.0, 1152.0], [440.0, 1152.0], [440.0, 1212.0], [408.0, 1212.0]], [[381.0, 1153.0], [404.0, 1153.0], [404.0, 1316.0], [381.0, 1316.0]], [[348.0, 1153.0], [374.0, 1153.0], [374.0, 1214.0], [348.0, 1214.0]]], "lines": ["ホラ、", "すみませんって", "言え。"]}, {"box": [128, 985, 221, 1193], "vertical": true, "font_size": 29, "lines_coords": [[[185.0, 985.0], [221.0, 985.0], [221.0, 1050.0], [185.0, 1050.0]], [[158.0, 988.0], [185.0, 988.0], [185.0, 1193.0], [158.0, 1193.0]], [[128.0, 989.0], [151.0, 989.0], [151.0, 1103.0], [128.0, 1103.0]]], "lines": ["違う、", "ス・ミ・マ・セ・ン", "だっつの！！"]}, {"box": [101, 1216, 125, 1298], "vertical": true, "font_size": 24, "lines_coords": [[[101.0, 1216.0], [125.0, 1216.0], [125.0, 1298.0], [101.0, 1298.0]]], "lines": ["すめん。"]}], "img_path": "010.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [847, 71, 870, 207], "vertical": true, "font_size": 24, "lines_coords": [[[847.0, 71.0], [870.0, 71.0], [870.0, 207.0], [847.0, 207.0]]], "lines": ["うぉーーい！！"]}, {"box": [730, 181, 816, 345], "vertical": true, "font_size": 24, "lines_coords": [[[791.0, 181.0], [816.0, 181.0], [816.0, 278.0], [791.0, 278.0]], [[761.0, 184.0], [784.0, 184.0], [784.0, 345.0], [761.0, 345.0]], [[730.0, 185.0], [753.0, 185.0], [753.0, 277.0], [730.0, 277.0]]], "lines": ["朝っから", "ムカつく男だね", "ホント！！"]}, {"box": [777, 583, 832, 676], "vertical": true, "font_size": 21, "lines_coords": [[[812.0, 586.0], [832.0, 586.0], [832.0, 627.0], [812.0, 627.0]], [[777.0, 583.0], [801.0, 583.0], [801.0, 676.0], [777.0, 676.0]]], "lines": ["んー", "仕事は？"]}, {"box": [812, 637, 832, 676], "vertical": true, "font_size": 21, "lines_coords": [[[812.0, 637.0], [832.0, 637.0], [832.0, 676.0], [812.0, 676.0]]], "lines": ["．．．"]}, {"box": [129, 199, 258, 523], "vertical": true, "font_size": 26, "lines_coords": [[[229.0, 199.0], [258.0, 199.0], [258.0, 304.0], [229.0, 304.0]], [[210.0, 325.0], [233.0, 325.0], [233.0, 464.0], [210.0, 464.0]], [[179.0, 324.0], [207.0, 324.0], [210.0, 477.0], [181.0, 477.0]], [[155.0, 328.0], [179.0, 328.0], [179.0, 523.0], [155.0, 523.0]], [[129.0, 326.0], [153.0, 326.0], [153.0, 475.0], [129.0, 475.0]]], "lines": ["ひっひっ。", "ちょっと今は", "カンベンして。", "かなり疲れてんの。", "完徹なの、俺。"]}, {"box": [262, 601, 319, 706], "vertical": true, "font_size": 25, "lines_coords": [[[295.0, 601.0], [319.0, 601.0], [319.0, 695.0], [295.0, 695.0]], [[265.0, 604.0], [289.0, 604.0], [287.0, 706.0], [262.0, 706.0]]], "lines": ["どうにか", "山越えた。"]}, {"box": [790, 809, 880, 998], "vertical": true, "font_size": 28, "lines_coords": [[[851.0, 809.0], [880.0, 809.0], [880.0, 936.0], [851.0, 936.0]], [[821.0, 812.0], [849.0, 812.0], [849.0, 996.0], [821.0, 996.0]], [[790.0, 813.0], [817.0, 813.0], [817.0, 998.0], [790.0, 998.0]]], "lines": ["あーーホラ、", "最早、むこうの国", "から、お迎えが．．．"]}, {"box": [133, 637, 221, 777], "vertical": true, "font_size": 25, "lines_coords": [[[194.0, 637.0], [221.0, 637.0], [221.0, 777.0], [194.0, 777.0]], [[165.0, 639.0], [188.0, 639.0], [188.0, 757.0], [165.0, 757.0]], [[133.0, 641.0], [158.0, 641.0], [158.0, 719.0], [133.0, 719.0]]], "lines": ["今日から俺は", "堕落するよ、", "マジで。"]}, {"box": [538, 1065, 633, 1248], "vertical": true, "font_size": 24, "lines_coords": [[[602.0, 1066.0], [626.0, 1066.0], [626.0, 1203.0], [602.0, 1203.0]], [[568.0, 1065.0], [596.0, 1065.0], [596.0, 1248.0], [568.0, 1248.0]], [[538.0, 1065.0], [564.0, 1065.0], [564.0, 1110.0], [538.0, 1110.0]], [[541.0, 1110.0], [561.0, 1110.0], [561.0, 1156.0], [541.0, 1156.0]]], "lines": ["芽衣子さんも", "お仕事、頑張って", "ねー", "．．．"]}], "img_path": "011.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [648, 87, 738, 318], "vertical": true, "font_size": 25, "lines_coords": [[[712.0, 88.0], [735.0, 88.0], [735.0, 247.0], [712.0, 247.0]], [[680.0, 87.0], [704.0, 87.0], [704.0, 315.0], [680.0, 315.0]], [[648.0, 87.0], [676.0, 87.0], [676.0, 165.0], [648.0, 165.0]]], "lines": ["あたしは東京の", "どこにでもいるような", "ＯＬで、"]}, {"box": [416, 87, 543, 295], "vertical": true, "font_size": 25, "lines_coords": [[[518.0, 87.0], [541.0, 87.0], [540.0, 270.0], [516.0, 270.0]], [[485.0, 87.0], [508.0, 87.0], [508.0, 269.0], [485.0, 269.0]], [[452.0, 88.0], [475.0, 88.0], [478.0, 293.0], [455.0, 293.0]], [[416.0, 88.0], [445.0, 87.0], [449.0, 214.0], [421.0, 216.0]]], "lines": ["でもまだ若いから", "社会とか大人とか", "いろいろ不平不満が", "全然あって。"]}, {"box": [191, 86, 313, 272], "vertical": true, "font_size": 24, "lines_coords": [[[287.0, 87.0], [310.0, 87.0], [310.0, 270.0], [287.0, 270.0]], [[255.0, 88.0], [278.0, 88.0], [278.0, 225.0], [255.0, 225.0]], [[222.0, 88.0], [247.0, 88.0], [247.0, 180.0], [222.0, 180.0]], [[191.0, 90.0], [214.0, 90.0], [214.0, 213.0], [191.0, 213.0]]], "lines": ["どうしていいのか", "わからなくて", "体に毒が", "たまってく。"]}, {"box": [717, 459, 839, 643], "vertical": true, "font_size": 24, "lines_coords": [[[814.0, 459.0], [838.0, 459.0], [839.0, 642.0], [816.0, 642.0]], [[783.0, 462.0], [806.0, 462.0], [806.0, 620.0], [783.0, 620.0]], [[750.0, 459.0], [775.0, 459.0], [776.0, 643.0], [751.0, 643.0]], [[717.0, 459.0], [742.0, 459.0], [745.0, 586.0], [720.0, 586.0]]], "lines": ["こんな日は道ゆく", "無関係な人すら", "心から憎く思えて", "ムカついて、"]}, {"box": [765, 868, 851, 1063], "vertical": true, "font_size": 22, "lines_coords": [[[828.0, 872.0], [851.0, 872.0], [851.0, 1063.0], [828.0, 1063.0]], [[794.0, 868.0], [818.0, 868.0], [820.0, 1019.0], [795.0, 1019.0]], [[765.0, 870.0], [784.0, 870.0], [784.0, 1039.0], [765.0, 1039.0]]], "lines": ["いや、そこのアナタ", "その顔完全に", "昇天してるから。"]}, {"box": [627, 877, 650, 993], "vertical": true, "font_size": 23, "lines_coords": [[[627.0, 877.0], [650.0, 877.0], [650.0, 993.0], [627.0, 993.0]]], "lines": ["．．．てゆーか"]}, {"box": [503, 943, 589, 1082], "vertical": true, "font_size": 23, "lines_coords": [[[561.0, 944.0], [586.0, 944.0], [589.0, 1082.0], [564.0, 1082.0]], [[530.0, 943.0], [555.0, 943.0], [557.0, 1060.0], [533.0, 1060.0]], [[503.0, 946.0], [522.0, 946.0], [522.0, 1036.0], [503.0, 1036.0]]], "lines": ["みんな消えて", "なくなって", "しまえ！！"]}, {"box": [138, 653, 279, 816], "vertical": true, "font_size": 22, "lines_coords": [[[254.0, 654.0], [277.0, 654.0], [277.0, 747.0], [254.0, 747.0]], [[220.0, 653.0], [247.0, 653.0], [250.0, 816.0], [222.0, 816.0]], [[195.0, 654.0], [218.0, 654.0], [218.0, 771.0], [195.0, 771.0]], [[168.0, 656.0], [187.0, 656.0], [187.0, 791.0], [168.0, 791.0]], [[139.0, 656.0], [158.0, 656.0], [158.0, 776.0], [139.0, 776.0]]], "lines": ["あたしは", "たくさんの人に", "邪悪な念を", "とはしながら", "通勤します。"]}, {"box": [276, 1150, 380, 1316], "vertical": true, "font_size": 27, "lines_coords": [[[351.0, 1152.0], [380.0, 1152.0], [380.0, 1263.0], [351.0, 1263.0]], [[313.0, 1152.0], [341.0, 1152.0], [341.0, 1316.0], [313.0, 1316.0]], [[277.0, 1152.0], [302.0, 1152.0], [302.0, 1270.0], [277.0, 1270.0]]], "lines": ["東京には", "魔物が潜んで", "おります。"]}], "img_path": "012.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [739, 102, 858, 241], "vertical": true, "font_size": 23, "lines_coords": [[[833.0, 102.0], [858.0, 102.0], [858.0, 226.0], [833.0, 226.0]], [[802.0, 103.0], [825.0, 103.0], [825.0, 240.0], [802.0, 240.0]], [[769.0, 102.0], [794.0, 102.0], [791.0, 241.0], [766.0, 241.0]], [[741.0, 103.0], [760.0, 103.0], [760.0, 217.0], [741.0, 217.0]]], "lines": ["えぇーーっ、", "井上先輩って", "同棲してるん", "てすかァ！？"]}, {"box": [447, 158, 534, 326], "vertical": true, "font_size": 24, "lines_coords": [[[511.0, 159.0], [534.0, 159.0], [534.0, 298.0], [511.0, 298.0]], [[479.0, 159.0], [503.0, 159.0], [503.0, 319.0], [479.0, 319.0]], [[447.0, 158.0], [470.0, 158.0], [471.0, 326.0], [448.0, 326.0]]], "lines": ["大学卒業して", "彼氏がちょっと", "プラプラしてて、"]}, {"box": [334, 190, 421, 375], "vertical": true, "font_size": 24, "lines_coords": [[[397.0, 191.0], [421.0, 191.0], [421.0, 329.0], [397.0, 329.0]], [[363.0, 190.0], [391.0, 190.0], [391.0, 375.0], [363.0, 375.0]], [[334.0, 191.0], [358.0, 191.0], [358.0, 317.0], [334.0, 317.0]]], "lines": ["そのあとから", "だから、そろそろ", "１年くらい。"]}, {"box": [110, 455, 166, 546], "vertical": true, "font_size": 21, "lines_coords": [[[144.0, 455.0], [166.0, 455.0], [166.0, 525.0], [144.0, 525.0]], [[110.0, 455.0], [133.0, 455.0], [133.0, 546.0], [110.0, 546.0]]], "lines": ["えぇー", "超スゴー"]}, {"box": [113, 520, 166, 600], "vertical": true, "font_size": 21, "lines_coords": [[[146.0, 520.0], [166.0, 520.0], [166.0, 576.0], [146.0, 576.0]], [[113.0, 541.0], [132.0, 541.0], [132.0, 600.0], [113.0, 600.0]]], "lines": ["ーっ、", "いい"]}, {"box": [787, 575, 895, 867], "vertical": true, "font_size": 22, "lines_coords": [[[869.0, 575.0], [892.0, 575.0], [892.0, 656.0], [869.0, 656.0]], [[850.0, 698.0], [873.0, 698.0], [873.0, 835.0], [850.0, 835.0]], [[818.0, 697.0], [842.0, 697.0], [842.0, 835.0], [818.0, 835.0]], [[787.0, 697.0], [806.0, 697.0], [806.0, 865.0], [787.0, 865.0]]], "lines": ["まぁね。", "ウザい時とか", "ホント死んで", "くれって思うよ。"]}, {"box": [419, 769, 508, 907], "vertical": true, "font_size": 20, "lines_coords": [[[485.0, 771.0], [504.0, 771.0], [504.0, 884.0], [485.0, 884.0]], [[451.0, 769.0], [475.0, 769.0], [473.0, 907.0], [448.0, 907.0]], [[419.0, 769.0], [442.0, 769.0], [442.0, 868.0], [419.0, 868.0]], [[423.0, 859.0], [438.0, 859.0], [438.0, 903.0], [423.0, 903.0]]], "lines": ["彼氏さんは", "何してるヒト", "ですかー", "ー？"]}, {"box": [157, 881, 217, 1054], "vertical": true, "font_size": 24, "lines_coords": [[[192.0, 884.0], [217.0, 884.0], [217.0, 973.0], [192.0, 973.0]], [[157.0, 881.0], [184.0, 881.0], [187.0, 1054.0], [159.0, 1054.0]]], "lines": ["えーっ", "超タイヘーン。"]}, {"box": [788, 1008, 909, 1213], "vertical": true, "font_size": 23, "lines_coords": [[[884.0, 1008.0], [907.0, 1008.0], [907.0, 1190.0], [884.0, 1190.0]], [[853.0, 1008.0], [876.0, 1008.0], [876.0, 1168.0], [853.0, 1168.0]], [[821.0, 1008.0], [844.0, 1008.0], [844.0, 1212.0], [821.0, 1212.0]], [[788.0, 1008.0], [812.0, 1008.0], [812.0, 1177.0], [788.0, 1177.0]]], "lines": ["新聞社の下請けの", "会社でイラスト", "描いてるけど、まだ", "バイト扱いでさ。"]}, {"box": [381, 1063, 501, 1257], "vertical": true, "font_size": 22, "lines_coords": [[[475.0, 1065.0], [499.0, 1065.0], [499.0, 1225.0], [475.0, 1225.0]], [[442.0, 1063.0], [466.0, 1063.0], [466.0, 1256.0], [442.0, 1256.0]], [[411.0, 1063.0], [434.0, 1063.0], [434.0, 1225.0], [411.0, 1225.0]], [[381.0, 1065.0], [400.0, 1065.0], [400.0, 1256.0], [381.0, 1256.0]]], "lines": ["時給低くて部屋", "借りられないって、", "仕方なく一緒に", "住んでるんだよね。"]}, {"box": [102, 1111, 220, 1297], "vertical": true, "font_size": 24, "lines_coords": [[[196.0, 1114.0], [220.0, 1114.0], [220.0, 1296.0], [196.0, 1296.0]], [[166.0, 1112.0], [190.0, 1112.0], [190.0, 1297.0], [166.0, 1297.0]], [[136.0, 1116.0], [155.0, 1116.0], [155.0, 1294.0], [136.0, 1294.0]], [[102.0, 1111.0], [125.0, 1111.0], [127.0, 1261.0], [103.0, 1261.0]]], "lines": ["アタシは今、彼に", "部屋広すぎるから", "一緒に住もうって", "言われててぇ。"]}], "img_path": "013.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [827, 83, 883, 252], "vertical": true, "font_size": 23, "lines_coords": [[[858.0, 83.0], [883.0, 83.0], [883.0, 176.0], [858.0, 176.0]], [[828.0, 84.0], [849.0, 84.0], [847.0, 248.0], [827.0, 248.0]]], "lines": ["ああ．．．", "お金持ちなのね、"]}, {"box": [587, 225, 702, 365], "vertical": true, "font_size": 22, "lines_coords": [[[678.0, 225.0], [699.0, 225.0], [702.0, 334.0], [680.0, 334.0]], [[648.0, 226.0], [671.0, 226.0], [671.0, 362.0], [648.0, 362.0]], [[616.0, 225.0], [639.0, 225.0], [639.0, 365.0], [616.0, 365.0]], [[587.0, 226.0], [608.0, 226.0], [608.0, 288.0], [587.0, 288.0]]], "lines": ["なんかァー", "ＩＴ企業だか", "なんかの社長", "てえー"]}, {"box": [440, 65, 554, 289], "vertical": true, "font_size": 28, "lines_coords": [[[474.0, 129.0], [508.0, 129.0], [508.0, 289.0], [474.0, 289.0]], [[440.0, 131.0], [463.0, 131.0], [463.0, 224.0], [440.0, 224.0]]], "lines": ["バカなんじゃ", "ないの？"]}, {"box": [94, 49, 211, 68], "vertical": false, "font_size": 19, "lines_coords": [[[94.0, 49.0], [211.0, 49.0], [211.0, 68.0], [94.0, 68.0]]], "lines": ["ソラニンの"]}, {"box": [88, 184, 210, 367], "vertical": true, "font_size": 22, "lines_coords": [[[184.0, 184.0], [209.0, 184.0], [209.0, 278.0], [184.0, 278.0]], [[154.0, 185.0], [173.0, 185.0], [173.0, 365.0], [154.0, 365.0]], [[123.0, 185.0], [142.0, 185.0], [142.0, 366.0], [123.0, 366.0]], [[88.0, 184.0], [112.0, 184.0], [113.0, 336.0], [90.0, 336.0]]], "lines": ["彼の夢は", "アルタ前に自分の", "銅像を建てること", "なんですよぉ。"]}, {"box": [607, 410, 723, 615], "vertical": true, "font_size": 22, "lines_coords": [[[699.0, 411.0], [723.0, 411.0], [723.0, 574.0], [699.0, 574.0]], [[668.0, 410.0], [691.0, 410.0], [691.0, 591.0], [668.0, 591.0]], [[635.0, 410.0], [658.0, 410.0], [658.0, 615.0], [635.0, 615.0]], [[608.0, 410.0], [627.0, 410.0], [627.0, 468.0], [608.0, 468.0]], [[607.0, 464.0], [626.0, 464.0], [626.0, 523.0], [607.0, 523.0]]], "lines": ["スゴいんですよ、", "両腕にブルガリの", "時計とかしちゃって", "てぇー", "！！"]}, {"box": [307, 605, 365, 753], "vertical": true, "font_size": 24, "lines_coords": [[[336.0, 605.0], [365.0, 605.0], [365.0, 701.0], [336.0, 701.0]], [[307.0, 605.0], [330.0, 605.0], [330.0, 753.0], [307.0, 753.0]]], "lines": ["あ、ホラ", "直ったじゃん。"]}, {"box": [165, 437, 226, 525], "vertical": true, "font_size": 29, "lines_coords": [[[191.0, 441.0], [226.0, 441.0], [226.0, 522.0], [191.0, 522.0]], [[165.0, 437.0], [188.0, 437.0], [188.0, 525.0], [165.0, 525.0]]], "lines": ["へえ。", "すごいね。"]}, {"box": [721, 643, 838, 854], "vertical": true, "font_size": 23, "lines_coords": [[[818.0, 645.0], [838.0, 645.0], [838.0, 777.0], [818.0, 777.0]], [[786.0, 643.0], [809.0, 643.0], [809.0, 766.0], [786.0, 766.0]], [[753.0, 645.0], [776.0, 645.0], [776.0, 803.0], [753.0, 803.0]], [[721.0, 643.0], [745.0, 643.0], [745.0, 854.0], [721.0, 854.0]]], "lines": ["ウチの会社は", "二流だけど、", "地味さは一流の", "ＯＡ機器メーカーで、"]}, {"box": [717, 866, 855, 1178], "vertical": true, "font_size": 26, "lines_coords": [[[813.0, 869.0], [847.0, 866.0], [855.0, 954.0], [821.0, 957.0]], [[813.0, 983.0], [836.0, 983.0], [836.0, 1097.0], [813.0, 1097.0]], [[782.0, 981.0], [806.0, 981.0], [803.0, 1103.0], [779.0, 1103.0]], [[749.0, 983.0], [772.0, 983.0], [772.0, 1142.0], [749.0, 1142.0]], [[717.0, 981.0], [741.0, 981.0], [742.0, 1178.0], [719.0, 1178.0]]], "lines": ["えへっ。", "でも先輩の", "修理する姿、", "なかなかサマに", "なってましたよォ。"]}, {"box": [617, 645, 672, 846], "vertical": true, "font_size": 23, "lines_coords": [[[649.0, 645.0], [672.0, 645.0], [672.0, 846.0], [649.0, 846.0]], [[617.0, 645.0], [641.0, 645.0], [641.0, 787.0], [617.0, 787.0]]], "lines": ["あたしはつつましく", "社員している。"]}, {"box": [150, 663, 267, 853], "vertical": true, "font_size": 24, "lines_coords": [[[244.0, 663.0], [267.0, 663.0], [267.0, 821.0], [244.0, 821.0]], [[213.0, 663.0], [236.0, 663.0], [236.0, 823.0], [213.0, 823.0]], [[181.0, 664.0], [205.0, 664.0], [205.0, 821.0], [181.0, 821.0]], [[153.0, 663.0], [172.0, 663.0], [169.0, 853.0], [150.0, 853.0]]], "lines": ["あんたもウチの", "社員なんだから", "コピー機くらい", "自分で直してよね。"]}, {"box": [444, 1163, 498, 1344], "vertical": true, "font_size": 19, "lines_coords": [[[475.0, 1164.0], [494.0, 1164.0], [494.0, 1327.0], [475.0, 1327.0]], [[445.0, 1166.0], [464.0, 1166.0], [464.0, 1343.0], [445.0, 1343.0]]], "lines": ["．．．このタヌキ女", "いつかぶっ殺す！！"]}, {"box": [196, 998, 306, 1275], "vertical": true, "font_size": 31, "lines_coords": [[[276.0, 1000.0], [304.0, 1000.0], [304.0, 1200.0], [276.0, 1200.0]], [[233.0, 998.0], [270.0, 998.0], [270.0, 1275.0], [233.0, 1275.0]], [[196.0, 999.0], [225.0, 999.0], [228.0, 1148.0], [199.0, 1148.0]]], "lines": ["あたしが思うに、", "大人は「まぁいいや」の", "カタマリだ。"]}], "img_path": "014.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [702, 125, 764, 334], "vertical": true, "font_size": 26, "lines_coords": [[[739.0, 128.0], [762.0, 128.0], [760.0, 334.0], [736.0, 334.0]], [[705.0, 125.0], [732.0, 125.0], [730.0, 258.0], [702.0, 258.0]]], "lines": ["おなかが出てきても", "まぁいいや。"]}, {"box": [605, 128, 663, 288], "vertical": true, "font_size": 24, "lines_coords": [[[635.0, 128.0], [660.0, 128.0], [661.0, 288.0], [637.0, 288.0]], [[605.0, 129.0], [628.0, 129.0], [628.0, 261.0], [605.0, 261.0]]], "lines": ["鼻毛が出てても", "まぁいいや。"]}, {"box": [503, 128, 559, 289], "vertical": true, "font_size": 21, "lines_coords": [[[533.0, 128.0], [556.0, 128.0], [557.0, 289.0], [534.0, 289.0]], [[504.0, 129.0], [523.0, 129.0], [523.0, 255.0], [504.0, 255.0]]], "lines": ["捕まらなければ", "まぁいいや。"]}, {"box": [399, 127, 463, 357], "vertical": true, "font_size": 24, "lines_coords": [[[433.0, 131.0], [456.0, 131.0], [456.0, 356.0], [433.0, 356.0]], [[401.0, 128.0], [426.0, 128.0], [423.0, 254.0], [399.0, 254.0]]], "lines": ["ココロなんて無くても", "まぁいいや。"]}, {"box": [233, 120, 356, 418], "vertical": true, "font_size": 24, "lines_coords": [[[329.0, 123.0], [352.0, 123.0], [352.0, 418.0], [329.0, 418.0]], [[295.0, 121.0], [322.0, 121.0], [322.0, 351.0], [295.0, 351.0]], [[265.0, 123.0], [288.0, 123.0], [288.0, 283.0], [265.0, 283.0]], [[233.0, 121.0], [258.0, 121.0], [258.0, 243.0], [233.0, 243.0]]], "lines": ["とこかで戦争や災害が起きて", "たくさん人が死んでも", "自分が幸せなら", "まぁいいや。"]}, {"box": [773, 654, 860, 816], "vertical": true, "font_size": 24, "lines_coords": [[[836.0, 654.0], [859.0, 654.0], [859.0, 769.0], [836.0, 769.0]], [[803.0, 656.0], [827.0, 656.0], [827.0, 816.0], [803.0, 816.0]], [[773.0, 654.0], [797.0, 654.0], [797.0, 780.0], [773.0, 780.0]]], "lines": ["この会社は", "給料がいいから", "まぁいいや。"]}, {"box": [784, 911, 900, 1048], "vertical": true, "font_size": 22, "lines_coords": [[[879.0, 913.0], [898.0, 913.0], [898.0, 1026.0], [879.0, 1026.0]], [[846.0, 911.0], [869.0, 911.0], [869.0, 1048.0], [846.0, 1048.0]], [[813.0, 913.0], [838.0, 913.0], [838.0, 1007.0], [813.0, 1007.0]], [[784.0, 913.0], [803.0, 913.0], [803.0, 1025.0], [784.0, 1025.0]]], "lines": ["．．．と自分を", "言いきかせて", "あたしも", "２年目．．．"]}, {"box": [128, 898, 183, 1014], "vertical": true, "font_size": 23, "lines_coords": [[[158.0, 899.0], [181.0, 899.0], [181.0, 1000.0], [158.0, 1000.0]], [[128.0, 898.0], [151.0, 898.0], [151.0, 1014.0], [128.0, 1014.0]]], "lines": ["井上くん、", "ちょっと！"]}, {"box": [555, 1163, 674, 1346], "vertical": true, "font_size": 23, "lines_coords": [[[650.0, 1163.0], [674.0, 1163.0], [671.0, 1290.0], [648.0, 1290.0]], [[617.0, 1163.0], [641.0, 1163.0], [641.0, 1346.0], [617.0, 1346.0]], [[586.0, 1163.0], [609.0, 1163.0], [609.0, 1323.0], [586.0, 1323.0]], [[555.0, 1164.0], [578.0, 1164.0], [578.0, 1241.0], [555.0, 1241.0]]], "lines": ["でもほんと", "おもしろいように", "貯金はたまるん", "だよな"]}, {"box": [235, 1100, 289, 1240], "vertical": true, "font_size": 24, "lines_coords": [[[261.0, 1100.0], [289.0, 1100.0], [289.0, 1175.0], [261.0, 1175.0]], [[235.0, 1104.0], [254.0, 1104.0], [254.0, 1240.0], [235.0, 1240.0]]], "lines": ["前にも", "言っただろ！？"]}, {"box": [84, 1177, 203, 1315], "vertical": true, "font_size": 24, "lines_coords": [[[180.0, 1177.0], [203.0, 1177.0], [203.0, 1315.0], [180.0, 1315.0]], [[147.0, 1177.0], [172.0, 1177.0], [169.0, 1293.0], [144.0, 1293.0]], [[116.0, 1177.0], [139.0, 1177.0], [139.0, 1293.0], [116.0, 1293.0]], [[84.0, 1177.0], [108.0, 1177.0], [108.0, 1270.0], [84.0, 1270.0]]], "lines": ["書類を留める", "ホチキスは", "右上に２個", "だって！！"]}], "img_path": "015.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [783, 97, 872, 236], "vertical": true, "font_size": 24, "lines_coords": [[[849.0, 169.0], [872.0, 169.0], [872.0, 214.0], [849.0, 214.0]], [[847.0, 98.0], [872.0, 98.0], [872.0, 175.0], [847.0, 175.0]], [[816.0, 97.0], [839.0, 97.0], [839.0, 235.0], [816.0, 235.0]], [[786.0, 97.0], [809.0, 97.0], [806.0, 236.0], [783.0, 236.0]]], "lines": ["．．．", "うへー", "どうでもいい", "じゃんか．．．"]}, {"box": [308, 126, 364, 287], "vertical": true, "font_size": 24, "lines_coords": [[[340.0, 127.0], [363.0, 127.0], [363.0, 265.0], [340.0, 265.0]], [[308.0, 127.0], [332.0, 127.0], [332.0, 287.0], [308.0, 287.0]]], "lines": ["：オイ井上君", "聞いてるのか？"]}, {"box": [808, 369, 894, 553], "vertical": true, "font_size": 23, "lines_coords": [[[870.0, 369.0], [894.0, 369.0], [894.0, 535.0], [870.0, 535.0]], [[839.0, 369.0], [862.0, 369.0], [862.0, 553.0], [839.0, 553.0]], [[809.0, 370.0], [832.0, 370.0], [831.0, 531.0], [808.0, 531.0]]], "lines": ["そもそもアレだ。", "君は仕事に対する", "意欲ってのが．．"]}, {"box": [411, 360, 519, 591], "vertical": true, "font_size": 30, "lines_coords": [[[486.0, 366.0], [519.0, 366.0], [519.0, 591.0], [486.0, 591.0]], [[449.0, 369.0], [478.0, 369.0], [475.0, 563.0], [447.0, 563.0]], [[411.0, 369.0], [438.0, 369.0], [438.0, 571.0], [411.0, 571.0]]], "lines": ["．．．つーかコイツの", "鼻毛は規格外の", "伸びっぷりだな。"]}, {"box": [103, 473, 130, 591], "vertical": true, "font_size": 25, "lines_coords": [[[103.0, 474.0], [128.0, 474.0], [128.0, 590.0], [103.0, 590.0]]], "lines": ["．．．ほぁ？"]}, {"box": [769, 684, 876, 853], "vertical": true, "font_size": 28, "lines_coords": [[[849.0, 684.0], [876.0, 684.0], [876.0, 843.0], [849.0, 843.0]], [[812.0, 689.0], [836.0, 689.0], [836.0, 805.0], [812.0, 805.0]], [[769.0, 684.0], [802.0, 684.0], [802.0, 853.0], [769.0, 853.0]]], "lines": ["「ほぁ？」じゃ", "ないだろ、", "お前ーーッ！！"]}, {"box": [650, 839, 754, 1036], "vertical": true, "font_size": 28, "lines_coords": [[[727.0, 839.0], [754.0, 839.0], [754.0, 1034.0], [727.0, 1034.0]], [[689.0, 840.0], [716.0, 840.0], [713.0, 1007.0], [686.0, 1007.0]], [[650.0, 839.0], [678.0, 839.0], [678.0, 1036.0], [650.0, 1036.0]]], "lines": ["ふぬけた顔して", "反抗的な態度", "とりやがって！！"]}, {"box": [85, 782, 227, 1006], "vertical": true, "font_size": 27, "lines_coords": [[[198.0, 783.0], [226.0, 783.0], [226.0, 951.0], [198.0, 951.0]], [[161.0, 782.0], [188.0, 782.0], [185.0, 1006.0], [158.0, 1006.0]], [[121.0, 782.0], [150.0, 782.0], [146.0, 922.0], [117.0, 922.0]], [[86.0, 783.0], [109.0, 783.0], [109.0, 921.0], [86.0, 921.0]]], "lines": ["若いからって", "学生ノリが社会で", "通用すると", "思うなよ！！"]}, {"box": [793, 1106, 817, 1252], "vertical": true, "font_size": 19, "lines_coords": [[[794.0, 1107.0], [813.0, 1107.0], [813.0, 1246.0], [794.0, 1246.0]]], "lines": ["．．．ずびません"]}, {"box": [140, 1104, 171, 1256], "vertical": true, "font_size": 25, "lines_coords": [[[140.0, 1173.0], [165.0, 1173.0], [168.0, 1256.0], [143.0, 1256.0]]], "lines": ["あぁ、"]}], "img_path": "016.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [656, 103, 763, 337], "vertical": true, "font_size": 31, "lines_coords": [[[732.0, 106.0], [761.0, 106.0], [761.0, 329.0], [732.0, 329.0]], [[691.0, 103.0], [728.0, 103.0], [724.0, 337.0], [687.0, 337.0]], [[656.0, 106.0], [684.0, 106.0], [684.0, 231.0], [656.0, 231.0]]], "lines": ["．．．きっと社会人に", "向いてないのだよ、", "あたしは。"]}, {"box": [315, 155, 403, 303], "vertical": true, "font_size": 23, "lines_coords": [[[380.0, 155.0], [403.0, 155.0], [403.0, 295.0], [380.0, 295.0]], [[349.0, 158.0], [369.0, 158.0], [369.0, 293.0], [349.0, 293.0]], [[315.0, 157.0], [339.0, 157.0], [339.0, 303.0], [315.0, 303.0]]], "lines": ["入社した頃は", "これでも努力", "してみたんだ。"]}, {"box": [771, 499, 858, 663], "vertical": true, "font_size": 24, "lines_coords": [[[833.0, 500.0], [858.0, 500.0], [858.0, 571.0], [833.0, 571.0]], [[802.0, 499.0], [827.0, 499.0], [827.0, 591.0], [802.0, 591.0]], [[772.0, 499.0], [792.0, 499.0], [791.0, 663.0], [771.0, 663.0]]], "lines": ["１日中", "塀の中に", "閉じ込められて、"]}, {"box": [637, 582, 727, 734], "vertical": true, "font_size": 24, "lines_coords": [[[704.0, 585.0], [727.0, 585.0], [727.0, 734.0], [704.0, 734.0]], [[672.0, 583.0], [695.0, 583.0], [695.0, 723.0], [672.0, 723.0]], [[639.0, 582.0], [668.0, 583.0], [665.0, 665.0], [637.0, 664.0]]], "lines": ["毎日我慢大会", "してるよーな", "カンジ。"]}, {"box": [177, 277, 299, 462], "vertical": true, "font_size": 23, "lines_coords": [[[276.0, 277.0], [299.0, 277.0], [299.0, 440.0], [276.0, 440.0]], [[241.0, 277.0], [266.0, 277.0], [265.0, 462.0], [240.0, 462.0]], [[210.0, 278.0], [233.0, 278.0], [233.0, 437.0], [210.0, 437.0]], [[177.0, 277.0], [203.0, 277.0], [205.0, 358.0], [179.0, 358.0]]], "lines": ["でもどーしても", "仕事つまんないし", "みんなと馴染め", "ないの。"]}, {"box": [814, 787, 903, 977], "vertical": true, "font_size": 24, "lines_coords": [[[880.0, 788.0], [903.0, 788.0], [903.0, 925.0], [880.0, 925.0]], [[847.0, 787.0], [872.0, 787.0], [869.0, 903.0], [844.0, 903.0]], [[814.0, 787.0], [839.0, 787.0], [840.0, 977.0], [816.0, 977.0]]], "lines": ["１年も経てば", "頭おかしく", "なれるかなーって、"]}, {"box": [689, 851, 777, 991], "vertical": true, "font_size": 24, "lines_coords": [[[754.0, 851.0], [777.0, 851.0], [777.0, 991.0], [754.0, 991.0]], [[723.0, 853.0], [746.0, 853.0], [746.0, 969.0], [723.0, 969.0]], [[689.0, 851.0], [712.0, 851.0], [715.0, 978.0], [691.0, 978.0]]], "lines": ["思ってたけど", "案外ならな", "かったりで。"]}, {"box": [375, 836, 438, 933], "vertical": true, "font_size": 31, "lines_coords": [[[408.0, 838.0], [438.0, 838.0], [438.0, 905.0], [408.0, 905.0]], [[375.0, 836.0], [407.0, 836.0], [407.0, 903.0], [375.0, 903.0]]], "lines": ["．．．ねー", "平八"]}, {"box": [80, 859, 217, 1066], "vertical": true, "font_size": 24, "lines_coords": [[[185.0, 859.0], [214.0, 859.0], [217.0, 957.0], [188.0, 957.0]], [[164.0, 861.0], [187.0, 861.0], [187.0, 1003.0], [164.0, 1003.0]], [[136.0, 861.0], [159.0, 861.0], [159.0, 1004.0], [136.0, 1004.0]], [[110.0, 859.0], [133.0, 859.0], [131.0, 1010.0], [108.0, 1010.0]], [[83.0, 859.0], [106.0, 859.0], [103.0, 1063.0], [80.0, 1063.0]]], "lines": ["とにかく", "平八と過ごす", "この昼休みが、", "仕事中唯一の", "癒やしダイムなのよ。"]}, {"box": [561, 1142, 648, 1282], "vertical": true, "font_size": 23, "lines_coords": [[[623.0, 1142.0], [648.0, 1142.0], [645.0, 1264.0], [620.0, 1264.0]], [[591.0, 1144.0], [615.0, 1144.0], [615.0, 1282.0], [591.0, 1282.0]], [[563.0, 1145.0], [582.0, 1145.0], [582.0, 1266.0], [563.0, 1266.0]]], "lines": ["．．．いやーん", "なんかこの話", "超重たーい。"]}], "img_path": "017.png"}, {"version": "0.2.0-beta.6", "img_width": 968, "img_height": 1400, "blocks": [{"box": [771, 220, 821, 501], "vertical": true, "font_size": 24, "lines_coords": [[[771.0, 466.0], [787.0, 466.0], [787.0, 501.0], [771.0, 501.0]], [[792.0, 220.0], [821.0, 220.0], [821.0, 315.0], [792.0, 315.0]]], "lines": ["．．．", "あっ．．．"]}, {"box": [767, 388, 854, 505], "vertical": true, "font_size": 24, "lines_coords": [[[829.0, 391.0], [854.0, 391.0], [854.0, 505.0], [829.0, 505.0]], [[798.0, 388.0], [823.0, 388.0], [821.0, 489.0], [797.0, 489.0]], [[767.0, 389.0], [791.0, 389.0], [791.0, 459.0], [767.0, 459.0]]], "lines": ["オーーーッ．．．", "恋人かい、", "平八"]}, {"box": [71, 274, 223, 504], "vertical": true, "font_size": 23, "lines_coords": [[[199.0, 277.0], [218.0, 277.0], [218.0, 416.0], [199.0, 416.0]], [[164.0, 274.0], [191.0, 274.0], [191.0, 482.0], [164.0, 482.0]], [[133.0, 276.0], [157.0, 276.0], [157.0, 396.0], [133.0, 396.0]], [[102.0, 276.0], [125.0, 276.0], [125.0, 504.0], [102.0, 504.0]], [[71.0, 276.0], [94.0, 276.0], [94.0, 488.0], [71.0, 488.0]]], "lines": ["：そういえば", "私と種田が付き合い", "だした頃は、", "こんな年のとり方する", "なんて思わなかった。"]}, {"box": [667, 620, 791, 807], "vertical": true, "font_size": 28, "lines_coords": [[[753.0, 622.0], [787.0, 620.0], [791.0, 719.0], [757.0, 720.0]], [[728.0, 623.0], [756.0, 623.0], [753.0, 806.0], [726.0, 806.0]], [[697.0, 622.0], [724.0, 622.0], [724.0, 762.0], [697.0, 762.0]], [[667.0, 624.0], [690.0, 624.0], [690.0, 741.0], [667.0, 741.0]]], "lines": ["それぞれ", "はるか北と南から", "上京してきた", "私と種田は"]}, {"box": [717, 866, 839, 1074], "vertical": true, "font_size": 25, "lines_coords": [[[814.0, 868.0], [839.0, 868.0], [839.0, 959.0], [814.0, 959.0]], [[780.0, 866.0], [808.0, 866.0], [808.0, 1030.0], [780.0, 1030.0]], [[750.0, 869.0], [773.0, 869.0], [773.0, 1074.0], [750.0, 1074.0]], [[717.0, 866.0], [741.0, 866.0], [741.0, 948.0], [717.0, 948.0]]], "lines": ["心細くて", "不安だったけど", "なんだかわくわくも", "あってー"]}, {"box": [449, 622, 575, 783], "vertical": true, "font_size": 25, "lines_coords": [[[548.0, 623.0], [572.0, 623.0], [574.0, 783.0], [549.0, 783.0]], [[518.0, 624.0], [541.0, 624.0], [541.0, 783.0], [518.0, 783.0]], [[484.0, 624.0], [508.0, 624.0], [508.0, 716.0], [484.0, 716.0]], [[449.0, 623.0], [477.0, 623.0], [481.0, 766.0], [453.0, 766.0]]], "lines": ["東京の圧倒的な", "密度と複雑さに", "右も左も", "わからなくて、"]}, {"box": [214, 619, 370, 828], "vertical": true, "font_size": 28, "lines_coords": [[[344.0, 623.0], [367.0, 623.0], [367.0, 782.0], [344.0, 782.0]], [[307.0, 620.0], [341.0, 620.0], [341.0, 697.0], [307.0, 697.0]], [[280.0, 623.0], [304.0, 623.0], [304.0, 739.0], [280.0, 739.0]], [[247.0, 622.0], [274.0, 622.0], [274.0, 828.0], [247.0, 828.0]], [[214.0, 619.0], [244.0, 619.0], [244.0, 701.0], [214.0, 701.0]]], "lines": ["どこか知らない", "惑星に", "２人きりで", "やって来てしまった", "感覚で、"]}, {"box": [129, 1085, 249, 1270], "vertical": true, "font_size": 23, "lines_coords": [[[225.0, 1108.0], [248.0, 1108.0], [248.0, 1225.0], [225.0, 1225.0]], [[195.0, 1088.0], [214.0, 1088.0], [214.0, 1223.0], [195.0, 1223.0]], [[159.0, 1085.0], [184.0, 1085.0], [185.0, 1270.0], [161.0, 1270.0]], [[129.0, 1086.0], [153.0, 1086.0], [153.0, 1189.0], [129.0, 1189.0]]], "lines": ["ーとにかく", "あの頃の空は", "なんだかすっごく", "広かった。"]}], "img_path": "018.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [738, 203, 832, 343], "vertical": true, "font_size": 26, "lines_coords": [[[808.0, 209.0], [831.0, 209.0], [831.0, 343.0], [808.0, 343.0]], [[776.0, 206.0], [801.0, 206.0], [797.0, 322.0], [772.0, 322.0]], [[738.0, 205.0], [769.0, 203.0], [772.0, 266.0], [741.0, 267.0]]], "lines": ["今、あたしの", "上に広がる", "空は、"]}, {"box": [441, 546, 534, 675], "vertical": true, "font_size": 34, "lines_coords": [[[499.0, 548.0], [534.0, 548.0], [534.0, 611.0], [499.0, 611.0]], [[464.0, 546.0], [507.0, 546.0], [507.0, 615.0], [464.0, 615.0]], [[441.0, 550.0], [464.0, 550.0], [464.0, 672.0], [441.0, 672.0]]], "lines": ["低く、", "狭く、", "そして重い。"]}, {"box": [445, 892, 533, 1084], "vertical": true, "font_size": 25, "lines_coords": [[[508.0, 892.0], [533.0, 892.0], [533.0, 987.0], [508.0, 987.0]], [[475.0, 892.0], [503.0, 892.0], [500.0, 1054.0], [473.0, 1054.0]], [[445.0, 892.0], [468.0, 892.0], [468.0, 1082.0], [445.0, 1082.0]]], "lines": ["自分には", "もっと違う道が", "あるんじゃないか、"]}, {"box": [676, 1022, 766, 1160], "vertical": true, "font_size": 26, "lines_coords": [[[738.0, 1024.0], [766.0, 1024.0], [766.0, 1118.0], [738.0, 1118.0]], [[706.0, 1022.0], [734.0, 1022.0], [734.0, 1160.0], [706.0, 1160.0]], [[676.0, 1024.0], [699.0, 1024.0], [699.0, 1126.0], [676.0, 1126.0]]], "lines": ["東京には", "魔物が潜んで", "おります。"]}, {"box": [79, 1153, 232, 1339], "vertical": true, "font_size": 25, "lines_coords": [[[205.0, 1153.0], [232.0, 1153.0], [232.0, 1317.0], [205.0, 1317.0]], [[174.0, 1155.0], [199.0, 1155.0], [199.0, 1271.0], [174.0, 1271.0]], [[143.0, 1155.0], [166.0, 1155.0], [166.0, 1339.0], [143.0, 1339.0]], [[112.0, 1156.0], [135.0, 1156.0], [135.0, 1315.0], [112.0, 1315.0]], [[79.0, 1155.0], [108.0, 1155.0], [108.0, 1231.0], [79.0, 1231.0]]], "lines": ["もっといろんな", "チャンスが", "この街のどこかに", "眠ってるんじゃ", "ないか"]}], "img_path": "019.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [775, 88, 898, 425], "vertical": true, "font_size": 24, "lines_coords": [[[873.0, 88.0], [898.0, 88.0], [896.0, 308.0], [872.0, 308.0]], [[840.0, 88.0], [865.0, 88.0], [866.0, 229.0], [842.0, 229.0]], [[810.0, 90.0], [833.0, 90.0], [833.0, 296.0], [810.0, 296.0]], [[775.0, 88.0], [802.0, 88.0], [802.0, 425.0], [775.0, 425.0]]], "lines": ["「人生のレールなんて", "外れちゃって", "自由になっちゃえば", "いいじゃん」という、黒い囁きが"]}, {"box": [425, 91, 512, 252], "vertical": true, "font_size": 22, "lines_coords": [[[488.0, 91.0], [512.0, 91.0], [509.0, 252.0], [485.0, 252.0]], [[458.0, 94.0], [477.0, 94.0], [477.0, 252.0], [458.0, 252.0]], [[425.0, 92.0], [448.0, 92.0], [448.0, 217.0], [425.0, 217.0]]], "lines": ["でも、あいにく", "あたしにそんな", "勇気無くて、"]}, {"box": [321, 158, 408, 344], "vertical": true, "font_size": 22, "lines_coords": [[[385.0, 158.0], [408.0, 158.0], [407.0, 319.0], [384.0, 319.0]], [[354.0, 158.0], [377.0, 158.0], [377.0, 344.0], [354.0, 344.0]], [[321.0, 158.0], [344.0, 158.0], [347.0, 262.0], [324.0, 262.0]]], "lines": ["特に才能も無い", "という自覚もある", "年なのさ。"]}, {"box": [99, 42, 225, 75], "vertical": false, "font_size": 28, "lines_coords": [[[99.0, 47.0], [224.0, 42.0], [225.0, 69.0], [101.0, 75.0]]], "lines": ["ソラニンの"]}, {"box": [88, 276, 149, 396], "vertical": true, "font_size": 26, "lines_coords": [[[110.0, 276.0], [149.0, 276.0], [149.0, 334.0], [110.0, 334.0]], [[88.0, 280.0], [113.0, 280.0], [113.0, 396.0], [88.0, 396.0]]], "lines": ["多少", "辛くても．．．"]}, {"box": [715, 310, 769, 503], "vertical": true, "font_size": 24, "lines_coords": [[[746.0, 310.0], [769.0, 310.0], [769.0, 426.0], [746.0, 426.0]], [[715.0, 311.0], [738.0, 311.0], [738.0, 503.0], [715.0, 503.0]]], "lines": ["どこからか", "聞こえてくるんだ。"]}, {"box": [146, 452, 199, 568], "vertical": true, "font_size": 26, "lines_coords": [[[176.0, 452.0], [199.0, 452.0], [199.0, 567.0], [176.0, 567.0]], [[146.0, 452.0], [165.0, 452.0], [165.0, 568.0], [146.0, 568.0]]], "lines": ["つつましく", "生きるため、"]}, {"box": [750, 918, 772, 1011], "vertical": true, "font_size": 21, "lines_coords": [[[750.0, 946.0], [771.0, 946.0], [771.0, 1011.0], [750.0, 1011.0]]], "lines": ["．．．ん？"]}, {"box": [254, 658, 311, 807], "vertical": true, "font_size": 25, "lines_coords": [[[277.0, 660.0], [307.0, 658.0], [311.0, 732.0], [281.0, 734.0]], [[255.0, 663.0], [274.0, 663.0], [274.0, 806.0], [255.0, 806.0]]], "lines": ["．．．．．．", "頑張らなきゃ。"]}, {"box": [200, 921, 416, 1101], "vertical": false, "font_size": 39.75, "lines_coords": [[[228.0, 921.0], [416.0, 951.0], [411.0, 985.0], [222.0, 955.0]], [[225.0, 955.0], [318.0, 970.0], [313.0, 1010.0], [220.0, 995.0]], [[217.0, 988.0], [367.0, 1011.0], [362.0, 1050.0], [211.0, 1026.0]], [[210.0, 1025.0], [369.0, 1056.0], [359.0, 1101.0], [200.0, 1070.0]]], "lines": ["さっきはどなったりして", "どういうことでどめん。わたが", "おおびに今晩", "食事とかどう？"]}], "img_path": "020.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [664, 75, 756, 370], "vertical": true, "font_size": 36, "lines_coords": [[[720.0, 79.0], [754.0, 79.0], [754.0, 185.0], [720.0, 185.0]], [[664.0, 77.0], [701.0, 77.0], [705.0, 370.0], [668.0, 370.0]]], "lines": ["やっぱ", "もう無理ーーっ！！"]}, {"box": [684, 954, 794, 1107], "vertical": true, "font_size": 29, "lines_coords": [[[765.0, 957.0], [794.0, 957.0], [794.0, 1066.0], [765.0, 1066.0]], [[725.0, 955.0], [754.0, 955.0], [754.0, 1069.0], [725.0, 1069.0]], [[687.0, 954.0], [716.0, 954.0], [713.0, 1107.0], [684.0, 1107.0]]], "lines": ["超気分が", "悪いんで", "早退します。"]}, {"box": [358, 705, 386, 829], "vertical": true, "font_size": 28, "lines_coords": [[[358.0, 706.0], [386.0, 706.0], [386.0, 829.0], [358.0, 829.0]]], "lines": ["．．．部長。"]}, {"box": [462, 1055, 518, 1115], "vertical": true, "font_size": 22.5, "lines_coords": [[[497.0, 1055.0], [518.0, 1055.0], [518.0, 1099.0], [497.0, 1099.0]], [[462.0, 1060.0], [486.0, 1060.0], [486.0, 1115.0], [462.0, 1115.0]]], "lines": ["タン", "タタン"]}, {"box": [158, 1049, 206, 1120], "vertical": true, "font_size": 26, "lines_coords": [[[180.0, 1050.0], [206.0, 1050.0], [206.0, 1106.0], [180.0, 1106.0]]], "lines": ["タタン"]}], "img_path": "021.png"}, {"version": "0.2.0-beta.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [793, 123, 846, 236], "vertical": true, "font_size": 25, "lines_coords": [[[818.0, 123.0], [843.0, 123.0], [846.0, 236.0], [821.0, 236.0]]], "lines": ["ただいまぁ"]}, {"box": [576, 125, 671, 289], "vertical": true, "font_size": 26, "lines_coords": [[[638.0, 125.0], [671.0, 125.0], [671.0, 180.0], [638.0, 180.0]], [[612.0, 129.0], [635.0, 129.0], [635.0, 289.0], [612.0, 289.0]], [[579.0, 127.0], [604.0, 127.0], [601.0, 246.0], [576.0, 246.0]]], "lines": ["会社", "早退しちゃった", "よーーん．．．"]}, {"box": [464, 217, 523, 333], "vertical": true, "font_size": 26, "lines_coords": [[[500.0, 217.0], [523.0, 217.0], [523.0, 333.0], [500.0, 333.0]], [[467.0, 217.0], [492.0, 217.0], [489.0, 333.0], [464.0, 333.0]]], "lines": ["．．．ってまだ", "寝てんし！！"]}, {"box": [95, 54, 209, 80], "vertical": false, "font_size": 23, "lines_coords": [[[95.0, 54.0], [209.0, 57.0], [209.0, 80.0], [95.0, 77.0]]], "lines": ["ノラニンの"]}, {"box": [641, 692, 663, 815], "vertical": true, "font_size": 19, "lines_coords": [[[642.0, 693.0], [661.0, 693.0], [661.0, 814.0], [642.0, 814.0]]], "lines": ["：ねぇ種田。"]}, {"box": [232, 702, 324, 841], "vertical": true, "font_size": 24, "lines_coords": [[[299.0, 705.0], [322.0, 705.0], [322.0, 820.0], [299.0, 820.0]], [[269.0, 706.0]