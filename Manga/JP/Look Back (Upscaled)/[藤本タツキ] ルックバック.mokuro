1054.0, 787.0]]], "lines": ["ＡＣ入試"]}], "img_path": "00106.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [841, 138, 1324, 269], "vertical": false, "font_size": 131, "lines_coords": [[[841.0, 138.0], [1324.0, 138.0], [1324.0, 269.0], [841.0, 269.0]]], "lines": ["合格通知書"]}, {"box": [747, 403, 1453, 616], "vertical": false, "font_size": 63.333333333333336, "lines_coords": [[[747.0, 405.0], [1431.0, 403.0], [1431.0, 459.0], [747.0, 461.0]], [[756.0, 473.0], [1453.0, 473.0], [1453.0, 543.0], [756.0, 543.0]], [[756.0, 550.0], [1441.0, 553.0], [1441.0, 616.0], [756.0, 614.0]]], "lines": ["とは、２０１２年度ＡＯ入学試験は", "今、合格と判定しましたので通知", "との所属学科、コースは下記の"]}], "img_path": "00107.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [480, 1244, 1476, 1328], "vertical": false, "font_size": 80, "lines_coords": [[[480.0, 1244.0], [1476.0, 1249.0], [1476.0, 1328.0], [480.0, 1324.0]]], "lines": ["２０１６年４月１０日今４時１ヶ月"]}], "img_path": "00108.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [77, 750, 1331, 895], "vertical": false, "font_size": 71.0, "lines_coords": [[[77.0, 754.0], [860.0, 750.0], [860.0, 822.0], [77.0, 827.0]], [[79.0, 825.0], [1331.0, 825.0], [1331.0, 895.0], [79.0, 895.0]]], "lines": ["美術科洋画コース様２階にて記事について、", "設置してあるソファに在学生が休憩目的で座る"]}, {"box": [49, 1666, 1363, 1818], "vertical": false, "font_size": 80.0, "lines_coords": [[[51.0, 1666.0], [1363.0, 1666.0], [1363.0, 1746.0], [51.0, 1746.0]], [[49.0, 1729.0], [1258.0, 1739.0], [1258.0, 1818.0], [49.0, 1809.0]]], "lines": ["在学生が階段から金属がぶつの時、コースロンになるつかるような音を聞く当先はハホホームに", "この時ソファの近出演がハンダーメージしてくに他の学生はいなかった"]}], "img_path": "00109.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [799, 257, 874, 1975], "vertical": true, "font_size": 72, "lines_coords": [[[799.0, 257.0], [871.0, 257.0], [874.0, 1975.0], [801.0, 1975.0]]], "lines": ["１１時１９分が外階段から棟内個人休憩中の在学生と接触する"]}], "img_path": "00110.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [1085, 398, 1342, 548], "vertical": true, "font_size": 55, "lines_coords": [[[1291.0, 405.0], [1342.0, 405.0], [1342.0, 482.0], [1291.0, 482.0]], [[1246.0, 400.0], [1300.0, 400.0], [1300.0, 513.0], [1246.0, 513.0]], [[1204.0, 398.0], [1265.0, 398.0], [1265.0, 510.0], [1204.0, 510.0]], [[1108.0, 438.0], [1169.0, 435.0], [1174.0, 546.0], [1113.0, 548.0]], [[1085.0, 442.0], [1131.0, 442.0], [1131.0, 517.0], [1085.0, 517.0]]], "lines": ["ねえ", "キミさ", "お前っ", "オマエ", "さあ"]}, {"box": [67, 157, 1314, 210], "vertical": false, "font_size": 49, "lines_coords": [[[67.0, 157.0], [1314.0, 161.0], [1314.0, 210.0], [67.0, 206.0]]], "lines": ["手には実習棟で拾った先端２の鋭利な工具を持っていた"]}, {"box": [464, 405, 694, 697], "vertical": true, "font_size": 46, "lines_coords": [[[639.0, 405.0], [686.0, 405.0], [691.0, 693.0], [644.0, 693.0]], [[583.0, 407.0], [623.0, 407.0], [623.0, 689.0], [583.0, 689.0]], [[522.0, 410.0], [571.0, 410.0], [571.0, 691.0], [522.0, 691.0]], [[464.0, 405.0], [510.0, 405.0], [510.0, 644.0], [464.0, 644.0]]], "lines": ["俺のネットに", "あけてた絵！", "パクったのが", "あったろ！？"]}, {"box": [815, 656, 939, 775], "vertical": true, "font_size": 63, "lines_coords": [[[867.0, 656.0], [939.0, 656.0], [939.0, 775.0], [867.0, 775.0]], [[815.0, 660.0], [869.0, 660.0], [869.0, 771.0], [815.0, 771.0]]], "lines": ["え？", "え？"]}, {"box": [784, 916, 1019, 1183], "vertical": true, "font_size": 39, "lines_coords": [[[979.0, 918.0], [1019.0, 918.0], [1019.0, 1050.0], [979.0, 1050.0]], [[939.0, 916.0], [981.0, 916.0], [981.0, 1050.0], [939.0, 1050.0]], [[902.0, 916.0], [942.0, 916.0], [942.0, 1047.0], [902.0, 1047.0]], [[867.0, 918.0], [899.0, 918.0], [899.0, 1078.0], [867.0, 1078.0]], [[829.0, 921.0], [862.0, 921.0], [862.0, 1078.0], [829.0, 1078.0]], [[789.0, 1075.0], [834.0, 1075.0], [834.0, 1183.0], [789.0, 1183.0]]], "lines": ["この間の", "展示っ．．．", "俺の絵に", "似たのっ．．", "あったろ？", "あ？"]}, {"box": [614, 991, 663, 1129], "vertical": true, "font_size": 