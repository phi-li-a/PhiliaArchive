: 1528, "img_height": 2400, "blocks": [{"box": [288, 302, 963, 379], "vertical": false, "font_size": 54, "lines_coords": [[[288.0, 325.0], [960.0, 302.0], [963.0, 356.0], [290.0, 379.0]]], "lines": ["『シャークキック』体験のお知らせ"]}, {"box": [276, 616, 1003, 902], "vertical": false, "font_size": 45, "lines_coords": [[[276.0, 632.0], [1003.0, 616.0], [1003.0, 658.0], [276.0, 675.0]], [[358.0, 742.0], [892.0, 735.0], [892.0, 782.0], [358.0, 789.0]], [[435.0, 684.0], [808.0, 679.0], [808.0, 721.0], [435.0, 726.0]], [[360.0, 799.0], [897.0, 792.0], [897.0, 839.0], [360.0, 846.0]], [[426.0, 855.0], [808.0, 853.0], [808.0, 900.0], [426.0, 902.0]]], "lines": ["いつも「シャークキック」をご愛読いいただきまして", "作者の族野キョウ先生が急病のため、", "ありがとうございます。", "「シャークキック」は、しばらくのあいだ", "体験させていいただきます。"]}, {"box": [431, 1031, 808, 1078], "vertical": false, "font_size": 47, "lines_coords": [[[431.0, 1031.0], [808.0, 1031.0], [808.0, 1078.0], [431.0, 1078.0]]], "lines": ["連載再開につきましては、"]}, {"box": [278, 1087, 996, 1134], "vertical": false, "font_size": 42, "lines_coords": [[[278.0, 1092.0], [996.0, 1087.0], [996.0, 1129.0], [278.0, 1134.0]]], "lines": ["藤野先生の体調のご快復を待つてのことになります。"]}, {"box": [276, 1270, 1003, 1359], "vertical": false, "font_size": 33.0, "lines_coords": [[[292.0, 1270.0], [991.0, 1270.0], [991.0, 1303.0], [292.0, 1303.0]], [[276.0, 1321.0], [1003.0, 1326.0], [1003.0, 1359.0], [276.0, 1354.0]]], "lines": ["「シャークキック」を楽しみにいただいている読者の", "皆様にはご心配おかけしますが、引き続き応援のほど"]}, {"box": [414, 1380, 820, 1403], "vertical": false, "font_size": 23, "lines_coords": [[[414.0, 1380.0], [820.0, 1380.0], [820.0, 1403.0], [414.0, 1403.0]]], "lines": ["トストレンセン商品、はい、んじゃねー"]}], "img_path": "00089.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [], "img_path": "00090.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [], "img_path": "00091.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [], "img_path": "00092.webp"}, {"version": "0.2.1", "img_width": 1528, "img_h