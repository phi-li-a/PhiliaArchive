68, 997, 755, 1139], "vertical": false, "font_size": 27, "lines_coords": [[[555.0, 1005.0], [747.0, 1000.0], [747.0, 1026.0], [555.0, 1031.0]], [[550.0, 1028.0], [749.0, 1021.0], [749.0, 1045.0], [550.0, 1052.0]], [[546.0, 1050.0], [733.0, 1042.0], [733.0, 1066.0], [546.0, 1073.0]], [[541.0, 1073.0], [733.0, 1064.0], [733.0, 1087.0], [541.0, 1096.0]], [[468.0, 1101.0], [733.0, 1080.0], [735.0, 1117.0], [471.0, 1139.0]]], "lines": ["断やキャラクターに悪さは", "感じるか、それでも１３００の", "クオリティではないこの", "ぷぷいろんな作品にふれて", "どんどん体感していってほしいです。"]}, {"box": [717, 846, 946, 902], "vertical": false, "font_size": 47, "lines_coords": [[[719.0, 846.0], [946.0, 855.0], [944.0, 902.0], [717.0, 892.0]]], "lines": ["藤野キョウ（１３）"]}, {"box": [632, 897, 1189, 1057], "vertical": false, "font_size": 75, "lines_coords": [[[638.0, 891.0], [1143.0, 929.0], [1136.0, 1015.0], [631.0, 977.0]], [[809.0, 969.0], [855.0, 992.0], [824.0, 1062.0], [779.0, 1038.0]]], "lines": ["これからも、コントロー画面が発売されているのですが、それ以外のブログによって、", "ああの．．．"]}, {"box": [904, 1021, 1204, 1171], "vertical": false, "font_size": 48, "lines_coords": [[[997.0, 1017.0], [1197.0, 1055.0], [1190.0, 1097.0], [990.0, 1060.0]], [[1002.0, 1038.0], [1122.0, 1064.0], [1115.0, 1097.0], [995.0, 1071.0]], [[987.0, 1043.0], [1160.0, 1083.0], [1143.0, 1160.0], [971.0, 1120.0]], [[910.0, 1083.0], [1160.0, 1128.0], [1153.0, 1174.0], [903.0, 1130.0]]], "lines": ["中学生とは思えない圧倒的なセンスでした！机に制服の．．．", "中学生とは思えないなセンスでした！特に判察のレベル", "中学生とは思えない圧倒なセンスでした！机に可愛のレベルが高かったです！！お話を助けてほしいです」", "このまま気がつたです。この武器を使わずにはしいです」"]}, {"box": [255, 1346, 394, 1434], "vertical": false, "font_size": 31, "lines_coords": [[[257.0, 1347.0], [377.0, 1347.0], [377.0, 1380.0], [257.0, 1380.0]], [[255.0, 1375.0], [393.0, 1375.0], [393.0, 1408.0], [255.0, 1408.0]], [[257.0, 1408.0], [365.0, 1408.0], [365.0, 1434.0], [257.0, 1434.0]]], "lines": ["八組織の", "食バンチは", "受付中！！"]}, {"box": [935, 1875, 1525, 2022], "vertical": false, "font_size": 82, "lines_coords": [[[944.0, 1875.0], [1525.0, 1940.0], [1516.0, 2022.0], [935.0, 1957.0]]], "lines": ["藤野キョウ（１３"]}, {"box": [921, 2085, 1434, 2189], "vertical": false, "font_size": 42.5, "lines_coords": [[[923.0, 2085.0], [1434.0, 2114.0], [1431.0, 2158.0], [921.0, 2130.0]], [[925.0, 2137.0], [1202.0, 2149.0], [1199.0, 2189.0], [923.0, 2177.0]]], "lines": ["来た旅異の中学生コンビ！", "てほしいです！"]}], "img_path": "00058.webp"}, {"version": "0.2.1", "img_width": 1528, "img_height": 2400, "blocks": [{"box": [740, 117, 974, 375], "vertical": true, "font_size": 52, "lines_coords": [[[923.0, 117.0], [974.0, 117.0], [974.0, 260.0], [923.0, 260.0]], [[853.0, 152.0], [895.0, 152.0], [895.0, 375.0], [853.0, 375.0]], [[780.0, 145.0], [853.0, 145.0], [853.0, 255.0], [780.0, 255.0]], [[740.0, 152.0], [782.0, 152.0], [782.0, 328.0], [740.0, 328.0]]], "lines": ["じゃん", "お母さんと", "通帳", "作った！"]}, {"box": [731, 473, 824, 667], "vertical": true, "font_size": 48, "lines_coords": [[[768.0, 473.0], [824.0, 473.0], [824.0, 564.0], [768.0, 564.0]], [[731.0, 478.0], [771.0, 478.0], [771.0, 667.0], [731.0, 667.0]]], "lines": ["私も", "作ったよ！"]}, {"box": [227, 128, 330, 358], "vertical": true, "font_size": 46, "lines_coords": [[[276.0, 128.0], [325.0, 128.0], [330.0, 358.0], [281.0, 358.0]], [[227.0, 133.0], [269.0, 133.0], [269.0, 314.0], [227.0, 314.0]]], "lines": ["でねでね！", "なんと．．．"]}, {"box": [128, 977, 332, 1507], "vertical": true, "font_size": 59, "lines_coords": [[[271.0, 977.0], [332.0, 979.0], [325.0, 1143.0], [264.0, 1141.0]], [[253.0, 1143.0], [321.0, 1143.0], [321.0, 1310.0], [253.0, 1310.0]], [[194.0, 1192.0], [250.0, 1192.0], [250.0, 1408.0], [194.0, 1408.0]], [[133.0, 1190.0], [185.0, 1190.0], [180.0, 1507.0], [128.0, 1507.0]]], "lines": ["じゃん", "１０万", "下ろして", "来ちゃった！！"]}, {"box": [874, 1795, 1021, 1933], "vertical": true, "font_size": 76, "lines_coords": [[[942.0, 1797.0], [1021.0, 1797.0], [1021.0, 1933.0], [942.0, 1933.0]], [[874.0, 1795.0], [946.0, 1795.0], [946.0, 1931.0], [874.0, 1931.0]]], "lines": ["ええ", "～！？"]}, {"box": [236, 1788, 374, 1982], "vertical": true, "font_si