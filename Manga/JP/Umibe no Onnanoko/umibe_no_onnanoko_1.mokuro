1787.0], [1288.0, 1787.0], [1288.0, 1852.0], [1271.0, 1852.0]]], "lines": ["１０２"]}], "img_path": "107.png"}, {"version": "0.2.0-beta.6", "img_width": 1360, "img_height": 2000, "blocks": [{"box": [765, 111, 810, 181], "vertical": true, "font_size": 41, "lines_coords": [[[765.0, 111.0], [810.0, 111.0], [810.0, 181.0], [765.0, 181.0]]], "lines": ["カタ"]}, {"box": [719, 208, 756, 275], "vertical": true, "font_size": 41, "lines_coords": [[[719.0, 208.0], [756.0, 208.0], [756.0, 275.0], [719.0, 275.0]]], "lines": ["カタ"]}, {"box": [50, 132, 95, 317], "vertical": true, "font_size": 41, "lines_coords": [[[50.0, 132.0], [91.0, 132.0], [91.0, 314.0], [50.0, 314.0]]], "lines": ["第６話"]}, {"box": [142, 431, 224, 603], "vertical": true, "font_size": 39, "lines_coords": [[[185.0, 431.0], [224.0, 431.0], [224.0, 496.0], [185.0, 496.0]], [[146.0, 533.0], [185.0, 535.0], [181.0, 603.0], [142.0, 601.0]]], "lines": ["カタ", "カタ"]}, {"box": [1170, 1011, 1203, 1128], "vertical": true, "font_size": 33, "lines_coords": [[[1170.0, 1011.0], [1203.0, 1011.0], [1203.0, 1128.0], [1170.0, 1128.0]]], "lines": ["カタカタ"]}, {"box": [1078, 1351, 1117, 1419], "vertical": true, "font_size": 36, "lines_coords": [[[1078.0, 1351.0], [1117.0, 1351.0], [1117.0, 1419.0], [1078.0, 1419.0]]], "lines": ["カタ"]}, {"box": [1037, 1453, 1070, 1517], "vertical": true, "font_size": 36, "lines_coords": [[[1037.0, 1453.0], [1070.0, 1453.0], [1070.0, 1517.0], [1037.0, 1517.0]]], "lines": ["カタ"]}, {"box": [473, 963, 893, 1043], "vertical": false, "font_size": 88, "lines_coords": [[[473.0, 955.0], [893.0, 955.0], [893.0, 1051.0], [473.0, 1051.0]]], "lines": ["ＳＤのアニメシロケートの先生も"]}, {"box": [463, 1044, 709, 1066], "vertical": false, "font_size": 20, "lines_coords": [[[463.0, 1044.0], [709.0, 1046.0], [709.0, 1066.0], [463.0, 1064.0]]], "lines": ["人見知りが結婚相手の心が気になる猛暑とお湯に"]}, {"box": [467, 1068, 603, 1082], "vertical": false, "font_size": 14, "lines_coords": [[[467.0, 1068.0], [603.0, 1068.0], [603.0, 1082.0], [467.0, 1082.0]]], "lines": ["教室ホーグシャンプーびっくり投資してみました。"]}, {"box": [467, 1103, 678, 1140], "vertical": false, "font_size": 14.0, "lines_coords": [[[467.0, 1103.0], [678.0, 1103.0], [678.0, 1117.0], [467.0, 1117.0]], [[467.0, 1126.0], [535.0, 1126.0], [535.0, 1140.0], [467.0, 1140.0]]], "lines": ["あれだった．．．。人類のように解釈を教えてくれるね参加者たちの先の声を探して", "おはようサンセット"]}, {"box": [459, 1271, 702, 1324], "vertical": false, "font_size": 22, "lines_coords": [[[465.0, 1275.0], [599.0, 1275.0], [599.0, 1289.0], [465.0, 1289.0]], [[465.0, 1306.0], [535.0, 1308.0], [535.0, 1324.0], [465.0, 1322.0]], [[607.0, 1271.0], [697.0, 1271.0], [697.0, 1306.0], [607.0, 1306.0]]], "lines": ["第五話ラストで突如現れた転校生は", "まんま何じゃんけ？", "はりヒナちゃんでしたね私１氏の十八番というか。"]}, {"box": [550, 1388, 755, 1415], "vertical": false, "font_size": 29, "lines_coords": [[[550.0, 1386.0], [755.0, 1386.0], [755.0, 1417.0], [550.0, 1417.0]]], "lines": ["おはようサンセットにしていただいたいと思いますので、"]}, {"box": [459, 1337, 676, 1376], "vertical": false, "font_size": 42, "lines_coords": [[[459.0, 1334.0], [670.0, 1334.0], [670.0, 1379.0], [459.0, 1379.0]]], "lines": ["その後は、その時はやってみました。それはそう嫌いなのかなと言えません。大丈夫だった。"]}, {"box": [209, 1093, 269, 1278], "vertical": true, "font_size": 37, "lines_coords": [[[224.0, 1093.0], [269.0, 1093.0], [269.0, 1162.0], [224.0, 1162.0]], [[209.0, 1214.0], [238.0, 1214.0], [238.0, 1275.0], [209.0, 1275.0]]], "lines": ["カタ", "カタ"]}, {"box": [132, 1097, 160, 1287], "vertical": true, "font_size": 28, "lines_coords": [[[132.0, 1097.0], [160.0, 1097.0], [160.0, 1287.0], [132.0, 1287.0]]], "lines": ["日曜午前火．．．。お"]}, {"box": [138, 1378, 191, 1400], "vertical": false, "font_size": 22, "lines_coords": [[[138.0, 1378.0], [191.0, 1378.0], [191.0, 1400.0], [138.0, 1400.0]]], "lines": ["遂にｅｒｋｕ"]}, {"box": [460, 1513, 757, 1636], "vertical": false, "font_size": 21, "lines_coords": [[[511.0, 1580.0], [576.0, 1580.0], [576.0, 1597.0], [511.0, 1597.0]], [[637.0, 1607.0], [738.0, 1607.0], [738.0, 1625.0], [637.0, 1625.0]], [[463.0, 1603.0], [523.0, 1603.0], [523.0, 1638.0], [463.0, 1638.0]]], "lines": ["クか？私手教いてると思う", "２０１７年３月３０日火まで", "３Ｐｏｓｔｏｄｂｅの基準アフィＯね"]}, {"box": [191, 1541, 232, 1644], "vertical": true, "font_size": 41, "lines_coords": [[[191.0, 1541.0], [232.0, 1541.0], [232.0, 1644.0], [191.0, 1644.0]]], "lines": ["カタ．．．"]}, {"box": [130, 1419, 160, 1638], "vertical": true, "font_size": 28, "lines_coords": [[[130.0, 1419.0], [158.0, 1419.0], [160.0, 1638.0], [132.0, 1638.0]]], "lines": ["汽念鎗塗諭塗龜藤謐蒸"]}, {"box": [64, 1785, 83, 1851], "vertical": true, "font_size": 19, "lines_coords": [[[64.0, 1785.0], [83.0, 1785.0], [83.0, 1851.0], [64.0, 1851.0]]], "lines": ["１０３"]}], "img_path": "108.png"}, {"version": "0.2.0-beta.6", "img_width": 1360, "img_height": 2000, "blocks": [{"box": [1102, 925, 1143, 1061], "vertical": true, "font_size": 41, "lines_coords": [[[1102.0, 925.0], [1143.0, 925.0], [1143.0, 1056.0], [1102.0, 1056.0]]], "lines": ["わ．．．．．．"]}, {"box": [1168, 1378, 1205, 1472], "vertical": true, "font_size": 37, "lines_coords": [[[1168.0, 1378.0], [1205.0, 1378.0], [1205.0, 1472.0], [1168.0, 1472.0]]], "lines": ["ピピピ"]}, {"box": [1267, 1790, 1285, 1854], "vertical": true, "font_size": 18, "lines_coords": [[[1267.0, 1790.0], [1285.0, 1790.0], [1285.0, 1854.0], [1267.0, 1854.0]]], "lines": ["１０４"]}, {"box": [373, 1564, 410, 1658], "vertical": true, "font_size": 37, "lines_coords": [[[373.0, 1564.0], [410.0, 1564.0], [410.0, 1658.0], [373.0, 1658.0]]], "lines": ["ピピピ"]}, {"box": [195, 1761, 236, 1863], "vertical": true, "font_size": 41, "lines_coords": [[[195.0, 1761.0], [236.0, 1761.0], [236.0, 1863.0], [195.0, 1863.0]]], "lines": ["ピピピ"]}], "img_path": "109.png"}, {"version": "0.2.0-beta.6", "img_width": 1360, "img_height": 2000, "blocks": [{"box": [1031, 187, 1078, 398], "vertical": true, "font_size": 47, "lines_coords": [[[1031.0, 187.0], [1078.0, 187.0], [1078.0, 398.0], [1031.0, 398.0]]], "lines": ["小梅――っ！！"]}, {"box": [273, 521, 369, 666], "vertical": true, "font_size": 28, "lines_coords": [[[341.0, 521.0], [369.0, 521.0], [369.0, 638.0], [341.0, 638.0]], [[304.0, 521.0], [332.0, 521.0], [332.0, 662.0], [304.0, 662.0]], [[273.0, 523.0], [300.0, 523.0], [300.0, 666.0], [273.0, 666.0]]], "lines": ["目覚まし", "鳴ってんで", "しょーー？"]}, {"box": [177, 722, 312, 898], "vertical": true, "font_size": 28, "lines_coords": [[[279.0, 722.0], [312.0, 722.0], [312.0, 841.0], [279.0, 841.0]], [[244.0, 724.0], [273.0, 724.0], [275.0, 898.0], [246.0, 898.0]], [[211.0, 724.0], [244.0, 724.0], [240.0, 867.0], [207.0, 867.0]], [[177.0, 724.0], [205.0, 724.0], [205.0, 787.0], [177.0, 787.0]]], "lines": ["さっさと", "起きちゃって", "ちょうだい", "よー"]}, {"box": [179, 806, 201, 867], "vertical": true, "font_size": 28, "lines_coords": [[[179.0, 806.0], [201.0, 806.0], [201.0, 867.0], [179.0, 867.0]]], "lines": ["！？"]}, {"box": [1164, 1035, 1195, 1210], "vertical": true, "font_size": 29, "lines_coords": [[[1164.0, 1035.0], [1193.0, 1035.0], [1193.0, 1082.0], [1164.0, 1082.0]]], "lines": ["んー"]}, {"box": [1174, 1451, 1209, 1542], "vertical": true, "font_size": 35, "lines_coords": [[[1174.0, 1451.0], [1209.0, 1451.0], [1209.0, 1542.0], [1174.0, 1542.0]]], "lines": ["ピピピ"]}, {"box": [812, 1064, 845, 1154], "vertical": true, "font_size": 30, "lines_coords": [[[812.0, 1064.0], [842.0, 1064.0], [842.0, 1154.0], [812.0, 1154.0]]], "lines": ["ピピピ"]}, {"box": [801, 1759, 836, 1855], "vertical": true, "font_size": 35, "lines_coords": [[[801.0, 1759.0], [836.0, 1759.0], [836.0, 1855.0], [801.0, 1855.0]]], "lines": ["ピピピ"]}, {"box": [65, 1783, 84, 1851], "vertical": true, "font_size": 19, "lines_coords": [[[65.0, 1783.0], [84.0, 1783.0], [84.0, 1851.0], [65.0, 1851.0]]], "lines": ["１０５"]}], "img_path": "110.png"}, {"version": "0.2.0-beta.6", "img_width": 1360, "img_height": 2000, "blocks": [{"box": [1143, 837, 1178, 916], "vertical": true, "font_size": 32, "lines_coords": [[[1143.0, 837.0], [1178.0, 837.0], [1178.0, 916.0], [1143.0, 916.0]]], "lines": ["うわー"]}, {"box": [1008, 935, 1072, 1082], "vertical": true, "font_size": 32, "lines_coords": [[[1039.0, 935.0], [1072.0, 935.0], [1072.0, 1056.0], [1039.0, 1056.0]], [[1008.0, 939.0], [1035.0, 939.0], [1035.0, 1082.0], [1008.0, 1082.0]]], "lines": ["なんだよ", "そのクマ！！"]}, {"box": [1199, 1242, 1232, 1357], "vertical": true, "font_size": 29, "lines_coords": [[[1199.0, 1242.0], [1232.0, 1242.0], [1232.0, 1357.0], [1199.0, 1357.0]]], "lines": ["寝不足？"]}, {"box": [1100, 1304, 1162, 1505], "vertical": true, "font_size": 29, "lines_coords": [[[1135.0, 1304.0], [1162.0, 1304.0], [1162.0, 1505.0], [1135.0, 1505.0]], [[1100.0, 1304.0], [1127.0, 1304.0], [1127.0, 1474.0], [1100.0, 1474.0]]], "lines": ["さっきの現国も", "爆睡だったし"]}, {"box": [615, 1322, 716, 1498], "vertical": true, "font_size": 29, "lines_coords": [[[687.0, 1326.0], [715.0, 1326.0], [715.0, 1498.0], [687.0, 1498.0]], [[648.0, 1322.0], [681.0, 1322.0], [681.0, 1468.0], [648.0, 1468.0]], [[615.0, 1326.0], [642.0, 1326.0], [642.0, 1441.0], [615.0, 1441.0]]], "lines": ["それは恋か！？", "恋わずらい", "なのか！？"]}, {"box": [468, 1230, 556, 1410], "vertical": true, "font_size": 26, "lines_coords": [[[531.0, 1232.0], [556.0, 1232.0], [556.0, 1408.0], [531.0, 1408.0]], [[500.0, 1232.0], [525.0, 1232.0], [525.0, 1386.0], [500.0, 1386.0]], [[468.0, 1230.0], [494.0, 1230.0], [494.0, 1410.0], [468.0, 1410.0]]], "lines": ["そういやアンタ", "三崎先輩の話", "しなくなったね"]}, {"box": [1193, 1587, 1227, 1730], "vertical": true, "font_size": 34, "lines_coords": [[[1193.0, 1587.0], [1227.0, 1587.0], [1227.0, 1730.0], [1193.0, 1730.0]]], "lines": ["ちげーやい"]}, {"box": [459, 1478, 523, 1652], "vertical": true, "font_size": 26, "lines_coords": [[[496.0, 1478.0], [523.0, 1478.0], [523.0, 1652.0], [496.0, 1652.0]], [[459.0, 1480.0], [486.0, 1480.0], [486.0, 1625.0], [459.0, 1625.0]]], "lines": ["どーなってん", "だよ最近？"]}, {"box": [638, 1720, 672, 1839], "vertical": true, "font_size": 34, "lines_coords": [[[638.0, 1720.0], [672.0, 1720.0], [672.0, 1839.0], [638.0, 1839.0]]], "lines": ["そーかい"]}, {"box": [115, 1695, 252, 1871], "vertical": true, "font_size": 28, "lines_coords": [[[222.0, 169