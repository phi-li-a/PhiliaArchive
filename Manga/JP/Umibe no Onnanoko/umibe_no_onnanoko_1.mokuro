0, 320.0]], [[969.0, 119.0], [996.0, 119.0], [996.0, 320.0], [969.0, 320.0]]], "lines": ["愛のある", "セックスなんて", "幻想なんだよ！！"]}, {"box": [293, 793, 319, 933], "vertical": true, "font_size": 21, "lines_coords": [[[293.0, 796.0], [314.0, 796.0], [314.0, 931.0], [293.0, 931.0]]], "lines": ["．．．うるさい"]}, {"box": [980, 1300, 1186, 1470], "vertical": false, "font_size": 25.666666666666668, "lines_coords": [[[998.0, 1300.0], [1123.0, 1300.0], [1123.0, 1322.0], [998.0, 1322.0]], [[980.0, 1337.0], [1186.0, 1337.0], [1186.0, 1365.0], [980.0, 1365.0]], [[980.0, 1367.0], [1164.0, 1363.0], [1164.0, 1388.0], [980.0, 1392.0]], [[984.0, 1394.0], [1145.0, 1390.0], [1145.0, 1416.0], [984.0, 1419.0]], [[1006.0, 1419.0], [1154.0, 1414.0], [1154.0, 1441.0], [1006.0, 1447.0]], [[982.0, 1445.0], [1174.0, 1441.0], [1174.0, 1466.0], [982.0, 1470.0]]], "lines": ["保健室の使い方", "１．使用は想像に届ける", "う、みだりにさわがない。", "３．用が済んだ者は。", "．．．冷やかんなの高やかに決定されるって！", "４．携帯電話・メル禁止・"]}, {"box": [1267, 1784, 1285, 1849], "vertical": true, "font_size": 18, "lines_coords": [[[1267.0, 1784.0], [1285.0, 1784.0], [1285.0, 1849.0], [1267.0, 1849.0]]], "lines": ["０６６"]}, {"box": [795, 1667, 842, 1742], "vertical": true, "font_size": 40, "lines_coords": [[[799.0, 1667.0], [842.0, 1671.0], [838.0, 1742.0], [795.0, 1738.0]]], "lines": ["カチ"]}, {"box": [756, 1779, 793, 1855], "vertical": true, "font_size": 40, "lines_coords": [[[756.0, 1779.0], [793.0, 1779.0], [793.0, 1855.0], [756.0, 1855.0]]], "lines": ["カチ"]}, {"box": [480, 1642, 637, 1849], "vertical": false, "font_size": 30.5, "lines_coords": [[[502.0, 1667.0], [631.0, 1832.0], [609.0, 1849.0], [480.0, 1685.0]], [[554.0, 1642.0], [637.0, 1738.0], [611.0, 1759.0], [531.0, 1664.0]]], "lines": ["やっぱり学校でするのは", "これからだとは"]}, {"box": [433, 1683, 603, 1861], "vertical": false, "font_size": 26.5, "lines_coords": [[[480.0, 1683.0], [603.0, 1843.0], [582.0, 1861.0], [457.0, 1701.0]], [[453.0, 1699.0], [515.0, 1779.0], [496.0, 1794.0], [433.0, 1716.0]]], "lines": ["スリルがありすぎるから", "もうちょっと"]}, {"box": [302, 1734, 457, 1910], "vertical": false, "font_size": 34.0, "lines_coords": [[[332.0, 1748.0], [433.0, 1888.0], [404.0, 1910.0], [302.0, 1767.0]], [[351.0, 1734.0], [457.0, 1875.0], [431.0, 1894.0], [326.0, 1753.0]]], "lines": ["あのようございよう", "止めよう、飛んなっちゃんっ"]}, {"box": [193, 1681, 236, 1750], "vertical": true, "font_size": 38, "lines_coords": [[[197.0, 1681.0], [236.0, 1683.0], [232.0, 1750.0], [193.0, 1748.0]]], "lines": ["カチ"]}, {"box": [138, 1802, 175, 1873], "vertical": true, "font_size": 38, "lines_coords": [[[138.0, 1802.0], [175.0, 1802.0], [175.0, 1873.0], [138.0, 1873.0]]], "lines": ["カチ"]}], "img_path": "071.png"}, {"version": "0.2.0-beta.6", "img_width": 1360, "img_height": 2000, "blocks": [{"box": [517, 291, 709, 400], "vertical": false, "font_size": 81, "lines_coords": [[[517.0, 320.0], [695.0, 291.0], [709.0, 371.0], [531.0, 400.0]]], "lines": ["前が自分から言い出たんじゃねーの？外とああいうシチューション俺嫌いじゃかったけど"]}, {"box": [406, 216, 777, 556], "vertical": false, "font_size": 97.0, "lines_coords": [[[480.0, 234.0], [549.0, 220.0], [554.0, 248.0], [486.0, 261.0]], [[470.0, 289.0], [680.0, 255.0], [685.0, 289.0], [476.0, 322.0]], [[406.0, 263.0], [736.0, 216.0], [777.0, 509.0], [447.0, 556.0]], [[554.0, 427.0], [701.0, 404.0], [705.0, 433.0], [560.0, 457.0]]], "lines": ["黒磯辺翔やめようっ", "このようにお前が自分から言い出したんじゃねーの？華がしましょうよっ", "そんなことはありがとうございますのですが、それではないでしょうか。", "ありたいと。会う機会がいうか学校で会う様へって寂しいんじゃないの？"]}, {"box": [187, 816, 226, 880], "vertical": true, "font_size": 39, "lines_coords": [[[187.0, 816.0], [226.0, 816.0], [226.0, 880.0], [187.0, 880.0]]], "lines": ["カチ"]}, {"box": [134, 886, 173, 955], "vertical": true, "font_size": 39, "lines_coords": [[[134.0, 886.0], [173.0, 886.0], [173.0, 955.0], [134.0, 955.0]]], "lines": ["カチ"]}, {"box": [250, 714, 556, 1021], "vertical": false, "font_size": 34.0, "lines_coords": [[[353.0, 714.0], [545.0, 796.0], [531.0, 830.0], [340.0, 748.0]], [[287.0, 761.0], [433.0, 832.0], [420.0, 863.0], [273.0, 792.0]], [[267.0, 792.0], [556.0, 923.0], [541.0, 957.0], [254.0, 826.0]], [[273.0, 835.0], [402.0, 896.0], [390.0, 923.0], [259.0, 863.0]], [[267.0, 869.0], [531.0, 988.0], [517.0, 1021.0], [254.0, 902.0]], [[263.0, 910.0], [404.0, 974.0], [390.0, 1001.0], [250.0, 937.0]]], "lines": ["Ｅ：やめようって", "さみしいよ。", "磯辺の下半身に会えな", "いってのは。", "「半身のほうは別にど", "でもいいや。"]}, {"box": [607, 529, 642, 550], "vertical": false, "font_size": 21, "lines_coords": [[[607.0, 529.0], [642.0, 529.0], [642.0, 550.0], [607.0, 550.0]]], "lines": ["選択"]}, {"box": [654, 753, 691, 820], "vertical": true, "font_size": 37, "lines_coords": [[[654.0, 753.0], [691.0, 753.0], [691.0, 820.0], [654.0, 820.0]]], "lines": ["カチ"]}, {"box": [160, 1328, 437, 1634], "vertical": false, "font_size": 36.42857142857143, "lines_coords": [[[203.0, 1328.0], [289.0, 1333.0], [287.0, 1371.0], [201.0, 1365.0]], [[230.0, 1367.0], [369.0, 1386.0], [363.0, 1421.0], [224.0, 1402.0]], [[185.0, 1445.0], [412.0, 1488.0], [404.0, 1529.0], [177.0, 1486.0]], [[191.0, 1427.0], [271.0, 1435.0], [267.0, 1468.0], [187.0, 1460.0]], [[170.0, 1503.0], [429.0, 1552.0], [424.0, 1587.0], [164.0, 1539.0]], [[168.0, 1533.0], [437.0, 1587.0], [429.0, 1623.0], [160.0, 1568.0]], [[166.0, 1566.0], [363.0, 1601.0], [357.0, 1634.0], [160.0, 1599.0]]], "lines": ["国機辺", "ＲＥ：ＰＥ：ＡＥ：ＲＥ・", "ハーカ真に受けんなよ（笑）", "バーカ", "けど磯辺君がサッカーと", "いく感じ右ハリツルーやってるとこ、ちょっと見てみたいかなー", "見てみたいかもー"]}, {"box": [650, 1087, 904, 1238], "vertical": false, "font_size": 28.0, "lines_coords": [[[662.0, 1105.0], [904.0, 1210.0], [892.0, 1238.0], [650.0, 1130.0]], [[676.0, 1087.0], [738.0, 1111.0], [728.0, 1136.0], [666.0, 1113.0]]], "lines": ["私に「だった．．．やめようって", "そんなことなった"]}, {"box": [558, 1156, 879, 1460], "vertical": false, "font_size": 25.7, "lines_coords": [[[635.0, 1156.0], [879.0, 1263.0], [869.0, 1289.0], [625.0, 1181.0]], [[627.0, 1175.0], [875.0, 1287.0], [863.0, 1312.0], [615.0, 1201.0]], [[617.0, 1197.0], [840.0, 1296.0], [828.0, 1322.0], [605.0, 1222.0]], [[609.0, 1218.0], [793.0, 1304.0], [781.0, 1328.0], [597.0, 1242.0]], [[599.0, 1244.0], [783.0, 1326.0], [773.0, 1343.0], [590.0, 1261.0]], [[582.0, 1283.0], [765.0, 1369.0], [756.0, 1390.0], [572.0, 1304.0]], [[590.0, 1263.0], [701.0, 1312.0], [693.0, 1333.0], [580.0, 1285.0]], [[568.0, 1300.0], [807.0, 1412.0], [797.0, 1433.0], [558.0, 1322.0]], [[597.0, 1339.0], [801.0, 1431.0], [789.0, 1457.0], [586.0, 1365.0]], [[570.0, 1353.0], [748.0, 1433.0], [736.0, 1460.0], [558.0, 1380.0]]], "lines": ["なにそれ超ひどくない！？", "そんな侮辱受けたの生まれて初めてやってみれ", "これは何等文りだの生まで初めてなんですけど！", "ううっ．．．悲しいですっ！！悲しーい！！。そいうか死んだ", "ていうか死にたい．．．", "いつーか死んでやるの", "（Ｔａｒ）ｍｏｗ", "アンタのチンコ切り取って", "タイのストラップにし", "やる（＾＾＾＊）"]}, {"box": [935, 1130, 1148, 1283], "vertical": false, "font_size": 32.666666666666664, "lines_coords": [[[935.0, 1181.0], [1125.0, 1130.0], [1135.0, 1162.0], [943.0, 1214.0]], [[971.0, 1228.0], [1141.0, 1183.0], [1148.0, 1216.0], [978.0, 1261.0]], [[998.0, 1257.0], [1035.0, 1236.0], [1049.0, 1261.0], [1014.0, 1283.0]]], "lines": ["１５歳２５年に．．．やめようって", "ご俺にはそんなにキャーの。", "この？"]}, {"box": [957, 1259, 1010, 1359], "vertical": true, "font_size": 29, "lines_coords": [[[957.0, 1267.0], [984.0, 1259.0], [1010.0, 1351.0], [982.0, 1359.0]]], "lines": ["違重Ｓ女"]}, {"box": [69, 1778, 89, 1848], "vertical": true, "font_size": 20, "lines_coords": [[[69.0, 1778.0], [89.0, 1778.0], [89.0, 1848.0], [69.0, 1848.0]]], "lines": ["０６７"]}, {"box": [724, 1623, 967, 1750], "vertical": false, "font_size": 35.0, "lines_coords": [[[724.0, 1646.0], [832.0, 1623.0], [840.0, 1656.0], [732.0, 1679.0]], [[740.0, 1681.0], [814.0, 1666.0], [820.0, 1697.0], [746.0, 1712.0]], [[750.0, 1712.0], [957.0, 1660.0], [967.0, 1697.0], [760.0, 1750.0]]], "lines": ["Ｍｏｏ！！", "自機の", "あっ、あんた．．．ＰＥ．ＲＥ．．"]}, {"box": [767, 1738, 1002, 1845], "vertical": false, "font_size": 32.5, "lines_coords": [[[767.0, 1783.0], [924.0, 1738.0], [932.0, 1769.0], [775.0, 1812.0]], [[773.0, 1812.0], [994.0, 1753.0], [1002.0, 1787.0], [781.0, 1845.0]]], "lines": ["すみません．．．", "母のよじん調子に乗りました。"]}, {"box": [789, 1794, 1074, 1984], "vertical": false, "font_size": 33.25, "lines_coords": [[[789.0, 1873.0], [1051.0, 1794.0], [1062.0, 1830.0], [801.0, 1908.0]], [[803.0, 1904.0], [887.0, 1880.0], [894.0, 1910.0], [810.0, 1933.0]], [[803.0, 1935.0], [1062.0, 1851.0], [1074.0, 1886.0], [814.0, 1968.0]], [[844.0, 1955.0], [963.0, 1921.0], [971.0, 1951.0], [851.0, 1984.0]]], "lines": ["僕は佐藤さんの性奴隷", "でした。", "ししに。なんでも命令してやっ", "ください。"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 1360, "img_height": 2000, "blocks": [{"box": [1270, 1782, 1288, 1849], "vertical": true, "font_size": 18, "lines_coords": [[[1270.0, 1782.0], [1288.0, 1782.0], [1288.0, 1849.0], [1270.0, 1849.0]]], "lines": ["０６８"]}], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 1360, "img_height": 2000, "blocks": [{"box": [214, 199, 271, 296], "vertical": true, "font_size": 44, "lines_coords": [[[214.0, 199.0], [271.0, 199.0], [271.0, 296.0], [214.0, 296.0]]], "lines": ["三中"]}, {"box": [181, 312, 211, 394], "vertical": true, "font_size": 44, "lines_coords": [[[181.0, 312.0], [211.0, 312.0], [211.0, 394.0], [181.0, 394.0]]], "lines": ["ッ！！"]}, {"box": [37, 130, 84, 321], "vertical": true, "font_size": 41, "lines_coords": [[[37.0, 130.0], [78.0, 130.0], [82.0, 318.0], [41.0, 318.0]]], "lines": ["第４話"]}, {"box": [1162, 625, 1195, 666], "vertical": true, "font_size": 33, "lines_coords": [[[1162.0, 625.0], [1195.0, 625.0], [1195.0, 666.0], [1162.0, 666.0]]], "lines": ["オー"]}, {"box": [1090, 792, 1123, 917], "vertical": true, "font_size": 33, "lines_coords": [[[1090.0, 792.0], [1123.0, 792.0], [1123.0, 917.0], [1090.0, 917.0]]], "lines": ["エッス！！"]}, {"box": [529, 625, 562, 669], "vertical": true, "font_size": 34, "lines_coords": [[[529.0, 625.0], [562.0, 625.0], [562.0, 669.0], [529.0, 669.0]]], "lines": ["オー"]}, {"box": [435, 728, 470, 847], "vertical": true, "font_size": 34, "lines_coords": [[[435.0, 728.0], [470.0, 728.0], [470.0, 847.0], [435.0, 847.0]]], "lines": ["エッス！！"]}, {"box": [218, 835, 254, 878], "vertical": true, "f