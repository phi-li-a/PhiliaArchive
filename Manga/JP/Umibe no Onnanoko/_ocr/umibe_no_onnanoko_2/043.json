tical": false, "font_size": 13, "lines_coords": [[[465.0, 1398.0], [562.0, 1399.0], [562.0, 1419.0], [465.0, 1417.0]], [[470.0, 1416.0], [540.0, 1416.0], [540.0, 1427.0], [470.0, 1427.0]]], "lines": ["そんなことはありませんでしたが．．．ありがとうございますのですが、それはそうですから、", "そんなお仕事できないのかわからないけど．．．とかも教えてくれました。"]}, {"box": [1037, 1427, 1051, 1479], "vertical": true, "font_size": 14, "lines_coords": [[[1037.0, 1427.0], [1051.0, 1427.0], [1051.0, 1479.0], [1037.0, 1479.0]]], "lines": ["ひ３６"]}]}