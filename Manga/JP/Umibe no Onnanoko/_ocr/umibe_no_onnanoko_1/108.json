s_coords": [[[467.0, 1103.0], [678.0, 1103.0], [678.0, 1117.0], [467.0, 1117.0]], [[467.0, 1126.0], [535.0, 1126.0], [535.0, 1140.0], [467.0, 1140.0]]], "lines": ["あれだった．．．。人類のように解釈を教えてくれるね参加者たちの先の声を探して", "おはようサンセット"]}, {"box": [459, 1271, 702, 1324], "vertical": false, "font_size": 22, "lines_coords": [[[465.0, 1275.0], [599.0, 1275.0], [599.0, 1289.0], [465.0, 1289.0]], [[465.0, 1306.0], [535.0, 1308.0], [535.0, 1324.0], [465.0, 1322.0]], [[607.0, 1271.0], [697.0, 1271.0], [697.0, 1306.0], [607.0, 1306.0]]], "lines": ["第五話ラストで突如現れた転校生は", "まんま何じゃんけ？", "はりヒナちゃんでしたね私１氏の十八番というか。"]}, {"box": [550, 1388, 755, 1415], "vertical": false, "font_size": 29, "lines_coords": [[[550.0, 1386.0], [755.0, 1386.0], [755.0, 1417.0], [550.0, 1417.0]]], "lines": ["おはようサンセットにしていただいたいと思いますので、"]}, {"box": [459, 1337, 676, 1376], "vertical": false, "font_size": 42, "lines_coords": [[[459.0, 1334.0], [670.0, 1334.0], [670.0, 1379.0], [459.0, 1379.0]]], "lines": ["その後は、その時はやってみました。それはそう嫌いなのかなと言えません。大丈夫だった。"]}, {"box": [209, 1093, 269, 1278], "vertical": true, "font_size": 37, "lines_coords": [[[224.0, 1093.0], [269.0, 1093.0], [269.0, 1162.0], [224.0, 1162.0]], [[209.0, 1214.0], [238.0, 1214.0], [238.0, 1275.0], [209.0, 1275.0]]], "lines": ["カタ", "カタ"]}, {"box": [132, 1097, 160, 1287], "vertical": true, "font_size": 28, "lines_coords": [[[132.0, 1097.0], [160.0, 1097.0], [160.0, 1287.0], [132.0, 1287.0]]], "lines": ["日曜午前火．．．。お"]}, {"box": [138, 1378, 191, 1400], "vertical": false, "font_size": 22, "lines_coords": [[[138.0, 1378.0], [191.0, 1378.0], [191.0, 1400.0], [138.0, 1400.0]]], "lines": ["遂にｅｒｋｕ"]}, {"box": [460, 1513, 757, 1636], "vertical": false, "font_size": 21, "lines_coords": [[[511.0, 1580.0], [576.0, 1580.0], [576.0, 1597.0], [511.0, 1597.0]], [[637.0, 1607.0], [738.0, 1607.0], [738.0, 1625.0], [637.0, 1625.0]], [[463.0, 1603.0], [523.0, 1603.0], [523.0, 1638.0], [463.0, 1638.0]]], "lines": ["クか？私手教いてると思う", "２０１７年３月３０日火まで", "３Ｐｏｓｔｏｄｂｅの基準アフィＯね"]}, {"box": [191, 1541, 232, 1644], "vertical": true, "font_size": 41, "lines_coords": [[[191.0, 1541.0], [232.0, 1541.0], [232.0, 1644.0], [191.0, 1644.0]]], "lines": ["カタ．．．"]}, {"box": [130, 1419, 160, 1638], "vertical": true, "font_size": 28, "lines_coords": [[[130.0, 1419.0], [158.0, 1419.0], [160.0, 1638.0], [132.0, 1638.0]]], "lines": ["汽念鎗塗諭塗龜藤謐蒸"]}, {"box": [64, 1785, 83, 1851], "vertical": true, "font_size": 19, "lines_coords": [[[64.0, 1785.0], [83.0, 1785.0], [83.0, 1851.0], [64.0, 1851.0]]], "lines": ["１０３"]}]}