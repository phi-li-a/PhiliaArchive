 "lines": ["幸太寺市大門に"]}, {"box": [586, 0, 642, 364], "vertical": true, "font_size": 53, "lines_coords": [[[586.0, 0.0], [639.0, 0.0], [642.0, 364.0], [589.0, 364.0]]], "lines": ["あああぁぁぁっ。あっ、あ、ああ"]}, {"box": [269, 0, 542, 35], "vertical": false, "font_size": 16, "lines_coords": [[[295.0, 18.0], [495.0, 18.0], [495.0, 34.0], [295.0, 34.0]]], "lines": ["やれやら大衆化学校じゃぁじは個人のため"]}, {"box": [225, 101, 454, 162], "vertical": false, "font_size": 24.0, "lines_coords": [[[240.0, 101.0], [431.0, 103.0], [431.0, 129.0], [240.0, 128.0]], [[225.0, 140.0], [454.0, 140.0], [454.0, 162.0], [225.0, 162.0]]], "lines": ["実際、ランチを見つけて、", "一般人一年の家に死ん可能な"]}, {"box": [282, 175, 451, 201], "vertical": false, "font_size": 26, "lines_coords": [[[282.0, 175.0], [451.0, 175.0], [451.0, 201.0], [282.0, 201.0]]], "lines": ["今時おいあんな"]}, {"box": [317, 306, 343, 323], "vertical": false, "font_size": 20, "lines_coords": [[[317.0, 306.0], [343.0, 306.0], [343.0, 323.0], [317.0, 323.0]]], "lines": ["えっ"]}, {"box": [176, 223, 273, 411], "vertical": true, "font_size": 26, "lines_coords": [[[240.0, 223.0], [268.0, 223.0], [268.0, 329.0], [240.0, 329.0]], [[211.0, 225.0], [237.0, 225.0], [237.0, 384.0], [211.0, 384.0]], [[176.0, 225.0], [200.0, 225.0], [201.0, 410.0], [178.0, 410.0]]], "lines": ["カップル", "コンテストで", "いいんじゃね？"]}, {"box": [869, 550, 966, 734], "vertical": true, "font_size": 21, "lines_coords": [[[944.0, 550.0], [966.0, 550.0], [966.0, 673.0], [944.0, 673.0]], [[919.0, 551.0], [940.0, 551.0], [940.0, 715.0], [919.0, 715.0]], [[894.0, 550.0], [914.0, 550.0], [914.0, 676.0], [894.0, 676.0]], [[869.0, 550.0], [889.0, 550.0], [889.0, 732.0], [869.0, 732.0]]], "lines": ["どうせ先生の", "許可おりないから", "表向きは仮装", "コンテストって事で"]}, {"box": [626, 642, 712, 785], "vertical": true, "font_size": 29, "lines_coords": [[[676.0, 642.0], [712.0, 642.0], [712.0, 698.0], [676.0, 698.0]], [[653.0, 643.0], [681.0, 643.0], [681.0, 785.0], [653.0, 785.0]], [[626.0, 646.0], [648.0, 646.0], [648.0, 760.0], [626.0, 760.0]]], "lines": ["誰も", "出ねーよ！！", "つまんねぇ"]}, {"box": [303, 396, 459, 418], "vertical": false, "font_size": 20, "lines_coords": [[[303.0, 396.0], [459.0, 396.0], [459.0, 418.0], [303.0, 418.0]]], "lines": ["建家、いお題目となる"]}, {"box": [282, 476, 442, 492], "vertical": false, "font_size": 16, "lines_coords": [[[282.0, 476.0], [442.0, 476.0], [442.0, 492.0], [282.0, 492.0]]], "lines": ["あぁぁあああはえっと。でも"]}, {"box": [937, 865, 987, 1004], "vertical": true, "font_size": 21, "lines_coords": [[[966.0, 865.0], [987.0, 865.0], [987.0, 1003.0], [966.0, 1003.0]], [[937.0, 867.0], [959.0, 867.0], [959.0, 1004.0], [937.0, 1004.0]]], "lines": ["それはそれで", "いいんだよ！！"]}, {"box": [797, 975, 894, 1139], "vertical": true, "font_size": 21, "lines_coords": [[[872.0, 975.0], [894.0, 975.0], [894.0, 1120.0], [872.0, 1120.0]], [[845.0, 975.0], [865.0, 975.0], [865.0, 1139.0], [845.0, 1139.0]], [[819.0, 975.0], [840.0, 975.0], [840.0, 1139.0], [819.0, 1139.0]], [[797.0, 976.0], [817.0, 976.0], [817.0, 1100.0], [797.0, 1100.0]]], "lines": ["食材準備とかで", "ハタつくよりかは", "楽なのがいいだろ", "文化祭なんて"]}, {"box": [443, 921, 540, 1087], "vertical": true, "font_size": 21, "lines_coords": [[[517.0, 923.0], [539.0, 923.0], [539.0, 1025.0], [517.0, 1025.0]], [[492.0, 921.0], [512.0, 921.0], [512.0, 1065.0], [492.0, 1065.0]], [[467.0, 921.0], [489.0, 921.0], [487.0, 1085.0], [465.0, 1085.0]], [[443.0, 923.0], [464.0, 923.0], [464.0, 1087.0], [443.0, 1087.0]]], "lines": ["お前自身が", "彼女出来たてで", "見せびらかしたい", "だけじゃねーの？"]}, {"box": [715, 1307, 762, 1412], "vertical": true, "font_size": 23, "lines_coords": [[[740.0, 1307.0], [762.0, 1307.0], [762.0, 1410.0], [740.0, 1410.0]], [[715.0, 1309.0], [737.0, 1309.0], [737.0, 1412.0], [715.0, 1412.0]]], "lines": ["．．．っかァー", "ちげーし！！"]}, {"box": [622, 1370, 694, 1459], "vertical": true, "font_size": 23, "lines_coords": [[[672.0, 1370.0], [694.0, 1370.0], [694.0, 1457.0], [672.0, 1457.0]], [[644.0, 1371.0], [670.0, 1371.0], [670.0, 1459.0], [644.0, 1459.0]], [[622.0, 1375.0], [644.0, 1375.0], [644.0, 1457.0], [622.0, 1457.0]]], "lines": ["ないわー", "その発想", "ないわー"]}, {"box": [403, 1256, 461, 1356], "vertical": true, "font_size": 28, "lines_coords": [[[434.0, 1259.0], [461.0, 1259.0], [461.0, 1356.0], [434.0, 1356.0]], [[403.0, 1256.0], [431.0, 1256.0], [434.0, 1353.0], [406.0, 1353.0]]], "lines": ["つかお前", "彼女さぁ"]}], "img_path": "021.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [826, 196, 855, 270], "vertical": true, "font_size": 31, "lines_coords": [[[826.0, 196.0], [855.0, 196.0], [855.0, 270.0], [826.0, 270.0]]], "lines": ["なに？"]}, {"box": [733, 260, 782, 330], "vertical": true, "font_size": 49, "lines_coords": [[[733.0, 260.0], [782.0, 260.0], [782.0, 330.0], [733.0, 330.0]]], "lines": ["なになに？"]}, {"box": [725, 256, 787, 332], "vertical": true, "font_size": 31, "lines_coords": [[[751.0, 256.0], [787.0, 256.0], [787.0, 314.0], [751.0, 314.0]], [[725.0, 259.0], [753.0, 257.0], [756.0, 331.0], [728.0, 332.0]]], "lines": ["なに", "なに？"]}, {"box": [540, 110, 592, 223], "vertical": true, "font_size": 22, "lines_coords": [[[562.0, 110.0], [589.0, 110.0], [592.0, 203.0], [565.0, 203.0]], [[540.0, 114.0], [562.0, 114.0], [562.0, 223.0], [540.0, 223.0]]], "lines": ["アレって", "どうなの？"]}, {"box": [445, 251, 543, 418], "vertical": true, "font_size": 22, "lines_coords": [[[523.0, 251.0], [543.0, 251.0], [543.0, 378.0], [523.0, 378.0]], [[497.0, 251.0], [520.0, 251.0], [517.0, 398.0], [493.0, 398.0]], [[470.0, 253.0], [492.0, 253.0], [490.0, 398.0], [468.0, 398.0]], [[445.0, 254.0], [465.0, 254.0], [465.0, 418.0], [445.0, 418.0]]], "lines": ["目ェ覚ませよ", "浮気でもしたら", "マジで刺される", "メンヘラ女だぞ？"]}, {"box": [676, 725, 706, 776], "vertical": true, "font_size": 27, "lines_coords": [[[676.0, 725.0], [706.0, 725.0], [706.0, 776.0], [676.0, 776.0]]], "lines": ["え？"]}, {"box": [601, 814, 656, 909], "vertical": true, "font_size": 27, "lines_coords": [[[623.0, 815.0], [653.0, 814.0], [656.0, 887.0], [626.0, 889.0]], [[601.0, 815.0], [623.0, 815.0], [623.0, 909.0], [601.0, 909.0]]], "lines": ["なんで", "なんで？"]}, {"box": [204, 1026, 248, 1203], "vertical": true, "font_size": 38, "lines_coords": [[[204.0, 1026.0], [248.0, 1026.0], [248.0, 1203.0], [204.0, 1203.0]]], "lines": ["ホテル"]}, {"box": [156, 971, 192, 1270], "vertical": true, "font_size": 38, "lines_coords": [[[161.0, 971.0], [192.0, 971.0], [187.0, 1270.0], [156.0, 1270.0]]], "lines": ["ＷｉｎｄｏｗｓのＷｉｌｄｏｒｄＰｒｅ"]}, {"box": [49, 1435, 63, 1488], "vertical": true, "font_size": 14, "lines_coords": [[[49.0, 1435.0], [63.0, 1435.0], [63.0, 1488.0], [49.0, 1488.0]]], "lines": ["０１５"]}], "img_path": "022.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [478, 1103, 600, 1167], "vertical": false, "font_size": 20.0, "lines_coords": [[[481.0, 1134.0], [600.0, 1148.0], [597.0, 1167.0], [478.0, 1153.0]], [[493.0, 1117.0], [564.0, 1123.0], [562.0, 1146.0], [492.0, 1140.0]], [[498.0, 1103.0], [565.0, 1106.0], [565.0, 1125.0], [498.0, 1121.0]]], "lines": ["ＢＡＲＥ．ＲＥ，ＲＥ－ＲＥ：", "三﨑先輩ＰＥＰ", "ＴＯＯＯ！ＲＩＤ"]}, {"box": [472, 1176, 642, 1231], "vertical": false, "font_size": 18.0, "lines_coords": [[[476.0, 1189.0], [642.0, 1201.0], [640.0, 1221.0], [475.0, 1209.0]], [[473.0, 1206.0], [565.0, 1214.0], [564.0, 1231.0], [472.0, 1223.0]], [[476.0, 1176.0], [517.0, 1176.0], [517.0, 1193.0], [476.0, 1193.0]]], "lines": ["じゃあ２８日午後１時に", "駅前で〜〜〜", "了解へ"]}, {"box": [1039, 1436, 1052, 1488], "vertical": true, "font_size": 13, "lines_coords": [[[1039.0, 1436.0], [1052.0, 1436.0], [1052.0, 1488.0], [1039.0, 1488.0]]], "lines": ["０１６"]}], "img_path": "023.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [], "img_path": "024.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [1038, 1432, 1053, 1486], "vertical": true, "font_size": 15, "lines_coords": [[[1038.0, 1432.0], [1053.0, 1432.0], [1053.0, 1486.0], [1038.0, 1486.0]]], "lines": ["Ｏｉ８"]}], "img_path": "025.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [72, 1259, 306, 1499], "vertical": false, "font_size": 22, "lines_coords": [[[78.0, 1468.0], [306.0, 1468.0], [306.0, 1490.0], [78.0, 1490.0]]], "lines": ["．．．ｓｉｄｅ"]}], "img_path": "026.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [], "img_path": "027.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [31, 107, 71, 259], "vertical": true, "font_size": 39, "lines_coords": [[[31.0, 107.0], [70.0, 107.0], [70.0, 259.0], [31.0, 259.0]]], "lines": ["第１２話"]}, {"box": [100, 23, 861, 432], "vertical": false, "font_size": 191.33333333333334, "lines_coords": [[[204.0, 29.0], [636.0, 23.0], [637.0, 134.0], [206.0, 140.0]], [[598.0, 46.0], [706.0, 46.0], [706.0, 131.0], [598.0, 131.0]], [[100.0, 54.0], [855.0, 42.0], [861.0, 420.0], [106.0, 432.0]]], "lines": ["Ｐｏｓｔｅｄｂｙ（ずわ）ま", "！ｂｙ", "Ｐｏｔｔｅｄ．ｂｏｏばれてますよ？かな２０前から気"]}, {"box": [815, 500, 882, 525], "vertical": false, "font_size": 24, "lines_coords": [[[820.0, 501.0], [873.0, 501.0], [873.0, 527.0], [820.0, 527.0]]], "lines": ["ｓｏｎｙ"]}, {"box": [801, 532, 898, 543], "vertical": false, "font_size": 11, "lines_coords": [[[801.0, 532.0], [898.0, 532.0], [898.0, 543.0], [801.0, 543.0]]], "lines": ["お前はどうして遊んでるんだよね。"]}, {"box": [815, 546, 876, 562], "vertical": false, "font_size": 16, "lines_coords": [[[815.0, 546.0], [876.0, 546.0], [876.0, 562.0], [815.0, 562.0]]], "lines": ["わたしは、その中によって"]}, {"box": [47, 1432, 61, 1484], "vertical": true, "font_size": 14, "lines_coords": [[[47.0, 1432.0], [61.0, 1432.0], [61.0, 1484.0], [47.0, 1484.0]]], "lines": ["Ｏ２ー"]}, {"box": [189, 1268, 248, 1284], "vertical": false, "font_size": 16, "lines_coords": [[[189.0, 1268.0], [248.0, 1268.0], [248.0, 1284.0], [189.0, 1284.0]]], "lines": ["今月の人気記事"]}, {"box": [334, 1346, 535, 1464], "vertical": false, "font_size": 14, "lines_coords": [[[334.0, 1346.0], [478.0, 1344.0], [478.0, 1364.0], [334.0, 1366.0]], [[348.0, 1362.0], [412.0, 1362.0], [412.0, 1377.0], [348.0, 1377.0]], [[347.0, 1373.0], [490.0, 1371.0], [490.0, 1391.0], [347.0, 1392.0]], [[350.0, 1388.0], [465.0, 1388.0], [465.0, 1403.0], [350.0, 1403.0]], [[348.0, 1401.0], [489.0, 1401.0], [489.0, 1416.0], [348.0, 1416.0]], [[350.0, 1415.0], [479.0, 1415.0], [479.0, 1430.0], [350.0, 1430.0]], [[350.0, 1427.0], [523.0, 1427.0], [523.0, 1442.0], [350.0, 1442.0]], [[350.0, 1441.0], [414.0, 1441.0], [414.0, 1456.0], [350.0, 1456.0]]], "lines": ["１．内容は、カッププリンシャーク上げかですよ。", "ばれてますよ？", "はれてるかなり前から気になってましたが、ください記事が構うか。", "くだらない記事が増えたり", "・たっぷり上がりに登場にアフィリエイトが増えたりするかもしれない", "ブログの劣化が目につきます。", "「ビックス」はさに２０１８年度人が変わったのなら発信すべきです。", "貴方誰ですか？"]}, {"box": [342, 1470, 475, 1481], "vertical": false, "font_size": 11, "lines_coords": [[[342.0, 1470.0], [475.0, 1470.0], [475.0, 1481.0], [342.0, 1481.0]]], "lines": ["２．Ｐａｓｔａｄから名無しの試験さん、"]}, {"box": [528, 1346, 670, 1362], "vertical": false, "font_size": 13, "lines_coords": [[[534.0, 1349.0], [592.0, 1349.0], [592.0, 1364.0], [534.0, 1364.0]]], "lines": ["２０１１／０１０"]}, {"box": [530, 1463, 670, 1483], "vertical": false, "font_size": 22, "lines_coords": [[[530.0, 1461.0], [670.0, 1461.0], [670.0, 1485.0], [530.0, 1485.0]]], "lines": ["２０１１年１０月１０日：２０日まる"]}], "img_path": "028.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [325, 21, 361, 218], "vertical": true, "font_size": 29, "lines_coords": [[[332.0, 21.0], [361.0, 23.0], [353.0, 218.0], [325.0, 217.0]]], "lines": ["そういえば、"]}, {"box": [282, 26, 304, 171], "vertical": true, "font_size": 22, "lines_coords": [[[282.0, 26.0], [304.0, 26.0], [304.0, 171.0], [282.0, 171.0]]], "lines": ["．．．"]}, {"box": [229, 37, 256, 220], "vertical": true, "font_size": 22, "lines_coords": [[[234.0, 37.0], [256.0, 37.0], [251.0, 220.0], [229.0, 220.0]]], "lines": ["．．．"]}, {"box": [182, 37, 209, 209], "vertical": true, "font_size": 27, "lines_coords": [[[182.0, 37.0], [209.0, 37.0], [209.0, 209.0], [182.0, 209.0]]], "lines": ["そういえば、"]}, {"box": [362, 1043, 415, 1132], "vertical": true, "font_size": 27, "lines_coords": [[[389.0, 1043.0], [415.0, 1043.0], [415.0, 1131.0], [389.0, 1131.0]], [[362.0, 1043.0], [390.0, 1043.0], [390.0, 1132.0], [362.0, 1132.0]]], "lines": ["佐藤さん", "白瀬さん"]}, {"box": [295, 1082, 348, 1156], "vertical": true, "font_size": 27, "lines_coords": [[[318.0, 1082.0], [348.0, 1082.0], [348.0, 1153.0], [318.0, 1153.0]], [[295.0, 1085.0], [318.0, 1085.0], [318.0, 1156.0], [295.0, 1156.0]]], "lines": ["こっち", "来なよ"]}, {"box": [192, 1093, 236, 1153], "vertical": true, "font_size": 19, "lines_coords": [[[212.0, 1093.0], [236.0, 1093.0], [236.0, 1153.0], [212.0, 1153.0]], [[192.0, 1095.0], [209.0, 1095.0], [209.0, 1131.0], [192.0, 1131.0]]], "lines": ["やだァ", "もー"]}, {"box": [192, 1134, 209, 1189], "vertical": true, "font_size": 19, "lines_coords": [[[192.0, 1134.0], [209.0, 1134.0], [209.0, 1189.0], [192.0, 1189.0]]], "lines": ["ーッ！！"]}, {"box": [1042, 1433, 1056, 1485], "vertical": true, "font_size": 14, "lines_coords": [[[1042.0, 1433.0], [1056.0, 1433.0], [1056.0, 1485.0], [1042.0, 1485.0]]], "lines": ["０２２"]}, {"box": [131, 1410, 153, 1503], "vertical": true, "font_size": 22, "lines_coords": [[[131.0, 1410.0], [153.0, 1410.0], [153.0, 1503.0], [131.0, 1503.0]]], "lines": ["ぎゃはは"]}], "img_path": "029.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [509, 64, 539, 139], "vertical": true, "font_size": 27, "lines_coords": [[[509.0, 64.0], [539.0, 64.0], [539.0, 139.0], [509.0, 139.0]]], "lines": ["あの．．．"]}, {"box": [428, 160, 481, 256], "vertical": true, "font_size": 27, "lines_coords": [[[459.0, 162.0], [481.0, 162.0], [481.0, 256.0], [459.0, 256.0]], [[428.0, 160.0], [456.0, 160.0], [456.0, 235.0], [428.0, 235.0]]], "lines": ["佐藤さん", "て．．．"]}, {"box": [90, 164, 145, 260], "vertical": true, "font_size": 28, "lines_coords": [[[117.0, 164.0], [145.0, 164.0], [145.0, 257.0], [117.0, 257.0]], [[90.0, 164.0], [117.0, 164.0], [117.0, 260.0], [90.0, 260.0]]], "lines": ["今いくつ", "ですか？"]}, {"box": [886, 692, 944, 768], "vertical": true, "font_size": 25, "lines_coords": [[[914.0, 692.0], [944.0, 692.0], [944.0, 767.0], [914.0, 767.0]], [[886.0, 693.0], [915.0, 693.0], [915.0, 768.0], [886.0, 768.0]]], "lines": ["．．．実は", "あたし"]}, {"box": [428, 354, 511, 495], "vertical": true, "font_size": 27, "lines_coords": [[[479.0, 354.0], [511.0, 354.0], [511.0, 409.0], [479.0, 409.0]], [[454.0, 356.0], [481.0, 356.0], [481.0, 453.0], [454.0, 453.0]], [[428.0, 359.0], [450.0, 359.0], [450.0, 495.0], [428.0, 495.0]]], "lines": ["．．．あ", "今１５です", "二中の三年で"]}, {"box": [87, 442, 168, 581], "vertical": true, "font_size": 25, "lines_coords": [[[142.0, 442.0], [168.0, 442.0], [168.0, 537.0], [142.0, 537.0]], [[114.0, 442.0], [140.0, 442.0], [140.0, 537.0], [114.0, 537.0]], [[87.0, 443.0], [109.0, 443.0], [109.0, 581.0], [87.0, 581.0]]], "lines": ["．．．なんだ", "タメかぁ", "あたしは三中"]}, {"box": [239, 735, 289, 832], "vertical": true, "font_size": 24, "lines_coords": [[[267.0, 739.0], [289.0, 739.0], [289.0, 831.0], [267.0, 831.0]], [[239.0, 735.0], [265.0, 735.0], [265.0, 832.0], [239.0, 832.0]]], "lines": ["あたしも", "実は．．．"]}, {"box": [767, 768, 870, 950], "vertical": true, "font_size": 25, "lines_coords": [[[845.0, 768.0], [869.0, 768.0], [870.0, 948.0], [847.0, 948.0]], [[820.0, 771.0], [842.0, 771.0], [842.0, 950.0], [820.0, 950.0]], [[794.0, 771.0], [815.0, 771.0], [814.0, 948.0], [792.0, 948.0]], [[767.0, 775.0], [789.0, 775.0], [789.0, 948.0], [767.0, 948.0]]], "lines": ["男の人と遊ぶって", "したことないから", "どうしたらいいか", "わかんなくって．．"]}, {"box": [131, 870, 212, 1032], "vertical": true, "font_size": 24, "lines_coords": [[[184.0, 870.0], [212.0, 870.0], [212.0, 945.0], [184.0, 945.0]], [[159.0, 873.0], [181.0, 873.0], [181.0, 1032.0], [159.0, 1032.0]], [[131.0, 873.0], [153.0, 873.0], [153.0, 967.0], [131.0, 967.0]]], "lines": ["なんか", "気遅れしちゃう", "よね．．．．．．"]}, {"box": [686, 1378, 855, 1435], "vertical": false, "font_size": 24.0, "lines_coords": [[[686.0, 1382.0], [839.0, 1378.0], [839.0, 1404.0], [686.0, 1409.0]], [[689.0, 1414.0], [855.0, 1412.0], [855.0, 1434.0], [689.0, 1435.0]]], "lines": ["お食事温水", "御休憩１００"]}, {"box": [204, 1287, 228, 1356], "vertical": true, "font_size": 23, "lines_coords": [[[204.0, 1287.0], [228.0, 1287.0], [228.0, 1356.0], [204.0, 1356.0]]], "lines": ["わぁ！！"]}, {"box": [139, 1387, 189, 1503], "vertical": true, "font_size": 23, "lines_coords": [[[167.0, 1387.0], [189.0, 1387.0], [189.0, 1501.0], [167.0, 1501.0]], [[139.0, 1387.0], [161.0, 1387.0], [161.0, 1503.0], [139.0, 1503.0]]], "lines": ["よかったァ", "仲間がいて"]}], "img_path": "030.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [569, 85, 720, 103], "vertical": false, "font_size": 20, "lines_coords": [[[569.0, 83.0], [720.0, 83.0], [720.0, 105.0], [569.0, 105.0]]], "lines": ["２０１７年１０月１０日：２５、返信する"]}, {"box": [370, 0, 574, 75], "vertical": false, "font_size": 12, "lines_coords": [[[378.0, 18.0], [529.0, 18.0], [529.0, 29.0], [378.0, 29.0]], [[378.0, 32.0], [514.0, 32.0], [514.0, 43.0], [378.0, 43.0]], [[378.0, 46.0], [564.0, 46.0], [564.0, 57.0], [378.0, 57.0]], [[376.0, 59.0], [447.0, 59.0], [447.0, 75.0], [376.0, 75.0]]], "lines": ["最寄にアフィリエイトが増えたと", "ブログのメイドが目につきます", "結城人が変わったのなら報告すべきです", "貴方誰ですか？"]}, {"box": [568, 242, 718, 258], "vertical": false, "font_size": 16, "lines_coords": [[[568.0, 242.0], [718.0, 242.0], [718.0, 258.0], [568.0, 258.0]]], "lines": ["２０１１／０８／１０以前、返信する"]}, {"box": [368, 86, 520, 103], "vertical": false, "font_size": 18, "lines_coords": [[[382.0, 85.0], [515.0, 85.0], [515.0, 105.0], [382.0, 105.0]]], "lines": ["Ｐｏｓｔａｄも、名無しの妖精さん"]}, {"box": [367, 245, 545, 315], "vertical": false, "font_size": 12, "lines_coords": [[[367.0, 245.0], [447.0, 245.0], [447.0, 256.0], [367.0, 256.0]], [[378.0, 259.0], [472.0, 259.0], [472.0, 270.0], [378.0, 270.0]], [[376.0, 273.0], [529.0, 273.0], [529.0, 284.0], [376.0, 284.0]], [[378.0, 287.0], [539.0, 287.0], [539.0, 298.0], [378.0, 298.0]], [[376.0, 300.0], [465.0, 300.0], [465.0, 315.0], [376.0, 315.0]]], "lines": ["．．．Ｐｏｓｔｅｄ．ｔｙ．", "・ゴブリンシャーク", "記事へのコメント以外の曲間等に", "メールフォームへ連絡くださるよ", "お願いいたします。"]}, {"box": [197, -2, 330, 332], "vertical": true, "font_size": 133, "lines_coords": [[[197.0, -2.0], [330.0, -2.0], [330.0, 332.0], [197.0, 332.0]]], "lines": ["それでも、"]}, {"box": [198, -1, 330, 334], "vertical": true, "font_size": 132, "lines_coords": [[[198.0, -1.0], [330.0, -1.0], [330.0, 334.0], [198.0, 334.0]]], "lines": ["．．．"]}, {"box": [894, 430, 919, 526], "vertical": true, "font_size": 21, "lines_coords": [[[895.0, 431.0], [919.0, 431.0], [919.0, 471.0], [895.0, 471.0]], [[897.0, 489.0], [915.0, 489.0], [915.0, 521.0], [897.0, 521.0]]], "lines": ["ポー", "へ"]}, {"box": [673, 1128, 734, 1145], "vertical": false, "font_size": 17, "lines_coords": [[[673.0, 1128.0], [734.0, 1128.0], [734.0, 1145.0], [673.0, 1145.0]]], "lines": ["送信済み"]}, {"box": [625, 1156, 723, 1178], "vertical": false, "font_size": 22, "lines_coords": [[[625.0, 1156.0], [723.0, 1156.0], [723.0, 1178.0], [625.0, 1178.0]]], "lines": ["・ロゴミ箱"]}, {"box": [220, 1068, 243, 1114], "vertical": true, "font_size": 23, "lines_coords": [[[220.0, 1068.0], [243.0, 1068.0], [243.0, 1114.0], [220.0, 1114.0]]], "lines": ["カタ"]}, {"box": [1042, 1434, 1056, 1486], "vertical": true, "font_size": 14, "lines_coords": [[[1042.0, 1434.0], [1056.0, 1434.0], [1056.0, 1486.0], [1042.0, 1486.0]]], "lines": ["０２４"]}, {"box": [564, 1288, 988, 1576], "vertical": false, "font_size": 29, "lines_coords": [[[583.0, 1310.0], [848.0, 1310.0], [848.0, 1331.0], [583.0, 1331.0]], [[581.0, 1335.0], [973.0, 1335.0], [973.0, 1356.0], [581.0, 1356.0]], [[581.0, 1360.0], [922.0, 1360.0], [922.0, 1381.0], [581.0, 1381.0]], [[583.0, 1387.0], [975.0, 1387.0], [975.0, 1407.0], [583.0, 1407.0]], [[579.0, 1434.0], [887.0, 1434.0], [887.0, 1460.0], [579.0, 1460.0]], [[581.0, 1462.0], [983.0, 1462.0], [983.0, 1484.0], [581.0, 1484.0]], [[581.0, 1487.0], [679.0, 1487.0], [679.0, 1509.0], [581.0, 1509.0]], [[564.0, 1495.0], [928.0, 1495.0], [928.0, 1576.0], [564.0, 1576.0]]], "lines": ["メールにて失礼いたします。", "先ほどコメントさせていただいた者です", "老婆心ながら管理人様に何か事故等", "あったのではないかと心配しております。", "もし何か事情があるのであれば、", "差し支えの無い、範囲で教えていただければ", "幸いです。", "幸いです。大きなお世話だったらすみません。よろしくお願いします。"]}, {"box": [172, 1197, 186, 1233], "vertical": true, "font_size": 14, "lines_coords": [[[172.0, 1197.0], [186.0, 1197.0], [186.0, 1233.0], [172.0, 1233.0]]], "lines": ["カタ"]}, {"box": [137, 1437, 156, 1476], "vertical": true, "font_size": 19, "lines_coords": [[[137.0, 1439.0], [156.0, 1439.0], [156.0, 1476.0], [137.0, 1476.0]]], "lines": ["カタ"]}], "img_path": "031.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [615, 34, 701, 45], "vertical": false, "font_size": 11, "lines_coords": [[[615.0, 34.0], [701.0, 34.0], [701.0, 45.0], [615.0, 45.0]]], "lines": ["トリアアー。わたし"]}, {"box": [576, 79, 642, 95], "vertical": false, "font_size": 16, "lines_coords": [[[576.0, 79.0], [642.0, 79.0], [642.0, 95.0], [576.0, 95.0]]], "lines": ["仲名．．．"]}, {"box": [535, 156, 875, 250], "vertical": false, "font_size": 18, "lines_coords": [[[537.0, 165.0], [869.0, 165.0], [869.0, 185.0], [537.0, 185.0]], [[537.0, 189.0], [754.0, 189.0], [754.0, 204.0], [537.0, 204.0]], [[536.0, 206.0], [797.0, 207.0], [797.0, 228.0], [536.0, 226.0]], [[539.0, 231.0], [826.0, 231.0], [826.0, 246.0], [539.0, 246.0]]], "lines": ["ご明察の通り、ブログの管理人は昨年他界しました。", "現在は弟の僕が引き継いでいます", "ご報告が滞ってしまい申し訳ありません", "今後も当ブログをよろしくお願いいいたします"]}, {"box": [539, 115, 662, 134], "vertical": false, "font_size": 17, "lines_coords": [[[539.0, 117.0], [662.0, 115.0], [662.0, 132.0], [539.0, 134.0]]], "lines": ["ゴブリンシャーク様"]}, {"box": [128, 182, 373, 254], "vertical": false, "font_size": 16, "lines_coords": [[[132.0, 182.0], [315.0, 182.0], [315.0, 198.0], [132.0, 198.0]], [[142.0, 200.0], [359.0, 198.0], [359.0, 215.0], [142.0, 217.0]], [[145.0, 218.0], [331.0, 218.0], [331.0, 234.0], [145.0, 234.0]], [[142.0, 237.0], [168.0, 237.0], [168.0, 254.0], [142.0, 254.0]]], "lines": ["素敵人、やりしていうそれにしても、何かの", "静香、龍水を、ゴツリシシャークです", "日時、２０１４年６月、『．．．あの", "兄先"]}, {"box": [126, 275, 429, 408], "vertical": false, "font_size": 17, "lines_coords": [[[129.0, 281.0], [403.0, 281.0], [403.0, 296.0], [129.0, 296.0]], [[126.0, 298.0], [190.0, 298.0], [190.0, 314.0], [126.0, 314.0]], [[126.0, 315.0], [246.0, 315.0], [246.0, 331.0], [126.0, 331.0]], [[126.0, 332.0], [332.0, 332.0], [332.0, 348.0], [126.0, 348.0]], [[126.0, 348.0], [361.0, 350.0], [361.0, 367.0], [126.0, 365.0]], [[126.0, 368.0], [190.0, 368.0], [190.0, 384.0], [126.0, 384.0]], [[126.0, 382.0], [418.0, 382.0], [418.0, 403.0], [126.0, 403.0]]], "lines": ["１５０さん、お亡くなりにならわたんですね", "残念です", "心中お察しします", "けどなぜ弟さんがなりすまして", "ブログを続けていたのかがちょっと", "美羽間です。", "もしよろしければご説明いただけませんか？"]}, {"box": [500, 379, 527, 476], "vertical": true, "font_size": 25, "lines_coords": [[[500.0, 379.0], [525.0, 379.0], [525.0, 421.0], [500.0, 421.0]]], "lines": ["ポー"]}, {"box": [47, 1432, 63, 1489], "vertical": true, "font_size": 16, "lines_coords": [[[47.0, 1432.0], [63.0, 1432.0], [63.0, 1489.0], [47.0, 1489.0]]], "lines": ["０２５"]}], "img_path": "032.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [806, 92, 889, 251], "vertical": true, "font_size": 26, "lines_coords": [[[862.0, 92.0], [889.0, 92.0], [889.0, 209.0], [862.0, 209.0]], [[834.0, 92.0], [861.0, 92.0], [861.0, 251.0], [834.0, 251.0]], [[806.0, 92.0], [830.0, 92.0], [831.0, 182.0], [808.0, 182.0]]], "lines": ["小梅ちゃん", "いっしょに食べ", "ようよぅ"]}, {"box": [892, 832, 970, 993], "vertical": true, "font_size": 23, "lines_coords": [[[948.0, 832.0], [969.0, 832.0], [969.0, 993.0], [948.0, 993.0]], [[917.0, 832.0], [944.0, 832.0], [944.0, 928.0], [917.0, 928.0]], [[892.0, 832.0], [912.0, 832.0], [912.0, 992.0], [892.0, 992.0]]], "lines": ["．．．小梅ちゃんは", "受験勉強", "はかどってる？"]}, {"box": [242, 834, 328, 951], "vertical": true, "font_size": 24, "lines_coords": [[[300.0, 834.0], [328.0, 834.0], [328.0, 909.0], [300.0, 909.0]], [[275.0, 835.0], [296.0, 835.0], [296.0, 951.0], [275.0, 951.0]], [[242.0, 834.0], [270.0, 834.0], [270.0, 931.0], [242.0, 931.0]]], "lines": ["夏休み", "入ってから", "全然．．．"]}, {"box": [146, 931, 225, 1070], "vertical": true, "font_size": 24, "lines_coords": [[[203.0, 931.0], [225.0, 931.0], [225.0, 1046.0], [203.0, 1046.0]], [[171.0, 931.0], [198.0, 931.0], [198.0, 1028.0], [171.0, 1028.0]], [[146.0, 932.0], [167.0, 932.0], [167.0, 1070.0], [146.0, 1070.0]]], "lines": ["．．．でもまぁ", "来週から", "合宿だから．．．"]}, {"box": [895, 1129, 966, 1274], "vertical": true, "font_size": 19, "lines_coords": [[[944.0, 1129.0], [964.0, 1129.0], [964.0, 1273.0], [944.0, 1273.0]], [[919.0, 1131.0], [939.0, 1131.0], [939.0, 1256.0], [919.0, 1256.0]], [[895.0, 1132.0], [912.0, 1132.0], [912.0, 1214.0], [895.0, 1214.0]]], "lines": ["香菜恵ちゃんは", "誰に誘われて", "来たの？"]}, {"box": [1036, 1430, 1050, 1485], "vertical": true, "font_size": 14, "lines_coords": [[[1036.0, 1430.0], [1050.0, 1430.0], [1050.0, 1485.0], [1036.0, 1485.0]]], "lines": ["Ｄ２６"]}, {"box": [240, 1228, 337, 1392], "vertical": true, "font_size": 19, "lines_coords": [[[315.0, 1228.0], [337.0, 1228.0], [337.0, 1353.0], [315.0, 1353.0]], [[290.0, 1228.0], [311.0, 1228.0], [311.0, 1392.0], [290.0, 1392.0]], [[267.0, 1229.0], [284.0, 1229.0], [284.0, 1329.0], [267.0, 1329.0]], [[240.0, 1229.0], [257.0, 1229.0], [257.0, 1329.0], [240.0, 1329.0]]], "lines": ["車運転してた", "人がウチの兄貴の", "高校の時の", "同級生でさ"]}, {"box": [153, 1378, 223, 1526], "vertical": true, "font_size": 19, "lines_coords": [[[201.0, 1378.0], [223.0, 1378.0], [223.0, 1465.0], [201.0, 1465.0]], [[176.0, 1378.0], [196.0, 1378.0], [196.0, 1526.0], [176.0, 1526.0]], [[153.0, 1381.0], [170.0, 1381.0], [170.0, 1482.0], [153.0, 1482.0]]], "lines": ["昔何度か", "会ったことある", "だけだけど"]}], "img_path": "033.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [919, 58, 967, 197], "vertical": true, "font_size": 21, "lines_coords": [[[919.0, 62.0], [940.0, 62.0], [940.0, 196.0], [919.0, 196.0]]], "lines": ["もしかしてさ"]}, {"box": [628, 62, 654, 133], "vertical": true, "font_size": 26, "lines_coords": [[[628.0, 62.0], [654.0, 62.0], [654.0, 93.0], [628.0, 93.0]]], "lines": ["ん"]}, {"box": [215, 207, 296, 370], "vertical": true, "font_size": 22, "lines_coords": [[[270.0, 207.0], [296.0, 207.0], [296.0, 304.0], [270.0, 304.0]], [[243.0, 209.0], [265.0, 209.0], [265.0, 370.0], [243.0, 370.0]], [[215.0, 210.0], [237.0, 210.0], [237.0, 326.0], [215.0, 326.0]]], "lines": ["あたしも", "その感じなんか", "わかるー．．．"]}, {"box": [729, 385, 810, 523], "vertical": true, "font_size": 22, "lines_coords": [[[787.0, 385.0], [809.0, 385.0], [809.0, 500.0], [787.0, 500.0]], [[758.0, 385.0], [779.0, 385.0], [779.0, 478.0], [758.0, 478.0]], [[729.0, 387.0], [751.0, 387.0], [751.0, 523.0], [729.0, 523.0]]], "lines": ["小梅ちゃん", "三崎先輩", "ねらってる？"]}, {"box": [919, 601, 940, 739], "vertical": true, "font_size": 24, "lines_coords": [[[919.0, 601.0], [940.0, 601.0], [940.0, 739.0], [919.0, 739.0]]], "lines": ["．．．だってさァ"]}, {"box": [503, 390, 555, 528], "vertical": true, "font_size": 22, "lines_coords": [[[531.0, 390.0], [553.0, 390.0], [553.0, 526.0], [531.0, 526.0]], [[503.0, 390.0], [525.0, 390.0], [525.0, 528.0], [503.0, 528.0]]], "lines": ["なんて言うか", "なんだろ．．．"]}, {"box": [509, 596, 583, 740], "vertical": true, "font_size": 24, "lines_coords": [[[561.0, 598.0], [583.0, 598.0], [583.0, 740.0], [561.0, 740.0]], [[533.0, 596.0], [561.0, 596.0], [561.0, 667.0], [533.0, 667.0]], [[511.0, 596.0], [533.0, 596.0], [531.0, 739.0], [509.0, 739.0]]], "lines": ["なんか喋ってて", "退屈？", "っていうかさァ"]}, {"box": [123, 346, 201, 531], "vertical": true, "font_size": 22, "lines_coords": [[[179.0, 348.0], [201.0, 348.0], [201.0, 485.0], [179.0, 485.0]], [[151.0, 348.0], [173.0, 348.0], [173.0, 531.0], [151.0, 531.0]], [[123.0, 346.0], [143.0, 346.0], [143.0, 482.0], [123.0, 482.0]]], "lines": ["こんなんなら", "家で勉強してれば", "よかったなァ"]}, {"box": [787, 742, 900, 928], "vertical": true, "font_size": 24, "lines_coords": [[[876.0, 742.0], [900.0, 742.0], [897.0, 882.0], [873.0, 882.0]], [[845.0, 742.0], [872.0, 742.0], [872.0, 884.0], [845.0, 884.0]], [[819.0, 743.0], [840.0, 743.0], [840.0, 928.0], [819.0, 928.0]], [[790.0, 742.0], [817.0, 742.0], [814.0, 835.0], [787.0, 835.0]]], "lines": ["歳上のくせに", "ガキっぽいし", "なんかチャラくて", "うざいし"]}, {"box": [211, 807, 237, 892], "vertical": true, "font_size": 23, "lines_coords": [[[211.0, 807.0], [237.0, 807.0], [237.0, 892.0], [211.0, 892.0]]], "lines": ["そう！！"]}, {"box": [225, 945, 320, 979], "vertical": false, "font_size": 16.0, "lines_coords": [[[225.0, 945.0], [317.0, 945.0], [317.0, 962.0], [225.0, 962.0]], [[226.0, 964.0], [320.0, 964.0], [320.0, 979.0], [226.0, 979.0]]], "lines": ["お忘れ物のない", "ご注意ください"]}, {"box": [218, 1009, 287, 1064], "vertical": false, "font_size": 20.666666666666668, "lines_coords": [[[223.0, 1009.0], [287.0, 1009.0], [287.0, 1031.0], [223.0, 1031.0]], [[225.0, 1026.0], [286.0, 1026.0], [286.0, 1048.0], [225.0, 1048.0]], [[218.0, 1046.0], [281.0, 1046.0], [281.0, 1064.0], [218.0, 1064.0]]], "lines": ["浮気の所は部屋大体の", "今後４８でも", "何だやっぱりおまえでしょう"]}, {"box": [132, 900, 181, 1040], "vertical": true, "font_size": 23, "lines_coords": [[[159.0, 900.0], [181.0, 900.0], [181.0, 1017.0], [159.0, 1017.0]], [[132.0, 900.0], [153.0, 900.0], [153.0, 1040.0], [132.0, 1040.0]]], "lines": ["そんな感じ", "そんな感じ！！"]}, {"box": [850, 1204, 956, 1365], "vertical": true, "font_size": 23, "lines_coords": [[[934.0, 1207.0], [956.0, 1207.0], [956.0, 1321.0], [934.0, 1321.0]], [[905.0, 1204.0], [926.0, 1204.0], [928.0, 1365.0], [906.0, 1365.0]], [[878.0, 1207.0], [900.0, 1207.0], [900.0, 1343.0], [878.0, 1343.0]], [[850.0, 1207.0], [872.0, 1207.0], [872.0, 1284.0], [850.0, 1284.0]]], "lines": ["別に何かを", "期待してたって", "訳じゃないん", "だけど"]}, {"box": [720, 1287, 869, 1428], "vertical": true, "font_size": 23, "lines_coords": [[[851.0, 1295.0], [869.0, 1295.0], [869.0, 1343.0], [851.0, 1343.0]], [[805.0, 1287.0], [831.0, 1287.0], [831.0, 1403.0], [805.0, 1403.0]], [[775.0, 1287.0], [801.0, 1287.0], [801.0, 1426.0], [775.0, 1426.0]], [[747.0, 1287.0], [773.0, 1287.0], [773.0, 1428.0], [747.0, 1428.0]], [[720.0, 1289.0], [742.0, 1289.0], [742.0, 1425.0], [720.0, 1425.0]]], "lines": ["．．．", "かといって", "ノリについて", "いけないのも", "なんか悪いし"]}, {"box": [106, 1315, 186, 1475], "vertical": true, "font_size": 20, "lines_coords": [[[161.0, 1315.0], [182.0, 1315.0], [182.0, 1475.0], [161.0, 1475.0]], [[131.0, 1317.0], [153.0, 1317.0], [153.0, 1431.0], [131.0, 1431.0]], [[106.0, 1317.0], [123.0, 1317.0], [123.0, 1425.0], [106.0, 1425.0]]], "lines": ["香菜恵ちゃんが", "いてくれて", "よかったー"]}], "img_path": "034.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [909, 210, 944, 276], "vertical": true, "font_size": 33, "lines_coords": [[[909.0, 210.0], [944.0, 210.0], [944.0, 276.0], [909.0, 276.0]]], "lines": ["うん"]}, {"box": [814, 354, 878, 445], "vertical": true, "font_size": 33, "lines_coords": [[[845.0, 354.0], [878.0, 354.0], [878.0, 445.0], [845.0, 445.0]], [[814.0, 356.0], [844.0, 356.0], [844.0, 406.0], [814.0, 406.0]]], "lines": ["あたし", "もー"]}, {"box": [262, 758, 568, 830], "vertical": false, "font_size": 34, "lines_coords": [[[262.0, 759.0], [568.0, 759.0], [568.0, 796.0], [262.0, 796.0]], [[262.0, 796.0], [512.0, 796.0], [512.0, 828.0], [262.0, 828.0]]], "lines": ["僕の兄は自殺しました。", "さんきいとしうえｎ"]}, {"box": [139, 742, 236, 759], "vertical": false, "font_size": 17, "lines_coords": [[[139.0, 742.0], [236.0, 742.0], [236.0, 759.0], [139.0, 759.0]]], "lines": ["わたちＶＣ．ｅｘｅ"]}, {"box": [933, 776, 964, 828], "vertical": true, "font_size": 30, "lines_coords": [[[933.0, 776.0], [964.0, 776.0], [964.0, 828.0], [933.0, 828.0]]], "lines": ["カタ"]}, {"box": [894, 814, 923, 862], "vertical": true, "font_size": 30, "lines_coords": [[[894.0, 814.0], [923.0, 814.0], [923.0, 862.0], [894.0, 862.0]]], "lines": ["カタ"]}, {"box": [964, 1053, 995, 1106], "vertical": true, "font_size": 31, "lines_coords": [[[964.0, 1053.0], [995.0, 1053.0], [995.0, 1106.0], [964.0, 1106.0]]], "lines": ["カタ"]}, {"box": [697, 1135, 728, 1190], "vertical": true, "font_size": 27, "lines_coords": [[[697.0, 1135.0], [728.0, 1135.0], [728.0, 1190.0], [697.0, 1190.0]]], "lines": ["カタ"]}, {"box": [170, 1032, 587, 1220], "vertical": false, "font_size": 23, "lines_coords": [[[190.0, 1035.0], [348.0, 1035.0], [348.0, 1051.0], [190.0, 1051.0]], [[192.0, 1053.0], [476.0, 1053.0], [476.0, 1068.0], [192.0, 1068.0]], [[190.0, 1073.0], [522.0, 1073.0], [522.0, 1089.0], [190.0, 1089.0]], [[189.0, 1092.0], [464.0, 1092.0], [464.0, 1107.0], [189.0, 1107.0]], [[190.0, 1110.0], [584.0, 1110.0], [584.0, 1126.0], [190.0, 1126.0]], [[189.0, 1129.0], [361.0, 1129.0], [361.0, 1145.0], [189.0, 1145.0]], [[186.0, 1145.0], [428.0, 1145.0], [428.0, 1167.0], [186.0, 1167.0]], [[171.0, 1148.0], [395.0, 1153.0], [393.0, 1220.0], [170.0, 1215.0]]], "lines": ["僕の兄は自殺しました", "３歳年トの兄は生まれっき少し足が悪く", "そのせいか子供の頃から学校を休みがちでした。", "由学の頃でどいいじめに会ったようで", "両親の半ばれで家族全員東言から田舎に引っ越しましたが", "高校に進学してから再び", "部屋に引き離りがちになりました", "部屋に引き寄りかちになり、兄はいわゆるオタクでした。けど"]}, {"box": [131, 775, 239, 978], "vertical": false, "font_size": 27.0, "lines_coords": [[[137.0, 775.0], [181.0, 775.0], [181.0, 800.0], [137.0, 800.0]], [[134.0, 809.0], [226.0, 809.0], [226.0, 837.0], [134.0, 837.0]], [[135.0, 842.0], [231.0, 842.0], [231.0, 870.0], [135.0, 870.0]], [[131.0, 878.0], [221.0, 881.0], [221.0, 907.0], [131.0, 904.0]], [[132.0, 912.0], [206.0, 915.0], [204.0, 943.0], [131.0, 940.0]], [[134.0, 951.0], [239.0, 951.0], [239.0, 978.0], [134.0, 978.0]]], "lines": ["Ｂｏｏｋ", "ｂｏｏｔｓｔａｔ", "Ｂｒａｎｄｉｎｇ", "Ｃｕｒｓｏｒｓ", "ｄｅｂｕｇ", "ｄｉａｇｎｏｓｔ"]}, {"box": [1035, 1430, 1049, 1484], "vertical": true, "font_size": 14, "lines_coords": [[[1035.0, 1430.0], [1049.0, 1430.0], [1049.0, 1484.0], [1035.0, 1484.0]]], "lines": ["Ｏ２８"]}, {"box": [672, 1187, 695, 1242], "vertical": true, "font_size": 27, "lines_coords": [[[672.0, 1187.0], [695.0, 1187.0], [695.0, 1242.0], [672.0, 1242.0]]], "lines": ["カタ"]}, {"box": [534, 1193, 597, 1282], "vertical": true, "font_size": 32, "lines_coords": [[[565.0, 1193.0], [597.0, 1193.0], [597.0, 1246.0], [565.0, 1246.0]], [[534.0, 1226.0], [565.0, 1226.0], [565.0, 1282.0], [534.0, 1282.0]]], "lines": ["カタ", "カタ"]}, {"box": [529, 1373, 583, 1484], "vertical": true, "font_size": 30, "lines_coords": [[[553.0, 1373.0], [583.0, 1373.0], [583.0, 1429.0], [553.0, 1429.0]], [[529.0, 1429.0], [559.0, 1429.0], [559.0, 1484.0], [529.0, 1484.0]]], "lines": ["カタ", "カタ"]}, {"box": [156, 1249, 180, 1298], "vertical": true, "font_size": 23, "lines_coords": [[[156.0, 1250.0], [179.0, 1250.0], [179.0, 1298.0], [156.0, 1298.0]]], "lines": ["カタ"]}, {"box": [134, 1467, 167, 1523], "vertical": true, "font_size": 30, "lines_coords": [[[134.0, 1468.0], [164.0, 1467.0], [167.0, 1521.0], [137.0, 1523.0]]], "lines": ["カタ"]}], "img_path": "035.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [558, 1, 987, 246], "vertical": false, "font_size": 20, "lines_coords": [[[567.0, 9.0], [872.0, 9.0], [872.0, 25.0], [567.0, 25.0]], [[567.0, 31.0], [983.0, 31.0], [983.0, 46.0], [567.0, 46.0]], [[564.0, 50.0], [762.0, 50.0], [762.0, 70.0], [564.0, 70.0]], [[565.0, 73.0], [834.0, 73.0], [834.0, 89.0], [565.0, 89.0]], [[564.0, 92.0], [787.0, 92.0], [787.0, 112.0], [564.0, 112.0]], [[564.0, 114.0], [880.0, 114.0], [880.0, 134.0], [564.0, 134.0]], [[558.0, 126.0], [845.0, 132.0], [845.0, 165.0], [558.0, 159.0]], [[562.0, 151.0], [856.0, 151.0], [856.0, 178.0], [562.0, 178.0]], [[565.0, 179.0], [884.0, 179.0], [884.0, 195.0], [565.0, 195.0]], [[565.0, 201.0], [690.0, 201.0], [690.0, 217.0], [565.0, 217.0]], [[564.0, 218.0], [787.0, 220.0], [787.0, 240.0], [564.0, 239.0]]], "lines": ["由学の頃でどいいじめに会ったようで", "両親の半ばれ．．．気性は、自由のから田舎にもっ越しまし", "高校に進学してから再び", "部屋に引き産りがちになりました", "兄はいわゆるオタクでした。", "けど性格に誰があったとは思えません。", "むしろ優しすぎたんだと思います。", "両親とも普通に会話をしてましたし", "弟である僕と部屋が同じでしたが１０営業を", "したこともなく", "気の合う友人のようでした。"]}, {"box": [151, 292, 181, 346], "vertical": true, "font_size": 28, "lines_coords": [[[151.0, 292.0], [181.0, 292.0], [181.0, 346.0], [151.0, 346.0]]], "lines": ["カタ"]}, {"box": [125, 354, 150, 403], "vertical": true, "font_size": 28, "lines_coords": [[[125.0, 354.0], [150.0, 354.0], [150.0, 403.0], [125.0, 403.0]]], "lines": ["カタ"]}, {"box": [911, 375, 967, 500], "vertical": true, "font_size": 28, "lines_coords": [[[937.0, 375.0], [967.0, 375.0], [967.0, 428.0], [937.0, 428.0]], [[911.0, 448.0], [937.0, 448.0], [937.0, 500.0], [911.0, 500.0]]], "lines": ["カタ", "カタ"]}, {"box": [525, 451, 554, 504], "vertical": true, "font_size": 29, "lines_coords": [[[525.0, 451.0], [554.0, 451.0], [554.0, 504.0], [525.0, 504.0]]], "lines": ["カタ"]}, {"box": [123, 584, 642, 704], "vertical": false, "font_size": 109, "lines_coords": [[[125.0, 584.0], [642.0, 595.0], [640.0, 704.0], [123.0, 693.0]]], "lines": ["でも兄は自殺し"]}, {"box": [919, 1281, 950, 1335], "vertical": true, "font_size": 30, "lines_coords": [[[919.0, 1281.0], [950.0, 1281.0], [950.0, 1335.0], [919.0, 1335.0]]], "lines": ["カタ"]}, {"box": [883, 1343, 912, 1400], "vertical": true, "font_size": 30, "lines_coords": [[[883.0, 1343.0], [912.0, 1343.0], [912.0, 1400.0], [883.0, 1400.0]]], "lines": ["カタ"]}, {"box": [256, 1268, 830, 1485], "vertical": false, "font_size": 28, "lines_coords": [[[256.0, 1306.0], [531.0, 1301.0], [531.0, 1332.0], [256.0, 1337.0]], [[257.0, 1332.0], [820.0, 1332.0], [820.0, 1368.0], [257.0, 1368.0]], [[261.0, 1368.0], [612.0, 1368.0], [612.0, 1395.0], [261.0, 1395.0]], [[261.0, 1398.0], [769.0, 1398.0], [769.0, 1425.0], [261.0, 1425.0]], [[259.0, 1428.0], [815.0, 1429.0], [815.0, 1456.0], [259.0, 1454.0]], [[262.0, 1460.0], [740.0, 1460.0], [740.0, 1482.0], [262.0, 1482.0]]], "lines": ["でも兄は自殺しました。", "兄のＰＰにはしっかり遺書が保存されていました。", "僕はその遺書を削除しました。", "両親を無駄に悲しませたくなかったんです。", "警察はあっさりと事故死で処理してくれました。", "兄が亡くなった９月１５日はぼくのたん．"]}, {"box": [268, 1248, 573, 1270], "vertical": false, "font_size": 22, "lines_coords": [[[268.0, 1248.0], [573.0, 1248.0], [573.0, 1270.0], [268.0, 1270.0]]], "lines": ["気の合う友人のようでした"]}, {"box": [196, 1310, 250, 1410], "vertical": true, "font_size": 27, "lines_coords": [[[218.0, 1310.0], [250.0, 1310.0], [250.0, 1364.0], [218.0, 1364.0]], [[196.0, 1343.0], [218.0, 1343.0], [218.0, 1410.0], [196.0, 1410.0]]], "lines": ["カタ", "カタ"]}, {"box": [120, 1237, 170, 1479], "vertical": true, "font_size": 21.0, "lines_coords": [[[148.0, 1243.0], [170.0, 1243.0], [170.0, 1473.0], [148.0, 1473.0]], [[120.0, 1237.0], [140.0, 1237.0], [140.0, 1479.0], [120.0, 1479.0]]], "lines": ["ＰＧＨＰＣＨＥＭＭＨＯＨＭＩＭＰＩＦＩ", "この時期は、この段階から"]}, {"box": [79, 1451, 109, 1503], "vertical": true, "font_size": 30, "lines_coords": [[[79.0, 1451.0], [109.0, 1451.0], [109.0, 1503.0], [79.0, 1503.0]]], "lines": ["カタ"]}], "img_path": "036.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [911, 99, 996, 270], "vertical": true, "font_size": 22, "lines_coords": [[[973.0, 100.0], [995.0, 100.0], [995.0, 270.0], [973.0, 270.0]], [[942.0, 100.0], [964.0, 100.0], [964.0, 215.0], [942.0, 215.0]], [[911.0, 100.0], [933.0, 100.0], [933.0, 246.0], [911.0, 246.0]]], "lines": ["ぎゃあっはっは", "馬鹿テメー", "歌えよ三崎！！"]}, {"box": [948, 617, 980, 670], "vertical": true, "font_size": 30, "lines_coords": [[[948.0, 617.0], [980.0, 617.0], [980.0, 670.0], [948.0, 670.0]]], "lines": ["カタ"]}, {"box": [719, 379, 780, 487], "vertical": true, "font_size": 27, "lines_coords": [[[751.0, 379.0], [779.0, 379.0], [776.0, 485.0], [748.0, 485.0]], [[719.0, 379.0], [745.0, 379.0], [745.0, 487.0], [719.0, 487.0]]], "lines": ["酒が足ん", "ねーよ！！"]}, {"box": [917, 671, 945, 728], "vertical": true, "font_size": 30, "lines_coords": [[[917.0, 671.0], [945.0, 671.0], [945.0, 728.0], [917.0, 728.0]]], "lines": ["カタ"]}, {"box": [231, 598, 872, 835], "vertical": false, "font_size": 42, "lines_coords": [[[509.0, 598.0], [612.0, 598.0], [612.0, 614.0], [509.0, 614.0]], [[253.0, 615.0], [776.0, 618.0], [776.0, 645.0], [253.0, 642.0]], [[253.0, 642.0], [809.0, 642.0], [809.0, 678.0], [253.0, 678.0]], [[251.0, 673.0], [662.0, 673.0], [662.0, 710.0], [251.0, 710.0]], [[231.0, 679.0], [872.0, 679.0], [872.0, 785.0], [231.0, 785.0]], [[256.0, 768.0], [794.0, 768.0], [794.0, 790.0], [256.0, 790.0]], [[254.0, 796.0], [520.0, 796.0], [520.0, 823.0], [254.0, 823.0]], [[797.0, 767.0], [833.0, 767.0], [833.0, 835.0], [797.0, 835.0]]], "lines": ["ソロビッツェ", "兄が亡くなった９月１５日は僕の誕生日です。", "これにはいったい何の意味があるんでしょうか？", "少なくとも僕は自分の誕生日の度に", "少なくとも新築自分の誕生日に日本で知っていますが、私達も自分で思い出していた。もしかしたらこれは誰でも気になるのかもわかりませんでしょうかもしれないですが", "しれないし、それに気付かない僕に苛立ちを威", "いたのかもしれません。", "カタ"]}, {"box": [154, 400, 242, 548], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 400.0], [242.0, 400.0], [239.0, 500.0], [211.0, 500.0]], [[182.0, 401.0], [211.0, 401.0], [211.0, 501.0], [182.0, 501.0]], [[154.0, 400.0], [176.0, 400.0], [176.0, 546.0], [154.0, 546.0]]], "lines": ["１０分ね！！", "１０分で俺", "決めるから！！"]}, {"box": [170, 650, 221, 673], "vertical": false, "font_size": 19, "lines_coords": [[[170.0, 654.0], [220.0, 650.0], [221.0, 668.0], [171.0, 673.0]]], "lines": ["ＰＩＮＳＴ．"]}, {"box": [101, 587, 228, 723], "vertical": false, "font_size": 68.0, "lines_coords": [[[164.0, 587.0], [228.0, 631.0], [165.0, 723.0], [101.0, 679.0]], [[150.0, 604.0], [207.0, 607.0], [206.0, 631.0], [148.0, 628.0]]], "lines": ["いやいや．．．", "ＤｉｇｉｔａｌｌｅＤｏｗｍｌｏｅ"]}, {"box": [198, 748, 225, 800], "vertical": true, "font_size": 27, "lines_coords": [[[198.0, 748.0], [225.0, 748.0], [225.0, 800.0], [198.0, 800.0]]], "lines": ["カタ"]}, {"box": [118, 603, 145, 793], "vertical": true, "font_size": 27, "lines_coords": [[[118.0, 603.0], [145.0, 603.0], [145.0, 793.0], [118.0, 793.0]]], "lines": ["顔線きき顔顔して"]}, {"box": [804, 785, 827, 830], "vertical": true, "font_size": 23, "lines_coords": [[[804.0, 785.0], [827.0, 785.0], [827.0, 830.0], [804.0, 830.0]]], "lines": ["カタ"]}, {"box": [930, 1270, 959, 1321], "vertical": true, "font_size": 29, "lines_coords": [[[930.0, 1270.0], [959.0, 1270.0], [959.0, 1321.0], [930.0, 1321.0]]], "lines": ["カタ"]}, {"box": [226, 1248, 1014, 1485], "vertical": false, "font_size": 45, "lines_coords": [[[226.0, 1248.0], [892.0, 1248.0], [892.0, 1360.0], [226.0, 1360.0]], [[251.0, 1328.0], [775.0, 1328.0], [775.0, 1359.0], [251.0, 1359.0]], [[256.0, 1392.0], [698.0, 1392.0], [698.0, 1418.0], [256.0, 1418.0]], [[254.0, 1421.0], [1014.0, 1420.0], [1014.0, 1446.0], [254.0, 1448.0]], [[254.0, 1450.0], [700.0, 1451.0], [700.0, 1479.0], [254.0, 1478.0]]], "lines": ["今にして思うと事が変わっていましたが、男子でもたちの建築室の関係を楽しめないのです。", "本音を言わない、関係だったようにも思います。", "兄はブログの運営だけは積極的でした。", "コメントのやり取り切は兄の唯一の外とのコミュニケーションでした", "僕はブログのこうしんをやめるのをたｍ"]}, {"box": [215, 1350, 245, 1400], "vertical": true, "font_size": 26, "lines_coords": [[[215.0, 1350.0], [245.0, 1350.0], [245.0, 1400.0], [215.0, 1400.0]]], "lines": ["カタ"]}, {"box": [146, 1264, 175, 1400], "vertical": true, "font_size": 29, "lines_coords": [[[146.0, 1264.0], [175.0, 1264.0], [175.0, 1400.0], [146.0, 1400.0]]], "lines": ["Ｈｏｌｉｍｉｎｆｉｎｉｎａ＿ＫＢＢ！！"]}, {"box": [189, 1389, 212, 1445], "vertical": true, "font_size": 26, "lines_coords": [[[189.0, 1389.0], [212.0, 1389.0], [212.0, 1445.0], [189.0, 1445.0]]], "lines": ["カタ"]}, {"box": [120, 1264, 140, 1492], "vertical": true, "font_size": 20, "lines_coords": [[[120.0, 1264.0], [140.0, 1264.0], [140.0, 1492.0], [120.0, 1492.0]]], "lines": ["そういうことで、"]}], "img_path": "037.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [872, 156, 925, 270], "vertical": true, "font_size": 23, "lines_coords": [[[901.0, 156.0], [925.0, 156.0], [925.0, 209.0], [901.0, 209.0]], [[872.0, 156.0], [894.0, 156.0], [894.0, 270.0], [872.0, 270.0]]], "lines": ["あれ", "気分悪い？"]}, {"box": [880, 643, 946, 724], "vertical": true, "font_size": 66, "lines_coords": [[[880.0, 643.0], [946.0, 643.0], [946.0, 724.0], [880.0, 724.0]]], "lines": ["カタカタ"]}, {"box": [146, 450, 1045, 829], "vertical": false, "font_size": 87, "lines_coords": [[[236.0, 484.0], [976.0, 471.0], [976.0, 518.0], [236.0, 531.0]], [[237.0, 504.0], [809.0, 512.0], [809.0, 560.0], [237.0, 553.0]], [[279.0, 554.0], [955.0, 546.0], [955.0, 615.0], [279.0, 623.0]], [[148.0, 450.0], [1045.0, 453.0], [1044.0, 829.0], [146.0, 826.0]], [[292.0, 609.0], [440.0, 606.0], [440.0, 634.0], [292.0, 637.0]], [[292.0, 635.0], [901.0, 635.0], [901.0, 671.0], [292.0, 671.0]], [[243.0, 726.0], [595.0, 726.0], [595.0, 759.0], [243.0, 759.0]], [[917.0, 639.0], [953.0, 639.0], [953.0, 695.0], [917.0, 695.0]]], "lines": ["コメントのやり取りは兄の唯一ボード。再びユールこの外とのコミュニケーションで", "僕はブログの更新を止めるのをためらいました。", "新の停止で兄の存在が完全に消えより僕一人で兄め存在を抱えていそしまうのが嫌だったし、かなければならない事が", "それでも、", "いったんです。", "ていつの間にかブログを浸然と更新し続けることが", "もう限界なのかもしれません。", "カタ"]}, {"box": [134, 487, 164, 534], "vertical": false, "font_size": 47, "lines_coords": [[[134.0, 487.0], [164.0, 487.0], [164.0, 534.0], [134.0, 534.0]]], "lines": ["Ｈｅｌｐｈｈｈ．ｅ"]}, {"box": [165, 545, 193, 603], "vertical": true, "font_size": 28, "lines_coords": [[[165.0, 545.0], [193.0, 545.0], [193.0, 603.0], [165.0, 603.0]]], "lines": ["カタ"]}, {"box": [118, 721, 145, 773], "vertical": true, "font_size": 27, "lines_coords": [[[118.0, 721.0], [145.0, 721.0], [145.0, 773.0], [118.0, 773.0]]], "lines": ["カタ"]}, {"box": [794, 973, 890, 992], "vertical": false, "font_size": 17, "lines_coords": [[[794.0, 973.0], [890.0, 975.0], [890.0, 992.0], [794.0, 990.0]]], "lines": ["私たちを選んだというわけで、"]}, {"box": [798, 993, 858, 1009], "vertical": false, "font_size": 16, "lines_coords": [[[798.0, 993.0], [858.0, 993.0], [858.0, 1009.0], [798.0, 1009.0]]], "lines": ["私は、ＣＤＰＯＳ７"]}, {"box": [915, 1276, 947, 1331], "vertical": true, "font_size": 31, "lines_coords": [[[915.0, 1276.0], [947.0, 1276.0], [947.0, 1331.0], [915.0, 1331.0]]], "lines": ["カタ"]}, {"box": [876, 1317, 906, 1373], "vertical": true, "font_size": 31, "lines_coords": [[[876.0, 1317.0], [906.0, 1317.0], [906.0, 1373.0], [876.0, 1373.0]]], "lines": ["カタ"]}, {"box": [242, 1299, 854, 1429], "vertical": false, "font_size": 29, "lines_coords": [[[243.0, 1307.0], [744.0, 1307.0], [744.0, 1334.0], [243.0, 1334.0]], [[243.0, 1337.0], [850.0, 1335.0], [850.0, 1364.0], [243.0, 1365.0]], [[245.0, 1370.0], [775.0, 1370.0], [775.0, 1396.0], [245.0, 1396.0]], [[242.0, 1395.0], [648.0, 1396.0], [648.0, 1429.0], [242.0, 1428.0]]], "lines": ["兄の自殺のきっかけはいじめだと思います。", "どんな理由であね僕は兄を蔑んだ奴らを許しません。", "他人の痛みを想像できない奴らを許しません。", "けれどとどめを刺したのは僕です。"]}, {"box": [240, 1246, 590, 1278], "vertical": false, "font_size": 32, "lines_coords": [[[240.0, 1246.0], [590.0, 1246.0], [590.0, 1278.0], [240.0, 1278.0]]], "lines": ["もう限界なのかもしれません。"]}, {"box": [248, 1489, 461, 1518], "vertical": false, "font_size": 26, "lines_coords": [[[248.0, 1489.0], [461.0, 1492.0], [461.0, 1518.0], [248.0, 1515.0]]], "lines": ["こんやもきっとあり"]}, {"box": [135, 1256, 217, 1354], "vertical": false, "font_size": 18.5, "lines_coords": [[[135.0, 1256.0], [217.0, 1256.0], [217.0, 1278.0], [135.0, 1278.0]], [[140.0, 1284.0], [217.0, 1284.0], [217.0, 1301.0], [140.0, 1301.0]], [[145.0, 1310.0], [215.0, 1310.0], [215.0, 1328.0], [145.0, 1328.0]], [[143.0, 1337.0], [203.0, 1337.0], [203.0, 1354.0], [143.0, 1354.0]]], "lines": ["ＭｏｄｅｒｎＬａ", "ｍｓｄｆｍａｐ", "ｎｏｔｅｐａｄ．", "Ｏｆｆｉｎｅｙ"]}, {"box": [156, 1396, 182, 1448], "vertical": true, "font_size": 26, "lines_coords": [[[156.0, 1396.0], [182.0, 1396.0], [182.0, 1448.0], [156.0, 1448.0]]], "lines": ["カタ"]}, {"box": [59, 1430, 73, 1483], "vertical": true, "font_size": 14, "lines_coords": [[[59.0, 1430.0], [73.0, 1430.0], [73.0, 1483.0], [59.0, 1483.0]]], "lines": ["Ｏ３１"]}], "img_path": "038.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [758, 345, 789, 400], "vertical": true, "font_size": 31, "lines_coords": [[[758.0, 345.0], [789.0, 345.0], [789.0, 400.0], [758.0, 400.0]]], "lines": ["カタ"]}, {"box": [215, 107, 980, 139], "vertical": false, "font_size": 32, "lines_coords": [[[215.0, 107.0], [980.0, 107.0], [980.0, 139.0], [215.0, 139.0]]], "lines": ["今夜もきっと、兄は窓の外から僕の事を呼ぶんです。"]}, {"box": [215, 456, 337, 493], "vertical": false, "font_size": 33, "lines_coords": [[[217.0, 456.0], [337.0, 460.0], [336.0, 493.0], [215.0, 489.0]]], "lines": ["助けて。"]}, {"box": [905, 1046, 987, 1209], "vertical": true, "font_size": 25, "lines_coords": [[[964.0, 1048.0], [986.0, 1048.0], [986.0, 1187.0], [964.0, 1187.0]], [[934.0, 1046.0], [961.0, 1046.0], [961.0, 1209.0], [934.0, 1209.0]], [[905.0, 1048.0], [931.0, 1048.0], [931.0, 1142.0], [905.0, 1142.0]]], "lines": ["：酒無理なら", "言ってくれりゃ", "いいのに"]}, {"box": [201, 781, 256, 898], "vertical": true, "font_size": 24, "lines_coords": [[[232.0, 782.0], [254.0, 782.0], [254.0, 898.0], [232.0, 898.0]], [[201.0, 781.0], [228.0, 781.0], [228.0, 878.0], [201.0, 878.0]]], "lines": ["．．．佐藤さん", "大丈夫？"]}, {"box": [318, 1071, 376, 1128], "vertical": true, "font_size": 32, "lines_coords": [[[345.0, 1071.0], [376.0, 1071.0], [376.0, 1126.0], [345.0, 1126.0]], [[318.0, 1071.0], [350.0, 1071.0], [350.0, 1128.0], [318.0, 1128.0]]], "lines": ["まあ", "まあ"]}, {"box": [1030, 1429, 1044, 1484], "vertical": true, "font_size": 14, "lines_coords": [[[1030.0, 1429.0], [1044.0, 1429.0], [1044.0, 1484.0], [1030.0, 1484.0]]], "lines": ["０３２"]}, {"box": [422, 1370, 502, 1528], "vertical": true, "font_size": 22, "lines_coords": [[[478.0, 1370.0], [501.0, 1370.0], [498.0, 1485.0], [475.0, 1485.0]], [[450.0, 1370.0], [472.0, 1370.0], [472.0, 1528.0], [450.0, 1528.0]], [[422.0, 1370.0], [443.0, 1370.0], [443.0, 1506.0], [422.0, 1506.0]]], "lines": ["．．．三崎先輩", "ここ女子トイレ", "ですよ．．．．．．？"]}, {"box": [129, 1379, 209, 1540], "vertical": true, "font_size": 22, "lines_coords": [[[187.0, 1379.0], [209.0, 1379.0], [209.0, 1517.0], [187.0, 1517.0]], [[157.0, 1379.0], [181.0, 1379.0], [179.0, 1540.0], [156.0, 1540.0]], [[129.0, 1381.0], [151.0, 1381.0], [151.0, 1539.0], [129.0, 1539.0]]], "lines": ["．．．コレ吸う？", "こっちなら平気", "かもしんないし"]}], "img_path": "039.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [912, 76, 966, 215], "vertical": true, "font_size": 24, "lines_coords": [[[939.0, 76.0], [966.0, 76.0], [966.0, 171.0], [939.0, 171.0]], [[912.0, 78.0], [934.0, 78.0], [934.0, 215.0], [912.0, 215.0]]], "lines": ["．．．．．．それ", "なんですか？"]}, {"box": [325, 109, 405, 246], "vertical": true, "font_size": 23, "lines_coords": [[[378.0, 109.0], [404.0, 109.0], [404.0, 225.0], [378.0, 225.0]], [[353.0, 109.0], [375.0, 109.0], [375.0, 246.0], [353.0, 246.0]], [[325.0, 109.0], [347.0, 109.0], [347.0, 223.0], [325.0, 223.0]]], "lines": ["いいじゃん", "こんなの全然", "フツーだし"]}, {"box": [733, 381, 820, 543], "vertical": true, "font_size": 27, "lines_coords": [[[787.0, 381.0], [820.0, 381.0], [820.0, 476.0], [787.0, 476.0]], [[764.0, 384.0], [786.0, 384.0], [786.0, 543.0], [764.0, 543.0]], [[736.0, 382.0], [759.0, 382.0], [756.0, 498.0], [733.0, 498.0]]], "lines": ["．．．タバコ", "みたいなもん？", "つーか．．．．．"]}, {"box": [862, 689, 943, 850], "vertical": true, "font_size": 22, "lines_coords": [[[919.0, 689.0], [940.0, 689.0], [940.0, 848.0], [919.0, 848.0]], [[890.0, 689.0], [912.0, 689.0], [912.0, 850.0], [890.0, 850.0]], [[862.0, 690.0], [884.0, 690.0], [884.0, 826.0], [862.0, 826.0]]], "lines": ["夏休みなんだし", "はっちゃければ", "いいのに．．．"]}, {"box": [653, 503, 711, 596], "vertical": true, "font_size": 27, "lines_coords": [[[679.0, 504.0], [711.0, 504.0], [711.0, 554.0], [679.0, 554.0]], [[653.0, 503.0], [679.0, 503.0], [679.0, 596.0], [653.0, 596.0]]], "lines": ["．．．？", "怖いの？"]}, {"box": [92, 426, 203, 612], "vertical": true, "font_size": 24, "lines_coords": [[[173.0, 426.0], [203.0, 426.0], [203.0, 500.0], [173.0, 500.0]], [[148.0, 429.0], [170.0, 429.0], [170.0, 589.0], [148.0, 589.0]], [[120.0, 428.0], [142.0, 428.0], [142.0, 612.0], [120.0, 612.0]], [[92.0, 428.0], [114.0, 428.0], [114.0, 587.0], [92.0, 587.0]]], "lines": ["俺毎日", "カバンに入れて", "持ち歩いてっけど", "全然バレねーし"]}, {"box": [872, 1045, 898, 1128], "vertical": true, "font_size": 26, "lines_coords": [[[872.0, 1045.0], [898.0, 1045.0], [898.0, 1128.0], [872.0, 1128.0]]], "lines": ["．．．先輩"]}, {"box": [135, 751, 243, 912], "vertical": true, "font_size": 21, "lines_coords": [[[218.0, 753.0], [240.0, 753.0], [240.0, 867.0], [218.0, 867.0]], [[193.0, 753.0], [211.0, 753.0], [211.0, 864.0], [193.0, 864.0]], [[162.0, 751.0], [184.0, 751.0], [184.0, 912.0], [162.0, 912.0]], [[135.0, 753.0], [156.0, 753.0], [156.0, 889.0], [135.0, 889.0]]], "lines": ["．．．君も今日", "こういうの", "期待して来たん", "じゃないの？"]}, {"box": [787, 1159, 814, 1285], "vertical": true, "font_size": 26, "lines_coords": [[[787.0, 1159.0], [814.0, 1159.0], [814.0, 1285.0], [787.0, 1285.0]]], "lines": ["だめです．．"]}, {"box": [167, 1253, 225, 1385], "vertical": true, "font_size": 27, "lines_coords": [[[198.0, 1253.0], [225.0, 1253.0], [225.0, 1360.0], [198.0, 1360.0]], [[167.0, 1256.0], [189.0, 1256.0], [189.0, 1385.0], [167.0, 1385.0]]], "lines": ["だめです", "だめです．．．"]}, {"box": [96, 1403, 129, 1489], "vertical": true, "font_size": 27, "lines_coords": [[[96.0, 1403.0], [129.0, 1403.0], [129.0, 1489.0], [96.0, 1489.0]]], "lines": ["だ．．．．．"]}], "img_path": "040.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [961, 110, 995, 189], "vertical": true, "font_size": 29, "lines_coords": [[[961.0, 110.0], [995.0, 110.0], [995.0, 189.0], [961.0, 189.0]]], "lines": ["．．．ん"]}, {"box": [931, 156, 955, 231], "vertical": true, "font_size": 29, "lines_coords": [[[931.0, 156.0], [955.0, 156.0], [955.0, 231.0], [931.0, 231.0]]], "lines": ["ッ！！"]}, {"box": [164, 171, 270, 231], "vertical": true, "font_size": 33, "lines_coords": [[[231.0, 171.0], [270.0, 171.0], [270.0, 217.0], [231.0, 217.0]], [[195.0, 171.0], [234.0, 171.0], [234.0, 229.0], [195.0, 229.0]], [[164.0, 176.0], [192.0, 176.0], [192.0, 231.0], [164.0, 231.0]]], "lines": ["ん", "んー", "んー"]}, {"box": [164, 242, 190, 329], "vertical": true, "font_size": 33, "lines_coords": [[[164.0, 242.0], [190.0, 242.0], [190.0, 329.0], [164.0, 329.0]]], "lines": ["ーッ！！"]}, {"box": [515, 1068, 598, 1165], "vertical": true, "font_size": 27, "lines_coords": [[[570.0, 1068.0], [598.0, 1068.0], [598.0, 1143.0], [570.0, 1143.0]], [[542.0, 1068.0], [570.0, 1068.0], [570.0, 1165.0], [542.0, 1165.0]], [[515.0, 1070.0], [539.0, 1070.0], [539.0, 1140.0], [515.0, 1140.0]]], "lines": ["あんま", "大きい声", "出すと"]}, {"box": [146, 1095, 231, 1234], "vertical": true, "font_size": 27, "lines_coords": [[[195.0, 1095.0], [231.0, 1095.0], [231.0, 1151.0], [195.0, 1151.0]], [[173.0, 1100.0], [195.0, 1100.0], [195.0, 1214.0], [173.0, 1214.0]], [[146.0, 1100.0], [168.0, 1100.0], [168.0, 1234.0], [146.0, 1234.0]]], "lines": ["他の", "お客さんに", "迷惑でしょ？"]}, {"box": [1038, 1429, 1052, 1481], "vertical": true, "font_size": 14, "lines_coords": [[[1038.0, 1429.0], [1052.0, 1429.0], [1052.0, 1481.0], [1038.0, 1481.0]]], "lines": ["０３４"]}, {"box": [506, 1315, 559, 1454], "vertical": true, "font_size": 24, "lines_coords": [[[533.0, 1315.0], [559.0, 1315.0], [559.0, 1410.0], [533.0, 1410.0]], [[509.0, 1315.0], [531.0, 1315.0], [528.0, 1454.0], [506.0, 1454.0]]], "lines": ["．．．．．．．", "すみません．．．"]}, {"box": [131, 1384, 212, 1523], "vertical": true, "font_size": 23, "lines_coords": [[[186.0, 1384.0], [212.0, 1384.0], [212.0, 1479.0], [186.0, 1479.0]], [[161.0, 1385.0], [182.0, 1385.0], [182.0, 1523.0], [161.0, 1523.0]], [[131.0, 1385.0], [153.0, 1385.0], [153.0, 1501.0], [131.0, 1501.0]]], "lines": ["．．．今日は", "ちょっともう", "帰ります．．"]}], "img_path": "041.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [578, 67, 606, 255], "vertical": true, "font_size": 22, "lines_coords": [[[578.0, 67.0], [600.0, 67.0], [600.0, 251.0], [578.0, 251.0]]], "lines": ["：香菜恵ちゃん"]}, {"box": [110, 177, 172, 337], "vertical": true, "font_size": 24, "lines_coords": [[[146.0, 179.0], [168.0, 179.0], [168.0, 335.0], [146.0, 335.0]], [[110.0, 178.0], [137.0, 178.0], [137.0, 285.0], [110.0, 285.0]]], "lines": ["香菜恵ちゃん", "帰ろう！！"]}, {"box": [704, 412, 813, 573], "vertical": true, "font_size": 21, "lines_coords": [[[790.0, 414.0], [811.0, 414.0], [811.0, 573.0], [790.0, 573.0]], [[762.0, 412.0], [784.0, 412.0], [779.0, 551.0], [758.0, 551.0]], [[733.0, 414.0], [754.0, 414.0], [754.0, 573.0], [733.0, 573.0]], [[704.0, 414.0], [726.0, 414.0], [726.0, 506.0], [704.0, 506.0]]], "lines": ["帰るっつっても", "車出さないと", "駅までけっこう", "歩くよ？"]}, {"box": [554, 429, 609, 526], "vertical": true, "font_size": 30, "lines_coords": [[[583.0, 431.0], [609.0, 431.0], [609.0, 526.0], [583.0, 526.0]], [[554.0, 429.0], [584.0, 429.0], [584.0, 492.0], [554.0, 492.0]]], "lines": ["．．．冷める", "ナアー"]}, {"box": [429, 460, 517, 556], "vertical": true, "font_size": 30, "lines_coords": [[[483.0, 462.0], [517.0, 462.0], [517.0, 546.0], [483.0, 546.0]], [[454.0, 460.0], [489.0, 460.0], [489.0, 539.0], [454.0, 539.0]], [[429.0, 462.0], [456.0, 462.0], [456.0, 556.0], [429.0, 556.0]]], "lines": ["君今日", "何しに", "来たの？"]}, {"box": [157, 979, 238, 1142], "vertical": true, "font_size": 22, "lines_coords": [[[215.0, 979.0], [237.0, 979.0], [237.0, 1117.0], [215.0, 1117.0]], [[184.0, 979.0], [207.0, 979.0], [209.0, 1118.0], [186.0, 1118.0]], [[157.0, 981.0], [178.0, 981.0], [178.0, 1107.0], [157.0, 1107.0]]], "lines": ["それに比べて", "香菜恵ちゃん", "ノリいいわ！"]}, {"box": [52, 1422, 68, 1478], "vertical": true, "font_size": 16, "lines_coords": [[[52.0, 1422.0], [68.0, 1422.0], [68.0, 1478.0], [52.0, 1478.0]]], "lines": ["０３５"]}], "img_path": "042.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [895, 91, 918, 251], "vertical": true, "font_size": 22, "lines_coords": [[[895.0, 92.0], [917.0, 92.0], [917.0, 250.0], [895.0, 250.0]]], "lines": ["小梅ちゃん．．．"]}, {"box": [175, 551, 256, 692], "vertical": true, "font_size": 24, "lines_coords": [[[228.0, 551.0], [256.0, 551.0], [256.0, 625.0], [228.0, 625.0]], [[201.0, 551.0], [225.0, 551.0], [226.0, 668.0], [203.0, 668.0]], [[175.0, 554.0], [195.0, 554.0], [195.0, 692.0], [175.0, 692.0]]], "lines": ["ごめん", "今ちょっと", "邪魔だから．．．"]}, {"box": [461, 1148, 596, 1273], "vertical": false, "font_size": 16, "lines_coords": [[[467.0, 1146.0], [525.0, 1151.0], [523.0, 1170.0], [465.0, 1166.0]], [[497.0, 1199.0], [548.0, 1199.0], [548.0, 1214.0], [497.0, 1214.0]], [[493.0, 1207.0], [551.0, 1210.0], [551.0, 1230.0], [493.0, 1227.0]]], "lines": ["まったけお問いました。１０時間とどこはまたインターネットですが、そのせいかもしれません。", "そうでした。何があったとは思うません。できたんだと思います。", "助けちゃったんですから、そうだんだと思ってましたけど．．．これはしかしないので"]}, {"box": [534, 1296, 578, 1307], "vertical": false, "font_size": 11, "lines_coords": [[[534.0, 1296.0], [578.0, 1296.0], [578.0, 1307.0], [534.0, 1307.0]]], "lines": ["おまえっていたからも幸に見えたも感じて"]}, {"box": [506, 1309, 584, 1331], "vertical": false, "font_size": 22, "lines_coords": [[[506.0, 1309.0], [584.0, 1309.0], [584.0, 1331.0], [506.0, 1331.0]]], "lines": ["んですからね、それは．．．お前と一緒にいっぱい見た目はありませんでしょうか？"]}, {"box": [467, 1450, 476, 1457], "vertical": false, "font_size": 7, "lines_coords": [[[467.0, 1450.0], [476.0, 1450.0], [476.0, 1457.0], [467.0, 1457.0]]], "lines": ["アアア"]}, {"box": [464, 1334, 626, 1407], "vertical": false, "font_size": 15, "lines_coords": [[[565.0, 1354.0], [595.0, 1354.0], [595.0, 1369.0], [565.0, 1369.0]], [[531.0, 1366.0], [586.0, 1369.0], [586.0, 1389.0], [531.0, 1386.0]], [[547.0, 1382.0], [570.0, 1382.0], [570.0, 1397.0], [547.0, 1397.0]]], "lines": ["して。うどが嫌だったのかわからない事が", "見えてくれなければならないのはまだと思い出したことが多かってきていました。", "あいたい食事していない"]}, {"box": [460, 1400, 584, 1428], "vertical": false, "font_size": 13, "lines_coords": [[[465.0, 1398.0], [562.0, 1399.0], [562.0, 1419.0], [465.0, 1417.0]], [[470.0, 1416.0], [540.0, 1416.0], [540.0, 1427.0], [470.0, 1427.0]]], "lines": ["そんなことはありませんでしたが．．．ありがとうございますのですが、それはそうですから、", "そんなお仕事できないのかわからないけど．．．とかも教えてくれました。"]}, {"box": [1037, 1427, 1051, 1479], "vertical": true, "font_size": 14, "lines_coords": [[[1037.0, 1427.0], [1051.0, 1427.0], [1051.0, 1479.0], [1037.0, 1479.0]]], "lines": ["ひ３６"]}], "img_path": "043.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [604, 46, 628, 62], "vertical": false, "font_size": 16, "lines_coords": [[[604.0, 46.0], [628.0, 46.0], [628.0, 62.0], [604.0, 62.0]]], "lines": [