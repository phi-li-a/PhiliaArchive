: [[[895.0, 1082.0], [928.0, 1082.0], [928.0, 1167.0], [895.0, 1167.0]], [[869.0, 1087.0], [890.0, 1087.0], [890.0, 1237.0], [869.0, 1237.0]]], "lines": ["．．．全部", "俺が悪かった"]}, {"box": [186, 839, 212, 943], "vertical": true, "font_size": 26, "lines_coords": [[[186.0, 839.0], [212.0, 839.0], [212.0, 943.0], [186.0, 943.0]]], "lines": ["そうだな"]}, {"box": [118, 1353, 181, 1457], "vertical": true, "font_size": 30, "lines_coords": [[[148.0, 1353.0], [181.0, 1353.0], [181.0, 1435.0], [148.0, 1435.0]], [[118.0, 1354.0], [145.0, 1354.0], [145.0, 1457.0], [118.0, 1457.0]]], "lines": ["殴って", "ごめんな"]}], "img_path": "103.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [873, 1114, 954, 1323], "vertical": true, "font_size": 22, "lines_coords": [[[930.0, 1117.0], [951.0, 1117.0], [951.0, 1231.0], [930.0, 1231.0]], [[900.0, 1114.0], [922.0, 1114.0], [922.0, 1321.0], [900.0, 1321.0]], [[873.0, 1115.0], [895.0, 1115.0], [895.0, 1298.0], [873.0, 1298.0]]], "lines": ["台風１６号は", "勢力を拡大しながら、", "北上を続けており、"]}, {"box": [167, 1276, 248, 1481], "vertical": true, "font_size": 21, "lines_coords": [[[225.0, 1278.0], [245.0, 1278.0], [245.0, 1414.0], [225.0, 1414.0]], [[195.0, 1276.0], [215.0, 1276.0], [215.0, 1481.0], [195.0, 1481.0]], [[167.0, 1276.0], [189.0, 1276.0], [189.0, 1392.0], [167.0, 1392.0]]], "lines": ["週末にかけて", "関東沿岸を通過する", "見通しです"]}], "img_path": "104.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [561, 82, 725, 364], "vertical": true, "font_size": 25, "lines_coords": [[[689.0, 84.0], [722.0, 82.0], [725.0, 135.0], [692.0, 137.0]], [[664.0, 85.0], [692.0, 85.0], [692.0, 181.0], [664.0, 181.0]], [[648.0, 181.0], [670.0, 181.0], [670.0, 320.0], [648.0, 320.0]], [[617.0, 179.0], [640.0, 179.0], [644.0, 296.0], [620.0, 296.0]], [[589.0, 179.0], [615.0, 179.0], [615.0, 278.0], [589.0, 278.0]], [[564.0, 182.0], [584.0, 182.0], [584.0, 364.0], [564.0, 364.0]]], "lines": ["ねぇ", "小梅ー？", "この調子だと", "文化祭の日", "台風直撃", "なんじゃないの？"]}, {"box": [308, 73, 506, 190], "vertical": false, "font_size": 14, "lines_coords": [[[311.0, 76.0], [503.0, 75.0], [503.0, 90.0], [311.0, 92.0]], [[312.0, 90.0], [447.0, 90.0], [447.0, 106.0], [312.0, 106.0]], [[314.0, 118.0], [495.0, 118.0], [495.0, 129.0], [314.0, 129.0]], [[311.0, 132.0], [497.0, 132.0], [497.0, 148.0], [311.0, 148.0]], [[312.0, 148.0], [501.0, 148.0], [501.0, 159.0], [312.0, 159.0]], [[311.0, 160.0], [504.0, 160.0], [504.0, 176.0], [311.0, 176.0]], [[311.0, 175.0], [487.0, 175.0], [487.0, 190.0], [311.0, 190.0]]], "lines": ["はっひいえんどはっぴいえんど、は", "実は日、そこで、８００ギ２・５１０", "お兄ちゃんう、うあれよい？曲声黒", "昨３のアルバムをダウンロード．．", "１０日時間、２０時に「お金だねです", "２０１７／３１２：００までにお賦けしま", "お魚在庫あり。ご注文はお早めに。"]}, {"box": [414, 261, 438, 358], "vertical": true, "font_size": 19, "lines_coords": [[[415.0, 264.0], [434.0, 264.0], [434.0, 301.0], [415.0, 301.0]]], "lines": ["んー"]}, {"box": [311, 202, 386, 230], "vertical": false, "font_size": 11, "lines_coords": [[[315.0, 204.0], [382.0, 204.0], [382.0, 215.0], [315.0, 215.0]], [[314.0, 218.0], [381.0, 218.0], [381.0, 229.0], [314.0, 229.0]]], "lines": ["．．．", "そういえば、"]}, {"box": [311, 340, 375, 398], "vertical": false, "font_size": 16.5, "lines_coords": [[[311.0, 340.0], [368.0, 340.0], [368.0, 357.0], [311.0, 357.0]], [[311.0, 353.0], [373.0, 353.0], [373.0, 370.0], [311.0, 370.0]], [[311.0, 368.0], [370.0, 368.0], [370.0, 384.0], [311.0, 384.0]], [[311.0, 382.0], [375.0, 382.0], [375.0, 398.0], [311.0, 398.0]]], "lines": ["ＨＯＫのアル", "３時間以内の", "２０１５年１２月", "５点在庫あり。"]}, {"box": [179, 451, 234, 546], "vertical": true, "font_size": 25, "lines_coords": [[[203.0, 451.0], [234.0, 451.0], [234.0, 506.0], [203.0, 506.0]], [[179.0, 453.0], [201.0, 453.0], [201.0, 546.0], [179.0, 546.0]]], "lines": ["．．．あ", "そうそう"]}, {"box": [100, 589, 179, 753], "vertical": true, "font_size": 25, "lines_coords": [[[153.0, 589.0], [179.0, 589.0], [179.0, 729.0], [153.0, 729.0]], [[125.0, 589.0], [151.0, 589.0], [151.0, 753.0], [125.0, 753.0]], [[100.0, 592.0], [120.0, 592.0], [120.0, 728.0], [100.0, 728.0]]], "lines": ["今月の小遣い", "机の上に置いて", "おけばいい？"]}, {"box": [805, 910, 914, 1073], "vertical": true, "font_size": 23, "lines_coords": [[[889.0, 910.0], [912.0, 910.0], [914.0, 1026.0], [890.0, 1026.0]], [[862.0, 912.0], [884.0, 912.0], [884.0, 1071.0], [862.0, 1071.0]], [[834.0, 910.0], [858.0, 910.0], [855.0, 1050.0], [831.0, 1050.0]], [[805.0, 910.0], [826.0, 910.0], [828.0, 1073.0], [806.0, 1073.0]]], "lines": ["それ使って", "ネットで買って", "ほしいものが", "あるんだけど．．．"]}], "img_path": "105.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [706, 79, 897, 223], "vertical": false, "font_size": 22.666666666666668, "lines_coords": [[[706.0, 79.0], [792.0, 79.0], [792.0, 101.0], [706.0, 101.0]], [[712.0, 101.0], [764.0, 101.0], [764.0, 123.0], [712.0, 123.0]], [[709.0, 121.0], [808.0, 115.0], [809.0, 142.0], [711.0, 148.0]], [[714.0, 162.0], [895.0, 150.0], [897.0, 171.0], [715.0, 184.0]], [[715.0, 184.0], [890.0, 168.0], [892.0, 190.0], [717.0, 206.0]], [[720.0, 203.0], [848.0, 193.0], [850.0, 214.0], [722.0, 223.0]]], "lines": ["月００１月１２日", "一瞬辺", "一瞬！！出（ｎｏｎｔｔｌｅ）", "もう一ヶ月くらい会って、", "もう一ヶ月くらい会ないね。元気？文化祭ち", "ないん。いえ、やんと来るよね？"]}, {"box": [168, 525, 200, 579], "vertical": true, "font_size": 32, "lines_coords": [[[168.0, 525.0], [200.0, 525.0], [200.0, 579.0], [168.0, 579.0]]], "lines": ["ピッ"]}, {"box": [150, 370, 522, 489], "vertical": false, "font_size": 72, "lines_coords": [[[150.0, 370.0], [192.0, 370.0], [192.0, 487.0], [150.0, 487.0]], [[200.0, 407.0], [514.0, 370.0], [520.0, 425.0], [206.0, 462.0]], [[204.0, 443.0], [420.0, 425.0], [425.0, 468.0], [209.0, 487.0]]], "lines": ["もなゃ", "編集中のメール内容を＂ｗｉ－±±〟。", "消去しますか？"]}, {"box": [256, 539, 322, 567], "vertical": false, "font_size": 28, "lines_coords": [[[256.0, 539.0], [322.0, 539.0], [322.0, 567.0], [256.0, 567.0]]], "lines": ["はい"]}, {"box": [414, 514, 503, 546], "vertical": false, "font_size": 32, "lines_coords": [[[414.0, 514.0], [503.0, 514.0], [503.0, 546.0], [414.0, 546.0]]], "lines": ["いいえ"]}, {"box": [1036, 1426, 1051, 1480], "vertical": true, "font_size": 15, "lines_coords": [[[1036.0, 1426.0], [1051.0, 1426.0], [1051.0, 1480.0], [1036.0, 1480.0]]], "lines": ["Ｏ９８"]}], "img_path": "106.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [], "img_path": "107.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [267, 806, 769, 887], "vertical": false, "font_size": 27, "lines_coords": [[[267.0, 831.0], [758.0, 806.0], [759.0, 837.0], [268.0, 862.0]], [[271.0, 859.0], [425.0, 856.0], [425.0, 884.0], [271.0, 887.0]], [[417.0, 854.0], [564.0, 851.0], [564.0, 871.0], [417.0, 875.0]]], "lines": ["突然の手紙っちゃん。メールだとうまく気持ちが行からない。", "気がしたので、", "するれって書きますの"]}, {"box": [1033, 1426, 1046, 1479], "vertical": true, "font_size": 13, "lines_coords": [[[1033.0, 1426.0], [1046.0, 1426.0], [1046.0, 1479.0], [1033.0, 1479.0]]], "lines": ["１００"]}], "img_path": "108.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [228, 14, 514, 51], "vertical": false, "font_size": 24, "lines_coords": [[[228.0, 26.0], [251.0, 26.0], [251.0, 50.0], [228.0, 50.0]], [[240.0, 26.0], [512.0, 14.0], [514.0, 39.0], [242.0, 51.0]]], "lines": ["にえ", "しかしたので、子系界で書きます。"]}, {"box": [236, 67, 687, 262], "vertical": false, "font_size": 24, "lines_coords": [[[236.0, 84.0], [687.0, 67.0], [687.0, 93.0], [236.0, 110.0]], [[242.0, 115.0], [679.0, 98.0], [679.0, 120.0], [242.0, 137.0]], [[242.0, 146.0], [381.0, 139.0], [382.0, 160.0], [243.0, 168.0]], [[245.0, 175.0], [684.0, 154.0], [684.0, 179.0], [245.0, 200.0]], [[248.0, 206.0], [645.0, 189.0], [645.0, 210.0], [248.0, 228.0]], [[246.0, 235.0], [547.0, 220.0], [548.0, 246.0], [248.0, 262.0]]], "lines": ["石鹸型と言えまおうになって半身以上経って、君をあったいけど", "最近このままだとお互いが高まれてないになっちゃいそうで", "リフレさんじいです。", "お客さんが「本当は人のを考えたりしてるのか、よくわからない。", "わがえあげられないのかもしれないけど、すいでも", "言ってほしいって思ってそのは本当だよ。"]}, {"box": [406, 1000, 556, 1020], "vertical": false, "font_size": 16, "lines_coords": [[[406.0, 1000.0], [556.0, 1004.0], [556.0, 1020.0], [406.0, 1015.0]]], "lines": ["ってるのは本当だよ。"]}, {"box": [237, 1045, 747, 1197], "vertical": false, "font_size": 22, "lines_coords": [[[250.0, 1045.0], [661.0, 1071.0], [659.0, 1093.0], [248.0, 1067.0]], [[251.0, 1075.0], [734.0, 1107.0], [733.0, 1129.0], [250.0, 1096.0]], [[251.0, 1104.0], [728.0, 1135.0], [726.0, 1162.0], [250.0, 1131.0]], [[246.0, 1137.0], [661.0, 1164.0], [659.0, 1185.0], [245.0, 1159.0]], [[245.0, 1170.0], [384.0, 1179.0], [382.0, 1196.0], [243.0, 1187.0]]], "lines": ["優しい人が好きなら後しくなれるよぅに努めたい。", "思ってるよ。これからもなるべく一番着いいたかし、漫画の数にも", "ゲームとお事業しかも、と考えては正しい。持ってないって言ってた", "しまってもいえいどのアレバムあんまからい一生君に言われてい", "夏休みでて．．．"]}, {"box": [47, 1437, 60, 1491], "vertical": true, "font_size": 13, "lines_coords": [[[47.0, 1437.0], [60.0, 1437.0], [60.0, 1491.0], [47.0, 1491.0]]], "lines": ["１０１"]}], "img_path": "109.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [], "img_path": "110.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [561, 351, 903, 438], "vertical": false, "font_size": 22, "lines_coords": [[[565.0, 353.0], [840.0, 351.0], [840.0, 371.0], [565.0, 373.0]], [[562.0, 368.0], [872.0, 370.0], [872.0, 392.0], [562.0, 390.0]], [[565.0, 390.0], [845.0, 390.0], [845.0, 412.0], [565.0, 412.0]], [[567.0, 409.0], [634.0, 409.0], [634.0, 432.0], [567.0, 432.0]]], "lines": ["みしゃみしや＠ｓｈｈｅ「相談が大丈夫だったのです。", "賭けビリヤード１Ｑ．連勝中やば〜（・て", "俺に貢ぎたい愉快な仲間達集まれ〜ｗ", "２３分前"]}, {"box": [567, 491, 851, 549], "vertical": false, "font_size": 15, "lines_coords": [[[567.0, 492.0], [820.0, 492.0], [820.0, 507.0], [567.0, 507.0]], [[567.0, 512.0], [812.0, 512.0], [812.0, 528.0], [567.0, 528.0]], [[575.0, 531.0], [645.0, 531.0], [645.0, 546.0], [575.0, 546.0]]], "lines": ["みしゃみしやはっかｕｈｅｉ前までスメズメメンズ", "＠ｄｉａｇｅａｐｏｎｃｈｏｒｃｈａめａいいよ〜、", "月１０日"]}, {"box": [245, 616, 663, 722], "vertical": false, "font_size": 19, "lines_coords": [[[257.0, 618.0], [604.0, 618.0], [604.0, 637.0], [257.0, 637.0]], [[251.0, 643.0], [431.0, 643.0], [431.0, 662.0], [251.0, 662.0]], [[245.0, 668.0], [656.0, 671.0], [656.0, 697.0], [245.0, 694.0]], [[245.0, 701.0], [387.0, 702.0], [387.0, 723.0], [245.0, 722.0]]], "lines": ["これを書いてみたけど、ホントはすごくい顔が", "ズキズキして苦しいです。", "もしかしたら二度と会えなくなる時がどるかもなんて", "考えたくないよ。。"]}, {"box": [42, 1437, 58, 1491], "vertical": true, "font_size": 16, "lines_coords": [[[42.0, 1437.0], [58.0, 1437.0], [58.0, 1491.0], [42.0, 1491.0]]], "lines": ["１０３"]}], "img_path": "111.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [290, 0, 717, 89], "vertical": false, "font_size": 21.0, "lines_coords": [[[318.0, 0.0], [492.0, 3.0], [492.0, 23.0], [318.0, 18.0]], [[293.0, 28.0], [717.0, 39.0], [717.0, 60.0], [293.0, 50.0]], [[290.0, 60.0], [445.0, 67.0], [445.0, 89.0], [290.0, 82.0]]], "lines": ["ドキズキして苦しいです。", "もしかしたら二度と伝えたくなるほどるかもない", "考えたくないよ。。"]}, {"box": [278, 130, 599, 195], "vertical": false, "font_size": 22, "lines_coords": [[[281.0, 131.0], [548.0, 137.0], [548.0, 159.0], [281.0, 153.0]], [[282.0, 165.0], [590.0, 173.0], [590.0, 195.0], [282.0, 187.0]]], "lines": ["柔らいはる後辺のことが「もうきです」", "ずっとずらとそれを伝えたかったです"]}, {"box": [323, 1043, 504, 1168], "vertical": false, "font_size": 125, "lines_coords": [[[323.0, 1043.0], [504.0, 1043.0], [504.0, 1168.0], [323.0, 1168.0]]], "lines": ["な"]}, {"box": [284, 1426, 423, 1465], "vertical": false, "font_size": 20, "lines_coords": [[[284.0, 1445.0], [420.0, 1426.0], [423.0, 1446.0], [287.0, 1465.0]]], "lines": ["ＰＳ、高速生日およ"]}, {"box": [1042, 1439, 1054, 1489], "vertical": true, "font_size": 12, "lines_coords": [[[1042.0, 1439.0], [1054.0, 1439.0], [1054.0, 1489.0], [1042.0, 1489.0]]], "lines": ["１０４"]}], "img_path": "112.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [121, 128, 196, 292], "vertical": true, "font_size": 32, "lines_coords": [[[161.0, 128.0], [193.0, 128.0], [196.0, 292.0], [164.0, 292.0]], [[121.0, 128.0], [154.0, 128.0], [154.0, 260.0], [121.0, 260.0]]], "lines": ["いよォーし", "きたべ！！"]}, {"box": [32, 115, 70, 267], "vertical": true, "font_size": 38, "lines_coords": [[[32.0, 115.0], [70.0, 115.0], [70.0, 267.0], [32.0, 267.0]]], "lines": ["第１６話"]}, {"box": [884, 393, 950, 534], "vertical": true, "font_size": 32, "lines_coords": [[[915.0, 393.0], [950.0, 393.0], [950.0, 482.0], [915.0, 482.0]], [[887.0, 395.0], [915.0, 395.0], [912.0, 534.0], [884.0, 534.0]]], "lines": ["うーわ", "マッジかよ"]}, {"box": [842, 642, 944, 810], "vertical": true, "font_size": 32, "lines_coords": [[[905.0, 642.0], [944.0, 642.0], [944.0, 732.0], [905.0, 732.0]], [[875.0, 643.0], [906.0, 643.0], [903.0, 810.0], [872.0, 810.0]], [[842.0, 643.0], [869.0, 643.0], [869.0, 757.0], [842.0, 757.0]]], "lines": ["パチで", "増やした分が", "消える！！"]}, {"box": [293, 420, 375, 561], "vertical": true, "font_size": 26, "lines_coords": [[[345.0, 420.0], [375.0, 420.0], [375.0, 495.0], [345.0, 495.0]], [[318.0, 421.0], [345.0, 421.0], [345.0, 518.0], [318.0, 518.0]], [[293.0, 423.0], [315.0, 423.0], [315.0, 560.0], [293.0, 560.0]]], "lines": ["．．．あの", "営業時間", "もう過ぎて．．．"]}, {"box": [241, 1104, 655, 1220], "vertical": false, "font_size": 25, "lines_coords": [[[246.0, 1106.0], [600.0, 1104.0], [600.0, 1126.0], [246.0, 1128.0]], [[248.0, 1132.0], [651.0, 1132.0], [651.0, 1154.0], [248.0, 1154.0]], [[253.0, 1159.0], [570.0, 1160.0], [570.0, 1187.0], [253.0, 1185.0]], [[254.0, 1189.0], [314.0, 1189.0], [314.0, 1218.0], [254.0, 1218.0]]], "lines": ["みしゃみしやはｓｈｕｈｅｉ自身大丈夫ですよねえよ．．．", "街道沿いのビデ才屋にいるよ〜☆早く誰か", "挑戦しに来いってｗ俺無敵だけどｗ", "４分前"]}, {"box": [121, 834, 257, 1060], "vertical": true, "font_size": 30, "lines_coords": [[[226.0, 834.0], [254.0, 834.0], [256.0, 1031.0], [228.0, 1031.0]], [[193.0, 835.0], [220.0, 835.0], [220.0, 1031.0], [193.0, 1031.0]], [[156.0, 835.0], [187.0, 835.0], [187.0, 1060.0], [156.0, 1060.0]], [[121.0, 834.0], [153.0, 834.0], [153.0, 1007.0], [121.0, 1007.0]]], "lines": ["ちょっと待って", "ちょっと待って", "マジであと一打で", "決めっから！！"]}, {"box": [237, 1245, 610, 1315], "vertical": false, "font_size": 21, "lines_coords": [[[240.0, 1248.0], [584.0, 1245.0], [584.0, 1267.0], [240.0, 1270.0]], [[243.0, 1271.0], [547.0, 1271.0], [547.0, 1292.0], [243.0, 1292.0]], [[243.0, 1295.0], [576.0, 1295.0], [576.0, 1315.0], [243.0, 1315.0]]], "lines": ["みしゃみしや＠ｓｈｉｂｅ「申請求書は必要です。", "賭けビリヤード１Ｏ連勝中やだった", "俺に言ぎたし、愉快な仲間審査まれて、"]}, {"box": [49, 1436, 65, 1493], "vertical": true, "font_size": 16, "lines_coords": [[[49.0, 1436.0], [65.0, 1436.0], [65.0, 1493.0], [49.0, 1493.0]]], "lines": ["１０５"]}], "img_path": "113.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [903, 87, 930, 284], "vertical": true, "font_size": 27, "lines_coords": [[[903.0, 87.0], [930.0, 87.0], [930.0, 279.0], [903.0, 279.0]]], "lines": ["やまねーな．．．"]}, {"box": [186, 262, 270, 448], "vertical": true, "font_size": 23, "lines_coords": [[[245.0, 265.0], [267.0, 265.0], [267.0, 425.0], [245.0, 425.0]], [[214.0, 262.0], [236.0, 262.0], [236.0, 448.0], [214.0, 448.0]], [[186.0, 264.0], [212.0, 264.0], [212.0, 356.0], [186.0, 356.0]]], "lines": ["土井呼び出すか", "アイツなら親の車", "出せんべ"]}, {"box": [184, 490, 225, 501], "vertical": false, "font_size": 11, "lines_coords": [[[184.0, 490.0], [225.0, 490.0], [225.0, 501.0], [184.0, 501.0]]], "lines": ["．．．"]}, {"box": [906, 826, 994, 946], "vertical": true, "font_size": 26, "lines_coords": [[[967.0, 826.0], [994.0, 826.0], [991.0, 946.0], [964.0, 946.0]], [[936.0, 829.0], [962.0, 829.0], [962.0, 923.0], [936.0, 923.0]], [[909.0, 828.0], [933.0, 828.0], [930.0, 945.0], [906.0, 945.0]]], "lines": ["ちょっと俺", "傘探して", "くるわー．．．"]}, {"box": [793, 935, 870, 1053], "vertical": true, "font_size": 24, "lines_coords": [[[844.0, 935.0], [870.0, 935.0], [870.0, 1032.0], [844.0, 1032.0]], [[814.0, 937.0], [837.0, 937.0], [840.0, 1053.0], [817.0, 1053.0]]], "lines": ["修平くん", "お腹すいた"]}, {"box": [275, 848, 357, 1012], "vertical": true, "font_size": 26, "lines_coords": 