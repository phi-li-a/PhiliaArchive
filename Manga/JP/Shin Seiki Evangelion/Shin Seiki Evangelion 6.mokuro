, 471, 348, 525], "vertical": true, "font_size": 32.0, "lines": ["私も"]}, {"box": [895, 1004, 922, 1052], "vertical": true, "font_size": 27.0, "lines": ["え？"]}, {"box": [666, 795, 763, 927], "vertical": true, "font_size": 26.0, "lines": ["僕なんかより", "しっかり", "してるし"]}, {"box": [104, 801, 141, 913], "vertical": true, "font_size": 25.0, "lines": ["そう思う．．．"]}, {"box": [419, 1206, 564, 1320], "vertical": true, "font_size": 27.0, "lines": ["あ", "ウソウソ", "なんでも", "ないっ"]}], "img_path": "img036.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [842, 113, 957, 264], "vertical": true, "font_size": 27.0, "lines": ["鈴原．．．", "私のこと何か", "言ってない？"]}, {"box": [532, 119, 557, 146], "vertical": true, "font_size": 25.0, "lines": ["あ"]}, {"box": [445, 128, 503, 235], "vertical": true, "font_size": 25.0, "lines": ["深い意味は", "ないのよ"]}, {"box": [173, 104, 370, 293], "vertical": true, "font_size": 26.0, "lines": ["「口うるさい」とか", "「仕切り屋」とか", "「おせっかい」とか", "思われてないか", "なーっと", "思って．．"]}, {"box": [845, 510, 912, 663], "vertical": true, "font_size": 26.0, "lines": ["べつに何も", "言ってないなら"]}, {"box": [602, 389, 630, 437], "vertical": true, "font_size": 28.0, "lines": ["え？"]}, {"box": [490, 528, 515, 638], "vertical": true, "font_size": 24.0, "lines": ["鈴原って．．．"]}, {"box": [586, 639, 610, 767], "vertical": true, "font_size": 20.0, "lines": ["いいんだけど"]}, {"box": [401, 536, 457, 689], "vertical": true, "font_size": 24.0, "lines": ["アスカのこと", "好きなのかな．．．"]}, {"box": [94, 526, 131, 643], "vertical": true, "font_size": 32.0, "lines": ["はぁ？！"]}, {"box": [861, 1066, 951, 1201], "vertical": true, "font_size": 22.0, "lines": ["だっていつも", "仲良さそうに", "してるし．．．"]}, {"box": [256, 1078, 326, 1277], "vertical": true, "font_size": 28.0, "lines": ["仲いいっていうのか", "アレ．．"]}], "img_path": "img037.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [849, 110, 943, 244], "vertical": true, "font_size": 26.0, "lines": ["それは", "間違っても", "ないと思うよ"]}, {"box": [717, 113, 806, 267], "vert