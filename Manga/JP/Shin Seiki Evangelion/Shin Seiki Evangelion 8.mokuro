nt_size": 22.0, "lines": ["それより", "その情報", "本当なの？"]}, {"box": [363, 92, 510, 213], "vertical": true, "font_size": 24.0, "lines": ["世界フか国で", "エヴァ", "１３号機までの", "建造を", "開始って．．．"]}, {"box": [173, 75, 223, 172], "vertical": true, "font_size": 22.0, "lines": ["上海経由の", "情報です"]}, {"box": [70, 119, 149, 221], "vertical": true, "font_size": 22.0, "lines": ["ソースに", "信頼は", "おけますよ"]}, {"box": [642, 544, 731, 682], "vertical": true, "font_size": 22.0, "lines": ["何故この時期に", "量産を急ぐの", "かしら"]}, {"box": [711, 792, 727, 925], "vertical": true, "font_size": 22.0, "lines": ["．．．．．そうかしら"]}, {"box": [238, 537, 382, 716], "vertical": true, "font_size": 20.0, "lines": ["現在エヴァは", "２機も大破して", "いますし", "予備戦力の増強を", "急いでいるのでは？"]}, {"box": [538, 858, 678, 1036], "vertical": true, "font_size": 22.0, "lines": ["ここの２機にしても", "ドイツで建造中の", "５、６号機の両腕を", "回してもらってる", "のよ"]}, {"box": [62, 817, 172, 1012], "vertical": true, "font_size": 23.0, "lines": ["では", "使徒の複数同時展開の", "ケースを設定したもの", "でしょうか"]}], "img_path": "eva08-155.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [{"box": [713, 81, 734, 141], "vertical": true, "font_size": 21.0, "lines": ["そうね"]}, {"box": [416, 86, 475, 223], "vertical": true, "font_size": 21.0, "lines": ["でも非公開に", "行う理由がない"]}, {"box": [61, 88, 150, 245], "vertical": true, "font_size": 20.0, "lines": ["委員会の", "焦りらしきものを", "感じるわ"]}, {"box": [346, 397, 463, 499], "vertical": true, "font_size": 24.0, "lines": ["委員会には", "何か", "別の目的が", "あるのよ"]}, {"box": [428, 641, 542, 743], "vertical": true, "font_size": 26.0, "lines": ["もっと", "詳しく", "探りま", "しょうか？"]}, {"box": [69, 638, 124, 756], "vertical": true, "font_size": 22.0, "lines": ["まかしといて", "下さいっ"]}, {"box": [690, 906, 715, 969], "vertical": true, "font_size": 21.0, "lines": ["そうね"]}, {"box": [649, 950, 668, 1048], "vertical": true, "font_size": 21.0, "lines": ["できるなら"]}], "img_path": "eva08-156.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [{"box": [625, 492, 713, 631], "vertical": true, "font