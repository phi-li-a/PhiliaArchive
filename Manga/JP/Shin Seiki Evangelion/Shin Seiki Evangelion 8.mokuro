ze": 21.0, "lines": ["全く手荒な", "歓迎ですな"]}, {"box": [420, 108, 497, 160], "vertical": false, "font_size": 31.0, "lines": ["０１"]}, {"box": [174, 84, 227, 202], "vertical": true, "font_size": 23.0, "lines": ["非礼を詫びる", "つもりはない"]}, {"box": [108, 160, 163, 359], "vertical": true, "font_size": 23.0, "lines": ["君とゆっくり話をする", "ためには当然の処置だ"]}, {"box": [693, 573, 753, 674], "vertical": true, "font_size": 22.0, "lines": ["相変わらず", "ですね"]}, {"box": [427, 535, 516, 675], "vertical": true, "font_size": 21.0, "lines": ["議題としている", "問題が急務", "なのでね"]}, {"box": [320, 774, 356, 823], "vertical": true, "font_size": 32.0, "lines": ["左様"]}, {"box": [542, 984, 621, 1088], "vertical": true, "font_size": 18.0, "lines": ["私の都合は", "おかまいなし", "ですか？"]}, {"box": [96, 1017, 146, 1114], "vertical": true, "font_size": 22.0, "lines": ["わかって", "くれたまえ"]}], "img_path": "eva08-082.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [607, 156, 686, 238], "vertical": true, "font_size": 23.0, "lines": ["フランスト．．．！", "委員会", "ではなく"]}, {"box": [536, 227, 589, 366], "vertical": true, "font_size": 23.0, "lines": ["ゼーレの", "お出ましとは．．"]}, {"box": [590, 766, 708, 922], "vertical": true, "font_size": 21.0, "lines": ["Ｓ機関を自ら", "搭載した", "エヴァンゲリオン", "初号機．．"]}, {"box": [72, 950, 191, 1108], "vertical": true, "font_size": 24.0, "lines": ["それは理論上", "無限に稼働する", "半永久機関を手に", "入れたのと同義だ"]}], "img_path": "eva08-083.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [679, 86, 740, 170], "vertical": true, "font_size": 26.0, "lines": ["５分から", "無限．．．"]}, {"box": [465, 70, 552, 226], "vertical": true, "font_size": 20.0, "lines": ["絶対的存在を", "手にしてよいのは", "待たけた"]}, {"box": [126, 67, 215, 186], "vertical": true, "font_size": 22.0, "lines": ["我々に", "具象化された", "神は不要だ"]}, {"box": [600, 442, 662, 513], "vertical": true, "font_size": 32.0, "lines": ["突飛な", "話だ"]}, {"box": [333, 396, 395, 533], "vertical": true, "font_size": 20.0, "lines": ["人はその分を", "超えてはならん"]}, {"box": [606, 636, 623, 693], "vertical": true, "font_size": 17.0, "lines": ["まして"]}, {"box": [72, 891, 190, 1046], "vertical": true, "font_size": 22.0, "lines": ["あの碇の息子を", "神の子とする", "わけにはいかんの", "だよ"]}], "img_path": "eva08-084.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [631, 84, 714, 204], "vertical": true, "font_size": 23.0, "lines": ["おっしゃって", "いる意味が", "よく．．．"]}, {"box": [542, 112, 592, 192], "vertical": true, "font_size": 23.0, "lines": ["わかりま", "せんが"]}, {"box": [436, 40, 463, 198], "vertical": true, "font_size": 19.0, "lines": ["碇ゲンドウー"]}, {"box": [49, 153, 129, 260], "vertical": true, "font_size": 20.0, "lines": ["はたして君の", "信用に足る", "人物かな"]}, {"box": [439, 310, 495, 407], "vertical": true, "font_size": 18.0, "lines": ["よく考えて", "みたまえ"]}, {"box": [45, 387, 137, 545], "vertical": true, "font_size": 24.0, "lines": ["君が碇につくのか", "我々の側につくの", "か．．．"]}, {"box": [621, 578, 732, 760], "vertical": true, "font_size": 24.0, "lines": ["どちらにしろ", "君の知る限りの事は", "すべて話してもらう", "が．．．"]}, {"box": [282, 614, 337, 696], "vertical": true, "font_size": 23.0, "lines": ["その気に", "なったら"]}, {"box": [61, 779, 119, 881], "vertical": true, "font_size": 24.0, "lines": ["教えて", "くれたまえ"]}, {"box": [567, 952, 605, 1060], "vertical": true, "font_size": 27.0, "lines": ["冬月先生"]}], "img_path": "eva08-085.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [373, 81, 494, 219], "vertical": true, "font_size": 21.0, "lines": ["今回の件ー", "委員会はどう", "対応するつもり", "なのですか？"]}, {"box": [694, 578, 723, 696], "vertical": true, "font_size": 16.0, "lines": ["「動かんよ"]}, {"box": [385, 609, 477, 748], "vertical": true, "font_size": 23.0, "lines": ["君は余計な", "心配をしなくて", "いい"]}, {"box": [120, 615, 227, 714], "vertical": true, "font_size": 22.0, "lines": ["レイと", "アスカの", "再テストを", "急ぎたまえ"]}, {"box": [518, 923, 579, 1080], "vertical": true, "font_size": 22.0, "lines": ["拉致を命じたのは", "委員会の奴らだ"]}], "img_path": "eva08-086.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [642, 115, 676, 167], "vertical": true, "font_size": 32.0, "lines": ["はい"]}, {"box": [113, 535, 143, 653], "vertical": true, "font_size": 20.0, "lines": ["冬月先生．．．か"]}], "img_path": "eva08-087.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [535, 54, 707, 94], "vertical": false, "font_size": 32.0, "lines": ["－１９９９年京都－"]}, {"box": [100, 145, 177, 207], "vertical": true, "font_size": 32.0, "lines": ["冬月せんせい", "先生"]}, {"box": [673, 260, 756, 363], "vertical": true, "font_size": 25.0, "lines": ["読んで", "いただけ", "ましたか？"]}, {"box": [652, 431, 710, 513], "vertical": true, "font_size": 26.0, "lines": ["今回の", "レボート"]}, {"box": [499, 523, 533, 575], "vertical": true, "font_size": 25.0, "lines": ["ああ"]}, {"box": [593, 785, 709, 908], "vertical": true, "font_size": 24.0, "lines": ["近年", "希に見る", "刺激的な", "レホートだよ"]}, {"box": [428, 567, 477, 666], "vertical": true, "font_size": 25.0, "lines": ["読ませて", "もらったよ"]}, {"box": [77, 575, 164, 692], "vertical": true, "font_size": 20.0, "lines": ["２、３疑問は", "残るが面白い", "着眼点だ"]}, {"box": [512, 1028, 545, 1091], "vertical": true, "font_size": 26.0, "lines": ["碇くん"]}, {"box": [93, 1011, 143, 1109], "vertical": true, "font_size": 20.0, "lines": ["ありがとう", "ございます"]}], "img_path": "eva08-088.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [643, 37, 727, 174], "vertical": true, "font_size": 21.0, "lines": ["君はこの先", "どうするつもり", "かね？"]}, {"box": [609, 168, 626, 246], "vertical": true, "font_size": 21.0, "lines": ["就職か？"]}, {"box": [491, 182, 567, 319], "vertical": true, "font_size": 21.0, "lines": ["それともここの", "研究室に入る", "つもりかな？"]}, {"box": [86, 79, 135, 196], "vertical": true, "font_size": 18.0, "lines": ["まだそこまで", "考えてません"]}, {"box": [718, 363, 738, 441], "vertical": true, "font_size": 16.0, "lines": ["それに．．．"]}, {"box": [519, 359, 545, 406], "vertical": true, "font_size": 26.0, "lines": ["え？"]}, {"box": [569, 573, 648, 680], "vertical": true, "font_size": 18.0, "lines": ["第３の選択も", "あるんじゃ", "ありません？"]}, {"box": [45, 577, 131, 697], "vertical": true, "font_size": 22.0, "lines": ["家庭に入ろう", "かとも思って", "いるんです"]}, {"box": [379, 1020, 465, 1117], "vertical": true, "font_size": 23.0, "lines": ["いい人が", "いればの", "話ですけど"]}], "img_path": "eva08-089.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [670, 201, 726, 338], "vertical": true, "font_size": 19.0, "lines": ["いえ面識は", "ありませんが．．．"]}, {"box": [378, 37, 446, 156], "vertical": true, "font_size": 26.0, "lines": ["六分儀", "ゲンドウ？"]}, {"box": [726, 462, 753, 511], "vertical": true, "font_size": 24.0, "lines": ["え？"]}, {"box": [370, 424, 401, 560], "vertical": true, "font_size": 20.0, "lines": ["いえ．．．伺います"]}, {"box": [105, 269, 197, 370], "vertical": true, "font_size": 20.0, "lines": ["色々と噂の", "絶えない男", "ですから．．．"]}, {"box": [680, 514, 700, 692], "vertical": true, "font_size": 24.0, "lines": ["私を身元引受人に？"]}, {"box": [86, 534, 144, 714], "vertical": true, "font_size": 22.0, "lines": ["いつ伺えば", "よろしいでしょう？"]}], "img_path": "eva08-090.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [645, 45, 702, 141], "vertical": true, "font_size": 20.0, "lines": ["お待ちして", "いました"]}, {"box": [545, 134, 574, 211], "vertical": true, "font_size": 20.0, "lines": ["冬月先生"]}, {"box": [672, 314, 757, 472], "vertical": true, "font_size": 21.0, "lines": ["懇意にしている", "女性からあなたの", "話を聞きましてね"]}, {"box": [361, 322, 446, 481], "vertical": true, "font_size": 23.0, "lines": ["酔ってケンカとは", "意外と安っぽい", "男だな"]}, {"box": [63, 499, 150, 638], "vertical": true, "font_size": 21.0, "lines": ["話す間もなく", "一方的に絡まれ", "たんですよ"]}, {"box": [467, 620, 555, 737], "vertical": true, "font_size": 22.0, "lines": ["一度お会い", "したかったん", "ですよ"]}, {"box": [290, 656, 405, 777], "vertical": true, "font_size": 25.0, "lines": ["まあ．．．", "疎まれるのは", "慣れてます", "がね"]}, {"box": [150, 822, 171, 903], "vertical": true, "font_size": 22.0, "lines": ["くくく．．．"]}, {"box": [605, 859, 694, 1035], "vertical": true, "font_size": 23.0, "lines": ["私も君の事を", "好きになれそうには", "ないよ"]}, {"box": [43, 887, 126, 1024], "vertical": true, "font_size": 22.0, "lines": ["あなたは僕が", "期待した通りの", "人の様だ"]}], "img_path": "eva08-091.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [563, 89, 682, 171], "vertical": true, "font_size": 24.0, "lines": ["あの男に", "私を紹介", "したのは", "君だね"]}, {"box": [370, 37, 390, 135], "vertical": true, "font_size": 19.0, "lines": ["すみません"]}, {"box": [85, 247, 145, 333], "vertical": true, "font_size": 26.0, "lines": ["ご迷惑", "でした？"]}, {"box": [370, 435, 405, 486], "vertical": true, "font_size": 32.0, "lines": ["いや"]}, {"box": [624, 568, 711, 708], "vertical": true, "font_size": 24.0, "lines": ["おもしろい男で", "ある事は認める", "よ"]}, {"box": [688, 798, 720, 863], "vertical": true, "font_size": 30.0, "lines": ["しかし"]}, {"box": [79, 627, 159, 745], "vertical": true, "font_size": 22.0, "lines": ["すすんで", "会いたいとは", "思わないがね"]}, {"box": [374, 951, 461, 1087], "vertical": true, "font_size": 19.0, "lines": ["君があの男と", "並んで歩くとは", "想像もつかんね"]}, {"box": [122, 1010, 152, 1088], "vertical": true, "font_size": 21.0, "lines": ["何故だ？"]}], "img_path": "eva08-092.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [645, 33, 703, 116], "vertical": true, "font_size": 30.0, "lines": ["いったい", "何故"]}, {"box": [141, 219, 199, 320], "vertical": true, "font_size": 22.0, "lines": ["君があんな", "男と．．．"]}, {"box": [694, 346, 724, 446], "vertical": true, "font_size": 20.0, "lines": ["冬月先生．．"]}, {"box": [162, 443, 243, 545], "vertical": true, "font_size": 23.0, "lines": ["あの人は", "とても寂し", "がり屋で"]}, {"box": [644, 778, 723, 898], "vertical": true, "font_size": 22.0, "lines": ["ただみんなが", "知らないだけ", "なんです"]}, {"box": [93, 561, 146, 661], "vertical": true, "font_size": 23.0, "lines": ["可愛い人", "なんですよ"]}, {"box": [109, 768, 136, 849], "vertical": true, "font_size": 26.0, "lines": ["だが．．．"]}], "img_path": "eva08-093.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [572, 84, 717, 263], "vertical": true, "font_size": 22.0, "lines": ["六分優ゲンドウは", "碇ユイの才能と", "そのバックボーンの", "ある組織を目的に", "近づいたというのが"]}, {"box": [105, 422, 164, 524], "vertical": true, "font_size": 22.0, "lines": ["仲間内での", "通説だった"]}, {"box": [638, 656, 659, 755], "vertical": true, "font_size": 23.0, "lines": ["その組織は"]}, {"box": [543, 715, 628, 859], "vertical": true, "font_size": 23.0, "lines": ["「ゼーレ」と", "呼ばれていると", "いう噂を"]}, {"box": [113, 979, 171, 1060], "vertical": true, "font_size": 23.0, "lines": ["その後", "耳にした"]}], "img_path": "eva08-094.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [32, 1070, 351, 1114], "vertical": false, "font_size": 32.0, "lines": ["ＳＴＡＥＬＥＲＩＡＬの"]}], "img_path": "eva08-095.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [435, 75, 670, 117], "vertical": false, "font_size": 32.0, "lines": ["２００７年南極大陸"]}, {"box": [83, 773, 347, 803], "vertical": false, "font_size": 23.0, "lines": ["セカンド・インパクト"]}, {"box": [60, 930, 314, 1007], "vertical": false, "font_size": 28.0, "lines": ["２０世紀最後の年に", "その悲劇は起こった"]}], "img_path": "eva08-096.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [436, 81, 718, 127], "vertical": false, "font_size": 32.0, "lines": ["２００２年１２月南極大陸"]}, {"box": [153, 450, 175, 528], "vertical": true, "font_size": 20.0, "lines": ["これが．．．"]}, {"box": [673, 672, 728, 790], "vertical": true, "font_size": 22.0, "lines": ["かつての氷の", "大陸とは"]}, {"box": [333, 722, 422, 804], "vertical": true, "font_size": 26.0, "lines": ["君はよく", "生きて", "いたな"]}, {"box": [445, 1013, 509, 1094], "vertical": true, "font_size": 26.0, "lines": ["見る影も", "ない"]}, {"box": [40, 982, 153, 1120], "vertical": true, "font_size": 22.0, "lines": ["たしか例の", "高城調査隊に", "参加していたと", "聞いていたが"]}], "img_path": "eva08-097.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [558, 89, 729, 209], "vertical": true, "font_size": 22.0, "lines": ["選よく", "事件の前日に", "日本に戻って", "いたので", "悲劇をまぬが", "れました"]}, {"box": [464, 49, 484, 128], "vertical": true, "font_size": 20.0, "lines": ["そうか．．"]}, {"box": [389, 104, 440, 186], "vertical": true, "font_size": 20.0, "lines": ["六分儀君", "君は．．．"]}, {"box": [694, 511, 723, 668], "vertical": true, "font_size": 20.0, "lines": ["今は碇といいます"]}, {"box": [225, 274, 268, 328], "vertical": true, "font_size": 32.0, "lines": ["失礼"]}, {"box": [52, 326, 109, 444], "vertical": true, "font_size": 20.0, "lines": ["今は名前が", "変わりまして"]}, {"box": [680, 742, 732, 863], "vertical": true, "font_size": 22.0, "lines": ["ユイ君は．．．", "どうしてる？"]}, {"box": [586, 805, 667, 963], "vertical": true, "font_size": 22.0, "lines": ["このツアーには", "参加しなかったの", "かね？"]}, {"box": [249, 742, 365, 891], "vertical": true, "font_size": 22.0, "lines": ["妻も来たがって", "いましたが今は", "子供がいるので", "ね"]}, {"box": [69, 1043, 90, 1121], "vertical": true, "font_size": 20.0, "lines": ["そうか．．．"]}], "img_path": "eva08-098.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [674, 106, 759, 207], "vertical": true, "font_size": 23.0, "lines": ["君の組織．．．", "セーレと", "言ったか"]}, {"box": [431, 87, 487, 185], "vertical": true, "font_size": 20.0, "lines": ["イヤな噂が", "絶えないな"]}, {"box": [81, 87, 168, 209], "vertical": true, "font_size": 22.0, "lines": ["力で理事会を", "抑え込むのは", "感心できん"]}, {"box": [431, 335, 485, 473], "vertical": true, "font_size": 20.0, "lines": ["相変わらずの", "潔癖主義ですね"]}, {"box": [74, 341, 161, 498], "vertical": true, "font_size": 20.0, "lines": ["この時代に", "きれいな組織など", "生き残れませんよ"]}, {"box": [411, 609, 526, 789], "vertical": true, "font_size": 21.0, "lines": ["ゼーレの人間だけで", "調査隊を組めば", "色々とめんどうな", "事になる"]}, {"box": [52, 689, 138, 828], "vertical": true, "font_size": 23.0, "lines": ["その間に合わせ", "だろう？", "私たちは"]}, {"box": [600, 954, 721, 1072], "vertical": true, "font_size": 24.0, "lines": ["今回のこの", "セカンド・", "インバクトの", "正式調査"]}, {"box": [23, 991, 111, 1129], "vertical": true, "font_size": 21.0, "lines": ["そんな質問には", "お答えできま", "せんよ"]}], "img_path": "eva08-099.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [679, 55, 730, 136], "vertical": true, "font_size": 23.0, "lines": ["もっとも", "あなたが"]}, {"box": [215, 173, 330, 311], "vertical": true, "font_size": 21.0, "lines": ["私の味方に", "なってくれると", "言うなら", "話は別ですが"]}, {"box": [616, 339, 656, 389], "vertical": true, "font_size": 32.0, "lines": ["失礼"]}, {"box": [226, 380, 247, 420], "vertical": true, "font_size": 17.0, "lines": ["国連"]}, {"box": [230, 408, 274, 516], "vertical": false, "font_size": 17.0, "lines": ["そうだなぁ。"]}, {"box": [172, 496, 253, 652], "vertical": true, "font_size": 32.0, "lines": ["国連正式発表"]}, {"box": [155, 514, 222, 659], "vertical": false, "font_size": 26.0, "lines": ["未知Ｓａｒｉｓｔシーズン"]}, {"box": [374, 565, 428, 648], "vertical": true, "font_size": 26.0, "lines": ["その後", "国連は．．．"]}, {"box": [28, 496, 140, 705], "vertical": true, "font_size": 22.0, "lines": ["セカンド・インバクトは", "大質量の限石の", "落下によるもので", "あると正式発表した"]}, {"box": [479, 1019, 506, 1069], "vertical": true, "font_size": 27.0, "lines": ["だが"]}], "img_path": "eva08-100.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [548, 63, 649, 109], "vertical": false, "font_size": 14.0, "lines": ["．．．お前はこのブログですので、これまでは「幸せなことです。お", "．．．ｈｌ９８９Ｗｏ"]}, {"box": [403, 62, 491, 162], "vertical": true, "font_size": 24.0, "lines": ["私の目から", "見れば", "それは"]}, {"box": [55, 70, 165, 188], "vertical": true, "font_size": 22.0, "lines": ["あからさまに", "情報操作を", "されたもの", "だった"]}, {"box": [546, 389, 749, 484], "vertical": false, "font_size": 13.0, "lines": ["Ｔｗｉｔｔｕｔｅｒｔｕｒｎとａｎｔａｔｉｓｔｉｐｔｉｅｎ．ｓｓｅｌ．", "そして、こんなことを言っていたのですが、それにこれではないでしょ。それは、このままではないので、", "ＧｏｏｇｌｅＣｏｎｔＮｏｗｓそれにしてもいいでしょうかなと", "いや、そうですね。これからもう一度見ていただけましたが、わたしはどうもいいんだ"]}, {"box": [660, 532, 716, 631], "vertical": true, "font_size": 24.0, "lines": ["その裏には", "ゼーレ"]}, {"box": [438, 829, 470, 876], "vertical": true, "font_size": 28.0, "lines": ["私は"]}, {"box": [75, 572, 183, 712], "vertical": true, "font_size": 22.0, "lines": ["そして", "キールという", "人物が見え隠れ", "していた"]}, {"box": [72, 837, 188, 938], "vertical": true, "font_size": 23.0, "lines": ["あの事件の", "闇の真相を", "知りたく", "なった"]}], "img_path": "eva08-101.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [628, 78, 670, 187], "vertical": true, "font_size": 24.0, "lines": ["冬月先生"]}, {"box": [207, 367, 231, 442], "vertical": true, "font_size": 24.0, "lines": ["うッ．．．"]}, {"box": [643, 670, 730, 771], "vertical": true, "font_size": 26.0, "lines": ["眠って", "もらっては", "困るよ"]}, {"box": [229, 676, 316, 815], "vertical": true, "font_size": 24.0, "lines": ["これで３０時間", "不眠の上", "飲まず食わずだ"]}, {"box": [359, 982, 435, 1099], "vertical": true, "font_size": 19.0, "lines": ["まだこちらの", "質問に答えて", "もらってない"]}, {"box": [31, 1011, 121, 1093], "vertical": true, "font_size": 23.0, "lines": ["老体には", "きついだ", "ろう"]}], "img_path": "eva08-102.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [674, 65, 754, 185], "vertical": true, "font_size": 21.0, "lines": ["そろそろ", "限界では", "ないのかね？"]}, {"box": [380, 47, 443, 150], "vertical": true, "font_size": 26.0, "lines": ["お気遣いは", "結構"]}, {"box": [62, 188, 147, 306], "vertical": true, "font_size": 22.0, "lines": ["これでも年の", "割には頑丈", "なのでね"]}, {"box": [88, 401, 262, 444], "vertical": false, "font_size": 32.0, "lines": ["２０１３年、箱根"]}, {"box": [467, 1027, 775, 1066], "vertical": false, "font_size": 22.0, "lines": ["んちょっ", "あはははっ", "人工進化研究所"]}], "img_path": "eva08-103.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [450, 395, 480, 473], "vertical": true, "font_size": 19.0, "lines": ["冬月先生"]}, {"box": [81, 546, 103, 625], "vertical": true, "font_size": 20.0, "lines": ["しばらく"]}, {"box": [649, 708, 765, 810], "vertical": true, "font_size": 24.0, "lines": ["本当に．．．", "どうしたん", "です？", "今日は"]}, {"box": [207, 718, 287, 837], "vertical": true, "font_size": 24.0, "lines": ["どうだね", "元気で", "やってるかね"]}, {"box": [452, 974, 509, 1093], "vertical": true, "font_size": 22.0, "lines": ["君のご主人に", "用があってね"]}, {"box": [38, 1034, 94, 1100], "vertical": true, "font_size": 28.0, "lines": ["ええ．．．", "私は．．"]}], "img_path": "eva08-104.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [326, 56, 403, 210], "vertical": true, "font_size": 20.0, "lines": ["主人は先生に", "ふられたと言って", "残念がってます"]}, {"box": [504, 297, 534, 377], "vertical": true, "font_size": 20.0, "lines": ["冬月先生"]}, {"box": [477, 482, 536, 563], "vertical": true, "font_size": 21.0, "lines": ["残念だが", "それは"]}, {"box": [284, 249, 364, 425], "vertical": true, "font_size": 20.0, "lines": ["もし先生の様な", "方が主人を理解して", "くれて．．"]}, {"box": [47, 260, 126, 398], "vertical": true, "font_size": 20.0, "lines": ["そばにいて", "いただけると", "助かるんですが"]}, {"box": [79, 654, 137, 735], "vertical": true, "font_size": 26.0, "lines": ["無理な", "相談だよ"]}], "img_path": "eva08-105.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [476, 60, 527, 157], "vertical": true, "font_size": 22.0, "lines": ["セカンド・", "インハクト"]}, {"box": [149, 46, 232, 203], "vertical": true, "font_size": 23.0, "lines": ["君らは", "知っていたんじゃ", "ないのかね？"]}, {"box": [62, 124, 112, 243], "vertical": true, "font_size": 23.0, "lines": ["あの日あれが", "起こる事を"]}, {"box": [643, 310, 700, 450], "vertical": true, "font_size": 20.0, "lines": ["なぜ光の巨人の", "存在を隠す"]}, {"box": [94, 527, 212, 646], "vertical": true, "font_size": 21.0, "lines": ["君は選よく", "事件の前目に", "引きあげたと", "言っていたが"]}, {"box": [637, 760, 725, 921], "vertical": true, "font_size": 22.0, "lines": ["全ての資料を", "緒に引きあげた", "のも幸運か？"]}, {"box": [325, 757, 437, 895], "vertical": true, "font_size": 23.0, "lines": ["こんな物が", "処分されずに", "残っていたとは", "意外です"]}, {"box": [56, 752, 142, 852], "vertical": true, "font_size": 22.0, "lines": ["君の資産を", "調べさせて", "もらった"]}], "img_path": "eva08-106.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [648, 72, 733, 214], "vertical": true, "font_size": 22.0, "lines": ["個人で持つには", "額が多すぎ", "ないかね"]}, {"box": [430, 79, 478, 158], "vertical": true, "font_size": 18.0, "lines": ["さすがは", "冬月都授"]}, {"box": [585, 420, 723, 604], "vertical": true, "font_size": 22.0, "lines": ["セカンド・インバクト", "の裏に潜む", "君たちセーレと", "死海文書を公表", "させてもらう！！"]}, {"box": [222, 244, 310, 380], "vertical": true, "font_size": 20.0, "lines": ["総済学部にても", "転向なさったら", "いかがです？"]}, {"box": [84, 661, 170, 801], "vertical": true, "font_size": 22.0, "lines": ["あれを起こした", "人間たちを許す", "つもりはない！"]}, {"box": [656, 858, 683, 936], "vertical": true, "font_size": 19.0, "lines": ["お好きに"]}, {"box": [86, 991, 163, 1075], "vertical": true, "font_size": 26.0, "lines": ["ただ", "その前に"]}], "img_path": "eva08-107.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [676, 92, 732, 231], "vertical": true, "font_size": 21.0, "lines": ["お目にかけたい", "ものがあります"]}, {"box": [496, 526, 555, 627], "vertical": true, "font_size": 25.0, "lines": ["ずい分", "潜るんだな"]}, {"box": [680, 983, 734, 1087], "vertical": true, "font_size": 25.0, "lines": ["なに", "すぐですよ"]}], "img_path": "eva08-108.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [339, 427, 427, 460], "vertical": false, "font_size": 21.0, "lines": ["．．．いや、この"]}, {"box": [582, 740, 602, 838], "vertical": true, "font_size": 19.0, "lines": ["これは．．．？"]}, {"box": [430, 786, 516, 904], "vertical": true, "font_size": 21.0, "lines": ["我々でない", "誰かが残した", "空洞ですよ"]}, {"box": [160, 788, 240, 924], "vertical": true, "font_size": 20.0, "lines": ["もとはきれいな", "球状の地底の", "空洞か．．．"]}, {"box": [271, 1005, 354, 1086], "vertical": true, "font_size": 25.0, "lines": ["８９６は", "埋まって", "ますがね"]}], "img_path": "eva08-109.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [667, 67, 725, 133], "vertical": true, "font_size": 30.0, "lines": ["そして", "あれが"]}, {"box": [100, 195, 190, 335], "vertical": true, "font_size": 22.0, "lines": ["人類の持てる", "全てを費やして", "いる施設です"]}, {"box": [378, 717, 408, 855], "vertical": true, "font_size": 20.0, "lines": ["赤木ナオコ君？"]}, {"box": [222, 724, 252, 769], "vertical": true, "font_size": 30.0, "lines": ["あら"]}, {"box": [61, 992, 92, 1070], "vertical": true, "font_size": 18.0, "lines": ["冬月先生"]}], "img_path": "eva08-110.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [580, 57, 698, 174], "vertical": true, "font_size": 23.0, "lines": ["君まで．．．", "こんな所で", "何をしとるの", "かね"]}, {"box": [311, 62, 363, 145], "vertical": true, "font_size": 25.0, "lines": ["こんな", "所って．．．"]}, {"box": [38, 96, 152, 315], "vertical": true, "font_size": 22.0, "lines": ["日指すべき", "生体コンビューターの", "基礎理論を模索するには", "ベストな所ですよ"]}, {"box": [91, 454, 173, 573], "vertical": true, "font_size": 23.0, "lines": ["「マギ」と", "名付ける", "つもりですわ"]}, {"box": [697, 645, 720, 726], "vertical": true, "font_size": 20.0, "lines": ["「マギ」．．"]}, {"box": [445, 652, 529, 733], "vertical": true, "font_size": 20.0, "lines": ["見せたい", "ものとは", "これか？"]}, {"box": [167, 650, 257, 718], "vertical": true, "font_size": 30.0, "lines": ["私が", "ご案内", "します"]}, {"box": [557, 957, 642, 1055], "vertical": true, "font_size": 21.0, "lines": ["東方より", "来たりし", "三賢者か．．．"]}, {"box": [317, 1019, 346, 1083], "vertical": true, "font_size": 29.0, "lines": ["いや．．．"]}, {"box": [79, 1006, 102, 1124], "vertical": true, "font_size": 20.0, "lines": ["こちらですわ"]}], "img_path": "eva08-111.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [], "img_path": "eva08-112.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [668, 63, 689, 144], "vertical": true, "font_size": 21.0, "lines": ["これは．．"]}, {"box": [100, 152, 152, 253], "vertical": true, "font_size": 20.0, "lines": ["まさかあの", "巨人を．．．？"]}, {"box": [591, 373, 710, 512], "vertical": true, "font_size": 23.0, "lines": ["あの巨人は我々", "「ゲヒルン」では", "アダムと", "呼んでいます"]}, {"box": [269, 366, 295, 431], "vertical": true, "font_size": 26.0, "lines": ["では．．．"]}, {"box": [269, 653, 290, 752], "vertical": true, "font_size": 20.0, "lines": ["そうです！"]}, {"