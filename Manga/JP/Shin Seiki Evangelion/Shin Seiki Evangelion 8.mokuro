 {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [656, 42, 748, 220], "vertical": true, "font_size": 23.0, "lines": ["現在ＬＣＬ濃度", "３６を維持", "酸素密度に問題なし"]}, {"box": [593, 366, 708, 417], "vertical": false, "font_size": 21.0, "lines": ["第３０５", "「ＨＥＴＡＨＲＴＥＴＨ"]}, {"box": [683, 509, 741, 646], "vertical": true, "font_size": 21.0, "lines": ["波形パターンは", "Ｂ"]}, {"box": [273, 525, 293, 597], "vertical": true, "font_size": 20.0, "lines": ["あのバカ"]}, {"box": [100, 239, 160, 377], "vertical": true, "font_size": 22.0, "lines": ["放射電子パルス", "異常なし"]}, {"box": [72, 517, 146, 623], "vertical": true, "font_size": 19.0, "lines": ["いったい", "どうなっちゃ", "うんだろ"]}, {"box": [350, 779, 412, 898], "vertical": true, "font_size": 19.0, "lines": ["各計測装置は", "正常に作動中"]}, {"box": [186, 564, 236, 705], "vertical": true, "font_size": 20.0, "lines": ["一か月も", "戻ってこないけど"]}], "img_path": "eva08-014.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [645, 72, 727, 222], "vertical": true, "font_size": 20.0, "lines": ["まさか一生", "あのままってコト", "ないわよね"]}, {"box": [356, 27, 430, 145], "vertical": true, "font_size": 27.0, "lines": ["シンジ君が", "心配かい？"]}, {"box": [40, 415, 107, 467], "vertical": true, "font_size": 32.0, "lines": ["加持", "さん"]}, {"box": [700, 556, 719, 656], "vertical": true, "font_size": 18.0, "lines": ["残念でした"]}, {"box": [580, 597, 676, 722], "vertical": true, "font_size": 18.0, "lines": ["これであたしの", "活躍の場面が", "増えるって", "喜んでたのよ"]}, {"box": [592, 820, 672, 955], "vertical": true, "font_size": 21.0, "lines": ["加持さん以外の", "彼氏なんか", "いらないわよッ"]}, {"box": [291, 837, 321, 937], "vertical": true, "font_size": 20.0, "lines": ["その意気だ"]}, {"box": [122, 567, 196, 657], "vertical": true, "font_size": 20.0, "lines": ["またそんな", "やせガマン", "して．．．"]}, {"box": [48, 607, 120, 734], "vertical": true, "font_size": 20.0, "lines": ["たまには素直に", "ならないと", "彼氏できないぞ"]}, {"box": [704, 806, 729, 998], "vertical": true, "font_size": 21.0, "lines": ["やせガマンじゃないッ"]}, {"box": [377, 1018, 398, 1095], "vertical": true, "font_size": 19.0, "lines": ["おっとと"]}, {"box": [50, 1062, 75, 1124], "vertical": true, "font_size": 25.0, "lines": ["アスカ"]}], "img_path": "eva08-015.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [719, 69, 783, 245], "vertical": true, "font_size": 22.0, "lines": ["確かにシンジ君の", "今の状態は心配だが"]}, {"box": [505, 74, 562, 167], "vertical": true, "font_size": 21.0, "lines": ["おまえも", "おまえで"]}, {"box": [128, 214, 157, 308], "vertical": true, "font_size": 24.0, "lines": ["かんばれ"]}, {"box": [584, 403, 645, 542], "vertical": true, "font_size": 22.0, "lines": ["きっと彼も", "必死で戦ってる"]}, {"box": [354, 571, 386, 689], "vertical": true, "font_size": 20.0, "lines": ["加持さん．．．？"]}, {"box": [255, 828, 300, 858], "vertical": false, "font_size": 12.0, "lines": ["へにゃい．．．"]}, {"box": [619, 953, 646, 1048], "vertical": true, "font_size": 24.0, "lines": ["じゃあな"]}, {"box": [189, 984, 369, 1077], "vertical": false, "font_size": 22.0, "lines": ["（金、１２３式補完手順）"]}, {"box": [114, 932, 406, 1076], "vertical": false, "font_size": 30.0, "lines": ["ＥＰ２式サルベージ作業手順要新"]}], "img_path": "eva08-016.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [615, 55, 698, 199], "vertical": true, "font_size": 25.0, "lines": ["シンジ君の", "サルベージ計画の", "要綱"]}, {"box": [71, 76, 176, 197], "vertical": true, "font_size": 18.0, "lines": ["たったひと月で", "できるなんて", "さすが先輩", "ですね"]}, {"box": [644, 385, 724, 492], "vertical": true, "font_size": 20.0, "lines": ["残念ながら", "原案は私じゃ", "ないわ"]}, {"box": [426, 381, 504, 488], "vertical": true, "font_size": 19.0, "lines": ["１０年前に", "実験済みの", "データなのよ"]}, {"box": [60, 398, 135, 508], "vertical": true, "font_size": 21.0, "lines": ["同じ様な事が", "あったんです", "か？"]}, {"box": [59, 547, 106, 621], "vertical": true, "font_size": 21.0, "lines": ["エヴァの", "開発中に"]}, {"box": [653, 667, 732, 792], "vertical": true, "font_size": 21.0, "lines": ["まだ私が", "ここに入る前の", "でき事よ"]}, {"box": [400, 679, 479, 773], "vertical": true, "font_size": 22.0, "lines": ["先輩の", "お母さんて", "あの"]}, {"box": [333, 745, 405, 904], "vertical": true, "font_size": 22.0, "lines": ["マキシステムを", "開発した赤木", "ナオコ博士ですよね"]}, {"box": [193, 675, 296, 784], "vertical": true, "font_size": 22.0, "lines": ["その時の", "結果は", "どうだったん", "ですか？"]}, {"box": [511, 975, 591, 1067], "vertical": true, "font_size": 21.0, "lines": ["私の母が", "立ち会った", "らしいけど"]}, {"box": [38, 1025, 77, 1099], "vertical": true, "font_size": 29.0, "lines": ["失敗よ"]}], "img_path": "eva08-017.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [732, 86, 759, 142], "vertical": true, "font_size": 27.0, "lines": ["え？"]}, {"box": [534, 86, 567, 206], "vertical": true, "font_size": 20.0, "lines": ["失敗したのよ"]}, {"box": [370, 83, 394, 148], "vertical": true, "font_size": 24.0, "lines": ["そして"]}, {"box": [97, 76, 188, 271], "vertical": true, "font_size": 22.0, "lines": ["碇司令が", "変わってしまったのは", "たぶんその時からよ"]}, {"box": [257, 518, 591, 619], "vertical": false, "font_size": 32.0, "lines": ["会議室", "Ａ．Ｉ作戦会議室", "Ｍｅｓｉｏｎの「ＰａｔＮｅｒＳＥＯＴＯＮ"]}], "img_path": "eva08-018.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [682, 83, 710, 138], "vertical": true, "font_size": 22.0, "lines": ["何か用"]}, {"box": [653, 502, 723, 644], "vertical": true, "font_size": 18.0, "lines": ["ここんとこロクに", "寝てないし", "食ってないだろ？"]}, {"box": [56, 318, 136, 443], "vertical": true, "font_size": 21.0, "lines": ["用がなきゃ", "来ちゃいけない", "のか？"]}, {"box": [606, 583, 622, 705], "vertical": true, "font_size": 18.0, "lines": ["大丈夫なのか？"]}, {"box": [50, 623, 132, 766], "vertical": true, "font_size": 21.0, "lines": ["こんな時に香気に", "寝たり食ったり", "できないわよ．．"]}, {"box": [461, 1002, 515, 1125], "vertical": true, "font_size": 20.0, "lines": ["シンジ君の学校", "調べたわ"]}, {"box": [322, 836, 395, 1005], "vertical": true, "font_size": 19.0, "lines": ["まさかあのクラスの", "全員がバイロット", "候補だったとはね"]}, {"box": [54, 845, 151, 952], "vertical": true, "font_size": 19.0, "lines": ["いったい", "ネルフの手は", "どこまで", "伸びてるの？"]}], "img_path": "e