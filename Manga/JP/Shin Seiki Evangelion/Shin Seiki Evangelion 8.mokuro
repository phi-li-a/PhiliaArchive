tical": true, "font_size": 16.0, "lines": ["どうして？"]}, {"box": [333, 111, 349, 248], "vertical": true, "font_size": 18.0, "lines": ["どうしてたろう"]}, {"box": [77, 182, 101, 320], "vertical": true, "font_size": 20.0, "lines": ["わからないけど"]}, {"box": [579, 367, 698, 489], "vertical": true, "font_size": 24.0, "lines": ["綾波の顔", "見たら", "そう言いたく", "なった"]}, {"box": [685, 842, 705, 904], "vertical": true, "font_size": 20.0, "lines": ["そう．．"]}, {"box": [324, 627, 412, 746], "vertical": true, "font_size": 25.0, "lines": ["また碇くんの", "顔が", "見られて"]}, {"box": [174, 623, 205, 742], "vertical": true, "font_size": 23.0, "lines": ["でも碇くんは"]}, {"box": [511, 989, 540, 1069], "vertical": true, "font_size": 20.0, "lines": ["良かった"]}, {"box": [79, 884, 107, 1060], "vertical": true, "font_size": 20.0, "lines": ["これで良かったの？"]}], "img_path": "eva08-077.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [661, 79, 723, 237], "vertical": true, "font_size": 20.0, "lines": ["正直言って", "よくわからないよ"]}, {"box": [167, 63, 245, 258], "vertical": true, "font_size": 18.0, "lines": ["エヴァに取り込まれてた", "間の事あんまり", "覚えてないし．．"]}, {"box": [99, 190, 120, 252], "vertical": true, "font_size": 21.0, "lines": ["でも．．"]}, {"box": [606, 362, 724, 465], "vertical": true, "font_size": 26.0, "lines": ["僕も", "また綾波に", "会えて", "良かった．．"]}, {"box": [78, 417, 152, 548], "vertical": true, "font_size": 32.0, "lines": ["拉致", "された！？"]}, {"box": [273, 968, 318, 1129], "vertical": true, "font_size": 32.0, "lines": ["副司令が！？"]}], "img_path": "eva08-078.jpg"}, {"version": "0.1.6", "img_width": 817, "img_height": 1185, "blocks": [{"box": [698, 84, 715, 260], "vertical": true, "font_size": 20.0, "lines": ["今より２時間前です"]}, {"box": [567, 84, 644, 278], "vertical": true, "font_size": 20.0, "lines": ["ジオフロント西の第８", "管区を最後に消息を", "絶っています"]}, {"box": [52, 84, 222, 221], "vertical": true, "font_size": 23.0, "lines": ["うちの", "所内じゃ", "ない", "あなたたち", "諜報部は何", "やってたの？"]}, {"box": [649, 518, 738, 657], "vertical": true, "font_size": 22.0, "