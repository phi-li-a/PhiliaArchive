0, "lines": ["そう．．"]}, {"box": [68, 473, 120, 572], "vertical": true, "font_size": 22.0, "lines": ["あのコが", "死んだの．．"]}], "img_path": "eva08-161.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [], "img_path": "eva08-162.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [{"box": [251, 75, 338, 192], "vertical": true, "font_size": 22.0, "lines": ["この部屋．．", "イヤな感じの", "におい"]}, {"box": [286, 408, 306, 523], "vertical": true, "font_size": 16.0, "lines": ["ごめんなさい"]}, {"box": [67, 246, 126, 348], "vertical": true, "font_size": 22.0, "lines": ["いつ来ても", "慣れないわ"]}, {"box": [706, 772, 727, 853], "vertical": true, "font_size": 19.0, "lines": ["あ．．．いえ"]}, {"box": [68, 605, 97, 687], "vertical": true, "font_size": 24.0, "lines": ["待った？"]}, {"box": [150, 759, 171, 822], "vertical": true, "font_size": 22.0, "lines": ["そう？"]}, {"box": [68, 822, 119, 1000], "vertical": true, "font_size": 22.0, "lines": ["じゃあいつもの通り", "腕を出して"]}], "img_path": "eva08-163.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [{"box": [712, 76, 731, 111], "vertical": true, "font_size": 19.0, "lines": ["はい"]}, {"box": [702, 68, 739, 119], "vertical": false, "font_size": 32.0, "lines": ["はい"]}, {"box": [566, 633, 582, 675], "vertical": true, "font_size": 16.0, "lines": ["う．．．"]}], "img_path": "eva08-164.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [{"box": [716, 89, 739, 128], "vertical": true, "font_size": 23.0, "lines": ["レイ"]}, {"box": [381, 78, 441, 195], "vertical": true, "font_size": 20.0, "lines": ["あなた最近", "変わったわね"]}, {"box": [242, 32, 328, 210], "vertical": true, "font_size": 22.0, "lines": ["きのうシンジ君と", "仲よく歩いてる所を", "見たわよ"]}, {"box": [706, 484, 725, 549], "vertical": true, "font_size": 19.0, "lines": ["．．．そうだな。"]}, {"box": [28, 274, 118, 430], "vertical": true, "font_size": 20.0, "lines": ["表情が人間らしく", "なって来たのは", "そのせい？"]}, {"box": [142, 521, 192, 620], "vertical": true, "font_size": 20.0, "lines": ["いけない", "事ですか？"]}, {"box": [649, 707, 729, 807], "vertical": true, "font_size": 22.0, "lines": ["まさか．．．", "いけないだ", "なんて"]}, {"box": [140, 703, 260, 839], "vertical": true, "font_size": 21.0, "lines": ["今まで", "碇司令しか", "眼中になかった", "みたいなのに"]}, {"box": [298, 974, 356, 1090], "vertical": true, "font_size": 22.0, "lines": ["ただ少し", "驚いてるのよ"]}], "img_path": "eva08-165.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [{"box": [710, 88, 738, 133], "vertical": true, "font_size": 28.0, "lines": ["ふふ"]}, {"box": [460, 70, 519, 207], "vertical": true, "font_size": 20.0, "lines": ["ただの人形かと", "思っていたら"]}, {"box": [562, 363, 615, 445], "vertical": true, "font_size": 24.0, "lines": ["たいした", "ものね"]}, {"box": [405, 503, 439, 530], "vertical": false, "font_size": 27.0, "lines": ["私"]}, {"box": [48, 289, 169, 408], "vertical": true, "font_size": 23.0, "lines": ["父親と息子を", "一度に手玉に", "取ろうとする", "なんて"]}, {"box": [626, 744, 743, 864], "vertical": true, "font_size": 21.0, "lines": ["碇司令ばかり", "見ていたのは", "本当の事がも", "しれないけど"]}, {"box": [383, 766, 471, 923], "vertical": true, "font_size": 20.0, "lines": ["それは赤木博士も", "同じなんじゃ", "ないですか？"]}, {"box": [67, 582, 129, 664], "vertical": true, "font_size": 24.0, "lines": ["人形じゃ", "ないわ"]}, {"box": [534, 1036, 560, 1081], "vertical": true, "font_size": 26.0, "lines": ["でも"]}], "img_path": "eva08-166.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [], "img_path": "eva08-167.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [{"box": [715, 83, 737, 128], "vertical": true, "font_size": 22.0, "lines": ["う．．．"]}, {"box": [582, 438, 606, 575], "vertical": true, "font_size": 19.0, "lines": ["ごめんなさい"]}, {"box": [99, 430, 167, 528], "vertical": true, "font_size": 27.0, "lines": ["冗談が", "すぎたわ"]}, {"box": [659, 660, 747, 728], "vertical": true, "font_size": 31.0, "lines": ["仕事が", "忙しく", "て"]}, {"box": [209, 655, 236, 701], "vertical": true, "font_size": 27.0, "lines": ["でも"]}, {"box": [549, 965, 601, 1083], "vertical": true, "font_size": 22.0, "lines": ["つい．．．", "イライラして"]}, {"box": [37, 970, 125, 1070], "vertical": true, "font_size": 23.0, "lines": ["ロの", "きき方には", "気をつけて"]}], "img_path": "eva08-168.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [{"box": [657, 94, 742, 252], "vertical": true, "font_size": 21.0, "lines": ["あなたがその体を", "維持できるのは", "私のおかげなのよ"]}, {"box": [708, 335, 725, 401], "vertical": true, "font_size": 17.0, "lines": ["．．．"]}, {"box": [480, 443, 502, 543], "vertical": true, "font_size": 20.0, "lines": ["すみません"]}, {"box": [660, 652, 722, 791], "vertical": true, "font_size": 24.0, "lines": ["何やってるの？", "私．．．"]}, {"box": [105, 631, 159, 712], "vertical": true, "font_size": 24.0, "lines": ["これじゃ", "まるで"]}, {"box": [389, 883, 450, 963], "vertical": true, "font_size": 22.0, "lines": ["母さんと", "同じ．．"]}], "img_path": "eva08-169.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [], "img_path": "eva08-170.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [{"box": [632, 74, 749, 231], "vertical": true, "font_size": 22.0, "lines": ["久しぶりに", "３人揃ったって", "いうのに", "ギスギスしてるな"]}, {"box": [283, 36, 412, 260], "vertical": false, "font_size": 30.0, "lines": ["くっくっと、"]}, {"box": [455, 451, 515, 531], "vertical": true, "font_size": 20.0, "lines": ["．．．無理も", "ないけど"]}, {"box": [355, 357, 413, 440], "vertical": true, "font_size": 26.0, "lines": ["はい", "もしもし"]}, {"box": [64, 374, 121, 420], "vertical": true, "font_size": 28.0, "lines": ["えっ", "はい"]}, {"box": [608, 629, 736, 806], "vertical": true, "font_size": 21.0, "lines": ["国際電話", "アスカのお母さん", "だって言ってる", "みたいだけど"]}, {"box": [707, 854, 733, 902], "vertical": true, "font_size": 26.0, "lines": ["あら"]}, {"box": [441, 862, 531, 1059], "vertical": true, "font_size": 22.0, "lines": ["無敵のシンジ様に", "この様な雑務をさせて", "申し訳ないですわね"]}, {"box": [381, 858, 402, 974], "vertical": true, "font_size": 17.0, "lines": ["なんだよそれ"]}, {"box": [53, 879, 134, 923], "vertical": false, "font_size": 21.0, "lines": ["Ｇｕｔｅｎでａの", "ふん．．．なんて、"]}], "img_path": "eva08-171.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [{"box": [664, 89, 784, 116], "vertical": false, "font_size": 20.0, "lines": ["Ｄａｎｋｅ．ｓｅｌｒａｕｔ"]}, {"box": [388, 67, 453, 206], "vertical": true, "font_size": 25.0, "lines": ["義理のお母さん", "か"]}, {"box": [64, 77, 163, 147], "vertical": false, "font_size": 21.0, "lines": ["２０１５年０７月２ｃｔ", "アメリカに", "あの方はｒｓｏｒｇｅｎ"]}, {"box": [491, 479, 586, 500], "vertical": false, "font_size": 20.0, "lines": ["Ｃｈａｄｇｏｎｔｅｎｔ．"]}, {"box": [380, 283, 440, 442], "vertical": true, "font_size": 22.0, "lines": ["本当のお母さんは", "たしか．．"]}, {"box": [317, 277, 338, 332], "vertical": true, "font_size": 21.0, "lines": ["ママ．．．"]}, {"box": [83, 383, 132, 532], "vertical": true, "font_size": 20.0, "lines": ["どうして", "死んじゃったの？"]}, {"box": [689, 560, 744, 737], "vertical": true, "font_size": 22.0, "lines": ["死んだんだよな", "僕の母さんと同じに"]}, {"box": [454, 577, 474, 677], "vertical": true, "font_size": 23.0, "lines": ["でも僕は．．"]}, {"box": [323, 610, 434, 767], "vertical": true, "font_size": 23.0, "lines": ["エヴァの中で", "死んだ母さんに", "会えたような気が", "する"]}, {"box": [82, 594, 104, 633], "vertical": true, "font_size": 22.0, "lines": ["いや"]}, {"box": [709, 887, 739, 1004], "vertical": true, "font_size": 20.0, "lines": ["確かに会った"]}, {"box": [95, 902, 151, 1038], "vertical": true, "font_size": 21.0, "lines": ["あれは確かに", "母さんだった．．"]}], "img_path": "eva08-172.jpg"}, {"version": "0.1.6", "img_width": 809, "img_height": 1186, "blocks": [{"box": [652, 130, 716, 169], "vertical": false, "font_size": 19.5, "lines": ["スリッ", "いや．．．いいえばピアＳｅ"]}, {"box": [682, 379, 732, 495], "vertical": true, "font_size": 20.0, "lines": ["なにジロジロ", "見てんのよッ"]}, {"box": [148, 372, 228, 514], "vertical": true, "font_size": 21.0, "lines": ["．．．なんで僕には", "そーゆー態度", "なんだよ"]}, {"box": [70, 391, 119, 566], "vertical": true, "font_size": 21.0, "lines": ["さっきまでニコニコ", "話してたくせに"]}, {"box": [707, 618, 735, 660], "vertical":