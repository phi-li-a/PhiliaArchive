30.0, "lines": ["だから", "バチが当たった"]}], "img_path": "166.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [896, 89, 929, 234], "vertical": true, "font_size": 24.0, "lines": ["それが１５年前"]}, {"box": [323, 356, 426, 525], "vertical": true, "font_size": 26.0, "lines": ["せっかく拾った", "神様も消えて", "しまったわ"]}, {"box": [805, 641, 906, 877], "vertical": true, "font_size": 24.0, "lines": ["でも今度は", "神様を自分たちで", "復活させようとしたの"]}, {"box": [465, 638, 564, 832], "vertical": true, "font_size": 26.0, "lines": ["そしてアダムから", "神様に似せて", "人間を作った"]}, {"box": [536, 947, 566, 1023], "vertical": true, "font_size": 30.0, "lines": ["それが"]}, {"box": [690, 1139, 715, 1280], "vertical": true, "font_size": 20.0, "lines": ["それがアダム"]}, {"box": [142, 1076, 173, 1151], "vertical": true, "font_size": 31.0, "lines": ["エヴァ"]}], "img_path": "167.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [863, 129, 902, 207], "vertical": true, "font_size": 31.0, "lines": ["人間？"]}, {"box": [548, 116, 657, 238], "vertical": true, "font_size": 29.0, "lines": ["人だって", "いうんです", "か？"]}, {"box": [820, 560, 917, 704], "vertical": true, "font_size": 27.0, "lines": ["あなたも", "気づいて", "いるでしょ？"]}, {"box": [383, 394, 411, 471], "vertical": true, "font_size": 26.0, "lines": ["そうよ"]}, {"box": [411, 566, 512, 779], "vertical": true, "font_size": 24.0, "lines": ["消えてしまった", "あなたのお母さんが", "今どこにいるのか"]}, {"box": [56, 337, 197, 529], "vertical": true, "font_size": 27.0, "lines": ["本来魂のない", "エヴァには", "人の魂が宿らせて", "あるもの"]}, {"box": [801, 991, 894, 1181], "vertical": true, "font_size": 26.0, "lines": ["でもここにある", "レイと同じものは", "人じゃない"]}, {"box": [732, 1144, 798, 1316], "vertical": true, "font_size": 26.0, "lines": ["魂のない", "ただの容れ物よ"]}, {"box": [115, 1066, 211, 1302], "vertical": true, "font_size": 25.0, "lines": ["たったひとつの", "魂を守り続けるための", "ただの器"]}], "img_path": "168.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [862, 112, 930, 193], "vertical": true, "font_size": 32.0, "lines": ["だから", "壊すの"]}, {"box": [587, 79, 625, 224], "vertical": true, "font_size": 26.0, "lines": ["私の苦しみを"]}, {"box": [664, 424, 769, 593], "vertical": true, "font_size": 26.0, "lines": ["もう二度と", "器が取り換え", "られないように"]}, {"box": [417, 468, 485, 587], "vertical": true, "font_size": 26.0, "lines": ["終わらせる", "ために"]}, {"box": [76, 1005, 96, 1023], "vertical": false, "font_size": 18.0, "lines": ["？"]}], "img_path": "169.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [504, 897, 540, 1050], "vertical": true, "font_size": 32.0, "lines": ["あんた！"]}, {"box": [90, 891, 171, 1094], "vertical": true, "font_size": 32.0, "lines": ["何やってんのか", "わかってんの！？"]}, {"box": [816, 891, 925, 1371], "vertical": true, "font_size": 32.0, "lines": ["わあああ"]}], "img_path": "170.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [882, 89, 944, 233], "vertical": true, "font_size": 26.0, "lines": ["ええ", "わかってるわ"]}, {"box": [559, 228, 597, 305], "vertical": true, "font_size": 31.0, "lines": ["破壊よ"]}, {"box": [370, 73, 470, 267], "vertical": true, "font_size": 28.0, "lines": ["でも", "そんなものにすら", "私は負けた"]}, {"box": [629, 354, 657, 522], "vertical": true, "font_size": 27.0, "lines": ["人じゃないもの"]}, {"box": [551, 447, 612, 593], "vertical": true, "font_size": 27.0, "lines": ["人の形をした", "ただの物体"]}, {"box": [103, 417, 135, 607], "vertical": true, "font_size": 24.0, "lines": ["勝てなかったのよ"]}, {"box": [736, 712, 896, 924], "vertical": true, "font_size": 23.0, "lines": ["あの人のこと", "考えるだけで", "どんな陵辱にだって", "耐えられた"]}, {"box": [876, 1022, 938, 1144], "vertical": true, "font_size": 26.0, "lines": ["でも", "あの人には"]}, {"box": [482, 1028, 508, 1124], "vertical": true, "font_size": 26.0, "lines": ["なのに．．．"]}, {"box": [73, 795, 183, 939], "vertical": true, "font_size": 29.0, "lines": ["私の体なんて", "どうでも", "いいのよ"]}, {"box": [796, 1100, 856, 1290], "vertical": true, "font_size": 26.0, "lines": ["そう思ってほしく", "なかった"]}, {"box": [418, 1128, 443, 1272], "vertical": true, "font_size": 26.0, "lines": ["なのにあの人"]}, {"box": [103, 1209, 171, 1333], "vertical": true, "font_size": 32.0, "lines": ["バカなのよ", "私は"]}], "img_path": "171.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [860, 32, 919, 220], "vertical": true, "font_size": 24.0, "lines": ["わかっていたのに"]}, {"box": [265, 120, 291, 216], "vertical": true, "font_size": 26.0, "lines": ["リツコ．．．"]}, {"box": [389, 508, 459, 653], "vertical": true, "font_size": 26.0, "lines": ["母娘そろって", "大バカ者だわ"]}, {"box": [107, 590, 133, 686], "vertical": true, "font_size": 25.0, "lines": ["あんた．．．"]}, {"box": [836, 776, 905, 944], "vertical": true, "font_size": 26.0, "lines": ["私を殺したいの", "なら殺して"]}, {"box": [496, 769, 520, 932], "vertical": true, "font_size": 19.0, "lines": ["それこそバカよ"]}, {"box": [96, 907, 123, 1003], "vertical": true, "font_size": 24.0, "lines": ["あんたは"]}, {"box": [647, 1080, 678, 1157], "vertical": true, "font_size": 29.0, "lines": ["いいえ"]}, {"box": [568, 1134, 630, 1326], "vertical": true, "font_size": 29.0, "lines": ["そうしてくれると", "嬉しい"]}, {"box": [500, 1088, 519, 1164], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．く"]}, {"box": [93, 1238, 119, 1338], "vertical": true, "font_size": 26.0, "lines": ["うっ．．．"]}], "img_path": "172.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [722, 944, 756, 1042], "vertical": true, "font_size": 25.0, "lines": ["父さん．．．"]}, {"box": [526, 972, 625, 1161], "vertical": true, "font_size": 23.0, "lines": ["父さんはいったい", "何をしようと", "してるんだ"]}, {"box": [382, 944, 423, 1025], "vertical": true, "font_size": 31.0, "lines": ["綾波を"]}, {"box": [305, 1062, 337, 1154], "vertical": true, "font_size": 16.0, "lines": ["母さんを"]}, {"box": [127, 1196, 154, 1290], "vertical": true, "font_size": 24.0, "lines": ["エヴァを"]}], "img_path": "173.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [687, 116, 768, 203], "vertical": true, "font_size": 32.0, "lines": ["そして", "僕を"]}, {"box": [237, 116, 338, 259], "vertical": true, "font_size": 26.0, "lines": ["どうしようと", "しているん", "だ"]}, {"box": [835, 381, 883, 444], "vertical": true, "font_size": 32.0, "lines": ["綾波"]}, {"box": [147, 423, 183, 496], "vertical": true, "font_size": 26.0, "lines": ["母さん"]}, {"box": [825, 803, 862, 988], "vertical": true, "font_size": 29.0, "lines": ["僕はこれから"]}, {"box": [160, 1108, 189, 1337], "vertical": true, "font_size": 26.0, "lines": ["どうしたらいい？"]}], "img_path": "174.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [607, 160, 626, 552], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．"]}, {"box": [649, 163, 673, 562], "vertical": true, "font_size": 20.0, "lines": ["そうだな．．．．．．"]}, {"box": [722, 167, 739, 195], "vertical": false, "font_size": 28.0, "lines": ["それでも、"]}, {"box": [691, 161, 721, 553], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．．．．"]}, {"box": [739, 163, 764, 572], "vertical": true, "font_size": 20.0, "lines": ["そうだな．．．うーーー．．．"]}, {"box": [836, 160, 850, 675], "vertical": true, "font_size": 14.0, "lines": ["．．．．．．．．．．．．．．．"]}, {"box": [785, 163, 809, 907], "vertical": true, "font_size": 20.0, "lines": ["．．．ファンディング．．．ロックスンには"]}], "img_path": "175.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [362, 73, 690, 117], "vertical": false, "font_size": 18.0, "lines": ["ＹＯＳＨＩＹＵＫＩＳＡＤＡＭＯＴＯ", "ＰＲＯＦＬＥ"]}, {"box": [361, 155, 695, 542], "vertical": false, "font_size": 19.0, "lines": ["貞本義行（さだもとよしゆき）の", "１９６２年１月２９日日生まれ。血液型Ａ型。", "山口県徳山市出身。東京造形大学卒", "業後、アニメーターーとなる。キャラク", "ター・デザイナー、、作画監督として活躍。", "代表作品「オネアミスの翼、王立宇", "宙軍Ｊ「トップをねらえ！！「ふしぎの", "海のナディア」「新世紀エヴァンゲリ", "オン」「フリクリ」「トップをねらえ！？", "Ｊ等。９５年２月号より月刊少年エー", "スにて「新世紀工ヴァンゲリオン」を", "連載。現在ＧＡＮＡＸ所属。"]}, {"box": [449, 672, 603, 694], "vertical": false, "font_size": 24.0, "lines": ["ＳＴＡＦＦＬＩＳＴ"]}, {"box": [363, 740, 472, 759], "vertical": false, "font_size": 18.0, "lines": ["Ｔｈｅａｕｔｈｏｎ"]}, {"box": [362, 806, 456, 823], "vertical": false,