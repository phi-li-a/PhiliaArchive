でも", "とにかく"]}, {"box": [376, 871, 474, 995], "vertical": true, "font_size": 31.0, "lines": ["レイが", "助かって", "良かった．．"]}, {"box": [298, 898, 326, 951], "vertical": true, "font_size": 28.0, "lines": ["ええ"]}, {"box": [390, 1229, 414, 1324], "vertical": true, "font_size": 24.0, "lines": ["でしょ？"]}, {"box": [245, 1196, 278, 1253], "vertical": true, "font_size": 32.0, "lines": ["でも"]}], "img_path": "121.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [829, 59, 901, 203], "vertical": true, "font_size": 29.0, "lines": ["素直には", "喜べないです"]}, {"box": [650, 501, 693, 582], "vertical": true, "font_size": 32.0, "lines": ["綾波が"]}, {"box": [443, 369, 464, 463], "vertical": true, "font_size": 20.0, "lines": ["もちろん"]}, {"box": [563, 553, 626, 721], "vertical": true, "font_size": 32.0, "lines": ["以前の綾波じゃ", "ない気がして"]}, {"box": [95, 562, 191, 734], "vertical": true, "font_size": 24.0, "lines": ["あの状況下で", "あの程度のケガで", "済むハズがない．．"]}, {"box": [829, 805, 931, 949], "vertical": true, "font_size": 24.0, "lines": ["今までにない", "大きな秘密が", "隠されてる"]}, {"box": [565, 949, 596, 1006], "vertical": true, "font_size": 31.0, "lines": ["そう"]}, {"box": [404, 849, 473, 995], "vertical": true, "font_size": 26.0, "lines": ["いったい何を", "隠してるの？"]}, {"box": [194, 920, 216, 1015], "vertical": true, "font_size": 20.0, "lines": ["リツコ．．．"]}, {"box": [531, 1171, 598, 1338], "vertical": true, "font_size": 25.0, "lines": ["すべての核心に", "触れるような．．．"]}], "img_path": "122.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [754, 325, 836, 363], "vertical": false, "font_size": 32.0, "lines": ["ＳＥＥＬＥ"]}, {"box": [224, 331, 303, 409], "vertical": false, "font_size": 32.0, "lines": ["．．．"]}, {"box": [486, 364, 568, 386], "vertical": false, "font_size": 24.0, "lines": ["さらにして"]}], "img_path": "123.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [828, 88, 898, 301], "vertical": true, "font_size": 26.0, "lines": ["いい加減に素直に", "なったらどうだね？"]}, {"box": [519, 96, 589, 242], "vertical": true, "font_size": 25.0, "lines": ["我々も穏便に", "事は進めたい"]}, {"box": [257, 79, 333, 248], "vertical": true, "font_size": 29.0, "lines": ["君にこれ以上の", "陵辱"]}, {"box": [826, 638, 899, 738], "vertical": true, "font_size": 32.0, "lines": ["私は何の", "屈辱も"]}, {"box": [643, 437, 677, 533], "vertical": true, "font_size": 25.0, "lines": ["赤木博士"]}, {"box": [93, 398, 160, 586], "vertical": true, "font_size": 23.0, "lines": ["つらい思いは", "させたくないのだ"]}, {"box": [156, 783, 224, 907], "vertical": true, "font_size": 31.0, "lines": ["感じて", "いませんが"]}, {"box": [837, 1046, 873, 1261], "vertical": true, "font_size": 25.0, "lines": ["「気の強い女性だ"]}, {"box": [230, 1022, 338, 1189], "vertical": true, "font_size": 31.0, "lines": ["碇が側に", "置きたがるのも", "分かる"]}, {"box": [129, 1267, 161, 1323], "vertical": true, "font_size": 32.0, "lines": ["だが"]}], "img_path": "124.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [843, 86, 947, 254], "vertical": true, "font_size": 26.0, "lines": ["君を我々に", "差し出したのは", "他でもない"]}, {"box": [811, 532, 915, 678], "vertical": true, "font_size": 30.0, "lines": ["零号機", "パイロットの", "尋問を拒否"]}, {"box": [590, 363, 624, 458], "vertical": true, "font_size": 24.0, "lines": ["碇君だよ"]}, {"box": [338, 564, 369, 727], "vertical": true, "font_size": 20.0, "lines": ["レイの代わり．．．"]}, {"box": [464, 849, 572, 1016], "vertical": true, "font_size": 28.0, "lines": ["代理人として", "君をよこしたの", "だよ"]}, {"box": [583, 1225, 619, 1321], "vertical": true, "font_size": 30.0, "lines": ["赤木博士"]}, {"box": [129, 1212, 168, 1286], "vertical": true, "font_size": 27.0, "lines": ["私が．．．"]}], "img_path": "125.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [], "img_path": "126.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [891, 709, 940, 771], "vertical": true, "font_size": 32.0, "lines": ["私．．．"]}, {"box": [491, 708, 560, 849], "vertical": true, "font_size": 25.0, "lines": ["何故また", "生きてるの？"]}, {"box": [167, 935, 203, 1079], "vertical": true, "font_size": 24.0, "lines": ["何のために？"]}, {"box": [653, 1154, 724, 1276], "vertical": true, "font_size": 27.0, "lines": ["何故ここに", "いるの？"]}, {"box": [528, 1206, 559, 1351], "vertical": true, "font_size": 24.0, "lines": ["誰のために？"]}], "img_path": "127.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [], "img_path": "128.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [458, 89, 501, 168], "vertical": true, "font_size": 32.0, "lines": ["涙．．．．．"]}, {"box": [155, 171, 188, 289], "vertical": true, "font_size": 20.0, "lines": ["これが涙？"]}, {"box": [436, 393, 458, 536], "vertical": true, "font_size": 19.0, "lines": ["どうして．．．？"]}, {"box": [117, 533, 186, 650], "vertical": true, "font_size": 22.0, "lines": ["初めて見た", "はずなのに"]}, {"box": [541, 819, 595, 860], "vertical": false, "font_size": 32.0, "lines": ["私"]}, {"box": [687, 1138, 790, 1260], "vertical": true, "font_size": 24.0, "lines": ["初めてじゃ", "ないような", "気がする"]}, {"box": [166, 1192, 206, 1334], "vertical": true, "font_size": 29.0, "lines": ["泣いてる．．．"]}], "img_path": "129.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [870, 78, 916, 193], "vertical": true, "font_size": 31.0, "lines": ["何故私は"]}, {"box": [585, 536, 621, 736], "vertical": true, "font_size": 28.0, "lines": ["泣いているの？"]}], "img_path": "130.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [83, 1314, 489, 1367], "vertical": false, "font_size": 32.0, "lines": ["汚れた血", "ＳＴＡＧＥ«６９"]}], "img_path": "131.jpg"}, {"version": "0.1.6", "img_width": 2048, "img_height": 1436, "blocks": [{"box": [1883, 652, 1907, 769], "vertical": true, "font_size": 22.0, "lines": ["よいのか？"]}, {"box": [1312, 690, 1353, 832], "vertical": true, "font_size": 30.0, "lines": ["冬月とは違う"]}, {"box": [1662, 1174, 1737, 1296], "vertical": true, "font_size": 32.0, "lines": ["赤木博士の", "処置"]}, {"box": [1204, 1118, 1274, 1264], "vertical": true, "font_size": 31.0, "lines": ["彼女は返した", "方が得策だ"]}, {"box": [876, 684, 942, 874], "vertical": true, "font_size": 31.0, "lines": ["エヴァシリーズの", "功労者"]}, {"box": [294, 698, 365, 844], "vertical": true, "font_size": 32.0, "lines": ["我々人類の", "未来のために"]}, {"box": [494, 1188, 600, 1316], "vertical": true, "font_size": 32.0, "lines": ["今少した", "役に立って", "もらおう"]}], "img_path": "132-133.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [637, 113, 805, 149], "vertical": false, "font_size": 32.0, "lines": ["２００８年箱根"]}, {"box": [678, 572, 851, 715], "vertical": true, "font_size": 28.0, "lines": ["発令所の", "軀体が", "できたって", "いうから", "見に来たけど"]}, {"box": [809, 839, 880, 984], "vertical": true, "font_size": 29.0, "lines": ["まるで迷路ね", "ここ"]}, {"box": [225, 826, 259, 881], "vertical": true, "font_size": 28.0, "lines": ["ふふ"]}, {"box": [110, 904, 204, 1140], "vertical": true, "font_size": 28.0, "lines": ["あなたもゲヒルンへの", "入所を目指すのなら", "慣れておかないとね"]}], "img_path": "134.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [876, 115, 914, 180], "vertical": true, "font_size": 32.0, "lines": ["わあ"]}, {"box": [545, 56, 629, 174], "vertical": true, "font_size": 32.0, "lines": ["これが", "「マギ」ね"]}, {"box": [339, 260, 361, 427], "vertical": true, "font_size": 22.0, "lines": ["ちょっとおまえゴミュニュースターではなかった。"]}, {"box": [633, 314, 662, 486], "vertical": true, "font_size": 29.0, "lines": ["どうなったんだろう。あの、あなたのころ．．．"]}, {"box": [248, 459, 273, 652], "vertical": true, "font_size": 25.0, "lines": ["２０１８年０９月２０日（金）ミュージョンセンターは"]}, {"box": [136, 615, 206, 759], "vertical": true, "font_size": 24.0, "lines": ["人格移植", "ＯＳの第一号"]}, {"box": [840, 834, 911, 934], "vertical": true, "font_size": 32.0, "lines": ["マギ", "カスパー"]}, {"box": [153, 884, 218, 1029], "vertical": true, "font_size": 32.0, "lines": ["マギ", "メルキオール"]}, {"box": [502, 1221, 566, 1365], "vertical": true, "font_size": 29.0, "lines": ["マギ", "ハルタザール"]}, {"box": [136, 1144, 340, 1216], "vertical": false, "font_size": 30.0, "lines": ["「日本「ＧＷＡＮＡＮＥ」のお"]}], "img_path": "135.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [654, 102, 694, 295], "vertical": true, "font_size": 24.0, "lines": ["科学者としての私"]}, {"box": [509, 182, 566, 484], "vertical": true, "font_size": 32.0, "lines": ["Ｓｒａｃｋｍａｔａｒａｍｅｎｄｏｗｓ"]}, {"box": [252, 115, 352, 266], "vertical": true, "font_size": 26.0, "lines": ["その３人の私が", "せめぎ合ってる", "のよ"]}, {"box": [818, 636, 920, 717], "vertical": true, "font_size": 32.0, "lines": ["マギは", "３人の", "私なの"]}, {"box": [443, 333, 478, 499], "vertical": true, "font_size": 24.0, "lines": ["母親としての私"]}, {"box": [240, 514, 364, 623], "vertical": true, "font_size": 23.0, "lines": ["人の持つ", "シレンマを", "わざわざ", "残したのね"]}, {"box": [839, 944, 899, 1042], "vertical": true, "font_size": 25.0, "lines": ["どうだね", "調子は？"]}, {"box": [553, 709, 629, 831], "vertical": true, "font_size": 32.0, "lines": ["女としての", "私"]}, {"box": [100, 752, 128, 901], "vertical": true, "font_size": 20.0, "lines": ["母さんらしいわ"]}, {"box": [791, 1049, 816, 1145], "vertical": true, "font_size": 25.0, "lines": ["赤木博士"]}, {"box": [132, 1246, 164, 1303], "vertical": true, "font_size": 32.0, "lines": ["あ．．．"]}], "img_path": "136.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [819, 132, 922, 276], "vertical": true, "font_size": 30.0, "lines": ["おはよう", "ございます！", "所長"]}, {"box": [511, 118, 547, 284], "vertical": true, "font_size": 24.0, "lines": ["娘さんが一緒か"]}, {"box": [127, 122, 234, 247], "vertical": true, "font_size": 32.0, "lines": ["確か", "リツコくん", "といったか"]}, {"box": [518, 450, 552, 506], "vertical": true, "font_size": 32.0, "lines": ["あ．．．"]}, {"box": [119, 461, 195, 586], "vertical": true, "font_size": 30.0, "lines": ["お久しぶり", "です"]}, {"box": [825, 759, 920, 880], "vertical": true, "font_size": 26.0, "lines": ["所長こそ", "娘さん連れ", "ですか？"]}, {"box": [755, 736, 786, 813], "vertical": true, "font_size": 26.0, "lines": ["なんて"]}, {"box": [724, 736, 783, 876], "vertical": true, "font_size": 20.0, "lines": ["かわいらしい"]}, {"box": [400, 741, 468, 822], "vertical": true, "font_size": 32.0, "lines": ["あら", "でも．．．"]}, {"box": [127, 751, 197, 966], "vertical": true, "font_size": 27.0, "lines": ["確か所長のところは", "男の子じゃ．．．"]}, {"box": [391, 1047, 455, 1191], "vertical": true, "font_size": 25.0, "lines": ["シンジでは", "ありませんよ"]}], "img_path": "137.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [694, 106, 798, 248], "vertical": true, "font_size": 23.0, "lines": ["知人の子を", "預かることに", "なりましてね"]}, {"box": [137, 231, 225, 379], "vertical": true, "font_size": 32.0, "lines": ["綾波レイと", "いいます"]}, {"box": [835, 552, 894, 692], "vertical": true, "font_size": 24.0, "lines": ["レイちゃんね", "こんにちは"]}, {"box": [835, 992, 900, 1091], "vertical": true, "font_size": 28.0, "lines": ["この子．．", "誰かに．．"]}, {"box": [143, 1199, 173, 1370], "vertical": true, "font_size": 28.0, "lines": ["ユイさん．．．？"]}], "img_path": "138.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [367, 269, 559, 382], "vertical": true, "font_size": 32.0, "lines": ["行こう", "レイ", "邪魔に", "なると", "いけない"]}, {"box": [913, 841, 946, 938], "vertical": true, "font_size": 25.0, "lines": ["母さん．．．"]}, {"box": [454, 878, 525, 974], "vertical": true, "font_size": 29.0, "lines": ["所長の", "奥さんよ"]}, {"box": [603, 1162, 632, 1336], "vertical": true, "font_size": 26.0, "lines": ["「ユイ」って．．．？"]}, {"box": [137, 1157, 204, 1279], "vertical": true, "font_size": 27.0, "lines": ["今はもう", "いないけど"]}], "img_path": "139.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [877, 93, 912, 227], "vertical": true, "font_size": 26.0, "lines": ["その時私は"]}, {"box": [509, 326, 536, 468], "vertical": true, "font_size": 26.0, "lines": ["母さんの顔が"]}, {"box": [423, 381, 482, 621], "vertical": true, "font_size": 26.0, "lines": ["科学者としてでもなく", "母としてでもない"]}, {"box": [129, 245, 198, 506], "vertical": true, "font_size": 26.0, "lines": ["女としての感情によって", "醜くゆがむのを見た"]}, {"box": [837, 744, 903, 935], "vertical": true, "font_size": 28.0, "lines": ["そしてあの事件が", "起きたのは"]}, {"box": [531, 762, 603, 905], "vertical": true, "font_size": 25.0, "lines": ["私は入所して", "間がなかった"]}, {"box": [474, 727, 496, 807], "vertical": true, "font_size": 20.0, "lines": ["いけない"]}, {"box": [75, 729, 122, 810], "vertical": true, "font_size": 32.0, "lines": ["忘れ物"]}, {"box": [696, 1132, 729, 1272], "vertical": true, "font_size": 20.0, "lines": ["２年後だった"]}, {"box": [515, 1057, 610, 1250], "vertical": true, "font_size": 24.0, "lines": ["せっかく久しぶりに", "ミサトがドイツから", "戻ってきてるのに"]}, {"box": [86, 1083, 179, 1212], "vertical": true, "font_size": 22.0, "lines": ["早くしないと", "待ち合わせに", "遅れちゃう"]}], "img_path": "140.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [565, 98, 598, 195], "vertical": true, "font_size": 24.0, "lines": ["母さんと"]}, {"box": [901, 413, 934, 468], "vertical": true, "font_size": 32.0, "lines": ["あら"]}, {"box": [109, 462, 137, 628], "vertical": true, "font_size": 24.0, "lines": ["レイ．．．ちゃん？"]}, {"box": [867, 756, 936, 873], "vertical": true, "font_size": 25.0, "lines": ["何してるの", "かしら"]}, {"box": [575, 684, 678, 809], "vertical": true, "font_size": 32.0, "lines": ["よく", "聞こえ", "なかったわ"]}, {"box": [711, 1203, 748, 1321], "vertical": true, "font_size": 30.0, "lines": ["怖い顔して"]}, {"box": [606, 1087, 645, 1191], "vertical": true, "font_size": 32.0, "lines": ["もう一度"]}, {"box": [413, 1206, 480, 1350], "vertical": true, "font_size": 30.0, "lines": ["言って", "ごらんなさい"]}, {"box": [113, 1250, 146, 1364], "vertical": true, "font_size": 30.0, "lines": ["バァさん"]}], "img_path": "141.jpg"}, {"version": "0.1.6", "img_width": 1024, "img_height": 1454, "blocks": [{"box": [872, 79, 901, 244], "vertical": true, "font_size": 22.0, "lines": ["わたしじゃない"]}, {"box": [815, 177, 835, 363], "vertical": true, "font_size": 22.0, "lines": ["所長が言ってるの"]}, {"box": [434, 75, 498, 174], "vertical": true, "font_size": 30.0, "lines": ["あ