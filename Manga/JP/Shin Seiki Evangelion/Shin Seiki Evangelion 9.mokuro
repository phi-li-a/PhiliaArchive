t_size": 19.0, "lines": ["捕まったのか．．．", "ライフルは幼かないっ", "つってんのに"]}, {"box": [80, 978, 133, 1096], "vertical": true, "font_size": 24.0, "lines": ["これも", "効かないのか"]}], "img_path": "171.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1200, "blocks": [{"box": [340, 655, 366, 725], "vertical": true, "font_size": 26.0, "lines": ["まずい"]}, {"box": [604, 843, 686, 1147], "vertical": true, "font_size": 32.0, "lines": ["イベキミチ"]}, {"box": [83, 956, 119, 1073], "vertical": true, "font_size": 21.0, "lines": ["侵蝕型か！！"]}], "img_path": "172.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1200, "blocks": [{"box": [589, 758, 723, 954], "vertical": false, "font_size": 32.0, "lines": ["〜舜藩"]}], "img_path": "173.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1200, "blocks": [], "img_path": "174.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1200, "blocks": [{"box": [55, 50, 74, 113], "vertical": true, "font_size": 19.0, "lines": ["Ｎｅｔ"]}], "img_path": "175.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1200, "blocks": [{"box": [265, 53, 525, 94], "vertical": false, "font_size": 16.0, "lines": ["ＹｏｓｕｒｕｋｌＳＡＤＡＭＯＴＯ", "ＰＲＯＦＬＥ"]}, {"box": [258, 126, 533, 444], "vertical": false, "font_size": 19.0, "lines": ["日本銀行（さだもとよしゆき）●ｌｑＢＰ", "年１月２９日生まれ。血液型Ａ型。山口", "県徳山市出身。東京造形大学卒業後、", "アニメーターとなる。キャラクター・", "デザイナー、作画監督として活躍。", "代表作品「オネアミスの翼、王立宇", "宙軍」「トップをねらえノ」「ふしぎ", "の海のナディア「新世紀エヴァンゲ", "リオン」「フリクリ」等。＇９５年２月号", "より月刊少年工－一スにて「新世紀工", "ヴァンゲリオン」を連載。現在", "ＧＡＩＮＡＸ所属。"]}, {"box": [330, 532, 456, 553], "vertical": false, "font_size": 23.0, "lines": ["ｓＴＡＦＦＬＩＳＴ"]}, {"box": [258, 604, 375, 625], "vertical": false, "font_size": 18.0, "lines": ["Ｔｈｅ．ａｕｔｈｏｒ"]}, {"box": [258, 657, 361, 676], "vertical": false, "font_size": 17.0, "lines": ["Ａｓｓｌｅｔａｎｔ"]}, {"box": [436, 601, 528, 834], "vertical": false, "font_size": 13.0, "lines": ["貞本祗行"]}, {"box": [434, 640, 528, 833], "vertical": false, "font_size": 17.0, "lines": ["野田バルス", "天草あむ", "下口智裕", "ツガノガク", "竹重真一郎"]}, {"box":