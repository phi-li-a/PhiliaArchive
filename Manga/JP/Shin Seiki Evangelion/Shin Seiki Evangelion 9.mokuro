29], "vertical": true, "font_size": 19.0, "lines": ["使徒は人の心を", "知ろうとして", "いるの？"]}], "img_path": "089.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1200, "blocks": [{"box": [669, 760, 728, 841], "vertical": true, "font_size": 24.0, "lines": ["因果な", "モノだな"]}, {"box": [330, 564, 381, 637], "vertical": true, "font_size": 32.0, "lines": ["痛い"]}, {"box": [111, 939, 167, 1079], "vertical": true, "font_size": 20.0, "lines": ["提唱した本人が", "実験台とは"]}], "img_path": "090.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1200, "blocks": [{"box": [700, 50, 720, 128], "vertical": true, "font_size": 19.0, "lines": ["精神崩壊"]}, {"box": [633, 162, 680, 316], "vertical": true, "font_size": 19.0, "lines": ["それがあの", "接触実験の結果が"]}, {"box": [83, 104, 192, 262], "vertical": true, "font_size": 22.0, "lines": ["しかしあんな", "小さな娘を残して", "自殺とは", "残酷なものだな"]}, {"box": [687, 494, 710, 534], "vertical": true, "font_size": 21.0, "lines": ["いや"]}, {"box": [587, 537, 666, 696], "vertical": true, "font_size": 21.0, "lines": ["それだけが", "原因ではないと", "もっぱらの噂だよ"]}, {"box": [106, 772, 220, 931], "vertical": true, "font_size": 20.0, "lines": ["みんなで相談して", "私があなたを", "引き取ることに", "なったから"]}, {"box": [603, 990, 624, 1107], "vertical": true, "font_size": 20.0, "lines": ["アスカちゃん"]}, {"box": [305, 1000, 366, 1119], "vertical": true, "font_size": 27.0, "lines": ["心配しなくて", "いいよ"]}], "img_path": "091.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1200, "blocks": [{"box": [650, 26, 701, 164], "vertical": true, "font_size": 20.0, "lines": ["アスカちゃんは", "お利口だから"]}, {"box": [285, 45, 309, 164], "vertical": true, "font_size": 20.0, "lines": ["アスカちゃん"]}, {"box": [402, 363, 459, 539], "vertical": true, "font_size": 20.0, "lines": ["おばさんの家でも", "ちゃんとやれるわね"]}, {"box": [653, 603, 676, 721], "vertical": true, "font_size": 20.0, "lines": ["アスカちゃん"]}, {"box": [71, 626, 179, 763], "vertical": true, "font_size": 21.0, "lines": ["ママ", "今日はあなたの", "大好物を", "作ったのよ"]}, {"box": [513, 891, 571, 957], "vertical": true, "font_size": 32.0, "lines": ["さあ", "食べて"]}], "img_path": "092.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1200, "blocks": [{"box": [336, 79, 420, 275], "vertical": true, "font_size": 20.0, "lines": ["好き嫌いしてると", "あそこのお姉ちゃんに", "笑われますよ"]}, {"box": [671, 421, 720, 540], "vertical": true, "font_size": 22.0, "lines": ["毎日あの調子", "なんです"]}, {"box": [140, 411, 200, 665], "vertical": true, "font_size": 22.0, "lines": ["自分の実の子が目の前に", "いるのに何故なんでしょうか"]}, {"box": [590, 549, 671, 708], "vertical": true, "font_size": 22.0, "lines": ["人形を娘さんだと", "思って話しかけて", "います"]}, {"box": [646, 842, 732, 1039], "vertical": true, "font_size": 22.0, "lines": ["今の彼女にとっては", "あの人形の方が", "本当の子供なんだろう"]}, {"box": [282, 860, 370, 1037], "vertical": true, "font_size": 22.0, "lines": ["本当は自分が愛した", "夫との子供が", "欲しかったんだよ"]}], "img_path": "093.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1200, "blocks": [{"box": [660, 58, 710, 233], "vertical": true, "font_size": 20.0, "lines": ["彼女は夫との子供が", "欲しかったが"]}, {"box": [576, 112, 627, 290], "vertical": true, "font_size": 20.0, "lines": ["彼女の子宮では", "それは叶わなかった"]}, {"box": [304, 80, 357, 199], "vertical": true, "font_size": 21.0, "lines": ["夫はそのうち", "他に女を作り"]}, {"box": [263, 154, 283, 271], "vertical": true, "font_size": 21.0, "lines": ["ほどなく離婚"]}, {"box": [51, 76, 159, 234], "vertical": true, "font_size": 20.0, "lines": ["あげくに", "その浮気相手と", "子供を作った上、", "再婚してしまった"]}, {"box": [626, 558, 675, 659], "vertical": true, "font_size": 21.0, "lines": ["無理もない", "話だろう？"]}, {"box": [452, 614, 590, 810], "vertical": true, "font_size": 21.0, "lines": ["高い金で精子を", "買って無理矢理子供を", "作っても心の穴は", "埋められなかったと", "いうワケだ"]}, {"box": [128, 583, 190, 636], "vertical": true, "font_size": 31.0, "lines": ["しっ", "先生"]}, {"box": [593, 952, 658, 1071], "vertical": true, "font_size": 26.0, "lines": ["娘さんに", "聞こえます"]}], "img_path": "094.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1200, "blocks": [{"box": [713, 75, 743, 173], "vertical": true, "font_size": 20.0, "lines": 