cal": true, "font_size": 20.0, "lines": ["健在です"]}, {"box": [260, 656, 373, 824], "vertical": true, "font_size": 19.0, "lines": ["相転移空間を内眼で", "確認できるほど", "強力なものが展開", "されています"]}, {"box": [63, 687, 82, 709], "vertical": true, "font_size": 19.0, "lines": ["十"]}], "img_path": "eve3_089.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [705, 59, 764, 139], "vertical": true, "font_size": 23.0, "lines": ["攻守共に", "ほぼ完璧"]}, {"box": [104, 78, 217, 235], "vertical": true, "font_size": 23.0, "lines": ["問題の", "ボーリング・", "マシンは？"]}, {"box": [395, 258, 472, 409], "vertical": true, "font_size": 20.0, "lines": ["まさに", "難攻不落の", "空中要塞なわけね"]}, {"box": [606, 479, 722, 688], "vertical": true, "font_size": 24.0, "lines": ["現在直径１７．５Ｍの", "巨大ドリル・ブレードが", "ネルフ本部に向かい", "穿孔中"]}, {"box": [298, 626, 365, 778], "vertical": true, "font_size": 20.0, "lines": ["第２装甲板まで", "到達しています。"]}, {"box": [652, 893, 722, 1029], "vertical": true, "font_size": 26.0, "lines": ["本部への到達", "予想時刻は？"]}, {"box": [101, 869, 172, 1046], "vertical": true, "font_size": 28.0, "lines": ["明日午前", "０時６分５４秒です"]}], "img_path": "eve3_090.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [500, 80, 665, 310], "vertical": true, "font_size": 27.0, "lines": ["その時刻には", "２２層すべての装甲", "防壁を貫通して", "ネルフ本部へ到達する", "ものと思われます"]}, {"box": [351, 84, 418, 204], "vertical": true, "font_size": 27.0, "lines": ["あと１０時間", "足らずか：・"]}, {"box": [376, 306, 412, 396], "vertical": true, "font_size": 24.0, "lines": ["赤木博士"]}, {"box": [78, 304, 144, 396], "vertical": true, "font_size": 22.0, "lines": ["初号機の", "状況は？"]}, {"box": [358, 539, 406, 688], "vertical": true, "font_size": 21.0, "lines": ["胸部第３装甲まで", "みごとに融解"]}, {"box": [234, 540, 308, 708], "vertical": true, "font_size": 21.0, "lines": ["でも機能中枢を", "やられなかったのは", "不幸中の幸いね"]}, {"box": [81, 550, 159, 663], "vertical": true, "font_size": 21.0, "lines": ["３時間後には", "換装作業", "終了よ"]}], "img_path": "eve3_091.jpg"}, {"version": "0.1.6", "img_width": 800, "i