true, "font_size": 20.0, "lines": ["こんな時でも", "迎えに来て", "くれないんだね"]}, {"box": [637, 783, 666, 841], "vertical": true, "font_size": 19.0, "lines": ["母さん"]}, {"box": [470, 641, 523, 753], "vertical": true, "font_size": 17.0, "lines": ["もし母さんが", "生きてたら"]}, {"box": [128, 759, 191, 881], "vertical": true, "font_size": 32.0, "lines": ["かあ", "母さん"]}, {"box": [355, 914, 410, 1026], "vertical": true, "font_size": 18.0, "lines": ["迎えに来て", "くれた．．．．．？"]}], "img_path": "eve3_099.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [660, 16, 705, 152], "vertical": true, "font_size": 23.0, "lines": ["かあ", "母さん．．．"]}], "img_path": "eve3_100.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [661, 52, 697, 125], "vertical": true, "font_size": 19.0, "lines": ["あやなみ", "綾波．．．"]}, {"box": [75, 108, 126, 203], "vertical": true, "font_size": 32.0, "lines": ["「チャ"]}, {"box": [419, 509, 435, 570], "vertical": true, "font_size": 16.0, "lines": ["．．．．．．"]}, {"box": [86, 339, 122, 432], "vertical": true, "font_size": 24.0, "lines": ["．．．食事"]}, {"box": [595, 517, 680, 633], "vertical": true, "font_size": 23.0, "lines": ["目が覚めたら", "食べるように", "．．．．．．"]}, {"box": [376, 750, 428, 896], "vertical": true, "font_size": 21.0, "lines": ["食べといたほうが", "いいと思うわ"]}, {"box": [84, 517, 142, 633], "vertical": true, "font_size": 22.0, "lines": ["何も食べたく", "ないよ"]}, {"box": [89, 831, 144, 924], "vertical": true, "font_size": 19.0, "lines": ["６０分後には", "出発だから"]}], "img_path": "eve3_101.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [117, 289, 139, 385], "vertical": true, "font_size": 19.0, "lines": ["え？"]}, {"box": [602, 541, 716, 674], "vertical": true, "font_size": 28.0, "lines": ["陽電子砲の", "準備は", "どう？"]}, {"box": [367, 535, 502, 711], "vertical": true, "font_size": 21.0, "lines": ["技術開発部の", "意地にかけても", "あと３時間で形に", "してみせますｍ"]}, {"box": [101, 931, 166, 1062], "vertical": true, "font_size": 23.0, "lines": ["任せてもらい", "ましょうか"]}], "img_path": "eve3_102.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [615, 38, 705, 170], "vertical": true, "font_size": 23.0, "lines": ["エネルギー・", "システムの", "見通しは？"]}, {"box": [25, 78, 157, 283], "vertical": true, "font_size": 22.0, "lines": ["現在予定より", "３．２．２遅れていますが", "本日２３時１０分には", "なんとかできます"]}, {"box": [669, 421, 689, 518], "vertical": true, "font_size": 20.0, "lines": ["ー頭の固い"]}, {"box": [558, 387, 661, 503], "vertical": true, "font_size": 20.0, "lines": ["戦自研がよく", "陽電子砲の", "徴発に応じた", "ものだ．．．"]}, {"box": [552, 584, 709, 743], "vertical": true, "font_size": 23.0, "lines": ["エヴァによる", "超長距離からの", "直接射撃．．．．．", "日本国内総電力", "の徴発！"]}, {"box": [42, 578, 169, 740], "vertical": true, "font_size": 26.0, "lines": ["ずいぶんと", "大胆な作戦を", "立てたものだな", "葛城一尉"]}, {"box": [606, 905, 713, 1050], "vertical": true, "font_size": 20.0, "lines": ["残された", "時間の内でできる", "もっとも確実な", "方法です"]}, {"box": [21, 870, 189, 1075], "vertical": true, "font_size": 21.0, "lines": ["目標の強硬な", "Ａ．Ｔ．フィールドを", "中和せず打破するには", "高エネルギー集中帯", "による一点突破！！", "それしか道はありません"]}], "img_path": "eve3_103.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [642, 89, 722, 274], "vertical": true, "font_size": 27.0, "lines": ["反対する理由は", "何もない"]}, {"box": [97, 91, 174, 224], "vertical": true, "font_size": 28.0, "lines": ["存分に", "やりたまえ"]}, {"box": [374, 363, 490, 529], "vertical": true, "font_size": 32.0, "lines": ["敵シールド", "第９装甲板を", "突破！！"]}, {"box": [107, 886, 198, 1062], "vertical": true, "font_size": 32.0, "lines": ["到達まであと", "６時間４５分"]}], "img_path": "eve3_104.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [71, 72, 363, 126], "vertical": false, "font_size": 32.0, "lines": ["ＳＴＡＥＬ７，大戦前に"]}, {"box": [675, 131, 754, 195], "vertical": false, "font_size": 29.0, "lines": ["．．．"]}], "img_path": "eve3_105.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [196, 95, 290, 276], "vertical": true, "font_size": 24.0, "lines": ["明日午前０時から", "発動される作戦の", "スケジュール．．．"]}, {"box": [136, 283, 160, 353], "vertical": true, "font_size": 24.0, "lines": ["読む？"]}, {"box": [357, 603, 468, 734], "vertical": true, "font_size": 23.0, "lines": ["碇・綾波の", "両パイロットは", "本日１７時３０分", "ケイジに集合"]}, {"box": [248, 607, 306, 739], "vertical": true, "font_size": 22.0, "lines": ["同３０分二子山", "仮設基地に到着"]}, {"box": [570, 864, 715, 1012], "vertical": true, "font_size": 26.0, "lines": ["１８時００分", "エヴァンゲリオン", "初号機および", "零号機起動", "１８時０５分出動"]}, {"box": [96, 908, 154, 1018], "vertical": true, "font_size": 20.0, "lines": ["以降は別命", "あるまで待機"]}], "img_path": "eve3_106.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [58, 188, 142, 322], "vertical": true, "font_size": 22.0, "lines": ["またアレに", "乗らなきゃ", "ならないのか"]}, {"box": [607, 420, 693, 535], "vertical": true, "font_size": 20.0, "lines": ["明朝日付変更", "と同時に", "作戦行動開始"]}, {"box": [313, 414, 396, 549], "vertical": true, "font_size": 23.0, "lines": ["こんな目に", "あったばかり", "なのに"]}, {"box": [621, 685, 641, 759], "vertical": true, "font_size": 20.0, "lines": ["いやなら"]}, {"box": [128, 685, 178, 781], "vertical": true, "font_size": 22.0, "lines": ["また", "逃げたら？"]}, {"box": [83, 931, 139, 1026], "vertical": true, "font_size": 22.0, "lines": ["初号機には", "私が乗る"]}], "img_path": "eve3_107.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [634, 42, 728, 176], "vertical": true, "font_size": 20.0, "lines": ["パーソナル・", "データの", "書き換えなんて", "すぐだもの"]}, {"box": [379, 23, 399, 102], "vertical": true, "font_size": 16.0, "lines": ["じゃ"]}, {"box": [141, 350, 200, 427], "vertical": true, "font_size": 22.0, "lines": ["６０分後に", "また"]}, {"box": [232, 498, 254, 599], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．"]}, {"box": [667, 810, 749, 889], "vertical": true, "font_size": 25.0, "lines": ["食事．．", "ちゃんと", "食べてね"]}], "img_path": "eve3_108.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [596, 332