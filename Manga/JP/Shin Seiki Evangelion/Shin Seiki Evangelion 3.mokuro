": [{"box": [736, 64, 757, 199], "vertical": true, "font_size": 18.0, "lines": ["．．．うれしくて？"]}, {"box": [124, 118, 174, 197], "vertical": true, "font_size": 23.0, "lines": ["ごめんな", "さい"]}, {"box": [429, 298, 485, 379], "vertical": true, "font_size": 28.0, "lines": ["私は", "こんな時"]}, {"box": [565, 504, 620, 621], "vertical": true, "font_size": 21.0, "lines": ["うれしい時も", "涙が出るのね"]}, {"box": [639, 723, 714, 834], "vertical": true, "font_size": 19.0, "lines": ["ほんとは", "うれしいはず", "なのにね．．．"]}, {"box": [316, 723, 409, 816], "vertical": true, "font_size": 28.0, "lines": ["ふつうは", "嬉しかっ", "たら"]}, {"box": [130, 542, 212, 674], "vertical": true, "font_size": 19.0, "lines": ["どんな顔したら", "いいのか", "わからない"]}, {"box": [89, 952, 158, 1022], "vertical": true, "font_size": 28.0, "lines": ["笑うん", "だよ"]}], "img_path": "eve3_162.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [100, 349, 131, 443], "vertical": true, "font_size": 23.0, "lines": ["立てる？"]}], "img_path": "eve3_163.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [], "img_path": "eve3_164.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [684, 40, 702, 107], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．"]}, {"box": [513, 62, 541, 94], "vertical": true, "font_size": 28.0, "lines": ["！？"]}, {"box": [667, 399, 720, 462], "vertical": true, "font_size": 26.0, "lines": ["あっ．．．", "いや．．．"]}, {"box": [474, 297, 493, 391], "vertical": true, "font_size": 19.0, "lines": ["どうしたの"]}, {"box": [107, 489, 142, 562], "vertical": true, "font_size": 28.0, "lines": ["綾波．．．"]}, {"box": [481, 625, 512, 687], "vertical": true, "font_size": 24.0, "lines": ["行こう"]}, {"box": [494, 829, 629, 1009], "vertical": true, "font_size": 25.0, "lines": ["もう別れ際に", "「さよなら」なんて", "悲しいこと", "言うなよ"]}], "img_path": "eve3_165.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [548, 283, 681, 507], "vertical": true, "font_size": 23.0, "lines": ["今僕達には", "エヴァに乗ること以外", "何もないかも", "しれないけど．．．"]}, {"box": [137, 382, 171, 438], "vertical": true, "font_size": 32.0, "lines": ["でも"]}, {"box": [585, 617, 682, 728], "vertical": true, "font_size": 25.0, "lines": ["生きてさえ", "いれば", "いつか必ず"]}, {"box": [124, 662, 250, 794], "vertical": true, "font_size": 25.0, "lines": ["生きてて", "よかったって", "思う時が", "きっとあるよ"]}], "img_path": "eve3_166.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [106, 123, 228, 260], "vertical": true, "font_size": 22.0, "lines": ["それは", "ずっと先の", "ことかも", "しれないけど"]}, {"box": [630, 373, 689, 486], "vertical": true, "font_size": 25.0, "lines": ["でも", "それまでは"]}, {"box": [94, 342, 208, 470], "vertical": false, "font_size": 32.0, "lines": ["ふふふ、", "レイ！"]}, {"box": [147, 811, 212, 880], "vertical": true, "font_size": 26.0, "lines": ["生きて", "行こう"]}], "img_path": "eve3_167.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [655, 105, 729, 288], "vertical": true, "font_size": 25.0, "lines": ["まっ暗で", "何もない道でも"]}, {"box": [491, 240, 527, 394], "vertical": true, "font_size": 23.0, "lines": ["２人で行けば"]}, {"box": [119, 230, 237, 397], "vertical": true, "font_size": 31.0, "lines": ["何か", "みつかるかも", "しれない"]}, {"box": [105, 719, 179, 903], "vertical": true, "font_size": 26.0, "lines": ["あの空に浮かぶ", "月のように"]}], "img_path": "eve3_168.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [128, 51, 167, 63], "vertical": false, "font_size": 12.0, "lines": ["．．．"]}, {"box": [132, 68, 274, 91], "vertical": false, "font_size": 23.0, "lines": ["．．．"]}, {"box": [185, 92, 204, 147], "vertical": true, "font_size": 17.0, "lines": ["．．．"]}, {"box": [402, 164, 406, 180], "vertical": true, "font_size": 12.0, "lines": ["．．．"]}, {"box": [468, 119, 479, 163], "vertical": true, "font_size": 12.0, "lines": ["．．．"]}, {"box": [502, 120, 513, 160], "vertical": true, "font_size": 12.0, "lines": ["．．．"]}, {"box": [571, 124, 579, 180], "vertical": true, "font_size": 12.0, "lines": ["．．．"]}, {"box": [401, 287, 408, 330], "vertical": true, "font_size": 12.0, "lines": ["．．．"]}, {"box": [437, 319, 441, 330], "vertical": true, "font_size": 12.0, "lines": ["．．．"]}, {"box": [574, 525, 582, 597], "vertical": true, "font_size": 12.0, "lines": ["．．．"]}, {"box": [609, 516, 617, 600], "vertical": true, "font_size": 12.0, "lines": ["．．．"]}], "img_path": "eve3_169.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [72, 57, 339, 375], "vertical": true, "font_size": 19.818181818181817, "lines": ["てしまいそうなとこころまで、潜ることが", "できました。そしてもちろん帰ってきま", "した。まずきっかけは、監督の「この子", "は、感慨がないわけではなくて、感情を", "知らないのです」のひと言。技術的な愛", "求としては、「棒読み」ということでした", "が、もちろん機械なわけではなく、あく", "までも血の通った人間としてです。この", "『感情がない』と「知らない」との差は、", "ものすごく大きなこことです。「知らない」", "は、知れば育つわけですから．．．。"]}, {"box": [347, 58, 484, 374], "vertical": true, "font_size": 21.6, "lines": ["感情を知らないレイとの", "出会いで知ったこと", "私は、ＥＶＡ、レイ、ユイと出会えた", "おかげで心の奥の奥への奥、見つめようと", "すればどんどん暗くなって見えなくなっ"]}, {"box": [517, 58, 547, 201], "vertical": true, "font_size": 30.0, "lines": ["綾波レイ役"]}, {"box": [70, 402, 91, 721], "vertical": true, "font_size": 19.0, "lines": ["なるとか、そんなこことはどうでもよくて、"]}, {"box": [95, 398, 494, 823], "vertical": true, "font_size": 21.88235294117647, "lines": ["「さ〜て、", "この子をど", "うするべえ」", "と悩んだ時", "まず私は、", "自分の心の", "中に旅（サ", "イコダイビ", "ング〕をす", "ることにし", "ました。感", "情って何だ", "ろう、どこ", "から、どん", "な時、どんなふうに湧いてくるんだろう", "．．．と。何でそこまでとか、それが何に", "ですけど。"]}, {"box": [71, 741, 89, 1050], "vertical": true, "font_size": 16.0, "lines": ["でも、おかげで今まで漠然と感じてい"]}, {"box": [123, 725, 138, 1052], "vertical": true, "font_size": 15.0, "lines": ["まあ、したかったからしたって感じなん"]}, {"box": [514, 761, 550, 1064], "vertical": true, "font_size": 30.0, "lines": ["ＮＥＢＵＭＴ－ＲＡＹＡＳＨＩＢＡＲ"]}], "img_path": "eve3_170.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [90, 63, 261, 381], "vertical": true, "font_size": 18.0, "lines": ["もっと簡単に言えば、本音と建前、ご", "の建前のほうが美しかったり、魅力的だ", "つたり、人に好かれちゃったりするもん", "だから、自分でそれを本音だと思い込ん", "じゃう。でも思い込んじゃっても、実は", "奥のほうでは本音がどろどろしちゃう。", "んで、な〜んかつらいわけです。"]}, {"box": [274, 62, 489, 381], "vertical": true, "font_size": 21.125, "lines": ["って、本心を認められたり、気付いたり", "した時に人は成長するってやつです。時々", "それは傷つく作業だったりして「あらや", "だ、気付くことは、傷つくことでもある", "このねえ、韻を踏んでるわ」なんて、ひと", "りで感動しちゃいました。", "自分でも気付かない", "本音と建前"]}, {"box": [392, 391, 661, 730], "vertical": true, "font_size": 22.181818181818183, "lines": ["ジ君に登場してもらいましょう。シンジ", "君のＥＶＡのパイロツトとして戦う理由", "です。建前は、みんなが乗れって言うか", "ら、僕しか乗れないから、人類を救うた", "めです。まあ立派、まあ偉い。そして彼", "自身もそうだと思い込んでいます。しかも", "し、奥のほうにちゃんといました。本音", "が、父さんに認めてほしい。誉めてはし", "い、建前に比べれば、なんと自分本位な", "感情でしょう。でもそれが人間なんです。", "大切なのは、その本音に気付き、認め、"]}, {"box": [494, 62, 687, 1060], "vertical": true, "font_size": 18.22222222222222, "lines": ["と、もっとわかりやすくするために、シン、するべきということではなく、ほっとい", "たことに確信が持てました。その確信と", "は、人は時々心の奥に、自分自身ですら", "気付いていない〈気付きたくない、認め", "たくない〉感情を持つていて、簡単に言", "えば本心ってやつですね。その本心のも", "っともっと奥に、その感情に気付かせな", "いようにしているさらにもうひとつの感", "情があるってこと。そして、それを取っ払"]}, {"box": [93, 409, 285, 723], "vertical": true, "font_size": 18.0, "lines": ["することもあります。ゆ〜っくり、焦ら", "ず、まず「感じれば」よいと思います。", "一見しんどそうに見えるこの作業も、", "度ても経験すると、その次の道の開け方", "に驚くはずです。今までイライラしてた", "ことがアララとはかりスムーズに過ぎて", "いくのです。", "しかし、これは決してこうしろとか"]}, {"box": [114, 754, 135, 848], "vertical": true, "font_size": 18.0, "lines": ["なわけです。"]}, {"box": [291, 409, 362, 725], "vertical": true, "font_size": 19.666666666666668, "lines": ["だったり、過去の経験、嫉妬等であった", "場合は、やっかいだったりすることもあ", "るのですが、もっと身近なことだったり"]}, {"box": [369, 411, 384, 721], "vertical": true, "font_size": 15.0, "lines": ["取り込み消化することこと。原因が幼児体験"]}, {"box": [138, 731, 661, 1063], "vertical": true, "font_size": 18.714285714285715, "lines": ["てくれという方には無理矢理勧めるつも", "りはありませんし、それに気付くための", "準備や、その人なりの時期もあるでしょ", "うから人それぞれなのですが、私はこの", "方法で「生きることが少し「楽」になります", "した〈楽と書いて楽〉しいって感じかな〜", "切迫したり、イライラしたり、うまくい", "かなかったりする時はって、けっこう目分", "の中に答えがあったりするんですね。", "最後にレイに話を戻しましょう。感情", "を知らない彼女は、本音も建前もあります", "せん。だから、一見美しく神秘なのです", "が、本当の彼女の魅力は、彼女み気付か", "ないところで生まれた本心涙だと私は", "思います。本音と建前の間で揺れるから", "こそ人は人間であり、「生きている」という", "うことだと思うのです。", "彼女の冷たい、言葉」に暖かい「思い」", "を見つけた時、私は彼女とシンクロした", "のです。それは、とても気持ちよいこと", "なのでした。まさに心から「ありがとう」"]}], "img_path": "eve3_171.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [309, 65, 540, 101], "vertical": false, "font_size": 15.0, "lines": ["ＹＯＳＨＹＵＫＩＳＡＤＡＮＯＴＯ", "ＰＲＯＦＬＥ"]}, {"box": [293, 147, 547, 447], "vertical": false, "font_size": 18.0, "lines": ["夏本発行（さたもとよししゆき）●ＩｇＥ２", "年１月２９日生まれ。血液型Ａ型。山", "口県徳山市出身。東京造形大学卒業", "後、アニメーターとなる。キャラク", "ター・テサイナー、作画監督として", "活躍。代表作品「オネアミスの翼王", "立宇宙軍Ｊ「トップをねらえノ「ふし", "ぎの海のナティアＪ新世紀エヴァン", "ゲリオン，奪。５６年２月号より月刊", "少年エースにて「新世紀エウァンゲ", "リオン，（漫画）を連載。現在ＧＡ－", "ＩＮＡＸ所属。"]}, {"box": [362, 535, 472, 554], "vertical": false, "font_size": 21.0, "lines": ["ＳＴＡＦＦＬＩＳＴ"]}, {"box": [296, 597, 404, 615], "vertical": false, "font_size": 13.0, "lines": ["Ｔｈｅａｕｔｈｏｒ"]}, {"box": [295, 647, 393, 663], "vertical": false, "font_size": 16.0, "lines": ["Ａｓｓｉｓｔａｎｔ"]}, {"box": [482, 604, 548, 761], "vertical": false, "font_size": 16.0, "lines": ["．．．", "美作英！", "八木宏幸"]}, {"box": [318, 792, 523, 815], "vertical": false, "font_size": 13.0, "lines": ["ｉｅｏｎｉｓｈｏｌＧＡＩＮＡＸ"]}, {"box": [339, 842, 506, 862], "vertical": false, "font_size": 17.0, "lines": ["ＴｈａｎｋｓｔｏＭＡＫＯ"]}], "img_path": "eve3_172.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [197, 397, 396, 417], "vertical": false, "font_size": 20.0, "lines": ["ＫｏｄｏｋｏｗｏＣｏｍｉｃｓＡ"]}, {"box": [160, 450, 436, 550], "vertical": false, "font_size": 19.0, "lines": ["角川コミックス・エース", "新世紀エヴァンゲリオン３", "漫画", "貞本義行ＧＡＮ", "原作"]}, {"box": [223, 569, 390, 603], "vertical": false, "font_size": 15.0, "lines": ["１９９６年１１月７日初版発行", "１９９７年１１月３０日第１３期発行"]}, {"box": [261, 622, 332, 659], "vertical": false, "font_size": 16.0, "lines": ["発行者", "角川歴彦"]}, {"box": [117, 678, 471, 773], "vertical": false, "font_size": 15.0, "lines": ["発行所", "角川書店", "毎１０２東京都千代田区富士見２－１８－３", "振替日座／ＣＯＨ３０－９－１９５２０と", "電話ノ東京（ＣＢ）２０１８－８５７０（営業）・（ＣＰ）５０００年、９５５年（月）"]}, {"box": [185, 781, 369, 869], "vertical": false, "font_size": 16.75, "lines": ["装備・デザイン", "鹿住忠広＋班♯ＨＴＯ", "印刷", "共同印刷"]}, {"box": [126, 881, 464, 897], "vertical": false, "font_size": 15.0, "lines": ["初出「月刊・少年エース。３６年３月号付月号〜１０月号まで"]}, {"box": [325, 830, 408, 870], "vertical": false, "font_size": 18.5, "lines": ["製本", "大谷製本"]}, {"box": [145, 906, 481, 978], "vertical": false, "font_size": 14.5, "lines": ["本書の無断複写・複製転載を禁じます。落丁・乱丁本は、", "ご面倒でも小社角川ブック・サ・ビス宛にお送りください。", "送料は小社負担でお取り替えいたします。", "１９９６．ＫＡＤＯＫＡＷＡ、ＳｉｃｒｏＴＥＮ，Ｐｒｉｎｔｉｎ．ｊａｃｒ．"]}, {"box": [245, 988, 348, 1005], "vertical": false, "font_size": 16.0, "lines": ["ＣＧＡＩＭＸ１９９６"]}, {"box": [210, 1016, 383, 1032], "vertical": false, "font_size": 15.0, "lines": ["ＳＥＢＮ４．０４－７３６５２００９"]}], "img_path": "eve3_173.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [0, 13, 328, 343], "vertical": false, "font_size": 32.0, "lines": ["多二公権保険サイコ", "田島昭手", "マクロスクトラッシュ、", "美樹太郎さんの言葉は", "．．．", "何言かうます", "そういうエアンスパウィ大丈夫だった"]}, {"box": [53, 330, 312, 500], "vertical": false, "font_size": 20.714285714285715, "lines": ["詩きつね", "朝武士クロスポーツオンラ", "福野田悠季渋長谷川裕", "ソフリンカラー", "ＳＵＥＺＥＮ", "あざめよ！はにわ先生", "佐藤よしひろ"]}, {"box": [438, 463, 749, 540], "vertical": false, "font_size": 32.0, "lines": ["車田正美", "新世紀エヴァンゲリオン"]}, {"box": [85, 783, 160, 825], "vertical": false, "font_size": 32.0, "lines": ["月刊"]}, {"box": [413, 732, 504, 747], "vertical": false, "font_size": 15.0, "lines": ["７月１０日（土）「北条"]}, {"box": [438, 671, 592, 709], "vertical": false, "font_size": 31.0, "lines": ["あかほりさと"]}, {"box": [391, 748, 515, 786], "vertical": false, "font_size": 12.0, "lines": ["ＣＯＭＡＮＴＡＬＡＮＳ", "．．．", "ＴＶＡ機材限Ｓ－ＳＰＯＲＴ"]}, {"box": [457, 569, 621, 599], "vertical": false, "font_size": 30.0, "lines": ["途撃宇宙敗詹"]}, {"box": [441, 544, 776, 707], "vertical": false, "font_size": 32.0, "lines": ["自本乗りナデシコ最大戦宮殿亜さんの技", "【ＳＰＯ戦士ラムネ４４０枚あかほりここで、吉崎駅音", "る千吉臨観音"]}, {"box": [193, 999, 549, 1097], "vertical": false, "font_size": 32.0, "lines": ["２６日発表", "ミピ"]}], "img_path": "eve3_174.jpg"}]}