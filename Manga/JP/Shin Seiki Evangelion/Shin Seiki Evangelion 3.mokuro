26, 1000], "vertical": true, "font_size": 22.0, "lines": ["それって．．．"]}, {"box": [157, 829, 214, 917], "vertical": true, "font_size": 24.0, "lines": ["エヴァと", "同じ．．．？"]}], "img_path": "eve3_020.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [80, 243, 108, 320], "vertical": true, "font_size": 18.0, "lines": ["父さん．．．"]}, {"box": [160, 411, 193, 493], "vertical": false, "font_size": 21.0, "lines": ["これが", "ククニチャ"]}, {"box": [563, 474, 669, 666], "vertical": true, "font_size": 22.0, "lines": ["ええ", "劣化が激しく", "サンプルとしては完全", "とは言えませんが．．．"]}, {"box": [345, 771, 364, 846], "vertical": true, "font_size": 19.0, "lines": ["くそ．．．．．"]}, {"box": [64, 826, 145, 990], "vertical": true, "font_size": 18.0, "lines": ["なんで父さんから", "コソコソ隠れなきゃ", "なんないんだろ"]}], "img_path": "eve3_021.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [632, 98, 712, 270], "vertical": true, "font_size": 20.0, "lines": ["僕が戻って来ても", "それが当然のように", "何も言ってはこない"]}, {"box": [608, 152, 624, 249], "vertical": true, "font_size": 20.0, "lines": ["小言ですら"]}, {"box": [252, 260, 275, 321], "vertical": true, "font_size": 20.0, "lines": ["なぜ？"]}, {"box": [145, 342, 219, 475], "vertical": true, "font_size": 20.0, "lines": ["僕とは話す", "価値もないって", "こと？"]}, {"box": [102, 826, 129, 898], "vertical": true, "font_size": 15.0, "lines": ["火傷．．．？"]}], "img_path": "eve3_022.jpg"}, {"version": "0.1.6", "img_width": 800, "img_height": 1125, "blocks": [{"box": [640, 93, 705, 236], "vertical": true, "font_size": 28.0, "lines": ["何見てんの？", "シンちゃん"]}, {"box": [230, 93, 336, 231], "vertical": true, "font_size": 25.0, "lines": ["お", "驚かさないで", "くださいよー", "もうっ"]}, {"box": [70, 91, 147, 225], "vertical": true, "font_size": 22.0, "lines": ["なによ", "勝手に驚い", "たんでしょーが"]}, {"box": [364, 432, 444, 525], "vertical": true, "font_size": 32.0, "lines": ["わっ"]}, {"box": [139, 469, 160, 508], "vertical": true, "font_size": 21.0, "lines": ["ん"]}, {"box": [110, 433, 160, 510], "vertical": true, "font_s