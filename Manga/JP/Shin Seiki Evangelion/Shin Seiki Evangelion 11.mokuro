"vertical": true, "font_size": 21.0, "lines": ["とんでもないことがね"]}], "img_path": "ÉVÉóïIâGâöâ@âôâQâèâIâô#11_011.jpg"}, {"version": "0.1.6", "img_width": 983, "img_height": 1400, "blocks": [], "img_path": "ÉVÉóïIâGâöâ@âôâQâèâIâô#11_012.jpg"}, {"version": "0.1.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [836, 103, 883, 164], "vertical": true, "font_size": 32.0, "lines": ["何？"]}, {"box": [252, 94, 322, 175], "vertical": true, "font_size": 32.0, "lines": ["べつに", "何も"]}, {"box": [452, 561, 520, 735], "vertical": true, "font_size": 23.0, "lines": ["あなた私と同じ", "感じがする"]}, {"box": [146, 392, 172, 462], "vertical": true, "font_size": 24.0, "lines": ["ごめん"]}, {"box": [91, 816, 132, 891], "vertical": true, "font_size": 32.0, "lines": ["何故？"]}], "img_path": "ÉVÉóïIâGâöâ@âôâQâèâIâô#11_013.jpg"}, {"version": "0.1.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [843, 47, 877, 124], "vertical": true, "font_size": 27.0, "lines": ["確かに"]}, {"box": [773, 105, 833, 313], "vertical": true, "font_size": 27.0, "lines": ["僕らを構成している", "物質は同じ"]}, {"box": [276, 87, 311, 225], "vertical": true, "font_size": 24.0, "lines": ["でも違うのは"]}, {"box": [120, 226, 190, 365], "vertical": true, "font_size": 27.0, "lines": ["これまで誰と", "出合い"]}, {"box": [391, 330, 491, 605], "vertical": true, "font_size": 25.0, "lines": ["姿形もお互い", "この星で生きていくために", "人の子へと行きついた"]}, {"box": [228, 441, 290, 602], "vertical": true, "font_size": 22.0, "lines": ["どう生きて", "来たかってこと"]}, {"box": [819, 724, 883, 838], "vertical": true, "font_size": 22.0, "lines": ["君と僕は", "似てるけど"]}, {"box": [466, 693, 566, 830], "vertical": true, "font_size": 24.0, "lines": ["以前君が", "僕にそう", "言ったんだよ"]}, {"box": [605, 1186, 675, 1279], "vertical": true, "font_size": 29.0, "lines": ["同じじゃ", "ない"]}, {"box": [136, 1182, 203, 1277], "vertical": true, "font_size": 30.0, "lines": ["覚えて", "ないの？"]}], "img_path": "ÉVÉóïIâGâöâ@âôâQâèâIâô#11_014.jpg"}, {"version": "0.1.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [809, 691, 882, 808], "vertical": true, "font_size": 30.0, "lines": ["留守番電話", "一ケン"]}, {"box": [838, 1025, 877, 1060], "vertical": false, "font_size": 32.0, "lines": ["碇"]}, {"box": [528, 813, 581, 932], "vertical": true, "font_size": 25.0, "lines": ["再生シマス"]}, {"box": [371, 674, 437, 838], "vertical": true, "font_size": 26.0, "lines": ["悪いけど君には", "会わないで行く"]}, {"box": [574, 1159, 607, 1233], "vertical": true, "font_size": 27.0, "lines": ["僕だよ"]}, {"box": [526, 1205, 549, 1298], "vertical": true, "font_size": 27.0, "lines": ["ケンスケ"]}, {"box": [159, 1066, 192, 1183], "vertical": true, "font_size": 26.0, "lines": ["っていうか"]}, {"box": [80, 1116, 140, 1327], "vertical": true, "font_size": 26.0, "lines": ["もう一生会うこと", "ないかもしれないな"]}], "img_path": "ÉVÉóïIâGâöâ@âôâQâèâIâô#11_015.jpg"}, {"version": "0.1.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [832, 76, 891, 211], "vertical": true, "font_size": 25.0, "lines": ["だって", "そうだろう？"]}, {"box": [783, 153, 808, 225], "vertical": true, "font_size": 25.0, "lines": ["僕たち"]}, {"box": [132, 228, 198, 363], "vertical": true, "font_size": 22.0, "lines": ["もう絶対に", "無理だもんな"]}, {"box": [857, 546, 894, 602], "vertical": true, "font_size": 30.0, "lines": ["じゃ"]}, {"box": [821, 578, 844, 694], "vertical": true, "font_size": 30.0, "lines": ["がんばれよ"]}, {"box": [592, 362, 657, 477], "vertical": true, "font_size": 22.0, "lines": ["笑って会う", "なんてこと"]}, {"box": [519, 650, 543, 742], "vertical": true, "font_size": 23.0, "lines": ["さいなら"]}, {"box": [358, 575, 417, 690], "vertical": true, "font_size": 24.0, "lines": ["ケンスケも", "委員長も"]}, {"box": [754, 828, 860, 994], "vertical": true, "font_size": 30.0, "lines": ["２３日午後", "２時１８分の伝言", "デス"]}, {"box": [108, 698, 164, 790], "vertical": true, "font_size": 24.0, "lines": ["クラスの", "みんなも"]}, {"box": [71, 1148, 170, 1313], "vertical": true, "font_size": 30.0, "lines": ["家を失って", "他の所へ", "行ってしまった"]}], "img_path": "ÉVÉóïIâGâöâ@âôâQâèâIâô#11_016.jpg"}, {"version": "0.1.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [788, 61, 851, 221], "vertical": true, "font_size": 22.0, "lines": ["誰もいなく", "なってしまった"]}, {"box": [359, 133, 393, 209], "vertical": true, "font_size": 29.0, "lines": ["僕は？"]}, {"box": [693, 388, 797, 505], "vertical": true, "font_size": 32.0, "lines": ["友達と", "呼べる人は", "誰も．．．"]}, {"box": [633, 1043, 772, 1208], "vertical": true, "font_size": 28.0, "lines": ["僕のことは", "“友達”って", "呼んでくれない", "んだ"]}], "img_path": "ÉVÉóïIâGâöâ@âôâQâèâIâô#11_017.jpg"}, {"version": "0.1.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [832, 75, 898, 150], "vertical": true, "font_size": 27.0, "lines": ["君には", "もう"]}, {"box": [431, 113, 487, 226], "vertical": true, "font_size": 21.0, "lines": ["セカンドは", "あのとおり"]}, {"box": [228, 87, 252, 224], "vertical": true, "font_size": 23.0, "lines": ["ファーストは"]}, {"box": [690, 475, 789, 591], "vertical": true, "font_size": 28.0, "lines": ["僕しか", "残ってない", "のに．．"]}, {"box": [328, 466, 424, 650], "vertical": true, "font_size": 23.0, "lines": ["ずっとベッドで", "人形みたいに", "寝ているだけだし"]}, {"box": [77, 496, 210, 612], "vertical": true, "font_size": 27.0, "lines": ["もう君の", "知ってる", "ファースト", "じゃない"]}, {"box": [823, 695, 889, 832], "vertical": true, "font_size": 23.0, "lines": ["君の知ってる", "ファーストは"]}, {"box": [494, 895, 598, 1009], "vertical": true, "font_size": 26.0, "lines": ["君を助け", "ようとして", "死んだ"]}, {"box": [590, 1209, 652, 1327], "vertical": true, "font_size": 28.0, "lines": ["かわいそう", "にね"]}], "img_path": "ÉVÉóïIâGâöâ@âôâQâèâIâô#11_018.jpg"}, {"version": "0.1.6", "img_width": 983, "img_height": 1400, "blocks": [{"box": [475, 65, 504, 200], "vertical": true, "font_size": 28.0, "lines": ["無視すんな"]}, {"box": [419, 150, 447, 318], "vertical": true, "font_size": 28.0, "lines": ["何か言えよ！"]}, {"box": [595, 561, 665, 638], "vertical": true, "font_size": 32.0, "lines": ["何か", "言えよ"]}, {"box": [555, 720, 590, 792], "vertical": true, "font_size": 28.0, "lines": ["君とは"]}, {"box": [378, 1138, 444, 1233], "vertical": true, "font_size": 29.0, "lines": ["友達に", "ならない"]}], 