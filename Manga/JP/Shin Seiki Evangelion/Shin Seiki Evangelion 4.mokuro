 623, 950], "vertical": true, "font_size": 21.0, "lines": ["あたしは", "試験管の中で", "産まれたのよ"]}], "img_path": "129.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [665, 64, 681, 138], "vertical": true, "font_size": 16.0, "lines": ["．．．．．．"]}, {"box": [416, 71, 489, 144], "vertical": true, "font_size": 21.0, "lines": ["なによ", "呆けた顔", "して"]}, {"box": [318, 77, 391, 182], "vertical": true, "font_size": 18.0, "lines": ["あ．．．だって", "そーゆー話", "よく聞くけど"]}, {"box": [248, 98, 291, 203], "vertical": true, "font_size": 18.0, "lines": ["現物見るの", "初めてだから"]}, {"box": [83, 66, 132, 139], "vertical": true, "font_size": 24.0, "lines": ["でね", "聞いて！"]}, {"box": [82, 335, 155, 411], "vertical": true, "font_size": 23.0, "lines": ["ただの", "精子じゃ", "ないのよ"]}, {"box": [530, 485, 680, 664], "vertical": true, "font_size": 19.0, "lines": ["あたしの父親の精子を", "売ってたバンクは", "学歴・人格共に", "厳しい資格審査に", "パスした人の精子しか", "置いてないの"]}, {"box": [422, 554, 519, 680], "vertical": true, "font_size": 19.0, "lines": ["もちろんそれを", "買う女性の方も", "相当な資格が", "いるのよ"]}, {"box": [82, 481, 177, 641], "vertical": true, "font_size": 18.0, "lines": ["どーでもいいけど", "１４歳の女の子が", "精子精子って言うの", "抵抗あるなあ"]}, {"box": [560, 775, 693, 920], "vertical": true, "font_size": 19.0, "lines": ["その中でも最高と", "言われてる", "ある天才科学者の", "精子があたしの", "父親なんですって"]}, {"box": [93, 795, 209, 1004], "vertical": true, "font_size": 23.0, "lines": ["つまりあたしは", "一流の精子と", "一流の卵子が出会って", "生まれたのよ"]}], "img_path": "130.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [621, 54, 674, 137], "vertical": true, "font_size": 22.0, "lines": ["つまり", "あたしは"]}, {"box": [435, 53, 496, 145], "vertical": true, "font_size": 32.0, "lines": ["選ばれた", "人間"]}, {"box": [399, 117, 427, 312], "vertical": true, "font_size": 32.0, "lines": ["特別ってことなのよ"]}, {"box": [280, 75, 357, 165], "vertical": true, "font_size": 19.0, "lines": ["結局それが", "言いたかっ", "たんだな"]}, {"box": [253, 281, 355, 422], "vertical": true, "font_size": 21.0, "lines": ["でも一流の", "精子と卵子で", "なぜこんな", "性格破綻者が．．．"]}, {"box": [60, 286, 148, 390], "vertical": true, "font_size": 25.0, "lines": ["なによ", "その疑惑の", "目は"]}, {"box": [652, 587, 671, 642], "vertical": true, "font_size": 19.0, "lines": ["でもさ"]}, {"box": [560, 593, 581, 701], "vertical": true, "font_size": 19.0, "lines": ["寂しくない？"]}, {"box": [493, 636, 537, 849], "vertical": true, "font_size": 19.0, "lines": ["お父さんが生まれた時から", "いないなんて"]}, {"box": [290, 588, 324, 634], "vertical": true, "font_size": 32.0, "lines": ["別に"]}, {"box": [68, 856, 173, 979], "vertical": true, "font_size": 20.0, "lines": ["だって", "関係ないもん", "父親がいようが", "いまいか"]}], "img_path": "131.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [553, 23, 673, 212], "vertical": true, "font_size": 25.0, "lines": ["あたしは大勢の", "中から選ばれて", "エヴァのパイロット", "になって"]}, {"box": [459, 122, 547, 250], "vertical": true, "font_size": 25.0, "lines": ["そして", "戦って", "使徒を倒して"]}, {"box": [190, 326, 244, 496], "vertical": true, "font_size": 22.0, "lines": ["それでみんなに", "認めてもらえたら"]}, {"box": [112, 449, 167, 556], "vertical": true, "font_size": 22.0, "lines": ["最高に", "幸せなのよ"]}], "img_path": "132.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [595, 487, 617, 562], "vertical": true, "font_size": 22.0, "lines": ["．．．ママ．．．"]}, {"box": [351, 511, 381, 596], "vertical": true, "font_size": 21.0, "lines": ["寝言．．．？"]}], "img_path": "133.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [597, 69, 686, 166], "vertical": true, "font_size": 18.0, "lines": ["なんだヨ", "人のこと", "バカにしてた", "くせに"]}, {"box": [533, 71, 573, 181], "vertical": true, "font_size": 18.0, "lines": ["自分はマザコン", "じゃないか"]}, {"box": [509, 219, 536, 275], "vertical": true, "font_size": 27.0, "lines": ["ママ．．．"]}, {"box": [312, 322, 378, 419], "vertical": true, "font_size": 19.0, "lines": ["．．．どうして", "死んじゃった", "の．．．．．？"]}, {"box": [588, 630, 685, 770], "vertical": true, "font_size": 18.0, "lines": ["アスカは", "本当はごく普通の", "女の子なんじゃ", "ないだろうか"]}, {"box": [114, 494, 193, 637], "vertical": true, "font_size": 19.0, "lines": ["性格の激しさや", "自信過剰なとこに", "惑わされてたけど"]}, {"box": [104, 887, 180, 976], "vertical": true, "font_size": 18.0, "lines": ["その時僕は", "ふとそんな", "気がした"]}], "img_path": "134.jpg"}, {"version": "0.1.6", "img_width": 748, "img_height": 1055, "blocks": [{"box": [254, 970, 386, 992], "vertical": false, "font_size": 22.0, "lines": ["ＳＴＡＧＥ．２５、"]}, {"box": [394, 967, 678, 998], "vertical": false, "font_size": 31.0, "lines": ["Ｓｈａｌｌｉｖｅ．ｄａｎｅｅｘ"]}], "img_path": "135.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [285, 133, 480, 220], "vertical": false, "font_size": 32.0, "lines": ["１１"]}], "img_path": "136.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [595, 723, 720, 849], "vertical": true, "font_size": 29.0, "lines": ["だめだめ", "ストップ"]}], "img_path": "137.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [517, 39, 693, 168], "vertical": true, "font_size": 27.0, "lines": ["シンジ君", "音楽よく", "聞いて！", "まだ照れが", "残ってるわよ"]}, {"box": [375, 69, 423, 159], "vertical": true, "font_size": 22.0, "lines": ["ははい", "すみません"]}, {"box": [83, 71, 106, 143], "vertical": true, "font_size": 23.0, "lines": ["アスカ"]}, {"box": [299, 339, 325, 407], "vertical": true, "font_size": 26.0, "lines": ["はい．．"]}, {"box": [543, 605, 668, 716], "vertical": true, "font_size": 19.0, "lines": ["何度言ったら", "わかるの！？", "自分だけ", "とばすんじゃ", "ないって"]}, {"box": [454, 604, 497, 744], "vertical": true, "font_size": 19.0, "lines": ["もっとシンジ君と", "合わせなさいよ"]}, {"box": [334, 603, 387, 751], "vertical": true, "font_size": 20.0, "lines": ["そんなこと", "できませ～～ん"]}, {"box": [184, 607, 285, 733], "vertical": true, "font_size": 20.0, "lines": ["碇君に合わせて", "自分のレベル", "下げるなんて", "．．．"]}, {"box": [81, 679, 150, 801], "vertical": true, "font_size": 20.0, "lines": ["合わせるのは", "碇君の方じゃ", "ないんですか？"]}], "img_path": "138.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [261, 67, 384, 227], "vertical": true, "font_size": 21.0, "lines": ["どうして", "昨日から", "ずっとファースト．．", "綾波さんが", "見てるんですか？"]}, {"box": [96, 72, 200, 165], "vertical": true, "font_size": 21.0, "lines": ["なんだか", "気が散って", "集中できま", "せん"]}, {"box": [431, 330, 452, 415], "vertical": true, "font_size": 19.0, "lines": ["それに．．．"]}, {"box": [396, 540, 425, 586], "vertical": true, "font_size": 29.0, "lines": ["レイ"]}, {"box": [79, 651, 104, 691], "vertical": true, "font_size": 25.0, "lines": ["はい"]}, {"box": [569, 764, 667, 854], "vertical": true, "font_size": 20.0, "lines": ["アスカの", "代わりに", "ちょっと", "やってみて"]}, {"box": [68, 774, 97, 822], "vertical": true, "font_size": 29.0, "lines": ["はい"]}], "img_path": "139.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [86, 75, 122, 115], "vertical": true, "font_size": 32.0, "lines": ["！！"]}, {"box": [325, 367, 396, 474], "vertical": true, "font_size": 20.0, "lines": ["いきなり", "綾波と", "踊れたなんて"]}, {"box": [258, 370, 301, 477], "vertical": true, "font_size": 20.0, "lines": ["何考えてんだ", "ミサトさん"]}], "img_path": "140.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [], "img_path": "141.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [630, 82, 676, 223], "vertical": true, "font_size": 18.0, "lines": ["零号機が修理中で", "なかったら"]}, {"box": [535, 122, 606, 263], "vertical": true, "font_size": 18.0, "lines": ["迷わずレイと", "シンジ君を", "組ませるところね"]}, {"box": [626, 343, 694, 415], "vertical": true, "font_size": 21.0, "lines": ["だったら", "あたしの", "弐号機に"]}, {"box": [467, 356, 545, 516], "vertical": true, "font_size": 22.0, "lines": ["綾波さんが", "乗って出撃すれば", "いいじゃないですか"]}, {"box": [267, 334, 286, 417], "vertical": true, "font_size": 18.0, "lines": ["アスカ？"]}, {"box": [624, 625, 688, 714], "vertical": true, "font_size": 30.0, "lines": ["失礼", "します！"]}, {"box": [268, 637, 303, 710], "vertical": true, "font_size": 23.0, "lines": ["惣流！？"]}, {"box": [336, 869, 392, 978], "vertical": true, "font_size": 32.0, "lines": ["アスカ！"]}], "img_path": "142.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [567, 55, 665, 178], "vertical": true, "font_size": 19.0, "lines": ["あちゃ～～～", "参ったわね", "もう時間が", "ないってのにィ"]}, {"box": [462, 55, 544, 224], "vertical": false, "font_size": 19.0, "lines": ["＞私たちの人との", "マリキッシットなど", "お兄ちゃん．．．私だけ"]}, {"box": [362, 60, 391, 146], "vertical": true, "font_size": 25.0, "lines": ["シンジ君"]}, {"box": [296, 54, 321, 177], "vertical": true, "font_size": 17.0, "lines": ["何してるんだ？"]}, {"box": [67, 63, 119, 169], "vertical": true, "font_size": 20.0, "lines": ["早くアスカを", "追いかけろ"]}, {"box": [625, 461, 675, 548], "vertical": true, "font_size": 19.0, "lines": ["これも君の", "仕事だよ"]}, {"box": [299, 266, 322, 307], "vertical": true, "font_size": 23.0, "lines": ["え．．"]}, {"box": [70, 271, 89, 341], "vertical": true, "font_size": 18.0, "lines": ["で．．．でも"]}], "img_path": "143.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [482, 38, 515, 106], "vertical": true, "font_size": 27.0, "lines": ["惣流．．．"]}, {"box": [83, 65, 190, 150], "vertical": true, "font_size": 25.0, "lines": ["なによ", "なんで", "ついて", "くんのよ"]}, {"box": [667, 411, 687, 494], "vertical": true, "font_size": 18.0, "lines": ["ごめん．．．"]}, {"box": [453, 425, 530, 550], "vertical": true, "font_size": 20.0, "lines": ["参ったな．．．", "何言っていいか", "わかんないや"]}, {"box": [325, 421, 395, 526], "vertical": true, "font_size": 16.0, "lines": ["．．．．．．なんで", "あたしの方が", "怒られるの？"]}, {"box": [86, 406, 251, 565], "vertical": true, "font_size": 20.0, "lines": ["あたしは", "完璧に", "やってるわ", "あんたが", "グズでトロイから", "上手くいかないのに"]}, {"box": [544, 797, 613, 910], "vertical": true, "font_size": 28.0, "lines": ["なのに", "なんで！？"]}], "img_path": "144.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [610, 38, 628, 109], "vertical": true, "font_size": 17.0, "lines": ["ごめん．．．"]}, {"box": [209, 34, 238, 90], "vertical": true, "font_size"