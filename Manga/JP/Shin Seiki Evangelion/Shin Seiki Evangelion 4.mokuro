{"version": "0.2.0-beta.6", "title": "Shin Seiki Evangelion", "title_uuid": "cc3209cd-c119-4870-b06c-9a34f447db7e", "volume": "Shin Seiki Evangelion 4", "volume_uuid": "d672da20-40a3-4d82-b304-2d1181b0b8f1", "pages": [{"version": "0.1.6", "img_width": 722, "img_height": 1058, "blocks": [{"box": [21, 313, 207, 387], "vertical": false, "font_size": 31.0, "lines": ["Ｖｏｌｕｍｅ", "アスカ、来！"]}, {"box": [26, 421, 88, 442], "vertical": false, "font_size": 20.0, "lines": ["漫画！"]}, {"box": [90, 396, 249, 457], "vertical": false, "font_size": 32.0, "lines": ["貞本義"]}, {"box": [27, 453, 279, 505], "vertical": false, "font_size": 22.0, "lines": ["ＹＯＳＨＹＬＫＩＳＡＤＡＭＯＴＯ", "原作／ＧＡＩＮＡＸ"]}], "img_path": "003.jpg"}, {"version": "0.1.6", "img_width": 738, "img_height": 1057, "blocks": [], "img_path": "004.jpg"}, {"version": "0.1.6", "img_width": 739, "img_height": 1060, "blocks": [], "img_path": "005.jpg"}, {"version": "0.1.6", "img_width": 737, "img_height": 1053, "blocks": [{"box": [260, 146, 531, 200], "vertical": false, "font_size": 32.0, "lines": ["ＰＲＯＧＲＡＭ"]}, {"box": [312, 220, 462, 241], "vertical": false, "font_size": 15.0, "lines": ["ＥｖＡＮＧＥＬＩＯＮ４"]}, {"box": [170, 252, 455, 307], "vertical": false, "font_size": 26.5, "lines": ["らいにち", "ＳＩＭＥ２０アスカ、米日"]}, {"box": [167, 331, 465, 384], "vertical": false, "font_size": 27.5, "lines": ["まね", "ＳＴＭＥ２、招かれざる者"]}, {"box": [165, 406, 447, 464], "vertical": false, "font_size": 32.0, "lines": ["アタック", "ＳＩＭＥ２２アスカ攻撃"]}, {"box": [435, 332, 463, 348], "vertical": false, "font_size": 16.0, "lines": ["もの"]}, {"box": [162, 498, 473, 534], "vertical": false, "font_size": 31.0, "lines": ["ＳＩＭＥ２３トライ・アゲイン"]}, {"box": [578, 260, 657, 757], "vertical": true, "font_size": 32.0, "lines": ["９３７６８７１１は５５９"]}, {"box": [170, 551, 423, 605], "vertical": false, "font_size": 26.5, "lines": ["ディソナンス", "ＳＴＭＥ２！不協和音"]}, {"box": [170, 645, 539, 676], "vertical": false, "font_size": 28.0, "lines": ["ＳＴＡＲＥ２５－Ｓｈａｌｌｗｅ．ｄａｎｃｅ？"]}, {"box": [171, 700, 522, 752], "vertical": false, "font_size": 27.5, "lines": ["あんかんころかきじゃない", "ＳＴＬＥの瞬間、心、重ねて"]}, {"box": [256, 895, 376, 911], "vertical": false, "font_size": 12.0, "lines": ["Ｗｉｎｄｏｗｓ"]}, {"box": [393, 826, 619, 840], "vertical": false, "font_size": 14.0, "lines": ["ＧＯＡＦＹＵＡＳＪＫＡＬＡＮＧＬ"]}], "img_path": "006.jpg"}, {"version": "0.1.6", "img_width": 747, "img_height": 1058, "blocks": [{"box": [0, 66, 22, 182], "vertical": true, "font_size": 17.0, "lines": ["登場人物紹介"]}, {"box": [54, 182, 306, 223], "vertical": false, "font_size": 16.5, "lines": ["突然、父・ゲンドウによりネルフに呼", "ばれエヴァのバイロットとなる。（１４歳）"]}, {"box": [175, 138, 307, 175], "vertical": false, "font_size": 14.0, "lines": ["以上もの間、伯父の", "家に預けられて育つ。"]}, {"box": [202, 114, 304, 128], "vertical": false, "font_size": 14.0, "lines": ["扇の主人公、１０年"]}, {"box": [53, 257, 308, 414], "vertical": false, "font_size": 21.0, "lines": ["葛城ミサト", "ネルフ本部戦術作戦", "部作戦局第一課所属", "シンジの直属の上司", "にあたる。おおらかな性格でシンジの", "数枚少ない理由子者、花の独身．．．．．．"]}, {"box": [169, 452, 294, 484], "vertical": false, "font_size": 32.0, "lines": ["碇ゲンドウ"]}, {"box": [172, 494, 306, 561], "vertical": false, "font_size": 18.333333333333332, "lines": ["シンジの実父。特務", "機関ネルフの最高司", "令長官。任務至上主"]}, {"box": [345, 31, 710, 547], "vertical": true, "font_size": 22.0, "lines": ["●前巻までのあらすじ", "ネルフへ戻ったシンジは、父・ケンドウの掌にある人傷の痕", "が、エヴァ起動実験中の事故でエントリープラグに閉じこめ", "られたレイを助けるために食ったものであることを知り、複", "雑な思いを抱く。他人に心を開けかないレイと、任務以外に関", "心がないような父の間にある見えない絆を考えるうち、自然、", "シンジはレイ自身に関心が向き始める。そこへ、新たなる使", "徒がネルフ本部への直接攻撃をしかけてきた。国内総電力徴", "発による〝ヤシマ作戦〟によりエヴァは勝利するが、初号機", "の盾となったため、レイは零号機の中で意識を失ってしまう。", "知らず、父のように夢中でレイを助け出したシンジに対し、", "感情を現さないレイナも変化を見せ始めた．．．"]}, {"box": [54, 568, 304, 605], "vertical": false, "font_size": 14.5, "lines": ["義で実の息子にも冷徹だが、レイには", "不思議な思いやりを見せる。（４８歳）"]}, {"box": [170, 633, 308, 751], "vertical": false, "font_size": 19.8, "lines": ["あやなみ", "綾波レイ", "零号機のバイロット。", "マルドゥック機関の", "報告書によって選ば"]}, {"box": [55, 758, 305, 795], "vertical": false, "font_size": 14.0, "lines": ["れたファースト・チルドレンという以", "外の経歴は不明の謎の＞美少女、【１４歳"]}, {"box": [576, 645, 629, 747], "vertical": true, "font_size": 23.0, "lines": ["この世で", "碇司令だけ"]}, {"box": [643, 568, 665, 729], "vertical": true, "font_size": 23.0, "lines": ["私が信じてるのは"]}, {"box": [163, 818, 301, 886], "vertical": false, "font_size": 32.0, "lines": ["惣流・アスカ・ラング", "ラングレー"]}, {"box": [52, 947, 305, 987], "vertical": false, "font_size": 16.0, "lines": ["脳内別術、学業縦センス抜群の完全無敵の", "バーフェクト美少女〈性格以外〉《１４歳》"]}, {"box": [171, 900, 305, 942], "vertical": false, "font_size": 18.0, "lines": ["ドイツから来た弐号", "機のバイロット。頭"]}], "img_path": "007.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1060, "blocks": [], "img_path": "008.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1060, "blocks": [{"box": [51, 77, 164, 107], "vertical": false, "font_size": 32.0, "lines": ["ＳＴＡＧＥ＿２０"]}, {"box": [50, 74, 322, 107], "vertical": false, "font_size": 32.0, "lines": ["ＳＴＡＲＥ－２０アスカ、来日"]}], "img_path": "009.jpg"}, {"version": "0.1.6", "img_width": 745, "img_height": 1057, "blocks": [{"box": [483, 107, 710, 140], "vertical": false, "font_size": 16.0, "lines": ["んよこす", "新横須賀沖ＰＭ３００"]}, {"box": [110, 475, 294, 509], "vertical": false, "font_size": 16.0, "lines": ["こくれんかいくんだいへいようかんたい", "ご注意して．．．"]}], "img_path": "010.jpg"}, {"version": "0.1.6", "img_width": 745, "img_height": 1058, "blocks": [{"box": [636, 34, 691, 141], "vertical": true, "font_size": 24.0, "lines": ["テンペスト", "沈黙！！"]}, {"box": [553, 99, 614, 224], "vertical": true, "font_size": 18.0, "lines": ["状況報告は", "どうしたぁ！！"]}, {"box": [174, 39, 193, 134], "vertical": true, "font_size": 27.0, "lines": ["くそう！"]}, {"box": [48, 106, 144, 215], "vertical": true, "font_size": 27.0, "lines": ["何が", "起こってる", "んだ！？"]}, {"box": [570, 629, 661, 775], "vertical": true, "font_size": 23.0, "lines": ["魚雷を", "４発もくらって", "なぜ沈まん！？"]}, {"box": [101, 817, 212, 966], "vertical": true, "font_size": 30.0, "lines": ["目標", "後方輸送船に", "接近！"]}], "img_path": "011.jpg"}, {"version": "0.1.6", "img_width": 749, "img_height": 1058, "blocks": [], "img_path": "012.jpg"}, {"version": "0.1.6", "img_width": 742, "img_height": 1058, "blocks": [], "img_path": "013.jpg"}, {"version": "0.1.6", "img_width": 740, "img_height": 1058, "blocks": [], "img_path": "014.jpg"}, {"version": "0.1.6", "img_width": 742, "img_height": 1058, "blocks": [], "img_path": "015.jpg"}, {"version": "0.1.6", "img_width": 742, "img_height": 1058, "blocks": [{"box": [61, 669, 168, 817], "vertical": true, "font_size": 26.0, "lines": ["この後", "戦艦２隻による", "零距離射撃"]}], "img_path": "016.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1060, "blocks": [{"box": [496, 39, 653, 251], "vertical": true, "font_size": 25.0, "lines": ["太平洋艦隊の力を", "借りたとはいえ", "出撃より３６秒", "内部電源の切れる前に", "使徒殲滅"]}, {"box": [33, 111, 129, 303], "vertical": true, "font_size": 23.0, "lines": ["危機回避判断能力", "操縦テクニック", "どれをとっても完璧"]}, {"box": [634, 524, 652, 630], "vertical": true, "font_size": 21.0, "lines": ["うわさ以上ね"]}, {"box": [532, 558, 605, 666], "vertical": true, "font_size": 21.0, "lines": ["セカンド・", "チルドレンの", "実力は"]}, {"box": [257, 532, 335, 672], "vertical": true, "font_size": 18.0, "lines": ["輸送中の弐号機を", "狙った．．．とも", "考えられるわね"]}, {"box": [386, 852, 455, 958], "vertical": true, "font_size": 17.0, "lines": ["でもなぜ", "使徒があんな", "ところに．．．"]}, {"box": [314, 755, 340, 879], "vertical": true, "font_size": 19.0, "lines": ["その弐号機は？"]}, {"box": [65, 747, 167, 887], "vertical": true, "font_size": 18.0, "lines": ["第５ケージに", "冷却保管中", "アスカはホテルで", "休ませてるわ"]}], "img_path": "017.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1060, "blocks": [{"box": [672, 77, 689, 164], "vertical": true, "font_size": 14.0, "lines": ["すごいなあ"]}, {"box": [500, 74, 569, 179], "vertical": true, "font_size": 17.0, "lines": ["どうして", "あんなふうに", "動けるんだろ"]}, {"box": [387, 45, 461, 236], "vertical": true, "font_size": 17.0, "lines": ["どんな人なんですか", "セカンド・チルドレンの", "惣流さんて"]}, {"box": [100, 45, 174, 136], "vertical": true, "font_size": 21.0, "lines": ["あら", "気になる？", "シンちゃん"]}, {"box": [502, 359, 519, 433], "vertical": true, "font_size": 17.0, "lines": ["．．．．．．"]}, {"box": [99, 363, 196, 487], "vertical": true, "font_size": 19.0, "lines": ["そりゃあ．．．", "仲間として", "これから一緒に", "戦うワケだし．．．"]}, {"box": [643, 598, 687, 687], "vertical": true, "font_size": 19.0, "lines": ["聡明な子よ", "とっても"]}, {"box": [534, 592, 609, 698], "vertical": true, "font_size": 19.0, "lines": ["１４歳でもう", "ドイツの大学", "出てるしね"]}, {"box": [440, 849, 525, 982], "vertical": true, "font_size": 32.0, "lines": ["え！？", "大学っ！？"]}, {"box": [355, 781, 402, 936], "vertical": true, "font_size": 17.0, "lines": ["あんたたちの中じゃ", "一番マトモかもねぇ"]}, {"box": [90, 786, 139, 945], "vertical": true, "font_size": 20.0, "lines": ["どういうイミです？", "それ"]}], "img_path": "018.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1060, "blocks": [{"box": [544, 71, 647, 195], "vertical": true, "font_size": 21.0, "lines": ["ま明日", "正式に手続きが", "終わったら", "紹介するわ"]}, {"box": [279, 91, 384, 182], "vertical": true, "font_size": 22.0, "lines": ["学校", "終わったら", "すぐ本部に", "来るのよ"]}, {"box": [90, 196, 150, 326], "vertical": true, "font_size": 24.0, "lines": ["知らなかった", "な"]}, {"box": [429, 435, 481, 508], "vertical": true, "font_size": 22.0, "lines": ["楽しみに", "してて"]}, {"box": [321, 482, 341, 521], "vertical": true, "font_size": 20.0, "lines": ["はい"]}, {"box": [311, 475, 349, 527], "vertical": false, "font_size": 32.0, "lines": ["はい"]}, {"box": [561, 568, 655, 673], "vertical": true, "font_size": 24.0, "lines": ["他の国でも", "エヴァを", "造ってて"]}, {"box": [334, 575, 427, 701], "vertical": true, "font_size": 21.0, "lines": ["僕らの他にも", "パイロットが", "いたなんて"]}, {"box": [241, 575, 302, 701], "vertical": true, "font_size": 26.0, "lines": ["綾波は", "知ってたの？"]}, {"box": [65, 826, 89, 872], "vertical": true, "font_size": 24.0, "lines": ["ええ"]}], "img_path": "019.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1060, "blocks": [{"box": [628, 40, 655, 138], "vertical": true, "font_size": 25.0, "lines": ["ふうん．．．"]}, {"box": [613, 283, 676, 428], "vertical": true, "font_size": 23.0, "lines": ["何を聞いても", "表情を変えない"]}, {"box": [152, 285, 246,