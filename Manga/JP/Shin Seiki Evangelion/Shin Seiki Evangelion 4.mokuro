ize": 20.0, "lines": ["エヴァは？"]}, {"box": [204, 649, 268, 755], "vertical": true, "font_size": 24.0, "lines": ["発進準備中", "です！"]}, {"box": [66, 628, 120, 797], "vertical": true, "font_size": 22.0, "lines": ["しかしパイロット", "両名がまだ．．．"]}, {"box": [546, 823, 629, 956], "vertical": true, "font_size": 19.0, "lines": ["マギの予想より", "３時間も早い", "じゃない．．．"]}], "img_path": "161.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [696, 97, 754, 331], "vertical": true, "font_size": 32.0, "lines": ["たとえば、"]}, {"box": [311, 56, 367, 142], "vertical": true, "font_size": 26.0, "lines": ["シンジ", "アスカ！"]}, {"box": [592, 287, 619, 343], "vertical": true, "font_size": 27.0, "lines": ["もう"]}, {"box": [415, 350, 474, 500], "vertical": true, "font_size": 22.0, "lines": ["何やってんのよ", "あの２人は"]}, {"box": [53, 418, 149, 488], "vertical": true, "font_size": 28.0, "lines": ["決戦よ", "用意は", "いい！？"]}, {"box": [568, 559, 673, 912], "vertical": true, "font_size": 32.0, "lines": ["きゃーーっ"]}], "img_path": "162.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [589, 63, 676, 170], "vertical": true, "font_size": 21.0, "lines": ["ちょっとォ", "なんでまだ", "寝てんのよ"]}, {"box": [400, 68, 494, 158], "vertical": true, "font_size": 28.0, "lines": ["警報", "鳴ったで", "しょーが"]}, {"box": [299, 68, 376, 193], "vertical": true, "font_size": 20.0, "lines": ["ほら早く", "プラグスーツに", "着替えんのよ"]}, {"box": [65, 55, 114, 169], "vertical": true, "font_size": 29.0, "lines": ["ねむ～～い"]}, {"box": [632, 458, 655, 563], "vertical": true, "font_size": 23.0, "lines": ["進路クリア"]}, {"box": [84, 275, 146, 404], "vertical": true, "font_size": 24.0, "lines": ["お願いだから", "起きてェ〜〜〜"]}, {"box": [557, 537, 609, 621], "vertical": true, "font_size": 23.0, "lines": ["オール", "グリーン"]}, {"box": [53, 773, 148, 903], "vertical": true, "font_size": 24.0, "lines": ["エヴァ初号機", "及び弐号機", "発進準備完了"]}], "img_path": "163.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [610, 29, 663, 137], "vertical": true, "font_size": 22.0, "lines": ["あ～～先が", "思いやられる"]}, {"box": [411, 60, 463, 202], "vertical": true, "font_size": 20.0, "lines": ["今朝の早朝練習も", "できなかったしィ"]}, {"box": [290, 67, 370, 172], "vertical": true, "font_size": 18.0, "lines": ["大丈夫よ", "ミサトさん", "心配しないで"]}, {"box": [83, 74, 127, 181], "vertical": true, "font_size": 18.0, "lines": ["ユニゾンは", "すでに完璧よ"]}, {"box": [637, 464, 685, 538], "vertical": true, "font_size": 22.0, "lines": ["いいわね", "碇くん"]}, {"box": [318, 468, 336, 554], "vertical": true, "font_size": 17.0, "lines": ["わかってる"]}, {"box": [80, 301, 104, 349], "vertical": true, "font_size": 24.0, "lines": ["え？"]}, {"box": [372, 475, 475, 636], "vertical": true, "font_size": 20.0, "lines": ["最初から", "Ａ．Ｔフィールド全開", "フル稼働最大戦速で", "いくわよ"]}, {"box": [81, 473, 158, 633], "vertical": true, "font_size": 19.0, "lines": ["内部電源が", "切れるまでの６２秒で", "ケリをつける"]}, {"box": [670, 789, 686, 877], "vertical": true, "font_size": 14.0, "lines": ["なんなの？"]}, {"box": [291, 791, 307, 818], "vertical": true, "font_size": 16.0, "lines": ["？"]}, {"box": [87, 792, 136, 917], "vertical": true, "font_size": 18.0, "lines": ["あの子たちの", "あの自信は．．．"]}], "img_path": "164.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [580, 20, 660, 111], "vertical": true, "font_size": 32.0, "lines": ["外電源", "パージ"]}, {"box": [496, 98, 551, 206], "vertical": true, "font_size": 32.0, "lines": ["発進！"]}], "img_path": "165.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [332, 623, 466, 654], "vertical": false, "font_size": 23.0, "lines": ["２０１６年１１月１０日（月）に"]}], "img_path": "166.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [563, 63, 637, 209], "vertical": true, "font_size": 30.0, "lines": ["ミュージック", "スタート！！"]}], "img_path": "167.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [], "img_path": "168.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [591, 58, 666, 134], "vertical": true, "font_size": 27.0, "lines": ["すごい", "息が", "ぴったり"]}, {"box": [477, 298, 496, 380], "vertical": true, "font_size": 18.0, "lines": ["いける！！"]}], "img_path": "169.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [], "img_path": "170.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [], "img_path": "171.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [], "img_path": "172.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [623, 551, 668, 691], "vertical": true, "font_size": 32.0, "lines": ["掩護射撃っ"]}, {"box": [483, 914, 557, 1020], "vertical": true, "font_size": 32.0, "lines": ["弾幕", "張って！"]}], "img_path": "173.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [653, 585, 690, 683], "vertical": true, "font_size": 32.0, "lines": ["シンジ"]}, {"box": [81, 588, 123, 692], "vertical": true, "font_size": 32.0, "lines": ["うんっ"]}], "img_path": "174.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [], "img_path": "175.jpg"}, {"version": "0.1.6", "img_width": 745, "img_height": 1055, "blocks": [], "img_path": "176.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [], "img_path": "177.jpg"}, {"version": "0.1.6", "img_width": 742, "img_height": 1056, "blocks": [], "img_path": "178.jpg"}, {"version": "0.1.6", "img_width": 746, "img_height": 1056, "blocks": [{"box": [225, 59, 264, 143], "vertical": true, "font_size": 32.0, "lines": ["や．．．．．．"]}, {"box": [266, 505, 338, 649], "vertical": true, "font_size": 32.0, "lines": ["やった！", "やった！"]}, {"box": [4, 532, 72, 735], "vertical": true, "font_size": 32.0, "lines": ["バンザーイ", "バンザーイ"]}], "img_path": "179.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [82, 60, 106, 146], "vertical": true, "font_size": 22.0, "lines": ["あれっ．．．"]}, {"box": [584, 324, 688, 467], "vertical": true, "font_size": 23.0, "lines": ["あのう", "エヴァ両機", "起き上がりません", "けど"]}, {"box": [89, 335, 120, 403], "vertical": true, "font_size": 31.0, "lines": ["え！？"]}, {"box": [269, 574, 321, 661], "vertical": true, "font_size": 18.0, "lines": ["最後着地の", "タイミング"]}, {"box": [83, 574, 108, 662], "vertical": true, "font_size": 18.0, "lines": ["外したわね"]}, {"box": [296, 794, 314, 865], "vertical": true, "font_size": 17.0, "lines": ["ごめん．．．"]}, {"box": [81, 793, 159, 971], "vertical": true, "font_size": 21.0, "lines": ["だってタベの特訓", "最後のとこで力つきて", "寝ちゃったからさ"]}], "img_path": "180.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [532, 66, 661, 191], "vertical": true, "font_size": 21.0, "lines": ["なによ", "着地くらい", "特訓しなくても", "ちゃんとやんな", "さいよ"]}, {"box": [229, 60, 244, 117], "vertical": true, "font_size": 15.0, "lines": ["．．．"]}, {"box": [429, 325, 526, 500], "vertical": true, "font_size": 18.0, "lines": ["だからごめんて", "言ってるだろ", "もう終わったんだから", "いいじゃないか！！"]}, {"box": [326, 267, 385, 330], "vertical": true, "font_size": 32.0, "lines": ["特別に", "許す"]}, {"box": [78, 269, 128, 393], "vertical": true, "font_size": 20.0, "lines": ["使徒には", "勝てたんだしね"]}, {"box": [604, 547, 659, 757], "vertical": true, "font_size": 20.0, "lines": ["どんくさいわりには", "まあよくがんばったわ"]}, {"box": [650, 815, 667, 883], "vertical": true, "font_size": 17.0, "lines": ["．．．"]}, {"box": [76, 829, 181, 952], "vertical": true, "font_size": 17.0, "lines": ["君の口から", "お誉めの言葉を", "聞けるとは", "思わなかったな"]}], "img_path": "181.jpg"}, {"version": "0.1.6", "img_width": 748, "img_height": 1056, "blocks": [{"box": [379, 820, 507, 947], "vertical": true, "font_size": 21.0, "lines": ["なんか", "２人とも", "中で寝ちゃった", "みたいなんです", "けど"]}, {"box": [166, 777, 183, 865], "vertical": true, "font_size": 18.0, "lines": ["わからん．．．"]}, {"box": [73, 806, 143, 949], "vertical": true, "font_size": 18.0, "lines": ["今回ばかりは", "どうなってんのか", "さっぱり．．．"]}], "img_path": "182.jpg"}, {"version": "0.1.6", "img_width": 745, "img_height": 1056, "blocks": [{"box": [256, 57, 487, 92], "vertical": false, "font_size": 13.0, "lines": ["ＹＯＳＨＹＵＫＩＳＡＯＡＭＯＴＯ", "ＰＲＯＦＬＥ"]}, {"box": [248, 120, 494, 380], "vertical": false, "font_size": 19.0, "lines": ["貞本義行（さたもとよしゆき）●１９９２", "年１月２９日生まれ。血液型Ａ型。山", "口県徳山市出身。東京造形大学卒業", "日本Ｗｅｂ１００円あり、水が固めて平素後、アニメーターとなる。キャラクター・テサイナー作品を観として、", "ター・テサイサー、作戦監督として", "活躍。代表作品オフミスの製玉代表代品「オネアミスクリスマスの異王士", "立宇宙軍「トップをねらえノ」ふし", "きの海のナティア「新世紀エウァン", "ゲリオン，零。３５年２月号より月刊", "少年エースにて「新世紀エヴァンゲ", "リオン」を連載。現在ＧＡＮＡＸ所属。"]}, {"box": [257, 121, 487, 383], "vertical": true, "font_size": 32.0, "lines": ["それは．．．こんなことは"]}, {"box": [313, 473, 425, 493], "vertical": false, "font_size": 22.0, "lines": ["ｓＴＡＦＦＬＩＳＴ"]}, {"box": [253, 538, 360, 558], "vertical": false, "font_size": 15.0, "lines": ["Ｔｈｅａｕｔｈｏｒ"]}, {"box": [255, 588, 346, 605], "vertical": false, "font_size": 17.0, "lines": ["Ａｓｓｉｓｔａｎｔ"]}, {"box": [277, 681, 474, 701], "vertical": false, "font_size": 16.0, "lines": ["Ｔｈｅ．ｏｒｉｇｈａｌｅＡＮＡＸ"]}, {"box": [417, 542, 495, 653], "vertical": false, "font_size": 15.0, "lines": ["本裁行", "ト部", "長尾主二", "さりたりな"]}, {"box": [295, 728, 457, 748], "vertical": false, "font_size": 15.0, "lines": ["ＴｈａｎｋｓｔｏＭＡＫＯ"]}], "img_path": "183.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [150, 50, 310, 379], "vertical": true, "font_size": 16.857142857142858, "lines": ["夢はせてくれた「役」でした。私の中の", "一部というよりは、私の中にいる別人格、", "友達に近いかなぁ．．．。今もアスカと一", "緒に人生を勉強中、現在進行形〕という", "感じです。", "と言っても、２４番目のビリーや５番目", "のサリーではありませんよ。私だけに住"]}, {"box": [317, 53, 400, 345], "vertical": true, "font_size": 19.333333333333332, "lines": ["心の中にある", "アスカの居場所", "アスカという娘は、私に色々なことを"]}, {"box": [420, 50, 448, 354], "vertical": true, "font_size": 28.0, "lines": ["惣流・アスカ・ラングレー役"]}, {"box": [81, 49, 100, 511], "vertical": true, "font_size": 17.0, "lines": ["人間って一面だけじゃないでしょよー。みーこから始まります。"]}, {"box": [102, 49, 124, 669], "vertical": true, "font_size": 18.0, "lines": ["きっと住んでいると思うんです。ほらー、もさまざまでず。私とアスカの関係もう"]}, {"box": [83, 51, 146, 991], "vertical": true, "font_size": 18.0, "lines": ["んでいるんじゃなくて、皆さんんの中にも、者さんがいるように、アプローチの仕方", "中に共有した感情で、精神的ダメージを"]}, {"box": [152, 364, 384, 675], "vertical": true, "font_size": 18.0, "lines": ["ただ私は役者というものをやっておる", "ので、アスカという「キャラクター」に", "アプローチする機会があっただけだと思った", "うんですよ。役者としてまだまだ未熟者", "の私がこういうことを書くのは、なんだ", "かエラソーに見えるかもしれませんが．．．。", "ううっ。見えたらすみません。いや、そ", "れて、何が書きたいのかっちゅーと役者", "が役を演じる時、その役へのアプローチ", "ってえのがありますよね。さまざまな役"]}, {"box": [388, 374, 410, 431], "vertical": true, "font_size": 22.0, "lines": ["たいな。"]}, {"box": [105, 696, 384, 1000], "vertical": true, "font_size": 18.0, "lines": ["かなか心を開いてくれません。たとえば", "私がアスカにシンクロ率４００％で演じて", "ていたとしますよね。でもそれは、私が", "アスカに寄ってシシクロしているわけで、", "アスカから私に近寄ってはくれないので、", "す。結局、最後まで一線を越えて寄って", "くれませんでしたね。ある時、これがア", "スカの「心の壁」だと気がついたんです。", "よ。でも、これではですね、私の方ばか", "リがアスカの感情にとりこまれて、心の", "壁」を越えられてしまうという恐怖感や", "孤独感やさみしさや、いろいろシンクロ"]}, {"box": [390, 712, 407, 991], "vertical": true, "font_size": 17.0, "lines": ["とーこーろーがー、アスカってば、な"]}, {"box": [423, 811, 448, 993], "vertical": true, "font_size": 25.0, "lines": ["Ｙｏｏ！！Ｙａｈｕｂｅ"]}], "img_path": "184.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [97, 59, 111, 354], "vertical": true, "font_size": 14.0, "lines": ["こんなに苦しいのか、なっていうのがあっ"]}, {"box": [46, 57, 92, 467], "vertical": true, "font_size": 20.5, "lines": ["て、理由がわからないからよけい苦しくしていくか", "で。苦しみの報酬が経験だとすると、アーらさっ。ぶ"]}, {"box": [118, 55, 587, 359], "vertical": true, "font_size": 18.55, "lines": ["らおうとしても、ますます「壁」は高く、", "なるばかり。そりゃそうでしょう。押さ", "えつければつけるほどど反抗する力は大き", "くなるってもんです。それなら、こっち", "が折れて様子を見ようかなと思いまして。", "うーん、夫婦ゲンカみたいですね。その", "「心の壁」ごとアスカを認めてあげよう。", "私の心の中にアスカの居場所をわけてあ", "げて、見守ることにしよう。．．．それ", "で、今でも私の心の中には、アスカと私の", "を区別する一線がひいてあって、アスカ", "という別の人間が住んでるっていうこと", "になったのですねぇ。うんうん。", "もちろん今は冷静にに分析してますけど、", "演じてる当時は戦いですから。ヘレンケ", "ラーとサリバン先生みたいなもんですか", "ねぇ。アスカの「私の中に入ってこない」", "で」という叫びや、必死の願いにも聞こ", "える訴えがあまりにも強かったので、その", "りゃあ苦しいのなんのって。私、なんで"]}, {"box": [93, 366, 328, 465], "vertical": true, "font_size": 18.3, "lines": ["くのか、心", "の中の居場", "所で自分べ", "ースでゆっ", "くり成長し", "てくれたま", "へ。私もア", "スカに負け", "ないように", "一緒に成長"]}, {"box": [330, 380, 355, 467], "vertical": true, "font_size": 25.0, "lines": ["になってい"]}, {"box": [358, 380, 423, 467], "vertical": true, "font_size": 16.333333333333332, "lines": ["選択し、何", "を良しとし、", "どんな大人"]}, {"box": [594, 57, 662, 1000], "vertical": true, "font_size": 19.0, "lines": ["受けてしまうので、いかんなと。こりゃ、スカからは相当な経験を得られたと思い、ちあたった壁が厚ければ厚いほど、それ", "あいかんなと。", "でも、いくら私が「心の壁」をとりは"]}, {"box": [431, 366, 638, 710], "vertical": true, "font_size": 18.0, "lines": ["ますよー", "のねっ」ってことですかな。１４歳ってい", "「アスカってば、やっぱしまた！？」の子供な", "「私が、心の中の友人へ言いたいことは", "うと、ちょうど人生の壁にぶちあたって、", "色々学んで、自分の生き方とか選択して", "いく思春期でしょー。ぶちあたったとこ．．．", "「ろで「エヴァ」がクライマックスを迎えて", "てしまったけど、－この後、アスカが何を"]}, {"box": [430, 690, 638, 1003], "vertical": true, "font_size": 18.0, "lines": ["を破る武器をたくさん手に入れることが", "できるしねっ。人生、日々鍛錬中ですわ。", "苦しみを共にするのではなく、喜びを共", "にすることで良い友人になれるようがん", "ばりまひょ。難しく考えることはないの", "じゃ、山に近ければ山を食い、海が近け", "れば海を食う。そここに美味があるから味", "わおうって、人生は楽しむことだぞ。ア", "スカ。"]}], "img_path": "185.jpg"}, {"version": "0.1.6", "img_width": 754, "img_height": 1058, "blocks": [{"box": [373, 449, 396, 463], "vertical": false, "font_size": 12.0, "lines": ["漫画"]}, {"box": [400, 402, 506, 416], "vertical": false, "font_size": 14.0, "lines": ["角川コミックス・エース"]}, {"box": [356, 417, 553, 440], "vertical": false, "font_size": 21.0, "lines": ["新世紀エヴァンゲリオン４"]}, {"box": [333, 469, 584, 493], "vertical": false, "font_size": 22.5, "lines": ["行ってＧＡＩＮＡＸ", "貞本義行"]}, {"box": [381, 512, 540, 542], "vertical": false, "font_size": 13.5, "lines": ["１９３７年１０月２２日初版発行", "１９５７年１２月２０日第５期発行"]}, {"box": [440, 564, 478, 579], "vertical": false, "font_size": 15.0, "lines": ["発行者"]}, {"box": [422, 581, 493, 603], "vertical": false, "font_size": 22.0, "lines": ["角川歴法"]}, {"box": [287, 613, 634, 706], "vertical": false, "font_size": 15.0, "lines": ["発行所", "角川貴店", "あいつ、あされて代田区賞士見２－１３の", "振替日座ノＯが３０－９－１９５２００", "電話ノ東京（ｉＰＳ）３２８そこの「営業」（Ｃ）５２２９－３５５５（編集"]}, {"box": [421, 716, 496, 730], "vertical": false, "font_size": 14.0, "lines": ["装備・デザイン"]}, {"box": [355, 738, 527, 799], "vertical": false, "font_size": 15.0, "lines": ["鹿住忠広＋班ＢＴＯ", "印刷", "共同印刷"]}, {"box": [490, 765, 562, 798], "vertical": false, "font_size": 13.5, "lines": ["製本", "大谷製本"]}, {"box": [322, 813, 647, 883], "vertical": false, "font_size": 13.5, "lines": ["初出／「月刊・少年エース．．．９７年１．３５〜９月号まで", "本書の無断複写・複製・転載を禁じます。落丁・乱丁本は、", "ご面倒でも小社角川ブック・サ・ビス（Ｂｏｔｇ２－５９－１１０）を", "にお送りください。送料は小社会負担でお取り替えいたします。"]}, {"box": [317, 903, 606, 917], "vertical": false, "font_size": 13.0, "lines": ["１９３７ＫＡＤＯＫＡＷＡ、ＳＨＯＴＥＮ、Ｐｒｉｎｅｄｉｎ．Ａｇａｎ"]}, {"box": [409, 929, 512, 943], "vertical": false, "font_size": 14.0, "lines": ["©ＧＡＮＡＸ１８９７"]}, {"box": [380, 956, 543, 970], "vertical": false, "font_size": 14.0, "lines": ["ＥＢＮ４－４－７－３９７９－ＣＡＰＡ"]}], "img_path": "186.jpg"}]}