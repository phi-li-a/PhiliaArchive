6, 952], "vertical": true, "font_size": 17.0, "lines": ["あれは装甲板", "ではないの"]}], "img_path": "EVA7-080.JPG"}, {"version": "0.1.6", "img_width": 1454, "img_height": 1061, "blocks": [{"box": [1283, 39, 1363, 212], "vertical": true, "font_size": 21.0, "lines": ["エヴァ本来の力を", "私たちが抑え込む為の", "拘束具なのよ"]}, {"box": [1135, 336, 1214, 477], "vertical": true, "font_size": 21.0, "lines": ["その呪縛が", "エヴァ自らの力で", "解かれていく．．．"]}, {"box": [1333, 545, 1363, 649], "vertical": true, "font_size": 20.0, "lines": ["私たちには"]}, {"box": [965, 556, 1049, 680], "vertical": true, "font_size": 21.0, "lines": ["エヴァを", "止めることは", "できないわ"]}, {"box": [1144, 894, 1167, 937], "vertical": true, "font_size": 23.0, "lines": ["もう"]}, {"box": [580, 551, 641, 676], "vertical": true, "font_size": 23.0, "lines": ["初号機の", "覚醒と解放．．．"]}, {"box": [134, 718, 218, 884], "vertical": true, "font_size": 24.0, "lines": ["こいつは", "ゼーレが黙っちゃ", "いませんな"]}], "img_path": "EVA7-081.JPG"}, {"version": "0.1.6", "img_width": 1451, "img_height": 1051, "blocks": [{"box": [1258, 67, 1341, 192], "vertical": true, "font_size": 24.0, "lines": ["これも", "シナリオの", "うちですか？"]}, {"box": [806, 263, 846, 341], "vertical": true, "font_size": 31.0, "lines": ["碇司令"]}, {"box": [976, 580, 1010, 645], "vertical": true, "font_size": 25.0, "lines": ["全ては"]}, {"box": [776, 896, 799, 997], "vertical": true, "font_size": 20.0, "lines": ["これからだ"]}, {"box": [454, 46, 671, 93], "vertical": false, "font_size": 32.0, "lines": ["ＳＴＡＧＥ－４８：消液"]}], "img_path": "EVA7-082.JPG"}, {"version": "0.1.6", "img_width": 1444, "img_height": 1057, "blocks": [{"box": [557, 83, 688, 204], "vertical": true, "font_size": 21.0, "lines": ["エヴァ零号機", "弐号機の損傷は", "ヘリフリックの", "限界を超えて", "います"]}, {"box": [424, 70, 513, 186], "vertical": true, "font_size": 24.0, "lines": ["そう．．．", "時間が", "かかるわね"]}, {"box": [104, 280, 152, 367], "vertical": true, "font_size": 20.0, "lines": ["でもここは", "もうだめね"]}, {"box": [631, 573, 682, 713], "vertical": true, "font_size": 22.0, "lines": ["破棄決定は", "時間の問題ですね"]}, {"box": [413, 558, 490, 684], "vertical": true, "font_size": 25.0, "lines": ["幸い", "マギシステムは", "移植可能です"]}, {"box": [274, 576, 356, 665], "vertical": true, "font_size": 24.0, "lines": ["明日には", "作業を開始", "します"]}, {"box": [204, 563, 256, 746], "vertical": true, "font_size": 20.0, "lines": ["予備の第２発令所を", "使用するしかないわね」"]}, {"box": [284, 841, 303, 962], "vertical": true, "font_size": 19.0, "lines": ["とりあえずは．．．"]}], "img_path": "EVA7-083.JPG"}, {"version": "0.1.6", "img_width": 1457, "img_height": 1047, "blocks": [{"box": [1326, 68, 1373, 203], "vertical": true, "font_size": 20.0, "lines": ["マギはなくとも．．．", "ですか？"]}, {"box": [1182, 69, 1281, 243], "vertical": true, "font_size": 22.0, "lines": ["椅子はキツいし", "センサーは固いし．．．", "やりづらいんですよね", "あそこ"]}, {"box": [1095, 76, 1148, 237], "vertical": true, "font_size": 22.0, "lines": ["第１発令所と造りは", "同じなんですけど"]}, {"box": [947, 66, 999, 186], "vertical": true, "font_size": 20.0, "lines": ["使えるかどうか", "わからないのは"]}, {"box": [1027, 439, 1079, 527], "vertical": true, "font_size": 17.0, "lines": ["今は使える", "だけマシよ"]}, {"box": [779, 442, 811, 524], "vertical": true, "font_size": 20.0, "lines": ["初号機ね"]}, {"box": [648, 22, 670, 145], "vertical": true, "font_size": 22.0, "lines": ["ケイジに拘束．．．"]}, {"box": [594, 78, 623, 220], "vertical": true, "font_size": 22.0, "lines": ["大丈夫でしょうね"]}, {"box": [150, 54, 199, 243], "vertical": true, "font_size": 21.0, "lines": ["内部に熱・電子・電磁他", "化学エネルギー反応なし"]}, {"box": [99, 123, 122, 347], "vertical": true, "font_size": 21.0, "lines": ["５機関は完全に停止してます。"]}, {"box": [414, 370, 435, 543], "vertical": true, "font_size": 18.0, "lines": ["ーにもかかわらず"]}, {"box": [618, 671, 670, 792], "vertical": true, "font_size": 20.0, "lines": ["この初号機は", "２度も動いたわ"]}], "img_path": "EVA7-084.JPG"}, {"version": "0.1.6", "img_width": 1454, "img_height": 1051, "blocks": [{"box": [603, 711, 680, 833], "vertical": true, "font_size": 20.0, "lines": ["まさか対使徒", "迎撃要塞都市の", "システムが"]}, {"box": [303, 835, 381, 974], "vertical": true, "font_size": 21.0, "lines": ["暴走したエヴァを", "止めるのに", "役立つなんて．．．"]}, {"box": [93, 913, 113, 965], "vertical": true, "font_size": 20.0, "lines": ["いえ．．．"]}], "img_path": "EVA7-085.JPG"}, {"version": "0.1.6", "img_width": 1454, "img_height": 1051, "blocks": [{"box": [1324, 72, 1376, 174], "vertical": true, "font_size": 18.0, "lines": ["最初から", "そのつもりの"]}, {"box": [785, 68, 839, 224], "vertical": true, "font_size": 21.0, "lines": ["防護システム", "だったとしたら．．．？"]}, {"box": [1297, 454, 1372, 644], "vertical": true, "font_size": 24.0, "lines": ["エヴァシリーズに", "生まれいずるはずのない", "Ｓ機関"]}, {"box": [815, 816, 865, 1008], "vertical": true, "font_size": 19.0, "lines": ["まさか使徒を食うことで", "自ら取り込むとはな"]}, {"box": [594, 61, 690, 160], "vertical": true, "font_size": 21.0, "lines": ["我らゼーレの", "シナリオとは", "大きく違った", "出来事だよ"]}, {"box": [461, 59, 485, 127], "vertical": true, "font_size": 16.0, "lines": ["この修正"]}, {"box": [301, 61, 357, 134], "vertical": true, "font_size": 24.0, "lines": ["容易では", "ないぞ"]}, {"box": [257, 65, 282, 149], "vertical": true, "font_size": 19.0, "lines": ["碇ゲンドウ"]}, {"box": [80, 65, 174, 191], "vertical": true, "font_size": 18.0, "lines": ["あの男にネルフを", "与えたのか", "そもそもの間違い", "ではないのかね？"]}, {"box": [658, 393, 685, 436], "vertical": true, "font_size": 27.0, "lines": ["だが"]}, {"box": [97, 386, 170, 543], "vertical": true, "font_size": 20.0, "lines": ["あの男でなければ", "全ての計画の遂行は", "できなかった"]}, {"box": [586, 596, 693, 720], "vertical": true, "font_size": 23.0, "lines": ["だが事態は", "エヴァ初号機の", "問題だけでは", "ない"]}, {"box": [455, 597, 485, 640], "vertical": true, "font_size": 29.0, "lines": ["左様"]}, {"box": [309, 605, 361, 710], "vertical": true, "font_size": 22.0, "lines": ["零号機と", "弐号機の大破"]}, {"box": [251, 604, 278, 725], "vertical": true, "font_size": 27.0, "lines": ["本部施設の半壊"]}, {"box": [251, 603, 269, 724], "vertical": true, "font_size": 23.0, "lines": ["本部施設の半壊"]}, {"box": [168, 596, 218, 755], "vertical": true, "font_size": 23.0, "lines": ["セントラルドグマの", "露呈"]}], "img_path": "EVA7-086.JPG"}, {"version": "0.1.6", "img_width": 1457, "img_height": 1054, "blocks": [{"box": [1337, 34, 1364, 153], "vertical": true, "font_size": 18.0, "lines": ["被害は基大だよ"]}, {"box": [1047, 54, 1150, 180], "vertical": true, "font_size": 24.0, "lines": ["我々がどれ程の", "金と時を失っ", "たのかどうか", "見当もつかん"]}, {"box": [813, 56, 890, 178], "vertical": true, "font_size": 18.0, "lines": ["これも碇の首に", "鈴をつけて", "おかないからだ"]}, {"box": [1336, 398, 1388, 473], "vertical": true, "font_size": 26.0, "lines": ["いや鈴は", "ついてる"]}, {"box": [1088, 385, 1163, 493], "vertical": true, "font_size": 24.0, "lines": ["だが", "鳴らない鈴に", "意味はない"]}, {"box": [1195, 544, 1269, 652], "vertical": true, "font_size": 23.0, "lines": ["ただ", "鳴らなかった", "だけだ"]}, {"box": [1131, 618, 1165, 685], "vertical": true, "font_size": 25.0, "lines": ["今度は"]}, {"box": [788, 852, 850, 958], "vertical": true, "font_size": 22.0, "lines": ["鈴に働いて", "もらおう"]}, {"box": [630, 56, 654, 139], "vertical": true, "font_size": 24.0, "lines": ["いやはや"]}, {"box": [116, 283, 179, 408], "vertical": true, "font_size": 22.0, "lines": ["この展開は", "予想外ですな"]}, {"box": [568, 556, 672, 682], "vertical": true, "font_size": 22.0, "lines": ["委員会．．．いや", "ゼーレの方には", "どう言い訳する", "つもりです？"]}, {"box": [226, 547, 304, 687], "vertical": true, "font_size": 20.0, "lines": ["初号機は", "我々の制御下では", "なかった"]}, {"box": [83, 560, 135, 664], "vertical": true, "font_size": 20.0, "lines": ["これは不慮の", "事故だよ"]}], "img_path": "EVA7-087.JPG"}, {"version": "0.1.6", "img_width": 1464, "img_height": 1047, "blocks": [{"box": [1342, 81, 1395, 205], "vertical": true, "font_size": 25.0, "lines": ["よって初号機は", "凍結"]}, {"box": [1168, 80, 1220, 200], "vertical": true, "font_size": 17.0, "lines": ["委員会の別命", "あるまでは．．．だ"]}, {"box": [1361, 449, 1388, 570], "vertical": true, "font_size": 20.0, "lines": ["適切な処置です"]}, {"box": [823, 427, 916, 552], "vertical": true, "font_size": 22.0, "lines": ["御子息を", "取り込まれた", "ままですか？"]}, {"box": [1169, 607, 1195, 665], "vertical": true, "font_size": 26.0, "lines": ["しかし"]}, {"box": [1072, 613, 1099, 629], "vertical": false, "font_size": 16.0, "lines": ["Ｇだ！！"]}, {"box": [1086, 728, 1283, 878], "vertical": false, "font_size": 26.333333333333332, "lines": ["このように２０１８年１２月", "しかし、この時期は２０１６年１０月までに、", "そうか．．．"]}, {"box": [646, 62, 697, 135], "vertical": true, "font_size": 24.0, "lines": ["やはり", "ダメです"]}, {"box": [447, 30, 516, 167], "vertical": true, "font_size": 20.0, "lines": ["エントリーブラグ", "排出信号", "受け付けません"]}, {"box": [68, 198, 149, 273], "vertical": true, "font_size": 28.0, "lines": ["予備といじん", "疑似信号", "は？"]}, {"box": [631, 350, 687, 439], "vertical": true, "font_size": 23.0, "lines": ["拒絶されて", "います"]}, {"box": [428, 344, 480, 466], "vertical": true, "font_size": 20.0, "lines": ["直轄回路も", "つながりません"]}, {"box": [348, 336, 399, 474], "vertical": true, "font_size": 18.0, "lines": ["ブラグの映像回路", "つながりました！"]}, {"box": [90, 334, 141, 439], "vertical": true, "font_size": 20.0, "lines": ["主モニターに", "回します"]}], "img_path": "EVA7-088.JPG"}, {"version": "0.1.6", "img_width": 1468, "img_height": 1054, "blocks": [{"box": [1378, 60, 1396, 133], "vertical": true, "font_size": 18.0, "lines": ["．．．！！"]}, {"box": [1188, 83, 1209, 139], "vertical": true, "font_size": 21.0, "lines": ["これが"]}, {"box": [801, 70, 854, 190], "vertical": true, "font_size": 22.0, "lines": ["シンクロ車", "４００％の正体．．．！？"]}, {"box": [1234, 345, 1284, 402], "vertical": true, "font_size": 26.0, "lines": ["なによ", "これ．．"]}, {"box": [764, 331, 842, 401], "vertical": false, "font_size": 18.0, "lines": ["ＯＢＪＥＧＴ：", "ＥＮＴＲＹＰにも"]}, {"box": [1336, 589, 1398, 737], "vertical": true, "font_size": 22.0, "lines": ["シンジ君は一体", "どうなったの！？"]}, {"box": [1066, 602, 1082, 737], "vertical": true, "font_size": 14.0, "lines": ["どういうこと．．"]}, {"box": [851, 593, 875, 718], "vertical": true, "font_size": 27.0, "lines": ["エヴァって．．．"]}, {"box": [785, 648, 820, 790], "vertical": true, "font_size": 27.0, "lines": ["何なのよ！"]}, {"box": [1111, 836, 1190, 958], "vertical": true, "font_size": 20.0, "lines": ["エヴァ初号機に", "取り込まれて", "しまったわ．．．"]}, {"box": [1013, 810, 1090, 950], "vertical": true, "font_size": 20.0, "lines": ["人の造りだした", "人に近い形をした", "物体．．．．．"]}, {"box": [778, 818, 851, 906], "vertical": true, "font_size": 22.0, "lines": ["としか", "言いようが", "ないわね"]}, {"box": [658, 63, 682, 189], "vertical": true, "font_size": 18.0, "lines": ["人が造りだした？"]}, {"box": [418, 28, 508, 138], "vertical": true, "font_size": 17.0, "lines": ["あの時南極で", "拾ったものを", "ただコピーした", "だけじゃないの"]}, {"box": [75, 177, 120, 316], "vertical": true, "font_size": 20.0, "lines": ["オリジナルが", "聞いて呆れるわ！"]}, {"box": [659, 326, 680, 500], "vertical": true, "font_size": 19.0, "lines": ["ただのコピーとは違うわ"]}, {"box": [592, 328, 637, 481], "vertical": true, "font_size": 19.0, "lines": ["人の意志が", "こめられているもの"]}, {"box": [83, 388, 177, 514], "vertical": true, "font_size": 25.0, "lines": ["これも誰かの", "意志だって", "いうの！？"]}, {"box": [636, 556, 680, 644], "vertical": true, "font_size": 19.0, "lines": ["あるいは", "エヴァの．．．"]}], "img_path": "EVA7-089.JPG"}, {"version": "0.1.6", "img_width": 1464, "img_height": 1054, "blocks": [{"box": [1362, 28, 1415, 219], "vertical": true, "font_size": 21.0, "lines": ["そんな平気にのん気な事", "言ってんじゃないわよ！"]}, {"box": [1029, 72, 1104, 161], "vertical": true, "font_size": 20.0, "lines": ["造ったのは", "あんたなん", "でしょ！？"]}, {"box": [790, 58, 854, 203], "vertical": true, "font_size": 22.0, "lines": ["最後まで責任", "持ちなさいよッ"]}, {"box": [1139, 431, 1200, 541], "vertical": true, "font_size": 27.0, "lines": ["何とか", "しなさいよ"]}, {"box": [1075, 366, 1090, 420], "vertical": true, "font_size": 15.0, "lines": ["．．．．．．"]}, {"box": [667, 248, 690, 373], "vertical": true, "font_size": 19.0, "lines": ["まだ生きてる．．．"]}, {"box": [315, 589, 344, 663], "vertical": true, "font_size": 26.0, "lines": ["碇くん．．．"]}], "img_path": "EVA7-090.JPG"}, {"version": "0.1.6", "img_width": 1468, "img_height": 1051, "blocks": [{"box": [1361, 610, 1394, 665], "vertical": true, "font_size": 32.0, "lines": ["何も．．"]}, {"box": [1054, 609, 1099, 719], "vertical": true, "font_size": 18.0, "lines": ["何もできな", "かったなんて．．．"]}, {"box": [1346, 825, 1386, 966], "vertical": true, "font_size": 16.0, "lines": ["あのバカシンジに", "助けられたなんて"]}, {"box": [798, 887, 816, 993], "vertical": true, "font_size": 16.0, "lines": ["くやしい．．．"]}, {"box": [491, 498, 506, 533], "vertical": true, "font_size": 15.0, "lines": ["そう"]}, {"box": [83, 215, 178, 322], "vertical": true, "font_size": 29.0, "lines": ["シンジ君の", "サルベージ", "計画！？"]}, {"box": [540, 490, 693, 650], "vertical": true, "font_size": 20.0, "lines": ["シンジ君の肉体は", "自我境界線を失って", "量子状態のまま", "エントリーブラグを", "漂っていると", "推測されます"]}, {"box": [271, 490, 348, 632], "vertical": true, "font_size": 20.0, "lines": ["フラグ中の成分は", "原始地球の海水に", "酷似してます"]}, {"box": [70, 486, 126, 577], "vertical": true, "font_size": 26.0, "lines": ["生命の", "スープか．．．"]}, {"box": [369, 814, 447, 973], "vertical": true, "font_size": 21.0, "lines": ["彼の精神――", "魂とでも呼ぶべき", "ものもいっしょにね"]}, {"box": [47, 815, 172, 972], "vertical": true, "font_size": 20.0, "lines": ["つまりシンジ君は", "私たちの眼では", "確認できない状態に", "変化しているって", "こと？"]}], "img_path": "EVA7-091.JPG"}, {"version": "0.1.6", "img_width": 1468, "img_height": 1051, "blocks": [{"box": [1302, 78, 1378, 219], "vertical": true, "font_size": 20.0, "lines": ["シンジ君の肉体を", "再構成して精神を", "定着させるわ"]}, {"box": [1066, 68, 1116, 156], "vertical": true, "font_size": 20.0, "lines": ["そんな事が", "できるの？"]}, {"box": [784, 58, 836, 196], "vertical": true, "font_size": 23.0, "lines": ["マギのサポートが", "あればね"]}, {"box": [1343, 361, 1395, 448], "vertical": true, "font_size": 20.0, "lines": ["理論上は．．．", "．．．．．でしょ"]}, {"box": [835, 362, 911, 454], "vertical": true, "font_size": 23.0, "lines": ["でも今は", "その理論に", "すがって"]}, {"box": [789, 433, 835, 557], "vertical": true, "font_size": 23.0, "lines": ["やってみるしか", "ないわね"]}, {"box": [1222, 709, 1298, 868], "vertical": true, "font_size": 23.0, "lines": ["たとえうまく", "鈴が鳴ったとしても", "だ．．"]}, {"box": [603, 53, 650, 190], "vertical": true, "font_size": 22.0, "lines": ["あの男を使うのは", "もう潮時だろう"]}, {"box": [547, 137, 596, 227], "vertical": true, "font_size": 22.0, "lines": ["それに", "碇の事だ．．．"]}, {"box": [108, 94, 177, 198], "vertical": true, "font_size": 20.0, "lines": ["それぐらいは", "推察の範疇", "やもしれぬ"]}, {"box": [643, 269, 666, 342], "vertical": true, "font_size": 23.0, "lines": ["そろそろ"]}, {"box": [308, 271, 332, 364], "vertical": true, "font_size": 24.0, "lines": ["タブリス"]}, {"box": [467, 560, 544, 699], "vertical": true, "font_size": 20.0, "lines": ["正鵠を射る", "我々の切り札に", "目覚めてもらおう"]}, {"box": [113, 557, 170, 699], "vertical": true, "font_size": 26.0, "lines": ["我々のシナリオの", "要よ"]}], "img_path": "EVA7-092.JPG"}, {"version": "0.1.6", "img_width": 1478, "img_height": 1051, "blocks": [{"box": [640, 30, 666, 133], "vertical": true, "font_size": 22.0, "lines": ["どうだね．．．"]}, {"box": [122, 148, 157, 216], "vertical": true, "font_size": 26.0, "lines": ["気分は"]}], "img_path": "EVA7-093.JPG"}, {"version": "0.1.6", "img_width": 1468, "img_height": 1051, "blocks": [{"box": [45, 40, 65, 216], "vertical": true, "font_size": 20.0, "lines": ["ＮＧＥ－－－．－－"]}, {"box": [283, 673, 293, 977], "vertical": true, "font_size": 12.0, "lines": ["．．．－．．ファンデータが"]}, {"box": [1357, 311, 1378, 416], "vertical": true, "font_size": 20.0, "lines": ["どこだ．．．？"]}, {"box": [814, 844, 838, 930], "vertical": true, "font_size": 24.0, "lines": ["ここ．．．"]}], "img_path": "EVA7-094.JPG"}, {"version": "0.1.6", "img_width": 1468, "img_height": 1061, "blocks": [{"box": [176, 338, 371, 359], "vertical": false, "font_size": 20.0, "lines": ["ＫａｄｏｋｏｗａＣｏｎｉｃｅＡ"]}, {"box": [210, 378, 331, 397], "vertical": false, "font_size": 19.0, "lines": ["角川コミックス・エース"]}, {"box": [167, 402, 371, 422], "vertical": false, "font_size": 20.0, "lines": ["新世紀エヴァンゲリオンの"]}, {"box": [164, 430, 381, 481], "vertical": false, "font_size": 17.666666666666668, "lines": ["漫画", "さだもとよし", "貞本義行．ＧＡＮＡＸ"]}, {"box": [197, 488, 354, 507], "vertical": false, "font_size": 19.0, "lines": ["２００１年１２月１日初版発行"]}, {"box": [313, 428, 364, 460], "vertical": false, "font_size": 17.5, "lines": ["原作", "ガイナックス"]}, {"box": [156, 738, 182, 755], "vertical": false, "font_size": 17.0, "lines": ["印刷"]}, {"box": [250, 536, 292, 557], "vertical": false, "font_size": 21.0, "lines": ["発行者"]}, {"box": [227, 559, 318, 574], "vertical": false, "font_size": 15.0, "lines": ["井上伸一郎"]}, {"box": [111, 582, 432, 681], "vertical": false, "font_size": 15.0, "lines": ["発行所", "株式会社田．．．", "振替口座／００１３０－９－１９５２０８", "〒１０２８１７７東京都千代田区富士見２－１３：", "電話ノ東京（Ｃ３）３２８８５３０（営業）・（０３）３２３８，８６６３（編集"]}, {"box": [227, 692, 318, 706], "vertical": false, "font_size": 14.0, "lines": ["装備・デザイン"]}, {"box": [189, 711, 356, 725], "vertical": false, "font_size": 14.0, "lines": ["鹿住忠広＋ＢＥＥＮＴＯ"]}, {"box": [116, 759, 430, 804], "vertical": false, "font_size": 17.0, "lines": ["共同印刷株式会社", "初出ノ『月刊少年エース』０１年１〜２５〜８、１０〜１１月号"]}, {"box": [364, 739, 388, 755], "vertical": false, "font_size": 16.0, "lines": ["製本"]}, {"box": [275, 757, 473, 775], "vertical": false, "font_size": 16.0, "lines": ["ｅＢｏｏｋマニュファクチュアリング"]}, {"box": [125, 808, 473, 915], "vertical": false, "font_size": 17.0, "lines": ["本書の無断複写・複製・転載を続け、一面倒でも小さめき延照キャックます。落丁・乱丁本は、一般業仮想にお送りくだ", "本番のＡｍａｚｏｎのご面倒でも小社営業部受注センターショックのあっ。落ち取り中は、一読者係宛にお送りください。しゃー", "２０１８年１０月１５日水は、送料は小社負担でお取り替えいたします。この本作はコーストレースポイルです。", "送料は小型製但しおより悩んで、この物語はフィクションでありたします。実在の人物・団体名とは", "この物語は関係がございません。", "２００１ＫＡＤＯＫＡＷＡＳＨＯＴＥＮ．Ｐｒｉｔｅｄｉｎ．ａｏａｎ"]}, {"box": [193, 923, 353, 960], "vertical": false, "font_size": 16.0, "lines": ["＠ＧＡＮＡＸ２００１", "ＲＳＭ４－０４７１３４６４４４９４１００７３"]}, {"box": [1003, 49, 1233, 87], "vertical": false, "font_size": 16.0, "lines": ["イスコードイレストラＡＤＡＮＥＴＴＯＴＯ", "「ローロール」"]}, {"box": [1000, 114, 1235, 392], "vertical": false, "font_size": 17.0, "lines": ["貞本龍行（さたもとよりしゆき）●１９０２", "年１月２９日生まれ。血液型Ａ型。山", "口県商山市出身。東京道形大学卒業", "後、アニメーター・となる。キャラク", "ター・テザイナー、作画監督として", "活躍。代表作品「オネアミスの翼王", "立宇宙軍Ｊ「トッブをねらえノ♪ふし", "ぎの海のナティアＪ新世紀エヴァン", "ゲリオン・「フリクリ・零。Ｖ５年２月", "私より月刊少年エースにて「新世紀", "エヴァンゲリオン」を連載。現在", "ＧＡＩＮＡＸ所属。"]}, {"box": [1060, 465, 1183, 485], "vertical": false, "font_size": 16.0, "lines": ["ＳＴＡＦＦＬＩＳＴ"]}, {"box": [1003, 533, 1101, 550], "vertical": false, "font_size": 18.0, "lines": ["Ｔｈｅａｕｔｈｏｒ"]}, {"box": [1002, 580, 1092, 598], "vertical": false, "font_size": 16.0, "lines": ["Ａｓｓｉｓｔａｎｔ"]}, {"box": [1178, 532, 1238, 549], "vertical": false, "font_size": 18.0, "lines": ["貞本裁行"]}, {"box": [1174, 569, 1241, 761], "vertical": false, "font_size": 19.0, "lines": ["内山一成", "さりたりな", "下口智裕", "楠引圭太", "杉山登志夫", "田中前朗", "土屋個人"]}, {"box": [1025, 814, 1212, 837], "vertical": false, "font_size": 16.0, "lines": ["Ｔｈｅ．ｏｒｔｅｌｎａｌＧＡＮＡＸ"]}, {"box": [1040, 863, 1198, 883], "vertical": false, "font_size": 16.0, "lines": ["ＴｈａｎｋｓｔｏＭＡＫＯ"]}], "img_path": "EVA7-095.JPG"}, {"version": "0.1.6", "img_width": 750, "img_height": 1056, "blocks": [{"box": [36, 36, 325, 220], "vertical": false, "font_size": 29.0, "lines": ["新世紀エヴァングリオン", "真本義行＋ＧＡＮＡＸ", "具体裁行や", "ケロロ軍曹吉崎観音", "吉崎観音", "同時期で、", "成恵の世界", "丸川ドモビロ"]}, {"box": [515, 45, 686, 272], "vertical": false, "font_size": 28.0, "lines": ["これから４時", "大和田秀樹", "天王寺きつね", "エディズボウィ", "現在、２０１０年以上", "ＧＲＬＳブラボー", "まりお金田"]}, {"box": [506, 178, 687, 224], "vertical": false, "font_size": 32.0, "lines": ["奥瀬市中日黒三吉"]}, {"box": [508, 276, 682, 293], "vertical": false, "font_size": 17.0, "lines": ["ガラーでいあんＨｅｎｔｅ"]}, {"box": [501, 294, 688, 431], "vertical": false, "font_size": 21.571428571428573, "lines": ["天井は天井が", "多星人権探唄サ徂", "田郡帝茨大塚英患", "移重火路探偵サイチェア", "ひちあん", "ラグナロク", "ことがきつかさ"]}, {"box": [541, 430, 681, 446], "vertical": false, "font_size": 15.0, "lines": ["＋安井健太郎＋ＴＡＳＡ"]}, {"box": [514, 448, 698, 568], "vertical": false, "font_size": 30.8, "lines": ["Ｄ．．．リアンが診てあげる", "「竹内玩紀」", "アンネ・ブルークスにるちは、", "２０１１年３月２５日", "にるちゃな"]}, {"box": [595, 569, 683, 605], "vertical": false, "font_size": 16.5, "lines": ["ガバメンッ", "夏元雅人"]}, {"box": [128, 943, 558, 1040], "vertical": false, "font_size": 32.0, "lines": ["毎月２６日発売！！"]}], "img_path": "EVA7-096.JPG"}]}