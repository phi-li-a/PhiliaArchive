{"version": "0.2.0-beta.6", "title": "Shin Seiki Evangelion", "title_uuid": "cc3209cd-c119-4870-b06c-9a34f447db7e", "volume": "Shin Seiki Evangelion 2", "volume_uuid": "9e1f636b-82b1-4906-b788-1c16821e9cea", "pages": [{"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [239, 5, 492, 66], "vertical": false, "font_size": 32.0, "lines": ["第１１条こ"]}, {"box": [496, 424, 688, 517], "vertical": false, "font_size": 31.0, "lines": ["Ｖｏｌｕｍｅ．", "ナイフと少年"]}, {"box": [382, 526, 447, 556], "vertical": false, "font_size": 30.0, "lines": ["漫画"]}, {"box": [516, 570, 686, 617], "vertical": false, "font_size": 20.0, "lines": ["ｙｏｓｙｍｕｋｉｓＡＤＡＭＯＴＯ", "原作、ＧＡＮＡＸ"]}], "img_path": "EVA2-001.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [671, 91, 691, 314], "vertical": true, "font_size": 24.0, "lines": ["時に西暦２０１５年"]}, {"box": [557, 40, 658, 311], "vertical": true, "font_size": 24.0, "lines": ["未督有のカタストロフィー", "「セカンド・インパクト」に", "見舞われた人類は"]}, {"box": [66, 40, 166, 308], "vertical": true, "font_size": 27.0, "lines": ["その半数を失いながらも", "ようやく復興への道を", "歩き始めていた"]}], "img_path": "EVA2-002.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [464, 0, 710, 472], "vertical": true, "font_size": 32.0, "lines": ["しかし、正体不明の巨大戦闘兵器群「便」", "Ｌ太戦闘兵器群〔便徒", "来により、冷たたび世界は", "．．．", "それは．．．"]}, {"box": [271, 39, 479, 385], "vertical": true, "font_size": 27.0, "lines": ["予測されていた", "圧倒的強さを誇る使徒", "迎え撃つべノ", "特務機関ネルフは上計画を発動", "究極の汎用人型決戦兵器", "エヴァンゲリオンを実用化する"]}, {"box": [55, 39, 229, 405], "vertical": true, "font_size": 29.0, "lines": ["明らかになってゆくＢ計画の全然", "同時進行する人類補完計画。", "優してはならない", "〝神の領域への扉が", "少しずつ開かれてゆくう．．．。"]}], "img_path": "EVA2-003.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [231, 126, 530, 191], "vertical": false, "font_size": 32.0, "lines": ["ＰＲＯＧＲＡＭ"]}, {"box": [304, 212, 452, 229], "vertical": false, "font_size": 16.0, "lines": ["ＥｖＡＮＧＥＬＩＤＮＡ"]}, {"box": [148, 450, 253, 479], "vertical": false, "font_size": 31.0, "lines": ["ＳＴＡＧＥ．ｇ"]}, {"box": [147, 257, 409, 307], "vertical": false, "font_size": 24.0, "lines": ["こころ", "ＳＴＭＥ：７［閉じゅく心"]}, {"box": [148, 353, 524, 394], "vertical": false, "font_size": 32.0, "lines": ["ＳＴＭＥＲレンジご機嫌などの"]}, {"box": [147, 438, 460, 484], "vertical": false, "font_size": 32.0, "lines": ["ＳＴＡＥＥＳマニアの受難"]}, {"box": [385, 342, 432, 358], "vertical": false, "font_size": 16.0, "lines": ["きげん"]}, {"box": [380, 425, 477, 449], "vertical": false, "font_size": 20.0, "lines": ["じゅなんじゃの"]}, {"box": [153, 711, 257, 742], "vertical": false, "font_size": 32.0, "lines": ["ＳＴＡＧＥ．１２"]}, {"box": [150, 517, 426, 569], "vertical": false, "font_size": 26.0, "lines": ["しょうねん", "ＳＩＮＥのナイフと少年"]}, {"box": [153, 623, 513, 656], "vertical": false, "font_size": 30.0, "lines": ["ＳＴＭＥＭさまはおサードチルトン"]}, {"box": [147, 691, 477, 746], "vertical": false, "font_size": 32.0, "lines": ["しかたちも今回は", "ＳＴＯＥＥＺ、やさしさの輸入"]}, {"box": [571, 706, 623, 739], "vertical": false, "font_size": 32.0, "lines": ["１３９"]}, {"box": [257, 909, 373, 928], "vertical": false, "font_size": 16.0, "lines": ["ＳＩＮＳＵＩＫＡＲ"]}, {"box": [340, 824, 525, 841], "vertical": false, "font_size": 16.0, "lines": ["ＭＥＡＴＯＫＡＴＥＡＧ"]}], "img_path": "EVA2-004.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [649, 57, 683, 339], "vertical": true, "font_size": 29.0, "lines": ["●前巻までのあらすじ"]}, {"box": [651, 75, 682, 336], "vertical": true, "font_size": 31.0, "lines": ["●前巻までのあらすじ"]}, {"box": [59, 58, 315, 214], "vertical": false, "font_size": 15.0, "lines": ["編の主人と、１０年", "以上もの間、．．．", "家に預けられて育つ", "突然、父・ゲンドウによりネルフに呼", "ぱれエヴァのパイロットとなる。（１４歳"]}, {"box": [11, 59, 34, 176], "vertical": true, "font_size": 21.0, "lines": ["登場人物紹介"]}, {"box": [57, 244, 312, 405], "vertical": false, "font_size": 17.0, "lines": ["『城ミサト", "ネルフ本部戦術作戦", "部作戦局第一一課所属", "シジの直属の上司", "にあたる。おおらかな出格でシンジの", "数少ない理解者。花の独身．．．（２５歳"]}, {"box": [54, 434, 311, 592], "vertical": false, "font_size": 18.0, "lines": ["硯ゲンドウ", "シンジの実父、特務", "機関ネルフの最高高", "令長官。任務王上主", "義で実の息子にも冷蔵だが、レイには", "ふしぎな思いやりをみせる。（４８歳。"]}, {"box": [351, 356, 694, 847], "vertical": true, "font_size": 21.0, "lines": ["西暦２０１５年１１月東京３新東京市に〝使徒〟と呼ば", "れる正体不明の怪物が出現。防衛側の国連特務機関ネルフ", "によって開発された汎用人型決戦兵器・エヴァンゲリオン", "が迎え撃つも、その力の差は圧倒的で敗退を余儀なくされ", "る。ネルフ最高司令長官である碇ゲンドウは、エヴァのバ", "イロットとして、長らく他所へ預けていた息子・シンジを", "呼び寄せる。積年の確執と、あまりに独善的な要求への反", "発心から自暴自棄となったシシンは、エヴァへ搭乗するこ", "とを承諾するが、操縦もおぼつかぬまま出撃し、途中で意", "識を失ってしまう。操縦者なきままエヴァは暴走し、戦闘", "を続けてついには使徒を倒ししてしまうのだが．．．。"]}, {"box": [174, 624, 224, 635], "vertical": false, "font_size": 15.0, "lines": ["あやなみ"]}, {"box": [52, 669, 306, 779], "vertical": false, "font_size": 15.0, "lines": ["エヴァの『イロット", "零号機の起動実験中", "に事故に遭い手傷を", "負う。真黙で、過去も生いい立ちも不明", "なぜの少女、シンジの同級生、〈１４歳"]}, {"box": [679, 859, 707, 913], "vertical": true, "font_size": 22.0, "lines": ["僕は．．．"]}, {"box": [52, 809, 305, 963], "vertical": false, "font_size": 18.0, "lines": ["赤木リ", "ネルフ本部支術開発", "部技術一課所属。工", "ヴァ開発の責任者", "クールな常識人でミサトとは対照的な", "出格。白衣の＞似合う美人科学者。（３０歳"]}], "img_path": "EVA2-005.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [], "img_path": "EVA2-006.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [451, 8, 532, 23], "vertical": false, "font_size": 15.0, "lines": ["ＹＯＰＰＡＲＡＩ"]}, {"box": [567, 854, 699, 880], "vertical": false, "font_size": 12.0, "lines": ["「ＡＫＯＹＡＫＩ"]}, {"box": [55, 925, 327, 955], "vertical": false, "font_size": 28.0, "lines": ["ＳＴＡＧＥ．７閉じゅく心"]}], "img_path": "EVA2-007.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [654, 584, 699, 686], "vertical": true, "font_size": 20.0, "lines": ["あ．．．ゴメン", "荷物持ってエ"]}, {"box": [522, 887, 542, 955], "vertical": true, "font_size": 19.0, "lines": ["あ．．．はい"]}, {"box": [353, 820, 432, 958], "vertical": true, "font_size": 19.0, "lines": ["シンジ君の荷物は", "もう届いてると", "思うんだけど．．．"]}], "img_path": "EVA2-008.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [577, 48, 632, 176], "vertical": true, "font_size": 20.0, "lines": ["あっだあった", "ここよ"]}, {"box": [475, 371, 602, 540], "vertical": true, "font_size": 22.0, "lines": ["実をいうと", "あたしもこの街に", "引っ越してきた", "ばっかなのよね"]}, {"box": [613, 616, 667, 716], "vertical": true, "font_size": 24.0, "lines": ["さー", "はいってェ"]}, {"box": [58, 733, 156, 857], "vertical": true, "font_size": 27.0, "lines": ["ちょっと", "ちらかってる", "けどさ"]}], "img_path": "EVA2-009.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [248, 56, 296, 196], "vertical": true, "font_size": 19.0, "lines": ["どっしぇ！", "これがちょっと？"]}, {"box": [73, 77, 176, 184], "vertical": true, "font_size": 21.0, "lines": ["ね悪いけど．．．いちこ", "それ冷蔵庫に", "入れといて", "くれる？"]}, {"box": [404, 374, 426, 463], "vertical": true, "font_size": 23.0, "lines": ["待っててね"]}, {"box": [339, 433, 390, 540], "vertical": true, "font_size": 23.0, "lines": ["今食事の", "仕度するから"]}, {"box": [664, 638, 685, 701], "vertical": true, "font_size": 21.0, "lines": ["あはい"]}, {"box": [328, 639, 379, 715], "vertical": true, "font_size": 24.0, "lines": ["ビール", "ばっかし"]}, {"box": [250, 634, 303, 702], "vertical": true, "font_size": 19.0, "lines": ["ないよ"]}, {"box": [85, 649, 156, 755], "vertical": true, "font_size": 20.0, "lines": ["どーゆー", "生活してんだ", "このヒト"]}], "img_path": "EVA2-010.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [408, 52, 509, 141], "vertical": true, "font_size": 23.0, "lines": ["あの．．．", "こっちの", "でっかい", "冷蔵庫は？"]}, {"box": [76, 178, 150, 301], "vertical": true, "font_size": 20.0, "lines": ["そっちはいいの", "まだ寝てると", "思うから"]}, {"box": [628, 375, 661, 460], "vertical": true, "font_size": 22.0, "lines": ["寝てる？"]}], "img_path": "EVA2-011.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [636, 451, 694, 516], "vertical": true, "font_size": 26.0, "lines": ["なんだ", "アレ．．．"]}, {"box": [209, 458, 228, 565], "vertical": true, "font_size": 19.0, "lines": ["かわいいでしょ"]}, {"box": [207, 456, 227, 565], "vertical": true, "font_size": 19.0, "lines": ["かわいいでしょ"]}, {"box": [671, 665, 689, 749], "vertical": true, "font_size": 17.0, "lines": ["はあ．．．"]}, {"box": [501, 687, 548, 757], "vertical": true, "font_size": 21.0, "lines": ["ところで", "シンジ君"]}, {"box": [330, 681, 462, 818], "vertical": true, "font_size": 20.0, "lines": ["あたしと君が", "同居を始める上で", "やっとかなきゃ", "ならないコトが", "あるわ"]}, {"box": [77, 466, 181, 594], "vertical": true, "font_size": 19.0, "lines": ["彼新種の", "温泉ペンギンなの", "名前はペンペン", "よろしくね♡"]}, {"box": [218, 671, 254, 741], "vertical": true, "font_size": 32.0, "lines": ["は？"]}], "img_path": "EVA2-012.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [537, 6, 692, 266], "vertical": true, "font_size": 32.0, "lines": ["ジャーン"]}, {"box": [305, 344, 405, 509], "vertical": true, "font_size": 20.0, "lines": ["やったあ～～～", "勝っちゃったあ", "月曜の朝は", "シンジ君ね"]}, {"box": [45, 361, 147, 434], "vertical": true, "font_size": 22.0, "lines": ["ななな", "なんなん", "ですかあ", "いったい"]}, {"box": [603, 684, 651, 788], "vertical": true, "font_size": 22.0, "lines": ["ようしっ", "次いくわよォ"]}, {"box": [551, 688, 582, 766], "vertical": true, "font_size": 29.0, "lines": ["ジャー"]}, {"box": [515, 691, 540, 731], "vertical": false, "font_size": 32.0, "lines": ["ケー"]}, {"box": [433, 668, 487, 760], "vertical": true, "font_size": 24.0, "lines": ["ま．．．待って", "下さい！"]}, {"box": [411, 748, 442, 812], "vertical": true, "font_size": 24.0, "lines": ["な怖い顔"]}, {"box": [44, 1017, 112, 1035], "vertical": false, "font_size": 18.0, "lines": ["焼たく"]}], "img_path": "EVA2-013.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [613, 168, 710, 336], "vertical": true, "font_size": 32.0, "lines": ["ホホホボ"]}, {"box": [446, 62, 633, 170], "vertical": true, "font_size": 21.0, "lines": ["これで", "公平に決めた", "生活当番も", "オールＯＫね", "さあ", "どんどん", "食べてェ"]}, {"box": [285, 93, 403, 108], "vertical": false, "font_size": 15.0, "lines": ["２人の生活当番表"]}, {"box": [117, 67, 132, 165], "vertical": true, "font_size": 15.0, "lines": ["．．．．．．"]}, {"box": [479, 474, 494, 549], "vertical": true, "font_size": 15.0, "lines": ["．．．．．．"]}, {"box": [656, 707, 692, 751], "vertical": true, "font_size": 32.0, "lines": ["僕．．"]}, {"box": [475, 705, 548, 793], "vertical": true, "font_size": 20.0, "lines": ["これから", "どうなるん", "だろう．．"]}], "img_path": "EVA2-014.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [605, 299, 624, 409], "vertical": true, "font_size": 19.0, "lines": ["というわけで"]}, {"box": [479, 350, 582, 526], "vertical": true, "font_size": 19.0, "lines": ["人類は科学の発達と", "ともに爆熱した文明を", "謳歌してきたわけ", "ですが"]}, {"box": [45, 602, 151, 725], "vertical": true, "font_size": 21.0, "lines": ["すべてが灰燼に", "帰す時が", "やってきたので", "あります"]}], "img_path": "EVA2-015.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [631, 67, 659, 191], "vertical": true, "font_size": 17.0, "lines": ["２０世紀最後の年"]}, {"box": [474, 58, 678, 272], "vertical": true, "font_size": 19.0, "lines": ["皆さんもご存知"]}, {"box": [525, 127, 573, 266], "vertical": true, "font_size": 20.0, "lines": ["巨大隕石が南極に", "衝突したのは"]}, {"box": [475, 127, 492, 247], "vertical": true, "font_size": 20.0, "lines": ["だと思いますが"]}, {"box": [502, 415, 522, 501], "vertical": true, "font_size": 18.0, "lines": ["これにより"]}, {"box": [137, 414, 216, 505], "vertical": true, "font_size": 22.0, "lines": ["氷の大陸は", "一瞬にして", "溶解し"]}, {"box": [64, 518, 138, 642], "vertical": true, "font_size": 22.0, "lines": ["海洋の水位は", "２０ｍも上昇した", "わけであります"]}, {"box": [630, 721, 683, 876], "vertical": true, "font_size": 32.0, "lines": ["そして干ばつや洪水火山の噴火など"]}, {"box": [627, 720, 676, 875], "vertical": true, "font_size": 19.0, "lines": ["そして千ばつや洪水", "火山の噴火など"]}, {"box": [556, 808, 608, 910], "vertical": true, "font_size": 32.0, "lines": ["異常気象が世界中を襲い"]}, {"box": [556, 807, 602, 908], "vertical": true, "font_size": 19.0, "lines": ["異常気象が", "世界中を襲い"]}, {"box": [87, 826, 139, 948], "vertical": true, "font_size": 17.0, "lines": ["さらに経済恐慌", "民族紛争や内戦"]}], "img_path": "EVA2-016.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [613, 57, 658, 130], "vertical": true, "font_size": 20.0, "lines": ["ねえねえ", "聞いた？"]}, {"box": [527, 72, 546, 111], "vertical": true, "font_size": 19.0, "lines": ["え？"]}, {"box": [307, 46, 412, 204], "vertical": true, "font_size": 18.0, "lines": ["わずか半年の間に", "世界の人口の半分が", "永久に失われたの", "であります"]}, {"box": [208, 59, 230, 117], "vertical": true, "font_size": 22.0, "lines": ["なによ"]}, {"box": [554, 369, 631, 546], "vertical": true, "font_size": 19.0, "lines": ["これが世にいう", "「セカンドインパクト」", "でありますな"]}, {"box": [392, 253, 493, 344], "vertical": true, "font_size": 23.0, "lines": ["さっき", "男子が", "話してたん", "だけどさ"]}, {"box": [61, 238, 137, 328], "vertical": true, "font_size": 21.0, "lines": ["ほら", "きのうきた", "あの転校生"]}, {"box": [74, 440, 176, 565], "vertical": true, "font_size": 21.0, "lines": ["あのコ", "例のロボットの", "パイロットって", "ウワサよ"]}, {"box": [611, 662, 668, 728], "vertical": true, "font_size": 25.0, "lines": ["え？", "ウソ！"]}, {"box": [501, 670, 521, 730], "vertical": true, "font_size": 20.0, "lines": ["マジ？"]}, {"box": [222, 667, 246, 730], "vertical": true, "font_size": 24.0, "lines": ["．．．"]}], "img_path": "EVA2-017.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [659, 63, 677, 174], "vertical": true, "font_size": 20.0, "lines": ["あれから１５年"]}, {"box": [535, 110, 635, 267], "vertical": true, "font_size": 20.0, "lines": ["わずか１５年で", "私たちはここまで", "復興をとげることが", "できました"]}, {"box": [415, 329, 495, 455], "vertical": true, "font_size": 20.0, "lines": ["これは私たち", "人類の優秀性も", "さることながら"]}, {"box": [164, 610, 294, 784], "vertical": true, "font_size": 19.0, "lines": ["皆さんの", "お父さんやお母さんの", "血と汗と涙の結晶", "努力の賜物と", "いえるでしょう"]}], "img_path": "EVA2-018.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [142, 78, 195, 150], "vertical": true, "font_size": 24.0, "lines": ["ねェねェ", "碇くん"]}, {"box": [92, 163, 142, 235], "vertical": true, "font_size": 24.0, "lines": ["ちょっと", "いい？"]}, {"box": [577, 315, 657, 471], "vertical": true, "font_size": 20.0, "lines": ["疎開始まってんのに", "なんで今頃", "この学校にきたの"]}, {"box": [422, 361, 471, 419], "vertical": true, "font_size": 24.0, "lines": ["え？", "あ．．．"]}, {"box": [293, 309, 366, 398], "vertical": true, "font_size": 21.0, "lines": ["やっぱり", "ウワサは", "本当なのネ"]}, {"box": [53, 309, 99, 379], "vertical": true, "font_size": 20.0, "lines": ["ウワサっ", "て？"]}, {"box": [222, 538, 374, 662], "vertical": true, "font_size": 22.0, "lines": ["とぼけないでよ", "君があの", "ロボットの", "パイロット", "だって", "ウワサよ！"]}, {"box": [49, 546, 119, 653], "vertical": true, "font_size": 23.0, "lines": ["あれ", "ホントなんで", "しょ？"]}, {"box": [54, 811, 79, 868], "vertical": true, "font_size": 25.0, "lines": ["！？？．．．？？"]}], "img_path": "EVA2-019.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [638, 70, 691, 155], "vertical": true, "font_size": 22.0, "lines": ["ホント．．", "だけど．．．"]}, {"box": [366, 60, 432, 228], "vertical": true, "font_size": 29.0, "lines": ["きゃ～～～", "やっぱり～～"]}, {"box": [310, 59, 333, 184], "vertical": true, "font_size": 19.0, "lines": ["なになに女に"]}, {"box": [125, 40, 181, 169], "vertical": true, "font_size": 23.0, "lines": ["やっぱホント", "なんだってよ"]}, {"box": [82, 273, 167, 439], "vertical": true, "font_size": 22.0, "lines": ["あいつがあの", "ロボットに乗って", "たんだって！"]}, {"box": [633, 499, 704, 668], "vertical": true, "font_size": 32.0, "lines": ["スッゲエ～～～", "カッコイイ"]}, {"box": [487, 587, 568, 694], "vertical": true, "font_size": 19.0, "lines": ["質問～～ん！", "どうやって", "選ばれたの？"]}, {"box": [332, 550, 377, 690], "vertical": true, "font_size": 18.0, "lines": ["デストとか", "あったんでしょ？"]}, {"box": [182, 531, 258, 621], "vertical": true, "font_size": 24.0, "lines": ["ネェネェ", "怖く", "なかった？"]}, {"box": [106, 855, 170, 977], "vertical": true, "font_size": 22.0, "lines": ["必殺ワザとか", "あんのか？"]}], "img_path": "EVA2-020.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [621, 58, 655, 187], "vertical": true, "font_size": 22.0, "lines": ["必殺ワザ．．．？"]}, {"box": [450, 66, 467, 137], "vertical": true, "font_size": 17.0, "lines": ["さあ．．．"]}, {"box": [337, 59, 417, 217], "vertical": true, "font_size": 21.0, "lines": ["あの怪獣みたいなの", "いったい", "なんなの？"]}, {"box": [605, 422, 652, 580], "vertical": true, "font_size": 21.0, "lines": ["僕も．．．", "よくわかんないんだ"]}, {"box": [510, 465, 586, 571], "vertical": true, "font_size": 21.0, "lines": ["みんな「使徒」", "とか呼んでる", "けど．．．"]}, {"box": [453, 285, 505, 368], "vertical": true, "font_size": 20.0, "lines": ["ねえねえ", "じゃあね"]}, {"box": [204, 265, 256, 370], "vertical": true, "font_size": 20.0, "lines": ["どこかの国の", "秘密兵器？"]}, {"box": [64, 429, 138, 588], "vertical": true, "font_size": 20.0, "lines": ["はっきりしたことは", "誰も知らない", "みたいだし．．．"]}, {"box": [541, 648, 613, 802], "vertical": true, "font_size": 19.0, "lines": ["エラそうに", "しとってもなーんも", "知らへんのやな"]}, {"box": [457, 748, 503, 834], "vertical": true, "font_size": 19.0, "lines": ["パー", "ちゃうか？"]}], "img_path": "EVA2-021.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [656, 47, 712, 140], "vertical": true, "font_size": 19.0, "lines": ["あー", "鈴原君！！"]}, {"box": [559, 66, 632, 189], "vertical": true, "font_size": 19.0, "lines": ["あなた１週間も", "無断で学校を", "！？", "欠席してー"]}, {"box": [153, 34, 177, 181], "vertical": true, "font_size": 28.0, "lines": ["じゃかあしい！"]}, {"box": [86, 86, 123, 230], "vertical": true, "font_size": 28.0, "lines": ["黙っとれ！！"]}, {"box": [434, 382, 482, 474], "vertical": true, "font_size": 22.0, "lines": ["ちょっと"]}, {"box": [227, 396, 256, 466], "vertical": true, "font_size": 17.0, "lines": ["転校生！！"]}, {"box": [613, 694, 645, 805], "vertical": true, "font_size": 31.0, "lines": ["ちょっと"]}, {"box": [556, 726, 590, 838], "vertical": true, "font_size": 31.0, "lines": ["顔かせや"]}], "img_path": "EVA2-022.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [589, 339, 645, 424], "vertical": true, "font_size": 24.0, "lines": ["えーか", "転校生！"]}, {"box": [539, 364, 564, 468], "vertical": true, "font_size": 24.0, "lines": ["よう聞けよ"]}, {"box": [166, 353, 241, 511], "vertical": true, "font_size": 19.0, "lines": ["ワシの妹はなァ", "今ケガして", "入院してんねんぞ！！"]}, {"box": [100, 390, 117, 528], "vertical": true, "font_size": 19.0, "lines": ["オトンもオジーも"]}, {"box": [20, 389, 120, 546], "vertical": true, "font_size": 18.0, "lines": ["おまえのおる研究所", "勤めで看病するんは", "ワシしかおらん！！"]}, {"box": [542, 592, 661, 860], "vertical": true, "font_size": 23.0, "lines": ["まあ：ワシのことは", "どうでもええ．．．そやけど", "妹の顔に傷でも残ってみいっ", "べっぴんが台無しや！！"]}, {"box": [362, 591, 387, 756], "vertical": true, "font_size": 22.0, "lines": ["かわいそうやろ？"]}, {"box": [255, 591, 320, 717], "vertical": true, "font_size": 22.0, "lines": ["誰のせいやと", "思う．．．？？"]}], "img_path": "EVA2-023.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [671, 44, 703, 267], "vertical": true, "font_size": 29.0, "lines": ["オマエのせいや！"]}, {"box": [526, 72, 628, 248], "vertical": true, "font_size": 21.0, "lines": ["オマエがムチャクチャ", "暴れたせいで", "ビルの破片の", "下敷になったんや！！"]}, {"box": [351, 56, 450, 250], "vertical": true, "font_size": 25.0, "lines": ["チヤホヤされて", "ええ気に", "なってんちゃうわ！"]}, {"box": [82, 52, 114, 111], "vertical": true, "font_size": 32.0, "lines": ["あ．．．"]}, {"box": [281, 301, 307, 373], "vertical": true, "font_size": 26.0, "lines": ["ごめん"]}, {"box": [642, 619, 703, 763], "vertical": true, "font_size": 32.0, "lines": ["なめとんのかワレ！"]}, {"box": [638, 617, 699, 762], "vertical": true, "font_size": 28.0, "lines": ["なめとんのか", "ワレ！"]}, {"box": [524, 695, 590, 817], "vertical": true, "font_size": 28.0, "lines": ["”ごめん”で", "すむかァ"]}, {"box": [525, 695, 588, 816], "vertical": true, "font_size": 32.0, "lines": ["”ごめん”ですむかァ"]}, {"box": [79, 641, 213, 759], "vertical": true, "font_size": 26.0, "lines": ["おおい", "トウジ", "そのヘンで", "やめとけよ"]}], "img_path": "EVA2-024.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [616, 65, 666, 183], "vertical": true, "font_size": 21.0, "lines": ["じゃどうして", "ほしいの？"]}, {"box": [534, 146, 613, 271], "vertical": true, "font_size": 21.0, "lines": ["土下座", "しろってのなら", "するけど"]}, {"box": [65, 621, 171, 729], "vertical": true, "font_size": 25.0, "lines": ["オイ！だいじ", "大事な", "パイロットに", "なんてことを"]}], "img_path": "EVA2-025.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [673, 67, 686, 141], "vertical": true, "font_size": 13.0, "lines": ["．．．．．．！？"]}, {"box": [322, 79, 434, 184], "vertical": true, "font_size": 20.0, "lines": ["おー", "やる気やな？", "くるんなら", "こいや！"]}, {"box": [106, 72, 181, 180], "vertical": true, "font_size": 23.0, "lines": ["おおい", "トウジ", "いいかげんに"]}, {"box": [604, 439, 692, 524], "vertical": true, "font_size": 24.0, "lines": ["ひとつ．．", "聞いても", "いい？"]}, {"box": [96, 438, 177, 506], "vertical": true, "font_size": 32.0, "lines": ["ああ"]}, {"box": [591, 737, 689, 840], "vertical": true, "font_size": 20.0, "lines": ["そんなに", "いちいち", "カッカしてて", "疲れない？"]}], "img_path": "EVA2-026.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [525, 33, 679, 329], "vertical": true, "font_size": 31.0, "lines": ["んどーゃっ", "ヒトなめんのも", "たいがいに", "せえよコラ"]}, {"box": [424, 87, 443, 169], "vertical": true, "font_size": 19.0, "lines": ["こらァ！！"]}, {"box": [355, 84, 406, 251], "vertical": true, "font_size": 19.0, "lines": ["なにやってんのよ", "あんたたちっ！！"]}, {"box": [241, 311, 305, 419], "vertical": true, "font_size": 24.0, "lines": ["ちっ邪魔が", "入りよった"]}, {"box": [621, 662, 669, 736], "vertical": true, "font_size": 21.0, "lines": ["ええか", "ドアホ！！"]}, {"box": [186, 645, 213, 772], "vertical": true, "font_size": 25.0, "lines": ["わかったか！！"]}, {"box": [424, 807, 470, 924], "vertical": true, "font_size": 20.0, "lines": ["コレだけは", "言うといたる！！"]}, {"box": [260, 811, 356, 974], "vertical": true, "font_size": 24.0, "lines": ["今度戦うときゃ", "足元よお見てから", "戦えや！"]}, {"box": [4, 865, 110, 998], "vertical": false, "font_size": 17.0, "lines": ["それでも、", "ではなかっ"]}], "img_path": "EVA2-027.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [583, 6, 676, 154], "vertical": true, "font_size": 26.0, "lines": ["シンジ君", "調子は？"]}, {"box": [194, 56, 217, 97], "vertical": true, "font_size": 23.0, "lines": ["はい"]}, {"box": [93, 89, 170, 230], "vertical": true, "font_size": 23.0, "lines": ["一応基本操作", "には慣れてきたと", "思います"]}, {"box": [630, 300, 677, 465], "vertical": true, "font_size": 18.0, "lines": ["いやそうじゃなくて", "学校のほうのことよ"]}, {"box": [97, 291, 200, 397], "vertical": true, "font_size": 23.0, "lines": ["べつに", "変わったこと", "ないです", "けど．．．"]}, {"box": [241, 468, 261, 532], "vertical": true, "font_size": 18.0, "lines": ["え．．．"]}, {"box": [595, 664, 614, 733], "vertical": true, "font_size": 20.0, "lines": ["そう．．．"]}, {"box": [597, 663, 613, 737], "vertical": true, "font_size": 16.0, "lines": ["そう．．．"]}, {"box": [544, 694, 569, 834], "vertical": true, "font_size": 20.0, "lines": ["ならいいんだけど"]}, {"box": [139, 700, 184, 821], "vertical": true, "font_size": 17.0, "lines": ["ーーじゃあ", "今日もいくわよ"]}], "img_path": "EVA2-028.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [530, 69, 655, 195], "vertical": true, "font_size": 21.0, "lines": ["エヴァの", "出現位置", "非常用電源", "兵装ビルの配置", "回収スポット"]}, {"box": [292, 71, 320, 117], "vertical": true, "font_size": 28.0, "lines": ["はい"]}, {"box": [66, 170, 91, 234], "vertical": true, "font_size": 25.0, "lines": ["たぶん"]}, {"box": [248, 283, 321, 382], "vertical": true, "font_size": 30.0, "lines": ["では昨日の", "続き"]}, {"box": [64, 466, 148, 588], "vertical": true, "font_size": 19.0, "lines": ["インダクション", "モード", "始めるわよ"]}, {"box": [361, 591, 418, 698], "vertical": true, "font_size": 22.0, "lines": ["全部頭に", "入ってるわね"]}, {"box": [60, 645, 85, 688], "vertical": true, "font_size": 25.0, "lines": ["はい"]}], "img_path": "EVA2-029.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [], "img_path": "EVA2-030.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [570, 38, 669, 132], "vertical": true, "font_size": 22.0, "lines": ["おちついて", "目標を", "センターに", "入れて！"]}, {"box": [350, 38, 397, 147], "vertical": true, "font_size": 22.0, "lines": ["．．．にしても", "シンジ君"]}, {"box": [74, 106, 125, 246], "vertical": true, "font_size": 18.0, "lines": ["よくまた乗る気に", "なってくれたわね"]}, {"box": [347, 315, 394, 386], "vertical": true, "font_size": 21.0, "lines": ["そうなの", "よね"]}, {"box": [426, 434, 483, 508], "vertical": true, "font_size": 26.0, "lines": ["次いくわ", "よ！"]}, {"box": [258, 381, 358, 506], "vertical": true, "font_size": 21.0, "lines": ["あたしも泣いて", "逃げ出すんじゃ", "ないかと思って", "たんだけど"]}, {"box": [510, 568, 663, 733], "vertical": true, "font_size": 22.0, "lines": ["こっちにきて", "１週間になるけどさ", "シンジ君の", "伯父さんたちから", "ぜんぜん連絡ないの", "よねー"]}, {"box": [55, 568, 104, 657], "vertical": true, "font_size": 22.0, "lines": ["え？", "なんの話？"]}, {"box": [603, 810, 652, 965], "vertical": true, "font_size": 21.0, "lines": ["１０年以上もめんどう", "みてたんならさ"]}, {"box": [482, 853, 585, 975], "vertical": true, "font_size": 21.0, "lines": ["心配して", "様子聞いて", "きてもよさそう", "じゃない？"]}, {"box": [448, 894, 465, 979], "vertical": true, "font_size": 21.0, "lines": ["ってことよ"]}, {"box": [10, 796, 83, 898], "vertical": true, "font_size": 19.0, "lines": ["そうね．．．．．．", "どういうこと", "かしら？"]}], "img_path": "EVA2-031.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [656, 55, 690, 121], "vertical": true, "font_size": 27.0, "lines": ["彼には"]}, {"box": [476, 285, 560, 432], "vertical": true, "font_size": 20.0, "lines": ["もうここにしか", "居場所がないの", "かもしれない"]}, {"box": [125, 301, 177, 389], "vertical": true, "font_size": 20.0, "lines": ["いつの頃", "からだろう"]}, {"box": [647, 530, 671, 637], "vertical": true, "font_size": 22.0, "lines": ["僕の心と体は"]}, {"box": [554, 622, 631, 780], "vertical": true, "font_size": 22.0, "lines": ["少しずつバラバラに", "なってきている", "ような気がする"]}], "img_path": "EVA2-032.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [562, 98, 641, 204], "vertical": true, "font_size": 20.0, "lines": ["悲しいことや", "つ