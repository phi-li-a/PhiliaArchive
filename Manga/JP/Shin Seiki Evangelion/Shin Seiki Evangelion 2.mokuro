s": ["シンジ君"]}, {"box": [594, 554, 680, 720], "vertical": true, "font_size": 22.0, "lines": ["あなたはもう", "ネルフの人間では", "ないのよ"]}, {"box": [561, 558, 679, 930], "vertical": true, "font_size": 32.0, "lines": ["あなたはもうあんフの人間ではないのよ今のあなには何も教えることはできないわ"]}, {"box": [557, 760, 650, 924], "vertical": true, "font_size": 24.0, "lines": ["今のあなたには", "何も教えることは", "できないわ"]}, {"box": [122, 857, 209, 981], "vertical": true, "font_size": 23.0, "lines": ["それがたとえ", "些細な", "ことでもね"]}], "img_path": "EVA2-144.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [617, 47, 680, 147], "vertical": true, "font_size": 32.0, "lines": ["悪く", "思わないで"]}, {"box": [316, 67, 362, 142], "vertical": true, "font_size": 20.0, "lines": ["そういう", "規則なの"]}, {"box": [618, 287, 668, 345], "vertical": true, "font_size": 23.0, "lines": ["さよう", "なら"]}], "img_path": "EVA2-145.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [323, 264, 354, 317], "vertical": true, "font_size": 24.0, "lines": ["仕事．．．"]}, {"box": [87, 259, 175, 356], "vertical": true, "font_size": 23.0, "lines": ["やっぱ", "行かなきゃ", "ね"]}, {"box": [71, 300, 123, 381], "vertical": false, "font_size": 19.0, "lines": ["それですから"]}, {"box": [358, 601, 434, 673], "vertical": true, "font_size": 22.0, "lines": ["あれで", "よかった", "のよね"]}, {"box": [273, 601, 321, 674], "vertical": true, "font_size": 22.0, "lines": ["あのコに", "とって"]}, {"box": [89, 607, 187, 695], "vertical": true, "font_size": 21.0, "lines": ["エヴァに", "乗るのが", "苦痛でしか", "ないのなら"]}], "img_path": "EVA2-146.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [596, 54, 676, 130], "vertical": true, "font_size": 27.0, "lines": ["じゃ．．．", "行って", "来るわね"]}, {"box": [600, 316, 626, 381], "vertical": true, "font_size": 26.0, "lines": ["はい？"]}, {"box": [421, 887, 444, 959], "vertical": true, "font_size": 23.0, "lines": ["あ．．．"]}], "img_path": "EVA2-147.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [658, 53, 681, 111], "vertical": true, "font_size": 23.0, "lines": ["あの．．．"]}, {"box": [411, 69, 516, 177], "vertical": true, "font_size": 23.0, "lines": ["碇君と", "同じクラスの", "相田と鈴原と", "申します"]}, {"box": [274, 67, 375, 228], "vertical": true, "font_size": 22.0, "lines": ["あ", "初号機の", "エントリーブラグに", "入った２人？"]}, {"box": [197, 61, 223, 168], "vertical": true, "font_size": 23.0, "lines": ["ははいっ"]}, {"box": [76, 76, 162, 241], "vertical": true, "font_size": 23.0, "lines": ["その節はまことに", "ご迷惑をおかけ", "しましたっ"]}, {"box": [588, 291, 687, 375], "vertical": true, "font_size": 21.0, "lines": ["碇のヤツ", "こんな美人の", "上司と", "住んどったん", "か～～っ"]}, {"box": [406, 290, 481, 387], "vertical": true, "font_size": 18.0, "lines": ["ああ～～オレも．．．", "一度でいいから", "こんな人に", "命令されたい"]}, {"box": [675, 603, 700, 646], "vertical": true, "font_size": 25.0, "lines": ["あの"]}, {"box": [390, 610, 520, 769], "vertical": true, "font_size": 19.0, "lines": ["碇君があれから", "ずっと休んで", "らっしゃるので", "気になって見によら", "してもろたんですが、"]}], "img_path": "EVA2-148.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [537, 83, 610, 207], "vertical": true, "font_size": 32.0, "lines": ["えっ"]}, {"box": [574, 327, 675, 435], "vertical": true, "font_size": 24.0, "lines": ["学校には", "連絡が", "遅れちゃった", "けど．．．"]}, {"box": [491, 389, 574, 499], "vertical": true, "font_size": 24.0, "lines": ["今頃列車に", "乗る頃だと", "思うわ"]}, {"box": [389, 332, 476, 476], "vertical": true, "font_size": 26.0, "lines": ["ななな", "なんでですかァ", "急にィ"]}, {"box": [175, 323, 368, 428], "vertical": true, "font_size": 21.0, "lines": ["ひょっとして", "クビです", "か？"]}, {"box": [172, 328, 246, 415], "vertical": true, "font_size": 21.0, "lines": ["このあいだ", "命令無視", "してたし"]}, {"box": [290, 611, 361, 700], "vertical": true, "font_size": 19.0, "lines": ["そういう", "ワケじゃ", "ないけど．．"]}, {"box": [579, 804, 677, 956], "vertical": true, "font_size": 19.0, "lines": ["じゃあもう", "エヴァンゲリオンに", "乗るのがイヤに", "なってとか．．．"]}, {"box": [154, 799, 228, 904], "vertical": true, "font_size": 21.0, "lines": ["ヘンだった", "もんな", "このあいだ．．．"]}, {"box": [50, 846, 124, 982], "vertical": true, "font_size": 21.0, "lines": ["昨日会った時は", "そうでもなかった", "けど．．．"]}], "img_path": "EVA2-149.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [643, 74, 676, 160], "vertical": true, "font_size": 25.0, "lines": ["戦闘の時"]}, {"box": [455, 60, 519, 147], "vertical": true, "font_size": 27.0, "lines": ["普通じゃ", "なかった"]}, {"box": [394, 62, 417, 127], "vertical": true, "font_size": 23.0, "lines": ["えっ？"]}, {"box": [519, 398, 682, 540], "vertical": true, "font_size": 18.0, "lines": ["学校じゃいつも", "トウジにからまれ", "たりとかしても", "かおー", "顔色ひとつ", "変えないヤツ", "なのに"]}, {"box": [246, 382, 303, 446], "vertical": true, "font_size": 24.0, "lines": ["なんて", "ゆーか"]}, {"box": [466, 633, 514, 756], "vertical": true, "font_size": 21.0, "lines": ["感情ムキ出しに", "しちゃって"]}, {"box": [364, 686, 439, 825], "vertical": true, "font_size": 21.0, "lines": ["葛城さんにも", "ワザと逆らってる", "みたいだったし"]}], "img_path": "EVA2-150.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [58, 70, 217, 177], "vertical": true, "font_size": 25.0, "lines": ["母ちゃんに", "反抗してる", "だだっ子", "みたいって", "ゆーか"]}, {"box": [498, 485, 691, 701], "vertical": true, "font_size": 25.0, "lines": ["あはははほは", "なんや～あいつ", "エラそうに", "しとっても", "美人には", "弱いんやな"]}, {"box": [363, 750, 435, 807], "vertical": true, "font_size": 26.0, "lines": ["ミサト", "さんに", "とって"]}, {"box": [95, 869, 123, 941], "vertical": true, "font_size": 22.0, "lines": ["僕は．．．"]}], "img_path": "EVA2-151.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [641, 79, 674, 187], "vertical": true, "font_size": 25.0, "lines": ["シンジ君．．．"]}, {"box": [456, 305, 482, 358], "vertical": true, "font_size": 24.0, "lines": ["え？"]}, {"box": [617, 508, 678, 635], "vertical": true, "font_size": 23.0, "lines": ["カ", "かつらぎ", "葛城さん？"]}, {"box": [257, 517, 297, 612], "vertical": true, "font_size": 29.0, "lines": ["見送りっ"]}, {"box": [72, 540, 173, 641], "vertical": true, "font_size": 27.0, "lines": ["まだ", "間に合う", "わ！！"]}, {"box": [308, 824, 408, 949], "vertical": true, "font_size": 29.0, "lines": ["どうしたん", "すか", "急にィ～～"]}], "img_path": "EVA2-152.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [613, 424, 683, 516], "vertical": true, "font_size": 32.0, "lines": ["葛城", "さ～～～ん"]}, {"box": [344, 600, 417, 736], "vertical": true, "font_size": 20.0, "lines": ["ひとりで", "行かんといて", "くださいよ～～っ"]}, {"box": [148, 757, 222, 877], "vertical": true, "font_size": 20.0, "lines": ["間もなく", "２番線に列車が", "参ります"]}, {"box": [53, 816, 128, 953], "vertical": true, "font_size": 20.0, "lines": ["ご乗車の方は", "白線まで下がって", "お待ちください"]}], "img_path": "EVA2-153.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [], "img_path": "EVA2-154.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [612, 49, 634, 159], "vertical": true, "font_size": 21.0, "lines": ["どうした？"]}, {"box": [105, 166, 170, 252], "vertical": true, "font_size": 25.0, "lines": ["早く", "乗るんだ"]}, {"box": [619, 388, 651, 440], "vertical": true, "font_size": 32.0, "lines": ["おい"]}], "img_path": "EVA2-155.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [87, 654, 111, 797], "vertical": true, "font_size": 21.0, "lines": ["ミサトさん．．．"]}], "img_path": "EVA2-156.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [651, 73, 669, 158], "vertical": true, "font_size": 21.0, "lines": ["あなたたち"]}, {"box": [575, 105, 624, 194], "vertical": true, "font_size": 21.0, "lines": ["悪いけど笑", "もう帰って"]}, {"box": [479, 383, 527, 456], "vertical": true, "font_size": 22.0, "lines": ["あとは", "私が．．．"]}, {"box": [371, 286, 436, 434], "vertical": true, "font_size": 24.0, "lines": ["言い忘れてた", "ことがあったわ"]}, {"box": [533, 685, 554, 786], "vertical": true, "font_size": 21.0, "lines": ["ペンペン．．．"]}, {"box": [467, 689, 490, 738], "vertical": true, "font_size": 23.0, "lines": ["え？"]}], "img_path": "EVA2-157.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [664, 57, 686, 129], "vertical": true, "font_size": 21.0, "lines": ["この子ネ"]}, {"box": [571, 122, 643, 264], "vertical": true, "font_size": 21.0, "lines": ["私が前働いてたじゃない", "トコで実験に使わ", "れててネ"]}, {"box": [103, 87, 209, 246], "vertical": true, "font_size": 20.0, "lines": ["用済みになって", "処分される寸前", "だったのを", "あたしがもらったの"]}, {"box": [553, 347, 676, 466], "vertical": true, "font_size": 21.0, "lines": ["こんな役にも", "たたない", "大喰らいの鳥"]}, {"box": [490, 373, 563, 481], "vertical": true, "font_size": 19.0, "lines": ["なぜあたしが", "引き取ったか", "わかる？"]}, {"box": [404, 370, 449, 476], "vertical": true, "font_size": 19.0, "lines": ["かわいそう", "だったから．．．"]}, {"box": [349, 467, 394, 537], "vertical": true, "font_size": 19.0, "lines": ["それも", "あるけど"]}, {"box": [196, 416, 243, 539], "vertical": true, "font_size": 18.0, "lines": ["ずっとひとりで", "暮らしてたし"]}, {"box": [351, 681, 397, 752], "vertical": true, "font_size": 20.0, "lines": ["でも", "あたしは"]}, {"box": [108, 636, 191, 743], "vertical": true, "font_size": 22.0, "lines": ["仕事が終って", "夜遅く疲れて", "帰った時"]}, {"box": [131, 887, 215, 959], "vertical": true, "font_size": 24.0, "lines": ["出迎えて", "くれるだれ", "誰かが．．．"]}], "img_path": "EVA2-158.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [104, 102, 230, 207], "vertical": true, "font_size": 24.0, "lines": ["家族がいて", "くれれば", "いいなって", "思ったのよ"]}, {"box": [593, 524, 614, 595], "vertical": true, "font_size": 19.0, "lines": ["あたしは"]}, {"box": [162, 746, 266, 868], "vertical": true, "font_size": 22.0, "lines": ["同情やしてと", "仕事の上だけで", "他人と一緒に", "住めるような"]}, {"box": [73, 856, 145, 975], "vertical": true, "font_size": 22.0, "lines": ["ものごと", "割り切れる", "人間じゃないわ"]}], "img_path": "EVA2-159.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [598, 59, 666, 147], "vertical": true, "font_size": 32.0, "lines": ["誤解", "しないで"]}, {"box": [261, 355, 320, 421], "vertical": true, "font_size": 28.0, "lines": ["ミサト", "さん．．"]}, {"box": [280, 634, 294, 706], "vertical": true, "font_size": 14.0, "lines": ["．．．．．．"]}], "img_path": "EVA2-160.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [603, 51, 643, 108], "vertical": true, "font_size": 32.0, "lines": ["僕は"]}, {"box": [49, 239, 164, 338], "vertical": true, "font_size": 28.0, "lines": ["昔の所に", "帰りたく", "ないです"]}, {"box": [97, 804, 226, 968], "vertical": true, "font_size": 24.0, "lines": ["ー２番線", "厚木行き", "政府専用特別列車", "発車いたします"]}], "img_path": "EVA2-161.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [613, 38, 671, 148], "vertical": true, "font_size": 26.0, "lines": ["ドアが", "閉まります"]}, {"box": [294, 85, 321, 159], "vertical": true, "font_size": 27.0, "lines": ["あかん"]}, {"box": [98, 171, 161, 275], "vertical": true, "font_size": 22.0, "lines": ["間に合わん", "かったァ"]}], "img_path": "EVA2-162.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [646, 807, 667, 912], "vertical": true, "font_size": 21.0, "lines": ["あ．．．あいつら"]}, {"box": [553, 853, 628, 939], "vertical": true, "font_size": 21.0, "lines": ["なんちゅー", "ハレンチな", "ことを"]}, {"box": [109, 838, 148, 927], "vertical": true, "font_size": 32.0, "lines": ["．．．！！！．．．"]}], "img_path": "EVA2-163.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [596, 332, 664, 399], "vertical": true, "font_size": 25.0, "lines": ["帰ろう", "か．．．"]}, {"box": [641, 676, 656, 749], "vertical": true, "font_size": 15.0, "lines": ["．．．．．．？"]}, {"box": [97, 474, 180, 605], "vertical": true, "font_size": 32.0, "lines": ["あたし達の", "家へ"]}, {"box": [558, 977, 695, 996], "vertical": false, "font_size": 18.0, "lines": ["第３巻につづく／"]}, {"box": [147, 824, 183, 879], "vertical": true, "font_size": 32.0, "lines": ["はい"]}], "img_path": "EVA2-164.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [184, 119, 198, 337], "vertical": true, "font_size": 14.0, "lines": ["そういえば"]}, {"box": [530, 44, 545, 134], "vertical": true, "font_size": 15.0, "lines": ["．．．"]}, {"box": [571, 44, 582, 95], "vertical": true, "font_size": 12.0, "lines": ["．．．"]}, {"box": [121, 42, 230, 981], "vertical": true, "font_size": 20.333333333333332, "lines": ["．．．．．．－－－ストール．．．", "ＮＥＮ－－－：：：／．．．－－－・シーン．．ーーー．．．．．．", "ＧＮＡ．Ｉ．Ｉｎｔｅｒ．「．．．」・アーファン・－－－：：：＿＿－＿＿＿＠"]}, {"box": [305, 317, 319, 419], "vertical": true, "font_size": 14.0, "lines": ["そういえば、"]}, {"box": [278, 69, 320, 926], "vertical": true, "font_size": 16.5, "lines": ["そういえば", "ｓｋ．．．－．．ここでは、違う原因がン．．．ーー広ー．．．．．．"]}, {"box": [471, 43, 510, 589], "vertical": true, "font_size": 16.5, "lines": ["そういえば、", "この時期は、これからのここで「熱くーー」正し清"]}, {"box": [115, 689, 129, 838], "vertical": true, "font_size": 14.0, "lines": ["そういえば、"]}, {"box": [482, 581, 500, 977], "vertical": true, "font_size": 14.0, "lines": ["特に「ねん．．．」．．．．．．"]}], "img_path": "EVA2-165.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [461, 62, 486, 185], "vertical": true, "font_size": 25.0, "lines": ["従シンジ役"]}, {"box": [54, 59, 394, 370], "vertical": true, "font_size": 21.0, "lines": ["２人のシンジに", "心からの尊敬を込めて．．．", "今、１８話「命の選択を」の台本を読み", "終わったところです。", "全身が痛いです。喉元まで膨張したよ", "臓が、きゅ、っと鳴ります。", "『エヴァ」の合本に目を通した後は、だ", "いたいいつもこうです。", "しばらく何もする気になれなくなる。", "俺を感じ脱力感、空虚感．．．それから私の", "を包む周りの空気が、ゆっくりとＬＣＬ", "に変化しています。肺の奥まで血の匂い", "いに満たされてゆく。妙に温かくて、優"]}, {"box": [60, 386, 394, 689], "vertical": true, "font_size": 20.785714285714285, "lines": ["しくて、懐", "かしくて、", "切なくて、", "淋しくて、", "寂しくて．．．", "そして私", "は、ひざを", "かかえて、", "眠るのです。", "初めて彼と", "出会った時、", "なんて繊細", "な子なんだろうと思いました。主人公ら", "しくない、でもシングルで優しい顔立ち。"]}, {"box": [460, 828, 490, 999], "vertical": true, "font_size": 28.0, "lines": ["ＭＥＢＵＭＩＯＧＡＴＡ"]}, {"box": [61, 680, 108, 1000], "vertical": true, "font_size": 19.0, "lines": ["最初に貞本さんとお会いした瞬間、あまり", "「リにシンジとイメージが重なってビック"]}], "img_path": "EVA2-166.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [76, 55, 241, 349], "vertical": true, "font_size": 20.571428571428573, "lines": ["でも、お２人のそういう部分、そして", "天才的な創造力がこの作品を生み出して", "いるということは言うまでもありません。", "お２人の中に、キャラクターが、世界", "が、息づいている。", "この魅力あふれる？人の創造主を、私", "は心から尊敬しています。"]}, {"box": [241, 56, 266, 99], "vertical": false, "font_size": 32.0, "lines": ["ふふっでも、"]}, {"box": [265, 47, 650, 349], "vertical": true, "font_size": 20.0625, "lines": ["リしました。でも何となく嬉しくて、ク", "スリと笑ったら、「何が可笑しいの！」と", "不思議そうな顔されたの〈真本さん、鬼〉", "えてますか？♡。その表情がますます似て", "で、もっと嬉しくなってしまい、どうと", "う声をたてて笑ってしまった．．．！貞本さ", "んあの時は本当にシツレイシマシタ。", "庵野さんも、そう。カントクとお話しした", "ているとね、あの見正反対に見えるお", "ヒゲの風貌の影から、ひょこっとシンジ", "が顔を覗かせるのですよ。あれ、シンちゃ", "ゃん、どうしたのって触ろうとすると、", "すかさずミサトさんと入れ替わってしまう", "う。そして気がつくと、父さんになっちゃ", "やってるの。じーっと見てると、それは", "それは楽しいんだよ。おあなんて失礼な。"]}, {"box": [439, 375, 647, 674], "vertical": true, "font_size": 22.375, "lines": ["逃げろゃダメだ、逃げちゃ", "ダメだ、逃げちゃダメた．．．", "鏡の中に、シンジがいます。", "目を合わせるのが辛くて切なくて、思う", "わず下を向いてしまう。そして呟きます。", "「逃げちゃダメだ退けちゃタメだ、逃げて", "ちゃダメだ．．．！！」", "それからおもむろに、私はスタジオへ"]}, {"box": [80, 379, 434, 678], "vertical": true, "font_size": 20.06666666666667, "lines": ["と向かうのです。", "今日の仕事は、ラッシュフィルムや他", "の役者さん達のヒッティング・パートナ", "ーです。", "様々な角度や方向から次々と打ち込ま", "れるボールを、時に無防備に、時と完全に", "武装で、その時感じたまま、できるだけ", "素直に打ち返すことが私の役目です。", "惚れ惚れするほど緩意目在に球を操る", "先輩方や、クリティカルスマッシュを気に", "持ちよく打ち込んでくる後輩の球、そして", "て鮮やかな余韻を残しつつ切り込んでく", "るスタッフの皆さんの球、そのひとつひ", "とつがスペシャル級で、震えがくるほど", "素敵なのは、皆さんがよくご存知の通り"]}, {"box": [391, 703, 419, 755], "vertical": false, "font_size": 32.0, "lines": ["う思いなです。どうか"]}, {"box": [110, 790, 131, 995], "vertical": true, "font_size": 18.0, "lines": ["１９９５・１２・１３、自宅にて"]}, {"box": [155, 688, 393, 994], "vertical": true, "font_size": 19.1, "lines": ["どうかこの試合、最後まで見守ってい", "てください", "皆さんの応援の声が、私の支えです。", "そして、この世界を創りし２人のシン", "＞＞君と共に、皆さんの心の中にも必ず満", "んでいる「碇シンジ」の部分に触れる」", "とかできたら、とても幸せです。", "一緒に大きくなりましょうね。", "創造主さま、皆さん、どうぞこれから", "もよろしくお願いします。"]}, {"box": [418, 702, 654, 993], "vertical": true, "font_size": 20.3, "lines": ["ですよね。", "私はというと、みっともないくらい汗", "と涙とはな水にまみれつつ、ラケットに", "当てることで精一杯。でも、今この場所は", "に立たせていただけていることを本当に", "誇らしく、幸せに思います。", "現時点で、私は壁役。", "でもいつか、シンジと共に一流アレイ", "ヤーに育つことができたらいいなあ。そ", "う思いながら、今日もスタンオに通うの"]}], "img_path": "EVA2-167.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [477, 47, 513, 360], "vertical": true, "font_size": 31.0, "lines": ["第後、四、拾四使徒デザイン"]}, {"box": [494, 791, 525, 970], "vertical": true, "font_size": 28.0, "lines": ["１０ＳＨＴＯＯＡＳＡＲ"]}], "img_path": "EVA2-168.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [660, 38, 685, 230], "vertical": true, "font_size": 25.0, "lines": ["「いただきます」の"]}, {"box": [377, 37, 655, 335], "vertical": true, "font_size": 20.0, "lines": ["その前に", "これを書いている時点で、アニメ版の", "ほうは全話数の本分を消化し、物語はい", "よいよ佳城に突入しているわけだが、", "こまでのところ皆さんエヴァンゲリオン", "という作品の情報量の多さに対惑されて", "はいるまいか？", "マニアックなディテールに凝った設定", "を「スゴい」「さすが」ともてはやしたり、", "なかなか全貌の見えない、「裏」設定をチー", "マチマほじくったり．．．。"]}, {"box": [280, 38, 375, 336], "vertical": true, "font_size": 20.0, "lines": ["確かにそういう楽しみ方もあるだろう。", "しかし、それらは料理で言えば「盛り付け", "けーであり「語」にあたる部分だ。「きれ」", "いったとか「おいしそう」では、料理へ"]}, {"box": [546, 299, 565, 333], "vertical": true, "font_size": 20.0, "lines": ["．"]}, {"box": [281, 308, 663, 859], "vertical": true, "font_size": 20.0, "lines": ["の賛辞にはなっていないし、拒絶するに", "しても「見た目がくどい」とか「器に焼き", "り過ぎにでは料理の本質を見誤ることを", "だしい。", "エヴァンゲリオンは実にオーソドック", "スなドラマである。ミセフタもない表現", "を使えば「シンシ君の成長ドラマ」とく", "くることができる。なのに、なぜ皆さん", "普通の見方をしない！？", "９５〜９６年の今という現在、器と見てく", "れ以外のそろった「料理」はエヴァを除", "いては皆無に等しい。外面だけのサンプ", "ル食品に慣らされて、料理が食えるとい", "うことを忘れてしまっている皆さん。エ", "ヴァは食えます。眺めてないでロに入れ", "てみなさい。「食える」という「あたりま"]}, {"box": [280, 684, 666, 985], "vertical": true, "font_size": 21.0, "lines": ["えみ、その一点において、エヴァは今」", "空前にして絶後、作品なのです。こんな", "時代にこれを食える幸せを、かみしめな", "さい。", "しかし、ここで勘違いをしないように。", "ここまで書いたことは作品の評価とはま", "ったく別次元の話。私は「食える」と言う", "っただけで、味」の保証までしたわけで", "はない。もしも最終回まで口に入れてみ", "てまずかったときには、ちゃんと「まず", "い」と言いましょう。食ったあなたは", "言う権利がある。もちろん私も言うとさ", "ゃ言う。でも美味しかったときには．．．", "それ以上にきちんと「美味しかった！！」", "と言いましょうね。", "この先また、買い料理を食うために．．．"]}], "img_path": "EVA2-169.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [443, 42, 477, 380], "vertical": true, "font_size": 22.0, "lines": ["漫画「キャラクター・デザイン"]}, {"box": [54, 43, 435, 341], "vertical": true, "font_size": 22.0, "lines": ["今のところ思うこと、", "キャラクターを", "デザインするうえで．．．", "真本さんはアニメ版にもキャラクター・", "デザインで参加されてるわけですが、その", "れぞれのキャラクターをデザインされる", "にあたって留意した点などうかがいたい", "のですが。まずシンシ君については。", "ロボットものの主人公というと紹介演", "というイメージですけど、この作品の主", "人公は、ロボットに乗って最終的にヒー", "ローになりますが、熱血液ではないので、", "それ以外のヒーロー像ということで考え", "ました。屈折したヒーローというか、"]}, {"box": [559, 474, 735, 714], "vertical": false, "font_size": 32.0, "lines": ["義"]}, {"box": [55, 361, 390, 712], "vertical": true, "font_size": 20.0, "lines": ["キャラクターに転いた感じがありますね。", "現代っ子というか、どこかしらアニメ", "ファンを意識したようなキャラ像を作る", "うということで始めたんです。", "現代ふうというと自分は自分、他人にあ", "まり興味をもたないといったような？", "異味を持たないように心がけている人。", "本当に興味がないわけではなくて、自分の", "でわざと殻を作ってるような人ですね。", "繊細な感じですよね。", "シンシは、女性的というか清潔感を出", "したかったんですよ。何事にも冷めてて、", "やる気のない、自殺できないくせに自殺", "願望があるというか、どうでもいいじゃ"]}, {"box": [451, 744, 479, 977], "vertical": true, "font_size": 26.0, "lines": ["ＯＳＨＹＵＫ＇ＳＡＤＡＭＯＴＯ"]}, {"box": [34, 653, 391, 1034], "vertical": true, "font_size": 30.0, "lines": ["んっていうふうの軽い感じのするキャラ", "としてデザインしたつもりです。", "顔のモデルはいるのですか？", "特にはないんです。でも生若丸とか月", "本に古来からあるヒーロー像ってあります", "すよね、日本武尊とか、一寸法師とか。", "日本には昔から、ヒーロー像として熱血", "湊よりはそういった少し中性的なヒーロ", "［像がなんとなくあると思うんですよ。", "美少年とかね。髪の毛は最初、今のシン", "人公は、情緒シーンで演出的に目を隠し", "日本ではどういっちゃんでも良いからなくなると思うんですから今日もありませんのでしょうかった教師とか知ってるんだろうと思っているのかも知らない人気がいたらいないけどのようにしいとからしいうといと思いますようことかものです。", "たりとか髪なびいたりしなきゃいけな", "ので。でも、そうするとワイルドが感じた"]}], "img_path": "EVA2-170.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [59, 45, 703, 359], "vertical": true, "font_size": 20.85185185185185, "lines": ["になって、繊細な、触ったらこわれてし", "まいそうな感じが薄れてしまうんですよ", "ね。そういう汗を感じちゃうキャラクタ", "ーではなくて、髪の毛短くして、お客さん", "出して、ボーイッシュな女の子どいう感", "しにしたかったんです。具体的に言うと、", "目は女性的ということでナディア空下数", "きにした部分があります。ナデオフを男", "にしたような。男ナディアですよ。だが、", "ら、まつげを除け了髪型変えれば、まん", "まいっしょですからね。", "キャラクターを単純な好みでは描いてな", "いということですね。", "そうですね。わりと、まわりのロボッ", "トものへのアンチューゼという意味が大", "きかったですよね。天体星のモッシン", "長くて、やってやるばーノみたいな世界", "じゃないですか。横に、こうー、２年の", "ロボットものって。こういう屈折してる", "性的なキャラクターっていないんですよ。", "僕は、生の自分の感じで主人公を話せせ", "たかったので、自分の中のストイックな", "部分というのをまとめたようなキャラク", "ター・デザインにしたんです。", "まったくつき離して動かしてるというよ。", "リも自分を重ねて描いているということ", "ですか？"]}, {"box": [59, 373, 418, 670], "vertical": true, "font_size": 21.733333333333334, "lines": ["の時に委員長だったっていうのと、おお", "こぼれで悪いことばっかりしてた僕との", "違いなんだろうなって〈笑〉。", "ひねくれ方が微妙に違うんですが。", "庵野さんが考えてたひねくれた感じと", "いつのは、表面はいいかっこうして陰に", "入ってく内側向きのひねぐれさ加減で、", "ある意味、現代の若者的、僕のはその逆", "で、中にはすごくストイックでまじめな", "んだけど外にはひねくれてしまうという", "ちょっと子供っぽいタイプ。だからアニ", "メ版の脚本を僕の言葉として書けないん", "ですよ。僕のシンシはニュじゃないって", "思っちゃうから。結果的には、ここで反", "抗するとか、ここでミサトに対して言う"]}, {"box": [443, 373, 513, 641], "vertical": true, "font_size": 21.0, "lines": ["ったらおかしいけど、優等生活感と", "すよね。漫画のほうはなんかひねく。", "て、おらこぼれを感じするじゃない"]}, {"box": [349, 302, 659, 739], "vertical": false, "font_size": 32.0, "lines": ["．．．"]}, {"box": [586, 372, 703, 668], "vertical": true, "font_size": 21.2, "lines": ["アニメ版の主人公とほんの少し性格変", "わってくるっていうのはそういうことだ", "と思うんですよ。アニメはたぶん鹿野さん", "んが自分の言葉で脚本を書いてるからあ", "あなるわけで。僕は、魔野さんがおっしゃ"]}, {"box": [160, 952, 212, 983], "vertical": false, "font_size": 15.0, "lines": ["なか", "でも"]}, {"box": [32, 670, 658, 1030], "vertical": true, "font_size": 26.24, "lines": ["方が違うんです。", "レイちゃんについては。", "昔、僕がニュータイプで描いた鬼の話", "「孤島の鬼」があるんですけど、それに", "出てくるヴキナというキャラクターをい", "じって、シャギー入った、ウルフへア", "っぽいおかっぱがいいなと思って描いた", "のがレイなんです。ちょっといやった", "けで、目の描き方とか基本的にいろしょ", "ですね。レイは、影とかそういう空気感。", "で決めたようなキャラクターです。触る", "ここができない少女性というか、憧れる", "けど、縁がなくて触れない。", "ケンスをＩウジがレイに対して感じる", "ようなスタンスですか？", "もっと離れてますね。レイは『最初に", "包帯まいたパポジョンが浮かんだんです。", "筋肉少女帯の歌の中に「包帯で真っ白な", "少女」というのがあるんですけど、その", "曲を聴いた時のいたいけなイメージが", "のままレイになりました。『あ、こん", "のままレイになりました。あ、こんなにの子出したいって。何かのきたのですよね", "．．．というのをジンジよりも先に考えてし", "まって。目を赤々したのは、ヒロインの", "クレジットカードローンがなかったのかもしれないって、何でもこんなことがないということでしょうかないのかどういうのかと思うと思えます。このようなんだように思うでし"]}, {"box": [663, 697, 703, 986], "vertical": true, "font_size": 16.0, "lines": ["こときかないとか、やることは決まって", "るんだけど、それまでのアプローチの仕"]}], "img_path": "EVA2-171.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [51, 44, 696, 347], "vertical": true, "font_size": 21.23076923076923, "lines": ["ひとりであるにもかかわらず地味すぎる", "というのと、ゲームにした時、ドッキの", "色味でキャラクターがわかるようにとり", "うビジネス的なことからだったんですけ", "ど、結果的にすごくよかったと思います。", "無口で目線や表情でしか語らないから、", "視線が強い感じで印象的になりましたね。", "漫画版とアニメ版", "それぞれのエヴァ", "ストーリーについてですが、漫画版エア", "二人版ではこのような違いがあると思わ", "れますか？", "アニメ用に書かれた脚本を原作として", "描いてるわけですけども、今のところ、", "ほとんど同じだと思います。起業転稿を", "短く言葉で言ってそれを並べていくと同じ", "じ文章になると思いますよ。でも、アプリ", "ローチのしかたが違う。演出が違っって", "言ったほうがいいかもしれない。アニメ", "も絵コンテ書いてる人は何人かいるわけ", "ですよね。たとえば同じ脚本で副監督の", "観客さんが、コンテ書いたのと廃砂雪さんの", "が書いたのでは違う作品になるわけです", "よっ、そういう違いはあると思いますよ。", "ましてや、フォーマットの違う通国で", "アニメの脚本そのままというのはできな"]}, {"box": [54, 370, 697, 681], "vertical": true, "font_size": 20.925925925925927, "lines": ["いですよね。", "ですから僕の場合、脚本もだいぶ姿を", "ちゃいます。こっちのほうがわかりやす", "いだろうとか。ア二メ版のほうは、相当", "マニア向けになるだろうと思ってたので、", "個人的には、５歳くらいまで対象不動", "下げたかったんですよね。でもこの話", "難しすぎて下がらないんですよ。下げる", "それは、エヴァンゲリオンじゃなくな", "ってしまう。ならエヴァでやる意味がな", "いやすから、そもそも僕も企画段階から", "この作品に入ってて、やりたいのはテレ", "ビのああいうストーリーラインだったわ", "けですから。でもアニメ版よりは少ない", "情報量でわかりやすくしようとか、主人", "父の心の流れだけにスポット当てて、その", "れを軸にエヴァの世界観念体を見たらと", "んな世界に見えるのかというのはわかり", "てます。アニメは、わりと神の視点から見", "てると思うんです。シンジ以外のところ", "にもスポット当てて、全体で見せていく", "という。それに対し、漫画どいうのは基本", "本的にひとりで描くものなので、内容的に", "にダイジェストにならざるをえないんで", "す。アニメは半年で終わりますが、漫画で", "同じことを短めに描いたとしても何年も", "かかってしまう。だからといって単純に"]}, {"box": [57, 699, 438, 991], "vertical": true, "font_size": 20.5, "lines": ["確かに、同じ物語を通り視点で見てる感", "しかしますね。アニメではわからないが、", "シン君の心情などが、漫画では、こんな", "こと考えていたのか、と。", "それも僕が勝手に思いこんでるだけで", "たぶん監督から見たら違うかもしれない", "ですよね。でも、そうでないと描けない", "ですよ。他人が考えてることを自分の感じ", "情では描けないっていう僕の欠点なんて", "すけど。だから、アニメ第１話でドラマを", "進める上でかなり重要なシンジのセリフ", "があるんですけど、僕は漫画には書きた", "くなかったんです。だから漫画ではわざ", "とそのセリフをはずしたんですけど。僕", "の中のシンジのセリフは、できるだけ", "分の生の感覚で書くようにしてるんです。"]}, {"box": [438, 699, 699, 989], "vertical": true, "font_size": 20.0, "lines": ["ダイジェストにしたら薄くなるわけです", "から、その分何を足すかといったらお", "ポットの当て方が違うとかる人ながらす", "た感情の流れをもうちょっどわかりやす", "くそいねいに描くとか、何か違うことした", "ないと薄くなった分を構築できないって", "いつかね。そうすると同じストーリーで", "も違った作品になると思うんです。ま、", "音楽や声優さんの声がない漫画なわけで", "すから本来、会派遣うものだとは思います。", "すけどね。"]}], "img_path": "EVA2-172.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [209, 360, 279, 374], "vertical": false, "font_size": 14.0, "lines": ["Ｋｅｄｏｋｅに"]}, {"box": [171, 472, 280, 499], "vertical": false, "font_size": 25.0, "lines": ["貞本義行"]}, {"box": [196, 424, 397, 466], "vertical": false, "font_size": 18.0, "lines": ["新世紀エヴァンゲリオンの", "酒漫"]}, {"box": [281, 474, 426, 498], "vertical": false, "font_size": 22.0, "lines": ["「ＧＡＩＮＡＸ"]}, {"box": [227, 513, 381, 545], "vertical": false, "font_size": 14.0, "lines": ["１５８５年３月１２日初版発行", "１９３０年３月１０日第１７期発行"]}, {"box": [265, 580, 331, 604], "vertical": false, "font_size": 22.0, "lines": ["角川歴藤"]}, {"box": [267, 637, 333, 656], "vertical": false, "font_size": 19.0, "lines": ["角川貴店"]}, {"box": [168, 661, 421, 677], "vertical": false, "font_size": 15.0, "lines": ["●１０２－８１７７東京都千代田区富士見２－１３－３"]}, {"box": [119, 678, 464, 693], "vertical": false, "font_size": 14.0, "lines": ["電話／東京（ＣＳ）２２３－６２２２５－２５：０５：「教授」（２０１３）２２２９９４年５月に開催"]}, {"box": [216, 694, 385, 710], "vertical": false, "font_size": 15.0, "lines": ["複雑な度ノＯｆｉｃＯ＋９－０５２０"]}, {"box": [191, 734, 373, 803], "vertical": false, "font_size": 17.333333333333332, "lines": ["鹿住忠広＋ＢＥ－ＨＴＯ", "印刷", "共同印刷"]}, {"box": [145, 808, 459, 826], "vertical": false, "font_size": 17.0, "lines": ["初出「月刊少年エース」３５年５月号〜９６年２月号まで"]}, {"box": [196, 865, 402, 875], "vertical": false, "font_size": 12.0, "lines": ["送料は小社負担でお取り替えいたします。"]}, {"box": [341, 784, 411, 802], "vertical": false, "font_size": 18.0, "lines": ["大谷製本"]}, {"box": [146, 885, 461, 901], "vertical": false, "font_size": 15.0, "lines": ["１９９６．ＫＡＤＯＫＡＷＡ、ＳＨＯＴＥＮ，Ｐｒｉｎｄｅｄｉｎ，ＪＡＰＡＮ"]}, {"box": [193, 831, 496, 860], "vertical": false, "font_size": 13.5, "lines": ["本書の無断複写・複製・転職を探します。落丁目丁本は、", "ご面倒でも小社営業部サービスセンター家にお送りください。"]}, {"box": [245, 910, 359, 924], "vertical": false, "font_size": 14.0, "lines": ["ＧｅＡＮＡＸ１９９６"]}, {"box": [216, 935, 387, 950], "vertical": false, "font_size": 14.0, "lines": ["２日Ｎ４－０４－７７５に２４００８／"]}], "img_path": "EVA2-173.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [462, 35, 585, 52], "vertical": false, "font_size": 17.0, "lines": ["絶賛発売中川"]}, {"box": [224, 40, 394, 60], "vertical": false, "font_size": 13.0, "lines": ["そのようにロードを．．．"]}, {"box": [172, 161, 217, 364], "vertical": true, "font_size": 32.0, "lines": ["マリンカラー"]}, {"box": [628, 142, 692, 509], "vertical": true, "font_size": 32.0, "lines": ["ザ・キング・オブラァイターズ！！"]}, {"box": [561, 146, 609, 505], "vertical": true, "font_size": 32.0, "lines": ["新世紀エヴァンゲリオン"]}, {"box": [405, 146, 532, 486], "vertical": true, "font_size": 32.0, "lines": ["Ｂ：Ｘビート・エックス", "マクロスプトラッシュ"]}, {"box": [323, 150, 377, 507], "vertical": true, "font_size": 32.0, "lines": ["機動戦士クロスボーンガンダム"]}, {"box": [250, 161, 296, 493], "vertical": true, "font_size": 32.0, "lines": ["天空のエスカフローネ"]}, {"box": [95, 158, 142, 509], "vertical": true, "font_size": 32.0, "lines": ["ぷりんせすＡ、ＧＯ／ピロ／"]}, {"box": [638, 571, 702, 734], "vertical": true, "font_size": 17.0, "lines": ["ＯＮＫの超人気ゲームをコ", "ミック化。Ｋ・ロ・Ｆを制", "するのはどのチームなのか"]}, {"box": [559, 573, 624, 735], "vertical": true, "font_size": 18.0, "lines": ["恐るべき〝使徒〟の攻撃か", "ら人類を守れノ汎用人型決", "戦兵器〝エヴァ〟登場！！"]}, {"box": [481, 574, 547, 747], "vertical": true, "font_size": 16.0, "lines": ["巨大な組織にたったひとり", "で戦いを挑む少年・鉄兵と", "相棒・エックスの大活躍／"]}, {"box": [403, 574, 468, 743], "vertical": true, "font_size": 17.0, "lines": ["西暦２０４６年。黒い爆撃", "機械の異名を取るシバ・御堂", "と彼をとりまく人々の物語"]}, {"box": [327, 564, 391, 741], "vertical": true, "font_size": 16.0, "lines": ["木星帝国の陰謀と戦うクロ", "スポーン・パンガードの活", "躍を描いたガンダム正伝／"]}, {"box": [247, 571, 314, 743], "vertical": true, "font_size": 18.0, "lines": ["地球から来た星野ひとみと", "共に守護神エスカフローネ", "を駆り、悪と戦うバァン！！"]}, {"box": [170, 575, 235, 746], "vertical": true, "font_size": 17.0, "lines": ["海が大好きな青年ススムと", "お茶目な人魚パレッティの", "恋を描いたファンタジー！"]}, {"box": [93, 572, 157, 743], "vertical": true, "font_size": 17.0, "lines": ["魔界のプリンセス・メイミ", "が仲間の協力を得て人間界", "を守るために立ち上がる！！"]}, {"box": [563, 759, 702, 952], "vertical": true, "font_size": 32.0, "lines": ["真行寺たつや", "貞本義行"]}, {"box": [407, 761, 551, 956], "vertical": true, "font_size": 32.0, "lines": ["車田正美", "美樹本晴彦"]}, {"box": [333, 764, 394, 941], "vertical": true, "font_size": 32.0, "lines": ["『富野由悠季", "置長谷川裕"]}, {"box": [253, 763, 316, 937], "vertical": true, "font_size": 32.0, "lines": ["克・亜樹"]}, {"box": [100, 770, 232, 964], "vertical": true, "font_size": 32.0, "lines": ["０ＵＥＮＥＮ", "内野文吾"]}], "img_path": "EVA2-174.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [446, 34, 566, 51], "vertical": false, "font_size": 17.0, "lines": ["絶賛発売中川"]}, {"box": [615, 73, 666, 365], "vertical": true, "font_size": 32.0, "lines": ["ヱデンズボゥ・"]}, {"box": [542, 154, 581, 343], "vertical": true, "font_size": 32.0, "lines": ["オンセンマン"]}, {"box": [214, 35, 383, 54], "vertical": false, "font_size": 21.0, "lines": ["ＫｅｄｏｋｏｗｅＣｏｎｋｓＡ"]}, {"box": [230, 153, 269, 326], "vertical": true, "font_size": 32.0, "lines": ["ガルダイヤ"]}, {"box": [305, 151, 507, 446], "vertical": true, "font_size": 32.0, "lines": ["ブリザードＹｕＫ－", "グルマンくん", "ビンパツ一番"]}, {"box": [152, 147, 191, 510], "vertical": true, "font_size": 32.0, "lines": ["光の剣間の刃。そんバートオランセイニー"]}, {"box": [71, 146, 118, 500], "vertical": true, "font_size": 32.0, "lines": ["機動戦士Ｖガンダム外伝"]}, {"box": [608, 566, 673, 734], "vertical": true, "font_size": 15.0, "lines": ["「神殺し」の業を持つ少年・", "ヨルンと謎の美少女はエデ", "ソ「天上都市」を目指す／"]}, {"box": [531, 571, 597, 734], "vertical": true, "font_size": 16.0, "lines": ["疲れきった都会の人々を救", "うため二百年に一度温泉卵", "から生まれた伝説の勇者！！"]}, {"box": [453, 572, 518, 735], "vertical": true, "font_size": 15.0, "lines": ["投げる〃叩く〃飛ぶ〃女子", "プロレスの頂点を目指し戦", "い続けるプリザードユキ！！"]}, {"box": [375, 572, 440, 735], "vertical": true, "font_size": 18.0, "lines": ["天才グルメ小学生・食井力", "ソロが真のおいしさを追求", "するお子様グルメバトル！！"]}, {"box": [298, 572, 362, 737], "vertical": true, "font_size": 16.0, "lines": ["発明少年の愛沢一番は、ど", "んな難題も得意のビンバツ", "でドカンと一発、解決だ！！"]}, {"box": [221, 572, 284, 735], "vertical": true, "font_size": 15.0, "lines": ["伝説の秘宝ガルダイヤを捜", "せ／大海賊の孫娘ココン元", "海賊バガドの大冒険は続く"]}, {"box": [144, 573, 205, 735], "vertical": true, "font_size": 16.0, "lines": ["＠スーパーファミコンで通", "載され人気を博したＨＰＩＧ", "マンガが単行本化！！"]}, {"box": [66, 556, 128, 734], "vertical": true, "font_size": 17.0, "lines": ["「外伝・脱出計画編」と「逆に", "一重のギガンティス」が一冊", "になったシリーズ外伝！！"]}, {"box": [612, 762, 670, 956], "vertical": true, "font_size": 32.0, "lines": ["天王寺きつね"]}, {"box": [531, 762, 593, 954], "vertical": true, "font_size": 32.0, "lines": ["島本和彦"]}, {"box": [456, 758, 525, 886], "vertical": true, "font_size": 32.0, "lines": ["栗吉岡", "盪安西"]}, {"box": [384, 764, 434, 948], "vertical": true, "font_size": 32.0, "lines": ["ゆでたまご"]}, {"box": [304, 761, 359, 951], "vertical": true, "font_size": 32.0, "lines": ["さとうげん"]}, {"box": [229, 771, 280, 861], "vertical": false, "font_size": 32.0, "lines": ["山崎"]}, {"box": [142, 756, 207, 944], "vertical": true, "font_size": 32.0, "lines": ["武林武士"]}, {"box": [65, 747, 146, 948], "vertical": true, "font_size": 32.0, "lines": ["『矢立肇霊野由悠季", "轟長谷川裕"]}], "img_path": "EVA2-175.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [0, 11, 326, 313], "vertical": false, "font_size": 32.0, "lines": ["第二条第項サイコ", "世界的な", "マクロストラッシュ、", "実際大事は１１", "．．．", "続きはうます。"]}, {"box": [67, 281, 259, 395], "vertical": false, "font_size": 19.0, "lines": ["ユランスポウィ", "天王寺さっ。", "最後はキクロスボーンが", "福野田区発出長合川は", "マリンカラ・"]}, {"box": [71, 398, 160, 412], "vertical": false, "font_size": 14.0, "lines": ["ＳＵＥＺＥＮ"]}, {"box": [68, 409, 280, 506], "vertical": false, "font_size": 25.25, "lines": ["あさめよ／はにわ先生", "佐藤よしいろ", "これは", "武林武士"]}, {"box": [431, 450, 676, 490], "vertical": false, "font_size": 32.0, "lines": ["新世紀エヴァンゲリオ"]}, {"box": [425, 573, 723, 655], "vertical": false, "font_size": 29.0, "lines": ["ラムネと４０戦", "あかほりきと", "吉崎観音"]}, {"box": [178, 728, 356, 887], "vertical": false, "font_size": 32.0, "lines": ["そう"]}], "img_path": "EVA2-176.jpg"}, {"version": "0.1.6", "img_width": 2582, "img_height": 1081, "blocks": [{"box": [516, 88, 1145, 287], "vertical": false, "font_size": 32.0, "lines": ["そういうわけじゃないですよ。"]}, {"box": [1019, 318, 1208, 387], "vertical": false, "font_size": 30.0, "lines": ["Ｖｏｌｕｍｅ", "ナイフと少年"]}, {"box": [155, 354, 408, 738], "vertical": false, "font_size": 26.0, "lines": ["貞本義行", "地味わかドエヴァ！のキャラデザヘートウォームが", "地味的かエリアのキャフチッインコンセプトでしたが、ブラグス．．．", "インコミュニケーションは新手で、恥ずかしいポディベへ", "ニッは卵子に、恥ずかしいハナイヘインティングって感じで、とても考えてるのは", "インフィングと激しく、とても一番で流行のコスプレ・マニアには見向きもやれないと思ってました。", "で流行りのムスレ．．．ーノには見回させされないと思ってました。ところでここにいた", "でもこれはいくと思ってました。と、ろが、コミケに、ワンフェスに、もっきです。なんややかな", "ろが、コミット、ソンシュムに、たそうです。なりきり少年少女達が「ゴード」のインドは", "たそうです。なりさッジ半少量が．．．。人ゴミ嫌いの私には、縁のないコーナーが", "．．．。入口に嫌いの体には、胸のコスプレワールドではありますが、男性ホールームページですよね", "コスンレン．．．ここで思わず「現たい」と心の中でさけん", "でしまいました。", "でしまいました。．．．青いかつらに白いブラグスーツ．．．", "．．．青いかつらに白いん〜〜、見だい！。"]}, {"box": [24, 982, 270, 1045], "vertical": false, "font_size": 26.0, "lines": ["カバー印刷ノ共同印刷装順ノ題住忠広", "カハーロルノ共同表情ノ鹿住忠広初出ノ目利以年も", "救鳩ノ鹿住忠広初比ノ月刊少年エース５年０月号"]}, {"box": [514, 944, 567, 972], "vertical": false, "font_size": 30.0, "lines": ["漫画"]}, {"box": [516, 1010, 668, 1040], "vertical": false, "font_size": 25.0, "lines": ["原作，ＧＡＩＮＡ"]}, {"box": [584, 987, 711, 1012], "vertical": false, "font_size": 25.0, "lines": ["このサイトでは"]}, {"box": [1248, 719, 1318, 1018], "vertical": true, "font_size": 30.0, "lines": ["『貞本義行", "原作ＧＡＩＮＡＸ"]}, {"box": [1656, 108, 1810, 133], "vertical": false, "font_size": 25.0, "lines": ["ｃＯ９７９．¥５４０Ｅ"]}, {"box": [1651, 59, 1908, 90], "vertical": false, "font_size": 28.0, "lines": ["ＩＳＢＮ４－Ｏ４－７１３１３２－６"]}, {"box": [1650, 172, 1938, 206], "vertical": false, "font_size": 27.0, "lines": ["定価：本体５４０円税別角川書店"]}, {"box": [2158, 151, 2526, 189], "vertical": false, "font_size": 32.0, "lines": ["ＫａｄａｋａｗｉｅＣｏｎｉｃｓ"]}, {"box": [2187, 207, 2480, 273], "vertical": false, "font_size": 28.0, "lines": ["ＢＥＳＴ", "ＳＥＬＥＣＴＩＯＮ"]}, {"box": [2162, 298, 2538, 715], "vertical": false, "font_size": 27.0, "lines": ["遊撃宇宙戦艦ナデシコ全４巻", "麻宮騎亜", "サイレントメビウスＯ－９", "麻宮騎亜", "ブレンバワード１－３", "マーケーキーを始めさる十富野田悠季．．．", "マ．．．南屋良樹", "強殖装甲ガイバー１．５", "天王寺きつね", "エデンズボゥイ！？", "男の一枚レッド・カード金４巻へー。島本和彦", "バーコレイション－Ｐａｒｄｏｒｄａｔｉｏｎに全国巻一部ＵＥＺＥＮ", "超酸素ダンクープロしていたので、超酸菌やサービスの", "あーー長谷川裕ー", "姫川明", "時空転妙ナスカ全２巻", "．．．こんなのは、ロース機能・英雄的にホートよーしよーっ！！！", "お客様の特徴的なコーストロール・出張ディ大変おサービス・パーソファイル・", "うわあああっ！！これで．．．ガサラキート３一人にはいけないですか？", "ビート・エックストＩＢ－", "車田正美", "リング２", "一鈴木光司＋ＭＥＭＵ"]}, {"box": [2324, 733, 2359, 1005], "vertical": true, "font_size": 32.0, "lines": ["大好評発売中"]}], "img_path": "cover.jpg"}, {"version": "0.1.6", "img_width": 1560, "img_height": 1062, "blocks": [{"box": [237, 285, 481, 315], "vertical": false, "font_size": 21.0, "lines": ["ＫｏｄｏｌｅＷｉｎｄ．ｃｏｍｉｃｅ＿"]}, {"box": [113, 365, 579, 566], "vertical": false, "font_size": 32.0, "lines": ["新世紀", "シゲリオン", "エヴァン", "貞本義行"]}, {"box": [748, 167, 804, 377], "vertical": true, "font_size": 32.0, "lines": ["新造エヴァ"]}, {"box": [284, 546, 434, 575], "vertical": false, "font_size": 23.0, "lines": ["原作ＧＡＮＡＸ"]}, {"box": [249, 629, 484, 659], "vertical": false, "font_size": 22.0, "lines": ["ＹｏｓｈｕｒｕＨ（ＳＡＤＡＮＯＴＯ"]}, {"box": [738, 691, 808, 947], "vertical": true, "font_size": 29.0, "lines": ["貞本義", "原作ＧＡＩＮＡＸ"]}, {"box": [745, 993, 810, 1013], "vertical": false, "font_size": 22.0, "lines": ["ＫＣＡＩ２．２"]}], "img_path": "inner_cover.jpg"}]}