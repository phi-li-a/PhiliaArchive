0], "vertical": true, "font_size": 29.0, "lines": ["了解！"]}, {"box": [546, 716, 609, 860], "vertical": true, "font_size": 29.0, "lines": ["エントリー", "プラグ挿入！！"]}], "img_path": "EVA1-079.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [596, 79, 679, 221], "vertical": true, "font_size": 30.0, "lines": ["プラグ固定", "終了！！"]}, {"box": [70, 79, 155, 227], "vertical": true, "font_size": 32.0, "lines": ["第一次接続", "開始！！"]}, {"box": [552, 324, 619, 471], "vertical": true, "font_size": 30.0, "lines": ["エントリー", "プラグ注水ノ"]}, {"box": [471, 723, 496, 795], "vertical": true, "font_size": 23.0, "lines": ["うわっ"]}, {"box": [374, 726, 402, 777], "vertical": true, "font_size": 28.0, "lines": ["なっ"]}, {"box": [75, 601, 111, 673], "vertical": true, "font_size": 32.0, "lines": ["．．．．．．？？"]}, {"box": [59, 855, 124, 982], "vertical": true, "font_size": 26.0, "lines": ["なんなんだ", "これ！？"]}], "img_path": "EVA1-080.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [633, 66, 664, 188], "vertical": true, "font_size": 21.0, "lines": ["心配しないで"]}, {"box": [70, 87, 194, 230], "vertical": true, "font_size": 22.0, "lines": ["肺がＬＣＬで", "満たされれば", "直接酸素を取り", "込んでくれます"]}, {"box": [637, 328, 682, 438], "vertical": true, "font_size": 32.0, "lines": ["ふっ"]}, {"box": [370, 338, 394, 487], "vertical": true, "font_size": 22.0, "lines": ["我慢しなさい！"]}, {"box": [331, 375, 355, 500], "vertical": true, "font_size": 22.0, "lines": ["すぐ慣れるわ"]}, {"box": [443, 642, 488, 751], "vertical": true, "font_size": 32.0, "lines": ["うわっ"]}, {"box": [635, 772, 658, 842], "vertical": true, "font_size": 23.0, "lines": ["くそっ"]}, {"box": [89, 796, 181, 942], "vertical": true, "font_size": 25.0, "lines": ["これじゃ", "使徒と戦う前に", "死んじまうよ"]}], "img_path": "EVA1-081.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [629, 74, 685, 223], "vertical": true, "font_size": 22.0, "lines": ["主電源接続", "全回路動力伝達"]}, {"box": [577, 144, 597, 290], "vertical": true, "f