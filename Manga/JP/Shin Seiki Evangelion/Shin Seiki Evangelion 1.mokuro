{"version": "0.2.0-beta.6", "title": "Shin Seiki Evangelion", "title_uuid": "cc3209cd-c119-4870-b06c-9a34f447db7e", "volume": "Shin Seiki Evangelion 1", "volume_uuid": "f9b2292a-63b7-44df-9644-ddfae9cc7248", "pages": [{"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [204, 0, 579, 186], "vertical": false, "font_size": 32.0, "lines": ["いいから"]}, {"box": [59, 673, 205, 746], "vertical": false, "font_size": 29.0, "lines": ["Ｖｏｌｕｍｅ", "使徒、選来"]}, {"box": [251, 769, 302, 783], "vertical": false, "font_size": 14.0, "lines": ["だ"]}, {"box": [53, 781, 195, 809], "vertical": false, "font_size": 28.0, "lines": ["細い言え"]}, {"box": [57, 817, 313, 865], "vertical": false, "font_size": 20.0, "lines": ["ＹｏｕＴｕｂｅＫｉｓｈｏｎｙＰｏｒｄの", "原作、ＧＡＮＡＸ"]}], "img_path": "EVA1-001.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [96, 54, 265, 295], "vertical": true, "font_size": 22.0, "lines": ["水位の上昇", "大変地異", "終済の崩壊", "民族紛争、内戦．．．", "世界人口は半分に激減"]}, {"box": [557, 55, 689, 474], "vertical": true, "font_size": 24.0, "lines": ["西暦２０００年", "南極に大質量隕石が落下。", "かくして有史以来未曾有のカタストロフィー", "「セカンド・イスクトは起きった"]}], "img_path": "EVA1-002.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [557, 104, 580, 243], "vertical": true, "font_size": 21.0, "lines": ["それから１５年"]}, {"box": [447, 51, 543, 368], "vertical": true, "font_size": 21.0, "lines": ["ようやく復興の兆しが", "見え始めた頃", "へ", "類に新たなる危機が訪れた。"]}, {"box": [377, 52, 403, 194], "vertical": true, "font_size": 20.0, "lines": ["使徒」である"]}, {"box": [162, 48, 331, 353], "vertical": true, "font_size": 23.0, "lines": ["次々に襲来する", "正体不明の巨大戦闘兵器群。", "はたして彼らは", "その冠する名のごとき", "神々の使いこなのか．．．"]}, {"box": [56, 48, 118, 302], "vertical": true, "font_size": 21.0, "lines": ["予測されていた使徒の", "襲来に対抗するべく"]}, {"box": [196, 455, 443, 917], "vertical": true, "font_size": 28.0, "lines": ["次類は汎用人型決戦兵器", "「エヴァンゲリオン」を開発。", "２０１５年にはすでに３体を実用化していた。", "そして「ヴァ」のバイタットには", "３人の少年と少女」が選ばれた。", "大人たちは彼らに未来の希望を", "突然さるをえなかったのである。"]}, {"box": [56, 456, 155, 891], "vertical": true, "font_size": 22.0, "lines": ["その肩に、人類の存亡という", "大きすぎる運命を担った少年たちの戦いが", "７、始まる"]}], "img_path": "EVA1-003.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [249, 143, 533, 210], "vertical": false, "font_size": 32.0, "lines": ["ＰＲＯＧＲＡＷ"]}, {"box": [315, 220, 455, 238], "vertical": false, "font_size": 17.0, "lines": ["Ｅｖ４ＮＧＥＬＩＯＮ１"]}, {"box": [144, 275, 413, 322], "vertical": false, "font_size": 23.0, "lines": ["普段", "ＳＩＧＥ：使徒、裏来", "襲来"]}, {"box": [145, 369, 381, 409], "vertical": false, "font_size": 31.0, "lines": ["ＳＴＡＯＥ２「再会．．"]}, {"box": [143, 453, 446, 588], "vertical": false, "font_size": 23.0, "lines": ["リフト・オフ．．．", "．．．", "しばらく", "ＳＩＭＥ３．初号機、出撃", "ちんちん、", "ＳＴＡＧＥ．４「沈黙・"]}, {"box": [143, 627, 499, 673], "vertical": false, "font_size": 32.0, "lines": ["ＳＴＥＥＥＴ光の淵に見えるの"]}, {"box": [135, 724, 394, 760], "vertical": false, "font_size": 30.0, "lines": ["ＳＴＡＧＥＳボクソナク"]}, {"box": [563, 464, 643, 743], "vertical": true, "font_size": 32.0, "lines": ["７１９５１１ｇ．"]}, {"box": [249, 842, 370, 858], "vertical": false, "font_size": 12.0, "lines": ["ＳＨＩＮＵＩＩＫＡＲＩ"]}, {"box": [371, 905, 508, 923], "vertical": false, "font_size": 15.0, "lines": ["ＰＥ「ＡＹＡＮＡＮＨ"]}], "img_path": "EVA1-004.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [], "img_path": "EVA1-005.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [381, 930, 691, 988], "vertical": false, "font_size": 32.0, "lines": ["ＩＳＴＥＥ１使徒、製来"]}], "img_path": "EVA1-006.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [124, 105, 328, 142], "vertical": false, "font_size": 32.0, "lines": ["西暦２０１５年－"]}], "img_path": "EVA1-007.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [623, 75, 674, 270], "vertical": true, "font_size": 20.0, "lines": ["僕には将来なりたいもの", "なんて何もない"]}, {"box": [563, 161, 612, 322], "vertical": true, "font_size": 20.0, "lines": ["夢とか希望のことも", "考えたことがない"]}, {"box": [129, 140, 175, 262], "vertical": true, "font_size": 20.0, "lines": ["ーてなことを", "作文に書いたら"]}, {"box": [551, 682, 631, 872], "vertical": true, "font_size": 20.0, "lines": ["１４歳の今まで", "なるようになってきたし、", "これからもそうだろう"]}, {"box": [301, 698, 406, 873], "vertical": true, "font_size": 21.0, "lines": ["だから何かの", "事故やなんかで", "死んでしまっても別に", "かまわないと思ってた"]}, {"box": [127, 703, 178, 893], "vertical": true, "font_size": 19.0, "lines": ["案の定「まじめにやれ」と", "先生に怒られた"]}], "img_path": "EVA1-008.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [204, 833, 326, 854], "vertical": false, "font_size": 21.0, "lines": ["フッコッッ．．．"]}], "img_path": "EVA1-009.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [603, 36, 699, 184], "vertical": true, "font_size": 19.0, "lines": ["正体不明の物体", "海面に姿を", "現しました"]}, {"box": [43, 62, 108, 200], "vertical": true, "font_size": 22.0, "lines": ["主モニターに", "回します"]}, {"box": [443, 193, 519, 339], "vertical": true, "font_size": 24.0, "lines": ["物体を映像で", "かくにん", "確認！！"]}, {"box": [459, 402, 520, 485], "vertical": true, "font_size": 24.0, "lines": ["１５年ぶり", "ですね"]}, {"box": [42, 397, 115, 564], "vertical": true, "font_size": 23.0, "lines": ["ああ．．．", "間違いない", "使徒だ！！"]}, {"box": [588, 599, 635, 708], "vertical": true, "font_size": 17.0, "lines": ["来たるべき時が", "ついに来たのだ"]}, {"box": [45, 607, 144, 737], "vertical": true, "font_size": 20.0, "lines": ["人類にとって", "避けることのでき", "ない試練の時", "が．．．"]}, {"box": [208, 793, 247, 888], "vertical": true, "font_size": 18.0, "lines": ["きんきゅうは", "緊急警報"]}, {"box": [80, 837, 144, 980], "vertical": true, "font_size": 22.0, "lines": ["緊急警報を", "お知らせします"]}], "img_path": "EVA1-010.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [574, 73, 682, 287], "vertical": true, "font_size": 19.0, "lines": ["本日１２時３０分東海地方を", "中心とした関東中部全域に", "特別非常事態宣言が", "発令されました"]}, {"box": [261, 91, 323, 216], "vertical": true, "font_size": 23.0, "lines": ["繰り返し", "お伝えします"]}, {"box": [165, 425, 227, 459], "vertical": false, "font_size": 16.0, "lines": ["金根不"]}, {"box": [69, 314, 137, 459], "vertical": true, "font_size": 19.0, "lines": ["速やかに", "指定のシェルターに", "避難してください"]}, {"box": [151, 474, 238, 524], "vertical": false, "font_size": 21.0, "lines": ["澱不通"]}, {"box": [351, 488, 456, 629], "vertical": true, "font_size": 19.0, "lines": ["住民の方々は", "速やかに指定の", "シェルターへ避難", "してください"]}, {"box": [442, 680, 465, 764], "vertical": true, "font_size": 21.0, "lines": ["ちえっ．．．"]}, {"box": [331, 682, 349, 802], "vertical": true, "font_size": 21.0, "lines": ["電話もだめかあ"]}, {"box": [261, 716, 309, 838], "vertical": true, "font_size": 21.0, "lines": ["電車も止まっち", "まったし"]}, {"box": [105, 525, 221, 594], "vertical": false, "font_size": 31.0, "lines": ["全線不通"]}, {"box": [362, 927, 411, 1044], "vertical": true, "font_size": 32.0, "lines": ["．．．"]}, {"box": [34, 906, 104, 1008], "vertical": true, "font_size": 18.0, "lines": ["こんなとこで", "足止めくって", "どーすんだよ"]}], "img_path": "EVA1-011.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [160, 56, 181, 142], "vertical": true, "font_size": 18.0, "lines": ["まいったナ"]}, {"box": [60, 92, 134, 214], "vertical": true, "font_size": 18.0, "lines": ["よりによって", "こんな時に待ち", "合わせなんて"]}, {"box": [510, 397, 532, 469], "vertical": true, "font_size": 20.0, "lines": ["ったく．．．"]}, {"box": [651, 710, 697, 799], "vertical": true, "font_size": 19.0, "lines": ["シェルター", "カ．．．"]}, {"box": [264, 887, 336, 1006], "vertical": true, "font_size": 19.0, "lines": ["まさか", "今さら戦争じゃ", "ないよな．．．"]}], "img_path": "EVA1-012.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [363, 100, 421, 199], "vertical": false, "font_size": 20.0, "lines": ["畔低掩循描鰍"]}, {"box": [321, 307, 398, 464], "vertical": true, "font_size": 20.0, "lines": ["いったい今になって", "なんの用があると", "いうのだろう"]}, {"box": [74, 233, 108, 301], "vertical": true, "font_size": 31.0, "lines": ["父は．．"]}, {"box": [139, 397, 271, 557], "vertical": true, "font_size": 20.0, "lines": ["１０年以上も", "僕を伯父の家に", "預けたまま", "ほったらかしだった", "というのに"]}, {"box": [90, 501, 127, 542], "vertical": true, "font_size": 32.0, "lines": ["授業後はない。何をおかえ．．．自分たちだ．．．全部中で！"]}, {"box": [13, 505, 25, 534], "vertical": true, "font_size": 12.0, "lines": ["．．．"]}, {"box": [285, 605, 319, 644], "vertical": true, "font_size": 32.0, "lines": ["．．．．．．"]}, {"box": [71, 590, 97, 724], "vertical": true, "font_size": 17.0, "lines": ["ヘンな女．．．"]}, {"box": [302, 762, 323, 883], "vertical": true, "font_size": 20.0, "lines": ["しょーがないな"]}, {"box": [239, 812, 286, 932], "vertical": true, "font_size": 20.0, "lines": ["あと２駅", "歩くしかないか"]}], "img_path": "EVA1-013.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [381, 90, 446, 198], "vertical": true, "font_size": 20.0, "lines": ["あんなに", "低く飛んでる"]}, {"box": [556, 818, 621, 986], "vertical": true, "font_size": 29.0, "lines": ["じゅ", "巡航ミサイル！？"]}], "img_path": "EVA1-014.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [150, 695, 169, 764], "vertical": true, "font_size": 19.0, "lines": ["なんだよ"]}, {"box": [33, 938, 54, 993], "vertical": true, "font_size": 21.0, "lines": ["あれ．．"]}], "img_path": "EVA1-015.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [282, 37, 346, 207], "vertical": true, "font_size": 21.0, "lines": ["ミサイル攻撃でも", "歯が立たんのか！？"]}, {"box": [73, 31, 128, 140], "vertical": true, "font_size": 16.0, "lines": ["ぜんだん", "全弾直撃", "のはずだぞ！！"]}, {"box": [67, 292, 138, 404], "vertical": true, "font_size": 32.0, "lines": ["なんて", "やつだ！！"]}, {"box": [580, 743, 623, 852], "vertical": true, "font_size": 32.0, "lines": ["後退っ！！"]}, {"box": [91, 855, 137, 1021], "vertical": true, "font_size": 32.0, "lines": ["後退ー"]}], "img_path": "EVA1-016.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [649, 873, 675, 974], "vertical": true, "font_size": 26.0, "lines": ["わああっ"]}], "img_path": "EVA1-017.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [], "img_path": "EVA1-018.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [459, 26, 517, 137], "vertical": true, "font_size": 26.0, "lines": ["お待たせ", "シンジ君！！"]}, {"box": [636, 381, 694, 489], "vertical": true, "font_size": 27.0, "lines": ["か．．．かっとき", "葛城さん？"]}, {"box": [29, 261, 95, 388], "vertical": true, "font_size": 27.0, "lines": ["こっちよ", "早く乗って"]}, {"box": [642, 553, 668, 648], "vertical": true, "font_size": 25.0, "lines": ["いいから"]}, {"box": [404, 615, 445, 724], "vertical": true, "font_size": 30.0, "lines": ["急いで！！"]}, {"box": [39, 623, 86, 762], "vertical": true, "font_size": 20.0, "lines": ["しっかり", "つかまってんのよ"]}, {"box": [417, 910, 467, 971], "vertical": true, "font_size": 28.0, "lines": ["あ", "はいっ"]}], "img_path": "EVA1-019.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [647, 90, 693, 197], "vertical": true, "font_size": 21.0, "lines": ["ごめんね", "遅れちゃって"]}, {"box": [471, 348, 520, 456], "vertical": true, "font_size": 20.0, "lines": ["いいえっ", "僕のほうこそ"]}, {"box": [591, 535, 700, 714], "vertical": true, "font_size": 20.0, "lines": ["国連軍の湾岸戦車隊も", "全滅したわ．．．"]}, {"box": [570, 524, 620, 666], "vertical": true, "font_size": 20.0, "lines": ["軍のミサイルじゃ", "何発撃ったって"]}, {"box": [404, 539, 477, 644], "vertical": true, "font_size": 20.0, "lines": ["あいつに", "ダメージを", "与えられない"]}, {"box": [298, 540, 373, 637], "vertical": true, "font_size": 20.0, "lines": ["状況のわりに", "落ちついてん", "のね"]}, {"box": [343, 722, 369, 817], "vertical": true, "font_size": 25.0, "lines": ["あれはね"]}, {"box": [73, 529, 113, 625], "vertical": true, "font_size": 14.0, "lines": ["そうですかあ"]}, {"box": [386, 888, 487, 1018], "vertical": true, "font_size": 23.0, "lines": ["あのう", "いったい", "何なんですか", "あれ？"]}, {"box": [110, 867, 145, 964], "vertical": true, "font_size": 27.0, "lines": ["＂使徒〟よ"]}], "img_path": "EVA1-020.jpg"}, {"version": "0.1.6", "img_width":