.0, "lines": ["．．．．．．"]}], "img_path": "EVA1-066.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [249, 329, 287, 381], "vertical": true, "font_size": 30.0, "lines": ["奴め"]}, {"box": [74, 331, 129, 435], "vertical": true, "font_size": 26.0, "lines": ["ここに", "気付いたか"]}, {"box": [480, 554, 514, 639], "vertical": true, "font_size": 21.0, "lines": ["この音は"]}, {"box": [408, 758, 479, 825], "vertical": false, "font_size": 32.0, "lines": ["大丈夫"]}], "img_path": "EVA1-067.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [], "img_path": "EVA1-068.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [54, 38, 402, 88], "vertical": false, "font_size": 32.0, "lines": ["就職中学", "河距３初号機出撃"]}, {"box": [334, 28, 384, 40], "vertical": false, "font_size": 12.0, "lines": ["．．．"]}], "img_path": "EVA1-069.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [], "img_path": "EVA1-070.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [78, 388, 151, 559], "vertical": true, "font_size": 28.0, "lines": ["天井都市が", "くずれ始めたっ"]}], "img_path": "EVA1-071.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [240, 2, 275, 200], "vertical": true, "font_size": 32.0, "lines": ["あぶないっ"]}, {"box": [320, 336, 350, 386], "vertical": false, "font_size": 32.0, "lines": ["あう"]}, {"box": [334, 458, 374, 585], "vertical": true, "font_size": 32.0, "lines": ["しっかり"]}, {"box": [431, 485, 481, 633], "vertical": true, "font_size": 32.0, "lines": ["ガッ"]}], "img_path": "EVA1-072.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [364, 87, 383, 173], "vertical": true, "font_size": 18.0, "lines": ["こんな．．．"]}, {"box": [72, 101, 162, 267], "vertical": true, "font_size": 24.0, "lines": ["こんな子が", "パイロットを", "やってただなんて"]}, {"box": [416, 388, 478, 533], "vertical": true, "font_size": 20.0, "lines": ["私達はあなたを", "必要としてるわ"]}, {"box": [87, 376, 205, 564], "vertical": true, "font_size": 22.0, "lines": ["でもエヴァに", "乗らなければ", "あなたはここでは", "用のない人間なのよ"]}, {"box": [654, 510, 685, 616], "vertical": true, "font_size": 23.0, "lines": ["シンジ君．．"]}, {"box": [443, 837, 465, 933], "vertical": true, "font_size": 21.0, "lines": ["わかる？"]}], "img_path": "EVA1-073.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [519, 62, 671, 287], "vertical": true, "font_size": 22.0, "lines": ["あなただって", "お父さんとの再会を", "喜び合うために来たん", "じゃないってことは", "わかってたんでしょう？"]}, {"box": [577, 377, 663, 503], "vertical": true, "font_size": 19.0, "lines": ["なんのために", "ここまで", "来たの？"]}, {"box": [115, 373, 206, 561], "vertical": true, "font_size": 22.0, "lines": ["お父さんに", "あそこまで言われて", "黙って帰るつもり？"]}, {"box": [558, 637, 679, 850], "vertical": true, "font_size": 25.0, "lines": ["あなたが乗らなければ", "傷ついたその子が", "また乗ることに", "なるのよ"]}, {"box": [57, 836, 151, 957], "vertical": true, "font_size": 23.0, "lines": ["自分を", "情けないとは", "思わないの！？"]}], "img_path": "EVA1-074.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [626, 78, 683, 175], "vertical": true, "font_size": 22.0, "lines": ["もういい"]}, {"box": [628, 78, 641, 130], "vertical": true, "font_size": 13.0, "lines": ["．．．．．"]}, {"box": [288, 89, 391, 217], "vertical": true, "font_size": 27.0, "lines": ["放っておき", "たまえ", "葛城一尉"]}, {"box": [80, 107, 92, 178], "vertical": true, "font_size": 12.0, "lines": ["．．．．．．"]}, {"box": [647, 385, 676, 463], "vertical": true, "font_size": 26.0, "lines": ["シンジ"]}, {"box": [63, 378, 85, 454], "vertical": true, "font_size": 15.0, "lines": ["．．．"]}, {"box": [550, 778, 638, 900], "vertical": true, "font_size": 23.0, "lines": ["帰るのなら", "ぐずぐずして", "ないで"]}, {"box": [508, 838, 532, 981], "vertical": true, "font_size": 23.0, "lines": ["さっさと帰れ！"]}], "img_path": "EVA1-075.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [629, 37, 656, 162], "vertical": true, "font_size": 25.0, "lines": ["