"vertical": true, "font_size": 18.0, "lines": ["情報操作のほうは", "どうなってる"]}, {"box": [256, 394, 284, 465], "vertical": true, "font_size": 22.0, "lines": ["ご安心を"]}, {"box": [54, 401, 146, 528], "vertical": true, "font_size": 25.0, "lines": ["正午の", "ニュースを", "お伝えします"]}, {"box": [596, 639, 648, 781], "vertical": true, "font_size": 20.0, "lines": ["その件については", "すでに対処済です"]}], "img_path": "EVA1-151.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [604, 87, 705, 193], "vertical": true, "font_size": 20.0, "lines": ["まず先日の", "第３新東京市", "爆発事故に", "ついてですが"]}, {"box": [535, 170, 584, 242], "vertical": true, "font_size": 20.0, "lines": ["政府の", "見解では"]}, {"box": [258, 273, 347, 421], "vertical": true, "font_size": 22.0, "lines": ["エヴァや使徒の", "ことはひと言も", "言わない．．．"]}, {"box": [624, 695, 676, 761], "vertical": true, "font_size": 22.0, "lines": ["あれは"]}, {"box": [334, 558, 399, 682], "vertical": true, "font_size": 22.0, "lines": ["僕がエヴァに", "乗ったことも"]}, {"box": [474, 884, 555, 987], "vertical": true, "font_size": 24.0, "lines": ["夢だったん", "じゃないの", "か．．．．．．？"]}, {"box": [70, 819, 139, 968], "vertical": true, "font_size": 32.0, "lines": ["使徒と", "戦ったことも．．．"]}], "img_path": "EVA1-152.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [], "img_path": "EVA1-153.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [], "img_path": "EVA1-154.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [312, 0, 433, 356], "vertical": true, "font_size": 32.0, "lines": ["カラーガラガン！！"]}, {"box": [451, 527, 529, 652], "vertical": true, "font_size": 20.0, "lines": ["傷心の", "息子に声も", "かけないなんて"]}, {"box": [65, 530, 82, 636], "vertical": true, "font_size": 17.0, "lines": ["ミサトさん．．．"]}, {"box": [605, 762, 626, 881], "vertical": true, "font_size": 20.0, "lines": ["ひどいわねェ"]}, {"box": [213, 794, 269, 850], "vertical": true, "font_size": 26.0, "lines": ["迎えに", "来たわ"]}, {"box": [50, 1009, 75, 1025], "vertical": false, "font_size": 16.0, "lines": ["．．．"]}], "img_path": "EVA1-155.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [645, 79, 697, 221], "vertical": true, "font_size": 19.0, "lines": ["外傷は大したこと", "ないんだって？"]}, {"box": [360, 79, 434, 170], "vertical": true, "font_size": 21.0, "lines": ["あなたの", "家まで", "送ってくわ"]}, {"box": [250, 152, 354, 276], "vertical": true, "font_size": 21.0, "lines": ["本部が", "あなた専用の", "個室を用意した", "そうだから"]}, {"box": [85, 241, 113, 286], "vertical": true, "font_size": 28.0, "lines": ["はい"]}, {"box": [631, 230, 654, 337], "vertical": true, "font_size": 18.0, "lines": ["よかったわね"]}, {"box": [464, 412, 512, 469], "vertical": true, "font_size": 21.0, "lines": ["はあ．．．", "まあ．．．"]}, {"box": [645, 537, 690, 608], "vertical": true, "font_size": 18.0, "lines": ["いいの？", "ひとりで"]}, {"box": [91, 535, 196, 660], "vertical": true, "font_size": 19.0, "lines": ["申請すれば", "お父さんと", "住むことだって", "できるのよ"]}, {"box": [631, 815, 650, 900], "vertical": true, "font_size": 17.0, "lines": ["いいんです"]}, {"box": [320, 809, 365, 928], "vertical": true, "font_size": 18.0, "lines": ["ひとりのほうが", "気が楽だし"]}, {"box": [212, 889, 288, 1027], "vertical": true, "font_size": 20.0, "lines": ["父さんだって", "僕なんか", "いないほうが"]}], "img_path": "EVA1-156.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [632, 52, 645, 91], "vertical": true, "font_size": 13.0, "lines": ["もー"]}, {"box": [535, 107, 582, 210], "vertical": true, "font_size": 21.0, "lines": ["ムリ", "しちゃってェ"]}, {"box": [408, 22, 484, 167], "vertical": true, "font_size": 21.0, "lines": ["親子なんだから", "一緒に住むほうが", "自然じゃないの"]}, {"box": [236, 59, 336, 237], "vertical": true, "font_size": 21.0, "lines": ["ガマンしてないで", "言いたいことあったら", "素直に言った", "ほうが．．．"]}, {"box": [580, 453, 650, 577], "vertical": true, "font_size": 18.0, "lines": ["ミサトさんには", "カンケーない", "でしょ！"]}, {"box": [249, 455, 374, 563], "vertical": true, "font_size": 19.0, "lines": ["なによその", "言いぐさ", "あたしはねー", "あなたのこと", "心配して！"]}, {"box": [22, 229, 93, 369], "vertical": true, "font_size": 28.0, "lines": ["ほっといて", "ください！！"]}, {"box": [59, 455, 179, 625], "vertical": true, "font_size": 25.0, "lines": ["よけいな", "心配なんて", "してくれなくても", "いいですっ！"]}], "img_path": "EVA1-157.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [669, 15, 705, 93], "vertical": true, "font_size": 30.0, "lines": ["暗い！"]}, {"box": [319, 62, 413, 150], "vertical": true, "font_size": 21.0, "lines": ["その性格", "あたしが", "直したる"]}, {"box": [106, 57, 125, 122], "vertical": true, "font_size": 18.0, "lines": ["え．．．？"]}, {"box": [610, 228, 648, 374], "vertical": true, "font_size": 25.0, "lines": ["暗すぎる．．．！"]}, {"box": [648, 573, 694, 668], "vertical": true, "font_size": 18.0, "lines": ["あもしもし", "リツコ？"]}, {"box": [608, 606, 625, 703], "vertical": true, "font_size": 18.0, "lines": ["うんあたし"]}, {"box": [609, 608, 626, 705], "vertical": true, "font_size": 17.0, "lines": ["うんあたし"]}, {"box": [433, 781, 539, 950], "vertical": true, "font_size": 21.0, "lines": ["シンジ君ねェ", "あたしのマンションで", "一緒に住むことに", "なったから"]}], "img_path": "EVA1-158.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [598, 40, 661, 185], "vertical": true, "font_size": 22.0, "lines": ["ちょっ．．．", "ミサトさんっ"]}, {"box": [193, 48, 240, 157], "vertical": true, "font_size": 22.0, "lines": ["だーいじょぶ", "だってェ"]}, {"box": [70, 141, 180, 304], "vertical": true, "font_size": 21.0, "lines": ["子供に手ェ出すほど", "飢えてないからー", "じゃ上の許可", "取っといてね"]}, {"box": [604, 382, 677, 562], "vertical": true, "font_size": 26.0, "lines": ["ちょっと", "葛城一尉！？"]}, {"box": [401, 373, 457, 472], "vertical": true, "font_size": 26.0, "lines": ["これで", "よしっと"]}, {"box": [262, 377, 316, 463], "vertical": true, "font_size": 23.0, "lines": ["さ", "行こうか"]}, {"box": [65, 383, 81, 447], "vertical": true, "font_size": 16.0, "lines": ["ジョ．．．"]}, {"box": [536, 681, 657, 801], "vertical": false, "font_size": 32.0, "lines": ["ジョーダンじゃないですよォ勝手に決めないぞくださいよォ"]}, {"box": [532, 681, 657, 803], "vertical": true, "font_size": 20.0, "lines": ["ジョーダンじゃ", "ないですよォ", "勝手に", "決めないで", "くださいよォ"]}, {"box": [357, 681, 506, 818], "vertical": true, "font_size": 20.0, "lines": ["そもそも", "なんで僕が", "ミサトさんと", "一緒に住まなきゃ", "なんないん", "ですかァ？"]}, {"box": [72, 679, 133, 821], "vertical": true, "font_size": 26.0, "lines": ["つべこべ", "うるさいわねっ"]}], "img_path": "EVA1-159.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [630, 56, 691, 227], "vertical": true, "font_size": 23.0, "lines": ["上司の言うことが", "聞けないっての？"]}, {"box": [268, 74, 324, 205], "vertical": true, "font_size": 24.0, "lines": ["め．．．目が", "すわってる．．．"]}, {"box": [78, 709, 193, 899], "vertical": true, "font_size": 26.0, "lines": ["ホホホふホホお", "今日はパー", "やらなきゃね"]}, {"box": [127, 827, 147, 922], "vertical": true, "font_size": 26.0, "lines": ["ーーッと"]}], "img_path": "EVA1-160.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [570, 73, 642, 197], "vertical": true, "font_size": 20.0, "lines": ["パーッとって", "何をパーッと", "やるんですか？"]}, {"box": [351, 79, 456, 169], "vertical": true, "font_size": 22.0, "lines": ["決まってる", "でしょ", "同居人の", "歓迎会よ"]}, {"box": [239, 70, 321, 192], "vertical": true, "font_size": 21.0, "lines": ["．．．．．僕は", "そんな気分じゃ", "ないです"]}, {"box": [300, 319, 323, 371], "vertical": true, "font_size": 23.0, "lines": ["もォ"]}, {"box": [53, 326, 135, 432], "vertical": true, "font_size": 27.0, "lines": ["何", "ふてくされ", "てんのよ"]}, {"box": [600, 534, 625, 620], "vertical": true, "font_size": 25.0, "lines": ["べつに．．．"]}, {"box": [584, 755, 606, 852], "vertical": true, "font_size": 22.0, "lines": ["ちょっと"]}, {"box": [100, 795, 137, 961], "vertical": true, "font_size": 24.0, "lines": ["寄り道するわよ"]}], "img_path": "EVA1-161.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [118, 335, 176, 441], "vertical": true, "font_size": 24.0, "lines": ["なんですか", "ここ"]}, {"box": [603, 530, 681, 680], "vertical": true, "font_size": 20.0, "lines": ["．．．僕こんなトコで", "ピクニックなんか", "したくないですよ"]}, {"box": [83, 535, 243, 727], "vertical": true, "font_size": 27.0, "lines": ["か～～も～～～", "いちいち", "かわいくない子ね", "黙って", "ついてらっしゃい"]}, {"box": [368, 783, 417, 854], "vertical": true, "font_size": 23.0, "lines": ["そろそろ", "時間ね"]}, {"box": [126, 817, 139, 841], "vertical": true, "font_size": 13.0, "lines": ["？"]}], "img_path": "EVA1-162.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [], "img_path": "EVA1-163.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [629, 753, 651, 835], "vertical": true, "font_size": 24.0, "lines": ["すごい．．．"]}, {"box": [527, 825, 615, 969], "vertical": true, "font_size": 24.0, "lines": ["ビルが", "地面から", "はえてゆく．．．！？"]}], "img_path": "EVA1-164.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [598, 613, 635, 835], "vertical": true, "font_size": 29.0, "lines": ["対使徒迎撃要塞都市"]}, {"box": [563, 657, 591, 809], "vertical": true, "font_size": 29.0, "lines": ["第３新東京市"]}, {"box": [50, 701, 117, 826], "vertical": true, "font_size": 25.0, "lines": ["これが私達の", "街よ"]}], "img_path": "EVA1-165.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [656, 53, 678, 118], "vertical": true, "font_size": 22.0, "lines": ["そして"]}, {"box": [500, 376, 556, 462], "vertical": true, "font_size": 24.0, "lines": ["あなたが", "守った街"]}, {"box": [270, 265, 322, 371], "vertical": true, "font_size": 20.0, "lines": ["僕がエヴァに", "乗ったのは"]}, {"box": [438, 482, 457, 537], "vertical": true, "font_size": 18.0, "lines": ["そんな"]}, {"box": [597, 653, 619, 778], "vertical": true, "font_size": 21.0, "lines": ["わかってるわ"]}, {"box": [351, 500, 422, 603], "vertical": true, "font_size": 18.0, "lines": ["りっぱな", "もんじゃない", "ですよ"]}, {"box": [313, 660, 403, 827], "vertical": true, "font_size": 24.0, "lines": ["理由はどうあれ", "あなたはりっぱに", "よくやった"]}, {"box": [72, 440, 152, 618], "vertical": true, "font_size": 20.0, "lines": ["人類を救うためでも", "あの子を守るためでも", "ないんです"]}, {"box": [121, 875, 178, 975], "vertical": true, "font_size": 22.0, "lines": ["自信を", "もちなさい"]}], "img_path": "EVA1-166.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [214, 543, 236, 650], "vertical": true, "font_size": 22.0, "lines": ["シンジ君？"]}, {"box": [122, 570, 174, 654], "vertical": true, "font_size": 22.0, "lines": ["アララ．．", "ちょっと"]}, {"box": [596, 756, 672, 876], "vertical": true, "font_size": 23.0, "lines": ["あたし", "なんか悪いこと", "言った？"]}, {"box": [303, 767, 377, 839], "vertical": true, "font_size": 20.0, "lines": ["な", "なんでも", "ないです"]}, {"box": [226, 744, 247, 848], "vertical": true, "font_size": 14.0, "lines": ["ミサトさん"]}, {"box": [68, 922, 98, 961], "vertical": true, "font_size": 30.0, "lines": ["僕は"]}, {"box": [51, 911, 107, 973], "vertical": false, "font_size": 32.0, "lines": ["僕は"]}], "img_path": "EVA1-167.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [603, 49, 645, 137], "vertical": true, "font_size": 32.0, "lines": ["僕は："]}, {"box": [610, 498, 643, 602], "vertical": true, "font_size": 22.0, "lines": ["その言葉を"]}, {"box": [451, 994, 652, 1031], "vertical": false, "font_size": 32.0, "lines": ["第２巻につづく"]}, {"box": [115, 776, 180, 948], "vertical": true, "font_size": 22.0, "lines": ["あの時、あの場所で", "聞きたかった"]}], "img_path": "EVA1-168.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [22, 207, 144, 716], "vertical": true, "font_size": 32.0, "lines": ["ＷＥＯＮ－ＧＥＮＥＳＳＳＥＶ"]}, {"box": [327, 363, 398, 377], "vertical": false, "font_size": 14.0, "lines": ["ＳＴＡＦＦ"]}, {"box": [206, 458, 373, 498], "vertical": false, "font_size": 15.5, "lines": ["キャラクター・デザイン・", "メカニック・デザイン"]}, {"box": [269, 402, 458, 421], "vertical": false, "font_size": 18.0, "lines": ["金田「原作」「ガイナックス"]}, {"box": [376, 459, 446, 499], "vertical": false, "font_size": 14.0, "lines": ["貞本義行", "山下いくと"]}, {"box": [373, 508, 412, 531], "vertical": false, "font_size": 15.5, "lines": ["はあ", "庵"]}, {"box": [404, 502, 449, 535], "vertical": false, "font_size": 24.0, "lines": ["野秀明"]}, {"box": [308, 562, 443, 580], "vertical": false, "font_size": 18.0, "lines": ["監督・庵野秀明"]}, {"box": [285, 642, 387, 655], "vertical": false, "font_size": 13.0, "lines": ["・ＣＡＳＴ"]}, {"box": [361, 677, 448, 793], "vertical": true, "font_size": 32.0, "lines": ["今", "緒ミ山林", "ホンポス三石琴乃山口由里林原めくの"]}, {"box": [374, 702, 461, 873], "vertical": true, "font_size": 32.0, "lines": ["＊", "琴乃日里につくみが", "林原め〈み宮村優子立木文彦清川元夢"]}, {"box": [179, 681, 363, 981], "vertical": false, "font_size": 26.0, "lines": ["はンンン", "朝シンシン地域ミサトが本リツコ「遊びはレイラング」", "．．．", "私たちミンド・", "惣流アスカ・ランクレー", "冬川コウソに", "キール・ローレンツ", "加害リョウン", "都合原トウジ", "Ｗｉｌｌケンスう", "はぁっ、こういう"]}, {"box": [369, 674, 447, 912], "vertical": true, "font_size": 32.0, "lines": ["う患者", "お", "宮立清麦山"]}, {"box": [365, 835, 428, 945], "vertical": true, "font_size": 32.0, "lines": ["元ー", "い", "麦人山寺５関智", "宏一"]}, {"box": [374, 943, 442, 982], "vertical": true, "font_size": 32.0, "lines": ["岩永哲哉", "お客様は、"]}], "img_path": "EVA1-169.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [67, 53, 589, 94], "vertical": false, "font_size": 32.0, "lines": ["我々は何を作ろうとししているのか？"]}, {"box": [69, 109, 556, 162], "vertical": false, "font_size": 24.0, "lines": ["連続アニメーション「新世紀エヴァンゲリオン。が、", "スタートする前に"]}, {"box": [70, 231, 84, 395], "vertical": true, "font_size": 14.0, "lines": ["全てが込められています。"]}, {"box": [493, 225, 517, 782], "vertical": true, "font_size": 24.0, "lines": ["そして、その街へはわけのわからない「保徒」と呼称される物体が、聖菜する世界。"]}, {"box": [674, 226, 699, 356], "vertical": true, "font_size": 25.0, "lines": ["時は、２０１５年。"]}, {"box": [518, 227, 673, 793], "vertical": true, "font_size": 17.714285714285715, "lines": ["過半数の人間が１５年前にに死んでしまった世界。", "コンビニの棚が埋まるくらいまでの、奇跡的な復興を遂げ、", "生産、流通、消費、経済がもとっている世界。", "その文景を見慣れたものとし、閉じた経営を当たり前の事としている人々の住む世界、", "次世代を担うべき子供の数が減少している世界", "日本では壊滅した旧東京を切り捨て、長野県に連載。第２新東京市を建設、", "次代連部計画をダミーとした、迎撃者家都市・第５新東京市を建設している世界、"]}, {"box": [87, 227, 492, 850], "vertical": true, "font_size": 19.055555555555557, "lines": ["これが『新世紀・エヴァンゲリオン』のおおまかな世界観です。", "悲観的なビジョンで彩られている世界観です。", "あえて、楽観的な気分を排除した舞台から、物語をスタートさせました。", "そこにいるＩ４歳の少年は、他人どの接触をこわがっています。", "その行為を無駄だとし、自分を理解してもらおうという努力を放棄し、", "閉じた世界で生きようとしています。", "父親に捨てられたと感じたことから、自分はいらない人間なんだと一方的に思い込み", "からいって自殺もできない、膣肉が少年です。", "そこにいる２３歳の女性は、他人との接触を可能な限り軽くしています。", "表層的なつきあいの中に逃げることで、自分を守って来ています。", "二人とも、傷つくことが極端にこわいのです。", "二人とも、いわゆる、物語の主人公としては積極さに欠け、不適当だと思われます。", "だが、あえて彼らを主人公としました。", "「生きていくことは、変化していくことだ」と云われます。", "私はこの物語が終局を迎えた時、世界も、彼らも、変わっていて欲しい、という願いを込めて", "この作品を始めました。", "それが、私の正直な『気分』だったからです。", "『新世紀・エヴァンゲリオン』には、４年間遅れたまま何もできなかった自分の"]}], "img_path": "EVA1-170.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [241, 52, 270, 177], "vertical": true, "font_size": 26.0, "lines": ["脚本：監督"]}, {"box": [668, 232, 682, 715], "vertical": true, "font_size": 14.0, "lines": ["４年間逃げ出したまま、ただ死んでいないだけだった自分が、ただひとつ"]}, {"box": [334, 200, 672, 782], "vertical": true, "font_size": 19.0, "lines": ["「逃げちゃダメだ」", "の思いから再び始めた作品です。", "自分の気分というものをフィルムに注意させてみたい、と感じ、考えた作品です。", "それが、無謀で傲慢で困難な行為だとは知っています。", "だが、目指したのです。", "結果はわかりません。", "また、自分の中でこの物語は軽息していないからです。", "シンシ、ミサト、レイがどうなるのか、どこへいくのか、わかりません。", "スタッフの思いがどこへいくのか、まだわからないからです", "無責任だとは、感じます。", "だがしかし、我々と作品展票のシンクロを目指した以上、当たり前のことなのです。", "「それすらも模造である」", "というリスクを背負ってでも、今はこの方法論で作るしかないのです。", "私たちの『オリジナル』は、その場所にしかないのですから．．．"]}, {"box": [307, 469, 326, 820], "vertical": true, "font_size": 17.0, "lines": ["１９９５７／１７雨とくもりの日に「スタジオにて"]}, {"box": [303, 862, 692, 991], "vertical": false, "font_size": 16.0, "lines": ["シジという名は友人から、ミサトという名は、好きなマンガ", "の主人公から、", "リツコという名は中学時代の友人から、それぞれ拝借しました。", "関係ない様に見える名前も、実は幾つかのルレールの中で決めら", "れています。", "お暇な方は調べてみるのも、一興かと。"]}], "img_path": "EVA1-171.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [514, 57, 543, 280], "vertical": true, "font_size": 19.0, "lines": ["メカニック，デザイン"]}, {"box": [74, 54, 497, 379], "vertical": true, "font_size": 19.0, "lines": ["デザイン・コンセプトは", "拘束される巨大な力", "エヴァンゲリオンは、なぜあんな形に落ち", "ついたのか？これから先、私は何度もこの", "質問を受けるだろうと予想しています。監督", "が私に言われたのは、「鬼のようなイメージ」。", "人間の制御下にかろうそしておかれている巨人。", "はて、この相関図はどここかで見たな．．．。デザ", "イン・コンセプトとして私がイメージしたの", "は、おとき話のガリバーでした。拘束される", "巨大な力、知恵をつくして縛りつけてはみた", "ものの、本当にねじ・ふせたのか。まるで自信", "のもてない未知で魅惑の存在。思いついたの", "は、壁に埋め込まれた巨人でした。このイメージ", "を突き通すために、テレビ・アニメ用ロポット", "トに本来求められるべき、見た目だけで推し", "量れる性能や巨大感は気持ちよく捨て去りま", "した。語るべきは前述した事柄であって、こ"]}, {"box": [92, 376, 179, 985], "vertical": true, "font_size": 18.0, "lines": ["れらの欠点は、演出の方やアニメーター諸氏、読者の方々、やがては視聴者の皆さんにも巻", "この技術と職人根性、ついでに昨日尊心にも訴え、き起こるのです。。そのつど、私は問われるで", "て、おすがりしたいと思います。", "が、やはり提出直後、スタッフ内でも賛否。になったのか？１２週間にそしてアニメに、ま"]}, {"box": [71, 349, 88, 903], "vertical": true, "font_size": 18.0, "lines": ["一両論巻き起こりました。そして、これからは、おあ活躍するトコを見てください、"]}, {"box": [512, 788, 544, 986], "vertical": true, "font_size": 28.0, "lines": ["ＨＫＵＴＯＹＡＮＡＳＨＩＴＡ"]}, {"box": [118, 696, 133, 984], "vertical": true, "font_size": 18.0, "lines": ["しょう。「なぜ、エヴァンゲリオンはあんな形"]}], "img_path": "EVA1-172.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [554, 387, 647, 433], "vertical": false, "font_size": 32.0, "lines": ["ＡＣＫ"]}, {"box": [84, 701, 268, 753], "vertical": false, "font_size": 32.0, "lines": ["３ＡＣＫ２"]}], "img_path": "EVA1-173.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [229, 355, 287, 374], "vertical": false, "font_size": 17.0, "lines": ["．．．"]}, {"box": [192, 415, 422, 494], "vertical": false, "font_size": 20.0, "lines": ["新世紀エヴァンゲリオン◯", "漫画", "貞本義行"]}, {"box": [258, 511, 408, 542], "vertical": false, "font_size": 14.0, "lines": ["１９５５年９月１日初版発行", "１９５６年３月２０日第７岡発行"]}, {"box": [302, 470, 452, 491], "vertical": false, "font_size": 21.0, "lines": ["・ＧＡＩＮＡＸ"]}, {"box": [289, 573, 360, 595], "vertical": false, "font_size": 22.0, "lines": ["角川歴彦"]}, {"box": [288, 624, 359, 643], "vertical": false, "font_size": 19.0, "lines": ["角川書店"]}, {"box": [159, 665, 455, 679], "vertical": false, "font_size": 14.0, "lines": ["電話／東京（Ｃ３）２２８２８－８５３０【営業】（Ｃ３）５２２９１３２５－３５６５"]}, {"box": [222, 650, 427, 663], "vertical": false, "font_size": 13.0, "lines": ["あ１０２東京都千代田区富士見２－１８－３"]}, {"box": [244, 681, 403, 695], "vertical": false, "font_size": 14.0, "lines": ["振替ロ座ノＯＰＯＲＯ４－１９２８"]}, {"box": [231, 702, 421, 799], "vertical": false, "font_size": 19.5, "lines": ["装敗・デザイン", "鹿住忠広十班－ＲＨＴＯ", "印刷", "共同印刷・大谷製本"]}, {"box": [370, 757, 396, 774], "vertical": false, "font_size": 17.0, "lines": ["製本"]}, {"box": [176, 805, 468, 845], "vertical": false, "font_size": 14.5, "lines": ["初出ノ「月刊・少年エ一ス。５５年２月号〜７月号まで", "本書の無断複写・複製「転職を探します。落丁・乱丁"]}, {"box": [180, 848, 467, 858], "vertical": false, "font_size": 12.0, "lines": ["本は、ご面倒でも小社角川ブック・サービス宛にお送"]}, {"box": [171, 862, 481, 924], "vertical": false, "font_size": 15.333333333333334, "lines": ["りください。送料は小社食担でお取り替えいたします。", "１９９５「ＫＡＤＯＫＡＷＡ－ＳＨＯＴＥＮＰｉｎｔｅｄｉｎ．ＪＡＰＡＮ", "◎ＧＡＮＡＸ・ＰｏｌｅｃｔＥｘ．テレビ東京・ＮＡＳ１９５５"]}, {"box": [236, 937, 411, 952], "vertical": false, "font_size": 14.0, "lines": ["ＲＥＢＮ４．０４－７ｉ３１５６ＧＯＲＰ"]}], "img_path": "EVA1-174.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [472, 188, 708, 250], "vertical": false, "font_size": 17.0, "lines": ["兄・鋼太郎を悪の組織・機械皇国", "から取り戻せ！主人公・鉄兵とエ", "ックスの過激な戦いは続く！"]}, {"box": [30, 306, 639, 600], "vertical": false, "font_size": 32.0, "lines": ["技術りのおもしろぎ！！"]}, {"box": [42, 698, 446, 743], "vertical": false, "font_size": 32.0, "lines": ["コミック界のトップに立つ！！"]}, {"box": [332, 752, 456, 805], "vertical": false, "font_size": 12.0, "lines": ["７０００ＭＣ．２Ｒ", "ＣＯＭＡＰＩＴＲ、ＣＡＮＳ", "．．．", "ＴＶ２ＭＯＭＡＳＰＯＲＩＳ"]}, {"box": [552, 641, 662, 711], "vertical": false, "font_size": 28.0, "lines": ["定価", "＄ｎｕ－"]}, {"box": [332, 808, 389, 815], "vertical": false, "font_size": 12.0, "lines": ["Ａｍａｚｏｎに"]}], "img_path": "EVA1-175.jpg"}, {"version": "0.1.6", "img_width": 757, "img_height": 1057, "blocks": [{"box": [59, 33, 715, 85], "vertical": false, "font_size": 32.0, "lines": ["ＫａｄｏｋａｙｐｅＣｏｍｉｋｓＡ．絶賛発売中！！"]}, {"box": [62, 102, 642, 981], "vertical": false, "font_size": 32.0, "lines": ["Ｂｘｔビート・エックス（Ｏ）の", "ＤＶＡ＿●事田正典・定価各ｆＣ２００円", "機動戦士クロスボーン・ガンダム（１）の", "神奈川県エリームパーノークレンジングラムの動作の画面が改善されています。２０１７年１２月１０日", "サキングオブファターズＡＣＯの", "サマキング・インター・●東行方たっや・定義（１２月２８日）", "天空のエスカフローネ○", "大元・亜樹・定価ＥＤＨＰ", "ヱテンズボウイ◯", "エアノヘハリヤし●天王寺きっね、定価別円", "マクロスフトラッシュ（", "◆●美樹本病彦・定価６５０円", "ブリザードＹｕｋｉＯ", "・アリアート「ＬＩＫＩＣＵＶ」の原稿、「前項の記事」という", "光の奥、闇の刃からもうちょっとだよね。", "プロノリ楽」「画レノン」●武林武士員定価５００円", "グルマンくんの", "●ゆでたまご・定価ＢＢＩ円", "ビンバツ一番", "●さとうけん、定価は４０円", "渋滞"]}, {"box": [77, 942, 419, 1012], "vertical": false, "font_size": 32.0, "lines": ["毎月１日発売！！"]}], "img_path": "EVA1-176.jpg"}, {"version": "0.1.6", "img_width": 2579, "img_height": 1082, "blocks": [{"box": [144, 353, 397, 684], "vertical": false, "font_size": 23.0, "lines": ["貞本義行", "恋人達が相手のことを想ったり親子が知らないお母さんやすく借りた感情。", "がお互いを想ったりする特別な感情。", "には脳の中のＡのＩＩという神経系が", "この風のバックスのパンツに触れた関っているそうです。エヴァングリ", "残っているマンじゃ。エンパンオンと操縦者はそのＡＩ神経の強い", "オンニ麻服はほとんど中継が良いシンクロによって一体となり戦士となるのです。つもり減のように、この", "なるのです。つまり愛の力が、この", "超兵器を操れるのです。なーんて単", "一緒に練習で、だがしかし、感動的で大丈夫です。でも", "すばらしい話なんでしょう。私にも", "９．８．はつの場のみんなイメージ彼には彼にアカリが動かせるでしょうか？．．．この『Ｈｅｒ", "吸い！！動いえ？．．．暴走！？"]}, {"box": [687, 295, 1044, 340], "vertical": false, "font_size": 32.0, "lines": ["Ｙｏｈｏｎｅ・横徒襲来"]}, {"box": [13, 985, 233, 1046], "vertical": false, "font_size": 24.0, "lines": ["カバー印刷レノ共同印刷装鵰ノ鹿住忠広", "また、女性の女性装備ノ鹿住忠広初出ノ目平山年", "装幀ノ塵住忠広初出ノ月刊少年エースＳＳ年"]}, {"box": [503, 951, 752, 1051], "vertical": false, "font_size": 27.0, "lines": ["漫画", "そう簡単なもののであれば、", "原作／ＧＡＩＮＡＸ"]}, {"box": [1241, 722, 1309, 988], "vertical": true, "font_size": 32.0, "lines": ["『自本義行", "原作ＧＡＩＮＡＹ"]}, {"box": [1645, 52, 1918, 129], "vertical": false, "font_size": 24.0, "lines": ["ＩＳＢＮ４－０４－７１３１１５－６", "ｃＯ９７９．Ｐ５６０Ｅ"]}, {"box": [1652, 173, 1935, 207], "vertical": false, "font_size": 30.0, "lines": ["定価５６０円（本体で４０円）角川憲店"]}, {"box": [2155, 163, 2530, 204], "vertical": false, "font_size": 32.0, "lines": ["Ｋａｄｄｏｋｅｗｓ（ｃｏｍｉｃｓ"]}, {"box": [2152, 234, 2530, 878], "vertical": false, "font_size": 28.0, "lines": ["車田正美", "●ビート・エックスト・３", "そういえば、この時期だけのボックスがありますので、今回はそれだけでもないんだ", "あなたのパンツルムーム・エージェンジャーのキャクアプリケーションになってきますのですが、", "克・亜樹", "●天空のエスカフローネー", "天王寺きつね", "●エデンズ・ボウイ！", "美樹本晴彦", "●マクロスアトラッシュー", "吉岡平十安西真", "●ブリザードＹｕｋ！", "武林武士", "●光の剣間の刃グループン", "ゆでたまご", "●グルマンくん！", "さとうげん", "●ビンパツ一番！", "一見本義行＋ＧＡＩＮＶＡＸ", "●新世紀エヴァングリオン！ーーー良くするんです。", "内野文吾", "あ．．．あなりんせすＡＧＤ／ＧＯ！！！", "ＳＵＥＺＥＮ", "●マリンカラー１－", "山崎浩", "●ガルダイヤーに", "伝ーーー富野由悠季十長谷川裕一", "●機動戦士Ｖガンダム外伝", "第４４５６十・Ａｍ・第スーパーファミコン編", "●●●グーム４コマンアター", "奥田ひとし", "●天地無用／魎皇完】－３－", "井荻寿ー", "●廃車タイガー・３", "船戸明里十重馬敬世に、美体料で", "マルナー幼年期の終りー", "．．．あまりの神坂一十義仲翔子", "今回開発前にスレイヤーズーーー", "被「教師が一奥田ひとし", "◆８０００ＷＡＰＩ・ペット・●ラジカルガーディアント・２・"]}], "img_path": "cover.jpg"}, {"version": "0.1.6", "img_width": 1560, "img_height": 1062, "blocks": [{"box": [249, 287, 497, 316], "vertical": false, "font_size": 18.0, "lines": ["ＫａｄｏｋａｗａＣｏｎｉｃｓＡ"]}, {"box": [141, 372, 570, 566], "vertical": false, "font_size": 32.0, "lines": ["新世紀", "エヴァンゲリオン", "真本義行"]}, {"box": [290, 556, 433, 582], "vertical": false, "font_size": 21.0, "lines": ["原作ＧＡＩＮＡＸ"]}, {"box": [260, 634, 491, 664], "vertical": false, "font_size": 22.0, "lines": ["ＹｏｓｈｕｒｕＲ（ＳＡＤＡＭＯＴＯ"]}, {"box": [761, 178, 808, 271], "vertical": false, "font_size": 32.0, "lines": ["新世紀工"]}, {"box": [757, 391, 815, 577], "vertical": true, "font_size": 32.0, "lines": ["グリオ"]}, {"box": [751, 685, 827, 965], "vertical": true, "font_size": 32.0, "lines": ["真本義に", "『作ＧＡＩＮＡＸ"]}, {"box": [750, 990, 821, 1047], "vertical": false, "font_size": 32.0, "lines": ["ＫＣＡＩ２．１０角川豪店！"]}, {"box": [1036, 1017, 1379, 1044], "vertical": false, "font_size": 17.0, "lines": ["ＩＳＢＮ４－０４－７１３１１５－６．ＣＤ９７９"]}], "img_path": "inner_cover.jpg"}]}