 1364], "vertical": true, "font_size": 24.0, "lines": ["被害状況は？"]}], "img_path": "img140.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [883, 129, 941, 347], "vertical": true, "font_size": 24.0, "lines": ["電線の物理的な切断が", "２７カ所"]}, {"box": [733, 216, 849, 394], "vertical": true, "font_size": 24.0, "lines": ["それにフロクラム", "操作による巧妙な", "隠蔽工作が１０カ所", "発見されました"]}, {"box": [113, 145, 180, 277], "vertical": true, "font_size": 25.0, "lines": ["現在５％まで", "復旧してます"]}, {"box": [886, 516, 952, 691], "vertical": true, "font_size": 26.0, "lines": ["やはり誰かが", "故意にやったのね"]}, {"box": [561, 528, 659, 682], "vertical": true, "font_size": 24.0, "lines": ["誰の仕業にしろ", "おそらく目的は", "ここの調査ね"]}, {"box": [426, 525, 523, 685], "vertical": true, "font_size": 25.0, "lines": ["復旧ルートから", "本部の構造を", "推測できるわ"]}, {"box": [117, 801, 177, 894], "vertical": true, "font_size": 28.0, "lines": ["シャクな", "やつらね"]}, {"box": [815, 1089, 939, 1396], "vertical": true, "font_size": 25.0, "lines": ["ＷＡＧＩにダミープログラムを", "走らせといたから", "全体の把握はできなかった", "と思うけど．．"]}, {"box": [104, 1105, 263, 1345], "vertical": true, "font_size": 24.0, "lines": ["でも", "本部初の被害が", "使徒ではなく", "人間にやられたものとは", "やり切れませんね"]}], "img_path": "img141.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [873, 113, 932, 186], "vertical": true, "font_size": 32.0, "lines": ["それに", "しても"]}, {"box": [512, 128, 580, 222], "vertical": true, "font_size": 31.0, "lines": ["いったい", "誰が．．．"]}, {"box": [413, 128, 480, 279], "vertical": true, "font_size": 22.0, "lines": ["内部の人間って", "ことは確かね"]}, {"box": [867, 499, 919, 669], "vertical": true, "font_size": 20.0, "lines": ["ネルフにスパイが", "いるってこと？"]}, {"box": [155, 504, 245, 679], "vertical": true, "font_size": 24.0, "lines": ["今所員全員の", "動向を詳しく", "チェックしてるわ"]}, {"box": [835, 950, 932, 1193], "vertical": true, "font_size": 26.0, "lines": ["身近な人間ほど", "本当の姿が見えないって", "こともあるわ"]}, {"box": [80, 718, 168, 875], "vertical": true, "font_size": 24.0, "lines": ["でも犯人は案外", "近くにいるかも", "しれない"]}], "img_path": "img142.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [859, 122, 957, 322], "vertical": true, "font_size": 30.0, "lines": ["彼は", "停電になった時", "私と一緒にいたわよ"]}, {"box": [928, 554, 953, 641], "vertical": true, "font_size": 24.0, "lines": ["確かにね"]}, {"box": [116, 584, 180, 737], "vertical": true, "font_size": 22.0, "lines": ["敵はひとりとは", "限らないのよ"]}, {"box": [809, 648, 898, 900], "vertical": true, "font_size": 24.0, "lines": ["でもそれもアリバイ工作", "だと疑おうと思えば", "疑えるわ"]}], "img_path": "img143.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [880, 123, 975, 253], "vertical": true, "font_size": 32.0, "lines": ["ギャ"]}, {"box": [558, 120, 645, 253], "vertical": true, "font_size": 23.0, "lines": ["ミサトさん", "昨夜は帰って", "来なかったな"]}, {"box": [120, 96, 242, 352], "vertical": true, "font_size": 23.0, "lines": ["ムリもないか", "あんな騒ぎがあったんじゃ", "本部もしっちゃか", "めっちゃかだろうし"]}, {"box": [806, 443, 886, 558], "vertical": true, "font_size": 32.0, "lines": ["ギャ"]}, {"box": [858, 712, 927, 884], "vertical": true, "font_size": 32.0, "lines": ["アスカ", "まだ寝てんの？"]}, {"box": [844, 957, 930, 1151], "vertical": true, "font_size": 22.0, "lines": ["あんな事があった", "後じゃちょっと", "顔合わせづらいもんな"]}, {"box": [582, 978, 613, 1156], "vertical": true, "font_size": 30.0, "lines": ["シンジ～～"]}, {"box": [91, 704, 165, 871], "vertical": true, "font_size": 26.0, "lines": ["学校先に", "行くよーっ！"]}, {"box": [641, 1134, 762, 1389], "vertical": false, "font_size": 24.0, "lines": ["独り負「それの．．．", "じゃねーでよ", "やるでね．．．", "状激しやさし"]}], "img_path": "img144.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [847, 110, 966, 218], "vertical": true, "font_size": 32.0, "lines": ["学校", "行っちゃ", "ダメ"]}, {"box": [486, 122, 525, 181], "vertical": true, "font_size": 32.0, "lines": ["は！？"]}, {"box": [413, 122, 442, 220], "vertical": true, "font_size": 26.0, "lines": ["なんで！？"]}, {"box": [104, 107, 300, 281], "vertical": true, "font_size": 29.0, "lines": ["ダメったら", "ダメなのよ", "あんたは今から", "ネルフ本部に", "行くの"]}, {"box": [876, 616, 953, 730], "vertical": true, "font_size": 32.0, "lines": ["だから", "なんでっ"]}, {"box": [107, 615, 417, 903], "vertical": true, "font_size": 32.0, "lines": ["あんたのせいで", "加持さんに誤解され", "ちゃったじゃないのッ", "責任取って", "誤解解いてよ", "私とは全然", "カンケーないって！！"]}, {"box": [825, 1082, 959, 1300], "vertical": true, "font_size": 27.0, "lines": ["なっあれは", "キミの方が", "迫って来たんだろ？", "自分で解けよ！"]}, {"box": [113, 1084, 286, 1361], "vertical": true, "font_size": 27.0, "lines": ["できるなら", "そうするわよ", "でも今日は生理２日目で", "死ぬほどお腹が", "痛いのようっ"]}], "img_path": "img145.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [851, 104, 911, 277], "vertical": true, "font_size": 26.0, "lines": ["セイリって．．．", "そんな大っぴらに"]}, {"box": [503, 109, 605, 305], "vertical": true, "font_size": 29.0, "lines": ["あんなとこ", "見られちゃったん", "だもん"]}, {"box": [75, 135, 185, 333], "vertical": true, "font_size": 27.0, "lines": ["どのつら下げて", "加持さんに会えば", "いいのよ"]}, {"box": [663, 497, 689, 573], "vertical": true, "font_size": 26.0, "lines": ["それに"]}, {"box": [216, 648, 344, 763], "vertical": true, "font_size": 30.0, "lines": ["わかった．．", "行けば", "いいんだ", "ろ？"]}, {"box": [114, 644, 145, 723], "vertical": true, "font_size": 31.0, "lines": ["まって"]}, {"box": [887, 1038, 922, 1094], "vertical": true, "font_size": 32.0, "lines": ["これ"]}, {"box": [416, 656, 574, 875], "vertical": true, "font_size": 26.0, "lines": ["まったく", "加持さんの事となると", "必死なんだから", "その顔には", "勝てねーよ"]}, {"box": [605, 1052, 630, 1148], "vertical": true, "font_size": 25.0, "lines": ["なにこれ"]}, {"box": [196, 1053, 245, 1116], "vertical": true, "font_size": 29.0, "lines": ["手紙"]}, {"box": [77, 1060, 168, 1277], "vertical": true, "font_size": 29.0, "lines": ["あんたの言葉だけじゃ", "信用できないから", "昨夜書いたの"]}], "img_path": "img146.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [903, 107, 964, 355], "vertical": true, "font_size": 25.0, "lines": ["絶対加持さんに会って", "直接渡してよ！"]}, {"box": [790, 111, 859, 280], "vertical": true, "font_size": 32.0, "lines": ["あんたは絶対中見ないでよ！"]}, {"box": [790, 110, 849, 279], "vertical": true, "font_size": 25.0, "lines": ["あんたは絶対", "中見ないでよ！"]}, {"box": [398, 125, 458, 256], "vertical": true, "font_size": 23.0, "lines": ["でも見るなと", "言われると"]}, {"box": [125, 109, 188, 242], "vertical": true, "font_size": 26.0, "lines": ["見たく", "なるんだよな"]}, {"box": [506, 535, 534, 688], "vertical": true, "font_size": 25.0, "lines": ["わかったよ．．．"]}, {"box": [131, 538, 197, 690], "vertical": true, "font_size": 20.0, "lines": ["何書いてあるか", "不安だし．．．"]}, {"box": [902, 761, 962, 893], "vertical": true, "font_size": 26.0, "lines": ["こーやって", "日にかざせば"]}, {"box": [942, 1062, 961, 1159], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．"]}, {"box": [323, 755, 525, 854], "vertical": false, "font_size": 32.0, "lines": ["いや、時間で私は"]}, {"box": [458, 1124, 557, 1273], "vertical": false, "font_size": 32.0, "lines": ["じゃ．．．"]}, {"box": [125, 1086, 198, 1281], "vertical": true, "font_size": 25.0, "lines": ["自分の言葉のみで", "誤解を解こう．．．"]}], "img_path": "img147.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [976, 60, 1021, 103], "vertical": false, "font_size": 32.0, "lines": ["ぶっ"]}, {"box": [289, 408, 385, 564], "vertical": true, "font_size": 31.0, "lines": ["参ったな"]}, {"box": [200, 404, 252, 501], "vertical": true, "font_size": 32.0, "lines": ["ＯＰＥＮＳＡＴＥ"]}, {"box": [74, 436, 97, 551], "vertical": true, "font_size": 20.0, "lines": ["スロホント"]}, {"box": [817, 696, 930, 841], "vertical": true, "font_size": 26.0, "lines": ["まだ完全に", "電気が復旧", "してないのか"]}, {"box": [430, 950, 462, 1025], "vertical": true, "font_size": 32.0, "lines": ["だめだ"]}, {"box": [90, 950, 124, 1116], "vertical": true, "font_size": 24.0, "lines": ["ここも開かない"]}], "img_path": "img148.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [927, 117, 952, 218], "vertical": true, "font_size": 24.0, "lines": ["まずい．．"]}, {"box": [657, 123, 757, 246], "vertical": true, "