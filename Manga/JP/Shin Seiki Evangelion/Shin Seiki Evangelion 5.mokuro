_height": 1485, "blocks": [{"box": [840, 126, 910, 268], "vertical": true, "font_size": 25.0, "lines": ["エヴァ３体の", "配置は？"]}, {"box": [85, 124, 157, 245], "vertical": true, "font_size": 26.0, "lines": ["すでに完了", "しています"]}, {"box": [279, 906, 308, 1053], "vertical": true, "font_size": 28.0, "lines": ["まったく．．"]}], "img_path": "img088.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1485, "blocks": [{"box": [868, 79, 968, 274], "vertical": true, "font_size": 27.0, "lines": ["ミサトもムチャな", "作戦たててくれる", "わよね"]}, {"box": [443, 91, 552, 191], "vertical": true, "font_size": 32.0, "lines": ["なんか", "言った？", "アスカ"]}, {"box": [123, 210, 147, 330], "vertical": true, "font_size": 20.0, "lines": ["．．．なんにも"]}, {"box": [579, 445, 757, 591], "vertical": true, "font_size": 26.0, "lines": ["落ちてくる", "使徒を直に", "エヴァの手で", "受け止める", "なんてさ"]}, {"box": [450, 382, 540, 511], "vertical": true, "font_size": 22.0, "lines": ["でいつまで", "こうしてれば", "いいワケ？"]}, {"box": [110, 385, 180, 555], "vertical": true, "font_size": 26.0, "lines": ["もちろん使徒が", "現れるまでよ"]}, {"box": [760, 667, 978, 925], "vertical": true, "font_size": 26.0, "lines": ["正確な位置の測定は", "できないけど", "ロスト直前までの", "データからＭＡＧＩが", "落下予想地点を", "算出したわ"]}, {"box": [257, 672, 329, 841], "vertical": true, "font_size": 24.0, "lines": ["こんなに範囲が", "広いの！？"]}, {"box": [856, 1032, 955, 1296], "vertical": true, "font_size": 26.0, "lines": ["そうだから", "あなたたちのエヴァを", "この３ヵ所に配置したの"]}, {"box": [73, 1032, 220, 1364], "vertical": true, "font_size": 27.0, "lines": ["あとは目標を確認", "できしだいあなたたちが", "全力で走ってＡＴ．フィールド", "最大で使徒を受け止めるのよ。"]}], "img_path": "img089.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1485, "blocks": [{"box": [834, 114, 932, 237], "vertical": true, "font_size": 29.0, "lines": ["あのねえ", "簡単に", "言うけどォ"]}, {"box": [659, 84, 736, 232], "vertical": true, "font_size": 32.0, "lines": ["もし", "失敗したら"]}, {"box": [95, 117, 157, 241], "vertical": true, "font_size": 27.0, "lines": ["その", "つもりでね"]}, {"box": [885, 565, 979, 770], "vertical": true, "font_size": 32.0, "lines": ["シンジ君も", "レイもいい！？"]}, {"box": [342, 343, 506, 488], "vertical": true, "font_size": 25.0, "lines": ["ネルフ本部を", "根こそぎ", "エグられる", "ことになるわ"]}, {"box": [108, 1155, 225, 1388], "vertical": true, "font_size": 29.0, "lines": ["いつでもスタート", "できるように", "準備してて"]}], "img_path": "img090.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1485, "blocks": [{"box": [924, 108, 959, 163], "vertical": true, "font_size": 32.0, "lines": ["はい"]}, {"box": [438, 102, 459, 180], "vertical": true, "font_size": 21.0, "lines": ["．．．．．．"]}, {"box": [311, 108, 381, 187], "vertical": true, "font_size": 32.0, "lines": ["シンジ", "くん？"]}, {"box": [108, 110, 214, 213], "vertical": true, "font_size": 32.0, "lines": ["はい．．", "わかって", "ます"]}, {"box": [856, 609, 966, 828], "vertical": true, "font_size": 29.0, "lines": ["なーんか心配だなあ", "ここ２３日元気", "ないのよね彼"]}, {"box": [660, 588, 737, 735], "vertical": true, "font_size": 32.0, "lines": ["カチャーを"]}, {"box": [465, 597, 604, 865], "vertical": true, "font_size": 30.0, "lines": ["あら．．．", "元気いっぱいの", "シンジ君なんてかえって", "気持ち悪いじゃない"]}, {"box": [354, 598, 414, 716], "vertical": true, "font_size": 23.0, "lines": ["いじわる", "ばあさんね"]}, {"box": [111, 598, 176, 722], "vertical": true, "font_size": 25.0, "lines": ["ばあさんは", "余計よ．．．"]}, {"box": [856, 1021, 881, 1118], "vertical": true, "font_size": 25.0, "lines": ["シンジ．．．"]}, {"box": [494, 1152, 557, 1305], "vertical": true, "font_size": 23.0, "lines": ["もう私を", "見るのはやめろ"]}], "img_path": "img091.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1485, "blocks": [{"box": [804, 127, 905, 261], "vertical": true, "font_size": 24.0, "lines": ["私とわかり", "合おうなどと", "思うな"]}, {"box": [566, 87, 664, 283], "vertical": true, "font_size": 23.0, "lines": ["人と人とが", "完全に理解し合う", "ことは決してできぬ"]}, {"box": [752, 662, 768, 711], "vertical": true, "font_size": 16.0, "lines": ["！！"]}, {"box": [349, 696, 376, 764], "vertical": true, "font_size": 27.0, "lines": ["．．．ほら"]}, {"box": [130, 369, 195, 525], "vertical": true, "font_size": 23.0, "