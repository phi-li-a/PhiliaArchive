, "font_size": 30.0, "lines": ["はい．．"]}, {"box": [535, 1315, 565, 1394], "vertical": true, "font_size": 30.0, "lines": ["あれ？"]}], "img_path": "img117.jpg"}, {"version": "0.1.6", "img_width": 1050, "img_height": 1480, "blocks": [{"box": [820, 65, 915, 199], "vertical": true, "font_size": 26.0, "lines": ["よォ", "なにいきり", "たってんだ？"]}, {"box": [321, 111, 416, 244], "vertical": true, "font_size": 28.0, "lines": ["ちょっとォ", "ついてこない", "でよ"]}, {"box": [639, 555, 733, 689], "vertical": true, "font_size": 26.0, "lines": ["べつにっ", "あんたには", "関係ないわよ"]}, {"box": [85, 563, 144, 718], "vertical": true, "font_size": 22.0, "lines": ["オレもこっちに", "用があるんだよ"]}, {"box": [830, 797, 927, 985], "vertical": true, "font_size": 24.0, "lines": ["しかしまあ今度も", "思い切った作戦", "立てたもんだよな"]}, {"box": [441, 803, 543, 958], "vertical": true, "font_size": 25.0, "lines": ["その一歩を", "間違えた子を", "叱りに行くのよ"]}, {"box": [591, 1149, 659, 1344], "vertical": true, "font_size": 26.0, "lines": ["一歩間違ったら", "オダブツだったぜ？"]}, {"box": [82, 1199, 148, 1331], "vertical": true, "font_size": 24.0, "lines": ["全くなに", "考えてんだか"]}], "img_path": "img118.jpg"}, {"version": "0.1.6", "img_width": 1050, "img_height": 1480, "blocks": [{"box": [875, 66, 969, 286], "vertical": true, "font_size": 25.0, "lines": ["子供のお守しながら", "得体の知れない奴らと", "戦うなんて"]}, {"box": [688, 110, 751, 305], "vertical": true, "font_size": 20.0, "lines": ["考えてみりゃ", "モノスゴイ仕事だな"]}, {"box": [451, 440, 475, 539], "vertical": true, "font_size": 24.0, "lines": ["あら．．．？"]}, {"box": [543, 569, 605, 722], "vertical": true, "font_size": 23.0, "lines": ["．．．言わないで", "頭痛くなるから"]}, {"box": [125, 476, 189, 600], "vertical": true, "font_size": 28.0, "lines": ["なんで", "止まんの？"]}, {"box": [887, 1002, 908, 1104], "vertical": true, "font_size": 21.0, "lines": ["．．．．．．！？"]}, {"box": [166, 1257, 186, 1332], "vertical": true, "font_size": 20.0, "lines": ["．．．"]}], "img_path": "img119.jpg"}, {"version": "0.1.6", "img_width": 1050, "img_height": 1480, "blocks": [{"box": [778, 66, 883, 224], "vertical": true, "font_size": 27.0, "lines": ["あんたなんか", "ヘンなボタン", "押した？"]}, {"box": [470, 88, 504, 232], "vertical": true, "font_size": 30.0, "lines": ["ちょっとォ"]}, {"box": [526, 607, 598, 687], "vertical": true, "font_size": 32.0, "lines": ["いや．．．", "べつに"]}, {"box": [76, 345, 180, 514], "vertical": true, "font_size": 26.0, "lines": ["なんでいきなり", "まっ暗になる", "ワケ？"]}, {"box": [795, 813, 893, 935], "vertical": true, "font_size": 25.0, "lines": ["なんにも", "見えない", "じゃないの"]}, {"box": [95, 815, 133, 911], "vertical": true, "font_size": 25.0, "lines": ["停電かな"]}, {"box": [817, 1053, 901, 1228], "vertical": true, "font_size": 23.0, "lines": ["ただの停電なら", "すぐに予備電源に", "切り替わるはずよ"]}, {"box": [652, 1052, 744, 1205], "vertical": true, "font_size": 23.0, "lines": ["５分も経つのに", "暗いままなんて", "おかしいわ"]}], "img_path": "img120.jpg"}, {"version": "0.1.6", "img_width": 1050, "img_height": 1480, "blocks": [{"box": [795, 104, 974, 276], "vertical": true, "font_size": 28.0, "lines": ["暗闇でいきなり", "ボソッと", "しゃべらないで", "くれる？", "怖いからっ"]}, {"box": [475, 95, 529, 224], "vertical": true, "font_size": 20.0, "lines": ["ここにいても", "仕方ないし"]}, {"box": [117, 303, 204, 436], "vertical": true, "font_size": 23.0, "lines": ["とりあえず", "発令所まで", "行きましょう"]}, {"box": [837, 635, 974, 831], "vertical": true, "font_size": 29.0, "lines": ["ちょっとなによ", "いつもは無口な", "くせに", "リーダーづらして"]}, {"box": [572, 417, 674, 572], "vertical": true, "font_size": 27.0, "lines": ["何か事故が", "起こったのかも", "しれないわ"]}, {"box": [133, 647, 232, 816], "vertical": true, "font_size": 25.0, "lines": ["よせよ", "ケンカしたって", "始まらないよ"]}, {"box": [903, 926, 964, 1040], "vertical": true, "font_size": 27.0, "lines": ["綾波の言う", "通りだよ"]}, {"box": [760, 939, 851, 1072], "vertical": true, "font_size": 27.0, "lines": ["発令所に", "行って指示を", "仰ごう"]}, {"box": [446, 922, 508, 1142], "vertical": true, "font_size": 22.0, "lines": ["どうでもいいけど", "歩くの速すぎるわよ"]}, {"box": [65, 1193, 172, 1390], "vertical": true, "font_size": 27.0, "lines": ["なんでこの暗闇で", "そんなに速く", "歩けんのよ"]}], "img_path": "img121.jpg"}, {"version": "0.1.6", "img_widt