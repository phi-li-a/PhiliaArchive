 24.0, "lines": ["綾波の言った", "とおり"]}, {"box": [727, 806, 812, 958], "vertical": true, "font_size": 24.0, "lines": ["父さんと話を", "してみようと", "思ったんだけど"]}, {"box": [373, 782, 472, 1002], "vertical": true, "font_size": 22.0, "lines": ["たぶん僕と父さんは", "二度と話し合うなんて", "ことはないと思う"]}, {"box": [296, 784, 321, 863], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．．．"]}, {"box": [611, 1156, 634, 1265], "vertical": true, "font_size": 20.0, "lines": ["ダメだった"]}, {"box": [125, 1263, 151, 1337], "vertical": true, "font_size": 26.0, "lines": ["そう．．"]}], "img_path": "img169.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [819, 78, 927, 247], "vertical": true, "font_size": 25.0, "lines": ["ふたりで仲よく", "お話し中悪いん", "だけどオ"]}, {"box": [324, 110, 346, 196], "vertical": true, "font_size": 20.0, "lines": ["なんだよ"]}, {"box": [85, 106, 225, 257], "vertical": true, "font_size": 28.0, "lines": ["ちょっと", "あからさまに", "イヤな顔", "しないでよ"]}, {"box": [793, 753, 914, 906], "vertical": true, "font_size": 29.0, "lines": ["加持さんに", "ちゃんと誤解", "解いてくれたで", "しょうね"]}, {"box": [625, 743, 753, 838], "vertical": true, "font_size": 29.0, "lines": ["手紙！", "ちゃんと", "渡して", "くれた？"]}, {"box": [445, 749, 510, 822], "vertical": true, "font_size": 32.0, "lines": ["ああ", "あれ．．"]}, {"box": [369, 755, 403, 810], "vertical": true, "font_size": 32.0, "lines": ["はい"]}, {"box": [892, 1118, 948, 1191], "vertical": true, "font_size": 29.0, "lines": ["返す"]}, {"box": [778, 1226, 867, 1379], "vertical": true, "font_size": 29.0, "lines": ["自分で渡せよ", "自分でまいた", "タネなんだから"]}, {"box": [81, 1127, 199, 1217], "vertical": true, "font_size": 32.0, "lines": ["まっ", "なによ", "それ"]}], "img_path": "img170.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [928, 126, 962, 215], "vertical": true, "font_size": 25.0, "lines": ["先に帰る"]}, {"box": [751, 114, 775, 205], "vertical": true, "font_size": 24.0, "lines": ["じゃあね"]}, {"box": [512, 107, 543, 218], "vertical": true, "font_size": 30.0, "lines": ["シンジっ"]}, {"box": [899, 603, 959, 694], "vertical": true, "font_size": 26.0, "lines": ["なに．．．？", "その手紙"]}, {"box": [497, 593, 629, 761], "vertical": true, "font_size": 24.0, "lines": ["うるさいわねっ", "あんたには", "ぜんっぜん", "関係ないわよ"]}, {"box": [144, 973, 218, 1143], "vertical": true, "font_size": 25.0, "lines": ["父さんのことを", "考えるのは"]}, {"box": [574, 1213, 595, 1332], "vertical": true, "font_size": 19.0, "lines": ["もうよそう"]}], "img_path": "img171.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [884, 48, 919, 241], "vertical": true, "font_size": 25.0, "lines": ["ずっと憎んでいた"]}, {"box": [702, 158, 738, 326], "vertical": true, "font_size": 20.0, "lines": ["母さんを死なせ"]}, {"box": [551, 52, 591, 176], "vertical": true, "font_size": 26.0, "lines": ["僕を捨てた"]}, {"box": [85, 128, 195, 322], "vertical": true, "font_size": 24.0, "lines": ["二度と好きに", "なることはないと", "思ってた"]}, {"box": [866, 419, 897, 538], "vertical": true, "font_size": 20.0, "lines": ["でもあの日"]}, {"box": [698, 465, 771, 707], "vertical": true, "font_size": 27.0, "lines": ["父さんに言われて", "エヴァに乗った日から"]}, {"box": [293, 422, 324, 563], "vertical": true, "font_size": 20.0, "lines": ["いつの間にか"]}, {"box": [864, 987, 893, 1040], "vertical": true, "font_size": 29.0, "lines": ["でも"]}, {"box": [113, 643, 220, 861], "vertical": true, "font_size": 26.0, "lines": ["いつかは父さんに", "認めてもらいたいと", "心の隅で願っていた"]}, {"box": [749, 1161, 775, 1343], "vertical": true, "font_size": 25.0, "lines": ["それももう．．"]}], "img_path": "img172.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [862, 90, 950, 291], "vertical": true, "font_size": 25.0, "lines": ["どうした？", "ぼんやり歩いてると", "繋がれるぞ"]}, {"box": [579, 614, 644, 746], "vertical": true, "font_size": 25.0, "lines": ["帰るんだろ？", "送ってくよ"]}, {"box": [161, 507, 195, 567], "vertical": false, "font_size": 32.0, "lines": ["でも"]}, {"box": [171, 630, 269, 762], "vertical": true, "font_size": 28.0, "lines": ["ハハハ", "そんなに", "警戒するなよ"]}, {"box": [895, 724, 929, 832], "vertical": true, "font_size": 20.0, "lines": ["加持さん．．．"]}, {"box": [864, 1020, 967, 1153], "vertical": true, "font_size": 28.0, "lines": ["君と少し", "話もしたいし", "ね"]}, {"box": [130, 825, 189, 915], "vertical": true, "font_size": 28.0, "lines": ["いいから", "乗りなよ"]}], "img_path": "img173.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [825, 446, 922, 622], "vertical": true, "font_size": 25.0, "lines": ["この間のことなら", "僕誰にも言い", "ませんよ"]}, {"box": [502, 443, 590, 576], "vertical": true, "font_size": 23.0, "lines": ["そうして", "もらえると", "ありがたいな"]}, {"box": [371, 448, 460, 602], "vertical": true, "font_size": 24.0, "lines": ["ミサトさんにも", "忘れろって", "言われました"]}, {"box": [403, 698, 466, 807], "vertical": true, "font_size": 23.0, "lines": ["忘れろと", "言われたら"]}, {"box": [636, 987, 670, 1057], "vertical": true, "font_size": 26.0, "lines": ["俺はね"]}, {"box": [303, 998, 401, 1152], "vertical": true, "font_size": 24.0, "lines": ["君があれを見て", "良かったと", "思っているんだ"]}, {"box": [80, 708, 149, 841], "vertical": true, "font_size": 28.0, "lines": ["忘れられるの", "かい？"]}, {"box": [733, 1308, 755, 1408], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．"]}, {"box": [471, 1255, 504, 1344], "vertical": true, "font_size": 26.0, "lines": ["シンジ君"]}], "img_path": "img174.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [867, 128, 959, 325], "vertical": true, "font_size": 22.0, "lines": ["君にはちっともっと", "知らなきゃいけない", "ことが沢山ある"]}, {"box": [152, 465, 221, 599], "vertical": true, "font_size": 25.0, "lines": ["少し寄り道を", "しようか"]}, {"box": [800, 883, 833, 1002], "vertical": true, "font_size": 25.0, "lines": ["シンジ君．．"]}, {"box": [160, 1132, 261, 1329], "vertical": true, "font_size": 28.0, "lines": ["ネルフについて", "どれくらいの事を", "知ってる？"]}], "img_path": "img175.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [807, 126, 906, 352], "vertical": true, "font_size": 26.0, "lines": ["「使徒」と呼称されてる", "正体不明の敵と戦い", "たおす"]}, {"box": [716, 352, 803, 528], "vertical": true, "font_size": 26.0, "lines": ["単にそれだけの", "特務機関だと", "思ってるだろう？"]}, {"box": [803, 595, 928, 806], "vertical": true, "font_size": 26.0, "lines": ["あと．．．", "予想される", "サード・インパクトを", "未然に防ぐ．．．とか"]}, {"box": [650, 605, 705, 778], "vertical": true, "font_size": 23.0, "lines": ["アスカの", "受けうりですけど"]}, {"box": [429, 609, 589, 830], "vertical": true, "font_size": 24.0, "lines": ["．．．使徒が", "第３新東京近郊に", "ばかり現れるのを", "不思議に思ったことは", "ないかい？"]}, {"box": [112, 379, 173, 538], "vertical": true, "font_size": 29.0, "lines": ["はい．．．な", "違うんですか？"]}, {"box": [78, 614, 199, 854], "vertical": true, "font_size": 24.0, "lines": ["そしてそれを", "予知していたかのような", "本部頭上の迎撃システム", "そしてエヴァ．．．"]}, {"box": [359, 710, 410, 950], "vertical": true, "font_size": 24.0, "lines": ["まるでネルフ本部を", "狙っているかのようにだ"]}, {"box": [860, 1059, 922, 1206], "vertical": true, "font_size": 25.0, "lines": ["どういう", "ことですか？"]}, {"box": [152, 1142, 249, 1318], "vertical": true, "font_size": 22.0, "lines": ["すべては最初から", "仕組まれている", "ということさ"]}], "img_path": "img176.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [800, 110, 930, 288], "vertical": true, "font_size": 24.0, "lines": ["君のお父さんは", "これから起こる", "すべてのことを", "知っているはずだ"]}, {"box": [566, 123, 590, 213], "vertical": true, "font_size": 24.0, "lines": ["そんな．．．"]}, {"box": [369, 122, 430, 216], "vertical": true, "font_size": 30.0, "lines": ["でも", "なぜ．．．？"]}, {"box": [668, 510, 761, 622], "vertical": true, "font_size": 28.0, "lines": ["そして", "セカンド・", "インパクト"]}, {"box": [446, 583, 545, 737], "vertical": true, "font_size": 25.0, "lines": ["君のお父さんの", "背後に付いてる", "組織の名称だ"]}, {"box": [195, 401, 224, 495], "vertical": true, "font_size": 26.0, "lines": ["“ゼーレ”"]}, {"box": [813, 1089, 911, 1295], "vertical": true, "font_size": 25.0, "lines": ["おそらくあの事件が", "あの日起こることも", "予測していた"]}, {"box": [374, 1050, 501, 1313], "vertical": true, "font_size": 24.0, "lines": ["古より", "世界を裏で", "動かしているといわれてる", "権力者の集団だ"]}, {"box": [123, 1259, 189, 1434], "vertical": true, "font_size": 23.0, "lines": ["ネルフの資金も", "そこから出ている"]}], "img_path": "img177.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [810, 116, 899, 289], "vertical": true, "font_size": 25.0, "lines": ["そのゼーレが", "所有し彼らの", "教典ともなってる"]}, {"box": [235, 125, 328, 410], "vertical": true, "font_size": 25.0, "lines": ["人類がこの世に現れた時には", "既にそこに在ったといわれる", "謎の古文書！"]}, {"box": [81, 225, 205, 500], "vertical": true, "font_size": 25.0, "lines": ["俺の調べた事が正しければ", "その古文書は一種預言書の", "ようなもので人の歴史の", "すべてが示されている"]}, {"box": [730, 344, 758, 462], "vertical": true, "font_size": 25.0, "lines": ["死海文書〟"]}, {"box": [902, 614, 922, 763], "vertical": true, "font_size": 22.0, "lines": ["今までのことも"]}, {"box": [283, 612, 375, 855], "vertical": true, "font_size": 25.0, "lines": ["その死海文書に基づき", "ゼーレと君のお父さんは", "ある計画を立てた"]}, {"box": [835, 651, 863, 923], "vertical": true, "font_size": 22.0, "lines": ["そしてこれからのことも．．．"]}, {"box": [391, 1047, 479, 1168], "vertical": true, "font_size": 32.0, "lines": ["待って", "下さい！"]}, {"box": [82, 745, 237, 986], "vertical": true, "font_size": 25.0, "lines": ["ゼーレが君のお父さんを", "利用しているのか", "君のお父さんがゼーレを", "利用しているのかは", "わからないが"]}, {"box": [813, 1084, 913, 1261], "vertical": true, "font_size": 28.0, "lines": ["使徒との戦いは", "その計画の序盤で", "しかない"]}], "img_path": "img178.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [873, 93, 969, 247], "vertical": true, "font_size": 24.0, "lines": ["待って下さい．．．", "なぜそんなこと", "僕に言うんです"]}, {"box": [659, 96, 755, 291], "vertical": true, "font_size": 22.0, "lines": ["なぜ僕がそんなこと", "知らなきゃ", "いけないんですか？"]}, {"box": [553, 69, 588, 269], "vertical": true, "font_size": 24.0, "lines": ["父さんにとって僕は"]}, {"box": [430, 275, 498, 427], "vertical": true, "font_size": 21.0, "lines": ["歯車のひとつで", "しかないのに"]}, {"box": [104, 80, 214, 298], "vertical": true, "font_size": 29.0, "lines": ["僕がそんなこと", "知ったって仕方ない", "じゃないですか！！"]}, {"box": [868, 522, 937, 656], "vertical": true, "font_size": 26.0, "lines": ["君には真実を", "知る権利と"]}, {"box": [177, 568, 247, 704], "vertical": true, "font_size": 30.0, "lines": ["そして義務が", "ある"]}, {"box": [820, 787, 947, 986], "vertical": true, "font_size": 25.0, "lines": ["碇ゲンドウと", "エヴァを作り出した", "碇ユイの子供として", "生まれたからにはね"]}, {"box": [542, 1126, 580, 1247], "vertical": true, "font_size": 25.0, "lines": ["母さん．．．？"]}], "img_path": "img179.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [876, 58, 934, 233], "vertical": true, "font_size": 25.0, "lines": ["“アダム”より", "生まれし。エヴァ”"]}, {"box": [656, 53, 755, 230], "vertical": true, "font_size": 24.0, "lines": ["その基礎理論を", "解いたのは", "君のお母さんだよ"]}, {"box": [494, 96, 560, 228], "vertical": true, "font_size": 26.0, "lines": ["僕が知ってる", "母さんは"]}, {"box": [363, 101, 431, 250], "vertical": true, "font_size": 25.0, "lines": ["学者なんかじゃ", "なかった"]}, {"box": [222, 106, 323, 205], "vertical": true, "font_size": 32.0, "lines": ["普通のかぁ", "お母さん", "だった"]}, {"box": [603, 513, 699, 685], "vertical": true, "font_size": 20.0, "lines": ["君のお母さんは", "優秀な生物工学の", "先駆者だった"]}, {"box": [420, 469, 553, 564], "vertical": true, "font_size": 31.0, "lines": ["父さんのじっけん", "実験の", "被験者に", "されて"]}, {"box": [82, 477, 145, 611], "vertical": true, "font_size": 29.0, "lines": ["そして", "死んだって．．．"]}, {"box": [867, 785, 932, 917], "vertical": true, "font_size": 24.0, "lines": ["そう人から", "聞いたのか？"]}, {"box": [673, 877, 769, 1030], "vertical": true, "font_size": 28.0, "lines": ["いや君は", "その目で", "見ているはずだ"]}, {"box": [133, 825, 196, 999], "vertical": true, "font_size": 22.0, "lines": ["お母さんが", "消えるその瞬間を"]}, {"box": [540, 1121, 634, 1340], "vertical": true, "font_size": 23.0, "lines": ["君はつらいことを", "無意識に記憶から", "締め出しているだけだ"]}], "img_path": "img180.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [925, 87, 955, 109], "vertical": false, "font_size": 22.0, "lines": ["何だ？"]}, {"box": [605, 82, 671, 216], "vertical": true, "font_size": 22.0, "lines": ["今日は大事な", "実験の日だぞ"]}, {"box": [776, 485, 826, 584], "vertical": true, "font_size": 19.0, "lines": ["なぜここに", "子供がいる"]}, {"box": [634, 695, 727, 721], "vertical": false, "font_size": 20.0, "lines": ["はいはい。そういう"]}, {"box": [886, 710, 942, 839], "vertical": true, "font_size": 22.0, "lines": ["ごめんなさい", "冬月先生"]}, {"box": [679, 758, 844, 803], "vertical": false, "font_size": 21.0, "lines": ["．．．", "ＦｕｓｏｒｄＰｏｌｌＺＡＴＯＮＴＥＳＴＭＯ－１８－１２．１３．１"]}, {"box": [702, 793, 772, 819], "vertical": false, "font_size": 21.0, "lines": ["．．．"]}, {"box": [899, 1011, 959, 1102], "vertical": true, "font_size": 30.0, "lines": ["だから", "なんです"]}, {"box": [604, 800, 670, 915], "vertical": true, "font_size": 27.0, "lines": ["私が連れて", "来たんです"]}, {"box": [478, 711, 512, 779], "vertical": true, "font_size": 28.0, "lines": ["ユイ君"]}, {"box": [116, 778, 182, 910], "vertical": true, "font_size": 22.0, "lines": ["今日は君の", "実験なんだぞ"]}, {"box": [480, 1150, 630, 1350], "vertical": true, "font_size": 32.0, "lines": ["この子には人類の", "明るい未来を", "見せておきたいん", "です"]}], "img_path": "img181.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [909, 61, 935, 146], "vertical": true, "font_size": 26.0, "lines": ["そうだ"]}, {"box": [636, 179, 657, 268], "vertical": true, "font_size": 16.0, "lines": ["どうした"]}, {"box": [496, 273, 568, 426], "vertical": true, "font_size": 32.0, "lines": ["僕は", "知っていた"]}, {"box": [864, 366, 896, 519], "vertical": true, "font_size": 20.0, "lines": ["何が起こった！？"]}, {"box": [721, 635, 790, 746], "vertical": true, "font_size": 29.0, "lines": ["脳波心音という", "共に停止！"]}, {"box": [515, 542, 591, 716], "vertical": true, "font_size": 25.0, "lines": ["被験者生命反応", "がありません！！"]}, {"box": [314, 570, 359, 686], "vertical": true, "font_size": 30.0, "lines": ["回路切断"]}, {"box": [852, 854, 947, 1092], "vertical": true, "font_size": 32.0, "lines": ["僕はエヴァを", "知っていた．．．！？"]}, {"box": [116, 708, 208, 829], "vertical": true, "font_size": 32.0, "lines": ["実験中止", "だ！！"]}, {"box": [394, 1140, 416, 1226], "vertical": true, "font_size": 20.0, "lines": ["すまない"]}, {"box": [117, 1283, 186, 1437], "vertical": true, "font_size": 25.0, "lines": ["ムリに思い出さ", "なくていい"]}], "img_path": "img182.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [851, 72, 879, 218], "vertical": true, "font_size": 26.0, "lines": ["だがシンジ君"]}, {"box": [733, 168, 796, 314], "vertical": true, "font_size": 26.0, "lines": ["目を背けては", "いけない"]}, {"box": [144, 685, 244, 766], "vertical": true, "font_size": 32.0, "lines": ["真実", "から"]}, {"box": [856, 1079, 892, 1105], "vertical": false, "font_size": 20.0, "lines": ["碇"]}, {"box": [136, 1251, 236, 1404], "vertical": true, "font_size": 23.0, "lines": ["停電の件", "委員会には報告", "したのか？"]}], "img_path": "img183.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [825, 107, 918, 202], "vertical": true, "font_size": 30.0, "lines": ["ああ", "“事故”と", "してな"]}, {"box": [510, 104, 575, 277], "vertical": true, "font_size": 23.0, "lines": ["それで納得する", "連中ではあるまい"]}, {"box": [355, 103, 451, 279], "vertical": true, "font_size": 24.0, "lines": ["シナリオ通りに", "事が進んでいれば", "支障はない"]}, {"box": [77, 417, 178, 571], "vertical": true, "font_size": 24.0, "lines": ["あの男の始末．．．", "どうするつもり", "かね？"]}, {"box": [854, 691, 917, 843], "vertical": true, "font_size": 20.0, "lines": ["今しばらくは", "泳がせておくよ"]}, {"box": [859, 957, 922, 1089], "vertical": true, "font_size": 22.0, "lines": ["アダム計画は", "どうなんだ"]}, {"box": [586, 966, 616, 1137], "vertical": true, "font_size": 25.0, "lines": ["ロンギヌスの槍は"]}, {"box": [84, 699, 212, 813], "vertical": true, "font_size": 28.0, "lines": ["あれで", "なかなか", "利用価値は", "ある"]}, {"box": [285, 963, 319, 1072], "vertical": true, "font_size": 25.0, "lines": ["予定通りだ"]}, {"box": [730, 1172, 764, 1245], "vertical": true, "font_size": 28.0, "lines": ["順調だ"]}, {"box": [669, 1214, 726, 1370], "vertical": true, "font_size": 28.0, "lines": ["２％も", "遅れてはいない"]}], "img_path": "img184.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [835, 71, 900, 203], "vertical": true, "font_size": 26.0, "lines": ["作業はレイが", "行っている"]}], "img_path": "img185.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [], "img_path": "img186.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [69, 71, 100, 251], "vertical": true, "font_size": 31.0, "lines": ["ＮＧＥ－－－"]}], "img_path": "img187.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [372, 82, 697, 135], "vertical": false, "font_size": 21.0, "lines": ["ＣＯＳＨＩＹＵＫＩｓＡロＡＭＯＴＯ"]}, {"box": [358, 185, 694, 540], "vertical": false, "font_size": 24.0, "lines": ["貞本務行（さだもとよしゅき）●１９５２", "年１月２９日生まれ。血液型Ａ型。山", "口県徳山市出身。東京造形大学卒業", "後、アニメーターとなる。キャラク", "ター・テサイナー、作画監督として", "活躍。代表作品「オネアミスの翼王", "立宇宙軍「トップをねらえノ」ふし", "ぎの海のナティア「新世紀エウァン", "ゲリオン」等。５６年２月号より月刊", "少年エースにて「新世紀エヴァンゲリ", "オン」を連載。現在ＧＡＮＡＸ所属。"]}, {"box": [455, 675, 596, 694], "vertical": false, "font_size": 19.0, "lines": ["ＳＴＡＦＦＬＥＴ"]}, {"box": [359, 763, 494, 785], "vertical": false, "font_size": 20.0, "lines": ["Ｔｈｅａｕｔｈｏ"]}, {"box": [360, 832, 478, 851], "vertical": false, "font_size": 20.0, "lines": ["Ａｓｓｌｅｔａｎｔ"]}, {"box": [608, 765, 686, 781], "vertical": false, "font_size": 18.0, "lines": ["貞本あ行"]}, {"box": [598, 832, 691, 915], "vertical": false, "font_size": 18.0, "lines": ["きりたりな", "ははは．．．", "近藤一馬"]}, {"box": [663, 1088, 692, 1113], "vertical": false, "font_size": 18.0, "lines": ["子"]}, {"box": [391, 1156, 656, 1183], "vertical": false, "font_size": 21.0, "lines": ["ＴｈｅｏｒｉｇｈａｌＧＡＮＡＸ"]}, {"box": [415, 1222, 638, 1249], "vertical": false, "font_size": 21.0, "lines": ["ＴｈｅｎｋｓｔｏＭＡＫＯ"]}], "img_path": "img188.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [272, 502, 539, 522], "vertical": false, "font_size": 20.0, "lines": ["ＫａｄｏｋｏｗａｃｏｍｉｃｓＡ"]}, {"box": [311, 548, 490, 574], "vertical": false, "font_size": 24.0, "lines": ["角川コミックス・エース"]}, {"box": [222, 584, 544, 695], "vertical": false, "font_size": 31.666666666666668, "lines": ["新世紀エヴァンゲリオン©", "漫画漫画", "貞本義行"]