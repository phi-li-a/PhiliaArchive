box": [110, 503, 243, 680], "vertical": true, "font_size": 24.0, "lines": ["同時に日本政府", "内務省調査部所属", "加持リョウジでも", "あるわけね"]}, {"box": [930, 913, 958, 1021], "vertical": true, "font_size": 24.0, "lines": ["ハレハレカ"]}, {"box": [563, 707, 649, 817], "vertical": true, "font_size": 26.0, "lines": ["それとも", "アルバイト", "かしら"]}, {"box": [487, 897, 547, 1068], "vertical": true, "font_size": 23.0, "lines": ["ネルフを", "甘く見ないで！！"]}, {"box": [346, 921, 438, 1054], "vertical": true, "font_size": 26.0, "lines": ["今は私の", "胸の中だけに", "留めておくわ"]}, {"box": [279, 971, 308, 1022], "vertical": true, "font_size": 26.0, "lines": ["でも"]}, {"box": [119, 1162, 188, 1382], "vertical": true, "font_size": 25.0, "lines": ["これ以上アルバイトを", "続けると死ぬわよ"]}], "img_path": "img153.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [896, 84, 924, 229], "vertical": true, "font_size": 25.0, "lines": ["まだいけるさ"]}, {"box": [427, 117, 526, 295], "vertical": true, "font_size": 26.0, "lines": ["だけど葛城に", "隠し事してたのは", "謝るよ"]}, {"box": [103, 410, 180, 595], "vertical": true, "font_size": 28.0, "lines": ["謝られても", "嬉しくないわよ"]}, {"box": [875, 995, 946, 1212], "vertical": true, "font_size": 24.0, "lines": ["司令やリッちゃんも", "君に隠し事をしてる"]}, {"box": [589, 740, 722, 897], "vertical": true, "font_size": 25.0, "lines": ["碇司令は", "オレの正体に", "気づきながらも", "利用してる"]}, {"box": [243, 694, 303, 861], "vertical": true, "font_size": 23.0, "lines": ["じゃあいい事を", "教えてやろう"]}, {"box": [94, 998, 208, 1041], "vertical": false, "font_size": 32.0, "lines": ["Ｃｉｓｓ"]}, {"box": [122, 1207, 192, 1287], "vertical": true, "font_size": 32.0, "lines": ["それが", "これさ"]}], "img_path": "img154.jpg"}, {"version": "0.1.6", "img_width": 1045, "img_height": 1490, "blocks": [{"box": [324, 155, 637, 187], "vertical": false, "font_size": 23.0, "lines": ["ＬＣＬＰＬＡＮＴ．ＯＬ３ＳＥＧ"]}, {"box": [302, 162, 641, 306], "vertical": false, "font_size": 24.0, "lines": ["ＦＥＣＯＣＡＩＺＡＧＳＹＳＴＥＭ", "それですかわいいのですが、人の仲間になります。と"]}], "img_path": "img155.jpg"}, {"version": "0.1.6", "img_width"