, 575, 599], "vertical": true, "font_size": 32.0, "lines": ["それが", "ファースト・インパクト"]}, {"box": [192, 307, 298, 582], "vertical": true, "font_size": 28.0, "lines": ["宇宙の塵となりやがて", "衛星となったその星が", "地中深く残したモノ"]}, {"box": [76, 514, 142, 695], "vertical": true, "font_size": 28.0, "lines": ["その生命の卵が", "リリス"]}, {"box": [300, 796, 336, 878], "vertical": true, "font_size": 32.0, "lines": ["対して"]}, {"box": [187, 904, 295, 1164], "vertical": true, "font_size": 32.0, "lines": ["地球自体が昔から", "宿していた生命の卵が", "アダム"]}, {"box": [736, 1181, 851, 1414], "vertical": true, "font_size": 30.0, "lines": ["ひとつの天体と共に", "生命の卵が", "この星に落ちた"]}, {"box": [282, 1315, 329, 1332], "vertical": false, "font_size": 17.0, "lines": ["．．．"]}], "img_path": "eva12_097.jpg"}, {"version": "0.1.6", "img_width": 1098, "img_height": 1600, "blocks": [{"box": [609, 143, 718, 326], "vertical": true, "font_size": 29.0, "lines": ["アダムは", "自身を含む", "１２の使徒を生み"]}, {"box": [357, 80, 391, 184], "vertical": true, "font_size": 27.0, "lines": ["シンジ君"]}, {"box": [337, 700, 412, 809], "vertical": true, "font_size": 30.0, "lines": ["私たち", "人間はね"]}, {"box": [882, 1162, 988, 1396], "vertical": true, "font_size": 30.0, "lines": ["それがゼーレの", "〈裏〉死海文書に", "示されていた名前よ。"]}, {"box": [482, 1153, 627, 1309], "vertical": true, "font_size": 28.0, "lines": ["リリスも", "同じように", "１つの使徒を", "生んだ"]}, {"box": [118, 1182, 312, 1390], "vertical": true, "font_size": 28.0, "lines": ["本来なら", "この星に生まれる", "はずのなかった", "１３番目の", "使徒なのよ"]}], "img_path": "eva12_098.jpg"}, {"version": "0.1.6", "img_width": 1094, "img_height": 1600, "blocks": [{"box": [838, 109, 941, 251], "vertical": true, "font_size": 29.0, "lines": ["１５年前の", "セカンド・", "インパクトは"]}, {"box": [143, 203, 249, 370], "vertical": true, "font_size": 27.0, "lines": ["人の手によって", "仕組まれたもの", "だったの"]}, {"box": [840, 470, 908, 546], "vertical": true, "font_size": 32.0, "lines": ["けど", "それは"]}, {"box": [364, 510, 537, 675], "vertical": true, "font_size": 26.0, "lines": ["他の使徒が", "覚醒する前に", "アダムを卵に", "還元することに", "よって"]}, {"box": [98, 529, 238, 743], "vertical": true, "font_size": 25.0, "lines": ["儀式の延引と", "その被害を", "最小限に食い止める", "ためだったのよ"]}, {"box": [806, 832, 945, 953], "vertical": true, "font_size": 29.0, "lines": ["他の使徒", "たちは", "別の可能性", "だったの"]}, {"box": [504, 812, 648, 1004], "vertical": true, "font_size": 25.0, "lines": ["使徒たちが", "ジオフロントの", "リリスを目指した", "のは"]}, {"box": [825, 1284, 927, 1426], "vertical": true, "font_size": 26.0, "lines": ["ヒトの形とは", "異なった", "人類のね．．．"]}, {"box": [346, 1176, 440, 1364], "vertical": true, "font_size": 25.0, "lines": ["失われた", "アダムの代わりに", "リリスと融合し"]}, {"box": [132, 1250, 262, 1485], "vertical": true, "font_size": 25.0, "lines": ["すべての種を滅ぼし", "自らが新しい種として", "この星で生き残る", "ためなのよ"]}], "img_path": "eva12_099.jpg"}, {"version": "0.1.6", "img_width": 1095, "img_height": 1600, "blocks": [{"box": [878, 93, 1006, 326], "vertical": true, "font_size": 23.0, "lines": ["あなたたち", "パイロットはエヴァで", "すべての使徒を倒し", "人類を守った"]}, {"box": [479, 106, 515, 167], "vertical": true, "font_size": 32.0, "lines": ["でも"]}, {"box": [115, 200, 246, 421], "vertical": true, "font_size": 26.0, "lines": ["ゼーレとあなたの", "お父さんは未だ", "サード・インパクトを", "望んでいるわ"]}, {"box": [877, 573, 937, 762], "vertical": true, "font_size": 28.0, "lines": ["最後の使徒である", "ヒトを滅ぼし"]}, {"box": [693, 703, 795, 823], "vertical": true, "font_size": 28.0, "lines": ["新たな", "生命体へと", "進化させる"]}, {"box": [954, 929, 976, 1022], "vertical": true, "font_size": 22.0, "lines": ["もっとも"]}, {"box": [563, 970, 659, 1111], "vertical": true, "font_size": 26.0, "lines": ["エヴァは", "補完計画の", "鍵を握ってる"]}, {"box": [131, 726, 199, 882], "vertical": true, "font_size": 30.0, "lines": ["それが", "人類補完計画"]}, {"box": [707, 1309, 870, 1493], "vertical": true, "font_size": 26.0, "lines": ["ゼーレと", "お父さんの", "望む方向は", "最終的に違ってる", "ようだけどね"]}, {"box": [151, 1385, 186, 1489], "vertical": true, "font_size": 28.0, "lines": ["シンジ君"]}], "img_path": "eva12_100.jpg"}, {"version": "0.1.6", "img_width": 1094, "img_height": 1600, "blocks": [{"box": [78, 234, 178, 398], "vertical": true, "font_s