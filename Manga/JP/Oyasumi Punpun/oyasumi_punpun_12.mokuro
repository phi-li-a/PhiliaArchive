282.0]], [[179.0, 193.0], [200.0, 193.0], [200.0, 256.0], [179.0, 256.0]]], "lines": ["勝手に調べ", "ないでくださいよ", "失礼な人達", "だなァ。"]}, {"box": [135, 378, 194, 485], "vertical": true, "font_size": 19, "lines_coords": [[[178.0, 379.0], [194.0, 379.0], [194.0, 480.0], [178.0, 480.0]], [[156.0, 378.0], [173.0, 378.0], [173.0, 481.0], [156.0, 481.0]], [[135.0, 378.0], [152.0, 378.0], [152.0, 485.0], [135.0, 485.0]]], "lines": ["弁当屋だって", "もう１０年以上", "前の話ですよ。"]}, {"box": [658, 562, 719, 685], "vertical": true, "font_size": 19, "lines_coords": [[[698.0, 563.0], [719.0, 563.0], [716.0, 635.0], [695.0, 635.0]], [[677.0, 564.0], [697.0, 564.0], [697.0, 685.0], [677.0, 685.0]], [[659.0, 562.0], [675.0, 562.0], [674.0, 675.0], [658.0, 675.0]]], "lines": ["店継いて", "親孝行しとけば", "よかったのに。"]}, {"box": [715, 854, 745, 919], "vertical": true, "font_size": 30, "lines_coords": [[[715.0, 854.0], [745.0, 854.0], [745.0, 919.0], [715.0, 919.0]]], "lines": ["あ．．．"]}, {"box": [366, 773, 387, 861], "vertical": true, "font_size": 19, "lines_coords": [[[366.0, 773.0], [387.0, 773.0], [387.0, 861.0], [366.0, 861.0]]], "lines": ["ははは．．．"]}, {"box": [134, 602, 194, 705], "vertical": true, "font_size": 18, "lines_coords": [[[176.0, 603.0], [194.0, 603.0], [192.0, 705.0], [174.0, 705.0]], [[153.0, 603.0], [173.0, 603.0], [173.0, 673.0], [153.0, 673.0]], [[134.0, 602.0], [151.0, 602.0], [151.0, 697.0], [134.0, 697.0]]], "lines": ["．．．って無理か", "火が苦手", "なんじゃあ。"]}, {"box": [506, 972, 586, 1110], "vertical": true, "font_size": 21, "lines_coords": [[[570.0, 975.0], [586.0, 975.0], [586.0, 1110.0], [570.0, 1110.0]], [[548.0, 973.0], [568.0, 973.0], [568.0, 1079.0], [548.0, 1079.0]], [[527.0, 972.0], [547.0, 972.0], [544.0, 1078.0], [524.0, 1078.0]], [[506.0, 972.0], [527.0, 972.0], [527.0, 1045.0], [506.0, 1045.0]]], "lines": ["彼女さんちの台所", "電気コンロに", "変えさせたん", "でしょ？"]}, {"box": [289, 848, 349, 952], "vertical": true, "font_size": 19, "lines_coords": [[[332.0, 848.0], [349.0, 848.0], [349.0, 936.0], [332.0, 936.0]], [[312.0, 849.0], [329.0, 849.0], [326.0, 952.0], [310.0, 952.0]], [[289.0, 848.0], [309.0, 848.0], [309.0, 952.0], [289.0, 952.0]]], "lines": ["ウチの犬と", "同じ反応して", "るわーー．．．"]}, {"box": [419, 1053, 483, 1123], "vertical": true, "font_size": 21, "lines_coords": [[[456.0, 1053.0], [483.0, 1053.0], [483.0, 1095.0], [456.0, 1095.0]], [[440.0, 1054.0], [460.0, 1054.0], [460.0, 1123.0], [440.0, 1123.0]], [[419.0, 1054.0], [440.0, 1054.0], [440.0, 1108.0], [419.0, 1108.0]]], "lines": ["何か", "トラウマ", "なの？"]}, {"box": [119, 987, 179, 1114], "vertical": true, "font_size": 17, "lines_coords": [[[159.0, 987.0], [179.0, 987.0], [179.0, 1092.0], [159.0, 1092.0]], [[139.0, 989.0], [155.0, 989.0], [155.0, 1108.0], [139.0, 1108.0]], [[119.0, 989.0], [134.0, 989.0], [134.0, 1114.0], [119.0, 1114.0]]], "lines": ["おでこの所に", "オール電化って", "刺青入れようよ。"]}], "img_path": "224.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [682, 64, 743, 168], "vertical": true, "font_size": 20, "lines_coords": [[[723.0, 65.0], [743.0, 65.0], [743.0, 135.0], [723.0, 135.0]], [[705.0, 66.0], [721.0, 66.0], [721.0, 168.0], [705.0, 168.0]], [[682.0, 64.0], [702.0, 64.0], [702.0, 137.0], [682.0, 137.0]]], "lines": ["．．．それは", "いいアイデア", "ですね！！"]}, {"box": [611, 173, 680, 275], "vertical": true, "font_size": 20, "lines_coords": [[[650.0, 174.0], [678.0, 173.0], [680.0, 221.0], [652.0, 222.0]], [[632.0, 179.0], [653.0, 179.0], [653.0, 257.0], [632.0, 257.0]], [[611.0, 179.0], [627.0, 179.0], [627.0, 275.0], [611.0, 275.0]]], "lines": ["ぜひ", "そうして", "ください！！"]}, {"box": [351, 105, 393, 176], "vertical": true, "font_size": 22, "lines_coords": [[[373.0, 105.0], [393.0, 105.0], [393.0, 176.0], [373.0, 176.0]], [[351.0, 106.0], [374.0, 106.0], [374.0, 144.0], [351.0, 144.0]]], "lines": ["関さーん", "．．．"]}, {"box": [677, 548, 727, 629], "vertical": true, "font_size": 24, "lines_coords": [[[695.0, 548.0], [727.0, 548.0], [727.0, 602.0], [695.0, 602.0]], [[677.0, 549.0], [701.0, 549.0], [701.0, 629.0], [677.0, 629.0]]], "lines": ["．．．ん、", "よしッ！！"]}, {"box": [141, 325, 223, 430], "vertical": true, "font_size": 18, "lines_coords": [[[202.0, 325.0], [223.0, 325.0], [223.0, 380.0], [202.0, 380.0]], [[183.0, 326.0], [200.0, 326.0], [200.0, 413.0], [183.0, 413.0]], [[162.0, 328.0], [179.0, 328.0], [179.0, 413.0], [162.0, 413.0]], [[141.0, 328.0], [158.0, 328.0], [158.0, 427.0], [141.0, 427.0]]], "lines": ["意地の", "張りどころ", "間違えたら", "損だよ～～．．．"]}, {"box": [571, 587, 640, 686], "vertical": true, "font_size": 24, "lines_coords": [[[616.0, 587.0], [640.0, 587.0], [640.0, 651.0], [616.0, 651.0]], [[593.0, 590.0], [615.0, 590.0], [615.0, 666.0], [593.0, 666.0]], [[571.0, 589.0], [591.0, 589.0], [591.0, 686.0], [571.0, 686.0]]], "lines": ["じゃあ", "歯ァ食い", "しばって！！"]}, {"box": [657, 812, 707, 912], "vertical": true, "font_size": 20, "lines_coords": [[[686.0, 813.0], [707.0, 813.0], [707.0, 904.0], [686.0, 904.0]], [[658.0, 813.0], [678.0, 813.0], [678.0, 911.0], [658.0, 911.0]]], "lines": ["そんな事", "言わずに、"]}, {"box": [139, 591, 206, 708], "vertical": true, "font_size": 20, "lines_coords": [[[181.0, 591.0], [206.0, 591.0], [206.0, 655.0], [181.0, 655.0]], [[159.0, 594.0], [179.0, 594.0], [179.0, 708.0], [159.0, 708.0]], [[139.0, 595.0], [155.0, 595.0], [155.0, 689.0], [139.0, 689.0]]], "lines": ["走馬灯", "見ないように", "かんばろ！！"]}, {"box": [148, 990, 201, 1128], "vertical": true, "font_size": 24, "lines_coords": [[[175.0, 991.0], [200.0, 991.0], [200.0, 1128.0], [175.0, 1128.0]], [[148.0, 990.0], [171.0, 990.0], [171.0, 1106.0], [148.0, 1106.0]]], "lines": ["いっそ殺して", "ください！！"]}], "img_path": "225.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [713, 153, 753, 307], "vertical": true, "font_size": 18, "lines_coords": [[[733.0, 153.0], [753.0, 153.0], [753.0, 249.0], [733.0, 249.0]], [[713.0, 153.0], [729.0, 153.0], [729.0, 307.0], [713.0, 307.0]]], "lines": ["「．．．．．．ねぇ！！", "続きはいつ読める！？"]}, {"box": [651, 152, 692, 297], "vertical": true, "font_size": 18, "lines_coords": [[[672.0, 152.0], [692.0, 152.0], [692.0, 291.0], [672.0, 291.0]], [[652.0, 153.0], [670.0, 153.0], [668.0, 297.0], [651.0, 297.0]]], "lines": ["今度は友達連れて", "来てもいいよね！？」"]}, {"box": [390, 206, 435, 241], "vertical": false, "font_size": 14, "lines_coords": [[[394.0, 219.0], [427.0, 219.0], [427.0, 234.0], [394.0, 234.0]], [[394.0, 229.0], [434.0, 229.0], [434.0, 241.0], [394.0, 241.0]]], "lines": ["．．．", "待て待って！！"]}, {"box": [182, 145, 243, 356], "vertical": true, "font_size": 19, "lines_coords": [[[226.0, 145.0], [243.0, 145.0], [242.0, 264.0], [224.0, 264.0]], [[205.0, 147.0], [221.0, 147.0], [221.0, 317.0], [205.0, 317.0]], [[182.0, 145.0], [199.0, 145.0], [199.0, 356.0], [182.0, 356.0]]], "lines": ["「．．．今日は特別。", "本当は描きかけなんか", "絶対見せたくないんだから、"]}, {"box": [91, 144, 154, 318], "vertical": true, "font_size": 19, "lines_coords": [[[134.0, 144.0], [154.0, 144.0], [153.0, 318.0], [133.0, 318.0]], [[113.0, 144.0], [134.0, 144.0], [130.0, 318.0], [108.0, 318.0]], [[93.0, 144.0], [113.0, 144.0], [111.0, 242.0], [91.0, 242.0]]], "lines": ["．．．と言いつつ最後まで", "描ききった事ないんだ", "けどね．．．．．．"]}, {"box": [674, 610, 713, 680], "vertical": true, "font_size": 17, "lines_coords": [[[693.0, 610.0], [713.0, 610.0], [713.0, 680.0], [693.0, 680.0]], [[674.0, 611.0], [691.0, 611.0], [691.0, 679.0], [674.0, 679.0]]], "lines": ["おーい", "ボウズー"]}, {"box": [571, 664, 634, 768], "vertical": true, "font_size": 17, "lines_coords": [[[615.0, 664.0], [634.0, 664.0], [634.0, 735.0], [615.0, 735.0]], [[595.0, 665.0], [611.0, 665.0], [611.0, 768.0], [595.0, 768.0]], [[574.0, 664.0], [591.0, 664.0], [589.0, 733.0], [571.0, 733.0]]], "lines": ["こっちで", "オジさん達と", "遊ぶかー"]}, {"box": [575, 737, 589, 766], "vertical": true, "font_size": 17, "lines_coords": [[[575.0, 737.0], [589.0, 737.0], [589.0, 766.0], [575.0, 766.0]]], "lines": ["ーっ"]}, {"box": [241, 607, 284, 693], "vertical": true, "font_size": 18, "lines_coords": [[[264.0, 607.0], [284.0, 607.0], [284.0, 684.0], [264.0, 684.0]], [[241.0, 608.0], [261.0, 608.0], [261.0, 693.0], [241.0, 693.0]]], "lines": ["呼んでも", "ムダムダ。"]}, {"box": [132, 651, 212, 771], "vertical": true, "font_size": 18, "lines_coords": [[[190.0, 651.0], [212.0, 651.0], [212.0, 710.0], [190.0, 710.0]], [[172.0, 652.0], [188.0, 652.0], [188.0, 739.0], [172.0, 739.0]], [[151.0, 653.0], [167.0, 653.0], [167.0, 771.0], [151.0, 771.0]], [[132.0, 653.0], [145.0, 653.0], [145.0, 724.0], [132.0, 724.0]]], "lines": ["アイツ、", "強がってる", "わりに人見知り", "だからよ"]}, {"box": [651, 882, 714, 1020], "vertical": true, "font_size": 17, "lines_coords": [[[692.0, 882.0], [714.0, 882.0], [714.0, 935.0], [692.0, 935.0]], [[673.0, 883.0], [690.0, 883.0], [690.0, 1003.0], [673.0, 1003.0]], [[651.0, 882.0], [667.0, 882.0], [668.0, 1020.0], [652.0, 1020.0]]], "lines": ["「．．．君、", "お弁当屋さんの", "トコの子でしょ？"]}, {"box": [549, 882, 626, 1072], "vertical": true, "font_size": 17, "lines_coords": [[[610.0, 882.0], [626.0, 882.0], [626.0, 1035.0], [610.0, 1035.0]], [[591.0, 883.0], [608.0, 883.0], [608.0, 1072.0], [591.0, 1072.0]], [[570.0, 883.0], [586.0, 883.0], [586.0, 1037.0], [570.0, 1037.0]], [[549.0, 883.0], [565.0, 883.0], [565.0, 967.0], [549.0, 967.0]]], "lines": ["あたしのお母さんも", "この工場で働いてるから", "またいつか会う事も", "あろうさ。」"]}], "img_path": "226.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [458, 86, 582, 228], "vertical": true, "font_size": 18, "lines_coords": [[[562.0, 87.0], [582.0, 87.0], [582.0, 154.0], [562.0, 154.0]], [[540.0, 86.0], [559.0, 86.0], [559.0, 174.0], [540.0, 174.0]], [[518.0, 87.0], [541.0, 87.0], [541.0, 145.0], [518.0, 145.0]], [[500.0, 89.0], [516.0, 89.0], [516.0, 192.0], [500.0, 192.0]], [[479.0, 90.0], [495.0, 90.0], [495.0, 208.0], [479.0, 208.0]], [[458.0, 90.0], [474.0, 90.0], [474.0, 226.0], [458.0, 226.0]]], "lines": ["「．．．まぁ、", "描き終わる", "頃には、", "君もあたしも", "大人になってる", "かもしれんがね。」"]}, {"box": [119, 168, 220, 325], "vertical": true, "font_size": 21, "lines_coords": [[[194.0, 169.0], [220.0, 169.0], [220.0, 226.0], [194.0, 226.0]], [[176.0, 171.0], [196.0, 171.0], [196.0, 325.0], [176.0, 325.0]], [[154.0, 171.0], [174.0, 171.0], [174.0, 310.0], [154.0, 310.0]], [[123.0, 168.0], [142.0, 168.0], [139.0, 316.0], [119.0, 316.0]]], "lines": ["「．．．俺、", "ちゃんと父さゃんの", "弁当屋継くから！！", "ずっと待つから！！」"]}, {"box": [360, 992, 479, 1099], "vertical": true, "font_size": 24, "lines_coords": [[[448.0, 992.0], [479.0, 992.0], [479.0, 1052.0], [448.0, 1052.0]], [[407.0, 993.0], [428.0, 993.0], [428.0, 1089.0], [407.0, 1089.0]], [[363.0, 993.0], [383.0, 993.0], [383.0, 1098.0], [363.0, 1098.0]]], "lines": ["「絶対、", "絶対に約束", "だからな！！」"]}], "img_path": "227.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [722, 77, 739, 169], "vertical": true, "font_size": 18, "lines_coords": [[[722.0, 77.0], [739.0, 77.0], [739.0, 169.0], [722.0, 169.0]]], "lines": ["．．．そうそう"]}, {"box": [583, 120, 664, 260], "vertical": true, "font_size": 18, "lines_coords": [[[644.0, 121.0], [664.0, 121.0], [664.0, 260.0], [644.0, 260.0]], [[623.0, 120.0], [643.0, 120.0], [643.0, 242.0], [623.0, 242.0]], [[604.0, 123.0], [620.0, 123.0], [620.0, 225.0], [604.0, 225.0]], [[583.0, 123.0], [599.0, 123.0], [599.0, 225.0], [583.0, 225.0]]], "lines": ["みんなで工場跡に", "行ったとき．．．", "あの女の人が", "いたんだ．．．"]}, {"box": [137, 159, 220, 263], "vertical": true, "font_size": 16, "lines_coords": [[[202.0, 161.0], [219.0, 161.0], [219.0, 263.0], [202.0, 263.0]], [[181.0, 161.0], [197.0, 161.0], [197.0, 263.0], [181.0, 263.0]], [[160.0, 160.0], [176.0, 160.0], [176.0, 247.0], [160.0, 247.0]], [[139.0, 159.0], [156.0, 159.0], [154.0, 246.0], [137.0, 246.0]]], "lines": ["．．．なんで俺は", "何も話しかけ", "なかったん", "だろう．．．"]}, {"box": [677, 431, 722, 501], "vertical": true, "font_size": 19, "lines_coords": [[[695.0, 431.0], [722.0, 431.0], [722.0, 488.0], [695.0, 488.0]], [[677.0, 431.0], [697.0, 431.0], [697.0, 501.0], [677.0, 501.0]]], "lines": ["．．．話し", "かけて？"]}, {"box": [227, 510, 284, 614], "vertical": true, "font_size": 17, "lines_coords": [[[268.0, 512.0], [284.0, 512.0], [284.0, 596.0], [268.0, 596.0]], [[246.0, 510.0], [265.0, 510.0], [265.0, 614.0], [246.0, 614.0]], [[227.0, 512.0], [246.0, 512.0], [246.0, 547.0], [227.0, 547.0]]], "lines": ["あの工場が", "つぶれてから", "．．．．．"]}, {"box": [596, 556, 675, 673], "vertical": true, "font_size": 19, "lines_coords": [[[659.0, 561.0], [675.0, 561.0], [675.0, 673.0], [659.0, 673.0]], [[636.0, 556.0], [656.0, 556.0], [656.0, 660.0], [636.0, 660.0]], [[617.0, 556.0], [633.0, 556.0], [633.0, 660.0], [617.0, 660.0]], [[596.0, 557.0], [612.0, 557.0], [612.0, 659.0], [596.0, 659.0]]], "lines": ["．．．いや、どうせ", "俺の事なんて", "憶えちゃいな", "かっただろ．．．"]}, {"box": [707, 832, 767, 924], "vertical": true, "font_size": 18, "lines_coords": [[[747.0, 833.0], [767.0, 833.0], [767.0, 904.0], [747.0, 904.0]], [[726.0, 832.0], [746.0, 832.0], [746.0, 921.0], [726.0, 921.0]], [[707.0, 834.0], [723.0, 834.0], [723.0, 924.0], [707.0, 924.0]]], "lines": ["何もかも", "うまくいく", "ことのない"]}, {"box": [144, 632, 201, 752], "vertical": true, "font_size": 17, "lines_coords": [[[185.0, 633.0], [201.0, 633.0], [201.0, 719.0], [185.0, 719.0]], [[164.0, 633.0], [180.0, 633.0], [180.0, 737.0], [164.0, 737.0]], [[144.0, 632.0], [159.0, 632.0], [159.0, 752.0], [144.0, 752.0]]], "lines": ["俺の人生は", "より噛み合わ", "なくなった．．．"]}, {"box": [645, 991, 723, 1095], "vertical": true, "font_size": 18, "lines_coords": [[[707.0, 993.0], [723.0, 993.0], [723.0, 1094.0], [707.0, 1094.0]], [[686.0, 992.0], [704.0, 992.0], [701.0, 1078.0], [684.0, 1078.0]], [[663.0, 991.0], [682.0, 991.0], [682.0, 1079.0], [663.0, 1079.0]], [[645.0, 993.0], [661.0, 993.0], [661.0, 1095.0], [645.0, 1095.0]]], "lines": ["殺される程の", "価値もない", "ださい人生", "だったな．．．．．．"]}, {"box": [158, 894, 209, 969], "vertical": true, "font_size": 21, "lines_coords": [[[185.0, 895.0], [209.0, 895.0], [209.0, 969.0], [185.0, 969.0]], [[158.0, 894.0], [186.0, 894.0], [186.0, 943.0], [158.0, 943.0]]], "lines": ["．．．悪いな", "清水。"]}, {"box": [93, 1018, 173, 1140], "vertical": true, "font_size": 21, "lines_coords": [[[153.0, 1018.0], [173.0, 1018.0], [173.0, 1092.0], [153.0, 1092.0]], [[133.0, 1020.0], [153.0, 1020.0], [153.0, 1108.0], [133.0, 1108.0]], [[114.0, 1020.0], [131.0, 1020.0], [131.0, 1140.0], [114.0, 1140.0]], [[93.0, 1020.0], [110.0, 1020.0], [110.0, 1123.0], [93.0, 1123.0]]], "lines": ["．．．意外と", "お前の事は", "全然思い出さな", "かったわ．．．"]}], "img_path": "228.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [685, 98, 702, 154], "vertical": true, "font_size": 17, "lines_coords": [[[685.0, 98.0], [702.0, 98.0], [702.0, 154.0], [685.0, 154.0]]], "lines": ["．．．うん"]}, {"box": [605, 191, 663, 296], "vertical": true, "font_size": 17, "lines_coords": [[[646.0, 192.0], [663.0, 192.0], [663.0, 295.0], [646.0, 295.0]], [[626.0, 191.0], [644.0, 191.0], [641.0, 296.0], [624.0, 296.0]], [[605.0, 193.0], [622.0, 193.0], [622.0, 277.0], [605.0, 277.0]]], "lines": ["アレもコレも", "とっくに時効", "なんだ．．．"]}, {"box": [140, 196, 208, 314], "vertical": true, "font_size": 20, "lines_coords": [[[183.0, 196.0], [208.0, 196.0], [208.0, 260.0], [183.0, 260.0]], [[160.0, 199.0], [180.0, 199.0], [180.0, 314.0], [160.0, 314.0]], [[140.0, 200.0], [156.0, 200.0], [156.0, 312.0], [140.0, 312.0]]], "lines": ["昔話に", "縛られるのは", "もういい．．．"]}, {"box": [686, 399, 711, 479], "vertical": true, "font_size": 26, "lines_coords": [[[686.0, 399.0], [711.0, 399.0], [711.0, 479.0], [686.0, 479.0]]], "lines": ["遠くへ．．．"]}, {"box": [590, 481, 639, 581], "vertical": true, "font_size": 26, "lines_coords": [[[610.0, 481.0], [639.0, 481.0], [639.0, 547.0], [610.0, 547.0]], [[590.0, 483.0], [615.0, 483.0], [615.0, 581.0], [590.0, 581.0]]], "lines": ["どこか", "遠くへ．．．"]}, {"box": [246, 430, 309, 517], "vertical": true, "font_size": 21, "lines_coords": [[[288.0, 430.0], [309.0, 430.0], [309.0, 501.0], [288.0, 501.0]], [[267.0, 431.0], [288.0, 431.0], [288.0, 502.0], [267.0, 502.0]], [[246.0, 432.0], [265.0, 432.0], [265.0, 517.0], [246.0, 517.0]]], "lines": ["外国でも", "どこでも", "いいから．．"]}, {"box": [147, 487, 195, 587], "vertical": true, "font_size": 21, "lines_coords": [[[171.0, 487.0], [195.0, 487.0], [193.0, 570.0], [168.0, 570.0]], [[149.0, 489.0], [171.0, 489.0], [168.0, 587.0], [147.0, 587.0]]], "lines": ["とにかく", "遠くへ．．．"]}, {"box": [194, 798, 251, 904], "vertical": true, "font_size": 26, "lines_coords": [[[221.0, 800.0], [249.0, 800.0], [251.0, 896.0], [223.0, 896.0]], [[194.0, 798.0], [219.0, 798.0], [221.0, 904.0], [196.0, 904.0]]], "lines": ["し～～～", "～～～みず。"]}], "img_path": "229.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [610, 71, 689, 209], "vertical": true, "font_size": 17, "lines_coords": [[[672.0, 73.0], [688.0, 73.0], [688.0, 175.0], [672.0, 175.0]], [[650.0, 71.0], [670.0, 71.0], [667.0, 176.0], [647.0, 176.0]], [[630.0, 73.0], [646.0, 73.0], [646.0, 175.0], [630.0, 175.0]], [[610.0, 73.0], [626.0, 73.0], [626.0, 209.0], [610.0, 209.0]]], "lines": ["．．．またこんな", "朝っぱらから", "あのおかしな", "オッサンのとこ？"]}, {"box": [661, 389, 742, 526], "vertical": true, "font_size": 18, "lines_coords": [[[722.0, 389.0], [742.0, 389.0], [742.0, 475.0], [722.0, 475.0]], [[702.0, 390.0], [719.0, 390.0], [719.0, 510.0], [702.0, 510.0]], [[681.0, 390.0], [698.0, 390.0], [698.0, 526.0], [681.0, 526.0]], [[661.0, 390.0], [678.0, 390.0], [678.0, 500.0], [661.0, 500.0]]], "lines": ["．．．これ以上", "深入りすんなよ", "俺はお前をマジで", "心配してんだ。"]}, {"box": [265, 452, 328, 540], "vertical": true, "font_size": 18, "lines_coords": [[[303.0, 452.0], [328.0, 452.0], [328.0, 513.0], [303.0, 513.0]], [[284.0, 453.0], [304.0, 453.0], [304.0, 526.0], [284.0, 526.0]], [[265.0, 454.0], [282.0, 454.0], [282.0, 540.0], [265.0, 540.0]]], "lines": ["．．．これ、", "最後通告", "だからな？"]}, {"box": [147, 582, 263, 728], "vertical": true, "font_size": 18, "lines_coords": [[[247.0, 582.0], [263.0, 582.0], [263.0, 680.0], [247.0, 680.0]], [[224.0, 582.0], [244.0, 582.0], [244.0, 650.0], [224.0, 650.0]], [[206.0, 583.0], [222.0, 583.0], [223.0, 704.0], [207.0, 704.0]], [[186.0, 583.0], [201.0, 583.0], [201.0, 728.0], [186.0, 728.0]], [[167.0, 583.0], [182.0, 583.0], [182.0, 698.0], [167.0, 698.0]], [[147.0, 583.0], [162.0, 583.0], [162.0, 703.0], [147.0, 703.0]]], "lines": ["どんな大義が", "あるのか", "知らねーけどさ、", "そんな遊びで世の中", "１ミリたりとも", "変わんねーから。"]}, {"box": [671, 874, 753, 1014], "vertical": true, "font_size": 18, "lines_coords": [[[733.0, 874.0], [753.0, 874.0], [750.0, 998.0], [731.0, 998.0]], [[712.0, 876.0], [728.0, 876.0], [728.0, 1012.0], [712.0, 1012.0]], [[691.0, 875.0], [711.0, 875.0], [711.0, 1014.0], [691.0, 1014.0]], [[671.0, 875.0], [686.0, 875.0], [686.0, 1000.0], [671.0, 1000.0]]], "lines": ["．．．今日これから", "ボタン押すだけで", "ドサッと金が入る", "仕事があるんだ"]}, {"box": [258, 909, 337, 1053], "vertical": true, "font_size": 17, "lines_coords": [[[320.0, 912.0], [337.0, 912.0], [337.0, 1048.0], [320.0, 1048.0]], [[299.0, 909.0], [319.0, 909.0], [318.0, 1053.0], [298.0, 1053.0]], [[281.0, 911.0], [297.0, 911.0], [297.0, 1048.0], [281.0, 1048.0]], [[258.0, 910.0], [278.0, 910.0], [278.0, 986.0], [258.0, 986.0]]], "lines": ["何のボタンなのか", "よく知らないけど、", "きっと何か事件が", "起きるよ。"]}, {"box": [123, 1007, 221, 1147], "vertical": true, "font_size": 17, "lines_coords": [[[205.0, 1008.0], [221.0, 1008.0], [221.0, 1112.0], [205.0, 1112.0]], [[183.0, 1010.0], [200.0, 1010.0], [200.0, 1144.0], [183.0, 1144.0]], [[160.0, 1007.0], [180.0, 1007.0], [181.0, 1147.0], [161.0, 1147.0]], [[141.0, 1008.0], [158.0, 1008.0], [158.0, 1095.0], [141.0, 1095.0]], [[123.0, 1010.0], [135.0, 1010.0], [135.0, 1093.0], [123.0, 1093.0]]], "lines": ["．．．だからもう", "こんな街は捨てて", "二人でチベットで", "僧侶の修行", "しようぜ？"]}], "img_path": "230.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [666, 70, 746, 191], "vertical": true, "font_size": 18, "lines_coords": [[[726.0, 70.0], [746.0, 70.0], [743.0, 159.0], [723.0, 159.0]], [[702.0, 71.0], [722.0, 71.0], [725.0, 176.0], [705.0, 176.0]], [[685.0, 71.0], [701.0, 71.0], [701.0, 189.0], [685.0, 189.0]], [[666.0, 72.0], [681.0, 72