ines_coords": [[[675.0, 977.0], [698.0, 975.0], [706.0, 1074.0], [684.0, 1076.0]]], "lines": ["時間になって"]}, {"box": [536, 785, 658, 1089], "vertical": true, "font_size": 19, "lines_coords": [[[634.0, 785.0], [651.0, 785.0], [658.0, 993.0], [641.0, 993.0]], [[618.0, 785.0], [638.0, 785.0], [644.0, 1010.0], [624.0, 1010.0]], [[605.0, 789.0], [624.0, 789.0], [631.0, 1012.0], [612.0, 1012.0]], [[590.0, 789.0], [610.0, 789.0], [619.0, 1017.0], [599.0, 1017.0]], [[579.0, 793.0], [595.0, 793.0], [605.0, 1005.0], [590.0, 1005.0]], [[563.0, 795.0], [583.0, 794.0], [597.0, 1026.0], [577.0, 1027.0]], [[550.0, 796.0], [570.0, 795.0], [588.0, 1035.0], [568.0, 1037.0]], [[540.0, 805.0], [559.0, 803.0], [578.0, 1088.0], [558.0, 1089.0]]], "lines": ["世界が平和ですますように、ありすの", "あばいが出来ますように．．．ゆえがストレ！！", "となりますようにサイドルとワンガンダード", "まずように吸血鬼なんかじゃないだけではないのですが、", "ひたいチラズラは俺のではいつですが、普段は", "運営に電気が導入れますようによろしくなっているのですが、", "マジからどうですかなあとは思ってなかったのですが、", "とりに体力なくあるはいいですが、"]}, {"box": [406, 931, 500, 1182], "vertical": true, "font_size": 42, "lines_coords": [[[445.0, 951.0], [500.0, 956.0], [481.0, 1151.0], [426.0, 1147.0]], [[413.0, 982.0], [442.0, 983.0], [435.0, 1117.0], [406.0, 1116.0]]], "lines": ["じ果て服が", "もちろん、桜井"]}, {"box": [317, 983, 337, 1045], "vertical": true, "font_size": 20, "lines_coords": [[[317.0, 983.0], [337.0, 983.0], [337.0, 1045.0], [317.0, 1045.0]]], "lines": ["家内に"]}, {"box": [322, 1057, 376, 1201], "vertical": true, "font_size": 15, "lines_coords": [[[354.0, 1059.0], [370.0, 1059.0], [374.0, 1188.0], [359.0, 1188.0]], [[339.0, 1058.0], [354.0, 1058.0], [359.0, 1196.0], [344.0, 1196.0]]], "lines": ["【スカバー機が増加して", "【お母さんの問い合わせ委員会を"]}, {"box": [248, 941, 306, 1080], "vertical": true, "font_size": 31, "lines_coords": [[[269.0, 956.0], [289.0, 952.0], [306.0, 1065.0], [287.0, 1068.0]], [[271.0, 941.0], [296.0, 1075.0], [272.0, 1080.0], [248.0, 945.0]], [[253.0, 999.0], [264.0, 999.0], [264.0, 1037.0], [253.0, 1037.0]]], "lines": ["マジかあさＣはんに", "わかったわけじゃないでしょう", "．．．"]}, {"box": [249, 1032, 262, 1082], "vertical": true, "font_size": 31, "lines_coords": [[[249.0, 1032.0], [262.0, 1032.0], [262.0, 1082.0], [249.0, 1082.0]]], "lines": ["ふろー"]}, {"box": [202, 950, 244, 1108], "vertical": true, "font_size": 31, "lines_coords": [[[202.0, 953.0], [226.0, 950.0], [244.0, 1105.0], [221.0, 1108.0]]], "lines": ["世の中からお金属と"]}, {"box": [167, 943, 236, 1146], "vertical": true, "font_size": 20, "lines_coords": [[[182.0, 949.0], [210.0, 945.0], [236.0, 1142.0], [208.0, 1146.0]], [[167.0, 946.0], [187.0, 943.0], [202.0, 1054.0], [182.0, 1058.0]]], "lines": ["時間の制限がなくなりや", "ますように！！"]}, {"box": [188, 1087, 201, 1160], "vertical": true, "font_size": 20, "lines_coords": [[[188.0, 1087.0], [201.0, 1087.0], [201.0, 1160.0], [188.0, 1160.0]]], "lines": ["それでも"]}, {"box": [90, 1052, 130, 1181], "vertical": true, "font_size": 14, "lines_coords": [[[113.0, 1055.0], [130.0, 1057.0], [120.0, 1181.0], [104.0, 1180.0]], [[99.0, 1052.0], [115.0, 1053.0], [106.0, 1155.0], [90.0, 1154.0]]], "lines": ["メロンバンが『えずな", "我々になります"]}, {"box": [89, 1157, 97, 1184], "vertical": true, "font_size": 14, "lines_coords": [[[89.0, 1157.0], [97.0, 1157.0], [97.0, 1184.0], [89.0, 1184.0]]], "lines": ["．．．"]}], "img_path": "092.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [703, 0, 755, 110], "vertical": true, "font_size": 18, "lines_coords": [[[733.0, 14.0], [749.0, 14.0], [749.0, 92.0], [733.0, 92.0]], [[704.0, 7.0], [723.0, 5.0], [729.0, 92.0], [709.0, 93.0]]], "lines": ["アゼンブ", "続けてい"]}, {"box": [726, 168, 759, 235], "vertical": true, "font_size": 33, "lines_coords": [[[726.0, 168.0], [759.0, 168.0], [759.0, 235.0], [726.0, 235.0]]], "lines": ["どが高ビット場をおクに！！足直也一個"]}, {"box": [574, 0, 604, 64], "vertical": true, "font_size": 30, "lines_coords": [[[574.0, 0.0], [604.0, 0.0], [604.0, 64.0], [574.0, 64.0]]], "lines": ["ストレス！！ひざすぐの！？"]}, {"box": [639, 62, 675, 190], "vertical": true, "font_size": 20, "lines_coords": [[[652.0, 62.0], [672.0, 62.0], [672.0, 1