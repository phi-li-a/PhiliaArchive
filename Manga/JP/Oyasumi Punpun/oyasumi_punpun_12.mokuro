.0, 963.0], [701.0, 963.0], [701.0, 1040.0], [681.0, 1040.0]]], "lines": ["．．．だから君は", "普通の生活に", "戻っていいん", "だよ．．．"]}, {"box": [237, 945, 308, 1068], "vertical": true, "font_size": 19, "lines_coords": [[[285.0, 945.0], [305.0, 945.0], [308.0, 1061.0], [288.0, 1061.0]], [[263.0, 946.0], [283.0, 946.0], [283.0, 1062.0], [263.0, 1062.0]], [[237.0, 945.0], [257.0, 945.0], [260.0, 1068.0], [240.0, 1068.0]]], "lines": ["あたしはもう", "君を追いかけ", "たりしないし、"]}, {"box": [114, 996, 180, 1112], "vertical": true, "font_size": 19, "lines_coords": [[[164.0, 999.0], [180.0, 999.0], [180.0, 1093.0], [164.0, 1093.0]], [[137.0, 996.0], [158.0, 996.0], [159.0, 1112.0], [138.0, 1112.0]], [[115.0, 997.0], [133.0, 997.0], [132.0, 1112.0], [114.0, 1112.0]]], "lines": ["あとの事は", "あたし一人で", "考えるから．．．"]}], "img_path": "204.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [604, 73, 660, 259], "vertical": true, "font_size": 20, "lines_coords": [[[637.0, 76.0], [658.0, 76.0], [660.0, 182.0], [639.0, 182.0]], [[604.0, 75.0], [624.0, 75.0], [624.0, 255.0], [604.0, 255.0]]], "lines": ["「．．．違う嘘だ", "僕が人殺しなんだ．．．」"]}, {"box": [373, 51, 393, 131], "vertical": true, "font_size": 25, "lines_coords": [[[373.0, 51.0], [393.0, 51.0], [393.0, 131.0], [373.0, 131.0]]], "lines": ["ううん．．．"]}, {"box": [285, 133, 335, 216], "vertical": true, "font_size": 25, "lines_coords": [[[306.0, 133.0], [335.0, 133.0], [335.0, 182.0], [306.0, 182.0]], [[285.0, 137.0], [310.0, 137.0], [310.0, 216.0], [285.0, 216.0]]], "lines": ["本当", "なの．．．"]}, {"box": [94, 187, 134, 292], "vertical": true, "font_size": 18, "lines_coords": [[[114.0, 187.0], [134.0, 187.0], [134.0, 258.0], [114.0, 258.0]], [[94.0, 189.0], [111.0, 189.0], [111.0, 292.0], [94.0, 292.0]]], "lines": ["君は何も", "してないの．．"]}, {"box": [681, 372, 703, 464], "vertical": true, "font_size": 21, "lines_coords": [[[681.0, 372.0], [702.0, 372.0], [702.0, 464.0], [681.0, 464.0]]], "lines": ["君は．．．"]}, {"box": [100, 527, 152, 653], "vertical": true, "font_size": 22, "lines_coords": [[[130.0, 527.0], [151.0, 527.0], [151.0, 619.0], [130.0, 619.0]], [[100.0, 527.0], [124.0, 527.0], [124.0, 653.0], [100.0, 653.0]]], "lines": ["なんにも", "してないの。"]}], "img_path": "205.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [603, 169, 699, 305], "vertical": true, "font_size": 27, "lines_coords": [[[668.0, 169.0], [697.0, 169.0], [699.0, 305.0], [671.0, 305.0]], [[639.0, 171.0], [664.0, 171.0], [664.0, 303.0], [639.0, 303.0]], [[603.0, 169.0], [631.0, 169.0], [631.0, 263.0], [603.0, 263.0]]], "lines": ["．．．人殺しに", "なったのは", "あたし。"]}], "img_path": "206.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [159, 479, 256, 639], "vertical": true, "font_size": 28, "lines_coords": [[[220.0, 479.0], [256.0, 479.0], [256.0, 540.0], [220.0, 540.0]], [[192.0, 482.0], [216.0, 482.0], [216.0, 612.0], [192.0, 612.0]], [[159.0, 483.0], [183.0, 483.0], [183.0, 638.0], [159.0, 638.0]]], "lines": ["君は", "ただ近くに", "いただけ．．．"]}], "img_path": "207.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [638, 208, 659, 296], "vertical": true, "font_size": 20, "lines_coords": [[[638.0, 208.0], [658.0, 208.0], [658.0, 294.0], [638.0, 294.0]]], "lines": ["ゴメン．．．"]}, {"box": [261, 404, 309, 464], "vertical": true, "font_size": 29, "lines_coords": [[[278.0, 404.0], [309.0, 404.0], [309.0, 464.0], [278.0, 464.0]], [[261.0, 405.0], [288.0, 405.0], [288.0, 461.0], [261.0, 461.0]]], "lines": ["ゴメン", "ね．．．．．"]}], "img_path": "208.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [222, 895, 262, 1003], "vertical": true, "font_size": 19, "lines_coords": [[[240.0, 895.0], [262.0, 895.0], [262.0, 951.0], [240.0, 951.0]], [[222.0, 897.0], [238.0, 897.0], [238.0, 1003.0], [222.0, 1003.0]]], "lines": ["．．．でも", "やっと言えて、"]}, {"box": [151, 992, 171, 1096], "vertical": true, "font_size": 19, "lines_coords": [[[151.0, 992.0], [171.0, 992.0], [171.0, 1096.0], [151.0, 1096.0]]], "lines": ["良かった．．．"]}], "img_path": "209.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "210.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "211.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [664, 592, 723, 680], "vertical": true, "font_size": 19, "lines_coords": [[[707.0, 595.0], [723.0, 595.0], [723.0, 679.0], [707.0, 679.0]], [[684.0, 592.0], [705.0, 592.0], [705.0, 664.0], [684.0, 664.0]], [[664.0, 592.0], [684.0, 592.0], [684.0, 680.0], [664.0, 680.0]]], "lines": ["．．．あたしは", "この島に", "残るよ．．．"]}, {"box": [570, 648, 611, 726], "vertical": true, "font_size": 19, "lines_coords": [[[591.0, 650.0], [611.0, 650.0], [611.0, 720.0], [591.0, 720.0]], [[570.0, 648.0], [590.0, 648.0], [590.0, 726.0], [570.0, 726.0]]], "lines": ["警察には", "行かない。"]}, {"box": [133, 637, 194, 741], "vertical": true, "font_size": 20, "lines_coords": [[[172.0, 638.0], [194.0, 638.0], [194.0, 693.0], [172.0, 693.0]], [[152.0, 638.0], [173.0, 638.0], [173.0, 708.0], [152.0, 708.0]], [[134.0, 637.0], [151.0, 637.0], [149.0, 741.0], [133.0, 741.0]]], "lines": ["．．．君は", "これから", "どうするの？"]}, {"box": [221, 809, 325, 928], "vertical": true, "font_size": 22, "lines_coords": [[[301.0, 812.0], [325.0, 812.0], [325.0, 885.0], [301.0, 885.0]], [[267.0, 809.0], [291.0, 809.0], [291.0, 875.0], [267.0, 875.0]], [[244.0, 810.0], [265.0, 810.0], [263.0, 909.0], [242.0, 909.0]], [[223.0, 814.0], [240.0, 814.0], [240.0, 925.0], [223.0, 925.0]]], "lines": ["「．．．君は、", "僕から", "何もかもを", "奪ってゆく。"]}, {"box": [379, 998, 424, 1084], "vertical": true, "font_size": 21, "lines_coords": [[[402.0, 999.0], [424.0, 999.0], [424.0, 1040.0], [402.0, 1040.0]], [[379.0, 999.0], [399.0, 999.0], [399.0, 1082.0], [379.0, 1082.0]]], "lines": ["．．．", "そうだね。"]}], "img_path": "212.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [609, 202, 655, 338], "vertical": true, "font_size": 21, "lines_coords": [[[633.0, 203.0], [654.0, 203.0], [654.0, 290.0], [633.0, 290.0]], [[609.0, 202.0], [630.0, 202.0], [631.0, 336.0], [610.0, 336.0]]], "lines": ["「神様神様", "チンクルホイ。」"]}, {"box": [328, 201, 373, 298], "vertical": true, "font_size": 22, "lines_coords": [[[349.0, 201.0], [373.0, 201.0], [373.0, 263.0], [349.0, 263.0]], [[328.0, 202.0], [347.0, 202.0], [347.0, 298.0], [328.0, 298.0]]], "lines": ["．．．．．．", "なにそれ？"]}, {"box": [205, 67, 246, 260], "vertical": true, "font_size": 18, "lines_coords": [[[229.0, 67.0], [246.0, 67.0], [246.0, 208.0], [229.0, 208.0]], [[205.0, 67.0], [221.0, 67.0], [221.0, 260.0], [205.0, 260.0]]], "lines": ["「．．．そう唱えると", "神様が来てくれるって、"]}, {"box": [131, 65, 174, 256], "vertical": true, "font_size": 18, "lines_coords": [[[154.0, 65.0], [174.0, 65.0], [174.0, 256.0], [154.0, 256.0]], [[131.0, 65.0], [151.0, 65.0], [151.0, 255.0], [131.0, 255.0]]], "lines": ["子供の頃、叔父さんに", "教えてもらったんだ。」"]}, {"box": [572, 609, 613, 697], "vertical": true, "font_size": 20, "lines_coords": [[[593.0, 610.0], [613.0, 610.0], [613.0, 689.0], [593.0, 689.0]], [[572.0, 609.0], [592.0, 609.0], [592.0, 697.0], [572.0, 697.0]]], "lines": ["「いつから", "だろう．．．"]}, {"box": [466, 608, 550, 713], "vertical": true, "font_size": 20, "lines_coords": [[[530.0, 609.0], [550.0, 609.0], [550.0, 713.0], [530.0, 713.0]], [[510.0, 611.0], [527.0, 611.0], [527.0, 712.0], [510.0, 712.0]], [[488.0, 609.0], [508.0, 609.0], [508.0, 680.0], [488.0, 680.0]], [[466.0, 608.0], [486.0, 608.0], [488.0, 698.0], [468.0, 698.0]]], "lines": ["それがただの", "自問自答だと", "気付いて", "いたのは。」"]}, {"box": [179, 713, 209, 1051], "vertical": true, "font_size": 27, "lines_coords": [[[181.0, 713.0], [208.0, 713.0], [206.0, 1047.0], [179.0, 1047.0]]], "lines": ["「．．．結婚しよう。愛子ちゃん。」"]}, {"box": [691, 1008, 733, 1103], "vertical": true, "font_size": 17, "lines_coords": [[[713.0, 1008.0], [731.0, 1008.0], [732.0, 1102.0], [714.0, 110