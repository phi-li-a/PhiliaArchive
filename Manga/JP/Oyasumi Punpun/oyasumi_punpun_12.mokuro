 [155.0, 237.0], [135.0, 237.0]], [[113.0, 82.0], [138.0, 82.0], [138.0, 145.0], [113.0, 145.0]]], "lines": ["首に絞め跡のほか", "腹部に数か所の", "刺し傷がある事から", "殺人の可能性がある", "として調査を進めて", "います。"]}, {"box": [636, 349, 718, 545], "vertical": true, "font_size": 17, "lines_coords": [[[699.0, 349.0], [716.0, 349.0], [715.0, 502.0], [698.0, 502.0]], [[677.0, 350.0], [697.0, 350.0], [695.0, 486.0], [675.0, 486.0]], [[658.0, 351.0], [674.0, 351.0], [674.0, 521.0], [658.0, 521.0]], [[636.0, 350.0], [652.0, 350.0], [654.0, 543.0], [638.0, 543.0]]], "lines": ["なお田中さんの車が", "鹿児島県○○市の", "山道に乗り捨てられて", "いるのが見つかっており、"]}, {"box": [202, 676, 271, 839], "vertical": true, "font_size": 21, "lines_coords": [[[248.0, 676.0], [271.0, 676.0], [271.0, 830.0], [248.0, 830.0]], [[226.0, 677.0], [246.0, 677.0], [246.0, 832.0], [226.0, 832.0]], [[202.0, 677.0], [222.0, 677.0], [222.0, 839.0], [202.0, 839.0]]], "lines": ["娘の愛子さん２０の", "行方がわからなく", "なっている事から、"]}, {"box": [296, 1023, 350, 1083], "vertical": false, "font_size": 25.0, "lines_coords": [[[299.0, 1023.0], [350.0, 1023.0], [350.0, 1051.0], [299.0, 1051.0]], [[298.0, 1057.0], [345.0, 1061.0], [343.0, 1083.0], [296.0, 1079.0]]], "lines": ["お名前", "こ住所"]}, {"box": [282, 1099, 346, 1148], "vertical": false, "font_size": 21, "lines_coords": [[[287.0, 1099.0], [345.0, 1101.0], [344.0, 1122.0], [285.0, 1120.0]], [[283.0, 1123.0], [343.0, 1127.0], [342.0, 1148.0], [282.0, 1144.0]]], "lines": ["ご希望の", "携帯機種"]}, {"box": [284, 1169, 328, 1187], "vertical": false, "font_size": 18, "lines_coords": [[[284.0, 1169.0], [328.0, 1169.0], [328.0, 1187.0], [284.0, 1187.0]]], "lines": ["証明書"]}, {"box": [124, 877, 242, 1071], "vertical": true, "font_size": 21, "lines_coords": [[[216.0, 877.0], [242.0, 877.0], [242.0, 941.0], [216.0, 941.0]], [[195.0, 880.0], [215.0, 880.0], [215.0, 1014.0], [195.0, 1014.0]], [[171.0, 881.0], [190.0, 881.0], [190.0, 1033.0], [171.0, 1033.0]], [[147.0, 881.0], [167.0, 881.0], [167.0, 1071.0], [147.0, 1071.0]], [[124.0, 880.0], [144.0, 880.0], [144.