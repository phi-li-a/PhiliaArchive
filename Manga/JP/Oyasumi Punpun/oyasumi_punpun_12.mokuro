, [85.0, 71.0]]], "lines": ["おやすみプンプン［２"]}, {"box": [265, 134, 294, 221], "vertical": true, "font_size": 20, "lines_coords": [[[265.0, 135.0], [285.0, 135.0], [285.0, 220.0], [265.0, 220.0]]], "lines": ["．．．翠さん。"]}, {"box": [370, 358, 451, 495], "vertical": true, "font_size": 16, "lines_coords": [[[433.0, 359.0], [449.0, 359.0], [449.0, 462.0], [433.0, 462.0]], [[412.0, 359.0], [428.0, 359.0], [428.0, 495.0], [412.0, 495.0]], [[391.0, 358.0], [406.0, 358.0], [406.0, 494.0], [391.0, 494.0]], [[371.0, 358.0], [387.0, 358.0], [386.0, 495.0], [370.0, 495.0]]], "lines": ["携帯失くした", "からってあの子が", "ここに捜しに来る", "とは思えないし．．．"]}, {"box": [93, 364, 156, 494], "vertical": true, "font_size": 20, "lines_coords": [[[137.0, 365.0], [156.0, 365.0], [156.0, 469.0], [137.0, 469.0]], [[115.0, 365.0], [135.0, 365.0], [135.0, 471.0], [115.0, 471.0]], [[93.0, 364.0], [113.0, 364.0], [114.0, 494.0], [94.0, 494.0]]], "lines": ["アパートまで", "届けてやれば", "いいじゃないか。"]}, {"box": [672, 560, 712, 692], "vertical": true, "font_size": 18, "lines_coords": [[[695.0, 562.0], [712.0, 562.0], [712.0, 682.0], [695.0, 682.0]], [[672.0, 560.0], [692.0, 560.0], [693.0, 692.0], [673.0, 692.0]]], "lines": ["帰ってる様子が", "ないんですって。"]}, {"box": [575, 629, 633, 748], "vertical": true, "font_size": 18, "lines_coords": [[[613.0, 629.0], [633.0, 629.0], [633.0, 700.0], [613.0, 700.0]], [[595.0, 630.0], [611.0, 630.0], [611.0, 748.0], [595.0, 748.0]], [[575.0, 629.0], [591.0, 629.0], [591.0, 700.0], [575.0, 700.0]]], "lines": ["バイトも", "休んでるみたい", "だし．．．"]}, {"box": [649, 808, 728, 929], "vertical": true, "font_size": 17, "lines_coords": [[[712.0, 810.0], [728.0, 810.0], [728.0, 918.0], [712.0, 918.0]], [[688.0, 809.0], [705.0, 809.0], [705.0, 929.0], [688.0, 929.0]], [[667.0, 808.0], [687.0, 808.0], [687.0, 915.0], [667.0, 915.0]], [[649.0, 809.0], [665.0, 809.0], [665.0, 912.0], [649.0, 912.0]]], "lines": ["．．．てもあの子、", "私が干渉すると", "あまりいい顔", "しないから．．．"]}, {"box": [466, 792, 524, 911], "vertical": true, "font_size": 16, "lines_coords"