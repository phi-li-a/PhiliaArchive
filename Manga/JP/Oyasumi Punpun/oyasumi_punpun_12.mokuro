, "半年くらい前が", "最後かしら．．"]}, {"box": [700, 543, 728, 603], "vertical": true, "font_size": 25, "lines_coords": [[[700.0, 544.0], [726.0, 543.0], [728.0, 602.0], [702.0, 603.0]]], "lines": ["あぁ．．．"]}, {"box": [115, 372, 220, 494], "vertical": true, "font_size": 18, "lines_coords": [[[197.0, 372.0], [220.0, 372.0], [220.0, 428.0], [197.0, 428.0]], [[180.0, 373.0], [196.0, 373.0], [196.0, 461.0], [180.0, 461.0]], [[159.0, 373.0], [175.0, 373.0], [175.0, 494.0], [159.0, 494.0]], [[138.0, 375.0], [154.0, 375.0], [154.0, 476.0], [138.0, 476.0]], [[115.0, 373.0], [135.0, 373.0], [135.0, 450.0], [115.0, 450.0]]], "lines": ["妊娠の", "報告したら", "プンプンすごく", "喜んでくれた", "みたいで。"]}, {"box": [619, 592, 685, 669], "vertical": true, "font_size": 25, "lines_coords": [[[660.0, 592.0], [685.0, 592.0], [685.0, 669.0], [660.0, 669.0]], [[639.0, 594.0], [665.0, 594.0], [665.0, 651.0], [639.0, 651.0]], [[619.0, 594.0], [640.0, 594.0], [640.0, 666.0], [619.0, 666.0]]], "lines": ["ずいぶん", "大きい", "てすね．．．"]}, {"box": [656, 754, 757, 892], "vertical": true, "font_size": 17, "lines_coords": [[[740.0, 757.0], [755.0, 757.0], [755.0, 892.0], [740.0, 892.0]], [[718.0, 755.0], [734.0, 755.0], [734.0, 891.0], [718.0, 891.0]], [[698.0, 757.0], [714.0, 757.0], [714.0, 842.0], [698.0, 842.0]], [[675.0, 754.0], [695.0, 754.0], [693.0, 877.0], [673.0, 877.0]], [[656.0, 754.0], [675.0, 754.0], [675.0, 826.0], [656.0, 826.0]]], "lines": ["．．．しばらくお店は", "出れないですけど", "復帰したら", "二店舗目を考え", "てて．．．．．．"]}, {"box": [144, 573, 189, 698], "vertical": true, "font_size": 22, "lines_coords": [[[165.0, 573.0], [189.0, 573.0], [189.0, 636.0], [165.0, 636.0]], [[144.0, 575.0], [164.0, 575.0], [164.0, 697.0], [144.0, 697.0]]], "lines": ["予定日", "来週なんです。"]}, {"box": [415, 955, 479, 1114], "vertical": true, "font_size": 18, "lines_coords": [[[459.0, 955.0], [479.0, 955.0], [479.0, 1058.0], [459.0, 1058.0]], [[440.0, 956.0], [456.0, 956.0], [456.0, 1091.0], [440.0, 1091.0]], [[417.0, 955.0], [436.0, 955.0], [435.0, 1112.0], [415.0, 1112.0]]], "lines": ["もし良ければ", "フンブンと一緒に", "いらしてくださいね"]}, {"box": [127, 1026, 175, 1145], "vertical": true, "font_size": 24, "lines_coords": [[[149.0, 1026.0], [175.0, 1026.0], [175.0, 1076.0], [149.0, 1076.0]], [[130.0, 1026.0], [151.0, 1026.0], [148.0, 1110.0], [127.0, 1110.0]]], "lines": ["店長ー", "電話です"]}], "img_path": "068.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [415, 60, 453, 172], "vertical": true, "font_size": 16, "lines_coords": [[[436.0, 62.0], [453.0, 62.0], [453.0, 131.0], [436.0, 131.0]], [[415.0, 60.0], [432.0, 60.0], [432.0, 172.0], [415.0, 172.0]]], "lines": ["．．．どうも", "すみませんね。"]}, {"box": [343, 159, 400, 277], "vertical": true, "font_size": 16, "lines_coords": [[[384.0, 159.0], [400.0, 159.0], [400.0, 277.0], [384.0, 277.0]], [[363.0, 159.0], [379.0, 159.0], [379.0, 261.0], [363.0, 261.0]], [[343.0, 160.0], [359.0, 160.0], [359.0, 251.0], [343.0, 251.0]]], "lines": ["妻はいまひとつ", "話の通じない", "人間でして"]}, {"box": [104, 128, 205, 284], "vertical": true, "font_size": 17, "lines_coords": [[[188.0, 130.0], [205.0, 130.0], [205.0, 233.0], [188.0, 233.0]], [[167.0, 130.0], [183.0, 130.0], [183.0, 249.0], [167.0, 249.0]], [[145.0, 128.0], [165.0, 128.0], [165.0, 284.0], [145.0, 284.0]], [[127.0, 131.0], [140.0, 131.0], [140.0, 214.0], [127.0, 214.0]], [[104.0, 128.0], [120.0, 128.0], [121.0, 239.0], [105.0, 239.0]]], "lines": ["彼女は恐らく", "世の中が自分を", "中心に回っていると", "思える人間", "なんでしょう。"]}, {"box": [89, 295, 169, 440], "vertical": true, "font_size": 17, "lines_coords": [[[147.0, 295.0], [167.0, 295.0], [169.0, 401.0], [149.0, 401.0]], [[128.0, 297.0], [148.0, 297.0], [148.0, 401.0], [128.0, 401.0]], [[110.0, 297.0], [126.0, 297.0], [126.0, 407.0], [110.0, 407.0]], [[89.0, 297.0], [104.0, 297.0], [104.0, 440.0], [89.0, 440.0]]], "lines": ["．．．だからこそ", "物事が順調に", "運ぶ事もある。", "素晴らしい事です。"]}, {"box": [200, 505, 222, 609], "vertical": true, "font_size": 20, "lines_coords": [[[202.0, 505.0], [222.0, 505.0], [220.0, 609.0], [200.0, 609.0]]], "lines": ["．．．南条さん。"]}, {"box": [691, 698, 711, 783], "vertical": true, "font_size": 20, "lines_coords": [[[691.0, 698.0], [711.0, 698.0], [711.0, 783.0], [691.0, 783.0]]], "lines": ["．．．あなた。"]}, {"box": [144, 867, 213, 1021], "vertical": true, "font_size": 20, "lines_coords": [[[192.0, 869.0], [212.0, 869.0], [212.0, 1021.0], [192.0, 1021.0]], [[167.0, 867.0], [187.0, 867.0], [187.0, 1000.0], [167.0, 1000.0]], [[144.0, 867.0], [164.0, 867.0], [164.0, 964.0], [144.0, 964.0]]], "lines": ["ただのバイト仲間", "なんかじゃない", "でしょう？"]}], "img_path": "069.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [673, 326, 701, 423], "vertical": true, "font_size": 28, "lines_coords": [[[673.0, 326.0], [701.0, 326.0], [701.0, 423.0], [673.0, 423.0]]], "lines": ["私は．．．"]}, {"box": [141, 610, 235, 747], "vertical": true, "font_size": 21, "lines_coords": [[[210.0, 610.0], [235.0, 610.0], [235.0, 673.0], [210.0, 673.0]], [[187.0, 611.0], [207.0, 611.0], [208.0, 746.0], [188.0, 746.0]], [[164.0, 611.0], [183.0, 611.0], [185.0, 747.0], [165.0, 747.0]], [[141.0, 611.0], [161.0, 611.0], [161.0, 698.0], [141.0, 698.0]]], "lines": ["とても", "身勝手な理由で", "フンフンに執着", "してます。"]}, {"box": [678, 862, 761, 967], "vertical": true, "font_size": 19, "lines_coords": [[[741.0, 863.0], [761.0, 863.0], [761.0, 935.0], [741.0, 935.0]], [[720.0, 863.0], [738.0, 863.0], [740.0, 950.0], [722.0, 950.0]], [[701.0, 866.0], [718.0, 866.0], [718.0, 966.0], [701.0, 966.0]], [[678.0, 862.0], [700.0, 862.0], [700.0, 905.0], [678.0, 905.0]]], "lines": ["．．．僕にも", "心当たりが", "無くて申し訳", "ない"]}, {"box": [530, 1017, 612, 1155], "vertical": true, "font_size": 17, "lines_coords": [[[593.0, 1020.0], [610.0, 1020.0], [610.0, 1123.0], [593.0, 1123.0]], [[574.0, 1019.0], [589.0, 1019.0], [589.0, 1155.0], [574.0, 1155.0]], [[552.0, 1019.0], [569.0, 1019.0], [569.0, 1139.0], [552.0, 1139.0]], [[530.0, 1017.0], [550.0, 1017.0], [550.0, 1089.0], [530.0, 1089.0]]], "lines": ["血縁とはいえ", "もともと家族感の", "薄い家系なもの", "でね．．．．．"]}], "img_path": "070.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [658, 59, 740, 171], "vertical": true, "font_size": 18, "lines_coords": [[[718.0, 59.0], [740.0, 59.0], [740.0, 114.0], [718.0, 114.0]], [[698.0, 59.0], [718.0, 59.0], [718.0, 153.0], [698.0, 153.0]], [[678.0, 62.0], [694.0, 62.0], [694.0, 147.0], [678.0, 147.0]], [[658.0, 62.0], [674.0, 62.0], [674.0, 171.0], [658.0, 171.0]]], "lines": ["部屋に", "女物の服と、", "布団に血が", "付いてました。"]}, {"box": [376, 128, 421, 208], "vertical": true, "font_size": 22, "lines_coords": [[[397.0, 128.0], [421.0, 128.0], [421.0, 208.0], [397.0, 208.0]], [[376.0, 128.0], [397.0, 128.0], [397.0, 206.0], [376.0, 206.0]]], "lines": ["漁ったん", "ですか？"]}, {"box": [679, 453, 701, 577], "vertical": true, "font_size": 20, "lines_coords": [[[679.0, 453.0], [699.0, 453.0], [701.0, 575.0], [681.0, 575.0]]], "lines": ["キモいですね。"]}, {"box": [500, 296, 558, 406], "vertical": true, "font_size": 17, "lines_coords": [[[538.0, 296.0], [558.0, 296.0], [558.0, 366.0], [538.0, 366.0]], [[520.0, 297.0], [536.0, 297.0], [536.0, 399.0], [520.0, 399.0]], [[500.0, 296.0], [516.0, 296.0], [516.0, 405.0], [500.0, 405.0]]], "lines": ["ゴミ箱に", "精液を拭いた", "ティッシュも。"]}, {"box": [180, 273, 224, 377], "vertical": true, "font_size": 22, "lines_coords": [[[199.0, 273.0], [224.0, 273.0], [224.0, 336.0], [199.0, 336.0]], [[180.0, 275.0], [196.0, 275.0], [196.0, 377.0], [180.0, 377.0]]], "lines": ["匂いも", "嗅ぎました。"]}, {"box": [94, 322, 141, 410], "vertical": true, "font_size": 22, "lines_coords": [[[114.0, 322.0], [141.0, 322.0], [141.0, 382.0], [114.0, 382.0]], [[94.0, 322.0], [114.0, 322.0], [114.0, 410.0], [94.0, 410.0]]], "lines": ["キモい", "ですよね。"]}, {"box": [113, 505, 206, 621], "vertical": true, "font_size": 19, "lines_coords": [[[186.0, 509.0], [202.0, 509.0], [202.0, 621.0], [186.0, 621.0]], [[161.0, 508.0], [181.0, 508.0], [181.0, 585.0], [161.0, 585.0]], [[138.0, 506.0], [158.0, 506.0], [158.0, 603.0], [138.0, 603.0]], [[113.0, 505.0], [134.0, 505.0], [135.0, 575.0], [114.0, 575.0]]], "lines": ["しかしながら", "最高だと", "言わざるを", "得ない。"]}, {"box": [367, 986, 389, 1109], "vertical": true, "font_size": 16, "lines_coords": [[[370.0, 986.0], [386.0, 986.0], [384.0, 1109.0], [367.0, 1109.0]]], "lines": ["次行者自転車とひどい"]}], "img_path": "071.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [687, 448, 707, 531], "vertical": true, "font_size": 20, "lines_coords": [[[687.0, 448.0], [707.0, 448.0], [707.0, 529.0], [687.0, 529.0]]], "lines": ["．．．ここが、"]}, {"box": [137, 476, 216, 604], "vertical": true, "font_size": 18, "lines_coords": [[[199.0, 478.0], [215.0, 478.0], [215.0, 563.0], [199.0, 563.0]], [[176.0, 476.0], [196.0, 476.0], [196.0, 598.0], [176.0, 598.0]], [[155.0, 476.0], [175.0, 476.0], [175.0, 598.0], [155.0, 598.0]], [[137.0, 478.0], [153.0, 478.0], [153.0, 604.0], [137.0, 604.0]]], "lines": ["フンフンが", "中学生の時まで", "住んでいた家が", "あった場所です。"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [511, 148, 695, 172], "vertical": false, "font_size": 19, "lines_coords": [[[511.0, 148.0], [695.0, 153.0], [695.0, 172.0], [511.0, 167.0]]], "lines": ["建築計画のお知らせ"]}, {"box": [551, 178, 609, 186], "vertical": false, "font_size": 8, "lines_coords": [[[551.0, 178.0], [609.0, 178.0], [609.0, 186.0], [551.0, 186.0]]], "lines": ["ですので私がお"]}, {"box": [548, 192, 600, 203], "vertical": false, "font_size": 11, "lines_coords": [[[548.0, 192.0], [600.0, 192.0], [600.0, 203.0], [548.0, 203.0]]], "lines": ["お願いです"]}, {"box": [524, 183, 542, 264], "vertical": true, "font_size": 16, "lines_coords": [[[527.0, 183.0], [542.0, 183.0], [540.0, 264.0], [524.0, 264.0]]], "lines": ["この最適損適敗"]}, {"box": [358, 46, 438, 152], "vertical": true, "font_size": 20, "lines_coords": [[[421.0, 46.0], [438.0, 46.0], [438.0, 116.0], [421.0, 116.0]], [[401.0, 48.0], [418.0, 48.0], [418.0, 134.0], [401.0, 134.0]], [[379.0, 46.0], [399.0, 46.0], [399.0, 152.0], [379.0, 152.0]], [[358.0, 46.0], [379.0, 46.0], [379.0, 103.0], [358.0, 103.0]]], "lines": ["そんなに", "古くない家", "だったんです", "が．．．．．"]}, {"box": [481, 191, 509, 275], "vertical": true, "font_size": 12.5, "lines_coords": [[[496.0, 191.0], [509.0, 191.0], [509.0, 275.0], [496.0, 275.0]], [[481.0, 208.0], [493.0, 208.0], [493.0, 258.0], [481.0, 258.0]]], "lines": ["あ用途地階は", "最終的の概要"]}, {"box": [297, 152, 360, 256], "vertical": true, "font_size": 20, "lines_coords": [[[340.0, 153.0], [360.0, 153.0], [360.0, 256.0], [340.0, 256.0]], [[318.0, 152.0], [338.0, 152.0], [338.0, 237.0], [318.0, 237.0]], [[297.0, 152.0], [322.0, 152.0], [322.0, 216.0], [297.0, 216.0]]], "lines": ["建て替えたァ", "景気のいい", "こった。"]}, {"box": [74, 92, 159, 233], "vertical": true, "font_size": 20, "lines_coords": [[[138.0, 93.0], [159.0, 93.0], [159.0, 150.0], [138.0, 150.0]], [[119.0, 96.0], [135.0, 96.0], [135.0, 198.0], [119.0, 198.0]], [[97.0, 94.0], [117.0, 94.0], [117.0, 233.0], [97.0, 233.0]], [[74.0, 93.0], [96.0, 92.0], [99.0, 173.0], [78.0, 174.0]]], "lines": ["きっと", "幸せな家族が", "引っ越してくるん", "でしょう。"]}, {"box": [668, 344, 697, 349], "vertical": false, "font_size": 5, "lines_coords": [[[668.0, 344.0], [697.0, 344.0], [697.0, 349.0], [668.0, 349.0]]], "lines": ["私と呼ばれる"]}, {"box": [487, 295, 527, 325], "vertical": false, "font_size": 12.5, "lines_coords": [[[487.0, 295.0], [516.0, 295.0], [516.0, 309.0], [487.0, 309.0]], [[487.0, 314.0], [527.0, 314.0], [527.0, 325.0], [487.0, 325.0]]], "lines": ["なける", "指工者（火）"]}, {"box": [279, 541, 324, 636], "vertical": true, "font_size": 19, "lines_coords": [[[297.0, 541.0], [324.0, 541.0], [324.0, 591.0], [297.0, 591.0]], [[279.0, 543.0], [299.0, 543.0], [299.0, 636.0], [279.0, 636.0]]], "lines": ["．．．今、", "思い返せば、"]}, {"box": [221, 341, 247, 403], "vertical": true, "font_size": 22, "lines_coords": [[[221.0, 341.0], [247.0, 341.0], [247.0, 403.0], [221.0, 403.0]]], "lines": ["．．．あの、"]}, {"box": [114, 377, 178, 464], "vertical": true, "font_size": 22, "lines_coords": [[[151.0, 377.0], [178.0, 377.0], [178.0, 433.0], [151.0, 433.0]], [[134.0, 378.0], [151.0, 378.0], [151.0, 464.0], [134.0, 464.0]], [[114.0, 379.0], [132.0, 379.0], [132.0, 416.0], [114.0, 416.0]]], "lines": ["なんで", "私をここに", "．．．？"]}, {"box": [472, 789, 550, 892], "vertical": true, "font_size": 17, "lines_coords": [[[530.0, 789.0], [550.0, 789.0], [550.0, 877.0], [530.0, 877.0]], [[511.0, 792.0], [528.0, 792.0], [528.0, 891.0], [511.0, 891.0]], [[490.0, 791.0], [507.0, 791.0], [507.0, 892.0], [490.0, 892.0]], [[472.0, 792.0], [485.0, 792.0], [485.0, 862.0], [472.0, 862.0]]], "lines": ["いつまでも", "続く訳はない", "生活とわかり", "なからも"]}, {"box": [138, 576, 240, 714], "vertical": true, "font_size": 19, "lines_coords": [[[220.0, 576.0], [240.0, 576.0], [240.0, 664.0], [220.0, 664.0]], [[199.0, 576.0], [219.0, 576.0], [219.0, 649.0], [199.0, 649.0]], [[179.0, 578.0], [195.0, 578.0], [195.0, 713.0], [179.0, 713.0]], [[159.0, 578.0], [175.0, 578.0], [175.0, 714.0], [159.0, 714.0]], [[138.0, 578.0], [154.0, 578.0], [154.0, 667.0], [138.0, 667.0]]], "lines": ["プンプンと", "暮らした", "数年間というのは", "楽しくにぎやかな", "日々でした。"]}, {"box": [196, 858, 233, 962], "vertical": true, "font_size": 20, "lines_coords": [[[216.0, 858.0], [233.0, 858.0], [233.0, 962.0], [216.0, 962.0]], [[196.0, 858.0], [213.0, 858.0], [213.0, 950.0], [196.0, 950.0]]], "lines": ["．．．いや恐らく", "それが故に、"]}, {"box": [87, 994, 183, 1114], "vertical": true, "font_size": 20, "lines_coords": [[[161.0, 996.0], [182.0, 996.0], [183.0, 1076.0], [162.0, 1076.0]], [[139.0, 998.0], [159.0, 998.0], [159.0, 1114.0], [139.0, 1114.0]], [[113.0, 998.0], [134.0, 998.0], [135.0, 1094.0], [114.0, 1094.0]], [[87.0, 996.0], [112.0, 994.0], [114.0, 1066.0], [90.0, 1067.0]]], "lines": ["．．．僕には", "どこか幸せな", "家族ごっこ", "でした。"]}], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [643, 97, 701, 251], "vertical": true, "font_size": 18, "lines_coords": [[[685.0, 98.0], [701.0, 98.0], [701.0, 219.0], [685.0, 219.0]], [[664.0, 99.0], [680.0, 99.0], [680.0, 251.0], [664.0, 251.0]], [[643.0, 97.0], [658.0, 97.0], [658.0, 251.0], [643.0, 251.0]]], "lines": ["僕は今の安寧を", "手に入れたかわりに", "生きる屍と成り果て"]}, {"box": [559, 254, 637, 394], "vertical": true, "font_size": 18, "lines_coords": [[[620.0, 257.0], [637.0, 257.0], [637.0, 343.0], [620.0, 343.0]], [[599.0, 255.0], [619.0, 255.0], [619.0, 394.0], [599.0, 394.0]], [[578.0, 254.0], [598.0, 254.0], [598.0, 394.0], [578.0, 394.0]], [[559.0, 254.0], [579.0, 254.0], [579.0, 317.0], [559.0, 317.0]]], "lines": ["これからは", "名ばかりの希望に", "すがってゆくので", "しょう。"]}, {"box": [167, 452, 247, 614], "vertical": true, "font_size": 17, "lines_coords": [[[229.0, 454.0], [246.0, 454.0], [246.0, 573.0], [229.0, 573.0]], [[208.0, 454.0], [224.0, 454.0], [224.0, 614.0], [208.0, 614.0]], [[186.0, 452.0], [206.0, 452.0], [206.0, 607.0], [186.0, 607.0]], [[167.0, 454.0], [182.0, 454.0], [182.0, 580.0], [167.0, 580.0]]], "lines": ["これを否定する", "つもりはありません。", "僕の望んだひとつの", "かたちですから。"]}, {"box": [727, 765, 748, 843], "vertical": true, "font_size": 19, "lines_coords": [[[727.0, 765.0], [748.0, 765.0], [748.0, 843.0], [727.0, 843.0]]], "lines": ["．．．僕ァね、"]}, {"box": [616, 809, 698, 935], "vertical": true, "font_size": 19, "lines_coords": [[[677.0, 809.0], [698.0, 809.0], [698.0, 896.0], [677.0, 896.0]], [[658.0, 809.0], [674.0, 809.0], [674.0, 896.0], [658.0, 896.0]], [[636.0, 809.0], [656.0, 809.0], [656.0, 914.0], [636.0, 914.0]], [[616.0, 809.0], [631.0, 809.0], [631.0, 935.0], [616.0, 935.0]]], "lines": ["プンプンが", "どこで何を", "していようが", "かまいませんよ。"]}, {"box": [494, 782, 514, 860], "vertical": true, "font_size": 22, "lines_coords": [[[494.0, 782.0], [514.0, 782.0], [514.0, 860.0], [494.0, 860.0]]], "lines": ["．．．ただね、"]}, {"box": [565, 1020, 637, 1125], "vertical": true, "font_size": 22, "lines_coords": [[[611.0, 1020.0], [637.0, 1020.0], [637.0, 1083.0], [611.0, 1083.0]], [[591.0, 1021.0], [611.0, 1021.0], [611.0, 1119.0], [591.0, 1119.0]], [[565.0, 1020.0], [585.0, 1020.0], [588.0, 1125.0], [568.0, 1125.0]]], "lines": ["それが", "彼の決断で", "あるならば。"]}, {"box": [421, 880, 467, 960], "vertical": true, "font_size": 22, "lines_coords": [[[442.0, 880.0], [467.0, 880.0], [467.0, 943.0], [442.0, 943.0]], [[421.0, 882.0], [441.0, 882.0], [441.0, 960.0], [421.0, 960.0]]], "lines": ["僕には", "わかる！！"]}, {"box": [117, 996, 209, 1110], "vertical": true, "font_size": 20, "lines_coords": [[[188.0, 997.0], [208.0, 997.0], [208.0, 1093.0], [188.0, 1093.0]], [[164.0, 997.0], [183.0, 997.0], [183.0, 1093.0], [164.0, 1093.0]], [[140.0, 997.0], [160.0, 997.0], [160.0, 1110.0], [140.0, 1110.0]], [[117.0, 996.0], [138.0, 996.0], [138.0, 1074.0], [117.0, 1074.0]]], "lines": ["ブンプンが", "本当は何を", "求めていたの", "か．．．．．！！"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [682, 57, 728, 160], "vertical": true, "font_size": 22, "lines_coords": [[[704.0, 57.0], [728.0, 57.0], [728.0, 119.0], [704.0, 119.0]], [[682.0, 58.0], [702.0, 58.0], [702.0, 160.0], [682.0, 160.0]]], "lines": ["．．．彼は", "寡黙ですが、"]}, {"box": [415, 66, 518, 222], "vertical": true, "font_size": 17, "lines_coords": [[[499.0, 67.0], [516.0, 67.0], [518.0, 171.0], [501.0, 171.0]], [[479.0, 67.0], [495.0, 67.0], [495.0, 187.0], [479.0, 187.0]], [[456.0, 66.0], [476.0, 66.0], [476.0, 222.0], [456.0, 222.0]], [[438.0, 67.0], [454.0, 67.0], [454.0, 205.0], [438.0, 205.0]], [[415.0, 67.0], [432.0, 67.0], [432.0, 145.0], [415.0, 145.0]]], "lines": ["本音はもっと", "自分が何を考え", "どんな気持ちなのか", "話したかったはず", "なんです。"]}, {"box": [325, 230, 385, 350], "vertical": true, "font_size": 18, "lines_coords": [[[369.0, 232.0], [385.0, 232.0], [384.0, 350.0], [367.0, 350.0]], [[347.0, 232.0], [364.0, 232.0], [364.0, 350.0], [347.0, 350.0]], [[325.0, 230.0], [345.0, 230.0], [345.0, 308.0], [325.0, 308.0]]], "lines": ["．．．もしあなたが", "その役割を負う", "覚悟なら、"]}, {"box": [229, 278, 291, 414], "vertical": true, "font_size": 18, "lines_coords": [[[271.0, 278.0], [291.0, 278.0], [291.0, 366.0], [271.0, 366.0]], [[253.0, 278.0], [269.0, 278.0], [269.0, 414.0], [253.0, 414.0]], [[231.0, 278.0], [249.0, 278.0], [247.0, 364.0], [229.0, 364.0]]], "lines": ["フンフンを", "もっと知ってやる", "べきだ．．．"]}, {"box": [250, 488, 298, 568], "vertical": true, "font_size": 22, "lines_coords": [[[272.0, 488.0], [298.0, 488.0], [298.0, 550.0], [272.0, 550.0]], [[250.0, 491.0], [271.0, 491.0], [271.0, 568.0], [250.0, 568.0]]], "lines": ["だって", "あなた．．．"]}, {"box": [124, 502, 196, 641], "vertical": true, "font_size": 22, "lines_coords": [[[176.0, 506.0], [196.0, 506.0], [196.0, 639.0], [176.0, 639.0]], [[153.0, 503.0], [173.0, 503.0], [171.0, 621.0], [151.0, 621.0]], [[127.0, 502.0], [151.0, 502.0], [147.0, 641.0], [124.0, 641.0]]], "lines": ["あの子の母親に", "そっくりなん", "ですもの．．．．．！！"]}, {"box": [609, 773, 701, 945], "vertical": true, "font_size": 20, "lines_coords": [[[680.0, 775.0], [697.0, 775.0], [697.0, 928.0], [680.0, 928.0]], [[656.0, 775.0], [675.0, 775.0], [675.0, 924.0], [656.0, 924.0]], [[631.0, 773.0], [654.0, 773.0], [654.0, 945.0], [631.0, 945.0]], [[609.0, 773.0], [630.0, 773.0], [630.0, 841.0], [609.0, 841.0]]], "lines": ["フンフンが年明け", "いずれ紹介したい", "人がいるって言って", "ました。"]}, {"box": [158, 900, 236, 1060], "vertical": true, "font_size": 22, "lines_coords": [[[212.0, 900.0], [235.0, 900.0], [235.0, 1060.0], [212.0, 1060.0]], [[183.0, 900.0], [207.0, 900.0], [207.0, 1039.0], [183.0, 1039.0]], [[158.0, 901.0], [178.0, 901.0], [178.0, 1059.0], [158.0, 1059.0]]], "lines": ["それってきっと", "南条さんの事", "なんでしょう？"]}], "img_path": "075.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "077.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [182, 75, 215, 503], "vertical": true, "font_size": 28, "lines_coords": [[[187.0, 75.0], [215.0, 75.0], [210.0, 503.0], [182.0, 503.0]]], "lines": ["ファンディングファイルスタッフの"]}, {"box": [673, 945, 700, 1038], "vertical": true, "font_size": 25, "lines_coords": [[[673.0, 967.0], [698.0, 966.0], [700.0, 1037.0], [675.0, 1038.0]]], "lines": ["．．．え？"]}, {"box": [135, 1016, 193, 1110], "vertical": true, "font_size": 31, "lines_coords": [[[156.0, 1016.0], [193.0, 1016.0], [193.0, 1072.0], [156.0, 1072.0]], [[135.0, 1019.0], [160.0, 1019.0], [160.0, 1110.0], [135.0, 1110.0]]], "lines": ["妊娠", "ですか？"]}], "img_path": "078.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [673, 66, 733, 170], "vertical": true, "font_size": 16, "lines_coords": [[[718.0, 119.0], [731.0, 119.0], [731.0, 152.0], [718.0, 152.0]], [[714.0, 66.0], [733.0, 66.0], [733.0, 98.0], [714.0, 98.0]], [[694.0, 66.0], [711.0, 66.0], [711.0, 153.0], [694.0, 153.0]], [[673.0, 67.0], [690.0, 67.0], [690.0, 169.0], [673.0, 169.0]]], "lines": ["．．．", "あー", "すみません", "報告遅くて．．．"]}, {"box": [383, 63, 442, 166], "vertical": true, "font_size": 18, "lines_coords": [[[421.0, 63.0], [442.0, 63.0], [442.0, 107.0], [421.0, 107.0]], [[404.0, 64.0], [420.0, 64.0], [420.0, 155.0], [404.0, 155.0]], [[383.0, 64.0], [399.0, 64.0], [399.0, 166.0], [383.0, 166.0]]], "lines": ["．．．ん", "てもそっか、", "参ったな．．．．．．"]}, {"box": [85, 161, 167, 300], "vertical": true, "font_size": 18, "lines_coords": [[[144.0, 161.0], [164.0, 161.0], [167.0, 291.0], [147.0, 291.0]], [[127.0, 162.0], [144.0, 162.0], [144.0, 300.0], [127.0, 300.0]], [[106.0, 162.0], [123.0, 162.0], [123.0, 283.0], [106.0, 283.0]], [[85.0, 161.0], [100.0, 161.0], [100.0, 270.0], [85.0, 270.0]]], "lines": ["明後日発売の号、", "もう届いてます？", "それに載ってる", "あなたの読切、"]}, {"box": [517, 400, 578, 539], "vertical": true, "font_size": 18, "lines_coords": [[[556.0, 400.0], [576.0, 400.0], [578.0, 498.0], [558.0, 498.0]], [[538.0, 403.0], [555.0, 403.0], [555.0, 539.0], [538.0, 539.0]], [[518.0, 400.0], [535.0, 400.0], [534.0, 522.0], [517.0, 522.0]]], "lines": ["．．．いやいや、", "それはおめでとう", "ございます．．．"]}, {"box": [130, 342, 209, 496], "vertical": true, "font_size": 18, "lines_coords": [[[189.0, 342.0], [209.0, 342.0], [209.0, 430.0], [189.0, 430.0]], [[169.0, 342.0], [189.0, 342.0], [189.0, 496.0], [169.0, 496.0]], [[151.0, 343.0], [167.0, 343.0], [167.0, 479.0], [151.0, 479.0]], [[130.0, 342.0], [146.0, 342.0], [146.0, 479.0], [130.0, 479.0]]], "lines": ["．．．編集長が", "気に入ったみたいで", "２巻完結くらいで", "連載どうかって．．．"]}, {"box": [165, 882, 185, 979], "vertical": true, "font_size": 20, "lines_coords": [[[165.0, 882.0], [185.0, 882.0], [185.0, 979.0], [165.0, 979.0]]], "lines": ["それは．．．"]}, {"box": [93, 1006, 164, 1123], "vertical": true, "font_size": 20, "lines_coords": [[[142.0, 1006.0], [164.0, 1006.0], [161.0, 1086.0], [140.0, 1086.0]], [[118.0, 1008.0], [139.0, 1008.0], [139.0, 1087.0], [118.0, 1087.0]], [[93.0, 1006.0], [113.0, 1006.0], [115.0, 1123.0], [96.0, 1123.0]]], "lines": ["もちろん", "やらせて", "もらいます．．．"]}], "img_path": "079.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [325, 123, 345, 147], "vertical": true, "font_size": 20, "lines_coords": [[[325.0, 123.0], [345.0, 123.0], [345.0, 147.0], [325.0, 147.0]]], "lines": ["ただいま彼女．．．"]}, {"box": [281, 269, 302, 300], "vertical": true, "font_size": 21, "lines_coords": [[[281.0, 269.0], [302.0, 269.0], [302.0, 300.0], [281.0, 300.0]]], "lines": ["ダーメだってっ"]}, {"box": [725, 453, 763, 574], "vertical": true, "font_size": 16, "lines_coords": [[[747.0, 455.0], [762.0, 455.0], [762.0, 574.0], [747.0, 574.0]], [[725.0, 453.0], [741.0, 453.0], [741.0, 557.0], [725.0, 557.0]]], "lines": ["２冊くらいなら", "半年あれば．．．"]}, {"box": [439, 324, 453, 355], "vertical": true, "font_size": 14, "lines_coords": [[[439.0, 324.0], [453.0, 324.0], [453.0, 355.0], [439.0, 355.0]]], "lines": ["あるかっ！？"]}, {"box": [455, 450, 515, 577], "vertical": true, "font_size": 19, "lines_coords": [[[495.0, 450.0], [515.0, 450.0], [515.0, 521.0], [495.0, 521.0]], [[474.0, 450.0], [494.0, 450.0], [494.0, 536.0], [474.0, 536.0]], [[455.0, 452.0], [472.0, 452.0], [472.0, 574.0], [455.0, 574.0]]], "lines": ["あたしは", "欠陥の多い", "人間なんだから、"]}, {"box": [311, 307, 354, 384], "vertical": true, "font_size": 14, "lines_coords": [[[336.0, 307.0], [352.0, 307.0], [354.0, 360.0], [338.0, 360.0]], [[323.0, 310.0], [336.0, 309.0], [340.0, 367.0], [328.0, 369.0]]], "lines": ["匹児の特砂の", "つい生き生きて"]}, {"box": [291, 437, 316, 515], "vertical": true, "font_size": 21, "lines_coords": [[[291.0, 437.0], [316.0, 437.0], [316.0, 515.0], [291.0, 515.0]]], "lines": ["．．．売れて、"]}, {"box": [200, 487, 241, 598], "vertical": true, "font_size": 21, "lines_coords": [[[224.0, 489.0], [241.0, 489.0], [241.0, 591.0], [224.0, 591.0]], [[200.0, 487.0], [220.0, 487.0], [222.0, 598.0], [202.0, 598.0]]], "lines": ["流れて売れて", "売れまくって、"]}, {"box": [567, 951, 626, 1087], "vertical": true, "font_size": 16, "lines_coords": [[[609.0, 951.0], [625.0, 951.0], [625.0, 1037.0], [609.0, 1037.0]], [[588.0, 951.0], [604.0, 951.0], [604.0, 1087.0], [588.0, 1087.0]], [[567.0, 951.0], [583.0, 951.0], [583.0, 1021.0], [567.0, 1021.0]]], "lines": ["．．．がんばり", "どころじゃないか", "自分．．．．．"]}, {"box": [291, 908, 392, 1046], "vertical": true, "font_size": 18, "lines_coords": [[[372.0, 909.0], [392.0, 909.0], [392.0, 982.0], [372.0, 982.0]], [[350.0, 908.0], [370.0, 908.0], [372.0, 996.0], [352.0, 996.0]], [[332.0, 910.0], [349.0, 910.0], [349.0, 1046.0], [332.0, 1046.0]], [[311.0, 910.0], [328.0, 910.0], [328.0, 1046.0], [311.0, 1046.0]], [[291.0, 910.0], [306.0, 910.0], [306.0, 1003.0], [291.0, 1003.0]]], "lines": ["人の数倍", "がんばって", "やっと他人と同じ", "スタートラインに", "立てるんだ。"]}, {"box": [104, 966, 170, 1100], "vertical": true, "font_size": 19, "lines_coords": [[[149.0, 966.0], [169.0, 966.0], [169.0, 1044.0], [149.0, 1044.0]], [[126.0, 966.0], [146.0, 966.0], [146.0, 1100.0], [126.0, 1100.0]], [[104.0, 967.0], [120.0, 967.0], [120.0, 1068.0], [104.0, 1068.0]]], "lines": ["あたしは", "ようやく普通に", "なれるんだ"]}], "img_path": "080.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [321, 123, 340, 147], "ve