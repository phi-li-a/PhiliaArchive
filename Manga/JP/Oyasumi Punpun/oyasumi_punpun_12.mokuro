 598, 700], "vertical": true, "font_size": 27, "lines_coords": [[[571.0, 653.0], [598.0, 653.0], [598.0, 700.0], [571.0, 700.0]]], "lines": ["あ．．．"]}, {"box": [461, 723, 481, 801], "vertical": true, "font_size": 20, "lines_coords": [[[461.0, 723.0], [481.0, 723.0], [481.0, 801.0], [461.0, 801.0]]], "lines": ["はっは．．．"]}, {"box": [126, 1045, 174, 1123], "vertical": true, "font_size": 23, "lines_coords": [[[149.0, 1045.0], [174.0, 1045.0], [174.0, 1112.0], [149.0, 1112.0]], [[126.0, 1045.0], [147.0, 1045.0], [147.0, 1123.0], [126.0, 1123.0]]], "lines": ["．．．最悪、", "最悪だ．．．"]}], "img_path": "236.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [718, 71, 759, 189], "vertical": true, "font_size": 19, "lines_coords": [[[739.0, 71.0], [759.0, 71.0], [759.0, 142.0], [739.0, 142.0]], [[718.0, 71.0], [734.0, 71.0], [734.0, 189.0], [718.0, 189.0]]], "lines": ["君達が今", "見ている世界．．"]}, {"box": [595, 164, 675, 269], "vertical": true, "font_size": 19, "lines_coords": [[[653.0, 164.0], [675.0, 164.0], [675.0, 220.0], [653.0, 220.0]], [[632.0, 164.0], [653.0, 164.0], [654.0, 236.0], [633.0, 236.0]], [[613.0, 165.0], [633.0, 165.0], [633.0, 269.0], [613.0, 269.0]], [[595.0, 168.0], [612.0, 168.0], [612.0, 203.0], [595.0, 203.0]]], "lines": ["これは", "停滞でも", "閉塞でもなく", "．．．．．"]}, {"box": [124, 202, 179, 339], "vertical": true, "font_size": 24, "lines_coords": [[[155.0, 202.0], [179.0, 202.0], [179.0, 338.0], [155.0, 338.0]], [[126.0, 202.0], [149.0, 202.0], [147.0, 338.0], [124.0, 338.0]]], "lines": ["ビッキビキの", "完成なのだ．．"]}, {"box": [12, 200, 64, 330], "vertical": true, "font_size": 48, "lines_coords": [[[12.0, 201.0], [60.0, 200.0], [64.0, 329.0], [16.0, 330.0]]], "lines": ["第１３４話"]}, {"box": [667, 467, 768, 589], "vertical": true, "font_size": 18, "lines_coords": [[[753.0, 468.0], [768.0, 468.0], [768.0, 571.0], [753.0, 571.0]], [[732.0, 468.0], [748.0, 468.0], [748.0, 588.0], [732.0, 588.0]], [[711.0, 468.0], [727.0, 468.0], [727.0, 589.0], [711.0, 589.0]], [[690.0, 468.0], [706.0, 468.0], [706.0, 588.0], [690.0, 588.0]], [[667.0, 467.0], [684.0, 467.0], [686.0, 554.0], [670.0, 554.0]]], "lines": ["しかしながら", "更なる新世界を", "渇望する君達は", "なんて貪欲なの", "だろう．．．．．"]}, {"box": [235, 496, 318, 618], "vertical": true, "font_size": 19, "lines_coords": [[[298.0, 496.0], [318.0, 496.0], [318.0, 568.0], [298.0, 568.0]], [[279.0, 500.0], [296.0, 500.0], [296.0, 584.0], [279.0, 584.0]], [[258.0, 499.0], [275.0, 499.0], [275.0, 585.0], [258.0, 585.0]], [[235.0, 496.0], [256.0, 496.0], [257.0, 618.0], [236.0, 618.0]]], "lines": ["．．．つまり", "個の時代は", "終焉を迎え", "集の時代へ．．．"]}, {"box": [585, 646, 668, 738], "vertical": true, "font_size": 18, "lines_coords": [[[649.0, 649.0], [668.0, 649.0], [668.0, 719.0], [649.0, 719.0]], [[629.0, 650.0], [649.0, 650.0], [649.0, 738.0], [629.0, 738.0]], [[610.0, 650.0], [626.0, 650.0], [626.0, 737.0], [610.0, 737.0]], [[585.0, 646.0], [610.0, 646.0], [610.0, 712.0], [585.0, 712.0]]], "lines": ["．．．しかし", "僕はそれを", "あえて賞賛", "したい。"]}, {"box": [155, 628, 217, 733], "vertical": true, "font_size": 19, "lines_coords": [[[192.0, 628.0], [217.0, 628.0], [217.0, 686.0], [192.0, 686.0]], [[174.0, 630.0], [194.0, 630.0], [194.0, 700.0], [174.0, 700.0]], [[155.0, 630.0], [171.0, 630.0], [171.0, 733.0], [155.0, 733.0]]], "lines": ["僕から", "言わせて", "もらえば．．．"]}, {"box": [693, 870, 745, 971], "vertical": true, "font_size": 24, "lines_coords": [[[719.0, 870.0], [745.0, 870.0], [745.0, 942.0], [719.0, 942.0]], [[693.0, 873.0], [714.0, 873.0], [714.0, 971.0], [693.0, 971.0]]], "lines": ["．．．この", "世界は今、"]}, {"box": [124, 967, 185, 1100], "vertical": true, "font_size": 26, "lines_coords": [[[155.0, 967.0], [185.0, 967.0], [185.0, 1050.0], [155.0, 1050.0]], [[124.0, 967.0], [147.0, 967.0], [149.0, 1100.0], [126.0, 1100.0]]], "lines": ["最高に", "キてるッ！！"]}], "img_path": "237.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [684, 57, 745, 164], "vertical": true, "font_size": 17, "lines_coords": [[[725.0, 57.0], [745.0, 57.0], [742.0, 164.0], [722.0, 164.0]], [[705.0, 60.0], [721.0, 60.0], [721.0, 146.0], [705.0, 146.0]], [[684.0, 59.0], [700.0, 59.0], [700.0, 161.0], [684.0, 161.0]]], "lines": ["ラヴァーズは", "僕に伝えて", "くれた．．．．．．！！"]}, {"box": [592, 210, 693, 329], "vertical": true, "font_size": 17, "lines_coords": [[[673.0, 210.0], [693.0, 210.0], [693.0, 296.0], [673.0, 296.0]], [[653.0, 210.0], [670.0, 210.0], [670.0, 311.0], [653.0, 311.0]], [[632.0, 210.0], [649.0, 210.0], [649.0, 329.0], [632.0, 329.0]], [[612.0, 210.0], [627.0, 210.0], [627.0, 312.0], [612.0, 312.0]], [[592.0, 210.0], [605.0, 210.0], [605.0, 295.0], [592.0, 295.0]]], "lines": ["一人一人が", "手を取り合い", "未来の子供達の", "ために人生を", "捧けると！！"]}, {"box": [197, 71, 279, 192], "vertical": true, "font_size": 18, "lines_coords": [[[263.0, 73.0], [279.0, 73.0], [279.0, 192.0], [263.0, 192.0]], [[242.0, 73.0], [258.0, 73.0], [258.0, 175.0], [242.0, 175.0]], [[221.0, 73.0], [237.0, 73.0], [237.0, 175.0], [221.0, 175.0]], [[197.0, 71.0], [221.0, 71.0], [221.0, 114.0], [197.0, 114.0]]], "lines": ["決して恣意的に", "振る舞う事も", "なく曖昧にも", "せず、"]}, {"box": [130, 206, 210, 344], "vertical": true, "font_size": 18, "lines_coords": [[[189.0, 206.0], [210.0, 206.0], [210.0, 277.0], [189.0, 277.0]], [[171.0, 207.0], [187.0, 207.0], [187.0, 311.0], [171.0, 311.0]], [[149.0, 207.0], [167.0, 207.0], [166.0, 344.0], [148.0, 344.0]], [[130.0, 206.0], [145.0, 206.0], [145.0, 343.0], [130.0, 343.0]]], "lines": ["．．．そして", "その気持ちを", "ズっと忘れないと", "約束してくれた．．．"]}, {"box": [686, 486, 725, 613], "vertical": true, "font_size": 16, "lines_coords": [[[708.0, 486.0], [725.0, 486.0], [725.0, 573.0], [708.0, 573.0]], [[686.0, 487.0], [702.0, 487.0], [702.0, 611.0], [686.0, 611.0]]], "lines": ["．．．要するに", "超平たく言うと、"]}, {"box": [171, 481, 230, 619], "vertical": true, "font_size": 18, "lines_coords": [[[214.0, 483.0], [230.0, 483.0], [230.0, 569.0], [214.0, 569.0]], [[192.0, 482.0], [212.0, 482.0], [212.0, 619.0], [192.0, 619.0]], [[171.0, 481.0], [187.0, 481.0], [189.0, 568.0], [173.0, 568.0]]], "lines": ["愛て世界は", "ひとつに繋がって", "るんダッ！！"]}, {"box": [138, 645, 180, 767], "vertical": true, "font_size": 18, "lines_coords": [[[158.0, 645.0], [180.0, 645.0], [180.0, 703.0], [158.0, 703.0]], [[139.0, 645.0], [156.0, 645.0], [155.0, 767.0], [138.0, 767.0]]], "lines": ["．．．そう", "言ってくれた．．"]}, {"box": [680, 851, 735, 1014], "vertical": true, "font_size": 17, "lines_coords": [[[720.0, 851.0], [735.0, 851.0], [735.0, 965.0], [720.0, 965.0]], [[700.0, 851.0], [715.0, 851.0], [715.0, 982.0], [700.0, 982.0]], [[680.0, 853.0], [697.0, 853.0], [697.0, 1014.0], [680.0, 1014.0]]], "lines": ["．．．僕はまだ正直", "それを理解できて", "いないかもしれない．．．"]}, {"box": [597, 1017, 643, 1132], "vertical": true, "font_size": 17, "lines_coords": [[[625.0, 1017.0], [643.0, 1017.0], [640.0, 1113.0], [623.0, 1113.0]], [[597.0, 1018.0], [617.0, 1018.0], [619.0, 1132.0], [599.0, 1132.0]]], "lines": ["．．．けど僕は", "感動したッ！！"]}, {"box": [434, 926, 582, 946], "vertical": false, "font_size": 20, "lines_coords": [[[434.0, 926.0], [582.0, 926.0], [582.0, 946.0], [434.0, 946.0]]], "lines": ["＞＞０７４０９"]}, {"box": [128, 997, 210, 1119], "vertical": true, "font_size": 19, "lines_coords": [[[189.0, 997.0], [210.0, 997.0], [210.0, 1068.0], [189.0, 1068.0]], [[169.0, 999.0], [186.0, 999.0], [186.0, 1083.0], [169.0, 1083.0]], [[146.0, 997.0], [166.0, 997.0], [168.0, 1119.0], [148.0, 1119.0]], [[128.0, 999.0], [145.0, 999.0], [145.0, 1083.0], [128.0, 1083.0]]], "lines": ["何故なら", "僕は君達を", "圧倒的に信じて", "いるから！！"]}], "img_path": "238.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [688, 78, 708, 165], "vertical": true, "font_size": 20, "lines_coords": [[[688.0, 78.0], [708.0, 78.0], [708.0, 165.0], [688.0, 165.0]]], "lines": ["信じて．．．"]}, {"box": [604, 162, 646, 251], "vertical": true, "font_size": 20, "lines_coords": [[[625.0, 162.0], [646.0, 162.0], [646.0, 226.0], [625.0, 226.0]], [[604.0, 164.0], [624.0, 164.0], [624.0, 251.0], [604.0, 251.0]]], "lines": ["．．．そう、", "信じている"]}, {"box": [140, 146, 178, 249], "vertical": true, "font_size": 16, "lines_coords": [[[161.0, 147.0], [178.0, 147.0], [178.0, 248.0], [161.0, 248.0]], [[140.0, 146.0], [155.0, 146.0], [155.0, 248.0], [140.0, 248.0]]], "lines": ["信じるっきゃ", "ないんだ．．．"]}, {"box": [674, 415, 716, 528], "vertical": true, "font_size": 16, "lines_coords": [[[699.0, 417.0], [715.0, 417.0], [715.0, 528.0], [699.0, 528.0]], [[675.0, 417.0], [692.0, 417.0], [692.0, 517.0], [675.0, 517.0]]], "lines": ["．．．もしそれが", "嘘だったら、"]}, {"box": [131, 546, 200, 650], "vertical": true, "font_size": 22, "lines_coords": [[[174.0, 546.0], [200.0, 546.0], [200.0, 608.0], [174.0, 608.0]], [[153.0, 548.0], [173.0, 548.0], [173.0, 644.0], [153.0, 644.0]], [[131.0, 547.0], [151.0, 547.0], [151.0, 650.0], [131.0, 650.0]]], "lines": ["君達を", "一人残らず", "ぶっ殺すぞ。"]}, {"box": [693, 765, 712, 899], "vertical": true, "font_size": 16, "lines_coords": [[[693.0, 766.0], [709.0, 766.0], [709.0, 898.0], [693.0, 898.0]]], "lines": ["ラヴァーズよ．．．"]}, {"box": [131, 966, 212, 1122], "vertical": true, "font_size": 19, "lines_coords": [[[192.0, 967.0], [212.0, 967.0], [212.0, 1042.0], [192.0, 1042.0]], [[171.0, 966.0], [190.0, 966.0], [188.0, 1087.0], [168.0, 1087.0]], [[149.0, 967.0], [169.0, 967.0], [169.0, 1122.0], [149.0, 1122.0]], [[131.0, 967.0], [146.0, 967.0], [146.0, 1071.0], [131.0, 1071.0]]], "lines": ["これは僕、", "ペガサスからの", "最後のメッセージに", "なるだろう．．．"]}], "img_path": "239.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [633, 50, 714, 221], "vertical": true, "font_size": 19, "lines_coords": [[[693.0, 51.0], [713.0, 51.0], [713.0, 180.0], [693.0, 180.0]], [[673.0, 51.0], [693.0, 51.0], [693.0, 191.0], [673.0, 191.0]], [[651.0, 50.0], [671.0, 50.0], [672.0, 221.0], [652.0, 221.0]], [[633.0, 52.0], [650.0, 52.0], [650.0, 157.0], [633.0, 157.0]]], "lines": ["我々魔法戦士は", "ソウル体へ昇華し", "アカシックレコードへ", "調和を刻もう"]}, {"box": [212, 353, 234, 440], "vertical": true, "font_size": 19, "lines_coords": [[[212.0, 353.0], [233.0, 353.0], [234.0, 440.0], [213.0, 440.0]]], "lines": ["７月７日。"]}, {"box": [130, 492, 210, 631], "vertical": true, "font_size": 19, "lines_coords": [[[190.0, 492.0], [210.0, 492.0], [210.0, 614.0], [190.0, 614.0]], [[171.0, 492.0], [187.0, 492.0], [187.0, 598.0], [171.0, 598.0]], [[149.0, 492.0], [169.0, 492.0], [169.0, 631.0], [149.0, 631.0]], [[130.0, 492.0], [146.0, 492.0], [146.0, 618.0], [130.0, 618.0]]], "lines": ["乳の川と希望が", "すれ違う瞬間", "我々を思い出して", "くれたら幸いだ。"]}, {"box": [658, 769, 712, 928], "vertical": true, "font_size": 24, "lines_coords": [[[687.0, 769.0], [712.0, 769.0], [712.0, 928.0], [687.0, 928.0]], [[658.0, 769.0], [681.0, 769.0], [681.0, 907.0], [658.0, 907.0]]], "lines": ["グッドヴァイブ", "レーション．．．"]}, {"box": [139, 964, 193, 1136], "vertical": true, "font_size": 24, "lines_coords": [[[167.0, 964.0], [192.0, 964.0], [192.0, 1102.0], [167.0, 1102.0]], [[139.0, 964.0], [162.0, 964.0], [162.0, 1136.0], [139.0, 1136.0]]], "lines": ["美しい世界を", "Ｆｏｒｙｏｕ："]}], "img_path": "240.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [661, 70, 706, 166], "vertical": true, "font_size": 20, "lines_coords": [[[685.0, 71.0], [706.0, 71.0], [706.0, 146.0], [685.0, 146.0]], [[661.0, 70.0], [681.0, 70.0], [681.0, 166.0], [661.0, 166.0]]], "lines": ["１２音階の", "戦士達よ．．．"]}, {"box": [117, 193, 141, 271], "vertical": true, "font_size": 24, "lines_coords": [[[117.0, 193.0], [141.0, 193.0], [141.0, 270.0], [117.0, 270.0]]], "lines": ["．．．乾杯"]}, {"box": [675, 881, 697, 950], "vertical": true, "font_size": 22, "lines_coords": [[[675.0, 881.0], [697.0, 881.0], [697.0, 950.0], [675.0, 950.0]]], "lines": ["ま．．．．．"]}, {"box": [148, 1020, 175, 1125], "vertical": true, "font_size": 24, "lines_coords": [[[148.0, 1020.0], [173.0, 1020.0], [175.0, 1125.0], [151.0, 1125.0]]], "lines": ["．．．待って。"]}], "img_path": "241.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [671, 69, 741, 222], "vertical": true, "font_size": 30, "lines_coords": [[[706.0, 69.0], [739.0, 69.0], [741.0, 193.0], [708.0, 193.0]], [[671.0, 69.0], [699.0, 69.0], [702.0, 222.0], [674.0, 222.0]]], "lines": ["飲んじゃ", "ダメェッ！！"]}, {"box": [668, 529, 732, 662], "vertical": true, "font_size": 18, "lines_coords": [[[715.0, 529.0], [732.0, 529.0], [732.0, 662.0], [715.0, 662.0]], [[691.0, 529.0], [708.0, 529.0], [707.0, 660.0], [690.0, 660.0]], [[668.0, 529.0], [684.0, 529.0], [684.0, 643.0], [668.0, 643.0]]], "lines": ["こんな独善的な", "自己犠牲なんて", "馬鹿みたい！！"]}, {"box": [133, 386, 223, 495], "vertical": true, "font_size": 26, "lines_coords": [[[199.0, 389.0], [223.0, 389.0], [223.0, 493.0], [199.0, 493.0]], [[161.0, 386.0], [190.0, 386.0], [193.0, 495.0], [164.0, 495.0]], [[133.0, 387.0], [158.0, 387.0], [158.0, 469.0], [133.0, 469.0]]], "lines": ["こんなの", "間違って", "るッ！！"]}, {"box": [536, 619, 627, 735], "vertical": true, "font_size": 18, "lines_coords": [[[608.0, 619.0], [627.0, 619.0], [627.0, 735.0], [608.0, 735.0]], [[583.0, 621.0], [603.0, 621.0], [603.0, 718.0], [583.0, 718.0]], [[559.0, 621.0], [579.0, 621.0], [579.0, 735.0], [559.0, 735.0]], [[536.0, 621.0], [554.0, 621.0], [556.0, 698.0], [538.0, 698.0]]], "lines": ["私はみんなと", "仲良くなり", "たかっただけ", "なのに！！"]}, {"box": [372, 819, 394, 876], "vertical": true, "font_size": 23, "lines_coords": [[[372.0, 819.0], [394.0, 819.0], [394.0, 876.0], [372.0, 876.0]]], "lines": ["私も．．．"]}, {"box": [285, 839, 329, 929], "vertical": true, "font_size": 23, "lines_coords": [[[303.0, 839.0], [329.0, 839.0], [329.0, 898.0], [303.0, 898.0]], [[285.0, 841.0], [305.0, 841.0], [305.0, 929.0], [285.0, 929.0]]], "lines": ["とても", "怖いです．．．"]}, {"box": [671, 907, 755, 994], "vertical": true, "font_size": 19, "lines_coords": [[[734.0, 908.0], [755.0, 908.0], [755.0, 962.0], [734.0, 962.0]], [[715.0, 909.0], [732.0, 909.0], [732.0, 994.0], [715.0, 994.0]], [[693.0, 909.0], [709.0, 909.0], [709.0, 994.0], [693.0, 994.0]], [[671.0, 907.0], [693.0, 907.0], [693.0, 962.0], [671.0, 962.0]]], "lines": ["コレ！！", "まんこ姫！！", "おだまんな", "さい！！"]}, {"box": [112, 1037, 154, 1131], "vertical": true, "font_size": 21, "lines_coords": [[[128.0, 1037.0], [154.0, 1037.0], [154.0, 1094.0], [128.0, 1094.0]], [[112.0, 1039.0], [128.0, 1039.0], [128.0, 1129.0], [112.0, 1129.0]]], "lines": ["．．．でも", "ガンバだよ。"]}], "img_path": "242.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [663, 70, 743, 158], "vertical": true, "font_size": 18, "lines_coords": [[[722.0, 70.0], [742.0, 70.0], [742.0, 140.0], [722.0, 140.0]], [[701.0, 71.0], [720.0, 71.0], [722.0, 158.0], [704.0, 158.0]], [[685.0, 72.0], [701.0, 72.0], [701.0, 158.0], [685.0, 158.0]], [[663.0, 70.0], [679.0, 70.0], [679.0, 157.0], [663.0, 157.0]]], "lines": ["．．．確かに", "同調圧力が", "あった事は", "否めない．．．"]}, {"box": [404, 140, 487, 247], "vertical": true, "font_size": 18, "lines_coords": [[[467.0, 141.0], [487.0, 141.0], [487.0, 214.0], [467.0, 214.0]], [[447.0, 144.0], [463.0, 144.0], [463.0, 246.0], [447.0, 246.0]], [[426.0, 144.0], [442.0, 144.0], [442.0, 247.0], [426.0, 247.0]], [[404.0, 140.0], [425.0, 140.0], [425.0, 198.0], [404.0, 198.0]]], "lines": ["．．．もっと", "公平な議論が", "必要だったん", "だ．．．"]}, {"box": [84, 51, 298, 71], "vertical": false, "font_size": 20, "lines_coords": [[[84.0, 51.0], [298.0, 51.0], [298.0, 71.0], [84.0, 71.0]]], "lines": ["おやすみプンプン［Ｚ"]}, {"box": [658, 536, 700, 639], "vertical": true, "font_size": 18, "lines_coords": [[[680.0, 536.0], [700.0, 536.0], [700.0, 632.0], [680.0, 632.0]], [[659.0, 537.0], [675.0, 537.0], [675.0, 639.0], [659.0, 639.0]]], "lines": ["．．．いったん", "休憩しよう。"]}, {"box": [452, 292, 508, 408], "vertical": true, "font_size": 27, "lines_coords": [[[475.0, 292.0], [508.0, 292.0], [508.0, 345.0], [475.0, 345.0]], [[453.0, 296.0], [474.0, 296.0], [474.0, 408.0], [453.0, 408.0]]], "lines": ["この", "日和り者！！"]}, {"box": [105, 285, 130, 355], "vertical": true, "font_size": 25, "lines_coords": [[[105.0, 285.0], [130.0, 285.0], [130.0, 355.0], [105.0, 355.0]]], "lines": ["．．．ＯＫ。"]}, {"box": [142, 633, 209, 786], "vertical": true, "font_size": 20, "lines_coords": [[[189.0, 633.0], [209.0, 633.0], [209.0, 786.0], [189.0, 786.0]], [[166.0, 633.0], [186.0, 633.0], [186.0, 785.0], [166.0, 785.0]], [[142.0, 633.0], [162.0, 633.0], [162.0, 738.0], [142.0, 738.0]]], "lines": ["みんなの気持ちを", "ひとつにする事が", "大切なんだ。"]}], "img_path": "243.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [626, 94, 706, 215], "vertical": true, "font_size": 18, "lines_coords": [[[688.0, 96.0], [706.0, 96.0], [704.0, 182.0], [686.0, 182.0]], [[666.0, 94.0], [686.0, 94.0], [686.0, 199.0], [666.0, 199.0]], [[647.0, 96.0], [664.0, 96.0], [664.0, 199.0], [647.0, 199.0]], [[626.0, 97.0], [641.0, 97.0], [641.0, 215.0], [626.0, 215.0]]], "lines": ["何も疑わず", "死んでいれば", "時代の寵児に", "なれたものを．．．"]}, {"box": [128, 158, 212, 280], "vertical": true, "font_size": 18, "lines_coords": [[[194.0, 160.0], [210.0, 160.0], [210.0, 280.0], [194.0, 280.0]], [[172.0, 160.0], [188.0, 160.0], [188.0, 263.0], [172.0, 263.0]], [[149.0, 159.0], [169.0, 159.0], [169.0, 264.0], [149.0, 264.0]], [[128.0, 158.0], [148.0, 158.0], [148.0, 229.0], [128.0, 229.0]]], "lines": ["．．．いずれにせよ", "結果は大きく", "変わらない訳", "だが．．．"]}, {"box": [661, 420, 700, 514], "vertical": true, "font_size": 18, "lines_coords": [[[684.0, 420.0], [700.0, 420.0], [700.0, 489.0], [684.0, 489.0]], [[661.0, 420.0], [681.0, 420.0], [681.0, 514.0], [661.0, 514.0]]], "lines": ["．．．みんな", "真面目だな。"]}, {"box": [269, 365, 286, 411], "vertical": true, "font_size": 17, "lines_coords": [[[269.0, 365.0], [286.0, 365.0], [286.0, 411.0], [269.0, 411.0]]], "lines": ["お父さま"]}, {"box": [214, 588, 241, 649], "vertical": true, "font_size": 24, "lines_coords": [[[214.0, 588.0], [241.0, 588.0], [241.0, 649.0], [214.0, 649.0]]], "lines": ["いや．．．"]}, {"box": [152, 696, 197, 794], "vertical": true, "font_size": 24, "lines_coords": [[[169.0, 696.0], [197.0, 696.0], [197.0, 742.0], [169.0, 742.0]], [[152.0, 699.0], [168.0, 699.0], [168.0, 794.0], [152.0, 794.0]]], "lines": ["平凡", "なんだな．．．"]}, {"box": [673, 930, 713, 1044], "vertical": true, "font_size": 19, "lines_coords": [[[697.0, 930.0], [713.0, 930.0], [713.0, 1041.0], [697.0, 1041.0]], [[673.0, 930.0], [690.0, 930.0], [690.0, 1044.0], [673.0, 1044.0]]], "lines": ["その他大勢の", "烏合の衆が．．．"]}, {"box": [548, 996, 617, 1128], "vertical": true, "font_size": 19, "lines_coords": [[[596.0, 999.0], [617.0, 999.0], [617.0, 1074.0], [596.0, 1074.0]], [[575.0, 998.0], [591.0, 998.0], [591.0, 1128.0], [575.0, 1128.0]], [[548.0, 996.0], [572.0, 996.0], [572.0, 1065.0], [548.0, 1065.0]]], "lines": ["一丁前に", "主張するんじゃ", "ないよ。"]}], "img_path": "244.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [694, 69, 740, 148], "vertical": true, "font_size": 23, "lines_coords": [[[714.0, 69.0], [740.0, 69.0], [740.0, 132.0], [714.0, 132.0]], [[694.0, 70.0], [714.0, 70.0], [714.0, 148.0], [694.0, 148.0]]], "lines": ["純感は", "罪だな．．．"]}, {"box": [96, 182, 166, 280], "vertical": true, "font_size": 22, "lines_coords": [[[138.0, 182.0], [166.0, 182.0], [166.0, 233.0], [138.0, 233.0]], [[118.0, 185.0], [139.0, 185.0], [139.0, 262.0], [118.0, 262.0]], [[97.0, 186.0], [113.0, 186.0], [113.0, 280.0], [97.0, 280.0]]], "lines": ["．．．あ、", "もしもし", "警察さん？"]}, {"box": [650, 455, 708, 558], "vertical": true, "font_size": 17, "lines_coords": [[[692.0, 457.0], [708.0, 457.0], [708.0, 558.0], [692.0, 558.0]], [[670.0, 455.0], [686.0, 455.0], [686.0, 526.0], [670.0, 526.0]], [[650.0, 455.0], [666.0, 455.0], [666.0, 542.0], [650.0, 542.0]]], "lines": ["最近連続して", "起きてる", "強盗未遂．．．"]}, {"box": [479, 233, 559, 405], "vertical": true, "font_size": 16, "lines_coords": [[[540.0, 233.0], [559.0, 233.0], [559.0, 319.0], [540.0, 319.0]], [[520.0, 234.0], [536.0, 234.0], [536.0, 405.0], [520.0, 405.0]], [[499.0, 234.0], [515.0, 234.0], [515.0, 371.0], [499.0, 371.0]], [[479.0, 234.0], [494.0, 234.0], [494.0, 370.0], [479.0, 370.0]]], "lines": ["思考停止の", "足のひっぱり合いじゃ", "色気も何もあった", "もんじゃない．．．"]}, {"box": [593, 611, 653, 717], "vertical": true, "font_size": 17, "lines_coords": [[[637.0, 611.0], [653.0, 611.0], [653.0, 699.0], [637.0, 699.0]], [[617.0, 614.0], [632.0, 614.0], [632.0, 717.0], [617.0, 717.0]], [[593.0, 611.0], [615.0, 611.0], [615.0, 667.0], [593.0, 667.0]]], "lines": ["．．．そうそう", "ヒゲとメガネ", "の．．．．．．"]}, {"box": [135, 742, 209, 861], "vertical": true, "font_size": 24, "lines_coords": [[[178.0, 742.0], [209.0, 742.0], [209.0, 793.0], [178.0, 793.0]], [[160.0, 747.0], [180.0, 747.0], [180.0, 861.0], [160.0, 861.0]], [[135.0, 745.0], [155.0, 745.0], [155.0, 823.0], [135.0, 823.0]]], "lines": ["．．．僕", "居場所知って", "ます．．．．．"]}, {"box": [641, 960, 692, 1096], "vertical": true, "font_size": 20, "lines_coords": [[[672.0, 960.0], [692.0, 960.0], [692.0, 1096.0], [672.0, 1096.0]], [[641.0, 960.0], [661.0, 960.0], [664.0, 1065.0], [644.0, 1065.0]]], "lines": ["．．．ペガサスこと", "星川敏樹は、"]}, {"box": [145, 997, 214, 1112], "vertical": true, "font_size": 19, "lines_coords": [[[192.0, 998.0], [213.0, 998.0], [214.0, 1094.0], [193.0, 1094.0]], [[171.0, 999.0], [187.0, 999.0], [187.0, 1112.0], [171.0, 1112.0]], [[145.0, 997.0], [165.0, 997.0], [165.0, 1093.0], [145.0, 1093.0]]], "lines": ["いつだって", "俺と対極の男", "だった．．．"]}], "img_path": "245.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [617, 76, 715, 216], "vertical": true, "font_size": 18, "lines_coords": [[[695.0, 78.0], [715.0, 78.0], [715.0, 147.0], [695.0, 147.0]], [[677.0, 78.0], [693.0, 78.0], [693.0, 181.0], [677.0, 181.0]], [[653.0, 76.0], [673.0, 76.0], [674.0, 216.0], [654.0, 216.0]], [[633.0, 77.0], [650.0, 77.0], [650.0, 214.0], [633.0, 214.0]]], "lines": ["奴はこの", "愚鈍に溢れた", "世の中を最後まで", "信頼しようとした"]}, {"box": [261, 70, 320, 208], "vertical": true, "font_size": 18, "lines_coords": [[[301.0, 71.0], [320.0, 71.0], [320.0, 141.0], [301.0, 141.0]], [[281.0, 70.0], [301.0, 70.0], [301.0, 208.0], [281.0, 208.0]], [[261.0, 70.0], [277.0, 70.0], [277.0, 162.0], [261.0, 162.0]]], "lines": ["一方俺は", "他人を疑い嘲って", "生きてきた。"]}, {"box": [147, 203, 228, 341], "vertical": true, "font_size": 18, "lines_coords": [[[208.0, 203.0], [228.0, 203.0], [228.0, 341.0], [208.0, 341.0]], [[188.0, 205.0], [205.0, 205.0], [205.0, 307.0], [188.0, 307.0]], [[166.0, 203.0], [186.0, 203.0], [186.0, 309.0], [166.0, 309.0]], [[147.0, 205.0], [164.0, 205.0], [164.0, 324.0], [147.0, 324.0]]], "lines": ["不正確なものへの", "懐疑をついに", "拭い去る事は", "出来なかった．．．"]}, {"box": [659, 632, 719, 735], "vertical": true, "font_size": 21, "lines_coords": [[[701.0, 632.0], [719.0, 632.0], [716.0, 734.0], [699.0, 734.0]], [[679.0, 632.0], [699.0, 632.0], [699.0, 735.0], [679.0, 735.0]], [[659.0, 633.0], [675.0, 633.0], [675.0, 707.0], [659.0, 707.0]]], "lines": ["俺は絶対」に", "取り憑かれて", "いたんだ"]}, {"box": [581, 739, 646, 814], "vertical": true, "font_size": 21, "lines_coords": [[[622.0, 741.0], [646.0, 741.0], [646.0, 814.0], [622.0, 814.0]], [[603.0, 740.0], [624.0, 740.0], [624.0, 810.0], [603.0, 810.0]], [[581.0, 739.0], [606.0, 739.0], [606.0, 788.0], [581.0, 788.0]]], "lines": ["．．．しかし", "人の心は", "深淵。"]}, {"box": [133, 676, 220, 819], "vertical": true, "font_size": 17, "lines_coords": [[[201.0, 676.0], [217.0, 676.0], [217.0, 816.0], [201.0, 816.0]], [[180.0, 676.0], [196.0, 676.0], [196.0, 813.0], [180.0, 813.0]], [[154.0, 676.0], [171.0, 676.0], [171.0, 812.0], [154.0, 812.0]], [[133.0, 676.0], [153.0, 676.0], [153.0, 748.0], [133.0, 748.0]]], "lines": ["疑えばきりはなく", "真実を求めるほど", "霞み朧げになって", "ゆく．．．"]}, {"box": [128, 952, 243, 1067], "vertical": true, "font_size": 19, "lines_coords": [[[223.0, 953.0], [243.0, 953.0], [243.0, 1067.0], [223.0, 1067.0]], [[200.0, 952.0], [220.0, 952.0], [217.0, 1067.0], [197.0, 1067.0]], [[178.0, 953.0], [194.0, 953.0], [194.0, 1067.0], [178.0, 1067.0]], [[152.0, 953.0], [172.0, 953.0], [172.0, 1066.0], [152.0, 1066.0]], [[128.0, 952.0], [148.0, 952.0], [148.0, 1038.0], [128.0, 1038.0]]], "lines": ["．．．つまり俺は", "わかったんだ", "真実とは己で", "作り出すもの", "なのだと。"]}], "img_path": "246.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [677, 89, 705, 205], "vertical": true, "font_size": 20, "lines_coords": [[[677.0, 89.0], [697.0, 89.0], [697.0, 205.0], [677.0, 205.0]]], "lines": ["関真澄くん．．．"]}, {"box": [145, 191, 225, 304], "vertical": true, "font_size": 21, "lines_coords": [[[201.0, 191.0], [221.0, 191.0], [221.0, 303.0], [201.0, 303.0]], [[173.0, 193.0], [194.0, 193.0], [194.0, 304.0], [173.0, 304.0]], [[145.0, 193.0], [166.0, 193.0], [166.0, 281.0], [145.0, 281.0]]], "lines": ["君が信じて", "いるものは", "何だい？"]}, {"box": [656, 769, 713, 890], "vertical": true, "font_size": 18, "lines_coords": [[[697.0, 771.0], [713.0, 771.0], [713.0, 839.0], [697.0, 839.0]], [[677.0, 771.0], [693.0, 771.0], [693.0, 873.0], [677.0, 873.0]], [[656.0, 769.0], [672.0, 769.0], [672.0, 890.0], [656.0, 890.0]]], "lines": ["俺が君に", "関心を持った", "理由は単純だ．．．"]}, {"box": [161, 826, 259, 947], "vertical": true, "font_size": 16, "lines_coords": [[[242.0, 826.0], [258.0, 826.0], [258.0, 903.0], [242.0, 903.0]], [[221.0, 826.0], [237.0, 826.0], [237.0, 945.0], [221.0, 945.0]]], "lines": ["．．．そうさ、", "偶然の出会いが"]}, {"box": [156, 825, 216, 945], "vertical": true, "font_size": 18, "lines_coords": [[[200.0, 827.0], [216.0, 827.0], [216.0, 945.0], [200.0, 945.0]], [[179.0, 827.0], [195.0, 827.0], [195.0, 944.0], [179.0, 944.0]], [[156.0, 825.0], [178.0, 825.0], [178.0, 878.0], [156.0, 878.0]]], "lines": ["人生を左右する", "なんて馬鹿げて", "る．．．．．"]}, {"box": [602, 935, 682, 1057], "vertical": true, "font_size": 18, "lines_coords": [[[661.0, 935.0], [682.0, 935.0], [682.0, 1006.0], [661.0, 1006.0]], [[641.0, 936.0], [661.0, 936.0], [661.0, 1040.0], [641.0, 1040.0]], [[620.0, 936.0], [640.0, 936.0], [640.0, 1057.0], [620.0, 1057.0]], [[602.0, 937.0], [618.0, 937.0], [618.0, 1039.0], [602.0, 1039.0]]], "lines": ["．．．お互い", "大変な友人を", "持ってしまった", "ものだね．．．"]}, {"box": [97, 1013, 155, 1100], "vertical": true, "font_size": 18, "lines_coords": [