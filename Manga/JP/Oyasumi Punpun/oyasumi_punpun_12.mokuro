、"]}, {"box": [137, 122, 158, 297], "vertical": true, "font_size": 21, "lines_coords": [[[137.0, 122.0], [158.0, 122.0], [158.0, 297.0], [137.0, 297.0]]], "lines": ["絶望をありがとう。」"]}, {"box": [139, 125, 155, 294], "vertical": true, "font_size": 18, "lines_coords": [[[139.0, 125.0], [155.0, 125.0], [155.0, 294.0], [139.0, 294.0]]], "lines": ["絶望をありがとう。"]}, {"box": [670, 493, 691, 578], "vertical": true, "font_size": 21, "lines_coords": [[[670.0, 493.0], [691.0, 493.0], [691.0, 578.0], [670.0, 578.0]]], "lines": ["．．．行くよ。"]}], "img_path": "044.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [442, 94, 463, 161], "vertical": true, "font_size": 21, "lines_coords": [[[442.0, 94.0], [463.0, 94.0], [463.0, 160.0], [442.0, 160.0]]], "lines": ["．．．南条、"]}, {"box": [148, 87, 209, 196], "vertical": true, "font_size": 22, "lines_coords": [[[187.0, 87.0], [209.0, 87.0], [209.0, 145.0], [187.0, 145.0]], [[168.0, 89.0], [188.0, 89.0], [188.0, 160.0], [168.0, 160.0]], [[148.0, 89.0], [164.0, 89.0], [164.0, 196.0], [148.0, 196.0]]], "lines": ["だから", "あたしは", "言ったんだよ"]}, {"box": [107, 217, 180, 341], "vertical": true, "font_size": 22, "lines_coords": [[[152.0, 217.0], [180.0, 217.0], [180.0, 268.0], [152.0, 268.0]], [[130.0, 223.0], [155.0, 223.0], [155.0, 287.0], [130.0, 287.0]], [[107.0, 223.0], [127.0, 223.0], [130.0, 341.0], [110.0, 341.0]]], "lines": ["早く", "素直に", "なれってさ！！"]}, {"box": [19, 222, 66, 349], "vertical": true, "font_size": 43, "lines_coords": [[[19.0, 223.0], [62.0, 222.0], [66.0, 348.0], [24.0, 349.0]]], "lines": ["第１２４話"]}, {"box": [700, 482, 743, 570], "vertical": true, "font_size": 22, "lines_coords": [[[718.0, 482.0], [743.0, 482.0], [743.0, 540.0], [718.0, 540.0]], [[700.0, 485.0], [716.0, 485.0], [716.0, 570.0], [700.0, 570.0]]], "lines": ["．．．おぉ", "蟹江さん．．．"]}, {"box": [651, 619, 700, 717], "vertical": true, "font_size": 22, "lines_coords": [[[671.0, 621.0], [698.0, 619.0], [700.0, 682.0], [673.0, 683.0]], [[651.0, 619.0], [672.0, 619.0], [673.0, 717.0], [652.0, 717.0]]], "lines": ["肉です", "なあ～～～．．．"]}, {"box": [153, 671, 254, 823], "vertical": true, "font_size": 16, "lines_coords": [[[236.0, 671.0], [253.0, 671.0], [253.0, 791.0], [236.0, 791.0]], [[215.0, 671.0], [231.0, 671.0], [231.0, 823.0], [215.0, 823.0]], [[194.0, 671.0], [210.0, 671.0], [210.0, 757.0], [194.0, 757.0]], [[173.0, 672.0], [189.0, 672.0], [189.0, 774.0], [173.0, 774.0]], [[153.0, 671.0], [169.0, 671.0], [169.0, 808.0], [153.0, 808.0]]], "lines": ["気付いた時には", "とり返しがつかない", "という事は", "人生に於いて", "往々にしてある！！"]}, {"box": [148, 1001, 196, 1119], "vertical": true, "font_size": 24, "lines_coords": [[[174.0, 1004.0], [195.0, 1004.0], [196.0, 1082.0], [175.0, 1082.0]], [[148.0, 1001.0], [175.0, 1001.0], [175.0, 1045.0], [148.0, 1045.0]]], "lines": ["こんにち", "はー"]}], "img_path": "045.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [666, 501, 727, 622], "vertical": true, "font_size": 20, "lines_coords": [[[711.0, 503.0], [727.0, 503.0], [727.0, 622.0], [711.0, 622.0]], [[688.0, 502.0], [708.0, 502.0], [708.0, 608.0], [688.0, 608.0]], [[666.0, 501.0], [688.0, 501.0], [688.0, 557.0], [666.0, 557.0]]], "lines": ["：小野寺くんの", "仲の良かった", "子．．．"]}, {"box": [482, 385, 530, 403], "vertical": false, "font_size": 18, "lines_coords": [[[482.0, 385.0], [530.0, 385.0], [530.0, 403.0], [482.0, 403.0]]], "lines": ["ｃｏｌｅｚ"]}, {"box": [570, 594, 630, 699], "vertical": true, "font_size": 20, "lines_coords": [[[613.0, 596.0], [630.0, 596.0], [630.0, 667.0], [613.0, 667.0]], [[590.0, 594.0], [611.0, 594.0], [612.0, 699.0], [591.0, 699.0]], [[570.0, 594.0], [591.0, 594.0], [591.0, 650.0], [570.0, 650.0]]], "lines": ["うーん", "そうですねぇ", "～～～．．．"]}, {"box": [708, 766, 745, 868], "vertical": true, "font_size": 17, "lines_coords": [[[728.0, 766.0], [745.0, 766.0], [745.0, 868.0], [728.0, 868.0]], [[708.0, 766.0], [725.0, 766.0], [725.0, 856.0], [708.0, 856.0]]], "lines": ["．．．聞くまでも", "なかったか"]}, {"box": [615, 796, 672, 901], "vertical": true, "font_size": 17, "lines_coords": [[[656.0, 796.0], [672.0, 796.0], [672.0, 874.0], [656.0, 874.0]], [[634.0, 796.0], [651.0, 796.0], [651.0, 884.0], [634.0, 884.0]], [[615.0, 798.0], [631.0, 798.0], [631.0, 901.0], [615.0, 901.0]]], "lines": ["．．．ま、あの", "卑屈な性格", "じゃあね．．．"]}, {"box": [413, 758, 472, 894], "vertical": true, "font_size": 18, "lines_coords": [[[452.0, 758.0], [469.0, 758.0], [472.0, 861.0], [454.0, 861.0]], [[434.0, 758.0], [449.0, 758.0], [449.0, 894.0], [434.0, 894.0]], [[413.0, 758.0], [428.0, 758.0], [428.0, 894.0], [413.0, 894.0]]], "lines": ["確かに高校の", "三年間目立たない", "感じだったけど．．．"]}, {"box": [315, 796, 376, 918], "vertical": true, "font_size": 18, "lines_coords": [[[352.0, 796.0], [374.0, 796.0], [376.0, 869.0], [353.0, 869.0]], [[335.0, 798.0], [354.0, 798.0], [354.0, 870.0], [335.0, 870.0]], [[315.0, 800.0], [331.0, 800.0], [331.0, 918.0], [315.0, 918.0]]], "lines": ["別に悪く", "言う人も", "いなかったし．．"]}, {"box": [137, 557, 217, 712], "vertical": true, "font_size": 17, "lines_coords": [[[197.0, 557.0], [217.0, 557.0], [217.0, 626.0], [197.0, 626.0]], [[179.0, 558.0], [195.0, 558.0], [195.0, 694.0], [179.0, 694.0]], [[156.0, 557.0], [173.0, 557.0], [173.0, 677.0], [156.0, 677.0]], [[137.0, 560.0], [153.0, 560.0], [153.0, 712.0], [137.0, 712.0]]], "lines": ["あたしの", "知ってる限りでは", "高校で女友達は", "いなかったような．．．"]}, {"box": [523, 1003, 570, 1087], "vertical": true, "font_size": 24, "lines_coords": [[[543.0, 1003.0], [570.0, 1003.0], [570.0, 1062.0], [543.0, 1062.0]], [[523.0, 1003.0], [544.0, 1003.0], [544.0, 1086.0], [523.0, 1086.0]]], "lines": ["．．．あっ", "でもでも、"]}, {"box": [229, 973, 249, 1042], "vertical": true, "font_size": 18, "lines_coords": [[[229.0, 973.0], [249.0, 973.0], [249.0, 1042.0], [229.0, 1042.0]]], "lines": ["ふぅん．．．"]}, {"box": [106, 973, 183, 1128], "vertical": true, "font_size": 18, "lines_coords": [[[167.0, 975.0], [183.0, 975.0], [183.0, 1128.0], [167.0, 1128.0]], [[146.0, 973.0], [164.0, 973.0], [165.0, 1128.0], [147.0, 1128.0]], [[127.0, 975.0], [144.0, 975.0], [144.0, 1110.0], [127.0, 1110.0]], [[106.0, 975.0], [123.0, 975.0], [123.0, 1083.0], [106.0, 1083.0]]], "lines": ["あいつの自信喪失は", "学生時代によっぽど", "トラウマがあると", "思ってたけど。"]}], "img_path": "046.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [678, 73, 738, 194], "vertical": true, "font_size": 18, "lines_coords": [[[721.0, 76.0], [738.0, 76.0], [738.0, 194.0], [721.0, 194.0]], [[700.0, 75.0], [716.0, 75.0], [716.0, 179.0], [700.0, 179.0]], [[678.0, 73.0], [698.0, 73.0], [698.0, 179.0], [678.0, 179.0]]], "lines": ["あたしの印象は", "生真面目な人", "だなーって．．．"]}, {"box": [647, 234, 707, 338], "vertical": true, "font_size": 18, "lines_coords": [[[686.0, 234.0], [707.0, 234.0], [707.0, 289.0], [686.0, 289.0]], [[667.0, 235.0], [684.0, 235.0], [684.0, 322.0], [667.0, 322.0]], [[647.0, 235.0], [663.0, 235.0], [663.0, 338.0], [647.0, 338.0]]], "lines": ["頑固と", "言えばそう", "なんだけど．．．"]}, {"box": [398, 82, 483, 221], "vertical": true, "font_size": 18, "lines_coords": [[[459.0, 83.0], [479.0, 83.0], [479.0, 171.0], [459.0, 171.0]], [[440.0, 84.0], [456.0, 84.0], [456.0, 169.0], [440.0, 169.0]], [[417.0, 82.0], [436.0, 82.0], [435.0, 221.0], [415.0, 221.0]], [[398.0, 84.0], [414.0, 84.0], [414.0, 203.0], [398.0, 203.0]]], "lines": ["梓ちゃんは", "フンプンの", "そういうところが", "好きだったの？"]}, {"box": [197, 49, 277, 154], "vertical": true, "font_size": 18, "lines_coords": [[[257.0, 50.0], [277.0, 50.0], [277.0, 154.0], [257.0, 154.0]], [[236.0, 49.0], [256.0, 49.0], [256.0, 153.0], [236.0, 153.0]], [[217.0, 49.0], [234.0, 49.0], [234.0, 153.0], [217.0, 153.0]], [[197.0, 49.0], [215.0, 49.0], [215.0, 86.0], [197.0, 86.0]]], "lines": ["いやいや全然", "好きとかじゃ", "なくて流れて", "．．．．．"]}, {"box": [112, 140, 193, 288], "vertical": true, "font_size": 18, "lines_coords": [[[171.0, 140.0], [190.0, 140.0], [193.0, 229.0], [173.0, 229.0]], [[152.0, 142.0], [168.0, 142.0], [168.0, 288.0], [152.0, 288.0]], [[133.0, 142.0], [149.0, 142.0], [149.0, 280.0], [133.0, 280.0]], [[112.0, 142.0], [128.0, 142.0], [128.0, 288.0], [112.0, 288.0]]], "lines": ["．．．やっぱり", "あるじゃないですか", "高校生なりたてて", "大人びたい瞬間って"]}, {"box": [550, 404, 611, 508], "vertical": true, "font_size": 20, "lines_coords": [[[591.0, 405.0], [611.0, 405.0], [609.0, 508.0], [589.0, 508.0]], [[571.0, 404.0], [591.0, 404.0], [589.0, 493.0], [569.0, 493.0]], [[550.0, 404.0], [571.0, 404.0], [571.0, 460.0], [550.0, 460.0]]], "lines": ["嘘のつけない", "人って感じ", "て．．．．．"]}, {"box": [444, 350, 483, 437], "vertical": true, "font_size": 18, "lines_coords": [[[462.0, 350.0], [483.0, 350.0], [483.0, 421.0], [462.0, 421.0]], [[444.0, 350.0], [460.0, 350.0], [460.0, 437.0], [444.0, 437.0]]], "lines": ["．．．おい姉", "聞いたか！？"]}, {"box": [323, 365, 401, 503], "vertical": true, "font_size": 18, "lines_coords": [[[385.0, 366.0], [401.0, 366.0], [401.0, 451.0], [385.0, 451.0]], [[361.0, 365.0], [381.0, 365.0], [384.0, 469.0], [364.0, 469.0]], [[342.0, 365.0], [361.0, 365.0], [361.0, 503.0], [342.0, 503.0]], [[323.0, 366.0], [339.0, 366.0], [339.0, 492.0], [323.0, 492.0]]], "lines": ["お前の妹の", "思わせぶりが", "人ひとりの人格を", "破壊したんだぞ。"]}, {"box": [111, 434, 132, 502], "vertical": true, "font_size": 21, "lines_coords": [[[111.0, 434.0], [132.0, 434.0], [132.0, 502.0], [111.0, 502.0]]], "lines": ["知るか。"]}, {"box": [692, 814, 716, 896], "vertical": true, "font_size": 18, "lines_coords": [[[692.0, 814.0], [716.0, 814.0], [716.0, 896.0], [692.0, 896.0]]], "lines": ["でも．．．．．．"]}, {"box": [592, 923, 693, 1113], "vertical": true, "font_size": 18, "lines_coords": [[[677.0, 924.0], [693.0, 924.0], [693.0, 1028.0], [677.0, 1028.0]], [[656.0, 924.0], [672.0, 924.0], [670.0, 1079.0], [653.0, 1079.0]], [[632.0, 923.0], [652.0, 923.0], [652.0, 1113.0], [632.0, 1113.0]], [[613.0, 925.0], [630.0, 925.0], [630.0, 1045.0], [613.0, 1045.0]], [[592.0, 926.0], [609.0, 926.0], [609.0, 1062.0], [592.0, 1062.0]]], "lines": ["喧嘩した後も", "話しかけてくれたり", "仲のいいグループ同士で", "遊びに行った時", "一緒になったり．．．"]}, {"box": [169, 853, 250, 1025], "vertical": true, "font_size": 18, "lines_coords": [[[234.0, 853.0], [250.0, 853.0], [250.0, 990.0], [234.0, 990.0]], [[213.0, 854.0], [229.0, 854.0], [229.0, 1025.0], [213.0, 1025.0]], [[192.0, 854.0], [208.0, 854.0], [208.0, 992.0], [192.0, 992.0]], [[169.0, 853.0], [186.0, 853.0], [188.0, 962.0], [172.0, 962.0]]], "lines": ["むこうはこれ以上", "気まずくならないよう", "無理してたのかも", "しれないけど、"]}, {"box": [93, 1005, 161, 1121], "vertical": true, "font_size": 18, "lines_coords": [[[140.0, 1005.0], [161.0, 1005.0], [161.0, 1083.0], [140.0, 1083.0]], [[117.0, 1006.0], [137.0, 1006.0], [137.0, 1121.0], [117.0, 1121.0]], [[93.0, 1006.0], [114.0, 1006.0], [114.0, 1083.0], [93.0, 1083.0]]], "lines": ["．．．普通に", "いい人だなー", "って．．．"]}], "img_path": "047.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [731, 78, 755, 155], "vertical": true, "font_size": 19, "lines_coords": [[[731.0, 78.0], [755.0, 78.0], [755.0, 155.0], [731.0, 155.0]]], "lines": ["へえ．．．"]}, {"box": [604, 105, 684, 210], "vertical": true, "font_size": 19, "lines_coords": [[[667.0, 105.0], [684.0, 105.0], [684.0, 192.0], [667.0, 192.0]], [[644.0, 105.0], [664.0, 105.0], [664.0, 210.0], [644.0, 210.0]], [[625.0, 106.0], [641.0, 106.0], [641.0, 208.0], [625.0, 208.0]], [[604.0, 106.0], [620.0, 106.0], [620.0, 199.0], [604.0, 199.0]]], "lines": ["そんな気を", "利かせられる", "男だったかね", "フンフンて"]}, {"box": [121, 134, 202, 255], "vertical": true, "font_size": 18, "lines_coords": [[[182.0, 134.0], [202.0, 134.0], [202.0, 222.0], [182.0, 222.0]], [[161.0, 134.0], [179.0, 134.0], [180.0, 221.0], [162.0, 221.0]], [[142.0, 135.0], [159.0, 135.0], [159.0, 255.0], [142.0, 255.0]], [[121.0, 135.0], [138.0, 135.0], [138.0, 247.0], [121.0, 247.0]]], "lines": ["むしろ気を", "遣い過ぎて", "逆効果なんだよ", "小野寺くんは。"]}, {"box": [685, 309, 743, 430], "vertical": true, "font_size": 17, "lines_coords": [[[727.0, 311.0], [743.0, 311.0], [743.0, 397.0], [727.0, 397.0]], [[705.0, 310.0], [721.0, 310.0], [721.0, 430.0], [705.0, 430.0]], [[685.0, 309.0], [701.0, 309.0], [702.0, 406.0], [686.0, 406.0]]], "lines": ["自信過剰で", "客観性ない奴は", "論外だけど。"]}, {"box": [619, 453, 697, 592], "vertical": true, "font_size": 17, "lines_coords": [[[681.0, 454.0], [697.0, 454.0], [697.0, 575.0], [681.0, 575.0]], [[660.0, 454.0], [677.0, 454.0], [677.0, 557.0], [660.0, 557.0]], [[638.0, 453.0], [658.0, 453.0], [658.0, 592.0], [638.0, 592.0]], [[619.0, 454.0], [634.0, 454.0], [634.0, 548.0], [619.0, 548.0]]], "lines": ["あたしから見た", "小野寺くんは", "ちょっと自己評価", "低過ぎだよ。"]}, {"box": [126, 530, 207, 651], "vertical": true, "font_size": 18, "lines_coords": [[[190.0, 530.0], [207.0, 530.0], [205.0, 617.0], [188.0, 617.0]], [[169.0, 532.0], [186.0, 532.0], [186.0, 651.0], [169.0, 651.0]], [[148.0, 532.0], [165.0, 532.0], [165.0, 635.0], [148.0, 635.0]], [[126.0, 530.0], [148.0, 530.0], [148.0, 577.0], [126.0, 577.0]]], "lines": ["それもまた", "自意識過剰さが", "故だとは思う", "けど。"]}, {"box": [651, 744, 730, 897], "vertical": true, "font_size": 16, "lines_coords": [[[713.0, 744.0], [729.0, 744.0], [729.0, 829.0], [713.0, 829.0]], [[692.0, 745.0], [708.0, 745.0], [708.0, 847.0], [692.0, 847.0]], [[670.0, 744.0], [686.0, 744.0], [686.0, 897.0], [670.0, 897.0]], [[651.0, 745.0], [666.0, 745.0], [666.0, 837.0], [651.0, 837.0]]], "lines": ["もっと心底", "他人を馬鹿に", "てきるようになれば", "楽なのにさ。"]}, {"box": [350, 741, 431, 862], "vertical": true, "font_size": 18, "lines_coords": [[[413.0, 744.0], [429.0, 744.0], [429.0, 862.0], [413.0, 862.0]], [[391.0, 742.0], [411.0, 742.0], [411.0, 832.0], [391.0, 832.0]], [[370.0, 741.0], [391.0, 741.0], [391.0, 813.0], [370.0, 813.0]], [[350.0, 741.0], [366.0, 741.0], [366.0, 851.0], [350.0, 851.0]]], "lines": ["あいつがそんな", "尊大な態度", "とったら", "はったおすわ。"]}, {"box": [511, 986, 556, 1100], "vertical": true, "font_size": 20, "lines_coords": [[[536.0, 987.0], [556.0, 987.0], [556.0, 1100.0], [536.0, 1100.0]], [[511.0, 986.0], [531.0, 986.0], [531.0, 1072.0], [511.0, 1072.0]]], "lines": ["優しい人って", "損だよね。"]}, {"box": [223, 978, 243, 1048], "vertical": true, "font_size": 18, "lines_coords": [[[223.0, 978.0], [243.0, 978.0], [243.0, 1048.0], [223.0, 1048.0]]], "lines": ["．．．そう？"]}, {"box": [106, 1003, 187, 1125], "vertical": true, "font_size": 18, "lines_coords": [[[171.0, 1004.0], [187.0, 1004.0], [187.0, 1107.0], [171.0, 1107.0]], [[149.0, 1004.0], [166.0, 1004.0], [166.0, 1125.0], [149.0, 1125.0]], [[128.0, 1004.0], [145.0, 1004.0], [145.0, 1108.0], [128.0, 1108.0]], [[106.0, 1003.0], [127.0, 1003.0], [127.0, 1057.0], [106.0, 1057.0]]], "lines": ["小野寺くんて", "割りとちゃんと", "してると思う", "けど？"]}], "img_path": "048.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [645, 71, 725, 227], "vertical": true, "font_size": 17, "lines_coords": [[[708.0, 73.0], [725.0, 73.0], [725.0, 227.0], [708.0, 227.0]], [[687.0, 72.0], [704.0, 72.0], [704.0, 191.0], [687.0, 191.0]], [[667.0, 71.0], [684.0, 71.0], [681.0, 192.0], [665.0, 192.0]], [[645.0, 71.0], [661.0, 71.0], [661.0, 214.0], [645.0, 214.0]]], "lines": ["フリーターとはいえ", "現状一応は自立", "てきてる訳だし", "資格の勉強もして、"]}, {"box": [524, 202, 585, 312], "vertical": true, "font_size": 17, "lines_coords": [[[563.0, 202.0], [585.0, 202.0], [585.0, 257.0], [563.0, 257.0]], [[545.0, 202.0], [563.0, 202.0], [561.0, 307.0], [543.0, 307.0]], [[524.0, 203.0], [541.0, 203.0], [541.0, 312.0], [524.0, 312.0]]], "lines": ["そして", "それを愚痴る", "訳てもなくね。"]}, {"box": [223, 113, 302, 234], "vertical": true, "font_size": 16, "lines_coords": [[[284.0, 113.0], [302.0, 113.0], [299.0, 201.0], [282.0, 201.0]], [[263.0, 116.0], [279.0, 116.0], [279.0, 219.0], [263.0, 219.0]], [[243.0, 116.0], [260.0, 116.0], [260.0, 234.0], [243.0, 234.0]], [[224.0, 117.0], [238.0, 117.0], [238.0, 207.0], [224.0, 207.0]]], "lines": ["まぁ南条は", "小野寺くんに", "自信持たれちゃ", "困るもんな。"]}, {"box": [463, 338, 544, 476], "vertical": true, "font_size": 17, "lines_coords": [[[528.0, 339.0], [544.0, 339.0], [544.0, 444.0], [528.0, 444.0]], [[506.0, 338.0], [521.0, 338.0], [523.0, 460.0], [508.0, 460.0]], [[486.0, 341.0], [502.0, 341.0], [502.0, 476.0], [486.0, 476.0]], [[463.0, 341.0], [480.0, 341.0], [482.0, 451.0], [466.0, 451.0]]], "lines": ["才能あろうが", "能書き垂れてる", "だけの奴よりかは", "マシでしょう。"]}, {"box": [83, 357, 164, 469], "vertical": true, "font_size": 18, "lines_coords": [[[144.0, 358.0], [164.0, 358.0], [164.0, 446.0], [144.0, 446.0]], [[123.0, 358.0], [144.0, 358.0], [144.0, 430.0], [123.0, 430.0]], [[104.0, 358.0], [120.0, 358.0], [120.0, 442.0], [104.0, 442.0]], [[83.0, 357.0], [98.0, 357.0], [98.0, 467.0], [83.0, 467.0]]], "lines": ["常に自分の", "手の内で", "飼い殺しに", "するためには。"]}, {"box": [649, 557, 727, 685], "vertical": true, "font_size": 17, "lines_coords": [[[711.0, 557.0], [727.0, 557.0], [727.0, 652.0], [711.0, 652.0]], [[690.0, 558.0], [706.0, 558.0], [706.0, 677.0], [690.0, 677.0]], [[667.0, 558.0], [684.0, 558.0], [684.0, 685.0], [667.0, 685.0]], [[649.0, 557.0], [665.0, 557.0], [665.0, 665.0], [649.0, 665.0]]], "lines": ["「自分を理解", "してくれるのは", "この人だけ」って", "錯覚するよう、"]}, {"box": [584, 726, 684, 848], "vertical": true, "font_size": 17, "lines_coords": [[[667.0, 730.0], [684.0, 730.0], [684.0, 848.0], [667.0, 848.0]], [[647.0, 728.0], [664.0, 728.0], [664.0, 830.0], [647.0, 830.0]], [[625.0, 728.0], [641.0, 728.0], [641.0, 832.0], [625.0, 832.0]], [[603.0, 726.0], [623.0, 726.0], [620.0, 832.0], [600.0, 832.0]], [[584.0, 728.0], [600.0, 728.0], [600.0, 819.0], [584.0, 819.0]]], "lines": ["いつもアンタは", "自分の都合で", "小野寺くんを", "甘やかしたり", "叱責したり、"]}, {"box": [125, 752, 224, 889], "vertical": true, "font_size": 18, "lines_coords": [[[208.0, 753.0], [224.0, 753.0], [224.0, 856.0], [208.0, 856.0]], [[187.0, 753.0], [203.0, 753.0], [203.0, 856.0], [187.0, 856.0]], [[165.0, 752.0], [185.0, 752.0], [182.0, 841.0], [162.0, 841.0]], [[145.0, 754.0], [161.0, 754.0], [161.0, 856.0], [145.0, 856.0]], [[125.0, 754.0], [141.0, 754.0], [141.0, 889.0], [125.0, 889.0]]], "lines": ["小野寺くんが", "本当はどんな", "人間なのか", "南条はそれで", "知ってるつもり？"]}, {"box": [74, 951, 155, 1074], "vertical": true, "font_size": 18, "lines_coords": [[[135.0, 952.0], [155.0, 952.0], [155.0, 1074.0], [135.0, 1074.0]], [[115.0, 951.0], [137.0, 951.0], [134.0, 1073.0], [113.0, 1073.0]], [[96.0, 953.0], [112.0, 953.0], [112.0, 1072.0], [96.0, 1072.0]], [[74.0, 953.0], [91.0, 953.0], [91.0, 1046.0], [74.0, 1046.0]]], "lines": ["そういう傲慢な", "人付き合いしか", "できないなんて", "可哀想だわ。"]}], "img_path": "049.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [688, 62, 770, 201], "vertical": true, "font_size": 20, "lines_coords": [[[749.0, 63.0], [770.0, 63.0], [770.0, 135.0], [749.0, 135.0]], [[729.0, 63.0], [749.0, 63.0], [749.0, 201.0], [729.0, 201.0]], [[707.0, 62.0], [727.0, 62.0], [729.0, 168.0], [709.0, 168.0]], [[688.0, 64.0], [706.0, 64.0], [706.0, 116.0], [688.0, 116.0]]], "lines": ["．．．じゃあ", "プンプンが一人で", "生きてけると", "思う？"]}, {"box": [677, 492, 756, 596], "vertical": true, "font_size": 17, "lines_coords": [[[740.0, 493.0], [756.0, 493.0], [756.0, 595.0], [740.0, 595.0]], [[715.0, 492.0], [735.0, 492.0], [735.0, 578.0], [715.0, 578.0]], [[698.0, 493.0], [714.0, 493.0], [714.0, 596.0], [698.0, 596.0]], [[677.0, 492.0], [693.0, 492.0], [693.0, 578.0], [677.0, 578.0]]], "lines": ["南条は自分の", "主観だけで", "他人を見過ぎ", "なんだよ！！"]}, {"box": [133, 292, 181, 411], "vertical": true, "font_size": 24, "lines_coords": [[[152.0, 292.0], [181.0, 292.0], [181.0, 357.0], [152.0, 357.0]], [[133.0, 295.0], [153.0, 295.0], [153.0, 384.0], [133.0, 384.0]]], "lines": ["主観の", "押しつけー"]}, {"box": [535, 534, 634, 675], "vertical": true, "font_size": 17, "lines_coords": [[[619.0, 536.0], [634.0, 536.0], [634.0, 639.0], [619.0, 639.0]], [[598.0, 536.0], [615.0, 536.0], [615.0, 671.0], [598.0, 671.0]], [[577.0, 536.0], [593.0, 536.0], [593.0, 657.0], [577.0, 657.0]], [[551.0, 534.0], [571.0, 534.0], [575.0, 675.0], [555.0, 675.0]], [[535.0, 536.0], [551.0, 536.0], [551.0, 641.0], [535.0, 641.0]]], "lines": ["自分に見える", "範囲だけで相手の", "人間性を決める", "なんて愚かだって", "言いたいの！"]}, {"box": [714, 752, 731, 839], "vertical": true, "font_size": 17, "lines_coords": [[[714.0, 752.0], [731.0, 752.0], [731.0, 839.0], [714.0, 839.0]]], "lines": ["ところで．．．"]}, {"box": [425, 759, 446, 816], "vertical": true, "font_size": 20, "lines_coords": [[[425.0, 759.0], [446.0, 759.0], [446.0, 816.0], [425.0, 816.0]]], "lines": ["ん．．．．．"]}, {"box": [359, 808, 406, 892], "vertical": true, "font_size": 20, "lines_coords": [[[380.0, 808.0], [406.0, 808.0], [406.0, 876.0], [380.0, 876.0]], [[359.0, 815.0], [380.0, 815.0], [380.0, 892.0], [359.0, 892.0]]], "lines": ["ううん", "別に別に"]}, {"box": [337, 837, 354, 871], "vertical": true, "font_size": 20, "lines_coords": [[[342.0, 837.0], [354.0, 840.0], [351.0, 871.0], [337.0, 870.0]]], "lines": ["．．．"]}, {"box": [127, 558, 186, 712], "vertical": true, "font_size": 17, "lines_coords": [[[169.0, 560.0], [186.0, 560.0], [186.0, 678.0], [169.0, 678.0]], [[147.0, 558.0], [165.0, 558.0], [166.0, 712.0], [148.0, 712.0]], [[127.0, 560.0], [144.0, 560.0], [144.0, 660.0], [127.0, 660.0]]], "lines": ["つまりあたしの", "本質は太ってるって", "事じゃない！！"]}, {"box": [506, 977, 568, 1081], "vertical": true, "font_size": 19, "lines_coords": [[[548.0, 978.0], [568.0, 978.0], [568.0, 1066.0], [548.0, 1066.0]], [[528.0, 979.0], [544.0, 979.0], [544.0, 1081.0], [528.0, 1081.0]], [[506.0, 977.0], [526.0, 977.0], [526.0, 1048.0], [506.0, 1048.0]]], "lines": ["小野寺くん", "何かあったん", "ですか？"]}, {"box": [94, 1020, 179, 1141], "vertical": true, "font_size": 18, "lines_coords": [[[155.0, 1020.0], [175.0, 1020.0], [175.0, 1093.0], [155.0, 1093.0]], [[135.0, 1021.0], [155.0, 1021.0], [155.0, 1127.0], [135.0, 1127.0]], [[115.0, 1023.0], [132.0, 1023.0], [132.0, 1141.0], [115.0, 1141.0]], [[94.0, 1021.0], [111.0, 1021.0], [111.0, 1109.0], [94.0, 1109.0]]], "lines": ["幸さんて", "小野寺くんと", "付き合ってるん", "ですよね？"]}], "img_path": "050.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [141, 546, 243, 584], "vertical": false, "font_size": 11, "lines_coords": [[[145.0, 548.0], [206.0, 548.0], [206.0, 556.0], [145.0, 556.0]], [[141.0, 557.0], [217.0, 558.0], [217.0, 570.0], [141.0, 569.0]], [[164.0, 571.0], [241.0, 571.0], [241.0, 583.0], [164.0, 583.0]]], "lines": ["．．．", "そういうわけではないの", "それはそうですね。それではないのですが、そのままでそういうことでしょう。"]}, {"box": [499, 860, 599, 874], "vertical": false, "font_size": 14, "lines_coords": [[[500.0, 860.0], [597.0, 858.0], [597.0, 873.0], [500.0, 876.0]]], "lines": ["●再度の方、は真帆忘れの方が"]}, {"box": [230, 912, 251, 991], "vertical": true, "font_size": 21, "lines_coords": [[[230.0, 912.0], [251.0, 912.0], [251.0, 991.0], [230.0, 991.0]]], "lines": ["．．．あれ？"]}, {"box": [165, 1005, 209, 1121], "vertical": true, "font_size": 21, "lines_coords": [[[189.0, 1006.0], [209.0, 1006.0], [209.0, 1121.0], [189.0, 1121.0]], [[167.0, 1005.0], [188.0, 1005.0], [186.0, 1083.0], [165.0, 1083.0]]], "lines": ["．．．みすずさん", "社長は？"]}], "img_path": "051.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [440, 378, 522, 499], "vertical": true, "font_size": 19, "lines_coords": [[[504.0, 380.0], [521.0, 380.0], [521.0, 482.0], [504.0, 482.0]], [[482.0, 379.0], [502.0, 379.0], [500.0, 485.0], [480.0, 485.0]], [[463.0, 382.0], [480.0, 382.0], [480.0, 499.0], [463.0, 499.0]], [[440.0, 378.0], [461.0, 378.0], [461.0, 434.0], [440.0, 434.0]]], "lines": ["リハビリ室で", "ババア達でも", "口説いてんじゃ", "ない？"]}], "img_path": "052.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [237, 110, 322, 232], "vertical": true, "font_size": 20, "lines_coords": [[[302.0, 110.0], [322.0, 110.0], [322.0, 185.0], [302.0, 185.0]], [[281.0, 110.0], [301.0, 110.0], [301.0, 215.0], [281.0, 215.0]], [[260.0, 110.0], [279.0, 110.0], [279.0, 232.0], [260.0, 232.0]], [[237.0, 110.0], [260.0, 110.0], [260.0, 165.0], [237.0, 165.0]]], "lines": ["．．．父さん、", "この数か月で", "随分よくなった", "わ．．．"]}, {"box": [645, 541, 726, 646], "vertical": true, "font_size": 18, "lines_coords": [[[709.0, 544.0], [726.0, 544.0], [726.0, 629.0], [709.0, 629.0]], [[688.0, 543.0], [705.0, 543.0], [705.0, 629.0], [688.0, 629.0]], [[668.0, 543.0], [685.0, 543.0], [685.0, 646.0], [668.0, 646.0]], [[645.0, 541.0], [667.0, 541.0], [667.0, 589.0], [645.0, 589.0]]], "lines": ["．．．こんなに", "会話したの", "子供の時以来", "だわ。"]}, {"box": [263, 527, 342, 663], "vertical": true, "font_size": 16, "lines_coords": [[[325.0, 527.0], [342.0, 527.0], [342.0, 629.0], [325.0, 629.0]], [[304.0, 527.0], [320.0, 527.0], [320.0, 645.0], [304.0, 645.0]], [[284.0, 527.0], [301.0, 527.0], [301.0, 663.0], [284.0, 663.0]], [[263.0, 527.0], [279.0, 527.0], [279.0, 631.0], [263.0, 631.0]]], "lines": ["両足の麻痺は", "残るだろうから", "今後の事を思うと", "面倒だけど．．．"]}, {"box": [86, 335, 167, 471], "vertical": true, "font_size": 17, "lines_coords": [[[148.0, 336.0], [165.0, 336.0], [165.0, 437.0], [148.0, 437.0]], [[127.0, 335.0], [144.0, 335.0], [144.0, 437.0], [127.0, 437.0]], [[107.0, 335.0], [124.0, 335.0], [124.0, 471.0], [107.0, 471.0]], [[86.0, 336.0], [103.0, 336.0], [103.0, 410.0], [86.0, 410.0]]], "lines": ["むしろ前より", "よく喋るから", "うるせえのなんの", "いい迷惑。"]}, {"box": [670, 766, 727, 873], "vertical": true, "font_size": 17, "lines_coords": [[[711.0, 767.0], [727.0, 767.0], [727.0, 869.0], [711.0, 869.0]], [[690.0, 766.0], [707.0, 766.0], [705.0, 869.0], [687.0, 869.0]], [[670.0, 766.0], [686.0, 766.0], [686.0, 873.0], [670.0, 873.0]]], "lines": ["．．．そういえば", "病室にあった", "まねき猫の山"]}, {"box": [579, 833, 638, 938], "vertical": true, "font_size": 17, "lines_coords": [[[619.0, 833.0], [637.0, 833.0], [638.0, 903.0], [620.0, 903.0]], [[597.0, 833.0], [615.0, 833.0], [617.0, 937.0], [599.0, 937.0]], [[579.0, 834.0], [596.0, 834.0], [596.0, 938.0], [579.0, 938.0]]], "lines": ["あれ全部", "小野寺くんが", "持ってきたの"]}, {"box": [435, 585, 458, 710], "vertical": true, "font_size": 20, "lines_coords": [[[438.0, 585.0], [458.0, 585.0], [455.0, 710.0], [435.0, 710.0]]], "lines": ["英季総合病院"]}, {"box": [312, 829, 396, 942], "vertical": true, "font_size": 20, "lines_coords": [[[378.0, 830.0], [395.0, 830.0], [393.0, 935.0], [376.0, 935.0]], [[356.0, 830.0], [376.0, 830.0], [376.0, 919.0], [356.0, 919.0]], [[336.0, 832.0], [352.0, 832.0], [352.0, 942.0], [336.0, 942.0]], [[312.0, 829.0], [337.0, 829.0], [337.0, 894.0], [312.0, 894.0]]], "lines": ["どこで探して", "くるんだか", "週に二、三度は", "来てて。"]}, {"box": [137, 570, 237, 708], "vertical": true, "font_size": 16, "lines_coords": [[[220.0, 570.0], [237.0, 570.0], [235.0, 658.0], [217.0, 658.0]], [[199.0, 571.0], [214.0, 571.0], [214.0, 692.0], [199.0, 692.0]], [[178.0, 571.0], [194.0, 571.0], [194.0, 708.0], [178.0, 708.0]], [[158.0, 571.0], [174.0, 571.0], [174.0, 675.0], [158.0, 675.0]], [[137.0, 571.0], [153.0, 571.0], [153.0, 691.0], [137.0, 691.0]]], "lines": ["せめて突然", "逝かれるよりは", "後味良かったって", "思えるように", "しないとね．．．"]}, {"box": [451, 1003, 472, 1062], "vertical": true, "font_size": 20, "lines_coords": [[[451.0, 1003.0], [472.0, 1003.0], [472.0, 1062.0], [451.0, 1062.0]]], "lines": ["え．．．．．"]}, {"box": [323, 1037, 408, 1144], "vertical": true, "font_size": 20, "lines_coords": [[[384.0, 1037.0], [408.0, 1037.0], [408.0, 1116.0], [384.0, 1116.0]], [[364.0, 1039.0], [384.0, 1039.0], [384.0, 1110.0], [364.0, 1110.0]], [[346.0, 1041.0], [363.0, 1041.0], [363.0, 1144.0], [346.0, 1144.0]], [[323.0, 1040.0], [343.0, 1040.0], [343.0, 1112.0], [323.0, 1112.0]]], "lines": ["プンプン、", "そんなに", "ここ来てたん", "ですか？"]}, {"box": [214, 948, 234, 1011], "vertical": true, "font_size": 19, "lines_coords": [[[214.0, 948.0], [234.0, 948.0], [234.0, 1011.0], [214.0, 1011.0]]], "lines": ["そうよ。"]}, {"box": [97, 990, 179, 1130], "vertical": true, "font_size": 19, "lines_coords": [[[159.0, 990.0], [179.0, 990.0], [179.0, 1130.0], [159.0, 1130.0]], [[138.0, 990.0], [158.0, 990.0], [159.0, 1130.0], [139.0, 1130.0]], [[118.0, 992.0], [138.0, 992.0], [138.0, 1129.0], [118.0, 1129.0]], [[99.0, 991.0], [115.0, 991.0], [113.0, 1100.0], [97.0, 1100.0]]], "lines": ["ここの帰りは必ず", "ウチの店に寄って", "パソコンで資格の", "勉強してたわ。"]}], "img_path": "053.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [695, 72, 758, 177], "vertical": true, "font_size": 19, "lines_coords": [[[741.0, 75.0], [757.0, 75.0], [757.0, 176.0], [741.0, 176.0]], [[716.0, 72.0], [736.0, 72.0], [739.0, 161.0], [719.0, 161.0]], [[698.0, 73.0], [718.0, 73.0], [715.0, 160.0], [695.0, 160.0]]], "lines": ["．．．小野寺くん", "まだ帰って", "来ないの？"]}, {"box": [131, 151, 195, 273], "vertical": true, "font_size": 21, "lines_coords": [[[167.0, 152.0], [195.0, 152.0], [195.0, 193.0], [167.0, 193.0]], [[148.0, 151.0], [168.0, 151.0], [171.0, 273.0], [151.0, 273.0]], [[131.0, 153.0], [147.0, 153.0], [147.0, 240.0], [131.0, 240.0]]], "lines": ["一応", "捜してはいるん", "てすけど．．．"]}, {"box": [679, 332, 736, 441], "vertical": true, "font_size": 18, "lines_coords": [[[720.0, 332.0], [736.0, 332.0], [736.0, 418.0], [720.0, 418.0]], [[699.0, 332.0], [716.0, 332.0], [718.0, 419.0], [700.0, 419.0]], [[679.0, 332.0], [695.0, 332.0], [695.0, 441.0], [679.0, 441.0]]], "lines": ["．．．さっさと", "帰ってきて", "もらわないと。"]}, {"box": [627, 495, 691, 602], "vertical": true, "font_size": 18, "lines_coords": [[[674.0, 499.0], [691.0, 499.0], [691.0, 584.0], [674.0, 584.0]], [[653.0, 499.0], [670.0, 499.0], [670.0, 602.0], [653.0, 602.0]], [[627.0, 495.0], [654.0, 495.0], [654.0, 544.0], [627.0, 544.0]]], "lines": ["．．．父さんが", "寂しがってる", "のよ。"]}, {"box": [401, 353, 467, 458], "vertical": true, "font_size": 20, "lines_coords": [[[442.0, 353.0], [467.0, 353.0], [467.0, 416.0], [442.0, 416.0]], [[425.0, 357.0], [441.0, 357.0], [441.0, 458.0], [425.0, 458.0]], [[404.0, 355.0], [421.0, 355.0], [419.0, 433.0], [401.0, 433.0]]], "lines": ["．．．コレ、", "小野寺くんの", "部屋の鍵。"]}, {"box": [134, 694, 176, 799], "vertical": true, "font_size": 19, "lines_coords": [[[155.0, 694.0], [176.0, 694.0], [176.0, 717.0], [155.0, 717.0]], [[134.0, 696.0], [151.0, 696.0], [151.0, 798.0], [134.0, 798.0]]], "lines": ["．．．", "すみません。"]}, {"box": [681, 892, 766, 1014], "vertical": true, "font_size": 19, "lines_coords": [[[746.0, 892.0], [766.0, 892.0], [763.0, 998.0], [743.0, 998.0]], [[723.0, 894.0], [741.0, 894.0], [742.0, 1014.0], [725.0, 1014.0]], [[705.0, 895.0], [721.0, 895.0], [721.0, 980.0], [705.0, 980.0]], [[681.0, 892.0], [702.0, 892.0], [702.0, 955.0], [681.0, 955.0]]], "lines": ["部屋の様子が", "おかしかったら", "警察行きな", "さいね。"]}, {"box": [388, 890, 489, 1028], "vertical": true, "font_size": 18, "lines_coords": [[[473.0, 892.0], [489.0, 892.0], [489.0, 996.0], [473.0, 996.0]], [[452.0, 891.0], [468.0, 891.0], [468.0, 1008.0], [452.0, 1008.0]], [[432.0, 892.0], [448.0, 892.0], [448.0, 1016.0], [432.0, 1016.0]], [[411.0, 892.0], [427.0, 892.0], [427.0, 994.0], [411.0, 994.0]], [[388.0, 890.0], [408.0, 890.0], [411.0, 1028.0], [391.0, 1028.0]]], "lines": ["だってあの子、", "宅建とＭＯＳの", "試験控えてるし、", "免許の講習も", "残ってるでしょ？"]}, {"box": [290, 1001, 388, 1154], "vertical": true, "font_size": 18, "lines_coords": [[[373.0, 1003.0], [388.0, 1003.0], [388.0, 1154.0], [373.0, 1154.0]], [[352.0, 1003.0], [369.0, 1003.0], [369.0, 1106.0], [352.0, 1106.0]], [[332.0, 1004.0], [349.0, 1004.0], [349.0, 1139.0], [332.0, 1139.0]], [[310.0, 1003.0], [330.0, 1003.0], [330.0, 1137.0], [310.0, 1137.0]], [[290.0, 1001.0], [312.0, 1001.0], [312.0, 1048.0], [290.0, 1048.0]]], "lines": ["こんな大事な時期に", "事件なんかに", "巻き込まれてたら", "たまったもんじゃ", "ない。"]}, {"box": [115, 1055, 137, 1133], "vertical": true, "font_size": 22, "lines_coords": [[[115.0, 1055.0], [137.0, 1055.0], [137.0, 1133.0], [115.0, 1133.0]]], "lines": ["はい．．．"]}], "img_path": "054.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [684, 51, 727, 193], "vertical": true, "font_size": 18, "lines_coords": [[[709.0, 52.0], [726.0, 52.0], [726.0, 169.0], [709.0, 169.0]], [[684.0, 51.0], [704.0, 51.0], [704.0, 193.0], [684.0, 193.0]]], "lines": ["．．．あの子はね", "格好つけなのよ。"]}, {"box": [417, 107, 517, 247], "vertical": true, "font_size": 17, "lines_coords": [[[497.0, 110.0], [517.0, 110.0], [517.0, 213.0], [497.0, 213.0]], [[475.0, 107.0], [495.0, 107.0], [497.0, 203.0], [477.0, 203.0]], [[458.0, 110.0], [474.0, 110.0], [474.0, 247.0], [458.0, 247.0]], [[436.0, 110.0], [453.0, 110.0], [453.0, 212.0], [436.0, 212.0]], [[417.0, 110.0], [433.0, 110.0], [433.0, 178.0], [417.0, 178.0]]], "lines": ["あえて愚鈍に", "振る舞って、", "頑張ってるとこを", "隠そうとする", "てしょ？"]}, {"box": [296, 49, 354, 168], "vertical": true, "font_size": 16, "lines_coords": [[[338.0, 49.0], [354.0, 49.0], [354.0, 152.0], [338.0, 152.0]], [[317.0, 51.0], [333.0, 51.0], [333.0, 168.0], [317.0, 168.0]], [[296.0, 50.0], [312.0, 50.0], [312.0, 137.0], [296.0, 137.0]]], "lines": ["．．．そういえば", "パソコン検定の", "合否の結果"]}, {"box": [221, 161, 279, 254], "vertical": true, "font_size": 16, "lines_coords": [[[263.0, 161.0], [279.0, 161.0], [279.0, 232.0], [263.0, 232.0]], [[242.0, 161.0], [258.0, 161.0], [258.0, 246.0], [242.0, 246.0]], [[221.0, 161.0], [237.0, 161.0], [238.0, 254.0], [222.0, 254.0]]], "lines": ["そろそろ", "来るんじゃ", "ないかしら。"]}, {"box": [690, 519, 713, 604], "vertical": true, "font_size": 22, "lines_coords": [[[690.0, 519.0], [711.0, 519.0], [713.0, 604.0], [692.0, 604.0]]], "lines": ["．．．あたし、"]}, {"box": [571, 543, 641, 649], "vertical": true, "font_size": 22, "lines_coords": [[[616.0, 543.0], [641.0, 543.0], [641.0, 607.0], [616.0, 607.0]], [[593.0, 544.0], [615.0, 544.0], [615.0, 623.0], [593.0, 623.0]], [[571.0, 544.0], [589.0, 544.0], [590.0, 649.0], [572.0, 649.0]]], "lines": ["聞いて", "ないです", "そういう話。"]}, {"box": [418, 280, 516, 458], "vertical": true, "font_size": 17, "lines_coords": [[[500.0, 282.0], [516.0, 282.0], [516.0, 420.0], [500.0, 420.0]], [[480.0, 282.0], [495.0, 282.0], [495.0, 458.0], [480.0, 458.0]], [[459.0, 281.0], [474.0, 281.0], [474.0, 452.0], [459.0, 452.0]], [[434.0, 280.0], [454.0, 280.0], [454.0, 420.0], [434.0, 420.0]], [[418.0, 282.0], [433.0, 282.0], [433.0, 375.0], [418.0, 375.0]]], "lines": ["隠したって努力は", "伝わってくるんだから、", "あたしだって同業者の", "紹介のアテは準備", "してたのに。"]}, {"box": [94, 308, 174, 437], "vertical": true, "font_size": 18, "lines_coords": [[[154.0, 308.0], [174.0, 308.0], [174.0, 413.0], [154.0, 413.0]], [[133.0, 309.0], [153.0, 309.0], [153.0, 430.0], [133.0, 430.0]], [[114.0, 310.0], [131.0, 310.0], [131.0, 430.0], [114.0, 430.0]], [[94.0, 310.0], [110.0, 310.0], [110.0, 437.0], [94.0, 437.0]]], "lines": ["合格してたら", "パソコン買って", "あげるって約束", "しちゃったのよ。"]}, {"box": [619, 767, 680, 871], "vertical": true, "font_size": 18, "lines_coords": [[[660.0, 768.0], [680.0, 768.0], [680.0, 840.0], [660.0, 840.0]], [[640.0, 769.0], [657.0, 769.0], [657.0, 870.0], [640.0, 870.0]], [[619.0, 767.0], [637.0, 767.0], [639.0, 837.0], [622.0, 837.0]]], "lines": ["あなたも", "漫画忙しいん", "てしょ？"]}, {"box": [176, 1008, 238, 1130], "vertical": true, "font_size": 18, "lines_coords": [[[216.0, 1008.0], [237.0, 1008.0], [238.0, 1098.0], [217.0, 1098.0]], [[199.0, 1011.0], [215.0, 1011.0], [215.0, 1129.0], [199.0, 1129.0]], [[179.0, 1008.0], [195.0, 1008.0], [193.0, 1095.0], [176.0, 1095.0]]], "lines": ["気を遣って", "言わなかったん", "じゃない？"]}], "img_path": "055.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [258, 108, 421, 143], "vertical": false, "font_size": 14, "lines_coords": [[[333.0, 111.0], [413.0, 109.0], [413.0, 125.0], [333.0, 127.0]]], "lines": ["東西自由通路口"]}, {"box": [318, 172, 390, 186], "vertical": false, "font_size": 12, "lines_coords": [[[318.0, 174.0], [390.0, 172.0], [390.0, 183.0], [318.0, 186.0]]], "lines": ["上野恩陽公園薬の"]}, {"box": [568, 178, 637, 215], "vertical": false, "font_size": 40, "lines_coords": [[[568.0, 175.0], [637.0, 175.0], [637.0, 218.0], [568.0, 218.0]]], "lines": ["．．．"]}], "img_path": "056.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [678, 137, 699, 241], "vertical": true, "font_size": 20, "lines_coords": [[[678.0, 150.0], [698.0, 150.0], [698.0, 236.0], [678.0, 236.0]]], "lines": ["．．．．．．．私は"]}, {"box": [421, 439, 489, 509], "vertical": true, "font_size": 19, "lines_coords": [[[472.0, 441.0], [488.0, 441.0], [488.0, 503.0], [472.0, 503.0]], [[454.0, 441.0], [475.0, 441.0], [475.0, 506.0], [454.0, 506.0]], [[432.0, 440.0], [453.0, 439.0], [458.0, 508.0], [436.0, 509.0]], [[421.0, 440.0], [438.0, 440.0], [440.0, 508.0], [424.0, 508.0]]], "lines": ["ロビドの", "金６００", "ビクラマ！！", "．．．"]}, {"box": [386, 992, 455, 1135], "vertical": true, "font_size": 20, "lines_coords": [[[433.0, 994.0], [454.0, 994.0], [454.0, 1091.0], [433.0, 1091.0]], [[408.0, 993.0], [428.0, 993.0], [428.0, 1135.0], [408.0, 1135.0]], [[386.0, 992.0], [406.0, 992.0], [406.0, 1069.0], [386.0, 1069.0]]], "lines": ["ブンブンの", "何を知っていたん", "だろう？"]}], "img_path": "057.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [285, 563, 308, 577], "vertical": false, "font_size": 14, "lines_coords": [[[285.0, 563.0], [308.0, 563.0], [308.0, 577.0], [285.0, 577.0]]], "lines": ["いつまで"]}, {"box": [722, 837, 743, 915], "vertical": true, "font_size": 21, "lines_coords": [[[722.0, 837.0], [743.0, 837.0], [743.0, 911.0], [722.0, 911.0]]], "lines": ["あ．．．．．．"]}], "img_path": "058.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "059.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [672, 864, 715, 960], "vertical": true, "font_size": 20, "lines_coords": [[[694.0, 864.0], [714.0, 864.0], [714.0, 959.0], [694.0, 959.0]], [[672.0, 864.0], [693.0, 864.0], [693.0, 942.0], [672.0, 942.0]]], "lines": ["何やってん", "だよ．．．"]}, {"box": [145, 998, 167, 1112], "vertical": true, "font_size": 20, "lines_coords": [[[145.0, 998.0], [165.0, 998.0], [165.0, 1112.0], [145.0, 1112.0]]], "lines": ["あの馬鹿．．．"]}], "img_path": "060.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [326, 809, 502, 836], "vertical": false, "font_size": 17, "lines_coords": [[[337.0, 812.0], [496.0, 812.0], [496.0, 831.0], [337.0, 831.0]]], "lines": ["６月２４日「午後６時"]}, {"box": [271, 983, 311, 998], "vertical": false, "font_size": 13, "lines_coords": [[[271.0, 985.0], [310.0, 983.0], [311.0, 996.0], [272.0, 998.0]]], "lines": ["合格証書"]}, {"box": [242, 952, 409, 980], "vertical": false, "font_size": 18, "lines_coords": [[[242.0, 958.0], [407.0, 950.0], [407.0, 969.0], [242.0, 978.0]]], "lines": ["ＰＲＯＦＯはＮＧＹＡＳＳＳＮＥＮ"]}, {"box": [198, 994, 392, 1060], "vertical": false, "font_size": 13, "lines_coords": [[[207.0, 1004.0], [289.0, 1001.0], [289.0, 1014.0], [207.0, 1018.0]], [[271.0, 1033.0], [378.0, 1030.0], [378.0, 1046.0], [271.0, 1049.0]]], "lines": ["そんなことをしていたので、これまで一生懸命についているのですが、", "かわいいことですのですが、この世界ではお客様においてくれる"]}, {"box": [230, 1085, 386, 1148], "vertical": false, "font_size": 16, "lines_coords": [[[268.0, 1087.0], [343.0, 1083.0], [343.0, 1099.0], [268.0, 1103.0]], [[231.0, 1104.0], [378.0, 1092.0], [379.0, 1110.0], [233.0, 1122.0]], [[257.0, 1118.0], [358.0, 1110.0], [359.0, 1126.0], [258.0, 1134.0]], [[265.0, 1132.0], [350.0, 1126.0], [351.0, 1142.0], [267.0, 1148.0]]], "lines": ["ＧｌｏｇｌｅＰＣ検定３級", "でも、それはないのですが、これまではありがとうございません。", "これは．．．これからは、どのような", "Ｍａｃｍｅの野幸フンフン"]}], "img_path": "061.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [99, 812, 194, 860], "vertical": false, "font_size": 48, "lines_coords": [[[99.0, 812.0], [194.0, 812.0], [194.0, 860.0], [99.0, 860.0]]], "lines": ["００１"]}, {"box": [215, 808, 374, 895], "vertical": false, "font_size": 82, "lines_coords": [[[215.0, 813.0], [372.0, 808.0], [374.0, 890.0], [217.0, 895.0]]], "lines": ["大隈"]}, {"box": [418, 822, 486, 894], "vertical": false, "font_size": 72, "lines_coords": [[[418.0, 822.0], [486.0, 822.0], [486.0, 894.0], [418.0, 894.0]]], "lines": ["翠"]}, {"box": [493, 801, 521, 846], "vertical": true, "font_size": 28, "lines_coords": [[[493.0, 801.0], [521.0, 801.0], [521.0, 846.0], [493.0, 846.0]]], "lines": ["ピッ"]}, {"box": [693, 766, 715, 789], "vertical": true, "font_size": 22, "lines_coords": [[[693.0, 766.0], [715.0, 766.0], [715.0, 789.0], [693.0, 789.0]]], "lines": ["ピ"]}, {"box": [613, 888, 682, 907], "vertical": false, "font_size": 16, "lines_coords": [[[613.0, 888.0], [682.0, 891.0], [682.0, 