[494.0, 592.0], [468.0, 592.0]], [[449.0, 543.0], [469.0, 543.0], [468.0, 684.0], [448.0, 684.0]], [[429.0, 547.0], [446.0, 547.0], [446.0, 653.0], [429.0, 653.0]]], "lines": ["「．．．今、", "そういうもしもの", "話をする事に"]}, {"box": [347, 547, 388, 683], "vertical": true, "font_size": 41, "lines_coords": [[[347.0, 547.0], [388.0, 547.0], [388.0, 683.0], [347.0, 683.0]]], "lines": ["どれほどの意味があるんだろう。」"]}, {"box": [345, 547, 383, 684], "vertical": true, "font_size": 20, "lines_coords": [[[366.0, 547.0], [383.0, 547.0], [383.0, 684.0], [366.0, 684.0]], [[345.0, 547.0], [365.0, 547.0], [365.0, 666.0], [345.0, 666.0]]], "lines": ["どれほどの意味が", "あるんだろう。」"]}, {"box": [165, 995, 183, 1081], "vertical": true, "font_size": 16, "lines_coords": [[[165.0, 996.0], [181.0, 996.0], [181.0, 1079.0], [165.0, 1079.0]]], "lines": ["．．．ごめん"]}], "img_path": "165.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [376, 693, 422, 705], "vertical": false, "font_size": 12, "lines_coords": [[[376.0, 693.0], [422.0, 693.0], [422.0, 705.0], [376.0, 705.0]]], "lines": ["．．．"]}], "img_path": "166.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [396, 75, 465, 224], "vertical": true, "font_size": 19, "lines_coords": [[[442.0, 76.0], [462.0, 76.0], [462.0, 179.0], [442.0, 179.0]], [[420.0, 82.0], [440.0, 82.0], [440.0, 179.0], [420.0, 179.0]], [[398.0, 84.0], [414.0, 84.0], [414.0, 199.0], [398.0, 199.0]]], "lines": ["「かわいいよ", "愛子ちゃん", "かわいいよ。"]}], "img_path": "167.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "168.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [290, 955, 311, 1032], "vertical": true, "font_size": 20, "lines_coords": [[[290.0, 955.0], [311.0, 955.0], [311.0, 1032.0], [290.0, 1032.0]]], "lines": ["．．．あたし、"]}, {"box": [178, 1013, 246, 1101], "vertical": true, "font_size": 20, "lines_coords": [[[224.0, 1013.0], [246.0, 1013.0], [246.0, 1092.0], [224.0, 1092.0]], [[201.0, 1014.0], [221.0, 1014.0], [221.0, 1092.0], [201.0, 1092.0]], [[178.0, 1013.0], [197.0, 1013.0], [197.0, 1101.0], [178.0, 1101.0]]], "lines": ["この景色", "好きかも", "しれない。"]}], "img_path": "169.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [687, 235, 748, 347], "vertical": true, "font_size": 19, "lines_coords": [[[728.0, 235.0], [748.0, 235.0], [748.0, 307.0], [728.0, 307.0]], [[707.0, 235.0], [728.0, 235.0], [728.0, 307.0], [707.0, 307.0]], [[687.0, 236.0], [704.0, 236.0], [704.0, 346.0], [687.0, 346.0]]], "lines": ["．．．あたし", "この島に", "住んでみたい"]}, {"box": [713, 912, 774, 999], "vertical": true, "font_size": 19, "lines_coords": [[[754.0, 912.0], [774.0, 912.0], [774.0, 984.0], [754.0, 984.0]], [[734.0, 914.0], [754.0, 914.0], [754.0, 999.0], [734.0, 999.0]], [[713.0, 912.0], [734.0, 912.0], [734.0, 984.0], [713.0, 984.0]]], "lines": ["こういう", "自然が多い", "所で．．．"]}, {"box": [623, 1000, 682, 1103], "vertical": true, "font_size": 19, "lines_coords": [[[666.0, 1000.0], [682.0, 1000.0], [682.0, 1103.0], [666.0, 1103.0]], [[645.0, 1000.0], [661.0, 1000.0], [661.0, 1086.0], [645.0, 1086.0]], [[623.0, 1000.0], [645.0, 1000.0], [645.0, 1040.0], [623.0, 1040.0]]], "lines": ["のんびりした", "暮らしとか", "．．．"]}, {"box": [226, 898, 287, 1035], "vertical": true, "font_size": 17, "lines_coords": [[[267.0, 898.0], [287.0, 898.0], [287.0, 970.0], [267.0, 970.0]], [[247.0, 900.0], [263.0, 900.0], [263.0, 1034.0], [247.0, 1034.0]], [[226.0, 898.0], [242.0, 898.0], [243.0, 1035.0], [227.0, 1035.0]]], "lines": ["言うほど", "簡単にはいかない", "かもしれないけど"]}, {"box": [137, 1023, 195, 1109], "vertical": true, "font_size": 17, "lines_coords": [[[179.0, 1023.0], [195.0, 1023.0], [195.0, 1109.0], [179.0, 1109.0]], [[158.0, 1023.0], [174.0, 1023.0], [174.0, 1108.0], [158.0, 1108.0]], [[137.0, 1023.0], [155.0, 1023.0], [155.0, 1059.0], [137.0, 1059.0]]], "lines": ["二人で力を", "合わせれば", "．．．．．．"]}], "img_path": "170.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [183, 194, 243, 314], "vertical": true, "font_size": 18, "lines_coords": [[[227.0, 195.0], [243.0, 195.0], [243.0, 314.0], [227.0, 314.0]], [[206.0, 195.0], [222.0, 195.0], [222.0, 298.0], [206.0, 298.0]], [[183.0, 194.0], [203.0, 194.0], [203.0, 281.0], [183.0, 281.0]]], "lines": ["狭くていいから", "庭のある部屋", "借りて．．．"]}, {"box": [93, 249, 155, 373], "vertical": true, "font_size": 18, "lines_coords": [[[137.0, 250.0], [154.0, 250.0], [155.0, 371.0], [138.0, 371.0]], [[114.0, 250.0], [134.0, 250.0], [134.0, 373.0], [114.0, 373.0]], [[93.0, 249.0], [113.0, 249.0], [115.0, 339.0], [96.0, 339.0]]], "lines": ["野菜とか育てて", "少し自給自足な", "感じて．．．"]}, {"box": [570, 571, 607, 680], "vertical": true, "font_size": 16, "lines_coords": [[[590.0, 573.0], [606.0, 573.0], [606.0, 675.0], [590.0, 675.0]], [[570.0, 571.0], [586.0, 571.0], [586.0, 678.0], [570.0, 678.0]]], "lines": ["あまり人とは", "関わらないで、"]}, {"box": [148, 793, 192, 907], "vertical": true, "font_size": 16, "lines_coords": [[[173.0, 794.0], [189.0, 794.0], [189.0, 907.0], [173.0, 907.0]], [[149.0, 793.0], [166.0, 793.0], [166.0, 888.0], [149.0, 888.0]]], "lines": ["．．．ただ毎日を", "暮らす．．．．．"]}], "img_path": "171.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "172.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [638, 85, 659, 162], "vertical": true, "font_size": 21, "lines_coords": [[[638.0, 85.0], [659.0, 85.0], [659.0, 162.0], [638.0, 162.0]]], "lines": ["あれ．．．"]}], "img_path": "173.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [627, 728, 668, 832], "vertical": true, "font_size": 18, "lines_coords": [[[650.0, 730.0], [666.0, 730.0], [666.0, 832.0], [650.0, 832.0]], [[627.0, 728.0], [647.0, 728.0], [647.0, 805.0], [627.0, 805.0]]], "lines": ["．．．もし子供が", "できたら、"]}, {"box": [160, 1004, 239, 1140], "vertical": true, "font_size": 16, "lines_coords": [[[221.0, 1004.0], [237.0, 1004.0], [237.0, 1091.0], [221.0, 1091.0]], [[201.0, 1005.0], [217.0, 1005.0], [217.0, 1140.0], [201.0, 1140.0]], [[180.0, 1004.0], [196.0, 1004.0], [196.0, 1125.0], [180.0, 1125.0]], [[160.0, 1005.0], [175.0, 1005.0], [175.0, 1115.0], [160.0, 1115.0]]], "lines": ["その子には", "何にも縛られない", "自由な生き方を", "してほしいな。"]}], "img_path": "174.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [681, 72, 721, 159], "vertical": true, "font_size": 20, "lines_coords": [[[701.0, 72.0], [721.0, 72.0], [721.0, 142.0], [701.0, 142.0]], [[681.0, 72.0], [701.0, 72.0], [701.0, 159.0], [681.0, 159.0]]], "lines": ["．．．ううん", "やっぱり．．．"]}, {"box": [358, 262, 440, 408], "vertical": true, "font_size": 19, "lines_coords": [[[420.0, 263.0], [440.0, 263.0], [440.0, 351.0], [420.0, 351.0]], [[399.0, 262.0], [419.0, 262.0], [417.0, 352.0], [397.0, 352.0]], [[376.0, 263.0], [395.0, 263.0], [398.0, 369.0], [378.0, 369.0]], [[358.0, 266.0], [373.0, 266.0], [373.0, 406.0], [358.0, 406.0]]], "lines": ["．．．やっぱり", "子供なんか", "いないほうが", "いいに決まってる。"]}, {"box": [377, 471, 481, 587], "vertical": true, "font_size": 20, "lines_coords": [[[459.0, 472.0], [480.0, 472.0], [480.0, 563.0], [459.0, 563.0]], [[421.0, 473.0], [441.0, 473.0], [441.0, 587.0], [421.0, 587.0]], [[399.0, 473.0], [419.0, 473.0], [419.0, 587.0], [399.0, 587.0]]], "lines": ["「．．．だから、", "もしもの話は", "無意味だって"]}, {"box": [89, 271, 170, 420], "vertical": true, "font_size": 17, "lines_coords": [[[152.0, 271.0], [168.0, 271.0], [168.0, 376.0], [152.0, 376.0]], [[130.0, 271.0], [149.0, 271.0], [149.0, 360.0], [130.0, 360.0]], [[108.0, 271.0], [125.0, 271.0], [127.0, 392.0], [111.0, 392.0]], [[89.0, 271.0], [105.0, 271.0], [107.0, 420.0], [91.0, 420.0]]], "lines": ["もし同じ事を", "繰り返して", "しまったら．．．", "それは不毛過ぎる。"]}, {"box": [151, 843, 173, 932], "vertical": true, "font_size": 20, "lines_coords": [[[151.0, 843.0], [171.0, 843.0], [171.0, 928.0], [151.0, 928.0]]], "lines": ["．．．ごめん"]}, {"box": [412, 1042, 436, 1136], "vertical": true, "font_size": 21, "lines_coords": [[[412.0, 1042.0], [433.0, 1042.0], [435.0, 1135.0], [414.0, 1135.0]]], "lines": ["「．．．でも。」"]}], "img_path": "175.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [186, 823, 251, 963], "vertical": true, "font_size": 20, "lines_coords": [[[229.0, 825.0], [250.0, 825.0], [251.0, 909.0], [230.0, 909.0]], [[209.0, 825.0], [229.0, 825.0], [229.0, 963.0], [209.0, 963.0]], [[186.0, 823.0], [210.0, 823.0], [210.0, 887.0], [186.0, 887.0]]], "lines": ["「．．．僕はね、", "今とてもいい気分", "なんだ。"]}, {"box": [630, 823, 714, 1029], "vertical": true, "font_size": 18, "lines_coords": [[[695.0, 826.0], [712.0, 826.0], [712.0, 1006.0], [695.0, 1006.0]], [[673.0, 825.0], [690.0, 825.0], [690.0, 1028.0], [673.0, 1028.0]], [[653.0, 825.0], [670.0, 825.0], [670.0, 1012.0], [653.0, 1012.0]], [[630.0, 823.0], [650.0, 823.0], [650.0, 962.0], [630.0, 962.0]]], "lines": ["「でも．．．意味がなくても", "いつかそんなもしもの話が", "楽しくできる時が来れば", "いいなって思う。」"]}, {"box": [128, 825, 167, 994], "vertical": true, "font_size": 20, "lines_coords": [[[149.0, 825.0], [166.0, 825.0], [167.0, 994.0], [151.0, 994.0]], [[128.0, 825.0], [145.0, 825.0], [147.0, 962.0], [131.0, 962.0]]], "lines": ["君に会えてよかったと", "本当に思ってる。」"]}], "img_path": "176.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [410, 341, 435, 491], "vertical": true, "font_size": 24, "lines_coords": [[[410.0, 341.0], [434.0, 341.0], [434.0, 491.0], [410.0, 491.0]]], "lines": ["「．．．ありがとう。」"]}], "img_path": "177.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "178.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [49, 1024, 90, 1151], "vertical": true, "font_size": 28, "lines_coords": [[[55.0, 1024.0], [83.0, 1024.0], [83.0, 1143.0], [55.0, 1143.0]]], "lines": ["第１３話"]}], "img_path": "179.png"}, {"version": "0.2.0-beta.6", "img_width": 847,