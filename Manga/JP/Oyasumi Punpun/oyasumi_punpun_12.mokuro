, 394.0], [397.0, 476.0], [372.0, 476.0]]], "lines": ["もう限界", "なんだ。」"]}, {"box": [426, 965, 495, 1119], "vertical": true, "font_size": 20, "lines_coords": [[[473.0, 969.0], [494.0, 969.0], [495.0, 1072.0], [474.0, 1072.0]], [[451.0, 967.0], [470.0, 967.0], [470.0, 1119.0], [451.0, 1119.0]], [[426.0, 965.0], [447.0, 965.0], [447.0, 1066.0], [426.0, 1066.0]]], "lines": ["「君が一人に", "なりたくないって", "言うのなら、"]}, {"box": [354, 966, 398, 1155], "vertical": true, "font_size": 20, "lines_coords": [[[378.0, 966.0], [398.0, 966.0], [398.0, 1081.0], [378.0, 1081.0]], [[354.0, 967.0], [374.0, 967.0], [374.0, 1155.0], [354.0, 1155.0]]], "lines": ["こうするのが", "一番いいと思うんだ。」"]}], "img_path": "197.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [677, 198, 700, 284], "vertical": true, "font_size": 21, "lines_coords": [[[677.0, 198.0], [698.0, 198.0], [698.0, 283.0], [677.0, 283.0]]], "lines": ["ブンブン"]}, {"box": [213, 526, 254, 596], "vertical": true, "font_size": 20, "lines_coords": [[[234.0, 527.0], [254.0, 527.0], [254.0, 596.0], [234.0, 596.0]], [[213.0, 526.0], [234.0, 526.0], [234.0, 588.0], [213.0, 588.0]]], "lines": ["セックス", "しよう。"]}, {"box": [687, 805, 711, 848], "vertical": true, "font_size": 24, "lines_coords": [[[687.0, 806.0], [711.0, 806.0], [711.0, 848.0], [687.0, 848.0]]], "lines": ["．．．フ"]}, {"box": [148, 602, 168, 685], "vertical": true, "font_size": 20, "lines_coords": [[[148.0, 602.0], [168.0, 602.0], [168.0, 685.0], [148.0, 685.0]]], "lines": ["セックス"]}, {"box": [646, 998, 673, 1059], "vertical": true, "font_size": 25, "lines_coords": [[[646.0, 999.0], [671.0, 998.0], [673.0, 1058.0], [649.0, 1059.0]]], "lines": ["．．．フッ"]}, {"box": [130, 1046, 154, 1127], "vertical": true, "font_size": 24, "lines_coords": [[[130.0, 1046.0], [154.0, 1046.0], [154.0, 1127.0], [130.0, 1127.0]]], "lines": ["フゥー．．．"]}], "img_path": "198.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [727, 66, 766, 119], "vert