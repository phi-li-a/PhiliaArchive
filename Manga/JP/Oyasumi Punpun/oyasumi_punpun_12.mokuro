52.0], [433.0, 152.0], [433.0, 294.0], [413.0, 294.0]]], "lines": ["「．．．だから、", "もっと強く．．．．．．」"]}, {"box": [305, 123, 363, 212], "vertical": true, "font_size": 22, "lines_coords": [[[340.0, 123.0], [363.0, 123.0], [363.0, 180.0], [340.0, 180.0]], [[320.0, 124.0], [340.0, 124.0], [340.0, 212.0], [320.0, 212.0]]], "lines": ["変な事", "言わないで"]}, {"box": [559, 309, 582, 433], "vertical": true, "font_size": 20, "lines_coords": [[[559.0, 309.0], [579.0, 309.0], [582.0, 433.0], [562.0, 433.0]]], "lines": ["．．．死んじゃう。"]}, {"box": [657, 526, 704, 610], "vertical": true, "font_size": 24, "lines_coords": [[[677.0, 527.0], [704.0, 527.0], [704.0, 587.0], [677.0, 587.0]], [[657.0, 526.0], [677.0, 526.0], [677.0, 608.0], [657.0, 608.0]]], "lines": ["一人に", "なったら、"]}, {"box": [105, 302, 152, 399], "vertical": true, "font_size": 22, "lines_coords": [[[127.0, 302.0], [152.0, 302.0], [152.0, 363.0], [127.0, 363.0]], [[105.0, 302.0], [125.0, 302.0], [125.0, 397.0], [105.0, 397.0]]], "lines": ["お願い", "だから．．．"]}, {"box": [141, 783, 215, 900], "vertical": true, "font_size": 23, "lines_coords": [[[186.0, 783.0], [215.0, 783.0], [215.0, 848.0], [186.0, 848.0]], [[167.0, 786.0], [187.0, 786.0], [187.0, 883.0], [167.0, 883.0]], [[141.0, 787.0], [161.0, 787.0], [161.0, 898.0], [141.0, 898.0]]], "lines": ["あたし", "どうすれば", "いいの．．．．．？"]}, {"box": [332, 984, 414, 1005], "vertical": false, "font_size": 13, "lines_coords": [[[332.0, 992.0], [413.0, 984.0], [414.0, 997.0], [333.0, 1005.0]]], "lines": ["利用料金請求則"]}], "img_path": "039.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [435, 195, 495, 212], "vertical": false, "font_size": 17, "lines_coords": [[[435.0, 195.0], [495.0, 195.0], [495.0, 212.0], [435.0, 212.0]]], "lines": ["紫楽"]}, {"box": [356, 387, 397, 467], "vertical": true, "font_size": 20, "lines_coords": [[[356.0, 387.0], [376.0, 387.0], [376.0, 466.0], [356.0, 466.0]]], "lines": ["今日未明"]}, {"box": [187, 426, 236, 545], "vertical": true, "font_size": 24, "lines_coords": [[[210.0, 426.0], [236.0, 427.0], [234.0, 489.0], [208.0, 488.0]], [[189.0, 428.0], [210.0, 428.0], [208.0, 520.0], [187.0, 520.0]]], "lines": ["東京都", "○○市でー"]}, {"box": [678, 1040, 722, 1120], "vertical": true, "font_size": 22, "lines_coords": [[[701.0, 1041.0], [722.0, 1041.0], [722.0, 1120.0], [701.0, 1120.0]], [[678.0, 1053.0], [701.0, 1053.0], [701.0, 1083.0], [678.0, 1083.0]]], "lines": ["うちの市", "．．．"]}, {"box": [470, 932, 487, 996], "vertical": true, "font_size": 18, "lines_coords": [[[470.0, 932.0], [487.0, 932.0], [487.0, 996.0], [470.0, 996.0]]], "lines": ["強盗が"]}, {"box": [429, 876, 468, 996], "vertical": true, "font_size": 18, "lines_coords": [[[448.0, 876.0], [468.0, 876.0], [468.0, 996.0], [448.0, 996.0]], [[429.0, 876.0], [446.0, 876.0], [446.0, 978.0], [429.0, 978.0]]], "lines": ["押し入ったとの", "通報がありー"]}, {"box": [345, 901, 398, 941], "vertical": false, "font_size": 21.5, "lines_coords": [[[345.0, 903.0], [397.0, 901.0], [398.0, 921.0], [346.0, 923.0]], [[345.0, 918.0], [394.0, 918.0], [394.0, 941.0], [345.0, 941.0]]], "lines": ["５０代３", "物取り"]}, {"box": [101, 996, 183, 1151], "vertical": true, "font_size": 16, "lines_coords": [[[166.0, 998.0], [181.0, 998.0], [181.0, 1117.0], [166.0, 1117.0]], [[145.0, 998.0], [161.0, 998.0], [161.0, 1140.0], [145.0, 1140.0]], [[123.0, 998.0], [139.0, 998.0], [139.0, 1122.0], [123.0, 1122.0]], [[101.0, 996.0], [118.0, 996.0], [119.0, 1151.0], [103.0, 1151.0]]], "lines": ["立ち去った男は", "年齢３０代から４０代、", "黒縁眼鏡て長髪、", "髭を生やしており．．．"]}], "img_path": "040.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [682, 44, 757, 182], "vertical": true, "font_size": 18, "lines_coords": [[[742.0, 46.0], [757.0, 46.0], [757.0, 182.0], [742.0, 182.0]], [[723.0, 46.0], [739.0, 46.0], [739.0, 139.0], [723.0, 139.0]], [[704.0, 45.0], [720.0, 45.0], [720.0, 168.0], [704.0, 168.0]], [[682.0, 44.0], [705.0, 44.0], [705.0, 82.0], [682.0, 82.0]]], "lines": ["市内では数日前から", "同様の事件が", "立て続けに起きて", "おり"]}, {"box": [426, 67, 495, 221], "vertical": true, "font_size": 20, "lines_coords": [[[474.0, 69.0], [494.0, 69.0], [494.0, 155.0], [474.0, 155.0]], [[449.0, 69.0], [469.0, 69.0], [469.0, 221.0], [449.0, 221.0]], [[426.0, 69.0], [446.0, 69.0], [446.0, 155.0], [426.0, 155.0]]], "lines": ["「．．．大丈夫", "関係無いニュース", "だよ．．．．．．"]}, {"box": [356, 91, 384, 134], "vertical": true, "font_size": 28, "lines_coords": [[[356.0, 91.0], [384.0, 91.0], [384.0, 134.0], [356.0, 134.0]]], "lines": ["．．．ぱ"]}, {"box": [322, 160, 349, 206], "vertical": true, "font_size": 28, "lines_coords": [[[322.0, 160.0], [349.0, 160.0], [349.0, 206.0], [322.0, 206.0]]], "lines": ["あ．．．"]}, {"box": [82, 205, 113, 253], "vertical": true, "font_size": 31, "lines_coords": [[[82.0, 205.0], [113.0, 205.0], [113.0, 253.0], [82.0, 253.0]]], "lines": ["た．．"]}, {"box": [547, 292, 608, 450], "vertical": true, "font_size": 19, "lines_coords": [[[588.0, 295.0], [608.0, 295.0], [608.0, 448.0], [588.0, 448.0]], [[568.0, 292.0], [588.0, 292.0], [585.0, 450.0], [565.0, 450.0]], [[547.0, 295.0], [564.0, 295.0], [564.0, 351.0], [547.0, 351.0]]], "lines": ["○○署では同一犯の", "可能性があると見て", "調査を"]}, {"box": [695, 553, 718, 601], "vertical": true, "font_size": 23, "lines_coords": [[[695.0, 553.0], [718.0, 553.0], [718.0, 601.0], [695.0, 601.0]]], "lines": ["あっ"]}, {"box": [688, 548, 725, 608], "vertical": true, "font_size": 34, "lines_coords": [[[688.0, 548.0], [725.0, 548.0], [725.0, 608.0], [688.0, 608.0]]], "lines": ["あっ"]}, {"box": [458, 323, 486, 373], "vertical": true, "font_size": 28, "lines_coords": [[[458.0, 323.0], [486.0, 323.0], [486.0, 373.0], [458.0, 373.0]]], "lines": ["あ．．．"]}, {"box": [100, 359, 127, 411], "vertical": true, "font_size": 27, "lines_coords": [[[100.0, 359.0], [127.0, 359.0], [127.0, 411.0], [100.0, 411.0]]], "lines": ["あ．．．"]}, {"box": [178, 541, 209, 625], "vertical": true, "font_size": 29, "lines_coords": [[[178.0, 542.0], [207.0, 541.0], [209.0, 624.0], [180.0, 625.0]]], "lines": ["あぁ．．．"]}, {"box": [637, 631, 668, 692], "vertical": true, "font_size": 34, "lines_coords": [[[637.0, 631.0], [668.0, 631.0], [668.0, 692.0], [637.0, 692.0]]], "lines": ["あ．．．"]}, {"box": [113, 760, 137, 867], "vertical": true, "font_size": 21, "lines_coords": [[[113.0, 762.0], [134.0, 762.0], [134.0, 867.0], [113.0, 867.0]]], "lines": ["あああ．．．"]}, {"box": [467, 959, 490, 1090], "vertical": true, "font_size": 23, "lines_coords": [[[467.0, 959.0], [490.0, 959.0], [490.0, 1089.0], [467.0, 1089.0]]], "lines": ["「．．．愛子ちゃん"]}, {"box": [345, 962, 365, 1060], "vertical": true, "font_size": 20, "lines_coords": [[[345.0, 962.0], [365.0, 962.0], [365.0, 1059.0], [345.0, 1059.0]]], "lines": ["．．．僕はね。」"]}], "img_path": "041.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [147, 205, 173, 256], "vertical": true, "font_size": 21, "lines_coords": [[[152.0, 205.0], [173.0, 207.0], [168.0, 256.0], [147.0, 254.0]]], "lines": ["マルハン"]}, {"box": [609, 261, 630, 449], "vertical": true, "font_size": 18, "lines_coords": [[[609.0, 261.0], [626.0, 261.0], [630.0, 432.0], [612.0, 432.0]]], "lines": ["みんなに笑顔を届けた。"]}, {"box": [524, 266, 545, 342], "vertical": true, "font_size": 21, "lines_coords": [[[524.0, 266.0], [545.0, 266.0], [545.0, 342.0], [524.0, 342.0]]], "lines": ["じゃりま"]}, {"box": [233, 676, 329, 829], "vertical": true, "font_size": 21, "lines_coords": [[[309.0, 677.0], [329.0, 677.0], [329.0, 801.0], [309.0, 801.0]], [[284.0, 678.0], [304.0, 678.0], [304.0, 829.0], [284.0, 829.0]], [[262.0, 678.0], [278.0, 678.0], [278.0, 828.0], [262.0, 828.0]], [[233.0, 676.0], [262.0, 676.0], [262.0, 747.0], [233.0, 747.0]]], "lines": ["「．．．僕はとても", "後ろ向きな考えの", "人間かもしれない", "けれど、"]}, {"box": [140, 678, 208, 810], "vertical": true, "font_size": 21, "lines_coords": [[[188.0, 678.0], [208.0, 678.0], [208.0, 810.0], [188.0, 810.0]], [[164.0, 678.0], [183.0, 678.0], [183.0, 774.0], [164.0, 774.0]], [[140.0, 679.0], [160.0, 679.0], [160.0, 810.0], [140.0, 810.0]]], "lines": ["今