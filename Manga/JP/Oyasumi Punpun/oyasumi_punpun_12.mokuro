ds": [[[374.0, 213.0], [395.0, 213.0], [395.0, 289.0], [374.0, 289.0]]], "lines": ["．．．はい？"]}, {"box": [286, 175, 312, 216], "vertical": true, "font_size": 26, "lines_coords": [[[286.0, 175.0], [312.0, 175.0], [312.0, 216.0], [286.0, 216.0]]], "lines": ["全然飛ばない最終だってうとしてるっしょ"]}, {"box": [226, 39, 278, 93], "vertical": true, "font_size": 52, "lines_coords": [[[226.0, 39.0], [278.0, 39.0], [278.0, 93.0], [226.0, 93.0]]], "lines": ["バーカリなんてヤツギリになってそーゆうことかなか！？"]}, {"box": [84, 14, 110, 51], "vertical": true, "font_size": 26, "lines_coords": [[[84.0, 14.0], [110.0, 14.0], [110.0, 51.0], [84.0, 51.0]]], "lines": ["．．．あんまりあたしに何か変わないでよ"]}, {"box": [213, 157, 232, 211], "vertical": true, "font_size": 19, "lines_coords": [[[213.0, 157.0], [232.0, 157.0], [232.0, 211.0], [213.0, 211.0]]], "lines": ["なんてつまんないですか？"]}, {"box": [124, 66, 160, 111], "vertical": true, "font_size": 36, "lines_coords": [[[124.0, 66.0], [160.0, 66.0], [160.0, 111.0], [124.0, 111.0]]], "lines": ["彼氏だったら「ガンバレ」って言ってくれるよ」じゃんか！！"]}, {"box": [144, 202, 190, 299], "vertical": true, "font_size": 23, "lines_coords": [[[165.0, 202.0], [190.0, 202.0], [190.0, 273.0], [165.0, 273.0]], [[144.0, 203.0], [165.0, 203.0], [165.0, 298.0], [144.0, 298.0]]], "lines": ["．．．コレ、", "ですか．．．？"]}, {"box": [562, 314, 583, 423], "vertical": true, "font_size": 21, "lines_coords": [[[562.0, 314.0], [583.0, 314.0], [583.0, 423.0], [562.0, 423.0]]], "lines": ["「．．．その漫画"]}, {"box": [670, 517, 715, 614], "vertical": true, "font_size": 22, "lines_coords": [[[695.0, 519.0], [715.0, 519.0], [715.0, 614.0], [695.0, 614.0]], [[670.0, 517.0], [694.0, 517.0], [694.0, 587.0], [670.0, 587.0]]], "lines": ["つまんない", "ですね。"]}, {"box": [510, 314, 534, 460], "vertical": true, "font_size": 21, "lines_coords": [[[513.0, 314.0], [534.0, 314.0], [531.0, 460.0], [510.0, 460.0]]], "lines": ["面白いですか？」"]}, {"box": [152, 660, 217, 832], "vertical": true, "font_size": 19, "lines_coords": [[[197.0, 660.0], [217.0, 660.0], [217.0, 815.0], [197.0, 815.0]], [[172.0,