393.0, 251.0], [413.0, 251.0], [413.0, 348.0], [393.0, 348.0]]], "lines": ["．．．誰？", "その子．．．"]}, {"box": [646, 413, 729, 503], "vertical": true, "font_size": 21, "lines_coords": [[[708.0, 416.0], [729.0, 416.0], [729.0, 491.0], [708.0, 491.0]], [[686.0, 414.0], [707.0, 414.0], [707.0, 501.0], [686.0, 501.0]], [[667.0, 414.0], [687.0, 414.0], [687.0, 503.0], [667.0, 503.0]], [[646.0, 413.0], [667.0, 413.0], [667.0, 469.0], [646.0, 469.0]]], "lines": ["．．．この子、", "フンフンの", "彼女さんで", "ね．．．．．"]}, {"box": [90, 393, 149, 512], "vertical": true, "font_size": 17, "lines_coords": [[[130.0, 393.0], [149.0, 393.0], [149.0, 468.0], [130.0, 468.0]], [[111.0, 393.0], [127.0, 393.0], [127.0, 512.0], [111.0, 512.0]], [[90.0, 393.0], [106.0, 393.0], [106.0, 496.0], [90.0, 496.0]]], "lines": ["．．．ははは、", "ちょっと事情が", "あってだな．．．"]}, {"box": [645, 624, 706, 734], "vertical": true, "font_size": 22, "lines_coords": [[[684.0, 625.0], [706.0, 625.0], [706.0, 672.0], [684.0, 672.0]], [[663.0, 624.0], [682.0, 624.0], [685.0, 704.0], [665.0, 704.0]], [[645.0, 626.0], [661.0, 626.0], [661.0, 734.0], [645.0, 734.0]]], "lines": ["．．．あ。", "南条さん、", "紹介しますね。"]}, {"box": [649, 795, 704, 942], "vertical": true, "font_size": 22, "lines_coords": [[[675.0, 795.0], [704.0, 795.0], [704.0, 890.0], [675.0, 890.0]], [[649.0, 798.0], [673.0, 798.0], [673.0, 942.0], [649.0, 942.0]]], "lines": ["．．．地元の", "つり仲間です。"]}, {"box": [434, 849, 454, 936], "vertical": true, "font_size": 20, "lines_coords": [[[434.0, 849.0], [454.0, 849.0], [454.0, 935.0], [434.0, 935.0]]], "lines": ["どーもー。"]}, {"box": [165, 840, 209, 935], "vertical": true, "font_size": 21, "lines_coords": [[[189.0, 895.0], [207.0, 895.0], [207.0, 932.0], [189.0, 932.0]], [[187.0, 840.0], [209.0, 840.0], [209.0, 895.0], [187.0, 895.0]], [[165.0, 840.0], [185.0, 840.0], [185.0, 935.0], [165.0, 935.0]]], "lines": ["い", "おぅー", "この野郎！！"]}, {"box": [98, 980, 179, 1117], "vertical": true, "font_size": 21, "lines_coords": [[[156.0, 980.0], [179.0, 980.0], [179.0, 1096.0], [156.0, 1096.0]], [[128.0, 980.0], [148.0, 980.0], [148.0, 1117.0], [128.0, 1117.0]], [[100.0, 980.0], [121.0, 980.0], [119.0, 1117.0], [98.0, 1117.0]]], "lines": ["雑すぎだろ", "ちゃんと紹介", "してくれや！！"]}], "img_path": "115.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [263, 69, 310, 166], "vertical": true, "font_size": 24, "lines_coords": [[[290.0, 71.0], [310.0, 71.0], [310.0, 148.0], [290.0, 148.0]], [[263.0, 69.0], [290.0, 69.0], [290.0, 111.0], [263.0, 111.0]]], "lines": ["こんばん", "はー"]}, {"box": [133, 244, 154, 341], "vertical": true, "font_size": 21, "lines_coords": [[[133.0, 244.0], [154.0, 244.0], [154.0, 317.0], [133.0, 317.0]]], "lines": ["かわいー"]}, {"box": [688, 585, 712, 626], "vertical": true, "font_size": 22, "lines_coords": [[[688.0, 585.0], [712.0, 585.0], [712.0, 626.0], [688.0, 626.0]]], "lines": ["あっ"]}, {"box": [632, 656, 652, 735], "vertical": true, "font_size": 22, "lines_coords": [[[632.0, 656.0], [652.0, 656.0], [652.0, 735.0], [632.0, 735.0]]], "lines": ["逃げた！！"]}, {"box": [669, 992, 748, 1129], "vertical": true, "font_size": 16, "lines_coords": [[[731.0, 992.0], [747.0, 992.0], [747.0, 1112.0], [731.0, 1112.0]], [[709.0, 992.0], [726.0, 992.0], [726.0, 1128.0], [709.0, 1128.0]], [[688.0, 992.0], [705.0, 992.0], [705.0, 1129.0], [688.0, 1129.0]], [[670.0, 993.0], [682.0, 993.0], [682.0, 1078.0], [670.0, 1078.0]]], "lines": ["なんだアイツら", "こんなキレイな人", "滅多に見ねぇから", "照れたか！！"]}, {"box": [415, 880, 456, 970], "vertical": true, "font_size": 20, "lines_coords": [[[434.0, 880.0], [454.0, 880.0], [456.0, 970.0], [436.0, 970.0]], [[415.0, 882.0], [436.0, 882.0], [436.0, 942.0], [415.0, 942.0]]], "lines": ["．．．南条さん", "実はね。"]}, {"box": [142, 994, 200, 1114], "vertical": true, "font_size": 17, "lines_coords": [[[183.0, 996.0], [200.0, 996.0], [200.0, 1081.0], [183.0, 1081.0]], [[162.0, 996.0], [179.0, 996.0], [179.0, 1114.0], [162.0, 1114.0]], [[142.0, 994.0], [158.0, 994.0], [158.0, 1088.0], [142.0, 1088.0]]], "lines": ["ここにいる", "みんなバツイチ", "なんですよ。"]}], "img_path": "116.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [653, 64, 712, 172], "vertical": true, "font_size": 17, "lines_coords": [[[695.0, 64.0], [711.0, 64.0], [711.0, 167.0], [695.0, 167.0]], [[674.0, 64.0], [691.0, 64.0], [691.0, 168.0], [674.0, 168.0]], [[653.0, 64.0], [670.0, 64.0], [670.0, 169.0], [653.0, 169.0]]], "lines": ["今の仕事先も", "この家を安く", "借りれたのも、"]}, {"box": [123, 157, 212, 297], "vertical": true, "font_size": 22, "lines_coords": [[[185.0, 158.0], [212.0, 158.0], [212.0, 200.0], [185.0, 200.0]], [[169.0, 161.0], [186.0, 161.0], [186.0, 263.0], [169.0, 263.0]], [[146.0, 159.0], [164.0, 159.0], [165.0, 297.0], [147.0, 297.0]], [[123.0, 157.0], [148.0, 157.0], [148.0, 221.0], [123.0, 221.0]]], "lines": ["全部", "この人たちに", "教えてもらったん", "ですよ。"]}, {"box": [569, 506, 660, 620], "vertical": true, "font_size": 16, "lines_coords": [[[640.0, 507.0], [657.0, 507.0], [657.0, 601.0], [640.0, 601.0]], [[617.0, 507.0], [633.0, 507.0], [633.0, 619.0], [617.0, 619.0]], [[593.0, 506.0], [610.0, 506.0], [610.0, 619.0], [593.0, 619.0]], [[570.0, 506.0], [586.0, 506.0], [586.0, 610.0], [570.0, 610.0]]], "lines": ["僕らみんな", "夜が暇だから", "よくこうして", "集まってて。"]}, {"box": [224, 535, 267, 624], "vertical": true, "font_size": 18, "lines_coords": [[[241.0, 535.0], [267.0, 535.0], [267.0, 594.0], [241.0, 594.0]], [[224.0, 537.0], [241.0, 537.0], [241.0, 624.0], [224.0, 624.0]]], "lines": ["プン山", "ちゃーん．．．"]}, {"box": [118, 587, 196, 708], "vertical": true, "font_size": 18, "lines_coords": [[[180.0, 588.0], [196.0, 588.0], [196.0, 656.0], [180.0, 656.0]], [[159.0, 589.0], [175.0, 589.0], [175.0, 708.0], [159.0, 708.0]], [[139.0, 587.0], [155.0, 587.0], [155.0, 707.0], [139.0, 707.0]], [[118.0, 587.0], [134.0, 587.0], [134.0, 707.0], [118.0, 707.0]]], "lines": ["お客さん", "いるんだったら", "もっと酒買って", "きたのによォ．．．"]}, {"box": [688, 1023, 727, 1126], "vertical": true, "font_size": 18, "lines_coords": [[[708.0, 1023.0], [726.0, 1023.0], [727.0, 1098.0], [709.0, 1098.0]], [[688.0, 1023.0], [705.0, 1023.0], [705.0, 1126.0], [688.0, 1126.0]]], "lines": ["．．．ままま、", "とりあえず．．．"]}, {"box": [98, 1007, 153, 1111], "vertical": true, "font_size": 25, "lines_coords": [[[124.0, 1012.0], [149.0, 1011.0], [153.0, 1106.0], [127.0, 1107.0]], [[98.0, 1007.0], [123.0, 1007.0], [125.0, 1105.0], [100.0, 1105.0]]], "lines": ["かんぱ～", "～～～い"]}], "img_path": "117.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [631, 90, 653, 189], "vertical": true, "font_size": 21, "lines_coords": [[[631.0, 90.0], [652.0, 90.0], [652.0, 181.0], [631.0, 181.0]]], "lines": ["あの．．．．．．"]}, {"box": [461, 430, 482, 525], "vertical": true, "font_size": 21, "lines_coords": [[[461.0, 430.0], [482.0, 430.0], [482.0, 525.0], [461.0, 525.0]]], "lines": ["なんか．．．"]}, {"box": [398, 513, 421, 610], "vertical": true, "font_size": 21, "lines_coords": [[[400.0, 513.0], [421.0, 513.0], [419.0, 610.0], [398.0, 610.0]]], "lines": ["用ですか？"]}], "img_path": "118.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [456, 32, 476, 161], "vertical": true, "font_size": 18, "lines_coords": [[[456.0, 32.0], [476.0, 32.0], [476.0, 161.0], [456.0, 161.0]]], "lines": ["「．．．ポイ捨ては"]}, {"box": [390, 44, 406, 199], "vertical": true, "font_size": 18, "lines_coords": [[[390.0, 44.0], [406.0, 44.0], [406.0, 199.0], [390.0, 199.0]]], "lines": ["良くないですよ。"]}, {"box": [388, 43, 410, 204], "vertical": true, "font_size": 22, "lines_coords": [[[388.0, 43.0], [410.0, 43.0], [410.0, 204.0], [388.0, 204.0]]], "lines": ["良くないですよ。」"]}, {"box": [25, 196, 67, 321], "vertical": true, "font_size": 41, "lines_coords": [[[25.0, 196.0], [66.0, 196.0], [66.0, 321.0], [25.0, 321.0]]], "lines": ["第１２８話"]}, {"box": [634, 781, 657, 839], "vertical": true, "font_size": 25, "lines_coords": [[[634.0, 781.0], [657.0, 781.0], [657.0, 839.0], [634.0, 839.0]]], "lines": ["あぁ．．．"]}, {"box": [552, 802, 598, 880], "vertical": true, "font_size": 25, "lines_coords": [[[572.0, 802.0], [598.0, 802.0], [598.0, 864.0], [572.0, 864.0]], [[552.0, 803.0], [577.0, 803.0], [577.0, 880.0], [552.0, 880.0]]], "lines": ["すみま", "せん．．．．．"]}], "img_path": "119.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [224, 397, 276, 413], "vertical": false, "font_size": 16, "lines_coords": [[[224.0, 397.0], [276.0, 397.0], [276.0, 413.0], [224.0, 413.0]]], "lines": ["ちょっとだけ"]}, {"box": [173, 625, 197, 746], "vertical": true, "font_size": 23, "lines_coords": [[[173.0, 625.0], [196.0, 625.0], [196.0, 745.0], [173.0, 745.0]]], "lines": ["．．．プンプン？"]}, {"box": [668, 870, 692, 1041], "vertical": true, "font_size": 24, "lines_coords": [[[668.0, 870.0], [692.0, 870.0], [692.0, 1041.0], [668.0, 1041.0]]], "lines": ["「：僕に謝ったって"]}, {"box": [618, 876, 644, 1100], "vertical": true, "font_size": 24, "lines_coords": [[[618.0, 876.0], [641.0, 876.0], [644.0, 1100.0], [620.0, 1100.0]]], "lines": ["しょうがないんですよ。」"]}, {"box": [434, 872, 455, 951], "vertical": true, "font_size": 21, "lines_coords": [[[434.0, 875.0], [455.0, 875.0], [455.0, 951.0], [434.0, 951.0]]], "lines": ["．．．は？"]}], "img_path": "120.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [674, 103, 757, 358], "vertical": true, "font_size": 17, "lines_coords": [[[740.0, 103.0], [756.0, 103.0], [756.0, 322.0], [740.0, 322.0]], [[718.0, 111.0], [734.0, 111.0], [734.0, 357.0], [718.0, 357.0]], [[694.0, 111.0], [714.0, 111.0], [714.0, 341.0], [694.0, 341.0]], [[674.0, 112.0], [691.0, 112.0], [691.0, 234.0], [674.0, 234.0]]], "lines": ["．．．こういう些細な身勝手が", "他人を不愉快にさせている事を", "理解してもらわないと意味が", "無いんですよ。」"]}, {"box": [345, 29, 427, 169], "vertical": true, "font_size": 18, "lines_coords": [[[407.0, 29.0], [427.0, 29.0], [427.0, 118.0], [407.0, 118.0]], [[388.0, 30.0], [405.0, 30.0], [405.0, 120.0], [388.0, 120.0]], [[365.0, 29.0], [385.0, 29.0], [385.0, 169.0], [365.0, 169.0]], [[345.0, 30.0], [361.0, 30.0], [361.0, 124.0], [345.0, 124.0]]], "lines": ["．．．あの店の", "缶のゴミ箱", "いっつもいっぱい", "なんですよ。"]}, {"box": [291, 206, 374, 297], "vertical": true, "font_size": 18, "lines_coords": [[[358.0, 206.0], [374.0, 206.0], [374.0, 296.0], [358.0, 296.0]], [[336.0, 206.0], [352.0, 206.0], [352.0, 296.0], [336.0, 296.0]], [[313.0, 206.0], [333.0, 206.0], [333.0, 297.0], [313.0, 297.0]], [[291.0, 206.0], [312.0, 206.0], [312.0, 267.0], [291.0, 267.0]]], "lines": ["それとなく", "注意しても", "改善の気配", "無いし。"]}, {"box": [144, 96, 208, 206], "vertical": true, "font_size": 18, "lines_coords": [[[192.0, 99.0], [208.0, 99.0], [208.0, 206.0], [192.0, 206.0]], [[169.0, 100.0], [186.0, 100.0], [186.0, 189.0], [169.0, 189.0]], [[144.0, 96.0], [171.0, 96.0], [171.0, 146.0], [144.0, 146.0]]], "lines": ["じゃあそれは", "店側の怠慢", "だし、"]}, {"box": [90, 248, 193, 391], "vertical": true, "font_size": 18, "lines_coords": [[[176.0, 250.0], [193.0, 250.0], [193.0, 373.0], [176.0, 373.0]], [[153.0, 250.0], [169.0, 250.0], [169.0, 373.0], [153.0, 373.0]], [[133.0, 250.0], [149.0, 250.0], [149.0, 391.0], [133.0, 391.0]], [[110.0, 248.0], [126.0, 248.0], [128.0, 356.0], [112.0, 356.0]], [[90.0, 249.0], [106.0, 249.0], [106.0, 338.0], [90.0, 338.0]]], "lines": ["あの店で買った", "缶の処理くらい", "店側のサービスの", "範疇だと思い", "ませんか？"]}, {"box": [549, 682, 635, 841], "vertical": true, "font_size": 20, "lines_coords": [[[612.0, 682.0], [633.0, 682.0], [633.0, 764.0], [612.0, 764.0]], [[593.0, 689.0], [613.0, 689.0], [613.0, 814.0], [593.0, 814.0]], [[571.0, 687.0], [591.0, 687.0], [591.0, 814.0], [571.0, 814.0]], [[549.0, 687.0], [569.0, 687.0], [570.0, 840.0], [550.0, 840.0]]], "lines": ["「．．．あなた、", "さっきゴミ箱の", "中身を確認して", "なかったでしょ？」"]}, {"box": [557, 1011, 640, 1136], "vertical": true, "font_size": 19, "lines_coords": [[[620.0, 1011.0], [640.0, 1011.0], [638.0, 1135.0], [618.0, 1135.0]], [[598.0, 1011.0], [618.0, 1011.0], [618.0, 1136.0], [598.0, 1136.0]], [[577.0, 1012.0], [597.0, 1012.0], [597.0, 1136.0], [577.0, 1136.0]], [[557.0, 1012.0], [574.0, 1012.0], [574.0, 1134.0], [557.0, 1134.0]]], "lines": ["．．．いや、だから", "ほとんどいつも", "いっぱいだって", "言ったでしょ？"]}, {"box": [438, 925, 501, 1092], "vertical": true, "font_size": 17, "lines_coords": [[[480.0, 925.0], [500.0, 925.0], [500.0, 1041.0], [480.0, 1041.0]], [[460.0, 935.0], [476.0, 935.0], [476.0, 1092.0], [460.0, 1092.0]], [[439.0, 933.0], [455.0, 933.0], [455.0, 1047.0], [439.0, 1047.0]]], "lines": ["「．．．いやだから", "今日はまだ確認して", "ないでしょ？」"]}, {"box": [110, 1065, 131, 1144], "vertical": true, "font_size": 18, "lines_coords": [[[110.0, 1065.0], [131.0, 1065.0], [131.0, 1096.0], [110.0, 1096.0]], [[113.0, 1113.0], [127.0, 1113.0], [127.0, 1141.0], [113.0, 1141.0]]], "lines": ["んー", "．．．"]}], "img_path": "121.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [685, 86, 746, 198], "vertical": true, "font_size": 18, "lines_coords": [[[726.0, 87.0], [746.0, 87.0], [746.0, 162.0], [726.0, 162.0]], [[707.0, 89.0], [723.0, 89.0], [723.0, 179.0], [707.0, 179.0]], [[685.0, 86.0], [701.0, 86.0], [701.0, 198.0], [685.0, 198.0]]], "lines": ["．．．はい、", "そうですね、", "わかりました。"]}, {"box": [600, 205, 663, 309], "vertical": true, "font_size": 18, "lines_coords": [[[641.0, 205.0], [663.0, 205.0], [663.0, 262.0], [641.0, 262.0]], [[623.0, 207.0], [639.0, 207.0], [639.0, 309.0], [623.0, 309.0]], [[603.0, 205.0], [620.0, 205.0], [618.0, 309.0], [600.0, 309.0]]], "lines": ["じゃあ", "確認しに戻り", "ましょうか？"]}, {"box": [203, 295, 284, 451], "vertical": true, "font_size": 17, "lines_coords": [[[268.0, 297.0], [284.0, 297.0], [284.0, 399.0], [268.0, 399.0]], [[246.0, 295.0], [265.0, 295.0], [263.0, 451.0], [243.0, 451.0]], [[226.0, 297.0], [242.0, 297.0], [242.0, 433.0], [226.0, 433.0]], [[203.0, 295.0], [223.0, 295.0], [223.0, 357.0], [203.0, 357.0]]], "lines": ["確かに今日は", "ゴミ箱に捨てられた", "かもしれないです", "からね。"]}, {"box": [146, 460, 224, 633], "vertical": true, "font_size": 17, "lines_coords": [[[208.0, 460.0], [224.0, 460.0], [224.0, 551.0], [208.0, 551.0]], [[186.0, 461.0], [202.0, 461.0], [202.0, 615.0], [186.0, 615.0]], [[166.0, 460.0], [182.0, 460.0], [182.0, 615.0], [166.0, 615.0]], [[146.0, 462.0], [162.0, 462.0], [162.0, 633.0], [146.0, 633.0]]], "lines": ["．．．てももし", "ゴミて満杯だったら", "あなたの言いがかり", "って事ていいですか？"]}, {"box": [668, 707, 749, 846], "vertical": true, "font_size": 18, "lines_coords": [[[729.0, 707.0], [749.0, 707.0], [749.0, 801.0], [729.0, 801.0]], [[709.0, 708.0], [726.0, 708.0], [726.0, 846.0], [709.0, 846.0]], [[690.0, 708.0], [706.0, 708.0], [706.0, 810.0], [690.0, 810.0]], [[668.0, 707.0], [685.0, 707.0], [685.0, 828.0], [668.0, 828.0]]], "lines": ["．．．その場合、", "あなたはちゃんと", "僕に謝罪して", "くれますよね？"]}, {"box": [490, 1007, 591, 1127], "vertical": true, "font_size": 17, "lines_coords": [[[574.0, 1007.0], [590.0, 1007.0], [590.0, 1109.0], [574.0, 1109.0]], [[552.0, 1007.0], [569.0, 1007.0], [569.0, 1100.0], [552.0, 1100.0]], [[531.0, 1007.0], [548.0, 1007.0], [548.0, 1110.0], [531.0, 1110.0]], [[510.0, 1007.0], [527.0, 1007.0], [527.0, 1109.0], [510.0, 1109.0]], [[490.0, 1007.0], [507.0, 1007.0], [507.0, 1127.0], [490.0, 1127.0]]], "lines": ["僕を不愉快に", "させた上に、", "無駄な時間を", "使わせた責任", "取れますよね？"]}, {"box": [298, 1034, 361, 1113], "vertical": true, "font_size": 20, "lines_coords": [[[342.0, 1034.0], [361.0, 1034.0], [361.0, 1110.0], [342.0, 1110.0]], [[318.0, 1040.0], [338.0, 1040.0], [338.0, 1110.0], [318.0, 1110.0]], [[298.0, 1040.0], [319.0, 1040.0], [319.0, 1113.0], [298.0, 1113.0]]], "lines": ["「．．．そんな", "屁理屈は", "いいから、"]}, {"box": [162, 1038, 225, 1160], "vertical": true, "font_size": 18, "lines_coords": [[[205.0, 1040.0], [222.0, 1040.0], [223.0, 1158.0], [206.0, 1158.0]], [[183.0, 1039.0], [201.0, 1039.0], [202.0, 1158.0], [185.0, 1158.0]], [[162.0, 1039.0], [182.0, 1039.0], [182.0, 1110.0], [162.0, 1110.0]]], "lines": ["缶くらい黙って", "持って帰れって", "話だよ。」"]}], "img_path": "122.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [658, 51, 736, 191], "vertical": true, "font_size": 17, "lines_coords": [[[720.0, 55.0], [736.0, 55.0], [736.0, 139.0], [720.0, 139.0]], [[700.0, 53.0], [716.0, 53.0], [716.0, 155.0], [700.0, 155.0]], [[678.0, 51.0], [698.0, 51.0], [697.0, 191.0], [677.0, 191.0]], [[658.0, 53.0], [674.0, 53.0], [674.0, 189.0], [658.0, 189.0]]], "lines": ["．．．そもそも", "さっきの店で", "もっと注意すべき", "奴はいたでしょ？"]}, {"box": [465, 100, 506, 173], "vertical": true, "font_size": 18, "lines_coords": [[[482.0, 100.0], [503.0, 100.0], [506.0, 173.0], [485.0, 173.0]], [[465.0, 101.0], [485.0, 101.0], [485.0, 172.0], [465.0, 172.0]]], "lines": ["．．．なんで", "僕だけ？"]}, {"box": [388, 209, 470, 303], "vertical": true, "font_size": 18, "lines_coords": [[[449.0, 209.0], [470.0, 209.0], [470.0, 266.0], [449.0, 266.0]], [[431.0, 213.0], [447.0, 213.0], [447.0, 303.0], [431.0, 303.0]], [[410.0, 212.0], [426.0, 212.0], [426.0, 298.0], [410.0, 298.0]], [[388.0, 212.0], [405.0, 212.0], [405.0, 281.0], [388.0, 281.0]]], "lines": ["正義感", "ふるう相手、", "間違えてる", "だろ．．．．．"]}, {"box": [282, 75, 323, 169], "vertical": true, "font_size": 19, "lines_coords": [[[301.0, 75.0], [323.0, 75.0], [323.0, 128.0], [301.0, 128.0]], [[282.0, 75.0], [298.0, 75.0], [298.0, 167.0], [282.0, 167.0]]], "lines": ["．．．あぁ", "そうですか"]}, {"box": [125, 196, 206, 331], "vertical": true, "font_size": 18, "lines_coords": [[[185.0, 196.0], [206.0, 196.0], [206.0, 267.0], [185.0, 267.0]], [[165.0, 196.0], [181.0, 196.0], [181.0, 298.0], [165.0, 298.0]], [[144.0, 196.0], [160.0, 196.0], [160.0, 331.0], [144.0, 331.0]], [[125.0, 196.0], [141.0, 196.0], [141.0, 288.0], [125.0, 288.0]]], "lines": ["．．．これは", "この先にある", "自販機のゴミ箱に", "捨てますよ。"]}, {"box": [584, 324, 603, 384], "vertical": true, "font_size": 19, "lines_coords": [[[584.0, 324.0], [603.0, 324.0], [603.0, 384.0], [584.0, 384.0]]], "lines": ["「．．．話を"]}, {"box": [581, 321, 605, 387], "vertical": true, "font_size": 22, "lines_coords": [[[581.0, 321.0], [605.0, 321.0], [605.0, 387.0], [581.0, 387.0]]], "lines": ["「．．．話を"]}, {"box": [524, 333, 543, 452], "vertical": true, "font_size": 19, "lines_coords": [[[524.0, 333.0], [543.0, 333.0], [543.0, 452.0], [524.0, 452.0]]], "lines": ["すり替えるな。」"]}, {"box": [523, 333, 543, 454], "vertical": true, "font_size": 22, "lines_coords": [[[523.0, 333.0], [543.0, 333.0], [543.0, 454.0], [523.0, 454.0]]], "lines": ["すり替えるな。」"]}, {"box": [97, 355, 138, 457], "vertical": true, "font_size": 18, "lines_coords": [[[117.0, 355.0], [138.0, 355.0], [138.0, 424.0], [117.0, 424.0]], [[99.0, 355.0], [117.0, 355.0], [114.0, 457.0], [97.0, 457.0]]], "lines": ["．．．それで", "いいですか？"]}, {"box": [665, 578, 703, 706], "vertical": true, "font_size": 16, "lines_coords": [[[686.0, 580.0], [702.0, 580.0], [702.0, 665.0], [686.0, 665.0]], [[665.0, 580.0], [681.0, 580.0], [681.0, 706.0], [665.0, 706.0]]], "lines": ["．．．てもよく", "考えてください。"]}, {"box": [199, 663, 279, 767], "vertical": true, "font_size": 20, "lines_coords": [[[263.0, 664.0], [279.0, 664.0], [279.0, 766.0], [263.0, 766.0]], [[242.0, 665.0], [258.0, 665.0], [258.0, 766.0], [242.0, 766.0]], [[221.0, 664.0], [237.0, 664.0], [237.0, 767.0], [221.0, 767.0]], [[199.0, 663.0], [220.0, 663.0], [220.0, 720.0], [199.0, 720.0]]], "lines": ["さっきの店に", "いた客の中で", "僕とあなたも", "含めて、"]}, {"box": [112, 769, 165, 919], "vertical": true, "font_size": 20, "lines_coords": [[[140.0, 769.0], [165.0, 769.0], [165.0, 866.0], [140.0, 866.0]], [[112.0, 772.0], [135.0, 772.0], [135.0, 919.0], [112.0, 919.0]]], "lines": ["誰が一番", "おかしいのか。"]}, {"box": [385, 1017, 456, 1122], "vertical": true, "font_size": 24, "lines_coords": [[[432.0, 1017.0], [456.0, 1017.0], [456.0, 1086.0], [432.0, 1086.0]], [[410.0, 1024.0], [431.0, 1024.0], [431.0, 1122.0], [410.0, 1122.0]], [[385.0, 1024.0], [411.0, 1024.0], [411.0, 1086.0], [385.0, 1086.0]]], "lines": ["「．．．何が", "言いたいん", "だよ。」"]}], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [685, 79, 728, 195], "vertical": true, "font_size": 20, "lines_coords": [[[708.0, 80.0], [728.0, 80.0], [728.0, 195.0], [708.0, 195.0]], [[685.0, 79.0], [705.0, 79.0], [705.0, 180.0], [685.0, 180.0]]], "lines": ["．．．言いたいん", "じゃなくて、"]}, {"box": [351, 120, 399, 246], "vertical": true, "font_size": 23, "lines_coords": [[[374.0, 123.0], [399.0, 123.0], [399.0, 202.0], [374.0, 202.0]], [[351.0, 120.0], [372.0, 120.0], [373.0, 246.0], [352.0, 246.0]]], "lines": ["気付いて", "欲しいんです。"]}, {"box": [208, 50, 248, 158], "vertical": true, "font_size": 20, "lines_coords": [[[227.0, 50.0], [248.0, 50.0], [248.0, 104.0], [227.0, 104.0]], [[208.0, 50.0], [224.0, 50.0], [224.0, 158.0], [208.0, 158.0]]], "lines": ["．．．もう", "いいですけど"]}, {"box": [118, 99, 181, 203], "vertical": true, "font_size": 20, "lines_coords": [[[161.0, 101.0], [181.0, 101.0], [181.0, 173.0], [161.0, 173.0]], [[142.0, 104.0], [159.0, 104.0], [159.0, 203.0], [142.0, 203.0]], [[118.0, 99.0], [144.0, 99.0], [144.0, 150.0], [118.0, 150.0]]], "lines": ["さすがに", "馬鹿馬鹿しい", "ので。"]}, {"box": [661, 551, 729, 675], "vertical": true, "font_size": 23, "lines_coords": [[[705.0, 553.0], [729.0, 553.0], [729.0, 617.0], [705.0, 617.0]], [[687.0, 555.0], [704.0, 555.0], [704.0, 673.0], [687.0, 673.0]], [[661.0, 551.0], [688.0, 551.0], [688.0, 600.0], [661.0, 600.0]]], "lines": ["．．．けど、", "あんたみたいな", "奴が、"]}, {"box": [237, 553, 320, 676], "vertical": true, "font_size": 18, "lines_coords": [[[304.0, 556.0], [320.0, 556.0], [320.0, 675.0], [304.0, 675.0]], [[283.0, 556.0], [299.0, 556.0], [299.0, 676.0], [283.0, 676.0]], [[262.0, 556.0], [278.0, 556.0], [278.0, 676.0], [262.0, 676.0]], [[237.0, 553.0], [258.0, 553.0], [261.0, 632.0], [240.0, 632.0]]], "lines": ["身勝手な正義を", "履き違えたまま", "平然と生きてる", "と思うと、"]}, {"box": [132, 604, 193, 693], "vertical": true, "font_size": 18, "lines_coords": [[[172.0, 604.0], [193.0, 604.0], [193.0, 662.0], [172.0, 662.0]], [[151.0, 605.0], [171.0, 605.0], [171.0, 693.0], [151.0, 693.0]], [[132.0, 607.0], [148.0, 607.0], [148.0, 683.0], [132.0, 683.0]]], "lines": ["怒りを", "通り越して", "心が痛い。"]}], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [608, 55, 627, 159], "vertical": true, "font_size": 19, "lines_coords": [[[608.0, 55.0], [627.0, 55.0], [627.0, 159.0], [608.0, 159.0]]], "lines": ["「．．．いちいち、"]}, {"box": [606, 56, 626, 158], "vertical": true, "font_size": 21, "lines_coords": [[[606.0, 56.0], [626.0, 56.0], [626.0, 158.0], [606.0, 158.0]]], "lines": ["「．．．いちいち、"]}, {"box": [521, 67, 560, 153], "vertical": true, "font_size": 39, "lines_coords": [[[521.0, 67.0], [560.0, 67.0], [560.0, 153.0], [521.0, 153.0]]], "lines": ["一言多いんだよ。」"]}, {"box": [518, 66, 561, 154], "vertical": true, "font_size": 21, "lines_coords": [[[540.0, 70.0], [561.0, 70.0], [561.0, 154.0], [540.0, 154.0]], [[518.0, 66.0], [541.0, 66.0], [541.0, 124.0], [518.0, 124.0]]], "lines": ["一言多いん", "だよ。」"]}, {"box": [195, 119, 265, 265], "vertical": true, "font_size": 22, "lines_coords": [[[238.0, 119.0], [265.0, 119.0], [265.0, 174.0], [238.0, 174.0]], [[219.0, 131.0], [238.0, 131.0], [238.0, 246.0], [219.0, 246.0]], [[195.0, 132.0], [215.0, 132.0], [215.0, 264.0], [195.0, 264.0]]], "lines": ["「お前", "みたいな奴が", "一番むかつく。」"]}, {"box": [422, 289, 453, 363], "vertical": true, "font_size": 31, "lines_coords": [[[422.0, 289.0], [453.0, 289.0], [453.0, 363.0], [422.0, 363.0]]], "lines": ["．．．あ？"]}, {"box": [374, 1010, 472, 1155], "vertical": true, "font_size": 24, "lines_coords": [[[445.0, 1010.0], [472.0, 1010.0], [472.0, 1065.0], [445.0, 1065.0]], [[422.0, 1023.0], [445.0, 1023.0], [445.0, 1139.0], [422.0, 1139.0]], [[400.0, 1021.0], [421.0, 1021.0], [419.0, 1155.0], [398.0, 1155.0]], [[374.0, 1020.0], [400.0, 1020.0], [400.0, 1082.0], [374.0, 1082.0]]], "lines": ["「お前", "みたいな奴が", "一番むかつくん", "だよ。」"]}], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [674, 83, 740, 219], "vertical": true, "font_size": 19, "lines_coords": [[[720.0, 83.0], [740.0, 83.0], [740.0, 182.0], [720.0, 182.0]], [[695.0, 84.0], [715.0, 84.0], [715.0, 200.0], [695.0, 200.0]], [[674.0, 84.0], [691.0, 84.0], [691.0, 194.0], [674.0, 194.0]]], "lines": ["さーーさー", "のーはー", "さーらさらー"]}, {"box": [117, 323, 209, 443], "vertical": true, "font_size": 21, "lines_coords": [[[183.0, 323.0], [207.0, 323.0], [209.0, 418.0], [186.0, 418.0]], [[162.0, 326.0], [183.0, 326.0], [183.0, 424.0], [162.0, 424.0]], [[139.0, 325.0], [160.0, 325.0], [160.0, 421.0], [139.0, 421.0]], [[117.0, 326.0], [137.0, 326.0], [137.0, 355.0], [117.0, 355.0]]], "lines": ["のーーきー", "ばーーにー", "ゆーーれー", "るー"]}, {"box": [220, 551, 258, 638], "vertical": true, "font_size": 16, "lines_coords": [[[242.0, 551.0], [258.0, 551.0], [258.0, 638.0], [242.0, 638.0]], [[220.0, 551.0], [240.0, 551.0], [240.0, 628.0], [220.0, 628.0]]], "lines": ["榎か織姫役", "なんだと。"]}, {"box": [686, 555, 751, 653], "vertical": true, "font_size": 18, "lines_coords": [[[733.0, 558.0], [749.0, 558.0], [749.0, 652.0], [733.0, 652.0]], [[708.0, 555.0], [729.0, 555.0], [727.0, 635.0], [706.0, 635.0]], [[686.0, 557.0], [702.0, 557.0], [702.0, 652.0], [686.0, 652.0]]], "lines": ["あっはっは", "じょうず", "じょうす！！"]}, {"box": [470, 624, 515, 698], "vertical": true, "font_size": 24, "lines_coords": [[[494.0, 626.0], [515.0, 626.0], [515.0, 698.0], [494.0, 698.0]], [[470.0, 624.0], [497.0, 624.0], [497.0, 666.0], [470.0, 666.0]]], "lines": ["幼稚園の", "劇？"]}, {"box": [448, 775, 487, 887], "vertical": true, "font_size": 20, "lines_coords": [[[470.0, 775.0], [487.0, 775.0], [487.0, 862.0], [470.0, 862.0]], [[448.0, 775.0], [465.0, 775.0], [467.0, 887.0], [451.0, 887.0]]], "lines": ["流れ星でも", "いいじゃない。"]}, {"box": [342, 800, 405, 908], "vertical": true, "font_size": 20, "lines_coords": [[[377.0, 800.0], [405.0, 800.0], [405.0, 846.0], [377.0, 846.0]], [[360.0, 803.0], [380.0, 803.0], [380.0, 908.0], [360.0, 908.0]], [[342.0, 805.0], [358.0, 805.0], [358.0, 890.0], [342.0, 890.0]]], "lines": ["私は", "かっこいいと", "思うけど？"]}, {"box": [124, 603, 179, 706], "vertical": true, "font_size": 16, "lines_coords": [[[164.0, 604.0], [179.0, 604.0], [179.0, 706.0], [164.0, 706.0]], [[141.0, 603.0], [158.0, 603.0], [158.0, 672.0], [141.0, 672.0]], [[124.0, 605.0], [137.0, 605.0], [137.0, 690.0], [124.0, 690.0]]], "lines": ["天馬は端役の", "流れ星Ａ", "だけどな！！"]}, {"box": [734, 964, 755, 1038], "vertical": true, "font_size": 18, "lines_coords": [[[734.0, 964.0], [755.0, 964.0], [755.0, 1038.0], [734.0, 1038.0]]], "lines": ["．．．おっと、"]}, {"box": [665, 1004, 702, 1106], "vertical": true, "font_size": 18, "lines_coords": [[[686.0, 1005.0], [702.0, 1005.0], [702.0, 1091.0], [686.0, 1091.0]], [[665.0, 1004.0], [681.0, 1004.0], [681.0, 1106.0], [665.0, 1106.0]]], "lines": ["意外と気に", "してたか．．．"]}, {"box": [428, 985, 474, 1091], "vertical": true, "font_size": 21, "lines_coords": [[[449.0, 985.0], [474.0, 985.0], [474.0, 1058.0], [449.0, 1058.0]], [[428.0, 987.0], [445.0, 987.0], [445.0, 1091.0], [428.0, 1091.0]]], "lines": ["．．．うおっ", "急に懐いた！！"]}, {"box": [114, 1044, 182, 1149], "vertical": true, "font_size": 23, "lines_coords": [[[151.0, 1045.0], [180.0, 1044.0], [182.0, 1100.0], [153.0, 1101.0]], [[139.0, 1047.0], [155.0, 1047.0], [155.0, 1149.0], [139.0, 1149.0]], [[114.0, 1047.0], [137.0, 1047.0], [137.0, 1082.0], [114.0, 1082.0]]], "lines": ["うへへ", "子供あったか", "いー"]}], "img_path": "126.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [709, 79, 738, 140], "vertical": true, "font_size": 26, "lines_coords": [[[712.0, 79.0], [738.0, 80.0], [735.0, 140.0], [709.0, 139.0]]], "lines": ["あ．．．"]}, {"box": [403, 167, 422, 282], "vertical": true, "font_size": 16, "lines_coords": [[[404.0, 168.0], [420.0, 168.0], [420.0, 282.0], [404.0, 282.0]]], "lines": ["思い出した．．．"]}, {"box": [646, 318, 727, 440], "vertical": true, "font_size": 19, "lines_coords": [[[706.0, 319.0], [727.0, 319.0], [727.0, 390.0], [706.0, 390.0]], [[686.0, 319.0], [706.0, 319.0], [706.0, 407.0], [686.0, 407.0]], [[666.0, 318.0], [684.0, 318.0], [682.0, 439.0], [665.0, 439.0]], [[646.0, 319.0], [663.0, 319.0], [663.0, 439.0], [646.0, 439.0]]], "lines": ["．．．あれは", "プンプンが", "小学二年生の時", "だったかな．．．"]}, {"box": [688, 529, 727, 632], "vertical": true, "font_size": 18, "lines_coords": [[[707.0, 529.0], [727.0, 529.0], [727.0, 601.0], [707.0, 601.0]], [[688.0, 530.0], [705.0, 530.0], [705.0, 632.0], [688.0, 632.0]]], "lines": ["流れ星を", "追いかけて．．．"]}, {"box": [90, 308, 171, 445], "vertical": true, "font_size": 17, "lines_coords": [[[152.0, 308.0], [168.0, 308.0], [168.0, 444.0], [152.0, 444.0]], [[132.0, 308.0], [148.0, 308.0], [148.0, 445.0], [132.0, 445.0]], [[108.0, 308.0], [128.0, 308.0], [128.0, 430.0], [108.0, 430.0]], [[90.0, 309.0], [107.0, 309.0], [107.0, 363.0], [90.0, 363.0]]], "lines": ["前にもブンフンが", "行方不明になった", "事があるんです", "よ．．．．．"]}, {"box": [619, 672, 698, 786], "vertical": true, "font_size": 18, "lines_coords": [[[678.0, 672.0], [698.0, 672.0], [698.0, 748.0], [678.0, 748.0]], [[657.0, 673.0], [677.0, 673.0], [677.0, 786.0], [657.0, 786.0]], [[638.0, 672.0], [656.0, 672.0], [653.0, 775.0], [636.0, 775.0]], [[619.0, 675.0], [633.0, 675.0], [633.0, 765.0], [619.0, 765.0]]], "lines": ["その時は、", "結局隣の市で", "保護されたん", "てすけどね。"]}, {"box": [144, 699, 208, 832], "vertical": true, "font_size": 16, "lines_coords": [[[190.0, 699.0], [207.0, 699.0], [207.0, 795.0], [190.0, 795.0]], [[167.0, 700.0], [183.0, 700.0], [183.0, 832.0], [167.0, 832.0]], [[144.0, 699.0], [160.0, 699.0], [160.0, 813.0], [144.0, 813.0]]], "lines": ["．．．あの日は", "みんなで大騒ぎ", "だったなァ．．．"]}, {"box": [650, 902, 735, 1066], "vertical": true, "font_size": 18, "lines_coords": [[[715.0, 902.0], [735.0, 902.0], [735.0, 1025.0], [715.0, 1025.0]], [[694.0, 903.0], [714.0, 903.0], [714.0, 1040.0], [694.0, 1040.0]], [[668.0, 902.0], [688.0, 902.0], [688.0, 1025.0], [668.0, 1025.0]], [[650.0, 903.0], [666.0, 903.0], [666.0, 1066.0], [650.0, 1066.0]]], "lines": ["当時プンプンと", "一番仲の良かった", "渡辺君っていう", "男の子がいましてね。"]}, {"box": [541, 983, 598, 1121], "vertical": true, "font_size": 18, "lines_coords": [[[582.0, 983.0], [598.0, 983.0], [598.0, 1120.0], [582.0, 1120.0]], [[561.0, 983.0], [577.0, 983.0], [577.0, 1121.0], [561.0, 1121.0]], [[541.0, 984.0], [557.0, 984.0], [557.0, 1109.0], [541.0, 1109.0]]], "lines": ["その子がみんなに", "こう言い張ってた", "らしいんですよ。"]}, {"box": [216, 936, 279, 1067], "vertical": true, "font_size": 17, "lines_coords": [[[262.0, 936.0], [279.0, 936.0], [277.0, 1016.0], [260.0, 1016.0]], [[240.0, 937.0], [256.0, 937.0], [256.0, 1067.0], [240.0, 1067.0]], [[219.0, 936.0], [240.0, 936.0], [237.0, 1008.0], [216.0, 1008.0]]], "lines": ["「流れ星を", "捕まえた事ある」", "って．．．"]}, {"box": [79, 1001, 158, 1140], "vertical": true, "font_size": 17, "lines_coords": [[[141.0, 1001.0], [158.0, 1001.0], [158.0, 1087.0], [141.0, 1087.0]], [[120.0, 1003.0], [137.0, 1003.0], [137.0, 1123.0], [120.0, 1123.0]], [[100.0, 1003.0], [117.0, 1003.0], [117.0, 1140.0], [100.0, 1140.0]], [[79.0, 1003.0], [96.0, 1003.0], [96.0, 1072.0], [79.0, 1072.0]]], "lines": ["子供らしい", "たわいもない嘘", "だったんでしょう", "けど．．．"]}], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [154, 982, 202, 1130], "vertical": true, "font_size": 46, "lines_coords": [[[154.0, 983.0], [200.0, 982.0], [202.0, 1129.0], [156.0, 1130.0]]], "lines": ["うっ．．．"]}], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [685, 77, 726, 198], "vertical": true, "font_size": 18, "lines_coords": [[[701.0, 77.0], [723.0, 77.0], [726.0, 151.0], [704.0, 151.0]], [[685.0, 79.0], [701.0, 79.0], [701.0, 198.0], [685.0, 198.0]]], "lines": ["．．．恐らく", "フンフンは．．．．．．"]}, {"box": [581, 147, 660, 269], "vertical": true, "font_size": 18, "lines_coords": [[[640.0, 147.0], [660.0, 147.0], [660.0, 219.0], [640.0, 219.0]], [[619.0, 147.0], [639.0, 147.0], [639.0, 269.0], [619.0, 269.0]], [[600.0, 148.0], [617.0, 148.0], [617.0, 250.0], [600.0, 250.0]], [[581.0, 148.0], [597.0, 148.0], [597.0, 232.0], [581.0, 232.0]]], "lines": ["渡辺君を", "嘘つきにしたく", "なかったんて", "しょう．．．"]}, {"box": [222, 70, 281, 206], "vertical": t