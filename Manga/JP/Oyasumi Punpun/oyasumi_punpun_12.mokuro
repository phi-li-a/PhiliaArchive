], [679.0, 155.0]]], "lines": ["あたしが", "どこかへ", "行ったら．．．"]}, {"box": [650, 216, 712, 336], "vertical": true, "font_size": 18, "lines_coords": [[[692.0, 219.0], [712.0, 219.0], [712.0, 305.0], [692.0, 305.0]], [[672.0, 219.0], [688.0, 219.0], [688.0, 303.0], [672.0, 303.0]], [[650.0, 216.0], [666.0, 216.0], [668.0, 336.0], [652.0, 336.0]]], "lines": ["一人で．．．", "死ぬつもり", "なんでしょ．．．"]}, {"box": [323, 152, 395, 269], "vertical": true, "font_size": 21, "lines_coords": [[[370.0, 152.0], [395.0, 152.0], [395.0, 217.0], [370.0, 217.0]], [[347.0, 154.0], [367.0, 154.0], [367.0, 269.0], [347.0, 269.0]], [[325.0, 153.0], [345.0, 153.0], [343.0, 251.0], [323.0, 251.0]]], "lines": ["ずっと", "わかってたよ", "そんなの．．．"]}, {"box": [151, 147, 197, 287], "vertical": true, "font_size": 20, "lines_coords": [[[178.0, 148.0], [197.0, 148.0], [197.0, 273.0], [178.0, 273.0]], [[151.0, 147.0], [174.0, 147.0], [174.0, 287.0], [151.0, 287.0]]], "lines": ["「．．．そんな同情", "いらないんだよ。"]}, {"box": [64, 147, 132, 300], "vertical": true, "font_size": 20, "lines_coords": [[[112.0, 147.0], [132.0, 147.0], [132.0, 263.0], [112.0, 263.0]], [[87.0, 147.0], [107.0, 147.0], [107.0, 300.0], [87.0, 300.0]], [[64.0, 148.0], [84.0, 148.0], [84.0, 283.0], [64.0, 283.0]]], "lines": ["だって僕は今", "とても満たされて", "いるんだから。」"]}, {"box": [681, 508, 716, 587], "vertical": true, "font_size": 37, "lines_coords": [[[681.0, 508.0], [716.0, 508.0], [716.0, 587.0], [681.0, 587.0]]], "lines": ["ハアッ"]}, {"box": [271, 322, 340, 421], "vertical": true, "font_size": 21, "lines_coords": [[[315.0, 322.0], [340.0, 322.0], [340.0, 370.0], [315.0, 370.0]], [[296.0, 328.0], [312.0, 328.0], [312.0, 421.0], [296.0, 421.0]], [[274.0, 325.0], [291.0, 325.0], [289.0, 385.0], [271.0, 385.0]]], "lines": ["でも", "それは駄目", "．．．．．．"]}, {"box": [167, 536, 202, 615], "vertical": true, "font_size": 35, "lines_coords": [[[167.0, 536.0], [202.0, 536.0], [202.0, 615.0], [167.0, 615.0]]], "lines": ["ハアッ"]}, {"box": [641, 638, 680, 720], "vertical": true, "font_size": 37, "lin