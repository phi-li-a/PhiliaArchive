011.0]], [[135.0, 1017.0], [759.0, 1018.0], [759.0, 1033.0], [135.0, 1032.0]], [[138.0, 1038.0], [665.0, 1038.0], [665.0, 1053.0], [138.0, 1053.0]], [[135.0, 1058.0], [623.0, 1057.0], [623.0, 1073.0], [135.0, 1074.0]], [[137.0, 1078.0], [623.0, 1078.0], [623.0, 1093.0], [137.0, 1093.0]], [[138.0, 1098.0], [545.0, 1098.0], [545.0, 1113.0], [138.0, 1113.0]]], "lines": ["●法本には十分注意しておりますが、落丁。見ずに体のページの抜け落ちや順序の間違いの場合はお取り", "替えいたします。購入された書店名を明記して「耐作局」あてにお送りください。送料小社負担にてお取り", "り替えいたします。", "●本書の一部あるいは全部を無断で複製・転載・上演放送等をすることは、法律で認められた場合を除き", "著作者および出版者の権利の侵害となります。あらかじめ小社あて請請をお求めください。", "国｛公益社団法人日本教製権センター委託出版物", "本書を無断で被写被製にコピーいずることは、著作権法上の例外を除き、禁じられています。本書をコピー", "される場合は、事前に公益社団法人日本複製権センターＪＲＲＣの許諾を受けてください。", "ＪＲＲＣ／ｈｔｔｐ／／ｗｗｗｉｔｃｏｒｙセメール・ゴールＣｉｎｆｏ＠ｃｈｔｒｏ！！ＴＥＬ．ＯＳ－３０１－２８２", "●本書の電子データ化等の無断複製は著作権法上での例外を除き禁じられています。", "代行業者等の第三者による本書の電子的複製も認められておりません。"]}, {"box": [589, 939, 756, 951], "vertical": false, "font_size": 12, "lines_coords": [[[589.0, 939.0], [756.0, 939.0], [756.0, 951.0], [589.0, 951.0]]], "lines": ["制作局（ＴＥＬ０１２０－３３６－０８２"]}], "img_path": "256.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [120, 815, 194, 916], "vertical": true, "font_size": 27.0, "lines_coords": [[[165.0, 815.0], [194.0, 815.0], [194.0, 916.0], [165.0, 916.0]], [[120.0, 815.0], [145.0, 815.0], [145.0, 911.0], [120.0, 911.0]]], "lines": ["名名行", "書著発"]}, {"box": [139, 807, 455, 878], "vertical": false, "font_size": 30.333333333333332, "lines_coords": [[[214.0, 815.0], [454.0, 807.0], [455.0, 840.0], [215.0, 848.0]], [[214.0, 849.0], [336.0, 849.0], [336.0, 877.0], [214.0, 877.0]], [[139.0, 848.0], [173.0, 848.0], [173.0, 878.0], [139.0, 878.0]]], "lines": ["おやすみプンプン１２．", "浅野いにお", "皆者イ"]}, {"box": [217, 889, 384, 909], "vertical": false, "font_size": 20, "lines_coords": [[[217.0, 889.0], [384.0, 889.0], [384.0, 909.0], [217.0, 909.0]]], "lines": ["株式会社小学館"]}, {"box": [124, 994, 571, 1018], "vertical": false, "font_size": 24, "lines_coords": [[[124.0, 994.0], [571.0, 994