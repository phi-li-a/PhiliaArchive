], "vertical": true, "font_size": 81, "lines_coords": [[[668.0, 88.0], [749.0, 88.0], [749.0, 190.0], [668.0, 190.0]]], "lines": ["．．．バイト先のコンビニかビデオ屋、社長の店．．．．．"]}, {"box": [551, 235, 672, 375], "vertical": true, "font_size": 18, "lines_coords": [[[656.0, 239.0], [672.0, 239.0], [672.0, 357.0], [656.0, 357.0]], [[633.0, 236.0], [653.0, 236.0], [651.0, 325.0], [631.0, 325.0]], [[611.0, 237.0], [631.0, 237.0], [631.0, 325.0], [611.0, 325.0]], [[589.0, 235.0], [609.0, 235.0], [611.0, 360.0], [591.0, 360.0]], [[571.0, 239.0], [588.0, 239.0], [588.0, 375.0], [571.0, 375.0]], [[551.0, 239.0], [568.0, 239.0], [568.0, 314.0], [551.0, 314.0]]], "lines": ["あとはせいぜい", "ゲーセンか", "家電量販店", "くらいでしょう", "野郎が行きそうな", "所なんて。"]}, {"box": [670, 544, 729, 648], "vertical": true, "font_size": 20, "lines_coords": [[[709.0, 544.0], [729.0, 544.0], [729.0, 615.0], [709.0, 615.0]], [[691.0, 544.0], [707.0, 544.0], [707.0, 646.0], [691.0, 646.0]], [[670.0, 544.0], [686.0, 544.0], [686.0, 648.0], [670.0, 648.0]]], "lines": ["．．．例えば", "君らの共通の", "友達とかは？"]}, {"box": [125, 372, 165, 483], "vertical": true, "font_size": 17, "lines_coords": [[[148.0, 373.0], [165.0, 373.0], [165.0, 475.0], [148.0, 475.0]], [[127.0, 372.0], [145.0, 372.0], [142.0, 481.0], [125.0, 481.0]]], "lines": ["そこらへんは", "大体まわった"]}, {"box": [740, 766, 760, 794], "vertical": true, "font_size": 18, "lines_coords": [[[740.0, 766.0], [760.0, 766.0], [760.0, 794.0], [740.0, 794.0]]], "lines": ["んー"]}, {"box": [563, 575, 627, 699], "vertical": true, "font_size": 20, "lines_coords": [[[608.0, 578.0], [627.0, 578.0], [627.0, 650.0], [608.0, 650.0]], [[586.0, 577.0], [606.0, 577.0], [606.0, 699.0], [586.0, 699.0]], [[563.0, 575.0], [589.0, 575.0], [589.0, 624.0], [563.0, 624.0]]], "lines": ["誰かんち", "泊まり歩いてる", "とか。"]}, {"box": [432, 759, 468, 869], "vertical": true, "font_size": 18, "lines_coords": [[[452.0, 760.0], [468.0, 760.0], [468.0, 863.0], [452.0, 863.0]], [[432.0, 759.0], [447.0, 759.0], [447.0, 869.0], [432.0, 869.0]]], "lines": ["俺と南条さん", "くらいですよ。"]}, {"box": [339, 844, 400, 938], "vertical": true, "font_size": 18, "lines_coords": [[[378.0, 844.0], [400.0, 844.0], [400.0, 900.0], [378.0, 900.0]], [[358.0, 844.0], [376.0, 844.0], [377.0, 931.0], [359.0, 931.0]], [[339.0, 846.0], [356.0, 846.0], [356.0, 938.0], [339.0, 938.0]]], "lines": ["奴から", "連絡できる", "人間なんて。"]}, {"box": [680, 855, 740, 977], "vertical": true, "font_size": 18, "lines_coords": [[[723.0, 856.0], [740.0, 856.0], [740.0, 960.0], [723.0, 960.0]], [[701.0, 855.0], [718.0, 855.0], [718.0, 977.0], [701.0, 977.0]], [[680.0, 856.0], [700.0, 856.0], [700.0, 928.0], [680.0, 928.0]]], "lines": ["高校の奴らは", "とんとご無沙汰", "だし．．．"]}, {"box": [529, 977, 592, 1100], "vertical": true, "font_size": 20, "lines_coords": [[[567.0, 977.0], [592.0, 977.0], [592.0, 1025.0], [567.0, 1025.0]], [[548.0, 977.0], [568.0, 977.0], [570.0, 1100.0], [550.0, 1100.0]], [[529.0, 979.0], [545.0, 979.0], [545.0, 1081.0], [529.0, 1081.0]]], "lines": ["正直、", "オノッティーに", "友達なんて．．．"]}, {"box": [145, 862, 209, 953], "vertical": true, "font_size": 18, "lines_coords": [[[181.0, 863.0], [207.0, 862.0], [209.0, 918.0], [183.0, 919.0]], [[166.0, 864.0], [186.0, 864.0], [186.0, 953.0], [166.0, 953.0]], [[145.0, 866.0], [165.0, 866.0], [165.0, 938.0], [145.0, 938.0]]], "lines": ["なんせ", "ああいう男", "ですから"]}, {"box": [104, 1006, 203, 1127], "vertical": true, "font_size": 18, "lines_coords": [[[165.0, 1007.0], [181.0, 1007.0], [181.0, 1127.0], [165.0, 1127.0]], [[187.0, 1008.0], [203.0, 1008.0], [203.0, 1076.0], [187.0, 1076.0]], [[144.0, 1007.0], [160.0, 1007.0], [160.0, 1096.0], [144.0, 1096.0]], [[124.0, 1007.0], [140.0, 1007.0], [140.0, 1127.0], [124.0, 1127.0]], [[104.0, 1006.0], [120.0, 1006.0], [120.0, 1127.0], [104.0, 1127.0]]], "lines": ["携帯持ち歩いて", "いまどき", "ないなんて", "そもそもアレで", "ございましょ？"]}], "img_path": "014.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [714, 82, 732, 110], "vertical": true, "font_size": 19, "lines_coords": [[[714.0, 82.