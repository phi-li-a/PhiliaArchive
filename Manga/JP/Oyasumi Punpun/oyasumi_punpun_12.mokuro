, 445.0]], [[130.0, 331.0], [146.0, 331.0], [146.0, 452.0], [130.0, 452.0]], [[104.0, 329.0], [124.0, 329.0], [124.0, 445.0], [104.0, 445.0]], [[78.0, 326.0], [105.0, 326.0], [105.0, 380.0], [78.0, 380.0]]], "lines": ["奴とて立派な", "ますらおです。", "ますらおぶり", "です。"]}, {"box": [487, 741, 507, 834], "vertical": true, "font_size": 18, "lines_coords": [[[487.0, 741.0], [507.0, 741.0], [507.0, 834.0], [487.0, 834.0]]], "lines": ["プンプンさ、"]}, {"box": [383, 782, 440, 919], "vertical": true, "font_size": 18, "lines_coords": [[[424.0, 782.0], [440.0, 782.0], [440.0, 869.0], [424.0, 869.0]], [[401.0, 782.0], [419.0, 782.0], [420.0, 919.0], [402.0, 919.0]], [[383.0, 783.0], [399.0, 783.0], [399.0, 869.0], [383.0, 869.0]]], "lines": ["三村に何か", "変わった事言って", "なかった？"]}, {"box": [212, 571, 257, 676], "vertical": true, "font_size": 20, "lines_coords": [[[237.0, 573.0], [257.0, 573.0], [257.0, 667.0], [237.0, 667.0]], [[214.0, 571.0], [234.0, 571.0], [231.0, 676.0], [212.0, 676.0]]], "lines": ["嫌な予感が", "するんだよ。"]}, {"box": [74, 867, 182, 1126], "vertical": true, "font_size": 18, "lines_coords": [[[162.0, 867.0], [179.0, 867.0], [179.0, 933.0], [162.0, 933.0]], [[135.0, 986.0], [155.0, 986.0], [153.0, 1074.0], [133.0, 1074.0]], [[158.0, 989.0], [174.0, 989.0], [174.0, 1075.0], [158.0, 1075.0]], [[115.0, 989.0], [132.0, 989.0], [132.0, 1075.0], [115.0, 1075.0]], [[93.0, 987.0], [113.0, 987.0], [113.0, 1126.0], [93.0, 1126.0]], [[74.0, 989.0], [91.0, 989.0], [91.0, 1107.0], [74.0, 1107.0]]], "lines": ["いえね．．．", "就職活動で", "俺も学業と", "奴とは近頃", "やや疎遠になって", "おりまして．．．"]}], "img_path": "015.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [654, 110, 698, 194], "vertical": true, "font_size": 20, "lines_coords": [[[677.0, 110.0], [698.0, 110.0], [698.0, 187.0], [677.0, 187.0]], [[654.0, 110.0], [674.0, 110.0], [674.0, 194.0], [654.0, 194.0]]], "lines": ["というか", "南条さん。"]}, {"box": [295, 510, 356, 633], "vertical": true, "font_size": 18, "lines_coords": [[[333.0, 510.0], [353.0, 510.0], [356.0, 632.0], [336.0, 632.0]], [[313.0, 512.0], [333.0, 512.0], [333.0, 583.0], [313.0, 583.0]], [[295.0, 512.0], [311.0, 512.0], [311.0, 633.0], [295.0, 633.0]]], "lines": ["オノッティーが", "一番心を", "開いていたのは"]}, {"box": [200, 612, 242, 725], "vertical": true, "font_size": 18, "lines_coords": [[[226.0, 614.0], [242.0, 614.0], [242.0, 725.0], [226.0, 725.0]], [[200.0, 612.0], [220.0, 612.0], [220.0, 712.0], [200.0, 712.0]]], "lines": ["南条さんじゃ", "ないですか。"]}, {"box": [667, 847, 747, 985], "vertical": true, "font_size": 16, "lines_coords": [[[732.0, 848.0], [747.0, 848.0], [747.0, 967.0], [732.0, 967.0]], [[709.0, 849.0], [726.0, 849.0], [726.0, 967.0], [709.0, 967.0]], [[688.0, 848.0], [705.0, 848.0], [705.0, 985.0], [688.0, 985.0]], [[667.0, 847.0], [682.0, 847.0], [682.0, 973.0], [667.0, 973.0]]], "lines": ["くせーですけど", "お二人の間には", "ある種の絆を俺は", "感じてましたよ。"]}, {"box": [372, 1018, 419, 1123], "vertical": true, "font_size": 23, "lines_coords": [[[397.0, 1018.0], [418.0, 1018.0], [419.0, 1123.0], [398.0, 1123.0]], [[372.0, 1018.0], [397.0, 1018.0], [397.0, 1088.0], [372.0, 1088.0]]], "lines": ["結構固めの", "ソレを。"]}], "img_path": "016.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [366, 94, 434, 193], "vertical": true, "font_size": 21, "lines_coords": [[[415.0, 96.0], [432.0, 96.0], [432.0, 173.0], [415.0, 173.0]], [[391.0, 96.0], [411.0, 96.0], [411.0, 193.0], [391.0, 193.0]], [[366.0, 94.0], [392.0, 94.0], [392.0, 146.0], [366.0, 146.0]]], "lines": ["．．．前にも", "聞きました", "けど、"]}, {"box": [82, 144, 150, 278], "vertical": true, "font_size": 18, "lines_coords": [[[130.0, 146.0], [149.0, 146.0], [149.0, 261.0], [130.0, 261.0]], [[107.0, 147.0], [124.0, 147.0], [124.0, 278.0], [107.0, 278.0]], [[82.0, 144.0], [101.0, 144.0], [101.0, 223.0], [82.0, 223.0]]], "lines": ["二人はなんで", "付き合わないん", "ですか？"]}, {"box": [506, 319, 585, 474], "vertical": true, "font_size": 16, "lines_coords": [[[568.0, 319.0], [584.0, 319.0], [584.0, 439.0], [568.0, 439.0]], [[547.0, 321.0], [563.0, 321.0], [563.0, 473.0], [547.0, 473.0]], [[526.0, 321.0], [542.0, 321.0], [542.0, 441.0], [526.0, 441.0]], [[506.0, 319.0], [522.0, 319.0], [522.0, 472.0], [506.0, 472.0]]], "lines": ["．．．固いものほど", "小さなヒビひとつで", "粉々になる事も", "あるっていうね．．．"]}, {"box": [347, 328, 407, 465], "vertical": true, "font_size": 17, "lines_coords": [[[388.0, 328.0], [405.0, 328.0], [405.0, 457.0], [388.0, 457.0]], [[367.0, 328.0], [385.0, 328.0], [384.0, 465.0], [366.0, 465.0]], [[347.0, 330.0], [364.0, 330.0], [364.0, 433.0], [347.0, 433.0]]], "lines": ["今更恋人面して", "イチャつけるかい", "気持ち悪い！！"]}, {"box": [629, 597, 712, 703], "vertical": true, "font_size": 19, "lines_coords": [[[692.0, 598.0], [712.0, 598.0], [712.0, 703.0], [692.0, 703.0]], [[673.0, 600.0], [690.0, 600.0], [690.0, 701.0], [673.0, 701.0]], [[652.0, 600.0], [668.0, 600.0], [668.0, 701.0], [652.0, 701.0]], [[629.0, 597.0], [651.0, 597.0], [651.0, 643.0], [629.0, 643.0]]], "lines": ["．．．南条さんて", "なんだかんだ", "超女の子です", "よね。"]}, {"box": [145, 819, 167, 920], "vertical": true, "font_size": 20, "lines_coords": [[[145.0, 820.0], [165.0, 820.0], [165.0, 917.0], [145.0, 917.0]]], "lines": ["うるさい"]}], "img_path": "017.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [719, 56, 740, 103], "vertical": true, "font_size": 19, "lines_coords": [[[719.0, 56.0], [740.0, 56.0], [740.0, 103.0], [719.0, 103.0]]], "lines": ["．．．ま"]}, {"box": [640, 125, 681, 267], "vertical": true, "font_size": 19, "lines_coords": [[[661.0, 125.0], [681.0, 125.0], [681.0, 258.0], [661.0, 258.0]], [[640.0, 126.0], [657.0, 126.0], [657.0, 267.0], [640.0, 267.0]]], "lines": ["オノッティーは", "帰ってきますよ。"]}, {"box": [685, 505, 731, 584], "vertical": true, "font_size": 20, "lines_coords": [[[706.0, 505.0], [731.0, 505.0], [731.0, 584.0], [706.0, 584.0]], [[685.0, 505.0], [706.0, 505.0], [706.0, 573.0], [685.0, 573.0]]], "lines": ["．．．だから", "ですよ。"]}, {"box": [333, 269, 404, 404], "vertical": true, "font_size": 20, "lines_coords": [[[383.0, 274.0], [402.0, 274.0], [402.0, 404.0], [383.0, 404.0]], [[359.0, 270.0], [380.0, 270.0], [378.0, 369.0], [357.0, 369.0]], [[333.0, 269.0], [353.0, 269.0], [356.0, 394.0], [336.0, 394.0]]], "lines": ["一人でブラブラ", "したい時も", "あるでしょう。"]}, {"box": [124, 307, 188, 416], "vertical": true, "font_size": 21, "lines_coords": [[[162.0, 307.0], [188.0, 307.0], [188.0, 367.0], [162.0, 367.0]], [[144.0, 309.0], [164.0, 309.0], [164.0, 416.0], [144.0, 416.0]], [[124.0, 309.0], [140.0, 309.0], [140.0, 416.0], [124.0, 416.0]]], "lines": ["他人事", "みたいに．．．", "友達でしょ？"]}, {"box": [612, 632, 694, 754], "vertical": true, "font_size": 20, "lines_coords": [[[674.0, 633.0], [694.0, 633.0], [694.0, 721.0], [674.0, 721.0]], [[654.0, 633.0], [671.0, 633.0], [671.0, 754.0], [654.0, 754.0]], [[633.0, 632.0], [651.0, 632.0], [650.0, 754.0], [632.0, 754.0]], [[612.0, 633.0], [632.0, 633.0], [632.0, 711.0], [612.0, 711.0]]], "lines": ["だって俺が", "じたばたしても", "どうにもならん", "でしょう。"]}, {"box": [203, 582, 250, 679], "vertical": true, "font_size": 20, "lines_coords": [[[230.0, 584.0], [250.0, 584.0], [250.0, 679.0], [230.0, 679.0]], [[203.0, 582.0], [230.0, 582.0], [230.0, 636.0], [203.0, 636.0]]], "lines": ["信じてるん", "です。"]}, {"box": [135, 707, 202, 841], "vertical": true, "font_size": 20, "lines_coords": [[[182.0, 707.0], [202.0, 707.0], [202.0, 786.0], [182.0, 786.0]], [[160.0, 708.0], [176.0, 708.0], [176.0, 841.0], [160.0, 841.0]], [[135.0, 708.0], [152.0, 708.0], [154.0, 830.0], [138.0, 830.0]]], "lines": ["というか", "信じてやるしか", "ないでしょう。"]}, {"box": [624, 948, 725, 1105], "vertical": true, "font_size": 18, "lines_coords": [[[707.0, 950.0], [725.0, 950.0], [722.0, 1035.0], [705.0, 1035.0]], [[684.0, 948.0], [704.0, 948.0], [705.0, 1088.0], [685.0, 1088.0]], [[666.0, 951.0], [682.0, 951.0], [682.0, 1087.0], [666.0, 1087.0]], [[645.0, 951.0], [661.0, 951.0], [661.0, 1105.0], [645.0, 1105.0]], [[624.0, 950.0], [640.0, 950.0], [640.0, 1059.0], [624.0, 1059.0]]], "lines": ["．．．仮に奴が", "タイで性転換して", "ムチムチボインに", "なって帰ってきても", "驚きませんね。"]}, {"box": [511, 1018, 575, 1113], "vertical": true, "font_size": 18, "lines_coords": [[[549.0, 1018.0], [575.0, 1018.0], [575.0, 1076.0], [549.0, 1076.0]], [[533.0, 1020.0], [549.0, 1020.0], [549.0, 1106.0], [533.0, 1106.0]], [[511.0, 1020.0], [528.0, 1020.0], [528.0, 1113.0], [511.0, 1113.0]]], "lines": ["それが", "俺と奴との", "関係性です"]}, {"box": [241, 955, 301, 1079], "vertical": true, "font_size": 17, "lines_coords": [[[281.0, 955.0], [301.0, 955.0], [301.0, 1042.0], [281.0, 1042.0]], [[262.0, 956.0], [278.0, 956.0], [278.0, 1060.0], [262.0, 1060.0]], [[241.0, 955.0], [257.0, 955.0], [257.0, 1079.0], [241.0, 1079.0]]], "lines": ["俺は野郎の", "孤高な感じを", "尊敬してるんで、"]}, {"box": [107, 1010, 207, 1149], "vertical": true, "font_size": 17, "lines_coords": [[[190.0, 1012.0], [207.0, 1012.0], [207.0, 1098.0], [190.0, 1098.0]], [[169.0, 1012.0], [186.0, 1012.0], [186.0, 1141.0], [169.0, 1141.0]], [[147.0, 1010.0], [167.0, 1010.0], [166.0, 1149.0], [146.0, 1149.0]], [[127.0, 1012.0], [144.0, 1012.0], [144.0, 1114.0], [127.0, 1114.0]], [[107.0, 1012.0], [123.0, 1012.0], [123.0, 1120.0], [107.0, 1120.0]]], "lines": ["俺は俺だし", "あぃつはあいつ。", "ベタベタするのが", "友達とは限ら", "ないんですよ。"]}], "img_path": "018.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [681, 55, 702, 126], "vertical": true, "font_size": 19, "lines_coords": [[[681.0, 55.0], [702.0, 55.0], [702.0, 126.0], [681.0, 126.0]]], "lines": ["三村ァー"]}, {"box": [660, 93, 677, 150], "vertical": true, "font_size": 19, "lines_coords": [[[660.0, 93.0], [677.0, 93.0], [677.0, 150.0], [660.0, 150.0]]], "lines": ["ーッ！！"]}, {"box": [657, 516, 735, 618], "vertical": true, "font_size": 16, "lines_coords": [[[719.0, 516.0], [735.0, 516.0], [735.0, 617.0], [719.0, 617.0]], [[697.0, 516.0], [713.0, 516.0], [713.0, 602.0], [697.0, 602.0]], [[677.0, 516.0], [693.0, 516.0], [693.0, 618.0], [677.0, 618.0]], [[657.0, 516.0], [673.0, 516.0], [673.0, 608.0], [657.0, 608.0]]], "lines": ["．．．南条さんの", "その心配は", "優しさなんか", "じゃなくて、"]}, {"box": [221, 310, 243, 405], "vertical": true, "font_size": 17, "lines_coords": [[[221.0, 310.0], [241.0, 310.0], [243.0, 405.0], [223.0, 405.0]]], "lines": ["．．．わかった。"]}, {"box": [97, 337, 176, 458], "vertical": true, "font_size": 17, "lines_coords": [[[160.0, 337.0], [176.0, 337.0], [176.0, 450.0], [160.0, 450.0]], [[139.0, 338.0], [155.0, 338.0], [155.0, 458.0], [139.0, 458.0]], [[118.0, 338.0], [134.0, 338.0], [134.0, 457.0], [118.0, 457.0]], [[97.0, 337.0], [114.0, 337.0], [114.0, 392.0], [97.0, 392.0]]], "lines": ["てもあたしは", "じっと待ってる", "訳にはいかない", "から．．．"]}, {"box": [243, 529, 263, 614], "vertical": true, "font_size": 18, "lines_coords": [[[243.0, 529.0], [263.0, 529.0], [263.0, 614.0], [243.0, 614.0]]], "lines": ["．．．てもね。"]}, {"box": [555, 588, 631, 725], "vertical": true, "font_size": 16, "lines_coords": [[[616.0, 588.0], [631.0, 588.0], [631.0, 725.0], [616.0, 725.0]], [[593.0, 588.0], [613.0, 588.0], [613.0, 675.0], [593.0, 675.0]], [[575.0, 588.0], [591.0, 588.0], [591.0, 691.0], [575.0, 691.0]], [[555.0, 589.0], [570.0, 589.0], [570.0, 683.0], [555.0, 683.0]]], "lines": ["自分のフライドを", "守るための", "意地のように", "見えますよ。"]}, {"box": [640, 825, 711, 966], "vertical": true, "font_size": 22, "lines_coords": [[[685.0, 826.0], [711.0, 826.0], [711.0, 888.0], [685.0, 888.0]], [[663.0, 825.0], [684.0, 825.0], [685.0, 959.0], [664.0, 959.0]], [[640.0, 827.0], [660.0, 827.0], [660.0, 962.0], [640.0, 962.0]]], "lines": ["．．．ただ", "オノッティーが", "帰ってきた時は"]}, {"box": [133, 597, 190, 719], "vertical": true, "font_size": 18, "lines_coords": [[[174.0, 600.0], [190.0, 600.0], [190.0, 719.0], [174.0, 719.0]], [[152.0, 597.0], [172.0, 597.0], [169.0, 704.0], [149.0, 704.0]], [[133.0, 598.0], [149.0, 598.0], [149.0, 676.0], [133.0, 676.0]]], "lines": ["今の南条さんは", "それでいいと", "俺は思う。"]}, {"box": [132, 972, 225, 1086], "vertical": true, "font_size": 18, "lines_coords": [[[207.0, 973.0], [223.0, 973.0], [223.0, 1067.0], [207.0, 1067.0]], [[183.0, 973.0], [200.0, 973