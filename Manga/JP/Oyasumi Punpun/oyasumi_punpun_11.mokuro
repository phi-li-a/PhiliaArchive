11.0]], [[4902.0, 403.0], [5063.0, 403.0], [5063.0, 462.0], [4902.0, 462.0]], [[4327.0, 413.0], [4635.0, 413.0], [4635.0, 457.0], [4327.0, 457.0]], [[4322.0, 449.0], [4645.0, 449.0], [4645.0, 507.0], [4322.0, 507.0]], [[4327.0, 499.0], [4680.0, 499.0], [4680.0, 542.0], [4327.0, 542.0]], [[4322.0, 534.0], [4665.0, 534.0], [4665.0, 593.0], [4322.0, 593.0]], [[4856.0, 534.0], [5058.0, 534.0], [5058.0, 593.0], [4856.0, 593.0]], [[4881.0, 580.0], [5063.0, 580.0], [5063.0, 638.0], [4881.0, 638.0]], [[4332.0, 590.0], [4624.0, 590.0], [4624.0, 633.0], [4332.0, 633.0]], [[4332.0, 635.0], [4589.0, 635.0], [4589.0, 678.0], [4332.0, 678.0]], [[4327.0, 670.0], [4645.0, 670.0], [4645.0, 729.0], [4327.0, 729.0]], [[4322.0, 716.0], [4685.0, 706.0], [4685.0, 764.0], [4322.0, 774.0]], [[4332.0, 766.0], [4730.0, 766.0], [4730.0, 809.0], [4332.0, 809.0]], [[4332.0, 811.0], [4720.0, 811.0], [4720.0, 855.0], [4332.0, 855.0]], [[4327.0, 852.0], [4710.0, 852.0], [4710.0, 895.0], [4327.0, 895.0]], [[4332.0, 907.0], [4700.0, 907.0], [4700.0, 935.0], [4332.0, 935.0]], [[4332.0, 942.0], [5053.0, 942.0], [5053.0, 985.0], [4332.0, 985.0]], [[4332.0, 988.0], [4695.0, 988.0], [4695.0, 1031.0], [4332.0, 1031.0]], [[4927.0, 988.0], [5053.0, 988.0], [5053.0, 1031.0], [4927.0, 1031.0]], [[4332.0, 1033.0], [5053.0, 1033.0], [5053.0, 1076.0], [4332.0, 1076.0]], [[4332.0, 1078.0], [4720.0, 1078.0], [4720.0, 1121.0], [4332.0, 1121.0]], [[4327.0, 1113.0], [5063.0, 1113.0], [5063.0, 1172.0], [4327.0, 1172.0]], [[4327.0, 1159.0], [5063.0, 1159.0], [5063.0, 1217.0], [4327.0, 1217.0]], [[4332.0, 1209.0], [4645.0, 1209.0], [4645.0, 1252.0], [4332.0, 1252.0]], [[4937.0, 1209.0], [5053.0, 1209.0], [5053.0, 1257.0], [4937.0, 1257.0]], [[4327.0, 1249.0], [4760.0, 1239.0], [4760.0, 1298.0], [4327.0, 1308.0]], [[4947.0, 1254.0], [5048.0, 1254.0], [5048.0, 1298.0], [4947.0, 1298.0]], [[4433.0, 1290.0], [4927.0, 1285.0], [4927.0, 1343.0], [4433.0, 1348.0]], [[4332.0, 1340.0], [5048.0, 1340.0], [5048.0, 1383.0], [4332.0, 1383.0]], [[4327.0, 1375.0], [4771.0, 1375.0], [4771.0, 1434.0], [4327.0, 1434.0]], [[4891.0, 1390.0], [5048.0, 1390.0], [5048.0, 1419.0], [4891.0, 1419.0]], [[4357.0, 1441.0], [5022.0, 1441.0], [5022.0, 1484.0], [4357.0, 1484.0]], [[4352.0, 1486.0], [5017.0, 1476.0], [5017.0, 1519.0], [4352.0, 1529.0]]], "lines": ["ＹＯＵＲＧ－ＳＵＮＤＡＹＣＯＨＫＣ", "おやすみプンプン", "浅野いんお浅野ぃにお", "ソラニン全２巻ケースで", "おーーー原秀則", "シンーン、エビ。ほしのふるまち、全７巻、ぜ、いっ！！", "高橋留美子", "はい．．．。１ポンドの福音、全４巻", "高橋由美丁山田貴敏官屋番", "「ハンバーの間にログコトー診療所なんですが、", "レ・コトーレポ！！おしゃれ手帖・全１０巻ワードローンの", "２０１８年１１月１４日日曜日に二舎が売り上げ、全国の", "ＦＡＮＥＵＮ－高いアパー鉄腕バーティー全２０巻、新六十五１", "ゆうきまさみ", "つごはとの猪熊しのぶ", "都立水商！全２２巻－", "クロサギ全２０巻", "クロリキ・エイゼイキガミ・ＴｉｐＵｔｍｉｎｄｅｔは生産／エグラムの旧", "イキノミ「Ｍｅｕｍｉｎｅｃ」の土竜（モグラ）の唄・１〜の物無しみなさい。", "超無気力戦隊ジャパファイブ", "Ｑ．．．ｃｏ．．ｎｏｄｉｓオッズ・＋１巻～～", "しかし、さくらんぼンンドロームックとの悪", "タナトスｔｕｒｉｓの挙、全日巻一", "フハハハムルシャーエングとめはねっ！！鈴里高校書道部－うふぇーーーっっ！！１〜１０巻一河合克敏", "ビーチスターズ・全７巻－", "森尾正博", "まったなものが減る道、全日巻一枚は二人、木根ヲサムノ恒川光太郎", "美晴♥ライジング全５巻", "実際のイージス、全日巻モノース・七月鏡ーノ藤原芳秀", "晩のうーん、エロるあんころ。脳器松川丁目は馬鹿だ。いつかあ．．．豚ポクが全５巻――万乗大智", "ＧｏｏｇｌｅＧＯ－ＯＮ－全４巻", "秋重", "ＤＵＤＮＶ生４をドライブアライフ（全Ｃ巻）", "中井那彦", "ファンフィン・エゴ商・ヤングサンテーヨミックススペシャル・ポインテリーのＦａｃｅｂｏｏｋ", "絶望に効くクスリックにＯＮＯにおいて、お子さん、ページ・全ＩＢ巻一山田玲司", "簡単に外人スメリットしていたおしゃれ手術・全５巻一", "長尾謙一郎", "ｈｔｔｐ／／ｃｏｍｉｃｓにｓｈｏｇａｋｕｋａｎ．ｃｏ．ｊｐ／", "にアクセスすると、オンラインショップコミックス情報が詳しくわかり、"]}, {"box": [4356, 1446, 5040, 1556], "vertical": false, "font_size": 39, "lines_coords": [[[4388.0, 1517.0], [4997.0, 1517.0], [4997.0, 1559.0], [4388.0, 1559.0]]], "lines": ["シラインショップご購入することもできます。"]}, {"box": [4414, 1602, 4988, 1911], "vertical": false, "font_size": 40, "lines_coords": [[[4569.0, 1618.0], [4806.0, 1618.0], [4806.0, 1659.0], [4569.0, 1659.0]], [[4478.0, 1673.0], [4897.0, 1673.0], [4897.0, 1715.0], [4478.0, 1715.0]], [[4428.0, 1714.0], [4962.0, 1714.0], [4962.0, 1755.0], [4428.0, 1755.0]], [[4493.0, 1744.0], [4942.0, 1744.0], [4942.0, 1785.0], [4493.0, 1785.0]], [[4438.0, 1774.0], [4942.0, 1774.0], [4942.0, 1815.0], [4438.0, 1815.0]], [[4463.0, 1819.0], [4912.0, 1819.0], [4912.0, 1861.0], [4463.0, 1861.0]], [[4433.0, 1835.0], [4947.0, 1850.0], [4947.0, 1906.0], [4433.0, 1891.0]]], "lines": ["浅野いにお", "「９６０年生まれ、茨城県出身。", "２００１年、第１４６の人２０１７年、１回サンデー、キャギルに「美味城元山つ。ＧＸ新人賞入賞いい＃早１", "「平成年１回リンナーリン新入賞の主な者作に「素晴らしい世界」", "・主な者作に「素晴らしい世界」「ひかりのまち」（どもに小名刊）がある", "しかしそうとしていたのは、「ソラニン「全２巻」小社刊」が、同じ中心。お肌を超えたまま、", "「ソラニン（金２巻かなかが、全国より世代・性別を超えた大量だ。"]}], "img_path": "001.png"}, {"version": "0.2.0-beta.6", "img_width": 3181, "img_height": 2119, "blocks": [{"box": [1509, 40, 1668, 1177], "vertical": true, "font_size": 159, "lines_coords": [[[1509.0, 40.0], [1668.0, 40.0], [1668.0, 1177.0], [1509.0, 1177.0]]], "lines": ["最近、おやすみプンプン●「活動したお"]}, {"box": [57, 1017, 121, 1311], "vertical": true, "font_size": 52, "lines_coords": [[[62.0, 1019.0], [114.0, 1019.0], [114.0, 1298.0], [62.0, 1298.0]]], "lines": ["浅野いにお"]}, {"box": [1217, 1480, 1394, 1643], "vertical": false, "font_size": 179, "lines_coords": [[[1217.0, 1464.0], [1394.0, 1464.0], [1394.0, 1659.0], [1217.0, 1659.0]]], "lines": ["２０１７"]}, {"box": [1231, 1599, 1383, 1642], "vertical": false, "font_size": 37, "lines_coords": [[[1282.0, 1600.0], [1363.0, 1600.0], [1363.0, 1640.0], [1282.0, 1640.0]]], "lines": ["部突破！！"]}, {"box": [910, 1851, 1320, 1904], "vertical": false, "font_size": 53, "lines_coords": [[[910.0, 1851.0], [1320.0, 1851.0], [1320.0, 1904.0], [910.0, 1904.0]]], "lines": ["破"]}, {"box": [1541, 77, 1640, 173], "vertical": false, "font_size": 105, "lines_coords": [[[1541.0, 68.0], [1640.0, 68.0], [1640.0, 182.0], [1541.0, 182.0]]], "lines": ["スピリッツＹロＵＮＥ３ＭＮＤＡＹＯＯＭＩＣＳ"]}, {"box": [1814, 242, 2193, 282], "vertical": false, "font_size": 40, "lines_coords": [[[1814.0, 242.0], [2193.0, 242.0], [2193.0, 282.0], [1814.0, 282.0]]], "lines": ["９７８．８．０９．８／１９／１０９１５１５４３８"]}, {"box": [1812, 490, 2190, 540], "vertical": false, "font_size": 55, "lines_coords": [[[1812.0, 485.0], [2190.0, 485.0], [2190.0, 545.0], [1812.0, 545.0]]], "lines": ["１０月１１日－１００ｋｍｂｕｍｉ－１９２９９７９００５５２８"]}, {"box": [2317, 198, 2516, 233], "vertical": false, "font_size": 35, "lines_coords": [[[2317.0, 198.0], [2516.0, 198.0], [2516.0, 233.0], [2317.0, 233.0]]], "lines": ["Ｃ９９７９＼５５５２Ｅ"]}, {"box": [2318, 96, 2735, 139], "vertical": false, "font_size": 40, "lines_coords": [[[2323.0, 99.0], [2724.0, 99.0], [2724.0, 139.0], [2323.0, 139.0]]], "lines": ["ＳＢＮ９７８－４－０９－－１５１５４３－８"]}, {"box": [2320, 366, 2783, 410], "vertical": false, "font_size": 44, "lines_coords": [[[2320.0, 366.0], [2783.0, 366.0], [2783.0, 410.0], [2320.0, 410.0]]], "lines": ["定価：本体５５０円＋税"]}, {"box": [2311, 444, 2761, 503], "vertical": false, "font_size": 47.0, "lines_coords": [[[2550.0, 444.0], [2761.0, 453.0], [2758.0, 503.0], [2547.0, 494.0]], [[2311.0, 453.0], [2556.0, 453.0], [2556.0, 497.0], [2311.0, 497.0]]], "lines": ["３．小学館", "雑誌，４５：６５－４３"]}, {"box": [1764, 1488, 2252, 1550], "vertical": false, "font_size": 62, "lines_coords": [[[1764.0, 1488.0], [2252.0, 1488.0], [2252.0, 1550.0], [1764.0, 1550.0]]], "lines": ["この瞬間を。"]}, {"box": [1612, 1354, 2882, 1441], "vertical": false, "font_size": 84, "lines_coords": [[[1612.0, 1357.0], [2882.0, 1354.0], [2882.0, 1438.0], [1612.0, 1441.0]]], "lines": ["５「きっと僕は待っていたんだと思"]}, {"box": [2245, 1593, 2838, 1814], "vertical": false, "font_size": 44, "lines_coords": [[[2258.0, 1589.0], [2718.0, 1602.0], [2718.0, 1653.0], [2258.0, 1641.0]], [[2264.0, 1655.0], [2742.0, 1652.0], [2742.0, 1703.0], [2264.0, 1706.0]], [[2245.0, 1714.0], [2708.0, 1717.0], [2708.0, 1768.0], [2245.0, 1765.0]], [[2273.0, 1779.0], [2584.0, 1779.0], [2584.0, 1818.0], [2273.0, 1818.0]]], "lines": ["少年はいま、その手に掴んだ。", "絶望という名の未来をーー", "ありふれた日常は終わり、", "圧倒的現実が胎動する"]}, {"box": [2260, 1899, 2603, 2056], "vertical": false, "font_size": 34, "lines_coords": [[[2270.0, 1901.0], [2450.0, 1901.0], [2450.0, 1938.0], [2270.0, 1938.0]], [[2270.0, 1960.0], [2593.0, 1960.0], [2593.0, 1997.0], [2270.0, 1997.0]], [[2267.0, 2019.0], [2503.0, 2019.0], [2503.0, 2056.0], [2267.0, 2056.0]]], "lines": ["ある街に住む", "少年・ブンブンの悲喜殿", "破滅的新章開幕。"]}], "img_path": "002.png"}, {"version": "0.2.0-beta.6", "img_width": 5168, "img_height": 800, "blocks": [{"box": [46, 523, 534, 667], "vertical": false, "font_size": 158, "lines_coords": [[[46.0, 509.0], [534.0, 509.0], [534.0, 681.0], [46.0, 681.0]]], "lines": ["スピリッツ"]}, {"box": [3229, 276, 3715, 522], "vertical": false, "font_size": 49, "lines_coords": [[[3260.0, 333.0], [3573.0, 333.0], [3573.0, 391.0], [3260.0, 391.0]], [[3235.0, 388.0], [3633.0, 388.0], [3633.0, 446.0], [3235.0, 446.0]], [[3235.0, 453.0], [3603.0, 453.0], [3603.0, 497.0], [3235.0, 497.0]]], "lines": ["絶望という名の未来を", "ｗｅｂエージョンバからありふれた日常は終わり、", "圧倒的現実が胎動する。"]}, {"box": [3250, 563, 3452, 623], "vertical": false, "font_size": 50, "lines_coords": [[[3250.0, 563.0], [3452.0, 573.0], [3452.0, 623.0], [3250.0, 613.0]]], "lines": ["ある街に住む"]}, {"box": [3260, 633, 3558, 744], "vertical": false, "font_size": 50.5, "lines_coords": [[[3265.0, 633.0], [3558.0, 633.0], [3558.0, 684.0], [3265.0, 684.0]], [[3260.0, 694.0], [3492.0, 694.0], [3492.0, 744.0], [3260.0, 744.0]]], "lines": ["少年・プンプンの悲喜", "破滅的新章開幕。"]}], "img_path": "003.png"}, {"version": "0.2.0-beta.6", "img_width": 3165, "img_height": 2120, "blocks": [{"box": [1521, 91, 1624, 193], "vertical": false, "font_size": 14, "lines_coords": [[[1570.0, 121.0], [1607.0, 121.0], [1607.0, 137.0], [1570.0, 137.0]]], "lines": ["ＵＮＧ"]}, {"box": [880, 786, 1287, 835], "vertical": false, "font_size": 34, "lines_coords": [[[880.0, 791.0], [1270.0, 788.0], [1270.0, 822.0], [880.0, 825.0]]], "lines": ["おやすみプンプン"]}, {"box": [1529, 1010, 1600, 1423], "vertical": true, "font_size": 62, "lines_coords": [[[1536.0, 1010.0], [1597.0, 1010.0], [1591.0, 1418.0], [1529.0, 1418.0]]], "lines": ["『浅野いにお"]}], "img_path": "004.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "005.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [70, 1035, 128, 1322], "vertical": true, "font_size": 56, "lines_coords": [[[70.0, 1037.0], [126.0, 1037.0], [126.0, 1322.0], [70.0, 1322.0]]], "lines": ["浅野いにお"]}, {"box": [128, 1995, 287, 2010], "vertical": false, "font_size": 15, "lines_coords": [[[128.0, 1995.0], [287.0, 1995.0], [287.0, 2010.0], [128.0, 2010.0]]], "lines": ["«ＯＵＮＧ．ＳＵＮＣＡＹ"]}], "img_path": "006.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "007.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "008.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [279, 469, 565, 515], "vertical": false, "font_size": 38, "lines_coords": [[[279.0, 478.0], [565.0, 469.0], [565.0, 507.0], [279.0, 515.0]]], "lines": ["第２８条のプロルディング"]}, {"box": [122, 188, 954, 269], "vertical": false, "font_size": 77, "lines_coords": [[[122.0, 192.0], [954.0, 188.0], [954.0, 265.0], [122.0, 269.0]]], "lines": ["『ああ、そうですねぇっはいやいないのよ』"]}, {"box": [128, 277, 1286, 420], "vertical": false, "font_size": 39.0, "lines_coords": [[[128.0, 298.0], [1269.0, 277.0], [1269.0, 314.0], [128.0, 335.0]], [[128.0, 337.0], [1286.0, 316.0], [1286.0, 358.0], [128.0, 378.0]], [[130.0, 383.0], [236.0, 376.0], [238.0, 414.0], [132.0, 420.0]]], "lines": ["ＹｒｐａｒｎｓｔａｌｎｅｒＭａｙＴｕｍｅｒｄわかりましたので、それがバスいたんですよね。やぶんぶっけやですかわいいのでしょうかっ", "これからもどうしようとしているのですから、やってきたのかもしれないと思いましたが、あっ、あっ．．．いや、ちょっとんじゃないんだからねえねえええっえっとねえ２０１８年４月１０日（月）日曜日２月３１日（日）に開催されていますが、", "．．．そんなんだけじゃねー"]}, {"box": [267, 525, 980, 708], "vertical": false, "font_size": 34, "lines_coords": [[[283.0, 524.0], [449.0, 522.0], [449.0, 557.0], [283.0, 559.0]], [[281.0, 560.0], [959.0, 551.0], [959.0, 586.0], [281.0, 595.0]], [[281.0, 622.0], [563.0, 613.0], [563.0, 655.0], [281.0, 663.0]], [[287.0, 669.0], [957.0, 657.0], [957.0, 692.0], [287.0, 704.0]]], "lines": ["［ａＴａｋｅｒｓｔ＇ＪＡｕｂｌ．", "いや．．．んっ、ちょっとやっているのかわかってるんですね。あんまり気になりますからａｍａｎのＭｉｌｕｂｕｓｅｆｒａｒｕ２０１", "ｗｒｕｎｅｌａｍｅ", "２０１４年０３月３０日、ＷｏｒｄＰｒｅｓｔａｌｄａｔｉｏｎやっぱり好きなのか気になったのですが、"]}, {"box": [285, 761, 1284, 884], "vertical": false, "font_size": 31.333333333333332, "lines_coords": [[[285.0, 770.0], [563.0, 761.0], [563.0, 797.0], [285.0, 805.0]], [[287.0, 817.0], [1284.0, 801.0], [1284.0, 830.0], [287.0, 846.0]], [[287.0, 855.0], [580.0, 848.0], [580.0, 877.0], [287.0, 884.0]]], "lines": ["ＴａｍｐｒｉｐｅＴｗｉｎ", "９０ｍｍａｚｏｎｔｉｏｎ（ａｍｐｒｉｃａｒａｓｔｉｎｓ．たとえば「ＷｉｎｄｏｗｓＷｏｒｄＰｒｉｓｔｉｏｎ」のうっ、やはりＳｔｏｒｒｉｐｐｌａｍａｎｄｏｒｋの", "２００２０１３年１０月２５日（月）の"]}, {"box": [287, 904, 1166, 993], "vertical": false, "font_size": 38.5, "lines_coords": [[[287.0, 904.0], [967.0, 904.0], [967.0, 952.0], [287.0, 952.0]], [[292.0, 964.0], [1166.0, 948.0], [1166.0, 977.0], [292.0, 993.0]]], "lines": ["ＷｏｒｄｄｕｂｌＳｗｅｔＰｒｅｔｙＬｏｎｅｂｙ（３００％）", "いやっちゃんも、そういえばやってや！！ｉＰｈｏｎｅＴｅｍｉｎ－ｉｎｇｉｎｆｉｎｉｓｓにありますので、つのうわつではＰｒｏｓｔｙｐｈａｒｍの"]}, {"box": [287, 1193, 378, 1238], "vertical": false, "font_size": 41, "lines_coords": [[[292.0, 1197.0], [368.0, 1197.0], [368.0, 1241.0], [292.0, 1241.0]]], "lines": ["それが"]}, {"box": [294, 1057, 1261, 1138], "vertical": false, "font_size": 32.0, "lines_coords": [[[296.0, 1060.0], [474.0, 1057.0], [474.0, 1088.0], [296.0, 1091.0]], [[294.0, 1105.0], [1261.0, 1091.0], [1261.0, 1124.0], [294.0, 1138.0]]], "lines": ["Ｗｉｎｄｏｗｓ", "２０１８年１２月１８日から３００ｃｍ以上の２０１７年から２００９年に３月１６日に２０１８／１６／１０／００／ＪＡＲＡＮＡＪＡＳＴ"]}, {"box": [298, 1343, 980, 1431], "vertical": false, "font_size": 33, "lines_coords": [[[298.0, 1344.0], [474.0, 1340.0], [474.0, 1381.0], [298.0, 1385.0]], [[304.0, 1394.0], [652.0, 1386.0], [652.0, 1421.0], [304.0, 1429.0]], [[652.0, 1390.0], [969.0, 1384.0], [969.0, 1417.0], [652.0, 1423.0]]], "lines": ["ぴいっとつる", "やっぱり言われてるのですが、ＷｅｂＭａｃｅｂｏｏｋ", "Ｓｔａｂｌａｍｉｎｉｏｎｓｉｎａｎｄ２３１"]}, {"box": [296, 1235, 1267, 1281], "vertical": false, "font_size": 29, "lines_coords": [[[296.0, 1252.0], [1267.0, 1235.0], [1267.0, 1264.0], [296.0, 1281.0]]], "lines": ["２０１７年１２月３０日月２９日日からのおａｎｄｉｏｎの声がきっかけっきりというのはつまり２０１３年１月１９日（日）ですが、"]}, {"box": [157, 1563, 383, 1621], "vertical": false, "font_size": 58, "lines_coords": [[[157.0, 1563.0], [383.0, 1563.0], [383.0, 1621.0], [157.0, 1621.0]]], "lines": ["［ａｎｓｉｊａ！］"]}, {"box": [82, 1939, 171, 1987], "vertical": false, "font_size": 32, "lines_coords": [[[82.0, 1956.0], [165.0, 1939.0], [171.0, 1970.0], [89.0, 1987.0]]], "lines": ["☆"]}, {"box": [139, 1635, 1190, 1981], "vertical": false, "font_size": 67, "lines_coords": [[[509.0, 1644.0], [1157.0, 1629.0], [1160.0, 1711.0], [511.0, 1726.0]], [[161.0, 1656.0], [447.0, 1656.0], [447.0, 1724.0], [161.0, 1724.0]], [[867.0, 1728.0], [1157.0, 1728.0], [1157.0, 1798.0], [867.0, 1798.0]], [[513.0, 1730.0], [812.0, 1735.0], [812.0, 1811.0], [513.0, 1807.0]], [[157.0, 1730.0], [453.0, 1735.0], [453.0, 1819.0], [157.0, 1815.0]], [[867.0, 1813.0], [1162.0, 1817.0], [1162.0, 1881.0], [867.0, 1877.0]], [[515.0, 1822.0], [805.0, 1817.0], [805.0, 1889.0], [515.0, 1894.0]], [[161.0, 1826.0], [455.0, 1826.0], [455.0, 1902.0], [161.0, 1902.0]], [[513.0, 1900.0], [814.0, 1909.0], [812.0, 1985.0], [511.0, 1976.0]], [[163.0, 1923.0], [453.0, 1919.0], [453.0, 1981.0], [163.0, 1985.0]]], "lines": ["ｍａｍｉｒｉｓｅのＷｏｒｄＰｒｉｇの", "ｑａｎａｒｉ１１＠", "ｗｅｂＭ１１２００", "ｗａｂＭ１１６０", "．．．．．．。ａｎａｒｉ１２の", "＠ａｕｓｈｉｌ２１＠", "＠ａｚａｎｉｔ１７．９", "９０１８年１１３０", "．．．ａｎｄｉｔＢｏｏｋ", "＠ａｕａｒｉ１４．０"]}], "img_path": "009.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [199, 0, 366, 234], "vertical": true, "font_size": 38, "lines_coords": [[[248.0, 39.0], [285.0, 45.0], [261.0, 196.0], [223.0, 190.0]]], "lines": ["俺の家！！"]}, {"box": [50, 422, 116, 628], "vertical": true, "font_size": 43, "lines_coords": [[[60.0, 426.0], [103.0, 426.0], [103.0, 480.0], [60.0, 480.0]]], "lines": ["第"]}, {"box": [300, 786, 374, 1033], "vertical": true, "font_size": 33.0, "lines_coords": [[[323.0, 786.0], [360.0, 792.0], [337.0, 966.0], [300.0, 962.0]], [[345.0, 900.0], [374.0, 900.0], [370.0, 1033.0], [341.0, 1033.0]]], "lines": ["お嫁は目が", "病気が"]}, {"box": [178, 1702, 309, 2023], "vertical": true, "font_size": 36, "lines_coords": [[[263.0, 1726.0], [298.0, 1728.0], [285.0, 1999.0], [250.0, 1997.0]], [[219.0, 1759.0], [256.0, 1761.0], [248.0, 1958.0], [211.0, 1956.0]]], "lines": ["おかげＡｐｐｙ！！", "すようにな"]}], "img_path": "010.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "011.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "012.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "013.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "014.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "015.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "016.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [698, 99, 743, 358], "vertical": true, "font_size": 41, "lines_coords": [[[698.0, 99.0], [739.0, 99.0], [743.0, 354.0], [702.0, 354.0]]], "lines": ["チューペット君。"]}, {"box": [1203, 511, 1238, 658], "vertical": true, "font_size": 31, "lines_coords": [[[1203.0, 511.0], [1238.0, 511.0], [1238.0, 658.0], [1203.0, 658.0]]], "lines": ["．．．君にも"]}, {"box": [1102, 763, 1174, 997], "vertical": true, "font_size": 31, "lines_coords": [[[1145.0, 763.0], [1174.0, 763.0], [1174.0, 964.0], [1145.0, 964.0]], [[1102.0, 763.0], [1131.0, 763.0], [1131.0, 997.0], [1102.0, 997.0]]], "lines": ["未来を感じて", "もらえたかい？"]}, {"box": [203, 788, 362, 1060], "vertical": true, "font_size": 33, "lines_coords": [[[325.0, 792.0], [362.0, 792.0], [362.0, 927.0], [325.0, 927.0]], [[283.0, 788.0], [321.0, 788.0], [316.0, 993.0], [279.0, 993.0]], [[246.0, 795.0], [275.0, 795.0], [275.0, 1060.0], [246.0, 1060.0]], [[205.0, 792.0], [234.0, 792.0], [234.0, 1024.0], [205.0, 1024.0]]], "lines": ["．．．これが", "今からたった", "一か月後に起こる", "出来事なのだ．．．"]}, {"box": [1114, 1529, 1267, 1745], "vertical": true, "font_size": 33, "lines_coords": [[[1238.0, 1534.0], [1267.0, 1534.0], [1267.0, 1745.0], [1238.0, 1745.0]], [[1199.0, 1529.0], [1234.0, 1529.0], [1230.0, 1745.0], [1195.0, 1745.0]], [[1153.0, 1534.0], [1189.0, 1534.0], [1189.0, 1687.0], [1153.0, 1687.0]], [[1114.0, 1532.0], [1157.0, 1532.0], [1157.0, 1639.0], [1114.0, 1639.0]]], "lines": ["．．．私が体得した", "「超ひも理論」の", "応用を以て", "しても、"]}, {"box": [969, 1763, 1110, 1946], "vertical": true, "font_size": 33, "lines_coords": [[[1081.0, 1765.0], [1110.0, 1765.0], [1110.0, 1886.0], [1081.0, 1886.0]], [[1046.0, 1765.0], [1075.0, 1765.0], [1075.0, 1915.0], [1046.0, 1915.0]], [[1008.0, 1765.0], [1037.0, 1765.0], [1037.0, 1946.0], [1008.0, 1946.0]], [[969.0, 1763.0], [1004.0, 1763.0], [1004.0, 1896.0], [969.0, 1896.0]]], "lines": ["これより", "先の未来を", "私は聴く事が", "出来ない。"]}, {"box": [308, 1567, 449, 1778], "vertical": true, "font_size": 31, "lines_coords": [[[420.0, 1567.0], [449.0, 1567.0], [449.0, 1720.0], [420.0, 1720.0]], [[383.0, 1567.0], [412.0, 1567.0], [412.0, 1749.0], [383.0, 1749.0]], [[345.0, 1567.0], [374.0, 1567.0], [374.0, 1720.0], [345.0, 1720.0]], [[308.0, 1567.0], [337.0, 1567.0], [337.0, 1778.0], [308.0, 1778.0]]], "lines": ["それが何を", "意味するかは", "容易に想像", "できる訳だが．．．"]}, {"box": [171, 1803, 292, 1970], "vertical": true, "font_size": 31, "lines_coords": [[[256.0, 1807.0], [292.0, 1807.0], [292.0, 1941.0], [256.0, 1941.0]], [[217.0, 1807.0], [246.0, 1807.0], [246.0, 1970.0], [217.0, 1970.0]], [[171.0, 1803.0], [207.0, 1803.0], [207.0, 1950.0], [171.0, 1950.0]]], "lines": ["．．．それは", "さして問題", "ではない。"]}], "img_path": "017.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1155, 124, 1273, 329], "vertical": true, "font_size": 35, "lines_coords": [[[1244.0, 128.0], [1273.0, 128.0], [1273.0, 296.0], [1244.0, 296.0]], [[1199.0, 126.0], [1234.0, 126.0], [1234.0, 265.0], [1199.0, 265.0]], [[1160.0, 124.0], [1195.0, 124.0], [1191.0, 329.0], [1155.0, 329.0]]], "lines": ["それよりも", "至急問題", "なのは．．．．．．"]}, {"box": [1031, 275, 1112, 463], "vertical": true, "font_size": 35, "lines_coords": [[[1066.0, 275.0], [1112.0, 275.0], [1112.0, 370.0], [1066.0, 370.0]], [[1031.0, 283.0], [1060.0, 283.0], [1060.0, 463.0], [1031.0, 463.0]]], "lines": ["そう、", "黒点なのだ。"]}, {"box": [760, 151, 838, 356], "vertical": true, "font_size": 36, "lines_coords": [[[801.0, 153.0], [836.0, 153.0], [836.0, 356.0], [801.0, 356.0]], [[760.0, 151.0], [797.0, 151.0], [797.0, 267.0], [760.0, 267.0]]], "lines": ["たった一つの", "黒点が、"]}, {"box": [277, 128, 385, 370], "vertical": true, "font_size": 32, "lines_coords": [[[350.0, 128.0], [385.0, 128.0], [385.0, 343.0], [350.0, 343.0]], [[314.0, 128.0], [345.0, 128.0], [343.0, 370.0], [312.0, 370.0]], [[277.0, 128.0], [310.0, 128.0], [310.0, 233.0], [277.0, 233.0]]], "lines": ["ぷゅあぴゅあな", "ラヴァーズの祈り", "並びに、"]}, {"box": [126, 339, 267, 534], "vertical": true, "font_size": 32, "lines_coords": [[[238.0, 343.0], [267.0, 343.0], [267.0, 523.0], [238.0, 523.0]], [[194.0, 339.0], [229.0, 339.0], [234.0, 523.0], [198.0, 523.0]], [[165.0, 345.0], [194.0, 345.0], [194.0, 527.0], [165.0, 527.0]], [[126.0, 341.0], [155.0, 341.0], [155.0, 534.0], [126.0, 534.0]]], "lines": ["我らＺ戦士の", "カオティック", "パワーを阻害", "しているのだ。"]}, {"box": [729, 639, 857, 782], "vertical": true, "font_size": 41, "lines_coords": [[[812.0, 639.0], [857.0, 639.0], [857.0, 751.0], [812.0, 751.0]], [[776.0, 643.0], [812.0, 643.0], [812.0, 782.0], [776.0, 782.0]], [[729.0, 641.0], [772.0, 641.0], [772.0, 751.0], [729.0, 751.0]]], "lines": ["だから", "僕は行く", "よ．．．"]}, {"box": [584, 691, 671, 830], "vertical": true, "font_size": 41, "lines_coords": [[[625.0, 691.0], [671.0, 691.0], [671.0, 801.0], [625.0, 801.0]], [[588.0, 691.0], [625.0, 691.0], [621.0, 830.0], [584.0, 830.0]]], "lines": ["時間が", "ない．．．"]}, {"box": [298, 946, 455, 1155], "vertical": true, "font_size": 32, "lines_coords": [[[426.0, 952.0], [455.0, 952.0], [455.0, 1117.0], [426.0, 1117.0]], [[385.0, 952.0], [414.0, 952.0], [414.0, 1117.0], [385.0, 1117.0]], [[341.0, 946.0], [377.0, 946.0], [372.0, 1120.0], [337.0, 1120.0]], [[298.0, 948.0], [333.0, 948.0], [333.0, 1155.0], [298.0, 1155.0]]], "lines": ["近いうちに", "力を貸して", "もら