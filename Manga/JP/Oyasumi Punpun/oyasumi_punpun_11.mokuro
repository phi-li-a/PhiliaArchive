2, 861], "vertical": true, "font_size": 34, "lines_coords": [[[244.0, 691.0], [281.0, 691.0], [281.0, 826.0], [244.0, 826.0]], [[203.0, 689.0], [238.0, 689.0], [238.0, 861.0], [203.0, 861.0]], [[165.0, 720.0], [194.0, 720.0], [194.0, 790.0], [165.0, 790.0]]], "lines": ["いつもの", "女性の方は", "．．．？"]}, {"box": [776, 1787, 812, 1907], "vertical": true, "font_size": 36, "lines_coords": [[[776.0, 1787.0], [812.0, 1787.0], [812.0, 1907.0], [776.0, 1907.0]]], "lines": ["「今日は"]}, {"box": [690, 1783, 813, 2030], "vertical": true, "font_size": 38, "lines_coords": [[[774.0, 1788.0], [812.0, 1788.0], [812.0, 1904.0], [774.0, 1904.0]]], "lines": ["「今日は"]}, {"box": [687, 1788, 721, 2027], "vertical": true, "font_size": 29, "lines_coords": [[[687.0, 1790.0], [716.0, 1790.0], [716.0, 2020.0], [687.0, 2020.0]]], "lines": ["出かけてます。」"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [654, 1000, 858, 1240], "vertical": true, "font_size": 30, "lines_coords": [[[824.0, 1002.0], [853.0, 1002.0], [853.0, 1171.0], [824.0, 1171.0]], [[783.0, 1004.0], [812.0, 1004.0], [812.0, 1169.0], [783.0, 1169.0]], [[741.0, 1004.0], [770.0, 1004.0], [770.0, 1238.0], [741.0, 1238.0]], [[700.0, 1004.0], [729.0, 1004.0], [729.0, 1238.0], [700.0, 1238.0]], [[654.0, 1002.0], [689.0, 1002.0], [689.0, 1217.0], [654.0, 1217.0]]], "lines": ["：そもそも", "馬鹿丁寧に", "荷物を受け取る", "必要は無かった", "かもしれない。"]}, {"box": [435, 1349, 598, 1584], "vertical": true, "font_size": 33, "lines_coords": [[[559.0, 1351.0], [594.0, 1351.0], [594.0, 1583.0], [559.0, 1583.0]], [[519.0, 1349.0], [551.0, 1349.0], [546.0, 1515.0], [515.0, 1515.0]], [[476.0, 1351.0], [511.0, 1351.0], [511.0, 1583.0], [476.0, 1583.0]], [[435.0, 1351.0], [464.0, 1351.0], [464.0, 1496.0], [435.0, 1496.0]]], "lines": ["冷静なつもりが", "思いのほか", "動揺しているの", "だろうか。"]}, {"box": [229, 1346, 313, 1584], "vertical": true, "font_size": 36, "lines_coords": [[[273.0, 1349.0], [308.0, 1349.0], [308.0, 1583.0], [273.0, 1583.0]], [[229.0, 1349.0], [265.0, 1349.0], [265.0, 1527.0], [229.0, 1527.0]]], "lines": ["そうフンフンは", "思いました。"]}], "img_path": "075.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1191, 194, 1259, 434], "vertical": true, "font_size": 32, "lines_coords": [[[1230.0, 194.0], [1259.0, 194.0], [1259.0, 370.0], [1230.0, 370.0]], [[1191.0, 194.0], [1220.0, 194.0], [1220.0, 434.0], [1191.0, 434.0]]], "lines": ["試色の空も、", "古ぼけた建物も、"]}, {"box": [1073, 190, 1149, 573], "vertical": true, "font_size": 32, "lines_coords": [[[1114.0, 190.0], [1149.0, 190.0], [1147.0, 530.0], [1112.0, 530.0]], [[1073.0, 192.0], [1108.0, 192.0], [1108.0, 573.0], [1073.0, 573.0]]], "lines": ["目に映る風景がまるで", "舞台の書き割りのようで、"]}, {"box": [699, 651, 773, 855], "vertical": true, "font_size": 74, "lines_coords": [[[699.0, 651.0], [773.0, 651.0], [773.0, 855.0], [699.0, 855.0]]], "lines": ["もしかしたら部屋に戻れば"]}, {"box": [700, 654, 770, 857], "vertical": true, "font_size": 33, "lines_coords": [[[741.0, 654.0], [770.0, 654.0], [770.0, 852.0], [741.0, 852.0]], [[700.0, 654.0], [729.0, 654.0], [729.0, 857.0], [700.0, 857.0]]], "lines": ["もしかしたら", "部屋に戻れば"]}, {"box": [314, 650, 646, 923], "vertical": true, "font_size": 33, "lines_coords": [[[611.0, 652.0], [646.0, 652.0], [646.0, 852.0], [611.0, 852.0]], [[567.0, 652.0], [602.0, 652.0], [602.0, 823.0], [567.0, 823.0]], [[528.0, 652.0], [559.0, 652.0], [557.0, 886.0], [526.0, 886.0]], [[486.0, 654.0], [515.0, 654.0], [515.0, 888.0], [486.0, 888.0]], [[445.0, 656.0], [474.0, 656.0], [474.0, 857.0], [445.0, 857.0]], [[399.0, 652.0], [435.0, 652.0], [435.0, 923.0], [399.0, 923.0]], [[354.0, 650.0], [395.0, 650.0], [395.0, 892.0], [354.0, 892.0]], [[314.0, 650.0], [350.0, 650.0], [352.0, 873.0], [316.0, 873.0]]], "lines": ["売り出し中の", "若手芸人が", "ドッキリ番組の", "仕掛け人として", "部屋の陰から", "満面のニヤけ面で", "飛び出してくる", "かもしれない。"]}, {"box": [830, 1752, 909, 2003], "vertical": true, "font_size": 35, "lines_coords": [[[872.0, 1755.0], [907.0, 1755.0], [907.0, 1956.0], [872.0, 1956.0]], [[830.0, 1755.0], [865.0, 1755.0], [865.0, 1999.0], [830.0, 1999.0]]], "lines": ["そしたら僕は", "言ってやるんだ。"]}, {"box": [577, 1751, 748, 2071], "vertical": true, "font_size": 36, "lines_coords": [[[708.0, 1753.0], [745.0, 1753.0], [745.0, 1931.0], [708.0, 1931.0]], [[673.0, 1757.0], [702.0, 1757.0], [702.0, 2022.0], [673.0, 2022.0]], [[627.0, 1755.0], [664.0, 1755.0], [662.0, 2057.0], [625.0, 2057.0]], [[584.0, 1751.0], [625.0, 1751.0], [619.0, 2070.0], [577.0, 2070.0]]], "lines": ["「もォ～～～", "ちょっとちょ、と", "マジでカンベンして", "くださいよォ～～～笑"]}, {"box": [475, 1761, 510, 1839], "vertical": true, "font_size": 35, "lines_coords": [[[475.0, 1761.0], [510.0, 1761.0], [510.0, 1839.0], [475.0, 1839.0]]], "lines": ["って。"]}], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "077.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [449, 97, 555, 377], "vertical": true, "font_size": 36, "lines_coords": [[[513.0, 97.0], [551.0, 97.0], [555.0, 291.0], [517.0, 291.0]], [[449.0, 101.0], [484.0, 101.0], [486.0, 374.0], [451.0, 374.0]]], "lines": ["「．．．やめなよ", "もう死んでるよ。」"]}, {"box": [797, 538, 834, 679], "vertical": true, "font_size": 37, "lines_coords": [[[797.0, 538.0], [834.0, 538.0], [834.0, 676.0], [797.0, 676.0]]], "lines": ["荷物．．．"]}, {"box": [182, 674, 225, 838], "vertical": true, "font_size": 43, "lines_coords": [[[182.0, 676.0], [225.0, 676.0], [225.0, 838.0], [182.0, 838.0]]], "lines": ["．．．．．．何？"]}, {"box": [673, 1411, 716, 1569], "vertical": true, "font_size": 43, "lines_coords": [[[673.0, 1411.0], [716.0, 1411.0], [716.0, 1567.0], [673.0, 1567.0]]], "lines": ["「バイブ。」"]}], "img_path": "078.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1267, 159, 1313, 300], "vertical": true, "font_size": 51, "lines_coords": [[[1267.0, 159.0], [1313.0, 159.0], [1313.0, 300.0], [1267.0, 300.0]]], "lines": ["ふっ．．．"]}, {"box": [1186, 360, 12