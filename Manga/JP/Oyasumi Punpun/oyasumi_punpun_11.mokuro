eight": 2120, "blocks": [{"box": [1151, 80, 1292, 389], "vertical": true, "font_size": 32, "lines_coords": [[[1257.0, 80.0], [1292.0, 80.0], [1292.0, 298.0], [1257.0, 298.0]], [[1220.0, 80.0], [1255.0, 80.0], [1255.0, 389.0], [1220.0, 389.0]], [[1184.0, 80.0], [1213.0, 80.0], [1213.0, 296.0], [1184.0, 296.0]], [[1151.0, 82.0], [1178.0, 82.0], [1178.0, 302.0], [1151.0, 302.0]]], "lines": ["我々魔法戦士が", "アカシックレコードの", "不協和音を安定", "させるためには、"]}, {"box": [435, 130, 555, 366], "vertical": true, "font_size": 35, "lines_coords": [[[519.0, 130.0], [555.0, 130.0], [555.0, 300.0], [519.0, 300.0]], [[476.0, 130.0], [511.0, 130.0], [511.0, 366.0], [476.0, 366.0]], [[435.0, 130.0], [470.0, 130.0], [470.0, 271.0], [435.0, 271.0]]], "lines": ["僕は君達に", "未来を与えたい", "のだ．．．．．"]}, {"box": [1218, 904, 1294, 1074], "vertical": true, "font_size": 37, "lines_coords": [[[1257.0, 904.0], [1294.0, 904.0], [1294.0, 1010.0], [1257.0, 1010.0]], [[1218.0, 904.0], [1253.0, 904.0], [1253.0, 1074.0], [1218.0, 1074.0]]], "lines": ["君達は", "出来るッ．．．"]}, {"box": [849, 509, 996, 784], "vertical": true, "font_size": 32, "lines_coords": [[[959.0, 511.0], [996.0, 511.0], [996.0, 635.0], [959.0, 635.0]], [[921.0, 509.0], [957.0, 509.0], [957.0, 755.0], [921.0, 755.0]], [[888.0, 511.0], [915.0, 511.0], [915.0, 784.0], [888.0, 784.0]], [[849.0, 509.0], [878.0, 509.0], [880.0, 737.0], [851.0, 737.0]]], "lines": ["これ以上", "純真なる乳の川に", "黒い染みを打たせる", "訳にはいかない。"]}, {"box": [153, 536, 312, 772], "vertical": true, "font_size": 31, "lines_coords": [[[279.0, 536.0], [308.0, 536.0], [308.0, 705.0], [279.0, 705.0]], [[234.0, 536.0], [269.0, 536.0], [265.0, 705.0], [229.0, 705.0]], [[194.0, 540.0], [223.0, 540.0], [223.0, 737.0], [194.0, 737.0]], [[153.0, 538.0], [182.0, 538.0], [182.0, 772.0], [153.0, 772.0]]], "lines": ["．．．なぜなら", "僕は君達を", "圧倒的に信頼", "しているから！！"]}, {"box": [403, 904, 519, 1140], "vertical": true, "font_size": 33, "lines_coords": [[[490.0, 906.0], [519.0, 906.0], [519.0, 1105.0], [490.0, 1105.0]], [[445.0, 904.0], [476.0, 904.0], [478.0, 1140.0], [447.0, 1140.0]], [[403.0, 906.0], [439.0, 906.0], [439.0, 1080.0], [403.0, 1080.0]]], "lines": ["人種も言語も", "あらゆる垣根を", "飛び越えて、"]}, {"box": [1008, 991, 1172, 1229], "vertical": true, "font_size": 37, "lines_coords": [[[1128.0, 993.0], [1172.0, 993.0], [1172.0, 1134.0], [1128.0, 1134.0]], [[1091.0, 993.0], [1126.0, 993.0], [1126.0, 1165.0], [1091.0, 1165.0]], [[1048.0, 991.0], [1083.0, 991.0], [1085.0, 1229.0], [1050.0, 1229.0]], [[1008.0, 995.0], [1044.0, 995.0], [1044.0, 1165.0], [1008.0, 1165.0]]], "lines": ["完全なる", "秩序と調和", "という新世界の", "創造を．．．．．．"]}, {"box": [1135, 1349, 1257, 1672], "vertical": true, "font_size": 31, "lines_coords": [[[1224.0, 1351.0], [1253.0, 1351.0], [1253.0, 1614.0], [1224.0, 1614.0]], [[1178.0, 1349.0], [1209.0, 1349.0], [1211.0, 1581.0], [1180.0, 1581.0]], [[1135.0, 1349.0], [1168.0, 1349.0], [1172.0, 1672.0], [1139.0, 1672.0]]], "lines": ["僕は全人類共通の", "接拶としてこの", "言葉を提案している。"]}, {"box": [165, 993, 331, 1285], "vertical": true, "font_size": 33, "lines_coords": [[[302.0, 1002.0], [331.0, 1002.0], [331.0, 1198.0], [302.0, 1198.0]], [[258.0, 1002.0], [287.0, 1002.0], [287.0, 1165.0], [258.0, 1165.0]], [[213.0, 997.0], [248.0, 997.0], [248.0, 1169.0], [213.0, 1169.0]], [[165.0, 993.0], [207.0, 993.0], [213.0, 1285.0], [171.0, 1285.0]]], "lines": ["全ての喜びを", "魂の振動で", "共有し合う", "新たなステージへ。"]}, {"box": [271, 1658, 370, 1979], "vertical": true, "font_size": 45, "lines_coords": [[[321.0, 1658.0], [370.0, 1658.0], [370.0, 1960.0], [321.0, 1960.0]], [[271.0, 1664.0], [312.0, 1664.0], [312.0, 1973.0], [271.0, 1973.0]]], "lines": ["「グッドヴァイブ", "レーション」とね。"]}], "img_path": "098.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1139, 103, 1261, 345], "vertical": true, "font_size": 35, "lines_coords": [[[1226.0, 107.0], [1261.0, 107.0], [1261.0, 279.0], [1226.0, 279.0]], [[1182.0, 105.0], [1218.0, 105.0], [1218.0, 244.0], [1182.0, 244.0]], [[1141.0, 103.0], [1176.0, 103.0], [1174.0, 345.0], [1139.0, 345.0]]], "lines": ["．．．お金でも", "なんでも", "あげますから．．"]}, {"box": [192, 360, 281, 536], "vertical": true, "font_size": 48, "lines_coords": [[[229.0, 362.0], [281.0, 362.0], [281.0, 476.0], [229.0, 476.0]], [[192.0, 360.0], [236.0, 360.0], [240.0, 536.0], [196.0, 536.0]]], "lines": ["お願い", "帰って．．．"]}, {"box": [1189, 687, 1224, 859], "vertical": true, "font_size": 36, "lines_coords": [[[1189.0, 687.0], [1224.0, 687.0], [1224.0, 859.0], [1189.0, 859.0]]], "lines": ["あなたも．．．"]}, {"box": [1041, 884, 1160, 1088], "vertical": true, "font_size": 36, "lines_coords": [[[1124.0, 886.0], [1160.0, 886.0], [1160.0, 1055.0], [1124.0, 1055.0]], [[1083.0, 886.0], [1118.0, 886.0], [1118.0, 1055.0], [1083.0, 1055.0]], [[1041.0, 884.0], [1077.0, 884.0], [1077.0, 1088.0], [1041.0, 1088.0]]], "lines": ["人としての", "良心がある", "でしょう．．．？"]}, {"box": [209, 1320, 325, 1524], "vertical": true, "font_size": 31, "lines_coords": [[[294.0, 1325.0], [323.0, 1325.0], [323.0, 1490.0], [294.0, 1490.0]], [[248.0, 1320.0], [283.0, 1320.0], [279.0, 1461.0], [244.0, 1461.0]], [[209.0, 1322.0], [238.0, 1322.0], [238.0, 1519.0], [209.0, 1519.0]]], "lines": ["娘だけには", "絶対手を", "出さないで："]}], "img_path": "099.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1079, 227, 1203, 449], "vertical": true, "font_size": 54, "lines_coords": [[[1145.0, 231.0], [1203.0, 231.0], [1203.0, 401.0], [1145.0, 401.0]], [[1083.0, 227.0], [1133.0, 227.0], [1128.0, 449.0], [1079.0, 449.0]]], "lines": ["ちがう", "ちがう！！"]}, {"box": [399, 826, 441, 1062], "vertical": true, "font_size": 48, "lines_coords": [[[399.0, 826.0], [441.0, 826.0], [441.0, 1062.0], [399.0, 1062.0]]], "lines": ["そうじゃ！！"]}, {"box": [234, 1119, 351, 1333], "vertical": true, "font_size": 117, "lines_coords": [[[234.0, 1119.0], [351.0, 1119.0], [351.0, 1333.0], [234.0, 1333.0]]], "lines": ["そうじゃない！！"]}, {"box": [234, 1122, 352, 1333], "vertical": true, "font_size": 48, "lines_coords": [[[296.0, 1124.0], [345.0, 1122.0], [352.0, 1