], [350.0, 343.0]], [[308.0, 97.0], [343.0, 97.0], [343.0, 225.0], [308.0, 225.0]]], "lines": ["．．．．．で？", "どこで知り合った", "方なの？"]}, {"box": [151, 279, 290, 492], "vertical": true, "font_size": 31, "lines_coords": [[[261.0, 281.0], [290.0, 281.0], [290.0, 492.0], [261.0, 492.0]], [[223.0, 281.0], [252.0, 281.0], [252.0, 405.0], [223.0, 405.0]], [[184.0, 279.0], [213.0, 279.0], [217.0, 463.0], [188.0, 463.0]], [[151.0, 281.0], [180.0, 281.0], [180.0, 492.0], [151.0, 492.0]]], "lines": ["誰に会ったのか", "毎日報告", "しなさいって", "言ったわよね？"]}, {"box": [1110, 881, 1215, 1128], "vertical": true, "font_size": 34, "lines_coords": [[[1180.0, 881.0], [1215.0, 881.0], [1215.0, 1010.0], [1180.0, 1010.0]], [[1141.0, 881.0], [1176.0, 881.0], [1178.0, 1128.0], [1143.0, 1128.0]], [[1110.0, 884.0], [1139.0, 884.0], [1139.0, 1035.0], [1110.0, 1035.0]]], "lines": ["．．．昔から", "知り合いだったん", "だけど．．．"]}, {"box": [936, 1086, 1044, 1240], "vertical": true, "font_size": 34, "lines_coords": [[[1008.0, 1086.0], [1044.0, 1086.0], [1044.0, 1213.0], [1008.0, 1213.0]], [[971.0, 1086.0], [1008.0, 1086.0], [1008.0, 1211.0], [971.0, 1211.0]], [[936.0, 1086.0], [971.0, 1086.0], [971.0, 1240.0], [936.0, 1240.0]]], "lines": ["教習所で", "ばったり", "会って．．．"]}, {"box": [1182, 1428, 1290, 1618], "vertical": true, "font_size": 30, "lines_coords": [[[1253.0, 1428.0], [1290.0, 1428.0], [1290.0, 1529.0], [1253.0, 1529.0]], [[1222.0, 1432.0], [1244.0, 1432.0], [1244.0, 1579.0], [1222.0, 1579.0]], [[1182.0, 1430.0], [1211.0, 1430.0], [1211.0, 1618.0], [1182.0, 1618.0]]], "lines": ["：馬鹿、", "そんな偶然", "信じないわよ。"]}, {"box": [594, 1471, 735, 1656], "vertical": true, "font_size": 32, "lines_coords": [[[700.0, 1471.0], [735.0, 1471.0], [735.0, 1596.0], [700.0, 1596.0]], [[660.0, 1471.0], [696.0, 1471.0], [700.0, 1631.0], [664.0, 1631.0]], [[631.0, 1474.0], [660.0, 1474.0], [660.0, 1656.0], [631.0, 1656.0]], [[594.0, 1476.0], [623.0, 1476.0], [623.0, 1606.0], [594.0, 1606.0]]], "lines": ["嘘なんか", "つかないで", "ちゃんと説明", "しなさい"]}, {"box": [1019, 1674, 1200,