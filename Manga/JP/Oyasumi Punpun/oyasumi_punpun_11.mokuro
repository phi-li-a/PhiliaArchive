, 476.0], [310.0, 645.0], [267.0, 645.0]], [[229.0, 476.0], [265.0, 476.0], [269.0, 660.0], [234.0, 660.0]]], "lines": ["富士山て", "モンブラン", "みたいだよ。"]}, {"box": [1184, 1016, 1224, 1221], "vertical": true, "font_size": 36, "lines_coords": [[[1184.0, 1016.0], [1220.0, 1016.0], [1220.0, 1221.0], [1184.0, 1221.0]]], "lines": ["．．．プンプン？"]}, {"box": [277, 1778, 399, 1981], "vertical": true, "font_size": 39, "lines_coords": [[[364.0, 1780.0], [399.0, 1780.0], [399.0, 1950.0], [364.0, 1950.0]], [[316.0, 1778.0], [362.0, 1778.0], [362.0, 1886.0], [316.0, 1886.0]], [[277.0, 1778.0], [314.0, 1778.0], [316.0, 1981.0], [279.0, 1981.0]]], "lines": ["さっきから", "なんで", "笑ってるの？"]}], "img_path": "202.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1085, 235, 1165, 511], "vertical": true, "font_size": 36, "lines_coords": [[[1128.0, 236.0], [1164.0, 236.0], [1164.0, 465.0], [1128.0, 465.0]], [[1085.0, 240.0], [1120.0, 240.0], [1120.0, 511.0], [1085.0, 511.0]]], "lines": ["「そういう事か。", "って感じですよ。」"]}, {"box": [809, 140, 855, 231], "vertical": true, "font_size": 46, "lines_coords": [[[809.0, 140.0], [855.0, 140.0], [855.0, 231.0], [809.0, 231.0]]], "lines": ["え？"]}, {"box": [211, 250, 263, 378], "vertical": true, "font_size": 52, "lines_coords": [[[211.0, 250.0], [263.0, 250.0], [263.0, 378.0], [211.0, 378.0]]], "lines": ["何が？"]}, {"box": [552, 514, 630, 668], "vertical": true, "font_size": 35, "lines_coords": [[[594.0, 515.0], [629.0, 515.0], [629.0, 668.0], [594.0, 668.0]]], "lines": ["「僕は結局"]}, {"box": [412, 509, 630, 681], "vertical": true, "font_size": 44, "lines_coords": [[[548.0, 511.0], [592.0, 511.0], [592.0, 639.0], [548.0, 639.0]]], "lines": ["僕だよ。"]}, {"box": [410, 513, 446, 687], "vertical": true, "font_size": 35, "lines_coords": [[[410.0, 517.0], [445.0, 517.0], [445.0, 685.0], [410.0, 685.0]]], "lines": ["今も昔も。」"]}, {"box": [308, 1387, 432, 1590], "vertical": true, "font_size": 34, "lines_coords": [[[395.0, 1387.0], [430.0, 1387.0], [430.0, 1590.0], [395.0, 1590.0]], [[356.0, 1391.0], [385.0, 1391.0], [385.0, 1590.0], [356.0, 1590.0]], [[312.0, 1389.0], [350.0, 1389.0], [345.0, 1538.0], [308.0, 1538.0]]], "lines": ["何言ってるか", "わかんねーよ", "バーカ。"]}], "img_path": "203.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [45, 411, 118, 633], "vertical": true, "font_size": 73, "lines_coords": [[[45.0, 411.0], [118.0, 411.0], [118.0, 633.0], [45.0, 633.0]]], "lines": ["第１２１話"]}], "img_path": "204.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1106, 606, 1149, 811], "vertical": true, "font_size": 43, "lines_coords": [[[1106.0, 606.0], [1149.0, 606.0], [1149.0, 811.0], [1106.0, 811.0]]], "lines": ["プンプン！！"]}, {"box": [238, 1169, 321, 1374], "vertical": true, "font_size": 40, "lines_coords": [[[271.0, 1169.0], [321.0, 1169.0], [321.0, 1250.0], [271.0, 1250.0]], [[240.0, 1175.0], [269.0, 1175.0], [269.0, 1372.0], [240.0, 1372.0]]], "lines": ["これ", "おいしいよ！！"]}, {"box": [1067, 1644, 1127, 1699], "vertical": false, "font_size": 49, "lines_coords": [[[1073.0, 1650.0], [1124.0, 1650.0], [1124.0, 1699.0], [1073.0, 1699.0]]], "lines": ["笑"]}], "img_path": "205.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [705, 33, 784, 265], "vertical": true, "font_size": 29, "lines_coords": [[[747.0, 35.0], [776.0, 35.0], [776.0, 256.0], [747.0, 256.0]], [[706.0, 33.0], [735.0, 33.0], [735.0, 190.0], [706.0, 190.0]]], "lines": ["一．．．愛子ちゃん", "お腹は？」"]}, {"box": [548, 614, 592, 739], "vertical": true, "font_size": 46, "lines_coords": [[[548.0, 614.0], [592.0, 614.0], [592.0, 739.0], [548.0, 739.0]]], "lines": ["うん！"]}, {"box": [360, 747, 459, 913], "vertical": true, "font_size": 46, "lines_coords": [[[401.0, 747.0], [459.0, 747.0], [459.0, 844.0], [401.0, 844.0]], [[360.0, 751.0], [397.0, 751.0], [397.0, 913.0], [360.0, 913.0]]], "lines": ["お腹", "すいた！！"]}, {"box": [1128, 1511, 1246, 1813], "vertical": true, "font_size": 31, "lines_coords": [[[1213.0, 1515.0], [1242.0, 1515.0], [1242.0, 1693.0], [1213.0, 1693.0]], [[1168.0, 1511.0], [1203.0, 1511.0], [1203.0, 1747.0], [1168.0, 1747.0]], [[1131.0, 1513.0], [1160.0, 1513.0], [1160.0, 1807.0], [1131.0, 1807.0]]], "lines": ["お腹の傷は", "大丈夫かなって", "聞きたかったんだ。"]}, {"box": [700, 1810, 739, 1989], "vertical": true, "font_size": 35, "lines_coords": [[[700.0, 1811.0], [735.0, 1811.0], [735.0, 1983.0], [700.0, 1983.0]]], "lines": ["フンフンは"]}, {"box": [391, 1813, 470, 1963], "vertical": true, "font_size": 36, "lines_coords": [[[432.0, 1813.0], [470.0, 1813.0], [470.0, 1917.0], [432.0, 1917.0]], [[391.0, 1813.0], [426.0, 1813.0], [426.0, 1960.0], [391.0, 1960.0]]], "lines": ["考えて", "いました。"]}], "img_path": "206.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [791, 1341, 841, 1426], "vertical": true, "font_size": 38, "lines_coords": [[[791.0, 1341.0], [841.0, 1341.0], [841.0, 1426.0], [791.0, 1426.0]]], "lines": ["ただ、"]}, {"box": [802, 1343, 878, 1509], "vertical": true, "font_size": 35, "lines_coords": [[[841.0, 1343.0], [876.0, 1343.0], [876.0, 1509.0], [841.0, 1509.0]]], "lines": ["これからは"]}, {"box": [644, 1341, 722, 1542], "vertical": true, "font_size": 38, "lines_coords": [[[693.0, 1345.0], [722.0, 1345.0], [722.0, 1542.0], [693.0, 1542.0]], [[644.0, 1341.0], [689.0, 1341.0], [689.0, 1457.0], [644.0, 1457.0]]], "lines": ["あるがままに", "感じて、"]}, {"box": [402, 1341, 562, 1511], "vertical": true, "font_size": 33, "lines_coords": [[[526.0, 1341.0], [561.0, 1341.0], [557.0, 1511.0], [522.0, 1511.0]], [[484.0, 1345.0], [513.0, 1345.0], [513.0, 1509.0], [484.0, 1509.0]], [[437.0, 1343.0], [472.0, 1343.0], [472.0, 1511.0], [437.0, 1511.0]]], "lines": ["思うままに", "行動すれば", "いいのかも"]}, {"box": [401, 1343, 430, 1486], "vertical": true, "font_size": 38, "lines_coords": [[[401.0, 1343.0], [430.0, 1343.0], [430.0, 1486.0], [401.0, 1486.0]]], "lines": ["しれない。"]}], "img_path": "207.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1126, 239, 1248, 541], "vertical": true, "font_size": 30, "lines_coords": [[[1213.0, 240.0], [1244.0, 240.0], [1242.0, 472.0], [1211.0, 472.0]], [[1172.0, 240.0], [1201.0, 240.0], [1201.0, 540.0], [1172.0, 540.0]], [[1128.0, 240.0], [1160.0, 240.0], [1157.0, 440.0], [1126.0, 440.0]]], "lines": ["他人から見れば", "とうに終わった人生", "なのだろうが"]}, {"box": [1147, 1469, 1191, 1648], "vertical": true, "font_size": 44, "lines_coords": [[[1147.0, 1469.0], [1191.0, 1469.0], [1191.0, 1647.0], [1147.0, 1647.0]]], "lines": ["おしっこ。"]}, {"box": [327, 1558, 406, 1894], "vertical": true, "font_size": 32, "lines_coords": [[[370.0, 1563.0], [406.0, 1563.0], [406.0, 1730.0], [370.0, 1730.0]], [[329.0, 1558.0], [364.0, 1558.0], [362.0, 1894.0], [327.0, 1894.0]]], "lines": ["もし誰かが", "そう後ろ指を指すなら"]}, {"box": [215, 1558, 285, 1871], "vertical": true, "font_size": 32, "lines_coords": [[[256.0, 1558.0], [285.0, 1558.0], [285.0, 1828.0], [256.0, 1828.0]], [[215.0, 1565.0], [244.0, 1565.0], [244.0, 1871.0], [215.0, 1871.0]]], "lines": ["それがどうしたと", "言い返してやるんだ。"]}], "img_path": "208.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [240, 1198, 1182, 1227], "vertical": false, "font_size": 29, "lines_coords": [[[240.0, 1198.0], [1182.0, 1198.0], [1182.0, 1227.0], [240.0, 1227.0]]], "lines": ["この終わりの向こうがわには、きっと地獄や絶望なんかではなく"]}], "img_path": "209.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [418, 925, 1062, 966], "vertical": false, "font_size": 41, "lines_coords": [[[418.0, 925.0], [1062.0, 925.0], [1062.0, 966.0], [418.0, 966.0]]], "lines": ["この高鳴りが、一瞬のから騒ぎだとしても。"]}], "img_path": "210.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [986, 105, 1333, 730], "vertical": true, "font_size": 297, "lines_coords": [[[986.0, 109.0], [1282.0, 105.0], [1292.0, 726.0], [994.0, 730.0]]], "lines": ["おゃすみプンプンの"]}, {"box": [961, 146, 991, 419], "vertical": true, "font_size": 27, "lines_coords": [[[963.0, 149.0], [990.0, 149.0], [990.0, 411.0], [963.0, 411.0]]], "lines": ["えへへごえの、ぬこえロシャヘロマエスの"]}, {"box": [681, 103, 828, 639], "vertical": true, "font_size": 139, "lines_coords": [[[689.0, 103.0], [828.0, 105.0], [820.0, 639.0], [681.0, 637.0]]], "lines": ["浅野いにお"]}], "img_path": "211.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "212.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "213.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [480, 514, 517, 665], "vertical": true, "font_size": 35, "lines_coords": [[[480.0, 515.0], [515.0, 515.0], [515.0, 664.0], [480.0, 664.0]]], "lines": ["おしっこ。"]}], "img_path": "214.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1176, 1469, 1247, 1621], "vertical": true, "font_size": 35, "lines_coords": [[[1176.0, 1469.0], [1211.0, 1469.0], [1211.0, 1621.0], [1176.0, 1621.0]]], "lines": ["ブンブン"]}, {"box": [357, 1457, 466, 1663], "vertical": true, "font_size": 36, "lines_coords": [[[426.0, 1457.0], [464.0, 1457.0], [464.0, 1643.0], [426.0, 1643.0]], [[358.0, 1459.0], [393.0, 1459.0], [393.0, 1660.0], [358.0, 1660.0]]], "lines": ["「．．．ずいぶん", "遅かったね。」"]}, {"box": [555, 1803, 680, 1979], "vertical": true, "font_size": 40, "lines_coords": [[[644.0, 1809.0], [679.0, 1809.0], [679.0, 1979.0], [644.0, 1979.0]], [[600.0, 1809.0], [635.0, 1809.0], [635.0, 1977.0], [600.0, 1977.0]], [[555.0, 1803.0], [604.0, 1803.0], [604.0, 1867.0], [555.0, 1867.0]]], "lines": ["お腹の包帯", "巻き直して", "た。"]}], "img_path": "215.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1106, 217, 1143, 354], "vertical": true, "font_size": 37, "lines_coords": [[[1106.0, 217.0], [1143.0, 217.0], [1143.0, 351.0], [1106.0, 351.0]]], "lines": ["あと．．．"]}, {"box": [234, 732, 323, 857], "vertical": true, "font_size": 48, "lines_coords": [[[269.0, 732.0], [323.0, 732.0], [323.0, 848.0], [269.0, 848.0]], [[234.0, 734.0], [277.0, 734.0], [277.0, 857.0], [234.0, 857.0]]], "lines": ["生理に", "なった。"]}, {"box": [1162, 1101, 1197, 1238], "vertical": true, "font_size": 35, "lines_coords": [[[1162.0, 1101.0], [1197.0, 1101.0], [1197.0, 1238.0], [1162.0, 1238.0]]], "lines": ["．．．あたし、"]}, {"box": [205, 1180, 354, 1368], "vertical": true, "font_size": 35, "lines_coords": [[[306.0, 1180.0], [354.0, 1180.0], [354.0, 1258.0], [306.0, 1258.0]], [[275.0, 1186.0], [306.0, 1186.0], [308.0, 1339.0], [277.0, 1339.0]], [[242.0, 1188.0], [271.0, 1188.0], [271.0, 1368.0], [242.0, 1368.0]], [[205.0, 1188.0], [238.0, 1188.0], [238.0, 1293.0], [205.0, 1293.0]]], "lines": ["少し", "落ちついて", "考えてみたん", "だけど。"]}, {"box": [1133, 1478, 1276, 1751], "vertical": true, "font_size": 31, "lines_coords": [[[1236.0, 1478.0], [1271.0, 1478.0], [1276.0, 1662.0], [1240.0, 1662.0]], [[1201.0, 1480.0], [1236.0, 1480.0], [1238.0, 1751.0], [1203.0, 1751.0]], [[1166.0, 1480.0], [1201.0, 1480.0], [1201.0, 1695.0], [1166.0, 1695.0]], [[1133.0, 1482.0], [1162.0, 1482.0], [1162.0, 1608.0], [1133.0, 1608.0]]], "lines": ["仮に鹿児島の", "住みやすそうな所で", "しばらく暮らす", "としても、"]}, {"box": [938, 1714, 1118, 1896], "vertical": true, "font_size": 31, "lines_coords": [[[1087.0, 1714.0], [1118.0, 1714.0], [1118.0, 1807.0], [1087.0, 1807.0]], [[1054.0, 1718.0], [1077.0, 1718.0], [1077.0, 1863.0], [1054.0, 1863.0]], [[1015.0, 1716.0], [1044.0, 1716.0], [1044.0, 1865.0], [1015.0, 1865.0]], [[977.0, 1716.0], [1006.0, 1716.0], [1006.0, 1865.0], [977.0, 1865.0]], [[940.0, 1714.0], [969.0, 1714.0], [967.0, 1896.0], [938.0, 1896.0]]], "lines": ["部屋を", "借りる時の", "保証人とか", "住民票とか", "どうするの？"]}, {"box": [339, 1544, 486, 1761], "vertical": true, "font_size": 30, "lines_coords": [[[445.0, 1546.0], [480.0, 1546.0], [486.0, 1732.0], [451.0, 1732.0]], [[410.0, 1544.0], [445.0, 1544.0], [449.0, 1761.0], [414.0, 1761.0]], [[379.0, 1550.0], [408.0, 1550.0], [408.0, 1730.0], [379.0, 1730.0]], [[339.0, 1548.0], [374.0, 1548.0], [374.0, 1676.0], [339.0, 1676.0]]], "lines": ["車のナンバー", "プレートだって", "遠い県外じゃ", "怪しいし、"]}, {"box": [153, 1759, 333, 2062], "vertical": true, "font_size": 30, "lines_coords": [[[300.0, 1759.0], [329.0, 1759.0], [333.0, 1999.0], [304.0, 1999.0]], [[267.0, 1761.0], [294.0, 1761.0], [294.0, 2001.0], [267.0, 2001.0]], [[229.0, 1763.0], [256.0, 1763.0], [256.0, 2062.0], [229.0, 2062.0]], [[192.0, 1763.0], [219.0, 1763.0], [219.0, 1970.0], [192.0, 1970.0]], [[153.0, 1759.0], [182.0, 1759.0], [184.0, 1981.0], [155.0, 1981.0]]], "lines": ["変更するにしても", "あの車はもともと", "お母さんのものだから", "必要な書類とか", "揃えられないよ。"]}], "img_path": "216.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1141, 173, 1282, 389], "vertical": true, "font_size": 29, "lines_coords": [[[1249.0, 173.0], [1280.0, 173.0], [1282.0, 366.0], [1251.0, 366.0]], [[1215.0, 175.0], [1244.0, 175.0], [1244.0, 389.0], [1215.0, 389.0]], [[1176.0, 178.0], [1205.0, 178.0], [1205.0, 329.0], [1176.0, 329.0]], [[1141.0, 175.0], [1170.0, 175.0], [1170.0, 308.0], [1141.0, 308.0]]], "lines": ["これからの事、", "もっと現実的に", "考えて計画", "しないと"]}, {"box": [981, 469, 1160, 712], "vertical": true, "font_size": 29, "lines_coords": [[[1131.0, 469.0], [1160.0, 469.0], [1160.0, 681.0], [1131.0, 681.0]], [[1093.0, 472.0], [1122.0, 472.0], [1122.0, 652.0], [1093.0, 652.0]], [[1056.0, 472.0], [1085.0, 472.0], [1085.0, 654.0], [1056.0, 654.0]], [[1019.0, 472.0], [1048.0, 472.0], [1048.0, 712.0], [1019.0, 712.0]], [[981.0, 469.0], [1010.0, 469.0], [1012.0, 633.0], [983.0, 633.0]]], "lines": ["あまり先走って", "行動されると", "君もあたしも", "のちのち後悔する", "事になるし。"]}, {"box": [248, 608, 406, 844], "vertical": true, "font_size": 31, "lines_coords": [[[370.0, 610.0], [406.0, 610.0], [406.0, 745.0], [370.0, 745.0]], [[331.0, 612.0], [360.0, 612.0], [360.0, 844.0], [331.0, 844.0]], [[290.0, 610.0], [319.0, 610.0], [319.0, 842.0], [290.0, 842.0]], [[248.0, 608.0], [277.0, 608.0], [277.0, 819.0], [248.0, 819.0]]], "lines": ["特に君は", "馬鹿なんだから", "ちゃんと考えて", "もらわないと。"]}, {"box": [1199, 1469, 1302, 1693], "vertical": true, "font_size": 28, "lines_coords": [[[1273.0, 1469.0], [1302.0, 1469.0], [1302.0, 1621.0], [1273.0, 1621.0]], [[1234.0, 1469.0], [1263.0, 1469.0], [1263.0, 1681.0], [1234.0, 1681.0]], [[1199.0, 1469.0], [1226.0, 1469.0], [1226.0, 1693.0], [1199.0, 1693.0]]], "lines": ["ちょっと．．．", "あまりあたしを", "苛つかせないで。"]}, {"box": [567, 1080, 727, 1324], "vertical": true, "font_size": 36, "lines_coords": [[[687.0, 1082.0], [725.0, 1082.0], [725.0, 1235.0], [687.0, 1235.0]], [[629.0, 1082.0], [664.0, 1082.0], [664.0, 1219.0], [629.0, 1219.0]], [[567.0, 1082.0], [602.0, 1082.0], [604.0, 1320.0], [569.0, 1320.0]]], "lines": ["「．．．君ほど", "馬鹿では", "ないと思うよ。」"]}, {"box": [857, 1788, 999, 2012], "vertical": true, "font_size": 29, "lines_coords": [[[967.0, 1790.0], [996.0, 1790.0], [996.0, 1941.0], [967.0, 1941.0]], [[932.0, 1788.0], [961.0, 1788.0], [961.0, 1997.0], [932.0, 1997.0]], [[894.0, 1790.0], [923.0, 1790.0], [923.0, 1973.0], [894.0, 1973.0]], [[857.0, 1788.0], [886.0, 1788.0], [886.0, 2012.0], [857.0, 2012.0]]], "lines": ["きまぐれで", "あたしが警察に", "駆け込んだら", "君困るでしょ？"]}, {"box": [621, 1496, 762, 1741], "vertical": true, "font_size": 30, "lines_coords": [[[733.0, 1503.0], [760.0, 1503.0], [760.0, 1679.0], [733.0, 1679.0]], [[696.0, 1503.0], [725.0, 1503.0], [725.0, 1652.0], [696.0, 1652.0]], [[650.0, 1496.0], [685.0, 1496.0], [691.0, 1741.0], [656.0, 1741.0]], [[621.0, 1500.0], [650.0, 1500.0], [650.0, 1660.0], [621.0, 1660.0]]], "lines": ["あたしと君の", "今の関係は", "信頼で成り立って", "るんだから"]}, {"box": [348, 1587, 383, 1722], "vertical": true, "font_size": 29, "lines_coords": [[[348.0, 1587.0], [383.0, 1587.0], [383.0, 1722.0], [348.0, 1722.0]]], "lines": ["わかる？"]}, {"box": [188, 1786, 325, 2010], "vertical": true, "font_size": 29, "lines_coords": [[[298.0, 1786.0], [325.0, 1786.0], [325.0, 1997.0], [298.0, 1997.0]], [[256.0, 1786.0], [285.0, 1786.0], [285.0, 1939.0], [256.0, 1939.0]], [[221.0, 1786.0], [250.0, 1786.0], [250.0, 1964.0], [221.0, 1964.0]], [[188.0, 1788.0], [215.0, 1788.0], [215.0, 2010.0], [188.0, 2010.0]]], "lines": ["君はあたしから", "強い信頼を", "勝ち得なきゃ", "いけないって事。"]}], "img_path": "217.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1111, 194, 1187, 567], "vertical": true, "font_size": 32, "lines_coords": [[[1151.0, 194.0], [1186.0, 194.0], [1184.0, 484.0], [1149.0, 484.0]], [[1112.0, 209.0], [1141.0, 209.0], [1141.0, 565.0], [1112.0, 565.0]]], "lines": ["「．．．だとしたら僕に", "どうしろって言うの？"]}, {"box": [325, 405, 360, 542], "vertical": true, "font_size": 43, "lines_coords": [[[325.0, 405.0], [360.0, 405.0], [360.0, 542.0], [325.0, 542.0]]], "lines": ["じゃあ．．．"]}, {"box": [171, 616, 298, 795], "vertical": true, "font_size": 43, "lines_coords": [[[248.0, 616.0], [298.0, 616.0], [298.0, 701.0], [248.0, 701.0]], [[207.0, 619.0], [258.0, 619.0], [258.0, 734.0], [207.0, 734.0]], [[171.0, 627.0], [207.0, 627.0], [207.0, 795.0], [171.0, 795.0]]], "lines": ["片目", "潰して", "いいかな？"]}, {"box": [1079, 991, 1244, 1228], "vertical": true, "font_size": 33, "lines_coords": [[[1205.0, 991.0], [1242.0, 991.0], [1242.0, 1163.0], [1205.0, 1163.0]], [[1166.0, 995.0], [1195.0, 995.0], [1195.0, 1194.0], [1166.0, 1194.0]], [[1124.0, 993.0], [1153.0, 993.0], [1153.0, 1227.0], [1124.0, 1227.0]], [[1079.0, 991.0], [1116.0, 991.0], [1116.0, 1109.0], [1079.0, 1109.0]]], "lines": ["プンプンは", "あたしだけを", "見てればいいん", "だから。"]}, {"box": [211, 1198, 379, 1399], "vertical": true, "font_size": 35, "lines_coords": [[[335.0, 1198.0], [379.0, 1198.0], [379.0, 1306.0], [335.0, 1306.0]], [[300.0, 1202.0], [329.0, 1202.0], [329.0, 1399.0], [300.0, 1399.0]], [[254.0, 1200.0], [290.0, 1200.0], [290.0, 1368.0], [254.0, 1368.0]], [[211.0, 1200.0], [242.0, 1200.0], [246.0, 1347.0], [215.0, 1347.0]]], "lines": ["むしろ", "片目のほうが", "都合いいと", "思うんだ。"]}], "img_path": "218.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "219.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [373, 987, 418, 1306], "vertical": true, "font_size": 42, "lines_coords": [[[374.0, 999.0], [416.0, 999.0], [416.0, 1298.0], [374.0, 1298.0]]], "lines": ["「．．．そうだね。」"]}], "img_path": "220.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1148, 1763, 1265, 1948], "vertical": true, "font_size": 30, "lines_coords": [[[1218.0, 1763.0], [1255.0, 1763.0], [1255.0, 1948.0], [1218.0, 1948.0]], [[1182.0, 1768.0], [1211.0, 1768.0], [1211.0, 1915.0], [1182.0, 1915.0]], [[1149.0, 1765.0], [1172.0, 1765.0], [1172.0, 1912.0], [1149.0, 1912.0]]], "lines": ["．．．どした蟹江", "豚みたいな", "声出して？"]}, {"box": [816, 1855, 950, 1890], "vertical": false, "font_size": 28, "lines_coords": [[[816.0, 1861.0], [950.0, 1855.0], [950.0, 1883.0], [816.0, 1890.0]]], "lines": ["あんたーパファリン"]}, {"box": [617, 1819, 720, 2013], "vertical": true, "font_size": 28, "lines_coords": [[[689.0, 1821.0], [718.0, 1821.0], [718.0, 1970.0], [689.0, 1970.0]], [[654.0, 1819.0], [683.0, 1819.0], [683.0, 2001.0], [654.0, 2001.0]], [[617.0, 1819.0], [644.0, 1819.0], [644.0, 2012.0], [617.0, 2012.0]]], "lines": ["．．．いつもと", "変わらない？", "えっかそっか。"]}, {"box": [218, 1545, 381, 1992], "vertical": true, "font_size": 28, "lines_coords": [[[348.0, 1548.0], [379.0, 1548.0], [379.0, 1645.0], [348.0, 1645.0]], [[329.0, 1753.0], [358.0, 1753.0], [358.0, 1929.0], [329.0, 1929.0]], [[296.0, 1753.0], [319.0, 1753.0], [319.0, 1908.0], [296.0, 1908.0]], [[254.0, 1753.0], [283.0, 1753.0], [283.0, 1991.0], [254.0, 1991.0]], [[219.0, 1751.0], [248.0, 1751.0], [248.0, 1975.0], [219.0, 1975.0]]], "lines": ["．．．うん", "今は連載用の", "話作ってる。", "来週中に５話とか", "死ねるわマジで。"]}], "img_path": "221.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1205, 200, 1240, 385], "vertical": true, "font_size": 31, "lines_coords": [[[1205.0, 200.0], [1240.0, 200.0], [1240.0, 385.0], [1205.0, 385.0]]], "lines": ["．．．プンプン？"]}, {"box": [1012, 424, 1186, 648], "vertical": true, "font_size": 31, "lines_coords": [[[1157.0, 426.0], [1186.0, 426.0], [1186.0, 623.0], [1157.0, 623.0]], [[1116.0, 424.0], [1151.0, 424.0], [1151.0, 581.0], [1116.0, 581.0]], [[1085.0, 426.0], [1114.0, 426.0], [1114.0, 610.0], [1085.0, 610.0]], [[1048.0, 426.0], [1077.0, 426.0], [1077.0, 606.0], [1048.0, 606.0]], [[1012.0, 426.0], [1041.0, 426.0], [1041.0, 648.0], [1012.0, 648.0]]], "lines": ["この前電話で", "喧嘩っぽく", "なったもんで", "家まで謝りに", "行ったんだけど、"]}, {"box": [1126, 863, 1236, 1060], "vertical": true, "font_size": 35, "lines_coords": [[[1201.0, 863.0], [1236.0, 863.0], [1236.0, 1020.0], [1201.0, 1020.0]], [[1162.0, 863.0], [1197.0, 863.0], [1197.0, 1004.0], [1162.0, 1004.0]], [[1126.0, 863.0], [1162.0, 863.0], [1162.0, 1060.0], [1126.0, 1060.0]]], "lines": ["．．．アタシも", "結局病院", "行かなかった。"]}, {"box": [190, 426, 337, 671], "vertical": true, "font_size": 34, "lines_coords": [[[302.0, 428.0], [337.0, 428.0], [337.0, 554.0], [302.0, 554.0]], [[267.0, 428.0], [302.0, 428.0], [302.0, 645.0], [267.0, 645.0]], [[232.0, 430.0], [261.0, 430.0], [261.0, 670.0], [232.0, 670.0]], [[194.0, 426.0], [229.0, 426.0], [225.0, 594.0], [190.0, 594.0]]], "lines": ["．．．なんか", "あれからずっと", "部屋に戻ってきて", "ないっぽい。"]}, {"box": [350, 900, 453, 1051], "vertical": true, "font_size": 37, "lines_coords": [[[424.0, 902.0], [453.0, 902.0], [453.0, 1051.0], [424.0, 1051.0]], [[379.0, 900.0], [414.0, 900.0], [418.0, 1051.0], [383.0, 1051.0]], [[350.0, 902.0], [379.0, 902.0], [379.0, 1035.0], [350.0, 1035.0]]], "lines": ["多分流れで", "産むんじゃ", "ないかね"]}, {"box": [1228, 1302, 1271, 1409], "vertical": true, "font_size": 33, "lines_coords": [[[1228.0, 1302.0], [1271.0, 1302.0], [1271.0, 1409.0], [1228.0, 1409.0]]], "lines": ["．．．あ？"]}, {"box": [1037, 1364, 1176, 1517], "vertical": true, "font_size": 33, "lines_coords": [[[1147.0, 1364.0], [1176.0, 1364.0], [1176.0, 1484.0], [1147.0, 1484.0]], [[1110.0, 1364.0], [1139.0, 1364.0], [