], [296.0, 563.0], [296.0, 703.0], [236.0, 703.0]]], "lines": ["「田中愛子", "です。」"]}, {"box": [1292, 1111, 1334, 1186], "vertical": true, "font_size": 36, "lines_coords": [[[1292.0, 1111.0], [1334.0, 1111.0], [1334.0, 1186.0], [1292.0, 1186.0]]], "lines": ["はァ"]}, {"box": [1261, 1233, 1290, 1269], "vertical": true, "font_size": 36, "lines_coords": [[[1261.0, 1233.0], [1290.0, 1233.0], [1290.0, 1269.0], [1261.0, 1269.0]]], "lines": ["は"]}, {"box": [517, 1453, 559, 1525], "vertical": true, "font_size": 42, "lines_coords": [[[517.0, 1453.0], [559.0, 1453.0], [559.0, 1525.0], [517.0, 1525.0]]], "lines": ["は．．．"]}, {"box": [472, 1900, 513, 1973], "vertical": true, "font_size": 41, "lines_coords": [[[472.0, 1900.0], [513.0, 1900.0], [513.0, 1973.0], [472.0, 1973.0]]], "lines": ["は．．．"]}, {"box": [203, 1809, 240, 1944], "vertical": true, "font_size": 37, "lines_coords": [[[203.0, 1809.0], [240.0, 1809.0], [240.0, 1944.0], [203.0, 1944.0]]], "lines": ["なんで．．．"]}], "img_path": "147.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [650, 93, 819, 302], "vertical": true, "font_size": 38, "lines_coords": [[[783.0, 97.0], [818.0, 97.0], [818.0, 283.0], [783.0, 283.0]], [[739.0, 95.0], [774.0, 95.0], [774.0, 267.0], [739.0, 267.0]], [[698.0, 95.0], [735.0, 95.0], [731.0, 302.0], [693.0, 302.0]], [[650.0, 93.0], [696.0, 93.0], [696.0, 207.0], [650.0, 207.0]]], "lines": ["「：俺だって", "そんな事は", "わかってるん", "だよ。」"]}, {"box": [1141, 515, 1224, 687], "vertical": true, "font_size": 40, "lines_coords": [[[1178.0, 515.0], [1224.0, 515.0], [1224.0, 627.0], [1178.0, 627.0]], [[1141.0, 517.0], [1176.0, 517.0], [1176.0, 687.0], [1141.0, 687.0]]], "lines": ["なんで", "こんな事に"]}, {"box": [275, 683, 352, 821], "vertical": true, "font_size": 36, "lines_coords": [[[314.0, 683.0], [352.0, 683.0], [352.0, 819.0], [314.0, 819.0]], [[275.0, 685.0], [310.0, 685.0], [310.0, 821.0], [275.0, 821.0]]], "lines": ["なったの", "かな．．．"]}], "img_path": "148.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1164, 140, 1193, 490], "vertical": true, "font_size": 32, "lines_coords": [[[1164.0, 140.0], [1193.0, 140.0], [1193.0, 490.0], [1164.0, 490.0]]], "lines": ["「．．．でもね、愛子ちゃん"]}, {"box": [1050, 136, 1128, 556], "vertical": true, "font_size": 32, "lines_coords": [[[1091.0, 136.0], [1128.0, 136.0], [1124.0, 351.0], [1087.0, 351.0]], [[1050.0, 138.0], [1079.0, 138.0], [1079.0, 556.0], [1050.0, 556.0]]], "lines": ["僕は一つだけ", "思い出した事があるんだ。"]}, {"box": [768, 262, 807, 390], "vertical": true, "font_size": 35, "lines_coords": [[[768.0, 267.0], [803.0, 267.0], [803.0, 380.0], [768.0, 380.0]]], "lines": ["．．．うん"]}, {"box": [1052, 948, 1090, 1079], "vertical": true, "font_size": 37, "lines_coords": [[[1052.0, 950.0], [1089.0, 950.0], [1089.0, 1074.0], [1052.0, 1074.0]]], "lines": ["．．．うん。"]}, {"box": [573, 441, 658, 628], "vertical": true, "font_size": 40, "lines_coords": [[[615.0, 443.0], [658.0, 443.0], [658.0, 569.0], [615.0, 569.0]], [[573.0, 443.0], [611.0, 443.0], [613.0, 621.0], [575.0, 621.0]]], "lines": ["「今さら", "こんな約束"]}, {"box": [296, 440, 424, 688], "vertical": true, "font_size": 36, "lines_coords": [[[385.0, 440.0], [420.0, 440.0], [416.0, 619.0], [381.0, 619.0]], [[339.0, 443.0], [377.0, 443.0], [372.0, 621.0], [335.0, 621.0]], [[296.0, 440.0], [331.0, 440.0], [333.0, 687.0], [298.0, 687.0]]], "lines": ["果たしても", "無意味かも", "しれないけど。」"]}, {"box": [167, 1012, 216, 1635], "vertical": true, "font_size": 42, "lines_coords": [[[167.0, 1014.0], [209.0, 1014.0], [209.0, 1621.0], [167.0, 1621.0]]], "lines": ["「．．．行ってみようか。鹿児島に。」"]}], "img_path": "149.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [735, 10, 801, 49], "vertical": false, "font_size": 17, "lines_coords": [[[735.0, 33.0], [795.0, 10.0], [801.0, 26.0], [741.0, 49.0]]], "lines": ["．．．そうだなんだ"]}, {"box": [743, 28, 807, 91], "vertical": false, "font_size": 19.5, "lines_coords": [[[745.0, 51.0], [797.0, 28.0], [803.0, 43.0], [751.0, 66.0]], [[743.0, 70.0], [797.0, 43.0], [807.0, 64.0], [754.0, 91.0]]], "lines": ["．．．", "しーと、どれかわから"]}, {"box": [256, 221, 345, 366], "vertical": true, "font_size": 42, "lines_coords": [[[302.0, 227.0], [345.0, 227.0], [345.0, 366.0], [302.0, 366.0]], [[256.0, 221.0], [310.0, 221.0], [310.0, 349.0], [256.0, 349.0]]], "lines": ["．．．先日の", "一件で、"]}, {"box": [22, 411, 95, 635], "vertical": true, "font_size": 73, "lines_coords": [[[22.0, 411.0], [95.0, 411.0], [95.0, 635.0], [22.0, 635.0]]], "lines": ["第１１８話"]}, {"box": [1128, 869, 1222, 1010], "vertical": true, "font_size": 44, "lines_coords": [[[1178.0, 869.0], [1222.0, 869.0], [1222.0, 993.0], [1178.0, 993.0]], [[1128.0, 869.0], [1172.0, 869.0], [1172.0, 1010.0], [1128.0, 1010.0]]], "lines": ["気分は", "寝釈迦。"]}, {"box": [188, 438, 312, 625], "vertical": true, "font_size": 42, "lines_coords": [[[267.0, 438.0], [312.0, 440.0], [306.0, 587.0], [261.0, 585.0]], [[227.0, 447.0], [265.0, 447.0], [265.0, 602.0], [227.0, 602.0]], [[188.0, 447.0], [217.0, 447.0], [217.0, 625.0], [188.0, 625.0]]], "lines": ["僕の心は", "８２・５Ｈｚで", "揺れている。"]}, {"box": [312, 999, 455, 1215], "vertical": true, "font_size": 34, "lines_coords": [[[426.0, 999.0], [455.0, 999.0], [455.0, 1153.0], [426.0, 1153.0]], [[385.0, 999.0], [414.0, 999.0], [414.0, 1215.0], [385.0, 1215.0]], [[352.0, 999.0], [381.0, 999.0], [381.0, 1184.0], [352.0, 1184.0]], [[312.0, 999.0], [341.0, 999.0], [341.0, 1122.0], [312.0, 1122.0]]], "lines": ["だが自分が", "ごくありふれた", "凡人なのだと", "したら？"]}, {"box": [267, 1269, 350, 1457], "vertical": true, "font_size": 34, "lines_coords": [[[300.0, 1269.0], [350.0, 1269.0], [350.0, 1349.0], [300.0, 1349.0]], [[267.0, 1273.0], [302.0, 1273.0], [302.0, 1457.0], [267.0, 1457.0]]], "lines": ["僕は", "ひどく辛い。"]}, {"box": [1145, 1683, 1317, 1892], "vertical": true, "font_size": 37, "lines_coords": [[[1282.0, 1689.0], [1317.0, 1689.0], [1317.0, 1859.0], [1282.0, 1859.0]], [[1238.0, 1687.0], [1273.0, 1687.0], [1273.0, 1892.0], [1238.0, 1892.0]],