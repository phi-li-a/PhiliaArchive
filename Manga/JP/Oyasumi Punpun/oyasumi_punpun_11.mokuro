"]}, {"box": [341, 1730, 422, 1879], "vertical": true, "font_size": 40, "lines_coords": [[[379.0, 1730.0], [422.0, 1730.0], [422.0, 1838.0], [379.0, 1838.0]], [[341.0, 1732.0], [377.0, 1732.0], [377.0, 1879.0], [341.0, 1879.0]]], "lines": ["この家", "出てくよ。"]}, {"box": [153, 1842, 271, 2022], "vertical": true, "font_size": 40, "lines_coords": [[[227.0, 1842.0], [271.0, 1842.0], [271.0, 1981.0], [227.0, 1981.0]], [[184.0, 1844.0], [232.0, 1844.0], [232.0, 1950.0], [184.0, 1950.0]], [[153.0, 1846.0], [182.0, 1846.0], [182.0, 2022.0], [153.0, 2022.0]]], "lines": ["この人と", "二人で", "暮らすから。"]}], "img_path": "030.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1201, 1194, 1230, 1360], "vertical": true, "font_size": 35, "lines_coords": [[[1201.0, 1194.0], [1230.0, 1194.0], [1230.0, 1360.0], [1201.0, 1360.0]]], "lines": ["ああそう．．．"]}, {"box": [1035, 1289, 1114, 1457], "vertical": true, "font_size": 35, "lines_coords": [[[1075.0, 1289.0], [1112.0, 1289.0], [1114.0, 1457.0], [1077.0, 1457.0]], [[1035.0, 1289.0], [1073.0, 1289.0], [1073.0, 1424.0], [1035.0, 1424.0]]], "lines": ["いいんじゃ", "ないの？"]}, {"box": [184, 1264, 362, 1488], "vertical": true, "font_size": 29, "lines_coords": [[[329.0, 1264.0], [358.0, 1264.0], [358.0, 1382.0], [329.0, 1382.0]], [[294.0, 1267.0], [323.0, 1267.0], [323.0, 1416.0], [294.0, 1416.0]], [[256.0, 1267.0], [285.0, 1267.0], [285.0, 1447.0], [256.0, 1447.0]], [[219.0, 1267.0], [248.0, 1267.0], [248.0, 1476.0], [219.0, 1476.0]], [[184.0, 1264.0], [213.0, 1264.0], [213.0, 1488.0], [184.0, 1488.0]]], "lines": ["あんたが", "足の自由が", "利かない親を", "放っておける人", "だって言うなら。"]}, {"box": [1166, 1618, 1201, 1753], "vertical": true, "font_size": 36, "lines_coords": [[[1166.0, 1618.0], [1201.0, 1618.0], [1201.0, 1753.0], [1166.0, 1753.0]]], "lines": ["お金は．．"]}, {"box": [1017, 1830, 1135, 2014], "vertical": true, "font_size": 36, "lines_coords": [[[1099.0, 1830.0], [1135.0, 1830.0], [1135.0, 1966.0], [1099.0, 1966.0]], [[1058.0, 1830.0], [