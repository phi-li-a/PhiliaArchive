", "事あるよ。"]}, {"box": [1170, 962, 1251, 1115], "vertical": true, "font_size": 35, "lines_coords": [[[1222.0, 966.0], [1251.0, 966.0], [1251.0, 1115.0], [1222.0, 1115.0]], [[1170.0, 962.0], [1213.0, 962.0], [1213.0, 1072.0], [1170.0, 1072.0]]], "lines": ["．．．そういや", "関くん、"]}, {"box": [768, 668, 878, 855], "vertical": true, "font_size": 36, "lines_coords": [[[841.0, 670.0], [878.0, 670.0], [878.0, 795.0], [841.0, 795.0]], [[803.0, 668.0], [838.0, 668.0], [838.0, 855.0], [803.0, 855.0]], [[768.0, 670.0], [803.0, 670.0], [803.0, 805.0], [768.0, 805.0]]], "lines": ["なんでよ", "俺にくれれば", "いいのに。"]}, {"box": [395, 668, 584, 689], "vertical": false, "font_size": 24, "lines_coords": [[[395.0, 668.0], [584.0, 668.0], [584.0, 689.0], [395.0, 689.0]]], "lines": ["もう大く、遠くすために、下記のような検討"]}, {"box": [339, 737, 584, 892], "vertical": false, "font_size": 24, "lines_coords": [[[389.0, 741.0], [534.0, 737.0], [534.0, 759.0], [389.0, 763.0]], [[408.0, 770.0], [584.0, 770.0], [584.0, 797.0], [408.0, 797.0]], [[410.0, 805.0], [499.0, 805.0], [499.0, 828.0], [410.0, 828.0]], [[339.0, 832.0], [472.0, 832.0], [472.0, 861.0], [339.0, 861.0]], [[412.0, 869.0], [524.0, 869.0], [524.0, 892.0], [412.0, 892.0]]], "lines": ["おはようございます", "こんにちは、ただいま", "行ってきます", "＞＞私なら「ただいま。", "お先に失礼します"]}, {"box": [165, 521, 309, 763], "vertical": true, "font_size": 29, "lines_coords": [[[277.0, 521.0], [306.0, 521.0], [306.0, 734.0], [277.0, 734.0]], [[240.0, 521.0], [269.0, 521.0], [269.0, 763.0], [240.0, 763.0]], [[203.0, 523.0], [232.0, 523.0], [232.0, 705.0], [203.0, 705.0]], [[165.0, 521.0], [194.0, 521.0], [194.0, 716.0], [165.0, 716.0]]], "lines": ["持ち主わかって", "事件になったけど", "あれはマジで", "えげつないわ。"]}, {"box": [1070, 1182, 1180, 1426], "vertical": true, "font_size": 35, "lines_coords": [[[1143.0, 1182.0], [1180.0, 1182.0], [1180.0, 1281.0], [1143.0, 1281.0]], [[1110.0, 1184.0], [1139.0, 1184.0], [1139.0, 1426.0], [1110.0, 1426.0]], [[1070.0, 1182.0], [1106.0, 1182.0], [1106.0, 1318.0], [1070.0, 1318.0]]], "lines": ["社長が", "すっげえ怒ってる", "らしいよ。"]}, {"box": [372, 1209, 482, 1420], "vertical": true, "font_size": 33, "lines_coords": [[[437.0, 1209.0], [482.0, 1209.0], [482.0, 1310.0], [437.0, 1310.0]], [[406.0, 1213.0], [441.0, 1213.0], [441.0, 1420.0], [406.0, 1420.0]], [[372.0, 1213.0], [401.0, 1213.0], [401.0, 1298.0], [372.0, 1298.0]]], "lines": ["彼女に", "ＤＶはまずいっ", "しょー"]}, {"box": [232, 1420, 335, 1658], "vertical": true, "font_size": 33, "lines_coords": [[[306.0, 1420.0], [335.0, 1420.0], [335.0, 1571.0], [306.0, 1571.0]], [[269.0, 1420.0], [298.0, 1420.0], [298.0, 1598.0], [269.0, 1598.0]], [[232.0, 1422.0], [261.0, 1422.0], [261.0, 1658.0], [232.0, 1658.0]]], "lines": ["早く謝りに", "行ったほうが", "いいんじゃない？"]}, {"box": [1189, 1783, 1220, 1886], "vertical": true, "font_size": 31, "lines_coords": [[[1189.0, 1786.0], [1220.0, 1786.0], [1220.0, 1886.0], [1189.0, 1886.0]]], "lines": ["．．．え？"]}, {"box": [209, 1813, 294, 1952], "vertical": true, "font_size": 46, "lines_coords": [[[256.0, 1819.0], [294.0, 1819.0], [294.0, 1952.0], [256.0, 1952.0]], [[209.0, 1813.0], [263.0, 1813.0], [263.0, 1908.0], [209.0, 1908.0]]], "lines": ["なんすか", "ソレ。"]}], "img_path": "157.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1172, 260, 1315, 503], "vertical": true, "font_size": 31, "lines_coords": [[[1280.0, 260.0], [1315.0, 260.0], [1315.0, 476.0], [1280.0, 476.0]], [[1247.0, 265.0], [1276.0, 265.0], [1276.0, 474.0], [1247.0, 474.0]], [[1209.0, 260.0], [1240.0, 260.0], [1238.0, 503.0], [1207.0, 503.0]], [[1172.0, 262.0], [1201.0, 262.0], [1201.0, 397.0], [1172.0, 397.0]]], "lines": ["だから言ったろ", "社長の娘なんか", "手ェ出すもんじゃ", "ないって。"]}, {"box": [1142, 899, 1259, 1101], "vertical": true, "font_size": 34, "lines_coords": [[[1222.0, 900.0], [1259.0, 900.0], [1259.0, 1037.0], [1222.0, 1037.0]], [[1182.0, 900.0], [1218.0, 900.0], [1218.0, 1068.0], [1182.0, 1068.0]], [[1143.0, 900.0], [1172.0, 900.0], [1172.0, 1099.0], [1143.0, 1099.0]]], "lines": ["．．．あれ？", "行かないの", "社長んトコ？"]}, {"box": [737, 550, 882, 739], "vertical": true, "font_size": 34, "lines_coords": [[[847.0, 554.0], [882.0, 554.0], [882.0, 739.0], [847.0, 739.0]], [[809.0, 554.0], [847.0, 554.0], [847.0, 679.0], [809.0, 679.0]], [[770.0, 554.0], [805.0, 554.0], [809.0, 739.0], [774.0, 739.0]], [[737.0, 550.0], [776.0, 550.0], [776.0, 612.0], [737.0, 612.0]]], "lines": ["このままだと", "怖い人達", "呼ばれちゃう", "よー"]}, {"box": [741, 639, 764, 703], "vertical": true, "font_size": 34, "lines_coords": [[[741.0, 639.0], [764.0, 639.0], [764.0, 703.0], [741.0, 703.0]]], "lines": ["ー？"]}, {"box": [213, 1190, 333, 1393], "vertical": true, "font_size": 35, "lines_coords": [[[294.0, 1192.0], [329.0, 1192.0], [329.0, 1393.0], [294.0, 1393.0]], [[254.0, 1192.0], [290.0, 1192.0], [290.0, 1364.0], [254.0, 1364.0]], [[213.0, 1190.0], [248.0, 1190.0], [248.0, 1376.0], [213.0, 1376.0]]], "lines": ["．．．いやなんか", "もうめんど", "くさいんで。"]}, {"box": [1133, 1482, 1273, 1707], "vertical": true, "font_size": 31, "lines_coords": [[[1238.0, 1482.0], [1273.0, 1482.0], [1273.0, 1604.0], [1238.0, 1604.0]], [[1205.0, 1484.0], [1234.0, 1484.0], [1234.0, 1664.0], [1205.0, 1664.0]], [[1166.0, 1482.0], [1197.0, 1482.0], [1199.0, 1693.0], [1168.0, 1693.0]], [[1133.0, 1484.0], [1162.0, 1484.0], [1162.0, 1705.0], [1133.0, 1705.0]]], "lines": ["南の島に", "移住するんで", "勝手にしろって", "伝えてください。"]}, {"box": [633, 1534, 708, 1720], "vertical": true, "font_size": 32, "lines_coords": [[[669.0, 1534.0], [704.0, 1534.0], [704.0, 1672.0], [669.0, 1672.0]], [[633.0, 1538.0], [662.0, 1538.0], [662.0, 1716.0], [633.0, 1716.0]]], "lines": ["それでは", "さようなら。"]}], "img_path": "158.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1052, 89, 1216, 304], "vertical": true, "font_size": 34, "lines_coords": [[[1186.0, 93.0], [1215.0, 93.0], [1215.0, 227.0], [1186.0, 227.0]], [[1141.0, 95.0], [1176.0, 95.0], [1176.0, 300.0], [1141.0, 300.0]], [[1097.0, 101.0], [1133.0, 101.0], [1133.0, 300.0], [1097.0, 300.0]], [[1052.0, 89.0], [1087.0, 89.0], [1091.0, 304.0], [1056.0, 304.0]]], "lines": ["．．．自分が", "廃品回収業を", "一年も続けて", "こられたのは、"]}, {"box": [793, 91, 955, 402], "vertical": true, "font_size": 34, "lines_coords": [[[915.0, 93.0], [952.0, 93.0], [952.0, 265.0], [915.0, 265.0]], [[876.0, 95.0], [911.0, 95.0], [911.0, 364.0], [876.0, 364.0]], [[834.0, 93.0], [870.0, 93.0], [870.0, 399.0], [834.0, 399.0]], [[793.0, 91.0], [822.0, 91.0], [826.0, 312.0], [797.0, 312.0]]], "lines": ["本や雑誌が", "いくらでもタダで", "手に入る環境だった", "からだと思う。"]}, {"box": [449, 1759, 654, 2030], "vertical": true, "font_size": 34, "lines_coords": [[[617.0, 1761.0], [652.0, 1761.0], [652.0, 1896.0], [617.0, 1896.0]], [[580.0, 1761.0], [609.0, 1761.0], [609.0, 1991.0], [580.0, 1991.0]], [[532.0, 1759.0], [573.0, 1759.0], [567.0, 2026.0], [526.0, 2026.0]], [[495.0, 1759.0], [526.0, 1759.0], [524.0, 2026.0], [493.0, 2026.0]], [[451.0, 1759.0], [486.0, 1759.0], [484.0, 2030.0], [449.0, 2030.0]]], "lines": ["暇潰しに", "見知らぬ他人の", "趣味嗜好にまかせ", "本を読み漁った末", "辿り着いた結論は"]}, {"box": [190, 1755, 356, 2061], "vertical": true, "font_size": 38, "lines_coords": [[[312.0, 1755.0], [356.0, 1755.0], [356.0, 1865.0], [312.0, 1865.0]], [[273.0, 1759.0], [310.0, 1759.0], [308.0, 2059.0], [271.0, 2059.0]], [[232.0, 1759.0], [267.0, 1759.0], [267.0, 1962.0], [232.0, 1962.0]], [[190.0, 1759.0], [225.0, 1759.0], [225.0, 1939.0], [190.0, 1939.0]]], "lines": ["何事も", "「人それぞれ」という", "ひどく退屈な", "答えだった。"]}], "img_path": "159.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1184, 153, 1265, 337], "vertical": true, "font_size": 40, "lines_coords": [[[1220.0, 153.0], [1265.0, 153.0], [1265.0, 262.0], [1220.0, 262.0]], [[1184.0, 157.0], [1220.0, 157.0], [1220.0, 335.0], [1184.0, 335.0]]], "lines": ["ホント", "いっその事、"]}, {"box": [517, 178, 674, 416], "vertical": true, "font_size": 30, "lines_coords": [[[644.0, 182.0], [673.0, 182.0], [673.0, 380.0], [644.0, 380.0]], [[598.0, 178.0], [633.0, 178.0], [629.0, 351.0], [594.0, 351.0]], [[561.0, 188.0], [590.0, 188.0], [590.0, 416.0], [561.0, 416.0]], [[517.0, 184.0], [546.0, 184.0], [546.0, 316.0], [517.0, 316.0]]], "lines": ["身も蓋もない", "この結論を", "一歩前進させる", "ためには"]}, {"box": [331, 176, 498, 406], "vertical": true, "font_size": 35, "lines_coords": [[[420.0, 188.0], [455.0, 188.0], [455.0, 351.0], [420.0, 351.0]], [[379.0, 182.0], [414.0, 182.0], [414.0, 318.0], [379.0, 318.0]], [[337.0, 178.0], [372.0, 178.0], [368.0, 391.0], [333.0, 391.0]]], "lines": ["一番面倒な", "自意識が", "再び顔を出す。"]}, {"box": [186, 180, 267, 434], "vertical": true, "font_size": 32, "lines_coords": [[[234.0, 182.0], [263.0, 182.0], [263.0, 351.0], [234.0, 351.0]], [[186.0, 184.0], [221.0, 184.0], [223.0, 428.0], [188.0, 428.0]]], "lines": ["そしてまた", "ふりだしに戻る。"]}, {"box": [979, 768, 1056, 1039], "vertical": true, "font_size": 33, "lines_coords": [[[1021.0, 768.0], [1056.0, 768.0], [1054.0, 1039.0], [1019.0, 1039.0]], [[981.0, 770.0], [1012.0, 770.0], [1010.0, 1004.0], [979.0, 1004.0]]], "lines": ["どっか外国にでも", "行っちまうか？"]}, {"box": [816, 571, 849, 718], "vertical": true, "font_size": 29, "lines_coords": [[[816.0, 571.0], [845.0, 571.0], [845.0, 718.0], [816.0, 718.0]]], "lines": ["．．．なんか、"]}, {"box": [507, 590, 593, 665], "vertical": false, "font_size": 75, "lines_coords": [[[507.0, 590.0], [593.0, 590.0], [593.0, 665.0], [507.0, 665.0]]], "lines": ["の指導で感情験。上空らのダイブまさに神秘"]}, {"box": [639, 997, 879, 1060], "vertical": false, "font_size": 19, "lines_coords": [[[673.0, 1006.0], [849.0, 997.0], [849.0, 1018.0], [673.0, 1026.0]], [[642.0, 1033.0], [874.0, 1016.0], [874.0, 1037.0], [642.0, 1053.0]], [[747.0, 1045.0], [861.0, 1045.0], [861.0, 1060.0], [747.0, 1060.0]]], "lines": ["チ最寄りのホテルか", "の数分のとこるにあるべス", "これまで当たり前提として"]}, {"box": [513, 850, 590, 1022], "vertical": true, "font_size": 30, "lines_coords": [[[563.0, 956.0], [582.0, 956.0], [582.0, 983.0], [563.0, 983.0]], [[553.0, 850.0], [590.0, 850.0], [590.0, 958.0], [553.0, 958.0]], [[513.0, 852.0], [548.0, 852.0], [548.0, 1022.0], [513.0, 1022.0]]], "lines": ["．．．", "すげー", "楽しそう．．．"]}, {"box": [320, 675, 358, 986], "vertical": true, "font_size": 29, "lines_coords": [[[323.0, 676.0], [352.0, 676.0], [352.0, 981.0], [323.0, 981.0]]], "lines": ["．．．なんでもいいから"]}, {"box": [167, 674, 248, 894], "vertical": true, "font_size": 36, "lines_coords": [[[213.0, 676.0], [248.0, 676.0], [248.0, 846.0], [213.0, 846.0]], [[167.0, 676.0], [205.0, 676.0], [207.0, 894.0], [169.0, 894.0]]], "lines": ["早く仕事を", "見つけなきゃ。"]}, {"box": [1157, 1474, 1195, 1641], "vertical": true, "font_size": 35, "lines_coords": [[[1164.0, 1583.0], [1191.0, 1583.0], [1191.0, 1641.0], [1164.0, 1641.0]], [[1157.0, 1474.0], [1195.0, 1474.0], [1195.0, 1596.0], [1157.0, 1596.0]]], "lines": ["ーん", "関さー"]}, {"box": [1044, 1658, 1089, 1861], "vertical": true, "font_size": 35, "lines_coords": [[[1044.0, 1658.0], [1085.0, 1658.0], [1089.0, 1861.0], [1048.0, 1861.0]]], "lines": ["いるんでしょ"]}], "img_path": "160.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [834, 134, 975, 351], "vertical": true, "font_size": 32, "lines_coords": [[[944.0, 134.0], [975.0, 134.0], [973.0, 351.0], [942.0, 351.0]], [[907.0, 138.0], [936.0, 138.0], [936.0, 289.0], [907.0, 289.0]], [[872.0, 134.0], [903.0, 134.0], [899.0, 318.0], [867.0, 318.0]], [[834.0, 138.0], [863.0, 138.0], [863.0, 246.0], [834.0, 246.0]]], "lines": ["社長さんに早く", "詫び入れに", "行ったほうが", "いいよー"]}, {"box": [735, 401, 845, 585], "vertical": true, "font_size": 32, "lines_coords": [[[805.0, 401.0], [845.0, 401.0], [845.0, 501.0], [805.0, 501.0]], [[774.0, 403.0], [803.0, 403.0], [803.0, 585.0], [774.0, 585.0]], [[735.0, 401.0], [770.0, 401.0], [770.0, 513.0], [735.0, 513.0]]], "lines": ["居留守", "使っても無駄", "だから"]}, {"box": [1172, 587, 1259, 662], "vertical": false, "font_size": 44.0, "lines_coords": [[[1184.0, 587.0], [1240.0, 587.0], [1240.0, 629.0], [1184.0, 629.0]], [[1172.0, 616.0], [1259.0, 616.0], [1259.0, 662.0], [1172.0, 662.0]]], "lines": ["６１６", "．．．"]}, {"box": [211, 767, 331, 1003], "vertical": true, "font_size": 33, "lines_coords": [[[294.0, 768.0], [329.0, 768.0], [329.0, 956.0], [294.0, 956.0]], [[254.0, 770.0], [283.0, 770.0], [283.0, 1002.0], [254.0, 1002.0]], [[211.0, 768.0], [246.0, 768.0], [246.0, 819.0], [211.0, 819.0]]], "lines": ["次来た時は", "鍵壊して入るん", "てー"]}, {"box": [1189, 1113, 1232, 1288], "vertical": true, "font_size": 43, "lines_coords": [[[1189.0, 1113.0], [1232.0, 1113.0], [1232.0, 1169.0], [1189.0, 1169.0]]], "lines": ["あー"]}, {"box": [207, 1194, 304, 1362], "vertical": true, "font_size": 44, "lines_coords": [[[258.0, 1198.0], [304.0, 1198.0], [304.0, 1325.0], [258.0, 1325.0]], [[207.0, 1194.0], [250.0, 1194.0], [254.0, 1362.0], [211.0, 1362.0]]], "lines": ["めんど", "くせぇ．．．"]}, {"box": [1203, 1488, 1271, 1755], "vertical": true, "font_size": 34, "lines_coords": [[[1242.0, 1488.0], [1271.0, 1488.0], [1271.0, 1755.0], [1242.0, 1755.0]], [[1203.0, 1492.0], [1232.0, 1492.0], [1232.0, 1734.0], [1203.0, 1734.0]]], "lines": ["どいつもこいづも", "大袈裟なんだよ。"]}, {"box": [1006, 1652, 1126, 1821], "vertical": true, "font_size": 34, "lines_coords": [[[1089.0, 1652.0], [1126.0, 1652.0], [1126.0, 1821.0], [1089.0, 1821.0]], [[1048.0, 1654.0], [1083.0, 1654.0], [1083.0, 1821.0], [1048.0, 1821.0]], [[1006.0, 1654.0], [1044.0, 1654.0], [1044.0, 1788.0], [1006.0, 1788.0]]], "lines": ["１か１００しか", "ねーのかよ", "クソッ！！"]}, {"box": [219, 1699, 368, 1983], "vertical": true, "font_size": 47, "lines_coords": [[[308.0, 1699.0], [368.0, 1699.0], [368.0, 1836.0], [308.0, 1836.0]], [[267.0, 1708.0], [310.0, 1708.0], [310.0, 1983.0], [267.0, 1983.0]], [[219.0, 1705.0], [256.0, 1705.0], [256.0, 1865.0], [219.0, 1865.0]]], "lines": ["適当で", "いいじゃねーか", "適当で！！"]}], "img_path": "161.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [747, 1, 1029, 336], "vertical": false, "font_size": 16, "lines_coords": [[[950.0, 68.0], [1008.0, 68.0], [1008.0, 86.0], [950.0, 86.0]], [[807.0, 93.0], [932.0, 93.0], [932.0, 111.0], [807.0, 111.0]]], "lines": ["．．．", "それでも、"]}, {"box": [1170, 838, 1280, 1062], "vertical": true, "font_size": 32, "lines_coords": [[[1251.0, 840.0], [1280.0, 840.0], [1280.0, 993.0], [1251.0, 993.0]], [[1207.0, 838.0], [1242.0, 838.0], [1242.0, 993.0], [1207.0, 993.0]], [[1170.0, 838.0], [1199.0, 838.0], [1199.0, 1062.0], [1170.0, 1062.0]]], "lines": ["．．．もしもし", "清水くん？", "．．．沼田裕美です。"]}, {"box": [237, 845, 559, 1238], "vertical": true, "font_size": 29, "lines_coords": [[[526.0, 850.0], [555.0, 850.0], [555.0, 1033.0], [526.0, 1033.0]], [[488.0, 850.0], [517.0, 850.0], [517.0, 1091.0], [488.0, 1091.0]], [[453.0, 850.0], [482.0, 850.0], [482.0, 1016.0], [453.0, 1016.0]]], "lines": ["ペガサスが今", "とっても悲しんで", "るんだって。"]}, {"box": [1015, 1022, 1128, 1240], "vertical": true, "font_size": 32, "lines_coords": [[[1093.0, 1022.0], [1128.0, 1022.0], [1128.0, 1159.0], [1093.0, 1159.0]], [[1052.0, 1024.0], [1087.0, 1024.0], [1087.0, 1194.0], [1052.0, 1194.0]], [[1015.0, 1024.0], [1044.0, 1024.0], [1044.0, 1240.0], [1015.0, 1240.0]]], "lines": ["ごめんね", "朝早くに．．．", "緊急の用なの。"]}, {"box": [1242, 1550, 1284, 1614], "vertical": true, "font_size": 42, "lines_coords": [[[1242.0, 1550.0], [1284.0, 1550.0], [1284.0, 1614.0], [1242.0, 1614.0]]], "lines": ["ピッ"]}, {"box": [231, 1004, 391, 1246], "vertical": true, "font_size": 34, "lines_coords": [[[356.0, 1006.0], [391.0, 1006.0], [391.0, 1244.0], [356.0, 1244.0]], [[314.0, 1006.0], [350.0, 1006.0], [350.0, 1244.0], [314.0, 1244.0]], [[271.0, 1006.0], [306.0, 1006.0], [306.0, 1244.0], [271.0, 1244.0]], [[234.0, 1008.0], [263.0, 1008.0], [263.0, 1242.0], [234.0, 1242.0]]], "lines": ["あたし達が力に", "ならなきゃ．．．．．．", "今みんなに招集", "かけてるわ．．．"]}], "img_path": "162.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1209, 161, 1278, 354], "vertical": true, "font_size": 30, "lines_coords": [[[1242.0, 161.0], [1278.0, 161.0], [1278.0, 316.0], [1242.0, 316.0]], [[1209.0, 163.0], [1238.0, 163.0], [1238.0, 354.0], [1209.0, 354.0]]], "lines": ["おっと．．．．．", "やっ