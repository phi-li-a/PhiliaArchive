36.0], [1288.0, 1836.0], [1288.0, 1952.0], [1253.0, 1952.0]]], "lines": ["仮説２、"]}, {"box": [155, 1751, 320, 2018], "vertical": true, "font_size": 34, "lines_coords": [[[287.0, 1755.0], [316.0, 1755.0], [316.0, 1954.0], [287.0, 1954.0]], [[246.0, 1753.0], [275.0, 1753.0], [275.0, 2018.0], [246.0, 2018.0]], [[200.0, 1751.0], [236.0, 1751.0], [236.0, 1921.0], [200.0, 1921.0]], [[155.0, 1751.0], [198.0, 1751.0], [198.0, 1873.0], [155.0, 1873.0]]], "lines": ["自分の行動を", "正当化するための", "僕の虚妄で", "あった。"]}], "img_path": "151.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1143, 273, 1184, 444], "vertical": true, "font_size": 37, "lines_coords": [[[1143.0, 273.0], [1180.0, 273.0], [1184.0, 443.0], [1147.0, 443.0]]], "lines": ["仮説３．．．．．"]}, {"box": [283, 617, 358, 801], "vertical": true, "font_size": 32, "lines_coords": [[[323.0, 619.0], [358.0, 619.0], [358.0, 755.0], [323.0, 755.0]], [[283.0, 619.0], [312.0, 619.0], [312.0, 797.0], [283.0, 797.0]]], "lines": ["人はみな", "黒点である。"]}, {"box": [1131, 1480, 1176, 1620], "vertical": true, "font_size": 45, "lines_coords": [[[1131.0, 1480.0], [1176.0, 1480.0], [1176.0, 1616.0], [1131.0, 1616.0]]], "lines": ["ヤダ．．．"]}, {"box": [294, 1542, 334, 1712], "vertical": true, "font_size": 37, "lines_coords": [[[294.0, 1542.0], [331.0, 1542.0], [333.0, 1712.0], [296.0, 1712.0]]], "lines": ["超ヤバい．．．"]}], "img_path": "152.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [981, 813, 1126, 1017], "vertical": true, "font_size": 41, "lines_coords": [[[1081.0, 813.0], [1126.0, 815.0], [1122.0, 937.0], [1077.0, 935.0]], [[1033.0, 815.0], [1068.0, 815.0], [1068.0, 1016.0], [1033.0, 1016.0]], [[981.0, 813.0], [1025.0, 813.0], [1025.0, 979.0], [981.0, 979.0]]], "lines": ["世界が", "とろけそう", "だ．．．．．！！"]}, {"box": [436, 1389, 469, 1557], "vertical": true, "font_size": 29, "lines_coords": [[[437.0, 1391.0], [466.0, 1391.0], [466.0, 1554.0], [437.0, 1554.0]]], "lines": ["なんでよ．．．"]}