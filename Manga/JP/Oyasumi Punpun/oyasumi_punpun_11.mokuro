version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1108, 161, 1255, 371], "vertical": true, "font_size": 44, "lines_coords": [[[1211.0, 163.0], [1255.0, 163.0], [1251.0, 327.0], [1207.0, 327.0]], [[1155.0, 163.0], [1199.0, 163.0], [1203.0, 370.0], [1160.0, 370.0]], [[1108.0, 161.0], [1151.0, 161.0], [1151.0, 291.0], [1108.0, 291.0]]], "lines": ["１２音階の", "魔法戦士達", "よ．．．．．．"]}, {"box": [275, 803, 418, 1010], "vertical": true, "font_size": 37, "lines_coords": [[[379.0, 805.0], [416.0, 805.0], [416.0, 968.0], [379.0, 968.0]], [[325.0, 805.0], [362.0, 805.0], [364.0, 1010.0], [327.0, 1010.0]], [[275.0, 803.0], [312.0, 803.0], [312.0, 970.0], [275.0, 970.0]]], "lines": ["さぁ僕を", "勃起させて", "くれ．．．"]}, {"box": [1240, 1289, 1323, 1467], "vertical": true, "font_size": 38, "lines_coords": [[[1292.0, 1298.0], [1321.0, 1298.0], [1321.0, 1467.0], [1292.0, 1467.0]], [[1240.0, 1289.0], [1288.0, 1289.0], [1288.0, 1387.0], [1240.0, 1387.0]]], "lines": ["やりますよ", "仕事。"]}, {"box": [706, 1298, 815, 1496], "vertical": true, "font_size": 29, "lines_coords": [[[783.0, 1300.0], [812.0, 1300.0], [812.0, 1453.0], [783.0, 1453.0]], [[743.0, 1300.0], [772.0, 1300.0], [772.0, 1455.0], [743.0, 1455.0]], [[706.0, 1298.0], [735.0, 1298.0], [737.0, 1496.0], [708.0, 1496.0]]], "lines": ["必ず信じて", "もらえると", "思っていたさ。"]}, {"box": [163, 1385, 310, 1611], "vertical": true, "font_size": 34, "lines_coords": [[[273.0, 1385.0], [310.0, 1385.0], [310.0, 1511.0], [273.0, 1511.0]], [[236.0, 1385.0], [271.0, 1385.0], [271.0, 1569.0], [236.0, 1569.0]], [[198.0, 1385.0], [234.0, 1385.0], [234.0, 1511.0], [198.0, 1511.0]], [[163.0, 1385.0], [192.0, 1385.0], [192.0, 1608.0], [163.0, 1608.0]]], "lines": ["．．．なぁに", "わかっていた", "君と俺は", "似た者同士だと。"]}, {"box": [901, 1751, 1046, 1937], "vertical": true, "font_size": 32, "lines_coords": [[[1010.0, 1751.0], [1046.0, 1751.0], [1046.0, 1937.0], [1010.0, 1937.0]], [[975.0, 1753.0], [1004.0, 1753.0], [1004.0, 1935.0], [975.0, 1935.0]], [[934.0, 1751.0], [969.0, 1751.0], [969.0, 1908.0], [934.0, 1908.0]], [[901.0, 1753.0], [930.0, 1753.0], [930.0, 1888.0], [901.0, 1888.0]]], "lines": ["怪しいけれど", "とてもお金が", "欲しい気分", "なんです。"]}, {"box": [254, 1774, 418, 1981], "vertical": true, "font_size": 35, "lines_coords": [[[383.0, 1776.0], [418.0, 1776.0], [418.0, 1950.0], [383.0, 1950.0]], [[337.0, 1774.0], [372.0, 1774.0], [377.0, 1981.0], [341.0, 1981.0]], [[298.0, 1774.0], [333.0, 1774.0], [333.0, 1948.0], [298.0, 1948.0]], [[254.0, 1776.0], [290.0, 1776.0], [290.0, 1981.0], [254.0, 1981.0]]], "lines": ["．．．ボタンを", "押す仕事って", "具体的に何", "なんですか？"]}], "img_path": "170.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1226, 146, 1265, 298], "vertical": true, "font_size": 32, "lines_coords": [[[1226.0, 146.0], [1261.0, 146.0], [1265.0, 298.0], [1230.0, 298.0]]], "lines": ["愚問だな。"]}, {"box": [1041, 258, 1184, 445], "vertical": true, "font_size": 32, "lines_coords": [[[1155.0, 262.0], [1184.0, 262.0], [1184.0, 385.0], [1155.0, 385.0]], [[1118.0, 262.0], [1147.0, 262.0], [1147.0, 445.0], [1118.0, 445.0]], [[1081.0, 262.0], [1110.0, 262.0], [1110.0, 445.0], [1081.0, 445.0]], [[1041.0, 258.0], [1077.0, 258.0], [1077.0, 368.0], [1041.0, 368.0]]], "lines": ["ボタンを", "押す仕事とは", "ボタンを押す", "仕事だ。"]}, {"box": [441, 155, 622, 371], "vertical": true, "font_size": 31, "lines_coords": [[[592.0, 157.0], [621.0, 157.0], [621.0, 281.0], [592.0, 281.0]], [[553.0, 155.0], [584.0, 155.0], [586.0, 341.0], [555.0, 341.0]], [[517.0, 159.0], [546.0, 159.0], [546.0, 370.0], [517.0, 370.0]], [[482.0, 159.0], [511.0, 159.0], [511.0, 370.0], [482.0, 370.0]], [[441.0, 155.0], [478.0, 155.0], [478.0, 265.0], [441.0, 265.0]]], "lines": ["ボタンを", "押す事で何が", "起こるかを君が", "気にする必要は", "ないし、"]}, {"box": [171, 670, 288, 875], "vertical": true, "font_size": 33, "lines_coords": [[[252.0, 670.0], [287.0, 670.0], [287.0, 873.0], [252.0, 873.0]], [[211.0, 672.0], [246.0, 672.0], [246.0, 875.0], [211.0, 875.0]], [[171.0, 672.0], [200.0, 672.0], [200.0, 819.0], [171.0, 819.0]]], "lines": ["もちろん君に", "迷惑がかかる", "事もない。"]}, {"box": [1231, 1438, 1264, 1620], "vertical": true, "font_size": 29, "lines_coords": [[[1232.0, 1438.0], [1261.0, 1438.0], [1261.0, 1618.0], [1232.0, 1618.0]]], "lines": ["それはない。"]}, {"box": [370, 1035, 408, 1217], "vertical": true, "font_size": 36, "lines_coords": [[[370.0, 1035.0], [408.0, 1035.0], [408.0, 1217.0], [370.0, 1217.0]]], "lines": ["．．．やですよ。"]}, {"box": [207, 1115, 281, 1302], "vertical": true, "font_size": 36, "lines_coords": [[[246.0, 1115.0], [281.0, 1115.0], [281.0, 1254.0], [246.0, 1254.0]], [[207.0, 1120.0], [242.0, 1120.0], [242.0, 1302.0], [207.0, 1302.0]]], "lines": ["人に迷惑", "かけるのも。"]}, {"box": [913, 1753, 1000, 1942], "vertical": true, "font_size": 43, "lines_coords": [[[946.0, 1755.0], [996.0, 1753.0], [1000.0, 1834.0], [950.0, 1836.0]], [[913.0, 1755.0], [948.0, 1755.0], [952.0, 1935.0], [917.0, 1935.0]]], "lines": ["安心", "したらいい。"]}, {"box": [667, 1668, 772, 1908], "vertical": true, "font_size": 29, "lines_coords": [[[741.0, 1668.0], [770.0, 1668.0], [770.0, 1879.0], [741.0, 1879.0]], [[704.0, 1668.0], [733.0, 1668.0], [733.0, 1848.0], [704.0, 1848.0]], [[667.0, 1670.0], [696.0, 1670.0], [696.0, 1908.0], [667.0, 1908.0]]], "lines": ["．．．和田さん達は", "何をしようと", "してるんですか？"]}, {"box": [157, 1780, 265, 2021], "vertical": true, "font_size": 33, "lines_coords": [[[225.0, 1780.0], [265.0, 1780.0], [265.0, 1875.0], [225.0, 1875.0]], [[194.0, 1782.0], [223.0, 1782.0], [223.0, 1993.0], [194.0, 1993.0]], [[157.0, 1782.0], [186.0, 1782.0], [186.0, 2020.0], [157.0, 2020.0]]], "lines": ["ただの", "ピアニカ同好会", "じゃないでしょ？"]}], "img_path": "171.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [712, 165, 785, 382], "vertical": true, "font_size": 34, "lines_coords": [[[754.0, 169.0], [783.0, 169.0], [783.0, 380.0], [754.0, 380.0]], [[712.0, 165.0], [751.0, 165.0], [751.0, 262.0], [712.0, 262.0]]], "lines": ["チューペット君", "かい？"]}, {"box": [198, 180, 374, 453], "vertical": true, "font_size": 29, "lines_coords": [[[345.0, 182.0], [374.0, 182.0], [374.0, 453.0], [345.0, 453.0]], [[306.0, 180.0], [335.0, 180.0], [335.0, 422.0], [306.0, 422.0]], [[271.0, 182.0], [300.0, 182.0], [300.0, 409.0], [271.0, 409.0]], [[234.0, 182.0], [263.0, 182.0], [263.0, 422.0], [234.0, 422.0]], [[198.0, 182.0], [227.0, 182.0], [227.0, 345.0], [198.0, 345.0]]], "lines": ["幼なじみを心配する", "君の姿勢はとても", "感心するが、残念", "ながらそれは彼の", "自由意志だ。"]}, {"box": [1139, 438, 1259, 681], "vertical": true, "font_size": 36, "lines_coords": [[[1224.0, 440.0], [1259.0, 440.0], [1259.0, 681.0], [1224.0, 681.0]], [[1182.0, 440.0], [1218.0, 440.0], [1218.0, 679.0], [1182.0, 679.0]], [[1143.0, 438.0], [1180.0, 438.0], [1176.0, 592.0], [1139.0, 592.0]]], "lines": ["．．．あまり清水を", "巻き込まないで", "ください。"]}, {"box": [1106, 840, 1271, 1113], "vertical": true, "font_size": 32, "lines_coords": [[[1236.0, 842.0], [1271.0, 842.0], [1271.0, 1113.0], [1236.0, 1113.0]], [[1186.0, 840.0], [1222.0, 840.0], [1222.0, 1014.0], [1186.0, 1014.0]], [[1147.0, 842.0], [1176.0, 842.0], [1176.0, 1043.0], [1147.0, 1043.0]], [[1106.0, 844.0], [1135.0, 844.0], [1135.0, 1022.0], [1106.0, 1022.0]]], "lines": ["俺がペガサスこと", "星川敏樹と", "出会ったのは", "大学生の時。"]}, {"box": [151, 469, 217, 639], "vertical": true, "font_size": 29, "lines_coords": [[[188.0, 472.0], [217.0, 472.0], [217.0, 623.0], [188.0, 623.0]], [[151.0, 469.0], [180.0, 469.0], [180.0, 639.0], [151.0, 639.0]]], "lines": ["我々は強制", "していない。"]}, {"box": [994, 1138, 1149, 1407], "vertical": true, "font_size": 32, "lines_coords": [[[1120.0, 1142.0], [1149.0, 1142.0], [1149.0, 1372.0], [1120.0, 1372.0]], [[1079.0, 1142.0], [1108.0, 1142.0], [1108.0, 1343.0], [1079.0, 1343.0]], [[1033.0, 1138.0], [1064.0, 1138.0], [1066.0, 1407.0], [1035.0, 1407.0]], [[994.0, 1140.0], [1029.0, 1140.0], [1029.0, 1325.0], [994.0, 1325.0]]], "lines": ["以前話した通り", "彼には未来を", "予知する不思議な", "力があった。"]}, {"box": [294, 946, 453, 1186], "vertical": true, "font_size": 34, "lines_coords": [[[418.0, 948.0], [453.0, 948.0], [453.0, 1082.0], [418.0, 1082.0]], [[377.0, 946.0], [412.0, 946.0], [412.0, 1186.0], [377.0, 1186.0]], [[337.0, 948.0], [366.0, 948.0], [366.0, 1149.0], [337.0, 1149.0]], [[294.0, 946.0], [325.0, 946.0], [329.0, 1132.0], [298.0, 1132.0]]], "lines": ["知りたい", "未来を指定して", "予知する事は", "出来ないが、"]}, {"box": [182, 1213, 343, 1447], "vertical": true, "font_size": 34, "lines_coords": [[[308.0, 1213.0], [343.0, 1213.0], [343.0, 1382.0], [308.0, 1382.0]], [[267.0, 1215.0], [302.0, 1215.0], [302.0, 1399.0], [267.0, 1399.0]], [[223.0, 1217.0], [258.0, 1217.0], [258.0, 1447.0], [223.0, 1447.0]], [[182.0, 1215.0], [217.0, 1215.0], [217.0, 1362.0], [182.0, 1362.0]]], "lines": ["予言できた", "内容は、俺の", "知る限り１００％の", "的中率だ。"]}, {"box": [1133, 1641, 1238, 1855], "vertical": true, "font_size": 33, "lines_coords": [[[1203.0, 1643.0], [1238.0, 1643.0], [1238.0, 1768.0], [1203.0, 1768.0]], [[1168.0, 1641.0], [1203.0, 1641.0], [1199.0, 1855.0], [1164.0, 1855.0]], [[1133.0, 1645.0], [1162.0, 1645.0], [1162.0, 1834.0], [1133.0, 1834.0]]], "lines": ["僕だって", "そう思っていた", "時もあります。"]}, {"box": [211, 1786, 334, 1954], "vertical": true, "font_size": 37, "lines_coords": [[[298.0, 1786.0], [329.0, 1786.0], [331.0, 1954.0], [300.0, 1954.0]], [[256.0, 1786.0], [294.0, 1786.0], [294.0, 1950.0], [256.0, 1950.0]], [[211.0, 1786.0], [254.0, 1786.0], [254.0, 1904.0], [211.0, 1904.0]]], "lines": ["こんな社会", "糞くらえっ", "．．．てね。"]}], "img_path": "172.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1137, 146, 1240, 376], "vertical": true, "font_size": 32, "lines_coords": [[[1211.0, 149.0], [1240.0, 149.0], [1240.0, 364.0], [1211.0, 364.0]], [[1170.0, 146.0], [1205.0, 146.0], [1205.0, 275.0], [1170.0, 275.0]], [[1137.0, 151.0], [1166.0, 151.0], [1166.0, 376.0], [1137.0, 376.0]]], "lines": ["でもこの楽団に", "参加して", "気付いたんです。"]}, {"box": [350, 356, 526, 627], "vertical": true, "font_size": 31, "lines_coords": [[[497.0, 358.0], [526.0, 358.0], [526.0, 569.0], [497.0, 569.0]], [[459.0, 358.0], [488.0, 358.0], [488.0, 598.0], [459.0, 598.0]], [[422.0, 358.0], [451.0, 358.0], [451.0, 627.0], [422.0, 627.0]], [[385.0, 358.0], [414.0, 358.0], [414.0, 569.0], [385.0, 569.0]], [[350.0, 356.0], [377.0, 356.0], [377.0, 538.0], [350.0, 538.0]]], "lines": ["１２音階の個性が", "組み合わさる事で", "無限のハーモニーが", "生まれる．．．．．．", "この可能性？"]}, {"box": [1062, 424, 1168, 668], "vertical": true, "font_size": 32, "lines_coords": [[[1133.0, 426.0], [1168.0, 426.0], [1168.0, 581.0], [1133.0, 581.0]], [[1095.0, 424.0], [1131.0, 424.0], [1131.0, 610.0], [1095.0, 610.0]], [[1062.0, 428.0], [1091.0, 428.0], [1091.0, 668.0], [1062.0, 668.0]]], "lines": ["無駄な人間", "なんて一人も", "いないって事を！！"]}, {"box": [211, 629, 329, 867], "vertical": true, "font_size": 31, "lines_coords": [[[294.0, 629.0], [329.0, 629.0], [329.0, 801.0], [294.0, 801.0]], [[250.0, 631.0], [285.0, 631.0], [285.0, 867.0], [250.0, 867.0]], [[211.0, 629.0], [246.0, 629.0], [246.0, 770.0], [211.0, 770.0]]], "lines": ["．．．楽団長が", "教えてくれたん", "ですよ！！"]}, {"box": [1099, 1039, 1244, 1294], "vertical": true, "font_size": 28, "lines_coords": [[[1213.0, 1041.0], [1242.0, 1041.0], [1242.0, 1223.0], [1213.0, 1223.0]], [[1178.0, 1039.0], [1207.0, 1039.0], [1207.0, 1221.0], [1178.0, 1221.0]], [[1141.0, 1039.0], [1168.0, 1039.0], [1168.0, 1281.0], [1141.0, 1281.0]], [[1099.0, 1039.0], [1128.0, 1039.0], [1133.0, 1293.0], [1104.0, 1293.0]]], "lines": ["俺は彼の力を", "多くの人間に", "認めさせる責務が", "あると思っている。"]}, {"box": [1170, 1443, 1276, 1656], "vertical": true, "font_size": 31, "lines_coords": [[[1240.0, 1443.0], [1276.0, 1443.0], [1276.0, 1567.0], [1240.0, 1567.0]], [[1205.0, 1443.0], [1234.0, 1443.0], [1234.0, 1654.0], [1205.0, 1654.0]], [[1170.0, 1443.0], [1199.0, 1443.0], [1199.0, 1602.0], [1170.0, 1602.0]]], "lines": ["．．．馬鹿は", "果たしてどっち", "だろうかね"]}, {"box": [190, 1107, 334, 1320], "vertical": true, "font_size": 29, "lines_coords": [[[302.0, 1107.0], [331.0, 1107.0], [331.0, 1260.0], [302.0, 1260.0]], [[265.0, 1107.0], [294.0, 1107.0], [294.0, 1320.0], [265.0, 1320.0]], [[227.0, 1107.0], [256.0, 1107.0], [256.0, 1289.0], [227.0, 1289.0]], [[190.0, 1111.0], [219.0, 1111.0], [219.0, 1271.0], [190.0, 1271.0]]], "lines": ["彼の言動は", "周囲の人間達に", "馬鹿にされて", "いたからね。"]}, {"box": [777, 1811, 919, 2020], "vertical": true, "font_size": 30, "lines_coords": [[[882.0, 1811.0], [919.0, 1811.0], [919.0, 1906.0], [882.0, 1906.0]], [[849.0, 1813.0], [878.0, 1813.0], [878.0, 1993.0], [849.0, 1993.0]], [[812.0, 1813.0], [841.0, 1813.0], [841.0, 2020.0], [812.0, 2020.0]], [[778.0, 1815.0], [801.0, 1815.0], [801.0, 1966.0], [778.0, 1966.0]]], "lines": ["自分の", "価値観でしか", "ものを語れない", "低能たちめ"]}, {"box": [171, 1757, 383, 2025], "vertical": true, "font_size": 35, "lines_coords": [[[337.0, 1757.0], [383.0, 1757.0], [383.0, 1867.0], [337.0, 1867.0]], [[300.0, 1761.0], [335.0, 1761.0], [335.0, 1995.0], [300.0, 1995.0]], [[261.0, 1763.0], [290.0, 1763.0], [290.0, 1960.0], [261.0, 1960.0]], [[219.0, 1761.0], [248.0, 1761.0], [248.0, 2024.0], [219.0, 2024.0]], [[176.0, 1759.0], [211.0, 1759.0], [207.0, 1962.0], [171.0, 1962.0]]], "lines": ["．．．彼は", "夢の中で聴いた", "音楽を解析し", "未来を予知できる", "と言った．．．"]}], "img_path": "173.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1139, 101, 1244, 374], "vertical": true, "font_size": 31, "lines_coords": [[[1218.0, 103.0], [1244.0, 103.0], [1244.0, 316.0], [1218.0, 316.0]], [[1178.0, 103.0], [1205.0, 103.0], [1205.0, 374.0], [1178.0, 374.0]], [[1139.0, 101.0], [1176.0, 101.0], [1176.0, 211.0], [1139.0, 211.0]]], "lines": ["彼の宇宙観では", "この世の始まりから", "終わり、"]}, {"box": [1031, 383, 1139, 569], "vertical": true, "font_size": 31, "lines_coords": [[[1110.0, 387.0], [1139.0, 387.0], [1139.0, 538.0], [1110.0, 538.0]], [[1070.0, 385.0], [1102.0, 385.0], [1097.0, 569.0], [1066.0, 569.0]], [[1031.0, 383.0], [1068.0, 383.0], [1068.0, 484.0], [1031.0, 484.0]]], "lines": ["過去未来に", "起こる全ての", "事象は、"]}, {"box": [227, 269, 406, 571], "vertical": true, "font_size": 29, "lines_coords": [[[374.0, 271.0], [403.0, 271.0], [403.0, 571.0], [374.0, 571.0]], [[337.0, 271.0], [366.0, 271.0], [366.0, 484.0], [337.0, 484.0]], [[300.0, 269.0], [329.0, 269.0], [329.0, 511.0], [300.0, 511.0]], [[261.0, 271.0], [292.0, 271.0], [294.0, 513.0], [263.0, 513.0]], [[227.0, 271.0], [256.0, 271.0], [256.0, 554.0], [227.0, 554.0]]], "lines": ["アカシックレコードと", "呼ばれる巨大な", "円周を持った筒の", "表面に音階として", "刻まれているという。"]}, {"box": [1114, 745, 1235, 928], "vertical": true, "font_size": 36, "lines_coords": [[[1199.0, 747.0], [1234.0, 747.0], [1234.0, 915.0], [1199.0, 915.0]], [[1155.0, 747.0], [1193.0, 747.0], [1193.0, 884.0], [1155.0, 884.0]], [[1114.0, 745.0], [1149.0, 745.0], [1149.0, 925.0], [1114.0, 925.0]]], "lines": ["果てしない", "大きさの", "オルゴール、"]}, {"box": [242, 1217, 358, 1466], "vertical": true, "font_size": 31, "lines_coords": [[[323.0, 1217.0], [352.0, 1217.0], [352.0, 1411.0], [323.0, 1411.0]], [[279.0, 1217.0], [314.0, 1217.0], [314.0, 1420.0], [279.0, 1420.0]], [[242.0, 1219.0], [271.0, 1219.0], [271.0, 1463.0], [242.0, 1463.0]]], "lines": ["それが宇宙の", "姿だと思って", "もらえればいい。"]}, {"box": [1097, 1583, 1224, 1819], "vertical": true, "font_size": 39, "lines_coords": [[[1189.0, 1587.0], [1224.0, 1587.0], [1224.0, 1757.0], [1189.0, 1757.0]], [[1145.0, 1585.0], [1182.0, 1585.0], [1178.0, 1819.0], [1141.0, 1819.0]], [[1102.0, 1583.0], [1145.0, 1585.0], [1141.0, 1724.0], [1097.0, 1722.0]]], "lines": ["そして現在", "そのオルゴール", "は．．．．．．"]}, {"box": [217, 1703, 377, 1941], "vertical": true, "font_size": 34, "lines_coords": [[[339.0, 1703.0], [377.0, 1703.0], [377.0, 1842.0], [339.0, 1842.0]], [[298.0, 1705.0], [333.0, 1705.0], [333.0, 1939.0], [298.0, 1939.0]], [[256.0, 1705.0], [292.0, 1705.0], [292.0, 1908.0], [256.0, 1908.0]], [[217.0, 1710.0], [246.0, 1710.0], [246.0, 1935.0], [217.0, 1935.0]]], "lines": ["限りなく", "不安定な旋律を", "奏でていると", "いうのだ．．．．．．"]}], "img_path": "174.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1162, 192, 1244, 339], "vertical": true, "font_size": 37, "lines_coords": [[[1199.0, 192.0], [1244.0, 192.0], [1244.0, 304.0], [1199.0, 304.0]], [[1162.0, 192.0], [1197.0, 192.0], [1197.0, 339.0], [1162.0, 339.0]]], "lines": ["そして", "７月７日、"]}, {"box": [969, 343, 1128, 662], "vertical": true, "font_size": 37, "lines_coords": [[[1091.0, 343.0], [1128.0, 343.0], [1128.0, 451.0], [1091.0, 451.0]], [[1052.0, 343.0], [1087.0, 343.0], [1087.0, 583.0], [1052.0, 583.0]], [[1008.0, 343.0], [1044.0, 343.0], [1046.0, 616.0], [1010.0, 616.0]], [[969.0, 345.0], [1004.0, 345.0], [1004.0, 662.0], [969.0, 662.0]]], "lines": ["激烈な", "不協和音により", "それまでの旋律は", "ついに完全崩壊する。"]}, {"box": [353, 412, 431, 510], "vertical": true, "font_size": 78, "lines_coords": [[[353.0, 412.0], [431.0, 412.0], [431.0, 510.0], [353.0, 510.0]]], "lines": ["振動の乱れ、"]}, {"box": [345, 405, 437, 519], "vertical": true, "font_size": 44, "lines_coords": [[[385.0, 405.0], [437.0, 405.0], [437.0, 519.0], [385.0, 519.0]], [[345.0, 409.0], [395.0, 409.0], [395.0, 498.0], [345.0, 498.0]]], "lines": ["振動の", "乱れ、"]}, {"box": [617, 614, 766, 639], "vertical": false, "font_size": 20, "lines_coords": [[[617.0, 614.0], [766.0, 619.0], [766.0, 639.0], [617.0, 635.0]]], "lines": ["ｘｅｌａｘ．ｓｕｔｆａｃｔｏｒｙ"]}, {"box": [221, 629, 393, 906], "vertical": true, "font_size": 44, "lines_coords": [[[358.0, 639.0], [393.0, 639.0], [393.0, 844.0], [358.0, 844.0]], [[316.0, 639.0], [352.0, 639.0], [352.0, 877.0], [316.0, 877.0]], [[275.0, 637.0], [312.0, 637.0], [308.0, 906.0], [271.0, 906.0]], [[227.0, 629.0], [279.0, 635.0], [273.0, 697.0], [221.0, 693.0]]], "lines": ["その瞬間こそ", "ペガサスの言う。", "「約束された絶望」", "だ。"]}, {"box": [1149, 1142, 1255, 1356], "vertical": true, "font_size": 32, "lines_coords": [[[1224.0, 1142.0], [1255.0, 1142.0], [1249.0, 1296.0], [1218.0, 1296.0]], [[1182.0, 1142.0], [1218.0, 1142.0], [1218.0, 1327.0], [1182.0, 1327.0]], [[1149.0, 1144.0], [1178.0, 1144.0], [1178.0, 1353.0], [1149.0, 1353.0]]], "lines": ["「黒点」すら", "許してしまう", "貴方の優しさ．．．"]}, {"box": [865, 1322, 1004, 1500], "vertical": true, "font_size": 29, "lines_coords": [[[975.0, 1322.0], [1004.0, 1322.0], [1004.0, 1443.0], [975.0, 1443.0]], [[938.0, 1322.0], [967.0, 1322.0], [967.0, 1500.0], [938.0, 1500.0]], [[901.0, 1322.0], [930.0, 1322.0], [930.0, 1500.0], [901.0, 1500.0]], [[865.0, 1322.0], [894.0, 1322.0], [894.0, 1474.0], [865.0, 1474.0]]], "lines": ["．．．そうよ", "私達はもっと", "仲良くできる", "はずなの！！"]}, {"box": [557, 1126, 702, 1339], "vertical": true, "font_size": 34, "lines_coords": [[[662.0, 1126.0], [702.0, 1126.0], [702.0, 1225.0], [662.0, 1225.0]], [[629.0, 1126.0], [660.0, 1126.0], [658.0, 1339.0], [627.0, 1339.0]], [[590.0, 1126.0], [625.0, 1126.0], [625.0, 1312.0], [590.0, 1312.0]], [[557.0, 1128.0], [586.0, 1128.0], [586.0, 1283.0], [557.0, 1283.0]]], "lines": ["．．．彼は", "「目出し達磨」が", "降ってくると", "表現したが、"]}, {"box": [165, 1252, 270, 1461], "vertical": true, "font_size": 29, "lines_coords": [[[238.0, 1252.0], [267.0, 1252.0], [267.0, 1403.0], [238.0, 1403.0]], [[203.0, 1252.0], [232.0, 1252.0], [232.0, 1461.0], [203.0, 1461.0]], [[165.0, 1252.0], [194.0, 1252.0], [194.0, 1447.0], [165.0, 1447.0]]], "lines": ["それが何を", "意味しているか", "俺はわからん。"]}, {"box": [741, 1544, 880, 1786], "vertical": true, "font_size": 29, "lines_coords": [[[851.0, 1546.0], [880.0, 1546.0], [880.0, 1728.0], [851.0, 1728.0]], [[816.0, 1544.0], [843.0, 1544.0], [843.0, 1726.0], [816.0, 1726.0]], [[778.0, 1544.0], [807.0, 1544.0], [807.0, 1726.0], [778.0, 1726.0]], [[741.0, 1546.0], [770.0, 1546.0], [770.0, 1786.0], [741.0, 1786.0]]], "lines": ["この気持ちを", "忘れない限り", "世界は永遠に", "輝いているから！！"]}, {"box": [372, 1563, 515, 1805], "vertical": true, "font_size": 29, "lines_coords": [[[480.0, 1563.0], [515.0, 1563.0], [515.0, 1691.0], [480.0, 1691.0]], [[443.0, 1563.0], [474.0, 1563.0], [478.0, 1716.0], [447.0, 1716.0]], [[410.0, 1565.0], [439.0, 1565.0], [439.0, 1805.0], [410.0, 1805.0]], [[372.0, 1565.0], [401.0, 1565.0], [401.0, 1687.0], [372.0, 1687.0]]], "lines": ["大規模な", "災害なのか", "はたまた社会不安", "なのか．．．"]}, {"box": [184, 1794, 356, 2001], "vertical": true, "font_size": 29, "lines_coords": [[[327.0, 1797.0], [356.0, 1797.0], [356.0, 1975.0], [327.0, 1975.0]], [[292.0, 1794.0], [319.0, 1794.0], [319.0, 1975.0], [292.0, 1975.0]], [[254.0, 1794.0], [281.0, 1794.0], [281.0, 1977.0], [254.0, 1977.0]], [[217.0, 1794.0], [246.0, 1794.0], [246.0, 2001.0], [217.0, 2001.0]], [[184.0, 1797.0], [209.0, 1797.0], [209.0, 1956.0], [184.0, 1956.0]]], "lines": ["いずれにせよ", "人類史に残る", "大きな悲劇と", "なるのは間違い", "ないだろう。"]}], "img_path": "175.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [967, 93, 1116, 370], "vertical": true, "font_size": 30, "lines_coords": [[[1081.0, 95.0], [1116.0, 95.0], [1116.0, 308.0], [1081.0, 308.0]], [[1046.0, 95.0], [1075.0, 95.0], [1075.0, 370.0], [1046.0, 370.0]], [[1010.0, 95.0], [1037.0, 95.0], [1037.0, 279.0], [1010.0, 279.0]], [[971.0, 93.0], [1006.0, 93.0], [1002.0, 225.0], [967.0, 225.0]]], "lines": ["ペガサスはその", "「乱れ」を安定させる", "術を長年研究", "した結果、"]}, {"box": [768, 277, 944, 581], "vertical": true, "font_size": 30, "lines_coords": [[[915.0, 279.0], [944.0, 279.0], [944.0, 569.0], [915.0, 569.0]], [[878.0, 279.0], [907.0, 279.0], [907.0, 430.0], [878.0, 430.0]], [[836.0, 277.0], [867.0, 277.0], [870.0, 581.0], [838.0, 581.0]], [[803.0, 279.0], [832.0, 279.0], [832.0, 490.0], [803.0, 490.0]], [[768.0, 279.0], [795.0, 279.0], [795.0, 503.0], [768.0, 503.0]]], "lines": ["不協和音を調和させる", "別の旋律を", "アカシックレコードに", "刻み込む方法に", "辿り着いたんだ。"]}, {"box": [553, 118, 664, 304], "vertical": true, "font_size": 32, "lines_coords": [[[623.0, 118.0], [664.0, 118.0], [664.0, 188.0], [623.0, 188.0]], [[594.0, 122.0], [621.0, 122.0], [621.0, 304.0], [594.0, 304.0]], [[553.0, 122.0], [588.0, 122.0], [588.0, 289.0], [553.0, 289.0]]], "lines": ["君の", "言う通り５ｋｇ", "やせたんだ。"]}, {"box": [374, 267, 519, 484], "vertical": true, "font_size": 32, "lines_coords": [[[488.0, 267.0], [519.0, 267.0], [519.0, 364.0], [488.0, 364.0]], [[451.0, 271.0], [480.0, 271.0], [480.0, 453.0], [451.0, 453.0]], [[414.0, 271.0], [443.0, 271.0], [443.0, 484.0], [414.0, 484.0]], [[374.0, 269.0], [403.0, 269.0], [403.0, 391.0], [374.0, 391.0]]], "lines": ["．．．でも", "予言のおかげ", "だなんて思って", "ないよ？"]}, {"box": [82, 151, 227, 397], "vertical": true, "font_size": 32, "lines_coords": [[[190.0, 151.0], [227.0, 151.0], [227.0, 250.0], [190.0, 250.0]], [[155.0, 151.0], [190.0, 151.0], [190.0, 347.0], [155.0, 347.0]], [[122.0, 153.0], [151.0, 153.0], [151.0, 368.0], [122.0, 368.0]], [[84.0, 153.0], [113.0, 153.0], [111.0, 397.0], [82.0, 397.0]]], "lines": ["やれば", "できるって事、", "もっとみんなに", "知ってほしいな！！"]}, {"box": [1133, 697, 1238, 946], "vertical": true, "font_size": 30, "lines_coords": [[[1209.0, 701.0], [1238.0, 701.0], [1238.0, 886.0], [1209.0, 886.0]], [[1170.0, 697.0], [1205.0, 697.0], [1199.0, 946.0], [1164.0, 946.0]], [[1133.0, 701.0], [1160.0, 701.0], [1160.0, 896.0], [1133.0, 896.0]]], "lines": ["：その旋律は", "「翼をください」に", "離似していた。"]}, {"box": [1145, 1088, 1288, 1368], "vertical": true, "font_size": 33, "lines_coords": [[[1259.0, 1095.0], [1288.0, 1095.0], [1288.0, 1273.0], [1259.0, 1273.0]], [[1220.0, 1088.0], [1255.0, 1088.0], [1253.0, 1368.0], [1218.0, 1368.0]], [[1184.0, 1095.0], [1213.0, 1095.0], [1213.0, 1277.0], [1184.0, 1277.0]], [[1145.0, 1091.0], [1174.0, 1091.0], [1174.0, 1287.0], [1145.0, 1287.0]]], "lines": ["．．．だから我々", "「ペガサス合奏団」は", "毎日毎日演奏", "しているのだ。"]}, {"box": [994, 1314, 1102, 1509], "vertical": true, "font_size": 33, "lines_coords": [[[1062.0, 1314.0], [1102.0, 1314.0], [1102.0, 1414.0], [1062.0, 1414.0]], [[1027.0, 1318.0], [1064.0, 1318.0], [1064.0, 1443.0], [1027.0, 1443.0]], [[994.0, 1320.0], [1023.0, 1320.0], [1023.0, 1509.0], [994.0, 1509.0]]], "lines": ["宇宙に", "向かって", "何度も同度も。"]}, {"box": [401, 1099, 507, 1281], "vertical": true, "font_size": 32, "lines_coords": [[[472.0, 1099.0], [507.0, 1099.0], [507.0, 1225.0], [472.0, 1225.0]], [[437.0, 1103.0], [466.0, 1103.0], [466.0, 1281.0], [437.0, 1281.0]], [[401.0, 1101.0], [428.0, 1101.0], [428.0, 1281.0], [401.0, 1281.0]]], "lines": ["もちろん", "人々の未来の", "ためにさ．．．"]}, {"box": [198, 1312, 383, 1558], "vertical": true, "font_size": 32, "lines_coords": [[[345.0, 1314.0], [383.0, 1314.0], [383.0, 1422.0], [345.0, 1422.0]], [[312.0, 1318.0], [341.0, 1318.0], [341.0, 1529.0], [312.0, 1529.0]], [[271.0, 1318.0], [306.0, 1318.0], [306.0, 1558.0], [271.0, 1558.0]], [[238.0, 1318.0], [267.0, 1318.0], [267.0, 1498.0], [238.0, 1498.0]], [[198.0, 1312.0], [234.0, 1312.0], [234.0, 1438.0], [198.0, 1438.0]]], "lines": ["．．．ふふ、", "なかなか上手く", "いかないようだが", "彼は優しい男", "だよ．．．"]}, {"box": [1209, 1718, 1245, 1928], "vertical": true, "font_size": 35, "lines_coords": [[[1209.0, 1718.0], [1244.0, 1718.0], [1244.0, 1925.0], [1209.0, 1925.0]]], "lines": ["ペガサスさん、"]}, {"box": [213, 1817, 295, 2002], "vertical": true, "font_size": 36, "lines_coords": [[[258.0, 1819.0], [294.0, 1819.0], [294.0, 1954.0], [258.0, 1954.0]], [[213.0, 1817.0], [248.0, 1817.0], [252.0, 2001.0], [217.0, 2001.0]]], "lines": ["ご報告が", "あるんです。"]}], "img_path": "176.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1151, 142, 1230, 383], "vertical": true, "font_size": 36, "lines_coords": [[[1193.0, 142.0], [1230.0, 142.0], [1230.0, 248.0], [1193.0, 248.0]], [[1151.0, 142.0], [1186.0, 142.0], [1186.0, 383.0], [1151.0, 383.0]]], "lines": ["．．．俺達", "結婚しました！！"]}, {"box": [362, 221, 540, 445], "vertical": true, "font_size": 29, "lines_coords": [[[505.0, 221.0], [536.0, 221.0], [540.0, 376.0], [509.0, 376.0]], [[470.0, 221.0], [499.0, 221.0], [503.0, 436.0], [474.0, 436.0]], [[437.0, 223.0], [466.0, 223.0], [466.0, 434.0], [437.0, 434.0]], [[399.0, 223.0], [428.0, 223.0], [428.0, 436.0], [399.0, 436.0]], [[362.0, 223.0], [391.0, 223.0], [391.0, 445.0], [362.0, 445.0]]], "lines": ["難しい事は", "わからないけど", "ペガサスさんの", "おかげで私達は", "結ばれたって事、"]}, {"box": [1131, 948, 1237, 1144], "vertical": true, "font_size": 29, "lines_coords": [[[1205.0, 950.0], [1234.0, 950.0], [1234.0, 1099.0], [1205.0, 1099.0]], [[1170.0, 950.0], [1199.0, 950.0], [1199.0, 1130.0], [1170.0, 1130.0]], [[1131.0, 948.0], [1160.0, 948.0], [1160.0, 1138.0], [1131.0, 1138.0]]], "lines": ["和田さんの", "お友達の事は", "わかりました。"]}, {"box": [215, 488, 319, 699], "vertical": true, "font_size": 29, "lines_coords": [[[290.0, 490.0], [319.0, 490.0], [319.0, 668.0], [290.0, 668.0]], [[252.0, 488.0], [281.0, 488.0], [281.0, 641.0], [252.0, 641.0]], [[215.0, 488.0], [244.0, 488.0], [244.0, 699.0], [215.0, 699.0]]], "lines": ["この事だけは", "どうしても", "伝えたくて．．．"]}, {"box": [1149, 1378, 1291, 1676], "vertical": true, "font_size": 28, "lines_coords": [[[1259.0, 1380.0], [1288.0, 1380.0], [1288.0, 1590.0], [1259.0, 1590.0]], [[1224.0, 1380.0], [1251.0, 1380.0], [1251.0, 1563.0], [1224.0, 1563.0]], [[1186.0, 1380.0], [1215.0, 1380.0], [1215.0, 1676.0], [1186.0, 1676.0]], [[1149.0, 1378.0], [1178.0, 1378.0], [1178.0, 1602.0], [1149.0, 1602.0]]], "lines": ["俺は彼の予知の", "素晴らしさを", "みんなに知って欲しい", "と思うよ切実に。"]}, {"box": [664, 1368, 768, 1639], "vertical": true, "font_size": 33, "lines_coords": [[[741.0, 1368.0], [768.0, 1368.0], [768.0, 1579.0], [741.0, 1579.0]], [[702.0, 1368.0], [731.0, 1368.0], [731.0, 1552.0], [702.0, 1552.0]], [[664.0, 1368.0], [693.0, 1368.0], [696.0, 1639.0], [667.0, 1639.0]]], "lines": ["でも和田さんの", "友達は世界を", "救いたいんでしょ？"]}, {"box": [181, 963, 434, 1255], "vertical": true, "font_size": 35, "lines_coords": [[[281.0, 1066.0], [327.0, 1062.0], [333.0, 1140.0], [287.0, 1144.0]], [[252.0, 1068.0], [287.0, 1068.0], [287.0, 1225.0], [252.0, 1225.0]], [[219.0, 1074.0], [248.0, 1074.0], [248.0, 1254.0], [219.0, 1254.0]], [[182.0, 1072.0], [211.0, 1072.0], [211.0, 1194.0], [182.0, 1194.0]]], "lines": ["結局", "和田さんは", "何をしたいん", "てすか？"]}, {"box": [211, 1430, 314, 1641], "vertical": true, "font_size": 30, "lines_coords": [[[285.0, 1430.0], [314.0, 1430.0], [314.0, 1612.0], [285.0, 1612.0]], [[248.0, 1432.0], [277.0, 1432.0], [277.0, 1641.0], [248.0, 1641.0]], [[211.0, 1434.0], [238.0, 1434.0], [238.0, 1616.0], [211.0, 1616.0]]], "lines": ["でもあなたは", "予言をみんなに", "知らしめたい"]}, {"box": [522, 1610, 631, 1765], "vertical": true, "font_size": 33, "lines_coords": [[[594.0, 1610.0], [631.0, 1610.0], [627.0, 1739.0], [590.0, 1739.0]], [[557.0, 1610.0], [596.0, 1610.0], [596.0, 1712.0], [557.0, 1712.0]], [[522.0, 1612.0], [557.0, 1612.0], [557.0, 1765.0], [522.0, 1765.0]]], "lines": ["救ったら", "予言は", "外れる．．．"]}, {"box": [140, 1710, 250, 1865], "vertical": true, "font_size": 30, "lines_coords": [[[217.0, 1714.0], [250.0, 1714.0], [250.0, 1776.0], [217.0, 1776.0]], [[180.0, 1712.0], [209.0, 1712.0], [209.0, 1865.0], [180.0, 1865.0]], [[145.0, 1710.0], [176.0, 1710.0], [171.0, 1832.0], [140.0, 1832.0]]], "lines": ["．．．．．．", "矛盾してま", "せんか？"]}], "img_path": "177.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1215, 184, 1253, 329], "vertical": true, "font_size": 30, "lines_coords": [[[1215.0, 184.0], [1253.0, 184.0], [1253.0, 329.0], [1215.0, 329.0]]], "lines": ["．．．いや、"]}, {"box": [863, 134, 942, 321], "vertical": true, "font_size": 36, "lines_coords": [[[899.0, 134.0], [942.0, 134.0], [942.0, 244.0], [899.0, 244.0]], [[865.0, 138.0], [894.0, 138.0], [894.0, 320.0], [865.0, 320.0]]], "lines": ["これは", "確定事項だ。"]}, {"box": [360, 132, 524, 370], "vertical": true, "font_size": 34, "lines_coords": [[[488.0, 132.0], [524.0, 132.0], [517.0, 370.0], [482.0, 370.0]], [[443.0, 132.0], [478.0, 132.0], [478.0, 337.0], [443.0, 337.0]], [[401.0, 132.0], [437.0, 132.0], [437.0, 339.0], [401.0, 339.0]], [[360.0, 132.0], [391.0, 132.0], [393.0, 318.0], [362.0, 318.0]]], "lines": ["．．．ペガサス自ら", "自分の予知が", "外れる予知を", "しない限り。"]}, {"box": [1087, 438, 1271, 681], "vertical": true, "font_size": 30, "lines_coords": [[[1242.0, 438.0], [1271.0, 438.0], [1271.0, 590.0], [1242.0, 590.0]], [[1199.0, 438.0], [1228.0, 438.0], [1228.0, 650.0], [1199.0, 650.0]], [[1162.0, 438.0], [1189.0, 438.0], [1189.0, 621.0], [1162.0, 621.0]], [[1122.0, 438.0], [1151.0, 438.0], [1151.0, 681.0], [1122.0, 681.0]], [[1087.0, 438.0], [1116.0, 438.0], [1116.0, 571.0], [1087.0, 571.0]]], "lines": ["７月７日は", "彼の言う通りに", "我々に大きな", "厄災が降りかかる", "だろうね。"]}, {"box": [635, 612, 751, 852], "vertical": true, "font_size": 33, "lines_coords": [[[716.0, 614.0], [751.0, 614.0], [751.0, 819.0], [716.0, 819.0]], [[675.0, 614.0], [710.0, 614.0], [710.0, 852.0], [675.0, 852.0]], [[635.0, 612.0], [664.0, 612.0], [664.0, 768.0], [635.0, 768.0]]], "lines": ["そしてそれは", "俺の望むところ", "でもある。"]}, {"box": [151, 600, 308, 803], "vertical": true, "font_size": 30, "lines_coords": [[[271.0, 600.0], [306.0, 600.0], [306.0, 803.0], [271.0, 803.0]], [[234.0, 602.0], [263.0, 602.0], [263.0, 770.0], [234.0, 770.0]], [[192.0, 602.0], [221.0, 602.0], [221.0, 803.0], [192.0, 803.0]], [[151.0, 604.0], [180.0, 604.0], [180.0, 784.0], [151.0, 784.0]]], "lines": ["．．．つまり奴に", "もう予知を", "させなければ", "いいんだよ。"]}, {"box": [923, 964, 1269, 1207], "vertical": false, "font_size": 28, "lines_coords": [[[934.0, 973.0], [1267.0, 973.0], [1267.0, 999.0], [934.0, 999.0]], [[928.0, 1016.0], [1257.0, 1016.0], [1257.0, 1043.0], [928.0, 1043.0]], [[930.0, 1057.0], [1124.0, 1057.0], [1124.0, 1086.0], [930.0, 1086.0]], [[936.0, 1109.0], [1195.0, 1109.0], [1195.0, 1136.0], [936.0, 1136.0]], [[979.0, 1144.0], [1162.0, 1144.0], [1162.0, 1173.0], [979.0, 1173.0]], [[1031.0, 1178.0], [1213.0, 1178.0], [1213.0, 1206.0], [1031.0, 1206.0]]], "lines": ["Ｓｉｍｍｅａｂｒｅａｋ！！Ｄｕｄｅ", "ｙｏｕｉｒｅｔｈｅｃｏｏｌｅｓｔｇｕｙ", "ｍｉｈｅｗｏｒｄ！", "オイオイ待ってくれ！！", "あんたは最高の", "クールガイさ！！"]}, {"box": [555, 1492, 590, 1647], "vertical": true, "font_size": 35, "lines_coords": [[[555.0, 1492.0], [590.0, 1492.0], [590.0, 1647.0], [555.0, 1647.0]]], "lines": ["７月７日．．．"]}, {"box": [180, 1084, 512, 1324], "vertical": false, "font_size": 32, "lines_coords": [[[184.0, 1088.0], [406.0, 1088.0], [406.0, 1117.0], [184.0, 1117.0]], [[180.0, 1126.0], [439.0, 1128.0], [439.0, 1163.0], [180.0, 1161.0]], [[188.0, 1171.0], [495.0, 1171.0], [495.0, 1206.0], [188.0, 1206.0]], [[186.0, 1221.0], [430.0, 1221.0], [430.0, 1256.0], [186.0, 1256.0]], [[194.0, 1260.0], [499.0, 1260.0], [499.0, 1289.0], [194.0, 1289.0]], [[207.0, 1293.0], [507.0, 1293.0], [507.0, 1322.0], [207.0, 1322.0]]], "lines": ["Ｍｙｂｕｄｄｙｆｏｒｎ", "Ｋａｎｓａｓａｌｓｏｓａｉｄ", "Ｐｅｇａｓｕｓｓｈｏｕｌｄｍｙ", "〈カンザス州の友人も", "言っていたよ『ペガサスは", "空を飛べるはずだ』って。"]}, {"box": [1189, 1480, 1294, 1722], "vertical": true, "font_size": 31, "lines_coords": [[[1259.0, 1480.0], [1290.0, 1480.0], [1294.0, 1664.0], [1263.0, 1664.0]], [[1226.0, 1482.0], [1255.0, 1482.0], [1255.0, 1722.0], [1226.0, 1722.0]], [[1189.0, 1480.0], [1218.0, 1480.0], [1218.0, 1639.0], [1189.0, 1639.0]]], "lines": ["そして彼には", "是非有名になって", "もらいたい。"]}, {"box": [1017, 1695, 1162, 1881], "vertical": true, "font_size": 31, "lines_coords": [[[1120.0, 1695.0], [1162.0, 1695.0], [1162.0, 1768.0], [1120.0, 1768.0]], [[1089.0, 1701.0], [1118.0, 1701.0], [1118.0, 1859.0], [1089.0, 1859.0]], [[1052.0, 1701.0], [1081.0, 1701.0], [1081.0, 1852.0], [1052.0, 1852.0]], [[1017.0, 1701.0], [1044.0, 1701.0], [1044.0, 1881.0], [1017.0, 1881.0]]], "lines": ["彼の", "豪壮な許し、", "博愛過ぎる", "あの精神．．．"]}, {"box": [816, 1616, 886, 1739], "vertical": true, "font_size": 33, "lines_coords": [[[851.0, 1616.0], [886.0, 1616.0], [886.0, 1739.0], [851.0, 1739.0]], [[816.0, 1618.0], [847.0, 1618.0], [847.0, 1720.0], [816.0, 1720.0]]], "lines": ["．．．そして", "無力さ。"]}, {"box": [679, 1846, 797, 2014], "vertical": true, "font_size": 33, "lines_coords": [[[758.0, 1848.0], [797.0, 1848.0], [797.0, 1950.0], [758.0, 1950.0]], [[720.0, 1846.0], [751.0, 1846.0], [747.0, 2014.0], [716.0, 2014.0]], [[679.0, 1850.0], [710.0, 1850.0], [710.0, 1950.0], [679.0, 1950.0]]], "lines": ["美しい", "とは思わん", "かね！？"]}, {"box": [329, 1554, 515, 1807], "vertical": true, "font_size": 35, "lines_coords": [[[470.0, 1554.0], [515.0, 1554.0], [515.0, 1660.0], [470.0, 1660.0]], [[437.0, 1563.0], [472.0, 1563.0], [472.0, 1807.0], [437.0, 1807.0]], [[403.0, 1565.0], [432.0, 1565.0], [432.0, 1776.0], [403.0, 1776.0]], [[368.0, 1565.0], [397.0, 1565.0], [397.0, 1745.0], [368.0, 1745.0]], [[329.0, 1563.0], [366.0, 1563.0], [366.0, 1664.0], [329.0, 1664.0]]], "lines": ["人々が", "いつもと変わらず", "明日への期待と", "不安を抱えて", "眠る時、"]}, {"box": [140, 1786, 283, 2030], "vertical": true, "font_size": 31, "lines_coords": [[[250.0, 1788.0], [281.0, 1788.0], [279.0, 1999.0], [248.0, 1999.0]], [[213.0, 1790.0], [242.0, 1790.0], [242.0, 2006.0], [213.0, 2006.0]], [[176.0, 1786.0], [211.0, 1786.0], [203.0, 2030.0], [167.0, 2030.0]], [[140.0, 1788.0], [169.0, 1788.0], [169.0, 1981.0], [140.0, 1981.0]]], "lines": ["圧倒的な絶望を", "目の当たりにし、", "ペガサスの尊顔を", "思い出すんだ。"]}], "img_path": "178.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [733, 279, 845, 467], "vertical": true, "font_size": 36, "lines_coords": [[[816.0, 283.0], [845.0, 283.0], [845.0, 407.0], [816.0, 407.0]], [[778.0, 285.0], [807.0, 285.0], [807.0, 467.0], [778.0, 467.0]], [[733.0, 279.0], [780.0, 279.0], [780.0, 366.0], [733.0, 366.0]]], "lines": ["その瞬間", "皆は実感する", "のだ。"]}, {"box": [586, 449, 710, 726], "vertical": true, "font_size": 36, "lines_coords": [[[673.0, 449.0], [710.0, 449.0], [704.0, 643.0], [667.0, 643.0]], [[627.0, 453.0], [664.0, 453.0], [667.0, 726.0], [629.0, 726.0]], [[586.0, 453.0], [621.0, 453.0], [621.0, 687.0], [586.0, 687.0]]], "lines": ["「この世界は", "壮大なギャグ漫画", "だったのだ」と。"]}, {"box": [1224, 1151, 1298, 1339], "vertical": true, "font_size": 32, "lines_coords": [[[1251.0, 1151.0], [1298.0, 1151.0], [1298.0, 1225.0], [1251.0, 1225.0]], [[1224.0, 1155.0], [1253.0, 1155.0], [1253.0, 1339.0], [1224.0, 1339.0]]], "lines": ["俺ァ", "信じねェぜ！！"]}, {"box": [1037, 1219, 1139, 1432], "vertical": true, "font_size": 32, "lines_coords": [[[1110.0, 1221.0], [1139.0, 1221.0], [1139.0, 1432.0], [1110.0, 1432.0]], [[1073.0, 1221.0], [1102.0, 1221.0], [1102.0, 1372.0], [1073.0, 1372.0]], [[1037.0, 1219.0], [1064.0, 1219.0], [1064.0, 1428.0], [1037.0, 1428.0]]], "lines": ["アンタがそんな", "優柔不断な", "野郎だなんて！！"]}, {"box": [372, 1157, 482, 1405], "vertical": true, "font_size": 29, "lines_coords": [[[439.0, 1157.0], [474.0, 1157.0], [482.0, 1405.0], [447.0, 1405.0]], [[410.0, 1161.0], [439.0, 1161.0], [439.0, 1372.0], [410.0, 1372.0]], [[372.0, 1161.0], [401.0, 1161.0], [401.0, 1345.0], [372.0, 1345.0]]], "lines": ["いつだって歴史は", "偶然と不思議の", "連続だった．．．"]}, {"box": [174, 1262, 312, 1488], "vertical": true, "font_size": 29, "lines_coords": [[[283.0, 1262.0], [312.0, 1262.0], [312.0, 1445.0], [283.0, 1445.0]], [[244.0, 1264.0], [273.0, 1264.0], [273.0, 1411.0], [244.0, 1411.0]], [[209.0, 1264.0], [238.0, 1264.0], [238.0, 1488.0], [209.0, 1488.0]], [[174.0, 1264.0], [200.0, 1264.0], [200.0, 1453.0], [174.0, 1453.0]]], "lines": ["だったら僕は", "この新しい", "流れに乗りたい。", "．．．そう思うよ。"]}, {"box": [1162, 1577, 1303, 1803], "vertical": true, "font_size": 30, "lines_coords": [[[1273.0, 1581.0], [1302.0, 1581.0], [1302.0, 1759.0], [1273.0, 1759.0]], [[1234.0, 1577.0], [1269.0, 1577.0], [1265.0, 1790.0], [1230.0, 1790.0]], [[1199.0, 1581.0], [1228.0, 1581.0], [1228.0, 1730.0], [1199.0, 1730.0]], [[1162.0, 1577.0], [1191.0, 1577.0], [1191.0, 1799.0], [1162.0, 1799.0]]], "lines": ["．．．そういえば", "ペガサスさんの", "お兄さんが", "言ってましたよ。"]}, {"box": [671, 1637, 814, 1850], "vertical": true, "font_size": 28, "lines_coords": [[[785.0, 1639.0], [814.0, 1639.0], [814.0, 1749.0], [785.0, 1749.0]], [[747.0, 1639.0], [776.0, 1639.0], [776.0, 1790.0], [747.0, 1790.0]], [[712.0, 1639.0], [739.0, 1639.0], [739.0, 1850.0], [712.0, 1850.0]], [[675.0, 1637.0], [704.0, 1637.0], [700.0, 1807.0], [671.0, 1807.0]]], "lines": ["「弟は昔", "大災害から", "人々を救ったと", "言っていた」"]}, {"box": [596, 1881, 660, 2012], "vertical": true, "font_size": 28, "lines_coords": [[[629.0, 1881.0], [660.0, 1881.0], [660.0, 1975.0], [629.0, 1975.0]], [[596.0, 1886.0], [619.0, 1886.0], [619.0, 2012.0], [596.0, 2012.0]]], "lines": ["．．．とか", "なんとか"]}, {"box": [167, 1844, 248, 2030], "vertical": true, "font_size": 36, "lines_coords": [[[211.0, 1844.0], [248.0, 1844.0], [244.0, 1999.0], [207.0, 1999.0]], [[167.0, 1848.0], [203.0, 1848.0], [203.0, 2030.0], [167.0, 2030.0]]], "lines": ["．．．「相模原", "三角事件」！！"]}], "img_path": "179.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1124, 146, 1269, 362], "vertical": true, "font_size": 32, "lines_coords": [[[1238.0, 146.0], [1267.0, 146.0], [1265.0, 362.0], [1236.0, 362.0]], [[1201.0, 146.0], [1230.0, 146.0], [1230.0, 337.0], [1201.0, 337.0]], [[1164.0, 149.0], [1193.0, 149.0], [1193.0, 360.0], [1164.0, 360.0]], [[1124.0, 146.0], [1164.0, 146.0], [1164.0, 229.0], [1124.0, 229.0]]], "lines": ["俺自身その話は", "子供の戯れ事、", "眉唾だと思って", "いる。"]}, {"box": [600, 329, 703, 515], "vertical": true, "font_size": 29, "lines_coords": [[[673.0, 329.0], [702.0, 329.0], [698.0, 511.0], [669.0, 511.0]], [[631.0, 329.0], [667.0, 329.0], [667.0, 515.0], [631.0, 515.0]], [[602.0, 333.0], [625.0, 333.0], [625.0, 467.0], [602.0, 467.0]]], "lines": ["俺の知る限り", "奴にはそんな", "力は無い。"]}, {"box": [283, 304, 368, 511], "vertical": true, "font_size": 41, "lines_coords": [[[316.0, 304.0], [368.0, 304.0], [368.0, 418.0], [316.0, 418.0]], [[283.0, 308.0], [319.0, 308.0], [319.0, 511.0], [283.0, 511.0]]], "lines": ["それに", "言ったろう？"]}, {"box": [1199, 639, 1265, 834], "vertical": true, "font_size": 35, "lines_coords": [[[1236.0, 639.0], [1265.0, 639.0], [1265.0, 792.0], [1236.0, 792.0]], [[1199.0, 639.0], [1228.0, 639.0], [1228.0, 834.0], [1199.0, 834.0]]], "lines": ["できる事は", "ただ予知のみ。"]}, {"box": [988, 685, 1110, 875], "vertical": true, "font_size": 35, "lines_coords": [[[1073.0, 687.0], [1110.0, 687.0], [1110.0, 823.0], [1073.0, 823.0]], [[1029.0, 687.0], [1073.0, 687.0], [1073.0, 797.0], [1029.0, 797.0]], [[988.0, 685.0], [1023.0, 685.0], [1027.0, 875.0], [992.0, 875.0]]], "lines": ["．．．やはり", "結末は", "変わらない。"]}, {"box": [200, 604, 325, 790], "vertical": true, "font_size": 41, "lines_coords": [[[290.0, 606.0], [325.0, 606.0], [325.0, 778.0], [290.0, 778.0]], [[242.0, 604.0], [287.0, 604.0], [287.0, 716.0], [242.0, 716.0]], [[200.0, 606.0], [236.0, 606.0], [240.0, 790.0], [205.0, 790.0]]], "lines": ["彼にはもう", "予知を", "させないと。"]}, {"box": [1238, 1010, 1267, 1163], "vertical": true, "font_size": 32, "lines_coords": [[[1238.0, 1010.0], [1267.0, 1010.0], [1267.0, 1163.0], [1238.0, 1163.0]]], "lines": ["要するに．．．"]}, {"box": [1019, 1078, 1160, 1235], "vertical": true, "font_size": 32, "lines_coords": [[[1131.0, 1080.0], [1160.0, 1080.0], [1160.0, 1231.0], [1131.0, 1231.0]], [[1089.0, 1078.0], [1126.0, 1078.0], [1126.0, 1178.0], [1089.0, 1178.0]], [[1054.0, 1078.0], [1089.0, 1078.0], [1089.0, 1235.0], [1054.0, 1235.0]], [[1019.0, 1080.0], [1048.0, 1080.0], [1048.0, 1215.0], [1019.0, 1215.0]]], "lines": ["和田さんは", "友達を", "裏切ってる", "訳ですね。"]}, {"box": [1222, 1397, 1289, 1608], "vertical": true, "font_size": 29, "lines_coords": [[[1257.0, 1397.0], [1286.0, 1397.0], [1286.0, 1546.0], [1257.0, 1546.0]], [[1222.0, 1399.0], [1251.0, 1399.0], [1251.0, 1608.0], [1222.0, 1608.0]]], "lines": ["それ以前に", "なんと言うか？"]}, {"box": [718, 1393, 798, 1592], "vertical": true, "font_size": 36, "lines_coords": [[[760.0, 1393.0], [797.0, 1393.0], [797.0, 1592.0], [760.0, 1592.0]], [[718.0, 1395.0], [754.0, 1395.0], [754.0, 1573.0], [718.0, 1573.0]]], "lines": ["グッドバイブ", "レーション。"]}, {"box": [372, 981, 441, 1146], "vertical": true, "font_size": 31, "lines_coords": [[[412.0, 983.0], [441.0, 983.0], [441.0, 1103.0], [412.0, 1103.0]], [[372.0, 981.0], [408.0, 981.0], [408.0, 1146.0], [372.0, 1146.0]]], "lines": ["．．．そうさ", "困った男さ。"]}, {"box": [213, 1113, 279, 1293], "vertical": true, "font_size": 31, "lines_coords": [[[250.0, 1113.0], [279.0, 1113.0], [279.0, 1293.0], [250.0, 1293.0]], [[213.0, 1115.0], [242.0, 1115.0], [242.0, 1264.0], [213.0, 1264.0]]], "lines": ["こういう男は", "嫌いかい？"]}, {"box": [196, 1482, 274, 1635], "vertical": true, "font_size": 36, "lines_coords": [[[236.0, 1484.0], [273.0, 1484.0], [273.0, 1621.0], [236.0, 1621.0]], [[196.0, 1482.0], [232.0, 1482.0], [232.0, 1635.0], [196.0, 1635.0]]], "lines": ["悪い返答", "じゃない。"]}, {"box": [890, 1757, 996, 1938], "vertical": true, "font_size": 32, "lines_coords": [[[961.0, 1757.0], [996.0, 1757.0], [996.0, 1881.0], [961.0, 1881.0]], [[923.0, 1757.0], [954.0, 1757.0], [957.0, 1937.0], [925.0, 1937.0]], [[890.0, 1757.0], [919.0, 1757.0], [919.0, 1919.0], [890.0, 1919.0]]], "lines": ["頭大丈夫", "かなー．．．って", "思ってます。"]}, {"box": [176, 1823, 243, 2046], "vertical": true, "font_size": 29, "lines_coords": [[[213.0, 1823.0], [242.0, 1823.0], [242.0, 2004.0], [213.0, 2004.0]], [[176.0, 1823.0], [205.0, 1823.0], [205.0, 2045.0], [176.0, 2045.0]]], "lines": ["．．．はっきりと", "わかったんです。"]}], "img_path": "180.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1203, 163, 1342, 457], "vertical": true, "font_size": 30, "lines_coords": [[[1313.0, 167.0], [1342.0, 167.0], [1342.0, 341.0], [1313.0, 341.0]], [[1273.0, 165.0], [1305.0, 165.0], [1307.0, 455.0], [1276.0, 455.0]], [[1240.0, 165.0], [1269.0, 165.0], [1269.0, 457.0], [1240.0, 457.0]], [[1203.0, 163.0], [1232.0, 163.0], [1232.0, 436.0], [1203.0, 436.0]]], "lines": ["やはり我々は", "あえて不便を受け入れ", "インフラはもっと稲小", "されるべきでしょう。"]}, {"box": [774, 341, 954, 645], "vertical": true, "font_size": 30, "lines_coords": [[[919.0, 341.0], [954.0, 341.0], [954.0, 534.0], [919.0, 534.0]], [[884.0, 341.0], [913.0, 341.0], [913.0, 645.0], [884.0, 645.0]], [[847.0, 343.0], [876.0, 343.0], [876.0, 523.0], [847.0, 523.0]], [[807.0, 341.0], [838.0, 341.0], [841.0, 585.0], [809.0, 585.0]], [[774.0, 343.0], [803.0, 343.0], [803.0, 532.0], [774.0, 532.0]]], "lines": ["時代は追い風、", "子供達の未来のために", "やはり貴方は", "ラヴァーズを救う", "べきなんです。"]}, {"box": [204, 204, 325, 411], "vertical": true, "font_size": 35, "lines_coords": [[[279.0, 204.0], [325.0, 204.0], [325.0, 314.0], [279.0, 314.0]], [[246.0, 209.0], [275.0, 209.0], [275.0, 376.0], [246.0, 376.0]], [[205.0, 209.0], [234.0, 209.0], [234.0, 409.0], [205.0, 409.0]]], "lines": ["横から", "その意見に", "さんせーい！！"]}, {"box": [1056, 478, 1236, 724], "vertical": true, "font_size": 30, "lines_coords": [[[1207.0, 480.0], [1236.0, 480.0], [1236.0, 724.0], [1207.0, 724.0]], [[1168.0, 480.0], [1199.0, 480.0], [1197.0, 695.0], [1166.0, 695.0]], [[1128.0, 478.0], [1160.0, 478.0], [1162.0, 695.0], [1131.0, 695.0]], [[1093.0, 480.0], [1122.0, 480.0], [1122.0, 724.0], [1093.0, 724.0]], [[1056.0, 478.0], [1087.0, 478.0], [1089.0, 705.0], [1058.0, 705.0]]], "lines": ["自由を犠牲にして", "はじめて本当の", "意味での秩序と", "規律の社会が実現", "できるんだって。"]}, {"box": [1168, 1053, 1253, 1273], "vertical": true, "font_size": 41, "lines_coords": [[[1205.0, 1053.0], [1253.0, 1053.0], [1253.0, 1134.0], [1205.0, 1134.0]], [[1168.0, 1055.0], [1203.0, 1055.0], [1203.0, 1273.0], [1168.0, 1273.0]]], "lines": ["俺は", "リアリストだ。"]}, {"box": [963, 1149, 1087, 1325], "vertical": true, "font_size": 41, "lines_coords": [[[1052.0, 1153.0], [1087.0, 1153.0], [1087.0, 1325.0], [1052.0, 1325.0]], [[1008.0, 1153.0], [1046.0, 1153.0], [1046.0, 1291.0], [1008.0, 1291.0]], [[963.0, 1149.0], [1010.0, 1149.0], [1010.0, 1240.0], [963.0, 1240.0]]], "lines": ["オカルトは", "趣味では", "ない。"]}, {"box": [1213, 1486, 1296, 1598], "vertical": true, "font_size": 35, "lines_coords": [[[1259.0, 1492.0], [1296.0, 1492.0], [1296.0, 1598.0], [1259.0, 1598.0]], [[1213.0, 1486.0], [1261.0, 1486.0], [1261.0, 1579.0], [1213.0, 1579.0]]], "lines": ["．．．君は", "神様、"]}, {"box": [490, 1451, 532, 1569], "vertical": true, "font_size": 37, "lines_coords": [[[490.0, 1451.0], [530.0, 1451.0], [532.0, 1569.0], [493.0, 1569.0]]], "lines": ["．．．そう。"]}, {"box": [186, 1128, 331, 1327], "vertical": true, "font_size": 31, "lines_coords": [[[298.0, 1130.0], [327.0, 1130.0], [327.0, 1283.0], [298.0, 1283.0]], [[258.0, 1128.0], [294.0, 1128.0], [294.0, 1254.0], [258.0, 1254.0]], [[223.0, 1130.0], [252.0, 1130.0], [252.0, 1279.0], [223.0, 1279.0]], [[186.0, 1128.0], [215.0, 1128.0], [217.0, 1322.0], [188.0, 1322.0]]], "lines": ["末期症状を", "起こした", "この社会に", "未練など無い。"]}, {"box": [981, 1503, 1168, 1776], "vertical": true, "font_size": 35, "lines_coords": [[[1133.0, 1503.0], [1168.0, 1503.0], [1168.0, 1631.0], [1133.0, 1631.0]], [[1097.0, 1505.0], [1126.0, 1505.0], [1126.0, 1658.0], [1097.0, 1658.0]], [[1060.0, 1505.0], [1089.0, 1505.0], [1089.0, 1776.0], [1060.0, 1776.0]], [[1023.0, 1505.0], [1052.0, 1505.0], [1052.0, 1687.0], [1023.0, 1687.0]], [[981.0, 1503.0], [1021.0, 1503.0], [1021.0, 1600.0], [981.0, 1600.0]]], "lines": ["．．．つまり", "創造神的な", "インテリジェンスな", "存在を信じる", "かい？"]}, {"box": [637, 1861, 745, 2045], "vertical": true, "font_size": 35, "lines_coords": [[[700.0, 1861.0], [745.0, 1861.0], [745.0, 1960.0], [700.0, 1960.0]], [[667.0, 1861.0], [704.0, 1861.0], [704.0, 2045.0], [667.0, 2045.0]], [[638.0, 1865.0], [660.0, 1865.0], [660.0, 1995.0], [638.0, 1995.0]]], "lines": ["いる訳", "ないでしょう", "そんなの。"]}, {"box": [339, 1579, 459, 1784], "vertical": true, "font_size": 37, "lines_coords": [[[424.0, 1579.0], [459.0, 1579.0], [459.0, 1753.0], [424.0, 1753.0]], [[381.0, 1581.0], [416.0, 1581.0], [416.0, 1784.0], [381.0, 1784.0]], [[339.0, 1583.0], [377.0, 1583.0], [377.0, 1699.0], [339.0, 1699.0]]], "lines": ["だが人には", "信じるものが", "必要だ。"]}, {"box": [145, 1844, 252, 2027], "vertical": true, "font_size": 33, "lines_coords": [[[217.0, 1844.0], [252.0, 1844.0], [252.0, 1970.0], [217.0, 1970.0]], [[184.0, 1846.0], [213.0, 1846.0], [213.0, 2026.0], [184.0, 2026.0]], [[145.0, 1846.0], [180.0, 1846.0], [180.0, 1983.0], [145.0, 1983.0]]], "lines": ["．．．前金を", "渡しておくよ", "チュチュ。"]}], "img_path": "181.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1203, 130, 1307, 316], "vertical": true, "font_size": 30, "lines_coords": [[[1278.0, 132.0], [1307.0, 132.0], [1307.0, 256.0], [1278.0, 256.0]], [[1242.0, 134.0], [1271.0, 134.0], [1271.0, 316.0], [1242.0, 316.0]], [[1203.0, 130.0], [1238.0, 130.0], [1238.0, 316.0], [1203.0, 316.0]]], "lines": ["．．．例えば", "金かな夢かな", "絆かな．．．．．？"]}, {"box": [957, 182, 1135, 424], "vertical": true, "font_size": 30, "lines_coords": [[[1104.0, 182.0], [1135.0, 182.0], [1133.0, 397.0], [1102.0, 397.0]], [[1068.0, 184.0], [1095.0, 184.0], [1095.0, 395.0], [1068.0, 395.0]], [[1031.0, 182.0], [1060.0, 182.0], [1060.0, 424.0], [1031.0, 424.0]], [[996.0, 184.0], [1023.0, 184.0], [1023.0, 368.0], [996.0, 368.0]], [[957.0, 184.0], [986.0, 184.0], [986.0, 407.0], [957.0, 407.0]]], "lines": ["否定はしないが", "それら普遍性の", "欠片もないものを", "盲信せずには", "いられないのだ。"]}, {"box": [1226, 919, 1315, 1041], "vertical": true, "font_size": 37, "lines_coords": [[[1263.0, 919.0], [1315.0, 919.0], [1315.0, 1041.0], [1263.0, 1041.0]], [[1226.0, 921.0], [1271.0, 921.0], [1271.0, 1028.0], [1226.0, 1028.0]]], "lines": ["．．．いや、", "１０年前"]}, {"box": [538, 474, 685, 736], "vertical": true, "font_size": 32, "lines_coords": [[[652.0, 480.0], [681.0, 480.0], [681.0, 693.0], [652.0, 693.0]], [[611.0, 474.0], [646.0, 474.0], [648.0, 734.0], [613.0, 734.0]], [[580.0, 480.0], [609.0, 480.0], [609.0, 689.0], [580.0, 689.0]], [[540.0, 476.0], [575.0, 476.0], [573.0, 734.0], [538.0, 734.0]]], "lines": ["だから俺は提示", "してやりたかった、", "絶対的な時代の", "ポップアイコンを。"]}, {"box": [159, 577, 245, 767], "vertical": true, "font_size": 36, "lines_coords": [[[209.0, 577.0], [244.0, 577.0], [244.0, 763.0], [209.0, 763.0]], [[165.0, 577.0], [203.0, 577.0], [196.0, 766.0], [159.0, 766.0]]], "lines": ["「ふとめ座の", "女の子」．．．"]}, {"box": [352, 908, 513, 1146], "vertical": true, "font_size": 32, "lines_coords": [[[478.0, 908.0], [513.0, 908.0], [513.0, 1144.0], [478.0, 1144.0]], [[437.0, 910.0], [472.0, 910.0], [472.0, 1078.0], [437.0, 1078.0]], [[397.0, 910.0], [426.0, 910.0], [426.0, 1144.0], [397.0, 1144.0]], [[352.0, 913.0], [387.0, 913.0], [387.0, 1146.0], [352.0, 1146.0]]], "lines": ["俺は１０年計画で", "奴を時代の", "神様にしてやる", "つもりだった！！"]}, {"box": [965, 1008, 1166, 1248], "vertical": true, "font_size": 37, "lines_coords": [[[1131.0, 1008.0], [1166.0, 1008.0], [1166.0, 1215.0], [1131.0, 1215.0]], [[1091.0, 1010.0], [1120.0, 1010.0], [1120.0, 1211.0], [1091.0, 1211.0]], [[1046.0, 1008.0], [1081.0, 1008.0], [1081.0, 1213.0], [1046.0, 1213.0]], [[1000.0, 1008.0], [1037.0, 1008.0], [1041.0, 1248.0], [1004.0, 1248.0]], [[965.0, 1012.0], [994.0, 1012.0], [994.0, 1178.0], [965.0, 1178.0]]], "lines": ["この街で家族", "３人を殺して", "捕まった男が", "いた事を知って", "いるかい？"]}, {"box": [799, 1455, 906, 1639], "vertical": true, "font_size": 32, "lines_coords": [[[876.0, 1459.0], [905.0, 1459.0], [905.0, 1610.0], [876.0, 1610.0]], [[838.0, 1455.0], [870.0, 1455.0], [865.0, 1639.0], [834.0, 1639.0]], [[799.0, 1459.0], [834.0, 1459.0], [834.0, 1583.0], [799.0, 1583.0]]], "lines": ["僕のことを", "信じてくれた", "のは．．．"]}, {"box": [157, 1053, 298, 1252], "vertical": true, "font_size": 32, "lines_coords": [[[269.0, 1055.0], [298.0, 1055.0], [298.0, 1204.0], [269.0, 1204.0]], [[234.0, 1055.0], [263.0, 1055.0], [263.0, 1206.0], [234.0, 1206.0]], [[192.0, 1053.0], [229.0, 1053.0], [229.0, 1180.0], [192.0, 1180.0]], [[157.0, 1053.0], [186.0, 1053.0], [190.0, 1252.0], [161.0, 1252.0]]], "lines": ["．．．だが奴は", "あっけなく", "出頭して", "しまったのだ。"]}, {"box": [120, 1805, 189, 1984], "vertical": true, "font_size": 29, "lines_coords": [[[157.0, 1807.0], [186.0, 1807.0], [186.0, 1983.0], [157.0, 1983.0]], [[120.0, 1805.0], [149.0, 1805.0], [149.0, 1968.0], [120.0, 1968.0]]], "lines": ["ペガサスだけ", "だったんだ。"]}], "img_path": "182.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1100, 202, 1180, 409], "vertical": true, "font_size": 36, "lines_coords": [[[1137.0, 202.0], [1180.0, 202.0], [1180.0, 349.0], [1137.0, 349.0]], [[1102.0, 209.0], [1131.0, 209.0], [1131.0, 407.0], [1102.0, 407.0]]], "lines": ["．．．すごく", "嬉しかった！！"]}, {"box": [1131, 708, 1305, 1072], "vertical": true, "font_size": 28, "lines_coords": [[[1276.0, 708.0], [1305.0, 708.0], [1305.0, 904.0], [1276.0, 904.0]], [[1238.0, 708.0], [1267.0, 708.0], [1267.0, 1072.0], [1238.0, 1072.0]], [[1201.0, 708.0], [1230.0, 708.0], [1230.0, 952.0], [1201.0, 952.0]], [[1166.0, 710.0], [1193.0, 710.0], [1193.0, 1012.0], [1166.0, 1012.0]], [[1131.0, 710.0], [1157.0, 710.0], [1157.0, 873.0], [1131.0, 873.0]]], "lines": ["音階は数値だ。", "つまり奴のオルゴール説が", "確定すれば宇宙は", "数列に置き換えられる", "ことになる。"]}, {"box": [669, 732, 812, 991], "vertical": true, "font_size": 29, "lines_coords": [[[780.0, 732.0], [812.0, 732.0], [809.0, 950.0], [778.0, 950.0]], [[743.0, 737.0], [772.0, 737.0], [772.0, 946.0], [743.0, 946.0]], [[706.0, 734.0], [735.0, 734.0], [735.0, 948.0], [706.0, 948.0]], [[669.0, 734.0], [696.0, 734.0], [696.0, 991.0], [669.0, 991.0]]], "lines": ["時の概念を越え", "人類が４次元に", "突入するなんて", "ロマンじゃないか。"]}, {"box": [227, 881, 368, 1126], "vertical": true, "font_size": 36, "lines_coords": [[[339.0, 886.0], [368.0, 886.0], [368.0, 1080.0], [339.0, 1080.0]], [[302.0, 886.0], [331.0, 886.0], [331.0, 1105.0], [302.0, 1105.0]], [[267.0, 886.0], [296.0, 886.0], [296.0, 1126.0], [267.0, 1126.0]], [[227.0, 881.0], [263.0, 881.0], [263.0, 993.0], [227.0, 993.0]]], "lines": ["数学は絶対だ。", "俺は絶対を愛し、", "それが俺のテーマ", "なんだ。"]}, {"box": [979, 1084, 1151, 1356], "vertical": true, "font_size": 28, "lines_coords": [[[1124.0, 1084.0], [1151.0, 1084.0], [1151.0, 1298.0], [1124.0, 1298.0]], [[1087.0, 1088.0], [1116.0, 1088.0], [1116.0, 1329.0], [1087.0, 1329.0]], [[1050.0, 1086.0], [1079.0, 1086.0], [1079.0, 1356.0], [1050.0, 1356.0]], [[1012.0, 1084.0], [1041.0, 1084.0], [1041.0, 1353.0], [1012.0, 1353.0]], [[979.0, 1086.0], [1002.0, 1086.0], [1002.0, 1242.0], [979.0, 1242.0]]], "lines": ["．．．わかるかい？", "つまりこの世界は", "無限に小数展開する", "Ｔの一部に過ぎない", "という事だ。"]}, {"box": [1155, 1505, 1300, 1670], "vertical": true, "font_size": 31, "lines_coords": [[[1265.0, 1505.0], [1300.0, 1505.0], [1300.0, 1633.0], [1265.0, 1633.0]], [[1230.0, 1507.0], [1261.0, 1507.0], [1257.0, 1658.0], [1226.0, 1658.0]], [[1195.0, 1509.0], [1224.0, 1509.0], [1224.0, 1660.0], [1195.0, 1660.0]], [[1155.0, 1509.0], [1184.0, 1509.0], [1184.0, 1666.0], [1155.0, 1666.0]]], "lines": ["僕は．．．", "毎日楽しく", "過ごせれば", "いいんです"]}, {"box": [192, 1215, 319, 1387], "vertical": true, "font_size": 36, "lines_coords": [[[265.0, 1215.0], [319.0, 1215.0], [319.0, 1296.0], [265.0, 1296.0]], [[227.0, 1217.0], [271.0, 1217.0], [271.0, 1360.0], [227.0, 1360.0]], [[192.0, 1221.0], [221.0, 1221.0], [221.0, 1387.0], [192.0, 1387.0]]], "lines": ["君の", "テーマは", "なんだい？"]}, {"box": [1108, 1834, 1288, 2078], "vertical": true, "font_size": 31, "lines_coords": [[[1259.0, 1838.0], [1288.0, 1838.0], [1288.0, 1987.0], [1259.0, 1987.0]], [[1220.0, 1836.0], [1251.0, 1836.0], [1249.0, 2078.0], [1218.0, 2078.0]], [[1184.0, 1838.0], [1213.0, 1838.0], [1213.0, 2049.0], [1184.0, 2049.0]], [[1147.0, 1838.0], [1176.0, 1838.0], [1176.0, 2076.0], [1147.0, 2076.0]], [[1108.0, 1834.0], [1147.0, 1834.0], [1147.0, 1915.0], [1108.0, 1915.0]]], "lines": ["その言葉も", "円周率のどこかに", "内包されている", "ことを付け加えて", "おく。"]}, {"box": [677, 1583, 745, 1721], "vertical": true, "font_size": 33, "lines_coords": [[[708.0, 1583.0], [745.0, 1583.0], [745.0, 1683.0], [708.0, 1683.0]], [[677.0, 1587.0], [706.0, 1587.0], [706.0, 1718.0], [677.0, 1718.0]]], "lines": ["できる", "ことなら。"]}, {"box": [453, 1517, 519, 1699], "vertical": true, "font_size": 28, "lines_coords": [[[488.0, 1521.0], [517.0, 1521.0], [517.0, 1668.0], [488.0, 1668.0]], [[453.0, 1517.0], [480.0, 1517.0], [480.0, 1699.0], [453.0, 1699.0]]], "lines": ["この祭りは", "魂の解放だ．．．"]}, {"box": [155, 1768, 297, 2050], "vertical": true, "font_size": 28, "lines_coords": [[[267.0, 1768.0], [296.0, 1768.0], [296.0, 1977.0], [267.0, 1977.0]], [[229.0, 1770.0], [258.0, 1770.0], [258.0, 1979.0], [229.0, 1979.0]], [[192.0, 1768.0], [221.0, 1768.0], [221.0, 1979.0], [192.0, 1979.0]], [[155.0, 1768.0], [182.0, 1768.0], [182.0, 2049.0], [155.0, 2049.0]]], "lines": ["君にもし恋人が", "いるのであれば", "今のうち愛でも", "語らっておきたまえ。"]}], "img_path": "183.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [739, 124, 884, 368], "vertical": true, "font_size": 33, "lines_coords": [[[855.0, 128.0], [884.0, 128.0], [884.0, 281.0], [855.0, 281.0]], [[818.0, 126.0], [847.0, 126.0], [847.0, 339.0], [818.0, 339.0]], [[780.0, 126.0], [809.0, 126.0], [809.0, 368.0], [780.0, 368.0]], [[739.0, 124.0], [776.0, 124.0], [776.0, 223.0], [739.0, 223.0]]], "lines": ["．．．本当なら", "君の話ももっと", "聞いてみたかった", "が．．．"]}, {"box": [638, 356, 754, 587], "vertical": true, "font_size": 33, "lines_coords": [[[714.0, 356.0], [754.0, 356.0], [754.0, 455.0], [714.0, 455.0]], [[675.0, 356.0], [710.0, 356.0], [714.0, 517.0], [679.0, 517.0]], [[638.0, 356.0], [673.0, 356.0], [679.0, 587.0], [644.0, 587.0]]], "lines": ["時空が", "ねじれたら", "またお茶しよう。"]}, {"box": [142, 347, 292, 534], "vertical": true, "font_size": 36, "lines_coords": [[[246.0, 347.0], [292.0, 347.0], [292.0, 447.0], [246.0, 447.0]], [[215.0, 349.0], [250.0, 349.0], [250.0, 505.0], [215.0, 505.0]], [[182.0, 351.0], [211.0, 351.0], [211.0, 534.0], [182.0, 534.0]], [[142.0, 347.0], [178.0, 347.0], [178.0, 507.0], [142.0, 507.0]]], "lines": ["お互い", "苦労するね", "面倒な友人を", "持つと．．．"]}, {"box": [992, 664, 1097, 861], "vertical": true, "font_size": 31, "lines_coords": [[[1060.0, 664.0], [1097.0, 664.0], [1097.0, 763.0], [1060.0, 763.0]], [[1027.0, 668.0], [1056.0, 668.0], [1056.0, 850.0], [1027.0, 850.0]], [[992.0, 664.0], [1019.0, 664.0], [1019.0, 855.0], [992.0, 855.0]]], "lines": ["．．．もう", "諦めましたよ", "そういうのは、"]}, {"box": [217, 768, 292, 892], "vertical": true, "font_size": 38, "lines_coords": [[[254.0, 768.0], [292.0, 768.0], [292.0, 892.0], [254.0, 892.0]], [[217.0, 768.0], [254.0, 768.0], [254.0, 875.0], [217.0, 875.0]]], "lines": ["．．．変な人", "ですね。"]}, {"box": [1236, 1035, 1271, 1171], "vertical": true, "font_size": 33, "lines_coords": [[[1236.0, 1035.0], [1271.0, 1035.0], [1271.0, 1171.0], [1236.0, 1171.0]]], "lines": ["だろう？"]}, {"box": [1139, 1242, 1213, 1391], "vertical": true, "font_size": 33, "lines_coords": [[[1178.0, 1242.0], [1213.0, 1242.0], [1213.0, 1380.0], [1178.0, 1380.0]], [[1139.0, 1246.0], [1168.0, 1246.0], [1168.0, 1391.0], [1139.0, 1391.0]]], "lines": ["自分でも", "そう思う。"]}, {"box": [675, 1436, 847, 1612], "vertical": true, "font_size": 42, "lines_coords": [[[799.0, 1436.0], [847.0, 1436.0], [847.0, 1519.0], [799.0, 1519.0]], [[762.0, 1443.0], [799.0, 1443.0], [799.0, 1612.0], [762.0, 1612.0]], [[718.0, 1440.0], [756.0, 1440.0], [758.0, 1612.0], [720.0, 1612.0]], [[675.0, 1440.0], [722.0, 1440.0], [722.0, 1532.0], [675.0, 1532.0]]], "lines": ["では", "最後に一言", "申し述べて", "おく。"]}, {"box": [319, 1091, 462, 1313], "vertical": true, "font_size": 27, "lines_coords": [[[435.0, 1095.0], [457.0, 1095.0], [457.0, 1242.0], [435.0, 1242.0]], [[391.0, 1091.0], [420.0, 1091.0], [424.0, 1310.0], [395.0, 1310.0]], [[358.0, 1093.0], [387.0, 1093.0], [387.0, 1244.0], [358.0, 1244.0]], [[319.0, 1091.0], [348.0, 1091.0], [348.0, 1242.0], [319.0, 1242.0]]], "lines": ["人生をどう", "楽しもうと自由、", "己の自意識", "次第だろ？"]}, {"box": [551, 1685, 718, 1956], "vertical": true, "font_size": 42, "lines_coords": [[[679.0, 1687.0], [716.0, 1687.0], [718.0, 1861.0], [681.0, 1861.0]], [[633.0, 1689.0], [679.0, 1689.0], [679.0, 1799.0], [633.0, 1799.0]], [[598.0, 1691.0], [633.0, 1691.0], [633.0, 1956.0], [598.0, 1956.0]], [[551.0, 1685.0], [600.0, 1685.0], [600.0, 1749.0], [551.0, 1749.0]]], "lines": ["俺にとって", "人生は", "ＯＭＯＳＨＩＲＯ", "だ。"]}, {"box": [149, 1859, 234, 1968], "vertical": true, "font_size": 44, "lines_coords": [[[188.0, 1859.0], [234.0, 1859.0], [234.0, 1968.0], [188.0, 1968.0]], [[149.0, 1859.0], [192.0, 1859.0], [192.0, 1968.0], [149.0, 1968.0]]], "lines": ["だから", "俺は："]}], "img_path": "184.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1151, 207, 1246, 377], "vertical": true, "font_size": 42, "lines_coords": [[[1205.0, 211.0], [1242.0, 211.0], [1242.0, 372.0], [1205.0, 372.0]], [[1151.0, 207.0], [1197.0, 207.0], [1197.0, 335.0], [1151.0, 335.0]]], "lines": ["星川敏樹", "を．．．．．"]}, {"box": [174, 482, 325, 730], "vertical": true, "font_size": 41, "lines_coords": [[[277.0, 482.0], [321.0, 482.0], [325.0, 645.0], [281.0, 645.0]], [[232.0, 486.0], [271.0, 486.0], [271.0, 691.0], [232.0, 691.0]], [[178.0, 482.0], [219.0, 482.0], [215.0, 728.0], [174.0, 728.0]]], "lines": ["みんなの", "神様にして", "やるんだ．．．．．"]}, {"box": [397, 997, 434, 1