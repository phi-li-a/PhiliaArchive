0, 1209.0], [652.0, 1209.0]]], "lines": ["「．．．じゃあ", "流れ星なんかが", "二度と流れて", "こないようにって", "お願いする。」"]}, {"box": [921, 1811, 959, 1948], "vertical": true, "font_size": 38, "lines_coords": [[[921.0, 1811.0], [959.0, 1811.0], [959.0, 1948.0], [921.0, 1948.0]]], "lines": ["それだったのか"]}], "img_path": "198.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [240, 279, 356, 407], "vertical": false, "font_size": 38, "lines_coords": [[[258.0, 317.0], [308.0, 317.0], [308.0, 338.0], [258.0, 338.0]], [[252.0, 334.0], [331.0, 334.0], [331.0, 361.0], [252.0, 361.0]], [[240.0, 336.0], [339.0, 336.0], [339.0, 410.0], [240.0, 410.0]]], "lines": ["貴様はねえみえええん？もそれの時子供のカップルですか？", "おまえもちょっということもありますほどのままでしておいしょうかもしれませんが．．．わからなかったのだからこれから", "わーっとしてくださいっているのですから、それはそうだったのだろうなんでしょうがないのかなんだかわからなかったんですが．．．ありがとうございませんかないですね。"]}, {"box": [488, 279, 602, 399], "vertical": false, "font_size": 21, "lines_coords": [[[493.0, 285.0], [575.0, 279.0], [577.0, 308.0], [495.0, 314.0]], [[505.0, 306.0], [573.0, 306.0], [573.0, 327.0], [505.0, 327.0]], [[503.0, 322.0], [588.0, 316.0], [590.0, 339.0], [505.0, 345.0]], [[499.0, 341.0], [592.0, 335.0], [594.0, 358.0], [501.0, 364.0]], [[495.0, 360.0], [573.0, 360.0], [573.0, 380.0], [495.0, 380.0]], [[499.0, 380.0], [546.0, 380.0], [546.0, 389.0], [499.0, 389.0]]], "lines": ["いろいろ勝ちだ", "『私は見てて", "前回はいかにして", "や．．．あのうじゃ", "できますようお", "．．．"]}, {"box": [515, 434, 590, 457], "vertical": false, "font_size": 23, "lines_coords": [[[515.0, 434.0], [590.0, 434.0], [590.0, 457.0], [515.0, 457.0]]], "lines": ["邦外よ！！"]}, {"box": [855, 278, 990, 339], "vertical": false, "font_size": 28, "lines_coords": [[[859.0, 281.0], [979.0, 279.0], [979.0, 306.0], [859.0, 308.0]], [[867.0, 308.0], [981.0, 302.0], [983.0, 335.0], [870.0, 341.0]]], "lines": ["確かにバカっていたで", "悪いの事実だければいいの"]}, {"box": [455, 708, 977, 891], "vertical": false, "font_size": 82, "lines_coords": [[[455.0, 745.0], [799.0, 708.0], [807.0, 795.0], [464.0, 832.0]], [[509.0, 813.0], [894.0, 805.0], [896.0, 881.0], [511.0, 890.0]]], "lines": ["ニュームサイの", "来年もおに来まーで"]}, {"box": [553, 906, 903, 1010], "vertical": false, "font_size": 34.666666666666664, "lines_coords": [[[553.0, 915.0], [903.0, 906.0], [903.0, 956.0], [553.0, 964.0]], [[582.0, 950.0], [627.0, 950.0], [627.0, 975.0], [582.0, 975.0]], [[557.0, 981.0], [642.0, 977.0], [644.0, 1006.0], [559.0, 1010.0]]], "lines": ["ちゃぁーやういみあった", "やれやれ", "都道府県"]}], "img_path": "199.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [963, 138, 1004, 364], "vertical": true, "font_size": 41, "lines_coords": [[[963.0, 138.0], [1004.0, 138.0], [1004.0, 364.0], [963.0, 364.0]]], "lines": ["それあれ"]}, {"box": [178, 136, 298, 401], "vertical": true, "font_size": 81, "lines_coords": [[[217.0, 136.0], [298.0, 149.0], [258.0, 401.0], [178.0, 389.0]]], "lines": ["イッス！"]}, {"box": [1222, 931, 1269, 1008], "vertical": true, "font_size": 44, "lines_coords": [[[1222.0, 931.0], [1269.0, 931.0], [1269.0, 1008.0], [1222.0, 1008.0]]], "lines": ["ズッ"]}, {"box": [1157, 1020, 1197, 1084], "vertical": true, "font_size": 44, "lines_coords": [[[1157.0, 1020.0], [1197.0, 1020.0], [1197.0, 1084.0], [1157.0, 1084.0]]], "lines": ["ズッ"]}, {"box": [733, 556, 791, 648], "vertical": true, "font_size": 58, "lines_coords": [[[733.0, 556.0], [791.0, 556.0], [791.0, 648.0], [733.0, 648.0]]], "lines": ["はっ"]}, {"box": [936, 1024, 969, 1083], "vertical": true, "font_size": 33, "lines_coords": [[[936.0, 1024.0], [969.0, 1024.0], [969.0, 1083.0], [936.0, 1083.0]]], "lines": ["ズッ"]}, {"box": [227, 683, 285, 815], "vertical": true, "font_size": 54, "lines_coords": [[[232.0, 683.0], [285.0, 685.0], [281.0, 815.0], [227.0, 813.0]]], "lines": ["はっ．．．"]}, {"box": [530, 1086, 577, 1163], "vertical": true, "font_size": 47, "lines_coords": [[[530.0, 1086.0], [577.0, 1086.0], [577.0, 1163.0], [530.0, 1163.0]]], "lines": ["ズッ"]}, {"box": [312, 1380, 358, 1449], "vertical": true, "font_size": 42, "lines_coords": [[[312.