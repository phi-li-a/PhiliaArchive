34, "lines_coords": [[[950.0, 1378.0], [979.0, 1378.0], [979.0, 1561.0], [950.0, 1561.0]], [[909.0, 1378.0], [944.0, 1378.0], [944.0, 1565.0], [909.0, 1565.0]], [[870.0, 1374.0], [913.0, 1374.0], [913.0, 1432.0], [870.0, 1432.0]]], "lines": ["．．．いや、でも", "俺も悪かった", "よ。"]}, {"box": [716, 1432, 822, 1600], "vertical": true, "font_size": 34, "lines_coords": [[[783.0, 1432.0], [822.0, 1432.0], [822.0, 1532.0], [783.0, 1532.0]], [[751.0, 1434.0], [780.0, 1434.0], [780.0, 1587.0], [751.0, 1587.0]], [[716.0, 1436.0], [743.0, 1436.0], [743.0, 1600.0], [716.0, 1600.0]]], "lines": ["向いて", "ないんだな", "こういうの。"]}, {"box": [507, 1404, 584, 1573], "vertical": true, "font_size": 36, "lines_coords": [[[548.0, 1405.0], [584.0, 1405.0], [584.0, 1540.0], [548.0, 1540.0]], [[507.0, 1405.0], [542.0, 1405.0], [542.0, 1573.0], [507.0, 1573.0]]], "lines": ["．．．はっは", "何でだよ？"]}, {"box": [219, 1086, 258, 1275], "vertical": true, "font_size": 35, "lines_coords": [[[219.0, 1086.0], [254.0, 1086.0], [258.0, 1275.0], [223.0, 1275.0]]], "lines": ["馬鹿だなぁ。"]}, {"box": [1234, 1728, 1271, 1875], "vertical": true, "font_size": 37, "lines_coords": [[[1234.0, 1728.0], [1271.0, 1728.0], [1271.0, 1871.0], [1234.0, 1871.0]]], "lines": ["．．．この事、"]}, {"box": [668, 1739, 785, 1955], "vertical": true, "font_size": 31, "lines_coords": [[[749.0, 1739.0], [785.0, 1739.0], [785.0, 1879.0], [749.0, 1879.0]], [[712.0, 1743.0], [741.0, 1743.0], [741.0, 1906.0], [712.0, 1906.0]], [[669.0, 1741.0], [698.0, 1741.0], [698.0, 1952.0], [669.0, 1952.0]]], "lines": ["ちゃんと", "お父さんに", "報告するから。"]}, {"box": [192, 1823, 272, 1995], "vertical": true, "font_size": 36, "lines_coords": [[[236.0, 1826.0], [271.0, 1826.0], [271.0, 1962.0], [236.0, 1962.0]], [[192.0, 1823.0], [229.0, 1823.0], [229.0, 1995.0], [192.0, 1995.0]]], "lines": ["．．．好きに", "すれば．．．"]}], "img_path": "155.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1118, 472, 1154, 670], "vertical": true, "font_size": 35, "lines_coords": 