0], [182.0, 411.0], [153.0, 411.0]]], "lines": ["この件はもう", "時間切れと", "言って差し支え", "ないのだ。"]}, {"box": [828, 558, 909, 801], "vertical": true, "font_size": 36, "lines_coords": [[[867.0, 558.0], [909.0, 558.0], [903.0, 801.0], [861.0, 801.0]], [[828.0, 563.0], [857.0, 563.0], [857.0, 766.0], [828.0, 766.0]]], "lines": ["「できなかった」", "と言ったな？"]}, {"box": [698, 861, 818, 1088], "vertical": true, "font_size": 36, "lines_coords": [[[780.0, 861.0], [818.0, 861.0], [812.0, 1088.0], [774.0, 1088.0]], [[737.0, 865.0], [772.0, 865.0], [772.0, 1053.0], [737.0, 1053.0]], [[698.0, 865.0], [733.0, 865.0], [733.0, 1004.0], [698.0, 1004.0]]], "lines": ["「やらなければ", "ならない」の", "だろう？"]}, {"box": [171, 1037, 318, 1312], "vertical": true, "font_size": 30, "lines_coords": [[[285.0, 1039.0], [314.0, 1039.0], [314.0, 1221.0], [285.0, 1221.0]], [[246.0, 1037.0], [281.0, 1037.0], [281.0, 1312.0], [246.0, 1312.0]], [[211.0, 1039.0], [240.0, 1039.0], [240.0, 1252.0], [211.0, 1252.0]], [[171.0, 1041.0], [200.0, 1041.0], [200.0, 1171.0], [171.0, 1171.0]]], "lines": ["黒点の隠滅は", "我々にとって重要な", "テーゼだったと", "いうのに"]}, {"box": [192, 1370, 249, 1525], "vertical": true, "font_size": 44, "lines_coords": [[[192.0, 1370.0], [236.0, 1370.0], [236.0, 1525.0], [192.0, 1525.0]]], "lines": ["．．．和田君。"]}, {"box": [1199, 1594, 1228, 1799], "vertical": true, "font_size": 32, "lines_coords": [[[1199.0, 1594.0], [1228.0, 1594.0], [1228.0, 1799.0], [1199.0, 1799.0]]], "lines": ["もしかしたら、"]}, {"box": [940, 1776, 1139, 1979], "vertical": true, "font_size": 32, "lines_coords": [[[1108.0, 1776.0], [1139.0, 1776.0], [1137.0, 1977.0], [1106.0, 1977.0]], [[1064.0, 1778.0], [1099.0, 1778.0], [1099.0, 1977.0], [1064.0, 1977.0]], [[1025.0, 1778.0], [1054.0, 1778.0], [1054.0, 1977.0], [1025.0, 1977.0]], [[979.0, 1776.0], [1015.0, 1776.0], [1015.0, 1979.0], [979.0, 1979.0]], [[940.0, 1778.0], [969.0, 1778.0], [969.0, 1917.0], [940.0, 1917.0]]], "lines": ["この世の中は", "僕が思うより", "ずっとずつと", "平凡なのかも", "しれない"]}, {"box": [182, 1784, 306, 1987], "vertical": true, "font_size": 39, "lines_coords": [[[254.0, 1784.0], [306.0, 1784.0], [306.0, 1898.0], [254.0, 1898.0]], [[219.0, 1788.0], [256.0, 1788.0], [256.0, 1925.0], [219.0, 1925.0]], [[182.0, 1790.0], [211.0, 1790.0], [211.0, 1985.0], [182.0, 1985.0]]], "lines": ["．．．一体", "黒点とは", "何なんだい？"]}], "img_path": "101.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1182, 94, 1282, 277], "vertical": true, "font_size": 27, "lines_coords": [[[1253.0, 95.0], [1282.0, 95.0], [1282.0, 275.0], [1253.0, 275.0]], [[1215.0, 95.0], [1244.0, 95.0], [1244.0, 277.0], [1215.0, 277.0]], [[1182.0, 95.0], [1205.0, 95.0], [1205.0, 244.0], [1182.0, 244.0]]], "lines": ["そんな議論を", "してる時間は", "もう無い！！"]}, {"box": [828, 186, 971, 372], "vertical": true, "font_size": 33, "lines_coords": [[[936.0, 186.0], [971.0, 186.0], [971.0, 310.0], [936.0, 310.0]], [[901.0, 188.0], [930.0, 188.0], [930.0, 339.0], [901.0, 339.0]], [[861.0, 188.0], [896.0, 188.0], [896.0, 372.0], [861.0, 372.0]], [[828.0, 192.0], [857.0, 192.0], [857.0, 341.0], [828.0, 341.0]]], "lines": ["君は僕の", "言う事だけ", "聞いていれば", "いいのさ．．．"]}, {"box": [585, 95, 704, 367], "vertical": true, "font_size": 48, "lines_coords": [[[652.0, 95.0], [704.0, 95.0], [704.0, 258.0], [652.0, 258.0]], [[588.0, 97.0], [633.0, 97.0], [635.0, 366.0], [590.0, 366.0]]], "lines": ["．．．この", "愚か者ォ！！"]}, {"box": [1238, 933, 1276, 1070], "vertical": true, "font_size": 44, "lines_coords": [[[1238.0, 933.0], [1276.0, 933.0], [1276.0, 1070.0], [1238.0, 1070.0]]], "lines": ["君は今．．．"]}, {"box": [1025, 985, 1157, 1124], "vertical": true, "font_size": 44, "lines_coords": [[[1108.0, 985.0], [1157.0, 985.0], [1157.0, 1064.0], [1108.0, 1064.0]], [[1066.0, 987.0], [1112.0, 987.0], [1112.0, 1124.0], [1066.0, 1124.0]], [[1025.0, 985.0], [1070.0, 985.0], [1070.0, 1095.0], [1025.0, 1095.0]]], "lines": ["最も", "神に近い", "男．．．．．"]}, {"box": [778, 459, 938, 668], "vertical": true, "font_size": 33, "lines_coords": [[[901.0, 459.0], [938.0, 459.0], [938.0, 583.0], [901.0, 583.0]], [[859.0, 459.0], [894.0, 459.0], [894.0, 668.0], [859.0, 668.0]], [[816.0, 461.0], [851.0, 461.0], [851.0, 614.0], [816.0, 614.0]], [[778.0, 463.0], [807.0, 463.0], [807.0, 598.0], [778.0, 598.0]]], "lines": ["「世界は", "もっと美しく", "なれる」ん", "だろう！？"]}, {"box": [157, 525, 343, 855], "vertical": true, "font_size": 55, "lines_coords": [[[285.0, 527.0], [341.0, 527.0], [341.0, 855.0], [285.0, 855.0]], [[219.0, 525.0], [277.0, 525.0], [277.0, 801.0], [219.0, 801.0]], [[157.0, 534.0], [207.0, 534.0], [207.0, 855.0], [157.0, 855.0]]], "lines": ["しかしながら", "愛さずには", "いられない！！"]}, {"box": [1173, 1300, 1251, 1573], "vertical": true, "font_size": 34, "lines_coords": [[[1213.0, 1304.0], [1251.0, 1304.0], [1251.0, 1409.0], [1213.0, 1409.0]], [[1176.0, 1304.0], [1205.0, 1304.0], [1205.0, 1571.0], [1176.0, 1571.0]]], "lines": ["．．．もう", "行くっきゃない！！"]}, {"box": [246, 987, 282, 1141], "vertical": true, "font_size": 35, "lines_coords": [[[246.0, 987.0], [281.0, 987.0], [281.0, 1138.0], [246.0, 1138.0]]], "lines": ["：イエス。"]}, {"box": [275, 1674, 338, 1879], "vertical": true, "font_size": 50, "lines_coords": [[[275.0, 1674.0], [325.0, 1674.0], [325.0, 1879.0], [275.0, 1879.0]]], "lines": ["宇宙へ．．．"]}], "img_path": "102.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1018, 172, 1195, 507], "vertical": true, "font_size": 29, "lines_coords": [[[1166.0, 173.0], [1195.0, 173.0], [1195.0, 418.0], [1166.0, 418.0]], [[1128.0, 173.0], [1157.0, 173.0], [1157.0, 476.0], [1128.0, 476.0]], [[1091.0, 173.0], [1120.0, 173.0], [1120.0, 507.0], [1091.0, 507.0]], [[1054.0, 173.0], [1083.0, 173.0], [1083.0, 476.0], [1054.0, 476.0]], [[1019.0, 173.0], [1046.0, 173.0], [1046.0, 360.0], [1019.0, 360.0]]], "lines": ["進展期においては", "供給過多・需要不足が", "１９５３〜１９：９９年の", "入力と出力から政治を", "経験しており、"]}, {"box": [229, 256, 408, 563], "vertical": true, "font_size": 29, "lines_coords": [[[377.0, 260.0], [406.0, 260.0], [406.0, 469.0], [377.0, 469.0]], [[339.0, 260.0], [368.0, 260.0], [368.0, 563.0], [339.0, 563.0]], [[302.0, 260.0], [331.0, 260.0], [331.0, 563.0], [302.0, 563.0]], [[265.0, 260.0], [294.0, 260.0], [294.0, 563.0], [265.0, 563.0]], [[229.0, 256.0], [258.0, 256.0], [258.0, 534.0], [229.0, 534.0]]], "lines": ["イデオロギーが", "抜本的に掌握している", "ため、生徒数の減少が", "加速しており過失障害", "が世界中に報道され"]}, {"box": [187, 1786, 290, 1966], "vertical": true, "font_size": 27, "lines_coords": [[[256.0, 1790.0], [285.0, 1790.0], [285.0, 1939.0], [256.0, 1939.0]], [[221.0, 1786.0], [250.0, 1786.0], [248.0, 1966.0], [219.0, 1966.0]], [[188.0, 1790.0], [211.0, 1790.0], [211.0, 1941.0], [188.0, 1941.0]]], "lines": ["科学理論に", "構造主義者の", "認識主体は"]}], "img_path": "103.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1147, 124, 1296, 312], "vertical": true, "font_size": 35, "lines_coords": [[[1265.0, 132.0], [1294.0, 132.0], [1294.0, 308.0], [1265.0, 308.0]], [[1224.0, 128.0], [1259.0, 128.0], [1259.0, 285.0], [1224.0, 285.0]], [[1191.0, 130.0], [1220.0, 130.0], [1220.0, 312.0], [1191.0, 312.0]], [[1147.0, 124.0], [1193.0, 124.0], [1193.0, 207.0], [1147.0, 207.0]]], "lines": ["西ヨーロッパ", "全域で検証", "不可能である", "場合、"]}, {"box": [675, 250, 855, 666], "vertical": false, "font_size": 132, "lines_coords": [[[675.0, 347.0], [747.0, 339.0], [780.0, 587.0], [708.0, 596.0]], [[793.0, 322.0], [855.0, 565.0], [799.0, 579.0], [737.0, 337.0]]], "lines": ["私は不幸に", "今世モットサード"]}, {"box": [1114, 857, 1254, 1052], "vertical": true, "font_size": 31, "lines_coords": [[[1224.0, 859.0], [1253.0, 859.0], [1249.0, 1012.0], [1220.0, 1012.0]], [[1184.0, 857.0], [1220.0, 859.0], [1213.0, 1014.0], [1178.0, 1012.0]], [[1147.0, 861.0], [1176.0, 861.0], [1176.0, 981.0], [1147.0, 981.0]], [[1114.0, 861.0], [1143.0, 861.0], [1143.0, 1049.0], [1114.0, 1049.0]]], "lines": ["雇用形態が", "派遣である", "細胞膜は", "流動性を持ち、"]}, {"box": [592, 602, 704, 732], "vertical": true, "font_size": 39, "lines_coords": [[[669.0, 606.0], [704.0, 606.0], [704.0, 732.0], [669.0, 732.0]], [[633.0, 606.0], [669.0, 606.0], [669.0, 732.0], [633.0, 732.0]], [[592.0, 602.0], [638.0, 602.0], [638.0, 685.0], [592.0, 685.0]]], "lines": ["排他的な", "嫌悪感も", "強く、"]}, {"box": [215, 1024, 358, 1234], "vertical": true, "font_size": 28, "lines_coords": [[[327.0, 1024.0], [356.0, 1024.0], [356.0, 1144.0], [327.0, 1144.0]], [[287.0, 1024.0], [316.0, 1024.0], [316.0, 1204.0], [287.0, 1204.0]], [[252.0, 1024.0], [279.0, 1024.0], [279.0, 1233.0], [252.0, 1233.0]], [[215.0, 1028.0], [244.0, 1028.0], [244.0, 1186.0], [215.0, 1186.0]]], "lines": ["世界保健", "機関と無作為", "抽出した体罰の", "一つである。"]}], "img_path": "104.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1097, 851, 1134, 1060], "vertical": true, "font_size": 36, "lines_coords": [[[1097.0, 867.0], [1133.0, 867.0], [1133.0, 1053.0], [1097.0, 1053.0]]], "lines": ["．．．起きた？」"]}, {"box": [737, 888, 773, 1028], "vertical": true, "font_size": 35, "lines_coords": [[[737.0, 888.0], [772.0, 888.0], [772.0, 1026.0], [737.0, 1026.0]]], "lines": ["ごめん．．．"]}, {"box": [198, 590, 250, 730], "vertical": true, "font_size": 52, "lines_coords": [[[198.0, 592.0], [250.0, 592.0], [250.0, 730.0], [198.0, 730.0]]], "lines": ["．．．ああ、"]}, {"box": [1054, 1484, 1182, 1627], "vertical": true, "font_size": 42, "lines_coords": [[[1131.0, 1484.0], [1182.0, 1484.0], [1182.0, 1614.0], [1131.0, 1614.0]], [[1095.0, 1488.0], [1133.0, 1488.0], [1133.0, 1625.0], [1095.0, 1625.0]], [[1054.0, 1488.0], [1091.0, 1488.0], [1091.0, 1627.0], [1054.0, 1627.0]]], "lines": ["「．．．少し", "うなされ", "てたよ。」"]}, {"box": [165, 1175, 246, 1351], "vertical": true, "font_size": 40, "lines_coords": [[[211.0, 1182.0], [246.0, 1182.0], [246.0, 1351.0], [211.0, 1351.0]], [[165.0, 1175.0], [209.0, 1175.0], [209.0, 1287.0], [165.0, 1287.0]]], "lines": ["寝ちゃって", "た．．．"]}, {"box": [567, 1461, 725, 1810], "vertical": true, "font_size": 41, "lines_coords": [[[683.0, 1465.0], [718.0, 1465.0], [718.0, 1600.0], [683.0, 1600.0]], [[646.0, 1668.0], [691.0, 1668.0], [691.0, 1782.0], [646.0, 1782.0]], [[602.0, 1668.0], [648.0, 1668.0], [648.0, 1780.0], [602.0, 1780.0]], [[567.0, 1670.0], [604.0, 1670.0], [604.0, 1809.0], [567.0, 1809.0]]], "lines": ["なんか．．．", "すごく", "嫌な夢", "だった．．．"]}, {"box": [171, 1792, 250, 1963], "vertical": true, "font_size": 37, "lines_coords": [[[205.0, 1792.0], [250.0, 1792.0], [250.0, 1900.0], [205.0, 1900.0]], [[171.0, 1797.0], [200.0, 1797.0], [200.0, 1962.0], [171.0, 1962.0]]], "lines": ["高校の", "授業中で．．．"]}], "img_path": "105.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [845, 113, 983, 356], "vertical": true, "font_size": 29, "lines_coords": [[[954.0, 115.0], [983.0, 115.0], [983.0, 298.0], [954.0, 298.0]], [[917.0, 115.0], [946.0, 115.0], [946.0, 327.0], [917.0, 327.0]], [[880.0, 113.0], [909.0, 113.0], [909.0, 356.0], [880.0, 356.0]], [[845.0, 113.0], [872.0, 113.0], [872.0, 298.0], [845.0, 298.0]]], "lines": ["数学の磯畑は", "いつもあたしに", "難しい問題ばかり", "当ててきて．．．"]}, {"box": [696, 260, 836, 507], "vertical": true, "font_size": 29, "lines_coords": [[[809.0, 260.0], [836.0, 260.0], [836.0, 440.0], [809.0, 440.0]], [[772.0, 262.0], [801.0, 262.0], [801.0, 472.0], [772.0, 472.0]], [[735.0, 262.0], [764.0, 262.0], [764.0, 440.0], [735.0, 440.0]], [[696.0, 260.0], [731.0, 260.0], [731.0, 507.0], [696.0, 507.0]]], "lines": ["本当はトイレ", "我慢してるけど", "トイレは湖の", "向こう側にあって"]}, {"box": [234, 221, 329, 606], "vertical": true, "font_size": 40, "lines_coords": [[[285.0, 221.0], [329.0, 221.0], [329.0, 333.0], [285.0, 333.0]], [[269.0, 428.0], [316.0, 428.0], [316.0, 511.0], [269.0, 511.0]], [[236.0, 436.0], [265.0, 436.0], [265.0, 604.0], [236.0, 604.0]]], "lines": ["あと．．．", "あと", "何だっけ．．．"]}, {"box": [749, 811, 785, 950], "vertical": true, "font_size": 36, "lines_coords": [[[749.0, 811.0], [785.0, 811.0], [785.0, 948.0], [749.0, 948.0]]], "lines": ["あれ．．．"]}, {"box": [176, 1043, 321, 1231], "vertical": true, "font_size": 32, "lines_coords": [[[287.0, 1045.0], [319.0, 1045.0], [321.0, 1231.0], [290.0, 1231.0]], [[252.0, 1047.0], [281.0, 1047.0], [281.0, 1229.0], [252.0, 1229.0]], [[215.0, 1045.0], [244.0, 1045.0], [244.0, 1196.0], [215.0, 1196.0]], [[176.0, 1043.0], [213.0, 1043.0], [213.0, 1144.0], [176.0, 1144.0]]], "lines": ["今こうやって", "話してるのは", "夢じゃない", "よね？"]}, {"box": [1120, 1525, 1160, 1730], "vertical": true, "font_size": 36, "lines_coords": [[[1120.0, 1525.0], [1155.0, 1525.0], [1160.0, 1730.0], [1124.0, 1730.0]]], "lines": ["「．．．現実だよ。"]}, {"box": [221, 1819, 258, 1956], "vertical": true, "font_size": 37, "lines_coords": [[[221.0, 1819.0], [258.0, 1819.0], [258.0, 1956.0], [221.0, 1956.0]]], "lines": ["そっか．．．"]}], "img_path": "106.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [263, 1445, 299, 1616], "vertical": true, "font_size": 35, "lines_coords": [[[263.0, 1445.0], [298.0, 1445.0], [298.0, 1614.0], [263.0, 1614.0]]], "lines": ["そっか．．．"]}], "img_path": "107.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "108.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [140, 118, 673, 484], "vertical": false, "font_size": 126, "lines_coords": [[[140.0, 118.0], [594.0, 118.0], [594.0, 248.0], [140.0, 248.0]], [[142.0, 242.0], [648.0, 236.0], [650.0, 360.0], [145.0, 366.0]], [[153.0, 356.0], [673.0, 360.0], [673.0, 484.0], [153.0, 480.0]]], "lines": ["本作品純屬虚構，", "典實際存在的團體、", "人物皆無任何粛係。"]}], "img_path": "109.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "110.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [268, 273, 703, 341], "vertical": false, "font_size": 61, "lines_coords": [[[298.0, 268.0], [681.0, 280.0], [679.0, 346.0], [296.0, 334.0]]], "lines": ["オオオォォ"]}], "img_path": "111.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "112.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "113.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "114.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "115.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "116.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "117.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [654, 1157, 820, 1474], "vertical": true, "font_size": 34, "lines_coords": [[[783.0, 1165.0], [820.0, 1165.0], [820.0, 1248.0], [783.0, 1248.0]], [[739.0, 1159.0], [774.0, 1159.0], [774.0, 1471.0], [739.0, 1471.0]], [[700.0, 1159.0], [731.0, 1159.0], [729.0, 1393.0], [698.0, 1393.0]], [[654.0, 1157.0], [689.0, 1157.0], [689.0, 1362.0], [654.0, 1362.0]]], "lines": ["「僕は", "悪い事をしたなんて、", "これっぽっちも", "思ってない。」"]}], "img_path": "118.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [391, 224, 431, 414], "vertical": true, "font_size": 37, "lines_coords": [[[391.0, 227.0], [428.0, 227.0], [428.0, 409.0], [391.0, 409.0]]], "lines": ["．．．すごい霧。"]}, {"box": [751, 1360, 787, 1527], "vertical": true, "font_size": 36, "lines_coords": [[[751.0, 1360.0], [787.0, 1360.0], [787.0, 1527.0], [751.0, 1527.0]]], "lines": ["普通にって"]}, {"box": [924, 1459, 1219, 1863], "vertical": true, "font_size": 32, "lines_coords": [[[1184.0, 1467.0], [1215.0, 1467.0], [1213.0, 1745.0], [1182.0, 1745.0]], [[1139.0, 1459.0], [1174.0, 1459.0], [1176.0, 1799.0], [1141.0, 1799.0]], [[1097.0, 1461.0], [1126.0, 1461.0], [1126.0, 1826.0], [1097.0, 1826.0]], [[1056.0, 1461.0], [1091.0, 1461.0], [1091.0, 1780.0], [1056.0, 1780.0]], [[1006.0, 1461.0], [1041.0, 1461.0], [1041.0, 1863.0], [1006.0, 1863.0]], [[967.0, 1463.0], [996.0, 1463.0], [996.0, 1861.0], [967.0, 1861.0]], [[925.0, 1463.0], [954.0, 1463.0], [954.0, 1660.0], [925.0, 1660.0]]], "lines": ["「話し合った通りに", "君は自分の家に帰って", "普通の生活をこれからも", "続ければいいんだよ。", "別の場所で暮らしたいなら", "落ちついてから引っ越せは", "いいんだし。"]}, {"box": [484, 1850, 673, 2064], "vertical": true, "font_size": 37, "lines_coords": [[[635.0, 1850.0], [673.0, 1850.0], [669.0, 2039.0], [631.0, 2039.0]], [[594.0, 1852.0], [629.0, 1852.0], [629.0, 2064.0], [594.0, 2064.0]], [[526.0, 1850.0], [561.0, 1850.0], [561.0, 2053.0], [526.0, 2053.0]], [[484.0, 1852.0], [522.0, 1852.0], [522.0, 1995.0], [484.0, 1995.0]]], "lines": ["「．．．人が一人", "いなくなった。", "それだけの事", "なんだよ。"]}, {"box": [182, 1633, 227, 1741], "vertical": true, "font_size": 45, "lines_coords": [[[182.0, 1633.0], [227.0, 1633.0], [227.0, 1741.0], [182.0, 1741.0]]], "lines": ["．．．何？"]}, {"box": [234, 1848, 435, 2084], "vertical": true, "font_size": 37, "lines_coords": [[[399.0, 1850.0], [435.0, 1850.0], [430.0, 2084.0], [395.0, 2084.0]], [[354.0, 1848.0], [399.0, 1850.0], [395.0, 1960.0], [350.0, 1958.0]], [[316.0, 1850.0], [354.0, 1850.0], [350.0, 2020.0], [312.0, 2020.0]], [[273.0, 1852.0], [308.0, 1852.0], [308.0, 2022.0], [273.0, 2022.0]], [[234.0, 1855.0], [263.0, 1855.0], [263.0, 2078.0], [234.0, 2078.0]]], "lines": ["君が思っている", "以上に", "人は他人に", "興味なんて", "ないんだから。"]}], "img_path": "119.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1155, 128, 1297, 374], "vertical": true, "font_size": 30, "lines_coords": [[[1267.0, 132.0], [1296.0, 132.0], [1296.0, 312.0], [1267.0, 312.0]], [[1230.0, 132.0], [1259.0, 132.0], [1259.0, 370.0], [1230.0, 370.0]], [[1191.0, 128.0], [1226.0, 128.0], [1226.0, 374.0], [1191.0, 374.0]], [[1155.0, 130.0], [1184.0, 130.0], [1184.0, 310.0], [1155.0, 310.0]]], "lines": ["．．．お母さんの", "宗教の友達たちが", "捜そうとするかも", "しれない．．．"]}, {"box": [863, 235, 942, 605], "vertical": true, "font_size": 32, "lines_coords": [[[905.0, 240.0], [940.0, 240.0], [938.0, 488.0], [903.0, 488.0]], [[865.0, 238.0], [894.0, 238.0], [894.0, 600.0], [865.0, 600.0]]], "lines": ["「君は嘘つくのが", "上手だったじゃないか。"]}, {"box": [238, 237, 272, 479], "vertical": true, "font_size": 27, "lines_coords": [[[240.0, 240.0], [267.0, 240.0], [267.0, 478.0], [240.0, 478.0]]], "lines": ["．．．罪悪感？」"]}, {"box": [978, 596, 1079, 780], "vertical": true, "font_size": 34, "lines_coords": [[[1041.0, 596.0], [1079.0, 596.0], [1079.0, 732.0], [1041.0, 732.0]], [[1008.0, 600.0], [1037.0, 600.0], [1037.0, 780.0], [1008.0, 780.0]]], "lines": ["あの人達、", "しつこいから"]}, {"box": [416, 639, 497, 759], "vertical": true, "font_size": 40, "lines_coords": [[[453.0, 639.0], [497.0, 639.0], [497.0, 749.0], [453.0, 749.0]], [[416.0, 641.0], [451.0, 641.0], [451.0, 759.0], [416.0, 759.0]]], "lines": ["．．．自信", "ないよ。"]}, {"box": [677, 1780, 1120, 2084], "vertical": true, "font_size": 34, "lines_coords": [[[1091.0, 1786.0], [1120.0, 1786.0], [1120.0, 2033.0], [1091.0, 2033.0]], [[1050.0, 1786.0], [1079.0, 1786.0], [1079.0, 1956.0], [1050.0, 1956.0]], [[990.0, 1784.0], [1021.0, 1784.0], [1019.0, 2018.0], [988.0, 2018.0]], [[946.0, 1784.0], [981.0, 1784.0], [981.0, 1952.0], [946.0, 1952.0]], [[903.0, 1784.0], [938.0, 1784.0], [938.0, 2082.0], [903.0, 2082.0]], [[861.0, 1780.0], [896.0, 1780.0], [894.0, 2084.0], [859.0, 2084.0]], [[801.0, 1780.0], [838.0, 1780.0], [834.0, 1954.0], [797.0, 1954.0]], [[760.0, 1784.0], [795.0, 1784.0], [795.0, 1954.0], [760.0, 1954.0]], [[718.0, 1786.0], [754.0, 1786.0], [754.0, 2022.0], [718.0, 2022.0]], [[677.0, 1786.0], [712.0, 1786.0], [712.0, 2033.0], [677.0, 2033.0]]], "lines": ["「申し訳ないけど", "愛子ちゃん、", "君のお母さんが", "死んだ事で", "悲しんだり困ったり", "する人がいるかい？", "そんな人間", "はじめから", "いなかったのと", "同じじゃないか。"]}, {"box": [331, 1784, 635, 2053], "vertical": true, "font_size": 34, "lines_coords": [[[604.0, 1786.0], [635.0, 1786.0], [633.0, 2049.0], [602.0, 2049.0]], [[561.0, 1786.0], [596.0, 1786.0], [596.0, 2020.0], [561.0, 2020.0]], [[517.0, 1784.0], [555.0, 1784.0], [557.0, 2020.0], [519.0, 2020.0]], [[476.0, 1784.0], [511.0, 1784.0], [511.0, 2053.0], [476.0, 2053.0]], [[437.0, 1788.0], [466.0, 1788.0], [466.0, 1989.0], [437.0, 1989.0]], [[368.0, 1786.0], [403.0, 1786.0], [408.0, 1987.0], [372.0, 1987.0]], [[331.0, 1786.0], [362.0, 1786.0], [364.0, 2053.0], [333.0, 2053.0]]], "lines": ["ほとんどの人間が", "生きてるだけで", "社会にとっては", "単なる負債でしか", "ないんだから", "むしろこれは", "いい事なんだよ。」"]}], "img_path": "120.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [972, 668, 1049, 978], "vertical": true, "font_size": 77, "lines_coords": [[[972.0, 668.0], [1049.0, 668.0], [1049.0, 978.0], [972.0, 978.0]]], "lines": ["「：君がこの事を抱えきれないのなら"]}, {"box": [969, 670, 1048, 981], "vertical": true, "font_size": 34, "lines_coords": [[[1012.0, 670.0], [1048.0, 670.0], [1048.0, 925.0], [1012.0, 925.0]], [[969.0, 670.0], [1004.0, 670.0], [1004.0, 981.0], [969.0, 981.0]]], "lines": ["「．．．君がこの事を", "抱えきれないのなら、"]}, {"box": [843, 672, 921, 975], "vertical": true, "font_size": 34, "lines_coords": [[[886.0, 674.0], [921.0, 674.0], [921.0, 975.0], [886.0, 975.0]], [[843.0, 672.0], [878.0, 672.0], [878.0, 890.0], [843.0, 890.0]]], "lines": ["一人で警察に行けば", "いいと思うよ。"]}, {"box": [677, 670, 793, 975], "vertical": true, "font_size": 34, "lines_coords": [[[764.0, 672.0], [793.0, 672.0], [793.0, 904.0], [764.0, 904.0]], [[718.0, 670.0], [754.0, 670.0], [749.0, 975.0], [714.0, 975.0]], [[677.0, 670.0], [712.0, 670.0], [712.0, 846.0], [677.0, 846.0]]], "lines": ["都合の悪い事は", "全部僕がやった事に", "すればいい。"]}, {"box": [548, 668, 625, 954], "vertical": true, "font_size": 34, "lines_coords": [[[596.0, 674.0], [625.0, 674.0], [625.0, 939.0], [596.0, 939.0]], [[548.0, 668.0], [584.0, 668.0], [588.0, 954.0], [553.0, 954.0]]], "lines": ["包丁で刺したのも", "死体を運んだのも。"]}, {"box": [468, 668, 503, 873], "vertical": true, "font_size": 34, "lines_coords": [[[468.0, 668.0], [503.0, 668.0], [503.0, 873.0], [468.0, 873.0]]], "lines": ["被害者として"]}, {"box": [382, 667, 515, 1006], "vertical": true, "font_size": 29, "lines_coords": [[[428.0, 672.0], [457.0, 672.0], [457.0, 1006.0], [428.0, 1006.0]], [[387.0, 672.0], [416.0, 672.0], [416.0, 973.0], [387.0, 973.0]]], "lines": ["生きればきっと誰かが", "同情してくれるさ。"]}, {"box": [865, 1664, 985, 1928], "vertical": true, "font_size": 120, "lines_coords": [[[865.0, 1664.0], [985.0, 1664.0], [985.0, 1928.0], [865.0, 1928.0]]], "lines": ["「なんでも君のいいようにすればいいんだよ。"]}, {"box": [863, 1662, 981, 1929], "vertical": true, "font_size": 35, "lines_coords": [[[952.0, 1668.0], [981.0, 1668.0], [981.0, 1875.0], [952.0, 1875.0]], [[903.0, 1662.0], [940.0, 1662.0], [942.0, 1929.0], [905.0, 1929.0]], [[863.0, 1662.0], [899.0, 1662.0], [899.0, 1840.0], [863.0, 1840.0]]], "lines": ["「なんでも君の", "いいようにすれば", "いいんだよ。"]}, {"box": [691, 1660, 816, 1896], "vertical": true, "font_size": 35, "lines_coords": [[[780.0, 1662.0], [816.0, 1662.0], [816.0, 1844.0], [780.0, 1844.0]], [[739.0, 1662.0], [774.0, 1662.0], [774.0, 1896.0], [739.0, 1896.0]], [[691.0, 1660.0], [737.0, 1660.0], [737.0, 1784.0], [691.0, 1784.0]]], "lines": ["君を救った。", "僕はそれだけで", "十分だ。"]}, {"box": [569, 1662, 644, 1894], "vertical": true, "font_size": 35, "lines_coords": [[[615.0, 1664.0], [644.0, 1664.0], [644.0, 1894.0], [615.0, 1894.0]], [[569.0, 1662.0], [604.0, 1662.0], [604.0, 1863.0], [569.0, 1863.0]]], "lines": ["後は捕まろうが", "裁かれようが"]}, {"box": [457, 1660, 532, 1958], "vertical": true, "font_size": 35, "lines_coords": [[[497.0, 1660.0], [532.0, 1660.0], [532.0, 1832.0], [497.0, 1832.0]], [[457.0, 1666.0], [486.0, 1666.0], [486.0, 1958.0], [457.0, 1958.0]]], "lines": ["そんな事は", "知った事じゃない。"]}], "img_path": "121.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [629, 674, 837, 915], "vertical": true, "font_size": 36, "lines_coords": [[[797.0, 674.0], [836.0, 674.0], [836.0, 772.0], [797.0, 772.0]], [[758.0, 679.0], [793.0, 679.0], [793.0, 915.0], [758.0, 915.0]], [[716.0, 679.0], [751.0, 679.0], [751.0, 815.0], [716.0, 815.0]], [[673.0, 676.0], [710.0, 676.0], [706.0, 915.0], [669.0, 915.0]], [[631.0, 679.0], [667.0, 679.0], [664.0, 913.0], [629.0, 913.0]]], "lines": ["「ただ、", "他人の価値観に", "晒されて", "自由を奪われる", "つもりもない。」"]}], "img_path": "122.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1141, 1248, 1211, 1575], "vertical": true, "font_size": 70, "lines_coords": [[[1141.0, 1248.0], [1211.0, 1248.0], [1211.0, 1575.0], [1141.0, 1575.0]]], "lines": ["待ってよ！！"]}], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [925, 291, 1035, 548], "vertical": true, "font_size": 56, "lines_coords": [[[973.0, 300.0], [1035.0, 300.0], [1035.0, 430.0], [973.0, 430.0]], [[925.0, 291.0], [975.0, 291.0], [975.0, 548.0], [925.0, 548.0]]], "lines": ["一人に", "しないで．．．"]}], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "126.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [801, 95, 886, 284], "vertical": true, "font_size": 36, "lines_coords": [[[849.0, 99.0], [884.0, 99.0], [884.0, 252.0], [849.0, 252.0]], [[801.0, 95.0], [838.0, 95.0], [843.0, 279.0], [805.0, 279.0]]], "lines": ["「すごいよ", "愛子ちゃん。"]}, {"box": [557, 98, 634, 273], "vertical": true, "font_size": 36, "lines_coords": [[[598.0, 99.0], [633.0, 99.0], [633.0, 236.0], [598.0, 236.0]], [[557.0, 99.0], [594.0, 99.0], [594.0, 269.0], [557.0, 269.0]]], "lines": ["もう何も", "怖くない。」"]}, {"box": [428, 1333, 468, 1414], "vertical": true, "font_size": 40, "lines_coords": [[[428.0, 1333.0], [468.0, 1333.0], [468.0, 1414.0], [428.0, 1414.0]]], "lines": ["爆笑"]}, {"box": [617, 1831, 791, 2036], "vertical": true, "font_size": 35, "lines_coords": [[[754.0, 1838.0], [789.0, 1838.0], [789.0, 1985.0], [754.0, 1985.0]], [[685.0, 1834.0], [720.0, 1834.0], [720.0, 2001.0], [685.0, 2001.0]], [[617.0, 1834.0], [652.0, 1834.0], [656.0, 2035.0], [621.0, 2035.0]]], "lines": ["「結局僕は", "こういう奴", "なんですよ。」"]}], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [47, 397, 121, 619], "vertical": true, "font_size": 67, "lines_coords": [[[51.0, 401.0], [118.0, 403.0], [113.0, 619.0], [47.0, 616.0]]], "lines": ["第１１７話"]}], "img_path": "130.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "131.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1044, 142, 1113, 269], "vertical": true, "font_size": 33, "lines_coords": [[[1077.0, 142.0], [1112.0, 142.0], [1112.0, 269.0], [1077.0, 269.0]], [[1044.0, 144.0], [1075.0, 144.0], [1075.0, 240.0], [1044.0, 240.0]]], "lines": ["これから", "．．．．．．"]}, {"box": [418, 221, 493, 408], "vertical": true, "font_size": 38, "lines_coords": [[[447.0, 221.0], [493.0, 221.0], [493.0, 325.0], [447.0, 325.0]], [[418.0, 227.0], [447.0, 227.0], [447.0, 407.0], [418.0, 407.0]]], "lines": ["どこに", "向かうの．．．？"]}, {"box": [948, 1420, 1037, 1593], "vertical": true, "font_size": 42, "lines_coords": [[[990.0, 1420.0], [1037.0, 1420.0], [1037.0, 1525.0], [990.0, 1525.0]], [[948.0, 1420.0], [986.0, 1420.0], [986.0, 1592.0], [948.0, 1592.0]]], "lines": ["「．．．今、", "考えてる。」"]}, {"box": [733, 1660, 812, 1799], "vertical": true, "font_size": 32, "lines_coords": [[[774.0, 1660.0], [812.0, 1660.0], [812.0, 1797.0], [774.0, 1797.0]], [[733.0, 1660.0], [768.0, 1660.0], [768.0, 1799.0], [733.0, 1799.0]]], "lines": ["あたしは", "もう．．．．．"]}, {"box": [540, 1782, 656, 1979], "vertical": true, "font_size": 32, "lines_coords": [[[627.0, 1782.0], [656.0, 1782.0], [656.0, 1915.0], [627.0, 1915.0]], [[584.0, 1782.0], [613.0, 1782.0], [613.0, 1979.0], [584.0, 1979.0]], [[540.0, 1782.0], [569.0, 1782.0], [569.0, 1977.0], [540.0, 1977.0]]], "lines": ["あの街に", "戻るつもりは", "ないから．．．"]}], "img_path": "132.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [343, 1155, 372, 1335], "vertical": true, "font_size": 32, "lines_coords": [[[343.0, 1155.0], [372.0, 1155.0], [372.0, 1335.0], [343.0, 1335.0]]], "lines": ["お父さん．．．"]}, {"box": [130, 1213, 236, 1461], "vertical": true, "font_size": 32, "lines_coords": [[[200.0, 1215.0], [236.0, 1215.0], [236.0, 1372.0], [200.0, 1372.0]], [[163.0, 1213.0], [198.0, 1213.0], [196.0, 1461.0], [161.0, 1461.0]], [[130.0, 1217.0], [159.0, 1217.0], [159.0, 1380.0], [130.0, 1380.0]]], "lines": ["中三の時に", "別居になってから", "会ってない。"]}, {"box": [1106, 1542, 1244, 1753], "vertical": true, "font_size": 30, "lines_coords": [[[1215.0, 1546.0], [1244.0, 1546.0], [1244.0, 1695.0], [1215.0, 1695.0]], [[1178.0, 1544.0], [1207.0, 1544.0], [1207.0, 1724.0], [1178.0, 1724.0]], [[1139.0, 1542.0], [1168.0, 1542.0], [1172.0, 1753.0], [1143.0, 1753.0]], [[1106.0, 1544.0], [1135.0, 1544.0], [1135.0, 1670.0], [1106.0, 1670.0]]], "lines": ["お母さんが", "嫌がったから", "離婚にはなって", "ないけど、"]}, {"box": [961, 1763, 1104, 1979], "vertical": true, "font_size": 30, "lines_coords": [[[1066.0, 1763.0], [1104.0, 1763.0], [1104.0, 1863.0], [1066.0, 1863.0]], [[1033.0, 1768.0], [1062.0, 1768.0], [1062.0, 1979.0], [1033.0, 1979.0]], [[996.0, 1768.0], [1025.0, 1768.0], [1025.0, 1921.0], [996.0, 1921.0]], [[961.0, 1768.0], [990.0, 1768.0], [990.0, 1979.0], [961.0, 1979.0]]], "lines": ["どこに", "住んでるのかは", "結局聞かず", "じまいだった．．．"]}, {"box": [290, 1563, 464, 1801], "vertical": true, "font_size": 29, "lines_coords": [[[435.0, 1563.0], [464.0, 1563.0], [464.0, 1745.0], [435.0, 1745.0]], [[397.0, 1565.0], [426.0, 1565.0], [426.0, 1801.0], [397.0, 1801.0]], [[362.0, 1565.0], [391.0, 1565.0], [391.0, 1743.0], [362.0, 1743.0]], [[325.0, 1565.0], [354.0, 1565.0], [354.0, 1745.0], [325.0, 1745.0]], [[290.0, 1563.0], [312.0, 1563.0], [312.0, 1714.0], [290.0, 1714.0]]], "lines": ["：仕事好きで", "あまり家にいない", "人だったけど", "たまには電話", "くれたのに"]}, {"box": [138, 1801, 281, 2012], "vertical": true, "font_size": 29, "lines_coords": [[[246.0, 1801.0], [281.0, 1801.0], [281.0, 1923.0], [246.0, 1923.0]], [[211.0, 1801.0], [242.0, 1801.0], [240.0, 2012.0], [209.0, 2012.0]], [[174.0, 1801.0], [205.0, 1801.0], [203.0, 2012.0], [171.0, 2012.0]], [[138.0, 1803.0], [167.0, 1803.0], [167.0, 1981.0], [138.0, 1981.0]]], "lines": ["．．．別居が", "決まってからは", "ぱったり連絡が", "途絶えて．．．．．"]}], "img_path": "133.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [830, 320, 954, 528], "vertical": true, "font_size": 38, "lines_coords": [[[919.0, 322.0], [954.0, 322.0], [954.0, 527.0], [919.0, 527.0]], [[876.0, 322.0], [911.0, 322.0], [911.0, 527.0], [876.0, 527.0]], [[830.0, 320.0], [874.0, 320.0], [874.0, 443.0], [830.0, 443.0]]], "lines": ["もしかしたら", "もう死んでる", "のかな。"]}, {"box": [631, 74, 673, 318], "vertical": true, "font_size": 42, "lines_coords": [[[631.0, 74.0], [673.0, 74.0], [673.0, 316.0], [631.0, 316.0]]], "lines": ["プンプンは．．．"]}, {"box": [183, 223, 302, 461], "vertical": true, "font_size": 34, "lines_coords": [[[265.0, 225.0], [300.0, 225.0], [300.0, 461.0], [265.0, 461.0]], [[219.0, 223.0], [256.0, 223.0], [261.0, 397.0], [223.0, 397.0]], [[184.0, 227.0], [213.0, 227.0], [213.0, 424.0], [184.0, 424.0]]], "lines": ["家族とか友達に", "心残りって", "あるの．．．．．．？"]}, {"box": [542, 1198, 577, 1378], "vertical": true, "font_size": 38, "lines_coords": [[[542.0, 1198.0], [577.0, 1198.0], [577.0, 1378.0], [542.0, 1378.0]]], "lines": ["．．．ごめん。"]}, {"box": [323, 1337, 447, 1507], "vertical": true, "font_size": 38, "lines_coords": [[[403.0, 1337.0], [447.0, 1337.0], [447.0, 1478.0], [403.0, 1478.0]], [[364.0, 1339.0], [401.0, 1339.0], [401.0, 1478.0], [364.0, 1478.0]], [[323.0, 1339.0], [358.0, 1339.0], [358.0, 1507.0], [323.0, 1507.0]]], "lines": ["やっぱり", "やめよう", "この話．．．．．．"]}, {"box": [828, 1832, 865, 2061], "vertical": true, "font_size": 35, "lines_coords": [[[828.0, 1836.0], [863.0, 1836.0], [863.0, 2055.0], [828.0, 2055.0]]], "lines": ["「：愛子ちゃん"]}, {"box": [673, 1836, 755, 2072], "vertical": true, "font_size": 29, "lines_coords": [[[718.0, 1840.0], [747.0, 1840.0], [747.0, 2004.0], [718.0, 2004.0]], [[677.0, 1838.0], [706.0, 1838.0], [706.0, 2072.0], [677.0, 2072.0]]], "lines": ["僕はずっと", "信じてたんだ。」"]}], "img_path": "134.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1192, 157, 1226, 298], "vertical": true, "font_size": 29, "lines_coords": [[[1193.0, 157.0], [1222.0, 157.0], [1222.0, 296.0], [1193.0, 296.0]]], "lines": ["．．．何を？"]}, {"box": [107, 277, 448, 788], "vertical": true, "font_size": 35, "lines_coords": [[[412.0, 283.0], [447.0, 283.0], [447.0, 604.0], [412.0, 604.0]], [[366.0, 279.0], [403.0, 279.0], [406.0, 699.0], [368.0, 699.0]], [[327.0, 277.0], [362.0, 277.0], [362.0, 763.0], [327.0, 763.0]], [[287.0, 281.0], [323.0, 281.0], [323.0, 720.0], [287.0, 720.0]], [[242.0, 279.0], [277.0, 279.0], [281.0, 668.0], [246.0, 668.0]], [[188.0, 281.0], [223.0, 281.0], [225.0, 788.0], [190.0, 788.0]], [[151.0, 279.0], [182.0, 279.0], [180.0, 585.0], [149.0, 585.0]], [[109.0, 279.0], [145.0, 279.0], [142.0, 722.0], [107.0, 722.0]]], "lines": ["「世の中の人はみんな", "僕なんかより優秀で賢くて、", "どんな人にも必ず良心があって、", "どんな嫌な人でもきっと何か", "事情があるんだろうって。", "だからたいした理由も無いくせに", "卑屈で根暗な自分が", "ずっとすっと嫌だったんだ。」"]}, {"box": [254, 1119, 682, 1438], "vertical": true, "font_size": 35, "lines_coords": [[[640.0, 1122.0], [677.0, 1122.0], [677.0, 1250.0], [640.0, 1250.0]], [[582.0, 1124.0], [617.0, 1124.0], [617.0, 1291.0], [582.0, 1291.0]], [[540.0, 1124.0], [575.0, 1124.0], [575.0, 1327.0], [540.0, 1327.0]], [[493.0, 1126.0], [522.0, 1126.0], [522.0, 1391.0], [493.0, 1391.0]], [[449.0, 1124.0], [484.0, 1124.0], [484.0, 1438.0], [449.0, 1438.0]], [[381.0, 1122.0], [418.0, 1122.0], [414.0, 1329.0], [377.0, 1329.0]], [[339.0, 1120.0], [377.0, 1120.0], [370.0, 1393.0], [333.0, 1393.0]], [[298.0, 1124.0], [333.0, 1124.0], [333.0, 1362.0], [298.0, 1362.0]], [[254.0, 1132.0], [290.0, 1132.0], [290.0, 1360.0], [254.0, 1360.0]]], "lines": ["「．．．けど、", "悪意の塊の", "ような人間が", "身勝手ながさつを", "平然とまき散らして、", "他人の人生を", "台無しにしている", "現実というのが", "一方であって、」"]}], "img_path": "135.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [977, 169, 1315, 512], "vertical": true, "font_size": 35, "lines_coords": [[[1276.0, 171.0], [1311.0, 171.0], [1311.0, 494.0], [1276.0, 494.0]], [[1232.0, 171.0], [1267.0, 171.0], [1267.0, 389.0], [1232.0, 389.0]], [[1174.0, 171.0], [1209.0, 171.0], [1209.0, 511.0], [1174.0, 511.0]], [[1128.0, 169.0], [1164.0, 169.0], [1166.0, 476.0], [1131.0, 476.0]], [[1070.0, 171.0], [1106.0, 171.0], [1106.0, 478.0], [1070.0, 478.0]], [[1019.0, 169.0], [1054.0, 169.0], [1056.0, 443.0], [1021.0, 443.0]], [[977.0, 169.0], [1012.0, 169.0], [1015.0, 509.0], [979.0, 509.0]]], "lines": ["「今となってはむしろ", "不思議に思う。", "なんで人は誰も誰かを", "殺さないんだろう？", "なんでみんな平然と", "それを見逃す事が", "できるんだろうって。」"]}, {"box": [155, 170, 543, 523], "vertical": true, "font_size": 35, "lines_coords": [[[505.0, 180.0], [540.0, 180.0], [540.0, 463.0], [505.0, 463.0]], [[461.0, 175.0], [497.0, 175.0], [497.0, 490.0], [461.0, 490.0]], [[401.0, 171.0], [439.0, 171.0], [435.0, 378.0], [397.0, 378.0]], [[360.0, 173.0], [395.0, 173.0], [395.0, 391.0], [360.0, 391.0]], [[300.0, 173.0], [335.0, 173.0], [335.0, 523.0], [300.0, 523.0]], [[242.0, 175.0], [271.0, 175.0], [271.0, 478.0], [242.0, 478.0]], [[198.0, 173.0], [234.0, 173.0], [234.0, 457.0], [198.0, 457.0]], [[155.0, 171.0], [190.0, 171.0], [190.0, 411.0], [155.0, 411.0]]], "lines": ["「僕は期待しすぎて", "いたのかもしれない。", "期待するから", "失望するんだ。", "答えは単純だったんだ。", "まともな人間なんて", "一人もいないんだ。", "誰一人として。」"]}, {"box": [1137, 1536, 1189, 1650], "vertical": true, "font_size": 41, "lines_coords": [[[1137.0, 1536.0], [1189.0, 1536.0], [1189.0, 1650.0], [1137.0, 1650.0]]], "lines": ["早く．．．"]}, {"box": [994, 1618, 1070, 1801], "vertical": true, "font_size": 41, "lines_coords": [[[1035.0, 1618.0], [1070.0, 1618.0], [1070.0, 1801.0], [1035.0, 1801.0]], [[994.0, 1618.0], [1031.0, 1618.0], [1031.0, 1755.0], [994.0, 1755.0]]], "lines": ["雨止まない", "かな．．．"]}], "img_path": "136.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [704, 142, 878, 461], "vertical": true, "font_size": 31, "lines_coords": [[[849.0, 144.0], [878.0, 144.0], [878.0, 293.0], [849.0, 293.0]], [[801.0, 142.0], [836.0, 142.0], [841.0, 461.0], [805.0, 461.0]], [[743.0, 142.0], [778.0, 142.0], [778.0, 281.0], [743.0, 281.0]], [[704.0, 146.0], [733.0, 146.0], [733.0, 391.0], [704.0, 391.0]]], "lines": ["「けど僕は", "やるべき事をやった。", "気持ちは", "晴れやかなんだ"]}, {"box": [528, 144, 658, 513], "vertical": true, "font_size": 31, "lines_coords": [[[629.0, 146.0], [658.0, 146.0], [658.0, 387.0], [629.0, 387.0]], [[571.0, 146.0], [600.0, 146.0], [600.0, 383.0], [571.0, 383.0]], [[528.0, 144.0], [557.0, 144.0], [557.0, 513.0], [528.0, 513.0]]], "lines": ["だから言えるよ", "世の中はもっと", "混沌とあるべきだって。"]}, {"box": [1182, 761, 1234, 875], "vertical": true, "font_size": 46, "lines_coords": [[[1182.0, 761.0], [1234.0, 761.0], [1234.0, 875.0], [1182.0, 875.0]]], "lines": ["あ．．．"]}, {"box": [1048, 888, 1131, 1070], "vertical": true, "font_size": 46, "lines_coords": [[[1075.0, 888.0], [1131.0, 888.0], [1131.0, 979.0], [1075.0, 979.0]], [[1048.0, 900.0], [1077.0, 900.0], [1077.0, 1070.0], [1048.0, 1070.0]]], "lines": ["血が", "付いてる．．．"]}, {"box": [188, 879, 313, 1055], "vertical": true, "font_size": 39, "lines_coords": [[[277.0, 884.0], [312.0, 884.0], [312.0, 1055.0], [277.0, 1055.0]], [[234.0, 884.0], [269.0, 884.0], [269.0, 1053.0], [234.0, 1053.0]], [[188.0, 879.0], [234.0, 879.0], [234.0, 989.0], [188.0, 989.0]]], "lines": ["Ｔシャツも", "買わなきゃ", "ね．．．．．"]}, {"box": [1102, 1220, 1270, 1699], "vertical": true, "font_size": 30, "lines_coords": [[[1236.0, 1221.0], [1265.0, 1221.0], [1265.0, 1399.0], [1236.0, 1399.0]], [[1213.0, 1457.0], [1242.0, 1457.0], [1242.0, 1608.0], [1213.0, 1608.0]], [[1174.0, 1455.0], [1209.0, 1455.0], [1209.0, 1670.0], [1174.0, 1670.0]], [[1139.0, 1457.0], [1168.0, 1457.0], [1168.0, 1699.0], [1139.0, 1699.0]], [[1102.0, 1457.0], [1131.0, 1457.0], [1131.0, 1668.0], [1102.0, 1668.0]]], "lines": ["あたしはね．．．", "難しい話は", "あまり理解して", "あげられないかも", "しれないけど．．．"]}, {"box": [559, 1741, 699, 1952], "vertical": true, "font_size": 28, "lines_coords": [[[669.0, 1743.0], [698.0, 1743.0], [698.0, 1863.0], [669.0, 1863.0]], [[631.0, 1741.0], [660.0, 1741.0], [660.0, 1923.0], [631.0, 1923.0]], [[596.0, 1741.0], [625.0, 1741.0], [625.0, 1923.0], [596.0, 1923.0]], [[559.0, 1741.0], [586.0, 1741.0], [586.0, 1952.0], [559.0, 1952.0]]], "lines": ["あなたは", "もうどこにも", "行かないって", "信じてるから．．．"]}], "img_path": "137.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1215, 113, 1257, 258], "vertical": true, "font_size": 37, "lines_coords": [[[1220.0, 113.0], [1257.0, 113.0], [1253.0, 258.0], [1215.0, 258.0]]], "lines": ["ごめん．．．"]}, {"box": [1112, 293, 1189, 434], "vertical": true, "font_size": 37, "lines_coords": [[[1151.0, 293.0], [1189.0, 293.0], [1189.0, 405.0], [1151.0, 405.0]], [[1112.0, 298.0], [1147.0, 298.0], [1147.0, 434.0], [1112.0, 434.0]]], "lines": ["気持ち", "悪い．．．"]}, {"box": [306, 639, 389, 849], "vertical": true, "font_size": 42, "lines_coords": [[[339.0, 639.0], [389.0, 639.0], [389.0, 720.0], [339.0, 720.0]], [[306.0, 643.0], [341.0, 643.0], [341.0, 846.0], [306.0, 846.0]]], "lines": ["少し", "休ませて．．．"]}], "img_path": "138.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1000, 198, 1184, 509], "vertical": true, "font_size": 32, "lines_coords": [[[1147.0, 198.0], [1178.0, 198.0], [1182.0, 391.0], [1151.0, 391.0]], [[1114.0, 200.0], [1143.0, 200.0], [1143.0, 411.0], [1114.0, 411.0]], [[1070.0, 198.0], [1106.0, 198.0], [1110.0, 509.0], [1075.0, 509.0]], [[1037.0, 198.0], [1066.0, 198.0], [1070.0, 414.0], [1041.0, 414.0]], [[1000.0, 200.0], [1035.0, 200.0], [1037.0, 484.0], [1002.0, 484.0]]], "lines": ["農業の効率化、", "あるいは太陽の", "３７０万倍の質量を持った", "普遍宗教の運動", "エネルギーの増加は、"]}, {"box": [213, 287, 394, 604], "vertical": true, "font_size": 29, "lines_coords": [[[364.0, 287.0], [391.0, 287.0], [391.0, 527.0], [364.0, 527.0]], [[323.0, 287.0], [352.0, 287.0], [354.0, 532.0], [325.0, 532.0]], [[287.0, 289.0], [316.0, 289.0], [316.0, 592.0], [287.0, 592.0]], [[252.0, 289.0], [281.0, 289.0], [281.0, 594.0], [252.0, 594.0]], [[213.0, 287.0], [242.0, 287.0], [244.0, 604.0], [215.0, 604.0]]], "lines": ["可処分所得が多い", "Ｉ型超新星爆発を", "起こす質量が０である", "理論的根拠が悔悟の情", "及び改善更生の意欲に、"]}, {"box": [741, 1356, 885, 1559], "vertical": true, "font_size": 30, "lines_coords": [[[849.0, 1358.0], [884.0, 1358.0], [884.0, 1482.0], [849.0, 1482.0]], [[816.0, 1356.0], [845.0, 1356.0], [845.0, 1538.0], [816.0, 1538.0]], [[778.0, 1360.0], [807.0, 1360.0], [807.0, 1511.0], [778.0, 1511.0]], [[741.0, 1356.0], [768.0, 1356.0], [768.0, 1554.0], [741.0, 1554.0]]], "lines": ["第五元素", "「エーテル」は", "公益活動に", "取り組んでいる"]}, {"box": [188, 1823, 294, 1977], "vertical": true, "font_size": 31, "lines_coords": [[[258.0, 1823.0], [294.0, 1823.0], [294.0, 1950.0], [258.0, 1950.0]], [[223.0, 1826.0], [252.0, 1826.0], [252.0, 1977.0], [223.0, 1977.0]], [[188.0, 1823.0], [217.0, 1823.0], [217.0, 1952.0], [188.0, 1952.0]]], "lines": ["相対的な", "スケールを", "考えると、"]}], "img_path": "139.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1164, 138, 1272, 331], "vertical": true, "font_size": 29, "lines_coords": [[[1242.0, 140.0], [1271.0, 140.0], [1271.0, 260.0], [1242.0, 260.0]], [[1203.0, 140.0], [1232.0, 140.0], [1232.0, 291.0], [1203.0, 291.0]], [[1166.0, 138.0], [1195.0, 138.0], [1193.0, 327.0], [1164.0, 327.0]]], "lines": ["嫌気性の", "破傷風菌に", "必要な思考力。"]}, {"box": [803, 192, 882, 300], "vertical": true, "font_size": 41, "lines_coords": [[[838.0, 192.0], [882.0, 192.0], [882.0, 300.0], [838.0, 300.0]], [[803.0, 192.0], [841.0, 192.0], [841.0, 296.0], [803.0, 296.0]]], "lines": ["判断力、", "表現力、"]}, {"box": [706, 329, 845, 683], "vertical": true, "font_size": 59.5, "lines_coords": [[[718.0, 343.0], [783.0, 329.0], [845.0, 592.0], [780.0, 606.0]], [[706.0, 486.0], [758.0, 478.0], [793.0, 674.0], [741.0, 683.0]]], "lines": ["お店になった", "ギ不幸に"]}, {"box": [1091, 871, 1241, 1091], "vertical": true, "font_size": 35, "lines_coords": [[[1209.0, 877.0], [1238.0, 877.0], [1236.0, 1060.0], [1207.0, 1060.0]], [[1172.0, 875.0], [1203.0, 875.0], [1197.0, 1091.0], [1166.0, 1091.0]], [[1133.0, 877.0], [1168.0, 877.0], [1168.0, 1064.0], [1133.0, 1064.0]], [[1091.0, 871.0], [1137.0, 871.0], [1137.0, 956.0], [1091.0, 956.0]]], "lines": ["心身の調和的", "発達を図る事を", "同署は暴行や", "傷害、"]}, {"box": [586, 619, 698, 753], "vertical": true, "font_size": 37, "lines_coords": [[[660.0, 619.0], [698.0, 619.0], [698.0, 745.0], [660.0, 745.0]], [[621.0, 619.0], [660.0, 619.0], [660.0, 718.0], [621.0, 718.0]], [[586.0, 619.0], [621.0, 619.0], [621.0, 753.0], [586.0, 753.0]]], "lines": ["その他の", "能力を", "はぐくみ、"]}, {"box": [194, 1037, 343, 1279], "vertical": true, "font_size": 34, "lines_coords": [[[304.0, 1037.0], [343.0, 1037.0], [343.0, 1136.0], [304.0, 1136.0]], [[273.0, 1041.0], [302.0, 1041.0], [302.0, 1279.0], [273.0, 1279.0]], [[236.0, 1039.0], [265.0, 1039.0], [265.0, 1248.0], [236.0, 1248.0]], [[194.0, 1037.0], [234.0, 1037.0], [234.0, 1117.0], [194.0, 1117.0]]], "lines": ["または", "マリンスポーツも", "盛んに行われて", "いる。"]}], "img_path": "140.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1170, 149, 1215, 277], "vertical": true, "font_size": 45, "lines_coords": [[[1170.0, 149.0], [1215.0, 149.0], [1215.0, 277.0], [1170.0, 277.0]]], "lines": ["あ．．．"]}, {"box": [551, 902, 598, 979], "vertical": true, "font_size": 47, "lines_coords": [[[551.0, 902.0], [598.0, 902.0], [598.0, 979.0], [551.0, 979.0]]], "lines": ["はぁ"]}, {"box": [234, 1264, 287, 1345], "vertical": true, "font_size": 45, "lines_coords": [[[234.0, 1267.0], [281.0, 1264.0], [287.0, 1341.0], [240.0, 1345.0]]], "lines": ["はぁ"]}, {"box": [1