3], "vertical": true, "font_size": 48, "lines_coords": [[[664.0, 122.0], [714.0, 122.0], [714.0, 209.0], [664.0, 209.0]], [[625.0, 250.0], [671.0, 248.0], [675.0, 331.0], [629.0, 333.0]]], "lines": ["はぁ", "はぁ"]}, {"box": [743, 890, 867, 1066], "vertical": true, "font_size": 33, "lines_coords": [[[822.0, 890.0], [867.0, 890.0], [867.0, 983.0], [822.0, 983.0]], [[789.0, 894.0], [818.0, 894.0], [818.0, 1060.0], [789.0, 1060.0]], [[743.0, 892.0], [778.0, 892.0], [778.0, 1066.0], [743.0, 1066.0]]], "lines": ["「僕の", "言うことを", "聞いてれば、"]}, {"box": [617, 892, 687, 1095], "vertical": true, "font_size": 33, "lines_coords": [[[658.0, 894.0], [687.0, 894.0], [687.0, 1095.0], [658.0, 1095.0]], [[617.0, 892.0], [646.0, 892.0], [646.0, 1095.0], [617.0, 1095.0]]], "lines": ["何も心配する", "事は無いよ。」"]}, {"box": [217, 610, 267, 697], "vertical": true, "font_size": 48, "lines_coords": [[[217.0, 610.0], [267.0, 610.0], [267.0, 697.0], [217.0, 697.0]]], "lines": ["はぁ"]}, {"box": [145, 708, 192, 795], "vertical": true, "font_size": 48, "lines_coords": [[[145.0, 708.0], [192.0, 708.0], [192.0, 795.0], [145.0, 795.0]]], "lines": ["はぁ"]}, {"box": [716, 1529, 762, 1637], "vertical": true, "font_size": 46, "lines_coords": [[[716.0, 1529.0], [762.0, 1529.0], [762.0, 1637.0], [716.0, 1637.0]]], "lines": ["はっ．．．"]}, {"box": [416, 1260, 559, 1401], "vertical": true, "font_size": 39, "lines_coords": [[[515.0, 1264.0], [559.0, 1264.0], [559.0, 1393.0], [515.0, 1393.0]], [[455.0, 1264.0], [493.0, 1264.0], [493.0, 1401.0], [455.0, 1401.0]], [[416.0, 1260.0], [451.0, 1260.0], [451.0, 1399.0], [416.0, 1399.0]]], "lines": ["「．．．ほら、", "傷見せて", "ごらん。」"]}, {"box": [155, 1892, 198, 2001], "vertical": true, "font_size": 43, "lines_coords": [[[155.0, 1892.0], [198.0, 1892.0], [198.0, 2001.0], [155.0, 2001.0]]], "lines": ["はっ．．．"]}], "img_path": "082.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1255, 485, 1297, 789], "vertical": true, "font_size": 35, "lines_coords": [[[1257.0, 488.0], [1292.0, 488.0], [1290.0, 784.0], [1255.0, 784.0]]], "lines": ["「．．．愛子ちゃんにも"]}, {"box": [1191, 778, 1220, 1242], "vertical": true, "font_size": 29, "lines_coords": [[[1191.0, 778.0], [1220.0, 778.0], [1220.0, 1242.0], [1191.0, 1242.0]]], "lines": ["少しがんばってもらわないと。"]}], "img_path": "083.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "084.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "085.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "086.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1234, 88, 1271, 228], "vertical": true, "font_size": 37, "lines_coords": [[[1234.0, 91.0], [1271.0, 91.0], [1271.0, 146.0], [1234.0, 146.0]]], "lines": ["ふー"]}, {"box": [420, 45, 486, 99], "vertical": false, "font_size": 52, "lines_coords": [[[420.0, 47.0], [481.0, 41.0], [485.0, 96.0], [424.0, 102.0]]], "lines": ["この"]}, {"box": [1194, 962, 1245, 1071], "vertical": true, "font_size": 51, "lines_coords": [[[1194.0, 962.0], [1245.0, 962.0], [1245.0, 1071.0], [1194.0, 1071.0]]], "lines": ["．．．あ"]}, {"box": [843, 525, 888, 633], "vertical": true, "font_size": 44, "lines_coords": [[[843.0, 525.0], [888.0, 525.0], [888.0, 633.0], [843.0, 633.0]]], "lines": ["ふー．．．"]}, {"box": [778, 658, 820, 720], "vertical": true, "font_size": 44, "lines_coords": [[[778.0, 658.0], [820.0, 658.0], [820.0, 720.0], [778.0, 720.0]]], "lines": ["ふー"]}, {"box": [229, 1427, 278, 1644], "vertical": true, "font_size": 44, "lines_coords": [[[229.0, 1430.0], [273.0, 1430.0], [273.0, 1643.0], [229.0, 1643.0]]], "lines": ["あぁ．．．！！"]}], "img_path": "087.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "088.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [], "img_path": "089.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [814, 60, 853, 326], "vertical": true, "font_size": 35, "lines_coords": [[[814.0, 60.0], [849.0, 60.0], [851.0, 318.0], [816.0, 318.0]]], "lines": ["「私と二人で．．．"]}, {"box": [658, 57, 848, 393], "vertical": true, "font_size": 32, "lines_coords": [[[708.0, 64.0], [737.0, 64.0], [737.0, 306.0], [708.0, 306.0]], [[662.0, 60.0], [698.0, 60.0], [693.0, 393.0], [658.0, 393.0]]], "lines": ["もう一度人生を", "やり直しませんか？」"]}, {"box": [40, 406, 113, 613], "vertical": true, "font_size": 40, "lines_coords": [[[51.0, 411.0], [91.0, 411.0], [91.0, 494.0], [51.0, 494.0]]], "lines": ["第２"]}, {"box": [901, 1811, 936, 1968], "vertical": true, "font_size": 35, "lines_coords": [[[901.0, 1811.0], [936.0, 1811.0], [936.0, 1966.0], [901.0, 1966.0]]], "lines": ["「僕は．．．．．"]}, {"box": [816, 1811, 859, 2054], "vertical": true, "font_size": 35, "lines_coords": [[[816.0, 1811.0], [851.0, 1811.0], [851.0, 2047.0], [816.0, 2047.0]]], "lines": ["残念ながら．．．"]}, {"box": [646, 1809, 726, 1986], "vertical": true, "font_size": 30, "lines_coords": [[[693.0, 1815.0], [722.0, 1815.0], [722.0, 1981.0], [693.0, 1981.0]], [[650.0, 1809.0], [681.0, 1809.0], [677.0, 1981.0], [646.0, 1981.0]]], "lines": ["君を助ける", "ことは．．．"]}, {"box": [548, 1809, 591, 2032], "vertical": true, "font_size": 38, "lines_coords": [[[553.0, 1809.0], [590.0, 1809.0], [586.0, 2028.0], [548.0, 2028.0]]], "lines": ["できない．．．"]}], "img_path": "090.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1112, 171, 1259, 360], "vertical": true, "font_size": 34, "lines_coords": [[[1224.0, 173.0], [1259.0, 173.0], [1259.0, 300.0], [1224.0, 300.0]], [[1189.0, 175.0], [1218.0, 175.0], [1218.0, 360.0], [1189.0, 360.0]], [[1147.0, 171.0], [1182.0, 171.0], [1182.0, 327.0], [1147.0, 327.0]], [[1112.0, 173.0], [1147.0, 173.0], [1147.0, 300.0], [1112.0, 300.0]]], "lines": ["．．．あの時", "あの娘の手を", "握り返して", "いたら．．．"]}, {"box": [190, 248, 337, 494], "vertical": true, "font_size": 30, "lines_coords": [[[304.0, 250.0], [333.0, 250.0], [333.0, 461.0], [304.0, 461.0]], [[267.0, 252.0], [296.0, 252.0], [296.0, 463.0], [267.0, 463.0]], [[229.0, 250.0], [258.0, 250.0], [258.0, 494.0], [229.0, 494.0]], [[190.0, 248.0], [225.0, 248.0], [225.0, 376.0], [190.0, 376.0]]], "lines": ["或いは僕の人生", "全く違うものに", "なっていたのかも", "しれない"]}, {"box": [1170, 954, 1273, 1165], "vertical": true, "font_size": 29, "lines_coords": [[[1244.0, 954.0], [1273.0, 954.0], [1273.0, 1165.0], [1244.0, 1165.0]], [[1207.0, 954.0], [1236.0, 954.0], [1236.0, 1163.0], [1207.0, 1163.0]], [[1170.0, 954.0], [1199.0, 954.0], [1199.0, 1142.0], [1170.0, 1142.0]]], "lines": ["ただ若い時分の", "僕はこう勘違い", "しがちだった。"]}, {"box": [917, 1014, 1095, 1227], "vertical": true, "font_size": 29, "lines_coords": [[[1064.0, 1014.0], [1095.0, 1014.0], [1091.0, 1192.0], [1060.0, 1192.0]], [[1029.0, 1014.0], [1058.0, 1014.0], [1058.0, 1146.0], [1029.0, 1146.0]], [[992.0, 1014.0], [1021.0, 1014.0], [1021.0, 1196.0], [992.0, 1196.0]], [[954.0, 1014.0], [983.0, 1014.0], [983.0, 1227.0], [954.0, 1227.0]], [[917.0, 1014.0], [946.0, 1014.0], [948.0, 1221.0], [919.0, 1221.0]]], "lines": ["選択肢が二つ", "ある場合、", "努めて冷静に", "正解を選び取る", "べきなのだ、と。"]}, {"box": [1138, 1360, 1244, 1573], "vertical": true, "font_size": 33, "lines_coords": [[[1209.0, 1360.0], [1244.0, 1360.0], [1244.0, 1488.0], [1209.0, 1488.0]], [[1174.0, 1362.0], [1209.0, 1362.0], [1209.0, 1486.0], [1174.0, 1486.0]], [[1139.0, 1364.0], [1168.0, 1364.0], [1168.0, 1573.0], [1139.0, 1573.0]]], "lines": ["．．．その時", "君の命は", "燃えているか？"]}, {"box": [323, 954, 503, 1200], "vertical": true, "font_size": 32, "lines_coords": [[[474.0, 958.0], [503.0, 958.0], [503.0, 1140.0], [474.0, 1140.0]], [[432.0, 954.0], [468.0, 954.0], [468.0, 1200.0], [432.0, 1200.0]], [[399.0, 958.0], [428.0, 958.0], [428.0, 1146.0], [399.0, 1146.0]], [[362.0, 956.0], [391.0, 956.0], [391.0, 1138.0], [362.0, 1138.0]], [[323.0, 956.0], [358.0, 956.0], [358.0, 1109.0], [323.0, 1109.0]]], "lines": ["しかし実際は", "どちらとも正解の", "場合もあるし、", "その逆もまた", "然りだ．．．"]}, {"box": [167, 1028, 271, 1244], "vertical": true, "font_size": 32, "lines_coords": [[[242.0, 1031.0], [271.0, 1031.0], [271.0, 1242.0], [242.0, 1242.0]], [[200.0, 1028.0], [236.0, 1028.0], [236.0, 1244.0], [200.0, 1244.0]], [[167.0, 1031.0], [196.0, 1031.0], [196.0, 1242.0], [167.0, 1242.0]]], "lines": ["結論を急ぐのは", "若さの特権かも", "しれないが．．．"]}, {"box": [625, 1548, 669, 1656], "vertical": true, "font_size": 40, "lines_coords": [[[625.0, 1548.0], [669.0, 1548.0], [669.0, 1656.0], [625.0, 1656.0]]], "lines": ["ん．．．．．"]}, {"box": [803, 1788, 946, 1979], "vertical": true, "font_size": 33, "lines_coords": [[[907.0, 1788.0], [946.0, 1788.0], [946.0, 1886.0], [907.0, 1886.0]], [[874.0, 1788.0], [909.0, 1788.0], [909.0, 1979.0], [874.0, 1979.0]], [[838.0, 1790.0], [867.0, 1790.0], [867.0, 1966.0], [838.0, 1966.0]], [[803.0, 1790.0], [832.0, 1790.0], [832.0, 1939.0], [803.0, 1939.0]]], "lines": ["．．．時折", "夢想するんだ、", "もうひとつの", "人生を．．．"]}, {"box": [588, 1728, 623, 1931], "vertical": true, "font_size": 40, "lines_coords": [[[588.0, 1728.0], [623.0, 1728.0], [623.0, 1931.0], [588.0, 1931.0]]], "lines": ["．．．雄一くん？"]}, {"box": [174, 1803, 253, 2004], "vertical": true, "font_size": 33, "lines_coords": [[[215.0, 1803.0], [250.0, 1803.0], [250.0, 1941.0], [215.0, 1941.0]], [[176.0, 1803.0], [207.0, 1803.0], [205.0, 2001.0], [174.0, 2001.0]]], "lines": ["誰とお話", "してるの．．．？"]}], "img_path": "091.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1238, 126, 1278, 314], "vertical": true, "font_size": 36, "lines_coords": [[[1238.0, 126.0], [1273.0, 126.0], [1278.0, 314.0], [1242.0, 314.0]]], "lines": ["．．．友達だよ。"]}, {"box": [676, 122, 713, 296], "vertical": true, "font_size": 35, "lines_coords": [[[677.0, 122.0], [712.0, 122.0], [712.0, 293.0], [677.0, 293.0]]], "lines": ["ふふふ．．．"]}, {"box": [331, 327, 366, 498], "vertical": true, "font_size": 32, "lines_coords": [[[331.0, 327.0], [366.0, 327.0], [366.0, 498.0], [331.0, 498.0]]], "lines": ["ところで．．．"]}, {"box": [1135, 790, 1259, 1047], "vertical": true, "font_size": 39, "lines_coords": [[[1215.0, 792.0], [1259.0, 792.0], [1259.0, 902.0], [1215.0, 902.0]], [[1176.0, 790.0], [1213.0, 790.0], [1209.0, 966.0], [1172.0, 966.0]], [[1135.0, 797.0], [1170.0, 797.0], [1170.0, 1045.0], [1135.0, 1045.0]]], "lines": ["．．．僕は", "「亀太郎」が", "いいと思ってる。"]}, {"box": [870, 472, 994, 691], "vertical": true, "font_size": 39, "lines_coords": [[[948.0, 472.0], [994.0, 472.0], [994.0, 592.0], [948.0, 592.0]], [[911.0, 474.0], [946.0, 474.0], [946.0, 643.0], [911.0, 643.0]], [[870.0, 476.0], [905.0, 476.0], [905.0, 691.0], [870.0, 691.0]]], "lines": ["．．．ふふ、", "友達なんて", "いないくせに。"]}, {"box": [151, 465, 269, 701], "vertical": true, "font_size": 32, "lines_coords": [[[234.0, 467.0], [269.0, 467.0], [269.0, 676.0], [234.0, 676.0]], [[194.0, 469.0], [223.0, 469.0], [223.0, 701.0], [194.0, 701.0]], [[151.0, 465.0], [180.0, 465.0], [180.0, 604.0], [151.0, 604.0]]], "lines": ["この子の名前、", "ちゃんと考えて", "くれた？"]}, {"box": [1143, 1463, 1261, 1666], "vertical": true, "font_size": 36, "lines_coords": [[[1226.0, 1463.0], [1261.0, 1463.0], [1261.0, 1600.0], [1226.0, 1600.0]], [[1184.0, 1465.0], [1222.0, 1465.0], [1218.0, 1664.0], [1180.0, 1664.0]], [[1143.0, 1463.0], [1178.0, 1463.0], [1178.0, 1666.0], [1143.0, 1666.0]]], "lines": ["．．．ならば", "いっそ二つの", "間をとって．．．"]}, {"box": [273, 956, 381, 1169], "vertical": true, "font_size": 34, "lines_coords": [[[341.0, 958.0], [381.0, 958.0], [381.0, 1055.0], [341.0, 1055.0]], [[306.0, 956.0], [341.0, 956.0], [337.0, 1169.0], [302.0, 1169.0]], [[273.0, 960.0], [302.0, 960.0], [302.0, 1153.0], [273.0, 1153.0]]], "lines": ["やだァ", "もっとかわいい", "ほうがいいな。"]}, {"box": [167, 1217, 285, 1457], "vertical": true, "font_size": 34, "lines_coords": [[[250.0, 1219.0], [285.0, 1219.0], [285.0, 1391.0], [250.0, 1391.0]], [[207.0, 1217.0], [244.0, 1217.0], [240.0, 1457.0], [203.0, 1457.0]], [[167.0, 1219.0], [196.0, 1219.0], [196.0, 1387.0], [167.0, 1387.0]]], "lines": ["蒼い空って", "書いて「そあら」", "とかどう？"]}, {"box": [221, 1616, 340, 1823], "vertical": true, "font_size": 37, "lines_coords": [[[302.0, 1616.0], [339.0, 1616.0], [333.0, 1821.0], [296.0, 1821.0]], [[254.0, 1618.0], [300.0, 1618.0], [300.0, 1728.0], [254.0, 1728.0]], [[221.0, 1621.0], [250.0, 1621.0], [250.0, 1819.0], [221.0, 1819.0]]], "lines": ["「希望」なんて", "名前は", "どうだろう？"]}], "img_path": "092.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1162, 826, 1305, 1014], "vertical": true, "font_size": 34, "lines_coords": [[[1276.0, 830.0], [1305.0, 830.0], [1305.0, 983.0], [1276.0, 983.0]], [[1238.0, 830.0], [1267.0, 830.0], [1267.0, 1014.0], [1238.0, 1014.0]], [[1201.0, 828.0], [1230.0, 828.0], [1230.0, 1012.0], [1201.0, 1012.0]], [[1162.0, 826.0], [1199.0, 826.0], [1199.0, 944.0], [1162.0, 944.0]]], "lines": ["何気に仮免", "余裕でしたー", "本試験も楽勝", "でしょー"]}, {"box": [977, 879, 1106, 1068], "vertical": true, "font_size": 34, "lines_coords": [[[1062.0, 879.0], [1106.0, 879.0], [1106.0, 1002.0], [1062.0, 1002.0]], [[1023.0, 881.0], [1058.0, 881.0], [1058.0, 1022.0], [1023.0, 1022.0]], [[977.0, 879.0], [1012.0, 879.0], [1017.0, 1068.0], [981.0, 1068.0]]], "lines": ["そうそ、", "問題は車", "なんですよ。"]}, {"box": [377, 801, 517, 1074], "vertical": true, "font_size": 30, "lines_coords": [[[488.0, 801.0], [517.0, 801.0], [517.0, 1014.0], [488.0, 1014.0]], [[451.0, 801.0], [480.0, 801.0], [480.0, 1074.0], [451.0, 1074.0]], [[414.0, 803.0], [443.0, 803.0], [443.0, 1045.0], [414.0, 1045.0]], [[377.0, 805.0], [406.0, 805.0], [406.0, 1043.0], [377.0, 1043.0]]], "lines": ["パパは駐車場代", "出せば買ってくれる", "って言ってたけど", "ママがねェ―．．．"]}, {"box": [190, 906, 306, 1111], "vertical": true, "font_size": 30, "lines_coords": [[[271.0, 906.0], [306.0, 906.0], [306.0, 1111.0], [271.0, 1111.0]], [[234.0, 908.0], [263.0, 908.0], [263.0, 1107.0], [234.0, 1107.0]], [[190.0, 906.0], [223.0, 906.0], [223.0, 958.0], [190.0, 958.0]]], "lines": ["ねぇ亮ちんも", "説得手伝って", "よー"]}, {"box": [1147, 1198, 1324, 1455], "vertical": true, "font_size": 30, "lines_coords": [[[1294.0, 1200.0], [1323.0, 1200.0], [1323.0, 1455.0], [1294.0, 1455.0]], [[1255.0, 1198.0], [1286.0, 1198.0], [1288.0, 1426.0], [1257.0, 1426.0]], [[1220.0, 1200.0], [1249.0, 1200.0], [1249.0, 1411.0], [1220.0, 1411.0]], [[1180.0, 1198.0], [1211.0, 1198.0], [1213.0, 1438.0], [1182.0, 1438.0]], [[1147.0, 1198.0], [1176.0, 1198.0], [1176.0, 1380.0], [1147.0, 1380.0]]], "lines": ["．．．あっそハナから", "期待してねぇし。", "つか亮太の茶髪", "嫌いだってママが", "言ってたよ？"]}, {"box": [696, 1349, 880, 1590], "vertical": true, "font_size": 32, "lines_coords": [[[843.0, 1353.0], [880.0, 1353.0], [880.0, 1505.0], [843.0, 1505.0]], [[805.0, 1353.0], [841.0, 1353.0], [836.0, 1503.0], [801.0, 1503.0]], [[772.0, 1353.0], [801.0, 1353.0], [801.0, 1534.0], [772.0, 1534.0]], [[735.0, 1353.0], [764.0, 1353.0], [764.0, 1590.0], [735.0, 1590.0]], [[700.0, 1349.0], [731.0, 1349.0], [727.0, 1488.0], [696.0, 1488.0]]], "lines": ["あの人、頭", "固いんすわ", "真面目すぎて", "言ったら引かない", "ちゅうか。"]}, {"box": [225, 1360, 366, 1542], "vertical": true, "font_size": 31, "lines_coords": [[[337.0, 1449.0], [366.0, 1449.0], [366.0, 1515.0], [337.0, 1515.0]], [[339.0, 1360.0], [362.0, 1360.0], [362.0, 1453.0], [339.0, 1453.0]], [[300.0, 1362.0], [329.0, 1362.0], [329.0, 1542.0], [300.0, 1542.0]], [[261.0, 1362.0], [290.0, 1362.0], [290.0, 1511.0], [261.0, 1511.0]], [[225.0, 1364.0], [252.0, 1364.0], [252.0, 1542.0], [225.0, 1542.0]]], "lines": ["．．．", "まァー", "当面はママの", "原付借りる", "感じかなー"]}, {"box": [192, 1643, 273, 1817], "vertical": true, "font_size": 31, "lines_coords": [[[238.0, 1650.0], [273.0, 1650.0], [273.0, 1817.0], [238.0, 1817.0]], [[192.0, 1643.0], [236.0, 1643.0], [236.0, 1755.0], [192.0, 1755.0]]], "lines": ["そういえば", "明日．．．"]}], "img_path": "093.png"}, {"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1149, 1454, 1278, 1815], "vertical": true, "font_size": 36, "lines_coords": [[[1186.0, 1633.0], [1222.0, 1633.0], [1222.0, 1813.0], [1186.0, 1813.0]], [[1