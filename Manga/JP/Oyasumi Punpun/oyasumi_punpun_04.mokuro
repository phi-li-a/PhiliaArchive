128.0], [535.0, 128.0], [535.0, 310.0], [514.0, 310.0]], [[481.0, 128.0], [503.0, 128.0], [503.0, 337.0], [481.0, 337.0]], [[446.0, 128.0], [470.0, 128.0], [471.0, 320.0], [448.0, 320.0]]], "lines": ["．．．食品衛生", "管理者の資格とか、", "もちろん資金も", "まだ十分な準備は", "出来てないけど、"]}, {"box": [89, 45, 373, 67], "vertical": false, "font_size": 22, "lines_coords": [[[89.0, 45.0], [373.0, 45.0], [373.0, 67.0], [89.0, 67.0]]], "lines": ["おやすみプンプンは"]}, {"box": [95, 210, 239, 396], "vertical": true, "font_size": 24, "lines_coords": [[[210.0, 210.0], [237.0, 210.0], [237.0, 396.0], [210.0, 396.0]], [[184.0, 212.0], [206.0, 212.0], [206.0, 343.0], [184.0, 343.0]], [[153.0, 210.0], [179.0, 210.0], [179.0, 376.0], [153.0, 376.0]], [[126.0, 210.0], [148.0, 210.0], [148.0, 368.0], [126.0, 368.0]], [[95.0, 210.0], [117.0, 210.0], [120.0, 393.0], [98.0, 393.0]]], "lines": ["内装をそのまま", "引き渡して", "もらえるなら、", "費用はずっと", "抑えられるし．．．"]}, {"box": [428, 484, 557, 723], "vertical": true, "font_size": 24, "lines_coords": [[[529.0, 487.0], [556.0, 487.0], [556.0, 721.0], [529.0, 721.0]], [[496.0, 487.0], [518.0, 487.0], [518.0, 615.0], [496.0, 615.0]], [[460.0, 484.0], [487.0, 484.0], [487.0, 723.0], [460.0, 723.0]], [[428.0, 485.0], [450.0, 485.0], [450.0, 692.0], [428.0, 692.0]]], "lines": ["．．．それと、雄一君も", "陶芸教室て", "また働くかどうかで", "迷ってたでしょ？"]}, {"box": [848, 796, 951, 1007], "vertical": true, "font_size": 28, "lines_coords": [[[920.0, 798.0], [951.0, 798.0], [951.0, 985.0], [920.0, 985.0]], [[884.0, 798.0], [910.0, 798.0], [910.0, 1006.0], [884.0, 1006.0]], [[848.0, 796.0], [875.0, 796.0], [875.0, 1007.0], [848.0, 1007.0]]], "lines": ["雄一君は先生を", "やりつつ、自分の", "作品を作って．．．"]}, {"box": [715, 967, 818, 1179], "vertical": true, "font_size": 28, "lines_coords": [[[789.0, 968.0], [817.0, 968.0], [818.0, 1131.0], [790.0, 1131.0]], [[756.0, 968.0], [782.0, 968.0], [782.0, 1179.0], [756.0, 1179.0]], [[715.0, 967.0], [748.0, 967.0], [748.0, 1078.0], [715.0, 1078.0]]], "lines": ["私はその器で", "料理をお客さんに", "出す．．．"]}, {"box": [217, 856, 318, 971], "vertical": true, "font_size": 27, "lines_coords": [[[290.0, 856.0], [318.0, 856.0], [318.0, 960.0], [290.0, 960.0]], [[253.0, 857.0], [281.0, 857.0], [281.0, 962.0], [253.0, 962.0]], [[217.0, 859.0], [245.0, 859.0], [245.0, 971.0], [217.0, 971.0]]], "lines": ["．．．そんな", "喫茶店も", "いいかな。"]}, {"box": [139, 1031, 235, 1214], "vertical": true, "font_size": 27, "lines_coords": [[[207.0, 1031.0], [235.0, 1031.0], [235.0, 1140.0], [207.0, 1140.0]], [[171.0, 1032.0], [200.0, 1032.0], [200.0, 1168.0], [171.0, 1168.0]], [[139.0, 1034.0], [160.0, 1034.0], [160.0, 1214.0], [139.0, 1214.0]]], "lines": ["．．．なんて", "勝手に想像", "しちゃった．．．"]}, {"box": [873, 1323, 971, 1468], "vertical": true, "font_size": 27, "lines_coords": [[[943.0, 1326.0], [971.0, 1326.0], [971.0, 1435.0], [943.0, 1435.0]], [[907.0, 1323.0], [935.0, 1323.0], [932.0, 1457.0], [904.0, 1457.0]], [[873.0, 1325.0], [900.0, 1325.0], [900.0, 1468.0], [873.0, 1468.0]]], "lines": ["．．．店長ね、", "基本的には", "ＯＫだって。"]}, {"box": [743, 1371, 843, 1545], "vertical": true, "font_size": 27, "lines_coords": [[[817.0, 1375.0], [843.0, 1375.0], [843.0, 1520.0], [817.0, 1520.0]], [[781.0, 1375.0], [807.0, 1375.0], [807.0, 1532.0], [781.0, 1532.0]], [[743.0, 1371.0], [768.0, 1371.0], [771.0, 1545.0], [746.0, 1545.0]]], "lines": ["むしろ、少し", "賃料安くして", "くれるってさ。"]}], "img_path": "198.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [931, 121, 953, 278], "vertical": true, "font_size": 27, "lines_coords": [[[931.0, 121.0], [953.0, 121.0], [953.0, 278.0], [931.0, 278.0]]], "lines": ["弱ちゃんは．．．"]}, {"box": [826, 314, 890, 443], "vertical": true, "font_size": 27, "lines_coords": [[[864.0, 317.0], [890.0, 317.0], [890.0, 443.0], [864.0, 443.0]], [[826.0, 314.0], [859.0, 314.0], [859.0, 400.0], [826.0, 400.0]]], "lines": ["たくましい", "な．．．．．"]}, {"box": [243, 379, 304, 535], "vertical": true, "font_size": 27, "lines_coords": [[[278.0, 379.0], [304.0, 379.0], [304.0, 535.0], [278.0, 535.0]], [[243.0, 379.0], [270.0, 379.0], [270.0, 484.0], [243.0, 484.0]]], "lines": ["なんというか", "こう．．．"]}, {"box": [148, 554, 250, 712], "vertical": true, "font_size": 27, "lines_coords": [[[223.0, 556.0], [250.0, 556.0], [250.0, 687.0], [223.0, 687.0]], [[187.0, 554.0], [214.0, 554.0], [214.0, 664.0], [187.0, 664.0]], [[148.0, 554.0], [175.0, 554.0], [178.0, 712.0], [151.0, 712.0]]], "lines": ["夢を現実に", "できる子", "なんだな．．．"]}, {"box": [982, 835, 1009, 968], "vertical": true, "font_size": 28, "lines_coords": [[[982.0, 835.0], [1009.0, 835.0], [1009.0, 968.0], [982.0, 968.0]]], "lines": ["ううん．．．"]}, {"box": [851, 865, 943, 1035], "vertical": true, "font_size": 28, "lines_coords": [[[912.0, 865.0], [943.0, 865.0], [943.0, 1035.0], [912.0, 1035.0]], [[882.0, 868.0], [909.0, 868.0], [909.0, 998.0], [882.0, 998.0]], [[851.0, 868.0], [878.0, 868.0], [878.0, 1032.0], [851.0, 1032.0]]], "lines": ["多分、一人じゃ", "何もできな", "かったと思う。"]}, {"box": [350, 842, 495, 1056], "vertical": true, "font_size": 29, "lines_coords": [[[453.0, 842.0], [490.0, 842.0], [490.0, 993.0], [453.0, 993.0]], [[417.0, 842.0], [448.0, 842.0], [451.0, 1056.0], [420.0, 1056.0]], [[385.0, 845.0], [412.0, 845.0], [412.0, 1026.0], [385.0, 1026.0]], [[351.0, 846.0], [373.0, 846.0], [373.0, 959.0], [351.0, 959.0]]], "lines": ["．．．でも、側に", "いてくれるだけで", "がんばれる気が", "したんだ。"]}, {"box": [660, 1295, 765, 1501], "vertical": true, "font_size": 33, "lines_coords": [[[726.0, 1295.0], [765.0, 1295.0], [765.0, 1392.0], [726.0, 1392.0]], [[693.0, 1296.0], [726.0, 1296.0], [726.0, 1501.0], [693.0, 1501.0]], [[660.0, 1298.0], [687.0, 1298.0], [687.0, 1493.0], [660.0, 1493.0]]], "lines": ["：正直、", "雄一君はとっても", "頼りないけどさ、"]}, {"box": [145, 1320, 175, 1495], "vertical": true, "font_size": 26, "lines_coords": [[[145.0, 1320.0], [171.0, 1320.0], [171.0, 1495.0], [145.0, 1495.0]]], "lines": ["．．．翠ちゃん！！"]}], "img_path": "199.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [904, 93, 931, 206], "vertical": true, "font_size": 27, "lines_coords": [[[904.0, 93.0], [931.0, 93.0], [931.0, 206.0], [904.0, 206.0]]], "lines": ["．．．僕はね、"]}, {"box": [756, 192, 820, 321], "vertical": true, "font_size": 27, "lines_coords": [[[793.0, 192.0], [820.0, 192.0], [820.0, 321.0], [793.0, 321.0]], [[756.0, 192.0], [782.0, 192.0], [782.0, 279.0], [756.0, 279.0]]], "lines": ["この瞬間の", "ために、"]}, {"box": [229, 196, 334, 367], "vertical": true, "font_size": 29, "lines_coords": [[[300.0, 196.0], [334.0, 196.0], [334.0, 282.0], [300.0, 282.0]], [[267.0, 198.0], [293.0, 198.0], [293.0, 356.0], [267.0, 356.0]], [[229.0, 196.0], [256.0, 196.0], [256.0, 362.0], [229.0, 362.0]]], "lines": ["今まで", "生きてきたの", "かもしれない。"]}, {"box": [753, 1060, 895, 1270], "vertical": true, "font_size": 29, "lines_coords": [[[865.0, 1064.0], [893.0, 1064.0], [893.0, 1195.0], [865.0, 1195.0]], [[826.0, 1062.0], [857.0, 1062.0], [857.0, 1270.0], [826.0, 1270.0]], [[795.0, 1067.0], [817.0, 1067.0], [817.0, 1192.0], [795.0, 1192.0]], [[753.0, 1060.0], [787.0, 1060.0], [787.0, 1150.0], [753.0, 1150.0]]], "lines": ["観覧車から", "はるか下に見える", "たくさんの", "人達は、"]}, {"box": [564, 1060, 667, 1245], "vertical": true, "font_size": 28, "lines_coords": [[[634.0, 1060.0], [667.0, 1060.0], [667.0, 1153.0], [634.0, 1153.0]], [[600.0, 1064.0], [626.0, 1064.0], [626.0, 1245.0], [600.0, 1245.0]], [[565.0, 1062.0], [589.0, 1062.0], [587.0, 1229.0], [564.0, 1229.0]]], "lines": ["まるで、", "蟻んこみたいに", "ちっほけです。"]}, {"box": [285, 1059, 385, 1269], "vertical": true, "font_size": 32, "lines_coords": [[[353.0, 1059.0], [385.0, 1059.0], [382.0, 1246.0], [350.0, 1246.0]]], "lines": ["その一粒一粒に"]}, {"box": [281, 1060, 345, 1270], "vertical": true, "font_size": 28, "lines_coords": [[[317.0, 1060.0], [345.0, 1060.0], [343.0, 1270.0], [315.0, 1270.0]], [[281.0, 1064.0], [307.0, 1064.0], [307.0, 1221.0], [281.0, 1221.0]]], "lines": ["それぞれの人生が", "あると思うと"]}, {"box": [187, 1062, 218, 1246], "vertical": true, "font_size": 28, "lines_coords": [[[187.0, 1062.0], [218.0, 1062.0], [218.0, 1246.0], [187.0, 1246.0]]], "lines": ["フンフンは少し"]}, {"box": [153, 1061, 219, 1309], "vertical": true, "font_size": 26, "lines_coords": [[[153.0, 1062.0], [179.0, 1062.0], [179.0, 1304.0], [153.0, 1304.0]]], "lines": ["気が遠くなりました。"]}, {"box": [85, 1370, 162, 1499], "vertical": true, "font_size": 34, "lines_coords": [[[121.0, 1370.0], [162.0, 1370.0], [162.0, 1475.0], [121.0, 1475.0]], [[85.0, 1373.0], [112.0, 1373.0], [112.0, 1498.0], [85.0, 1498.0]]], "lines": ["．．．約束", "しよう！！"]}], "img_path": "200.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [832, 109, 898, 295], "vertical": true, "font_size": 29, "lines_coords": [[[867.0, 109.0], [898.0, 109.0], [898.0, 295.0], [867.0, 295.0]], [[832.0, 110.0], [859.0, 110.0], [859.0, 295.0], [832.0, 295.0]]], "lines": ["二人とも仕事が", "落ちついたら．．"]}, {"box": [243, 498, 281, 721], "vertical": true, "font_size": 33, "lines_coords": [[[243.0, 498.0], [276.0, 498.0], [281.0, 721.0], [248.0, 721.0]]], "lines": ["結婚するって！！"]}, {"box": [976, 1087, 1004, 1156], "vertical": true, "font_size": 32, "lines_coords": [[[976.0, 1087.0], [1004.0, 1087.0], [1004.0, 1156.0], [976.0, 1156.0]]], "lines": ["．．．あー"]}, {"box": [901, 1218, 940, 1290], "vertical": true, "font_size": 32, "lines_coords": [[[904.0, 1218.0], [940.0, 1220.0], [937.0, 1290.0], [901.0, 1289.0]]], "lines": ["それ、"]}, {"box": [478, 1115, 583, 1301], "vertical": true, "font_size": 30, "lines_coords": [[[554.0, 1117.0], [582.0, 1117.0], [582.0, 1248.0], [554.0, 1248.0]], [[518.0, 1115.0], [545.0, 1115.0], [545.0, 1301.0], [518.0, 1301.0]], [[478.0, 1115.0], [512.0, 1115.0], [512.0, 1210.0], [478.0, 1210.0]]], "lines": ["前の彼女に", "言ったセリフと", "同じだ。"]}, {"box": [625, 1367, 651, 1473], "vertical": true, "font_size": 27, "lines_coords": [[[625.0, 1367.0], [651.0, 1367.0], [651.0, 1473.0], [625.0, 1473.0]]], "lines": ["今度は．．．"]}, {"box": [317, 1112, 422, 1296], "vertical": true, "font_size": 27, "lines_coords": [[[392.0, 1114.0], [420.0, 1114.0], [420.0, 1220.0], [392.0, 1220.0]], [[354.0, 1112.0], [381.0, 1112.0], [384.0, 1296.0], [357.0, 1296.0]], [[317.0, 1112.0], [343.0, 1112.0], [346.0, 1273.0], [320.0, 1273.0]]], "lines": ["．．．けれど", "下から見上げた", "自分の存在も"]}, {"box": [514, 1414, 542, 1537], "vertical": true, "font_size": 27, "lines_coords": [[[514.0, 1414.0], [542.0, 1414.0], [542.0, 1537.0], [514.0, 1537.0]]], "lines": ["絶対さ！！"]}, {"box": [132, 1112, 269, 1388], "vertical": true, "font_size": 28, "lines_coords": [[[242.0, 1115.0], [268.0, 1115.0], [268.0, 1276.0], [242.0, 1276.0]], [[203.0, 1112.0], [234.0, 1112.0], [234.0, 1301.0], [203.0, 1301.0]], [[168.0, 1115.0], [195.0, 1115.0], [195.0, 1350.0], [168.0, 1350.0]], [[132.0, 1114.0], [159.0, 1114.0], [160.0, 1387.0], [134.0, 1387.0]]], "lines": ["空を舞う塵か、", "そもそも、誰も", "気付いてないくらい", "ちっほけなんでしょう。"]}], "img_path": "201.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [868, 168, 938, 338], "vertical": true, "font_size": 30, "lines_coords": [[[909.0, 168.0], [937.0, 168.0], [937.0, 303.0], [909.0, 303.0]], [[868.0, 168.0], [900.0, 168.0], [903.0, 337.0], [871.0, 337.0]]], "lines": ["プンプンは", "強い子なので、"]}, {"box": [170, 235, 234, 431], "vertical": true, "font_size": 26, "lines_coords": [[[206.0, 235.0], [232.0, 235.0], [232.0, 395.0], [206.0, 395.0]], [[170.0, 237.0], [196.0, 237.0], [196.0, 428.0], [170.0, 428.0]]], "lines": ["そんなことは", "へっちゃらです。"]}, {"box": [226, 681, 326, 869], "vertical": true, "font_size": 25, "lines_coords": [[[298.0, 681.0], [325.0, 681.0], [325.0, 814.0], [298.0, 814.0]], [[262.0, 681.0], [289.0, 681.0], [289.0, 840.0], [262.0, 840.0]], [[228.0, 682.0], [250.0, 682.0], [250.0, 829.0], [228.0, 829.0]]], "lines": ["それなのに", "こんなに涙が", "出る理由はー"]}, {"box": [468, 1007, 532, 1124], "vertical": true, "font_size": 28, "lines_coords": [[[504.0, 1007.0], [532.0, 1007.0], [532.0, 1114.0], [504.0, 1114.0]], [[468.0, 1009.0], [495.0, 1009.0], [495.0, 1117.0], [468.0, 1117.0]]], "lines": ["考えども", "考えとも"]}, {"box": [196, 1007, 298, 1194], "vertical": true, "font_size": 27, "lines_coords": [[[271.0, 1010.0], [293.0, 1010.0], [293.0, 1165.0], [271.0, 1165.0]], [[231.0, 1007.0], [262.0, 1007.0], [262.0, 1192.0], [231.0, 1192.0]], [[196.0, 1007.0], [223.0, 1007.0], [223.0, 1150.0], [196.0, 1150.0]]], "lines": ["観覧車はただ", "終わりに近づく", "だけでした。"]}, {"box": [112, 1368, 148, 1525], "vertical": true, "font_size": 31, "lines_coords": [[[117.0, 1368.0], [148.0, 1368.0], [143.0, 1525.0], [112.0, 1525.0]]], "lines": ["ゴメンね？"]}], "img_path": "202.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [957, 65, 1018, 196], "vertical": true, "font_size": 25, "lines_coords": [[[990.0, 65.0], [1018.0, 65.0], [1018.0, 173.0], [990.0, 173.0]], [[957.0, 67.0], [979.0, 67.0], [979.0, 195.0], [957.0, 195.0]]], "lines": ["．．．ホント", "ごめんッ！！"]}, {"box": [510, 42, 633, 279], "vertical": true, "font_size": 27, "lines_coords": [[[603.0, 42.0], [631.0, 42.0], [632.0, 279.0], [604.0, 279.0]], [[571.0, 42.0], [603.0, 42.0], [603.0, 214.0], [571.0, 214.0]], [[542.0, 43.0], [568.0, 43.0], [568.0, 240.0], [542.0, 240.0]], [[510.0, 43.0], [532.0, 43.0], [532.0, 225.0], [510.0, 225.0]]], "lines": ["私達から別行動って", "言っておいて、", "待ち合わせ、遅れ", "ちゃうなんて．．．"]}, {"box": [332, 109, 423, 306], "vertical": true, "font_size": 27, "lines_coords": [[[396.0, 110.0], [423.0, 110.0], [423.0, 306.0], [396.0, 306.0]], [[365.0, 110.0], [392.0, 110.0], [392.0, 281.0], [365.0, 281.0]], [[332.0, 109.0], [359.0, 109.0], [359.0, 265.0], [332.0, 265.0]]], "lines": ["オゥオゥ、小僧！！", "一人で、イカ串", "三本たぁ．．．"]}, {"box": [465, 453, 589, 614], "vertical": true, "font_size": 28, "lines_coords": [[[556.0, 453.0], [589.0, 453.0], [589.0, 564.0], [556.0, 564.0]], [[526.0, 454.0], [554.0, 454.0], [554.0, 589.0], [526.0, 589.0]], [[493.0, 453.0], [520.0, 453.0], [523.0, 614.0], [496.0, 614.0]], [[465.0, 454.0], [487.0, 454.0], [487.0, 609.0], [465.0, 609.0]]], "lines": ["この人が", "飲み過ぎて", "気分悪いって", "言うから．．．．．"]}, {"box": [112, 475, 201, 668], "vertical": true, "font_size": 26, "lines_coords": [[[173.0, 476.0], [200.0, 476.0], [200.0, 582.0], [173.0, 582.0]], [[140.0, 475.0], [167.0, 475.0], [167.0, 662.0], [140.0, 662.0]], [[112.0, 476.0], [135.0, 476.0], [137.0, 659.0], [114.0, 659.0]]], "lines": ["なかなか", "男前じゃねーか", "このヤロウッ！！"]}], "img_path": "203.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [750, 114, 821, 248], "vertical": true, "font_size": 26, "lines_coords": [[[785.0, 114.0], [818.0, 114.0], [821.0, 248.0], [789.0, 248.0]], [[750.0, 114.0], [782.0, 114.0], [782.0, 221.0], [750.0, 221.0]]], "lines": ["ハァ～～～", "遊園地？"]}, {"box": [596, 164, 717, 332], "vertical": true, "font_size": 26, "lines_coords": [[[695.0, 164.0], [717.0, 164.0], [717.0, 331.0], [695.0, 331.0]], [[660.0, 165.0], [687.0, 165.0], [687.0, 310.0], [660.0, 310.0]], [[628.0, 165.0], [651.0, 165.0], [653.0, 332.0], [629.0, 332.0]], [[596.0, 167.0], [618.0, 167.0], [618.0, 307.0], [596.0, 307.0]]], "lines": ["誘えっつーの！！", "パートなんて", "余裕でサボって", "やるっつの！！"]}, {"box": [325, 132, 414, 310], "vertical": true, "font_size": 36, "lines_coords": [[[381.0, 135.0], [414.0, 135.0], [414.0, 310.0], [381.0, 310.0]], [[328.0, 132.0], [367.0, 132.0], [364.0, 278.0], [325.0, 278.0]]], "lines": ["．．．ファッ！！", "死ねッ！！"]}, {"box": [160, 184, 193, 293], "vertical": true, "font_size": 28, "lines_coords": [[[160.0, 184.0], [193.0, 184.0], [193.0, 293.0], [160.0, 293.0]]], "lines": ["ですよね"]}, {"box": [131, 225, 154, 290], "vertical": true, "font_size": 28, "lines_coords": [[[131.0, 225.0], [154.0, 225.0], [154.0, 290.0], [131.0, 290.0]]], "lines": ["～～～．．．"]}, {"box": [446, 578, 551, 762], "vertical": true, "font_size": 29, "lines_coords": [[[517.0, 578.0], [551.0, 578.0], [551.0, 665.0], [517.0, 665.0]], [[485.0, 579.0], [512.0, 579.0], [512.0, 762.0], [485.0, 762.0]], [[446.0, 578.0], [473.0, 578.0], [473.0, 682.0], [446.0, 682.0]]], "lines": ["．．．けど", "カップルばかり", "ですよ？"]}, {"box": [103, 609, 167, 763], "vertical": true, "font_size": 26, "lines_coords": [[[137.0, 609.0], [164.0, 609.0], [164.0, 760.0], [137.0, 760.0]], [[103.0, 610.0], [129.0, 610.0], [129.0, 751.0], [103.0, 751.0]]], "lines": ["．．．あ、雄一君、", "寝ちゃった。"]}, {"box": [942, 795, 1003, 1006], "vertical": true, "font_size": 25, "lines_coords": [[[981.0, 798.0], [1003.0, 798.0], [1003.0, 981.0], [981.0, 981.0]], [[945.0, 795.0], [971.0, 795.0], [968.0, 1006.0], [942.0, 1006.0]]], "lines": ["．．．ねぇ翠ちゃん", "今夜はどうなの？"]}, {"box": [831, 910, 925, 1062], "vertical": true, "font_size": 25, "lines_coords": [[[892.0, 910.0], [925.0, 910.0], [925.0, 996.0], [892.0, 996.0]], [[864.0, 921.0], [885.0, 921.0], [885.0, 1060.0], [864.0, 1060.0]], [[831.0, 921.0], [853.0, 921.0], [853.0, 1062.0], [831.0, 1062.0]]], "lines": ["今日も", "女子トークで", "飲み明かす？"]}, {"box": [465, 926, 596, 1132], "vertical": true, "font_size": 23, "lines_coords": [[[570.0, 928.0], [596.0, 928.0], [596.0, 1046.0], [570.0, 1046.0]], [[543.0, 928.0], [567.0, 928.0], [568.0, 1087.0], [545.0, 1087.0]], [[518.0, 929.0], [540.0, 929.0], [540.0, 1132.0], [518.0, 1132.0]], [[492.0, 928.0], [514.0, 928.0], [514.0, 1087.0], [492.0, 1087.0]], [[465.0, 926.0], [487.0, 926.0], [487.0, 1042.0], [465.0, 1042.0]]], "lines": ["いやぁ～～", "なんだかんだて", "ひと月のうち半分は", "泊めてもらって", "るんて．．．．．．"]}, {"box": [139, 850, 263, 1051], "vertical": true, "font_size": 22, "lines_coords": [[[239.0, 851.0], [260.0, 851.0], [260.0, 1028.0], [239.0, 1028.0]], [[204.0, 853.0], [226.0, 853.0], [226.0, 1040.0], [204.0, 1040.0]], [[171.0, 853.0], [193.0, 853.0], [193.0, 1042.0], [171.0, 1042.0]], [[139.0, 850.0], [160.0, 850.0], [160.0, 1050.0], [139.0, 1050.0]]], "lines": ["．．．じゃあ、明日の", "夕飯何にします？", "お姉さんの好きな", "もの、作りますよ？"]}, {"box": [926, 1176, 1015, 1353], "vertical": true, "font_size": 23, "lines_coords": [[[992.0, 1176.0], [1014.0, 1176.0], [1014.0, 1329.0], [992.0, 1329.0]], [[956.0, 1176.0], [982.0, 1176.0], [982.0, 1340.0], [956.0, 1340.0]], [[926.0, 1178.0], [948.0, 1178.0], [948.0, 1353.0], [926.0, 1353.0]]], "lines": ["．．．なによ、全然", "迷惑じゃないっ", "つってんじゃん。"]}, {"box": [728, 1389, 821, 1537], "vertical": true, "font_size": 25, "lines_coords": [[[793.0, 1389.0], [821.0, 1389.0], [818.0, 1487.0], [790.0, 1487.0]], [[759.0, 1390.0], [785.0, 1390.0], [785.0, 1537.0], [759.0, 1537.0]], [[729.0, 1392.0], [750.0, 1392.0], [750.0, 1532.0], [729.0, 1532.0]]], "lines": ["料理上手", "だしさぁ～～", "住めっつの！！"]}, {"box": [87, 1321, 214, 1565], "vertical": true, "font_size": 24, "lines_coords": [[[189.0, 1323.0], [210.0, 1323.0], [210.0, 1495.0], [189.0, 1495.0]], [[160.0, 1321.0], [187.0, 1321.0], [187.0, 1565.0], [160.0, 1565.0]], [[137.0, 1323.0], [159.0, 1323.0], [159.0, 1518.0], [137.0, 1518.0]], [[109.0, 1321.0], [135.0, 1321.0], [135.0, 1532.0], [109.0, 1532.0]], [[87.0, 1326.0], [110.0, 1326.0], [110.0, 1371.0], [87.0, 1371.0]]], "lines": ["あ～～だったら", "あたし、バート終わりに", "食材買って、早目に", "帰ってこようかしら", "．．．"]}], "img_path": "204.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [939, 142, 968, 193], "vertical": true, "font_size": 31, "lines_coords": [[[939.0, 142.0], [968.0, 142.0], [968.0, 193.0], [939.0, 193.0]]], "lines": ["あ。"]}, {"box": [857, 179, 890, 290], "vertical": true, "font_size": 31, "lines_coords": [[[857.0, 179.0], [890.0, 179.0], [890.0, 290.0], [857.0, 290.0]]], "lines": ["何コレ？"]}, {"box": [160, 201, 189, 331], "vertical": true, "font_size": 27, "lines_coords": [[[160.0, 201.0], [187.0, 201.0], [187.0, 331.0], [160.0, 331.0]]], "lines": ["この感じ？"]}, {"box": [645, 448, 714, 612], "vertical": true, "font_size": 57, "lines_coords": [[[657.0, 448.0], [714.0, 453.0], [701.0, 612.0], [645.0, 607.0]]], "lines": ["キャハハ"]}, {"box": [542, 415, 575, 604], "vertical": true, "font_size": 27, "lines_coords": [[[543.0, 415.0], [570.0, 415.0], [570.0, 601.0], [543.0, 601.0]]], "lines": ["家族みたい！！"]}, {"box": [907, 1006, 989, 1196], "vertical": true, "font_size": 36, "lines_coords": [[[951.0, 1007.0], [989.0, 1007.0], [989.0, 1162.0], [951.0, 1162.0]], [[910.0, 1006.0], [943.0, 1006.0], [940.0, 1196.0], [907.0, 1196.0]]], "lines": ["アハハハ！！", "楽しいワァ！！"]}, {"box": [568, 1010, 596, 1171], "vertical": true, "font_size": 27, "lines_coords": [[[568.0, 1010.0], [595.0, 1010.0], [595.0, 1167.0], [568.0, 1167.0]]], "lines": ["：フンフンは"]}, {"box": [370, 1009, 475, 1166], "vertical": true, "font_size": 30, "lines_coords": [[[446.0, 1010.0], [475.0, 1010.0], [475.0, 1115.0], [446.0, 1115.0]], [[410.0, 1012.0], [437.0, 1012.0], [437.0, 1165.0], [410.0, 1165.0]], [[370.0, 1009.0], [404.0, 1009.0], [404.0, 1101.0], [370.0, 1101.0]]], "lines": ["こんなの", "家族ごっこの", "ようて、"]}, {"box": [154, 1007, 295, 1118], "vertical": true, "font_size": 32, "lines_coords": [[[267.0, 1010.0], [293.0, 1010.0], [293.0, 1117.0], [267.0, 1117.0]], [[229.0, 1009.0], [257.0, 1009.0], [259.0, 1115.0], [231.0, 1115.0]], [[189.0, 1007.0], [228.0, 1007.0], [228.0, 1118.0], [189.0, 1118.0]], [[154.0, 1009.0], [189.0, 1009.0], [189.0, 1100.0], [154.0, 1100.0]]], "lines": ["馬鹿馬鹿", "しくって", "全然フー", "てした。"]}, {"box": [698, 1348, 788, 1515], "vertical": true, "font_size": 23, "lines_coords": [[[764.0, 1351.0], [785.0, 1351.0], [785.0, 1473.0], [764.0, 1473.0]], [[728.0, 1348.0], [754.0, 1348.0], [751.0, 1515.0], [725.0, 1515.0]], [[698.0, 1348.0], [720.0, 1348.0], [720.0, 1500.0], [698.0, 1500.0]]], "lines": ["．．．お姉さん、", "最近そればかり", "言ってますね。"]}, {"box": [198, 1284, 225, 1439], "vertical": true, "font_size": 28, "lines_coords": [[[198.0, 1284.0], [225.0, 1284.0], [225.0, 1439.0], [198.0, 1439.0]]], "lines": ["．．．プンプン？"]}, {"box": [95, 1403, 159, 1534], "vertical": true, "font_size": 28, "lines_coords": [[[129.0, 1403.0], [157.0, 1403.0], [159.0, 1534.0], [131.0, 1534.0]], [[95.0, 1404.0], [123.0, 1404.0], [123.0, 1518.0], [95.0, 1518.0]]], "lines": ["今日は楽し", "かったね。"]}], "img_path": "205.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [885, 73, 1010, 239], "vertical": true, "font_size": 25, "lines_coords": [[[984.0, 73.0], [1010.0, 75.0], [1006.0, 170.0], [979.0, 168.0]], [[950.0, 75.0], [976.0, 75.0], [976.0, 239.0], [950.0, 239.0]], [[920.0, 75.0], [942.0, 75.0], [942.0, 217.0], [920.0, 217.0]], [[885.0, 76.0], [912.0, 76.0], [912.0, 170.0], [885.0, 170.0]]], "lines": ["．．．なんか", "お姉さんがコレ", "渡しておいて", "って．．．"]}, {"box": [715, 68, 814, 215], "vertical": true, "font_size": 31, "lines_coords": [[[775.0, 68.0], [814.0, 68.0], [814.0, 154.0], [775.0, 154.0]], [[748.0, 73.0], [775.0, 73.0], [775.0, 215.0], [748.0, 215.0]], [[715.0, 73.0], [742.0, 73.0], [742.0, 168.0], [715.0, 168.0]]], "lines": ["．．．手紙、", "ココに置いて", "おくね？"]}, {"box": [382, 517, 596, 734], "vertical": true, "font_size": 29, "lines_coords": [[[565.0, 518.0], [596.0, 518.0], [596.0, 734.0], [565.0, 734.0]], [[529.0, 518.0], [560.0, 518.0], [560.0, 679.0], [529.0, 679.0]], [[495.0, 517.0], [526.0, 517.0], [523.0, 704.0], [492.0, 704.0]], [[457.0, 518.0], [485.0, 518.0], [484.0, 728.0], [456.0, 728.0]], [[421.0, 520.0], [448.0, 520.0], [448.0, 678.0], [421.0, 678.0]], [[382.0, 518.0], [417.0, 518.0], [417.0, 609.0], [382.0, 609.0]]], "lines": ["人の気も知らずに、", "また能天気に", "ジャイアンツと", "宇宙のことばかり", "書いてあると", "思うと、"]}, {"box": [203, 518, 339, 726], "vertical": true, "font_size": 29, "lines_coords": [[[310.0, 518.0], [339.0, 518.0], [339.0, 623.0], [310.0, 623.0]], [[275.0, 520.0], [301.0, 520.0], [301.0, 678.0], [275.0, 678.0]], [[239.0, 518.0], [265.0, 518.0], [265.0, 726.0], [239.0, 726.0]], [[203.0, 520.0], [229.0, 520.0], [229.0, 659.0], [203.0, 659.0]]], "lines": ["なんだか", "腹立たしくて", "封を開ける気にも", "なりません。"]}, {"box": [203, 519, 339, 726], "vertical": true, "font_size": 136, "lines_coords": [[[203.0, 519.0], [339.0, 519.0], [339.0, 726.0], [203.0, 726.0]]], "lines": ["なんだか腹立たしくて封を開ける気にもなりません。"]}, {"box": [871, 1231, 995, 1457], "vertical": true, "font_size": 22, "lines_coords": [[[971.0, 1232.0], [993.0, 1232.0], [993.0, 1389.0], [971.0, 1389.0]], [[937.0, 1232.0], [959.0, 1232.0], [959.0, 1398.0], [937.0, 1398.0]], [[904.0, 1232.0], [926.0, 1232.0], [926.0, 1379.0], [904.0, 1379.0]], [[873.0, 1234.0], [895.0, 1234.0], [895.0, 1453.0], [873.0, 1453.0]]], "lines": ["．．．え〜〜では", "次のおたよりは", "ラジオネーム", "スネークマン君から、"]}, {"box": [96, 1303, 267, 1520], "vertical": true, "font_size": 24, "lines_coords": [[[239.0, 1304.0], [267.0, 1304.0], [267.0, 1390.0], [239.0, 1390.0]], [[207.0, 1303.0], [234.0, 1303.0], [235.0, 1520.0], [209.0, 1520.0]], [[179.0, 1304.0], [203.0, 1304.0], [204.0, 1504.0], [181.0, 1504.0]], [[153.0, 1306.0], [175.0, 1306.0], [175.0, 1473.0], [153.0, 1473.0]], [[121.0, 1304.0], [145.0, 1304.0], [146.0, 1495.0], [123.0, 1495.0]], [[96.0, 1306.0], [117.0, 1306.0], [117.0, 1471.0], [96.0, 1471.0]]], "lines": ["「ついに", "念願の彼女ができた", "中学二年男子です。", "先日のデートで", "手をつなぐことに", "成功しました。」"]}], "img_path": "206.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [868, 81, 1004, 345], "vertical": true, "font_size": 27, "lines_coords": [[[975.0, 81.0], [1003.0, 81.0], [1004.0, 343.0], [976.0, 343.0]], [[942.0, 81.0], [968.0, 81.0], [968.0, 304.0], [942.0, 304.0]], [[906.0, 81.0], [932.0, 81.0], [932.0, 343.0], [906.0, 343.0]], [[868.0, 82.0], [895.0, 82.0], [895.0, 345.0], [868.0, 345.0]]], "lines": ["「けれど、手をつないだ。", "だけで、僕の息子は", "完全ビッキビキ状態で", "まともに歩けません！！"]}, {"box": [720, 278, 842, 475], "vertical": true, "font_size": 27, "lines_coords": [[[815.0, 279.0], [842.0, 279.0], [842.0, 462.0], [815.0, 462.0]], [[784.0, 282.0], [810.0, 282.0], [810.0, 462.0], [784.0, 462.0]], [[750.0, 279.0], [782.0, 279.0], [782.0, 364.0], [750.0, 364.0]], [[721.0, 278.0], [748.0, 278.0], [746.0, 475.0], [720.0, 475.0]]], "lines": ["どうしたらいい", "のでしょうか？", "教えて", "ＴＡＫＵＭＩ！！」"]}, {"box": [157, 540, 259, 779], "vertical": true, "font_size": 28, "lines_coords": [[[228.0, 540.0], [259.0, 540.0], [259.0, 779.0], [228.0, 779.0]], [[193.0, 542.0], [220.0, 542.0], [220.0, 698.0], [193.0, 698.0]], [[157.0, 542.0], [184.0, 542.0], [184.0, 698.0], [157.0, 698.0]]], "lines": ["．．．わっかるナァ～～", "僕も中学生の", "頃なんて．．．"]}, {"box": [870, 895, 973, 1158], "vertical": true, "font_size": 26, "lines_coords": [[[948.0, 896.0], [970.0, 896.0], [970.0, 1157.0], [948.0, 1157.0]], [[906.0, 895.0], [937.0, 895.0], [937.0, 1132.0], [906.0, 1132.0]], [[870.0, 895.0], [896.0, 895.0], [896.0, 1010.0], [870.0, 1010.0]]], "lines": ["．．この頃のフンフンは", "ひたすらに猛勉強の", "子てした。"]}, {"box": [575, 821, 700, 1062], "vertical": true, "font_size": 26, "lines_coords": [[[673.0, 821.0], [700.0, 821.0], [700.0, 1062.0], [673.0, 1062.0]], [[640.0, 823.0], [667.0, 823.0], [667.0, 1026.0], [640.0, 1026.0]], [[607.0, 823.0], [634.0, 823.0], [634.0, 1028.0], [607.0, 1028.0]], [[575.0, 821.0], [596.0, 821.0], [596.0, 1060.0], [575.0, 1060.0]]], "lines": ["「先日、一浪が確定した", "大阪の苦学生です。", "両親は、いい大学に", "行けとうるさいです。」"]}, {"box": [89, 892, 245, 1145], "vertical": true, "font_size": 25, "lines_coords": [[[218.0, 893.0], [245.0, 893.0], [245.0, 1078.0], [218.0, 1078.0]], [[182.0, 892.0], [209.0, 892.0], [210.0, 1062.0], [184.0, 1062.0]], [[151.0, 893.0], [178.0, 893.0], [178.0, 1084.0], [151.0, 1084.0]], [[121.0, 895.0], [143.0, 895.0], [143.0, 1089.0], [121.0, 1089.0]], [[89.0, 895.0], [110.0, 895.0], [110.0, 1143.0], [89.0, 1143.0]]], "lines": ["「一度きりの人生、", "勉強することに", "どれほどの意味が", "あるんでしょうか。", "教えてＴＡＫＵＭＩ！！」"]}, {"box": [742, 1071, 844, 1373], "vertical": true, "font_size": 27, "lines_coords": [[[815.0, 1073.0], [842.0, 1073.0], [842.0, 1318.0], [815.0, 1318.0]], [[775.0, 1071.0], [806.0, 1071.0], [809.0, 1373.0], [778.0, 1373.0]], [[745.0, 1079.0], [767.0, 1079.0], [767.0, 1342.0], [745.0, 1342.0]]], "lines": ["．．．理由はありません。", "ただ、今はこうしてるのが", "一番落ちつくのでした。"]}, {"box": [560, 1168, 662, 1379], "vertical": true, "font_size": 30, "lines_coords": [[[635.0, 1173.0], [662.0, 1173.0], [662.0, 1379.0], [635.0, 1379.0]], [[596.0, 1170.0], [628.0, 1170.0], [628.0, 1356.0], [596.0, 1356.0]], [[560.0, 1168.0], [589.0, 1168.0], [590.0, 1364.0], [562.0, 1364.0]]], "lines": ["たくさん勉強して", "東大の理学部か", "そこらに入って、"]}, {"box": [418, 1168, 523, 1432], "vertical": true, "font_size": 30, "lines_coords": [[[496.0, 1171.0], [523.0, 1171.0], [523.0, 1432.0], [496.0, 1432.0]], [[453.0, 1168.0], [485.0, 1168.0], [489.0, 1382.0], [456.0, 1382.0]], [[418.0, 1168.0], [450.0, 1168.0], [453.0, 1409.0], [421.0, 1409.0]]], "lines": ["原子力を研究している", "地下組織の一員か", "なんかになって．．．"]}], "img_path": "207.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [643, 60, 765, 202], "vertical": true, "font_size": 34, "lines_coords": [[[726.0, 60.0], [765.0, 60.0], [765.0, 159.0], [726.0, 159.0]], [[685.0, 62.0], [718.0, 62.0], [718.0, 190.0], [685.0, 190.0]], [[643.0, 62.0], [671.0, 62.0], [675.0, 200.0], [646.0, 200.0]]], "lines": ["人類を", "皆殺しに", "してやる。"]}, {"box": [264, 137, 340, 356], "vertical": true, "font_size": 32, "lines_coords": [[[309.0, 137.0], [340.0, 137.0], [340.0, 356.0], [309.0, 356.0]], [[264.0, 137.0], [295.0, 137.0], [295.0, 356.0], [264.0, 356.0]]], "lines": ["．．．なァ〰〰んて", "ウソっ子です！！"]}, {"box": [140, 135, 214, 418], "vertical": true, "font_size": 32, "lines_coords": [[[182.0, 135.0], [214.0, 135.0], [214.0, 418.0], [182.0, 418.0]], [[140.0, 135.0], [173.0, 135.0], [173.0, 264.0], [140.0, 264.0]]], "lines": ["ヒィヤアァアアッ！！", "ポウッ！！"]}, {"box": [879, 1258, 941, 1431], "vertical": true, "font_size": 27, "lines_coords": [[[912.0, 1260.0], [939.0, 1260.0], [939.0, 1431.0], [912.0, 1431.0]], [[879.0, 1260.0], [906.0, 1260.0], [906.0, 1425.0], [879.0, 1425.0]]], "lines": ["「はじめまして", "中一男子です。"]}, {"box": [810, 1259, 839, 1398], "vertical": true, "font_size": 27, "lines_coords": [[[810.0, 1260.0], [837.0, 1260.0], [837.0, 1390.0], [810.0, 1390.0]]], "lines": ["家族構成は"]}, {"box": [676, 1258, 770, 1418], "vertical": true, "font_size": 27, "lines_coords": [[[743.0, 1260.0], [770.0, 1260.0], [770.0, 1415.0], [743.0, 1415.0]], [[710.0, 1259.0], [737.0, 1259.0], [737.0, 1415.0], [710.0, 1415.0]], [[676.0, 1260.0], [703.0, 1260.0], [703.0, 1370.0], [676.0, 1370.0]]], "lines": ["家庭内暴力で", "離婚した父と", "酒乱の母、"]}, {"box": [507, 1257, 639, 1495], "vertical": true, "font_size": 28, "lines_coords": [[[607.0, 1257.0], [639.0, 1257.0], [637.0, 1495.0], [606.0, 1495.0]], [[575.0, 1260.0], [601.0, 1260.0], [601.0, 1467.0], [575.0, 1467.0]], [[542.0, 1259.0], [568.0, 1259.0], [565.0, 1417.0], [539.0, 1417.0]], [[507.0, 1260.0], [534.0, 1260.0], [534.0, 1451.0], [507.0, 1451.0]]], "lines": ["深夜は隣の部屋から", "叔父とその彼女の", "やってる声が", "聞こえてきます。"]}, {"box": [440, 1259, 469, 1455], "vertical": true, "font_size": 27, "lines_coords": [[[440.0, 1260.0], [467.0, 1260.0], [467.0, 1450.0], [440.0, 1450.0]]], "lines": ["夢はありません。"]}, {"box": [371, 1259, 400, 1448], "vertical": true, "font_size": 27, "lines_coords": [[[373.0, 1259.0], [400.0, 1259.0], [398.0, 1448.0], [371.0, 1448.0]]], "lines": ["彼女もいません"]}, {"box": [240, 1259, 331, 1506], "vertical": true, "font_size": 24, "lines_coords": [[[304.0, 1259.0], [331.0, 1259.0], [331.0, 1417.0], [304.0, 1417.0]], [[271.0, 1260.0], [293.0, 1260.0], [293.0, 1467.0], [271.0, 1467.0]], [[240.0, 1262.0], [262.0, 1262.0], [262.0, 1506.0], [240.0, 1506.0]]], "lines": ["僕はこれから", "どのように生きて", "いけば良いですか？」"]}, {"box": [170, 1285, 196, 1442], "vertical": true, "font_size": 24, "lines_coords": [[[170.0, 1285.0], [196.0, 1285.0], [196.0, 1442.0], [170.0, 1442.0]]], "lines": ["ラジオネーム"]}, {"box": [134, 1284, 195, 1574], "vertical": true, "font_size": 28, "lines_coords": [[[135.0, 1284.0], [164.0, 1284.0], [162.0, 1570.0], [134.0, 1570.0]]], "lines": ["悩めるエンジェル・バイ"]}], "img_path": "208.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [696, 978, 882, 1282], "vertical": true, "font_size": 69, "lines_coords": [[[784.0, 990.0], [851.0, 979.0], [882.0, 1164.0], [815.0, 1175.0]], [[723.0, 995.0], [800.0, 978.0], [865.0, 1265.0], [789.0, 1282.0]], [[703.0, 1034.0], [762.0, 1029.0], [770.0, 1142.0], [710.0, 1146.0]]], "lines": ["なんかッ", "超ー言いがかり", "んやねー"]}, {"box": [182, 696, 344, 910], "vertical": true, "font_size": 27, "lines_coords": [[[315.0, 698.0], [342.0, 698.0], [342.0, 857.0], [315.0, 857.0]], [[279.0, 696.0], [310.0, 696.0], [310.0, 910.0], [279.0, 910.0]], [[248.0, 698.0], [275.0, 698.0], [275.0, 893.0], [248.0, 893.0]], [[212.0, 698.0], [239.0, 698.0], [239.0, 907.0], [212.0, 907.0]], [[182.0, 700.0], [204.0, 700.0], [204.0, 839.0], [182.0, 839.0]]], "lines": ["神様のくせに", "気の利いた一言も", "言えないなんて、", "ブンブンは残念で", "なりません。"]}, {"box": [45, 945, 644, 1301], "vertical": true, "font_size": 114, "lines_coords": [[[568.0, 995.0], [643.0, 995.0], [643.0, 1103.0], [568.0, 1103.0]], [[489.0, 985.0], [578.0, 1001.0], [550.0, 1159.0], [460.0, 1143.0]], [[298.0, 1051.0], [403.0, 1032.0], [435.0, 1210.0], [331.0, 1229.0]], [[237.0, 1043.0], [332.0, 1045.0], [329.0, 1229.0], [234.0, 1228.0]], [[109.0, 945.0], [314.0, 987.0], [250.0, 1301.0], [45.0, 1260.0]]], "lines": ["だっ", "君が", "様って", "んでる", "だけでしょ？"]}, {"box": [296, 1305, 326, 1445], "vertical": true, "font_size": 27, "lines_coords": [[[296.0, 1312.0], [323.0, 1312.0], [323.0, 1432.0], [296.0, 1432.0]]], "lines": ["．．．じゃあ"]}, {"box": [154, 1301, 241, 1493], "vertical": true, "font_size": 38, "lines_coords": [[[203.0, 1304.0], [235.0, 1304.0], [232.0, 1493.0], [200.0, 1493.0]], [[154.0, 1301.0], [198.0, 1301.0], [198.0, 1376.0], [154.0, 1376.0]]], "lines": ["あなたは一体", "誰？"]}], "img_path": "209.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [887, 407, 998, 593], "vertical": true, "font_size": 24, "lines_coords": [[[970.0, 410.0], [996.0, 410.0], [996.0, 553.0], [970.0, 553.0]], [[940.0, 410.0], [967.0, 410.0], [967.0, 570.0], [940.0, 570.0]], [[909.0, 407.0], [935.0, 407.0], [937.0, 593.0], [910.0, 593.0]], [[887.0, 414.0], [904.0, 414.0], [904.0, 510.0], [887.0, 510.0]]], "lines": ["じゃあ、次の", "おたより紹介", "しちゃおうかな", "．．．"]}, {"box": [475, 481, 574, 665], "vertical": true, "font_size": 25, "lines_coords": [[[546.0, 481.0], [573.0, 481.0], [573.0, 650.0], [546.0, 650.0]], [[509.0, 482.0], [535.0, 482.0], [535.0, 665.0], [509.0, 665.0]], [[476.0, 484.0], [498.0, 484.0], [498.0, 639.0], [476.0, 639.0]]], "lines": ["ラジオネーム、", "北陸のトマト姫", "ちゃんから！！"]}, {"box": [82, 359, 212, 642], "vertical": true, "font_size": 28, "lines_coords": [[[181.0, 359.0], [209.0, 359.0], [210.0, 598.0], [182.0, 598.0]], [[148.0, 360.0], [179.0, 360.0], [179.0, 612.0], [148.0, 612.0]], [[114.0, 362.0], [142.0, 362.0], [143.0, 642.0], [115.0, 642.0]], [[82.0, 362.0], [109.0, 362.0], [109.0, 626.0], [82.0, 626.0]]], "lines": ["「男子は、好きな子を", "想像しながら、一人で", "エッチなことしてるって", "友達から聞きました。」"]}, {"box": [851, 721, 989, 985], "vertical": true, "font_size": 27, "lines_coords": [[[960.0, 721.0], [989.0, 721.0], [989.0, 868.0], [960.0, 868.0]], [[925.0, 723.0], [951.0, 723.0], [951.0, 985.0], [925.0, 985.0]], [[887.0, 723.0], [914.0, 723.0], [914.0, 934.0], [887.0, 934.0]], [[851.0, 721.0], [878.0, 721.0], [878.0, 973.0], [851.0, 973.0]]], "lines": ["「私も誰かに", "汚されてるかと思うと、", "我慢できません！！", "そんなの最低です！！」"]}, {"box": [101, 778, 231, 1056], "vertical": true, "font_size": 27, "lines_coords": [[[200.0, 778.0], [231.0, 778.0], [231.0, 1004.0], [200.0, 1004.0]], [[168.0, 779.0], [195.0, 779.0], [195.0, 992.0], [168.0, 992.0]], [[135.0, 778.0], [162.0, 778.0], [162.0, 939.0], [135.0, 939.0]], [[101.0, 779.0], [123.0, 779.0], [126.0, 1056.0], [104.0, 1056.0]]], "lines": ["「どうして男の子は", "そんなことするん", "でしょうか！？", "教えてＴＡＫＵＭＩ！！」"]}], "img_path": "210.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [636, 1315, 701, 1509], "vertical": true, "font_size": 28, "lines_coords": [[[673.0, 1317.0], [701.0, 1317.0], [701.0, 1423.0], [673.0, 1423.0]], [[637.0, 1317.0], [664.0, 1317.0], [664.0, 1504.0], [637.0, 1504.0]]], "lines": ["もうすく", "春だというのに、"]}, {"box": [515, 1314, 579, 1524], "vertical": true, "font_size": 27, "lines_coords": [[[551.0, 1317.0], [578.0, 1317.0], [578.0, 1523.0], [551.0, 1523.0]], [[515.0, 1315.0], [542.0, 1315.0], [542.0, 1475.0], [515.0, 1475.0]]], "lines": ["深夜の住宅街には", "ここえるほど"]}, {"box": [394, 1315, 459, 1510], "vertical": true, "font_size": 24, "lines_coords": [[[429.0, 1317.0], [456.0, 1317.0], [456.0, 1473.0], [429.0, 1473.0]], [[395.0, 1318.0], [417.0, 1318.0], [417.0, 1507.0], [395.0, 1507.0]]], "lines": ["冷たい夜風が", "吹いていました。"]}], "img_path": "211.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [847, 114, 947, 283], "vertical": true, "font_size": 26, "lines_coords": [[[917.0, 114.0], [945.0, 114.0], [946.0, 259.0], [918.0, 259.0]], [[882.0, 115.0], [909.0, 115.0], [909.0, 246.0], [882.0, 246.0]], [[848.0, 114.0], [870.0, 114.0], [870.0, 281.0], [848.0, 281.0]]], "lines": ["けれど、春は", "いつか必ず", "やってきます。"]}, {"box": [170, 507, 234, 691], "vertical": true, "font_size": 26, "lines_coords": [[[204.0, 507.0], [231.0, 507.0], [231.0, 689.0], [204.0, 689.0]], [[170.0, 507.0], [196.0, 507.0], [196.0, 650.0], [170.0, 650.0]]], "lines": ["終わらない冬は", "ありません。"]}, {"box": [304, 840, 403, 1179], "vertical": true, "font_size": 24, "lines_coords": [[[373.0, 840.0], [400.0, 840.0], [403.0, 1168.0], [376.0, 1168.0]], [[340.0, 845.0], [362.0, 845.0], [362.0, 1001.0], [340.0, 1001.0]], [[304.0, 843.0], [326.0, 843.0], [326.0, 1056.0], [304.0, 1056.0]]], "lines": ["．．．たとえ、明日じゃなくても", "明後日か来月", "それとも何年後か。"]}, {"box": [213, 1020, 276, 1212], "vertical": true, "font_size": 22, "lines_coords": [[[251.0, 1021.0], [273.0, 1021.0], [273.0, 1175.0], [251.0, 1175.0]], [[215.0, 1023.0], [237.0, 1023.0], [237.0, 1207.0], [215.0, 1207.0]]], "lines": ["とんでもなく", "幸せな日か来る。"]}, {"box": [950, 1160, 976, 1317], "vertical": true, "font_size": 26, "lines_coords": [[[950.0, 1160.0], [976.0, 1160.0], [976.0, 1317.0], [950.0, 1317.0]]], "lines": ["．．．フンフンも"]}, {"box": [864, 1162, 921, 1425], "vertical": true, "font_size": 26, "lines_coords": [[[895.0, 1162.0], [921.0, 1162.0], [921.0, 1345.0], [895.0, 1345.0]], [[864.0, 1162.0], [885.0, 1162.0], [885.0, 1425.0], [864.0, 1425.0]]], "lines": ["今日がこんなに", "苦しい一日だったなら"]}, {"box": [735, 1159, 832, 1448], "vertical": true, "font_size": 26, "lines_coords": [[[801.0, 1160.0], [832.0, 1160.0], [832.0, 1395.0], [801.0, 1395.0]], [[767.0, 1159.0], [793.0, 1159.0], [796.0, 1448.0], [770.0, 1448.0]], [[735.0, 1159.0], [762.0, 1159.0], [764.0, 1437.0], [737.0, 1437.0]]], "lines": ["明日はとんでもなく", "楽しい一日か待ってるに", "違いないと思うのです。"]}, {"box": [119, 1181, 182, 1374], "vertical": true, "font_size": 25, "lines_coords": [[[154.0, 1181.0], [182.0, 1181.0], [182.0, 1268.0], [154.0, 1268.0]], [[121.0, 1182.0], [143.0, 1182.0], [143.0, 1370.0], [121.0, 1370.0]]], "lines": ["．．．と、", "思いたいのです。"]}], "img_path": "212.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [634, 620, 734, 782], "vertical": true, "font_size": 28, "lines_coords": [[[704.0, 620.0], [731.0, 620.0], [734.0, 781.0], [707.0, 781.0]], [[668.0, 623.0], [696.0, 623.0], [698.0, 754.0], [670.0, 754.0]], [[634.0, 623.0], [662.0, 623.0], [662.0, 742.0], [634.0, 742.0]]], "lines": ["：それはもう", "祈るような", "気持ちで。"]}, {"box": [396, 623, 459, 755], "vertical": true, "font_size": 28, "lines_coords": [[[431.0, 623.0], [459.0, 623.0], [459.0, 731.0], [431.0, 731.0]], [[396.0, 628.0], [423.0, 628.0], [423.0, 754.0], [396.0, 754.0]]], "lines": ["．．．でも", "一体何に？"]}, {"box": [682, 1240, 706, 1406], "vertical": true, "font_size": 22, "lines_coords": [[[682.0, 1240.0], [704.0, 1240.0], [704.0, 1398.0], [682.0, 1398.0]]], "lines": ["．．．とりあえず"]}, {"box": [526, 1237, 591, 1370], "vertical": true, "font_size": 27, "lines_coords": [[[564.0, 1237.0], [590.0, 1237.0], [587.0, 1370.0], [560.0, 1370.0]], [[526.0, 1239.0], [553.0, 1239.0], [553.0, 1357.0], [526.0, 1357.0]]], "lines": ["今日はもう", "おやすみ。"]}, {"box": [414, 1236, 442, 1355], "vertical": true, "font_size": 26, "lines_coords": [[[414.0, 1239.0], [440.0, 1239.0], [440.0, 1350.0], [414.0, 1350.0]]], "lines": ["フンフン。"]}], "img_path": "213.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "214.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "215.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [925, 51, 962, 214], "vertical": true, "font_size": 39, "lines_coords": [[[925.0, 51.0], [962.0, 51.0], [962.0, 214.0], [925.0, 214.0]]], "lines": ["．．．どっ！！"]}, {"box": [789, 112, 889, 332], "vertical": true, "font_size": 39, "lines_coords": [[[840.0, 112.0], [889.0, 112.0], [889.0, 332.0], [840.0, 332.0]], [[789.0, 220.0], [829.0, 220.0], [829.0, 329.0], [789.0, 329.0]]], "lines": ["どわひゃー", "っ！！"]}, {"box": [187, 128, 334, 385], "vertical": true, "font_size": 32, "lines_coords": [[[298.0, 128.0], [331.0, 128.0], [334.0, 257.0], [301.0, 257.0]], [[260.0, 129.0], [293.0, 129.0], [296.0, 385.0], [264.0, 385.0]], [[225.0, 131.0], [256.0, 131.0], [256.0, 384.0], [225.0, 384.0]], [[187.0, 128.0], [218.0, 128.0], [218.0, 289.0], [187.0, 289.0]]], "lines": ["これ以上", "安くしちゃったら", "部長に大目玉っス", "よォ～～！！"]}, {"box": [12, 287, 62, 456], "vertical": true, "font_size": 50, "lines_coords": [[[12.0, 287.0], [62.0, 287.0], [62.0, 456.0], [12.0, 456.0]]], "lines": ["第４６話"]}, {"box": [790, 414, 912, 635], "vertical": true, "font_size": 39, "lines_coords": [[[879.0, 414.0], [912.0, 414.0], [912.0, 603.0], [879.0, 603.0]], [[831.0, 414.0], [871.0, 414.0], [871.0, 512.0], [831.0, 512.0]], [[790.0, 414.0], [823.0, 414.0], [823.0, 635.0], [790.0, 635.0]]], "lines": ["参っちゃう", "ナァー", "奥さんには！！"]}, {"box": [126, 417, 273, 704], "vertical": true, "font_size": 32, "lines_coords": [[[242.0, 420.0], [273.0, 420.0], [273.0, 609.0], [242.0, 609.0]], [[204.0, 418.0], [237.0, 418.0], [237.0, 595.0], [204.0, 595.0]], [[165.0, 417.0], [196.0, 417.0], [196.0, 704.0], [165.0, 704.0]], [[126.0, 417.0], [159.0, 417.0], [160.0, 704.0], [128.0, 704.0]]], "lines": ["チラシ広告の", "ポスト投函、", "休み返上でやらされ", "るンですよォ～～！！"]}, {"box": [820, 771, 910, 964], "vertical": true, "font_size": 25, "lines_coords": [[[884.0, 771.0], [910.0, 771.0], [907.0, 939.0], [881.0, 939.0]], [[850.0, 773.0], [876.0, 773.0], [876.0, 964.0], [850.0, 964.0]], [[820.0, 775.0], [842.0, 775.0], [842.0, 948.0], [820.0, 948.0]]], "lines": ["．．．やればいい", "じゃない、麗しい", "あたしのために。"]}, {"box": [706, 1131, 729, 1182], "vertical": true, "font_size": 25, "lines_coords": [[[706.0, 1131.0], [729.0, 1131.0], [729.0, 1182.0], [706.0, 1182.0]]], "lines": ["．．．"]}, {"box": [673, 1084, 729, 1240], "vertical": true, "font_size": 25, "lines_coords": [[[706.0, 1087.0], [729.0, 1087.0], [729.0, 1134.0], [706.0, 1134.0]], [[673.0, 1084.0], [696.0, 1084.0], [698.0, 1240.0], [675.0, 1240.0]]], "lines": ["あー", "もしもし、部長"]}, {"box": [593, 1084, 668, 1409], "vertical": true, "font_size": 25, "lines_coords": [[[640.0, 1084.0], [668.0, 1084.0], [668.0, 1184.0], [640.0, 1184.0]], [[626.0, 1287.0], [653.0, 1287.0], [653.0, 1409.0], [626.0, 1409.0]], [[593.0, 1287.0], [620.0, 1287.0], [620.0, 1393.0], [593.0, 1393.0]]], "lines": ["ですか？", "南営業所の", "久米です。"]}, {"box": [270, 1093, 385, 1326], "vertical": true, "font_size": 25, "lines_coords": [[[359.0, 1095.0], [385.0, 1095.0], [385.0, 1196.0], [359.0, 1196.0]], [[328.0, 1095.0], [354.0, 1095.0], [354.0, 1268.0], [328.0, 1268.0]], [[296.0, 1093.0], [323.0, 1093.0], [326.0, 1326.0], [300.0, 1326.0]], [[270.0, 1093.0], [292.0, 1093.0], [295.0, 1260.0], [273.0, 1260.0]]], "lines": ["え～～～", "戸建て３ＬＤＫ、", "荷造リオプション付き", "なんですか．．．．．．"]}, {"box": [142, 1150, 245, 1285], "vertical": false, "font_size": 23.0, "lines_coords": [[[193.0, 1150.0], [245.0, 1251.0], [225.0, 1260.0], [173.0, 1159.0]], [[164.0, 1156.0], [223.0, 1275.0], [201.0, 1285.0], [142.0, 1167.0]]], "lines": ["本当のサイトについて", "自分の体についての"]}, {"box": [117, 1178, 217, 1343], "vertical": false, "font_size": 31, "lines_coords": [[[145.0, 1178.0], [217.0, 1329.0], [189.0, 1343.0], [117.0, 1192.0]]], "lines": ["マイナルを"]}, {"box": [40, 1357, 165, 1526], "vertical": true, "font_size": 26, "lines_coords": [[[139.0, 1359.0], [165.0, 1359.0], [165.0, 1464.0], [139.0, 1464.0]], [[106.0, 1357.0], [132.0, 1357.0], [132.0, 1526.0], [106.