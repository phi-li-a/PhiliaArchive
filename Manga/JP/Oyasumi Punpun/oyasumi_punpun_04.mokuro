の．．．"]}, {"box": [798, 1390, 865, 1525], "vertical": true, "font_size": 28, "lines_coords": [[[837.0, 1392.0], [865.0, 1392.0], [865.0, 1507.0], [837.0, 1507.0]], [[803.0, 1390.0], [831.0, 1390.0], [826.0, 1525.0], [798.0, 1525.0]]], "lines": ["．．．．．その、", "ゴメン．．．"]}, {"box": [152, 1351, 247, 1547], "vertical": true, "font_size": 24, "lines_coords": [[[217.0, 1351.0], [243.0, 1351.0], [246.0, 1546.0], [220.0, 1546.0]], [[184.0, 1354.0], [206.0, 1354.0], [206.0, 1535.0], [184.0, 1535.0]]], "lines": ["．．．なんでしょう、", "その用ってのは"]}], "img_path": "026.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [950, 135, 1018, 257], "vertical": true, "font_size": 34, "lines_coords": [[[976.0, 135.0], [1018.0, 135.0], [1018.0, 210.0], [976.0, 210.0]], [[950.0, 140.0], [976.0, 140.0], [976.0, 257.0], [950.0, 257.0]]], "lines": ["いや、", "なんかさ、"]}, {"box": [301, 84, 364, 250], "vertical": true, "font_size": 26, "lines_coords": [[[337.0, 84.0], [364.0, 84.0], [364.0, 190.0], [337.0, 190.0]], [[301.0, 84.0], [328.0, 84.0], [328.0, 250.0], [301.0, 250.0]]], "lines": ["でも今日", "こんな雨だし、"]}, {"box": [157, 228, 284, 412], "vertical": true, "font_size": 26, "lines_coords": [[[248.0, 229.0], [281.0, 228.0], [284.0, 310.0], [251.0, 312.0]], [[221.0, 229.0], [248.0, 229.0], [248.0, 389.0], [221.0, 389.0]], [[190.0, 231.0], [212.0, 231.0], [212.0, 412.0], [190.0, 412.0]], [[157.0, 232.0], [179.0, 232.0], [179.0, 367.0], [157.0, 367.0]]], "lines": ["両親も", "電車止まって", "足止めされてる", "らしいから、"]}, {"box": [546, 471, 650, 706], "vertical": true, "font_size": 27, "lines_coords": [[[623.0, 471.0], [650.0, 471.0], [650.0, 682.0], [623.0, 682.0]], [[585.0, 473.0], [612.0, 473.0], [612.0, 706.0], [585.0, 706.0]], [[550.0, 471.0], [578.0, 471.0], [575.0, 615.0], [546.0, 615.0]]], "lines": ["今日ウチの両親が", "横浜に遊びに行くっ", "ていうから、"]}, {"box": [952, 1034, 1010, 1179], "vertical": true, "font_size": 22, "lines_coords": [[[985.0, 1035.0], [1007.0, 1035.0], [1007.0, 1164.0], [985.0, 1164.0]], [[953.0, 1035.0], [975.0, 1035.0], [975.0, 1178.0], [953.0, 1178.0]]], "lines": ["あぁ．．．はは", "そうなんだ！！"]}, {"box": [442, 723, 570, 935], "vertical": true, "font_size": 27, "lines_coords": [[[542.0, 726.0], [568.0, 726.0], [570.0, 907.0], [543.0, 907.0]], [[510.0, 725.0], [537.0, 725.0], [537.0, 860.0], [510.0, 860.0]], [[475.0, 725.0], [501.0, 725.0], [501.0, 935.0], [475.0, 935.0]], [[442.0, 723.0], [470.0, 723.0], [470.0, 818.0], [442.0, 818.0]]], "lines": ["一緒に中華街で", "ゴハンでも", "どうかなーーって", "思って。"]}, {"box": [137, 785, 201, 943], "vertical": true, "font_size": 27, "lines_coords": [[[173.0, 785.0], [200.0, 785.0], [200.0, 918.0], [173.0, 918.0]], [[137.0, 785.0], [164.0, 785.0], [164.0, 943.0], [137.0, 943.0]]], "lines": ["．．．また今度", "改めてね．．．"]}, {"box": [809, 1281, 837, 1390], "vertical": true, "font_size": 25, "lines_coords": [[[809.0, 1281.0], [837.0, 1281.0], [837.0, 1390.0], [809.0, 1390.0]]], "lines": ["．．．じゃさ、"]}, {"box": [682, 1376, 795, 1553], "vertical": true, "font_size": 25, "lines_coords": [[[776.0, 1376.0], [795.0, 1376.0], [795.0, 1496.0], [776.0, 1496.0]], [[745.0, 1378.0], [767.0, 1378.0], [767.0, 1553.0], [745.0, 1553.0]], [[712.0, 1376.0], [739.0, 1376.0], [739.0, 1521.0], [712.0, 1521.0]], [[682.0, 1376.0], [709.0, 1376.0], [709.0, 1473.0], [682.0, 1473.0]]], "lines": ["とりあえず", "お風呂入りなよ。", "風邪引いたら", "大変だ！！"]}, {"box": [552, 1302, 644, 1448], "vertical": true, "font_size": 24, "lines_coords": [[[618.0, 1304.0], [640.0, 1304.0], [640.0, 1445.0], [618.0, 1445.0]], [[582.0, 1303.0], [610.0, 1303.0], [610.0, 1400.0], [582.0, 1400.0]], [[553.0, 1304.0], [575.0, 1304.0], [575.0, 1423.0], [553.0, 1423.0]]], "lines": ["そうなんだ」", "って．．．", "軽くない？"]}, {"box": [137, 1360, 228, 1538], "vertical": true, "font_size": 22, "lines_coords": [[[203.0, 1362.0], [225.0, 1362.0], [225.0, 1535.0], [203.0, 1535.0]], [[168.0, 1360.0], [192.0, 1360.0], [190.0, 1528.0], [167.0, 1528.0]], [[137.0, 1365.0], [159.0, 1365.0], [159.0, 1506.0], [137.0, 1506.0]]], "lines": ["．．．雄ちゃんコレ、", "どういうことか", "わかってる？"]}], "img_path": "027.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [543, 111, 571, 270], "vertical": true, "font_size": 27, "lines_coords": [[[543.0, 112.0], [570.0, 112.0], [570.0, 270.0], [543.0, 270.0]]], "lines": ["あ．．．．．あの．．．"]}, {"box": [242, 150, 306, 315], "vertical": true, "font_size": 27, "lines_coords": [[[276.0, 150.0], [303.0, 150.0], [306.0, 282.0], [279.0, 282.0]], [[242.0, 153.0], [268.0, 153.0], [268.0, 315.0], [242.0, 315.0]]], "lines": ["今ちょっと", "アレというか、"]}, {"box": [84, 275, 218, 434], "vertical": true, "font_size": 27, "lines_coords": [[[192.0, 275.0], [218.0, 275.0], [218.0, 406.0], [192.0, 406.0]], [[154.0, 275.0], [182.0, 275.0], [182.0, 384.0], [154.0, 384.0]], [[118.0, 275.0], [146.0, 275.0], [143.0, 407.0], [115.0, 407.0]], [[84.0, 275.0], [110.0, 275.0], [110.0, 434.0], [84.0, 434.0]]], "lines": ["なんか外で", "ご飯でも", "食べながら", "話しようか！？"]}, {"box": [881, 820, 947, 1007], "vertical": true, "font_size": 27, "lines_coords": [[[917.0, 820.0], [945.0, 820.0], [946.0, 964.0], [918.0, 964.0]], [[882.0, 821.0], [909.0, 821.0], [907.0, 1007.0], [881.0, 1007.0]]], "lines": ["．．．雄ちゃん、", "なんか変だよ？"]}, {"box": [293, 801, 323, 934], "vertical": true, "font_size": 27, "lines_coords": [[[296.0, 801.0], [323.0, 801.0], [320.0, 934.0], [293.0, 934.0]]], "lines": ["そんなに．．．"]}, {"box": [156, 896, 220, 1056], "vertical": true, "font_size": 27, "lines_coords": [[[189.0, 896.0], [217.0, 896.0], [220.0, 1006.0], [192.0, 1006.0]], [[156.0, 898.0], [182.0, 898.0], [182.0, 1056.0], [156.0, 1056.0]]], "lines": ["結婚の話", "するの、嫌？"]}, {"box": [859, 1181, 925, 1312], "vertical": true, "font_size": 28, "lines_coords": [[[898.0, 1182.0], [925.0, 1182.0], [925.0, 1312.0], [898.0, 1312.0]], [[859.0, 1181.0], [893.0, 1181.0], [893.0, 1271.0], [859.0, 1271.0]]], "lines": ["．．．これでも", "あたし、"]}, {"box": [731, 1334, 856, 1492], "vertical": true, "font_size": 28, "lines_coords": [[[829.0, 1335.0], [856.0, 1335.0], [856.0, 1443.0], [829.0, 1443.0]], [[798.0, 1334.0], [825.0, 1334.0], [825.0, 1492.0], [798.0, 1492.0]], [[762.0, 1334.0], [790.0, 1334.0], [792.0, 1467.0], [764.0, 1467.0]], [[731.0, 1334.0], [757.0, 1334.0], [757.0, 1451.0], [731.0, 1451.0]]], "lines": ["けっこう", "ギリギリまで", "我慢したと", "思うんだ。"]}, {"box": [121, 1341, 150, 1502], "vertical": true, "font_size": 29, "lines_coords": [[[121.0, 1342.0], [150.0, 1342.0], [150.0, 1418.0], [121.0, 1418.0]]], "lines": ["僕はー"]}], "img_path": "028.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [937, 117, 1026, 281], "vertical": true, "font_size": 24, "lines_coords": [[[1004.0, 118.0], [1026.0, 118.0], [1026.0, 242.0], [1004.0, 242.0]], [[970.0, 117.0], [992.0, 117.0], [992.0, 281.0], [970.0, 281.0]], [[937.0, 117.0], [959.0, 117.0], [959.0, 235.0], [937.0, 235.0]]], "lines": ["．．．あたし達", "付き合ってもう", "五年だよ？"]}, {"box": [845, 276, 939, 465], "vertical": true, "font_size": 24, "lines_coords": [[[912.0, 276.0], [939.0, 276.0], [939.0, 398.0], [912.0, 398.0]], [[879.0, 278.0], [901.0, 278.0], [901.0, 465.0], [879.0, 465.0]], [[845.0, 276.0], [873.0, 276.0], [873.0, 353.0], [845.0, 353.0]]], "lines": ["もう少しで", "３０になっちゃうん", "だよ？"]}, {"box": [196, 128, 320, 317], "vertical": true, "font_size": 23, "lines_coords": [[[298.0, 129.0], [320.0, 129.0], [320.0, 317.0], [298.0, 317.0]], [[262.0, 128.0], [289.0, 128.0], [289.0, 275.0], [262.0, 275.0]], [[228.0, 128.0], [254.0, 128.0], [254.0, 275.0], [228.0, 275.0]], [[196.0, 128.0], [218.0, 128.0], [218.0, 279.0], [196.0, 279.0]]], "lines": ["ユッコもカンナも", "アキちゃんも", "大学の友達が", "次々結婚して、"]}, {"box": [732, 613, 764, 789], "vertical": true, "font_size": 32, "lines_coords": [[[732.0, 614.0], [764.0, 614.0], [764.0, 789.0], [732.0, 789.0]]], "lines": ["．．．この時僕は、"]}, {"box": [454, 614, 636, 834], "vertical": true, "font_size": 32, "lines_coords": [[[604.0, 615.0], [635.0, 615.0], [635.0, 776.0], [604.0, 776.0]], [[564.0, 615.0], [595.0, 615.0], [600.0, 806.0], [568.0, 806.0]], [[528.0, 615.0], [560.0, 615.0], [564.0, 831.0], [531.0, 831.0]], [[490.0, 614.0], [523.0, 614.0], [526.0, 831.0], [493.0, 831.0]], [[454.0, 614.0], [487.0, 614.0], [490.0, 762.0], [457.0, 762.0]]], "lines": ["今まで必死に", "取り繕っていた", "何かがゆっくりと", "崩壊してゆくのを", "感じていた。"]}, {"box": [167, 360, 256, 553], "vertical": true, "font_size": 23, "lines_coords": [[[231.0, 360.0], [253.0, 360.0], [256.0, 529.0], [234.0, 529.0]], [[198.0, 362.0], [220.0, 362.0], [220.0, 531.0], [198.0, 531.0]], [[167.0, 362.0], [189.0, 362.0], [189.0, 553.0], [167.0, 553.0]]], "lines": ["取り残されてく", "あたしの気持ち", "考えたことある？"]}, {"box": [925, 943, 987, 1068], "vertical": true, "font_size": 24, "lines_coords": [[[957.0, 943.0], [985.0, 943.0], [987.0, 1051.0], [959.0, 1051.0]], [[928.0, 943.0], [954.0, 943.0], [951.0, 1068.0], [925.0, 1068.0]]], "lines": ["．．．おえ、", "憶えてる？"]}, {"box": [778, 1018, 900, 1234], "vertical": true, "font_size": 24, "lines_coords": [[[878.0, 1018.0], [900.0, 1018.0], [900.0, 1140.0], [878.0, 1140.0]], [[845.0, 1021.0], [867.0, 1021.0], [867.0, 1234.0], [845.0, 1234.0]], [[812.0, 1021.0], [834.0, 1021.0], [834.0, 1185.0], [812.0, 1185.0]], [[778.0, 1021.0], [800.0, 1021.0], [800.0, 1170.0], [778.0, 1170.0]]], "lines": ["雄ちゃんが", "働きだしてすぐの頃", "那須の遊園地の", "観覧車の中で、"]}, {"box": [170, 1010, 275, 1262], "vertical": true, "font_size": 28, "lines_coords": [[[245.0, 1010.0], [271.0, 1010.0], [271.0, 1262.0], [245.0, 1262.0]], [[206.0, 1010.0], [237.0, 1010.0], [237.0, 1212.0], [206.0, 1212.0]], [[173.0, 1010.0], [200.0, 1010.0], [196.0, 1170.0], [170.0, 1170.0]]], "lines": ["「仕事が落ちついたら", "結婚しよう」って", "言ったこと！！"]}, {"box": [629, 1315, 803, 1504], "vertical": true, "font_size": 33, "lines_coords": [[[773.0, 1318.0], [801.0, 1318.0], [801.0, 1425.0], [773.0, 1425.0]], [[737.0, 1318.0], [765.0, 1318.0], [765.0, 1453.0], [737.0, 1453.0]], [[698.0, 1317.0], [731.0, 1317.0], [731.0, 1503.0], [698.0, 1503.0]], [[654.0, 1315.0], [700.0, 1315.0], [700.0, 1409.0], [654.0, 1409.0]], [[629.0, 1320.0], [657.0, 1320.0], [657.0, 1460.0], [629.0, 1460.0]]], "lines": ["目の前の", "彼女が吐く", "下らない言葉は", "耳から", "こぼれ落ち、"]}, {"box": [328, 1315, 511, 1540], "vertical": true, "font_size": 29, "lines_coords": [[[475.0, 1317.0], [501.0, 1317.0], [501.0, 1475.0], [475.0, 1475.0]], [[435.0, 1317.0], [467.0, 1317.0], [467.0, 1478.0], [435.0, 1478.0]], [[400.0, 1318.0], [431.0, 1318.0], [431.0, 1529.0], [400.0, 1529.0]], [[364.0, 1317.0], [390.0, 1317.0], [393.0, 1504.0], [367.0, 1504.0]], [[328.0, 1315.0], [356.0, 1315.0], [357.0, 1540.0], [329.0, 1540.0]]], "lines": ["襖の向こうの", "少女の視線を", "全身で浴びている", "事実に興奮さえ", "憶えはじめていた。"]}], "img_path": "029.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [932, 76, 960, 182], "vertical": true, "font_size": 26, "lines_coords": [[[932.0, 76.0], [960.0, 76.0], [960.0, 182.0], [932.0, 182.0]]], "lines": ["あたし．．"]}, {"box": [826, 204, 923, 390], "vertical": true, "font_size": 26, "lines_coords": [[[896.0, 204.0], [923.0, 204.0], [923.0, 390.0], [896.0, 390.0]], [[859.0, 206.0], [885.0, 206.0], [885.0, 365.0], [859.0, 365.0]], [[826.0, 207.0], [848.0, 207.0], [848.0, 337.0], [826.0, 337.0]]], "lines": ["雄ちゃんのその", "曖昧な言葉を", "信じて．．．．．．"]}, {"box": [239, 79, 265, 262], "vertical": true, "font_size": 27, "lines_coords": [[[239.0, 79.0], [265.0, 79.0], [265.0, 262.0], [239.0, 262.0]]], "lines": ["ずっとずつと．．．"]}, {"box": [680, 589, 896, 780], "vertical": true, "font_size": 30, "lines_coords": [[[857.0, 589.0], [896.0, 589.0], [896.0, 703.0], [857.0, 703.0]], [[826.0, 592.0], [854.0, 592.0], [854.0, 725.0], [826.0, 725.0]], [[789.0, 590.0], [820.0, 590.0], [820.0, 751.0], [789.0, 751.0]], [[753.0, 590.0], [784.0, 590.0], [784.0, 778.0], [753.0, 778.0]], [[718.0, 592.0], [745.0, 592.0], [745.0, 723.0], [718.0, 723.0]], [[681.0, 593.0], [707.0, 593.0], [707.0, 703.0], [681.0, 703.0]]], "lines": ["少しずつ", "僕の意識は", "１６歳の少女の", "太腿から覗いた", "白い下着に", "支配され、"]}, {"box": [479, 590, 625, 775], "vertical": true, "font_size": 29, "lines_coords": [[[592.0, 592.0], [620.0, 592.0], [617.0, 771.0], [589.0, 771.0]], [[554.0, 593.0], [582.0, 593.0], [582.0, 723.0], [554.0, 723.0]], [[518.0, 592.0], [545.0, 592.0], [545.0, 723.0], [518.0, 723.0]], [[479.0, 590.0], [512.0, 590.0], [512.0, 682.0], [479.0, 682.0]]], "lines": ["腐ったトマトの", "ように歪む", "彼女の顔を", "尻目に、"]}, {"box": [162, 296, 228, 507], "vertical": true, "font_size": 27, "lines_coords": [[[200.0, 300.0], [228.0, 300.0], [228.0, 407.0], [200.0, 407.0]], [[162.0, 296.0], [189.0, 296.0], [190.0, 507.0], [164.0, 507.0]]], "lines": ["我慢して", "きたんだから．．．！！"]}, {"box": [204, 587, 423, 804], "vertical": true, "font_size": 31, "lines_coords": [[[393.0, 592.0], [420.0, 592.0], [420.0, 695.0], [393.0, 695.0]], [[357.0, 592.0], [384.0, 592.0], [384.0, 721.0], [357.0, 721.0]], [[320.0, 592.0], [346.0, 592.0], [346.0, 775.0], [320.0, 775.0]], [[279.0, 590.0], [310.0, 590.0], [314.0, 726.0], [282.0, 726.0]], [[243.0, 589.0], [276.0, 589.0], [276.0, 803.0], [243.0, 803.0]], [[204.0, 587.0], [243.0, 587.0], [243.0, 687.0], [204.0, 687.0]]], "lines": ["まだ見ぬ", "白い乳房や", "まばらな陰毛を", "想像しては", "しつこく脳の中で", "弄んだ。"]}, {"box": [907, 846, 934, 1031], "vertical": true, "font_size": 24, "lines_coords": [[[907.0, 846.0], [934.0, 846.0], [934.0, 1031.0], [907.0, 1031.0]]], "lines": ["でっ．．．でもっ！！"]}, {"box": [779, 1014, 893, 1209], "vertical": true, "font_size": 24, "lines_coords": [[[871.0, 1014.0], [893.0, 1014.0], [893.0, 1137.0], [871.0, 1137.0]], [[840.0, 1017.0], [862.0, 1017.0], [862.0, 1209.0], [840.0, 1209.0]], [[810.0, 1018.0], [832.0, 1018.0], [832.0, 1185.0], [810.0, 1185.0]], [[779.0, 1017.0], [806.0, 1017.0], [806.0, 1117.0], [779.0, 1117.0]]], "lines": ["．．．あたしは", "雄ちゃんの気持ち", "一番わかってる", "から．．．"]}, {"box": [225, 895, 287, 1078], "vertical": true, "font_size": 28, "lines_coords": [[[259.0, 895.0], [287.0, 895.0], [284.0, 1078.0], [256.0, 1078.0]], [[225.0, 896.0], [246.0, 896.0], [246.0, 1050.0], [225.0, 1050.0]]], "lines": ["無理強いなんて", "しないよ．．．"]}, {"box": [153, 1117, 218, 1231], "vertical": true, "font_size": 28, "lines_coords": [[[185.0, 1117.0], [218.0, 1117.0], [218.0, 1207.0], [185.0, 1207.0]], [[153.0, 1125.0], [181.0, 1125.0], [181.0, 1231.0], [153.0, 1231.0]]], "lines": ["しない", "けど．．．"]}, {"box": [668, 1281, 734, 1474], "vertical": true, "font_size": 30, "lines_coords": [[[701.0, 1281.0], [734.0, 1281.0], [734.0, 1371.0], [701.0, 1371.0]], [[668.0, 1281.0], [695.0, 1281.0], [695.0, 1470.0], [668.0, 1470.0]]], "lines": ["．．．ああ、", "こんなことなら、"]}, {"box": [365, 1281, 576, 1490], "vertical": true, "font_size": 27, "lines_coords": [[[546.0, 1282.0], [573.0, 1282.0], [573.0, 1389.0], [546.0, 1389.0]], [[510.0, 1281.0], [539.0, 1281.0], [535.0, 1414.0], [507.0, 1414.0]], [[473.0, 1281.0], [500.0, 1281.0], [500.0, 1440.0], [473.0, 1440.0]], [[435.0, 1282.0], [462.0, 1282.0], [462.0, 1439.0], [435.0, 1439.0]], [[400.0, 1282.0], [428.0, 1282.0], [428.0, 1389.0], [400.0, 1389.0]], [[365.0, 1282.0], [392.0, 1282.0], [392.0, 1490.0], [365.0, 1490.0]]], "lines": ["さっさと", "僕の肉棒を", "少女の秘密に", "ねじり込んで", "しまえば", "よかった．．．ッ！！"]}], "img_path": "030.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [892, 114, 973, 275], "vertical": true, "font_size": 39, "lines_coords": [[[928.0, 114.0], [973.0, 114.0], [973.0, 217.0], [928.0, 217.0]], [[892.0, 117.0], [925.0, 117.0], [925.0, 275.0], [892.0, 275.0]]], "lines": ["せめて", "お願い．．．"]}, {"box": [154, 489, 234, 679], "vertical": true, "font_size": 33, "lines_coords": [[[198.0, 490.0], [231.0, 490.0], [234.0, 679.0], [201.0, 679.0]], [[154.0, 489.0], [187.0, 489.0], [190.0, 650.0], [157.0, 650.0]]], "lines": ["愛してるって", "言って．．．．．"]}, {"box": [868, 1025, 1003, 1296], "vertical": true, "font_size": 135, "lines_coords": [[[868.0, 1025.0], [1003.0, 1025.0], [1003.0, 1296.0], [868.0, 1296.0]]], "lines": ["ああ。"]}, {"box": [487, 775, 706, 928], "vertical": false, "font_size": 61.0, "lines_coords": [[[507.0, 775.0], [610.0, 801.0], [590.0, 878.0], [487.0, 851.0]], [[584.0, 801.