3.0]], [[184.0, 1289.0], [965.0, 1325.0], [957.0, 1498.0], [176.0, 1462.0]], [[718.0, 1337.0], [885.0, 1325.0], [890.0, 1379.0], [723.0, 1392.0]]], "lines": ["、数量は", "ルバドミントン競技大会", "；普扶－"]}], "img_path": "103.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [873, 78, 975, 264], "vertical": true, "font_size": 29, "lines_coords": [[[940.0, 78.0], [975.0, 78.0], [975.0, 185.0], [940.0, 185.0]], [[906.0, 79.0], [937.0, 79.0], [937.0, 264.0], [906.0, 264.0]], [[875.0, 81.0], [896.0, 81.0], [896.0, 209.0], [875.0, 209.0]]], "lines": ["午前中の", "小松っちゃんの", "試合見た？"]}, {"box": [514, 57, 578, 262], "vertical": true, "font_size": 24, "lines_coords": [[[548.0, 57.0], [576.0, 57.0], [578.0, 242.0], [550.0, 242.0]], [[517.0, 59.0], [539.0, 59.0], [535.0, 262.0], [514.0, 262.0]]], "lines": ["２セット目から", "相手泣いてたもん。"]}, {"box": [401, 192, 460, 334], "vertical": true, "font_size": 24, "lines_coords": [[[434.0, 192.0], [460.0, 192.0], [460.0, 326.0], [434.0, 326.0]], [[401.0, 195.0], [423.0, 195.0], [423.0, 334.0], [401.0, 334.0]]], "lines": ["あんな試合", "初めて見た。"]}, {"box": [676, 509, 747, 650], "vertical": true, "font_size": 30, "lines_coords": [[[718.0, 510.0], [746.0, 510.0], [746.0, 650.0], [718.0, 650.0]], [[679.0, 509.0], [712.0, 509.0], [709.0, 628.0], [676.0, 628.0]]], "lines": ["超ヤバイよ、", "マジ無敵。"]}, {"box": [251, 593, 275, 645], "vertical": true, "font_size": 26, "lines_coords": [[[251.0, 593.0], [275.0, 593.0], [275.0, 645.0], [251.0, 645.0]]], "lines": ["．．．"]}, {"box": [176, 487, 276, 670], "vertical": true, "font_size": 26, "lines_coords": [[[250.0, 487.0], [276.0, 487.0], [276.0, 593.0], [250.0, 593.0]], [[214.0, 487.0], [240.0, 487.0], [240.0, 670.0], [214.0, 670.0]], [[176.0, 489.0], [203.0, 489.0], [203.0, 646.0], [176.0, 646.0]]], "lines": ["あとはー", "ウチのガッコで", "残ってんのは"]}, {"box": [140, 489, 167, 631], "vertical": true, "font_size": 26, "lines_coords": [[[140.0, 489.0], [167.0, 489.0], [167.0, 631.0], [140.0, 631.0]]], "lines": ["矢口先輩か。"]}, {"box": [896, 800, 959, 959], "vertical": true, "font_size": 24, "lines_coords": [[[932.0, 801.0], [959.0, 801.0], [959.0, 931.0], [932.0, 931.0]], [[896.0, 800.0], [923.0, 800.0], [923.0, 959.0], [896.0, 959.0]]], "lines": ["矢口先輩の", "次の相手は．．．"]}, {"box": [770, 968, 893, 1162], "vertical": true, "font_size": 24, "lines_coords": [[[867.0, 968.0], [893.0, 968.0], [893.0, 1151.0], [867.0, 1151.0]], [[835.0, 970.0], [857.0, 970.0], [857.0, 1162.0], [835.0, 1162.0]], [[801.0, 968.0], [823.0, 968.0], [823.0, 1112.0], [801.0, 1112.0]], [[770.0, 970.0], [792.0, 970.0], [792.0, 1123.0], [770.0, 1123.0]]], "lines": ["あぁーー西中の", "武者小路っていう", "転校してきた", "ばっかの奴ね。"]}, {"box": [221, 821, 345, 1010], "vertical": true, "font_size": 26, "lines_coords": [[[323.0, 825.0], [345.0, 825.0], [345.0, 964.0], [323.0, 964.0]], [[287.0, 821.0], [314.0, 821.0], [314.0, 989.0], [287.0, 989.0]], [[256.0, 825.0], [278.0, 825.0], [278.0, 1010.0], [256.0, 1010.0]], [[221.0, 821.0], [248.0, 821.0], [248.0, 929.0], [221.0, 929.0]]], "lines": ["前の学校ん時", "茨城の県選抜に", "一年で選ばれたん", "だってよ。"]}, {"box": [103, 1000, 239, 1196], "vertical": true, "font_size": 26, "lines_coords": [[[207.0, 1000.0], [239.0, 1000.0], [239.0, 1164.0], [207.0, 1164.0]], [[171.0, 1003.0], [198.0, 1003.0], [198.0, 1187.0], [171.0, 1187.0]], [[135.0, 1001.0], [162.0, 1001.0], [162.0, 1162.0], [135.0, 1162.0]], [[103.0, 1004.0], [125.0, 1004.0], [125.0, 1196.0], [103.0, 1196.0]]], "lines": ["あはは、でも", "奇跡で勝っても", "決勝の相手は", "小松っちゃんか。"]}, {"box": [293, 1298, 320, 1412], "vertical": true, "font_size": 32, "lines_coords": [[[293.0, 1298.0], [320.0, 1298.0], [320.0, 1412.0], [293.0, 1412.0]]], "lines": ["かわいそ。"]}, {"box": [140, 1334, 212, 1484], "vertical": true, "font_size": 32, "lines_coords": [[[184.0, 1340.0], [212.0, 1340.0], [212.0, 1484.0], [184.0, 1484.0]], [[140.0, 1335.0], [181.0, 1334.0], [184.0, 1412.0], [143.0, 1414.0]]], "lines": ["終わったなー", "先輩。"]}], "img_path": "104.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [185, 4, 941, 776], "vertical": true, "font_size": 367, "lines_coords": [[[206.0, 71.0], [571.0, 34.0], [623.0, 531.0], [257.0, 568.0]]], "lines": ["つい、"]}, {"box": [415, 792, 557, 1003], "vertical": true, "font_size": 30, "lines_coords": [[[520.0, 795.0], [553.0, 793.0], [557.0, 909.0], [525.0, 910.0]], [[489.0, 795.0], [515.0, 795.0], [515.0, 1003.0], [489.0, 1003.0]], [[453.0, 795.0], [479.0, 795.0], [479.0, 979.0], [453.0, 979.0]], [[415.0, 792.0], [450.0, 792.0], [450.0, 835.0], [415.0, 835.0]]], "lines": ["なんでェ、", "心配して損したセ", "チキショーめ！！", "と、"]}, {"box": [387, 1115, 459, 1240], "vertical": true, "font_size": 35, "lines_coords": [[[417.0, 1115.0], [459.0, 1115.0], [459.0, 1184.0], [417.0, 1184.0]], [[387.0, 1120.0], [415.0, 1120.0], [417.0, 1240.0], [389.0, 1240.0]]], "lines": ["早く", "行こーぜ。"]}, {"box": [214, 795, 318, 1032], "vertical": true, "font_size": 29, "lines_coords": [[[285.0, 795.0], [317.0, 795.0], [317.0, 1032.0], [285.0, 1032.0]], [[250.0, 796.0], [278.0, 796.0], [279.0, 1004.0], [251.0, 1004.0]], [[214.0, 795.0], [240.0, 795.0], [240.0, 960.0], [214.0, 960.0]]], "lines": ["もうフンフンの心は", "余裕じゃくしゃく", "大魔王でした。"]}, {"box": [137, 1154, 332, 1223], "vertical": false, "font_size": 26.0, "lines_coords": [[[137.0, 1154.0], [332.0, 1154.0], [332.0, 1181.0], [137.0, 1181.0]], [[159.0, 1198.0], [203.0, 1198.0], [203.0, 1223.0], [159.0, 1223.0]]], "lines": ["男子シングルスＢ組", "笹岡"]}, {"box": [157, 1251, 203, 1314], "vertical": false, "font_size": 63, "lines_coords": [[[157.0, 1251.0], [203.0, 1251.0], [203.0, 1314.0], [157.0, 1314.0]]], "lines": ["矢口大村"]}, {"box": [156, 1437, 207, 1471], "vertical": false, "font_size": 34, "lines_coords": [[[156.0, 1437.0], [207.0, 1437.0], [207.0, 1471.0], [156.0, 1471.0]]], "lines": ["酒井"]}], "img_path": "105.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [917, 134, 959, 182], "vertical": true, "font_size": 38, "lines_coords": [[[917.0, 134.0], [959.0, 134.0], [959.0, 182.0], [917.0, 182.0]]], "lines": ["あー"]}, {"box": [871, 357, 906, 428], "vertical": true, "font_size": 38, "lines_coords": [[[871.0, 357.0], [906.0, 357.0], [906.0, 428.0], [871.0, 428.0]]], "lines": ["結果、"]}, {"box": [129, 250, 270, 485], "vertical": true, "font_size": 28, "lines_coords": [[[242.0, 253.0], [268.0, 253.0], [268.0, 485.0], [242.0, 485.0]], [[203.0, 250.0], [234.0, 250.0], [234.0, 409.0], [203.0, 409.0]], [[168.0, 250.0], [195.0, 250.0], [195.0, 485.0], [168.0, 485.0]], [[132.0, 250.0], [159.0, 250.0], [156.0, 414.0], [129.0, 414.0]]], "lines": ["シングルスの決勝は", "矢口と小松の", "共に我が校の選手と", "なった訳だが、"]}, {"box": [881, 604, 970, 814], "vertical": true, "font_size": 25, "lines_coords": [[[943.0, 604.0], [970.0, 604.0], [970.0, 764.0], [943.0, 764.0]], [[914.0, 606.0], [935.0, 606.0], [935.0, 814.0], [914.0, 814.0]], [[881.0, 604.0], [907.0, 604.0], [907.0, 798.0], [881.0, 798.0]]], "lines": ["他校の負けた", "選手違への敬意を", "忘れないように。"]}, {"box": [746, 709, 867, 870], "vertical": true, "font_size": 25, "lines_coords": [[[834.0, 709.0], [867.0, 709.0], [867.0, 795.0], [834.0, 795.0]], [[804.0, 710.0], [831.0, 710.0], [831.0, 870.0], [804.0, 870.0]], [[775.0, 712.0], [798.0, 712.0], [796.0, 868.0], [773.0, 868.0]], [[746.0, 714.0], [764.0, 714.0], [764.0, 821.0], [746.0, 821.0]]], "lines": ["決して", "はしゃいだり", "軽率な行動を", "とるなよ"]}, {"box": [135, 676, 274, 890], "vertical": true, "font_size": 28, "lines_coords": [[[245.0, 681.0], [271.0, 681.0], [271.0, 835.0], [245.0, 835.0]], [[206.0, 678.0], [237.0, 678.0], [237.0, 890.0], [206.0, 890.0]], [[171.0, 676.0], [198.0, 676.0], [198.0, 876.0], [171.0, 876.0]], [[135.0, 676.0], [162.0, 676.0], [162.0, 862.0], [135.0, 862.0]]], "lines": ["一年で線審に", "つかなかった者は", "各自、気を抜かず", "応援すること！！"]}, {"box": [673, 1001, 740, 1118], "vertical": true, "font_size": 30, "lines_coords": [[[712.0, 1001.0], [739.0, 1001.0], [739.0, 1114.0], [712.0, 1114.0]], [[673.0, 1003.0], [706.0, 1003.0], [706.0, 1085.0], [673.0, 1085.0]]], "lines": ["では各自", "解散！！"]}], "img_path": "106.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [973, 76, 1003, 153], "vertical": true, "font_size": 28, "lines_coords": [[[973.0, 76.0], [1003.0, 76.0], [1003.0, 153.0], [973.0, 153.0]]], "lines": ["．．．ん？"]}, {"box": [865, 118, 928, 282], "vertical": true, "font_size": 28, "lines_coords": [[[901.0, 118.0], [928.0, 118.0], [928.0, 282.0], [901.0, 282.0]], [[865.0, 118.0], [892.0, 118.0], [892.0, 276.0], [865.0, 276.0]]], "lines": ["どうした矢口、", "ひねったか？"]}, {"box": [315, 268, 449, 436], "vertical": true, "font_size": 25, "lines_coords": [[[423.0, 268.0], [445.0, 268.0], [445.0, 432.0], [423.0, 432.0]], [[385.0, 270.0], [412.0, 270.0], [412.0, 432.0], [385.0, 432.0]], [[348.0, 268.0], [376.0, 268.0], [376.0, 400.0], [348.0, 400.0]], [[315.0, 268.0], [337.0, 268.0], [337.0, 409.0], [315.0, 409.0]]], "lines": ["．．．まぁ、あまり", "無理はするな、", "相手は小松", "なんだしな。"]}, {"box": [640, 542, 740, 683], "vertical": true, "font_size": 31, "lines_coords": [[[707.0, 542.0], [740.0, 542.0], [740.0, 589.0], [707.0, 589.0]], [[673.0, 543.0], [706.0, 543.0], [706.0, 681.0], [673.0, 681.0]], [[640.0, 543.0], [668.0, 543.0], [668.0, 659.0], [640.0, 659.0]]], "lines": ["あー", "いや、全然、", "大丈夫す。"]}, {"box": [102, 348, 201, 532], "vertical": true, "font_size": 25, "lines_coords": [[[173.0, 348.0], [200.0, 348.0], [200.0, 479.0], [173.0, 479.0]], [[135.0, 348.0], [162.0, 348.0], [162.0, 532.0], [135.0, 532.0]], [[103.0, 350.0], [125.0, 350.0], [125.0, 531.0], [103.0, 531.0]]], "lines": ["準優勝でも", "県大会に行ける", "訳てあって．．．"]}], "img_path": "107.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [904, 46, 960, 257], "vertical": true, "font_size": 24, "lines_coords": [[[934.0, 46.0], [960.0, 46.0], [960.0, 242.0], [934.0, 242.0]], [[906.0, 48.0], [928.0, 48.0], [928.0, 257.0], [906.0, 257.0]]], "lines": ["．．．小松っちゃーん、", "マジで頑張ってよ！！"]}, {"box": [431, 73, 605, 284], "vertical": true, "font_size": 27, "lines_coords": [[[575.0, 76.0], [601.0, 76.0], [601.0, 257.0], [575.0, 257.0]], [[542.0, 79.0], [564.0, 79.0], [564.0, 256.0], [542.0, 256.0]], [[501.0, 75.0], [532.0, 75.0], [532.0, 284.0], [501.0, 284.0]], [[465.0, 78.0], [493.0, 78.0], [493.0, 229.0], [465.0, 229.0]], [[431.0, 76.0], [459.0, 76.0], [459.0, 190.0], [431.0, 190.0]]], "lines": ["フンフンはもう", "試合は見ないで", "帰ってチョコバイ", "食べて寝たい", "所存です。"]}, {"box": [246, 43, 275, 184], "vertical": true, "font_size": 27, "lines_coords": [[[246.0, 43.0], [275.0, 43.0], [275.0, 184.0], [246.0, 184.0]]], "lines": ["五月蝿いよ。"]}, {"box": [93, 53, 193, 264], "vertical": true, "font_size": 27, "lines_coords": [[[167.0, 54.0], [193.0, 54.0], [193.0, 187.0], [167.0, 187.0]], [[129.0, 53.0], [156.0, 53.0], [156.0, 264.0], [129.0, 264.0]], [[93.0, 56.0], [120.0, 56.0], [123.0, 209.0], [96.0, 209.0]]], "lines": ["．．．試合前に", "不快なことを言う", "奴だな、君は。"]}, {"box": [689, 315, 784, 596], "vertical": true, "font_size": 25, "lines_coords": [[[757.0, 318.0], [784.0, 318.0], [784.0, 496.0], [757.0, 496.0]], [[723.0, 318.0], [750.0, 318.0], [750.0, 470.0], [723.0, 470.0]], [[689.0, 315.0], [717.0, 315.0], [721.0, 596.0], [693.0, 596.0]]], "lines": ["俺、矢口先輩って", "調子乗ってて、", "嫌いなんだよ。さくっと"]}, {"box": [631, 500, 685, 665], "vertical": true, "font_size": 25, "lines_coords": [[[664.0, 500.0], [685.0, 500.0], [685.0, 665.0], [664.0, 665.0]], [[631.0, 500.0], [653.0, 500.0], [653.0, 595.0], [631.0, 595.0]]], "lines": ["圧勝しちゃおう", "ぜーー？"]}, {"box": [58, 464, 183, 667], "vertical": true, "font_size": 24, "lines_coords": [[[157.0, 468.0], [179.0, 468.0], [179.0, 660.0], [157.0, 660.0]], [[120.0, 464.0], [146.0, 464.0], [146.0, 667.0], [120.0, 667.0]], [[89.0, 468.0], [115.0, 468.0], [115.0, 610.0], [89.0, 610.0]], [[59.0, 468.0], [81.0, 468.0], [81.0, 665.0], [59.0, 665.0]]], "lines": ["僕が求める勝利は", "そんなくだらない", "感情を排した", "高尚なものなんだ。"]}, {"box": [893, 1075, 956, 1209], "vertical": true, "font_size": 26, "lines_coords": [[[926.0, 1076.0], [954.0, 1076.0], [956.0, 1187.0], [928.0, 1187.0]], [[893.0, 1075.0], [920.0, 1075.0], [920.0, 1209.0], [893.0, 1209.0]]], "lines": ["あぁ～～", "～～あぁ！！"]}, {"box": [271, 754, 339, 926], "vertical": true, "font_size": 31, "lines_coords": [[[301.0, 756.0], [334.0, 754.0], [339.0, 875.0], [306.0, 876.0]], [[271.0, 757.0], [298.0, 757.0], [298.0, 926.0], [271.0, 926.0]]], "lines": ["．．．はっ、", "なんだよソレ。"]}, {"box": [189, 837, 221, 934], "vertical": true, "font_size": 31, "lines_coords": [[[189.0, 837.0], [221.0, 837.0], [221.0, 934.0], [189.0, 934.0]]], "lines": ["あっそ。"]}, {"box": [779, 1195, 875, 1392], "vertical": true, "font_size": 26, "lines_coords": [[[848.0, 1195.0], [875.0, 1195.0], [875.0, 1351.0], [848.0, 1351.0]], [[812.0, 1195.0], [839.0, 1195.0], [839.0, 1379.0], [812.0, 1379.0]], [[779.0, 1196.0], [801.0, 1196.0], [801.0, 1392.0], [779.0, 1392.0]]], "lines": ["別にどっちが", "勝っても俺には", "関係ねーけどぉ！！"]}, {"box": [189, 1120, 325, 1281], "vertical": true, "font_size": 31, "lines_coords": [[[298.0, 1123.0], [325.0, 1123.0], [325.0, 1254.0], [298.0, 1254.0]], [[259.0, 1120.0], [287.0, 1120.0], [290.0, 1229.0], [262.0, 1229.0]], [[226.0, 1123.0], [253.0, 1123.0], [253.0, 1281.0], [226.0, 1281.0]], [[189.0, 1121.0], [217.0, 1121.0], [218.0, 1231.0], [190.0, 1231.0]]], "lines": ["試合なんか", "見ないで", "帰っちまうか", "なぁ～～"]}, {"box": [125, 1312, 195, 1409], "vertical": true, "font_size": 31, "lines_coords": [[[160.0, 1312.0], [195.0, 1312.0], [195.0, 1392.0], [160.0, 1392.0]], [[125.0, 1312.0], [164.0, 1312.0], [164.0, 1409.0], [125.0, 1409.0]]], "lines": ["マンコ", "マンコ。"]}], "img_path": "108.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [762, 239, 804, 410], "vertical": true, "font_size": 38, "lines_coords": [[[762.0, 240.0], [800.0, 239.0], [804.0, 409.0], [767.0, 410.0]]], "lines": ["マンコッコ。"]}, {"box": [216, 1050, 249, 1426], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 1050.0], [243.0, 1050.0], [243.0, 1423.0], [217.0, 1423.0]]], "lines": ["．．．愛子ちゃんが来とる！！"]}], "img_pa