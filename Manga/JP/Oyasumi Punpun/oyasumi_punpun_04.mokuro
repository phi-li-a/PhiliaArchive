2.0]], [[773.0, 879.0], [806.0, 879.0], [806.0, 964.0], [773.0, 964.0]]], "lines": ["小野寺さん", "は．．．"]}, {"box": [901, 1095, 967, 1368], "vertical": true, "font_size": 66, "lines_coords": [[[901.0, 1095.0], [967.0, 1095.0], [967.0, 1368.0], [901.0, 1368.0]]], "lines": ["ホギャッ！！"]}, {"box": [82, 1132, 251, 1570], "vertical": true, "font_size": 109, "lines_coords": [[[142.0, 1132.0], [251.0, 1134.0], [248.0, 1415.0], [139.0, 1414.0]]], "lines": ["ホギャー"]}], "img_path": "098.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [960, 865, 988, 1050], "vertical": true, "font_size": 22, "lines_coords": [[[960.0, 865.0], [982.0, 865.0], [982.0, 1046.0], [960.0, 1046.0]]], "lines": ["．．．いいですよ！！"]}, {"box": [506, 939, 570, 1072], "vertical": true, "font_size": 27, "lines_coords": [[[540.0, 939.0], [568.0, 939.0], [570.0, 1071.0], [542.0, 1071.0]], [[506.0, 940.0], [532.0, 940.0], [532.0, 1045.0], [506.0, 1045.0]]], "lines": ["だから．．．", "もう．．．"]}, {"box": [128, 990, 233, 1153], "vertical": true, "font_size": 28, "lines_coords": [[[201.0, 992.0], [232.0, 992.0], [232.0, 1153.0], [201.0, 1153.0]], [[167.0, 992.0], [193.0, 992.0], [193.0, 1125.0], [167.0, 1125.0]], [[131.0, 990.0], [159.0, 990.0], [156.0, 1150.0], [128.0, 1150.0]]], "lines": ["絶対に私から", "離れないで", "ください．．．"]}, {"box": [623, 1300, 759, 1492], "vertical": true, "font_size": 26, "lines_coords": [[[732.0, 1300.0], [759.0, 1300.0], [759.0, 1432.0], [732.0, 1432.0]], [[695.0, 1301.0], [721.0, 1301.0], [721.0, 1492.0], [695.0, 1492.0]], [[659.0, 1300.0], [685.0, 1300.0], [685.0, 1459.0], [659.0, 1459.0]], [[623.0, 1300.0], [650.0, 1300.0], [650.0, 1432.0], [623.0, 1432.0]]], "lines": ["なんだって", "してあげますよ、", "小野寺さんが", "望むなら！！"]}, {"box": [229, 1285, 296, 1425], "vertical": true, "font_size": 28, "lines_coords": [[[260.0, 1287.0], [293.0, 1285.0], [296.0, 1371.0], [264.0, 1373.0]], [[229.0, 1290.0], [256.0, 1290.0], [256.0, 1425.0], [229.0, 1425.0]]], "lines": ["じゃ．．．", "じゃあ．．．．．"]}, {"box":