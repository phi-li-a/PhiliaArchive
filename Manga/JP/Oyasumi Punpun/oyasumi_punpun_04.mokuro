], "lines": ["倒れた。"]}], "img_path": "153.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "154.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "155.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [375, 146, 445, 282], "vertical": true, "font_size": 32, "lines_coords": [[[412.0, 148.0], [445.0, 148.0], [445.0, 265.0], [412.0, 265.0]], [[378.0, 146.0], [410.0, 146.0], [407.0, 282.0], [375.0, 282.0]]], "lines": ["おーい、", "プンプン！！"]}, {"box": [23, 262, 67, 418], "vertical": true, "font_size": 44, "lines_coords": [[[23.0, 262.0], [67.0, 262.0], [67.0, 418.0], [23.0, 418.0]]], "lines": ["第４３話"]}, {"box": [110, 525, 178, 659], "vertical": true, "font_size": 28, "lines_coords": [[[150.0, 526.0], [178.0, 526.0], [178.0, 646.0], [150.0, 646.0]], [[114.0, 525.0], [142.0, 525.0], [139.0, 659.0], [110.0, 659.0]]], "lines": ["早く、見に", "行こーぜ！？"]}], "img_path": "156.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [953, 121, 1015, 306], "vertical": true, "font_size": 28, "lines_coords": [[[989.0, 121.0], [1015.0, 121.0], [1015.0, 256.0], [989.0, 256.0]], [[953.0, 121.0], [979.0, 121.0], [979.0, 306.0], [953.0, 306.0]]], "lines": ["．．．慢性的な", "アキレス腱炎？"]}, {"box": [837, 331, 940, 515], "vertical": true, "font_size": 28, "lines_coords": [[[912.0, 332.0], [940.0, 332.0], [940.0, 439.0], [912.0, 439.0]], [[876.0, 334.0], [903.0, 334.0], [903.0, 515.0], [876.0, 515.0]], [[837.0, 331.0], [870.0, 331.0], [870.0, 415.0], [837.0, 415.0]]], "lines": ["どうして", "言わなかったん", "だ．．．．．"]}, {"box": [151, 534, 253, 743], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 534.0], [248.0, 534.0], [246.0, 742.0], [223.0, 742.0]], [[187.0, 534.0], [214.0, 534.0], [214.0, 743.0], [187.0, 743.0]], [[151.0, 534.0], [179.0, 534.0], [179.0, 628.0], [151.0, 628.0]]], "lines": ["どうりで不自然に", "右足をかばってた", "はずだ。"]}, {"box": [912, 865, 1012, 1075], "vertical": true, "font_size": 27, "lines_coords": [[[984.0, 865.0], [1010.0, 865.0], [1010.0, 1037.0], [984.0, 1037.0]], [[948.0, 865.0], [975.0, 865.0], [975.0, 1075.0], [948.0, 1075.0]], [[912.0, 865.0], [939.0, 865.0], [939.0, 957.0], [912.0, 957.0]]], "lines": ["左足に、急激な", "負担がかかったん", "だろう。"]}, {"box": [597, 898, 691, 1031], "vertical": true, "font_size": 25, "lines_coords": [[[662.0, 898.0], [690.0, 898.0], [690.0, 987.0], [662.0, 987.0]], [[629.0, 901.0], [651.0, 901.0], [651.0, 1031.0], [629.0, 1031.0]]], "lines": ["．．．先輩、", "終わったな"]}, {"box": [207, 867, 273, 1034], "vertical": true, "font_size": 27, "lines_coords": [[[240.0, 867.0], [273.0, 867.0], [273.0, 976.0], [240.0, 976.0]], [[207.0, 868.0], [234.0, 868.0], [234.0, 1034.0], [207.0, 1034.0]]], "lines": ["無茶して", "勝たなくても、"]}, {"box": [96, 914, 181, 1073], "vertical": true, "font_size": 27, "lines_coords": [[[153.0, 914.0], [181.0, 914.0], [181.0, 1018.0], [153.0, 1018.0]], [[123.0, 915.0], [150.0, 915.0], [150.0, 1073.0], [123.0, 1073.0]], [[96.0, 917.0], [118.0, 917.0], [118.0, 1023.0], [96.0, 1023.0]]], "lines": ["県大会が", "まだ残ってた", "のにさぁ"]}, {"box": [713, 1284, 814, 1507], "vertical": true, "font_size": 26, "lines_coords": [[[785.0, 1284.0], [812.0, 1284.0], [812.0, 1468.0], [785.0, 1468.0]], [[750.0, 1284.0], [776.0, 1284.0], [776.0, 1507.0], [750.0, 1507.0]], [[714.0, 1284.0], [740.0, 1284.0], [740.0, 1428.0], [714.0, 1428.0]]], "lines": ["腱が断裂してる", "なら、最低二か月は", "ギプスだな。"]}, {"box": [332, 1159, 437, 1373], "vertical": true, "font_size": 30, "lines_coords": [[[404.0, 1162.0], [437.0, 1162.0], [437.0, 1282.0], [404.0, 1282.0]], [[370.0, 1159.0], [401.0, 1159.0], [398.0, 1373.0], [367.0, 1373.0]], [[335.0, 1159.0], [362.0, 1159.0], [359.0, 1292.0], [332.0, 1292.0]]], "lines": ["．．．マモル、", "すごく頑張ってた", "と思うわ！！"]}, {"box": [106, 1376, 170, 1545], "vertical": true, "font_size": 26, "lines_coords": [[[142.0, 1379.0], [168.0, 1379.0], [168.0, 1545.0], [142.0, 1545.0]], [[106.0, 1376.0], [1