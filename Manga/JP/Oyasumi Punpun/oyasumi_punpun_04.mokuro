"0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [763, 107, 900, 392], "vertical": true, "font_size": 25, "lines_coords": [[[875.0, 110.0], [896.0, 110.0], [896.0, 343.0], [875.0, 343.0]], [[834.0, 107.0], [860.0, 107.0], [860.0, 320.0], [834.0, 320.0]], [[798.0, 109.0], [825.0, 109.0], [825.0, 392.0], [798.0, 392.0]], [[764.0, 107.0], [790.0, 107.0], [790.0, 371.0], [764.0, 371.0]]], "lines": ["．．．けれど数日後には", "堕胎や軟禁なんて", "あの少女の妄想だったん", "じゃないかと思えたし、"]}, {"box": [212, 248, 351, 468], "vertical": true, "font_size": 26, "lines_coords": [[[325.0, 253.0], [346.0, 253.0], [346.0, 467.0], [325.0, 467.0]], [[282.0, 248.0], [309.0, 248.0], [312.0, 460.0], [285.0, 460.0]], [[248.0, 251.0], [275.0, 251.0], [275.0, 435.0], [248.0, 435.0]], [[212.0, 250.0], [239.0, 250.0], [239.0, 445.0], [212.0, 445.0]]], "lines": ["１０日も経つ頃には、", "少女の存在自体が", "幻だったように", "すら感じられた。"]}, {"box": [265, 1021, 408, 1235], "vertical": true, "font_size": 29, "lines_coords": [[[381.0, 1023.0], [407.0, 1023.0], [407.0, 1214.0], [381.0, 1214.0]], [[343.0, 1025.0], [371.0, 1025.0], [371.0, 1145.0], [343.0, 1145.0]], [[307.0, 1023.0], [334.0, 1023.0], [334.0, 1234.0], [307.0, 1234.0]], [[265.0, 1023.0], [298.0, 1021.0], [301.0, 1118.0], [268.0, 1120.0]]], "lines": ["．．．どちらにせよ、", "僕はこの", "くだらない日常を", "選んだ。"]}, {"box": [882, 1123, 951, 1482], "vertical": true, "font_size": 27, "lines_coords": [[[915.0, 1123.0], [942.0, 1123.0], [945.0, 1248.0], [918.0, 1248.0]], [[914.0, 1367.0], [946.0, 1367.0], [946.0, 1457.0], [914.0, 1457.0]], [[882.0, 1371.0], [904.0, 1371.0], [904.0, 1482.0], [882.0, 1482.0]]], "lines": ["あのさ．．．", "．．．結婚", "しようか"]}, {"box": [82, 1332, 184, 1518], "vertical": true, "font_size": 26, "lines_coords": [[[156.0, 1332.0], [182.0, 1332.0], [182.0, 1492.0], [156.0, 1492.0]], [[118.0, 1334.0], [145.0, 1334.0], [145.0, 1518.0], [118.0, 1518.0]], [[82.0, 1332.0], [109.0, 1332.0], [110.0, 1503.0], [84.0, 1503.0]]], "lines": ["それはむしろ", "晴れ晴れとした", "気分だったよ。"]}], "img_path": "044.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [923, 96, 1023, 281], "vertical": true, "font_size": 26, "lines_coords": [[[992.0, 98.0], [1018.0, 98.0], [1023.0, 281.0], [996.0, 281.0]], [[956.0, 96.0], [984.0, 96.0], [985.0, 231.0], [957.0, 231.0]], [[923.0, 101.0], [946.0, 101.0], [948.0, 267.0], [925.0, 267.0]]], "lines": ["え～～それでは", "始めさせて", "いただきます。"]}, {"box": [210, 154, 368, 415], "vertical": true, "font_size": 26, "lines_coords": [[[342.0, 156.0], [368.0, 156.0], [368.0, 323.0], [342.0, 323.0]], [[312.0, 157.0], [334.0, 157.0], [334.0, 415.0], [312.0, 415.0]], [[275.0, 154.0], [301.0, 154.0], [301.0, 367.0], [275.0, 367.0]], [[243.0, 156.0], [270.0, 156.0], [270.0, 315.0], [243.0, 315.0]], [[210.0, 156.0], [237.0, 156.0], [237.0, 296.0], [210.0, 296.0]]], "lines": ["．．．早速ですが、", "こちらの青磁の大壺が", "各公募展において、", "大変高く評価", "されました。"]}, {"box": [784, 310, 920, 548], "vertical": true, "font_size": 26, "lines_coords": [[[893.0, 312.0], [920.0, 312.0], [920.0, 526.0], [893.0, 526.0]], [[856.0, 310.0], [882.0, 310.0], [882.0, 537.0], [856.0, 537.0]], [[821.0, 312.0], [848.0, 312.0], [848.0, 548.0], [821.0, 548.0]], [[785.0, 310.0], [812.0, 310.0], [810.0, 532.0], [784.0, 532.0]]], "lines": ["インタビューは私", "一月刊美と生きる」", "編集部の成瀬が務め", "させてもらいます。"]}, {"box": [137, 456, 306, 731], "vertical": true, "font_size": 26, "lines_coords": [[[279.0, 459.0], [306.0, 459.0], [306.0, 670.0], [279.0, 670.0]], [[245.0, 460.0], [271.0, 460.0], [271.0, 731.0], [245.0, 731.0]], [[206.0, 456.0], [237.0, 456.0], [235.0, 721.0], [204.0, 721.0]], [[171.0, 460.0], [198.0, 460.0], [198.0, 723.0], [171.0, 723.0]], [[137.0, 462.0], [159.0, 462.0], [159.0, 696.0], [137.0, 696.0]]], "lines": ["前衛に流れがちな", "昨今の陶芸界において、", "弱冠２５歳とは思えない", "鷲尾さんのこの作品は", "正に青天の露震と．．．"]}, {"box": [976, 1021, 1003, 1137], "vertical": true, "font_size": 26, "lines_coords": [[[976.0, 1021.0], [1003.0, 1021.0], [1003.0, 1137.0], [976.0, 1137.0]]], "lines": ["え～と"]}, {"box": [595, 759, 662, 926], "vertical": true, "font_size": 30, "lines_coords": [[[626.0, 760.0], [659.0, 759.0], [662.0, 843.0], [629.0, 845.0]], [[595.0, 762.0], [621.0, 762.0], [621.0, 920.0], [595.0, 920.0]]], "lines": ["けれど", "そんな気分は"]}, {"box": [431, 762, 495, 919], "vertical": true, "font_size": 26, "lines_coords": [[[467.0, 764.0], [493.0, 764.0], [493.0, 918.0], [467.0, 918.0]], [[431.0, 762.0], [457.0, 762.0], [457.0, 903.0], [431.0, 903.0]]], "lines": ["ほんの束の間", "だったんだ。"]}, {"box": [942, 1204, 968, 1303], "vertical": true, "font_size": 26, "lines_coords": [[[942.0, 1204.0], [968.0, 1204.0], [968.0, 1303.0], [942.0, 1303.0]]], "lines": ["．．．アレ？"]}, {"box": [540, 1172, 592, 1283], "vertical": true, "font_size": 22, "lines_coords": [[[570.0, 1173.0], [592.0, 1173.0], [592.0, 1235.0], [570.0, 1235.0]]], "lines": ["んすくん～～～"]}, {"box": [700, 1350, 726, 1482], "vertical": true, "font_size": 26, "lines_coords": [[[700.0, 1350.0], [726.0, 1350.0], [726.0, 1482.0], [700.0, 1482.0]]], "lines": ["鷲尾さん？"]}], "img_path": "045.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [707, 62, 778, 248], "vertical": true, "font_size": 32, "lines_coords": [[[739.0, 62.0], [778.0, 62.0], [778.0, 151.0], [739.0, 151.0]], [[707.0, 64.0], [739.0, 64.0], [739.0, 248.0], [707.0, 248.0]]], "lines": ["小野寺", "せんせぇ～～！！"]}, {"box": [576, 120, 642, 306], "vertical": true, "font_size": 32, "lines_coords": [[[614.0, 120.0], [642.0, 120.0], [639.0, 231.0], [610.0, 231.0]], [[576.0, 123.0], [603.0, 123.0], [603.0, 306.0], [576.0, 306.0]]], "lines": ["ごぶさた", "してますぅ～～"]}, {"box": [121, 267, 185, 450], "vertical": true, "font_size": 26, "lines_coords": [[[154.0, 267.0], [185.0, 267.0], [185.0, 426.0], [154.0, 426.0]], [[121.0, 270.0], [143.0, 270.0], [143.0, 448.0], [121.0, 448.0]]], "lines": ["モロッコ旅行", "いかがでした？"]}, {"box": [330, 820, 354, 891], "vertical": true, "font_size": 24, "lines_coords": [[[330.0, 820.0], [354.0, 820.0], [354.0, 891.0], [330.0, 891.0]]], "lines": ["ミン！"]}, 