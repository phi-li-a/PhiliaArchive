0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [807, 117, 945, 378], "vertical": true, "font_size": 26, "lines_coords": [[[917.0, 117.0], [943.0, 117.0], [943.0, 248.0], [917.0, 248.0]], [[878.0, 117.0], [909.0, 117.0], [909.0, 328.0], [878.0, 328.0]], [[843.0, 117.0], [870.0, 117.0], [870.0, 378.0], [843.0, 378.0]], [[807.0, 117.0], [829.0, 117.0], [829.0, 321.0], [807.0, 321.0]]], "lines": ["フンフンは", "なんだかとっても", "逃げ出したい気持ちで", "いっぱいでした！！"]}, {"box": [110, 118, 414, 330], "vertical": true, "font_size": 29, "lines_coords": [[[379.0, 120.0], [414.0, 120.0], [414.0, 204.0], [379.0, 204.0]], [[346.0, 123.0], [373.0, 123.0], [373.0, 253.0], [346.0, 253.0]], [[307.0, 120.0], [335.0, 120.0], [337.0, 253.0], [309.0, 253.0]], [[270.0, 118.0], [303.0, 118.0], [303.0, 237.0], [270.0, 237.0]], [[220.0, 121.0], [246.0, 121.0], [246.0, 304.0], [220.0, 304.0]], [[181.0, 121.0], [209.0, 121.0], [210.0, 329.0], [182.0, 329.0]], [[146.0, 123.0], [173.0, 123.0], [173.0, 304.0], [146.0, 304.0]], [[110.0, 121.0], [137.0, 121.0], [137.0, 304.0], [110.0, 304.0]]], "lines": ["しかし", "震える膝を", "抑えるのが", "精一杯で、", "何か言いたけな", "愛子ちゃんの前て", "なすすべのない", "フンフンです！！"]}, {"box": [26, 1068, 1056, 1600], "vertical": false, "font_size": 499, "lines_coords": [[[26.0, 1137.0], [1018.0, 1068.0], [1056.0, 1600.0], [64.0, 1600.0]]], "lines": ["あっ．．．あっ、はっはっ、大丈夫だったんだろう"]}], "img_path": "118.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "119.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [459, 56, 685, 604], "vertical": true, "font_size": 76, "lines_coords": [[[576.0, 60.0], [651.0, 56.0], [685.0, 526.0], [610.0, 531.0]], [[514.0, 162.0], [590.0, 157.0], [614.0, 554.0], [537.0, 559.0]], [[459.0, 185.0], [535.0, 181.0], [556.0, 600.0], [479.0, 604.0]]], "lines": ["そしてそのくらびるに", "やさくチッスを", "してやろうか．．．？"]}, {"box": [615, 790, 679, 1009], "vertical": true, "font_size": 27, "lines_coords": [[[651.0, 792.