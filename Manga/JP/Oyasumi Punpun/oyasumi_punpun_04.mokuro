e": 29, "lines_coords": [[[571.0, 204.0], [598.0, 204.0], [598.0, 337.0], [571.0, 337.0]], [[535.0, 203.0], [557.0, 203.0], [557.0, 387.0], [535.0, 387.0]], [[500.0, 200.0], [526.0, 200.0], [523.0, 335.0], [496.0, 335.0]]], "lines": ["忘れるワケ", "ないじゃな～～", "～～～いい！！"]}, {"box": [284, 150, 384, 281], "vertical": true, "font_size": 28, "lines_coords": [[[353.0, 151.0], [382.0, 151.0], [384.0, 257.0], [354.0, 257.0]], [[318.0, 153.0], [345.0, 153.0], [345.0, 281.0], [318.0, 281.0]], [[284.0, 150.0], [310.0, 150.0], [310.0, 281.0], [284.0, 281.0]]], "lines": ["ホンット", "いい子なの", "よーっ！？"]}, {"box": [99, 582, 220, 791], "vertical": true, "font_size": 26, "lines_coords": [[[192.0, 584.0], [218.0, 584.0], [218.0, 718.0], [192.0, 718.0]], [[160.0, 582.0], [189.0, 582.0], [185.0, 781.0], [157.0, 781.0]], [[129.0, 584.0], [156.0, 584.0], [156.0, 715.0], [129.0, 715.0]], [[101.0, 584.0], [123.0, 584.0], [123.0, 790.0], [101.0, 790.0]]], "lines": ["あたしが男", "だったら、確実に", "押し倒して", "ねじ込んでるワ！！"]}, {"box": [939, 881, 1001, 1023], "vertical": true, "font_size": 24, "lines_coords": [[[976.0, 884.0], [998.0, 884.0], [998.0, 1017.0], [976.0, 1017.0]], [[939.0, 882.0], [965.0, 882.0], [965.0, 1023.0], [939.0, 1023.0]]], "lines": ["：ごめんね", "こんな姉で。"]}, {"box": [482, 915, 547, 1059], "vertical": true, "font_size": 27, "lines_coords": [[[518.0, 917.0], [545.0, 917.0], [545.0, 1048.0], [518.0, 1048.0]], [[482.0, 915.0], [509.0, 915.0], [509.0, 1057.0], [482.0, 1057.0]]], "lines": ["相変わらず", "元気ですね。"]}, {"box": [982, 1184, 1017, 1292], "vertical": true, "font_size": 28, "lines_coords": [[[982.0, 1184.0], [1017.0, 1184.0], [1017.0, 1292.0], [982.0, 1292.0]]], "lines": ["．．．雄一！！"]}, {"box": [842, 1254, 965, 1448], "vertical": true, "font_size": 28, "lines_coords": [[[939.0, 1254.0], [965.0, 1254.0], [965.0, 1448.0], [939.0, 1448.0]], [[907.0, 1259.0], [935.0, 1259.0], [932.0, 1421.0], [904.0, 1421.0]], [[876.0, 1262.0], [903.0, 1262.0], [903.0, 1379.0], [876.0, 1379.0]], [[845.0, 1260.0], [871.0, 1260.0], [868.0, 1421.0], [842.0, 1421.0]]], "lines": ["あんたみたいな", "うすらハゲに", "しちゃあ、", "上出来だわ！！"]}, {"box": [518, 1207, 637, 1393], "vertical": true, "font_size": 26, "lines_coords": [[[604.0, 1207.0], [637.0, 1207.0], [634.0, 1370.0], [601.0, 1370.0]], [[575.0, 1210.0], [601.0, 1210.0], [601.0, 1357.0], [575.0, 1357.0]], [[550.0, 1212.0], [571.0, 1212.0], [571.0, 1393.0], [550.0, 1393.0]], [[520.0, 1210.0], [543.0, 1210.0], [542.0, 1367.0], [518.0, 1367.0]]], "lines": ["やっぱアレ？", "あたし、今晩", "家空けたほうが", "良いかしら？"]}, {"box": [429, 1331, 493, 1501], "vertical": true, "font_size": 24, "lines_coords": [[[470.0, 1334.0], [492.0, 1334.0], [492.0, 1473.0], [470.0, 1473.0]], [[431.0, 1331.0], [457.0, 1331.0], [456.0, 1500.0], [429.0, 1500.0]]], "lines": ["うるせーよ、", "露骨なんだよ。"]}, {"box": [240, 1218, 285, 1346], "vertical": true, "font_size": 45, "lines_coords": [[[240.0, 1218.0], [285.0, 1218.0], [285.0, 1346.0], [240.0, 1346.0]]], "lines": ["Ｌｅｂｌュー"]}, {"box": [116, 1060, 205, 1514], "vertical": true, "font_size": 25, "lines_coords": [[[170.0, 1068.0], [196.0, 1068.0], [196.0, 1225.0], [170.0, 1225.0]], [[153.0, 1332.0], [179.0, 1332.0], [179.0, 1514.0], [153.0, 1514.0]], [[120.0, 1334.0], [142.0, 1334.0], [142.0, 1487.0], [120.0, 1487.0]]], "lines": ["キャハハハ！！", "なんだか今日は", "楽しいワァ！！"]}], "img_path": "177.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [892, 67, 981, 257], "vertical": true, "font_size": 27, "lines_coords": [[[954.0, 70.0], [981.0, 70.0], [981.0, 182.0], [954.0, 182.0]], [[920.0, 67.0], [951.0, 67.0], [948.0, 257.0], [917.0, 257.0]], [[892.0, 70.0], [918.0, 70.0], [918.0, 203.0], [892.0, 203.0]]], "lines": ["翠ちゃん、", "実家暮らしなん", "でしょオ！？"]}, {"box": [818, 276, 915, 460], "vertical": true, "font_size": 27, "lines_coords": [[[889.0, 276.0], [915.0, 276.0], [915.0, 443.0], [889.0, 443.0]], [[851.0, 278.0], [879.0, 278.0], [879.0, 410.0], [851.0, 410.0]], [[818.0, 279.0], [840.0, 279.0], [840.0, 460.0], [818.0, 460.0]]], "lines": ["いいじゃない、", "このウチに", "住んじゃえば！！"]}, {"box": [183, 92, 319, 287], "vertical": true, "font_size": 26, "lines_coords": [[[290.0, 92.0], [317.0, 92.0], [317.0, 287.0], [290.0, 287.0]], [[254.0, 95.0], [281.0, 95.0], [281.0, 225.0], [254.0, 225.0]], [[218.0, 92.0], [245.0, 92.0], [245.0, 259.0], [218.0, 259.0]], [[184.0, 93.0], [206.0, 93.0], [206.0, 248.0], [184.0, 248.0]]], "lines": ["そして、あたしが", "ヨボヨボに", "なったら、下の", "世話をして！！"]}, {"box": [870, 637, 982, 903], "vertical": true, "font_size": 49, "lines_coords": [[[917.0, 639.0], [976.0, 637.0], [982.0, 901.0], [923.0, 903.0]], [[870.0, 639.0], [909.0, 639.0], [914.0, 835.0], [875.0, 835.0]]], "lines": ["アアアァッ、", "もうっ！！"]}, {"box": [81, 353, 223, 562], "vertical": true, "font_size": 26, "lines_coords": [[[192.0, 354.0], [218.0, 354.0], [218.0, 562.0], [192.0, 562.0]], [[157.0, 354.0], [185.0, 354.0], [185.0, 468.0], [157.0, 468.0]], [[123.0, 356.0], [145.0, 356.0], [145.0, 509.0], [123.0, 509.0]], [[84.0, 353.0], [110.0, 353.0], [107.0, 512.0], [81.0, 512.0]]], "lines": ["何言ってんですか", "お姉さん、", "まだ３０代じゃ", "ないですか！"]}, {"box": [695, 1048, 759, 1212], "vertical": true, "font_size": 27, "lines_coords": [[[729.0, 1048.0], [757.0, 1048.0], [759.0, 1212.0], [731.0, 1212.0]], [[695.0, 1053.0], [721.0, 1053.0], [721.0, 1209.0], [695.0, 1209.0]]], "lines": ["えーーと．．．", "大隈翠です。"]}, {"box": [109, 682, 254, 984], "vertical": true, "font_size": 43, "lines_coords": [[[209.0, 682.0], [251.0, 682.0], [251.0, 984.0], [209.0, 984.0]], [[157.0, 682.0], [200.0, 682.0], [203.0, 973.0], [160.0, 973.0]], [[109.0, 685.0], [154.0, 685.0], [154.0, 810.0], [109.0, 810.0]]], "lines": ["なんだかとっても", "ダイヤモンド☆", "愉快！！"]}, {"box": [382, 1384, 407, 1540], "vertical": true, "font_size": 22, "lines_coords": [[[382.0, 1384.0], [404.0, 1384.0], [404.0, 1539.0], [382.0, 1539.0]]], "lines": ["よろしくね？"]}], "img_path": "178.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [935, 651, 968, 793], "vertical": true, "font_size": 30, "lines_coords": [[[935.0, 651.0], [968.0, 651.0], [968.0, 793.0], [935.0, 793.0]]], "lines": ["．．．へぇ〜〜〜"]}, {"box": [873, 829, 900, 942], "vertical": true, "font_size": 30, "lines_coords": [[[873.0, 829.0], [900.0, 829.0], [900.0, 942.0], [873.0, 942.0]]], "lines": ["．．．なんか"]}, {"box": [602, 1090, 702, 1275], "vertical": true, "font_size": 26, "lines_coords": [[[671.0, 1090.0], [700.0, 1090.0], [701.0, 1209.0], [673.0, 1209.0]], [[639.0, 1093.0], [665.0, 1093.0], [665.0, 1275.0], [639.0, 1275.0]], [[603.0, 1092.0], [625.0, 1092.0], [625.0, 1232.0], [603.0, 1232.0]]], "lines": ["．．．そうね。", "シャイボーイな", "ところもね。"]}, {"box": [126, 831, 270, 976], "vertical": true, "font_size": 26, "lines_coords": [[[231.0, 831.0], [257.0, 831.0], [260.0, 973.0], [234.0, 973.0]], [[196.0, 832.0], [223.0, 832.0], [223.0, 965.0], [196.0, 965.0]], [[160.0, 832.0], [187.0, 832.0], [187.0, 965.0], [160.0, 965.0]], [[128.0, 834.0], [150.0, 834.0], [150.0, 973.0], [128.0, 973.0]]], "lines": ["甥とはいえ、", "よく見ると", "雄一君に顔", "似てるねぇ。"]}, {"box": [354, 1393, 426, 1503], "vertical": true, "font_size": 38, "lines_coords": [[[392.0, 1396.0], [426.0, 1396.0], [426.0, 1501.0], [392.0, 1501.0]], [[354.0, 1393.0], [395.0, 1393.0], [395.0, 1443.0], [354.0, 1443.0]]], "lines": ["フンフン", "はー"]}, {"box": [121, 1160, 184, 1345], "vertical": true, "font_size": 26, "lines_coords": [[[156.0, 1160.0], [182.0, 1160.0], [182.0, 1320.0], [156.0, 1320.0]], [[121.0, 1160.0], [148.0, 1160.0], [148.0, 1345.0], [121.0, 1345.0]]], "lines": ["陰鬱なところ", "じゃなくてェ！？"]}], "img_path": "179.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [873, 106, 971, 314], "vertical": true, "font_size": 26, "lines_coords": [[[945.0, 107.0], [971.0, 107.0], [971.0, 296.0], [945.0, 296.0]], [[906.0, 106.0], [937.0, 106.0], [937.0, 267.0], [906.0, 267.0]], [[873.0, 106.0], [895.0, 106.0], [895.0, 314.0], [873.0, 314.0]]], "lines": ["ねぇ翠ちゃあん、", "せめて今日は", "治まってってェ？"]}, {"box": [720, 196, 842, 393], "vertical": true, "font_size": 26, "lines_coords": [[[815.0, 196.0], [842.0, 196.0], [842.0, 393.0], [815.0, 393.0]], [[785.0, 200.0], [812.0, 200.0], [812.0, 332.0], [785.0, 332.0]], [[756.0, 198.0], [778.0, 198.0], [778.0, 381.0], [756.0, 381.0]], [[720.0, 196.0], [748.0, 196.0], [751.0, 318.0], [723.0, 318.0]]], "lines": ["てないと、あたし", "寂しくって", "泣いちゃうかも", "しれない。"]}, {"box": [598, 290, 626, 396], "vertical": true, "font_size": 27, "lines_coords": [[[598.0, 290.0], [626.0, 290.0], [626.0, 396.0], [598.0, 396.0]]], "lines": ["えええ？"]}, {"box": [485, 396, 582, 598], "vertical": true, "font_size": 27, "lines_coords": [[[556.0, 396.0], [582.0, 396.0], [582.0, 585.0], [556.0, 585.0]], [[521.0, 400.0], [548.0, 400.0], [548.0, 598.0], [521.0, 598.0]], [[485.0, 401.0], [512.0, 401.0], [512.0, 534.0], [485.0, 534.0]]], "lines": ["そうですか．．．", "じゃあ、お言葉に", "甘えて．．．"]}, {"box": [637, 682, 662, 824], "vertical": true, "font_size": 21, "lines_coords": [[[639.0, 682.0], [660.0, 682.0], [660.0, 814.0], [639.0, 814.0]]], "lines": ["この数日間"]}, {"box": [451, 681, 552, 840], "vertical": true, "font_size": 27, "lines_coords": [[[523.0, 684.0], [551.0, 684.0], [551.0, 789.0], [523.0, 789.0]], [[489.0, 681.0], [515.0, 681.0], [515.0, 840.0], [489.0, 840.0]], [[451.0, 682.0], [478.0, 682.0], [478.0, 823.0], [451.0, 823.0]]], "lines": ["なんだか", "ちょっと変な", "感じてした。"]}, {"box": [282, 1215, 346, 1510], "vertical": true, "font_size": 27, "lines_coords": [[[318.0, 1217.0], [345.0, 1217.0], [342.0, 1375.0], [315.0, 1375.0]], [[282.0, 1218.0], [309.0, 1218.0], [309.0, 1504.0], [282.0, 1504.0]]], "lines": ["部活の大会が", "終わってからというもの"]}, {"box": [153, 1215, 219, 1467], "vertical": true, "font_size": 27, "lines_coords": [[[190.0, 1218.0], [217.0, 1218.0], [217.0, 1414.0], [190.0, 1414.0]], [[153.0, 1215.0], [179.0, 1215.0], [181.0, 1460.0], [154.0, 1460.0]]], "lines": ["毎日、同じような", "夢はかり見るのです。"]}], "img_path": "180.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [756, 1026, 1023, 1511], "vertical": true, "font_size": 82, "lines_coords": [[[918.0, 1026.0], [1023.0, 1031.0], [1006.0, 1421.0], [901.0, 1417.0]], [[906.0, 1060.0], [934.0, 1057.0], [942.0, 1117.0], [914.0, 1120.0]], [[845.0, 1035.0], [948.0, 1035.0], [948.0, 1454.0], [845.0, 1454.0]], [[756.0, 1075.0], [846.0, 1060.0], [907.0, 1464.0], [815.0, 1478.0]]], "lines": ["深い闇の底へ", "．．", "落ちてゆくような", "気がするってっ"]}, {"box": [400, 1051, 629, 1560], "vertical": true, "font_size": 80, "lines_coords": [[[528.0, 1209.0], [610.0, 1207.0], [617.0, 1456.0], [534.0, 1457.0]], [[437.0, 1057.0], [514.0, 1051.0], [546.0, 1440.0], [470.0, 1446.0]]], "lines": ["ははは", "落ちちゃえっ"]}], "img_path": "181.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [934, 68, 1026, 584], "vertical": true, "font_size": 92, "lines_coords": [[[934.0, 68.0], [1026.0, 68.0], [1026.0, 584.0], [934.0, 584.0]]], "lines": ["捨てるのが惜しいほど"]}, {"box": [695, 53, 814, 673], "vertical": true, "font_size": 113, "lines_coords": [[[695.0, 54.0], [807.0, 53.0], [814.0, 671.0], [701.0, 673.0]]], "lines": ["上等な家族がいるのから"]}, {"box": [549, 75, 615, 376], "vertical": true, "font_size": 24, "lines_coords": [[[589.0, 76.0], [610.0, 76.0], [610.0, 373.0], [589.0, 373.0]], [[550.0, 76.0], [576.0, 76.0], [576.0, 296.0], [550.0, 296.0]]], "lines": ["アタシ、４０歳になったら", "全身整形するの！！」"]}, {"box": [343, 37, 475, 653], "vertical": true, "font_size": 121, "lines_coords": [[[343.0, 39.0], [464.0, 37.0], [475.0, 651.0], [354.0, 653.0]]], "lines": ["あきらめられないような"]}, {"box": [73, 8, 209, 678], "vertical": true, "font_size": 131, "lines_coords": [[[78.0, 18.0], [209.0, 18.0], [204.0, 678.0], [73.0, 678.0]]], "lines": ["立派な夢でもあるのか？"]}, {"box": [704, 690, 1006, 1167], "vertical": true, "font_size": 76, "lines_coords": [[[939.0, 837.0], [973.0, 840.0], [965.0, 912.0], [931.0, 909.0]], [[864.0, 714.0], [939.0, 715.0], [929.0, 1071.0], [854.0, 1070.0]], [[757.0, 690.0], [878.0, 690.0], [878.0, 1167.0], [757.0, 1167.0]], [[704.0, 715.0], [779.0, 712.0], [796.0, 1143.0], [721.0, 1146.0]]], "lines": ["〜", "どんな人生でも", "人は必ずいつか死ぬことですよーなぞ", "これだけは平等だ。"]}, {"box": [126, 696, 392, 1179], "vertical": true, "font_size": 74, "lines_coords": [[[320.0, 729.0], [385.0, 728.0], [392.0, 1037.0], [326.0, 1039.0]], [[232.0, 748.0], [325.0, 742.0], [351.0, 1173.0], [259.0, 1179.0]], [[171.0, 698.0], [259.0, 696.0], [268.0, 1175.0], [181.0, 1176.0]], [[134.0, 767.0], [182.0, 767.0], [178.0, 996.0], [129.0, 996.0]]], "lines": ["そんな人生で", "人が選べる選択肢は", "たったらつしかないって", "知ってた？"]}, {"box": [375, 1228, 464, 1560], "vertical": true, "font_size": 89, "lines_coords": [[[375.0, 1228.0], [464.0, 1228.0], [464.0, 1560.0], [375.0, 1560.0]]], "lines": ["やらないか"]}, {"box": [96, 1221, 314, 1573], "vertical": true, "font_size": 106, "lines_coords": [[[182.0, 1234.0], [293.0, 1225.0], [314.0, 1481.0], [203.0, 1490.0]], [[96.0, 1228.0], [196.0, 1221.0], [217.0, 1539.0], [117.0, 1545.0]]], "lines": ["それだけ", "だっつーの"]}], "img_path": "182.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [869, 93, 976, 232], "vertical": true, "font_size": 33, "lines_coords": [[[934.0, 93.0], [976.0, 93.0], [976.0, 159.0], [934.0, 159.0]], [[903.0, 98.0], [935.0, 98.0], [935.0, 232.0], [903.0, 232.0]], [[870.0, 100.0], [896.0, 100.0], [896.0, 215.0], [870.0, 215.0]]], "lines": ["今の", "プンプンは", "とにかく、"]}, {"box": [657, 681, 763, 813], "vertical": true, "font_size": 29, "lines_coords": [[[739.0, 682.0], [760.0, 682.0], [760.0, 810.0], [739.0, 810.0]], [[698.0, 684.0], [726.0, 684.0], [726.0, 812.0], [698.0, 812.0]], [[657.0, 681.0], [696.0, 681.0], [696.0, 771.0], [657.0, 771.0]]], "lines": ["．．．もう誰も", "傷つけたく", "ないし、"]}, {"box": [529, 680, 601, 865], "vertical": true, "font_size": 34, "lines_coords": [[[573.0, 682.0], [600.0, 682.0], [600.0, 864.0], [573.0, 864.0]], [[529.0, 681.0], [570.0, 681.0], [570.0, 771.0], [529.0, 771.0]]], "lines": ["誰とも話したく", "ないし、"]}, {"box": [295, 681, 470, 903], "vertical": true, "font_size": 26, "lines_coords": [[[442.0, 682.0], [468.0, 682.0], [468.0, 867.0], [442.0, 867.0]], [[406.0, 682.0], [432.0, 682.0], [432.0, 840.0], [406.0, 840.0]], [[370.0, 682.0], [396.0, 682.0], [396.0, 821.0], [370.0, 821.0]], [[332.0, 682.0], [359.0, 682.0], [359.0, 892.0], [332.0, 892.0]], [[295.0, 681.0], [321.0, 681.0], [323.0, 900.0], [296.0, 900.0]]], "lines": ["世界中の人から", "忘れ去られて", "しまったら、", "どれだけ楽だろう", "とすら思いました。"]}, {"box": [143, 406, 244, 620], "vertical": true, "font_size": 28, "lines_coords": [[[217.0, 409.0], [243.0, 409.0], [243.0, 606.0], [217.0, 606.0]], [[178.0, 406.0], [209.0, 406.0], [209.0, 618.0], [178.0, 618.0]], [[143.0, 407.0], [170.0, 407.0], [170.0, 567.0], [143.0, 567.0]]], "lines": ["何も考えず、ただ", "眠っていたいのだ", "というのに！！"]}, {"box": [748, 1040, 835, 1126], "vertical": false, "font_size": 32, "lines_coords": [[[771.0, 1040.0], [835.0, 1104.0], [812.0, 1126.0], [748.0, 1062.0]]], "lines": ["知りん。"]}, {"box": [467, 1254, 617, 1351], "vertical": false, "font_size": 33, "lines_coords": [[[481.0, 1254.0], [617.0, 1321.0], [603.0, 1351.0], [467.0, 1284.0]]], "lines": ["つまやのを！？"]}], "img_path": "183.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [409, 477, 585, 714], "vertical": true, "font_size": 28, "lines_coords": [[[554.0, 478.0], [585.0, 478.0], [585.0, 637.0], [554.0, 637.0]], [[520.0, 479.0], [546.0, 479.0], [546.0, 615.0], [520.0, 615.0]], [[482.0, 479.0], [509.0, 479.0], [509.0, 714.0], [482.0, 714.0]], [[445.0, 478.0], [473.0, 478.0], [471.0, 687.0], [443.0, 687.0]], [[409.0, 479.0], [435.0, 479.0], [435.0, 670.0], [409.0, 670.0]]], "lines": ["いつだったか", "小学生の頃、", "田中愛子という子が", "言っていたことを", "思い出しました。"]}, {"box": [197, 476, 329, 665], "vertical": true, "font_size": 28, "lines_coords": [[[301.0, 479.0], [328.0, 479.0], [328.0, 659.0], [301.0, 659.0]], [[262.0, 478.0], [293.0, 478.0], [293.0, 664.0], [262.0, 664.0]], [[228.0, 476.0], [254.0, 476.0], [254.0, 662.0], [228.0, 662.0]]], "lines": ["石油が無くなり", "環境は破壊され", "人類は滅亡する"]}, {"box": [757, 776, 898, 962], "vertical": true, "font_size": 27, "lines_coords": [[[868.0, 779.0], [896.0, 779.0], [896.0, 912.0], [868.0, 912.0]], [[832.0, 779.0], [859.0, 779.0], [859.0, 962.0], [832.0, 962.0]], [[795.0, 779.0], [821.0, 779.0], [821.0, 962.0], [795.0, 962.0]], [[757.0, 776.0], [784.0, 776.0], [787.0, 943.0], [760.0, 943.0]]], "lines": ["プンプンは", "大人になったら", "宇宙を研究する", "学者になって、"]}, {"box": [124, 1046, 262, 1207], "vertical": true, "font_size": 27, "lines_coords": [[[232.0, 1046.0], [260.0, 1046.0], [257.0, 1181.0], [229.0, 1181.0]], [[196.0, 1050.0], [223.0, 1050.0], [223.0, 1181.0], [196.0, 1181.0]], [[157.0, 1046.0], [189.0, 1046.0], [189.0, 1207.0], [157.0, 1207.0]], [[126.0, 1050.0], [148.0, 1050.0], [148.0, 1190.0], [126.0, 1190.0]]], "lines": ["人類を移住", "させようと", "思ったことも", "ありました。"]}, {"box": [873, 1321, 938, 1464], "vertical": true, "font_size": 28, "lines_coords": [[[909.0, 1321.0], [937.0, 1321.0], [937.0, 1454.0], [909.0, 1454.0]], [[873.0, 1321.0], [900.0, 1321.0], [900.0, 1462.0], [873.0, 1462.0]]], "lines": ["プンプンは", "思いました。"]}, {"box": [85, 1360, 191, 1531], "vertical": true, "font_size": 30, "lines_coords": [[[162.0, 1365.0], [190.0, 1365.0], [190.0, 1471.0], [162.0, 1471.0]], [[128.0, 1367.0], [150.0, 1367.0], [150.0, 1525.0], [128.0, 1525.0]], [[85.0, 1360.0], [125.0, 1360.0], [125.0, 1412.0], [85.0, 1412.0]]], "lines": ["あの頃は", "子供たったな", "と。"]}], "img_path": "184.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [878, 96, 1015, 307], "vertical": true, "font_size": 28, "lines_coords": [[[987.0, 98.0], [1014.0, 98.0], [1014.0, 229.0], [987.0, 229.0]], [[948.0, 96.0], [979.0, 96.0], [979.0, 307.0], [948.0, 307.0]], [[914.0, 98.0], [940.0, 98.0], [940.0, 282.0], [914.0, 282.0]], [[878.0, 98.0], [906.0, 98.0], [906.0, 185.0], [878.0, 185.0]]], "lines": ["子供の頃は", "手を伸ばすだけで", "掴めそうだった", "星空も、"]}, {"box": [254, 303, 332, 376], "vertical": true, "font_size": 33, "lines_coords": [[[289.0, 303.0], [332.0, 303.0], [332.0, 365.0], [289.0, 365.0]], [[254.0, 303.0], [295.0, 303.0], [295.0, 376.0], [254.0, 376.0]]], "lines": ["今は", "もう、"]}, {"box": [153, 453, 253, 621], "vertical": true, "font_size": 33, "lines_coords": [[[226.0, 454.0], [253.0, 454.0], [253.0, 612.0], [226.0, 612.0]], [[189.0, 454.0], [215.0, 454.0], [215.0, 612.0], [189.0, 612.0]], [[153.0, 453.0], [179.0, 453.0], [179.0, 621.0], [153.0, 621.0]]], "lines": ["すっとずっと", "遠いところで", "知らん顔です。"]}, {"box": [957, 723, 1023, 884], "vertical": true, "font_size": 29, "lines_coords": [[[996.0, 725.0], [1023.0, 725.0], [1023.0, 882.0], [996.0, 882.0]], [[957.0, 723.0], [989.0, 723.0], [989.0, 884.0], [957.0, 884.0]]], "lines": ["ちょちょ．．．", "雄一君．．．．．！！"]}, {"box": [837, 790, 935, 975], "vertical": true, "font_size": 29, "lines_coords": [[[907.0, 792.0], [935.0, 792.0], [935.0, 926.0], [907.0, 926.0]], [[870.0, 790.0], [901.0, 790.0], [901.0, 953.0], [870.0, 953.0]], [[837.0, 792.0], [864.0, 792.0], [864.0, 975.0], [837.0, 975.0]]], "lines": ["私、今日は", "そのつもりで", "来てないし．．．"]}, {"box": [925, 1062, 1021, 1245], "vertical": true, "font_size": 25, "lines_coords": [[[995.0, 1064.0], [1021.0, 1064.0], [1021.0, 1195.0], [995.0, 1195.0]], [[959.0, 1062.0], [985.0, 1062.0], [985.0, 1245.0], [959.0, 1245.0]], [[926.0, 1065.0], [948.0, 1065.0], [948.0, 1243.0], [926.0, 1243.0]]], "lines": ["．．．ていうか", "この襖一枚じゃ", "聞こえちゃう．．．"]}, {"box": [456, 1095, 496, 1171], "vertical": true, "font_size": 34, "lines_coords": [[[456.0, 1095.0], [496.0, 1095.0], [496.0, 1171.0], [456.0, 1171.0]]], "lines": ["．．．あ、"]}, {"box": [284, 751, 343, 935], "vertical": true, "font_size": 24, "lines_coords": [[[321.0, 756.0], [343.0, 756.0], [343.0, 935.0], [321.0, 935.0]], [[284.0, 751.0], [310.0, 751.0], [310.0, 910.0], [284.0, 910.0]]], "lines": ["つもりもなにも", "翠ちゃん．．．！！"]}, {"box": [135, 818, 232, 1001], "vertical": true, "font_size": 24, "lines_coords": [[[206.0, 818.0], [232.0, 818.0], [232.0, 1001.0], [206.0, 1001.0]], [[171.0, 818.0], [193.0, 818.0], [193.0, 950.0], [171.0, 950.0]], [[135.0, 818.0], [157.0, 818.0], [157.0, 1000.0], [135.0, 1000.0]]], "lines": ["僕のポテンツは", "もう最高潮", "なのだよ．．．．！！"]}, {"box": [676, 1332, 776, 1490], "vertical": true, "font_size": 27, "lines_coords": [[[748.0, 1334.0], [775.0, 1334.0], [775.0, 1465.0], [748.0, 1465.0]], [[712.0, 1334.0], [739.0, 1334.0], [739.0, 1490.0], [712.0, 1490.0]], [[676.0, 1332.0], [703.0, 1332.0], [703.0, 1489.0], [676.0, 1489.0]]], "lines": ["．．．大丈夫！！", "二人とももう", "寝てるさ．．．"]}, {"box": [404, 1198, 432, 1282], "vertical": true, "font_size": 34, "lines_coords": [[[404.0, 1198.0], [432.0, 1198.0], [432.0, 1282.0], [404.0, 1282.0]]], "lines": ["や．．．"]}, {"box": [285, 1107, 346, 1364], "vertical": true, "font_size": 25, "lines_coords": [[[325.0, 1107.0], [346.0, 1107.0], [346.0, 1364.0], [325.0, 1364.0]], [[285.0, 1107.0], [312.0, 1107.0], [312.0, 1240.0], [285.0, 1240.0]]], "lines": ["人類は減亡するような", "気もするし、"]}, {"box": [176, 1104, 240, 1365], "vertical": true, "font_size": 25, "lines_coords": [[[214.0, 1104.0], [240.0, 1104.0], [237.0, 1365.0], [210.0, 1365.0]], [[176.0, 1106.0], [203.0, 1106.0], [203.0, 1273.0], [176.0, 1273.0]]], "lines": ["やっぱりしないような", "気もしました。"]}, {"box": [112, 1407, 148, 1515], "vertical": true, "font_size": 33, "lines_coords": [[[112.0, 1409.0], [145.0, 1407.0], [148.0, 1512.0], [115.0, 1514.0]]], "lines": ["んっ．．．"]}], "img_path": "185.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [842, 121, 942, 289], "vertical": true, "font_size": 27, "lines_coords": [[[912.0, 121.0], [940.0, 121.0], [940.0, 253.0], [912.0, 253.0]], [[878.0, 123.0], [904.0, 123.0], [904.0, 254.0], [878.0, 254.0]], [[842.0, 121.0], [868.0, 121.0], [868.0, 285.0], [842.0, 285.0]]], "lines": ["ただひとつ", "はっきりと", "しているのは、"]}, {"box": [128, 531, 264, 756], "vertical": true, "font_size": 24, "lines_coords": [[[239.0, 534.0], [260.0, 534.0], [260.0, 689.0], [239.0, 689.0]], [[198.0, 531.0], [225.0, 531.0], [225.0, 714.0], [198.0, 714.0]], [[164.0, 532.0], [190.0, 532.0], [190.0, 756.0], [164.0, 756.0]], [[129.0, 532.0], [151.0, 532.0], [151.0, 726.0], [129.0, 726.0]]], "lines": ["自分の人生は", "まだしばらくは", "続くのだな、という", "ことだけでした。"]}, {"box": [204, 912, 237, 1015], "vertical": true, "font_size": 28, "lines_coords": [[[204.0, 912.0], [237.0, 912.0], [237.0, 1015.0], [204.0, 1015.0]]], "lines": ["プンプー"]}, {"box": [175, 981, 198, 1045], "vertical": true, "font_size": 28, "lines_coords": [[[175.0, 981.0], [198.0, 981.0], [198.0, 1045.0], [175.0, 1045.0]]], "lines": ["ン！！"]}, {"box": [864, 1214, 975, 1410], "vertical": true, "font_size": 23, "lines_coords": [[[950.0, 1215.0], [973.0, 1215.0], [975.0, 1359.0], [951.0, 1359.0]], [[923.0, 1217.0], [945.0, 1217.0], [945.0, 1371.0], [923.0, 1371.0]], [[892.0, 1215.0], [918.0, 1215.0], [918.0, 1410.0], [892.0, 1410.0]], [[864.0, 1214.0], [890.0, 1214.0], [890.0, 1314.0], [864.0, 1314.0]]], "lines": ["前にみんなで", "春休み、遊びに", "行こうって言ってた", "じゃん？"]}, {"box": [776, 1340, 860, 1543], "vertical": true, "font_size": 23, "lines_coords": [[[839.0, 1340.0], [860.0, 1340.0], [860.0, 1509.0], [839.0, 1509.0]], [[807.0, 1342.0], [829.0, 1342.0], [829.0, 1543.0], [807.0, 1543.0]], [[776.0, 1342.0], [798.0, 1342.0], [798.0, 1540.0], [776.0, 1540.0]]], "lines": ["女子達の意見を", "尊重して、渋谷って", "ことになったけど、"]}, {"box": [103, 1354, 170, 1512], "vertical": true, "font_size": 26, "lines_coords": [[[140.0, 1356.0], [167.0, 1356.0], [167.0, 1487.0], [140.0, 1487.0]], [[103.0, 1354.0], [129.0, 1354.0], [132.0, 1512.0], [106.0, 1512.0]]], "lines": ["プンプンも", "来るでしょ？"]}], "img_path": "186.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [975, 123, 1001, 253], "vertical": true, "font_size": 29, "lines_coords": [[[975.0, 123.0], [1001.0, 123.0], [1001.0, 253.0], [975.0, 253.0]]], "lines": ["．．．アレ？"]}, {"box": [884, 281, 948, 415], "vertical": true, "font_size": 29, "lines_coords": [[[915.0, 281.0], [948.0, 281.0], [948.0, 401.0], [915.0, 401.0]], [[884.0, 284.0], [912.0, 284.0], [912.0, 415.0], [884.0, 415.0]]], "lines": ["おーい、", "プンプン？"]}, {"box": [881, 625, 943, 756], "vertical": true, "font_size": 27, "lines_coords": [[[917.0, 625.0], [943.0, 625.0], [943.0, 756.0], [917.0, 756.0]], [[881.0, 625.0], [907.0, 625.0], [907.0, 756.0], [881.0, 756.0]]], "lines": ["．．．まー別に", "よくねー？"]}, {"box": [165, 334, 229, 504], "vertical": true, "font_size": 25, "lines_coords": [[[200.0, 335.0], [228.0, 335.0], [228.0, 451.0], [200.0, 451.0]], [[167.0, 337.0], [189.0, 337.0], [189.0, 501.0], [167.0, 501.0]]], "lines": ["．．．なんだ、", "寝てんじゃん。"]}, {"box": [154, 631, 255, 815], "vertical": true, "font_size": 27, "lines_coords": [[[226.0, 637.0], [253.0, 637.0], [253.0, 815.0], [226.0, 815.0]], [[189.0, 634.0], [215.0, 634.0], [215.0, 795.0], [189.0, 795.0]], [[154.0, 631.0], [181.0, 631.0], [181.0, 725.0], [154.0, 725.0]]], "lines": ["一緒に行っても", "つまんねーよ、", "きっと。"]}, {"box": [739, 717, 862, 903], "vertical": true, "font_size": 27, "lines_coords": [[[834.0, 717.0], [862.0, 717.0], [862.0, 839.0], [834.0, 839.0]], [[803.0, 721.0], [829.0, 721.0], [829.0, 853.0], [803.0, 853.0]], [[771.0, 720.0], [798.0, 720.0], [798.0, 903.0], [771.0, 903.0]], [[739.0, 718.0], [767.0, 718.0], [768.0, 839.0], [740.0, 839.0]]], "lines": ["プンプン、", "最近なんか", "すげー付き合い", "わりーし。"]}, {"box": [323, 948, 346, 1078], "vertical": true, "font_size": 23, "lines_coords": [[[325.0, 948.0], [346.0, 948.0], [346.0, 981.0], [325.0, 981.0]], [[323.0, 993.0], [345.0, 993.0], [345.0, 1078.0], [323.0, 1078.0]]], "lines": ["うー", "ーん．．．"]}, {"box": [253, 1078, 282, 1196], "vertical": true, "font_size": 23, "lines_coords": [[[253.0, 1078.0], [279.0, 1078.0], [282.0, 1196.0], [256.0, 1196.0]]], "lines": ["そうかも。"]}, {"box": [162, 1306, 284, 1490], "vertical": true, "font_size": 26, "lines_coords": [[[256.0, 1309.0], [284.0, 1309.0], [284.0, 1451.0], [256.0, 1451.0]], [[225.0, 1307.0], [251.0, 1307.0], [251.0, 1490.0], [225.0, 1490.0]], [[192.0, 1307.0], [218.0, 1307.0], [218.0, 1490.0], [192.0, 1490.0]], [[162.0, 1306.0], [185.0, 1306.0], [185.0, 1379.0], [162.0, 1379.0]]], "lines": ["つーかアレ、", "シカトだったら", "超最悪なんです", "けどー"]}, {"box": [100, 1418, 126, 1532], "vertical": true, "font_size": 21, "lines_coords": [[[100.0, 1418.0], [121.0, 1418.0], [121.0, 1532.0], [100.0, 1532.0]]], "lines": ["あははは。"]}], "img_path": "187.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [842, 793, 918, 896], "vertical": true, "font_size": 43, "lines_coords": [[[881.0, 798.0], [914.0, 796.0], [918.0, 895.0], [885.0, 896.0]], [[842.0, 793.0], [895.0, 793.0], [895.0, 854.0], [842.0, 854.0]]], "lines": ["．．．なぁ、", "関。"]}, {"box": [881, 1059, 988, 1220], "vertical": true, "font_size": 31, "lines_coords": [[[960.0, 1064.0], [987.0, 1064.0], [987.0, 1220.0], [960.0, 1220.0]], [[921.0, 1062.0], [948.0, 1062.0], [951.0, 1204.0], [925.0, 1204.0]], [[881.0, 1059.0], [921.0, 1059.0], [921.0, 1135.0], [881.0, 1135.0]]], "lines": ["俺も何度でも", "言うけどさ、", "先生。"]}, {"box": [350, 862, 749, 937], "vertical": false, "font_size": 75, "lines_coords": [[[350.0, 862.0], [739.0, 862.0], [739.0, 937.0], [350.0, 937.0]]], "lines": ["社会科資料室"]}, {"box": [501, 1107, 600, 1264], "vertical": true, "font_size": 27, "lines_coords": [[[573.0, 1107.0], [600.0, 1107.0], [600.0, 1264.0], [573.0, 1264.0]], [[535.0, 1107.0], [562.0, 1107.0], [562.0, 1214.0], [535.0, 1214.0]], [[501.0, 1109.0], [528.0, 1109.0], [528.0, 1225.0], [501.0, 1225.0]]], "lines": ["高校行く気は", "さらさら", "ねーから。"]}, {"box": [128, 792, 265, 1014], "vertical": true, "font_size": 26, "lines_coords": [[[234.0, 792.0], [260.0, 792.0], [260.0, 1014.0], [234.0, 1014.0]], [[196.0, 792.0], [223.0, 792.0], [223.0, 1001.0], [196.0, 1001.0]], [[162.0, 792.0], [189.0, 792.0], [189.0, 1014.0], [162.0, 1014.0]], [[128.0, 792.0], [150.0, 792.0], [150.0, 946.0], [128.0, 946.0]]], "lines": ["何度も言うが、まだ", "一年の三学期なん", "だし、焦って考える", "ことないぞ？"]}, {"box": [220, 1100, 286, 1245], "vertical": true, "font_size": 26, "lines_coords": [[[259.0, 1101.0], [285.0, 1101.0], [285.0, 1237.0], [259.0, 1237.0]], [[220.0, 1100.0], [246.0, 1100.0], [250.0, 1245.0], [223.0, 1245.0]]], "lines": ["．．．もういい", "勝手にしろ。"]}, {"box": [487, 1340, 621, 1551], "vertical": true, "font_size": 27, "lines_coords": [[[595.0, 1342.0], [621.0, 1342.0], [621.0, 1550.0], [595.0, 1550.0]], [[553.0, 1340.0], [584.0, 1340.0], [587.0, 1510.0], [556.0, 1510.0]], [[518.0, 1342.0], [545.0, 1342.0], [545.0, 1551.0], [518.0, 1551.0]], [[487.0, 1342.0], [509.0, 1342.0], [509.0, 1496.0], [487.0, 1496.0]]], "lines": ["俺みたいな人間が", "勉強したって、", "悪知恵が身に付く", "だけじゃね？"]}], "img_path": "188.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [942, 98, 1014, 266], "vertical": true, "font_size": 28, "lines_coords": [[[975.0, 98.0], [1003.0, 98.0], [1006.0, 260.0], [978.0, 260.0]], [[943.0, 98.0], [970.0, 98.0], [970.0, 215.0], [943.0, 215.0]]], "lines": ["わりーな清水", "待たせて。"]}, {"box": [612, 95, 682, 256], "vertical": true, "font_size": 32, "lines_coords": [[[645.0, 95.0], [682.0, 96.0], [679.0, 187.0], [642.0, 185.0]], [[615.0, 98.0], [642.0, 98.0], [639.0, 193.0], [612.0, 193.0]]], "lines": ["．．．清水、", "お前はー"]}, {"box": [118, 244, 218, 373], "vertical": true, "font_size": 27, "lines_coords": [[[184.0, 245.0], [218.0, 245.0], [218.0, 328.0], [184.0, 328.0]], [[153.0, 245.0], [179.0, 245.0], [179.0, 373.0], [153.0, 373.0]], [[118.0, 246.0], [140.0, 246.0], [140.0, 348.0], [118.0, 348.0]]], "lines": ["．．．高校", "どうするか", "決めた？"]}, {"box": [770, 317, 966, 544], "vertical": true, "font_size": 34, "lines_coords": [[[928.0, 317.0], [965.0, 317.0], [960.0, 532.0], [923.0, 532.0]], [[875.0, 320.0], [907.0, 320.0], [907.0, 500.0], [875.0, 500.0]], [[825.0, 318.0], [857.0, 318.0], [857.0, 518.0], [825.0, 518.0]], [[773.0, 318.0], [806.0, 318.0], [806.0, 464.0], [773.0, 464.0]]], "lines": ["学年一吾園談", "四組：図書室", "五組：進路穏", "六組：社会"]}, {"box": [754, 520, 818, 676], "vertical": true, "font_size": 24, "lines_coords": [[[789.0, 520.0], [815.0, 520.0], [815.0, 675.0], [789.0, 675.0]], [[756.0, 523.0], [778.0, 523.0], [778.0, 660.0], [756.0, 660.0]]], "lines": ["ちょっと色々", "長びいてさ。"]}, {"box": [564, 467, 657, 673], "vertical": true, "font_size": 24, "lines_coords": [[[635.0, 467.0], [657.0, 467.0], [657.0, 673.0], [635.0, 673.0]], [[600.0, 467.0], [621.0, 467.0], [621.0, 659.0], [600.0, 659.0]], [[564.0, 470.0], [585.0, 470.0], [585.0, 650.0], [564.0, 650.0]]], "lines": ["たくさん勉強して", "できるだけ、いい", "高校行けって．．．"]}, {"box": [450, 546, 518, 703], "vertical": true, "font_size": 24, "lines_coords": [[[490.0, 546.0], [518.0, 546.0], [515.0, 676.0], [487.0, 676.0]], [[454.0, 546.0], [482.0, 546.0], [478.0, 703.0], [450.0, 703.0]]], "lines": ["．．．言ったの", "関くんだよ？"]}, {"box": [918, 784, 949, 953], "vertical": true, "font_size": 27, "lines_coords": [[[921.0, 785.0], [948.0, 785.0], [945.0, 953.0], [918.0, 953.0]]], "lines": ["．．．だったな。"]}, {"box": [295, 870, 321, 1037], "vertical": true, "font_size": 27, "lines_coords": [[[295.0, 870.0], [321.0, 870.0], [321.0, 1037.0], [295.0, 1037.0]]], "lines": ["．．．それでいい。"]}, {"box": [165, 1017, 229, 1171], "vertical": true, "font_size": 27, "lines_coords": [[[200.0, 1017.0], [228.0, 1017.0], [229.0, 1171.0], [201.0, 1171.0]], [[165.0, 1020.0], [193.0, 1020.0], [193.0, 1132.0], [165.0, 1132.0]]], "lines": ["お前は普通が", "一番いい。"]}], "img_path": "189.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [225, 60, 296, 243], "vertical": true, "font_size": 30, "lines_coords": [[[260.0, 60.0], [296.0, 60.0], [296.0, 134.0], [260.0, 134.0]], [[228.0, 60.0], [259.0, 60.0], [256.0, 243.0], [225.0, 243.0]]], "lines": ["．．．おー", "プンプンじゃん。"]}, {"box": [95, 259, 234, 432], "vertical": true, "font_size": 30, "lines_coords": [[[207.0, 260.0], [234.0, 260.0], [234.0, 432.0], [207.0, 432.0]], [[170.0, 262.0], [196.0, 262.0], [196.0, 429.0], [170.0, 429.0]], [[131.0, 260.0], [159.0, 260.0], [162.0, 395.0], [134.0, 395.0]], [[95.0, 259.0], [128.0, 259.0], [128.0, 345.0], [95.0, 345.0]]], "lines": ["なんか、すげー", "久しぶりだな。", "お前も今日", "面談？"]}, {"box": [181, 695, 218, 729], "vertical": false, "font_size": 34, "lines_coords": [[[181.0, 695.0], [218.0, 695.0], [218.0, 729.0], [181.0, 729.0]]], "lines": ["ぷ"]}, {"box": [154, 732, 317, 860], "vertical": false, "font_size": 40.333333333333336, "lines_coords": [[[204.0, 751.0], [310.0, 732.0], [317.0, 771.0], [210.0, 790.0]], [[154.0, 781.0], [187.0, 781.0], [187.0, 825.0], [154.0, 825.0]], [[160.0, 823.0], [195.0, 823.0], [195.0, 860.0], [160.0, 860.0]]], "lines": ["おお", "ギャ", "．．．"]}, {"box": [93, 650, 160, 757], "vertical": true, "font_size": 49, "lines_coords": [[[93.0, 659.0], [142.0, 650.0], [160.0, 748.0], [112.0, 757.0]]], "lines": ["おお"]}, {"box": [876, 984, 996, 1175], "vertical": true, "font_size": 26, "lines_coords": [[[971.0, 985.0], [993.0, 985.0], [993.0, 1142.0], [971.0, 1142.0]], [[939.0, 985.0], [965.0, 985.0], [965.0, 1175.0], [939.0, 1175.0]], [[909.0, 987.0], [935.0, 987.0], [935.0, 1145.0], [909.0, 1145.0]], [[876.0, 984.0], [904.0, 984.0], [907.0, 1075.0], [879.0, 1075.0]]], "lines": ["久々．．．すぎて", "なんか、何話して", "いいかわかん", "ねーな。"]}, {"box": [570, 970, 601, 1131], "vertical": true, "font_size": 33, "lines_coords": [[[570.0, 970.0], [601.0, 970.0], [601.0, 1131.0], [570.0, 1131.0]]], "lines": ["毛、生えた？"]}, {"box": [504, 1087, 539, 1159], "vertical": true, "font_size": 33, "lines_coords": [[[504.0, 1087.0], [539.0, 1087.0], [539.0, 1159.0], [504.0, 1159.0]]], "lines": ["はは。"]}, {"box": [121, 1045, 144, 1162], "vertical": true, "font_size": 22, "lines_coords": [[[121.0, 1045.0], [143.0, 1045.0], [143.0, 1160.0], [121.0, 1160.0]]], "lines": ["じゃーな。"]}, {"box": [664, 1325, 800, 1482], "vertical": true, "font_size": 27, "lines_coords": [[[771.0, 1328.0], [798.0, 1328.0], [798.0, 1459.0], [771.0, 1459.0]], [[735.0, 1328.0], [762.0, 1328.0], [762.0, 1471.0], [735.0, 1471.0]], [[700.0, 1326.0], [726.0, 1326.0], [726.0, 1482.0], [700.0, 1482.0]], [[664.0, 1325.0], [693.0, 1325.0], [693.0, 1396.0], [664.0, 1396.0]]], "lines": ["．．．元気か？", "つーか、随分", "声低くなった", "なあ。"]}, {"box": [182, 1314, 249, 1426], "vertical": true, "font_size": 28, "lines_coords": [[[225.0, 1321.0], [246.0, 1321.0], [246.0, 1423.0], [225.0, 1423.0]], [[182.0, 1314.0], [218.0, 1314.0], [218.0, 1387.0], [182.0, 1387.0]]], "lines": ["ホーホー", "です。"]}], "img_path": "190.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [964, 129, 1028, 264], "vertical": true, "font_size": 28, "lines_coords": [[[995.0, 129.0], [1028.0, 129.0], [1028.0, 168.0], [995.0, 168.0]], [[964.0, 132.0], [990.0, 132.0], [990.0, 264.0], [964.0, 264.0]]], "lines": ["あー", "小野寺は．．．"]}, {"box": [804, 264, 951, 448], "vertical": true, "font_size": 28, "lines_coords": [[[925.0, 264.0], [951.0, 264.0], [951.0, 398.0], [925.0, 398.0]], [[895.0, 264.0], [921.0, 264.0], [921.0, 401.0], [895.0, 401.0]], [[865.0, 267.0], [892.0, 267.0], [892.0, 403.0], [865.0, 403.0]], [[835.0, 264.0], [862.0, 264.0], [862.0, 421.0], [835.0, 421.0]], [[807.0, 264.0], [835.0, 264.0], [832.0, 448.0], [804.0, 448.0]]], "lines": ["授業態度は", "．．．まぁ普通", "成績も中膺、", "上がりもせず", "下がりもせず："]}, {"box": [207, 235, 332, 445], "vertical": true, "font_size": 26, "lines_coords": [[[304.0, 237.0], [332.0, 237.0], [328.0, 431.0], [300.0, 431.0]], [[271.0, 237.0], [298.0, 237.0], [298.0, 398.0], [271.0, 398.0]], [[240.0, 235.0], [262.0, 235.0], [262.0, 445.0], [240.0, 445.0]], [[210.0, 235.0], [237.0, 235.0], [234.0, 396.0], [207.0, 396.0]]], "lines": ["．．．まぁ、先生から", "特別言うべき", "ことは思い当たら", "ないんだが．．．"]}, {"box": [153, 500, 289, 687], "vertical": true, "font_size": 26, "lines_coords": [[[262.0, 503.0], [289.0, 503.0], [289.0, 682.0], [262.0, 682.0]], [[225.0, 504.0], [251.0, 504.0], [251.0, 637.0], [225.0, 637.0]], [[189.0, 500.0], [215.0, 500.0], [212.0, 687.0], [185.0, 687.0]], [[153.0, 503.0], [179.0, 503.0], [179.0, 662.0], [153.0, 662.0]]], "lines": ["．．．なんか、こう、", "無いのか！？", "自分らしい目標", "とか夢とか！？"]}, {"box": [870, 776, 973, 910], "vertical": true, "font_size": 27, "lines_coords": [[[945.0, 778.0], [971.0, 778.0], [971.0, 910.0], [945.0, 910.0]], [[906.0, 776.0], [934.0, 776.0], [935.0, 884.0], [907.0, 884.0]], [[870.0, 778.0], [896.0, 778.0], [896.0, 893.0], [870.0, 893.0]]], "lines": ["ブンブンは", "超考えて", "みました。"]}, {"box": [915, 1104, 981, 1298], "vertical": true, "font_size": 28, "lines_coords": [[[951.0, 1104.0], [978.0, 1104.0], [981.0, 1264.0], [954.0, 1264.0]], [[915.0, 1106.0], [943.0, 1106.0], [945.0, 1293.0], [917.0, 1293.0]]], "lines": ["けれどまるで", "浮かはないので、"]}, {"box": [773, 1103, 876, 1365], "vertical": true, "font_size": 25, "lines_coords": [[[850.0, 1106.0], [871.0, 1106.0], [871.0, 1298.0], [850.0, 1298.0]], [[810.0, 1103.0], [842.0, 1103.0], [842.0, 1265.0], [810.0, 1265.0]], [[778.0, 1106.0], [800.0, 1106.0], [800.0, 1362.0], [778.0, 1362.0]]], "lines": ["宇宙を研究する", "学者になって", "世界を救いたいです。"]}, {"box": [704, 1103, 733, 1329], "vertical": true, "font_size": 26, "lines_coords": [[[706.0, 1103.0], [732.0, 1103.0], [731.0, 1321.0], [704.0, 1321.0]]], "lines": ["と言ってみました。"]}, {"box": [156, 1379, 259, 1553], "vertical": false, "font_size": 54, "lines_coords": [[[207.0, 1379.0], [259.0, 1535.0], [207.0, 1553.0], [156.0, 1396.0]]], "lines": ["しかし、"]}], "img_path": "191.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [932, 76, 1000, 234], "vertical": true, "font_size": 28, "lines_coords": [[[971.0, 76.0], [1000.0, 76.0], [1000.0, 184.0], [971.0, 184.0]], [[932.0, 76.0], [959.0, 76.0], [962.0, 231.0], [935.0, 231.0]]], "lines": ["あぁ～～", "そうかァ．．．"]}, {"box": [494, 123, 631, 317], "vertical": true, "font_size": 27, "lines_coords": [[[604.0, 125.0], [631.0, 125.0], [631.0, 281.0], [604.0, 281.0]], [[564.0, 123.0], [596.0, 123.0], [596.0, 232.0], [564.0, 232.0]], [[531.0, 123.0], [557.0, 123.0], [554.0, 309.0], [528.0, 309.0]], [[495.0, 123.0], [517.0, 123.0], [517.0, 312.0], [495.0, 312.0]]], "lines": ["．．．そういえば", "小野寺は", "パドミントン部", "辞めるんだよな。"]}, {"box": [107, 289, 212, 450], "vertical": true, "font_size": 27, "lines_coords": [[[184.0, 292.0], [210.0, 292.0], [210.0, 423.0], [184.0, 423.0]], [[146.0, 292.0], [173.0, 292.0], [173.0, 450.0], [146.0, 450.0]], [[110.0, 289.0], [139.0, 289.0], [135.0, 448.0], [107.0, 448.0]]], "lines": ["．．．どうだ？", "新しい部活は", "決まったか？"]}, {"box": [675, 385, 810, 575], "vertical": true, "font_size": 25, "lines_coords": [[[782.0, 389.0], [810.0, 389.0], [810.0, 503.0], [782.0, 503.0]], [[748.0, 389.0], [770.0, 389.0], [770.0, 518.0], [748.0, 518.0]], [[710.0, 385.0], [737.0, 385.0], [734.0, 546.0], [707.0, 546.0]], [[676.0, 389.0], [698.0, 389.0], [698.0, 521.0], [676.0, 521.0]]], "lines": ["．．．じゃあ、", "これからは", "死ぬほど勉強", "せんとナァ"]}, {"box": [878, 659, 1000, 890], "vertical": true, "font_size": 25, "lines_coords": [[[970.0, 659.0], [996.0, 659.0], [1000.0, 825.0], [973.0, 825.0]], [[942.0, 664.0], [964.0, 664.0], [964.0, 890.0], [942.0, 890.0]], [[909.0, 659.0], [934.0, 659.0], [931.0, 868.0], [906.0, 868.0]], [[878.0, 664.0], [900.0, 664.0], [900.0, 875.0], [878.0, 875.0]]], "lines": ["．．．いやぁ～～", "世間じゃ囲碁プーム", "だってのにウチの", "部は全然でね～～"]}, {"box": [320, 590, 401, 607], "vertical": false, "font_size": 17, "lines_coords": [[[320.0, 590.0], [401.0, 590.0], [401.0, 607.0], [320.0, 607.0]]], "lines": ["．．．"]}, {"box": [218, 495, 375, 598], "vertical": false, "font_size": 29.666666666666668, "lines_coords": [[[218.0, 512.0], [365.0, 495.0], [370.0, 529.0], [223.0, 546.0]], [[240.0, 542.0], [346.0, 531.0], [350.0, 559.0], [243.0, 570.0]], [[250.0, 571.0], [370.0, 553.0], [375.0, 579.0], [254.0, 598.0]]], "lines": ["私達と著書の上に", "広がる宇宙を", "席におませんか．．．"]}, {"box": [743, 853, 867, 1059], "vertical": true, "font_size": 25, "lines_coords": [[[840.0, 853.0], [867.0, 853.0], [867.0, 1017.0], [840.0, 1017.0]], [[807.0, 853.0], [834.0, 853.0], [834.0, 1039.0], [807.0, 1039.0]], [[778.0, 854.0], [800.0, 854.0], [800.0, 1059.0], [778.0, 1059.0]], [[743.0, 853.0], [770.0, 853.0], [770.0, 959.0], [743.0, 959.0]]], "lines": ["今は部員二人、", "しかもほとんど", "帰宅部と変わらん", "のよ～～"]}, {"box": [223, 842, 343, 1051], "vertical": true, "font_size": 27, "lines_coords": [[[317.0, 845.0], [343.0, 845.0], [343.0, 1039.0], [317.0, 1039.0]], [[285.0, 843.0], [312.0, 843.0], [312.0, 1035.0], [285.0, 1035.0]], [[251.0, 842.0], [278.0, 842.0], [278.0, 1051.0], [251.0, 1051.0]], [[223.0, 843.0], [250.0, 843.0], [250.0, 1026.0], [223.0, 1026.0]]], "lines": ["しかし、君は実に", "真面目そうだし、", "ひやかしではなく", "経験者と見た！！"]}, {"box": [131, 1043, 229, 1243], "vertical": true, "font_size": 27, "lines_coords": [[[203.0, 1045.0], [229.0, 1045.0], [226.0, 1204.0], [200.0, 1204.0]], [[164.0, 1043.0], [195.0, 1043.0], [195.0, 1243.0], [164.0, 1243.0]], [[131.0, 1050.0], [153.0, 1050.0], [153.0, 1178.0], [131.0, 1178.0]]], "lines": ["．．．どうだい？", "早速、僕と打って", "みるかい？"]}, {"box": [884, 1312, 951, 1482], "vertical": true, "font_size": 30, "lines_coords": [[[917.0, 1312.0], [951.0, 1312.0], [951.0, 1396.0], [917.0, 1396.0]], [[885.0, 1315.0], [912.0, 1315.0], [912.0, 1475.0], [885.0, 1475.0]]], "lines": ["二月の", "高い高い空は"]}, {"box": [151, 1328, 254, 1539], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 1329.0], [251.0, 1329.0], [251.0, 1539.0], [225.0, 1539.0]], [[189.0, 1328.0], [215.0, 1328.0], [215.0, 1539.0], [189.0, 1539.0]], [[151.0, 1329.0], [178.0, 1329.0], [178.0, 1421.0], [151.0, 1421.0]]], "lines": ["今のプンプンには", "ちょっと冷たすぎ", "ました。"]}], "img_path": "192.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [835, 360, 943, 479], "vertical": true, "font_size": 33, "lines_coords": [[[901.0, 360.0], [943.0, 360.0], [943.0, 426.0], [901.0, 426.0]], [[871.0, 367.0], [900.0, 367.0], [900.0, 471.0], [871.0, 471.0]], [[835.0, 364.0], [862.0, 364.0], [862.0, 476.0], [835.0, 476.0]]], "lines": ["今は", "ただただ", "この冬が、"]}, {"box": [193, 776, 257, 972], "vertical": true, "font_size": 27, "lines_coords": [[[229.0, 778.0], [256.0, 778.0], [256.0, 959.0], [229.0, 959.0]], [[193.0, 778.0], [220.0, 778.0], [220.0, 970.0], [193.0, 970.0]]], "lines": ["早く終わるのを", "願うばかりです。"]}, {"box": [109, 1209, 160, 1555], "vertical": true, "font_size": 44, "lines_coords": [[[109.0, 1209.0], [153.0, 1209.0], [156.0, 1551.0], [112.0, 1551.0]]], "lines": ["：：：出来るッ！！"]}], "img_path": "193.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "194.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [1036, 290, 1082, 453], "vertical": true, "font_size": 44, "lines_coords": [[[1037.0, 293.0], [1081.0, 293.0], [1081.0, 453.0], [1037.0, 453.0]]], "lines": ["第４５話"]}, {"box": [742, 921, 771, 1065], "vertical": true, "font_size": 26, "lines_coords": [[[742.0, 921.0], [768.0, 921.0], [768.0, 1062.0], [742.0, 1062.0]]], "lines": ["平和ですね。"]}, {"box": [482, 1376, 511, 1533], "vertical": true, "font_size": 27, "lines_coords": [[[482.0, 1376.0], [509.0, 1376.0], [509.0, 1532.0], [482.0, 1532.0]]], "lines": ["平和ですよ！！"]}], "img_path": "195.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [570, 103, 690, 392], "vertical": true, "font_size": 27, "lines_coords": [[[668.0, 107.0], [690.0, 107.0], [690.0, 259.0], [668.0, 259.0]], [[634.0, 106.0], [660.0, 106.0], [660.0, 392.0], [634.0, 392.0]], [[604.0, 103.0], [631.0, 103.0], [631.0, 312.0], [604.0, 312.0]], [[570.0, 106.0], [598.0, 106.0], [598.0, 245.0], [570.0, 245.0]]], "lines": ["おしさん達に", "連れられて来た遊園地は", "とてもとでも良い", "天気でした。"]}, {"box": [481, 104, 542, 365], "vertical": true, "font_size": 27, "lines_coords": [[[515.0, 106.0], [542.0, 106.0], [542.0, 365.0], [515.0, 365.0]], [[481.0, 104.0], [514.0, 104.0], [514.0, 195.0], [481.0, 195.0]]], "lines": ["フンフンの気持ちとは", "裏腹に。"]}, {"box": [140, 210, 215, 350], "vertical": true, "font_size": 29, "lines_coords": [[[165.0, 215.0], [207.0, 210.0], [215.0, 285.0], [173.0, 290.0]], [[140.0, 218.0], [168.0, 218.0], [168.0, 350.0], [140.0, 350.0]]], "lines": ["でも、", "なんか．．．"]}, {"box": [70, 401, 171, 560], "vertical": true, "font_size": 29, "lines_coords": [[[145.0, 401.0], [171.0, 401.0], [171.0, 510.0], [145.0, 510.0]], [[110.0, 406.0], [132.0, 406.0], [132.0, 560.0], [110.0, 560.0]], [[70.0, 401.0], [96.0, 401.0], [100.0, 542.0], [73.0, 542.0]]], "lines": ["こう．．．", "無闇に幸せな", "気持ちだと、"]}, {"box": [793, 687, 937, 1018], "vertical": true, "font_size": 28, "lines_coords": [[[903.0, 689.0], [937.0, 689.0], [937.0, 798.0], [903.0, 798.0]], [[887.0, 845.0], [909.0, 845.0], [909.0, 965.0], [887.0, 965.0]], [[853.0, 842.0], [879.0, 842.0], [879.0, 1014.0], [853.0, 1014.0]], [[823.0, 840.0], [850.0, 840.0], [853.0, 1018.0], [826.0, 1018.0]], [[793.0, 840.0], [821.0, 840.0], [825.0, 953.0], [796.0, 953.0]]], "lines": ["逆に．．．", "こんな目が", "いつまで続くの", "かなって思うと", "．．．．．．不安。"]}, {"box": [203, 818, 265, 931], "vertical": true, "font_size": 27, "lines_coords": [[[239.0, 820.0], [265.0, 820.0], [265.0, 926.0], [239.0, 926.0]], [[203.0, 818.0], [231.0, 818.0], [231.0, 931.0], [203.0, 931.0]]], "lines": ["オイオイ", "翠ちゃん、"]}, {"box": [126, 998, 225, 1185], "vertical": true, "font_size": 27, "lines_coords": [[[196.0, 1000.0], [225.0, 1000.0], [225.0, 1132.0], [196.0, 1132.0]], [[159.0, 998.0], [190.0, 998.0], [190.0, 1185.0], [159.0, 1185.0]], [[126.0, 1001.0], [148.0, 1001.0], [148.0, 1157.0], [126.0, 1157.0]]], "lines": ["僕の根暗が", "伝染ったんじゃ", "ないのかい？"]}, {"box": [864, 1273, 960, 1482], "vertical": true, "font_size": 25, "lines_coords": [[[934.0, 1273.0], [960.0, 1273.0], [960.0, 1434.0], [934.0, 1434.0]], [[898.0, 1275.0], [925.0, 1275.0], [925.0, 1482.0], [898.0, 1482.0]], [[864.0, 1279.0], [885.0, 1279.0], [885.0, 1464.0], [864.0, 1464.0]]], "lines": ["本当に幸せな", "時なんて、ほんの", "一瞬だからこそ、"]}, {"box": [712, 1331, 809, 1542], "vertical": true, "font_size": 25, "lines_coords": [[[782.0, 1332.0], [809.0, 1332.0], [809.0, 1464.0], [782.0, 1464.0]], [[746.0, 1331.0], [773.0, 1331.0], [773.0, 1542.0], [746.0, 1542.0]], [[712.0, 1332.0], [734.0, 1332.0], [734.0, 1539.0], [712.0, 1539.0]]], "lines": ["全力で満喫", "しようぜってこと", "なんじゃないの？"]}, {"box": [146, 1263, 577, 1607], "vertical": false, "font_size": 344, "lines_coords": [[[146.0, 1263.0], [577.0, 1263.0], [577.0, 1607.0], [146.0, 1607.0]]], "lines": ["い"]}], "img_path": "196.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [910, 128, 945, 206], "vertical": true, "font_size": 27, "lines_coords": [[[910.0, 129.0], [940.0, 128.0], [945.0, 204.0], [915.0, 206.0]]], "lines": ["．．うん、"]}, {"box": [807, 145, 834, 285], "vertical": true, "font_size": 27, "lines_coords": [[[810.0, 145.0], [834.0, 145.0], [831.0, 285.0], [807.0, 285.0]]], "lines": ["そうだよね。"]}, {"box": [202, 171, 265, 342], "vertical": true, "font_size": 24, "lines_coords": [[[237.0, 171.0], [264.0, 171.0], [260.0, 304.0], [234.0, 304.0]], [[204.0, 175.0], [226.0, 175.0], [226.0, 340.0], [204.0, 340.0]]], "lines": ["．．．オイオイ", "納得はえーな。"]}, {"box": [943, 451, 973, 593], "vertical": true, "font_size": 26, "lines_coords": [[[943.0, 451.0], [970.0, 451.0], [973.0, 593.0], [946.0, 593.0]]], "lines": ["．．．実はさ、"]}, {"box": [801, 548, 903, 681], "vertical": true, "font_size": 26, "lines_coords": [[[875.0, 548.0], [903.0, 548.0], [903.0, 659.0], [875.0, 659.0]], [[839.0, 548.0], [865.0, 548.0], [862.0, 681.0], [835.0, 681.0]], [[801.0, 550.0], [825.0, 550.0], [826.0, 670.0], [803.0, 670.0]]], "lines": ["ちょっと", "大切な話が", "あるんだ。"]}, {"box": [168, 679, 220, 906], "vertical": true, "font_size": 49, "lines_coords": [[[168.0, 679.0], [217.0, 679.0], [220.0, 906.0], [171.0, 906.0]]], "lines": ["．．．ホァッ！？"]}, {"box": [956, 1028, 1021, 1211], "vertical": true, "font_size": 26, "lines_coords": [[[993.0, 1031.0], [1020.0, 1031.0], [1020.0, 1210.0], [993.0, 1210.0]], [[956.0, 1028.0], [982.0, 1028.0], [982.0, 1143.0], [956.0, 1143.0]]], "lines": ["私のバイト先の", "店長がね、"]}, {"box": [563, 1044, 648, 1214], "vertical": true, "font_size": 28, "lines_coords": [[[612.0, 1087.0], [640.0, 1082.0], [648.0, 1131.0], [620.0, 1135.0]]], "lines": ["．．．あ"]}, {"box": 