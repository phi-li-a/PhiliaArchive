7.0, 345.0]], [[3651.0, 317.0], [3787.0, 317.0], [3787.0, 349.0], [3651.0, 349.0]], [[3572.0, 335.0], [3790.0, 343.0], [3790.0, 387.0], [3572.0, 379.0]], [[3241.0, 347.0], [3448.0, 347.0], [3448.0, 379.0], [3241.0, 379.0]], [[3617.0, 381.0], [3787.0, 381.0], [3787.0, 413.0], [3617.0, 413.0]], [[3237.0, 377.0], [3433.0, 377.0], [3433.0, 420.0], [3237.0, 420.0]], [[3241.0, 407.0], [3794.0, 407.0], [3794.0, 451.0], [3241.0, 451.0]], [[3241.0, 448.0], [3561.0, 448.0], [3561.0, 481.0], [3241.0, 481.0]], [[3602.0, 452.0], [3787.0, 452.0], [3787.0, 484.0], [3602.0, 484.0]], [[3234.0, 475.0], [3787.0, 478.0], [3787.0, 522.0], [3234.0, 518.0]], [[3237.0, 516.0], [3520.0, 516.0], [3520.0, 548.0], [3237.0, 548.0]], [[3723.0, 520.0], [3787.0, 520.0], [3787.0, 552.0], [3723.0, 552.0]], [[3230.0, 542.0], [3681.0, 539.0], [3681.0, 582.0], [3230.0, 586.0]], [[3693.0, 554.0], [3787.0, 554.0], [3787.0, 586.0], [3693.0, 586.0]], [[3234.0, 580.0], [3790.0, 580.0], [3790.0, 624.0], [3234.0, 624.0]], [[3241.0, 618.0], [3531.0, 618.0], [3531.0, 650.0], [3241.0, 650.0]], [[3572.0, 621.0], [3783.0, 621.0], [3783.0, 654.0], [3572.0, 654.0]], [[3237.0, 644.0], [3520.0, 644.0], [3520.0, 688.0], [3237.0, 688.0]], [[3696.0, 652.0], [3783.0, 652.0], [3783.0, 684.0], [3696.0, 684.0]], [[3237.0, 678.0], [3790.0, 678.0], [3790.0, 722.0], [3237.0, 722.0]], [[3234.0, 719.0], [3787.0, 719.0], [3787.0, 752.0], [3234.0, 752.0]], [[3237.0, 753.0], [3452.0, 753.0], [3452.0, 786.0], [3237.0, 786.0]], [[3696.0, 757.0], [3779.0, 757.0], [3779.0, 789.0], [3696.0, 789.0]], [[3678.0, 787.0], [3779.0, 787.0], [3779.0, 819.0], [3678.0, 819.0]], [[3237.0, 787.0], [3516.0, 787.0], [3516.0, 819.0], [3237.0, 819.0]], [[3572.0, 813.0], [3787.0, 817.0], [3787.0, 853.0], [3572.0, 850.0]], [[3230.0, 813.0], [3474.0, 817.0], [3474.0, 853.0], [3230.0, 850.0]], [[3234.0, 847.0], [3459.0, 855.0], [3459.0, 887.0], [3234.0, 880.0]], [[3689.0, 855.0], [3783.0, 855.0], [3783.0, 887.0], [3689.0, 887.0]], [[3234.0, 881.0], [3790.0, 881.0], [3790.0, 925.0], [3234.0, 925.0]], [[3234.0, 919.0], [3471.0, 915.0], [3471.0, 951.0], [3234.0, 955.0]], [[3241.0, 957.0], [3561.0, 957.0], [3561.0, 989.0], [3241.0, 989.0]], [[3693.0, 957.0], [3787.0, 957.0], [3787.0, 996.0], [3693.0, 996.0]]], "lines": ["おやすみプンプンＶラー、〈Ａｎ＃", "浅野いにお羊取りにお", "ソラニン・全２巻", "浅野いにお", "ソフニー・コトー診療所・１～２０巻", "ええ．．．この山田貴敏", "しかし、一診療が「これを円ＡＮＥＯＩに手が取りますが、１〜１０巻安部譲二ノ柿崎正澄ゅぱミキキさヵ", "鉄腕バーティー全２０巻", "ゆうきまさみ", "室積光ノ猪熊しのぶ", "都立水商」全２０巻", "黒丸ノ夏原武", "部立小間．．．主にもクロサギ・全２０巻イキガミです。", "プロリキ・エイムをイキガミーＴｈｅｌＵＮｉｎｄｅＬＩｎｔ－ｌｉｎｔ＿ユーザー」の一黒丸ノ夏尿武日巻一間瀬元朗", "土竜（モグラ）の唄「ーーは巻ー」", "ここ高橋のぼる光", "上国、モノンの唄超無気力戦隊ジャパ、ハイルーナルで「こんなコーラー向かります。ファイブ全日巻一佐藤まささき", "Ｑ．．．Ｏｄｄｅ－オッズ－１〜１０巻", "石渡治", "ＬＵＵＳイッスー「トールをさらにはジトローム」のＷＥＢに全てコーヒーが", "－北崎拓", "ここからインタームページのタナトスでしたが、全日巻、とめければわっし、全国大統領部に・主「１０００個竹原慎二ノ落合裕介１〜２数、司会志織", "とめはねっ！鈴里高校書館部", "１〜４４巻－河合克敏", "とめはんっ！すぎｍなんだけどーチスターズ、１〜６巻、イームホーポロポート", "森尾正博", "逃亡弁護士成田成１－１－５巻高田優ノ剛英城", "ここでは、このまつらはなの男の女性、全日巻くここ、本根ヲサムノ国川光太郎", "魔口ケン・１〜２巻キャラー", "喜国雅彦", "大谷じろう", "美晴♥ライシング。全５巻", "七月鏡一ノ商原芳秀", "実際のイージス、全日巻", "晩の「イヘニンビアオイホノオ「巻」", "島本和彦", "ナオイハンイ．．．やあんころ。劇場か「日は帰路先」「ロローコ」・「」の１～４４島ＡＭ彦７～４巻一万乗大智", "Ｐｒｏｕｂｅ．ｃｏｍｅＢＯ－ＯＮＩＩ－１－３巻", "ドライブ・ア・ライフ・フィブ・コースを", "中井邦彦"]}, {"box": [2004, 1042, 2959, 1088], "vertical": false, "font_size": 42, "lines_coords": [[[2004.0, 1046.0], [2959.0, 1042.0], [2959.0, 1084.0], [2004.0, 1088.0]]], "lines": ["各所書評にて大絶賛！！浅野いにおの話題作！！"]}, {"box": [2002, 1276, 2306, 1445], "vertical": false, "font_size": 28, "lines_coords": [[[2083.0, 1274.0], [2294.0, 1274.0], [2294.0, 1304.0], [2083.0, 1304.0]], [[2008.0, 1308.0], [2305.0, 1304.0], [2305.0, 1334.0], [2008.0, 1338.0]], [[2011.0, 1334.0], [2297.0, 1330.0], [2297.0, 1361.0], [2011.0, 1364.0]], [[2011.0, 1360.0], [2275.0, 1360.0], [2275.0, 1391.0], [2011.0, 1391.0]], [[2011.0, 1387.0], [2294.0, 1387.0], [2294.0, 1417.0], [2011.0, 1417.0]], [[2008.0, 1409.0], [2237.0, 1417.0], [2237.0, 1447.0], [2008.0, 1440.0]]], "lines": ["プンが落書きのようなも", "のだからこその破壊力、新しさが", "と聞かして、リアルなのに", "シュール、平和なのに乱暴．．．", "私を相反するものの共存を可能ですが、", "わざわざ、能にしているＪＩＧＨＤＬＩＰ"]}, {"box": [1977, 1145, 2893, 1265], "vertical": false, "font_size": 28, "lines_coords": [[[2011.0, 1150.0], [2839.0, 1150.0], [2839.0, 1180.0], [2011.0, 1180.0]], [[2075.0, 1180.0], [2797.0, 1180.0], [2797.0, 1210.0], [2075.0, 1210.0]], [[2079.0, 1210.0], [2794.0, 1210.0], [2794.0, 1240.0], [2079.0, 1240.0]], [[2075.0, 1232.0], [2463.0, 1232.0], [2463.0, 1263.0], [2075.0, 1263.0]]], "lines": ["「どこにでもいるフツーの男子をフツーじゃなく描いた浅野にいにおの新境地上（広告批評）", "「リアリスティックな風景のなかに、おいおいこんな．．．。ボソンと放り込まれた、なんの生き物だ", "かもよくわからない主人公、その絵は、まずのこちらのビジネスはキャッチひどくシュールだけれど、なぜか私", "たちの心をひどく動揺させるーーーっ"]}, {"box": [2329, 1272, 2594, 1355], "vertical": false, "font_size": 25, "lines_coords": [[[2335.0, 1270.0], [2579.0, 1270.0], [2579.0, 1300.0], [2335.0, 1300.0]], [[2342.0, 1304.0], [2594.0, 1304.0], [2594.0, 1323.0], [2342.0, 1323.0]], [[2331.0, 1326.0], [2557.0, 1326.0], [2557.0, 1357.0], [2331.0, 1357.0]]], "lines": ["「おやすみプンプンは前", "前です。しかも泣けます。", "報情的です（図書新聞）"]}, {"box": [2149, 1453, 2720, 1574], "vertical": false, "font_size": 28, "lines_coords": [[[2151.0, 1454.0], [2707.0, 1454.0], [2707.0, 1485.0], [2151.0, 1485.0]], [[2151.0, 1485.0], [2711.0, 1485.0], [2711.0, 1515.0], [2151.0, 1515.0]], [[2169.0, 1511.0], [2707.0, 1507.0], [2707.0, 1538.0], [2169.0, 1541.0]]], "lines": ["「これは二十一世紀のつけ義者「かもしれない、と思わされ", "たりする。センスと作画技術のないためにアメリィで「両輪のバランスが、軌道をしのいーい」を", "そしながら平然として作品をもと心と結婚にのレールに復帰させる、誠"]}, {"box": [2369, 1366, 2752, 1438], "vertical": false, "font_size": 38.0, "lines_coords": [[[2369.0, 1400.0], [2752.0, 1400.0], [2752.0, 1438.0], [2369.0, 1438.0]], [[2373.0, 1370.0], [2579.0, 1366.0], [2579.0, 1404.0], [2373.0, 1408.0]]], "lines": ["き細密で完成された物語構成には、会社", "「圧倒的なリアリティー芸秘密で室成された"]}, {"box": [2587, 1280, 3042, 1362], "vertical": false, "font_size": 30.0, "lines_coords": [[[2613.0, 1280.0], [3038.0, 1280.0], [3038.0, 1306.0], [2613.0, 1306.0]], [[2587.0, 1298.0], [3042.0, 1302.0], [3042.0, 1340.0], [2587.0, 1336.0]], [[2609.0, 1336.0], [2967.0, 1336.0], [2967.0, 1362.0], [2609.0, 1362.0]]], "lines": ["「乾いた叙情性、現代的で「スタイリッシュなセール", "続いた設備性、現代のシス、文学的余韻。もしか一生としています。すると、漫画史に残", "る僕作になるかもしれない」（朝日新聞）"]}, {"box": [2860, 1182, 3076, 1266], "vertical": false, "font_size": 92, "lines_coords": [[[2860.0, 1174.0], [3076.0, 1174.0], [3076.0, 1274.0], [2860.0, 1274.0]]], "lines": ["「シュールで提供的な機能が心にしなくて」はいてショッイイントし"]}, {"box": [2636, 1359, 3072, 1404], "vertical": false, "font_size": 30, "lines_coords": [[[2636.0, 1374.0], [3072.0, 1359.0], [3072.0, 1389.0], [2636.0, 1404.0]]], "lines": ["冊やかな感情の動物は一生懸命悩んだり、人の気はわたし"]}, {"box": [2817, 1387, 3092, 1556], "vertical": false, "font_size": 31, "lines_coords": [[[2831.0, 1417.0], [3072.0, 1417.0], [3072.0, 1447.0], [2831.0, 1447.0]], [[2831.0, 1447.0], [3072.0, 1439.0], [3072.0, 1470.0], [2831.0, 1477.0]], [[2831.0, 1470.0], [3068.0, 1470.0], [3068.0, 1500.0], [2831.0, 1500.0]], [[2843.0, 1492.0], [3068.0, 1496.0], [3068.0, 1538.0], [2843.0, 1534.0]]], "lines": ["気持ちを考えたり、時にはまったく頼りにならない世帯にキャーナリナマ", "はぁっに、頼りにならない神様にすがったりするファンの", "神様に９月ったりするンブンの姿が、ものすごく", "おしい。そして、ものすごく痛みしい"]}], "img_path": "002.png"}, {"version": "0.2.0-beta.6", "img_width": 2380, "img_height": 1600, "blocks": [{"box": [2169, 149, 2214, 290], "vertical": true, "font_size": 35, "lines_coords": [[[2175.0, 176.0], [2210.0, 176.0], [2210.0, 283.0], [2175.0, 283.0]]], "lines": ["ッ．．．"]}, {"box": [1506, 172, 1547, 313], "vertical": true, "font_size": 41, "lines_coords": [[[1506.0, 172.0], [1547.0, 172.0], [1547.0, 313.0], [1506.0, 313.0]]], "lines": ["ハウツ．．．"]}, {"box": [1511, 174, 1550, 321], "vertical": true, "font_size": 39, "lines_coords": [[[1511.0, 174.0], [1550.0, 174.0], [1550.0, 321.0], [1511.0, 321.0]]], "lines": ["ウツ．．．"]}, {"box": [2147, 513, 2233, 676], "vertical": true, "font_size": 51, "lines_coords": [[[2182.0, 513.0], [2233.0, 513.0], [2233.0, 627.0], [2182.0, 627.0]]], "lines": ["ハック"]}, {"box": [2090, 513, 2224, 910], "vertical": true, "font_size": 40, "lines_coords": [[[2145.0, 513.0], [2184.0, 513.0], [2184.0, 679.0], [2145.0, 679.0]], [[2131.0, 734.0], [2180.0, 734.0], [2180.0, 858.0], [2131.0, 858.0]], [[2091.0, 734.0], [2124.0, 734.0], [2124.0, 904.0], [2091.0, 904.0]]], "lines": ["ションッ！！", "ハック", "ションッ！！"]}, {"box": [1441, 365, 1482, 486], "vertical": true, "font_size": 41, "lines_coords": [[[1441.0, 365.0], [1482.0, 365.0], [1482.0, 486.0], [1441.0, 486.0]]], "lines": ["ッ！！"]}, {"box": [2089, 729, 2176, 907], "vertical": true, "font_size": 87, "lines_coords": [[[2089.0, 729.0], [2176.0, 729.0], [2176.0, 907.0], [2089.0, 907.0]]], "lines": ["ハックションッ！！"]}, {"box": [1441, 743, 1571, 1069], "vertical": true, "font_size": 43, "lines_coords": [[[1527.0, 744.0], [1568.0, 744.0], [1568.0, 895.0], [1527.0, 895.0]], [[1482.0, 881.0], [1531.0, 881.0], [1531.0, 1009.0], [1482.0, 1009.0]], [[1441.0, 881.0], [1480.0, 881.0], [1480.0, 1067.0], [1441.0, 1067.0]]], "lines": ["ファッ！！", "ハック", "ショイッ！！"]}, {"box": [1148, 1511, 1233, 1566], "vertical": false, "font_size": 60, "lines_coords": [[[1148.0, 1506.0], [1233.0, 1506.0], [1233.0, 1571.0], [1148.0, 1571.0]]], "lines": ["小学館"]}, {"box": [1153, 83, 1222, 142], "vertical": false, "font_size": 28, "lines_coords": [[[1157.0, 81.0], [1217.0, 81.0], [1217.0, 111.0], [1157.0, 111.0]], [[1157.0, 98.0], [1217.0, 98.0], [1217.0, 127.0], [1157.0, 127.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹ", "．．．。それ、じゃあのんじゃ"]}, {"box": [913, 72, 1024, 275], "vertical": true, "font_size": 54, "lines_coords": [[[957.0, 74.0], [1024.0, 74.0], [1024.0, 220.0], [957.0, 220.0]], [[913.0, 72.0], [955.0, 72.0], [955.0, 274.0], [913.0, 274.0]]], "lines": ["ハック", "ションッ！！"]}, {"box": [18, 54, 230, 744], "vertical": true, "font_size": 112, "lines_coords": [[[90.0, 132.0], [220.0, 130.0], [230.0, 716.0], [99.0, 718.0]], [[20.0, 439.0], [113.0, 439.0], [113.0, 693.0], [20.0, 693.0]]], "lines": ["アァアアック", "イツ！"]}, {"box": [1169, 155, 1208, 876], "vertical": true, "font_size": 39, "lines_coords": [[[1169.0, 155.0], [1208.0, 155.0], [1208.0, 876.0], [1169.0, 876.0]]], "lines": ["おやすみプンフンの、浅野いにお"]}, {"box": [733, 601, 841, 812], "vertical": true, "font_size": 48, "lines_coords": [[[783.0, 602.0], [841.0, 602.0], [841.0, 748.0], [783.0, 748.0]], [[734.0, 602.0], [773.0, 602.0], [773.0, 809.0], [734.0, 809.0]]], "lines": ["ハック", "ションッ！！"]}, {"box": [583, 521, 623, 642], "vertical": true, "font_size": 40, "lines_coords": [[[583.0, 521.0], [623.0, 521.0], [623.0, 642.0], [583.0, 642.0]]], "lines": ["ッ．．．"]}, {"box": [304, 697, 355, 841], "vertical": true, "font_size": 51, "lines_coords": [[[304.0, 697.0], [355.0, 697.0], [355.0, 841.0], [304.0, 841.0]]], "lines": ["ファ．．．"]}, {"box": [846, 907, 975, 1102], "vertical": true, "font_size": 33, "lines_coords": [[[871.0, 948.0], [904.0, 948.0], [904.0, 1102.0], [871.0, 1102.0]]], "lines": ["ハックション"]}, {"box": [581, 790, 622, 967], "vertical": true, "font_size": 46, "lines_coords": [[[581.0, 790.0], [622.0, 790.0], [622.0, 967.0], [581.0, 967.0]]], "lines": ["ンファッ！！"]}, {"box": [474, 900, 525, 1067], "vertical": true, "font_size": 46, "lines_coords": [[[474.0, 900.0], [525.0, 900.0], [525.0, 1067.0], [474.0, 1067.0]]], "lines": ["ハアツ．．．"]}, {"box": [901, 1183, 1018, 1397], "vertical": true, "font_size": 55, "lines_coords": [[[957.0, 1186.0], [1018.0, 1186.0], [1018.0, 1327.0], [957.0, 1327.0]], [[906.0, 1183.0], [955.0, 1183.0], [950.0, 1395.0], [901.0, 1395.0]]], "lines": ["ハック", "ションッ！！"]}, {"box": [460, 1330, 583, 1537], "vertical": true, "font_size": 58, "lines_coords": [[[515.0, 1330.0], [583.0, 1332.0], [578.0, 1483.0], [511.0, 1481.0]], [[464.0, 1332.0], [513.0, 1332.0], [509.0, 1537.0], [460.0, 1537.0]]], "lines": ["ハック", "ションッ！！"]}, {"box": [88, 1213, 234, 1489], "vertical": true, "font_size": 65, "lines_coords": [[[151.0, 1216.0], [223.0, 1213.0], [234.0, 1483.0], [162.0, 1486.0]], [[88.0, 1218.0], [146.0, 1218.0], [146.0, 1488.0], [88.0, 1488.0]]], "lines": ["ハアァック", "ションッ！！"]}], "img_path": "003.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [196, 78, 259, 806], "vertical": true, "font_size": 54, "lines_coords": [[[206.0, 78.0], [259.0, 78.0], [250.0, 806.0], [196.0, 806.0]]], "lines": ["おやすみプンプンの「浅野にお"]}, {"box": [62, 1498, 268, 1521], "vertical": false, "font_size": 22, "lines_coords": [[[65.0, 1498.0], [262.0, 1499.0], [262.0, 1523.0], [65.0, 1522.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹＣＯＭＣＳ"]}], "img_path": "004.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [126, 229, 257, 257], "vertical": false, "font_size": 28, "lines_coords": [[[126.0, 229.0], [257.0, 229.0], [257.0, 257.0], [126.0, 257.0]]], "lines": ["登場人物"]}, {"box": [196, 278, 371, 309], "vertical": false, "font_size": 31, "lines_coords": [[[196.0, 278.0], [371.0, 278.0], [371.0, 309.0], [196.0, 309.0]]], "lines": ["小野寺プンプン"]}, {"box": [193, 309, 706, 334], "vertical": false, "font_size": 22, "lines_coords": [[[193.0, 312.0], [706.0, 309.0], [706.0, 331.0], [193.0, 334.0]]], "lines": ["チョコパイ好きのヤングがん、得意な必殺技は真空波動拳。"]}, {"box": [195, 368, 726, 428], "vertical": false, "font_size": 32.0, "lines_coords": [[[195.0, 368.0], [418.0, 368.0], [418.0, 400.0], [195.0, 400.0]], [[196.0, 396.0], [726.0, 396.0], [726.0, 428.0], [196.0, 428.0]]], "lines": ["「小野寺プンプンママさんの", "ブンブンの母親。前世は天使だ。わたと信じている。若干アル中で"]}, {"box": [198, 462, 559, 535], "vertical": false, "font_size": 23.333333333333332, "lines_coords": [[[200.0, 462.0], [328.0, 462.0], [328.0, 484.0], [200.0, 484.0]], [[200.0, 490.0], [559.0, 490.0], [559.0, 512.0], [200.0, 512.0]], [[198.0, 509.0], [478.0, 509.0], [478.0, 535.0], [198.0, 535.0]]], "lines": ["小野寺雄一", "プンプンママの弟。素直にこなれない年頃。", "フンフンママの売り素直になれば、現在はビデオ屋でアルバイト中。"]}, {"box": [200, 550, 565, 607], "vertical": false, "font_size": 27.0, "lines_coords": [[[200.0, 553.0], [304.0, 550.0], [304.0, 578.0], [200.0, 581.0]], [[201.0, 581.0], [565.0, 581.0], [565.0, 607.0], [201.0, 607.0]]], "lines": ["田中愛子", "ブンブンが小学生の時から好きな女の子。"]}, {"box": [198, 639, 567, 698], "vertical": false, "font_size": 27.5, "lines_coords": [[[198.0, 642.0], [276.0, 639.0], [278.0, 667.0], [200.0, 670.0]], [[200.0, 671.0], [567.0, 671.0], [567.0, 698.0], [200.0, 698.0]]], "lines": ["大限早", "喫茶店で働くフリーター一女子。元・看護師。"]}, {"box": [715, 78, 979, 1006], "vertical": true, "font_size": 97, "lines_coords": [[[929.0, 168.0], [967.0, 168.0], [975.0, 896.0], [937.0, 896.0]], [[876.0, 167.0], [912.0, 167.0], [918.0, 885.0], [882.0, 885.0]], [[789.0, 87.0], [900.0, 87.0], [900.0, 126.0], [789.0, 126.0]], [[715.0, 114.0], [945.0, 114.0], [945.0, 1006.0], [715.0, 1006.0]], [[820.0, 884.0], [881.0, 884.0], [881.0, 953.0], [820.0, 953.0]], [[875.0, 896.0], [979.0, 896.0], [979.0, 956.0], [875.0, 956.0]]], "lines": ["．．．それ、また、お．．．はっ、は、", "話話語話話話話の話が話し話して話しました。", "次", "第５５条第３７号第３５回第３９回第４１号４１第４２期第４８話第１４話第４５回東北区第４６", "４６", "話"]}, {"box": [201, 912, 448, 965], "vertical": false, "font_size": 25.0, "lines_coords": [[[201.0, 915.0], [306.0, 912.0], [306.0, 940.0], [201.0, 943.0]], [[206.0, 943.0], [448.0, 943.0], [448.0, 965.0], [206.0, 965.0]]], "lines": ["東海関", "プンプンの同級生。すぐ怒る。"]}, {"box": [201, 1004, 487, 1059], "vertical": false, "font_size": 28.0, "lines_coords": [[[203.0, 1004.0], [257.0, 1004.0], [257.0, 1034.0], [203.0, 1034.0]], [[201.0, 1031.0], [487.0, 1032.0], [487.0, 1059.0], [201.0, 1057.0]]], "lines": ["清水", "プンプンの同級生。すぐ怒られる。"]}, {"box": [201, 732, 634, 878], "vertical": false, "font_size": 27.2, "lines_coords": [[[201.0, 732.0], [304.0, 732.0], [304.0, 760.0], [201.0, 760.0]], [[204.0, 760.0], [385.0, 760.0], [385.0, 787.0], [204.0, 787.0]], [[204.0, 787.0], [581.0, 787.0], [581.0, 814.0], [204.0, 814.0]], [[204.0, 823.0], [351.0, 823.0], [351.0, 850.0], [204.0, 850.0]], [[204.0, 851.0], [634.0, 851.0], [634.0, 878.0], [204.0, 878.0]]], "lines": ["矢口先輩", "バドミントン部の先輩。", "チャンコが超でかいと下級生に噂されている。", "小松っちゃん", "プンプンのクラスメイト。パドミントン部の赤い彗星。"]}, {"box": [203, 1096, 650, 1150], "vertical": false, "font_size": 28.5, "lines_coords": [[[203.0, 1096.0], [256.0, 1096.0], [256.0, 1126.0], [203.0, 1126.0]], [[226.0, 1123.0], [650.0, 1123.0], [650.0, 1150.0], [226.0, 1150.0]]], "lines": ["沼田", "ラスーのセクシーギャル。好きな食べものはコマ。"]}, {"box": [773, 1001, 1068, 1050], "vertical": false, "font_size": 49, "lines_coords": [[[773.0, 1001.0], [1068.0, 1001.0], [1068.0, 1050.0], [773.0, 1050.0]]], "lines": ["３巻までのあらすじ"]}, {"box": [778, 1067, 964, 1125], "vertical": false, "font_size": 22.0, "lines_coords": [[[779.0, 1067.0], [964.0, 1067.0], [964.0, 1089.0], [779.0, 1089.0]], [[778.0, 1103.0], [962.0, 1103.0], [962.0, 1125.0], [778.0, 1125.0]]], "lines": ["ごく普通の中学生、", "小野寺プンプンは、"]}, {"box": [776, 1131, 1004, 1200], "vertical": false, "font_size": 29.0, "lines_coords": [[[776.0, 1134.0], [1004.0, 1131.0], [1004.0, 1162.0], [776.0, 1165.0]], [[778.0, 1173.0], [970.0, 1173.0], [970.0, 1200.0], [778.0, 1200.0]]], "lines": ["片想い（？）の女の子・", "田中愛子を巡って、"]}, {"box": [231, 1215, 604, 1237], "vertical": false, "font_size": 22, "lines_coords": [[[231.0, 1215.0], [604.0, 1215.0], [604.0, 1237.0], [231.0, 1237.0]]], "lines": ["・一が五年前に働いていた陶芸教室の生徒。"]}, {"box": [201, 1273, 743, 1331], "vertical": false, "font_size": 29.0, "lines_coords": [[[201.0, 1273.0], [435.0, 1273.0], [435.0, 1306.0], [201.0, 1306.0]], [[203.0, 1306.0], [743.0, 1303.0], [743.0, 1328.0], [203.0, 1331.0]]], "lines": ["おかっばの女子高生．．．", "八木の娘。母親に軟禁されていふと言い、雄一に助けを求める。"]}, {"box": [206, 1398, 687, 1420], "vertical": false, "font_size": 22, "lines_coords": [[[206.0, 1398.0], [687.0, 1398.0], [687.0, 1420.0], [206.0, 1420.0]]], "lines": ["雄一の陶芸教室講師時代の同僚。陶芸界期待の新人。"]}, {"box": [204, 1456, 673, 1510], "vertical": false, "font_size": 24.0, "lines_coords": [[[204.0, 1456.0], [356.0, 1456.0], [356.0, 1482.0], [204.0, 1482.0]], [[206.0, 1489.0], [673.0, 1485.0], [673.0, 1507.0], [206.0, 1510.0]]], "lines": ["雄一の元カノ", "酒好きで悪口が多い以外は、概ね親切で優しい女性。"]}, {"box": [779, 1210, 982, 1232], "vertical": false, "font_size": 22, "lines_coords": [[[779.0, 1210.0], [982.0, 1210.0], [982.0, 1232.0], [779.0, 1232.0]]], "lines": ["部活の先輩と無謀な"]}, {"box": [776, 1242, 1026, 1417], "vertical": false, "font_size": 27.8, "lines_coords": [[[776.0, 1242.0], [960.0, 1242.0], [960.0, 1275.0], [776.0, 1275.0]], [[779.0, 1281.0], [993.0, 1281.0], [993.0, 1307.0], [779.0, 1307.0]], [[778.0, 1317.0], [1026.0, 1317.0], [1026.0, 1343.0], [778.0, 1343.0]], [[776.0, 1354.0], [943.0, 1351.0], [943.0, 1378.0], [776.0, 1381.0]], [[778.0, 1390.0], [943.0, 1390.0], [943.0, 1417.0], [778.0, 1417.0]]], "lines": ["勝負をすることに。", "一方、叔父の雄一は、", "気になるフリーター女子、", "大隈翠に過去を", "打ち明け始める。"]}], "img_path": "005.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [23, 289, 70, 454], "vertical": true, "font_size": 45, "lines_coords": [[[23.0, 292.0], [68.0, 292.0], [68.0, 454.0], [23.0, 454.0]]], "lines": ["第３５話"]}, {"box": [873, 632, 895, 785], "vertical": true, "font_size": 25, "lines_coords": [[[873.0, 632.0], [895.0, 632.0], [895.0, 785.0], [873.0, 785.0]]], "lines": ["そのあと．．．"]}, {"box": [765, 785, 826, 945], "vertical": true, "font_size": 25, "lines_coords": [[[800.0, 785.0], [826.0, 785.0], [826.0, 945.0], [800.0, 945.0]], [[765.0, 785.0], [792.0, 785.0], [792.0, 945.0], [765.0, 945.0]]], "lines": ["どうなったん", "ですか．．．．．．？"]}, {"box": [770, 1285, 834, 1483], "vertical": true, "font_size": 28, "lines_coords": [[[801.0, 1285.0], [834.0, 1285.0], [834.0, 1396.0], [801.0, 1396.0]], [[771.0, 1290.0], [793.0, 1290.0], [793.0, 1479.0], [771.0, 1479.0]]], "lines": ["雨が．．．", "降ってきたんだ。"]}], "img_path": "006.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [609, 140, 718, 351], "vertical": true, "font_size": 32, "lines_coords": [[[687.0, 142.0], [714.0, 142.0], [714.0, 275.0], [687.0, 275.0]], [[646.0, 142.0], [678.0, 142.0], [678.0, 351.0], [646.0, 351.0]], [[609.0, 140.0], [645.0, 140.0], [645.0, 207.0], [609.0, 207.0]]], "lines": ["：瞬く間に", "勢いを増してゆく", "雨は、"]}, {"box": [414, 143, 551, 324], "vertical": true, "font_size": 25, "lines_coords": [[[526.0, 145.0], [548.0, 145.0], [548.0, 271.0], [526.0, 271.0]], [[490.0, 145.0], [512.0, 145.0], [512.0, 323.0], [490.0, 323.0]], [[4