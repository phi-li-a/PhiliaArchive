, "lines": ["フンフンは"]}, {"box": [409, 1337, 443, 1431], "vertical": true, "font_size": 29, "lines_coords": [[[409.0, 1337.0], [443.0, 1337.0], [443.0, 1431.0], [409.0, 1431.0]]], "lines": ["その時、"]}, {"box": [378, 1342, 404, 1473], "vertical": true, "font_size": 27, "lines_coords": [[[378.0, 1342.0], [404.0, 1342.0], [404.0, 1473.0], [378.0, 1473.0]]], "lines": ["図らずも！！"]}], "img_path": "138.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [506, 911, 560, 1112], "vertical": true, "font_size": 54, "lines_coords": [[[506.0, 912.0], [560.0, 912.0], [560.0, 1112.0], [506.0, 1112.0]]], "lines": ["大興奮！！"]}], "img_path": "139.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [939, 56, 970, 214], "vertical": true, "font_size": 30, "lines_coords": [[[939.0, 56.0], [970.0, 56.0], [970.0, 214.0], [939.0, 214.0]]], "lines": ["プンプンは．．．"]}, {"box": [828, 115, 895, 246], "vertical": true, "font_size": 30, "lines_coords": [[[865.0, 115.0], [893.0, 115.0], [895.0, 246.0], [867.0, 246.0]], [[828.0, 117.0], [860.0, 117.0], [860.0, 206.0], [828.0, 206.0]]], "lines": ["好きな人の", "ために、"]}, {"box": [339, 134, 367, 268], "vertical": true, "font_size": 26, "lines_coords": [[[339.0, 135.0], [365.0, 135.0], [365.0, 265.0], [339.0, 265.0]]], "lines": ["なんて．．．"]}, {"box": [65, 210, 198, 373], "vertical": true, "font_size": 29, "lines_coords": [[[168.0, 215.0], [195.0, 215.0], [195.0, 373.0], [168.0, 373.0]], [[134.0, 215.0], [160.0, 215.0], [160.0, 356.0], [134.0, 356.0]], [[100.0, 215.0], [128.0, 215.0], [129.0, 346.0], [101.0, 346.0]], [[65.0, 212.0], [98.0, 210.0], [101.0, 306.0], [68.0, 307.0]]], "lines": ["プンプンには", "無理だよね、", "いくじなし", "だもん。"]}, {"box": [579, 521, 717, 715], "vertical": true, "font_size": 28, "lines_coords": [[[685.0, 521.0], [717.0, 521.0], [714.0, 714.0], [682.0, 714.0]], [[651.0, 525.0], [678.0, 525.0], [678.0, 709.0], [651.0, 709.0]], [[615.0, 525.0], [642.0, 525.0], [642.0, 659.0], [615.0, 659.0]], [[579.0, 526.0], [606.0, 526.0], [606.0, 682.0], [579.0, 682.0]]], "lines": ["家族とか夢とか、", "自分の持ってる", "ものを全部", "捨てられる？"]}, {"box": [304, 834, 331, 950], "vertical": true, "font_size": 25, "lines_coords": [[[304.0, 834.0], [331.0, 834.0], [331.0, 950.0], [304.0, 950.0]]], "lines": ["．．．でもね。"]}, {"box": [114, 878, 273, 1075], "vertical": true, "font_size": 25, "lines_coords": [[[243.0, 879.0], [271.0, 879.0], [273.0, 987.0], [245.0, 987.0]], [[210.0, 878.0], [237.0, 878.0], [237.0, 1075.0], [210.0, 1075.0]], [[179.0, 881.0], [201.0, 881.0], [201.0, 1037.0], [179.0, 1037.0]], [[143.0, 879.0], [170.0, 879.0], [170.0, 1045.0], [143.0, 1045.0]], [[114.0, 882.0], [135.0, 882.0], [135.0, 1021.0], [114.0, 1021.0]]], "lines": ["あたしは", "きっとできるよ。", "本当に好きな", "人のためなら、", "なんだって。"]}, {"box": [932, 1145, 962, 1303], "vertical": true, "font_size": 26, "lines_coords": [[[932.0, 1145.0], [959.0, 1145.0], [962.0, 1303.0], [935.0, 1303.0]]], "lines": ["あたしね．．．．．．"]}, {"box": [793, 1300, 893, 1459], "vertical": true, "font_size": 26, "lines_coords": [[[871.0, 1300.0], [893.0, 1300.0], [893.0, 1459.0], [871.0, 1459.0]], [[831.0, 1300.0], [859.0, 1300.0], [859.0, 1409.0], [831.0, 1409.0]], [[793.0, 1300.0], [820.0, 1300.0], [823.0, 1420.0], [796.0, 1420.0]]], "lines": ["何度も同度も", "同じ夢を", "見るんだ。"]}, {"box": [96, 1328, 204, 1518], "vertical": true, "font_size": 35, "lines_coords": [[[171.0, 1331.0], [204.0, 1331.0], [204.0, 1417.0], [171.0, 1417.0]], [[135.0, 1331.0], [167.0, 1331.0], [167.0, 1518.0], [135.0, 1518.0]], [[96.0, 1328.0], [135.0, 1328.0], [135.0, 1379.0], [96.0, 1379.0]]], "lines": ["誰かを", "ずっと待ってる", "夢。"]}], "img_path": "140.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [875, 95, 1010, 318], "vertical": true, "font_size": 27, "lines_coords": [[[984.0, 96.0], [1010.0, 96.0], [1010.0, 253.0], [984.0, 253.0]], [[945.0, 95.0], [976.0, 95.0], [976.0, 290.0], [945.0, 290.0]], [[910.0, 96.0], [937.0, 96.0], [937.0, 281.0], [910.0, 281.0]], [[875.0, 96.0], [901.0, 96.0], [901.0, 318.0], [875.0, 318.0]]], "lines": ["暗い闇の中の", "水辺のほとりで、", "あたしはずっと", "誰かを待ってるの。"]}, {"box": [765, 318, 865, 478], "vertical": true, "font_size": 27, "lines_coords": [[[839.0, 321.0], [865.0, 321.0], [865.0, 478.0], [839.0, 478.0]], [[800.0, 323.0], [828.0, 323.0], [828.0, 428.0], [800.0, 428.0]], [[765.0, 318.0], [793.0, 318.0], [795.0, 439.0], [767.0, 439.0]]], "lines": ["きっと何年も", "何十年も", "ずっとね。"]}, {"box": [303, 159, 420, 417], "vertical": true, "font_size": 26, "lines_coords": [[[393.0, 160.0], [420.0, 160.0], [420.0, 312.0], [393.0, 312.0]], [[360.0, 159.0], [387.0, 159.0], [389.0, 417.0], [362.0, 417.0]], [[331.0, 160.0], [357.0, 160.0], [357.0, 396.0], [331.0, 396.0]], [[303.0, 162.0], [325.0, 162.0], [325.0, 298.0], [303.0, 298.0]]], "lines": ["でも、ある時、", "あたしのことをじっと", "見てる人がいるのに", "気が付いて、"]}, {"box": [844, 655, 943, 889], "vertical": true, "font_size": 22, "lines_coords": [[[917.0, 656.0], [939.0, 656.0], [939.0, 876.0], [917.0, 876.0]], [[882.0, 656.0], [904.0, 656.0], [904.0, 889.0], [882.0, 889.0]], [[846.0, 657.0], [868.0, 657.0], [868.0, 873.0], [846.0, 873.0]]], "lines": ["．．．けど、よく見ると", "それはただ、水面に", "映ったあたしなの。"]}, {"box": [125, 323, 295, 568], "vertical": true, "font_size": 26, "lines_coords": [[[268.0, 323.0], [295.0, 323.0], [295.0, 543.0], [268.0, 543.0]], [[231.0, 323.0], [262.0, 323.0], [262.0, 568.0], [231.0, 568.0]], [[196.0, 323.0], [223.0, 323.0], [223.0, 559.0], [196.0, 559.0]], [[162.0, 323.0], [184.0, 323.0], [184.0, 557.0], [162.0, 557.0]], [[125.0, 323.0], [151.0, 323.0], [151.0, 493.0], [125.0, 493.0]]], "lines": ["全然見憶えの無い", "オバサンだったけど、", "あたしは嬉しくって", "足をひきずりながら、", "駆け寄るんだ。"]}, {"box": [278, 1007, 378, 1178], "vertical": true, "font_size": 30, "lines_coords": [[[351.0, 1007.0], [378.0, 1007.0], [378.0, 1178.0], [351.0, 1178.0]], [[314.0, 1007.0], [340.0, 1007.0], [340.0, 1164.0], [314.0, 1164.0]], [[278.0, 1007.0], [306.0, 1007.0], [306.0, 1137.0], [278.0, 1137.0]]], "lines": ["なんか、ひどく", "寂しい気分に", "なって．．．"]}, {"box": [150, 1078, 220, 1175], "vertical": true, "font_size": 30, "lines_coords": [[[178.0, 1078.0], [220.0, 1078.0], [220.0, 1143.0], [178.0, 1143.0]], [[150.0, 1084.0], [178.0, 1084.0], [178.0, 1175.0], [150.0, 1175.0]]], "lines": ["目が", "覚める。"]}, {"box": [834, 1278, 959, 1521], "vertical": true, "font_size": 26, "lines_coords": [[[932.0, 1278.0], [959.0, 1278.0], [959.0, 1435.0], [932.0, 1435.0]], [[900.0, 1278.0], [926.0, 1278.0], [926.0, 1409.0], [900.0, 1409.0]], [[865.0, 1278.0], [892.0, 1278.0], [892.0, 1521.0], [865.0, 1521.0]], [[834.0, 1281.0], [856.0, 1281.0], [856.0, 1440.0], [834.0, 1440.0]]], "lines": ["死ぬ瞬間って", "こんな風に", "ひとりぼっちなのかな", "．．．って思うと、"]}, {"box": [709, 1362, 771, 1531], "vertical": true, "font_size": 26, "lines_coords": [[[743.0, 1362.0], [771.0, 1362.0], [771.0, 1468.0], [743.0, 1468.0]], [[709.0, 1362.0], [735.0, 1362.0], [735.0, 1531.0], [709.0, 1531.0]]], "lines": ["気持ちが", "真っ暗になる。"]}], "img_path": "141.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [962, 120, 989, 278], "vertical": true, "font_size": 27, "lines_coords": [[[962.0, 120.0], [989.0, 120.0], [989.0, 278.0], [962.0, 278.0]]], "lines": ["．．．憶えてる？"]}, {"box": [840, 209, 907, 368], "vertical": true, "font_size": 27, "lines_coords": [[[881.0, 209.0], [907.0, 209.0], [907.0, 368.0], [881.0, 368.0]], [[843.0, 209.0], [871.0, 209.0], [868.0, 350.0], [840.0, 350.0]]], "lines": ["小学校の時に", "書いた作文。"]}, {"box": [246, 81, 367, 339], "vertical": true, "font_size": 27, "lines_coords": [[[337.0, 81.0], [364.0, 81.0], [367.0, 248.0], [340.0, 248.0]], [[304.0, 81.0], [335.0, 81.0], [335.0, 264.0], [304.0, 264.0]], [[275.0, 81.0], [301.0, 81.0], [303.0, 339.0], [276.0, 339.0]], [[246.0, 84.0], [268.0, 84.0], [268.0, 223.0], [246.0, 223.0]]], "lines": ["あたしは将来、", "女優か、歌手か、", "モデルになりたいって", "書いたんだ。"]}, {"box": [84, 217, 242, 453], "vertical": true, "font_size": 27, "lines_coords": [[[215.0, 221.0], [242.0, 221.0], [242.0, 337.0], [215.0, 337.0]], [[184.0, 221.0], [210.0, 221.0], [210.0, 406.0], [184.0, 406.0]], [[153.0, 221.0], [179.0, 221.0], [179.0, 453.0], [153.0, 453.0]], [[121.0, 221.0], [143.0, 221.0], [143.0, 429.0], [121.0, 429.0]], [[87.0, 217.0], [123.0, 218.0], [120.0, 290.0], [84.0, 289.0]]], "lines": ["．．．たぶん、", "たくさんの人に", "自分のことを知って", "ほしかったんだと", "思う。"]}, {"box": [326, 532, 395, 656], "vertical": true, "font_size": 34, "lines_coords": [[[367.0, 535.0], [395.0, 535.0], [395.0, 656.0], [367.0, 656.0]], [[326.0, 532.0], [362.0, 532.0], [362.0, 606.0], [326.0, 606.0]]], "lines": ["けど、今は", "違う。"]}, {"box": [195, 585, 268, 721], "vertical": true, "font_size": 34, "lines_coords": [[[232.0, 589.0], [265.0, 589.0], [268.0, 721.0], [235.0, 721.0]], [[195.0, 585.0], [235.0, 585.0], [235.0, 662.0], [195.0, 662.0]]], "lines": ["一人だけで", "いい。"]}, {"box": [896, 812, 968, 1003], "vertical": true, "font_size": 30, "lines_coords": [[[932.0, 812.0], [968.0, 814.0], [965.0, 898.0], [929.0, 896.0]], [[900.0, 818.0], [928.0, 818.0], [925.0, 1003.0], [896.0, 1003.0]]], "lines": ["たった", "一人でいいから、"]}, {"box": [751, 856, 853, 1093], "vertical": true, "font_size": 30, "lines_coords": [[[826.0, 859.0], [853.0, 859.0], [853.0, 1067.0], [826.0, 1067.0]], [[792.0, 860.0], [818.0, 860.0], [818.0, 1093.0], [792.0, 1093.0]], [[754.0, 856.0], [785.0, 856.0], [782.0, 1093.0], [751.0, 1093.0]]], "lines": ["頭のてっぺんから", "つま先まで１ミリの", "間違いも無いくらい"]}, {"box": [182, 896, 251, 1094], "vertical": true, "font_size": 30, "lines_coords": [[[217.0, 896.0], [251.0, 896.0], [251.0, 981.0], [217.0, 981.0]], [[182.0, 896.0], [209.0, 896.0], [212.0, 1092.0], [185.0, 1092.0]]], "lines": ["完全に", "わかり合いたい。"]}, {"box": [859, 1253, 959, 1395], "vertical": true, "font_size": 27, "lines_coords": [[[932.0, 1254.0], [959.0, 1254.0], [959.0, 1362.0], [932.0, 1362.0]], [[896.0, 1256.0], [923.0, 1256.0], [923.0, 1387.0], [896.0, 1387.0]], [[859.0, 1253.0], [885.0, 1253.0], [889.0, 1393.0], [862.0, 1393.0]]], "lines": ["その人と", "二人きりに", "なれるなら、"]}, {"box": [115, 1353, 181, 1522], "vertical": true, "font_size": 28, "lines_coords": [[[146.0, 1353.0], [181.0, 1353.0], [181.0, 1439.0], [146.0, 1439.0]], [[115.0, 1357.0], [137.0, 1357.0], [137.0, 1521.0], [115.0, 1521.0]]], "lines": ["他には", "何もいらない。"]}], "img_path": "142.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [853, 151, 956, 286], "vertical": true, "font_size": 30, "lines_coords": [[[929.0, 153.0], [956.0, 153.0], [956.0, 284.0], [929.0, 284.0]], [[890.0, 154.0], [918.0, 154.0], [918.0, 285.0], [890.0, 285.0]], [[853.0, 151.0], [887.0, 151.0], [887.0, 221.0], [853.0, 221.0]]], "lines": ["もし、その", "夢がかなう", "なら、"]}, {"box": [337, 523, 721, 754], "vertical": false, "font_size": 254, "lines_coords": [[[337.0, 500.0], [721.0, 500.0], [721.0, 777.0], [337.0, 777.0]]], "lines": ["．．．"]}, {"box": [151, 483, 253, 653], "vertical": true, "font_size": 25, "lines_coords": [[[225.0, 484.0], [251.0, 484.0], [251.0, 590.0], [225.0, 590.0]], [[190.0, 484.0], [212.0, 484.0], [212.0, 614.0], [190.0, 614.0]], [[151.0, 484.0], [178.0, 484.0], [178.0, 651.0], [151.0, 651.0]]], "lines": ["あたしは", "その瞬間に", "死んでもいい。"]}, {"box": [862, 817, 925, 1004], "vertical": true, "font_size": 57, "lines_coords": [[[868.0, 817.0], [925.0, 818.0], [918.0, 1004.0], [862.0, 1003.0]]], "lines": ["っ．．．！！"]}, {"box": [715, 1095, 922, 1409], "vertical": true, "font_size": 207, "lines_coords": [[[715.0, 1095.0], [922.0, 1095.0], [922.0, 1409.0], [715.0, 1409.0]]], "lines": ["．．．"]}, {"box": [89, 1354, 168, 1564], "vertical": true, "font_size": 79, "lines_coords": [[[89.0, 1354.0], [168.0, 1354.0], [168.0, 1564.0], [89.0, 1564.0]]], "lines": ["だぉ！！"]}], "img_path": "143.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [939, 137, 1007, 245], "vertical": true, "font_size": 28, "lines_coords": [[[973.0, 137.0], [1007.0, 137.0], [1007.0, 232.0], [973.0, 232.0]], [[939.0, 140.0], [967.0, 140.0], [967.0, 245.0], [939.0, 245.0]]], "lines": ["．．．矢口、", "大丈夫か"]}, {"box": [906, 195, 928, 243], "vertical": true, "font_size": 28, "lines_coords": [[[906.0, 195.0], [928.0, 195.0], [928.0, 243.0], [906.0, 243.0]]], "lines": ["！？"]}, {"box": [95, 62, 378, 84], "vertical": false, "font_size": 22, "lines_coords": [[[95.0, 62.0], [378.0, 62.0], [378.0, 84.0], [95.0, 84.0]]], "lines": ["おやすみプンプンは"]}, {"box": [101, 177, 240, 400], "vertical": true, "font_size": 24, "lines_coords": [[[212.0, 178.0], [234.0, 178.0], [234.0, 385.0], [212.0, 385.0]], [[175.0, 178.0], [201.0, 178.0], [201.0, 400.0], [175.0, 400.0]], [[140.0, 178.0], [162.0, 178.0], [162.0, 362.0], [140.0, 362.0]], [[101.0, 178.0], [128.0, 178.0], [128.0, 398.0], [101.0, 398.0]]], "lines": ["負けても県大会の", "切符は確定なんだ。", "怪我でもしたら", "水の泡じゃないか。"]}, {"box": [685, 437, 810, 673], "vertical": true, "font_size": 26, "lines_coords": [[[782.0, 437.0], [809.0, 437.0], [807.0, 612.0], [781.0, 612.0]], [[750.0, 439.0], [776.0, 439.0], [776.0, 673.0], [750.0, 673.0]], [[717.0, 440.0], [743.0, 440.0], [740.0, 596.0], [714.0, 596.0]], [[685.0, 440.0], [712.0, 440.0], [712.0, 582.0], [685.0, 582.0]]], "lines": ["どうも、右足を", "かばってるようだが", "調子悪いなら", "無理するな。"]}, {"box": [506, 437, 618, 593], "vertical": true, "font_size": 24, "lines_coords": [[[592.0, 437.0], [618.0, 437.0], [618.0, 539.0], [592.0, 539.0]], [[560.0, 437.0], [587.0, 437.0], [587.0, 593.0], [560.0, 593.0]], [[534.0, 439.0], [556.0, 439.0], [556.0, 581.0], [534.0, 581.0]], [[506.0, 437.0], [528.0, 437.0], [528.0, 592.0], [506.0, 592.0]]], "lines": ["やべーな、", "先輩、ポイント", "追いつかれて", "きてんじゃん。"]}, {"box": [318, 592, 428, 648], "vertical": false, "font_size": 24, "lines_coords": [[[326.0, 592.0], [428.0, 626.0], [421.0, 648.0], [318.0, 615.0]]], "lines": ["．．．"]}, {"box": [908, 735, 942, 932], "vertical": true, "font_size": 31, "lines_coords": [[[909.0, 735.0], [940.0, 735.0], [940.0, 925.0], [909.0, 925.0]]], "lines": ["．．．ぜんっぜん"]}, {"box": [162, 836, 258, 989], "vertical": true, "font_size": 41, "lines_coords": [[[217.0, 839.0], [254.0, 839.0], [254.0, 989.0], [217.0, 989.0]], [[162.0, 837.0], [207.0, 837.0], [207.0, 954.0], [162.0, 954.0]]], "lines": ["．．．大丈夫", "です！！"]}, {"box": [898, 1114, 959, 1310], "vertical": true, "font_size": 27, "lines_coords": [[[932.0, 1114.0], [959.0, 1114.0], [959.0, 1310.0], [932.0, 1310.0]], [[898.0, 1115.0], [925.0, 1115.0], [925.0, 1281.0], [898.0, 1281.0]]], "lines": ["昨日、あの人から", "電話があって、"]}, {"box": [739, 1245, 873, 1492], "vertical": true, "font_size": 27, "lines_coords": [[[851.0, 1248.0], [873.0, 1248.0], [873.0, 1378.0], [851.0, 1378.0]], [[810.0, 1245.0], [842.0, 1245.0], [842.0, 1492.0], [810.0, 1492.0]], [[776.0, 1248.0], [803.0, 1248.0], [803.0, 1459.0], [776.0, 1459.0]], [[739.0, 1246.0], [765.0, 1246.0], [765.0, 1418.0], [739.0, 1418.0]]], "lines": ["試合の後に", "大事な話があるから、", "必ず観に来いって", "言われたんだ。"]}, {"box": [94, 1287, 228, 1550], "vertical": true, "font_size": 25, "lines_coords": [[[201.0, 1287.0], [228.0, 1287.0], [226.0, 1531.0], [200.0, 1531.0]], [[162.0, 1289.0], [193.0, 1289.0], [193.0, 1537.0], [162.0, 1537.0]], [[129.0, 1290.0], [151.0, 1290.0], [151.0, 1548.0], [129.0, 1548.0]], [[95.0, 1290.0], [117.0, 1290.0], [117.0, 1509.0], [95.0, 1509.0]]], "lines": ["よくわかんないけど、", "何勝手に盛り上がっ", "てんのかなって思って", "なんかイヤだった。"]}], "img_path": "144.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [915, 148, 1017, 335], "vertical": true, "font_size": 29, "lines_coords": [[[981.0, 150.0], [1014.0, 148.0], [1017.0, 242.0], [984.0, 243.0]], [[948.0, 150.0], [975.0, 150.0], [978.0, 335.0], [951.0, 335.0]], [[915.0, 151.0], [942.0, 151.0], [942.0, 295.0], [915.0, 295.0]]], "lines": ["だから、", "あたしも言って", "やったんだ。"]}, {"box": [301, 221, 401, 356], "vertical": true, "font_size": 28, "lines_coords": [[[375.0, 223.0], [401.0, 223.0], [401.0, 356.0], [375.0, 356.0]], [[337.0, 221.0], [364.0, 221.0], [364.0, 354.0], [337.0, 354.0]], [[301.0, 223.0], [328.0, 223.0], [328.0, 334.0], [301.0, 334.0]]], "lines": ["試合なんて", "行かなくて", "いいから、"]}, {"box": [835, 662, 940, 877], "vertical": true, "font_size": 28, "lines_coords": [[[912.0, 662.0], [940.0, 662.0], [940.0, 782.0], [912.0, 782.0]], [[873.0, 665.0], [900.0, 665.0], [900.0, 875.0], [873.0, 875.0]], [[839.0, 667.0], [867.0, 667.0], [864.0, 846.0], [835.0, 846.0]]], "lines": ["．．．あの人、", "「意味わかんねー」", "って、笑ってた。"]}, {"box": [190, 360, 259, 560], "vertical": true, "font_size": 28, "lines_coords": [[[228.0, 360.0], [259.0, 360.0], [259.0, 560.0], [228.0, 560.0]], [[190.0, 362.0], [221.0, 362.0], [221.0, 520.0], [190.0, 520.0]]], "lines": ["「二人で駆け落ち", "しよう」って。"]}, {"box": [234, 990, 350, 1140], "vertical": true, "font_size": 26, "lines_coords": [[[317.0, 990.0], [350.0, 990.0], [350.0, 1078.0], [317.0, 1078.0]], [[292.0, 993.0], [318.0, 993.0], [318.0, 1114.0], [292.0, 1114.0]], [[262.0, 993.0], [289.0, 993.0], [289.0, 1114.0], [262.0, 1114.0]], [[234.0, 992.0], [256.0, 992.0], [256.0, 1140.0], [234.0, 1140.0]]], "lines": ["．．．田中、", "さっきから", "何ブツブツ", "言ってんだよ。"]}, {"box": [101, 1020, 212, 1190], "vertical": true, "font_size": 26, "lines_coords": [[[185.0, 1020.0], [212.0, 1020.0], [212.0, 1121.0], [185.0, 1121.0]], [[154.0, 1023.0], [182.0, 1023.0], [182.0, 1128.0], [154.0, 1128.0]], [[126.0, 1023.0], [153.0, 1023.0], [153.0, 1146.0], [126.0, 1146.0]], [[101.0, 1025.0], [121.0, 1025.0], [121.0, 1190.0], [101.0, 1190.0]]], "lines": ["ちゃんと", "見とけよ、", "超いい試合", "なんだからさ！！"]}, {"box": [923, 1306, 987, 1527], "vertical": true, "font_size": 26, "lines_coords": [[[959.0, 1306.0], [985.0, 1306.0], [985.0, 1478.0], [959.0, 1478.0]], [[923.0, 1307.0], [950.0, 1307.0], [950.0, 1526.0], [923.0, 1526.0]]], "lines": ["それで、やっと", "はっきりわかった。"]}, {"box": [637, 1225, 664, 1384], "vertical": true, "font_size": 27, "lines_coords": [[[637.0, 1226.0], [664.0, 1226.0], [664.0, 1384.0], [637.0, 1384.0]]], "lines": ["違うな、って。"]}, {"box": [332, 1389, 402, 1523], "vertical": true, "font_size": 32, "lines_coords": [[[373.0, 1392.0], [400.0, 1392.0], [400.0, 1523.0], [373.0, 1523.0]], [[332.0, 1389.0], [368.0, 1389.0], [368.0, 1460.0], [332.0, 1460.0]]], "lines": ["住む世界が", "全然。"]}, {"box": [201, 1287, 229, 1523], "vertical": true, "font_size": 26, "lines_coords": [[[201.0, 1287.0], [228.0, 1287.0], [229.0, 1520.0], [203.0, 1520.0]]], "lines": ["「愛子ちゃんは．．．"]}], "img_path": "145.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [934, 98, 1001, 185], "vertical": true, "font_size": 34, "lines_coords": [[[967.0, 101.0], [1001.0, 101.0], [1001.0, 185.0], [967.0, 185.0]], [[934.0, 98.0], [968.0, 98.0], [968.0, 162.0], [934.0, 162.0]]], "lines": ["あたし", "．．．"]}, {"box": [467, 64, 610, 298], "vertical": true, "font_size": 32, "lines_coords": [[[581.0, 65.0], [607.0, 65.0], [607.0, 212.0], [581.0, 212.0]], [[537.0, 64.0], [578.0, 64.0], [578.0, 154.0], [537.0, 154.0]], [[504.0, 64.0], [535.0, 64.0], [534.0, 298.0], [503.0, 298.0]], [[470.0, 64.0], [498.0, 64.0], [495.0, 235.0], [467.0, 235.0]]], "lines": ["「愛子ちゃん、", "つーか、", "愛子ちゃんの気持ち", "つーのは．．．．．．"]}, {"box": [381, 294, 408, 403], "vertical": true, "font_size": 26, "lines_coords": [[[381.0, 295.0], [407.0, 295.0], [407.0, 403.0], [381.0, 403.0]]], "lines": ["ううん．．．"]}, {"box": [682, 517, 781, 648], "vertical": true, "font_size": 27, "lines_coords": [[[753.0, 517.0], [781.0, 517.0], [781.0, 621.0], [753.0, 621.0]], [[718.0, 517.0], [745.0, 517.0], [745.0, 648.0], [718.0, 648.0]], [[682.0, 517.0], [707.0, 517.0], [707.0, 596.0], [682.0, 596.0]]], "lines": ["変なこと", "言ってると", "思う？"]}, {"box": [79, 431, 185, 620], "vertical": true, "font_size": 31, "lines_coords": [[[156.0, 434.0], [182.0, 434.0], [182.0, 567.0], [156.0, 567.0]], [[117.0, 432.0], [148.0, 432.0], [148.0, 620.0], [117.0, 620.0]], [[79.0, 431.0], [114.0, 431.0], [114.0, 503.0], [79.0, 503.0]]], "lines": ["プンプンは", "わかってくれる", "よね。"]}, {"box": [731, 1271, 831, 1489], "vertical": true, "font_size": 27, "lines_coords": [[[803.0, 1273.0], [831.0, 1273.0], [831.0, 1390.0], [803.0, 1390.0]], [[767.0, 1271.0], [793.0, 1271.0], [795.0, 1481.0], [768.0, 1481.0]], [[731.0, 1273.0], [757.0, 1273.0], [757.0, 1485.0], [731.0, 1485.0]]], "lines": ["「あの日の", "あの市民ホールの", "待ち合わせ場所で"]}, {"box": [542, 1274, 680, 1481], "vertical": true, "font_size": 26, "lines_coords": [[[653.0, 1275.0], [679.0, 1275.0], [679.0, 1404.0], [653.0, 1404.0]], [[615.0, 1275.0], [642.0, 1275.0], [642.0, 1404.0], [615.0, 1404.0]], [[578.0, 1275.0], [604.0, 1275.0], [604.0, 1481.0], [578.0, 1481.0]], [[542.0, 1275.0], [568.0, 1275.0], [568.0, 1435.0], [542.0, 1435.0]]], "lines": ["鹿児島まで", "行くための", "おっきいカハンを", "肩からさけて、"]}, {"box": [468, 1275, 495, 1387], "vertical": true, "font_size": 27, "lines_coords": [[[468.0, 1275.0], [495.0, 1275.0], [495.0, 1382.0], [468.0, 1382.0]]], "lines": ["今もまだ"]}, {"box": [265, 1271, 407, 1485], "vertical": true, "font_size": 31, "lines_coords": [[[375.0, 1271.0], [407.0, 1271.0], [407.0, 1356.0], [375.0, 1356.0]], [[342.0, 1275.0], [368.0, 1275.0], [368.0, 1484.0], [342.0, 1484.0]], [[303.0, 1273.0], [334.0, 1273.0], [334.0, 1485.0], [303.0, 1485.0]], [[265.0, 1273.0], [300.0, 1273.0], [300.0, 1368.0], [265.0, 1368.0]]], "lines": ["誰かが", "むかえに来るのを", "待ってるのだろう", "か．．．．．．"]}], "img_path": "146.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [325, 231, 768, 453], "vertical": false, "font_size": 179, "lines_coords": [[[343.0, 231.0], [768.0, 275.0], [750.0, 453.0], [325.0, 409.0]]], "lines": ["この"]}, {"box": [608, 729, 672, 895], "vertical": true, "font_size": 25, "lines_coords": [[[642.0, 729.0], [670.0, 729.0], [670.0, 835.0], [642.0, 835.0]], [[609.0, 732.0], [631.0, 732.0], [631.0, 890.0], [609.0, 890.0]]], "lines": ["神様神様", "チンクルホイ"]}, {"box": [468, 728, 532, 898], "vertical": true, "font_size": 24, "lines_coords": [[[509.0, 729.0], [531.0, 729.0], [531.0, 859.0], [509.0, 859.0]], [[468.0, 728.0], [495.0, 728.0], [496.0, 896.0], [470.0, 896.0]]], "lines": ["と唱えると", "神様が来ます。"]}, {"box": [835, 1448, 950, 1473], "vertical": false, "font_size": 22, "lines_coords": [[[835.0, 1451.0], [950.0, 1448.0], [950.0, 1470.0], [835.0, 1473.0]]], "lines": ["．．．"]}, {"box": [781, 1426, 926, 1445], "vertical": false, "font_size": 17, "lines_coords": [[[781.0, 1426.0], [926.0, 1428.0], [926.0, 1445.0], [781.0, 1443.0]]], "lines": ["お客様からお"]}, {"box": [542, 1126, 642, 1294], "vertical": true, "font_size": 25, "lines_coords": [[[614.0, 1126.0], [640.0, 1126.0], [640.0, 1232.0], [614.0, 1232.0]], [[576.0, 1128.0], [603.0, 1128.0], [603.0, 1284.0], [576.0, 1284.0]], [[543.0, 1129.0], [565.0, 1129.0], [565.0, 1290.0], [543.0, 1290.0]]], "lines": ["この頃は", "呼ばなくても", "勝手に来ます。"]}, {"box": [150, 1112, 253, 1403], "vertical": true, "font_size": 25, "lines_coords": [[[226.0, 1115.0], [250.0, 1115.0], [248.0, 1375.0], [225.0, 1375.0]], [[189.0, 1115.0], [215.0, 1115.0], [215.0, 1400.0], [189.0, 1400.0]], [[151.0, 1114.0], [178.0, 1114.0], [176.0, 1298.0], [150.0, 1298.0]]], "lines": ["今、愛子ちゃんの手を", "ンッ！！グゥキュッ！？と", "握り返せは．．．："]}], "img_path": "147.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [803, 32, 946, 271], "vertical": true, "font_size": 103, "lines_coords": [[[803.0, 53.0], [904.0, 32.0], [946.0, 251.0], [845.0, 271.0]]], "lines": ["ヨヨ、"]}, {"box": [687, 143, 707, 450], "vertical": true, "font_size": 21, "lines_coords": [[[687.0, 143.0], [707.0, 143.0], [707.0, 450.0], [687.0, 450.0]]], "lines": ["約束を守れなかったことを"]}, {"box": [650, 167, 673, 484], "vertical": true, "font_size": 21, "lines_coords": [[[650.0, 167.0], [671.0, 167.0], [673.0, 484.0], [651.0, 484.0]]], "lines": ["許してくれるかもしれない"]}, {"box": [356, -1, 529, 259], "vertical": true, "font_size": 173, "lines_coords": [[[356.0, -1.0], [529.0, -1.0], [529.0, 259.0], [356.0, 259.0]]], "lines": ["ふイ！！"]}, {"box": [275, 100, 295, 334], "vertical": true, "font_size": 20, "lines_coords": [[[275.0, 100.0], [295.0, 100.0], [295.0, 334.0], [275.0, 334.0]]], "lines": ["むしろチッスしたり"]}, {"box": [215, 178, 237, 409],