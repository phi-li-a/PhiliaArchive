5.0], [228.0, 1025.0], [228.0, 1156.0], [201.0, 1156.0]], [[164.0, 1023.0], [192.0, 1023.0], [192.0, 1117.0], [164.0, 1117.0]]], "lines": ["話を聞いて", "くれて。"]}, {"box": [848, 1342, 949, 1476], "vertical": true, "font_size": 27, "lines_coords": [[[921.0, 1343.0], [948.0, 1343.0], [948.0, 1476.0], [921.0, 1476.0]], [[884.0, 1343.0], [912.0, 1343.0], [912.0, 1450.0], [884.0, 1450.0]], [[848.0, 1342.0], [875.0, 1342.0], [875.0, 1450.0], [848.0, 1450.0]]], "lines": ["なんだか．．．", "少し楽に", "なった！！"]}], "img_path": "085.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [601, 69, 625, 226], "vertical": true, "font_size": 20, "lines_coords": [[[603.0, 70.0], [623.0, 70.0], [623.0, 223.0], [603.0, 223.0]]], "lines": ["．．．というのは"]}, {"box": [482, 72, 509, 131], "vertical": true, "font_size": 22, "lines_coords": [[[484.0, 73.0], [506.0, 73.0], [506.0, 126.0], [484.0, 126.0]]], "lines": ["嘘だ"]}, {"box": [778, 362, 980, 638], "vertical": true, "font_size": 46, "lines_coords": [[[932.0, 365.0], [976.0, 365.0], [976.0, 575.0], [932.0, 575.0]], [[879.0, 362.0], [928.0, 362.0], [928.0, 634.0], [879.0, 634.0]], [[832.0, 365.0], [875.0, 365.0], [875.0, 632.0], [832.0, 632.0]], [[778.0, 365.0], [828.0, 365.0], [828.0, 575.0], [778.0, 575.0]]], "lines": ["五年もの間、", "僕の背中に重く", "まとわりついて", "いたものは、"]}, {"box": [110, 359, 316, 667], "vertical": true, "font_size": 46, "lines_coords": [[[267.0, 367.0], [312.0, 367.0], [312.0, 498.0], [267.0, 498.0]], [[212.0, 364.0], [262.0, 364.0], [262.0, 593.0], [212.0, 593.0]], [[167.0, 367.0], [210.0, 367.0], [210.0, 667.0], [167.0, 667.0]], [[110.0, 365.0], [156.0, 364.0], [160.0, 576.0], [115.0, 578.0]]], "lines": ["過去の", "あやまちへの", "罪悪感だったのは", "間違い無い。"]}, {"box": [826, 839, 982, 1114], "vertical": true, "font_size": 49, "lines_coords": [[[926.0, 843.0], [973.0, 840.0], [982.0, 1017.0], [935.0, 1020.0]], [[875.0, 839.0], [929.0, 839.0], [929.0, 1114.0], [875.0, 1114.0]], [[826.0, 843.0], [871.0, 842.0], [876.0, 1009.0], [831.0, 1010.0]]], "lines": ["．．．けれど、", "幾ばくかの光が", "見えた今、"]}, {"box": [128, 835, 233, 1182], "vertical": true, "font_size": 52, "lines_coords": [[[185.0, 842.0], [229.0, 842.0], [229.0, 1181.0], [185.0, 1181.0]], [[128.0, 835.0], [187.0, 835.0], [187.0, 1098.0], [128.0, 1098.0]]], "lines": ["なぜか前にも増して", "重く、苦しい。"]}, {"box": [217, 1315, 282, 1475], "vertical": true, "font_size": 65, "lines_coords": [[[217.0, 1315.0], [282.0, 1315.0], [282.0, 1475.0], [217.0, 1475.0]]], "lines": ["．．．背筋が凍る思いだった。"]}, {"box": [217, 1317, 278, 1475], "vertical": true, "font_size": 26, "lines_coords": [[[251.0, 1317.0], [278.0, 1317.0], [278.0, 1475.0], [251.0, 1475.0]], [[217.0, 1320.0], [243.0, 1320.0], [243.0, 1459.0], [217.0, 1459.0]]], "lines": ["．．．背筋が凍る", "思いだった。"]}, {"box": [109, 1318, 170, 1481], "vertical": true, "font_size": 26, "lines_coords": [[[143.0, 1318.0], [170.0, 1318.0], [170.0, 1476.0], [143.0, 1476.0]], [[109.0, 1318.0], [131.0, 1318.0], [131.0, 1481.0], [109.0, 1481.0]]], "lines": ["僕は気付いて", "しまったんだ。"]}], "img_path": "086.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [442, 185, 649, 696], "vertical": true, "font_size": 65, "lines_coords": [[[579.0, 189.0], [643.0, 187.0], [648.0, 346.0], [584.0, 348.0]], [[507.0, 187.0], [578.0, 187.0], [578.0, 696.0], [507.0, 696.0]], [[442.0, 187.0], [501.0, 187.0], [506.0, 693.0], [446.0, 693.0]]], "lines": ["．．．僕は", "罪の意識という呪縛に", "生かされていた．．．！？"]}, {"box": [732, 903, 872, 1089], "vertical": true, "font_size": 29, "lines_coords": [[[843.0, 906.0], [871.0, 906.0], [868.0, 1087.0], [840.0, 1087.0]], [[806.0, 903.0], [839.0, 903.0], [835.0, 1015.0], [803.0, 1015.0]], [[770.0, 904.0], [796.0, 904.0], [793.0, 1062.0], [767.0, 1062.0]], [[732.0, 906.0], [760.0, 906.0], [760.0, 1010.0], [732.0, 1010.0]]], "lines": ["恐ろしいほどの", "罪悪感に", "身動きひとつ", "とれす！！"]}, {"box": [440, 903, 654, 1146], "vertical": true, "font_size": 28, "lines_coords": [[[625.0, 904.0], [653.0, 904.0], [654.0, 1100.0], [626.0, 