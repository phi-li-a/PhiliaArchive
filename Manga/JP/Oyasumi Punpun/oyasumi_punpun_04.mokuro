8.0], [150.0, 778.0]], [[117.0, 635.0], [139.0, 635.0], [139.0, 792.0], [117.0, 792.0]]], "lines": ["．．．そういえば", "先日来られた", "娘さん．．．何か", "言ってました？"]}, {"box": [868, 892, 992, 1098], "vertical": true, "font_size": 25, "lines_coords": [[[960.0, 892.0], [989.0, 892.0], [992.0, 1050.0], [964.0, 1050.0]], [[934.0, 893.0], [956.0, 893.0], [956.0, 1098.0], [934.0, 1098.0]], [[901.0, 893.0], [928.0, 893.0], [928.0, 1050.0], [901.0, 1050.0]], [[871.0, 892.0], [898.0, 892.0], [895.0, 993.0], [868.0, 993.0]]], "lines": ["：アラ、先週", "センセがお休みの", "時も来てたん", "ですよー"]}, {"box": [728, 1009, 853, 1167], "vertical": true, "font_size": 25, "lines_coords": [[[826.0, 1009.0], [853.0, 1009.0], [853.0, 1140.0], [826.0, 1140.0]], [[796.0, 1010.0], [818.0, 1010.0], [818.0, 1139.0], [796.0, 1139.0]], [[762.0, 1010.0], [784.0, 1010.0], [784.0, 1167.0], [762.0, 1167.0]], [[728.0, 1010.0], [754.0, 1010.0], [754.0, 1128.0], [728.0, 1128.0]]], "lines": ["今日もつい", "さっきまで", "そこにいたん", "ですけど。"]}, {"box": [178, 970, 279, 1154], "vertical": true, "font_size": 27, "lines_coords": [[[250.0, 996.0], [279.0, 996.0], [279.0, 1054.0], [250.0, 1054.0]], [[215.0, 970.0], [242.0, 970.0], [242.0, 1154.0], [215.0, 1154.0]], [[178.0, 971.0], [204.0, 971.0], [204.0, 1078.0], [178.0, 1078.0]]], "lines": ["．．．", "どこに行ったの", "かしら？"]}, {"box": [276, 1315, 304, 1396], "vertical": true, "font_size": 30, "lines_coords": [[[276.0, 1315.0], [304.0, 1315.0], [304.0, 1396.0], [276.0, 1396.0]]], "lines": ["．．．え？"]}, {"box": [150, 1403, 256, 1518], "vertical": true, "font_size": 30, "lines_coords": [[[220.0, 1403.0], [256.0, 1403.0], [256.0, 1479.0], [220.0, 1479.0]], [[185.0, 1410.0], [214.0, 1410.0], [214.0, 1518.0], [185.0, 1518.0]], [[150.0, 1410.0], [178.0, 1410.0], [178.0, 1518.0], [150.0, 1518.0]]], "lines": ["今日、", "来てたん", "ですか？"]}], "img_path": "047.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [917, 87, 980, 270], "vertical": true, "font_size": 27, "lines_coords": [[[953.0, 87.0], [