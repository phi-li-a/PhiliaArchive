1170.0], [168.0, 1170.0], [168.0, 1378.0], [142.0, 1378.0]]], "lines": ["さすがフンフン！！"]}], "img_path": "121.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [917, 59, 985, 228], "vertical": true, "font_size": 29, "lines_coords": [[[950.0, 59.0], [985.0, 59.0], [985.0, 129.0], [950.0, 129.0]], [[917.0, 62.0], [948.0, 62.0], [948.0, 228.0], [917.0, 228.0]]], "lines": ["．．．あ", "ハイハイパイ。"]}, {"box": [771, 104, 871, 270], "vertical": true, "font_size": 29, "lines_coords": [[[845.0, 107.0], [871.0, 107.0], [871.0, 270.0], [845.0, 270.0]], [[810.0, 107.0], [832.0, 107.0], [832.0, 264.0], [810.0, 264.0]], [[771.0, 104.0], [800.0, 104.0], [800.0, 198.0], [771.0, 198.0]]], "lines": ["わかりました、", "そーゆうこと", "ですか。"]}, {"box": [598, 70, 700, 257], "vertical": true, "font_size": 30, "lines_coords": [[[673.0, 73.0], [700.0, 73.0], [700.0, 181.0], [673.0, 181.0]], [[634.0, 70.0], [665.0, 70.0], [662.0, 257.0], [631.0, 257.0]], [[598.0, 71.0], [631.0, 71.0], [631.0, 207.0], [598.0, 207.0]]], "lines": ["もう試合", "始まってんじゃ", "ねーの？"]}, {"box": [104, 321, 206, 454], "vertical": true, "font_size": 27, "lines_coords": [[[176.0, 323.0], [203.0, 323.0], [203.0, 454.0], [176.0, 454.0]], [[140.0, 321.0], [167.0, 321.0], [167.0, 453.0], [140.0, 453.0]], [[104.0, 321.0], [132.0, 321.0], [132.0, 401.0], [104.0, 401.0]]], "lines": ["矢口先輩を", "見に来たん", "だろ？"]}, {"box": [864, 810, 978, 1200], "vertical": true, "font_size": 55, "lines_coords": [[[918.0, 810.0], [978.0, 810.0], [978.0, 1103.0], [918.0, 1103.0]], [[864.0, 814.0], [914.0, 814.0], [915.0, 1200.0], [865.0, 1200.0]]], "lines": ["：来週の県北、", "俺が優勝したら．．．"]}, {"box": [218, 814, 329, 1075], "vertical": true, "font_size": 53, "lines_coords": [[[271.0, 815.0], [328.0, 815.0], [329.0, 1037.0], [273.0, 1037.0]], [[221.0, 814.0], [271.0, 814.0], [268.0, 1075.0], [218.0, 1075.0]]], "lines": ["田中は一生", "俺のもんだ！！"]}, {"box": [79, 1332, 242, 1545], "vertical": true, "font_size": 27, "lines_coords": [[[214.0, 1334.0], [240.0, 1334.0], [240.0, 1545.0], [214.0, 1545.0]], [[181.0, 1332.0], [209.0, 1332.0], [206.0, 1493.0], [178.0, 1493.0]], [[146.0, 1334.0], [175.0, 1334.0], [171.0, 1481.0], [143.0, 1481.0]], [[112.0, 1334.0], [139.0, 1334.0], [139.0, 1492.0], [112.0, 1492.0]], [[79.0, 1335.0], [106.0, 1335.0], [106.0, 1475.0], [79.0, 1475.0]]], "lines": ["プンプンは今なら", "富士山が爆発", "しても、全然", "かまわないと", "思いました。"]}], "img_path": "122.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [171, 970, 403, 1059], "vertical": false, "font_size": 50, "lines_coords": [[[181.0, 970.0], [403.0, 1009.0], [393.0, 1059.0], [171.0, 1018.0]]], "lines": ["．．．"]}, {"box": [223, 1060, 357, 1101], "vertical": false, "font_size": 33, "lines_coords": [[[225.0, 1060.0], [357.0, 1068.0], [356.0, 1101.0], [223.0, 1093.0]]], "lines": ["．．．"]}, {"box": [206, 1125, 348, 1154], "vertical": false, "font_size": 22, "lines_coords": [[[207.0, 1125.0], [348.0, 1132.0], [346.0, 1154.0], [206.0, 1146.0]]], "lines": ["．．．"]}], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [207, 851, 240, 1022], "vertical": true, "font_size": 32, "lines_coords": [[[207.0, 851.0], [239.0, 851.0], [239.0, 1021.0], [207.0, 1021.0]]], "lines": ["．．．うっそ。"]}, {"box": [479, 964, 732, 1121], "vertical": false, "font_size": 70.0, "lines_coords": [[[501.0, 964.0], [695.0, 964.0], [695.0, 1043.0], [501.0, 1043.0]], [[479.0, 1060.0], [732.0, 1060.0], [732.0, 1121.0], [479.0, 1121.0]]], "lines": ["．．．そう", "＿前半休憩＿後半延長"]}], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [865, 73, 962, 231], "vertical": true, "font_size": 26, "lines_coords": [[[940.0, 76.0], [962.0, 76.0], [962.0, 184.0], [940.0, 184.0]], [[901.0, 73.0], [928.0, 73.0], [928.0, 231.0], [901.0, 231.0]], [[865.0, 73.0], [893.0, 73.0], [893.0, 165.0], [865.0, 165.0]]], "lines": ["矢口先輩、", "リードしてん", "じゃん。"]}, {"box": [717, 62, 815, 257], "vertical": true, "font_size": 26, "lines_coords": [[[789.0, 64.0], [815.0, 64.0], [815.0, 257.0], [789.0, 257.0]], [[753.0, 62.0], [779.0, 62.0], [779.0, 195.0], [753.0, 195.0]], [[717.0, 65.0], [743.0, 65.0], [743.0, 220.0], [717.0, 220.0]]], "lines": ["つーか、なにげに", "１セット目", "取ってるし！！"]}, {"box": [322, 128, 456, 339], "vertical": true, "font_size": 23, "lines_coords": [[[432.0, 129.0], [454.0, 129.0], [454.0, 285.0], [432.0, 285.0]], [[400.0, 129.0], [426.0, 129.0], [426.0, 259.0], [400.0, 259.0]], [[375.0, 129.0], [396.0, 129.0], [396.0, 285.0], [375.0, 285.0]], [[345.0, 128.0], [367.0, 128.0], [367.0, 339.0], [345.0, 339.0]]], "lines": ["どー考えても", "矢口先輩の", "ボロ負けだと", "思ってたんだけど"]}, {"box": [775, 503, 992, 553], "vertical": false, "font_size": 39, "lines_coords": [[[775.0, 514.0], [990.0, 503.0], [992.0, 542.0], [776.0, 553.0]]], "lines": ["それだろう。矢口"]}, {"box": [742, 551, 1001, 584], "vertical": false, "font_size": 25.0, "lines_coords": [[[742.0, 556.0], [887.0, 559.0], [887.0, 581.0], [742.0, 578.0]], [[878.0, 556.0], [1000.0, 551.0], [1001.0, 579.0], [879.0, 584.0]]], "lines": ["前半休憩後半延長", "．．．"]}, {"box": [90, 515, 160, 609], "vertical": true, "font_size": 35, "lines_coords": [[[126.0, 517.0], [160.0, 517.0], [160.0, 609.0], [126.0, 609.0]], [[90.0, 515.0], [126.0, 515.0], [126.0, 585.0], [90.0, 585.0]]], "lines": ["．．．．．あ、", "ワリ。"]}], "img_path": "126.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [828, 0, 1148, 823], "vertical": true, "font_size": 294, "lines_coords": [[[854.0, 0.0], [1148.0, 7.0], [1121.0, 823.0], [828.0, 814.0]]], "lines": ["ホワアアアァァアアッ！？"]}], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [948, 1200, 1003, 1376], "vertical": true, "font_size": 50, "lines_coords": [[[948.0, 1200.0], [1003.0, 1200.0], [1003.0, 1376.0], [948.0, 1376.0]]], "lines": ["マモルー"]}, {"box": [889, 1323, 937, 1445], "vertical": true, "font_size": 50, "lines_coords": [[[892.0, 1323.0], [937.0, 1325.0], [934.0, 1445.0], [889.0, 1443.0]]], "lines": ["ッ！！"]}, {"box": [93, 1307, 209, 1515], "vertical": true, "font_size": 42, "lines_coords": [[[159.0, 1312.0], [209.0, 1312.0], [206.0, 1515.0], [156.0, 1515.0]], [[93.0, 1307.0], [142.0, 1307.0], [142.0, 1387.0], [93.0, 1387.0]]], "lines": ["ファイト", "よー"]}, {"box": [104, 1442, 132, 1506], "vertical": true, "font_size": 42, "lines_coords": [[[104.0, 1442.0], [132.0, 1442.0], [132.0, 1506.0], [104.0, 1506.0]]], "lines": ["．．．"]}], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [923, 1050, 1012, 1248], "vertical": true, "font_size": 27, "lines_coords": [[[984.0, 1050.0], [1010.0, 1050.0], [1010.0, 1248.0], [984.0, 1248.0]], [[953.0, 1051.0], [981.0, 1051.0], [981.0, 1181.0], [953.0, 1181.0]], [[923.0, 1051.0], [950.0, 1051.0], [950.0, 1245.0], [923.0, 1245.0]]], "lines": ["中二でヤリチンで", "エリンギで", "マザコンなのか。"]}, {"box": [534, 775, 634, 960], "vertical": true, "font_size": 27, "lines_coords": [[[603.0, 775.0], [631.0, 775.0], [634.0, 893.0], [606.0, 893.0]], [[570.0, 776.0], [598.0, 776.0], [595.0, 909.0], [567.0, 909.0]], [[534.0, 778.0], [560.0, 778.0], [560.0, 960.0], [534.0, 960.0]]], "lines": ["．．．あの人、", "矢口先輩の", "お母さんかな？"]}, {"box": [715, 1381, 820, 1553], "vertical": true, "font_size": 32, "lines_coords": [[[787.0, 1381.0], [820.0, 1381.0], [820.0, 1492.0], [787.0, 1492.0]], [[750.0, 1382.0], [782.0, 1382.0], [785.0, 1503.0], [753.0, 1503.0]], [[715.0, 1385.0], [746.0, 1385.0], [746.0, 1551.0], [715.0, 1551.0]]], "lines": ["どーでも", "いいけど。", "マンヨマンコ。"]}, {"box": [356, 1115, 493, 1334], "vertical": true, "font_size": 28, "lines_coords": [[[459.0, 1115.0], [490.0, 1115.0], [490.0, 1331.0], [459.0, 1331.0]], [[428.0, 1120.0], [454.0, 1120.0], [454.0, 1290.0], [428.0, 1290.0]], [[390.0, 1118.0], [417.0, 1118.0], [417.0, 1326.0], [390.0, 1326.0]], [[356.0, 1120.0], [382.0, 1120.0], [382.0, 1284.0], [356.0, 1284.0]]], "lines": ["フンブンはこの時", "なぜかふいに", "非常に嫌な予感が", "していました。"]}], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [919, 109, 981, 250], "vertical": true, "font_size": 25, "lines_coords": [[[953.0, 112.0], [981.0, 112.0], [981.0, 218.0], [953.0, 218.0]], [[920.0, 112.0], [942.0, 112.0], [942.0, 245.0], [920.0, 245.0]]], "lines": ["今までも、", "これからも。"]}, {"box": [733, 107, 870, 433], "vertical": true, "font_size": 24, "lines_coords": [[[845.0, 110.0], [867.0, 110.0], [867.0, 368.0], [845.0, 368.0]], [[806.0, 109.0], [832.0, 109.0], [832.0, 371.0], [806.0, 371.0]], [[771.0, 112.0], [793.0, 112.0], [793.0, 292.0], [771.0, 292.0]], [[734.0, 107.0], [760.0, 107.0], [760.0, 431.0], [734.0, 431.0]]], "lines": ["自分の人生というのは", "何ひとつ思い通りには", "いかないように", "出来てるんじゃないか、と。"]}], "img_path": "130.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [945, 114, 1010, 230], "vertical": true, "font_size": 28, "lines_coords": [[[982.0, 115.0], [1010.0, 115.0], [1010.0, 228.0], [982.0, 228.0]], [[945.0, 114.0], [973.0, 114.0], [973.0, 220.0], [945.0, 220.0]]], "lines": ["．．．オイ、", "線審．．．"]}, {"box": [371, 125, 442, 235], "vertical": true, "font_size": 33, "lines_coords": [[[409.0, 125.0], [442.0, 125.0], [442.0, 235.0], [409.0, 235.0]], [[371.0, 126.0], [404.0, 126.0], [404.0, 235.0], [371.0, 235.0]]], "lines": ["ジャッジ", "は．．．．．．？"]}, {"box": [128, 592, 206, 751], "vertical": true, "font_size": 32, "lines_coords": [[[171.0, 592.0], [204.0, 592.0], [204.0, 721.0], [171.0, 721.0]], [[128.0, 593.0], [159.0, 593.0], [159.0, 751.0], [128.0, 751.0]]], "lines": ["インか？", "アウトか？"]}, {"box": [518, 1018, 621, 1205], "vertical": true, "font_size": 30, "lines_coords": [[[589.0, 1018.0], [621.0, 1018.0], [621.0, 1134.0], [589.0, 1134.0]], [[553.0, 1021.0], [584.0, 1021.0], [584.0, 1204.0], [553.0, 1204.0]], [[518.0, 1020.0], [545.0, 1020.0], [548.0, 1185.0], [521.0, 1185.0]]], "lines": ["．．．きっと、", "なんだかんたて", "先輩が勝って、"]}, {"box": [370, 1017, 471, 1264], "vertical": true, "font_size": 28, "lines_coords": [[[440.0, 1017.0], [471.0, 1017.0], [471.0, 1178.0], [440.0, 1178.0]], [[406.0, 1020.0], [432.0, 1020.0], [432.0, 1178.0], [406.0, 1178.0]], [[370.0, 1020.0], [396.0, 1020.0], [396.0, 1260.0], [370.0, 1260.0]]], "lines": ["帰りのバスで", "愛子ちゃんと", "チュッチュバしたり、"]}, {"box": [115, 1018, 333, 1206], "vertical": true, "font_size": 29, "lines_coords": [[[295.0, 1020.0], [329.0, 1020.0], [329.0, 1104.0], [295.0, 1104.0]], [[259.0, 1018.0], [285.0, 1018.0], [289.0, 1203.0], [262.0, 1203.0]], [[223.0, 1020.0], [251.0, 1020.0], [253.0, 1178.0], [225.0, 1178.0]], [[187.0, 1020.0], [218.0, 1020.0], [218.0, 1179.0], [187.0, 1179.0]], [[150.0, 1018.0], [178.0, 1018.0], [179.0, 1151.0], [151.0, 1151.0]], [[115.0, 1020.0], [142.0, 1020.0], [142.0, 1162.0], [115.0, 1162.0]]], "lines": ["いずれ", "場合によっては", "先輩の部屋で", "セックス等を", "するに違い", "ないのです。"]}], "img_path": "131.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [875, 23, 1028, 267], "vertical": true, "font_size": 153, "lines_coords": [[[875.0, 23.0], [1028.0, 23.0], [1028.0, 267.0], [875.0, 267.0]]], "lines": ["ハアァ！？インン！？"]}, {"box": [187, 48, 246, 223], "vertical": true, "font_size": 25, "lines_coords": [[[217.0, 48.0], [245.0, 48.0], [246.0, 162.0], [218.0, 162.0]], [[187.0, 50.0], [214.0, 50.0], [214.0, 223.0], [187.0, 223.0]]], "lines": ["あ～～あ、", "小松っちゃん。"]}, {"box": [87, 135, 173, 351], "vertical": true, "font_size": 25, "lines_coords": [[[143.0, 135.0], [170.0, 135.0], [173.0, 275.0], [146.0, 275.0]], [[115.0, 142.0], [137.0, 142.0], [137.0, 351.0], [115.0, 351.0]], [[87.0, 145.0], [107.0, 145.0], [107.0, 284.0], [87.0, 284.0]]], "lines": ["あそこまで", "勝ちにこだわると", "みじめだね。"]}, {"box": [645, 381, 767, 607], "vertical": true, "font_size": 37, "lines_coords": [[[728.0, 382.0], [767.0, 382.0], [764.0, 546.0], [725.0, 546.0]], [[685.0, 381.0], [723.0, 381.0], [720.0, 607.0], [682.0, 607.0]], [[645.0, 387.0], [678.0, 387.0], [678.0, 604.0], [645.0, 604.0]]], "lines": ["オォオイ、", "ちゃんと見て", "たのかよっ！！"]}, {"box": [546, 376, 576, 516], "vertical": true, "font_size": 26, "lines_coords": [[[546.0, 376.0], [573.0, 376.0], [576.0, 515.0], [550.0, 515.0]]], "lines": ["．．．そうです。"]}, {"box": [368, 373, 467, 585], "vertical": true, "font_size": 25, "lines_coords": [[[437.0, 375.0], [465.0, 375.0], [465.0, 481.0], [437.0, 481.0]], [[400.0, 373.0], [426.0, 373.0], [429.0, 582.0], [403.0, 582.0]], [[370.0, 376.0], [392.0, 376.0], [392.0, 559.0], [370.0, 559.0]]], "lines": ["これほど", "みしめな気持ちに", "なるくらいなら"]}, {"box": [156, 370, 299, 567], "vertical": true, "font_size": 29, "lines_coords": [[[270.0, 373.0], [298.0, 373.0], [295.0, 504.0], [267.0, 504.0]], [[232.0, 373.0], [259.0, 373.0], [259.0, 506.0], [232.0, 506.0]], [[196.0, 375.0], [225.0, 375.0], [225.0, 504.0], [196.0, 504.0]], [[159.0, 370.0], [190.0, 370.0], [187.0, 567.0], [156.0, 567.0]]], "lines": ["はしめから", "こんな勝負", "しなければ", "良かったんです。"]}, {"box": [843, 623, 1001, 1046], "vertical": true, "font_size": 53, "lines_coords": [[[953.0, 628.0], [1001.0, 628.0], [1001.0, 981.0], [953.0, 981.0]], [[895.0, 623.0], [954.0, 623.0], [954.0, 984.0], [895.0, 984.0]], [[843.0, 623.0], [896.0, 623.0], [896.0, 1046.0], [843.0, 1046.0]]], "lines": ["おまえみたいな", "すっからぴんの", "くだらんミスでェ！！"]}, {"box": [87, 803, 278, 1196], "vertical": true, "font_size": 55, "lines_coords": [[[221.0, 803.0], [278.0, 803.0], [275.0, 1051.0], [218.0, 1051.0]], [[171.0, 804.0], [235.0, 804.0], [235.0, 1196.0], [171.0, 1196.0]], [[131.0, 806.0], [184.0, 806.0], [181.0, 1192.0], [128.0, 1192.0]], [[87.0, 809.0], [134.0, 809.0], [134.0, 1179.0], [87.0, 1179.0]]], "lines": ["僕の美しい", "勝利が左右される", "なんて馬鹿げてる", "でしょオオオォ！？"]}, {"box": [275, 1365, 311, 1507], "vertical": true, "font_size": 32, "lines_coords": [[[275.0, 1365.0], [307.0, 1365.0], [310.0, 1507.0], [278.0, 1507.0]]], "lines": ["アウトだ。"]}], "img_path": "132.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [925, 89, 987, 246], "vertical": true, "font_size": 27, "lines_coords": [[[960.0, 89.0], [987.0, 89.0], [987.0, 246.0], [960.0, 246.0]], [[925.0, 89.0], [951.0, 89.0], [951.0, 206.0], [925.0, 206.0]]], "lines": ["俺、ちゃんと", "見てたよ。"]}, {"box": [787, 206, 889, 401], "vertical": true, "font_size": 27, "lines_coords": [[[862.0, 207.0], [889.0, 207.0], [889.0, 367.0], [862.0, 367.0]], [[823.0, 206.0], [851.0, 206.0], [853.0, 315.0], [825.0, 315.0]], [[787.0, 207.0], [814.0, 207.0], [817.0, 401.0], [790.0, 401.0]]], "lines": ["きわどいけど", "アウトで", "小松のボイント。"]}, {"box": [957, 675, 984, 814], "vertical": true, "font_size": 26, "lines_coords": [[[957.0, 675.0], [984.0, 675.0], [984.0, 814.0], [957.0, 814.0]]], "lines": ["．．．そうです。"]}, {"box": [735, 671, 764, 867], "vertical": true, "font_size": 27, "lines_coords": [[[735.0, 671.0], [762.0, 671.0], [764.0, 867.0], [737.0, 867.0]]], "lines": ["言うんでしょう。"]}, {"box": [581, 671, 707, 882], "vertical": true, "font_size": 27, "lines_coords": [[[681.0, 673.0], [707.0, 673.0], [704.0, 843.0], [678.0, 843.0]], [[648.0, 673.0], [675.0, 673.0], [675.0, 882.0], [648.0, 882.0]], [[612.0, 671.0], [643.0, 671.0], [643.0, 832.0], [612.0, 832.0]], [[581.0, 673.0], [607.0, 673.0], [607.0, 867.0], [581.0, 867.0]]], "lines": ["「実は中学ん時", "お前を取り合って", "部活の試合で", "賭をしてたんだ。"]}, {"box": [360, 673, 551, 909], "vertical": true, "font_size": 27, "lines_coords": [[[523.0, 673.0], [551.0, 673.0], [551.0, 779.0], [523.0, 779.0]], [[489.0, 673.0], [520.0, 673.0], [520.0, 859.0], [489.0, 859.0]], [[457.0, 673.0], [484.0, 673.0], [484.0, 909.0], [457.0, 909.0]], [[426.0, 673.0], [453.0, 673.0], [453.0, 820.0], [426.0, 820.0]], [[393.0, 673.0], [420.0, 673.0], [420.0, 832.0], [393.0, 832.0]], [[360.0, 673.0], [387.0, 673.0], [387.0, 870.0], [360.0, 870.0]]], "lines": ["．．．あの時", "負けてたら今頃", "とうなってたのかな", "．．．．．ははは。", "憶えてるかい", "小野寺って奴？」"]}, {"box": [159, 423, 223, 554], "vertical": true, "font_size": 26, "lines_coords": [[[195.0, 423.0], [221.0, 423.0], [221.0, 554.0], [195.0, 554.0]], [[159.0, 423.0], [185.0, 423.0], [185.0, 553.0], [159.0, 553.0]]], "lines": ["．．．フェアに", "やろーぜ？"]}, {"box": [271, 675, 329, 856], "vertical": true, "font_size": 27, "lines_coords": [[[303.0, 675.0], [329.0, 675.0], [329.0, 856.0], [303.0, 856.0]], [[271.0, 676.0], [293.0, 676.0], [293.0, 856.0], [271.0, 856.0]]], "lines": ["忘れてもらって", "かまいません！！"]}, {"box": [115, 671, 237, 909], "vertical": true, "font_size": 27, "lines_coords": [[[215.0, 675.0], [237.0, 675.0], [237.0, 804.0], [215.0, 804.0]], [[179.0, 673.0], [206.0, 673.0], [206.0, 856.0], [179.0, 856.0]], [[145.0, 671.0], [173.0, 671.0], [175.0, 831.0], [146.0, 831.0]], [[115.0, 673.0], [142.0, 673.0], [142.0, 909.0], [115.0, 909.0]]], "lines": ["自分なんて", "先輩達の人生の", "添え物程度の", "存在なんですから！！"]}, {"box": [771, 671, 928, 948], "vertical": true, "font_size": 26, "lines_coords": [[[898.0, 673.0], [926.0, 673.0], [928.0, 918.0], [900.0, 918.0]], [[865.0, 675.0], [892.0, 675.0], [892.0, 884.0], [865.0, 884.0]], [[834.0, 673.0], [860.0, 673.0], [860.0, 948.0], [834.0, 948.0]], [[801.0, 671.0], [829.0, 671.0], [828.0, 909.0], [800.0, 909.0]], [[771.0, 676.0], [793.0, 676.0], [793.0, 831.0], [771.0, 831.0]]], "lines": ["いつだって正しくて、", "格好の良い先輩は", "数年後、結婚式の前日に", "きっとこんなことを", "愛子ちゃんに"]}, {"box": [442, 1046, 546, 1204], "vertical": true, "font_size": 28, "lines_coords": [[[517.0, 1048.0], [545.0, 1048.0], [545.0, 1153.0], [517.0, 1153.0]], [[476.0, 1046.0], [507.0, 1046.0], [510.0, 1203.0], [479.0, 1203.0]], [[442.0, 1046.0], [468.0, 1046.0], [468.0, 1159.0], [442.0, 1159.0]]], "lines": ["とっても", "悲しくなって", "きました。"]}, {"box": [257, 1045, 398, 1284], "vertical": true, "font_size": 28, "lines_coords": [[[364.0, 1048.0], [390.0, 1048.0], [390.0, 1178.0], [364.0, 1178.0]], [[326.0, 1046.0], [354.0, 1046.0], [354.0, 1151.0], [326.0, 1151.0]], [[289.0, 1046.0], [320.0, 1046.0], [320.0, 1279.0], [289.0, 1279.0]]], "lines": ["今日は家に", "帰ったら", "たくさん泣こう、と"]}, {"box": [176, 1046, 240, 1189], "vertical": true, "font_size": 24, "lines_coords": [[[210.0, 1048.0], [237.0, 1048.0], [237.0, 1176.0], [210.0, 1176.0]], [[176.0, 1048.0], [198.0, 1048.0], [198.0, 1184.0], [176.0, 1184.0]]], "lines": ["フンフンは", "思いました。"]}, {"box": [185, 1388, 215, 1508], "vertical": true, "font_size": 29, "lines_coords": [[[185.0, 1390.0], [214.0, 1390.0], [214.0, 1506.0], [185.0, 1506.0]]], "lines": ["．．．．．．ねえ。"]}], "img_path": "133.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [215, 70, 351, 253], "vertical": true, "font_size": 25, "lines_coords": [[[325.0, 71.0], [351.0, 71.0], [351.0, 228.0], [325.0, 228.0]], [[289.0, 70.0], [315.0, 70.0], [315.0, 253.0], [289.0, 253.0]], [[251.0, 71.0], [278.0, 71.0], [278.0, 229.0], [251.0, 229.0]], [[215.0, 70.0], [242.0, 70.0], [242.0, 229.0], [215.0, 229.0]]], "lines": ["：他人同士が", "好きになったり", "付き合ったり", "するのって．．"]}, {"box": [148, 256, 206, 385], "vertical": true, "font_size": 25, "lines_coords": [[[184.0, 256.0], [206.0, 256.0], [206.0, 385.0], [184.0, 385.0]], [[148.0, 256.0], [170.0, 256.0], [170.0, 385.0], [148.0, 385.0]]], "lines": ["．．．なんなん", "だろうね？"]}, {"box": [179, 515, 318, 751], "vertical": true, "font_size": 28, "lines_coords": [[[285.0, 515.0], [317.0, 515.0], [317.0, 675.0], [285.0, 675.0]], [[251.0, 517.0], [278.0, 517.0], [278.0, 712.0], [251.0, 712.0]], [[215.0, 517.0], [242.0, 517.0], [242.0, 751.0], [215.0, 751.0]], [[179.0, 517.0], [206.0, 517.0], [206.0, 710.0], [179.0, 710.0]]], "lines": ["優しい家族が", "いるのに、さらに", "愛情を求めるなんて", "欲張りだと思う。"]}, {"box": [870, 793, 970, 1004], "vertical": true, "font_size": 26, "lines_coords": [[[948.0, 795.0], [970.0, 795.0], [970.0, 976.0], [948.0, 976.0]], [[907.0, 793.0], [935.0, 793.0], [937.0, 1004.0], [909.0, 1004.0]], [[870.0, 793.0], [898.0, 793.0], [901.0, 909.0], [873.0, 909.0]]], "lines": ["どんなに好きで", "彼氏彼女になった", "としても、"]}, {"box": [743, 910, 843, 1137], "vertical": true, "font_size": 26, "lines_coords": [[[817.0, 910.0], [843.0, 910.0], [843.0, 1070.0], [817.0, 1070.0]], [[779.0, 910.0], [806.0, 910.0], [806.0, 1137.0], [779.0, 1137.0]], [[743.0, 910.0], [770.0, 910.0], [770.0, 1081.0], [743.0, 1081.0]]], "lines": ["きっと永遠に", "他人以上の存在には", "なれないんだ。"]}, {"box": [301, 843, 365, 1040], "vertical": true, "font_size": 26, "lines_coords": [[[339.0, 845.0], [365.0, 845.0], [365.0, 1040.0], [339.0, 1040.0]], [[301.0, 843.0], [328.0, 843.0], [328.0, 1012.0], [301.0, 1012.0]]], "lines": ["．．．でも、あたしは", "そんなの嫌だ。"]}, {"box": [135, 943, 271, 1171], "vertical": true, "font_size": 26, "lines_coords": [[[245.0, 945.0], [271.0, 945.0], [271.0, 1104.0], [245.0, 1104.0]], [[206.0, 943.0], [234.0, 943.0], [235.0, 1079.0], [207.0, 1079.0]], [[171.0, 946.0], [198.0, 946.0], [198.0, 1171.0], [171.0, 1171.0]], [[135.0, 945.0], [159.0, 945.0], [160.0, 1115.0], [137.0, 1115.0]]], "lines": ["余計なものは", "全部捨てて", "ただ、あたしだけを", "見ててほしい。"]}, {"box": [895, 1304, 960, 1464], "vertical": true, "font_size": 27, "lines_coords": [[[934.0, 1304.0], [960.0, 1304.0], [960.0, 1437.0], [934.0, 1437.0]], [[898.0, 1304.0], [925.0, 1304.0], [921.0, 1464.0], [895.0, 1464.0]]], "lines": ["矢口先輩は", "いい人だよ．．．"]}, {"box": [753, 1367, 853, 1512], "vertical": true, "font_size": 27, "lines_coords": [[[826.0, 1370.0], [853.0, 1370.0], [853.0, 1500.0], [826.0, 1500.0]], [[790.0, 1368.0], [818.0, 1368.0], [818.0, 1475.0], [790.0, 1475.0]], [[753.0, 1367.0], [781.0, 1367.0], [782.0, 1512.0], [754.0, 1512.0]]], "lines": ["やさしくて", "真面目で", "格好良くて。"]}, {"box": [109, 1337, 246, 1520], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 1337.0], [246.0, 1337.0], [246.0, 1432.0], [214.0, 1432.0]], [[181.0, 1340.0], [203.0, 1340.0], [203.0, 1520.0], [181.0, 1520.0]], [[142.0, 1339.0], [168.0, 1339.0], [168.0, 1470.0], [142.0, 1470.0]], [[109.0, 1340.0], [131.0, 1340.0], [131.0, 1504.0], [109.0, 1504.0]]], "lines": ["．．．けど、", "あの人にはまだ", "逃げ場所が", "たくさんある。"]}], "img_path": "134.png"}, {"version": "0.2.0-beta.6", 