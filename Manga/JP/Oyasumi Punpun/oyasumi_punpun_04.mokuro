[3696.0, 684.0]], [[3237.0, 678.0], [3790.0, 678.0], [3790.0, 722.0], [3237.0, 722.0]], [[3234.0, 719.0], [3787.0, 719.0], [3787.0, 752.0], [3234.0, 752.0]], [[3237.0, 753.0], [3456.0, 753.0], [3456.0, 786.0], [3237.0, 786.0]], [[3696.0, 757.0], [3783.0, 757.0], [3783.0, 789.0], [3696.0, 789.0]], [[3678.0, 787.0], [3779.0, 787.0], [3779.0, 819.0], [3678.0, 819.0]], [[3237.0, 787.0], [3516.0, 787.0], [3516.0, 819.0], [3237.0, 819.0]], [[3572.0, 813.0], [3783.0, 817.0], [3783.0, 853.0], [3572.0, 850.0]], [[3230.0, 813.0], [3478.0, 817.0], [3478.0, 853.0], [3230.0, 850.0]], [[3234.0, 847.0], [3463.0, 855.0], [3463.0, 887.0], [3234.0, 880.0]], [[3689.0, 855.0], [3783.0, 855.0], [3783.0, 887.0], [3689.0, 887.0]], [[3230.0, 874.0], [3794.0, 874.0], [3794.0, 929.0], [3230.0, 929.0]], [[3234.0, 919.0], [3471.0, 915.0], [3471.0, 951.0], [3234.0, 955.0]], [[3696.0, 923.0], [3783.0, 923.0], [3783.0, 955.0], [3696.0, 955.0]], [[3237.0, 949.0], [3565.0, 945.0], [3565.0, 989.0], [3237.0, 993.0]], [[3696.0, 957.0], [3783.0, 957.0], [3783.0, 989.0], [3696.0, 989.0]], [[3332.0, 987.0], [3681.0, 987.0], [3681.0, 1019.0], [3332.0, 1019.0]], [[3241.0, 1024.0], [3775.0, 1024.0], [3775.0, 1057.0], [3241.0, 1057.0]]], "lines": ["おやすみプンプンＶラー、〈Ａｎ＃", "浅野いにお洋服いたお", "ソラニン・全２巻", "浅野いにお", "ソフーローコトー診療所・Ｉ－Ｐｕｎｎｃｕ－", "ええ．．．この山田貴敏", "しかし、「診療所」「これを、ＦＡＮＥＯＦ－主が切りました。１〜２０巻安部課二／柿崎正澄", "「Ａｎｄｕｒｉ」鉄腕バーディー全２０巻", "ゆうきまさみ", "室積光／猪熊しのご宝積光ノ猪熊レのぶ", "都立水商」「全２０巻", "黒丸ノ夏原武", "部屋から生徒をクロサギ、全２０巻イキガミで。", "シロリギーエイの客イキガミーＴｈｅｌＵＮｉｎｄｅｌＩｎｔ－Ｔｗｉｔｔｅｒ！！一黒丸〃昱尿武日巻一間瀬元朗", "土竜（モグラ）の唄「ーーは巻ー」", "ですが、自然の研究者一高橋のぼる業務ではまった", "上電、モンション限超無気力戦隊ジャパ、ハッコーナー「こんなコーラーラスのファイブ全日巻一佐藤まささき", "２０１６年１０月１６日－オッズ－１〜１０巻", "石渡治", "ＬＵＮＳメンバー「トールをさらけばジトローム」の吸血に全力巻ールギー", "これ崎拓", "ところが、インタームページのタナトスがいたのか、全日巻、とめ付けやってしまうのですが、・生いる竹原慎二ノ落合裕介「この数、司会志織", "とめはねっ！。鈴里高校書道部", "１〜４巻－河合克敏", "このはんっ！ぁぁあああ、ビーチスターズ、１〜６巻氷一本森土ーーー", "森尾正博", "ビーナスターへ「こわる逃亡弁護士・成田成」１－５０代のＡｍａｚｏｎ高田優ノ剛英城", "２０１１年１１月１４日まつ３時の月の３日、全日港１０ここ、本根ラサムノ国川光太郎", "魔口ケン・コーヒ巻・キャラー．．．", "喜国雅彦", "大谷じろう", "美晴♥ライシング、全５巻", "七月鏡一ノ藤原芳秀", "実際、暁のイージス、全日巻二十", "晩のアオイホノオ「巻", "島本和彦", "アオイホルオールさんは、あんころが続いていますが、この時期、１２時間、５０００円", "ＤＶＯＪＯ。ＭａｃＢＯ－ＯＮＩＮＩＴ－３巻", "秋重学", "ＯＵＰＵＮ．「Ｃ３もドライブ・ア・ライフ・フィーナー」", "ハニ中井邦彦", "ファントノートビービオヤングサンデーコミックススペシャル", "絶望に効くクスリ・ＯＮＥＯＮＯＮＥＴ－１４巻山田玲司"]}, {"box": [3242, 1069, 3767, 1161], "vertical": false, "font_size": 34, "lines_coords": [[[3264.0, 1066.0], [3745.0, 1069.0], [3745.0, 1113.0], [3264.0, 1109.0]], [[3253.0, 1100.0], [3753.0, 1103.0], [3753.0, 1139.0], [3253.0, 1136.0]], [[3256.0, 1130.0], [3591.0, 1130.0], [3591.0, 1162.0], [3256.0, 1162.0]]], "lines": ["ｈｔｔｐ／／ｗｗｗ．ｏｕｍｇｕｓｕｎｃｋｏｒｏｎ．", "にアクセスすると、やグサンデー情報が詳しくわかり", "ＹＳＤを入ると、インタッフールやＹＳＯＣをオンラインショップで購入す"]}, {"box": [3294, 1226, 3739, 1439], "vertical": false, "font_size": 39, "lines_coords": [[[3418.0, 1224.0], [3599.0, 1224.0], [3599.0, 1267.0], [3418.0, 1267.0]], [[3365.0, 1246.0], [3738.0, 1261.0], [3734.0, 1350.0], [3362.0, 1335.0]], [[3309.0, 1299.0], [3433.0, 1299.0], [3433.0, 1331.0], [3309.0, 1331.0]], [[3354.0, 1329.0], [3678.0, 1329.0], [3678.0, 1362.0], [3354.0, 1362.0]], [[3324.0, 1356.0], [3505.0, 1356.0], [3505.0, 1388.0], [3324.0, 1388.0]], [[3343.0, 1382.0], [3678.0, 1382.0], [3678.0, 1414.0], [3343.0, 1414.0]], [[3328.0, 1408.0], [3708.0, 1408.0], [3708.0, 1441.0], [3328.0, 1441.0]]], "lines": ["浅野いにお", "１９３０年１０月１９日０年生まれ。放射県出身。１１年、第１１回ナンデーＧＸ新人賞入賞。主が売上に講師らしい世界」", "２００１年、第１", "１０年、第回リノナーＯＫが入り、主な著作に「素晴らしい世界」のままじゃありがあります。", "「ひかりのまち」と", "おかしのまら、どもこの辺りかの「ソラニン（全２巻」小社刊）が、国土１４４４世紀間おねえよ。", "全国よりラーン「モニオリエリア、全国はリ世代・性例を超えた大阪圏作に"]}], "img_path": "001.png"}, {"version": "0.2.0-beta.6", "img_width": 3851, "img_height": 1600, "blocks": [{"box": [880, 131, 943, 858], "vertical": true, "font_size": 52, "lines_coords": [[[883.0, 131.0], [936.0, 131.0], [932.0, 858.0], [880.0, 858.0]]], "lines": ["おやすみプンプンの「浅野にお"]}, {"box": [710, 1005, 1808, 1114], "vertical": false, "font_size": 107, "lines_coords": [[[718.0, 996.0], [1808.0, 1007.0], [1808.0, 1123.0], [718.0, 1112.0]]], "lines": ["各所書部にて大絶賛話題は"]}, {"box": [1178, 1139, 1382, 1217], "vertical": false, "font_size": 85, "lines_coords": [[[1178.0, 1132.0], [1382.0, 1132.0], [1382.0, 1224.0], [1178.0, 1224.0]]], "lines": ["ダ．．．コＶＢｒｏｓ．オトナファミ"]}, {"box": [714, 1523, 849, 1568], "vertical": false, "font_size": 49, "lines_coords": [[[714.0, 1519.0], [849.0, 1519.0], [849.0, 1572.0], [714.0, 1572.0]]], "lines": ["ｃｉｂｙｕｆｅ"]}, {"box": [1151, 1311, 1276, 1362], "vertical": false, "font_size": 56, "lines_coords": [[[1151.0, 1306.0], [1276.0, 1306.0], [1276.0, 1367.0], [1151.0, 1367.0]]], "lines": ["Ｇｅｏｄ．ｎｉｇｈｔ．ｐｕｍｐｕｎ．．．"]}, {"box": [1310, 1449, 1413, 1486], "vertical": false, "font_size": 40, "lines_coords": [[[1310.0, 1446.0], [1413.0, 1446.0], [1413.0, 1489.0], [1310.0, 1489.0]]], "lines": ["京都新聞"]}, {"box": [1275, 1502, 1368, 1543], "vertical": false, "font_size": 45, "lines_coords": [[[1282.0, 1498.0], [1368.0, 1498.0], [1368.0, 1547.0], [1282.0, 1547.0]]], "lines": ["月刊Ｈ－"]}, {"box": [1278, 1170, 1816, 1336], "vertical": false, "font_size": 55.333333333333336, "lines_coords": [[[1470.0, 1276.0], [1756.0, 1287.0], [1756.0, 1336.0], [1470.0, 1325.0]], [[1278.0, 1234.0], [1744.0, 1234.0], [1744.0, 1298.0], [1278.0, 1298.0]], [[1455.0, 1193.0], [1812.0, 1170.0], [1816.0, 1223.0], [1459.0, 1246.0]]], "lines": ["ＨＥＲＥ（台湾）・マ導界・新日新聞・編集", "また、「日本人としてはる」「日経フィーターメント」の", "ＮＨＫマンガノグンバ広告批評"]}, {"box": [1289, 1445, 1587, 1490], "vertical": false, "font_size": 42, "lines_coords": [[[1289.0, 1449.0], [1587.0, 1445.0], [1587.0, 1487.0], [1289.0, 1490.0]]], "lines": ["京都新聞「Ｌ２５Ｓｏｌｐ．"]}, {"box": [1177, 1313, 1831, 1479], "vertical": false, "font_size": 59.333333333333336, "lines_coords": [[[1365.0, 1325.0], [1831.0, 1313.0], [1831.0, 1377.0], [1365.0, 1389.0]], [[1459.0, 1385.0], [1737.0, 1374.0], [1737.0, 1423.0], [1459.0, 1434.0]], [[1177.0, 1415.0], [1477.0, 1374.0], [1489.0, 1438.0], [1188.0, 1479.0]]], "lines": ["最新聞いていただけだが、文字列というのは、「明日新聞・解決会は", "これでは、「ＣＵＣＫＵＲＡＰＡＮ」", "ＢＲＵＴＵＳ『中日新聞"]}, {"box": [1632, 1426, 1801, 1453], "vertical": false, "font_size": 27, "lines_coords": [[[1632.