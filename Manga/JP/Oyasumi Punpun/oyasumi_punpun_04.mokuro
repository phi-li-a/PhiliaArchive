5.0, 670.0], [635.0, 781.0], [603.0, 781.0]], [[568.0, 671.0], [595.0, 671.0], [595.0, 828.0], [568.0, 828.0]], [[534.0, 671.0], [560.0, 671.0], [560.0, 854.0], [534.0, 854.0]], [[500.0, 675.0], [521.0, 675.0], [521.0, 857.0], [500.0, 857.0]]], "lines": ["自分のせいで", "先輩から", "色んなものを", "奪ってしまった", "ような気かして"]}, {"box": [348, 670, 453, 881], "vertical": true, "font_size": 29, "lines_coords": [[[426.0, 671.0], [453.0, 671.0], [453.0, 829.0], [426.0, 829.0]], [[389.0, 671.0], [415.0, 671.0], [415.0, 878.0], [389.0, 878.0]], [[348.0, 670.0], [382.0, 670.0], [382.0, 764.0], [348.0, 764.0]]], "lines": ["やりきれない", "気持ちのフンフン", "でした。"]}, {"box": [154, 318, 259, 532], "vertical": true, "font_size": 31, "lines_coords": [[[228.0, 321.0], [256.0, 321.0], [256.0, 428.0], [228.0, 428.0]], [[192.0, 320.0], [223.0, 320.0], [223.0, 532.0], [192.0, 532.0]], [[154.0, 318.0], [187.0, 318.0], [187.0, 414.0], [154.0, 414.0]]], "lines": ["ひとつも", "嬉しくありません", "でした。"]}, {"box": [472, 988, 539, 1107], "vertical": true, "font_size": 31, "lines_coords": [[[504.0, 989.0], [539.0, 989.0], [539.0, 1073.0], [504.0, 1073.0]], [[473.0, 990.0], [500.0, 990.0], [500.0, 1107.0], [473.0, 1107.0]]], "lines": ["．．．いや", "違います。"]}, {"box": [326, 992, 428, 1146], "vertical": true, "font_size": 30, "lines_coords": [[[401.0, 992.0], [428.0, 992.0], [428.0, 1146.0], [401.0, 1146.0]], [[364.0, 992.0], [390.0, 992.0], [390.0, 1146.0], [364.0, 1146.0]], [[326.0, 992.0], [354.0, 992.0], [354.0, 1101.0], [326.0, 1101.0]]], "lines": ["頭の中でさえ", "いい人のふり", "だなんて、"]}, {"box": [256, 992, 284, 1121], "vertical": true, "font_size": 30, "lines_coords": [[[256.0, 992.0], [284.0, 992.0], [284.0, 1121.0], [256.0, 1121.0]]], "lines": ["フンフンは"]}, {"box": [178, 985, 218, 1060], "vertical": true, "font_size": 30, "lines_coords": [[[178.0, 985.0], [218.0, 985.0], [218.0, 1060.0], [178.0, 1060.0]]], "lines": ["です。"]}, {"box": [186, 990, 285, 1175], "vertical": true, "font_size": 26, "lines_coords": [[[220.0, 990.0], [246.0, 990.0], [245.0, 1173.0], [218.0, 1173.0]]], "lines": ["本当にするい子"]}, {"box": [351, 1351, 392, 1500], "vertical": true, "font_size": 38, "lines_coords": [[[351.0, 1351.0], [389.0, 1351.0], [392.0, 1500.0], [354.0, 1500.0]]], "lines": ["プンプン。"]}], "img_path": "161.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [922, 179, 984, 375], "vertical": true, "font_size": 27, "lines_coords": [[[957.0, 179.0], [984.0, 179.0], [984.0, 312.0], [957.0, 312.0]]], "lines": ["．．．認めたく"]}, {"box": [920, 181, 946, 370], "vertical": true, "font_size": 27, "lines_coords": [[[920.0, 181.0], [946.0, 181.0], [946.0, 370.0], [920.0, 370.0]]], "lines": ["なかったのです。"]}, {"box": [775, 178, 878, 414], "vertical": true, "font_size": 27, "lines_coords": [[[851.0, 179.0], [878.0, 179.0], [878.0, 393.0], [851.0, 393.0]], [[812.0, 179.0], [839.0, 179.0], [839.0, 414.0], [812.0, 414.0]], [[775.0, 178.0], [803.0, 178.0], [806.0, 296.0], [778.0, 296.0]]], "lines": ["ほんの一瞬感した", "人を裏切り蹴落とす", "高揚感を。"]}, {"box": [687, 80, 714, 210], "vertical": true, "font_size": 27, "lines_coords": [[[687.0, 81.0], [714.0, 81.0], [714.0, 210.0], [687.0, 210.0]]], "lines": ["．．．帰るの？"]}, {"box": [295, 176, 324, 396], "vertical": true, "font_size": 26, "lines_coords": [[[295.0, 176.0], [321.0, 176.0], [323.0, 392.0], [296.0, 392.0]]], "lines": ["．．．自分の頭の中に"]}, {"box": [137, 178, 241, 389], "vertical": true, "font_size": 27, "lines_coords": [[[214.0, 179.0], [235.0, 179.0], [235.0, 362.0], [214.0, 362.0]], [[176.0, 178.0], [203.0, 178.0], [203.0, 385.0], [176.0, 385.0]], [[137.0, 178.0], [170.0, 178.0], [170.0, 271.0], [137.0, 271.0]]], "lines": ["まるでもう一人", "誰かがいるみたい", "でした。"]}, {"box": [668, 1303, 770, 1545], "vertical": true, "font_size": 26, "lines_coords": [[[742.0, 1303.0], [768.0, 1303.0], [768.0, 1437.0], [742.0, 1437.0]], [[706.0, 1304.0], [732.0, 1304.0], [732.0, 1539.0], [706.0, 1539.0]], [[668.0, 1304.0], [695.0, 1304.0], [696.0, 1542.0], [670.0, 1542.0]]], "lines": ["．．．こんなに", "まんまるできれいな", "愛子ちゃんの瞳には"]}, {"box": [357, 1303, 494, 1540], "vertical": true, "font_size": 27, "lines_coords": [[[465.0, 1303.0], [493.0, 1303.0], [492.0, 1514.0], [464.0, 1514.0]], [[426.0, 1303.0], [457.0, 1303.0], [457.0, 1540.0], [426.0, 1540.0]], [[393.0, 1304.0], [417.0, 1304.0], [418.0, 1460.0], [395.0, 1460.0]], [[357.0, 1304.0], [384.0, 1304.0], [384.0, 1495.0], [357.0, 1495.0]]], "lines": ["さそ、自分なんて", "汚らわしい生き物に", "映っているに", "違いありません。"]}], "img_path": "162.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [582, 541, 685, 733], "vertical": true, "font_size": 31, "lines_coords": [[[653.0, 542.0], [685.0, 542.0], [685.0, 635.0], [653.0, 635.0]], [[615.0, 542.0], [648.0, 542.0], [648.0, 645.0], [615.0, 645.0]], [[582.0, 545.0], [609.0, 545.0], [609.0, 728.0], [582.0, 728.0]]], "lines": ["「あの日", "鹿児島へ", "一緒に行く約束"]}, {"box": [434, 540, 501, 725], "vertical": true, "font_size": 29, "lines_coords": [[[473.0, 542.0], [500.0, 542.0], [500.0, 696.0], [473.0, 696.0]], [[434.0, 540.0], [465.0, 540.0], [465.0, 721.0], [434.0, 721.0]]], "lines": ["：守れなくて", "ごめんなさい。"]}, {"box": [718, 1306, 743, 1394], "vertical": true, "font_size": 18, "lines_coords": [[[721.0, 1310.0], [739.0, 1310.0], [739.0, 1382.0], [721.0, 1382.0]]], "lines": ["一年間"]}, {"box": [507, 1304, 647, 1501], "vertical": true, "font_size": 24, "lines_coords": [[[620.0, 1309.0], [643.0, 1309.0], [643.0, 1382.0], [620.0, 1382.0]], [[585.0, 1309.0], [607.0, 1309.0], [607.0, 1498.0], [585.0, 1498.0]], [[548.0, 1307.0], [570.0, 1307.0], [570.0, 1485.0], [548.0, 1485.0]], [[507.0, 1304.0], [535.0, 1304.0], [537.0, 1418.0], [509.0, 1418.0]]], "lines": ["三分は", "ただこの一言が", "言いたかったん", "たな、と、"]}, {"box": [339, 1306, 439, 1476], "vertical": true, "font_size": 22, "lines_coords": [[[414.0, 1309.0], [435.0, 1309.0], [435.0, 1434.0], [414.0, 1434.0]], [[375.0, 1307.0], [401.0, 1307.0], [401.0, 1407.0], [375.0, 1407.0]], [[342.0, 1309.0], [362.0, 1309.0], [362.0, 1468.0], [342.0, 1468.0]]], "lines": ["フンフンは", "ようやく", "わかりました"]}], "img_path": "163.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [945, 539, 971, 670], "vertical": true, "font_size": 32, "lines_coords": [[[945.0, 539.0], [971.0, 539.0], [971.0, 670.0], [945.0, 670.0]]], "lines": ["．．．ううん"]}, {"box": [879, 718, 917, 850], "vertical": true, "font_size": 32, "lines_coords": [[[879.0, 718.0], [917.0, 718.0], [917.0, 850.0], [879.0, 850.0]]], "lines": ["いいよ？"]}, {"box": [160, 998, 239, 1189], "vertical": true, "font_size": 32, "lines_coords": [[[204.0, 998.0], [237.0, 998.0], [237.0, 1189.0], [204.0, 1189.0]], [[160.0, 998.0], [192.0, 998.0], [192.0, 1157.0], [160.0, 1157.0]]], "lines": ["全然気にして", "ないから！！"]}, {"box": [517, 1295, 596, 1521], "vertical": true, "font_size": 32, "lines_coords": [[[560.0, 1296.0], [593.0, 1296.0], [593.0, 1501.0], [560.0, 1501.0]], [[517.0, 1296.0], [548.0, 1296.0], [548.0, 1517.0], [517.0, 1517.0]]], "lines": ["「愛子ちゃんが", "．．．笑っとる。」"]}], "img_path": "164.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [837, 284, 945, 656], "vertical": true, "font_size": 49, "lines_coords": [[[896.0, 284.0], [929.0, 284.0], [929.0, 409.0], [896.0, 409.0]], [[867.0, 498.0], [937.0, 493.0], [945.0, 626.0], [875.0, 631.0]], [[837.0, 503.0], [881.0, 503.0], [881.0, 656.0], [837.0, 656.0]]], "lines": ["じゃ．．．．．", "今から．．．", "行こう？"]}, {"box": [192, 755, 241, 957], "vertical": true, "font_size": 48, "lines_coords": [[[192.0, 756.0], [240.0, 756.0], [240.0, 957.0], [192.0, 957.0]]], "lines": ["鹿児島！！"]}], "img_path": "165.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [938, 937, 971, 1109], "vertical": true, "font_size": 31, "lines_coords": [[[939.0, 937.0], [970.0, 937.0], [970.0, 1107.0], [939.0, 1107.0]]], "lines": ["プンプンは、"]}, {"box": [514, 764, 584, 876], "vertical": true, "font_size": 35, "lines_coords": [[[551.0, 765.0], [584.0, 765.0], [584.0, 870.0], [551.0, 870.0]], [[514.0, 764.0], [551.0, 764.0], [551.0, 812.0], [514.0, 812.0]]], "lines": ["フンフン", "はー"]}, {"box": [432, 1071, 509, 1228], "vertical": true, "font_size": 29, "lines_coords": [[[476.0, 1073.0], [506.0, 1073.0], [506.0, 1228.0], [476.0, 1228.0]], [[432.0, 1071.0], [460.0, 1071.0], [460.0, 1196.0], [432.0, 1196.0]]], "lines": ["嘘つかない", "もんね？"]}, {"box": [325, 1054, 355, 1303], "vertical": true, "font_size": 25, "lines_coords": [[[325.0, 1054.0], [350.0, 1054.0], [353.0, 1293.0], [328.0, 1293.0]]], "lines": ["．．．深い深い闇の底へ"]}, {"box": [940, 1282, 965, 1444], "vertical": true, "font_size": 22, "lines_coords": [[[940.0, 1284.0], [962.0, 1284.0], [962.0, 1439.0], [940.0, 1439.0]]], "lines": ["なんというか"]}, {"box": [758, 1279, 859, 1489], "vertical": true, "font_size": 27, "lines_coords": [[[832.0, 1282.0], [859.0, 1282.0], [859.0, 1487.0], [832.0, 1487.0]], [[795.0, 1282.0], [821.0, 1282.0], [821.0, 1439.0], [795.0, 1439.0]], [[759.0, 1279.0], [787.0, 1279.0], [787.0, 1418.0], [759.0, 1418.0]]], "lines": ["これ以上一歩でも", "愛子ちゃんに", "近づいたら、"]}, {"box": [132, 1153, 233, 1361], "vertical": true, "font_size": 26, "lines_coords": [[[206.0, 1154.0], [232.0, 1154.0], [232.0, 1285.0], [206.0, 1285.0]], [[168.0, 1153.0], [195.0, 1153.0], [196.0, 1359.0], [170.0, 1359.0]], [[132.0, 1154.0], [159.0, 1154.0], [159.0, 1318.0], [132.0, 1318.0]]], "lines": ["とこまでも", "堕ちてゆくような", "気がしました。"]}], "img_path": "166.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [846, 110, 952, 295], "vertical": true, "font_size": 27, "lines_coords": [[[923.0, 112.0], [950.0, 112.0], [950.0, 245.0], [923.0, 245.0]], [[884.0, 112.0], [912.0, 112.0], [914.0, 295.0], [885.0, 295.0]], [[850.0, 110.0], [876.0, 110.0], [873.0, 256.0], [846.0, 256.0]]], "lines": ["プンプンは", "声を振り絞って", "言いました。"]}, {"box": [614, 732, 642, 865], "vertical": true, "font_size": 26, "lines_coords": [[[614.0, 732.0], [640.0, 732.0], [640.0, 864.0], [614.0, 864.0]]], "lines": ["．．．なんで？"]}, {"box": [795, 862, 918, 1159], "vertical": true, "font_size": 30, "lines_coords": [[[885.0, 864.0], [912.0, 864.0], [912.0, 1153.0], [885.0, 1153.0]], [[840.0, 865.0], [873.0, 865.0], [873.0, 1146.0], [840.0, 1146.0]], [[795.0, 862.0], [826.0, 862.0], [826.0, 1062.0], [795.0, 1062.0]]], "lines": ["一矢口先輩のところへ", "今すぐ行ってあげて", "ください。」と。"]}, {"box": [522, 1054, 623, 1290], "vertical": true, "font_size": 27, "lines_coords": [[[593.0, 1054.0], [621.0, 1054.0], [623.0, 1225.0], [595.0, 1225.0]], [[557.0, 1054.0], [584.0, 1054.0], [585.0, 1289.0], [559.0, 1289.0]], [[523.0, 1056.0], [550.0, 1056.0], [550.0, 1259.0], [523.0, 1259.0]]], "lines": ["「今の先輩には", "愛子ちゃんがきっと", "必要なのて．．．」と。"]}, {"box": [106, 1361, 167, 1468], "vertical": true, "font_size": 26, "lines_coords": [[[106.0, 1362.0], [132.0, 1362.0], [132.0, 1467.0], [106.0, 1467.0]]], "lines": ["なんで？"]}], "img_path": "167.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [687, 390, 757, 537], "vertical": true, "font_size": 32, "lines_coords": [[[720.0, 390.0], [757.0, 390.0], [757.0, 454.0], [720.0, 454.0]], [[687.0, 392.0], [714.0, 392.0], [717.0, 537.0], [690.0, 537.0]]], "lines": ["意味", "わかんない。"]}, {"box": [93, 373, 179, 551], "vertical": true, "font_size": 40, "lines_coords": [[[131.0, 373.0], [179.0, 373.0], [179.0, 451.0], [131.0, 451.0]], [[93.0, 376.0], [126.0, 376.0], [129.0, 551.0], [96.0, 551.0]]], "lines": ["意味", "わかんない。"]}, {"box": [676, 1347, 705, 1487], "vertical": true, "font_size": 27, "lines_coords": [[[676.0, 1348.0], [703.0, 1348.0], [703.0, 1481.0], [676.0, 1481.0]]], "lines": ["フンフンは"]}, {"box": [403, 1346, 506, 1532], "vertical": true, "font_size": 29, "lines_coords": [[[478.0, 1346.0], [506.0, 1346.0], [506.0, 1454.0], [478.0, 1454.0]], [[442.0, 1348.0], [468.0, 1348.0], [468.0, 1531.0], [442.0, 1531.0]], [[403.0, 1346.0], [435.0, 1346.0], [435.0, 1439.0], [403.0, 1439.0]]], "lines": ["こわくて", "振り返れません", "でした。"]}], "img_path": "168.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [956, 921, 988, 1093], "vertical": true, "font_size": 28, "lines_coords": [[[956.0, 1026.0], [984.0, 1025.0], [987.0, 1089.0], [959.0, 1090.0]], [[959.0, 921.0], [987.0, 921.0], [984.0, 1025.0], [956.0, 1025.0]]], "lines": ["ーン。", "プンプー"]}, {"box": [760, 1003, 793, 1089], "vertical": true, "font_size": 33, "lines_coords": [[[760.0, 1003.0], [793.0, 1003.0], [793.0, 1089.0], [760.0, 1089.0]]], "lines": ["はいはい"]}, {"box": [560, 947, 588, 1039], "vertical": true, "font_size": 28, "lines_coords": [[[560.0, 947.0], [588.0, 947.0], [588.0, 1039.0], [560.0, 1039.0]]], "lines": ["ーー今、"]}, {"box": [442, 951, 507, 1135], "vertical": true, "font_size": 26, "lines_coords": [[[476.0, 951.0], [503.0, 951.0], [503.0, 1129.0], [476.0, 1129.0]], [[442.0, 951.0], [468.0, 951.0], [468.0, 1084.0], [442.0, 1084.0]]], "lines": ["ただはっきりと", "わかるのは"]}, {"box": [325, 950, 389, 1184], "vertical": true, "font_size": 27.5, "lines_coords": [[[362.0, 951.0], [389.0, 951.0], [389.0, 1184.0], [362.0, 1184.0]], [[325.0, 950.0], [353.0, 950.0], [353.0, 1089.0], [325.0, 1089.0]]], "lines": ["ゆうへの雪のせいで", "より際立つ、"]}, {"box": [207, 948, 275, 1133], "vertical": true, "font_size": 28, "lines_coords": [[[243.0, 948.0], [271.0, 948.0], [273.0, 1132.0], [245.0, 1132.0]], [[207.0, 948.0], [235.0, 948.0], [237.0, 1115.0], [209.0, 1115.0]]], "lines": ["汚れてしまった", "自分の姿です。"]}, {"box": [707, 1331, 808, 1537], "vertical": true, "font_size": 27, "lines_coords": [[[779.0, 1332.0], [806.0, 1332.0], [806.0, 1465.0], [779.0, 1465.0]], [[743.0, 1331.0], [770.0, 1331.0], [770.0, 1537.0], [743.0, 1537.0]], [[707.0, 1332.0], [734.0, 1332.0], [734.0, 1464.0], [707.0, 1464.0]]], "lines": ["獣姦と死姦", "だったら、どっちが", "興味ある？"]}, {"box": [364, 1260, 390, 1445], "vertical": true, "font_size": 26, "lines_coords": [[[364.0, 1260.0], [390.0, 1260.0], [390.0, 1445.0], [364.0, 1445.0]]], "lines": ["できることなら"]}, {"box": [271, 1259, 334, 1415], "vertical": true, "font_size": 26, "lines_coords": [[[307.0, 1259.0], [334.0, 1259.0], [334.0, 1415.0], [307.0, 1415.0]], [[271.0, 1260.0], [298.0, 1260.0], [298.0, 1395.0], [271.0, 1395.0]]], "lines": ["この真っ白な", "雪に溶けて、"]}, {"box": [115, 1259, 240, 1468], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 1259.0], [240.0, 1259.0], [240.0, 1365.0], [214.0, 1365.0]], [[179.0, 1259.0], [206.0, 1259.0], [206.0, 1468.0], [179.0, 1468.0]], [[145.0, 1259.0], [171.0, 1259.0], [171.0, 1417.0], [145.0, 1417.0]], [[115.0, 1260.0], [137.0, 1260.0], [137.0, 1400.0], [115.0, 1400.0]]], "lines": ["何もかも", "消えて失くなって", "しまいたいと", "思いました。"]}], "img_path": "169.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [65, 1031, 282, 1262], "vertical": true, "font_size": 89, "lines_coords": [[[137.0, 1051.0], [221.0, 1031.0], [270.0, 1242.0], [185.0, 1262.0]], [[65.0, 1064.0], [154.0, 1040.0], [204.0, 1228.0], [115.0, 1251.0]]], "lines": ["泣いてん", "じゃん。"]}, {"box": [515, 1031, 646, 1192], "vertical": false, "font_size": 41.0, "lines_coords": [[[543.0, 1057.0], [646.0, 1164.0], [618.0, 1192.0], [515.0, 1085.0]], [[565.0, 1031.0], [620.0, 1073.0], [595.0, 1107.0], [540.0, 1065.0]]], "lines": ["おい、さ。", "秋！！"]}, {"box": [732, 878, 789, 932], "vertical": false, "font_size": 30, "lines_coords": [[[751.0, 878.0], [789.0, 909.0], [770.0, 932.0], [732.0, 901.0]]], "lines": ["うん"]}, {"box": [689, 1325, 753, 1516], "vertical": true, "font_size": 28, "lines_coords": [[[690.0, 1326.0], [718.0, 1326.0], [720.0, 1514.0], [692.0, 1514.0]]], "lines": ["泣きません！！"]}], "img_path": "170.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "171.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [235, 248, 479, 686], "vertical": true, "font_size": 104, "lines_coords": [[[376.0, 257.0], [479.0, 257.0], [479.0, 662.0], [376.0, 662.0]], [[235.0, 250.0], [340.0, 248.0], [346.0, 651.0], [242.0, 653.0]]], "lines": ["おやすみっ", "浅野いに