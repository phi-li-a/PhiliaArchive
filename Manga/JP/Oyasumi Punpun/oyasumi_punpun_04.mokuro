, 881.0], [250.0, 1078.0], [229.0, 1078.0]]], "lines": ["まーーあたしの", "教育方針も", "あながち間違って", "なかったってコト！？"]}, {"box": [153, 1045, 179, 1164], "vertical": true, "font_size": 23, "lines_coords": [[[153.0, 1045.0], [179.0, 1045.0], [179.0, 1164.0], [153.0, 1164.0]]], "lines": ["アハアハ！！"]}, {"box": [920, 1336, 946, 1446], "vertical": true, "font_size": 26, "lines_coords": [[[920.0, 1340.0], [946.0, 1340.0], [946.0, 1446.0], [920.0, 1446.0]]], "lines": ["．．．．．．ハァ。"]}, {"box": [250, 1256, 337, 1401], "vertical": true, "font_size": 24, "lines_coords": [[[315.0, 1259.0], [337.0, 1259.0], [337.0, 1401.0], [315.0, 1401.0]], [[279.0, 1256.0], [307.0, 1256.0], [307.0, 1337.0], [279.0, 1337.0]], [[250.0, 1259.0], [271.0, 1259.0], [271.0, 1379.0], [250.0, 1379.0]]], "lines": ["．．．ちょっとォ", "～～～", "翠ちゃん！？"]}, {"box": [100, 1368, 223, 1537], "vertical": true, "font_size": 24, "lines_coords": [[[200.0, 1368.0], [223.0, 1368.0], [220.0, 1490.0], [196.0, 1490.0]], [[160.0, 1368.0], [189.0, 1368.0], [190.0, 1537.0], [162.0, 1537.0]], [[131.0, 1371.0], [157.0, 1371.0], [157.0, 1515.0], [131.0, 1515.0]], [[100.0, 1373.0], [121.0, 1373.0], [121.0, 1535.0], [100.0, 1535.0]]], "lines": ["まだ一週間", "でしょォ～～！？", "雄一が帰って", "こなくなって！！"]}], "img_path": "219.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [890, 81, 1004, 265], "vertical": true, "font_size": 29, "lines_coords": [[[978.0, 82.0], [1004.0, 82.0], [1004.0, 237.0], [978.0, 237.0]], [[950.0, 82.0], [976.0, 82.0], [976.0, 239.0], [950.0, 239.0]], [[920.0, 82.0], [946.0, 82.0], [946.0, 265.0], [920.0, 265.0]], [[892.0, 81.0], [918.0, 81.0], [917.0, 265.0], [890.0, 265.0]]], "lines": ["確かに雄一の", "人間性なんて", "ウンコと紙一重", "だけどさァ．．．"]}, {"box": [818, 245, 889, 356], "vertical": true, "font_size": 29, "lines_coords": [[[846.0, 245.0], [889.0, 245.0], [889.0, 312.0], [846.0, 312.0]], [[818.0, 250.0], [846.0, 250.0], [846.0, 356.0], [818.0, 356.0]]], "lines": ["心配", "し過ぎ！！"]}, {"box": [504, 73, 606, 205], "vertical": t