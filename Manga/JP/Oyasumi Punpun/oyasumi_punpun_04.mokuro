95.0], [321.0, 1295.0], [321.0, 1393.0], [295.0, 1393.0]], [[262.0, 1293.0], [289.0, 1293.0], [289.0, 1451.0], [262.0, 1451.0]], [[229.0, 1295.0], [256.0, 1295.0], [256.0, 1460.0], [229.0, 1460.0]]], "lines": ["その金額", "考えたら、全然", "チャラでしょ？"]}, {"box": [103, 1373, 165, 1535], "vertical": true, "font_size": 26, "lines_coords": [[[139.0, 1373.0], [165.0, 1373.0], [165.0, 1535.0], [139.0, 1535.0]], [[103.0, 1373.0], [129.0, 1373.0], [129.0, 1479.0], [103.0, 1479.0]]], "lines": ["頭固いんだよ、", "アイツ！！"]}], "img_path": "218.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [976, 65, 998, 201], "vertical": true, "font_size": 28, "lines_coords": [[[976.0, 65.0], [998.0, 65.0], [998.0, 201.0], [976.0, 201.0]]], "lines": ["お姉さんも、"]}, {"box": [843, 220, 964, 379], "vertical": true, "font_size": 28, "lines_coords": [[[928.0, 220.0], [964.0, 220.0], [964.0, 281.0], [928.0, 281.0]], [[901.0, 221.0], [928.0, 221.0], [928.0, 379.0], [901.0, 379.0]], [[870.0, 220.0], [898.0, 220.0], [900.0, 379.0], [871.0, 379.0]], [[843.0, 221.0], [871.0, 221.0], [871.0, 312.0], [843.0, 312.0]]], "lines": ["一度", "言い出したら", "引かないです", "けどね。"]}, {"box": [259, 75, 323, 234], "vertical": true, "font_size": 25, "lines_coords": [[[295.0, 76.0], [323.0, 76.0], [323.0, 185.0], [295.0, 185.0]], [[259.0, 75.0], [285.0, 75.0], [285.0, 234.0], [259.0, 234.0]]], "lines": ["だ～～～", "～～からっ！！"]}, {"box": [140, 250, 237, 407], "vertical": true, "font_size": 25, "lines_coords": [[[210.0, 250.0], [237.0, 250.0], [237.0, 357.0], [210.0, 357.0]], [[176.0, 253.0], [198.0, 253.0], [198.0, 407.0], [176.0, 407.0]], [[140.0, 253.0], [162.0, 253.0], [162.0, 381.0], [140.0, 381.0]]], "lines": ["この家は", "もう売るって", "決めたの！！"]}, {"box": [956, 517, 978, 662], "vertical": true, "font_size": 23, "lines_coords": [[[956.0, 517.0], [978.0, 517.0], [978.0, 662.0], [956.0, 662.0]]], "lines": ["．．．そういえば、"]}, {"box": [814, 603, 925, 798], "vertical": true, "font_size": 23, "lines_coords": [[[898.0, 603.0], [9