: true, "font_size": 24, "lines_coords": [[[907.0, 89.0], [931.0, 89.0], [934.0, 217.0], [910.0, 217.0]]], "lines": ["．．．．．さぁ．．．"]}, {"box": [539, 118, 602, 275], "vertical": true, "font_size": 24, "lines_coords": [[[573.0, 118.0], [600.0, 118.0], [600.0, 250.0], [573.0, 250.0]], [[540.0, 118.0], [562.0, 118.0], [562.0, 273.0], [540.0, 273.0]]], "lines": ["小野寺さん", "にはもう．．．"]}, {"box": [407, 526, 473, 682], "vertical": true, "font_size": 26, "lines_coords": [[[445.0, 526.0], [471.0, 526.0], [471.0, 682.0], [445.0, 682.0]], [[407.0, 526.0], [434.0, 526.0], [434.0, 668.0], [407.0, 668.0]]], "lines": ["関係ないじゃ", "ないですか。"]}, {"box": [112, 514, 176, 698], "vertical": true, "font_size": 28, "lines_coords": [[[145.0, 514.0], [173.0, 514.0], [175.0, 698.0], [146.0, 698.0]], [[112.0, 517.0], [139.0, 517.0], [139.0, 659.0], [112.0, 659.0]]], "lines": ["．．．心配しなくて", "いいですよ。"]}, {"box": [765, 940, 832, 1128], "vertical": true, "font_size": 30, "lines_coords": [[[798.0, 940.0], [832.0, 940.0], [832.0, 1026.0], [798.0, 1026.0]], [[765.0, 945.0], [792.0, 945.0], [792.0, 1125.0], [765.0, 1125.0]]], "lines": ["私には", "いつだって．．．"]}, {"box": [257, 1160, 364, 1333], "vertical": true, "font_size": 30, "lines_coords": [[[328.0, 1160.0], [364.0, 1162.0], [360.0, 1246.0], [325.0, 1245.0]], [[295.0, 1164.0], [321.0, 1164.0], [321.0, 1321.0], [295.0, 1321.0]], [[257.0, 1162.0], [284.0, 1162.0], [284.0, 1331.0], [257.0, 1331.0]]], "lines": ["神様が", "見守っていて", "くれますから。"]}], "img_path": "060.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [671, 1267, 734, 1410], "vertical": true, "font_size": 24, "lines_coords": [[[706.0, 1267.0], [732.0, 1267.0], [732.0, 1400.0], [706.0, 1400.0]], [[671.0, 1270.0], [693.0, 1270.0], [693.0, 1406.0], [671.0, 1406.0]]], "lines": ["僕はその時", "思ったんだ"]}, {"box": [429, 1265, 535, 1455], "vertical": true, "font_size": 34, "lines_coords": [[[506.0, 1270.0], [534.0, 1270.0], [534.0, 1376.0], [506.0, 1376.0]], [[468.0, 1268.0], [500.0, 1268.0], [500.0, 1454.0], [468.0, 1454.0]], [[429.0, 1265.0], [470.0, 1265.0], [470.0, 1339.0], [429.0, 1339.0]]], "lines": ["神様って", "なんなんだろう", "って。"]}], "img_path": "061.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [653, 523, 717, 662], "vertical": true, "font_size": 26, "lines_coords": [[[689.0, 523.0], [715.0, 523.0], [715.0, 628.0], [689.0, 628.0]], [[653.0, 523.0], [679.0, 523.0], [679.0, 656.0], [653.0, 656.0]]], "lines": ["いるとか", "いないとか"]}, {"box": [545, 520, 620, 730], "vertical": true, "font_size": 33, "lines_coords": [[[590.0, 521.0], [617.0, 521.0], [617.0, 728.0], [590.0, 728.0]], [[545.0, 521.0], [584.0, 520.0], [589.0, 610.0], [550.0, 612.0]]], "lines": ["そういうことしゃ", "なくて、"]}, {"box": [364, 521, 503, 733], "vertical": true, "font_size": 26, "lines_coords": [[[475.0, 523.0], [501.0, 523.0], [501.0, 654.0], [475.0, 654.0]], [[439.0, 523.0], [465.0, 523.0], [465.0, 706.0], [439.0, 706.0]], [[401.0, 525.0], [428.0, 525.0], [428.0, 732.0], [401.0, 732.0]], [[364.0, 521.0], [390.0, 521.0], [393.0, 665.0], [367.0, 665.0]]], "lines": ["あの少女か", "信じた神様って", "一体なんだったん", "だろうって。"]}, {"box": [528, 1364, 701, 1556], "vertical": true, "font_size": 27, "lines_coords": [[[673.0, 1367.0], [700.0, 1367.0], [700.0, 1521.0], [673.0, 1521.0]], [[637.0, 1365.0], [664.0, 1365.0], [664.0, 1548.0], [637.0, 1548.0]], [[598.0, 1364.0], [629.0, 1364.0], [629.0, 1528.0], [598.0, 1528.0]], [[564.0, 1364.0], [590.0, 1364.0], [590.0, 1525.0], [564.0, 1525.0]], [[528.0, 1368.0], [550.0, 1368.0], [550.0, 1550.0], [528.0, 1550.0]]], "lines": ["たとえ、その", "神様と呼ばれる", "存在の正体か、", "とす黒い魔物", "だったとしても"]}, {"box": [310, 1364, 448, 1523], "vertical": true, "font_size": 26, "lines_coords": [[[423.0, 1368.0], [445.0, 1368.0], [445.0, 1521.0], [423.0, 1521.0]], [[385.0, 1365.0], [412.0, 1365.0], [412.0, 1523.0], [385.0, 1523.0]], [[348.0, 1367.0], [375.0, 1367.0], [375.0, 1521.0], [348.0, 1521.0]], [[310.0, 1367.0], [337.0, 1367.0], [340.0, 1479.0], [314.0, 1479.0]]], "lines": ["それにすがる", "しかないのが", "人間なのかも", "しれない。"]}], "img_path": "062.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [742, 107, 969, 532], "vertical": true, "font_size": 68, "lines_coords": [[[901.0, 168.0], [959.0, 168.0], [964.0, 507.0], [906.0, 507.0]], [[810.0, 109.0], [892.0, 107.0], [903.0, 520.0], [821.0, 521.0]], [[743.0, 115.0], [806.0, 115.0], [806.0, 301.0], [743.0, 301.0]]], "lines": ["そう思うと、", "目の前に広がる", "景色が"]}, {"box": [218, 107, 384, 529], "vertical": true, "font_size": 85, "lines_coords": [[[284.0, 110.0], [370.0, 107.0], [384.0, 498.0], [298.0, 501.0]], [[218.0, 109.0], [301.0, 107.0], [306.0, 495.0], [223.0, 496.0]]], "lines": ["いつもより少し", "歪んで見えた。"]}, {"box": [615, 714, 751, 899], "vertical": true, "font_size": 23, "lines_coords": [[[726.0, 717.0], [746.0, 717.0], [746.0, 843.0], [726.0, 843.0]], [[689.0, 717.0], [710.0, 717.0], [710.0, 840.0], [689.0, 840.0]], [[654.0, 718.0], [676.0, 718.0], [676.0, 893.0], [654.0, 893.0]], [[615.0, 717.0], [643.0, 717.0], [643.0, 773.0], [615.0, 773.0]]], "lines": ["雑踏の中に", "消えてゆく", "少女の後ろ姿を", "見て、"]}, {"box": [418, 714, 481, 910], "vertical": true, "font_size": 24, "lines_coords": [[[454.0, 715.0], [481.0, 715.0], [481.0, 843.0], [454.0, 843.0]], [[418.0, 717.0], [440.0, 717.0], [440.0, 904.0], [418.0, 904.0]]], "lines": ["僕はやっと", "気が付いたんだ"]}, {"box": [615, 1082, 677, 1253], "vertical": true, "font_size": 62, "lines_coords": [[[615.0, 1082.0], [677.0, 1082.0], [677.0, 1253.0], [615.0, 1253.0]]], "lines": ["はじめて会ったその瞬間、"]}, {"box": [477, 1075, 686, 1399], "vertical": true, "font_size": 26, "lines_coords": [[[648.0, 1079.0], [675.0, 1079.0], [676.0, 1260.0], [650.0, 1260.0]], [[614.0, 1079.0], [640.0, 1079.0], [640.0, 1189.0], [614.0, 1189.0]]], "lines": ["はじめて会った", "その瞬間、"]}, {"box": [479, 1209, 580, 1397], "vertical": true, "font_size": 25, "lines_coords": [[[551.0, 1210.0], [578.0, 1210.0], [578.0, 1393.0], [551.0, 1393.0]], [[514.0, 1210.0], [540.0, 1210.0], [540.0, 1371.0], [514.0, 1371.0]], [[481.0, 1212.0], [503.0, 1212.0], [503.0, 1379.0], [481.0, 1379.0]]], "lines": ["僕はあの少女に", "恋をしていた", "ということを。"]}], "img_path": "063.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [735, 136, 798, 302], "vertical": true, "font_size": 24, "lines_coords": [[[770.0, 139.0], [798.0, 139.0], [798.0, 170.0], [770.0, 170.0]], [[737.0, 142.0], [757.0, 142.0], [757.0, 293.0], [737.0, 293.0]]], "lines": ["今、", "名前を呼べば"]}, {"box": [446, 137, 585, 348], "vertical": true, "font_size": 25, "lines_coords": [[[556.0, 137.0], [582.0, 137.0], [582.0, 295.0], [556.0, 295.0]], [[520.0, 137.0], [546.0, 137.0], [546.0, 270.0], [520.0, 270.0]], [[484.0, 137.0], [510.0, 137.0], [510.0, 348.0], [484.0, 348.0]], [[446.0, 139.0], [468.0, 139.0], [468.0, 328.0], [446.0, 328.0]]], "lines": ["雑踏の中から", "あの少女か", "戻ってきてくれる", "ような気がした。"]}, {"box": [706, 1314, 731, 1477], "vertical": true, "font_size": 21, "lines_coords": [[[707.0, 1317.0], [728.0, 1317.0], [728.0, 1470.0], [707.0, 1470.0]]], "lines": ["．．．けれと僕は"]}, {"box": [426, 1312, 528, 1523], "vertical": true, "font_size": 27, "lines_coords": [[[498.0, 1312.0], [525.0, 1312.0], [526.0, 1521.0], [500.0, 1521.0]], [[462.0, 1314.0], [489.0, 1314.0], [489.0, 1470.0], [462.0, 1470.0]], [[426.0, 1314.0], [453.0, 1314.0], [453.0, 1507.0], [426.0, 1507.0]]], "lines": ["少女の下の名前を", "結局知らない", "ままだったんだ。"]}], "img_path": "064.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [633, 156, 948, 561], "vertical": true, "font_size": 315, "lines_coords": [[[633.0, 156.0], [948.0, 156.0], [948.0, 561.0], [633.0, 561.0]]], "lines": ["綾"]}, {"box": [465, 239, 584, 468], "vertical": true, "font_size": 57, "lines_coords": [[[504.0, 239.0], [584.0, 254.0], [545.0, 468.0], [465.0, 453.0]], [[481.0, 257.0], [514.0, 256.0], [518.0, 337.0], [485.0, 339.0]]], "lines": ["そういえば、", "あ．．．"]}, {"box": [882, 696, 909, 828], "vertical": true, "font_size": 27, "lines_coords": [[[882.0, 696.0], [909.0, 696.0], [909.0, 826.0], [882.0, 826.0]]], "lines": ["これが．．．"]}, {"box": [904, 982, 933, 1167], "vertical": true, "font_size": 26, "lines_coords": [[[906.0, 982.0], [932.0, 982.0], [931.0, 1165.0], [904.0, 1165.0]]], "lines": ["．．．ひいたかい？"]}, {"box": [173, 743, 273, 929], "vertical": true, "font_size": 29, "lines_coords": [[[245.0, 746.0], [271.0, 746.0], [270.0, 929.0], [243.0, 929.0]], [[206.0, 743.0], [239.0, 743.0], [239.0, 853.0], [206.0, 853.0]], [[173.0, 745.0], [200.0, 745.0], [200.0, 890.0], [173.0, 890.0]]], "lines": ["五年前に起きた", "出来事の", "すべてだよ。"]}, {"box": [482, 1355, 513, 1476], "vertical": true, "font_size": 28, "lines_coords": [[[482.0, 1357.0], [510.0, 1357.0], [510.0, 1475.0], [482.0, 1475.0]]], "lines": ["はい。．．．。"]}], "img_path": "065.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [893, 98, 990, 270], "vertical": true, "font_size": 25, "lines_coords": [[[968.0, 104.0], [990.0, 104.0], [990.0, 257.0], [968.0, 257.0]], [[935.0, 104.0], [957.0, 104.0], [957.0, 270.0], [935.0, 270.0]], [[893.0, 100.0], [929.0, 98.0], [932.0, 165.0], [896.0, 167.0]]], "lines": ["．．．結果、二人も", "怪我人を出した", "んだ。"]}, {"box": [750, 125, 873, 340], "vertical": true, "font_size": 25, "lines_coords": [[[851.0, 126.0], [873.0, 126.0], [873.0, 317.0], [851.0, 317.0]], [[815.0, 125.0], [842.0, 125.0], [842.0, 321.0], [815.0, 321.0]], [[784.0, 126.0], [806.0, 126.0], [806.0, 340.0], [784.0, 340.0]], [[750.0, 125.0], [776.0, 125.0], [776.0, 331.0], [750.0, 331.0]]], "lines": ["陶芸教室は潰れは", "しなかったけれど、", "その後の立て直しが", "大変そうだったよ。"]}, {"box": [359, 162, 495, 400], "vertical": true, "font_size": 26, "lines_coords": [[[464.0, 162.0], [492.0, 162.0], [495.0, 298.0], [467.0, 298.0]], [[431.0, 164.0], [457.0, 164.0], [457.0, 362.0], [431.0, 362.0]], [[395.0, 165.0], [421.0, 165.0], [421.0, 400.0], [395.0, 400.0]], [[359.0, 164.0], [385.0, 164.0], [385.0, 359.0], [359.0, 359.0]]], "lines": ["．．．彼女とも", "それ以降、なぜか", "噛み合わなくなって", "別れてしまった。"]}, {"box": [92, 54, 381, 81], "vertical": false, "font_size": 27, "lines_coords": [[[92.0, 54.0], [381.0, 54.0], [381.0, 81.0], [92.0, 81.0]]], "lines": ["おやすみプンプン図"]}, {"box": [123, 225, 188, 334], "vertical": true, "font_size": 28, "lines_coords": [[[159.0, 225.0], [187.0, 225.0], [187.0, 334.0], [159.0, 334.0]], [[123.0, 225.0], [151.0, 225.0], [151.0, 332.0], [123.0, 332.0]]], "lines": ["あれから", "五年．．．"]}, {"box": [631, 590, 767, 802], "vertical": true, "font_size": 26, "lines_coords": [[[742.0, 595.0], [764.0, 595.0], [764.0, 696.0], [742.0, 696.0]], [[703.0, 590.0], [729.0, 590.0], [729.0, 801.0], [703.0, 801.0]], [[664.0, 592.0], [690.0, 592.0], [693.0, 778.0], [667.0, 778.0]], [[631.0, 593.0], [659.0, 593.0], [659.0, 698.0], [631.0, 698.0]]], "lines": ["僕はその", "どさくさに紛れて", "辞めてしまった", "けど．．．"]}, {"box": [84, 603, 222, 814], "vertical": true, "font_size": 25, "lines_coords": [[[192.0, 604.0], [218.0, 604.0], [218.0, 762.0], [192.0, 762.0]], [[156.0, 604.0], [182.0, 604.0], [182.0, 743.0], [156.0, 743.0]], [[120.0, 604.0], [146.0, 604.0], [146.0, 787.0], [120.0, 787.0]], [[84.0, 606.0], [106.0, 606.0], [106.0, 814.0], [84.0, 814.0]]], "lines": ["誰にも頼らず", "何も信じず、", "思考を放棄して", "ただ生きてきた．．．"]}, {"box": [942, 943, 964, 1039], "vertical": true, "font_size": 24, "lines_coords": [[[942.0, 943.0], [964.0, 943.0], [964.0, 1039.0], [942.0, 1039.0]]], "lines": ["僕は．．．"]}, {"box": [779, 975, 876, 1134], "vertical": true, "font_size": 24, "lines_coords": [[[850.0, 975.0], [876.0, 975.0], [876.0, 1134.0], [850.0, 1134.0]], [[814.0, 976.0], [840.0, 976.0], [840.0, 1109.0], [814.0, 1109.0]], [[779.0, 978.0], [801.0, 978.0], [801.0, 1132.0], [779.0, 1132.0]]], "lines": ["．．．ただ漠然と", "わからなく", "なったんだ．．．"]}, {"box": [276, 935, 403, 1104], "vertical": true, "font_size": 26, "lines_coords": [[[376.0, 935.0], [403.0, 935.0], [403.0, 1034.0], [376.0, 1034.0]], [[343.0, 935.0], [370.0, 935.0], [370.0, 1104.0], [343.0, 1104.0]], [[312.0, 937.0], [334.0, 937.0], [334.0, 1054.0], [312.0, 1054.0]], [[276.0, 935.0], [304.0, 935.0], [304.0, 1035.0], [276.0, 1035.0]]], "lines": ["人と人が", "自我という棘で", "傷つけ合い", "ながら．．"]}, {"box": [148, 982, 250, 1168], "vertical": true, "font_size": 26, "lines_coords": [[[220.0, 982.0], [248.0, 982.0], [250.0, 1168.0], [221.0, 1168.0]], [[184.0, 984.0], [210.0, 984.0], [210.0, 1118.0], [184.0, 1118.0]], [[148.0, 984.0], [175.0, 984.0], [175.0, 1118.0], [148.0, 1118.0]]], "lines": ["それでも人間が", "生きてゆく", "理由が．．．．．"]}, {"box": [93, 1309, 232, 1596], "vertical": true, "font_size": 68, "lines_coords": [[[159.0, 1309.0], [232.0, 1309.0], [232.0, 1501.0], [159.0, 1501.0]], [[93.0, 1312.0], [157.0, 1312.0], [157.0, 1596.0], [93.0, 1596.0]]], "lines": ["．．．人間", "なんてっ！！"]}], "img_path": "066.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [543, 186, 567, 329], "vertical": true, "font_size": 22, "lines_coords": [[[543.0, 189.0], [565.0, 189.0], [565.0, 326.0], [543.0, 326.0]]], "lines": ["人間なんて．．．"]}, {"box": [267, 556, 371, 729], "vertical": true, "font_size": 50, "lines_coords": [[[321.0, 556.0], [371.0, 556.0], [371.0, 725.0], [321.0, 725.0]], [[267.0, 556.0], [317.0, 556.0], [317.0, 729.0], [267.0, 729.0]]], "lines": ["大っ嫌い", "だ．．．．．！！"]}, {"box": [890, 985, 920, 1120], "vertical": true, "font_size": 28, "lines_coords": [[[890.0, 985.0], [918.0, 985.0], [920.0, 1115.0], [892.0, 1115.0]]], "lines": ["人間を．．．．．"]}, {"box": [173, 1079, 202, 1212], "vertical": true, "font_size": 27, "lines_coords": [[[173.0, 1079.0], [200.0, 1079.0], [200.0, 1212.0], [173.0, 1212.0]]], "lines": ["．．．ですか？"]}], "img_path": "067.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [539, 75, 567, 242], "vertical": true, "font_size": 26, "lines_coords": [[[539.0, 75.0], [565.0, 75.0], [565.0, 239.0], [539.0, 239.0]]], "lines": ["．．．自分なんて、"]}, {"box": [117, 226, 145, 396], "vertical": true, "font_size": 26, "lines_coords": [[[117.0, 228.0], [143.0, 228.0], [143.0, 393.0], [117.0, 393.0]]], "lines": ["．．．大っ嫌いだ。"]}, {"box": [862, 721, 890, 917], "vertical": true, "font_size": 27, "lines_coords": [[[862.0, 721.0], [889.0, 721.0], [889.0, 915.0], [862.0, 915.0]]], "lines": ["私は好きですよ。"]}, {"box": [193, 901, 262, 1062], "vertical": true, "font_size": 31, "lines_coords": [[[234.0, 906.0], [260.0, 906.0], [260.0, 1062.0], [234.0, 1062.0]], [[193.0, 901.0], [229.0, 901.0], [229.0, 976.0], [193.0, 976.0]]], "lines": ["小野寺さんの", "こと。"]}, {"box": [857, 1241, 921, 1451], "vertical": true, "font_size": 28, "lines_coords": [[[892.0, 1242.0], [920.0, 1242.0], [920.0, 1371.0], [892.0, 1371.0]], [[857.0, 1242.0], [884.0, 1242.0], [884.0, 1451.0], [857.0, 1451.0]]], "lines": ["．．．昔に何が", "あったとしても．．．"]}, {"box": [112, 1338, 213, 1496], "vertical": true, "font_size": 27, "lines_coords": [[[185.0, 1339.0], [212.0, 1339.0], [212.0, 1443.0], [185.0, 1443.0]], [[148.0, 1340.0], [175.0, 1340.0], [175.0, 1496.0], [148.0, 1496.0]], [[112.0, 1339.0], [139.0, 1339.0], [139.0, 1457.0], [112.0, 1457.0]]], "lines": ["私は今の", "小野寺さんが", "好きです。"]}], "img_path": "068.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [968, 120, 995, 227], "vertical": true, "font_size": 27, "lines_coords": [[[968.0, 120.0], [995.0, 120.0], [995.0, 226.0], [968.0, 226.0]]], "lines": ["僕は．．．"]}, {"box": [409, 36, 448, 250], "vertical": true, "font_size": 37, "lines_coords": [[[409.0, 37.0], [446.0, 37.0], [446.0, 250.0], [409.0, 250.0]]], "lines": ["違うでしょ！！"]}, {"box": [693, 529, 756, 714], "vertical": true, "font_size": 22, "lines_coords": [[[729.0, 531.0], [751.0, 531.0], [751.0, 712.0], [729.0, 712.0]], [[693.0, 529.0], [715.0, 529.0], [715.0, 685.0], [693.0, 685.0]]], "lines": ["君を傷つけたく", "ないんだ．．．．．"]}, {"box": [106, 503, 247, 714], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 506.0], [243.0, 506.0], [243.0, 685.0], [217.0, 685.0]], [[181.0, 504.0], [207.0, 504.0], [204.0, 689.0], [178.0, 689.0]], [[143.0, 504.0], [170.0, 504.0], [170.0, 689.0], [143.0, 689.0]], [[106.0, 503.0], [132.0, 503.0], [132.0, 714.0], [106.0, 714.0]]], "lines": ["小野寺さんはっ", "．．．ただ自分が", "傷つきたくない", "だけなんでしょ！？"]}, {"box": [892, 834, 956, 1019], "vertical": true, "font_size": 27, "lines_coords": [[[929.0, 837.0], [956.0, 837.0], [956.0, 970.0], [929.0, 970.0]], [[893.0, 834.0], [920.0, 834.0], [918.0, 1017.0], [892.0, 1017.0]]], "lines": ["今から行き", "ませんか．．．．？"]}, {"box": [229, 906, 298, 1092], "vertical": true, "font_size": 29, "lines_coords": [[[264.0, 906.0], [295.0, 906.0], [298.0, 1092.0], [267.0, 1092.0]], [[232.0, 907.0], [260.0, 907.0], [257.0, 1067.0], [229.0, 1067.0]]], "lines": ["：小野寺さんが", "働いてた．．．"]}, {"box": [165, 1103, 195, 1220], "vertical": true, "font_size": 29, "lines_coords": [[[165.0, 1103.0], [192.0, 1103.0], [195.0, 1220.0], [168.0, 1220.0]]], "lines": ["陶芸教室。"]}], "img_path": "069.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [810, 106, 875, 460], "vertical": true, "font_size": 65, "lines_coords": [[[810.0, 106.0], [875.0, 106.0], [875.0, 460.0], [810.0, 460.0]]], "lines": ["．．．オホホ！！"]}, {"box": [235, 731, 264, 829], "vertical": true, "font_size": 30, "lines_coords": [[[235.0, 731.0], [264.0, 731.0], [264.0, 829.0], [235.0, 829.0]]], "lines": ["オホホ．．．"]}, {"box": [867, 726, 957, 921], "vertical": true, "font_size": 24, "lines_coords": [[[931.0, 726.0], [957.0, 726.0], [957.0, 920.0], [931.0, 920.0]], [[898.0, 729.0], [925.0, 729.0], [925.0, 896.0], [898.0, 896.0]], [[867.0, 726.0], [893.0, 726.0], [893.0, 921.0], [867.0, 921.0]]], "lines": ["あの雄一って人は", "一体いつ帰って", "くるのかしら～～"]}, {"box": [731, 853, 854, 1032], "vertical": true, "font_size": 24, "lines_coords": [[[828.0, 853.0], [854.0, 853.0], [854.0, 975.0], [828.0, 975.0]], [[795.0, 853.0], [818.0, 853.0], [820.0, 1032.0], [796.0, 1032.0]], [[764.0, 856.0], [785.0, 856.0], [785.0, 1020.0], [764.0, 1020.0]], [[731.0, 856.0], [753.0, 856.0], [753.0, 996.0], [731.0, 996.0]]], "lines": ["昼に買い物", "頼んだのに、もう", "７時まわってる", "じゃない．．．"]}, {"box": [568, 751, 643, 876], "vertical": true, "font_size": 29, "lines_coords": [[[617.0, 753.0], [643.0, 753.0], [643.0, 876.0], [617.0, 876.0]], [[568.0, 751.0], [603.0, 751.0], [603.0, 850.0], [568.0, 850.0]]], "lines": ["．．．まさか", "事故！？"]}, {"box": [500, 864, 526, 985], "vertical": true, "font_size": 29, "lines_coords": [[[500.0, 864.0], [526.0, 864.0], [526.0, 985.0], [500.0, 985.0]]], "lines": ["．．．アッラ～"]}, {"box": [588, 1053, 667, 1176], "vertical": true, "font_size": 79, "lines_coords": [[[588.0, 1053.0], [667.0, 1053.0], [667.0, 1176.0], [588.0, 1176.0]]], "lines": ["チャイ！"]}, {"box": [148, 831, 182, 990], "vertical": true, "font_size": 30, "lines_coords": [[[148.0, 831.0], [179.0, 831.0], [182.0, 990.0], [151.0, 990.0]]], "lines": ["知るかっ！！"]}, {"box": [528, 1321, 684, 1518], "vertical": true, "font_size": 24, "lines_coords": [[[660.0, 1325.0], [682.0, 1325.0], [682.0, 1462.0], [660.0, 1462.0]], [[625.0, 1321.0], [651.0, 1321.0], [651.0, 1518.0], [625.0, 1518.0]], [[592.0, 1323.0], [618.0, 1323.0], [618.0, 1514.0], [592.0, 1514.0]], [[560.0, 1323.0], [582.0, 1323.0], [582.0, 1489.0], [560.0, 1489.0]], [[528.0, 1323.0], [550.0, 1323.0], [550.0, 1473.0], [528.0, 1473.0]]], "lines": ["何が言いたい", "かっつーとアタシ、", "お酒が無くなると", "とっても不安に", "なっちゃうの。"]}, {"box": [62, 1306, 200, 1565], "vertical": true, "font_size": 29, "lines_coords": [[[168.0, 1306.0], [200.0, 1306.0], [200.0, 1506.0], [168.0, 1506.0]], [[135.0, 1309.0], [162.0, 1309.0], [162.0, 1564.0], [135.0, 1564.0]], [[96.0, 1306.0], [125.0, 1306.0], [128.0, 1437.0], [100.0, 1437.0]], [[62.0, 1309.0], [89.0, 1309.0], [89.0, 1464.0], [62.0, 1464.0]]], "lines": ["てか、さっきから", "シュッシュシュツシュ", "うるさいっ", "つーのっ！！"]}], "img_path": "070.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [353, 0, 792, 409], "vertical": false, "font_size": 248, "lines_coords": [[[353.0, 243.0], [589.0, 0.0], [792.0, 120.0], [556.0, 409.0]]], "lines": ["その"]}, {"box": [429, 493, 482, 595], "vertical": false, "font_size": 26, "lines_coords": [[[429.0, 587.0], [457.0, 493.0], [482.0, 501.0], [454.0, 595.0]]], "lines": ["．．．"]}, {"box": [634, 1060, 759, 1249], "vertical": true, "font_size": 26, "lines_coords": [[[729.0, 1060.0], [757.0, 1060.0], [759.0, 1190.0], [731.0, 1190.0]], [[698.0, 1062.0], [725.0, 1062.0], [725.0, 1242.0], [698.0, 1242.0]], [[667.0, 1062.0], [689.0, 1062.0], [689.0, 1248.0], [667.0, 1248.0]], [[634.0, 1062.0], [660.0, 1062.0], [660.0, 1159.0], [634.0, 1159.0]]], "lines": ["．．．ねぇねぇ、", "アンタ、補欠にも", "選ばれなかったん", "でしょ！？"]}, {"box": [789, 1171, 1001, 1384], "vertical": true, "font_size": 30, "lines_coords": [[[971.0, 1175.0], [1000.0, 1175.0], [1000.0, 1304.0], [971.0, 1304.0]], [[935.0, 1173.0], [962.0, 1173.0], [962.0, 1331.0], [935.0, 1331.0]], [[896.0, 1171.0], [929.0, 1171.0], [929.0, 1356.0], [896.0, 1356.0]], [[862.0, 1173.0], [889.0, 1173.0], [889.0, 1382.0], [862.0, 1382.0]], [[825.0, 1171.0], [856.0, 1171.0], [856.0, 1332.0], [825.0, 1332.0]], [[789.0, 1171.0], [820.0, 1171.0], [820.0, 1384.0], [789.0, 1384.0]]], "lines": ["フンフンは", "明日に控えた", "バドミントンの", "県北大会に備えて", "ジャンシャン", "素振りっ子です！！"]}, {"box": [366, 1367, 456, 1510], "vertical": true, "font_size": 25, "lines_coords": [[[429.0, 1367.0], [456.0, 1367.0], [456.0, 1487.0], [429.0, 1487.0]], [[396.0, 1367.0], [423.0, 1367.0], [423.0, 1510.0], [396.0, 1510.0]], [[367.0, 1368.0], [389.0, 1368.0], [389.0, 1509.0], [367.0, 1509.0]]], "lines": ["素振りって", "意味あんの？", "早く寝たら？"]}, {"box": [135, 1170, 310, 1381], "vertical": true, "font_size": 27, "lines_coords": [[[279.0, 1171.0], [306.0, 1171.0], [309.0, 1328.0], [282.0, 1328.0]], [[243.0, 1170.0], [270.0, 1170.0], [270.0, 1357.0], [243.0, 1357.0]], [[207.0, 1170.0], [234.0, 1170.0], [234.0, 1379.0], [207.0, 1379.0]], [[171.0, 1171.0], [198.0, 1171.0], [198.0, 1354.0], [171.0, 1354.0]], [[135.0, 1170.0], [162.0, 1170.0], [162.0, 1360.0], [135.0, 1360.0]]], "lines": ["そんなことは", "わかってますか", "ほとはしる何かが", "おさえきれない", "フンフンでした。"]}], "img_path": "071.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [864, 95, 998, 355], "vertical": true, "font_size": 60, "lines_coords": [[[939.0, 100.0], [998.0, 100.0], [998.0, 331.0], [939.0, 331.0]], [[871.0, 106.0], [932.0, 107.0], [925.0, 353.0], [864.0, 351.0]]], "lines": ["「俺が優勝", "したら．．．"]}, {"box": [118, 90, 260, 426], "vertical": true, "font_size": 67, "lines_coords": [[[184.0, 112.0], [260.0, 114.0], [254.0, 390.0], [178.0, 389.0]], [[118.0, 90.0], [176.0, 90.0], [181.0, 421.0], [123.0, 421.0]]], "lines": ["「田中は一生", "俺のもんだ！！"]}, {"box": [884, 528, 906, 692], "vertical": true, "font_size": 29, "lines_coords": [[[884.0, 528.0], [906.0, 528.0], [906.0, 692.0], [884.0, 692.0]]], "lines": ["あぁ、なんて！！"]}, {"box": [748, 520, 857, 737], "vertical": true, "font_size": 29, "lines_coords": [[[815.0, 520.0], [857.0, 520.0], [857.0, 737.0], [815.0, 737.0]], [[782.0, 523.0], [814.0, 523.0], [814.0, 709.0], [782.0, 709.0]], [[748.0, 526.0], [775.0, 526.0], [775.0, 709.0], [748.0, 709.0]]], "lines": ["なーんて勝手な", "ことを言う野郎", "なんてしょう！！"]}, {"box": [617, 526, 715, 707], "vertical": true, "font_size": 29, "lines_coords": [[[689.0, 526.0], [715.0, 526.0], [715.0, 682.0], [689.0, 682.0]], [[653.0, 526.0], [679.0, 526.0], [679.0, 707.0], [653.0, 707.0]], [[617.0, 526.0], [643.0, 526.0], [643.0, 657.0], [617.0, 657.0]]], "lines": ["もう心の中で", "呼び捨てにして", "やります！！"]}, {"box": [465, 525, 501, 722], "vertical": true, "font_size": 27, "lines_coords": [[[465.0, 525.0], [492.0, 525.0], [492.0, 720.0], [465.0, 720.0]]], "lines": ["．．．コラ、矢口っ！！"]}, {"box": [170, 524, 344, 762], "vertical": true, "font_size": 27, "lines_coords": [[[315.0, 526.0], [342.0, 526.0], [342.0, 682.0], [315.0, 682.0]], [[276.0, 525.0], [304.0, 525.0], [306.0, 707.0], [278.0, 707.0]], [[242.0, 525.0], [268.0, 525.0], [268.0, 657.0], [242.0, 657.0]], [[206.0, 526.0], [232.0, 526.0], [232.0, 734.0], [206.0, 734.0]], [[170.0, 526.0], [196.0, 526.0], [196.0, 760.0], [170.0, 760.0]]], "lines": ["そんな後輩に", "呼び捨てされる", "ような奴に", "愛子ちゃんを渡す", "訳にはいきません！！"]}, {"box": [940, 1162, 967, 1270], "vertical": true, "font_size": 27, "lines_coords": [[[940.0, 1162.0], [967.0, 1162.0], [967.0, 1270.0], [940.0, 1270.0]]], "lines": ["．．．ですか"]}, {"box": [735, 1157, 949, 1381], "vertical": true, "font_size": 28, "lines_coords": [[[875.0, 1157.0], [907.0, 1157.0], [910.0, 1270.0], [878.0, 1270.0]], [[843.0, 1160.0], [871.0, 1160.0], [868.0, 1293.0], [840.0, 1293.0]], [[806.0, 1159.0], [832.0, 1159.0], [832.0, 1368.0], [806.0, 1368.0]], [[771.0, 1160.0], [798.0, 1160.0], [795.0, 1318.0], [768.0, 1318.0]], [[735.0, 1160.0], [762.0, 1160.0], [762.0, 1379.0], [735.0, 1379.0]]], "lines": ["具体的に", "自分が何を", "どうしていいやら", "さっぱり思い", "つきませんでした。"]}, {"box": [66, 1290, 238, 1539], "vertical": true, "font_size": 28, "lines_coords": [[[210.0, 1290.0], [237.0, 1290.0], [237.0, 1539.0], [210.0, 1539.0]], [[171.0, 1290.0], [203.0, 1290.0], [203.0, 1503.0], [171.0, 1503.0]], [[134.0, 1290.0], [165.0, 1290.0], [165.0, 1501.0], [134.0, 1501.0]], [[100.0, 1292.0], [126.0, 1292.0], [126.0, 1512.0], [100.0, 1512.0]], [[67.0, 1290.0], [89.0, 1290.0], [89.0, 1512.0], [67.0, 1512.0]]], "lines": ["「うっかり事故とかで", "骨がバッキバキに", "なって薬権したり", "しないだろうか．．．」", "．．．と、思いましたが"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [848, 104, 948, 326], "vertical": true, "font_size": 25, "lines_coords": [[[918.0, 104.0], [945.0, 104.0], [945.0, 212.0], [918.0, 212.0]], [[882.0, 106.0], [909.0, 106.0], [909.0, 290.0], [882.0, 290.0]], [[848.0, 106.0], [870.0, 106.0], [870.0, 321.0], [848.0, 321.0]]], "lines": ["その瞬間", "背中のあたりが", "フワッとしたので、"]}, {"box": [607, 745, 710, 940], "vertical": true, "font_size": 29, "lines_coords": [[[682.0, 746.0], [709.0, 746.0], [709.0, 917.0], [682.0, 917.0]], [[643.0, 746.0], [676.0, 746.0], [676.0, 856.0], [643.0, 856.0]], [[607.0, 745.0], [634.0, 745.0], [637.0, 940.0], [610.0, 940.0]]], "lines": ["．．．まぁ、それは", "さすがに", "あんまりなので、"]}, {"box": [351, 746, 527, 879], "vertical": true, "font_size": 26, "lines_coords": [[[498.0, 748.0], [526.0, 748.0], [526.0, 878.0], [498.0, 878.0]], [[460.0, 746.0], [489.0, 746.0], [489.0, 854.0], [460.0, 854.0]], [[425.0, 746.0], [451.0, 746.0], [451.0, 879.0], [425.0, 879.0]], [[390.0, 748.0], [412.0, 748.0], [412.0, 878.0], [390.0, 878.0]], [[351.0, 746.0], [378.0, 746.0], [378.0, 862.0], [351.0, 862.0]]], "lines": ["プンプンは", "これ以上", "考えるのは", "止すことに", "しました。"]}], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [373, 859, 454, 900], "vertical": false, "font_size": 20.5, "lines_coords": [[[373.0, 859.0], [453.0, 859.0], [453.0, 876.0], [373.0, 876.0]], [[378.0, 876.0], [454.0, 876.0], [454.0, 900.0], [378.0, 900.0]]], "lines": ["自転車を除く", "一方通行"]}, {"box": [498, 1043, 547, 1254], "vertical": true, "font_size": 49, "lines_coords": [[[498.0, 1043.0], [547.0, 1043.0], [547.0, 1254.0], [498.0, 1254.0]]], "lines": ["２０１７年１２月２４日（水）ですがここであるのはしましたでしょうかってしまったようにしています。または．．．"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "075.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [32, 290, 76, 450], "vertical": true, "font_size": 44, "lines_coords": [[[32.0, 290.0], [76.0, 290.0], [76.0, 450.0], [32.0, 450.0]]], "lines": ["第３９話"]}, {"box": [309, 237, 413, 370], "vertical": true, "font_size": 30, "lines_coords": [[[384.0, 239.0], [412.0, 239.0], [412.0, 353.0], [384.0, 353.0]], [[350.0, 239.0], [376.0, 239.0], [376.0, 370.0], [350.0, 370.0]], [[309.0, 237.0], [345.0, 237.0], [345.0, 307.0], [309.0, 307.0]]], "lines": ["．．．．．．正直、", "僕は怯えて", "いた。"]}, {"box": [809, 465, 946, 723], "vertical": true, "font_size": 26, "lines_coords": [[[920.0, 465.0], [946.0, 465.0], [945.0, 651.0], [918.0, 651.0]], [[881.0, 467.0], [907.0, 467.0], [907.0, 634.0], [881.0, 634.0]], [[843.0, 467.0], [870.0, 467.0], [870.0, 676.0], [843.0, 676.0]], [[809.0, 467.0], [835.0, 467.0], [835.0, 723.0], [809.0, 723.0]]], "lines": ["出来ることなら", "知りたくない、", "何か最悪の事実を", "知ってしまいそうで．．．"]}, {"box": [115, 1101, 373, 1326], "vertical": false, "font_size": 103.5, "lines_coords": [[[117.0, 1109.0], [370.0, 1101.0], [373.0, 1200.0], [120.0, 1207.0]], [[115.0, 1218.0], [364.0, 1218.0], [364.0, 1326.0], [115.0, 1326.0]]], "lines": ["ビめ陶芸教室", "どめ陶芸教室"]}, {"box": [109, 1351, 375, 1407], "vertical": false, "font_size": 53, "lines_coords": [[[109.0, 1354.0], [375.0, 1351.0], [375.0, 1404.0], [109.0, 1407.0]]], "lines": ["・海原不動"]}, {"box": [529, 1267, 640, 1325], "vertical": false, "font_size": 63, "lines_coords": [[[529.0, 1262.0], [640.0, 1262.0], [640.0, 1330.0], [529.0, 1330.0]]], "lines": ["でも、このＥＣＨＡの"]}], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [895, 143, 1017, 290], "vertical": true, "font_size": 25, "lines_coords": [[[990.0, 143.0], [1017.0, 143.0], [1017.0, 290.0], [990.0, 290.0]], [[957.0, 143.0], [984.0, 143.0], [984.0, 275.0], [957.0, 275.0]], [[925.0, 145.0], [951.0, 145.0], [951.0, 290.0], [925.0, 290.0]], [[895.0, 143.0], [917.0, 143.0], [917.0, 275.0], [895.0, 275.0]]], "lines": ["．．．いやぁ～～", "でもホント、", "久々に会えて", "良かったよ。"]}, {"box": [800, 282, 889, 475], "vertical": true, "font_size": 25, "lines_coords": [[[862.0, 282.0], [889.0, 282.0], [889.0, 439.0], [862.0, 439.0]], [[831.0, 282.0], [857.0, 282.0], [857.0, 475.0], [831.0, 475.0]], [[800.0, 285.0], [821.0, 285.0], [821.0, 460.0], [800.0, 460.0]]], "lines": ["実は、けっこう", "小野寺くんのこと", "心配してたんだ。"]}, {"box": [879, 617, 969, 841], "vertical": true, "font_size": 22, "lines_coords": [[[946.0, 617.0], [968.0, 617.0], [968.0, 762.0], [946.0, 762.0]], [[914.0, 617.0], [935.0, 617.0], [935.0, 831.0], [914.0, 831.0]], [[881.0, 618.0], [903.0, 618.0], [903.0, 840.0], [881.0, 840.0]]], "lines": ["．．．てもまさか", "こんなかわいい彼女", "連れてくるなんてね。"]}, {"box": [125, 300, 282, 523], "vertical": true, "font_size": 26, "lines_coords": [[[254.0, 303.0], [282.0, 303.0], [282.0, 401.0], [254.0, 401.0]], [[220.0, 301.0], [246.0, 301.0], [250.0, 523.0], [223.0, 523.0]], [[185.0, 301.0], [212.0, 301.0], [217.0, 476.0], [190.0, 476.0]], [[154.0, 300.0], [181.0, 300.0], [182.0, 470.0], [156.0, 470.0]], [[125.0, 303.0], [146.0, 303.0], [148.0, 456.0], [126.0, 456.0]]], "lines": ["あの頃は", "バタバタしちゃってて", "仕事辞める理由、", "ちゃんと聞けな", "かったからさ。"]}, {"box": [179, 703, 244, 873], "vertical": true, "font_size": 27, "lines_coords": [[[215.0, 704.0], [242.0, 704.0], [242.0, 837.0], [215.0, 837.0]], [[179.0, 703.0], [206.0, 703.0], [206.0, 873.0], [179.0, 873.0]]], "lines": ["元気そうで", "なによりだよ。"]}, {"box": [918, 1012, 984, 1147], "vertical": true, "font_size": 30, "lines_coords": [[[950.0, 1012.0], [984.0, 1012.0], [984.0, 1098.0], [950.0, 1098.0]], [[918.0, 1015.0], [945.0, 1015.0], [945.0, 1145.0], [918.0, 1145.0]]], "lines": ["や．．．", "．．．あの．．．．．"]}, {"box": [511, 1014, 602, 1216], "vertical": true, "font_size": 22, "lines_coords": [[[578.0, 1015.0], [600.0, 1015.0], [600.0, 1134.0], [578.0, 1134.0]], [[543.0, 1014.0], [565.0, 1014.0], [565.0, 1203.0], [543.0, 1203.0]], [[512.0, 1015.0], [534.0, 1015.0], [534.0, 1215.0], [512.0, 1215.0]]], "lines": ["実はたまに", "鷲尾くんもココに", "遊びに来てるんだ。"]}, {"box": [168, 1101, 262, 1271], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 1103.0], [259.0, 1101.0], [262.0, 1189.0], [228.0, 1190.0]], [[198.0, 1104.0], [225.0, 1104.0], [225.0, 1271.0], [198.0, 1271.0]], [[168.0, 1106.0], [190.0, 1106.0], [190.0, 1231.0], [168.0, 1231.0]]], "lines": ["．．．彼も", "ずいぶん元気に", "なったよね。"]}, {"box": [700, 1368, 732, 1489], "vertical": true, "font_size": 32, "lines_coords": [[[700.0, 1390.0], [732.0, 1390.0], [732.0, 1489.0], [700.0, 1489.0]]], "lines": ["．．．ハイ。"]}, {"box": [120, 1326, 248, 1546], "vertical": true, "font_size": 26, "lines_coords": [[[221.0, 1329.0], [248.0, 1329.0], [248.0, 1496.0], [221.0, 1496.0]], [[190.0, 1329.0], [212.0, 1329.0], [212.0, 1546.0], [190.0, 1546.0]], [[157.0, 1328.0], [179.0, 1328.0], [179.0, 1542.0], [157.0, 1542.0]], [[120.0, 1326.0], [146.0, 1326.0], [150.0, 1437.0], [123.0, 1437.0]]], "lines": ["あの時のことは", "話してくれないけど、", "前よりも笑うように", "なったし。"]}], "img_path": "077.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [940, 89, 1000, 281], "vertical": true, "font_size": 27, "lines_coords": [[[973.0, 89.0], [1000.0, 89.0], [996.0, 235.0], [970.0, 235.0]], [[940.0, 90.0], [967.0, 90.0], [967.0, 279.0], [940.0, 279.0]]], "lines": ["．．．あの．．．．．", "八木さんは．．．？"]}, {"box": [409, 146, 568, 387], "vertical": true, "font_size": 25, "lines_coords": [[[540.0, 148.0], [567.0, 148.0], [567.0, 318.0], [540.0, 318.0]], [[507.0, 146.0], [534.0, 146.0], [535.0, 376.0], [509.0, 376.0]], [[476.0, 150.0], [498.0, 150.0], [498.0, 387.0], [476.0, 387.0]], [[442.0, 148.0], [468.0, 148.0], [468.0, 329.0], [442.0, 329.0]], [[409.0, 150.0], [431.0, 150.0], [431.0, 350.0], [409.0, 350.0]]], "lines": ["怪我はたいした", "ことなかったけどさ、", "訴訟でも起こされたら", "今頃、この教室は", "無かっただろうね。"]}, {"box": [95, 53, 382, 79], "vertical": false, "font_size": 26, "lines_coords": [[[95.0, 53.0], [382.0, 53.0], [382.0, 79.0], [95.0, 79.0]]], "lines": ["おやすみプンプン＠"]}, {"box": [703, 492, 798, 673], "vertical": true, "font_size": 25, "lines_coords": [[[767.0, 492.0], [795.0, 492.0], [798.0, 639.0], [770.0, 639.0]], [[739.0, 495.0], [760.0, 495.0], [760.0, 657.0], [739.0, 657.0]], [[703.0, 492.0], [729.0, 492.0], [731.0, 673.0], [704.0, 673.0]]], "lines": ["あぁ～～～．．．", "あの後、かなり", "長々もめてねぇ。"]}, {"box": [93, 421, 217, 637], "vertical": true, "font_size": 25, "lines_coords": [[[189.0, 423.0], [217.0, 423.0], [217.0, 526.0], [189.0, 526.0]], [[156.0, 421.0], [184.0, 421.0], [179.0, 637.0], [151.0, 637.0]], [[125.0, 423.0], [146.0, 423.0], [146.0, 637.0], [125.0, 637.0]], [[93.0, 423.0], [115.0, 423.0], [115.0, 553.0], [93.0, 553.0]]], "lines": ["．．．でも、", "八木さんの娘さんが", "必死に止めてくれた", "らしいんだ。"]}, {"box": [923, 766, 948, 900], "vertical": true, "font_size": 21, "lines_coords": [[[925.0, 818.0], [946.0, 818.0], [946.0, 898.0], [925.0, 898.0]]], "lines": ["．．．え？"]}, {"box": [229, 748, 357, 940], "vertical": true, "font_size": 28, "lines_coords": [[[321.0, 748.0], [357.0, 748.0], [357.0, 814.0], [321.0, 814.0]], [[293.0, 751.0], [317.0, 751.0], [318.0, 896.0], [295.0, 896.0]], [[260.0, 751.0], [282.0, 751.0], [282.0, 940.0], [260.0, 940.0]], [[229.0, 751.0], [251.0, 751.0], [251.0, 895.0], [229.0, 895.0]]], "lines": ["ホラ、", "いたじゃない", "八木さんが勝手に", "連れて来た！"]}, {"box": [134, 953, 235, 1090], "vertical": true, "font_size": 28, "lines_coords": [[[207.0, 957.0], [235.0, 957.0], [235.0, 1090.0], [207.0, 1090.0]], [[165.0, 953.0], [204.0, 953.0], [204.0, 1042.0], [165.0, 1042.0]], [[134.0, 957.0], [160.0, 957.0], [160.0, 1064.0], [134.0, 1064.0]]], "lines": ["おかっぱで", "色白の", "女の子！！"]}, {"box": [842, 1251, 980, 1497], "vertical": true, "font_size": 27, "lines_coords": [[[953.0, 1254.0], [979.0, 1254.0], [979.0, 1360.0], [953.0, 1360.0]], [[917.0, 1254.0], [943.0, 1254.0], [943.0, 1492.0], [917.0, 1492.0]], [[878.0, 1251.0], [906.0, 1251.0], [907.0, 1412.0], [879.0, 1412.0]], [[842.0, 1251.0], [870.0, 1251.0], [871.0, 1462.0], [843.0, 1462.0]]], "lines": ["．．．なんで", "かばってくれたのか、", "今となっては", "わからないけど．．"]}, {"box": [309, 1254, 382, 1376], "vertical": true, "font_size": 31, "lines_coords": [[[334.0, 1257.0], [373.0, 1254.0], [382.0, 1353.0], [343.0, 1356.0]], [[309.0, 1259.0], [337.0, 1259.0], [337.0, 1376.0], [309.0, 1376.0]]], "lines": ["．．．あ、", "そうそう。"]}, {"box": [110, 1273, 250, 1521], "vertical": true, "font_size": 31, "lines_coords": [[[218.0, 1273.0], [250.0, 1273.0], [250.0, 1510.0], [218.0, 1510.0]], [[182.0, 1273.0], [214.0, 1273.0], [214.0, 1487.0], [182.0, 1487.0]], [[146.0, 1273.0], [175.0, 1273.0], [173.0, 1510.0], [145.0, 1510.0]], [[112.0, 1273.0], [139.0, 1273.0], [137.0, 1521.0], [110.0, 1521.0]]], "lines": ["生徒さん達の話じゃ", "その娘さん、今は", "京都の美大で陶芸の", "勉強してるらしいよ。"]}], "img_path": "078.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [281, 0, 1001, 614], "vertical": false, "font_size": 581, "lines_coords": [[[281.0, 0.0], [928.0, 0.0], [1001.0, 539.0], [354.0, 614.0]]], "lines": ["僕、"]}, {"box": [854, 840, 923, 1000], "vertical": true, "font_size": 30, "lines_coords": [[[890.0, 840.0], [923.0, 840.0], [923.0, 951.0], [890.0, 951.0]], [[857.0, 840.0], [884.0, 840.0], [881.0, 1000.0], [854.0, 1000.0]]], "lines": ["ん．．．．．．", "どうしたの？"]}, {"box": [560, 857, 593, 964], "vertical": true, "font_size": 33, "lines_coords": [[[560.0, 857.0], [593.0, 857.0], [593.0, 964.0], [560.0, 964.0]]], "lines": ["いや．．．"]}, {"box": [110, 910, 215, 1040], "vertical": true, "font_size": 29, "lines_coords": [[[185.0, 912.0], [212.0, 912.0], [212.0, 1040.0], [185.0, 1040.0]], [[150.0, 912.0], [178.0, 912.0], [178.0, 1017.0], [150.0, 1017.0]], [[110.0, 910.0], [143.0, 910.0], [143.0, 1007.0], [110.0, 1007.0]]], "lines": ["あの．．．コレ", "いい茶碗", "ですね。"]}, {"box": [553, 1156, 659, 1326], "vertical": true, "font_size": 31, "lines_coords": [[[626.0, 1156.0], [659.0, 1156.0], [659.0, 1245.0], [626.0, 1245.0]], [[590.0, 1157.0], [621.0, 1157.0], [621.0, 1320.0], [590.0, 1320.0]], [[556.0, 1157.0], [584.0, 1157.0], [581.0, 1326.0], [553.0, 1326.0]]], "lines": ["．．．はは、", "好きだね～～", "小野寺くんも。"]}, {"box": [364, 1360, 467, 1532], "vertical": true, "font_size": 26, "lines_coords": [[[437.0, 1362.0], [464.0, 1362.0], [464.0, 1532.0], [437.0, 1532.0]], [[400.0, 1364.0], [426.0, 1364.0], [426.0, 1532.0], [400.0, 1532.0]], [[364.0, 1360.0], [390.0, 1360.0], [393.0, 1520.0], [367.0, 1520.0]]], "lines": ["それ、小ぶりで", "雑だけど、味が", "あるでしょ？"]}, {"box": [92, 1328, 194, 1485], "vertical": true, "font_size": 27, "lines_coords": [[[167.0, 1329.0], [193.0, 1329.0], [193.0, 1485.0], [167.0, 1485.0]], [[129.0, 1331.0], [157.0, 1331.0], [157.0, 1460.0], [129.0, 1460.0]], [[95.0, 1328.0], [121.0, 1328.0], [118.0, 1471.0], [92.0, 1471.0]]], "lines": ["．．．驚尾くんの", "五年振りの", "復帰作だよ。"]}], "img_path": "079.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [596, 132, 667, 245], "vertical": true, "font_size": 34, "lines_coords": [[[631.0, 132.0], [667.0, 132.0], [667.0, 204.0], [631.0, 204.0]], [[596.0, 134.0], [629.0, 134.0], [629.0, 245.0], [596.0, 245.0]]], "lines": ["じゃ、", "あの．．．"]}, {"box": [107, 150, 246, 310], "vertical": true, "font_size": 30, "lines_coords": [[[210.0, 150.0], [246.0, 150.0], [246.0, 210.0], [210.0, 210.0]], [[178.0, 151.0], [206.0, 151.0], [207.0, 310.0], [179.0, 310.0]], [[143.0, 151.0], [170.0, 151.0], [170.0, 284.0], [143.0, 284.0]], [[107.0, 153.0], [135.0, 153.0], [135.0, 243.0], [107.0, 243.0]]], "lines": ["突然", "おじゃまして", "すみません", "でした。"]}, {"box": [240, 404, 268, 548], "vertical": true, "font_size": 31, "lines_coords": [[[240.0, 404.0], [268.0, 404.0], [268.0, 548.0], [240.0, 548.0]]], "lines": ["いやいやぁ。"]}, {"box": [115, 535, 215, 657], "vertical": true, "font_size": 31, "lines_coords": [[[182.0, 537.0], [215.0, 537.0], [215.0, 648.0], [182.0, 648.0]], [[146.0, 535.0], [181.0, 535.0], [181.0, 623.0], [146.0, 623.0]], [[115.0, 540.0], [142.0, 540.0], [142.0, 657.0], [115.0, 657.0]]], "lines": ["いつでも", "遊びに", "おいでよ。"]}, {"box": [917, 768, 939, 898], "vertical": true, "font_size": 23, "lines_coords": [[[917.0, 768.0], [939.0, 768.0], [939.0, 898.0], [917.0, 898.0]]], "lines": ["それにさ．．．"]}, {"box": [778, 870, 867, 1060], "vertical": true, "font_size": 23, "lines_coords": [[[840.0, 870.0], [867.0, 870.0], [867.0, 1060.0], [840.0, 1060.0]], [[810.0, 871.0], [832.0, 871.0], [832.0, 1039.0], [810.0, 1039.0]], [[778.0, 873.0], [800.0, 873.0], [800.0, 1037.0], [778.0, 1037.0]]], "lines": ["もし小野寺くんが", "また焼き物やり", "たくなったら．．．"]}, {"box": [160, 906, 229, 1066], "vertical": true, "font_size": 28, "lines_coords": [[[201.0, 907.0], [228.0, 907.0], [228.0, 1064.0], [201.0, 1064.0]], [[164.0, 906.0], [192.0, 906.0], [189.0, 1023.0], [160.0, 1023.0]]], "lines": ["．．．また一緒に", "働こうよ。"]}], "img_path": "080.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "081.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "082.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [928, 153, 962, 235], "vertical": true, "font_size": 32, "lines_coords": [[[928.0, 153.0], [962.0, 153.0], [962.0, 235.0], [928.0, 235.0]]], "lines": ["あの．．．"]}, {"box": [851, 257, 918, 387], "vertical": true, "font_size": 32, "lines_coords": [[[884.0, 257.0], [918.0, 257.0], [918.0, 364.0], [884.0, 364.0]], [[851.0, 278.0], [879.0, 278.0], [879.0, 387.0], [851.0, 387.0]]], "lines": ["なんて", "言うか．．．"]}, {"box": [489, 220, 607, 253], "vertical": false, "font_size": 33, "lines_coords": [[[489.0, 220.0], [607.0, 220.0], [607.0, 253.0], [489.0, 253.0]]], "lines": ["それはそれで"]}, {"box": [229, 125, 262, 257], "vertical": true, "font_size": 28, "lines_coords": [[[234.0, 125.0], [262.0, 125.0], [257.0, 257.0], [229.0, 257.0]]], "lines": ["よかった．．"]}, {"box": [164, 285, 195, 420], "vertical": true, "font_size": 28, "lines_coords": [[[167.0, 285.0], [195.0, 285.0], [192.0, 420.0], [164.0, 420.0]]], "lines": ["ですよね？"]}, {"box": [882, 550, 909, 657], "vertical": true, "font_size": 26, "lines_coords": [[[882.0, 550.0], [909.0, 550.0], [909.0, 657.0], [882.0, 657.0]]], "lines": ["うん．．．"]}, {"box": [795, 656, 821, 812], "vertical": true, "font_size": 26, "lines_coords": [[[795.0, 656.0], [821.0, 656.0], [821.0, 812.0], [795.0, 812.0]]], "lines": ["よかった．．．"]}, {"box": [167, 940, 234, 1101], "vertical": true, "font_size": 30, "lines_coords": [[[200.0, 940.0], [234.0, 940.0], [234.0, 1026.0], [200.0, 1026.0]], [[167.0, 942.0], [193.0, 942.0], [193.0, 1100.0], [167.0, 1100.0]]], "lines": ["本当に", "よかった．．．"]}, {"box": [300, 1285, 328, 1390], "vertical": true, "font_size": 27, "lines_coords": [[[300.0, 1285.0], [328.0, 1285.0], [328.0, 1390.0], [300.0, 1390.0]]], "lines": ["結局．．．"]}, {"box": [159, 1323, 221, 1540], "vertical": true, "font_size": 27, "lines_coords": [[[190.0, 1323.0], [221.0, 1323.0], [218.0, 1540.0], [187.0, 1540.0]], [[159.0, 1328.0], [181.0, 1328.0], [181.0, 1509.0], [159.0, 1509.0]]], "lines": ["僕のとりこし苦労", "だったのかな？"]}], "img_path": "083.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [935, 50, 1006, 164], "vertical": true, "font_size": 29, "lines_coords": [[[978.0, 54.0], [1006.0, 54.0], [1006.0, 164.0], [978.0, 164.0]], [[940.0, 50.0], [975.0, 51.0], [970.0, 160.0], [935.0, 159.0]]], "lines": ["．．．いや、", "でも．．．．．．"]}, {"box": [826, 106, 926, 262], "vertical": true, "font_size": 29, "lines_coords": [[[898.0, 106.0], [926.0, 106.0], [926.0, 212.0], [898.0, 212.0]], [[862.0, 106.0], [889.0, 106.0], [889.0, 262.0], [862.0, 262.0]], [[826.0, 106.0], [853.0, 106.0], [853.0, 225.0], [826.0, 225.0]]], "lines": ["そういう", "問題じゃ無い", "気がする。"]}, {"box": [473, 100, 633, 268], "vertical": true, "font_size": 23, "lines_coords": [[[606.0, 101.0], [632.0, 101.0], [632.0, 221.0], [606.0, 221.0]], [[575.0, 103.0], [595.0, 103.0], [595.0, 268.0], [575.0, 268.0]], [[535.0, 100.0], [562.0, 100.0], [565.0, 229.0], [539.0, 229.0]], [[506.0, 100.0], [528.0, 100.0], [528.0, 243.0], [506.0, 243.0]], [[473.0, 100.0], [495.0, 100.0], [495.0, 265.0], [473.0, 265.0]]], "lines": ["過去にして", "しまったことは", "消えないし、", "僕の人間性も", "変わらない．．．"]}, {"box": [675, 481, 774, 667], "vertical": true, "font_size": 23, "lines_coords": [[[748.0, 484.0], [770.0, 484.0], [770.0, 665.0], [748.0, 665.0]], [[709.0, 482.0], [735.0, 482.0], [735.0, 667.0], [709.0, 667.0]], [[675.0, 482.0], [696.0, 482.0], [696.0, 637.0], [675.0, 637.0]]], "lines": ["結果的に今回は", "僕の杞憂だった", "としても．．．"]}, {"box": [328, 449, 484, 667], "vertical": true, "font_size": 24, "lines_coords": [[[457.0, 450.0], [484.0, 450.0], [484.0, 601.0], [457.0, 601.0]], [[426.0, 450.0], [450.0, 450.0], [448.0, 617.0], [425.0, 617.0]], [[390.0, 450.0], [417.0, 450.0], [417.0, 667.0], [390.0, 667.0]], [[