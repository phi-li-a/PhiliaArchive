], [840.0, 732.0], [820.0, 732.0]]], "lines": ["「みんな仲良く", "平等に」なんて", "河原の石ころにしか", "当てはまらないよ。"]}, {"box": [167, 551, 326, 743], "vertical": true, "font_size": 26, "lines_coords": [[[296.0, 553.0], [326.0, 553.0], [326.0, 628.0], [296.0, 628.0]], [[264.0, 551.0], [290.0, 551.0], [290.0, 743.0], [264.0, 743.0]], [[232.0, 553.0], [259.0, 553.0], [259.0, 698.0], [232.0, 698.0]], [[203.0, 554.0], [225.0, 554.0], [225.0, 720.0], [203.0, 720.0]], [[167.0, 556.0], [193.0, 556.0], [193.0, 660.0], [167.0, 660.0]]], "lines": ["誰とも", "争いたくないなら", "無人島にでも", "行ってしまえば", "いいんだ。"]}, {"box": [803, 851, 939, 1075], "vertical": true, "font_size": 27, "lines_coords": [[[912.0, 851.0], [939.0, 851.0], [939.0, 982.0], [912.0, 982.0]], [[876.0, 853.0], [903.0, 853.0], [903.0, 984.0], [876.0, 984.0]], [[839.0, 853.0], [865.0, 853.0], [865.0, 1075.0], [839.0, 1075.0]], [[803.0, 851.0], [829.0, 851.0], [829.0, 1062.0], [803.0, 1062.0]]], "lines": ["．．．そう！！", "僕にとって", "勝利も敗北も、生命", "そのものなんだ！！"]}, {"box": [670, 995, 768, 1154], "vertical": true, "font_size": 27, "lines_coords": [[[742.0, 995.0], [768.0, 995.0], [768.0, 1154.0], [742.0, 1154.0]], [[706.0, 996.0], [734.0, 998.0], [729.0, 1128.0], [701.0, 1126.0]], [[670.0, 996.0], [696.0, 996.0], [696.0, 1103.0], [670.0, 1103.0]]], "lines": ["生きることは", "細胞と魂の", "躍動だ！！"]}, {"box": [304, 846, 403, 1081], "vertical": true, "font_size": 31, "lines_coords": [[[376.0, 848.0], [403.0, 848.0], [403.0, 981.0], [376.0, 981.0]], [[340.0, 851.0], [367.0, 851.0], [367.0, 1057.0], [340.0, 1057.0]], [[304.0, 846.0], [331.0, 846.0], [331.0, 1081.0], [304.0, 1081.0]]], "lines": ["だから僕は", "いつだって全力で", "ぶつかっていくよ！！"]}, {"box": [142, 965, 265, 1189], "vertical": true, "font_size": 31, "lines_coords": [[[226.0, 965.0], [265.0, 965.0], [265.0, 1064.0], [226.0, 1064.0]], [[185.0, 967.0], [218.0, 967.0], [218.0, 1159.0], [185.0, 1159.0]], [[142.0, 967.0], [173.0, 967.0], [173.0, 1189.0], [142.0, 1189.0]]], "lines": ["最高の", "勝利と敗北を", "味わうために！！"]}, {"box": [820, 1329, 950, 1486], "vertical": true, "font_size": 27, "lines_coords": [[[921.0, 1329.0], [950.0, 1329.0], [946.0, 1470.0], [918.0, 1470.0]], [[887.0, 1331.0], [914.0, 1331.0], [914.0, 1462.0], [887.0, 1462.0]], [[854.0, 1331.0], [881.0, 1331.0], [881.0, 1485.0], [854.0, 1485.0]], [[820.0, 1331.0], [846.0, 1331.0], [846.0, 1485.0], [820.0, 1485.0]]], "lines": ["．．．プンプン", "あぁ無知な", "平和主義者の", "ブンブン．．．"]}, {"box": [164, 1318, 302, 1504], "vertical": true, "font_size": 27, "lines_coords": [[[275.0, 1320.0], [301.0, 1320.0], [301.0, 1504.0], [275.0, 1504.0]], [[235.0, 1318.0], [264.0, 1318.0], [265.0, 1479.0], [237.0, 1479.0]], [[201.0, 1321.0], [228.0, 1321.0], [228.0, 1504.0], [201.0, 1504.0]], [[164.0, 1318.0], [190.0, 1318.0], [192.0, 1501.0], [165.0, 1501.0]]], "lines": ["君はそうやって", "生命の歓びを", "知らずに死んで", "ゆくのかい．．．"]}]}