{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [903, 118, 929, 279], "vertical": true, "font_size": 25, "lines_coords": [[[903.0, 118.0], [929.0, 118.0], [929.0, 279.0], [903.0, 279.0]]], "lines": ["小野寺さんは、"]}, {"box": [312, 248, 339, 376], "vertical": true, "font_size": 29, "lines_coords": [[[312.0, 248.0], [339.0, 248.0], [339.0, 376.0], [312.0, 376.0]]], "lines": ["．．．僕かい？"]}, {"box": [803, 346, 898, 503], "vertical": true, "font_size": 25, "lines_coords": [[[876.0, 348.0], [898.0, 348.0], [898.0, 451.0], [876.0, 451.0]], [[839.0, 346.0], [865.0, 346.0], [865.0, 503.0], [839.0, 503.0]], [[803.0, 346.0], [829.0, 346.0], [829.0, 453.0], [803.0, 453.0]]], "lines": ["．．．とんな", "学生だったん", "ですか？"]}, {"box": [209, 440, 275, 598], "vertical": true, "font_size": 29, "lines_coords": [[[242.0, 440.0], [275.0, 440.0], [275.0, 551.0], [242.0, 551.0]], [[209.0, 442.0], [235.0, 442.0], [235.0, 598.0], [209.0, 598.0]]], "lines": ["僕は．．．", "まぁ、月並さ。"]}, {"box": [860, 859, 1005, 1072], "vertical": true, "font_size": 24, "lines_coords": [[[981.0, 859.0], [1003.0, 859.0], [1003.0, 1031.0], [981.0, 1031.0]], [[951.0, 859.0], [975.0, 859.0], [973.0, 1071.0], [950.0, 1071.0]], [[923.0, 859.0], [945.0, 859.0], [945.0, 1070.0], [923.0, 1070.0]], [[893.0, 859.0], [914.0, 859.0], [914.0, 1070.0], [893.0, 1070.0]], [[860.0, 860.0], [889.0, 860.0], [889.0, 943.0], [860.0, 943.0]]], "lines": ["．．．自分は特別で、", "他人とは違う何かを", "持っていると信じて", "それをずっと探して", "いたよ。"]}, {"box": [831, 1256, 921, 1468], "vertical": true, "font_size": 24, "lines_coords": [[[898.0, 1256.0], [921.0, 1256.0], [920.0, 1423.0], [896.0, 1423.0]], [[862.0, 1256.0], [889.0, 1256.0], [887.0, 1468.0], [860.0, 1468.0]], [[831.0, 1260.0], [853.0, 1260.0], [853.0, 1429.0], [831.0, 1429.0]]], "lines": ["．．．今はその頃の", "自分を「若かった」の", "一言で片付けて、"]}, {"box": [690, 1315, 779, 1492], "vertical": true, "font_size": 24, "lines_coords": [[[753.0, 1315.0], [779.0, 1315.0], [776.0, 1457.0], [750.0, 1457.0]], [[721.0, 1318.0], [743.0, 1318.0], [743.0, 1482.0], [721.0, 1482.0]], [[690.0, 1317.0], [712.0, 1317.0], [712.0, 1492.0], [690.0, 1492.0]]], "lines": ["でっちあげの", "屁理屈で帳尻を", "合わせてるんだ。"]}, {"box": [568, 1166, 594, 1285], "vertical": true, "font_size": 22, "lines_coords": [[[568.0, 1167.0], [590.0, 1167.0], [590.0, 1284.0], [568.0, 1284.0]]], "lines": ["今はただ．．．"]}, {"box": [226, 1190, 351, 1389], "vertical": true, "font_size": 23, "lines_coords": [[[325.0, 1190.0], [351.0, 1190.0], [351.0, 1335.0], [325.0, 1335.0]], [[293.0, 1192.0], [315.0, 1192.0], [315.0, 1381.0], [293.0, 1381.0]], [[262.0, 1192.0], [284.0, 1192.0], [284.0, 1346.0], [262.0, 1346.0]], [[229.0, 1190.0], [251.0, 1190.0], [248.0, 1389.0], [226.0, 1389.0]]], "lines": ["器の中の水が", "表面張力の限界を", "超えて、一気に", "こぼれ出すように、"]}, {"box": [89, 1331, 209, 1532], "vertical": true, "font_size": 23, "lines_coords": [[[182.0, 1331.0], [209.0, 1331.0], [206.0, 1500.0], [179.0, 1500.0]], [[153.0, 1332.0], [175.0, 1332.0], [175.0, 1476.0], [153.0, 1476.0]], [[120.0, 1332.0], [142.0, 1332.0], [142.0, 1532.0], [120.0, 1532.0]], [[89.0, 1332.0], [110.0, 1332.0], [110.0, 1460.0], [89.0, 1460.0]]], "lines": ["心の中の何かが", "溢れ出すのを", "恐れながら、目常を", "過ごしてる。"]}]}