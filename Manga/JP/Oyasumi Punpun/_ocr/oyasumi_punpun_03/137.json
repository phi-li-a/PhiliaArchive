 1235, 244, 1445], "vertical": true, "font_size": 23, "lines_coords": [[[214.0, 1237.0], [240.0, 1237.0], [240.0, 1445.0], [214.0, 1445.0]], [[179.0, 1239.0], [201.0, 1239.0], [201.0, 1392.0], [179.0, 1392.0]], [[143.0, 1237.0], [165.0, 1237.0], [165.0, 1434.0], [143.0, 1434.0]]], "lines": ["基本的には優しく", "面倒見の良い", "性格なのだろう。"]}]}