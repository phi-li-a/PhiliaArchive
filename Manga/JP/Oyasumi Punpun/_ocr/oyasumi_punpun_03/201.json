73.0, 1082.0], [246.0, 1082.0]], [[210.0, 912.0], [237.0, 912.0], [237.0, 1135.0], [210.0, 1135.0]], [[178.0, 914.0], [200.0, 914.0], [200.0, 1070.0], [178.0, 1070.0]]], "lines": ["普段、私は本当に", "家の柱に、縄で", "縛られて、生活して", "るんですよ？"]}, {"box": [303, 1237, 365, 1435], "vertical": true, "font_size": 26, "lines_coords": [[[339.0, 1237.0], [365.0, 1237.0], [365.0, 1435.0], [339.0, 1435.0]], [[303.0, 1237.0], [329.0, 1237.0], [329.0, 1423.0], [303.0, 1423.0]]], "lines": ["：私はこのまま", "きっと一生．．．"]}, {"box": [153, 1304, 250, 1539], "vertical": true, "font_size": 26, "lines_coords": [[[223.0, 1304.0], [250.0, 1304.0], [250.0, 1539.0], [223.0, 1539.0]], [[185.0, 1306.0], [212.0, 1306.0], [212.0, 1514.0], [185.0, 1514.0]], [[153.0, 1310.0], [175.0, 1310.0], [175.0, 1485.0], [153.0, 1485.0]]], "lines": ["狭い部屋の中だけで", "孤独に年を取って", "いくんです．．．"]}]}