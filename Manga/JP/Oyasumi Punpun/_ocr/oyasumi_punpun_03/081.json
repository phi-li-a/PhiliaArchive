{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [926, 112, 989, 256], "vertical": true, "font_size": 26, "lines_coords": [[[959.0, 112.0], [985.0, 112.0], [989.0, 256.0], [962.0, 256.0]], [[926.0, 117.0], [953.0, 117.0], [953.0, 234.0], [926.0, 234.0]]], "lines": ["．．．あのさぁ、", "プンプン。"]}, {"box": [750, 192, 873, 435], "vertical": true, "font_size": 26, "lines_coords": [[[846.0, 192.0], [873.0, 192.0], [873.0, 300.0], [846.0, 300.0]], [[814.0, 193.0], [840.0, 193.0], [840.0, 415.0], [814.0, 415.0]], [[781.0, 192.0], [807.0, 192.0], [804.0, 403.0], [778.0, 403.0]], [[750.0, 193.0], [771.0, 193.0], [771.0, 435.0], [750.0, 435.0]]], "lines": ["この話は", "僕にとって、とても", "大事なことだから", "言わせてもらうけど、"]}, {"box": [518, 120, 671, 357], "vertical": true, "font_size": 34, "lines_coords": [[[639.0, 123.0], [671.0, 123.0], [671.0, 312.0], [639.0, 312.0]], [[596.0, 120.0], [634.0, 120.0], [634.0, 282.0], [596.0, 282.0]], [[557.0, 121.0], [589.0, 121.0], [589.0, 281.0], [557.0, 281.0]], [[518.0, 120.0], [550.0, 120.0], [550.0, 350.0], [518.0, 350.0]]], "lines": ["コートの中に", "立った以上", "勝ち負けが", "すべてなんだよ。"]}, {"box": [879, 814, 976, 998], "vertical": true, "font_size": 25, "lines_coords": [[[950.0, 815.0], [976.0, 815.0], [976.0, 973.0], [950.0, 973.0]], [[914.0, 814.0], [942.0, 814.0], [939.0, 998.0], [910.0, 998.0]], [[879.0, 818.0], [901.0, 818.0], [901.0, 979.0], [879.0, 979.0]]], "lines": ["先輩にどんな", "事情があるのか", "知らないけど、"]}, {"box": [682, 856, 832, 1098], "vertical": true, "font_size": 25, "lines_coords": [[[806.0, 857.0], [832.0, 857.0], [832.0, 1040.0], [806.0, 1040.0]], [[775.0, 856.0], [801.0, 856.0], [801.0, 1040.0], [775.0, 1040.0]], [[745.0, 857.0], [767.0, 857.0], [767.0, 1014.0], [745.0, 1014.0]], [[710.0, 857.0], [737.0, 857.0], [737.0, 1092.0], [710.0, 1092.0]], [[682.0, 857.0], [704.0, 857.0], [704.0, 1098.0], [682.0, 1098.0]]], "lines": ["コートに入って", "きた以上、僕は", "誰であろうと", "最大の敬意を払って", "徹底的に叩き潰すよ。"]}, {"box": [168, 937, 231, 1081], "vertical": true, "font_size": 27, "lines_coords": [[[204.0, 939.0], [231.0, 939.0], [231.0, 1068.0], [204.0, 1068.0]], [[168.0, 937.0], [195.0, 937.0], [195.0, 1081.0], [168.0, 1081.0]]], "lines": ["これは僕の", "美学だもの。"]}, {"box": [951, 1175, 1014, 1332], "vertical": true, "font_size": 28, "lines_coords": [[[987.0, 1176.0], [1014.0, 1176.0], [1014.0, 1332.0], [987.0, 1332.0]], [[951.0, 1175.0], [978.0, 1175.0], [978.0, 1295.0], [951.0, 1295.0]]], "lines": ["スポーツだけ", "じゃない。"]}, {"box": [767, 1259, 925, 1501], "vertical": true, "font_size": 28, "lines_coords": [[[898.0, 1264.0], [925.0, 1264.0], [925.0, 1451.0], [898.0, 1451.0]], [[865.0, 1265.0], [892.0, 1265.0], [892.0, 1501.0], [865.0, 1501.0]], [[828.0, 1259.0], [865.0, 1259.0], [865.0, 1454.0], [828.0, 1454.0]], [[800.0, 1264.0], [826.0, 1264.0], [826.0, 1448.0], [800.0, 1448.0]], [[767.0, 1264.0], [793.0, 1264.0], [793.0, 1460.0], [767.0, 1460.0]]], "lines": ["人生という同じ", "コートに立っている", "以上、人と人は", "優劣を常に競い", "合うべきなんだ。"]}, {"box": [281, 1210, 382, 1432], "vertical": true, "font_size": 25, "lines_coords": [[[356.0, 1212.0], [382.0, 1212.0], [382.0, 1346.0], [356.0, 1346.0]], [[320.0, 1212.0], [346.0, 1212.0], [346.0, 1398.0], [320.0, 1398.0]], [[282.0, 1210.0], [310.0, 1210.0], [309.0, 1432.0], [281.0, 1432.0]]], "lines": ["人はみんな", "平等や平和って", "言葉が好きだけど、"]}, {"box": [107, 1314, 235, 1532], "vertical": true, "font_size": 25, "lines_coords": [[[214.0, 1315.0], [235.0, 1315.0], [235.0, 1496.0], [214.0, 1496.0]], [[179.0, 1314.0], [201.0, 1314.0], [201.0, 1532.0], [179.0, 1532.0]], [[140.0, 1314.0], [167.0, 1314.0], [167.0, 1498.0], [140.0, 1498.0]], [[107.0, 1317.0], [129.0, 1317.0], [129.0, 1532.0], [107.0, 1532.0]]], "lines": ["僕から言わせて", "もらえば、そんなの", "敗北者達の宗教", "みたいなものだよ。"]}]}