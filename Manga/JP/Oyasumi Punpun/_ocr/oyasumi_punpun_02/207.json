]}, {"box": [1029, 916, 1099, 1635], "vertical": true, "font_size": 70, "lines_coords": [[[1029.0, 916.0], [1099.0, 916.0], [1099.0, 1635.0], [1029.0, 1635.0]]], "lines": ["れぞれの恋の炎。行く末は、"]}, {"box": [932, 1173, 959, 1326], "vertical": true, "font_size": 26, "lines_coords": [[[932.0, 1173.0], [959.0, 1173.0], [959.0, 1326.0], [932.0, 1326.0]]], "lines": ["いや、でもね。"]}, {"box": [775, 1254, 892, 1454], "vertical": true, "font_size": 26, "lines_coords": [[[865.0, 1254.0], [892.0, 1254.0], [892.0, 1454.0], [865.0, 1454.0]], [[832.0, 1257.0], [859.0, 1257.0], [859.0, 1390.0], [832.0, 1390.0]], [[803.0, 1257.0], [829.0, 1257.0], [829.0, 1442.0], [803.0, 1442.0]], [[775.0, 1259.0], [796.0, 1259.0], [796.0, 1414.0], [775.0, 1414.0]]], "lines": ["どんな人間だって", "少なからず", "変わった所って", "あるでしょ？"]}, {"box": [154, 1262, 291, 1500], "vertical": true, "font_size": 25, "lines_coords": [[[264.0, 1264.0], [290.0, 1264.0], [290.0, 1423.0], [264.0, 1423.0]], [[228.0, 1264.0], [254.0, 1264.0], [254.0, 1500.0], [228.0, 1500.0]], [[193.0, 1265.0], [215.0, 1265.0], [215.0, 1496.0], [193.0, 1496.0]], [[154.0, 1262.0], [181.0, 1262.0], [181.0, 1353.0], [154.0, 1353.0]]], "lines": ["つきつめると", "完全な普通の人こそ、", "究極の変人ってこと", "だよね。"]}]}