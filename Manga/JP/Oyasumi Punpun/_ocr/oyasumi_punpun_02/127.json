 1242.0]], [[231.0, 1035.0], [259.0, 1035.0], [259.0, 1175.0], [231.0, 1175.0]]], "lines": ["．．．とにかく、退院は", "予定通り明日、", "骨折は通院だけで", "いいってさ。"]}, {"box": [925, 1150, 1025, 1335], "vertical": true, "font_size": 26, "lines_coords": [[[996.0, 1151.0], [1025.0, 1151.0], [1025.0, 1242.0], [996.0, 1242.0]], [[960.0, 1151.0], [987.0, 1151.0], [987.0, 1335.0], [960.0, 1335.0]], [[925.0, 1150.0], [946.0, 1150.0], [946.0, 1318.0], [925.0, 1318.0]]], "lines": ["じゃあ、", "足が滑ったって", "ことにするわ。"]}, {"box": [484, 1145, 588, 1306], "vertical": true, "font_size": 27, "lines_coords": [[[557.0, 1145.0], [585.0, 1145.0], [587.0, 1306.0], [559.0, 1306.0]], [[521.0, 1146.0], [548.0, 1146.0], [548.0, 1260.0], [521.0, 1260.0]], [[484.0, 1145.0], [510.0, 1145.0], [514.0, 1279.0], [487.0, 1279.0]]], "lines": ["「じゃあ」って", "なんだよ、", "あんた．．．"]}, {"box": [121, 1295, 279, 1532], "vertical": true, "font_size": 27, "lines_coords": [[[253.0, 1296.0], [279.0, 1296.0], [279.0, 1510.0], [253.0, 1510.0]], [[220.0, 1295.0], [246.0, 1295.0], [243.0, 1532.0], [217.0, 1532.0]], [[182.0, 1295.0], [214.0, 1295.0], [214.0, 1509.0], [182.0, 1509.0]], [[153.0, 1296.0], [179.0, 1296.0], [179.0, 1456.0], [153.0, 1456.0]], [[121.0, 1296.0], [143.0, 1296.0], [143.0, 1504.0], [121.0, 1504.0]]], "lines": ["あなたとプンプン、", "二人きりじゃ何かと", "不安だから、僕も", "しばらく居候", "させてもらうよ．．．"]}]}