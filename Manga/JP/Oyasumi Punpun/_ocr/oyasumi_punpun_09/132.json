{"version": "0.2.0-beta.6", "img_width": 1436, "img_height": 2127, "blocks": [{"box": [1197, 91, 1305, 307], "vertical": true, "font_size": 30, "lines_coords": [[[1275.0, 93.0], [1305.0, 93.0], [1305.0, 307.0], [1275.0, 307.0]], [[1238.0, 91.0], [1267.0, 91.0], [1265.0, 274.0], [1236.0, 274.0]], [[1201.0, 91.0], [1232.0, 91.0], [1228.0, 257.0], [1197.0, 257.0]]], "lines": ["：実行したのは", "当時中学生の", "男女十数人。"]}, {"box": [617, 83, 660, 226], "vertical": true, "font_size": 37, "lines_coords": [[[617.0, 83.0], [660.0, 83.0], [660.0, 226.0], [617.0, 226.0]]], "lines": ["あの．．．"]}, {"box": [446, 145, 594, 369], "vertical": true, "font_size": 37, "lines_coords": [[[550.0, 145.0], [594.0, 145.0], [594.0, 255.0], [550.0, 255.0]], [[517.0, 151.0], [552.0, 151.0], [552.0, 276.0], [517.0, 276.0]], [[480.0, 153.0], [515.0, 153.0], [515.0, 282.0], [480.0, 282.0]], [[446.0, 155.0], [473.0, 155.0], [473.0, 369.0], [446.0, 369.0]]], "lines": ["なんで", "わざわざ", "そんな事", "するんですか？"]}, {"box": [222, 336, 257, 467], "vertical": true, "font_size": 33, "lines_coords": [[[222.0, 336.0], [257.0, 336.0], [257.0, 467.0], [222.0, 467.0]]], "lines": ["さぁ．．．"]}, {"box": [916, 477, 1093, 751], "vertical": true, "font_size": 29, "lines_coords": [[[1061.0, 477.0], [1091.0, 477.0], [1091.0, 751.0], [1061.0, 751.0]], [[1024.0, 479.0], [1053.0, 479.0], [1053.0, 693.0], [1024.0, 693.0]], [[989.0, 479.0], [1018.0, 479.0], [1018.0, 691.0], [989.0, 691.0]], [[951.0, 477.0], [980.0, 477.0], [980.0, 691.0], [951.0, 691.0]], [[916.0, 479.0], [943.0, 479.0], [943.0, 704.0], [916.0, 704.0]]], "lines": ["それらを呼びかけて", "指示をした弟は", "学校の用務員を", "監禁した主犯で", "補導されたけど。"]}, {"box": [1203, 893, 1284, 1113], "vertical": true, "font_size": 36, "lines_coords": [[[1246.0, 895.0], [1284.0, 895.0], [1284.0, 1034.0], [1246.0, 1034.0]], [[1207.0, 893.0], [1242.0, 893.0], [1238.0, 1111.0], [1203.0, 1111.0]]], "lines": ["．．．それは", "解せませんね。"]}, {"box": [137, 544, 280, 791], "vertical": true, "font_size": 33, "lines_coords": [[[245.0, 544.0], [280.0, 544.0], [280.0, 702.0], [245.0, 702.0]], [[211.0, 548.0], [241.0, 548.0], [241.0, 791.0], [211.0, 791.0]], [[174.0, 546.0], [203.0, 546.0], [201.0, 731.0], [172.0, 731.0]], [[137.0, 546.0], [172.0, 546.0], [172.0, 656.0], [137.0, 656.0]]], "lines": ["意味なんて", "ないんじゃない？", "弟はそういう", "奴だよ。"]}, {"box": [214, 1264, 377, 1518], "vertical": true, "font_size": 34, "lines_coords": [[[338.0, 1269.0], [374.0, 1269.0], [374.0, 1439.0], [338.0, 1439.0]], [[295.0, 1267.0], [330.0, 1267.0], [330.0, 1503.0], [295.0, 1503.0]], [[255.0, 1264.0], [290.0, 1264.0], [290.0, 1437.0], [255.0, 1437.0]], [[216.0, 1267.0], [247.0, 1267.0], [245.0, 1518.0], [214.0, 1518.0]]], "lines": ["仮に理由が", "あったとしても", "常人が納得", "できるかどうか。"]}, {"box": [1169, 1686, 1292, 1898], "vertical": true, "font_size": 35, "lines_coords": [[[1257.0, 1688.0], [1292.0, 1688.0], [1292.0, 1859.0], [1257.0, 1859.0]], [[1215.0, 1690.0], [1251.0, 1690.0], [1251.0, 1827.0], [1215.0, 1827.0]], [[1174.0, 1686.0], [1209.0, 1686.0], [1205.0, 1898.0], [1169.0, 1898.0]]], "lines": ["．．．あぁでも", "こんな事", "言ってたかな、"]}, {"box": [955, 1734, 1080, 1985], "vertical": true, "font_size": 35, "lines_coords": [[[1045.0, 1734.0], [1080.0, 1734.0], [1076.0, 1923.0], [1041.0, 1923.0]], [[1001.0, 1736.0], [1036.0, 1736.0], [1036.0, 1937.0], [1001.0, 1937.0]], [[958.0, 1736.0], [993.0, 1736.0], [991.0, 1985.0], [955.0, 1985.0]]], "lines": ["「正四面体は", "最も安定した", "正多面体だから」"]}]}