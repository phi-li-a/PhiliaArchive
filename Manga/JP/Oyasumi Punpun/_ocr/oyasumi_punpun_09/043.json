, 961.0], [1129.0, 961.0], [1129.0, 1100.0], [1092.0, 1100.0]], [[1059.0, 963.0], [1088.0, 963.0], [1088.0, 1208.0], [1059.0, 1208.0]], [[1021.0, 965.0], [1051.0, 965.0], [1051.0, 1121.0], [1021.0, 1121.0]]], "lines": ["まぁ一言、", "甘ったれんなって", "感じですね"]}, {"box": [182, 1244, 321, 1485], "vertical": true, "font_size": 28, "lines_coords": [[[294.0, 1244.0], [321.0, 1244.0], [321.0, 1424.0], [294.0, 1424.0]], [[257.0, 1244.0], [284.0, 1244.0], [284.0, 1485.0], [257.0, 1485.0]], [[222.0, 1246.0], [245.0, 1246.0], [245.0, 1393.0], [222.0, 1393.0]], [[182.0, 1244.0], [211.0, 1244.0], [211.0, 1366.0], [182.0, 1366.0]]], "lines": ["病気や障害に", "立ち向かっている", "人もいるん", "てすよ？"]}, {"box": [1154, 1605, 1237, 1744], "vertical": true, "font_size": 37, "lines_coords": [[[1200.0, 1607.0], [1237.0, 1607.0], [1237.0, 1744.0], [1200.0, 1744.0]], [[1154.0, 1605.0], [1200.0, 1605.0], [1200.0, 1728.0], [1154.0, 1728.0]]], "lines": ["．．．つまり", "それは、"]}, {"box": [1019, 1784, 1136, 1991], "vertical": true, "font_size": 37, "lines_coords": [[[1100.0, 1784.0], [1136.0, 1784.0], [1132.0, 1956.0], [1096.0, 1956.0]], [[1059.0, 1788.0], [1094.0, 1788.0], [1094.0, 1991.0], [1059.0, 1991.0]], [[1019.0, 1788.0], [1048.0, 1788.0], [1048.0, 1960.0], [1019.0, 1960.0]]], "lines": ["その本当に", "不幸な人達を", "ネタにして、"]}, {"box": [155, 1763, 276, 2000], "vertical": true, "font_size": 32, "lines_coords": [[[240.0, 1767.0], [270.0, 1767.0], [270.0, 1998.0], [240.0, 1998.0]], [[193.0, 1763.0], [230.0, 1763.0], [232.0, 2000.0], [195.0, 2000.0]], [[155.0, 1763.0], [184.0, 1763.0], [184.0, 1931.0], [155.0, 1931.0]]], "lines": ["感動的なお話を", "創作しろって事", "てすかね？"]}]}