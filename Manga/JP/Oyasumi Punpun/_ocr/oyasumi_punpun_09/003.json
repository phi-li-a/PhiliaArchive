{"version": "0.2.0-beta.6", "img_width": 3198, "img_height": 798, "blocks": [{"box": [2991, 130, 3169, 657], "vertical": true, "font_size": 42, "lines_coords": [[[3129.0, 137.0], [3160.0, 137.0], [3160.0, 579.0], [3129.0, 579.0]], [[3057.0, 137.0], [3098.0, 137.0], [3101.0, 554.0], [3060.0, 554.0]], [[2991.0, 130.0], [3044.0, 130.0], [3044.0, 657.0], [2991.0, 657.0]]], "lines": ["あなたが思っている以上に", "世の中のほとんどの人は、", "あなたのことなんかに興味が"]}, {"box": [2667, 3, 2963, 564], "vertical": true, "font_size": 65, "lines_coords": [[[2879.0, 81.0], [2945.0, 77.0], [2963.0, 561.0], [2898.0, 564.0]], [[2835.0, 121.0], [2888.0, 118.0], [2898.0, 339.0], [2845.0, 342.0]], [[2773.0, 74.0], [2851.0, 77.0], [2838.0, 542.0], [2760.0, 539.0]], [[2667.0, 12.0], [2729.0, 12.0], [2729.0, 339.0], [2667.0, 339.0]]], "lines": ["「凡な日常", "手を繋ぐこと", "屈を嘆く", "ような"]}, {"box": [2426, 81, 2635, 573], "vertical": true, "font_size": 91.0, "lines_coords": [[[2535.0, 84.0], [2623.0, 81.0], [2635.0, 567.0], [2548.0, 570.0]], [[2432.0, 102.0], [2526.0, 102.0], [2520.0, 573.0], [2426.0, 573.0]]], "lines": ["うたいな漫画", "う意味な"]}, {"box": [1754, 56, 1934, 726], "vertical": true, "font_size": 44, "lines_coords": [[[1886.0, 59.0], [1930.0, 59.0], [1930.0, 635.0], [1886.0, 635.0]], [[1820.0, 59.0], [1864.0, 59.0], [1864.0, 723.0], [1820.0, 723.0]], [[1758.0, 62.0], [1801.0, 62.0], [1801.0, 533.0], [1758.0, 533.0]]], "lines": ["哀と絶望と僅かなる希望。", "同時代を生きる少年・プンプンの", "成長議・震撼の最新章。"]}, {"box": [2229, 168, 2417, 741], "vertical": true, "font_size": 50.0, "lines_coords": [[[2361.0, 168.0], [2414.0, 168.0], [2417.0, 741.0], [2364.0, 741.0]], [[2298.0, 193.0], [2342.0, 193.0], [2342.0, 741.0], [2298.0, 741.0]], [[2229.0, 190.0], [2282.0, 190.0], [2292.0, 735.0], [2239.0, 735.0]]], "lines": ["今日みたいにとるに足らない", "平穏な日が、毎日毎日いつま", "でも続けばいいと思ってる。"]}, {"box": [2663, 620, 2954, 651], "vertical": false, "font_size": 31, "lines_coords": [[[2663.0, 620.0], [2954.0, 620.0], [2954.0, 651.0], [2663.0, 651.0]]], "lines": ["だって生で買えない"]}, {"box": [2529, 657, 3098, 713], "vertical": false, "font_size": 50, "lines_coords": [[[2529.0, 657.0], [3098.0, 663.0], [3098.0, 713.0], [2529.0, 707.0]]], "lines": ["くらいの時にあった時というのは、"]}, {"box": [2585, 723, 3082, 763], "vertical": false, "font_size": 34, "lines_coords": [[[2585.0, 729.0], [3082.0, 723.0], [3082.0, 757.0], [2585.0, 763.0]]], "lines": ["そう思われないじゃないですか。"]}, {"box": [1524, 74, 1657, 670], "vertical": true, "font_size": 60, "lines_coords": [[[1608.0, 190.0], [1652.0, 190.0], [1652.0, 645.0], [1608.0, 645.0]], [[1539.0, 74.0], [1614.0, 74.0], [1599.0, 651.0], [1524.0, 651.0]]], "lines": ["大人気御礼！！", "ここで、累計一万部突破！！"]}, {"box": [1389, 27, 1482, 763], "vertical": true, "font_size": 88, "lines_coords": [[[1389.0, 99.0], [1477.0, 99.0], [1477.0, 757.0], [1389.0, 757.0]]], "lines": ["これゆく日常と"]}, {"box": [1049, 121, 1351, 627], "vertical": true, "font_size": 41, "lines_coords": [[[1305.0, 124.0], [1346.0, 124.0], [1346.0, 492.0], [1305.0, 492.0]], [[1239.0, 127.0], [1280.0, 127.0], [1280.0, 545.0], [1239.0, 545.0]], [[1174.0, 121.0], [1217.0, 121.0], [1214.0, 620.0], [1171.0, 620.0]], [[1108.0, 124.0], [1152.0, 124.0], [1152.0, 299.0], [1108.0, 299.0]], [[1049.0, 130.0], [1083.0, 130.0], [1083.0, 311.0], [1049.0, 311.0]]], "lines": ["幸との出会いによって、", "ようやく自分の居場所を", "見つけたかに思えたブンブン。", "そんな時、", "ある事件が"]}, {"box": [41, 6, 145, 686], "vertical": true, "font_size": 88, "lines_coords": [[[46.0, 134.0], [134.0, 134.0], [134.0, 673.0], [46.0, 673.0]]], "lines": ["世界の胎動"]}]}