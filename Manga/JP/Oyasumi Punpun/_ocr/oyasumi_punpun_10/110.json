1163.0, 1432.0], [1163.0, 1598.0], [1134.0, 1598.0]]], "lines": ["南条は一度", "決めたら無駄に", "行動力だけは", "あるからさ。"]}, {"box": [633, 1416, 701, 1604], "vertical": true, "font_size": 30, "lines_coords": [[[666.0, 1416.0], [701.0, 1416.0], [701.0, 1569.0], [666.0, 1569.0]], [[633.0, 1416.0], [662.0, 1416.0], [662.0, 1604.0], [633.0, 1604.0]]], "lines": ["大学ん時も", "そうだったよ、"]}, {"box": [376, 1037, 484, 1258], "vertical": true, "font_size": 33, "lines_coords": [[[445.0, 1037.0], [482.0, 1037.0], [484.0, 1163.0], [447.0, 1163.0]], [[414.0, 1039.0], [443.0, 1039.0], [443.0, 1219.0], [414.0, 1219.0]], [[376.0, 1039.0], [405.0, 1039.0], [405.0, 1258.0], [376.0, 1258.0]]], "lines": ["コイツは", "自己実現しか", "考えてないから。"]}, {"box": [146, 1126, 298, 1296], "vertical": true, "font_size": 33, "lines_coords": [[[252.0, 1128.0], [298.0, 1128.0], [298.0, 1227.0], [252.0, 1227.0]], [[219.0, 1126.0], [254.0, 1126.0], [254.0, 1252.0], [219.0, 1252.0]], [[188.0, 1130.0], [211.0, 1130.0], [211.0, 1281.0], [188.0, 1281.0]], [[146.0, 1128.0], [178.0, 1128.0], [180.0, 1296.0], [149.0, 1296.0]]], "lines": ["いずれ", "躊躇なく", "捨てられる", "だけでしょ。"]}, {"box": [511, 1668, 654, 1912], "vertical": true, "font_size": 30, "lines_coords": [[[625.0, 1670.0], [654.0, 1670.0], [654.0, 1883.0], [625.0, 1883.0]], [[587.0, 1672.0], [616.0, 1672.0], [616.0, 1883.0], [587.0, 1883.0]], [[550.0, 1670.0], [579.0, 1670.0], [577.0, 1881.0], [548.0, 1881.0]], [[515.0, 1668.0], [544.0, 1668.0], [540.0, 1912.0], [511.0, 1912.0]]], "lines": ["せっかく楽勝で", "マスコミの内定", "とったのに結局", "蹴って中退して．．．"]}, {"box": [113, 1759, 249, 2030], "vertical": true, "font_size": 31, "lines_coords": [[[219.0, 1759.0], [248.0, 1759.0], [248.0, 1910.0], [219.0, 1910.0]], [[182.0, 1761.0], [211.0, 1761.0], [211.0, 2030.0], [182.0, 2030.0]], [[140.0, 1759.0], [175.0, 1759.0], [175.0, 2004.0], [140.0, 2004.0]]], "lines": ["それは君が", "あの時就職しろって", "しつこく言うから"]}]}