095.0]], [[883.0, 788.0], [910.0, 788.0], [910.0, 1066.0], [883.0, 1066.0]]], "lines": ["成功ってのは", "やりがいのある仕事で", "それに見合った収入を", "得ること、それ以外の", "なにものでもないし、"]}, {"box": [345, 790, 486, 1006], "vertical": true, "font_size": 33, "lines_coords": [[[463.0, 797.0], [486.0, 797.0], [486.0, 944.0], [463.0, 944.0]], [[424.0, 792.0], [451.0, 792.0], [451.0, 1006.0], [424.0, 1006.0]], [[385.0, 795.0], [414.0, 795.0], [414.0, 977.0], [385.0, 977.0]], [[345.0, 790.0], [382.0, 790.0], [382.0, 896.0], [345.0, 896.0]]], "lines": ["たとえ君が", "瞬間的に幸せを", "感じられたと", "しても、"]}, {"box": [136, 873, 283, 1060], "vertical": true, "font_size": 33, "lines_coords": [[[248.0, 877.0], [283.0, 877.0], [283.0, 1004.0], [248.0, 1004.0]], [[204.0, 873.0], [250.0, 873.0], [250.0, 987.0], [204.0, 987.0]], [[175.0, 879.0], [204.0, 879.0], [204.0, 1060.0], [175.0, 1060.0]], [[136.0, 875.0], [173.0, 875.0], [173.0, 956.0], [136.0, 956.0]]], "lines": ["負け犬は", "負け犬、", "それは変わら", "ない。"]}, {"box": [1136, 1190, 1242, 1401], "vertical": true, "font_size": 35, "lines_coords": [[[1213.0, 1192.0], [1242.0, 1192.0], [1242.0, 1372.0], [1213.0, 1372.0]], [[1175.0, 1192.0], [1204.0, 1192.0], [1204.0, 1401.0], [1175.0, 1401.0]], [[1136.0, 1190.0], [1171.0, 1190.0], [1171.0, 1316.0], [1136.0, 1316.0]]], "lines": ["小野寺くんの", "考える幸せって", "何だい？"]}, {"box": [1026, 1376, 1072, 1484], "vertical": true, "font_size": 35, "lines_coords": [[[1026.0, 1376.0], [1072.0, 1376.0], [1072.0, 1484.0], [1026.0, 1484.0]]], "lines": ["結婚？"]}, {"box": [318, 1238, 403, 1374], "vertical": true, "font_size": 40, "lines_coords": [[[358.0, 1238.0], [403.0, 1238.0], [403.0, 1351.0], [358.0, 1351.0]], [[318.0, 1240.0], [354.0, 1240.0], [354.0, 1374.0], [318.0, 1374.0]]], "lines": ["健康で", "長生き？"]}, {"box": [171, 1337, 252, 1511], "vertical": true, "font_size": 40, "lines_coords": [[[217.0, 1343.0], [252.0, 1343.0], [252.0, 1511.0], [217.0, 1511.0]], [[171.0, 1337.0], [215.0, 1337.0], [215.0, 1447.0], [171.0, 1447.0]]], "lines": ["趣味の充実", "とか？"]}, {"box": [1084, 1676, 1242, 1927], "vertical": true, "font_size": 34, "lines_coords": [[[1204.0, 1676.0], [1242.0, 1676.0], [1242.0, 1807.0], [1204.0, 1807.0]], [[1167.0, 1681.0], [1196.0, 1681.0], [1196.0, 1925.0], [1167.0, 1925.0]], [[1126.0, 1679.0], [1155.0, 1679.0], [1155.0, 1927.0], [1126.0, 1927.0]], [[1084.0, 1676.0], [1122.0, 1676.0], [1122.0, 1780.0], [1084.0, 1780.0]]], "lines": ["君がもし", "つつましい小さな", "幸せを望んでいる", "ならば、"]}, {"box": [939, 1792, 1020, 1995], "vertical": true, "font_size": 34, "lines_coords": [[[985.0, 1794.0], [1020.0, 1794.0], [1020.0, 1995.0], [985.0, 1995.0]], [[939.0, 1792.0], [975.0, 1792.0], [979.0, 1975.0], [944.0, 1975.0]]], "lines": ["それはきっと", "叶うと思う。"]}, {"box": [360, 1645, 463, 1944], "vertical": true, "font_size": 30, "lines_coords": [[[434.0, 1645.0], [463.0, 1645.0], [463.0, 1859.0], [434.0, 1859.0]], [[397.0, 1645.0], [426.0, 1645.0], [426.0, 1944.0], [397.0, 1944.0]], [[360.0, 1647.0], [389.0, 1647.0], [389.0, 1892.0], [360.0, 1892.0]]], "lines": ["ただその幸せは", "「弱者に優しい社会」が", "作った虚妄だから、"]}, {"box": [134, 1739, 275, 2024], "vertical": true, "font_size": 30, "lines_coords": [[[242.0, 1741.0], [273.0, 1741.0], [275.0, 1979.0], [244.0, 1979.0]], [[204.0, 1739.0], [240.0, 1739.0], [240.0, 1958.0], [204.0, 1958.0]], [[171.0, 1741.0], [200.0, 1741.0], [200.0, 2012.0], [171.0, 2012.0]], [[134.0, 1741.0], [161.0, 1741.0], [161.0, 2024.0], [134.0, 2024.0]]], "lines": ["いずれその社会は", "破綻してゆくし、", "生産性の低い奴から", "切り捨てられてゆく。"]}]}