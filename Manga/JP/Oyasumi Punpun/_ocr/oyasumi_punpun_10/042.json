.0, 606.0], [730.0, 877.0], [701.0, 877.0]], [[664.0, 606.0], [693.0, 606.0], [693.0, 846.0], [664.0, 846.0]], [[629.0, 606.0], [656.0, 606.0], [656.0, 799.0], [629.0, 799.0]]], "lines": ["．．．あ、でもそんな", "お金は持ってないよ", "普通の中小企業の", "会社員だから。"]}, {"box": [173, 921, 314, 1227], "vertical": true, "font_size": 31, "lines_coords": [[[285.0, 925.0], [314.0, 925.0], [314.0, 1198.0], [285.0, 1198.0]], [[244.0, 921.0], [279.0, 921.0], [279.0, 1211.0], [244.0, 1211.0]], [[211.0, 923.0], [240.0, 923.0], [240.0, 1227.0], [211.0, 1227.0]], [[173.0, 923.0], [202.0, 923.0], [202.0, 1209.0], [173.0, 1209.0]]], "lines": ["けど私がこんな風で", "基本甘ったれだから、", "ちゃんと叱ってくれる", "人で助かってるんだ。"]}, {"box": [138, 1304, 320, 1577], "vertical": true, "font_size": 31, "lines_coords": [[[285.0, 1304.0], [320.0, 1304.0], [320.0, 1459.0], [285.0, 1459.0]], [[252.0, 1308.0], [281.0, 1308.0], [281.0, 1577.0], [252.0, 1577.0]], [[215.0, 1308.0], [244.0, 1308.0], [244.0, 1517.0], [215.0, 1517.0]], [[178.0, 1306.0], [207.0, 1306.0], [207.0, 1517.0], [178.0, 1517.0]], [[138.0, 1306.0], [173.0, 1306.0], [173.0, 1519.0], [138.0, 1519.0]]], "lines": ["昔は堅実な", "人生設計の人なんて", "アレだったけど", "今は素直に尊敬", "してるよね．．．"]}]}