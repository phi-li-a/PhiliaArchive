, 795.0]], [[167.0, 700.0], [183.0, 700.0], [183.0, 832.0], [167.0, 832.0]], [[144.0, 699.0], [160.0, 699.0], [160.0, 813.0], [144.0, 813.0]]], "lines": ["．．．あの日は", "みんなで大騒ぎ", "だったなァ．．．"]}, {"box": [650, 902, 735, 1066], "vertical": true, "font_size": 18, "lines_coords": [[[715.0, 902.0], [735.0, 902.0], [735.0, 1025.0], [715.0, 1025.0]], [[694.0, 903.0], [714.0, 903.0], [714.0, 1040.0], [694.0, 1040.0]], [[668.0, 902.0], [688.0, 902.0], [688.0, 1025.0], [668.0, 1025.0]], [[650.0, 903.0], [666.0, 903.0], [666.0, 1066.0], [650.0, 1066.0]]], "lines": ["当時プンプンと", "一番仲の良かった", "渡辺君っていう", "男の子がいましてね。"]}, {"box": [541, 983, 598, 1121], "vertical": true, "font_size": 18, "lines_coords": [[[582.0, 983.0], [598.0, 983.0], [598.0, 1120.0], [582.0, 1120.0]], [[561.0, 983.0], [577.0, 983.0], [577.0, 1121.0], [561.0, 1121.0]], [[541.0, 984.0], [557.0, 984.0], [557.0, 1109.0], [541.0, 1109.0]]], "lines": ["その子がみんなに", "こう言い張ってた", "らしいんですよ。"]}, {"box": [216, 936, 279, 1067], "vertical": true, "font_size": 17, "lines_coords": [[[262.0, 936.0], [279.0, 936.0], [277.0, 1016.0], [260.0, 1016.0]], [[240.0, 937.0], [256.0, 937.0], [256.0, 1067.0], [240.0, 1067.0]], [[219.0, 936.0], [240.0, 936.0], [237.0, 1008.0], [216.0, 1008.0]]], "lines": ["「流れ星を", "捕まえた事ある」", "って．．．"]}, {"box": [79, 1001, 158, 1140], "vertical": true, "font_size": 17, "lines_coords": [[[141.0, 1001.0], [158.0, 1001.0], [158.0, 1087.0], [141.0, 1087.0]], [[120.0, 1003.0], [137.0, 1003.0], [137.0, 1123.0], [120.0, 1123.0]], [[100.0, 1003.0], [117.0, 1003.0], [117.0, 1140.0], [100.0, 1140.0]], [[79.0, 1003.0], [96.0, 1003.0], [96.0, 1072.0], [79.0, 1072.0]]], "lines": ["子供らしい", "たわいもない嘘", "だったんでしょう", "けど．．．"]}]}