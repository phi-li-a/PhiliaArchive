{"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [645, 71, 725, 227], "vertical": true, "font_size": 17, "lines_coords": [[[708.0, 73.0], [725.0, 73.0], [725.0, 227.0], [708.0, 227.0]], [[687.0, 72.0], [704.0, 72.0], [704.0, 191.0], [687.0, 191.0]], [[667.0, 71.0], [684.0, 71.0], [681.0, 192.0], [665.0, 192.0]], [[645.0, 71.0], [661.0, 71.0], [661.0, 214.0], [645.0, 214.0]]], "lines": ["フリーターとはいえ", "現状一応は自立", "てきてる訳だし", "資格の勉強もして、"]}, {"box": [524, 202, 585, 312], "vertical": true, "font_size": 17, "lines_coords": [[[563.0, 202.0], [585.0, 202.0], [585.0, 257.0], [563.0, 257.0]], [[545.0, 202.0], [563.0, 202.0], [561.0, 307.0], [543.0, 307.0]], [[524.0, 203.0], [541.0, 203.0], [541.0, 312.0], [524.0, 312.0]]], "lines": ["そして", "それを愚痴る", "訳てもなくね。"]}, {"box": [223, 113, 302, 234], "vertical": true, "font_size": 16, "lines_coords": [[[284.0, 113.0], [302.0, 113.0], [299.0, 201.0], [282.0, 201.0]], [[263.0, 116.0], [279.0, 116.0], [279.0, 219.0], [263.0, 219.0]], [[243.0, 116.0], [260.0, 116.0], [260.0, 234.0], [243.0, 234.0]], [[224.0, 117.0], [238.0, 117.0], [238.0, 207.0], [224.0, 207.0]]], "lines": ["まぁ南条は", "小野寺くんに", "自信持たれちゃ", "困るもんな。"]}, {"box": [463, 338, 544, 476], "vertical": true, "font_size": 17, "lines_coords": [[[528.0, 339.0], [544.0, 339.0], [544.0, 444.0], [528.0, 444.0]], [[506.0, 338.0], [521.0, 338.0], [523.0, 460.0], [508.0, 460.0]], [[486.0, 341.0], [502.0, 341.0], [502.0, 476.0], [486.0, 476.0]], [[463.0, 341.0], [480.0, 341.0], [482.0, 451.0], [466.0, 451.0]]], "lines": ["才能あろうが", "能書き垂れてる", "だけの奴よりかは", "マシでしょう。"]}, {"box": [83, 357, 164, 469], "vertical": true, "font_size": 18, "lines_coords": [[[144.0, 358.0], [164.0, 358.0], [164.0, 446.0], [144.0, 446.0]], [[123.0, 358.0], [144.0, 358.0], [144.0, 430.0], [123.0, 430.0]], [[104.0, 358.0], [120.0, 358.0], [120.0, 442.0], [104.0, 442.0]], [[83.0, 357.0], [98.0, 357.0], [98.0, 467.0], [83.0, 467.0]]], "lines": ["常に自分の", "手の内で", "飼い殺しに", "するためには。"]}, {"box": [649, 557, 727, 685], "vertical": true, "font_size": 17, "lines_coords": [[[711.0, 557.0], [727.0, 557.0], [727.0, 652.0], [711.0, 652.0]], [[690.0, 558.0], [706.0, 558.0], [706.0, 677.0], [690.0, 677.0]], [[667.0, 558.0], [684.0, 558.0], [684.0, 685.0], [667.0, 685.0]], [[649.0, 557.0], [665.0, 557.0], [665.0, 665.0], [649.0, 665.0]]], "lines": ["「自分を理解", "してくれるのは", "この人だけ」って", "錯覚するよう、"]}, {"box": [584, 726, 684, 848], "vertical": true, "font_size": 17, "lines_coords": [[[667.0, 730.0], [684.0, 730.0], [684.0, 848.0], [667.0, 848.0]], [[647.0, 728.0], [664.0, 728.0], [664.0, 830.0], [647.0, 830.0]], [[625.0, 728.0], [641.0, 728.0], [641.0, 832.0], [625.0, 832.0]], [[603.0, 726.0], [623.0, 726.0], [620.0, 832.0], [600.0, 832.0]], [[584.0, 728.0], [600.0, 728.0], [600.0, 819.0], [584.0, 819.0]]], "lines": ["いつもアンタは", "自分の都合で", "小野寺くんを", "甘やかしたり", "叱責したり、"]}, {"box": [125, 752, 224, 889], "vertical": true, "font_size": 18, "lines_coords": [[[208.0, 753.0], [224.0, 753.0], [224.0, 856.0], [208.0, 856.0]], [[187.0, 753.0], [203.0, 753.0], [203.0, 856.0], [187.0, 856.0]], [[165.0, 752.0], [185.0, 752.0], [182.0, 841.0], [162.0, 841.0]], [[145.0, 754.0], [161.0, 754.0], [161.0, 856.0], [145.0, 856.0]], [[125.0, 754.0], [141.0, 754.0], [141.0, 889.0], [125.0, 889.0]]], "lines": ["小野寺くんが", "本当はどんな", "人間なのか", "南条はそれで", "知ってるつもり？"]}, {"box": [74, 951, 155, 1074], "vertical": true, "font_size": 18, "lines_coords": [[[135.0, 952.0], [155.0, 952.0], [155.0, 1074.0], [135.0, 1074.0]], [[115.0, 951.0], [137.0, 951.0], [134.0, 1073.0], [113.0, 1073.0]], [[96.0, 953.0], [112.0, 953.0], [112.0, 1072.0], [96.0, 1072.0]], [[74.0, 953.0], [91.0, 953.0], [91.0, 1046.0], [74.0, 1046.0]]], "lines": ["そういう傲慢な", "人付き合いしか", "できないなんて", "可哀想だわ。"]}]}