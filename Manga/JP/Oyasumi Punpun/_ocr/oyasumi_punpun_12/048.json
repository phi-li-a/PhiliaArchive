.0, 532.0], [165.0, 635.0], [148.0, 635.0]], [[126.0, 530.0], [148.0, 530.0], [148.0, 577.0], [126.0, 577.0]]], "lines": ["それもまた", "自意識過剰さが", "故だとは思う", "けど。"]}, {"box": [651, 744, 730, 897], "vertical": true, "font_size": 16, "lines_coords": [[[713.0, 744.0], [729.0, 744.0], [729.0, 829.0], [713.0, 829.0]], [[692.0, 745.0], [708.0, 745.0], [708.0, 847.0], [692.0, 847.0]], [[670.0, 744.0], [686.0, 744.0], [686.0, 897.0], [670.0, 897.0]], [[651.0, 745.0], [666.0, 745.0], [666.0, 837.0], [651.0, 837.0]]], "lines": ["もっと心底", "他人を馬鹿に", "てきるようになれば", "楽なのにさ。"]}, {"box": [350, 741, 431, 862], "vertical": true, "font_size": 18, "lines_coords": [[[413.0, 744.0], [429.0, 744.0], [429.0, 862.0], [413.0, 862.0]], [[391.0, 742.0], [411.0, 742.0], [411.0, 832.0], [391.0, 832.0]], [[370.0, 741.0], [391.0, 741.0], [391.0, 813.0], [370.0, 813.0]], [[350.0, 741.0], [366.0, 741.0], [366.0, 851.0], [350.0, 851.0]]], "lines": ["あいつがそんな", "尊大な態度", "とったら", "はったおすわ。"]}, {"box": [511, 986, 556, 1100], "vertical": true, "font_size": 20, "lines_coords": [[[536.0, 987.0], [556.0, 987.0], [556.0, 1100.0], [536.0, 1100.0]], [[511.0, 986.0], [531.0, 986.0], [531.0, 1072.0], [511.0, 1072.0]]], "lines": ["優しい人って", "損だよね。"]}, {"box": [223, 978, 243, 1048], "vertical": true, "font_size": 18, "lines_coords": [[[223.0, 978.0], [243.0, 978.0], [243.0, 1048.0], [223.0, 1048.0]]], "lines": ["．．．そう？"]}, {"box": [106, 1003, 187, 1125], "vertical": true, "font_size": 18, "lines_coords": [[[171.0, 1004.0], [187.0, 1004.0], [187.0, 1107.0], [171.0, 1107.0]], [[149.0, 1004.0], [166.0, 1004.0], [166.0, 1125.0], [149.0, 1125.0]], [[128.0, 1004.0], [145.0, 1004.0], [145.0, 1108.0], [128.0, 1108.0]], [[106.0, 1003.0], [127.0, 1003.0], [127.0, 1057.0], [106.0, 1057.0]]], "lines": ["小野寺くんて", "割りとちゃんと", "してると思う", "けど？"]}]}