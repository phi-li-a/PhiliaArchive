{"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [690, 98, 727, 398], "vertical": true, "font_size": 16, "lines_coords": [[[711.0, 101.0], [727.0, 101.0], [727.0, 398.0], [711.0, 398.0]], [[690.0, 98.0], [706.0, 98.0], [706.0, 356.0], [690.0, 356.0]]], "lines": ["僕が夜勤に出るために夕方頃起きると", "ちょうど君は仕事から帰ってくる"]}, {"box": [583, 97, 661, 459], "vertical": true, "font_size": 16, "lines_coords": [[[645.0, 97.0], [661.0, 97.0], [661.0, 371.0], [645.0, 371.0]], [[623.0, 97.0], [639.0, 97.0], [639.0, 459.0], [623.0, 459.0]], [[603.0, 98.0], [619.0, 98.0], [619.0, 387.0], [603.0, 387.0]], [[583.0, 97.0], [599.0, 97.0], [599.0, 455.0], [583.0, 455.0]]], "lines": ["君は仕事先の人間関係について少し", "愚痴を漏らして、それはいつもの事なのだけど、", "僕は若干苛立ちながら、それで鬱憤が", "晴れるなら、我慢は仕方ないと僕は思うんだ。」"]}, {"box": [160, 596, 566, 755], "vertical": true, "font_size": 19, "lines_coords": [[[542.0, 600.0], [562.0, 600.0], [562.0, 713.0], [542.0, 713.0]], [[522.0, 598.0], [538.0, 598.0], [538.0, 754.0], [522.0, 754.0]], [[497.0, 598.0], [517.0, 598.0], [518.0, 738.0], [499.0, 738.0]], [[477.0, 598.0], [497.0, 598.0], [497.0, 673.0], [477.0, 673.0]], [[458.0, 600.0], [477.0, 600.0], [477.0, 721.0], [458.0, 721.0]], [[439.0, 600.0], [455.0, 600.0], [455.0, 753.0], [439.0, 753.0]], [[413.0, 598.0], [439.0, 598.0], [439.0, 662.0], [413.0, 662.0]], [[386.0, 600.0], [402.0, 600.0], [402.0, 703.0], [386.0, 703.0]], [[364.0, 600.0], [384.0, 600.0], [384.0, 687.0], [364.0, 687.0]], [[344.0, 602.0], [360.0, 602.0], [360.0, 735.0], [344.0, 735.0]], [[319.0, 598.0], [345.0, 598.0], [345.0, 660.0], [319.0, 660.0]], [[288.0, 598.0], [308.0, 598.0], [308.0, 740.0], [288.0, 740.0]], [[269.0, 601.0], [285.0, 601.0], [285.0, 719.0], [269.0, 719.0]], [[244.0, 597.0], [269.0, 597.0], [269.0, 662.0], [244.0, 662.0]], [[226.0, 600.0], [243.0, 600.0], [244.0, 735.0], [227.0, 735.0]], [[207.0, 600.0], [223.0, 600.0], [223.0, 708.0], [207.0, 708.0]], [[183.0, 598.0], [203.0, 598.0], [203.0, 670.0], [183.0, 670.0]], [[164.0, 598.0], [183.0, 598.0], [183.0, 754.0], [164.0, 754.0]]], "lines": ["「それは見事に", "すれ違いの生活だし", "貯金なんてできる", "訳ないし、", "もしどちらかが", "事故にでもあったら", "大変だ。", "僕はくたびれ", "今より更に", "つまらない人間に", "なって、", "きっと君はいずれ", "僕より少し背が", "高くて、", "少し朗らかな男を", "好きになって、", "僕を捨て", "出てゆくんだろう。」"]}, {"box": [464, 1028, 621, 1143], "vertical": true, "font_size": 18, "lines_coords": [[[597.0, 1030.0], [618.0, 1030.0], [618.0, 1109.0], [597.0, 1109.0]], [[567.0, 1031.0], [583.0, 1031.0], [583.0, 1117.0], [567.0, 1117.0]], [[545.0, 1031.0], [562.0, 1031.0], [562.0, 1140.0], [545.0, 1140.0]]], "lines": ["「．．．あれ？", "ごめん全然", "楽しくないね。"]}, {"box": [462, 1029, 501, 1119], "vertical": true, "font_size": 18, "lines_coords": [[[481.0, 1030.0], [501.0, 1030.0], [501.0, 1117.0], [481.0, 1117.0]], [[462.0, 1031.0], [479.0, 1031.0], [479.0, 1116.0], [462.0, 1116.0]]], "lines": ["．．．始めから", "やり直し。」"]}]}