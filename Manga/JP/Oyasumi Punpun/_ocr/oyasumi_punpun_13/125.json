{"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [693, 96, 752, 284], "vertical": true, "font_size": 17, "lines_coords": [[[735.0, 97.0], [752.0, 97.0], [752.0, 244.0], [735.0, 244.0]], [[714.0, 97.0], [731.0, 97.0], [731.0, 284.0], [714.0, 284.0]], [[693.0, 96.0], [709.0, 96.0], [709.0, 269.0], [693.0, 269.0]]], "lines": ["少しの間、目を閉じ", "改札に吸い込まれてゆく", "人の波に身を委ねれば"]}, {"box": [584, 94, 665, 318], "vertical": true, "font_size": 17, "lines_coords": [[[649.0, 98.0], [665.0, 98.0], [665.0, 268.0], [649.0, 268.0]], [[627.0, 97.0], [644.0, 97.0], [644.0, 318.0], [627.0, 318.0]], [[603.0, 94.0], [623.0, 94.0], [625.0, 303.0], [605.0, 303.0]], [[584.0, 96.0], [600.0, 96.0], [602.0, 288.0], [585.0, 288.0]]], "lines": ["次に目を開けた時には", "自分がまだ何者でもなかった", "数か月前のあの時に戻って", "いるのではないだろうが、"]}, {"box": [376, 90, 411, 208], "vertical": true, "font_size": 34, "lines_coords": [[[376.0, 90.0], [410.0, 90.0], [410.0, 200.0], [376.0, 200.0]]], "lines": ["ヨッス"]}, {"box": [175, 86, 254, 295], "vertical": true, "font_size": 17, "lines_coords": [[[237.0, 86.0], [254.0, 86.0], [254.0, 237.0], [237.0, 237.0]], [[217.0, 86.0], [234.0, 86.0], [234.0, 257.0], [217.0, 257.0]], [[196.0, 87.0], [213.0, 87.0], [213.0, 273.0], [196.0, 273.0]], [[175.0, 86.0], [192.0, 86.0], [192.0, 295.0], [175.0, 295.0]]], "lines": ["二度と帰る事のない", "八畳間の薄暗い部屋と", "無意味で退屈なあの街の", "景色を懐かしく感じました。"]}, {"box": [117, 84, 154, 321], "vertical": true, "font_size": 17, "lines_coords": [[[138.0, 85.0], [154.0, 85.0], [154.0, 321.0], [138.0, 321.0]], [[118.0, 84.0], [135.0, 84.0], [134.0, 247.0], [117.0, 247.0]]], "lines": ["けれど自分が向かうべき場所は", "そこではないのです。"]}, {"box": [466, 1011, 485, 1068], "vertical": true, "font_size": 19, "lines_coords": [[[466.0, 1011.0], [485.0, 1011.0], [485.0, 1068.0], [466.0, 1068.0]]], "lines": ["．．．彼は"]}, {"box": [460, 1008, 489, 1073], "vertical": true, "font_size": 24, "lines_coords": [[[460.0, 1008.0], [489.0, 1008.0], [489.0, 1073.0], [460.0, 1073.0]]], "lines": ["．．．彼は"]}, {"