{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [862, 103, 996, 315], "vertical": true, "font_size": 26, "lines_coords": [[[968.0, 103.0], [995.0, 103.0], [996.0, 315.0], [970.0, 315.0]], [[934.0, 104.0], [960.0, 104.0], [960.0, 248.0], [934.0, 248.0]], [[896.0, 104.0], [923.0, 104.0], [923.0, 314.0], [896.0, 314.0]], [[862.0, 106.0], [884.0, 106.0], [884.0, 245.0], [862.0, 245.0]]], "lines": ["父は人生の大半を", "勤労に捧げ、", "母は子供の教育に", "努め続けた。"]}, {"box": [793, 310, 859, 470], "vertical": true, "font_size": 26, "lines_coords": [[[829.0, 310.0], [857.0, 310.0], [859.0, 420.0], [831.0, 420.0]], [[793.0, 312.0], [820.0, 312.0], [820.0, 470.0], [793.0, 470.0]]], "lines": ["姉は来月", "公務員の男と"]}, {"box": [758, 312, 858, 468], "vertical": true, "font_size": 26, "lines_coords": [[[759.0, 312.0], [785.0, 312.0], [785.0, 428.0], [759.0, 428.0]]], "lines": ["結婚する。"]}, {"box": [201, 171, 267, 345], "vertical": true, "font_size": 27, "lines_coords": [[[235.0, 171.0], [267.0, 171.0], [267.0, 335.0], [235.0, 335.0]], [[201.0, 175.0], [228.0, 175.0], [228.0, 345.0], [201.0, 345.0]]], "lines": ["．．．でも、よく", "考えてほしい。"]}, {"box": [107, 400, 242, 637], "vertical": true, "font_size": 27, "lines_coords": [[[215.0, 403.0], [242.0, 403.0], [240.0, 637.0], [214.0, 637.0]], [[178.0, 401.0], [204.0, 401.0], [204.0, 585.0], [178.0, 585.0]], [[142.0, 400.0], [168.0, 400.0], [168.0, 625.0], [142.0, 625.0]], [[107.0, 404.0], [129.0, 404.0], [129.0, 626.0], [107.0, 626.0]]], "lines": ["一見、何不自由ない", "幸福な家庭だが", "そんな幸せっただの", "ハリボテじゃないか。"]}, {"box": [871, 735, 975, 881], "vertical": true, "font_size": 30, "lines_coords": [[[946.0, 737.0], [973.0, 737.0], [973.0, 878.0], [946.0, 878.0]], [[906.0, 735.0], [939.0, 735.0], [939.0, 881.0], [906.0, 881.0]], [[871.0, 737.0], [900.0, 737.0], [900.0, 840.0], [871.0, 840.0]]], "lines": ["病気、事故、", "天災、人災、", "裏切りー"]}, {"box": [906, 1083, 1006, 1266], "vertical": true, "font_size": 23, "lines_coords": [[[981.0, 1085.0], [1003.0, 1085.0], [1003.0, 1214.0], [981.0, 1214.0]], [[945.0, 1085.0], [967.0, 1085.0], [967.0, 1264.0], [945.0, 1264.0]], [[906.0, 1084.0], [932.0, 1084.0], [932.0, 1223.0], [906.0, 1223.0]]], "lines": ["定年間際に", "親父は僕にこう", "言ったんだ。"]}, {"box": [142, 803, 281, 1014], "vertical": true, "font_size": 28, "lines_coords": [[[253.0, 804.0], [279.0, 804.0], [279.0, 989.0], [253.0, 989.0]], [[215.0, 804.0], [243.0, 804.0], [242.0, 1014.0], [214.0, 1014.0]], [[178.0, 803.0], [209.0, 803.0], [209.0, 1014.0], [178.0, 1014.0]], [[145.0, 803.0], [171.0, 803.0], [168.0, 970.0], [142.0, 970.0]]], "lines": ["不幸のカードを", "いつ引くかなんて", "それこそ神のみぞ", "知る、なんだ。"]}, {"box": [489, 1128, 589, 1312], "vertical": true, "font_size": 26, "lines_coords": [[[562.0, 1128.0], [589.0, 1128.0], [589.0, 1275.0], [562.0, 1275.0]], [[525.0, 1129.0], [551.0, 1129.0], [551.0, 1287.0], [525.0, 1287.0]], [[489.0, 1131.0], [515.0, 1131.0], [515.0, 1312.0], [489.0, 1312.0]]], "lines": ["「これからは", "第二の人生を", "楽しむぞ」って。"]}, {"box": [448, 1342, 545, 1551], "vertical": true, "font_size": 26, "lines_coords": [[[518.0, 1342.0], [545.0, 1342.0], [545.0, 1484.0], [518.0, 1484.0]], [[481.0, 1343.0], [507.0, 1343.0], [507.0, 1551.0], [481.0, 1551.0]], [[448.0, 1345.0], [470.0, 1345.0], [470.0, 1503.0], [448.0, 1503.0]]], "lines": ["彼はその後、", "癌に冒されていた", "のを知ったよ。"]}, {"box": [92, 1259, 285, 1523], "vertical": true, "font_size": 26, "lines_coords": [[[257.0, 1260.0], [284.0, 1260.0], [284.0, 1523.0], [257.0, 1523.0]], [[225.0, 1260.0], [251.0, 1260.0], [251.0, 1496.0], [225.0, 1496.0]], [[193.0, 1262.0], [215.0, 1262.0], [215.0, 1495.0], [193.0, 1495.0]], [[157.0, 1260.0], [184.0, 1260.0], [184.0, 1496.0], [157.0, 1496.0]], [[125.0, 1259.0], [151.0, 1259.0], [151.0, 1496.0], [125.0, 1496.0]], [[92.0, 1259.0], [118.0, 1259.0], [118.0, 1445.0], [92.0, 1445.0]]], "lines": ["いつ振り落とされるか", "わからない、小さな", "幸せや希望に必死に", "しがみつこうとする", "その姿は、果たして", "幸せな姿かね！？"]}]}