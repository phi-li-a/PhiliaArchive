 881.0]], [[784.0, 709.0], [810.0, 709.0], [810.0, 904.0], [784.0, 904.0]]], "lines": ["「入院食が", "少ない！！」とか", "「夜が退屈」って。"]}, {"box": [921, 989, 1021, 1144], "vertical": true, "font_size": 27, "lines_coords": [[[995.0, 990.0], [1021.0, 990.0], [1021.0, 1120.0], [995.0, 1120.0]], [[957.0, 989.0], [984.0, 989.0], [984.0, 1143.0], [957.0, 1143.0]], [[921.0, 989.0], [948.0, 989.0], [948.0, 1121.0], [921.0, 1121.0]]], "lines": ["あーーっ！！", "プン山さんの", "息子さん！？"]}, {"box": [570, 981, 671, 1164], "vertical": true, "font_size": 27, "lines_coords": [[[643.0, 982.0], [670.0, 982.0], [670.0, 1164.0], [643.0, 1164.0]], [[606.0, 981.0], [634.0, 981.0], [634.0, 1112.0], [606.0, 1112.0]], [[570.0, 981.0], [596.0, 981.0], [596.0, 1137.0], [570.0, 1137.0]]], "lines": ["お母さん、すぐ", "退院できる", "からねーー！！"]}, {"box": [148, 723, 210, 891], "vertical": true, "font_size": 24, "lines_coords": [[[182.0, 723.0], [209.0, 723.0], [209.0, 829.0], [182.0, 829.0]], [[150.0, 725.0], [171.0, 725.0], [171.0, 890.0], [150.0, 890.0]]], "lines": ["あらら？", "失礼しました。"]}]}