{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [946, 135, 974, 267], "vertical": true, "font_size": 27, "lines_coords": [[[946.0, 137.0], [973.0, 137.0], [973.0, 267.0], [946.0, 267.0]]], "lines": ["．．．．．．脳が？"]}, {"box": [656, 562, 799, 748], "vertical": true, "font_size": 30, "lines_coords": [[[771.0, 565.0], [798.0, 565.0], [798.0, 698.0], [771.0, 698.0]], [[732.0, 564.0], [764.0, 564.0], [764.0, 725.0], [732.0, 725.0]], [[698.0, 564.0], [725.0, 564.0], [725.0, 748.0], [698.0, 748.0]], [[656.0, 564.0], [689.0, 562.0], [693.0, 656.0], [660.0, 657.0]]], "lines": ["そんな病気", "知らないけど", "まー死んじゃう", "かもね。"]}, {"box": [395, 504, 572, 693], "vertical": true, "font_size": 27, "lines_coords": [[[542.0, 510.0], [568.0, 510.0], [568.0, 678.0], [542.0, 678.0]], [[503.0, 506.0], [534.0, 506.0], [534.0, 693.0], [503.0, 693.0]], [[468.0, 506.0], [495.0, 506.0], [495.0, 690.0], [468.0, 690.0]], [[432.0, 507.0], [459.0, 507.0], [459.0, 664.0], [432.0, 664.0]], [[395.0, 506.0], [421.0, 506.0], [421.0, 650.0], [395.0, 650.0]]], "lines": ["「脳がとろけて", "変なところから", "とび出すなんて", "ことはあるの", "だろうか！？」"]}, {"box": [221, 505, 323, 673], "vertical": true, "font_size": 26, "lines_coords": [[[293.0, 506.0], [321.0, 506.0], [321.0, 635.0], [293.0, 635.0]], [[257.0, 507.0], [284.0, 507.0], [284.0, 662.0], [257.0, 662.0]], [[223.0, 509.0], [245.0, 509.0], [245.0, 668.0], [223.0, 668.0]]], "lines": ["プンプンは", "勇気を出して", "たずねました。"]}, {"box": [971, 789, 1001, 934], "vertical": true, "font_size": 27, "lines_coords": [[[975.0, 789.0], [1001.0, 789.0], [998.0, 934.0], [971.0, 934.0]]], "lines": ["はっはーん。"]}, {"box": [848, 846, 948, 1043], "vertical": true, "font_size": 27, "lines_coords": [[[918.0, 846.0], [945.0, 846.0], [948.0, 967.0], [921.0, 967.0]], [[882.0, 848.0], [909.0, 848.0], [910.0, 1043.0], [884.0, 1043.0]], [[848.0, 851.0], [875.0, 851.0], [875.0, 970.0], [848.0, 970.0]]], "lines": ["なるほど、", "そういうことね、", "はっはっ。"]}, {"box": [176, 871, 282, 1042], "vertical": true, "font_size": 27, "lines_coords": [[[251.0, 871.0], [278.0, 871.0], [281.0, 1042.0], [254.0, 1042.0]], [[217.0, 873.0], [243.0, 873.0], [243.0, 1006.0], [217.0, 1006.0]], [[176.0, 873.0], [203.0, 873.0], [206.0, 1040.0], [179.0, 1040.0]]], "lines": ["だいじょーぶ、", "プンプンは", "死なないから。"]}, {"box": [978, 1146, 1042, 1284], "vertical": true, "font_size": 26, "lines_coords": [[[1015.0, 1148.0], [1042.0, 1148.0], [1042.0, 1284.0], [1015.0, 1284.0]], [[978.0, 1146.0], [1006.0, 1146.0], [1006.0, 1265.0], [978.0, 1265.0]]], "lines": ["しかしだね、", "プンプン。"]}, {"box": [821, 1229, 945, 1464], "vertical": true, "font_size": 26, "lines_coords": [[[918.0, 1229.0], [945.0, 1229.0], [945.0, 1429.0], [918.0, 1429.0]], [[884.0, 1229.0], [910.0, 1229.0], [910.0, 1464.0], [884.0, 1464.0]], [[850.0, 1231.0], [876.0, 1231.0], [876.0, 1454.0], [850.0, 1454.0]], [[821.0, 1232.0], [843.0, 1232.0], [843.0, 1371.0], [821.0, 1371.0]]], "lines": ["世の中にはまだ", "プンプンの知らない", "ことが、たーくさん", "あるのだよ。"]}, {"box": [140, 1300, 279, 1535], "vertical": true, "font_size": 28, "lines_coords": [[[250.0, 1301.0], [276.0, 1301.0], [278.0, 1535.0], [251.0, 1535.0]], [[215.0, 1303.0], [242.0, 1303.0], [242.0, 1460.0], [215.0, 1460.0]], [[178.0, 1303.0], [204.0, 1303.0], [204.0, 1518.0], [178.0, 1518.0]], [[140.0, 1300.0], [173.0, 1300.0], [173.0, 1393.0], [140.0, 1393.0]]], "lines": ["おじさんチョイスで", "本を貸すから", "少し勉強したまえ。", "はっは。"]}]}