, "lines": ["黒点の隠滅は", "我々にとって重要な", "テーゼだったと", "いうのに"]}, {"box": [192, 1370, 249, 1525], "vertical": true, "font_size": 44, "lines_coords": [[[192.0, 1370.0], [236.0, 1370.0], [236.0, 1525.0], [192.0, 1525.0]]], "lines": ["．．．和田君。"]}, {"box": [1199, 1594, 1228, 1799], "vertical": true, "font_size": 32, "lines_coords": [[[1199.0, 1594.0], [1228.0, 1594.0], [1228.0, 1799.0], [1199.0, 1799.0]]], "lines": ["もしかしたら、"]}, {"box": [940, 1776, 1139, 1979], "vertical": true, "font_size": 32, "lines_coords": [[[1108.0, 1776.0], [1139.0, 1776.0], [1137.0, 1977.0], [1106.0, 1977.0]], [[1064.0, 1778.0], [1099.0, 1778.0], [1099.0, 1977.0], [1064.0, 1977.0]], [[1025.0, 1778.0], [1054.0, 1778.0], [1054.0, 1977.0], [1025.0, 1977.0]], [[979.0, 1776.0], [1015.0, 1776.0], [1015.0, 1979.0], [979.0, 1979.0]], [[940.0, 1778.0], [969.0, 1778.0], [969.0, 1917.0], [940.0, 1917.0]]], "lines": ["この世の中は", "僕が思うより", "ずっとずつと", "平凡なのかも", "しれない"]}, {"box": [182, 1784, 306, 1987], "vertical": true, "font_size": 39, "lines_coords": [[[254.0, 1784.0], [306.0, 1784.0], [306.0, 1898.0], [254.0, 1898.0]], [[219.0, 1788.0], [256.0, 1788.0], [256.0, 1925.0], [219.0, 1925.0]], [[182.0, 1790.0], [211.0, 1790.0], [211.0, 1985.0], [182.0, 1985.0]]], "lines": ["．．．一体", "黒点とは", "何なんだい？"]}]}