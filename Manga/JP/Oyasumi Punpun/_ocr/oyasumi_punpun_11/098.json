519.0, 1105.0], [490.0, 1105.0]], [[445.0, 904.0], [476.0, 904.0], [478.0, 1140.0], [447.0, 1140.0]], [[403.0, 906.0], [439.0, 906.0], [439.0, 1080.0], [403.0, 1080.0]]], "lines": ["人種も言語も", "あらゆる垣根を", "飛び越えて、"]}, {"box": [1008, 991, 1172, 1229], "vertical": true, "font_size": 37, "lines_coords": [[[1128.0, 993.0], [1172.0, 993.0], [1172.0, 1134.0], [1128.0, 1134.0]], [[1091.0, 993.0], [1126.0, 993.0], [1126.0, 1165.0], [1091.0, 1165.0]], [[1048.0, 991.0], [1083.0, 991.0], [1085.0, 1229.0], [1050.0, 1229.0]], [[1008.0, 995.0], [1044.0, 995.0], [1044.0, 1165.0], [1008.0, 1165.0]]], "lines": ["完全なる", "秩序と調和", "という新世界の", "創造を．．．．．．"]}, {"box": [1135, 1349, 1257, 1672], "vertical": true, "font_size": 31, "lines_coords": [[[1224.0, 1351.0], [1253.0, 1351.0], [1253.0, 1614.0], [1224.0, 1614.0]], [[1178.0, 1349.0], [1209.0, 1349.0], [1211.0, 1581.0], [1180.0, 1581.0]], [[1135.0, 1349.0], [1168.0, 1349.0], [1172.0, 1672.0], [1139.0, 1672.0]]], "lines": ["僕は全人類共通の", "接拶としてこの", "言葉を提案している。"]}, {"box": [165, 993, 331, 1285], "vertical": true, "font_size": 33, "lines_coords": [[[302.0, 1002.0], [331.0, 1002.0], [331.0, 1198.0], [302.0, 1198.0]], [[258.0, 1002.0], [287.0, 1002.0], [287.0, 1165.0], [258.0, 1165.0]], [[213.0, 997.0], [248.0, 997.0], [248.0, 1169.0], [213.0, 1169.0]], [[165.0, 993.0], [207.0, 993.0], [213.0, 1285.0], [171.0, 1285.0]]], "lines": ["全ての喜びを", "魂の振動で", "共有し合う", "新たなステージへ。"]}, {"box": [271, 1658, 370, 1979], "vertical": true, "font_size": 45, "lines_coords": [[[321.0, 1658.0], [370.0, 1658.0], [370.0, 1960.0], [321.0, 1960.0]], [[271.0, 1664.0], [312.0, 1664.0], [312.0, 1973.0], [271.0, 1973.0]]], "lines": ["「グッドヴァイブ", "レーション」とね。"]}]}