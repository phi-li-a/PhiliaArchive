.0], [1168.0, 1364.0], [1168.0, 1573.0], [1139.0, 1573.0]]], "lines": ["．．．その時", "君の命は", "燃えているか？"]}, {"box": [323, 954, 503, 1200], "vertical": true, "font_size": 32, "lines_coords": [[[474.0, 958.0], [503.0, 958.0], [503.0, 1140.0], [474.0, 1140.0]], [[432.0, 954.0], [468.0, 954.0], [468.0, 1200.0], [432.0, 1200.0]], [[399.0, 958.0], [428.0, 958.0], [428.0, 1146.0], [399.0, 1146.0]], [[362.0, 956.0], [391.0, 956.0], [391.0, 1138.0], [362.0, 1138.0]], [[323.0, 956.0], [358.0, 956.0], [358.0, 1109.0], [323.0, 1109.0]]], "lines": ["しかし実際は", "どちらとも正解の", "場合もあるし、", "その逆もまた", "然りだ．．．"]}, {"box": [167, 1028, 271, 1244], "vertical": true, "font_size": 32, "lines_coords": [[[242.0, 1031.0], [271.0, 1031.0], [271.0, 1242.0], [242.0, 1242.0]], [[200.0, 1028.0], [236.0, 1028.0], [236.0, 1244.0], [200.0, 1244.0]], [[167.0, 1031.0], [196.0, 1031.0], [196.0, 1242.0], [167.0, 1242.0]]], "lines": ["結論を急ぐのは", "若さの特権かも", "しれないが．．．"]}, {"box": [625, 1548, 669, 1656], "vertical": true, "font_size": 40, "lines_coords": [[[625.0, 1548.0], [669.0, 1548.0], [669.0, 1656.0], [625.0, 1656.0]]], "lines": ["ん．．．．．"]}, {"box": [803, 1788, 946, 1979], "vertical": true, "font_size": 33, "lines_coords": [[[907.0, 1788.0], [946.0, 1788.0], [946.0, 1886.0], [907.0, 1886.0]], [[874.0, 1788.0], [909.0, 1788.0], [909.0, 1979.0], [874.0, 1979.0]], [[838.0, 1790.0], [867.0, 1790.0], [867.0, 1966.0], [838.0, 1966.0]], [[803.0, 1790.0], [832.0, 1790.0], [832.0, 1939.0], [803.0, 1939.0]]], "lines": ["．．．時折", "夢想するんだ、", "もうひとつの", "人生を．．．"]}, {"box": [588, 1728, 623, 1931], "vertical": true, "font_size": 40, "lines_coords": [[[588.0, 1728.0], [623.0, 1728.0], [623.0, 1931.0], [588.0, 1931.0]]], "lines": ["．．．雄一くん？"]}, {"box": [174, 1803, 253, 2004], "vertical": true, "font_size": 33, "lines_coords": [[[215.0, 1803.0], [250.0, 1803.0], [250.0, 1941.0], [215.0, 1941.0]], [[176.0, 1803.0], [207.0, 1803.0], [205.0, 2001.0], [174.0, 2001.0]]], "lines": ["誰とお話", "してるの．．．？"]}]}