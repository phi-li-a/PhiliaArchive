{"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [712, 165, 785, 382], "vertical": true, "font_size": 34, "lines_coords": [[[754.0, 169.0], [783.0, 169.0], [783.0, 380.0], [754.0, 380.0]], [[712.0, 165.0], [751.0, 165.0], [751.0, 262.0], [712.0, 262.0]]], "lines": ["チューペット君", "かい？"]}, {"box": [198, 180, 374, 453], "vertical": true, "font_size": 29, "lines_coords": [[[345.0, 182.0], [374.0, 182.0], [374.0, 453.0], [345.0, 453.0]], [[306.0, 180.0], [335.0, 180.0], [335.0, 422.0], [306.0, 422.0]], [[271.0, 182.0], [300.0, 182.0], [300.0, 409.0], [271.0, 409.0]], [[234.0, 182.0], [263.0, 182.0], [263.0, 422.0], [234.0, 422.0]], [[198.0, 182.0], [227.0, 182.0], [227.0, 345.0], [198.0, 345.0]]], "lines": ["幼なじみを心配する", "君の姿勢はとても", "感心するが、残念", "ながらそれは彼の", "自由意志だ。"]}, {"box": [1139, 438, 1259, 681], "vertical": true, "font_size": 36, "lines_coords": [[[1224.0, 440.0], [1259.0, 440.0], [1259.0, 681.0], [1224.0, 681.0]], [[1182.0, 440.0], [1218.0, 440.0], [1218.0, 679.0], [1182.0, 679.0]], [[1143.0, 438.0], [1180.0, 438.0], [1176.0, 592.0], [1139.0, 592.0]]], "lines": ["．．．あまり清水を", "巻き込まないで", "ください。"]}, {"box": [1106, 840, 1271, 1113], "vertical": true, "font_size": 32, "lines_coords": [[[1236.0, 842.0], [1271.0, 842.0], [1271.0, 1113.0], [1236.0, 1113.0]], [[1186.0, 840.0], [1222.0, 840.0], [1222.0, 1014.0], [1186.0, 1014.0]], [[1147.0, 842.0], [1176.0, 842.0], [1176.0, 1043.0], [1147.0, 1043.0]], [[1106.0, 844.0], [1135.0, 844.0], [1135.0, 1022.0], [1106.0, 1022.0]]], "lines": ["俺がペガサスこと", "星川敏樹と", "出会ったのは", "大学生の時。"]}, {"box": [151, 469, 217, 639], "vertical": true, "font_size": 29, "lines_coords": [[[188.0, 472.0], [217.0, 472.0], [217.0, 623.0], [188.0, 623.0]], [[151.0, 469.0], [180.0, 469.0], [180.0, 639.0], [151.0, 639.0]]], "lines": ["我々は強制", "していない。"]}, {"box": [994, 1138, 1149, 1407], "vertical": true, "font_size": 32, "lines_coords": [[[1120.0, 1142.0], [1149.0, 1142.0], [1149.0, 1372.0], [1120.0, 1372.0]], [[1079.0, 1142.0], [1108.0, 1142.0], [1108.0, 1343.0], [1079.0, 1343.0]], [[1033.0, 1138.0], [1064.0, 1138.0], [1066.0, 1407.0], [1035.0, 1407.0]], [[994.0, 1140.0], [1029.0, 1140.0], [1029.0, 1325.0], [994.0, 1325.0]]], "lines": ["以前話した通り", "彼には未来を", "予知する不思議な", "力があった。"]}, {"box": [294, 946, 453, 1186], "vertical": true, "font_size": 34, "lines_coords": [[[418.0, 948.0], [453.0, 948.0], [453.0, 1082.0], [418.0, 1082.0]], [[377.0, 946.0], [412.0, 946.0], [412.0, 1186.0], [377.0, 1186.0]], [[337.0, 948.0], [366.0, 948.0], [366.0, 1149.0], [337.0, 1149.0]], [[294.0, 946.0], [325.0, 946.0], [329.0, 1132.0], [298.0, 1132.0]]], "lines": ["知りたい", "未来を指定して", "予知する事は", "出来ないが、"]}, {"box": [182, 1213, 343, 1447], "vertical": true, "font_size": 34, "lines_coords": [[[308.0, 1213.0], [343.0, 1213.0], [343.0, 1382.0], [308.0, 1382.0]], [[267.0, 1215.0], [302.0, 1215.0], [302.0, 1399.0], [267.0, 1399.0]], [[223.0, 1217.0], [258.0, 1217.0], [258.0, 1447.0], [223.0, 1447.0]], [[182.0, 1215.0], [217.0, 1215.0], [217.0, 1362.0], [182.0, 1362.0]]], "lines": ["予言できた", "内容は、俺の", "知る限り１００％の", "的中率だ。"]}, {"box": [1133, 1641, 1238, 1855], "vertical": true, "font_size": 33, "lines_coords": [[[1203.0, 1643.0], [1238.0, 1643.0], [1238.0, 1768.0], [1203.0, 1768.0]], [[1168.0, 1641.0], [1203.0, 1641.0], [1199.0, 1855.0], [1164.0, 1855.0]], [[1133.0, 1645.0], [1162.0, 1645.0], [1162.0, 1834.0], [1133.0, 1834.0]]], "lines": ["僕だって", "そう思っていた", "時もあります。"]}, {"box": [211, 1786, 334, 1954], "vertical": true, "font_size": 37, "lines_coords": [[[298.0, 1786.0], [329.0, 1786.0], [331.0, 1954.0], [300.0, 1954.0]], [[256.0, 1786.0], [294.0, 1786.0], [294.0, 1950.0], [256.0, 1950.0]], [[211.0, 1786.0], [254.0, 1786.0], [254.0, 1904.0], [211.0, 1904.0]]], "lines": ["こんな社会", "糞くらえっ", "．．．てね。"]}]}