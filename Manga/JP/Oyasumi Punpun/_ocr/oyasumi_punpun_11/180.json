{"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1124, 146, 1269, 362], "vertical": true, "font_size": 32, "lines_coords": [[[1238.0, 146.0], [1267.0, 146.0], [1265.0, 362.0], [1236.0, 362.0]], [[1201.0, 146.0], [1230.0, 146.0], [1230.0, 337.0], [1201.0, 337.0]], [[1164.0, 149.0], [1193.0, 149.0], [1193.0, 360.0], [1164.0, 360.0]], [[1124.0, 146.0], [1164.0, 146.0], [1164.0, 229.0], [1124.0, 229.0]]], "lines": ["俺自身その話は", "子供の戯れ事、", "眉唾だと思って", "いる。"]}, {"box": [600, 329, 703, 515], "vertical": true, "font_size": 29, "lines_coords": [[[673.0, 329.0], [702.0, 329.0], [698.0, 511.0], [669.0, 511.0]], [[631.0, 329.0], [667.0, 329.0], [667.0, 515.0], [631.0, 515.0]], [[602.0, 333.0], [625.0, 333.0], [625.0, 467.0], [602.0, 467.0]]], "lines": ["俺の知る限り", "奴にはそんな", "力は無い。"]}, {"box": [283, 304, 368, 511], "vertical": true, "font_size": 41, "lines_coords": [[[316.0, 304.0], [368.0, 304.0], [368.0, 418.0], [316.0, 418.0]], [[283.0, 308.0], [319.0, 308.0], [319.0, 511.0], [283.0, 511.0]]], "lines": ["それに", "言ったろう？"]}, {"box": [1199, 639, 1265, 834], "vertical": true, "font_size": 35, "lines_coords": [[[1236.0, 639.0], [1265.0, 639.0], [1265.0, 792.0], [1236.0, 792.0]], [[1199.0, 639.0], [1228.0, 639.0], [1228.0, 834.0], [1199.0, 834.0]]], "lines": ["できる事は", "ただ予知のみ。"]}, {"box": [988, 685, 1110, 875], "vertical": true, "font_size": 35, "lines_coords": [[[1073.0, 687.0], [1110.0, 687.0], [1110.0, 823.0], [1073.0, 823.0]], [[1029.0, 687.0], [1073.0, 687.0], [1073.0, 797.0], [1029.0, 797.0]], [[988.0, 685.0], [1023.0, 685.0], [1027.0, 875.0], [992.0, 875.0]]], "lines": ["．．．やはり", "結末は", "変わらない。"]}, {"box": [200, 604, 325, 790], "vertical": true, "font_size": 41, "lines_coords": [[[290.0, 606.0], [325.0, 606.0], [325.0, 778.0], [290.0, 778.0]], [[242.0, 604.0], [287.0, 604.0], [287.0, 716.0], [242.0, 716.0]], [[200.0, 606.0], [236.0, 606.0], [240.0, 790.0], [205.0, 790.0]]], "lines": ["彼にはもう", "予知を", "させないと。"]}, {"box": [1238, 1010, 1267, 1163], "vertical": true, "font_size": 32, "lines_coords": [[[1238.0, 1010.0], [1267.0, 1010.0], [1267.0, 1163.0], [1238.0, 1163.0]]], "lines": ["要するに．．．"]}, {"box": [1019, 1078, 1160, 1235], "vertical": true, "font_size": 32, "lines_coords": [[[1131.0, 1080.0], [1160.0, 1080.0], [1160.0, 1231.0], [1131.0, 1231.0]], [[1089.0, 1078.0], [1126.0, 1078.0], [1126.0, 1178.0], [1089.0, 1178.0]], [[1054.0, 1078.0], [1089.0, 1078.0], [1089.0, 1235.0], [1054.0, 1235.0]], [[1019.0, 1080.0], [1048.0, 1080.0], [1048.0, 1215.0], [1019.0, 1215.0]]], "lines": ["和田さんは", "友達を", "裏切ってる", "訳ですね。"]}, {"box": [1222, 1397, 1289, 1608], "vertical": true, "font_size": 29, "lines_coords": [[[1257.0, 1397.0], [1286.0, 1397.0], [1286.0, 1546.0], [1257.0, 1546.0]], [[1222.0, 1399.0], [1251.0, 1399.0], [1251.0, 1608.0], [1222.0, 1608.0]]], "lines": ["それ以前に", "なんと言うか？"]}, {"box": [718, 1393, 798, 1592], "vertical": true, "font_size": 36, "lines_coords": [[[760.0, 1393.0], [797.0, 1393.0], [797.0, 1592.0], [760.0, 1592.0]], [[718.0, 1395.0], [754.0, 1395.0], [754.0, 1573.0], [718.0, 1573.0]]], "lines": ["グッドバイブ", "レーション。"]}, {"box": [372, 981, 441, 1146], "vertical": true, "font_size": 31, "lines_coords": [[[412.0, 983.0], [441.0, 983.0], [441.0, 1103.0], [412.0, 1103.0]], [[372.0, 981.0], [408.0, 981.0], [408.0, 1146.0], [372.0, 1146.0]]], "lines": ["．．．そうさ", "困った男さ。"]}, {"box": [213, 1113, 279, 1293], "vertical": true, "font_size": 31, "lines_coords": [[[250.0, 1113.0], [279.0, 1113.0], [279.0, 1293.0], [250.0, 1293.0]], [[213.0, 1115.0], [242.0, 1115.0], [242.0, 1264.0], [213.0, 1264.0]]], "lines": ["こういう男は", "嫌いかい？"]}, {"box": [196, 1482, 274, 1635], "vertical": true, "font_size": 36, "lines_coords": [[[236.0, 1484.0], [273.0, 1484.0], [273.0, 1621.0], [236.0, 1621.0]], [[196.0, 1482.0], [232.0, 1482.0], [232.0, 1635.0], [196.0, 1635.0]]], "lines": ["悪い返答", "じゃない。"]}, {"box": [890, 1757, 996, 1938], "vertical": true, "font_size": 32, "lines_coords": [[[961.0, 1757.0], [996.0, 1757.0], [996.0, 1881.0], [961.0, 1881.0]], [[923.0, 1757.0], [954.0, 1757.0], [957.0, 1937.0], [925.0, 1937.0]], [[890.0, 1757.0], [919.0, 1757.0], [919.0, 1919.0], [890.0, 1919.0]]], "lines": ["頭大丈夫", "かなー．．．って", "思ってます。"]}, {"box": [176, 1823, 243, 2046], "vertical": true, "font_size": 29, "lines_coords": [[[213.0, 1823.0], [242.0, 1823.0], [242.0, 2004.0], [213.0, 2004.0]], [[176.0, 1823.0], [205.0, 1823.0], [205.0, 2045.0], [176.0, 2045.0]]], "lines": ["．．．はっきりと", "わかったんです。"]}]}