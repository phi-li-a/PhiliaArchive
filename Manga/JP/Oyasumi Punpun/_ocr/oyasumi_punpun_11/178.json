{"version": "0.2.0-beta.6", "img_width": 1450, "img_height": 2120, "blocks": [{"box": [1215, 184, 1253, 329], "vertical": true, "font_size": 30, "lines_coords": [[[1215.0, 184.0], [1253.0, 184.0], [1253.0, 329.0], [1215.0, 329.0]]], "lines": ["．．．いや、"]}, {"box": [863, 134, 942, 321], "vertical": true, "font_size": 36, "lines_coords": [[[899.0, 134.0], [942.0, 134.0], [942.0, 244.0], [899.0, 244.0]], [[865.0, 138.0], [894.0, 138.0], [894.0, 320.0], [865.0, 320.0]]], "lines": ["これは", "確定事項だ。"]}, {"box": [360, 132, 524, 370], "vertical": true, "font_size": 34, "lines_coords": [[[488.0, 132.0], [524.0, 132.0], [517.0, 370.0], [482.0, 370.0]], [[443.0, 132.0], [478.0, 132.0], [478.0, 337.0], [443.0, 337.0]], [[401.0, 132.0], [437.0, 132.0], [437.0, 339.0], [401.0, 339.0]], [[360.0, 132.0], [391.0, 132.0], [393.0, 318.0], [362.0, 318.0]]], "lines": ["．．．ペガサス自ら", "自分の予知が", "外れる予知を", "しない限り。"]}, {"box": [1087, 438, 1271, 681], "vertical": true, "font_size": 30, "lines_coords": [[[1242.0, 438.0], [1271.0, 438.0], [1271.0, 590.0], [1242.0, 590.0]], [[1199.0, 438.0], [1228.0, 438.0], [1228.0, 650.0], [1199.0, 650.0]], [[1162.0, 438.0], [1189.0, 438.0], [1189.0, 621.0], [1162.0, 621.0]], [[1122.0, 438.0], [1151.0, 438.0], [1151.0, 681.0], [1122.0, 681.0]], [[1087.0, 438.0], [1116.0, 438.0], [1116.0, 571.0], [1087.0, 571.0]]], "lines": ["７月７日は", "彼の言う通りに", "我々に大きな", "厄災が降りかかる", "だろうね。"]}, {"box": [635, 612, 751, 852], "vertical": true, "font_size": 33, "lines_coords": [[[716.0, 614.0], [751.0, 614.0], [751.0, 819.0], [716.0, 819.0]], [[675.0, 614.0], [710.0, 614.0], [710.0, 852.0], [675.0, 852.0]], [[635.0, 612.0], [664.0, 612.0], [664.0, 768.0], [635.0, 768.0]]], "lines": ["そしてそれは", "俺の望むところ", "でもある。"]}, {"box": [151, 600, 308, 803], "vertical": true, "font_size": 30, "lines_coords": [[[271.0, 600.0], [306.0, 600.0], [306.0, 803.0], [271.0, 803.0]], [[234.0, 602.0], [263.0, 602.0], [263.0, 770.0], [234.0, 770.0]], [[192.0, 602.0], [221.0, 602.0], [221.0, 803.0], [192.0, 803.0]], [[151.0, 604.0], [180.0, 604.0], [180.0, 784.0], [151.0, 784.0]]], "lines": ["．．．つまり奴に", "もう予知を", "させなければ", "いいんだよ。"]}, {"box": [923, 964, 1269, 1207], "vertical": false, "font_size": 28, "lines_coords": [[[934.0, 973.0], [1267.0, 973.0], [1267.0, 999.0], [934.0, 999.0]], [[928.0, 1016.0], [1257.0, 1016.0], [1257.0, 1043.0], [928.0, 1043.0]], [[930.0, 1057.0], [1124.0, 1057.0], [1124.0, 1086.0], [930.0, 1086.0]], [[936.0, 1109.0], [1195.0, 1109.0], [1195.0, 1136.0], [936.0, 1136.0]], [[979.0, 1144.0], [1162.0, 1144.0], [1162.0, 1173.0], [979.0, 1173.0]], [[1031.0, 1178.0], [1213.0, 1178.0], [1213.0, 1206.0], [1031.0, 1206.0]]], "lines": ["Ｓｉｍｍｅａｂｒｅａｋ！！Ｄｕｄｅ", "ｙｏｕｉｒｅｔｈｅｃｏｏｌｅｓｔｇｕｙ", "ｍｉｈｅｗｏｒｄ！", "オイオイ待ってくれ！！", "あんたは最高の", "クールガイさ！！"]}, {"box": [555, 1492, 590, 1647], "vertical": true, "font_size": 35, "lines_coords": [[[555.0, 1492.0], [590.0, 1492.0], [590.0, 1647.0], [555.0, 1647.0]]], "lines": ["７月７日．．．"]}, {"box": [180, 1084, 512, 1324], "vertical": false, "font_size": 32, "lines_coords": [[[184.0, 1088.0], [406.0, 1088.0], [406.0, 1117.0], [184.0, 1117.0]], [[180.0, 1126.0], [439.0, 1128.0], [439.0, 1163.0], [180.0, 1161.0]], [[188.0, 1171.0], [495.0, 1171.0], [495.0, 1206.0], [188.0, 1206.0]], [[186.0, 1221.0], [430.0, 1221.0], [430.0, 1256.0], [186.0, 1256.0]], [[194.0, 1260.0], [499.0, 1260.0], [499.0, 1289.0], [194.0, 1289.0]], [[207.0, 1293.0], [507.0, 1293.0], [507.0, 1322.0], [207.0, 1322.0]]], "lines": ["Ｍｙｂｕｄｄｙｆｏｒｎ", "Ｋａｎｓａｓａｌｓｏｓａｉｄ", "Ｐｅｇａｓｕｓｓｈｏｕｌｄｍｙ", "〈カンザス州の友人も", "言っていたよ『ペガサスは", "空を飛べるはずだ』って。"]}, {"box": [1189, 1480, 1294, 1722], "vertical": true, "font_size": 31, "lines_coords": [[[1259.0, 1480.0], [1290.0, 1480.0], [1294.0, 1664.0], [1263.0, 1664.0]], [[1226.0, 1482.0], [1255.0, 1482.0], [1255.0, 1722.0], [1226.0, 1722.0]], [[1189.0, 1480.0], [1218.0, 1480.0], [1218.0, 1639.0], [1189.0, 1639.0]]], "lines": ["そして彼には", "是非有名になって", "もらいたい。"]}, {"box": [1017, 1695, 1162, 1881], "vertical": true, "font_size": 31, "lines_coords": [[[1120.0, 1695.0], [1162.0, 1695.0], [1162.0, 1768.0], [1120.0, 1768.0]], [[1089.0, 1701.0], [1118.0, 1701.0], [1118.0, 1859.0], [1089.0, 1859.0]], [[1052.0, 1701.0], [1081.0, 1701.0], [1081.0, 1852.0], [1052.0, 1852.0]], [[1017.0, 1701.0], [1044.0, 1701.0], [1044.0, 1881.0], [1017.0, 1881.0]]], "lines": ["彼の", "豪壮な許し、", "博愛過ぎる", "あの精神．．．"]}, {"box": [816, 1616, 886, 1739], "vertical": true, "font_size": 33, "lines_coords": [[[851.0, 1616.0], [886.0, 1616.0], [886.0, 1739.0], [851.0, 1739.0]], [[816.0, 1618.0], [847.0, 1618.0], [847.0, 1720.0], [816.0, 1720.0]]], "lines": ["．．．そして", "無力さ。"]}, {"box": [679, 1846, 797, 2014], "vertical": true, "font_size": 33, "lines_coords": [[[758.0, 1848.0], [797.0, 1848.0], [797.0, 1950.0], [758.0, 1950.0]], [[720.0, 1846.0], [751.0, 1846.0], [747.0, 2014.0], [716.0, 2014.0]], [[679.0, 1850.0], [710.0, 1850.0], [710.0, 1950.0], [679.0, 1950.0]]], "lines": ["美しい", "とは思わん", "かね！？"]}, {"box": [329, 1554, 515, 1807], "vertical": true, "font_size": 35, "lines_coords": [[[470.0, 1554.0], [515.0, 1554.0], [515.0, 1660.0], [470.0, 1660.0]], [[437.0, 1563.0], [472.0, 1563.0], [472.0, 1807.0], [437.0, 1807.0]], [[403.0, 1565.0], [432.0, 1565.0], [432.0, 1776.0], [403.0, 1776.0]], [[368.0, 1565.0], [397.0, 1565.0], [397.0, 1745.0], [368.0, 1745.0]], [[329.0, 1563.0], [366.0, 1563.0], [366.0, 1664.0], [329.0, 1664.0]]], "lines": ["人々が", "いつもと変わらず", "明日への期待と", "不安を抱えて", "眠る時、"]}, {"box": [140, 1786, 283, 2030], "vertical": true, "font_size": 31, "lines_coords": [[[250.0, 1788.0], [281.0, 1788.0], [279.0, 1999.0], [248.0, 1999.0]], [[213.0, 1790.0], [242.0, 1790.0], [242.0, 2006.0], [213.0, 2006.0]], [[176.0, 1786.0], [211.0, 1786.0], [203.0, 2030.0], [167.0, 2030.0]], [[140.0, 1788.0], [169.0, 1788.0], [169.0, 1981.0], [140.0, 1981.0]]], "lines": ["圧倒的な絶望を", "目の当たりにし、", "ペガサスの尊顔を", "思い出すんだ。"]}]}