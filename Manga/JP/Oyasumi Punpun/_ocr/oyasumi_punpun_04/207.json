{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [868, 81, 1004, 345], "vertical": true, "font_size": 27, "lines_coords": [[[975.0, 81.0], [1003.0, 81.0], [1004.0, 343.0], [976.0, 343.0]], [[942.0, 81.0], [968.0, 81.0], [968.0, 304.0], [942.0, 304.0]], [[906.0, 81.0], [932.0, 81.0], [932.0, 343.0], [906.0, 343.0]], [[868.0, 82.0], [895.0, 82.0], [895.0, 345.0], [868.0, 345.0]]], "lines": ["「けれど、手をつないだ。", "だけで、僕の息子は", "完全ビッキビキ状態で", "まともに歩けません！！"]}, {"box": [720, 278, 842, 475], "vertical": true, "font_size": 27, "lines_coords": [[[815.0, 279.0], [842.0, 279.0], [842.0, 462.0], [815.0, 462.0]], [[784.0, 282.0], [810.0, 282.0], [810.0, 462.0], [784.0, 462.0]], [[750.0, 279.0], [782.0, 279.0], [782.0, 364.0], [750.0, 364.0]], [[721.0, 278.0], [748.0, 278.0], [746.0, 475.0], [720.0, 475.0]]], "lines": ["どうしたらいい", "のでしょうか？", "教えて", "ＴＡＫＵＭＩ！！」"]}, {"box": [157, 540, 259, 779], "vertical": true, "font_size": 28, "lines_coords": [[[228.0, 540.0], [259.0, 540.0], [259.0, 779.0], [228.0, 779.0]], [[193.0, 542.0], [220.0, 542.0], [220.0, 698.0], [193.0, 698.0]], [[157.0, 542.0], [184.0, 542.0], [184.0, 698.0], [157.0, 698.0]]], "lines": ["．．．わっかるナァ～～", "僕も中学生の", "頃なんて．．．"]}, {"box": [870, 895, 973, 1158], "vertical": true, "font_size": 26, "lines_coords": [[[948.0, 896.0], [970.0, 896.0], [970.0, 1157.0], [948.0, 1157.0]], [[906.0, 895.0], [937.0, 895.0], [937.0, 1132.0], [906.0, 1132.0]], [[870.0, 895.0], [896.0, 895.0], [896.0, 1010.0], [870.0, 1010.0]]], "lines": ["．．この頃のフンフンは", "ひたすらに猛勉強の", "子てした。"]}, {"box": [575, 821, 700, 1062], "vertical": true, "font_size": 26, "lines_coords": [[[673.0, 821.0], [700.0, 821.0], [700.0, 1062.0], [673.0, 1062.0]], [[640.0, 823.0], [667.0, 823.0], [667.0, 1026.0], [640.0, 1026.0]], [[607.0, 823.0], [634.0, 823.0], [634.0, 1028.0], [607.0, 1028.0]], [[575.0, 821.0], [596.0, 821.0], [596.0, 1060.0], [575.0, 1060.0]]], "lines": ["「先日、一浪が確定した", "大阪の苦学生です。", "両親は、いい大学に", "行けとうるさいです。」"]}, {"box": [89, 892, 245, 1145], "vertical": true, "font_size": 25, "lines_coords": [[[218.0, 893.0], [245.0, 893.0], [245.0, 1078.0], [218.0, 1078.0]], [[182.0, 892.0], [209.0, 892.0], [210.0, 1062.0], [184.0, 1062.0]], [[151.0, 893.0], [178.0, 893.0], [178.0, 1084.0], [151.0, 1084.0]], [[121.0, 895.0], [143.0, 895.0], [143.0, 1089.0], [121.0, 1089.0]], [[89.0, 895.0], [110.0, 895.0], [110.0, 1143.0], [89.0, 1143.0]]], "lines": ["「一度きりの人生、", "勉強することに", "どれほどの意味が", "あるんでしょうか。", "教えてＴＡＫＵＭＩ！！」"]}, {"box": [742, 1071, 844, 1373], "vertical": true, "font_size": 27, "lines_coords": [[[815.0, 1073.0], [842.0, 1073.0], [842.0, 1318.0], [815.0, 1318.0]], [[775.0, 1071.0], [806.0, 1071.0], [809.0, 1373.0], [778.0, 1373.0]], [[745.0, 1079.0], [767.0, 1079.0], [767.0, 1342.0], [745.0, 1342.0]]], "lines": ["．．．理由はありません。", "ただ、今はこうしてるのが", "一番落ちつくのでした。"]}, {"box": [560, 1168, 662, 1379], "vertical": true, "font_size": 30, "lines_coords": [[[635.0, 1173.0], [662.0, 1173.0], [662.0, 1379.0], [635.0, 1379.0]], [[596.0, 1170.0], [628.0, 1170.0], [628.0, 1356.0], [596.0, 1356.0]], [[560.0, 1168.0], [589.0, 1168.0], [590.0, 1364.0], [562.0, 1364.0]]], "lines": ["たくさん勉強して", "東大の理学部か", "そこらに入って、"]}, {"box": [418, 1168, 523, 1432], "vertical": true, "font_size": 30, "lines_coords": [[[496.0, 1171.0], [523.0, 1171.0], [523.0, 1432.0], [496.0, 1432.0]], [[453.0, 1168.0], [485.0, 1168.0], [489.0, 1382.0], [456.0, 1382.0]], [[418.0, 1168.0], [450.0, 1168.0], [453.0, 1409.0], [421.0, 1409.0]]], "lines": ["原子力を研究している", "地下組織の一員か", "なんかになって．．．"]}]}