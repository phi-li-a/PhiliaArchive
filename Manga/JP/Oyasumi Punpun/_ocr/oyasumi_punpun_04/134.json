]]], "lines": ["．．．でも、あたしは", "そんなの嫌だ。"]}, {"box": [135, 943, 271, 1171], "vertical": true, "font_size": 26, "lines_coords": [[[245.0, 945.0], [271.0, 945.0], [271.0, 1104.0], [245.0, 1104.0]], [[206.0, 943.0], [234.0, 943.0], [235.0, 1079.0], [207.0, 1079.0]], [[171.0, 946.0], [198.0, 946.0], [198.0, 1171.0], [171.0, 1171.0]], [[135.0, 945.0], [159.0, 945.0], [160.0, 1115.0], [137.0, 1115.0]]], "lines": ["余計なものは", "全部捨てて", "ただ、あたしだけを", "見ててほしい。"]}, {"box": [895, 1304, 960, 1464], "vertical": true, "font_size": 27, "lines_coords": [[[934.0, 1304.0], [960.0, 1304.0], [960.0, 1437.0], [934.0, 1437.0]], [[898.0, 1304.0], [925.0, 1304.0], [921.0, 1464.0], [895.0, 1464.0]]], "lines": ["矢口先輩は", "いい人だよ．．．"]}, {"box": [753, 1367, 853, 1512], "vertical": true, "font_size": 27, "lines_coords": [[[826.0, 1370.0], [853.0, 1370.0], [853.0, 1500.0], [826.0, 1500.0]], [[790.0, 1368.0], [818.0, 1368.0], [818.0, 1475.0], [790.0, 1475.0]], [[753.0, 1367.0], [781.0, 1367.0], [782.0, 1512.0], [754.0, 1512.0]]], "lines": ["やさしくて", "真面目で", "格好良くて。"]}, {"box": [109, 1337, 246, 1520], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 1337.0], [246.0, 1337.0], [246.0, 1432.0], [214.0, 1432.0]], [[181.0, 1340.0], [203.0, 1340.0], [203.0, 1520.0], [181.0, 1520.0]], [[142.0, 1339.0], [168.0, 1339.0], [168.0, 1470.0], [142.0, 1470.0]], [[109.0, 1340.0], [131.0, 1340.0], [131.0, 1504.0], [109.0, 1504.0]]], "lines": ["．．．けど、", "あの人にはまだ", "逃げ場所が", "たくさんある。"]}]}