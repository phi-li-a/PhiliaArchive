.0]], [[900.0, 818.0], [928.0, 818.0], [925.0, 1003.0], [896.0, 1003.0]]], "lines": ["たった", "一人でいいから、"]}, {"box": [751, 856, 853, 1093], "vertical": true, "font_size": 30, "lines_coords": [[[826.0, 859.0], [853.0, 859.0], [853.0, 1067.0], [826.0, 1067.0]], [[792.0, 860.0], [818.0, 860.0], [818.0, 1093.0], [792.0, 1093.0]], [[754.0, 856.0], [785.0, 856.0], [782.0, 1093.0], [751.0, 1093.0]]], "lines": ["頭のてっぺんから", "つま先まで１ミリの", "間違いも無いくらい"]}, {"box": [182, 896, 251, 1094], "vertical": true, "font_size": 30, "lines_coords": [[[217.0, 896.0], [251.0, 896.0], [251.0, 981.0], [217.0, 981.0]], [[182.0, 896.0], [209.0, 896.0], [212.0, 1092.0], [185.0, 1092.0]]], "lines": ["完全に", "わかり合いたい。"]}, {"box": [859, 1253, 959, 1395], "vertical": true, "font_size": 27, "lines_coords": [[[932.0, 1254.0], [959.0, 1254.0], [959.0, 1362.0], [932.0, 1362.0]], [[896.0, 1256.0], [923.0, 1256.0], [923.0, 1387.0], [896.0, 1387.0]], [[859.0, 1253.0], [885.0, 1253.0], [889.0, 1393.0], [862.0, 1393.0]]], "lines": ["その人と", "二人きりに", "なれるなら、"]}, {"box": [115, 1353, 181, 1522], "vertical": true, "font_size": 28, "lines_coords": [[[146.0, 1353.0], [181.0, 1353.0], [181.0, 1439.0], [146.0, 1439.0]], [[115.0, 1357.0], [137.0, 1357.0], [137.0, 1521.0], [115.0, 1521.0]]], "lines": ["他には", "何もいらない。"]}]}