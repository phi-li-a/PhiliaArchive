8.0], [950.0, 1098.0]], [[918.0, 1015.0], [945.0, 1015.0], [945.0, 1145.0], [918.0, 1145.0]]], "lines": ["や．．．", "．．．あの．．．．．"]}, {"box": [511, 1014, 602, 1216], "vertical": true, "font_size": 22, "lines_coords": [[[578.0, 1015.0], [600.0, 1015.0], [600.0, 1134.0], [578.0, 1134.0]], [[543.0, 1014.0], [565.0, 1014.0], [565.0, 1203.0], [543.0, 1203.0]], [[512.0, 1015.0], [534.0, 1015.0], [534.0, 1215.0], [512.0, 1215.0]]], "lines": ["実はたまに", "鷲尾くんもココに", "遊びに来てるんだ。"]}, {"box": [168, 1101, 262, 1271], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 1103.0], [259.0, 1101.0], [262.0, 1189.0], [228.0, 1190.0]], [[198.0, 1104.0], [225.0, 1104.0], [225.0, 1271.0], [198.0, 1271.0]], [[168.0, 1106.0], [190.0, 1106.0], [190.0, 1231.0], [168.0, 1231.0]]], "lines": ["．．．彼も", "ずいぶん元気に", "なったよね。"]}, {"box": [700, 1368, 732, 1489], "vertical": true, "font_size": 32, "lines_coords": [[[700.0, 1390.0], [732.0, 1390.0], [732.0, 1489.0], [700.0, 1489.0]]], "lines": ["．．．ハイ。"]}, {"box": [120, 1326, 248, 1546], "vertical": true, "font_size": 26, "lines_coords": [[[221.0, 1329.0], [248.0, 1329.0], [248.0, 1496.0], [221.0, 1496.0]], [[190.0, 1329.0], [212.0, 1329.0], [212.0, 1546.0], [190.0, 1546.0]], [[157.0, 1328.0], [179.0, 1328.0], [179.0, 1542.0], [157.0, 1542.0]], [[120.0, 1326.0], [146.0, 1326.0], [150.0, 1437.0], [123.0, 1437.0]]], "lines": ["あの時のことは", "話してくれないけど、", "前よりも笑うように", "なったし。"]}]}