{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [126, 229, 257, 257], "vertical": false, "font_size": 28, "lines_coords": [[[126.0, 229.0], [257.0, 229.0], [257.0, 257.0], [126.0, 257.0]]], "lines": ["登場人物"]}, {"box": [196, 278, 371, 309], "vertical": false, "font_size": 31, "lines_coords": [[[196.0, 278.0], [371.0, 278.0], [371.0, 309.0], [196.0, 309.0]]], "lines": ["小野寺プンプン"]}, {"box": [193, 309, 706, 334], "vertical": false, "font_size": 22, "lines_coords": [[[193.0, 312.0], [706.0, 309.0], [706.0, 331.0], [193.0, 334.0]]], "lines": ["チョコパイ好きのヤングがん、得意な必殺技は真空波動拳。"]}, {"box": [195, 368, 726, 428], "vertical": false, "font_size": 32.0, "lines_coords": [[[195.0, 368.0], [418.0, 368.0], [418.0, 400.0], [195.0, 400.0]], [[196.0, 396.0], [726.0, 396.0], [726.0, 428.0], [196.0, 428.0]]], "lines": ["「小野寺プンプンママさんの", "ブンブンの母親。前世は天使だ。わたと信じている。若干アル中で"]}, {"box": [198, 462, 559, 535], "vertical": false, "font_size": 23.333333333333332, "lines_coords": [[[200.0, 462.0], [328.0, 462.0], [328.0, 484.0], [200.0, 484.0]], [[200.0, 490.0], [559.0, 490.0], [559.0, 512.0], [200.0, 512.0]], [[198.0, 509.0], [478.0, 509.0], [478.0, 535.0], [198.0, 535.0]]], "lines": ["小野寺雄一", "プンプンママの弟。素直にこなれない年頃。", "フンフンママの売り素直になれば、現在はビデオ屋でアルバイト中。"]}, {"box": [200, 550, 565, 607], "vertical": false, "font_size": 27.0, "lines_coords": [[[200.0, 553.0], [304.0, 550.0], [304.0, 578.0], [200.0, 581.0]], [[201.0, 581.0], [565.0, 581.0], [565.0, 607.0], [201.0, 607.0]]], "lines": ["田中愛子", "ブンブンが小学生の時から好きな女の子。"]}, {"box": [198, 639, 567, 698], "vertical": false, "font_size": 27.5, "lines_coords": [[[198.0, 642.0], [276.0, 639.0], [278.0, 667.0], [200.0, 670.0]], [[200.0, 671.0], [567.0, 671.0], [567.0, 698.0], [200.0, 698.0]]], "lines": ["大限早", "喫茶店で働くフリーター一女子。元・看護師。"]}, {"box": [715, 78, 979, 1006], "vertical": true, "font_size": 97, "lines_coords": [[[929.0, 168.0], [967.0, 168.0], [975.0, 896.0], [937.0, 896.0]], [[876.0, 167.0], [912.0, 167.0], [918.0, 885.0], [882.0, 885.0]], [[789.0, 87.0], [900.0, 87.0], [900.0, 126.0], [789.0, 126.0]], [[715.0, 114.0], [945.0, 114.0], [945.0, 1006.0], [715.0, 1006.0]], [[820.0, 884.0], [881.0, 884.0], [881.0, 953.0], [820.0, 953.0]], [[875.0, 896.0], [979.0, 896.0], [979.0, 956.0], [875.0, 956.0]]], "lines": ["．．．それ、また、お．．．はっ、は、", "話話語話話話話の話が話し話して話しました。", "次", "第５５条第３７号第３５回第３９回第４１号４１第４２期第４８話第１４話第４５回東北区第４６", "４６", "話"]}, {"box": [201, 912, 448, 965], "vertical": false, "font_size": 25.0, "lines_coords": [[[201.0, 915.0], [306.0, 912.0], [306.0, 940.0], [201.0, 943.0]], [[206.0, 943.0], [448.0, 943.0], [448.0, 965.0], [206.0, 965.0]]], "lines": ["東海関", "プンプンの同級生。すぐ怒る。"]}, {"box": [201, 1004, 487, 1059], "vertical": false, "font_size": 28.0, "lines_coords": [[[203.0, 1004.0], [257.0, 1004.0], [257.0, 1034.0], [203.0, 1034.0]], [[201.0, 1031.0], [487.0, 1032.0], [487.0, 1059.0], [201.0, 1057.0]]], "lines": ["清水", "プンプンの同級生。すぐ怒られる。"]}, {"box": [201, 732, 634, 878], "vertical": false, "font_size": 27.2, "lines_coords": [[[201.0, 732.0], [304.0, 732.0], [304.0, 760.0], [201.0, 760.0]], [[204.0, 760.0], [385.0, 760.0], [385.0, 787.0], [204.0, 787.0]], [[204.0, 787.0], [581.0, 787.0], [581.0, 814.0], [204.0, 814.0]], [[204.0, 823.0], [351.0, 823.0], [351.0, 850.0], [204.0, 850.0]], [[204.0, 851.0], [634.0, 851.0], [634.0, 878.0], [204.0, 878.0]]], "lines": ["矢口先輩", "バドミントン部の先輩。", "チャンコが超でかいと下級生に噂されている。", "小松っちゃん", "プンプンのクラスメイト。パドミントン部の赤い彗星。"]}, {"box": [203, 1096, 650, 1150], "vertical": false, "font_size": 28.5, "lines_coords": [[[203.0, 1096.0], [256.0, 1096.0], [256.0, 1126.0], [203.0, 1126.0]], [[226.0, 1123.0], [650.0, 1123.0], [650.0, 1150.0], [226.0, 1150.0]]], "lines": ["沼田", "ラスーのセクシーギャル。好きな食べものはコマ。"]}, {"box": [773, 1001, 1068, 1050], "vertical": false, "font_size": 49, "lines_coords": [[[773.0, 1001.0], [1068.0, 1001.0], [1068.0, 1050.0], [773.0, 1050.0]]], "lines": ["３巻までのあらすじ"]}, {"box": [778, 1067, 964, 1125], "vertical": false, "font_size": 22.0, "lines_coords": [[[779.0, 1067.0], [964.0, 1067.0], [964.0, 1089.0], [779.0, 1089.0]], [[778.0, 1103.0], [962.0, 1103.0], [962.0, 1125.0], [778.0, 1125.0]]], "lines": ["ごく普通の中学生、", "小野寺プンプンは、"]}, {"box": [776, 1131, 1004, 1200], "vertical": false, "font_size": 29.0, "lines_coords": [[[776.0, 1134.0], [1004.0, 1131.0], [1004.0, 1162.0], [776.0, 1165.0]], [[778.0, 1173.0], [970.0, 1173.0], [970.0, 1200.0], [778.0, 1200.0]]], "lines": ["片想い（？）の女の子・", "田中愛子を巡って、"]}, {"box": [231, 1215, 604, 1237], "vertical": false, "font_size": 22, "lines_coords": [[[231.0, 1215.0], [604.0, 1215.0], [604.0, 1237.0], [231.0, 1237.0]]], "lines": ["・一が五年前に働いていた陶芸教室の生徒。"]}, {"box": [201, 1273, 743, 1331], "vertical": false, "font_size": 29.0, "lines_coords": [[[201.0, 1273.0], [435.0, 1273.0], [435.0, 1306.0], [201.0, 1306.0]], [[203.0, 1306.0], [743.0, 1303.0], [743.0, 1328.0], [203.0, 1331.0]]], "lines": ["おかっばの女子高生．．．", "八木の娘。母親に軟禁されていふと言い、雄一に助けを求める。"]}, {"box": [206, 1398, 687, 1420], "vertical": false, "font_size": 22, "lines_coords": [[[206.0, 1398.0], [687.0, 1398.0], [687.0, 1420.0], [206.0, 1420.0]]], "lines": ["雄一の陶芸教室講師時代の同僚。陶芸界期待の新人。"]}, {"box": [204, 1456, 673, 1510], "vertical": false, "font_size": 24.0, "lines_coords": [[[204.0, 1456.0], [356.0, 1456.0], [356.0, 1482.0], [204.0, 1482.0]], [[206.0, 1489.0], [673.0, 1485.0], [673.0, 1507.0], [206.0, 1510.0]]], "lines": ["雄一の元カノ", "酒好きで悪口が多い以外は、概ね親切で優しい女性。"]}, {"box": [779, 1210, 982, 1232], "vertical": false, "font_size": 22, "lines_coords": [[[779.0, 1210.0], [982.0, 1210.0], [982.0, 1232.0], [779.0, 1232.0]]], "lines": ["部活の先輩と無謀な"]}, {"box": [776, 1242, 1026, 1417], "vertical": false, "font_size": 27.8, "lines_coords": [[[776.0, 1242.0], [960.0, 1242.0], [960.0, 1275.0], [776.0, 1275.0]], [[779.0, 1281.0], [993.0, 1281.0], [993.0, 1307.0], [779.0, 1307.0]], [[778.0, 1317.0], [1026.0, 1317.0], [1026.0, 1343.0], [778.0, 1343.0]], [[776.0, 1354.0], [943.0, 1351.0], [943.0, 1378.0], [776.0, 1381.0]], [[778.0, 1390.0], [943.0, 1390.0], [943.0, 1417.0], [778.0, 1417.0]]], "lines": ["勝負をすることに。", "一方、叔父の雄一は、", "気になるフリーター女子、", "大隈翠に過去を", "打ち明け始める。"]}]}