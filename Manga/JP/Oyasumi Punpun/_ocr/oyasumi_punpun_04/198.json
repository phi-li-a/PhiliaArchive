{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [756, 57, 860, 269], "vertical": true, "font_size": 30, "lines_coords": [[[831.0, 60.0], [859.0, 60.0], [859.0, 179.0], [831.0, 179.0]], [[792.0, 57.0], [823.0, 57.0], [823.0, 221.0], [792.0, 221.0]], [[756.0, 59.0], [787.0, 59.0], [787.0, 268.0], [756.0, 268.0]]], "lines": ["「私にお店", "貸してくれま", "せんか？」．．．って。"]}, {"box": [446, 127, 609, 350], "vertical": true, "font_size": 23, "lines_coords": [[[584.0, 129.0], [606.0, 129.0], [606.0, 259.0], [584.0, 259.0]], [[548.0, 128.0], [575.0, 128.0], [575.0, 350.0], [548.0, 350.0]], [[514.0, 128.0], [535.0, 128.0], [535.0, 310.0], [514.0, 310.0]], [[481.0, 128.0], [503.0, 128.0], [503.0, 337.0], [481.0, 337.0]], [[446.0, 128.0], [470.0, 128.0], [471.0, 320.0], [448.0, 320.0]]], "lines": ["．．．食品衛生", "管理者の資格とか、", "もちろん資金も", "まだ十分な準備は", "出来てないけど、"]}, {"box": [89, 45, 373, 67], "vertical": false, "font_size": 22, "lines_coords": [[[89.0, 45.0], [373.0, 45.0], [373.0, 67.0], [89.0, 67.0]]], "lines": ["おやすみプンプンは"]}, {"box": [95, 210, 239, 396], "vertical": true, "font_size": 24, "lines_coords": [[[210.0, 210.0], [237.0, 210.0], [237.0, 396.0], [210.0, 396.0]], [[184.0, 212.0], [206.0, 212.0], [206.0, 343.0], [184.0, 343.0]], [[153.0, 210.0], [179.0, 210.0], [179.0, 376.0], [153.0, 376.0]], [[126.0, 210.0], [148.0, 210.0], [148.0, 368.0], [126.0, 368.0]], [[95.0, 210.0], [117.0, 210.0], [120.0, 393.0], [98.0, 393.0]]], "lines": ["内装をそのまま", "引き渡して", "もらえるなら、", "費用はずっと", "抑えられるし．．．"]}, {"box": [428, 484, 557, 723], "vertical": true, "font_size": 24, "lines_coords": [[[529.0, 487.0], [556.0, 487.0], [556.0, 721.0], [529.0, 721.0]], [[496.0, 487.0], [518.0, 487.0], [518.0, 615.0], [496.0, 615.0]], [[460.0, 484.0], [487.0, 484.0], [487.0, 723.0], [460.0, 723.0]], [[428.0, 485.0], [450.0, 485.0], [450.0, 692.0], [428.0, 692.0]]], "lines": ["．．．それと、雄一君も", "陶芸教室て", "また働くかどうかで", "迷ってたでしょ？"]}, {"box": [848, 796, 951, 1007], "vertical": true, "font_size": 28, "l