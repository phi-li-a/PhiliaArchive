34.0, 1126.0]], [[606.0, 1046.0], [634.0, 1046.0], [631.0, 1184.0], [603.0, 1184.0]], [[576.0, 1046.0], [603.0, 1046.0], [603.0, 1142.0], [576.0, 1142.0]], [[551.0, 1048.0], [573.0, 1048.0], [573.0, 1206.0], [551.0, 1206.0]], [[521.0, 1046.0], [543.0, 1046.0], [543.0, 1193.0], [521.0, 1193.0]]], "lines": ["あと僕、", "一応童貞じゃ", "ないんで", "馬鹿にしないで", "もらえます？」"]}, {"box": [145, 809, 216, 931], "vertical": true, "font_size": 20, "lines_coords": [[[193.0, 809.0], [215.0, 809.0], [215.0, 931.0], [193.0, 931.0]], [[167.0, 809.0], [189.0, 809.0], [189.0, 893.0], [167.0, 893.0]], [[145.0, 809.0], [162.0, 809.0], [162.0, 912.0], [145.0, 912.0]]], "lines": ["ゴーョゴニョ", "聞きとれ", "ないって！！"]}, {"box": [912, 1300, 990, 1439], "vertical": true, "font_size": 22, "lines_coords": [[[967.0, 1300.0], [989.0, 1300.0], [989.0, 1439.0], [967.0, 1439.0]], [[940.0, 1300.0], [962.0, 1300.0], [962.0, 1417.0], [940.0, 1417.0]], [[912.0, 1300.0], [934.0, 1300.0], [934.0, 1415.0], [912.0, 1415.0]]], "lines": ["．．．いつだって", "本当の敵は", "己自身．．．"]}, {"box": [425, 1357, 535, 1543], "vertical": true, "font_size": 23, "lines_coords": [[[507.0, 1357.0], [535.0, 1357.0], [535.0, 1454.0], [507.0, 1454.0]], [[481.0, 1357.0], [504.0, 1357.0], [503.0, 1520.0], [479.0, 1520.0]], [[453.0, 1359.0], [473.0, 1359.0], [473.0, 1543.0], [453.0, 1543.0]], [[425.0, 1359.0], [445.0, 1359.0], [445.0, 1520.0], [425.0, 1520.0]]], "lines": ["しかして", "オノッティーに", "俺のこの裁紙さは", "わかるまい．．．"]}, {"box": [310, 1106, 395, 1316], "vertical": true, "font_size": 26, "lines_coords": [[[371.0, 1110.0], [393.0, 1110.0], [393.0, 1237.0], [371.0, 1237.0]], [[340.0, 1107.0], [367.0, 1107.0], [367.0, 1315.0], [340.0, 1315.0]], [[310.0, 1106.0], [339.0, 1106.0], [340.0, 1206.0], [312.0, 1206.0]]], "lines": ["「三村のこと", "別に嫌いじゃないん", "ですけど、"]}, {"box": [104, 1106, 271, 1339], "vertical": true, "font_size": 23, "lines_coords": [[[246.0, 1107.0], [268.0, 1107.0], [267.0, 1317.0], [245.0, 1317.0]], [[217.0, 1107.0], [239.0, 1107.0], [239.0, 1312.0], [217.0, 1312.0]], [