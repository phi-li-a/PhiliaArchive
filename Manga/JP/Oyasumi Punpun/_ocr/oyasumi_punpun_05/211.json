.0], [742.0, 279.0], [703.0, 26.0]], [[801.0, 0.0], [850.0, 248.0], [812.0, 254.0], [765.0, 0.0]]], "lines": ["ネＭトナッ製製，", "ゆっくり飛車角ーっけんってん", "国際ローザールホテルに", "やれやがって！！きゃぁぁぁっ", "この場合はサービスによりお", "そのそんなのだけのね。", "その想像を認める"]}, {"box": [731, 0, 790, 184], "vertical": true, "font_size": 31, "lines_coords": [[[731.0, 3.0], [762.0, 0.0], [790.0, 179.0], [759.0, 184.0]]], "lines": ["の講師をやめて"]}, {"box": [806, 0, 907, 210], "vertical": true, "font_size": 31.5, "lines_coords": [[[851.0, 18.0], [879.0, 12.0], [907.0, 171.0], [879.0, 178.0]], [[806.0, 0.0], [840.0, 0.0], [871.0, 206.0], [837.0, 210.0]]], "lines": ["同意のスター", "様々失速ぶりで、"]}, {"box": [153, 639, 276, 796], "vertical": true, "font_size": 27, "lines_coords": [[[245.0, 639.0], [276.0, 639.0], [276.0, 796.0], [245.0, 796.0]], [[215.0, 639.0], [242.0, 639.0], [242.0, 793.0], [215.0, 793.0]], [[182.0, 640.0], [209.0, 640.0], [209.0, 768.0], [182.0, 768.0]], [[153.0, 640.0], [175.0, 640.0], [175.0, 778.0], [153.0, 778.0]]], "lines": ["今日ほど心底", "くだらないと", "思った日は", "ありません。"]}, {"box": [843, 473, 965, 688], "vertical": true, "font_size": 25, "lines_coords": [[[937.0, 475.0], [964.0, 475.0], [964.0, 612.0], [937.0, 612.0]], [[906.0, 475.0], [932.0, 475.0], [932.0, 656.0], [906.0, 656.0]], [[875.0, 475.0], [901.0, 475.0], [901.0, 631.0], [875.0, 631.0]], [[843.0, 473.0], [865.0, 473.0], [865.0, 681.0], [843.0, 681.0]]], "lines": ["いつも通り、", "ジャイアンツと", "宇宙の話題で", "もちきりでしたが、"]}, {"box": [118, 1175, 338, 1384], "vertical": true, "font_size": 25, "lines_coords": [[[312.0, 1176.0], [334.0, 1176.0], [334.0, 1303.0], [312.0, 1303.0]], [[278.0, 1175.0], [304.0, 1175.0], [303.0, 1384.0], [276.0, 1384.0]], [[245.0, 1178.0], [271.0, 1178.0], [271.0, 1331.0], [245.0, 1331.0]], [[212.0, 1176.0], [239.0, 1176.0], [237.0, 1359.0], [210.0, 1359.0]], [[182.0, 1179.0], [204.0, 1179.0], [204.0, 1379.0], [182.0, 1379.0]], [[146.0, 1175.0], [173.0, 1175.0], [175.0, 1379.0], [148.0, 1379.0]], [[118.0, 1178.0], [140.0, 1178.0], [140.0, 1337.0], [118.0, 1337.0]]], "lines": ["黒魔術でも", "大声で唱えなから", "全裸で駅前を", "全力疾走したら", "なんだかとっても", "気持ち良いのでは", "なかろうかと。"]}, {"box": [370, 1175, 401, 1445], "vertical": true, "font_size": 26, "lines_coords": [[[370.0, 1175.0], [396.0, 1175.0], [400.0, 1439.0], [373.0, 1439.0]]], "lines": ["フンフンは思いました。"]}, {"box": [776, 1176, 895, 1364], "vertical": true, "font_size": 24, "lines_coords": [[[873.0, 1176.0], [895.0, 1176.0], [895.0, 1354.0], [873.0, 1354.0]], [[839.0, 1176.0], [865.0, 1176.0], [865.0, 1331.0], [839.0, 1331.0]], [[804.0, 1176.0], [831.0, 1176.0], [831.0, 1354.0], [804.0, 1354.0]], [[776.0, 1176.0], [798.0, 1176.0], [798.0, 1360.0], [776.0, 1360.0]]], "lines": ["どうしてこうも", "大人のくせに", "みんな自分勝手", "なのだろう、と"]}, {"box": [948, 1175, 975, 1444], "vertical": true, "font_size": 22, "lines_coords": [[[948.0, 1175.0], [970.0, 1175.0], [970.0, 1435.0], [948.0, 1435.0]]], "lines": ["フンフンは思いました"]}]}