{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [893, 56, 1001, 263], "vertical": true, "font_size": 22, "lines_coords": [[[976.0, 56.0], [998.0, 56.0], [1000.0, 243.0], [978.0, 243.0]], [[950.0, 59.0], [971.0, 59.0], [971.0, 193.0], [950.0, 193.0]], [[920.0, 57.0], [942.0, 57.0], [942.0, 262.0], [920.0, 262.0]], [[893.0, 57.0], [915.0, 57.0], [915.0, 179.0], [893.0, 179.0]]], "lines": ["これから行く部屋", "身寄りの無い", "７０過ぎのジイさんが", "住んでてね。"]}, {"box": [350, 114, 434, 288], "vertical": true, "font_size": 26, "lines_coords": [[[404.0, 114.0], [434.0, 114.0], [434.0, 190.0], [404.0, 190.0]], [[381.0, 117.0], [403.0, 117.0], [403.0, 287.0], [381.0, 287.0]], [[350.0, 114.0], [376.0, 114.0], [376.0, 234.0], [350.0, 234.0]]], "lines": ["．．．けど", "四、五年前だった", "かな〜〜．．．"]}, {"box": [671, 432, 788, 629], "vertical": true, "font_size": 23, "lines_coords": [[[760.0, 432.0], [787.0, 432.0], [785.0, 621.0], [759.0, 621.0]], [[729.0, 435.0], [751.0, 435.0], [751.0, 628.0], [729.0, 628.0]], [[701.0, 434.0], [723.0, 434.0], [720.0, 621.0], [698.0, 621.0]], [[671.0, 434.0], [693.0, 434.0], [695.0, 607.0], [673.0, 607.0]]], "lines": ["金の無い人だった", "けど朴訥な人でね。", "僕も随分安く紹介", "してあげたんだ。"]}, {"box": [115, 421, 196, 657], "vertical": true, "font_size": 24, "lines_coords": [[[171.0, 421.0], [193.0, 421.0], [193.0, 656.0], [171.0, 656.0]], [[140.0, 421.0], [167.0, 421.0], [167.0, 653.0], [140.0, 653.0]], [[115.0, 421.0], [137.0, 421.0], [137.0, 643.0], [115.0, 643.0]]], "lines": ["突然ウチに満面の笑みで", "大量のペットボトルの", "水を持ってきてさァ。"]}, {"box": [900, 726, 1006, 912], "vertical": true, "font_size": 22, "lines_coords": [[[982.0, 726.0], [1006.0, 726.0], [1003.0, 867.0], [979.0, 867.0]], [[954.0, 728.0], [976.0, 728.0], [976.0, 889.0], [954.0, 889.0]], [[925.0, 726.0], [948.0, 726.0], [950.0, 912.0], [926.0, 912.0]], [[900.0, 726.0], [920.0, 726.0], [920.0, 854.0], [900.0, 854.0]]], "lines": ["パワーが注入", "されてて健康に", "いいから飲めって", "言われてね。"]}, {"box": [815, 898, 893, 1082], "vertical": true, "font_size": 22, "lines_coords": [[[871.0, 898.0], [893.0, 898.0], [893.0, 1082.0], [871.0, 1082.0]], [[843.0, 900.0], [865.0, 900.0], [865.0, 1060.0], [843.0, 1060.0]], [[815.0, 900.0], [837.0, 900.0], [837.0, 1045.0], [815.0, 1045.0]]], "lines": ["笑顔が足りないと", "不幸になるとも", "言ってたかな。"]}, {"box": [198, 792, 287, 1010], "vertical": true, "font_size": 28, "lines_coords": [[[260.0, 795.0], [287.0, 795.0], [287.0, 1010.0], [260.0, 1010.0]], [[226.0, 792.0], [257.0, 792.0], [254.0, 978.0], [223.0, 978.0]], [[198.0, 793.0], [220.0, 793.0], [220.0, 982.0], [198.0, 982.0]]], "lines": ["それ、宗教なんじゃ", "ないのって僕は", "言ったんだけど、"]}, {"box": [143, 1020, 237, 1179], "vertical": true, "font_size": 28, "lines_coords": [[[206.0, 1020.0], [237.0, 1020.0], [237.0, 1179.0], [206.0, 1179.0]], [[175.0, 1021.0], [201.0, 1021.0], [198.0, 1154.0], [171.0, 1154.0]], [[143.0, 1021.0], [171.0, 1021.0], [171.0, 1131.0], [143.0, 1131.0]]], "lines": ["本人は頑なに", "否定してた", "ねぇ～～"]}, {"box": [914, 1264, 970, 1451], "vertical": true, "font_size": 24, "lines_coords": [[[946.0, 1264.0], [970.0, 1264.0], [968.0, 1420.0], [945.0, 1420.0]], [[914.0, 1265.0], [935.0, 1265.0], [935.0, 1451.0], [914.0, 1451.0]]], "lines": ["まぁ僕の顔は", "生まれつきだし、"]}, {"box": [757, 1340, 879, 1548], "vertical": true, "font_size": 24, "lines_coords": [[[853.0, 1343.0], [879.0, 1343.0], [879.0, 1525.0], [853.0, 1525.0]], [[818.0, 1340.0], [845.0, 1340.0], [846.0, 1525.0], [820.0, 1525.0]], [[790.0, 1345.0], [812.0, 1345.0], [812.0, 1548.0], [790.0, 1548.0]], [[757.0, 1342.0], [784.0, 1342.0], [784.0, 1448.0], [757.0, 1448.0]]], "lines": ["酒が水みたいな", "もんだからって", "突き返しちゃった", "けど．．．"]}, {"box": [107, 1373, 170, 1516], "vertical": true, "font_size": 32, "lines_coords": [[[135.0, 1373.0], [170.0, 1373.0], [170.0, 1465.0], [135.0, 1465.0]], [[107.0, 1375.0], [135.0, 1375.0], [135.0, 1515.0], [107.0, 1515.0]]], "lines": ["．．．．．あ、", "ココ、ココ。"]}]}