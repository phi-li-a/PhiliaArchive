{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [926, 34, 990, 251], "vertical": true, "font_size": 30, "lines_coords": [[[956.0, 34.0], [987.0, 34.0], [990.0, 192.0], [959.0, 192.0]], [[926.0, 34.0], [954.0, 34.0], [956.0, 251.0], [928.0, 251.0]]], "lines": ["全裸で街中を", "走りまわることも、"]}, {"box": [823, 32, 910, 217], "vertical": true, "font_size": 27.0, "lines_coords": [[[887.0, 107.0], [910.0, 107.0], [910.0, 179.0], [887.0, 179.0]], [[860.0, 34.0], [887.0, 34.0], [887.0, 217.0], [860.0, 217.0]], [[826.0, 32.0], [857.0, 32.0], [854.0, 215.0], [823.0, 215.0]]], "lines": ["お願いします。こちらのおまじをお客さまでも", "年寄りから金を", "騙し取ることも"]}, {"box": [754, 32, 788, 280], "vertical": true, "font_size": 31, "lines_coords": [[[756.0, 32.0], [787.0, 32.0], [785.0, 279.0], [754.0, 279.0]]], "lines": ["人を殺すことだって、"]}, {"box": [159, 34, 254, 268], "vertical": true, "font_size": 27, "lines_coords": [[[223.0, 34.0], [250.0, 34.0], [253.0, 192.0], [226.0, 192.0]], [[190.0, 34.0], [218.0, 34.0], [220.0, 268.0], [192.0, 268.0]], [[160.0, 35.0], [187.0, 35.0], [187.0, 256.0], [160.0, 256.0]]], "lines": ["倫理的問題を", "度外視してしまえば", "なんだってできる。"]}, {"box": [840, 562, 967, 806], "vertical": true, "font_size": 30, "lines_coords": [[[935.0, 587.0], [967.0, 587.0], [967.0, 800.0], [935.0, 800.0]], [[904.0, 592.0], [935.0, 592.0], [935.0, 775.0], [904.0, 775.0]], [[873.0, 590.0], [900.0, 590.0], [903.0, 775.0], [876.0, 775.0]], [[840.0, 562.0], [871.0, 562.0], [871.0, 760.0], [840.0, 760.0]]], "lines": ["だから子供の頃に", "しっこいくらい", "協調とか道徳を", "戦刷り込まれる。"]}, {"box": [670, 589, 804, 842], "vertical": true, "font_size": 36, "lines_coords": [[[770.0, 589.0], [801.0, 589.0], [804.0, 776.0], [773.0, 776.0]], [[735.0, 589.0], [773.0, 589.0], [776.0, 842.0], [739.0, 842.0]], [[703.0, 590.0], [742.0, 590.0], [746.0, 832.0], [707.0, 832.0]], [[670.0, 595.0], [706.0, 593.0], [714.0, 818.0], [678.0, 820.0]]], "lines": ["なのに世の中は", "当たり前に、人と人が", "争い、欺き、奪い合う", "ように作られてる。"]}, {"box": [303, 590, 398, 776], "vertical": true, "font_size": 30, "lines_coords": [[[364.0, 590.0], [395.0, 590.0], [398.0, 776.0], [367.0, 776.0]], [[335.0, 592.0], [364.0, 592.0], [365.0, 750.0], [337.0, 750.0]], [[306.0, 592.0], [334.0, 592.0], [331.0, 735.0], [303.0, 735.0]]], "lines": ["その矛盾の中で", "生きてるから", "人は苦しむ。"]}, {"box": [143, 590, 271, 870], "vertical": true, "font_size": 30, "lines_coords": [[[245.0, 593.0], [271.0, 593.0], [271.0, 776.0], [245.0, 776.0]], [[210.0, 592.0], [242.0, 592.0], [242.0, 778.0], [210.0, 778.0]], [[178.0, 590.0], [209.0, 590.0], [209.0, 870.0], [178.0, 870.0]], [[148.0, 590.0], [181.0, 590.0], [176.0, 842.0], [143.0, 842.0]]], "lines": ["今もあちこちで", "幸せと不幸が", "株みだいに目まぐるしく", "やり取りされてんだ。"]}, {"box": [151, 1120, 223, 1457], "vertical": true, "font_size": 30, "lines_coords": [[[190.0, 1121.0], [223.0, 1121.0], [223.0, 1307.0], [190.0, 1307.0]], [[151.0, 1120.0], [179.0, 1120.0], [181.0, 1457.0], [153.0, 1457.0]]], "lines": ["．．．どうすれば", "みんなが幸せになれる？"]}]}