{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [943, 79, 970, 364], "vertical": true, "font_size": 28, "lines_coords": [[[943.0, 79.0], [970.0, 79.0], [970.0, 364.0], [943.0, 364.0]]], "lines": ["そんなもんわかるもんか。"]}, {"box": [832, 153, 925, 487], "vertical": true, "font_size": 28, "lines_coords": [[[898.0, 153.0], [925.0, 153.0], [925.0, 487.0], [898.0, 487.0]], [[867.0, 154.0], [893.0, 154.0], [893.0, 451.0], [867.0, 451.0]], [[832.0, 153.0], [864.0, 153.0], [864.0, 451.0], [832.0, 451.0]]], "lines": ["子供の浅知恵でどうにかなる", "くらいだったら、とっくに", "戦争なんて無くなってる。"]}, {"box": [532, 118, 625, 376], "vertical": true, "font_size": 22, "lines_coords": [[[598.0, 118.0], [620.0, 118.0], [620.0, 348.0], [598.0, 348.0]], [[564.0, 118.0], [585.0, 118.0], [585.0, 371.0], [564.0, 371.0]], [[532.0, 120.0], [554.0, 120.0], [554.0, 253.0], [532.0, 253.0]]], "lines": ["けど社会とか政治に", "責任を丸投げするのも", "なんか嫌だ"]}, {"box": [398, 289, 491, 610], "vertical": true, "font_size": 27, "lines_coords": [[[460.0, 289.0], [489.0, 289.0], [490.0, 550.0], [462.0, 550.0]], [[431.0, 290.0], [457.0, 290.0], [457.0, 601.0], [431.0, 601.0]], [[398.0, 289.0], [425.0, 289.0], [425.0, 610.0], [398.0, 610.0]]], "lines": ["だって偉い人達なんて", "結局は民意に踊らされてる", "ただのオッサンじゃないか。"]}, {"box": [95, 309, 225, 554], "vertical": true, "font_size": 30, "lines_coords": [[[187.0, 309.0], [220.0, 309.0], [223.0, 506.0], [190.0, 506.0]], [[159.0, 309.0], [190.0, 309.0], [190.0, 521.0], [159.0, 521.0]], [[126.0, 310.0], [157.0, 310.0], [157.0, 546.0], [126.0, 546.0]], [[95.0, 309.0], [121.0, 309.0], [125.0, 551.0], [98.0, 551.0]]], "lines": ["世の中だってのは、", "剥き出しになった", "人間の本質が具現化", "したものじゃねーか。"]}, {"box": [876, 789, 973, 1000], "vertical": true, "font_size": 30, "lines_coords": [[[948.0, 795.0], [970.0, 795.0], [970.0, 971.0], [948.0, 971.0]], [[914.0, 795.0], [940.0, 795.0], [940.0, 1000.0], [914.0, 1000.0]], [[876.0, 789.0], [917.0, 789.0], [917.0, 860.0], [876.0, 860.0]]], "lines": ["きっとみんなが", "幸せになることは", "無い。"]}, {"box": [229, 792, 292, 1006], "vertical": true, "font_size": 27, "lines_coords": [[[262.0, 795.0], [289.0, 795.0], [289.0, 975.0], [262.0, 975.0]], [[229.0, 792.0], [256.0, 792.0], [257.0, 1006.0], [231.0, 1006.0]]], "lines": ["幸福って感覚は", "相対的なもんだし、"]}, {"box": [112, 793, 172, 985], "vertical": true, "font_size": 25, "lines_coords": [[[143.0, 793.0], [171.0, 793.0], [171.0, 925.0], [143.0, 925.0]], [[112.0, 793.0], [134.0, 793.0], [134.0, 981.0], [112.0, 981.0]]], "lines": ["それを人は", "望んでいるから。"]}, {"box": [914, 1140, 973, 1300], "vertical": true, "font_size": 27, "lines_coords": [[[946.0, 1140.0], [973.0, 1140.0], [970.0, 1300.0], [943.0, 1300.0]], [[914.0, 1140.0], [940.0, 1140.0], [940.0, 1281.0], [914.0, 1281.0]]], "lines": ["悪って感覚も", "相対的だ。"]}, {"box": [782, 1137, 876, 1375], "vertical": true, "font_size": 27, "lines_coords": [[[845.0, 1137.0], [876.0, 1137.0], [876.0, 1328.0], [845.0, 1328.0]], [[814.0, 1142.0], [840.0, 1142.0], [840.0, 1375.0], [814.0, 1375.0]], [[782.0, 1140.0], [809.0, 1140.0], [809.0, 1293.0], [782.0, 1293.0]]], "lines": ["他人から子供を", "守るためなら母親は", "鬼になれる。"]}, {"box": [515, 1138, 579, 1389], "vertical": true, "font_size": 29, "lines_coords": [[[548.0, 1139.0], [579.0, 1139.0], [579.0, 1318.0], [548.0, 1318.0]], [[515.0, 1140.0], [542.0, 1140.0], [545.0, 1387.0], [518.0, 1387.0]]], "lines": ["そしてそれは", "美談として語られる。"]}, {"box": [212, 1139, 318, 1386], "vertical": true, "font_size": 31, "lines_coords": [[[285.0, 1140.0], [317.0, 1140.0], [317.0, 1350.0], [285.0, 1350.0]], [[254.0, 1140.0], [282.0, 1140.0], [279.0, 1303.0], [251.0, 1303.0]], [[221.0, 1142.0], [253.0, 1142.0], [253.0, 1382.0], [221.0, 1382.0]]], "lines": ["愛する人や祖国を", "守るだめなら", "国家は戦争ができる。"]}, {"box": [140, 1139, 176, 1345], "vertical": true, "font_size": 33, "lines_coords": [[[143.0, 1139.0], [176.0, 1139.0], [173.0, 1345.0], [140.0, 1345.0]]], "lines": ["同じじゃねーか。"]}]}