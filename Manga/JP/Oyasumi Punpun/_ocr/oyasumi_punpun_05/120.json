{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [885, 39, 982, 328], "vertical": true, "font_size": 28, "lines_coords": [[[948.0, 39.0], [979.0, 39.0], [982.0, 328.0], [951.0, 328.0]], [[915.0, 39.0], [946.0, 39.0], [950.0, 257.0], [918.0, 257.0]], [[885.0, 42.0], [912.0, 42.0], [917.0, 225.0], [890.0, 225.0]]], "lines": ["善良なふりをしていても", "誰だって本質には", "負を抱えてる。"]}, {"box": [828, 112, 851, 154], "vertical": true, "font_size": 28, "lines_coords": [[[828.0, 112.0], [851.0, 112.0], [851.0, 154.0], [828.0, 154.0]]], "lines": ["．．．"]}, {"box": [735, 42, 825, 275], "vertical": true, "font_size": 28, "lines_coords": [[[798.0, 42.0], [825.0, 42.0], [825.0, 275.0], [798.0, 275.0]], [[765.0, 43.0], [792.0, 43.0], [792.0, 228.0], [765.0, 228.0]], [[735.0, 45.0], [762.0, 45.0], [762.0, 262.0], [735.0, 262.0]]], "lines": ["そして意外なくらい", "誰もそのごとに", "気付こうとしない。"]}, {"box": [646, 46, 673, 200], "vertical": true, "font_size": 27, "lines_coords": [[[646.0, 46.0], [673.0, 46.0], [673.0, 200.0], [646.0, 200.0]]], "lines": ["．．．なんでだ？"]}, {"box": [275, 40, 335, 282], "vertical": true, "font_size": 30, "lines_coords": [[[309.0, 42.0], [335.0, 42.0], [335.0, 276.0], [309.0, 276.0]], [[275.0, 40.0], [306.0, 40.0], [306.0, 282.0], [275.0, 282.0]]], "lines": ["言い訳とか責任転嫁", "ばかり上手になって、"]}, {"box": [115, 40, 245, 326], "vertical": true, "font_size": 30, "lines_coords": [[[212.0, 40.0], [245.0, 40.0], [245.0, 326.0], [212.0, 326.0]], [[178.0, 42.0], [210.0, 42.0], [209.0, 321.0], [176.0, 321.0]], [[146.0, 42.0], [178.0, 42.0], [178.0, 304.0], [146.0, 304.0]], [[115.0, 40.0], [143.0, 40.0], [145.0, 215.0], [117.0, 215.0]]], "lines": ["てめーが抱えてる問題は", "でも川目身が作り出し", "たんだっていう可能性", "すら考えない。"]}, {"box": [934, 623, 992, 856], "vertical": true, "font_size": 27, "lines_coords": [[[965.0, 623.0], [992.0, 623.0], [992.0, 831.0], [965.0, 831.0]], [[934.0, 625.0], [960.0, 625.0], [960.0, 856.0], [934.0, 856.0]]], "lines": ["．．．さっきから俺は", "何を考えてるんだ？"]}, {"box": [845, 618, 910, 959], "vertical": true, "font_size": 27, "lines_coords": [[[873.0, 618.0], [910.0, 618.0], [906.0, 959.0], [868.0, 959.0]], [[845.0, 621.0], [871.0, 621.0], [871.0, 923.0], [845.0, 923.0]]], "lines": ["俺一人が何を考えたところで", "世の中は何も変わらない。"]}, {"box": [820, 703, 837, 765], "vertical": true, "font_size": 27, "lines_coords": [[[820.0, 703.0], [837.0, 703.0], [837.0, 765.0], [820.0, 765.0]]], "lines": ["．．．"]}, {"box": [756, 621, 817, 829], "vertical": true, "font_size": 27, "lines_coords": [[[789.0, 621.0], [817.0, 621.0], [814.0, 779.0], [785.0, 779.0]], [[756.0, 623.0], [782.0, 623.0], [782.0, 829.0], [756.0, 829.0]]], "lines": ["．．．じゃあ俺は", "どうしたいんだ？"]}, {"box": [700, 618, 726, 750], "vertical": true, "font_size": 27, "lines_coords": [[[700.0, 618.0], [726.0, 618.0], [726.0, 750.0], [700.0, 750.0]]], "lines": ["俺個人は？"]}, {"box": [587, 623, 615, 753], "vertical": true, "font_size": 27, "lines_coords": [[[587.0, 623.0], [614.0, 623.0], [614.0, 753.0], [587.0, 753.0]]], "lines": ["だーれだ？"]}, {"box": [265, 618, 334, 809], "vertical": true, "font_size": 30, "lines_coords": [[[301.0, 618.0], [334.0, 620.0], [329.0, 770.0], [296.0, 768.0]], [[268.0, 620.0], [301.0, 620.0], [298.0, 809.0], [265.0, 809.0]]], "lines": ["．．．俺はただ", "何もしたくない。"]}, {"box": [134, 618, 226, 867], "vertical": true, "font_size": 30, "lines_coords": [[[195.0, 620.0], [226.0, 620.0], [226.0, 856.0], [195.0, 856.0]], [[162.0, 618.0], [195.0, 618.0], [192.0, 842.0], [159.0, 842.0]], [[134.0, 621.0], [156.0, 621.0], [156.0, 867.0], [134.0, 867.0]]], "lines": ["誰にも命令されない", "かわりに誰にも、", "迷惑をかけたくない。"]}, {"box": [751, 1142, 985, 1378], "vertical": true, "font_size": 29, "lines_coords": [[[959.0, 1143.0], [985.0, 1143.0], [985.0, 1275.0], [959.0, 1275.0]], [[923.0, 1142.0], [954.0, 1142.0], [957.0, 1331.0], [926.0, 1331.0]], [[870.0, 1143.0], [896.0, 1143.0], [896.0, 1303.0], [870.0, 1303.0]], [[837.0, 1148.0], [865.0, 1148.0], [865.0, 1289.0], [837.0, 1289.0]], [[787.0, 1143.0], [818.0, 1143.0], [820.0, 1378.0], [789.0, 1378.0]], [[751.0, 1142.0], [784.0, 1142.0], [787.0, 1289.0], [754.0, 1289.0]]], "lines": ["その結果が", "ただの怠け者だ。", "学校も行かず", "働きもせず。", "昼間からアテもなく", "ブラついで。"]}, {"box": [579, 1142, 726, 1389], "vertical": true, "font_size": 29, "lines_coords": [[[696.0, 1142.0], [725.0, 1142.0], [726.0, 1353.0], [698.0, 1353.0]], [[665.0, 1142.0], [693.0, 1142.0], [695.0, 1389.0], [667.0, 1389.0]], [[612.0, 1146.0], [639.0, 1146.0], [639.0, 1275.0], [612.0, 1275.0]], [[579.0, 1145.0], [610.0, 1145.0], [610.0, 1384.0], [579.0, 1384.0]]], "lines": ["人は自由だなんて", "強引に言い聞かせて。", "実際は街の", "不審者じゃねーか。"]}, {"box": [256, 1143, 325, 1353], "vertical": true, "font_size": 30, "lines_coords": [[[292.0, 1143.0], [325.0, 1143.0], [325.0, 1353.0], [292.0, 1353.0]], [[256.0, 1145.0], [282.0, 1145.0], [282.0, 1310.0], [256.0, 1310.0]]], "lines": ["結論はいつだって", "身も蓋もない。"]}, {"box": [129, 1142, 223, 1403], "vertical": true, "font_size": 30, "lines_coords": [[[195.0, 1145.0], [223.0, 1145.0], [220.0, 1323.0], [192.0, 1323.0]], [[162.0, 1146.0], [193.0, 1146.0], [193.0, 1403.0], [162.0, 1403.0]], [[129.0, 1142.0], [162.0, 1142.0], [162.0, 1295.0], [129.0, 1295.0]]], "lines": ["つまり俺が今、", "二番何を言いたいかと", "言うと．．．．．．"]}]}