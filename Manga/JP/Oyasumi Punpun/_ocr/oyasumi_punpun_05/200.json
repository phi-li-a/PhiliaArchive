{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [853, 51, 962, 259], "vertical": true, "font_size": 23, "lines_coords": [[[935.0, 53.0], [962.0, 53.0], [962.0, 153.0], [935.0, 153.0]], [[910.0, 53.0], [932.0, 53.0], [932.0, 192.0], [910.0, 192.0]], [[881.0, 51.0], [903.0, 51.0], [903.0, 259.0], [881.0, 259.0]], [[853.0, 51.0], [875.0, 51.0], [875.0, 246.0], [853.0, 246.0]]], "lines": ["．．．なんか、", "結局最後まで", "すきま風が吹いてる", "親子関係だったわ。"]}, {"box": [715, 73, 801, 268], "vertical": true, "font_size": 23, "lines_coords": [[[775.0, 73.0], [801.0, 73.0], [801.0, 250.0], [775.0, 250.0]], [[742.0, 78.0], [764.0, 78.0], [764.0, 259.0], [742.0, 259.0]], [[715.0, 75.0], [735.0, 75.0], [735.0, 268.0], [715.0, 268.0]]], "lines": ["仕方無いわよね。", "血が繋がってても", "他人は他人だもの。"]}, {"box": [554, 56, 610, 220], "vertical": true, "font_size": 24, "lines_coords": [[[587.0, 59.0], [609.0, 59.0], [609.0, 220.0], [587.0, 220.0]], [[557.0, 56.0], [584.0, 56.0], [581.0, 195.0], [554.0, 195.0]]], "lines": ["ホントに申し訳", "ないです．．．"]}, {"box": [90, 167, 226, 356], "vertical": true, "font_size": 22, "lines_coords": [[[200.0, 170.0], [226.0, 170.0], [226.0, 310.0], [200.0, 310.0]], [[173.0, 170.0], [195.0, 170.0], [195.0, 356.0], [173.0, 356.0]], [[146.0, 167.0], [168.0, 167.0], [165.0, 356.0], [143.0, 356.0]], [[117.0, 170.0], [139.0, 170.0], [139.0, 331.0], [117.0, 331.0]], [[90.0, 168.0], [110.0, 168.0], [110.0, 309.0], [90.0, 309.0]]], "lines": ["私達が旅行で", "出かけてなければ", "もっと早く見つけ", "られたかもしれ", "ないのに．．．"]}, {"box": [926, 686, 956, 789], "vertical": true, "font_size": 28, "lines_coords": [[[926.0, 687.0], [954.0, 687.0], [954.0, 789.0], [926.0, 789.0]]], "lines": ["雄一は？"]}, {"box": [134, 439, 223, 571], "vertical": true, "font_size": 26, "lines_coords": [[[196.0, 443.0], [223.0, 443.0], [223.0, 556.0], [196.0, 556.0]], [[164.0, 439.0], [190.0, 439.0], [190.0, 571.0], [164.0, 571.0]], [[134.0, 439.0], [160.0, 439.0], [160.0, 542.0], [134.0, 542.0]]], "lines": ["いいのよ。", "これも寿命", "でしょ？"]}, {"box": [789, 837, 911, 992], "vertical": true, "font_size": 25, "lines_coords": [[[884.0, 837.0], [910.0, 837.0], [910.0, 981.0], [884.0, 981.0]], [[851.0, 839.0], [878.0, 839.0], [878.0, 992.0], [851.0, 992.0]], [[821.0, 839.0], [843.0, 839.0], [843.0, 964.0], [821.0, 964.0]], [[789.0, 837.0], [815.0, 837.0], [815.0, 951.0], [789.0, 951.0]]], "lines": ["．．．あ、２階で", "葬儀屋さんと", "打ち合わせ", "してます。"]}, {"box": [167, 873, 259, 1028], "vertical": true, "font_size": 25, "lines_coords": [[[231.0, 879.0], [259.0, 879.0], [256.0, 1017.0], [228.0, 1017.0]], [[200.0, 875.0], [226.0, 875.0], [226.0, 1028.0], [200.0, 1028.0]], [[167.0, 873.0], [195.0, 873.0], [195.0, 962.0], [167.0, 962.0]]], "lines": ["一応、あたし", "軽く顔出して", "くるわ。"]}, {"box": [125, 1101, 232, 1287], "vertical": true, "font_size": 25, "lines_coords": [[[210.0, 1103.0], [232.0, 1103.0], [232.0, 1275.0], [210.0, 1275.0]], [[179.0, 1103.0], [206.0, 1103.0], [206.0, 1287.0], [179.0, 1287.0]], [[153.0, 1101.0], [175.0, 1101.0], [176.0, 1262.0], [154.0, 1262.0]], [[125.0, 1101.0], [146.0, 1101.0], [148.0, 1251.0], [126.0, 1251.0]]], "lines": ["この後、ちょっと", "別の予定があって", "早目に出なきゃ", "なんないのよ。"]}, {"box": [615, 1340, 735, 1521], "vertical": true, "font_size": 25, "lines_coords": [[[706.0, 1340.0], [732.0, 1340.0], [735.0, 1493.0], [709.0, 1493.0]], [[675.0, 1342.0], [701.0, 1342.0], [704.0, 1470.0], [678.0, 1470.0]], [[645.0, 1342.0], [671.0, 1342.0], [671.0, 1520.0], [645.0, 1520.0]], [[615.0, 1343.0], [637.0, 1343.0], [637.0, 1506.0], [615.0, 1506.0]]], "lines": ["．．．フンフンは", "いまひとつ", "状況が飲み込め", "ませんでした。"]}, {"box": [314, 1337, 471, 1522], "vertical": true, "font_size": 28, "lines_coords": [[[442.0, 1343.0], [468.0, 1343.0], [468.0, 1521.0], [442.0, 1521.0]], [[410.0, 1342.0], [437.0, 1342.0], [437.0, 1521.0], [410.0, 1521.0]], [[378.0, 1342.0], [404.0, 1342.0], [404.0, 1495.0], [378.0, 1495.0]], [[346.0, 1342.0], [375.0, 1342.0], [375.0, 1446.0], [346.0, 1446.0]], [[314.0, 1337.0], [346.0, 1337.0], [346.0, 1384.0], [314.0, 