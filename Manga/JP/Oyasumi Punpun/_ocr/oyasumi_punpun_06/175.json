 1112.0], [373.0, 1262.0], [351.0, 1262.0]]], "lines": ["強くて自信に"]}, {"box": [251, 1107, 342, 1289], "vertical": true, "font_size": 25, "lines_coords": [[[320.0, 1112.0], [342.0, 1112.0], [342.0, 1289.0], [320.0, 1289.0]], [[287.0, 1110.0], [309.0, 1110.0], [309.0, 1289.0], [287.0, 1289.0]], [[251.0, 1107.0], [284.0, 1107.0], [284.0, 1193.0], [251.0, 1193.0]]], "lines": ["溢れてる人には", "もちろん憧れる", "けれど、"]}, {"box": [771, 1273, 892, 1484], "vertical": true, "font_size": 27, "lines_coords": [[[865.0, 1276.0], [892.0, 1276.0], [892.0, 1484.0], [865.0, 1484.0]], [[832.0, 1275.0], [860.0, 1275.0], [862.0, 1468.0], [834.0, 1468.0]], [[801.0, 1273.0], [829.0, 1273.0], [828.0, 1481.0], [800.0, 1481.0]], [[771.0, 1276.0], [793.0, 1276.0], [793.0, 1439.0], [771.0, 1439.0]]], "lines": ["大人の人でも悩ん", "でるんだなって、", "ちょっと安心して", "しまいました。"]}, {"box": [228, 1318, 250, 1473], "vertical": true, "font_size": 25, "lines_coords": [[[228.0, 1318.0], [250.0, 1318.0], [250.0, 1473.0], [228.0, 1473.0]]], "lines": ["自分の弱さを"]}, {"box": [96, 1315, 251, 1525], "vertical": true, "font_size": 28, "lines_coords": [[[193.0, 1315.0], [220.0, 1315.0], [218.0, 1521.0], [192.0, 1521.0]], [[159.0, 1315.0], [190.0, 1315.0], [190.0, 1525.0], [159.0, 1525.0]], [[129.0, 1317.0], [156.0, 1317.0], [153.0, 1523.0], [126.0, 1523.0]], [[98.0, 1315.0], [125.0, 1315.0], [123.0, 1484.0], [96.0, 1484.0]]], "lines": ["素直に出せる人の", "ほうが、なんだか", "ずっと信用できる", "気がしました。"]}]}