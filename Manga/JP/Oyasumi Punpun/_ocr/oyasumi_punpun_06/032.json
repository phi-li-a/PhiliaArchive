{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [834, 134, 874, 334], "vertical": true, "font_size": 26, "lines_coords": [[[834.0, 134.0], [860.0, 134.0], [860.0, 331.0], [834.0, 331.0]]], "lines": ["「肺気胸」ですね。"]}, {"box": [534, 131, 661, 340], "vertical": true, "font_size": 27, "lines_coords": [[[632.0, 131.0], [660.0, 131.0], [657.0, 289.0], [629.0, 289.0]], [[601.0, 131.0], [628.0, 131.0], [628.0, 289.0], [601.0, 289.0]], [[568.0, 131.0], [595.0, 131.0], [595.0, 340.0], [568.0, 340.0]], [[534.0, 131.0], [560.0, 131.0], [564.0, 298.0], [537.0, 298.0]]], "lines": ["肺胞に開いた", "穴から胸腔に", "空気が漏れ、肺を", "圧迫してます。"]}, {"box": [265, 142, 389, 376], "vertical": true, "font_size": 27, "lines_coords": [[[362.0, 142.0], [389.0, 142.0], [389.0, 356.0], [362.0, 356.0]], [[329.0, 142.0], [356.0, 142.0], [356.0, 351.0], [329.0, 351.0]], [[298.0, 143.0], [325.0, 143.0], [325.0, 376.0], [298.0, 376.0]], [[265.0, 143.0], [292.0, 143.0], [292.0, 328.0], [265.0, 328.0]]], "lines": ["そのため呼吸困難、", "更にひどい場合は", "ショック状態に陥る", "時もありますが、"]}, {"box": [722, 439, 972, 480], "vertical": false, "font_size": 36, "lines_coords": [[[725.0, 439.0], [959.0, 443.0], [959.0, 479.0], [725.0, 475.0]]], "lines": ["救急専用口"]}, {"box": [557, 743, 623, 764], "vertical": false, "font_size": 18, "lines_coords": [[[559.0, 743.0], [621.0, 746.0], [621.0, 764.0], [559.0, 760.0]]], "lines": ["教えるかの"]}, {"box": [100, 454, 222, 662], "vertical": true, "font_size": 25, "lines_coords": [[[195.0, 456.0], [221.0, 456.0], [221.0, 662.0], [195.0, 662.0]], [[162.0, 456.0], [189.0, 456.0], [189.0, 639.0], [162.0, 639.0]], [[129.0, 456.0], [156.0, 456.0], [156.0, 662.0], [129.0, 662.0]], [[100.0, 454.0], [121.0, 454.0], [121.0, 643.0], [100.0, 643.0]]], "lines": ["特にこれといった", "原因は無いので、", "自然気胸と呼ばれ", "だりもしますね。"]}, {"box": [848, 745, 1000, 970], "vertical": true, "font_size": 26, "lines_coords": [[[976.0, 754.0], [1000.0, 754.0], [998.0, 926.0], [975.0, 926.0]], [[943.0, 748.0], [970.0, 748.0], [970.