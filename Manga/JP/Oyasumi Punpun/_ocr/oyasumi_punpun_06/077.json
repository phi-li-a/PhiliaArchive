{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [876, 84, 985, 300], "vertical": true, "font_size": 23, "lines_coords": [[[964.0, 85.0], [985.0, 85.0], [985.0, 275.0], [964.0, 275.0]], [[937.0, 85.0], [959.0, 85.0], [959.0, 300.0], [937.0, 300.0]], [[907.0, 85.0], [929.0, 85.0], [929.0, 253.0], [907.0, 253.0]], [[876.0, 84.0], [898.0, 84.0], [901.0, 259.0], [879.0, 259.0]]], "lines": ["．．．あたしが海外で", "遊びまわってる時に", "母親が乳がんて", "死んだんだけど、"]}, {"box": [731, 300, 875, 490], "vertical": true, "font_size": 23, "lines_coords": [[[846.0, 300.0], [875.0, 300.0], [875.0, 445.0], [846.0, 445.0]], [[820.0, 301.0], [842.0, 301.0], [842.0, 443.0], [820.0, 443.0]], [[790.0, 301.0], [812.0, 301.0], [812.0, 470.0], [790.0, 470.0]], [[760.0, 300.0], [782.0, 300.0], [782.0, 490.0], [760.0, 490.0]], [[731.0, 300.0], [753.0, 300.0], [753.0, 473.0], [731.0, 473.0]]], "lines": ["元々、親とは", "ソリが合わな", "かったとはいえ。", "拍子抜けするほど", "悲しくなくてさ。"]}, {"box": [176, 229, 289, 421], "vertical": true, "font_size": 22, "lines_coords": [[[259.0, 229.0], [287.0, 229.0], [289.0, 331.0], [260.0, 331.0]], [[234.0, 232.0], [256.0, 232.0], [256.0, 421.0], [234.0, 421.0]], [[204.0, 232.0], [226.0, 232.0], [226.0, 398.0], [204.0, 398.0]], [[176.0, 232.0], [196.0, 232.0], [196.0, 362.0], [176.0, 362.0]]], "lines": ["葬式にも", "行かなかったけど", "誰にも咎められ", "なかったな。"]}, {"box": [131, 479, 242, 668], "vertical": true, "font_size": 22, "lines_coords": [[[220.0, 482.0], [242.0, 482.0], [242.0, 601.0], [220.0, 601.0]], [[189.0, 481.0], [210.0, 481.0], [210.0, 668.0], [189.0, 668.0]], [[162.0, 481.0], [184.0, 481.0], [184.0, 650.0], [162.0, 650.0]], [[131.0, 479.0], [153.0, 479.0], [153.0, 656.0], [131.0, 656.0]]], "lines": ["父親も弟も", "ハナからあたしが", "薄情な人間って", "思ってたからね。"]}, {"box": [801, 784, 907, 995], "vertical": true, "font_size": 23, "lines_coords": [[[887.0, 787.0], [907.0, 787.0], [907.0, 970.0], [887.0, 970.0]], [[859.0, 785.0], [881.0, 785.0], [881.0, 995.0], [859.0, 995.0]], [[829.0, 784.0], [856.0, 784.0], [854.0, 973.0], [828.0, 973.0]], [[801.0, 784.0], [828.0, 784.0], [828.0, 893.0], [801.0, 893.0]]], "lines": ["あの頃のあたしは", "そういうことが自由", "ってことなんだと", "思ってた。"]}, {"box": [876, 1096, 965, 1287], "vertical": true, "font_size": 26, "lines_coords": [[[939.0, 1098.0], [965.0, 1098.0], [965.0, 1267.0], [939.0, 1267.0]], [[906.0, 1096.0], [932.0, 1096.0], [932.0, 1279.0], [906.0, 1279.0]], [[876.0, 1098.0], [898.0, 1098.0], [898.0, 1287.0], [876.0, 1287.0]]], "lines": ["．．．でもね、今は", "自分探しなんて", "言葉があるけど、"]}, {"box": [659, 800, 764, 1007], "vertical": true, "font_size": 23, "lines_coords": [[[742.0, 800.0], [764.0, 800.0], [764.0, 1007.0], [742.0, 1007.0]], [[714.0, 800.0], [735.0, 800.0], [735.0, 962.0], [714.0, 962.0]], [[685.0, 801.0], [707.0, 801.0], [707.0, 984.0], [685.0, 984.0]], [[659.0, 800.0], [681.0, 800.0], [681.0, 904.0], [659.0, 904.0]]], "lines": ["世の中のことなんて", "これっぽっちも", "わかっちゃいない", "くせにさ。"]}, {"box": [767, 1287, 859, 1448], "vertical": true, "font_size": 26, "lines_coords": [[[832.0, 1290.0], [859.0, 1290.0], [859.0, 1448.0], [832.0, 1448.0]], [[798.0, 1287.0], [826.0, 1287.0], [828.0, 1446.0], [800.0, 1446.0]], [[770.0, 1289.0], [796.0, 1289.0], [793.0, 1446.0], [767.0, 1446.0]]], "lines": ["あたしは自分", "なんて探して", "なかった．．．"]}, {"box": [264, 1156, 406, 1364], "vertical": true, "font_size": 25, "lines_coords": [[[381.0, 1157.0], [406.0, 1157.0], [406.0, 1237.0], [381.0, 1237.0]], [[350.0, 1156.0], [376.0, 1156.0], [376.0, 1364.0], [350.0, 1364.0]], [[320.0, 1157.0], [346.0, 1157.0], [346.0, 1362.0], [320.0, 1362.0]], [[290.0, 1157.0], [317.0, 1157.0], [317.0, 1342.0], [290.0, 1342.0]], [[264.0, 1159.0], [285.0, 1159.0], [285.0, 1323.0], [264.0, 1323.0]]], "lines": ["どうせ", "見つけたところで", "自分がくだらない", "人間なのは十分", "承知だったし。"]}, {"box": [106, 1296, 262, 1506], "vertical": true, "font_size": 25, "lines_coords": [[[231.0, 1296.0], [259.0, 1296.0], [262.0, 1440.0], [234.0, 1440.0]], [[203.0, 1301.0], [225.0, 1301.0], [225.0, 1479.0], [203.0, 1479.0]], [[171.0, 1300.0], [193.0, 1300.0], [193.0, 1506.0], [171.0, 1506.0]], [[137.0, 1298.0], [164.0, 1298.0], [164.0, 1482.0], [137.0, 1482.0]], [[106.0, 1300.0], [132.0, 1300.0], [132.0, 1415.0], [106.0, 1415.0]]], "lines": ["．．．おしろ、", "あたしは誰かに", "見つけられるのを", "待ってたのかも", "しれない。"]}]}