{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [846, 73, 940, 206], "vertical": true, "font_size": 30, "lines_coords": [[[914.0, 73.0], [940.0, 73.0], [940.0, 204.0], [914.0, 204.0]], [[881.0, 73.0], [909.0, 73.0], [906.0, 206.0], [878.0, 206.0]], [[846.0, 73.0], [879.0, 73.0], [879.0, 170.0], [846.0, 170.0]]], "lines": ["でも絶対に", "復縁なんて", "しない。"]}, {"box": [721, 121, 818, 281], "vertical": true, "font_size": 30, "lines_coords": [[[785.0, 123.0], [818.0, 123.0], [818.0, 207.0], [785.0, 207.0]], [[754.0, 121.0], [782.0, 121.0], [784.0, 281.0], [756.0, 281.0]], [[721.0, 121.0], [754.0, 121.0], [754.0, 217.0], [721.0, 217.0]]], "lines": ["これは", "あたしの意地", "だから。"]}, {"box": [273, 98, 339, 231], "vertical": true, "font_size": 34, "lines_coords": [[[298.0, 98.0], [339.0, 98.0], [339.0, 159.0], [298.0, 159.0]], [[273.0, 100.0], [300.0, 100.0], [300.0, 231.0], [273.0, 231.0]]], "lines": ["全然", "ないね．．．"]}, {"box": [387, 478, 477, 675], "vertical": true, "font_size": 25, "lines_coords": [[[450.0, 478.0], [476.0, 478.0], [473.0, 637.0], [446.0, 637.0]], [[417.0, 479.0], [443.0, 479.0], [443.0, 612.0], [417.0, 612.0]], [[387.0, 482.0], [409.0, 482.0], [409.0, 675.0], [387.0, 675.0]]], "lines": ["息子さんとは", "そういう話", "しないんですか？"]}, {"box": [120, 514, 182, 657], "vertical": true, "font_size": 30, "lines_coords": [[[148.0, 514.0], [182.0, 514.0], [182.0, 598.0], [148.0, 598.0]], [[120.0, 515.0], [146.0, 515.0], [146.0, 656.0], [120.0, 656.0]]], "lines": ["最悪に", "仲悪いもん。"]}, {"box": [912, 737, 934, 915], "vertical": true, "font_size": 23, "lines_coords": [[[912.0, 737.0], [934.0, 737.0], [934.0, 915.0], [912.0, 915.0]]], "lines": ["親子なのに．．．？"]}, {"box": [796, 903, 881, 1114], "vertical": true, "font_size": 23, "lines_coords": [[[850.0, 903.0], [876.0, 903.0], [881.0, 1071.0], [854.0, 1071.0]], [[825.0, 906.0], [846.0, 906.0], [846.0, 1114.0], [825.0, 1114.0]], [[798.0, 906.0], [820.0, 906.0], [818.0, 1070.0], [796.0, 1070.0]]], "lines": ["自分の子供って", "可愛いものなんじゃ", "ないんですか？"]}, {"box": [223, 756, 318, 940], "vertical": true, "font_size": 27, "lines_coords": [[[279.0, 757.0], [314.0, 756.0], [318.0, 842.0], [284.0, 843.0]], [[257.0, 762.0], [278.0, 762.0], [278.0, 940.0], [257.0, 940.0]], [[225.0, 760.0], [248.0, 760.0], [246.0, 929.0], [223.0, 929.0]]], "lines": ["そりゃ", "そんな風に思う", "時もあるわよ。"]}, {"box": [156, 970, 250, 1129], "vertical": true, "font_size": 27, "lines_coords": [[[217.0, 970.0], [250.0, 970.0], [250.0, 1065.0], [217.0, 1065.0]], [[190.0, 973.0], [212.0, 973.0], [212.0, 1101.0], [190.0, 1101.0]], [[156.0, 973.0], [182.0, 973.0], [182.0, 1129.0], [156.0, 1129.0]]], "lines": ["．．．けど、", "それ以上に", "大半が―．．．"]}, {"box": [927, 1245, 954, 1362], "vertical": true, "font_size": 26, "lines_coords": [[[928.0, 1245.0], [954.0, 1245.0], [954.0, 1362.0], [928.0, 1362.0]]], "lines": ["．．．嫌悪感。"]}, {"box": [296, 1231, 390, 1426], "vertical": true, "font_size": 26, "lines_coords": [[[364.0, 1232.0], [390.0, 1232.0], [390.0, 1370.0], [364.0, 1370.0]], [[332.0, 1232.0], [359.0, 1232.0], [359.0, 1370.0], [332.0, 1370.0]], [[296.0, 1231.0], [323.0, 1231.0], [326.0, 1426.0], [300.0, 1426.0]]], "lines": ["．．．やっぱね、", "似てるのよ、", "あたしや旦那に。"]}, {"box": [106, 1296, 260, 1507], "vertical": true, "font_size": 26, "lines_coords": [[[235.0, 1300.0], [259.0, 1300.0], [260.0, 1487.0], [237.0, 1487.0]], [[203.0, 1298.0], [229.0, 1298.0], [229.0, 1481.0], [203.0, 1481.0]], [[170.0, 1298.0], [196.0, 1298.0], [196.0, 1507.0], [170.0, 1507.0]], [[139.0, 1298.0], [165.0, 1298.0], [165.0, 1482.0], [139.0, 1482.0]], [[106.0, 1296.0], [132.0, 1296.0], [134.0, 1507.0], [107.0, 1507.0]]], "lines": ["親子だからこそ、", "あたしと旦那の", "嫌いなトコが凝縮", "してるみたいで", "とにかく憎いの．．．"]}]}