{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [626, 118, 750, 376], "vertical": true, "font_size": 27, "lines_coords": [[[721.0, 121.0], [750.0, 121.0], [750.0, 225.0], [721.0, 225.0]], [[690.0, 120.0], [717.0, 120.0], [717.0, 350.0], [690.0, 350.0]], [[657.0, 118.0], [684.0, 118.0], [685.0, 376.0], [659.0, 376.0]], [[626.0, 121.0], [653.0, 121.0], [653.0, 335.0], [626.0, 335.0]]], "lines": ["なぜなら", "クラスのアイドルの", "ミヨちゃんが転校して", "しまったからです。"]}, {"box": [365, 115, 579, 254], "vertical": false, "font_size": 27.75, "lines_coords": [[[378.0, 115.0], [571.0, 120.0], [571.0, 146.0], [378.0, 142.0]], [[384.0, 148.0], [579.0, 156.0], [579.0, 182.0], [384.0, 175.0]], [[365.0, 181.0], [562.0, 189.0], [562.0, 215.0], [365.0, 207.0]], [[378.0, 212.0], [528.0, 221.0], [526.0, 254.0], [376.0, 245.0]]], "lines": ["それを言っておりも未経を", "の中身を満たし続けようと", "の内教室のドアーバラー人。", "すち止ったのです。"]}, {"box": [225, 121, 312, 432], "vertical": true, "font_size": 23, "lines_coords": [[[287.0, 121.0], [310.0, 121.0], [312.0, 325.0], [289.0, 325.0]], [[257.0, 123.0], [279.0, 123.0], [279.0, 325.0], [257.0, 325.0]], [[225.0, 121.0], [246.0, 121.0], [246.0, 432.0], [225.0, 432.0]]], "lines": ["けれどその数日後", "遠い星から一人の", "女の子が転校してきました"]}, {"box": [134, 126, 192, 307], "vertical": true, "font_size": 23, "lines_coords": [[[168.0, 126.0], [192.0, 126.0], [190.0, 300.0], [167.0, 300.0]], [[134.0, 128.0], [160.0, 128.0], [162.0, 307.0], [135.0, 307.0]]], "lines": ["「僕」はその子に", "一目惚れでした。"]}, {"box": [911, 735, 938, 1003], "vertical": true, "font_size": 22, "lines_coords": [[[912.0, 735.0], [934.0, 735.0], [935.0, 995.0], [914.0, 995.0]]], "lines": ["理由なんてありません"]}, {"box": [770, 734, 860, 1027], "vertical": true, "font_size": 26, "lines_coords": [[[834.0, 737.0], [860.0, 737.0], [860.0, 840.0], [834.0, 840.0]], [[803.0, 735.0], [829.0, 735.0], [829.0, 940.0], [803.0, 940.0]], [[770.0, 734.0], [796.0, 734.0], [798.0, 1026.0], [771.0, 1026.0]]], "lines": ["ただただ", "運命の人なのだと", "確信してしまったのです。"]}, {"box": [600, 734, 721, 993], "vertical": true, "font_size": 25, "lines_coords": [[[692.0, 734.0], [718.0, 734.0], [721.0, 890.0], [695.0, 890.0]], [[664.0, 737.0], [690.0, 737.0], [690.0, 915.0], [664.0, 915.0]], [[629.0, 734.0], [656.0, 734.0], [657.0, 990.0], [631.0, 990.0]], [[601.0, 739.0], [623.0, 739.0], [623.0, 898.0], [601.0, 898.0]]], "lines": ["何があっても", "「僕」はその子を", "守ってあげなくちゃと", "思ったのです。"]}, {"box": [457, 734, 550, 1004], "vertical": true, "font_size": 27, "lines_coords": [[[521.0, 734.0], [548.0, 734.0], [550.0, 939.0], [523.0, 939.0]], [[489.0, 735.0], [515.0, 735.0], [517.0, 990.0], [490.0, 990.0]], [[457.0, 735.0], [484.0, 735.0], [485.0, 998.0], [459.0, 998.0]]], "lines": ["それなのに「僕」は", "いつの間にかその子を", "見失ってしまいました。"]}, {"box": [285, 735, 409, 966], "vertical": true, "font_size": 25, "lines_coords": [[[382.0, 739.0], [409.0, 739.0], [409.0, 964.0], [382.0, 964.0]], [[350.0, 737.0], [376.0, 737.0], [376.0, 965.0], [350.0, 965.0]], [[317.0, 735.0], [343.0, 735.0], [345.0, 965.0], [318.0, 965.0]], [[287.0, 739.0], [309.0, 739.0], [309.0, 898.0], [287.0, 898.0]]], "lines": ["大人になった「僕」は", "失ったものを探して", "あてもなく天の川を", "漂っています。"]}, {"box": [212, 739, 238, 979], "vertical": true, "font_size": 20, "lines_coords": [[[214.0, 740.0], [234.0, 740.0], [234.0, 968.0], [214.0, 968.0]]], "lines": ["．．．たとえばこんな話"]}, {"box": [910, 1281, 966, 1469], "vertical": true, "font_size": 24, "lines_coords": [[[939.0, 1281.0], [965.0, 1281.0], [965.0, 1384.0], [939.0, 1384.0]], [[910.0, 1284.0], [932.0, 1284.0], [932.0, 1464.0], [910.0, 1464.0]]], "lines": ["こんなに", "つまらない話が、"]}, {"box": [139, 1342, 262, 1536], "vertical": true, "font_size": 26, "lines_coords": [[[232.0, 1345.0], [259.0, 1345.0], [262.0, 1473.0], [235.0, 1473.0]], [[203.0, 1345.0], [229.0, 1345.0], [229.0, 1475.0], [203.0, 1475.0]], [[167.0, 1342.0], [195.0, 1342.0], [196.0, 1475.0], [168.0, 1475.0]], [[139.0, 1342.0], [162.0, 1342.0], [164.0, 1534.0], [140.0, 1534.0]]], "lines": ["いくらでも", "溢れてきて", "ブンブンは", "泣きそうでした。"]