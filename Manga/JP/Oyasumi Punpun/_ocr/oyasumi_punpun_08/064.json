{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [890, 62, 968, 250], "vertical": true, "font_size": 21, "lines_coords": [[[946.0, 64.0], [968.0, 64.0], [968.0, 248.0], [946.0, 248.0]], [[920.0, 65.0], [940.0, 65.0], [940.0, 250.0], [920.0, 250.0]], [[890.0, 62.0], [910.0, 62.0], [910.0, 246.0], [890.0, 246.0]]], "lines": ["神懸かった奇跡も", "証明さえできれば", "現実で科学なんだ。"]}, {"box": [779, 134, 829, 273], "vertical": true, "font_size": 21, "lines_coords": [[[807.0, 134.0], [829.0, 134.0], [829.0, 273.0], [807.0, 273.0]], [[779.0, 134.0], [801.0, 134.0], [801.0, 215.0], [779.0, 215.0]]], "lines": ["そしてそれは", "浪漫だ。"]}, {"box": [378, 37, 459, 217], "vertical": true, "font_size": 22, "lines_coords": [[[432.0, 37.0], [459.0, 37.0], [456.0, 181.0], [429.0, 181.0]], [[406.0, 42.0], [428.0, 42.0], [428.0, 179.0], [406.0, 179.0]], [[378.0, 39.0], [400.0, 39.0], [400.0, 217.0], [378.0, 217.0]]], "lines": ["．．．幸いながら", "奴は無邪気で", "すこぶる優しい．．．"]}, {"box": [257, 93, 335, 270], "vertical": true, "font_size": 22, "lines_coords": [[[314.0, 93.0], [335.0, 93.0], [335.0, 267.0], [314.0, 267.0]], [[287.0, 95.0], [304.0, 95.0], [304.0, 207.0], [287.0, 207.0]], [[257.0, 95.0], [279.0, 95.0], [279.0, 270.0], [257.0, 270.0]]], "lines": ["全人類を信頼する", "その姿勢は", "絶対的な許しだ．．．"]}, {"box": [106, 157, 213, 369], "vertical": true, "font_size": 107, "lines_coords": [[[106.0, 157.0], [213.0, 157.0], [213.0, 369.0], [106.0, 369.0]]], "lines": ["その許しの精神を人々に伝え説くのはもはや俺の責務だとすら思っている。"]}, {"box": [104, 160, 210, 370], "vertical": true, "font_size": 22, "lines_coords": [[[189.0, 160.0], [210.0, 160.0], [210.0, 346.0], [189.0, 346.0]], [[160.0, 160.0], [182.0, 160.0], [182.0, 370.0], [160.0, 370.0]], [[131.0, 160.0], [153.0, 160.0], [153.0, 368.0], [131.0, 368.0]], [[104.0, 160.0], [126.0, 160.0], [126.0, 332.0], [104.0, 332.0]]], "lines": ["その許しの精神を", "人々に伝え説くのは", "もはや俺の責務だと", "すら思っている。"]}, {"box": [904, 457, 982, 607], "vertical": true, "font_size": 23, "lines_coords": [[[960.0, 457.0], [98