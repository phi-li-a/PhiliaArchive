{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [501, 81, 623, 314], "vertical": true, "font_size": 25, "lines_coords": [[[596.0, 81.0], [623.0, 81.0], [623.0, 181.0], [596.0, 181.0]], [[565.0, 81.0], [592.0, 81.0], [590.0, 312.0], [564.0, 312.0]], [[531.0, 82.0], [557.0, 82.0], [557.0, 285.0], [531.0, 285.0]], [[501.0, 84.0], [521.0, 84.0], [521.0, 271.0], [501.0, 271.0]]], "lines": ["「．．．．．．昔、", "好きだった女の子と", "決着をつけなきゃ", "ならんのです。」"]}, {"box": [379, 81, 406, 185], "vertical": true, "font_size": 27, "lines_coords": [[[379.0, 81.0], [406.0, 81.0], [406.0, 185.0], [379.0, 185.0]]], "lines": ["．．．決着？"]}, {"box": [126, 325, 185, 456], "vertical": true, "font_size": 24, "lines_coords": [[[160.0, 326.0], [182.0, 326.0], [182.0, 456.0], [160.0, 456.0]], [[126.0, 325.0], [153.0, 325.0], [153.0, 432.0], [126.0, 432.0]]], "lines": ["．．．告白ても", "すんの？"]}, {"box": [948, 973, 973, 1006], "vertical": true, "font_size": 22, "lines_coords": [[[948.0, 973.0], [973.0, 973.0], [973.0, 1006.0], [948.0, 1006.0]]], "lines": ["ん"]}, {"box": [881, 1079, 929, 1242], "vertical": true, "font_size": 22, "lines_coords": [[[907.0, 1079.0], [929.0, 1079.0], [929.0, 1242.0], [907.0, 1242.0]], [[881.0, 1081.0], [901.0, 1081.0], [901.0, 1242.0], [881.0, 1242.0]]], "lines": ["単に諦めがつか", "ないってだけ？"]}, {"box": [689, 711, 750, 901], "vertical": true, "font_size": 61, "lines_coords": [[[689.0, 711.0], [750.0, 711.0], [750.0, 901.0], [689.0, 901.0]]], "lines": ["「そういう訳じゃないですけど．．．"]}, {"box": [690, 714, 748, 900], "vertical": true, "font_size": 26, "lines_coords": [[[726.0, 714.0], [748.0, 714.0], [748.0, 900.0], [726.0, 900.0]], [[690.0, 714.0], [717.0, 714.0], [717.0, 892.0], [690.0, 892.0]]], "lines": ["「そういう訳じゃ", "ないですけど．．．"]}, {"box": [526, 712, 654, 925], "vertical": true, "font_size": 26, "lines_coords": [[[626.0, 712.0], [654.0, 712.0], [654.0, 825.0], [626.0, 825.0]], [[596.0, 714.0], [618.0, 714.0], [618.0, 917.0], [596.0, 917.0]], [[562.0, 712.0], [589.0, 712.0], [589.0, 840.0], [562.0, 840.0]], [[526.0, 712.0], [554.0, 712.0], [556.0, 925.0], [528.0, 925.0]]], "lines": ["．．．．．．でも、", "とにかくもう一度", "会わなきゃ", "いけない気がして、"]}, {"box": [370, 709, 490, 920], "vertical": true, "font_size": 26, "lines_coords": [[[467.0, 714.0], [490.0, 714.0], [489.0, 865.0], [465.0, 865.0]], [[435.0, 714.0], [457.0, 714.0], [457.0, 868.0], [435.0, 868.0]], [[396.0, 709.0], [428.0, 709.0], [431.0, 920.0], [400.0, 920.0]], [[370.0, 710.0], [396.0, 710.0], [396.0, 893.0], [370.0, 893.0]]], "lines": ["今日みたいに", "街を毎日毎日", "捜し回っているん", "ですね、僕ァ。」"]}, {"box": [564, 1007, 618, 1150], "vertical": true, "font_size": 24, "lines_coords": [[[589.0, 1007.0], [615.0, 1007.0], [618.0, 1150.0], [592.0, 1150.0]], [[564.0, 1009.0], [590.0, 1009.0], [590.0, 1109.0], [564.0, 1109.0]]], "lines": ["そんな効率の", "悪いこと、"]}, {"box": [789, 1368, 821, 1490], "vertical": true, "font_size": 28, "lines_coords": [[[789.0, 1370.0], [817.0, 1368.0], [821.0, 1489.0], [793.0, 1490.0]]], "lines": ["「．．．二年後"]}, {"box": [470, 1126, 550, 1300], "vertical": true, "font_size": 24, "lines_coords": [[[528.0, 1126.0], [550.0, 1126.0], [550.0, 1245.0], [528.0, 1245.0]], [[496.0, 1126.0], [520.0, 1126.0], [523.0, 1267.0], [500.0, 1267.0]], [[470.0, 1128.0], [492.0, 1128.0], [495.0, 1300.0], [473.0, 1300.0]]], "lines": ["いつまでも", "続ける訳には", "いかないっしょ。"]}, {"box": [629, 1370, 753, 1546], "vertical": true, "font_size": 28, "lines_coords": [[[731.0, 1371.0], [753.0, 1371.0], [753.0, 1546.0], [731.0, 1546.0]], [[696.0, 1370.0], [723.0, 1370.0], [723.0, 1500.0], [696.0, 1500.0]], [[664.0, 1370.0], [690.0, 1370.0], [690.0, 1525.0], [664.0, 1525.0]], [[629.0, 1370.0], [664.0, 1370.0], [664.0, 1467.0], [629.0, 1467.0]]], "lines": ["今のアハートの", "契約期間が", "終わるまでは", "一応。」"]}, {"box": [75, 1367, 154, 1508], "vertical": true, "font_size": 24, "lines_coords": [[[131.0, 1370.0], [153.0, 1370.0], [153.0, 1507.0], [131.0, 1507.0]], [[100.0, 1367.0], [128.0, 1367.0], [128.0, 1465.0], [100.0, 1465.0]], [[75.0, 1370.0], [96.0, 1370.0], [96.0, 1507.0], [75.0, 1507.0]]], "lines": ["．．．それまでに", "見つから", "なかったら？"]}]}