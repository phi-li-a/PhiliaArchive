{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [910, 92, 939, 175], "vertical": true, "font_size": 29, "lines_coords": [[[910.0, 92.0], [939.0, 92.0], [939.0, 175.0], [910.0, 175.0]]], "lines": ["．．．君さ、"]}, {"box": [146, 101, 255, 265], "vertical": true, "font_size": 22, "lines_coords": [[[231.0, 103.0], [253.0, 103.0], [253.0, 220.0], [231.0, 220.0]], [[203.0, 103.0], [225.0, 103.0], [225.0, 240.0], [203.0, 240.0]], [[175.0, 101.0], [196.0, 101.0], [196.0, 265.0], [175.0, 265.0]], [[146.0, 101.0], [168.0, 101.0], [168.0, 217.0], [146.0, 217.0]]], "lines": ["本当は内心", "その女の子に", "会いたくないん", "じゃない？"]}, {"box": [842, 384, 946, 548], "vertical": true, "font_size": 21, "lines_coords": [[[925.0, 384.0], [946.0, 384.0], [945.0, 525.0], [923.0, 525.0]], [[896.0, 385.0], [918.0, 385.0], [918.0, 548.0], [896.0, 548.0]], [[868.0, 385.0], [889.0, 385.0], [889.0, 525.0], [868.0, 525.0]], [[842.0, 385.0], [862.0, 385.0], [862.0, 509.0], [842.0, 509.0]]], "lines": ["君はその子に", "運命的な再会を", "期待してるん", "だろうけど、"]}, {"box": [739, 529, 817, 670], "vertical": true, "font_size": 21, "lines_coords": [[[796.0, 531.0], [817.0, 531.0], [817.0, 670.0], [796.0, 670.0]], [[767.0, 531.0], [789.0, 531.0], [789.0, 670.0], [767.0, 670.0]], [[739.0, 529.0], [760.0, 529.0], [760.0, 623.0], [739.0, 623.0]]], "lines": ["そんなもんに", "なんの意味が", "あるの？"]}, {"box": [256, 396, 304, 510], "vertical": true, "font_size": 21, "lines_coords": [[[282.0, 396.0], [304.0, 396.0], [304.0, 510.0], [282.0, 510.0]], [[256.0, 396.0], [278.0, 396.0], [278.0, 492.0], [256.0, 492.0]]], "lines": ["あたしには", "ただ単に"]}, {"box": [137, 492, 214, 700], "vertical": true, "font_size": 21, "lines_coords": [[[192.0, 492.0], [214.0, 492.0], [214.0, 700.0], [192.0, 700.0]], [[164.0, 495.0], [185.0, 495.0], [185.0, 656.0], [164.0, 656.0]], [[137.0, 493.0], [157.0, 493.0], [157.0, 687.0], [137.0, 687.0]]], "lines": ["結論を先送りにする", "言い逃れにしか", "思えないんだけど。"]}, {"box": [867, 775, 943, 960], "vertical": true, "font_size": 21, "lines_coords": [[[923.0, 776.0], [943.0, 776.0], [943.0, 951.0], [923.0, 951.0]], [[895.0, 775.0], [917.0, 775.0], [917.0, 960.0], [895.0, 960.0]], [[867.0, 775.0], [889.0, 775.0], [889.0, 870.0], [867.0, 870.0]]], "lines": ["あたしの予想だと", "君の言う二年後は", "もちろん"]}, {"box": [740, 882, 843, 1068], "vertical": true, "font_size": 21, "lines_coords": [[[821.0, 882.0], [843.0, 882.0], [843.0, 1023.0], [821.0, 1023.0]], [[793.0, 884.0], [815.0, 884.0], [815.0, 1000.0], [793.0, 1000.0]], [[765.0, 884.0], [787.0, 884.0], [787.0, 1068.0], [765.0, 1068.0]], [[740.0, 885.0], [757.0, 885.0], [757.0, 985.0], [740.0, 985.0]]], "lines": ["十年後も君は", "同じように", "言い訳を探してる", "と思うな。"]}, {"box": [293, 792, 343, 964], "vertical": true, "font_size": 22, "lines_coords": [[[321.0, 795.0], [343.0, 795.0], [343.0, 964.0], [321.0, 964.0]], [[293.0, 792.0], [314.0, 792.0], [314.0, 934.0], [293.0, 934.0]]], "lines": ["一見苦悩してる", "ように見せて、"]}, {"box": [121, 889, 256, 1092], "vertical": true, "font_size": 22, "lines_coords": [[[234.0, 893.0], [256.0, 893.0], [256.0, 1032.0], [234.0, 1032.0]], [[206.0, 893.0], [228.0, 893.0], [228.0, 1031.0], [206.0, 1031.0]], [[175.0, 889.0], [201.0, 889.0], [201.0, 1064.0], [175.0, 1064.0]], [[150.0, 892.0], [171.0, 892.0], [171.0, 1092.0], [150.0, 1092.0]], [[121.0, 893.0], [143.0, 893.0], [143.0, 1017.0], [121.0, 1017.0]]], "lines": ["実はなんにも", "考えてないし", "行動もできない、", "不毛な人生を送るん", "てしょうよ。"]}, {"box": [917, 1150, 967, 1312], "vertical": true, "font_size": 22, "lines_coords": [[[943.0, 1150.0], [967.0, 1150.0], [965.0, 1312.0], [942.0, 1312.0]], [[917.0, 1151.0], [939.0, 1151.0], [939.0, 1270.0], [917.0, 1270.0]]], "lines": ["．．．いや別に構わ", "ないけどね"]}, {"box": [812, 1290, 892, 1507], "vertical": true, "font_size": 22, "lines_coords": [[[870.0, 1290.0], [892.0, 1290.0], [892.0, 1434.0], [870.0, 1434.0]], [[842.0, 1290.0], [864.0, 1290.0], [864.0, 1507.0], [842.0, 1507.0]], [[812.0, 1290.0], [834.0, 1290.0], [834.0, 1462.0], [812.0, 1462.0]]], "lines": ["沢山いるもん", "そういう絶望ごっこで", "満たされてる人。"]}, {"box": [235, 1171, 314, 1340], "vertical": true, "font_size": 22, "lines_coords": [[[292.0, 1171.0], [314.0, 1171.0], [314.0, 1296.0], [292.0, 1296.0]], [[264.0, 1171.0], [285.0, 1171.0], [285.0, 1309.0], [264.0, 1309.0]], [[235.0, 1171.0], [256.0, 1171.0], [256.0, 1340.0], [235.0, 1340.0]]], "lines": ["．．．ても、君の", "その絶望って", "無駄だと思うよ。"]}, {"box": [101, 1318, 209, 1517], "vertical": true, "font_size": 22, "lines_coords": [[[187.0, 1318.0], [209.0, 1318.0], [209.0, 1517.0], [187.0, 1517.0]], [[159.0, 1321.0], [181.0, 1321.0], [181.0, 1509.0], [159.0, 1509.0]], [[129.0, 1320.0], [151.0, 1320.0], [151.0, 1507.0], [129.0, 1507.0]], [[101.0, 1320.0], [123.0, 1320.0], [123.0, 1515.0], [101.0, 1515.0]]], "lines": ["．．．なんでって、君は", "孤独を望んでいて、", "その絶望を誰とも", "共有できない訳で。"]}]}