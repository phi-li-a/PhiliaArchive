{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [940, 38, 992, 208], "vertical": true, "font_size": 22, "lines_coords": [[[967.0, 40.0], [990.0, 40.0], [992.0, 176.0], [968.0, 176.0]], [[940.0, 39.0], [960.0, 39.0], [960.0, 206.0], [940.0, 206.0]]], "lines": ["いいですなぁ", "恵まれてる人は。"]}, {"box": [704, 207, 789, 376], "vertical": true, "font_size": 28, "lines_coords": [[[753.0, 207.0], [789.0, 207.0], [789.0, 271.0], [753.0, 271.0]], [[729.0, 210.0], [756.0, 210.0], [753.0, 376.0], [726.0, 376.0]], [[704.0, 212.0], [726.0, 212.0], [726.0, 371.0], [704.0, 371.0]]], "lines": ["．．．あ、", "チャンネル変え", "ちゃっていいよ。"]}, {"box": [537, 90, 636, 272], "vertical": true, "font_size": 27, "lines_coords": [[[601.0, 90.0], [628.0, 90.0], [628.0, 257.0], [601.0, 257.0]], [[568.0, 92.0], [595.0, 92.0], [595.0, 271.0], [568.0, 271.0]], [[537.0, 92.0], [564.0, 92.0], [564.0, 246.0], [537.0, 246.0]]], "lines": ["「．．．南条さんて", "意外と親切な人", "なんですね。」"]}, {"box": [179, 207, 338, 390], "vertical": true, "font_size": 27, "lines_coords": [[[310.0, 210.0], [337.0, 210.0], [337.0, 353.0], [310.0, 353.0]], [[278.0, 209.0], [304.0, 209.0], [301.0, 342.0], [275.0, 342.0]], [[246.0, 207.0], [273.0, 207.0], [271.0, 390.0], [245.0, 390.0]], [[214.0, 209.0], [240.0, 209.0], [239.0, 390.0], [212.0, 390.0]], [[182.0, 209.0], [209.0, 209.0], [206.0, 326.0], [179.0, 326.0]]], "lines": ["「人に優しく", "できるのは、", "それだけ自分に", "自信があるから", "ですか？」"]}, {"box": [946, 437, 982, 498], "vertical": true, "font_size": 36, "lines_coords": [[[946.0, 437.0], [982.0, 437.0], [982.0, 498.0], [946.0, 498.0]]], "lines": ["ん？"]}, {"box": [485, 551, 518, 634], "vertical": true, "font_size": 33, "lines_coords": [[[485.0, 551.0], [518.0, 551.0], [518.0, 634.0], [485.0, 634.0]]], "lines": ["そお？"]}, {"box": [875, 729, 989, 915], "vertical": true, "font_size": 25, "lines_coords": [[[962.0, 731.0], [989.0, 731.0], [989.0, 826.0], [962.0, 826.0]], [[931.0, 729.0], [957.0, 729.0], [960.0, 881.0], [934.0, 881.0]], [[900.0, 729.0], [921.0, 729.0], [921.0, 915.0], [900.0, 915.0]], [[875.0, 731.0], [896.0, 731.0], [896.0, 825.0], [875.0, 825.0]]], "lines": ["おーい", "なんだよ、その", "捻くれた考え方は", "よー！！"]}, {"box": [818, 937, 900, 1082], "vertical": true, "font_size": 25, "lines_coords": [[[871.0, 942.0], [900.0, 942.0], [900.0, 1015.0], [871.0, 1015.0]], [[845.0, 937.0], [871.0, 937.0], [868.0, 1082.0], [842.0, 1082.0]], [[818.0, 943.0], [840.0, 943.0], [840.0, 1068.0], [818.0, 1068.0]]], "lines": ["つーか", "「意外と」とか", "余計だしな。"]}, {"box": [210, 882, 264, 1001], "vertical": true, "font_size": 23, "lines_coords": [[[234.0, 882.0], [260.0, 882.0], [264.0, 1001.0], [237.0, 1001.0]], [[210.0, 884.0], [232.0, 884.0], [232.0, 984.0], [210.0, 984.0]]], "lines": ["普通でしょ", "こんなん"]}, {"box": [121, 1062, 229, 1250], "vertical": true, "font_size": 23, "lines_coords": [[[207.0, 1064.0], [229.0, 1064.0], [229.0, 1181.0], [207.0, 1181.0]], [[179.0, 1062.0], [201.0, 1062.0], [201.0, 1246.0], [179.0, 1246.0]], [[150.0, 1062.0], [171.0, 1062.0], [173.0, 1250.0], [151.0, 1250.0]], [[121.0, 1062.0], [143.0, 1062.0], [145.0, 1235.0], [123.0, 1235.0]]], "lines": ["そりゃまあ", "人並みに誰からも", "好かれたいっつー", "打算はあるけど。"]}, {"box": [744, 1347, 769, 1528], "vertical": true, "font_size": 21, "lines_coords": [[[746.0, 1350.0], [767.0, 1350.0], [767.0, 1521.0], [746.0, 1521.0]]], "lines": ["「．．．すみません。"]}, {"box": [565, 1346, 625, 1477], "vertical": true, "font_size": 25, "lines_coords": [[[601.0, 1350.0], [623.0, 1350.0], [623.0, 1475.0], [601.0, 1475.0]], [[565.0, 1348.0], [593.0, 1348.0], [593.0, 1454.0], [565.0, 1454.0]]], "lines": ["人と話すの", "苦手で。」"]}, {"box": [329, 1347, 453, 1487], "vertical": true, "font_size": 27, "lines_coords": [[[425.0, 1348.0], [451.0, 1348.0], [451.0, 1476.0], [425.0, 1476.0]], [[393.0, 1348.0], [420.0, 1348.0], [420.0, 1476.0], [393.0, 1476.0]], [[362.0, 1348.0], [389.0, 1348.0], [389.0, 1476.0], [362.0, 1476.0]], [[329.0, 1348.0], [356.0, 1348.0], [356.0, 1485.0], [329.0, 1485.0]]], "lines": ["ブンブンは", "言わなきゃ", "良かったと", "思いました。"]}]}