{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [931, 67, 1010, 260], "vertical": true, "font_size": 22, "lines_coords": [[[987.0, 68.0], [1010.0, 68.0], [1007.0, 209.0], [984.0, 209.0]], [[959.0, 70.0], [981.0, 70.0], [981.0, 232.0], [959.0, 232.0]], [[931.0, 67.0], [953.0, 67.0], [953.0, 260.0], [931.0, 260.0]]], "lines": ["南条のことは", "小学生の頃から", "ずっと見てるけど、"]}, {"box": [801, 198, 909, 373], "vertical": true, "font_size": 22, "lines_coords": [[[887.0, 201.0], [909.0, 201.0], [909.0, 317.0], [887.0, 317.0]], [[859.0, 201.0], [881.0, 201.0], [881.0, 360.0], [859.0, 360.0]], [[831.0, 200.0], [853.0, 200.0], [853.0, 339.0], [831.0, 339.0]], [[803.0, 198.0], [826.0, 198.0], [825.0, 373.0], [801.0, 373.0]]], "lines": ["肌身離さず", "スケッチブック", "持ち歩いてる", "ような子供でさ。"]}, {"box": [128, 223, 239, 415], "vertical": true, "font_size": 25, "lines_coords": [[[212.0, 223.0], [239.0, 223.0], [239.0, 343.0], [212.0, 343.0]], [[185.0, 225.0], [207.0, 225.0], [207.0, 364.0], [185.0, 364.0]], [[156.0, 225.0], [182.0, 225.0], [182.0, 415.0], [156.0, 415.0]], [[128.0, 225.0], [154.0, 225.0], [154.0, 331.0], [128.0, 331.0]]], "lines": ["中高と絵で", "県知事賞とか", "バンバン取っちゃう", "カンジで。"]}, {"box": [857, 510, 993, 696], "vertical": true, "font_size": 23, "lines_coords": [[[971.0, 514.0], [993.0, 514.0], [993.0, 629.0], [971.0, 629.0]], [[942.0, 510.0], [964.0, 510.0], [964.0, 696.0], [942.0, 696.0]], [[915.0, 512.0], [935.0, 512.0], [935.0, 654.0], [915.0, 654.0]], [[885.0, 510.0], [906.0, 510.0], [906.0, 696.0], [885.0, 696.0]], [[859.0, 510.0], [881.0, 510.0], [879.0, 635.0], [857.0, 635.0]]], "lines": ["．．．完っ全に", "天才気取りだった", "からなー．．．", "実際才能はあった", "と思うけど"]}, {"box": [795, 740, 907, 940], "vertical": true, "font_size": 23, "lines_coords": [[[881.0, 740.0], [907.0, 740.0], [904.0, 882.0], [878.0, 882.0]], [[850.0, 742.0], [876.0, 742.0], [876.0, 940.0], [850.0, 940.0]], [[825.0, 740.0], [848.0, 740.0], [846.0, 906.0], [823.0, 906.0]], [[796.0, 740.0], [818.0, 740.0], [817.0, 935.0], [795.0, 935.0]]], "lines": ["要するに続か", "なかったんだよね。", "あっという間に", "枯渇したというか。"]}, {"box": [137, 882, 246, 1117], "vertical": true, "font_size": 23, "lines_coords": [[[223.0, 885.0], [245.0, 885.0], [245.0, 1048.0], [223.0, 1048.0]], [[193.0, 882.0], [215.0, 882.0], [215.0, 1068.0], [193.0, 1068.0]], [[164.0, 884.0], [190.0, 884.0], [189.0, 1117.0], [162.0, 1117.0]], [[137.0, 884.0], [159.0, 884.0], [159.0, 1078.0], [137.0, 1078.0]]], "lines": ["あたしと一緒に", "早稲田入ったけど", "色んなドタバタで結局", "中退しちゃったし。"]}, {"box": [867, 1212, 978, 1421], "vertical": true, "font_size": 24, "lines_coords": [[[951.0, 1212.0], [978.0, 1212.0], [978.0, 1310.0], [951.0, 1310.0]], [[923.0, 1214.0], [945.0, 1214.0], [945.0, 1421.0], [923.0, 1421.0]], [[895.0, 1214.0], [918.0, 1214.0], [917.0, 1376.0], [893.0, 1376.0]], [[867.0, 1212.0], [889.0, 1212.0], [889.0, 1357.0], [867.0, 1357.0]]], "lines": ["今でこそ", "趣味で絵本作るとか", "一線退いたこと", "言ってるけど、"]}, {"box": [956, 1507, 973, 1573], "vertical": true, "font_size": 17, "lines_coords": [[[956.0, 1507.0], [973.0, 1507.0], [973.0, 1573.0], [956.0, 1573.0]]], "lines": ["だからなんだ"]}, {"box": [776, 1375, 828, 1493], "vertical": true, "font_size": 24, "lines_coords": [[[801.0, 1375.0], [828.0, 1375.0], [828.0, 1473.0], [801.0, 1473.0]], [[776.0, 1376.0], [798.0, 1376.0], [798.0, 1493.0], [776.0, 1493.0]]], "lines": ["．．．本心は", "どうかな？"]}, {"box": [125, 1285, 262, 1500], "vertical": true, "font_size": 24, "lines_coords": [[[237.0, 1290.0], [259.0, 1290.0], [259.0, 1475.0], [237.0, 1475.0]], [[209.0, 1290.0], [231.0, 1290.0], [231.0, 1451.0], [209.0, 1451.0]], [[179.0, 1287.0], [206.0, 1287.0], [203.0, 1453.0], [176.0, 1453.0]], [[151.0, 1285.0], [178.0, 1285.0], [176.0, 1500.0], [150.0, 1500.0]], [[126.0, 1287.0], [148.0, 1287.0], [146.0, 1442.0], [125.0, 1442.0]]], "lines": ["あたしはそろそろ", "アイツの迷走に", "とどめを刺して", "やったほうがいいと", "思ってんのね。"]}]}