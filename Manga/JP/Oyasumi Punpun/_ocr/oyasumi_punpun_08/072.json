{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [898, 46, 979, 220], "vertical": true, "font_size": 23, "lines_coords": [[[950.0, 46.0], [978.0, 46.0], [979.0, 143.0], [951.0, 143.0]], [[926.0, 48.0], [948.0, 48.0], [948.0, 207.0], [926.0, 207.0]], [[898.0, 46.0], [918.0, 46.0], [918.0, 215.0], [898.0, 215.0]]], "lines": ["蟹江こそ", "すっかり社畜に", "なり下がったな。"]}, {"box": [729, 204, 843, 406], "vertical": true, "font_size": 28, "lines_coords": [[[812.0, 204.0], [840.0, 204.0], [843.0, 353.0], [815.0, 353.0]], [[784.0, 204.0], [810.0, 204.0], [814.0, 370.0], [787.0, 370.0]], [[756.0, 204.0], [787.0, 204.0], [787.0, 406.0], [756.0, 406.0]], [[729.0, 204.0], [756.0, 204.0], [757.0, 403.0], [731.0, 403.0]]], "lines": ["．．．なんだよォ、", "クソ忙しい時間", "縫って久々会いに", "来てやったのにィ。"]}, {"box": [615, 59, 645, 137], "vertical": true, "font_size": 30, "lines_coords": [[[615.0, 62.0], [645.0, 62.0], [645.0, 137.0], [615.0, 137.0]]], "lines": ["．．．んで、"]}, {"box": [192, 45, 270, 207], "vertical": true, "font_size": 24, "lines_coords": [[[248.0, 48.0], [270.0, 48.0], [270.0, 162.0], [248.0, 162.0]], [[220.0, 46.0], [242.0, 46.0], [242.0, 207.0], [220.0, 207.0]], [[192.0, 45.0], [214.0, 45.0], [214.0, 207.0], [192.0, 207.0]]], "lines": ["磨けば光る", "原石君の調子は", "どうだったの？"]}, {"box": [98, 200, 179, 365], "vertical": true, "font_size": 24, "lines_coords": [[[153.0, 200.0], [176.0, 200.0], [179.0, 342.0], [156.0, 342.0]], [[126.0, 200.0], [153.0, 200.0], [153.0, 365.0], [126.0, 365.0]], [[98.0, 200.0], [126.0, 200.0], [126.0, 273.0], [98.0, 273.0]]], "lines": ["アンタの目に", "狂いはなかった", "ワケ？"]}, {"box": [939, 593, 965, 760], "vertical": true, "font_size": 23, "lines_coords": [[[939.0, 593.0], [965.0, 593.0], [965.0, 760.0], [939.0, 760.0]]], "lines": ["．．．小野寺くん。"]}, {"box": [200, 718, 290, 875], "vertical": true, "font_size": 25, "lines_coords": [[[264.0, 720.0], [290.0, 720.0], [290.0, 875.0], [264.0, 875.0]], [[237.0, 721.0], [259.0, 721.0], [259.0, 848.0], [237.0, 848.0]], [[203.0, 718.0], [229.0, 718.0], [226.0, 859.0], [200.0, 859.0]]], "lines": ["恥ずかしがる", "ことなんて", "ないんだよ。"]}, {"box": [798, 754, 906, 931], "vertical": true, "font_size": 23, "lines_coords": [[[884.0, 757.0], [906.0, 757.0], [906.0, 873.0], [884.0, 873.0]], [[851.0, 754.0], [875.0, 754.0], [878.0, 873.0], [854.0, 873.0]], [[825.0, 756.0], [846.0, 756.0], [846.0, 931.0], [825.0, 931.0]], [[798.0, 756.0], [818.0, 756.0], [818.0, 881.0], [798.0, 881.0]]], "lines": ["話を戻すと", "君はもっと", "いいものが書ける", "と思うんだ。"]}, {"box": [107, 935, 232, 1092], "vertical": true, "font_size": 25, "lines_coords": [[[206.0, 935.0], [232.0, 935.0], [232.0, 1067.0], [206.0, 1067.0]], [[176.0, 937.0], [198.0, 937.0], [198.0, 1090.0], [176.0, 1090.0]], [[139.0, 935.0], [165.0, 935.0], [168.0, 1092.0], [142.0, 1092.0]], [[107.0, 937.0], [137.0, 937.0], [139.0, 1028.0], [109.0, 1028.0]]], "lines": ["昔みたいに", "思ったままに", "素直に書きや", "いいの。"]}, {"box": [293, 1225, 320, 1343], "vertical": true, "font_size": 29, "lines_coords": [[[293.0, 1225.0], [320.0, 1225.0], [320.0, 1343.0], [293.0, 1343.0]]], "lines": ["．．．どう？"]}, {"box": [156, 1346, 226, 1512], "vertical": true, "font_size": 29, "lines_coords": [[[190.0, 1346.0], [223.0, 1346.0], [226.0, 1512.0], [193.0, 1512.0]], [[156.0, 1351.0], [184.0, 1351.0], [184.0, 1503.0], [156.0, 1503.0]]], "lines": ["書き直す気、", "．．．．．ある？"]}]}