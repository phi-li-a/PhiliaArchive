{"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [929, 39, 954, 162], "vertical": true, "font_size": 22, "lines_coords": [[[929.0, 43.0], [951.0, 43.0], [951.0, 157.0], [929.0, 157.0]]], "lines": ["．．．ところで"]}, {"box": [703, 39, 775, 220], "vertical": true, "font_size": 20, "lines_coords": [[[753.0, 39.0], [773.0, 39.0], [773.0, 220.0], [753.0, 220.0]], [[728.0, 39.0], [748.0, 39.0], [748.0, 178.0], [728.0, 178.0]], [[703.0, 40.0], [723.0, 40.0], [723.0, 192.0], [703.0, 192.0]]], "lines": ["南条の子供の頃の", "本当の夢って、", "なんだと思う？"]}, {"box": [576, 93, 603, 207], "vertical": true, "font_size": 27, "lines_coords": [[[576.0, 93.0], [603.0, 93.0], [603.0, 207.0], [576.0, 207.0]]], "lines": ["．．．漫画家。"]}, {"box": [90, 143, 227, 307], "vertical": true, "font_size": 22, "lines_coords": [[[203.0, 146.0], [225.0, 146.0], [225.0, 306.0], [203.0, 306.0]], [[173.0, 145.0], [196.0, 145.0], [198.0, 292.0], [175.0, 292.0]], [[146.0, 146.0], [168.0, 146.0], [168.0, 284.0], [146.0, 284.0]], [[118.0, 146.0], [140.0, 146.0], [140.0, 306.0], [118.0, 306.0]], [[92.0, 143.0], [114.0, 143.0], [112.0, 292.0], [90.0, 292.0]]], "lines": ["大学ん時は本腰", "入れてたけど、", "連載直前まで", "行って結局流れ", "ちゃったから。"]}, {"box": [890, 640, 965, 778], "vertical": true, "font_size": 20, "lines_coords": [[[948.0, 642.0], [965.0, 642.0], [965.0, 756.0], [948.0, 756.0]], [[917.0, 642.0], [939.0, 642.0], [939.0, 778.0], [917.0, 778.0]], [[890.0, 640.0], [912.0, 640.0], [912.0, 765.0], [890.0, 765.0]]], "lines": ["．．．アイツは", "話が作れない", "みたいでね。"]}, {"box": [109, 407, 223, 569], "vertical": true, "font_size": 26, "lines_coords": [[[196.0, 409.0], [223.0, 409.0], [223.0, 503.0], [196.0, 503.0]], [[168.0, 409.0], [196.0, 409.0], [196.0, 503.0], [168.0, 503.0]], [[142.0, 410.0], [164.0, 410.0], [164.0, 568.0], [142.0, 568.0]], [[109.0, 409.0], [137.0, 407.0], [140.0, 490.0], [112.0, 492.0]]], "lines": ["挫折感が", "強すぎて", "封印するつもり", "らしい。"]}, {"box": [815, 768, 864, 953], "vertical": true, "font_size": 20, "lines_coords": [[[843.0, 771.0], [864.0, 771.0], [864.0, 953.0], [843.0, 953.0]], [[815.0, 768.0], [835.0, 768.0], [835.0, 934.0], [815.0, 934.0]]], "lines": ["一時期は熱っぽく", "語ってたけどさ。"]}, {"box": [145, 962, 260, 1178], "vertical": true, "font_size": 37, "lines_coords": [[[228.0, 962.0], [259.0, 962.0], [256.0, 1148.0], [225.0, 1148.0]], [[190.0, 964.0], [223.0, 964.0], [220.0, 1178.0], [187.0, 1178.0]], [[145.0, 962.0], [192.0, 962.0], [192.0, 1046.0], [145.0, 1046.0]]], "lines": ["漫画で世界を", "ぶっ壊してやる", "って。"]}]}