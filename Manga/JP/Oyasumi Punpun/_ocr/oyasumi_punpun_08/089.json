 984.0]], [[751.0, 865.0], [778.0, 865.0], [778.0, 1007.0], [751.0, 1007.0]], [[721.0, 864.0], [750.0, 864.0], [750.0, 939.0], [721.0, 939.0]]], "lines": ["若い奴らは", "口ばかり達者", "て．．．"]}, {"box": [915, 1082, 993, 1268], "vertical": true, "font_size": 20, "lines_coords": [[[971.0, 1082.0], [993.0, 1082.0], [992.0, 1223.0], [970.0, 1223.0]], [[943.0, 1084.0], [965.0, 1084.0], [965.0, 1246.0], [943.0, 1246.0]], [[915.0, 1084.0], [935.0, 1084.0], [935.0, 1268.0], [915.0, 1268.0]]], "lines": ["．．．どうせ実際", "行き詰まったら", "こう言うんだろ？"]}, {"box": [253, 1120, 306, 1259], "vertical": true, "font_size": 23, "lines_coords": [[[276.0, 1120.0], [304.0, 1120.0], [306.0, 1217.0], [278.0, 1217.0]], [[253.0, 1125.0], [275.0, 1125.0], [275.0, 1259.0], [253.0, 1259.0]]], "lines": ["そうじゃ", "ねーだろ．．．"]}, {"box": [740, 1210, 870, 1376], "vertical": true, "font_size": 20, "lines_coords": [[[853.0, 1214.0], [870.0, 1214.0], [870.0, 1325.0], [853.0, 1325.0]], [[821.0, 1210.0], [843.0, 1210.0], [843.0, 1376.0], [821.0, 1376.0]], [[792.0, 1212.0], [814.0, 1212.0], [814.0, 1375.0], [792.0, 1375.0]], [[765.0, 1212.0], [787.0, 1212.0], [787.0, 1351.0], [765.0, 1351.0]], [[740.0, 1212.0], [757.0, 1212.0], [757.0, 1326.0], [740.0, 1326.0]]], "lines": ["雇用政策に", "問題があるとか、", "時代が悪いとか", "働いたら負け", "だとか．．．．．"]}, {"box": [110, 1309, 246, 1471], "vertical": true, "font_size": 23, "lines_coords": [[[225.0, 1310.0], [246.0, 1310.0], [246.0, 1471.0], [225.0, 1471.0]], [[196.0, 1312.0], [218.0, 1312.0], [218.0, 1471.0], [196.0, 1471.0]], [[167.0, 1309.0], [190.0, 1309.0], [189.0, 1460.0], [165.0, 1460.0]], [[140.0, 1312.0], [162.0, 1312.0], [162.0, 1448.0], [140.0, 1448.0]], [[112.0, 1312.0], [134.0, 1312.0], [132.0, 1471.0], [110.0, 1471.0]]], "lines": ["昔の人間だって", "理不尽な社会で", "闘っては、一敗", "地にまみれて", "いったんだよ．．．"]}]}