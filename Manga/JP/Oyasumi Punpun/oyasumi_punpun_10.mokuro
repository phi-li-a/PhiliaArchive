8.0], [227.0, 1088.0]]], "lines": ["ひとりは", "さみしい。"]}, {"box": [1155, 1357, 1192, 1654], "vertical": true, "font_size": 35, "lines_coords": [[[1155.0, 1360.0], [1190.0, 1360.0], [1190.0, 1650.0], [1155.0, 1650.0]]], "lines": ["「．．．さっちゃんは。」"]}, {"box": [304, 1359, 337, 1662], "vertical": true, "font_size": 29, "lines_coords": [[[304.0, 1362.0], [333.0, 1362.0], [333.0, 1645.0], [304.0, 1645.0]]], "lines": ["一前の旦那さんと僕"]}, {"box": [207, 1353, 265, 1712], "vertical": true, "font_size": 35, "lines_coords": [[[211.0, 1353.0], [246.0, 1353.0], [242.0, 1710.0], [207.0, 1710.0]]], "lines": ["どっちが大切ですか？」"]}, {"box": [543, 1828, 580, 1928], "vertical": true, "font_size": 37, "lines_coords": [[[543.0, 1828.0], [580.0, 1828.0], [580.0, 1928.0], [543.0, 1928.0]]], "lines": ["．．．ん。"]}], "img_path": "122.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [623, 115, 703, 321], "vertical": true, "font_size": 35, "lines_coords": [[[666.0, 118.0], [701.0, 118.0], [701.0, 318.0], [666.0, 318.0]], [[623.0, 115.0], [658.0, 115.0], [658.0, 262.0], [623.0, 262.0]]], "lines": ["．．．どっちって", "答えれば、"]}, {"box": [190, 341, 273, 548], "vertical": true, "font_size": 42, "lines_coords": [[[225.0, 341.0], [273.0, 341.0], [273.0, 420.0], [225.0, 420.0]], [[190.0, 343.0], [225.0, 343.0], [225.0, 544.0], [190.0, 544.0]]], "lines": ["君は", "嬉しいの．．．？"]}, {"box": [703, 1002, 832, 1242], "vertical": true, "font_size": 38, "lines_coords": [[[797.0, 1006.0], [832.0, 1006.0], [832.0, 1242.0], [797.0, 1242.0]], [[757.0, 1006.0], [786.0, 1006.0], [786.0, 1206.0], [757.0, 1206.0]], [[703.0, 1002.0], [753.0, 1002.0], [753.0, 1088.0], [703.0, 1088.0]]], "lines": ["．．．よりによって", "言わなくても", "いい、"]}, {"box": [612, 1006, 650, 1117], "vertical": true, "font_size": 38, "lines_coords": [[[612.0, 1006.0], [650.0, 1006.0], [650.0, 1117.0], [612.0, 1117.0]]], "lines": ["最低で、"]}, {"box": [520, 1005, 554, 1218], "vertical": true, "font_size": 29, "lines_coords": [[[521.0, 1010.0], [550.0, 1010.0], [550.0, 1211.0], [521.0, 1211.0]]], "lines": ["余計な一言が"]}, {"box": [264, 1672, 297, 1855], "vertical": true, "font_size": 29, "lines_coords": [[[264.0, 1672.0], [293.0, 1672.0], [293.0, 1855.0], [264.0, 1855.0]]], "lines": ["．．．あたしは。"]}], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1128, 120, 1166, 290], "vertical": true, "font_size": 35, "lines_coords": [[[1128.0, 120.0], [1163.0, 120.0], [1163.0, 289.0], [1128.0, 289.0]]], "lines": ["プンプンが"]}, {"box": [240, 879, 280, 1028], "vertical": true, "font_size": 35, "lines_coords": [[[240.0, 879.0], [275.0, 879.0], [275.0, 1028.0], [240.0, 1028.0]]], "lines": ["大切だよ。"]}, {"box": [1194, 1217, 1258, 1426], "vertical": true, "font_size": 30, "lines_coords": [[[1229.0, 1217.0], [1258.0, 1217.0], [1258.0, 1426.0], [1229.0, 1426.0]], [[1194.0, 1217.0], [1223.0, 1217.0], [1223.0, 1380.0], [1194.0, 1380.0]]], "lines": ["あたしの勝手な", "都合だけど、"]}, {"box": [1010, 1378, 1115, 1633], "vertical": true, "font_size": 30, "lines_coords": [[[1080.0, 1378.0], [1115.0, 1378.0], [1115.0, 1532.0], [1080.0, 1532.0]], [[1047.0, 1380.0], [1076.0, 1380.0], [1076.0, 1527.0], [1047.0, 1527.0]], [[1010.0, 1378.0], [1039.0, 1378.0], [1039.0, 1633.0], [1010.0, 1633.0]]], "lines": ["プンプンが", "いないのは", "考えられないんだ。"]}, {"box": [198, 1681, 316, 1964], "vertical": true, "font_size": 34, "lines_coords": [[[279.0, 1681.0], [316.0, 1681.0], [316.0, 1817.0], [279.0, 1817.0]], [[238.0, 1681.0], [273.0, 1681.0], [273.0, 1850.0], [238.0, 1850.0]], [[198.0, 1685.0], [227.0, 1685.0], [227.0, 1962.0], [198.0, 1962.0]]], "lines": ["あたしは", "君のせいで", "お人好しになった。"]}], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [935, 103, 1016, 244], "vertical": true, "font_size": 34, "lines_coords": [[[972.0, 103.0], [1016.0, 103.0], [1016.0, 233.0], [972.0, 233.0]], [[935.0, 103.0], [979.0, 103.0], [979.0, 244.0], [935.0, 244.0]]], "lines": ["．．．ずっと", "迷ってた。"]}, {"box": [1148, 320, 1268, 674], "vertical": true, "font_size": 32, "lines_coords": [[[1235.0, 322.0], [1264.0, 322.0], [1264.0, 594.0], [1235.0, 594.0]], [[1190.0, 320.0], [1225.0, 320.0], [1225.0, 592.0], [1190.0, 592.0]], [[1148.0, 322.0], [1180.0, 322.0], [1182.0, 670.0], [1151.0, 670.0]]], "lines": ["．．．余計なひと言が", "彼女の弱った心を", "さらに切り刻んでゆく。"]}, {"box": [732, 182, 873, 370], "vertical": true, "font_size": 34, "lines_coords": [[[842.0, 182.0], [873.0, 182.0], [873.0, 281.0], [842.0, 281.0]], [[807.0, 186.0], [836.0, 186.0], [836.0, 308.0], [807.0, 308.0]], [[770.0, 186.0], [799.0, 186.0], [799.0, 370.0], [770.0, 370.0]], [[732.0, 184.0], [761.0, 184.0], [761.0, 366.0], [732.0, 366.0]]], "lines": ["こんな", "身勝手が", "許されるのか", "なって．．．．．．"]}, {"box": [240, 498, 380, 712], "vertical": true, "font_size": 30, "lines_coords": [[[351.0, 498.0], [380.0, 498.0], [380.0, 652.0], [351.0, 652.0]], [[314.0, 501.0], [343.0, 501.0], [343.0, 712.0], [314.0, 712.0]], [[277.0, 501.0], [306.0, 501.0], [306.0, 685.0], [277.0, 685.0]], [[240.0, 501.0], [269.0, 501.0], [269.0, 689.0], [240.0, 689.0]]], "lines": ["早乙女には", "伝えるつもりも", "会うつもりも", "もうないけど、"]}, {"box": [167, 755, 275, 999], "vertical": true, "font_size": 30, "lines_coords": [[[240.0, 755.0], [275.0, 755.0], [275.0, 884.0], [240.0, 884.0]], [[204.0, 757.0], [233.0, 757.0], [233.0, 999.0], [204.0, 999.0]], [[167.0, 757.0], [196.0, 757.0], [196.0, 968.0], [167.0, 968.0]]], "lines": ["正直もう", "どうすればいいか", "わからない．．．"]}, {"box": [1246, 1450, 1283, 1589], "vertical": true, "font_size": 37, "lines_coords": [[[1246.0, 1451.0], [1283.0, 1451.0], [1283.0, 1583.0], [1246.0, 1583.0]]], "lines": ["もし．．．"]}, {"box": [629, 1109, 863, 1315], "vertical": true, "font_size": 35, "lines_coords": [[[826.0, 1113.0], [863.0, 1113.0], [863.0, 1248.0], [826.0, 1248.0]], [[788.0, 1113.0], [817.0, 1113.0], [817.0, 1279.0], [788.0, 1279.0]], [[714.0, 1109.0], [749.0, 1109.0], [753.0, 1283.0], [718.0, 1283.0]], [[679.0, 1113.0], [708.0, 1113.0], [708.0, 1312.