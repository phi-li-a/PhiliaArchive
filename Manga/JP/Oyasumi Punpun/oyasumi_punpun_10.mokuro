, 1685.0], [1068.0, 1811.0], [1033.0, 1811.0]], [[997.0, 1687.0], [1030.0, 1687.0], [1026.0, 1869.0], [993.0, 1869.0]], [[962.0, 1687.0], [991.0, 1687.0], [991.0, 1898.0], [962.0, 1898.0]], [[927.0, 1687.0], [954.0, 1687.0], [954.0, 1925.0], [927.0, 1925.0]]], "lines": ["歩けなく", "なってからは", "あたしが支えて", "あげなきゃって．．．"]}, {"box": [343, 1571, 449, 1753], "vertical": true, "font_size": 30, "lines_coords": [[[420.0, 1573.0], [449.0, 1573.0], [449.0, 1724.0], [420.0, 1724.0]], [[382.0, 1573.0], [411.0, 1573.0], [411.0, 1753.0], [382.0, 1753.0]], [[343.0, 1571.0], [372.0, 1571.0], [372.0, 1730.0], [343.0, 1730.0]]], "lines": ["．．．毎日毎日", "怒鳴られても", "叩かれても、"]}, {"box": [124, 1701, 260, 1941], "vertical": true, "font_size": 30, "lines_coords": [[[233.0, 1703.0], [260.0, 1703.0], [260.0, 1941.0], [233.0, 1941.0]], [[196.0, 1703.0], [225.0, 1703.0], [225.0, 1886.0], [196.0, 1886.0]], [[157.0, 1701.0], [192.0, 1701.0], [192.0, 1917.0], [157.0, 1917.0]], [[124.0, 1705.0], [153.0, 1705.0], [153.0, 1836.0], [124.0, 1836.0]]], "lines": ["それでお母さんの", "気が済むなら", "それでいいって", "思ってた。"]}], "img_path": "208.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1233, 80, 1310, 277], "vertical": true, "font_size": 36, "lines_coords": [[[1264.0, 80.0], [1310.0, 80.0], [1310.0, 167.0], [1264.0, 167.0]], [[1233.0, 86.0], [1262.0, 86.0], [1262.0, 277.0], [1233.0, 277.0]]], "lines": ["でも、", "もしかしたら、"]}, {"box": [1018, 186, 1163, 405], "vertical": true, "font_size": 36, "lines_coords": [[[1124.0, 186.0], [1163.0, 186.0], [1163.0, 285.0], [1124.0, 285.0]], [[1088.0, 188.0], [1124.0, 188.0], [1124.0, 405.0], [1088.0, 405.0]], [[1051.0, 188.0], [1086.0, 188.0], [1086.0, 403.0], [1051.0, 403.0]], [[1018.0, 188.0], [1047.0, 188.0], [1047.0, 387.0], [1018.0, 387.0]]], "lines": ["それは", "お互いのために", "良くないんじゃ", "ないか、って．．．"]}, {"box": [358, 103, 474, 233], "vertical": true, "font_size": 36, "lines_coords": [[[438.0, 105.0], [474.0, 105.0], [474.0, 231.0], [438.0, 231.0]], [[397.0, 103.0], [432.0, 103.0], [436.0, 233.0], [401.0, 233.0]], [[358.0, 103.0], [405.0, 103.0], [405.0, 188.0], [358.0, 188.0]]], "lines": ["あたしが", "このまま", "一生、"]}, {"box": [167, 182, 312, 399], "vertical": true, "font_size": 36, "lines_coords": [[[277.0, 182.0], [312.0, 182.0], [312.0, 372.0], [277.0, 372.0]], [[240.0, 184.0], [275.0, 184.0], [275.0, 399.0], [240.0, 399.0]], [[200.0, 182.0], [236.0, 182.0], [240.0, 339.0], [204.0, 339.0]], [[167.0, 182.0], [196.0, 182.0], [196.0, 335.0], [167.0, 335.0]]], "lines": ["あの暗い家で", "ただ年を取って", "いくんだと", "したら．．．"]}, {"box": [676, 813, 747, 981], "vertical": true, "font_size": 36, "lines_coords": [[[712.0, 813.0], [747.0, 813.0], [747.0, 970.0], [712.0, 970.0]], [[676.0, 815.0], [712.0, 815.0], [712.0, 981.0], [676.0, 981.0]]], "lines": ["思うように", "なってきた。"]}, {"box": [1198, 1138, 1308, 1327], "vertical": true, "font_size": 34, "lines_coords": [[[1264.0, 1140.0], [1302.0, 1140.0], [1308.0, 1327.0], [1271.0, 1327.0]], [[1229.0, 1138.0], [1264.0, 1138.0], [1269.0, 1325.0], [1233.0, 1325.0]], [[1198.0, 1142.0], [1227.0, 1142.0], [1227.0, 1293.0], [1198.0, 1293.0]]], "lines": ["いつかきっと", "そう遠くない", "うちに．．．"]}, {"box": [198, 1223, 378, 1467], "vertical": true, "font_size": 30, "lines_coords": [[[343.0, 1223.0], [378.0, 1223.0], [378.0, 1380.0], [343.0, 1380.0]], [[308.0, 1227.0], [337.0, 1227.0], [337.0, 1378.0], [308.0, 1378.0]], [[271.0, 1227.0], [300.0, 1227.0], [300.0, 1407.0], [271.0, 1407.0]], [[231.0, 1225.0], [262.0, 1225.0], [264.0, 1467.0], [233.0, 1467.0]], [[198.0, 1227.0], [225.0, 1227.0], [225.0, 1407.0], [198.0, 1407.0]]], "lines": ["自分が誰で", "何のために", "生きてるのか", "わからなくなって", "しまいそう．．．"]}, {"box": [1206, 1565, 1289, 1769], "vertical": true, "font_size": 42, "lines_coords": [[[1242.0, 1567.0], [1289.0, 1567.0], [1289.0, 1674.0], [1242.0, 1674.0]], [[1206.0, 1565.0], [1242.0, 1565.0], [1242.0, 1768.0], [1206.0, 1768.0]]], "lines": ["おねー", "ちゃーん！！"]}, {"box": [146, 1828, 267, 1968], "vertical": true, "font_size": 40, "lines_coords": [[[223.0, 1830.0], [267.0, 1830.0], [267.0, 1968.0], [223.0, 1968.0]], [[182.0, 1828.0], [225.0, 1828.0], [225.0, 1937.0], [182.0, 1937.0]], [[146.0, 1832.0], [180.0, 1832.0], [180.0, 1937.0], [146.0, 1937.0]]], "lines": ["ホイホイ", "こっち", "ぞなー"]}], "img_path": "209.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1229, 173, 1335, 370], "vertical": true, "font_size": 30, "lines_coords": [[[1300.0, 175.0], [1335.0, 175.0], [1335.0, 302.0], [1300.0, 302.0]], [[1264.0, 175.0], [1293.0, 175.0], [1293.0, 329.0], [1264.0, 329.0]], [[1229.0, 173.0], [1258.0, 173.0], [1260.0, 370.0], [1231.0, 370.0]]], "lines": ["．．．あたし", "合コン苦手", "なんだけどー、"]}, {"box": [1111, 385, 1217, 601], "vertical": true, "font_size": 106, "lines_coords": [[[1111.0, 385.0], [1217.0, 385.0], [1217.0, 601.0], [1111.0, 601.0]]], "lines": ["お姉ちゃんの会社の後輩役でいいのね？"]}, {"box": [1109, 385, 1215, 600], "vertical": true, "font_size": 30, "lines_coords": [[[1186.0, 389.0], [1215.0, 389.0], [1215.0, 571.0], [1186.0, 571.0]], [[1148.0, 387.0], [1177.0, 387.0], [1177.0, 600.0], [1148.0, 600.0]], [[1113.0, 385.0], [1142.0, 385.0], [1138.0, 538.0], [1109.0, 538.0]]], "lines": ["お姉ちゃんの", "会社の後輩役で", "いいのね？"]}, {"box": [204, 291, 326, 633], "vertical": true, "font_size": 33, "lines_coords": [[[293.0, 293.0], [322.0, 293.0], [320.0, 519.0], [291.0, 519.0]], [[248.0, 293.0], [283.0, 293.0], [283.0, 633.0], [248.0, 633.0]], [[204.0, 293.0], [240.0, 293.0], [240.0, 567.0], [204.0, 567.0]]], "lines": ["「：愛子ちゃん", "今、僕はずっと考えて", "いたのだけれど。」"]}, {"box": [592, 478, 695, 674], "vertical": true, "font_size": 33, "lines_coords": [[[666.0, 480.0], [695.0, 480.0], [695.0, 674.0], [666.0, 674.0]], [[627.0, 478.0], [662.0, 478.0], [662.0, 604.0], [627.0, 604.0]], [[592.0, 478.0], [621.0, 478.0], [621.0, 660.0], [592.0, 660.0]]], "lines": ["あともちろん", "アタシは", "未婚設定で！！"]}, {"box": [453, 745, 635, 989], "vertical": true, "font_size": 33, "lines_coords": [[[600.0, 747.0], [635.0, 747.0], [635.0, 933.0], [600.0, 933.0]], [[565.0, 745.0], [600.0, 745.0], [600.0, 904.0], [565.0, 904.0]], [[527.0, 747.0], [563.0, 747.0], [563.0, 966.0], [527.0, 966.0]], [[492.0, 745.0], [521.0, 745.0], [521.0, 989.0], [492.0, 989.0]], [[453.0, 745.0], [488.0, 745.0], [488.0, 886.0], [453.0, 886.0]]], "lines": ["５ｋｇやせた後", "７ｋｇ太った", "アタシの底力で", "男達を真っ二つに", "してやる。"]}, {"box": [1026, 1577, 1211, 1850], "vertical": true, "font_size": 36, "lines_coords": [[[1173.0, 1579.0], [1211.0, 1579.0], [1206.0, 1763.0], [1169.0, 1763.0]], [[1113.0, 1581.0], [1148.0, 1581.0], [1148.0, 1749.0], [1113.0, 1749.0]], [[1072.0, 1579.0], [1109.0, 1579.0], [1103.0, 1782.0], [1066.0, 1782.0]], [[1030.0, 1577.0], [1066.0, 1577.0], [1062.0, 1846.0], [1026.0, 1846.0]]], "lines": ["「近々、僕は", "遠くの街に", "引っ越そうと", "思っていたんだ。」"]}, {"box": [513, 1819, 768, 2057], "vertical": true, "font_size": 36, "lines_coords": [[[724.0, 1821.0], [768.0, 1821.0], [768.0, 1946.0], [724.0, 1946.0]], [[683.0, 1821.0], [720.0, 1821.0], [720.0, 1958.0], [683.0, 1958.0]], [[641.0, 1821.0], [676.0, 1821.0], [676.0, 1958.0], [641.0, 1958.0]], [[602.0, 1823.0], [631.0, 1823.0], [631.0, 2053.0], [602.0, 2053.0]], [[558.0, 1819.0], [594.0, 1819.0], [594.0, 2022.0], [558.0, 2022.0]], [[513.0, 1821.0], [548.0, 1821.0], [548.0, 1960.0], [513.0, 1960.0]]], "lines": ["「色々と", "身辺整理", "してから", "ここを出ようと", "思っていたの", "だけれど"]}, {"box": [287, 1815, 416, 2024], "vertical": true, "font_size": 40, "lines_coords": [[[370.0, 1815.0], [416.0, 1815.0], [416.0, 1906.0], [370.0, 1906.0]], [[333.0, 1819.0], [368.0, 1819.0], [368.0, 1989.0], [333.0, 1989.0]], [[291.0, 1819.0], [329.0, 1819.0], [325.0, 2022.0], [287.0, 2022.0]]], "lines": ["もう、", "その必要は", "なくなった。」"]}], "img_path": "210.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [865, 142, 937, 482], "vertical": true, "font_size": 30, "lines_coords": [[[908.0, 144.0], [937.0, 144.0], [937.0, 426.0], [908.0, 426.0]], [[865.0, 142.0], [894.0, 142.0], [894.0, 482.0], [865.0, 482.0]]], "lines": ["「免許を取るまでは", "ここを動けないけれど"]}, {"box": [728, 140, 803, 513], "vertical": true, "font_size": 30, "lines_coords": [[[774.0, 140.0], [803.0, 140.0], [803.0, 447.0], [774.0, 447.0]], [[730.0, 140.0], [761.0, 140.0], [759.0, 513.0], [728.0, 513.0]]], "lines": ["それまでこの部屋に", "居てくれても構わない。」"]}, {"box": [409, 289, 438, 616], "vertical": true, "font_size": 32, "lines_coords": [[[409.0, 289.0], [438.0, 289.0], [438.0, 616.0], [409.0, 616.0]]], "lines": ["「どこか遠いところで、"]}, {"box": [302, 285, 337, 558], "vertical": true, "font_size": 32, "lines_coords": [[[302.0, 285.0], [337.0, 285.0], [337.0, 558.0], [302.0, 558.0]]], "lines": ["二人で暮らそう。」"]}, {"box": [964, 1409, 1028, 1563], "vertical": true, "font_size": 60, "lines_coords": [[[964.0, 1411.0], [1024.0, 1409.0], [1028.0, 1561.0], [968.0, 1563.0]]], "lines": ["た、い、"]}, {"box": [240, 997, 283, 1138], "vertical": true, "font_size": 43, "lines_coords": [[[240.0, 997.0], [283.0, 997.0], [283.0, 1138.0], [240.0, 1138.0]]], "lines": ["いいの？"]}, {"box": [1211, 1467, 1290, 1743], "vertical": true, "font_size": 35, "lines_coords": [[[1254.0, 1467.0], [1289.0, 1467.0], [1285.0, 1627.0], [1250.0, 1627.0]], [[1213.0, 1469.0], [1248.0, 1469.0], [1246.0, 1741.0], [1211.0, 1741.0]]], "lines": ["「いいから", "言ってるんだよ。」"]}, {"box": [500, 1834, 558, 2006], "vertical": true, "font_size": 58, "lines_coords": [[[500.0, 1834.0], [558.0, 1834.0], [558.0, 2006.0], [500.0, 2006.0]]], "lines": ["く、つ！！"]}, {"box": [149, 1869, 185, 2020], "vertical": true, "font_size": 35, "lines_coords": [[[149.0, 1869.0], [184.0, 1869.0], [184.0, 2020.0], [149.0, 2020.0]]], "lines": ["ゲス美よ。"]}], "img_path": "211.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1151, 115, 1291, 391], "vertical": true, "font_size": 30, "lines_coords": [[[1262.0, 115.0], [1291.0, 115.0], [1291.0, 360.0], [1262.0, 360.0]], [[1223.0, 115.0], [1252.0, 115.0], [1252.0, 391.0], [1223.0, 391.0]], [[1186.0, 115.0], [1215.0, 115.0], [1215.0, 356.0], [1186.0, 356.0]], [[1151.0, 115.0], [1180.0, 115.0], [1180.0, 300.0], [1151.0, 300.0]]], "lines": ["確かに俺の腹筋に", "この華奢なスーツは", "滑稽かもしれない", "だがしかし！！"]}, {"box": [650, 130, 794, 359], "vertical": true, "font_size": 31, "lines_coords": [[[757.0, 130.0], [794.0, 130.0], [794.0, 254.0], [757.0, 254.0]], [[724.0, 132.0], [753.0, 132.0], [753.0, 316.0], [724.0, 316.0]], [[685.0, 130.0], [714.0, 130.0], [714.0, 358.0], [685.0, 358.0]], [[650.0, 132.0], [679.0, 132.0], [679.0, 327.0], [650.0, 327.0]]], "lines": ["どうだい", "何言ってるか", "わからんだろう。", "俺もわからん。"]}, {"box": [1010, 455, 1186, 726], "vertical": true, "font_size": 30, "lines_coords": [[[1157.0, 459.0], [1186.0, 459.0], [1186.0, 670.0], [1157.0, 670.0]], [[1117.0, 455.0], [1155.0, 455.0], [1151.0, 672.0], [1113.0, 672.0]], [[1082.0, 457.0], [1111.0, 457.0], [1111.0, 701.0], [1082.0, 701.0]], [[1045.0, 459.0], [1074.0, 459.0], [1074.0, 726.0], [1045.0, 726.0]], [[1010.0, 459.0], [1039.0, 459.0], [1039.0, 579.0], [1010.0, 579.0]]], "lines": ["この無縁社会で", "賢くサヴァイブ", "したいならつまり", "糖衣まとってチンコ", "隠さず！！"]}, {"box": [819, 981, 857, 1107], "vertical": true, "font_size": 36, "lines_coords": [[[819.0, 981.0], [857.0, 981.0], [857.0, 1107.0], [819.0, 1107.0]]], "lines": ["「．．．ただ、"]}, {"box": [279, 643, 316, 797], "vertical": true, "font_size": 32, "lines_coords": [[[279.0, 643.0], [316.0, 643.0], [316.0, 797.0], [279.0, 797.0]]], "lines": ["はーーァ。"]}, {"box": [173, 842, 277, 1026], "vertical": true, "font_size": 32, "lines_coords": [[[246.0, 842.0], [277.0, 842.0], [273.0, 999.0], [242.0, 999.0]], [[209.0, 844.0], [238.0, 844.0], [238.0, 999.0], [209.0, 999.0]], [[173.0, 846.0], [202.0, 846.0], [202.0, 1026.0], [173.0, 1026.0]]], "lines": ["幸さん達と", "沖縄行きた", "かったぁ．．．"]}, {"box": [573, 979, 778, 1235], "vertical": true, "font_size": 36, "lines_coords": [[[743.0, 979.0], [778.0, 979.0], [774.0, 1184.0], [739.0, 1184.0]], [[699.0, 979.0], [734.0, 979.0], [732.0, 1217.0], [697.0, 1217.0]], [[658.0, 981.0], [693.0, 981.0], [693.0, 1186.0], [658.0, 1186.0]], [[614.0, 979.0], [650.0, 979.0], [647.0, 1219.0], [612.0, 1219.0]], [[573.0, 981.0], [608.0, 981.0], [608.0, 1235.0], [573.0, 1235.0]]], "lines": ["お母さんには", "きちんと事情を", "説明してから", "家を出てあげて", "くれませんか？」"]}, {"box": [296, 1348, 503, 1548], "vertical": true, "font_size": 37, "lines_coords": [[[459.0, 1349.0], [503.0, 1349.0], [503.0, 1469.0], [459.0, 1469.0]], [[422.0, 1351.0], [453.0, 1351.0], [449.0, 1546.0], [418.0, 1546.0]], [[376.0, 1349.0], [414.0, 1349.0], [414.0, 1517.0], [376.0, 1517.0]], [[335.0, 1349.0], [370.0, 1349.0], [370.0, 1484.0], [335.0, 1484.0]], [[296.0, 1349.0], [331.0, 1349.0], [331.0, 1519.0], [296.0, 1519.0]]], "lines": ["「子供の", "心配をしない", "母親なんて", "いないと", "思うので。」"]}, {"box": [138, 1695, 360, 1968], "vertical": true, "font_size": 34, "lines_coords": [[[322.0, 1705.0], [351.0, 1705.0], [351.0, 1950.0], [322.0, 1950.0]], [[279.0, 1699.0], [314.0, 1699.0], [314.0, 1910.0], [279.0, 1910.0]], [[221.0, 1695.0], [256.0, 1695.0], [254.0, 1968.0], [219.0, 1968.0]], [[180.0, 1701.0], [215.0, 1701.0], [215.0, 1935.0], [180.0, 1935.0]], [[138.0, 1699.0], [173.0, 1699.0], [173.0, 1871.0], [138.0, 1871.0]]], "lines": ["一僕もいっしょに", "説得するから、", "その気になったら", "いつでも言って", "ください。」"]}], "img_path": "212.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1254, 157, 1289, 298], "vertical": true, "font_size": 35, "lines_coords": [[[1254.0, 157.0], [1289.0, 157.0], [1289.0, 298.0], [1254.0, 298.0]]], "lines": ["．．．じゃあ"]}, {"box": [757, 401, 842, 515], "vertical": true, "font_size": 46, "lines_coords": [[[797.0, 403.0], [842.0, 403.0], [842.0, 515.0], [797.0, 515.0]], [[757.0, 401.0], [805.0, 401.0], [805.0, 496.0], [757.0, 496.0]]], "lines": ["今から", "行く。"]}, {"box": [345, 136, 432, 277], "vertical": true, "font_size": 40, "lines_coords": [[[389.0, 136.0], [432.0, 136.0], [432.0, 250.0], [389.0, 250.0]], [[349.0, 138.0], [387.0, 138.0], [382.0, 277.0], [345.0, 277.0]]], "lines": ["今すぐ", "行こう？"]}, {"box": [256, 1446, 308, 1575], "vertical": true, "font_size": 52, "lines_coords": [[[256.0, 1449.0], [308.0, 1449.0], [308.0, 1575.0], [256.0, 1575.0]]], "lines": ["．．．ね？"]}, {"box": [809, 1786, 845, 2001], "vertical": true, "font_size": 29, "lines_coords": [[[811.0, 1786.0], [840.0, 1786.0], [840.0, 1993.0], [811.0, 1993.0]]], "lines": ["：愛子ちゃん"]}, {"box": [590, 1787, 629, 1971], "vertical": true, "font_size": 35, "lines_coords": [[[590.0, 1788.0], [625.0, 1788.0], [625.0, 1964.0], [590.0, 1964.0]]], "lines": ["君って娘は。"]}], "img_path": "213.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1215, 113, 1293, 264], "vertical": true, "font_size": 34, "lines_coords": [[[1262.0, 118.0], [1293.0, 118.0], [1293.0, 219.0], [1262.0, 219.0]], [[1219.0, 113.0], [1256.0, 113.0], [1252.0, 262.0], [1215.0, 262.0]]], "lines": ["．．．．．．", "お父さん、"]}, {"box": [433, 78, 507, 295], "vertical": true, "font_size": 36, "lines_coords": [[[459.0, 80.0], [503.0, 78.0], [507.0, 186.0], [463.0, 188.0]], [[434.0, 80.0], [461.0, 80.0], [461.0, 291.0], [434.0, 291.0]]], "lines": ["．．．もう、", "また寝たふり？"]}, {"box": [596, 583, 741, 801], "vertical": true, "font_size": 30, "lines_coords": [[[710.0, 585.0], [739.0, 585.0], [739.0, 739.0], [710.0, 739.0]], [[674.0, 587.0], [703.0, 587.0], [703.0, 768.0], [674.0, 768.0]], [[637.0, 590.0], [666.0, 590.0], [666.0, 801.0], [637.0, 801.0]], [[596.0, 583.0], [631.0, 583.0], [631.0, 710.0], [596.0, 710.0]]], "lines": ["きのうまた", "看護師さんの", "お尻さわったん", "だって？"]}, {"box": [752, 926, 904, 1149], "vertical": true, "font_size": 36, "lines_coords": [[[861.0, 927.0], [904.0, 927.0], [904.0, 1039.0], [861.0, 1039.0]], [[797.0, 929.0], [832.0, 929.0], [832.0, 1066.0], [797.0, 1066.0]], [[757.0, 933.0], [786.0, 933.0], [786.0, 1142.0], [757.0, 1142.0]]], "lines": ["．．．うん、", "そうだね", "今すぐ行こう。"]}, {"box": [513, 925, 680, 1130], "vertical": true, "font_size": 37, "lines_coords": [[[641.0, 927.0], [679.0, 927.0], [679.0, 1068.0], [641.0, 1068.0]], [[600.0, 929.0], [637.0, 929.0], [637.0, 1037.0], [600.0, 1037.0]], [[558.0, 925.0], [596.0, 925.0], [590.0, 1130.0], [552.0, 1130.0]], [[517.0, 929.0], [552.0, 929.0], [548.0, 1103.0], [513.0, 1103.0]]], "lines": ["僕もそう", "思うし、", "君の言う事は", "全部正しい。"]}], "img_path": "214.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1033, 97, 1069, 286], "vertical": true, "font_size": 35, "lines_coords": [[[1033.0, 97.0], [1068.0, 97.0], [1068.0, 281.0], [1033.0, 281.0]]], "lines": ["これでいい。"]}, {"box": [807, 100, 933, 339], "vertical": true, "font_size": 39, "lines_coords": [[[888.0, 101.0], [933.0, 101.0], [933.0, 209.0], [888.0, 209.0]], [[848.0, 101.0], [883.0, 101.0], [883.0, 339.0], [848.0, 339.0]], [[807.0, 101.0], [844.0, 101.0], [844.0, 248.0], [807.0, 248.0]]], "lines": ["全てが", "あるべき場所に", "収まった。"]}, {"box": [271, 219, 424, 530], "vertical": true, "font_size": 33, "lines_coords": [[[389.0, 225.0], [418.0, 225.0], [418.0, 424.0], [389.0, 424.0]], [[329.0, 221.0], [364.0, 221.0], [364.0, 525.0], [329.0, 525.0]], [[271.0, 223.0], [306.0, 223.0], [306.0, 345.0], [271.0, 345.0]]], "lines": ["つまり世界は", "僕のものというより", "むしろー"]}, {"box": [798, 1767, 830, 1942], "vertical": true, "font_size": 32, "lines_coords": [[[798.0, 1767.0], [830.0, 1767.0], [830.0, 1942.0], [798.0, 1942.0]]], "lines": ["僕の世界は、"]}, {"box": [635, 1767, 840, 1948], "vertical": true, "font_size": 29, "lines_coords": [[[797.0, 1770.0], [826.0, 1770.0], [826.0, 1937.0], [797.0, 1937.0]]], "lines": ["僕の世界は"]}, {"box": [630, 1767, 705, 1952], "vertical": true, "font_size": 32, "lines_coords": [[[668.0, 1770.0], [703.0, 1770.0], [703.0, 1904.0], [668.0, 1904.0]], [[631.0, 1770.0], [660.0, 1770.0], [660.0, 1948.0], [631.0, 1948.0]]], "lines": ["君のもの", "だったんだ。"]}], "img_path": "215.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [811, 1316, 891, 1521], "vertical": true, "font_size": 34, "lines_coords": [[[854.0, 1318.0], [886.0, 1318.0], [888.0, 1519.0], [857.0, 1519.0]], [[811.0, 1316.0], [848.0, 1316.0], [848.0, 1434.0], [811.0, 1434.0]]], "lines": ["止まっていた", "時間が、"]}, {"box": [527, 1312, 652, 1517], "vertical": true, "font_size": 38, "lines_coords": [[[616.0, 1316.0], [652.0, 1316.0], [652.0, 1451.0], [616.0, 1451.0]], [[575.0, 1316.0], [604.0, 1316.0], [604.0, 1513.0], [575.0, 1513.0]], [[527.0, 1312.0], [575.0, 1312.0], [575.0, 1403.0], [527.0, 1403.0]]], "lines": ["ようやく", "進み始めたの", "です。"]}], "img_path": "216.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [765, 64, 801, 246], "vertical": true, "font_size": 36, "lines_coords": [[[765.0, 64.0], [801.0, 64.0], [801.0, 246.0], [765.0, 246.0]]], "lines": ["プンプンは、"]}, {"box": [761, 66, 797, 236], "vertical": true, "font_size": 32, "lines_coords": [[[761.0, 66.0], [797.0, 66.0], [797.0, 236.0], [761.0, 236.0]]], "lines": ["フンフンは"]}, {"box": [650, 68, 679, 314], "vertical": true, "font_size": 32, "lines_coords": [[[650.0, 68.0], [679.0, 68.0], [679.0, 314.0], [650.0, 314.0]]], "lines": ["確信したのです。"]}, {"box": [647, 65, 682, 318], "vertical": true, "font_size": 35, "lines_coords": [[[647.0, 65.0], [682.0, 65.0], [682.0, 318.0], [647.0, 318.0]]], "lines": ["確信したのです。"]}, {"box": [784, 1742, 865, 1956], "vertical": true, "font_size": 36, "lines_coords": [[[821.0, 1743.0], [865.0, 1743.0], [865.0, 1850.0], [821.0, 1850.0]], [[784.0, 1747.0], [813.0, 1747.0], [813.0, 1948.0], [784.0, 1948.0]]], "lines": ["やはり", "愛子ちゃんは"]}, {"box": [578, 1740, 861, 1995], "vertical": false, "font_size": 255, "lines_coords": [[[578.0, 1740.0], [861.0, 1740.0], [861.0, 1995.0], [578.0, 1995.0]]], "lines": ["やはり空子ちゃんは、運命の人だったのだ、と。"]}, {"box": [590, 1743, 664, 1995], "vertical": true, "font_size": 32, "lines_coords": [[[629.0, 1747.0], [664.0, 1747.0], [664.0, 1883.0], [629.0, 1883.0]], [[592.0, 1747.0], [621.0, 1747.0], [621.0, 1989.0], [592.0, 1989.0]]], "lines": ["運命の人", "だったのだ、と。"]}], "img_path": "217.png"}, {"version": "0.2.0-beta.6", "img_width"