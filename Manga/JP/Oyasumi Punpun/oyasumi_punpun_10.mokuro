": ["ああいう場所", "苦手．．．．．"]}, {"box": [954, 1407, 989, 1645], "vertical": true, "font_size": 29, "lines_coords": [[[956.0, 1407.0], [985.0, 1407.0], [985.0, 1637.0], [956.0, 1637.0]]], "lines": ["「漫画喫茶は？」"]}, {"box": [1186, 1765, 1254, 1948], "vertical": true, "font_size": 29, "lines_coords": [[[1219.0, 1765.0], [1254.0, 1765.0], [1254.0, 1892.0], [1219.0, 1892.0]], [[1186.0, 1770.0], [1215.0, 1770.0], [1215.0, 1948.0], [1186.0, 1948.0]]], "lines": ["私、漫画", "読まないから"]}, {"box": [1153, 1823, 1177, 1859], "vertical": true, "font_size": 29, "lines_coords": [[[1153.0, 1823.0], [1177.0, 1823.0], [1177.0, 1859.0], [1153.0, 1859.0]]], "lines": ["．．．"]}, {"box": [302, 1500, 424, 1856], "vertical": true, "font_size": 31, "lines_coords": [[[385.0, 1500.0], [420.0, 1500.0], [424.0, 1662.0], [389.0, 1662.0]], [[347.0, 1505.0], [376.0, 1505.0], [376.0, 1739.0], [347.0, 1739.0]], [[304.0, 1505.0], [333.0, 1505.0], [331.0, 1850.0], [302.0, 1850.0]]], "lines": ["「．．．じゃあ、", "このまま二人で", "電車に飛び込もうか？"]}], "img_path": "080.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1165, 499, 1208, 606], "vertical": true, "font_size": 39, "lines_coords": [[[1169.0, 517.0], [1208.0, 519.0], [1204.0, 606.0], [1165.0, 604.0]]], "lines": ["．．．え？"]}, {"box": [778, 966, 813, 1124], "vertical": true, "font_size": 32, "lines_coords": [[[778.0, 966.0], [813.0, 966.0], [813.0, 1124.0], [778.0, 1124.0]]], "lines": ["「；ホテル"]}, {"box": [681, 968, 710, 1136], "vertical": true, "font_size": 32, "lines_coords": [[[681.0, 968.0], [710.0, 968.0], [710.0, 1136.0], [681.0, 1136.0]]], "lines": ["行こうよ。」"]}], "img_path": "081.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [910, 59, 947, 276], "vertical": true, "font_size": 29, "lines_coords": [[[912.0, 60.0], [941.0, 60.0], [941.0, 269.0], [912.0, 269.0]]], "lines": ["：愛子ちゃん"]}, {"box": [455, 57, 621, 302], "vertical": true, "font_size": 32, "lines_coords": [[[587.0, 62.0], [616.0, 62.0], [616.0, 265.0], [587.0, 265.0]], [[546.0, 60.0], [577.0, 60.0], [575.0, 262.0], [544.0, 262.0]], [[503.0, 57.0], [538.0, 57.0], [538.0, 265.0], [503.0, 265.0]], [[455.0, 57.0], [490.0, 57.0], [494.0, 256.0], [459.0, 256.0]]], "lines": ["君がとういう", "つもりなのか", "僕は知る由も", "ないけれどー"]}, {"box": [801, 1196, 848, 1287], "vertical": true, "font_size": 47, "lines_coords": [[[801.0, 1196.0], [848.0, 1196.0], [848.0, 1287.0], [801.0, 1287.0]]], "lines": ["僕は、"]}, {"box": [592, 1196, 674, 1337], "vertical": true, "font_size": 39, "lines_coords": [[[637.0, 1200.0], [672.0, 1200.0], [672.0, 1337.0], [637.0, 1337.0]], [[592.0, 1196.0], [635.0, 1196.0], [635.0, 1312.0], [592.0, 1312.0]]], "lines": ["なにやら", "悲しい。"]}], "img_path": "082.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [985, 1705, 1015, 1893], "vertical": true, "font_size": 29, "lines_coords": [[[985.0, 1705.0], [1014.0, 1705.0], [1014.0, 1890.0], [985.0, 1890.0]]], "lines": ["いずれにせよ、"]}, {"box": [743, 1700, 919, 2033], "vertical": true, "font_size": 28, "lines_coords": [[[888.0, 1703.0], [917.0, 1703.0], [917.0, 1975.0], [888.0, 1975.0]], [[850.0, 1703.0], [877.0, 1703.0], [877.0, 1944.0], [850.0, 1944.0]], [[815.0, 1703.0], [842.0, 1703.0], [842.0, 2033.0], [815.0, 2033.0]], [[778.0, 1703.0], [807.0, 1703.0], [807.0, 1973.0], [778.0, 1973.0]], [[743.0, 1703.0], [772.0, 1703.0], [772.0, 1859.0], [743.0, 1859.0]]], "lines": ["数年振りに再会した", "軽薄な同級生Ａに", "簡単について来てしまう", "不良娘であることは", "明白であり、"]}, {"box": [621, 1697, 668, 1782], "vertical": true, "font_size": 47, "lines_coords": [[[621.0, 1697.0], [668.0, 1697.0], [668.0, 1782.0], [621.0, 1782.0]]], "lines": ["僕は、"]}, {"box": [476, 1699, 550, 1915], "vertical": true, "font_size": 34, "lines_coords": [[[517.0, 1703.0], [546.0, 1703.0], [546.0, 1852.0], [517.0, 1852.0]], [[476.0, 1699.0], [515.0, 1699.0], [515.0, 1780.0], [476.0, 1780.0]]], "lines": ["僭越ながら", "僕はー"]}], "img_path": "083.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [722, 1755, 757, 1925], "vertical": true, "font_size": 35, "lines_coords": [[[722.0, 1755.0], [757.0, 1755.0], [757.0, 1925.0], [722.0, 1925.0]]], "lines": ["君を不幸に"]}, {"box": [621, 1753, 658, 2001], "vertical": true, "font_size": 35, "lines_coords": [[[623.0, 1753.0], [658.0, 1753.0], [656.0, 2001.0], [621.0, 2001.0]]], "lines": ["叩き落としたい。"]}, {"box": [623, 1758, 657, 2001], "vertical": true, "font_size": 34, "lines_coords": [[[623.0, 1758.0], [657.0, 1758.0], [657.0, 2001.0], [623.0, 2001.0]]], "lines": ["叩き落としたい。"]}], "img_path": "084.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [867, 142, 912, 211], "vertical": true, "font_size": 43, "lines_coords": [[[867.0, 142.0], [912.0, 142.0], [912.0, 211.0], [867.0, 211.0]]], "lines": ["ハァ"]}, {"box": [826, 246, 867, 314], "vertical": true, "font_size": 43, "lines_coords": [[[826.0, 246.0], [867.0, 246.0], [867.0, 314.0], [826.0, 314.0]]], "lines": ["ハァ"]}, {"box": [1180, 422, 1212, 721], "vertical": true, "font_size": 26, "lines_coords": [[[1180.0, 422.0], [1206.0, 422.0], [1206.0, 710.0], [1180.0, 710.0]]], "lines": ["空子ちゃん、僕は"]}, {"box": [724, 752, 799, 919], "vertical": true, "font_size": 29, "lines_coords": [[[765.0, 753.0], [794.0, 753.0], [794.0, 917.0], [765.0, 917.0]], [[724.0, 753.0], [753.0, 753.0], [753.0, 919.0], [724.0, 919.0]]], "lines": ["僕に呪いを", "かけたまま"]}, {"box": [515, 747, 639, 989], "vertical": true, "font_size": 37, "lines_coords": [[[606.0, 755.0], [635.0, 755.0], [635.0, 915.0], [606.0, 915.0]], [[563.0, 751.0], [598.0, 751.0], [598.0, 989.0], [563.0, 989.0]], [[515.0, 747.0], [563.0, 747.0], [563.0, 838.0], [515.0, 838.0]]], "lines": ["別の世界へ", "行ってしまった", "君を、"]}, {"box": [403, 749, 439, 969], "vertical": true, "font_size": 35, "lines_coords": [[[403.0, 751.0], [438.0, 751.0], [438.0, 958.0], [403.0, 958.0]]], "lines": ["許したくない。"]}, {"box": [171, 629, 221, 701], "vertical": true, "font_size": 50, "lines_coords":