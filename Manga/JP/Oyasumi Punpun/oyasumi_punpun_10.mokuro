1399.0], [703.0, 1579.0], [674.0, 1579.0]], [[639.0, 1397.0], [668.0, 1397.0], [668.0, 1519.0], [639.0, 1519.0]]], "lines": ["君は少し", "優しすぎたん", "だよ．．．"]}, {"box": [204, 1068, 316, 1256], "vertical": true, "font_size": 36, "lines_coords": [[[271.0, 1068.0], [316.0, 1068.0], [316.0, 1173.0], [271.0, 1173.0]], [[240.0, 1070.0], [275.0, 1070.0], [275.0, 1229.0], [240.0, 1229.0]], [[204.0, 1076.0], [233.0, 1076.0], [233.0, 1256.0], [204.0, 1256.0]]], "lines": ["なんか", "ちょっと急", "なんだけど．．"]}, {"box": [815, 1743, 929, 1929], "vertical": true, "font_size": 35, "lines_coords": [[[898.0, 1749.0], [927.0, 1749.0], [927.0, 1927.0], [898.0, 1927.0]], [[861.0, 1747.0], [890.0, 1747.0], [890.0, 1929.0], [861.0, 1929.0]], [[815.0, 1743.0], [861.0, 1743.0], [861.0, 1830.0], [815.0, 1830.0]]], "lines": ["あたし一人で", "どうにかする", "から。"]}, {"box": [188, 1523, 293, 1718], "vertical": true, "font_size": 30, "lines_coords": [[[258.0, 1523.0], [293.0, 1523.0], [293.0, 1705.0], [258.0, 1705.0]], [[223.0, 1525.0], [252.0, 1525.0], [252.0, 1705.0], [223.0, 1705.0]], [[188.0, 1523.0], [215.0, 1523.0], [215.0, 1716.0], [188.0, 1716.0]]], "lines": ["もっと怒って", "然るべき時が", "あったと思う。"]}, {"box": [416, 1852, 457, 2044], "vertical": true, "font_size": 35, "lines_coords": [[[416.0, 1852.0], [451.0, 1852.0], [455.0, 2039.0], [420.0, 2039.0]]], "lines": ["「．．．．．あの。」"]}], "img_path": "182.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1247, 139, 1279, 286], "vertical": true, "font_size": 29, "lines_coords": [[[1248.0, 140.0], [1277.0, 140.0], [1277.0, 281.0], [1248.0, 281.0]]], "lines": ["あたしは、"]}, {"box": [596, 194, 716, 367], "vertical": true, "font_size": 33, "lines_coords": [[[672.0, 196.0], [712.0, 194.0], [716.0, 302.0], [676.0, 304.0]], [[639.0, 198.0], [668.0, 198.0], [668.0, 366.0], [639.0, 366.0]], [[596.0, 198.0], [625.0, 198.0], [625.0, 347.0], [596.0, 347.0]]], "lines": ["そんな", "君に甘えて", "たと思う。"]}, {"box": [257, 220, 417, 708], "vertical": true, "font_size": 30, "lines_coords": [[[385.0, 223.0], [414.0, 223.0], [414.0, 606.0], [385.0, 606.0]], [[337.0, 221.0], [372.0, 221.0], [372.0, 590.0], [337.0, 590.0]], [[300.0, 221.0], [329.0, 221.0], [329.0, 558.0], [300.0, 558.0]], [[258.0, 223.0], [287.0, 223.0], [287.0, 708.0], [258.0, 708.0]]], "lines": ["「そう言いながらもすでに", "行かない訳にはいかなぃ", "雰囲気なのはあなたも", "わかって言ってますよね：：：？」"]}, {"box": [1080, 521, 1242, 805], "vertical": true, "font_size": 32, "lines_coords": [[[1206.0, 521.0], [1242.0, 521.0], [1240.0, 778.0], [1204.0, 778.0]], [[1163.0, 523.0], [1198.0, 523.0], [1198.0, 795.0], [1163.0, 795.0]], [[1124.0, 525.0], [1153.0, 525.0], [1153.0, 792.0], [1124.0, 792.0]], [[1082.0, 523.0], [1111.0, 523.0], [1111.0, 805.0], [1082.0, 805.0]]], "lines": ["「来いと言ったり", "来るなと言ったり", "あなたもずいぶん", "勝手ですね．．．．．．"]}, {"box": [1237, 973, 1283, 1086], "vertical": true, "font_size": 40, "lines_coords": [[[1237.0, 973.0], [1283.0, 973.0], [1283.0, 1086.0], [1237.0, 1086.0]]], "lines": ["．．．でも、"]}, {"box": [1095, 1144, 1219, 1318], "vertical": true, "font_size": 40, "lines_coords": [[[1175.0, 1144.0], [1219.0, 1144.0], [1219.0, 1254.0], [1175.0, 1254.0]], [[1134.0, 1146.0], [1171.0, 1146.0], [1173.0, 1285.0], [1136.0, 1285.0]], [[1095.0, 1149.0], [1130.0, 1149.0], [1130.0, 1318.0], [1095.0, 1318.0]]], "lines": ["本当に", "来なくて", "いいから．．．"]}, {"box": [242, 1120, 393, 1331], "vertical": true, "font_size": 34, "lines_coords": [[[356.0, 1120.0], [393.0, 1120.0], [393.0, 1221.0], [356.0, 1221.0]], [[322.0, 1126.0], [351.0, 1126.0], [351.0, 1304.0], [322.0, 1304.0]], [[283.0, 1122.0], [312.0, 1122.0], [312.0, 1331.0], [283.0, 1331.0]], [[242.0, 1122.0], [279.0, 1120.0], [283.0, 1231.0], [246.0, 1233.0]]], "lines": ["だから", "お願いだから", "今は怒らないで", "ほしい。"]}, {"box": [207, 1420, 329, 1623], "vertical": true, "font_size": 34, "lines_coords": [[[293.0, 1422.0], [329.0, 1422.0], [329.0, 1556.0], [293.0, 1556.0]], [[250.0, 1422.0], [285.0, 1422.0], [285.0, 1623.0], [250.0, 1623.0]], [[207.0, 1420.0], [244.0, 1420.0], [244.0, 1556.0], [207.0, 1556.0]]], "lines": ["あたしが", "全部悪かった", "から．．．"]}, {"box": [1084, 1821, 1142, 1910], "vertical": true, "font_size": 58, "lines_coords": [[[1084.0, 1821.0], [1142.0, 1821.0], [1142.0, 1910.0], [1084.0, 1910.0]]], "lines": ["コン"]}, {"box": [339, 1865, 395, 1958], "vertical": true, "font_size": 56, "lines_coords": [[[339.0, 1865.0], [395.0, 1865.0], [395.0, 1958.0], [339.0, 1958.0]]], "lines": ["コン"]}], "img_path": "183.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1080, 165, 1200, 488], "vertical": true, "font_size": 35, "lines_coords": [[[1165.0, 173.0], [1200.0, 173.0], [1198.0, 459.0], [1163.0, 459.0]], [[1124.0, 165.0], [1159.0, 165.0], [1157.0, 411.0], [1122.0, 411.0]], [[1082.0, 165.0], [1117.0, 165.0], [1115.0, 488.0], [1080.0, 488.0]]], "lines": ["「僕は怒ってないし", "誰が悪いとかは", "どうでもいいんです。"]}, {"box": [998, 166, 1032, 346], "vertical": true, "font_size": 34, "lines_coords": [[[998.0, 166.0], [1032.0, 166.0], [1032.0, 346.0], [998.0, 346.0]]], "lines": ["．．．ただ、」"]}, {"box": [995, 171, 1030, 341], "vertical": true, "font_size": 35, "lines_coords": [[[995.0, 171.0], [1030.0, 171.0], [1030.0, 341.0], [995.0, 341.0]]], "lines": ["．．．ただ、」"]}, {"box": [329, 163, 449, 469], "vertical": true, "font_size": 34, "lines_coords": [[[414.0, 165.0], [449.0, 165.0], [449.0, 457.0], [414.0, 457.0]], [[368.0, 163.0], [403.0, 163.0], [403.0, 469.0], [368.0, 469.0]], [[329.0, 167.0], [364.0, 167.0], [364.0, 310.0], [329.0, 310.0]]], "lines": ["「あなたが本心では", "どうしたいと思って", "いるのか、"]}, {"box": [207, 165, 281, 521], "vertical": true, "font_size": 34, "lines_coords": [[[246.0, 165.0], [281.0, 165.0], [281.0, 405.0], [246.0, 405.0]], [[207.0, 165.0], [236.0, 165.0], [236.0, 521.0], [207.0, 521.0]]], "lines": ["ただそれだけが", "聞きたいんです．．．！！」"]}, {"box": [1187, 1718, 1228, 1908], "vertical": true, "font_size": 37, "lines_coords": [[[1188.0, 1720.0], [1225.0, 1720.0], [1225.0, 1904.0], [1188.0, 1904.0]]], "lines": ["．．．プンプン。"]}, {"box": [182, 1794, 217, 1964], "vertical": true, "font_size": 35, "lines_coords": [[[182.0, 1794.0], [217.0, 1794.0], [217.0, 1964.0], [182.0, 1964.0]]], "lines": ["．．．いるの？"]}], "img_path": "184.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1175, 151, 1213, 322], "vertical": true, "font_size": 36, "lines_coords": [[[1175.0, 151.0], [1211.0, 151.0], [1211.0, 320.0], [1175.0, 320.0]]], "lines": ["．．．プンプン"]}, {"box": [236, 250, 271, 383], "vertical": true, "font_size": 35, "lines_coords": [[[236.0, 250.0], [271.0, 250.0], [271.0, 383.0], [236.0, 383.0]]], "lines": ["いるの？"]}, {"box": [22, 383, 95, 606], "vertical": true, "font_size": 73, "lines_coords": [[[22.0, 383.0], [95.0, 383.0], [95.0, 606.0], [22.0, 606.0]]], "lines": ["第１０Ｓ話"]}, {"box": [1188, 625, 1225, 749], "vertical": true, "font_size": 37, "lines_coords": [[[1188.0, 625.0], [1225.0, 625.0], [1225.0, 749.0], [1188.0, 749.0]]], "lines": ["ごめん。"]}, {"box": [1217, 964, 1246, 1088], "vertical": true, "font_size": 32, "lines_coords": [[[1217.0, 964.0], [1246.0, 964.0], [1246.0, 1088.0], [1217.0, 1088.0]]], "lines": ["．．．あとは"]}, {"box": [200, 666, 303, 879], "vertical": true, "font_size": 29, "lines_coords": [[[273.0, 666.0], [302.0, 666.0], [302.0, 821.0], [273.0, 821.0]], [[236.0, 666.0], [264.0, 666.0], [264.0, 879.0], [236.0, 879.0]], [[200.0, 668.0], [229.0, 668.0], [229.0, 834.0], [200.0, 834.0]]], "lines": ["．．．あたしも", "どうしたいのか", "わからない。"]}, {"box": [1076, 1138, 1146, 1289], "vertical": true, "font_size": 32, "lines_coords": [[[1117.0, 1140.0], [1146.0, 1140.0], [1146.0, 1289.0], [1117.0, 1289.0]], [[1076.0, 1138.0], [1113.0, 1138.0], [1113.0, 1246.0], [1076.0, 1246.0]]], "lines": ["君の判断に", "任せる。"]}, {"box": [320, 1190, 432, 1318], "vertical": true, "font_size": 33, "lines_coords": [[[385.0, 1190.0], [432.0, 1190.0], [432.0, 1264.0], [385.0, 1264.0]], [[354.0, 1190.0], [389.0, 1190.0], [389.0, 1316.0], [354.0, 1316.0]], [[320.0, 1192.0], [349.0, 1192.0], [349.0, 1318.0], [320.0, 1318.0]]], "lines": ["一応", "あたしは", "約束通り、"]}, {"box": [202, 1387, 306, 1598], "vertical": true, "font_size": 33, "lines_coords": [[[271.0, 1387.0], [306.0, 1387.0], [306.0, 1511.0], [271.0, 1511.0]], [[236.0, 1389.0], [264.0, 1389.0], [264.0, 1598.0], [236.0, 1598.0]], [[202.0, 1389.0], [225.0, 1389.0], [225.0, 1534.0], [202.0, 1534.0]]], "lines": ["３時まで", "駅前の駐輪所に", "いるよ．．．"]}, {"box": [1151, 1780, 1227, 1980], "vertical": true, "font_size": 33, "lines_coords": [[[1190.0, 1780.0], [1227.0, 1780.0], [1227.0, 1883.0], [1190.0, 1883.0]], [[1153.0, 1784.0], [1182.0, 1784.0], [1182.0, 1979.0], [1153.0, 1979.0]]], "lines": ["今日が", "過ぎれば．．．．．"]}, {"box": [229, 1782, 354, 1989], "vertical": true, "font_size": 35, "lines_coords": [[[316.0, 1786.0], [351.0, 1786.0], [351.0, 1929.0], [316.0, 1929.0]], [[275.0, 1786.0], [310.0, 1786.0], [310.0, 1989.0], [275.0, 1989.0]], [[233.0, 1782.0], [269.0, 1782.0], [264.0, 1989.0], [229.0, 1989.0]]], "lines": ["あたし達、", "普通に仲良く", "できるかな．．．"]}], "img_path": "185.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1186, 1609, 1224, 1793], "vertical": true, "font_size": 37, "lines_coords": [[[1186.0, 1610.0], [1223.0, 1610.0], [1223.0, 1790.0], [1186.0, 1790.0]]], "lines": ["．．．プンプン"]}, {"box": [204, 1656, 322, 1843], "vertical": true, "font_size": 36, "lines_coords": [[[285.0, 1658.0], [320.0, 1658.0], [320.0, 1792.0], [285.0, 1792.0]], [[238.0, 1656.0], [283.0, 1656.0], [283.0, 1765.0], [238.0, 1765.0]], [[204.0, 1658.0], [233.0, 1658.0], [233.0, 1838.0], [204.0, 1838.0]]], "lines": ["．．．今まで", "本当に", "ありがとう。"]}], "img_path": "186.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [304, 118, 337, 325], "vertical": true, "font_size": 29, "lines_coords": [[[304.0, 118.0], [333.0, 118.0], [333.0, 318.0], [304.0, 318.0]]], "lines": ["「その傷．．．．．"]}, {"box": [705, 536, 816, 720], "vertical": true, "font_size": 35, "lines_coords": [[[780.0, 536.0], [815.0, 536.0], [815.0, 662.0], [780.0, 662.0]], [[747.0, 540.0], [776.0, 540.0], [776.0, 720.0], [747.0, 720.0]], [[705.0, 536.0], [745.0, 536.0], [745.0, 619.0], [705.0, 619.0]]], "lines": ["．．．これは", "なんでもない", "から。"]}, {"box": [768, 933, 879, 1155], "vertical": true, "font_size": 37, "lines_coords": [[[838.0, 933.0], [879.0, 933.0], [879.0, 1155.0], [838.0, 1155.0]], [[768.0, 933.0], [803.0, 933.0], [803.0, 1101.0], [768.0, 1101.0]]], "lines": ["「なんでもない", "訳ないじゃ"]}, {"box": [693, 935, 728, 1122], "vertical": true, "font_size": 37, "lines_coords": [[[693.0, 935.0], [728.0, 935.0], [728.0, 1122.0], [693.0, 1122.0]]], "lines": ["ないか．．．．．"]}, {"box": [157, 668, 266, 823], "vertical": true, "font_size": 32, "lines_coords": [[[233.0, 672.0], [262.0, 672.0], [262.0, 823.0], [233.0, 823.0]], [[192.0, 670.0], [229.0, 670.0], [229.0, 768.0], [192.0, 768.0]], [[157.0, 668.0], [186.0, 668.0], [186.0, 790.0], [157.0, 790.0]]], "lines": ["．．．ごめんね", "電話中", "だった？"]}, {"box": [1173, 1300, 1283, 1515], "vertical": true, "font_size": 31, "lines_coords": [[[1248.0, 1300.0], [1283.0, 1300.0], [1279.0, 1488.0], [1244.0, 1488.0]], [[1213.0, 1304.0], [1242.0, 1304.0], [1242.0, 1484.0], [1213.0, 1484.0]], [[1175.0, 1302.0], [1204.0, 1302.0], [1202.0, 1515.0], [1173.0, 1515.0]]], "lines": ["ちょっと近く", "通りかかった", "だけだから．．．"]}, {"box": [366, 1538, 432, 1749], "vertical": true, "font_size": 32, "lines_coords": [[[403.0, 1538.0], [432.0, 1538.0], [432.0, 1660.0], [403.0, 1660.0]], [[366.0, 1540.0], [395.0, 1540.0], [395.0, 1749.0], [366.0, 1749.0]]], "lines": ["ごめんね", "邪魔しちゃって"]}, {"box": [242, 1782, 281, 1900], "vertical": true, "font_size": 32, "lines_coords": [[[242.0, 1782.0], [279.0, 1782.0], [281.0, 1900.0], [244.0, 1900.0]]], "lines": ["帰るね。"]}], "img_path": "187.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [654, 983, 738, 1140], "vertical": true, "font_size": 36, "lines_coords": [[[697.0, 989.0], [732.0, 989.0], [732.0, 1140.0], [697.0, 1140.0]], [[658.0, 983.0], [695.0, 983.0], [691.0, 1124.0], [654.0, 1124.0]]], "lines": ["なんなん", "ですか。」"]}, {"box": [532, 1320, 635, 1532], "vertical": true, "font_size": 33, "lines_coords": [[[598.0, 1320.0], [635.0, 1320.0], [635.0, 1430.0], [598.0, 1430.0]], [[567.0, 1322.0], [596.0, 1322.0], [594.0, 1503.0], [565.0, 1503.0]], [[532.0, 1322.0], [561.0, 1322.0], [561.0, 1532.0], [532.0, 1532.0]]], "lines": ["「こんな", "もやもやした", "気持ちじゃ．．．"]}, {"box": [530, 1321, 634, 1533], "vertical": true, "font_size": 104, "lines_coords": [[[530.0, 1321.0], [634.0, 1321.0], [634.0, 1533.0], [530.0, 1533.0]]], "lines": ["「こんなもやもやした気持ちじゃ．．．"]}, {"box": [267, 1318, 455, 1558], "vertical": true, "font_size": 33, "lines_coords": [[[414.0, 1318.0], [455.0, 1318.0], [455.0, 1395.0], [414.0, 1395.0]], [[382.0, 1322.0], [411.0, 1322.0], [411.0, 1503.0], [382.0, 1503.0]], [[343.0, 1318.0], [378.0, 1318.0], [374.0, 1532.0], [339.0, 1532.0]], [[308.0, 1322.0], [337.0, 1322.0], [337.0, 1558.0], [308.0, 1558.0]], [[267.0, 1322.0], [304.0, 1322.0], [304.0, 1401.0], [267.0, 1401.0]]], "lines": ["今後、", "僕はまともに", "うどんを茹でる", "ことすらできない", "．．．いい"]}, {"box": [283, 1720, 349, 1915], "vertical": true, "font_size": 29, "lines_coords": [[[320.0, 1720.0], [349.0, 1720.0], [345.0, 1915.0], [316.0, 1915.0]], [[283.0, 1722.0], [312.0, 1722.0], [312.0, 1875.0], [283.0, 1875.0]]], "lines": ["「言いたい事が", "あるんなら"]}, {"box": [182, 1722, 248, 1977], "vertical": true, "font_size": 29, "lines_coords": [[[219.0, 1722.0], [248.0, 1722.0], [248.0, 1960.0], [219.0, 1960.0]], [[182.0, 1722.0], [211.0, 1722.0], [211.0, 1977.0], [182.0, 1977.0]]], "lines": ["はっきり言ったら", "いいじゃないか．．．」"]}], "img_path": "188.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [310, 662, 414, 911], "vertical": true, "font_size": 35, "lines_coords": [[[374.0, 664.0], [409.0, 664.0], [409.0, 832.0], [374.0, 832.0]], [[310.0, 664.0], [345.0, 664.0], [345.0, 910.0], [310.0, 910.0]]], "lines": ["「：：：言えば", "いいじゃないか。」"]}, {"box": [338, 1019, 478, 1190], "vertical": true, "font_size": 71, "lines_coords": [[[407.0, 1022.0], [478.0, 1022.0], [478.0, 1165.0], [407.0, 1165.0]]], "lines": ["お前"]}, {"box": [159, 1509, 759, 2088], "vertical": false, "font_size": 485, "lines_coords": [[[159.0, 1614.0], [660.0, 1509.0], [759.0, 1985.0], [258.0, 2088.0]]], "lines": ["そんなしたいああ！！"]}, {"box": [376, 1277, 1411, 2120], "vertical": false, "font_size": 398.0, "lines_coords": [[[979.0, 1718.0], [1202.0, 1741.0], [1173.0, 2012.0], [950.0, 1987.0]], [[376.0, 1691.0], [1153.0, 1277.0], [1411.0, 1759.0], [635.0, 2120.0]]], "lines": ["はは君と", "ああ"]}], "img_path": "189.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [], "img_path": "190.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1211, 99, 1283, 293], "vertical": true, "font_size": 34, "lines_coords": [[[1244.0, 99.0], [1283.0, 99.0], [1283.0, 196.0], [1244.0, 196.0]], [[1211.0, 99.0], [1240.0, 99.0], [1240.0, 293.0], [1211.0, 293.0]]], "lines": ["．．．君に", "会いたかった。"]}, {"box": [1128, 378, 1198, 521], "vertical": true, "font_size": 34, "lines_coords": [[[1159.0, 378.0], [1198.0, 378.0], [1198.0, 453.0], [1159.0, 453.0]], [[1128.0, 385.0], [1157.0, 385.0], [1157.0, 521.0], [1128.0, 521.0]]], "lines": ["ただ", "それだけ。"]}, {"box": [621, 737, 695, 892], "vertical": true, "font_size": 37, "lines_coords": [[[660.0, 737.0], [695.0, 737.0], [695.0, 892.0], [660.0, 892.0]], [[621.0, 737.0], [660.0, 737.0], [660.0, 832.0], [621.0, 832.0]]], "lines": ["．．．それじゃ", "ダメ？"]}, {"box": [173, 637, 243, 880], "vertical": true, "font_size": 29, "lines_coords": [[[213.0, 637.0], [242.0, 637.0], [242.0, 786.0], [213.0, 786.0]], [[173.0, 637.0], [202.0, 637.0], [202.0, 879.0], [173.0, 879.0]]], "lines": ["言わなきゃ", "わからなかった？"]}, {"box": [426, 1807, 540, 1957], "vertical": true, "font_size": 38, "lines_coords": [[[500.0, 1811.0], [540.0, 1811.0], [540.0, 1912.0], [500.0, 1912.0]], [[426.0, 1807.0], [463.0, 1807.0], [4