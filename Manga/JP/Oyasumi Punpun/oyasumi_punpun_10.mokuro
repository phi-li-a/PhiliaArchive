, 1844.0], [188.0, 1844.0], [188.0, 1985.0], [159.0, 1985.0]]], "lines": ["．．．", "お母さん"]}], "img_path": "167.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1099, 167, 1153, 277], "vertical": true, "font_size": 54, "lines_coords": [[[1099.0, 167.0], [1153.0, 167.0], [1153.0, 277.0], [1099.0, 277.0]]], "lines": ["え？"]}, {"box": [157, 1380, 260, 1534], "vertical": true, "font_size": 29, "lines_coords": [[[225.0, 1380.0], [260.0, 1380.0], [260.0, 1507.0], [225.0, 1507.0]], [[192.0, 1382.0], [221.0, 1382.0], [221.0, 1534.0], [192.0, 1534.0]], [[157.0, 1382.0], [180.0, 1382.0], [180.0, 1529.0], [157.0, 1529.0]]], "lines": ["．．．ごめん", "あたし馬鹿", "だから．．．"]}, {"box": [1160, 1701, 1277, 1937], "vertical": true, "font_size": 33, "lines_coords": [[[1242.0, 1703.0], [1277.0, 1703.0], [1277.0, 1873.0], [1242.0, 1873.0]], [[1200.0, 1701.0], [1235.0, 1701.0], [1235.0, 1904.0], [1200.0, 1904.0]], [[1161.0, 1703.0], [1190.0, 1703.0], [1190.0, 1933.0], [1161.0, 1933.0]]], "lines": ["．．．いちいち", "説明しなきゃ", "わかんないの？"]}, {"box": [600, 1699, 746, 2006], "vertical": true, "font_size": 32, "lines_coords": [[[716.0, 1703.0], [745.0, 1703.0], [745.0, 1975.0], [716.0, 1975.0]], [[674.0, 1701.0], [703.0, 1701.0], [708.0, 2006.0], [679.0, 2006.0]], [[641.0, 1701.0], [670.0, 1701.0], [670.0, 2006.0], [641.0, 2006.0]], [[600.0, 1699.0], [639.0, 1699.0], [639.0, 1782.0], [600.0, 1782.0]]], "lines": ["消費者を舐めきった", "クソ企業の隠蔽体質を", "ネットに晒してやるん", "だよ。"]}, {"box": [115, 1753, 298, 2030], "vertical": true, "font_size": 32, "lines_coords": [[[260.0, 1753.0], [296.0, 1753.0], [298.0, 1985.0], [262.0, 1985.0]], [[229.0, 1757.0], [258.0, 1757.0], [258.0, 2030.0], [229.0, 2030.0]], [[188.0, 1755.0], [219.0, 1755.0], [221.0, 1997.0], [190.0, 1997.0]], [[155.0, 1757.0], [184.0, 1757.0], [184.0, 2028.0], [155.0, 2028.0]], [[115.0, 1753.0], [151.0, 1753.0], [151.0, 1865.0], [115.0, 1865.0]]], "lines": ["あたし達庶民は", "正確で安全な情報を", "与えられて健康に", "生きる権利があるん", "だから。"]}], "img_path": "168.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1211, 93, 1352, 310], "vertical": true, "font_size": 30, "lines_coords": [[[1322.0, 95.0], [1351.0, 95.0], [1351.0, 279.0], [1322.0, 279.0]], [[1279.0, 93.0], [1314.0, 93.0], [1314.0, 221.0], [1279.0, 221.0]], [[1248.0, 95.0], [1277.0, 95.0], [1277.0, 250.0], [1248.0, 250.0]], [[1211.0, 95.0], [1240.0, 95.0], [1240.0, 306.0], [1211.0, 306.0]]], "lines": ["．．．お母さんは", "毎日毎日", "そういう事", "してるけど．．．"]}, {"box": [478, 92, 513, 251], "vertical": true, "font_size": 35, "lines_coords": [[[478.0, 93.0], [513.0, 93.0], [513.0, 246.0], [478.0, 246.0]]], "lines": ["．．．ううん。"]}, {"box": [240, 349, 312, 476], "vertical": true, "font_size": 39, "lines_coords": [[[275.0, 351.0], [312.0, 351.0], [312.0, 476.0], [275.0, 476.0]], [[240.0, 349.0], [277.0, 349.0], [277.0, 476.0], [240.0, 476.0]]], "lines": ["なんでも", "ない．．．"]}, {"box": [912, 585, 1016, 739], "vertical": true, "font_size": 29, "lines_coords": [[[987.0, 585.0], [1016.0, 585.0], [1016.0, 734.0], [987.0, 734.0]], [[950.0, 587.0], [979.0, 587.0], [979.0, 739.0], [950.0, 739.0]], [[912.0, 585.0], [941.0, 585.0], [941.0, 708.0], [912.0, 708.0]]], "lines": ["．．．それって", "本当に意味", "あるの？"]}, {"box": [674, 610, 730, 722], "vertical": true, "font_size": 56, "lines_coords": [[[674.0, 610.0], [730.0, 610.0], [730.0, 722.0], [674.0, 722.0]]], "lines": ["愛子。"]}, {"box": [169, 542, 254, 761], "vertical": true, "font_size": 39, "lines_coords": [[[211.0, 542.0], [254.0, 542.0], [254.0, 666.0], [211.0, 666.0]], [[173.0, 542.0], [211.0, 542.0], [207.0, 761.0], [169.0, 761.0]]], "lines": ["．．．仕事、", "行ってくるね。"]}, {"box": [1093, 941, 1273, 1221], "vertical": true, "font_size": 34, "lines_coords": [[[1235.0, 946.0], [1273.0, 946.0], [1273.0, 1070.0], [1235.0, 1070.0]], [[1200.0, 946.0], [1235.0, 946.0], [1235.0, 1132.0], [1200.0, 1132.0]], [[1163.0, 944.0], [1194.0, 944.0], [1196.0, 1190.0], [1165.0, 1190.0]], [[1126.0, 941.0], [1161.0, 941.0], [1161.0, 1221.0], [1126.0, 1221.0]], [[1093.0, 946.0], [1122.0, 946.0], [1122.0, 1082.0], [1093.0, 1082.0]]], "lines": ["．．．コイツ", "大学中退して", "親のスネかじって", "部屋にとじこもって", "たんだと。"]}, {"box": [211, 1368, 356, 1582], "vertical": true, "font_size": 32, "lines_coords": [[[320.0, 1368.0], [356.0, 1368.0], [356.0, 1552.0], [320.0, 1552.0]], [[285.0, 1370.0], [314.0, 1370.0], [314.0, 1550.0], [285.0, 1550.0]], [[248.0, 1370.0], [277.0, 1370.0], [277.0, 1581.0], [248.0, 1581.0]], [[211.0, 1370.0], [244.0, 1370.0], [244.0, 1476.0], [211.0, 1476.0]]], "lines": ["心入れ換えて", "やるつもりで", "みんなよろしく", "頼むよ。"]}, {"box": [1180, 1716, 1284, 1939], "vertical": true, "font_size": 29, "lines_coords": [[[1254.0, 1718.0], [1283.0, 1718.0], [1283.0, 1867.0], [1254.0, 1867.0]], [[1217.0, 1718.0], [1246.0, 1718.0], [1246.0, 1925.0], [1217.0, 1925.0]], [[1180.0, 1716.0], [1208.0, 1716.0], [1208.0, 1935.0], [1180.0, 1935.0]]], "lines": ["後のことは", "チーフに聞けば", "大体わかっから。"]}, {"box": [399, 1705, 447, 1857], "vertical": true, "font_size": 42, "lines_coords": [[[399.0, 1705.0], [443.0, 1705.0], [447.0, 1857.0], [403.0, 1857.0]]], "lines": ["あ．．．．．と、"]}, {"box": [202, 1761, 287, 2004], "vertical": true, "font_size": 42, "lines_coords": [[[246.0, 1761.0], [287.0, 1761.0], [283.0, 1973.0], [242.0, 1973.0]], [[202.0, 1765.0], [244.0, 1765.0], [244.0, 2004.0], [202.0, 2004.0]]], "lines": ["よ、よろしく", "お願いします！！"]}], "img_path": "169.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1192, 99, 1242, 308], "vertical": true, "font_size": 50, "lines_coords": [[[1192.0, 99.0], [1242.0, 99.0], [1242.0, 169.0], [1192.0, 169.0]]], "lines": ["あー"]}, {"box": [1186, 892, 1223, 1026], "vertical": true, "font_size": 34, "lines_coords": [[[1186.0, 892.0], [1223.0, 892.0], [1223.0, 1026.0], [1186.0, 1026.0]]], "lines": ["あ、あの、"]}, {"box": [565, 565, 616, 693], "vertical": true, "font_size": 51, "lines_coords": [[[565.0, 565.0], [616.0, 565.0], [616.0, 693.0], [565.0, 693.0]]], "lines": ["新人？"]}, {"box": [1074, 1091, 1184, 1339], "vertical": true, "font_size": 34, "lines_coords": [[[1148.0, 1095.0], [1184.0, 1095.0], [1184.0, 1252.0], [1148.0, 1252.0]], [[1115.0, 1097.0], [1144.0, 1097.0], [1144.0, 1339.0], [1115.0, 1339.0]], [[1074.0, 1091.0], [1109.0, 1091.0], [1109.0, 1219.0], [1074.0, 1219.0]]], "lines": ["田中さんて", "お、俺とタメって", "聞いて．．"]}, {"box": [190, 1115, 301, 1302], "vertical": true, "font_size": 35, "lines_coords": [[[264.0, 1117.0], [300.0, 1117.0], [300.0, 1302.0], [264.0, 1302.0]], [[227.0, 1115.0], [262.0, 1115.0], [262.0, 1302.0], [227.0, 1302.0]], [[190.0, 1115.0], [225.0, 1115.0], [225.0, 1298.0], [190.0, 1298.0]]], "lines": ["こ、高校って", "ドコだったん", "ですか．．．．．？"]}], "img_path": "170.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1235, 82, 1266, 248], "vertical": true, "font_size": 28, "lines_coords": [[[1235.0, 82.0], [1264.0, 82.0], [1266.0, 248.0], [1237.0, 248.0]]], "lines": ["：無駄無駄。"]}, {"box": [1070, 167, 1173, 351], "vertical": true, "font_size": 28, "lines_coords": [[[1144.0, 169.0], [1173.0, 169.0], [1173.0, 351.0], [1144.0, 351.0]], [[1107.0, 167.0], [1134.0, 167.0], [1134.0, 351.0], [1107.0, 351.0]], [[1070.0, 169.0], [1099.0, 169.0], [1099.0, 304.0], [1070.0, 304.0]]], "lines": ["話しかけても", "まともに返事", "しねえよ。"]}, {"box": [817, 109, 919, 325], "vertical": true, "font_size": 30, "lines_coords": [[[890.0, 111.0], [919.0, 111.0], [919.0, 322.0], [890.0, 322.0]], [[850.0, 109.0], [886.0, 109.0], [886.0, 302.0], [850.0, 302.0]], [[817.0, 109.0], [844.0, 109.0], [844.0, 325.0], [817.0, 325.0]]], "lines": ["．．．ウチの社長の", "義理の妹の娘、", "だったっけな？"]}, {"box": [623, 339, 799, 616], "vertical": true, "font_size": 30, "lines_coords": [[[770.0, 341.0], [799.0, 341.0], [799.0, 527.0], [770.0, 527.0]], [[732.0, 339.0], [759.0, 339.0], [759.0, 552.0], [732.0, 552.0]], [[697.0, 345.0], [726.0, 345.0], [726.0, 527.0], [697.0, 527.0]], [[656.0, 341.0], [687.0, 341.0], [689.0, 616.0], [658.0, 616.0]], [[623.0, 343.0], [652.0, 343.0], [652.0, 536.0], [623.0, 536.0]]], "lines": ["あいつの母親", "社長に散々金の", "無心した挙句", "腰悪くして動けなく", "なったんだと。"]}, {"box": [248, 262, 354, 457], "vertical": true, "font_size": 30, "lines_coords": [[[318.0, 262.0], [354.0, 262.0], [354.0, 389.0], [318.0, 389.0]], [[285.0, 267.0], [314.0, 267.0], [314.0, 449.0], [285.0, 449.0]], [[248.0, 265.0], [277.0, 265.0], [277.0, 457.0], [248.0, 457.0]]], "lines": ["とんずら", "しないように", "娘連れて来て、"]}, {"box": [1153, 898, 1295, 1142], "vertical": true, "font_size": 33, "lines_coords": [[[1260.0, 898.0], [1295.0, 898.0], [1295.0, 1026.0], [1260.0, 1026.0]], [[1223.0, 900.0], [1254.0, 900.0], [1256.0, 1142.0], [1225.0, 1142.0]], [[1190.0, 902.0], [1219.0, 902.0], [1219.0, 1084.0], [1190.0, 1084.0]], [[1153.0, 900.0], [1182.0, 900.0], [1182.0, 1124.0], [1153.0, 1124.0]]], "lines": ["娘は娘で", "アイドルの真似事", "みたいな仕事", "やってたんだと。"]}, {"box": [153, 536, 331, 763], "vertical": true, "font_size": 30, "lines_coords": [[[302.0, 538.0], [331.0, 538.0], [331.0, 722.0], [302.0, 722.0]], [[262.0, 538.0], [298.0, 538.0], [298.0, 666.0], [262.0, 666.0]], [[227.0, 538.0], [256.0, 538.0], [256.0, 761.0], [227.0, 761.0]], [[190.0, 536.0], [219.0, 536.0], [219.0, 751.0], [190.0, 751.0]], [[153.0, 536.0], [180.0, 536.0], [180.0, 763.0], [153.0, 763.0]]], "lines": ["馬鹿みたいな", "低賃金で", "働かされてるよ。", "まァ本人も馬鹿", "なんだろうけど。"]}, {"box": [360, 958, 426, 1122], "vertical": true, "font_size": 28, "lines_coords": [[[397.0, 958.0], [426.0, 958.0], [426.0, 1120.0], [397.0, 1120.0]], [[360.0, 958.0], [389.0, 958.0], [389.0, 1122.0], [360.0, 1122.0]]], "lines": ["色気もねえ、", "愛想もねえ。"]}, {"box": [983, 1051, 1132, 1296], "vertical": true, "font_size": 33, "lines_coords": [[[1099.0, 1055.0], [1130.0, 1055.0], [1132.0, 1238.0], [1101.0, 1238.0]], [[1062.0, 1055.0], [1093.0, 1055.0], [1097.0, 1235.0], [1066.0, 1235.0]], [[1028.0, 1057.0], [1057.0, 1057.0], [1057.0, 1296.0], [1028.0, 1296.0]], [[983.0, 1051.0], [1030.0, 1051.0], [1030.0, 1138.0], [983.0, 1138.0]]], "lines": ["親子そろって", "ろくでなしの", "血でも流れてんの", "かね。"]}, {"box": [1204, 1416, 1311, 1631], "vertical": true, "font_size": 29, "lines_coords": [[[1281.0, 1420.0], [1310.0, 1420.0], [1310.0, 1629.0], [1281.0, 1629.0]], [[1244.0, 1420.0], [1273.0, 1420.0], [1273.0, 1629.0], [1244.0, 1629.0]], [[1206.0, 1416.0], [1235.0, 1416.0], [1233.0, 1600.0], [1204.0, 1600.0]]], "lines": ["．．．や、えっと．．．", "聞こえちゃって", "ませんか．．．？"]}, {"box": [527, 1436, 604, 1602], "vertical": true, "font_size": 35, "lines_coords": [[[573.0, 1532.0], [602.0, 1532.0], [602.0, 1602.0], [573.0, 1602.0]], [[565.0, 1436.0], [604.0, 1436.0], [604.0, 1517.0], [565.0, 1517.0]], [[527.0, 1438.0], [563.0, 1438.0], [563.0, 1587.0], [527.0, 1587.0]]], "lines": ["―ア", "なー", "お前さァ。"]}, {"box": [178, 1091, 279, 1304], "vertical": true, "font_size": 28, "lines_coords": [[[250.0, 1091.0], [279.0, 1091.0], [279.0, 1273.0], [250.0, 1273.0]], [[213.0, 1093.0], [242.0, 1093.0], [242.0, 1304.0], [213.0, 1304.0]], [[178.0, 1093.0], [204.0, 1093.0], [204.0, 1285.0], [178.0, 1285.0]]], "lines": ["あんなんじゃ", "枕営業したって", "仕事ねえだろ。"]}, {"box": [921, 1788, 1035, 1972], "vertical": true, "font_size": 34, "lines_coords": [[[997.0, 1788.0], [1035.0, 1788.0], [1035.0, 1888.0], [997.0, 1888.0]], [[964.0, 1792.0], [993.0, 1792.0], [993.0, 1970.0], [964.0, 1970.0]], [[921.0, 1790.0], [956.0, 1790.0], [960.0, 1927.0], [925.0, 1927.0]]], "lines": ["どうせ", "なんも言って", "こねーよ。"]}, {"box": [153, 1767, 273, 1970], "vertical": true, "font_size": 34, "lines_coords": [[[236.0, 1768.0], [273.0, 1768.0], [273.0, 1964.0], [236.0, 1964.0]], [[194.0, 1768.0], [229.0, 1768.0], [229.0, 1970.0], [194.0, 1970.0]], [[153.0, 1768.0], [182.0, 1768.0], [182.0, 1966.0], [153.0, 1966.0]]], "lines": ["今まで何人の", "チンコくわえ", "たんだァー？"]}], "img_path": "171.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1204, 118, 1244, 279], "vertical": true, "font_size": 36, "lines_coords": [[[1208.0, 118.0], [1244.0, 118.0], [1240.0, 279.0], [1204.0, 279.0]]], "lines": ["ちょっと．．．"]}, {"box": [1128, 306, 1165, 430], "vertical": true, "font_size": 36, "lines_coords": [[[1128.0, 306.0], [1165.0, 306.0], [1165.0, 430.0], [1128.0, 430.0]]], "lines": ["あの．．．"]}, {"box": [175, 674, 300, 884], "vertical": true, "font_size": 39, "lines_coords": [[[254.0, 674.0], [300.0, 674.0], [300.0, 788.0], [254.0, 788.0]], [[217.0, 679.0], [252.0, 679.0], [252.0, 884.0], [217.0, 884.0]], [[175.0, 676.0], [211.0, 676.0], [211.0, 884.0], [175.0, 884.0]]], "lines": ["それは", "言いすぎだと", "思います．．．！！"]}, {"box": [1138, 1045, 1298, 1254], "vertical": true, "font_size": 34, "lines_coords": [[[1262.0, 1049.0], [1298.0, 1049.0], [1298.0, 1254.0], [1262.0, 1254.0]], [[1225.0, 1049.0], [1254.0, 1049.0], [1254.0, 1219.0], [1225.0, 1219.0]], [[1177.0, 1049.0], [1213.0, 1049.0], [1213.0, 1250.0], [1177.0, 1250.0]], [[1138.0, 1045.0], [1173.0, 1045.0], [1173.0, 1184.0], [1138.0, 1184.0]]], "lines": ["女性に対して", "その発言は", "最低じゃない", "ですか！？"]}, {"box": [1088, 1327, 1202, 1561], "vertical": true, "font_size": 34, "lines_coords": [[[1167.0, 1327.0], [1202.0, 1327.0], [1202.0, 1498.0], [1167.0, 1498.0]], [[1126.0, 1327.0], [1161.0, 1327.0], [1161.0, 1561.0], [1126.0, 1561.0]], [[1088.0, 1327.0], [1117.0, 1327.0], [1117.0, 1496.0], [1088.0, 1496.0]]], "lines": ["少なくとも", "完全にセクハラ", "ですよッ！！"]}, {"box": [836, 1146, 886, 1324], "vertical": true, "font_size": 50, "lines_coords": [[[836.0, 1146.0], [886.0, 1146.0], [886.0, 1217.0], [836.0, 1217.0]]], "lines": ["あー"]}, {"box": [476, 1120, 637, 1393], "vertical": true, "font_size": 34, "lines_coords": [[[606.0, 1126.0], [635.0, 1126.0], [635.0, 1258.0], [606.0, 1258.0]], [[561.0, 1120.0], [596.0, 1120.0], [594.0, 1362.0], [558.0, 1362.0]], [[519.0, 1122.0], [554.0, 1122.0], [554.0, 1327.0], [519.0, 1327.0]], [[476.0, 1120.0], [511.0, 1120.0], [511.0, 1393.0], [476.0, 1393.0]]], "lines": ["あなたは", "相手の気持ちを", "想像する力が", "ないんですかッ！？"]}, {"box": [169, 1471, 250, 1625], "vertical": true, "font_size": 40, "lines_coords": [[[204.0, 1471.0], [250.0, 1471.0], [250.0, 1581.0], [204.0, 1581.0]], [[169.0, 1476.0], [204.0, 1476.0], [204.0, 1625.0], [169.0, 1625.0]]], "lines": ["あるよ", "いっぱい。"]}, {"box": [662, 1751, 823, 1985], "vertical": true, "font_size": 35, "lines_coords": [[[788.0, 1753.0], [823.0, 1753.0], [823.0, 1927.0], [788.0, 1927.0]], [[747.0, 1753.0], [782.0, 1753.0], [782.0, 1985.0], [747.0, 1985.0]], [[705.0, 1751.0], [741.0, 1751.0], [736.0, 1956.0], [701.0, 1956.0]], [[662.0, 1751.0], [697.0, 1751.0], [697.0, 1890.0], [662.0, 1890.0]]], "lines": ["そんなの僕", "黙って見てるの", "ちょっと無理", "ですね！！"]}, {"box": [163, 1815, 242, 2018], "vertical": true, "font_size": 34, "lines_coords": [[[207.0, 1817.0], [242.0, 1817.0], [242.0, 1985.0], [207.0, 1985.0]], [[163.0, 1815.0], [198.0, 1815.0], [198.0, 2018.0], [163.0, 2018.0]]], "lines": ["田中さんも", "何か言ったら"]}, {"box": [124, 1879, 155, 1948], "vertical": true, "font_size": 34, "lines_coords": [[[124.0, 1879.0], [155.0, 1879.0], [155.0, 1948.0], [124.0, 1948.0]]], "lines": ["．．．！！"]}], "img_path": "172.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1192, 869, 1229, 1086], "vertical": true, "font_size": 35, "lines_coords": [[[1192.0, 869.0], [1227.0, 869.0], [1227.0, 1082.0], [1192.0, 1082.0]]], "lines": ["．．．ほっといて。"]}, {"box": [239, 1318, 318, 1536], "vertical": true, "font_size": 36, "lines_coords": [[[275.0, 1318.0], [318.0, 1318.0], [318.0, 1426.0], [275.0, 1426.0]], [[240.0, 1325.0], [269.0, 1325.0], [269.0, 1532.0], [240.0, 1532.0]]], "lines": ["余計な", "お世話だから。"]}, {"box": [699, 1794, 776, 1996], "vertical": true, "font_size": 32, "lines_coords": [[[741.0, 1794.0], [776.0, 1794.0], [776.0, 1964.0], [741.0, 1964.0]], [[701.0, 1799.0], [730.0, 1799.0], [730.0, 1995.0], [701.0, 1995.0]]], "lines": ["：田中さん", "朗報ですヨ！！"]}], "img_path": "173.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1117, 95, 1225, 343], "vertical": true, "font_size": 31, "lines_coords": [[[1190.0, 95.0], [1225.0, 95.0], [1225.0, 343.0], [1190.0, 343.0]], [[1153.0, 95.0], [1182.0, 95.0], [1182.0, 308.0], [1153.0, 308.0]], [[1117.0, 95.0], [1146.0, 95.0], [1146.0, 281.0], [1117.0, 281.0]]], "lines": ["先生は肉体を捨て", "ソウル体に昇格", "されました．．．"]}, {"box": [933, 279, 1074, 523], "vertical": true, "font_size": 31, "lines_coords": [[[1041.0, 279.0], [1072.0, 279.0], [1074.0, 523.0], [1043.0, 523.0]], [[1006.0, 281.0], [1035.0, 281.0], [1035.0, 494.0], [1006.0, 494.0]], [[966.0, 279.0], [1001.0, 279.0], [1001.0, 467.0], [966.0, 467.0]], [[933.0, 281.0], [962.0, 281.0], [962.0, 494.0], [933.0, 494.0]]], "lines": ["しかし組織経営は", "我々「主婦部」が", "引き継ぐ事に", "決まりました！！"]}, {"box": [602, 80, 749, 417], "vertical": true, "font_size": 31, "lines_coords": [[[716.0, 84.0], [745.0, 84.0], [745.0, 362.0], [716.0, 362.0]], [[674.0, 82.0], [710.0, 82.0], [710.0, 364.0], [674.0, 364.0]], [[641.0, 80.0], [672.0, 80.0], [670.0, 416.0], [639.0, 416.0]], [[602.0, 82.0], [631.0, 82.0], [631.0, 360.0], [602.0, 360.0]]], "lines": ["本部は北地区へ移し", "大池氏を代表に迎え", "「コスモさん健康の森」へ", "生まれ変わります！！"]}, {"box": [360, 387, 428, 581], "vertical": true, "font_size": 28, "lines_coords": [[[399.0, 391.0], [428.0, 391.0], [428.0, 544.0], [399.0, 544.0]], [[360.0, 387.0], [389.0, 387.0], [391.0, 581.0], [362.0, 581.0]]], "lines": ["笑顔と健康", "．．．そして調和。"]}, {"box": [198, 608, 337, 821], "vertical": true, "font_size": 28, "lines_coords": [[[308.0, 608.0], [337.0, 608.0], [337.0, 790.0], [308.0, 790.0]], [[271.0, 608.0], [300.0, 608.0], [300.0, 792.0], [271.0, 792.0]], [[236.0, 608.0], [262.0, 608.0], [262.0, 790.0], [236.0, 790.0]], [[198.0, 608.0], [227.0, 608.0], [227.0, 821.0], [198.0, 821.0]]], "lines": ["先生の理念を", "継承し今後も", "全民の幸せを", "祈りましょう！！"]}, {"box": [1202, 1519, 1246, 1660], "vertical": true, "font_size": 42, "lines_coords": [[[1202.0, 1519.0], [1246.0, 1519.0], [1246.0, 1660.0], [1202.0, 1660.0]]], "lines": ["．．．アッ！！"]}, {"box": [1066, 1666, 1180, 1886], "vertical": true, "font_size": 42, "lines_coords": [[[1134.0, 1666.0], [1180.0, 1666.0], [1180.0, 1768.0],