0, 420.0], [285.0, 420.0]]], "lines": ["「そういう事じゃ", "ない．．．．．．．．"]}, {"box": [816, 1830, 853, 2038], "vertical": true, "font_size": 37, "lines_coords": [[[816.0, 1830.0], [853.0, 1830.0], [853.0, 2038.0], [816.0, 2038.0]]], "lines": ["：フンブンは、"]}, {"box": [672, 1826, 851, 2040], "vertical": true, "font_size": 35, "lines_coords": [[[815.0, 1830.0], [850.0, 1830.0], [850.0, 2035.0], [815.0, 2035.0]]], "lines": ["．．．フンフンは"]}, {"box": [669, 1830, 702, 2012], "vertical": true, "font_size": 27, "lines_coords": [[[670.0, 1832.0], [697.0, 1832.0], [697.0, 2004.0], [670.0, 2004.0]]], "lines": ["思いました。"]}], "img_path": "055.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [654, 627, 736, 873], "vertical": true, "font_size": 36.0, "lines_coords": [[[701.0, 627.0], [736.0, 627.0], [736.0, 873.0], [701.0, 873.0]], [[664.0, 650.0], [701.0, 652.0], [691.0, 869.0], [654.0, 867.0]]], "lines": ["裏通学路に", "転車はスピ"]}, {"box": [701, 1130, 746, 1299], "vertical": true, "font_size": 38, "lines_coords": [[[705.0, 1132.0], [743.0, 1132.0], [739.0, 1293.0], [701.0, 1293.0]]], "lines": ["「自分で」"]}], "img_path": "056.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [726, 969, 806, 1159], "vertical": true, "font_size": 35, "lines_coords": [[[770.0, 970.0], [805.0, 970.0], [805.0, 1124.0], [770.0, 1124.0]], [[726.0, 973.0], [761.0, 973.0], [761.0, 1159.0], [726.0, 1159.0]]], "lines": ["「．．．こんな", "顔だっけ？」"]}], "img_path": "057.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [552, 548, 604, 741], "vertical": true, "font_size": 52, "lines_coords": [[[552.0, 548.0], [604.0, 548.0], [604.0, 741.0], [552.0, 741.0]]], "lines": ["．．．"]}, {"box": [726, 670, 902, 747], "vertical": false, "font_size": 35.0, "lines_coords": [[[761.0, 670.0], [877.0, 670.0], [877.0, 705.0], [761.0, 705.0]], [[726.0, 712.0], [902.0, 712.0], [902.0, 747.0], [726.0, 747.0]]], "lines": ["月", "撤去しました"]}, {"box": [714, 784, 898, 863], "vertical": false, "font_size": 25.0, "lines_coords": [[[714.0, 784.0], [815.0, 784.0], [815.0, 813.0], [714.0, 813.0]], [[728.0, 811.0], [894.0, 815.0], [894.0, 838.0], [728.0, 834.0]], [[732.0, 838.0], [898.0, 840.0], [898.0, 863.0], [732.0, 861.0]]], "lines": ["返還手数料", "最新車・３，０００円", "最低４０００円"]}, {"box": [710, 900, 915, 946], "vertical": false, "font_size": 20.5, "lines_coords": [[[710.0, 900.0], [915.0, 900.0], [915.0, 921.0], [710.0, 921.0]], [[720.0, 921.0], [908.0, 925.0], [908.0, 946.0], [720.0, 941.0]]], "lines": ["そうなる様々なと、彼女します", "ちゃんちょっともいいでしょうか？"]}], "img_path": "058.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1190, 159, 1307, 482], "vertical": true, "font_size": 35, "lines_coords": [[[1269.0, 159.0], [1304.0, 159.0], [1304.0, 302.0], [1269.0, 302.0]], [[1227.0, 163.0], [1262.0, 163.0], [1262.0, 368.0], [1227.0, 368.0]]], "lines": ["子供の頃", "愛子ちゃんは"]}, {"box": [1190, 163, 1219, 474], "vertical": true, "font_size": 32, "lines_coords": [[[1190.0, 163.0], [1219.0, 163.0], [1219.0, 474.0], [1190.0, 474.0]]], "lines": ["こう言っていました。"]}, {"box": [968, 161, 1132, 480], "vertical": true, "font_size": 32, "lines_coords": [[[1097.0, 163.0], [1132.0, 163.0], [1132.0, 351.0], [1097.0, 351.0]], [[1053.0, 163.0], [1088.0, 163.0], [1088.0, 436.0], [1053.0, 436.0]], [[1014.0, 161.0], [1043.0, 161.0], [1043.0, 432.0], [1014.0, 432.0]], [[970.0, 161.0], [1001.0, 161.0], [999.0, 480.0], [968.0, 480.0]]], "lines": ["「あと数年で", "石油が無くなって", "環境も破壊されて", "人類は減亡する。」と。"]}, {"box": [554, 43, 837, 515], "vertical": true, "font_size": 113, "lines_coords": [[[755.0, 157.0], [834.0, 159.0], [826.0, 482.0], [747.0, 480.0]], [[666.0, 53.0], [778.0, 60.0], [759.0, 436.0], [647.0, 430.0]], [[554.0, 43.0], [701.0, 43.0], [701.0, 498.0], [554.0, 498.0]]], "lines": ["それにせよ", "今のお前が", "お前のすべて"]}, {"box": [656, 612, 738, 896], "vertical": true, "font_size": 38, "lines_coords": [[[701.0, 616.0], [736.0, 616.0], [736.0, 886.0], [701.0, 886.0]], [[656.0, 612.0], [697.0, 612.0], [697.0, 896.0], [656.0, 896.0]]], "lines": ["真に受けた自分は", "このような有様で、"]}, {"box": [258, 614, 459, 888], "vertical": true, "font_size": 30, "lines_coords": [[[426.0, 619.0], [455.0, 619.0], [455.0, 819.0], [426.0, 819.0]], [[380.0, 616.0], [416.0, 616.0], [416.0, 855.0], [380.0, 855.0]], [[341.0, 619.0], [370.0, 619.0], [370.0, 788.0], [341.0, 788.0]], [[300.0, 619.0], [329.0, 619.0], [329.0, 886.0], [300.0, 886.0]], [[258.0, 616.0], [287.0, 616.0], [287.0, 755.0], [258.0, 755.0]]], "lines": ["愛子ちゃんは", "何事も無かった", "かのように", "しれっとさらっと", "夢を叶え"]}, {"box": [1213, 1003, 1274, 1522], "vertical": true, "font_size": 49, "lines_coords": [[[1217.0, 1095.0], [1266.0, 1095.0], [1266.0, 1513.0], [1217.0, 1513.0]]], "lines": ["ンプンは．．．：：："]}, {"box": [200, 1004, 277, 1592], "vertical": true, "font_size": 77, "lines_coords": [[[200.0, 1004.0], [277.0, 1004.0], [277.0, 1592.0], [200.0, 1592.0]]], "lines": ["嘘つかないもんね？"]}, {"box": [761, 1741, 797, 1935], "vertical": true, "font_size": 36, "lines_coords": [[[761.0, 1741.0], [797.0, 1741.0], [797.0, 1935.0], [761.0, 1935.0]]], "lines": ["．．．嘘つきは"]}, {"box": [666, 1739, 703, 1912], "vertical": true, "font_size": 36, "lines_coords": [[[666.0, 1739.0], [703.0, 1739.0], [703.0, 1912.0], [666.0, 1912.0]]], "lines": ["お前だろ。"]}], "img_path": "059.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1221, 1399, 1277, 1492], "vertical": true, "font_size": 56, "lines_coords": [[[1221.0, 1399.0], [1277.0, 1399.0], [1277.0, 1492.0], [1221.0, 1492.0]]], "lines": ["ん？"]}, {"box": [637, 1451, 757, 1623], "vertical": true, "font_size": 39, "lines_coords": [[[720.0, 1455.0], [757.0, 1455.0], [757.0, 1623.0], [720.0, 1623.0]], [[674.0, 1451.0], [720.0, 1451.0], [720.0, 1587.0], [674.0, 1587.0]], [[637.0, 1455.0], [672.0, 1455.0], [672.0, 1621.0], [637.0, 1621.0]]], "lines": ["この面子で", "プンプン", "いないの？"]}, {"box": [459, 1432, 496, 1583], "vertical": true, "font_size": 37, "lines_coords": [[[459.0, 1432.0], [496.0, 1432.0], [496.0, 1581.0], [459.0, 1581.0]]], "lines": ["．．．ふうん。"]}, {"box": [1159, 1716, 1302, 1991], "vertical": true, "font_size": 32, "lines_coords": [[[1266.0, 1720.0], [1302.0, 1720.0], [1302.0, 1964.0], [1266.0, 1964.0]], [[1229.0, 1716.0], [1264.0, 1716.0], [1258.0, 1962.0], [1223.0, 1962.0]], [[1194.0, 1720.0], [1223.0, 1720.0], [1223.0, 1991.0], [1194.0, 1991.0]], [[1159.0, 1720.0], [1188.0, 1720.0], [1188.0, 1977.0], [1159.0, 1977.0]]], "lines": ["連絡したんすけど", "生意気にあの野郎", "今週一杯なんか用事", "あるとかなんとか。"]}, {"box": [167, 1774, 281, 2004], "vertical": true, "font_size": 38, "lines_coords": [[[244.0, 1778.0], [281.0, 1778.0], [281.0, 1948.0], [244.0, 1948.0]], [[204.0, 1778.0], [244.0, 1778.0], [244.0, 1873.0], [204.0, 1873.0]], [[167.0, 1774.0], [202.0, 1774.0], [207.0, 2004.0], [171.0, 2004.0]]], "lines": ["．．．アレ、南条", "珍しい", "飴なんて食べて。"]}], "img_path": "060.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1097, 64, 1203, 311], "vertical": true, "font_size": 28, "lines_coords": [[[1171.0, 70.0], [1200.0, 70.0], [1200.0, 233.0], [1171.0, 233.0]], [[1136.0, 68.0], [1163.0, 68.0], [1163.0, 281.0], [1136.0, 281.0]], [[1097.0, 64.0], [1126.0, 64.0], [1126.0, 310.0], [1097.0, 310.0]]], "lines": ["．．．禁煙だよ。", "あんな高いもん", "買ってられるか！！"]}, {"box": [776, 84, 854, 292], "vertical": true, "font_size": 39, "lines_coords": [[[811.0, 84.0], [854.0, 84.0], [854.0, 196.0], [811.0, 196.0]], [[776.0, 86.0], [811.0, 86.0], [811.0, 291.0], [776.0, 291.0]]], "lines": ["なんか", "悩んでます？"]}, {"box": [968, 726, 1039, 886], "vertical": true, "font_size": 34, "lines_coords": [[[1001.0, 726.0], [1039.0, 728.0], [1033.0, 886.0], [995.0, 884.0]], [[968.0, 730.0], [997.0, 730.0], [997.0, 881.0], [968.0, 881.0]]], "lines": ["あのー．．．", "南条さん？"]}, {"box": [724, 664, 828, 878], "vertical": true, "font_size": 29, "lines_coords": [[[797.0, 664.0], [826.0, 664.0], [826.0, 813.0], [797.0, 813.0]], [[761.0, 666.0], [790.0, 