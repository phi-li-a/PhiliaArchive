_size": 29, "lines_coords": [[[739.0, 842.0], [768.0, 842.0], [770.0, 1057.0], [741.0, 1057.0]], [[701.0, 844.0], [730.0, 844.0], [730.0, 1086.0], [701.0, 1086.0]], [[662.0, 844.0], [691.0, 844.0], [691.0, 1115.0], [662.0, 1115.0]], [[627.0, 844.0], [656.0, 844.0], [656.0, 1072.0], [627.0, 1072.0]]], "lines": ["俺もさっきまで", "喫茶店でコーヒー", "すすりこほしながら", "勉強してたし！！」"]}, {"box": [186, 530, 364, 772], "vertical": true, "font_size": 35, "lines_coords": [[[335.0, 530.0], [364.0, 530.0], [364.0, 772.0], [335.0, 772.0]], [[302.0, 532.0], [331.0, 532.0], [331.0, 743.0], [302.0, 743.0]], [[264.0, 530.0], [293.0, 530.0], [293.0, 743.0], [264.0, 743.0]], [[227.0, 530.0], [256.0, 530.0], [256.0, 712.0], [227.0, 712.0]], [[186.0, 530.0], [221.0, 530.0], [221.0, 654.0], [186.0, 654.0]]], "lines": ["カメラマンさんが", "グアム土産って", "くれたんだけど", "食べきれない", "から．．．"]}, {"box": [1240, 1217, 1281, 1271], "vertical": true, "font_size": 39, "lines_coords": [[[1240.0, 1217.0], [1281.0, 1217.0], [1281.0, 1271.0], [1240.0, 1271.0]]], "lines": ["んー"]}, {"box": [1167, 1372, 1244, 1532], "vertical": true, "font_size": 39, "lines_coords": [[[1196.0, 1372.0], [1244.0, 1372.0], [1244.0, 1449.0], [1196.0, 1449.0]], [[1167.0, 1378.0], [1196.0, 1378.0], [1196.0, 1532.0], [1167.0, 1532.0]]], "lines": ["どこ", "行こうか？"]}, {"box": [1182, 1782, 1285, 1992], "vertical": true, "font_size": 28, "lines_coords": [[[1254.0, 1782.0], [1283.0, 1782.0], [1283.0, 1991.0], [1254.0, 1991.0]], [[1217.0, 1784.0], [1246.0, 1784.0], [1246.0, 1962.0], [1217.0, 1962.0]], [[1182.0, 1782.0], [1208.0, 1782.0], [1208.0, 1962.0], [1182.0, 1962.0]]], "lines": ["もしプンプンが", "知ってるお店", "あるなら．．．．．"]}, {"box": [631, 1581, 703, 1710], "vertical": true, "font_size": 35, "lines_coords": [[[668.0, 1583.0], [703.0, 1583.0], [699.0, 1710.0], [664.0, 1710.0]], [[631.0, 1581.0], [666.0, 1581.0], [666.0, 1708.0], [631.0, 1708.0]]], "lines": ["もうタカ", "だし．．．"]}], "img_path": "063.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1180, 1755, 1223, 1881], "vertical": true, "font_size": 43, "lines_coords": [[[1180.0, 1755.0], [1223.0, 1755.0], [1223.0, 1881.0], [1180.0, 1881.0]]], "lines": ["．．．ん？"]}, {"box": [482, 1755, 520, 1909], "vertical": true, "font_size": 37, "lines_coords": [[[482.0, 1755.0], [519.0, 1755.0], [519.0, 1908.0], [482.0, 1908.0]]], "lines": ["「．．．別に？"]}, {"box": [285, 1755, 366, 1945], "vertical": true, "font_size": 38, "lines_coords": [[[320.0, 1755.0], [366.0, 1755.0], [366.0, 1865.0], [320.0, 1865.0]], [[285.0, 1759.0], [314.0, 1759.0], [314.0, 1939.0], [285.0, 1939.0]]], "lines": ["じゃあ", "行こっか！！」"]}], "img_path": "064.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [], "img_path": "065.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [], "img_path": "066.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1221, 146, 1289, 364], "vertical": true, "font_size": 32, "lines_coords": [[[1260.0, 149.0], [1289.0, 149.0], [1289.0, 364.0], [1260.0, 364.0]], [[1221.0, 146.0], [1256.0, 146.0], [1256.0, 289.0], [1221.0, 289.0]]], "lines": ["．．．なんていうか", "やっぱり、"]}, {"box": [1053, 287, 1163, 536], "vertical": true, "font_size": 32, "lines_coords": [[[1126.0, 287.0], [1163.0, 287.0], [1163.0, 416.0], [1126.0, 416.0]], [[1090.0, 289.0], [1119.0, 289.0], [1119.0, 536.0], [1090.0, 536.0]], [[1053.0, 291.0], [1082.0, 291.0], [1082.0, 453.0], [1053.0, 453.0]]], "lines": ["プンプン", "わかってるなァー", "っていうか。"]}, {"box": [349, 285, 455, 567], "vertical": true, "font_size": 31, "lines_coords": [[[426.0, 289.0], [455.0, 289.0], [455.0, 472.0], [426.0, 472.0]], [[385.0, 287.0], [420.0, 287.0], [420.0, 567.0], [385.0, 567.0]], [[351.0, 285.0], [380.0, 285.0], [378.0, 486.0], [349.0, 486.0]]], "lines": ["私もちょうど", "あの映画観たいって", "思ってたんだ。"]}, {"box": [39, 374, 111, 604], "vertical": true, "font_size": 72, "lines_coords": [[[39.0, 374.0], [111.0, 374.0], [111.0, 604.0], [39.0, 604.0]]], "lines": ["第１０に話"]}, {"box": [296, 530, 335, 695], "vertical": true, "font_size": 31, "lines_coords": [[[296.0, 530.0], [331.0, 530.0], [335.0, 695.0], [300.0, 695.0]]], "lines": ["もしかして"]}, {"box": [227, 534, 334, 784], "vertical": true, "font_size": 36, "lines_coords": [[[262.0, 534.0], [298.0, 534.0], [298.0, 784.0], [262.0, 784.0]]], "lines": ["私とも映画の趣味"]}, {"box": [225, 534, 256, 720], "vertical": true, "font_size": 31, "lines_coords": [[[227.0, 534.0], [256.0, 534.0], [254.0, 720.0], [225.0, 720.0]]], "lines": ["合うのかも？"]}, {"box": [1233, 1447, 1269, 1602], "vertical": true, "font_size": 36, "lines_coords": [[[1233.0, 1447.0], [1269.0, 1447.0], [1269.0, 1600.0], [1233.0, 1600.0]]], "lines": ["．．．そうだ"]}, {"box": [251, 1095, 360, 1327], "vertical": true, "font_size": 30, "lines_coords": [[[320.0, 1095.0], [356.0, 1095.0], [360.0, 1256.0], [325.0, 1256.0]], [[289.0, 1099.0], [318.0, 1099.0], [318.0, 1314.0], [289.0, 1314.0]], [[252.0, 1097.0], [279.0, 1097.0], [279.0, 1322.0], [252.0, 1322.0]]], "lines": ["．．．なーんて", "言ったら彼女に", "怒られちゃうか。"]}, {"box": [604, 1772, 749, 2020], "vertical": true, "font_size": 32, "lines_coords": [[[714.0, 1776.0], [749.0, 1776.0], [749.0, 1931.0], [714.0, 1931.0]], [[676.0, 1772.0], [712.0, 1772.0], [710.0, 2020.0], [674.0, 2020.0]], [[639.0, 1778.0], [668.0, 1778.0], [668.0, 1991.0], [639.0, 1991.0]], [[604.0, 1776.0], [633.0, 1776.0], [633.0, 1929.0], [604.0, 1929.0]]], "lines": ["この近くに", "すっごくかわいい", "カフェがあるん", "だけど．．．"]}, {"box": [171, 1755, 242, 1973], "vertical": true, "font_size": 31, "lines_coords": [[[207.0, 1755.0], [242.0, 1755.0], [238.0, 1973.0], [202.0, 1973.0]], [[171.0, 1759.0], [198.0, 1759.0], [198.0, 1927.0], [171.0, 1927.0]]], "lines": ["友達がやってる", "お店なんだ。"]}], "img_path": "067.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1101, 113, 1146, 331], "vertical": true, "font_size": 41, "lines_coords": [[[1105.0, 113.0], [1146.0, 113.0], [1142.0, 331.0], [1101.0, 331.0]]], "lines": ["ごめーーん．．．"]}, {"box": [563, 1443, 652, 1635], "vertical": true, "font_size": 44, "lines_coords": [[[600.0, 1443.0], [652.0, 1443.0], [652.0, 1558.0], [600.0, 1558.0]], [[563.0, 1447.0], [600.0, 1447.0], [604.0, 1635.0], [567.0, 1635.0]]], "lines": ["．．．陽が", "のびたねぇ。"]}, {"box": [231, 1078, 343, 1268], "vertical": true, "font_size": 39, "lines_coords": [[[298.0, 1078.0], [343.0, 1078.0], [343.0, 1184.0], [298.0, 1184.0]], [[262.0, 1078.0], [306.0, 1078.0], [306.0, 1211.0], [262.0, 1211.0]], [[231.0, 1082.0], [260.0, 1082.0], [260.0, 1267.0], [231.0, 1267.0]]], "lines": ["今日は", "貸し切り", "なんだって．．"]}], "img_path": "068.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1223, 66, 1295, 209], "vertical": true, "font_size": 37, "lines_coords": [[[1266.0, 70.0], [1295.0, 70.0], [1295.0, 101.0], [1266.0, 101.0]], [[1223.0, 66.0], [1258.0, 66.0], [1258.0, 209.0], [1223.0, 209.0]]], "lines": ["．．．", "そうそう。"]}, {"box": [1078, 227, 1200, 457], "vertical": true, "font_size": 37, "lines_coords": [[[1161.0, 231.0], [1200.0, 231.0], [1200.0, 331.0], [1161.0, 331.0]], [[1122.0, 233.0], [1157.0, 233.0], [1157.0, 457.0], [1122.0, 457.0]], [[1078.0, 227.0], [1126.0, 227.0], [1126.0, 312.0], [1078.0, 312.0]]], "lines": ["私達が", "はじめて喋った", "のも、"]}, {"box": [233, 575, 356, 820], "vertical": true, "font_size": 36, "lines_coords": [[[318.0, 575.0], [356.0, 575.0], [356.0, 720.0], [318.0, 720.0]], [[275.0, 577.0], [310.0, 577.0], [310.0, 819.0], [275.0, 819.0]], [[233.0, 577.0], [269.0, 577.0], [269.0, 786.0], [233.0, 786.0]]], "lines": ["ちょうど", "今くらいの時期", "だったよね？"]}, {"box": [832, 1004, 942, 1291], "vertical": true, "font_size": 29, "lines_coords": [[[910.0, 1008.0], [939.0, 1008.0], [939.0, 1192.0], [910.0, 1192.0]], [[871.0, 1008.0], [900.0, 1008.0], [900.0, 1254.0], [871.0, 1254.0]], [[832.0, 1008.0], [861.0, 1008.0], [861.0, 1285.0], [832.0, 1285.0]]], "lines": ["ほんの数日で", "全身に染み渡った", "たーくんのソウルは"]}, {"box": [639, 1005, 751, 1223], "vertical": true, "font_size": 32, "lines_coords": [[[720.0, 1008.0], [749.0, 1008.0], [749.0, 1221.0], [720.0, 1221.0]], [[681.0, 1008.0], [710.0, 1008.0], [710.0, 1192.0], [681.0, 1192.0]], [[639.0, 1008.0], [676.0, 1008.0], [676.0, 1142.0], [639.0, 1142.0]]], "lines": ["若干の拒否反応", "以外は非常に", "心地良く、"]}, {"box": [258, 1505, 480, 1944], "vertical": true, "font_size": 29, "lines_coords": [[[449.0, 1513.0], [478.0, 1513.0], [478.0, 1871.0], [449.0, 1871.0]], [[411.0, 1509.0], [440.0, 1509.0], [440.0, 1941.0], [411.0, 1941.0]], [[374.0, 1507.0], [403.0, 1507.0], [399.0, 1751.0], [370.0, 1751.0]], [[335.0, 1507.0], [364.0, 1507.0], [364.0, 1842.0], [335.0, 1842.0]], [[298.0, 1507.0], [327.0, 1507.0], [325.0, 1902.0], [296.0, 1902.0]], [[258.0, 1505.0], [287.0, 1505.0], [289.0, 1666.0], [260.0, 1666.0]]], "lines": ["一夜漬けで頭に詰め込んだ", "映画やお洒落カフェーの知識等", "心底とうでも良い", "虚飾に満ち溢れた会話が", "口先から次々とこぼれ落ちて", "ゆきました。"]}], "img_path": "069.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1237, 96, 1270, 240], "vertical": true, "font_size": 32, "lines_coords": [[[1237.0, 157.0], [1269.0, 157.0], [1269.0, 238.0], [1237.0, 238.0]]], "lines": ["え？"]}, {"box": [730, 105, 874, 362], "vertical": true, "font_size": 29, "lines_coords": [[[840.0, 105.0], [869.0, 105.0], [871.0, 360.0], [842.0, 360.0]], [[805.0, 109.0], [834.0, 109.0], [834.0, 349.0], [805.0, 349.0]], [[768.0, 107.0], [797.0, 107.0], [797.0, 258.0], [768.0, 258.0]], [[730.0, 105.0], [759.0, 105.0], [759.0, 273.0], [730.0, 273.0]]], "lines": ["なんでいいじゃん、", "こういう庶民的な", "お店も逆に", "落ちつくし。"]}, {"box": [169, 600, 313, 846], "vertical": true, "font_size": 32, "lines_coords": [[[277.0, 602.0], [308.0, 602.0], [312.0, 757.0], [281.0, 757.0]], [[238.0, 600.0], [273.0, 600.0], [277.0, 821.0], [242.0, 821.0]], [[204.0, 602.0], [233.0, 602.0], [236.0, 846.0], [207.0, 846.0]], [[169.0, 602.0], [200.0, 602.0], [200.0, 685.0], [169.0, 685.0]]], "lines": ["私も友達と", "飲む時はいつも", "安いお店ばっかり", "だよー"]}, {"box": [1111, 968, 1217, 1192], "vertical": true, "font_size": 31, "lines_coords": [[[1182.0, 968.0], [1217.0, 968.0], [1217.0, 1153.0], [1182.0, 1153.0]], [[1148.0, 968.0], [1177.0, 968.0], [1177.0, 1180.0], [1148.0, 1180.0]], [[1111.0, 968.0], [1140.0, 968.0], [1140.0, 1192.0], [1111.0, 1192.0]]], "lines": ["でもいいねぇ", "いかにも大学生", "男子って感じで。"]}, {"box": [931, 1072, 1037, 1345], "vertical": true, "font_size": 31, "lines_coords": [[[997.0, 1072.0], [1033.0, 1072.0], [1037.0, 1291.0], [1001.0, 1291.0]], [[966.0, 1074.0], [995.0, 1074.0], [995.0, 1345.0], [966.0, 1345.0]], [[931.0, 1074.0], [960.0, 1074.0], [960.0, 1227.0], [931.0, 1227.0]]], "lines": ["飾らない感じも", "プンプンらしいって", "いうか．．．"]}, {"box": [184, 1105, 221, 1310], "vertical": true, "font_size": 29, "lines_coords": [[[184.0, 1105.0], [213.0, 1105.0], [217.0, 1306.0], [188.0, 1306.0]]], "lines": ["．．．なに飲む？"]}, {"box": [941, 1782, 989, 2004], "vertical": true, "font_size": 42, "lines_coords": [[[948.0, 1782.0], [989.0, 1782.0], [983.0, 2001.0], [941.0, 2001.0]]], "lines": ["「えーーと．．．"]}, {"box": [817, 1786, 851, 1969], "vertical": true, "font_size": 29, "lines_coords": [[[817.0, 1786.0], [846.0, 1786.0], [846.0, 1964.0], [817.0, 1964.0]]], "lines": ["なまなか？」"]}, {"box": [120, 1788, 241, 1919], "vertical": true, "font_size": 38, "lines_coords": [[[188.0, 1788.0], [231.0, 1788.0], [231.0, 1919.0], [188.0, 1919.0]], [[151.0, 1788.0], [194.0, 1788.0], [194.0, 1917.0], [151.0, 1917.0]], [[120.0, 1792.0], [149.0, 1792.0], [149.0, 1912.0], [120.0, 1912.0]]], "lines": ["．．．生中で", "よろしい", "てすか？"]}], "img_path": "070.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1263, 201, 1296, 451], "vertical": true, "font_size": 27, "lines_coords": [[[1264.0, 202.0], [1291.0, 202.0], [1291.0, 451.0], [1264.0, 451.0]]], "lines": ["．．．なんでしょう。"]}, {"box": [1034, 197, 1275, 605], "vertical": true, "font_size": 31, "lines_coords": [[[1161.0, 200.0], [1192.0, 200.0], [1190.0, 602.0], [1159.0, 602.0]], [[1119.0, 202.0], [1148.0, 202.0], [1148.0, 469.0], [1119.0, 469.0]], [[1074.0, 200.0], [1109.0, 200.0], [1109.0, 505.0], [1074.0, 505.0]], [[1035.0, 200.0], [1064.0, 200.0], [1064.0, 407.0], [1035.0, 407.0]]], "lines": ["大根役者たらけのドラマを", "更にただの大根が", "再現しているような", "この虚しさは"]}, {"box": [244, 198, 451, 604], "vertical": true, "font_size": 33, "lines_coords": [[[416.0, 202.0], [445.0, 202.0], [445.0, 403.0], [416.0, 403.0]], [[370.0, 200.0], [405.0, 200.0], [405.0, 472.0], [370.0, 472.0]], [[333.0, 200.0], [362.0, 200.0], [358.0, 401.0], [329.0, 401.0]], [[287.0, 200.0], [322.0, 200.0], [322.0, 405.0], [287.0, 405.0]], [[244.0, 198.0], [279.0, 198.0], [281.0, 505.0], [246.0, 505.0]]], "lines": ["しかしながら", "先刻から猛々しく", "吃立し続ける", "我が魔勃起に", "鎮まる気配は無くー"]}, {"box": [1187, 761, 1264, 1000], "vertical": true, "font_size": 33, "lines_coords": [[[1227.0, 761.0], [1264.0, 761.0], [1264.0, 861.0], [1227.0, 861.0]], [[1190.0, 766.0], [1219.0, 766.0], [1219.0, 999.0], [1190.0, 999.0]]], "lines": ["うそー", "なにその友達？"]}, {"box": [422, 1132, 565, 1345], "vertical": true, "font_size": 31, "lines_coords": [[[536.0, 1134.0], [565.0, 1134.0], [565.0, 1287.0], [536.0, 1287.0]], [[498.0, 1134.0], [527.0, 1134.0], [527.0, 1345.0], [498.0, 1345.0]], [[461.0, 1134.0], [490.0, 1134.0], [490.0, 1314.0], [461.0, 1314.0]], [[424.0, 1132.0], [453.0, 1132.0], [451.0, 1345.0], [422.0, 1345.0]]], "lines": ["片想いの子", "捜すために部屋", "借りてるとか", "可哀相すぎる！！"]}, {"box": [217, 1382, 397, 1569], "vertical": true, "font_size": 31, "lines_coords": [[[366.0, 1387.0], [397.0, 1387.0], [393.0, 1538.0], [362.0, 1538.0]], [[329.0, 1387.0], [358.0, 1387.0], [358.0, 1567.0], [329.0, 1567.0]], [[289.0, 1382.0], [325.0, 1382.0], [320.0, 1569.0], [285.0, 1569.0]], [[252.0, 1385.0], [287.0, 1385.0], [287.0, 1540.0], [252.0, 1540.0]], [[217.0, 1385.0], [250.0, 1385.0], [250.0, 1438.0], [217.0, 1438.0]]], "lines": ["モデル友達", "紹介するから", "その子呼んで", "今度飲もう", "よー"]}, {"box": [830, 1799, 863, 1938], "vertical": true, "font_size": 33, "lines_coords": [[[830.0, 1799.0], [863.0, 1799.0], [863.0, 1938.0], [830.0, 1938.0]]], "lines": ["僕は一体"]}, {"box": [828, 1801, 863, 1937], "vertical": true, "font_size": 36, "lines_coords": [[[828.0, 1801.0], [863.0, 1801.0], [863.0, 1937.0], [828.0, 1937.0]]], "lines": ["僕は一体"]}, {"box": [734, 1801, 770, 2001], "vertical": true, "font_size": 36, "lines_coords": [[[734.0, 1801.0], [770.0, 1801.0], [770.0, 2001.0], [734.0, 2001.0]]], "lines": ["何がしたいの"]}, {"box": [641, 1801, 679, 1917], "vertical": true, "font_size": 36, "lines_coords": [[[641.0, 1801.0], [679.0, 1801.0], [679.0, 1917.0], [641.0, 1917.0]]], "lines": ["だろう。"]}], "img_path": "071.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1161, 270, 1193, 423], "vertical": true, "font_size": 29, "lines_coords": [[[1161.0, 271.0], [1190.0, 271.0], [1190.0, 422.0], [1161.0, 422.0]]], "lines": ["．．．なんか"]}, {"box": [157, 598, 285, 772], "vertical": true, "font_size": 43, "lines_coords": [[[240.0, 600.0], [285.0, 600.0], [285.0, 708.0], [240.0, 708.0]], [[204.0, 600.0], [240.0, 600.0], [240.0, 772.0], [204.0, 772.0]], [[157.0, 598.0], [204.0, 598.0], [204.0, 691.0], [157.0, 691.0]]], "lines": ["大人に", "なったねー", "私達。"]}, {"box": [619, 1302, 794, 1477], "vertical": true, "font_size": 40, "lines_coords": [[[749.0, 1302.0], [794.0, 1302.0], [794.0, 1414.0], [749.0, 1414.0]], [[683.0, 1302.0], [728.0, 1302.0], [728.0, 1414.0], [683.0, 1414.0]], [[623.0, 1308.0], [652.0, 1308.0], [652.0, 1471.0], [623.0, 1471.0]]], "lines": ["そして", "お前は", "誰なんだ？"]}, {"box": [1155, 1699, 1244, 1813], "vertical": true, "font_size": 38, "lines_coords": [[[1192.0, 1699.0], [1244.0, 1699.0], [1244.0, 1813.0], [1192.0, 1813.0]], [[1155.0, 1701.0], [1198.0, 1701.0], [1198.0, 1811.0], [1155.0, 1811.0]]], "lines": ["．．．ほら", "アレ！！"]}, {"box": [1028, 1722, 1095, 1917], "vertical": true, "font_size": 38, "lines_coords": [[[1066.0, 1724.0], [1095.0, 1724.0], [1095.0, 1844.0], [1066.0, 1844.0]], [[1028.0, 1722.0], [1057.0, 1722.0], [1057.0, 1917.0], [1028.0, 1917.0]]], "lines": ["そうそう", "あそこらへん。"]}, {"box": [171, 1792, 253, 1997], "vertical": true, "font_size": 32, "lines_coords": [[[219.0, 1797.0], [248.0, 1797.0], [248.0, 1995.0], [219.0, 1995.0]], [[175.0, 1792.0], [211.0, 1792.0], [207.0, 1962.0], [171.0, 1962.0]]], "lines": ["私達の中学校", "じゃない？"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1277, 120, 1316, 296], "vertical": true, "font_size": 33, "lines_coords": [[[1277.0, 120.0], [1312.0, 120.0], [1316.0, 296.0], [1281.0, 296.0]]], "lines": ["変だよねぇ。"]}, {"box": [1180, 356, 1254, 563], "vertical": true, "font_size": 33, "lines_coords": [[[1225.0, 360.0], [1254.0, 360.0], [1254.0, 484.0], [1225.0, 484.0]], [[1180.0, 356.0], [1215.0, 356.0], [1219.0, 563.0], [1184.0, 563.0]]], "lines": ["こんなに", "狭い街なのに。"]}, {"box": [1113, 791, 1292, 1227], "vertical": true, "font_size": 34, "lines_coords": [[[1188.0, 946.0], [1225.0, 946.0], [1225.0, 1047.0], [1188.0, 1047.0]], [[1153.0, 952.0], [1182.0, 952.0], [1182.0, 1227.0], [1153.0, 1227.0]], [[1113.0, 950.0], [1148.0, 950.0], [1148.0, 1107.0], [1113.0, 1107.0]]], "lines": ["なんか", "酔っぱらっちゃった", "かな．．．？"]}, {"box": [629, 424, 744, 705], "vertical": true, "font_size": 33, "lines_coords": [[[712.0, 428.0], [741.0, 428.0], [741.0, 614.0], [712.0, 614.0]], [[666.0, 424.0], [701.0, 424.0], [701.0, 705.0], [666.0, 705.0]], [[629.0, 424.0], [664.0, 424.0], [664.0, 554.0], [629.0, 554.0]]], "lines": ["なんで今まで", "すれ違わなかったん", "だろう？"]}, {"box": [333, 1120, 449, 1306], "vertical": true, "font_size": 36, "lines_coords": [[[397.0, 1120.0], [449.0, 1120.0], [449.0, 1196.0], [397.0, 1196.0]], [[368.0, 1122.0], [403.0, 1122.0], [403.0, 1306.0], [368.0, 1306.0]], [[333.0, 1122.0], [362.0, 1122.0], [362.0, 1273.0], [333.0, 1273.0]]], "lines": ["いや", "酔っぱらって", "ないかな？"]}, {"box": [215, 1331, 329, 1486], "vertical": true, "font_size": 36, "lines_coords": [[[289.0, 1331.0], [329.0, 1331.0], [329.0, 1432.0], [289.0, 1432.0]], [[254.0, 1333.0], [283.0, 1333.0], [283.0, 1486.0], [254.0, 1486.0]], [[215.0, 1366.0], [244.0, 1366.0], [244.0, 1428.0], [215.0, 1428.0]]], "lines": ["．．．いや", "酔ってるな", "．．．"]}, {"box": [1235, 1689, 1264, 1844], "vertical": true, "font_size": 32, "lines_coords": [[[1235.0, 1689.0], [1264.0, 1689.0], [1264.0, 1844.0], [1235.0, 1844.0]]], "lines": ["．．．なんかね"]}, {"box": [1076, 1736, 1148, 1921], "vertical": true, "font_size": 32, "lines_coords": [[[1109.0, 1736.0], [1148.0, 1736.0], [1148.0, 1801.0], [1109.0, 1801.0]], [[1076.0, 1739.0], [1105.0, 1739.0], [1105.0, 1921.0], [1076.0, 1921.0]]], "lines": ["あー", "誤解しないで"]}, {"box": [1115, 1846, 1144, 1890], "vertical": true, "font_size": 32, "lines_coords": [[[1115.0, 1846.0], [1144.0, 1846.0], [1144.0, 1890.0], [1115.0, 1890.0]]], "lines": ["．．．"]}, {"box": [1035, 1734, 1072, 1958], "vertical": true, "font_size": 32, "lines_coords": [[[1037.0, 1734.0], [1072.0, 1734.0], [1070.0, 1958.0], [1035.0, 1958.0]]], "lines": ["ほしいんだけど、"]}, {"box": [354, 1693, 538, 1906], "vertical": true, "font_size": 32, "lines_coords": [[[503.0, 1697.0], [538.0, 1697.0], [538.0, 1819.0], [503.0, 1819.0]], [[465.0, 1695.0], [500.0, 1695.0], [500.0, 1848.0], [465.0, 1848.0]], [[430.0, 1697.0], [459.0, 1697.0], [459.0, 1906.0], [430.0, 1906.0]], [[395.0, 1695.0], [424.0, 1695.0], [424.0, 1904.0], [395.0, 1904.0]], [[354.0, 1693.0], [389.0, 1693.0], [389.0, 1819.0], [354.0, 1819.0]]], "lines": ["いっつも", "こんな風に", "ナャラチャラと", "遊んでる訳じゃ", "ないよ？"]}, {"box": [196, 1809, 273, 1966], "vertical": true, "font_size": 32, "lines_coords": [[[244.0, 1813.0], [273.0, 1813.0], [273.0, 1964.0], [244.0, 1964.0]], [[196.0, 1809.0], [231.0, 1809.0], [236.0, 1966.0], [200.0, 1966.0]]], "lines": ["一応彼氏も", "いる訳だし"]}], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1113, 109, 1219, 325], "vertical": true, "font_size": 32, "lines_coords": [[[1190.0, 113.0], [1219.0, 113.0], [1219.0, 296.0], [1190.0, 296.0]], [[1151.0, 111.0], [1180.0, 111.0], [1180.0, 325.0], [1151.0, 325.0]], [[1113.0, 109.0], [1142.0, 109.0], [1142.0, 233.0], [1113.0, 233.0]]], "lines": ["．．．でもずっと", "謝りたかったん", "だ．．．．．．"]}, {"box": [997, 374, 1107, 602], "vertical": true, "font_size": 32, "lines_coords": [[[1068.0, 376.0], [1107.0, 376.0], [1107.0, 476.0], [1068.0, 476.0]], [[1035.0, 374.0], [1070.0, 374.0], [1066.0, 592.0], [1030.0, 592.0]], [[999.0, 378.0], [1028.0, 378.0], [1026.0, 602.0], [997.0, 602.0]]], "lines": ["なんか", "ずっと気まずい", "ままだったから。"]}, {"box": [349, 165, 461, 327], "vertical": true, "font_size": 32, "lines_coords": [[[422.0, 165.0], [457.0, 165.0], [461.0, 327.0], [426.0, 327.0]], [[387.0, 167.0], [418.0, 167.0], [422.0, 325.0], [391.0, 325.0]], [[349.0, 165.0], [387.0, 165.0], [387.0, 265.0], [349.0, 265.0]]], "lines": ["私も子供で", "馬鹿だった", "し．．．．．"]}, {"box": [138, 310, 316, 552], "vertical": true, "font_size": 32, "lines_coords": [[[287.0, 312.0], [316.0, 312.0], [316.0, 461.0], [287.0, 461.0]], [[246.0, 310.0], [281.0, 310.0], [281.0, 496.0], [246.0, 496.0]], [[213.0, 312.0], [240.0, 312.0], [240.0, 521.0], [213.0, 521.0]], [[173.0, 310.0], [202.0, 310.0], [202.0, 552.0], [173.0, 552.0]], [[138.0, 312.0], [169.0, 312.0], [169.0, 403.0], [138.0, 403.0]]], "lines": ["きっと色々", "嫌な思いさせ", "ちゃったんじゃ", "ないかって思って", "て．．．．．"]}, {"box": [1163, 1296, 1271, 1539], "vertical": true, "font_size": 31, "lines_coords": [[[1242.0, 1304.0], [1271.0, 1304.0], [1271.0, 1538.0], [1242.0, 1538.0]], [[1204.0, 1300.0], [1233.0, 1300.0], [1233.0, 1482.0], [1204.0, 1482.0]], [[1163.0, 1296.0], [1198.0, 1296.0], [1200.0, 1519.0], [1165.0, 1519.0]]], "lines": ["いつかこんな風に", "普通に話せる", "時が来ればって、"]}, {"box": [823, 1763, 936, 1977], "vertical": true, "font_size": 32, "lines_coords": [[[904.0, 1768.0], [933.0, 1768.0], [933.0, 1977.0], [904.0, 1977.0]], [[867.0, 1768.0], [896.0, 1768.0], [896.0, 1948.0], [867.0, 1948.0]], [[823.0, 1765.0], [861.0, 1763.0], [865.0, 1873.0], [828.0, 1875.0]]], "lines": ["．．．思ってたから", "今日はすごく", "嬉しい。"]}, {"box": [505, 1813, 541, 1980], "vertical": true, "font_size": 35, "lines_coords": [[[505.0, 1815.0], [540.0, 1815.0], [540.0, 1975.0], [505.0, 1975.0]]], "lines": ["「．．．僕も今、"]}, {"box": [362, 1812, 518, 2001], "vertical": true, "font_size": 35, "lines_coords": [[[403.0, 1817.0], [438.0, 1817.0], [438.0, 1952.0], [403.0, 1952.0]], [[362.0, 1815.0], [397.0, 1815.0], [397.0, 1999.0], [362.0, 1999.0]]], "lines": ["同じこと", "考えてた．．．」"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1215, 132, 1318, 286], "vertical": true, "font_size": 29, "lines_coords": [[[1289.0, 134.0], [1318.0, 134.0], [1318.0, 269.0], [1289.0, 269.0]], [[1250.0, 134.0], [1279.0, 134.0], [1279.0, 285.0], [1250.0, 285.0]], [[1215.0, 132.0], [1244.0, 132.0], [1244.0, 238.0], [1215.0, 238.0]]], "lines": ["．．．けどね、", "正直なこと", "言うと、"]}, {"box": [981, 97, 1122, 308], "vertical": true, "font_size": 30, "lines_coords": [[[1093.0, 99.0], [1122.0, 99.0], [1122.0, 279.0], [1093.0, 279.0]], [[1055.0, 97.0], [1084.0, 97.0], [1084.0, 308.0], [1055.0, 308.0]], [[1018.0, 97.0], [1049.0, 97.0], [1045.0, 254.0], [1014.0, 254.0]], [[981.0, 97.0], [1010.0, 97.0], [1010.0, 289.0], [981.0, 289.0]]], "lines": ["昔のプンプン", "ウジウジしてて", "ホント頼り", "なかったから、"]}, {"box": [834, 200, 937, 443], "vertical": true, "font_size": 30, "lines_coords": [[[908.0, 200.0], [937.0, 200.0], [937.0, 443.0], [908.0, 443.0]], [[867.0, 200.0], [902.0, 200.0], [902.0, 418.0], [867.0, 418.0]], [[834.0, 200.0], [863.0, 200.0], [863.0, 368.0], [834.0, 368.0]]], "lines": ["自殺してるんじゃ", "ないかって心配", "してたの私。"]}, {"box": [223, 149, 428, 441], "vertical": true, "font_size": 34, "lines_coords": [[[395.0, 157.0], [424.0, 157.0], [424.0, 438.0], [395.0, 438.0]], [[349.0, 149.0], [385.0, 149.0], [382.0, 426.0], [347.0, 426.0]], [[306.0, 149.0], [343.0, 149.0], [341.0, 426.0], [304.0, 426.0]], [[267.0, 153.0], [298.0, 153.0], [296.0, 387.0], [264.0, 387.0]], [[223.0, 153.0], [258.0, 153.0], [258.0, 358.0], [223.0, 358.0]]], "lines": ["「僕も愛子ちゃんは", "とっくに発狂して", "下水の底みたいな", "人生送ってると", "思ってたよ。」"]}, {"box": [728, 664, 770, 788], "vertical": true, "font_size": 38, "lines_coords": [[[728.0, 664.0], [765.0, 664.0], [770.0, 788.0], [732.0, 788.0]]], "lines": ["あはは。"]}, {"box": [138, 782, 269, 927], "vertical": true, "font_size": 43, "lines_coords": [[[211.0, 782.0], [269.0, 782.0], [269.0, 877.0], [211.0, 877.0]], [[178.0, 786.0], [215.0, 786.0], [215.0, 927.0], [178.0, 927.0]], [[138.0, 786.0], [173.0, 786.0], [173.0, 925.0], [138.0, 925.0]]], "lines": ["．．．私", "そんな子", "だった？"]}, {"box": [1252, 1144, 1293, 1406], "vertical": true, "font_size": 35, "lines_coords": [[[1254.0, 1144.0], [1289.0, 1144.0], [1289.0, 1401.0], [1254.0, 1401.0]]], "lines": ["「あはは」とか。"]}, {"box": [542, 1144, 587, 1635], "vertical": true, "font_size": 37, "lines_coords": [[[542.0, 1144.0], [579.0, 1144.0], [581.0, 1629.0], [544.0, 1629.0]]], "lines": ["笑い事じゃ、ないだろう？"]}], "img_path": "075.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [758, 106, 789, 321], "vertical": true, "font_size": 31, "lines_coords": [[[758.0, 106.0], [789.0, 106.0], [789.0, 321.0], [758.0, 321.0]]], "lines": ["．．．ふざけるな、"]}, {"box": [755, 107, 784, 312], "vertical": true, "font_size": 29, "lines_coords": [[[755.0, 107.0], [784.0, 107.0], [784.0, 312.0], [755.0, 312.0]]], "lines": ["．．．ふさけるな"]}, {"box": [610, 109, 639, 254], "vertical": true, "font_size": 29, "lines_coords": [[[610.0, 109.0], [639.0, 109.0], [639.0, 254.0], [610.0, 254.0]]], "lines": ["田中愛子。"]}, {"box": [609, 106, 641, 259], "vertical": true, "font_size": 32, "lines_coords": [[[609.0, 106.0], [641.0, 106.0], [641.0, 259.0], [609.0, 259.0]]], "lines": ["田中愛子。"]}, {"box": [637, 1552, 745, 1810], "vertical": true, "font_size": 40, "lines_coords": [[[701.0, 1552.0], [745.0, 1552.0], [745.0, 1685.0], [701.0, 1685.0]], [[639.0, 1552.0], [674.0, 1552.0], [672.0, 1807.0], [637.0, 1807.0]]], "lines": ["「．．．．．．手、", "繋いでもいい？」"]}, {"box": [120, 1801, 192, 1997], "vertical": true, "font_size": 33, "lines_coords": [[[155.0, 1801.0], [192.0, 1801.0], [192.0, 1898.0], [155.0, 1898.0]], [[120.0, 1803.0], [149.0, 1803.0], [149.0, 1993.0], [120.0, 1993.0]]], "lines": ["．．．もう", "繋いでるけど。"]}], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1136, 161, 1258, 403], "vertical": true, "font_size": 36, "lines_coords": [[[1223.0, 163.0], [1258.0, 163.0], [1258.0, 354.0], [1223.0, 354.0]], [[1175.0, 161.0], [1213.0, 161.0], [1215.0, 401.0], [1177.0, 401.0]], [[1136.0, 165.0], [1171.0, 165.0], [1171.0, 356.0], [1136.0, 356.0]]], "lines": ["「．．．しばらく", "このままでいい", "だろうか？」"]}, {"box": [610, 533, 643, 686], "vertical": true, "font_size": 29, "lines_coords": [[[610.0, 534.0], [639.0, 534.0], [639.0, 685.0], [610.0, 685.0]]], "lines": ["．．．なんで？"]}, {"box": [310, 385, 347, 778], "vertical": true, "font_size": 29, "lines_coords": [[[310.0, 440.0], [339.0, 440.0], [339.0, 772.0], [310.0, 772.0]]], "lines": ["．．．．．．．なんでだろう。」"]}, {"box": [279, 1306, 318, 1477], "vertical": true, "font_size": 31, "lines_coords": [[[283.0, 1306.0], [314.0, 1306.0], [310.0, 1476.0], [279.0, 1476.0]]], "lines": ["だめだよ．．．"]}, {"box": [1219, 1579, 1256, 1815], "vertical": true, "font_size": 35, "lines_coords": [[[1221.0, 1581.0], [1256.0, 1581.0], [1254.0, 1809.0], [1219.0, 1809.0]]], "lines": ["こういうの．．．"]}, {"box": [254, 1772, 288, 1974], "vertical": true, "font_size": 29, "lines_coords": [[[254.0, 1772.0], [283.0, 1772.0], [283.0, 1966.0], [254.0, 1966.0]]], "lines": ["だめだよ．．．"]}], "img_path": "077.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1322, 268, 1359, 478], "vertical": true, "font_size": 36, "lines_coords": [[[1322.0, 269.0], [1358.0, 269.0], [1358.0, 474.0], [1322.0, 474.0]]], "lines": ["プンプン．．．"]}, {"box": [1146, 1668, 1229, 1805], "vertical": true, "font_size": 40, "lines_coords": [[[1192.0, 1668.0], [1229.0, 1668.0], [1229.0, 1805.