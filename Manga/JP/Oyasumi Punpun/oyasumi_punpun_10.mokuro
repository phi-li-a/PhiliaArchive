.0, 1828.0], [225.0, 1828.0], [225.0, 1993.0], [196.0, 1993.0]]], "lines": ["．．．だよね？"]}], "img_path": "138.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1182, 103, 1289, 346], "vertical": true, "font_size": 29, "lines_coords": [[[1258.0, 105.0], [1287.0, 105.0], [1287.0, 256.0], [1258.0, 256.0]], [[1221.0, 105.0], [1250.0, 105.0], [1250.0, 345.0], [1221.0, 345.0]], [[1186.0, 103.0], [1215.0, 103.0], [1211.0, 258.0], [1182.0, 258.0]]], "lines": ["小五の時の", "合唱コンクールの", "課題曲．．．：："]}, {"box": [600, 109, 705, 325], "vertical": true, "font_size": 31, "lines_coords": [[[666.0, 109.0], [703.0, 109.0], [703.0, 248.0], [666.0, 248.0]], [[635.0, 111.0], [664.0, 111.0], [664.0, 325.0], [635.0, 325.0]], [[600.0, 111.0], [627.0, 111.0], [627.0, 277.0], [600.0, 277.0]]], "lines": ["プンプン、", "練習さぼった日", "あったよね。"]}, {"box": [850, 697, 958, 882], "vertical": true, "font_size": 30, "lines_coords": [[[915.0, 699.0], [954.0, 697.0], [958.0, 797.0], [919.0, 799.0]], [[883.0, 699.0], [912.0, 699.0], [917.0, 881.0], [888.0, 881.0]], [[852.0, 701.0], [875.0, 701.0], [875.0, 850.0], [852.0, 850.0]]], "lines": ["．．．よく", "憶えてるなぁ", "あたし．．．"]}, {"box": [204, 685, 343, 884], "vertical": true, "font_size": 28, "lines_coords": [[[314.0, 687.0], [343.0, 687.0], [343.0, 840.0], [314.0, 840.0]], [[277.0, 687.0], [306.0, 687.0], [306.0, 840.0], [277.0, 840.0]], [[240.0, 687.0], [269.0, 687.0], [269.0, 838.0], [240.0, 838.0]], [[204.0, 685.0], [231.0, 685.0], [231.0, 879.0], [204.0, 879.0]]], "lines": ["．．．こんな事", "憶えてても", "何の役にも", "立たないけど、"]}, {"box": [335, 1250, 373, 1418], "vertical": true, "font_size": 37, "lines_coords": [[[335.0, 1250.0], [372.0, 1250.0], [372.0, 1414.0], [335.0, 1414.0]]], "lines": ["１０年か．．．"]}, {"box": [1159, 1714, 1285, 1919], "vertical": true, "font_size": 37, "lines_coords": [[[1242.0, 1716.0], [1285.0, 1716.0], [1285.0, 1826.0], [1242.0, 1826.0]], [[1202.0, 1718.0], [1237.0, 1718.0], [1237.0, 1919.0], [1202.0, 1919.0]], [[1163.0, 1714.0], [1198.0, 1714.0], [1194.0, 1888.0], [1159.0, 1888.0]]], "lines": ["今まで", "何やってたん", "だろう．．．"]}, {"box": [1018, 1805, 1057, 1958], "vertical": true, "font_size": 37, "lines_coords": [[[1018.0, 1805.0], [1053.0, 1805.0], [1057.0, 1958.0], [1022.0, 1958.0]]], "lines": ["．．．あたし。"]}], "img_path": "139.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1148, 443, 1184, 583], "vertical": true, "font_size": 32, "lines_coords": [[[1148.0, 443.0], [1184.0, 443.0], [1184.0, 583.0], [1148.0, 583.0]]], "lines": ["ごめん．．．"]}, {"box": [1082, 627, 1111, 759], "vertical": true, "font_size": 32, "lines_coords": [[[1082.0, 627.0], [1111.0, 627.0], [1111.0, 759.0], [1082.0, 759.0]]], "lines": ["あたし．．．"]}, {"box": [180, 1517, 267, 1656], "vertical": true, "font_size": 44, "lines_coords": [[[223.0, 1519.0], [267.0, 1519.0], [267.0, 1656.0], [223.0, 1656.0]], [[180.0, 1517.0], [223.0, 1517.0], [223.0, 1641.0], [180.0, 1641.0]]], "lines": ["やっぱり", "帰るね。"]}], "img_path": "140.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [546, 958, 585, 1167], "vertical": true, "font_size": 35, "lines_coords": [[[546.0, 958.0], [581.0, 958.0], [581.0, 1153.0], [546.0, 1153.0]]], "lines": ["「あの．．．．．．"]}, {"box": [888, 1771, 925, 1872], "vertical": true, "font_size": 37, "lines_coords": [[[888.0, 1771.0], [925.0, 1771.0], [925.0, 1872.0], [888.0, 1872.0]]], "lines": ["「．．．僕、"]}, {"box": [730, 1772, 811, 2006], "vertical": true, "font_size": 38, "lines_coords": [[[768.0, 1772.0], [811.0, 1772.0], [811.0, 1879.0], [768.0, 1879.0]], [[730.0, 1776.0], [759.0, 1776.0], [759.0, 2006.0], [730.0, 2006.0]]], "lines": ["本当は", "藤川じゃなくて"]}, {"box": [585, 1774, 668, 1956], "vertical": true, "font_size": 38, "lines_coords": [[[625.0, 1774.0], [668.0, 1774.0], [668.0, 1881.0], [625.0, 1881.0]], [[585.0, 1776.0], [621.0, 1776.0], [621.0, 1956.0], [585.0, 1956.0]]], "lines": ["小野寺", "なんです．．．」"]}], "img_path": "141.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [803, 890, 989, 1136], "vertical": true, "font_size": 32, "lines_coords": [[[952.0, 892.0], [989.0, 892.0], [989.0, 1002.0], [952.0, 1002.0]], [[915.0, 890.0], [950.0, 890.0], [950.0, 1136.0], [915.0, 1136.0]], [[881.0, 894.0], [910.0, 894.0], [910.0, 1076.0], [881.0, 1076.0]], [[844.0, 892.0], [873.0, 892.0], [873.0, 1049.0], [844.0, 1049.0]], [[805.0, 890.0], [836.0, 890.0], [834.0, 1103.0], [803.0, 1103.0]]], "lines": ["「本当は", "大学生じゃないし", "フットサルは", "できないし、", "彼女もいないし"]}, {"box": [426, 886, 724, 1115], "vertical": true, "font_size": 32, "lines_coords": [[[676.0, 886.0], [724.0, 886.0], [724.0, 962.0], [676.0, 962.0]], [[645.0, 890.0], [676.0, 890.0], [681.0, 1074.0], [650.0, 1074.0]], [[612.0, 892.0], [641.0, 892.0], [641.0, 1045.0], [612.0, 1045.0]], [[573.0, 892.0], [602.0, 892.0], [602.0, 1072.0], [573.0, 1072.0]], [[538.0, 892.0], [567.0, 892.0], [567.0, 1072.0], [538.0, 1072.0]], [[500.0, 892.0], [529.0, 892.0], [529.0, 1074.0], [500.0, 1074.0]], [[463.0, 892.0], [492.0, 892.0], [492.0, 1043.0], [463.0, 1043.0]], [[426.0, 890.0], [455.0, 890.0], [455.0, 1115.0], [426.0, 1115.0]]], "lines": ["特に", "楽しくもなく", "とりたてて", "不幸でもない", "半端な毎日を", "ただ過ごして", "いるだけの", "ワカメなんです。"]}, {"box": [289, 884, 395, 1132], "vertical": true, "font_size": 32, "lines_coords": [[[358.0, 884.0], [393.0, 884.0], [395.0, 1132.0], [360.0, 1132.0]], [[327.0, 892.0], [356.0, 892.0], [356.0, 1074.0], [327.0, 1074.0]], [[289.0, 890.0], [318.0, 890.0], [318.0, 1043.0], [289.0, 1043.0]]], "lines": ["．．．いや、それじゃ", "ワカメに失礼", "ですよね。」"]}, {"box": [1001, 1751, 1037, 1869], "vertical": true, "font_size": 36, "lines_coords": [[[1001.0, 1753.0], [1037.0, 1753.0], [1037.0, 1865.0], [1001.0, 1865.0]]], "lines": ["「．．．僕は"]}, {"box": [788, 1752, 929, 1946], "vertical": true, "font_size": 33, "lines_coords": [[[900.0, 1755.0], [929.0, 1755.0], [929.0, 1935.0], [900.0, 1935.0]], [[859.0, 1755.0], [894.0, 1755.0], [894.0, 1877.0], [859.0, 1877.0]], [[823.0, 1753.0], [861.0, 1753.0], [857.0, 1877.0], [819.0, 1877.0]], [[788.0, 1755.0], [817.0, 1755.0], [817.0, 1944.0], [788.0, 1944.0]]], "lines": ["ずっと探して", "たんです", "１０年前の", "愛子ちゃんを。"]}, {"box": [632, 1749, 703, 1949], "vertical": true, "font_size": 32, "lines_coords": [[[668.0, 1749.0], [703.0, 1751.0], [697.0, 1906.0], [662.0, 1904.0]], [[633.0, 1755.0], [662.0, 1755.0], [662.0, 1944.0], [633.0, 1944.0]]], "lines": ["この数年間", "馬鹿みたいに。"]}, {"box": [418, 1751, 567, 2079], "vertical": true, "font_size": 35, "lines_coords": [[[538.0, 1751.0], [567.0, 1751.0], [563.0, 1993.0], [534.0, 1993.0]], [[496.0, 1753.0], [532.0, 1753.0], [532.0, 1935.0], [496.0, 1935.0]], [[463.0, 1753.0], [492.0, 1753.0], [492.0, 2078.0], [463.0, 2078.0]], [[418.0, 1751.0], [463.0, 1751.0], [463.0, 1859.0], [418.0, 1859.0]]], "lines": ["でもやっと会えた", "愛子ちゃんは", "やっぱり愛子ちゃんじゃ", "なくて、"]}, {"box": [276, 1751, 346, 1994], "vertical": true, "font_size": 29, "lines_coords": [[[314.0, 1751.0], [343.0, 1751.0], [341.0, 1989.0], [312.0, 1989.0]], [[277.0, 1755.0], [306.0, 1755.0], [306.0, 1979.0], [277.0, 1979.0]]], "lines": ["．．．情けなくもあり", "悔しくもあり．．．」"]}], "img_path": "142.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [946, 747, 1024, 1037], "vertical": true, "font_size": 35, "lines_coords": [[[989.0, 747.0], [1024.0, 747.0], [1022.0, 1037.0], [987.0, 1037.0]], [[946.0, 749.0], [983.0, 749.0], [983.0, 884.0], [946.0, 884.0]]], "lines": ["「いつも心の奥底に", "眠ってる"]}, {"box": [788, 745, 910, 1053], "vertical": true, "font_size": 35, "lines_coords": [[[875.0, 745.0], [910.0, 745.0], [906.0, 987.0], [871.0, 987.0]], [[830.0, 747.0], [865.0, 747.0], [861.0, 917.0], [826.0, 917.0]], [[788.0, 747.0], [823.0, 747.0], [823.0, 1053.0], [788.0, 1053.0]]], "lines": ["二人で鹿児島に", "行く約束を", "守れなかった後悔が"]}, {"box": [641, 751, 712, 1020], "vertical": true, "font_size": 32, "lines_coords": [[[683.0, 751.0], [712.0, 751.0], [712.0, 917.0], [683.0, 917.0]], [[641.0, 751.0], [670.0, 751.0], [670.0, 1020.0], [641.0, 1020.0]]], "lines": ["僕の自信を", "根こそぎ奪い去り"]}, {"box": [401, 746, 561, 1020], "vertical": true, "font_size": 32, "lines_coords": [[[527.0, 751.0], [556.0, 751.0], [556.0, 952.0], [527.0, 952.0]], [[482.0, 747.0], [517.0, 747.0], [517.0, 1018.0], [482.0, 1018.0]]], "lines": ["こんな卑屈で", "どうしようもない"]}, {"box": [395, 745, 474, 952], "vertical": true, "font_size": 32, "lines_coords": [[[438.0, 745.0], [474.0, 745.0], [474.0, 952.0], [438.0, 952.0]], [[399.0, 745.0], [434.0, 745.0], [430.0, 921.0], [395.0, 921.0]]], "lines": ["人間にしたん", "でしょう。」"]}, {"box": [939, 1720, 1063, 1899], "vertical": true, "font_size": 38, "lines_coords": [[[1024.0, 1722.0], [1062.0, 1722.0], [1062.0, 1888.0], [1024.0, 1888.0]]], "lines": ["「．．．．．いや、"]}, {"box": [939, 1724, 975, 1902], "vertical": true, "font_size": 33, "lines_coords": [[[939.0, 1724.0], [975.0, 1724.0], [975.0, 1902.0], [939.0, 1902.0]]], "lines": ["というより、"]}, {"box": [799, 1724, 869, 2022], "vertical": true, "font_size": 33, "lines_coords": [[[840.0, 1728.0], [869.0, 1728.0], [869.0, 1958.0], [840.0, 1958.0]], [[799.0, 1724.0], [828.0, 1724.0], [828.0, 2022.0], [799.0, 2022.0]]], "lines": ["なにをやっても", "うまくいかない事を"]}, {"box": [658, 1726, 736, 1991], "vertical": true, "font_size": 33, "lines_coords": [[[701.0, 1728.0], [736.0, 1728.0], [736.0, 1991.0], [701.0, 1991.0]], [[658.0, 1726.0], [693.0, 1726.0], [693.0, 1970.0], [658.0, 1970.0]]], "lines": ["全て愛子ちゃんの", "せいにしていた。"]}, {"box": [544, 1724, 616, 1991], "vertical": true, "font_size": 33, "lines_coords": [[[587.0, 1726.0], [616.0, 1726.0], [616.0, 1991.0], [587.0, 1991.0]], [[544.0, 1724.0], [579.0, 1724.0], [579.0, 1991.0], [544.0, 1991.0]]], "lines": ["．．．ただそれだけの", "話かもしれない。」"]}], "img_path": "143.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [879, 78, 997, 268], "vertical": true, "font_size": 34, "lines_coords": [[[960.0, 80.0], [997.0, 80.0], [997.0, 204.0], [960.0, 204.0]], [[919.0, 78.0], [954.0, 78.0], [954.0, 252.0], [919.0, 252.0]], [[879.0, 82.0], [908.0, 82.0], [908.0, 262.0], [879.0, 262.0]]], "lines": ["「．．．でも", "やっと目が", "覚めました。"]}, {"box": [631, 80, 790, 285], "vertical": true, "font_size": 34, "lines_coords": [[[755.0, 80.0], [790.0, 80.0], [790.0, 219.0], [755.0, 219.0]], [[716.0, 80.0], [745.0, 80.0], [745.0, 285.0], [716.0, 285.0]], [[670.0, 80.0], [705.0, 80.0], [705.0, 219.0], [670.0, 219.0]], [[631.0, 80.0], [666.0, 80.0], [666.0, 265.0], [631.0, 265.0]]], "lines": ["あなたは", "僕がとうこう", "気に病む", "までもなく、"]}, {"box": [436, 76, 556, 289], "vertical": true, "font_size": 34, "lines_coords": [[[521.0, 80.0], [556.0, 80.0], [556.0, 285.0], [521.0, 285.0]], [[480.0, 76.0], [515.0, 76.0], [511.0, 289.0], [476.0, 289.0]], [[436.0, 82.0], [472.0, 82.0], [472.0, 285.0], [436.0, 285.0]]], "lines": ["楽しい人生を", "送れる女の子", "なのであって"]}, {"box": [356, 78, 393, 331], "vertical": true, "font_size": 34, "lines_coords": [[[356.0, 78.0], [391.0, 78.0], [393.0, 331.0], [358.0, 331.0]]], "lines": ["つまりその：．．．"]}, {"box": [1188, 950, 1254, 1080], "vertical": true, "font_size": 30, "lines_coords": [[[1223.0, 989.0], [1254.0, 989.0], [1254.0, 1072.0], [1223.0, 1072.0]], [[1188.0, 966.0], [1217.0, 966.0], [1221.0, 1080.0], [1192.0, 1080.0]]], "lines": ["青栄陛", "１４名義務"]}, {"box": [674, 1701, 711, 2030], "vertical": true, "font_size": 29, "lines_coords": [[[676.0, 1708.0], [705.0, 1708.0], [705.0, 2020.0], [676.0, 2020.0]]], "lines": ["「．．．会えてよかった。」"]}], "img_path": "144.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1177, 1452, 1213, 1709], "vertical": true, "font_size": 29, "lines_coords": [[[1177.0, 1455.0], [1206.0, 1455.0], [1206.0, 1703.0], [1177.0, 1703.0]]], "lines": ["「．．．ありがとう。」"]}, {"box": [925, 1285, 970, 1419], "vertical": true, "font_size": 45, "lines_coords": [[[925.0, 1285.0], [970.0, 1285.0], [970.0, 1418.0], [925.0, 1418.0]]], "lines": ["へえ．．．．．．"]}, {"box": [618, 1807, 650, 1990], "vertical": true, "font_size": 29, "lines_coords": [[[618.0, 1807.0], [647.0, 1807.0], [647.0, 1987.0], [618.0, 1987.0]]], "lines": ["そうなんだ。"]}, {"box": [242, 1768, 271, 1933], "vertical": true, "font_size": 26, "lines_coords": [[[242.0, 1768.0], [271.0, 1768.0], [271.0, 1933.0], [242.0, 1933.0]]], "lines": ["そうなんだ"]}, {"box": [202, 1832, 225, 1898], "vertical": true, "font_size": 26, "lines_coords": [[[202.0, 1832.0], [225.0, 1832.0], [225.0, 1898.0], [202.0, 1898.0]]], "lines": ["．．．．．"]}], "img_path": "145.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1260, 132, 1298, 273], "vertical": true, "font_size": 34, "lines_coords": [[[1260.0, 132.0], [1298.0, 132.0], [1298.0, 273.0], [1260.0, 273.0]]], "lines": ["なんか．．．"]}, {"box": [1033, 149, 1177, 370], "vertical": true, "font_size": 34, "lines_coords": [[[1142.0, 149.0], [1177.0, 149.0], [1177.0, 308.0], [1142.0, 308.0]], [[1103.0, 151.0], [1140.0, 151.0], [1140.0, 279.0], [1103.0, 279.0]], [[1068.0, 151.0], [1097.0, 151.0], [1097.0, 366.0], [1068.0, 366.0]], [[1033.0, 151.0], [1062.0, 151.0], [1062.0, 370.0], [1033.0, 370.0]]], "lines": ["プンプンは", "絶対に嘘", "つかない子だと", "思ってたのに：："]}, {"box": [333, 146, 457, 322], "vertical": true, "font_size": 37, "lines_coords": [[[420.0, 153.0], [457.0, 153.0], [457.0, 291.0], [420.0, 291.0]], [[378.0, 151.0], [416.0, 151.0], [416.0, 322.0], [378.0, 322.0]], [[333.0, 146.0], [378.0, 146.0], [378.0, 258.0], [333.0, 258.0]]], "lines": ["あたしに", "嘘ついてた", "なんて"]}, {"box": [194, 246, 223, 428], "vertical": true, "font_size": 37, "lines_coords": [[[194.0, 246.0], [223.0, 246.0], [223.0, 428.0], [194.0, 428.0]]], "lines": ["．．．悲しいな。"]}, {"box": [1134, 550, 1179, 818], "vertical": true, "font_size": 41, "lines_coords": [[[1134.0, 550.0], [1175.0, 550.0], [1175.0, 809.0], [1134.0, 809.0]]], "lines": ["約束したよね。"]}, {"box": [296, 1060, 385, 1260], "vertical": true, "font_size": 48, "lines_coords": [[[347.0, 1060.0], [385.0, 1060.0], [385.0, 1225.0], [347.0, 1225.0]], [[296.0, 1060.0], [33