0], [296.0, 1494.0]], [[252.0, 1289.0], [296.0, 1289.0], [296.0, 1401.0], [252.0, 1401.0]]], "lines": ["．．．いいね君は、", "人生楽しそう", "で．．．．．．"]}], "img_path": "093.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [310, 256, 387, 397], "vertical": true, "font_size": 36, "lines_coords": [[[351.0, 258.0], [387.0, 258.0], [387.0, 397.0], [351.0, 397.0]], [[310.0, 256.0], [345.0, 256.0], [345.0, 395.0], [310.0, 395.0]]], "lines": ["こんな事", "なら．．．"]}, {"box": [204, 1072, 325, 1310], "vertical": true, "font_size": 36, "lines_coords": [[[287.0, 1074.0], [325.0, 1074.0], [325.0, 1213.0], [287.0, 1213.0]], [[246.0, 1074.0], [281.0, 1074.0], [281.0, 1310.0], [246.0, 1310.0]], [[204.0, 1072.0], [240.0, 1072.0], [240.0, 1225.0], [204.0, 1225.0]]], "lines": ["．．．二度と", "会えないほうが", "よかった。"]}], "img_path": "094.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [886, 178, 923, 596], "vertical": true, "font_size": 35, "lines_coords": [[[888.0, 178.0], [923.0, 178.0], [921.0, 596.0], [886.0, 596.0]]], "lines": ["．．．フンフンは、思いました。"]}, {"box": [571, 1049, 608, 1167], "vertical": true, "font_size": 37, "lines_coords": [[[571.0, 1049.0], [608.0, 1049.0], [608.0, 1167.0], [571.0, 1167.0]]], "lines": ["全てにー"]}, {"box": [574, 1753, 607, 1866], "vertical": true, "font_size": 29, "lines_coords": [[[575.0, 1755.0], [604.0, 1755.0], [604.0, 1861.0], [575.0, 1861.0]]], "lines": ["負けた。"]}], "img_path": "095.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [724, 128, 774, 478], "vertical": true, "font_size": 50, "lines_coords": [[[724.0, 128.0], [774.0, 128.0], [774.0, 478.0], [724.0, 478.0]]], "lines": ["：万策、尽きた"]}], "img_path": "096.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [], "img_path": "097.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [486, 111, 563, 322], "vertical": true, "font_size": 58, "lines_coords": [[[505.0, 111.0], [563.0, 118.0], [544.0, 322.0], [486.0, 316.0]]], "lines": ["ニターセンター"]}, {"box": [815, 1681, 939, 2000], "vertical": true, "font_size": 33, "lines_coords": [[[906.0, 1685.0], [935.0, 1685.0], [935.0, 1819.0], [906.0, 1819.0]], [[861.0, 1683.0], [896.0, 1683.0], [896.0, 1954.0], [861.0, 1954.0]], [[817.0, 1681.0], [852.0, 1681.0], [850.0, 1991.0], [815.0, 1991.0]]], "lines": ["虚無感は", "銀河鉄道前立腺を", "尿道駅で途中下車し"]}, {"box": [658, 1678, 738, 2055], "vertical": true, "font_size": 35, "lines_coords": [[[701.0, 1685.0], [736.0, 1685.0], [736.0, 2049.0], [701.0, 2049.0]], [[658.0, 1683.0], [693.0, 1683.0], [693.0, 1958.0], [658.0, 1958.0]]], "lines": ["血の混じった精液と共に", "下水へと旅立つと、"]}, {"box": [418, 1681, 578, 1986], "vertical": true, "font_size": 31, "lines_coords": [[[546.0, 1685.0], [575.0, 1685.0], [575.0, 1948.0], [546.0, 1948.0]], [[500.0, 1683.0], [536.0, 1683.0], [536.0, 1985.0], [500.0, 1985.0]], [[461.0, 1685.0], [490.0, 1685.0], [490.0, 1983.0], [461.0, 1983.0]], [[418.0, 1683.0], [447.0, 1683.0], [447.0, 1828.0], [418.0, 1828.0]]], "lines": ["５月中旬の早朝は", "ビル風と手を繋いで", "初夏の気配を運んで", "きました。"]}], "img_path": "098.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1173, 561, 1318, 778], "vertical": true, "font_size": 32, "lines_coords": [[[1287.0, 565.0], [1316.0, 565.0], [1314.0, 778.0], [1285.0, 778.0]], [[1250.0, 565.0], [1279.0, 565.0], [1279.0, 716.0], [1250.0, 716.0]], [[1213.0, 563.0], [1244.0, 563.0], [1240.0, 747.0], [1208.0, 747.0]], [[1173.0, 561.0], [1213.0, 561.0], [1213.0, 645.0], [1173.0, 645.0]]], "lines": ["もうフンフンは", "歩きまわる", "必要はあります", "せん。"]}, {"box": [929, 558, 1113, 805], "vertical": true, "font_size": 33, "lines_coords": [[[1078.0, 567.0], [1107.0, 567.0], [1107.0, 751.0], [1078.0, 751.0]], [[1041.0, 565.0], [1070.0, 565.0], [1070.0, 805.0], [1041.0, 805.0]], [[1001.0, 561.0], [1037.0, 561.0], [1037.0, 718.0], [1001.0, 718.0]], [[966.0, 558.0], [1001.0, 558.0], [1001.0, 716.0], [966.0, 716.0]], [[929.0, 561.0], [964.0, 561.0], [964.0, 703.0], [929.0, 703.0]]], "lines": ["ただひたすら", "じっとしていれば", "勝手に夏が", "やってくる", "でしょう。"]}, {"box": [349, 1705, 427, 1956], "vertical": true, "font_size": 36, "lines_coords": [[[391.0, 1708.0], [426.0, 1708.0], [426.0, 1842.0], [391.0, 1842.0]], [[349.0, 1708.0], [385.0, 1708.0], [385.0, 1948.0], [349.0, 1948.0]]], "lines": ["とっても", "夏が楽しみです。"]}], "img_path": "099.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1163, 140, 1233, 333], "vertical": true, "font_size": 33, "lines_coords": [[[1196.0, 140.0], [1233.0, 140.0], [1233.0, 240.0], [1196.0, 240.0]], [[1163.0, 142.0], [1192.0, 142.0], [1192.0, 333.0], [1163.0, 333.0]]], "lines": ["．．．．．．．", "小野寺さんて、"]}, {"box": [1051, 378, 1159, 596], "vertical": true, "font_size": 33, "lines_coords": [[[1130.0, 383.0], [1159.0, 383.0], [1159.0, 567.0], [1130.0, 567.0]], [[1093.0, 380.0], [1122.0, 380.0], [1122.0, 596.0], [1093.0, 596.0]], [[1051.0, 378.0], [1090.0, 378.0], [1090.0, 459.0], [1051.0, 459.0]]], "lines": ["なんで平然と", "生きてられるん", "だろー"]}, {"box": [848, 182, 954, 401], "vertical": true, "font_size": 31, "lines_coords": [[[915.0, 182.0], [950.0, 182.0], [954.0, 401.0], [919.0, 401.0]], [[883.0, 184.0], [912.0, 184.0], [912.0, 370.0], [883.0, 370.0]], [[848.0, 182.0], [877.0, 182.0], [877.0, 296.0], [848.0, 296.0]]], "lines": ["気が小さいのは", "むこうの勝手", "だけどー"]}, {"box": [291, 171, 445, 457], "vertical": true, "font_size": 32, "lines_coords": [[[409.0, 171.0], [445.0, 171.0], [445.0, 302.0], [409.0, 302.0]], [[366.0, 171.0], [401.0, 171.0], [403.0, 397.0], [368.0, 397.0]], [[333.0, 178.0], [362.0, 178.0], [362.0, 457.0], [333.0, 457.0]], [[291.0, 171.0], [320.0, 171.0], [322.0, 374.0], [293.0, 374.0]]], "lines": ["やめなよ", "かわいそうだよ", "一応仕事は人並みに", "出来るんだし。"]}, {"box": [151, 409, 262, 629], "vertical": true, "font_size": 31, "lines_coords": [[[227.0, 409.0], [262.0, 409.0], [262.0, 567.0], [227.0, 567.0]], [[190.0, 411.0], [219.0, 411.0], [219.0, 629.0], [190.0, 629.0]], [[151.0, 411.0], [180.0, 411.0], [180.0, 583.0], [151.0, 583.0]]], "lines": ["飲みで散々", "文句言ってたの", "先輩じゃん。"]}, {"box": [743, 399, 881, 689], "vertical": true, "font_size": 31, "lines_coords": [[[846.0, 399.0], [881.0, 399.0], [881.0, 550.0], [846.0, 550.0]], [[813.0, 403.0], [842.0, 403.0], [842.0, 606.0], [813.0, 606.0]], [[778.0, 405.0], [807.0, 405.0], [807.0, 689.0], [778.0, 689.0]], [[743.0, 405.0], [772.0, 405.0], [772.0, 645.0], [743.0, 645.0]]], "lines": ["こっちまで", "気をつかわせて", "ストレスになってんの", "わかってんのかな。"]}, {"box": [979, 1434, 1121, 1709], "vertical": true, "font_size": 29, "lines_coords": [[[1090.0, 1434.0], [1119.0, 1434.0], [1119.0, 1556.0], [1090.0, 1556.0]], [[1051.0, 1434.0], [1080.0, 1434.0], [1080.0, 1705.0], [1051.0, 1705.0]], [[1016.0, 1436.0], [1045.0, 1436.0], [1045.0, 1676.0], [1016.0, 1676.0]], [[979.0, 1434.0], [1008.0, 1434.0], [1010.0, 1662.0], [981.0, 1662.0]]], "lines": ["教習所に", "振り込んでしまった", "３０万円を取り戻す", "までの辛抱です。"]}, {"box": [757, 1432, 787, 1567], "vertical": true, "font_size": 29, "lines_coords": [[[757.0, 1432.0], [786.0, 1432.0], [786.0, 1567.0], [757.0, 1567.0]]], "lines": ["そうです。"]}, {"box": [631, 1433, 699, 1674], "vertical": true, "font_size": 29, "lines_coords": [[[670.0, 1434.0], [699.0, 1434.0], [699.0, 1672.0], [670.0, 1672.0]], [[631.0, 1434.0], [660.0, 1434.0], [660.0, 1596.0], [631.0, 1596.0]]], "lines": ["フンフンは今日も", "強い子です。"]}, {"box": [356, 1505, 393, 1652], "vertical": true, "font_size": 31, "lines_coords": [[[356.0, 1505.0], [393.0, 1505.0], [393.0, 1652.0], [356.0, 1652.0]]], "lines": ["．．．けれど、"]}, {"box": [252, 1507, 322, 1809], "vertical": true, "font_size": 31, "lines_coords": [[[293.0, 1507.0], [322.0, 1507.0], [322.0, 1807.0], [293.0, 1807.0]], [[252.0, 1507.0], [281.0, 1507.0], [281.0, 1809.0], [252.0, 1809.0]]], "lines": ["自動車免許の取得を", "すずめてきた社長は"]}, {"box": [186, 1509, 215, 1786], "vertical": true, "font_size": 31, "lines_coords": [[[186.0, 1509.0], [215.0, 1509.0], [215.0, 1786.0], [186.0, 1786.0]]], "lines": ["まだ寝たきりです。"]}], "img_path": "100.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [277, 122, 830, 839], "vertical": true, "font_size": 553, "lines_coords": [[[277.0, 122.0], [830.0, 122.0], [830.0, 839.0], [277.0, 839.0]]], "lines": ["あんたはいいですから．．．"]}, {"box": [1072, 682, 1235, 952], "vertical": true, "font_size": 35, "lines_coords": [[[1198.0, 683.0], [1233.0, 683.0], [1233.0, 852.0], [1198.0, 852.0]], [[1157.0, 683.0], [1192.0, 683.0], [1192.0, 852.0], [1157.0, 852.0]], [[1115.0, 683.0], [1151.0, 683.0], [1151.0, 952.0], [1115.0, 952.0]], [[1072.0, 683.0], [1107.0, 683.0], [1107.0, 894.0], [1072.0, 894.0]]], "lines": ["ふざけんな", "ふざけんな", "馬鹿野郎クズ野郎", "死ね死ね宛ね。"]}, {"box": [995, 1066, 1073, 1236], "vertical": true, "font_size": 32, "lines_coords": [[[1041.0, 1070.0], [1070.0, 1070.0], [1070.0, 1231.0], [1041.0, 1231.0]], [[995.0, 1066.0], [1030.0, 1066.0], [1030.0, 1206.0], [995.0, 1206.0]]], "lines": ["車の免許が", "取れたら"]}, {"box": [695, 1064, 904, 1300], "vertical": true, "font_size": 34, "lines_coords": [[[869.0, 1068.0], [904.0, 1068.0], [904.0, 1269.0], [869.0, 1269.0]], [[826.0, 1068.0], [861.0, 1068.0], [861.0, 1277.0], [826.0, 1277.0]], [[788.0, 1068.0], [817.0, 1068.0], [817.0, 1300.0], [788.0, 1300.0]], [[747.0, 1068.0], [776.0, 1068.0], [776.0, 1269.0], [747.0, 1269.0]], [[695.0, 1064.0], [739.0, 1064.0], [739.0, 1184.0], [695.0, 1184.0]]], "lines": ["知ってる人が", "一人もいない、", "どこか遠い遠い", "街まで行って", "みよう。"]}, {"box": [542, 1066, 623, 1273], "vertical": true, "font_size": 30, "lines_coords": [[[592.0, 1070.0], [618.0, 1070.0], [618.0, 1269.0], [592.0, 1269.0]], [[542.0, 1066.0], [577.0, 1066.0], [581.0, 1252.0], [546.0, 1252.0]]], "lines": ["最低限の荷物", "だけ持って。"]}, {"box": [302, 1066, 426, 1337], "vertical": true, "font_size": 36, "lines_coords": [[[389.0, 1068.0], [424.0, 1068.0], [424.0, 1337.0], [389.0, 1337.0]], [[345.0, 1066.0], [380.0, 1066.0], [385.0, 1273.0], [349.0, 1273.0]], [[306.0, 1066.0], [343.0, 1066.0], [339.0, 1217.0], [302.0, 1217.0]]], "lines": ["そして一番景色が", "きれいな街で", "暮らそう。"]}, {"box": [1026, 1718, 1060, 1994], "vertical": true, "font_size": 29, "lines_coords": [[[1026.0, 1722.0], [1055.0, 1722.0], [1055.0, 1989.0], [1026.0, 1989.0]]], "lines": ["もう焦らないから"]}, {"box": [854, 1718, 935, 1964], "vertical": true, "font_size": 30, "lines_coords": [[[902.0, 1722.0], [931.0, 1722.0], [931.0, 1917.0], [902.0, 1917.0]], [[854.0, 1718.0], [886.0, 1718.0], [888.0, 1956.0], [857.0, 1956.0]]], "lines": ["ずっと先でも", "かまわないから"]}, {"box": [666, 1716, 792, 2055], "vertical": true, "font_size": 39, "lines_coords": [[[759.0, 1718.0], [790.0, 1718.0], [788.0, 1952.0], [757.0, 1952.0]], [[712.0, 1716.0], [753.0, 1716.0], [753.0, 2055.0], [712.0, 2055.0]], [[666.0, 1718.0], [712.0, 1718.0], [712.0, 1834.0], [666.0, 1834.0]]], "lines": ["その街でいつか", "大切な人が見つかれば", "いいな。"]}, {"box": [443, 1713, 524, 2069], "vertical": true, "font_size": 38, "lines_coords": [[[488.0, 1718.0], [523.0, 1718.0], [523.0, 1888.0], [488.0, 1888.0]], [[443.0, 1716.0], [484.0, 1716.0], [484.0, 2068.0], [443.0, 2068.0]]], "lines": ["そんな風に", "プンブンは思いました。"]}], "img_path": "101.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [788, 915, 825, 1131], "vertical": true, "font_size": 29, "lines_coords": [[[790.0, 919.0], [819.0, 919.0], [819.0, 1122.0], [790.0, 1122.0]]], "lines": ["．．．気がつくと"]}, {"box": [522, 913, 642, 1186], "vertical": true, "font_size": 33, "lines_coords": [[[602.0, 917.0], [637.0, 917.0], [637.0, 1117.0], [602.0, 1117.0]], [[561.0, 913.0], [596.0, 913.0], [594.0, 1186.0], [558.0, 1186.0]], [[523.0, 919.0], [552.0, 919.0], [552.0, 1165.0], [523.0, 1165.0]]], "lines": ["さっちゃんの", "マンションの前に", "立っていました。"]}], "img_path": "102.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [838, 169, 867, 256], "vertical": true, "font_size": 29, "lines_coords": [[[838.0, 169.0], [867.0, 169.0], [867.0, 256.0], [838.0, 256.0]]], "lines": ["ん？ン"]}, {"box": [1275, 1265, 1300, 1352], "vertical": true, "font_size": 25, "lines_coords": [[[1275.0, 1265.0], [1300.0, 1265.0], [1300.0, 1352.0], [1275.0, 1352.0]]], "lines": ["タタン"]}, {"box": [614, 1130, 768, 1198], "vertical": false, "font_size": 30, "lines_coords": [[[614.0, 1169.0], [759.0, 1130.0], [768.0, 1159.0], [623.0, 1198.0]]], "lines": ["藤井さんは"]}, {"box": [214, 1276, 269, 1433], "vertical": true, "font_size": 55, "lines_coords": [[[214.0, 1276.0], [269.0, 1276.0], [269.0, 1433.0], [214.0, 1433.0]]], "lines": ["タタッタタン"]}, {"box": [1012, 1536, 1136, 1740], "vertical": true, "font_size": 35, "lines_coords": [[[1097.0, 1536.0], [1132.0, 1536.0], [1132.0, 1739.0], [1097.0, 1739.0]], [[1057.0, 1538.0], [1093.0, 1538.0], [1093.0, 1674.0], [1057.0, 1674.0]], [[1016.0, 1536.0], [1051.0, 1536.0], [1047.0, 1710.0], [1012.0, 1710.0]]], "lines": ["机に無造作に", "置かれた", "完成原稿は"]}, {"box": [194, 1592, 314, 1993], "vertical": true, "font_size": 33, "lines_coords": [[[281.0, 1594.0], [310.0, 1594.0], [310.0, 1892.0], [281.0, 1892.0]], [[236.0, 1592.0], [271.0, 1592.0], [271.0, 1993.0], [236.0, 1993.0]], [[194.0, 1592.0], [229.0, 1592.0], [229.0, 1873.0], [194.0, 1873.0]]], "lines": ["自分などいなくても", "十分にさっちゃんの魅力を", "感じさせる内容で、"]}], "img_path": "103.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [135, 812, 190, 978], "vertical": true, "font_size": 55, "lines_coords": [[[135.0, 812.0], [190.0, 812.0], [190.0, 978.0], [135.0, 978.0]]], "lines": ["？タッタ？"]}, {"box": [651, 987, 773, 1229], "vertical": true, "font_size": 33, "lines_coords": [[[734.0, 991.0], [770.0, 991.0], [770.0, 1161.0], [734.0, 1161.0]], [[693.0, 987.0], [728.0, 987.0], [726.0, 1227.0], [691.0, 1227.0]], [[654.0, 993.0], [683.0, 993.0], [683.0, 1204.0], [654.0, 1204.0]]], "lines": ["フンフンは", "「これでいい」と", "思ったのです。"]}], "img_path": "104.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [862, 258, 943, 463], "vertical": true, "font_size": 81, "lines_coords": [[[862.0, 258.0], [943.0, 258.0], [943.0, 463.0], [862.0, 463.0]]], "lines": ["タタッタタタン"]}, {"box": [213, 780, 245, 884], "vertical": true, "font_size": 32, "lines_coords": [[[213.0, 780.0], [245.0, 780.0], [245.0, 884.0], [213.0, 884.0]]], "lines": ["タタン"]}, {"box": [1196, 1039, 1273, 1218], "vertical": true, "font_size": 77, "lines_coords": [[[1196.0, 1039.0], [1273.0, 1039.0], [1273.0, 1218.0], [1196.0, 1218.0]]], "lines": ["タタッタタン"]}, {"box": [234, 1440, 263, 1530], "vertical": true, "font_size": 29, "lines_coords": [[[234.0, 1440.0], [263.0, 1440.0], [263.0, 1530.0], [234.0, 1530.0]]], "lines": ["タタン"]}, {"box": [966, 1900, 1004, 1993], "vertical": true, "font_size": 38, "lines_coords": [[[966.0, 1900.0], [1004.0, 1900.0], [1004.0, 1993.0], [966.0, 1993.0]]], "lines": ["ガチャ"]}], "img_path": "105.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [814, 811, 855, 1064], "vertical": true, "font_size": 35, "lines_coords": [[[815.0, 811.0], [850.0, 811.0], [850.0, 1062.0], [815.0, 1062.0]]], "lines": ["．．．あんた誰？"]}], "img_path": "106.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [], "img_path": "107.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [], "img_path": "108.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1198, 122, 1302, 290], "vertical": true, "font_size": 30, "lines_coords": [[[1271.0, 122.0], [1300.0, 122.0], [1300.0, 275.0], [1271.0, 275.0]], [[1235.0, 122.0], [1266.0, 122.0], [1262.0, 277.0], [1231.0, 277.0]], [[1198.0, 124.0], [1227.0, 124.0], [1227.0, 287.0], [1198.0, 287.0]]], "lines": ["．．．ごめんね", "平日なのに", "呼び出して。"]}, {"box": [770, 76, 846, 267], "vertical": true, "font_size": 38, "lines_coords": [[[799.0, 76.0], [846.0, 76.0], [846.0, 161.0], [799.0, 161.0]], [[770.0, 82.0], [799.0, 82.0], [799.0, 267.0], [770.0, 267.0]]], "lines": ["．．．あ、", "お土産いる？"]}, {"box": [380, 175, 488, 318], "vertical": true, "font_size": 38, "lines_coords": [[[449.0, 180.0], [488.0, 180.0], [488.0, 277.0], [449.0, 277.0]], [[409.0, 175.0], [455.0, 175.0], [455.0, 277.0], [409.0, 277.0]], [[380.0, 182.0], [409.0, 182.0], [409.0, 316.0], [380.0, 316.0]]], "lines": ["．．．まあ", "美容の", "ためにね。"]}, {"box": [45, 374, 120, 590], "vertical": true, "font_size": 75, "lines_coords": [[[45.0, 374.0], [120.0, 374.0], [120.0, 590.0], [45.0, 590.0]]], "lines": ["第１０５話"]}, {"box": [1194, 606, 1246, 724], "vertical": true, "font_size": 36, "lines_coords": [[[1194.0, 606.0], [1246.0, 606.0], [1246.0, 724.0], [1194.0, 724.0]]], "lines": ["別に．．．"]}, {"box": [993, 668, 1134, 917], "vertical": true, "font_size": 36, "lines_coords": [[[1099.0, 668.0], [1134.0, 668.0], [1134.0, 828.0], [1099.0, 828.0]], [[1064.0, 668.0], [1101.0, 668.0], [1097.0, 917.0], [1059.0, 917.0]], [[1030.0, 672.0], [1059.0, 672.0], [1059.0, 797.0], [1030.0, 797.0]], [[993.0, 674.0], [1022.0, 674.0], [1022.0, 869.0], [993.0, 869.0]]], "lines": ["でも旅行は", "しっかり楽しんで", "くるのは", "お前らしいよ。"]}, {"box": [786, 523, 857, 720], "vertical": true, "font_size": 36, "lines_coords": [[[817.0, 523.0], [852.0, 523.0], [857.0, 681.0], [821.0, 681.0]], [[786.0, 523.0], [815.0, 523.0], [815.0, 720.0], [786.0, 720.0]]], "lines": ["いらねーよ", "荷物になるし。"]}, {"box": [685, 708, 763, 958], "vertical": true, "font_size": 36, "lines_coords": [[[720.0, 708.0], [763.0, 708.0], [763.0, 842.0], [720.0, 842.0]], [[687.0, 710.0], [722.0, 710.0], [720.0, 958.0], [685.0, 958.0]]], "lines": ["というか", "タバコやめたの？"]}, {"box": [347, 612, 395, 693], "vertical": true, "font_size": 37, "lines_coords": [[[347.0, 612.0], [395.0, 612.0], [395.0, 693.0], [347.0, 693.0]]], "lines": ["は？"]}, {"box": [155, 718, 298, 900], "vertical": true, "font_size": 37, "lines_coords": [[[262.0, 718.0], [298.0, 718.0], [298.0, 875.0], [262.0, 875.0]], [[223.0, 718.0], [262.0, 718.0], [262.0, 817.0], [223.0, 817.0]], [[192.0, 720.0], [221.0, 720.0], [221.0, 900.0], [192.0, 900.0]], [[155.0, 720.0], [188.0, 720.0], [188.0, 826.0], [155.0, 826.0]]], "lines": ["お前らしく", "ねーな", "ヒアルロン酸", "打てよ。"]}, {"box": [1264, 1049, 1293, 1209], "vertical": true, "font_size": 36, "lines_coords": [[[1264.0, 1049.0], [1293.0, 1049.0], [1293.0, 1209.0], [1264.0, 1209.0]]], "lines": ["．．．早乙女は、"]}, {"box": [1099, 1093, 1175, 1281], "vertical": true, "font_size": 36, "lines_coords": [[[1126.0, 1093.0], [1175.0, 1093.0], [1175.0, 1171.0], [1126.0, 1171.0]], [[1099.0, 1099.0], [1128.0, 1099.0], [1128.0, 1281.0], [1099.0, 1281.0]]], "lines": ["仕事", "大丈夫なの？"]}, {"box": [1202, 1455, 1308, 1635], "vertical": true, "font_size": 32, "lines_coords": [[[1279.0, 1455.0], [1308.0, 1455.0], [1308.0, 1635.0], [1279.0, 1635.0]], [[1244.0, 1455.0], [1273.0, 1455.0], [1273.0, 1606.0], [1244.0, 1606.0]], [[1202.0, 1455.0], [1237.0, 1455.0], [1237.0, 1606.0], [1202.0, 1606.0]]], "lines": ["．．．あんな番組", "担当してて", "楽しいの？"]}, {"box": [240, 1115, 346, 1314], "vertical": true, "font_size": 31, "lines_coords": [[[310.0, 1115.0], [345.0, 1115.0], [345.0, 1273.0], [310.0, 1273.0]], [[277.0, 1117.0], [306.0, 1117.0], [306.0, 1269.0], [277.0, 1269.0]], [[240.0, 1117.0], [269.0, 1117.0], [269.0, 1314.0], [240.0, 1314.0]]], "lines": ["午後イチで", "会議だけど", "それまでなら。"]}, {"box": [1095, 1741, 1242, 1985], "vertical": true, "font_size": 32, "lines_coords": [[[1206.0, 1741.0], [1242.0, 1741.0], [1242.0, 1925.0], [1206.0, 1925.0]], [[1169.0, 1741.0], [1204.0, 1741.0], [1204.0, 1985.0], [1169.0, 1985.0]], [[1134.0, 1745.0], [1163.0, 1745.0], [1163.0, 1983.0], [1134.0, 1983.0]], [[1097.0, 1741.0], [1128.0, 1741.0], [1126.0, 1952.0], [1095.0, 1952.0]]], "lines": ["モデルと芸人", "散りばめた安直な", "クイズ番組なんて", "退屈じゃない？"]}, {"box": [256, 1507, 364, 1691], "vertical": true, "font_size": 30, "lines_coords": [[[335.0, 1602.0], [356.0, 1602.0], [356.0, 1633.0], [335.0, 1633.0]], [[325.0, 1507.0], [364.0, 1507.0], [364.0, 1569.0], [325.0, 1569.0]], [[291.0, 1511.0], [320.0, 1511.0], [320.0, 1691.0], [291.0, 1691.0]], [[256.0, 1509.0], [285.0, 1509.0], [285.0, 1645.0], [256.0, 1645.0]]], "lines": ["ん", "あー", "終わる終わろ", "あんなの。"]}, {"box": [163, 1763, 269, 1985], "vertical": true, "font_size": 30, "lines_coords": [[[233.0, 1763.0], [269.0, 1763.0], [269.0, 1888.0], [233.0, 1888.0]], [[200.0, 1765.0], [229.0, 1765.0], [229.0, 1917.0], [200.0, 1917.0]], [[163.0, 1763.0], [192.0, 1763.0], [192.0, 1985.0], [163.0, 1985.0]]], "lines": ["いや別に", "いいんだよ", "俺の仕事の話は。"]}], "img_path": "109.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1117, 144, 1258, 424], "vertical": true, "font_size": 30, "lines_coords": [[[1231.0, 146.0], [1258.0, 146.0], [1258.0, 333.0], [1231.0, 333.0]], [[1190.0, 144.0], [1221.0, 144.0], [1223.0, 393.0], [1192.0, 393.0]], [[1155.0, 144.0], [1186.0, 144.0], [1184.0, 424.0], [1153.0, 424.0]], [[1117.0, 144.0], [1146.0, 144.0], [1146.0, 403.0], [1117.0, 403.0]]], "lines": ["．．．まァ状況が", "わかればわざわざ", "事を荒だてる必要も", "ないんだろうけど。"]}, {"box": [1020, 509, 1136, 757], "vertical": true, "font_size": 30, "lines_coords": [[[1101.0, 509.0], [1136.0, 509.0], [1136.0, 714.0], [1101.0, 714.0]], [[1062.0, 511.0], [1090.0, 511.0], [1090.0, 710.0], [1062.0, 710.0]], [[1020.0, 511.0], [1049.0, 511.0], [1049.0, 757.0], [1020.0, 757.0]]], "lines": ["元夫とはいえ", "俺も他人には", "変わりない訳で。"]}, {"box": [153, 635, 322, 875], "vertical": true, "font_size": 40, "lines_coords": [[[281.0, 637.0], [316.0, 637.0], [316.0, 838.0], [281.0, 838.0]], [[238.0, 637.0], [281.0, 637.0], [281.0, 780.0], [238.0, 780.0]], [[200.0, 639.0], [236.0, 639.0], [236.0, 875.0], [200.0, 875.0]], [[153.0, 635.0], [200.0, 635.0], [200.0, 726.0], [153.0, 726.0]]], "lines": ["ただ老婆心で", "彼に一言", "言ってやりたく", "てね。"]}, {"box": [1086, 1051, 1227, 1250], "vertical": true, "font_size": 33, "lines_coords": [[[1198.0, 1055.0], [1227.0, 1055.0], [1227.0, 1204.0], [1198.0, 1204.0]], [[1157.0, 1051.0], [1194.0, 1051.0], [1194.0, 1151.0], [1157.0, 1151.0]], [[1119.0, 1053.0], [1155.0, 1053.0], [1155.0, 1206.0], [1119.0, 1206.0]], [[1086.0, 1053.0], [1115.0, 1053.0], [1115.0, 1250.0], [1086.0, 1250.0]]], "lines": ["．．．これ以上", "南条に", "関わらない", "ほうがいいよ。"]}, {"box": [1134, 1430, 1275, 1643], "vertical": true, "font_size": 29, "lines_coords": [[[1244.0, 1430.0], [1273.0, 1430.0], [1273.0, 1583.0], [1244.0, 1583.0]], [[1208.0, 1434.0], [1237.0, 1434.0], [1237.0, 1643.0], [1208.0, 1643.0]], [[1171.0, 1432.0], [1200.0, 1432.0], [1200.0, 1614.0], [1171.0, 1614.0]], [[1134.0, 1432.0], [1163.0, 1432.0], [1163.0, 1598.0], [1134.0, 1598.0]]], "lines": ["南条は一度", "決めたら無駄に", "行動力だけは", "あるからさ。"]}, {"box": [633, 1416, 701, 1604], "vertical": true, "font_size": 30, "lines_coords": [[[666.0, 1416.0], [701.0, 1416.0], [701.0, 1569.0], [666.0, 1569.0]], [[633.0, 1416.0], [662.0, 1416.0], [662.0, 1604.0], [633.0, 1604.0]]], "lines": ["大学ん時も", "そうだったよ、"]}, {"box": [376, 1037, 484, 1258], "vertical": true, "font_size": 33, "lines_coords": [[[445.0, 1037.0], [482.0, 1037.0], [484.0, 1163.0], [447.0, 1163.0]], [[414.0, 1039.0], [443.0, 1039.0], [443.0, 1219.0], [414.0, 1219.0]], [[376.0, 1039.0], [405.0, 1039.0], [405.0, 1258.0], [376.0, 1258.0]]], "lines": ["コイツは", "自己実現しか", "考えてないから。"]}, {"box": [146, 1126, 298, 1296], "vertical": true, "font_size": 33, "lines_coords": [[[252.0, 1128.0], [298.0, 1128.0], [298.0, 1227.0], [252.0, 1227.0]], [[219.0, 1126.0], [254.0, 1126.0], [254.0, 1252.0], [219.0, 1252.0]], [[188.0, 1130.0], [211.0, 1130.0], [211.0, 1281.0], [188.0, 1281.0]], [[146.0, 1128.0], [178.0, 1128.0], [180.0, 1296.0], [149.0, 1296.0]]], "lines": ["いずれ", "躊躇なく", "捨てられる", "だけでしょ。"]}, {"box": [511, 1668, 654, 1912], "vertical": true, "font_size": 30, "lines_coords": [[[625.0, 1670.0], [654.0, 1670.0], [654.0, 1883.0], [625.0, 1883.0]], [[587.0, 1672.0], [616.0, 1672.0], [616.0, 1883.0], [587.0, 1883.0]], [[550.0, 1670.0], [579.0, 1670.0], [577.0, 1881.0], [548.0, 1881.0]], [[515.0, 1668.0], [544.0, 1668.0], [540.0, 1912.0], [511.0, 1912.0]]], "lines": ["せっかく楽勝で", "マスコミの内定", "とったのに結局", "蹴って中退して．．．"]}, {"box": [113, 1759, 249, 2030], "vertical": true, "font_size": 31, "lines_coords": [[[219.0, 1759.0], [248.0, 1759.0], [248.0, 1910.0], [219.0, 1910.0]], [[182.0, 1761.0], [211.0, 1761.0], [211.0, 2030.0], [182.0, 2030.0]], [[140.0, 1759.0], [175.0, 1759.0], [175.0, 2004.0], [140.0, 2004.0]]], "lines": ["それは君が", "あの時就職しろって", "しつこく言うから"]}], "img_path": "110.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1206, 161, 1314, 378], "vertical": true, "font_size": 32, "lines_coords": [[[1279.0, 163.0], [1314.0, 163.0], [1314.0, 378.0], [1279.0, 378.0]], [[1242.0, 161.0], [1277.0, 161.0], [1277.0, 287.0], [1242.0, 287.0]], [[1206.0, 161.0], [1242.0, 161.0], [1242.0, 273.0], [1206.0, 273.0]]], "lines": ["：天の邪鬼って", "逆に素直", "だよね。"]}, {"box": [1078, 405, 1219, 652], "vertical": true, "font_size": 32, "lines_coords": [[[1190.0, 407.0], [1219.0, 407.0], [1219.0, 648.0], [1190.0, 648.0]], [[1151.0, 405.0], [1180.0, 405.0], [1180.0, 652.0], [1151.0, 652.0]], [[1113.0, 407.0], [1142.0, 407.0], [1142.0, 590.0], [1113.0, 590.0]], [[1078.0, 407.0], [1107.0, 407.0], [1107.0, 544.0], [1078.0, 544.0]]], "lines": ["右に行かせたきゃ", "まず左に行けって", "言えばいいん", "だからさ。"]}, {"box": [693, 339, 797, 614], "vertical": true, "font_size": 28, "lines_coords": [[[765.0, 339.0], [797.0, 339.0], [792.0, 523.0], [761.0, 523.0]], [[728.0, 341.0], [757.0, 341.0], [757.0, 614.0], [728.0, 614.0]], [[693.0, 341.0], [720.0, 341.0], [720.0, 585.0], [693.0, 585.0]]], "lines": ["稼ぎが無きや", "もっと俺になつくと", "思ったんだけど．．．"]}, {"box": [1194, 904, 1264, 1121], "vertical": true, "font_size": 34, "lines_coords": [[[1225.0, 904.0], [1264.0, 904.0], [1264.0, 1004.0], [1225.0, 1004.0]], [[1194.0, 908.0], [1223.0, 908.0], [1223.0, 1120.0], [1194.0, 1120.0]]], "lines": ["．．．それ", "どういう意味？"]}, {"box": [542, 563, 643, 776], "vertical": true, "font_size": 28, "lines_coords": [[[616.0, 563.0], [643.0, 563.0], [643.0, 776.0], [616.0, 776.0]], [[579.0, 565.0], [606.0, 565.0], [606.0, 776.0], [579.0, 776.0]], [[542.0, 563.0], [571.0, 563.0], [571.0, 745.0], [542.0, 745.0]]], "lines": ["まさかそのまま", "離婚までされる", "とはねー．．．"]}, {"box": [264, 941, 335, 1158], "vertical": true, "font_size": 34, "lines_coords": [[[296.0, 941.0], [335.0, 941.0], [335.0, 1043.0], [296.0, 1043.0]], [[264.0, 946.0], [293.0, 946.0], [293.0, 1157.0], [264.0, 1157.0]]], "lines": ["．．．ん？", "独り言だけど？"]}, {"box": [1262, 1291, 1291, 1469], "vertical": true, "font_size": 33, "lines_coords": [[[1262.0, 1291.0], [1291.0, 1291.0], [1291.0, 1469.0], [1262.0, 1469.0]]], "lines": ["小野寺くん。"]}, {"box": [679, 1304, 788, 1490], "vertical": true, "font_size": 33, "lines_coords": [[[759.0, 1308.0], [788.0, 1308.0], [788.0, 1430.0], [759.0, 1430.0]], [[720.0, 1308.0], [749.0, 1308.0], [749.0, 1490.0], [720.0, 1490.0]], [[679.0, 1304.0], [718.0, 1304.0], [718.0, 1403.0], [679.0, 1403.0]]], "lines": ["たまたま", "事の成りゆき", "で．．．．．"]}, {"box": [538, 1374, 647, 1536], "vertical": true, "font_size": 33, "lines_coords": [[[600.0, 1374.0], [647.0, 1374.0], [647.0, 1455.0], [600.0, 1455.0]], [[573.0, 1385.0], [602.0, 1385.0], [602.0, 1536.0], [573.0, 1536.0]], [[538.0, 1387.0], [561.0, 1387.0], [561.0, 1534.0], [538.0, 1534.0]]], "lines": ["大方", "君はそんな", "感じだろ？"]}, {"box": [1223, 1554, 1260, 1676], "vertical": true, "font_size": 33, "lines_coords": [[[1223.0, 1554.0], [1260.0, 1554.0], [1260.0, 1676.0], [1223.0, 1676.0]]], "lines": ["．．．君さ。"]}, {"box": [867, 1674, 1010, 1917], "vertical": true, "font_size": 32, "lines_coords": [[[975.0, 1674.0], [1010.0, 1674.0], [1010.0, 1857.0], [975.0, 1857.0]], [[937.0, 1674.0], [972.0, 1674.0], [972.0, 1857.0], [937.0, 1857.0]], [[904.0, 1676.0], [933.0, 1676.0], [933.0, 1832.0], [904.0, 1832.0]], [[867.0, 1674.0], [896.0, 1674.0], [896.0, 1917.0], [867.0, 1917.0]]], "lines": ["不動産関係の", "仕事やりたい", "らしいけど、", "それはどうして？"]}, {"box": [331, 1645, 405, 1799], "vertical": true, "font_size": 31, "lines_coords": [[[370.0, 1647.0], [405.0, 1647.0], [405.0, 1799.0], [370.0, 1799.0]], [[331.0, 1645.0], [368.0, 1645.0], [368.0, 1770.0], [331.0, 1770.0]]], "lines": ["今、二十歳", "だっけ？"]}, {"box": [140, 1782, 283, 1997], "vertical": true, "font_size": 31, "lines_coords": [[[254.0, 1784.0], [283.0, 1784.0], [283.0, 1935.0], [254.0, 1935.0]], [[217.0, 1784.0], [246.0, 1784.0], [246.0, 1997.0], [217.0, 1997.0]], [[180.0, 1782.0], [209.0, 1782.0], [209.0, 1933.0], [180.0, 1933.0]], [[140.0, 1782.0], [169.0, 1782.0], [169.0, 1975.0], [140.0, 1975.0]]], "lines": ["そのノリで", "生きてきたなら", "今後も一生", "その程度だね。"]}], "img_path": "111.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1148, 163, 1289, 440], "vertical": true, "font_size": 32, "lines_coords": [[[1254.0, 165.0], [1289.0, 165.0], [1289.0, 325.0], [1254.0, 325.0]], [[1217.0, 163.0], [1246.0, 163.0], [1246.0, 436.0], [1217.0, 436.0]], [[1182.0, 165.0], [1211.0, 165.0], [1211.0, 440.0], [1182.0, 440.0]], [[1148.0, 167.0], [1171.0, 167.0], [1171.0, 318.0], [1148.0, 318.0]]], "lines": ["もしかして", "まだたっぷり時間と", "選択肢が残ってると", "思ってる？"]}, {"box": [1012, 424, 1126, 587], "vertical": true, "font_size": 32, "lines_coords": [[[1090.0, 430.0], [1126.0, 430.0], [1126.0, 587.0], [1090.0, 587.0]], [[1053.0, 430.0], [1082.0, 430.0], [1082.0, 583.0], [1053.0, 583.0]], [[1012.0, 424.0], [1057.0, 424.0], [1057.0, 509.0], [1012.0, 509.0]]], "lines": ["残念ながら", "もう手遅れ", "だよ。"]}, {"box": [126, 351, 306, 602], "vertical": true, "font_size": 32, "lines_coords": [[[273.0, 356.0], [304.0, 356.0], [302.0, 600.0], [271.0, 600.0]], [[236.0, 356.0], [271.0, 356.0], [271.0, 544.0], [236.0, 544.0]], [[196.0, 351.0], [231.0, 351.0], [231.0, 600.0], [196.0, 600.0]], [[163.0, 358.0], [192.0, 358.0], [192.0, 571.0], [163.0, 571.0]], [[126.0, 356.0], [155.0, 356.0], [155.0, 546.0], [126.0, 546.0]]], "lines": ["少なくとも今から", "本気出しても", "十代から走ってる", "奴との差は生涯", "埋まらないし。"]}, {"box": [1122, 782, 1229, 997], "vertical": true, "font_size": 32, "lines_coords": [[[1200.0, 788.0], [1229.0, 788.0], [1229.0, 937.0], [1200.0, 937.0]], [[1163.0, 786.0], [1198.0, 786.0], [1194.0, 997.0], [1159.0, 997.0]], [[1122.0, 782.0], [1165.0, 782.0], [1165.0, 896.0], [1122.0, 896.0]]], "lines": ["．．．いいかな", "はっきり言って", "おくよ。"]}, {"box": [883, 786, 1059, 1095], "vertical": true, "font_size": 32, "lines_coords": [[[1030.0, 790.0], [1059.0, 790.0], [1059.0, 973.0], [1030.0, 973.0]], [[995.0, 790.0], [1024.0, 790.0], [1024.0, 1093.0], [995.0, 1093.0]], [[956.0, 788.0], [985.0, 788.0], [985.0, 1095.0], [956.0, 1095.0]], [[917.0, 786.0], [952.0, 786.0], [952.0, 1095.0], [917.0, 1095.0]], [[883.0, 788.0], [910.0, 788.0], [910.0, 1066.0], [883.0, 1066.0]]], "lines": ["成功ってのは", "やりがいのある仕事で", "それに見合った収入を", "得ること、それ以外の", "なにものでもないし、"]}, {"box": [345, 790, 486, 1006], "vertical": true, "font_size": 33, "lines_coords": [[[463.0, 797.0], [486.0, 797.0], [486.0, 944.0], [463.0, 944.0]], [[424.0, 792.0], [451.0, 792.0], [451.0, 1006.0], [424.0, 1006.0]], [[385.0, 795.0], [414.0, 795.0], [414.0, 977.0], [385.0, 977.0]], [[345.0, 790.0], [382.0, 790.0], [382.0, 896.0], [345.0, 896.0]]], "lines": ["たとえ君が", "瞬間的に幸せを", "感じられたと", "しても、"]}, {"box": [136, 873, 283, 1060], "vertical": true, "font_size": 33, "lines_coords": [[[248.0, 877.0], [283.0, 877.0], [283.0, 1004.0], [248.0, 1004.0]], [[204.0, 873.0], [250.0, 873.0], [250.0, 987.0], [204.0, 987.0]], [[175.0, 879.0], [204.0, 879.0], [204.0, 1060.0], [175.0, 1060.0]], [[136.0, 875.0], [173.0, 875.0], [173.0, 956.0], [136.0, 956.0]]], "lines": ["負け犬は", "負け犬、", "それは変わら", "ない。"]}, {"box": [1136, 1190, 1242, 1401], "vertical": true, "font_size": 35, "lines_coords": [[[1213.0, 1192.0], [1242.0, 1192.0], [1242.0, 1372.0], [1213.0, 1372.0]], [[1175.0, 1192.0], [1204.0, 1192.0], [1204.0, 1401.0], [1175.0, 1401.0]], [[1136.0, 1190.0], [1171.0, 1190.0], [1171.0, 1316.0], [1136.0, 1316.0]]], "lines": ["小野寺くんの", "考える幸せって", "何だい？"]}, {"box": [1026, 1376, 1072, 1484], "vertical": true, "font_size": 35, "lines_coords": [[[1026.0, 1376.0], [1072.0, 1376.0], [1072.0, 1484.0], [1026.0, 1484.0]]], "lines": ["結婚？"]}, {"box": [318, 1238, 403, 1374], "vertical": true, "font_size": 40, "lines_coords": [[[358.0, 1238.0], [403.0, 1238.0], [403.0, 1351.0], [358.0, 1351.0]], [[318.0, 1240.0], [354.0, 1240.0], [354.0, 1374.0], [318.0, 1374.0]]], "lines": ["健康で", "長生き？"]}, {"box": [171, 1337, 252, 1511], "vertical": true, "font_size": 40, "lines_coords": [[[217.0, 1343.0], [252.0, 1343.0], [252.0, 1511.0], [217.0, 1511.0]], [[171.0, 1337.0], [215.0, 1337.0], [215.0, 1447.0], [171.0, 1447.0]]], "lines": ["趣味の充実", "とか？"]}, {"box": [1084, 1676, 1242, 1927], "vertical": true, "font_size": 34, "lines_coords": [[[1204.0, 1676.0], [1242.0, 1676.0], [1242.0, 1807.0], [1204.0, 1807.0]], [[1167.0, 1681.0], [1196.0, 1681.0], [1196.0, 1925.0], [1167.0, 1925.0]], [[1126.0, 1679.0], [1155.0, 1679.0], [1155.0, 1927.0], [1126.0, 1927.0]], [[1084.0, 1676.0], [1122.0, 1676.0], [1122.0, 1780.0], [1084.0, 1780.0]]], "lines": ["君がもし", "つつましい小さな", "幸せを望んでいる", "ならば、"]}, {"box": [939, 1792, 1020, 1995], "vertical": true, "font_size": 34, "lines_coords": [[[985.0, 1794.0], [1020.0, 1794.0], [1020.0, 1995.0], [985.0, 1995.0]], [[939.0, 1792.0], [975.0, 1792.0], [979.0, 1975.0], [944.0, 1975.0]]], "lines": ["それはきっと", "叶うと思う。"]}, {"box": [360, 1645, 463, 1944], "vertical": true, "font_size": 30, "lines_coords": [[[434.0, 1645.0], [463.0, 1645.0], [463.0, 1859.0], [434.0, 1859.0]], [[397.0, 1645.0], [426.0, 1645.0], [426.0, 1944.0], [397.0, 1944.0]], [[360.0, 1647.0], [389.0, 1647.0], [389.0, 1892.0], [360.0, 1892.0]]], "lines": ["ただその幸せは", "「弱者に優しい社会」が", "作った虚妄だから、"]}, {"box": [134, 1739, 275, 2024], "vertical": true, "font_size": 30, "lines_coords": [[[242.0, 1741.0], [273.0, 1741.0], [275.0, 1979.0], [244.0, 1979.0]], [[204.0, 1739.0], [240.0, 1739.0], [240.0, 1958.0], [204.0, 1958.0]], [[171.0, 1741.0], [200.0, 1741.0], [200.0, 2012.0], [171.0, 2012.0]], [[134.0, 1741.0], [161.0, 1741.0], [161.0, 2024.0], [134.0, 2024.0]]], "lines": ["いずれその社会は", "破綻してゆくし、", "生産性の低い奴から", "切り捨てられてゆく。"]}], "img_path": "112.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1175, 151, 1285, 339], "vertical": true, "font_size": 34, "lines_coords": [[[1250.0, 151.0], [1285.0, 151.0], [1281.0, 339.0], [1246.0, 339.0]], [[1211.0, 153.0], [1250.0, 153.0], [1250.0, 250.0], [1211.0, 250.0]], [[1175.0, 151.0], [1211.0, 151.0], [1211.0, 287.0], [1175.0, 287.0]]], "lines": ["．．．でもそれは", "君達の", "自業自得、"]}, {"box": [1001, 314, 1144, 532], "vertical": true, "font_size": 34, "lines_coords": [[[1115.0, 320.0], [1144.0, 320.0], [1144.0, 472.0], [1115.0, 472.0]], [[1080.0, 318.0], [1109.0, 318.0], [1109.0, 498.0], [1080.0, 498.0]], [[1039.0, 314.0], [1070.0, 314.0], [1072.0, 532.0], [1041.0, 532.0]], [[1001.0, 314.0], [1039.0, 314.0], [1039.0, 422.0], [1001.0, 422.0]]], "lines": ["いやむしろ", "君達が社会の", "足を引っぱった", "責任だ。"]}, {"box": [364, 132, 505, 378], "vertical": true, "font_size": 30, "lines_coords": [[[476.0, 132.0], [505.0, 132.0], [505.0, 285.0], [476.0, 285.0]], [[438.0, 134.0], [467.0, 134.0], [467.0, 378.0], [438.0, 378.0]], [[401.0, 132.0], [430.0, 132.0], [430.0, 287.0], [401.0, 287.0]], [[364.0, 134.0], [393.0, 134.0], [393.0, 327.0], [364.0, 327.0]]], "lines": ["だから君は", "切り捨てられても", "文句を言う", "権利はないし、"]}, {"box": [213, 339, 322, 525], "vertical": true, "font_size": 30, "lines_coords": [[[289.0, 339.0], [318.0, 339.0], [322.0, 525.0], [293.0, 525.0]], [[252.0, 341.0], [281.0, 341.0], [281.0, 492.0], [252.0, 492.0]], [[213.0, 339.0], [250.0, 339.0], [250.0, 438.0], [213.0, 438.0]]], "lines": ["．．．その覚悟は", "出来てるの", "かな？"]}, {"box": [1169, 650, 1274, 865], "vertical": true, "font_size": 29, "lines_coords": [[[1244.0, 652.0], [1273.0, 652.0], [1273.0, 865.0], [1244.0, 865.0]], [[1206.0, 654.0], [1235.0, 654.0], [1235.0, 836.0], [1206.0, 836.0]], [[1169.0, 650.0], [1198.0, 650.0], [1200.0, 846.0], [1171.0, 846.0]]], "lines": ["それは早乙女が", "勝ち組だから", "言えるんだよ。"]}, {"box": [211, 772, 325, 959], "vertical": true, "font_size": 36, "lines_coords": [[[283.0, 772.0], [320.0, 772.0], [325.0, 900.0], [287.0, 900.0]], [[254.0, 778.0], [283.0, 778.0], [283.0, 958.0], [254.0, 958.0]], [[211.0, 772.0], [252.0, 772.0], [252.0, 826.0], [211.0, 826.0]]], "lines": ["そうだよ", "勝ち組だから", "ね。"]}, {"box": [1043, 1117, 1267, 1424], "vertical": true, "font_size": 34, "lines_coords": [[[1235.0, 1124.0], [1264.0, 1124.0], [1264.0, 1275.0], [1235.0, 1275.0]], [[1196.0, 1122.0], [1231.0, 1122.0], [1231.0, 1397.0], [1196.0, 1397.0]], [[1161.0, 1124.0], [1190.0, 1124.0], [1190.0, 1424.0], [1161.0, 1424.0]], [[1122.0, 1120.0], [1157.0, 1120.0], [1159.0, 1397.0], [1124.0, 1397.0]], [[1088.0, 1124.0], [1117.0, 1124.0], [1117.0, 1364.0], [1088.0, 1364.0]], [[1043.0, 1117.0], [1093.0, 1117.0], [1093.0, 1196.0], [1043.0, 1196.0]]], "lines": ["勝つために", "子供の頃から必死に", "リスクヘッジしながら", "不安や堕落と戦って", "真剣に生きてきた", "俺が"]}, {"box": [207, 1385, 331, 1556], "vertical": true, "font_size": 39, "lines_coords": [[[293.0, 1389.0], [331.0, 1389.0], [331.0, 1525.0], [293.0, 1525.0]], [[252.0, 1389.0], [287.0, 1389.0], [287.0, 1556.0], [252.0, 1556.0]], [[207.0, 1385.0], [250.0, 1385.0], [250.0, 1492.0], [207.0, 1492.0]]], "lines": ["負け犬を", "貶めて何が", "悪い？"]}, {"box": [1225, 1718, 1254, 1867], "vertical": true, "font_size": 35, "lines_coords": [[[1225.0, 1718.0], [1254.0, 1718.0], [1254.0, 1867.0], [1225.0, 1867.0]]], "lines": ["君はなに？"]}, {"box": [1264, 1832, 1291, 1871], "vertical": true, "font_size": 35, "lines_coords": [[[1264.0, 1832.0], [1291.0, 1832.0], [1291.0, 1871.0], [1264.0, 1871.0]]], "lines": ["て"]}, {"box": [1072, 1803, 1155, 1939], "vertical": true, "font_size": 35, "lines_coords": [[[1117.0, 1807.0], [1155.0, 1807.0], [1155.0, 1939.0], [1117.0, 1939.0]], [[1072.0, 1803.0], [1119.0, 1803.0], [1119.0, 1886.0], [1072.0, 1886.0]]], "lines": ["喋れない", "の？"]}, {"box": [730, 1761, 813, 1904], "vertical": true, "font_size": 40, "lines_coords": [[[770.0, 1761.0], [813.0, 1761.0], [813.0, 1904.0], [770.0, 1904.0]], [[730.0, 1763.0], [768.0, 1763.0], [768.0, 1902.0], [730.0, 1902.0]]], "lines": ["喋りたく", "ないの？"]}, {"box": [385, 1736, 488, 1946], "vertical": true, "font_size": 32, "lines_coords": [[[459.0, 1736.0], [488.0, 1736.0], [488.0, 1919.0], [459.0, 1919.0]], [[420.0, 1736.0], [451.0, 1736.0], [449.0, 1946.0], [418.0, 1946.0]], [[385.0, 1736.0], [414.0, 1736.0], [414.0, 1923.0], [385.0, 1923.0]]], "lines": ["まァ賢明だよ", "言い返す言葉が", "ある訳ないし、"]}, {"box": [173, 1774, 283, 1989], "vertical": true, "font_size": 32, "lines_coords": [[[250.0, 1776.0], [281.0, 1776.0], [283.0, 1987.0], [252.0, 1987.0]], [[213.0, 1776.0], [248.0, 1776.0], [248.0, 1989.0], [213.0, 1989.0]], [[173.0, 1774.0], [211.0, 1774.0], [213.0, 1904.0], [175.0, 1904.0]]], "lines": ["出来る事なんて", "せいぜい逆切れ", "くらいか。"]}], "img_path": "113.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1225, 128, 1266, 275], "vertical": true, "font_size": 37, "lines_coords": [[[1225.0, 128.0], [1262.0, 128.0], [1266.0, 267.0], [1229.0, 267.0]]], "lines": ["ちょ．．．"]}, {"box": [436, 200, 465, 385], "vertical": true, "font_size": 40, "lines_coords": [[[436.0, 200.0], [465.0, 200.0], [465.0, 385.0], [436.0, 385.0]]], "lines": ["ちょっと．．．"]}, {"box": [227, 320, 331, 558], "vertical": true, "font_size": 40, "lines_coords": [[[287.0, 325.0], [331.0, 325.0], [331.0, 558.0], [287.0, 558.0]], [[227.0, 320.0], [275.0, 320.0], [275.0, 422.0], [227.0, 422.0]]], "lines": ["ひどすぎる", "よ！！"]}, {"box": [1217, 1206, 1287, 1362], "vertical": true, "font_size": 32, "lines_coords": [[[1250.0, 1206.0], [1287.0, 1206.0], [1287.0, 1310.0], [1250.0, 1310.0]], [[1217.0, 1211.0], [1246.0, 1211.0], [1246.0, 1362.0], [1217.0, 1362.0]]], "lines": ["君も女", "だなー．．．"]}, {"box": [1159, 1488, 1264, 1703], "vertical": true, "font_size": 32, "lines_coords": [[[1229.0, 1488.0], [1260.0, 1488.0], [1264.0, 1652.0], [1233.0, 1652.0]], [[1192.0, 1488.0], [1227.0, 1488.0], [1227.0, 1703.0], [1192.0, 1703.0]], [[1159.0, 1494.0], [1188.0, 1494.0], [1188.0, 1656.0], [1159.0, 1656.0]]], "lines": ["甘過ぎるよ、", "この子のどこが", "いいんだか。"]}, {"box": [867, 1749, 972, 2020], "vertical": true, "font_size": 32, "lines_coords": [[[937.0, 1749.0], [972.0, 1749.0], [972.0, 1875.0], [937.0, 1875.0]], [[902.0, 1749.0], [933.0, 1749.0], [931.0, 2020.0], [900.0, 2020.0]], [[867.0, 1749.0], [896.0, 1749.0], [896.0, 1960.0], [867.0, 1960.0]]], "lines": ["幸は本来", "こっち側の人間だと", "思ってたけど？"]}, {"box": [484, 1784, 527, 1908], "vertical": true, "font_size": 39, "lines_coords": [[[484.0, 1784.0], [527.0, 1784.0], [527.0, 1908.0], [484.0, 1908.0]]], "lines": ["「．．．もう"]}, {"box": [403, 1786, 443, 1956], "vertical": true, "font_size": 39, "lines_coords": [[[403.0, 1786.0], [438.0, 1786.0], [443.0, 1956.0], [407.0, 1956.0]]], "lines": ["いいです。」"]}], "img_path": "114.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [608, 146, 649, 608], "vertical": true, "font_size": 35, "lines_coords": [[[608.0, 146.0], [643.0, 146.0], [645.0, 608.0], [610.0, 608.0]]], "lines": ["「わかってます、そういうの。」"]}, {"box": [724, 1024, 805, 1234], "vertical": true, "font_size": 36, "lines_coords": [[[765.0, 1024.0], [803.0, 1024.0], [803.0, 1146.0], [765.0, 1146.0]], [[724.0, 1024.0], [759.0, 1024.0], [759.0, 1231.0], [724.0, 1231.0]]], "lines": ["「．．．僕が", "言えるのは。」"]}], "img_path": "115.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [741, 112, 776, 453], "vertical": true, "font_size": 29, "lines_coords": [[[741.0, 115.0], [770.0, 115.0], [770.0, 436.0], [741.0, 436.0]]], "lines": ["一言方と僕は合わない"]}, {"box": [624, 110, 777, 453], "vertical": true, "font_size": 153, "lines_coords": [[[624.0, 110.0], [777.0, 110.0], [777.0, 453.0], [624.0, 453.0]]], "lines": ["「貴方と僕は合わない。それだけです。」"]}, {"box": [622, 111, 655, 355], "vertical": true, "font_size": 29, "lines_coords": [[[623.0, 113.0], [652.0, 113.0], [652.0, 349.0], [623.0, 349.0]]], "lines": ["それだけです。」"]}, {"box": [1130, 606, 1167, 703], "vertical": true, "font_size": 36, "lines_coords": [[[1130.0, 606.0], [1167.0, 606.0], [1167.0, 703.0], [1130.0, 703.0]]], "lines": ["彼はー"]}, {"box": [1055, 807, 1090, 960], "vertical": true, "font_size": 36, "lines_coords": [[[1055.0, 807.0], [1090.0, 807.0], [1090.0, 960.0], [1055.0, 960.0]]], "lines": ["早乙女は。"]}, {"box": [236, 1619, 303, 1780], "vertical": true, "font_size": 26, "lines_coords": [[[271.0, 1621.0], [300.0, 1621.0], [300.0, 1770.0], [271.0, 1770.0]], [[238.0, 1623.0], [260.0, 1623.0], [260.0, 1776.0], [238.0, 1776.0]]], "lines": ["弱点の無い", "人間だから、"]}], "img_path": "116.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1151, 103, 1277, 289], "vertical": true, "font_size": 34, "lines_coords": [[[1233.0, 103.0], [1277.0, 103.0], [1277.0, 215.0], [1233.0, 215.0]], [[1198.0, 109.0], [1227.0, 109.0], [1227.0, 277.0], [1198.0, 277.0]], [[1151.0, 103.0], [1186.0, 103.0], [1190.0, 289.0], [1155.0, 289.0]]], "lines": ["そこが", "尊敬できる", "ところだし、"]}, {"box": [1107, 300, 1138, 453], "vertical": true, "font_size": 29, "lines_coords": [[[1107.0, 300.0], [1136.0, 300.0], [1136.0, 453.0], [1107.0, 453.0]]], "lines": ["新宿美衣湯？"]}, {"box": [929, 151, 1047, 322], "vertical": true, "font_size": 34, "lines_coords": [[[1018.0, 155.0], [1047.0, 155.0], [1047.0, 322.0], [1018.0, 322.0]], [[977.0, 153.0], [1006.0, 153.0], [1006.0, 322.0], [977.0, 322.0]], [[929.0, 151.0], [968.0, 151.0], [968.0, 242.0], [929.0, 242.0]]], "lines": ["軽蔑してる", "ところでも", "ある。"]}, {"box": [660, 161, 766, 376], "vertical": true, "font_size": 32, "lines_coords": [[[734.0, 161.0], [765.0, 161.0], [763.0, 372.0], [732.0, 372.0]], [[695.0, 163.0], [730.0, 163.0], [730.0, 376.0], [695.0, 376.0]], [[660.0, 163.0], [689.0, 163.0], [689.0, 345.0], [660.0, 345.0]]], "lines": ["．．．けどさっきの", "八つ当たりには", "落胆したな．．．"]}, {"box": [269, 434, 304, 573], "vertical": true, "font_size": 34, "lines_coords": [[[269.0, 434.0], [304.0, 434.0], [304.0, 573.0], [269.0, 573.0]]], "lines": ["あのさ．．．"]}, {"box": [1219, 944, 1248, 1144], "vertical": true, "font_size": 32, "lines_coords": [[[1219.0, 944.0], [1248.0, 944.0], [1248.0, 1144.0], [1219.0, 1144.0]]], "lines": ["ひとつめは．．．"]}, {"box": [171, 627, 248, 869], "vertical": true, "font_size": 34, "lines_coords": [[[213.0, 627.0], [248.0, 627.0], [248.0, 869.0], [213.0, 869.0]], [[171.0, 629.0], [202.0, 629.0], [204.0, 838.0], [173.0, 838.0]]], "lines": ["二つお知らせが", "あるんだけど、"]}, {"box": [1099, 1097, 1134, 1341], "vertical": true, "font_size": 32, "lines_coords": [[[1099.0, 1097.0], [1134.0, 1097.0], [1134.0, 1341.0], [1099.0, 1341.0]]], "lines": ["この間、あたしが"]}, {"box": [1020, 1093, 1133, 1338], "vertical": true, "font_size": 38, "lines_coords": [[[1064.0, 1099.0], [1093.0, 1099.0], [1093.0, 1337.0], [1064.0, 1337.0]], [[1020.0, 1093.0], [1066.0, 1093.0], [1066.0, 1178.0], [1020.0, 1178.0]]], "lines": ["ひとりで描いてた", "原稿。"]}, {"box": [484, 1250, 542, 1312], "vertical": false, "font_size": 51, "lines_coords": [[[500.0, 1250.0], [542.0, 1262.0], [527.0, 1312.0], [484.0, 1298.0]]], "lines": ["Ａｍａｚｏｎ"]}, {"box": [211, 1306, 412, 1575], "vertical": true, "font_size": 30, "lines_coords": [[[378.0, 1310.0], [407.0, 1310.0], [407.0, 1575.0], [378.0, 1575.0]], [[331.0, 1306.0], [366.0, 1306.0], [366.0, 1575.0], [331.0, 1575.0]], [[293.0, 1310.0], [322.0, 1310.0], [322.0, 1509.0], [293.0, 1509.0]], [[252.0, 1310.0], [281.0, 1310.0], [281.0, 1542.0], [252.0, 1542.0]], [[211.0, 1310.0], [240.0, 1310.0], [240.0, 1521.0], [211.0, 1521.0]]], "lines": ["他の漫画家さんが", "間に合わなかった", "埋め合わせて", "近々雑誌に掲載", "されるってさ。"]}, {"box": [1119, 1703, 1238, 1937], "vertical": true, "font_size": 33, "lines_coords": [[[1200.0, 1703.0], [1235.0, 1703.0], [1235.0, 1937.0], [1200.0, 1937.0]], [[1163.0, 1705.0], [1192.0, 1705.0], [1192.0, 1873.0], [1163.0, 1873.0]], [[1119.0, 1703.0], [1155.0, 1703.0], [1155.0, 1915.0], [1119.0, 1915.0]]], "lines": ["あたし個人だと", "前に新人賞", "もらってるし、"]}, {"box": [149, 1784, 270, 2022], "vertical": true, "font_size": 31, "lines_coords": [[[236.0, 1788.0], [264.0, 1788.0], [264.0, 2018.0], [236.0, 2018.0]], [[190.0, 1786.0], [225.0, 1786.0], [225.0, 2022.0], [190.0, 2022.0]], [[149.0, 1784.0], [180.0, 1784.0], [182.0, 1999.0], [151.0, 1999.0]]], "lines": ["評判が良ければ", "連載になるかも", "しれないって。"]}], "img_path": "117.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1173, 886, 1208, 1038], "vertical": true, "font_size": 35, "lines_coords": [[[1173.0, 886.0], [1208.0, 886.0], [1208.0, 1035.0], [1173.0, 1035.0]]], "lines": ["．．．あたし、"]}, {"box": [829, 440, 862, 657], "vertical": true, "font_size": 29, "lines_coords": [[[830.0, 440.0], [859.0, 440.0], [859.0, 656.0], [830.0, 656.0]]], "lines": ["もうひとつは。"]}, {"box": [196, 1262, 279, 1448], "vertical": true, "font_size": 40, "lines_coords": [[[229.0, 1262.0], [279.0, 1262.0], [279.0, 1343.0], [229.0, 1343.0]], [[196.0, 1269.0], [225.0, 1269.0], [225.0, 1447.0], [196.0, 1447.0]]], "lines": ["妊娠", "してるんだ。"]}], "img_path": "118.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1140, 76, 1188, 91], "vertical": false, "font_size": 15, "lines_coords": [[[1140.0, 76.0], [1188.0, 76.0], [1188.0, 91.0], [1140.0, 91.0]]], "lines": ["ああ君はちょーっと"]}], "img_path": "119.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [], "img_path": "120.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [697, 1, 1065, 139], "vertical": false, "font_size": 151, "lines_coords": [[[697.0, 0.0], [1065.0, 0.0], [1065.0, 152.0], [697.0, 152.0]]], "lines": ["ＰＵＳＲＡＲ"]}, {"box": [263, 96, 299, 430], "vertical": true, "font_size": 29, "lines_coords": [[[264.0, 103.0], [293.0, 103.0], [293.0, 424.0], [264.0, 424.0]]], "lines": ["「．．．中出しですか。」"]}, {"box": [792, 714, 880, 923], "vertical": true, "font_size": 44, "lines_coords": [[[844.0, 720.0], [879.0, 720.0], [879.0, 923.0], [844.0, 923.0]], [[792.0, 714.0], [846.0, 714.0], [846.0, 811.0], [792.0, 811.0]]], "lines": ["早乙女くんの", "子供。"]}, {"box": [587, 611, 