x": [736, 1554, 1084, 1618], "vertical": false, "font_size": 32.0, "lines_coords": [[[972.0, 1554.0], [1084.0, 1554.0], [1084.0, 1590.0], [972.0, 1590.0]], [[736.0, 1590.0], [972.0, 1590.0], [972.0, 1618.0], [736.0, 1618.0]]], "lines": ["株式株入社", "販売０３（５２８）３５５６"]}, {"box": [1084, 1231, 1300, 1258], "vertical": false, "font_size": 27, "lines_coords": [[[1084.0, 1231.0], [1300.0, 1231.0], [1300.0, 1258.0], [1084.0, 1258.0]]], "lines": ["Ｐｒｉｎｔｅｄｉｎ，Ｊａｐａｎ："]}, {"box": [198, 1654, 1298, 1683], "vertical": false, "font_size": 29, "lines_coords": [[[198.0, 1654.0], [1298.0, 1654.0], [1298.0, 1683.0], [198.0, 1683.0]]], "lines": ["●選本には十分注意しておりますが、落丁・乱丁「本のページの抜け落ちや順序の問違いの場合はお取り"]}, {"box": [196, 2008, 923, 2035], "vertical": false, "font_size": 27, "lines_coords": [[[196.0, 2008.0], [923.0, 2008.0], [923.0, 2035.0], [196.0, 2035.0]]], "lines": ["代行業者等の第三者による本書の電子的検製も認められておりません。"]}, {"box": [664, 1546, 1227, 1635], "vertical": false, "font_size": 46.5, "lines_coords": [[[664.0, 1546.0], [968.0, 1548.0], [968.0, 1577.0], [664.0, 1575.0]], [[946.0, 1571.0], [1221.0, 1550.0], [1227.0, 1614.0], [952.0, 1635.0]]], "lines": ["クロン編集（３３）５１）編集１６（３２３）「５０５", "２０１６年会社小学館"]}, {"box": [194, 1693, 1304, 1964], "vertical": false, "font_size": 23.11111111111111, "lines_coords": [[[196.0, 1693.0], [1302.0, 1693.0], [1302.0, 1714.0], [196.0, 1714.0]], [[200.0, 1728.0], [389.0, 1728.0], [389.0, 1749.0], [200.0, 1749.0]], [[198.0, 1763.0], [1293.0, 1763.0], [1293.0, 1784.0], [198.0, 1784.0]], [[194.0, 1797.0], [1151.0, 1797.0], [1151.0, 1823.0], [194.0, 1823.0]], [[198.0, 1834.0], [701.0, 1834.0], [701.0, 1855.0], [198.0, 1855.0]], [[194.0, 1865.0], [1304.0, 1865.0], [1304.0, 1892.0], [194.0, 1892.0]], [[202.0, 1904.0], [1132.0, 1904.0], [1132.0, 1925.0], [202.0, 1925.0]], [[196.0, 1937.0], [486.0, 1939.0], [486.0, 1962.0], [196.0, 1960.0]], [[480.0, 1937.0], [1016.0, 1937.0], [1016.0, 1964.0], [480.0, 1964.0]]], "lines": ["替えいたします。購入された書店名を明記して「制作局」あてにお送りください。送料小社負担にてお取り", "り替えいたします。", "●本書の一部あるいは全部を無断で複製・転載・上演・放送等をすることは、法律で認められた場合を除き", "著作者および出版者の権利の授害となります。あらかじめ小社あて苦諾をお求めください。", "国｛公益社団法人日本複製権センター委託出版物", "本書を無断で複写複製（コピー一つすることは、著作権法、上の例外を除き、禁じられています。本書をコピー", "される場合は、事前に公益社団法人日本複製権センター（ＪＲＲＣ）の許諾を受けてください。", "ＪＲＲＣ－Ａｔｔｐ／／ｗｗｗｉｒｉｃｏｒｐ：", "ゆっくりメール。ｉｎｄｏ＠ｆｉｃｏｒｉｐ．ＴＥＬ（３－３４０１－２８２）"]}, {"box": [196, 1975, 1057, 1995], "vertical": false, "font_size": 20, "lines_coords": [[[196.0, 1975.0], [1057.0, 1975.0], [1057.0, 1995.0], [196.0, 1995.0]]], "lines": ["●本書の電子データ化等の無断複製は著作権法上での例外を除き禁じられています。"]}, {"box": [997, 1728, 1295, 1749], "vertical": false, "font_size": 21, "lines_coords": [[[997.0, 1728.0], [1295.0, 1728.0], [1295.0, 1749.0], [997.0, 1749.0]]], "lines": ["制作局（ＴＥＬ０１２０－３３６－０８２"]}], "img_path": "228.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [], "img_path": "229.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [35, 697, 1736, 2120], "vertical": false, "font_size": 1169, "lines_coords": [[[35.0, 1062.0], [1422.0, 697.0], [1736.0, 1892.0], [347.0, 2120.0]]], "lines": ["あっは〜はいはいっぱいはなんだけど、はっはじめ、はぁ．．．"]}, {"box": [93, 1256, 633, 2051], "vertical": true, "font_size": 255.0, "lines_coords": [[[260.0, 1256.0], [633.0, 1302.0], [540.0, 2051.0], [167.0, 2006.0]], [[93.0, 1509.0], [225.0, 1484.0], [314.0, 1962.0], [182.0, 1987.0]]], "lines": ["はははっはぁっはっ", "よっはっは"]}], "img_path": "230.png"}]}