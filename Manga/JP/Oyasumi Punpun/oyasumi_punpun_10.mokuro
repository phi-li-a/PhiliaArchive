"vertical": true, "font_size": 35, "lines_coords": [[[850.0, 1358.0], [886.0, 1358.0], [886.0, 1482.0], [850.0, 1482.0]], [[817.0, 1360.0], [846.0, 1360.0], [846.0, 1538.0], [817.0, 1538.0]], [[778.0, 1356.0], [813.0, 1356.0], [813.0, 1571.0], [778.0, 1571.0]], [[739.0, 1353.0], [778.0, 1353.0], [778.0, 1434.0], [739.0, 1434.0]]], "lines": ["あたしも", "たくさんウソ", "ついちゃってた", "から。"]}, {"box": [229, 1469, 269, 1645], "vertical": true, "font_size": 40, "lines_coords": [[[233.0, 1469.0], [269.0, 1469.0], [264.0, 1645.0], [229.0, 1645.0]]], "lines": ["ごめんね？"]}, {"box": [153, 1759, 281, 1935], "vertical": true, "font_size": 40, "lines_coords": [[[244.0, 1765.0], [281.0, 1765.0], [281.0, 1871.0], [244.0, 1871.0]], [[200.0, 1765.0], [238.0, 1765.0], [238.0, 1935.0], [200.0, 1935.0]], [[153.0, 1759.0], [204.0, 1759.0], [204.0, 1906.0], [153.0, 1906.0]]], "lines": ["悪気は", "なかったん", "だ．．．．．．"]}], "img_path": "148.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1167, 277, 1205, 423], "vertical": true, "font_size": 35, "lines_coords": [[[1167.0, 279.0], [1202.0, 279.0], [1202.0, 407.0], [1167.0, 407.0]]], "lines": ["．．．．．．あ"]}, {"box": [898, 105, 1024, 345], "vertical": true, "font_size": 38, "lines_coords": [[[987.0, 107.0], [1022.0, 107.0], [1022.0, 314.0], [987.0, 314.0]], [[944.0, 107.0], [979.0, 107.0], [979.0, 345.0], [944.0, 345.0]], [[898.0, 105.0], [941.0, 105.0], [941.0, 225.0], [898.0, 225.0]]], "lines": ["プンプンだけ", "人生楽しんでる", "なんて、"]}, {"box": [165, 200, 285, 372], "vertical": true, "font_size": 40, "lines_coords": [[[248.0, 200.0], [285.0, 200.0], [285.0, 372.0], [248.0, 372.0]], [[200.0, 200.0], [246.0, 200.0], [246.0, 310.0], [200.0, 310.0]], [[165.0, 200.0], [202.0, 200.0], [202.0, 339.0], [165.0, 339.0]]], "lines": ["．．．それって", "不公平", "じゃん？"]}, {"box": [937, 589, 972, 762], "vertical": true, "font_size": 35, "lines_coords": [[[937.0, 590.0], [972.0, 590.0], [972.0, 759.0], [937.0, 759.0]]], "lines": ["ううん．．．．．"]}, {"box": [40