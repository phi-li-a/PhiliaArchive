, 989.0], [310.0, 1240.0], [281.0, 1240.0]], [[242.0, 989.0], [271.0, 989.0], [271.0, 1258.0], [242.0, 1258.0]], [[196.0, 987.0], [231.0, 987.0], [231.0, 1227.0], [196.0, 1227.0]], [[157.0, 989.0], [186.0, 989.0], [186.0, 1223.0], [157.0, 1223.0]]], "lines": ["そして７月７日、", "新世界の始まりを", "ラヴァーズ達と", "語り合いたい！！"]}, {"box": [1014, 1712, 1155, 1956], "vertical": true, "font_size": 43, "lines_coords": [[[1111.0, 1712.0], [1155.0, 1712.0], [1151.0, 1919.0], [1107.0, 1919.0]], [[1062.0, 1716.0], [1103.0, 1716.0], [1103.0, 1956.0], [1062.0, 1956.0]], [[1014.0, 1716.0], [1049.0, 1716.0], [1049.0, 1954.0], [1014.0, 1954.0]]], "lines": ["僕は君達を", "圧倒的に評価", "しているッ！！"]}, {"box": [184, 1693, 349, 1977], "vertical": true, "font_size": 46, "lines_coords": [[[298.0, 1693.0], [349.0, 1693.0], [349.0, 1838.0], [298.0, 1838.0]], [[242.0, 1697.0], [285.0, 1697.0], [285.0, 1977.0], [242.0, 1977.0]], [[184.0, 1697.0], [227.0, 1697.0], [227.0, 1929.0], [184.0, 1929.0]]], "lines": ["世界は", "もっと美しく", "なれるッ！！"]}], "img_path": "136.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1223, 84, 1306, 277], "vertical": true, "font_size": 42, "lines_coords": [[[1256.0, 84.0], [1306.0, 84.0], [1306.0, 269.0], [1256.0, 269.0]], [[1223.0, 89.0], [1258.0, 89.0], [1258.0, 277.0], [1223.0, 277.0]]], "lines": ["あのー．．．", "すみません。"]}, {"box": [931, 474, 1011, 710], "vertical": true, "font_size": 33, "lines_coords": [[[975.0, 474.0], [1010.0, 474.0], [1010.0, 645.0], [975.0, 645.0]], [[933.0, 476.0], [964.0, 476.0], [962.0, 710.0], [931.0, 710.0]]], "lines": ["演奏始めて", "もらえますか？"]}, {"box": [1142, 857, 1262, 1097], "vertical": true, "font_size": 36, "lines_coords": [[[1225.0, 859.0], [1262.0, 859.0], [1262.0, 964.0], [1225.0, 964.0]], [[1186.0, 859.0], [1221.0, 859.0], [1221.0, 1028.0], [1186.0, 1028.0]], [[1144.0, 857.0], [1180.0, 857.0], [1177.0, 1095.0], [1142.0, 1095.0]]], "lines": ["．．．さあ", "十二音階の", "魔法戦士達よ："]}, {"box": [732, 973, 873, 1215], "vertical": true, "font_size"