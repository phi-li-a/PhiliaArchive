_coords": [[[1167.0, 138.0], [1206.0, 138.0], [1206.0, 343.0], [1167.0, 343.0]]], "lines": ["あたしも．．"]}, {"box": [184, 850, 279, 1033], "vertical": true, "font_size": 42, "lines_coords": [[[233.0, 850.0], [279.0, 850.0], [279.0, 979.0], [233.0, 979.0]], [[186.0, 855.0], [223.0, 855.0], [223.0, 1028.0], [186.0, 1028.0]]], "lines": ["ずっと", "待ってた。"]}], "img_path": "152.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [142, 51, 1196, 378], "vertical": false, "font_size": 270.0, "lines_coords": [[[821.0, 97.0], [1196.0, 97.0], [1196.0, 310.0], [821.0, 310.0]], [[142.0, 51.0], [896.0, 51.0], [896.0, 378.0], [142.0, 378.0]]], "lines": ["．．．", "．．．"]}, {"box": [492, 521, 534, 619], "vertical": true, "font_size": 38, "lines_coords": [[[492.0, 523.0], [529.0, 521.0], [534.0, 616.0], [496.0, 619.0]]], "lines": ["中町商店"]}, {"box": [726, 517, 788, 679], "vertical": true, "font_size": 46, "lines_coords": [[[743.0, 517.0], [788.0, 521.0], [772.0, 679.0], [726.0, 674.0]]], "lines": ["中町市店街"]}, {"box": [167, 1855, 204, 1991], "vertical": true, "font_size": 37, "lines_coords": [[[167.0, 1855.0], [204.0, 1855.0], [204.0, 1991.0], [167.0, 1991.0]]], "lines": ["．．．はァ？"]}], "img_path": "153.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1138, 192, 1231, 306], "vertical": true, "font_size": 55, "lines_coords": [[[1177.0, 196.0], [1231.0, 196.0], [1231.0, 306.0], [1177.0, 306.0]], [[1138.0, 192.0], [1194.0, 192.0], [1194.0, 289.0], [1138.0, 289.0]]], "lines": ["アンタ", "それ、"]}, {"box": [204, 427, 247, 607], "vertical": true, "font_size": 38, "lines_coords": [[[204.0, 428.0], [242.0, 428.0], [244.0, 606.0], [207.0, 606.0]]], "lines": ["最低だろ。"]}, {"box": [1146, 823, 1250, 1010], "vertical": true, "font_size": 30, "lines_coords": [[[1221.0, 826.0], [1250.0, 826.0], [1250.0, 1010.0], [1221.0, 1010.0]], [[1184.0, 826.0], [1213.0, 826.0], [1213.0, 1010.0], [1184.0, 1010.0]], [[1146.0, 823.0], [1177.0, 823.0], [1177.0, 925.0], [1146.0, 925.0]]], "lines": ["中絶すんのは", "あんたの勝手", "だけど、"]}, {"box": [1016, 1012, 1119, 1256], "vertical": true, "font_size": 30, "lines_coords": [[[1088.0, 1012.0], [1119.0, 1012.0], [1117.0, 1256.0], [1086.0, 1256.0]], [[1051.0, 1014.0], [1082.0, 1014.0], [1080.0, 1227.0], [1049.0, 1227.0]], [[1016.0, 1012.0], [1045.0, 1012.0], [1045.0, 1136.0], [1016.0, 1136.0]]], "lines": ["てめーの不手際に", "他人巻き込んで", "さぁ．．．"]}, {"box": [1157, 1364, 1259, 1606], "vertical": true, "font_size": 29, "lines_coords": [[[1227.0, 1366.0], [1256.0, 1366.0], [1256.0, 1517.0], [1227.0, 1517.0]], [[1194.0, 1366.0], [1223.0, 1366.0], [1223.0, 1548.0], [1194.0, 1548.0]], [[1157.0, 1366.0], [1186.0, 1366.0], [1186.0, 1606.0], [1157.0, 1606.0]]], "lines": ["．．．アタシに", "だって言い分", "くらいあるけど？"]}, {"box": [614, 1380, 794, 1650], "vertical": true, "font_size": 30, "lines_coords": [[[759.0, 1380.0], [794.0, 1380.0], [794.0, 1505.0], [759.0, 1505.0]], [[726.0, 1380.0], [755.0, 1380.0], [755.0, 1558.0], [726.0, 1558.0]], [[689.0, 1380.0], [718.0, 1380.0], [718.0, 1592.0], [689.0, 1592.0]], [[652.0, 1380.0], [681.0, 1380.0], [681.0, 1650.0], [652.0, 1650.0]], [[614.0, 1380.0], [643.0, 1380.0], [645.0, 1575.0], [616.0, 1575.0]]], "lines": ["アンタと", "小野寺くんの", "微妙な関係性は", "アタシもわかってる", "つもりだけど。"]}, {"box": [184, 1062, 291, 1217], "vertical": true, "font_size": 36, "lines_coords": [[[256.0, 1064.0], [291.0, 1064.0], [291.0, 1188.0], [256.0, 1188.0]], [[219.0, 1062.0], [254.0, 1062.0], [254.0, 1217.0], [219.0, 1217.0]], [[184.0, 1062.0], [223.0, 1062.0], [223.0, 1111.0], [184.0, 1111.0]]], "lines": ["ましてや", "小野寺くん", "を。"]}, {"box": [115, 1465, 296, 1676], "vertical": true, "font_size": 31, "lines_coords": [[[256.0, 1465.0], [291.0, 1465.0], [296.0, 1629.0], [260.0, 1629.0]], [[225.0, 1467.0], [254.0, 1467.0], [254.0, 1618.0], [225.0, 1618.0]], [[188.0, 1465.0], [219.0, 1465.0], [215.0, 1618.0], [184.0, 1618.0]], [[153.0, 1469.0], [182.0, 1469.0], [182.0, 1621.0], [153.0, 1621.0]], [[115.0, 1467.0], [144.0, 1467.0], [144.0, 1676.0], [115.0, 1676.0]]], "lines": ["けどむしろ、", "だからこそ", "もっと彼に", "気遣うべき", "なんじゃない？"]}, {"box": [859, 1776, 977, 1917], "vertical": true, "font_size": 40, "lines_coords": [[[931.0, 1776.0], [977.0, 1776.0], [977.0, 1892.0], [931.0, 1892.0]], [[896.0, 1780.0], [935.0, 1780.0], [935.0, 1877.0], [896.0, 1877.0]], [[859.0, 1778.0], [894.0, 1778.0], [898.0, 1917.0], [863.0, 1917.0]]], "lines": ["．．．いや、", "南条が", "おかしい。"]}, {"box": [372, 1805, 478, 1999], "vertical": true, "font_size": 27, "lines_coords": [[[449.0, 1805.0], [478.0, 1805.0], [478.0, 1985.0], [449.0, 1985.0]], [[411.0, 1807.0], [440.0, 1807.0], [440.0, 1956.0], [411.0, 1956.0]], [[372.0, 1807.0], [401.0, 1807.0], [401.0, 1999.0], [372.0, 1999.0]]], "lines": ["断りきれない", "彼の性格に", "つけ込んでる。"]}, {"box": [211, 1865, 233, 2012], "vertical": true, "font_size": 27, "lines_coords": [[[211.0, 1865.0], [233.0, 1865.0], [233.0, 2012.0], [211.0, 2012.0]]], "lines": ["．．．というか"]}], "img_path": "154.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1180, 78, 1320, 296], "vertical": true, "font_size": 31, "lines_coords": [[[1291.0, 82.0], [1318.0, 82.0], [1318.0, 296.0], [1291.0, 296.0]], [[1250.0, 78.0], [1285.0, 78.0], [1281.0, 267.0], [1246.0, 267.0]], [[1213.0, 80.0], [1248.0, 80.0], [1248.0, 296.0], [1213.0, 296.0]], [[1180.0, 82.0], [1208.0, 82.0], [1208.0, 244.0], [1180.0, 244.0]]], "lines": ["アンタがあえて", "小野寺くんに", "利己的なお願い", "することで、"]}, {"box": [443, 70, 556, 260], "vertical": true, "font_size": 37, "lines_coords": [[[509.0, 70.0], [556.0, 70.0], [556.0, 146.0], [509.0, 146.0]], [[474.0, 72.0], [509.0, 72.0], [513.0, 260.0], [478.0, 260.0]], [[443.0, 74.0], [472.0, 74.0], [472.0, 227.0], [443.0, 227.0]]], "lines": ["一度", "素直になって", "考えてみ？"]}, {"box": [1146, 826, 1275, 1033], "vertical": true, "font_size": 42, "lines_coords": [[[1229.0, 826.0], [1275.0, 826.0], [1275.0, 935.0], [1229.0, 935.0]], [[1190.0, 826.0], [1227.0, 826.0], [1229.0, 1033.0], [1192.0, 1033.0]], [[1146.0, 826.0], [1190.0, 826.0], [1190.0, 944.0], [1146.0, 944.0]]], "lines": ["本当の", "自分の気持ち", "なんて、"]}, {"box": [848, 480, 960, 668], "vertical": true, "font_size": 31, "lines_coords": [[[929.0, 486.0], [958.0, 486.0], [958.0, 666.0], [929.0, 666.0]], [[892.0, 486.0], [921.0, 486.0], [921.0, 668.0], [892.0, 668.0]], [[852.0, 480.0], [888.0, 480.0], [883.0, 610.0], [848.0, 610.0]]], "lines": ["小野寺くんの", "反応を試して", "ないか？"]}, {"box": [152, 432, 330, 688], "vertical": true, "font_size": 29, "lines_coords": [[[300.0, 436.0], [329.0, 436.0], [329.0, 676.0], [300.0, 676.0]], [[262.0, 438.0], [291.0, 438.0], [291.0, 683.0], [262.0, 683.0]], [[223.0, 432.0], [254.0, 432.0], [252.0, 631.0], [221.0, 631.0]], [[188.0, 436.0], [217.0, 436.0], [217.0, 619.0], [188.0, 619.0]], [[153.0, 436.0], [182.0, 436.0], [182.0, 662.0], [153.0, 662.0]]], "lines": ["アンタは賢い人間", "かもしれないけど、", "その分、自分の", "気持ちに嘘を", "つくのも上手い。"]}, {"box": [242, 1128, 367, 1335], "vertical": true, "font_size": 37, "lines_coords": [[[333.0, 1134.0], [362.0, 1134.0], [362.0, 1298.0], [333.0, 1298.0]], [[287.0, 1130.0], [325.0, 1130.0], [320.0, 1335.0], [283.0, 1335.0]], [[242.0, 1128.0], [287.0, 1128.0], [287.0, 1219.0], [242.0, 1219.0]]], "lines": ["気付かない", "ほうがいいん", "だよ。"]}, {"box": [1192, 1567, 1300, 1761], "vertical": true, "font_size": 36, "lines_coords": [[[1262.0, 1567.0], [1300.0, 1567.0], [1300.0, 1691.0], [1262.0, 1691.0]], [[1229.0, 1569.0], [1258.0, 1569.0], [1258.0, 1749.0], [1229.0, 1749.0]], [[1192.0, 1569.0], [1221.0, 1569.0], [1221.0, 1761.0], [1192.0, 1761.0]]], "lines": ["．．．モデル", "やってるって", "いうのもウソ。"]}, {"box": [1055, 1768, 1173, 1954], "vertical": true, "font_size": 36, "lines_coords": [[[1128.0, 1768.0], [1173.0, 1768.0], [1173.0, 1869.0], [1128.0, 1869.0]], [[1099.0, 1776.0], [1128.0, 1776.0], [1128.0, 1954.0], [1099.0, 1954.0]], [[1055.0, 1768.0], [1101.0, 1768.0], [1101.0, 1857.0], [1055.0, 1857.0]]], "lines": ["彼氏が", "いるって話も", "ウソ。"]}, {"box": [416, 1594, 519, 1834], "vertical": true, "font_size": 30, "lines_coords": [[[488.0, 1594.0], [519.0, 1594.0], [517.0, 1834.0], [486.0, 1834.0]], [[453.0, 1594.0], [482.0, 1594.0], [482.0, 1778.0], [453.0, 1778.0]], [[416.0, 1594.0], [445.0, 1594.0], [445.0, 1784.0], [416.0, 1784.0]]], "lines": ["高校卒業してから", "友達と一度も", "会ってないし、"]}, {"box": [221, 1739, 364, 1952], "vertical": true, "font_size": 30, "lines_coords": [[[329.0, 1741.0], [364.0, 1741.0], [364.0, 1923.0], [329.0, 1923.0]], [[293.0, 1741.0], [322.0, 1741.0], [322.0, 1952.0], [293.0, 1952.0]], [[254.0, 1739.0], [285.0, 1739.0], [289.0, 1921.0], [258.0, 1921.0]], [[221.0, 1741.0], [250.0, 1741.0], [250.0, 1877.0], [221.0, 1877.0]]], "lines": ["服も靴も君が", "好きそうなのを", "選んで買って", "きたんだ。"]}], "img_path": "155.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1231, 124, 1260, 262], "vertical": true, "font_size": 33, "lines_coords": [[[1231.0, 124.0], [1260.0, 124.0], [1260.0, 262.0], [1231.0, 262.0]]], "lines": ["．．．だから"]}, {"box": [1101, 372, 1182, 577], "vertical": true, "font_size": 33, "lines_coords": [[[1146.0, 374.0], [1182.0, 374.0], [1182.0, 577.0], [1146.0, 577.0]], [[1105.0, 372.0], [1140.0, 372.0], [1136.0, 544.0], [1101.0, 544.0]]], "lines": ["アレもコレも", "ぜーーんぶ"]}, {"box": [1171, 782, 1215, 902], "vertical": true, "font_size": 36, "lines_coords": [[[1171.0, 782.0], [1215.0, 782.0], [1215.0, 902.0], [1171.0, 902.0]]], "lines": ["．．．けど、"]}, {"box": [202, 465, 248, 613], "vertical": true, "font_size": 46, "lines_coords": [[[202.0, 467.0], [248.0, 467.0], [248.0, 612.0], [202.0, 612.0]]], "lines": ["．．．ウソ。"]}, {"box": [1020, 1033, 1169, 1221], "vertical": true, "font_size": 36, "lines_coords": [[[1132.0, 1033.0], [1169.0, 1033.0], [1169.0, 1130.0], [1132.0, 1130.0]], [[1095.0, 1035.0], [1130.0, 1035.0], [1130.0, 1221.0], [1095.0, 1221.0]], [[1062.0, 1037.0], [1090.0, 1037.0], [1090.0, 1219.0], [1062.0, 1219.0]], [[1020.0, 1037.0], [1057.0, 1037.0], [1057.0, 1146.0], [1020.0, 1146.0]]], "lines": ["小さい", "芸能事務所に", "入ってたのは", "ホント。"]}, {"box": [182, 1664, 331, 1911], "vertical": true, "font_size": 33, "lines_coords": [[[285.0, 1664.0], [331.0, 1664.0], [331.0, 1770.0], [285.0, 1770.0]], [[256.0, 1672.0], [285.0, 1672.0], [285.0, 1881.0], [256.0, 1881.0]], [[219.0, 1672.0], [248.0, 1672.0], [248.0, 1910.0], [219.0, 1910.0]], [[182.0, 1670.0], [211.0, 1670.0], [211.0, 1834.0], [182.0, 1834.0]]], "lines": ["．．．街で", "スカウトされて", "アイドルみたいな", "事やってた。"]}], "img_path": "156.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1213, 109, 1289, 337], "vertical": true, "font_size": 32, "lines_coords": [[[1254.0, 113.0], [1289.0, 113.0], [1289.0, 240.0], [1254.0, 240.0]], [[1213.0, 109.0], [1248.0, 109.0], [1252.0, 337.0], [1217.0, 337.0]]], "lines": ["お母さん", "大反対だったし、"]}, {"box": [1020, 256, 1165, 440], "vertical": true, "font_size": 32, "lines_coords": [[[1136.0, 258.0], [1165.0, 258.0], [1165.0, 440.0], [1136.0, 440.0]], [[1095.0, 258.0], [1124.0, 258.0], [1124.0, 409.0], [1095.0, 409.0]], [[1059.0, 262.0], [1088.0, 262.0], [1088.0, 440.0], [1059.0, 440.0]], [[1020.0, 256.0], [1055.0, 256.0], [1055.0, 380.0], [1020.0, 380.0]]], "lines": ["人前でうまく", "笑えなくて", "いつも怒られ", "てた．．．"]}, {"box": [360, 146, 463, 362], "vertical": true, "font_size": 29, "lines_coords": [[[434.0, 146.0], [463.0, 146.0], [463.0, 329.0], [434.0, 329.0]], [[397.0, 146.0], [426.0, 146.0], [426.0, 362.0], [397.0, 362.0]], [[360.0, 146.0], [389.0, 146.0], [389.0, 271.0], [360.0, 271.0]]], "lines": ["もっと簡単に", "稼げると思って", "たけど．．．"]}, {"box": [178, 262, 320, 480], "vertical": true, "font_size": 29, "lines_coords": [[[285.0, 262.0], [320.0, 262.0], [320.0, 480.0], [285.0, 480.0]], [[254.0, 267.0], [277.0, 267.0], [277.0, 418.0], [254.0, 418.0]], [[215.0, 262.0], [246.0, 262.0], [242.0, 449.0], [211.0, 449.0]], [[178.0, 265.0], [207.0, 265.0], [207.0, 459.0], [178.0, 459.0]]], "lines": ["楽しくないのに", "愛想なんて", "出せないから", "辞めちゃった。"]}, {"box": [1269, 608, 1304, 745], "vertical": true, "font_size": 31, "lines_coords": [[[1269.0, 608.0], [1304.0, 608.0], [1304.0, 745.0], [1269.0, 745.0]]], "lines": ["．．．でもさ、"]}, {"box": [1113, 759, 1258, 1026], "vertical": true, "font_size": 31, "lines_coords": [[[1223.0, 759.0], [1258.0, 759.0], [1258.0, 927.0], [1223.0, 927.0]], [[1188.0, 770.0], [1217.0, 770.0], [1217.0, 954.0], [1188.0, 954.0]], [[1151.0, 770.0], [1180.0, 770.0], [1180.0, 954.0], [1151.0, 954.0]], [[1113.0, 768.0], [1140.0, 768.0], [1140.0, 1026.0], [1113.0, 1026.0]]], "lines": ["プンプンと", "再会してから", "自然に笑える", "ようになったんだ。"]}, {"box": [316, 720, 457, 933], "vertical": true, "font_size": 28, "lines_coords": [[[428.0, 720.0], [457.0, 720.0], [457.0, 933.0], [428.0, 933.0]], [[389.0, 722.0], [418.0, 722.0], [418.0, 873.0], [389.0, 873.0]], [[354.0, 722.0], [380.0, 722.0], [380.0, 933.0], [354.0, 933.0]], [[316.0, 722.0], [345.0, 722.0], [345.0, 884.0], [316.0, 884.0]]], "lines": ["それまでずっと", "普通に笑う", "ことすら出来な", "かったのに。"]}, {"box": [258, 981, 325, 1196], "vertical": true, "font_size": 28, "lines_coords": [[[296.0, 981.0], [325.0, 981.0], [325.0, 1196.0], [296.0, 1196.0]], [[258.0, 983.0], [287.0, 983.0], [287.0, 1105.0], [258.0, 1105.0]]], "lines": ["．．．どうしてだか", "わかる？"]}, {"box": [394, 1378, 540, 1594], "vertical": true, "font_size": 33, "lines_coords": [[[500.0, 1380.0], [540.0, 1380.0], [540.0, 1478.0], [500.0, 1478.0]], [[465.0, 1380.0], [500.0, 1380.0], [500.0, 1594.0], [465.0, 1594.0]], [[432.0, 1380.0], [463.0, 1380.0], [459.0, 1563.0], [428.0, 1563.0]], [[395.0, 1378.0], [422.0, 1378.0], [422.0, 1575.0], [395.0, 1575.0]]], "lines": ["今日は", "この間みたいに", "触ってきたり", "しないんだね。"]}, {"box": [1068, 1614, 1136, 1832], "vertical": true, "font_size": 32, "lines_coords": [[[1101.0, 1614.0], [1136.0, 1614.0], [1136.0, 1768.0], [1101.0, 1768.0]], [[1068.0, 1616.0], [1097.0, 1616.0], [1097.0, 1832.0], [1068.0, 1832.0]]], "lines": ["．．．あたしも", "わからないけど、"]}, {"box": [902, 1780, 1010, 1962], "vertical": true, "font_size": 32, "lines_coords": [[[981.0, 1784.0], [1010.0, 1784.0], [1010.0, 1962.0], [981.0, 1962.0]], [[944.0, 1784.0], [972.0, 1784.0], [972.0, 1962.0], [944.0, 1962.0]], [[902.0, 1780.0], [939.0, 1780.0], [939.0, 1877.0], [902.0, 1877.0]]], "lines": ["きっと理由は", "あると思うん", "だ．．．．．"]}, {"box": [173, 1821, 212, 1976], "vertical": true, "font_size": 38, "lines_coords": [[[173.0, 1823.0], [211.0, 1823.0], [211.0, 1970.0], [173.0, 1970.0]]], "lines": ["．．．偉いね。"]}], "img_path": "157.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [765, 751, 803, 904], "vertical": true, "font_size": 33, "lines_coords": [[[765.0, 751.0], [803.0, 751.0], [803.0, 904.0], [765.0, 904.0]]], "lines": ["「あの．．．．．"]}, {"box": [614, 751, 734, 1068], "vertical": true, "font_size": 33, "lines_coords": [[[699.0, 751.0], [734.0, 751.0], [734.0, 1022.0], [699.0, 1022.0]], [[660.0, 755.0], [689.0, 755.0], [689.0, 1055.0], [660.0, 1055.0]], [[614.0, 751.0], [643.0, 751.0], [643.0, 1068.0], [614.0, 1068.0]]], "lines": ["こう、すんなりと", "部屋に入れておいて", "なんなんですか．．．"]}, {"box": [1117, 1138, 1223, 1416], "vertical": true, "font_size": 33, "lines_coords": [[[1188.0, 1142.0], [1223.0, 1142.0], [1223.0, 1298.0], [1188.0, 1298.0]], [[1148.0, 1138.0], [1184.0, 1138.0], [1184.0, 1416.0], [1148.0, 1416.0]], [[1117.0, 1144.0], [1146.0, 1144.0], [1146.0, 1298.0], [1117.0, 1298.0]]], "lines": ["プンプンの", "部屋見てみたいって", "言ったのは"]}, {"box": [161, 1405, 246, 1517], "vertical": true, "font_size": 44, "lines_coords": [[[200.0, 1405.0], [246.0, 1405.0], [246.0, 1517.0], [200.0, 1517.0]], [[161.0, 1405.0], [204.0, 1405.0], [204.0, 1515.0], [161.0, 1515.0]]], "lines": ["あたし", "だよ？"]}, {"box": [790, 1730, 826, 1883], "vertical": true, "font_size": 36, "lines_coords": [[[790.0, 1730.0], [826.0, 1730.0], [826.0, 1881.0], [790.0, 1881.0]]], "lines": ["「今は．．．"]}, {"box": [478, 1728, 643, 1962], "vertical": true, "font_size": 36, "lines_coords": [[[606.0, 1728.0], [643.0, 1728.0], [643.0, 1834.0], [606.0, 1834.0]], [[567.0, 1732.0], [596.0, 1732.0], [596.0, 1960.0], [567.0, 1960.0]], [[523.0, 1732.0], [554.0, 1732.0], [556.0, 1927.0], [525.0, 1927.0]], [[478.0, 1730.0], [523.0, 1730.0], [523.0, 1836.0], [478.0, 1836.0]]], "lines": ["誰とも", "お付き合いする", "つもりはない", "ので。」"]}], "img_path": "158.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1155, 136, 1197, 293], "vertical": true, "font_size": 35, "lines_coords": [[[1155.0, 138.0], [1190.0, 136.0], [1196.0, 291.0], [1161.0, 293.0]]], "lines": ["．．．うふふ。"]}, {"box": [238, 349, 309, 538], "vertical": true, "font_size": 32, "lines_coords": [[[277.0, 354.0], [306.0, 354.0], [306.0, 536.0], [277.0, 536.0]], [[238.0, 349.0], [273.0, 349.0], [273.0, 538.0], [238.0, 538.0]]], "lines": ["まってまった", "ちょっと．．．"]}, {"box": [1233, 701, 1271, 838], "vertical": true, "font_size": 38, "lines_coords": [[[1233.0, 701.0], [1271.0, 701.0], [1271.0, 838.0], [1233.0, 838.0]]], "lines": ["別に．．．"]}, {"box": [312, 830, 420, 1030], "vertical": true, "font_size": 31, "lines_coords": [[[380.0, 830.0], [416.0, 830.0], [420.0, 989.0], [385.0, 989.0]], [[351.0, 834.0], [380.0, 834.0], [380.0, 1018.0], [351.0, 1018.0]], [[312.0, 836.0], [341.0, 836.0], [341.0, 1026.0], [312.0, 1026.0]]], "lines": ["付き合って", "なんか一言も", "言ってないよ。"]}, {"box": [1217, 1146, 1287, 1362], "vertical": true, "font_size": 32, "lines_coords": [[[1258.0, 1149.0], [1287.0, 1149.0], [1287.0, 1362.0], [1258.0, 1362.0]], [[1217.0, 1146.0], [1252.0, 1146.0], [1252.0, 1300.0], [1217.0, 1300.0]]], "lines": ["子供じゃないん", "だから．．．"]}, {"box": [1088, 1370, 1194, 1556], "vertical": true, "font_size": 32, "lines_coords": [[[1165.0, 1374.0], [1194.0, 1374.0], [1194.0, 1556.0], [1165.0, 1556.0]], [[1128.0, 1374.0], [1157.0, 1374.0], [1157.0, 1554.0], [1128.0, 1554.0]], [[1088.0, 1370.0], [1124.0, 1370.0], [1124.0, 1523.0], [1088.0, 1523.0]]], "lines": ["そう簡単には", "決められない", "よね．．．．．．"]}, {"box": [304, 1233, 407, 1507], "vertical": true, "font_size": 35, "lines_coords": [[[372.0, 1233.0], [407.0, 1233.0], [407.0, 1360.0], [372.0, 1360.0]], [[335.0, 1233.0], [370.0, 1233.0], [372.0, 1507.0], [337.0, 1507.0]], [[304.0, 1235.0], [331.0, 1235.0], [331.0, 1459.0], [304.0, 1459.0]]], "lines": ["これから", "ゆっくり話し合って", "考えればいいよ。"]}, {"box": [223, 1517, 267, 1627], "vertical": true, "font_size": 35, "lines_coords": [[[223.0, 1517.0], [267.0, 1517.0], [267.0, 1627.0], [223.0, 1627.0]]], "lines": ["．．．ね？"]}, {"box": [803, 1714, 881, 1890], "vertical": true, "font_size": 36, "lines_coords": [[[846.0, 1714.0], [881.0, 1714.0], [881.0, 1890.0], [846.0, 1890.0]], [[803.0, 1716.0], [838.0, 1716.0], [838.0, 1861.0], [803.0, 1861.0]]], "lines": ["フンフンは、", "何か一言、"]}, {"box": [612, 1712, 732, 1948], "vertical": true, "font_size": 36, "lines_coords": [[[695.0, 1714.0], [732.0, 1714.0], [732.0, 1857.0], [695.0, 1857.0]], [[654.0, 1714.0], [689.0, 1714.0], [687.0, 1948.0], [652.0, 1948.0]], [[612.0, 1712.0], [650.0, 1712.0], [650.0, 1838.0], [612.0, 1838.0]]], "lines": ["何か一言", "言いたかったの", "ですがー"]}], "img_path": "159.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1184, 140, 1214, 347], "vertical": true, "font_size": 29, "lines_coords": [[[1184.0, 140.0], [1213.0, 140.0], [1213.0, 343.0], [1184.0, 343.0]]], "lines": ["そろそろ．．．"]}, {"box": [498, 258, 575, 611], "vertical": true, "font_size": 34, "lines_coords": [[[542.0, 258.0], [573.0, 258.0], [571.0, 461.0], [540.0, 461.0]], [[498.0, 260.0], [534.0, 260.0], [534.0, 610.0], [498.0, 610.0]]], "lines": ["上手く言葉が", "見つかりませんでした。"]}, {"box": [691, 734, 780, 914], "vertical": true, "font_size": 46, "lines_coords": [[[724.0, 734.0], [780.0, 734.0], [780.0, 823.0], [724.0, 823.0]], [[691.0, 741.0], [728.0, 741.0], [730.0, 910.0], [693.0, 910.0]]], "lines": ["帰ら", "なきゃ．．．．．．"]}, {"box": [198, 637, 306, 792], "vertical": true, "font_size": 31, "lines_coords": [[[269.0, 637.0], [306.0, 637.0], [306.0, 734.0], [269.0, 734.0]], [[233.0, 641.0], [262.0, 641.0], [262.0, 790.0], [233.0, 790.0]], [[198.0, 639.0], [227.0, 639.0], [227.0, 792