, 283.0]], [[517.0, 95.0], [540.0, 95.0], [540.0, 225.0], [517.0, 225.0]]], "lines": ["このページで", "アカウント作って", "ログインすれば", "いいわけ？"]}, {"box": [1175, 890, 1256, 1041], "vertical": true, "font_size": 40, "lines_coords": [[[1213.0, 890.0], [1256.0, 890.0], [1256.0, 997.0], [1213.0, 997.0]], [[1175.0, 892.0], [1211.0, 892.0], [1211.0, 1041.0], [1175.0, 1041.0]]], "lines": ["死ねば", "いいのに。"]}, {"box": [221, 558, 256, 714], "vertical": true, "font_size": 35, "lines_coords": [[[221.0, 558.0], [256.0, 558.0], [256.0, 712.0], [221.0, 712.0]]], "lines": ["そうそう。"]}, {"box": [1078, 1045, 1119, 1157], "vertical": true, "font_size": 41, "lines_coords": [[[1078.0, 1045.0], [1119.0, 1045.0], [1119.0, 1117.0], [1078.0, 1117.0]]], "lines": ["ねー"]}], "img_path": "015.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [], "img_path": "016.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [], "img_path": "017.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1235, 126, 1275, 194], "vertical": true, "font_size": 37, "lines_coords": [[[1235.0, 126.0], [1275.0, 126.0], [1275.0, 194.0], [1235.0, 194.0]]], "lines": ["あー"]}, {"box": [1105, 285, 1182, 459], "vertical": true, "font_size": 37, "lines_coords": [[[1146.0, 285.0], [1182.0, 285.0], [1182.0, 457.0], [1146.0, 457.0]], [[1105.0, 285.0], [1140.0, 285.0], [1140.0, 459.0], [1105.0, 459.0]]], "lines": ["すみません", "なんか．．．．．"]}, {"box": [182, 931, 269, 1105], "vertical": true, "font_size": 44, "lines_coords": [[[215.0, 931.0], [269.0, 931.0], [269.0, 1039.0], [215.0, 1039.0]], [[182.0, 933.0], [217.0, 933.0], [217.0, 1103.0], [182.0, 1103.0]]], "lines": ["人違い", "てした．．．．．"]}, {"box": [287, 1379, 332, 1689], "vertical": true, "font_size": 38, "lines_coords": [[[293.0, 1411.0], [331.0, 1411.0], [325.0, 1685.0], [287.0, 1685.0]]], "lines": ["．．．．．．僕です。」"]}], "img_path": "018.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1237, 1550, 1273, 1756], "vertical": true, "font_size": 36, "lines_coords": [[[1237.0, 1550.0], [1273.0, 1550.0], [1273.0, 1751.0], [1237.0, 1751.0]]], "lines": ["私のこと．．．"]}, {"box": [210, 1759, 242, 1961], "vertical": true, "font_size": 29, "lines_coords": [[[211.0, 1759.0], [240.0, 1759.0], [240.0, 1960.0], [211.0, 1960.0]]], "lines": ["．．．憶えてる？"]}], "img_path": "019.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [871, 438, 902, 536], "vertical": true, "font_size": 33, "lines_coords": [[[871.0, 438.0], [902.0, 438.0], [902.0, 536.0], [871.0, 536.0]]], "lines": ["あのー"]}, {"box": [805, 689, 840, 861], "vertical": true, "font_size": 33, "lines_coords": [[[805.0, 689.0], [840.0, 689.0], [840.0, 861.0], [805.0, 861.0]]], "lines": ["藤川くん？"]}, {"box": [519, 1455, 596, 1692], "vertical": true, "font_size": 32, "lines_coords": [[[558.0, 1455.0], [594.0, 1455.0], [594.0, 1658.0], [558.0, 1658.0]], [[521.0, 1461.0], [550.0, 1461.0], [550.0, 1691.0], [521.0, 1691.0]]], "lines": ["．．．あ、あれ？", "知り合いの方？"]}, {"box": [235, 1134, 276, 1336], "vertical": true, "font_size": 37, "lines_coords": [[[236.0, 1134.0], [273.0, 1134.0], [273.0, 1333.0], [236.0, 1333.0]]], "lines": ["藤川くん？"]}, {"box": [741, 1525, 781, 1847], "vertical": true, "font_size": 35, "lines_coords": [[[743.0, 1527.0], [778.0, 1527.0], [778.0, 1846.0], [743.0, 1846.0]]], "lines": ["．．．．．．藤川くん！！"]}], "img_path": "020.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [658, 53, 695, 275], "vertical": true, "font_size": 35, "lines_coords": [[[660.0, 53.0], [695.0, 53.0], [693.0, 275.0], [658.0, 275.0]]], "lines": ["「．．．．．．ああ！！"]}, {"box": [403, 51, 612, 424], "vertical": true, "font_size": 34, "lines_coords": [[[577.0, 55.0], [612.0, 55.0], [612.0, 393.0], [577.0, 393.0]], [[534.0, 55.0], [569.0, 55.0], [569.0, 329.0], [534.0, 329.0]], [[490.0, 51.0], [525.0, 51.0], [527.0, 424.0], [492.0, 424.0]], [[447.0, 53.0], [482.0, 53.0], [486.0, 362.0], [451.0, 362.0]], [[407.0, 51.0], [443.0, 51.0], [438.0, 233.0], [403.0, 233.0]]], "lines": ["彼女は地元の同級生で", "今さっきばったり", "再会しちゃって、いやァ", "偶然だネーって感じ", "なんだけど、"]}, {"box": [238, 51, 358, 376], "vertical": true, "font_size": 34, "lines_coords": [[[322.0, 53.0], [358.0, 53.0], [358.0, 296.0], [322.0, 296.0]], [[281.0, 51.0], [316.0, 51.0], [312.0, 362.0], [277.0, 362.0]], [[242.0, 51.0], [271.0, 51.0], [267.0, 376.0], [238.0, 376.0]]], "lines": ["君はアレかい？", "偶然とか因果律とか", "信じるタイフかい？」"]}, {"box": [1225, 904, 1295, 1091], "vertical": true, "font_size": 30, "lines_coords": [[[1256.0, 904.0], [1295.0, 904.0], [1295.0, 985.0], [1256.0, 985.0]], [[1225.0, 908.0], [1254.0, 908.0], [1254.0, 1091.0], [1225.0, 1091.0]]], "lines": ["．．．あ、", "そうなんだ．．．"]}, {"box": [1062, 1101, 1200, 1343], "vertical": true, "font_size": 30, "lines_coords": [[[1177.0, 1103.0], [1200.0, 1103.0], [1200.0, 1254.0], [1177.0, 1254.0]], [[1136.0, 1101.0], [1171.0, 1101.0], [1167.0, 1285.0], [1132.0, 1285.0]], [[1099.0, 1105.0], [1128.0, 1105.0], [1128.0, 1285.0], [1099.0, 1285.0]], [[1062.0, 1103.0], [1090.0, 1103.0], [1090.0, 1343.0], [1062.0, 1343.0]]], "lines": ["．．．それより", "さっき電話が", "あって急用が", "できちゃって．．．"]}, {"box": [318, 1008, 459, 1298], "vertical": true, "font_size": 30, "lines_coords": [[[424.0, 1008.0], [459.0, 1008.0], [459.0, 1134.0], [424.0, 1134.0]], [[385.0, 1008.0], [420.0, 1008.0], [422.0, 1285.0], [387.0, 1285.0]], [[354.0, 1010.0], [382.0, 1010.0], [382.0, 1298.0], [354.0, 1298.0]], [[318.0, 1012.0], [341.0, 1012.0], [341.0, 1161.0], [318.0, 1161.0]]], "lines": ["母が急に", "上京してきちゃって", "駅まで迎えに来いって、", "言うから．．．"]}, {"box": [227, 1291, 331, 1500], "vertical": true, "font_size": 30, "lines_coords": [[[302.0, 1291.0], [331.0, 1291.0], [331.0, 1471.0], [302.0, 1471.0]], [[264.0, 1293.0], [293.0, 1293.0], [293.0, 1500.0], [264.0, 1500.0]], [[227.0, 1293.0], [256.0, 1293.0], [256.0, 1498.0], [227.0, 1498.0]]], "lines": ["ごめんなさい", "なんかドタバタ", "しちゃって．．．"]}, {"box": [304, 1710, 385, 1848], "vertical": true, "font_size": 40, "lines_coords": [[[349.0, 1714.0], [385.0, 1714.0], [385.0, 1848.0], [349.0, 1848.0]], [[304.0, 1710.0], [347.0, 1710.0], [347.0, 1821.0], [304.0, 1821.0]]], "lines": ["．．．じゃあ", "また！！"]}, {"box": [161, 1844, 242, 2012], "vertical": true, "font_size": 40, "lines_coords": [[[198.0, 1844.0], [242.0, 1844.0], [242.0, 1954.0], [198.0, 1954.0]], [[161.0, 1846.0], [198.0, 1846.0], [198.0, 2012.0], [161.0, 2012.0]]], "lines": ["今度は", "授業で．．．"]}], "img_path": "021.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1219, 1230, 1252, 1434], "vertical": true, "font_size": 29, "lines_coords": [[[1219.0, 1231.0], [1248.0, 1231.0], [1248.0, 1430.0], [1219.0, 1430.0]]], "lines": ["．．．もしもし？"]}, {"box": [641, 1246, 749, 1432], "vertical": true, "font_size": 34, "lines_coords": [[[712.0, 1246.0], [749.0, 1246.0], [749.0, 1327.0], [712.0, 1327.0]], [[676.0, 1246.0], [712.0, 1246.0], [712.0, 1432.0], [676.0, 1432.0]], [[641.0, 1248.0], [670.0, 1248.0], [670.0, 1407.0], [641.0, 1407.0]]], "lines": ["．．．ん", "具合はだいぶ", "良くなった。"]}, {"box": [254, 1242, 358, 1424], "vertical": true, "font_size": 31, "lines_coords": [[[322.0, 1244.0], [358.0, 1244.0], [358.0, 1368.0], [322.0, 1368.0]], [[289.0, 1246.0], [318.0, 1246.0], [318.0, 1424.0], [289.0, 1424.0]], [[254.0, 1242.0], [283.0, 1242.0], [283.0, 1353.0], [254.0, 1353.0]]], "lines": ["風邪じゃ", "ないと思うん", "だけどー"]}, {"box": [120, 1376, 225, 1558], "vertical": true, "font_size": 31, "lines_coords": [[[190.0, 1376.0], [225.0, 1376.0], [225.0, 1503.0], [190.0, 1503.0]], [[153.0, 1380.0], [182.0, 1380.0], [182.0, 1529.0], [153.0, 1529.0]], [[120.0, 1380.0], [146.0, 1380.0], [146.0, 1558.0], [120.0, 1558.0]]], "lines": ["まあ明日", "病院行って", "みますわ．．．"]}, {"box": [811, 1745, 956, 1985], "vertical": true, "font_size": 32, "lines_coords": [[[921.0, 1745.0], [956.0, 1745.0], [956.0, 1871.0], [921.0, 1871.0]], [[888.0, 1747.0], [917.0, 1747.0], [917.0, 1927.0], [888.0, 1927.0]], [[850.0, 1749.0], [879.0, 1749.0], [879.0, 1985.0], [850.0, 1985.0]], [[811.0, 1749.0], [846.0, 1749.0], [846.0, 1883.0], [811.0, 1883.0]]], "lines": ["んああ？", "なんだよ蟹江", "声だけで暑苦しい", "っつうの。"]}, {"box": [126, 1732, 267, 1985], "vertical": true, "font_size": 29, "lines_coords": [[[236.0, 1734.0], [264.0, 1734.0], [264.0, 1857.0], [236.0, 1857.0]], [[198.0, 1734.0], [227.0, 1734.0], [227.0, 1985.0], [198.0, 1985.0]], [[161.0, 1732.0], [190.0, 1732.0], [186.0, 1946.0], [157.0, 1946.0]], [[126.0, 1734.0], [155.0, 1734.0], [155.0, 1927.0], [126.0, 1927.0]]], "lines": ["．．．原稿は", "そろそろ終わるよ、", "来週編集さんに", "見てもらうし。"]}], "img_path": "022.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1186, 24, 1221, 41], "vertical": false, "font_size": 17, "lines_coords": [[[1186.0, 24.0], [1221.0, 24.0], [1221.0, 41.0], [1186.0, 41.0]]], "lines": ["Ｓｃｏｌｌｅ"]}, {"box": [1256, 93, 1298, 252], "vertical": true, "font_size": 31, "lines_coords": [[[1260.0, 93.0], [1298.0, 93.0], [1293.0, 252.0], [1256.0, 252.0]]], "lines": ["プンプン？"]}, {"box": [1109, 291, 1252, 563], "vertical": true, "font_size": 31, "lines_coords": [[[1217.0, 291.0], [1252.0, 291.0], [1252.0, 476.0], [1217.0, 476.0]], [[1180.0, 291.0], [1208.0, 291.0], [1208.0, 563.0], [1180.0, 563.0]], [[1146.0, 293.0], [1173.0, 293.0], [1173.0, 505.0], [1146.0, 505.0]], [[1109.0, 293.0], [1136.0, 293.0], [1136.0, 474.0], [1109.0, 474.0]]], "lines": ["知らねーよ", "あたしが聞きたいわ", "アイツちゃんと", "生きてんの？"]}, {"box": [850, 689, 993, 905], "vertical": true, "font_size": 30, "lines_coords": [[[958.0, 689.0], [993.0, 689.0], [993.0, 846.0], [958.0, 846.0]], [[923.0, 689.0], [954.0, 689.0], [952.0, 902.0], [921.0, 902.0]], [[886.0, 691.0], [915.0, 691.0], [915.0, 904.0], [886.0, 904.0]], [[850.0, 689.0], [877.0, 689.0], [877.0, 902.0], [850.0, 902.0]]], "lines": ["．．．ハイハイ", "心配してくれて", "ありがとねー", "じゃあ切るよ？"]}, {"box": [370, 1623, 416, 1745], "vertical": true, "font_size": 38, "lines_coords": [[[370.0, 1623.0], [416.0, 1623.0], [416.0, 1745.0], [370.0, 1745.0]]], "lines": ["．．．はい、"]}, {"box": [250, 1755, 279, 1923], "vertical": true, "font_size": 38, "lines_coords": [[[250.0, 1755.0], [279.0, 1755.0], [279.0, 1923.0], [250.0, 1923.0]]], "lines": ["もしもし？"]}], "img_path": "023.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1180, 151, 1208, 314], "vertical": true, "font_size": 28, "lines_coords": [[[1180.0, 151.0], [1208.0, 151.0], [1208.0, 314.0], [1180.0, 314.0]]], "lines": ["．．．そっかぁ、"]}, {"box": [1037, 389, 1140, 571], "vertical": true, "font_size": 28, "lines_coords": [[[1111.0, 389.0], [1140.0, 389.0], [1140.0, 540.0], [1111.0, 540.0]], [[1074.0, 389.0], [1103.0, 389.0], [1103.0, 571.0], [1074.0, 571.0]], [[1037.0, 389.0], [1064.0, 389.0], [1064.0, 571.0], [1037.0, 571.0]]], "lines": ["プンプンの", "お母さん再婚", "したんだ．．．"]}, {"box": [202, 710, 343, 921], "vertical": true, "font_size": 28, "lines_coords": [[[312.0, 710.0], [341.0, 710.0], [341.0, 894.0], [312.0, 894.0]], [[275.0, 710.0], [304.0, 710.0], [304.0, 919.0], [275.0, 919.0]], [[238.0, 710.0], [267.0, 710.0], [267.0, 921.0], [238.0, 921.0]], [[202.0, 710.0], [229.0, 710.0], [229.0, 890.0], [202.0, 890.0]]], "lines": ["．．．なんにせよ", "私にはプン山の", "ほうがしっくり", "くるけど．．．"]}, {"box": [1262, 1167, 1300, 1296], "vertical": true, "font_size": 36, "lines_coords": [[[1262.0, 1167.0], [1300.0, 1167.0], [1300.0, 1296.0], [1262.0, 1296.0]]], "lines": ["．．．でもさ"]}, {"box": [1142, 1356, 1252, 1482], "vertical": true, "font_size": 36, "lines_coords": [[[1215.0, 1356.0], [1252.0, 1356.0], [1252.0, 1453.0], [1215.0, 1453.0]], [[1177.0, 1356.0], [1213.0, 1356.0], [1213.0, 1482.0], [1177.0, 1482.0]], [[1142.0, 1356.0], [1177.0, 1356.0], [1177.0, 1465.0], [1142.0, 1465.0]]], "lines": ["なんか", "変な感じ", "だよね。"]}, {"box": [834, 1231, 950, 1333], "vertical": false, "font_size": 29.0, "lines_coords": [[[846.0, 1231.0], [915.0, 1231.0], [915.0, 1260.0], [846.0, 1260.0]], [[836.0, 1298.0], [950.0, 1304.0], [948.0, 1333.0], [834.0, 1327.0]]], "lines": ["きれいな", "写真を撮影されるか"]}, {"box": [598, 1182, 668, 1409], "vertical": true, "font_size": 32, "lines_coords": [[[633.0, 1182.0], [668.0, 1182.0], [668.0, 1308.0], [633.0, 1308.0]], [[598.0, 1182.0], [627.0, 1182.0], [627.0, 1403.0], [598.0, 1403.0]]], "lines": ["．．．なんか", "安心しちゃった。"]}, {"box": [138, 1391, 242, 1618], "vertical": true, "font_size": 30, "lines_coords": [[[207.0, 1391.0], [242.0, 1391.0], [242.0, 1548.0], [207.0, 1548.0]], [[173.0, 1393.0], [202.0, 1393.0], [202.0, 1604.0], [173.0, 1604.0]], [[138.0, 1393.0], [165.0, 1393.0], [165.0, 1616.0], [138.0, 1616.0]]], "lines": ["良かったよ", "プンプンあまり", "変わってなくて。"]}, {"box": [786, 1493, 891, 1713], "vertical": true, "font_size": 105, "lines_coords": [[[786.0, 1493.0], [891.0, 1493.0], [891.0, 1713.0], [786.0, 1713.0]]], "lines": ["教習所とはいえまた同じ学校に通ってるなんて、"]}, {"box": [784, 1492, 888, 1710], "vertical": true, "font_size": 29, "lines_coords": [[[859.0, 1492.0], [888.0, 1492.0], [888.0, 1705.0], [859.0, 1705.0]], [[821.0, 1492.0], [850.0, 1492.0], [850.0, 1703.0], [821.0, 1703.0]], [[784.0, 1492.0], [813.0, 1492.0], [813.0, 1710.0], [784.0, 1710.0]]], "lines": ["教習所とはいえ", "また同じ学校に", "通ってるなんて、"]}, {"box": [718, 1780, 861, 1993], "vertical": true, "font_size": 29, "lines_coords": [[[832.0, 1784.0], [861.0, 1784.0], [861.0, 1993.0], [832.0, 1993.0]], [[794.0, 1784.0], [821.0, 1784.0], [821.0, 1964.0], [794.0, 1964.0]], [[757.0, 1782.0], [786.0, 1782.0], [786.0, 1933.0], [757.0, 1933.0]], [[718.0, 1780.0], [747.0, 1780.0], [751.0, 1964.0], [722.0, 1964.0]]], "lines": ["あと少しで教習", "終わりだから", "私のが全然", "先輩だけど．．．"]}], "img_path": "024.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1273, 47, 1308, 173], "vertical": true, "font_size": 30, "lines_coords": [[[1273.0, 47.0], [1308.0, 47.0], [1308.0, 173.0], [1273.0, 173.0]]], "lines": ["えっと．．．"]}, {"box": [1171, 194, 1273, 409], "vertical": true, "font_size": 30, "lines_coords": [[[1244.0, 194.0], [1273.0, 194.0], 