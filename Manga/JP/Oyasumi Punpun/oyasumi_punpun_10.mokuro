, 322.0], [778.0, 519.0], [751.0, 519.0]]], "lines": ["．．．はァー", "知るかよ", "アンタの女んちの", "合い鏡なんて。"]}, {"box": [248, 341, 391, 556], "vertical": true, "font_size": 30, "lines_coords": [[[356.0, 343.0], [391.0, 343.0], [391.0, 511.0], [356.0, 511.0]], [[320.0, 343.0], [349.0, 343.0], [349.0, 556.0], [320.0, 556.0]], [[277.0, 341.0], [312.0, 341.0], [316.0, 496.0], [281.0, 496.0]], [[248.0, 343.0], [275.0, 343.0], [275.0, 509.0], [248.0, 509.0]]], "lines": ["いや、アタシ", "来週から旅行で", "蟹江と沖縄", "行くんだわ。"]}, {"box": [1045, 662, 1124, 832], "vertical": true, "font_size": 38, "lines_coords": [[[1078.0, 662.0], [1124.0, 662.0], [1124.0, 770.0], [1078.0, 770.0]], [[1045.0, 664.0], [1074.0, 664.0], [1074.0, 830.0], [1045.0, 830.0]]], "lines": ["．．．はい", "もしもし？"]}, {"box": [146, 577, 285, 821], "vertical": true, "font_size": 30, "lines_coords": [[[258.0, 579.0], [285.0, 579.0], [285.0, 821.0], [258.0, 821.0]], [[223.0, 579.0], [252.0, 579.0], [252.0, 792.0], [223.0, 792.0]], [[184.0, 579.0], [213.0, 579.0], [213.0, 792.0], [184.0, 792.0]], [[146.0, 577.0], [175.0, 577.0], [178.0, 792.0], [149.0, 792.0]]], "lines": ["．．．じゃあウチの鏡", "ドアのあたりに", "隠しておくから", "勝手に入って！！"]}, {"box": [1199, 997, 1306, 1186], "vertical": true, "font_size": 31, "lines_coords": [[[1275.0, 1086.0], [1298.0, 1086.0], [1298.0, 1182.0], [1275.0, 1182.0]], [[1266.0, 999.0], [1306.0, 999.0], [1306.0, 1072.0], [1266.0, 1072.0]], [[1231.0, 997.0], [1266.0, 997.0], [1262.0, 1186.0], [1227.0, 1186.0]], [[1200.0, 1006.0], [1225.0, 1006.0], [1225.0, 1165.0], [1200.0, 1165.0]]], "lines": ["．．．？", "んー", "大丈夫ただの", "風邪だから。"]}, {"box": [325, 1223, 399, 1362], "vertical": true, "font_size": 34, "lines_coords": [[[362.0, 1225.0], [399.0, 1225.0], [399.0, 1322.0], [362.0, 1322.0]], [[325.0, 1223.0], [360.0, 1223.0], [360.0, 1362.0], [325.0, 1362.0]]], "lines": ["．．．．．．", "はいはい。"]}, {"box": [254, 1414, 283, 1565], "vertical": true, "font_size": 34, "lines_coords": [[[254.0, 1414.0], [283.0, 1414.0], [283.0, 1565.0], [254.0, 1565.0]]], "lines": ["じゃあね。"]}], "img_path": "031.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [122, 28, 180, 122], "vertical": true, "font_size": 31.0, "lines_coords": [[[149.0, 28.0], [180.0, 28.0], [180.0, 118.0], [149.0, 118.0]], [[122.0, 33.0], [153.0, 33.0], [153.0, 122.0], [122.0, 122.0]]], "lines": ["発弟応シ", "ひとつの"]}], "img_path": "032.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [], "img_path": "033.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1169, 146, 1200, 246], "vertical": true, "font_size": 33, "lines_coords": [[[1169.0, 146.0], [1200.0, 146.0], [1200.0, 246.0], [1169.0, 246.0]]], "lines": ["．．．ほら、"]}, {"box": [1051, 244, 1122, 463], "vertical": true, "font_size": 33, "lines_coords": [[[1084.0, 244.0], [1122.0, 244.0], [1122.0, 374.0], [1084.0, 374.0]], [[1051.0, 248.0], [1080.0, 248.0], [1080.0, 463.0], [1051.0, 463.0]]], "lines": ["私、背が", "小さいじゃん？"]}, {"box": [221, 1273, 364, 1517], "vertical": true, "font_size": 34, "lines_coords": [[[329.0, 1275.0], [364.0, 1275.0], [364.0, 1517.0], [329.0, 1517.0]], [[291.0, 1273.0], [327.0, 1273.0], [322.0, 1459.0], [287.0, 1459.0]], [[252.0, 1275.0], [289.0, 1275.0], [289.0, 1399.0], [252.0, 1399.0]], [[221.0, 1275.0], [250.0, 1275.0], [250.0, 1461.0], [221.0, 1461.0]]], "lines": ["．．．だからショーの", "モデルとかは", "全然無理", "なんだけどさ、"]}, {"box": [1126, 1724, 1266, 1964], "vertical": true, "font_size": 31, "lines_coords": [[[1237.0, 1726.0], [1266.0, 1726.0], [1266.0, 1894.0], [1237.0, 1894.0]], [[1200.0, 1726.0], [1229.0, 1726.0], [1229.0, 1964.0], [1200.0, 1964.0]], [[1163.0, 1724.0], [1192.0, 1724.0], [1192.0, 1962.0], [1163.0, 1962.0]], [[1126.0, 1726.0], [1155.0, 1726.0], [1155.0, 1944.0], [1126.0, 1944.0]]], "lines": ["今通ってる", "服飾の専門学校の", "友達が読者モデル", "やってたりして、"]}, {"box": [937, 1772, 1043, 2016], "vertical": true, "font_size": 31, "lines_coords": [[[1008.0, 1772.0], [1043.0, 1772.0], [1043.0, 1958.0], [1008.0, 1958.0]], [[972.0, 1772.0], [1008.0, 1772.0], [1008.0, 2016.0], [972.0, 2016.0]], [[937.0, 1774.0], [966.0, 1774.0], [966.0, 1933.0], [937.0, 1933.0]]], "lines": ["私も誘われて", "ファッション誌に", "出てるんだ。"]}, {"box": [364, 1716, 498, 2016], "vertical": true, "font_size": 31, "lines_coords": [[[469.0, 1718.0], [498.0, 1718.0], [498.0, 1888.0], [469.0, 1888.0]], [[434.0, 1716.0], [461.0, 1716.0], [461.0, 1970.0], [434.0, 1970.0]], [[397.0, 1716.0], [426.0, 1716.0], [426.0, 1973.0], [397.0, 1973.0]], [[364.0, 1716.0], [393.0, 1716.0], [393.0, 2016.0], [364.0, 2016.0]]], "lines": ["読モの子達を", "管理してる事務所の", "社長さんが私のこと", "気に入ってるらしくて、"]}, {"box": [132, 1801, 279, 2014], "vertical": true, "font_size": 31, "lines_coords": [[[240.0, 1801.0], [279.0, 1801.0], [279.0, 1900.0], [240.0, 1900.0]], [[207.0, 1803.0], [236.0, 1803.0], [236.0, 2014.0], [207.0, 2014.0]], [[169.0, 1803.0], [198.0, 1803.0], [198.0, 2012.0], [169.0, 2012.0]], [[132.0, 1801.0], [167.0, 1801.0], [167.0, 1937.0], [132.0, 1937.0]]], "lines": ["なんか", "他の仕事とかも", "させてみたいん", "だってさ。"]}], "img_path": "034.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1086, 170, 1284, 625], "vertical": true, "font_size": 31, "lines_coords": [[[1242.0, 178.0], [1281.0, 178.0], [1281.0, 262.0], [1242.0, 262.0]], [[1229.0, 341.0], [1258.0, 341.0], [1258.0, 517.0], [1229.0, 517.0]], [[1194.0, 343.0], [1223.0, 343.0], [1223.0, 542.0], [1194.0, 542.0]], [[1161.0, 341.0], [1190.0, 341.0], [1184.0, 625.0], [1155.0, 625.0]], [[1124.0, 343.0], [1153.0, 343.0], [1153.0, 602.0], [1124.0, 602.0]], [[1086.0, 339.0], [1115.0, 339.0], [1115.0, 492.0], [1086.0, 492.0]]], "lines": ["うん。", "最近はそれで", "タレント養成の", "レッスンとかボイトレ", "受けさせてもらって", "るんだけど、"]}, {"box": [370, 455, 409, 610], "vertical": true, "font_size": 32, "lines_coords": [[[370.0, 455.0], [407.0, 455.0], [409.0, 610.0], [372.0, 610.0]]], "lines": ["．．．でもねぇ"]}, {"box": [225, 643, 366, 904], "vertical": true, "font_size": 32, "lines_coords": [[[337.0, 648.0], [366.0, 648.0], [366.0, 859.0], [337.0, 859.0]], [[300.0, 643.0], [331.0, 643.0], [327.0, 801.0], [296.0, 801.0]], [[260.0, 643.0], [296.0, 643.0], [291.0, 873.0], [256.0, 873.0]], [[225.0, 645.0], [254.0, 645.0], [256.0, 904.0], [227.0, 904.0]]], "lines": ["なかなか軌道に", "乗せるのは", "難しいというか、", "才能も運も必要で。"]}, {"box": [1182, 975, 1333, 1254], "vertical": true, "font_size": 34, "lines_coords": [[[1298.0, 981.0], [1333.0, 981.0], [1333.0, 1196.0], [1298.0, 1196.0]], [[1262.0, 981.0], [1291.0, 981.0], [1291.0, 1190.0], [1262.0, 1190.0]], [[1225.0, 981.0], [1254.0, 981.0], [1254.0, 1254.0], [1225.0, 1254.0]], [[1182.0, 975.0], [1225.0, 975.0], [1225.0, 1037.0], [1182.0, 1037.0]]], "lines": ["：私、ホントは", "テキスタイルの", "仕事がしたかったん", "だー"]}, {"box": [1043, 1105, 1155, 1291], "vertical": true, "font_size": 34, "lines_coords": [[[1109.0, 1105.0], [1155.0, 1105.0], [1155.0, 1188.0], [1109.0, 1188.0]], [[1080.0, 1111.0], [1109.0, 1111.0], [1109.0, 1291.0], [1080.0, 1291.0]], [[1043.0, 1111.0], [1072.0, 1111.0], [1072.0, 1275.0], [1043.0, 1275.0]]], "lines": ["．．．あ、", "簡単に言うと", "服作る人ね。"]}, {"box": [875, 1461, 906, 1686], "vertical": true, "font_size": 27, "lines_coords": [[[875.0, 1461.0], [902.0, 1461.0], [902.0, 1679.0], [875.0, 1679.0]]], "lines": ["こう思いました。"]}, {"box": [223, 1109, 366, 1382], "vertical": true, "font_size": 29, "lines_coords": [[[335.0, 1109.0], [364.0, 1109.0], [364.0, 1322.0], [335.0, 1322.0]], [[298.0, 1111.0], [327.0, 1111.0], [327.0, 1382.0], [298.0, 1382.0]], [[260.0, 1111.0], [289.0, 1111.0], [289.0, 1322.0], [260.0, 1322.0]], [[223.0, 1111.0], [252.0, 1111.0], [252.0, 1291.0], [223.0, 1291.0]]], "lines": ["まぁ今の仕事で", "人脈築いておくのも", "無駄じゃないと", "思うけど．．．．．"]}, {"box": [1047, 1461, 1118, 1736], "vertical": true, "font_size": 29, "lines_coords": [[[1086.0, 1465.0], [1115.0, 1465.0], [1115.0, 1732.0], [1086.0, 1732.0]], [[1049.0, 1463.0], [1078.0, 1463.0], [1076.0, 1643.0], [1047.0, 1643.0]]], "lines": ["小野寺フンフンこと", "藤川たかしは"]}, {"box": [443, 1540, 472, 1776], "vertical": true, "font_size": 29, "lines_coords": [[[443.0, 1540.0], [472.0, 1540.0], [472.0, 1776.0], [443.0, 1776.0]]], "lines": ["．．．愛子ちゃんが"]}, {"box": [442, 1546, 478, 1780], "vertical": true, "font_size": 36, "lines_coords": [[[442.0, 1546.0], [478.0, 1546.0], [478.0, 1780.0], [442.0, 1780.0]]], "lines": ["：愛子ちゃんが、"]}, {"box": [297, 1532, 336, 1876], "vertical": true, "font_size": 39, "lines_coords": [[[297.0, 1532.0], [336.0, 1532.0], [336.0, 1876.0], [297.0, 1876.0]]], "lines": ["目の前で喋っとる．．．"]}, {"box": [300, 1542, 329, 1871], "vertical": true, "font_size": 29, "lines_coords": [[[300.0, 1542.0], [329.0, 1542.0], [329.0, 1871.0], [300.0, 1871.0]]], "lines": ["目の前で喋っとる．．．"]}], "img_path": "035.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1105, 165, 1234, 561], "vertical": true, "font_size": 36, "lines_coords": [[[1155.0, 358.0], [1184.0, 358.0], [1184.0, 558.0], [1155.0, 558.0]], [[1105.0, 351.0], [1148.0, 351.0], [1148.0, 463.0], [1105.0, 463.0]]], "lines": ["私が載ってる", "雑誌？"]}, {"box": [173, 614, 252, 888], "vertical": true, "font_size": 36, "lines_coords": [[[213.0, 614.0], [248.0, 614.0], [252.0, 788.0], [217.0, 788.0]], [[173.0, 614.0], [209.0, 614.0], [209.0, 888.0], [173.0, 888.0]]], "lines": ["むりむり！！", "恥ずかしいから！！"]}, {"box": [1113, 1033, 1225, 1279], "vertical": true, "font_size": 37, "lines_coords": [[[1180.0, 1033.0], [1225.0, 1033.0], [1225.0, 1134.0], [1180.0, 1134.0]], [[1148.0, 1037.0], [1184.0, 1037.0], [1184.0, 1279.0], [1148.0, 1279.0]], [[1113.0, 1037.0], [1142.0, 1037.0], [1142.0, 1223.0], [1113.0, 1223.0]]], "lines": ["．．．でも", "コンビニで普通に", "売ってるから、"]}, {"box": [523, 1432, 556, 1569], "vertical": true, "font_size": 28, "lines_coords": [[[527.0, 1517.0], [552.0, 1517.0], [552.0, 1565.0], [527.0, 1565.0]], [[523.0, 1434.0], [554.0, 1434.0], [554.0, 1492.0], [523.0, 1492.0]]], "lines": ["！？", "えー"]}, {"box": [144, 1095, 254, 1310], "vertical": true, "font_size": 30, "lines_coords": [[[215.0, 1095.0], [250.0, 1095.0], [254.0, 1250.0], [219.0, 1250.0]], [[186.0, 1097.0], [215.0, 1097.0], [215.0, 1310.0], [186.0, 1310.0]], [[144.0, 1095.0], [182.0, 1095.0], [182.0, 1192.0], [144.0, 1192.0]]], "lines": ["探せばすぐ", "見つかっちゃう", "かぁー"]}, {"box": [153, 1219, 173, 1277], "vertical": true, "font_size": 30, "lines_coords": [[[153.0, 1219.0], [173.0, 1219.0], [173.0, 1277.0], [153.0, 1277.0]]], "lines": ["．．．"]}, {"box": [1208, 1732, 1237, 1929], "vertical": true, "font_size": 31, "lines_coords": [[[1208.0, 1732.0], [1237.0, 1732.0], [1237.0, 1929.0], [1208.0, 1929.0]]], "lines": ["「．．．そっかァ！！"]}, {"box": [1099, 1747, 1169, 2020], "vertical": true, "font_size": 31, "lines_coords": [[[1140.0, 1749.0], [1169.0, 1749.0], [1169.0, 1927.0], [1140.0, 1927.0]], [[1099.0, 1747.0], [1134.0, 1747.0], [1134.0, 2020.0], [1099.0, 2020.0]]], "lines": ["今度こっそり", "探しちゃおうかな："]}, {"box": [972, 1745, 1041, 1989], "vertical": true, "font_size": 30, "lines_coords": [[[1012.0, 1747.0], [1041.0, 1747.0], [1041.0, 1869.0], [1012.0, 1869.0]], [[972.0, 1745.0], [1001.0, 1745.0], [1006.0, 1989.0], [977.0, 1989.0]]], "lines": ["いやいや", "照れることないさ"]}, {"box": [830, 1747, 933, 2014], "vertical": true, "font_size": 30, "lines_coords": [[[904.0, 1749.0], [933.0, 1749.0], [933.0, 1987.0], [904.0, 1987.0]], [[863.0, 1747.0], [898.0, 1747.0], [898.0, 1900.0], [863.0, 1900.0]], [[830.0, 1749.0], [859.0, 1749.0], [859.0, 2014.0], [830.0, 2014.0]]], "lines": ["なんだか洒落てて", "楽しそうで", "うらやましいよ．．．"]}, {"box": [647, 1747, 754, 2078], "vertical": true, "font_size": 29, "lines_coords": [[[718.0, 1747.0], [749.0, 1747.0], [751.0, 2020.0], [720.0, 2020.0]], [[681.0, 1749.0], [710.0, 1749.0], [714.0, 2078.0], [685.0, 2078.0]], [[647.0, 1749.0], [674.0, 1749.0], [674.0, 1977.0], [647.0, 1977.0]]], "lines": ["まァ愛予ちゃんなら", "なんでも上手くいくって", "思ってたけど！！」"]}, {"box": [138, 1778, 209, 1988], "vertical": true, "font_size": 32, "lines_coords": [[[171.0, 1778.0], [207.0, 1778.0], [207.0, 1931.0], [171.0, 1931.0]], [[138.0, 1782.0], [167.0, 1782.0], [167.0, 1987.0], [138.0, 1987.0]]], "lines": ["プンプンは", "楽しくないの？"]}], "img_path": "036.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [660, 72, 779, 397], "vertical": true, "font_size": 33, "lines_coords": [[[747.0, 72.0], [776.0, 72.0], [776.0, 291.0], [747.0, 291.0]], [[701.0, 86.0], [739.0, 86.0], [734.0, 289.0], [697.0, 289.0]]], "lines": ["「．．．まあ俺って", "ホント普通の"]}, {"box": [658, 86, 691, 389], "vertical": true, "font_size": 33, "lines_coords": [[[660.0, 86.0], [691.0, 86.0], [689.0, 389.0], [658.0, 389.0]]], "lines": ["大学生だからねーー"]}, {"box": [436, 86, 600, 397], "vertical": true, "font_size": 33, "lines_coords": [[[565.0, 93.0], [600.0, 93.0], [596.0, 289.0], [561.0, 289.0]], [[523.0, 89.0], [558.0, 89.0], [558.0, 391.0], [523.0, 391.0]], [[484.0, 91.0], [513.0, 91.0], [513.0, 325.0], [484.0, 325.0]], [[438.0, 86.0], [474.0, 86.0], [472.0, 397.0], [436.0, 397.0]]], "lines": ["一応実務的な", "勉強がいいと思って", "教育学部入って", "教員試験受けるけど"]}, {"box": [349, 86, 385, 391], "vertical": true, "font_size": 33, "lines_coords": [[[349.0, 86.0], [385.0, 86.0], [385.0, 391.0], [349.0, 391.0]]], "lines": ["実際はセミの奴らと"]}, {"box": [226, 84, 390, 388], "vertical": true, "font_size": 29, "lines_coords": [[[310.0, 89.0], [339.0, 89.0], [339.0, 385.0], [310.0, 385.0]], [[269.0, 89.0], [298.0, 89.0], [298.0, 322.0], [269.0, 322.0]]], "lines": ["フットサル行ったり", "徹夜で飲んだり"]}, {"box": [223, 84, 256, 372], "vertical": true, "font_size": 33, "lines_coords": [[[227.0, 84.0], [256.0, 84.0], [252.0, 372.0], [223.0, 372.0]]], "lines": ["そんなんはっか！！」"]}, {"box": [718, 570, 865, 865], "vertical": true, "font_size": 37, "lines_coords": [[[749.0, 674.0], [794.0, 674.0], [794.0, 782.0], [749.0, 782.0]], [[720.0, 683.0], [749.0, 683.0], [749.0, 863.0], [720.0, 863.0]]], "lines": ["なんで", "いいじゃん？"]}, {"box": [225, 693, 293, 876], "vertical": true, "font_size": 29, "lines_coords": [[[262.0, 693.0], [291.0, 693.0], [291.0, 875.0], [262.0, 875.0]], [[225.0, 695.0], [254.0, 695.0], [254.0, 823.0], [225.0, 823.0]]], "lines": ["それはそれで", "楽しそう"]}, {"box": [1248, 1006, 1285, 1178], "vertical": true, "font_size": 36, "lines_coords": [[[1248.0, 1006.0], [1285.0, 1006.0], [1285.0, 1178.0], [1248.0, 1178.0]]], "lines": ["．．．ところで、"]}, {"box": [1074, 1202, 1194, 1403], "vertical": true, "font_size": 36, "lines_coords": [[[1157.0, 1202.0], [1194.0, 1202.0], [1194.0, 1337.0], [1157.0, 1337.0]], [[1115.0, 1202.0], [1151.0, 1202.0], [1151.0, 1403.0], [1115.0, 1403.0]], [[1074.0, 1202.0], [1109.0, 1202.0], [1109.0, 1339.0], [1074.0, 1339.0]]], "lines": ["この間の", "教習所にいた", "女の子．．．"]}, {"box": [244, 1362, 368, 1568], "vertical": true, "font_size": 38, "lines_coords": [[[333.0, 1366.0], [368.0, 1366.0], [368.0, 1536.0], [333.0, 1536.0]], [[287.0, 1364.0], [322.0, 1364.0], [322.0, 1563.0], [287.0, 1563.0]], [[244.0, 1362.0], [287.0, 1362.0], [287.0, 1474.0], [244.0, 1474.0]]], "lines": ["もしかして", "彼女だったり", "する？"]}, {"box": [890, 1759, 926, 1980], "vertical": true, "font_size": 35, "lines_coords": [[[890.0, 1759.0], [925.0, 1759.0], [925.0, 1979.0], [890.0, 1979.0]]], "lines": ["「．．．いやいや！！"]}, {"box": [643, 1771, 913, 2062], "vertical": true, "font_size": 32, "lines_coords": [[[770.0, 1776.0], [805.0, 1776.0], [801.0, 1979.0], [765.0, 1979.0]], [[730.0, 1780.0], [759.0, 1780.0], [759.0, 2043.0], [730.0, 2043.0]], [[685.0, 1778.0], [720.0, 1778.0], [720.0, 2014.0], [685.0, 2014.0]], [[643.0, 1778.0], [672.0, 1778.0], [672.0, 2057.0], [643.0, 2057.0]]], "lines": ["違うょ違うよ", "あの子はちょっと", "話しかけてみた", "だけっていうか！！」"]}], "img_path": "037.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1173, 89, 1202, 223], "vertical": true, "font_size": 35, "lines_coords": [[[1173.0, 89.0], [1202.0, 89.0], [1202.0, 223.0], [1173.0, 223.0]]], "lines": ["えーー？"]}, {"box": [1055, 281, 1134, 422], "vertical": true, "font_size": 35, "lines_coords": [[[1097.0, 281.0], [1134.0, 281.0], [1134.0, 422.0], [1097.0, 422.0]], [[1055.0, 281.0], [1093.0, 281.0], [1093.0, 420.0], [1055.0, 420.0]]], "lines": ["それって", "ナンパ？"]}, {"box": [175, 215, 300, 424], "vertical": true, "font_size": 41, "lines_coords": [[[256.0, 217.0], [300.0, 217.0], [300.0, 358.0], [256.0, 358.0]], [[213.0, 215.0], [256.0, 215.0], [256.0, 329.0], [213.0, 329.0]], [[175.0, 219.0], [211.0, 219.0], [211.0, 424.0], [175.0, 424.0]]], "lines": ["プンプン", "意外と", "かるーい！！"]}, {"box": [1140, 660, 1186, 772], "vertical": true, "font_size": 38, "lines_coords": [[[1140.0, 660.0], [1186.0, 660.0], [1186.0, 772.0], [1140.0, 772.0]]], "lines": ["．．．でも"]}, {"box": [1022, 855, 1103, 1097], "vertical": true, "font_size": 38, "lines_coords": [[[1066.0, 855.0], [1103.0, 855.0], [1099.0, 1097.0], [1062.0, 1097.0]], [[1026.0, 857.0], [1057.0, 857.0], [1053.0, 1026.0], [1022.0, 1026.0]]], "lines": ["「あの子は」って", "ことは．．．"]}, {"box": [520, 1482, 598, 1652], "vertical": true, "font_size": 44, "lines_coords": [[[554.0, 1482.0], [598.0, 1482.0], [598.0, 1621.0], [554.0, 1621.0]]], "lines": ["やっぱり"]}, {"box": [204, 1080, 285, 1250], "vertical": true, "font_size": 36, "lines_coords": [[[248.0, 1080.0], [285.0, 1080.0], [285.0, 1184.0], [248.0, 1184.0]], [[209.0, 1080.0], [244.0, 1080.0], [240.0, 1250.0], [204.0, 1250.0]]], "lines": ["彼女は", "いるんだ？"]}, {"box": [714, 1576, 752, 1798], "vertical": true, "font_size": 29, "lines_coords": [[[714.0, 1598.0], [743.0, 1598.0], [743.0, 1794.0], [714.0, 1794.0]]], "lines": ["．．．．．．．だね。"]}, {"box": [132, 1803, 209, 1973], "vertical": true, "font_size": 33, "lines_coords": [[[171.0, 1803.0], [209.0, 1803.0], [204.0, 1944.0], [167.0, 1944.0]], [[132.0, 1807.0], [161.0, 1807.0], [161.0, 1973.0], [132.0, 1973.0]]], "lines": ["どんな人", "どんな人？"]}], "img_path": "038.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [757, 109, 861, 390], "vertical": true, "font_size": 40, "lines_coords": [[[815.0, 109.0], [861.0, 109.0], [861.0, 209.0], [815.0, 209.0]], [[757.0, 130.0], [792.0, 130.0], [792.0, 383.0], [757.0, 383.0]]], "lines": ["「あー", "バイトの後輩？！"]}, {"box": [567, 62, 645, 250], "vertical": true, "font_size": 40, "lines_coords": [[[600.0, 62.0], [645.0, 62.0], [645.0, 165.0], [600.0, 165.0]], [[567.0, 64.0], [602.0, 64.0], [602.0, 250.0], [567.0, 250.0]]], "lines": ["うっそ", "年下なんだ？"]}, {"box": [190, 293, 262, 451], "vertical": true, "font_size": 36, "lines_coords": [[[225.0, 296.0], [262.0, 296.0], [262.0, 422.0], [225.0, 422.0]], [[190.0, 293.0], [225.0, 293.0], [225.0, 451.0], [190.0, 451.0]]], "lines": ["どっちが", "告ったの？"]}, {"box": [641, 523, 823, 717], "vertical": true, "font_size": 31, "lines_coords": [[[786.0, 523.0], [823.0, 523.0], [823.0, 616.0], [786.0, 616.0]], [[753.0, 525.0], [784.0, 525.0], [780.0, 676.0], [749.0, 676.0]], [[716.0, 527.0], [745.0, 527.0], [745.0, 714.0], [716.0, 714.0]], [[679.0, 527.0], [708.0, 527.0], [708.0, 648.0], [679.0, 648.0]], [[641.0, 527.0], [670.0, 527.0], [670.0, 705.0], [641.0, 705.0]]], "lines": ["「いやー", "何って事は", "ないんだけど。", "要するに", "タイミング？"]}, {"box": [285, 512, 542, 850], "vertical": true, "font_size": 31, "lines_coords": [[[511.0, 515.0], [540.0, 515.0], [536.0, 790.0], [507.0, 790.0]], [[474.0, 519.0], [503.0, 519.0], [503.0, 850.0], [474.0, 850.0]], [[436.0, 517.0], [465.0, 517.0], [465.0, 759.0], [436.0, 759.0]], [[397.0, 513.0], [432.0, 513.0], [430.0, 763.0], [395.0, 763.0]], [[362.0, 515.0], [393.0, 515.0], [391.0, 766.0], [360.0, 766.0]], [[322.0, 513.0], [358.0, 513.0], [358.0, 639.0], [322.0, 639.0]], [[287.0, 513.0], [318.0, 513.0], [316.0, 768.0], [285.0, 768.0]]], "lines": ["でもまー今のバイト", "レンタルショップだから", "音楽とか映画とか", "共通の趣味の話で", "盛り上がってたし、", "価値観が", "近いっていうか笑"]}, {"box": [949, 1673, 1068, 2030], "vertical": true, "font_size": 32, "lines_coords": [[[1030.0, 1679.0], [1066.0, 1679.0], [1066.0, 2028.0], [1030.0, 2028.0]], [[991.0, 1683.0], [1022.0, 1683.0], [1020.0, 1879.0], [989.0, 1879.0]], [[950.0, 1679.0], [979.0, 1679.0], [979.0, 1954.0], [950.0, 1954.0]]], "lines": ["「といっても付き合って", "一年半だから", "倦怠期っていうか、"]}, {"box": [703, 1676, 867, 2012], "vertical": true, "font_size": 35, "lines_coords": [[[830.0, 1676.0], [865.0, 1676.0], [863.0, 1979.0], [828.0, 1979.0]], [[788.0, 1676.0], [823.0, 1676.0], [821.0, 2012.0], [786.0, 2012.0]], [[745.0, 1679.0], [780.0, 1679.0], [780.0, 1948.0], [745.0, 1948.0]], [[703.0, 1681.0], [739.0, 1681.0], [739.0, 1948.0], [703.0, 1948.0]]], "lines": ["彼女、なんというか", "慢性的に軽い鬱だから", "気遣いもひと苦労", "なんだよねー．．．"]}, {"box": [420, 1677, 622, 1981], "vertical": true, "font_size": 34, "lines_coords": [[[585.0, 1679.0], [621.0, 1679.0], [621.0, 1977.0], [585.0, 1977.0]], [[544.0, 1679.0], [579.0, 1679.0], [579.0, 1919.0], [544.0, 1919.0]], [[503.0, 1679.0], [538.0, 1679.0], [538.0, 1881.0], [503.0, 1881.0]], [[461.0, 1679.0], [496.0, 1679.0], [496.0, 1981.0], [461.0, 1981.0]], [[422.0, 1681.0], [451.0, 1681.0], [451.0, 1960.0], [422.0, 1960.0]]], "lines": ["ま、俺も世話焼くの", "嫌いじゃないし、", "性欲弱いから", "セックスレスが逆に", "助かってるけど爆"]}], "img_path": "039.png"}, {"version": "0.2.0-beta.6", "img_width": 1445, "img_height": 2120, "blocks": [{"box": [1177, 370, 1208, 461], "vertical": true, "font_size": 29, "lines_coords": [[[1177.0, 370.0], [1208.0, 370.0], [1208.0, 461.0], [1177.0, 461.0]]], "lines": ["こらー"]}, {"box": [1140, 365, 1207, 511], "vertical": true, "font_size": 67, "lines_coords": [[[1140.0, 365.0], [1207.0, 365.0], [1207.0, 511.0], [1140.0, 511.0]]], "lines": ["こらー！！"]}, {"box": [1037, 438, 1165, 805], "vertical": true, "font_size": 29, "lines_coords": [[[1136.0, 438.0], [1165.0, 438.0], [1165.0, 505.0], [1136.0, 505.0]], [[1111.0, 594.0], [1140.0, 594.0], [1140.0, 774.0], [1111.0, 774.0]], [[1074.0, 594.0], [1103.0, 594.0], [1103.0, 745.0], [1074.0, 745.0]], [[1037.0, 594.0], [1066.0, 594.0], [1066.0, 805.0], [1037.0, 805.0]]], "lines": ["！！！", "君の性生活の", "ことまでは", "聞いてないし！！"]}, {"box": [271, 484, 349, 621], "vertical": true, "font_size": 34, "lines_coords": [[[312.0, 488.0], [349.0, 488.0], [349.0, 621.0], [312.0, 621.0]], [[271.0, 484.0], [316.0, 484.0], [316.0, 567.0], [271.0, 567.0]]], "l