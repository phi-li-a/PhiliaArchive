, "ボーっとしてないで", "ちゃんと聞けよ！？"]}, {"box": [804, 1376, 950, 1563], "vertical": true, "font_size": 33, "lines_coords": [[[917.0, 1376.0], [950.0, 1376.0], [946.0, 1487.0], [914.0, 1487.0]], [[881.0, 1376.0], [914.0, 1376.0], [910.0, 1489.0], [878.0, 1489.0]], [[846.0, 1379.0], [873.0, 1379.0], [873.0, 1562.0], [846.0, 1562.0]], [[804.0, 1378.0], [843.0, 1378.0], [843.0, 1471.0], [804.0, 1471.0]]], "lines": ["これ以上", "考えると", "脳が爆発しそう", "なので、"]}, {"box": [550, 1377, 725, 1535], "vertical": true, "font_size": 29, "lines_coords": [[[696.0, 1379.0], [725.0, 1379.0], [725.0, 1509.0], [696.0, 1509.0]], [[657.0, 1378.0], [689.0, 1378.0], [689.0, 1535.0], [657.0, 1535.0]], [[623.0, 1379.0], [650.0, 1379.0], [650.0, 1535.0], [623.0, 1535.0]], [[587.0, 1379.0], [614.0, 1379.0], [614.0, 1535.0], [587.0, 1535.0]], [[550.0, 1379.0], [578.0, 1379.0], [578.0, 1493.0], [550.0, 1493.0]]], "lines": ["フンフンは", "宇宙とチョコ", "バイのことで", "頭を満たして", "いました。"]}, {"box": [112, 1351, 150, 1543], "vertical": true, "font_size": 33, "lines_coords": [[[112.0, 1353.0], [150.0, 1353.0], [150.0, 1407.0], [112.0, 1407.0]], [[115.0, 1442.0], [143.0, 1442.0], [143.0, 1542.0], [115.0, 1542.0]]], "lines": ["おー", "い！！"]}], "img_path": "096.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [868, 170, 898, 327], "vertical": true, "font_size": 26, "lines_coords": [[[871.0, 268.0], [895.0, 268.0], [895.0, 325.0], [871.0, 325.0]], [[868.0, 170.0], [895.0, 170.0], [895.0, 279.0], [868.0, 279.0]]], "lines": ["！！", "小野寺ー"]}, {"box": [192, 193, 292, 381], "vertical": true, "font_size": 28, "lines_coords": [[[264.0, 198.0], [290.0, 198.0], [290.0, 351.0], [264.0, 351.0]], [[225.0, 193.0], [257.0, 193.0], [254.0, 381.0], [221.0, 381.0]], [[192.0, 195.0], [218.0, 195.0], [218.0, 353.0], [192.0, 353.0]]], "lines": ["おまえんちの", "途中まで一緒に", "帰ろーぜ！！"]}, {"box": [90, 1020, 150, 1165], "vertical": true, "font_size": 26, "lines_coords": [[[123.0, 1020.0], [150.0, 1020.0], [150.0, 1165.0], [123.0, 1165.0]], [[90.0, 1021.0], [114.0, 1021.0], [114.0, 1093.0], [90.0, 1093.0]]], "lines": ["きのう、病院", "てさー"]}, {"box": [92, 1107, 112, 1151], "vertical": true, "font_size": 26, "lines_coords": [[[92.0, 1107.0], [112.0, 1107.0], [112.0, 1151.0], [92.0, 1151.0]]], "lines": ["．．．"]}, {"box": [129, 1257, 265, 1456], "vertical": true, "font_size": 26, "lines_coords": [[[239.0, 1259.0], [265.0, 1259.0], [265.0, 1443.0], [239.0, 1443.0]], [[200.0, 1259.0], [231.0, 1259.0], [231.0, 1418.0], [200.0, 1418.0]], [[165.0, 1259.0], [192.0, 1259.0], [192.0, 1456.0], [165.0, 1456.0]], [[129.0, 1257.0], [156.0, 1257.0], [156.0, 1428.0], [129.0, 1428.0]]], "lines": ["．．．足、けっこー", "やばいとかで", "医者に運動止め", "られちまった。"]}], "img_path": "097.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [842, 162, 910, 323], "vertical": true, "font_size": 32, "lines_coords": [[[878.0, 162.0], [910.0, 162.0], [910.0, 256.0], [878.0, 256.0]], [[842.0, 164.0], [873.0, 164.0], [873.0, 321.0], [842.0, 321.0]]], "lines": ["．．．来週、", "大会か～～．．．"]}, {"box": [823, 578, 850, 712], "vertical": true, "font_size": 27, "lines_coords": [[[823.0, 578.0], [850.0, 578.0], [850.0, 709.0], [823.0, 709.0]]], "lines": ["ごみ〜〜．．．"]}, {"box": [372, 602, 399, 782], "vertical": true, "font_size": 22, "lines_coords": [[[373.0, 603.0], [395.0, 603.0], [395.0, 781.0], [373.0, 781.0]]], "lines": ["雪降んじゃね？"]}, {"box": [945, 779, 970, 893], "vertical": true, "font_size": 22, "lines_coords": [[[948.0, 779.0], [970.0, 779.0], [967.0, 893.0], [945.0, 893.0]]], "lines": ["さいとう様"]}, {"box": [898, 979, 962, 1087], "vertical": true, "font_size": 27, "lines_coords": [[[935.0, 981.0], [962.0, 981.0], [962.0, 1087.0], [935.0, 1087.0]], [[898.0, 979.0], [925.0, 979.0], [925.0, 1085.0], [898.0, 1085.0]]], "lines": ["．．．なんか", "飲むか？"]}], "img_path": "098.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [959, 104, 985, 235], "vertical": true, "font_size": 26, "lines_coords": [[[959.0, 104.0], [985.0, 104.0], [985.0, 235.0], [959.0, 235.0]]], "lines": ["あのさ．．．"]}, {"box": [817, 173, 915, 332], "vertical": true, "font_size": 26, "lines_coords": [[[889.0, 173.0], [915.0, 173.0], [915.0, 332.0], [889.0, 332.0]], [[851.0, 176.0], [878.0, 176.0], [878.0, 309.0], [851.0, 309.0]], [[817.0, 175.0], [840.0, 175.0], [842.0, 315.0], [818.0, 315.0]]], "lines": ["きのー話した", "彼女のこと", "なんだけど、"]}, {"box": [154, 280, 309, 710], "vertical": true, "font_size": 27, "lines_coords": [[[276.0, 287.0], [303.0, 287.0], [303.0, 396.0], [276.0, 396.0]], [[260.0, 493.0], [289.0, 493.0], [290.0, 673.0], [262.0, 673.0]], [[228.0, 490.0], [254.0, 490.0], [251.0, 710.0], [225.0, 710.0]], [[190.0, 490.0], [217.0, 490.0], [217.0, 687.0], [190.0, 687.0]], [[154.0, 489.0], [181.0, 489.0], [181.0, 684.0], [154.0, 684.0]]], "lines": ["なんかさ", "一回手ぇ繋いだ", "つきりで、それから", "全然触らせても", "くれねーんだ。"]}, {"box": [915, 851, 977, 982], "vertical": true, "font_size": 24, "lines_coords": [[[953.0, 853.0], [975.0, 853.0], [975.0, 981.0], [953.0, 981.0]], [[915.0, 851.0], [940.0, 851.0], [940.0, 931.0], [915.0, 931.0]]], "lines": ["なんでだと", "思う？"]}, {"box": [640, 1306, 743, 1464], "vertical": true, "font_size": 28, "lines_coords": [[[715.0, 1309.0], [742.0, 1309.0], [742.0, 1439.0], [715.0, 1439.0]], [[682.0, 1309.0], [704.0, 1309.0], [704.0, 1464.0], [682.0, 1464.0]], [[640.0, 1306.0], [675.0, 1306.0], [675.0, 1389.0], [640.0, 1389.0]]], "lines": ["あっちから", "告ってきたん", "だぜ？"]}, {"box": [463, 1146, 589, 1421], "vertical": true, "font_size": 28, "lines_coords": [[[562.0, 1148.0], [589.0, 1148.0], [589.0, 1382.0], [562.0, 1382.0]], [[523.0, 1146.0], [551.0, 1146.0], [553.0, 1415.0], [525.0, 1415.0]]], "lines": ["：今の愛子ちゃんが", "何を考えてるかなんて、"]}, {"box": [407, 1145, 474, 1360], "vertical": true, "font_size": 30, "lines_coords": [[[442.0, 1145.0], [473.0, 1145.0], [473.0, 1359.0], [442.0, 1359.0]], [[407.0, 1148.0], [435.0, 1148.0], [437.0, 1315.0], [409.0, 1315.0]]], "lines": ["プンプンには到底", "わかりません。"]}], "img_path": "099.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [678, 85, 748, 134], "vertical": true, "font_size": 29, "lines_coords": [[[709.0, 90.0], [742.0, 85.0], [748.0, 131.0], [714.0, 134.0]], [[678.0, 90.0], [709.0, 90.0], [709.0, 134.0], [678.0, 134.0]]], "lines": ["そー", "そー"]}, {"box": [539, 96, 639, 335], "vertical": true, "font_size": 29, "lines_coords": [[[612.0, 98.0], [639.0, 98.0], [639.0, 264.0], [612.0, 264.0]], [[575.0, 96.0], [601.0, 96.0], [600.0, 335.0], [573.0, 335.0]], [[539.0, 98.0], [565.0, 98.0], [565.0, 240.0], [539.0, 240.0]]], "lines": ["今日の昼休み、", "彼女に小野寺のこと", "話したんだ。"]}, {"box": [96, 54, 382, 81], "vertical": false, "font_size": 27, "lines_coords": [[[96.0, 54.0], [382.0, 54.0], [382.0, 81.0], [96.0, 81.0]]], "lines": ["おやすみプンプン図"]}, {"box": [110, 215, 214, 413], "vertical": true, "font_size": 29, "lines_coords": [[[185.0, 215.0], [212.0, 215.0], [212.0, 385.0], [185.0, 385.0]], [[146.0, 217.0], [178.0, 217.0], [178.0, 404.0], [146.0, 404.0]], [[110.0, 217.0], [137.0, 217.0], [137.0, 410.0], [110.0, 410.0]]], "lines": ["部活に、面白い", "後輩がいてさー", "みたいな感じで。"]}, {"box": [889, 744, 917, 942], "vertical": true, "font_size": 22, "lines_coords": [[[892.0, 793.0], [914.0, 793.0], [914.0, 939.0], [892.0, 939.0]]], "lines": ["．．．そしたら、"]}, {"box": [198, 904, 277, 1145], "vertical": true, "font_size": 32, "lines_coords": [[[240.0, 904.0], [273.0, 904.0], [273.0, 1096.0], [240.0, 1096.0]], [[198.0, 907.0], [229.0, 907.0], [229.0, 1145.0], [198.0, 1145.0]]], "lines": ["彼女の顔色が", "急に変わってさ。"]}, {"box": [854, 1298, 954, 1509], "vertical": true, "font_size": 27, "lines_coords": [[[926.0, 1298.0], [953.0, 1298.0], [954.0, 1509.0], [928.0, 1509.0]], [[890.0, 1300.0], [917.0, 1300.0], [917.0, 1457.0], [890.0, 1457.0]], [[854.0, 1300.0], [881.0, 1300.0], [881.0, 1464.0], [854.0, 1464.0]]], "lines": ["．．．どうした？って", "聞いても全然", "答えねーーし、"]}, {"box": [178, 1342, 245, 1528], "vertical": true, "font_size": 28, "lines_coords": [[[215.0, 1346.0], [245.0, 1346.0], [245.0, 1501.0], [215.0, 1501.0]], [[181.0, 1342.0], [207.0, 1342.0], [204.0, 1526.0], [178.0, 1526.0]]], "lines": ["つーかなんか", "泣いてたし．．．"]}], "img_path": "100.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [837, 101, 865, 189], "vertical": true, "font_size": 28, "lines_coords": [[[837.0, 101.0], [865.0, 101.0], [865.0, 189.0], [837.0, 189.0]]], "lines": ["お前さ、"]}, {"box": [151, 332, 249, 465], "vertical": true, "font_size": 26, "lines_coords": [[[221.0, 334.0], [248.0, 334.0], [248.0, 465.0], [221.0, 465.0]], [[184.0, 332.0], [212.0, 332.0], [212.0, 437.0], [184.0, 437.0]], [[151.0, 335.0], [173.0, 335.0], [173.0, 462.0], [151.0, 462.0]]], "lines": ["田中愛子と", "昔なんか", "あったの？"]}, {"box": [857, 900, 956, 1092], "vertical": true, "font_size": 27, "lines_coords": [[[929.0, 900.0], [956.0, 900.0], [956.0, 1031.0], [929.0, 1031.0]], [[893.0, 901.0], [920.0, 901.0], [920.0, 1056.0], [893.0, 1056.0]], [[857.0, 900.0], [884.0, 900.0], [884.0, 1090.0], [857.0, 1090.0]]], "lines": ["もしかして", "田中の本当に", "好きなやつって、"]}, {"box": [265, 902, 320, 1046], "vertical": true, "font_size": 24, "lines_coords": [[[293.0, 903.0], [320.0, 903.0], [320.0, 1001.0], [293.0, 1001.0]], [[265.0, 904.0], [287.0, 904.0], [287.0, 1043.0], [265.0, 1043.0]]], "lines": ["．．．なんか", "言えって．．．"]}, {"box": [560, 1345, 667, 1479], "vertical": true, "font_size": 33, "lines_coords": [[[628.0, 1346.0], [667.0, 1346.0], [667.0, 1434.0], [628.0, 1434.0]], [[598.0, 1348.0], [626.0, 1348.0], [626.0, 1453.0], [598.0, 1453.0]], [[560.0, 1345.0], [593.0, 1345.0], [593.0, 1479.0], [560.0, 1479.0]]], "lines": ["小野寺", "なんじゃ", "ねーの？"]}, {"box": [123, 1296, 214, 1534], "vertical": true, "font_size": 25, "lines_coords": [[[184.0, 1296.0], [210.0, 1296.0], [210.0, 1448.0], [184.0, 1448.0]], [[154.0, 1296.0], [181.0, 1296.0], [181.0, 1534.0], [154.0, 1534.0]], [[123.0, 1298.0], [145.0, 1298.0], [145.0, 1459.0], [123.0, 1459.0]]], "lines": ["じゃねーと俺、", "すっげーダセーことに", "なるからさ．．．"]}], "img_path": "101.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [906, 49, 1006, 262], "vertical": true, "font_size": 25, "lines_coords": [[[979.0, 51.0], [1001.0, 51.0], [1001.0, 259.0], [979.0, 259.0]], [[940.0, 51.0], [967.0, 51.0], [967.0, 206.0], [940.0, 206.0]], [[906.0, 50.0], [932.0, 50.0], [932.0, 189.0], [906.0, 189.0]]], "lines": ["．．．ホラ、田中ってさ", "放課後帰んの", "はえーんだ。"]}, {"box": [593, 81, 692, 240], "vertical": true, "font_size": 26, "lines_coords": [[[665.0, 81.0], [692.0, 81.0], [692.0, 237.0], [665.0, 237.0]], [[628.0, 82.0], [654.0, 82.0], [654.0, 240.0], [628.0, 240.0]], [[593.0, 81.0], [620.0, 81.0], [620.0, 237.0], [593.0, 237.0]]], "lines": ["俺、ひとりで", "勝手に超～～", "考えててさ！"]}, {"box": [428, 118, 564, 367], "vertical": true, "font_size": 26, "lines_coords": [[[537.0, 118.0], [564.0, 118.0], [564.0, 354.0], [537.0, 354.0]], [[501.0, 118.0], [528.0, 118.0], [528.0, 367.0], [501.0, 367.0]], [[465.0, 118.0], [489.0, 118.0], [487.0, 353.0], [464.0, 353.0]], [[428.0, 120.0], [454.0, 120.0], [454.0, 312.0], [428.0, 312.0]]], "lines": ["田中に楽させるため", "には、俺が早く稼げる", "ようになったほうが", "いいじゃんとか。"]}, {"box": [771, 506, 837, 714], "vertical": true, "font_size": 27, "lines_coords": [[[807.0, 507.0], [834.0, 507.0], [834.0, 714.0], [807.0, 714.0]], [[771.0, 506.0], [798.0, 506.0], [798.0, 678.0], [771.0, 678.0]]], "lines": ["病気の親父さんの", "看病とかでさ。"]}, {"box": [117, 500, 254, 709], "vertical": true, "font_size": 25, "lines_coords": [[[225.0, 500.0], [251.0, 500.0], [251.0, 660.0], [225.0, 660.0]], [[189.0, 503.0], [215.0, 503.0], [215.0, 684.0], [189.0, 684.0]], [[151.0, 503.0], [178.0, 503.0], [178.0, 709.0], [151.0, 709.0]], [[117.0, 500.0], [139.0, 500.0], [139.0, 706.0], [117.0, 706.0]]], "lines": ["それだったら", "パドミントンも", "簡単に諦められん", "じゃねーかとか！！"]}, {"box": [942, 806, 973, 939], "vertical": true, "font_size": 27, "lines_coords": [[[945.0, 806.0], [973.0, 806.0], [970.0, 939.0], [942.0, 939.0]]], "lines": ["．．．田中が！！"]}, {"box": [801, 875, 901, 1059], "vertical": true, "font_size": 27, "lines_coords": [[[875.0, 875.0], [901.0, 875.0], [901.0, 1059.0], [875.0, 1059.0]], [[839.0, 875.0], [865.0, 875.0], [865.0, 1032.0], [839.0, 1032.0]], [[801.0, 875.0], [828.0, 875.0], [828.0, 1032.0], [801.0, 1032.0]]], "lines": ["なんかいっつも", "悲しそうな顔", "してるから！！"]}, {"box": [160, 1026, 299, 1209], "vertical": true, "font_size": 26, "lines_coords": [[[270.0, 1029.0], [296.0, 1029.0], [296.0, 1187.0], [270.0, 1187.0]], [[234.0, 1026.0], [256.0, 1026.0], [256.0, 1209.0], [234.0, 1209.0]], [[196.0, 1028.0], [225.0, 1028.0], [221.0, 1185.0], [193.0, 1185.0]], [[160.0, 1026.0], [187.0, 1026.0], [187.0, 1132.0], [160.0, 1132.0]]], "lines": ["俺がなんとか", "してやんねーと", "って思ったり", "してさ！！"]}, {"box": [851, 1281, 880, 1397], "vertical": true, "font_size": 27, "lines_coords": [[[851.0, 1282.0], [878.0, 1282.0], [878.0, 1392.0], [851.0, 1392.0]]], "lines": ["．．．そうだ。"]}, {"box": [635, 1279, 812, 1465], "vertical": true, "font_size": 29, "lines_coords": [[[778.0, 1279.0], [812.0, 1279.0], [812.0, 1367.0], [778.0, 1367.0]], [[745.0, 1281.0], [771.0, 1281.0], [771.0, 1440.0], [745.0, 1440.0]], [[707.0, 1282.0], [735.0, 1282.0], [732.0, 1464.0], [704.0, 1464.0]], [[671.0, 1282.0], [698.0, 1282.0], [698.0, 1464.0], [671.0, 1464.0]], [[635.0, 1282.0], [664.0, 1282.0], [664.0, 1398.0], [635.0, 1398.0]]], "lines": ["確かに", "愛子ちゃんは", "いつだって少し", "寂しそうな目を", "している。"]}, {"box": [446, 1281, 545, 1493], "vertical": true, "font_size": 26, "lines_coords": [[[518.0, 1281.0], [545.0, 1281.0], [545.0, 1412.0], [518.0, 1412.0]], [[482.0, 1281.0], [509.0, 1281.0], [509.0, 1387.0], [482.0, 1387.0]], [[446.0, 1282.0], [468.0, 1282.0], [468.0, 1493.0], [446.0, 1493.0]]], "lines": ["それだけは", "昔と何も", "変わらないのだね"]}, {"box": [335, 1278, 403, 1462], "vertical": true, "font_size": 26, "lines_coords": [[[375.0, 1278.0], [403.0, 1278.0], [400.0, 1462.0], [371.0, 1462.0]], [[339.0, 1279.0], [365.0, 1279.0], [362.0, 1423.0], [335.0, 1423.0]]], "lines": ["と、フンフンは", "思いました。"]}], "img_path": "102.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [250, 193, 357, 354], "vertical": true, "font_size": 62, "lines_coords": [[[250.0, 217.0], [307.0, 193.0], [357.0, 317.0], [300.0, 340.0]]], "lines": ["撃て！"]}, {"box": [529, 702, 560, 857], "vertical": true, "font_size": 27, "lines_coords": [[[529.0, 706.0], [556.0, 706.0], [556.0, 850.0], [529.0, 850.0]]], "lines": ["僕は．．．．．"]}, {"box": [557, 1035, 626, 1053], "vertical": false, "font_size": 18, "lines_coords": [[[557.0, 1035.0], [626.0, 1035.0], [626.0, 1053.0], [557.0, 1053.0]]], "lines": ["．．．"]}, {"box": [232, 996, 311, 1204], "vertical": true, "font_size": 32, "lines_coords": [[[276.0, 996.0], [307.0, 996.0], [307.0, 1201.0], [276.0, 1201.0]], [[232.0, 998.0], [265.0, 998.0], [265.0, 1189.0], [232.0, 1189.0]]], "lines": ["「愛子ちゃんが", "．．．好きです。」"]}, {"box": [112, 1096, 134, 1278], "vertical": true, "font_size": 17, "lines_coords": [[[117.0, 1096.0], [134.0, 1096.0], [129.0, 1278.0], [112.0, 1278.0]]], "lines": ["犬の放し続いは、止めて下さ"]}], "img_path": "103.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "104.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "105.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [473, 107, 597, 299], "vertical": true, "font_size": 34, "lines_coords": [[[559.0, 107.0], [596.0, 107.0], [596.0, 234.0], [559.0, 234.0]], [[517.0, 110.0], [550.0, 110.0], [550.0, 298.0], [517.0, 298.0]], [[475.0, 110.0], [506.0, 110.0], [506.0, 270.0], [475.0, 270.0]]], "lines": ["「．．．僕は、", "愛子ちゃんが", "好きです。」"]}, {"box": [25, 286, 72, 451], "vertical": true, "font_size": 45, "lines_coords": [[[26.0, 289.0], [71.0, 289.0], [71.0, 451.0], [26.0, 451.0]]], "lines": ["第３０話"]}, {"box": [921, 1086, 982, 1245], "vertical": true, "font_size": 28, "lines_coords": [[[954.0, 1089.0], [982.0, 1089.0], [982.0,