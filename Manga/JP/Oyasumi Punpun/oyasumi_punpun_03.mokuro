], [787.0, 837.0], [760.0, 837.0]], [[731.0, 617.0], [753.0, 617.0], [753.0, 806.0], [731.0, 806.0]], [[698.0, 618.0], [720.0, 618.0], [720.0, 795.0], [698.0, 795.0]], [[667.0, 617.0], [687.0, 617.0], [687.0, 842.0], [667.0, 842.0]]], "lines": ["クールなアイディアで", "ピンチを切り抜け", "ましたが、油断は", "まだまだできません。"]}, {"box": [457, 456, 635, 653], "vertical": true, "font_size": 62, "lines_coords": [[[579.0, 471.0], [635.0, 484.0], [598.0, 653.0], [542.0, 640.0]], [[548.0, 473.0], [595.0, 482.0], [568.0, 604.0], [521.0, 593.0]], [[490.0, 456.0], [568.0, 473.0], [535.0, 617.0], [457.0, 600.0]]], "lines": ["とんでもね～", "野郎に", "決まっとる！！"]}, {"box": [518, 987, 607, 1137], "vertical": true, "font_size": 36, "lines_coords": [[[573.0, 990.0], [607.0, 990.0], [607.0, 1098.0], [573.0, 1098.0]], [[518.0, 989.0], [556.0, 989.0], [556.0, 1137.0], [518.0, 1137.0]]], "lines": ["おっと", "危ない！！"]}, {"box": [320, 757, 353, 854], "vertical": true, "font_size": 33, "lines_coords": [[[320.0, 757.0], [353.0, 757.0], [353.0, 854.0], [320.0, 854.0]]], "lines": ["あっ！！"]}], "img_path": "057.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [584, 149, 850, 396], "vertical": false, "font_size": 149, "lines_coords": [[[615.0, 215.0], [778.0, 231.0], [764.0, 379.0], [601.0, 364.0]]], "lines": ["んっ"]}, {"box": [370, 135, 401, 261], "vertical": true, "font_size": 22, "lines_coords": [[[373.0, 139.0], [395.0, 139.0], [395.0, 256.0], [373.0, 256.0]]], "lines": ["間、髪は"]}, {"box": [132, 214, 306, 398], "vertical": true, "font_size": 26, "lines_coords": [[[273.0, 215.0], [306.0, 215.0], [306.0, 296.0], [273.0, 296.0]], [[242.0, 217.0], [264.0, 217.0], [264.0, 396.0], [242.0, 396.0]], [[201.0, 215.0], [228.0, 215.0], [228.0, 398.0], [201.0, 398.0]], [[167.0, 214.0], [193.0, 214.0], [192.0, 398.0], [165.0, 398.0]], [[132.0, 215.0], [154.0, 215.0], [154.0, 396.0], [132.0, 396.0]]], "lines": ["危うく", "振り向きさまに", "鋭利なナイフで", "切りつけられる", "ところでした！！"]}, {"box": [806, 696, 870, 740], "vertical": false, "font_size": 25, "lines_coords": [[[806.0, 717.0], [860.0, 696.0], [870.0, 720.0], [815.0, 740.0]]], "lines": ["ふ"]}, {"box": [693, 634, 870, 759], "vertical": false, "font_size": 53, "lines_coords": [[[693.0, 712.0], [845.0, 634.0], [870.0, 681.0], [718.0, 759.0]]], "lines": ["って何か"]}, {"box": [962, 964, 985, 1071], "vertical": true, "font_size": 23, "lines_coords": [[[962.0, 964.0], [985.0, 964.0], [985.0, 1023.0], [962.0, 1023.0]]], "lines": ["ワリ"]}, {"box": [629, 957, 732, 1118], "vertical": true, "font_size": 30, "lines_coords": [[[704.0, 957.0], [732.0, 957.0], [732.0, 1067.0], [704.0, 1067.0]], [[668.0, 959.0], [695.0, 959.0], [695.0, 1118.0], [668.0, 1118.0]], [[629.0, 957.0], [664.0, 957.0], [664.0, 1040.0], [629.0, 1040.0]]], "lines": ["ちょっと", "飲み物買って", "いい？"]}], "img_path": "058.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [454, 1, 1046, 706], "vertical": false, "font_size": 619, "lines_coords": [[[454.0, 100.0], [918.0, 1.0], [1046.0, 607.0], [582.0, 706.0]]], "lines": ["教室で"]}], "img_path": "059.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [389, 213, 415, 320], "vertical": true, "font_size": 26, "lines_coords": [[[389.0, 214.0], [415.0, 214.0], [415.0, 320.0], [389.0, 320.0]]], "lines": ["．．．ホイ！！"]}, {"box": [937, 851, 1002, 1020], "vertical": true, "font_size": 27, "lines_coords": [[[973.0, 851.0], [1000.0, 851.0], [1000.0, 1007.0], [973.0, 1007.0]], [[937.0, 851.0], [964.0, 851.0], [964.0, 1018.0], [937.0, 1018.0]]], "lines": ["今日、すげー", "さみーからさ。"]}, {"box": [503, 1004, 531, 1096], "vertical": true, "font_size": 28, "lines_coords": [[[503.0, 1004.0], [531.0, 1004.0], [531.0, 1095.0], [503.0, 1095.0]]], "lines": ["飲めよ。"]}, {"box": [593, 1159, 743, 1300], "vertical": false, "font_size": 37, "lines_coords": [[[629.0, 1243.0], [670.0, 1159.0], [704.0, 1176.0], [664.0, 1260.0]], [[640.0, 1278.0], [715.0, 1179.0], [743.0, 1201.0], [668.0, 1300.0]]], "lines": ["．．．", "こでは、"]}, {"box": [96, 1285, 232, 1496], "vertical": true, "font_size": 26, "lines_coords": [[[206.0, 1287.0], [232.0, 1287.0], [232.0, 1496.0], [206.0, 1496.0]], [[168.0, 1285.0], [196.0, 1285.0], [193.0, 1446.0], [165.0, 1446.0]], [[132.0, 1287.0], [159.0, 1287.0], [159.0, 1470.0], [132.0, 1470.0]], [[96.0, 1285.0], [126.0, 1285.0], [126.0, 1331.0], [96.0, 1331.0]]], "lines": ["．．．そろそろ一年も", "外で素振りも", "キツい季節だよ", "なー"]}, {"box": [101, 1346, 118, 1390], "vertical": true, "font_size": 26, "lines_coords": [[[101.0, 1346.0], [118.0, 1346.0], [118.0, 1390.0], [101.0, 1390.0]]], "lines": ["．．．"]}], "img_path": "060.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [892, 137, 1009, 326], "vertical": true, "font_size": 23, "lines_coords": [[[987.0, 139.0], [1009.0, 139.0], [1009.0, 326.0], [987.0, 326.0]], [[954.0, 137.0], [981.0, 137.0], [981.0, 282.0], [954.0, 282.0]], [[925.0, 137.0], [946.0, 137.0], [946.0, 281.0], [925.0, 281.0]], [[892.0, 137.0], [914.0, 137.0], [914.0, 268.0], [892.0, 268.0]]], "lines": ["いつもつまんねー", "練習ばっかで", "わりーなって", "思ってんだ。"]}, {"box": [221, 204, 378, 421], "vertical": true, "font_size": 24, "lines_coords": [[[356.0, 204.0], [378.0, 204.0], [378.0, 395.0], [356.0, 395.0]], [[320.0, 204.0], [346.0, 204.0], [346.0, 395.0], [320.0, 395.0]], [[287.0, 204.0], [314.0, 204.0], [314.0, 421.0], [287.0, 421.0]], [[256.0, 206.0], [278.0, 206.0], [278.0, 350.0], [256.0, 350.0]], [[221.0, 204.0], [243.0, 204.0], [243.0, 354.0], [221.0, 354.0]]], "lines": ["もうちょっと俺も", "強く言えばいいん", "だけど、なんか軽く", "見られがちで", "説得力ねーし、"]}, {"box": [779, 340, 900, 531], "vertical": true, "font_size": 23, "lines_coords": [[[878.0, 342.0], [900.0, 342.0], [900.0, 482.0], [878.0, 482.0]], [[842.0, 340.0], [868.0, 340.0], [868.0, 484.0], [842.0, 484.0]], [[810.0, 342.0], [832.0, 342.0], [832.0, 531.0], [810.0, 531.0]], [[779.0, 342.0], [800.0, 342.0], [800.0, 493.0], [779.0, 493.0]]], "lines": ["部長も顧問も", "シキタリとか", "ケジメとか頭ん中", "カチカチでさ。"]}, {"box": [118, 425, 240, 596], "vertical": true, "font_size": 24, "lines_coords": [[[214.0, 428.0], [240.0, 428.0], [240.0, 550.0], [214.0, 550.0]], [[181.0, 426.0], [207.0, 426.0], [207.0, 596.0], [181.0, 596.0]], [[148.0, 425.0], [175.0, 425.0], [173.0, 596.0], [146.0, 596.0]], [[118.0, 428.0], [140.0, 428.0], [140.0, 509.0], [118.0, 509.0]]], "lines": ["バドの実力", "だったら二年で", "ダントツなんだ", "けどなー"]}, {"box": [914, 1009, 978, 1167], "vertical": true, "font_size": 27, "lines_coords": [[[950.0, 1012.0], [976.0, 1012.0], [976.0, 1167.0], [950.0, 1167.0]], [[914.0, 1009.0], [942.0, 1009.0], [942.0, 1125.0], [914.0, 1125.0]]], "lines": ["一年の小松は", "すげーよ。"]}, {"box": [504, 1051, 640, 1237], "vertical": true, "font_size": 27, "lines_coords": [[[609.0, 1051.0], [637.0, 1051.0], [640.0, 1195.0], [612.0, 1195.0]], [[575.0, 1054.0], [603.0, 1054.0], [600.0, 1237.0], [571.0, 1237.0]], [[539.0, 1054.0], [567.0, 1054.0], [564.0, 1212.0], [535.0, 1212.0]], [[504.0, 1056.0], [526.0, 1056.0], [526.0, 1184.0], [504.0, 1184.0]]], "lines": ["あいつさぁ、", "１教えただけで", "１０も２０も吸収", "すんだろ？"]}, {"box": [167, 798, 198, 931], "vertical": true, "font_size": 28, "lines_coords": [[[170.0, 798.0], [198.0, 798.0], [195.0, 931.0], [167.0, 931.0]]], "lines": ["．．．つーか．．．"]}, {"box": [676, 1350, 739, 1492], "vertical": true, "font_size": 26, "lines_coords": [[[710.0, 1350.0], [739.0, 1350.0], [739.0, 1456.0], [710.0, 1456.0]], [[678.0, 1354.0], [700.0, 1354.0], [700.0, 1489.0], [678.0, 1489.0]]], "lines": ["あいつは", "マジで天才。"]}, {"box": [78, 1239, 253, 1483], "vertical": true, "font_size": 26, "lines_coords": [[[223.0, 1239.0], [250.0, 1239.0], [250.0, 1460.0], [223.0, 1460.0]], [[189.0, 1240.0], [215.0, 1240.0], [215.0, 1479.0], [189.0, 1479.0]], [[151.0, 1240.0], [178.0, 1240.0], [178.0, 1476.0], [151.0, 1476.0]], [[114.0, 1240.0], [140.0, 1240.0], [140.0, 1450.0], [114.0, 1450.0]], [[81.0, 1240.0], [107.0, 1240.0], [104.0, 1425.0], [78.0, 1425.0]]], "lines": ["そーゆーあいつの", "生まれ持った才能が、", "俺の今までの努力を", "超無意味にしてる", "って思うと．．．"]}], "img_path": "061.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [915, 82, 1015, 321], "vertical": true, "font_size": 27, "lines_coords": [[[985.0, 82.0], [1014.0, 82.0], [1015.0, 248.0], [987.0, 248.0]], [[950.0, 82.0], [976.0, 82.0], [976.0, 290.0], [950.0, 290.0]], [[915.0, 84.0], [942.0, 84.0], [942.0, 321.0], [915.0, 321.0]]], "lines": ["．．．しょーじき、", "今までなんの為に", "頑張ってきたんだ？"]}, {"box": [820, 248, 882, 365], "vertical": true, "font_size": 27, "lines_coords": [[[856.0, 248.0], [882.0, 248.0], [882.0, 356.0], [856.0, 356.0]], [[820.0, 248.0], [846.0, 248.0], [846.0, 365.0], [820.0, 365.0]]], "lines": ["．．．なんて", "思う訳よ。"]}, {"box": [296, 87, 396, 295], "vertical": true, "font_size": 26, "lines_coords": [[[368.0, 87.0], [396.0, 87.0], [396.0, 201.0], [368.0, 201.0]], [[332.0, 87.0], [359.0, 87.0], [359.0, 295.0], [332.0, 295.0]], [[296.0, 87.0], [323.0, 87.0], [323.0, 256.0], [296.0, 256.0]]], "lines": ["．．．．．．全中、", "全日本ジュニアを", "駆け上がって、"]}, {"box": [118, 125, 237, 389], "vertical": true, "font_size": 26, "lines_coords": [[[215.0, 131.0], [237.0, 131.0], [237.0, 362.0], [215.0, 362.0]], [[182.0, 126.0], [209.0, 126.0], [209.0, 314.0], [182.0, 314.0]], [[151.0, 125.0], [178.0, 125.0], [175.0, 389.0], [148.0, 389.0]], [[123.0, 129.0], [145.0, 129.0], [140.0, 368.0], [118.0, 368.0]]], "lines": ["スター選手になれる", "なら、俺の人生", "すべてを捧げてもいい", "って思ってたのにさ．．．"]}, {"box": [898, 537, 996, 719], "vertical": true, "font_size": 24, "lines_coords": [[[971.0, 539.0], [993.0, 539.0], [993.0, 667.0], [971.0, 667.0]], [[935.0, 537.0], [957.0, 537.0], [957.0, 718.0], [935.0, 718.0]], [[898.0, 537.0], [925.0, 537.0], [925.0, 679.0], [898.0, 679.0]]], "lines": ["なんか結局", "俺って天才とか", "じゃなくて、"]}, {"box": [928, 1070, 987, 1202], "vertical": true, "font_size": 28, "lines_coords": [[[959.0, 1071.0], [987.0, 1071.0], [987.0, 1201.0], [959.0, 1201.0]]], "lines": ["やっぱさー"]}, {"box": [365, 1065, 431, 1269], "vertical": true, "font_size": 27, "lines_coords": [[[393.0, 1065.0], [431.0, 1065.0], [431.0, 1268.0], [393.0, 1268.0]], [[367.0, 1068.0], [389.0, 1068.0], [389.0, 1212.0], [367.0, 1212.0]], [[365.0, 1206.0], [385.0, 1204.0], [389.0, 1267.0], [368.0, 1268.0]]], "lines": ["あーっ、ワリ！！", "なんでもねー", "！！"]}, {"box": [177, 776, 276, 933], "vertical": true, "font_size": 26, "lines_coords": [[[248.0, 778.0], [276.0, 778.0], [276.0, 884.0], [248.0, 884.0]], [[212.0, 776.0], [239.0, 776.0], [239.0, 932.0], [212.0, 932.0]], [[178.0, 778.0], [200.0, 778.0], [200.0, 918.0], [178.0, 918.0]]], "lines": ["けっこー", "フツーに凡人", "だったのな。"]}, {"box": [476, 1325, 615, 1495], "vertical": true, "font_size": 24, "lines_coords": [[[587.0, 1326.0], [615.0, 1326.0], [615.0, 1425.0], [587.0, 1425.0]], [[559.0, 1328.0], [582.0, 1328.0], [585.0, 1468.0], [562.0, 1468.0]], [[531.0, 1325.0], [557.0, 1325.0], [557.0, 1495.0], [531.0, 1495.0]], [[504.0, 1328.0], [526.0, 1328.0], [526.0, 1468.0], [504.0, 1468.0]], [[478.0, 1326.0], [500.0, 1326.0], [500.0, 1492.0], [478.0, 1492.0]]], "lines": ["フツーは", "フツーなりの", "ちっちゃい目標", "持ったほうが", "幸せなのかな？"]}, {"box": [118, 1376, 182, 1534], "vertical": true, "font_size": 27, "lines_coords": [[[154.0, 1376.0], [181.0, 1376.0], [181.0, 1532.0], [154.0, 1532.0]], [[118.0, 1378.0], [145.0, 1378.0], [145.0, 1534.0], [118.0, 1534.0]]], "lines": ["もっと楽しい", "話しようぜ！！"]}], "img_path": "062.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [825, 137, 945, 295], "vertical": true, "font_size": 26, "lines_coords": [[[918.0, 139.0], [945.0, 139.0], [945.0, 270.0], [918.0, 270.0]], [[887.0, 139.0], [914.0, 139.0], [914.0, 271.0], [887.0, 271.0]], [[854.0, 137.0], [881.0, 137.0], [881.0, 295.0], [854.0, 295.0]], [[825.0, 139.0], [846.0, 139.0], [846.0, 240.0], [825.0, 240.0]]], "lines": ["．．．ところで", "小野寺って", "好きな子とか", "いんの？"]}, {"box": [112, 322, 140, 439], "vertical": true, "font_size": 28, "lines_coords": [[[112.0, 323.0], [140.0, 323.0], [140.0, 437.0], [112.0, 437.0]]], "lines": ["．．．つーか。"]}, {"box": [284, 534, 325, 629], "vertical": true, "font_size": 31, "lines_coords": [[[284.0, 534.0], [325.0, 534.0], [325.0, 629.0], [284.0, 629.0]]], "lines": ["．．．俺さ、"]}, {"box": [150, 546, 215, 745], "vertical": true, "font_size": 31, "lines_coords": [[[189.0, 548.0], [215.0, 548.0], [215.0, 706.0], [189.0, 706.0]], [[150.0, 546.0], [176.0, 546.0], [179.0, 745.0], [153.0, 745.0]]], "lines": ["最近はじめて", "彼女ができてさ。"]}, {"box": [806, 831, 940, 1039], "vertical": true, "font_size": 27, "lines_coords": [[[918.0, 834.0], [940.0, 834.0], [940.0, 1039.0], [918.0, 1039.0]], [[876.0, 831.0], [907.0, 831.0], [907.0, 1000.0], [876.0, 1000.0]], [[843.0, 832.0], [875.0, 832.0], [875.0, 1020.0], [843.0, 1020.0]], [[809.0, 834.0], [835.0, 834.0], [832.0, 1020.0], [806.0, 1020.0]]], "lines": ["どう話せはいいか", "わかんねーし、", "手ぇ繋ぐだけで", "超緊張するし！！"]}, {"box": [675, 996, 798, 1181], "vertical": true, "font_size": 27, "lines_coords": [[[776.0, 996.0], [798.0, 996.0], [798.0, 1179.0], [776.0, 1179.0]], [[740.0, 998.0], [767.0, 998.0], [767.0, 1167.0], [740.0, 1167.0]], [[707.0, 996.0], [734.0, 996.0], [734.0, 1181.0], [707.0, 1181.0]], [[675.0, 996.0], [703.0, 996.0], [703.0, 1087.0], [675.0, 1087.0]]], "lines": ["もーなんか最近", "頭ん中、彼女の", "ことで一杯なん", "だよね。"]}, {"box": [167, 975, 269, 1185], "vertical": true, "font_size": 27, "lines_coords": [[[240.0, 976.0], [267.0, 976.0], [267.0, 1185.0], [240.0, 1185.0]], [[201.0, 976.0], [232.0, 976.0], [232.0, 1185.0], [201.0, 1185.0]], [[167.0, 975.0], [195.0, 975.0], [195.0, 1056.0], [167.0, 1056.0]], [[170.0, 1056.0], [192.0, 1056.0], [192.0, 1106.0], [170.0, 1106.0]]], "lines": ["．．．こんなんだから", "小松に勝てねーの", "かなー", "．．．"]}, {"box": [553, 1301, 618, 1461], "vertical": true, "font_size": 27, "lines_coords": [[[592.0, 1371.0], [615.0, 1371.0], [612.0, 1459.0], [589.0, 1459.0]], [[582.0, 1301.0], [618.0, 1301.0], [618.0, 1357.0], [582.0, 1357.0]], [[554.0, 1304.0], [576.0, 1304.0], [576.0, 1435.0], [554.0, 1435.0]]], "lines": ["ーっ！！", "がー", "ごめんな！！"]}, {"box": [112, 1364, 211, 1521], "vertical": true, "font_size": 25, "lines_coords": [[[181.0, 1364.0], [207.0, 1364.0], [207.0, 1521.0], [181.0, 1521.0]], [[146.0, 1365.0], [173.0, 1365.0], [173.0, 1521.0], [146.0, 1521.0]], [[112.0, 1367.0], [134.0, 1367.0], [134.0, 1520.0], [112.0, 1520.0]]], "lines": ["また暗い話に", "なってきた！！", "おかしーな！！"]}], "img_path": "063.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [881, 103, 917, 159], "vertical": true, "font_size": 33, "lines_coords": [[[881.0, 103.0], [917.0, 103.0], [917.0, 159.0], [881.0, 159.0]]], "lines": ["．．．あ、"]}, {"box": [757, 114, 825, 282], "vertical": true, "font_size": 33, "lines_coords": [[[790.0, 114.0], [825.0, 114.0], [825.0, 220.0], [790.0, 220.0]], [[757.0, 115.0], [784.0, 115.0], [784.0, 282.0], [757.0, 282.0]]], "lines": ["俺、ココ", "寄ってくから。"]}, {"box": [462, 123, 525, 256], "vertical": true, "font_size": 26, "lines_coords": [[[498.0, 129.0], [525.0, 129.0], [525.0, 256.0], [498.0, 256.0]], [[462.0, 123.0], [489.0, 123.0], [489.0, 231.0], [462.0, 231.0]]], "lines": ["．．．．．．．ん？", "．．．ああ！！"]}, {"box": [304, 173, 437, 384], "vertical": true, "font_size": 26, "lines_coords": [[[415.0, 173.0], [437.0, 173.0], [437.0, 357.0], [415.0, 357.0]], [[378.0, 173.0], [404.0, 173.0], [404.0, 384.0], [378.0, 384.0]], [[340.0, 175.0], [367.0, 175.0], [367.0, 359.0], [340.0, 359.0]], [[304.0, 173.0], [332.0, 173.0], [332.0, 256.0], [304.0, 256.0]]], "lines": ["別に大した怪我", "じゃねーからさ！！", "みんなには言う", "なよ！？"]}, {"box": [131, 537, 231, 732], "vertical": true, "font_size": 25, "lines_coords": [[[201.0, 537.0], [228.0, 537.0], [228.0, 685.0], [201.0, 685.0]], [[167.0, 537.0], [193.0, 537.0], [190.0, 721.0], [164.0, 721.0]], [[132.0, 537.0], [154.0, 537.0], [154.0, 731.0], [132.0, 731.0]]], "lines": ["つーかお前、", "明日は朝練から", "ちゃんと来いよ！？"]}, {"box": [859, 1043, 962, 1192], "vertical": true, "font_size": 30, "lines_coords": [[[926.0, 1043.0], [962.0, 1043.0], [962.0, 1114.0], [926.0, 1114.0]], [[895.0, 1045.0], [923.0, 1045.0], [923.0, 1192.0], [895.0, 1192.0]], [[859.0, 1045.0], [885.0, 1045.0], [885.0, 1151.0], [859.0, 1151.0]]], "lines": ["．．．あ", "それともう", "ひとつ！！"]}], "img_path": "064.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [844, 190, 945, 450], "vertical": true, "font_size": 25, "lines_coords": [[[917.0, 190.0], [943.0, 190.0], [943.0, 350.0], [917.0, 350.0]], [[879.0, 190.0], [906.0, 190.0], [906.0, 450.0], [879.0, 450.0]], [[846.0, 196.0], [868.0, 196.0], [868.0, 428.0], [846.0, 428.0]]], "lines": ["彼女を幸せに", "することが俺にとって", "一番の幸せってのは"]}, {"box": [162, 335, 266, 468], "vertical": true, "font_size": 29, "lines_coords": [[[237.0, 339.0], [265.0, 339.0], [265.0, 443.0], [237.0, 443.0]], [[201.0, 339.0], [228.0, 339.0], [228.0, 468.0], [201.0, 468.0]], [[162.0, 335.0], [195.0, 335.0], [195.0, 420.0], [162.0, 420.0]]], "lines": ["人として", "小さすぎる", "かな？"]}, {"box": [870, 1020, 1007, 1207], "vertical": true, "font_size": 28, "lines_coords": [[[979.0, 1023.0], [1007.0, 1023.0], [1007.0, 1109.0], [979.0, 1109.0]], [[943.0, 1020.0], [970.0, 1020.0], [970.0, 1168.0], [943.0, 1168.0]], [[906.0, 1020.0], [937.0, 1020.0], [937.0, 1196.0], [906.0, 1196.0]], [[870.0, 1020.0], [896.0, 1020.0], [900.0, 1168.0], [873.0, 1168.0]]], "lines": ["．．．ワリ", "なんでもねー", "お前聞き上手", "だからさぁ。"]}, {"box": [260, 775, 546, 973], "vertical": false, "font_size": 189, "lines_coords": [[[260.0, 784.0], [540.0, 775.0], [546.0, 964.0], [267.0, 973.0]]], "lines": ["が"]}, {"box": [617, 1364, 681, 1520], "vertical": true, "font_size": 26, "lines_coords": [[[654.0, 1364.0], [681.0, 1364.0], [681.0, 1520.0], [654.0, 1520.0]], [[617.0, 1364.0], [643.0, 1364.0], [643.0, 1495.0], [617.0, 1495.0]]], "lines": ["またゆっくり", "話そうぜ！"]}, {"box": [231, 1369, 440, 1570], "vertical": true, "font_size": 30, "lines_coords": [[[406.0, 1371.0], [440.0, 1371.0], [440.0, 1454.0], [406.0, 1454.0]], [[375.0, 1371.0], [401.0, 1371.0], [401.0, 1503.0], [375.0, 1503.0]], [[335.0, 1370.0], [367.0, 1370.0], [367.0, 1570.0], [335.0, 1570.0]], [[298.0, 1371.0], [331.0, 1371.0], [331.0, 1557.0], [298.0, 1557.0]], [[260.0, 1371.0], [295.0, 1371.0], [295.0, 1456.0], [260.0, 1456.0]], [[231.0, 1373.0], [253.0, 1373.0], [253.0, 1510.0], [231.0, 1510.0]]], "lines": ["先輩は", "笑った顔が", "昔、仲の良かった", "ハルミンという", "友達に", "似てました。"]}], "img_path": "065.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [845, 92, 980, 302], "vertical": true, "font_size": 25, "lines_coords": [[[951.0, 92.0], [978.0, 92.0], [978.0, 301.0], [951.0, 301.0]], [[917.0, 93.0], [943.0, 93.0], [943.0, 276.0], [917.0, 276.0]], [[881.0, 93.0], [907.0, 93.0], [907.0, 301.0], [881.0, 301.0]], [[846.0, 95.0], [868.0, 95.0], [868.0, 259.0], [846.0, 259.0]]], "lines": ["先輩が言っていた", "彼女とはきっと", "愛子ちゃんのこと", "なのでしょう。"]}, {"box": [68, 453, 205, 637], "vertical": true, "font_size": 27, "lines_coords": [[[176.0, 454.0], [203.0, 454.0], [203.0, 637.0], [176.0, 637.0]], [[140.0, 454.0], [167.0, 454.0], [167.0, 587.0], [140.0, 587.0]], [[101.0, 453.0], [129.0, 453.0], [131.0, 612.0], [103.0, 612.0]], [[68.0, 454.0], [95.0, 454.0], [95.0, 568.0], [68.0, 568.0]]], "lines": ["それでもやはり", "プンプンは", "愛子ちゃんが", "好きです。"]}, {"box": [877, 773, 946, 964], "vertical": true, "font_size": 32, "lines_coords": [[[907.0, 773.0], [946.0, 773.0], [946.0, 864.0], [907.0, 864.0]], [[878.0, 778.0], [904.0, 778.0], [904.0, 920.0], [878.0, 920.0]]], "lines": ["そして", "プンプンは"]}, {"box": [167, 1328, 273, 1489], "vertical": true, "font_size": 29, "lines_coords": [[[240.0, 1329.0], [268.0, 1329.0], [271.0, 1462.0], [243.0, 1462.0]], [[209.0, 1331.0], [235.0, 1331.0], [235.0, 1489.0], [209.0, 1489.0]], [[167.0, 1328.0], [201.0, 1328.0], [201.0, 1425.0], [167.0, 1425.0]]], "lines": ["矢口先輩も", "ちょっと好き", "でした。"]}], "img_path": "066.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [833, 121, 934, 593], "vertical": true, "font_size": 89, "lines_coords": [[[845.0, 214.0], [934.0, 