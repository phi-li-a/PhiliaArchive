 [[140.0, 846.0], [167.0, 846.0], [167.0, 1004.0], [140.0, 1004.0]]], "lines": ["．．．いやいや、", "別に期待なんて", "してないさ．．"]}, {"box": [673, 1298, 812, 1456], "vertical": true, "font_size": 25, "lines_coords": [[[784.0, 1303.0], [810.0, 1303.0], [810.0, 1432.0], [784.0, 1432.0]], [[750.0, 1301.0], [771.0, 1301.0], [771.0, 1456.0], [750.0, 1456.0]], [[710.0, 1300.0], [737.0, 1300.0], [737.0, 1432.0], [710.0, 1432.0]], [[676.0, 1298.0], [703.0, 1298.0], [700.0, 1432.0], [673.0, 1432.0]]], "lines": ["いい年して", "そんなもんに", "乗せられて", "どうする？"]}, {"box": [575, 1118, 602, 1327], "vertical": true, "font_size": 26, "lines_coords": [[[575.0, 1118.0], [601.0, 1118.0], [601.0, 1325.0], [575.0, 1325.0]]], "lines": ["．．ただちょっと．．．"]}, {"box": [423, 1182, 487, 1365], "vertical": true, "font_size": 27, "lines_coords": [[[456.0, 1182.0], [482.0, 1182.0], [487.0, 1364.0], [460.0, 1364.0]], [[423.0, 1184.0], [450.0, 1184.0], [450.0, 1315.0], [423.0, 1315.0]]], "lines": ["．．．ただちょっと", "なんだよ？"]}], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [901, 73, 931, 218], "vertical": true, "font_size": 27, "lines_coords": [[[901.0, 73.0], [928.0, 73.0], [931.0, 218.0], [904.0, 218.0]]], "lines": ["．．．ただいま。"]}, {"box": [96, 65, 381, 92], "vertical": false, "font_size": 27, "lines_coords": [[[96.0, 65.0], [381.0, 65.0], [381.0, 92.0], [96.0, 92.0]]], "lines": ["おやすみプンプン回"]}, {"box": [829, 850, 939, 1075], "vertical": true, "font_size": 93, "lines_coords": [[[829.0, 856.0], [921.0, 850.0], [939.0, 1068.0], [846.0, 1075.0]]], "lines": ["脇毛．．．"]}, {"box": [156, 489, 845, 1481], "vertical": false, "font_size": 258.3333333333333, "lines_coords": [[[329.0, 489.0], [631.0, 489.0], [631.0, 726.0], [329.0, 726.0]], [[156.0, 800.0], [445.0, 734.0], [503.0, 989.0], [214.0, 1054.0]], [[567.0, 1198.0], [845.0, 1204.0], [839.0, 1481.0], [560.0, 1475.0]]], "lines": ["．．．", "あ、", "ドッ"]}, {"box": [270, 1235, 406, 1524], "vertical": true, "font_size": 136, "lines_coords": [[[270.0, 1235.0], [406.0, 1235.0], [406.0, 1485.0], [270.0, 1485.0]]], "lines": ["死ね！！"]}], "img_path": "130.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [885, 87, 984, 305], "vertical": true, "font_size": 27, "lines_coords": [[[956.0, 87.0], [982.0, 87.0], [982.0, 303.0], [956.0, 303.0]], [[921.0, 87.0], [948.0, 87.0], [948.0, 273.0], [921.0, 273.0]], [[885.0, 89.0], [912.0, 89.0], [912.0, 245.0], [885.0, 245.0]]], "lines": ["．．．ホラホラ姉さん、", "布団で寝ないと", "風邪ひくよ？"]}, {"box": [515, 65, 640, 246], "vertical": true, "font_size": 24, "lines_coords": [[[614.0, 67.0], [640.0, 67.0], [640.0, 210.0], [614.0, 210.0]], [[581.0, 67.0], [603.0, 67.0], [603.0, 215.0], [581.0, 215.0]], [[546.0, 65.0], [573.0, 65.0], [573.0, 246.0], [546.0, 246.0]], [[515.0, 67.0], [537.0, 67.0], [537.0, 232.0], [515.0, 232.0]]], "lines": ["．．．う、うん？", "なによアンタ", "なんでそんなに", "やさしいのよ．．"]}, {"box": [436, 581, 587, 750], "vertical": true, "font_size": 26, "lines_coords": [[[560.0, 582.0], [587.0, 582.0], [587.0, 704.0], [560.0, 704.0]], [[526.0, 581.0], [554.0, 581.0], [556.0, 750.0], [528.0, 750.0]], [[496.0, 582.0], [523.0, 582.0], [523.0, 750.0], [496.0, 750.0]], [[464.0, 585.0], [485.0, 585.0], [485.0, 726.0], [464.0, 726.0]]], "lines": ["．．．んん．．．．．", "そうかしら．．．", "うぅ．．．ん、そう", "いえばそうね"]}, {"box": [84, 306, 175, 503], "vertical": true, "font_size": 24, "lines_coords": [[[146.0, 306.0], [173.0, 306.0], [175.0, 484.0], [148.0, 484.0]], [[117.0, 309.0], [139.0, 309.0], [139.0, 487.0], [117.0, 487.0]], [[84.0, 309.0], [106.0, 309.0], [106.0, 498.0], [84.0, 498.0]]], "lines": ["何言ってんだい、", "僕ぁ、いつだって", "優しいじゃないか。"]}, {"box": [900, 1320, 943, 1442], "vertical": true, "font_size": 37, "lines_coords": [[[900.0, 1320.0], [943.0, 1320.0], [943.0, 1442.0], [900.0, 1442.0]]], "lines": ["プンプー"]}, {"box": [859, 1389, 893, 1482], "vertical": true, "font_size": 37, "lines_coords": [[[859.0, 1390.0], [890.0, 1389.0], [893.0, 1481.0], [862.0, 1482.0]]], "lines": ["ーン！！"]}, {"box": [153, 1370, 292, 1554], "vertical": true, "font_size": 26, "lines_coords": [[[262.0, 1371.0], [290.0, 1371.0], [290.0, 1503.0], [262.0, 1503.0]], [[226.0, 1370.0], [253.0, 1370.0], [250.0, 1554.0], [223.0, 1554.0]], [[189.0, 1371.0], [215.0, 1371.0], [215.0, 1528.0], [189.0, 1528.0]], [[154.0, 1375.0], [176.0, 1375.0], [176.0, 1492.0], [154.0, 1492.0]]], "lines": ["チョコパイ", "買ってきたから", "部屋に置いて", "おいたよー"]}], "img_path": "131.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [600, 3, 692, 334], "vertical": true, "font_size": 66, "lines_coords": [[[626.0, 3.0], [692.0, 7.0], [665.0, 334.0], [600.0, 329.0]]], "lines": ["明呪呪呪収呪哭哭"]}, {"box": [323, 178, 385, 312], "vertical": true, "font_size": 25, "lines_coords": [[[359.0, 179.0], [385.0, 179.0], [385.0, 312.0], [359.0, 312.0]], [[323.0, 178.0], [351.0, 178.0], [351.0, 256.0], [323.0, 256.0]]], "lines": ["明日も朝練", "だろー"]}, {"box": [328, 257, 345, 306], "vertical": true, "font_size": 25, "lines_coords": [[[328.0, 257.0], [345.0, 257.0], [345.0, 306.0], [328.0, 306.0]]], "lines": ["ー？"]}, {"box": [210, 345, 309, 556], "vertical": true, "font_size": 25, "lines_coords": [[[282.0, 346.0], [309.0, 346.0], [309.0, 531.0], [282.0, 531.0]], [[246.0, 346.0], [273.0, 346.0], [273.0, 542.0], [246.0, 542.0]], [[210.0, 345.0], [237.0, 345.0], [239.0, 556.0], [212.0, 556.0]]], "lines": ["早いとこ部屋に", "戻ってゆっくり", "寝たまえ、ははは。"]}, {"box": [861, 726, 998, 956], "vertical": true, "font_size": 27, "lines_coords": [[[970.0, 726.0], [996.0, 726.0], [996.0, 920.0], [970.0, 920.0]], [[932.0, 728.0], [959.0, 728.0], [959.0, 950.0], [932.0, 950.0]], [[896.0, 728.0], [923.0, 728.0], [923.0, 935.0], [896.0, 935.0]], [[862.0, 726.0], [889.0, 726.0], [889.0, 956.0], [862.0, 956.0]]], "lines": ["．．．気まぐれでも、", "たとえ、からかわれ", "てるのだとしても", "それは問題じゃない。"]}, {"box": [821, 1307, 924, 1465], "vertical": true, "font_size": 28, "lines_coords": [[[895.0, 1309.0], [923.0, 1309.0], [923.0, 1439.0], [895.0, 1439.0]], [[856.0, 1307.0], [884.0, 1307.0], [885.0, 1465.0], [857.0, 1465.0]], [[821.0, 1309.0], [848.0, 1309.0], [848.0, 1465.0], [821.0, 1465.0]]], "lines": ["僕は一人で", "生きてゆくと", "決めた男．．．．．．"]}, {"box": [556, 1381, 606, 1503], "vertical": true, "font_size": 47, "lines_coords": [[[556.0, 1382.0], [603.0, 1381.0], [606.0, 1501.0], [559.0, 1503.0]]], "lines": ["プイン"]}], "img_path": "132.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [270, 368, 320, 470], "vertical": true, "font_size": 26, "lines_coords": [[[298.0, 371.0], [320.0, 371.0], [320.0, 470.0], [298.0, 470.0]], [[270.0, 368.0], [300.0, 368.0], [300.0, 417.0], [270.0, 417.0]]], "lines": ["何を偉そう", "に．．．"]}, {"box": [225, 509, 282, 601], "vertical": true, "font_size": 26, "lines_coords": [[[256.0, 510.0], [282.0, 510.0], [282.0, 601.0], [256.0, 601.0]], [[225.0, 509.0], [251.0, 509.0], [251.0, 601.0], [225.0, 601.0]]], "lines": ["偽善者の", "くせに！！"]}, {"box": [671, 790, 696, 981], "vertical": true, "font_size": 22, "lines_coords": [[[671.0, 790.0], [693.0, 790.0], [693.0, 975.0], [671.0, 975.0]]], "lines": ["．．．こんな自分に"]}, {"box": [448, 789, 552, 931], "vertical": true, "font_size": 27, "lines_coords": [[[523.0, 790.0], [550.0, 790.0], [550.0, 893.0], [523.0, 893.0]], [[485.0, 789.0], [512.0, 789.0], [512.0, 921.0], [485.0, 921.0]], [[451.0, 789.0], [478.0, 789.0], [475.0, 926.0], [448.0, 926.0]]], "lines": ["恋愛する", "資格なんて", "ないんだよ。"]}, {"box": [896, 1154, 964, 1368], "vertical": true, "font_size": 28, "lines_coords": [[[932.0, 1154.0], [964.0, 1154.0], [964.0, 1368.0], [932.0, 1368.0]], [[896.0, 1154.0], [923.0, 1154.0], [923.0, 1314.0], [896.0, 1314.0]]], "lines": ["．．．あ、あのホント", "すみません！！"]}, {"box": [718, 1281, 854, 1440], "vertical": true, "font_size": 28, "lines_coords": [[[826.0, 1281.0], [854.0, 1281.0], [854.0, 1387.0], [826.0, 1387.0]], [[790.0, 1281.0], [817.0, 1281.0], [817.0, 1439.0], [790.0, 1439.0]], [[754.0, 1281.0], [781.0, 1281.0], [781.0, 1440.0], [754.0, 1440.0]], [[718.0, 1281.0], [745.0, 1281.0], [745.0, 1412.0], [718.0, 1412.0]]], "lines": ["自分から", "誘っておいて", "遅刻しちゃう", "なんて．．．"]}, {"box": [138, 1231, 275, 1475], "vertical": true, "font_size": 26, "lines_coords": [[[243.0, 1232.0], [271.0, 1232.0], [275.0, 1389.0], [246.0, 1389.0]], [[209.0, 1231.0], [237.0, 1231.0], [235.0, 1475.0], [207.0, 1475.0]], [[173.0, 1234.0], [200.0, 1234.0], [200.0, 1457.0], [173.0, 1457.0]], [[139.0, 1235.0], [160.0, 1235.0], [160.0, 1471.0], [139.0, 1471.0]]], "lines": ["なんか、あの、", "とってもベタなんです", "けど、ガスの元栓が", "気になっちゃって．．．"]}], "img_path": "133.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [785, 89, 906, 301], "vertical": true, "font_size": 23, "lines_coords": [[[884.0, 89.0], [906.0, 89.0], [906.0, 231.0], [884.0, 231.0]], [[853.0, 89.0], [875.0, 89.0], [875.0, 243.0], [853.0, 243.0]], [[820.0, 90.0], [842.0, 90.0], [842.0, 301.0], [820.0, 301.0]], [[785.0, 89.0], [812.0, 89.0], [812.0, 231.0], [785.0, 231.0]]], "lines": ["でもよくよく", "考えたら、先月", "電気コンロに換えた", "ばかりで．．．"]}, {"box": [646, 145, 735, 323], "vertical": true, "font_size": 23, "lines_coords": [[[709.0, 145.0], [735.0, 145.0], [735.0, 243.0], [709.0, 243.0]], [[679.0, 148.0], [701.0, 148.0], [701.0, 323.0], [679.0, 323.0]], [[646.0, 148.0], [668.0, 148.0], [668.0, 309.0], [646.0, 309.0]]], "lines": ["というか", "母親、仕事休みで", "家にいるし．．．"]}, {"box": [317, 90, 477, 304], "vertical": true, "font_size": 25, "lines_coords": [[[453.0, 93.0], [475.0, 93.0], [475.0, 259.0], [453.0, 259.0]], [[417.0, 92.0], [443.0, 92.0], [443.0, 304.0], [417.0, 304.0]], [[384.0, 90.0], [410.0, 90.0], [407.0, 257.0], [381.0, 257.0]], [[353.0, 90.0], [379.0, 90.0], [376.0, 259.0], [350.0, 259.0]], [[320.0, 90.0], [346.0, 90.0], [343.0, 254.0], [317.0, 254.0]]], "lines": ["．．．それで急いで", "引き返そうとしたら", "今度は自転車の", "チェーンが外れ", "ちゃって．．．．．．"]}, {"box": [175, 470, 278, 667], "vertical": true, "font_size": 27, "lines_coords": [[[246.0, 471.0], [275.0, 471.0], [276.0, 637.0], [248.0, 637.0]], [[214.0, 473.0], [240.0, 473.0], [240.0, 667.0], [214.0, 667.0]], [[175.0, 470.0], [201.0, 470.0], [204.0, 667.0], [178.0, 667.0]]], "lines": ["いやいやぃや、", "だから全然気に", "してないってば。"]}, {"box": [920, 750, 984, 906], "vertical": true, "font_size": 28, "lines_coords": [[[951.0, 750.0], [984.0, 750.0], [984.0, 859.0], [951.0, 859.0]], [[921.0, 753.0], [943.0, 753.0], [943.0, 904.0], [921.0, 904.0]]], "lines": ["てっ．．．", "てもあのっ！！"]}, {"box": [332, 906, 461, 1275], "vertical": true, "font_size": 25, "lines_coords": [[[429.0, 912.0], [451.0, 912.0], [451.0, 1035.0], [429.0, 1035.0]], [[404.0, 1090.0], [432.0, 1090.0], [432.0, 1196.0], [404.0, 1196.0]], [[371.0, 1092.0], [393.0, 1092.0], [393.0, 1268.0], [371.0, 1268.0]], [[334.0, 1085.0], [360.0, 1085.0], [359.0, 1273.0], [332.0, 1273.0]]], "lines": ["．．．え～～～．．", "大限様は", "明日１８時からの", "ご予約ですが："]}, {"box": [647, 1279, 785, 1423], "vertical": true, "font_size": 27, "lines_coords": [[[753.0, 1279.0], [785.0, 1279.0], [785.0, 1385.0], [753.0, 1385.0]], [[718.0, 1279.0], [746.0, 1279.0], [746.0, 1418.0], [718.0, 1418.0]], [[682.0, 1279.0], [709.0, 1279.0], [709.0, 1423.0], [682.0, 1423.0]], [[648.0, 1279.0], [670.0, 1279.0], [670.0, 1407.0], [648.0, 1407.0]]], "lines": ["ゴハンは", "がんばって、", "いい店予約", "したんて！！"]}], "img_path": "134.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [973, 115, 995, 207], "vertical": true, "font_size": 26, "lines_coords": [[[973.0, 115.0], [995.0, 115.0], [995.0, 207.0], [973.0, 207.0]]], "lines": ["うぅ．．．"]}, {"box": [806, 140, 932, 312], "vertical": true, "font_size": 26, "lines_coords": [[[906.0, 143.0], [932.0, 143.0], [932.0, 292.0], [906.0, 292.0]], [[873.0, 145.0], [900.0, 145.0], [900.0, 312.0], [873.0, 312.0]], [[840.0, 142.0], [867.0, 142.0], [864.0, 310.0], [837.0, 310.0]], [[809.0, 140.0], [835.0, 140.0], [832.0, 264.0], [806.0, 264.0]]], "lines": ["．．．すみません、", "全然こんなハズ", "じゃなかったん", "ですが．．．"]}, {"box": [661, 307, 751, 461], "vertical": true, "font_size": 25, "lines_coords": [[[723.0, 309.0], [751.0, 309.0], [751.0, 406.0], [723.0, 406.0]], [[695.0, 307.0], [720.0, 307.0], [717.0, 437.0], [692.0, 437.0]], [[662.0, 309.0], [684.0, 309.0], [684.0, 460.0], [662.0, 460.0]]], "lines": ["ここまで", "続けば、たい", "したもんだよ。"]}, {"box": [146, 192, 211, 351], "vertical": true, "font_size": 27, "lines_coords": [[[182.0, 193.0], [209.0, 193.0], [209.0, 350.0], [182.0, 350.0]], [[146.0, 192.0], [173.0, 192.0], [173.0, 351.0], [146.0, 351.0]]], "lines": ["あの．．．ホント", "すみません！！"]}, {"box": [109, 650, 211, 857], "vertical": true, "font_size": 26, "lines_coords": [[[184.0, 651.0], [206.0, 651.0], [206.0, 803.0], [184.0, 803.0]], [[146.0, 650.0], [173.0, 650.0], [173.0, 857.0], [146.0, 857.0]], [[109.0, 650.0], [137.0, 650.0], [139.0, 856.0], [110.0, 856.0]]], "lines": ["．．．別に適当に", "カラオケとかでも", "いいけどね、僕ァ。"]}, {"box": [912, 1014, 971, 1143], "vertical": true, "font_size": 25, "lines_coords": [[[943.0, 1014.0], [971.0, 1014.0], [971.0, 1132.0], [943.0, 1132.0]], [[912.0, 1014.0], [939.0, 1014.0], [939.0, 1143.0], [912.0, 1143.0]]], "lines": ["え～～と", "生中ふたつ。"]}, {"box": [200, 1045, 287, 1259], "vertical": true, "font_size": 23, "lines_coords": [[[265.0, 1048.0], [287.0, 1048.0], [287.0, 1206.0], [265.0, 1206.0]], [[229.0, 1045.0], [256.0, 1045.0], [256.0, 1259.0], [229.0, 1259.0]], [[200.0, 1048.0], [221.0, 1048.0], [221.0, 1223.0], [200.0, 1223.0]]], "lines": ["えっと、それと、", "トムヤムトーフって", "のをひとつ．．．"]}, {"box": [762, 1156, 887, 1323], "vertical": true, "font_size": 25, "lines_coords": [[[860.0, 1156.0], [887.0, 1156.0], [887.0, 1323.0], [860.0, 1323.0]], [[828.0, 1156.0], [854.0, 1156.0], [854.0, 1260.0], [828.0, 1260.0]], [[798.0, 1157.0], [820.0, 1157.0], [820.0, 1321.0], [798.0, 1321.0]], [[765.0, 1156.0], [787.0, 1156.0], [784.0, 1275.0], [762.0, 1275.0]]], "lines": ["オクラと豆腐の", "サラダと、", "鶏のナンコツの", "唐揚げ．．．"]}, {"box": [126, 1306, 246, 1545], "vertical": true, "font_size": 23, "lines_coords": [[[225.0, 1310.0], [246.0, 1310.0], [246.0, 1453.0], [225.0, 1453.0]], [[192.0, 1310.0], [214.0, 1310.0], [214.0, 1476.0], [192.0, 1476.0]], [[157.0, 1306.0], [184.0, 1306.0], [181.0, 1545.0], [154.0, 1545.0]], [[126.0, 1310.0], [148.0, 1310.0], [148.0, 1475.0], [126.0, 1475.0]]], "lines": ["あ、コレ、豆腐", "かぷるなぁ．．．．．．", "やっぱトムヤムクンで！", "クンにします！！"]}], "img_path": "135.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [934, 165, 1004, 589], "vertical": true, "font_size": 70, "lines_coords": [[[934.0, 165.0], [1004.0, 165.0], [1004.0, 589.0], [934.0, 589.0]]], "lines": ["シミします．．．："]}, {"box": [596, 131, 621, 260], "vertical": true, "font_size": 24, "lines_coords": [[[598.0, 184.0], [621.0, 184.0], [621.0, 260.0], [598.0, 260.0]], [[596.0, 131.0], [620.0, 131.0], [620.0, 189.0], [596.0, 189.0]]], "lines": ["ーっ．．．", "ふー"]}, {"box": [456, 220, 542, 412], "vertical": true, "font_size": 24, "lines_coords": [[[520.0, 220.0], [542.0, 220.0], [542.0, 410.0], [520.0, 410.0]], [[487.0, 220.0], [514.0, 220.0], [514.0, 412.0], [487.0, 412.0]], [[456.0, 223.0], [478.0, 223.0], [478.0, 365.0], [456.0, 365.0]]], "lines": ["なんか出たしから", "ドタバタしちゃい", "ましたね．．．"]}, {"box": [89, 70, 371, 92], "vertical": false, "font_size": 22, "lines_coords": [[[89.0, 70.0], [371.0, 70.0], [371.0, 92.0], [89.0, 92.0]]], "lines": ["おやすみプンプン［３"]}, {"box": [932, 768, 973, 821], "vertical": true, "font_size": 41, "lines_coords": [[[940.0, 768.0], [973.0, 773.0], [965.0, 821.0], [932.0, 817.0]]], "lines": ["あー"]}, {"box": [723, 521, 825, 678], "vertical": true, "font_size": 29, "lines_coords": [[[792.0, 523.0], [825.0, 523.0], [825.0, 631.0], [792.0, 631.0]], [[759.0, 523.0], [785.0, 523.0], [785.0, 678.0], [759.0, 678.0]], [[723.0, 521.0], [750.0, 521.0], [750.0, 628.0], [723.0, 628.0]]], "lines": ["．．．ハイ！", "以上でお願い", "します！！"]}, {"box": [218, 481, 318, 664], "vertical": true, "font_size": 28, "lines_coords": [[[292.0, 481.0], [318.0, 481.0], [318.0, 615.0], [292.0, 615.0]], [[254.0, 481.0], [281.0, 481.0], [281.0, 664.0], [254.0, 664.0]], [[218.0, 484.0], [245.0, 484.0], [245.0, 615.0], [218.0, 615.0]]], "lines": ["とりあえず", "忘れないうちに", "コレを．．．"]}, {"box": [89, 545, 192, 729], "vertical": true, "font_size": 28, "lines_coords": [[[162.0, 545.0], [189.0, 545.0], [192.0, 729.0], [165.0, 729.0]], [[126.0, 545.0], [153.0, 545.0], [153.0, 678.0], [126.0, 678.0]], [[89.0, 545.0], [121.0, 545.0], [121.0, 639.0], [89.0, 639.0]]], "lines": ["濡らしちゃって", "すみません", "でした。"]}, {"box": [853, 893, 901, 971], "vertical": true, "font_size": 41, "lines_coords": [[[853.0, 893.0], [901.0, 893.0], [901.0, 971.0], [853.0, 971.0]]], "lines": ["成程。"]}, {"box": [528, 1109, 596, 1265], "vertical": true, "font_size": 29, "lines_coords": [[[559.0, 1109.0], [596.0, 1109.0], [596.0, 1245.0], [559.0, 1245.0]], [[528.0, 1110.0], [557.0, 1110.0], [557.0, 1265.0], [528.0, 1265.0]]], "lines": ["いや、そう", "いう訳じゃ．．．"]}, {"box": [121, 835, 189, 1018], "vertical": true, "font_size": 27, "lines_coords": [[[157.0, 835.0], [189.0, 835.0], [189.0, 993.0], [157.0, 993.0]], [[125.0, 835.0], [151.0, 835.0], [148.0, 964.0], [121.0, 964.0]], [[126.0, 956.0], [148.0, 956.0], [148.0, 1017.0], [126.0, 1017.0]]], "lines": ["オマータセ", "シマシター", "！！"]}, {"box": [867, 1082, 996, 1318], "vertical": true, "font_size": 25, "lines_coords": [[[975.0, 1082.0], [996.0, 1082.0], [996.0, 1317.0], [975.0, 1317.0]], [[937.0, 1082.0], [964.0, 1082.0], [964.0, 1318.0], [937.0, 1318.0]], [[903.0, 1084.0], [925.0, 1084.0], [925.0, 1304.0], [903.0, 1304.0]], [[867.0, 1084.0], [889.0, 1084.0], [889.0, 1307.0], [867.0, 1307.0]]], "lines": ["よくこんなオッサン", "食事に誘うな～～と", "思ってたけど、コレを", "渡すためだったのか。"]}, {"box": [823, 1339, 889, 1510], "vertical": true, "font_size": 25, "lines_coords": [[[859.0, 1339.0], [887.0, 1339.0], [889.0, 1510.0], [860.0, 1510.0]], [[823.0, 1340.0], [850.0, 1340.0], [853.0, 1460.0], [826.0, 1460.0]]], "lines": ["君はアレだね。", "律義だね。"]}, {"box": [473, 1326, 575, 1485], "vertical": true, "font_size": 29, "lines_coords": [[[548.0, 1326.0], [575.0, 1326.0], [575.0, 1485.0], [548.0, 1485.0]], [[512.0, 1326.0], [539.0, 1326.0], [539.0, 1485.0], [512.0, 1485.0]], [[476.0, 1326.0], [503.0, 1326.0], [500.0, 1482.0], [473.0, 1482.0]]], "lines": ["そういう訳も", "ありますけど", "なんていうか"]}], "img_path": "136.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [159, 109, 289, 334], "vertical": true, "font_size": 35, "lines_coords": [[[243.0, 109.0], [285.0, 109.0], [285.0, 320.0], [243.0, 320.0]], [[203.0, 110.0], [235.0, 110.0], [235.0, 332.0], [203.0, 332.0]], [[160.0, 110.0], [192.0, 110.0], [192.0, 285.0], [160.0, 285.0]]], "lines": ["大隈翠２５歳、", "市内出身で現在", "実家暮らし。"]}, {"box": [758, 595, 980, 798], "vertical": true, "font_size": 28, "lines_coords": [[[950.0, 603.0], [976.0, 603.0], [976.0, 753.0], [950.0, 753.0]], [[910.0, 600.0], [942.0, 600.0], [942.0, 785.0], [910.0, 785.0]], [[876.0, 600.0], [903.0, 600.0], [903.0, 798.0], [876.0, 798.0]]], "lines": ["看護学校を", "卒業後、市内の", "第二病院に就職。"]}, {"box": [243, 600, 382, 845], "vertical": true, "font_size": 29, "lines_coords": [[[351.0, 603.0], [378.0, 603.0], [378.0, 812.0], [351.0, 812.0]], [[312.0, 600.0], [343.0, 600.0], [343.0, 840.0], [312.0, 840.0]], [[276.0, 600.0], [307.0, 600.0], [307.0, 789.0], [276.0, 789.0]], [[243.0, 601.0], [270.0, 601.0], [270.0, 756.0], [243.0, 756.0]]], "lines": ["姉が入院した際に", "担当の看護師だった", "ため、僕もよく", "憶えている。"]}, {"box": [135, 598, 206, 881], "vertical": true, "font_size": 29, "lines_coords": [[[175.0, 601.0], [201.0, 601.0], [201.0, 864.0], [175.0, 864.0]], [[135.0, 598.0], [167.0, 598.0], [168.0, 865.0], [137.0, 865.0]]], "lines": ["退院祝いに幸福の木を", "贈ってくれた子だ。"]}, {"box": [870, 1230, 939, 1475], "vertical": true, "font_size": 27, "lines_coords": [[[907.0, 1235.0], [934.0, 1235.0], [934.0, 1471.0], [907.0, 1471.0]], [[871.0, 1234.0], [898.0, 1234.0], [898.0, 1414.0], [871.0, 1414.0]]], "lines": ["：多少ドジな部分も", "あるようだが、"]}, {"box": [334, 1236, 437, 1453], "vertical": true, "font_size": 28, "lines_coords": [[[407.0, 1237.0], [434.0, 1237.0], [434.0, 1429.0], [407.0, 1429.0]], [[370.0, 1237.0], [398.0, 1237.0], [396.0, 1453.0], [368.0, 1453.0]], [[334.0, 1237.0], [362.0, 1237.0], [362.0, 1353.0], [334.0, 1353.0]]], "lines": ["姉が当時、よく", "なついていたのを", "見る限り、"]}, {"box": [141, 1235, 244, 1445], "vertical": true, "font_size": 23, "lines_coords": [[[214.0, 1237.0], [240.0, 1237.0], [240.0, 1445.0], [214.0, 1445.0]], [[179.0, 1239.0], [201.0, 1239.0], [201.0, 1392.0], [179.0, 1392.0]], [[143.0, 1237.0], [165.0, 1237.0], [165.0, 1434.0], [143.0, 1434.0]]], "lines": ["基本的には優しく", "面倒見の良い", "性格なのだろう。"]}], "img_path": "137.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [860, 30, 962, 281], "vertical": true, "font_size": 29, "lines_coords": [[[931.0, 40.0], [957.0, 40.0], [957.0, 168.0], [931.0, 168.0]], [[893.0, 40.0], [925.0, 40.0], [925.0, 278.0], [893.0, 278.0]], [[860.0, 37.0], [889.0, 37.0], [890.0, 165.0], [862.0, 165.0]]], "lines": ["労働条件の", "厳しさ等の理由から", "昨年退職。"]}, {"box": [296, 38, 402, 316], "vertical": true, "font_size": 29, "lines_coords": [[[370.0, 42.0], [396.0, 42.0], [396.0, 290.0], [370.0, 290.0]], [[331.0, 39.0], [364.0, 39.0], [364.0, 315.0], [331.0, 315.0]], [[296.0, 39.0], [323.0, 39.0], [323.0, 259.0], [296.0, 259.0]]], "lines": ["高校時代、夢見ていた", "喫茶店経営を思い出し、", "バイトを始めるが、"]}, {"box": [142, 35, 251, 260], "vertical": true, "font_size": 29, "lines_coords": [[[220.0, 39.0], [246.0, 39.0], [245.0, 251.0], [218.0, 251.0]], [[184.0, 39.0], [210.0, 39.0], [210.0, 260.0], [184.0, 260.0]], [[142.0, 37.0], [175.0, 35.0], [178.0, 129.0], [145.0, 131.0]]], "lines": ["漠然とした将来に", "不安を感じている", "ようだ。"]}, {"box": [815, 527, 920, 690], "vertical": true, "font_size": 31, "lines_coords": [[[889.0, 531.0], [917.0, 531.0], [917.0, 642.0], [889.0, 642.0]], [[850.0, 531.0], [882.0, 531.0], [885.0, 690.0], [853.0, 690.0]], [[815.0, 531.0], [848.0, 531.0], [848.0, 632.0], [815.0, 632.0]]], "lines": ["．．．非常に", "二十代的では", "あるが、"]}, {"box": [168, 521, 272, 717], "vertical": true, "font_size": 29, "lines_coords": [[[239.0, 521.0], [270.0, 521.0], [270.0, 717.0], [239.0, 717.0]], [[204.0, 529.0], [232.0, 529.0], [232.0, 665.0], [204.0, 665.0]], [[168.0, 529.0], [195.0, 529.0], [195.0, 676.0], [168.0, 676.0]]], "lines": ["．．．非常に素直な", "良い子では", "あると思う。"]}, {"box": [148, 851, 204, 1025], "vertical": true, "font_size": 52, "lines_coords": [[[148.0, 853.0], [200.0, 851.0], [204.0, 1023.0], [153.0, 1025.0]]], "lines": ["．．．笑顔。"]}, {"box": [554, 1259, 979, 1456], "vertical": false, "font_size": 183, "lines_coords": [[[560.0, 1259.0], [979.0, 1273.0], [973.0, 1456.0], [554.0, 1442.0]]], "lines": ["チャッ"]}, {"box": [104, 1285, 337, 1559], "vertical": true, "font_size": 75, "lines_coords": [[[259.0, 1290.0], [337.0, 1290.0], [337.0, 1417.0], [259.0, 1417.0]], [[176.0, 1285.0], [256.0, 1285.0], [256.0, 1490.0], [176.0, 1490.0]], [[104.0, 1287.0], [171.0, 1287.0], [171.0, 1521.0], [104.0, 1521.0]]], "lines": ["何が", "目的だ、", "貴様ァッ！！"]}], "img_path": "138.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [867, 84, 999, 516], "vertical": true, "font_size": 24, "lines_coords": [[[970.0, 84.0], [996.0, 84.0], [996.0, 184.0], [970.0, 184.0]], [[965.0, 289.0], [992.0, 289.0], [989.0, 504.0], [962.0, 504.0]], [[934.0, 292.0], [956.0, 292.0], [956.0, 457.0], [934.0, 457.0]], [[901.0, 292.0], [923.0, 292.0], [923.0, 515.0], [901.0, 515.0]], [[867.0, 290.0], [889.0, 290.0], [889.0, 456.0], [867.0, 456.0]]], "lines": ["あのォー", "さっきから私ばかり", "歌ってますけど", "小野寺さん、カラオケ", "苦手でしたか？"]}, {"box": [540, 759, 961, 840], "vertical": false, "font_size": 70, "lines_coords": [[[540.0, 770.0], [959.0, 759.0], [960.0, 829.0], [542.0, 840.0]]], "lines": ["予約受け付けました"]}, {"box": [145, 512, 213, 646], "vertical": true, "font_size": 28, "lines_coords": [[[185.0, 515.0], [212.0, 515.0], [212.0, 646.0], [185.0, 646.0]], [[148.0, 512.0], [176.0, 512.0], [173.0, 643.0], [145.0, 643.0]]], "lines": ["おっとっと", "失礼失礼。"]}, {"box": [920, 940, 1024, 1140], "vertical": true, "font_size": 28, "lines_coords": [[[995.0, 942.0], [1021.0, 942.0], [1021.0, 1110.0], [995.0, 1110.0]], [[959.0, 945.0], [985.0, 945.0], [985.0, 1103.0], [959.0, 1103.0]], [[920.0, 940.0], [951.0, 940.0], [954.0, 1140.0], [923.0, 1140.0]]], "lines": ["．．．でもなんか、", "小野寺さんて", "優しいですよね。"]}, {"box": [531, 973, 626, 1157], "vertical": true, "font_size": 27, "lines_coords": [[[600.0, 973.0], [626.0, 973.0], [625.0, 1156.0], [598.0, 1156.0]], [[565.0, 976.0], [592.0, 976.0], [592.0, 1157.0], [565.0, 1157.0]], [[531.0, 975.0], [557.0, 975.0], [559.0, 1153.0], [532.0, 1153.0]]], "lines": ["ま、二年もいれば", "情も湧くし、家族", "みたいなもんさ。"]}, {"box": [185, 773, 421, 837], "vertical": false, "font_size": 59, "lines_coords": [[[185.0, 778.0], [420.0, 773.0], [421.0, 832.0], [187.0, 837.0]]], "lines": ["．．．"]}, {"box": [110, 1031, 235, 1244], "vertical": true, "font_size": 24, "lines_coords": [[[206.0, 1031.0], [232.0, 1031.0], [234.0, 1200.0], [207.0, 1200.0]], [[171.0, 1031.0], [198.0, 1031.0], [201.0, 1179.0], [175.0, 1179.0]], [[143.0, 1032.0], [165.0, 1032.0], [165.0, 1243.0], [143.0, 1243.0]], [[110.0, 1031.0], [131.0, 1031.0], [131.0, 1195.0], [110.0, 1195.0]]], "lines": ["偉いなぁー．．．", "あたしも早く", "ちゃんとした大人に", "ならなきゃ．．．"]}, {"box": [648, 1328, 785, 1484], "vertical": true, "font_size": 27, "lines_coords": [[[757.0, 1329.0], [784.0, 1329.0], [784.0, 1462.0], [757.0, 1462.0]], [[721.0, 1331.0], [748.0, 1331.0], [748.0, 1484.0], [721.0, 1484.0]], [[682.0, 1328.0], [709.0, 1328.0], [712.0, 1462.0], [685.0, 1462.0]], [[648.0, 1329.0], [676.0, 1329.0], [676.0, 1421.0], [648.0, 1421.0]]], "lines": ["お姉さんと", "甥っ子さんの", "面倒みてる", "なんて。"]}, {"box": [109, 1342, 213, 1512], "vertical": true, "font_size": 28, "lines_coords": [[[181.0, 1342.0], [209.0, 1342.0], [210.0, 1510.0], [182.0, 1510.0]], [[146.0, 1343.0], [175.0, 1343.0], [175.0, 1489.0], [146.0, 1489.0]], [[109.0, 1343.0], [135.0, 1343.0], [135.0, 1512.0], [109.0, 1512.0]]], "lines": ["君なら大丈夫。", "夢もきっと", "叶うと思うし。"]}], "img_path": "139.png"}, {"version": "0.2.0-b