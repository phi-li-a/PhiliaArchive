.0, 803.0], [882.0, 803.0]]], "lines": ["．．．見ての通り", "今作ってるところ", "ですが。"]}, {"box": [296, 734, 328, 892], "vertical": true, "font_size": 28, "lines_coords": [[[296.0, 734.0], [328.0, 734.0], [328.0, 892.0], [296.0, 892.0]]], "lines": ["プンプンはァ"]}, {"box": [134, 909, 270, 1096], "vertical": true, "font_size": 26, "lines_coords": [[[240.0, 910.0], [268.0, 910.0], [268.0, 1018.0], [240.0, 1018.0]], [[203.0, 909.0], [235.0, 909.0], [232.0, 1096.0], [200.0, 1096.0]], [[170.0, 914.0], [192.0, 914.0], [192.0, 1093.0], [170.0, 1093.0]], [[134.0, 912.0], [156.0, 912.0], [156.0, 1051.0], [134.0, 1051.0]]], "lines": ["学校から", "帰って来てから", "部屋にこもった", "きりだけど。"]}, {"box": [926, 1185, 990, 1318], "vertical": true, "font_size": 26, "lines_coords": [[[964.0, 1185.0], [990.0, 1185.0], [990.0, 1293.0], [964.0, 1293.0]], [[926.0, 1187.0], [953.0, 1187.0], [953.0, 1318.0], [926.0, 1318.0]]], "lines": ["っったぁー", "あの子は！！"]}, {"box": [882, 1370, 901, 1396], "vertical": true, "font_size": 26, "lines_coords": [[[882.0, 1370.0], [901.0, 1370.0], [901.0, 1396.0], [882.0, 1396.0]]], "lines": ["．．．"]}, {"box": [768, 1226, 906, 1434], "vertical": true, "font_size": 26, "lines_coords": [[[879.0, 1226.0], [906.0, 1226.0], [906.0, 1368.0], [879.0, 1368.0]], [[842.0, 1226.0], [868.0, 1226.0], [868.0, 1418.0], [842.0, 1418.0]], [[803.0, 1226.0], [829.0, 1226.0], [829.0, 1434.0], [803.0, 1434.0]], [[768.0, 1229.0], [796.0, 1229.0], [796.0, 1331.0], [768.0, 1331.0]]], "lines": ["なんで、あー", "陰気なのかなァ、", "こっちまで滅入る", "っての！！"]}, {"box": [103, 1314, 240, 1475], "vertical": true, "font_size": 30, "lines_coords": [[[176.0, 1315.0], [207.0, 1315.0], [207.0, 1475.0], [176.0, 1475.0]], [[142.0, 1315.0], [168.0, 1315.0], [168.0, 1471.0], [142.0, 1471.0]], [[103.0, 1314.0], [137.0, 1314.0], [137.0, 1398.0], [103.0, 1398.0]]], "lines": ["姉さん、また", "呑んできたの", "かい？"]}], "img_path": "026.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [187, 812, 257, 923], "vertical": true, "font_size":