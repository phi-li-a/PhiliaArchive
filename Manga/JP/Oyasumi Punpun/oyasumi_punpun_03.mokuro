, [785.0, 650.0], [759.0, 650.0]], [[721.0, 517.0], [748.0, 517.0], [748.0, 675.0], [721.0, 675.0]], [[685.0, 517.0], [712.0, 517.0], [712.0, 659.0], [685.0, 659.0]]], "lines": ["結局、人なんて", "自分の力で", "生きてくしか", "ないんだよ。"]}, {"box": [929, 870, 961, 1003], "vertical": true, "font_size": 28, "lines_coords": [[[932.0, 870.0], [960.0, 870.0], [957.0, 1003.0], [929.0, 1003.0]]], "lines": ["．．．お前が．．．"]}, {"box": [232, 921, 310, 1093], "vertical": true, "font_size": 32, "lines_coords": [[[278.0, 925.0], [309.0, 925.0], [309.0, 1082.0], [278.0, 1082.0]], [[232.0, 921.0], [264.0, 921.0], [264.0, 1092.0], [232.0, 1092.0]]], "lines": ["お前が俺を", "信じるなら、"]}, {"box": [134, 1296, 257, 1490], "vertical": true, "font_size": 33, "lines_coords": [[[223.0, 1300.0], [254.0, 1300.0], [254.0, 1459.0], [223.0, 1459.0]], [[176.0, 1296.0], [214.0, 1296.0], [210.0, 1490.0], [173.0, 1490.0]], [[134.0, 1300.0], [165.0, 1300.0], [165.0, 1457.0], [134.0, 1457.0]]], "lines": ["俺がお前を", "絶対に守って", "やるから！！"]}], "img_path": "020.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [170, 320, 271, 506], "vertical": true, "font_size": 28, "lines_coords": [[[242.0, 323.0], [270.0, 323.0], [270.0, 454.0], [242.0, 454.0]], [[204.0, 323.0], [235.0, 323.0], [235.0, 506.0], [204.0, 506.0]], [[170.0, 320.0], [196.0, 320.0], [196.0, 451.0], [170.0, 451.0]]], "lines": ["．．．もう俺を", "一人にしないで", "くれよ．．．"]}, {"box": [829, 1140, 855, 1275], "vertical": true, "font_size": 22, "lines_coords": [[[829.0, 1168.0], [851.0, 1168.0], [851.0, 1273.0], [829.0, 1273.0]]], "lines": ["．．．うん！！"]}], "img_path": "021.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [40, 294, 85, 459], "vertical": true, "font_size": 44, "lines_coords": [[[40.0, 298.0], [84.0, 298.0], [84.0, 459.0], [40.0, 459.0]]], "lines": ["第２５話"]}, {"box": [30, 651, 70, 741], "vertical": true, "font_size": 40, "lines_coords": [[[30.0, 651.0], [70.0, 651.0], [70.0, 741.0], [30.0, 741.0]]], "