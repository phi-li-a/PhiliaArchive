0, 1270.0], [500.0, 1270.0], [500.0, 1401.0], [471.0, 1401.0]], [[434.0, 1268.0], [462.0, 1268.0], [462.0, 1378.0], [434.0, 1378.0]]], "lines": ["「．．．愛子ちゃんを", "守れるのは", "僕です。」"]}, {"box": [125, 1426, 154, 1520], "vertical": true, "font_size": 28, "lines_coords": [[[125.0, 1426.0], [153.0, 1426.0], [153.0, 1520.0], [125.0, 1520.0]]], "lines": ["．．．俺だ"]}], "img_path": "111.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "112.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [561, 221, 769, 246], "vertical": false, "font_size": 18, "lines_coords": [[[567.0, 224.0], [759.0, 224.0], [759.0, 244.0], [567.0, 244.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＸＹＣＯＭＣＳ"]}, {"box": [776, 120, 893, 943], "vertical": true, "font_size": 117, "lines_coords": [[[776.0, 120.0], [893.0, 120.0], [893.0, 943.0], [776.0, 943.0]]], "lines": ["おやすみプンプン＠"]}, {"box": [814, 869, 850, 918], "vertical": true, "font_size": 36, "lines_coords": [[[814.0, 869.0], [850.0, 869.0], [850.0, 918.0], [814.0, 918.0]]], "lines": ["３"]}, {"box": [773, 1039, 876, 1432], "vertical": true, "font_size": 60, "lines_coords": [[[831.0, 1048.0], [864.0, 1048.0], [864.0, 1201.0], [831.0, 1201.0]], [[773.0, 1043.0], [859.0, 1039.0], [876.0, 1428.0], [790.0, 1432.0]]], "lines": ["もっと", "浅野いにお"]}], "img_path": "113.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "114.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "115.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [910, 1164, 1009, 1370], "vertical": true, "font_size": 26, "lines_coords": [[[982.0, 1165.0], [1009.0, 1165.0], [1009.0, 1348.0], [982.0, 1348.0]], [[946.0, 1165.0], [968.0, 1165.0], [968.0, 1370.0], [946.0, 1370.0]], [[910.0, 1164.0], [937.0, 1164.0], [937.0, 1306.0], [910.0, 1306.0]]], "lines": ["．．．なんか彼女が", "生理が来ないとか", "言い出して、"]}, {"box": [740, 1285, 898, 1526], "vertical": true, "font_size": 26, "lines_coords": [[[871.0, 1285.0], [898.0, 1285.0], [896.0, 1512.0], [870.0, 1512.0]], [[837.0, 1290.0], [864.0, 1290.0], [864.0, 1506.0], [837.0, 1506.0]], [[801.0, 1289.0], [832.0, 1289.0], [832.0, 1526.0], [801.0, 1526.0]], [[771.0, 1290.0], [798.0, 1290.0], [798.0, 1526.0], [771.0, 1526.0]], [[740.0, 1292.0], [762.0, 1292.0], [762.0, 1510.0], [740.0, 1510.0]]], "lines": ["まぁ、ゴム付けない", "俺も俺なんスけど、", "ナマじゃないとイケ", "ないって言い出した", "のは彼女なんスよ。"]}, {"box": [253, 1201, 434, 1476], "vertical": true, "font_size": 25, "lines_coords": [[[407.0, 1204.0], [434.0, 1204.0], [434.0, 1453.0], [407.0, 1453.0]], [[378.0, 1203.0], [404.0, 1203.0], [404.0, 1454.0], [378.0, 1454.0]], [[348.0, 1201.0], [375.0, 1201.0], [375.0, 1415.0], [348.0, 1415.0]], [[320.0, 1204.0], [342.0, 1204.0], [342.0, 1476.0], [320.0, 1476.0]], [[290.0, 1204.0], [312.0, 1204.0], [312.0, 1439.0], [290.0, 1439.0]], [[253.0, 1203.0], [284.0, 1203.0], [284.0, 1398.0], [253.0, 1398.0]]], "lines": ["んで、検査も何もまだ", "してないのに、産むと", "したらどうする？", "とか聞くんで、僕はまぁ", "実際困るって答える", "訳じゃないスか。"]}, {"box": [70, 1303, 243, 1567], "vertical": true, "font_size": 25, "lines_coords": [[[215.0, 1303.0], [240.0, 1303.0], [243.0, 1517.0], [218.0, 1517.0]], [[187.0, 1304.0], [214.0, 1304.0], [214.0, 1567.0], [187.0, 1567.0]], [[159.0, 1306.0], [181.0, 1306.0], [181.0, 1567.0], [159.0, 1567.0]], [[128.0, 1306.0], [150.0, 1306.0], [150.0, 1514.0], [128.0, 1514.0]], [[96.0, 1303.0], [123.0, 1303.0], [123.0, 1514.0], [96.0, 1514.0]], [[70.0, 1306.0], [92.0, 1306.0], [92.0, 1493.0], [70.0, 1493.0]]], "lines": ["そしたら超～～～", "機嫌悪くなっちゃって", "なんで女ってのはこう", "自分勝手なのかな", "〜〜って正直呆れ", "ちゃいましたね。"]}], "img_path": "116.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [906, 120, 1031, 345], "vertical": true, "font_size": 26, "lines_coords": [[[1001.0, 121.0], [1028.0, 121.0], [1031.0, 292.0], [1004.0, 292.0]], [[970.0, 120.0], [996.0, 120.0], [996.0, 345.0], [970.0, 345.0]], [[937.0, 121.0], [964.0, 121.0], [964.0, 306.0], [937.0, 306.0]], [[906.0, 129.0], [932.0, 129.0], [932.0, 293.0], [906.0, 293.0]]], "lines": ["．．．以上が、僕が", "きのう、布団の中で", "していた妄想の", "一部始終です。"]}, {"box": [823, 360, 928, 523], "vertical": true, "font_size": 26, "lines_coords": [[[900.0, 360.0], [928.0, 360.0], [925.0, 523.0], [896.0, 523.0]], [[865.0, 367.0], [887.0, 367.0], [887.0, 521.0], [865.0, 521.0]], [[823.0, 360.0], [850.0, 360.0], [853.0, 521.0], [826.0, 521.0]]], "lines": ["．．．どうしたら", "僕、彼女でき", "るんスかね？"]}, {"box": [187, 404, 253, 574], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 407.0], [251.0, 407.0], [251.0, 539.0], [225.0, 539.0]], [[187.0, 404.0], [214.0, 404.0], [215.0, 573.0], [189.0, 573.0]]], "lines": ["．．．君は十分", "たくましいよ。"]}, {"box": [821, 732, 960, 970], "vertical": true, "font_size": 26, "lines_coords": [[[932.0, 732.0], [959.0, 732.0], [957.0, 956.0], [931.0, 956.0]], [[895.0, 734.0], [921.0, 734.0], [921.0, 970.0], [895.0, 970.0]], [[856.0, 734.0], [882.0, 734.0], [882.0, 920.0], [856.0, 920.0]], [[821.0, 734.0], [848.0, 734.0], [848.0, 928.0], [821.0, 928.0]]], "lines": ["．．．ま、恋愛なんて", "孤独っていう恐怖を", "やわらげる麻薬", "みたいなもので、"]}, {"box": [960, 1070, 1028, 1239], "vertical": true, "font_size": 30, "lines_coords": [[[995.0, 1070.0], [1028.0, 1070.0], [1028.0, 1153.0], [995.0, 1153.0]], [[960.0, 1071.0], [987.0, 1071.0], [987.0, 1239.0], [960.0, 1239.0]]], "lines": ["．．．．．．", "小野寺さんて、"]}, {"box": [181, 776, 320, 1023], "vertical": true, "font_size": 26, "lines_coords": [[[290.0, 778.0], [317.0, 778.0], [317.0, 987.0], [290.0, 987.0]], [[264.0, 778.0], [290.0, 778.0], [290.0, 937.0], [264.0, 937.0]], [[232.0, 776.0], [260.0, 776.0], [262.0, 1023.0], [234.0, 1023.0]], [[206.0, 779.0], [232.0, 779.0], [232.0, 1021.0], [206.0, 1021.0]], [[181.0, 779.0], [203.0, 779.0], [203.0, 1004.0], [181.0, 1004.0]]], "lines": ["醒めた時に広がる", "更なる恐怖を", "味わいたくないなら、", "一人でいるのも決して", "間違いじゃないけど。"]}, {"box": [714, 1425, 775, 1579], "vertical": true, "font_size": 24, "lines_coords": [[[748.0, 1426.0], [775.0, 1426.0], [775.0, 1553.0], [748.0, 1553.0]], [[715.0, 1425.0], [737.0, 1425.0], [737.0, 1579.0], [715.0, 1579.0]]], "lines": ["いまいくつ", "でしたっけ？"]}, {"box": [435, 1412, 464, 1556], "vertical": true, "font_size": 27, "lines_coords": [[[435.0, 1412.0], [462.0, 1412.0], [462.0, 1556.0], [435.0, 1556.0]]], "lines": ["３３歳でちゅ。"]}, {"box": [93, 1373, 196, 1557], "vertical": true, "font_size": 30, "lines_coords": [[[168.0, 1375.0], [195.0, 1375.0], [195.0, 1510.0], [168.0, 1510.0]], [[128.0, 1373.0], [160.0, 1373.0], [160.0, 1482.0], [128.0, 1482.0]], [[93.0, 1373.0], [125.0, 1373.0], [125.0, 1557.0], [93.0, 1557.0]]], "lines": ["小野寺さん、", "生きてて", "楽しいっスか？"]}], "img_path": "117.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [901, 65, 965, 276], "vertical": true, "font_size": 26, "lines_coords": [[[939.0, 67.0], [965.0, 67.0], [965.0, 201.0], [939.0, 201.0]], [[901.0, 65.0], [928.0, 65.0], [929.0, 276.0], [903.0, 276.0]]], "lines": ["まぁ～～～", "なんつーかねぇ．．．"]}, {"box": [482, 160, 585, 396], "vertical": true, "font_size": 28, "lines_coords": [[[554.0, 160.0], [585.0, 160.0], [585.0, 348.0], [554.0, 348.0]], [[520.0, 162.0], [546.0, 162.0], [546.0, 396.0], [520.0, 396.0]], [[482.0, 160.0], [509.0, 160.0], [512.0, 375.0], [485.0, 375.0]]], "lines": ["もう楽しいとか", "楽しくないとかじゃ", "ないんだよねぇ．．．"]}, {"box": [84, 56, 375, 82], "vertical": false, "font_size": 26, "lines_coords": [[[84.0, 56.0], [375.0, 56.0], [375.0, 82.0], [84.0, 82.0]]], "lines": ["おやすみプンプン国"]}, {"box": [956, 459, 990, 532], "vertical": true, "font_size": 31, "lines_coords": [[[956.0, 459.0], [990.0, 459.0], [990.0, 532.0], [956.0, 532.0]]], "lines": ["へぇー"]}, {"box": [807, 501, 912, 684], "vertical": true, "font_size": 31, "lines_coords": [[[881.0, 501.0], [909.0, 501.0], [912.0, 635.0], [884.0, 635.0]], [[846.0, 503.0], [873.0, 503.0], [876.0, 684.0], [850.0, 684.0]], [[807.0, 503.0], [843.0, 503.0], [843.0, 571.0], [807.0, 571.0]]], "lines": ["なんかそれ", "超かっこいいっ", "スね。"]}, {"box": [421, 520, 550, 719], "vertical": true, "font_size": 27, "lines_coords": [[[517.0, 520.0], [550.0, 520.0], [550.0, 606.0], [517.0, 606.0]], [[487.0, 521.0], [514.0, 521.0], [514.0, 679.0], [487.0, 679.0]], [[451.0, 520.0], [478.0, 520.0], [478.0, 718.0], [451.0, 718.0]], [[421.0, 523.0], [443.0, 523.0], [443.0, 703.0], [421.0, 703.0]]], "lines": ["じゃあ", "小野寺さんに", "とって生きるって", "なんなんスか？"]}, {"box": [243, 915, 283, 1088], "vertical": true, "font_size": 32, "lines_coords": [[[243.0, 915.0], [275.0, 915.0], [275.0, 1087.0], [243.0, 1087.0]]], "lines": ["．．．償い、かな。"]}, {"box": [934, 1220, 970, 1282], "vertical": true, "font_size": 32, "lines_coords": [[[934.0, 1220.0], [970.0, 1220.0], [970.0, 1282.0], [934.0, 1282.0]]], "lines": ["へえ"]}, {"box": [815, 1354, 914, 1528], "vertical": true, "font_size": 32, "lines_coords": [[[878.0, 1354.0], [914.0, 1354.0], [914.0, 1423.0], [878.0, 1423.0]], [[848.0, 1356.0], [879.0, 1356.0], [879.0, 1528.0], [848.0, 1528.0]], [[815.0, 1356.0], [842.0, 1356.0], [842.0, 1525.0], [815.0, 1525.0]]], "lines": ["ソレ、", "今度合コンで", "使ってみます。"]}, {"box": [164, 1426, 192, 1521], "vertical": true, "font_size": 28, "lines_coords": [[[164.0, 1426.0], [192.0, 1426.0], [192.0, 1521.0], [164.0, 1521.0]]], "lines": ["どうぞ。"]}], "img_path": "118.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [918, 98, 981, 206], "vertical": true, "font_size": 28, "lines_coords": [[[953.0, 98.0], [981.0, 98.0], [981.0, 206.0], [953.0, 206.0]], [[918.0, 98.0], [946.0, 98.0], [946.0, 204.0], [918.0, 204.0]]], "lines": ["若いうち", "はさ．．．"]}, {"box": [156, 201, 258, 414], "vertical": true, "font_size": 28, "lines_coords": [[[231.0, 201.0], [257.0, 201.0], [254.0, 335.0], [228.0, 335.0]], [[195.0, 204.0], [221.0, 204.0], [221.0, 414.0], [195.0, 414.0]], [[156.0, 204.0], [189.0, 204.0], [189.0, 390.0], [156.0, 390.0]]], "lines": ["とりあえず", "ガンガンいっとけ", "っつーんだ！！"]}, {"box": [734, 515, 834, 727], "vertical": true, "font_size": 25, "lines_coords": [[[806.0, 515.0], [832.0, 515.0], [832.0, 675.0], [806.0, 675.0]], [[770.0, 517.0], [796.0, 517.0], [796.0, 700.0], [770.0, 700.0]], [[735.0, 518.0], [757.0, 518.0], [757.0, 723.0], [735.0, 723.0]]], "lines": ["生きてる意味", "なんて考えてる", "ヒマがあるなら．．．"]}, {"box": [554, 496, 651, 657], "vertical": true, "font_size": 27, "lines_coords": [[[623.0, 496.0], [650.0, 496.0], [650.0, 629.0], [623.0, 629.0]], [[590.0, 501.0], [617.0, 501.0], [617.0, 656.0], [590.0, 656.0]], [[554.0, 496.0], [581.0, 496.0], [584.0, 657.0], [557.0, 657.0]]], "lines": ["年をとれば", "いずれ答えは", "分かるさ．．．"]}, {"box": [448, 804, 478, 961], "vertical": true, "font_size": 27, "lines_coords": [[[448.0, 804.0], [475.0, 804.0], [478.0, 960.0], [451.0, 960.0]]], "lines": ["恋なんてっ！！"]}, {"box": [143, 779, 170, 906], "vertical": true, "font_size": 27, "lines_coords": [[[143.0, 779.0], [170.0, 779.0], [170.0, 906.0], [143.0, 906.0]]], "lines": ["遺自転車"]}], "img_path": "119.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [875, 1043, 987, 1239], "vertical": true, "font_size": 34, "lines_coords": [[[937.0, 1043.0], [987.0, 1043.0], [987.0, 1239.0], [937.0, 1239.0]], [[909.0, 1048.0], [935.0, 1048.0], [935.0, 1214.0], [909.0, 1214.0]], [[875.0, 1050.0], [901.0, 1050.0], [901.0, 1206.0], [875.0, 1206.0]]], "lines": ["湯上くーん！！", "来てたんだね、", "帰るのかい？"]}, {"box": [209, 785, 237, 914], "vertical": true, "font_size": 28, "lines_coords": [[[209.0, 785.0], [237.0, 785.0], [237.0, 914.0], [209.0, 914.0]]], "lines": ["．．．．．．オヤ？"]}, {"box": [588, 1317, 689, 1539], "vertical": true, "font_size": 27, "lines_coords": [[[657.0, 1317.0], [689.0, 1317.0], [689.0, 1504.0], [657.0, 1504.0]], [[623.0, 1320.0], [650.0, 1320.0], [650.0, 1528.0], [623.0, 1528.0]], [[589.0, 1320.0], [610.0, 1320.0], [610.0, 1535.0], [589.0, 1535.0]]], "lines": ["時間があったら", "コーヒー一杯だけ", "付き合ってくれよ。"]}, {"box": [468, 1326, 498, 1484], "vertical": true, "font_size": 27, "lines_coords": [[[471.0, 1326.0], [498.0, 1326.0], [495.0, 1484.0], [468.0, 1484.0]]], "lines": ["．．．そーかい？"]}, {"box": [81, 1407, 146, 1517], "vertical": true, "font_size": 30, "lines_coords": [[[118.0, 1409.0], [145.0, 1409.0], [145.0, 1517.0], [118.0, 1517.0]], [[81.0, 1407.0], [114.0, 1407.0], [114.0, 1504.0], [81.0, 1504.0]]], "lines": ["また連絡", "するよ。"]}], "img_path": "120.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [893, 81, 992, 306], "vertical": true, "font_size": 29, "lines_coords": [[[965.0, 81.0], [992.0, 81.0], [992.0, 218.0], [965.0, 218.0]], [[926.0, 82.0], [957.0, 82.0], [957.0, 306.0], [926.0, 306.0]], [[893.0, 82.0], [921.0, 82.0], [921.0, 196.0], [893.0, 196.0]]], "lines": ["え～～～", "シナモン・フレンチ", "トースト、"]}, {"box": [329, 245, 432, 429], "vertical": true, "font_size": 31, "lines_coords": [[[395.0, 245.0], [432.0, 245.0], [432.0, 307.0], [395.0, 307.0]], [[364.0, 246.0], [392.0, 246.0], [393.0, 429.0], [365.0, 429.0]], [[329.0, 248.0], [356.0, 248.0], [356.0, 393.0], [329.0, 393.0]]], "lines": ["あと", "キリマンジャロ", "ブレンドを。"]}, {"box": [935, 835, 964, 942], "vertical": true, "font_size": 29, "lines_coords": [[[935.0, 835.0], [964.0, 835.0], [964.0, 942.0], [935.0, 942.0]]], "lines": ["あの．．．"]}, {"box": [128, 890, 276, 1079], "vertical": true, "font_size": 40, "lines_coords": [[[231.0, 892.0], [276.0, 892.0], [276.0, 1010.0], [231.0, 1010.0]], [[181.0, 893.0], [220.0, 893.0], [220.0, 1079.0], [181.0, 1079.0]], [[131.0, 890.0], [168.0, 890.0], [165.0, 1042.0], [128.0, 1042.0]]], "lines": ["本当に", "すみません", "でした！！"]}, {"box": [675, 1315, 740, 1424], "vertical": true, "font_size": 30, "lines_coords": [[[707.0, 1315.0], [740.0, 1315.0], [740.0, 1400.0], [707.0, 1400.0]], [[675.0, 1315.0], [701.0, 1315.0], [701.0, 1421.0], [675.0, 1421.0]]], "lines": ["先日は", "あの．．．．．"]}, {"box": [509, 1314, 601, 1493], "vertical": true, "font_size": 26, "lines_coords": [[[571.0, 1314.0], [600.0, 1314.0], [601.0, 1478.0], [573.0, 1478.0]], [[540.0, 1317.0], [567.0, 1317.0], [567.0, 1439.0], [540.0, 1439.0]], [[509.0, 1317.0], [531.0, 1317.0], [531.0, 1492.0], [509.0, 1492.0]]], "lines": ["あーいいよ、", "別に火傷も", "何もしてないし。"]}, {"box": [101, 1387, 191, 1556], "vertical": true, "font_size": 25, "lines_coords": [[[164.0, 1387.0], [190.0, 1387.0], [190.0, 1485.0], [164.0, 1485.0]], [[129.0, 1387.0], [156.0, 1387.0], [156.0, 1556.0], [129.0, 1556.0]], [[101.0, 1389.0], [123.0, 1389.0], [123.0, 1542.0], [101.0, 1542.0]]], "lines": ["文庫本は", "逝ってしまった", "けど。わはは。"]}], "img_path": "121.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [850, 67, 976, 260], "vertical": true, "font_size": 29, "lines_coords": [[[948.0, 68.0], [975.0, 68.0], [975.0, 257.0], [948.0, 257.0]], [[912.0, 67.0], [943.0, 67.0], [943.0, 254.0], [912.0, 254.0]], [[881.0, 67.0], [912.0, 67.0], [912.0, 253.0], [881.0, 253.0]], [[850.0, 68.0], [876.0, 68.0], [876.0, 200.0], [850.0, 200.0]]], "lines": ["す．．．すみません、", "あたし、なんか", "そういうヘマが", "多くて．．．"]}, {"box": [542, 101, 670, 287], "vertical": true, "font_size": 27, "lines_coords": [[[642.0, 103.0], [670.0, 103.0], [667.0, 276.0], [639.0, 276.0]], [[606.0, 103.0], [637.0, 103.0], [637.0, 287.0], [606.0, 287.0]], [[578.0, 104.0], [600.0, 104.0], [600.0, 259.0], [578.0, 259.0]], [[542.0, 101.0], [570.0, 101.0], [570.0, 190.0], [542.0, 190.0]]], "lines": ["．．．と、いうかね", "あれから考えて", "思い出したん", "だけど、"]}, {"box": [93, 54, 373, 76], "vertical": false, "font_size": 22, "lines_coords": [[[93.0, 54.0], [373.0, 54.0], [373.0, 76.0], [93.0, 76.0]]], "lines": ["おやすみプンプンＩＢ"]}, {"box": [744, 468, 843, 684], "vertical": true, "font_size": 27, "lines_coords": [[[814.0, 471.0], [843.0, 471.0], [843.0, 626.0], [814.0, 626.0]], [[775.0, 468.0], [806.0, 468.0], [809.0, 684.0], [778.0, 684.0]], [[745.0, 471.0], [767.0, 471.0], [767.0, 676.0], [745.0, 676.0]]], "lines": ["今日もまさか", "いらっしゃるなんて", "思ってなくて．．．"]}, {"box": [415, 462, 515, 673], "vertical": true, "font_size": 26, "lines_coords": [[[489.0, 464.0], [515.0, 464.0], [515.0, 595.0], [489.0, 595.0]], [[450.0, 462.0], [481.0, 462.0], [481.0, 673.0], [450.0, 673.0]], [[415.0, 464.0], [442.0, 464.0], [442.0, 593.0], [415.0, 593.0]]], "lines": ["君、以前に", "第二病院で働いて", "なかった？"]}, {"box": [264, 523, 354, 689], "vertical": true, "font_size": 26, "lines_coords": [[[328.0, 525.0], [354.0, 525.0], [354.0, 689.0], [328.0, 689.0]], [[295.0, 523.0], [321.0, 523.0], [321.0, 668.0], [295.0, 668.0]], [[264.0, 523.0], [285.0, 523.0], [287.0, 656.0], [265.0, 656.0]]], "lines": ["二年程前に僕の", "姉がお世話に", "なりまして。"]}, {"box": [907, 829, 935, 939], "vertical": true, "font_size": 30, "lines_coords": [[[907.0, 829.0], [935.0, 829.0], [935.0, 939.0], [907.0, 939.0]]], "lines": ["．．．あっ！！"]}, {"box": [757, 917, 860, 1053], "vertical": true, "font_size": 30, "lines_coords": [[[828.0, 917.0], [860.0, 917.0], [860.0, 1053.0], [828.0, 1053.0]], [[792.0, 917.0], [825.0, 917.0], [825.0, 1053.0], [792.0, 1053.0]], [[757.0, 917.0], [785.0, 917.0], [785.0, 1025.0], [757.0, 1025.0]]], "lines": ["もしかして", "プン山さん", "ですか！？"]}, {"box": [273, 829, 407, 1065], "vertical": true, "font_size": 26, "lines_coords": [[[381.0, 829.0], [407.0, 829.0], [407.0, 1037.0], [381.0, 1037.0]], [[343.0, 829.0], [371.0, 829.0], [373.0, 1053.0], [345.0, 1053.0]], [[309.0, 829.0], [335.0, 829.0], [335.0, 1065.0], [309.0, 1065.0]], [[273.0, 829.0], [300.0, 829.0], [300.0, 1034.0], [273.0, 1034.0]]], "lines": ["そうそう。退院の", "時に、君から貰った", "ドラセナの木、今も", "リビングにあるよ。"]}, {"box": [145, 960, 234, 1126], "vertical": true, "font_size": 26, "lines_coords": [[[206.0, 960.0], [234.0, 960.0], [234.0, 1060.0], [206.0, 1060.0]], [[176.0, 962.0], [198.0, 962.0], [198.0, 1126.0], [176.0, 1126.0]], [[145.0, 962.0], [167.0, 962.0], [167.0, 1109.0], [145.0, 1109.0]]], "lines": ["ちなみに", "今は色々あって", "小野寺ですが。"]}, {"box": [903, 1203, 934, 1423], "vertical": true, "font_size": 33, "lines_coords": [[[903.0, 1203.0], [934.0, 1203.0], [934.0, 1423.0], [903.0, 1423.0]]], "lines": ["すごぉ～い！！"]}, {"box": [739, 1285, 818, 1492], "vertical": true, "font_size": 33, "lines_coords": [[[781.0, 1285.0], [818.0, 1285.0], [818.0, 1448.0], [781.0, 1448.0]], [[739.0, 1289.0], [771.0, 1289.0], [771.0, 1492.0], [739.0, 1492.0]]], "lines": ["すごい偶然", "ですね、コレ！！"]}, {"box": [167, 1337, 231, 1524], "vertical": true, "font_size": 27, "lines_coords": [[[201.0, 1337.0], [229.0, 1337.0], [231.0, 1523.0], [203.0, 1523.0]], [[167.0, 1339.0], [193.0, 1339.0], [193.0, 1496.0], [167.0, 1496.0]]], "lines": ["すごいねぇ～～", "ははは．．．"]}], "img_path": "122.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [910, 263, 990, 626], "vertical": true, "font_size": 32, "lines_coords": [[[953.0, 268.0], [985.0, 268.0], [985.0, 585.0], [953.0, 585.0]], [[910.0, 270.0], [943.0, 270.0], [943.0, 621.0], [910.0, 621.0]]], "lines": ["．．．特に望んでもいない", "奇跡を偶然と呼ぶならば"]}, {"box": [181, 337, 307, 626], "vertical": true, "font_size": 36, "lines_coords": [[[268.0, 337.0], [306.0, 337.0], [303.0, 626.0], [265.0, 626.0]], [[220.0, 339.0], [257.0, 339.0], [260.0, 598.0], [223.0, 598.0]], [[182.0, 342.0], [215.0, 342.0], [215.0, 576.0], [182.0, 576.0]]], "lines": ["その偶然に甘んじて", "しまいそうになる", "自分が許せない。"]}, {"box": [281, 765, 321, 975], "vertical": true, "font_size": 34, "lines_coords": [[[281.0, 768.0], [315.0, 768.0], [318.0, 975.0], [284.0, 975.0]]], "lines": ["．．．美しくない。"]}, {"box": [903, 1118, 981, 1385], "vertical": true, "font_size": 33, "lines_coords": [[[948.0, 1120.0], [981.0, 1120.0], [981.0, 1314.0], [948.0, 1314.0]], [[903.0, 1118.0], [935.0, 1118.0], [939.0, 1385.0], [906.0, 1385.0]]], "lines": ["傷を舐め合う", "ような恋愛なんて、"]}, {"box": [123, 1117, 206, 1292], "vertical": true, "font_size": 36, "lines_coords": [[[165.0, 1117.0], [204.0, 1117.0], [204.0, 1250.0], [165.0, 1250.0]], [[123.0, 1117.0], [156.0, 1117.0], [159.0, 1292.0], [126.0, 1292.0]]], "lines": ["ただただ", "醜いだけだ。"]}], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [357, 204, 417, 336], "vertical": true, "font_size": 24, "lines_coords": [[[390.0, 204.0], [417.0, 204.0], [417.0, 310.0], [390.0, 310.0]], [[357.0, 206.0], [379.0, 206.0], [379.0, 334.0], [357.0, 334.0]]], "lines": ["おまたせ", "しました！！"]}, {"box": [350, 620, 410, 815], "vertical": true, "font_size": 26, "lines_coords": [[[384.0, 620.0], [410.0, 620.0], [410.0, 803.0], [384.0, 803.0]], [[350.0, 620.0], [376.0, 620.0], [376.0, 815.0], [350.0, 815.0]]], "lines": ["．．．おいおぃおい", "本当にドジだね。"]}, {"box": [196, 692, 296, 876], "vertical": true, "font_size": 26, "lines_coords": [[[270.0, 692.0], [296.0, 692.0], [296.0, 876.0], [270.0, 876.0]], [[234.0, 692.0], [260.0, 692.0], [260.0, 853.0], [234.0, 853.0]], [[196.0, 692.0], [223.0, 692.0], [223.0, 798.0], [196.0, 798.0]]], "lines": ["アイスコーヒー", "なんて頼んで", "ないよ？"]}, {"box": [909, 1021, 972, 1129], "vertical": true, "font_size": 28, "lines_coords": [[[943.0, 1021.0], [971.0, 1021.0], [971.0, 1128.0], [943.0, 1128.0]], [[909.0, 1021.0], [937.0, 1021.0], [937.0, 1129.0], [909.0, 1129.0]]], "lines": ["サービス", "ですっ！！"]}, {"box": [273, 1443, 507, 1515], "vertical": false, "font_size": 32, "lines_coords": [[[279.0, 1443.0], [507.0, 1484.0], [503.0, 1515.0], [273.0, 1475.0]]], "lines": ["カンドクビジですか！！"]}, {"box": [123, 1140, 152, 1273], "vertical": true, "font_size": 27, "lines_coords": [[[123.0, 1140.0], [150.0, 1140.0], [150.0, 1273.0], [123.0, 1273.0]]], "lines": ["．．．冬だぜ！？"]}], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "126.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [29, 295, 79, 462], "vertical": true, "font_size": 50, "lines_coords": [[[29.0, 296.0], [79.0, 296.0], [79.0, 462.0], [29.0, 462.0]]], "lines": ["第３１話"]},