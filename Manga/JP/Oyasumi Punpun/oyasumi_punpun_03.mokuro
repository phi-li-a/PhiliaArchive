2.0, 1170.0]], [[301.0, 934.0], [323.0, 934.0], [323.0, 1065.0], [301.0, 1065.0]]], "lines": ["やっぱ、俺．．．", "バドミントンだけ", "やってりゃよかったん", "だよな．．．"]}, {"box": [148, 985, 248, 1145], "vertical": true, "font_size": 26, "lines_coords": [[[221.0, 987.0], [248.0, 987.0], [248.0, 1120.0], [221.0, 1120.0]], [[185.0, 989.0], [212.0, 989.0], [212.0, 1145.0], [185.0, 1145.0]], [[148.0, 985.0], [176.0, 985.0], [176.0, 1093.0], [148.0, 1093.0]]], "lines": ["彼女なんて", "つくらねーで", "さ．．．．！！"]}], "img_path": "107.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [875, 101, 1000, 285], "vertical": true, "font_size": 26, "lines_coords": [[[971.0, 101.0], [998.0, 101.0], [998.0, 257.0], [971.0, 257.0]], [[940.0, 103.0], [967.0, 103.0], [967.0, 235.0], [940.0, 235.0]], [[907.0, 101.0], [934.0, 101.0], [934.0, 270.0], [907.0, 270.0]], [[878.0, 104.0], [900.0, 104.0], [900.0, 284.0], [878.0, 284.0]]], "lines": ["．．．だめだ．．．．．", "俺、やっぱ", "どっちかとか、", "選べねーよ．．．！！"]}, {"box": [707, 640, 843, 810], "vertical": true, "font_size": 24, "lines_coords": [[[815.0, 640.0], [842.0, 640.0], [842.0, 809.0], [815.0, 809.0]], [[778.0, 640.0], [804.0, 640.0], [804.0, 801.0], [778.0, 801.0]], [[745.0, 640.0], [767.0, 640.0], [767.0, 809.0], [745.0, 809.0]], [[707.0, 643.0], [729.0, 643.0], [729.0, 793.0], [707.0, 793.0]]], "lines": ["両方手に入れ", "らんねーなら、", "もうどっちも", "いらねーよ！！"]}, {"box": [396, 587, 421, 743], "vertical": true, "font_size": 23, "lines_coords": [[[396.0, 587.0], [420.0, 587.0], [421.0, 743.0], [398.0, 743.0]]], "lines": ["なんだよっ．．．"]}, {"box": [320, 731, 342, 856], "vertical": true, "font_size": 23, "lines_coords": [[[320.0, 731.0], [342.0, 731.0], [342.0, 856.0], [320.0, 856.0]]], "lines": ["クソッ．．．．．"]}, {"box": [931, 1092, 957, 1221], "vertical": true, "font_size": 26, "lines_coords": [[[931.0, 1092.0], [957.0, 1092.0], [957.0, 1221.0], [931.0, 1221.0]]], "lines": ["．．．小野寺！！"]}, {"box": [862, 1304, 995, 1545], "vertical": true, "font_size": 26, "lines_coords": [[[96