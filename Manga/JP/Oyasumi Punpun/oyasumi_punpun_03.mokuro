675.0], [168.0, 675.0]]], "lines": ["見るな．．．"]}, {"box": [859, 856, 996, 1035], "vertical": true, "font_size": 27, "lines_coords": [[[968.0, 857.0], [995.0, 857.0], [995.0, 964.0], [968.0, 964.0]], [[932.0, 856.0], [959.0, 856.0], [959.0, 990.0], [932.0, 990.0]], [[896.0, 857.0], [923.0, 857.0], [923.0, 1035.0], [896.0, 1035.0]], [[859.0, 857.0], [887.0, 857.0], [887.0, 964.0], [859.0, 964.0]]], "lines": ["あんなに", "綺麗な目で", "見つめられなく", "ても．．．"]}, {"box": [114, 857, 217, 1060], "vertical": true, "font_size": 29, "lines_coords": [[[187.0, 859.0], [214.0, 859.0], [214.0, 989.0], [187.0, 989.0]], [[148.0, 857.0], [181.0, 857.0], [181.0, 1029.0], [148.0, 1029.0]], [[114.0, 857.0], [140.0, 857.0], [140.0, 1054.0], [114.0, 1054.0]]], "lines": ["自分の汚さ", "くらい、十分に", "わかってるさ．．．"]}, {"box": [865, 1252, 892, 1371], "vertical": true, "font_size": 22, "lines_coords": [[[867.0, 1254.0], [889.0, 1254.0], [889.0, 1367.0], [867.0, 1367.0]]], "lines": ["．．．帰ろう。"]}, {"box": [673, 1252, 775, 1421], "vertical": true, "font_size": 28, "lines_coords": [[[746.0, 1253.0], [775.0, 1253.0], [775.0, 1357.0], [746.0, 1357.0]], [[710.0, 1253.0], [739.0, 1253.0], [739.0, 1359.0], [710.0, 1359.0]], [[673.0, 1253.0], [700.0, 1253.0], [703.0, 1418.0], [676.0, 1418.0]]], "lines": ["．．．自分の", "軽薄さに", "吐き気かする。"]}, {"box": [473, 1251, 578, 1462], "vertical": true, "font_size": 28, "lines_coords": [[[546.0, 1251.0], [573.0, 1251.0], [575.0, 1460.0], [548.0, 1460.0]], [[509.0, 1251.0], [540.0, 1251.0], [540.0, 1412.0], [509.0, 1412.0]], [[473.0, 1251.0], [500.0, 1251.0], [501.0, 1460.0], [475.0, 1460.0]]], "lines": ["うわへの優しさに", "なんの意味が", "あるというんだ！"]}, {"box": [240, 1251, 348, 1543], "vertical": true, "font_size": 44, "lines_coords": [[[300.0, 1253.0], [343.0, 1253.0], [343.0, 1543.0], [300.0, 1543.0]], [[243.0, 1251.0], [287.0, 1251.0], [284.0, 1464.0], [240.0, 1464.0]]], "lines": ["あの時の後悔を", "忘れるな！！"]}], "img_path": "141.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "im