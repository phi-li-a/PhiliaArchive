 1406.0]], [[804.0, 1262.0], [826.0, 1262.0], [826.0, 1404.0], [804.0, 1404.0]], [[771.0, 1262.0], [793.0, 1262.0], [793.0, 1464.0], [771.0, 1464.0]], [[739.0, 1262.0], [760.0, 1262.0], [760.0, 1473.0], [739.0, 1473.0]]], "lines": ["日本海側から", "狂烈な素気が", "流れ込み、内陸では", "積雪があるでしょう。"]}, {"box": [600, 1112, 676, 1306], "vertical": true, "font_size": 40, "lines_coords": [[[632.0, 1112.0], [676.0, 1112.0], [676.0, 1281.0], [632.0, 1281.0]], [[600.0, 1115.0], [637.0, 1115.0], [637.0, 1306.0], [600.0, 1306.0]]], "lines": ["ねーーっ！！", "雄一氏ーーッ！！"]}, {"box": [323, 1339, 465, 1526], "vertical": true, "font_size": 30, "lines_coords": [[[428.0, 1339.0], [465.0, 1339.0], [465.0, 1503.0], [428.0, 1503.0]], [[396.0, 1343.0], [423.0, 1343.0], [423.0, 1501.0], [396.0, 1501.0]], [[362.0, 1342.0], [389.0, 1342.0], [389.0, 1525.0], [362.0, 1525.0]], [[323.0, 1340.0], [354.0, 1340.0], [354.0, 1526.0], [323.0, 1526.0]]], "lines": ["明日、雪降る", "みたいだから", "買い出し行って", "来てよーーッ！！"]}], "img_path": "147.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [796, 240, 860, 382], "vertical": true, "font_size": 27, "lines_coords": [[[828.0, 240.0], [860.0, 240.0], [860.0, 323.0], [828.0, 323.0]], [[796.0, 242.0], [818.0, 242.0], [818.0, 376.0], [796.0, 376.0]]], "lines": ["．．．結局", "この数日間"]}, {"box": [142, 476, 244, 634], "vertical": true, "font_size": 27, "lines_coords": [[[214.0, 478.0], [242.0, 478.0], [242.0, 582.0], [214.0, 582.0]], [[176.0, 476.0], [204.0, 476.0], [206.0, 634.0], [178.0, 634.0]], [[142.0, 478.0], [168.0, 478.0], [168.0, 607.0], [142.0, 607.0]]], "lines": ["何も手に", "つかなかった", "訳だが．．．"]}, {"box": [346, 725, 800, 1193], "vertical": false, "font_size": 362, "lines_coords": [[[346.0, 864.0], [648.0, 725.0], [800.0, 1054.0], [496.0, 1193.0]]], "lines": ["♡！"]}, {"box": [190, 1018, 218, 1128], "vertical": true, "font_size": 27, "lines_coords": [[[190.0, 1018.0], [217.0, 1018.0], [217.0, 1125.0], [190.0, 1125.0]]], "lines": ["雪か．．．"]}, {"box": [825, 1242, 963, 1460], "vertical": true, "font_size": 25, "lines_coords": [[[937.0, 1245.0], [959.0, 1245.0], [959.0, 1457.0], [937.0, 1457.0]], [[898.0, 1243.0], [925.0, 1243.0], [925.0, 1350.0], [898.0, 1350.0]], [[859.0, 1242.0], [887.0, 1242.0], [889.0, 1401.0], [860.0, 1401.0]], [[825.0, 1242.0], [846.0, 1242.0], [850.0, 1409.0], [828.0, 1409.0]]], "lines": ["いっそ降るならば、", "思い切り", "降り積もって", "しまえばいい。"]}, {"box": [154, 1321, 293, 1534], "vertical": true, "font_size": 28, "lines_coords": [[[262.0, 1323.0], [290.0, 1323.0], [290.0, 1435.0], [262.0, 1435.0]], [[226.0, 1321.0], [257.0, 1321.0], [257.0, 1534.0], [226.0, 1534.0]], [[192.0, 1323.0], [218.0, 1323.0], [218.0, 1456.0], [192.0, 1456.0]], [[154.0, 1323.0], [181.0, 1323.0], [181.0, 1464.0], [154.0, 1464.0]]], "lines": ["何もかも、", "すべてを真っ白に", "覆い隠して", "しまうまで。"]}], "img_path": "148.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [882, 1082, 984, 1253], "vertical": true, "font_size": 29, "lines_coords": [[[951.0, 1082.0], [984.0, 1082.0], [984.0, 1126.0], [951.0, 1126.0]], [[917.0, 1082.0], [945.0, 1082.0], [945.0, 1196.0], [917.0, 1196.0]], [[882.0, 1085.0], [909.0, 1085.0], [909.0, 1250.0], [882.0, 1250.0]]], "lines": ["あー", "湯上くん、", "これまた奇遇。"]}, {"box": [387, 1307, 523, 1517], "vertical": true, "font_size": 26, "lines_coords": [[[493.0, 1307.0], [520.0, 1307.0], [520.0, 1439.0], [493.0, 1439.0]], [[457.0, 1307.0], [485.0, 1307.0], [484.0, 1517.0], [456.0, 1517.0]], [[421.0, 1309.0], [448.0, 1309.0], [448.0, 1439.0], [421.0, 1439.0]], [[389.0, 1309.0], [410.0, 1309.0], [410.0, 1464.0], [389.0, 1464.0]]], "lines": ["どうだい？", "コーヒー一杯分の", "時間くらい", "あるだろう？"]}], "img_path": "149.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [934, 60, 997, 206], "vertical": true, "font_size": 26, "lines_coords": [[[970.0, 60.0], [996.0, 60.0], [996.0, 193.0], [970.0, 193.0]], [[934.0, 62.0], [960.0, 62.0], [960.0, 206.0], [934.0, 206.0]]], "lines": ["またかい？", "妙な奴だね。"]}, {"box": [770, 266, 990, 409], "vertical": false, "font_size": 97, "lines_coords": [[[793.0, 293.0], [920.0, 293.0], [920.0, 398.0], [793.0, 398.0]]], "lines": ["．．"]}, {"box": [92, 46, 382, 73], "vertical": false, "font_size": 27, "lines_coords": [[[92.0, 46.0], [382.0, 46.0], [382.0, 73.0], [92.0, 73.0]]], "lines": ["おやすみプンプン国"]}, {"box": [766, 534, 829, 690], "vertical": true, "font_size": 24, "lines_coords": [[[801.0, 535.0], [828.0, 535.0], [828.0, 665.0], [801.0, 665.0]], [[767.0, 534.0], [789.0, 534.0], [789.0, 689.0], [767.0, 689.0]]], "lines": ["働き過ぎも", "体に毒だよ？"]}, {"box": [112, 484, 214, 695], "vertical": true, "font_size": 24, "lines_coords": [[[187.0, 484.0], [209.0, 484.0], [209.0, 692.0], [187.0, 692.0]], [[148.0, 485.0], [175.0, 485.0], [175.0, 620.0], [148.0, 620.0]], [[112.0, 485.0], [134.0, 485.0], [137.0, 687.0], [115.0, 687.0]]], "lines": ["すみませーーん！", "今日はもう", "終わりなんで．．．"]}, {"box": [939, 795, 970, 890], "vertical": true, "font_size": 28, "lines_coords": [[[939.0, 831.0], [967.0, 829.0], [970.0, 884.0], [942.0, 885.0]]], "lines": ["．．．あ"]}, {"box": [535, 801, 600, 944], "vertical": true, "font_size": 29, "lines_coords": [[[573.0, 851.0], [600.0, 851.0], [600.0, 934.0], [573.0, 934.0]], [[570.0, 801.0], [600.0, 801.0], [600.0, 850.0], [570.0, 850.0]], [[535.0, 803.0], [564.0, 803.0], [564.0, 942.0], [535.0, 942.0]]], "lines": ["．．．．．．", "あー", "いや、失礼。"]}, {"box": [489, 1062, 590, 1253], "vertical": true, "font_size": 28, "lines_coords": [[[559.0, 1062.0], [590.0, 1062.0], [590.0, 1253.0], [559.0, 1253.0]], [[525.0, 1064.0], [551.0, 1064.0], [551.0, 1196.0], [525.0, 1196.0]], [[489.0, 1062.0], [515.0, 1062.0], [515.0, 1170.0], [489.0, 1170.0]]], "lines": ["あーっ、全然！！", "全然大丈夫", "ですよ！！"]}, {"box": [135, 865, 203, 986], "vertical": true, "font_size": 32, "lines_coords": [[[167.0, 865.0], [203.0, 865.0], [203.0, 929.0], [167.0, 929.0]], [[135.0, 870.0], [162.0, 870.0], [162.0, 984.0], [135.0, 984.0]]], "lines": ["また", "出直すよ。"]}, {"box": [217, 1087, 317, 1278], "vertical": true, "font_size": 26, "lines_coords": [[[290.0, 1087.0], [317.0, 1087.0], [317.0, 1204.0], [290.0, 1204.0]], [[251.0, 1089.0], [278.0, 1089.0], [278.0, 1278.0], [251.0, 1278.0]], [[217.0, 1090.0], [243.0, 1090.0], [243.0, 1220.0], [217.0, 1220.0]]], "lines": ["どぞどぞ、", "ゆっくりしてって", "ください！！"]}, {"box": [685, 1262, 712, 1419], "vertical": true, "font_size": 27, "lines_coords": [[[685.0, 1262.0], [712.0, 1262.0], [712.0, 1418.0], [685.0, 1418.0]]], "lines": ["小野寺さん．．．"]}, {"box": [67, 1285, 201, 1503], "vertical": true, "font_size": 26, "lines_coords": [[[175.0, 1287.0], [201.0, 1287.0], [201.0, 1445.0], [175.0, 1445.0]], [[139.0, 1285.0], [165.0, 1285.0], [165.0, 1503.0], [139.0, 1503.0]], [[101.0, 1287.0], [128.0, 1287.0], [128.0, 1495.0], [101.0, 1495.0]], [[67.0, 1285.0], [93.0, 1285.0], [93.0, 1482.0], [67.0, 1482.0]]], "lines": ["店長が急用で", "先に帰っちゃって、", "あたしがレジ締め", "頼まれてるんで。"]}], "img_path": "150.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [670, 170, 782, 385], "vertical": true, "font_size": 30, "lines_coords": [[[740.0, 171.0], [773.0, 171.0], [776.0, 285.0], [743.0, 285.0]], [[704.0, 170.0], [735.0, 170.0], [740.0, 385.0], [709.0, 385.0]], [[670.0, 171.0], [696.0, 171.0], [701.0, 370.0], [675.0, 370.0]]], "lines": ["．．．椅子に", "腰をかけることに", "躊躇は無かった。"]}, {"box": [907, 645, 973, 835], "vertical": true, "font_size": 28, "lines_coords": [[[940.0, 645.0], [973.0, 645.0], [973.0, 759.0], [940.0, 759.0]], [[907.0, 646.0], [934.0, 646.0], [934.0, 835.0], [907.0, 835.0]]], "lines": ["．．．しかし、", "気がつけば夕方。"]}, {"box": [723, 643, 865, 857], "vertical": true, "font_size": 28, "lines_coords": [[[839.0, 646.0], [865.0, 646.0], [865.0, 840.0], [839.0, 840.0]], [[803.0, 646.0], [829.0, 646.0], [829.0, 828.0], [803.0, 828.0]], [[765.0, 645.0], [793.0, 645.0], [790.0, 776.0], [762.0, 776.0]], [[728.0, 643.0], [759.0, 643.0], [754.0, 857.0], [723.0, 857.0]]], "lines": ["女性とこれほど", "穏やかな時間を", "過ごすのは", "いつ振りだろう？"]}, {"box": [410, 314, 588, 532], "vertical": true, "font_size": 32, "lines_coords": [[[554.0, 315.0], [587.0, 315.0], [587.0, 434.0], [554.0, 434.0]], [[517.0, 314.0], [550.0, 314.0], [550.0, 503.0], [517.0, 503.0]], [[481.0, 317.0], [512.0, 317.0], [512.0, 517.0], [481.0, 517.0]], [[445.0, 315.0], [478.0, 315.0], [475.0, 528.0], [442.0, 528.0]], [[410.0, 320.0], [439.0, 320.0], [439.0, 432.0], [410.0, 432.0]]], "lines": ["僕はただ、", "先日のお詫びを", "言ったら、直ぐに", "帰るつもりだった", "のだから。"]}, {"box": [879, 971, 982, 1162], "vertical": true, "font_size": 29, "lines_coords": [[[948.0, 971.0], [979.0, 971.0], [982.0, 1145.0], [951.0, 1145.0]], [[915.0, 973.0], [946.0, 973.0], [946.0, 1134.0], [915.0, 1134.0]], [[879.0, 975.0], [906.0, 975.0], [906.0, 1162.0], [879.0, 1162.0]]], "lines": ["「こじんまりと", "した、小さな", "カフェをつくる。」"]}, {"box": [739, 973, 842, 1190], "vertical": true, "font_size": 29, "lines_coords": [[[810.0, 973.0], [842.0, 973.0], [842.0, 1185.0], [810.0, 1185.0]], [[773.0, 975.0], [801.0, 975.0], [803.0, 1107.0], [775.0, 1107.0]], [[739.0, 973.0], [765.0, 973.0], [767.0, 1190.0], [740.0, 1190.0]]], "lines": ["自分の夢について", "凛々と語る", "彼女を見ていると、"]}, {"box": [234, 1290, 272, 1440], "vertical": true, "font_size": 37, "lines_coords": [[[234.0, 1290.0], [271.0, 1290.0], [271.0, 1440.0], [234.0, 1440.0]]], "lines": ["僕は．．．"]}], "img_path": "151.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [473, 64, 613, 257], "vertical": true, "font_size": 27, "lines_coords": [[[584.0, 65.0], [610.0, 65.0], [610.0, 248.0], [584.0, 248.0]], [[546.0, 64.0], [573.0, 64.0], [573.0, 257.0], [546.0, 257.0]], [[510.0, 65.0], [537.0, 65.0], [537.0, 196.0], [510.0, 196.0]], [[473.0, 64.0], [501.0, 64.0], [503.0, 248.0], [475.0, 248.0]]], "lines": ["この子に好意を", "持っているという", "事実を否定", "できない．．．！！"]}, {"box": [926, 831, 987, 939], "vertical": true, "font_size": 30, "lines_coords": [[[953.0, 831.0], [987.0, 831.0], [987.0, 914.0], [953.0, 914.0]], [[926.0, 835.0], [953.0, 835.0], [953.0, 939.0], [926.0, 939.0]]], "lines": ["．．．でも", "やっぱり、"]}, {"box": [631, 804, 653, 946], "vertical": true, "font_size": 26, "lines_coords": [[[631.0, 804.0], [653.0, 804.0], [653.0, 946.0], [631.0, 946.0]]], "lines": ["え！？あぁ．．．"]}, {"box": [473, 856, 596, 1112], "vertical": true, "font_size": 26, "lines_coords": [[[570.0, 856.0], [596.0, 856.0], [595.0, 1089.0], [568.0, 1089.0]], [[534.0, 859.0], [565.0, 859.0], [565.0, 1112.0], [534.0, 1112.0]], [[503.0, 860.0], [529.0, 860.0], [529.0, 1076.0], [503.0, 1076.0]], [[473.0, 862.0], [495.0, 862.0], [495.0, 1060.0], [473.0, 1060.0]]], "lines": ["まぁ、確かに実際問題", "バイトだけでは、お店を", "始めるだけの資金は", "貯まり辛いかもね。"]}, {"box": [371, 926, 418, 1020], "vertical": false, "font_size": 94, "lines_coords": [[[371.0, 926.0], [418.0, 926.0], [418.0, 1020.0], [371.0, 1020.0]]], "lines": ["はっ"]}, {"box": [104, 895, 231, 1087], "vertical": true, "font_size": 24, "lines_coords": [[[206.0, 898.0], [228.0, 898.0], [228.0, 1050.0], [206.0, 1050.0]], [[170.0, 895.0], [196.0, 895.0], [196.0, 1064.0], [170.0, 1064.0]], [[137.0, 895.0], [160.0, 895.0], [162.0, 1062.0], [139.0, 1062.0]], [[104.0, 896.0], [131.0, 896.0], [131.0, 1087.0], [104.0, 1087.0]]], "lines": ["ても、具体的な", "夢のビジョンを", "持ち続けるって", "大事だと思うな！！"]}, {"box": [684, 1264, 809, 1431], "vertical": true, "font_size": 24, "lines_coords": [[[781.0, 1267.0], [807.0, 1267.0], [807.0, 1385.0], [781.0, 1385.0]], [[751.0, 1265.0], [773.0, 1265.0], [773.0, 1407.0], [751.0, 1407.0]], [[717.0, 1264.0], [743.0, 1264.0], [743.0, 1431.0], [717.0, 1431.0]], [[685.0, 1265.0], [707.0, 1265.0], [707.0, 1384.0], [685.0, 1384.0]]], "lines": ["いつまでも", "そんな絵空事", "言ってられない", "ですよね？"]}, {"box": [575, 1190, 632, 1360], "vertical": true, "font_size": 24, "lines_coords": [[[606.0, 1190.0], [632.0, 1190.0], [632.0, 1357.0], [606.0, 1357.0]], [[575.0, 1193.0], [596.0, 1193.0], [596.0, 1360.0], [575.0, 1360.0]]], "lines": ["：最近、両親の", "目も冷たくて："]}, {"box": [445, 1303, 535, 1484], "vertical": true, "font_size": 24, "lines_coords": [[[509.0, 1304.0], [535.0, 1304.0], [535.0, 1428.0], [509.0, 1428.0]], [[475.0, 1303.0], [501.0, 1303.0], [503.0, 1484.0], [476.0, 1484.0]], [[445.0, 1309.0], [467.0, 1309.0], [467.0, 1446.0], [445.0, 1446.0]]], "lines": ["仕事も安定", "しないし、恋人も", "いないし．．．"]}, {"box": [112, 1278, 204, 1518], "vertical": true, "font_size": 24, "lines_coords": [[[176.0, 1279.0], [203.0, 1279.0], [203.0, 1484.0], [176.0, 1484.0]], [[145.0, 1279.0], [168.0, 1279.0], [167.0, 1493.0], [143.0, 1493.0]], [[114.0, 1278.0], [135.0, 1278.0], [134.0, 1518.0], [112.0, 1518.0]]], "lines": ["早くこの環境から", "抜け出さなきゃとは", "思ってるんですけど．．．"]}], "img_path": "152.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [890, 121, 956, 293], "vertical": true, "font_size": 27, "lines_coords": [[[929.0, 123.0], [956.0, 123.0], [956.0, 256.0], [929.0, 256.0]], [[893.0, 121.0], [920.0, 121.0], [917.0, 293.0], [890.0, 293.0]]], "lines": ["．．．．．それに", "実はその．．．"]}, {"box": [815, 310, 842, 496], "vertical": true, "font_size": 27, "lines_coords": [[[815.0, 310.0], [842.0, 310.0], [842.0, 496.0], [815.0, 496.0]]], "lines": ["なんていうか．．．"]}, {"box": [154, 348, 293, 546], "vertical": true, "font_size": 27, "lines_coords": [[[265.0, 350.0], [292.0, 350.0], [292.0, 509.0], [265.0, 509.0]], [[226.0, 351.0], [253.0, 351.0], [253.0, 540.0], [226.0, 540.0]], [[189.0, 348.0], [215.0, 348.0], [215.0, 546.0], [189.0, 546.0]], [[154.0, 351.0], [181.0, 351.0], [181.0, 534.0], [154.0, 534.0]]], "lines": ["湯上さんに今", "口説かれていて、", "もうどうしたら", "いいのやら．．．"]}, {"box": [585, 971, 640, 1114], "vertical": true, "font_size": 26, "lines_coords": [[[618.0, 973.0], [640.0, 973.0], [640.0, 1092.0], [618.0, 1092.0]], [[585.0, 971.0], [607.0, 971.0], [607.0, 1114.0], [585.0, 1114.0]]], "lines": ["．．．なんだ！！", "そうなんだ！！"]}, {"box": [423, 1023, 550, 1206], "vertical": true, "font_size": 26, "lines_coords": [[[523.0, 1026.0], [550.0, 1026.0], [550.0, 1195.0], [523.0, 1195.0]], [[489.0, 1023.0], [520.0, 1023.0], [520.0, 1206.0], [489.0, 1206.0]], [[457.0, 1023.0], [484.0, 1023.0], [484.0, 1206.0], [457.0, 1206.0]], [[423.0, 1023.0], [450.0, 1023.0], [450.0, 1192.0], [423.0, 1192.0]]], "lines": ["いいじゃないか、", "彼はいい大学も", "出てるし、稼ぎも", "素晴らしいよ！！"]}, {"box": [118, 1018, 217, 1190], "vertical": true, "font_size": 29, "lines_coords": [[[189.0, 1023.0], [215.0, 1023.0], [215.0, 1153.0], [189.0, 1153.0]], [[156.0, 1021.0], [182.0, 1021.0], [182.0, 1190.0], [156.0, 1190.0]], [[118.0, 1018.0], [154.0, 1018.0], [154.0, 1089.0], [118.0, 1089.0]]], "lines": ["それに第一、", "真面目で誠実な", "男だ。"]}, {"box": [112, 1314, 249, 1525], "vertical": true, "font_size": 25, "lines_coords": [[[220.0, 1315.0], [246.0, 1315.0], [246.0, 1475.0], [220.0, 1475.0]], [[184.0, 1314.0], [210.0, 1314.0], [210.0, 1525.0], [184.0, 1525.0]], [[146.0, 1314.0], [173.0, 1314.0], [173.0, 1525.0], [146.0, 1525.0]], [[112.0, 1315.0], [134.0, 1315.0], [134.0, 1496.0], [112.0, 1496.0]]], "lines": ["仕事とか性格", "とか．．．．もちろん", "それも重要だとは", "思いますけど．．"]}], "img_path": "153.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [850, 89, 988, 335], "vertical": true, "font_size": 24, "lines_coords": [[[959.0, 89.0], [985.0, 89.0], [985.0, 335.0], [959.0, 335.0]], [[923.0, 90.0], [945.0, 90.0], [945.0, 326.0], [923.0, 326.0]], [[887.0, 90.0], [914.0, 90.0], [914.0, 312.0], [887.0, 312.0]], [[853.0, 92.0], [875.0, 92.0], [875.0, 323.0], [853.0, 323.0]]], "lines": ["理屈じゃなくて直感で", "この人だって思える人", "って、どこかに必ず", "いると思うんです．．．"]}, {"box": [440, 98, 541, 310], "vertical": true, "font_size": 29, "lines_coords": [[[510.0, 98.0], [539.0, 98.0], [540.0, 232.0], [512.0, 232.0]], [[475.0, 100.0], [506.0, 100.0], [506.0, 310.0], [475.0, 310.0]], [[440.0, 100.0], [467.0, 100.0], [467.0, 257.0], [440.0, 257.0]]], "lines": ["．．．私、実は", "けっこう人見知り", "なんですよ！？"]}, {"box": [123, 401, 190, 512], "vertical": true, "font_size": 28, "lines_coords": [[[151.0, 401.0], [190.0, 401.0], [190.0, 489.0], [151.0, 489.0]], [[123.0, 406.0], [150.0, 406.0], [150.0, 512.0], [123.0, 512.0]]], "lines": ["．．．特に", "男性は．．．"]}, {"box": [79, 579, 215, 796], "vertical": true, "font_size": 28, "lines_coords": [[[189.0, 581.0], [215.0, 581.0], [215.0, 792.0], [189.0, 792.0]], [[154.0, 584.0], [176.0, 584.0], [176.0, 796.0], [154.0, 796.0]], [[115.0, 582.0], [142.0, 582.0], [142.0, 767.0], [115.0, 767.0]], [[79.0, 579.0], [106.0, 579.0], [106.0, 765.0], [79.0, 765.0]]], "lines": ["ほぼ初対面の人を", "食事に誘うなんて、", "初めてだったん", "てすから．．．．．！！"]}, {"box": [840, 926, 901, 1026], "vertical": true, "font_size": 30, "lines_coords": [[[875.0, 928.0], [901.0, 928.0], [901.0, 1023.0], [875.0, 1023.0]], [[840.0, 926.0], [873.0, 926.0], [873.0, 1026.0], [840.0, 1026.0]]], "lines": ["．．．．．あの", "私っ．．．"]}, {"box": [751, 971, 815, 1081], "vertical": true, "font_size": 28, "lines_coords": [[[785.0, 971.0], [814.0, 971.0], [815.0, 1081.0], [787.0, 1081.0]], [[751.0, 975.0], [778.0, 975.0], [778.0, 1081.0], [751.0, 1081.0]]], "lines": ["ちょっと", "待って！！"]}, {"box": [140, 1023, 183, 1231], "vertical": true, "font_size": 42, "lines_coords": [[[140.0, 1023.0], [182.0, 1023.0], [182.0, 1231.0], [140.0, 1231.0]]], "lines": ["おしっこ！！"]}, {"box": [165, 1429, 323, 1534], "vertical": false, "font_size": 45.5, "lines_coords": [[[173.0, 1465.0], [209.0, 1489.0], [201.0, 1503.0], [165.0, 1479.0]], [[184.0, 1429.0], [323.0, 1460.0], [306.0, 1534.0], [167.0, 1501.0]]], "lines": ["なん", "．．．"]}], "img_path": "154.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [859, 120, 975, 523], "vertical": true, "font_size": 52, "lines_coords": [[[920.0, 120.0], [975.0, 120.0], [970.0, 392.0], [915.0, 392.0]], [[865.0, 125.0], [914.0, 125.0], [907.0, 500.0], [859.0, 500.0]]], "lines": ["この後、大抵", "何が起こるのか．．．"]}, {"box": [278, 123, 383, 467], "vertical": true, "font_size": 46, "lines_coords": [[[329.0, 123.0], [378.0, 123.0], [381.0, 467.0], [332.0, 467.0]], [[278.0, 126.0], [320.0, 126.0], [320.0, 346.0], [278.0, 346.0]]], "lines": ["アシビバレンスな", "感情が！？．．．"]}, {"box": [439, 401, 562, 737], "vertical": true, "font_size": 68, "lines_coords": [[[496.0, 404.0], [562.0, 404.0], [562.0, 503.0], [496.0, 503.0]], [[439.0, 401.0], [509.0, 401.0], [512.0, 712.0], [442.0, 712.0]]], "lines": ["僕は", "知っている．．．"]}, {"box": [140, 804, 305, 1081], "vertical": true, "font_size": 44, "lines_coords": [[[256.0, 807.0], [301.0, 807.0], [304.0, 978.0], [259.0, 978.0]], [[203.0, 806.0], [245.0, 806.0], [245.0, 1081.0], [203.0, 1081.0]], [[140.0, 804.0], [184.0, 804.0], [187.0, 1060.0], [143.0, 1060.0]]], "lines": ["．．．誰だ！？", "この穢らわしい", "生き物は．．．！？"]}, {"box": [148, 1339, 213, 1496], "vertical": true, "font_size": 27, "lines_coords": [[[185.0, 1339.0], [212.0, 1339.0], [212.0, 1496.0], [185.0, 1496.0]], [[148.0, 1340.0], [175.0, 1340.0], [175.0, 1481.0], [148.0, 1481.0]]], "lines": ["．．．まぁ、でも", "アレですよ。"]}], "img_path": "155.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [904, 165, 932, 270], "vertical": true, "font_size": 28, "lines_coords": [[[904.0, 165.0], [932.0, 165.0], [932.0, 270.0], [904.0, 270.0]]], "lines": ["僕は．．．"]}, {"box": [160, 281, 261, 477], "vertical": true, "font_size": 24, "lines_coords": [[[232.0, 282.0], [259.0, 282.0], [259.0, 415.0], [232.0, 415.0]], [[198.0, 284.0], [220.0, 284.0], [220.0, 464.0], [198.0, 464.0]], [[162.0, 281.0], [184.0, 281.0], [184.0, 473.0], [162.0, 473.0]]], "lines": ["君の想像を", "はるかに超えた", "最低の人間だよ。"]}, {"box": [921, 678, 957, 743], "vertical": true, "font_size": 30, "lines_coords": [[[921.0, 679.0], [954.0, 678.0], [957.0, 742.0], [925.0, 743.0]]], "lines": ["．．．な、"]}, {"box": [821, 720, 885, 859], "vertical": true, "font_size": 30, "lines_coords": [[[857.0, 720.0], [885.0, 720.0], [885.0, 859.0], [857.0, 859.0]], [[821.0, 720.0], [850.0, 720.0], [850.0, 825.0], [821.0, 825.0]]], "lines": ["なんですか、", "急に．．．"]}, {"box": [275, 664, 414, 846], "vertical": true, "font_size": 28, "lines_coords": [[[387.0, 665.0], [414.0, 665.0], [414.0, 795.0], [387.0, 795.0]], [[351.0, 667.0], [378.0, 667.0], [378.0, 823.0], [351.0, 823.0]], [[312.0, 665.0], [343.0, 665.0], [343.0, 846.0], [312.0, 846.0]], [[275.0, 664.0], [309.0, 664.0], [309.0, 757.0], [275.0, 757.0]]], "lines": ["お姉さんの", "生活の面倒を", "みてるじゃない", "ですか。"]}, {"box": [143, 703, 240, 884], "vertical": true, "font_size": 28, "lines_coords": [[[214.0, 703.0], [240.0, 703.0], [237.0, 845.0], [210.0, 845.0]], [[176.0, 704.0], [203.0, 704.0], [203.0, 884.0], [176.0, 884.0]], [[143.0, 704.0], [165.0, 704.0], [165.0, 859.0], [143.0, 859.0]]], "lines": ["小野寺さん、", "いい人だと思い", "ますよ．．．．．？"]}, {"box": [862, 970, 987, 1185], "vertical": true, "font_size": 24, "lines_coords": [[[960.0, 971.0], [987.0, 971.0], [987.0, 1100.0], [960.0, 1100.0]], [[928.0, 970.0], [954.0, 970.0], [951.0, 1139.0], [925.0, 1139.0]], [[895.0, 971.0], [917.0, 971.0], [917.0, 1182.0], [895.0, 1182.0]], [[864.0, 971.0], [884.0, 971.0], [884.0, 1170.0], [864.0, 1170.0]]], "lines": ["．．．本当はね、", "僕は、姉家族に", "愛情や絆なんて一切", "感じてないんだよ。"]}, {"box": [440, 979, 563, 1184], "vertical": true, "font_size": 23, "lines_coords": [[[535.0, 979.0], [562.0, 979.0], [562.0, 1107.0], [535.0, 1107.0]], [[504.0, 982.0], [526.0, 982.0], [526.0, 1146.0], [504.0, 1146.0]], [[470.0, 981.0], [492.0, 981.0], [492.0, 1168.0], [470.0, 1168.0]], [[440.0, 981.0], [460.0, 981.0], [460.0, 1182.0], [440.0, 1182.0]]], "lines": ["．．．僕はただ、", "誰とも関わらず", "生きていられれば", "よかっただけなのさ。"]}, {"box": [98, 1037, 224, 1226], "vertical": true, "font_size": 25, "lines_coords": [[[198.0, 1039.0], [218.0, 1039.0], [218.0, 1204.0], [198.0, 1204.0]], [[164.0, 1039.0], [190.0, 1039.0], [190.0, 1206.0], [164.0, 1206.0]], [[129.0, 1037.0], [156.0, 1037.0], [156.0, 1226.0], [129.0, 1226.0]], [[98.0, 1037.0], [126.0, 1037.0], [126.0, 1156.0], [98.0, 1156.0]]], "lines": ["こんな身勝手な", "大人を果たして", "いい人と呼べるの", "かい．．．．？"]}, {"box": [602, 1304, 758, 1540], "vertical": true, "font_size": 23, "lines_coords": [[[734.0, 1306.0], [756.0, 1306.0], [756.0, 1537.0], [734.0, 1537.0]], [[701.0, 1306.0], [723.0, 1306.0], [723.0, 1517.0], [701.0, 1517.0]], [[668.0, 1306.0], [690.0, 1306.0], [690.0, 1517.0], [668.0, 1517.0]], [[632.0, 1304.0], [659.0, 1304.0], [659.0, 1540.0], [632.0, 1540.0]], [[603.0, 1306.0], [625.0, 1306.0], [625.0, 1481.0], [603.0, 1481.0]]], "lines": ["あの家は、僕が社会から", "存在を忘れ去られて", "ゴミのように生きて", "ゆくのに、都合のいい", "ただの箱なんだ。"]}, {"box": [240, 1326, 268, 1456], "vertical": true, "font_size": 27, "lines_coords": [[[240.0, 1326.0], [268.0, 1326.0], [268.0, 1456.0], [240.0, 1456.0]]], "lines": ["てもっ．．．！！"]}, {"box": [71, 1365, 209, 1550], "vertical": true, "font_size": 27, "lines_coords": [[[181.0, 1367.0], [209.0, 1367.0], [209.0, 1498.0], [181.0, 1498.0]], [[145.0, 1367.0], [171.0, 1367.0], [171.0, 1550.0], [145.0, 1550.0]], [[107.0, 1365.0], [134.0, 1365.0], [134.0, 1550.0], [107.0, 1550.0]], [[71.0, 1367.0], [98.0, 1367.0], [100.0, 1550.0], [73.0, 1550.0]]], "lines": ["この本って", "あたしのために", "買ってきてくれ", "たんですよね！？"]}], "img_path": "156.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [844, 70, 907, 281], "vertical": true, "font_size": 24, "lines_coords": [[[879.0, 71.0], [906.0, 71.0], [906.0, 254.0], [879.0, 254.0]], [[845.0, 73.0], [867.0, 73.0], [867.0, 276.0], [845.0, 276.0]]], "lines": ["君とカラオケに", "行った日の前日：："]}, {"box": [234, 476, 335, 770], "vertical": true, "font_size": 43, "lines_coords": [[[292.0, 476.0], [334.0, 476.0], [334.0, 770.0], [292.0, 770.0]], [[234.0, 478.0], [278.0, 478.0], [278.0, 765.0], [234.0, 765.0]]], "lines": ["僕は五年振りに", "オナニーをした。"]}, {"box": [648, 873, 687, 1004], "vertical": true, "font_size": 37, "lines_coords": [[[648.0, 873.0], [687.0, 873.0], [687.0, 1004.0], [648.0, 1004.0]]], "lines": ["なっ．．．"]}, {"box": [457, 931, 598, 1226], "vertical": true, "font_size": 37, "lines_coords": [[[560.0, 931.0], [598.0, 931.0], [598.0, 1193.0], [560.0, 1193.0]], [[510.0, 932.0], [543.0, 932.0], [543.0, 1226.0], [510.0, 1226.0]], [[457.0, 931.0], [495.0, 931.0], [495.0, 1118.0], [457.0, 1118.0]]], "lines": ["なんでわざわざ", "そんなこと言うん", "ですかっ！！"]}, {"box": [81, 1242, 223, 1506], "vertical": true, "font_size": 40, "lines_coords": [[[182.0, 1248.0], [221.0, 1248.0], [221.0, 1440.0], [182.0, 1440.0]], [[126.0, 1242.0], [170.0, 1242.0], [173.0, 1437.0], [129.0, 1437.0]], [[81.0, 1245.0], [118.0, 1245.0], [118.0, 1506.0], [81.0, 1506.0]]], "lines": ["小野寺さん、", "私に嫌われ", "たいんですか！？"]}], "img_path": "157.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [769, 89, 832, 273], "vertical": true, "font_size": 24, "lines_coords": [[[804.0, 90.0], [831.0, 90.0], [831.0, 221.0], [804.0, 221.0]], [[771.0, 92.0], [793.0, 92.0], [793.0, 271.0], [771.0, 271.0]]], "lines": ["．．．なんだか", "小野寺さんは．．．"]}, {"box": [318, 53, 418, 245], "vertical": true, "font_size": 29, "lines_coords": [[[390.0, 54.0], [418.0, 54.0], [418.0, 160.0], [390.0, 160.0]], [[353.0, 53.0], [384.0, 53.0], [384.0, 245.0], [353.0, 245.0]], [[318.0, 54.0], [345.0, 54.0], [345.0, 235.0], [318.0, 235.0]]], "lines": ["．．．なんか", "それってずるく", "ないですか．．．？"]}, {"box": [505, 490, 630, 690], "vertical": true, "font_size": 23, "lines_coords": [[[601.0, 490.0], [628.0, 490.0], [628.0, 612.0], [601.0, 612.0]], [[568.0, 492.0], [592.0, 492.0], [593.0, 689.0], [570.0, 689.0]], [[535.0, 492.0], [557.0, 492.0], [557.0, 681.0], [535.0, 681.0]], [[506.0, 493.0], [526.0, 493.0], [526.0, 684.0], [506.0, 684.0]]], "lines": ["私が距離を", "縮めようとすると、", "同じだけ離れよう", "とするんですね．．．"]}, {"box": [134, 509, 202, 696], "vertical": true, "font_size": 27, "lines_coords": [[[173.0, 514.0], [200.0, 514.0], [200.0, 670.0], [173.0, 670.0]], [[137.0, 509.0], [164.0, 509.0], [160.0, 696.0], [134.0, 696.0]]], "lines": ["小野寺さんは", "ずるい人です．．．"]}, {"box": [329, 821, 421, 989], "vertical": true, "font_size": 26, "lines_coords": [[[395.0, 821.0], [421.0, 821.0], [421.0, 965.0], [395.0, 965.0]], [[362.0, 821.0], [389.0, 821.0], [389.0, 989.0], [362.0, 989.0]], [[329.0, 823.0], [359.0, 823.0], [359.0, 875.0], [329.0, 875.0]]], "lines": ["君は、僕より", "ずっと若いから", "．．．"]}, {"box": [220, 959, 309, 1082], "vertical": true, "font_size": 26, "lines_coords": [[[282.0, 959.0], [309.0, 959.0], [309.0, 1082.0], [282.0, 1082.0]], [[250.0, 959.0], [276.0, 959.0], [276.0, 1082.0], [250.0, 1082.0]], [[220.0, 962.0], [242.0, 962.0], [242.0, 1081.0], [220.0, 1081.0]]], "lines": ["君の未来を", "傷つけたく", "ないんだ．．．"]}, {"box": [303, 1309, 329, 1440], "vertical": true, "font_size": 29, "lines_coords": [[[303.0, 1309.0], [329.0, 1309.0], [329.0, 1440.0], [303.0, 1440.0]]], "lines": ["あたしは．．"]}, {"box": [160, 1379, 260, 1540], "vertical": true, "font_size": 29, "lines_coords": [[[232.0, 1381.0], [260.0, 1381.0], [260.0, 1514.0], [232.0, 1514.0]], [[193.0, 1379.0], [225.0, 1379.0], [225.0, 1540.0], [193.0, 1540.0]], [[160.0, 1379.0], [189.0, 1379.0], [189.0, 1462.0], [160.0, 1462.0]]], "lines": ["今、すでに", "傷ついてます", "よ．．．"]}], "img_path": "158.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [896, 73, 923, 237], "vertical": true, "font_size": 27, "lines_coords": [[[896.0, 73.0], [923.0, 73.0], [923.0, 237.0], [896.0, 237.0]]], "lines": ["．．．小野寺さん、"]}, {"box": [725, 96, 825, 306], "vertical": true, "font_size": 27, "lines_coords": [[[798.0, 98.0], [825.0, 98.0], [825.0, 306.0], [798.0, 306.0]], [[762.0, 96.0], [789.0, 96.0], [789.0, 293.0], [762.0, 293.0]], [[725.0, 96.0], [751.0, 96.0], [751.0, 256.0], [725.0, 256.0]]], "lines": ["なんなんですか？", "昔、何かあったん", "ですか．．．．．．？"]}, {"box": [567, 360, 595, 473], "vertical": true, "font_size": 27, "lines_coords": [[[567.0, 360.0], [595.0, 360.0], [595.0, 473.0], [567.0, 473.0]]], "lines": ["．．ごめん。"]}, {"box": [456, 454, 556, 621], "vertical": true, "font_size": 27, "lines_coords": [[[529.0, 454.0], [556.0, 454.0], [556.0, 553.0], [529.0, 553.0]], [[492.0, 465.0], [518.0, 465.0], [518.0, 598.0], [492.0, 598.0]], [[456.0, 468.0], [482.0, 468.0], [482.0, 621.0], [456.0, 621.0]]], "lines": ["えぇと、", "コーヒー代", "いくらかな？"]}, {"box": [131, 478, 194, 662], "vertical": true, "font_size": 26, "lines_coords": [[[167.0, 478.0], [193.0, 478.0], [193.0, 618.0], [167.0, 618.0]], [[131.0, 479.0], [157.0, 479.0], [157.0, 660.0], [131.0, 660.0]]], "lines": ["．．．そろそろ、", "僕は帰るよ．．．"]}, {"box": [245, 884, 275, 1002], "vertical": true, "font_size": 28, "lines_coords": [[[245.0, 885.0], [273.0, 885.0], [273.0, 1001.0], [245.0, 1001.0]]], "lines": ["．．．１００万円。"]}, {"box": [765, 1182, 867, 1382], "vertical": true, "font_size": 30, "lines_coords": [[[835.0, 1182.0], [867.0, 1182.0], [867.0, 1382.0], [835.0, 1382.0]], [[796.0, 1182.0], [828.0, 1182.0], [831.0, 1368.0], [800.0, 1368.0]], [[765.0, 1185.0], [793.0, 1185.0], [793.0, 1290.0], [765.0, 1290.0]]], "lines": ["昔、何があったか", "教えてくれない", "限り．．．"]}, {"box": [173, 1343, 236, 1529], "vertical": true, "font_size": 24, "lines_coords": [[[209.0, 1343.0], [235.0, 1343.0], [234.0, 1529.0], [207.0, 1529.0]], [[175.0, 1346.0], [196.0, 1346.0], [196.0, 1526.0], [175.0, 1526.0]]], "lines": ["．．．１円たりとも", "まけません．．．"]}], "img_path": "159.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "160.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "161.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [28, 292, 76, 460], "vertical": true, "font_size": 48, "lines_coords": [[[28.0, 292.0], [76.0, 292.0], [76.0, 460.0], [28.0, 460.0]]], "lines": ["第３３３話"]}, {"box": [195, 206, 301, 417], "vertical": true, "font_size": 30, "lines_coords": [[[270.0, 206.0], [296.0, 206.0], [296.0, 417.0], [270.0, 417.0]], [[232.0, 206.0], [264.0, 206.0], [264.0, 392.0], [232.0, 392.0]], [[195.0, 206.0], [228.0, 206.0], [228.0, 317.0], [195.0, 317.0]]], "lines": ["昔、何があったか", "教えてくれない", "限り．．．"]}, {"box": [853, 548, 916, 734], "vertical": true, "font_size": 24, "lines_coords": [[[892.0, 550.0], [914.0, 550.0], [914.0, 729.0], [892.0, 729.0]], [[854.0, 548.0], [881.0, 548.0], [879.0, 734.0], [853.0, 734.0]]], "lines": ["．．．１円たりとも", "まけません．．．"]}, {"box": [407, 1414, 623, 1495], "vertical": false, "font_size": 62, "lines_coords": [[[410.0, 1413.0], [623.0, 1424.0], [620.0, 1490.0], [407.0, 1480.0]]], "lines": ["ＣｌＯＳＥ"]}], "img_path": "162.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [453, 973, 514, 1103], "vertical": true, "font_size": 24, "lines_coords": [[[487.0, 973.0], [514.0, 973.0], [514.0, 1079.0], [487.0, 1079.0]], [[453.0, 975.0], [475.0, 975.0], [475.0, 1103.0], [453.0, 1103.0]]], "lines": ["．．．．．どう", "しました？"]}, {"box": [129, 1340, 193, 1512], "vertical": true, "font_size": 30, "lines_coords": [[[160.0, 1340.0], [193.0, 1340.0], [193.0, 1478.0], [160.0, 1478.0]], [[129.0, 1343.0], [156.0, 1343.0], [156.0, 1512.0], [129.0, 1512.0]]], "lines": ["．．．あ、いや", "なんでも無い。"]}], "img_path": "163.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [879, 89, 978, 223], "vertical": true, "font_size": 29, "lines_coords": [[[950.0, 92.0], [978.0, 92.0], [978.0, 196.0], [950.0, 196.0]], [[914.0, 89.0], [946.0, 89.0], [943.0, 198.0], [910.0, 198.0]], [[879.0, 92.0], [906.0, 92.0], [906.0, 223.0], [879.0, 223.0]]], "lines": ["．．．時間は", "たっぷり", "あります．．．"]}, {"box": [93, 59, 382, 85], "vertical": false, "font_size": 26, "lines_coords": [[[93.0, 59.0], [382.0, 59.0], [382.0, 85.0], [93.0, 85.0]]], "lines": ["おやすみプンプン国"]}, {"box": [164, 361, 226, 581], "vertical": true, "font_size": 24, "lines_coords": [[[200.0, 362.0], [226.0, 362.0], [226.0, 518.0], [200.0, 518.0]], [[165.0, 362.0], [187.0, 362.0], [187.0, 579.0], [165.0, 579.0]]], "lines": ["ゆっくり．．．", "聞かせてください。"]}, {"box": [829, 1348, 928, 1531], "vertical": true, "font_size": 25, "lines_coords": [[[901.0, 1350.0], [928.0, 1350.0], [928.0, 1481.0], [901.0, 1481.0]], [[865.0, 1348.0], [892.0, 1348.0], [892.0, 1531.0], [865.0, 1531.0]], [[831.0, 1351.0], [853.0, 1351.0], [853.0, 1479.0], [831.0, 1479.0]]], "lines": ["．．．この話を", "するのは、君が", "初めてだ．．．"]}], "img_path": "164.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [618, 81, 681, 251], "vertical": true, "font_size": 25, "lines_coords": [[[653.0, 81.0], [681.0, 81.0], [681.0, 189.0], [653.0, 189.0]], [[620.0, 85.0], [642.0, 85.0], [642.0, 240.0], [620.0, 240.0]]], "lines": ["．．．あれは", "今から五年前"]}, {"box": [454, 78, 574, 266], "vertical": true, "font_size": 27, "lines_coords": [[[529.0, 78.0], [557.0, 78.0], [554.0, 240.0], [526.0, 240.0]], [[490.0, 84.0], [517.0, 84.0], [517.0, 264.0], [490.0, 264.0]], [[454.0, 84.0], [481.0, 84.0], [481.0, 240.0], [454.0, 240.0]]], "lines": ["．．．そう、もう", "五年も前のこと", "なんだよな．．"]}, {"box": [703, 553, 1001, 682], "vertical": false, "font_size": 119, "lines_coords": [[[707.0, 563.0], [936.0, 543.0], [945.0, 671.0], [717.0, 691.0]]], "lines": ["Ｆａｖｉｔ"]}, {"box": [165, 706, 326, 934], "vertical": true, "font_size": 26, "lines_coords": [[[298.0, 707.0], [325.0, 707.0], [325.0, 860.0], [298.0, 860.0]], [[264.0, 706.0], [290.0, 706.0], [292.0, 934.0], [265.0, 934.0]], [[229.0, 706.0], [256.0, 706.0], [256.0, 882.0], [229.0, 882.0]], [[198.0, 709.0], [225.0, 709.0], [225.0, 853.0], [198.0, 853.0]], [[165.0, 707.0], [187.0, 707.0], [190.0, 860.0], [168.0, 860.0]]], "lines": ["その頃の僕は、", "実家からほど近くに", "アパートを借り、", "一人暮らしを", "していたんだ。"]}, {"box": [808, 1168, 929, 1234], "vertical": false, "font_size": 22, "lines_coords": [[[809.0, 1176.0], [921.0, 1168.0], [923.0, 1195.0], [810.0, 1203.0]], [[812.0, 1200.0], [918.0, 1193.0], [920.0, 1215.0], [814.0, 1221.0]], [[846.0, 1217.0], [889.0, 1217.0], [889.0, 1234.0], [846.0, 1234.0]]], "lines": ["大船駅", "ＯＦＵＮＡＳＴＡＴＯＡ", "．．．"]}, {"box": [495, 1378, 567, 1563], "vertical": true, "font_size": 33, "lines_coords": [[[539.0, 1378.0], [565.0, 1378.0], [564.0, 1560.0], [537.0, 1560.0]], [[495.0, 1378.0], [534.0, 1378.0], [534.0, 1471.0], [495.0, 1471.0]]], "lines": ["美術大学の院を", "卒業し、"]}, {"box": [273, 1376, 453, 1564], "vertical": true, "font_size": 28, "lines_coords": [[[426.0, 1379.0], [451.0, 1379.0], [453.0, 1539.0], [428.0, 1539.0]], [[390.0, 1382.0], [412.0, 1382.0], [412.0, 1560.0], [390.0, 1560.0]], [[353.0, 1381.0], [379.0, 1381.0], [379.0, 1510.0], [353.0, 1510.0]], [[317.0, 1381.0], [343.0, 1381.0], [343.0, 1560.0], [317.0, 1560.0]], [[273.0, 1376.0], [314.0, 1376.0], [314.0, 1448.0], [273.0, 1448.0]]], "lines": ["それでもなお", "自分の居場所を", "見いだせず", "くすぶっている", "僕に、"]}, {"box": [128, 1379, 230, 1537], "vertical": true, "font_size": 28, "lines_coords": [[[201.0, 1379.0], [229.0, 1379.0], [226.0, 1535.0], [198.0, 1535.0]], [[165.0, 1381.0], [192.0, 1381.0], [192.0, 1537.0], [165.0, 1537.0]], [[128.0, 1381.0], [156.0, 1381.0], [156.0, 1518.0], [128.0, 1518.0]]], "lines": ["大学の教授が", "就職先を紹介", "してくれた。"]}], "img_path": "165.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [515, 142, 616, 275], "vertical": true, "font_size": 29, "lines_coords": [[[589.0, 143.0], [615.0, 143.0], [615.0, 275.0], [589.0, 275.0]], [[548.0, 142.0], [581.0, 142.0], [581.0, 226.0], [548.0, 226.0]], [[515.0, 145.0], [542.0, 145.0], [542.0, 259.0], [515.0, 259.0]]], "lines": ["駅から徒歩", "数分の", "陶芸教室。"]}, {"box": [284, 167, 425, 267], "vertical": false, "font_size": 26, "lines_coords": [[[298.0, 167.0], [425.0, 245.0], [410.0, 267.0], [284.0, 189.0]]], "lines": ["そっとお肉素水を"]}, {"box": [292, 217, 415, 304], "vertical": false, "font_size": 19, "lines_coords": [[[303.0, 217.0], [415.0, 289.0], [404.0, 304.0], [292.0, 232.0]]], "lines": ["美海県不動産"]}, {"box": [192, 898, 334, 1094], "vertical": true, "font_size": 28, "lines_coords": [[[301.0, 898.0], [334.0, 898.0], [334.0, 984.0], [301.0, 984.0]], [[267.0, 900.0], [295.0, 900.0], [295.0, 1031.0], [267.0, 1031.0]], [[229.0, 900.0], [256.0, 900.0], [256.0, 1056.0], [229.0, 1056.0]], [[192.0, 898.0], [218.0, 898.0], [218.0, 1090.0], [192.0, 1090.0]]], "lines": ["五年前、", "２８歳の僕は", "陶芸の先生を", "していたんだよ。"]}, {"box": [801, 1287, 940, 1540], "vertical": true, "font_size": 28, "lines_coords": [[[910.0, 1287.0], [939.0, 1287.0], [940.0, 1523.0], [912.0, 1523.0]], [[873.0, 1290.0], [904.0, 1290.0], [904.0, 1503.0], [873.0, 1503.0]], [[837.0, 1290.0], [864.0, 1290.0], [867.0, 1501.0], [840.0, 1501.0]], [[801.0, 1287.0], [828.0, 1287.0], [829.0, 1540.0], [803.0, 1540.0]]], "lines": ["．．．もっとも、近所の", "オバサン達が集う", "市営のカルチャー", "スクールだったけどね。"]}, {"box": [126, 1379, 192, 1565], "vertical": true, "font_size": 30, "lines_coords": [[[159.0, 1379.0], [192.0, 1379.0], [192.0, 1465.0], [159.0, 1465.0]], [[126.0, 1382.0], [153.0, 1382.0], [153.0, 1565.0], [126.0, 1565.0]]], "lines": ["小野寺", "せんせぇ～～！！"]}], "img_path": "166.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [901, 121, 964, 304], "vertical": true, "font_size": 27, "lines_coords": [[[937.0, 123.0], [964.0, 123.0], [964.0, 279.0], [937.0, 279.0]], [[901.0, 121.0], [928.0, 121.0], [928.0, 304.0], [901.0, 304.0]]], "lines": ["おつかれさま", "でしたぁ～～！！"]}, {"box": [173, 356, 243, 567], "vertical": true, "font_size": 30, "lines_coords": [[[207.0, 356.0], [239.0, 356.0], [243.0, 567.0], [212.0, 567.0]], [[173.0, 356.0], [201.0, 356.0], [204.0, 556.0], [176.0, 556.0]]], "lines": ["それでは来週まで", "ごめんあそばせ。"]}, {"box": [874, 728, 975, 891], "vertical": true, "font_size": 28, "lines_coords": [[[945.0, 728.0], [975.0, 728.0], [975.0, 798.0], [945.0, 798.0]], [[909.0, 731.0], [937.0, 731.0], [937.0, 864.0], [909.0, 864.0]], [[875.0, 731.0], [901.0, 731.0], [901.0, 828.0], [875.0, 828.0]]], "lines": ["どもー", "おつかれ様", "でしたー"]}, {"box": [944, 1014, 1000, 1180], "vertical": true, "font_size": 22, "lines_coords": [[[976.0, 1014.0], [998.0, 1014.0], [998.0, 1132.0], [976.0, 1132.0]], [[945.0, 1018.0], [967.0, 1018.0], [967.0, 1179.0], [945.0, 1179.0]]], "lines": ["．．．あのォ．．．", "小野寺センセ？"]}, {"box": [573, 1010, 637, 1113], "vertical": true, "font_size": 33, "lines_coords": [[[604.0, 1010.0], [637.0, 1010.0], [637.0, 1050.0], [604.0, 1050.0]], [[573.0, 1010.0], [606.0, 1010.0], [606.0, 1112.0], [573.0, 1112.0]]], "lines": ["あー", "．．．いや．．．"]}, {"box": [179, 748, 248, 906], "vertical": true, "font_size": 27, "lines_coords": [[[220.0, 748.0], [246.0, 748.0], [243.0, 906.0], [217.0, 906.0]], [[182.0, 748.0], [210.0, 748.0], [207.0, 890.0], [179.0, 890.0]]], "lines": ["この頃の僕は", "よくモテた。"]}, {"box": [645, 1340, 768, 1531], "vertical": true, "font_size": 25, "lines_coords": [[[742.0, 1340.0], [768.0, 1340.0], [764.0, 1507.0], [737.0, 1507.0]], [[709.0, 1340.0], [737.0, 1342.0], [732.0, 1464.0], [704.0, 1462.0]], [[678.0, 1343.0], [700.0, 1343.0], [700.0, 1529.0], [678.0, 1529.0]], [[645.0, 1342.0], [667.0, 1342.0], [667.0, 1470.0], [645.0, 1470.0]]], "lines": ["シュークリーム", "食べます？", "私、並んで買って", "きましたの。"]}, {"box": [332, 1130, 421, 1343], "vertical": true, "font_size": 22, "lines_coords": [[[396.0, 1131.0], [418.0, 1131.0], [418.0, 1296.0], [396.0, 1296.0]], [[364.0, 1131.0], [385.0, 1131.0], [385.0, 1343.0], [364.0, 1343.0]], [[332.0, 1132.0], [354.0, 1132.0], [354.0, 1307.0], [332.0, 1307.0]]], "lines": ["生徒さんからの", "贈り物の受け取りは", "原則禁止でして。"]}, {"box": [429, 1390, 454, 1476], "vertical": true, "font_size": 24, "lines_coords": [[[429.0, 1393.0], [453.0, 1393.0], [453.0, 1468.0], [429.0, 1468.0]]], "lines": ["．．．特に"]}, {"box": [223, 1385, 446, 1574], "vertical": true, "font_size": 32, "lines_coords": [[[335.0, 1389.0], [367.0, 1389.0], [367.0, 1573.0], [335.0, 1573.0]], [[301.0, 1390.0], [328.0, 1390.0], [328.0, 1520.0], [301.0, 1520.0]], [[262.0, 1390.0], [289.0, 1390.0], [292.0, 1545.0], [265.0, 1545.0]], [[223.0, 1385.0], [264.0, 1385.0], [264.0, 1459.0], [223.0, 1459.0]]], "lines": ["八木さんという", "女性からは", "妙に好かれて", "いた。"]}], "img_path": "167.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [785, 67, 904, 235], "vertical": true, "font_size": 26.0, "lines_coords": [[[878.0, 68.0], [904.0, 68.0], [904.0, 235.0], [878.0, 235.0]], [[846.0, 67.0], [875.0, 67.0], [871.0, 226.0], [843.0, 226.0]], [[817.0, 68.0], [843.0, 68.0], [843.0, 225.0], [817.0, 225.0]], [[785.0, 70.0], [809.0, 70.0], [812.0, 196.0], [789.0, 196.0]]], "lines": ["ねっ、ちょっと", "一体どーゆう", "おつもりなの", "かしらっ！？"]}, {"box": [481, 276, 573, 317], "vertical": false, "font_size": 19.5, "lines_coords": [[[481.0, 276.0], [573.0, 276.0], [573.0, 293.0], [481.0, 293.0]], [[495.0, 295.0], [567.0, 295.0], [567.0, 317.0], [495.0, 317.0]]], "lines": ["Ｆａｍａｓｏｎｉｋ、", "Ｋ６Ｔ－３０４"]}, {"box": [195, 125, 334, 339], "vertical": true, "font_size": 26, "lines_coords": [[[303.0, 125.0], [329.0, 125.0], [331.0, 337.0], [304.0, 337.0]], [[265.0, 126.0], [293.0, 126.0], [295.0, 339.0], [267.0, 339.0]], [[231.0, 128.0], [257.0, 128.0], [257.0, 335.0], [231.0, 335.0]], [[195.0, 129.0], [218.0, 129.0], [220.0, 285.0], [196.0, 285.0]]], "lines": ["私も他の方と同じ", "授業料を払ってる", "のに、不公平じゃ", "ありません！？"]}, {"box": [884, 314, 981, 496], "vertical": true, "font_size": 27, "lines_coords": [[[954.0, 314.0], [981.0, 314.0], [981.0, 468.0], [954.0, 468.0]], [[920.0, 314.0], [946.0, 314.0], [946.0, 496.0], [920.0, 496.0]], [[884.0, 314.0], [910.0, 314.0], [910.0, 443.0], [884.0, 443.0]]], "lines": ["小野寺先生の", "あの態度ったら", "ないわよ！！"]}, {"box": [815, 451, 845, 712], "vertical": true, "font_size": 26, "lines_coords": [[[815.0, 451.0], [842.0, 451.0], [845.0, 712.0], [818.0, 712.0]]], "lines": ["小嶋さんや大池さんも"]}, {"box": [750, 450, 812, 687], "vertical": true, "font_size": 27, "lines_coords": [[[782.0, 450.0], [809.0, 450.0], [812.0, 687.0], [785.0, 687.0]], [[750.0, 450.0], [781.0, 450.0], [781.0, 643.0], [750.0, 643.0]]], "lines": ["菅原さんにばっかり", "愛想ふりまいて、"]}, {"box": [684, 453, 745, 637], "vertical": true, "font_size": 26, "lines_coords": [[[718.0, 453.0], [745.0, 453.0], [745.0, 637.0], [718.0, 637.0]], [[684.0, 453.0], [707.0, 453.0], [709.0, 609.0], [685.0, 609.0]]], "lines": ["あたしにだけは", "冷たいのよ！！"]}, {"box": [152, 132, 331, 687], "vertical": true, "font_size": 27, "lines_coords": [[[253.0, 503.0], [279.0, 503.0], [282.0, 662.0], [256.0, 662.0]], [[220.0, 503.0], [246.0, 503.0], [250.0, 685.0], [223.0, 685.0]], [[190.0, 506.0], [217.0, 506.0], [217.0, 643.0], [190.0, 643.0]], [[154.0, 503.0], [182.0, 503.0], [184.0, 687.0], [156.0, 687.0]]], "lines": ["あなたのとこ", "みたいな市営の", "教室なんて、", "市役所に苦情の"]}, {"box": [95, 506, 285, 685], "vertical": true, "font_size": 22, "lines_coords": [[[123.0, 506.0], [146.0, 506.0], [148.0, 685.0], [125.0, 685.0]], [[95.0, 507.0], [115.0, 507.0], [115.0, 660.0], [95.0, 660.0]]], "lines": ["ひとつも言えば", "すぐに閉．．．"]}, {"box": [876, 834, 1006, 1034], "vertical": true, "font_size": 25, "lines_coords": [[[975.0, 835.0], [1003.0, 835.0], [1006.0, 1004.0], [978.0, 1004.0]], [[945.0, 834.0], [968.0, 834.0], [970.0, 1032.0], [946.0, 1032.0]], [[912.0, 834.0], [934.0, 834.0], [934.0, 1023.0], [912.0, 1023.0]], [[876.0, 834.0], [903.0, 834.0], [906.0, 942.0], [879.0, 942.0]]], "lines": ["いや、八木さん", "どうもすみません、", "よく言って聞かせ", "ますんで。"]}, {"box": [640, 896, 767, 1064], "vertical": true, "font_size": 24, "lines_coords": [[[734.0, 896.0], [762.0, 896.0], [767.0, 1062.0], [739.0, 1062.0]], [[703.0, 898.0], [729.0, 898.0], [729.0, 1021.0], [703.0, 1021.0]], [[673.0, 898.0], [693.0, 898.0], [693.0, 1064.0], [673.0, 1064.0]], [[640.0, 900.0], [662.0, 900.0], [662.0, 1040.0], [640.0, 1040.0]]], "lines": ["えぇえぇ、へへ、", "はいどうも、", "また来週お待ち", "してます．．．"]}, {"box": [145, 908, 204, 1051], "vertical": true, "font_size": 22, "lines_coords": [[[146.0, 910.0], [168.0, 910.0], [168.0, 1048.0], [146.0, 1048.0]]], "lines": ["すみません。"]}, {"box": [554, 1181, 664, 1309], "vertical": true, "font_size": 24, "lines_coords": [[[637.0, 1181.0], [664.0, 1181.0], [664.0, 1301.0], [637.0, 1301.0]], [[610.0, 1182.0], [632.0, 1182.0], [632.0, 1298.0], [610.0, 1298.0]], [[579.0, 1182.0], [606.0, 1182.0], [606.0, 1279.0], [579.0, 1279.0]], [[554.0, 1182.0], [576.0, 1182.0], [576.0, 1309.0], [554.0, 1309.0]]], "lines": ["いやあ～～", "たまぁ〜に", "いるんだ", "こういう人。"]}, {"box": [304, 1207, 427, 1410], "vertical": true, "font_size": 23, "lines_coords": [[[400.0, 1210.0], [421.0, 1210.0], [425.0, 1335.0], [403.0, 1335.0]], [[368.0, 1209.0], [390.0, 1209.0], [393.0, 1409.0], [371.0, 1409.0]], [[331.0, 1207.0], [357.0, 1207.0], [362.0, 1403.0], [335.0, 1403.0]], [[304.0, 1212.0], [326.0, 1212.0], [326.0, 1331.0], [304.0, 1331.0]]], "lines": ["小野寺くん、", "真面目だからさぁ、", "真剣にとらなくて", "大丈夫よ？"]}, {"box": [71, 1339, 197, 1564], "vertical": true, "font_size": 27, "lines_coords": [[[167.0, 1340.0], [193.0, 1340.0], [196.0, 1509.0], [170.0, 1509.0]], [[135.0, 1340.0], [164.0, 1340.0], [165.0, 1564.0], [137.0, 1564.0]], [[104.0, 1339.0], [131.0, 1339.0], [132.0, 1557.0], [106.0, 1557.0]], [[71.0, 1342.0], [98.0, 1342.0], [100.0, 1520.0], [73.0, 1520.0]]], "lines": ["生徒っつっても", "ただの客だからさぁ、", "まぁ、なんか適当に", "上手くやってよ。"]}], "img_path": "168.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [878, 69, 906, 240], "vertical": true, "font_size": 26, "lines_coords": [[[878.0, 73.0], [904.0, 73.0], [904.0, 237.0], [878.0, 237.0]]], "lines": ["．．．いいですね。"]}, {"box": [973, 684, 1001, 751], "vertical": true, "font_size": 26, "lines_coords": [[[973.0, 684.0], [1001.0, 684.0], [1001.0, 751.0], [973.0, 751.0]]], "lines": ["オォー"]}, {"box": [939, 743, 962, 815], "vertical": true, "font_size": 26, "lines_coords": [[[939.0, 743.0], [962.0, 743.0], [962.0, 815.0], [939.0, 815.0]]], "lines": ["イ！！"]}, {"box": [245, 371, 269, 512], "vertical": true, "font_size": 22, "lines_coords": [[[245.0, 371.0], [267.0, 371.0], [267.0, 510.0], [245.0, 510.0]]], "lines": ["モテモテで。"]}, {"box": [820, 754, 884, 925], "vertical": true, "font_size": 26, "lines_coords": [[[857.0, 757.0], [884.0, 757.0], [884.0, 925.0], [857.0, 925.0]], [[820.0, 754.0], [846.0, 754.0], [850.0, 889.0], [823.0, 889.0]]], "lines": ["やめてくれよ、", "鷲尾くん！！"]}, {"box": [503, 1025, 653, 1217], "vertical": true, "font_size": 22, "lines_coords": [[[629.0, 1028.0], [651.0, 1028.0], [651.0, 1146.0], [629.0, 1146.0]], [[598.0, 1025.0], [620.0, 1025.0], [620.0, 1192.0], [598.0, 1192.0]], [[565.0, 1025.0], [589.0, 1025.0], [587.0, 1217.0], [564.0, 1217.0]], [[534.0, 1028.0], [554.0, 1028.0], [554.0, 1173.0], [534.0, 1173.0]], [[503.0, 1025.0], [523.0, 1025.0], [523.0, 1179.0], [503.0, 1179.0]]], "lines": ["君みたいな", "若手のホープが", "この教室なんかに", "いること自体", "勿体ないよね。"]}, {"box": [140, 757, 275, 942], "vertical": true, "font_size": 24, "lines_coords": [[[246.0, 759.0], [273.0, 759.0], [273.0, 890.0], [246.0, 890.0]], [[210.0, 757.0], [237.0, 757.0], [237.0, 892.0], [210.0, 892.0]], [[176.0, 760.0], [198.0, 760.0], [198.0, 915.0], [176.0, 915.0]], [[140.0, 762.0], [162.0, 762.0], [162.0, 942.0], [140.0, 942.0]]], "lines": ["僕のほうが", "君のことを", "何十倍も羨ま", "しいと思うよ？"]}, {"box": [135, 1068, 227, 1271], "vertical": true, "font_size": 24, "lines_coords": [[[198.0, 1071.0], [225.0, 1071.0], [225.0, 1271.0], [198.0, 1271.0]], [[168.0, 1070.0], [190.0, 1070.0], [190.0, 1257.0], [168.0, 1257.0]], [[135.0, 1068.0], [157.0, 1068.0], [159.0, 1270.0], [137.0, 1270.0]]], "lines": ["いつかあの作品も", "いい値がついたり", "するんだろうなぁ。"]}, {"box": [859, 1242, 995, 1503], "vertical": true, "font_size": 26, "lines_coords": [[[967.0, 1242.0], [993.0, 1242.0], [993.0, 1456.0], [967.0, 1456.0]], [[931.0, 1242.0], [957.0, 1242.0], [957.0, 1492.0], [931.0, 1492.0]], [[895.0, 1242.0], [921.0, 1242.0], [921.0, 1503.0], [895.0, 1503.0]], [[859.0, 1243.0], [885.0, 1243.0], [885.0, 1437.0], [859.0, 1437.0]]], "lines": ["．．．ホラ、君の作品、", "あの青磁の大壺、今度", "雑誌で取り上げられる", "らしいじゃない。"]}, {"box": [160, 1401, 226, 1507], "vertical": true, "font_size": 30, "lines_coords": [[[193.0, 1401.0], [226.0, 1401.0], [226.0, 1487.0], [193.0, 1487.0]], [[160.0, 1401.0], [187.0, 1401.0], [187.0, 1507.0], [160.0, 1507.0]]], "lines": ["あんな", "もの．．．"]}], "img_path": "169.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [899, 64, 927, 259], "vertical": true, "font_size": 26, "lines_coords": [[[900.0, 64.0], [926.0, 64.0], [926.0, 259.0], [900.0, 259.0]]], "lines": ["単なる「物」です。"]}, {"box": [506, 132, 639, 343], "vertical": true, "font_size": 26, "lines_coords": [[[612.0, 132.0], [639.0, 132.0], [639.0, 239.0], [612.0, 239.0]], [[576.0, 135.0], [603.0, 135.0], [603.0, 318.0], [576.0, 318.0]], [[539.0, 134.0], [565.0, 134.0], [565.0, 342.0], [539.0, 342.0]], [[506.0, 137.0], [528.0, 137.0], [528.0, 317.0], [506.0, 317.0]]], "lines": ["そもそも", "美の基準なんて", "人が後から決めた", "ものでしょう？"]}, {"box": [89, 168, 221, 406], "vertical": true, "font_size": 25, "lines_coords": [[[195.0, 168.0], [221.0, 168.0], [221.0, 337.0], [195.0, 337.0]], [[157.0, 168.0], [184.0, 168.0], [184.0, 406.0], [157.0, 406.0]], [[125.0, 170.0], [146.0, 170.0], [146.0, 404.0], [125.0, 404.0]], [[89.0, 170.0], [110.0, 170.0], [110.0, 389.0], [89.0, 389.0]]], "lines": ["だったら僕は、", "変わり続けるものに", "こそ不変の美しさが", "あると思うんです。"]}, {"box": [129, 445, 231, 632], "vertical": true, "font_size": 25, "lines_coords": [[[204.0, 450.0], [231.0, 450.0], [231.0, 632.0], [204.0, 632.0]], [[167.0, 445.0], [193.0, 445.0], [193.0, 632.0], [167.0, 632.0]], [[129.0, 445.0], [156.0, 445.0], [159.0, 567.0], [132.0, 567.0]]], "lines": ["それは例えば．．．", "「生命」のような", "ものです。"]}, {"box": [879, 720, 971, 931], "vertical": true, "font_size": 23, "lines_coords": [[[945.0, 720.0], [971.0, 720.0], [971.0, 864.0], [945.0, 864.0]], [[914.0, 720.0], [935.0, 720.0], [935.0, 931.0], [914.0, 931.0]], [[879.0, 720.0], [901.0, 720.0], [901.0, 865.0], [879.0, 865.0]]], "lines": ["あの壺だって", "釜の中で燃えている", "その時こそが"]}, {"box": [742, 789, 832, 981], "vertical": true, "font_size": 23, "lines_coords": [[[806.0, 789.0], [832.0, 789.0], [832.0, 981.0], [806.0, 981.0]], [[775.0, 790.0], [796.0, 790.0], [796.0, 978.0], [775.0, 978.0]], [[742.0, 789.0], [764.0, 789.0], [764.0, 979.0], [742.0, 979.0]]], "lines": ["もっとも美しさを", "放っていた瞬間だ", "と思いませんか？"]}, {"box": [140, 823, 241, 979], "vertical": true, "font_size": 26, "lines_coords": [[[212.0, 823.0], [239.0, 823.0], [239.0, 956.0], [212.0, 956.0]], [[175.0, 823.0], [201.0, 823.0], [201.0, 978.0], [175.0, 978.0]], [[142.0, 823.0], [165.0, 823.0], [164.0, 979.0], [140.0, 979.0]]], "lines": ["．．．僕は十分", "素晴らしいと", "思うけどね．．．"]}, {"box": [871, 1073, 987, 1456], "vertical": true, "font_size": 55, "lines_coords": [[[934.0, 1075.0], [982.0, 1075.0], [987.0, 1453.0], [939.0, 1453.0]], [[871.0, 1075.0], [932.0, 1073.0], [939.0, 1256.0], [878.0, 1257.0]]], "lines": ["このたっぷりとした", "量感：．．．"]}, {"box": [134, 1075, 243, 1382], "vertical": true, "font_size": 52, "lines_coords": [[[193.0, 1076.0], [243.0, 1076.0], [243.0, 1296.0], [193.0, 1296.0]], [[134.0, 1075.0], [189.0, 1075.0], [189.0, 1382.0], [134.0, 1382.0]]], "lines": ["それでいて", "繊細な曲線：：："]}], "img_path": "170.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [669, 72, 690, 177], "vertical": true, "font_size": 17, "lines_coords": [[[670.0, 75.0], [687.0, 75.0], [687.0, 171.0], [670.0, 171.0]]], "lines": ["じも．．．？"]}, {"box": [576, 71, 603, 229], "vertical": true, "font_size": 22, "lines_coords": [[[578.0, 71.0], [600.0, 71.0], [598.0, 226.0], [576.0, 226.0]]], "lines": ["僕もいつか！！"]}, {"box": [414, 71, 515, 282], "vertical": true, "font_size": 26, "lines_coords": [[[485.0, 73.0], [512.0, 73.0], [512.0, 228.0], [485.0, 228.0]], [[450.0, 71.0], [476.0, 71.0], [476.0, 279.0], [450.0, 279.0]], [[414.0, 71.0], [440.0, 71.0], [440.0, 178.0], [414.0, 178.0]]], "lines": ["あんなものを", "作ってみたかった", "．．．"]}, {"box": [100, 3, 356, 392], "vertical": false, "font_size": 20, "lines_coords": [[[145.0, 309.0], [206.0, 204.0], [223.0, 214.0], [162.0, 320.0]]], "lines": ["．．．"]}, {"box": [896, 385, 926, 598], "vertical": true, "font_size": 24, "lines_coords": [[[900.0, 531.0], [921.0, 531.0], [921.0, 595.0], [900.0, 595.0]], [[896.0, 385.0], [923.0, 385.0], [923.0, 487.0], [896.0, 487.0]]], "lines": ["ん！！", "雄ちゃー"]}, {"box": [214, 607, 281, 819], "vertical": true, "font_size": 28, "lines_coords": [[[245.0, 607.0], [278.0, 607.0], [281.0, 729.0], [248.0, 729.0]], [[215.0, 615.0], [237.0, 615.0], [237.0, 729.0], [215.0, 729.0]]], "lines": ["雄ちゃん、", "いないの"]}, {"box": [375, 1007, 438, 1140], "vertical": true, "font_size": 27, "lines_coords": [[[409.0, 1007.0], [437.0, 1007.0], [437.0, 1140.0], [409.0, 1140.0]], [[375.0, 1007.0], [401.0, 1007.0], [401.0, 1125.0], [375.0, 1125.0]]], "lines": ["わぁ、また", "プラモだ。"]}, {"box": [956, 1204, 1021, 1376], "vertical": true, "font_size": 28, "lines_coords": [[[989.0, 1204.0], [1021.0, 1204.0], [1021.0, 1296.0], [989.0, 1296.0]], [[956.0, 1209.0], [979.0, 1209.0], [981.0, 1373.0], [957.0, 1373.0]]], "lines": ["なによ、", "いるんじゃん。"]}, {"box": [495, 1309, 596, 1442], "vertical": true, "font_size": 27, "lines_coords": [[[568.0, 1310.0], [595.0, 1310.0], [595.0, 1440.0], [568.0, 1440.0]], [[531.0, 1309.0], [559.0, 1309.0], [559.0, 1440.0], [531.0, 1440.0]], [[495.0, 1309.0], [521.0, 1309.0], [521.0, 1442.0], [495.0, 1442.0]]], "lines": ["カギ開けて", "くれたって", "よくない？"]}, {"box": [151, 1334, 214, 1530], "vertical": true, "font_size": 27, "lines_coords": [[[182.0, 1334.0], [214.0, 1334.0], [214.0, 1492.0], [182.0, 1492.0]], [[151.0, 1337.0], [173.0, 1337.0], [173.0, 1529.0], [151.0, 1529.0]]], "lines": ["パーツが１コ", "足りないんだよ。"]}], "img_path": "171.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [784, 71, 943, 317], "vertical": true, "font_size": 26, "lines_coords": [[[917.0, 75.0], [943.0, 75.0], [943.0, 175.0], [917.0, 175.0]], [[884.0, 73.0], [910.0, 73.0], [909.0, 315.0], [882.0, 315.0]], [[848.0, 73.0], [875.0, 73.0], [875.0, 240.0], [848.0, 240.0]], [[820.0, 76.0], [842.0, 76.0], [842.0, 287.0], [820.0, 287.0]], [[784.0, 71.0], [810.0, 71.0], [812.0, 271.0], [785.0, 271.0]]], "lines": ["．．．当時、", "付き合っていた女性は、", "学生の時分から", "知り合いだった実家", "暮らしの会社員で、"]}, {"box": [167, 729, 268, 860], "vertical": true, "font_size": 27, "lines_coords": [[[237.0, 729.0], [265.0, 729.0], [267.0, 860.0], [239.0, 860.0]], [[201.0, 732.0], [229.0, 732.0], [229.0, 860.0], [201.0, 860.0]], [[167.0, 731.0], [193.0, 731.0], [193.0, 846.0], [167.0, 846.0]]], "lines": ["酒が好きで", "悪口の多い", "女だった。"]}, {"box": [850, 946, 987, 1184], "vertical": true, "font_size": 28, "lines_coords": [[[959.0, 948.0], [985.0, 948.0], [985.0, 1107.0], [959.0, 1107.0]], [[920.0, 946.0], [951.0, 946.0], [951.0, 1184.0], [920.0, 1184.0]], [[882.0, 948.0], [910.0, 948.0], [914.0, 1081.0], [885.0, 1081.0]], [[850.0, 948.0], [876.0, 948.0], [876.0, 1171.0], [850.0, 1171.0]]], "lines": ["．．．とはいえ", "それ以外においては", "概ね親切で", "優しい女性だった。"]}, {"box": [540, 964, 605, 1133], "vertical": true, "font_size": 27, "lines_coords": [[[578.0, 964.0], [604.0, 964.0], [603.0, 1132.0], [576.0, 1132.0]], [[540.0, 964.0], [568.0, 964.0], [568.0, 1056.0], [540.0, 1056.0]]], "lines": ["．．．じゃ、アタシ", "帰るね。"]}, {"box": [94, 1004, 220, 1187], "vertical": true, "font_size": 24, "lines_coords": [[[193.0, 1006.0], [215.0, 1006.0], [215.0, 1187.0], [193.0, 1187.0]], [[157.0, 1004.0], [185.0, 1004.0], [185.0, 1137.0], [157.0, 1137.0]], [[128.0, 1006.0], [150.0, 1006.0], [150.0, 1185.0], [128.0, 1185.0]], [[95.0, 1007.0], [117.0, 1007.0], [117.0, 1170.0], [95.0, 1170.0]]], "lines": ["あと、土曜の夜", "空けといて", "もらえるかな？", "用があるから。"]}, {"box": [309, 1256, 373, 1412], "vertical": true, "font_size": 26, "lines_coords": [[[345.0, 1256.0], [371.0, 1256.0], [371.0, 1400.0], [345.0, 1400.0]], [[309.0, 1256.0], [335.0, 1256.0], [335.0, 1412.0], [309.0, 1412.0]]], "lines": ["．．．あれ、コレ", "忘れ物じゃ．．．"]}, {"box": [95, 1379, 121, 1539], "vertical": true, "font_size": 22, "lines_coords": [[[95.0, 1382.0], [117.0, 1382.0], [117.0, 1495.0], [95.0, 1495.0]]], "lines": ["おやすみー"]}], "img_path": "172.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [277, 218, 810, 423], "vertical": false, "font_size": 48, "lines_coords": [[[283.0, 363.0], [763.0, 214.0], [777.0, 263.0], [297.0, 412.0]]], "lines": ["間違いのない結婚式場探し"]}, {"box": [471, 493, 865, 665], "vertical": false, "font_size": 167, "lines_coords": [[[471.0, 498.0], [864.0, 493.0], [865.0, 660.0], [473.0, 665.0]]], "lines": ["いや、"]}, {"box": [210, 529, 310, 687], "vertical": true, "font_size": 27, "lines_coords": [[[281.0, 529.0], [309.0, 529.0], [309.0, 637.0], [281.0, 637.0]], [[246.0, 531.0], [273.0, 531.0], [273.0, 687.0], [246.0, 687.0]], [[210.0, 531.0], [237.0, 531.0], [237.0, 671.0], [210.0, 671.0]]], "lines": ["．．．これが", "この頃の僕の", "日常だった。"]}, {"box": [594, 807, 693, 1025], "vertical": true, "font_size": 25, "lines_coords": [[[665.0, 809.0], [692.0, 809.0], [692.0, 1017.0], [665.0, 1017.0]], [[629.0, 807.0], [656.0, 807.0], [656.0, 940.0], [629.0, 940.0]], [[595.0, 809.0], [617.0, 809.0], [617.0, 1020.0], [595.0, 1020.0]]], "lines": ["当たり前のように", "過ぎてゆく", "当たり前の日々は"]}, {"box": [179, 1042, 281, 1214], "vertical": true, "font_size": 29, "lines_coords": [[[254.0, 1042.0], [281.0, 1042.0], [281.0, 1173.0], [254.0, 1173.0]], [[217.0, 1042.0], [248.0, 1042.0], [248.0, 1214.0], [217.0, 1214.0]], [[182.0, 1042.0], [210.0, 1042.0], [207.0, 1212.0], [179.0, 1212.0]]], "lines": ["当たり前の", "未来へきっと", "繋がっている。"]}], "img_path": "173.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [831, 132, 967, 343], "vertical": true, "font_size": 26, "lines_coords": [[[940.0, 132.0], [967.0, 132.0], [964.0, 343.0], [937.0, 343.0]], [[901.0, 132.0], [928.0, 132.0], [928.0, 342.0], [901.0, 342.0]], [[867.0, 135.0], [893.0, 135.0], [893.0, 318.0], [867.0, 318.0]], [[831.0, 134.0], [857.0, 134.0], [857.0, 275.0], [831.0, 275.0]]], "lines": ["ピースの足りない", "ジグソーバズルの", "ような気持ちを", "感じながら、"]}, {"box": [736, 665, 799, 915], "vertical": true, "font_size": 63, "lines_coords": [[[736.0, 665.0], [799.0, 665.0], [799.0, 915.0], [736.0, 915.0]]], "lines": ["人、人、"]}, {"box": [495, 645, 560, 935], "vertical": true, "font_size": 65, "lines_coords": [[[495.0, 645.0], [560.0, 645.0], [560.0, 935.0], [495.0, 935.0]]], "lines": ["様々な人々に"]}, {"box": [89, 396, 225, 582], "vertical": true, "font_size": 27, "lines_coords": [[[195.0, 396.0], [223.0, 396.0], [223.0, 503.0], [195.0, 503.0]], [[159.0, 396.0], [190.0, 396.0], [190.0, 582.0], [159.0, 582.0]], [[125.0, 396.0], [151.0, 396.0], [148.0, 556.0], [121.0, 556.0]], [[92.0, 398.0], [115.0, 398.0], [112.0, 537.0], [89.0, 537.0]]], "lines": ["それでも", "大人になるのが", "人間なのだと", "信じていた。"]}, {"box": [242, 673, 300, 868], "vertical": true, "font_size": 50, "lines_coords": [[[242.0, 676.0], [292.0, 675.0], [300.0, 867.0], [250.0, 868.0]]], "lines": ["囲まれて、"]}, {"box": [839, 1095, 939, 1306], "vertical": true, "font_size": 23, "lines_coords": [[[912.0, 1095.0], [934.0, 1095.0], [934.0, 1300.0], [912.0, 1300.0]], [[878.0, 1100.0], [900.0, 1100.0], [900.0, 1276.0], [878.0, 1276.0]], [[839.0, 1096.0], [865.0, 1096.0], [865.0, 1212.0], [839.0, 1212.0]]], "lines": ["それでも僕だけは", "平常心を保って", "生きよう。"]}, {"box": [792, 1213, 818, 1454], "vertical": true, "font_size": 22, "lines_coords": [[[793.0, 1231.0], [815.0, 1231.0], [815.0, 1446.0], [793.0, 1446.0]]], "lines": ["．．．そう思っていた"]}, {"box": [134, 1381, 160, 1484], "vertical": true, "font_size": 28, "lines_coords": [[[134.0, 1381.0], [160.0, 1381.0], [160.0, 1484.0], [134.0, 1484.0]]], "lines": ["ー．．．でも"]}, {"box": [98, 1350, 129, 1539], "vertical": true, "font_size": 28, "lines_coords": [[[98.0, 1350.0], [129.0, 1350.0], [129.0, 1539.0], [98.0, 1539.0]]], "lines": ["でも、もし．．．"]}], "img_path": "174.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [607, 328, 839, 739], "vertical": true, "font_size": 58, "lines_coords": [[[775.0, 337.0], [839.0, 337.0], [839.0, 739.0], [775.0, 739.0]], [[695.0, 337.0], [760.0, 337.0], [760.0, 625.0], [695.0, 625.0]], [[607.0, 334.0], [687.0, 328.0], [698.0, 475.0], [618.0, 481.0]]], "lines": ["異常という名の", "この日常の", "中で"]}, {"box": [634, 656, 656, 734], "vertical": true, "font_size": 58, "lines_coords": [[[634.0, 656.0], [656.0, 656.0], [656.0, 734.0], [634.0, 734.0]]], "lines": ["．．．"]}], "img_path": "175.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [518, 133, 589, 492], "vertical": true, "font_size": 71, "lines_coords": [[[518.0, 162.0], [589.0, 162.0], [589.0, 492.0], [518.0, 492.0]]], "lines": ["９でに僕も："]}, {"box": [96, 122, 221, 502], "vertical": true, "font_size": 125, "lines_coords": [[[96.0, 128.0], [221.0, 128.0], [221.0, 470.0], [96.0, 470.0]]], "lines": ["．．．違うー"]}, {"box": [256, 681, 350, 1600], "vertical": true, "font_size": 90, "lines_coords": [[[256.0, 704.0], [346.0, 704.0], [350.0, 1600.0], [259.0, 1600.0]]], "lines": ["壊れてしまっているのだもしたら．．．"]}, {"box": [0, 965, 125, 1468], "vertical": true, "font_size": 120, "lines_coords": [[[0.0, 965.0], [125.0, 968.0], [114.0, 1376.0], [0.0, 1373.0]]], "lines": ["僕は僕だ"]}], "img_path": "176.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [629, 879, 662, 990], "vertical": true, "font_size": 31, "lines_coords": [[[629.0, 879.0], [662.0, 879.0], [662.0, 990.0], [629.0, 990.0]]], "lines": ["．．．アッ！！"]}, {"box": [528, 967, 593, 1079], "vertical": true, "font_size": 31, "lines_coords": [[[560.0, 967.0], [593.0, 967.0], [593.0, 1057.0], [560.0, 1057.0]], [[528.0, 975.0], [554.0, 975.0], [554.0, 1079.0], [528.0, 1079.0]]], "lines": ["小野寺", "センセ！！"]}, {"box": [126, 1020, 232, 1206], "vertical": true, "font_size": 28, "lines_coords": [[[196.0, 1020.0], [229.0, 1020.0], [232.0, 1139.0], [200.0, 1139.0]], [[165.0, 1023.0], [192.0, 1023.0], [192.0, 1153.0], [165.0, 1153.0]], [[129.0, 1021.0], [157.0, 1021.0], [154.0, 1206.0], [126.0, 1206.0]]], "lines": ["あのコレ、", "ウチの娘で", "ございますの！！"]}, {"box": [92, 1265, 262, 1500], "vertical": true, "font_size": 28, "lines_coords": [[[235.0, 1270.0], [262.0, 1270.0], [262.0, 1489.0], [235.0, 1489.0]], [[198.0, 1270.0], [226.0, 1270.0], [226.0, 1401.0], [198.0, 1401.0]], [[162.0, 1267.0], [193.0, 1267.0], [190.0, 1453.0], [159.0, 1453.0]], [[126.0, 1267.0], [154.0, 1267.0], [153.0, 1500.0], [125.0, 1500.0]], [[92.0, 1265.0], [118.0, 1265.0], [118.0, 1400.0], [92.0, 1400.0]]], "lines": ["もし、よろしければ", "この子にも", "小野寺センセに", "教えていただきたい", "と思って！！"]}], "img_path": "177.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [928, 417, 994, 581], "vertical": true, "font_size": 27, "lines_coords": [[[967.0, 421.0], [993.0, 421.0], [993.0, 579.0], [967.0, 579.0]], [[928.0, 417.0], [956.0, 417.0], [959.0, 525.0], [931.0, 525.0]]], "lines": ["八木さぁ～～", "～～ん！！"]}, {"box": [493, 507, 615, 706], "vertical": true, "font_size": 22, "lines_coords": [[[590.0, 507.0], [612.0, 507.0], [612.0, 626.0], [590.0, 626.0]], [[559.0, 507.0], [581.0, 507.0], [581.0, 671.0], [559.0, 671.0]], [[528.0, 507.0], [550.0, 507.0], [550.0, 701.0], [528.0, 701.0]], [[496.0, 507.0], [518.0, 507.0], [515.0, 673.0], [493.0, 673.0]]], "lines": ["大池さんが", "カステラ買って", "きてくださったの、", "ひとついかか？"]}, {"box": [142, 223, 265, 600], "vertical": true, "font_size": 29, "lines_coords": [[[237.0, 223.0], [264.0, 223.0], [264.0, 318.0], [237.0, 318.0]], [[212.0, 376.0], [243.0, 376.0], [243.0, 545.0], [212.0, 545.0]], [[175.0, 376.0], [207.0, 376.0], [207.0, 518.0], [175.0, 518.0]], [[142.0, 376.0], [168.0, 376.0], [168.0, 600.0], [142.0, 600.0]]], "lines": ["オホホ。", "小野寺センセ、", "それじゃ私、", "ちょっと失礼して．．．"]}, {"box": [935, 1276, 964, 1384], "vertical": true, "font_size": 28, "lines_coords": [[[935.0, 1276.0], [964.0, 1276.0], [964.0, 1384.0], [935.0, 1384.0]]], "lines": ["．．．あの．．．"]}, {"box": [834, 1364, 898, 1526], "vertical": true, "font_size": 28, "lines_coords": [[[870.0, 1364.0], [898.0, 1364.0], [895.0, 1500.0], [867.0, 1500.0]], [[834.0, 1365.0], [860.0, 1365.0], [860.0, 1526.0], [834.0, 1526.0]]], "lines": ["なんか母が", "すみません．．．"]}, {"box": [289, 1257, 351, 1467], "vertical": true, "font_size": 27, "lines_coords": [[[325.0, 1257.0], [351.0, 1257.0], [351.0, 1465.0], [325.0, 1465.0]], [[289.0, 1257.0], [315.0, 1257.0], [315.0, 1467.0], [289.0, 1467.0]]], "lines": ["強引に連れられて", "来てしまって．．．"]}, {"box": [101, 1323, 237, 1560], "vertical": true, "font_size": 27, "lines_coords": [[[206.0, 1323.0], [237.0, 1323.0], [235.0, 1560.0], [204.0, 1560.0]], [[171.0, 1326.0], [198.0, 1326.0], [198.0, 1548.0], [171.0, 1548.0]], [[134.0, 1323.0], [165.0, 1323.0], [165.0, 1534.0], [134.0, 1534.0]], [[101.0, 1326.0], [123.0, 1326.0], [123.0, 1481.0], [101.0, 1481.0]]], "lines": ["どんな口実でもいい", "から、小野寺さんに", "近づきたいみたい", "なんです．．．"]}], "img_path": "178.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [903, 111, 1020, 380], "vertical": true, "font_size": 26, "lines_coords": [[[957.0, 228.0], [987.0, 228.0], [987.0, 304.0], [957.0, 304.0]], [[929.0, 228.0], [956.0, 228.0], [956.0, 376.0], [929.0, 376.0]], [[903.0, 229.0], [925.0, 229.0], [925.0, 326.0], [903.0, 326.0]]], "lines": ["ああ！！", "そうでしたか、", "ははは！"]}, {"box": [652, 121, 715, 304], "vertical": true, "font_size": 24, "lines_coords": [[[687.0, 121.0], [714.0, 121.0], [714.0, 254.0], [687.0, 254.0]], [[654.0, 123.0], [676.0, 123.0], [676.0, 304.0], [654.0, 304.0]]], "lines": ["あの．．．全然", "お気遣いなく．．．"]}, {"box": [243, 237, 307, 404], "vertical": true, "font_size": 28, "lines_coords": [[[275.0, 237.0], [307.0, 237.0], [307.0, 276.0], [275.0, 276.0]], [[243.0, 240.0], [270.0, 240.0], [270.0, 404.0], [243.0, 404.0]]], "lines": ["あ", "いやいやぃや！！"]}, {"box": [437, 439, 536, 598], "vertical": true, "font_size": 25, "lines_coords": [[[507.0, 440.0], [534.0, 440.0], [534.0, 598.0], [507.0, 598.0]], [[471.0, 440.0], [498.0, 440.0], [498.0, 585.0], [471.0, 585.0]], [[437.0, 440.0], [459.0, 440.0], [459.0, 556.0], [437.0, 556.0]]], "lines": ["母の気が済ん", "だら、すぐに", "帰ります。"]}, {"box": [131, 442, 270, 665], "vertical": true, "font_size": 28, "lines_coords": [[[243.0, 443.0], [270.0, 443.0], [270.0, 631.0], [243.0, 631.0]], [[201.0, 442.0], [232.0, 442.0], [235.0, 632.0], [204.0, 632.0]], [[170.0, 445.0], [196.0, 445.0], [196.0, 631.0], [170.0, 631.0]], [[131.0, 445.0], [159.0, 445.0], [162.0, 665.0], [134.0, 665.0]]], "lines": ["こっちこそ何も", "気付かなくて！！", "お茶淹れるから", "ゆっくりしてって。"]}], "img_path": "179.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [937, 162, 965, 251], "vertical": true, "font_size": 28, "lines_coords": [[[937.0, 162.0], [965.0, 162.0], [965.0, 251.0], [937.0, 251.0]]], "lines": ["あ．．．"]}, {"box": [860, 273, 889, 407], "vertical": true, "font_size": 28, "lines_coords": [[[860.0, 273.0], [889.0, 273.0], [889.0, 407.0], [860.0, 407.0]]], "lines": ["その本．．．"]}, {"box": [150, 268, 254, 431], "vertical": true, "font_size": 28, "lines_coords": [[[217.0, 268.0], [251.0, 268.0], [254.0, 384.0], [220.0, 384.0]], [[185.0, 273.0], [212.0, 273.0], [212.0, 431.0], [185.0, 431.0]], [[151.0, 273.0], [175.0, 273.0], [173.0, 429.0], [150.0, 429.0]]], "lines": ["私も、今", "読んでる途中", "なんです．．．"]}, {"box": [896, 562, 968, 728], "vertical": true, "font_size": 29, "lines_coords": [[[940.0, 648.0], [964.0, 648.0], [964.0, 720.0], [940.0, 720.0]], [[931.0, 562.0], [968.0, 562.0], [968.0, 610.0], [931.0, 610.0]], [[896.0, 564.0], [940.0, 564.0], [940.0, 728.0], [896.0, 728.0]]], "lines": ["ーっ！！", "あー", "へぇーーっ！！"]}, {"box": [768, 635, 865, 773], "vertical": true, "font_size": 29, "lines_coords": [[[839.0, 635.0], [865.0, 635.0], [865.0, 773.0], [839.0, 773.0]], [[804.0, 637.0], [826.0, 637.0], [826.0, 767.0], [804.0, 767.0]], [[768.0, 637.0], [790.0, 637.0], [790.0, 740.0], [768.0, 740.0]]], "lines": ["そうなんだ、", "それは偶然", "だねぇ！！"]}, {"box": [267, 598, 332, 785], "vertical": true, "font_size": 27, "lines_coords": [[[306.0, 600.0], [332.0, 600.0], [332.0, 770.0], [306.0, 770.0]], [[271.0, 598.0], [298.0, 598.0], [293.0, 785.0], [267.0, 785.0]]], "lines": ["しかし、渋いの", "読んでるねー"]}, {"box": [151, 653, 214, 837], "vertical": true, "font_size": 27, "lines_coords": [[[182.0, 653.0], [214.0, 653.0], [214.0, 828.0], [182.0, 828.0]], [[151.0, 656.0], [173.0, 656.0], [173.0, 837.0], [151.0, 837.0]]], "lines": ["あの．．．．君は", "今いくつなの？"]}, {"box": [945, 925, 973, 1015], "vertical": true, "font_size": 28, "lines_coords": [[[945.0, 925.0], [973.0, 925.0], [973.0, 1015.0], [945.0, 1015.0]]], "lines": ["１６です。"]}, {"box": [403, 923, 431, 1053], "vertical": true, "font_size": 26, "lines_coords": [[[403.0, 923.0], [429.0, 923.0], [429.0, 1053.0], [403.0, 1053.0]]], "lines": ["趣味が．．．"]}, {"box": [93, 1315, 155, 1525], "vertical": true, "font_size": 24, "lines_coords": [[[126.0, 1315.0], [153.0, 1315.0], [153.0, 1450.0], [126.0, 1450.0]], [[93.0, 1315.0], [115.0, 1315.0], [115.0, 1521.0], [93.0, 1521.0]]], "lines": ["合うのかも", "しれませんね．．．"]}], "img_path": "180.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [914, 95, 976, 365], "vertical": true, "font_size": 48, "lines_coords": [[[923.0, 148.0], [971.0, 148.0], [971.0, 332.0], [923.0, 332.0]]], "lines": ["．．．この"]}, {"box": [120, 89, 267, 509], "vertical": true, "font_size": 68, "lines_coords": [[[192.0, 90.0], [267.0, 90.0], [264.0, 509.0], [189.0, 509.0]], [[120.0, 96.0], [181.0, 96.0], [181.0, 337.0], [120.0, 337.0]]], "lines": ["たっぷりとした", "量感：：：．．"]}, {"box": [268, 643, 342, 892], "vertical": true, "font_size": 74, "lines_coords": [[[268.0, 678.0], [342.0, 678.0], [342.0, 881.0], [268.0, 881.0]]], "lines": ["・繊細な、"]}, {"box": [121, 629, 204, 790], "vertical": true, "font_size": 83, "lines_coords": [[[121.0, 629.0], [204.0, 629.0], [204.0, 790.0], [121.0, 790.0]]], "lines": ["曲線。"]}, {"box": [870, 634, 957, 998], "vertical": true, "font_size": 75, "lines_coords": [[[882.0, 634.0], [957.0, 637.0], [945.0, 998.0], [870.0, 995.0]]], "lines": ["それでいて．．．"]}], "img_path": "181.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [544, 109, 682, 318], "vertical": true, "font_size": 28, "lines_coords": [[[651.0, 110.0], [679.0, 110.0], [681.0, 292.0], [653.0, 292.0]], [[617.0, 110.0], [645.0, 110.0], [645.0, 242.0], [617.0, 242.0]], [[579.0, 109.0], [610.0, 109.0], [610.0, 318.0], [579.0, 318.0]], [[546.0, 110.0], [573.0, 110.0], [573.0, 259.0], [546.0, 259.0]]], "lines": ["今にして思うと", "その少女は", "僕の「日常」の中に", "突然現れた、"]}, {"box": [420, 110, 485, 317], "vertical": true, "font_size": 24, "lines_coords": [[[459.0, 112.0], [481.0, 112.0], [481.0, 314.0], [459.0, 314.0]], [[420.0, 110.0], [446.0, 110.0], [446.0, 221.0], [420.0, 221.0]]], "lines": ["「非日常」だったの", "だと思う。"]}, {"box": [12, 84, 54, 194], "vertical": true, "font_size": 42, "lines_coords": [[[12.0, 84.0], [54.0, 84.0], [54.0, 194.0], [12.0, 194.0]]], "lines": ["え．．．"]}, {"box": [29, 293, 73, 452], "vertical": true, "font_size": 38, "lines_coords": [[[32.0, 296.0], [70.0, 296.0], [70.0, 450.0], [32.0, 450.0]]], "lines": ["第３４話"]}, {"box": [619, 1312, 723, 1543], "vertical": true, "font_size": 29, "lines_coords": [[[690.0, 1312.0], [723.0, 1312.0], [723.0, 1423.0], [690.0, 1423.0]], [[657.0, 1314.0], [684.0, 1314.0], [684.0, 1492.0], [657.0, 1492.0]], [[620.0, 1314.0], [646.0, 1314.0], [646.0, 1535.0], [620.0, 1535.0]]], "lines": ["．．．或いは、", "１０歳以上も年の", "離れた、その少女に"]}, {"box": [385, 1310, 559, 1521], "vertical": true, "font_size": 29, "lines_coords": [[[532.0, 1312.0], [559.0, 1312.0], [559.0, 1493.0], [532.0, 1493.0]], [[493.0, 1310.0], [525.0, 1310.0], [521.0, 1496.0], [490.0, 1496.0]], [[457.0, 1310.0], [489.0, 1310.0], [489.0, 1521.0], [457.0, 1521.0]], [[423.0, 1314.0], [450.0, 1314.0], [450.0, 1493.0], [423.0, 1493.0]], [[385.0, 1312.0], [412.0, 1312.0], [412.0, 1426.0], [385.0, 1426.0]]], "lines": ["僕が心の奥底で", "求め続けていた", "「何か」を投影して", "しまったのかも", "しれない。"]}], "img_path": "182.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [232, 723, 264, 820], "vertical": true, "font_size": 28, "lines_coords": [[[232.0, 723.0], [260.0, 723.0], [264.0, 820.0], [235.0, 820.0]]], "lines": ["．．．あ。"]}, {"box": [915, 960, 978, 1160], "vertical": true, "font_size": 30, "lines_coords": [[[946.0, 960.0], [978.0, 960.0], [978.0, 1160.0], [946.0, 1160.0]], [[915.0, 964.0], [942.0, 964.0], [942.0, 1121.0], [915.0, 1121.0]]], "lines": ["．．．でも、今日って", "平日だよね？"]}, {"box": [637, 1259, 736, 1470], "vertical": true, "font_size": 24, "lines_coords": [[[712.0, 1260.0], [734.0, 1260.0], [734.0, 1467.0], [712.0, 1467.0]], [[673.0, 1259.0], [700.0, 1259.0], [700.0, 1431.0], [673.0, 1431.0]], [[639.0, 1259.0], [662.0, 1259.0], [660.0, 1417.0], [637.0, 1417.0]]], "lines": ["．．．えーっと．．．．．", "今日は、学校は", "休みか何か？"]}, {"box": [431, 1331, 495, 1546], "vertical": true, "font_size": 22, "lines_coords": [[[470.0, 1331.0], [492.0, 1331.0], [492.0, 1510.0], [470.0, 1510.0]], [[431.0, 1331.0], [453.0, 1331.0], [453.0, 1537.0], [431.0, 1537.0]]], "lines": ["．．．伏し目かちな", "その少女の様子は"]}, {"box": [193, 1328, 375, 1526], "vertical": true, "font_size": 29, "lines_coords": [[[337.0, 1328.0], [375.0, 1328.0], [375.0, 1390.0], [337.0, 1390.0]], [[306.0, 1331.0], [332.0, 1331.0], [332.0, 1523.0], [306.0, 1523.0]], [[271.0, 1332.0], [293.0, 1332.0], [293.0, 1487.0], [271.0, 1487.0]], [[232.0, 1332.0], [259.0, 1332.0], [259.0, 1487.0], [232.0, 1487.0]], [[193.0, 1329.0], [226.0, 1329.0], [226.0, 1423.0], [193.0, 1423.0]]], "lines": ["僕に", "不登校や、いじめ", "という言葉を", "たやすく連想", "させた。"]}], "img_path": "183.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [867, 81, 985, 226], "vertical": true, "font_size": 28, "lines_coords": [[[957.0, 81.0], [985.0, 81.0], [985.0, 159.0], [957.0, 159.0]], [[928.0, 84.0], [954.0, 84.0], [954.0, 206.0], [928.0, 206.0]], [[901.0, 85.0], [923.0, 85.0], [923.0, 226.0], [901.0, 226.0]], [[867.0, 82.0], [901.0, 82.0], [901.0, 160.0], [867.0, 160.0]]], "lines": ["．．．あ．．．", "えーと．．．", "なんていうか", "ホラ！！"]}, {"box": [565, 89, 595, 196], "vertical": true, "font_size": 28, "lines_coords": [[[565.0, 89.0], [593.0, 89.0], [595.0, 195.0], [567.0, 195.0]]], "lines": ["私は．．．"]}, {"box": [100, 235, 205, 473], "vertical": true, "font_size": 26, "lines_coords": [[[173.0, 235.0], [200.0, 235.0], [201.0, 446.0], [175.0, 446.0]], [[137.0, 235.0], [164.0, 235.0], [165.0, 473.0], [139.0, 473.0]], [[100.0, 235.0], [126.0, 235.0], [129.0, 395.0], [103.0, 395.0]]], "lines": ["普段は、母に縄で", "縛られて軟禁されて", "ますから．．．"]}, {"box": [676, 456, 800, 684], "vertical": true, "font_size": 25, "lines_coords": [[[775.0, 546.0], [798.0, 546.0], [798.0, 610.0], [775.0, 610.0]], [[770.0, 459.0], [800.0, 459.0], [800.0, 531.0], [770.0, 531.0]], [[739.0, 457.0], [765.0, 457.0], [765.0, 648.0], [739.0, 648.0]], [[706.0, 456.0], [732.0, 456.0], [732.0, 684.0], [706.0, 684.0]], [[676.0, 457.0], [698.0, 457.0], [698.0, 668.0], [676.0, 668.0]]], "lines": ["ーっ、", "いやー", "１６歳とは若いね！！", "今の若い子って、普段", "何して遊んでんの？"]}, {"box": [217, 432, 570, 729], "vertical": false, "font_size": 326, "lines_coords": [[[217.0, 403.0], [570.0, 403.0], [570.0, 758.0], [217.0, 758.0]]], "lines": ["はっ"]}, {"box": [946, 765, 973, 876], "vertical": true, "font_size": 26, "lines_coords": [[[946.0, 765.0], [973.0, 765.0], [973.0, 876.0], [946.0, 876.0]]], "lines": ["．．．はは、"]}, {"box": [870, 854, 931, 998], "vertical": true, "font_size": 26, "lines_coords": [[[901.0, 854.0], [931.0, 854.0], [931.0, 925.0], [901.0, 925.0]], [[870.0, 868.0], [892.0, 868.0], [892.0, 998.0], [870.0, 998.0]]], "lines": ["また", "またぁ～～"]}, {"box": [220, 868, 253, 951], "vertical": true, "font_size": 29, "lines_coords": [[[223.0, 868.0], [253.0, 870.0], [250.0, 951.0], [220.0, 950.0]]], "lines": ["はは！"]}, {"box": [182, 1009, 209, 1153], "vertical": true, "font_size": 29, "lines_coords": [[[182.0, 1009.0], [209.0, 1009.0], [209.0, 1153.0], [182.0, 1153.0]]], "lines": ["すみません。"]}, {"box": [609, 1279, 782, 1526], "vertical": true, "font_size": 27, "lines_coords": [[[754.0, 1279.0], [782.0, 1279.0], [782.0, 1387.0], [754.0, 1387.0]], [[718.0, 1282.0], [746.0, 1282.0], [743.0, 1437.0], [715.0, 1437.0]], [[682.0, 1281.0], [709.0, 1281.0], [706.0, 1420.0], [679.0, 1420.0]], [[645.0, 1284.0], [671.0, 1284.0], [671.0, 1525.0], [645.0, 1525.0]], [[609.0, 1282.0], [635.0, 1282.0], [635.0, 1448.0], [609.0, 1448.0]]], "lines": ["．．．こんな", "冗談を言える", "くらいなら、", "たいしたいじめじゃ", "ないのだろう。"]}, {"box": [450, 1282, 547, 1451], "vertical": true, "font_size": 22, "lines_coords": [[[523.0, 1284.0], [545.0, 1284.0], [545.0, 1448.0], [523.0, 1448.0]], [[487.0, 1284.0], [509.0, 1284.0], [509.0, 1410.0], [487.0, 1410.0]], [[451.0, 1284.0], [473.0, 1284.0], [473.0, 1418.0], [451.0, 1418.0]]], "lines": ["この時は、まだ", "その程度に", "考えていた。"]}, {"box": [276, 1295, 304, 1329], "vertical": true, "font_size": 26, "lines_coords": [[[276.0, 1295.0], [304.0, 1295.0], [304.0, 1329.0], [276.0, 1329.0]]], "lines": ["あ"]}, {"box": [110, 1332, 209, 1517], "vertical": true, "font_size": 26, "lines_coords": [[[181.0, 1332.0], [209.0, 1332.0], [209.0, 1448.0], [181.0, 1448.0]], [[145.0, 1332.0], [171.0, 1332.0], [168.0, 1465.0], [142.0, 1465.0]], [[110.0, 1335.0], [132.0, 1335.0], [132.0, 1517.0], [110.0, 1517.0]]], "lines": ["ちょっと、", "ろくろとか", "まわしてみる？"]}], "img_path": "184.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [961, 93, 990, 289], "vertical": true, "font_size": 21, "lines_coords": [[[964.0, 93.0], [985.0, 93.0], [985.0, 285.0], [964.0, 285.0]]], "lines": ["．．．楽しいですね。"]}, {"box": [170, 337, 201, 432], "vertical": true, "font_size": 30, "lines_coords": [[[170.0, 337.0], [200.0, 337.0], [201.0, 432.0], [171.0, 432.0]]], "lines": ["．．．コレ"]}, {"box": [693, 539, 757, 695], "vertical": true, "font_size": 27, "lines_coords": [[[726.0, 539.0], [753.0, 539.0], [756.0, 695.0], [729.0, 695.0]], [[693.0, 542.0], [720.0, 542.0], [720.0, 650.0], [693.0, 650.0]]], "lines": ["：それよりも", "何よりも、"]}, {"box": [529, 538, 633, 709], "vertical": true, "font_size": 29, "lines_coords": [[[604.0, 539.0], [631.0, 539.0], [631.0, 707.0], [604.0, 707.0]], [[565.0, 540.0], [596.0, 540.0], [596.0, 698.0], [565.0, 698.0]], [[529.0, 540.0], [557.0, 540.0], [559.0, 696.0], [531.0, 696.0]]], "lines": ["６月の、湿った", "空気に乗って", "伝わってくる"]}, {"box": [443, 538, 471, 706], "vertical": true, "font_size": 22, "lines_coords": [[[443.0, 540.0], [465.0, 540.0], [465.0, 693.0], [443.0, 693.0]]], "lines": ["彼女の匂いと"]}, {"box": [354, 537, 381, 651], "vertical": true, "font_size": 27, "lines_coords": [[[354.