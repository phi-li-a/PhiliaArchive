.0]], [[93.0, 1034.0], [143.0, 1034.0], [143.0, 1237.0], [93.0, 1237.0]]], "lines": ["他人に傷つけ", "られないための", "一番の方法って", "知ってる？"]}, {"box": [331, 1321, 509, 1553], "vertical": true, "font_size": 65, "lines_coords": [[[425.0, 1326.0], [509.0, 1326.0], [509.0, 1465.0], [425.0, 1465.0]], [[337.0, 1332.0], [434.0, 1321.0], [457.0, 1542.0], [360.0, 1553.0]], [[334.0, 1465.0], [370.0, 1467.0], [367.0, 1535.0], [331.0, 1534.0]]], "lines": ["先に", "殺しちゃ", "え"]}, {"box": [315, 1535, 365, 1575], "vertical": true, "font_size": 65, "lines_coords": [[[315.0, 1535.0], [365.0, 1535.0], [365.0, 1575.0], [315.0, 1575.0]]], "lines": ["ば"]}, {"box": [175, 1448, 246, 1596], "vertical": true, "font_size": 65, "lines_coords": [[[175.0, 1454.0], [232.0, 1448.0], [246.0, 1590.0], [189.0, 1596.0]]], "lines": ["だよ。"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [410, 62, 443, 170], "vertical": true, "font_size": 30, "lines_coords": [[[410.0, 62.0], [443.0, 62.0], [443.0, 170.0], [410.0, 170.0]]], "lines": ["プンプー"]}, {"box": [379, 115, 406, 221], "vertical": true, "font_size": 30, "lines_coords": [[[379.0, 115.0], [406.0, 115.0], [406.0, 221.0], [379.0, 221.0]]], "lines": ["ーンっ！！"]}, {"box": [884, 667, 1004, 895], "vertical": true, "font_size": 31, "lines_coords": [[[970.0, 667.0], [1001.0, 667.0], [1004.0, 895.0], [973.0, 895.0]], [[926.0, 668.0], [959.0, 668.0], [959.0, 860.0], [926.0, 860.0]], [[884.0, 668.0], [915.0, 668.0], [915.0, 860.0], [884.0, 860.0]]], "lines": ["．．．ちょおお～～～", "ガン無視なん", "ですけどぉ！？"]}, {"box": [92, 417, 192, 579], "vertical": true, "font_size": 30, "lines_coords": [[[159.0, 417.0], [192.0, 417.0], [192.0, 554.0], [159.0, 554.0]], [[123.0, 418.0], [154.0, 418.0], [154.0, 579.0], [123.0, 579.0]], [[92.0, 421.0], [118.0, 421.0], [118.0, 578.0], [92.0, 578.0]]], "lines": ["朝練、遅刻", "すんじゃない", "のォーーっ！？"]}, {"box": [817, 990, 939, 1148], "vertical": true, "font_size": 31, "lines_coords": [[[901.0, 990.0], [939.0, 990.0], [939.0, 1057.0], [901.0, 1057.0]], [[860.0, 993.0], [889.0, 993.0], [889.0, 1115.0], [860.0, 1115.0]], [[817.0, 992.0], [843.0, 992.0], [843.0, 1148.0], [817.0, 1148.0]]], "lines": ["何！？", "反抗期！？", "ムカツク！！"]}, {"box": [350, 1020, 449, 1192], "vertical": true, "font_size": 26, "lines_coords": [[[420.0, 1020.0], [446.0, 1020.0], [446.0, 1126.0], [420.0, 1126.0]], [[385.0, 1021.0], [412.0, 1021.0], [412.0, 1181.0], [385.0, 1181.0]], [[350.0, 1023.0], [376.0, 1023.0], [376.0, 1192.0], [350.0, 1192.0]]], "lines": ["あなたの", "更年期障害と", "いい勝負だよ。"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "075.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [293, 957, 421, 1170], "vertical": true, "font_size": 26, "lines_coords": [[[395.0, 960.0], [421.0, 960.0], [421.0, 1143.0], [395.0, 1143.0]], [[362.0, 957.0], [389.0, 957.0], [389.0, 1170.0], [362.0, 1170.0]], [[331.0, 959.0], [357.0, 959.0], [357.0, 1142.0], [331.0, 1142.0]], [[296.0, 960.0], [325.0, 960.0], [321.0, 1093.0], [293.0, 1093.0]]], "lines": ["やっと体育館で", "打てると思ったら", "審判ばっかじゃ", "ねーか！！"]}, {"box": [129, 1003, 253, 1189], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 1003.0], [253.0, 1003.0], [253.0, 1110.0], [225.0, 1110.0]], [[193.0, 1004.0], [220.0, 1004.0], [220.0, 1189.0], [193.0, 1189.0]], [[157.0, 1004.0], [184.0, 1004.0], [187.0, 1137.0], [160.0, 1137.0]], [[129.0, 1006.0], [151.0, 1006.0], [151.0, 1159.0], [129.0, 1159.0]]], "lines": ["朝っから", "やってられっかっ", "つーの！！", "マンコマンユ！！"]}, {"box": [125, 1314, 453, 1469], "vertical": false, "font_size": 117, "lines_coords": [[[203.0, 1322.0], [418.0, 1322.0], [418.0, 1449.0], [203.0, 1449.0]]], "lines": ["はぁっ"]}], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [857, 142, 938, 340], "vertical": true, "font_size": 32, "lines_coords": [[[903.0, 145.0], [934.0, 145.0], [937.0, 340.0], [906.0, 340.0]], [[857.0, 142.0], [890.0, 142.0], [893.0, 321.0], [860.0, 321.0]]], "lines": ["せんばぁ～～", "〜〜〜～～い。"]}, {"box": [203, 134, 281, 375], "vertical": true, "font_size": 32, "lines_coords": [[[248.0, 139.0], [281.0, 139.0], [281.0, 362.0], [248.0, 362.0]], [[206.0, 134.0], [237.0, 134.0], [234.0, 375.0], [203.0, 375.0]]], "lines": ["真面目にやって", "くださぁ～～い。"]}, {"box": [920, 643, 952, 784], "vertical": true, "font_size": 28, "lines_coords": [[[920.0, 646.0], [948.0, 646.0], [948.0, 778.0], [920.0, 778.0]]], "lines": ["．．．．．．あは"]}, {"box": [217, 707, 248, 865], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 709.0], [243.0, 709.0], [243.0, 865.0], [217.0, 865.0]]], "lines": ["あははは！！"]}, {"box": [142, 978, 235, 1261], "vertical": true, "font_size": 30, "lines_coords": [[[203.0, 978.0], [235.0, 978.0], [235.0, 1071.0], [203.0, 1071.0]], [[176.0, 1098.0], [207.0, 1098.0], [207.0, 1260.0], [176.0, 1260.0]], [[142.0, 1103.0], [168.0, 1103.0], [168.0, 1232.0], [142.0, 1232.0]]], "lines": ["センセ。", "ちょっと休憩", "いいスか？"]}, {"box": [932, 1195, 995, 1323], "vertical": true, "font_size": 27, "lines_coords": [[[967.0, 1195.0], [995.0, 1195.0], [995.0, 1259.0], [967.0, 1259.0]], [[932.0, 1195.0], [960.0, 1195.0], [960.0, 1279.0], [932.0, 1279.0]], [[935.0, 1268.0], [957.0, 1268.0], [957.0, 1323.0], [935.0, 1323.0]]], "lines": ["ワリー", "ワリー", "．．．"]}, {"box": [807, 1339, 907, 1523], "vertical": true, "font_size": 27, "lines_coords": [[[879.0, 1339.0], [907.0, 1339.0], [904.0, 1473.0], [876.0, 1473.0]], [[840.0, 1339.0], [871.0, 1339.0], [871.0, 1498.0], [840.0, 1498.0]], [[807.0, 1342.0], [834.0, 1342.0], [834.0, 1523.0], [807.0, 1523.0]]], "lines": ["さっきから", "すげートイレ", "我慢しててさ！！"]}], "img_path": "077.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [854, 85, 957, 298], "vertical": true, "font_size": 30, "lines_coords": [[[926.0, 87.0], [957.0, 87.0], [957.0, 253.0], [926.0, 253.0]], [[890.0, 87.0], [921.0, 87.0], [921.0, 248.0], [890.0, 248.0]], [[856.0, 85.0], [882.0, 85.0], [881.0, 293.0], [854.0, 293.0]]], "lines": ["．．．ま〜〜実際、", "矢口先輩って", "下火だよな〜〜．．．"]}, {"box": [128, 50, 234, 234], "vertical": true, "font_size": 27, "lines_coords": [[[203.0, 51.0], [231.0, 51.0], [231.0, 187.0], [203.0, 187.0]], [[168.0, 50.0], [195.0, 50.0], [192.0, 184.0], [165.0, 184.0]], [[128.0, 51.0], [154.0, 51.0], [159.0, 234.0], [132.0, 234.0]]], "lines": ["今度の県北", "しょーじき", "優勝無理っしょ。"]}, {"box": [496, 492, 671, 729], "vertical": true, "font_size": 27, "lines_coords": [[[645.0, 492.0], [671.0, 492.0], [668.0, 678.0], [642.0, 678.0]], [[607.0, 492.0], [634.0, 492.0], [634.0, 676.0], [607.0, 676.0]], [[570.0, 493.0], [596.0, 493.0], [596.0, 715.0], [570.0, 715.0]], [[531.0, 493.0], [562.0, 493.0], [562.0, 729.0], [531.0, 729.0]], [[496.0, 493.0], [523.0, 493.0], [523.0, 637.0], [496.0, 637.0]]], "lines": ["ちょい前までは", "市内最強だった", "らしいけど、今じゃ", "小松っちゃんに手ぇ", "出ないもん。"]}, {"box": [59, 537, 189, 775], "vertical": true, "font_size": 29, "lines_coords": [[[157.0, 539.0], [189.0, 539.0], [189.0, 726.0], [157.0, 726.0]], [[128.0, 540.0], [150.0, 540.0], [150.0, 775.0], [128.0, 775.0]], [[92.0, 539.0], [120.0, 539.0], [121.0, 726.0], [93.0, 726.0]], [[59.0, 537.0], [85.0, 537.0], [89.0, 682.0], [62.0, 682.0]]], "lines": ["仮に決勝行けた", "としてもシングルは", "小松っちゃんと", "当たる訳で。"]}, {"box": [164, 814, 267, 987], "vertical": true, "font_size": 29, "lines_coords": [[[239.0, 814.0], [267.0, 814.0], [264.0, 973.0], [235.0, 973.0]], [[200.0, 815.0], [232.0, 815.0], [232.0, 976.0], [200.0, 976.0]], [[164.0, 814.0], [195.0, 814.0], [195.0, 987.0], [164.0, 987.0]]], "lines": ["な〜〜〜んか", "せつねーよ", "なーーマンコ。"]}], "img_path": "078.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "079.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [910, 612, 975, 743], "vertical": true, "font_size": 28, "lines_coords": [[[943.0, 612.0], [971.0, 612.0], [975.0, 731.0], [946.0, 731.0]], [[910.0, 614.0], [937.0, 614.0], [937.0, 743.0], [910.0, 743.0]]], "lines": ["．．．．．あぁ、", "矢口先輩？"]}, {"box": [273, 645, 378, 809], "vertical": true, "font_size": 32, "lines_coords": [[[342.0, 645.0], [378.0, 645.0], [378.0, 715.0], [342.0, 715.0]], [[307.0, 646.0], [339.0, 646.0], [339.0, 809.0], [307.0, 809.0]], [[273.0, 648.0], [300.0, 648.0], [300.0, 793.0], [273.0, 793.0]]], "lines": ["うん、", "今朝の朝練で", "試合したよ。"]}, {"box": [142, 753, 250, 920], "vertical": true, "font_size": 32, "lines_coords": [[[215.0, 754.0], [250.0, 754.0], [250.0, 840.0], [215.0, 840.0]], [[179.0, 753.0], [207.0, 753.0], [209.0, 920.0], [181.0, 920.0]], [[142.0, 753.0], [178.0, 753.0], [178.0, 826.0], [142.0, 826.0]]], "lines": ["途中で", "終わっちゃった", "けど。"]}, {"box": [942, 1198, 1009, 1307], "vertical": true, "font_size": 28, "lines_coords": [[[981.0, 1200.0], [1009.0, 1200.0], [1006.0, 1307.0], [978.0, 1307.0]], [[945.0, 1198.0], [973.0, 1198.0], [970.0, 1306.0], [942.0, 1306.0]]], "lines": ["．．．え？", "手加減？"]}, {"box": [675, 1340, 770, 1540], "vertical": true, "font_size": 25, "lines_coords": [[[742.0, 1340.0], [768.0, 1340.0], [767.0, 1540.0], [740.0, 1540.0]], [[707.0, 1343.0], [734.0, 1343.0], [734.0, 1525.0], [707.0, 1525.0]], [[678.0, 1342.0], [700.0, 1342.0], [696.0, 1498.0], [675.0, 1498.0]]], "lines": ["なんで矢口先輩に", "手加減しなきゃ", "ならないの？"]}], "img_path": "080.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [926, 112, 989, 256], "vertical": true, "font_size": 26, "lines_coords": [[[959.0, 112.0], [985.0, 112.0], [989.0, 256.0], [962.0, 256.0]], [[926.0, 117.0], [953.0, 117.0], [953.0, 234.0], [926.0, 234.0]]], "lines": ["．．．あのさぁ、", "プンプン。"]}, {"box": [750, 192, 873, 435], "vertical": true, "font_size": 26, "lines_coords": [[[846.0, 192.0], [873.0, 192.0], [873.0, 300.0], [846.0, 300.0]], [[814.0, 193.0], [840.0, 193.0], [840.0, 415.0], [814.0, 415.0]], [[781.0, 192.0], [807.0, 192.0], [804.0, 403.0], [778.0, 403.0]], [[750.0, 193.0], [771.0, 193.0], [771.0, 435.0], [750.0, 435.0]]], "lines": ["この話は", "僕にとって、とても", "大事なことだから", "言わせてもらうけど、"]}, {"box": [518, 120, 671, 357], "vertical": true, "font_size": 34, "lines_coords": [[[639.0, 123.0], [671.0, 123.0], [671.0, 312.0], [639.0, 312.0]], [[596.0, 120.0], [634.0, 120.0], [634.0, 282.0], [596.0, 282.0]], [[557.0, 121.0], [589.0, 121.0], [589.0, 281.0], [557.0, 281.0]], [[518.0, 120.0], [550.0, 120.0], [550.0, 350.0], [518.0, 350.0]]], "lines": ["コートの中に", "立った以上", "勝ち負けが", "すべてなんだよ。"]}, {"box": [879, 814, 976, 998], "vertical": true, "font_size": 25, "lines_coords": [[[950.0, 815.0], [976.0, 815.0], [976.0, 973.0], [950.0, 973.0]], [[914.0, 814.0], [942.0, 814.0], [939.0, 998.0], [910.0, 998.0]], [[879.0, 818.0], [901.0, 818.0], [901.0, 979.0], [879.0, 979.0]]], "lines": ["先輩にどんな", "事情があるのか", "知らないけど、"]}, {"box": [682, 856, 832, 1098], "vertical": true, "font_size": 25, "lines_coords": [[[806.0, 857.0], [832.0, 857.0], [832.0, 1040.0], [806.0, 1040.0]], [[775.0, 856.0], [801.0, 856.0], [801.0, 1040.0], [775.0, 1040.0]], [[745.0, 857.0], [767.0, 857.0], [767.0, 1014.0], [745.0, 1014.0]], [[710.0, 857.0], [737.0, 857.0], [737.0, 1092.0], [710.0, 1092.0]], [[682.0, 857.0], [704.0, 857.0], [704.0, 1098.0], [682.0, 1098.0]]], "lines": ["コートに入って", "きた以上、僕は", "誰であろうと", "最大の敬意を払って", "徹底的に叩き潰すよ。"]}, {"box": [168, 937, 231, 1081], "vertical": true, "font_size": 27, "lines_coords": [[[204.0, 939.0], [231.0, 939.0], [231.0, 1068.0], [204.0, 1068.0]], [[168.0, 937.0], [195.0, 937.0], [195.0, 1081.0], [168.0, 1081.0]]], "lines": ["これは僕の", "美学だもの。"]}, {"box": [951, 1175, 1014, 1332], "vertical": true, "font_size": 28, "lines_coords": [[[987.0, 1176.0], [1014.0, 1176.0], [1014.0, 1332.0], [987.0, 1332.0]], [[951.0, 1175.0], [978.0, 1175.0], [978.0, 1295.0], [951.0, 1295.0]]], "lines": ["スポーツだけ", "じゃない。"]}, {"box": [767, 1259, 925, 1501], "vertical": true, "font_size": 28, "lines_coords": [[[898.0, 1264.0], [925.0, 1264.0], [925.0, 1451.0], [898.0, 1451.0]], [[865.0, 1265.0], [892.0, 1265.0], [892.0, 1501.0], [865.0, 1501.0]], [[828.0, 1259.0], [865.0, 1259.0], [865.0, 1454.0], [828.0, 1454.0]], [[800.0, 1264.0], [826.0, 1264.0], [826.0, 1448.0], [800.0, 1448.0]], [[767.0, 1264.0], [793.0, 1264.0], [793.0, 1460.0], [767.0, 1460.0]]], "lines": ["人生という同じ", "コートに立っている", "以上、人と人は", "優劣を常に競い", "合うべきなんだ。"]}, {"box": [281, 1210, 382, 1432], "vertical": true, "font_size": 25, "lines_coords": [[[356.0, 1212.0], [382.0, 1212.0], [382.0, 1346.0], [356.0, 1346.0]], [[320.0, 1212.0], [346.0, 1212.0], [346.0, 1398.0], [320.0, 1398.0]], [[282.0, 1210.0], [310.0, 1210.0], [309.0, 1432.0], [281.0, 1432.0]]], "lines": ["人はみんな", "平等や平和って", "言葉が好きだけど、"]}, {"box": [107, 1314, 235, 1532], "vertical": true, "font_size": 25, "lines_coords": [[[214.0, 1315.0], [235.0, 1315.0], [235.0, 1496.0], [214.0, 1496.0]], [[179.0, 1314.0], [201.0, 1314.0], [201.0, 1532.0], [179.0, 1532.0]], [[140.0, 1314.0], [167.0, 1314.0], [167.0, 1498.0], [140.0, 1498.0]], [[107.0, 1317.0], [129.0, 1317.0], [129.0, 1532.0], [107.0, 1532.0]]], "lines": ["僕から言わせて", "もらえば、そんなの", "敗北者達の宗教", "みたいなものだよ。"]}], "img_path": "081.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [873, 164, 971, 350], "vertical": true, "font_size": 25, "lines_coords": [[[945.0, 164.0], [971.0, 164.0], [971.0, 348.0], [945.0, 348.0]], [[909.0, 164.0], [935.0, 164.0], [935.0, 350.0], [909.0, 350.0]], [[873.0, 164.0], [895.0, 164.0], [895.0, 331.0], [873.0, 331.0]]], "lines": ["人は歴史の中で", "争い合うことで", "進歩してきた。"]}, {"box": [667, 196, 834, 446], "vertical": true, "font_size": 25, "lines_coords": [[[812.0, 200.0], [834.0, 200.0], [834.0, 431.0], [812.0, 431.0]], [[773.0, 200.0], [800.0, 200.0], [800.0, 357.0], [773.0, 357.0]], [[737.0, 196.0], [765.0, 196.0], [762.0, 385.0], [734.0, 385.0]], [[700.0, 198.0], [726.0, 198.0], [726.0, 434.0], [700.0, 434.0]], [[667.0, 200.0], [689.0, 200.0], [689.0, 446.0], [667.0, 446.0]]], "lines": ["そして言葉が生まれ", "文化が生まれ", "喜びや悲しみを", "分かち合えるように", "なったんじゃないか。"]}, {"box": [242, 110, 379, 293], "vertical": true, "font_size": 26, "lines_coords": [[[353.0, 110.0], [379.0, 110.0], [379.0, 293.0], [353.0, 293.0]], [[317.0, 110.0], [343.0, 110.0], [343.0, 250.0], [317.0, 250.0]], [[281.0, 110.0], [307.0, 110.0], [307.0, 293.0], [281.0, 293.0]], [[242.0, 110.0], [270.0, 110.0], [270.0, 223.0], [242.0, 223.0]]], "lines": ["人と人が完全に", "同列になり、", "個という意味を", "捨てた時、"]}, {"box": [90, 209, 225, 445], "vertical": true, "font_size": 26, "lines_coords": [[[198.0, 210.0], [225.0, 210.0], [225.0, 395.0], [198.0, 395.0]], [[162.0, 209.0], [189.0, 209.0], [189.0, 445.0], [162.0, 445.0]], [[126.0, 210.0], [148.0, 210.0], [148.0, 393.0], [126.0, 393.0]], [[90.0, 210.0], [117.0, 210.0], [117.0, 345.0], [90.0, 345.0]]], "lines": ["本当の意味での", "生命の喜びを感じる", "ことができると", "思うかい？"]}, {"box": [820, 534, 934, 748], "vertical": true, "font_size": 23, "lines_coords": [[[909.0, 534.0], [931.0, 534.0], [931.0, 687.0], [909.0, 687.0]], [[878.0, 534.0], [901.0, 534.0], [903.0, 689.0], [879.0, 689.0]], [[848.0, 534.0], [875.0, 534.0], [875.0, 748.0], [848.0, 748.0]], [[820.0, 534.0], [840.0, 534.0], [840.0, 732.0], [820.0, 732.0]]], "lines": ["「みんな仲良く", "平等に」なんて", "河原の石ころにしか", "当てはまらないよ。"]}, {"box": [167, 551, 326, 743], "vertical": true, "font_size": 26, "lines_coords": [[[296.0, 553.0], [326.0, 553.0], [326.0, 628.0], [296.0, 628.0]], [[264.0, 551.0], [290.0, 551.0], [290.0, 743.0], [264.0, 743.0]], [[232.0, 553.0], [259.0, 553.0], [259.0, 698.0], [232.0, 698.0]], [[203.0, 554.0], [225.0, 554.0], [225.0, 720.0], [203.0, 720.0]], [[167.0, 556.0], [193.0, 556.0], [193.0, 660.0], [167.0, 660.0]]], "lines": ["誰とも", "争いたくないなら", "無人島にでも", "行ってしまえば", "いいんだ。"]}, {"box": [803, 851, 939, 1075], "vertical": true, "font_size": 27, "lines_coords": [[[912.0, 851.0], [939.0, 851.0], [939.0, 982.0], [912.0, 982.0]], [[876.0, 853.0], [903.0, 853.0], [903.0, 984.0], [876.0, 984.0]], [[839.0, 853.0], [865.0, 853.0], [865.0, 1075.0], [839.0, 1075.0]], [[803.0, 851.0], [829.0, 851.0], [829.0, 1062.0], [803.0, 1062.0]]], "lines": ["．．．そう！！", "僕にとって", "勝利も敗北も、生命", "そのものなんだ！！"]}, {"box": [670, 995, 768, 1154], "vertical": true, "font_size": 27, "lines_coords": [[[742.0, 995.0], [768.0, 995.0], [768.0, 1154.0], [742.0, 1154.0]], [[706.0, 996.0], [734.0, 998.0], [729.0, 1128.0], [701.0, 1126.0]], [[670.0, 996.0], [696.0, 996.0], [696.0, 1103.0], [670.0, 1103.0]]], "lines": ["生きることは", "細胞と魂の", "躍動だ！！"]}, {"box": [304, 846, 403, 1081], "vertical": true, "font_size": 31, "lines_coords": [[[376.0, 848.0], [403.0, 848.0], [403.0, 981.0], [376.0, 981.0]], [[340.0, 851.0], [367.0, 851.0], [367.0, 1057.0], [340.0, 1057.0]], [[304.0, 846.0], [331.0, 846.0], [331.0, 1081.0], [304.0, 1081.0]]], "lines": ["だから僕は", "いつだって全力で", "ぶつかっていくよ！！"]}, {"box": [142, 965, 265, 1189], "vertical": true, "font_size": 31, "lines_coords": [[[226.0, 965.0], [265.0, 965.0], [265.0, 1064.0], [226.0, 1064.0]], [[185.0, 967.0], [218.0, 967.0], [218.0, 1159.0], [185.0, 1159.0]], [[142.0, 967.0], [173.0, 967.0], [173.0, 1189.0], [142.0, 1189.0]]], "lines": ["最高の", "勝利と敗北を", "味わうために！！"]}, {"box": [820, 1329, 950, 1486], "vertical": true, "font_size": 27, "lines_coords": [[[921.0, 1329.0], [950.0, 1329.0], [946.0, 1470.0], [918.0, 1470.0]], [[887.0, 1331.0], [914.0, 1331.0], [914.0, 1462.0], [887.0, 1462.0]], [[854.0, 1331.0], [881.0, 1331.0], [881.0, 1485.0], [854.0, 1485.0]], [[820.0, 1331.0], [846.0, 1331.0], [846.0, 1485.0], [820.0, 1485.0]]], "lines": ["．．．プンプン", "あぁ無知な", "平和主義者の", "ブンブン．．．"]}, {"box": [164, 1318, 302, 1504], "vertical": true, "font_size": 27, "lines_coords": [[[275.0, 1320.0], [301.0, 1320.0], [301.0, 1504.0], [275.0, 1504.0]], [[235.0, 1318.0], [264.0, 1318.0], [265.0, 1479.0], [237.0, 1479.0]], [[201.0, 1321.0], [228.0, 1321.0], [228.0, 1504.0], [201.0, 1504.0]], [[164.0, 1318.0], [190.0, 1318.0], [192.0, 1501.0], [165.0, 1501.0]]], "lines": ["君はそうやって", "生命の歓びを", "知らずに死んで", "ゆくのかい．．．"]}], "img_path": "082.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [556, 573, 582, 768], "vertical": true, "font_size": 26, "lines_coords": [[[556.0, 573.0], [582.0, 573.0], [582.0, 768.0], [556.0, 768.0]]], "lines": ["いや、ちょっと"]}, {"box": [256, 107, 385, 796], "vertical": true, "font_size": 129, "lines_coords": [[[256.0, 107.0], [385.0, 107.0], [385.0, 796.0], [256.0, 796.0]]], "lines": ["「生命の歓びを！！」"]}, {"box": [928, 1054, 957, 1218], "vertical": true, "font_size": 26, "lines_coords": [[[928.0, 1054.0], [954.0, 1054.0], [954.0, 1210.0], [928.0, 1210.0]]], "lines": ["．．．フンフンは"]}, {"box": [765, 1051, 867, 1298], "vertical": true, "font_size": 26, "lines_coords": [[[839.0, 1054.0], [865.0, 1054.0], [865.0, 1232.0], [839.0, 1232.0]], [[803.0, 1054.0], [829.0, 1054.0], [829.0, 1235.0], [803.0, 1235.0]], [[765.0, 1051.0], [792.0, 1051.0], [792.0, 1295.0], [765.0, 1295.0]]], "lines": ["小松っちゃんの", "言うことはよく", "わかりませんでした。"]}, {"box": [635, 979, 700, 1137], "vertical": true, "font_size": 24, "lines_coords": [[[673.0, 979.0], [700.0, 979.0], [700.0, 1137.0], [673.0, 1137.0]], [[639.0, 981.0], [660.0, 981.0], [660.0, 1109.0], [639.0, 1109.0]]], "lines": ["次の授業って", "視聴覚室？"]}, {"box": [510, 1336, 575, 1465], "vertical": true, "font_size": 27, "lines_coords": [[[548.0, 1337.0], [575.0, 1337.0], [575.0, 1465.0], [548.0, 1465.0]], [[510.0, 1337.0], [537.0, 1337.0], [537.0, 1451.0], [510.0, 1451.0]]], "lines": ["フンフンは", "ただただ、"]}, {"box": [113, 1103, 212, 1298], "vertical": true, "font_size": 25, "lines_coords": [[[184.0, 1103.0], [210.0, 1103.0], [210.0, 1235.0], [184.0, 1235.0]], [[146.0, 1103.0], [173.0, 1103.0], [173.0, 1287.0], [146.0, 1287.0]], [[114.0, 1104.0], [135.0, 1104.0], [135.0, 1295.0], [114.0, 1295.0]]], "lines": ["息しないで", "行けるかどうか", "やってみようよ。"]}, {"box": [235, 1335, 449, 1549], "vertical": true, "font_size": 26, "lines_coords": [[[420.0, 1337.0], [448.0, 1337.0], [448.0, 1443.0], [420.0, 1443.0]], [[385.0, 1335.0], [412.0, 1335.0], [412.0, 1493.0], [385.0, 1493.0]], [[348.0, 1337.0], [375.0, 1337.0], [375.0, 1545.0], [348.0, 1545.0]], [[314.0, 1339.0], [335.0, 1339.0], [335.0, 1517.0], [314.0, 1517.0]], [[275.0, 1337.0], [301.0, 1337.0], [301.0, 1495.0], [275.0, 1495.0]], [[239.0, 1335.0], [265.0, 1335.0], [262.0, 1501.0], [235.0, 1501.0]]], "lines": ["みんなが", "幸せになれば", "いいと思うことの", "何かいけないん", "だろうと思う", "ばかりでした。"]}], "img_path": "083.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [840, 68, 981, 306], "vertical": true, "font_size": 26, "lines_coords": [[[953.0, 70.0], [979.0, 70.0], [979.0, 187.0], [953.0, 187.0]], [[917.0, 70.0], [943.0, 70.0], [943.0, 306.0], [917.0, 306.0]], [[881.0, 70.0], [907.0, 70.0], [907.0, 229.0], [881.0, 229.0]], [[843.0, 68.0], [871.0, 68.0], [868.0, 239.0], [840.0, 239.0]]], "lines": ["「みんなも", "自分とは別のことを", "考えているん", "だろうか．．．．．．"]}, {"box": [578, 662, 715, 880], "vertical": true, "font_size": 26, "lines_coords": [[[685.0, 662.0], [714.0, 662.0], [714.0, 793.0], [685.0, 793.0]], [[651.0, 662.0], [678.0, 662.0], [678.0, 871.0], [651.0, 871.0]], [[617.0, 664.0], [639.0, 664.0], [639.0, 845.0], [617.0, 845.0]], [[578.0, 662.0], [604.0, 662.0], [604.0, 876.0], [578.0, 876.0]]], "lines": ["自分以外の", "みんなが、どこか", "別の星から来た", "宇宙人だとしても"]}, {"box": [379, 659, 519, 858], "vertical": true, "font_size": 27, "lines_coords": [[[489.0, 664.0], [515.0, 664.0], [515.0, 795.0], [489.0, 795.0]], [[451.0, 664.0], [479.0, 664.0], [479.0, 795.0], [451.0, 795.0]], [[412.0, 660.0], [440.0, 660.0], [443.0, 820.0], [415.0, 820.0]], [[379.0, 662.0], [406.0, 662.0], [406.0, 856.0], [379.0, 856.0]]], "lines": ["今だったら", "納得できて", "しまいそうな", "ブンブンでした。"]}, {"box": [129, 339, 266, 557], "vertical": true, "font_size": 24, "lines_coords": [[[239.0, 339.0], [265.0, 339.0], [265.0, 478.0], [239.0, 478.0]], [[201.0, 340.0], [228.0, 340.0], [228.0, 546.0], [201.0, 546.0]], [[167.0, 342.0], [189.0, 342.0], [189.0, 520.0], [167.0, 520.0]], [[131.0, 342.0], [153.0, 342.0], [153.0, 557.0], [131.0, 557.0]]], "lines": ["そう思うと、", "なんだかとっても", "恐ろしい気分に", "なってしまいます。"]}], "img_path": "084.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [820, 1291, 857, 1583], "vertical": true, "font_size": 33, "lines_coords": [[[821.0, 1292.0], [854.0, 1292.0], [854.0, 1582.0], [821.0, 1582.0]]], "lines": ["「愛子ちゃんだ！！」"]}], "img_path": "085.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "086.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "087.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [500, 207, 692, 495], "vertical": true, "font_size": 91.5, "lines_coords": [[[573.0, 217.0], [667.0, 207.0], [692.0, 448.0], [598.0, 457.0]], [[500.0, 314.0], [589.0, 314.0], [589.0, 495.0], [500.0, 495.0]]], "lines": ["子ちゃが", "いつも"]}, {"box": [31, 281, 85, 451], "vertical": true, "font_size": 54, "lines_coords": [[[31.0, 282.0], [85.0, 282.0], [85.0, 451.0], [31.0, 451.0]]], "lines": ["第２９話"]}, {"box": [662, 1260, 921, 1562], "vertical": true, "font_size": 259, "lines_coords": [[[662.0, 1260.0], [921.0, 1260.0], [921.0, 1562.0], [662.0, 1562.0]]], "lines": ["答子ちゃんが"]}, {"box": [256, 1282, 609, 1559], "vertical": false, "font_size": 277, "lines_coords": [[[256.0, 1282.0], [609.0, 1282.0], [609.0, 1559.0], [256.0, 1559.0]]], "lines": ["ちっちに口かって大丈夫"]}], "img_path": "088.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "089.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "090.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "091.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [845, 837, 939, 965], "vertical": true, "font_size": 42, "lines_coords": [[[893.0, 837.0], [939.0, 837.0], [939.0, 956.0], [893.0, 956.0]], [[845.0, 839.0], [884.0, 839.0], [884.0, 965.0], [845.0, 965.0]]], "lines": ["超無視", "でした。"]}, {"box": [904, 1123, 992, 1375], "vertical": true, "font_size": 24, "lines_coords": [[[970.0, 1128.0], [992.0, 1128.0], [992.0, 1375.0], [970.0, 1375.0]], [[932.0, 1123.0], [959.0, 1123.0], [962.0, 1340.0], [935.0, 1340.0]], [[904.0, 1126.0], [926.0, 1126.0], [926.0, 1254.0], [904.0, 1254.0]]], "lines": ["いやいや、愛子ちゃんは", "そんな非違い子じゃ", "ありません。"]}, {"box": [902, 1125, 994, 1374], "vertical": true, "font_size": 92, "lines_coords": [[[902.0, 1125.0], [994.0, 1125.0], [994.0, 1374.0], [902.0, 1374.0]]], "lines": ["いやいや、愛子ちゃんはそんな非違い子じゃありません。"]}, {"box": [798, 1126, 820, 1314], "vertical": true, "font_size": 22, "lines_coords": [[[798.0, 1126.0], [820.0, 1126.0], [820.0, 1314.0], [798.0, 1314.0]]], "lines": ["きっと深い事情が"]}, {"box": [764, 1123, 790, 1317], "vertical": true, "font_size": 24, "lines_coords": [[[764.0, 1123.0], [790.0, 1123.0], [790.0, 1317.0], [764.0, 1317.0]]], "lines": ["あるに違いないと"]}, {"box": [734, 1126, 756, 1371], "vertical": true, "font_size": 22, "lines_coords": [[[734.0, 1126.0], [756.0, 1126.0], [756.0, 1371.0], [734.0, 1371.0]]], "lines": ["プンプンは思いました。"]}, {"box": [590, 1123, 683, 1310], "vertical": true, "font_size": 23, "lines_coords": [[[656.0, 1123.0], [682.0, 1123.0], [682.0, 1310.0], [656.0, 1310.0]], [[625.0, 1128.0], [646.0, 1128.0], [646.0, 1268.0], [625.0, 1268.0]], [[592.0, 1128.0], [614.0, 1128.0], [614.0, 1273.0], [592.0, 1273.0]]], "lines": ["「あぁ、なるほど、", "この二年間で", "愛子ちゃんは、"]}, {"box": [429, 1126, 523, 1371], "vertical": true, "font_size": 24, "lines_coords": [[[498.0, 1128.0], [520.0, 1128.0], [520.0, 1292.0], [498.0, 1292.0]], [[465.0, 1128.0], [487.0, 1128.0], [487.0, 1368.0], [465.0, 1368.0]], [[429.0, 1126.0], [456.0, 1126.0], [456.0, 1295.0], [429.0, 1295.0]]], "lines": ["とっても視力が", "落ちてしまったのだね", "はい、はいはい。」"]}, {"box": [323, 1125, 352, 1363], "vertical": true, "font_size": 27, "lines_coords": [[[323.0, 1125.0], [350.0, 1125.0], [350.0, 1362.0], [323.0, 1362.0]]], "lines": ["「．．．だと、いいな．．．．」"]}, {"box": [128, 1123, 226, 1314], "vertical": true, "font_size": 27, "lines_coords": [[[196.0, 1123.0], [223.0, 1123.0], [223.0, 1314.0], [196.0, 1314.0]], [[164.0, 1126.0], [190.0, 1126.0], [190.0, 1268.0], [164.0, 1268.0]], [[128.0, 1125.0], [156.0, 1125.0], [159.0, 1232.0], [131.0, 1232.0]]], "lines": ["プンプンは自分の", "希望的観測に", "辟易です。"]}], "img_path": "092.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [468, 178, 581, 387], "vertical": true, "font_size": 82, "lines_coords": [[[468.0, 190.0], [550.0, 178.0], [581.0, 375.0], [500.0, 387.0]]], "lines": ["なんか、"]}, {"box": [567, 151, 778, 493], "vertical": false, "font_size": 321, "lines_coords": [[[610.0, 151.0], [778.0, 175.0], [734.0, 493.0], [567.0, 470.0]]], "lines": ["それは．．．"]}, {"box": [78, 117, 885, 898], "vertical": true, "font_size": 117.11111111111111, "lines_coords": [[[784.0, 168.0], [885.0, 173.0], [875.0, 421.0], [773.0, 417.0]], [[551.0, 246.0], [679.0, 251.0], [667.0, 629.0], [539.0, 625.0]], [[523.0, 520.0], [584.0, 520.0], [584.0, 717.0], [523.0, 717.0]], [[384.0, 164.0], [514.0, 159.0], [531.0, 732.0], [401.0, 737.0]], [[320.0, 181.0], [440.0, 176.0], [454.0, 614.0], [334.0, 618.0]], [[198.0, 228.0], [340.0, 207.0], [403.0, 657.0], [260.0, 678.0]], [[143.0, 117.0], [312.0, 121.0], [292.0, 898.0], [123.0, 893.0]], [[112.0, 548.0], [223.0, 559.0], [189.0, 890.0], [78.0, 879.0]], [[89.0, 162.0], [176.0, 164.0], [170.0, 679.0], [82.0, 678.0]]], "lines": ["ボタティも", "日の野郎に", "います、", "くるめられて姫２理に", "き合わせれて", "この部分としたい", "はぐるるる的にお目されてることだけど、", "それは、だいよいは", "てるに遠いない"]}, {"box": [457, 571, 510, 745], "vertical": true, "font_size": 50, "lines_coords": [[[457.0, 571.0], [507.0, 571.0], [510.0, 745.0], [460.0, 745.0]]], "lines": ["ここまで"]}, {"box": [704, 167, 909, 906], "vertical": true, "font_size": 91.5, "lines_coords": [[[820.0, 706.0], [906.0, 704.0], [909.0, 904.0], [823.0, 906.0]], [[704.0, 171.0], [801.0, 167.0], [828.0, 760.0], [731.0, 765.0]]], "lines": ["年間", "いや僕のことを想"]}, {"box": [842, 445, 904, 701], "vertical": true, "font_size": 53, "lines_coords": [[[851.0, 445.0], [904.0, 446.0], [895.0, 701.0], [842.0, 700.0]]], "lines": ["いいよこの"]}, {"box": [928, 270, 1007, 693], "vertical": true, "font_size": 72, "lines_coords": [[[928.0, 271.0], [1000.0, 270.0], [1007.0, 692.0], [935.0, 693.0]]], "lines": ["いやいまるほど、"]}, {"box": [110, 1020, 267, 1236], "vertical": true, "font_size": 29, "lines_coords": [[[232.0, 1026.0], [260.0, 1026.0], [260.0, 1157.0], [232.0, 1157.0]], [[193.0, 1025.0], [225.0, 1025.0], [221.0, 1209.0], [190.0, 1209.0]], [[159.0, 1025.0], [187.0, 1025.0], [187.0, 1157.0], [159.0, 1157.0]], [[123.0, 1026.0], [151.0, 1026.0], [151.0, 1156.0], [123.0, 1156.0]]], "lines": ["フンフンは", "なんだか自分が", "嫌になって", "きました。"]}, {"box": [490, 1022, 600, 1268], "vertical": true, "font_size": 30, "lines_coords": [[[570.0, 1023.0], [596.0, 1023.0], [596.0, 1168.0], [570.0, 1168.0]], [[528.0, 1023.0], [559.0, 1023.0], [562.0, 1240.0], [531.0, 1240.0]], [[493.0, 1023.0], [526.0, 1023.0], [523.0, 1268.0], [490.0, 1268.0]]], "lines": ["「矢口先輩は", "そんな悪い人じゃ", "ないやい！！」〈わ〉"]}, {"box": [70, 1320, 482, 1554], "vertical": true, "font_size": 42.888888888888886, "lines_coords": [[[460.0, 1431.0], [482.0, 1431.0], [482.0, 1515.0], [460.0, 1515.0]], [[385.0, 1326.0], [434.0, 1320.0], [465.0, 1525.0], [417.0, 1532.0]], [[342.0, 1331.0], [392.0, 1325.0], [420.0, 1534.0], [370.0, 1540.0]], [[300.0, 1348.0], [343.0, 1342.0], [370.0, 1529.0], [326.0, 1535.0]], [[226.0, 1354.0], [279.0, 1348.0], [295.0, 1471.0], [242.0, 1478.0]], [[139.0, 1351.0], [190.0, 1346.0], [207.0, 1529.0], [156.0, 1534.0]], [[185.0, 1343.0], [225.0, 1339.0], [253.0, 1550.0], [214.0, 1554.0]], [[106.0, 1354.0], [145.0, 1351.0], [157.0, 1518.0], [118.0, 1521.0]], [[70.0, 1353.0], [107.0, 1348.0], [125.0, 1518.0], [87.0, 1523.0]]], "lines": ["皆さん、", "なんか野郎が", "悲しませた", "＞つーことで、", "「シプンは", "わかりたい", "とってもその理由", "つーかんじゃ", "でもたが"]}, {"box": [475, 1423, 528, 1528], "vertical": true, "font_size": 30, "lines_coords": [[[475.0, 1429.0], [504.0, 1423.0], [528.0, 1520.0], [498.0, 1528.0]]], "lines": ["「ここは"]}, {"box": [657, 996, 1006, 1537], "vertical": true, "font_size": 72, "lines_coords": [[[914.0, 1021.0], [982.0, 1012.0], [1006.0, 1203.0], [937.0, 1212.0]], [[854.0, 1010.0], [931.0, 1001.0], [979.0, 1423.0], [903.0, 1432.0]], [[798.0, 1007.0], [868.0, 996.0], [937.0, 1462.0], [867.0, 1473.0]], [[748.0, 1050.0], [829.0, 1039.0], [892.0, 1504.0], [810.0, 1515.0]], [[707.0, 1096.0], [765.0, 1090.0], [796.0, 1373.0], [739.0, 1379.0]], [[659.0, 1106.0], [731.0, 1096.0], [771.0, 1423.0], [700.0, 1432.0]]], "lines": ["ひでぇな", "なんで野郎だ", "先日ご野郎は！！", "嫉妬深水鬼！！", "ヨから一頭を", "みっぱたいでや、"]}], "img_path": "093.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [892, 112, 997, 338], "vertical": true, "font_size": 26, "lines_coords": [[[960.0, 115.0], [987.0, 115.0], [987.0, 323.0], [960.0, 323.0]], [[928.0, 118.0], [954.0, 118.0], [954.0, 275.0], [928.0, 275.0]], [[892.0, 112.0], [918.0, 112.0], [918.0, 337.0], [892.0, 337.0]]], "lines": ["．．．いくら考えても", "わかりそうに", "ありませんでした。"]}, {"box": [409, 113, 645, 330], "vertical": true, "font_size": 28, "lines_coords": [[[607.0, 125.0], [635.0, 125.0], [637.0, 285.0], [609.0, 285.0]], [[571.0, 118.0], [603.0, 118.0], [603.0, 276.0], [571.0, 276.0]], [[535.0, 120.0], [562.0, 120.0], [562.0, 273.0], [535.0, 273.0]], [[496.0, 117.0], [528.0, 117.0], [528.0, 328.0], [496.0, 328.0]], [[464.0, 115.0], [485.0, 115.0], [485.0, 321.0], [464.0, 321.0]], [[426.0, 117.0], [453.0, 117.0], [453.0, 279.0], [426.0, 279.0]]], "lines": ["愛子ちゃんも", "いつのまにか", "全然知らない", "別の愛子ちゃんに", "なってしまったの", "だろうか．．．．．"]}, {"box": [696, 448, 876, 726], "vertical": true, "font_size": 29, "lines_coords": [[[846.0, 453.0], [873.0, 453.0], [873.0, 610.0], [846.0, 610.0]], [[809.0, 451.0], [835.0, 451.0], [835.0, 659.0], [809.0, 659.0]], [[771.0, 450.0], [800.0, 450.0], [801.0, 687.0], [773.0, 687.0]], [[731.0, 448.0], [764.0, 448.0], [767.0, 689.0], [734.0, 689.0]], [[696.0, 448.0], [728.0, 448.0], [729.0, 721.0], [698.0, 721.0]]], "lines": ["それどころか", "先輩もお母さんも", "小松っちゃんも何を", "考えているのかもう", "さっはリチンフンです。"]}, {"box": [293, 504, 472, 744], "vertical": false, "font_size": 28, "lines_coords": [[[307.0, 690.0], [371.0, 576.0], [398.0, 592.0], [334.0, 706.0]], [[329.0, 731.0], [382.0, 623.0], [404.0, 634.0], [351.0, 742.0]]], "lines": ["これからの", "ちょっと"]}, {"box": [920, 992, 976, 1112], "vertical": true, "font_size": 37, "lines_coords": [[[920.0, 998.0], [957.0, 992.0], [976.0, 1106.0], [939.0, 1112.0]]], "lines": ["なさや"]}, {"box": [479, 851, 656, 1051], "vertical": true, "font_size": 28, "lines_coords": [[[628.0, 856.0], [654.0, 856.0], [654.0, 1009.0], [628.0, 1009.0]], [[590.0, 853.0], [618.0, 853.0], [615.0, 985.0], [587.0, 985.0]], [[551.0, 853.0], [582.0, 853.0], [582.0, 1012.0], [551.0, 1012.0]], [[517.0, 851.0], [545.0, 851.0], [542.0, 1034.0], [514.0, 1034.0]], [[481.0, 854.0], [507.0, 854.0], [506.0, 1034.0], [479.0, 1034.0]]], "lines": ["愛子ちゃんは", "僕のことを", "嫌いになって", "しまったんじゃ", "ないかしら．．．"]}], "img_path": "094.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [228, 110, 321, 354], "vertical": true, "font_size": 89, "lines_coords": [[[232.0, 110.0], [321.0, 112.0], [317.0, 354.0], [228.0, 353.0]]], "lines": ["ププップ"]}, {"box": [287, 907, 396, 1070], "vertical": true, "font_size": 34, "lines_coords": [[[354.0, 907.0], [396.0, 907.0], [396.0, 973.0], [354.0, 973.0]], [[326.0, 912.0], [353.0, 912.0], [353.0, 1070.0], [326.0, 1070.0]], [[287.0, 910.0], [320.0, 910.0], [320.0, 1006.0], [287.0, 1006.0]]], "lines": ["胸が", "張り裂けそう", "でした。"]}], "img_path": "095.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [932, 120, 979, 210], "vertical": true, "font_size": 47, "lines_coords": [[[932.0, 120.0], [979.0,