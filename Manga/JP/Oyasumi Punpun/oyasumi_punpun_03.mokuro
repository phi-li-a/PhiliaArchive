が", "幸せなら", "それでいいじゃ", "ないか．．．"]}, {"box": [254, 1027, 281, 1168], "vertical": true, "font_size": 22, "lines_coords": [[[254.0, 1029.0], [276.0, 1029.0], [276.0, 1168.0], [254.0, 1168.0]]], "lines": ["無理でした。"]}], "img_path": "028.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [885, 146, 914, 285], "vertical": true, "font_size": 29, "lines_coords": [[[885.0, 146.0], [914.0, 146.0], [914.0, 243.0], [885.0, 243.0]]], "lines": ["え～～～"]}, {"box": [246, 128, 312, 297], "vertical": true, "font_size": 27, "lines_coords": [[[282.0, 128.0], [309.0, 128.0], [309.0, 284.0], [282.0, 284.0]]], "lines": ["本日は皆様の"]}, {"box": [191, 126, 313, 526], "vertical": true, "font_size": 26, "lines_coords": [[[243.0, 126.0], [270.0, 126.0], [273.0, 293.0], [246.0, 293.0]], [[228.0, 385.0], [254.0, 385.0], [254.0, 518.0], [228.0, 518.0]], [[192.0, 384.0], [218.0, 384.0], [218.0, 526.0], [192.0, 526.0]]], "lines": ["意表を突いて、", "トマト鍋で", "ございます。"]}, {"box": [873, 717, 964, 915], "vertical": true, "font_size": 36, "lines_coords": [[[921.0, 717.0], [960.0, 717.0], [964.0, 915.0], [925.0, 915.0]], [[873.0, 720.0], [906.0, 720.0], [906.0, 868.0], [873.0, 868.0]]], "lines": ["あっ．．．あぁっ", "あたし！！"]}, {"box": [545, 1068, 682, 1256], "vertical": true, "font_size": 27, "lines_coords": [[[654.0, 1073.0], [682.0, 1073.0], [682.0, 1135.0], [654.0, 1135.0]], [[617.0, 1070.0], [645.0, 1070.0], [642.0, 1256.0], [614.0, 1256.0]], [[576.0, 1068.0], [607.0, 1068.0], [607.0, 1226.0], [576.0, 1226.0]], [[545.0, 1071.0], [567.0, 1071.0], [567.0, 1234.0], [545.0, 1234.0]]], "lines": ["．．．まー", "今更こんなこと", "言うのもアレ", "なんですけど、"]}, {"box": [125, 775, 267, 962], "vertical": true, "font_size": 36, "lines_coords": [[[229.0, 776.0], [262.0, 776.0], [262.0, 925.0], [229.0, 925.0]], [[175.0, 775.0], [212.0, 775.0], [212.0, 962.0], [175.0, 962.0]], [[125.0, 775.0], [164.0, 775.0], [164.0, 889.0], [125.0, 889.0]]], "lines": ["あなたが", "本当に好き", "なの！！"]}, {"box": [128, 1100, 225, 1285], "vertical": true, "font_size": 26, "lines_coords": [[[198.0, 1103.0], [225.0, 1103.0], [225.0, 1260.0], [198.0, 1260.0]], [[162.0, 1100.0], [189.0, 1100.0], [185.0, 1285.0], [159.0, 1285.0]], [[128.0, 1103.0], [150.0, 1103.0], [150.0, 1243.0], [128.0, 1243.0]]], "lines": ["いつもながら", "不穏な食卓だね", "このウチは。"]}, {"box": [909, 1301, 947, 1485], "vertical": true, "font_size": 33, "lines_coords": [[[910.0, 1303.0], [943.0, 1303.0], [943.0, 1484.0], [910.0, 1484.0]]], "lines": ["好きなの！！"]}, {"box": [121, 1342, 221, 1551], "vertical": true, "font_size": 26, "lines_coords": [[[193.0, 1343.0], [221.0, 1343.0], [221.0, 1457.0], [193.0, 1457.0]], [[157.0, 1342.0], [184.0, 1342.0], [184.0, 1551.0], [157.0, 1551.0]], [[121.0, 1342.0], [148.0, 1342.0], [148.0, 1500.0], [121.0, 1500.0]]], "lines": ["．．．姉さん、", "仕事はどうだい？", "楽しいかい？"]}], "img_path": "029.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [892, 93, 1031, 331], "vertical": true, "font_size": 25, "lines_coords": [[[1003.0, 96.0], [1031.0, 96.0], [1031.0, 200.0], [1003.0, 200.0]], [[975.0, 95.0], [1001.0, 95.0], [1000.0, 331.0], [973.0, 331.0]], [[945.0, 93.0], [971.0, 93.0], [971.0, 296.0], [945.0, 296.0]], [[920.0, 95.0], [943.0, 95.0], [942.0, 284.0], [918.0, 284.0]], [[892.0, 95.0], [914.0, 95.0], [914.0, 282.0], [892.0, 282.0]]], "lines": ["．．．アンタ、", "スーパーのレジ打ちの", "中年女から、どんな", "おもしろトークが", "飛び出すと思う？"]}, {"box": [518, 192, 582, 351], "vertical": true, "font_size": 27, "lines_coords": [[[554.0, 193.0], [581.0, 193.0], [581.0, 326.0], [554.0, 326.0]], [[518.0, 192.0], [545.0, 192.0], [545.0, 351.0], [518.0, 351.0]]], "lines": ["ため息しか", "出ないわよ！！"]}, {"box": [235, 118, 335, 329], "vertical": true, "font_size": 27, "lines_coords": [[[309.0, 120.0], [335.0, 120.0], [335.0, 312.0], [309.0, 312.0]], [[271.0, 118.0], [298.0, 118.0], [296.0, 329.0], [270.0, 329.0]], [[235.0, 121.0], [262.0, 121.0], [262.0, 304.0], [235.0, 304.0]]], "lines": ["．．．それより雄一、", "アンタいつもより", "口数多くない？"]}, {"box": [120, 314, 218, 479], "vertical": true, "font_size": 27, "lines_coords": [[[192.0, 314.0], [218.0, 314.0], [218.0, 473.0], [192.0, 473.0]], [[156.0, 314.0], [184.0, 314.0], [179.0, 479.0], [151.0, 479.0]], [[120.0, 315.0], [146.0, 315.0], [146.0, 471.0], [120.0, 471.0]]], "lines": ["なんでそんな", "上機嫌なのよ、", "気持ち悪い！！"]}, {"box": [767, 466, 829, 635], "vertical": true, "font_size": 24, "lines_coords": [[[801.0, 518.0], [829.0, 518.0], [829.0, 575.0], [801.0, 575.0]], [[803.0, 468.0], [826.0, 468.0], [826.0, 518.0], [803.0, 518.0]], [[768.0, 467.0], [790.0, 467.0], [790.0, 634.0], [768.0, 634.0]]], "lines": ["．．．", "あー", "失礼しました。"]}, {"box": [867, 779, 1010, 998], "vertical": true, "font_size": 32, "lines_coords": [[[975.0, 779.0], [1007.0, 779.0], [1010.0, 971.0], [978.0, 971.0]], [[939.0, 779.0], [971.0, 779.0], [975.0, 998.0], [942.0, 998.0]], [[906.0, 781.0], [937.0, 781.0], [937.0, 942.0], [906.0, 942.0]], [[867.0, 781.0], [900.0, 781.0], [903.0, 970.0], [870.0, 970.0]]], "lines": ["あたしっ．．．", "あなた無しじゃ", "もう生きて", "いかれない！！"]}, {"box": [187, 837, 309, 1026], "vertical": true, "font_size": 29, "lines_coords": [[[278.0, 839.0], [306.0, 839.0], [306.0, 964.0], [278.0, 964.0]], [[234.0, 839.0], [262.0, 839.0], [262.0, 978.0], [234.0, 978.0]], [[187.0, 837.0], [218.0, 837.0], [218.0, 1026.0], [187.0, 1026.0]]], "lines": ["ああっ．．．", "僕もだよ、", "礼子さんっ！！"]}, {"box": [943, 1214, 970, 1381], "vertical": true, "font_size": 27, "lines_coords": [[[943.0, 1214.0], [970.0, 1214.0], [970.0, 1378.0], [943.0, 1378.0]]], "lines": ["．．．恋、かな．．．？"]}, {"box": [126, 1166, 268, 1509], "vertical": true, "font_size": 35, "lines_coords": [[[231.0, 1170.0], [268.0, 1170.0], [268.0, 1306.0], [231.0, 1306.0]], [[196.0, 1301.0], [234.0, 1301.0], [234.0, 1476.0], [196.0, 1476.0]], [[164.0, 1300.0], [196.0, 1300.0], [196.0, 1464.0], [164.0, 1464.0]], [[126.0, 1303.0], [159.0, 1303.0], [159.0, 1509.0], [126.0, 1509.0]]], "lines": ["ブァッ！？", "んだとコラ、", "もいっぺん", "言ってみろァ！！"]}], "img_path": "030.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [829, 123, 858, 266], "vertical": true, "font_size": 27, "lines_coords": [[[829.0, 123.0], [856.0, 123.0], [856.0, 259.0], [829.0, 259.0]]], "lines": ["プンプンは"]}, {"box": [415, 700, 626, 884], "vertical": true, "font_size": 27, "lines_coords": [[[598.0, 700.0], [626.0, 700.0], [621.0, 832.0], [593.0, 832.0]], [[557.0, 700.0], [589.0, 700.0], [589.0, 860.0], [557.0, 860.0]], [[521.0, 701.0], [550.0, 701.0], [550.0, 832.0], [521.0, 832.0]], [[485.0, 703.0], [512.0, 703.0], [512.0, 884.0], [485.0, 884.0]], [[450.0, 701.0], [476.0, 701.0], [476.0, 884.0], [450.0, 884.0]], [[415.0, 704.0], [437.0, 704.0], [437.0, 857.0], [415.0, 857.0]]], "lines": ["だってまだ", "愛子ちゃんと", "矢口先輩が", "つき合っている", "確証なんて無い", "のですから！！"]}, {"box": [164, 409, 302, 619], "vertical": true, "font_size": 26, "lines_coords": [[[275.0, 410.0], [301.0, 410.0], [301.0, 568.0], [275.0, 568.0]], [[237.0, 410.0], [264.0, 410.0], [264.0, 570.0], [237.0, 570.0]], [[198.0, 409.0], [225.0, 409.0], [225.0, 618.0], [198.0, 618.0]], [[164.0, 410.0], [190.0, 410.0], [190.0, 582.0], [164.0, 582.0]]], "lines": ["ここはひとつ", "冷静に考えて", "みようじゃないか", "と思いました。"]}, {"box": [845, 951, 984, 1136], "vertical": true, "font_size": 28, "lines_coords": [[[954.0, 951.0], [982.0, 951.0], [984.0, 1068.0], [956.0, 1068.0]], [[918.0, 951.0], [945.0, 951.0], [948.0, 1135.0], [921.0, 1135.0]], [[879.0, 951.0], [907.0, 951.0], [907.0, 1059.0], [879.0, 1059.0]], [[845.0, 951.0], [873.0, 951.0], [875.0, 1135.0], [846.0, 1135.0]]], "lines": ["そーです、", "その調子です！！", "クールな", "プンプンです！！"]}, {"box": [863, 1301, 928, 1495], "vertical": true, "font_size": 65, "lines_coords": [[[863.0, 1301.0], [928.0, 1301.0], [928.0, 1495.0], [863.0, 1495.0]]], "lines": ["「仮につき合っていたとしても、"]}, {"box": [859, 1301, 923, 1496], "vertical": true, "font_size": 28, "lines_coords": [[[896.0, 1303.0], [923.0, 1303.0], [923.0, 1496.0], [896.0, 1496.0]], [[859.0, 1301.0], [887.0, 1301.0], [889.0, 1464.0], [860.0, 1464.0]]], "lines": ["「仮につき合って", "いたとしても、"]}, {"box": [718, 1300, 825, 1459], "vertical": true, "font_size": 28, "lines_coords": [[[798.0, 1303.0], [825.0, 1303.0], [825.0, 1459.0], [798.0, 1459.0]], [[760.0, 1303.0], [787.0, 1303.0], [787.0, 1459.0], [760.0, 1459.0]], [[718.0, 1300.0], [757.0, 1300.0], [757.0, 1395.0], [718.0, 1395.0]]], "lines": ["愛子ちゃんの", "先輩への好き", "なんて、"]}, {"box": [626, 1304, 688, 1534], "vertical": true, "font_size": 62, "lines_coords": [[[626.0, 1304.0], [688.0, 1304.0], [688.0, 1534.0], [626.0, 1534.0]]], "lines": ["たいしたことないに決まっとる！！」"]}, {"box": [623, 1303, 684, 1535], "vertical": true, "font_size": 28, "lines_coords": [[[662.0, 1304.0], [684.0, 1304.0], [684.0, 1535.0], [662.0, 1535.0]], [[623.0, 1303.0], [650.0, 1303.0], [650.0, 1473.0], [623.0, 1473.0]]], "lines": ["たいしたことないに", "決まっとる！！」"]}, {"box": [460, 1301, 562, 1434], "vertical": true, "font_size": 28, "lines_coords": [[[532.0, 1301.0], [560.0, 1301.0], [560.0, 1434.0], [532.0, 1434.0]], [[495.0, 1303.0], [523.0, 1303.0], [523.0, 1407.0], [495.0, 1407.0]], [[460.0, 1303.0], [487.0, 1303.0], [487.0, 1434.0], [460.0, 1434.0]]], "lines": ["そーです！！", "フンフン", "超クール！！"]}], "img_path": "031.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [848, 51, 951, 286], "vertical": true, "font_size": 28, "lines_coords": [[[920.0, 51.0], [948.0, 51.0], [950.0, 221.0], [921.0, 221.0]], [[885.0, 53.0], [912.0, 53.0], [912.0, 285.0], [885.0, 285.0]], [[848.0, 53.0], [875.0, 53.0], [875.0, 248.0], [848.0, 248.0]]], "lines": ["「愛子ちゃんは", "もうチュー等はした", "のだろうか．．．．．．」"]}, {"box": [684, 466, 823, 676], "vertical": true, "font_size": 28, "lines_coords": [[[793.0, 468.0], [820.0, 468.0], [820.0, 637.0], [793.0, 637.0]], [[754.0, 467.0], [785.0, 467.0], [785.0, 676.0], [754.0, 676.0]], [[720.0, 468.0], [746.0, 468.0], [746.0, 650.0], [720.0, 650.0]], [[684.0, 467.0], [710.0, 467.0], [710.0, 662.0], [684.0, 662.0]]], "lines": ["「もしかしたら", "もうセックス等を", "してしまったの", "だろうか．．．．．！！」"]}, {"box": [135, 501, 209, 645], "vertical": true, "font_size": 33, "lines_coords": [[[173.0, 501.0], [206.0, 501.0], [209.0, 645.0], [176.0, 645.0]], [[135.0, 503.0], [168.0, 501.0], [171.0, 593.0], [139.0, 595.0]]], "lines": ["．．．プンプン、", "冷静に。"]}, {"box": [844, 817, 936, 965], "vertical": true, "font_size": 36, "lines_coords": [[[893.0, 817.0], [932.0, 817.0], [932.0, 964.0], [893.0, 964.0]], [[846.0, 818.0], [879.0, 818.0], [879.0, 964.0], [846.0, 964.0]]], "lines": ["ブンブン", "冷静に！！"]}, {"box": [523, 1240, 585, 1478], "vertical": true, "font_size": 61, "lines_coords": [[[523.0, 1240.0], [584.0, 1240.0], [584.0, 1478.0], [523.0, 1478.0]]], "lines": ["冷静に！！"]}], "img_path": "032.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [193, 751, 228, 942], "vertical": true, "font_size": 33, "lines_coords": [[[193.0, 754.0], [226.0, 754.0], [226.0, 942.0], [193.0, 942.0]]], "lines": ["．．．プンプン！！"]}, {"box": [481, 1137, 587, 1342], "vertical": true, "font_size": 34, "lines_coords": [[[551.0, 1137.0], [584.0, 1137.0], [587.0, 1257.0], [554.0, 1257.0]], [[517.0, 1139.0], [548.0, 1139.0], [553.0, 1342.0], [521.0, 1342.0]], [[481.0, 1139.0], [517.0, 1139.0], [517.0, 1200.0], [481.0, 1200.0]]], "lines": ["．．．あんた、", "いつまで入ってん", "の！？"]}, {"box": [114, 1332, 235, 1531], "vertical": true, "font_size": 26, "lines_coords": [[[203.0, 1334.0], [235.0, 1334.0], [235.0, 1442.0], [203.0, 1442.0]], [[175.0, 1334.0], [201.0, 1334.0], [201.0, 1493.0], [175.0, 1493.0]], [[142.0, 1332.0], [168.0, 1332.0], [170.0, 1518.0], [143.0, 1518.0]], [[114.0, 1335.0], [135.0, 1335.0], [135.0, 1531.0], [114.0, 1531.0]]], "lines": ["お母さん", "疲れてるから", "さっさと入って", "寝たいんだけど！？"]}], "img_path": "033.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [878, 160, 979, 321], "vertical": true, "font_size": 27, "lines_coords": [[[950.0, 162.0], [978.0, 162.0], [979.0, 301.0], [951.0, 301.0]], [[917.0, 164.0], [943.0, 164.0], [943.0, 321.0], [917.0, 321.0]], [[881.0, 160.0], [907.0, 160.0], [904.0, 306.0], [878.0, 306.0]]], "lines": ["．．．そういや、", "アンタに手紙", "来てたわよ。"]}, {"box": [290, 239, 353, 395], "vertical": true, "font_size": 26, "lines_coords": [[[326.0, 239.0], [353.0, 239.0], [353.0, 395.0], [326.0, 395.0]], [[290.0, 242.0], [317.0, 242.0], [317.0, 356.0], [290.0, 356.0]]], "lines": ["．．．あのヒトも", "マメよね。"]}, {"box": [145, 357, 279, 579], "vertical": true, "font_size": 26, "lines_coords": [[[253.0, 357.0], [279.0, 357.0], [279.0, 523.0], [253.0, 523.0]], [[218.0, 360.0], [245.0, 360.0], [245.0, 565.0], [218.0, 565.0]], [[181.0, 359.0], [207.0, 359.0], [207.0, 568.0], [181.0, 568.0]], [[145.0, 359.0], [171.0, 359.0], [171.0, 579.0], [145.0, 579.0]]], "lines": ["きっかり毎月、", "おもしろくもない", "日々を掘り返して", "手紙よこすなんて。"]}, {"box": [826, 931, 987, 1155], "vertical": true, "font_size": 27, "lines_coords": [[[956.0, 931.0], [984.0, 931.0], [987.0, 1073.0], [959.0, 1073.0]], [[926.0, 932.0], [953.0, 932.0], [953.0, 1090.0], [926.0, 1090.0]], [[892.0, 931.0], [918.0, 931.0], [918.0, 1140.0], [892.0, 1140.0]], [[860.0, 932.0], [887.0, 932.0], [887.0, 1118.0], [860.0, 1118.0]], [[826.0, 931.0], [853.0, 931.0], [856.0, 1154.0], [829.0, 1154.0]]], "lines": ["この手紙は、", "生まれ故郷の", "福島県で水道局の", "夜警をしている", "お父さんからです。"]}, {"box": [817, 1271, 957, 1485], "vertical": true, "font_size": 30, "lines_coords": [[[931.0, 1273.0], [957.0, 1273.0], [957.0, 1485.0], [931.0, 1485.0]], [[893.0, 1273.0], [920.0, 1273.0], [920.0, 1456.0], [893.0, 1456.0]], [[853.0, 1271.0], [884.0, 1271.0], [887.0, 1482.0], [856.0, 1482.0]], [[817.0, 1271.0], [851.0, 1271.0], [851.0, 1364.0], [817.0, 1364.0]]], "lines": ["話題はいつも通り", "巨人軍と宇宙と", "たわいのない内容", "でした。"]}, {"box": [571, 1232, 768, 1531], "vertical": false, "font_size": 30, "lines_coords": [[[659.0, 1435.0], [690.0, 1521.0], [664.0, 1531.0], [632.0, 1445.0]], [[693.0, 1256.0], [768.0, 1450.0], [737.0, 1462.0], [662.0, 1268.0]], [[643.0, 1251.0], [731.0, 1478.0], [704.0, 1487.0], [617.0, 1262.0]], [[598.0, 1254.0], [639.0, 1354.0], [612.0, 1365.0], [571.0, 1265.0]]], "lines": ["．．．", "ハムトバトルのご", "やっぱり何とせっかけ", "だから。"]}, {"box": [95, 1337, 239, 1535], "vertical": true, "font_size": 31, "lines_coords": [[[200.0, 1337.0], [239.0, 1337.0], [239.0, 1425.0], [200.0, 1425.0]], [[168.0, 1342.0], [195.0, 1342.0], [195.0, 1496.0], [168.0, 1496.0]], [[129.0, 1339.0], [160.0, 1339.0], [160.0, 1500.0], [129.0, 1500.0]], [[95.0, 1339.0], [121.0, 1339.0], [123.0, 1534.0], [96.0, 1534.0]]], "lines": ["そして", "いつも通りの", "言葉で、締め", "られていました。"]}], "img_path": "034.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [246, 86, 347, 300], "vertical": true, "font_size": 27, "lines_coords": [[[320.0, 87.0], [346.0, 87.0], [346.0, 215.0], [320.0, 215.0]], [[282.0, 87.0], [309.0, 87.0], [309.0, 295.0], [282.0, 295.0]], [[246.0, 87.0], [273.0, 87.0], [273.0, 298.0], [246.0, 298.0]]], "lines": ["冬の夜空は", "静けさが耳の奥に", "突き刺さるくらい"]}, {"box": [122, 85, 185, 306], "vertical": true, "font_size": 24, "lines_coords": [[[159.0, 85.0], [185.0, 85.0], [185.0, 217.0], [159.0, 217.0]], [[123.0, 89.0], [145.0, 89.0], [145.0, 301.0], [123.0, 301.0]]], "lines": ["どこまでも", "透き通っています。"]}, {"box": [125, 509, 264, 747], "vertical": true, "font_size": 28, "lines_coords": [[[232.0, 510.0], [264.0, 510.0], [264.0, 696.0], [232.0, 696.0]], [[200.0, 512.0], [226.0, 512.0], [226.0, 696.0], [200.0, 696.0]], [[162.0, 512.0], [189.0, 512.0], [189.0, 746.0], [162.0, 746.0]], [[125.0, 509.0], [151.0, 509.0], [151.0, 726.0], [125.0, 726.0]]], "lines": ["実はコーヒーの", "おいしさなんて", "まるでわかってない", "プンブンでしたが、"]}, {"box": [839, 826, 942, 1047], "vertical": true, "font_size": 27, "lines_coords": [[[914.0, 828.0], [940.0, 828.0], [940.0, 1010.0], [914.0, 1010.0]], [[875.0, 826.0], [903.0, 826.0], [904.0, 984.0], [876.0, 984.0]], [[839.0, 828.0], [865.0, 828.0], [868.0, 1043.0], [842.0, 1043.0]]], "lines": ["自分の気持ちが", "少しずつ黒く", "澱んでいることは、"]}, {"box": [170, 1226, 271, 1367], "vertical": true, "font_size": 27, "lines_coords": [[[240.0, 1226.0], [268.0, 1226.0], [270.0, 1365.0], [242.0, 1365.0]], [[204.0, 1226.0], [232.0, 1226.0], [232.0, 1332.0], [204.0, 1332.0]], [[170.0, 1228.0], [196.0, 1228.0], [196.0, 1343.0], [170.0, 1343.0]]], "lines": ["なんとなく、", "気付いて", "いました。"]}], "img_path": "035.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "036.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "037.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [23, 299, 69, 465], "vertical": true, "font_size": 44, "lines_coords": [[[23.0, 301.0], [67.0, 301.0], [67.0, 465.0], [23.0, 465.0]]], "lines": ["第２６話"]}, {"box": [939, 684, 973, 770], "vertical": true, "font_size": 28, "lines_coords": [[[939.0, 684.0], [973.0, 684.0], [973.0, 770.0], [939.0, 770.0]]], "lines": ["え～～"]}, {"box": [806, 757, 903, 940], "vertical": true, "font_size": 28, "lines_coords": [[[876.0, 757.0], [903.0, 757.0], [903.0, 889.0], [876.0, 889.0]], [[840.0, 759.0], [867.0, 759.0], [867.0, 940.0], [840.0, 940.0]], [[806.0, 760.0], [828.0, 760.0], [828.0, 898.0], [806.0, 898.0]]], "lines": ["では以上で", "ホームルームを", "終わります。"]}, {"box": [903, 1050, 969, 1182], "vertical": true, "font_size": 28, "lines_coords": [[[940.0, 1051.0], [967.0, 1051.0], [967.0, 1182.0], [940.0, 1182.0]], [[906.0, 1050.0], [934.0, 1050.0], [931.0, 1181.0], [903.0, 1181.0]]], "lines": ["特にありま", "せーーん！！"]}, {"box": [138, 724, 238, 907], "vertical": true, "font_size": 25, "lines_coords": [[[206.0, 725.0], [234.0, 725.0], [234.0, 831.0], [206.0, 831.0]], [[171.0, 725.0], [198.0, 725.0], [198.0, 907.0], [171.0, 907.0]], [[139.0, 725.0], [160.0, 725.0], [160.0, 853.0], [139.0, 853.0]]], "lines": ["委員長！！", "他に何か連絡は", "あるかな？"]}, {"box": [620, 1328, 653, 1435], "vertical": true, "font_size": 27, "lines_coords": [[[620.0, 1328.0], [653.0, 1328.0], [653.0, 1435.0], [620.0, 1435.0]]], "lines": ["．．．ハイ！！"]}, {"box": [528, 1393, 