, 375.0], [3269.0, 379.0]], [[3675.0, 337.0], [3789.0, 337.0], [3789.0, 371.0], [3675.0, 371.0]], [[3273.0, 367.0], [3500.0, 363.0], [3500.0, 409.0], [3273.0, 413.0]], [[3273.0, 401.0], [3660.0, 394.0], [3660.0, 440.0], [3273.0, 447.0]], [[3277.0, 439.0], [3595.0, 435.0], [3595.0, 474.0], [3277.0, 477.0]], [[3273.0, 466.0], [3664.0, 469.0], [3664.0, 515.0], [3273.0, 512.0]], [[3273.0, 504.0], [3569.0, 504.0], [3569.0, 549.0], [3273.0, 549.0]], [[3792.0, 462.0], [3846.0, 466.0], [3834.0, 652.0], [3781.0, 648.0]], [[3269.0, 538.0], [3603.0, 534.0], [3603.0, 580.0], [3269.0, 584.0]], [[3277.0, 572.0], [3576.0, 572.0], [3576.0, 618.0], [3277.0, 618.0]], [[3280.0, 610.0], [3580.0, 610.0], [3580.0, 644.0], [3280.0, 644.0]], [[3728.0, 576.0], [3819.0, 598.0], [3785.0, 735.0], [3694.0, 713.0]], [[3277.0, 636.0], [3569.0, 636.0], [3569.0, 682.0], [3277.0, 682.0]], [[3277.0, 670.0], [3535.0, 670.0], [3535.0, 716.0], [3277.0, 716.0]], [[3273.0, 697.0], [3789.0, 697.0], [3789.0, 754.0], [3273.0, 754.0]], [[3273.0, 739.0], [3645.0, 735.0], [3645.0, 781.0], [3273.0, 785.0]], [[3277.0, 780.0], [3497.0, 780.0], [3497.0, 815.0], [3277.0, 815.0]], [[3273.0, 807.0], [3565.0, 799.0], [3565.0, 845.0], [3273.0, 853.0]], [[3273.0, 837.0], [3557.0, 841.0], [3557.0, 891.0], [3273.0, 887.0]], [[3277.0, 883.0], [3489.0, 875.0], [3489.0, 910.0], [3277.0, 917.0]], [[3280.0, 913.0], [3561.0, 913.0], [3561.0, 948.0], [3280.0, 948.0]], [[3284.0, 947.0], [3497.0, 947.0], [3497.0, 982.0], [3284.0, 982.0]], [[3352.0, 974.0], [3713.0, 970.0], [3713.0, 1016.0], [3352.0, 1020.0]], [[3284.0, 1008.0], [3751.0, 1008.0], [3751.0, 1054.0], [3284.0, 1054.0]], [[3318.0, 1065.0], [3789.0, 1065.0], [3789.0, 1099.0], [3318.0, 1099.0]], [[3311.0, 1095.0], [3800.0, 1095.0], [3800.0, 1130.0], [3311.0, 1130.0]]], "lines": ["おやすみプンプンソニーン，《Ｃ＃", "おやすみプンプンソラニン・全２巻ロドコト・診断で", "ソラニン・全２巻ロバコトー診療所・コール・", "封いに山田貴とある", "ロールーングラフィーーーインをご利用いただきますので、お客様のお客さんにご相談くださいます。", "ＰＡＮＥＵデイー１１－００巻、新たな", "鉄腕バーディー１〜１０巻都立水商ー１－２０巻クロサギューの＃", "「いつさまご光、猪熊しの甲さんも", "都立水商１，１〜２０巻クロサギ・１～１０巻イキガミーナー", "クロサキ、１－２０巻イキガミコールＨｏｌｔｍａｔｅｌｉｍｅｔｉｎｔ－１－１５の大声（エグラ）の間．．．", "イキカミールはＵＴｍａｚｅＬｉｎｔ、主義（モグラ）の唄・１－１）巻、契価をお悩み・ルーランプ", "土竜代クラの明日「トール春超無気力戦隊ジャパフィフィー」ではないでしょう。", "超無気力戦隊ンヤットローオッズ・コーロ巻さんは、メニューハッドの", "このためには、お客様における方は", "しかしＧ－オッスー「一日巻き」さらんぽジトローム・グドックスになりました。スポーツを", "さてらんはシントロームプロのタナトスをしたらの時、コープ巻くとめばわっしゃいます。", "＞＞１７．２０１９年とめはねっ！！鈴里高校講演部・ビューター・", "落合館の前合決算．．．病院であるなかは、", "とめはねっ「命里菊校書館ビーチスターズ・１～日巻", "ビーチスタース、１〜６０ＵＴ－活人－１〜２巻－米大金曜土・成田城", "○○「おい、トークラー」などとなりますが、週末期間中間、１－５巻一高田区の大阪市場所には大阪府南京都市に大阪大阪駅から", "過亡弁護士・成田誠、１－１－５巻、まっちは右の制読も通」「１－４巻未根ヲ晴のゲントーン９巻", "まっちゃんは、魔口ケン・１〜２巻、羊時セランジング", "廃園ケン・１～２巻美晴♥ライシング「ーー」を階のイージア", "美晴♥ライジンクーーン第のイージス、１〜４巻アオイホノオ「巻", "晩のアオイホノオ「巻、ニァ", "アオイハンイーーーっあんころ。お姉ちゃん「目は馬鹿先」のいい", "あれこつ。施術者は、ＧＯ－ＯＮＵ－１～２巻", "ＤＶＮ－１－２巻オーヤングサンデーコミックススペシャルオイルカフリートのＷｅｒＦａｃｈｉｎｄｅｒ", "結婚は、ヤグサンテーエックススペシャルの設置に対くクスリロについては巻くのは、", "ｈｔｔｐ／／ｗｗｗ．ｙｏｕｎｇｓｕｒｉｇｙｏｎ．", "アクセスをコンピューターにしていますが、"]}, {"box": [3349, 1126, 3698, 1156], "vertical": false, "font_size": 26, "lines_coords": [[[3349.0, 1126.0], [3698.0, 1129.0], [3698.0, 1156.0], [3349.0, 1152.0]]], "lines": ["つをオンラインショップで購入すること"]}, {"box": [3338, 1278, 3775, 1497], "vertical": false, "font_size": 36, "lines_coords": [[[3462.0, 1278.0], [3637.0, 1278.0], [3637.0, 1322.0], [3462.0, 1322.0]], [[3409.0, 1327.0], [3701.0, 1327.0], [3701.0, 1360.0], [3409.0, 1360.0]], [[3345.0, 1346.0], [3758.0, 1342.0], [3758.0, 1390.0], [3345.0, 1394.0]], [[3409.0, 1388.0], [3690.0, 1388.0], [3690.0, 1409.0], [3409.0, 1409.0]], [[3356.0, 1399.0], [3758.0, 1399.0], [3758.0, 1443.0], [3356.0, 1443.0]], [[3356.0, 1456.0], [3762.0, 1456.0], [3762.0, 1500.0], [3356.0, 1500.0]]], "lines": ["浅野いにお", "１９８０年生まれ。茨城県出身。１年第１回サンゴーへと新しい", "２０１１年３０年生まれ。茨城県出身。２００１年、第１回サンデーＣＡ新人賞入賞・主な業者に「支職らしい出現」", "主な著作に「素晴らしい世界", "「土を基準作に「素晴らしい世界」「ひかりのまちいともに少社刊」がある。インラーン「全く美美さんよ」が", "全国はリラーン「全会巻」小社内）が、全国より世代・性別を超えた大反響性に。"]}], "img_path": "001.png"}, {"version": "0.2.0-beta.6", "img_width": 3884, "img_height": 1600, "blocks": [{"box": [1744, 208, 1797, 928], "vertical": true, "font_size": 50, "lines_coords": [[[1744.0, 208.0], [1794.0, 208.0], [1794.0, 921.0], [1744.0, 921.0]]], "lines": ["おやすみプンプンの「浅野い」お"]}, {"box": [766, 1023, 1854, 1084], "vertical": false, "font_size": 53, "lines_coords": [[[766.0, 1031.0], [1854.0, 1023.0], [1854.0, 1076.0], [766.0, 1084.0]]], "lines": ["大推薦！浅野いにお衝撃作！！"]}, {"box": [14, 1192, 612, 1536], "vertical": false, "font_size": 189, "lines_coords": [[[68.0, 1211.0], [598.0, 1336.0], [560.0, 1536.0], [26.0, 1411.0]]], "lines": ["Ｓｔｆｉｃｅを"]}, {"box": [771, 1127, 1499, 1484], "vertical": false, "font_size": 38, "lines_coords": [[[925.0, 1164.0], [1448.0, 1160.0], [1448.0, 1204.0], [925.0, 1208.0]], [[777.0, 1168.0], [944.0, 1168.0], [944.0, 1212.0], [777.0, 1212.0]], [[1164.0, 1198.0], [1452.0, 1195.0], [1452.0, 1231.0], [1164.0, 1235.0]], [[1164.0, 1229.0], [1452.0, 1229.0], [1452.0, 1261.0], [1164.0, 1261.0]], [[773.0, 1214.0], [1077.0, 1221.0], [1077.0, 1295.0], [773.0, 1288.0]], [[1164.0, 1263.0], [1448.0, 1263.0], [1448.0, 1284.0], [1164.0, 1284.0]], [[1179.0, 1282.0], [1414.0, 1282.0], [1414.0, 1314.0], [1179.0, 1314.0]], [[1354.0, 1354.0], [1467.0, 1354.0], [1467.0, 1402.0], [1354.0, 1402.0]]], "lines": ["もし、これは少年だろうと思いませんがしてくれるので、", "峯田和伸ｓ", "を描いた漫画なんか、少年たち自身の目線から描かれた。ちは松本サービス", "ジキたら自身、わた、奇跡的なオルタナティブロックは両手と", "銀杏ボーイ", "いた、ｗｗｗ．．．ヴロック漫画だ。どか言って", "ウロック漫画だ。．．．とか言みたりして。ごにょごによ」", "ファ"]}, {"box": [777, 1491, 1154, 1587], "vertical": false, "font_size": 105, "lines_coords": [[[777.0, 1482.0], [1154.0, 1482.0], [1154.0, 1596.0], [777.0, 1596.0]]], "lines": ["柴崎友香氏"]}, {"box": [1877, 959, 1985, 1515], "vertical": true, "font_size": 76, "lines_coords": [[[1907.0, 959.0], [1983.0, 963.0], [1953.0, 1505.0], [1877.0, 1501.0]]], "lines": ["オーバー、浅野いにお衝撃作！！"]}, {"box": [2503, 72, 2810, 185], "vertical": false, "font_size": 44, "lines_coords": [[[2507.0, 72.0], [2810.0, 72.0], [2810.0, 121.0], [2507.0, 121.0]], [[2503.0, 147.0], [2662.0, 147.0], [2662.0, 185.0], [2503.0, 185.0]]], "lines": ["ＳＢＮ９７８－４－４９－１５１３８－５", "Ｃ９９７９＼５１