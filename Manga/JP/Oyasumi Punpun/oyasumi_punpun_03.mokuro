[3273.0, 679.0]], [[3277.0, 669.0], [3535.0, 669.0], [3535.0, 717.0], [3277.0, 717.0]], [[3277.0, 704.0], [3800.0, 704.0], [3800.0, 751.0], [3277.0, 751.0]], [[3273.0, 738.0], [3645.0, 734.0], [3645.0, 782.0], [3273.0, 786.0]], [[3667.0, 741.0], [3789.0, 741.0], [3789.0, 778.0], [3667.0, 778.0]], [[3277.0, 779.0], [3504.0, 779.0], [3504.0, 816.0], [3277.0, 816.0]], [[3273.0, 806.0], [3572.0, 798.0], [3572.0, 846.0], [3273.0, 854.0]], [[3732.0, 813.0], [3785.0, 813.0], [3785.0, 839.0], [3732.0, 839.0]], [[3694.0, 829.0], [3796.0, 840.0], [3792.0, 888.0], [3690.0, 877.0]], [[3273.0, 836.0], [3584.0, 840.0], [3584.0, 892.0], [3273.0, 888.0]], [[3277.0, 882.0], [3497.0, 874.0], [3497.0, 911.0], [3277.0, 918.0]], [[3269.0, 908.0], [3626.0, 901.0], [3626.0, 949.0], [3269.0, 956.0]], [[3277.0, 935.0], [3512.0, 946.0], [3512.0, 994.0], [3277.0, 983.0]]], "lines": ["ＹｏｕＮｅｓＵＮＤＡＹＣＯＮ", "おやすみプンプンソラーン、全Ｃ業", "おやすみプンプンソラニン・全２巻「ｒ－コトー診療所", "浅野いに浅野ぃに", "ソラニン・全２巻ロバコトー診療所・１〜２２巻ＢＡＮＡＧＡＴＯＶ－Ｓｔａｒｉｏｔａｌｌ－ｃの", "多いに山田貴様あるお", "ロコートを参考する際に、「２０１４年１１月１０日にごめん」においております。実際に実際ハーティー・１１時", "ＦＡＮＥＵＶ－Ｆｉｒｅ鉄腕バーディー１〜１０巻類されましょうのは", "鉄腕バーディー１〜１０巻都立水商１－１－２０巻クロサギーユーのは", "都立水商１，１〜２０巻クロサギ・１〜４０巻イキガミーナーは", "クロサギーーー２０巻イキガミットはＵＨＴｍａｔｉｍｅＬｉｎｔ．Ｔｗｉｔｔｅｒです。すでに", "イキカミＴｉｎｅＵｎｍａｔｉｎｔ－１土恵（モグラ）の唄】１～１４巻協会が開催：カバーファイトの", "土竜代クラの唄１－１１巻超無気力削除シャバフィグ１－９巻ＯｎｔＢ－オッズ・１・９巻", "超無気力戦隊シャバファイフロｔｕｂｅ－オッズ・１〜９巻さんはマンドロームビッグの", "ＯＴＬＥＧオッズ－１〜日巻さぐらんぼンドローム２４の戦いタイトスポールの魅力・コープ等、", "．．．", "いや．．．そういうことで、私はそうだったのだけじゃないか", "こっちんはントローバングのタナトスさしげらのキーマンスも、", "タナトメもルルの楽しみをとめはねっ！！鈴里高校着道部－ビーチフターデューニュームを", "とめはねっ！鈴里高校爆道部ビーチスターズ、１〜日巻『ハテーキル』１〜２巻", "ビーチスタース１～６８０ＵＴ－活人－１〜２巻－逃亡弁護士・成田誠", "ＯＵＪＪＲＡ、１－２巻、１２巻。ここである方は、２０１７年２月２５日土大阪東京大阪府大阪市東京都大阪駅東京オリンピックストリークスクリーム", "逆色弁護士・成田誠・１・日巻一まつ政府の認知識・１－４巻未根ラケン・コータ業", "・高田優・剛英タサムノ恒川光太", "まっちは分かります。魔口ケン・１〜２巻一美時サライジング", "魔口ケン・１～２巻美晴♥ライジング・１〜４巻席のイージア", "「当国の大谷じゃ", "一大谷じろ第一ノ藤原芳", "美晴♥ライジング・１〜４巻暁のイージス・１～４巻アオイホノオ・１巻", "暁のイーシスー〜んアオイホノオ「巻あんころ", "アオイホノオ「巻あんころ。紙掲ＮｉＴＨＥＢＳ」にＧＰＯ「ＮＵ－１－２９第", "あんころ。納得小門間は、ＧＯ－ＯＮＵ１－２巻"]}, {"box": [2184, 1038, 2939, 1076], "vertical": false, "font_size": 38, "lines_coords": [[[2184.0, 1038.0], [2939.0, 1038.0], [2939.0, 1076.0], [2184.0, 1076.0]]], "lines": ["パパとママが離婚。ママと叔父さんと暮らす少年・ブンブン。"]}, {"box": [2215, 1242, 2449, 1534], "vertical": true, "font_size": 234, "lines_coords": [[[2215.0, 1242.0], [2449.0, 1242.0], [2449.0, 1534.0], [2215.0, 1534.0]]], "lines": ["これを捨て人のように引きつけたほうがしまんこは、おそう感覚もありますが．．．！？"]}, {"box": [2844, 1342, 2882, 1463], "vertical": true, "font_size": 38, "lines_coords": [[[2844.0, 1342.0], [2882.0, 1342.0], [2882.0, 1463.0], [2844.0, 1463.0]]], "lines": ["うな片思いの"]}], "img_path": "002.png"}, {"version": "0.2.0-beta.6", "img_width": 2380, "img_height": 1600, "blocks": [{"box": [152, 769, 204, 1364], "vertical": true, "font_size": 32, "lines_coords": [[[160.0, 769.0], [192.0, 769.0], [192.0, 1304.0], [160.0, 1304.0]]], "lines": ["おやすみフンフン。"]}, {"box": [79, 1162, 125, 1375], "vertical": true, "font_size": 33, "lines_coords": [[[83.0, 1162.0], [116.0, 1162.0], [118.0, 1369.0], [85.0, 1369.0]]], "lines": ["浅野いにお"]}, {"box": [1159, 73, 1230, 131], "vertical": false, "font_size": 63, "lines_coords": [[[1159.0, 68.0], [1230.0, 68.0], [1230.0, 136.0], [1159.0, 136.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹＧＯＭＩＣＳ"]}, {"box": [1176, 118, 1215, 865], "vertical": true, "font_size": 39, "lines_coords": [[[1176.0, 118.0], [1215.0, 118.0], [1215.0, 865.0], [1176.0, 865.0]]], "lines": ["おやすみプンプンっと、浅野いにお"]}], "img_path": "003.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [946, 201, 1007, 925], "vertical": true, "font_size": 54, "lines_coords": [[[954.0, 201.0], [1007.0, 201.0], [1000.0, 925.0], [946.0, 925.0]]], "lines": ["おやすみプンプン●、浅野いにお"]}, {"box": [64, 1499, 271, 1523], "vertical": false, "font_size": 22, "lines_coords": [[[68.0, 1499.0], [265.0, 1501.0], [265.0, 1525.0], [68.0, 1523.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹＣＯＭＣＳ"]}], "img_path": "004.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [123, 315, 565, 445], "vertical": false, "font_size": 30.666666666666668, "lines_coords": [[[125.0, 315.0], [410.0, 317.0], [410.0, 350.0], [125.0, 348.0]], [[126.0, 373.0], [443.0, 376.0], [443.0, 404.0], [126.0, 401.0]], [[123.0, 414.0], [565.0, 414.0], [565.0, 445.0], [123.0, 445.0]]], "lines": ["２巻までのあらすじ", "プンプンは、なんだかんだで", "とるに足らない中学生にしなったようです。"]}, {"box": [132, 526, 267, 559], "vertical": false, "font_size": 33, "lines_coords": [[[132.0, 526.0], [267.0, 526.0], [267.0, 559.0], [132.0, 559.0]]], "lines": ["登場人物"]}, {"box": [200, 592, 643, 651], "vertical": false, "font_size": 27.0, "lines_coords": [[[200.0, 593.0], [375.0, 592.0], [375.0, 620.0], [200.0, 621.0]], [[204.0, 625.0], [643.0, 625.0], [643.0, 651.0], [204.0, 651.0]]], "lines": ["小野寺プンプン", "旧姓・プン山プンプン。チョコ・パイ好きのヤングガイ。"]}, {"box": [203, 682, 603, 739], "vertical": false, "font_size": 30.0, "lines_coords": [[[203.0, 682.0], [426.0, 682.0], [426.0, 715.0], [203.0, 715.0]], [[203.0, 712.0], [603.0, 712.0], [603.0, 739.0], [203.0, 739.0]]], "lines": ["小野寺プンプンママ", "ブンブンの母親。離婚後も性格は相変わらず。"]}, {"box": [776, 128, 906, 895], "vertical": true, "font_size": 53, "lines_coords": [[[814.0, 128.0], [906.0, 128.0], [906.0, 167.0], [814.0, 167.0]], [[787.0, 184.0], [803.0, 184.0], [803.0, 207.0], [787.0, 207.0]], [[779.0, 210.0], [810.0, 210.0], [807.0, 895.0], [776.0, 895.0]]], "lines": ["次", "そういえば、", "第第２９第１第第３第第１３第１２条第１５条第項第第号第１１第条第２第１９条第第第５項第２３第２２第第７第１８条第「第３１第１６第２６第３２３１２第３項第３３第３号、第第項、第３０第第一第第、第１７第３条第３６第１０第３５第１４３第項「第２８第第６第項の第３７第２５３第７条第５第５号第２項第１の第２０３第５条、第２４第２１第３の第第条項第項・第１号第第４第３８第１項第一条第条の第１条第７３第６条第６項第、東京・第第二第２号・第３９第第十条第号「第１回第３期、第５回第２の第５３１３号第３第１１第１９第一第一条第二第一項の第二条第十条第項第条第条項第２項第第２３項第１項第３第１第第１２第１６第２第２６第１３第２１第３１第２２第第３項、第１７第１５項第７第２８第１８第２９第２４第２０第１０第２号、第２の第２５第２７第３３第３２第３条第１号の第１４項第５第１の第３号第２回第１回第２条第２期第１発表の第号の発表第１条第３の第第第一策、第７項第項「第１"]}, {"box": [814, 209, 978, 879], "vertical": true, "font_size": 53, "lines_coords": [[[935.0, 212.0], [978.0, 212.0], [978.0, 865.0], [935.0, 865.0]], [[882.0, 209.0], [925.0, 209.0], [925.0, 876.0], [882.0, 876.0]], [[821.0, 214.0], [878.0, 214.0], [878.0, 242.0], [821.0, 242.0]], [[814.0, 254.0], [882.0, 254.0], [882.0, 879.0], [814.0, 879.0]]], "lines": ["もちまちがあたりなのは", "話諾話話詁話話詰話話", "２４", "２５８７８２９３０３１２３"]}, {"box": [203, 1135, 257, 1165], "vertical": false, "font_size": 30, "lines_coords": [[[203.0, 1135.0], [257.0, 1135.0], [257.0, 1165.0], [203.0, 1165.0]]], "lines": ["清水"]}, {"box": [206, 1079, 504, 1100], "vertical": false, "font_size": 21, "lines_coords": [[[206.0, 1079.0], [504.0, 1079.0], [504.0, 1100.0], [206.0, 1100.0]]], "lines": ["同級生。アル中気味の父親を持つ。"]}, {"box": [204, 1167, 412, 1189], "vertical": false, "font_size": 22, "lines_coords": [[[204.0, 1167.0], [412.0, 1167.0], [412.0, 1189.0], [204.0, 1189.0]]], "lines": ["同級生。関しは幼なじみ。"]}, {"box": [198, 768, 596, 832], "vertical": false, "font_size": 36.0, "lines_coords": [[[198.0, 768.0], [337.0, 768.0], [337.0, 814.0], [198.0, 814.0]], [[203.0, 801.0], [596.0, 806.0], [596.0, 832.0], [203.0, 828.0]]], "lines": ["小野寺雄一プンプンママの", "コブンブンママの弟。３３歳。プップンと同居中。"]}, {"box": [203, 865, 706, 921], "vertical": false, "font_size": 27.0, "lines_coords": [[[204.0, 865.0], [306.0, 865.0], [306.0, 893.0], [204.0, 893.0]], [[203.0, 895.0], [706.0, 895.0], [706.0, 921.0], [203.0, 921.0]]], "lines": ["田中愛子", "小学生時代に好きだった女の子。二年間会話は一切無し。"]}, {"box": [192, 957, 576, 1010], "vertical": false, "font_size": 22.0, "lines_coords": [[[193.0, 957.0], [254.0, 957.0], [254.0, 979.0], [193.0, 979.0]], [[192.0, 985.0], [576.0, 989.0], [576.0, 1010.0], [192.0, 1007.0]]], "lines": ["小松", "同級生。生粋の右利き。バドミントン部所属。"]}, {"box": [779, 868, 971, 943], "vertical": true, "font_size": 53, "lines_coords": [[[935.0, 879.0], [971.0, 879.0], [971.0, 918.0], [935.0, 918.0]], [[779.0, 885.0], [887.0, 885.0], [887.0, 920.0], [779.0, 920.0]], [[864.0, 907.0], [903.0, 868.0], [939.0, 904.0], [900.0, 943.0]]], "lines": ["１８", "第３４", "ぶ"]}, {"box": [792, 1095, 862, 1182], "vertical": false, "font_size": 34, "lines_coords": [[[792.0, 1165.0], [831.0, 1095.0], [862.0, 1112.0], [821.0, 1182.0]]], "lines": ["それ"]}, {"box": [195, 1214, 387, 1289], "vertical": false, "font_size": 36.0, "lines_coords": [[[195.0, 1223.0], [254.0, 1214.0], [260.0, 1253.0], [201.0, 1262.0]], [[203.0, 1250.0], [387.0, 1256.0], [385.0, 1289.0], [201.0, 1282.0]]], "lines": ["先輩", "ブドミントン部の先輩。"]}, {"box": [201, 1317, 592, 1437], "vertical": false, "font_size": 32.0, "lines_coords": [[[204.0, 1317.0], [259.0, 1317.0], [259.0, 1348.0], [204.0, 1348.0]], [[201.0, 1339.0], [592.0, 1339.0], [592.0, 1376.0], [201.0, 1376.0]], [[201.0, 1406.0], [385.0, 1409.0], [385.0, 1437.0], [201.0, 1434.0]]], "lines": ["湯上", "「ブンブツママの糖質問題を担当した弁護士」", "喫茶店の女の子"]}, {"box": [200, 1439, 562, 1460], "vertical": false, "font_size": 21, "lines_coords": [[[200.0, 1439.0], [562.0, 1439.0], [562.0, 1460.0], [200.0, 1460.0]]], "lines": ["雄一はどこかで見憶えがあるようだが．．．！？"]}], "img_path": "005.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [831, 107, 932, 298], "vertical": true, "font_size": 28, "lines_coords": [[[901.0, 109.0], [932.0, 109.0], [932.0, 298.0], [901.0, 298.0]], [[862.0, 107.0], [893.0, 107.0], [896.0, 293.0], [865.0, 293.0]], [[831.0, 109.0], [859.0, 109.0], [859.0, 187.0], [831.0, 187.0]]], "lines": ["コーちゃ〜〜〜ん、", "マフラー持った", "～～～？"]}, {"box": [26, 293, 70, 457], "vertical": true, "font_size": 44, "lines_coords": [[[26.0, 293.0], [70.0, 293.0], [70.0, 457.0], [26.0, 457.0]]], "lines": ["第２４話"]}, {"box": [704, 310, 840, 520], "vertical": true, "font_size": 28, "lines_coords": [[[814.0, 310.0], [840.0, 310.0], [840.0, 420.0], [814.0, 420.0]], [[778.0, 312.0], [804.0, 312.0], [804.0, 507.0], [778.0, 507.0]], [[740.0, 314.0], [767.0, 314.0], [767.0, 520.0], [740.0, 520.0]], [[704.0, 312.0], [731.0, 312.0], [731.0, 443.0], [704.0, 443.0]]], "lines": ["ちゃんと", "巻かないと、また", "お腹痛くしちゃう", "わよ～～！？"]}, {"box": [173, 307, 312, 517], "vertical": true, "font_size": 27, "lines_coords": [[[282.0, 310.0], [309.0, 310.0], [309.0, 450.0], [282.0, 450.0]], [[245.0, 307.0], [271.0, 307.0], [271.0, 517.0], [245.0, 517.0]], [[209.0, 307.0], [235.0, 307.0], [235.0, 517.0], [209.0, 517.0]], [[173.0, 307.0], [201.0, 307.0], [201.0, 414.0], [173.0, 414.0]]], "lines": ["おこづかい、", "またカバンの中に", "入れておいたから", "ね～～！！"]}, {"box": [801, 710, 959, 946], "vertical": true, "font_size": 25, "lines_coords": [[[929.0, 710.0], [956.0, 710.0], [959.0, 854.0], [932.0, 854.0]], [[901.0, 715.0], [923.0, 715.0], [923.0, 867.0], [901.0, 867.0]], [[864.0, 710.0], [895.0, 710.0], [895.0, 946.0], [864.0, 946.0]], [[831.0, 710.0], [857.0, 710.0], [857.0, 920.0], [831.0, 920.0]], [[801.0, 712.0], [823.0, 712.0], [823.0, 918.0], [801.0, 918.0]]], "lines": ["今日もママ、", "コーちゃんの", "だ〜〜い好物作って", "待ってるから早く", "帰ってくるのよ！？"]}, {"box": [745, 890, 767, 1017], "vertical": true, "font_size": 25, "lines_coords": [[[745.0, 890.0], [767.0, 890.0], [767.0, 1017.0], [745.0, 1017.0]]], "lines": ["お返事は！？"]}, {"box": [275, 787, 307, 915], "vertical": true, "font_size": 29, "lines_coords": [[[275.0, 787.0], [307.0, 787.0], [307.0, 915.0], [275.0, 915.0]]], "lines": ["．．．ハイ！！"]}, {"box": [154, 864, 217, 1020], "vertical": true, "font_size": 29, "lines_coords": [[[190.0, 864.0], [217.0, 864.0], [217.0, 1020.0], [190.0, 1020.0]], [[154.0, 864.0], [181.0, 864.0], [181.0, 968.0], [154.0, 968.0]]], "lines": ["おりこうさん", "ですね！！"]}, {"box": [112, 1295, 236, 1486], "vertical": true, "font_size": 34, "lines_coords": [[[198.0, 1295.0], [235.0, 1295.0], [235.0, 1439.0], [198.0, 1439.0]], [[154.0, 1296.0], [187.0, 1296.0], [190.0, 1451.0], [157.0, 1451.0]], [[115.0, 1295.0], [148.0, 1295.0], [145.0, 1485.0], [112.0, 1485.0]]], "lines": ["それじゃ、", "いっちらっ", "しゃ～い！！"]}], "img_path": "006.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [870, 748, 912, 971], "vertical": true, "font_size": 42, "lines_coords": [[[870.0, 748.0], [912.0, 748.0], [912.0, 971.0], [870.0, 971.0]]], "lines": ["いっちくす！！"]}, {"box": [98, 1326, 243, 1550], "vertical": true, "font_size": 26, "lines_coords": [[[204.0, 1326.0], [237.0, 1326.0], [237.0, 1443.0], [204.0, 1443.0]], [[167.0, 1326.0], [195.0, 1326.0], [196.0, 1485.0], [168.0, 1485.0]], [[134.0, 1329.0], [156.0, 1329.0], [156.0, 1548.0], [134.0, 1548.0]], [[100.0, 1329.0], [120.0, 1329.0], [120.0, 1509.0], [100.0, 1509.0]]], "lines": ["．．．なぁ関、", "よく聞けよ？", "先生、大事な話して", "るんだからな？"]}], "img_path": "007.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [675, 54, 812, 290], "vertical": true, "font_size": 26, "lines_coords": [[[784.0, 56.0], [812.0, 56.0], [812.0, 195.0], [784.0, 195.0]], [[748.0, 56.0], [775.0, 56.0], [775.0, 290.0], [748.0, 290.0]], [[714.0, 57.0], [735.0, 57.0], [735.0, 223.0], [714.0, 223.0]], [[675.0, 54.0], [701.0, 54.0], [703.0, 251.0], [676.0, 251.0]]], "lines": ["遅刻、欠席、", "特に三学期になって", "からはろくに", "授業に出てない。"]}, {"box": [498, 101, 634, 270], "vertical": true, "font_size": 26, "lines_coords": [[[607.0, 106.0], [634.0, 106.0], [634.0, 262.0], [607.0, 262.0]], [[570.0, 103.0], [596.0, 103.0], [596.0, 270.0], [570.0, 270.0]], [[532.0, 101.0], [559.0, 101.0], [562.0, 235.0], [535.0, 235.0]], [[498.0, 104.0], [525.0, 104.0], [525.0, 220.0], [498.0, 220.0]]], "lines": ["一学期の頃と", "比べて、成績も", "目に見えて", "落ちてる。"]}, {"box": [114, 185, 250, 393], "vertical": true, "font_size": 26, "lines_coords": [[[220.0, 185.0], [248.0, 185.0], [248.0, 318.0], [220.0, 318.0]], [[184.0, 185.0], [210.0, 185.0], [210.0, 343.0], [184.0, 343.0]], [[148.0, 185.0], [175.0, 185.0], [175.0, 370.0], [148.0, 370.0]], [[114.0, 187.0], [135.0, 187.0], [135.0, 392.0], [114.0, 392.0]]], "lines": ["お前、誰か", "悪い先輩達と", "つるんだりして", "るんじゃないか？"]}, {"box": [176, 478, 217, 564], "vertical": true, "font_size": 41, "lines_coords": [[[176.0, 478.0], [217.0, 478.0], [217.0, 564.0], [176.0, 564.0]]], "lines": ["先生。"]}, {"box": [834, 787, 971, 971], "vertical": true, "font_size": 26, "lines_coords": [[[943.0, 789.0], [970.0, 789.0], [970.0, 920.0], [943.0, 920.0]], [[906.0, 790.0], [932.0, 790.0], [932.0, 956.0], [906.0, 956.0]], [[870.0, 790.0], [896.0, 790.0], [896.0, 971.0], [870.0, 971.0]], [[834.0, 787.0], [860.0, 787.0], [862.0, 959.0], [835.0, 959.0]]], "lines": ["俺は誰とも", "つるまねーし、", "誰にも迷惑かけ", "てもいねーよ。"]}, {"box": [265, 765, 425, 960], "vertical": true, "font_size": 25, "lines_coords": [[[398.0, 768.0], [425.0, 768.0], [425.0, 900.0], [398.0, 900.0]], [[368.0, 771.0], [390.0, 771.0], [390.0, 950.0], [368.0, 950.0]], [[335.0, 770.0], [357.0, 770.0], [357.0, 923.0], [335.0, 923.0]], [[301.0, 767.0], [329.0, 767.0], [326.0, 960.0], [298.0, 960.0]], [[265.0, 765.0], [296.0, 765.0], [296.0, 931.0], [265.0, 931.0]]], "lines": ["勉強なんて", "いくらできても", "頭の使い方が", "悪けりゃなんの", "意味も無いし、"]}, {"box": [126, 912, 250, 1121], "vertical": true, "font_size": 25, "lines_coords": [[[228.0, 914.0], [250.0, 914.0], [250.0, 1070.0], [228.0, 1070.0]], [[193.0, 914.0], [215.0, 914.0], [215.0, 1120.0], [193.0, 1120.0]], [[160.0, 912.0], [187.0, 912.0], [187.0, 1121.0], [160.0, 1121.0]], [[126.0, 915.0], [154.0, 915.0], [154.0, 1032.0], [126.0, 1032.0]]], "lines": ["自分のことは", "自分で決めるから", "ほっといてくれて", "いーよ。"]}, {"box": [878, 1245, 978, 1479], "vertical": true, "font_size": 27, "lines_coords": [[[943.0, 1245.0], [978.0, 1245.0], [978.0, 1334.0], [943.0, 1334.0]], [[910.0, 1246.0], [937.0, 1246.0], [937.0, 1479.0], [910.0, 1479.0]], [[878.0, 1246.0], [900.0, 1246.0], [900.0, 1464.0], [878.0, 1464.0]]], "lines": ["．．．．．．関、", "お前が思ってるほど", "社会は甘くないぞ。"]}, {"box": [695, 1335, 829, 1546], "vertical": true, "font_size": 27, "lines_coords": [[[803.0, 1337.0], [829.0, 1337.0], [829.0, 1546.0], [803.0, 1546.0]], [[767.0, 1337.0], [793.0, 1337.0], [793.0, 1546.0], [767.0, 1546.0]], [[731.0, 1335.0], [757.0, 1335.0], [757.0, 1520.0], [731.0, 1520.0]], [[695.0, 1339.0], [721.0, 1339.0], [721.0, 1481.0], [695.0, 1481.0]]], "lines": ["本当に賢い人間は", "友人関係も勉強も", "要領良くやって", "いくもんだ。"]}, {"box": [200, 1284, 338, 1505], "vertical": true, "font_size": 25, "lines_coords": [[[310.0, 1285.0], [332.0, 1285.0], [332.0, 1467.0], [310.0, 1467.0]], [[270.0, 1284.0], [296.0, 1284.0], [296.0, 1481.0], [270.0, 1481.0]], [[235.0, 1284.0], [262.0, 1284.0], [262.0, 1504.0], [235.0, 1504.0]], [[200.0, 1284.0], [226.0, 1284.0], [226.0, 1415.0], [200.0, 1415.0]]], "lines": ["先生の経験から", "言っても、高校は", "進学してゆっくり", "進路を．．．．．"]}, {"box": [115, 1387, 146, 1514], "vertical": true, "font_size": 28, "lines_coords": [[[115.0, 1389.0], [143.0, 1389.0], [143.0, 1514.0], [115.0, 1514.0]]], "lines": ["．．．先生！！"]}], "img_path": "008.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [889, 123, 989, 310], "vertical": true, "font_size": 26, "lines_coords": [[[962.0, 125.0], [989.0, 125.0], [989.0, 282.0], [962.0, 282.0]], [[926.0, 126.0], [953.0, 126.0], [953.0, 307.0], [926.0, 307.0]], [[892.0, 123.0], [920.0, 123.0], [917.0, 310.0], [889.0, 310.0]]], "lines": ["教師がそんな", "テキトーなこと", "言っていいの？"]}, {"box": [260, 151, 393, 362], "vertical": true, "font_size": 27, "lines_coords": [[[367.0, 154.0], [393.0, 154.0], [393.0, 335.0], [367.0, 335.0]], [[329.0, 151.0], [360.0, 151.0], [360.0, 337.0], [329.0, 337.0]], [[295.0, 153.0], [321.0, 153.0], [321.0, 362.0], [295.0, 362.0]], [[260.0, 154.0], [282.0, 154.0], [282.0, 281.0], [260.0, 281.0]]], "lines": ["あんたの経験が", "すべての人間に", "当てはまるなんて", "思うなよ？"]}, {"box": [795, 315, 892, 496], "vertical": true, "font_size": 26, "lines_coords": [[[865.0, 315.0], [892.0, 315.0], [892.0, 434.0], [865.0, 434.0]], [[828.0, 315.0], [854.0, 315.0], [854.0, 496.0], [828.0, 496.0]], [[795.0, 317.0], [817.0, 317.0], [817.0, 471.0], [795.0, 471.0]]], "lines": ["今は、俺の", "話をしてんじゃ", "なかったの？"]}, {"box": [143, 339, 245, 576], "vertical": true, "font_size": 27, "lines_coords": [[[217.0, 339.0], [245.0, 339.0], [243.0, 550.0], [215.0, 550.0]], [[178.0, 340.0], [209.0, 340.0], [209.0, 576.0], [178.0, 576.0]], [[146.0, 342.0], [170.0, 342.0], [167.0, 545.0], [143.0, 545.0]]], "lines": ["賢い大人ってのは", "話のすりかえが上手", "ってことなのか？"]}, {"box": [914, 941, 978, 1059], "vertical": true, "font_size": 27, "lines_coords": [[[950.0, 942.0], [978.0, 942.0], [978.0, 1056.0], [950.0, 1056.0]], [[914.0, 942.0], [940.0, 942.0], [940.0, 1059.0], [914.0, 1059.0]]], "lines": ["．．．．．よし、", "わかった。"]}, {"box": [564, 951, 590, 1095], "vertical": true, "font_size": 22, "lines_coords": [[[565.0, 953.0], [587.0, 953.0], [587.0, 1093.0], [565.0, 1093.0]]], "lines": ["．．．いいけど。"]}, {"box": [98, 981, 236, 1189], "vertical": true, "font_size": 26, "lines_coords": [[[206.0, 982.0], [232.0, 982.0], [232.0, 1120.0], [206.0, 1120.0]], [[168.0, 981.0], [196.0, 981.0], [195.0, 1189.0], [167.0, 1189.0]], [[132.0, 981.0], [159.0, 981.0], [159.0, 1150.0], [132.0, 1150.0]], [[100.0, 985.0], [121.0, 985.0], [121.0, 1137.0], [100.0, 1137.0]]], "lines": ["．．．でも先生、", "俺んちの酔っ払い", "親父は、俺より", "タチ悪いよ？"]}, {"box": [646, 1282, 782, 1477], "vertical": true, "font_size": 26, "lines_coords": [[[754.0, 1285.0], [781.0, 1285.0], [781.0, 1428.0], [754.0, 1428.0]], [[717.0, 1282.0], [745.0, 1282.0], [740.0, 1465.0], [712.0, 1465.0]], [[681.0, 1284.0], [707.0, 1284.0], [707.0, 1454.0], [681.0, 1454.0]], [[648.0, 1285.0], [670.0, 1285.0], [670.0, 1475.0], [648.0, 1475.0]]], "lines": ["来週、特別に", "保護者面談やる", "から、ご両親に", "そう伝えておけ。"]}, {"box": [212, 1293, 239, 1435], "vertical": true, "font_size": 31, "lines_coords": [[[212.0, 1293.0], [239.0, 1293.0], [239.0, 1435.0], [212.0, 1435.0]]], "lines": ["．．．もういい。"]}, {"box": [112, 1440, 181, 1529], "vertical": true, "font_size": 31, "lines_coords": [[[148.0, 1440.0], [181.0, 1440.0], [181.0, 1529.0], [148.0, 1529.0]], [[112.0, 1440.0], [146.0, 1440.0], [146.0, 1515.0], [112.0, 1515.0]]], "lines": ["今日は", "帰れ。"]}], "img_path": "009.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [318, 114, 387, 248], "vertical": true, "font_size": 34, "lines_coords": [[[353.0, 115.0], [387.0, 115.0], [387.0, 198.0], [353.0, 198.0]], [[318.0, 114.0], [351.0, 114.0], [351.0, 248.0], [318.0, 248.0]]], "lines": ["．．．．．．", "ダセ～～～．．．"]}, {"box": [118, 462, 145, 604], "vertical": true, "font_size": 22, "lines_coords": [[[120.0, 464.0], [142.0, 464.0], [142.0, 604.0], [120.0, 604.0]]], "lines": ["超反抗期だ。"]}, {"box": [164, 1373, 211, 1501], "vertical": true, "font_size": 39, "lines_coords": [[[164.0, 1373.0], [203.0, 1373.0], [203.0, 1501.0], [164.0, 1501.0]]], "lines": ["．．．清水？"]}], "img_path": "010.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [537, 1296, 575, 1443], "vertical": true, "font_size": 34, "lines_coords": [[[537.0, 1296.0], [571.0, 1296.0], [575.0, 1443.0], [540.0, 1443.0]]], "lines": ["はあぁ！？"]}], "img_path": "011.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [789, 110, 924, 303], "vertical": true, "font_size": 26, "lines_coords": [[[896.0, 110.0], [923.0, 110.0], [923.0, 301.0], [896.0, 301.0]], [[860.0, 110.0], [889.0, 110.0], [889.0, 256.0], [860.0, 256.0]], [[823.0, 110.0], [851.0, 110.0], [848.0, 268.0], [820.0, 268.0]], [[790.0, 112.0], [812.0, 112.0], [812.0, 267.0], [790.0, 267.0]]], "lines": ["．．．．．っなんだよ、", "オメーそれ", "超いいがかり", "なんだけど！！"]}, {"box": [78, 326, 215, 539], "vertical": true, "font_size": 26, "lines_coords": [[[185.0, 329.0], [212.0, 329.0], [212.0, 512.0], [185.0, 512.0]], [[148.0, 326.0], [176.0, 326.0], [175.0, 539.0], [146.0, 539.0]], [[115.0, 328.0], [139.0, 328.0], [137.0, 535.0], [114.0, 535.0]], [[79.0, 328.0], [103.0, 328.0], [101.0, 510.0], [78.0, 510.0]]], "lines": ["清水から勝手に", "くれるっつーから", "もらってやってる", "だけだろがよ！！"]}, {"box": [176, 667, 276, 851], "vertical": true, "font_size": 27, "lines_coords": [[[248.0, 668.0], [275.0, 668.0], [275.0, 801.0], [248.0, 801.0]], [[212.0, 668.0], [239.0, 668.0], [239.0, 826.0], [212.0, 826.0]], [[176.0, 667.0], [203.0, 667.0], [203.0, 851.0], [176.0, 851.0]]], "lines": ["金ってのは", "フツー働いて", "稼ぐもんだろ？"]}, {"box": [878, 942, 1001, 1129], "vertical": true, "font_size": 31, "lines_coords": [[[968.0, 942.0], [1001.0, 942.0], [1001.0, 1026.0], [968.0, 1026.0]], [[939.0, 942.0], [970.0, 942.0], [970.0, 1106.0], [939.0, 1106.0]], [[910.0, 943.0], [937.0, 943.0], [937.0, 1129.0], [910.0, 1129.0]], [[878.0, 943.0], [910.0, 943.0], [910.0, 1053.0], [878.0, 1053.0]]], "lines": ["あぁ！？", "テメーの理屈", "なんて知らねー", "っつの！！"]}, {"box": [496, 971, 620, 1169], "vertical": true, "font_size": 24, "lines_coords": [[[593.0, 973.0], [620.0, 973.0], [620.0, 1117.0], [593.0, 1117.0]], [[560.0, 971.0], [587.0, 971.0], [587.0, 1157.0], [560.0, 1157.0]], [[529.0, 973.0], [551.0, 973.0], [551.0, 1168.0], [529.0, 1168.0]], [[496.0, 973.0], [518.0, 973.0], [518.0, 1129.0], [496.0, 1129.0]]], "lines": ["つかなんで", "テメーみてーな", "馬鹿に、俺が説教", "されんだよ！！"]}, {"box": [135, 968, 275, 1181], "vertical": true, "font_size": 31, "lines_coords": [[[243.0, 970.0], [275.0, 970.0], [275.0, 1145.0], [243.0, 1145.0]], [[207.0, 971.0], [239.0, 971.0], [239.0, 1157.0], [207.0, 1157.0]], [[171.0, 970.0], [203.0, 970.0], [203.0, 1170.0], [171.0, 1170.0]], [[137.0, 968.0], [164.0, 968.0], [162.0, 1181.0], [135.0, 1181.0]]], "lines": ["オメーいつも", "一人でフラフラ", "孤独気取ってん", "じゃねーっつの！！"]}, {"box": [643, 1285, 782, 1470], "vertical": true, "font_size": 27, "lines_coords": [[[756.0, 1287.0], [782.0, 1287.0], [778.0, 1420.0], [751.0, 1420.0]], [[717.0, 1289.0], [743.0, 1289.0], [743.0, 1470.0], [717.0, 1470.0]], [[679.0, 1289.0], [706.0, 1289.0], [706.0, 1445.0], [679.0, 1445.0]], [[643.0, 1285.0], [670.0, 1285.0], [670.0, 1393.0], [643.0, 1393.0]]], "lines": ["ジュヨーと", "キョーキューが", "成り立ってん", "だろが！！"]}, {"box": [82, 1265, 203, 1490], "vertical": true, "font_size": 31, "lines_coords": [[[170.0, 1270.0], [203.0, 1270.0], [203.0, 1460.0], [170.0, 1460.0]], [[128.0, 1268.0], [159.0, 1268.0], [159.0, 1490.0], [128.0, 1490.0]], [[82.0, 1265.0], [120.0, 1265.0], [120.0, 1332.0], [82.0, 1332.0]]], "lines": ["頭ワリー奴が", "正義面すんじゃ", "ねー"]}, {"box": [89, 1345, 112, 1395], "vertical": true, "font_size": 31, "lines_coords": [[[89.0, 1345.0], [112.0, 1345.0], [112.0, 1395.0], [89.0, 1395.0]]], "lines": ["．．．"]}], "img_path": "012.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [935, 1073, 1014, 1232], "vertical": true, "font_size": 32, "lines_coords": [[[976.0, 1075.0], [1014.0, 1075.0], [1014.0, 1217.0], [976.0, 1217.0]], [[937.0, 1076.0], [964.0, 1076.0], [964.0, 1232.0], [937.0, 1232.0]]], "lines": ["．．．．．せっ、", "関くんっ！！"]}, {"box": [509, 1084, 634, 1245], "vertical": true, "font_size": 33, "lines_coords": [[[590.0, 1087.0], [623.0, 1087.0], [623.0, 1223.0], [590.0, 1223.0]], [[550.0, 1085.0], [582.0, 1085.0], [582.0, 1214.0], [550.0, 1214.0]], [[512.0, 1084.0], [545.0, 1084.0], [542.0, 1245.0], [509.0, 1245.0]]], "lines": ["阿部くん、", "全然悪く", "ないから！！"]}, {"box": [668, 1393, 746, 1520], "vertical": true, "font_size": 34, "lines_coords": [[[707.0, 1393.0], [746.0, 1393.0], [746.0, 1503.0], [707.0, 1503.0]], [[668.0, 1395.0], [696.0, 1395.0], [696.0, 1520.0], [668.0, 1520.0]]], "lines": ["関くん、", "関くん！！"]}, {"box": [90, 1318, 244, 1461], "vertical": true, "font_size": 31, "lines_coords": [[[214.0, 1318.0], [242.0, 1318.0], [239.0, 1456.0], [210.0, 1456.0]], [[171.0, 1321.0], [200.0, 1321.0], [200.0, 1457.0], [171.0, 1457.0]], [[128.0, 1318.0], [162.0, 1318.0], [159.0, 1451.0], [125.0, 1451.0]], [[90.0, 1320.0], [123.0, 1320.0], [123.0, 1450.0], [90.0, 1450.0]]], "lines": ["ごめんね", "ごめんね、", "僕が全部", "悪いの！！"]}], "img_path": "013.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [0, 20, 176, 434], "vertical": true, "font_size": 58, "lines_coords": [[[121.0, 20.0], [176.0, 20.0], [173.0, 262.0], [118.0, 262.0]], [[53.0, 20.0], [118.0, 20.0], [115.0, 348.0], [50.0, 348.0]], [[0.0, 139.0], [54.0, 139.0], [51.0, 434.0], [0.0, 434.0]]], "lines": ["そういう", "問題じゃねー", "んだよっ！！"]}, {"box": [840, 723, 1006, 1053], "vertical": true, "font_size": 52, "lines_coords": [[[950.0, 725.0], [1006.0, 725.0], [1006.0, 851.0], [950.0, 851.0]], [[892.0, 723.0], [951.0, 723.0], [951.0, 1009.0], [892.0, 1009.0]], [[840.0, 726.0], [88