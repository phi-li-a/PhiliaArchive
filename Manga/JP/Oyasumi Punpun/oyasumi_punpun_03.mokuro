0], [873.0, 1032.0]]], "lines": ["．．．"]}, {"box": [110, 907, 339, 1543], "vertical": true, "font_size": 207, "lines_coords": [[[110.0, 914.0], [317.0, 907.0], [339.0, 1537.0], [132.0, 1543.0]]], "lines": ["勃起した！"]}], "img_path": "186.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [650, 84, 716, 246], "vertical": true, "font_size": 29, "lines_coords": [[[687.0, 87.0], [714.0, 87.0], [714.0, 225.0], [687.0, 225.0]], [[650.0, 84.0], [681.0, 84.0], [681.0, 246.0], [650.0, 246.0]]], "lines": ["小野寺くん、", "電話ーーっ！！"]}, {"box": [89, 242, 209, 424], "vertical": true, "font_size": 24, "lines_coords": [[[181.0, 242.0], [207.0, 242.0], [207.0, 354.0], [181.0, 354.0]], [[153.0, 245.0], [175.0, 245.0], [175.0, 398.0], [153.0, 398.0]], [[121.0, 243.0], [143.0, 243.0], [143.0, 423.0], [121.0, 423.0]], [[89.0, 242.0], [115.0, 242.0], [115.0, 348.0], [89.0, 348.0]]], "lines": ["．．．なんだ", "姉さんか．．．", "仕事中なんです", "けど．．．"]}, {"box": [581, 517, 609, 635], "vertical": true, "font_size": 28, "lines_coords": [[[581.0, 517.0], [609.0, 517.0], [609.0, 635.0], [581.0, 635.0]]], "lines": ["．．．ハァ？"]}, {"box": [445, 545, 545, 732], "vertical": true, "font_size": 28, "lines_coords": [[[517.0, 548.0], [545.0, 548.0], [545.0, 679.0], [517.0, 679.0]], [[475.0, 545.0], [507.0, 545.0], [510.0, 732.0], [478.0, 732.0]], [[445.0, 548.0], [471.0, 548.0], [471.0, 656.0], [445.0, 656.0]]], "lines": ["プンプンが", "学校から帰って", "来ない！？"]}, {"box": [129, 550, 230, 732], "vertical": true, "font_size": 27, "lines_coords": [[[198.0, 550.0], [226.0, 550.0], [228.0, 732.0], [200.0, 732.0]], [[165.0, 550.0], [192.0, 550.0], [192.0, 721.0], [165.0, 721.0]], [[129.0, 551.0], [156.0, 551.0], [156.0, 706.0], [129.0, 706.0]]], "lines": ["．．．わかったよ！！", "すぐにそっち", "向かうから！！"]}, {"box": [965, 810, 992, 898], "vertical": true, "font_size": 31, "lines_coords": [[[965.0, 810.0], [992.0, 810.0], [992.0, 898.0], [965.0, 898.0]]], "lines": ["いやあー"]}, {"box": [817, 931, 926, 1090], "vertical": true, "font_size": 31, "lines_coords": [[[896.0, 931.0], [925.0, 931.0], [926.0, 1090.0], [898.0, 1090.0]], [[862.0, 935.0], [889.0, 935.0], [889.0, 1068.0], [862.0, 1068.0]], [[817.0, 932.0], [857.0, 931.0], [860.0, 1007.0], [820.0, 1009.0]]], "lines": ["あの、ゴメン", "実に申し訳", "ない。"]}, {"box": [250, 884, 310, 1090], "vertical": true, "font_size": 21, "lines_coords": [[[284.0, 884.0], [310.0, 884.0], [310.0, 1042.0], [284.0, 1042.0]], [[250.0, 884.0], [271.0, 884.0], [271.0, 1090.0], [250.0, 1090.0]]], "lines": ["急用ができて", "しまったもんで．．．"]}, {"box": [117, 1009, 215, 1181], "vertical": true, "font_size": 21, "lines_coords": [[[193.0, 1009.0], [215.0, 1009.0], [215.0, 1137.0], [193.0, 1137.0]], [[167.0, 1012.0], [187.0, 1012.0], [187.0, 1181.0], [167.0, 1181.0]], [[142.0, 1009.0], [162.0, 1009.0], [162.0, 1159.0], [142.0, 1159.0]], [[117.0, 1012.0], [134.0, 1012.0], [134.0, 1117.0], [117.0, 1117.0]]], "lines": ["本当は釉薬の", "かけ方とか色々と", "教えたかったん", "だけど．．．"]}, {"box": [863, 1279, 950, 1471], "vertical": true, "font_size": 23, "lines_coords": [[[926.0, 1281.0], [948.0, 1281.0], [948.0, 1423.0], [926.0, 1423.0]], [[892.0, 1279.0], [918.0, 1279.0], [920.0, 1471.0], [893.0, 1471.0]], [[864.0, 1281.0], [885.0, 1281.0], [885.0, 1470.0], [864.0, 1470.0]]], "lines": ["お母さんとは", "一緒じゃなくても", "構わないからさ．．．"]}, {"box": [164, 1314, 229, 1525], "vertical": true, "font_size": 29, "lines_coords": [[[196.0, 1315.0], [228.0, 1315.0], [228.0, 1475.0], [196.0, 1475.0]], [[164.0, 1315.0], [190.0, 1315.0], [190.0, 1525.0], [164.0, 1525.0]]], "lines": ["．．．近いうちに", "また、おいでよ！！"]}], "img_path": "187.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [893, 664, 962, 771], "vertical": true, "font_size": 34, "lines_coords": [[[929.0, 664.0], [962.0, 664.0], [962.0, 759.0], [929.0, 759.0]], [[893.0, 665.0], [928.0, 665.0], [928.0, 771.0], [893.0, 771.0]]], "lines": ["．．．．．あ、", "いや．．．"]}, {"box": [157, 675, 257, 857], "vertical": true, "font_size": 27, "lines_coords": [[[229.0, 675.0], [256.0, 675.0], [256.0, 782.0], [229.0, 782.0]], [[193.0, 675.0], [220.0, 675.0], [220.0, 857.0], [193.0, 857.0]], [[157.0, 675.0], [184.0, 675.0], [184.0, 807.0], [157.0, 807.0]]], "lines": ["もちろん", "君さえ良ければ", "だけど．．．"]}, {"box": [248, 1065, 310, 1198], "vertical": true, "font_size": 33, "lines_coords": [[[284.0, 1065.0], [310.0, 1065.0], [307.0, 1198.0], [281.0, 1198.0]], [[248.0, 1067.0], [276.0, 1067.0], [276.0, 1156.0], [248.0, 1156.0]]], "lines": ["．．．小野寺", "さんは、"]}, {"box": [650, 1307, 926, 1495], "vertical": false, "font_size": 182, "lines_coords": [[[653.0, 1307.0], [926.0, 1314.0], [923.0, 1495.0], [650.0, 1489.0]]], "lines": ["ん"]}, {"box": [221, 1270, 310, 1493], "vertical": true, "font_size": 33, "lines_coords": [[[271.0, 1273.0], [310.0, 1273.0], [310.0, 1456.0], [271.0, 1456.0]], [[221.0, 1270.0], [259.0, 1270.0], [259.0, 1493.0], [221.0, 1493.0]]], "lines": ["．．．神様って", "信じますか？"]}, {"box": [96, 1412, 127, 1521], "vertical": true, "font_size": 29, "lines_coords": [[[96.0, 1412.0], [125.0, 1412.0], [125.0, 1521.0], [96.0, 1521.0]]], "lines": ["．．．え？"]}], "img_path": "188.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [950, 112, 982, 231], "vertical": true, "font_size": 30, "lines_coords": [[[950.0, 112.0], [982.0, 112.0], [982.0, 231.0], [950.0, 231.0]]], "lines": ["神様．．．．．"]}, {"box": [864, 298, 892, 412], "vertical": true, "font_size": 30, "lines_coords": [[[864.0, 298.0], [892.0, 298.0], [892.0, 412.0], [864.0, 412.0]]], "lines": ["．．．いや、"]}, {"box": [134, 315, 234, 473], "vertical": true, "font_size": 26, "lines_coords": [[[206.0, 315.0], [232.0, 315.0], [232.0, 471.0], [206.0, 471.0]], [[168.0, 315.0], [195.0, 315.0], [195.0, 473.0], [168.0, 473.0]], [[134.0, 315.0], [160.0, 315.0], [160.0, 471.0], [134.0, 471.0]]], "lines": ["あまり真剣に", "考えたことも", "ないなぁ．．．"]}, {"box": [832, 662, 954, 853], "vertical": true, "font_size": 23, "lines_coords": [[[928.0, 662.0], [954.0, 662.0], [953.0, 831.0], [926.0, 831.0]], [[898.0, 665.0], [920.0, 665.0], [920.0, 829.0], [898.0, 829.0]], [[865.0, 665.0], [887.0, 665.0], [887.0, 853.0], [865.0, 853.0]], [[832.0, 665.0], [854.0, 665.0], [854.0, 806.0], [832.0, 806.0]]], "lines": ["．．．それはつまり", "キリストだとか", "お釈迦様のような", "もののこと？"]}, {"box": [875, 1098, 903, 1204], "vertical": true, "font_size": 24, "lines_coords": [[[875.0, 1098.0], [903.0, 1098.0], [903.0, 1204.0], [875.0, 1204.0]]], "lines": ["私も．．．"]}, {"box": [126, 721, 250, 957], "vertical": true, "font_size": 23, "lines_coords": [[[223.0, 723.0], [245.0, 723.0], [245.0, 909.0], [223.0, 909.0]], [[190.0, 721.0], [217.0, 721.0], [217.0, 957.0], [190.0, 957.0]], [[159.0, 723.0], [181.0, 723.0], [181.0, 864.0], [159.0, 864.0]], [[126.0, 721.0], [148.0, 721.0], [148.0, 885.0], [126.0, 885.0]]], "lines": ["それとも．．．例えば", "お金とか自由だとかの", "比喩的な表現", "なのかな．．．？"]}, {"box": [812, 1307, 904, 1487], "vertical": true, "font_size": 24, "lines_coords": [[[882.0, 1307.0], [904.0, 1307.0], [904.0, 1457.0], [882.0, 1457.0]], [[848.0, 1307.0], [870.0, 1307.0], [870.0, 1462.0], [848.0, 1462.0]], [[812.0, 1307.0], [834.0, 1307.0], [834.0, 1487.0], [812.0, 1487.0]]], "lines": ["あまり難しい", "ことはわかり", "ませんけど．．．"]}, {"box": [79, 1250, 478, 1554], "vertical": false, "font_size": 208, "lines_coords": [[[79.0, 1356.0], [414.0, 1250.0], [478.0, 1448.0], [143.0, 1554.0]]], "lines": ["ひ"]}], "img_path": "189.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [937, 151, 963, 313], "vertical": true, "font_size": 21, "lines_coords": [[[939.0, 154.0], [960.0, 154.0], [960.0, 310.0], [939.0, 310.0]]], "lines": ["神様神様．．．．．．"]}, {"box": [212, 431, 234, 584], "vertical": true, "font_size": 26, "lines_coords": [[[212.0, 431.0], [234.0, 431.0], [234.0, 584.0], [212.0, 584.0]]], "lines": ["チンクル．．．．．"]}, {"box": [164, 628, 193, 696], "vertical": true, "font_size": 26, "lines_coords": [[[164.0, 628.0], [193.0, 628.0], [193.0, 696.0], [164.0, 696.0]]], "lines": ["ホイ。"]}, {"box": [961, 926, 984, 1070], "vertical": true, "font_size": 20, "lines_coords": [[[962.0, 928.0], [982.0, 928.0], [982.0, 1067.0], [962.0, 1067.0]]], "lines": ["チンクル．．．？"]}, {"box": [753, 1298, 812, 1465], "vertical": true, "font_size": 26, "lines_coords": [[[785.0, 1298.0], [812.0, 1298.0], [812.0, 1409.0], [785.0, 1409.0]], [[753.0, 1298.0], [779.0, 1298.0], [779.0, 1465.0], [753.0, 1465.0]]], "lines": ["え？何？", "何、それ、今の？"]}, {"box": [178, 1195, 264, 1359], "vertical": true, "font_size": 23, "lines_coords": [[[242.0, 1196.0], [264.0, 1196.0], [264.0, 1359.0], [242.0, 1359.0]], [[210.0, 1196.0], [232.0, 1196.0], [232.0, 1310.0], [210.0, 1310.0]], [[178.0, 1195.0], [200.0, 1195.0], [200.0, 1304.0], [178.0, 1304.0]]], "lines": ["子供の頃からの", "おまじない", "なんです。"]}, {"box": [81, 1360, 203, 1531], "vertical": true, "font_size": 23, "lines_coords": [[[176.0, 1360.0], [203.0, 1360.0], [203.0, 1460.0], [176.0, 1460.0]], [[143.0, 1362.0], [170.0, 1362.0], [170.0, 1531.0], [143.0, 1531.0]], [[114.0, 1362.0], [135.0, 1362.0], [135.0, 1529.0], [114.0, 1529.0]], [[81.0, 1364.0], [103.0, 1364.0], [103.0, 1468.0], [81.0, 1468.0]]], "lines": ["ひとりで", "寂しくなったり", "苦しくなったり", "した時の"]}], "img_path": "190.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [885, 115, 982, 320], "vertical": true, "font_size": 25, "lines_coords": [[[957.0, 118.0], [979.0, 118.0], [979.0, 320.0], [957.0, 320.0]], [[921.0, 118.0], [948.0, 118.0], [948.0, 287.0], [921.0, 287.0]], [[885.0, 115.0], [912.0, 115.0], [917.0, 270.0], [890.0, 270.0]]], "lines": ["．．．でも、神様なんて", "実際に見たこと", "なんてないし、"]}, {"box": [276, 121, 390, 289], "vertical": true, "font_size": 23, "lines_coords": [[[368.0, 121.0], [390.0, 121.0], [390.0, 287.0], [368.0, 287.0]], [[337.0, 121.0], [360.0, 121.0], [362.0, 289.0], [339.0, 289.0]], [[306.0, 123.0], [332.0, 123.0], [332.0, 289.0], [306.0, 289.0]], [[276.0, 121.0], [303.0, 121.0], [303.0, 268.0], [276.0, 268.0]]], "lines": ["どれだけ必死に", "お願いしたって", "いいことなんて", "起きないし．．．"]}, {"box": [126, 151, 248, 371], "vertical": true, "font_size": 23, "lines_coords": [[[226.0, 153.0], [248.0, 153.0], [248.0, 356.0], [226.0, 356.0]], [[193.0, 154.0], [215.0, 154.0], [215.0, 371.0], [193.0, 371.0]], [[160.0, 153.0], [182.0, 153.0], [182.0, 343.0], [160.0, 343.0]], [[126.0, 151.0], [148.0, 151.0], [150.0, 345.0], [128.0, 345.0]]], "lines": ["．．．私は、いもしない", "神様に頼るしかない", "こんな自分が嫌い", "だったんです．．．"]}, {"box": [854, 484, 957, 734], "vertical": true, "font_size": 27, "lines_coords": [[[926.0, 485.0], [953.0, 485.0], [953.0, 732.0], [926.0, 732.0]], [[889.0, 484.0], [915.0, 484.0], [915.0, 695.0], [889.0, 695.0]], [[854.0, 487.0], [881.0, 487.0], [881.0, 656.0], [854.0, 656.0]]], "lines": ["．．．けど、もしかしたら", "本当にいるのかも", "しれないって、"]}, {"box": [144, 646, 207, 828], "vertical": true, "font_size": 24, "lines_coords": [[[179.0, 646.0], [206.0, 646.0], [206.0, 828.0], [179.0, 828.0]], [[145.0, 646.0], [167.0, 646.0], [167.0, 785.0], [145.0, 785.0]]], "lines": ["．．．今、はじめて", "思いました。"]}, {"box": [779, 1189, 845, 1362], "vertical": true, "font_size": 29, "lines_coords": [[[818.0, 1190.0], [845.0, 1190.0], [845.0, 1362.0], [818.0, 1362.0]], [[779.0, 1189.0], [807.0, 1189.0], [809.0, 1362.0], [781.0, 1362.0]]], "lines": ["．．．と、とにかく", "またおいで！！"]}, {"box": [642, 1301, 748, 1487], "vertical": true, "font_size": 29, "lines_coords": [[[712.0, 1301.0], [748.0, 1301.0], [748.0, 1373.0], [712.0, 1373.0]], [[679.0, 1301.0], [707.0, 1301.0], [704.0, 1487.0], [676.0, 1487.0]], [[642.0, 1303.0], [668.0, 1303.0], [671.0, 1460.0], [645.0, 1460.0]]], "lines": ["あと、", "ちゃんと学校も", "行きなさい！！"]}, {"box": [382, 1153, 409, 1346], "vertical": true, "font_size": 25, "lines_coords": [[[382.0, 1153.0], [409.0, 1153.0], [409.0, 1346.0], [382.0, 1346.0]]], "lines": ["．．．学校行ったら、"]}, {"box": [282, 1270, 343, 1457], "vertical": true, "font_size": 25, "lines_coords": [[[314.0, 1270.0], [340.0, 1270.0], [343.0, 1457.0], [317.0, 1457.0]], [[282.0, 1273.0], [304.0, 1273.0], [304.0, 1429.0], [282.0, 1429.0]]], "lines": ["私とデートして", "くれますか！？"]}], "img_path": "191.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [923, 128, 950, 234], "vertical": true, "font_size": 24, "lines_coords": [[[923.0, 128.0], [950.0, 128.0], [950.0, 234.0], [923.0, 234.0]]], "lines": ["．．．ああ！！"]}, {"box": [837, 232, 859, 389], "vertical": true, "font_size": 24, "lines_coords": [[[837.0, 232.0], [859.0, 232.0], [859.0, 389.0], [837.0, 389.0]]], "lines": ["約束するよ！！"]}, {"box": [580, 85, 645, 279], "vertical": true, "font_size": 22, "lines_coords": [[[618.0, 85.0], [640.0, 85.0], [640.0, 239.0], [618.0, 239.0]], [[581.0, 87.0], [603.0, 87.0], [603.0, 270.0], [581.0, 270.0]]], "lines": ["．．．僕はこの時", "こう思ったんだ"]}, {"box": [457, 85, 520, 289], "vertical": true, "font_size": 22, "lines_coords": [[[492.0, 87.0], [514.0, 87.0], [514.0, 287.0], [492.0, 287.0]], [[457.0, 85.0], [479.0, 85.0], [479.0, 214.0], [457.0, 214.0]]], "lines": ["もし神様がいると", "するならば"]}, {"box": [256, 125, 394, 393], "vertical": true, "font_size": 26, "lines_coords": [[[370.0, 129.0], [392.0, 129.0], [390.0, 371.0], [368.0, 371.0]], [[328.0, 125.0], [359.0, 125.0], [359.0, 337.0], [328.0, 337.0]], [[293.0, 125.0], [320.0, 125.0], [318.0, 384.0], [292.0, 384.0]], [[256.0, 126.0], [282.0, 126.0], [282.0, 390.0], [256.0, 390.0]]], "lines": ["一体、なんのつもりで", "僕の平坦な日常に", "その少女という存在を", "与えたのだろうか、と。"]}, {"box": [976, 518, 1003, 637], "vertical": true, "font_size": 28, "lines_coords": [[[976.0, 518.0], [1003.0, 518.0], [1003.0, 637.0], [976.0, 637.0]]], "lines": ["よかったー"]}, {"box": [942, 568, 967, 648], "vertical": true, "font_size": 28, "lines_coords": [[[942.0, 568.0], [967.0, 568.0], [967.0, 648.0], [942.0, 648.0]]], "lines": ["ーッ！！"]}, {"box": [860, 671, 926, 806], "vertical": true, "font_size": 28, "lines_coords": [[[893.0, 671.0], [926.0, 671.0], [926.0, 764.0], [893.0, 764.0]], [[860.0, 673.0], [887.0, 673.0], [887.0, 806.0], [860.0, 806.0]]], "lines": ["すっげー", "捜したよ！！"]}, {"box": [164, 592, 300, 778], "vertical": true, "font_size": 29, "lines_coords": [[[273.0, 595.0], [300.0, 595.0], [300.0, 750.0], [273.0, 750.0]], [[234.0, 592.0], [267.0, 592.0], [267.0, 695.0], [234.0, 695.0]], [[200.0, 595.0], [231.0, 595.0], [231.0, 767.0], [200.0, 767.0]], [[165.0, 592.0], [192.0, 592.0], [190.0, 778.0], [164.0, 778.0]]], "lines": ["ダーメじゃ", "ないかー", "一人でこんな", "遠くに来ちゃ！！"]}, {"box": [543, 1093, 604, 1233], "vertical": true, "font_size": 27, "lines_coords": [[[543.0, 1093.0], [570.0, 1093.0], [570.0, 1231.0], [543.0, 1231.0]]], "lines": ["わからない。"]}, {"box": [167, 854, 270, 1012], "vertical": true, "font_size": 29, "lines_coords": [[[242.0, 857.0], [270.0, 857.0], [267.0, 1012.0], [239.0, 1012.0]], [[203.0, 854.0], [235.0, 854.0], [232.0, 990.0], [200.0, 990.0]], [[170.0, 856.0], [196.0, 856.0], [193.0, 1012.0], [167.0, 1012.0]]], "lines": ["パパとママも", "今、必死に", "捜してるよ！？"]}, {"box": [198, 1340, 342, 1551], "vertical": true, "font_size": 30, "lines_coords": [[[303.0, 1340.0], [342.0, 1340.0], [342.0, 1434.0], [303.0, 1434.0]], [[273.0, 1343.0], [300.0, 1343.0], [300.0, 1551.0], [273.0, 1551.0]], [[237.0, 1342.0], [265.0, 1342.0], [262.0, 1473.0], [234.0, 1473.0]], [[201.0, 1342.0], [229.0, 1342.0], [226.0, 1510.0], [198.0, 1510.0]]], "lines": ["．．．いや、", "わからないふりを", "していたの", "かもしれない。"]}], "img_path": "192.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [937, 100, 1010, 290], "vertical": true, "font_size": 26, "lines_coords": [[[979.0, 100.0], [1010.0, 100.0], [1010.0, 290.0], [979.0, 290.0]], [[937.0, 100.0], [968.0, 100.0], [968.0, 259.0], [937.0, 259.0]]], "lines": ["いやぁ～～～", "雄一くん！！"]}, {"box": [801, 196, 896, 381], "vertical": true, "font_size": 26, "lines_coords": [[[875.0, 200.0], [896.0, 200.0], [896.0, 381.0], [875.0, 381.0]], [[835.0, 196.0], [862.0, 196.0], [862.0, 356.0], [835.0, 356.0]], [[801.0, 200.0], [823.0, 200.0], [823.0, 354.0], [801.0, 354.0]]], "lines": ["ごめんねぇ～～", "今日はホント", "助かったよ！！"]}, {"box": [132, 165, 234, 359], "vertical": true, "font_size": 32, "lines_coords": [[[203.0, 168.0], [234.0, 168.0], [234.0, 329.0], [203.0, 329.0]], [[164.0, 165.0], [201.0, 165.0], [201.0, 359.0], [164.0, 359.0]], [[132.0, 170.0], [159.0, 170.0], [159.0, 356.0], [132.0, 356.0]]], "lines": ["遠慮しないで", "ホラ、どんどん", "飲んじゃって！！"]}, {"box": [934, 523, 1000, 695], "vertical": true, "font_size": 26, "lines_coords": [[[973.0, 526.0], [1000.0, 526.0], [1000.0, 678.0], [973.0, 678.0]], [[937.0, 523.0], [965.0, 523.0], [962.0, 695.0], [934.0, 695.0]]], "lines": ["オホホ～～～", "オッオゥオゥッ、"]}, {"box": [873, 675, 895, 804], "vertical": true, "font_size": 26, "lines_coords": [[[873.0, 675.0], [895.0, 675.0], [895.0, 804.0], [873.0, 804.0]]], "lines": ["トトトゥ！！"]}, {"box": [139, 671, 162, 817], "vertical": true, "font_size": 22, "lines_coords": [[[139.0, 671.0], [160.0, 671.0], [162.0, 815.0], [140.0, 815.0]]], "lines": ["．．．トトトゥ。"]}, {"box": [885, 975, 998, 1207], "vertical": true, "font_size": 22, "lines_coords": [[[975.0, 978.0], [995.0, 978.0], [995.0, 1190.0], [975.0, 1190.0]], [[943.0, 975.0], [970.0, 975.0], [970.0, 1207.0], [943.0, 1207.0]], [[914.0, 976.0], [935.0, 976.0], [935.0, 1165.0], [914.0, 1165.0]], [[885.0, 978.0], [907.0, 978.0], [907.0, 1190.0], [885.0, 1190.0]]], "lines": ["ところで雄一くん！！", "あのブ．．．．．．あの愛嬌の", "ある顔の彼女とは", "上手くいってんの？"]}, {"box": [189, 1029, 217, 1160], "vertical": true, "font_size": 25, "lines_coords": [[[189.0, 1029.0], [217.0, 1029.0], [217.0, 1160.0], [189.0, 1160.0]]], "lines": ["いやぁ～～"]}, {"box": [106, 1137, 170, 1250], "vertical": true, "font_size": 25, "lines_coords": [[[140.0, 1137.0], [168.0, 1137.0], [170.0, 1250.0], [142.0, 1250.0]], [[106.0, 1145.0], [132.0, 1145.0], [132.0, 1248.0], [106.0, 1248.0]]], "lines": ["どうです", "かねぇー"]}, {"box": [635, 1296, 738, 1508], "vertical": true, "font_size": 25, "lines_coords": [[[710.0, 1300.0], [737.0, 1300.0], [737.0, 1468.0], [710.0, 1468.0]], [[676.0, 1300.0], [698.0, 1300.0], [698.0, 1507.0], [676.0, 1507.0]], [[639.0, 1296.0], [665.0, 1296.0], [662.0, 1457.0], [635.0, 1457.0]]], "lines": ["そろそろさぁ、", "結婚とか考えてん", "じゃないの？"]}, {"box": [454, 1355, 479, 1468], "vertical": true, "font_size": 22, "lines_coords": [[[454.0, 1356.0], [476.0, 1356.0], [476.0, 1462.0], [454.0, 1462.0]]], "lines": ["．．．．．．いや"]}, {"box": [366, 1328, 392, 1545], "vertical": true, "font_size": 21, "lines_coords": [[[368.0, 1328.0], [389.0, 1328.0], [389.0, 1537.0], [368.0, 1537.0]]], "lines": ["・この時にはもう"]}, {"box": [110, 1257, 128, 1298], "vertical": true, "font_size": 25, "lines_coords": [[[110.0, 1257.0], [128.0, 1257.0], [128.0, 1298.0], [110.0, 1298.0]]], "lines": ["．．．"]}, {"box": [201, 1353, 304, 1533], "vertical": true, "font_size": 24, "lines_coords": [[[276.0, 1353.0], [304.0, 1353.0], [301.0, 1459.0], [273.0, 1459.0]], [[240.0, 1356.0], [262.0, 1356.0], [262.0, 1531.0], [240.0, 1531.0]], [[201.0, 1354.0], [225.0, 1354.0], [226.0, 1517.0], [203.0, 1517.0]]], "lines": ["すべてが", "決まっていたの", "かもしれない。"]}], "img_path": "193.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [701, 1046, 735, 1183], "vertical": true, "font_size": 34, "lines_coords": [[[701.0, 1046.0], [735.0, 1046.0], [735.0, 1117.0], [701.0, 1117.0]]], "lines": ["あのー"]}, {"box": [400, 1310, 501, 1496], "vertical": true, "font_size": 29, "lines_coords": [[[467.0, 1312.0], [501.0, 1312.0], [501.0, 1396.0], [467.0, 1396.0]], [[429.0, 1310.0], [460.0, 1310.0], [460.0, 1496.0], [429.0, 1496.0]], [[400.0, 1314.0], [421.0, 1314.0], [421.0, 1468.0], [400.0, 1468.0]]], "lines": ["土曜は", "午前中で終わり", "ですけど．．．"]}], "img_path": "194.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [973, 970, 1001, 1142], "vertical": true, "font_size": 26, "lines_coords": [[[973.0, 970.0], [1000.0, 970.0], [1001.0, 1140.0], [975.0, 1140.0]]], "lines": ["．．．こんにちは。"]}, {"box": [151, 1073, 220, 1259], "vertical": true, "font_size": 30, "lines_coords": [[[187.0, 1073.0], [220.0, 1073.0], [220.0, 1165.0], [187.0, 1165.0]], [[154.0, 1073.0], [182.0, 1073.0], [179.0, 1259.0], [151.0, 1259.0]]], "lines": ["．．．約束、", "憶えてますか？"]}], "img_path": "195.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [105, 911, 233, 929], "vertical": false, "font_size": 20, "lines_coords": [[[105.0, 909.0], [233.0, 909.0], [233.0, 931.0], [105.0, 931.0]]], "lines": ["それじゃ、じゃねーから前後にも、"]}, {"box": [110, 1335, 209, 1532], "vertical": true, "font_size": 27, "lines_coords": [[[176.0, 1335.0], [209.0, 1335.0], [209.0, 1425.0], [176.0, 1425.0]], [[142.0, 1335.0], [168.0, 1335.0], [170.0, 1517.0], [143.0, 1517.0]], [[110.0, 1337.0], [132.0, 1337.0], [132.0, 1525.0], [110.0, 1525.0]]], "lines": ["なんか、", "学生時代を思い", "出しちゃったな。"]}, {"box": [767, 1266, 810, 1280], "vertical": false, "font_size": 16, "lines_coords": [[[767.0, 1264.0], [810.0, 1264.0], [810.0, 1282.0], [767.0, 1282.0]]], "lines": ["．．．"]}, {"box": [884, 1202, 914, 1389], "vertical": true, "font_size": 30, "lines_coords": [[[884.0, 1204.0], [914.0, 1204.0], [914.0, 1237.0], [884.0, 1237.0]]], "lines": ["ふ"]}], "img_path": "196.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [903, 118, 929, 279], "vertical": true, "font_size": 25, "lines_coords": [[[903.0, 118.0], [929.0, 118.0], [929.0, 279.0], [903.0, 279.0]]], "lines": ["小野寺さんは、"]}, {"box": [312, 248, 339, 376], "vertical": true, "font_size": 29, "lines_coords": [[[312.0, 248.0], [339.0, 248.0], [339.0, 376.0], [312.0, 376.0]]], "lines": ["．．．僕かい？"]}, {"box": [803, 346, 898, 503], "vertical": true, "font_size": 25, "lines_coords": [[[876.0, 348.0], [898.0, 348.0], [898.0, 451.0], [876.0, 451.0]], [[839.0, 346.0], [865.0, 346.0], [865.0, 503.0], [839.0, 503.0]], [[803.0, 346.0], [829.0, 346.0], [829.0, 453.0], [803.0, 453.0]]], "lines": ["．．．とんな", "学生だったん", "ですか？"]}, {"box": [209, 440, 275, 598], "vertical": true, "font_size": 29, "lines_coords": [[[242.0, 440.0], [275.0, 440.0], [275.0, 551.0], [242.0, 551.0]], [[209.0, 442.0], [235.0, 442.0], [235.0, 598.0], [209.0, 598.0]]], "lines": ["僕は．．．", "まぁ、月並さ。"]}, {"box": [860, 859, 1005, 1072], "vertical": true, "font_size": 24, "lines_coords": [[[981.0, 859.0], [1003.0, 859.0], [1003.0, 1031.0], [981.0, 1031.0]], [[951.0, 859.0], [975.0, 859.0], [973.0, 1071.0], [950.0, 1071.0]], [[923.0, 859.0], [945.0, 859.0], [945.0, 1070.0], [923.0, 1070.0]], [[893.0, 859.0], [914.0, 859.0], [914.0, 1070.0], [893.0, 1070.0]], [[860.0, 860.0], [889.0, 860.0], [889.0, 943.0], [860.0, 943.0]]], "lines": ["．．．自分は特別で、", "他人とは違う何かを", "持っていると信じて", "それをずっと探して", "いたよ。"]}, {"box": [831, 1256, 921, 1468], "vertical": true, "font_size": 24, "lines_coords": [[[898.0, 1256.0], [921.0, 1256.0], [920.0, 1423.0], [896.0, 1423.0]], [[862.0, 1256.0], [889.0, 1256.0], [887.0, 1468.0], [860.0, 1468.0]], [[831.0, 1260.0], [853.0, 1260.0], [853.0, 1429.0], [831.0, 1429.0]]], "lines": ["．．．今はその頃の", "自分を「若かった」の", "一言で片付けて、"]}, {"box": [690, 1315, 779, 1492], "vertical": true, "font_size": 24, "lines_coords": [[[753.0, 1315.0], [779.0, 1315.0], [776.0, 1457.0], [750.0, 1457.0]], [[721.0, 1318.0], [743.0, 1318.0], [743.0, 1482.0], [721.0, 1482.0]], [[690.0, 1317.0], [712.0, 1317.0], [712.0, 1492.0], [690.0, 1492.0]]], "lines": ["でっちあげの", "屁理屈で帳尻を", "合わせてるんだ。"]}, {"box": [568, 1166, 594, 1285], "vertical": true, "font_size": 22, "lines_coords": [[[568.0, 1167.0], [590.0, 1167.0], [590.0, 1284.0], [568.0, 1284.0]]], "lines": ["今はただ．．．"]}, {"box": [226, 1190, 351, 1389], "vertical": true, "font_size": 23, "lines_coords": [[[325.0, 1190.0], [351.0, 1190.0], [351.0, 1335.0], [325.0, 1335.0]], [[293.0, 1192.0], [315.0, 1192.0], [315.0, 1381.0], [293.0, 1381.0]], [[262.0, 1192.0], [284.0, 1192.0], [284.0, 1346.0], [262.0, 1346.0]], [[229.0, 1190.0], [251.0, 1190.0], [248.0, 1389.0], [226.0, 1389.0]]], "lines": ["器の中の水が", "表面張力の限界を", "超えて、一気に", "こぼれ出すように、"]}, {"box": [89, 1331, 209, 1532], "vertical": true, "font_size": 23, "lines_coords": [[[182.0, 1331.0], [209.0, 1331.0], [206.0, 1500.0], [179.0, 1500.0]], [[153.0, 1332.0], [175.0, 1332.0], [175.0, 1476.0], [153.0, 1476.0]], [[120.0, 1332.0], [142.0, 1332.0], [142.0, 1532.0], [120.0, 1532.0]], [[89.0, 1332.0], [110.0, 1332.0], [110.0, 1460.0], [89.0, 1460.0]]], "lines": ["心の中の何かが", "溢れ出すのを", "恐れながら、目常を", "過ごしてる。"]}], "img_path": "197.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [940, 69, 966, 240], "vertical": true, "font_size": 22, "lines_coords": [[[942.0, 70.0], [964.0, 70.0], [964.0, 239.0], [942.0, 239.0]]], "lines": ["小野寺さんは．．．"]}, {"box": [217, 87, 279, 225], "vertical": true, "font_size": 28, "lines_coords": [[[251.0, 87.0], [279.0, 87.0], [279.0, 192.0], [251.0, 192.0]], [[217.0, 87.0], [243.0, 87.0], [243.0, 225.0], [217.0, 225.0]]], "lines": ["．．．納得は", "してるけど、"]}, {"box": [106, 182, 171, 325], "vertical": true, "font_size": 28, "lines_coords": [[[139.0, 182.0], [171.0, 182.0], [171.0, 267.0], [139.0, 267.0]], [[106.0, 184.0], [132.0, 184.0], [132.0, 325.0], [106.0, 325.0]]], "lines": ["満足は", "していない。"]}, {"box": [704, 418, 773, 605], "vertical": true, "font_size": 31, "lines_coords": [[[742.0, 421.0], [773.0, 421.0], [773.0, 579.0], [742.0, 579.0]], [[704.0, 418.0], [735.0, 418.0], [735.0, 604.0], [704.0, 604.0]]], "lines": ["今、幸せじゃ", "ないんですか？"]}, {"box": [187, 415, 312, 631], "vertical": true, "font_size": 23, "lines_coords": [[[287.0, 415.0], [309.0, 415.0], [309.0, 534.0], [287.0, 534.0]], [[251.0, 415.0], [278.0, 415.0], [278.0, 620.0], [251.0, 620.0]], [[220.0, 415.0], [242.0, 415.0], [242.0, 629.0], [220.0, 629.0]], [[187.0, 415.0], [209.0, 415.0], [209.0, 615.0], [187.0, 615.0]]], "lines": ["本当は．．．", "無心で、陶芸に没頭", "できる環境が欲しい、", "．．．それだけなんだ。"]}, {"box": [892, 760, 956, 906], "vertical": true, "font_size": 25, "lines_coords": [[[929.0, 760.0], [956.0, 760.0], [956.0, 906.0], [929.0, 906.0]], [[895.0, 760.0], [918.0, 760.0], [915.0, 895.0], [892.0, 895.0]]], "lines": ["．．．でも、年を", "取るにつれ"]}, {"box": [154, 882, 257, 1105], "vertical": true, "font_size": 26, "lines_coords": [[[228.0, 884.0], [254.0, 884.0], [254.0, 1090.0], [228.0, 1090.0]], [[189.0, 882.0], [215.0, 882.0], [215.0, 1104.0], [189.0, 1104.0]], [[154.0, 884.0], [181.0, 884.0], [181.0, 1100.0], [154.0, 1100.0]]], "lines": ["価値の無いもので", "すら、失うのが怖く", "なってくるんだよ。"]}, {"box": [315, 1250, 343, 1356], "vertical": true, "font_size": 24, "lines_coords": [[[315.0, 1250.0], [343.0, 1250.0], [343.0, 1356.0], [315.0, 1356.0]]], "lines": ["．．．ゴメン、"]}, {"box": [151, 1292, 271, 1496], "vertical": true, "font_size": 24, "lines_coords": [[[250.0, 1298.0], [271.0, 1298.0], [271.0, 1462.0], [250.0, 1462.0]], [[217.0, 1298.0], [239.0, 1298.0], [239.0, 1471.0], [217.0, 1471.0]], [[181.0, 1292.0], [207.0, 1292.0], [206.0, 1496.0], [179.0, 1496.0]], [[151.0, 1296.0], [173.0, 1296.0], [173.0, 1404.0], [151.0, 1404.0]]], "lines": ["つまらないこと", "喋り過ぎたかな。", "．．．今日はそろそろ", "帰ろうか。"]}], "img_path": "198.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [904, 90, 932, 198], "vertical": true, "font_size": 28, "lines_coords": [[[904.0, 90.0], [932.0, 90.0], [932.0, 198.0], [904.0, 198.0]]], "lines": ["．．．君は．．．"]}, {"box": [681, 290, 789, 331], "vertical": false, "font_size": 16.0, "lines_coords": [[[681.0, 290.0], [789.0, 290.0], [789.0, 306.0], [681.0, 306.0]], [[684.0, 315.0], [787.0, 315.0], [787.0, 331.0], [684.0, 331.0]]], "lines": ["胎内拝観の拝観時間", "輝くなると意味につき"]}, {"box": [684, 351, 787, 367], "vertical": false, "font_size": 16, "lines_coords": [[[684.0, 351.0], [787.0, 351.0], [787.0, 367.0], [684.0, 367.0]]], "lines": ["ＡＭＢＯＯ－ＰＭ４３０"]}, {"box": [689, 332, 762, 343], "vertical": false, "font_size": 11, "lines_coords": [[[689.0, 332.0], [762.0, 332.0], [762.0, 343.0], [689.0, 343.0]]], "lines": ["下記時間とします"]}, {"box": [570, 290, 643, 345], "vertical": false, "font_size": 31.5, "lines_coords": [[[603.0, 326.0], [631.0, 326.0], [631.0, 345.0], [603.0, 345.0]], [[570.0, 293.0], [642.0, 290.0], [643.0, 334.0], [571.0, 337.0]]], "lines": ["はいはいっ", "そういえば、そうですね．．．"]}, {"box": [415, 126, 443, 234], "vertical": true, "font_size": 28, "lines_coords": [[[415.0, 126.0], [443.0, 126.0], [443.0, 234.0], [415.0, 234.0]]], "lines": ["私は．．．"]}, {"box": [538, 532, 601, 715], "vertical": true, "font_size": 24, "lines_coords": [[[573.0, 532.0], [600.0, 532.0], [600.0, 690.0], [573.0, 690.0]], [[539.0, 534.0], [560.0, 534.0], [560.0, 715.0], [539.0, 715.0]]], "lines": ["君は幸せって", "なんだと思う？"]}, {"box": [101, 540, 237, 750], "vertical": true, "font_size": 27, "lines_coords": [[[207.0, 540.0], [235.0, 540.0], [237.0, 673.0], [209.0, 673.0]], [[173.0, 543.0], [200.0, 543.0], [200.0, 750.0], [173.0, 750.0]], [[135.0, 542.0], [162.0, 542.0], [162.0, 673.0], [135.0, 673.0]], [[101.0, 543.0], [128.0, 543.0], [128.0, 684.0], [101.0, 684.0]]], "lines": ["大切な人と", "一緒にいられれば", "それだけで", "いいんです。"]}, {"box": [876, 810, 906, 971], "vertical": true, "font_size": 27, "lines_coords": [[[876.0, 810.0], [903.0, 810.0], [906.0, 971.0], [879.0, 971.0]]], "lines": ["．．．そうかぁ．．．"]}, {"box": [946, 1082, 1007, 1190], "vertical": true, "font_size": 28, "lines_coords": [[[981.0, 1082.0], [1007.0, 1082.0], [1007.0, 1190.0], [981.0, 1190.0]], [[946.0, 1084.0], [975.0, 1084.0], [975.0, 1190.0], [946.0, 1190.0]]], "lines": ["．．．君なら", "大丈夫！！"]}, {"box": [153, 1043, 251, 1203], "vertical": true, "font_size": 24, "lines_coords": [[[220.0, 1045.0], [248.0, 1045.0], [251.0, 1164.0], [223.0, 1164.0]], [[187.0, 1043.0], [214.0, 1043.0], [210.0, 1203.0], [184.0, 1203.0]], [[153.0, 1046.0], [175.0, 1046.0], [175.0, 1176.0], [153.0, 1176.0]]], "lines": ["．．．お互い、", "明日からまた", "頑張ろう！！"]}, {"box": [720, 1359, 821, 1543], "vertical": true, "font_size": 28, "lines_coords": [[[790.0, 1360.0], [821.0, 1360.0], [821.0, 1532.0], [790.0, 1532.0]], [[756.0, 1359.0], [782.0, 1359.0], [782.0, 1543.0], [756.0, 1543.0]], [[720.0, 1360.0], [748.0, 1360.0], [748.0, 1465.0], [720.0, 1465.0]]], "lines": ["いつかきっと", "幸せになれると", "思うし！！"]}, {"box": [103, 1289, 196, 1473], "vertical": true, "font_size": 24, "lines_coords": [[[175.0, 1289.0], [196.0, 1289.0], [196.0, 1453.0], [175.0, 1453.0]], [[135.0, 1292.0], [162.0, 1292.0], [162.0, 1473.0], [135.0, 1473.0]], [[103.0, 1290.0], [125.0, 1290.0], [125.0, 1421.0], [103.0, 1421.0]]], "lines": ["．．．だから君も、", "いじめなんかに", "負けるな！！"]}], "img_path": "199.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [613, 60, 649, 174], "vertical": true, "font_size": 34, "lines_coords": [[[614.0, 65.0], [648.0, 65.0], [648.0, 170.0], [614.0, 170.0]]], "lines": ["．．．．．私"]}, {"box": [154, 540, 280, 732], "vertical": true, "font_size": 37, "lines_coords": [[[245.0, 546.0], [278.0, 546.0], [278.0, 729.0], [245.0, 729.0]], [[195.0, 540.0], [240.0, 540.0], [240.0, 643.0], [195.0, 643.0]], [[157.0, 543.0], [190.0, 543.0], [187.0, 732.0], [154.0, 732.0]]], "lines": ["いじめられて", "なんか", "いませんよ？"]}, {"box": [826, 1092, 965, 1252], "vertical": true, "font_size": 28, "lines_coords": [[[929.0, 1092.0], [965.0, 1092.0], [965.0, 1159.0], [929.0, 1159.0]], [[900.0, 1095.0], [926.0, 1095.0], [923.0, 1250.0], [896.0, 1250.0]], [[865.0, 1095.0], [887.0, 1095.0], [887.0, 1251.0], [865.0, 1251.0]], [[826.0, 1095.0], [854.0, 1095.0], [854.0, 1209.0], [826.0, 1209.0]]], "lines": ["．．．私", "同じクラスの", "男子の子供を", "妊娠して、"]}, {"box": [148, 1335, 273, 1498], "vertical": true, "font_size": 36, "lines_coords": [[[235.0, 1335.0], [268.0, 1335.0], [271.0, 1467.0], [239.0, 1467.0]], [[193.0, 1339.0], [226.0, 1339.0], [226.0, 1498.0], [193.0, 1498.0]], [[148.0, 1335.0], [190.0, 1335.0], [190.0, 1423.0], [148.0, 1423.0]]], "lines": ["半年前に", "堕ろしたん", "です。"]}], "img_path": "200.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [1001, 50, 1029, 251], "vertical": true, "font_size": 24, "lines_coords": [[[1001.0, 50.0], [1028.0, 50.0], [1029.0, 251.0], [1003.0, 251.0]]], "lines": ["．．．別にいいんです。"]}, {"box": [835, 103, 954, 323], "vertical": true, "font_size": 24, "lines_coords": [[[932.0, 103.0], [954.0, 103.0], [954.0, 268.0], [932.0, 268.0]], [[903.0, 104.0], [925.0, 104.0], [925.0, 323.0], [903.0, 323.0]], [[864.0, 103.0], [892.0, 103.0], [895.0, 318.0], [867.0, 318.0]], [[835.0, 104.0], [857.0, 104.0], [857.0, 281.0], [835.0, 281.0]]], "lines": ["何のいい友達か", "そっけなくなっても、", "クラスの皆が、裏で", "陰口言ってても。"]}, {"box": [409, 95, 440, 240], "vertical": true, "font_size": 26, "lines_coords": [[[412.0, 95.0], [439.0, 95.0], [435.0, 240.0], [409.0, 240.0]]], "lines": ["でも、母が．．"]}, {"box": [668, 559, 770, 718], "vertical": true, "font_size": 27, "lines_coords": [[[739.0, 559.0], [767.0, 559.0], [768.0, 692.0], [740.0, 692.0]], [[704.0, 562.0], [731.0, 562.0], [731.0, 718.0], [704.0, 718.0]], [[668.0, 562.0], [695.0, 562.0], [695.0, 678.0], [668.0, 678.0]]], "lines": ["学校なんて", "たった三年間", "ですから。"]}, {"box": [125, 603, 223, 760], "vertical": true, "font_size": 26, "lines_coords": [[[195.0, 603.0], [223.0, 603.0], [220.0, 750.0], [192.0, 750.0]], [[157.0, 604.0], [184.0, 604.0], [184.0, 760.0], [157.0, 760.0]], [[125.0, 607.0], [148.0, 607.0], [148.0, 659.0], [125.0, 659.0]]], "lines": ["母は、どこか", "おかしいから", "．．．．．"]}, {"box": [852, 856, 951, 1064], "vertical": true, "font_size": 25, "lines_coords": [[[923.0, 857.0], [950.0, 857.0], [950.0, 1000.0], [923.0, 1000.0]], [[887.0, 856.0], [914.0, 856.0], [914.0, 1064.0], [887.0, 1064.0]], [[853.0, 859.0], [875.0, 859.0], [875.0, 1037.0], [853.0, 1037.0]]], "lines": ["．．．これ以上、", "悪い虫が付かない", "ようにって．．．"]}, {"box": [177, 912, 314, 1135], "vertical": true, "font_size": 26, "lines_coords": [[[284.0, 912.0], [312.0, 912.0], [309.0, 1109.0], [281.0, 1109.0]], [[246.0, 912.0], [273.0, 912.0], [273.0, 1082.0], [246.0, 1082.0]], [[210.0, 912.0], [237.0, 912.0], [237.0, 1135.0], [210.0, 1135.0]], [[178.0, 914.0], [200.0, 914.0], [200.0, 1070.0], [178.0, 1070.0]]], "lines": ["普段、私は本当に", "家の柱に、縄で", "縛られて、生活して", "るんですよ？"]}, {"box": [303, 1237, 365, 1435], "vertical": true, "font_size": 26, "lines_coords": [[[339.0, 1237.0], [365.0, 1237.0], [365.0, 1435.0], [339.0, 1435.0]], [[303.0, 1237.0], [329.0, 1237.0], [329.0, 1423.0], [303.0, 1423.0]]], "lines": ["：私はこのまま", "きっと一生．．．"]}, {"box": [153, 1304, 250, 1539], "vertical": true, "font_size": 26, "lines_coords": [[[223.0, 1304.0], [250.0, 1304.0], [250.0, 1539.0], [223.0, 1539.0]], [[185.0, 1306.0], [212.0, 1306.0], [212.0, 1514.0], [185.0, 1514.0]], [[153.0, 1310.0], [175.0, 1310.0], [175.0, 1485.0], [153.0, 1485.0]]], "lines": ["狭い部屋の中だけで", "孤独に年を取って", "いくんです．．．"]}], "img_path": "201.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [826, 128, 963, 322], "vertical": true, "font_size": 26, "lines_coords": [[[935.0, 128.0], [962.0, 128.0], [959.0, 287.0], [932.0, 287.0]], [[900.0, 131.0], [926.0, 131.0], [926.0, 320.0], [900.0, 320.0]], [[862.0, 129.0], [889.0, 129.0], [889.0, 287.0], [862.0, 287.0]], [[828.0, 131.0], [851.0, 131.0], [850.0, 310.0], [826.0, 310.0]]], "lines": ["今日は強引に", "母を押し切って、", "逃げるように", "出て来たから．．"]}, {"box": [125, 332, 259, 515], "vertical": true, "font_size": 25, "lines_coords": [[[232.0, 334.0], [259.0, 334.0], [259.0, 440.0], [232.0, 440.0]], [[193.0, 332.0], [220.0, 332.0], [220.0, 503.0], [193.0, 503.0]], [[159.0, 332.0], [185.0, 332.0], [185.0, 464.0], [159.0, 464.0]], [[126.0, 334.0], [146.0, 334.0], [146.0, 515.0], [126.0, 515.0]]], "lines": ["このまま", "帰ったら、母に", "何されるか", "わかりません．．．"]}, {"box": [875, 800, 938, 959], "vertical": true, "font_size": 28, "lines_coords": [[[910.0, 800.0], [937.0, 800.0], [937.0, 959.0], [910.0, 959.0]], [[875.0, 800.0], [903.0, 800.0], [903.0, 907.0], [875.0, 907.0]]], "lines": ["もしかしたら", "私は．．．"]}, {"box": [201, 1156, 244, 1383], "vertical": true, "font_size": 42, "lines_coords": [[[201.0, 1157.0], [243.0, 1157.0], [243.0, 1382.0], [201.0, 1382.0]]], "lines": ["．．．殺される。"]}], "img_path": "202.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [407, 387, 446, 573], "vertical": true, "font_size": 38, "lines