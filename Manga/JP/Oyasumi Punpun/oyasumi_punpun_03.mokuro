.0], [920.0, 534.0], [920.0, 664.0], [893.0, 664.0]]], "lines": ["．．．え？", "矢口先輩？", "バド部の？"]}, {"box": [435, 542, 573, 728], "vertical": true, "font_size": 27, "lines_coords": [[[540.0, 542.0], [573.0, 542.0], [573.0, 678.0], [540.0, 678.0]], [[506.0, 543.0], [532.0, 543.0], [532.0, 675.0], [506.0, 675.0]], [[471.0, 542.0], [498.0, 542.0], [495.0, 728.0], [468.0, 728.0]], [[437.0, 545.0], [459.0, 545.0], [459.0, 726.0], [437.0, 726.0]]], "lines": ["あぁ～～～", "まー確かに", "園ちゃんの好き", "そうな顔だね〜"]}, {"box": [857, 845, 957, 1025], "vertical": true, "font_size": 28, "lines_coords": [[[925.0, 846.0], [957.0, 846.0], [957.0, 957.0], [925.0, 957.0]], [[892.0, 846.0], [918.0, 846.0], [918.0, 1025.0], [892.0, 1025.0]], [[857.0, 845.0], [884.0, 845.0], [884.0, 960.0], [857.0, 960.0]]], "lines": ["．．．．．先輩、", "チンコ超でかい", "らしーよ。"]}, {"box": [195, 1000, 223, 1190], "vertical": true, "font_size": 22, "lines_coords": [[[195.0, 1000.0], [217.0, 1000.0], [217.0, 1184.0], [195.0, 1184.0]]], "lines": ["エリンギくらい。"]}], "img_path": "040.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [903, 120, 1007, 281], "vertical": true, "font_size": 31, "lines_coords": [[[975.0, 121.0], [1007.0, 121.0], [1007.0, 235.0], [975.0, 235.0]], [[942.0, 123.0], [970.0, 123.0], [970.0, 243.0], [942.0, 243.0]], [[903.0, 120.0], [935.0, 120.0], [935.0, 281.0], [903.0, 281.0]]], "lines": ["バーカ、", "聞いてねー", "っつーの！！"]}, {"box": [518, 140, 623, 285], "vertical": true, "font_size": 30, "lines_coords": [[[582.0, 142.0], [618.0, 140.0], [623.0, 232.0], [587.0, 234.0]], [[553.0, 143.0], [581.0, 143.0], [581.0, 250.0], [553.0, 250.0]], [[518.0, 143.0], [545.0, 143.0], [545.0, 281.0], [518.0, 281.0]]], "lines": ["あたし、", "ああいう", "軽そうな男、"]}, {"box": [129, 260, 157, 402], "vertical": true, "font_size": 25, "lines_coords": [[[129.0, 260.0], [157.0, 260.0], [157.0, 335.0], [129.0, 335.0]], [[131.0, 343.0], [153.0, 343.0], [153.0, 396.0], [131.0, 396.0]]], "lines": ["キラー", "イ"]}, {"box": [526, 47