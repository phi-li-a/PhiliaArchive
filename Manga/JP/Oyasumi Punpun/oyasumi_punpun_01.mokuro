lines": ["プンブンは冷静に", "考えていました。"]}, {"box": [739, 957, 876, 1221], "vertical": true, "font_size": 28, "lines_coords": [[[846.0, 957.0], [875.0, 957.0], [876.0, 1115.0], [848.0, 1115.0]], [[810.0, 957.0], [842.0, 957.0], [842.0, 1221.0], [810.0, 1221.0]], [[775.0, 960.0], [801.0, 960.0], [801.0, 1218.0], [775.0, 1218.0]], [[739.0, 959.0], [767.0, 959.0], [767.0, 1098.0], [739.0, 1098.0]]], "lines": ["人類を宇宙に", "イジューさせるなんて", "自分には無理なのでは", "ないか、と。"]}, {"box": [260, 1268, 363, 1485], "vertical": true, "font_size": 29, "lines_coords": [[[335.0, 1268.0], [362.0, 1268.0], [362.0, 1376.0], [335.0, 1376.0]], [[296.0, 1270.0], [328.0, 1270.0], [328.0, 1431.0], [296.0, 1431.0]], [[260.0, 1271.0], [287.0, 1271.0], [287.0, 1481.0], [260.0, 1481.0]]], "lines": ["そもそも", "本当に学者に", "なりたいのかすら"]}, {"box": [120, 1325, 184, 1534], "vertical": true, "font_size": 27, "lines_coords": [[[156.0, 1325.0], [182.0, 1325.0], [184.0, 1532.0], [157.0, 1532.0]], [[120.0, 1326.0], [148.0, 1326.0], [148.0, 1439.0], [120.0, 1439.0]]], "lines": ["わからなくなって", "きました。"]}], "img_path": "051.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [881, 97, 909, 256], "vertical": true, "font_size": 26, "lines_coords": [[[881.0, 100.0], [907.0, 100.0], [907.0, 256.0], [881.0, 256.0]]], "lines": ["．．．ブンプン！！"]}, {"box": [84, 65, 370, 92], "vertical": false, "font_size": 27, "lines_coords": [[[84.0, 65.0], [370.0, 65.0], [370.0, 92.0], [84.0, 92.0]]], "lines": ["おやすみプンプン［"]}, {"box": [896, 739, 967, 873], "vertical": true, "font_size": 32, "lines_coords": [[[928.0, 739.0], [967.0, 739.0], [967.0, 829.0], [928.0, 829.0]], [[896.0, 743.0], [925.0, 743.0], [925.0, 873.0], [896.0, 873.0]]], "lines": ["なんで", "嘘つくの？"]}, {"box": [756, 820, 860, 953], "vertical": true, "font_size": 32, "lines_coords": [[[826.0, 820.0], [860.0, 820.0], [860.0, 907.0], [826.0, 907.0]], [[793.0, 823.0], [821.0, 823.0], [821.0, 953.0], [793.0, 953.0]], [[756.0, 823.0], [784.0, 823.0], [784.0, 914.0], [756.0, 914.0]]], "lines": ["．．．学者", "かっこいい", "じゃん。"]}, {"box": [253, 768, 354, 925], "vertical": true, "font_size": 27, "lines_coords": [[[328.0, 770.0], [354.0, 770.0], [354.0, 875.0], [328.0, 875.0]], [[290.0, 768.0], [317.0, 768.0], [317.0, 925.0], [290.0, 925.0]], [[253.0, 770.0], [281.0, 770.0], [281.0, 906.0], [253.0, 906.0]]], "lines": ["はっきり", "言ってやれば", "いいのにさ、"]}, {"box": [96, 878, 232, 1035], "vertical": true, "font_size": 27, "lines_coords": [[[206.0, 879.0], [232.0, 879.0], [232.0, 984.0], [206.0, 984.0]], [[168.0, 879.0], [195.0, 879.0], [195.0, 1035.0], [168.0, 1035.0]], [[132.0, 878.0], [159.0, 878.0], [159.0, 992.0], [132.0, 992.0]], [[96.0, 878.0], [125.0, 878.0], [125.0, 971.0], [96.0, 971.0]]], "lines": ["みんなを", "メツボーから", "救うんだ、", "．．．って。"]}, {"box": [185, 1289, 213, 1460], "vertical": true, "font_size": 27, "lines_coords": [[[185.0, 1289.0], [212.0, 1289.0], [212.0, 1457.0], [185.0, 1457.0]]], "lines": ["．．．いくじなし。"]}], "img_path": "052.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [540, 142, 676, 351], "vertical": true, "font_size": 26, "lines_coords": [[[650.0, 143.0], [676.0, 143.0], [676.0, 248.0], [650.0, 248.0]], [[612.0, 142.0], [639.0, 142.0], [639.0, 351.0], [612.0, 351.0]], [[578.0, 143.0], [600.0, 143.0], [600.0, 298.0], [578.0, 298.0]], [[540.0, 142.0], [567.0, 142.0], [567.0, 246.0], [540.0, 246.0]]], "lines": ["みんなに", "馬鹿にされるのが", "こわかったん", "てしょ？"]}, {"box": [114, 195, 214, 379], "vertical": true, "font_size": 25, "lines_coords": [[[187.0, 196.0], [214.0, 196.0], [214.0, 301.0], [187.0, 301.0]], [[151.0, 196.0], [175.0, 196.0], [173.0, 353.0], [150.0, 353.0]], [[115.0, 195.0], [139.0, 195.0], [137.0, 379.0], [114.0, 379.0]]], "lines": ["そんなの", "勝手に言わせ", "とけばいいの！！"]}, {"box": [125, 428, 257, 664], "vertical": true, "font_size": 25, "lines_coords": [[[231.0, 428.0], [257.0, 428.0], [257.0, 639.0], [231.0, 639.0]], [[195.0, 429.0], [221.0, 429.0], [223.0, 623.0], [196.0, 623.0]], [[159.0, 428.0],