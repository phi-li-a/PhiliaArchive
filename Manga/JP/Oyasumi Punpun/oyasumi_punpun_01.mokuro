ox": [464, 164, 554, 314], "vertical": true, "font_size": 38, "lines_coords": [[[515.0, 167.0], [554.0, 167.0], [554.0, 312.0], [515.0, 312.0]], [[464.0, 164.0], [501.0, 164.0], [501.0, 314.0], [464.0, 314.0]]], "lines": ["バカじゃ", "ないの？"]}, {"box": [114, 687, 308, 901], "vertical": true, "font_size": 27, "lines_coords": [[[279.0, 692.0], [306.0, 692.0], [306.0, 848.0], [279.0, 848.0]], [[250.0, 692.0], [271.0, 692.0], [271.0, 854.0], [250.0, 854.0]], [[214.0, 690.0], [240.0, 690.0], [237.0, 848.0], [210.0, 848.0]], [[178.0, 690.0], [209.0, 690.0], [209.0, 901.0], [178.0, 901.0]], [[145.0, 687.0], [173.0, 687.0], [175.0, 873.0], [146.0, 873.0]], [[114.0, 690.0], [142.0, 690.0], [142.0, 781.0], [114.0, 781.0]]], "lines": ["愛子ちゃんが", "そう言うなら、", "きっと自分は", "バカなんだろうと", "プンプンは思い", "ました。"]}, {"box": [787, 960, 1017, 1170], "vertical": false, "font_size": 52, "lines_coords": [[[787.0, 1131.0], [982.0, 960.0], [1017.0, 998.0], [821.0, 1170.0]]], "lines": ["．．．９３かこちらが"]}, {"box": [346, 962, 628, 1264], "vertical": false, "font_size": 71, "lines_coords": [[[400.0, 1037.0], [498.0, 962.0], [526.0, 998.0], [426.0, 1073.0]], [[353.0, 1110.0], [509.0, 1014.0], [535.0, 1057.0], [379.0, 1154.0]], [[346.0, 1170.0], [512.0, 964.0], [628.0, 1057.0], [460.0, 1264.0]], [[385.0, 1198.0], [582.0, 1081.0], [604.0, 1118.0], [407.0, 1235.0]]], "lines": ["ケンジ", "ゃＣご潔茶字", "またご無茶をしていることにしか", "．．．いいよ。"]}], "img_path": "184.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [112, 1092, 143, 1223], "vertical": true, "font_size": 23, "lines_coords": [[[120.0, 1092.0], [143.0, 1093.0], [135.0, 1223.0], [112.0, 1221.0]]], "lines": ["月セミターは"]}, {"box": [906, 800, 925, 806], "vertical": false, "font_size": 6, "lines_coords": [[[906.0, 800.0], [925.0, 800.0], [925.0, 806.0], [906.0, 806.0]]], "lines": ["．．"]}], "img_path": "185.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [787, 587, 940, 789], "vertical": true, "font_size": 153, "lines_coords": [[[787.0, 587.0], [940.0, 587.0], [940.0, 789.0], [787.0, 789.0]]], "lines": ["．．．"]}], "img_path": "186.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [607, 548, 713, 776], "vertical": true, "font_size": 25, "lines_coords": [[[684.0, 551.0], [710.0, 551.0], [710.0, 698.0], [684.0, 698.0]], [[648.0, 550.0], [670.0, 550.0], [670.0, 757.0], [648.0, 757.0]], [[609.0, 548.0], [637.0, 548.0], [635.0, 773.0], [607.0, 773.0]]], "lines": ["「鹿児島とは", "どこらへんにある", "島なのだろうか？」"]}, {"box": [375, 551, 479, 711], "vertical": true, "font_size": 27, "lines_coords": [[[448.0, 551.0], [476.0, 551.0], [476.0, 684.0], [448.0, 684.0]], [[412.0, 551.0], [439.0, 551.0], [439.0, 709.0], [412.0, 709.0]], [[375.0, 551.0], [401.0, 551.0], [401.0, 695.0], [375.0, 695.0]]], "lines": ["フンフンは", "愛子ちゃんに", "聞きました。"]}, {"box": [915, 864, 946, 1009], "vertical": true, "font_size": 28, "lines_coords": [[[915.0, 868.0], [943.0, 868.0], [943.0, 1006.0], [915.0, 1006.0]]], "lines": ["．．．プンプン、"]}, {"box": [142, 1040, 207, 1196], "vertical": true, "font_size": 27, "lines_coords": [[[178.0, 1045.0], [206.0, 1045.0], [206.0, 1196.0], [178.0, 1196.0]], [[142.0, 1040.0], [168.0, 1040.0], [168.0, 1171.0], [142.0, 1171.0]]], "lines": ["一緒に行って", "くれるの？"]}], "img_path": "187.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [904, 123, 934, 281], "vertical": true, "font_size": 25, "lines_coords": [[[907.0, 125.0], [932.0, 125.0], [929.0, 279.0], [904.0, 279.0]]], "lines": ["．．．絶対だよ？"]}, {"box": [169, 273, 207, 460], "vertical": true, "font_size": 33, "lines_coords": [[[171.0, 275.0], [204.0, 275.0], [204.0, 460.0], [171.0, 460.0]]], "lines": ["約束だよ！？"]}, {"box": [601, 925, 739, 1162], "vertical": true, "font_size": 30, "lines_coords": [[[707.0, 925.0], [739.0, 925.0], [739.0, 1087.0], [707.0, 1087.0]], [[671.0, 925.0], [703.0, 925.0], [703.0, 1085.0], [671.0, 1085.0]], [[637.0, 925.0], [664.0, 925.0], [664.0, 1162.0], [637.0, 1162.0]], [[601.0, 925.0], [628.0, 925.0], [628.0, 1093.0], [601.0, 1093.0]]], "lines": ["手を離したら", "愛子ちゃんが", "どこか遠くに行って", "しまいそうで、"]}, {"box": [409, 923, 550, 1110], "vertical": true, "font_size": 29, "lines_coords": [[[521.0, 926.0], [550.0, 926.0], [550.0, 1059.0], [521.0, 1059.0]], [[482.0, 923.0], [509.0, 923.0], [512.0, 1109.0], [485.0, 1109.0]], [[448.0, 926.0], [476.0, 926.0], [476.0, 1059.0], [448.0, 1059.0]], [[409.0, 925.0], [442.0, 925.0], [442.0, 1021.0], [409.0, 1021.0]]], "lines": ["プンプンは", "とにかく必死に", "しがみつき", "ました。"]}, {"box": [900, 1231, 968, 1390], "vertical": true, "font_size": 33, "lines_coords": [[[929.0, 1232.0], [964.0, 1231.0], [968.0, 1348.0], [934.0, 1350.0]], [[900.0, 1232.0], [931.0, 1232.0], [931.0, 1390.0], [900.0, 1390.0]]], "lines": ["．．．．．ねぇ、", "プンプン．．．"]}, {"box": [264, 1253, 328, 1410], "vertical": true, "font_size": 26, "lines_coords": [[[300.0, 1253.0], [328.0, 1253.0], [328.0, 1373.0], [300.0, 1373.0]], [[264.0, 1254.0], [290.0, 1254.0], [290.0, 1410.0], [264.0, 1410.0]]], "lines": ["もし、約束", "やぶったら．．．"]}, {"box": [96, 1378, 231, 1535], "vertical": true, "font_size": 26, "lines_coords": [[[203.0, 1379.0], [231.0, 1379.0], [231.0, 1510.0], [203.0, 1510.0]], [[167.0, 1378.0], [193.0, 1378.0], [193.0, 1512.0], [167.0, 1512.0]], [[128.0, 1379.0], [154.0, 1379.0], [154.0, 1487.0], [128.0, 1487.0]], [[96.0, 1382.0], [118.0, 1382.0], [118.0, 1535.0], [96.0, 1535.0]]], "lines": ["プンプンが", "もし、また", "あたしを", "裏切ったら．．．"]}], "img_path": "188.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [178, 345, 268, 512], "vertical": true, "font_size": 39, "lines_coords": [[[225.0, 346.0], [265.0, 345.0], [268.0, 460.0], [228.0, 462.0]], [[178.0, 345.0], [215.0, 345.0], [215.0, 512.0], [178.0, 512.0]]], "lines": ["今度は", "殺すから。"]}, {"box": [467, 1326, 641, 1536], "vertical": true, "font_size": 26, "lines_coords": [[[614.0, 1326.0], [640.0, 1326.0], [640.0, 1457.0], [614.0, 1457.0]], [[576.0, 1328.0], [603.0, 1328.0], [603.0, 1534.0], [576.0, 1534.0]], [[539.0, 1328.0], [565.0, 1328.0], [565.0, 1509.0], [539.0, 1509.0]], [[503.0, 1326.0], [529.0, 1326.0], [529.0, 1459.0], [503.0, 1459.0]], [[467.0, 1326.0], [493.0, 1326.0], [493.0, 1443.0], [467.0, 1443.0]]], "lines": ["フンフンは", "一学期の終業式に", "二人で鹿児島に", "行く約束を", "しました。"]}], "img_path": "189.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "190.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "191.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [218, 128, 248, 253], "vertical": true, "font_size": 27, "lines_coords": [[[218.0, 129.0], [245.0, 129.0], [245.0, 253.0], [218.0, 253.0]]], "lines": ["鹿児島？"]}, {"box": [40, 290, 78, 448], "vertical": true, "font_size": 38, "lines_coords": [[[40.0, 290.0], [78.0, 290.0], [78.0, 448.0], [40.0, 448.0]]], "lines": ["第１１話"]}, {"box": [854, 440, 993, 621], "vertical": true, "font_size": 26, "lines_coords": [[[970.0, 440.0], [993.0, 440.0], [993.0, 487.0], [970.0, 487.0]], [[931.0, 442.0], [959.0, 442.0], [956.0, 600.0], [928.0, 600.0]], [[895.0, 442.0], [921.0, 442.0], [918.0, 621.0], [892.0, 621.0]], [[857.0, 440.0], [885.0, 440.0], [882.0, 571.0], [854.0, 571.0]]], "lines": ["まー", "飛行機使えば", "３、４万くらい", "じゃない？"]}, {"box": [273, 465, 375, 651], "vertical": true, "font_size": 30, "lines_coords": [[[348.0, 467.0], [375.0, 467.0], [375.0, 600.0], [348.0, 600.0]], [[309.0, 465.0], [340.0, 465.0], [340.0, 651.0], [309.0, 651.0]], [[273.0, 467.0], [303.0, 467.0], [303.0, 540.0], [273.0, 540.0]]], "lines": ["新幹線なら", "３万弱ってとこ", "かねー"]}, {"box": [168, 637, 235, 782], "vertical": true, "font_size": 30, "lines_coords": [[[201.0, 637.0], [235.0, 637.0], [235.0, 725.0], [201.0, 725.0]], [[168.0, 640.0], [195.0, 640.0], [195.0, 782.0], [168.0, 782.0]]], "lines": ["半日は", "かかるけど。"]}, {"box": [937, 1271, 1004, 1381], "vertical": true, "font_size": 32, "lines_coords": [[[968.0, 1271.0], [1004.0, 1271.0], [1004.0, 1334.0], [968.0, 1334.0]], [[937.0, 1276.0], [965.0, 1276.0], [965.0, 1381.0], [937.0, 1381.0]]], "lines": ["え？", "歩いて？"]}, {"box": [534, 1265, 596, 1381], "vertical": true, "font_size": 28, "lines_coords": [[[568.0, 1265.0], [596.0, 1265.0], [596.0, 1354.0], [568.0, 1354.0]], [[534.0, 1267.0], [560.0, 1267.0], [560.0, 1381.0], [534.0, 1381.0]]], "lines": ["あはは、", "ムリムリ。"]}, {"box": [410, 1365, 478, 1523], "vertical": true, "font_size": 28, "lines_coords": [[[446.0, 1365.0], [478.0, 1365.0], [478.0, 1523.0], [446.0, 1523.0]], [[410.0, 1367.0], [437.0, 1367.0], [437.0, 1498.0], [410.0, 1498.0]]], "lines": ["伊能忠敬かっ", "つーの！！"]}], "img_path": "192.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [204, 242, 307, 437], "vertical": true, "font_size": 26, "lines_coords": [[[278.0, 242.0], [304.0, 242.0], [304.0, 376.0], [278.0, 376.0]], [[242.0, 242.0], [268.0, 242.0], [268.0, 401.0], [242.0, 401.0]], [[204.0, 242.0], [231.0, 242.0], [231.0, 434.0], [204.0, 434.0]]], "lines": ["プンプンは", "こんな気持ち", "はじめてでした。"]}, {"box": [519, 685, 559, 776], "vertical": true, "font_size": 39, "lines_coords": [[[520.0, 687.0], [559.0, 687.0], [559.0, 773.0], [520.0, 773.0]]], "lines": ["絶望。"]}, {"box": [251, 996, 379, 1220], "vertical": true, "font_size": 30, "lines_coords": [[[353.0, 1000.0], [379.0, 1000.0], [379.0, 1184.0], [353.0, 1184.0]], [[321.0, 1001.0], [348.0, 1001.0], [348.0, 1189.0], [321.0, 1189.0]], [[284.0, 998.0], [317.0, 998.0], [320.0, 1220.0], [287.0, 1220.0]], [[259.0, 996.0], [292.0, 998.0], [289.0, 1096.0], [256.0, 1095.0]]], "lines": ["そんなにより", "しばらくの間", "閉店させて頂き", "ます。"]}], "img_path": "193.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [945, 306, 992, 401], "vertical": false, "font_size": 18, "lines_coords": [[[946.0, 395.0], [968.0, 329.0], [985.0, 335.0], [964.0, 401.0]]], "lines": ["お弁当の"]}, {"box": [523, 103, 626, 315], "vertical": true, "font_size": 28, "lines_coords": [[[595.0, 103.0], [626.0, 103.0], [626.0, 315.0], [595.0, 315.0]], [[560.0, 106.0], [587.0, 106.0], [587.0, 289.0], [560.0, 289.0]], [[523.0, 104.0], [550.0, 104.0], [550.0, 289.0], [523.0, 289.0]]], "lines": ["．．．親父、今日から", "新しい仕事じゃ", "なかったっけ？"]}, {"box": [125, 109, 303, 325], "vertical": true, "font_size": 30, "lines_coords": [[[276.0, 114.0], [303.0, 114.0], [303.0, 284.0], [276.0, 284.0]], [[240.0, 115.0], [267.0, 115.0], [267.0, 271.0], [240.0, 271.0]], [[204.0, 115.0], [231.0, 115.0], [231.0, 300.0], [204.0, 300.0]], [[168.0, 114.0], [195.0, 114.0], [192.0, 325.0], [165.0, 325.0]], [[125.0, 109.0], [165.0, 109.0], [165.0, 185.0], [125.0, 185.0]]], "lines": ["．．．うるせえよ。", "んなチマチマ", "働かなくたって", "貯金くらいあるん", "だよ。"]}, {"box": [620, 810, 684, 971], "vertical": true, "font_size": 29, "lines_coords": [[[653.0, 810.0], [684.0, 810.0], [684.0, 971.0], [653.0, 971.0]], [[620.0, 810.0], [646.0, 810.0], [646.0, 954.0], [620.0, 954.0]]], "lines": ["．．．強がってん", "じゃねーよ。"]}, {"box": [503, 903, 603, 1064], "vertical": true, "font_size": 29, "lines_coords": [[[576.0, 904.0], [603.0, 904.0], [603.0, 1012.0], [576.0, 1012.0]], [[537.0, 903.0], [568.0, 903.0], [568.0, 1064.0], [537.0, 1064.0]], [[503.0, 904.0], [531.0, 904.0], [531.0, 984.0], [503.0, 984.0]]], "lines": ["また逃げ", "だして来たん", "だろ？"]}, {"box": [148, 873, 250, 1086], "vertical": true, "font_size": 25, "lines_coords": [[[225.0, 879.0], [246.0, 879.0], [246.0, 1010.0], [225.0, 1010.0]], [[184.0, 875.0], [210.0, 875.0], [210.0, 1085.0], [184.0, 1085.0]], [[148.0, 873.0], [175.0, 873.0], [175.0, 1060.0], [148.0, 1060.0]]], "lines": ["．．．お前こそ", "そんなもん持って", "どうする気だ？"]}, {"box": [740, 1270, 876, 1488], "vertical": true, "font_size": 26, "lines_coords": [[[848.0, 1270.0], [875.0, 1270.0], [875.0, 1478.0], [848.0, 1478.0]], [[812.0, 1270.0], [839.0, 1270.0], [839.0, 1487.0], [812.0, 1487.0]], [[773.0, 1270.0], [800.0, 1270.0], [800.0, 1429.0], [773.0, 1429.0]], [[740.0, 1270.0], [762.0, 1270.0], [762.0, 1426.0], [740.0, 1426.0]]], "lines": ["．．．母ちゃんばかり", "働かせて、あんた、", "なんとも思わ", "ねえの．．．．．．？"]}, {"box": [534, 1389, 584, 1435], "vertical": false, "font_size": 15, "lines_coords": [[[545.0, 1389.0], [584.0, 1425.0], [573.0, 1435.0], [534.0, 1400.0]]], "lines": ["なかっ"]}], "img_path": "194.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [890, 150, 1026, 360], "vertical": true, "font_size": 27, "lines_coords": [[[998.0, 151.0], [1025.0, 151.0], [1025.0, 309.0], [998.0, 309.0]], [[960.0, 150.0], [987.0, 150.0], [987.0, 360.0], [960.0, 360.0]], [[926.0, 150.0], [953.0, 150.0], [953.0, 359.0], [926.0, 359.0]], [[890.0, 150.0], [917.0, 150.0], [917.0, 318.0], [890.0, 318.0]]], "lines": ["いいかげんな", "飲んだくれ野郎を", "これでおもいきり", "ぶん殴ったら、"]}, {"box": [171, 285, 276, 449], "vertical": true, "font_size": 30, "lines_coords": [[[248.0, 287.0], [275.0, 287.0], [271.0, 420.0], [245.0, 420.0]], [[207.0, 287.0], [242.0, 287.0], [242.0, 365.0], [207.0, 365.0]], [[171.0, 287.0], [198.0, 285.0], [203.0, 406.0], [176.0, 407.0]]], "lines": ["どうなんの", "かなー", "と思って。"]}, {"box": [884, 606, 949, 762], "vertical": true, "font_size": 23, "lines_coords": [[[923.0, 606.0], [946.0, 606.0], [945.0, 762.0], [921.0, 762.0]], [[887.0, 606.0], [909.0, 606.0], [909.0, 746.0], [887.0, 746.0]]], "lines": ["．．．どうにも", "なんねーよ。"]}, {"box": [178, 604, 281, 815], "vertical": true, "font_size": 27, "lines_coords": [[[254.0, 606.0], [281.0, 606.0], [281.0, 764.0], [254.0, 764.0]], [[218.0, 607.0], [245.0, 607.0], [245.0, 815.0], [218.0, 815.0]], [[181.0, 604.0], [209.0, 604.0], [206.0, 746.0], [178.0, 746.0]]], "lines": ["てめー自身の", "人生がブチ壊れる", "だけだろが。"]}, {"box": [887, 956, 914, 1145], "vertical": true, "font_size": 30, "lines_coords": [[[887.0, 956.0], [914.0, 956.0], [914.0, 1145.0], [887.0, 1145.0]]], "lines": ["．．．ねぇ父ちゃん、"]}, {"box": [712, 1076, 818, 1212], "vertical": true, "font_size": 30, "lines_coords": [[[785.0, 1076.0], [818.0, 1076.0], [818.0, 1189.0], [785.0, 1189.0]], [[751.0, 1079.0], [778.0, 1079.0], [778.0, 1212.0], [751.0, 1212.0]], [[712.0, 1078.0], [745.0, 1078.0], [745.0, 1162.0], [712.0, 1162.0]]], "lines": ["早く、店", "再開させな", "よ．．．．．"]}], "img_path": "195.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [468, 203, 554, 318], "vertical": false, "font_size": 32.5, "lines_coords": [[[489.0, 203.0], [554.0, 256.0], [534.0, 281.0], [468.0, 228.0]], [[492.0, 239.0], [548.0, 295.0], [525.0, 318.0], [468.0, 262.0]]], "lines": ["うんっ", "くどく"]}, {"box": [298, 81, 325, 235], "vertical": true, "font_size": 25, "lines_coords": [[[298.0, 81.0], [325.0, 81.0], [325.0, 235.0], [298.0, 235.0]]], "lines": ["コーちゃん！！"]}, {"box": [171, 150, 201, 284], "vertical": true, "font_size": 25, "lines_coords": [[[171.0, 150.0], [198.0, 150.0], [201.0, 284.0], [175.0, 284.0]]], "lines": ["コーちゃー"]}, {"box": [140, 206, 162, 279], "vertical": true, "font_size": 25, "lines_coords": [[[140.0, 206.0], [162.0, 206.0], [162.0, 279.0], [140.0, 279.0]]], "lines": ["ん！！"]}, {"box": [529, 867, 669, 1104], "vertical": true, "font_size": 29, "lines_coords": [[[640.0, 868.0], [667.0, 868.0], [667.0, 1051.0], [640.0, 1051.0]], [[601.0, 868.0], [632.0, 868.0], [632.0, 1054.0], [601.0, 1054.0]], [[565.0, 868.0], [596.0, 868.0], [596.0, 1104.0], [565.0, 1104.0]], [[532.0, 867.0], [559.0, 867.0], [556.0, 1078.0], [529.0, 1078.0]]], "lines": ["そんなお下劣な", "絵描いてないで", "おつかい行ってきて", "ちょうだーい！！"]}, {"box": [347, 1261, 397, 1446], "vertical": true, "font_size": 44, "lines_coords": [[[348.0, 1300.0], [392.0, 1300.0], [392.0, 1446.0], [348.0, 1446.0]]], "lines": ["さやはは"]}, {"box": [214, 1251, 314, 1409], "vertical": true, "font_size": 28, "lines_coords": [[[287.0, 1253.0], [314.0, 1253.0], [314.0, 1357.0], [287.0, 1357.0]], [[250.0, 1253.0], [276.0, 1253.0], [276.0, 1409.0], [250.0, 1409.0]], [[214.0, 1251.0], [240.0, 1251.0], [240.0, 1384.0], [214.0, 1384.0]]], "lines": ["キャッ！！", "なぜか笑われ", "ちゃった！！"]}, {"box": [