sion": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [796, 1018, 977, 1259], "vertical": true, "font_size": 30, "lines_coords": [[[948.0, 1023.0], [976.0, 1023.0], [976.0, 1139.0], [948.0, 1139.0]], [[910.0, 1023.0], [937.0, 1023.0], [937.0, 1259.0], [910.0, 1259.0]], [[871.0, 1021.0], [898.0, 1021.0], [898.0, 1232.0], [871.0, 1232.0]], [[832.0, 1018.0], [864.0, 1018.0], [868.0, 1235.0], [837.0, 1235.0]], [[796.0, 1018.0], [832.0, 1018.0], [832.0, 1093.0], [796.0, 1093.0]]], "lines": ["なぜなら、", "クラスのアイドルの", "ミヨちゃんが転校", "してしまったから", "です。"]}, {"box": [462, 735, 601, 959], "vertical": true, "font_size": 28, "lines_coords": [[[573.0, 737.0], [600.0, 737.0], [600.0, 950.0], [573.0, 950.0]], [[534.0, 735.0], [567.0, 735.0], [562.0, 925.0], [529.0, 925.0]], [[496.0, 739.0], [525.0, 739.0], [525.0, 873.0], [496.0, 873.0]], [[464.0, 740.0], [485.0, 740.0], [485.0, 959.0], [464.0, 959.0]]], "lines": ["プンプンはその日", "学校に行くのが", "憂鬱で仕方", "ありませんでした。"]}, {"box": [148, 1282, 250, 1495], "vertical": true, "font_size": 25, "lines_coords": [[[225.0, 1284.0], [246.0, 1284.0], [246.0, 1493.0], [225.0, 1493.0]], [[185.0, 1282.0], [212.0, 1282.0], [212.0, 1417.0], [185.0, 1417.0]], [[148.0, 1282.0], [175.0, 1282.0], [175.0, 1431.0], [148.0, 1431.0]]], "lines": ["みんなと過ごした", "時間は一生", "忘れません。"]}], "img_path": "007.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [232, 0, 374, 82], "vertical": true, "font_size": 34, "lines_coords": [[[342.0, 4.0], [373.0, 4.0], [373.0, 62.0], [342.0, 62.0]], [[304.0, 0.0], [339.0, 0.0], [339.0, 82.0], [304.0, 82.0]], [[262.0, 0.0], [301.0, 0.0], [301.0, 53.0], [262.0, 53.0]], [[232.0, 17.0], [264.0, 17.0], [264.0, 71.0], [232.0, 71.0]]], "lines": ["んな", "なかよく", "気", "よく"]}, {"box": [866, 673, 967, 866], "vertical": true, "font_size": 27, "lines_coords": [[[940.0, 673.0], [967.0, 673.0], [967.0, 856.0], [940.0, 856.0]], [[903.0, 673.0], [931.0, 673.0], [931.0, 779.0], [903.0, 779.0]], [[867.0, 