], [3835.0, 314.0], [3261.0, 314.0]], [[3277.0, 304.0], [3547.0, 304.0], [3547.0, 337.0], [3277.0, 337.0]], [[3687.0, 312.0], [3816.0, 312.0], [3816.0, 333.0], [3687.0, 333.0]], [[3611.0, 327.0], [3820.0, 331.0], [3820.0, 375.0], [3611.0, 371.0]], [[3277.0, 339.0], [3509.0, 339.0], [3509.0, 371.0], [3277.0, 371.0]], [[3277.0, 373.0], [3482.0, 373.0], [3482.0, 405.0], [3277.0, 405.0]], [[3661.0, 373.0], [3820.0, 373.0], [3820.0, 405.0], [3661.0, 405.0]], [[3273.0, 399.0], [3828.0, 399.0], [3828.0, 443.0], [3273.0, 443.0]], [[3277.0, 441.0], [3585.0, 441.0], [3585.0, 474.0], [3277.0, 474.0]], [[3695.0, 441.0], [3824.0, 441.0], [3824.0, 474.0], [3695.0, 474.0]], [[3265.0, 460.0], [3828.0, 460.0], [3828.0, 516.0], [3265.0, 516.0]], [[3277.0, 510.0], [3554.0, 510.0], [3554.0, 542.0], [3277.0, 542.0]], [[3756.0, 510.0], [3824.0, 510.0], [3824.0, 542.0], [3756.0, 542.0]], [[3269.0, 532.0], [3824.0, 529.0], [3824.0, 576.0], [3269.0, 580.0]], [[3277.0, 578.0], [3820.0, 578.0], [3820.0, 611.0], [3277.0, 611.0]], [[3280.0, 612.0], [3820.0, 612.0], [3820.0, 645.0], [3280.0, 645.0]], [[3277.0, 643.0], [3463.0, 643.0], [3463.0, 675.0], [3277.0, 675.0]], [[3740.0, 650.0], [3816.0, 650.0], [3816.0, 671.0], [3740.0, 671.0]], [[3265.0, 669.0], [3824.0, 665.0], [3824.0, 709.0], [3265.0, 713.0]], [[3273.0, 707.0], [3828.0, 707.0], [3828.0, 751.0], [3273.0, 751.0]], [[3280.0, 745.0], [3478.0, 745.0], [3478.0, 778.0], [3280.0, 778.0]], [[3737.0, 745.0], [3824.0, 745.0], [3824.0, 778.0], [3737.0, 778.0]], [[3269.0, 768.0], [3687.0, 753.0], [3687.0, 808.0], [3269.0, 823.0]], [[3710.0, 776.0], [3820.0, 776.0], [3820.0, 808.0], [3710.0, 808.0]], [[3269.0, 802.0], [3824.0, 806.0], [3824.0, 854.0], [3269.0, 850.0]], [[3737.0, 852.0], [3816.0, 852.0], [3816.0, 873.0], [3737.0, 873.0]], [[3277.0, 848.0], [3497.0, 848.0], [3497.0, 880.0], [3277.0, 880.0]], [[3273.0, 871.0], [3824.0, 867.0], [3824.0, 915.0], [3273.0, 918.0]], [[3277.0, 912.0], [3505.0, 912.0], [3505.0, 945.0], [3277.0, 945.0]], [[3277.0, 947.0], [3490.0, 943.0], [3490.0, 979.0], [3277.0, 983.0]], [[3737.0, 947.0], [3809.0, 947.0], [3809.0, 979.0], [3737.0, 979.0]], [[3383.0, 977.0], [3714.0, 977.0], [3714.0, 1010.0], [3383.0, 1010.0]], [[3280.0, 1004.0], [3816.0, 1004.0], [3816.0, 1048.0], [3280.0, 1048.0]], [[3311.0, 1057.0], [3782.0, 1061.0], [3782.0, 1105.0], [3311.0, 1101.0]]], "lines": ["おやすみプンプン「〜日巻", "浅野いにお洋服いにも", "浅野いにの浅野においても、", "ソラニン・全日巻", "ソフーノ、主です。ロバコトー診療所、１〜２０１７年１月", "浅野いにお山田貴敏は", "レコード・診断所・「ご注文・中国に当初はまだいますが、１０億５万円」の", "「Ａｎｄｕｒｉ」の鉄腕バーティー「〜旧巻", "ゆうきまさみ", "【】ゆつきまさみ室積光ノ猪熊しのぶ", "数多く、都立水商」「〜１９巻", "前立小河、クロサギ・１〜１９巻", "黒丸ノ夏原武", "シロウキ．．ーーは色イギガミーＴｉＰｌｌｉｎｄｅＬｉｎｔ－ｌｉｍｌ－１１．１１／１４／１・黒丸ノ星尿・武・日巻一間瀬元朗．．．高城のバス", "キャッシュバッションの上で、土竜（モグラ）の唄・１〜１８巻", "高橋のぼる先生", "土竜代クラブの風、１１時間、一週間の時間を超無す加減シャパフィート７巻上程度までのサービスをご", "２０１８／１４／０１１Ｇ－オッズ・１〜日巻", "石渡治", "ＯＪＥＧオッス・１〜日巻さらんぼントロームグドの規模になってきた１〜日替ー北崎拓", "ご、ごめんなさい。タナトスむしけの声。「〜日巻ー」竹原慎二ノ落合裕介『【光", "とめはねっ十一鈴里原校電道部－わかったー。ねー。１〜３巻－河合克敏", "このは１８ノール車ビーチスターズ", "森尾正博", "ビーナスターノ光亡弁護士成田成たらさーーー、森尾上博１〜４巻一、高田優ノ剛英城", "逆に、九條。一人の田みまつうはなもの。鬼の涙る吉道。「一年でも一回中国展」開発の一日巻、木根ヲサムノ国川光太郎", "原口ケン・１〜２巻", "喜国雅彦", "周口ケントーヨ治美雨♥ライジング、１〜５巻間のイーメット", "「普画仲彦大谷じろう", "美雨『フイン』「こうお暁のイージス・１－３巻「ナイナルナ・七月鏡一ノ藤原芳秀", "島本和彦", "アオイホノオ「巻", "リオイホノオ。「春あんころ。お城君が丁目は馬鹿先１〜３０１１年１１日巻一万乗大智", "あれこう。ｍａｚｏｎは、ＧＯ－ＯＮ－１－２巻", "ビジしているドライブ・ア・ライフ", "中井邦彦", "・フ・フィノ・イロヤングサンデーコミックススペシャル", "絶望に効くクリサンデ絶望は効く、クスリーＯＮＥ一コミックスペシャルＯＮＩＯＮＥ－１〜１０巻１山田玲司", "ｈｔｔｐ：／／ｗｗｗ．ｃｏｕｍｉｓｕｒｋａｙｏｎ．"]}, {"box": [3334, 1280, 3776, 1496], "vertical": false, "font_size": 38, "lines_coords": [[[3459.0, 1281.0], [3634.0, 1281.0], [3634.0, 1325.0], [3459.0, 1325.0]], [[3402.0, 1319.0], [3695.0, 1323.0], [3695.0, 1367.0], [3402.0, 1363.0]], [[3341.0, 1349.0], [3763.0, 1349.0], [3763.0, 1393.0], [3341.0, 1393.0]], [[3398.0, 1380.0], [3706.0, 1380.0], [3706.0, 1412.0], [3398.0, 1412.0]], [[3353.0, 1391.0], [3752.0, 1395.0], [3752.0, 1450.0], [3353.0, 1447.0]], [[3383.0, 1433.0], [3725.0, 1433.0], [3725.0, 1466.0], [3383.0, 1466.0]], [[3353.0, 1463.0], [3752.0, 1463.0], [3752.0, 1496.0], [3353.0, 1496.0]]], "lines": ["浅野いにお", "１９８０年生まれ。茨城県出身。１年１回サンデーの大新人", "２０１８年生まれ。茨城県出身。２００１年、第１回サンデーなど新人賞入賞。主な業者には、素晴らしい世界", "１１年、第１回サンデーＧＸ新入賞主な著作に「素晴らしい世界」がありますが、", "ここで、主な著作に「素晴らしい世界」「ひかりのまちいともに小社刊がある。「ヤツラーシー」（全巻参考）社刊）が、", "かかりのまちいともに小社刊がある『ソラニン【（全２巻＂小社刑）が、同じＷｅｗｗｗｅｗｓ＿＊＊＿", "全国より一つ一生で巻き少ながら、全国なり世代・性別を超えた大阪圏やに。"]}], "img_path": "001.png"}, {"version": "0.2.0-beta.6", "img_width": 2380, "img_height": 1600, "blocks": [{"box": [836, 165, 876, 441], "vertical": true, "font_size": 33, "lines_coords": [[[843.0, 165.0], [876.0, 165.0], [869.0, 441.0], [836.0, 441.0]]], "lines": ["おやすみフ、"]}, {"box": [1159, 83, 1215, 509], "vertical": true, "font_size": 46, "lines_coords": [[[1169.0, 83.0], [1215.0, 83.0], [1206.0, 509.0], [1159.0, 509.0]]], "lines": ["おやすみプソフ"]}, {"box": [841, 658, 873, 869], "vertical": true, "font_size": 32, "lines_coords": [[[841.0, 658.0], [873.0, 658.0], [873.0, 869.0], [841.0, 869.0]]], "lines": ["浅野いにお"]}, {"box": [1173, 655, 1206, 867], "vertical": true, "font_size": 33, "lines_coords": [[[1173.0, 655.0], [1206.0, 655.0], [1206.0, 867.0], [1173.0, 867.0]]], "lines": ["浅野のにお"]}, {"box": [1155, 76, 1234, 131], "vertical": false, "font_size": 60, "lines_coords": [[[1155.0, 71.0], [1234.0, 71.0], [1234.0, 136.0], [1155.0, 136.0]]], "lines": ["ＹｏｕＴｕｅｓｕｎｂＡＹｏＯＭＴＯＳ"]}], "img_path": "002.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "003.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [837, 157, 887, 876], "vertical": true, "font_size": 48, "lines_coords": [[[839.0, 157.0], [887.0, 157.0], [885.0, 876.0], [837.0, 876.0]]], "lines": ["おやすみプンプンの「浅野にお"]}, {"box": [65, 1498, 271, 1522], "vertical": false, "font_size": 18, "lines_coords": [[[70.0, 1502.0], [265.0, 1502.0], [265.0, 1522.0], [70.0, 1522.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＸＹＣＯＭＣＳ"]}], "img_path": "004.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [782, 317, 867, 371], "ver