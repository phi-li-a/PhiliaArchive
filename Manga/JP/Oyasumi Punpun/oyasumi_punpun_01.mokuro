"入院が必要", "かな。"]}, {"box": [100, 1135, 237, 1335], "vertical": true, "font_size": 28, "lines_coords": [[[206.0, 1137.0], [237.0, 1137.0], [237.0, 1298.0], [206.0, 1298.0]], [[170.0, 1137.0], [201.0, 1137.0], [201.0, 1335.0], [170.0, 1335.0]], [[134.0, 1137.0], [162.0, 1137.0], [159.0, 1323.0], [131.0, 1323.0]], [[100.0, 1135.0], [126.0, 1135.0], [126.0, 1309.0], [100.0, 1309.0]]], "lines": ["これで無職の", "俺も、多少大きい", "顔ができるって", "もんだ、はは。"]}, {"box": [121, 1381, 184, 1553], "vertical": true, "font_size": 28, "lines_coords": [[[157.0, 1382.0], [184.0, 1382.0], [184.0, 1553.0], [157.0, 1553.0]], [[121.0, 1381.0], [148.0, 1381.0], [148.0, 1521.0], [121.0, 1521.0]]], "lines": ["って笑い事じゃ", "ないけどね。"]}], "img_path": "033.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [579, 137, 678, 320], "vertical": true, "font_size": 22, "lines_coords": [[[653.0, 139.0], [675.0, 139.0], [675.0, 300.0], [653.0, 300.0]], [[617.0, 137.0], [639.0, 137.0], [639.0, 318.0], [617.0, 318.0]], [[581.0, 139.0], [603.0, 139.0], [603.0, 320.0], [581.0, 320.0]]], "lines": ["あらあらめら、", "また随分派手に", "やったねー．．．"]}, {"box": [93, 60, 378, 82], "vertical": false, "font_size": 22, "lines_coords": [[[93.0, 60.0], [378.0, 60.0], [378.0, 82.0], [93.0, 82.0]]], "lines": ["おやすみプンプンＩ"]}, {"box": [89, 500, 226, 659], "vertical": true, "font_size": 25, "lines_coords": [[[200.0, 500.0], [226.0, 500.0], [226.0, 634.0], [200.0, 634.0]], [[162.0, 500.0], [189.0, 500.0], [189.0, 659.0], [162.0, 659.0]], [[126.0, 501.0], [153.0, 501.0], [153.0, 657.0], [126.0, 657.0]], [[89.0, 500.0], [118.0, 500.0], [118.0, 550.0], [89.0, 550.0]]], "lines": ["義兄さんも", "根は真面目な", "人なんだけど", "ねー"]}, {"box": [95, 559, 112, 604], "vertical": true, "font_size": 25, "lines_coords": [[[95.0, 559.0], [112.0, 559.0], [112.0, 604.0], [95.0, 604.0]]], "lines": ["．．．"]}, {"box": [775, 1047, 803, 1154], "vertical": true, "font_size": 28, "lines_coords": [[[775.0, 1073.0], [803.0, 1073.0], [803.0, 1154.0], [775.0, 1154.0]]], "lines": ["．．．ん？"]}, {"box": [381, 1143, 482, 1304], "vertical": true, "font_size": 28, "lines_coords": [[[454.0, 1143.0], [482.0, 1143.0], [479.0, 1278.0], [451.0, 1278.0]], [[415.0, 1143.0], [446.0, 1143.0], [446.0, 1304.0], [415.0, 1304.0]], [[381.0, 1143.0], [407.0, 1143.0], [407.0, 1276.0], [381.0, 1276.0]]], "lines": ["．．．片付ける", "前にちょっと", "遊ぼうか！！"]}, {"box": [487, 1350, 590, 1462], "vertical": false, "font_size": 53, "lines_coords": [[[487.0, 1429.0], [548.0, 1350.0], [590.0, 1381.0], [529.0, 1462.0]]], "lines": ["やめて"]}], "img_path": "034.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [854, 109, 958, 333], "vertical": true, "font_size": 28, "lines_coords": [[[925.0, 110.0], [956.0, 110.0], [956.0, 323.0], [925.0, 323.0]], [[892.0, 114.0], [918.0, 114.0], [918.0, 296.0], [892.0, 296.0]], [[854.0, 109.0], [881.0, 109.0], [882.0, 332.0], [856.0, 332.0]]], "lines": ["翌日、プンプンは", "いつものように", "学校に行きました。"]}, {"box": [203, 732, 246, 792], "vertical": true, "font_size": 43, "lines_coords": [[[203.0, 732.0], [246.0, 732.0], [246.0, 792.0], [203.0, 792.0]]], "lines": ["あ。"]}, {"box": [948, 1231, 1011, 1417], "vertical": true, "font_size": 28, "lines_coords": [[[982.0, 1231.0], [1010.0, 1231.0], [1007.0, 1375.0], [979.0, 1375.0]], [[948.0, 1232.0], [975.0, 1232.0], [975.0, 1364.0], [948.0, 1364.0]]], "lines": ["お、おはよー", "プンプン！！"]}, {"box": [496, 1399, 523, 1530], "vertical": true, "font_size": 22, "lines_coords": [[[496.0, 1400.0], [518.0, 1400.0], [518.0, 1493.0], [496.0, 1493.0]]], "lines": ["おはよー"]}, {"box": [117, 1339, 257, 1546], "vertical": true, "font_size": 26, "lines_coords": [[[228.0, 1339.0], [254.0, 1339.0], [254.0, 1501.0], [228.0, 1501.0]], [[192.0, 1339.0], [218.0, 1339.0], [218.0, 1546.0], [192.0, 1546.0]], [[153.0, 1339.0], [179.0, 1339.0], [179.0, 1495.0], [153.0, 1495.0]], [[117.0, 1340.0], [143.0, 1340.0], [143.0, 1506.0], [117.0, 1506.0]]], "lines": ["愛子ちゃんは、", "やっぱりというか", "もうクラスの", "人気者でした。"]}], "img_p