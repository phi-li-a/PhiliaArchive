ue, "font_size": 27, "lines_coords": [[[918.0, 846.0], [945.0, 846.0], [948.0, 967.0], [921.0, 967.0]], [[882.0, 848.0], [909.0, 848.0], [910.0, 1043.0], [884.0, 1043.0]], [[848.0, 851.0], [875.0, 851.0], [875.0, 970.0], [848.0, 970.0]]], "lines": ["なるほど、", "そういうことね、", "はっはっ。"]}, {"box": [176, 871, 282, 1042], "vertical": true, "font_size": 27, "lines_coords": [[[251.0, 871.0], [278.0, 871.0], [281.0, 1042.0], [254.0, 1042.0]], [[217.0, 873.0], [243.0, 873.0], [243.0, 1006.0], [217.0, 1006.0]], [[176.0, 873.0], [203.0, 873.0], [206.0, 1040.0], [179.0, 1040.0]]], "lines": ["だいじょーぶ、", "プンプンは", "死なないから。"]}, {"box": [978, 1146, 1042, 1284], "vertical": true, "font_size": 26, "lines_coords": [[[1015.0, 1148.0], [1042.0, 1148.0], [1042.0, 1284.0], [1015.0, 1284.0]], [[978.0, 1146.0], [1006.0, 1146.0], [1006.0, 1265.0], [978.0, 1265.0]]], "lines": ["しかしだね、", "プンプン。"]}, {"box": [821, 1229, 945, 1464], "vertical": true, "font_size": 26, "lines_coords": [[[918.0, 1229.0], [945.0, 1229.0], [945.0, 1429.0], [918.0, 1429.0]], [[884.0, 1229.0], [910.0, 1229.0], [910.0, 1464.0], [884.0, 1464.0]], [[850.0, 1231.0], [876.0, 1231.0], [876.0, 1454.0], [850.0, 1454.0]], [[821.0, 1232.0], [843.0, 1232.0], [843.0, 1371.0], [821.0, 1371.0]]], "lines": ["世の中にはまだ", "プンプンの知らない", "ことが、たーくさん", "あるのだよ。"]}, {"box": [140, 1300, 279, 1535], "vertical": true, "font_size": 28, "lines_coords": [[[250.0, 1301.0], [276.0, 1301.0], [278.0, 1535.0], [251.0, 1535.0]], [[215.0, 1303.0], [242.0, 1303.0], [242.0, 1460.0], [215.0, 1460.0]], [[178.0, 1303.0], [204.0, 1303.0], [204.0, 1518.0], [178.0, 1518.0]], [[140.0, 1300.0], [173.0, 1300.0], [173.0, 1393.0], [140.0, 1393.0]]], "lines": ["おじさんチョイスで", "本を貸すから", "少し勉強したまえ。", "はっは。"]}], "img_path": "109.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [657, 118, 914, 328], "vertical": false, "font_size": 174, "lines_coords": [[[657.0, 157.0], [884.0, 118.0], [914.0, 289.0], [687.0, 328.0]]], "lines": ["だが、"]}, {"box": [140, 487, 295, 525], "vertical": false, "font_size": 38, "lines_coords": [[[140.0, 487.0], [295.0, 487.0], [295.0, 525.0], [140.0, 525.0]]], "lines": ["アレットの"]}, {"box": [118, 587, 294, 800], "vertical": true, "font_size": 28, "lines_coords": [[[265.0, 589.0], [292.0, 589.0], [292.0, 723.0], [265.0, 723.0]], [[226.0, 590.0], [254.0, 590.0], [256.0, 775.0], [228.0, 775.0]], [[190.0, 587.0], [221.0, 587.0], [221.0, 800.0], [190.0, 800.0]], [[156.0, 589.0], [184.0, 589.0], [181.0, 748.0], [153.0, 748.0]], [[118.0, 589.0], [145.0, 589.0], [146.0, 759.0], [120.0, 759.0]]], "lines": ["プンプンは", "難しい字は苦手", "なので、図版だけ", "見てガンガン", "流し読みです。"]}], "img_path": "110.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [843, 46, 1009, 464], "vertical": true, "font_size": 86, "lines_coords": [[[926.0, 51.0], [1007.0, 51.0], [1007.0, 245.0], [926.0, 245.0]], [[843.0, 46.0], [935.0, 46.0], [935.0, 464.0], [843.0, 464.0]]], "lines": ["愚かな", "地球人どもを"]}, {"box": [135, 42, 300, 465], "vertical": true, "font_size": 89, "lines_coords": [[[204.0, 98.0], [300.0, 98.0], [300.0, 373.0], [204.0, 373.0]], [[135.0, 45.0], [217.0, 45.0], [217.0, 428.0], [135.0, 428.0]]], "lines": ["一人残念です", "抹殺するギリ"]}, {"box": [840, 692, 898, 785], "vertical": false, "font_size": 30, "lines_coords": [[[840.0, 775.0], [870.0, 692.0], [898.0, 703.0], [868.0, 785.0]]], "lines": ["オオラ"]}, {"box": [693, 687, 737, 784], "vertical": true, "font_size": 39, "lines_coords": [[[698.0, 687.0], [737.0, 690.0], [731.0, 784.0], [693.0, 781.0]]], "lines": ["オホホ"]}, {"box": [554, 745, 607, 842], "vertical": true, "font_size": 32, "lines_coords": [[[554.0, 753.0], [585.0, 745.0], [607.0, 834.0], [576.0, 842.0]]], "lines": ["オホホ"]}, {"box": [439, 696, 471, 783], "vertical": true, "font_size": 29, "lines_coords": [[[439.0, 698.0], [468.0, 696.0], [471.0, 779.0], [442.0, 781.0]]], "lines": ["オホホ"]}, {"box": [276, 696, 335, 796], "vertical": true, "font_size": 41, "lines_coords": [[[276.0, 706.0], [315.0, 696.0], [335.0, 787.0], [295.0, 796.0]]], "lines": ["オホホ"]}, {"box": [978, 764, 1021, 845], "vertical": true, "font_size": 29, "lines_coords": [[[978.0, 770.0], [1006.0, 764.0], [1021.0, 839.0], [993.0, 845.0]]], "lines": ["オホホ"]}, {"box": [895, 992, 1035, 1179], "vertical": true, "font_size": 28, "lines_coords": [[[1003.0, 993.0], [1035.0, 993.0], [1035.0, 1076.0], [1003.0, 1076.0]], [[968.0, 995.0], [995.0, 995.0], [995.0, 1126.0], [968.0, 1126.0]], [[929.0, 992.0], [960.0, 992.0], [960.0, 1179.0], [929.0, 1179.0]], [[896.0, 996.0], [920.0, 996.0], [918.0, 1159.0], [895.0, 1159.0]]], "lines": ["なぜか", "急に不安な", "気持ちになって", "しまいました。"]}, {"box": [406, 1023, 437, 1225], "vertical": true, "font_size": 30, "lines_coords": [[[409.0, 1023.0], [437.0, 1023.0], [434.0, 1225.0], [406.0, 1225.0]]], "lines": ["「やっぱり男なら"]}, {"box": [329, 1020, 367, 1226], "vertical": true, "font_size": 30, "lines_coords": [[[334.0, 1020.0], [367.0, 1020.0], [362.0, 1226.0], [329.0, 1226.0]]], "lines": ["見据えなきゃ！！」"]}, {"box": [946, 1292, 1014, 1426], "vertical": true, "font_size": 32, "lines_coords": [[[978.0, 1293.0], [1014.0, 1293.0], [1014.0, 1370.0], [978.0, 1370.0]], [[946.0, 1293.0], [975.0, 1293.0], [975.0, 1426.0], [946.0, 1426.0]]], "lines": ["「ねえ、", "知ってる？"]}, {"box": [368, 1078, 398, 1342], "vertical": true, "font_size": 30, "lines_coords": [[[370.0, 1078.0], [398.0, 1078.0], [396.0, 1342.0], [368.0, 1342.0]]], "lines": ["コーンとでかいもんを"]}, {"box": [473, 1292, 605, 1515], "vertical": true, "font_size": 30, "lines_coords": [[[575.0, 1296.0], [603.0, 1296.0], [604.0, 1515.0], [576.0, 1515.0]], [[540.0, 1292.0], [571.0, 1292.0], [571.0, 1456.0], [540.0, 1456.0]], [[507.0, 1292.0], [539.0, 1292.0], [539.0, 1484.0], [507.0, 1484.0]], [[475.0, 1293.0], [503.0, 1293.0], [501.0, 1503.0], [473.0, 1503.0]]], "lines": ["「別の星にイジュト", "でもしないと", "人類はメツボー", "しちゃうんだよ。」"]}, {"box": [139, 1170, 267, 1401], "vertical": true, "font_size": 38, "lines_coords": [[[226.0, 1181.0], [265.0, 1181.0], [265.0, 1359.0], [226.0, 1359.0]], [[181.0, 1175.0], [223.0, 1175.0], [223.0, 1401.0], [181.0, 1401.0]], [[139.0, 1170.0], [171.0, 1170.0], [171.0, 1348.0], [139.0, 1348.0]]], "lines": ["「夢っつーか、", "ロマンってのが", "あるよね！！！"]}], "img_path": "111.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [116, 246, 291, 434], "vertical": true, "font_size": 27, "lines_coords": [[[262.0, 246.0], [289.0, 246.0], [289.0, 381.0], [262.0, 381.0]], [[225.0, 250.0], [251.0, 250.0], [251.0, 385.0], [225.0, 385.0]], [[190.0, 246.0], [217.0, 246.0], [217.0, 432.0], [190.0, 432.0]], [[150.0, 246.0], [181.0, 246.0], [181.0, 434.0], [150.0, 434.0]], [[117.0, 251.0], [139.0, 251.0], [139.0, 360.0], [117.0, 360.0]]], "lines": ["プンプンは", "あの日以来、", "望遠鏡の存在を", "すっかり忘れて", "いました"]}, {"box": [824, 1145, 915, 1352], "vertical": true, "font_size": 36, "lines_coords": [[[875.0, 1148.0], [915.0, 1148.0], [915.0, 1242.0], [875.0, 1242.0]], [[826.0, 1146.0], [857.0, 1146.0], [857.0, 1345.0], [826.0, 1345.0]]], "lines": ["「星が", "動いたギ！！"]}], "img_path": "112.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [942, 65, 1031, 308], "vertical": true, "font_size": 25, "lines_coords": [[[1004.0, 68.0], [1031.0, 68.0], [1031.0, 284.0], [1004.0, 284.0]], [[970.0, 65.0], [996.0, 65.0], [996.0, 239.0], [970.0, 239.0]], [[942.0, 68.0], [964.0, 68.0], [967.0, 307.0], [945.0, 307.0]]], "lines": ["なんだいプンプン、", "そんなよだれ", "垂らすほど興奮して。"]}, {"box": [587, 118, 650, 303], "vertical": true, "font_size": 24, "lines_coords": [[[623.0, 118.0], [650.0, 118.0], [650.0, 303.0], [623.0, 303.0]], [[589.0, 120.0], [610.0, 120.0], [610.0, 250.0], [589.0, 250.0]]], "lines": ["．．．動いてる星を", "見つけた？"]}, {"box": [150, 120, 253, 279], "vertical": true, "font_size": 26, "lines_coords": [[[221.0, 120.0], [250.0, 120.0], [251.0, 259.0], [223.0, 259.0]], [[190.0, 123.0], [212.0, 123.0], [212.0, 254.0], [190.0, 254.0]], [[150.0, 120.0], [176.0, 120.0], [179.0, 279.0], [153.0, 279.0]]], "lines": ["．．．うーん、", "僕には見え", "ないけど．．．"]}, {"box": [667, 453, 767, 637], "vertical": true, "font_size": 24, "lines_coords": [[[740.0, 453.0], [762.0, 453.0], [762.0, 615.0], [740.0, 615.0]], [[701.0, 453.0], [728.0, 453.0], [728.0, 637.0], [701.0, 637.0]], [[668.0, 454.0], [690.0, 454.0], [690.0, 609.0], [668.0, 609.0]]], "lines": ["子供とはいえ", "その乱れぶりは", "目に余るな！！"]}, {"box": [170, 473, 239, 609], "vertical": true, "font_size": 28, "lines_coords": [[[209.0, 473.0], [237.0, 473.0], [237.0, 584.0], [209.0, 584.0]], [[173.0, 475.0], [201.0, 475.0], [198.0, 609.0], [170.0, 609.0]]], "lines": ["それ多分", "人工衛星．．．"]}, {"box": [892, 725, 985, 968], "vertical": true, "font_size": 40, "lines_coords": [[[943.0, 726.0], [985.0, 726.0], [985.0, 935.0], [943.0, 935.0]], [[892.0, 725.0], [929.0, 725.0], [934.0, 968.0], [896.0, 968.0]]], "lines": ["「新発見の星", "だろうかっ！？」"]}], "img_path": "113.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [973, 115, 1000, 218], "vertical": true, "font_size": 25, "lines_coords": [[[973.0, 115.0], [1000.0, 115.0], [1000.0, 218.0], [973.0, 218.0]]], "lines": ["．．．うん！！"]}, {"box": [875, 231, 971, 393], "vertical": true, "font_size": 25, "lines_coords": [[[945.0, 231.0], [971.0, 231.0], [971.0, 393.0], [945.0, 393.0]], [[907.0, 232.0], [934.0, 232.0], [934.0, 368.0], [907.0, 368.0]], [[875.0, 235.0], [896.0, 235.0], [896.0, 390.0], [875.0, 390.0]]], "lines": ["もしかしたら", "大発見かも", "しれないぞ！！"]}, {"box": [475, 101, 571, 231], "vertical": true, "font_size": 27, "lines_coords": [[[550.0, 103.0], [571.0, 103.0], [571.0, 231.0], [550.0, 231.0]], [[510.0, 101.0], [539.0, 101.0], [539.0, 209.0], [510.0, 209.0]], [[475.0, 101.0], [501.0, 101.0], [501.0, 217.0], [475.0, 217.0]]], "lines": ["もし本当に", "新しい星", "だったら、"]}, {"box": [407, 303, 509, 439], "vertical": true, "font_size": 27, "lines_coords": [[[482.0, 307.0], [509.0, 307.0], [509.0, 439.0], [482.0, 439.0]], [[446.0, 306.0], [473.0, 306.0], [473.0, 439.0], [446.0, 439.0]], [[407.0, 303.0], [440.0, 303.0], [440.0, 389.0], [407.0, 389.0]]], "lines": ["星の名前は", "プンプン星", "だな！！"]}, {"box": [96, 168, 164, 278], "vertical": true, "font_size": 30, "lines_coords": [[[134.0, 170.0], [162.0, 170.0], [162.0, 278.0], [134.0, 278.0]], [[96.0, 168.0], [129.0, 168.0], [129.0, 264.0], [96.0, 264.0]]], "lines": ["欲張りな", "やつめ。"]}, {"box": [462, 559, 564, 718], "vertical": true, "font_size": 25, "lines_coords": [[[534.0, 559.0], [562.0, 559.0], [559.0, 707.0], [531.0, 707.0]], [[498.0, 560.0], [525.0, 560.0], [525.0, 718.0], [498.0, 718.0]], [[464.0, 560.0], [485.0, 560.0], [485.0, 706.0], [464.0, 706.0]]], "lines": ["「ノーベル賞", "とかもらえる", "だろうか！？"]}, {"box": [453, 828, 596, 961], "vertical": true, "font_size": 29, "lines_coords": [[[568.0, 831.0], [595.0, 831.0], [595.0, 959.0], [568.0, 959.0]], [[531.0, 831.0], [559.0, 831.0], [559.0, 937.0], [531.0, 937.0]], [[496.0, 831.0], [523.0, 831.0], [523.0, 959.0], [496.0, 959.0]], [[453.0, 829.0], [485.0, 828.0], [490.0, 918.0], [457.0, 920.0]]], "lines": ["ブンブンは", "もう俄然", "ウッキウキ", "でした。"]}, {"box": [112, 1330, 176, 1515], "vertical": true, "font_size": 28, "lines_coords": [[[143.0, 1331.0], [176.0, 1331.0], [176.0, 1465.0], [143.0, 1465.0]], [[112.0, 1331.0], [134.0, 1331.0], [134.0, 1475.0], [112.0, 1475.0]]], "lines": ["ノーベル賞", "もらったらー"]}], "img_path": "114.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [908, 137, 1012, 298], "vertical": true, "font_size": 29, "lines_coords": [[[978.0, 137.0], [1012.0, 137.0], [1012.0, 234.0], [978.0, 234.0]], [[945.0, 139.0], [971.0, 139.0], [971.0, 296.0], [945.0, 296.0]], [[909.0, 140.0], [935.0, 140.0], [935.0, 298.0], [909.0, 298.0]]], "lines": ["「賞金で", "ブンブン星に", "家を建てて、」"]}, {"box": [157, 448, 260, 621], "vertical": true, "font_size": 29, "lines_coords": [[[231.0, 448.0], [257.0, 448.0], [257.0, 621.0], [231.0, 621.0]], [[192.0, 451.0], [226.0, 451.0], [226.0, 559.0], [192.0, 559.0]], [[157.0, 450.0], [185.0, 450.0], [185.0, 568.0], [157.0, 568.0]]], "lines": ["「愛子ちゃんと", "イジュー", "しよう！！」"]}, {"box": [891, 740, 994, 910], "vertical": true, "font_size": 29, "lines_coords": [[[965.0, 742.0], [992.0, 742.0], [992.0, 885.0], [965.0, 885.0]], [[925.0, 740.0], [959.0, 740.0], [959.0, 826.0], [925.0, 826.0]], [[892.0, 742.0], [918.0, 742.0], [918.0, 910.0], [892.0, 910.0]]], "lines": ["「ゲーム機も", "全機種", "そろえよう！！」"]}, {"box": [151, 768, 254, 964], "vertical": true, "font_size": 27, "lines_coords": [[[225.0, 768.0], [253.0, 768.0], [250.0, 915.0], [221.0, 915.0]], [[189.0, 770.0], [215.0, 770.0], [215.0, 964.0], [189.0, 964.0]], [[151.0, 770.0], [178.0, 770.0], [178.0, 943.0], [151.0, 943.0]]], "lines": ["「お母さんが", "ダメって言ってた", "犬も飼おう！！」"]}, {"box": [681, 1351, 821, 1550], "vertical": true, "font_size": 28, "lines_coords": [[[793.0, 1351.0], [820.0, 1351.0], [817.0, 1550.0], [790.0, 1550.0]], [[753.0, 1351.0], [784.0, 1351.0], [784.0, 1510.0], [753.0, 1510.0]], [[717.0, 1353.0], [745.0, 1353.0], [746.0, 1484.0], [718.0, 1484.0]], [[681.0, 1351.0], [709.0, 1351.0], [710.0, 1485.0], [682.0, 1485.0]]], "lines": ["「お金が余ったら", "お父さん達の", "家も買って", "あげよう。」"]}, {"box": [262, 1378, 442, 1539], "vertical": true, "font_size": 34, "lines_coords": [[[410.0, 1382.0], [439.0, 1382.0], [439.0, 1514.0], [410.0, 1514.0]], [[367.0, 1378.0], [409.0, 1378.0], [409.0, 1446.0], [367.0, 1446.0]], [[339.0, 1381.0], [367.0, 1381.0], [364.0, 1539.0], [335.0, 1539.0]], [[295.0, 1379.0], [334.0, 1379.0], [334.0, 1470.0], [295.0, 1470.0]], [[262.0, 1382.0], [295.0, 1382.0], [295.0, 1476.0], [262.0, 1476.0]]], "lines": ["フンフンは", "眠気", "そっちのけで", "大興奮", "でした。"]}], "img_path": "115.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [826, 82, 970, 257], "vertical": true, "font_size": 28, "lines_coords": [[[931.0, 82.0], [970.0, 82.0], [970.0, 168.0], [931.0, 168.0]], [[900.0, 87.0], [926.0, 87.0], [926.0, 220.0], [900.0, 220.0]], [[864.0, 87.0], [890.0, 87.0], [890.0, 246.0], [864.0, 246.0]], [[829.0, 89.0], [851.0, 89.0], [851.0, 254.0], [829.0, 254.0]]], "lines": ["「早く、", "この計画を", "愛子ちゃんに", "教えなきゃ！！」"]}, {"box": [481, 673, 622, 859], "vertical": true, "font_size": 30, "lines_coords": [[[592.0, 673.0], [620.0, 673.0], [620.0, 775.0], [592.0, 775.0]], [[556.0, 675.0], [584.0, 675.0], [584.0, 807.0], [556.0, 807.0]], [[517.0, 673.0], [548.0, 673.0], [545.0, 859.0], [514.0, 859.0]], [[481.0, 673.0], [512.0, 673.0], [512.0, 848.0], [481.0, 848.0]]], "lines": ["「みんな、", "すごいって", "ほめてくれるに", "違いない．．．．．」"]}, {"box": [148, 385, 250, 556], "vertical": true, "font_size": 27, "lines_coords": [[[221.0, 385.0], [248.0, 385.0], [246.0, 556.0], [220.0, 556.0]], [[184.0, 385.0], [212.0, 385.0], [209.0, 518.0], [181.0, 518.0]], [[148.0, 387.0], [175.0, 387.0], [175.0, 531.0], [148.0, 531.0]]], "lines": ["「お父さんにも", "教えてあげ", "なくちゃ！！」"]}], "img_path": "116.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [256, 151, 373, 326], "vertical": false, "font_size": 16.0, "lines_coords": [[[256.0, 304.0], [329.0, 151.0], [343.0, 157.0], [270.0, 310.0]], [[273.0, 312.0], [342.0, 159.0], [357.0, 165.0], [289.0, 318.0]], [[289.0, 320.0], [359.0, 171.0], [373.0, 179.0], [303.0, 326.0]]], "lines": ["．．．「きらきっきりと相手で", "アプリケーションを使用していますが、", "ですから、ホームページでは"]}, {"box": [320, 173, 406, 343], "vertical": false, "font_size": 17.0, "lines_coords": [[[335.0, 260.0], [378.0, 173.0], [392.0, 181.0], [350.0, 268.0]], [[320.0, 335.0], [390.0, 181.0], [406.0, 187.0], [335.0, 343.0]]], "lines": ["．．．やればいいの", "どうしてもいいようか、日本語にお"]}, {"box": [385, 215, 517, 387], "vertical": false, "font_size": 16.5, "lines_coords": [[[385.0, 362.0], [456.0, 215.0], [470.0, 221.0], [400.0, 368.0]], [[401.0, 370.0], [471.0, 221.0], [485.0, 228.0], [415.0, 376.0]], [[418.0, 379.0], [485.0, 228.0], [501.0, 234.0], [434.0, 385.0]], [[435.0, 379.0], [501.0, 235.0], [517.0, 242.0], [451.0, 387.0]]], "lines": ["お客さんのお客様にお話をして", "わたしはちゃんとしてみましたが、", "何しかするかもしれないけれどさ。", "．．．お前は誰にですよね私の場に"]}, {"box": [565, 285, 629, 401], "vertical": false, "font_size": 14, "lines_coords": [[[565.0, 396.0], [617.0, 285.0], [629.0, 292.0], [578.0, 401.0]]], "lines": ["いけれどまんじゃないか"]}, {"box": [609, 317, 709, 476], "vertical": false, "font_size": 14.5, "lines_coords": [[[609.0, 470.0], [681.0, 317.0], [695.0, 323.0], [621.0, 476.0]], [[631.0, 462.0], [695.0, 328.0], [709.0, 335.0], [645.0, 468.0]]], "lines": ["．．．やっちゃんはやっぱりねえ", "これで確かめましょうが、"]}, {"box": [818, 32, 843, 73], "vertical": true, "font_size": 14, "lines_coords": [[[829.0, 32.0], [843.0, 37.0], [831.0, 73.0], [818.0, 68.0]]], "lines": ["「愛」"]}, {"box": [723, 18, 832, 231], "vertical": false, "font_size": 16, "lines_coords": [[[723.0, 223.0], [818.0, 18.0], [832.0, 26.0], [737.0, 231.0]]], "lines": ["．．．おかげさ、おやすみ時なん"]}, {"box": [715, 14, 960, 445], "vertical": false, "font_size": 17.857142857142858, "lines_coords": [[[715.0, 321.0], [859.0, 15.0], [873.0, 23.0], [731.0, 328.0]], [[734.0, 325.0], [876.0, 14.0], [892.0, 20.0], [750.0, 331.0]], [[748.0, 334.0], [820.0, 178.0], [835.0, 184.0], [762.0, 342.0]], [[762.0, 346.0], [909.0, 29.0], [926.0, 37.0], [779.0, 354.0]], [[778.0, 351.0], [925.0, 34.0], [942.0, 42.0], [795.0, 359.0]], [[757.0, 435.0], [940.0, 42.0], [959.0, 51.0], [776.0, 445.0]], [[853.0, 276.0], [945.0, 78.0], [960.0, 84.0], [868.0, 282.0]]], "lines": ["やっぱりインターネットではまあ、それでおかげではない時間だと", "この時期までサラッキスト内側のこれが訪れている時間は、まずやかな", "なんですから、そんなことができなかったの", "おかげさんの目標は、サイトでここまで結婚して話し合ったのですが、", "ここで何度か意識していますが、あ、ありがとうわけではないですから", "しかし、それが不明になったのですが、いいから、このようなものですが．．．そんなことは", "いつもはときに、わかりませんがでしかねてっ"]}, {"box": [751, 73, 1037, 570], "vertical": false, "font_size": 65.0, "lines_coords": [[[751.0, 545.0], [968.0, 73.0], [1021.0, 98.0], [804.0, 570.0]], [[868.0, 423.0], [971.0, 171.0], [1037.0, 198.0], [934.0, 450.0]]], "lines": ["クラウドの出会い系サイトで", "一口押さ"]}, {"box": [606, 339, 776, 585], "vertical": false, "font_size": 16.0, "lines_coords": [[[606.0, 556.0], [703.0, 354.0], [717.0, 362.0], [620.0, 562.0]], [[615.0, 579.0], [729.0, 339.0], [743.0, 346.0], [629.0, 585.0]], [[637.0, 576.0], [742.0, 346.0], [757.0, 353.0], [653.0, 582.0]], [[687.0, 509.0], [760.0, 346.0], [776.0, 353.0], [701.0, 515.0]]], "lines": ["．．．お前は俺から、思い出し", "．．．そんなことをかけていく。ですが、", "当社の行事をしっかりそれは、これですけ実際そーからは", "．．．それはそんな気には"]}, {"box": [671, 367, 785, 593], "vertical": false, "font_size": 16, "lines_coords": [[[671.0, 585.0], [771.0, 367.0], [785.0, 375.0], [685.0, 593.0]]], "lines": ["．．．２０１７年７月１７日土曜日サービスとして、"]}], "img_path": "117.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [84, 53, 370, 79], "vertical": false, "font_size": 26, "lines_coords": [[[84.0, 53.0], [370.0, 53.0], [370.0, 79.0], [84.0, 79.0]]], "lines": ["おやすみプンプン［］"]}, {"box": [453, 764, 629, 938], "vertical": true, "font_size": 28, "lines_coords": [[[596.0, 764.0], [629.0, 764.0], [626.0, 901.0], [593.0, 901.0]], [[560.0, 765.0], [593.0, 765.0], [590.0, 876.0], [557.0, 876.0]], [[525.0, 768.0], [551.0, 768.0], [551.0, 926.0], [525.0, 926.0]], [[487.0, 768.0], [514.0, 768.0], [514.0, 926.0], [487.0, 926.0]], [[454.0, 770.0], [476.0, 770.0], [476.0, 934.0], [454.0, 934.0]]], "lines": ["ブンブンは", "なかなか", "愛子ちゃんに", "話しかけられ", "ませんでした。"]}, {"box": [495, 1081, 556, 1215], "vertical": true, "font_size": 28, "lines_coords": [[[525.0, 1081.0], [553.0, 1081.0], [556.0, 1192.0], [528.0, 1192.0]]], "lines": ["ちょ．．．"]}, {"box": [421, 1084, 552, 1447], "vertical": true, "font_size": 34, "lines_coords": [[[492.0, 1084.0], [518.0, 1084.0], [518.0, 1217.0], [492.0, 1217.0]], [[481.0, 1310.0], [523.0, 1310.0], [523.0, 1428.0], [481.0, 1428.0]]], "lines": ["ちょっと！！", "たっ．．．"]}, {"box": [432, 1310, 521, 1460], "vertical": true, "font_size": 38, "lines_coords": [[[432.0, 1310.0], [470.0, 1310.0], [470.0, 1460.0], [432.0, 1460.0]]], "lines": ["大変だ！！"]}, {"box": [100, 1303, 193, 1492], "vertical": true, "font_size": 44, "lines_coords": [[[148.0, 1307.0], [193.0, 1307.0], [193.0, 1456.0], [148.0, 1456.0]], [[100.0, 1303.0], [143.0, 1303.0], [143.0, 1492.0], [100.0, 1492.0]]], "lines": ["ハルミン", "がっ．．．．！！"]}], "img_path": "118.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "119.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "120.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "121.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [884, 157, 951, 290], "vertical": true, "font_size": 31, "lines_coords": [[[914.0, 157.0], [948.0, 157.0], [951.0, 281.0], [917.0, 281.0]], [[884.0, 159.0], [912.0, 159.0], [912.0, 290.0], [884.0, 290.0]]], "lines": ["おーい、", "晴見ーー！！"]}, {"box": [160, 235, 223, 417], "vertical": true, "font_size": 26, "lines_coords": [[[196.0, 239.0], [223.0, 239.0], [223.0, 396.0], [196.0, 396.0]], [[160.0, 235.0], [187.0, 235.0], [187.0, 417.0], [160.0, 417.0]]], "lines": ["何、ボーッと", "してんだーー？"]}, {"box": [35, 298, 75, 459], "vertical": true, "font_size": 40, "lines_coords": [[[35.0, 298.0], [75.0, 298.0], [75.0, 459.0], [35.0, 459.0]]], "lines": ["第７話"]}, {"box": [206, 485, 267, 620], "vertical": true, "font_size": 26, "lines_coords": [[[240.0, 485.0], [267.0, 485.0], [267.0, 592.0], [240.0, 592.0]], [[206.0, 489.0], [232.0, 489.0], [232.0, 620.0], [206.0, 620.0]]], "lines": ["まじめに", "やりなさー"]}, {"box": [171, 546, 195, 617], "vertical": true, "font_size": 26, "lines_coords": [[[171.0, 546.0], [195.0, 546.0], [195.0, 617.0], [171.0, 617.0]]], "lines": ["い！！"]}, {"box": [646, 1014, 681, 1132], "vertical": true, "font_size": 28, "lines_coords": [[[646.0, 1015.0], [676.0, 1014.0], [681.0, 1131.0], [651.0, 1132.0]]], "lines": ["．．．．．ねぇ、"]}, {"box": [507, 1054, 604, 1204], "vertical": true, "font_size": 28, "lines_coords": [[[578.0, 1054.0], [604.0, 1054.0], [604.0, 1204.0], [578.0, 1204.0]], [[543.0, 1057.0], [570.0, 1057.0], [570.0, 1189.0], [543.0, 1189.0]], [[507.0, 1057.0], [534.0, 1057.0], [534.0, 1162.0], [507.0, 1162.0]]], "lines": ["さっきのアレ", "やっぱ告白", "かなぁ？"]}, {"box": [145, 1012, 245, 1200], "vertical": true, "font_size": 27, "lines_coords": [[[214.0, 1012.0], [245.0, 1012.0], [242.0, 1200.0], [210.0, 1200.0]], [[179.0, 1014.0], [206.0, 1014.0], [206.0, 1171.0], [179.0, 1171.0]], [[145.0, 1014.0], [167.0, 1014.0], [167.0, 1168.0], [145.0, 1168.0]]], "lines": ["やっぱあの二人", "付き合ったり", "すんのかな？"]}, {"box": [667, 1288, 801, 1485], "vertical": true, "font_size": 26, "lines_coords": [[[773.0, 1289.0], [800.0, 1289.0], [800.0, 1420.0], [773.0, 1420.0]], [[737.0, 1289.0], [764.0, 1289.0], [764.0, 1421.0], [737.0, 1421.0]], [[701.0, 1289.0], [728.0, 1289.0], [728.0, 1482.0], [701.0, 1482.0]], [[668.0, 1289.0], [690.0, 1289.0], [690.0, 1485.0], [668.0, 1485.0]]], "lines": ["先生のこと", "怒らせると", "首の骨、へし折っ", "ちゃうぞーーっ！！"]}, {"box": [465, 1190, 498, 1275], "vertical": true, "font_size": 33, "lines_coords": [[[465.0, 1190.0], [498.0, 1190.0], [498.0, 1275.0], [465.0, 1275.0]]], "lines": ["だろ？"]}, {"box": [104, 1207, 205, 1434], "vertical": true, "font_size": 27, "lines_coords": [[[176.0, 1207.0], [203.0, 1207.0], [203.0, 1393.0], [176.0, 1393.0]], [[140.0, 1209.0], [168.0, 1209.0], [165.0, 1382.0], [137.0, 1382.0]], [[104.0, 1210.0], [131.0, 1210.0], [131.0, 1434.0], [104.0, 1434.0]]], "lines": ["．．．じゃねーー？", "だって、前から", "両想いだったじゃん。"]}], "img_path": "122.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [623, 108, 690, 306], "vertical": true, "font_size": 28, "lines_coords": [[[660.0, 109.0], [687.0, 109.0], [687.0, 303.0], [660.0, 303.0]], [[623.0, 109.0], [651.0, 109.0], [651.0, 240.0], [623.0, 240.0]]], "lines": ["「両想いの二人は", "付き合う。」"]}, {"box": [393, 103, 532, 318], "vertical": true, "font_size": 28, "lines_coords": [[[501.0, 104.0], [532.0, 104.0], [529.0, 318.0], [498.0, 318.0]], [[467.0, 107.0], [493.0, 107.0], [493.0, 315.0], [467.0, 315.0]], [[428.0, 103.0], [459.0, 103.0], [459.0, 317.0], [428.0, 317.0]], [[395.0, 107.0], [421.0, 107.0], [421.0, 250.0], [395.0, 250.0]]], "lines": ["プンプンにとって", "それはすさまじく", "新しく、モダンな", "概念でした。"]}, {"box": [871, 1046, 1010, 1231], "vertical": true, "font_size": 28, "lines_coords": [[[978.0, 1046.0], [1010.0, 1046.0], [1010.0, 1137.0], [978.0, 1137.0]], [[945.0, 1048.0], [971.0, 1048.0], [971.0, 1181.0], [945.0, 1181.0]], [[907.0, 1048.0], [934.0, 1048.0], [934.0, 1231.0], [907.0, 1231.0]], [[871.0, 1048.0], [898.0, 1048.0], [898.0, 1217.0], [871.0, 1217.0]]], "lines": ["しかし、", "ブンブンは", "ひとつの疑問が", "浮かびました。"]}, {"box": [79, 1029, 219, 1215], "vertical": true, "font_size": 26, "lines_coords": [[[192.0, 1031.0], [217.0, 1031.0], [214.0, 1215.0], [189.0, 1215.0]], [[153.0, 1029.0], [179.0, 1029.0], [179.0, 1201.0], [153.0, 1201.0]], [[117.0, 1031.0], [143.0, 1031.0], [140.0, 1190.0], [114.0, 1190.0]], [[81.0, 1031.0], [107.0, 1031.0], [106.0, 1212.0], [79.0, 1212.0]]], "lines": ["付き合うという", "ことはつまり", "何をすること", "なのだろう、と。"]}], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [106, 462, 247, 706], "vertical": true, "font_size": 33, "lines_coords": [[[215.0, 465.0], [246.0, 465.0], [246.0, 706.0], [215.0, 706.0]], [[173.0, 462.0], [215.0, 462.0], [215.0, 682.0], [173.0, 682.0]], [[139.0, 467.0], [170.0, 467.0], [173.0, 676.0], [142.0, 676.0]], [[107.0, 467.0], [134.0, 467.0], [132.0, 659.0], [106.0, 659.0]]], "lines": ["プンプンの頭の中を", "以前、ハルミンが", "言っていた一言が", "駆け巡りました。"]}, {"box": [510, 851, 613, 1035], "vertical": true, "font_size": 27, "lines_coords": [[[585.0, 853.0], [612.0, 853.0], [612.0, 998.0], [585.0, 998.0]], [[548.0, 854.0], [575.0, 854.0], [575.0, 1035.0], [548.0, 1035.0]], [[510.0, 851.0], [537.0, 851.0], [537.0, 996.0], [510.0, 996.0]]], "lines": ["「付き合った", "女子のアソコに", "男子の．．．：」"]}, {"box": [117, 1360, 145, 1545], "vertical": true, "font_size": 26, "lines_coords": [[[117.0, 1360.0], [143.0, 1360.0], [143.0, 1545.0], [117.0, 1545.0]]], "lines": ["せんせーーっ！！"]}], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [801, 102, 976, 337], "vertical": true, "font_size": 24, "lines_coords": [[[948.0, 106.0], [970.0, 106.0], [970.0, 284.0], [948.0, 284.0]], [[909.0, 103.0], [935.0, 103.0], [935.0, 262.0], [909.0, 262.0]], [[873.0, 103.0], [900.0, 103.0], [900.0, 243.0], [873.0, 243.0]], [[837.0, 103.0], [859.0, 103.0], [859.0, 335.0], [837.0, 335.0]], [[803.0, 104.0], [825.0, 104.0], [825.0, 264.0], [803.0, 264.0]]], "lines": ["タマがフラフラ", "している棒を", "穴に入れる、", "腰の使い方が重要な", "スポーツって、"]}, {"box": [176, 420, 208, 606], "vertical": true, "font_size": 28, "lines_coords": [[[179.0, 420.0], [207.0, 420.0], [204.0, 606.0], [176.0, 606.0]]], "lines": ["なぁ～～んだ？"]}, {"box": [951, 1034, 1018, 1231], "vertical": true, "font_size": 30, "lines_coords": [[[984.0, 1034.0], [1018.0, 1034.0], [1018.0, 1132.0], [984.0, 1132.0]], [[951.0, 1035.0], [978.0, 1035.0], [978.0, 1229.0], [951.0, 1229.0]]], "lines": ["何想像", "してんのアナタ。"]}, {"box": [185, 1057, 251, 1228], "vertical": true, "font_size": 30, "lines_coords": [[[218.0, 1057.0], [251.0, 1057.0], [251.0, 1142.0], [218.0, 1142.0]], [[185.0, 1060.0], [212.0, 1060.0], [212.0, 1228.0], [185.0, 1228.0]]], "lines": ["答えは", "けん玉でした。"]}, {"box": [685, 1400, 723, 1495], "vertical": true, "font_size": 33, "lines_coords": [[[685.0, 1401.0], [718.0, 1400.0], [723.0, 1493.0], [690.0, 1495.0]]], "lines": ["やらし。"]}, {"box": [91, 1342, 226, 1550], "vertical": true, "font_size": 25, "lines_coords": [[[198.0, 1342.0], [226.0, 1342.0], [226.0, 1448.0], [198.0, 1448.0]], [[162.0, 1342.0], [189.0, 1342.0], [189.0, 1526.0], [162.0, 1526.0]], [[126.0, 1343.0], [148.0, 1343.0], [148.0, 1550.0], [126.0, 1550.0]], [[92.0, 1343.0], [114.0, 1343.0], [114.0, 1481.0], [92.0, 1481.0]]], "lines": ["両想いの", "付き合っている", "男女はセックスを", "するという。"]}], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [562, 95, 660, 332], "vertical": true, "font_size": 29, "lines_coords": [[[634.0, 98.0], [660.0, 98.0], [660.0, 332.0], [634.0, 332.0]], [[593.0, 95.0], [625.0, 95.0], [628.0, 307.0], [596.0, 307.0]], [[562.0, 98.0], [589.0, 98.0], [589.0, 292.0], [562.0, 292.0]]], "lines": ["ならば愛子ちゃんは", "自分をどう思って", "いるのだろう、と"]}, {"box": [453, 95, 520, 306], "vertical": true, "font_size": 29, "lines_coords": [[[487.0, 95.0], [520.0, 95.0], [517.0, 306.0], [484.0, 306.0]], [[453.0, 98.0], [481.0, 98.0], [481.0, 228.0], [453.0, 228.0]]], "lines": ["プンプンは猛烈に", "気になって"]}, {"box": [417, 96, 519, 304], "vertical": true, "font_size": 26, "lines_coords": [[[417.0, 96.0], [443.0, 96.0], [443.0, 210.0], [417.0, 210.0]]], "lines": ["きました。"]}, {"box": [625, 429, 685, 571], "vertical": true, "font_size": 25, "lines_coords": [[[659.0, 429.0], [685.0, 429.0], [685.0, 571.0], [659.0, 571.0]], [[625.0, 432.0], [646.0, 432.0], [646.0, 560.0], [625.0, 560.0]]], "lines": ["．．．何、アナタ", "転んだの？"]}, {"box": [515, 568, 612, 701], "vertical": true, "font_size": 25, "lines_coords": [[[585.0, 568.0], [612.0, 568.0], [612.0, 676.0], [585.0, 676.0]], [[548.0, 573.0], [576.0, 573.0], [576.0, 678.0], [548.0, 678.0]], [[515.0, 573.0], [537.0, 573.0], [537.0, 701.0], [515.0, 701.0]]], "lines": ["こんなの", "かすり傷", "てしょう？"]}, {"box": [112, 567, 212, 723], "vertical": true, "font_size": 26, "lines_coords": [[[182.0, 567.0], [210.0, 567.0], [207.0, 723.0], [179.0, 723.0]], [[146.0, 567.0], [173.0, 567.0], [173.0, 709.0], [146.0, 709.0]], [[112.0, 567.0], [134.0, 567.0], [134.0, 721.0], [112.0, 721.0]]], "lines": ["ホント最近は", "みんな、ヤワ", "なんだから．．．"]}, {"box": [950, 765, 982, 884], "vertical": true, "font_size": 31, "lines_coords": [[[950.0, 765.0], [982.0, 765.0], [982.0, 884.0], [950.0, 884.0]]], "lines": ["．．．ハイ。"]}, {"box": [821, 879, 887, 1054], "vertical": true, "font_size": 31, "lines_coords": [[[854.0, 879.0], [887.0, 879.0], [884.0, 1054.0], [851.0, 1054.0]], [[821.0, 882.0], [848.0, 882.0], [848.0, 1025.0], [821.0, 1025.0]]], "lines": ["一応消毒して", "おいたから。"]}, {"box": [248, 825, 348, 968], "vertical": true, "font_size": 26, "lines_coords": [[[320.0, 825.0], [348.0, 825.0], [348.0, 957.0], [320.0, 957.0]], [[282.0, 825.0], [309.0, 825.0], [309.0, 957.0], [282.0, 957.0]], [[248.0, 826.0], [275.0, 826.0], [275.0, 968.0], [248.0, 968.0]]], "lines": ["先生、用が", "あるから席", "はずすけど、"]}, {"box": [128, 928, 225, 1089], "vertical": true, "font_size": 26, "lines_coords": [[[198.0, 928.0], [225.0, 928.0], [225.0, 1089.0], [198.0, 1089.0]], [[160.0, 929.0], [189.0, 929.0], [189.0, 1062.0], [160.0, 1062.0]], [[128.0, 929.0], [148.0, 929.0], [148.0, 1060.0], [128.0, 1060.0]]], "lines": ["少し休んだら", "授業に戻り", "なさいよ？"]}, {"box": [437, 1361, 514, 1547], "vertical": true, "font_size": 58, "lines_coords": [[[439.0, 1371.0], [496.0, 1365.0], [514.0, 1529.0], [456.0, 1535.0]]], "lines": ["キャン．．．"]}], "img_path": "126.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [910, 515, 975, 686], "vertical": true, "font_size": 28, "lines_coords": [[[946.0, 517.0], [975.0, 517.0], [975.0, 625.0], [946.0, 625.0]], [[910.0, 515.0], [937.0, 515.0], [937.0, 684.0], [910.0, 684.0]]], "lines": ["．．．わざと", "転んじゃった。"]}, {"box": [170, 667, 232, 800], "vertical": true, "font_size": 24, "lines_coords": [[[204.0, 667.0], [231.0, 667.0], [231.0, 800.0], [204.0, 800.0]], [[170.0, 670.0], [192.0, 670.0], [192.0, 771.0], [170.0, 771.0]]], "lines": ["どうしてか", "わかる？"]}, {"box": [140, 1027, 248, 1369], "vertical": true, "font_size": 27, "lines_coords": [[[143.0, 1210.0], [170.0, 1210.0], [170.0, 1367.0], [143.0, 1367.0]]], "lines": ["ふーん．．．"]}, {"box": [910, 1176, 1009, 1385], "vertical": true, "font_size": 25, "lines_coords": [[[987.0, 1181.0], [1009.0, 1181.0], [1009.0, 1385.0], [987.0, 1385.0]], [[948.0, 1181.0], [975.0, 1181.0], [975.0, 1362.0], [948.0, 1362.0]], [[910.0, 1176.0], [937.0, 1176.0], [940.0, 1321.0], [914.0, 1321.0]]], "lines": ["こうでもしないと", "二人きりになれ", "ないでしょ。"]}, {"box": [795, 1345, 892, 1537], "vertical": true, "font_size": 25, "lines_coords": [[[865.0, 1345.0], [892.0, 1345.0], [892.0, 1537.0], [865.0, 1537.0]], [[829.0, 1345.0], [856.0, 1345.0], [856.0, 1506.0], [829.0, 1506.0]], [[795.0, 1346.0], [817.0, 1346.0], [817.0, 1537.0], [795.0, 1537.0]]], "lines": ["だってプンプン、", "あたしのこと", "避けるんだもん。"]}, {"box": [492, 1420, 519, 1553], "vertical": true, "font_size": 26, "lines_coords": [[[492.0, 1420.0], [518.0, 1420.0], [518.0, 1553.0], [492.0, 1553.0]]], "lines": ["．．．違うの？"]}, {"box": [145, 1206, 173, 1368], "vertical": true, "font_size": 28, "lines_coords": [[[145.0, 1206.0], [173.0, 1206.0], [173.0, 1368.0], [145.0, 1368.0]]], "lines": ["ふーん．．．"]}], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [175, 359, 251, 582], "vertical": true, "font_size": 32, "lines_coords": [[[217.0, 359.0], [251.0, 359.0], [251.0, 459.0], [217.0, 459.0]], [[175.0, 359.0], [206.0, 359.0], [206.0, 582.0], [175.0, 582.0]]], "lines": ["じゃあ", "信じてあげる！！"]}, {"box": [850, 1056, 1022, 1319], "vertical": true, "font_size": 25, "lines_coords": [[[995.0, 1057.0], [1021.0, 1057.0], [1021.0, 1221.0], [995.0, 1221.0]], [[959.0, 1057.0], [985.0, 1057.0], [985.0, 1267.0], [959.0, 1267.0]], [[923.0, 1056.0], [950.0, 1056.0], [950.0, 1217.0], [923.0, 1217.0]], [[887.0, 1059.0], [909.0, 1059.0], [909.0, 1318.0], [887.0, 1318.0]], [[851.0, 1059.0], [875.0, 1059.0], [873.0, 1279.0], [850.0, 1279.0]]], "lines": ["．．．そうだよね、", "だってプンプンは", "どんな時でも", "あたしを守ってくれる", "って言ったもんね。"]}, {"box": [515, 1357, 620, 1517], "vertical": true, "font_size": 29, "lines_coords": [[[590.0, 1360.0], [618.0, 1360.0], [618.0, 1492.0], [590.0, 1492.0]], [[554.0, 1360.0], [581.0, 1360.0], [581.0, 1517.0], [554.0, 1517.0]], [[515.0, 1357.0], [548.0, 1357.0], [548.0, 1442.0], [515.0, 1442.0]]], "lines": ["プンプンは", "あたしのこと", "好き？"]}], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 