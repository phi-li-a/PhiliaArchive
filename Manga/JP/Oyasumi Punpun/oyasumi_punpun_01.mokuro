1.0, 401.0]]], "lines": ["．．．ねぇプンプン、", "園田さんが", "晴見くんに告白", "したの知ってる？"]}, {"box": [912, 689, 978, 785], "vertical": true, "font_size": 30, "lines_coords": [[[942.0, 704.0], [971.0, 701.0], [978.0, 767.0], [948.0, 770.0]], [[912.0, 689.0], [939.0, 689.0], [939.0, 785.0], [912.0, 785.0]]], "lines": ["．．．", "いいなー"]}, {"box": [195, 482, 293, 650], "vertical": true, "font_size": 28, "lines_coords": [[[265.0, 482.0], [293.0, 482.0], [293.0, 589.0], [265.0, 589.0]], [[228.0, 482.0], [259.0, 482.0], [259.0, 642.0], [228.0, 642.0]], [[195.0, 484.0], [221.0, 484.0], [221.0, 650.0], [195.0, 650.0]]], "lines": ["夏休みに", "二人で豊島園", "行くんだって。"]}, {"box": [765, 764, 870, 978], "vertical": true, "font_size": 30, "lines_coords": [[[832.0, 764.0], [870.0, 764.0], [870.0, 828.0], [832.0, 828.0]], [[801.0, 770.0], [828.0, 770.0], [828.0, 978.0], [801.0, 978.0]], [[765.0, 771.0], [792.0, 771.0], [792.0, 925.0], [765.0, 925.0]]], "lines": ["別に", "遊園地じゃなくて", "いいけど．．．"]}, {"box": [357, 1021, 459, 1209], "vertical": true, "font_size": 28, "lines_coords": [[[425.0, 1021.0], [456.0, 1021.0], [459.0, 1209.0], [428.0, 1209.0]], [[393.0, 1025.0], [420.0, 1025.0], [420.0, 1207.0], [393.0, 1207.0]], [[357.0, 1026.0], [384.0, 1026.0], [384.0, 1139.0], [357.0, 1139.0]]], "lines": ["あたし、他の人", "なんてどーでも", "いいしさ、"]}, {"box": [129, 785, 265, 942], "vertical": true, "font_size": 24, "lines_coords": [[[235.0, 785.0], [262.0, 785.0], [262.0, 926.0], [235.0, 926.0]], [[200.0, 785.0], [226.0, 785.0], [226.0, 940.0], [200.0, 940.0]], [[165.0, 787.0], [187.0, 787.0], [187.0, 942.0], [165.0, 942.0]], [[129.0, 787.0], [151.0, 787.0], [151.0, 914.0], [129.0, 914.0]]], "lines": ["誰もいない、", "どこか遠ーい", "ところに行き", "たいな．．．"]}, {"box": [103, 1067, 201, 1248], "vertical": true, "font_size": 26, "lines_coords": [[[175.0, 1067.0], [201.0, 1067.0], [201.0, 1198.0], [175.0, 1198.0]], [[139.0, 1067.0], [165.0, 1067.0], [165.0, 1248.0], [139.0, 1248.0]], [[103.0, 1068.0], [129.0, 1068.0], [129.0, 1176.0], [103.0, 1176.0]]], "lines": 