もね。"]}, {"box": [92, 1375, 155, 1483], "vertical": true, "font_size": 25, "lines_coords": [[[131.0, 1376.0], [153.0, 1376.0], [153.0, 1482.0], [131.0, 1482.0]], [[92.0, 1375.0], [120.0, 1375.0], [120.0, 1457.0], [92.0, 1457.0]]], "lines": ["ごちそう", "さま！！"]}], "img_path": "080.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [878, 135, 1014, 354], "vertical": true, "font_size": 24, "lines_coords": [[[987.0, 135.0], [1014.0, 135.0], [1014.0, 321.0], [987.0, 321.0]], [[950.0, 135.0], [976.0, 135.0], [976.0, 350.0], [950.0, 350.0]], [[915.0, 135.0], [937.0, 135.0], [937.0, 342.0], [915.0, 342.0]], [[878.0, 135.0], [900.0, 135.0], [900.0, 342.0], [878.0, 342.0]]], "lines": ["．．．父さんももう", "いい年なんだから、", "あまり一人で無理", "しちゃダメだよ？"]}, {"box": [896, 625, 968, 785], "vertical": true, "font_size": 34, "lines_coords": [[[926.0, 625.0], [968.0, 628.0], [964.0, 692.0], [923.0, 689.0]], [[896.0, 631.0], [923.0, 631.0], [923.0, 785.0], [896.0, 785.0]]], "lines": ["バカ", "おっしゃい！！"]}, {"box": [121, 321, 262, 532], "vertical": true, "font_size": 27, "lines_coords": [[[234.0, 323.0], [260.0, 323.0], [260.0, 532.0], [234.0, 532.0]], [[195.0, 325.0], [223.0, 325.0], [225.0, 481.0], [196.0, 481.0]], [[160.0, 323.0], [187.0, 323.0], [187.0, 482.0], [160.0, 482.0]], [[121.0, 321.0], [148.0, 321.0], [151.0, 442.0], [125.0, 442.0]]], "lines": ["あたし達の家なら", "いつ来たって", "かまわないん", "だからね。"]}, {"box": [214, 695, 281, 867], "vertical": true, "font_size": 28, "lines_coords": [[[250.0, 695.0], [281.0, 695.0], [281.0, 867.0], [250.0, 867.0]], [[214.0, 696.0], [240.0, 696.0], [243.0, 829.0], [217.0, 829.0]]], "lines": ["俺ぁ、まだまだ", "現役だヨ！！"]}, {"box": [881, 972, 992, 1380], "vertical": true, "font_size": 62, "lines_coords": [[[887.0, 1098.0], [948.0, 1089.0], [968.0, 1218.0], [907.0, 1228.0]]], "lines": ["．．．"]}, {"box": [645, 1253, 700, 1420], "vertical": true, "font_size": 55, "lines_coords": [[[645.0, 1256.0], [700.0, 1256.0], [700.0, 1420.0], [645.0, 1420.0]]], "lines"