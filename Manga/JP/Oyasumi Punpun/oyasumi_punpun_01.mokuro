, "あたしの幸せ", "だけを考えていて", "くれるもんね？"]}, {"box": [239, 739, 284, 854], "vertical": true, "font_size": 45, "lines_coords": [[[239.0, 739.0], [284.0, 739.0], [284.0, 854.0], [239.0, 854.0]]], "lines": ["ねっ！？"]}, {"box": [795, 1038, 822, 1168], "vertical": true, "font_size": 26, "lines_coords": [[[795.0, 1039.0], [821.0, 1039.0], [821.0, 1168.0], [795.0, 1168.0]]], "lines": ["．．．返事は？"]}, {"box": [517, 1192, 554, 1278], "vertical": true, "font_size": 34, "lines_coords": [[[517.0, 1193.0], [551.0, 1192.0], [554.0, 1276.0], [520.0, 1278.0]]], "lines": ["．．．ね？"]}], "img_path": "133.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [85, 60, 368, 87], "vertical": false, "font_size": 27, "lines_coords": [[[85.0, 60.0], [368.0, 60.0], [368.0, 87.0], [85.0, 87.0]]], "lines": ["おやすみプンプン［"]}, {"box": [501, 585, 570, 770], "vertical": true, "font_size": 27, "lines_coords": [[[542.0, 587.0], [568.0, 587.0], [568.0, 745.0], [542.0, 745.0]], [[504.0, 585.0], [532.0, 585.0], [529.0, 770.0], [501.0, 770.0]]], "lines": ["今、うんって", "言ったかんね！！"]}, {"box": [143, 1018, 266, 1212], "vertical": true, "font_size": 30, "lines_coords": [[[231.0, 1018.0], [264.0, 1018.0], [260.0, 1182.0], [228.0, 1182.0]], [[187.0, 1020.0], [218.0, 1020.0], [218.0, 1212.0], [187.0, 1212.0]], [[143.0, 1021.0], [171.0, 1021.0], [171.0, 1148.0], [143.0, 1148.0]]], "lines": ["嘘だったら", "ゆるさないん", "だから！！"]}, {"box": [603, 1312, 743, 1561], "vertical": true, "font_size": 29, "lines_coords": [[[714.0, 1317.0], [740.0, 1317.0], [740.0, 1471.0], [714.0, 1471.0]], [[675.0, 1314.0], [706.0, 1314.0], [706.0, 1478.0], [675.0, 1478.0]], [[640.0, 1315.0], [667.0, 1315.0], [667.0, 1448.0], [640.0, 1448.0]], [[603.0, 1312.0], [634.0, 1312.0], [634.0, 1559.0], [603.0, 1559.0]]], "lines": ["愛子ちゃんの", "ず〜〜っとは", "どれくらい", "ずぅ〜〜っとなのか"]}, {"box": [328, 1312, 503, 1524], "vertical": true, "font_size": 26, "lines_coords": [[[475.0, 1314.0], [501.0, 1314.0], [501.0, 1498.0], [475.0, 1498.0]], [[437.0, 1314.0], [465.0, 1314.0], [465.0, 1446.0], [437.0, 1446.0]], [[401.0, 1317.0], [423.0, 1317.0], [423.0, 1520.0], [401.0, 1520.0]], [[360.0, 1312.0], [389.0, 1312.0], [393.0, 1500.0], [365.0, 1500.0]], [[328.0, 1314.0], [354.0, 1314.0], [354.0, 1432.0], [328.0, 1432.0]]], "lines": ["それを考えると", "フンフンは", "なんとも言えない", "気持ちになって", "きました。"]}], "img_path": "134.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [870, 93, 1012, 307], "vertical": true, "font_size": 27, "lines_coords": [[[982.0, 96.0], [1009.0, 96.0], [1009.0, 231.0], [982.0, 231.0]], [[946.0, 96.0], [973.0, 96.0], [973.0, 256.0], [946.0, 256.0]], [[907.0, 93.0], [934.0, 93.0], [934.0, 307.0], [907.0, 307.0]], [[870.0, 95.0], [896.0, 95.0], [900.0, 289.0], [873.0, 289.0]]], "lines": ["プンプンは", "その気持ちを", "うまく言葉にでき", "ませんでしたが、"]}, {"box": [154, 415, 256, 612], "vertical": true, "font_size": 28, "lines_coords": [[[226.0, 417.0], [253.0, 417.0], [253.0, 601.0], [226.0, 601.0]], [[189.0, 415.0], [220.0, 415.0], [220.0, 604.0], [189.0, 604.0]], [[154.0, 415.0], [181.0, 415.0], [181.0, 607.0], [154.0, 607.0]]], "lines": ["あえて便宜的に", "言いかえるなら", "こうでしょうか。"]}, {"box": [987, 1100, 1015, 1226], "vertical": true, "font_size": 32, "lines_coords": [[[987.0, 1100.0], [1015.0, 1100.0], [1015.0, 1226.0], [987.0, 1226.0]]], "lines": ["ハルミン！！"]}, {"box": [509, 782, 541, 897], "vertical": true, "font_size": 29, "lines_coords": [[[510.0, 787.0], [539.0, 787.0], [539.0, 890.0], [510.0, 890.0]]], "lines": ["「怖い。"]}, {"box": [865, 1240, 934, 1375], "vertical": true, "font_size": 32, "lines_coords": [[[893.0, 1240.0], [934.0, 1240.0], [934.0, 1326.0], [893.0, 1326.0]], [[865.0, 1243.0], [892.0, 1243.0], [892.0, 1375.0], [865.0, 1375.0]]], "lines": ["ハール", "ミ～～ン！！"]}, {"box": [154, 1282, 254, 1508], "vertical": true, "font_size": 25, "lines_coords": [[[226.0, 1282.0], [253.0, 1282.0], [253.0, 1415.0], [226.0, 1415.0]], [[189.0, 1282.0], [215.0, 1282.0], [215.0, 1468.0], [189.0, 1468.0]], [[154.0, 1285.0]