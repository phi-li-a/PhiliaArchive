.0], [164.0, 1507.0], [140.0, 1507.0]]], "lines": ["なんでこんな", "遠いとこの", "みそ工場の場所", "知ってんの？"]}], "img_path": "213.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [869, 126, 1010, 290], "vertical": true, "font_size": 30, "lines_coords": [[[978.0, 128.0], [1010.0, 129.0], [1006.0, 264.0], [973.0, 262.0]], [[939.0, 129.0], [970.0, 129.0], [970.0, 290.0], [939.0, 290.0]], [[900.0, 126.0], [932.0, 126.0], [932.0, 275.0], [900.0, 275.0]], [[870.0, 131.0], [896.0, 131.0], [896.0, 275.0], [870.0, 275.0]]], "lines": ["俺、むかし", "ここらへんで", "よく一人で", "遊んでてさ。"]}, {"box": [764, 687, 942, 901], "vertical": true, "font_size": 28, "lines_coords": [[[912.0, 693.0], [940.0, 693.0], [939.0, 901.0], [910.0, 901.0]], [[875.0, 692.0], [901.0, 692.0], [901.0, 901.0], [875.0, 901.0]], [[840.0, 692.0], [867.0, 692.0], [867.0, 890.0], [840.0, 890.0]], [[804.0, 690.0], [831.0, 690.0], [829.0, 901.0], [803.0, 901.0]], [[764.0, 687.0], [798.0, 687.0], [798.0, 760.0], [764.0, 760.0]]], "lines": ["みそ工場の社長が", "ウチの親父の親友", "だかなんだかで", "トクイ先だったん", "だよ。"]}, {"box": [403, 303, 545, 515], "vertical": true, "font_size": 31, "lines_coords": [[[515.0, 306.0], [543.0, 306.0], [540.0, 442.0], [512.0, 442.0]], [[479.0, 306.0], [507.0, 306.0], [506.0, 515.0], [478.0, 515.0]], [[440.0, 306.0], [471.0, 306.0], [471.0, 492.0], [440.0, 492.0]], [[403.0, 303.0], [439.0, 303.0], [439.0, 371.0], [403.0, 371.0]]], "lines": ["田中は転校", "してきたばっかで", "知らねーだろう", "けど、"]}, {"box": [79, 454, 180, 612], "vertical": true, "font_size": 25, "lines_coords": [[[151.0, 456.0], [178.0, 456.0], [178.0, 612.0], [151.0, 612.0]], [[117.0, 457.0], [139.0, 457.0], [139.0, 609.0], [117.0, 609.0]], [[79.0, 454.0], [106.0, 454.0], [106.0, 560.0], [79.0, 560.0]]], "lines": ["ホラ、俺んち", "弁当屋だった", "じゃん？"]}, {"box": [173, 1112, 307, 1270], "vertical": true, "font_size": 28, "lines_coords": [[[281.0, 1114.0], [307.0, 1114.0], [307.0, 1245.0], [281.0, 1245.0]], [[245.0, 1112.0], [271.0, 1112.0], [271.0, 1270.0], [24