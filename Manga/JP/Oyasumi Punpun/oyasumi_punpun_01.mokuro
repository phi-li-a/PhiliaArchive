, {"box": [146, 1323, 226, 1437], "vertical": true, "font_size": 35, "lines_coords": [[[184.0, 1328.0], [218.0, 1328.0], [218.0, 1437.0], [184.0, 1437.0]], [[146.0, 1323.0], [182.0, 1323.0], [182.0, 1398.0], [146.0, 1398.0]]], "lines": ["田中愛子", "です。"]}], "img_path": "010.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [921, 992, 1020, 1148], "vertical": true, "font_size": 25, "lines_coords": [[[996.0, 995.0], [1018.0, 995.0], [1018.0, 1128.0], [996.0, 1128.0]], [[956.0, 992.0], [982.0, 992.0], [982.0, 1148.0], [956.0, 1148.0]], [[921.0, 993.0], [948.0, 993.0], [948.0, 1106.0], [921.0, 1106.0]]], "lines": ["それじゃあ、", "転校生が来た", "ことだし、"]}, {"box": [541, 755, 568, 940], "vertical": true, "font_size": 22, "lines_coords": [[[543.0, 756.0], [565.0, 756.0], [565.0, 937.0], [543.0, 937.0]]], "lines": ["一目惚れでした。"]}, {"box": [584, 1043, 646, 1176], "vertical": true, "font_size": 27, "lines_coords": [[[618.0, 1043.0], [646.0, 1043.0], [646.0, 1151.0], [618.0, 1151.0]], [[584.0, 1046.0], [610.0, 1046.0], [610.0, 1176.0], [584.0, 1176.0]]], "lines": ["なーん", "つってな！！"]}, {"box": [681, 1350, 781, 1481], "vertical": true, "font_size": 27, "lines_coords": [[[754.0, 1354.0], [781.0, 1354.0], [781.0, 1481.0], [754.0, 1481.0]], [[717.0, 1350.0], [745.0, 1350.0], [745.0, 1457.0], [717.0, 1457.0]], [[681.0, 1353.0], [707.0, 1353.0], [707.0, 1481.0], [681.0, 1481.0]]], "lines": ["一時間目は", "さっそく", "テストだ！！"]}, {"box": [245, 1296, 384, 1545], "vertical": true, "font_size": 27, "lines_coords": [[[356.0, 1296.0], [384.0, 1296.0], [381.0, 1429.0], [353.0, 1429.0]], [[315.0, 1296.0], [348.0, 1296.0], [348.0, 1507.0], [315.0, 1507.0]], [[279.0, 1296.0], [306.0, 1296.0], [306.0, 1506.0], [279.0, 1506.0]], [[245.0, 1296.0], [271.0, 1296.0], [271.0, 1545.0], [245.0, 1545.0]]], "lines": ["自己紹介も", "かねて、みんなに", "自分の夢について", "作文を書いてもらう。"]}, {"box": [115, 1354, 212, 1564], "vertical": true, "font_size": 27, "lines_coords": [[[182.0, 1354.0], [210.0, 1354.0], [212.0, 1540.0], [184.0, 1540.0]], [[148.0, 1356.0], [175.0, 1356.0], [175.0, 1564.0], [148.0, 1564.0]], [[115.0, 1357.0], [137.0, 1357.0], [137.0, 1459.0], [115.0, 1459.0]]], "lines": ["終わらなかった", "者は、明日までの", "宿題だー"]}], "img_path": "011.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [885, 81, 985, 292], "vertical": true, "font_size": 26, "lines_coords": [[[954.0, 81.0], [982.0, 81.0], [984.0, 243.0], [956.0, 243.0]], [[918.0, 84.0], [945.0, 84.0], [945.0, 292.0], [918.0, 292.0]], [[885.0, 84.0], [907.0, 84.0], [907.0, 225.0], [885.0, 225.0]]], "lines": ["夢といっても", "職業に限ったこと", "じゃないぞ！"]}, {"box": [528, 114, 668, 335], "vertical": true, "font_size": 27, "lines_coords": [[[639.0, 115.0], [665.0, 115.0], [665.0, 298.0], [639.0, 298.0]], [[603.0, 117.0], [629.0, 117.0], [629.0, 332.0], [603.0, 332.0]], [[565.0, 115.0], [593.0, 115.0], [592.0, 326.0], [564.0, 326.0]], [[529.0, 114.0], [556.0, 114.0], [554.0, 298.0], [528.0, 298.0]]], "lines": ["大人になったら", "やってみたいこと、", "みんな、何かしら", "あるだろーー？"]}, {"box": [82, 53, 368, 82], "vertical": false, "font_size": 26, "lines_coords": [[[82.0, 53.0], [368.0, 56.0], [368.0, 82.0], [82.0, 79.0]]], "lines": ["おやすみプンプン［"]}, {"box": [101, 240, 204, 401], "vertical": true, "font_size": 26, "lines_coords": [[[170.0, 242.0], [204.0, 242.0], [204.0, 332.0], [170.0, 332.0]], [[137.0, 240.0], [165.0, 240.0], [162.0, 401.0], [134.0, 401.0]], [[101.0, 242.0], [129.0, 242.0], [129.0, 343.0], [101.0, 343.0]]], "lines": ["みんな、", "夢はでっかく", "持てよー"]}, {"box": [150, 478, 251, 637], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 479.0], [251.0, 479.0], [251.0, 637.0], [225.0, 637.0]], [[187.0, 478.0], [214.0, 478.0], [214.0, 609.0], [187.0, 609.0]], [[153.0, 479.0], [176.0, 479.0], [173.0, 600.0], [150.0, 600.0]]], "lines": ["夢はどれだけ", "見てもタダ", "だからなー"]}, {"box": [104, 343, 176, 659], "vertical": true, "font_size": 26, "lines_coords": [[[154.0, 606.0], [176.0, 606.0], [176.0, 659.0], [154.0, 659.0]], [[104.0, 343.0], [126.0, 343.0], [126.0, 398.0], [104.0, 398.0]]], "lines": ["！！", "！！"]}, {"box": [793, 760, 967, 968], "vertical": true, "font_size": 24, "lines_coords": [[[940.0, 760.0], [967.0, 760.0], [967.0, 968.0], [940.0, 968.0]], [[903.0, 760.0], [929.0, 760.0], [929.0, 917.0], [903.0, 917.0]], [[867.0, 762.0], [889.0, 762.0], [889.0, 968.0], [867.0, 968.0]], [[832.0, 760.0], [854.0, 760.0], [854.0, 943.0], [832.0, 943.0]], [[796.0, 760.0], [818.0, 760.0], [818.0, 890.0], [796.0, 890.0]]], "lines": ["とはいえ、自分の", "器の大きさや", "家庭の経済状況を", "ふまえることも", "肝心だぞ！！"]}, {"box": [128, 973, 229, 1210], "vertical": true, "font_size": 25, "lines_coords": [[[196.0, 973.0], [229.0, 973.0], [229.0, 1162.0], [196.0, 1162.0]], [[162.0, 973.0], [189.0, 973.0], [189.0, 1184.0], [162.0, 1184.0]], [[128.0, 975.0], [150.0, 975.0], [150.0, 1160.0], [128.0, 1160.0]], [[131.0, 1157.0], [148.0, 1157.0], [148.0, 1207.0], [131.0, 1207.0]]], "lines": ["でないと、将来", "強い挫折に苦しめ", "られるからなー", "．．．"]}], "img_path": "012.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [921, 1233, 950, 1322], "vertical": true, "font_size": 29, "lines_coords": [[[921.0, 1234.0], [950.0, 1234.0], [950.0, 1321.0], [921.0, 1321.0]]], "lines": ["ねぇ君、"]}, {"box": [146, 1326, 246, 1539], "vertical": true, "font_size": 28, "lines_coords": [[[218.0, 1328.0], [245.0, 1328.0], [245.0, 1460.0], [218.0, 1460.0]], [[179.0, 1326.0], [210.0, 1326.0], [210.0, 1539.0], [179.0, 1539.0]], [[146.0, 1329.0], [173.0, 1329.0], [173.0, 1432.0], [146.0, 1432.0]]], "lines": ["さっきから", "どうして、ついて", "くるの？"]}], "img_path": "013.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [850, 27, 986, 437], "vertical": true, "font_size": 107, "lines_coords": [[[873.0, 101.0], [979.0, 110.0], [957.0, 379.0], [850.0, 370.0]]], "lines": ["だ、"]}, {"box": [115, 121, 143, 279], "vertical": true, "font_size": 27, "lines_coords": [[[115.0, 121.0], [142.0, 121.0], [142.0, 279.0], [115.0, 279.0]]], "lines": ["警察呼ぶよ！！"]}, {"box": [893, 728, 959, 889], "vertical": true, "font_size": 26, "lines_coords": [[[931.0, 732.0], [959.0, 732.0], [959.0, 848.0], [931.0, 848.0]], [[896.0, 728.0], [925.0, 728.0], [921.0, 889.0], [893.0, 889.0]]], "lines": ["．．．ごめん、", "ごめーーん！"]}, {"box": [817, 853, 839, 1006], "vertical": true, "font_size": 26, "lines_coords": [[[817.0, 853.0], [839.0, 853.0], [839.0, 1006.0], [817.0, 1006.0]]], "lines": ["冗談だから！！"]}, {"box": [145, 968, 247, 1104], "vertical": true, "font_size": 29, "lines_coords": [[[214.0, 968.0], [246.0, 968.0], [246.0, 1078.0], [214.0, 1078.0]], [[181.0, 971.0], [209.0, 971.0], [209.0, 1104.0], [181.0, 1104.0]], [[145.0, 970.0], [171.0, 970.0], [171.0, 1076.0], [145.0, 1076.0]]], "lines": ["君、同じ", "クラスの子", "だよね？"]}, {"box": [887, 1201, 957, 1359], "vertical": true, "font_size": 32, "lines_coords": [[[923.0, 1201.0], [957.0, 1201.0], [957.0, 1284.0], [923.0, 1284.0]], [[890.0, 1201.0], [917.0, 1201.0], [914.0, 1359.0], [887.0, 1359.0]]], "lines": ["帰り道", "こっちなの？"]}, {"box": [790, 1373, 860, 1465], "vertical": true, "font_size": 32, "lines_coords": [[[826.0, 1373.0], [860.0, 1373.0], [860.0, 1465.0], [826.0, 1465.0]], [[790.0, 1381.0], [823.0, 1381.0], [823.0, 1465.0], [790.0, 1465.0]]], "lines": ["一緒に", "帰る？"]}, {"box": [114, 1378, 177, 1550], "vertical": true, "font_size": 22, "lines_coords": [[[117.0, 1381.0], [139.0, 1381.0], [139.0, 1542.0], [117.0, 1542.0]]], "lines": ["愛子ちゃんは"]}], "img_path": "014.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [917, 115, 1017, 271], "vertical": true, "font_size": 27, "lines_coords": [[[989.0, 115.0], [1017.0, 115.0], [1017.0, 221.0], [989.0, 221.0]], [[954.0, 117.0], [981.0, 117.0], [981.0, 271.0], [954.0, 271.0]], [[917.0, 115.0], [943.0, 115.0], [943.0, 231.0], [917.0, 231.0]]], "lines": ["少しだけ", "いいにおいが", "しました。"]}, {"box": [691, 137, 790, 271], "vertical": true, "font_size": 26, "lines_coords": [[[762.0, 137.0], [789.0, 137.0], [789.0, 270.0], [762.0, 270.0]], [[725.0, 140.0], [753.0, 140.0], [753.0, 248.0], [725.0, 248.0]], [[692.0, 142.0], [714.0, 142.0], [714.0, 270.0], [692.0, 270.0]]], "lines": ["プンプンは", "作文書き", "終わった？"]}, {"box": [92, 312, 193, 498], "vertical": true, "font_size": 27, "lines_coords": [[[154.0, 314.0], [190.0, 312.0], [193.0, 406.0], [157.0, 407.0]], [[126.0, 315.0], [153.0, 315.0], [153.0, 451.0], [126.0, 451.0]], [[92.0, 318.0], [114.0, 318.0], [114.0, 498.0], [92.0, 498.0]]], "lines": ["あたし、", "すぐに書き", "終わっちゃった。"]}, {"box": [153, 518, 285, 743], "vertical": true, "font_size": 27, "lines_coords": [[[259.0, 520.0], [285.0, 520.0], [285.0, 657.0], [259.0, 657.0]], [[223.0, 520.0], [250.0, 520.0], [250.0, 678.0], [223.0, 678.0]], [[185.0, 518.0], [217.0, 518.0], [217.0, 731.0], [185.0, 731.0]], [[153.0, 520.0], [175.0, 520.0], [175.0, 743.0], [153.0, 743.0]]], "lines": ["だって絶対、", "女優か歌手か", "モデルになるって", "決めてるんだもん！！"]}, {"box": [948, 768, 1021, 905], "vertical": true, "font_size": 41, "lines_coords": [[[973.0, 773.0], [1014.0, 768.0], [1021.0, 843.0], [981.0, 848.0]]], "lines": ["ねえ、"]}, {"box": [798, 776, 1013, 1177], "vertical": true, "font_size": 26, "lines_coords": [[[946.0, 776.0], [975.0, 776.0], [975.0, 907.0], [946.0, 907.0]], [[945.0, 940.0], [971.0, 940.0], [971.0, 1075.0], [945.0, 1075.0]], [[907.0, 940.0], [934.0, 940.0], [934.0, 1159.0], [907.0, 1159.0]], [[871.0, 943.0], [898.0, 943.0], [898.0, 1160.0], [871.0, 1160.0]], [[834.0, 942.0], [860.0, 942.0], [860.0, 1175.0], [834.0, 1175.0]], [[798.0, 940.0], [820.0, 940.0], [823.0, 1160.0], [801.0, 1160.0]]], "lines": ["知ってる？", "あと数年で", "石油が無くなって、", "環境も破壊されて、", "地球は人の住めない", "星になるんだって。"]}, {"box": [170, 979, 304, 1190], "vertical": true, "font_size": 27, "lines_coords": [[[278.0, 981.0], [304.0, 981.0], [304.0, 1190.0], [278.0, 1190.0]], [[240.0, 979.0], [267.0, 979.0], [267.0, 1139.0], [240.0, 1139.0]], [[201.0, 979.0], [232.0, 979.0], [232.0, 1165.0], [201.0, 1165.0]], [[170.0, 982.0], [192.0, 982.0], [192.0, 1173.0], [170.0, 1173.0]]], "lines": ["別の星にイジュー", "てもしないと", "人類はメツボー", "しちゃうんだよ。"]}, {"box": [182, 1295, 209, 1425], "vertical": true, "font_size": 27, "lines_coords": [[[182.0, 1295.0], [209.0, 1295.0], [209.0, 1425.0], [182.0, 1425.0]]], "lines": ["知ってた！？"]}], "img_path": "015.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [829, 134, 962, 292], "vertical": true, "font_size": 26, "lines_coords": [[[940.0, 135.0], [962.0, 135.0], [962.0, 289.0], [940.0, 289.0]], [[901.0, 134.0], [928.0, 134.0], [928.0, 292.0], [901.0, 292.0]], [[867.0, 135.0], [889.0, 135.0], [889.0, 290.0], [867.0, 290.0]], [[829.0, 135.0], [856.0, 135.0], [856.0, 273.0], [829.0, 273.0]]], "lines": ["お父さん達は", "どうにかして", "生き残ろうと", "してるけど、"]}, {"box": [804, 364, 945, 604], "vertical": true, "font_size": 26, "lines_coords": [[[917.0, 364.0], [945.0, 364.0], [942.0, 526.0], [914.0, 526.0]], [[876.0, 368.0], [907.0, 368.0], [907.0, 579.0], [876.0, 579.0]], [[842.0, 368.0], [868.0, 368.0], [868.0, 604.0], [842.0, 604.0]], [[804.0, 367.0], [831.0, 367.0], [831.0, 484.0], [804.0, 484.0]]], "lines": ["でもやっぱり", "メツボーする時は", "メツボーしちゃうと", "思うんだ。"]}, {"box": [882, 751, 915, 845], "vertical": true, "font_size": 33, "lines_coords": [[[882.0, 751.0], [915.0, 751.0], [915.0, 845.0], [882.0, 845.0]]], "lines": ["．．．あ、"]}, {"box": [75, 387, 248, 632], "vertical": true, "font_size": 27, "lines_coords": [[[218.0, 389.0], [245.0, 389.0], [245.0, 623.0], [218.0, 623.0]], [[179.0, 387.0], [206.0, 387.0], [209.0, 631.0], [182.0, 631.0]], [[143.0, 389.0], [171.0, 389.0], [173.0, 632.0], [145.0, 632.0]], [[106.0, 387.0], [137.0, 387.0], [137.0, 570.0], [106.0, 570.0]], [[75.0, 390.0], [96.0, 390.0], [96.0, 492.0], [75.0, 492.0]]], "lines": ["だから１０代のうちに", "やりたいことやって、", "お金いっぱい貯めて、", "２０代で全部使い", "切るの！！"]}, {"box": [153, 784, 255, 959], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 784.0], [251.0, 784.0], [251.0, 901.0], [225.0, 901.0]], [[190.0, 785.0], [217.0, 785.0], [217.0, 948.0], [190.0, 948.0]], [[153.0, 789.0], [179.0, 789.0], [179.0, 959.0], [153.0, 959.0]]], "lines": ["ごめんね", "ここらへんで", "バイバイしよ。"]}, {"box": [550, 1304, 576, 1435], "vertical": true, "font_size": 22, "lines_coords": [[[551.0, 1304.0], [573.0, 1304.0], [573.0, 1434.0], [551.0, 1434.0]]], "lines": ["また明日！！"]}], "img_path": "016.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [875, 104, 1014, 315], "vertical": true, "font_size": 26, "lines_coords": [[[985.0, 104.0], [1012.0, 104.0], [1012.0, 239.0], [985.0, 239.0]], [[946.0, 104.0], [973.0, 104.0], [973.0, 314.0], [946.0, 314.0]], [[912.0, 106.0], [939.0, 106.0], [939.0, 240.0], [912.0, 240.0]], [[876.0, 106.0], [898.0, 106.0], [898.0, 271.0], [876.0, 271.0]]], "lines": ["プンプンは", "なんだかすっかり", "圧倒されて", "しまいました。"]}, {"box": [140, 384, 316, 621], "vertical": true, "font_size": 25, "lines_coords": [[[285.0, 385.0], [312.0, 385.0], [312.0, 621.0], [285.0, 621.0]], [[246.0, 387.0], [273.0, 387.0], [273.0, 595.0], [246.0, 595.0]], [[215.0, 389.0], [237.0, 389.0], [237.0, 593.0], [215.0, 593.0]], [[175.0, 384.0], [201.0, 384.0], [203.0, 595.0], [176.0, 595.0]], [[142.0, 387.0], [164.0, 387.0], [164.0, 525.0], [142.0, 525.0]]], "lines": ["愛子ちゃんが住んで", "いたという練馬は", "一体どんなすごい", "街なんだろう、と", "思いました。"]}, {"box": [721, 731, 827, 976], "vertical": true, "font_size": 28, "lines_coords": [[[795.0, 731.0], [826.0, 731.0], [826.0, 945.0], [795.0, 945.0]], [[760.0, 732.0], [787.0, 732.0], [787.0, 892.0], [760.0, 892.0]], [[723.0, 734.0], [750.0, 734.0], [750.0, 971.0], [723.0, 971.0]]], "lines": ["そしてプンプンは", "自分はどんな", "大人になるんだろう"]}, {"box": [476, 729, 649, 925], "vertical": true, "font_size": 28, "lines_coords": [[[626.0, 735.0], [648.0, 735.0], [648.0, 914.0], [626.0, 914.0]], [[582.0, 729.0], [617.0, 731.0], [614.0, 839.0], [579.0, 837.0]], [[548.0, 732.0], [575.0, 732.0], [575.0, 920.0], [548.0, 920.0]], [[512.0, 732.0], [539.0, 732.0], [539.0, 865.0], [512.0, 865.0]], [[476.0, 732.0], [503.0, 732.0], [503.0, 892.0], [476.0, 892.0]]], "lines": ["と考えていると", "帰り道が", "わからなくなり、", "泣きそうに", "なりましたが、"]}, {"box": [379, 731, 407, 982], "vertical": true, "font_size": 27, "lines_coords": [[[379.0, 731.0], [406.0, 731.0], [406.0, 976.0], [379.0, 976.0]]], "lines": ["グッとこらえました。"]}, {"box": [267, 1131, 453, 1223], "vertical": false, "font_size": 52.0, "lines_coords": [[[267.0, 1131.0], [443.0, 1131.0], [443.0, 1157.0], [267.0, 1157.0]], [[304.0, 1145.0], [448.0, 1137.0], [453.0, 1215.0], [309.0, 1223.0]]], "lines": ["プン山プップンパパパ", "山プップンパパフトプレプションプン"]}, {"box": [573, 1256, 639, 1481], "vertical": true, "font_size": 29, "lines_coords": [[[606.0, 1256.0], [639.0, 1256.0], [639.0, 1376.0], [606.0, 1376.0]], [[573.0, 1257.0], [600.0, 1257.0], [600.0, 1481.0], [573.0, 1481.0]]], "lines": ["．．．９回裏、", "満塁のチャンスに、"]}, {"box": [484, 1431, 548, 1539], "vertical": true, "font_size": 29, "lines_coords": [[[521.0, 1431.0], [548.0, 1431.0], [548.0, 1537.0], [521.0, 1537.0]], [[484.0, 1431.0], [512.0, 1431.0], [512.0, 1539.0], [484.0, 1539.0]]], "lines": ["打つか！？", "打つか．．．"]}, {"box": [126, 1378, 157, 1538], "vertical": true, "font_size": 28, "lines_coords": [[[126.0, 1378.0], [154.0, 1378.0], [156.0, 1537.0], [128.0, 1537.0]]], "lines": ["．．．おっおっ．．．"]}], "img_path": "017.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [889, 150, 987, 370], "vertical": true, "font_size": 39, "lines_coords": [[[937.0, 151.0], [981.0, 150.0], [987.0, 368.0], [943.0, 370.0]], [[890.0, 153.0], [923.0, 153.0], [923.0, 362.0], [890.0, 362.0]]], "lines": ["打ったぁ〜", "～～～っ！！"]}, {"box": [237, 93, 287, 323], "vertical": true, "font_size": 37, "lines_coords": [[[243.0, 93.0], [287.0, 95.0], [281.0, 323.0], [237.0, 321.0]]], "lines": ["んいよしっ！！"]}, {"box": [98, 248, 193, 409], "vertical": true, "font_size": 37, "lines_coords": [[[154.0, 248.0], [193.0, 248.0], [193.0, 393.0], [154.0, 393.0]], [[98.0, 248.0], [135.0, 248.0], [135.0, 409.0], [98.0, 409.0]]], "lines": ["まわれ、", "まわれー"]}, {"box": [860, 623, 962, 818], "vertical": true, "font_size": 28, "lines_coords": [[[931.0, 623.0], [962.0, 623.0], [962.0, 810.0], [931.0, 810.0]], [[898.0, 625.0], [925.0, 625.0], [925.0, 809.0], [898.0, 809.0]], [[860.0, 626.0], [887.0, 626.0], [889.0, 817.0], [862.0, 817.0]]], "lines": ["実はプンプンは", "プロ野球選手に", "なるのが夢です。"]}, {"box": [367, 628, 456, 797], "vertical": true, "font_size": 25, "lines_coords": [[[429.0, 631.0], [456.0, 631.0], [456.0, 753.0], [429.0, 753.0]], [[395.0, 628.0], [421.0, 628.0], [425.0, 773.0], [398.0, 773.0]], [[367.0, 632.0], [389.0, 632.0], [389.0, 796.0], [367.0, 796.0]]], "lines": ["いやぁ～～", "これぞ巨人の", "勝ち方だよ～～"]}, {"box": [103, 442, 131, 496], "vertical": true, "font_size": 37, "lines_coords": [[[103.0, 442.0], [131.0, 442.0], [131.0, 496.0], [103.0, 496.0]]], "lines": ["！！"]}, {"box": [117, 675, 265, 915], "vertical": true, "font_size": 26, "lines_coords": [[[237.0, 676.0], [264.0, 676.0], [264.0, 859.0], [237.0, 859.0]], [[206.0, 675.0], [232.0, 675.0], [235.0, 912.0], [209.0, 912.0]], [[178.0, 678.0], [204.0, 678.0], [204.0, 910.0], [178.0, 910.0]], [[148.0, 678.0], [175.0, 678.0], [175.0, 885.0], [148.0, 885.0]], [[117.0, 676.0], [143.0, 676.0], [146.0, 915.0], [120.0, 915.0]]], "lines": ["まだ野球をした", "ことはありませんが、", "野球中継を見ている", "お父さんはとても", "気分がいいからです。"]}, {"box": [844, 939, 1002, 1175], "vertical": true, "font_size": 26, "lines_coords": [[[975.0, 939.0], [1001.0, 939.0], [1001.0, 1175.0], [975.0, 1175.0]], [[942.0, 940.0], [968.0, 940.0], [968.0, 1123.0], [942.0, 1123.0]], [[907.0, 940.0], [934.0, 940.0], [934.0, 1125.0], [907.0, 1125.0]], [[875.0, 939.0], [901.0, 939.0], [903.0, 1150.0], [876.0, 1150.0]], [[845.0, 940.0], [867.0, 940.0], [868.0, 1078.0], [846.0, 1078.0]]], "lines": ["でも、それは本当に", "自分がやりたい", "ことなのかな？", "などと少し考えて", "しまいます。"]}, {"box": [517, 940, 584, 1046], "vertical": true, "font_size": 30, "lines_coords": [[[551.0, 942.0], [584.0, 942.0], [584.0, 1032.0], [551.0, 1032.0]], [[517.0, 940.0], [545.0, 940.0], [545.0, 1046.0], [517.0, 1046.0]]], "lines": ["母さん、", "ビール！！"]}, {"box": [105, 1053, 165, 1237], "vertical": true, "font_size": 24, "lines_coords": [[[137.0, 1053.0], [165.0, 1053.0], [165.0, 1134.0], [137.0, 1134.0]], [[106.0, 1056.0], [126.0, 1056.0], [126.0, 1235.0], [106.0, 1235.0]]], "lines": ["．．．もう", "ありませんよ．．．"]}, {"box": [906, 1228, 975, 1387], "vertical": true, "font_size": 30, "lines_coords": [[[940.0, 1228.0], [975.0, 1228.0], [975.0, 1335.0], [940.0, 1335.0]], [[906.0, 1229.0], [932.0, 1229.0], [935.0, 1385.0], [909.0, 1385.0]]], "lines": ["．．．やっぱ", "アレかな〜〜"]}, {"box": [637, 1295, 757, 1504], "vertical": true, "font_size": 26, "lines_coords": [[[728.0, 1296.0], [754.0, 1296.0], [756.0, 1504.0], [729.0, 1504.0]], [[698.0, 1296.0], [725.0, 1296.0], [725.0, 1479.0], [698.0, 1479.0]], [[664.0, 1295.0], [690.0, 1295.0], [690.0, 1478.0], [664.0, 1478.0]]], "lines": ["こんな試合の夜は", "ベッドの中でも", "猛打賞なのかね"]}, {"box": [545, 1290, 572, 1447], "vertical": true, "font_size": 26, "lines_coords": [[[545.0, 1290.0], [571.0, 1290.0], [571.0, 1446.0], [545.0, 1446.0]]], "lines": ["．．．無いって．．．"]}, {"box": [57, 1300, 220, 1600], "vertical": true, "font_size": 55, "lines_coords": [[[171.0, 1307.0], [220.0, 1307.0], [220.0, 1600.0], [171.0, 1600.0]], [[104.0, 1300.0], [171.0, 1300.0], [171.0, 1542.0], [104.0, 1542.0]], [[57.0, 1310.0], [106.0, 1310.0], [106.0, 1564.0], [57.0, 1564.0]]], "lines": ["無いってこたぁ", "ねーだろ、", "ンダラァッ！！"]}], "img_path": "018.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [923, 95, 1034, 287], "vertical": true, "font_size": 32, "lines_coords": [[[1001.0, 96.0], [1034.0, 96.0], [1034.0, 226.0], [1001.0, 226.0]], [[960.0, 95.0], [993.0, 95.0], [996.0, 273.0], [964.0, 273.0]], [[923.0, 96.0], [956.0, 96.0], [956.0, 287.0], [923.0, 287.0]]], "lines": ["冷蔵庫に", "あんの、俺ぁ", "知ってんど！！"]}, {"box": [832, 198, 904, 376], "vertical": true, "font_size": 32, "lines_coords": [[[864.0, 200.0], [898.0, 198.0], [904.0, 310.0], [870.0, 312.0]], [[832.0, 201.0], [859.0, 201.0], [859.0, 376.0], [832.0, 376.0]]], "lines": ["出せぁ、", "クソダラァ！！"]}, {"box": [542, 142, 668, 335], "vertical": true, "font_size": 32, "lines_coords": [[[634.0, 143.0], [665.0, 143.0], [665.0, 303.0], [634.0, 303.0]], [[589.0, 145.0], [621.0, 145.0], [621.0, 334.0], [589.0, 334.0]], [[542.0, 142.0], [575.0, 142.0], [578.0, 335.0], [545.0, 335.0]]], "lines": ["俺の稼いだ", "金で買った酒", "だろがよォ！！"]}, {"box": [132, 262, 255, 471], "vertical": true, "font_size": 33, "lines_coords": [[[220.0, 264.0], [253.0, 264.0], [253.0, 471.0], [220.0, 471.0]], [[171.0, 265.0], [204.0, 264.0], [210.0, 451.0], [178.0, 453.0]], [[132.0, 262.0], [164.0, 262.0], [164.0, 421.0], [132.0, 421.0]]], "lines": ["アンタ、一年前", "から無職じゃ", "ないのよ！！"]}, {"box": [676, 542, 828, 753], "vertical": true, "font_size": 33, "lines_coords": [[[790.0, 542.0], [828.0, 542.0], [823.0, 753.0], [785.0, 753.0]], [[753.0, 545.0], [784.0, 545.0], [784.0, 737.0], [753.0, 737.0]], [[712.0, 543.0], [743.0, 543.0], [746.0, 737.0], [715.0, 737.0]], [[676.0, 546.0], [707.0, 546.0], [707.0, 735.0], [676.0, 735.0]]], "lines": ["今日、アンタに", "飲ませる分は", "もう無いって", "ことでしょ！？"]}, {"box": [590, 526, 632, 590], "vertical": true, "font_size": 39, "lines_coords": [[[590.0, 526.0], [632.0, 526.0], [632.0, 590.0], [590.0, 590.0]]], "lines": ["おっ"]}, {"box": [553, 592, 589, 648], "vertical": true, "font_size": 39, "lines_coords": [[[553.0, 592.0], [589.0, 592.0], [589.0, 648.0], [553.0, 648.0]]], "lines": ["おっ"]}, {"box": [229, 559, 298, 640], "vertical": true, "font_size": 34, "lines_coords": [[[264.0, 559.0], [298.0, 559.0], [298.0, 639.0], [264.0, 639.0]], [[229.0, 559.0], [264.0, 559.0], [264.0, 640.0], [229.0, 640.0]]], "lines": ["おまっ", "おまっ"]}, {"box": [167, 662, 201, 746], "vertical": true, "font_size": 34, "lines_coords": [[[167.0, 662.0], [201.0, 662.0], [201.0, 746.0], [167.0, 746.0]]], "lines": ["おっ．．．"]}, {"box": [756, 782, 1038, 1229], "vertical": true, "font_size": 29, "lines_coords": [[[1009.0, 785.0], [1035.0, 785.0], [1035.0, 945.0], [1009.0, 945.0]], [[965.0, 782.0], [998.0, 782.0], [1001.0, 1051.0], [968.0, 1051.0]], [[928.0, 784.0], [959.0, 784.0], [959.0, 978.0], [928.0, 978.0]], [[889.0, 784.0], [920.0, 784.0], [920.0, 1001.0], [889.0, 1001.0]], [[881.0, 990.0], [909.0, 990.0], [906.0, 1132.0], [878.0, 1132.0]], [[839.0, 1006.0], [870.0, 1006.0], [870.0, 1168.0], [839.0, 1168.0]], [[801.0, 1007.0], [828.0, 1007.0], [828.0, 1229.0], [801.0, 1229.0]], [[760.0, 1006.0], [787.0, 1006.0], [787.0, 1195.0], [760.0, 1195.0]]], "lines": ["おまえらを", "置いてけないから、", "俺ぁ単身赴任", "蹴ったんだど！？", "まっさか", "それだけで", "首切られるとは", "思わないさ！！"]}, {"box": [142, 1006, 307, 1245], "vertical": true, "font_size": 33, "lines_coords": [[[273.0, 1006.0], [307.0, 1006.0], [307.0, 1104.0], [273.0, 1104.0]], [[229.0, 1006.0], [262.0, 1006.0], [262.0, 1245.0], [229.0, 1245.0]], [[185.0, 1006.0], [217.0, 1006.0], [217.0, 1168.0], [185.0, 1168.0]], [[142.0, 1006.0], [173.0, 1006.0], [173.0, 1196.0], [142.0, 1196.0]]], "lines": ["お前も", "女房なら、少しは", "俺の気持ち", "汲めよおぉ！！"]}, {"box": [753, 1326, 856, 1550], "vertical": true, "font_size": 27, "lines_coords": [[[826.0, 1329.0], [854.0, 1329.0], [854.0, 1460.0], [826.0, 1460.0]], [[789.0, 1329.0], [817.0, 1329.0], [817.0, 1460.0], [789.0, 1460.0]], [[753.0, 1326.0], [779.0, 1326.0], [782.0, 1548.0], [756.0, 1548.0]]], "lines": ["ブンフンは", "こんな日は", "少し慣れっこです。"]}, {"box": [220, 1342, 342, 1535], "vertical": true, "font_size": 33, "lines_coords": [[[310.0, 1343.0], [342.0, 1343.0], [342.0, 1503.0], [310.0, 1503.0]], [[262.0, 1342.0], [300.0, 1342.0], [300.0, 1506.0], [262.0, 1506.0]], [[220.0, 1342.0], [253.0, 1342.0], [256.0, 1535.0], [223.0, 1535.0]]], "lines": ["俺の愛情を", "汲んでくれ", "よおぉぉっ！！"]}], "img_path": "019.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [779, 146, 885, 303], "vertical": true, "font_size": 29, "lines_coords": [[[856.0, 146.0], [884.0, 146.0], [884.0, 293.0], [856.0, 293.0]], [[818.0, 146.0], [845.0, 146.0], [845.0, 303.0], [818.0, 303.0]], [[779.0, 146.0], [812.0, 146.0], [812.0, 240.0], [779.0, 240.0]]], "lines": ["ですが、一応", "神様にお祈り", "します。"]}, {"box": [81, 60, 368, 87], "vertical": false, "font_size": 27, "lines_coords": [[[81.0, 60.0], [368.0, 60.0], [368.0, 87.0], [81.0, 87.0]]], "lines": ["おやすみプンプン□"]}, {"box": [74, 193, 214, 368], "vertical": true, "font_size": 27, "lines_coords": [[[184.0, 195.0], [212.0, 195.0], [209.0, 317.0], [181.0, 317.0]], [[146.0, 193.0], [173.0, 193.0], [173.0, 367.0], [146.0, 367.0]], [[110.0, 195.0], [137.0, 195.0], [137.0, 329.0], [110.0, 329.0]], [[75.0, 195.0], [101.0, 195.0], [101.0, 365.0], [75.0, 365.0]]], "lines": ["「神様神様", "チンクルホイ」", "と唱えると", "神様が来ます。"]}, {"box": [187, 414, 290, 600], "vertical": true, "font_size": 30, "lines_coords": [[[256.0, 414.0], [290.0, 414.0], [290.0, 506.0], [256.0, 506.0]], [[221.0, 414.0], [253.0, 414.0], [253.0, 600.0], [221.0, 600.0]], [[187.0, 414.0], [214.0, 414.0], [214.0, 598.0], [187.0, 598.0]]], "lines": ["これは、", "大船に住んでる", "雄一おじさんに"]}, {"box": [151, 419, 288, 660], "vertical": true, "font_size": 137, "lines_coords": [[[151.0, 419.0], [288.0, 419.0], [288.0, 660.0], [151.0, 660.0]]], "lines": ["これは、大船に住んでる雄一おじさんに教えてもらいました。"]}, {"box": [150, 381, 176, 660], "vertical": true, "font_size": 30, "lines_coords": [[[150.0, 381.0], [176.0, 381.0], [176.0, 660.0], [150.0, 660.0]]], "lines": ["教えてもらいました。"]}, {"box": [176, 1062, 246, 1184], "vertical": true, "font_size": 34, "lines_coords": [[[206.0, 1062.0], [246.0, 1062.0], [246.0, 1134.0], [206.0, 1134.0]], [[176.0, 1067.0], [203.0, 1067.0], [203.0, 1184.0], [176.0, 1184.0]]], "lines": ["ほら、", "もう来た。"]}], "img_path": "020.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [390, 48, 829, 414], "vertical": false, "font_size": 298, "lines_coords": [[[390.0, 121.0], [773.0, 48.0], [829.0, 340.0], [446.0, 414.0]]], "lines": ["ふふ"]}, {"box": [184, 985, 287, 1182], "vertical": true, "font_size": 28, "lines_coords": [[[254.0, 985.0], [287.0, 985.0], [287.0, 1120.0], [254.0, 1120.0]], [[220.0, 987.0], [246.0, 987.0], [246.0, 1120.0], [220.0, 1120.0]], [[184.0, 985.0], [210.0, 985.0], [210.0, 1179.0], [184.0, 1179.0]]], "lines": ["プンプンは", "神様にそう", "語りかけました。"]}, {"box": [854, 859, 992, 1071], "vertical": true, "font_size": 28, "lines_coords": [[[965.0, 859.0], [992.0, 859.0], [989.0, 1007.0], [962.0, 1007.0]], [[926.0, 860.0], [957.0, 860.0], [957.0, 1071.0], [926.0, 1071.0]], [[890.0, 862.0], [917.0, 862.0], [917.0, 1043.0], [890.0, 1043.0]], [[854.0, 864.0], [881.0, 864.0], [881.0, 1032.0], [854.0, 1032.0]]], "lines": ["「お父さんと", "お母さんはもっと", "仲良くなれない", "のだろうか？」"]}, {"box": [92, 1243, 454, 1595], "vertical": false, "font_size": 80.5, "lines_coords": [[[92.0, 1526.0], [382.0, 1243.0], [450.0, 1312.0], [159.0, 1595.0]], [[193.0, 1534.0], [414.0, 1351.0], [454.0, 1401.0], [234.0, 1584.0]]], "lines": ["．．．ふたまも、", "いいーーーい"]}], "img_path": "021.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [921, 82, 953, 212], "vertical": true, "font_size": 28, "lines_coords": [[[925.0, 82.0], [953.0, 82.0], [950.0, 210.0], [921.0, 210.0]]], "lines": ["「僕は．．．．．"]}, {"box": [40, 0, 554, 542], "vertical": true, "font_size": 193, "lines_coords": [[[400.0, 68.0], [490.0, 73.0], [473.0, 481.0], [382.0, 476.0]], [[248.0, 46.0], [450.0, 46.0], [450.0, 515.0], [248.0, 515.0]], [[235.0, 146.0], [342.0, 462.0], [245.0, 493.0], [140.0, 179.0]], [[131.0, 109.0], [254.0, 445.0], [190.0, 470.0], [65.0, 134.0]], [[40.0, 84.0], [314.0, 0.0], [554.0, 398.0], [281.0, 542.0]]], "lines": ["焦らずゆっくり", "俺とすゆこくり考えればいいさなぜなら君には", "２０１６年８月２８日", "なんでその．．．", "おっそれじゃなぜならない。無限の可能性はあるから"]}, {"box": [697, 434, 834, 679], "vertical": true, "font_size": 24, "lines_coords": [[[807.0, 435.0], [829.0, 435.0], [829.0, 550.0], [807.0, 550.0]], [[767.0, 434.0], [795.0, 434.0], [796.0, 593.0], [768.0, 593.0]], [[732.0, 435.0], [759.0, 435.0], [759.0, 631.0], [732.0, 631.0]], [[700.0, 437.0], [721.0, 437.0], [721.0, 676.0], [700.0, 676.0]]], "lines": ["一僕は将来", "どんな大人に", "なるのだろう？」", "ふとそう思いました。"]}, {"box": [531, 729, 951, 1018], "vertical": false, "font_size": 76.33333333333333, "lines_coords": [[[531.0, 954.0], [792.0, 729.0], [846.0, 793.0], [585.0, 1018.0]], [[657.0, 962.0], [851.0, 740.0], [910.0, 792.0], [717.0, 1014.0]], [[789.0, 962.0], [893.0, 768.0], [951.0, 800.0], [846.0, 993.0]]], "lines": ["おいおい！！", "これからの", "．．．"]}, {"box": [826, 1256, 855, 1413], "vertical": true, "font_size": 22, "lines_coords": [[[828.0, 1259.0], [850.0, 1259.0], [850.0, 1409.0], [828.0, 1409.0]]], "lines": ["．．．フンフン！"]}], "img_path": "022.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [889, 139, 1032, 298], "vertical": true, "font_size": 31, "lines_coords": [[[995.0, 139.0], [1032.0, 139.0], [1032.0, 190.0], [995.0, 190.0]], [[964.0, 142.0], [992.0, 142.0], [992.0, 251.0], [964.0, 251.0]], [[928.0, 142.0], [954.0, 142.0], [954.0, 298.0], [928.0, 298.0]], [[889.0, 139.0], [923.0, 139.0], [923.0, 223.0], [889.0, 223.0]]], "lines": ["おー", "悪い悪い、", "勉強中だった", "か．．．"]}, {"box": [126, 525, 260, 682], "vertical": true, "font_size": 26, "lines_coords": [[[231.0, 525.0], [259.0, 525.0], [259.0, 659.0], [231.0, 659.0]], [[196.0, 526.0], [225.0, 526.0], [225.0, 657.0], [196.0, 657.0]], [[160.0, 526.0], [187.0, 526.0], [187.0, 682.0], [160.0, 682.0]], [[126.0, 528.0], [148.0, 528.0], [148.0, 667.0], [126.0, 667.0]]], "lines": ["．．．実は今日", "プンプンに", "プレゼントが", "あったんだ。"]}, {"box": [929, 784, 959, 943], "vertical": true, "font_size": 31, "lines_coords": [[[932.0, 784.0], [959.0, 784.0], [956.0, 943.0], [929.0, 943.0]]], "lines": ["天体望遠鏡！"]}, {"box": [803, 906, 871, 1015], "vertical": true, "font_size": 31, "lines_coords": [[[832.0, 906.0], [871.0, 906.0], [871.0, 998.0], [832.0, 998.0]], [[803.0, 910.0], [829.0, 910.0], [829.0, 1015.0], [803.0, 1015.0]]], "lines": ["すげー", "だろぉ？"]}, {"box": [254, 804, 315, 964], "vertical": true, "font_size": 27, "lines_coords": [[[289.0, 804.0], [315.0, 804.0], [315.0, 964.0], [289.0, 964.0]], [[254.0, 806.0], [281.0, 806.0], [281.0, 910.0], [254.0, 910.0]]], "lines": ["今日たまたま、", "スロッ．．．"]}, {"box": [154, 915, 218, 1084], "vertical": true, "font_size": 27, "lines_coords": [[[185.0, 915.0], [218.0, 915.0], [218.0, 1001.0], [185.0, 1001.0]], [[154.0, 920.0], [176.0, 920.0], [176.0, 1084.0], [154.0, 1084.0]]], "lines": ["友達に", "もらったんだ。"]}, {"box": [889, 1176, 984, 1337], "vertical": true, "font_size": 25, "lines_coords": [[[962.0, 1179.0], [984.0, 1179.0], [984.0, 1285.0], [962.0, 1285.0]], [[921.0, 1176.0], [953.0, 1176.0], [953.0, 1337.0], [921.0, 1337.0]], [[889.0, 1179.0], [915.0, 1179.0], [915.0, 1320.0], [889.0, 1320.0]]], "lines": ["これなら", "どんな遠くの", "ものだって、"]}, {"box": [775, 1339, 871, 1521], "vertical": true, "font_size": 25, "lines_coords": [[[842.0, 1339.0], [870.0, 1339.0], [871.0, 1448.0], [843.0, 1448.0]], [[810.0, 1342.0], [832.0, 1342.0], [832.0, 1496.0], [810.0, 1496.0]], [[775.0, 1342.0], [795.0, 1342.0], [795.0, 1521.0], [775.0, 1521.0]]], "lines": ["手にとる", "ように近くに", "見えるんだぞ？"]}], "img_path": "023.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [873, 115, 970, 325], "vertical": true, "font_size": 27, "lines_coords": [[[948.0, 118.0], [970.0, 118.0], [970.0, 273.0], [948.0, 273.0]], [[909.0, 115.0], [935.0, 115.0], [935.0, 300.0], [909.0, 300.0]], [[873.0, 115.0], [900.0, 115.0], [900.0, 325.0], [873.0, 325.0]]], "lines": ["今の時期だと", "東の空に大きな", "三角があるだろ？"]}, {"box": [254, 154, 353, 337], "vertical": true, "font_size": 26, "lines_coords": [[[326.0, 154.0], [353.0, 154.0], [350.0, 337.0], [323.0, 337.0]], [[289.0, 156.0], [315.0, 156.0], [315.0, 312.0], [289.0, 312.0]], [[254.0, 157.0], [276.0, 157.0], [276.0, 315.0], [254.0, 315.0]]], "lines": ["べガは地球から", "２７光年離れた", "所にあってな"]}, {"box": [764, 332, 868, 514], "vertical": true, "font_size": 27, "lines_coords": [[[842.0, 335.0], [868.0, 335.0], [868.0, 514.0], [842.0, 514.0]], [[803.0, 332.0], [834.0, 332.0], [834.0, 514.0], [803.0, 514.0]], [[768.0, 332.0], [800.0, 332.0], [795.0, 498.0], [764.0, 498.0]]], "lines": ["一番上に見える", "のが、こと座の", "べガって星だ。"]}, {"box": [142, 392, 279, 603], "vertical": true, "font_size": 26, "lines_coords": [[[251.0, 395.0], [279.0, 395.0], [279.0, 507.0], [251.0, 507.0]], [[214.0, 392.0], [245.0, 392.0], [245.0, 603.0], [214.0, 603.0]], [[179.0, 395.0], [206.0, 395.0], [206.0, 550.0], [179.0, 550.0]], [[142.0, 395.0], [165.0, 395.0], [168.0, 534.0], [145.0, 534.0]]], "lines": ["つまり今、", "プンプンが見てる", "光は２７年前の", "光なんだよ。"]}, {"box": [904, 1104, 968, 1289], "vertical": true, "font_size": 26, "lines_coords": [[[942.0, 1107.0], [968.0, 1107.0], [968.0, 1289.0], [942.0, 1289.0]], [[906.0, 1104.0], [934.0, 1104.0], [934.0, 1160.0], [906.0, 1160.0]], [[904.0, 1154.0], [931.0, 1154.0], [931.0, 1265.0], [904.0, 1265.0]]], "lines": ["やっぱり男なら", "ドー", "ーーンと"]}, {"box": [835, 1106, 893, 1287], "vertical": true, "font_size": 26, "lines_coords": [[[867.0, 1106.0], [893.0, 1106.0], [893.0, 1264.0], [867.0, 1264.0]], [[835.0, 1107.0], [857.0, 1107.0], [857.0, 1287.0], [835.0, 1287.0]]], "lines": ["てかいもんを", "見据えなきゃ！！"]}, {"box": [256, 728, 353, 907], "vertical": true, "font_size": 23, "lines_coords": [[[325.0, 729.0], [353.0, 729.0], [353.0, 834.0], [325.0, 834.0]], [[292.0, 729.0], [314.0, 729.0], [314.0, 884.0], [292.0, 884.0]], [[256.0, 728.0], [278.0, 728.0], [278.0, 907.0], [256.0, 907.0]]], "lines": ["．．．．．．ん？", "これで練馬は", "見えるかって？"]}, {"box": [159, 871, 214, 1037], "vertical": true, "font_size": 23, "lines_coords": [[[189.0, 871.0], [210.0, 871.0], [214.0, 1037.0], [192.0, 1037.0]], [[159.0, 873.0], [181.0, 873.0], [181.0, 1037.0], [159.0, 1037.0]]], "lines": ["緑馬はちょっと", "近すぎるかな．．．"]}, {"box": [220, 1118, 356, 1276], "vertical": true, "font_size": 30, "lines_coords": [[[329.0, 1118.0], [356.0, 1118.0], [356.0, 1250.0], [329.0, 1250.0]], [[292.0, 1120.0], [318.0, 1120.0], [318.0, 1276.0], [292.0, 1276.0]], [[254.0, 1121.0], [284.0, 1121.0], [284.0, 1276.0], [254.0, 1276.0]], [[220.0, 1120.0], [246.0, 1120.0], [246.0, 1225.0], [220.0, 1225.0]]], "lines": ["宇宙なんて", "俺の人生には", "一生関係ない", "けどな！！"]}, {"box": [106, 1310, 228, 1532], "vertical": true, "font_size": 30, "lines_coords": [[[190.0, 1310.0], [228.0, 1310.0], [228.0, 1478.0], [190.0, 1478.0]], [[150.0, 1314.0], [182.0, 1314.0], [182.0, 1532.0], [150.0, 1532.0]], [[106.0, 1310.0], [134.0, 1310.0], [135.0, 1470.0], [107.0, 1470.0]]], "lines": ["夢っつーか、", "ロマンってのが", "あるよね！！"]}], "img_path": "024.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [223, 475, 290, 669], "vertical": true, "font_size": 28, "lines_coords": [[[260.0, 475.0], [289.0, 475.0], [289.0, 607.0], [260.0, 607.0]], [[225.0, 475.0], [251.0, 475.0], [250.0, 668.0], [223.0, 668.0]]], "lines": ["プンプンは", "ピンときました。"]}, {"box": [517, 818, 618, 1028], "vertical": true, "font_size": 28, "lines_coords": [[[589.0, 818.0], [617.0, 818.0], [617.0, 918.0], [589.0, 918.0]], [[551.0, 818.0], [582.0, 818.0], [582.0, 1006.0], [551.0, 1006.0]], [[517.0, 818.0], [543.0, 818.0], [543.0, 1026.0], [517.0, 1026.0]]], "lines": ["「そうだ、", "僕は宇宙を研究", "する人になろう。」"]}, {"box": [890, 1079, 992, 1302], "vertical": true, "font_size": 30, "lines_coords": [[[962.0, 1079.0], [989.0, 1079.0], [989.0, 1298.0], [962.0, 1298.0]], [[926.0, 1081.0], [957.0, 1081.0], [957.0, 1239.0], [926.0, 1239.0]], [[890.0, 1079.0], [923.0, 1079.0], [923.0, 1187.0], [890.0, 1187.0]]], "lines": ["「いっぱい勉強して", "宇宙の学者に", "なって、」"]}, {"box": [228, 1118, 290, 1287], "vertical": true, "font_size": 40, "lines_coords": [[[228.0, 1125.0], [267.0, 1118.0], [290.0, 1281.0], [251.0, 1287.0]]], "lines": ["なったじっス"]}, {"box": [154, 1364, 295, 1548], "vertical": true, "font_size": 28, "lines_coords": [[[262.0, 1364.0], [295.0, 1364.0], [295.0, 1459.0], [262.0, 1459.0]], [[228.0, 1367.0], [254.0, 1367.0], [254.0, 1548.0], [228.0, 1548.0]], [[192.0, 1365.0], [218.0, 1365.0], [215.0, 1520.0], [189.0, 1520.0]], [[157.0, 1365.0], [185.0, 1365.0], [182.0, 1481.0], [154.0, 1481.0]]], "lines": ["「人類が", "宇宙にイジュー", "できるように", "しょう！！」"]}, {"box": [451, 1209, 493, 1284], "vertical": true, "font_size": 34, "lines_coords": [[[451.0, 1212.0], [485.0, 1209.0], [493.0, 1281.0], [459.0, 1284.0]]], "lines": ["はっ"]}, {"box": [517, 1420, 562, 1521], "vertical": true, "font_size": 30, "lines_coords": [[[517.0, 1425.0], [546.0, 1420.0], [562.0, 1517.0], [532.0, 1521.0]]], "lines": ["でもー"]}, {"box": [757, 1171, 837, 1329], "vertical": false, "font_size": 33, "lines_coords": [[[789.0, 1171.0], [837.0, 1320.0], [806.0, 1329.0], [757.0, 1181.0]]], "lines": ["あああのよの"]}], "img_path": "025.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [884, 48, 994, 250], "vertical": true, "font_size": 34, "lines_coords": [[[965.0, 54.0], [992.0, 54.0], [992.0, 250.0], [965.0, 250.0]], [[926.0, 50.0], [957.0, 50.0], [954.0, 237.0], [923.0, 237.0]], [[884.0, 48.0], [928.0, 48.0], [928.0, 117.0], [884.0, 117.0]]], "lines": ["「それはなんだか", "すごく格好いい", "そ。」"]}, {"box": [90, 87, 212, 270], "vertical": true, "font_size": 26, "lines_coords": [[[181.0, 87.0], [209.0, 87.0], [209.0, 204.0], [181.0, 204.0]], [[150.0, 87.0], [176.0, 87.0], [176.0, 270.0], [150.0, 270.0]], [[118.0, 87.0], [145.0, 87.0], [145.0, 218.0], [118.0, 218.0]], [[90.0, 87.0], [112.0, 87.0], [112.0, 217.0], [90.0, 217.0]]], "lines": ["プンプン、", "宿題はちゃんと", "やったんで", "しょうね？"]}, {"box": [115, 434, 148, 616], "vertical": true, "font_size": 28, "lines_coords": [[[118.0, 434.0], [146.0, 434.0], [143.0, 615.0], [115.0, 615.0]]], "lines": ["「そうしたら．．．」"]}, {"box": [773, 745, 842, 920], "vertical": true, "font_size": 34, "lines_coords": [[[810.0, 745.0], [842.0, 745.0], [842.0, 920.0], [810.0, 920.0]], [[773.0, 754.0], [809.0, 754.0], [809.0, 820.0], [773.0, 820.0]]], "lines": ["「もしかしたら", "．．．"]}, {"box": [481, 1275, 650, 1563], "vertical": true, "font_size": 32, "lines_coords": [[[614.0, 1278.0], [645.0, 1278.0], [648.0, 1482.0], [617.0, 1482.0]], [[571.0, 1276.0], [603.0, 1276.0], [603.0, 1437.0], [571.0, 1437.0]], [[525.0, 1276.0], [556.0, 1276.0], [556.0, 1562.0], [525.0, 1562.0]], [[482.0, 1278.0], [514.0, 1278.0], [514.0, 1517.0], [482.0, 1517.0]]], "lines": ["「愛子ちゃんが", "僕のことを", "好きになってくれる", "かもしれない！！」"]}], "img_path": "026.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [745, 51, 793, 145], "vertical": false, "font_size": 24, "lines_coords": [[[768.0, 51.0], [793.0, 139.0], [770.0, 145.0], [745.0, 57.0]]], "lines": ["クレジットが"]}], "img_path": "027.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [90, 51, 321, 81], "vertical": false, "font_size": 28, "lines_coords": [[[90.0, 53.0], [321.0, 51.0], [321.0, 79.0], [90.0, 81.0]]], "lines": ["おやすみプンプ、"]}, {"box": [900, 752, 931, 893], "vertical": true, "font_size": 28, "lines_coords": [[[900.0, 753.0], [928.0, 753.0], [928.0, 887.0], [900.0, 887.0]]], "lines": ["．．．プンプン"]}, {"box": [210, 868, 238, 1000], "vertical": true, "font_size": 27, "lines_coords": [[[210.0, 868.0], [237.0, 868.0], [237.0, 1000.0], [210.0, 1000.0]]], "lines": ["大変だ．．．"]}, {"box": [246, 1167, 282, 1373], "vertical": true, "font_size": 32, "lines_coords": [[[246.0, 1167.0], [278.0, 1167.0], [278.0, 1371.0], [246.0, 1371.0]]], "lines": ["強盗が入った。"]}], "img_path": "028.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [880, 487, 928, 864], "vertical": true, "font_size": 30, "lines_coords": [[[885.0, 706.0], [918.0, 706.0], [918.0, 864.0], [885.0, 864.0]], [[881.0, 487.0], [907.0, 487.0], [907.0, 618.0], [881.0, 618.0]]], "lines": ["本当だよ？", "プンプン．．．"]}, {"box": [168, 756, 246, 971], "vertical": true, "font_size": 32, "lines_coords": [[[212.0, 756.0], [243.0, 756.0], [243.0, 945.0], [212.0, 945.0]], [[168.0, 756.0], [200.0, 756.0], [200.0, 971.0], [168.0, 971.0]]], "lines": ["本当に強盗が", "入ったんだよ？"]}, {"box": [195, 1214, 317, 1387], "vertical": true, "font_size": 34, "lines_coords": [[[278.0, 1215.0], [317.0, 1215.0], [317.0, 1318.0], [278.0, 1318.0]], [[234.0, 1214.0], [267.0, 1214.0], [270.0, 1382.0], [237.0, 1382.0]], [[195.0, 1217.0], [226.0, 1217.0], [226.0, 1378.0], [195.0, 1378.0]]], "lines": ["信じて", "くれるよね、", "プンプン！！"]}], "img_path": "029.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "030.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "031.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [489, 123, 628, 334], "vertical": true, "font_size": 30, "lines_coords": [[[595.0, 125.0], [628.0, 125.0], [628.0, 209.0], [595.0, 209.0]], [[559.0, 123.0], [590.0, 123.0], [590.0, 334.0], [559.0, 334.0]], [[521.0, 125.0], [553.0, 125.0], [553.0, 282.0], [521.0, 282.0]], [[490.0, 125.0], [514.0, 125.0], [512.0, 287.0], [489.0, 287.0]]], "lines": ["その日、", "結局、プンプンは", "学校に行けず", "じまいでした。"]}, {"box": [40, 293, 84, 451], "vertical": true, "font_size": 39, "lines_coords": [[[43.0, 293.0], [82.0, 293.0], [79.0, 451.0], [40.0, 451.0]]], "lines": ["第２話"]}, {"box": [801, 1117, 975, 1326], "vertical": true, "font_size": 28, "lines_coords": [[[946.0, 1120.0], [973.0, 1120.0], [973.0, 1276.0], [946.0, 1276.0]], [[910.0, 1117.0], [939.0, 1117.0], [935.0, 1312.0], [907.0, 1312.0]], [[875.0, 1118.0], [903.0, 1118.0], [898.0, 1326.0], [870.0, 1326.0]], [[839.0, 1117.0], [867.0, 1117.0], [864.0, 1301.0], [835.0, 1301.0]], [[801.0, 1118.0], [828.0, 1118.0], [828.0, 1284.0], [801.0, 1284.0]]], "lines": ["夕方近くまで", "お巡りさん達に、", "お父さんのことを", "たくさん何度も", "聞かれました。"]}, {"box": [192, 1337, 230, 1528], "vertical": true, "font_size": 33, "lines_coords": [[[195.0, 1337.0], [228.0, 1337.0], [225.0, 1528.0], [192.0, 1528.0]]], "lines": ["．．．プンプン！"]}], "img_path": "032.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [840, 134, 907, 307], "vertical"