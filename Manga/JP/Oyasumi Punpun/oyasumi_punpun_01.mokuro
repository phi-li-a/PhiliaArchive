.0, 1012.0], [990.0, 1193.0], [964.0, 1193.0]], [[926.0, 1012.0], [953.0, 1012.0], [953.0, 1181.0], [926.0, 1181.0]], [[887.0, 1010.0], [920.0, 1010.0], [920.0, 1118.0], [887.0, 1118.0]]], "lines": ["．．．．．今", "リモコンに手を", "かけた、そこの", "少年．．．"]}, {"box": [651, 1282, 755, 1490], "vertical": true, "font_size": 27, "lines_coords": [[[728.0, 1282.0], [754.0, 1282.0], [754.0, 1440.0], [728.0, 1440.0]], [[690.0, 1284.0], [717.0, 1284.0], [717.0, 1490.0], [690.0, 1490.0]], [[654.0, 1282.0], [682.0, 1282.0], [679.0, 1443.0], [651.0, 1443.0]]], "lines": ["早送りせずに", "少しだけ僕の話を", "聞いてくれ．．．"]}, {"box": [250, 1218, 385, 1418], "vertical": true, "font_size": 27, "lines_coords": [[[353.0, 1218.0], [385.0, 1218.0], [385.0, 1326.0], [353.0, 1326.0]], [[321.0, 1220.0], [348.0, 1220.0], [348.0, 1404.0], [321.0, 1404.0]], [[282.0, 1218.0], [314.0, 1218.0], [314.0, 1418.0], [282.0, 1418.0]], [[250.0, 1218.0], [271.0, 1218.0], [271.0, 1376.0], [250.0, 1376.0]]], "lines": ["君がこの", "ビデオを拾った", "のは、ただの偶然", "ではない．．．"]}, {"box": [92, 1367, 228, 1526], "vertical": true, "font_size": 27, "lines_coords": [[[201.0, 1367.0], [228.0, 1367.0], [228.0, 1526.0], [201.0, 1526.0]], [[165.0, 1367.0], [192.0, 1367.0], [192.0, 1521.0], [165.0, 1521.0]], [[128.0, 1367.0], [154.0, 1367.0], [154.0, 1496.0], [128.0, 1496.0]], [[92.0, 1367.0], [118.0, 1367.0], [118.0, 1481.0], [92.0, 1481.0]]], "lines": ["これは運命だ", "君は最後まで", "見る義務が", "あるんだ。"]}], "img_path": "145.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [918, 129, 947, 261], "vertical": true, "font_size": 27, "lines_coords": [[[918.0, 129.0], [945.0, 129.0], [945.0, 260.0], [918.0, 260.0]]], "lines": ["僕は今．．．"]}, {"box": [527, 414, 628, 625], "vertical": true, "font_size": 25, "lines_coords": [[[600.0, 417.0], [626.0, 417.0], [626.0, 548.0], [600.0, 548.0]], [[562.0, 414.0], [589.0, 414.0], [589.0, 625.0], [562.0, 625.0]], [[528.0, 418.0], [550.0, 418.0], [550.0, 575.0], [528.0, 575.0]]], "lines": ["君に重大な", "告白をしなければ", "ならない．．．．．"]}, {"box": [871, 843, 900, 950], "vertical": true, "font_size": 29, "lines_coords": [[[871.0, 843.0], [900.0, 843.0], [900.0, 950.0], [871.0, 950.0]]], "lines": ["僕は．．．"]}, {"box": [218, 975, 328, 1085], "vertical": true, "font_size": 35, "lines_coords": [[[289.0, 975.0], [328.0, 975.0], [328.0, 1062.0], [289.0, 1062.0]], [[254.0, 976.0], [287.0, 976.0], [287.0, 1085.0], [254.0, 1085.0]], [[218.0, 976.0], [251.0, 976.0], [251.0, 1071.0], [218.0, 1071.0]]], "lines": ["家族を", "この手で", "殺した。"]}, {"box": [857, 1275, 965, 1514], "vertical": true, "font_size": 31, "lines_coords": [[[926.0, 1275.0], [965.0, 1275.0], [965.0, 1362.0], [926.0, 1362.0]], [[893.0, 1278.0], [920.0, 1278.0], [920.0, 1514.0], [893.0, 1514.0]], [[857.0, 1275.0], [885.0, 1275.0], [887.0, 1462.0], [859.0, 1462.0]]], "lines": ["決して", "家庭に不満があった", "訳じゃない．．．"]}, {"box": [131, 1354, 267, 1565], "vertical": true, "font_size": 26, "lines_coords": [[[237.0, 1354.0], [264.0, 1354.0], [264.0, 1512.0], [237.0, 1512.0]], [[201.0, 1354.0], [228.0, 1354.0], [228.0, 1539.0], [201.0, 1539.0]], [[164.0, 1356.0], [190.0, 1356.0], [190.0, 1565.0], [164.0, 1565.0]], [[131.0, 1368.0], [156.0, 1368.0], [156.0, 1409.0], [131.0, 1409.0]]], "lines": ["いや、むしろ", "感謝していたと", "言っていいだろう", "．．．"]}], "img_path": "146.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [862, 103, 996, 315], "vertical": true, "font_size": 26, "lines_coords": [[[968.0, 103.0], [995.0, 103.0], [996.0, 315.0], [970.0, 315.0]], [[934.0, 104.0], [960.0, 104.0], [960.0, 248.0], [934.0, 248.0]], [[896.0, 104.0], [923.0, 104.0], [923.0, 314.0], [896.0, 314.0]], [[862.0, 106.0], [884.0, 106.0], [884.0, 245.0], [862.0, 245.0]]], "lines": ["父は人生の大半を", "勤労に捧げ、", "母は子供の教育に", "努め続けた。"]}, {"box": [793, 310, 859, 470], "vertical": true, "font_size": 26, "lines_coords": [[[829.0, 310.0], [857.0, 310.0], [859.0, 420.0], [831.0, 420.0]], [[793.0, 312.0], [820.0, 312.0], [820.0, 470.0], [793.0, 470.0]]], "lines": ["姉は来月", "公務員の男と"]}, {"box": [758, 312, 858, 468], "vertical": true, "font_size": 26, "lines_coords": [[[759.0, 312.0], [785.0, 312.0], [785.0, 428.0], [759.0, 428.0]]], "lines": ["結婚する。"]}, {"box": [201, 171, 267, 345], "vertical": true, "font_size": 27, "lines_coords": [[[235.0, 171.0], [267.0, 171.0], [267.0, 335.0], [235.0, 335.0]], [[201.0, 175.0], [228.0, 175.0], [228.0, 345.0], [201.0, 345.0]]], "lines": ["．．．でも、よく", "考えてほしい。"]}, {"box": [107, 400, 242, 637], "vertical": true, "font_size": 27, "lines_coords": [[[215.0, 403.0], [242.0, 403.0], [240.0, 637.0], [214.0, 637.0]], [[178.0, 401.0], [204.0, 401.0], [204.0, 585.0], [178.0, 585.0]], [[142.0, 400.0], [168.0, 400.0], [168.0, 625.0], [142.0, 625.0]], [[107.0, 404.0], [129.0, 404.0], [129.0, 626.0], [107.0, 626.0]]], "lines": ["一見、何不自由ない", "幸福な家庭だが", "そんな幸せっただの", "ハリボテじゃないか。"]}, {"box": [871, 735, 975, 881], "vertical": true, "font_size": 30, "lines_coords": [[[946.0, 737.0], [973.0, 737.0], [973.0, 878.0], [946.0, 878.0]], [[906.0, 735.0], [939.0, 735.0], [939.0, 881.0], [906.0, 881.0]], [[871.0, 737.0], [900.0, 737.0], [900.0, 840.0], [871.0, 840.0]]], "lines": ["病気、事故、", "天災、人災、", "裏切りー"]}, {"box": [906, 1083, 1006, 1266], "vertical": true, "font_size": 23, "lines_coords": [[[981.0, 1085.0], [1003.0, 1085.0], [1003.0, 1214.0], [981.0, 1214.0]], [[945.0, 1085.0], [967.0, 1085.0], [967.0, 1264.0], [945.0, 1264.0]], [[906.0, 1084.0], [932.0, 1084.0], [932.0, 1223.0], [906.0, 1223.0]]], "lines": ["定年間際に", "親父は僕にこう", "言ったんだ。"]}, {"box": [142, 803, 281, 1014], "vertical": true, "font_size": 28, "lines_coords": [[[253.0, 804.0], [279.0, 804.0], [279.0, 989.0], [253.0, 989.0]], [[215.0, 804.0], [243.0, 804.0], [242.0, 1014.0], [214.0, 1014.0]], [[178.0, 803.0], [209.0, 803.0], [209.0, 1014.0], [178.0, 1014.0]], [[145.0, 803.0], [171.0, 803.0], [168.0, 970.0], [142.0, 970.0]]], "lines": ["不幸のカードを", "いつ引くかなんて", "それこそ神のみぞ", "知る、なんだ。"]}, {"box": [489, 1128, 589, 1312], "vertical": true, "font_size": 26, "lines_coords": [[[562.0, 1128.0], [589.0, 1128.0], [589.0, 1275.0], [562.0, 1275.0]], [[525.0, 1129.0], [551.0, 1129.0], [551.0, 1287.0], [525.0, 1287.0]], [[489.0, 1131.0], [515.0, 1131.0], [515.0, 1312.0], [489.0, 1312.0]]], "lines": ["「これからは", "第二の人生を", "楽しむぞ」って。"]}, {"box": [448, 1342, 545, 1551], "vertical": true, "font_size": 26, "lines_coords": [[[518.0, 1342.0], [545.0, 1342.0], [545.0, 1484.0], [518.0, 1484.0]], [[481.0, 1343.0], [507.0, 1343.0], [507.0, 1551.0], [481.0, 1551.0]], [[448.0, 1345.0], [470.0, 1345.0], [470.0, 1503.0], [448.0, 1503.0]]], "lines": ["彼はその後、", "癌に冒されていた", "のを知ったよ。"]}, {"box": [92, 1259, 285, 1523], "vertical": true, "font_size": 26, "lines_coords": [[[257.0, 1260.0], [284.0, 1260.0], [284.0, 1523.0], [257.0, 1523.0]], [[225.0, 1260.0], [251.0, 1260.0], [251.0, 1496.0], [225.0, 1496.0]], [[193.0, 1262.0], [215.0, 1262.0], [215.0, 1495.0], [193.0, 1495.0]], [[157.0, 1260.0], [184.0, 1260.0], [184.0, 1496.0], [157.0, 1496.0]], [[125.0, 1259.0], [151.0, 1259.0], [151.0, 1496.0], [125.0, 1496.0]], [[92.0, 1259.0], [118.0, 1259.0], [118.0, 1445.0], [92.0, 1445.0]]], "lines": ["いつ振り落とされるか", "わからない、小さな", "幸せや希望に必死に", "しがみつこうとする", "その姿は、果たして", "幸せな姿かね！？"]}], "img_path": "147.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [907, 100, 1008, 259], "vertical": true, "font_size": 27, "lines_coords": [[[979.0, 101.0], [1006.0, 101.0], [1006.0, 232.0], [979.0, 232.0]], [[943.0, 100.0], [971.0, 100.0], [968.0, 232.0], [940.0, 232.0]], [[907.0, 103.0], [934.0, 103.0], [934.0, 259.0], [907.0, 259.0]]], "lines": ["．．．僕はもう", "見てられな", "かったんだ．．．"]}, {"box": [89, 57, 376, 84], "vertical": false, "font_size": 27, "lines_coords": [[[89.0, 57.0], [376.0, 57.0], [376.0, 84.0], [89.0, 84.0]]], "lines": ["おやすみプンプン［"]}, {"box": [693, 415, 789, 601], "vertical": true, "font_size": 25, "lines_coords": [[[760.0, 415.0], [787.0, 415.0], [787.0, 600.0], [760.0, 600.0]], [[726.0, 417.0], [750.0, 417.0], [748.0, 600.0], [725.0, 600.0]], [[693.0, 431.0], [717.0, 431.0], [717.0, 471.0], [693.0, 471.0]]], "lines": ["とにかく全てが", "悲しかったんだ", "．．．"]}, {"box": [140, 457, 212, 576], "vertical": true, "font_size": 31, "lines_coords": [[[179.0, 459.0], [207.0, 459.0], [210.0, 576.0], [182.0, 576.0]], [[143.0, 457.0], [176.0, 459.0], [173.0, 550.0], [140.0, 548.0]]], "lines": ["．．．だから、", "殺した。"]}, {"box": [852, 784, 915, 928], "vertical": true, "font_size": 26, "lines_coords": [[[889.0, 787.0], [915.0, 787.0], [915.0, 892.0], [889.0, 892.0]], [[853.0, 785.0], [879.0, 785.0], [879.0, 925.0], [853.0, 925.0]]], "lines": ["．．．これは", "魂の解放だ。"]}, {"box": [290, 765, 323, 859], "vertical": true, "font_size": 32, "lines_coords": [[[290.0, 765.0], [323.0, 765.0], [323.0, 859.0], [290.0, 859.0]]], "lines": ["：僕は、"]}, {"box": [181, 953, 281, 1089], "vertical": true, "font_size": 32, "lines_coords": [[[253.0, 957.0], [281.0, 957.0], [281.0, 1089.0], [253.0, 1089.0]], [[210.0, 953.0], [250.0, 953.0], [250.0, 1040.0], [210.0, 1040.0]], [[181.0, 956.0], [207.0, 956.0], [207.0, 1073.0], [181.0, 1073.0]]], "lines": ["この行動を", "愛だと", "言いたい。"]}, {"box": [909, 1308, 937, 1441], "vertical": true, "font_size": 26, "lines_coords": [[[909.0, 1309.0], [935.0, 1309.0], [935.0, 1439.0], [909.0, 1439.0]]], "lines": ["．．．なのに．．．"]}, {"box": [109, 1379, 178, 1515], "vertical": true, "font_size": 32, "lines_coords": [[[139.0, 1379.0], [178.0, 1379.0], [178.0, 1468.0], [139.0, 1468.0]], [[109.0, 1382.0], [135.0, 1382.0], [135.0, 1514.0], [109.0, 1514.0]]], "lines": ["．．．それ", "なのに．．．"]}], "img_path": "148.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [928, 110, 994, 270], "vertical": true, "font_size": 26, "lines_coords": [[[967.0, 114.0], [993.0, 114.0], [993.0, 256.0], [967.0, 256.0]], [[931.0, 110.0], [957.0, 110.0], [954.0, 270.0], [928.0, 270.0]]], "lines": ["毎晩、夢枕に", "立つんだ．．．"]}, {"box": [570, 292, 598, 396], "vertical": true, "font_size": 27, "lines_coords": [[[570.0, 292.0], [598.0, 292.0], [598.0, 396.0], [570.0, 396.0]]], "lines": ["親父が．．"]}, {"box": [173, 312, 240, 471], "vertical": true, "font_size": 27, "lines_coords": [[[206.0, 312.0], [237.0, 312.0], [240.0, 471.0], [209.0, 471.0]], [[173.0, 314.0], [200.0, 314.0], [200.0, 418.0], [173.0, 418.0]]], "lines": ["僕は間違って", "たのか？"]}, {"box": [901, 681, 965, 839], "vertical": true, "font_size": 28, "lines_coords": [[[904.0, 681.0], [932.0, 681.0], [929.0, 839.0], [901.0, 839.0]]], "lines": ["わからない．．．"]}, {"box": [503, 454, 603, 617], "vertical": true, "font_size": 27, "lines_coords": [[[571.0, 454.0], [603.0, 454.0], [603.0, 617.0], [571.0, 617.0]], [[537.0, 456.0], [564.0, 456.0], [564.0, 615.0], [537.0, 615.0]], [[503.0, 459.0], [525.0, 459.0], [525.0, 614.0], [503.0, 614.0]]], "lines": ["悲しげな顔で", "じっと、僕を", "見てるんだ．．．"]}, {"box": [131, 495, 192, 626], "vertical": true, "font_size": 27, "lines_coords": [[[165.0, 495.0], [192.0, 495.0], [192.0, 603.0], [165.0, 603.0]], [[131.0, 500.0], [153.0, 500.0], [153.0, 626.0], [131.0, 626.0]]], "lines": ["それとも", "罪悪感．．．？"]}, {"box": [257, 689, 279, 826], "vertical": true, "font_size": 24, "lines_coords": [[[257.0, 689.0], [279.0, 689.0], [279.0, 826.0], [257.0, 826.0]]], "lines": ["この気持ち、"]}, {"box": [910, 942, 1004, 1337], "vertical": true, "font_size": 29, "lines_coords": [[[910.0, 1232.0], [937.0, 1232.0], [937.0, 1337.0], [910.0, 1337.0]], [[978.0, 942.0], [1004.0, 942.0], [1004.0, 1073.0], [978.0, 1073.0]]], "lines": ["ーっ♪", "．．．アイッ！！"]}, {"box": [415, 1081, 552, 1309], "vertical": true, "font_size": 29, "lines_coords": [[[525.0, 1081.0], [551.0, 1081.0], [551.0, 1309.0], [525.0, 1309.0]], [[487.0, 1103.0], [520.0, 1103.0], [520.0, 1262.0], [487.0, 1262.0]], [[454.0, 1106.0], [481.0, 1106.0], [481.0, 1264.0], [454.0, 1264.0]], [[415.0, 1107.0], [445.0, 1107.0], [445.0, 1159.0], [415.0, 1159.0]], [[418.0, 1156.0], [445.0, 1156.0], [445.0, 1265.0], [418.0, 1265.0]]], "lines": ["へわっからっないっ", "たーーーらっ", "わっからっな", "いー", "ーっ♪"]}, {"box": [125, 762, 225, 935], "vertical": true, "font_size": 24, "lines_coords": [[[198.0, 762.0], [225.0, 762.0], [225.0, 898.0], [198.0, 898.0]], [[160.0, 764.0], [187.0, 764.0], [187.0, 925.0], [160.0, 925.0]], [[125.0, 767.0], [146.0, 767.0], [146.0, 935.0], [125.0, 935.0]]], "lines": ["僕はあえて", "ダンスで表現", "したいと思う．．．"]}, {"box": [910, 1153, 1048, 1340], "vertical": true, "font_size": 29, "lines_coords": [[[1017.0, 1153.0], [1048.0, 1153.0], [1048.0, 1339.0], [1017.0, 1339.0]], [[976.0, 1173.0], [1014.0, 1173.0], [1014.0, 1340.0], [976.0, 1340.0]], [[946.0, 1179.0], [973.0, 1179.0], [973.0, 1337.0], [946.0, 1337.0]], [[910.0, 1181.0], [934.0, 1181.0], [934.0, 1226.0], [910.0, 1226.0]]], "lines": ["へわっからっな", "いーーっ♪", "わっからっな", "いー"]}], "img_path": "149.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [931, 125, 998, 285], "vertical": true, "font_size": 28, "lines_coords": [[[971.0, 128.0], [998.0, 128.0], [998.0, 284.0], [971.0, 284.0]], [[931.0, 125.0], [965.0, 125.0], [965.0, 189.0], [931.0, 189.0]], [[935.0, 175.0], [962.0, 175.0], [962.0, 285.0], [935.0, 285.0]]], "lines": ["わっからっな", "いー", "ーっ♪"]}, {"box": [860, 128, 925, 285], "vertical": true, "font_size": 28, "lines_coords": [[[898.0, 128.0], [925.0, 128.0], [925.0, 285.0], [898.0, 285.0]], [[860.0, 128.0], [890.0, 128.0], [890.0, 178.0], [860.0, 178.0]]], "lines": ["わっからっな", "いー"]}, {"box": [865, 206, 887, 282], "vertical": true, "font_size": 28, "lines_coords": [[[865.0, 206.0], [887.0, 206.0], [887.0, 282.0], [865.0, 282.0]]], "lines": ["ーっ♪"]}, {"box": [73, 214, 221, 381], "vertical": true, "font_size": 28, "lines_coords": [[[195.0, 223.0], [221.0, 223.0], [221.0, 381.0], [195.0, 381.0]], [[154.0, 221.0], [187.0, 221.0], [187.0, 323.0], [154.0, 323.0]], [[120.0, 223.0], [146.0, 223.0], [146.0, 381.0], [120.0, 381.0]], [[82.0, 214.0], [120.0, 221.0], [110.0, 270.0], [73.0, 262.0]]], "lines": ["わっからっな", "いったー", "わっからっな", "いー"]}, {"box": [89, 278, 181, 404], "vertical": true, "font_size": 28, "lines_coords": [[[89.0, 278.0], [110.0, 278.0], [110.0, 379.0], [89.0, 379.0]], [[157.0, 343.0], [181.0, 343.0], [181.0, 404.0], [157.0, 404.0]]], "lines": ["ーっ♪", "ーら"]}, {"box": [892, 708, 923, 866], "vertical": true, "font_size": 26, "lines_coords": [[[895.0, 742.0], [921.0, 742.0], [921.0, 865.0], [895.0, 865.0]]], "lines": ["．．．って！！"]}, {"box": [932, 998, 1007, 1081], "vertical": true, "font_size": 75, "lines_coords": [[[932.0, 998.0], [1007.0, 998.0], [1007.0, 1081.0], [932.0, 1081.0]]], "lines": ["！！"]}, {"box": [171, 742, 295, 964], "vertical": true, "font_size": 33, "lines_coords": [[[262.0, 746.0], [295.0, 746.0], [295.0, 873.0], [262.0, 873.0]], [[215.0, 742.0], [248.0, 742.0], [251.0, 964.0], [218.0, 964.0]], [[171.0, 743.0], [204.0, 743.0], [207.0, 903.0], [175.0, 903.0]]], "lines": ["つられて", "おどってんじゃ", "ないよっ！！"]}, {"box": [830, 1308, 930, 1465], "vertical": true, "font_size": 26, "lines_coords": [[[901.0, 1309.0], [929.0, 1309.0], [929.0, 1414.0], [901.0, 1414.0]], [[865.0, 1309.0], [893.0, 1309.0], [893.0, 1415.0], [865.0, 1415.0]], [[832.0, 1310.0], [854.0, 1310.0], [854.0, 1465.0], [832.0, 1465.0]]], "lines": ["とにかく", "僕はもう", "限界なんだ．．．"]}, {"box": [429, 1421, 607, 1543], "vertical": false, "font_size": 17.75, "lines_coords": [[[429.0, 1482.0], [548.0, 1421.0], [556.0, 1435.0], [437.0, 1496.0]], [[442.0, 1496.0], [579.0, 1423.0], [589.0, 1440.0], [451.0, 1514.0]], [[457.0, 1512.0], [600.0, 1437.0], [607.0, 1453.0], [465.0, 1528.0]], [[478.0, 1528.0], [567.0, 1475.0], [576.0, 1490.0], [487.0, 1543.0]]], "lines": ["前作「無女の教授をいた", "今朝の山田・ベニーですが、", "これからの時中にはやっているのですが、", "ビッキビキのページ"]}, {"box": [106, 1317, 264, 1528], "vertical": true, "font_size": 27, "lines_coords": [[[237.0, 1318.0], [264.0, 1318.0], [264.0, 1503.0], [237.0, 1503.0]], [[204.0, 1318.0], [231.0, 1318.0], [231.0, 1526.0], [204.0, 1526.0]], [[170.0, 1318.0], [196.0, 1318.0], [196.0, 1501.0], [170.0, 1501.0]], [[135.0, 1318.0], [162.0, 1318.0], [162.0, 1528.0], [135.0, 1528.0]], [[106.0, 1317.0], [132.0, 1317.0], [132.0, 1409.0], [106.0, 1409.0]]], "lines": ["僕はこのことを", "世間に晒すことで", "幸福とは何かを", "みんなに問いたい", "と思う。"]}], "img_path": "150.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [862, 128, 1039, 367], "vertical": true, "font_size": 27, "lines_coords": [[[1012.0, 129.0], [1034.0, 129.0], [1034.0, 337.0], [1012.0, 337.0]], [[973.0, 129.0], [1004.0, 129.0], [1004.0, 290.0], [973.0, 290.0]], [[940.0, 131.0], [962.0, 131.0], [962.0, 339.0], [940.0, 339.0]], [[903.0, 132.0], [929.0, 132.0], [929.0, 367.0], [903.0, 367.0]], [[862.0, 128.0], [898.0, 128.0], [898.0, 201.0], [862.0, 201.0]]], "lines": ["Ｋ街道沿いにある", "使われてない", "ミソの製造工場に", "三人の遺体を隠して", "ある。"]}, {"box": [421, 132, 559, 367], "vertical": true, "font_size": 28, "lines_coords": [[[532.0, 134.0], [559.0, 134.0], [559.0, 292.0], [532.0, 292.0]], [[493.0, 132.0], [520.0, 132.0], [520.0, 367.0], [493.0, 367.0]], [[456.0, 132.0], [487.0, 132.0], [487.0, 295.0], [456.0, 295.0]], [[421.0, 132.0], [448.0, 132.0], [448.0, 304.0], [421.0, 304.0]]], "lines": ["そこに、君の", "勇気に見合った分の", "現金も一緒に", "置いておこう。"]}, {"box": [839, 685, 1014, 897], "vertical": true, "font_size": 27, "lines_coords": [[[985.0, 687.0], [1012.0, 687.0], [1012.0, 896.0], [985.0, 896.0]], [[948.0, 687.0], [975.0, 687.0], [975.0, 876.0], [948.0, 876.0]], [[914.0, 689.0], [935.0, 689.0], [935.0, 895.0], [914.0, 895.0]], [[873.0, 685.0], [904.0, 685.0], [904.0, 873.0], [873.0, 873.0]], [[840.0, 689.0], [867.0, 689.0], [867.0, 896.0], [840.0, 896.0]]], "lines": ["君がこのビデオを", "見ている頃には、", "僕は遺書を残して", "もうこの世には", "いないだろう．．．"]}, {"box": [198, 332, 373, 543], "vertical": true, "font_size": 28, "lines_coords": [[[340.0, 332.0], [373.0, 332.0], [373.0, 453.0], [340.0, 453.0]], [[307.0, 334.0], [334.0, 334.0], [334.0, 517.0], [307.0, 517.0]], [[270.0, 335.0], [296.0, 335.0], [296.0, 467.0], [270.0, 467.0]], [[234.0, 334.0], [260.0, 334.0], [260.0, 543.0], [234.0, 543.0]], [[198.0, 335.0], [225.0, 335.0], [225.0, 481.0], [198.0, 481.0]]], "lines": ["．．．だから、", "三人を見つけて", "この事実を", "マスコミにリーク", "してほしい。"]}, {"box": [723, 1287, 825, 1473], "vertical": true, "font_size": 26, "lines_coords": [[[796.0, 1287.0], [825.0, 1287.0], [825.0, 1396.0], [796.0, 1396.0]], [[762.0, 1289.0], [784.0, 1289.0], [784.0, 1470.0], [762.0, 1470.0]], [[723.0, 1287.0], [750.0, 1287.0], [750.0, 1473.0], [723.0, 1473.0]]], "lines": ["君の．．．", "勇気と好奇心に", "期待してるよ：・"]}], "img_path": "151.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [902, 76, 1000, 259], "vertical": true, "font_size": 26, "lines_coords": [[[973.0, 76.0], [1000.0, 76.0], [998.0, 259.0], [971.0, 259.0]], [[935.0, 76.0], [964.0, 76.0], [964.0, 181.0], [935.0, 181.0]], [[903.0, 76.0], [925.0, 76.0], [925.0, 232.0], [903.0, 232.0]]], "lines": ["ってオーイ！！", "イタズラ", "じゃんかよ！！"]}, {"box": [372, 93, 508, 278], "vertical": true, "font_size": 26, "lines_coords": [[[481.0, 96.0], [507.0, 96.0], [507.0, 232.0], [481.0, 232.0]], [[445.0, 93.0], [473.0, 93.0], [470.0, 253.0], [442.0, 253.0]], [[407.0, 95.0], [434.0, 95.0], [434.0, 278.0], [407.0, 278.0]], [[373.0, 98.0], [395.0, 98.0], [395.0, 251.0], [373.0, 251.0]]], "lines": ["．．．大体さ、", "道の真ん中に", "落ちてる時点で", "おかしくね？"]}, {"box": [95, 254, 157, 373], "vertical": true, "font_size": 26, "lines_coords": [[[129.0, 254.0], [157.0, 254.0], [157.0, 364.0], [129.0, 364.0]], [[95.0, 257.0], [121.0, 257.0], [121.0, 373.0], [95.0, 373.0]]], "lines": ["あ～～～", "ムカツク。"]}, {"box": [937, 692, 960, 848], "vertical": true, "font_size": 24, "lines_coords": [[[939.0, 692.0], [960.0, 692.0], [960.0, 754.0], [939.0, 754.0]], [[937.0, 771.0], [960.0, 771.0], [960.0, 848.0], [937.0, 848.0]]], "lines": ["．．．う", "ーん．．．"]}, {"box": [673, 443, 773, 600], "vertical": true, "font_size": 27, "lines_coords": [[[745.0, 443.0], [771.0, 443.0], [771.0, 575.0], [745.0, 575.0]], [[709.0, 443.0], [737.0, 443.0], [737.0, 556.0], [709.0, 556.0]], [[673.0, 443.0], [700.0, 443.0], [700.0, 600.0], [673.0, 600.0]]], "lines": ["からかわれ", "たんだよ、", "チクショウ！！"]}, {"box": [89, 465, 187, 600], "vertical": true, "font_size": 26, "lines_coords": [[[159.0, 467.0], [187.0, 467.0], [187.0, 573.0], [159.0, 573.0]], [[123.0, 470.0], [151.0, 470.0], [151.0, 600.0], [123.0, 600.0]], [[89.0, 465.0], [110.0, 465.0], [110.0, 581.0], [89.0, 581.0]]], "lines": ["清水でも", "ぷん殴って", "くるかな"]}, {"box": [831, 792, 893, 939], "vertical": true, "font_size": 24, "lines_coords": [[[865.0, 792.0], [893.0, 792.0], [893.0, 939.0], [865.0, 939.0]], [[831.0, 796.0], [853.0, 796.0], [853.0, 925.0], [831.0, 925.0]]], "lines": ["じゃ、僕らも", "帰ろうかな"]}, {"box": [384, 1118, 492, 1289], "vertical": true, "font_size": 35, "lines_coords": [[[460.0, 1123.0], [492.0, 1123.0], [492.0, 1289.0], [460.0, 1289.0]], [[423.0, 1120.0], [456.0, 1120.0], [451.0, 1284.0], [418.0, 1284.0]], [[384.0, 1118.0], [425.0, 1118.0], [425.0, 1196.0], [384.0, 1196.0]]], "lines": ["い―よいーよ、", "気、つかわな", "くて。"]}], "img_path": "152.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [922, 107, 979, 215], "vertical": true, "font_size": 26, "lines_coords": [[[953.0, 109.0], [979.0, 109.0], [979.0, 215.0], [953.0, 215.0]]], "lines": ["ただいま"]}, {"box": [475, 118, 611, 345], "vertical": true, "font_size": 26, "lines_coords": [[[584.0, 118.0], [610.0, 118.0], [607.0, 267.0], [581.0, 267.0]], [[546.0, 120.0], [575.0, 120.0], [575.0, 254.0], [546.0, 254.0]], [[509.0, 118.0], [535.0, 118.0], [535.0, 345.0], [509.0, 345.0]], [[476.0, 123.0], [498.0, 123.0], [498.0, 323.0], [476.0, 323.0]]], "lines": ["じゃあ、丁度", "ビデオ屋で", "『インデペンデンス・", "デイ一借りたから、"]}, {"box": [107, 310, 245, 465], "vertical": true, "font_size": 28, "lines_coords": [[[217.0, 310.0], [243.0, 310.0], [243.0, 465.0], [217.0, 465.0]], [[176.0, 310.0], [209.0, 310.0], [209.0, 445.0], [176.0, 445.0]], [[143.0, 312.0], [170.0, 312.0], [170.0, 440.0], [143.0, 440.0]], [[107.0, 312.0], [134.0, 312.0], [134.0, 415.0], [107.0, 415.0]]], "lines": ["これでひとつ", "大笑いして", "やろうじゃ", "ないか！！"]}, {"box": [656, 515, 801, 701], "vertical": true, "font_size": 31, "lines_coords": [[[762.0, 517.0], [796.0, 515.0], [801.0, 612.0], [767.0, 614.0]], [[731.0, 518.0], [759.0, 518.0], [759.0, 635.0], [731.0, 635.0]], [[695.0, 517.0], [723.0, 517.0], [725.0, 701.0], [696.0, 701.0]], [[656.0, 515.0], [689.0, 515.0], [689.0, 612.0], [656.0, 612.0]]], "lines": ["おやぁ、", "どーした、", "元気無さ気じゃ", "ないの。"]}, {"box": [453, 896, 556, 1095], "vertical": true, "font_size": 28, "lines_coords": [[[525.0, 896.0], [556.0, 896.0], [556.0, 1095.0], [525.0, 1095.0]], [[489.0, 896.0], [515.0, 896.0], [515.0, 1056.0], [489.0, 1056.0]], [[453.0, 898.0], [481.0, 898.0], [481.0, 987.0], [453.0, 987.0]]], "lines": ["．．．おっ、なんだい", "その不思議な", "踊りは。"]}, {"box": [887, 1126, 1009, 1329], "vertical": true, "font_size": 32, "lines_coords": [[[971.0, 1128.0], [1009.0, 1128.0], [1004.0, 1315.0], [967.0, 1315.0]], [[935.0, 1159.0], [964.0, 1159.0], [964.0, 1234.0], [935.0, 1234.0]], [[887.0, 1129.0], [928.0, 1126.0], [940.0, 1303.0], [900.0, 1306.0]], [[939.0, 1228.0], [967.0, 1229.0], [962.0, 1329.0], [934.0, 1328.0]]], "lines": ["わっからっな", "いー", "あっからったよ", "ーっよ"]}, {"box": [862, 1160, 893, 1290], "vertical": true, "font_size": 32, "lines_coords": [[[862.0, 1160.0], [892.0, 1160.0], [892.0, 1218.0], [862.0, 1218.0]], [[865.0, 1217.0], [893.0, 1217.0], [893.0, 1290.0], [865.0, 1290.0]]], "lines": ["いー", "ーっよ"]}, {"box": [670, 1124, 750, 1324], "vertical": true, "font_size": 38, "lines_coords": [[[703.0, 1128.0], [740.0, 1126.0], [750.0, 1300.0], [712.0, 1301.0]], [[670.0, 1178.0], [709.0, 1178.0], [709.0, 1270.0], [670.0, 1270.0]]], "lines": ["あっからっな", "ったー"]}, {"box": [504, 1150, 575, 1332], "vertical": true, "font_size": 49, "lines_coords": [[[504.0, 1156.0], [553.0, 1150.0], [575.0, 1326.0], [526.0, 1332.0]]], "lines": ["わっからった"]}], "img_path": "153.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "154.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "155.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [879, 210, 944, 328], "vertical": true, "font_size": 27, "lines_coords": [[[917.0, 212.0], [943.0, 212.0], [943.0, 318.0], [917.0, 318.0]], [[879.0, 210.0], [907.0, 210.0], [907.0, 328.0], [879.0, 328.0]]], "lines": ["おかえり", "プンプン。"]}, {"box": [215, 170, 317, 362], "vertical": true, "font_size": 28, "lines_coords": [[[289.0, 171.0], [317.0, 171.0], [317.0, 312.0], [289.0, 312.0]], [[250.0, 170.0], [281.0, 170.0], [281.0, 359.0], [250.0, 359.0]], [[215.0, 170.0], [242.0, 170.0], [242.0, 362.0], [215.0, 362.0]]], "lines": ["カレーをね、", "甘口か中辛かで", "迷ったんだけど、"]}, {"box": [31, 295, 76, 457], "vertical": true, "font_size": 45, "lines_coords": [[[31.0, 295.0], [76.0, 295.0], [76.0, 457.0], [31.0, 457.0]]], "lines": ["第９話"]}, {"box": [154, 410, 256, 571], "vertical": true, "font_size": 28, "lines_coords": [[[226.0, 410.0], [254.0, 410.0], [256.0, 545.0], [228.0, 545.0]], [[190.0, 412.0], [218.0, 412.0], [220.0, 571.0], [192.0, 571.0]], [[154.0, 410.0], [182.0, 410.0], [182.0, 517.0], [154.0, 517.0]]], "lines": ["プンプンは", "中辛で平気な", "子かい？"]}, {"box": [962, 1004, 989, 1137], "vertical": true, "font_size": 25, "lines_coords": [[[962.0, 1004.0], [989.0, 1004.0], [989.0, 1137.0], [962.0, 1137.0]]], "lines": ["なにい～～"]}, {"box": [928, 1081, 951, 1134], "vertical": true, "font_size": 25, "lines_coords": [[[928.0, 1081.0], [951.0, 1081.0], [951.0, 1134.0], [928.0, 1134.0]]], "lines": ["～！！"]}, {"box": [506, 1054, 605, 1240], "vertical": true, "font_size": 23, "lines_coords": [[[579.0, 1057.0], [601.0, 1057.0], [601.0, 1239.0], [579.0, 1239.0]], [[539.0, 1054.0], [565.0, 1054.0], [565.0, 1189.0], [539.0, 1189.0]], [[506.0, 1057.0], [528.0, 1057.0], [528.0, 1212.0], [506.0, 1212.0]]], "lines": ["自分は辛口でも", "イケるクチ", "だとお〜〜！？"]}, {"box": [498, 1360, 568, 1526], "vertical": true, "font_size": 34, "lines_coords": [[[526.0, 1360.0], [568.0, 1360.0], [568.0, 1428.0], [526.0, 1428.0]], [[498.0, 1368.0], [525.0, 1368.0], [525.0, 1526.0], [498.0, 1526.0]]], "lines": ["この", "おませさん！！"]}], "img_path": "156.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [882, 204, 909, 365], "vertical": true, "font_size": 24, "lines_coords": [[[882.0, 204.0], [909.0, 204.0], [909.0, 365.0], [882.0, 365.0]]], "lines": ["ーーですから"]}, {"box": [776, 154, 870, 421], "vertical": true, "font_size": 24, "lines_coords": [[[848.0, 156.0], [870.0, 156.0], [870.0, 390.0], [848.0, 390.0]], [[810.0, 154.0], [837.0, 154.0], [837.0, 414.0], [810.0, 414.0]], [[776.0, 156.0], [798.0, 156.0], [798.0, 421.0], [776.0, 421.0]]], "lines": ["私共は皆様の健康と", "人生の充実をよりよい", "ものにして頂くために、"]}, {"box": [150, 267, 285, 476], "vertical": true, "font_size": 26, "lines_coords": [[[256.0, 268.0], [282.0, 268.0], [282.0, 476.0], [256.0, 476.0]], [[221.0, 270.0], [248.0, 270.0], [248.0, 401.0], [221.0, 401.0]], [[185.0, 267.0], [212.0, 267.0], [212.0, 476.0], [185.0, 476.0]], [[150.0, 267.0], [176.0, 267.0], [176.0, 410.0], [150.0, 410.0]]], "lines": ["このように商品を", "お売りして", "まわっている訳で", "ございます。"]}, {"box": [948, 834, 975, 967], "vertical": true, "font_size": 22, "lines_coords": [[[950.0, 837.0], [973.0, 837.0], [973.0, 875.0], [950.0, 875.0]], [[950.0, 895.0], [971.0, 895.0], [971.0, 965.0], [950.0, 965.0]]], "lines": ["ふー", "ん．．．"]}, {"box": [573, 859, 600, 975], "vertical": true, "font_size": 27, "lines_coords": [[[573.0, 859.0], [600.0, 859.0], [600.0, 975.0], [573.0, 975.0]]], "lines": ["いえいえ。"]}, {"box": [106, 901, 245, 1112], "vertical": true, "font_size": 28, "lines_coords": [[[215.0, 903.0], [242.0, 903.0], [242.0, 1062.0], [215.0, 1062.0]], [[179.0, 903.0], [206.0, 903.0], [206.0, 1035.0], [179.0, 1035.0]], [[140.0, 903.0], [171.0, 903.0], [171.0, 1112.0], [140.0, 1112.0]], [[109.0, 901.0], [135.0, 901.0], [132.0, 1070.0], [106.0, 1070.0]]], "lines": ["私共は決して", "そのような", "あやしい宗教じゃ", "ございません。"]}, {"box": [670, 1173, 809, 1517], "vertical": true, "font_size": 28, "lines_coords": [[[784.0, 1307.0], [806.0, 1307.0], [806.0, 1462.0], [784.0, 1462.0]], [[745.0, 1306.0], [771.0, 1306.0], [771.0, 1515.0], [745.0, 1515.0]], [[706.0, 1304.0], [739.0, 1304.0], [739.0, 1517.0], [706.0, 1517.0]], [[670.0, 1303.0], [703.0, 1303.0], [703.0, 1426.0], [670.0, 1426.0]]], "lines": ["そのシャツに", "プリントされてる", "のが、あなた達の", "神様、と。"]}, {"box": [346, 1179, 521, 1442], "vertical": true, "font_size": 25, "lines_coords": [[[492.0, 1179.0], [518.0, 1179.0], [517.0, 1415.0], [490.0, 1415.0]], [[456.0, 1182.0], [482.0, 1182.0], [482.0, 1415.0], [456.0, 1415.0]], [[418.0, 1184.0], [445.0, 1184.0], [445.0, 1442.0], [418.0, 1442.0]], [[385.0, 1182.0], [407.0, 1182.0], [407.0, 1442.0], [385.0, 1442.0]], [[346.0, 1181.0], [368.0, 1181.0], [371.0, 1376.0], [350.0, 1376.0]]], "lines": ["むしろ、そのように", "疑心暗鬼になられて", "いるのは、あなた様の", "健康が害されてる証と", "私共は考えます。"]}, {"box": [92, 1407, 120, 1514], "vertical": true, "font_size": 28, "lines_coords": [[[92.0, 1407.0], [120.0, 1407.0], [120.0, 1484.0], [92.0, 1484.0]]], "lines": ["なぬー"]}], "img_path": "157.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [870, 125, 1006, 284], "vertical": true, "font_size": 26, "lines_coords": [[[978.0, 126.0], [1006.0, 126.0], [1006.0, 215.0], [978.0, 215.0]], [[942.0, 125.0], [970.0, 125.0], [967.0, 284.0], [939.0, 284.0]], [[906.0, 126.0], [932.0, 126.0], [932.0, 284.0], [906.0, 284.0]], [[871.0, 128.0], [893.0, 128.0], [893.0, 240.0], [871.0, 240.0]]], "lines": ["．．．ほら、", "不健康な方は", "笑顔も減って", "ゆきます"]}, {"box": [368, 134, 468, 318], "vertical": true, "font_size": 26, "lines_coords": [[[440.0, 135.0], [468.0, 135.0], [468.0, 246.0], [440.0, 246.0]], [[404.0, 135.0], [431.0, 135.0], [431.0, 318.0], [404.0, 318.0]], [[370.0, 137.0], [392.0, 137.0], [392.0, 290.0], [370.0, 290.0]]], "lines": ["．．．あなた", "僕が不幸だって", "言いたい訳？"]}, {"box": [545, 429, 647, 653], "vertical": true, "font_size": 25, "lines_coords": [[[621.0, 432.0], [643.0, 432.0], [643.0, 612.0], [621.0, 612.0]], [[582.0, 429.0], [609.0, 429.0], [609.0, 653.0], [582.0, 653.0]], [[545.0, 431.0], [571.0, 431.0], [575.0, 585.0], [548.0, 585.0]]], "lines": ["笑顔の足りない", "方は、幸せも去って", "ゆきますよ？"]}, {"box": [79, 437, 215, 634], "vertical": true, "font_size": 23, "lines_coords": [[[189.0, 440.0], [210.0, 440.0], [210.0, 621.0], [189.0, 621.0]], [[150.0, 437.0], [178.0, 437.0], [175.0, 623.0], [146.0, 623.0]], [[115.0, 440.0], [137.0, 440.0], [137.0, 634.0], [115.0, 634.0]], [[79.0, 439.0], [101.0, 439.0], [101.0, 556.0], [79.0, 556.0]]], "lines": ["あなたみたいな", "貼りついた笑顔", "なんて、僕は御免", "だけどな。"]}, {"box": [912, 746, 978, 886], "vertical": true, "font_size": 27, "lines_coords": [[[950.0, 746.0], [978.0, 746.0], [978.0, 829.0], [950.0, 829.0]], [[914.0, 746.0], [940.0, 746.0], [940.0, 885.0], [914.0, 885.0]]], "lines": ["．．．", "失礼ですが、"]}, {"box": [926, 1084, 988, 1207], "vertical": true, "font_size": 28, "lines_coords": [[[959.0, 1084.0], [987.0, 1084.0], [987.0, 1192.0], [959.0, 1192.0]], [[926.0, 1085.0], [953.0, 1085.0], [953.0, 1207.0], [926.0, 1207.0]]], "lines": ["．．．カレー", "ですけど。"]}, {"box": [657, 1068, 690, 1261], "vertical": true, "font_size": 32, "lines_coords": [[[657.0, 1068.0], [689.0, 1068.0], [689.0, 1259.0], [657.0, 1259.0]]], "lines": ["でしたらっ！！"]}, {"box": [170, 787, 236, 971], "vertical": true, "font_size": 27, "lines_coords": [[[206.0, 789.0], [234.0, 789.0], [234.0, 893.0], [206.0, 893.0]], [[170.0, 787.0], [196.0, 787.0], [196.0, 971.0], [170.0, 971.0]]], "lines": ["お宅様の", "今晩の献立は？"]}, {"box": [115, 1076, 279, 1339], "vertical": true, "font_size": 31, "lines_coords": [[[242.0, 1078.0], [275.0, 1078.0], [278.0, 1300.0], [245.0, 1300.0]], [[203.0, 1078.0], [234.0, 1078.0], [234.0, 1301.0], [203.0, 1301.0]], [[156.0, 1076.0], [189.0, 1076.0], [189.0, 1339.0], [156.0, 1339.0]], [[115.0, 1078.0], [142.0, 1078.0], [142.0, 1298.0], [115.0, 1298.0]]], "lines": ["この水を使って", "頂ければ体にも", "いいし、味もグっと", "良くなります！！"]}, {"box": [128, 1437, 154, 1526], "vertical": true, "font_size": 26, "lines_coords": [[[128.0, 1437.0], [154.0, 1437.0], [154.0, 1526.0], [128.0, 1526.0]]], "lines": ["ほほう。"]}], "img_path": "158.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [909, 87, 978, 248], "vertical": true, "font_size": 27, "lines_coords": [[[945.0, 87.0], [978.0, 87.0], [975.0, 248.0], [942.0, 248.0]], [[909.0, 93.0], [937.0, 93.0], [937.0, 231.0], [909.0, 231.0]]], "lines": ["１．５４ペットが", "一本五千円、"]}, {"box": [779, 243, 907, 506], "vertical": true, "font_size": 27, "lines_coords": [[[881.0, 243.0], [907.0, 243.0], [904.0, 390.0], [878.0, 390.0]], [[846.0, 245.0], [873.0, 245.0], [873.0, 462.0], [846.0, 462.0]], [[814.0, 246.0], [837.0, 246.0], [835.0, 506.0], [812.0, 506.0]], [[781.0, 245.0], [804.0, 245.0], [803.0, 506.0], [779.0, 506.0]]], "lines": ["１０本まとめて", "お買い上げされると", "「本あたり三千八百円と", "大変お安くなりますよ？"]}, {"box": [171, 95, 234, 254], "vertical": true, "font_size": 24, "lines_coords": [[[206.0, 95.0], [232.0, 95.0], [232.0, 254.0], [206.0, 254.0]], [[171.0, 96.0], [193.0, 96.0], [193.0, 226.0], [171.0, 226.0]]], "lines": ["それでも十分", "たけーよ！！"]}, {"box": [939, 646, 1018, 775], "vertical": true, "font_size": 33, "lines_coords": [[[982.0, 646.0], [1015.0, 646.0], [1018.0, 775.0], [985.0, 775.0]], [[939.0, 646.0], [978.0, 646.0], [978.0, 746.0], [939.0, 746.0]]], "lines": ["いえいえ", "いえ！！"]}, {"box": [771, 718, 921, 910], "vertical": true, "font_size": 33, "lines_coords": [[[890.0, 718.0], [921.0, 718.0], [921.0, 879.0], [890.0, 879.0]], [[850.0, 720.0], [882.0, 720.0], [882.0, 910.0], [850.0, 910.0]], [[810.0, 720.0], [843.0, 720.0], [843.0, 846.0], [810.0, 846.0]], [[771.0, 718.0], [803.0, 718.0], [803.0, 878.0], [771.0, 878.0]]], "lines": ["商品自体は", "ホンっとーに", "いいもの", "なんです！！"]}, {"box": [543, 1014, 664, 1237], "vertical": true, "font_size": 31, "lines_coords": [[[632.0, 1014.0], [664.0, 1014.0], [664.0, 1204.0], [632.0, 1204.0]], [[587.0, 1014.0], [620.0, 1014.0], [620.0, 1237.0], [587.0, 1237.0]], [[543.0, 1015.0], [571.0, 1015.0], [573.0, 1142.0], [545.0, 1142.0]]], "lines": ["ちょぢょちょ", "ちょっと待った", "あああ！！"]}, {"box": [114, 725, 279, 948], "vertical": true, "font_size": 33, "lines_coords": [[[239.0, 725.0], [279.0, 725.0], [279.0, 825.0], [239.0, 825.0]], [[200.0, 729.0], [232.0, 729.0], [229.0, 948.0], [196.0, 948.0]], [[154.0, 726.0], [187.0, 726.0], [187.0, 917.0], [154.0, 917.0]], [[114.0, 728.0], [140.0, 728.0], [140.0, 851.0], [114.0, 851.0]]], "lines": ["先生が", "一本一本丹念に", "パワーを注入", "して．．．"]}, {"box": [92, 1304, 259, 1560], "vertical": true, "font_size": 34, "lines_coords": [[[221.0, 1304.0], [259.0, 1304.0], [259.0, 1468.0], [221.0, 1468.0]], [[179.0, 1306.0], [210.0, 1306.0], [210.0, 1560.0], [179.0, 1560.0]], [[134.0, 1304.0], [167.0, 1304.0], [164.0, 1560.0], [131.0, 1560.0]], [[92.0, 1309.0], [125.0, 1309.0], [125.0, 1434.0], [92.0, 1434.0]]], "lines": ["パワーって", "なんですかねぇ！？", "先生のパワーって", "のはぁ！？"]}], "img_path": "159.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [512, 111, 685, 470], "vertical": true, "font_size": 28, "lines_coords": [[[653.0, 117.0], [685.0, 117.0], [685.0, 209.0], [653.0, 209.0]], [[645.0, 309.0], [676.0, 309.0], [676.0, 470.0], [645.0, 470.0]], [[615.0, 312.0], [642.0, 312.0], [642.0, 443.0], [615.0, 443.0]], [[581.0, 310.0], [607.0, 310.0], [607.0, 468.0], [581.0, 468.0]], [[548.0, 310.0], [575.0, 310.0], [575.0, 468.0], [548.0, 468.0]], [[515.0, 309.0], [542.0, 309.0], [539.0, 468.0], [512.0, 468.0]]], "lines": ["あっ！！", "それに、この", "商品を飲み", "続けて病気が", "治ったという", "データが．．．"]}, {"box": [100, 57, 375, 79], "vertical": false, "font_size": 22, "lines_coords": [[[100.0, 57.0], [375.0, 57.0], [375.0, 79.0], [100.0, 79.0]]], "lines": ["おやすみプンプン［"]}, {"box": [107, 465, 204, 748], "vertical": true, "font_size": 42, "lines_coords": [[[162.0, 467.0], [204.0, 467.0], [204.0, 748.0], [162.0, 748.0]], [[112.0, 465.0], [154.0, 465.0], [150.0, 732.0], [107.0, 732.0]]], "lines": ["話そらすんじゃ", "ねーよォオォ！！"]}, {"box": [568, 968, 599, 1086], "vertical": true, "font_size": 28, "lines_coords": [[[568.0, 968.0], [596.0, 968.0], [596.0, 1084.0], [568.0, 1084.0]]], "lines": ["．．．．．中学。"]}, {"box": [439, 1321, 689, 1515], "vertical": true, "font_size": 26, "lines_coords": [[[660.0, 1323.0], [687.0, 1323.0], [687.0, 1453.0], [660.0, 1453.0]], [[623.0, 1323.0], [651.0, 1323.0], [651.0, 1454.0], [623.0, 1454.0]], [[587.0, 1323.0], [614.0, 1323.0], [614.0, 1506.0], [587.0, 1506.0]], [[551.0, 1325.0], [578.0, 1325.0], [578.0, 1459.0], [551.0, 1459.0]], [[514.0, 1323.0], [540.0, 1323.0], [540.0, 1506.0], [514.0, 1506.0]], [[479.0, 1325.0], [501.0, 1325.0], [501.0, 1479.0], [479.0, 1479.0]], [[439.0, 1321.0], [465.0, 1321.0], [468.0, 1515.0], [442.0, 1515.0]]], "lines": ["実をいうと", "フンフンは", "辛いものが苦手", "なのですが、", "雄一おしさんに", "気をつかって", "しまったのです。"]}], "img_path": "160.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [809, 93, 947, 306], "vertical": true, "font_size": 27, "lines_coords": [[[920.0, 93.0], [946.0, 93.0], [943.0, 254.0], [917.0, 254.0]], [[881.0, 96.0], [909.0, 96.0], [909.0, 231.0], [881.0, 231.0]], [[843.0, 95.0], [870.0, 95.0], [870.0, 304.0], [843.0, 304.0]], [[809.0, 95.0], [835.0, 95.0], [835.0, 267.0], [809.0, 267.0]]], "lines": ["ですが聡明な", "プンプンは", "またもひらめいて", "しまいました。"]}, {"box": [290, 42, 615, 335], "vertical": true, "font_size": 28, "lines_coords": [[[582.0, 45.0], [610.0, 45.0], [610.0, 178.0], [582.0, 178.0]], [[545.0, 43.0], [576.0, 43.0], [576.0, 298.0], [545.0, 298.0]], [[510.0, 45.0], [537.0, 45.0], [537.0, 231.0], [510.0, 231.0]], [[473.0, 43.0], [501.0, 43.0], [500.0, 307.0], [471.0, 307.0]], [[435.0, 42.0], [467.0, 42.0], [465.0, 335.0], [434.0, 335.0]], [[401.0, 45.0], [428.0, 45.0], [428.0, 231.0], [401.0, 231.0]], [[362.0, 45.0], [390.0, 45.0], [393.0, 309.0], [365.0, 309.0]], [[328.0, 43.0], [354.0, 43.0], [354.0, 254.0], [328.0, 254.0]], [[290.0, 45.0], [317.0, 45.0], [318.0, 265.0], [292.0, 265.0]]], "lines": ["お父さんが", "「カレーはやはり甘口", "さらにリンゴを", "すりおろして入れると", "よりマイルドになるので", "甘党の父的には", "たまらんのでござる。」", "と言っていたのを", "思い出したのです。"]}], "img_path": "161.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [263, 167, 398, 378], "vertical": true, "font_size": 26, "lines_coords": [[[370.0, 167.0], [398.0, 167.0], [395.0, 300.0], [367.0, 300.0]], [[334.0, 168.0], [360.0, 168.0], [360.0, 326.0], [334.0, 326.0]], [[298.0, 170.0], [325.0, 170.0], [325.0, 378.0], [298.0, 378.0]], [[264.0, 170.0], [285.0, 170.0], [285.0, 282.0], [264.0, 282.0]]], "lines": ["お父さんは", "もうかれこれ", "一か月以上帰って", "きません。"]}, {"box": [826, 664, 966, 860], "vertical": true, "font_size": 27, "lines_coords": [[[939.0, 664.0], [965.0, 664.0], [962.0, 848.0], [935.0, 848.0]], [[901.0, 667.0], [928.0, 667.0], [926.0, 860.0], [900.0, 860.0]], [[864.0, 667.0], [890.0, 667.0], [890.0, 834.0], [864.0, 834.0]], [[826.0, 665.0], [854.0, 665.0], [856.0, 801.0], [828.0, 801.0]]], "lines": ["雄一おじさんは", "「ちょっと遠くに", "出張」と言って", "いましたが、"]}, {"box": [817, 1048, 955, 1232], "vertical": true, "font_size": 27, "lines_coords": [[[926.0, 1048.0], [953.0, 1048.0], [953.0, 1168.0], [926.0, 1168.0]], [[892.0, 1053.0], [918.0, 1053.0], [918.0, 1232.0], [892.0, 1232.0]], [[856.0, 1050.0], [884.0, 1050.0], [881.0, 1182.0], [853.0, 1182.0]], [[817.0, 1050.0], [843.0, 1050.0], [843.0, 1218.0], [817.0, 1218.0]]], "lines": ["「おみやげ", "たくさん買って", "きてくれる", "だろうか．．．．．"]}, {"box": [112, 717, 287, 956], "vertical": true, "font_size": 30, "lines_coords": [[[257.0, 721.0], [284.0, 721.0], [284.0, 954.0], [257.0, 954.0]], [[218.0, 720.0], [250.0, 720.0], [250.0, 904.0], [218.0, 904.0]], [[181.0, 717.0], [212.0, 717.0], [215.0, 956.0], [184.0, 956.0]], [[146.0, 718.0], [178.0, 718.0], [178.0, 904.0], [146.0, 904.0]], [[112.0, 720.0], [140.0, 720.0], [140.0, 810.0], [112.0, 810.0]]], "lines": ["早く帰ってこないと", "日本シリーズが", "終わっちゃうぞ、と", "プンプンは思い", "ました。"]}, {"box": [643, 1338, 780, 1508], "vertical": true, "font_size": 24, "lines_coords": [[[750.0, 1340.0], [778.0, 1340.0], [778.0, 1471.0], [750.0, 1471.0]], [[714.0, 1340.0], [740.0, 1340.0], [740.0, 1495.0], [714.0, 1495.0]], [[679.0, 1342.0], [701.0, 1342.0], [701.0, 1495.0], [679.0, 1495.0]], [[643.0, 1342.0], [665.0, 1342.0], [665.0, 1503.0], [643.0, 1503.0]]], "lines": ["プンプンは", "なんだか急に", "寂しくなって", "しまいました。"]}, {"box": [93, 1332, 195, 1528], "vertical": true, "font_size": 27, "lines_coords": [[[165.0, 1332.0], [192.0, 1332.0], [192.0, 1451.0], [165.0, 1451.0]], [[129.0, 1332.0], [156.0, 1332.0], [156.0, 1528.0], [129.0, 1528.0]], [[93.0, 1332.0], [120.0, 1332.0], [120.0, 1442.0], [93.0, 1442.0]]], "lines": ["「神様神様", "チンクルホイ」と", "唱えると、"]}], "img_path": "162.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [882, 143, 953, 239], "vertical": true, "font_size": 34, "lines_coords": [[[918.0, 145.0], [953.0, 145.0], [953.0, 229.0], [918.0, 229.0]], [[882.0, 143.0], [915.0, 143.0], [915.0, 239.0], [882.0, 239.0]]], "lines": ["神様が", "来ます。"]}, {"box": [168, 445, 310, 629], "vertical": true, "font_size": 28, "lines_coords": [[[281.0, 446.0], [307.0, 446.0], [307.0, 578.0], [281.0, 578.0]], [[245.0, 446.0], [271.0, 446.0], [271.0, 629.0], [245.0, 629.0]], [[207.0, 446.0], [234.0, 446.0], [234.0, 603.0], [207.0, 603.0]], [[168.0, 445.0], [201.0, 445.0], [201.0, 539.0], [168.0, 539.0]]], "lines": ["この呪文は", "雄一おじさんに", "教えてもらい", "ました。"]}, {"box": [225, 722, 471, 992], "vertical": true, "font_size": 68, "lines_coords": [[[401.0, 726.0], [471.0, 728.0], [467.0, 893.0], [396.0, 892.0]], [[317.0, 756.0], [385.0, 756.0], [385.0, 904.0], [317.0, 904.0]], [[225.0, 725.0], [290.0, 725.0], [290.0, 992.0], [225.0, 992.0]]], "lines": ["ヤッホー", "ンプン。", "何か用かい？"]}, {"box": [229, 732, 288, 983], "vertical": true, "font_size": 59, "lines_coords": [[[229.0, 732.0], [288.0, 732.0], [288.0, 983.0], [229.0, 983.0]]], "lines": ["何か用かい？"]}, {"box": [151, 1027, 391, 1282], "vertical": true, "font_size": 40, "lines_coords": [[[351.0, 1029.0], [389.0, 1029.0], [389.0, 1207.0], [351.0, 1207.0]], [[281.0, 1029.0], [326.0, 1029.0], [326.0, 1142.0], [281.0, 1142.0]], [[217.0, 1029.0], [254.0, 1029.0], [257.0, 1282.0], [220.0, 1282.0]], [[151.0, 1029.0], [189.0, 1029.0], [192.0, 1221.0], [154.0, 1221.0]]], "lines": ["そのような", "質問は", "弊社ではお答え", "しかねます。"]}, {"box": [878, 1279, 1016, 1535], "vertical": true, "font_size": 26, "lines_coords": [[[989.0, 1279.0], [1015.0, 1279.0], [1015.0, 1528.0], [989.0, 1528.0]], [[951.0, 1281.0], [978.0, 1281.0], [978.0, 1492.0], [951.0, 1492.0]], [[915.0, 1281.0], [942.0, 1281.0], [942.0, 1503.0], [915.0, 1503.0]], [[878.0, 1281.0], [904.0, 1281.0], [904.0, 1535.0], [878.0, 1535.0]]], "lines": ["「日本シリーズまでに", "お父さんは帰って", "くるだろうか？」と", "プンフンは聞きました。"]}, {"box": [89, 1364, 192, 1551], "vertical": true, "font_size": 28, "lines_coords": [[[162.0, 1365.0], [189.0, 1365.0], [189.0, 1498.0], [162.0, 1498.0]], [[123.0, 1364.0], [154.0, 1364.0], [154.0, 1551.0], [123.0, 1551.0]], [[89.0, 1364.0], [115.0, 1364.0], [117.0, 1535.0], [90.0, 1535.0]]], "lines": ["「ケチンボ」", "プンプンはもう", "怒り心頭です。"]}], "img_path": "163.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [828, 54, 906, 623], "vertical": true, "font_size": 75, "lines_coords": [[[831.0, 54.0], [906.0, 54.0], [903.0, 623.0], [828.0, 623.0]]], "lines": ["その他の質問、絶賛受付！！"]}, {"box": [385, 117, 545, 303], "vertical": true, "font_size": 27, "lines_coords": [[[517.0, 120.0], [545.0, 120.0], [545.0, 237.0], [517.0, 237.0]], [[484.0, 117.0], [510.0, 117.0], [509.0, 301.0], [482.0, 301.0]], [[451.0, 117.0], [479.0, 117.0], [479.0, 265.0], [451.0, 265.0]], [[418.0, 118.0], [445.0, 118.0], [445.0, 303.0], [418.0, 303.0]], [[385.0, 120.0], [412.0, 120.0], [412.0, 285.0], [385.0, 285.0]]], "lines": ["「リンゴを", "すりおろすアレ", "どこー？」", "もうプンプンは", "なげやりです。"]}, {"box": [102, 133, 368, 467], "vertical": false, "font_size": 67, "lines_coords": [[[201.0, 148.0], [315.0, 440.0], [245.0, 467.0], [131.0, 175.0]], [[275.0, 171.0], [368.0, 428.0], [314.0, 448.0], [218.0, 193.0]]], "lines": ["無くいいのと", "僕１年コカミと"]}, {"box": [192, 603, 225, 762], "vertical": true, "font_size": 30, "lines_coords": [[[193.0, 606.0], [223.0, 606.0], [223.0, 760.0], [193.0, 760.0]]], "lines": ["「そっか！！」"]}, {"box": [128, 1123, 284, 1551], "vertical": true, "font_size": 49, "lines_coords": [[[137.0, 1335.0], [185.0, 1334.0], [189.0, 1492.0], [140.0, 1493.0]]], "lines": ["．．．"]}], "img_path": "164.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [975, 137, 1034, 293], "vertical": true, "font_size": 24, "lines_coords": [[[1012.0, 137.0], [1034.0, 137.0], [1034.0, 293.0], [1012.0, 293.0]], [[975.0, 139.0], [998.0, 139.0], [998.0, 207.0], [975.0, 207.0]]], "lines": ["言っときます", "けどー"]}, {"box": [825, 273, 962, 485], "vertical": true, "font_size": 24, "lines_coords": [[[931.0, 273.0], [957.0, 273.0], [962.0, 420.0], [935.0, 420.0]], [[895.0, 275.0], [921.0, 275.0], [921.0, 460.0], [895.0, 460.0]], [[859.0, 275.0], [885.0, 275.0], [885.0, 485.0], [859.0, 485.0]], [[825.0, 276.0], [846.0, 276.0], [846.0, 443.0], [825.0, 443.0]]], "lines": ["別にボカァ、", "宗教がイカンと", "言ってるわけでは", "ないのですよ。"]}, {"box": [159, 260, 292, 496], "vertical": true, "font_size": 30, "lines_coords": [[[265.0, 262.0], [292.0, 262.0], [292.0, 471.0], [265.0, 471.0]], [[226.0, 260.0], [254.0, 260.0], [256.0, 420.0], [228.0, 420.0]], [[192.0, 260.0], [218.0, 260.0], [220.0, 431.0], [193.0, 431.0]], [[159.0, 264.0], [181.0, 264.0], [181.0, 496.0], [159.0, 496.0]]], "lines": ["あんたがあんだの", "神様を信じて", "救われるなら、", "それはそれで結構！！"]}, {"box": [165, 578, 359, 803], "vertical": true, "font_size": 30, "lines_coords": [[[321.0, 578.0], [359.0, 578.0], [359.0, 771.0], [321.0, 771.0]], [[285.0, 579.0], [317.0, 579.0], [317.0, 740.0], [285.0, 740.0]], [[245.0, 579.0], [276.0, 579.0], [276.0, 803.0], [245.0, 803.0]], [[203.0, 578.0], [234.0, 578.0], [237.0, 801.0], [206.0, 801.0]], [[165.0, 579.0], [200.0, 579.0], [200.0, 675.0], [165.0, 675.0]]], "lines": ["ただ、それを", "他人にまで", "押しつけるのは", "どーなのよって", "話よ！！"]}, {"box": [950, 912, 1013, 1096], "vertical": true, "font_size": 24, "lines_coords": [[[984.0, 914.0], [1010.0, 914.0], [1010.0, 1096.0], [984.0, 1096.0]], [[951.0, 914.0], [973.0, 914.0], [973.0, 1068.0], [951.0, 1068.0]]], "lines": ["お．．．落ちついて", "ください．．．"]}, {"box": [618, 965, 668, 1137], "vertical": true, "font_size": 42, "lines_coords": [[[618.0, 967.0], [660.0, 965.0], [668.0, 1135.0], [626.0, 1137.0]]], "lines": ["うるせぇ"]}, {"box": [568, 1026, 609, 1137], "vertical": true, "font_size": 42, "lines_coords": [[[568.0, 1026.0], [609.0, 1026.0], [609.0, 1137.0], [568.0, 1137.0]]], "lines": ["ーっ！！"]}, {"box": [154, 1059, 197, 1225], "vertical": true, "font_size": 39, "lines_coords": [[[154.0, 1059.0], [193.0, 1059.0], [196.0, 1225.0], [157.0, 1225.0]]], "lines": ["ヒイィ！！"]}, {"box": [714, 1317, 817, 1476], "vertical": true, "font_size": 27, "lines_coords": [[[789.0, 1320.0], [815.0, 1320.0], [815.0, 1476.0], [789.0, 1476.0]], [[753.0, 1320.0], [779.0, 1320.0], [779.0, 1476.0], [753.0, 1476.0]], [[717.0, 1317.0], [745.0, 1317.0], [742.0, 1475.0], [714.0, 1475.0]]], "lines": ["と、とにかく", "水道水と飲み", "くらべて．．．"]}, {"box": [282, 1278, 401, 1471], "vertical": true, "font_size": 32, "lines_coords": [[[370.0, 1281.0], [401.0, 1281.0], [401.0, 1471.0], [370.0, 1471.0]], [[326.0, 1279.0], [357.0, 1279.0], [357.0, 1470.0], [326.0, 1470.0]], [[282.0, 1278.0], [309.0, 1278.0], [312.0, 1468.0], [285.0, 1468.0]]], "lines": ["つまるところ", "あんたは不安", "なんでしょ！？"]}, {"box": [132, 1381, 210, 1540], "vertical": true, "font_size": 32, "lines_coords": [[[173.0, 1381.0], [210.0, 1381.0], [210.0, 1510.0], [173.0, 1510.0]], [[132.0, 1381.0], [165.0, 1381.0], [165.0, 1540.0], [132.0, 1540.0]]], "lines": ["寂しいん", "でしょが！！"]}], "img_path": "165.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [795, 114, 953, 550], "vertical": true, "font_size": 37, "lines_coords": [[[910.0, 115.0], [948.0, 115.0], [948.0, 265.0], [910.0, 265.0]], [[896.0, 364.0], [934.0, 364.0], [934.0, 550.0], [896.0, 550.0]], [[843.0, 362.0], [882.0, 362.0], [882.0, 478.0], [843.0, 478.0]], [[795.0, 367.0], [828.0, 367.0], [828.0, 510.0], [795.0, 510.0]]], "lines": ["僕ぁね！！", "ひとりでも", "生きて", "いける！！"]}, {"box": [217, 70, 342, 509], "vertical": true, "font_size": 30, "lines_coords": [[[309.0, 71.0], [342.0, 71.0], [342.0, 201.0], [309.0, 201.0]], [[264.0, 70.0], [296.0, 70.0], [296.0, 293.0], [264.0, 293.0]], [[223.0, 70.0], [250.0, 70.0], [250.0, 329.0], [223.0, 329.0]], [[217.0, 315.0], [248.0, 315.0], [248.0, 509.0], [217.0, 509.0]]], "lines": ["必要なら", "他人だって蹴り", "落とす覚悟だよ！！", "．．．そんな業に"]}, {"box": [918, 740, 954, 796], "vertical": true, "font_size": 34, "lines_coords": [[[918.0, 740.0], [954.0, 740.0], [954.0, 796.0], [918.0, 796.0]]], "lines": ["あっ"]}, {"box": [87, 348, 203, 634], "vertical": true, "font_size": 30, "lines_coords": [[[170.0, 348.0], [203.0, 348.0], [203.0, 571.0], [170.0, 571.0]], [[126.0, 350.0], [157.0, 350.0], [157.0, 634.0], [126.0, 634.0]], [[87.0, 350.0], [115.0, 350.0], [115.0, 437.0], [87.0, 437.0]]], "lines": ["まみれてるのが", "人間じゃないかね！？", "えぇー"]}, {"box": [89, 445, 112, 506], "vertical": true, "font_size": 30, "lines_coords": [[[89.0, 445.0], [112.0, 445.0], [112.0, 506.0], [89.0, 506.0]]], "lines": ["！？"]}, {"box": [850, 810, 882, 896], "vertical": true, "font_size": 34, "lines_coords": [[[850.0, 810.0], [882.0, 810.0], [882.0, 896.0], [850.0, 896.0]]], "lines": ["あっ．．．"]}, {"box": [879, 1029, 1018, 1217], "vertical": true, "font_size": 29, "lines_coords": [[[989.0, 1032.0], [1017.0, 1032.0], [1017.0, 1139.0], [989.0, 1139.0]], [[946.0, 1029.0], [979.0, 1029.0], [982.0, 1175.0], [950.0, 1175.0]], [[915.0, 1034.0], [942.0, 1034.0], [942.0, 1190.0], [915.0, 1190.0]], [[879.0, 1034.0], [906.0, 1034.0], [906.0, 1217.0], [879.0, 1217.0]]], "lines": ["世界では", "３秒に一人、", "飢餓で子供が", "死んでいます"]}, {"box": [471, 1057, 634, 1142], "vertical": false, "font_size": 26, "lines_coords