[454.0, 812.0]]], "lines": ["と思いました。"]}, {"box": [468, 1343, 539, 1485], "vertical": true, "font_size": 34, "lines_coords": [[[500.0, 1343.0], [539.0, 1343.0], [539.0, 1432.0], [500.0, 1432.0]], [[468.0, 1348.0], [496.0, 1348.0], [496.0, 1479.0], [468.0, 1479.0]]], "lines": ["そして", "プンフンは"]}, {"box": [346, 1346, 409, 1517], "vertical": true, "font_size": 27, "lines_coords": [[[382.0, 1346.0], [409.0, 1346.0], [409.0, 1453.0], [382.0, 1453.0]], [[346.0, 1348.0], [373.0, 1348.0], [373.0, 1510.0], [346.0, 1510.0]]], "lines": ["この手を", "離したくない。"]}, {"box": [236, 1345, 263, 1543], "vertical": true, "font_size": 21, "lines_coords": [[[239.0, 1348.0], [260.0, 1348.0], [260.0, 1534.0], [239.0, 1534.0]]], "lines": ["そう思いました"]}], "img_path": "054.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "055.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [570, 1271, 649, 1430], "vertical": true, "font_size": 28, "lines_coords": [[[618.0, 1271.0], [646.0, 1271.0], [648.0, 1400.0], [620.0, 1400.0]], [[582.0, 1273.0], [609.0, 1273.0], [609.0, 1378.0], [582.0, 1378.0]]], "lines": ["ブンブンの", "頭の中を"]}, {"box": [476, 1271, 541, 1466], "vertical": true, "font_size": 27, "lines_coords": [[[512.0, 1271.0], [539.0, 1271.0], [539.0, 1454.0], [512.0, 1454.0]], [[476.0, 1273.0], [503.0, 1273.0], [503.0, 1464.0], [476.0, 1464.0]]], "lines": ["ひとつの想いが", "駆け巡りました。"]}], "img_path": "056.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [906, 814, 939, 909], "vertical": true, "font_size": 33, "lines_coords": [[[906.0, 814.0], [939.0, 814.0], [939.0, 909.0], [906.0, 909.0]]], "lines": ["「僕は、」"]}, {"box": [467, 893, 687, 1014], "vertical": false, "font_size": 102, "lines_coords": [[[467.0, 912.0], [678.0, 893.0], [687.0, 995.0], [476.0, 1014.0]]], "lines": ["．．．"]}, {"box": [154, 909, 286, 1118], "vertical": true, "font_size": 27, "lines_coords": [[[257.0, 909.0], [284.0, 909.0], [284.0, 1029.0], [257.0, 1029.0]], [[223.0, 909.0], [250.0, 909.0], [250.0, 1067.0], [223.0, 1067.0]], [[189.0, 909.0], [215.0, 909.0], [215.0, 1067.0], [189.0, 1067.0]], [[154.0, 910.0], [181.0, 910.0], [181.0, 1117.0], [154.0, 1117.0]]], "lines": ["「みんなを", "メツボーから", "救えないかも", "しれないけれど、」"]}, {"box": [896, 1302, 924, 1422], "vertical": true, "font_size": 23, "lines_coords": [[[898.0, 1343.0], [921.0, 1343.0], [921.0, 1420.0], [898.0, 1420.0]]], "lines": ["．．うん。"]}], "img_path": "057.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [878, 96, 950, 271], "vertical": true, "font_size": 32, "lines_coords": [[[914.0, 96.0], [950.0, 96.0], [950.0, 170.0], [914.0, 170.0]], [[881.0, 96.0], [909.0, 96.0], [906.0, 268.0], [878.0, 268.0]]], "lines": ["「でも", "何があっても」"]}, {"box": [139, 259, 279, 418], "vertical": true, "font_size": 27, "lines_coords": [[[251.0, 260.0], [278.0, 260.0], [278.0, 406.0], [251.0, 406.0]], [[217.0, 262.0], [239.0, 262.0], [239.0, 415.0], [217.0, 415.0]], [[175.0, 259.0], [203.0, 259.0], [204.0, 393.0], [176.0, 393.0]], [[139.0, 259.0], [171.0, 259.0], [171.0, 345.0], [139.0, 345.0]]], "lines": ["「愛子ちゃん", "だけは守って", "あげたいと", "思う。」"]}, {"box": [221, 990, 250, 1122], "vertical": true, "font_size": 22, "lines_coords": [[[221.0, 990.0], [243.0, 990.0], [243.0, 1120.0], [221.0, 1120.0]]], "lines": ["．．．なんて？"]}], "img_path": "058.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [521, 337, 587, 507], "vertical": true, "font_size": 27, "lines_coords": [[[557.0, 337.0], [584.0, 337.0], [584.0, 507.0], [557.0, 507.0]], [[521.0, 339.0], [548.0, 339.0], [548.0, 495.0], [521.0, 495.0]]], "lines": ["「愛子ちゃんが", "好きだから。」"]}], "img_path": "059.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "060.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [135, 1155, 165, 1288], "vertical": true, "font_size": 29, "lines_coords": [[[135.0, 1156.0], [164.0, 1156.0], [164.0, 1287.0], [135.0, 1287.0]]], "lines": ["．．．エッチ！！"]}], "img_path": "061.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [254, 106, 321, 240], "vertical": true, "font_size": 26, "lines_coords": [[[289.0, 106.0], [317.0, 106.0], [321.0, 240.0], [293.0, 240.0]], [[254.0, 106.0], [282.0, 106.0], [282.0, 212.0], [254.0, 212.0]]], "lines": ["せんせぇ～", "〜〜〜～！！"]}, {"box": [109, 232, 206, 392], "vertical": true, "font_size": 26, "lines_coords": [[[178.0, 232.0], [206.0, 232.0], [206.0, 337.0], [178.0, 337.0]], [[142.0, 235.0], [168.0, 235.0], [168.0, 392.0], [142.0, 392.0]], [[109.0, 234.0], [131.0, 234.0], [131.0, 339.0], [109.0, 339.0]]], "lines": ["プンプン", "いました～～", "くそくく！！"]}], "img_path": "062.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [729, 28, 937, 490], "vertical": true, "font_size": 208, "lines_coords": [[[729.0, 28.0], [937.0, 28.0], [937.0, 490.0], [729.0, 490.0]]], "lines": ["．．．"]}, {"box": [866, 978, 1004, 1198], "vertical": true, "font_size": 23, "lines_coords": [[[975.0, 978.0], [1001.0, 978.0], [1001.0, 1187.0], [975.0, 1187.0]], [[942.0, 981.0], [964.0, 981.0], [964.0, 1134.0], [942.0, 1134.0]], [[904.0, 981.0], [926.0, 981.0], [926.0, 1134.0], [904.0, 1134.0]], [[868.0, 981.0], [890.0, 981.0], [890.0, 1198.0], [868.0, 1198.0]]], "lines": ["プンプンはその日", "愛子ちゃんを", "見ることすら", "できませんでした。"]}, {"box": [726, 1325, 760, 1484], "vertical": true, "font_size": 31, "lines_coords": [[[726.0, 1326.0], [757.0, 1326.0], [757.0, 1484.0], [726.0, 1484.0]]], "lines": ["プンプン！！"]}, {"box": [471, 1379, 541, 1528], "vertical": true, "font_size": 70, "lines_coords": [[[471.0, 1379.0], [541.0, 1379.0], [541.0, 1528.0], [471.0, 1528.0]]], "lines": ["あはははばんは"]}, {"box": [104, 1107, 242, 1343], "vertical": true, "font_size": 28, "lines_coords": [[[217.0, 1107.0], [239.0, 1107.0], [239.0, 1264.0], [217.0, 1264.0]], [[176.0, 1107.0], [207.0, 1107.0], [207.0, 1301.0], [176.0, 1301.0]], [[140.0, 1107.0], [171.0, 1107.0], [171.0, 1343.0], [140.0, 1343.0]], [[104.0, 1107.0], [131.0, 1107.0], [131.0, 1262.0], [104.0, 1262.0]]], "lines": ["よそ見ばかり", "してると、先生、", "ヘッドロックしちゃ", "うンだから！！"]}], "img_path": "063.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [862, 115, 1006, 314], "vertical": true, "font_size": 30, "lines_coords": [[[973.0, 115.0], [1006.0, 115.0], [1006.0, 200.0], [973.0, 200.0]], [[940.0, 117.0], [967.0, 117.0], [967.0, 250.0], [940.0, 250.0]], [[903.0, 120.0], [931.0, 120.0], [931.0, 251.0], [903.0, 251.0]], [[862.0, 115.0], [893.0, 115.0], [896.0, 314.0], [865.0, 314.0]]], "lines": ["心臓の", "ドキドキが", "いつまでも", "鳴り止まなくて、"]}, {"box": [104, 375, 246, 609], "vertical": true, "font_size": 27, "lines_coords": [[[215.0, 375.0], [243.0, 375.0], [243.0, 509.0], [215.0, 509.0]], [[179.0, 376.0], [206.0, 376.0], [206.0, 560.0], [179.0, 560.0]], [[143.0, 378.0], [170.0, 378.0], [170.0, 609.0], [143.0, 609.0]], [[107.0, 375.0], [134.0, 375.0], [131.0, 515.0], [104.0, 515.0]]], "lines": ["プンプンは", "どこかに飛んで", "いってしまいそうな", "気分でした。"]}, {"box": [912, 1262, 940, 1362], "vertical": true, "font_size": 28, "lines_coords": [[[912.0, 1262.0], [940.0, 1262.0], [940.0, 1362.0], [912.0, 1362.0]]], "lines": ["．．．プン！！"]}, {"box": [176, 1408, 205, 1554], "vertical": true, "font_size": 27, "lines_coords": [[[176.0, 1410.0], [203.0, 1410.0], [203.0, 1554.0], [176.0, 1554.0]]], "lines": ["．．．プンプン！！"]}], "img_path": "064.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [442, 506, 675, 733], "vertical": false, "font_size": 42, "lines_coords": [[[446.0, 546.0], [545.0, 506.0], [560.0, 545.0], [462.0, 585.0]], [[442.0, 606.0], [604.0, 540.0], [620.0, 578.0], [457.0, 643.0]], [[471.0, 643.0], [650.0, 562.0], [665.0, 596.0], [487.0, 678.0]], [[482.0, 684.0], [621.0, 625.0], [642.0, 670.0], [501.0, 729.0]]], "lines": ["日よう日", "ラミちゃんちて", "エロビデオ上えい", "ＥＢＪ！！"]}, {"box": [909, 921, 1009, 1060], "vertical": true, "font_size": 26, "lines_coords": [[[987.0, 926.0], [1009.0, 926.0], [1009.0, 1060.0], [987.0, 1060.0]], [[948.0, 923.0], [975.0, 923.0], [975.0, 1057.0], [948.0, 1057.0]], [[909.0, 921.0], [939.0, 921.0], [940.0, 1015.0], [910.0, 1015.0]]], "lines": ["．．．じゃあ私", "これで失礼", "します。"]}, {"box": [514, 912, 652, 1097], "vertical": true, "font_size": 26, "lines_coords": [[[626.0, 914.0], [648.0, 914.0], [648.0, 1096.0], [626.0, 1096.0]], [[587.0, 912.0], [614.0, 912.0], [614.0, 1046.0], [587.0, 1046.0]], [[551.0, 912.0], [578.0, 912.0], [578.0, 1070.0], [551.0, 1070.0]], [[514.0, 914.0], [542.0, 914.0], [542.0, 1006.0], [514.0, 1006.0]]], "lines": ["どうぞ今後とも", "プンプンを", "宜しくお願い", "します。"]}, {"box": [850, 1132, 982, 1293], "vertical": true, "font_size": 26, "lines_coords": [[[956.0, 1132.0], [982.0, 1132.0], [982.0, 1240.0], [956.0, 1240.0]], [[920.0, 1134.0], [946.0, 1134.0], [946.0, 1293.0], [920.0, 1293.0]], [[882.0, 1134.0], [909.0, 1134.0], [909.0, 1292.0], [882.0, 1292.0]], [[850.0, 1135.0], [871.0, 1135.0], [871.0, 1251.0], [850.0, 1251.0]]], "lines": ["これから", "弁護士さんと", "打ち合わせが", "あるので。"]}], "img_path": "065.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [932, 131, 996, 248], "vertical": true, "font_size": 28, "lines_coords": [[[968.0, 131.0], [996.0, 131.0], [996.0, 240.0], [968.0, 240.0]], [[932.0, 132.0], [960.0, 132.0], [960.0, 248.0], [932.0, 248.0]]], "lines": ["．．．ご苦労", "さまです。"]}, {"box": [464, 237, 529, 355], "vertical": true, "font_size": 30, "lines_coords": [[[495.0, 237.0], [529.0, 237.0], [529.0, 350.0], [495.0, 350.0]], [[464.0, 240.0], [490.0, 240.0], [490.0, 354.0], [464.0, 354.0]]], "lines": ["いや～～～", "いえいえ。"]}, {"box": [92, 60, 368, 87], "vertical": false, "font_size": 27, "lines_coords": [[[92.0, 60.0], [368.0, 60.0], [368.0, 87.0], [92.0, 87.0]]], "lines": ["おやすみプンプン□"]}, {"box": [873, 423, 1012, 598], "vertical": true, "font_size": 28, "lines_coords": [[[984.0, 428.0], [1012.0, 428.0], [1012.0, 534.0], [984.0, 534.0]], [[948.0, 428.0], [975.0, 428.0], [975.0, 585.0], [948.0, 585.0]], [[910.0, 423.0], [939.0, 423.0], [935.0, 585.0], [907.0, 585.0]], [[873.0, 426.0], [900.0, 426.0], [900.0, 598.0], [873.0, 598.0]]], "lines": ["誰だって", "生きてる限り", "ご苦労ばかり", "じゃないすか。"]}, {"box": [395, 506, 534, 692], "vertical": true, "font_size": 26, "lines_coords": [[[506.0, 507.0], [532.0, 507.0], [532.0, 692.0], [506.0, 692.0]], [[471.0, 509.0], [493.0, 509.0], [493.0, 664.0], [471.0, 664.0]], [[432.0, 506.0], [459.0, 506.0], [459.0, 640.0], [432.0, 640.0]], [[395.0, 507.0], [423.0, 507.0], [423.0, 596.0], [395.0, 596.0]]], "lines": ["その定めだけは", "誰しも平等に", "逃れられま", "せんよ。"]}, {"box": [175, 1220, 521, 1521], "vertical": false, "font_size": 226, "lines_coords": [[[175.0, 1304.0], [457.0, 1220.0], [521.0, 1437.0], [239.0, 1521.0]]], "lines": ["でも"]}], "img_path": "066.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [875, 551, 1025, 907], "vertical": true, "font_size": 101, "lines_coords": [[[925.0, 551.0], [1025.0, 567.0], [975.0, 907.0], [875.0, 893.0]]], "lines": ["いや、いいんだろ"]}, {"box": [856, 1177, 986, 1575], "vertical": true, "font_size": 130, "lines_coords": [[[856.0, 1177.0], [986.0, 1177.0], [986.0, 1575.0], [856.0, 1575.0]]], "lines": ["いたしかの"]}], "img_path": "067.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [125, 207, 235, 498], "vertical": true, "font_size": 95, "lines_coords": [[[125.0, 212.0], [220.0, 207.0], [235.0, 493.0], [140.0, 498.0]]], "lines": ["さや、"]}, {"box": [112, 1114, 206, 1131], "vertical": false, "font_size": 16, "lines_coords": [[[112.0, 1115.0], [206.0, 1114.0], [206.0, 1129.0], [112.0, 1131.0]]], "lines": ["ＳＲＡＣ出０７０"]}, {"box": [376, 1206, 401, 1329], "vertical": true, "font_size": 23.5, "lines_coords": [[[378.0, 1256.0], [401.0, 1256.0], [401.0, 1329.0], [378.0, 1329.0]], [[376.0, 1206.0], [400.0, 1206.0], [400.0, 1260.0], [376.0, 1260.0]]], "lines": ["．．．", "やかー"]}, {"box": [481, 1259, 498, 1312], "vertical": true, "font_size": 17, "lines_coords": [[[481.0, 1259.0], [498.0, 1259.0], [498.0, 1312.0], [481.0, 1312.0]]], "lines": ["それ"]}, {"box": [671, 1237, 693, 1362], "vertical": true, "font_size": 22, "lines_coords": [[[671.0, 1237.0], [693.0, 1237.0], [693.0, 1362.0], [671.0, 1362.0]]], "lines": ["ものできー"]}], "img_path": "068.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [867, 346, 970, 589], "vertical": true, "font_size": 29, "lines_coords": [[[939.0, 346.0], [970.0, 346.0], [968.0, 589.0], [937.0, 589.0]], [[901.0, 350.0], [932.0, 350.0], [932.0, 560.0], [901.0, 560.0]], [[867.0, 350.0], [893.0, 350.0], [893.0, 543.0], [867.0, 543.0]]], "lines": ["この時、ブンブンは", "ぼんやりとですが", "感じていました。"]}, {"box": [113, 109, 392, 1004], "vertical": true, "font_size": 143, "lines_coords": [[[192.0, 660.0], [335.0, 656.0], [346.0, 1000.0], [203.0, 1004.0]]], "lines": ["いっか"]}, {"box": [447, 1143, 620, 1341], "vertical": true, "font_size": 26, "lines_coords": [[[590.0, 1143.0], [617.0, 1143.0], [617.0, 1337.0], [590.0, 1337.0]], [[554.0, 1143.0], [582.0, 1143.0], [579.0, 1301.0], [551.0, 1301.0]], [[518.0, 1145.0], [545.0, 1145.0], [545.0, 1329.0], [518.0, 1329.0]], [[482.0, 1145.0], [509.0, 1145.0], [509.0, 1331.0], [482.0, 1331.0]], [[448.0, 1148.0], [470.0, 1148.0], [470.0, 1242.0], [448.0, 1242.0]]], "lines": ["もちろん、子供の", "プンプンには", "はじめての感覚", "だった訳ですが、", "つまりー"]}], "img_path": "069.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [495, 328, 596, 495], "vertical": true, "font_size": 26, "lines_coords": [[[570.0, 331.0], [592.0, 331.0], [592.0, 484.0], [570.0, 484.0]], [[528.0, 328.0], [559.0, 328.0], [559.0, 489.0], [528.0, 489.0]], [[495.0, 328.0], [521.0, 328.0], [521.0, 495.0], [495.0, 495.0]]], "lines": ["愛子ちゃんは", "運命の人かも", "しれない、と。"]}], "img_path": "070.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "071.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [369, 230, 576, 256], "vertical": false, "font_size": 18, "lines_coords": [[[375.0, 233.0], [568.0, 233.0], [568.0, 253.0], [375.0, 253.0]]], "lines": ["ＹＯＵＮＧＳＵＭＤＡＹＣＯＭＣＳ"]}, {"box": [353, 304, 590, 1129], "vertical": true, "font_size": 100, "lines_coords": [[[484.0, 304.0], [590.0, 304.0], [585.0, 1015.0], [479.0, 1015.0]], [[353.0, 312.0], [446.0, 312.0], [446.0, 704.0], [353.0, 704.0]]], "lines": ["おやすみプンプン", "浅野いにお"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [814, 154, 917, 310], "vertical": true, "font_size": 30, "lines_coords": [[[882.0, 154.0], [917.0, 154.0], [917.0, 237.0], [882.0, 237.0]], [[851.0, 156.0], [878.0, 156.0], [878.0, 310.0], [851.0, 310.0]], [[814.0, 156.0], [842.0, 156.0], [842.0, 271.0], [814.0, 271.0]]], "lines": ["今日は", "楽しい茶しい", "祝日です。"]}, {"box": [217, 220, 281, 337], "vertical": true, "font_size": 28, "lines_coords": [[[251.0, 220.0], [279.0, 220.0], [279.0, 326.0], [251.0, 326.0]], [[217.0, 221.0], [245.0, 221.0], [245.0, 337.0], [217.0, 337.0]]], "lines": ["おはよう", "プンプン。"]}, {"box": [26, 303, 70, 465], "vertical": true, "font_size": 44, "lines_coords": [[[26.0, 303.0], [70.0, 303.0], [70.0, 465.0], [26.0, 465.0]]], "lines": ["第４話"]}, {"box": [871, 467, 978, 653], "vertical": true, "font_size": 29, "lines_coords": [[[950.0, 470.0], [978.0, 470.0], [978.0, 578.0], [950.0, 578.0]], [[910.0, 467.0], [942.0, 467.0], [942.0, 653.0], [910.0, 653.0]], [[871.0, 467.0], [910.0, 467.0], [910.0, 554.0], [871.0, 554.0]]], "lines": ["荷ほどき", "手伝ってくれる", "かい？"]}, {"box": [795, 684, 928, 909], "vertical": true, "font_size": 29, "lines_coords": [[[906.0, 689.0], [928.0, 689.0], [928.0, 898.0], [906.0, 898.0]], [[867.0, 689.0], [893.0, 689.0], [893.0, 909.0], [867.0, 909.0]], [[831.0, 684.0], [859.0, 684.0], [856.0, 871.0], [828.0, 871.0]], [[795.0, 687.0], [823.0, 687.0], [823.0, 781.0], [795.0, 781.0]]], "lines": ["姉さんと相談して", "しばらくこの家で", "生活することに", "したよ。"]}, {"box": [910, 1017, 978, 1160], "vertical": true, "font_size": 28, "lines_coords": [[[948.0, 1017.0], [978.0, 1017.0], [978.0, 1090.0], [948.0, 1090.0]], [[910.0, 1017.0], [937.0, 1017.0], [940.0, 1159.0], [914.0, 1159.0]]], "lines": ["じゃー", "とりあえず、"]}, {"box": [140, 693, 314, 931], "vertical": true, "font_size": 27, "lines_coords": [[[282.0, 693.0], [314.0, 693.0], [314.0, 882.0], [282.0, 882.0]], [[248.0, 698.0], [275.0, 698.0], [275.0, 853.0], [248.0, 853.0]], [[210.0, 698.0], [237.0, 698.0], [237.0, 892.0], [210.0, 892.0]], [[175.0, 695.0], [201.0, 695.0], [203.0, 931.0], [176.0, 931.0]], [[140.0, 700.0], [162.0, 700.0], [164.0, 865.0], [142.0, 865.0]]], "lines": ["まー、もともと", "貯金暮らしの", "実家男に、両親の", "目が冷たすぎたって", "のもあるけど。"]}, {"box": [223, 1120, 265, 1185], "vertical": true, "font_size": 42, "lines_coords": [[[223.0, 1120.0], [265.0, 1120.0], [265.0, 1185.0], [223.0, 1185.0]]], "lines": ["ん？"]}, {"box": [509, 1115, 645, 1300], "vertical": true, "font_size": 27, "lines_coords": [[[617.0, 1117.0], [645.0, 1117.0], [645.0, 1254.0], [617.0, 1254.0]], [[579.0, 1115.0], [610.0, 1115.0], [610.0, 1300.0], [579.0, 1300.0]], [[546.0, 1118.0], [568.0, 1118.0], [568.0, 1271.0], [546.0, 1271.0]], [[509.0, 1115.0], [535.0, 1115.0], [535.0, 1221.0], [509.0, 1221.0]]], "lines": ["小さい荷物、", "プンプンパパの", "部屋に運んで", "くれる？"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [925, 165, 987, 332], "vertical": true, "font_size": 25, "lines_coords": [[[954.0, 165.0], [987.0, 165.0], [987.0, 210.0], [954.0, 210.0]], [[925.0, 168.0], [946.0, 168.0], [946.0, 332.0], [925.0, 332.0]]], "lines": ["あー", "そっかそつか。"]}, {"box": [153, 275, 289, 471], "vertical": true, "font_size": 24, "lines_coords": [[[257.0, 275.0], [285.0, 275.0], [289.0, 395.0], [260.0, 395.0]], [[226.0, 279.0], [248.0, 279.0], [248.0, 407.0], [226.0, 407.0]], [[190.0, 276.0], [212.0, 276.0], [212.0, 459.0], [190.0, 459.0]], [[153.0, 279.0], [175.0, 279.0], [175.0, 471.0], [153.0, 471.0]]], "lines": ["それじゃ、", "お父さんが", "帰ってきたとき", "困っちゃうよね。"]}, {"box": [834, 367, 856, 484], "vertical": true, "font_size": 25, "lines_coords": [[[834.0, 367.0], [856.0, 367.0], [856.0, 484.0], [834.0, 484.0]]], "lines": ["そうだね。"]}], "img_path": "075.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [545, 140, 574, 256], "vertical": true, "font_size": 28, "lines_coords": [[[545.0, 140.0], [573.0, 140.0], [573.0, 256.0], [545.0, 256.0]]], "lines": ["．．．姉さん、"]}, {"box": [85, 65, 373, 92], "vertical": false, "font_size": 27, "lines_coords": [[[85.0, 65.0], [373.0, 65.0], [373.0, 92.0], [85.0, 92.0]]], "lines": ["おやすみプンプン□"]}, {"box": [68, 284, 194, 485], "vertical": true, "font_size": 28, "lines_coords": [[[154.0, 284.0], [185.0, 284.0], [185.0, 485.0], [154.0, 485.0]], [[121.0, 285.0], [153.0, 285.0], [156.0, 451.0], [125.0, 451.0]], [[101.0, 289.0], [123.0, 289.0], [123.0, 470.0], [101.0, 470.0]], [[71.0, 285.0], [98.0, 285.0], [95.0, 420.0], [68.0, 420.0]]], "lines": ["折角、プンプンが", "来たんだから、", "なんか話したら", "どうだい？"]}], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [898, 95, 1007, 291], "vertical": true, "font_size": 28, "lines_coords": [[[970.0, 95.0], [1001.0, 95.0], [1001.0, 256.0], [970.0, 256.0]], [[935.0, 96.0], [962.0, 96.0], [962.0, 231.0], [935.0, 231.0]], [[898.0, 98.0], [925.0, 98.0], [925.0, 290.0], [898.0, 290.0]]], "lines": ["プン山さんの", "額の怪我は", "心配ありません。"]}, {"box": [151, 100, 321, 320], "vertical": true, "font_size": 26, "lines_coords": [[[300.0, 104.0], [321.0, 104.0], [321.0, 259.0], [300.0, 259.0]], [[259.0, 100.0], [285.0, 100.0], [285.0, 285.0], [259.0, 285.0]], [[225.0, 101.0], [251.0, 101.0], [251.0, 320.0], [225.0, 320.0]], [[190.0, 103.0], [212.0, 103.0], [212.0, 259.0], [190.0, 259.0]], [[153.0, 101.0], [176.0, 101.0], [175.0, 289.0], [151.0, 289.0]]], "lines": ["転倒した際に", "打った後頭部は", "数針ぬいましたが、", "脳にも異常は", "見られませんし、"]}, {"box": [914, 635, 1012, 807], "vertical": true, "font_size": 26, "lines_coords": [[[984.0, 635.0], [1010.0, 635.0], [1012.0, 807.0], [985.0, 807.0]], [[950.0, 637.0], [976.0, 637.0], [976.0, 770.0], [950.0, 770.0]], [[914.0, 637.0], [942.0, 637.0], [942.0, 751.0], [914.0, 751.0]]], "lines": ["むしろ、元気が", "ありすぎる", "くらいで、"]}, {"box": [235, 381, 262, 576], "vertical": true, "font_size": 26, "lines_coords": [[[235.0, 381.0], [262.0, 381.0], [262.0, 576.0], [235.0, 576.0]]], "lines": ["一応、精密検査を"]}, {"box": [159, 375, 228, 537], "vertical": true, "font_size": 26, "lines_coords": [[[196.0, 376.0], [228.0, 376.0], [228.0, 535.0], [196.0, 535.0]], [[159.0, 375.0], [190.0, 375.0], [190.0, 537.0], [159.0, 537.0]]], "lines": ["受けてもらい", "ますが、問題"]}, {"box": [125, 376, 154, 546], "vertical": true, "font_size": 26, "lines_coords": [[[125.0, 376.0], [151.0, 376.0], [154.0, 546.0], [128.0, 546.0]]], "lines": ["ないでしょう。"]}, {"box": [784, 709, 882, 904], "vertical": true, "font_size": 26, "lines_coords": [[[856.0, 709.0], [882.0, 709.0], [882.0, 829.0], [856.0, 829.0]], [[820.0, 709.0], [846.0, 709.0], [846.0, 881.0], [820.0, 881.0]], [[784.0, 709.0], [810.0, 709.0], [810.0, 904.0], [784.0, 904.0]]], "lines": ["「入院食が", "少ない！！」とか", "「夜が退屈」って。"]}, {"box": [921, 989, 1021, 1144], "vertical": true, "font_size": 27, "lines_coords": [[[995.0, 990.0], [1021.0, 990.0], [1021.0, 1120.0], [995.0, 1120.0]], [[957.0, 989.0], [984.0, 989.0], [984.0, 1143.0], [957.0, 1143.0]], [[921.0, 989.0], [948.0, 989.0], [948.0, 1121.0], [921.0, 1121.0]]], "lines": ["あーーっ！！", "プン山さんの", "息子さん！？"]}, {"box": [570, 981, 671, 1164], "vertical": true, "font_size": 27, "lines_coords": [[[643.0, 982.0], [670.0, 982.0], [670.0, 1164.0], [643.0, 1164.0]], [[606.0, 981.0], [634.0, 981.0], [634.0, 1112.0], [606.0, 1112.0]], [[570.0, 981.0], [596.0, 981.0], [596.0, 1137.0], [570.0, 1137.0]]], "lines": ["お母さん、すぐ", "退院できる", "からねーー！！"]}, {"box": [148, 723, 210, 891], "vertical": true, "font_size": 24, "lines_coords": [[[182.0, 723.0], [209.0, 723.0], [209.0, 829.0], [182.0, 829.0]], [[150.0, 725.0], [171.0, 725.0], [171.0, 890.0], [150.0, 890.0]]], "lines": ["あらら？", "失礼しました。"]}], "img_path": "077.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [852, 212, 881, 438], "vertical": true, "font_size": 20, "lines_coords": [[[856.0, 256.0], [876.0, 256.0], [876.0, 428.0], [856.0, 428.0]]], "lines": ["ーフンフンは"]}, {"box": [99, 173, 200, 360], "vertical": true, "font_size": 23, "lines_coords": [[[173.0, 178.0], [195.0, 178.0], [195.0, 307.0], [173.0, 307.0]], [[132.0, 173.0], [159.0, 173.0], [160.0, 360.0], [134.0, 360.0]], [[100.0, 178.0], [121.0, 178.0], [121.0, 318.0], [100.0, 318.0]]], "lines": ["お母さんを", "あまり好きでは", "ありません。"]}, {"box": [829, 689, 968, 900], "vertical": true, "font_size": 28, "lines_coords": [[[935.0, 689.0], [967.0, 689.0], [967.0, 881.0], [935.0, 881.0]], [[901.0, 690.0], [929.0, 690.0], [926.0, 881.0], [898.0, 881.0]], [[865.0, 692.0], [892.0, 692.0], [892.0, 900.0], [865.0, 900.0]], [[829.0, 692.0], [856.0, 692.0], [856.0, 885.0], [829.0, 885.0]]], "lines": ["宿題、歯みがき、", "お風呂、片付け、", "ガミガミと、それ", "ばかり言います。"]}, {"box": [646, 439, 670, 554], "vertical": true, "font_size": 20, "lines_coords": [[[648.0, 442.0], [667.0, 442.0], [667.0, 465.0], [648.0, 465.0]], [[646.0, 500.0], [668.0, 500.0], [668.0, 550.0], [646.0, 550.0]]], "lines": ["う", "ん"]}, {"box": [98, 481, 199, 652], "vertical": true, "font_size": 25, "lines_coords": [[[170.0, 482.0], [198.0, 482.0], [198.0, 589.0], [170.0, 589.0]], [[131.0, 481.0], [157.0, 481.0], [157.0, 614.0], [131.0, 614.0]], [[100.0, 485.0], [121.0, 485.0], [121.0, 650.0], [100.0, 650.0]]], "lines": ["姉さんは", "相変わらず", "難しい人だね。"]}, {"box": [142, 937, 281, 1147], "vertical": true, "font_size": 27, "lines_coords": [[[250.0, 937.0], [278.0, 937.0], [281.0, 1068.0], [253.0, 1068.0]], [[215.0, 937.0], [242.0, 937.0], [242.0, 1145.0], [215.0, 1145.0]], [[179.0, 939.0], [206.0, 939.0], [206.0, 1071.0], [179.0, 1071.0]], [[142.0, 937.0], [168.0, 937.0], [168.0, 1081.0], [142.0, 1081.0]]], "lines": ["まだ帰って", "来なくてもいいと", "ブンブンは", "思いました。"]}, {"box": [89, 1334, 154, 1465], "vertical": true, "font_size": 30, "lines_coords": [[[120.0, 1334.0], [154.0, 1334.0], [154.0, 1442.0], [120.0, 1442.0]], [[89.0, 1335.0], [115.0, 1335.0], [115.0, 1465.0], [89.0, 1465.0]]], "lines": ["いいって", "いいって！！"]}], "img_path": "078.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [989, 65, 1018, 228], "vertical": true, "font_size": 26, "lines_coords": [[[989.0, 65.0], [1017.0, 65.0], [1018.0, 228.0], [990.0, 228.0]]], "lines": ["いやぃやいや、"]}, {"box": [826, 92, 925, 310], "vertical": true, "font_size": 26, "lines_coords": [[[898.0, 95.0], [925.0, 95.0], [925.0, 235.0], [898.0, 235.0]], [[860.0, 92.0], [887.0, 92.0], [887.0, 310.0], [860.0, 310.0]], [[826.0, 95.0], [848.0, 95.0], [848.0, 276.0], [826.0, 276.0]]], "lines": ["お義父さん、", "ちゃんと受け取って", "もらわないと！！"]}, {"box": [353, 131, 385, 267], "vertical": true, "font_size": 28, "lines_coords": [[[357.0, 131.0], [385.0, 131.0], [381.0, 267.0], [353.0, 267.0]]], "lines": ["ツァーオーギー"]}, {"box": [325, 131, 346, 267], "vertical": true, "font_size": 21, "lines_coords": [[[325.0, 131.0], [346.0, 131.0], [346.0, 267.0], [325.0, 267.0]]], "lines": ["はいめまして"]}, {"box": [315, 473, 382, 589], "vertical": true, "font_size": 30, "lines_coords": [[[354.0, 475.0], [382.0, 475.0], [382.0, 579.0], [354.0, 579.0]], [[315.0, 473.0], [350.0, 473.0], [350.0, 589.0], [315.0, 589.0]]], "lines": ["いやいや", "いやいや、"]}, {"box": [168, 485, 232, 668], "vertical": true, "font_size": 30, "lines_coords": [[[201.0, 485.0], [232.0, 485.0], [232.0, 668.0], [201.0, 668.0]], [[168.0, 487.0], [195.0, 487.0], [195.0, 667.0], [168.0, 667.0]]], "lines": ["いいんだって！！", "いいんだって！！"]}, {"box": [909, 725, 1009, 921], "vertical": true, "font_size": 28, "lines_coords": [[[981.0, 725.0], [1007.0, 725.0], [1007.0, 865.0], [981.0, 865.0]], [[943.0, 725.0], [975.0, 725.0], [975.0, 921.0], [943.0, 921.0]], [[909.0, 725.0], [935.0, 725.0], [935.0, 881.0], [909.0, 881.0]]], "lines": ["娘夫婦から、", "お代取れるワケ", "ないでショ！！"]}, {"box": [396, 1039, 495, 1204], "vertical": true, "font_size": 26, "lines_coords": [[[468.0, 1039.0], [495.0, 1039.0], [492.0, 1201.0], [465.0, 1201.0]], [[429.0, 1040.0], [457.0, 1040.0], [457.0, 1171.0], [429.0, 1171.0]], [[398.0, 1043.0], [420.0, 1043.0], [420.0, 1195.0], [398.0, 1195.0]]], "lines": ["あーそうだ。", "渡すものが", "あったんだ！"]}, {"box": [131, 782, 268, 967], "vertical": true, "font_size": 26, "lines_coords": [[[240.0, 784.0], [267.0, 784.0], [267.0, 915.0], [240.0, 915.0]], [[206.0, 785.0], [228.0, 785.0], [228.0, 940.0], [206.0, 940.0]], [[167.0, 782.0], [193.0, 782.0], [193.0, 967.0], [167.0, 967.0]], [[131.0, 784.0], [159.0, 784.0], [159.0, 889.0], [131.0, 889.0]]], "lines": ["そのお金は", "産まれてくる", "子供につかって", "やって！！"]}, {"box": [117, 1101, 185, 1235], "vertical": true, "font_size": 29, "lines_coords": [[[150.0, 1101.0], [182.0, 1101.0], [185.0, 1214.0], [153.0, 1214.0]], [[117.0, 1106.0], [143.0, 1106.0], [143.0, 1235.0], [117.0, 1235.0]]], "lines": ["ちょっと", "待ってて！！"]}], "img_path": "079.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [901, 140, 967, 314], "vertical": true, "font_size": 28, "lines_coords": [[[939.0, 142.0], [967.0, 142.0], [967.0, 250.0], [939.0, 250.0]], [[901.0, 140.0], [929.0, 140.0], [931.0, 314.0], [903.0, 314.0]]], "lines": ["．．．父さん", "変わったなー。"]}, {"box": [485, 290, 548, 450], "vertical": true, "font_size": 28, "lines_coords": [[[521.0, 290.0], [548.0, 290.0], [548.0, 450.0], [521.0, 450.0]], [[485.0, 292.0], [512.0, 292.0], [512.0, 435.0], [485.0, 435.0]]], "lines": ["もうすっかり", "好々爺だね。"]}, {"box": [309, 131, 410, 341], "vertical"