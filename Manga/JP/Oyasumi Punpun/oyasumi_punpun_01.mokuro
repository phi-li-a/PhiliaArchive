.0], [946.0, 437.0], [920.0, 437.0]], [[882.0, 304.0], [909.0, 304.0], [909.0, 439.0], [882.0, 439.0]], [[842.0, 303.0], [876.0, 303.0], [876.0, 387.0], [842.0, 387.0]]], "lines": ["今日やっぱ", "ＥＢＪ無理", "だ．．．"]}, {"box": [259, 103, 393, 315], "vertical": true, "font_size": 26, "lines_coords": [[[365.0, 106.0], [393.0, 106.0], [393.0, 214.0], [365.0, 214.0]], [[329.0, 103.0], [356.0, 103.0], [356.0, 315.0], [329.0, 315.0]], [[292.0, 104.0], [318.0, 104.0], [321.0, 290.0], [295.0, 290.0]], [[259.0, 106.0], [281.0, 106.0], [281.0, 235.0], [259.0, 235.0]]], "lines": ["あ．．．あと", "なんか母ちゃんも", "そろそろ帰って", "くるし．．．"]}, {"box": [867, 551, 970, 737], "vertical": true, "font_size": 30, "lines_coords": [[[937.0, 551.0], [970.0, 551.0], [970.0, 662.0], [937.0, 662.0]], [[901.0, 551.0], [932.0, 551.0], [932.0, 737.0], [901.0, 737.0]], [[867.0, 551.0], [893.0, 551.0], [893.0, 735.0], [867.0, 735.0]]], "lines": ["なんか．．．", "ビデオデッキが", "壊れちゃって．．"]}, {"box": [226, 396, 289, 507], "vertical": true, "font_size": 27, "lines_coords": [[[260.0, 396.0], [289.0, 396.0], [289.0, 504.0], [260.0, 504.0]], [[226.0, 396.0], [254.0, 396.0], [254.0, 507.0], [226.0, 507.0]]], "lines": ["あ、あと", "それと．．．"]}, {"box": [190, 568, 287, 740], "vertical": true, "font_size": 27, "lines_coords": [[[259.0, 568.0], [287.0, 568.0], [284.0, 704.0], [256.0, 704.0]], [[221.0, 570.0], [248.0, 570.0], [248.0, 740.0], [221.0, 740.0]], [[190.0, 575.0], [212.0, 575.0], [212.0, 729.0], [190.0, 729.0]]], "lines": ["さっきから", "なんかお腹が", "いたくて．．．"]}, {"box": [951, 1134, 1014, 1264], "vertical": true, "font_size": 28, "lines_coords": [[[987.0, 1134.0], [1014.0, 1134.0], [1014.0, 1264.0], [987.0, 1264.0]], [[951.0, 1134.0], [978.0, 1134.0], [978.0, 1239.0], [951.0, 1239.0]]], "lines": ["う．．．嘘じゃ", "ないよ！？"]}, {"box": [835, 1289, 940, 1473], "vertical": true, "font_size": 28, "lines_coords": [[[901.0, 1289.0], [940.0, 1289.0], [940.0, 1378.0], [901.0, 1378.0]], [[873.0, 1292.0], [895.0, 1292.0], [895.0, 1473.0], [873.0, 1473.0]], [[835.0, 1292.0], [859.0, 1292.0], [860.0, 1423.0], [837.0, 1423.0]]], "lines": ["本当に", "ビデオは部屋に", "あるし．．．．．"]}, {"box": [228, 1173, 295, 1306], "vertical": true, "font_size": 30, "lines_coords": [[[259.0, 1173.0], [292.0, 1173.0], [295.0, 1306.0], [262.0, 1306.0]], [[228.0, 1176.0], [256.0, 1176.0], [256.0, 1282.0], [228.0, 1282.0]]], "lines": ["てっ、でっ、", "でもっ！！"]}, {"box": [155, 1367, 225, 1526], "vertical": true, "font_size": 70, "lines_coords": [[[155.0, 1367.0], [225.0, 1367.0], [225.0, 1526.0], [155.0, 1526.0]]], "lines": ["今日は絶対ムリッ！！"]}, {"box": [157, 1368, 225, 1529], "vertical": true, "font_size": 30, "lines_coords": [[[192.0, 1368.0], [225.0, 1368.0], [225.0, 1454.0], [192.0, 1454.0]], [[157.0, 1371.0], [184.0, 1371.0], [184.0, 1529.0], [157.0, 1529.0]]], "lines": ["今日は", "絶対ムリッ！！"]}], "img_path": "091.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [601, 132, 711, 271], "vertical": true, "font_size": 28, "lines_coords": [[[673.0, 132.0], [701.0, 132.0], [701.0, 265.0], [673.0, 265.0]], [[637.0, 132.0], [665.0, 132.0], [665.0, 239.0], [637.0, 239.0]], [[601.0, 132.0], [628.0, 132.0], [628.0, 248.0], [601.0, 248.0]]], "lines": ["清水の野郎", "またウソ", "ついたな。"]}, {"box": [625, 332, 646, 415], "vertical": true, "font_size": 21, "lines_coords": [[[625.0, 334.0], [646.0, 334.0], [646.0, 357.0], [625.0, 357.0]]], "lines": ["う"]}, {"box": [96, 68, 381, 95], "vertical": false, "font_size": 27, "lines_coords": [[[96.0, 68.0], [381.0, 68.0], [381.0, 95.0], [96.0, 95.0]]], "lines": ["おやすみプンプン口"]}, {"box": [107, 221, 209, 415], "vertical": true, "font_size": 26, "lines_coords": [[[181.0, 221.0], [207.0, 221.0], [207.0, 404.0], [181.0, 404.0]], [[145.0, 223.0], [171.0, 223.0], [171.0, 381.0], [145.0, 381.0]], [[107.0, 221.0], [134.0, 221.0], [134.0, 414.0], [107.0, 414.0]]], "lines": ["どうせ最初から", "ビデオなんて", "無かったんだよ。"]}, {"box": [114, 468, 235, 673], "vertical": true, "font_size": 25, "lines_coords": [[[203.0, 468.0], [235.0, 468.0], [235.0, 584.0], [203.0, 584.0]], [[175.0, 468.0], [201.0, 468.0], [201.0, 651.0], [175.0, 651.0]], [[145.0, 470.0], [167.0, 470.0], [167.0, 673.0], [145.0, 673.0]], [[114.0, 471.0], [135.0, 471.0], [135.0, 582.0], [114.0, 582.0]]], "lines": ["いやいや、", "決めつけちゃあ", "シミちゃん、かわい", "そうだよ。"]}, {"box": [939, 751, 968, 918], "vertical": true, "font_size": 27, "lines_coords": [[[939.0, 751.0], [965.0, 751.0], [968.0, 918.0], [942.0, 918.0]]], "lines": ["．．．この前もさ、"]}, {"box": [804, 867, 903, 1056], "vertical": true, "font_size": 27, "lines_coords": [[[871.0, 867.0], [903.0, 867.0], [903.0, 1056.0], [871.0, 1056.0]], [[837.0, 870.0], [864.0, 870.0], [864.0, 1028.0], [837.0, 1028.0]], [[804.0, 871.0], [826.0, 871.0], [826.0, 1046.0], [804.0, 1046.0]]], "lines": ["「僕、かめはめ波", "撃てるように", "なった」っつって。"]}, {"box": [170, 881, 306, 1093], "vertical": true, "font_size": 28, "lines_coords": [[[279.0, 885.0], [306.0, 885.0], [306.0, 1090.0], [279.0, 1090.0]], [[243.0, 884.0], [270.0, 884.0], [268.0, 1068.0], [242.0, 1068.0]], [[203.0, 881.0], [234.0, 881.0], [234.0, 1093.0], [203.0, 1093.0]], [[170.0, 884.0], [196.0, 884.0], [196.0, 1079.0], [170.0, 1079.0]]], "lines": ["バッカじゃねーの", "って思ったけど", "「絶対できる」って", "言い張るからさ、"]}, {"box": [129, 1187, 229, 1345], "vertical": true, "font_size": 28, "lines_coords": [[[200.0, 1189.0], [228.0, 1189.0], [229.0, 1345.0], [201.0, 1345.0]], [[165.0, 1187.0], [192.0, 1187.0], [192.0, 1293.0], [165.0, 1293.0]], [[129.0, 1190.0], [156.0, 1190.0], [156.0, 1306.0], [129.0, 1306.0]]], "lines": ["パンダ公園で", "やらせて", "みたんだ。"]}], "img_path": "092.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [976, 135, 1000, 213], "vertical": true, "font_size": 24, "lines_coords": [[[976.0, 135.0], [1000.0, 135.0], [1000.0, 212.0], [976.0, 212.0]]], "lines": ["出た！？"]}, {"box": [837, 235, 935, 445], "vertical": true, "font_size": 26, "lines_coords": [[[907.0, 235.0], [934.0, 235.0], [934.0, 340.0], [907.0, 340.0]], [[871.0, 235.0], [900.0, 235.0], [901.0, 37