.0]]], "lines": ["．．．．．．オイ。"]}, {"box": [740, 612, 843, 772], "vertical": true, "font_size": 30, "lines_coords": [[[809.0, 612.0], [843.0, 612.0], [843.0, 701.0], [809.0, 701.0]], [[776.0, 617.0], [804.0, 617.0], [804.0, 721.0], [776.0, 721.0]], [[740.0, 617.0], [767.0, 617.0], [767.0, 768.0], [740.0, 768.0]]], "lines": ["なんで", "嘘なんか", "つくの．．．．．．？"]}, {"box": [590, 589, 618, 670], "vertical": true, "font_size": 28, "lines_coords": [[[590.0, 589.0], [618.0, 589.0], [618.0, 670.0], [590.0, 670.0]]], "lines": ["オイ！！"]}, {"box": [145, 671, 209, 778], "vertical": true, "font_size": 28, "lines_coords": [[[181.0, 673.0], [209.0, 673.0], [209.0, 778.0], [181.0, 778.0]], [[145.0, 671.0], [173.0, 671.0], [173.0, 765.0], [145.0, 765.0]]], "lines": ["なんとか", "言えよ。"]}, {"box": [189, 976, 311, 1104], "vertical": true, "font_size": 33, "lines_coords": [[[278.0, 976.0], [310.0, 976.0], [310.0, 1073.0], [278.0, 1073.0]], [[234.0, 976.0], [267.0, 976.0], [267.0, 1104.0], [234.0, 1104.0]], [[189.0, 978.0], [223.0, 978.0], [223.0, 1073.0], [189.0, 1073.0]]], "lines": ["なんか", "言えって", "オイ！！"]}], "img_path": "179.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [925, 634, 951, 793], "vertical": true, "font_size": 27, "lines_coords": [[[925.0, 634.0], [951.0, 634.0], [951.0, 793.0], [925.0, 793.0]]], "lines": ["．．．ぜったい．．．"]}, {"box": [340, 701, 404, 834], "vertical": true, "font_size": 27, "lines_coords": [[[376.0, 701.0], [404.0, 701.0], [404.0, 809.0], [376.0, 809.0]], [[340.0, 701.0], [367.0, 701.0], [367.0, 834.0], [340.0, 834.0]]], "lines": ["せっかく", "転校して．．．"]}, {"box": [762, 698, 890, 946], "vertical": true, "font_size": 27, "lines_coords": [[[864.0, 698.0], [890.0, 698.0], [890.0, 850.0], [864.0, 850.0]], [[828.0, 707.0], [859.0, 707.0], [859.0, 946.0], [828.0, 946.0]], [[796.0, 709.0], [823.0, 709.0], [823.0, 842.0], [796.0, 842.0]], [[762.0, 707.0], [789.0, 707.0], [790.0, 918.0], [764.0, 918.0]]], "lines": ["．．．ぜったい、", "クラスのみんなには", "見られた