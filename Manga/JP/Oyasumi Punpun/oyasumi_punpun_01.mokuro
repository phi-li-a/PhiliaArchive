ue, "font_size": 29, "lines_coords": [[[135.0, 989.0], [164.0, 989.0], [164.0, 1126.0], [135.0, 1126.0]]], "lines": ["．．．バイバイ。"]}, {"box": [531, 1359, 558, 1489], "vertical": true, "font_size": 26, "lines_coords": [[[531.0, 1359.0], [557.0, 1359.0], [557.0, 1489.0], [531.0, 1489.0]]], "lines": ["こんなの．．．"]}], "img_path": "181.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [895, 85, 961, 272], "vertical": true, "font_size": 26, "lines_coords": [[[934.0, 85.0], [960.0, 85.0], [959.0, 270.0], [932.0, 270.0]], [[896.0, 85.0], [923.0, 85.0], [921.0, 270.0], [895.0, 270.0]]], "lines": ["．．．どこか遠くに", "行きたいな．．．"]}, {"box": [87, 53, 371, 79], "vertical": false, "font_size": 26, "lines_coords": [[[87.0, 53.0], [371.0, 53.0], [371.0, 79.0], [87.0, 79.0]]], "lines": ["おやすみプンプン［"]}, {"box": [612, 498, 713, 670], "vertical": true, "font_size": 27, "lines_coords": [[[684.0, 500.0], [710.0, 500.0], [710.0, 656.0], [684.0, 656.0]], [[646.0, 498.0], [675.0, 498.0], [671.0, 670.0], [643.0, 670.0]], [[612.0, 500.0], [639.0, 500.0], [639.0, 632.0], [612.0, 632.0]]], "lines": ["誰も知らない", "ようなどこか", "遠くに．．．"]}, {"box": [198, 1353, 262, 1537], "vertical": true, "font_size": 27, "lines_coords": [[[232.0, 1353.0], [259.0, 1353.0], [259.0, 1464.0], [232.0, 1464.0]], [[198.0, 1356.0], [225.0, 1356.0], [225.0, 1537.0], [198.0, 1537.0]]], "lines": ["．．．なんで", "ついてくるの？"]}], "img_path": "182.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [885, 90, 1026, 315], "vertical": true, "font_size": 27, "lines_coords": [[[989.0, 92.0], [1021.0, 90.0], [1026.0, 237.0], [993.0, 239.0]], [[959.0, 93.0], [985.0, 93.0], [985.0, 315.0], [959.0, 315.0]], [[923.0, 93.0], [945.0, 93.0], [945.0, 275.0], [923.0, 275.0]], [[885.0, 93.0], [912.0, 93.0], [912.0, 262.0], [885.0, 262.0]]], "lines": ["．．．あたし、", "これから、鹿児島の", "親戚のおじさん", "所に行くから。"]}, {"box": [495, 112, 562, 229], "vertical": true, "font_size": 28, "lines_coords": [[[529.0, 1