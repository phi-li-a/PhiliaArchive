ont_size": 30, "lines_coords": [[[225.0, 1354.0], [253.0, 1354.0], [253.0, 1414.0], [225.0, 1414.0]]], "lines": ["．．．チ、"]}, {"box": [114, 1356, 145, 1514], "vertical": true, "font_size": 30, "lines_coords": [[[114.0, 1356.0], [145.0, 1356.0], [145.0, 1514.0], [114.0, 1514.0]]], "lines": ["チンク．．．．．．？"]}], "img_path": "084.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [765, 225, 938, 511], "vertical": true, "font_size": 24, "lines_coords": [[[914.0, 228.0], [935.0, 228.0], [935.0, 353.0], [914.0, 353.0]], [[876.0, 228.0], [898.0, 228.0], [898.0, 429.0], [876.0, 429.0]], [[840.0, 228.0], [862.0, 228.0], [862.0, 507.0], [840.0, 507.0]], [[800.0, 225.0], [826.0, 225.0], [829.0, 406.0], [803.0, 406.0]], [[765.0, 226.0], [792.0, 226.0], [792.0, 337.0], [765.0, 337.0]]], "lines": ["神様、神様", "チンクルホイ〟は", "三年前、雄一おしさんに", "教えてもらった", "呪文です。"]}, {"box": [625, 134, 690, 276], "vertical": true, "font_size": 32, "lines_coords": [[[660.0, 134.0], [690.0, 134.0], [690.0, 209.0], [660.0, 209.0]], [[625.0, 135.0], [651.0, 135.0], [651.0, 276.0], [625.0, 276.0]]], "lines": ["あぁー", "チンクルね、"]}, {"box": [521, 240, 590, 348], "vertical": true, "font_size": 32, "lines_coords": [[[562.0, 243.0], [590.0, 243.0], [590.0, 348.0], [562.0, 348.0]], [[521.0, 240.0], [564.0, 240.0], [564.0, 315.0], [521.0, 315.0]]], "lines": ["はいはい", "はい。"]}, {"box": [96, 237, 200, 356], "vertical": true, "font_size": 28, "lines_coords": [[[171.0, 240.0], [200.0, 240.0], [200.0, 345.0], [171.0, 345.0]], [[135.0, 239.0], [164.0, 239.0], [164.0, 353.0], [135.0, 353.0]], [[96.0, 237.0], [123.0, 237.0], [126.0, 354.0], [100.0, 354.0]]], "lines": ["チンクル", "チンクル、", "うんうん。"]}, {"box": [601, 462, 632, 557], "vertical": true, "font_size": 28, "lines_coords": [[[601.0, 462.0], [629.0, 462.0], [632.0, 557.0], [604.0, 557.0]]], "lines": ["．．．じゃ、"]}, {"box": [114, 506, 217, 675], "vertical": true, "font_size": 27, "lines_coords": [[[187.0, 506.0], [214.0, 506.0], [214.0, 675.0], [187.0, 675.0]], [[151.0, 506.0], [178.0, 506.0], [178.0, 639.0], [151.0, 639.0]], [[114.0, 506.0], [142.0, 506.0], [142.0, 598.0], [114.0, 598.0]]], "lines": ["これで、アイス", "ても買って", "帰りな。"]}, {"box": [268, 1082, 428, 1192], "vertical": false, "font_size": 99, "lines_coords": [[[276.0, 1082.0], [428.0, 1093.0], [420.0, 1192.0], [268.0, 1181.0]]], "lines": ["．．．"]}, {"box": [704, 1387, 889, 1467], "vertical": false, "font_size": 23, "lines_coords": [[[710.0, 1387.0], [889.0, 1445.0], [882.0, 1467.0], [704.0, 1409.0]]], "lines": ["みたひだひたひたぴたひ"]}, {"box": [266, 1322, 338, 1343], "vertical": false, "font_size": 23, "lines_coords": [[[266.0, 1320.0], [338.0, 1320.0], [338.0, 1345.0], [266.0, 1345.0]]], "lines": ["愛さや金を付けて"]}], "img_path": "085.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [878, 135, 946, 221], "vertical": true, "font_size": 29, "lines_coords": [[[912.0, 135.0], [946.0, 135.0], [946.0, 221.0], [912.0, 221.0]], [[878.0, 135.0], [909.0, 135.0], [909.0, 181.0], [878.0, 181.0]]], "lines": ["．．．神様", "ねー"]}, {"box": [881, 195, 904, 239], "vertical": true, "font_size": 29, "lines_coords": [[[881.0, 195.0], [904.0, 195.0], [904.0, 239.0], [881.0, 239.0]]], "lines": ["．．．"]}, {"box": [535, 132, 674, 320], "vertical": true, "font_size": 26, "lines_coords": [[[648.0, 135.0], [670.0, 135.0], [670.0, 292.0], [648.0, 292.0]], [[610.0, 135.0], [637.0, 135.0], [637.0, 276.0], [610.0, 276.0]], [[573.0, 134.0], [600.0, 134.0], [600.0, 293.0], [573.0, 293.0]], [[537.0, 132.0], [564.0, 132.0], [562.0, 320.0], [535.0, 320.0]]], "lines": ["神様が人間を", "作ったのか、", "人間が神様を", "作ったのか．．．"]}, {"box": [89, 64, 371, 90], "vertical": false, "font_size": 26, "lines_coords": [[[89.0, 64.0], [371.0, 64.0], [371.0, 90.0], [89.0, 90.0]]], "lines": ["おやすみプンプン□"]}, {"box": [125, 189, 228, 403], "vertical": true, "font_size": 28, "lines_coords": [[[189.0, 189.0], [228.0, 189.0], [228.0, 278.0], [189.0, 278.0]], [[156.0, 189.0], [187.0, 189.0], [184.0, 378.0], [153.0, 378.0]], [[125.0, 195.0], [146.0, 195.0], [146.0, 403.0], [125.0, 403.0]]], "lines": ["僕には", "どっちでもいい", "ことなんだけど。"]}, {"box": [126, 462, 226, 593], "vertical": true, "font_size": 28, "lines_coords": [[[203.0, 464.0], [226.0, 464.0], [226.0, 529.0], [203.0, 529.0]], [[164.0, 462.0], [190.0, 462.0], [190.0, 581.0], [164.0, 581.0]], [[126.0, 462.0], [153.0, 462.0], [153.0, 593.0], [126.0, 593.0]]], "lines": ["．．．まー", "結局人間", "なんて．．．"]}, {"box": [648, 837, 1026, 975], "vertical": false, "font_size": 32, "lines_coords": [[[671.0, 907.0], [976.0, 845.0], [982.0, 881.0], [678.0, 943.0]], [[731.0, 939.0], [945.0, 904.0], [948.0, 932.0], [735.0, 967.0]]], "lines": ["ローぐ、二輪車安全対策と", "この東京ご史全望会"]}, {"box": [231, 760, 289, 914], "vertical": true, "font_size": 29, "lines_coords": [[[260.0, 762.0], [289.0, 762.0], [289.0, 914.0], [260.0, 914.0]]], "lines": ["人間なんてっ"]}, {"box": [932, 1251, 962, 1321], "vertical": true, "font_size": 26, "lines_coords": [[[932.0, 1251.0], [962.0, 1251.0], [962.0, 1321.0], [932.0, 1321.0]]], "lines": ["いやー"]}, {"box": [873, 1335, 957, 1490], "vertical": true, "font_size": 26, "lines_coords": [[[937.0, 1335.0], [957.0, 1335.0], [957.0, 1379.0], [937.0, 1379.0]], [[873.0, 1379.0], [901.0, 1379.0], [901.0, 1490.0], [873.0, 1490.0]]], "lines": ["．．．", "これ以上"]}, {"box": [801, 1381, 864, 1542], "vertical": true, "font_size": 26, "lines_coords": [[[837.0, 1381.0], [864.0, 1381.0], [864.0, 1490.0], [837.0, 1490.0]], [[801.0, 1384.0], [828.0, 1384.0], [828.0, 1542.0], [801.0, 1542.0]]], "lines": ["言うのは", "止めとこう！"]}, {"box": [178, 1396, 204, 1515], "vertical": true, "font_size": 22, "lines_coords": [[[178.0, 1396.0], [200.0, 1396.0], [200.0, 1510.0], [178.0, 1510.0]]], "lines": ["うんうん"]}], "img_path": "086.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [859, 154, 929, 248], "vertical": true, "font_size": 34, "lines_coords": [[[895.0, 154.0], [929.0, 154.0], [929.0, 239.0], [895.0, 239.0]], [[859.0, 154.0], [8