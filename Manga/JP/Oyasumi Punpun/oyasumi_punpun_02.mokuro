1521.0], [220.0, 1521.0]], [[182.0, 1310.0], [210.0, 1310.0], [212.0, 1429.0], [184.0, 1429.0]]], "lines": ["プンプンはもう", "なにがなんだか", "わからなくなって", "きました。"]}], "img_path": "007.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [900, 174, 929, 320], "vertical": true, "font_size": 28, "lines_coords": [[[901.0, 203.0], [929.0, 203.0], [929.0, 320.0], [901.0, 320.0]]], "lines": ["．．．オイ。"]}, {"box": [170, 498, 295, 690], "vertical": true, "font_size": 36, "lines_coords": [[[259.0, 500.0], [292.0, 500.0], [295.0, 659.0], [262.0, 659.0]], [[218.0, 500.0], [251.0, 500.0], [251.0, 690.0], [218.0, 690.0]], [[170.0, 498.0], [212.0, 498.0], [212.0, 584.0], [170.0, 584.0]]], "lines": ["なに勝手に", "入って来てん", "だよ。"]}, {"box": [114, 1043, 217, 1228], "vertical": true, "font_size": 29, "lines_coords": [[[187.0, 1043.0], [215.0, 1043.0], [215.0, 1176.0], [187.0, 1176.0]], [[148.0, 1043.0], [179.0, 1043.0], [179.0, 1228.0], [148.0, 1228.0]], [[114.0, 1043.0], [142.0, 1043.0], [142.0, 1135.0], [114.0, 1135.0]]], "lines": ["プンプンは", "全力でひっこめ", "ました。"]}], "img_path": "008.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [193, 396, 227, 557], "vertical": true, "font_size": 33, "lines_coords": [[[193.0, 396.0], [226.0, 396.0], [226.0, 556.0], [193.0, 556.0]]], "lines": ["．．．小学生？"]}, {"box": [890, 789, 965, 962], "vertical": true, "font_size": 31, "lines_coords": [[[921.0, 789.0], [965.0, 789.0], [965.0, 860.0], [921.0, 860.0]], [[890.0, 790.0], [921.0, 790.0], [921.0, 962.0], [890.0, 962.0]]], "lines": ["いや、", "コメンゴメン。"]}, {"box": [684, 820, 839, 1043], "vertical": true, "font_size": 31, "lines_coords": [[[812.0, 821.0], [839.0, 821.0], [839.0, 931.0], [812.0, 931.0]], [[779.0, 821.0], [806.0, 821.0], [806.0, 1043.0], [779.0, 1043.0]], [[748.0, 821.0], [775.0, 821.0], [775.0, 1006.0], [748.0, 1006.0]], [[717.0, 821.0], [743.0, 821.0], [743.0, 1043.0], [717.0, 1043.0]], [[684.0, 820.0], [717.0, 820.0], [717.0, 917.0], [684.0, 917.0]]], "lines": ["たまーに", "ここらのヤンキーが", "ラブホがわりに", "来るから、ムカつい", "ててね。"]}, {"box": [132, 859, 273, 1045], "vertical": true, "font_size": 30, "lines_coords": [[[245.0, 862.0], [271.0, 862.0], [271.0, 995.0], [245.0, 995.0]], [[207.0, 860.0], [239.0, 860.0], [239.0, 1021.0], [207.0, 1021.0]], [[171.0, 862.0], [198.0, 862.0], [198.0, 1045.0], [171.0, 1045.0]], [[132.0, 859.0], [167.0, 859.0], [167.0, 931.0], [132.0, 931.0]]], "lines": ["今日こそは", "追っぱらって", "やろうと思って", "てさ。"]}, {"box": [869, 1114, 1006, 1293], "vertical": true, "font_size": 26, "lines_coords": [[[979.0, 1115.0], [1006.0, 1115.0], [1006.0, 1275.0], [979.0, 1275.0]], [[942.0, 1114.0], [968.0, 1114.0], [968.0, 1220.0], [942.0, 1220.0]], [[907.0, 1115.0], [934.0, 1115.0], [934.0, 1290.0], [907.0, 1290.0]], [[870.0, 1117.0], [896.0, 1117.0], [896.0, 1275.0], [870.0, 1275.0]]], "lines": ["．．．なーに！？", "なーに", "びびってんだよ、", "大丈夫だよ！！"]}, {"box": [446, 1121, 583, 1315], "vertical": true, "font_size": 26, "lines_coords": [[[554.0, 1121.0], [582.0, 1121.0], [579.0, 1306.0], [551.0, 1306.0]], [[518.0, 1121.0], [545.0, 1121.0], [545.0, 1281.0], [518.0, 1281.0]], [[481.0, 1121.0], [507.0, 1121.0], [507.0, 1281.0], [481.0, 1281.0]], [[446.0, 1121.0], [468.0, 1121.0], [468.0, 1312.0], [446.0, 1312.0]]], "lines": ["立入禁止なんて", "看板あるけど", "関係者なんて", "見たことないし。"]}, {"box": [91, 1207, 174, 1553], "vertical": true, "font_size": 25, "lines_coords": [[[146.0, 1207.0], [173.0, 1207.0], [173.0, 1326.0], [146.0, 1326.0]], [[126.0, 1370.0], [153.0, 1370.0], [153.0, 1528.0], [126.0, 1528.0]], [[93.0, 1370.0], [115.0, 1370.0], [115.0, 1551.0], [93.0, 1551.0]]], "lines": ["あの～～～", "おねーさんは", "ここで何を．．．？"]}], "img_path": "009.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [915, 62, 937, 192], "vertical": true, "font_size": 26, "lines_coords": [[[915.0, 62.0], [937.0, 62.0], [937.0, 192.0], [915.0, 192.0]]], "lines": ["．．．あたし？"]}, {"box": [704, 81, 843, 262], "vertical": true, "font_size": 26,