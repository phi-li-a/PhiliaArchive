1301.0], [679.0, 1323.0], [671.0, 1357.0], [573.0, 1335.0]]], "lines": ["？？０６．０５"]}, {"box": [99, 1306, 198, 1502], "vertical": true, "font_size": 25, "lines_coords": [[[170.0, 1306.0], [196.0, 1306.0], [196.0, 1476.0], [170.0, 1476.0]], [[132.0, 1306.0], [160.0, 1306.0], [160.0, 1439.0], [132.0, 1439.0]], [[101.0, 1309.0], [123.0, 1309.0], [123.0, 1501.0], [101.0, 1501.0]]], "lines": ["僕にはただの", "逃避にしか", "思えなかったな。"]}], "img_path": "118.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [887, 168, 987, 351], "vertical": true, "font_size": 26, "lines_coords": [[[960.0, 170.0], [987.0, 170.0], [987.0, 351.0], [960.0, 351.0]], [[923.0, 170.0], [950.0, 170.0], [950.0, 301.0], [923.0, 301.0]], [[887.0, 168.0], [914.0, 168.0], [914.0, 326.0], [887.0, 326.0]]], "lines": ["だって姉さんは", "結局戻って", "きたからね！"]}, {"box": [253, 137, 318, 321], "vertical": true, "font_size": 24, "lines_coords": [[[292.0, 140.0], [318.0, 140.0], [318.0, 321.0], [292.0, 321.0]], [[253.0, 137.0], [279.0, 137.0], [282.0, 296.0], [256.0, 296.0]]], "lines": ["すべてを捨てる", "という覚悟！！"]}, {"box": [778, 346, 875, 529], "vertical": true, "font_size": 26, "lines_coords": [[[845.0, 346.0], [873.0, 346.0], [875.0, 503.0], [846.0, 503.0]], [[810.0, 346.0], [837.0, 346.0], [837.0, 529.0], [810.0, 529.0]], [[778.0, 348.0], [798.0, 348.0], [798.0, 529.0], [778.0, 529.0]]], "lines": ["つまり、その", "程度の覚悟って", "ことなんだよ！！"]}, {"box": [704, 676, 727, 814], "vertical": true, "font_size": 20, "lines_coords": [[[706.0, 681.0], [726.0, 681.0], [726.0, 807.0], [706.0, 807.0]]], "lines": ["．．．．．きっと"]}, {"box": [493, 676, 556, 883], "vertical": true, "font_size": 63, "lines_coords": [[[493.0, 676.0], [556.0, 676.0], [556.0, 883.0], [493.0, 883.0]]], "lines": ["．．．きっと愛子ちゃんだって"]}, {"box": [375, 673, 560, 888], "vertical": true, "font_size": 26, "lines_coords": [[[531.0, 673.0], [557.0, 673.0], [557.0, 781.0], [531.0, 781.0]], [[493.0, 676.0], [520.0, 676.0], [520.0, 884.0], [493.0, 884.0]]], "lines": ["．．．きっと", "愛子ちゃんだって"]}, {"box": [334, 673, 442, 885], "vertical": true, "font_size": 27, "lines_coords": [[[409.0, 673.0], [435.0, 673.0], [437.0, 882.0], [410.0, 882.0]], [[371.0, 676.0], [400.0, 676.0], [400.0, 806.0], [371.0, 806.0]], [[334.0, 673.0], [360.0, 673.0], [364.0, 817.0], [337.0, 817.0]]], "lines": ["とってもとっくも", "怖いに違い", "ありません。"]}, {"box": [115, 387, 245, 570], "vertical": true, "font_size": 24, "lines_coords": [[[223.0, 389.0], [245.0, 389.0], [245.0, 568.0], [223.0, 568.0]], [[184.0, 387.0], [210.0, 387.0], [210.0, 570.0], [184.0, 570.0]], [[148.0, 387.0], [175.0, 387.0], [175.0, 545.0], [148.0, 545.0]], [[115.0, 389.0], [135.0, 389.0], [135.0, 542.0], [115.0, 542.0]]], "lines": ["その対価として", "与えられるのが", "真の自由だと", "思うんだよ！！"]}, {"box": [848, 929, 991, 1182], "vertical": true, "font_size": 29, "lines_coords": [[[962.0, 931.0], [989.0, 931.0], [989.0, 1150.0], [962.0, 1150.0]], [[920.0, 929.0], [951.0, 929.0], [951.0, 1150.0], [920.0, 1150.0]], [[884.0, 931.0], [915.0, 931.0], [915.0, 1182.0], [884.0, 1182.0]], [[850.0, 931.0], [876.0, 931.0], [876.0, 1181.0], [850.0, 1181.0]]], "lines": ["でもボカァね！！", "その自由の先に", "本当の幸せがある", "なんて思わない！！"]}, {"box": [428, 1003, 574, 1287], "vertical": true, "font_size": 31, "lines_coords": [[[539.0, 1003.0], [570.0, 1003.0], [570.0, 1287.0], [539.0, 1287.0]], [[501.0, 1003.0], [532.0, 1003.0], [532.0, 1285.0], [501.0, 1285.0]], [[464.0, 1004.0], [495.0, 1004.0], [495.0, 1257.0], [464.0, 1257.0]], [[428.0, 1004.0], [459.0, 1004.0], [459.0, 1257.0], [428.0, 1257.0]]], "lines": ["なぜなら「幸せ」とは", "その「瞬間」であって", "恒久的なものでは", "決してないから！！"]}, {"box": [151, 1110, 190, 1209], "vertical": true, "font_size": 34, "lines_coords": [[[151.0, 1110.0], [190.0, 1110.0], [190.0, 1209.0], [151.0, 1209.0]]], "lines": ["嗚呼！！"]}, {"box": [741, 1323, 880, 1535], "vertical": true, "font_size": 29, "lines_coords": [[[848.0, 1323.0], [879.0, 1323.0], [879.0, 1482.0], [848.0, 1482.0]], [[815.0, 1325.0], [842.0, 1325.0], [842.0, 1481.0], [815.0, 1481.0]], [[773.0, 1323.0], [804.0, 1323.0], [807.0, 1481.0], [776.0, 1481.0]], [[743.0, 1325.0], [770.0, 1325.0], [770.0, 1532.0], [743.0, 1532.0]]], "lines": ["愛子ちゃんも", "おじけついて", "約束の場所に", "来ていなかったら"]}, {"box": [546, 1321, 684, 1481], "vertical": true, "font_size": 28, "lines_coords": [[[651.0, 1321.0], [684.0, 1321.0], [684.0, 1429.0], [651.0, 1429.0]], [[615.0, 1323.0], [646.0, 1323.0], [646.0, 1481.0], [615.0, 1481.0]], [[581.0, 1323.0], [607.0, 1323.0], [607.0, 1453.0], [581.0, 1453.0]], [[548.0, 1325.0], [570.0, 1325.0], [570.0, 1460.0], [548.0, 1460.0]]], "lines": ["どれだけ", "いいだろうと", "フンフンは", "思いました。"]}, {"box": [93, 1282, 256, 1537], "vertical": true, "font_size": 34, "lines_coords": [[[223.0, 1284.0], [256.0, 1284.0], [256.0, 1506.0], [223.0, 1506.0]], [[179.0, 1282.0], [212.0, 1282.0], [212.0, 1473.0], [179.0, 1473.0]], [[137.0, 1282.0], [168.0, 1282.0], [168.0, 1537.0], [137.0, 1537.0]], [[93.0, 1284.0], [125.0, 1284.0], [125.0, 1535.0], [93.0, 1535.0]]], "lines": ["人はいつだって", "ありもしない", "真実を追い求める", "人生の迷い人だ！！"]}], "img_path": "119.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [615, 76, 787, 340], "vertical": true, "font_size": 27, "lines_coords": [[[759.0, 78.0], [785.0, 78.0], [785.0, 262.0], [759.0, 262.0]], [[725.0, 79.0], [751.0, 79.0], [751.0, 312.0], [725.0, 312.0]], [[685.0, 78.0], [712.0, 78.0], [715.0, 326.0], [689.0, 326.0]], [[646.0, 76.0], [678.0, 76.0], [681.0, 340.0], [650.0, 340.0]], [[615.0, 81.0], [639.0, 81.0], [640.0, 318.0], [617.0, 318.0]]], "lines": ["．．．もしかしたら", "今頃、愛子ちゃんも", "ふるえながら、お家で", "チョコパイでも食べて", "いるのかもしれない。"]}, {"box": [454, 78, 556, 286], "vertical": true, "font_size": 24, "lines_coords": [[[526.0, 79.0], [553.0, 79.0], [553.0, 212.0], [526.0, 212.0]], [[493.0, 81.0], [515.0, 81.0], [515.0, 281.0], [493.0, 281.0]], [[456.0, 79.0], [478.0, 79.0], [478.0, 257.0], [456.0, 257.0]]], "lines": ["だとしたら、", "なんて自分勝手な", "子なのだろう！！"]}, {"box": [294, 76, 394, 327], "vertical": true, "font_size": 25, "lines_coords": [[[365.0, 76.0], [392.0, 76.0], [390.0, 325.0], [364.0, 325.0]], [[329.0, 79.0], [356.0, 79.0], [356.0, 234.0], [329.0, 234.0]], [[296.0, 82.0], [318.0, 82.0], [318.0, 268.0], [296.0, 268.0]]], "lines": ["プンプンは、だんだん", "そんな気分に", "なってきました。"]}, {"box": [835, 420, 984, 650], "vertical": true, "font_size": 40, "lines_coords": [[[945.0, 423.0], [984.0, 423.0], [984.0, 610.0], [945.0, 610.0]], [[893.0, 426.0], [931.0, 426.0], [931.0, 610.0], [893.0, 610.0]], [[840.0, 420.0], [884.0, 420.0], [879.0, 650.0], [835.0, 650.0]]], "lines": ["だから僕わ", "いつだって", "悲しいんだ！！"]}, {"box": [68, 517, 234, 743], "vertical": true, "font_size": 37, "lines_coords": [[[195.0, 518.0], [234.0, 518.0], [231.0, 707.0], [192.0, 707.0]], [[151.0, 520.0], [190.0, 520.0], [190.0, 704.0], [151.0, 704.0]], [[106.0, 517.0], [143.0, 517.0], [143.0, 743.0], [106.0, 743.0]], [[68.0, 521.0], [100.0, 521.0], [100.0, 706.0], [68.0, 706.0]]], "lines": ["人はなんて", "強欲で弱い", "生き物なんだ", "ろうって！！"]}, {"box": [582, 884, 757, 1084], "vertical": true, "font_size": 31, "lines_coords": [[[725.0, 884.0], [757.0, 884.0], [757.0, 1067.0], [725.0, 1067.0]], [[692.0, 887.0], [718.0, 887.0], [718.0, 1045.0], [692.0, 1045.0]], [[654.0, 884.0], [687.0, 884.0], [684.0, 1084.0], [651.0, 1084.0]], [[617.0, 887.0], [648.0, 887.0], [648.0, 1046.0], [617.0, 1046.0]], [[582.0, 885.0], [614.0, 885.0], [614.0, 1071.0], [582.0, 1071.0]]], "lines": ["「な～～～んだ。", "愛子ちゃんも", "実は、いくじなし", "なのだね～～", "ゃーいやーい。」"]}, {"box": [315, 884, 492, 1120], "vertical": true, "font_size": 28, "lines_coords": [[[462.0, 887.0], [489.0, 887.0], [489.0, 1045.0], [462.0, 1045.0]], [[426.0, 887.0], [453.0, 887.0], [453.0, 1120.0], [426.0, 1120.0]], [[390.0, 887.0], [417.0, 887.0], [417.0, 1107.0], [390.0, 1107.0]], [[354.0, 887.0], [381.0, 887.0], [381.0, 1068.0], [354.0, 1068.0]], [[315.0, 884.0], [348.0, 884.0], [348.0, 979.0], [315.0, 979.0]]], "lines": ["次に会ったら", "こう言ってやろうと", "思うと、ブンフンは", "むしろウキウキ", "でした。"]}, {"box": [870, 1229, 917, 1476], "vertical": true, "font_size": 38, "lines_coords": [[[870.0, 1229.0], [914.0, 1229.0], [917.0, 1476.0], [873.0, 1476.0]]], "lines": ["人間なんてっ"]}, {"box": [821, 1278, 854, 1395], "vertical": true, "font_size": 38, "lines_coords": [[[821.0, 1278.0], [854.0, 1278.0], [854.0, 1395.0], [821.0, 1395.0]]], "lines": ["．．．"]}], "img_path": "120.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "121.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "122.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [946, 76, 975, 179], "vertical": true, "font_size": 34, "lines_coords": [[[946.0, 76.0], [975.0, 76.0], [975.0, 179.0], [946.0, 179.0]]], "lines": ["ハァッ．．．"]}, {"box": [889, 198, 928, 284], "vertical": true, "font_size": 34, "lines_coords": [[[889.0, 198.0], [928.0, 198.0], [928.0, 284.0], [889.0, 284.0]]], "lines": ["ハァ．．．"]}, {"box": [485, 57, 581, 292], "vertical": true, "font_size": 26, "lines_coords": [[[554.0, 57.0], [581.0, 57.0], [581.0, 192.0], [554.0, 192.0]], [[518.0, 57.0], [545.0, 57.0], [545.0, 292.0], [518.0, 292.0]], [[485.0, 59.0], [507.0, 59.0], [507.0, 256.0], [485.0, 256.0]]], "lines": ["．．．ゴメン．．．", "オジさん、ちょっぴり", "ヒートしちゃった。"]}, {"box": [379, 279, 515, 434], "vertical": true, "font_size": 26, "lines_coords": [[[489.0, 279.0], [515.0, 279.0], [515.0, 401.0], [489.0, 401.0]], [[451.0, 293.0], [478.0, 293.0], [478.0, 428.0], [451.0, 428.0]], [[414.0, 292.0], [442.0, 292.0], [442.0, 434.0], [414.0, 434.0]], [[379.0, 292.0], [406.0, 292.0], [406.0, 426.0], [379.0, 426.0]]], "lines": ["．．．独り言", "だから気に", "しないでね、", "プンプン．．．"]}, {"box": [865, 654, 895, 811], "vertical": true, "font_size": 30, "lines_coords": [[[865.0, 656.0], [895.0, 656.0], [895.0, 810.0], [865.0, 810.0]]], "lines": ["．．．プンプン？"]}, {"box": [346, 543, 392, 573], "vertical": false, "font_size": 30, "lines_coords": [[[346.0, 543.0], [392.0, 543.0], [392.0, 573.0], [346.0, 573.0]]], "lines": ["認識"]}, {"box": [676, 956, 778, 1096], "vertical": true, "font_size": 28, "lines_coords": [[[748.0, 956.0], [776.0, 956.0], [776.0, 1093.0], [748.0, 1093.0]], [[710.0, 956.0], [739.0, 956.0], [739.0, 1059.0], [710.0, 1059.0]], [[676.0, 956.0], [704.0, 956.0], [704.0, 1050.0], [676.0, 1050.0]]], "lines": ["プン山さん、", "こちらへ", "どうぞ。"]}], "img_path": "126.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [867, 162, 969, 387], "vertical": true, "font_size": 28, "lines_coords": [[[942.0, 165.0], [968.0, 165.0], [968.0, 303.0], [942.0, 303.0]], [[903.0, 162.0], [934.0, 162.0], [934.0, 335.0], [903.0, 335.0]], [[868.0, 162.0], [895.0, 162.0], [893.0, 387.0], [867.0, 387.0]]], "lines": ["．．．．．姉さん、", "まずはじめに", "言わせてもらうよ。"]}, {"box": [353, 111, 413, 293], "vertical": true, "font_size": 24, "lines_coords": [[[354.0, 112.0], [378.0, 112.0], [376.0, 293.0], [353.0, 293.0]]], "lines": ["ふざけんなよ？"]}, {"box": [582, 537, 684, 745], "vertical": true, "font_size": 26, "lines_coords": [[[657.0, 537.0], [684.0, 537.0], [684.0, 721.0], [657.0, 721.0]], [[623.0, 537.0], [645.0, 537.0], [645.0, 745.0], [623.0, 745.0]], [[584.0, 537.0], [610.0, 537.0], [609.0, 718.0], [582.0, 718.0]]], "lines": ["．．．何よ、あたし", "別に飛び降りた訳", "じゃないわよ？"]}, {"box": [454, 603, 557, 776], "vertical": true, "font_size": 26, "lines_coords": [[[526.0, 603.0], [557.0, 603.0], [557.0, 764.0], [526.0, 764.0]], [[492.0, 606.0], [518.0, 606.0], [518.0, 737.0], [492.0, 737.0]], [[454.0, 603.0], [481.0, 603.0], [482.0, 776.0], [456.0, 776.0]]], "lines": ["ちょっと手が", "滑ったって", "だけじゃない。"]}, {"box": [489, 860, 643, 1082], "vertical": true, "font_size": 26, "lines_coords": [[[610.0, 860.0], [643.0, 860.0], [643.0, 1025.0], [610.0, 1025.0]], [[581.0, 864.0], [609.0, 864.0], [609.0, 996.0], [581.0, 996.0]], [[551.0, 864.0], [573.0, 864.0], [573.0, 1071.0], [551.0, 1071.0]], [[520.0, 865.0], [542.0, 865.0], [542.0, 1079.0], [520.0, 1079.0]], [[489.0, 864.0], [515.0, 864.0], [515.0, 995.0], [489.0, 995.0]]], "lines": ["あーそう！！", "手が滑って", "３階から転落する", "なんて器用ですな。", "姉さんは！！"]}, {"box": [231, 1032, 356, 1256], "vertical": true, "font_size": 27, "lines_coords": [[[328.0, 1032.0], [354.0, 1032.0], [356.0, 1256.0], [329.0, 1256.0]], [[296.0, 1032.0], [323.0, 1032.0], [323.0, 1200.0], [296.0, 1200.0]], [[264.0, 1034.0], [290.0, 1034.0], [290.0, 1242.0], [264.0, 1242.0]], [[231.0, 1035.0], [259.0, 1035.0], [259.0, 1175.0], [231.0, 1175.0]]], "lines": ["．．．とにかく、退院は", "予定通り明日、", "骨折は通院だけで", "いいってさ。"]}, {"box": [925, 1150, 1025, 1335], "vertical": true, "font_size": 26, "lines_coords": [[[996.0, 1151.0], [1025.0, 1151.0], [1025.0, 1242.0], [996.0, 1242.0]], [[960.0, 1151.0], [987.0, 1151.0], [987.0, 1335.0], [960.0, 1335.0]], [[925.0, 1150.0], [946.0, 1150.0], [946.0, 1318.0], [925.0, 1318.0]]], "lines": ["じゃあ、", "足が滑ったって", "ことにするわ。"]}, {"box": [484, 1145, 588, 1306], "vertical": true, "font_size": 27, "lines_coords": [[[557.0, 1145.0], [585.0, 1145.0], [587.0, 1306.0], [559.0, 1306.0]], [[521.0, 1146.0], [548.0, 1146.0], [548.0, 1260.0], [521.0, 1260.0]], [[484.0, 1145.0], [510.0, 1145.0], [514.0, 1279.0], [487.0, 1279.0]]], "lines": ["「じゃあ」って", "なんだよ、", "あんた．．．"]}, {"box": [121, 1295, 279, 1532], "vertical": true, "font_size": 27, "lines_coords": [[[253.0, 1296.0], [279.0, 1296.0], [279.0, 1510.0], [253.0, 1510.0]], [[220.0, 1295.0], [246.0, 1295.0], [243.0, 1532.0], [217.0, 1532.0]], [[182.0, 1295.0], [214.0, 1295.0], [214.0, 1509.0], [182.0, 1509.0]], [[153.0, 1296.0], [179.0, 1296.0], [179.0, 1456.0], [153.0, 1456.0]], [[121.0, 1296.0], [143.0, 1296.0], [143.0, 1504.0], [121.0, 1504.0]]], "lines": ["あなたとプンプン、", "二人きりじゃ何かと", "不安だから、僕も", "しばらく居候", "させてもらうよ．．．"]}], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [737, 48, 803, 210], "vertical": true, "font_size": 30, "lines_coords": [[[770.0, 48.0], [803.0, 48.0], [803.0, 129.0], [770.0, 129.0]], [[737.0, 50.0], [764.0, 50.0], [764.0, 207.0], [737.0, 207.0]]], "lines": ["あらー", "助かるワァ！！"]}, {"box": [631, 54, 798, 498], "vertical": true, "font_size": 26, "lines_coords": [[[725.0, 253.0], [753.0, 253.0], [753.0, 334.0], [725.0, 334.0]], [[692.0, 251.0], [718.0, 251.0], [721.0, 448.0], [695.0, 448.0]], [[664.0, 253.0], [690.0, 253.0], [690.0, 498.0], [664.0, 498.0]], [[631.0, 254.0], [657.0, 254.0], [657.0, 412.0], [631.0, 412.0]]], "lines": ["右手は", "このとーりだし、", "家事全般任せちゃって", "いいかしら！？"]}, {"box": [157, 337, 307, 573], "vertical": true, "font_size": 26, "lines_coords": [[[279.0, 339.0], [307.0, 339.0], [307.0, 443.0], [279.0, 443.0]], [[250.0, 337.0], [276.0, 337.0], [276.0, 496.0], [250.0, 496.0]], [[218.0, 339.0], [245.0, 339.0], [245.0, 573.0], [218.0, 573.0]], [[185.0, 337.0], [212.0, 337.0], [212.0, 573.0], [185.0, 573.0]], [[157.0, 339.0], [179.0, 339.0], [179.0, 546.0], [157.0, 546.0]]], "lines": ["駐輪場の", "トタン屋根が", "クッションになって", "奇跡的にその程度の", "怪我らしいけど．．．"]}, {"box": [228, 642, 326, 823], "vertical": true, "font_size": 26, "lines_coords": [[[300.0, 642.0], [326.0, 642.0], [326.0, 750.0], [300.0, 750.0]], [[262.0, 643.0], [289.0, 643.0], [289.0, 801.0], [262.0, 801.0]], [[228.0, 643.0], [250.0, 643.0], [250.0, 823.0], [228.0, 823.0]]], "lines": ["．．．なんて", "無意味な奇跡", "なんだろうね！！"]}, {"box": [856, 950, 954, 1093], "vertical": true, "font_size": 25, "lines_coords": [[[928.0, 951.0], [954.0, 951.0], [954.0, 1082.0], [928.0, 1082.0]], [[892.0, 950.0], [918.0, 950.0], [918.0, 1082.0], [892.0, 1082.0]], [[857.0, 951.0], [879.0, 951.0], [879.0, 1087.0], [857.0, 1087.0]]], "lines": ["．．．アンタも", "言うように", "なったわね。"]}, {"box": [139, 1339, 201, 1496], "vertical": true, "font_size": 24, "lines_coords": [[[173.0, 1339.0], [201.0, 1339.0], [201.0, 1456.0], [173.0, 1456.0]], [[139.0, 1340.0], [160.0, 1340.0], [160.0, 1495.0], [139.0, 1495.0]]], "lines": ["．．．．．．ボク、", "どうしたの？"]}], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [187, 507, 248, 641], "vertical": true, "font_size": 28, "lines_coords": [[[218.0, 510.0], [246.0, 510.0], [246.0, 640.0], [218.0, 640.0]]], "lines": ["プンプンは"]}, {"box": [470, 1196, 609, 1408], "vertical": true, "font_size": 28, "lines_coords": [[[575.0, 1196.0], [609.0, 1196.0], [609.0, 1279.0], [575.0, 1279.0]], [[543.0, 1198.0], [570.0, 1198.0], [570.0, 1381.0], [543.0, 1381.0]], [[507.0, 1198.0], [534.0, 1198.0], [534.0, 1406.0], [507.0, 1406.0]], [[470.0, 1198.0], [496.0, 1198.0], [496.0, 1339.0], [470.0, 1339.0]]], "lines": ["今なら", "地球が爆発して", "しまってもいいと", "思いました。"]}], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "130.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "131.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [28, 271, 78, 439], "vertical": true, "font_size": 50, "lines_coords": [[[28.0, 271.0], [78.0, 271.0], [78.0, 439.0], [28.0, 439.0]]], "lines": ["第２０話"]}, {"box": [110, 1085, 171, 1220], "vertical": true, "font_size": 27, "lines_coords": [[[145.0, 1089.0], [171.0, 1089.0], [171.0, 1214.0], [145.0, 1214.0]], [[110.0, 1085.0], [137.0, 1085.0], [137.0, 1220.0], [110.0, 1220.0]]], "lines": ["ただいまー", "ーーって．．．"]}, {"box": [951, 1328, 978, 1434], "vertical": true, "font_size": 24, "lines_coords": [[[951.0, 1328.0], [978.0, 1328.0], [978.0, 1434.0], [951.0, 1434.0]]], "lines": ["ただいま"]}, {"box": [918, 1381, 940, 1431], "vertical": true, "font_size": 24, "lines_coords": [[[918.0, 1381.0], [940.0, 1381.0], [940.0, 1431.0], [918.0, 1431.0]]], "lines": ["！！"]}, {"box": [176, 1320, 242, 1451], "vertical": true, "font_size": 27, "lines_coords": [[[209.0, 1320.0], [242.0, 1320.0], [242.0, 1431.0], [209.0, 1431.0]], [[176.0, 1326.0], [198.0, 1326.0], [198.0, 1451.0], [176.0, 1451.0]]], "lines": ["プンプン", "いないのー"]}], "img_path": "132.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [812, 109, 921, 246], "vertical": true, "font_size": 32, "lines_coords": [[[893.0, 114.0], [921.0, 114.0], [921.0, 228.0], [893.0, 228.0]], [[853.0, 115.0], [881.0, 115.0], [884.0, 246.0], [856.0, 246.0]], [[812.0, 110.0], [853.0, 109.0], [856.0, 185.0], [815.0, 187.0]]], "lines": ["．．．なによ、", "いるんじゃ", "ない。"]}, {"box": [178, 82, 242, 292], "vertical": true, "font_size": 27, "lines_coords": [[[212.0, 82.0], [240.0, 82.0], [242.0, 243.0], [214.0, 243.0]], [[178.0, 84.0], [204.0, 84.0], [204.0, 292.0], [178.0, 292.0]]], "lines": ["ただいまって", "言ってんでしょ！！"]}, {"box": [823, 993, 884, 1151], "vertical": true, "font_size": 24, "lines_coords": [[[857.0, 993.0], [884.0, 993.0], [884.0, 1125.0], [857.0, 1125.0]], [[825.0, 995.0], [846.0, 995.0], [846.0, 1151.0], [825.0, 1151.0]]], "lines": ["．．．なんとか", "言えっつの！！"]}], "img_path": "133.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [804, 56, 873, 216], "vertical": true, "font_size": 30, "lines_coords": [[[839.0, 56.0], [873.0, 56.0], [873.0, 142.0], [839.0, 142.0]], [[804.0, 57.0], [831.0, 57.0], [831.0, 210.0], [804.0, 210.0]]], "lines": ["な．．．．．", "なによ．．．．．．？"]}, {"box": [584, 412, 648, 588], "vertical": true, "font_size": 24, "lines_coords": [[[623.0, 414.0], [645.0, 414.0], [645.0, 587.0], [623.0, 587.0]], [[584.0, 412.0], [610.0, 412.0], [610.0, 570.0], [584.0, 570.0]]], "lines": ["なっ．．．なんなの", "その顔はっ！！"]}, {"box": [90, 504, 218, 698], "vertical": true, "font_size": 34, "lines_coords": [[[178.0, 507.0], [212.0, 506.0], [218.0, 648.0], [184.0, 650.0]], [[137.0, 507.0], [170.0, 507.0], [170.0, 698.0], [137.0, 698.0]], [[90.0, 504.0], [125.0, 504.0], [125.0, 603.0], [90.0, 603.0]]], "lines": ["．．．．．．やっ、",