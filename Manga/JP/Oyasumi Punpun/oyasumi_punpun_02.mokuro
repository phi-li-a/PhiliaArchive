．"]}, {"box": [262, 240, 362, 420], "vertical": true, "font_size": 26, "lines_coords": [[[335.0, 243.0], [362.0, 243.0], [362.0, 403.0], [335.0, 403.0]], [[298.0, 243.0], [325.0, 243.0], [325.0, 420.0], [298.0, 420.0]], [[262.0, 240.0], [289.0, 240.0], [292.0, 350.0], [265.0, 350.0]]], "lines": ["大丈夫なの？", "明日から二学期", "てしょ？"]}, {"box": [754, 403, 820, 534], "vertical": true, "font_size": 26, "lines_coords": [[[792.0, 403.0], [820.0, 403.0], [817.0, 534.0], [789.0, 534.0]], [[754.0, 404.0], [782.0, 404.0], [782.0, 509.0], [754.0, 509.0]]], "lines": ["小松君から", "電話だよ"]}, {"box": [723, 457, 745, 481], "vertical": true, "font_size": 26, "lines_coords": [[[723.0, 457.0], [745.0, 457.0], [745.0, 481.0], [723.0, 481.0]]], "lines": ["．．．"]}, {"box": [106, 579, 207, 790], "vertical": true, "font_size": 26, "lines_coords": [[[178.0, 582.0], [204.0, 582.0], [204.0, 790.0], [178.0, 790.0]], [[140.0, 579.0], [167.0, 579.0], [167.0, 765.0], [140.0, 765.0]], [[106.0, 581.0], [132.0, 581.0], [132.0, 776.0], [106.0, 776.0]]], "lines": ["別に平気でしょ？", "ご飯はちゃんと", "食べてんだから。"]}, {"box": [854, 890, 955, 1104], "vertical": true, "font_size": 25, "lines_coords": [[[926.0, 893.0], [953.0, 893.0], [953.0, 1104.0], [926.0, 1104.0]], [[889.0, 890.0], [915.0, 890.0], [915.0, 1064.0], [889.0, 1064.0]], [[854.0, 892.0], [876.0, 892.0], [876.0, 1084.0], [854.0, 1084.0]]], "lines": ["．．．．．．僕ね、いい加減", "そろそろ、仕事", "探そうと思うよ。"]}, {"box": [176, 968, 280, 1179], "vertical": true, "font_size": 28, "lines_coords": [[[251.0, 970.0], [278.0, 970.0], [278.0, 1179.0], [251.0, 1179.0]], [[215.0, 970.0], [242.0, 970.0], [242.0, 1156.0], [215.0, 1156.0]], [[176.0, 968.0], [207.0, 968.0], [207.0, 1157.0], [176.0, 1157.0]]], "lines": ["．．．アラッ、偉いわ！！", "家賃入れる気に", "なってくれた？"]}, {"box": [295, 1287, 359, 1425], "vertical": true, "font_size": 27, "lines_coords": [[[323.0, 1287.0], [359.0, 1287.0], [359.0, 1367.0], [323.0, 1367.0]], [[295.0, 1290.0], [317.0, 1290.0], [317.0, 1425.0], [295.0, 1425.0]]], "lines": ["いやー", "というより、"]}, 