", "確かラーメン屋", "だったんだけどね。"]}, {"box": [285, 931, 392, 1103], "vertical": true, "font_size": 28, "lines_coords": [[[357.0, 931.0], [389.0, 931.0], [392.0, 1103.0], [360.0, 1103.0]], [[325.0, 932.0], [351.0, 932.0], [351.0, 1065.0], [325.0, 1065.0]], [[285.0, 953.0], [320.0, 953.0], [320.0, 1017.0], [285.0, 1017.0]]], "lines": ["あれはいつ頃", "だったかな", "～～．．．"]}, {"box": [125, 993, 259, 1195], "vertical": true, "font_size": 28, "lines_coords": [[[232.0, 996.0], [259.0, 996.0], [259.0, 1181.0], [232.0, 1181.0]], [[195.0, 993.0], [223.0, 993.0], [220.0, 1182.0], [192.0, 1182.0]], [[159.0, 995.0], [185.0, 995.0], [185.0, 1195.0], [159.0, 1195.0]], [[125.0, 995.0], [146.0, 995.0], [146.0, 1162.0], [125.0, 1162.0]]], "lines": ["姉さんが離婚で", "ドタバタしてた", "頃だから、２年と", "ちょっと前か。"]}, {"box": [832, 1275, 971, 1473], "vertical": true, "font_size": 27, "lines_coords": [[[942.0, 1279.0], [970.0, 1279.0], [970.0, 1382.0], [942.0, 1382.0]], [[906.0, 1278.0], [932.0, 1278.0], [932.0, 1442.0], [906.0, 1442.0]], [[870.0, 1276.0], [896.0, 1276.0], [896.0, 1435.0], [870.0, 1435.0]], [[832.0, 1275.0], [860.0, 1275.0], [862.0, 1473.0], [834.0, 1473.0]]], "lines": ["いやはや", "実に諸行無常、", "そして時間が", "経つのは早いね。"]}, {"box": [96, 1314, 231, 1548], "vertical": true, "font_size": 26, "lines_coords": [[[204.0, 1314.0], [231.0, 1314.0], [231.0, 1510.0], [204.0, 1510.0]], [[167.0, 1314.0], [193.0, 1314.0], [193.0, 1548.0], [167.0, 1548.0]], [[129.0, 1315.0], [156.0, 1315.0], [156.0, 1475.0], [129.0, 1475.0]], [[96.0, 1314.0], [118.0, 1314.0], [118.0, 1507.0], [96.0, 1507.0]]], "lines": ["まさかあなたと", "こんな長い付き合い", "になるなんて", "思わなかったな。"]}], "img_path": "192.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [900, 115, 926, 300], "vertical": true, "font_size": 26, "lines_coords": [[[900.0, 115.0], [926.0, 115.0], [926.0, 300.0], [900.0, 300.0]]], "lines": ["ウイッウィッ！！"]}, {"box": [160, 317, 296, 517], "vertical": true, "font_size": 26, "lines_coords": [[[270.0, 318.0], [296.0, 318.0], [296.0, 517.0], [270.0, 517.0]], [[234.0, 317.0], [260.0, 317.0], [260.0, 506.0], [234.0, 506.0]], [[196.0, 317.0], [225.0, 317.0], [221.0, 476.0], [193.0, 476.0]], [[160.0, 318.0], [187.0, 318.0], [187.0, 489.0], [160.0, 489.0]]], "lines": ["まー、きっかけは", "ともかく、今や", "僕の数少ない", "友人だからね。"]}, {"box": [185, 557, 282, 751], "vertical": true, "font_size": 26, "lines_coords": [[[218.0, 557.0], [245.0, 557.0], [246.0, 751.0], [220.0, 751.0]], [[256.0, 564.0], [282.0, 564.0], [282.0, 700.0], [256.0, 700.0]], [[185.0, 565.0], [206.0, 565.0], [206.0, 707.0], [185.0, 707.0]]], "lines": ["ひとつよろしく", "これからも", "．．．なんてね"]}, {"box": [926, 921, 990, 1096], "vertical": true, "font_size": 28, "lines_coords": [[[960.0, 921.0], [989.0, 921.0], [990.0, 1068.0], [962.0, 1068.0]], [[926.0, 921.0], [953.0, 921.0], [953.0, 1096.0], [926.0, 1096.0]]], "lines": ["あー、じゃあ", "僕ナポリタン。"]}, {"box": [856, 1057, 884, 1189], "vertical": true, "font_size": 28, "lines_coords": [[[856.0, 1057.0], [884.0, 1057.0], [884.0, 1189.0], [856.0, 1189.0]]], "lines": ["湯上君は？"]}, {"box": [120, 1015, 223, 1171], "vertical": true, "font_size": 29, "lines_coords": [[[195.0, 1018.0], [221.0, 1018.0], [221.0, 1171.0], [195.0, 1171.0]], [[157.0, 1017.0], [185.0, 1017.0], [185.0, 1146.0], [157.0, 1146.0]], [[120.0, 1015.0], [153.0, 1015.0], [153.0, 1109.0], [120.0, 1109.0]]], "lines": ["あ、それじゃ", "ナポリタン", "２つで。"]}, {"box": [825, 1315, 962, 1528], "vertical": true, "font_size": 28, "lines_coords": [[[935.0, 1315.0], [962.0, 1315.0], [959.0, 1450.0], [932.0, 1450.0]], [[895.0, 1317.0], [928.0, 1317.0], [928.0, 1485.0], [895.0, 1485.0]], [[859.0, 1317.0], [885.0, 1317.0], [885.0, 1528.0], [859.0, 1528.0]], [[825.0, 1320.0], [851.0, 1320.0], [851.0, 1460.0], [825.0, 1460.0]]], "lines": ["．．．姉さんも", "パートの仕事、", "だいぶ慣れてきた", "みたいだよ。"]}, {"box": [259, 1275, 379, 1465], "vertical": true, "font_size": 24, "lines_coords": [[[353.0, 1276.0], [379.0, 1276.0], [379.0, 1421.0], [353.0, 1421.0]], [[321.0, 1278.0], [343.0, 1278.0], [343.0, 1459.0], [321.0, 1459.0]], [[289.0, 1275.0], [315.0, 1275.0], [314.0, 1460.0], [287.0, 1460.0]], [[259.0, 1278.0], [281.0, 1278.0], [281.0, 1465.0], [259.0, 1465.0]]], "lines": ["ただ、近所に", "見栄張るために", "隣の街まで通勤", "してんだ、あの人。"]}, {"box": [261, 1279, 382, 1468], "vertical": true, "font_size": 121, "lines_coords": [[[261.0, 1279.0], [382.0, 1279.0], [382.0, 1468.0], [261.0, 1468.0]]], "lines": ["ただ、近所に見栄張るために隣の街まで通勤してんだ、あの人。"]}, {"box": [196, 1357, 218, 1565], "vertical": true, "font_size": 24, "lines_coords": [[[196.0, 1357.0], [218.0, 1357.0], [218.0, 1565.0], [196.0, 1565.0]]], "lines": ["世田谷のアバート"]}, {"box": [129, 1354, 189, 1540], "vertical": true, "font_size": 24, "lines_coords": [[[164.0, 1356.0], [187.0, 1356.0], [189.0, 1540.0], [165.0, 1540.0]], [[129.0, 1354.0], [156.0, 1354.0], [159.0, 1515.0], [132.0, 1515.0]]], "lines": ["経営してるって", "変なウソまで"]}, {"box": [100, 1357, 129, 1540], "vertical": true, "font_size": 24, "lines_coords": [[[100.0, 1357.0], [126.0, 1357.0], [129.0, 1540.0], [103.0, 1540.0]]], "lines": ["ついちゃってさ。"]}], "img_path": "193.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [928, 90, 957, 245], "vertical": true, "font_size": 29, "lines_coords": [[[928.0, 90.0], [957.0, 90.0], [957.0, 245.0], [928.0, 245.0]]], "lines": ["．．．プンプン？"]}, {"box": [804, 220, 906, 370], "vertical": true, "font_size": 29, "lines_coords": [[[871.0, 221.0], [903.0, 220.0], [906.0, 285.0], [875.0, 287.0]], [[840.0, 225.0], [867.0, 225.0], [867.0, 359.0], [840.0, 359.0]], [[804.0, 228.0], [831.0, 228.0], [831.0, 370.0], [804.0, 370.0]]], "lines": ["うん、", "相変わらず", "いい子だよ。"]}, {"box": [123, 189, 224, 348], "vertical": true, "font_size": 27, "lines_coords": [[[193.0, 190.0], [221.0, 190.0], [221.0, 325.0], [193.0, 325.0]], [[156.0, 189.0], [187.0, 189.0], [187.0, 348.0], [156.0, 348.0]], [[123.0, 192.0], [145.0, 192.0], [145.0, 318.0], [123.0, 318.0]]], "lines": ["今頃、部活", "やってんじゃ", "ないかな？"]}, {"box": [860, 465, 982, 678], "vertical": true, "font_size": 28, "lines_coords": [[[956.0, 470.0], [982.0, 470.0], [979.0, 664.0], [953.0, 664.0]], [[925.0, 468.0], [951.0, 468.0], [948.0, 628.0], [921.0, 628.0]], [[889.0, 465.0], [920.0, 465.0], [920.0, 635.0], [889.0, 635.0]], [[860.0, 468.0], [887.0, 468.0], [887.0, 676.0], [860.0, 676.0]]], "lines": ["いやぁ～確かに", "一時期は家中", "真っっっ暗闇で", "手探りだったけど、"]}, {"box": [223, 450, 326, 635], "vertical": true, "font_size": 26, "lines_coords": [[[293.0, 451.0], [326.0, 451.0], [326.0, 535.0], [293.0, 535.0]], [[259.0, 451.0], [285.0, 451.0], [285.0, 635.0], [259.0, 635.0]], [[225.0, 450.0], [248.0, 450.0], [246.0, 618.0], [223.0, 618.0]]], "lines": ["何事も", "時間が解決して", "くれるのかね。"]}, {"box": [112, 582, 173, 756], "vertical": true, "font_size": 26, "lines_coords": [[[146.0, 582.0], [173.0, 582.0], [173.0, 756.0], [146.0, 756.0]], [[112.0, 584.0], [134.0, 584.0], [134.0, 751.0], [112.0, 751.0]]], "lines": ["今はずいぶん", "落ちついたよ。"]}, {"box": [915, 860, 945, 937], "vertical": true, "font_size": 29, "lines_coords": [[[915.0, 860.0], [945.0, 860.0], [945.0, 937.0], [915.0, 937.0]]], "lines": ["彼女？"]}, {"box": [825, 970, 853, 1053], "vertical": true, "font_size": 29, "lines_coords": [[[825.0, 970.0], [853.0, 970.0], [853.0, 1053.0], [825.0, 1053.0]]], "lines": ["僕に？"]}, {"box": [267, 854, 334, 989], "vertical": true, "font_size": 28, "lines_coords": [[[301.0, 854.0], [334.0, 854.0], [334.0, 989.0], [301.0, 989.0]], [[267.0, 854.0], [293.0, 854.0], [293.0, 968.0], [267.0, 968.0]]], "lines": ["いやぁ～～", "全然だね"]}, {"box": [114, 917, 237, 1139], "vertical": true, "font_size": 28, "lines_coords": [[[209.0, 920.0], [237.0, 920.0], [237.0, 1053.0], [209.0, 1053.0]], [[176.0, 920.0], [203.0, 920.0], [203.0, 1129.0], [176.0, 1129.0]], [[143.0, 917.0], [170.0, 917.0], [173.0, 1112.0], [146.0, 1112.0]], [[114.0, 917.0], [140.0, 917.0], [143.0, 1139.0], [117.0, 1139.0]]], "lines": ["３３歳にして", "フリーターの男に", "惚れる酔狂な人、", "そういないでしょ。"]}, {"box": [96, 1379, 159, 1485], "vertical": true, "font_size": 28, "lines_coords": [[[131.0, 1381.0], [159.0, 1381.0], [159.0, 1485.0], [131.0, 1485.0]], [[96.0, 1379.0], [123.0, 1379.0], [123.0, 1485.0], [96.0, 1485.0]]], "lines": ["おまたせ", "しま．．．"]}], "img_path": "194.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [949, 135, 983, 282], "vertical": true, "font_size": 32, "lines_coords": [[[950.0, 135.0], [982.0, 135.0], [982.0, 282.0], [950.0, 282.0]]], "lines": ["あっ．．．！！"]}, {"box": [587, 110, 627, 298], "vertical": true, "font_size": 34, "lines_coords": [[[590.0, 110.0], [625.0, 110.0], [621.0, 298.0], [587.0, 298.0]]], "lines": ["どひゃあ！！"]}, {"box": [145, 237, 261, 427], "vertical": true, "font_size": 31, "lines_coords": [[[228.0, 237.0], [260.0, 237.0], [260.0, 365.0], [228.0, 365.0]], [[187.0, 239.0], [220.0, 239.0], [220.0, 368.0], [187.0, 368.0]], [[146.0, 239.0], [173.0, 239.0], [173.0, 426.0], [146.0, 426.0]]], "lines": ["アメリカ", "だったら", "訴訟もんだ！！"]}, {"box": [170, 551, 257, 764], "vertical": true, "font_size": 38, "lines_coords": [[[218.0, 551.0], [257.0, 551.0], [257.0, 704.0], [218.0, 704.0]], [[170.0, 551.0], [201.0, 551.0], [201.0, 764.0], [170.0, 764.0]]], "lines": ["すっ．．．", "すみません！！"]}, {"box": [189, 818, 282, 1032], "vertical": true, "font_size": 38, "lines_coords": [[[235.0, 818.0], [279.0, 818.0], [282.0, 1032.0], [239.0, 1032.0]], [[189.0, 818.0], [226.0, 818.0], [226.0, 1012.0], [189.0, 1012.0]]], "lines": ["今すぐ、拭き", "ますんで！！"]}, {"box": [921, 1181, 951, 1314], "vertical": true, "font_size": 28, "lines_coords": [[[921.0, 1182.0], [950.0, 1182.0], [951.0, 1314.0], [923.0, 1314.0]]], "lines": ["．．．あれ？"]}, {"box": [403, 1325, 466, 1487], "vertical": true, "font_size": 33, "lines_coords": [[[432.0, 1325.0], [465.0, 1325.0], [462.0, 1487.0], [429.0, 1487.0]]], "lines": ["君、どっかで"]}], "img_path": "195.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [393, 101, 767, 375], "vertical": false, "font_size": 194, "lines_coords": [[[442.0, 101.0], [767.0, 187.0], [718.0, 375.0], [393.0, 289.0]]], "lines": ["けどは"]}, {"box": [334, 1403, 394, 1538], "vertical": true, "font_size": 27, "lines_coords": [[[365.0, 1406.0], [392.0, 1406.0], [392.0, 1535.0], [365.0, 1535.0]]], "lines": ["フンフンは"]}], "img_path": "196.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [796, 599, 861, 770], "vertical": true, "font_size": 25, "lines_coords": [[[832.0, 600.0], [860.0, 600.0], [860.0, 731.0], [832.0, 731.0]], [[798.0, 600.0], [820.0, 600.0], [820.0, 765.0], [798.0, 765.0]]], "lines": ["バリバリに", "中学生でした。"]}, {"box": [900, 1212, 970, 1306], "vertical": true, "font_size": 31, "lines_coords": [[[942.0, 1212.0], [970.0, 1212.0], [970.0, 1306.0], [942.0, 1306.0]], [[900.0, 1212.0], [940.0, 1212.0], [940.0, 1296.0], [900.0, 1296.0]]], "lines": ["ホラァー", "一年！！"]}, {"box": [792, 1310, 856, 1456], "vertical": true, "font_size": 31, "lines_coords": [[[828.0, 1310.0], [856.0, 1310.0], [856.0, 1456.0], [828.0, 1456.0]], [[792.0, 1310.0], [820.0, 1310.0], [820.0, 1401.0], [792.0, 1401.0]]], "lines": ["ペース、乱れ", "てんぞー"]}, {"box": [114, 1378, 221, 1500], "vertical": true, "font_size": 37, "lines_coords": [[[176.0, 1378.0], [221.0, 1378.0], [221.0, 1456.0], [176.0, 1456.0]], [[142.0, 1381.0], [181.0, 1379.0], [184.0, 1492.0], [145.0, 1493.0]], [[114.0, 1384.0], [140.0, 1384.0], [140.0, 1498.0], [114.0, 1498.0]]], "lines": ["はい、", "ワンツー", "ワンツー。"]}], "img_path": "197.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [953, 79, 1025, 243], "vertical": true, "font_size": 28, "lines_coords": [[[992.0, 81.0], [1025.0, 81.0], [1025.0, 192.0], [992.0, 192.0]], [[956.0, 79.0], [987.0, 79.0], [984.0, 243.0], [953.0, 243.0]]], "lines": ["矢口せん", "ぱぁ～い．．．"]}, {"box": [846, 220, 945, 367], "vertical": true, "font_size": 28, "lines_coords": [[[918.0, 221.0], [945.0, 221.0], [945.0, 342.0], [918.0, 342.0]], [[879.0, 220.0], [906.0, 220.0], [906.0, 367.0], [879.0, 367.0]], [[846.0, 221.0], [868.0, 221.0], [868.0, 353.0], [846.0, 353.0]]], "lines": ["僕ら、もう", "素振り、飽き", "ましたよ．．．"]}, {"box": [464, 217, 565, 401], "vertical": true, "font_size": 28, "lines_coords": [[[534.0, 218.0], [565.0, 218.0], [565.0, 396.0], [534.0, 396.0]], [[501.0, 218.0], [528.0, 218.0], [528.0, 379.0], [501.0, 379.0]], [[464.0, 218.0], [490.0, 218.0], [490.0, 401.0], [464.0, 401.0]]], "lines": ["いつになったら", "体育館で試合", "できるんすか？"]}, {"box": [152, 101, 288, 315], "vertical": true, "font_size": 26, "lines_coords": [[[259.0, 101.0], [285.0, 101.0], [284.0, 301.0], [257.0, 301.0]], [[223.0, 104.0], [250.0, 104.0], [250.0, 289.0], [223.0, 289.0]], [[185.0, 103.0], [212.0, 103.0], [212.0, 300.0], [185.0, 300.0]], [[153.0, 103.0], [175.0, 103.0], [175.0, 312.0], [153.0, 312.0]]], "lines": ["．．．ま、俺らの代で", "古い慣習は改善", "するように、先生", "説得するけどさぁ、"]}, {"box": [634, 498, 662, 612], "vertical": true, "font_size": 24, "lines_coords": [[[634.0, 498.0], [662.0, 498.0], [662.0, 612.0], [634.0, 612.0]]], "lines": ["お前なぁ、"]}, {"box": [481, 542, 603, 710], "vertical": true, "font_size": 24, "lines_coords": [[[576.0, 542.0], [603.0, 542.0], [603.0, 710.0], [576.0, 710.0]], [[543.0, 542.0], [565.0, 542.0], [565.0, 707.0], [543.0, 707.0]], [[512.0, 542.0], [535.0, 542.0], [534.0, 710.0], [510.0, 710.0]], [[481.0, 543.0], [503.0, 543.0], [503.0, 700.0], [481.0, 700.0]]], "lines": ["俺らが一年の時", "んなこと先輩に", "言ったらマジで", "ボッコボコよ？"]}, {"box": [91, 520, 213, 704], "vertical": true, "font_size": 22, "lines_coords": [[[190.0, 523.0], [212.0, 523.0], [212.0, 640.0], [190.0, 640.0]], [[157.0, 521.0], [179.0, 521.0], [179.0, 687.0], [157.0, 687.0]], [[123.0, 520.0], [145.0, 520.0], [145.0, 687.0], [123.0, 687.0]], [[92.0, 521.0], [114.0, 521.0], [114.0, 704.0], [92.0, 704.0]]], "lines": ["．．．つっても", "基本は大事よ？", "とりあえず今は", "素振っとこうぜ？"]}, {"box": [859, 796, 968, 1000], "vertical": true, "font_size": 24, "lines_coords": [[[946.0, 798.0], [968.0, 798.0], [968.0, 1000.0], [946.0, 1000.0]], [[918.0, 798.0], [940.0, 798.0], [940.0, 965.0], [918.0, 965.0]], [[887.0, 796.0], [914.0, 796.0], [914.0, 965.0], [887.0, 965.0]], [[862.0, 798.0], [889.0, 798.0], [885.0, 937.0], [859.0, 937.0]], [[862.0, 934.0], [884.0, 934.0], [884.0, 987.0], [862.0, 987.0]]], "lines": ["でも小松っちゃんは", "先輩達と一緒に", "練習してるじゃ", "ないっすかー", "．．．"]}, {"box": [718, 910, 814, 1045], "vertical": true, "font_size": 24, "lines_coords": [[[785.0, 910.0], [814.0, 910.0], [814.0, 1031.0], [785.0, 1031.0]], [[750.0, 912.0], [778.0, 912.0], [778.0, 1045.0], [750.0, 1045.0]], [[718.0, 915.0], [737.0, 915.0], [737.0, 954.0], [718.0, 954.0]]], "lines": ["先輩、それ", "ひいきです", "よー"]}, {"box": [715, 970, 739, 1017], "vertical": true, "font_size": 24, "lines_coords": [[[715.0, 970.0], [739.0, 970.0], [739.0, 1017.0], [715.0, 1017.0]]], "lines": ["．．．"]}, {"box": [225, 909, 289, 1020], "vertical": true, "font_size": 26, "lines_coords": [[[264.0, 968.0], [287.0, 968.0], [287.0, 1020.0], [264.0, 1020.0]], [[260.0, 909.0], [289.0, 909.0], [289.0, 967.0], [260.0, 967.0]], [[225.0, 910.0], [253.0, 910.0], [253.0, 1018.0], [225.0, 1018.0]]], "lines": ["イ", "オー", "小松は別"]}, {"box": [192, 910, 215, 1040], "vertical": true, "font_size": 26, "lines_coords": [[[192.0, 981.0], [214.0, 981.0], [214.0, 1040.0], [192.0, 1040.0]], [[192.0, 910.0], [215.0, 910.0], [215.0, 987.0], [192.0, 987.0]]], "lines": ["ー？", "だろー"]}, {"box": [162, 1104, 256, 1350], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 1104.0], [256.0, 1104.0], [256.0, 1342.0], [225.0, 1342.0]], [[195.0, 1104.0], [223.0, 1104.0], [221.0, 1350.0], [193.0, 1350.0]], [[164.0, 1109.0], [190.0, 1109.0], [189.0, 1329.0], [162.0, 1329.0]]], "lines": ["あいつのスマッシュ", "くらってみ！？アレ、", "マジで鬼だからさ。"]}], "img_path": "198.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [768, 79, 871, 290], "vertical": true, "font_size": 28, "lines_coords": [[[842.0, 79.0], [870.0, 79.0], [870.0, 210.0], [842.0, 210.0]], [[804.0, 79.0], [835.0, 79.0], [835.0, 290.0], [804.0, 290.0]], [[770.0, 79.0], [796.0, 79.0], [796.0, 265.0], [770.0, 265.0]]], "lines": ["フンフンが", "バドミントン部に", "入部した理由は"]}, {"box": [534, 77, 710, 276], "vertical": true, "font_size": 27, "lines_coords": [[[682.0, 81.0], [709.0, 81.0], [709.0, 223.0], [682.0, 223.0]], [[645.0, 79.0], [671.0, 79.0], [671.0, 275.0], [645.0, 275.0]], [[609.0, 79.0], [635.0, 79.0], [635.0, 262.0], [609.0, 262.0]], [[573.0, 81.0], [595.0, 81.0], [595.0, 234.0], [573.0, 234.0]], [[534.0, 78.0], [567.0, 78.0], [567.0, 164.0], [534.0, 164.0]]], "lines": ["「なんとなく", "楽そうだから」と", "小松っちゃんに", "誘われたから", "ですが、"]}, {"box": [585, 946, 617, 998], "vertical": true, "font_size": 32, "lines_coords": [[[585.0, 946.0], [617.0, 946.0], [617.0, 998.0], [585.0, 998.0]]], "lines": ["あっ"]}, {"box": [439, 944, 590, 1133], "vertical": true, "font_size": 28, "lines_coords": [[[510.0, 945.0], [537.0, 945.0], [537.0, 1078.0], [510.0, 1078.0]], [[473.0, 946.0], [504.0, 946.0], [504.0, 1129.0], [473.0, 1129.0]], [[439.0, 946.0], [465.0, 946.0], [465.0, 1132.0], [439.0, 1132.0]]], "lines": ["という間に", "小松っちゃんは", "上達してしまい"]}, {"box": [287, 946, 392, 1155], "vertical": true, "font_size": 27, "lines_coords": [[[362.0, 948.0], [389.0, 948.0], [389.0, 1104.0], [362.0, 1104.0]], [[325.0, 948.0], [351.0, 948.0], [351.0, 1153.0], [325.0, 1153.0]], [[287.0, 946.0], [315.0, 946.0], [315.0, 1056.0], [287.0, 1056.0]]], "lines": ["なんだか納得", "いかないフンフン", "でしたが、"]}, {"box": [140, 943, 240, 1104], "vertical": true, "font_size": 27, "lines_coords": [[[212.0, 943.0], [240.0, 943.0], [237.0, 1101.0], [209.0, 1101.0]], [[176.0, 946.0], [203.0, 946.0], [203.0, 1103.0], [176.0, 1103.0]], [[140.0, 945.0], [167.0, 945.0], [167.0, 1087.0], [140.0, 1087.0]]], "lines": ["そこは気丈に", "ふるまいたい", "ところです。"]}, {"box": [907, 1242, 981, 1382], "vertical": true, "font_size": 28, "lines_coords": [[[942.0, 1242.0], [981.0, 1242.0], [981.0, 1292.0], [942.0, 1292.0]], [[910.0, 1242.0], [943.0, 1242.0], [940.0, 1382.0], [907.0, 1382.0]]], "lines": ["ねー", "プンプン！！"]}, {"box": [768, 135