], [196.0, 1453.0]], [[168.0, 1282.0], [190.0, 1282.0], [190.0, 1464.0], [168.0, 1464.0]], [[137.0, 1281.0], [164.0, 1281.0], [164.0, 1440.0], [137.0, 1440.0]], [[107.0, 1282.0], [134.0, 1282.0], [134.0, 1412.0], [107.0, 1412.0]]], "lines": ["．．．ま、あたしは", "そろそろ帰って", "くると思って", "たけど．．．"]}], "img_path": "185.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [870, 84, 906, 267], "vertical": true, "font_size": 33, "lines_coords": [[[870.0, 84.0], [903.0, 84.0], [906.0, 267.0], [873.0, 267.0]]], "lines": ["このっ．．．．．．！！"]}, {"box": [92, 48, 379, 79], "vertical": false, "font_size": 31, "lines_coords": [[[92.0, 48.0], [379.0, 48.0], [379.0, 79.0], [92.0, 79.0]]], "lines": ["おやすみプンプン図"]}, {"box": [842, 810, 870, 969], "vertical": true, "font_size": 26, "lines_coords": [[[842.0, 810.0], [868.0, 810.0], [868.0, 968.0], [842.0, 968.0]]], "lines": ["お母さんを．．．"]}, {"box": [185, 868, 251, 1029], "vertical": true, "font_size": 28, "lines_coords": [[[223.0, 871.0], [251.0, 871.0], [251.0, 978.0], [223.0, 978.0]], [[185.0, 868.0], [214.0, 868.0], [215.0, 1026.0], [187.0, 1026.0]]], "lines": ["ひとりに", "しないで．．．"]}, {"box": [127, 1337, 190, 1472], "vertical": true, "font_size": 28, "lines_coords": [[[159.0, 1337.0], [187.0, 1337.0], [187.0, 1470.0], [159.0, 1470.0]]], "lines": ["プンプンは"]}], "img_path": "186.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [476, 73, 615, 283], "vertical": true, "font_size": 30, "lines_coords": [[[585.0, 76.0], [615.0, 76.0], [615.0, 153.0], [585.0, 153.0]], [[551.0, 76.0], [579.0, 76.0], [579.0, 181.0], [551.0, 181.0]], [[512.0, 73.0], [543.0, 73.0], [543.0, 282.0], [512.0, 282.0]], [[476.0, 73.0], [509.0, 73.0], [509.0, 165.0], [476.0, 165.0]]], "lines": ["わけも", "わからず", "涙が止まりません", "でした。"]}, {"box": [888, 379, 957, 565], "vertical": true, "font_size": 30, "lines_coords": [[[925.0, 468.0], [948.0, 468.0], [948.0, 510.0], [925.0, 510.0]], [[915.0, 379.0], [957.0, 379.0], [95