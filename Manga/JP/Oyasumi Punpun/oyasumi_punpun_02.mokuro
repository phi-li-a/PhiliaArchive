, 450.0], [428.0, 500.0]]], "lines": ["俺たちと夢をつかもうぜ"]}, {"box": [676, 606, 778, 789], "vertical": true, "font_size": 26, "lines_coords": [[[750.0, 607.0], [778.0, 607.0], [778.0, 748.0], [750.0, 748.0]], [[715.0, 607.0], [737.0, 607.0], [737.0, 789.0], [715.0, 789.0]], [[676.0, 607.0], [704.0, 607.0], [704.0, 712.0], [676.0, 712.0]]], "lines": ["だからコレ、", "応募してみたり", "しない？"]}, {"box": [118, 556, 268, 770], "vertical": true, "font_size": 28, "lines_coords": [[[235.0, 559.0], [268.0, 559.0], [268.0, 600.0], [235.0, 600.0]], [[204.0, 556.0], [235.0, 556.0], [235.0, 718.0], [204.0, 718.0]], [[175.0, 559.0], [201.0, 559.0], [204.0, 770.0], [178.0, 770.0]], [[151.0, 559.0], [173.0, 559.0], [173.0, 768.0], [151.0, 768.0]], [[118.0, 559.0], [145.0, 559.0], [145.0, 693.0], [118.0, 693.0]]], "lines": ["ねー", "愛子ちゃん！！", "プンプンけっこー", "ジョニーズ系だと", "思わない！？"]}, {"box": [219, 889, 248, 1090], "vertical": true, "font_size": 22, "lines_coords": [[[221.0, 892.0], [243.0, 892.0], [243.0, 1081.0], [221.0, 1081.0]]], "lines": ["「．．．愛子ちゃん。"]}, {"box": [412, 1375, 443, 1470], "vertical": true, "font_size": 30, "lines_coords": [[[412.0, 1375.0], [442.0, 1375.0], [443.0, 1470.0], [414.0, 1470.0]]], "lines": ["かもね。"]}], "img_path": "141.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [901, 112, 970, 245], "vertical": true, "font_size": 33, "lines_coords": [[[937.0, 115.0], [970.0, 115.0], [970.0, 220.0], [937.0, 220.0]], [[901.0, 112.0], [934.0, 112.0], [934.0, 245.0], [901.0, 245.0]]], "lines": ["ハイハイ", "ハイ〜〜！！"]}, {"box": [120, 78, 221, 276], "vertical": true, "font_size": 29, "lines_coords": [[[193.0, 78.0], [221.0, 78.0], [221.0, 187.0], [193.0, 187.0]], [[156.0, 79.0], [184.0, 79.0], [185.0, 276.0], [157.0, 276.0]], [[120.0, 78.0], [146.0, 78.0], [146.0, 260.0], [120.0, 260.0]]], "lines": ["え～～～", "二学期始まって", "早々ですが．．．"]}, {"box": [681, 450, 745, 656], "vertical": true, "font_size": 28, "lines_coords": [[[714.0, 450.0], [745.0, 450.0], [745.0, 607.0]