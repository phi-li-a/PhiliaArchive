], [982.0, 834.0], [957.0, 834.0]], [[921.0, 792.0], [948.0, 792.0], [948.0, 940.0], [921.0, 940.0]]], "lines": ["まー", "とりあえず。"]}, {"box": [779, 896, 912, 1084], "vertical": true, "font_size": 25, "lines_coords": [[[884.0, 896.0], [912.0, 896.0], [912.0, 1004.0], [884.0, 1004.0]], [[846.0, 898.0], [873.0, 898.0], [876.0, 1084.0], [850.0, 1084.0]], [[815.0, 901.0], [837.0, 901.0], [837.0, 1056.0], [815.0, 1056.0]], [[779.0, 901.0], [801.0, 901.0], [801.0, 1031.0], [779.0, 1031.0]]], "lines": ["遊ぶのは", "かまわないけど", "あんま荒らさ", "ないでよ？"]}, {"box": [334, 1068, 381, 1109], "vertical": false, "font_size": 23.5, "lines_coords": [[[334.0, 1068.0], [367.0, 1068.0], [367.0, 1093.0], [334.0, 1093.0]], [[334.0, 1087.0], [381.0, 1087.0], [381.0, 1109.0], [334.0, 1109.0]]], "lines": ["ＳＡＩＴ", "．．．"]}, {"box": [123, 943, 264, 1156], "vertical": true, "font_size": 27, "lines_coords": [[[234.0, 945.0], [260.0, 945.0], [260.0, 1125.0], [234.0, 1125.0]], [[196.0, 945.0], [223.0, 945.0], [223.0, 1156.0], [196.0, 1156.0]], [[162.0, 943.0], [189.0, 943.0], [189.0, 1093.0], [162.0, 1093.0]], [[123.0, 943.0], [150.0, 943.0], [150.0, 1056.0], [123.0, 1056.0]]], "lines": ["けっこー、ココ、", "あたし的に特別な", "場所だったり", "するから。"]}, {"box": [160, 1344, 188, 1517], "vertical": true, "font_size": 27, "lines_coords": [[[160.0, 1345.0], [187.0, 1345.0], [187.0, 1514.0], [160.0, 1514.0]]], "lines": ["あ、そうそう。"]}], "img_path": "010.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [929, 171, 1031, 354], "vertical": true, "font_size": 27, "lines_coords": [[[1003.0, 173.0], [1031.0, 173.0], [1031.0, 287.0], [1003.0, 287.0]], [[968.0, 171.0], [995.0, 171.0], [993.0, 354.0], [967.0, 354.0]], [[932.0, 171.0], [959.0, 171.0], [956.0, 329.0], [929.0, 329.0]]], "lines": ["あんたら、", "日が暮れるまで", "には帰りな？"]}, {"box": [832, 371, 932, 573], "vertical": true, "font_size": 27, "lines_coords": [[[906.0, 375.0], [932.0, 375.0], [932.0, 532.0], [906.0, 532.0]], [[868.0, 371.0], [896.0, 371.0], [893.0, 506.0], [865.0, 506.0]], [[834.0, 371.0], [860.0, 371.0], [859.0, 573.0], [832.0, 573.0]]], "lines": ["鉄骨とか廃材", "散乱してて", "けっこー危険だし、"]}, {"box": [156, 471, 256, 609], "vertical": true, "font_size": 27, "lines_coords": [[[229.0, 473.0], [256.0, 473.0], [256.0, 609.0], [229.0, 609.0]], [[193.0, 473.0], [221.0, 473.0], [221.0, 603.0], [193.0, 603.0]], [[156.0, 471.0], [184.0, 471.0], [187.0, 590.0], [159.0, 590.0]]], "lines": ["それにホラ、", "この工場の", "社長がさ、"]}, {"box": [171, 695, 310, 934], "vertical": true, "font_size": 27, "lines_coords": [[[282.0, 698.0], [310.0, 698.0], [310.0, 804.0], [282.0, 804.0]], [[248.0, 698.0], [275.0, 698.0], [275.0, 934.0], [248.0, 934.0]], [[210.0, 698.0], [237.0, 698.0], [237.0, 856.0], [210.0, 856.0]], [[171.0, 695.0], [198.0, 695.0], [201.0, 835.0], [175.0, 835.0]]], "lines": ["経営難で", "首まわんなくなって", "焼身自殺した", "らしいから、"]}, {"box": [698, 1357, 801, 1518], "vertical": true, "font_size": 30, "lines_coords": [[[765.0, 1357.0], [801.0, 1359.0], [798.0, 1443.0], [762.0, 1442.0]], [[731.0, 1359.0], [759.0, 1359.0], [760.0, 1517.0], [732.0, 1517.0]], [[698.0, 1360.0], [725.0, 1360.0], [725.0, 1478.0], [698.0, 1478.0]]], "lines": ["なんか", "コレ出ちゃう", "らしーし。"]}, {"box": [582, 1376, 612, 1495], "vertical": true, "font_size": 28, "lines_coords": [[[582.0, 1376.0], [610.0, 1376.0], [612.0, 1495.0], [584.0, 1495.0]]], "lines": ["なんてね。"]}, {"box": [139, 1401, 168, 1547], "vertical": true, "font_size": 28, "lines_coords": [[[139.0, 1401.0], [167.0, 1401.0], [168.0, 1546.0], [140.0, 1546.0]]], "lines": ["じゃーね。"]}], "img_path": "011.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [414, 204, 476, 342], "vertical": true, "font_size": 24, "lines_coords": [[[448.0, 204.0], [475.0, 204.0], [475.0, 340.0], [448.0, 340.0]], [[415.0, 206.0], [437.0, 206.0], [437.0, 334.0], [415.0, 334.0]]], "lines": ["．．．なんだよ", "あの人．．．"]}, {"box": [576, 1268, 717, 1507], "vertical": true, "font_size": 30, "lines_coords": [[[681.0, 1268.0], [717.0, 1268.0], [717.0, 1334.0], [681.0, 1334.0]], [[648.0, 1271.0], [679.0, 1271.0], [679.0, 1507.0], [648.0, 1507.0]], [[614.0, 1273.0], [640.0, 1273.0], [640.0, 1481.0], [614.0, 1481.0]], [[576.0, 1273.0], [603.0, 1273.0], [603.0, 1381.0], [576.0, 1381.0]]], "lines": ["正直、", "プンプンは帰りたい", "気持ちでいっぱい", "でしたが、"]}, {"box": [390, 1271, 493, 1441], "vertical": true, "font_size": 29, "lines_coords": [[[459.0, 1271.0], [492.0, 1271.0], [492.0, 1379.0], [459.0, 1379.0]], [[426.0, 1273.0], [453.0, 1273.0], [453.0, 1429.0], [426.0, 1429.0]], [[390.0, 1273.0], [417.0, 1273.0], [417.0, 1437.0], [390.0, 1437.0]]], "lines": ["みんなで", "死体とお金を", "さがしました。"]}], "img_path": "012.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [834, 150, 939, 362], "vertical": true, "font_size": 29, "lines_coords": [[[907.0, 150.0], [939.0, 150.0], [939.0, 348.0], [907.0, 348.0]], [[871.0, 153.0], [900.0, 153.0], [900.0, 287.0], [871.0, 287.0]], [[834.0, 151.0], [860.0, 151.0], [860.0, 362.0], [834.0, 362.0]]], "lines": ["．．．ね、ハルミン、", "死体と幽霊", "どっちがこわい？"]}, {"box": [225, 428, 250, 573], "vertical": true, "font_size": 21, "lines_coords": [[[225.0, 429.0], [246.0, 429.0], [246.0, 571.0], [225.0, 571.0]]], "lines": ["．．．どっちも。"]}, {"box": [826, 882, 928, 1016], "vertical": true, "font_size": 25, "lines_coords": [[[900.0, 882.0], [928.0, 882.0], [928.0, 989.0], [900.0, 989.0]], [[867.0, 885.0], [889.0, 885.0], [889.0, 1014.0], [867.0, 1014.0]], [[829.0, 884.0], [853.0, 884.0], [850.0, 1015.0], [826.0, 1015.0]]], "lines": ["どっちも", "じゃなくて", "どっちか！！"]}, {"box": [510, 759, 540, 893], "vertical": true, "font_size": 26, "lines_coords": [[[514.0, 759.0], [540.0, 759.0], [537.0, 893.0], [510.0, 893.0]]], "lines": ["どっちも！！"]}], "img_path": "013.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [775, 43, 796, 276], "vertical": true, "font_size": 26, "lines_coords": [[[775.0, 43.0], [796.0, 43.0], [796.0, 276.0], [775.0, 276.0]]], "lines": ["じゃじゃジャじゃ！！！"]}, {"box": [631, 90, 698, 303], "vertical": true, "font_size": 26, "lines_coords": [[[667.0, 92.0], [698.0, 92.0], [698.0, 279.0], [667.0, 279.0]], [[632.0, 90.0], [659.0, 90.0], [657.0, 303.0], [631.0, 303.0]]], "lines": ["関くんだったら", "どっちがこわい！？"]}, {"box": [357, 135, 426, 269], "vertical": true, "font_size": 31, "lines_coords": [[[393.0, 137.0], [426.0, 137.0], [426.0, 245.0], [393.0, 245.0]], [[360.0, 135.0], [389.0, 135.0], [385.0, 268.0], [357.0, 268.0]]], "lines": ["バカじゃ", "ねーの？"]}, {"box": [89, 501, 190, 645], "vertical": true, "font_size": 26, "lines_coords": [[[162.0, 501.0], [189.0, 501.0], [189.0, 634.0], [162.0, 634.0]], [[128.0, 503.0], [150.0, 503.0], [150.0, 606.0], [128.0, 606.0]], [[89.0, 504.0], [117.0, 504.0], [117.0, 645.0], [89.0, 645.0]]], "lines": ["んな非現実", "なもんは", "いねーよ。"]}, {"box": [567, 744, 705, 932], "vertical": true, "font_size": 26, "lines_coords": [[[676.0, 745.0], [703.0, 745.0], [703.0, 876.0], [676.0, 876.0]], [[640.0, 746.0], [667.0, 746.0], [667.0, 901.0], [640.0, 901.0]], [[603.0, 746.0], [629.0, 746.0], [629.0, 926.0], [603.0, 926.0]], [[567.0, 746.0], [593.0, 746.0], [593.0, 929.0], [567.0, 929.0]]], "lines": ["フンフンは", "死体も幽霊も", "大変におそろし", "かったのですが"]}, {"box": [392, 742, 500, 929], "vertical": true, "font_size": 29, "lines_coords": [[[473.0, 745.0], [500.0, 745.0], [500.0, 928.0], [473.0, 928.0]], [[432.0, 745.0], [460.0, 745.0], [462.0, 901.0], [434.0, 901.0]], [[392.0, 743.0], [425.0, 742.0], [428.0, 837.0], [395.0, 839.0]]], "lines": ["ここは頑張り所", "なのだと思い", "ました。"]}], "img_path": "014.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [573, 1345, 711, 1504], "vertical": true, "font_size": 29, "lines_coords": [[[682.0, 1348.0], [710.0, 1348.0], [710.0, 1453.0], [682.0, 1453.0]], [[646.0, 1345.0], [678.0, 1345.0], [678.0, 1504.0], [646.0, 1504.0]], [[610.0, 1345.0], [639.0, 1345.0], [635.0, 1453.0], [607.0, 1453.0]], [[573.0, 1346.0], [601.0, 1346.0], [601.0, 1485.0], [573.0, 1485.0]]], "lines": ["なぜなら", "愛子ちゃんを", "鹿児島に", "つれてゆく、"]}, {"box": [370, 1340, 512, 1502], "vertical": true, "font_size": 31, "lines_coords": [[[484.0, 1343.0], [512.0, 1343.0], [509.0, 1478.0], [481.0, 1478.0]], [[446.0, 1346.0], [473.0, 1346.0], [473.0, 1501.0], [446.0, 1501.0]], [[410.0, 1343.0], [439.0, 1343.0], [435.0, 1476.0], [407.0, 1476.0]], [[370.0, 1340.0], [410.0, 1340.0], [410.0, 1418.0], [370.0, 1418.0]]], "lines": ["これはもう", "絶対に絶対の", "約束だから", "です。"]}], "img_path": "015.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [687, 1321, 752, 1512], "vertical": true, "font_size": 27, "lines_coords": [[[723.0, 1321.0], [750.0, 1321.0], [750.0, 1479.0], [723.0, 1479.0]], [[687.0, 1321.0], [714.0, 1321.0], [714.0, 1506.0], [687.0, 1506.0]]], "lines": ["愛子ちゃんが", "そう望むのなら"]}, {"box": [506, 1321, 607, 1556], "vertical": true, "font_size": 26, "lines_coords": [[[578.0, 1323.0], [604.0, 1323.0], [604.0, 1479.0], [578.0, 1479.0]], [[542.0, 1323.0], [568.0, 1323.0], [568.0, 1556.0], [542.0, 1556.0]], [[506.0, 1323.0], [532.0, 1323.0], [532.0, 1510.0], [506.0, 1510.0]]], "lines": ["それは絶対に", "叶えてあげなくちゃ", "ならないのだと、"]}, {"box": [353, 1321, 418, 1463], "vertical": true, "font_size": 25, "lines_coords": [[[387.0, 1321.0], [415.0, 1321.0], [415.0, 1453.0], [387.0, 1453.0]], [[354.0, 1325.0], [376.0, 1325.0], [376.0, 1459.0], [354.0, 1459.0]]], "lines": ["フンフンは", "思いました。"]}, {"box": [100, 1382, 135, 1551], "vertical": true, "font_size": 32, "lines_coords": [[[103.0, 1382.0], [135.0, 1382.0], [132.0, 1551.0], [100.0, 1551.0]]], "lines": ["う～～～ん．．．"]}], "img_path": "016.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [917, 140, 1015, 295], "vertical": true, "font_size": 22, "lines_coords": [[[987.0, 140.0], [1015.0, 140.0], [1015.0, 250.0], [987.0, 250.0]], [[953.0, 142.0], [975.0, 142.0], [975.0, 295.0], [953.0, 295.0]], [[917.0, 142.0], [940.0, 142.0], [940.0, 192.0], [917.0, 192.0]]], "lines": ["．．．全っ然", "見つかんない", "ねー"]}, {"box": [920, 195, 937, 245], "vertical": true, "font_size": 22, "lines_coords": [[[920.0, 195.0], [937.0, 195.0], [937.0, 245.0], [920.0, 245.0]]], "lines": ["．．．"]}, {"box": [181, 200, 246, 382], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 203.0], [243.0, 203.0], [243.0, 382.0], [217.0, 382.0]], [[181.0, 200.0], [207.0, 200.0], [207.0, 359.0], [181.0, 359.0]]], "lines": ["やっぱデタラメ", "だったかな？"]}, {"box": [864, 657, 989, 803], "vertical": true, "font_size": 36, "lines_coords": [[[948.0, 657.0], [985.0, 657.0], [989.0, 803.0], [951.0, 803.0]], [[904.0, 660.0], [945.0, 660.0], [945.0, 762.0], [904.0, 762.0]], [[867.0, 665.0], [895.0, 665.0], [895.0, 801.0], [867.0, 801.0]]], "lines": ["「そいつぁ", "大変に", "困るギ！！」"]}, {"box": [962, 1035, 999, 1152], "vertical": true, "font_size": 28, "lines_coords": [[[962.0, 1035.0], [990.0, 1035.0], [990.0, 1151.0], [962.0, 1151.0]]], "lines": ["晴見くん。"]}, {"box": [601, 1020, 626, 1165], "vertical": true, "font_size": 22, "lines_coords": [[[601.0, 1021.0], [623.0, 1021.0], [623.0, 1164.0], [601.0, 1164.0]]], "lines": ["ん？うん．．．"]}, {"box": [135, 760, 277, 896], "vertical": true, "font_size": 30, "lines_coords": [[[243.0, 760.0], [276.0, 760.0], [276.0, 896.0], [243.0, 896.0]], [[209.0, 764.0], [237.0, 764.0], [237.0, 868.0], [209.0, 868.0]], [[170.0, 762.0], [198.0, 762.0], [200.0, 893.0], [171.0, 893.0]], [[135.0, 764.0], [164.0, 764.0], [164.0, 853.0], [135.0, 853.0]]], "lines": ["プンプンは", "心の中で", "強くさけび", "ました。"]}, {"box": [165, 1145, 231, 1195], "vertical": true, "font_size": 28, "lines_coords": [[[201.0, 1145.0], [231.0, 1145.0], [231.0, 1192.0], [201.0, 1192.0]], [[165.0, 1145.0], [195.0, 1145.0], [195.0, 1195.0], [165.0, 1195.0]]], "lines": ["まー", "まー"]}, {"box": [700, 1293, 801, 1503], "vertical": true, "font_size": 23, "lines_coords": [[[773.0, 1295.0], [800.0, 1295.0], [800.0, 1503.0], [773.0, 1503.0]], [[739.0, 1295.0], [760.0, 1295.0], [760.0, 1501.0], [739.0, 1501.0]], [[703.0, 1296.0], [723.0, 1296.0], [723.0, 1501.0], [703.0, 1501.0]]], "lines": ["今日って肝だめし", "じゃなかったの？", "何か探してるの？"]}, {"box": [150, 1307, 250, 1489], "vertical": true, "font_size": 28, "lines_coords": [[[220.0, 1307.0], [246.0, 1307.0], [250.0, 1489.0], [223.0, 1489.0]], [[185.0, 1310.0], [212.0, 1310.0], [212.0, 1468.0], [185.0, 1468.0]], [[150.0, 1309.0], [176.0, 1309.0], [176.0, 1454.0], [150.0, 1454.0]]], "lines": ["まーーこの際、", "細かいことは", "置いといて。"]}], "img_path": "017.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [903, 56, 1001, 215], "vertical": true, "font_size": 27, "lines_coords": [[[973.0, 56.0], [1001.0, 56.0], [1001.0, 164.0], [973.0, 164.0]], [[939.0, 59.0], [965.0, 59.0], [965.0, 215.0], [939.0, 215.0]], [[903.0, 59.0], [929.0, 59.0], [929.0, 171.0], [903.0, 171.0]]], "lines": ["けっこー", "今日おもしろ", "かったし、"]}, {"box": [201, 101, 306, 282], "vertical": true, "font_size": 26, "lines_coords": [[[276.0, 103.0], [304.0, 103.0], [306.0, 239.0], [278.0, 239.0]], [[240.0, 103.0], [267.0, 103.0], [267.0, 282.0], [240.0, 282.0]], [[204.0, 101.0], [232.0, 101.0], [229.0, 218.0], [201.0, 218.0]]], "lines": ["つーかさぁ、", "これからもココ", "来よーよ。"]}, {"box": [95, 239, 212, 425], "vertical": true, "font_size": 26, "lines_coords": [[[190.0, 242.0], [212.0, 242.0], [212.0, 407.0], [190.0, 407.0]], [[154.0, 239.0], [185.0, 239.0], [185.0, 400.0], [154.0, 400.0]], [[126.0, 239.0], [148.0, 239.0], [148.0, 425.0], [126.0, 425.0]], [[95.0, 239.0], [117.0, 239.0], [117.0, 384.0], [95.0, 384.0]]], "lines": ["エアガン持って", "サバゲーとか", "やったらぜってー", "楽しいって！！"]}, {"box": [690, 443, 788, 601], "vertical": true, "font_size": 25, "lines_coords": [[[760.0, 443.0], [787.0, 443.0], [787.0, 601.0], [760.0, 601.0]], [[723.0, 443.0], [750.0, 443.0], [750.0, 601.0], [723.0, 601.0]], [[690.0, 443.0], [712.0, 443.0], [712.0, 548.0], [690.0, 548.0]]], "lines": ["これはこれで", "良かった気も", "するし！！"]}, {"box": [910, 818, 935, 859], "vertical": true, "font_size": 30, "lines_coords": [[[910.0, 818.0], [935.0, 818.0], [935.0, 859.0], [910.0, 859.0]]], "lines": ["ん、"]}, {"box": [743, 803, 850, 992], "vertical": true, "font_size": 30, "lines_coords": [[[815.0, 804.0], [850.0, 804.0], [850.0, 895.0], [815.0, 895.0]], [[779.0, 803.0], [810.0, 803.0], [810.0, 992.0], [779.0, 992.0]], [[746.0, 804.0], [773.0, 804.0], [770.0, 937.0], [743.0, 937.0]]], "lines": ["そだね、", "夏休みの間なら", "なんとか．．．"]}, {"box": [906, 1129, 973, 1247], "vertical": true, "font_size": 30, "lines_coords": [[[935.0, 1129.0], [973.0, 1129.0], [973.0, 1193.0], [935.0, 1193.0]], [[906.0, 1131.0], [928.0, 1131.0], [928.0, 1242.0], [906.0, 1242.0]]], "lines": ["実は", "僕んちさ"]}, {"box": [239, 907, 268, 964], "vertical": true, "font_size": 29, "lines_coords": [[[239.0, 907.0], [268.0, 907.0], [268.0, 964.0], [239.0, 964.0]]], "lines": ["え？"]}, {"box": [154, 1345, 258, 1531], "vertical": true, "font_size": 29, "lines_coords": [[[226.0, 1350.0], [254.0, 1350.0], [254.0, 1456.0], [226.0, 1456.0]], [[192.0, 1346.0], [220.0, 1346.0], [217.0, 1531.0], [189.0, 1531.0]], [[154.0, 1345.0], [185.0, 1345.0], [185.0, 1515.0], [154.0, 1515.0]]], "lines": ["二学期に", "なったらすぐに", "引っ越すんだ。"]}], "img_path": "018.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [762, 98, 795, 209], "vertical": true, "font_size": 31, "lines_coords": [[[762.0, 98.0], [795.0, 98.0], [795.0, 209.0], [762.0, 209.0]]], "lines": ["えー．．．"]}, {"box": [621, 131, 726, 292], "vertical": true, "font_size": 31, "lines_coords": [[[698.0, 135.0], [726.0, 135.0], [726.0, 251.0], [698.0, 251.0]], [[662.0, 134.0], [689.0, 134.0], [689.0, 292.0], [662.0, 292.0]], [[621.0, 131.0], [657.0, 131.0], [657.0, 192.0], [621.0, 192.0]]], "lines": ["ハルミン、", "転校しちゃう", "の？"]}, {"box": [219, 173, 247, 295], "vertical": true, "font_size": 22, "lines_coords": [[[220.0, 178.0], [242.0, 178.0], [242.0, 292.0], [220.0, 292.0]]], "lines": ["．．．うん"]}, {"box": [912, 832, 1012, 1020], "vertical": true, "font_size": 27, "lines_coord