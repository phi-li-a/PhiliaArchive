.0, 779.0], [3710.0, 779.0]], [[3297.0, 748.0], [3555.0, 748.0], [3555.0, 779.0], [3297.0, 779.0]], [[3297.0, 775.0], [3471.0, 775.0], [3471.0, 817.0], [3297.0, 817.0]], [[3706.0, 779.0], [3801.0, 779.0], [3801.0, 817.0], [3706.0, 817.0]], [[3676.0, 809.0], [3793.0, 809.0], [3793.0, 839.0], [3676.0, 839.0]], [[3297.0, 809.0], [3471.0, 809.0], [3471.0, 839.0], [3297.0, 839.0]], [[3297.0, 839.0], [3797.0, 839.0], [3797.0, 870.0], [3297.0, 870.0]], [[3304.0, 877.0], [3790.0, 877.0], [3790.0, 896.0], [3304.0, 896.0]], [[3384.0, 900.0], [3714.0, 900.0], [3714.0, 930.0], [3384.0, 930.0]], [[3293.0, 923.0], [3786.0, 926.0], [3786.0, 968.0], [3293.0, 965.0]], [[3323.0, 972.0], [3763.0, 976.0], [3763.0, 1010.0], [3323.0, 1006.0]]], "lines": ["おやすみブンブン・トークを", "浅野いにお浅野Ｖにお", "ソラニン・全２巻", "ほしのふるまち１〜日巻", "一原秀則", "はしいかなぁっ１０１ポントの福音、全４巻", "一原秀則高橋留美子", "ロｒコトー診療所「－－２）港", "山田貴敏", "七月鏡一ノ藤原芳秀", "間のイージス、１〜４０巻－ｎｕｓｅｍ", "ひかりの空、１－２７巻、かざま鋭二ノ坂田信弘", "ＦＡＮＥＯＷ三金の形に関わりましたが、本当に１０巻、安部長二ノ柿崎正澄", "一ゆうきまさみ", "結構バーティー「ーーリきー」", "室積光ノ猪熊しのぶ", "教えて、都立水商「１〜１７巻", "黒丸ノ夏原武", "都立公園・クロサギ・１〜１６巻", "クロウキートールも、インターネットボールに対して１０００円以上のページによると、", "高橋のぼるなぁ", "土竜（モグラ）の唄－１－１０巻サービス・", "土曜日で超無気力戦隊シャバファイブー一日巻、佐藤まさき", "石波治", "Ｏｄｄｅ－オッズ・１～６巻", "しかし、オッヘーーーも君さんはシトロームクトの原因について１〜５巻一北崎拓", "竹原慎二ノ落合裕介", "ここからジャームページのタナトスもいいからのチューヨーが", "一旦巻一河合克敵", "とめはねっ！鈴里高校建造部、キュールーーー", "２巻一盛田賢司", "花蓮女学院高校男子剣道部", "盗田真白森尾正博", "１０年ステルに入力して、ビーチスターズ、１〜日巻", "花の部・１〜２巻（｀）です。", "近藤隆史スポーツ", "むろなが供未", "１００７年１１月２０１７－活人－１巻", "ＵＵＩ『へー』逃亡弁護士・成田誠１〜２巻一高田優ノ剛英城", "まつろはぬもの。知り渡る古道。１巻一木根ヲサムノ国川光太郎", "おかしいならば、「ローバルン」というイングサンテーコミックススペシャルの", "結果に効くクスリンデーユニック管理に対してクリスリムにススペシャル１〜１１巻・山田玲司", "ｈｔｔｐ／／ｗｗｗ．ｙｏｕｎｇｓｕｎｄａｙｃｏｎ"]}, {"box": [3327, 1218, 3767, 1493], "vertical": false, "font_size": 30, "lines_coords": [[[3452.0, 1222.0], [3630.0, 1222.0], [3630.0, 1264.0], [3452.0, 1264.0]], [[3392.0, 1260.0], [3691.0, 1264.0], [3691.0, 1306.0], [3392.0, 1302.0]], [[3342.0, 1298.0], [3748.0, 1298.0], [3748.0, 1329.0], [3342.0, 1329.0]], [[3384.0, 1325.0], [3699.0, 1325.0], [3699.0, 1355.0], [3384.0, 1355.0]], [[3350.0, 1347.0], [3740.0, 1347.0], [3740.0, 1378.0], [3350.0, 1378.0]], [[3380.0, 1385.0], [3702.0, 1385.0], [3702.0, 1404.0], [3380.0, 1404.0]], [[3350.0, 1404.0], [3748.0, 1404.0], [3748.0, 1435.0], [3350.0, 1435.0]], [[3373.0, 1434.0], [3714.0, 1434.0], [3714.0, 1465.0], [3373.0, 1465.0]], [[3392.0, 1461.0], [3702.0, 1461.0], [3702.0, 1492.0], [3392.0, 1492.0]]], "lines": ["浅野いにお", "１９８０年生まれ、茨城県出身。１年前は、", "２００１年、第１１回サンデー城宗山身。ＧＸ新人賞入賞", "「中、第１回グラフィルスの主な著作に「素晴らしい世界」といっていますが、", "「主な者作に」素晴ら『ひかりのまち』（ともにしい世界小社刊がある", "２００５年、『ソラニン！を発表。", "全国より世代性別フーノ』を先表。を超えた反響を呼ぶ。", "皆さんとはいわかるんだよ。２００７年よりヤングサンテーにて「やめちゃって、", "３０「キュット・「おやすみプンプン」を連載中。"]}, {"box": [3299, 1539, 3778, 1579], "vertical": false, "font_size": 44, "lines_coords": [[[3299.0, 1535.0], [3778.0, 1535.0], [3778.0, 1583.0], [3299.0, 1583.0]]], "lines": ["イラスト型には「ガイン料理」ベリリンスタング"]}], "img_path": "001.png"}, {"version": "0.2.0-beta.6", "img_width": 2380, "img_height": 1600, "blocks": [{"box": [1148, 72, 1229, 891], "vertical": true, "font_size": 44, "lines_coords": [[[1166.0, 72.0], [1229.0, 72.0], [1210.0, 879.0], [1148.0, 879.0]], [[1159.0, 81.0], [1185.0, 81.0], [1185.0, 134.0], [1159.0, 134.0]]], "lines": ["あ、おですかプランスは、お客様にお", "．．．"]}, {"box": [76, 527, 132, 1250], "vertical": true, "font_size": 30, "lines_coords": [[[88.0, 530.0], [118.0, 530.0], [118.0, 1232.0], [88.0, 1232.0]]], "lines": ["おやすみフンフンる、浅野いにお"]}], "img_path": "002.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "003.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [103, 457, 154, 1178], "vertical": true, "font_size": 48, "lines_coords": [[[106.0, 457.0], [154.0, 457.0], [151.0, 1178.0], [103.0, 1178.0]]], "lines": ["おやすみプンプンの一浅野にお"]}, {"box": [69, 1489, 276, 1514], "vertical": false, "font_size": 23, "lines_coords": [[[76.0, 1491.0], [273.0, 1491.0], [273.0, 1516.0], [76.0, 1516.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹＣＯＭＣＳ"]}], "img_path": "004.png"}, {"ver