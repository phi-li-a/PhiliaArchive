, "lines_coords": [[[365.0, 64.0], [393.0, 64.0], [393.0, 195.0], [365.0, 195.0]], [[329.0, 64.0], [356.0, 64.0], [356.0, 246.0], [329.0, 246.0]], [[292.0, 62.0], [318.0, 62.0], [320.0, 257.0], [293.0, 257.0]]], "lines": ["フンフンは", "こっそりと強く", "握りしめました。"]}, {"box": [576, 1246, 715, 1484], "vertical": true, "font_size": 26, "lines_coords": [[[689.0, 1251.0], [710.0, 1251.0], [710.0, 1479.0], [689.0, 1479.0]], [[650.0, 1246.0], [676.0, 1246.0], [676.0, 1459.0], [650.0, 1459.0]], [[612.0, 1248.0], [640.0, 1248.0], [640.0, 1381.0], [612.0, 1381.0]], [[576.0, 1248.0], [603.0, 1248.0], [603.0, 1439.0], [576.0, 1439.0]]], "lines": ["今にもこほれそうな", "この満天の星空を", "いつかまた", "見れたらいいな。"]}, {"box": [378, 1248, 443, 1458], "vertical": true, "font_size": 26, "lines_coords": [[[414.0, 1250.0], [440.0, 1250.0], [440.0, 1456.0], [414.0, 1456.0]], [[378.0, 1248.0], [404.0, 1248.0], [404.0, 1439.0], [378.0, 1439.0]]], "lines": ["なぜかフンフンは", "そう思いました。"]}], "img_path": "093.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "094.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "095.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [876, 89, 1013, 326], "vertical": true, "font_size": 28, "lines_coords": [[[984.0, 93.0], [1010.0, 93.0], [1010.0, 326.0], [984.0, 326.0]], [[948.0, 95.0], [975.0, 95.0], [975.0, 303.0], [948.0, 303.0]], [[909.0, 89.0], [940.0, 89.0], [937.0, 301.0], [906.0, 301.0]], [[876.0, 92.0], [903.0, 92.0], [903.0, 209.0], [876.0, 209.0]]], "lines": ["．．．日未明、メメ署に", "「家族を殺した」と", "出頭してきた男の", "供述通り、"]}, {"box": [104, 156, 277, 392], "vertical": true, "font_size": 25, "lines_coords": [[[250.0, 160.0], [276.0, 160.0], [276.0, 343.0], [250.0, 343.0]], [[214.0, 159.0], [240.0, 159.0], [240.0, 378.0], [214.0, 378.0]], [[178.0, 159.0], [204.0, 159.0], [204.0, 392.0], [178.0, 392.0]], [[142.0, 160.0], [164.0, 160.0], [164.0, 365.0], [142.0, 365.0]], [[106.0, 156.0], [132.0, 156.0], [131.0, 350.0], [104.0, 350.0]]], "lines": ["ｘｘ市内にある", "みそ工場跡地から、", "死後数か月が経った", "男女三名の遺体が", "発見されました。"]}, {"box": [946, 485, 975, 614], "vertical": true, "font_size": 26, "lines_coords": [[[946.0, 485.0], [975.0, 485.0], [975.0, 614.0], [946.0, 614.0]]], "lines": ["．．．アラッ！！"]}, {"box": [806, 614, 921, 793], "vertical": true, "font_size": 26, "lines_coords": [[[898.0, 614.0], [921.0, 614.0], [920.0, 793.0], [896.0, 793.0]], [[865.0, 615.0], [892.0, 615.0], [892.0, 760.0], [865.0, 760.0]], [[832.0, 615.0], [859.0, 615.0], [859.0, 773.0], [832.0, 773.0]], [[806.0, 617.0], [828.0, 617.0], [828.0, 759.0], [806.0, 759.0]]], "lines": ["この工場、あたし", "知ってるワ！！", "ホラ、Ｋ街道を", "下った先の．．．"]}, {"box": [304, 489, 446, 650], "vertical": true, "font_size": 30, "lines_coords": [[[409.0, 489.0], [446.0, 489.0], [446.0, 637.0], [409.0, 637.0]], [[376.0, 492.0], [407.0, 492.0], [407.0, 650.0], [376.0, 650.0]], [[342.0, 495.0], [368.0, 495.0], [368.0, 623.0], [342.0, 623.0]], [[307.0, 490.0], [334.0, 490.0], [331.0, 621.0], [304.0, 621.0]]], "lines": ["あーあの", "大きな工場？", "いつの間に", "潰れたの？"]}, {"box": [40, 474, 86, 634], "vertical": true, "font_size": 44, "lines_coords": [[[40.0, 475.0], [84.0, 475.0], [84.0, 634.0], [40.0, 634.0]]], "lines": ["第１８話"]}, {"box": [101, 748, 212, 935], "vertical": true, "font_size": 23, "lines_coords": [[[185.0, 748.0], [212.0, 748.0], [212.0, 862.0], [185.0, 862.0]], [[156.0, 748.0], [182.0, 748.0], [182.0, 914.0], [156.0, 914.0]], [[129.0, 750.0], [151.0, 750.0], [151.0, 935.0], [129.0, 935.0]], [[101.0, 753.0], [118.0, 753.0], [118.0, 865.0], [101.0, 865.0]]], "lines": ["看護婦さー", "テレビもう少し", "映り良くならない", "のかしら？"]}, {"box": [187, 865, 209, 918], "vertical": true, "font_size": 23, "lines_coords": [[[187.0, 865.0], [209.0, 865.0], [209.0, 918.0], [187.0, 918.0]]], "lines": ["ーん"]}, {"box": [621, 1254, 776, 1478], "vertical": true, "font_size": 21, "lines_coords": [[[753.0, 1256.0], [775.0, 1256.0], [775.0, 1373.0], [753.0, 1373.0]], [[720.0, 1257.0], [742.0, 1257.0], [742.0, 1467.0], [720.0, 1467.0]], [[687.0, 1256.0], [707.0, 1256.0], [707.0, 1478.0], [687.0, 1478.0]], [[654.0, 1254.0], [676.0, 1254.0], [676.0, 1467.0], [654.0, 1467.0]], [[623.0, 1256.0], [643.0, 1256.0], [643.0, 1456.0], [623.0, 1456.0]]], "lines": ["：容疑者は", "犯行の動機について、", "一仕事について口論に", "なり、カッとなって", "殺した」と供述し．．．"]}, {"box": [103, 1148, 240, 1359], "vertical": true, "font_size": 27, "lines_coords": [[[210.0, 1148.0], [239.0, 1148.0], [237.0, 1356.0], [209.0, 1356.0]], [[173.0, 1148.0], [200.0, 1148.0], [200.0, 1357.0], [173.0, 1357.0]], [[139.0, 1148.0], [165.0, 1148.0], [165.0, 1359.0], [139.0, 1359.0]], [[103.0, 1148.0], [129.0, 1148.0], [129.0, 1318.0], [103.0, 1318.0]]], "lines": ["同工場では火災の", "形跡があり、現在", "事件との関連性を", "調べています。"]}], "img_path": "096.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [718, 40, 745, 210], "vertical": true, "font_size": 29, "lines_coords": [[[718.0, 40.0], [745.0, 40.0], [745.0, 210.0], [718.0, 210.0]]], "lines": ["．．．プン山さん！！"]}, {"box": [581, 96, 684, 271], "vertical": true, "font_size": 29, "lines_coords": [[[653.0, 96.0], [684.0, 96.0], [684.0, 257.0], [653.0, 257.0]], [[617.0, 98.0], [648.0, 98.0], [648.0, 271.0], [617.0, 271.0]], [[581.0, 98.0], [607.0, 98.0], [607.0, 204.0], [581.0, 204.0]]], "lines": ["ダメじゃない", "ですか、勝手に", "出ちゃ！！"]}, {"box": [260, 89, 398, 256], "vertical": true, "font_size": 30, "lines_coords": [[[371.0, 93.0], [398.0, 93.0], [395.0, 226.0], [368.0, 226.0]], [[328.0, 89.0], [367.0, 89.0], [367.0, 256.0], [328.0, 256.0]], [[296.0, 93.0], [323.0, 93.0], [323.0, 253.0], [296.0, 253.0]], [[260.0, 92.0], [287.0, 92.0], [287.0, 226.0], [260.0, 226.0]]], "lines": ["．．．それと！！", "院内、喫煙所", "以外はすべて", "禁煙です！！"]}, {"box": [889, 376, 950, 502], "vertical": true, "font_size": 19, "lines_coords": [[[932.0, 376.0], [950.0, 376.0], [950.0, 482.0], [932.0, 482.0]], [[909.0, 376.0], [926.0, 376.0], [926.0, 484.0], [909.0, 484.0]], [[889.0, 381.0], [910.0, 381.0], [910.0, 448.0], [889.0, 448.0]]], "lines": ["記念時以外の", "これだけここ", "ください"]}, {"box": [78, 495, 218, 679], "vertical": true, "font_size": 29, "lines_coords": [[[179.0, 495.0], [218.0, 495.0], [218.0, 582.0], [179.0, 582.0]], [[150.0, 498.0], [176.0, 498.0], [175.0, 679.0], [148.0, 679.0]], [[114.0, 498.0], [140.0, 498.0], [140.0, 628.0], [114.0, 628.0]], [[78.0, 495.0], [104.0, 495.0], [104.0, 615.0], [78.0, 615.0]]], "lines": ["．．．別に", "誰にもメーワク", "かけてない", "じゃない。"]}, {"box": [251, 850, 320, 968], "vertical": true, "font_size": 29, "lines_coords": [[[284.0, 850.0], [320.0, 850.0], [320.0, 921.0], [284.0, 921.0]], [[251.0, 854.0], [279.0, 854.0], [279.0, 968.0], [251.0, 968.0]]], "lines": ["．．．ま", "実は私も、"]}, {"box": [117, 929, 217, 1100], "vertical": true, "font_size": 29, "lines_coords": [[[190.0, 929.0], [217.0, 929.0], [217.0, 1060.0], [190.0, 1060.0]], [[153.0, 929.0], [179.0, 929.0], [179.0, 1100.0], [153.0, 1100.0]], [[117.0, 931.0], [143.0, 931.0], [143.0, 1046.0], [117.0, 1046.0]]], "lines": ["ここからの", "眺め、好きなん", "ですケド。"]}], "img_path": "097.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [904, 79, 973, 228], "vertical": true, "font_size": 28, "lines_coords": [[[934.0, 79.0], [973.0, 79.0], [973.0, 168.0], [934.0, 168.0]], [[904.0, 84.0], [931.0, 84.0], [931.0, 228.0], [904.0, 228.0]]], "lines": ["．．．明日", "退院ですね。"]}, {"box": [784, 212, 881, 396], "vertical": true, "font_size": 28, "lines_coords": [[[854.0, 212.0], [881.0, 212.0], [881.0, 346.0], [854.0, 346.0]], [[818.0, 214.0], [845.0, 214.0], [845.0, 396.0], [818.0, 396.0]], [[784.0, 215.0], [806.0, 215.0], [806.0, 370.0], [784.0, 370.0]]], "lines": ["息子さんも", "喜ばれるんじゃ", "ないですか？"]}, {"box": [209, 356, 268, 518], "vertical": true, "font_size": 26, "lines_coords": [[[242.0, 356.0], [268.0, 356.0], [268.0, 518.0], [242.0, 518.0]], [[209.0, 356.0], [231.0, 356.0], [231.0, 493.0], [209.0, 493.0]]], "lines": ["知らないわよ、", "そんなこと。"]}, {"box": [134, 614, 273, 753], "vertical": true, "font_size": 26, "lines_coords": [[[246.0, 617.0], [273.0, 617.0], [273.0, 750.0], [246.0, 750.0]], [[210.0, 615.0], [237.0, 615.0], [237.0, 753.0], [210.0, 753.0]], [[168.0, 614.0], [196.0, 614.0], [200.0, 748.0], [171.0, 748.0]], [[134.0, 614.0], [160.0, 614.0], [164.0, 732.0], [137.0, 732.0]]], "lines": ["あたし子供", "キライだし、", "帰りたくも", "ないわよ。"]}, {"box": [876, 900, 989, 1100], "vertical": true, "font_size": 21, "lines_coords": [[[968.0, 903.0], [985.0, 903.0], [985.0, 1000.0], [968.0, 1000.0]], [[935.0, 900.0], [957.0, 900.0], [957.0, 1098.0], [935.0, 1098.0]], [[904.0, 901.0], [928.0, 901.0], [929.0, 1068.0], [906.0, 1068.0]], [[876.0, 903.0], [898.0, 903.0], [898.0, 996.0], [876.0, 996.0]]], "lines": ["．．．もうね", "どこにも無いのよ。", "あたしの居場所", "なんて！！"]}, {"box": [215, 925, 335, 1090], "vertical": true, "font_size": 24, "lines_coords": [[[314.0, 926.0], [335.0, 926.0], [335.0, 1067.0], [314.0, 1067.0]], [[279.0, 926.0], [306.0, 926.0], [306.0, 1071.0], [279.0, 1071.0]], [[246.0, 925.0], [273.0, 925.0], [273.0, 1090.0], [246.0, 1090.0]], [[215.0, 925.0], [240.0, 925.0], [240.0, 973.0], [215.0, 973.0]], [[215.0, 968.0], [239.0, 968.0], [239.0, 1023.0], [215.0, 1023.0]]], "lines": ["．．．あなたって", "ホンッッット", "真面目でイイコ", "ねー", "．．．"]}, {"box": [92, 998, 207, 1190], "vertical": true, "font_size": 24, "lines_coords": [[[182.0, 998.0], [206.0, 998.0], [207.0, 1167.0], [184.0, 1167.0]], [[153.0, 1000.0], [175.0, 1000.0], [175.0, 1128.0], [153.0, 1128.0]], [[120.0, 998.0], [143.0, 998.0], [145.0, 1190.0], [121.0, 1190.0]], [[92.0, 1001.0], [112.0, 1001.0], [112.0, 1165.0], [92.0, 1165.0]]], "lines": ["あたしが若くて", "男だったら、", "確実にむしゃぶり", "ついてるわ．．．"]}, {"box": [642, 1320, 749, 1510], "vertical": true, "font_size": 22, "lines_coords": [[[728.0, 1420.0], [748.0, 1420.0], [748.0, 1464.0], [728.0, 1464.0]], [[726.0, 1321.0], [748.0, 1321.0], [748.0, 1417.0], [726.0, 1417.0]], [[698.0, 1321.0], [720.0, 1321.0], [720.0, 1510.0], [698.0, 1510.0]], [[667.0, 1320.0], [693.0, 1320.0], [693.0, 1489.0], [667.0, 1489.0]], [[642.0, 1320.0], [664.0, 1320.0], [664.0, 1417.0], [642.0, 1417.0]]], "lines": ["．．．", "そんなー", "そんな悲しいこと", "言わないでくだ", "さいよ．．．"]}, {"box": [468, 1275, 546, 1440], "vertical": true, "font_size": 32, "lines_coords": [[[515.0, 1275.0], [546.0, 1275.0], [546.0, 1440.0], [515.0, 1440.0]], [[468.0, 1275.0], [501.0, 1275.0], [501.0, 1435.0], [468.0, 1435.0]]], "lines": ["．．．いいわね、", "若いって！！"]}, {"box": [315, 1376, 439, 1506], "vertical": true, "font_size": 32, "lines_coords": [[[406.0, 1376.0], [439.0, 1376.0], [439.0, 1475.0], [406.0, 1475.0]], [[365.0, 1379.0], [393.0, 1379.0], [393.0, 1503.0], [365.0, 1503.0]], [[318.0, 1376.0], [351.0, 1376.0], [348.0, 1506.0], [315.0, 1506.0]]], "lines": ["あなた", "セックス", "してる！？"]}, {"box": [82, 1371, 181, 1546], "vertical": true, "font_size": 26, "lines_coords": [[[153.0, 1373.0], [179.0, 1373.0], [179.0, 1546.0], [153.0, 1546.0]], [[117.0, 1373.0], [143.0, 1373.0], [143.0, 1531.0], [117.0, 1531.0]], [[82.0, 1371.0], [109.0, 1371.0], [109.0, 1456.0], [82.0, 1456.0]]], "lines": ["．．．いや、あの．．．", "彼氏いないん", "で．．．．．"]}], "img_path": "098.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [829, 121, 948, 407], "vertical": true, "font_size": 31, "lines_coords": [[[915.0, 123.0], [948.0, 123.0], [948.0, 284.0], [915.0, 284.0]], [[868.0, 121.0], [910.0, 121.0], [910.0, 381.0], [868.0, 381.0]], [[829.0, 125.0], [856.0, 125.0], [856.0, 407.0], [829.0, 407.0]]], "lines": ["出し惜しみ", "しないでバンバン", "セックスしなさい！！"]}, {"box": [709, 417, 809, 551], "vertical": true, "font_size": 31, "lines_coords": [[[782.0, 417.0], [809.0, 417.0], [809.0, 551.0], [782.0, 551.0]], [[746.0, 418.0], [773.0, 418.0], [773.0, 551.0], [746.0, 551.0]], [[709.0, 418.0], [737.0, 418.0], [737.0, 500.0], [709.0, 500.0]]], "lines": ["それはもう", "擦り切れる", "程に！！"]}, {"box": [246, 346, 273, 464], "vertical": true, "font_size": 28, "lines_coords": [[[246.0, 346.0], [273.0, 346.0], [273.0, 464.0], [246.0, 464.0]]], "lines": ["は、はァ．．．"]}, {"box": [162, 467, 225, 575], "vertical": true, "font_size": 28, "lines_coords": [[[196.0, 467.0], [225.0, 467.0], [225.0, 571.0], [196.0, 571.0]], [[162.0, 470.0], [190.0, 470.0], [190.0, 575.0], [162.0, 575.0]]], "lines": ["検討して", "みます．．"]}, {"box": [898, 1095, 1002, 1267], "vertical": true, "font_size": 29, "lines_coords": [[[973.0, 1096.0], [1001.0, 1096.0], [1001.0, 1229.0], [973.0, 1229.0]], [[937.0, 1096.0], [965.0, 1096.0], [965.0, 1229.0], [937.0, 1229.0]], [[898.0, 1095.0], [929.0, 1095.0], [929.0, 1267.0], [898.0, 1267.0]]], "lines": ["プンプンは", "大変に困惑", "していました。"]}, {"box": [435, 853, 551, 975], "vertical": false, "font_size": 115, "lines_coords": [[[443.0, 853.0], [551.0, 860.0], [543.0, 975.0], [435.0, 967.0]]], "lines": ["〜"]}, {"box": [565, 1156, 795, 1221], "vertical": false, "font_size": 29.0, "lines_coords": [[[565.0, 1159.0], [760.0, 1156.0], [760.0, 1182.0], [565.0, 1185.0]], [[601.0, 1190.0], [793.0, 1182.0], [795.0, 1214.0], [603.0, 1221.0]]], "lines": ["大きいじゃ、１０年の", "家業式、化けのご"]}, {"box": [160, 1122, 373, 1421], "vertical": true, "font_size": 26, "lines_coords": [[[346.0, 1125.0], [368.0, 1125.0], [367.0, 1356.0], [345.0, 1356.0]], [[307.0, 1125.0], [334.0, 1125.0], [334.0, 1332.0], [307.0, 1332.0]], [[270.0, 1126.0], [296.0, 1126.0], [296.0, 1332.0], [270.0, 1332.0]], [[234.0, 1123.0], [260.0, 1123.0], [259.0, 1417.0], [232.0, 1417.0]], [[196.0, 1125.0], [223.0, 1125.0], [223.0, 1359.0], [196.0, 1359.0]], [[160.0, 1123.0], [187.0, 1123.0], [187.0, 1314.0], [160.0, 1314.0]]], "lines": ["どれだけ困惑しても", "何も解決しないと", "わかっているのに", "困惑しかできない自分に、", "ブンブンは憤りすら", "感じていました。"]}], "img_path": "099.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [575, 90, 638, 313], "vertical": true, "font_size": 24, "lines_coords": [[[610.0, 90.0], [637.0, 90.0], [635.0, 260.0], [609.0, 260.0]], [[575.0, 93.0], [596.0, 93.0], [596.0, 306.0], [575.0, 306.0]]], "lines": ["「このままだと", "愛子ちゃんに．．．"]}, {"box": [264, 173, 320, 473], "vertical": true, "font_size": 54, "lines_coords": [[[264.0, 173.0], [318.0, 173.0], [320.0, 470.0], [265.0, 470.0]]], "lines": ["「殺される！！」"]}], "img_path": "100.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [888, 1029, 1026, 1229], "vertical": true, "font_size": 28, "lines_coords": [[[993.0, 1029.0], [1026.0, 1029.0], [1026.0, 1073.0], [993.0, 1073.0]], [[962.0, 1032.0], [989.0, 1032.0], [989.0, 1229.0], [962.0, 1229.0]], [[925.0, 1032.0], [951.0, 1032.0], [951.0, 1189.0], [925.0, 1189.0]], [[889.0, 1032.0], [915.0, 1032.0], [915.0, 1189.0], [889.0, 1189.0]]], "lines": ["えー", "明日からみんな", "お待ちかねの", "夏休みです！！"]}, {"box": [546, 1035, 648, 1190], "vertical": true, "font_size": 27, "lines_coords": [[[626.0, 1040.0], [648.0, 1040.0], [648.0, 1187.0], [626.0, 1187.0]], [[585.0, 1040.0], [614.0, 1040.0], [614.0, 1190.0], [585.0, 1190.0]], [[546.0, 1035.0], [582.0, 1035.0], [582.0, 1107.0], [546.0, 1107.0]]], "lines": ["夏を満喫して", "遊ぶのも結構", "だが、"]}, {"box": [643, 1243, 860, 1379], "vertical": false, "font_size": 68.0, "lines_coords": [[[643.0, 1243.0], [860.0, 1243.0], [860.0, 1328.0], [643.0, 1328.0]], [[692.0, 1328.0], [823.0, 1325.0], [825.0, 1376.0], [693.0, 1379.0]]], "lines": ["市民ホール", "まってるよ"]}, {"box": [465, 1160, 565, 1334], "vertical": true, "font_size": 27, "lines_coords": [[[539.0, 1160.0], [565.0, 1160.0], [565.0, 1326.0], [539.0, 1326.0]], [[504.0, 1162.0], [526.0, 1162.0], [526.0, 1334.0], [504.0, 1334.0]], [[465.0, 1162.0], [492.0, 1162.0], [492.0, 1310.0], [465.0, 1310.0]]], "lines": ["みんな、大事な", "ことを忘れちゃ", "いけないぞ！！"]}, {"box": [93, 1306, 200, 1526], "vertical": true, "font_size": 25, "lines_coords": [[[165.0, 1306.0], [192.0, 1306.0], [192.0, 1526.0], [165.0, 1526.0]], [[126.0, 1307.0], [153.0, 1307.0], [153.0, 1503.0], [126.0, 1503.0]], [[93.0, 1307.0], [115.0, 1307.0], [115.0, 1504.0], [93.0, 1504.0]]], "lines": ["宿題を怠った者には", "「死」あるのみだと", "そう思うように！！"]}], "img_path": "101.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [825, 37, 962, 224], "vertical": true, "font_size": 27, "lines_coords": [[[929.0, 37.0], [962.0, 37.0], [962.0, 148.0], [929.0, 148.0]], [[898.0, 39.0], [925.0, 39.0], [925.0, 182.0], [898.0, 182.0]], [[860.0, 40.0], [887.0, 40.0], [887.0, 223.0], [860.0, 223.0]], [[825.0, 40.0], [846.0, 40.0], [846.0, 223.0], [825.0, 223.0]]], "lines": ["．．．それと", "もうひとつ、", "みんなに大事な", "お話があります。"]}, {"box": [520, 104, 548, 195], "vertical": true, "font_size": 29, "lines_coords": [[[520.0, 104.0], [548.0, 104.0], [548.0, 195.0], [520.0, 195.0]]], "lines": ["晴見！！"]}, {"box": [415, 201, 482, 335], "vertical": true, "font_size": 29, "lines_coords": [[[442.0, 203.0], [479.0, 201.0], [482.0, 264.0], [445.0, 265.0]], [[415.0, 207.0], [437.0, 207.0], [437.0, 335.0], [415.0, 335.0]]], "lines": ["前に", "出なさい！！"]}, {"box": [95, 45, 384, 75], "vertical": false, "font_size": 28, "lines_coords": [[[95.0, 45.0], [384.0, 46.0], [384.0, 75.0], [95.0, 73.0]]], "lines": ["おやすみプンプン図"]}, {"box": [885, 626, 989, 840], "vertical": true, "font_size": 27, "lines_coords": [[[957.0, 626.0], [989.0, 626.0], [989.0, 840.0], [957.0, 840.0]], [[921.0, 629.0], [948.0, 629.0], [948.0, 840.0], [921.0, 840.0]], [[885.0, 629.0], [912.0, 629.0], [912.0, 820.0], [885.0, 820.0]]], "lines": ["本来なら二学期に", "なってからの予定", "だったんですが、"]}, {"box": [126, 389, 162, 520], "vertical": true, "font_size": 33, "lines_coords": [[[129.0, 389.0], [162.0, 389.0], [159.0, 520.0], [126.0, 520.0]]], "lines": ["ハ、ハイ！！"]}, {"box": [731, 782, 868, 993], "vertical": true, "font_size": 27, "lines_coords": [[[839.0, 782.0], [867.0, 782.0], [868.0, 973.0], [840.0, 973.0]], [[801.0, 784.0], [829.0, 784.0], [831.0, 968.0], [803.0, 968.0]], [[770.0, 787.0], [792.0, 787.0], [792.0, 993.0], [770.0, 993.0]], [[731.0, 784.0], [754.0, 784.0], [756.0, 992.0], [732.0, 992.0]]], "lines": ["ご両親の希望で、", "今学期で晴見が", "隣の市に転校する", "ことになりました。"]}, {"box": [159, 1154, 264, 1364], "vertical": true, "font_size": 29, "lines_coords": [[[235.0, 1156.0], [262.0, 1156.0], [262.0, 1335.0], [235.0, 1335.0]], [[196.0, 1156.0], [223.0, 1156.0], [223.0, 1364.0], [196.0, 1364.0]], [[159.0, 1154.0], [192.0, 1154.0], [192.0, 1246.0], [159.0, 1246.0]]], "lines": ["えーーー晴見君、", "それじゃみんなに", "挨拶を。"]}], "img_path": "102.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [803, 75, 928, 301], "vertical": true, "font_size": 33, "lines_coords": [[[895.0, 81.0], [928.0, 81.0], [928.0, 209.0], [895.0, 209.0]], [[851.0, 79.0], [882.0, 79.0], [882.0, 240.0], [851.0, 240.0]], [[807.0, 75.0], [842.0, 75.0], [837.0, 301.0], [803.0, 301.0]]], "lines": ["いままで", "ありがとう", "ございました！！"]}, {"box": [218, 0, 361, 65], "vertical": true, "font_size": 27, "lines_coords": [[[218.0, 14.0], [245.0, 14.0], [245.0, 65.0], [218.0, 65.0]]], "lines": ["よく"]}], "img_path": "103.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [821, 59, 953, 306], "vertical": true, "font_size": 28, "lines_coords": [[[921.0, 59.0], [953.0, 59.0], [953.0, 306.0], [921.0, 306.0]], [[892.0, 60.0], [918.0, 60.0], [918.0, 295.0], [892.0, 295.0]], [[854.0, 59.0], [881.0, 59.0], [881.0, 268.0], [854.0, 268.0]], [[821.0, 59.0], [848.0, 59.0], [848.0, 293.0], [821.0, 293.0]]], "lines": ["引っ越す新しい家さ、", "３階建てでガレージ", "とか床下収納とか", "すげーかっけーの！！"]}, {"box": [489, 73, 643, 285], "vertical": true, "font_size": 27, "lines_coords": [[[610.0, 73.0], [643.0, 73.0], [640.0, 192.0], [607.0, 192.0]], [[582.0, 76.0], [609.0, 76.0], [609.0, 257.0], [582.0, 257.0]], [[551.0, 76.0], [578.0, 76.0], [578.0, 234.0], [551.0, 234.0]], [[523.0, 81.0], [545.0, 81.0], [545.0, 284.0], [523.0, 284.0]], [[489.0, 79.0], [515.0, 79.0], [515.0, 209.0], [489.0, 209.0]]], "lines": ["．．．いいな", "じゃあハルミン", "もうコソコソ", "ＥＢＪしなくても", "いーんだ．．．"]}, {"box": [168, 46, 229, 245], "vertical": true, "font_size": 26, "lines_coords": [[[207.0, 50.0], [229.0, 50.0], [229.0, 167.0], [207.0, 167.0]], [[168.0, 46.0], [195.0, 46.0], [195.0, 245.0], [168.0, 245.0]]], "lines": ["そりゃもー", "ガンガンですよ！！"]}, {"box": [81, 215, 145, 350], "vertical": true, "font_size": 26, "lines_coords": [[[118.0, 218.0], [145.0, 218.0], [145.0, 350.0], [118.0, 350.0]], [[81.0, 215.0], [107.0, 215.0], [107.0, 323.0], [81.0, 323.0]]], "lines": ["バッキバキ", "ですよ！！"]}, {"box": [696, 456, 796, 639], "vertical": true, "font_size": 25, "lines_coords": [[[767.0, 456.0], [793.0, 456.0], [793.0, 639.0], [767.0, 639.0]], [[731.0, 456.0], [757.0, 456.0], [757.0, 589.0], [731.0, 589.0]], [[696.0, 456.0], [718.0, 456.0], [718.0, 621.0], [696.0, 621.0]]], "lines": ["そんで、ついに", "自分の部屋", "もらえるんだ。"]}, {"box": [128, 445, 265, 629], "vertical": true, "font_size": 26, "lines_coords": [[[235.0, 450.0], [262.0, 450.0], [262.0, 584.0], [235.0, 584.0]], [[198.0, 445.0], [225.0, 445.0], [225.0, 553.0], [198.0, 553.0]], [[164.0, 448.0], [190.0, 448.0], [190.0, 629.0], [164.0, 629.0]], [[128.0, 448.0], [154.0, 448.0], [154.0, 579.0], [128.0, 579.0]]], "lines": ["．．．いやいや、", "とはいえ", "ＥＢＪは永遠に", "不滅だよ？"]}, {"box": [754, 741, 982, 959], "vertical": true, "font_size": 28, "lines_coords": [[[953.0, 746.0], [982.0, 746.0], [982.0, 810.0], [953.0, 810.0]], [[917.0, 746.0], [943.0, 746.0], [943.0, 878.0], [917.0, 878.0]], [[862.0, 773.0], [889.0, 773.0], [889.0, 931.0], [862.0, 931.0]], [[823.0, 773.0], [854.0, 773.0], [854.0, 957.0], [823.0, 957.0]], [[787.0, 773.0], [818.0, 773.0], [818.0, 959.0], [787.0, 959.0]], [[754.0, 773.0], [781.0, 773.0], [781.0, 931.0], [754.0, 931.0]]], "lines": ["．．．ま、", "てもね．．．．．", "ずっと団地で", "姉ちゃんと同じ", "部屋ってのイヤ", "だったし．．．"]}, {"box": [928, 1090, 951, 1220], "vertical": true, "font_size": 22, "lines_coords": [[[928.0, 1090.0], [950.0, 1090.0], [950.0, 1220.0], [928.0, 1220.0]]], "lines": ["なんだろ．．．"]}, {"box": [115, 792, 287, 964], "vertical": true, "font_size": 28, "lines_coords": [[[260.0, 793.0], [287.0, 793.0], [284.0, 951.0], [257.0, 951.0]], [[223.0, 793.0], [250.0, 793.0], [250.0, 950.0], [223.0, 950.0]], [[187.0, 793.0], [214.0, 793.0], [214.0, 925.0], [187.0, 925.0]], [[148.0, 792.0], [179.0, 792.0], [179.0, 964.0], [148.0, 964.0]], [[115.0, 795.0], [142.0, 795.0], [142.0, 950.0], [115.0, 950.0]]], "lines": ["お父さんから", "家建てるって", "聞いた時は", "すっげうれし", "かったけど．．．"]}, {"box": [496, 1145, 596, 1328], "vertical": true, "font_size": 25, "lines_coords": [[[567.0, 1146.0], [595.0, 1146.0], [595.0, 1251.0], [567.0, 1251.0]], [[531.0, 1145.0], [557.0, 1145.0], [557.0, 1328.0], [531.0, 1328.0]], [[498.0, 1146.0], [520.0, 1146.0], [520.0, 1275.0], [498.0, 1275.0]]], "lines": ["今は別に", "そーでもないん", "だよね．．．"]}, {"box": [81, 1351, 181, 1509], "vertical": true, "font_size": 26, "lines_coords": [[[153.0, 1353.0], [179.0, 1353.0], [179.0, 1509.0], [153.0, 1509.0]], [[117.0, 1351.0], [143.0, 1351.0], [143.0, 1509.0], [117.0, 1509.0]], [[81.0, 1353.0], [107.0, 1353.0], [107.0, 1482.0], [81.0, 1482.0]]], "lines": ["あーゴメン！！", "ちょいココで", "待ってて！！"]}], "img_path": "104.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [903, 81, 985, 250], "vertical": true, "font_size": 37, "lines_coords": [[[950.0, 157.0], [981.0, 157.0], [981.0, 214.0], [950.0, 214.0]], [[942.0, 81.0], [985.0, 81.0], [985.0, 151.0], [942.0, 151.0]], [[903.0, 81.0], [946.0, 81.0], [946.0, 250.0], [903.0, 250.0]]], "lines": ["ーん", "ずー", "ずーっず"]}, {"box": [854, 81, 903, 273], "vertical": true, "font_size": 37, "lines_coords": [[[865.0, 218.0], [889.0, 218.0], [889.0, 273.0], [865.0, 273.0]], [[859.0, 81.0], [903.0, 82.0], [898.0, 223.0], [854.0, 221.0]]], "lines": ["．．．", "ずっずー"]}, {"box": [206, 173, 287, 306], "vertical": true, "font_size": 36, "lines_coords": [[[246.0, 173.0], [287.0, 173.0], [287.0, 246.0], [246.0, 246.0]], [[206.0, 175.0], [245.0, 175.0], [245.0, 306.0], [206.0, 306.0]]], "lines": ["ずー", "ずっずっ"]}, {"box": [248, 240, 282, 310], "vertical": true, "font_size": 36, "lines_coords": [[[248.0, 240.0], [282.0, 240.0], [282.0, 310.0], [248.0, 310.0]]], "lines": ["す"]}, {"box": [164, 176, 196, 337], "vertical": true, "font_size": 36, "lines_coords": [[[164.0, 176.0], [196.0, 176.0], [196.0, 337.0], [164.0, 337.0]]], "lines": ["ずーん！！"]}, {"box": [810, 692, 950, 932], "vertical": true, "font_size": 30, "lines_coords": [[[918.0, 693.0], [950.0, 693.0], [950.0, 929.0], [918.0, 929.0]], [[881.0, 692.0], [912.0, 692.0], [914.0, 932.0], [882.0, 932.0]], [[845.0, 692.0], [873.0, 692.0], [875.0, 904.0], [846.0, 904.0]], [[810.0, 695.0], [837.0, 695.0], [837.0, 851.0], [810.0, 851.0]]], "lines": ["ホラ、なんつーの？", "やっぱ引っ越しって", "荷物少ないほーが", "いいじゃん？"]}, {"box": [852, 1068, 1015, 1298], "vertical": true, "font_size": 27, "lines_coords": [[[979.0, 1068.0], [1012.0, 1068.0], [1012.0, 1256.0], [979.0, 1256.0]], [[950.0, 1070.0], [976.0, 1070.0], [976.0, 1298.0], [950.0, 1298.0]], [[917.0, 1070.0], [943.0, 1070.0], [943.0, 1239.0], [917.0, 1239.0]], [[882.0, 1070.0], [909.0, 1070.0], [909.0, 1281.0], [882.0, 1281.0]], [[853.0, 1071.0], [875.0, 1071.0], [875.0, 1237.0], [853.0, 1237.0]]], "lines": ["小松っちゃんは", "プレステ欲しいって", "言ってたけど、", "それは無理だから", "せめてコレを。"]}, {"box": [396, 1034, 435, 1154], "vertical": true, "font_size": 28, "lines_coords": [[[396.0, 1035.0], [431.0, 1034.0], [435.0, 1153.0], [401.0, 1154.0]]], "lines": ["．．．へへへ、"]}, {"box": [126, 695, 265, 907], "vertical": true, "font_size": 26, "lines_coords": [[[234.0, 695.0], [262.0, 695.0], [264.0, 890.0], [235.0, 890.0]], [[200.0, 696.0], [226.0, 696.0], [226.0, 895.0], [200.0, 895.0]], [[160.0, 695.0], [187.0, 695.0], [189.0, 907.0], [162.0, 907.0]], [[126.0, 700.0], [148.0, 700.0], [148.0, 854.0], [126.0, 854.0]]], "lines": ["それにプンプン、", "６段変速、すげー", "うらやましがって", "だからさ．．．"]}, {"box": [253, 1071, 353, 1246], "vertical": true, "font_size": 28, "lines_coords": [[[326.0, 1071.0], [353.0, 1071.0], [353.0, 1246.0], [326.0, 1246.0]], [[289.0, 1071.0], [315.0, 1071.0], [315.0, 1229.0], [289.0, 1229.0]], [[253.0, 1073.0], [279.0, 1073.0], [279.0, 1229.0], [253.0, 1229.0]]], "lines": ["こういう時って", "なんて言えば", "いーのかな．．．"]}, {"box": [103, 1382, 209, 1515], "vertical": true, "font_size": 30, "lines_coords": [[[173.0, 1382.0], [209.0, 1382.0], [209.0, 1446.0], [173.0, 1446.0]], [[142.0, 1387.0], [168.0, 1387.0], [168.0, 1515.0], [142.0, 1515.0]], [[106.0, 1384.0], [134.0, 1384.0], [131.0, 1492.0], [103.0, 1492.0]]], "lines": ["よく", "わかんない", "けど．．．"]}], "img_path": "105.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [878, 182, 981, 302], "vertical": true, "font_size": 30, "lines_coords": [[[946.0, 182.0], [981.0, 182.0], [981.0, 268.0], [946.0, 268.0]], [[914.0, 185.0], [942.0, 185.0], [942.0, 292.0], [914.0, 292.0]], [[878.0, 184.0], [906.0, 184.0], [906.0, 301.0], [878.0, 301.0]]], "lines": ["．．．また", "みんなで", "遊ぼーよ。"]}, {"box": [281, 135, 342, 290], "vertical": true, "font_size": 26, "lines_coords": [[[315.0, 135.0], [342.0, 135.0], [342.0, 256.0], [315.0, 256.0]], [[281.0, 137.0], [303.0, 137.0], [303.0, 290.0], [281.0, 290.0]]], "lines": ["次会う時", "まてには．．．"]}, {"box": [123, 221, 221, 378], "vertical": true, "font_size": 26, "lines_coords": [[[195.0, 223.0], [221.0, 223.0], [221.0, 378.0], [195.0, 378.0]], [[159.0, 221.0], [185.0, 221.0], [185.0, 356.0], [159.0, 356.0]], [[123.0, 223.0], [150.0, 223.0], [150.0, 329.0], [123.0, 329.0]]], "lines": ["無修正のやつ", "見つけとく", "からさ！！"]}, {"box": [251, 623, 280, 814], "vertical": true, "font_size": 27, "lines_coords": [[[251.0, 623.0], [278.0, 623.0], [278.0, 812.0], [251.0, 812.0]]], "lines": ["．．．またねっ！！"]}], "img_path": "106.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [878, 103, 1017, 330], "vertical": true, "font_size": 26, "lines_coords": [[[989.0, 104.0], [1015.0, 104.0], [1015.0, 237.0], [989.0, 237.0]], [[953.0, 104.0], [975.0, 104.0], [975.0, 310.0], [953.0, 310.0]], [[914.0, 103.0], [945.0, 103.0], [945.0, 317.0], [914.0, 317.0]], [[878.0, 103.0], [904.0, 103.0], [904.0, 328.0], [878.0, 328.0]]], "lines": ["プンプンは", "なんだかとっても", "さびしい気持ちに", "なってしまいました。"]}, {"box": [887, 534, 954, 625], "vertical": true, "font_size": 30, "lines_coords": [[[921.0, 534.0], [954.0, 534.0], [954.0, 620.0], [921.0, 620.0]], [[887.0, 537.0], [915.0, 537.0], [915.0, 625.0], [887.0, 625.0]]], "lines": ["正直な", "気持ち、"]}, {"box": [125, 520, 301, 745], "vertical": true, "font_size": 28, "lines_coords": [[[273.0, 521.0], [301.0, 521.0], [298.0, 704.0], [270.0, 704.0]], [[232.0, 520.0], [260.0, 520.0], [264.0, 665.0], [235.0, 665.0]], [[196.0, 520.0], [225.0, 520.0], [226.0, 745.0], [198.0, 745.0]], [[162.0, 521.0], [190.0, 521.0], [187.0, 706.0], [159.0, 706.0]], [[125.0, 520.0], [151.0, 520.0], [151.0, 689.0], [125.0, 689.0]]], "lines": ["愛子ちゃんとの", "約束なんて、", "少しだけどうでも", "よくなってきて", "しまいました。"]}, {"box": [801, 878, 976, 1076], "vertical": true, "font_size": 26, "lines_coords": [[[948.0, 881.0], [975.0, 881.0], [975.0, 1076.0], [948.0, 1076.0]], [[910.0, 879.0], [937.0, 879.0], [937.0, 1021.0], [910.0, 1021.0]], [[875.0, 879.0], [901.0, 879.0], [901.0, 1012.0], [875.0, 1012.0]], [[837.0, 878.0], [864.0, 878.0], [862.0, 1062.0], [835.0, 1062.0]], [[803.0, 878.0], [826.0, 878.0], [825.0, 1034.0], [801.0, 1034.0]]], "lines": ["「鹿児島だなんて", "遠いところ、", "子供だけで", "行けるわけない", "じゃないか。"]}, {"box": [105, 914, 280, 1099], "vertical": true, "font_size": 27, "lines_coords": [[[251.0, 917.0], [278.0, 917.0], [278.0, 1065.0], [251.0, 1065.0]], [[215.0, 917.0], [242.0, 917.0], [242.0, 1073.0], [215.0, 1073.0]], [[178.0, 915.0], [206.0, 915.0], [203.0, 1071.0], [175.0, 1071.0]], [[140.0, 914.0], [167.0, 914.0], [167.0, 1068.0], [140.0, 1068.0]], [[106.0, 915.0], [132.0, 915.0], [132.0, 1098.0], [106.0, 1098.0]]], "lines": ["「というより、", "なんで約束を", "破っただけで", "殺されなきゃ", "ならないのか。」"]}, {"box": [121, 1332, 223, 1528], "vertical": true, "font_size": 27, "lines_coords": [[[193.0, 1332.0], [221.0, 1332.0], [218.0, 1526.0], [190.0, 1526.0]], [[157.0, 1332.0], [184.0, 1332.0], [184.0, 1498.0], [157.0, 1498.0]], [[121.0, 1332.0], [148.0, 1332.0], [148.0, 1528.0], [121.0, 1528.0]]], "lines": ["「．．．馬鹿なんじゃ", "ないだろーか、", "愛子ちゃんは．．．」"]}], "img_path": "107.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [156, 582, 298, 743], "vertical": true, "font_size": 28, "lines_coords": [[[268.0, 584.0], [296.0, 584.0], [296.0, 717.0], [268.0, 717.0]], [[231.0, 585.0], [257.0, 585.0], [257.0, 743.0], [231.0, 743.0]], [[195.0, 584.0], [221.0, 584.0], [221.0, 717.0], [195.0, 717.0]], [[156.0, 582.0], [189.0, 582.0], [189.0, 676.0], [156.0, 676.0]]], "lines": ["ブンブンは", "もう笑うしか", "ありません", "でした。"]}, {"box": [803, 862, 941, 1046], "vertical": true, "font_size": 26, "lines_coords": [[[912.0, 862.0], [939.0, 862.0], [939.0, 1046.0], [912.0, 1046.0]], [[876.0, 862.0], [903.0, 862.0], [903.0, 1020.0], [876.0, 1020.0]], [[842.0, 865.0], [864.0, 865.0], [864.0, 1045.0], [842.0, 1045.0]], [[803.0, 862.0], [831.0, 862.0], [831.0, 953.0], [803.0, 953.0]]], "lines": ["なにがなんだか", "おっかしくて", "仕方ありません", "でした。"]}, {"box": [869, 1313, 908, 1540], "vertical": true, "font_size": 33, "lines_coords": [[[870.0, 1315.0], [903.0, 1315.0], [906.0, 1532.0], [873.0, 1532.0]]], "lines": ["「裏切ったら"]}, {"box": [176, 1322, 215, 1503], "vertical": true, "font_size": 32, "lines_coords": [[[178.0, 1328.0], [210.0, 1328.0], [210.0, 1498.0], [178.0, 1498.0]]], "lines": ["殺すから"]}], "img_path": "108.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [425, 264, 564, 501], "vertical": true, "font_size": 28, "lines_coords": [[[535.0, 267.0], [562.0, 267.0], [562.0, 462.0], [535.0, 462.0]], [[498.0, 267.0], [525.0, 267.0], [525.0, 501.0], [498.0, 501.0]], [[459.0, 264.0], [490.0, 264.0], [490.0, 425.0], [459.0, 425.0]], [[425.0, 267.0], [451.0, 267.0], [451.0, 460.0], [425.0, 460.0]]], "lines": ["「．．愛子ちゃんは", "僕を痛くないように", "殺してくれる", "だろうか．．．．．？」"]}, {"box": [146, 1217, 285, 1375], "vertical": true, "font_size": 28, "lines_coords": [[[254.0, 1218.0], [282.0, 1218.0], [282.0, 1350.0], [254.0, 1350.0]], [[217.0, 1218.0], [245.0, 1218.0], [245.0, 1325.0], [217.0, 1325.0]], [[182.0, 1217.0], [209.0, 1217.0], [209.0, 1375.0], [182.0, 1375.0]], [[146.0, 1217.0], [175.0, 1217.0], [175.0, 1309.0], [146.0, 1309.0]]], "lines": ["プンプンは", "もう胸が", "張り裂けそう", "でした。"]}], "img_path": "109.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [478, 751, 616, 924], "vertical": true, "font_size": 26, "lines_coords": [[[587.0, 754.0], [614.0, 754.0], [614.0, 921.0], [587.0, 921.0]], [[551.0, 753.0], [578.0, 753.0], [578.0, 884.0], [551.0, 884.0]], [[514.0, 751.0], [540.0, 751.0], [540.0, 884.0], [514.0, 884.0]], [[478.0, 753.0], [504.0, 753.0], [504.0, 921.0], [478.0, 921.0]]], "lines": ["「ギア付きなら", "鹿児島まで", "行けるかも", "しれない．．．：」"]}, {"box": [637, 1042, 703, 1175], "vertical": true, "font_size": 27, "lines_coords": [[[668.0, 1042.0], [703.0, 1042.0], [703.0, 1126.0], [668.0, 1126.0]], [[637.0, 1042.0], [664.0, 1042.0], [664.0, 1175.0], [637.0, 1175.0]]], "lines": ["プン山", "さーーん！"]}, {"box": [534, 1184, 600, 1295], "vertical": true, "font_size": 27, "lines_coords": [[[571.0, 1185.0], [600.0, 1185.0], [600.0, 1295.0], [571.0, 1295.0]], [[540.0, 1184.0], [565.0, 1187.0], [559.0, 1235.0], [534.0, 1232.0]]], "lines": ["検温です", "よー"]}, {"box": [539, 1239, 560, 1315], "vertical": true, "font_size": 27, "lines_coords": [[[539.0, 1239.0], [560.0, 1239.0], [560.0, 1315.0], [539.0, 1315.0]]], "lines": ["．．．？"]}, {"box": [87, 1390, 153, 1500], "vertical": true, "font_size": 31, "lines_coords": [[[115.0, 1392.0], [150.0, 1390.0], [153.0, 1485.0], [118.0, 1487.0]], [[87.0, 1396.0], [114.0, 1396.0], [114.0, 1500.0], [87.0, 1500.0]]], "lines": ["．．．あら、", "いない？"]}], "img_path": "110.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [691, 62, 826, 225], "vertical": true, "font_size": 24, "lines_coords": [[[800.0, 64.0], [826.0, 64.0], [826.0, 223.0], [800.0, 223.0]], [[764.0, 64.0], [790.0, 64.0], [790.0, 195.0], [764.0, 195.0]], [[728.0, 64.0], [750.0, 64.0], [750.0, 220.0], [728.0, 220.0]], [[692.0, 62.0], [714.0, 62.0], [714.0, 167.0], [692.0, 167.0]]], "lines": ["．．．すいません", "プン山さん", "見かけません", "てした？"]}, {"box": [360, 118, 498, 275], "vertical": true, "font_size": 28, "lines_coords": [[[470.0, 120.0], [498.0, 120.0], [498.0, 232.0], [470.0, 232.0]], [[432.0, 118.0], [459.0, 118.0], [459.0, 275.0], [432.0, 275.0]], [[396.0, 120.0], [425.0, 120.0], [425.0, 251.0], [396.0, 251.0]], [[360.0, 120.0], [387.0, 120.0], [387.0, 250.0], [360.0, 250.0]]], "lines": ["．．．あの人", "まーたタバコ", "吸ってんの", "かしら．．．？"]}, {"box": [290, 407, 350, 542], "vertical": true, "font_size": 18, "lines_coords": [[[332.0, 407.0], [350.0, 407.0], [350.0, 518.0], [332.0, 518.0]], [[309.0, 409.0], [329.0, 409.0], [329.0, 542.0], [309.0, 542.0]], [[290.0, 412.0], [307.0, 412.0], [307.0, 482.0], [290.0, 482.0]]], "lines": ["緊急時以外の", "こ利用はご遠慮", "ください"]}, {"box": [253, 673, 393, 860], "vertical": true, "font_size": 28, "lines_coords": [[[357.0, 673.0], [390.0, 673.0], [393.0, 792.0], [360.0, 792.0]], [[326.0, 678.0], [353.0, 678.0], [353.0, 860.0], [326.0, 860.0]], [[289.0, 676.0], [315.0, 676.0], [315.0, 834.0], [289.0, 834.0]], [[253.0, 676.0], [281.0, 676.0], [281.0, 809.0], [253.0, 809.0]]], "lines": ["．．．ホント、", "最後の最後まで", "世話やけるん", "だから．．．"]}], "img_path": "111.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "112.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [845, 1025, 900, 1237], "vertical": true, "font_size": 33, "lines_coords": [[[867.0, 1025.0], [900.0, 1028.0], [878.0, 1237.0], [845.0, 1234.0]]], "lines": ["本日レンタルも"]}], "img_path": "113.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [215, 235, 245, 309], "vertical": true, "font_size": 30, "lines_coords": [[[215.0, 235.0], [245.0, 235.0], [245.0, 309.0], [215.0, 309.0]]], "lines": ["カチッ"]}, {"box": [867, 437, 926, 683], "vertical": true, "font_size": 59, "lines_coords": [[[867.0, 437.0], [926.0, 437.0], [926.0, 683.0], [867.0, 683.0]]], "lines": ["しかし、"]}, {"box": [25, 285, 69, 531], "vertical": true, "font_size": 43, "lines_coords": [[[25.0, 285.0], [68.0, 285.0], [68.0, 446.0], [25.0, 446.0]]], "lines": ["第１９話"]}, {"box": [948, 1006, 975, 1125], "vertical": true, "font_size": 27, "lines_coords": [[[948.0, 1006.0], [975.0, 1006.0], [975.0, 1125.0], [948.0, 1125.0]]], "lines": ["もしもし。"]}, {"box": [139, 1081, 237, 1278], "vertical": true, "font_size": 26, "lines_coords": [[[204.0, 1081.0], [237.0, 1081.0], [237.0, 1278.0], [204.0, 1278.0]], [[173.0, 1084.0], [200.0, 1084.0], [200.0, 1218.0], [173.0, 1218.0]], [[139.0, 1084.0], [167.0, 1084.0], [168.0, 1267.0], [140.0, 1267.0]]], "lines": ["あーどもども、", "姉がいつも", "お世話になって"]}, {"box": [114, 1157, 131, 1210], "vertical": true, "font_size": 26, "lines_coords": [[[114.0, 1157.0], [131.0, 1157.0], [131.0, 1210.0], [114.0, 1210.0]]], "lines": ["．．．．．"]}, {"box": [655, 1331, 767, 1514], "vertical": true, "font_size": 28, "lines_coords": [[[721.0, 1331.0], [754.0, 1331.0], [757.0, 1467.0], [725.0, 1467.0]], [[692.0, 1334.0], [718.0, 1334.0], [718.0, 1514.0], [692.0, 1514.0]], [[656.0, 1334.0], [682.0, 1334.0], [682.0, 1473.0], [656.0, 1473.0]]], "lines": ["小野寺．．．", "いえ、プン山で", "御座居ます。"]}], "img_path": "114.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [968, 910, 1002, 1068], "vertical": true, "font_size": 33, "lines_coords": [[[968.0, 910.0], [1001.0, 910.0], [1001.0, 1068.0], [968.0, 1068.0]]], "lines": ["プンプン！？"]}, {"box": [614, 918, 681, 1026], "vertical": true, "font_size": 30, "lines_coords": [[[648.0, 918.0], [681.0, 918.0], [681.0, 1003.0], [648.0, 1003.0]], [[614.0, 921.0], [642.0, 921.0], [642.0, 1026.0], [614.0, 1026.0]]], "lines": ["あっ！！", "いたっ！！"]}, {"box": [129, 1032, 264, 1242], "vertical": true, "font_size": 30, "lines_coords": [[[237.0, 1034.0], [264.0, 1034.0], [264.0, 1200.0], [237.0, 1200.0]], [[196.0, 1032.0], [228.0, 1032.0], [228.0, 1218.0], [196.0, 1218.0]], [[162.0, 1034.0], [189.0, 1034.0], [189.0, 1218.0], [162.0, 1218.0]], [[129.0, 1035.0], [151.0, 1035.0], [151.0, 1242.0], [129.0, 1242.0]]], "lines": ["．．．ってコラー、", "遊びに行く時は", "一声かけてって", "言ってるじゃ．．．"]}, {"box": [710, 1312, 792, 1472], "vertical": true, "font_size": 40, "lines_coords": [[[746.0, 1312.0], [792.0, 1312.0], [792.0, 1456.0], [746.0, 1456.0]], [[710.0, 1315.0], [743.0, 1315.0], [743.0, 1471.0], [710.0, 1471.0]]], "lines": ["おーい、", "プンプン！！"]}, {"box": [101, 1312, 265, 1535], "vertical": true, "font_size": 30, "lines_coords": [[[232.0, 1312.0], [265.0, 1312.0], [265.0, 1445.0], [232.0, 1445.0]], [[190.0, 1314.0], [221.0, 1314.0], [221.0, 1535.0], [190.0, 1535.0]], [[145.0, 1312.0], [178.0, 1312.0], [178.0, 1484.0], [145.0, 1484.0]], [[101.0, 1315.0], [134.0, 1315.0], [134.0, 1473.0], [101.0, 1473.0]]], "lines": ["とゆーか", "それどころじゃ", "ないのだよ、", "プンプン！！"]}], "img_path": "115.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [207, 190, 255, 403], "vertical": true, "font_size": 44, "lines_coords": [[[210.0, 190.0], [254.0, 190.0], [251.0, 403.0], [207.0, 403.0]]], "lines": ["姉さんが！！"]}, {"box": [833, 578, 954, 769], "vertical": true, "font_size": 30, "lines_coords": [[[920.0, 579.0], [954.0, 579.0], [954.0, 675.0], [920.0, 675.0]], [[875.0, 578.0], [906.0, 578.0], [906.0, 768.0], [875.0, 768.0]], [[834.0, 578.0], [860.0, 578.0], [860.0, 765.0], [834.0, 765.0]]], "lines": ["病院の", "非常階段から", "落ちたって！！"]}, {"box": [109, 1268, 246, 1478], "vertical": true, "font_size": 28, "lines_coords": [[[218.0, 1270.0], [245.0, 1270.0], [245.0, 1406.0], [218.0, 1406.0]], [[181.0, 1268.0], [209.0, 1268.0], [206.0, 1401.0], [178.0, 1401.0]], [[143.0, 1268.0], [175.0, 1268.0], [175.0, 1478.0], [143.0, 1478.0]], [[109.0, 1270.0], [135.0, 1270.0], [135.0, 1451.0], [109.0, 1451.0]]], "lines": ["運転手さん、", "急ぎなんで", "キノコダッシュで", "お願いします！！"]}], "img_path": "116.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "b