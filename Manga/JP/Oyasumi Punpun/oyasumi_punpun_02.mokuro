.0], [471.0, 1454.0], [443.0, 1454.0]], [[409.0, 1321.0], [440.0, 1321.0], [440.0, 1506.0], [409.0, 1506.0]], [[376.0, 1325.0], [398.0, 1325.0], [398.0, 1510.0], [376.0, 1510.0]]], "lines": ["ブンフンは", "ちょっとホッと", "していたのです。"]}], "img_path": "117.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [898, 65, 996, 273], "vertical": true, "font_size": 24, "lines_coords": [[[970.0, 65.0], [996.0, 65.0], [996.0, 259.0], [970.0, 259.0]], [[934.0, 65.0], [960.0, 65.0], [960.0, 273.0], [934.0, 273.0]], [[898.0, 68.0], [926.0, 68.0], [926.0, 168.0], [898.0, 168.0]]], "lines": ["．．．姉さんはねー、", "まぁ昔から難しい", "人でねー"]}, {"box": [903, 182, 921, 223], "vertical": true, "font_size": 24, "lines_coords": [[[903.0, 182.0], [921.0, 182.0], [921.0, 223.0], [903.0, 223.0]]], "lines": ["．．．"]}, {"box": [654, 3, 781, 444], "vertical": true, "font_size": 127, "lines_coords": [[[654.0, 3.0], [781.0, 3.0], [781.0, 444.0], [654.0, 444.0]]], "lines": ["んふっ．．．"]}, {"box": [493, 173, 562, 306], "vertical": true, "font_size": 27, "lines_coords": [[[535.0, 173.0], [562.0, 173.0], [562.0, 306.0], [535.0, 306.0]], [[496.0, 173.0], [529.0, 173.0], [526.0, 287.0], [493.0, 287.0]]], "lines": ["情緒不安定", "っつーか、"]}, {"box": [920, 518, 947, 734], "vertical": true, "font_size": 21, "lines_coords": [[[921.0, 518.0], [942.0, 518.0], [942.0, 723.0], [921.0, 723.0]]], "lines": ["だってフンフンは"]}, {"box": [757, 516, 857, 683], "vertical": true, "font_size": 27, "lines_coords": [[[831.0, 518.0], [857.0, 518.0], [857.0, 621.0], [831.0, 621.0]], [[793.0, 518.0], [820.0, 518.0], [820.0, 646.0], [793.0, 646.0]], [[757.0, 517.0], [784.0, 517.0], [784.0, 678.0], [757.0, 678.0]]], "lines": ["鹿児島に", "二人きりで", "行くのなんて"]}, {"box": [426, 304, 487, 503], "vertical": true, "font_size": 27, "lines_coords": [[[460.0, 304.0], [487.0, 304.0], [487.0, 465.0], [460.0, 465.0]], [[426.0, 307.0], [448.0, 307.0], [448.0, 503.0], [426.0, 503.0]]], "lines": ["平たく言うと", "変わり者だよね。"]}, {"box": [559, 518, 695, 724], "