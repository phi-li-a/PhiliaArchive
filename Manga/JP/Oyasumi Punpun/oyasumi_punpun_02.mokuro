.0, 568.0], [681.0, 568.0], [681.0, 751.0], [654.0, 751.0]], [[618.0, 565.0], [646.0, 565.0], [643.0, 698.0], [615.0, 698.0]], [[581.0, 567.0], [607.0, 567.0], [607.0, 725.0], [581.0, 725.0]]], "lines": ["それとも一人で", "鹿児島へ行って", "しまったの", "だろうか．．．"]}, {"box": [201, 839, 302, 1020], "vertical": true, "font_size": 25, "lines_coords": [[[273.0, 839.0], [300.0, 839.0], [300.0, 996.0], [273.0, 996.0]], [[240.0, 840.0], [262.0, 840.0], [262.0, 1018.0], [240.0, 1018.0]], [[201.0, 839.0], [228.0, 839.0], [228.0, 996.0], [201.0, 996.0]]], "lines": ["もしかしたら", "まだ泣いてるの", "だろうか．．．"]}, {"box": [642, 1332, 789, 1520], "vertical": true, "font_size": 31, "lines_coords": [[[746.0, 1332.0], [789.0, 1332.0], [789.0, 1404.0], [746.0, 1404.0]], [[717.0, 1337.0], [743.0, 1337.0], [743.0, 1495.0], [717.0, 1495.0]], [[679.0, 1337.0], [706.0, 1337.0], [706.0, 1520.0], [679.0, 1520.0]], [[643.0, 1340.0], [670.0, 1340.0], [670.0, 1496.0], [643.0, 1496.0]]], "lines": ["今頃、", "愛子ちゃんが", "何を想っている", "のかと思うと"]}, {"box": [518, 1335, 585, 1449], "vertical": true, "font_size": 30, "lines_coords": [[[553.0, 1335.0], [585.0, 1335.0], [585.0, 1443.0], [553.0, 1443.0]], [[518.0, 1337.0], [546.0, 1337.0], [546.0, 1448.0], [518.0, 1448.0]]], "lines": ["苦しくて", "苦しくて、"]}, {"box": [317, 1335, 457, 1521], "vertical": true, "font_size": 29, "lines_coords": [[[428.0, 1337.0], [456.0, 1337.0], [456.0, 1468.0], [428.0, 1468.0]], [[389.0, 1335.0], [415.0, 1335.0], [420.0, 1518.0], [393.0, 1518.0]], [[356.0, 1337.0], [382.0, 1337.0], [382.0, 1468.0], [356.0, 1468.0]], [[317.0, 1335.0], [351.0, 1335.0], [351.0, 1432.0], [317.0, 1432.0]]], "lines": ["フンフンは", "どうにかなって", "しまいそう", "でした。"]}], "img_path": "136.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [932, 110, 996, 268], "vertical": true, "font_size": 27, "lines_coords": [[[968.0, 110.0], [995.0, 110.0], [995.0, 268.0], [968.0, 268.0]], [[932.0, 110.0], [959.0, 110.0], [959.0, 254.0], [932.0, 254.0]]], "lines": ["こんな最低な", "自分