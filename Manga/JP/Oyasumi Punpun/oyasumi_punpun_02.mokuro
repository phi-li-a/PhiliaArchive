.0]], [[237.0, 110.0], [264.0, 110.0], [264.0, 214.0], [237.0, 214.0]]], "lines": ["いやぁ、", "僕ぐらいの年に", "なるとさ、"]}, {"box": [128, 200, 210, 357], "vertical": true, "font_size": 25, "lines_coords": [[[189.0, 200.0], [210.0, 200.0], [210.0, 335.0], [189.0, 335.0]], [[157.0, 200.0], [179.0, 200.0], [179.0, 357.0], [157.0, 357.0]], [[128.0, 200.0], [148.0, 200.0], [148.0, 345.0], [128.0, 345.0]]], "lines": ["若い女の子と", "何話していいか", "わかんないよ。"]}, {"box": [806, 496, 919, 721], "vertical": true, "font_size": 22, "lines_coords": [[[893.0, 496.0], [915.0, 496.0], [915.0, 645.0], [893.0, 645.0]], [[865.0, 498.0], [887.0, 498.0], [887.0, 720.0], [865.0, 720.0]], [[835.0, 498.0], [857.0, 498.0], [857.0, 656.0], [835.0, 656.0]], [[806.0, 496.0], [828.0, 496.0], [828.0, 684.0], [806.0, 684.0]]], "lines": ["なんせ、普段は", "女子アナと電化製品の", "ことくらいしか", "考えてないからね。"]}, {"box": [1021, 23, 1106, 1598], "vertical": true, "font_size": 78, "lines_coords": [[[1021.0, 23.0], [1100.0, 23.0], [1106.0, 1598.0], [1028.0, 1598.0]]], "lines": ["静かに再燃するプンプンと雄一それぞれの恋の炎。行く末は"]}, {"box": [275, 868, 301, 1000], "vertical": true, "font_size": 24, "lines_coords": [[[275.0, 868.0], [301.0, 868.0], [301.0, 1000.0], [275.0, 1000.0]]], "lines": ["ダメかな？"]}, {"box": [143, 948, 232, 1118], "vertical": true, "font_size": 24, "lines_coords": [[[206.0, 948.0], [232.0, 948.0], [232.0, 1118.0], [206.0, 1118.0]], [[175.0, 953.0], [196.0, 953.0], [196.0, 1118.0], [175.0, 1118.0]], [[143.0, 953.0], [165.0, 953.0], [165.0, 1093.0], [143.0, 1093.0]]], "lines": ["ダメな大人って", "罵ってくれても", "構わないよ？"]}, {"box": [1029, 916, 1099, 1635], "vertical": true, "font_size": 70, "lines_coords": [[[1029.0, 916.0], [1099.0, 916.0], [1099.0, 1635.0], [1029.0, 1635.0]]], "lines": ["れぞれの恋の炎。行く末は、"]}, {"box": [932, 1173, 959, 1326], "vertical": true, "font_size": 26, "lines_coords": [[[932.0, 1173.0], [959.0, 1173.0], [959.0, 1326.0], [932.0, 1326.0]]], "lines": ["いや、でもね。"]}, {"box": [775, 1254, 892, 1454], "vertical": true, "font_size": 26, "lines_coords": [[[