0]], [[159.0, 1217.0], [290.0, 1217.0], [290.0, 1262.0], [159.0, 1262.0]]], "lines": ["今、〈〒１０１８００１東京都千代田区一ツ橋二の三の", "発行所"]}, {"box": [157, 1314, 995, 1570], "vertical": false, "font_size": 20, "lines_coords": [[[160.0, 1328.0], [992.0, 1326.0], [992.0, 1348.0], [160.0, 1350.0]], [[157.0, 1354.0], [995.0, 1354.0], [995.0, 1376.0], [157.0, 1376.0]], [[160.0, 1381.0], [304.0, 1381.0], [304.0, 1401.0], [160.0, 1401.0]], [[159.0, 1407.0], [989.0, 1407.0], [989.0, 1428.0], [159.0, 1428.0]], [[159.0, 1434.0], [878.0, 1434.0], [878.0, 1454.0], [159.0, 1454.0]], [[160.0, 1464.0], [437.0, 1464.0], [437.0, 1479.0], [160.0, 1479.0]], [[157.0, 1489.0], [992.0, 1489.0], [992.0, 1509.0], [157.0, 1509.0]], [[162.0, 1518.0], [760.0, 1518.0], [760.0, 1534.0], [162.0, 1534.0]], [[157.0, 1540.0], [389.0, 1542.0], [389.0, 1564.0], [157.0, 1562.0]], [[381.0, 1543.0], [632.0, 1543.0], [632.0, 1564.0], [381.0, 1564.0]], [[631.0, 1542.0], [818.0, 1542.0], [818.0, 1562.0], [631.0, 1562.0]], [[753.0, 1381.0], [990.0, 1381.0], [990.0, 1401.0], [753.0, 1401.0]]], "lines": ["●遺本には十分注意しておりますが、落丁・乱丁（本のページの抜け落ちや瓶序の間違いつの場合はお取り", "替えいたします。購入された書店名を明記して「制作局」あてにお送りください。送料小社負担にてお取り", "り替えいたします。", "●本書の一部あるいいは全部を無断で複製転載：上演、放送等をすることは、法律で認められた場合を除き", "著作者および出版者の権利の侵害となります。あらかじめ小社あて許諾をお求めください。", "Ｒ「ＩＩ本類Ｓ権センター委託出版物", "本書を無断で複写複製（コピー）することは、著作権法上の例外を除き、禁じられています。本書をコピー", "される場合は、事前に日本複写権センター（ＲＲＣ）の許諾を受けてください", "ＪＲＲＣ〈ｈｔｔｐ：／／ｗｗｗ．ｊｉｔｃ．ｏｒ．ｊｐ", "．．．．．．ｉｎｆｏ＠ｉｎｔｃ．ｏｒ．ｊｐ", "．．．０３＿３４０１－２３８２", "制作局〈ＴＥＬ０１２０－３３６－０８２"]}, {"box": [496, 1228, 946, 1320], "vertical": false, "font_size": 92, "lines_coords": [[[496.0, 1228.0], [946.0, 1228.0], [946.0, 1320.0], [496.0, 1320.0]]], "lines": ["就学年間区一つ第一のこの一回、最終的に設定の設定があります。株式会社の学会・学習・学校のベーションは日本での時間がかかりません。"]}], "img_path": "209.png"}]}