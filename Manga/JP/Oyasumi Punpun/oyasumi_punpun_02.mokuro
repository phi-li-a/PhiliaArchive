276.0], [112.0, 1276.0], [112.0, 1523.0], [90.0, 1523.0]]], "lines": ["あのたくさんの星の", "どこかに運命の人が", "いたとしても、本当に", "巡り合うなんてこと", "てきるのかな．．．って。"]}], "img_path": "155.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [832, 54, 967, 282], "vertical": true, "font_size": 25, "lines_coords": [[[940.0, 54.0], [962.0, 54.0], [962.0, 259.0], [940.0, 259.0]], [[903.0, 54.0], [929.0, 54.0], [929.0, 282.0], [903.0, 282.0]], [[867.0, 54.0], [893.0, 54.0], [893.0, 262.0], [867.0, 262.0]], [[832.0, 56.0], [859.0, 56.0], [859.0, 248.0], [832.0, 248.0]]], "lines": ["きっとお父さんは", "スケベだから、いつも", "手近な人に夢中に", "なっちゃうんだ。"]}, {"box": [560, 210, 693, 395], "vertical": true, "font_size": 26, "lines_coords": [[[667.0, 212.0], [693.0, 212.0], [693.0, 392.0], [667.0, 392.0]], [[631.0, 210.0], [657.0, 210.0], [657.0, 351.0], [631.0, 351.0]], [[595.0, 210.0], [621.0, 210.0], [621.0, 395.0], [595.0, 395.0]], [[560.0, 212.0], [587.0, 212.0], [587.0, 300.0], [560.0, 300.0]]], "lines": ["わかり合いたい", "だけなのに、", "闇雲にぶつかり", "合って"]}, {"box": [335, 182, 401, 351], "vertical": true, "font_size": 31.5, "lines_coords": [[[370.0, 182.0], [401.0, 182.0], [401.0, 351.0], [370.0, 351.0]], [[335.0, 190.0], [367.0, 190.0], [367.0, 351.0], [335.0, 351.0]]], "lines": ["出る間大学", "テラ都"]}, {"box": [128, 57, 265, 281], "vertical": true, "font_size": 27, "lines_coords": [[[239.0, 59.0], [265.0, 59.0], [265.0, 281.0], [239.0, 281.0]], [[198.0, 57.0], [229.0, 57.0], [232.0, 270.0], [201.0, 270.0]], [[168.0, 60.0], [190.0, 60.0], [190.0, 242.0], [168.0, 242.0]], [[128.0, 59.0], [154.0, 59.0], [154.0, 267.0], [128.0, 267.0]]], "lines": ["．．．でもね、それでも", "大切にしたいって", "思った気持ちは", "本物だったって！！"]}, {"box": [482, 434, 606, 659], "vertical": true, "font_size": 26, "lines_coords": [[[579.0, 437.0], [606.0, 437.0], [606.0, 607.0], [579.0, 607.0]], [[545.0, 435.0], [571.0, 435.0], [571.0, 645.0], [545.0, 645.0]], [[515.0, 437.0], [542.0, 437.0], [542.0, 659.0], [515.0, 659.0]], [[484.0, 434.0], [510.0, 434.0], [509.0, 646.0], [482.0, 646.0]]], "lines": ["でも、人なんて", "きっとそんなもん", "なんだって、自分に", "言い聞かせながら"]}, {"box": [457, 489, 475, 515], "vertical": true, "font_size": 26, "lines_coords": [[[457.0, 489.0], [475.0, 489.0], [475.0, 515.0], [457.0, 515.0]]], "lines": ["．．"]}, {"box": [109, 351, 175, 493], "vertical": true, "font_size": 27, "lines_coords": [[[137.0, 353.0], [171.0, 351.0], [175.0, 437.0], [140.0, 439.0]], [[109.0, 357.0], [131.0, 357.0], [131.0, 493.0], [109.0, 493.0]]], "lines": ["信じて", "ほしいんだ。"]}, {"box": [896, 1082, 998, 1229], "vertical": true, "font_size": 33, "lines_coords": [[[965.0, 1084.0], [998.0, 1084.0], [998.0, 1181.0], [965.0, 1181.0]], [[923.0, 1084.0], [960.0, 1082.0], [964.0, 1168.0], [926.0, 1170.0]], [[896.0, 1087.0], [923.0, 1087.0], [923.0, 1229.0], [896.0, 1229.0]]], "lines": ["「わかる", "わかる", "超わかる！！」"]}, {"box": [281, 760, 345, 893], "vertical": true, "font_size": 27, "lines_coords": [[[318.0, 762.0], [345.0, 762.0], [345.0, 893.0], [318.0, 893.0]], [[281.0, 760.0], [314.0, 760.0], [314.0, 882.0], [281.0, 882.0]]], "lines": ["．．．ごめんよ", "プンプン、"]}, {"box": [154, 823, 251, 1032], "vertical": true, "font_size": 27, "lines_coords": [[[225.0, 823.0], [251.0, 823.0], [251.0, 935.0], [225.0, 935.0]], [[189.0, 825.0], [215.0, 825.0], [215.0, 982.0], [189.0, 982.0]], [[154.0, 829.0], [176.0, 829.0], [176.0, 1032.0], [154.0, 1032.0]]], "lines": ["こんな話、", "プンプンには", "つまんないかな？"]}, {"box": [912, 1378, 977, 1535], "vertical": true, "font_size": 28, "lines_coords": [[[948.0, 1378.0], [976.0, 1378.0], [976.0, 1490.0], [948.0, 1490.0]], [[912.0, 1379.0], [939.0, 1379.0], [939.0, 1534.0], [912.0, 1534.0]]], "lines": ["．．．そっか、", "超わかるか！！"]}, {"box": [464, 1129, 565, 1329], "vertical": true, "font_size": 27, "lines_coords": [[[535.0, 1131.0], [564.0, 1131.0], [564.0, 1264.0], [535.0, 1264.0]], [[495.0, 1129.0], [526.0, 1129.0], [529.0, 1329.0], [498.0, 1329.0]], [[465.0, 1134.0], [487.0, 1134.0], [487.0, 1271.0], [465.0, 1271.0]]], "lines": ["プンプンは", "かなりテキトーに", "答えました。"]}, {"box": [453, 1400, 556, 1529], "vertical": true, "font_size": 30, "lines_coords": [[[521.0, 1400.0], [556.0, 1400.0], [556.0, 1482.0], [521.0, 1482.0]], [[489.0, 1401.0], [517.0, 1401.0], [517.0, 1529.0], [489.0, 1529.0]], [[453.0, 1400.0], [481.0, 1400.0], [481.0, 1482.0], [453.0, 1482.0]]], "lines": ["さすが", "超プンプン", "だな！！"]}, {"box": [112, 1142, 274, 1534], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 1150.0], [243.0, 1150.0], [243.0, 1282.0], [217.0, 1282.0]], [[215.0, 1323.0], [243.0, 1323.0], [245.0, 1457.0], [217.0, 1457.0]], [[179.0, 1325.0], [207.0, 1325.0], [209.0, 1534.0], [181.0, 1534.0]], [[143.0, 1326.0], [170.0, 1326.0], [171.0, 1506.0], [145.0, 1506.0]], [[112.0, 1326.0], [134.0, 1326.0], [134.0, 1482.0], [112.0, 1482.0]]], "lines": ["お父さんね、", "プンプンに", "ひとつだけ言って", "おきたいことが", "あるんだ．．．．．"]}], "img_path": "156.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [396, 1009, 429, 1168], "vertical": true, "font_size": 33, "lines_coords": [[[396.0, 1009.0], [429.0, 1009.0], [429.0, 1168.0], [396.0, 1168.0]]], "lines": ["タハーーッ！！"]}, {"box": [323, 1112, 356, 1196], "vertical": true, "font_size": 33, "lines_coords": [[[323.0, 1112.0], [356.0, 1112.0], [356.0, 1196.0], [323.0, 1196.0]]], "lines": ["ワッ！！"]}, {"box": [90, 1049, 201, 1348], "vertical": true, "font_size": 27, "lines_coords": [[[171.0, 1054.0], [198.0, 1054.0], [198.0, 1092.0], [171.0, 1092.0]], [[162.0, 1214.0], [189.0, 1214.0], [189.0, 1346.0], [162.0, 1346.0]], [[125.0, 1212.0], [151.0, 1212.0], [151.0, 1346.0], [125.0, 1346.0]], [[90.0, 1212.0], [117.0, 1212.0], [117.0, 1346.0], [90.0, 1346.0]]], "lines": ["アー", "何言おうと", "したか忘れ", "ちゃった！！"]}], "img_path": "157.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [631, 83, 658, 219], "vertical": true, "font_size": 20, "lines_coords": [[[634.0, 84.0], [654.0, 84.0], [654.0, 214.0], [634.0, 214.0]]], "lines": ["お父さんは"]}, {"box": [431, 82, 570, 290], "vertical": true, "font_size": 26, "lines_coords": [[[537.0, 82.0], [570.0, 82.0], [570.0, 187.0], [537.0, 187.0]], [[504.0, 84.0], [531.0, 84.0], [531.0, 212.0], [504.0, 212.0]], [[470.0, 85.0], [492.0, 85.0], [492.0, 287.0], [470.0, 287.0]], [[434.0, 84.0], [454.0, 84.0], [454.0, 239.0], [434.0, 239.0]]], "lines": ["なんだか", "いつもより", "元気が無いように", "思えましたか"]}, {"box": [510, 467, 612, 611], "vertical": true, "font_size": 27, "lines_coords": [[[582.0, 467.0], [610.0, 467.0], [610.0, 600.0], [582.0, 600.0]], [[546.0, 468.0], [573.0, 468.0], [573.0, 600.0], [546.0, 600.0]], [[510.0, 467.0], [537.0, 467.0], [537.0, 610.0], [510.0, 610.0]]], "lines": ["プンプンは", "お父さんが", "好きでした。"]}, {"box": [873, 1079, 970, 1289], "vertical": true, "font_size": 26, "lines_coords": [[[943.0, 1082.0], [970.0, 1082.0], [970.0, 1279.0], [943.0, 1279.0]], [[906.0, 1079.0], [932.0, 1079.0], [932.0, 1289.0], [906.0, 1289.0]], [[873.0, 1082.0], [895.0, 1082.0], [895.0, 1248.0], [873.0, 1248.0]]], "lines": ["．．．お父さん、近頃", "宇宙のことばかり", "考えてるんだ。"]}, {"box": [757, 1276, 857, 1462], "vertical": true, "font_size": 26, "lines_coords": [[[831.0, 1276.0], [857.0, 1276.0], [857.0, 1390.0], [831.0, 1390.0]], [[795.0, 1279.0], [821.0, 1279.0], [821.0, 1462.0], [795.0, 1462.0]], [[757.0, 1279.0], [785.0, 1279.0], [785.0, 1364.0], [757.0, 1364.0]]], "lines": ["子供の頃、", "ＳＦ少年だった", "からね"]}, {"box": [201, 1125, 375, 1365], "vertical": true, "font_size": 28, "lines_coords": [[[348.0, 1129.0], [375.0, 1129.0], [375.0, 1287.0], [348.0, 1287.0]], [[310.0, 1125.0], [337.0, 1125.0], [337.0, 1312.0], [310.0, 1312.0]], [[273.0, 1128.0], [300.0, 1128.0], [300.0, 1365.0], [273.0, 1365.0]], [[237.0, 1126.0], [264.0, 1126.0], [265.0, 1339.0], [239.0, 1339.0]], [[201.0, 1129.0], [228.0, 1129.0], [228.0, 1267.0], [201.0, 1267.0]]], "lines": ["ホントは今頃", "どこか遠い星で", "豊かで幸せな人生を", "送ってるって想像", "してたけど、"]}, {"box": [98, 1343, 201, 1506], "vertical": true, "font_size": 28, "lines_coords": [[[170.0, 1343.0], [201.0, 1343.0], [201.0, 1506.0], [170.0, 1506.0]], [[134.0, 1343.0], [165.0, 1343.0], [165.0, 1506.0], [134.0, 1506.0]], [[101.0, 1346.0], [128.0, 1346.0], [125.0, 1489.0], [98.0, 1489.0]]], "lines": ["未来って案外", "地味なんだな", "って思うよ。"]}], "img_path": "158.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [898, 104, 1033, 282], "vertical": true, "font_size": 27, "lines_coords": [[[1010.0, 107.0], [1032.0, 107.0], [1032.0, 210.0], [1010.0, 210.0]], [[967.0, 104.0], [1000.0, 104.0], [1000.0, 215.0], [967.0, 215.0]], [[935.0, 107.0], [962.0, 107.0], [962.0, 267.0], [935.0, 267.0]], [[898.0, 106.0], [925.0, 106.0], [926.0, 282.0], [900.0, 282.0]]], "lines": ["．．．．．え？", "望遠鏡で", "プンプン星を", "見つけたって！？"]}, {"box": [412, 326, 479, 457], "vertical": true, "font_size": 30, "lines_coords": [[[451.0, 328.0], [478.0, 328.0], [478.0, 457.0], [451.0, 457.0]], [[412.0, 326.0], [445.0, 326.0], [445.0, 420.0], [412.0, 420.0]]], "lines": ["モチのロン", "でした。"]}, {"box": [677, 507, 800, 709], "vertical": true, "font_size": 26, "lines_coords": [[[767.0, 507.0], [800.0, 507.0], [800.0, 670.0], [767.0, 670.0]], [[740.0, 510.0], [762.0, 510.0], [762.0, 709.0], [740.0, 709.0]], [[706.0, 509.0], [734.0, 509.0], [734.0, 643.0], [706.0, 643.0]], [[678.0, 512.0], [700.0, 512.0], [700.0, 692.0], [678.0, 692.0]]], "lines": ["すげーな！！", "それはお父さんも", "連れてって", "くれるのかい？"]}, {"box": [178, 530, 205, 664], "vertical": true, "font_size": 26, "lines_coords": [[[178.0, 540.0], [204.0, 540.0], [204.0, 664.0], [178.0, 664.0]]], "lines": ["．．．うん．．．"]}, {"box": [882, 800, 910, 934], "vertical": true, "font_size": 30, "lines_coords": [[[882.0, 800.0], [910.0, 800.0], [910.0, 934.0], [882.0, 934.0]]], "lines": ["あ．．．．．あ．．．"]}, {"box": [782, 859, 818, 1045], "vertical": true, "font_size": 30, "lines_coords": [[[782.0, 859.0], [815.0, 859.0], [818.0, 1045.0], [785.0, 1045.0]]], "lines": ["あああっ！！"]}, {"box": [326, 835, 348, 1017], "vertical": true, "font_size": 26, "lines_coords": [[[326.0, 835.0], [348.0, 835.0], [348.0, 1017.0], [326.0, 1017.0]]], "lines": ["．．．ありがとう．．．"]}, {"box": [171, 1004, 275, 1162], "vertical": true, "font_size": 26, "lines_coords": [[[248.0, 1006.0], [275.0, 1006.0], [275.0, 1162.0], [248.0, 1162.0]], [[210.0, 1004.0], [239.0, 1004.0], [239.0, 1145.0], [210.0, 1145.0]], [[175.0, 1004.0], [203.0, 1004.0], [200.0, 1162.0], [171.0, 1162.0]]], "lines": ["お父さん．．．．．", "なんだか今、", "一番幸せだよ"]}, {"box": [140, 1043, 164, 1107], "vertical": true, "font_size": 26, "lines_coords": [[[140.0, 1043.0], [164.0, 1043.0], [164.0, 1107.0], [140.0, 1107.0]]], "lines": ["．．．！！"]}, {"box": [803, 1282, 945, 1495], "vertical": true, "font_size": 28, "lines_coords": [[[920.0, 1284.0], [942.0, 1284.0], [942.0, 1440.0], [920.0, 1440.0]], [[878.0, 1282.0], [909.0, 1282.0], [909.0, 1495.0], [878.0, 1495.0]], [[842.0, 1282.0], [870.0, 1282.0], [871.0, 1492.0], [843.0, 1492.0]], [[803.0, 1282.0], [834.0, 1282.0], [837.0, 1450.0], [806.0, 1450.0]]], "lines": ["こんなところ", "友達に見られたら", "恥ずかしいぞ、と", "思いましたが、"]}], "img_path": "159.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [782, 95, 883, 278], "vertical": true, "font_size": 27, "lines_coords": [[[854.0, 96.0], [881.0, 96.0], [881.0, 276.0], [854.0, 276.0]], [[818.0, 96.0], [845.0, 96.0], [845.0, 259.0], [818.0, 259.0]], [[782.0, 96.0], [809.0, 96.0], [809.0, 259.0], [782.0, 259.0]]], "lines": ["お父さんの体は", "あったかくて、", "気持ちよくて、"]}, {"box": [618, 95, 720, 277], "vertical": true, "font_size": 29, "lines_coords": [[[693.0, 95.0], [720.0, 95.0], [717.0, 251.0], [690.0, 251.0]], [[657.0, 96.0], [684.0, 96.0], [684.0, 276.0], [657.0, 276.0]], [[618.0, 95.0], [651.0, 95.0], [651.0, 209.0], [618.0, 209.0]]], "lines": ["いつの間にか", "秋になってたん", "だな、と、"]}, {"box": [497, 95, 561, 288], "vertical": true, "font_size": 24, "lines_coords": [[[529.0, 95.0], [556.0, 95.0], [559.0, 225.0], [532.0, 225.0]], [[500.0, 98.0], [520.0, 98.0], [520.0, 281.0], [500.0, 281.0]]], "lines": ["フンフンは", "気が付きました"]}, {"box": [304, 110, 368, 220], "vertical": true, "font_size": 27, "lines_coords": [[[332.0, 112.0], [365.0, 110.0], [368.0, 200.0], [335.0, 201.0]], [[304.0, 115.0], [332.0, 115.0], [332.0, 220.0], [304.0, 220.0]]], "lines": ["．．．じゃ、", "プンプン。"]}, {"box": [164, 175, 285, 320], "vertical": true, "font_size": 27, "lines_coords": [[[259.0, 175.0], [285.0, 175.0], [285.0, 320.0], [259.0, 320.0]], [[226.0, 175.0], [253.0, 175.0], [253.0, 275.0], [226.0, 275.0]], [[193.0, 175.0], [220.0, 175.0], [217.0, 320.0], [190.0, 320.0]], [[164.0, 178.0], [185.0, 178.0], [185.0, 284.0], [164.0, 284.0]]], "lines": ["涼しくなって", "きたから", "風邪ひかない", "ようにね。"]}, {"box": [948, 485, 970, 643], "vertical": true, "font_size": 25, "lines_coords": [[[948.0, 485.0], [970.0, 485.0], [970.0, 643.0], [948.0, 643.0]]], "lines": ["：お父さんね"]}, {"box": [796, 535, 896, 745], "vertical": true, "font_size": 25, "lines_coords": [[[868.0, 535.0], [896.0, 535.0], [896.0, 643.0], [868.0, 643.0]], [[829.0, 537.0], [856.0, 537.0], [859.0, 745.0], [832.0, 745.0]], [[796.0, 539.0], [818.0, 539.0], [818.0, 715.0], [796.0, 715.0]]], "lines": ["これ以上", "お家に近づいちゃ", "いけないんだ．．"]}, {"box": [873, 1009, 973, 1168], "vertical": true, "font_size": 27, "lines_coords": [[[945.0, 1009.0], [971.0, 1009.0], [971.0, 1168.0], [945.0, 1168.0]], [[907.0, 1009.0], [935.0, 1009.0], [935.0, 1142.0], [907.0, 1142.0]], [[873.0, 1010.0], [900.0, 1010.0], [900.0, 1151.0], [873.0, 1151.0]]], "lines": ["「．．．どこに？」", "プンプンは", "聞きました。"]}, {"box": [146, 721, 301, 917], "vertical": true, "font_size": 28, "lines_coords": [[[267.0, 721.0], [301.0, 721.0], [301.0, 815.0], [267.0, 815.0]], [[240.0, 723.0], [267.0, 723.0], [267.0, 903.0], [240.0, 903.0]], [[209.0, 723.0], [235.0, 723.0], [235.0, 856.0], [209.0, 856.0]], [[176.0, 725.0], [203.0, 725.0], [204.0, 917.0], [178.0, 917.0]], [[146.0, 723.0], [175.0, 723.0], [175.0, 817.0], [146.0, 817.0]]], "lines": ["だから、", "ここでプンプン", "見送ったら", "お父さんももう", "帰るよ。"]}, {"box": [948, 1261, 975, 1445], "vertical": true, "font_size": 27, "lines_coords": [[[948.0, 1262.0], [975.0, 1262.0], [975.0, 1443.0], [948.0, 1443.0]]], "lines": ["アメリカに．．．"]}, {"box": [450, 1306, 587, 1518], "vertical": true, "font_size": 25, "lines_coords": [[[560.0, 1307.0], [582.0, 1307.0], [582.0, 1467.0], [560.0, 1467.0]], [[521.0, 1307.0], [548.0, 1307.0], [548.0, 1515.0], [521.0, 1515.0]], [[482.0, 1306.0], [510.0, 1306.0], [512.0, 1518.0], [484.0, 1518.0]], [[451.0, 1307.0], [473.0, 1307.0], [473.0, 1473.0], [451.0, 1473.0]]], "lines": ["実はお父さん、", "ＮＡＳＡのテスト", "パイロットに選ばれ", "ちゃったんだ。"]}], "img_path": "160.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [909, 112, 1010, 248], "vertical": true, "font_size": 27, "lines_coords": [[[984.0, 114.0], [1010.0, 114.0], [1010.0, 245.0], [984.0, 245.0]], [[948.0, 114.0], [975.0, 114.0], [975.0, 248.0], [948.0, 248.0]], [[909.0, 112.0], [942.0, 112.0], [942.0, 196.0], [909.0, 196.0]]], "lines": ["．．．ホラッ！！", "早く行きな", "さい！！"]}, {"box": [812, 201, 912, 335], "vertical": true, "font_size": 27, "lines_coords": [[[885.0, 201.0], [912.0, 201.0], [912.0, 335.0], [885.0, 335.0]], [[850.0, 204.0], [876.0, 204.0], [876.0, 334.0], [850.0, 334.0]], [[815.0, 204.0], [839.0, 204.0], [835.0, 332.0], [812.0, 332.0]]], "lines": ["お母さんも", "心配してる", "だろうし！！"]}, {"box": [123, 260, 296, 470], "vertical": true, "font_size": 26, "lines_coords": [[[267.0, 260.0], [293.0, 260.0], [293.0, 443.0], [267.0, 443.0]], [[229.0, 260.0], [256.0, 260.0], [256.0, 417.0], [229.0, 417.0]], [[192.0, 260.0], [220.0, 260.0], [221.0, 470.0], [193.0, 470.0]], [[159.0, 264.0], [185.0, 264.0], [185.0, 470.0], [159.0, 470.0]], [[125.0, 264.0], [146.0, 264.0], [146.0, 390.0], [125.0, 390.0]]], "lines": ["下校を待ちぶせ", "してたなんて", "知られたら、また", "モメちゃうしね！！", "あははは！！"]}, {"box": [853, 706, 956, 862], "vertical": true, "font_size": 28, "lines_coords": [[[923.0, 706.0], [956.0, 706.0], [956.0, 803.0], [923.0, 803.0]], [[889.0, 709.0], [915.0, 709.0], [915.0, 862.0], [889.0, 862.0]], [[853.0, 707.0], [879.0, 707.0], [879.0, 850.0], [853.0, 850.0]]], "lines": ["「今度は", "いつ会えるの", "だろうか？」"]}, {"box": [894, 1048, 953, 1209], "vertical": true, "font_size": 22, "lines_coords": [[[928.0, 1050.0], [950.0, 1050.0], [950.0, 1167.0], [928.0, 1167.0]]], "lines": ["そりゃあ"]}, {"box": [140, 787, 244, 955], "vertical": true, "font_size": 27, "lines_coords": [[[214.0, 787.0], [242.0, 787.0], [242.0, 920.0], [214.0, 920.0]], [[178.0, 789.0], [204.0, 789.0], [204.0, 920.0], [178.0, 920.0]], [[143.0, 787.0], [171.0, 787.0], [168.0, 954.0], [140.0, 954.0]]], "lines": ["プンプンは", "お父さんに", "たずねました。"]}, {"box": [618, 1353, 719, 1534], "vertical": true, "font_size": 27, "lines_coords": [[[690.0, 1354.0], [717.0, 1354.0], [717.0, 1534.0], [690.0, 1534.0]], [[654.0, 1356.0], [682.0, 1356.0], [682.0, 1484.0], [654.0, 1484.0]], [[618.0, 1353.0], [645.0, 1353.0], [645.0, 1482.0], [618.0, 1482.0]]], "lines": ["会おうと思えば", "いつだって", "会えるさ！！"]}, {"box": [140, 1170, 205, 1313], "vertical": true, "font_size": 27, "lines_coords": [[[176.0, 1171.0], [203.0, 1171.0], [203.0, 1303.0], [176.0, 1303.0]], [[140.0, 1170.0], [167.0, 1170.0], [167.0, 1312.0], [140.0, 1312.0]]], "lines": ["プンプンは", "思いました。"]}, {"box": [322, 1372, 348, 1542], "vertical": true, "font_size": 20, "lines_coords": [[[325.0, 1375.0], [345.0, 1375.0], [345.0, 1535.0], [325.0, 1535.0]]], "lines": ["「．．．うそつき。"]}], "img_path": "161.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [864, 703, 906, 823], "vertical": true, "font_size": 42, "lines_coords": [[[864.0, 706.0], [906.0, 706.0], [906.0, 823.0], [864.0, 823.0]]], "lines": ["プッ．．．"]}, {"box": [214, 801, 256, 1026], "vertical": true, "font_size": 42, "lines_coords": [[[214.0, 801.0], [256.0, 801.0], [256.0, 1026.0], [214.0, 1026.0]]], "lines": ["プンプンっ！！"]}, {"box": [212, 1087, 367, 1296], "vertical": true, "font_size": 42, "lines_coords": [[[325.0, 1087.0], [367.0, 1087.0], [367.0, 1296.0], [325.0, 1296.0]], [[265.0, 1087.0], [309.0, 1087.0], [309.0, 1256.