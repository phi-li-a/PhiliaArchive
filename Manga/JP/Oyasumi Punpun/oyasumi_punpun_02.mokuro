 "lines": ["「神様なんて", "いないんだぁ！！」"]}, {"box": [557, 504, 627, 700], "vertical": true, "font_size": 46, "lines_coords": [[[568.0, 537.0], [614.0, 537.0], [614.0, 690.0], [568.0, 690.0]]], "lines": ["じゃあ、」"]}, {"box": [114, 515, 262, 715], "vertical": true, "font_size": 46, "lines_coords": [[[210.0, 526.0], [259.0, 526.0], [259.0, 696.0], [210.0, 696.0]], [[160.0, 517.0], [210.0, 517.0], [210.0, 662.0], [160.0, 662.0]], [[114.0, 521.0], [153.0, 521.0], [153.0, 651.0], [114.0, 651.0]]], "lines": ["「あたしも", "プンプッ", "好き！！"]}, {"box": [901, 814, 1001, 1095], "vertical": true, "font_size": 47, "lines_coords": [[[951.0, 823.0], [1001.0, 823.0], [1001.0, 990.0], [951.0, 990.0]], [[906.0, 814.0], [950.0, 814.0], [945.0, 1095.0], [901.0, 1095.0]]], "lines": ["「じゃあ、", "信じてあげる！！"]}, {"box": [453, 828, 548, 1017], "vertical": true, "font_size": 47.5, "lines_coords": [[[509.0, 831.0], [548.0, 831.0], [545.0, 1017.0], [506.0, 1017.0]], [[453.0, 828.0], [509.0, 828.0], [509.0, 1001.0], [453.0, 1001.0]]], "lines": ["嘘つかない", "もんね！？」"]}, {"box": [323, 828, 404, 1068], "vertical": true, "font_size": 32, "lines_coords": [[[367.0, 828.0], [400.0, 828.0], [400.0, 1068.0], [367.0, 1068.0]], [[325.0, 828.0], [357.0, 828.0], [357.0, 1057.0], [325.0, 1057.0]]], "lines": ["「渋谷で見つけた", "おしゃブリッ娘"]}, {"box": [119, 829, 159, 1018], "vertical": true, "font_size": 37, "lines_coords": [[[120.0, 829.0], [157.0, 829.0], [157.0, 1012.0], [120.0, 1012.0]]], "lines": ["「１０連発川！！」"]}, {"box": [924, 1169, 999, 1490], "vertical": true, "font_size": 31, "lines_coords": [[[964.0, 1190.0], [995.0, 1190.0], [995.0, 1420.0], [964.0, 1420.0]], [[925.0, 1176.0], [956.0, 1176.0], [956.0, 1387.0], [925.0, 1387.0]]], "lines": ["へわっからっないー", "わっからっないー"]}, {"box": [739, 1164, 825, 1515], "vertical": true, "font_size": 33, "lines_coords": [[[782.0, 1173.0], [815.0, 1173.0], [820.0, 1501.0], [787.0, 1501.0]], [[750.0, 1170.0], [782.0, 1170.0], [779.0, 1382.0], [746.0, 1382.0]]], "lines": ["ぐわっからないったーらっ", "わっからっない、"]}, {"box": [100, 1365, 165, 1509], "vertical": true, "font_size": 27, "lines_coords": [[[134.0, 1365.0], [162.0, 1365.0], [164.0, 1509.0], [135.0, 1509.0]], [[100.0, 1368.0], [126.0, 1368.0], [126.0, 1496.0], [100.0, 1496.0]]], "lines": ["．．．プンプン、", "大変だ．．．"]}], "img_path": "062.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [885, 26, 915, 197], "vertical": true, "font_size": 27, "lines_coords": [[[885.0, 26.0], [912.0, 26.0], [914.0, 196.0], [887.0, 196.0]]], "lines": ["強盗が入った。"]}, {"box": [237, 109, 265, 242], "vertical": true, "font_size": 27, "lines_coords": [[[237.0, 109.0], [265.0, 109.0], [265.0, 242.0], [237.0, 242.0]]], "lines": ["プンプン．．．"]}, {"box": [139, 212, 165, 348], "vertical": true, "font_size": 27, "lines_coords": [[[139.0, 212.0], [165.0, 212.0], [165.0, 348.0], [139.0, 348.0]]], "lines": ["本当だよ？"]}, {"box": [160, 468, 227, 654], "vertical": true, "font_size": 29, "lines_coords": [[[195.0, 468.0], [226.0, 468.0], [226.0, 628.0], [195.0, 628.0]], [[160.0, 470.0], [187.0, 470.0], [187.0, 654.0], [160.0, 654.0]]], "lines": ["本当に強盗が", "入ったんだよ？"]}, {"box": [809, 1182, 910, 1328], "vertical": true, "font_size": 28, "lines_coords": [[[878.0, 1182.0], [910.0, 1182.0], [910.0, 1268.0], [878.0, 1268.0]], [[843.0, 1184.0], [870.0, 1184.0], [870.0, 1323.0], [843.0, 1323.0]], [[809.0, 1185.0], [835.0, 1185.0], [835.0, 1318.0], [809.0, 1318.0]]], "lines": ["信じて", "くれるよね、", "プンプン！！"]}], "img_path": "063.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [943, 48, 974, 323], "vertical": true, "font_size": 22, "lines_coords": [[[946.0, 53.0], [968.0, 53.0], [968.0, 314.0], [946.0, 314.0]]], "lines": ["ねぇ、知ってる？"]}, {"box": [379, 45, 555, 281], "vertical": true, "font_size": 27, "lines_coords": [[[529.0, 50.0], [551.0, 50.0], [551.0, 187.0], [529.0, 187.0]], [[489.0, 46.0], [515.0, 46.0], [515.0, 254.0], [489.0, 254.0]], [[454.0, 46.0], [481.0, 46.0], [481.0, 256.0], [454.0, 256.0]], [[415.0, 46.0], [446.0, 46.0], [446.0, 279.0], [415.0, 279.0]], [[379.0, 45.0], [406.0, 45.0], [409.0, 276.0], [382.0, 276.0]]], "lines": ["「あと数年で", "石油が無くなって", "環境も破壊されて", "地球は人の住めない", "星になるんだって。"]}, {"box": [164, 309, 220, 332], "vertical": false, "font_size": 23, "lines_coords": [[[164.0, 309.0], [220.0, 309.0], [220.0, 332.0], [164.0, 332.0]]], "lines": ["．．．"]}, {"box": [137, 568, 300, 837], "vertical": true, "font_size": 30, "lines_coords": [[[270.0, 571.0], [296.0, 571.0], [296.0, 831.0], [270.0, 831.0]], [[220.0, 568.0], [257.0, 568.0], [257.0, 760.0], [220.0, 760.0]], [[178.0, 571.0], [210.0, 571.0], [210.0, 790.0], [178.0, 790.0]], [[139.0, 571.0], [165.0, 571.0], [165.0, 810.0], [139.0, 810.0]]], "lines": ["一別の星にインュー", "でもしないと", "人類はメツボー", "しちゃうんだよ。"]}, {"box": [64, 865, 412, 1210], "vertical": false, "font_size": 262.5, "lines_coords": [[[196.0, 865.0], [412.0, 937.0], [337.0, 1160.0], [121.0, 1089.0]], [[64.0, 921.0], [231.0, 915.0], [242.0, 1204.0], [75.0, 1210.0]]], "lines": ["ＪＲ", "あっ"]}, {"box": [78, 1332, 179, 1531], "vertical": true, "font_size": 29, "lines_coords": [[[148.0, 1334.0], [176.0, 1334.0], [176.0, 1450.0], [148.0, 1450.0]], [[110.0, 1332.0], [142.0, 1332.0], [142.0, 1531.0], [110.0, 1531.0]], [[78.0, 1334.0], [104.0, 1334.0], [104.0, 1439.0], [78.0, 1439.0]]], "lines": ["．．．何それ、", "あなた、もう一回", "言って？"]}], "img_path": "064.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [950, 40, 1048, 223], "vertical": true, "font_size": 27, "lines_coords": [[[1021.0, 40.0], [1048.0, 40.0], [1048.0, 223.0], [1021.0, 223.0]], [[982.0, 40.0], [1009.0, 40.0], [1012.0, 200.0], [985.0, 200.0]], [[950.0, 40.0], [976.0, 40.0], [976.0, 200.0], [950.0, 200.0]]], "lines": ["今月いっぱいで", "会社から解雇", "されるって：・"]}, {"box": [810, 154, 946, 395], "vertical": true, "font_size": 27, "lines_coords": [[[920.0, 154.0], [946.0, 154.0], [946.0, 365.0], [920.0, 365.0]], [[889.0, 154.0], [921.0, 154.0], [921.0, 395.0], [889.0, 395.0]], [[862.0, 157.0], [889.0, 157.0], [889.0, 379.0], [862.0, 379.0]], [[835.0, 157.0], [862.0, 157.0], [862.0, 365.0], [835.0, 365.0]], [[810.0, 157.0], [832.0, 157.0], [832.0, 296.0], [810.0, 296.0]]], "lines": ["．．．まぁ、今までが", "オーバーワーク気味", "だったから、これは", "これでいいと俺は", "思ってるよ。"]}, {"box": [265, 96, 329, 229], "vertical": true, "font_size": 28, "lines_coords": [[[301.0, 100.0], [329.0, 100.0], [329.0, 229.0], [301.0, 229.0]], [[265.0, 96.0], [298.0, 96.0], [298.0, 204.0], [265.0, 204.0]]], "lines": ["いいと思う", "って．．．"]}, {"box": [134, 215, 259, 426], "vertical": true, "font_size": 28, "lines_coords": [[[232.0, 215.0], [259.0, 215.0], [259.0, 400.0], [232.0, 400.0]], [[198.0, 215.0], [225.0, 215.0], [225.0, 423.0], [198.0, 423.0]], [[167.0, 217.0], [193.0, 217.0], [193.0, 426.0], [167.0, 426.0]], [[134.0, 217.0], [160.0, 217.0], [160.0, 350.0], [134.0, 350.0]]], "lines": ["だって収入は！？", "家のローンだって", "まだ全然残ってる", "じゃない！？"]}, {"box": [921, 496, 1009, 653], "vertical": true, "font_size": 25, "lines_coords": [[[982.0, 496.0], [1009.0, 496.0], [1009.0, 610.0], [982.0, 610.0]], [[954.0, 498.0], [976.0, 498.0], [976.0, 653.0], [954.0, 653.0]], [[921.0, 496.0], [943.0, 496.0], [943.0, 639.0], [921.0, 639.0]]], "lines": ["いやなに", "仕事はすぐに", "見つかるさ。"]}, {"box": [800, 592, 909, 842], "vertical": true, "font_size": 25, "lines_coords": [[[881.0, 592.0], [907.0, 592.0], [909.0, 842.0], [882.0, 842.0]], [[857.0, 593.0], [879.0, 593.0], [879.0, 776.0], [857.0, 776.0]], [[829.0, 593.0], [856.0, 593.0], [854.0, 804.0], [828.0, 804.0]], [[803.0, 592.0], [831.0, 592.0], [828.0, 751.0], [800.0, 751.0]]], "lines": ["それより、これからは", "家族三人の絆を", "深め合っていこう", "じゃないか！！"]}, {"box": [140, 693, 305, 884], "vertical": true, "font_size": 32, "lines_coords": [[[270.0, 695.0], [303.0, 695.0], [303.0, 851.0], [270.0, 851.0]], [[223.0, 693.0], [256.0, 693.0], [259.0, 854.0], [226.0, 854.0]], [[181.0, 695.0], [214.0, 695.0], [214.0, 854.0], [181.0, 854.0]], [[140.0, 693.0], [171.0, 693.0], [171.0, 884.0], [140.0, 884.0]]], "lines": ["酒臭い息で", "そんな言葉", "吐かないで", "ちょうだい！！"]}, {"box": [913, 960, 1032, 1151], "vertical": true, "font_size": 31, "lines_coords": [[[1000.0, 960.0], [1032.0, 960.0], [1032.0, 1120.0], [1000.0, 1120.0]], [[956.0, 962.0], [989.0, 962.0], [989.0, 1151.0], [956.0, 1151.0]], [[914.0, 962.0], [942.0, 962.0], [942.0, 1087.0], [914.0, 1087.0]]], "lines": ["ああァァ！！", "やっぱり失敗", "だった！！"]}, {"box": [753, 1015, 848, 1232], "vertical": true, "font_size": 84, "lines_coords": [[[764.0, 1015.0], [848.0, 1020.0], [837.0, 1232.0], [753.0, 1228.0]]], "lines": ["ああっ"]}, {"box": [513, 995, 637, 1182], "vertical": true, "font_size": 27, "lines_coords": [[[606.0, 995.0], [637.0, 995.0], [637.0, 1182.0], [606.0, 1182.0]], [[573.0, 996.0], [601.0, 996.0], [603.0, 1168.0], [575.0, 1168.0]], [[543.0, 998.0], [570.0, 998.0], [570.0, 1181.0], [543.0, 1181.0]], [[514.0, 998.0], [535.0, 998.0], [535.0, 1154.0], [514.0, 1154.0]]], "lines": ["子供なんか作ら", "ないで、もっと", "自由に生きれば", "良かったァ！！"]}, {"box": [157, 1126, 240, 1257], "vertical": true, "font_size": 34, "lines_coords": [[[195.0, 1126.0], [240.0, 1126.0], [240.0, 1240.0], [195.0, 1240.0]], [[157.0, 1129.0], [190.0, 1129.0], [190.0, 1257.0], [157.0, 1257.0]]], "lines": ["．．．てっ、", "てめぇ！！"]}, {"box": [684, 1328, 809, 1521], "vertical": true, "font_size": 33, "lines_coords": [[[776.0, 1332.0], [809.0, 1332.0], [809.0, 1457.0], [776.0, 1457.0]], [[728.0, 1331.0], [760.0, 1331.0], [764.0, 1489.0], [731.0, 1489.0]], [[684.0, 1328.0], [717.0, 1328.0], [720.0, 1521.0], [687.0, 1521.0]]], "lines": ["やっぱり", "この結婚は", "失敗だった！！"]}, {"box": [95, 1343, 257, 1534], "vertical": true, "font_size": 34, "lines_coords": [[[226.0, 1345.0], [257.0, 1345.0], [257.0, 1503.0], [226.0, 1503.0]], [[182.0, 1346.0], [214.0, 1346.0], [214.0, 1534.0], [182.0, 1534.0]], [[135.0, 1343.0], [168.0, 1343.0], [171.0, 1501.0], [139.0, 1501.0]], [[95.0, 1346.0], [128.0, 1346.0], [128.0, 1534.0], [95.0, 1534.0]]], "lines": ["そんなこと", "口が裂けても", "言うんじゃ", "ねーどっ！！"]}], "img_path": "065.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [153, 210, 179, 345], "vertical": true, "font_size": 28, "lines_coords": [[[153.0, 210.0], [179.0, 210.0], [179.0, 345.0], [153.0, 345.0]]], "lines": ["運転手さん"]}, {"box": [95, 414, 198, 571], "vertical": true, "font_size": 28, "lines_coords": [[[164.0, 414.0], [198.0, 414.0], [198.0, 500.0], [164.0, 500.0]], [[131.0, 417.0], [157.0, 417.0], [157.0, 571.0], [131.0, 571.0]], [[95.0, 415.0], [121.0, 415.0], [121.0, 557.0], [95.0, 557.0]]], "lines": ["適当に", "海までやって", "ちょうだい。"]}, {"box": [935, 820, 967, 984], "vertical": true, "font_size": 31, "lines_coords": [[[935.0, 820.0], [967.0, 820.0], [967.0, 984.0], [935.0, 984.0]]], "lines": ["奥さーーん．．．"]}, {"box": [793, 909, 895, 1106], "vertical": true, "font_size": 31, "lines_coords": [[[868.0, 909.0], [895.0, 909.0], [895.0, 1106.0], [868.0, 1106.0]], [[831.0, 921.0], [862.0, 921.0], [862.0, 1095.0], [831.0, 1095.0]], [[793.0, 920.0], [828.0, 920.0], [828.0, 1004.0], [793.0, 1004.0]]], "lines": ["こんな明け方に", "一体なんの用", "です？"]}, {"box": [132, 937, 237, 1085], "vertical": true, "font_size": 31, "lines_coords": [[[195.0, 937.0], [237.0, 937.0], [237.0, 1010.0], [195.0, 1010.0]], [[165.0, 942.0], [193.0, 942.0], [193.0, 1050.0], [165.0, 1050.0]], [[132.0, 943.0], [154.0, 943.0], [154.0, 1082.0], [132.0, 1082.0]]], "lines": ["今時、", "心中でも", "あるまいし。"]}, {"box": [154, 1315, 223, 1407], "vertical": true, "font_size": 30, "lines_coords": [[[189.0, 1315.0], [223.0, 1315.0], [223.0, 1404.0], [189.0, 1404.0]], [[154.0, 1315.0], [189.0, 1315.0], [189.0, 1407.0], [154.0, 1407.0]]], "lines": ["．．．いえ", "ははは。"]}, {"box": [78, 1410, 142, 1557], "vertical": true, "font_size": 30, "lines_coords": [[[115.0, 1412.0], [142.0, 1412.0], [142.0, 1550.0], [115.0, 1550.0]], [[81.0, 1410.0], [107.0, 1410.0], [104.0, 1557.0], [78.0, 1557.0]]], "lines": ["冗談ですよ、", "ジョーダン。"]}], "img_path": "066.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [840, 130, 940, 365], "vertical": true, "font_size": 26, "lines_coords": [[[915.0, 131.0], [937.0, 131.0], [937.0, 293.0], [915.0, 293.0]], [[873.0, 131.0], [903.0, 131.0], [904.0, 365.0], [875.0, 365.0]], [[840.0, 131.0], [867.0, 131.0], [867.0, 275.0], [840.0, 275.0]]], "lines": ["．．．運転手さん、", "やっぱり引き返して", "ちょうだい。"]}, {"box": [917, 957, 985, 1079], "vertical": true, "font_size": 30, "lines_coords": [[[948.0, 959.0], [982.0, 957.0], [985.0, 1029.0], [951.0, 1031.0]], [[917.0, 960.0], [943.0, 960.0], [943.0, 1075.0], [917.0, 1075.0]]], "lines": ["なあ、", "ブンフン"]}, {"box": [615, 962, 721, 1175], "vertical": true, "font_size": 32, "lines_coords": [[[679.0, 962.0], [721.0, 962.0], [721.0, 1035.0], [679.0, 1035.0]], [[651.0, 967.0], [678.0, 967.0], [678.0, 1175.0], [651.0, 1175.0]], [[615.0, 971.0], [642.0, 971.0], [642.0, 1162.0], [615.0, 1162.0]]], "lines": ["俺ら、", "そーゆー意味では", "一心同体だから。"]}, {"box": [106, 1096, 245, 1284], "vertical": true, "font_size": 28, "lines_coords": [[[215.0, 1100.0], [242.0, 1100.0], [242.0, 1257.0], [215.0, 1257.0]], [[173.0, 1096.0], [206.0, 1096.0], [210.0, 1284.0], [178.0, 1284.0]], [[140.0, 1098.0], [167.0, 1098.0], [170.0, 1271.0], [143.0, 1271.0]], [[106.0, 1100.0], [132.0, 1100.0], [132.0, 1215.0], [106.0, 1215.0]]], "lines": ["プンプンには", "わりーんだけど", "俺ら、超仲良し", "だからさ。"]}, {"box": [568, 1329, 704, 1562], "vertical": true, "font_size": 26, "lines_coords": [[[676.0, 1329.0], [703.0, 1329.0], [703.0, 1471.0], [676.0, 1471.0]], [[640.0, 1329.0], [667.0, 1329.0], [667.0, 1537.0], [640.0, 1537.0]], [[603.0, 1329.0], [629.0, 1329.0], [629.0, 1562.0], [603.0, 1562.0]], [[568.0, 1332.0], [590.0, 1332.0], [590.0, 1518.0], [568.0, 1518.0]]], "lines": ["でも、俺らの", "ゆーこと聞いたら", "２番目に仲良くして", "やってもいいよ。"]}], "img_path": "067.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [465, 3, 487, 104], "vertical": true, "font_size": 22, "lines_coords": [[[465.0, 3.0], [487.0, 3.0], [487.0, 104.0], [465.0, 104.0]]], "lines": ["２０１８年度はここです．．．"]}, {"box": [423, 670, 451, 740], "vertical": true, "font_size": 30, "lines_coords": [[[423.0, 670.0], [451.0, 670.0], [451.0, 740.0], [423.0, 740.0]]], "lines": ["あのー"]}, {"box": [678, 1100, 744, 1243], "vertical": true, "font_size": 26, "lines_coords": [[[717.0, 1101.0], [743.0, 1101.0], [743.0, 1232.0], [717.0, 1232.0]], [[678.0, 1100.0], [704.0, 1100.0], [707.0, 1243.0], [681.0, 1243.0]]], "lines": ["人数、足り", "ないんだっ。"]}, {"box": [360, 770, 392, 929], "vertical": true, "font_size": 30, "lines_coords": [[[360.0, 770.0], [392.0, 770.0], [392.0, 929.0], [360.0, 929.0]]], "lines": ["プン山くん？"]}, {"box": [382, 1168, 444, 1296], "vertical": true, "font_size": 24, "lines_coords": [[[417.0, 1168.0], [443.0, 1168.0], [443.0, 1296.0], [417.0, 1296.0]], [[382.0, 1168.0], [404.0, 1168.0], [404.0, 1295.0], [382.0, 1295.0]]], "lines": ["いっしょに", "遊ばない！？"]}, {"box": [135, 1289, 185, 1425], "vertical": true, "font_size": 44, "lines_coords": [[[135.0, 1289.0], [185.0, 1289.0], [185.0, 1425.0], [135.0, 1425.0]]], "lines": ["プンプー"]}, {"box": [89, 1339, 126, 1476], "vertical": true, "font_size": 44, "lines_coords": [[[89.0, 1339.0], [126.0, 1339.0], [126.0, 1476.0], [89.0, 1476.0]]], "lines": ["ーンっ！！"]}], "img_path": "068.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [981, 73, 1009, 210], "vertical": true, "font_size": 30, "lines_coords": [[[981.0, 73.0], [1009.0, 73.0], [1009.0, 210.0], [981.0, 210.0]]], "lines": ["よかった！"]}, {"box": [932, 189, 970, 262], "vertical": true, "font_size": 30, "lines_coords": [[[932.0, 192.0], [964.0, 189.0], [970.0, 259.0], [940.0, 262.0]]], "lines": ["ッ！！"]}, {"box": [840, 257, 910, 393], "vertical": true, "font_size": 30, "lines_coords": [[[876.0, 257.0], [910.0, 257.0], [910.0, 343.0], [876.0, 343.0]], [[840.0, 259.0], [868.0, 259.0], [871.0, 393.0], [843.0, 393.0]]], "lines": ["すっげ", "捜したよ！！"]}, {"box": [148, 256, 282, 437], "vertical": true, "font_size": 26, "lines_coords": [[[256.0, 256.0], [282.0, 256.0], [282.0, 382.0], [256.0, 382.0]], [[220.0, 256.0], [246.0, 256.0], [246.0, 360.0], [220.0, 360.0]], [[184.0, 259.0], [210.0, 259.0], [210.0, 412.0], [184.0, 412.0]], [[148.0, 257.0], [175.0, 257.0], [175.0, 437.0], [148.0, 437.0]]], "lines": ["ダーメじゃ", "ないかー", "一人でこんな", "遠くに来ちゃ！！"]}, {"box": [153, 525, 250, 682], "vertical": true, "font_size": 26, "lines_coords": [[[223.0, 525.0], [250.0, 525.0], [250.0, 681.0], [223.0, 681.0]], [[189.0, 525.0], [215.0, 525.0], [215.0, 657.0], [189.0, 657.0]], [[153.0, 525.0], [179.0, 525.0], [179.0, 682.0], [153.0, 682.0]]], "lines": ["パパとママも", "今、必死に", "捜してるよ！？"]}, {"box": [912, 932, 1015, 1124], "vertical": true, "font_size": 27, "lines_coords": [[[979.0, 932.0], [1010.0, 932.0], [1015.0, 1123.0], [984.0, 1123.0]], [[948.0, 935.0], [975.0, 935.0], [975.0, 1093.0], [948.0, 1093.0]], [[912.0, 937.0], [935.0, 937.0], [937.0, 1081.0], [914.0, 1081.0]]], "lines": ["あーードモドモ、", "ご迷惑おかけ", "しちゃって。"]}, {"box": [534, 1006, 651, 1162], "vertical": true, "font_size": 25, "lines_coords": [[[629.0, 1096.0], [648.0, 1096.0], [648.0, 1135.0], [629.0, 1135.0]], [[623.0, 1006.0], [651.0, 1006.0], [651.0, 1073.0], [623.0, 1073.0]], [[595.0, 1006.0], [621.0, 1006.0], [621.0, 1112.0], [595.0, 1112.0]], [[564.0, 1006.0], [590.0, 1006.0], [590.0, 1137.0], [564.0, 1137.0]], [[537.0, 1007.0], [564.0, 1007.0], [560.0, 1162.0], [534.0, 1162.0]]], "lines": ["．．．", "．．．あ", "流れ星を", "追いかけて", "ここまで．．．"]}, {"box": [114, 1109, 240, 1265], "vertical": true, "font_size": 27, "lines_coords": [[[212.0, 1109.0], [239.0, 1109.0], [239.0, 1243.0], [212.0, 1243.0]], [[179.0, 1109.0], [206.0, 1109.0], [206.0, 1265.0], [179.0, 1265.0]], [[143.0, 1109.0], [170.0, 1109.0], [173.0, 1265.0], [146.0, 1265.0]], [[114.0, 1109.0], [140.0, 1109.0], [140.0, 1200.0], [114.0, 1200.0]]], "lines": ["すみません", "そーゆートコ", "あるみたいで", "この子。"]}, {"box": [920, 1332, 1026, 1492], "vertical": true, "font_size": 32, "lines_coords": [[[984.0, 1332.0], [1026.0, 1332.0], [1026.0, 1379.0], [984.0, 1379.0]], [[956.0, 1335.0], [982.0, 1335.0], [982.0, 1492.0], [956.0, 1492.0]], [[920.0, 1337.0], [948.0, 1337.0], [948.0, 1465.0], [920.0, 1465.0]]], "lines": ["私、", "この子の叔父", "でして．．．"]}, {"box": [271, 1309, 373, 1532], "vertical": true, "font_size": 28, "lines_coords": [[[342.0, 1310.0], [368.0, 1310.0], [373.0, 1448.0], [346.0, 1448.0]], [[306.0, 1309.0], [332.0, 1309.0], [335.0, 1506.0], [309.0, 1506.0]], [[271.0, 1309.0], [298.0, 1309.0], [300.0, 1532.0], [273.0, 1532.0]]], "lines": ["．．．むおおぉ", "泣きやまねーぜ。", "参ったな、こらぁ！！"]}, {"box": [82, 1357, 225, 1568], "vertical": true, "font_size": 28, "lines_coords": [[[198.0, 1359.0], [225.0, 1359.0], [225.0, 1550.0], [198.0, 1550.0]], [[162.0, 1359.0], [189.0, 1359.0], [189.0, 1554.0], [162.0, 1554.0]], [[126.0, 1360.0], [153.0, 1360.0], [153.0, 1568.0], [126.0, 1568.0]], [[82.0, 1359.0], [118.0, 1357.0], [121.0, 1432.0], [85.0, 1434.0]]], "lines": ["そうね、そうな、", "さびしかったね。", "一人で心細かった", "よね。"]}], "img_path": "069.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [931, 67, 959, 196], "vertical": true, "font_size": 27, "lines_coords": [[[931.0, 67.0], [959.0, 67.0], [959.0, 196.0], [931.0, 196.0]]], "lines": ["．．．そうだ！！"]}, {"box": [804, 167, 918, 376], "vertical": true, "font_size": 27, "lines_coords": [[[892.0, 167.0], [918.0, 167.0], [918.0, 278.0], [892.0, 278.0]], [[860.0, 167.0], [889.0, 167.0], [889.0, 300.0], [860.0, 300.0]], [[828.0, 168.0], [859.0, 168.0], [859.0, 376.0], [828.0, 376.0]], [[804.0, 170.0], [826.0, 170.0], [826.0, 298.0], [804.0, 298.0]]], "lines": ["オジさん、", "プンプンに", "いいこと教えちゃ", "おうかな！！"]}, {"box": [232, 300, 335, 440], "vertical": true, "font_size": 27, "lines_coords": [[[303.0, 300.0], [335.0, 300.0], [335.0, 407.0], [303.0, 407.0]], [[265.0, 301.0], [298.0, 301.0], [298.0, 410.0], [265.0, 410.0]], [[232.0, 304.0], [259.0, 304.0], [259.0, 440.0], [232.0, 440.0]]], "lines": ["プンプン", "みたいな", "いい子には、"]}, {"box": [170, 484, 301, 692], "vertical": true, "font_size": 27, "lines_coords": [[[279.0, 485.0], [301.0, 485.0], [301.0, 664.0], [279.0, 664.0]], [[239.0, 484.0], [267.0, 484.0], [264.0, 642.0], [235.0, 642.0]], [[203.0, 485.0], [229.0, 485.0], [229.0, 668.0], [203.0, 668.0]], [[170.0, 487.0], [192.0, 487.0], [192.0, 692.0], [170.0, 692.0]]], "lines": ["実はいつだって", "そばに神様が", "いてくれてるん", "だって知ってる？"]}, {"box": [832, 807, 931, 1018], "vertical": true, "font_size": 24, "lines_coords": [[[904.0, 807.0], [931.0, 807.0], [928.0, 1018.0], [901.0, 1018.0]], [[868.0, 809.0], [892.0, 809.0], [890.0, 1017.0], [867.0, 1017.0]], [[834.0, 810.0], [856.0, 810.0], [856.0, 948.0], [834.0, 948.0]]], "lines": ["さびしくなったら", "こんな風に呪文を", "唱えるんだ。"]}, {"box": [153, 1021, 243, 1117], "vertical": true, "font_size": 41, "lines_coords": [[[195.0, 1021.0], [243.0, 1021.0], [243.0, 1114.0], [195.0, 1114.0]], [[153.0, 1021.0], [198.0, 1021.0], [198.0, 1117.0], [153.0, 1117.0]]], "lines": ["「神様", "神様」"]}, {"box": [877, 1319, 966, 1593], "vertical": true, "font_size": 89, "lines_coords": [[[877.0, 1319.0], [966.0, 1319.0], [966.0, 1593.0], [877.0, 1593.0]]], "lines": ["な、見え"]}, {"box": [162, 1192, 240, 1357], "vertical": true, "font_size": 41, "lines_coords": [[[203.0, 1192.0], [240.0, 1192.0], [240.0, 1346.0], [203.0, 1346.0]], [[162.0, 1203.0], [195.0, 1203.0], [195.0, 1357.0], [162.0, 1357.0]]], "lines": ["「チンクル", "ホイ」って。"]}], "img_path": "070.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [659, 831, 807, 1081], "vertical": true, "font_size": 61, "lines_coords": [[[734.0, 835.0], [795.0, 831.0], [807.0, 1026.0], [746.0, 1031.0]]], "lines": ["ヨッす！！"]}, {"box": [523, 828, 558, 988], "vertical": true, "font_size": 33, "lines_coords": [[[523.0, 828.0], [556.0, 828.0], [556.0, 987.0], [523.0, 987.0]]], "lines": ["「ヨッす！！」"]}, {"box": [426, 1198, 567, 1450], "vertical": true, "font_size": 30, "lines_coords": [[[529.0, 1200.0], [564.0, 1198.0], [567.0, 1282.0], [532.0, 1284.0]], [[498.0, 1200.0], [529.0, 1200.0], [529.0, 1360.0], [498.0, 1360.0]], [[462.0, 1201.0], [489.0, 1201.0], [489.0, 1450.0], [462.0, 1450.0]], [[426.0, 1200.0], [453.0, 1200.0], [453.0, 1446.0], [426.0, 1446.0]]], "lines": ["神様が", "珍しく真剣な", "顔をして、ブンブンに", "話しかけてきました。"]}], "img_path": "071.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [920, 103, 985, 297], "vertical": true, "font_size": 24, "lines_coords": [[[957.0, 106.0], [984.0, 106.0], [984.0, 278.0], [957.0, 278.0]], [[923.0, 106.0], [945.0, 106.0], [945.0, 292.0], [923.0, 292.0]]], "lines": ["「ねぇブンブン、", "神様は思うんだ。"]}, {"box": [715, 101, 852, 417], "vertical": true, "font_size": 29, "lines_coords": [[[825.0, 104.0], [851.0, 104.0], [851.0, 259.0], [825.0, 259.0]], [[785.0, 103.0], [817.0, 103.0], [817.0, 295.0], [785.0, 295.0]], [[748.0, 103.0], [779.0, 103.0], [779.0, 340.0], [748.0, 340.0]], [[715.0, 104.0], [742.0, 104.0], [742.0, 415.0], [715.0, 415.0]]], "lines": ["人が人として", "生きている以上、", "絶対に埋められない", "寂しさがあるよね、って。」"]}, {"box": [314, 103, 417, 293], "vertical": true, "font_size": 27, "lines_coords": [[[389.0, 103.0], [417.0, 103.0], [414.0, 273.0], [385.0, 273.0]], [[350.0, 103.0], [378.0, 103.0], [379.0, 260.0], [351.0, 260.0]], [[314.0, 103.0], [342.0, 103.0], [343.0, 293.0], [315.0, 293.0]]], "lines": ["「人がどれだけ", "求め合っても", "傷つけ合っても、"]}, {"box": [221, 104, 284, 364], "vertical": true, "font_size": 27, "lines_coords": [[[257.0, 104.0], [284.0, 104.0], [284.0, 364.0], [257.0, 364.0]], [[221.0, 104.0], [245.0, 104.0], [246.0, 267.0], [223.0, 267.0]]], "lines": ["完全にわかり合えない", "のだとしたら、"]}, {"box": [95, 103, 193, 364], "vertical": true, "font_size": 27, "lines_coords": [[[165.0, 103.0], [192.0, 103.0], [193.0, 364.0], [167.0, 364.0]], [[129.0, 104.0], [156.0, 104.0], [156.0, 287.0], [129.0, 287.0]], [[95.0, 104.0], [121.0, 104.0], [121.0, 235.0], [95.0, 235.0]]], "lines": ["一体何を信じてゆけば", "いいのだろう？", "なんてね。」"]}, {"box": [829, 1165, 999, 1492], "vertical": true, "font_size": 58, "lines_coords": [[[829.0, 1165.0], [887.0, 1165.0], [890.0, 1490.0], [832.0, 1490.0]]], "lines": ["ここはひとつ"]}, {"box": [92, 1167, 250, 1536], "vertical": true, "font_size": 40, "lines_coords": [[[203.0, 1173.0], [242.0, 1173.0], [245.0, 1445.0], [206.0, 1445.0]], [[146.0, 1173.0], [190.0, 1173.0], [193.0, 1323.0], [150.0, 1323.0]], [[95.0, 1175.0], [134.0, 1175.0], [131.0, 1384.0], [92.0, 1384.0]]], "lines": ["これからも", "仲良く", "しましょ"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [923, 123, 989, 309], "vertical": true, "font_size": 25, "lines_coords": [[[957.0, 123.0], [985.0, 123.0], [989.0, 268.0], [960.0, 268.0]], [[926.0, 128.0], [948.0, 128.0], [948.0, 307.0], [926.0, 307.0]]], "lines": ["．．．ねぇパパ、", "何か考えごと？"]}, {"box": [318, 87, 418, 323], "vertical": true, "font_size": 25, "lines_coords": [[[390.0, 129.0], [418.0, 129.0], [418.0, 254.0], [390.0, 254.0]], [[390.0, 90.0], [415.0, 90.0], [415.0, 135.0], [390.0, 135.0]], [[354.0, 87.0], [381.0, 87.0], [381.0, 323.0], [354.0, 323.0]], [[318.0, 87.0], [345.0, 87.0], [345.0, 256.0], [318.0, 256.0]]], "lines": ["ー．．．俺達、", "んー", "ここまで長い道のり", "だったなって。"]}, {"box": [120, 175, 296, 420], "vertical": true, "font_size": 25, "lines_coords": [[[270.0, 178.0], [296.0, 178.0], [296.0, 393.0], [270.0, 393.0]], [[245.0, 179.0], [267.0, 179.0], [267.0, 367.0], [245.0, 367.0]], [[210.0, 178.0], [237.0, 178.0], [237.0, 389.0], [210.0, 389.0]], [[181.0, 176.0], [207.0, 176.0], [207.0, 420.0], [181.0, 420.0]], [[154.0, 179.0], [176.0, 179.0], [176.0, 387.0], [154.0, 387.0]], [[120.0, 179.0], [143.0, 175.0], [151.0, 218.0], [128.0, 223.0]]], "lines": ["「いいこと悪い」と、", "くだらないこと、", "大切なはずなのに", "忘れてしまったこと、", "色々あったんだよ", "なー"]}, {"box": [128, 239, 145, 281], "vertical": true, "font_size": 25, "lines_coords": [[[128.0, 239.0], [145.0, 239.0], [145.0, 281.0], [128.0, 281.0]]], "lines": ["．．．"]}, {"box": [887, 503, 951, 692], "vertical": true, "font_size": 27, "lines_coords": [[[929.0, 620.0], [948.0, 620.0], [948.0, 659.0], [929.0, 659.0]], [[925.0, 504.0], [951.0, 504.0], [951.0, 603.0], [925.0, 603.0]], [[887.0, 503.0], [914.0, 503.0], [914.0, 692.0], [887.0, 692.0]]], "lines": ["．．．", "．．．いやー", "と言っても実際、"]}, {"box": [712, 556, 846, 750], "vertical": true, "font_size": 27, "lines_coords": [[[818.0, 560.0], [846.0, 560.0], [846.0, 667.0], [818.0, 667.0]], [[781.0, 559.0], [812.0, 559.0], [812.0, 720.0], [781.0, 720.0]], [[740.0, 556.0], [773.0, 556.0], [776.0, 693.0], [743.0, 693.0]], [[712.0, 559.0], [734.0, 559.0], [734.0, 750.0], [712.0, 750.0]]], "lines": ["この俺が", "マイホームを", "持つなんて", "信じられないよ。"]}, {"box": [175, 839, 311, 1035], "vertical": true, "font_size": 26, "lines_coords": [[[284.0, 840.0], [310.0, 840.0], [310.0, 1007.0], [284.0, 1007.0]], [[248.0, 840.0], [275.0, 840.0], [275.0, 1000.0], [248.0, 1000.0]], [[210.0, 840.0], [237.0, 840.0], [237.0, 1025.0], [210.0, 1025.0]], [[175.0, 839.0], [198.0, 839.0], [200.0, 1035.0], [176.0, 1035.0]]], "lines": ["何言ってるの、", "パパがお仕事", "がんばってきた", "からじゃないの。"]}, {"box": [889, 1167, 1006, 1417], "vertical": true, "font_size": 26, "lines_coords": [[[978.0, 1168.0], [1006.0, 1168.0], [1006.0, 1279.0], [978.0, 1279.0]], [[948.0, 1168.0], [975.0, 1168.0], [975.0, 1381.0], [948.0, 1381.0]], [[921.0, 1168.0], [943.0, 1168.0], [943.0, 1417.0], [921.0, 1417.0]], [[890.0, 1167.0], [917.0, 1167.0], [915.0, 1362.0], [889.0, 1362.0]]], "lines": ["頭金６００万、", "２５年ローンを完済", "する頃には、この子も", "立派な大人だな。"]}, {"box": [748, 1346, 873, 1507], "vertical": true, "font_size": 26, "lines_coords": [[[843.0, 1346.0], [870.0, 1346.0], [873.0, 1507.0], [846.0, 1507.0]], [[810.0, 1350.0], [837.0, 1350.0], [837.0, 1456.0], [810.0, 1456.0]], [[779.0, 1348.0], [806.0, 1348.0], [806.0, 1507.0], [779.0, 1507.0]], [[748.0, 1350.0], [775.0, 1350.0], [775.0, 1456.0], [748.0, 1456.0]]], "lines": ["繰り上げ返済", "目指して", "もりもり働く", "ぞー！！"]}, {"box": [156, 1353, 262, 1496], "vertical": true, "font_size": 27, "lines_coords": [[[229.0, 1353.0], [257.0, 1353.0], [257.0, 1481.0], [229.0, 1481.0]], [[190.0, 1353.0], [218.0, 1353.0], [218.0, 1460.0], [190.0, 1460.0]], [[156.0, 1354.0], [182.0, 1354.0], [182.0, 1495.0], [156.0, 1495.0]]], "lines": ["今日のパパ", "なんだか", "頼もしいわ。"]}], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [853, 806, 968, 1015], "vertical": true, "font_size": 26, "lines_coords": [[[942.0, 809.0], [968.0, 809.0], [968.0, 939.0], [942.0, 939.0]], [[909.0, 807.0], [937.0, 807.0], [939.0, 1015.0], [910.0, 1015.0]], [[879.0, 806.0], [906.0, 806.0], [906.0, 1015.0], [879.0, 1015.0]], [[854.0, 806.0], [876.0, 806.0], [875.0, 989.0], [853.0, 989.0]]], "lines": ["２０代の頃は", "マイホーム購入は", "人生のゴールだと", "思ってたけど．．"]}, {"box": [140, 954, 245, 1122], "vertical": true, "font_size": 27, "lines_coords": [[[217.0, 954.0], [243.0, 954.0], [243.0, 1059.0], [217.0, 1059.0]], [[181.0, 954.0], [209.0, 954.0], [206.0, 1112.0], [178.0, 1112.0]], [[143.0, 954.0], [170.0, 954.0], [167.0, 1118.0], [140.0, 1118.0]]], "lines": ["まだまだ", "通過点でしか", "ないんだよな。"]}, {"box": [760, 1239, 863, 1425], "vertical": true, "font_size": 29, "lines_coords": [[[835.0, 1240.0], [862.0, 1240.0], [862.0, 1425.0], [835.0, 1425.0]], [[796.0, 1239.0], [828.0, 1239.0], [828.0, 1400.0], [796.0, 1400.0]], [[760.0, 1240.0], [789.0, 1240.0], [790.0, 1398.0], [762.0, 1398.0]]], "lines": ["．．．三人で幸せな", "家庭を築いて", "いこう、な？"]}, {"box": [267, 1348, 296, 1418], "vertical": true, "font_size": 29, "lines_coords": [[[267.0, 1348.0], [296.0, 1348.0], [296.0, 1418.0], [267.0, 1418.0]]], "lines": ["うん。"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "075.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "077.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [36, 287, 82, 448], "vertical":