 30, "lines_coords": [[[422.0, 1030.0], [453.0, 1030.0], [453.0, 1075.0], [422.0, 1075.0]]], "lines": ["ふぅ"]}, {"box": [357, 1073, 386, 1137], "vertical": true, "font_size": 30, "lines_coords": [[[357.0, 1073.0], [386.0, 1073.0], [386.0, 1137.0], [357.0, 1137.0]]], "lines": ["ふぅ．．．"]}, {"box": [227, 881, 298, 1024], "vertical": true, "font_size": 20, "lines_coords": [[[277.0, 881.0], [298.0, 881.0], [296.0, 1024.0], [275.0, 1024.0]], [[254.0, 881.0], [274.0, 881.0], [274.0, 1014.0], [254.0, 1014.0]], [[229.0, 881.0], [250.0, 881.0], [248.0, 984.0], [227.0, 984.0]]], "lines": ["「．．．鹿児島市内に", "着いたら大阪に", "移動しよう。"]}, {"box": [162, 881, 203, 1079], "vertical": true, "font_size": 20, "lines_coords": [[[183.0, 881.0], [203.0, 881.0], [203.0, 1033.0], [183.0, 1033.0]], [[162.0, 884.0], [179.0, 884.0], [179.0, 1079.0], [162.0, 1079.0]]], "lines": ["大きな街のほうが", "人に紛れられるから．．"]}], "img_path": "031.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [638, 69, 684, 151], "vertical": true, "font_size": 20, "lines_coords": [[[663.0, 70.0], [684.0, 70.0], [684.0, 146.0], [663.0, 146.0]], [[638.0, 69.0], [658.0, 69.0], [658.0, 151.0], [638.0, 151.0]]], "lines": ["人が多い", "所はもう、"]}, {"box": [133, 305, 153, 403], "vertical": true, "font_size": 22, "lines_coords": [[[133.0, 305.0], [153.0, 305.0], [153.0, 403.0], [133.0, 403.0]]], "lines": ["．．．行きたく"]}, {"box": [154, 453, 179, 533], "vertical": true, "font_size": 22, "lines_coords": [[[154.0, 453.0], [179.0, 453.0], [179.0, 533.0], [154.0, 533.0]]], "lines": ["ない．．．"]}], "img_path": "032.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [631, 41, 651, 166], "vertical": true, "font_size": 18, "lines_coords": [[[631.0, 41.0], [651.0, 41.0], [651.0, 166.0], [631.0, 166.0]]], "lines": ["「．．．愛子ちゃん"]}, {"box": [583, 41, 599, 179], "vertical": true, "font_size": 18, "lines_coords": [[[583.0, 41.0], [599.0, 41.0], [599.0, 179.0], [583.0, 179.0]]], "lines": ["熱がひどいよ．．．"]}, {"box": [511, 240, 551, 325], "vertical": true, "font_size": 19, "lines_coords": [[[535.0, 241.0], [551.0, 241.0], [551.0, 325.0], [535.0, 325.0]], [[511.0, 240.0], [533.0, 240.0], [533.0, 295.0], [511.0, 295.0]]], "lines": ["薬飲んでも", "．．．．．．"]}, {"box": [608, 485, 629, 592], "vertical": true, "font_size": 22, "lines_coords": [[[608.0, 485.0], [629.0, 485.0], [629.0, 592.0], [608.0, 592.0]]], "lines": ["「．．．やっぱり、"]}, {"box": [444, 314, 482, 418], "vertical": true, "font_size": 19, "lines_coords": [[[461.0, 314.0], [482.0, 314.0], [482.0, 385.0], [461.0, 385.0]], [[444.0, 314.0], [460.0, 314.0], [460.0, 418.0], [444.0, 418.0]]], "lines": ["効かなく", "なってきた．．．"]}, {"box": [535, 483, 582, 591], "vertical": true, "font_size": 22, "lines_coords": [[[557.0, 483.0], [582.0, 483.0], [579.0, 591.0], [555.0, 591.0]], [[535.0, 483.0], [555.0, 483.0], [555.0, 589.0], [535.0, 589.0]]], "lines": ["一度病院に", "行こう．．．"]}, {"box": [230, 479, 272, 557], "vertical": true, "font_size": 20, "lines_coords": [[[251.0, 479.0], [272.0, 479.0], [272.0, 551.0], [251.0, 551.0]], [[230.0, 480.0], [251.0, 480.0], [251.0, 557.0], [230.0, 557.0]]], "lines": ["．．．そんな", "事したら、"]}, {"box": [149, 532, 188, 618], "vertical": true, "font_size": 20, "lines_coords": [[[168.0, 532.0], [188.0, 532.0], [188.0, 603.0], [168.0, 603.0]], [[149.0, 532.0], [166.0, 532.0], [166.0, 618.0], [149.0, 618.0]]], "lines": ["．．．あたし", "捕まるよ？"]}, {"box": [693, 699, 715, 815], "vertical": true, "font_size": 20, "lines_coords": [[[693.0, 699.0], [713.0, 699.0], [713.0, 814.0], [693.0, 814.0]]], "lines": ["うっふっふ．．．"]}, {"box": [271, 854, 291, 957], "vertical": true, "font_size": 19, "lines_coords": [[[271.0, 854.0], [291.0, 854.0], [291.0, 957.0], [271.0, 957.0]]], "lines": ["わかったぞ．．．"]}, {"box": [162, 943, 226, 1080], "vertical": true, "font_size": 19, "lines_coords": [[[205.0, 943.0], [226.0, 943.0], [226.0, 997.0], [205.0, 997.0]], [[183.0, 943.0], [201.0, 943.0], [203.0, 1080.0], [186.0, 1080.0]], [[164.0, 943.0], [181.0, 943.0], [180.0, 1064.0], [162.0, 1064.0]]], "lines": ["本当は", "あたしに捕まって", "ほしいんだね．．．"]}], "img_path": "033.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [681, 540, 702, 600], "vertical": true, "font_size": 22, "lines_coords": [[[681.0, 540.0], [702.0, 540.0], [702.0, 600.0], [681.0, 600.0]]], "lines": ["．．．え？"]}, {"box": [590, 645, 654, 734], "vertical": true, "font_size": 22, "lines_coords": [[[634.0, 645.0], [654.0, 645.0], [654.0, 734.0], [634.0, 734.0]], [[610.0, 645.0], [634.0, 645.0], [634.0, 719.0], [610.0, 719.0]], [[592.0, 645.0], [613.0, 645.0], [611.0, 718.0], [590.0, 718.0]]], "lines": ["西之沢って", "けっこう", "遠いよ？"]}, {"box": [379, 825, 422, 931], "vertical": true, "font_size": 18, "lines_coords": [[[404.0, 827.0], [420.0, 827.0], [420.0, 930.0], [404.0, 930.0]], [[381.0, 825.0], [401.0, 825.0], [399.0, 930.0], [379.0, 930.0]]], "lines": ["急いでもらえ", "ますか．．．．．？"]}, {"box": [114, 645, 195, 783], "vertical": true, "font_size": 17, "lines_coords": [[[176.0, 648.0], [193.0, 648.0], [193.0, 738.0], [176.0, 738.0]], [[155.0, 646.0], [172.0, 646.0], [172.0, 767.0], [155.0, 767.0]], [[134.0, 645.0], [151.0, 645.0], [151.0, 782.0], [134.0, 782.0]], [[114.0, 646.0], [130.0, 646.0], [130.0, 750.0], [114.0, 750.0]]], "lines": ["．．．お客さん、", "こんな時間から", "あんな山奥行って", "どうすんの？"]}, {"box": [670, 978, 736, 1068], "vertical": true, "font_size": 21, "lines_coords": [[[711.0, 978.0], [736.0, 979.0], [734.0, 1039.0], [708.0, 1038.0]], [[693.0, 983.0], [709.0, 983.0], [709.0, 1067.0], [693.0, 1067.0]], [[670.0, 982.0], [692.0, 982.0], [692.0, 1037.0], [670.0, 1037.0]]], "lines": ["．．．具合", "悪そうです", "ね．．．．．"]}, {"box": [332, 1000, 374, 1089], "vertical": true, "font_size": 18, "lines_coords": [[[354.0, 1000.0], [374.0, 1000.0], [374.0, 1089.0], [354.0, 1089.0]], [[332.0, 1001.0], [353.0, 1001.0], [353.0, 1089.0], [332.0, 1089.0]]], "lines": ["ビニール袋", "あるんで．．．"]}, {"box": [222, 1030, 281, 1150], "vertical": true, "font_size": 18, "lines_coords": [[[264.0, 1031.0], [281.0, 1031.0], [281.0, 1150.0], [264.0, 1150.0]], [[243.0, 1030.0], [260.0, 1030.0], [260.0, 1116.0], [243.0, 1116.0]], [[222.0, 1030.0], [238.0, 1030.0], [238.0, 1148.0], [222.0, 1148.0]]], "lines": ["危なくなったら", "早く言って", "くださいよ．．．"]}], "img_path": "034.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [658, 55, 739, 193], "vertical": true, "font_size": 17, "lines_coords": [[[719.0, 55.0], [739.0, 55.0], [739.0, 142.0], [719.0, 142.0]], [[698.0, 56.0], [714.0, 56.0], [714.0, 191.0], [698.0, 191.0]], [[679.0, 56.0], [695.0, 56.0], [695.0, 193.0], [679.0, 193.0]], [[658.0, 56.0], [674.0, 56.0], [674.0, 175.0], [658.0, 175.0]]], "lines": ["．．．子供の時", "あたしが鹿児島に", "行こうって言った", "元々の理由．．．"]}, {"box": [463, 280, 506, 350], "vertical": true, "font_size": 18, "lines_coords": [[[486.0, 280.0], [506.0, 280.0], [506.0, 350.0], [486.0, 350.0]], [[463.0, 281.0], [485.0, 281.0], [485.0, 335.0], [463.0, 335.0]]], "lines": ["憶えてる", "．．．．．"]}, {"box": [371, 360, 428, 498], "vertical": true, "font_size": 18, "lines_coords": [[[412.0, 360.0], [428.0, 360.0], [428.0, 496.0], [412.0, 496.0]], [[393.0, 362.0], [408.0, 362.0], [408.0, 498.0], [393.0, 498.0]], [[371.0, 363.0], [387.0, 363.0], [387.0, 498.0], [371.0, 498.0]]], "lines": ["親戚のおじさんが", "こっちに住んでる", "からなんだけど．．．"]}, {"box": [665, 594, 711, 672], "vertical": true, "font_size": 22, "lines_coords": [[[691.0, 595.0], [711.0, 595.0], [711.0, 672.0], [691.0, 672.0]], [[665.0, 594.0], [690.0, 594.0], [690.0, 656.0], [665.0, 656.0]]], "lines": ["おじさん", "は．．．"]}, {"box": [151, 587, 199, 686], "vertical": true, "font_size": 24, "lines_coords": [[[171.0, 587.0], [199.0, 587.0], [199.0, 636.0], [171.0, 636.0]], [[151.0, 590.0], [172.0, 590.0], [172.0, 685.0], [151.0, 685.0]]], "lines": ["医者", "だから．．．"]}], "img_path": "035.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [168, 243, 274, 417], "vertical": true, "font_size": 19, "lines_coords": [[[255.0, 246.0], [271.0, 246.0], [271.0, 417.0], [255.0, 417.0]], [[234.0, 247.0], [250.0, 247.0], [250.0, 400.0], [234.0, 400.0]], [[214.0, 248.0], [230.0, 248.0], [230.0, 383.0], [214.0, 383.0]], [[190.0, 247.0], [210.0, 247.0], [210.0, 384.0], [190.0, 384.0]], [[168.0, 243.0], [194.0, 243.0], [194.0, 290.0], [168.0, 290.0]]], "lines": ["．．．山中で死亡していた", "田中光子さんの車が", "鹿児島県○○市の", "山道で発見されて", "おリー"]}, {"box": [688, 623, 705, 705], "vertical": true, "font_size": 19, "lines_coords": [[[688.0, 623.0], [705.0, 623.0], [705.0, 705.0], [688.0, 705.0]]], "lines": ["ー行方が"]}, {"box": [603, 601, 685, 779], "vertical": true, "font_size": 19, "lines_coords": [[[665.0, 601.0], [685.0, 601.0], [685.0, 774.0], [665.0, 774.0]], [[644.0, 602.0], [660.0, 602.0], [663.0, 721.0], [646.0, 721.0]], [[622.0, 601.0], [641.0, 601.0], [643.0, 740.0], [623.0, 740.0]], [[603.0, 602.0], [623.0, 602.0], [623.0, 779.0], [603.0, 779.0]]], "lines": ["わからなくなっている", "娘の愛子さんが", "なんらかの事情を", "知っているものとみて、"]}, {"box": [426, 843, 554, 883], "vertical": false, "font_size": 9, "lines_coords": [[[426.0, 866.0], [469.0, 862.0], [469.0, 871.0], [426.0, 875.0]]], "lines": ["おまえさんので"]}, {"box": [132, 684, 202, 801], "vertical": true, "font_size": 21, "lines_coords": [[[183.0, 687.0], [200.0, 687.0], [200.0, 799.0], [183.0, 799.0]], [[156.0, 684.0], [178.0, 684.0], [179.0, 801.0], [158.0, 801.0]], [[132.0, 685.0], [156.0, 685.0], [156.0, 751.0], [132.0, 751.0]]], "lines": ["鹿児島県警が", "行方を追って", "います。"]}, {"box": [222, 999, 283, 1110], "vertical": true, "font_size": 18, "lines_coords": [[[263.0, 1000.0], [283.0, 1000.0], [283.0, 1103.0], [263.0, 1103.0]], [[244.0, 1001.0], [261.0, 1001.0], [261.0, 1103.0], [244.0, 1103.0]], [[222.0, 999.0], [238.0, 999.0], [241.0, 1109.0], [224.0, 1109.0]]], "lines": ["．．．では続いて", "ＫＢＦラジオ", "交通情報です。"]}], "img_path": "036.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [275, 53, 374, 207], "vertical": true, "font_size": 17, "lines_coords": [[[354.0, 53.0], [374.0, 53.0], [374.0, 159.0], [354.0, 159.0]], [[336.0, 55.0], [352.0, 55.0], [352.0, 191.0], [336.0, 191.0]], [[315.0, 55.0], [331.0, 55.0], [331.0, 192.0], [315.0, 192.0]], [[295.0, 55.0], [311.0, 55.0], [311.0, 207.0], [295.0, 207.0]], [[275.0, 60.0], [292.0, 60.0], [292.0, 91.0], [275.0, 91.0]]], "lines": ["あの〜〜〜．．．", "もう少しで西之沢", "なんですけど、私", "もよおしてしまって", "．．．"]}, {"box": [132, 209, 217, 315], "vertical": true, "font_size": 19, "lines_coords": [[[192.0, 209.0], [217.0, 209.0], [217.0, 267.0], [192.0, 267.0]], [[175.0, 214.0], [192.0, 214.0], [192.0, 315.0], [175.0, 315.0]], [[154.0, 213.0], [171.0, 213.0], [171.0, 298.0], [154.0, 298.0]], [[132.0, 210.0], [153.0, 210.0], [153.0, 268.0], [132.0, 268.0]]], "lines": ["近場の", "コンビニまで", "迂回します", "ね．．．．．"]}, {"box": [207, 424, 320, 448], "vertical": false, "font_size": 24, "lines_coords": [[[207.0, 424.0], [320.0, 424.0], [320.0, 448.0], [207.0, 448.0]]], "lines": ["賃走１５２０"]}, {"box": [120, 360, 156, 461], "vertical": true, "font_size": 19, "lines_coords": [[[140.0, 362.0], [156.0, 362.0], [156.0, 461.0], [140.0, 461.0]], [[120.0, 360.0], [137.0, 360.0], [137.0, 461.0], [120.0, 461.0]]], "lines": ["一度メーター", "止めます．．．"]}, {"box": [474, 1016, 593, 1148], "vertical": true, "font_size": 20, "lines_coords": [[[569.0, 1017.0], [590.0, 1017.0], [591.0, 1146.0], [570.0, 1146.0]], [[547.0, 1016.0], [567.0, 1016.0], [567.0, 1133.0], [547.0, 1133.0]], [[523.0, 1017.0], [543.0, 1017.0], [543.0, 1115.0], [523.0, 1115.0]], [[500.0, 1018.0], [520.0, 1018.0], [520.0, 1114.0], [500.0, 1114.0]], [[474.0, 1017.0], [495.0, 1017.0], [497.0, 1102.0], [476.0, 1102.0]]], "lines": ["「．．．愛子ちゃん、", "僕はやっぱり", "この選択が", "正しいとは", "思えない。"]}, {"box": [305, 1017, 398, 1154], "vertical": true, "font_size": 21, "lines_coords": [[[378.0, 1018.0], [398.0, 1018.0], [398.0, 1133.0], [378.0, 1133.0]], [[352.0, 1017.0], [376.0, 1017.0], [376.0, 1154.0], [352.0, 1154.0]], [[330.0, 1018.0], [350.0, 1018.0], [350.0, 1115.0], [330.0, 1115.0]], [[305.0, 1018.0], [326.0, 1018.0], [326.0, 1125.0], [305.0, 1125.0]]], "lines": ["．．．この場合に", "親類を頼るのは", "むしろ危険", "過ぎる．．．．．．」"]}], "img_path": "037.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [702, 71, 722, 158], "vertical": true, "font_size": 17, "lines_coords": [[[702.0, 71.0], [722.0, 71.0], [722.0, 158.0], [702.0, 158.0]]], "lines": ["じゃあ．．．"]}, {"box": [590, 147, 647, 267], "vertical": true, "font_size": 17, "lines_coords": [[[631.0, 148.0], [647.0, 148.0], [647.0, 234.0], [631.0, 234.0]], [[609.0, 147.0], [626.0, 147.0], [627.0, 267.0], [610.0, 267.0]], [[590.0, 147.0], [605.0, 147.0], [605.0, 250.0], [590.0, 250.0]]], "lines": ["フンフンは", "何かいい考えが", "あるの．．．．．？"]}, {"box": [123, 153, 203, 275], "vertical": true, "font_size": 17, "lines_coords": [[[185.0, 155.0], [201.0, 155.0], [201.0, 275.0], [185.0, 275.0]], [[161.0, 153.0], [181.0, 153.0], [183.0, 242.0], [164.0, 242.0]], [[141.0, 154.0], [159.0, 154.0], [160.0, 273.0], [142.0, 273.0]], [[123.0, 157.0], [139.0, 157.0], [139.0, 274.0], [123.0, 274.0]]], "lines": ["他に思いあたる", "あてなんて", "あたしには思い", "つかないし．．．"]}, {"box": [436, 842, 497, 949], "vertical": true, "font_size": 20, "lines_coords": [[[477.0, 842.0], [497.0, 842.0], [497.0, 929.0], [477.0, 929.0]], [[458.0, 846.0], [477.0, 846.0], [477.0, 949.0], [458.0, 949.0]], [[436.0, 843.0], [456.0, 843.0], [456.0, 915.0], [436.0, 915.0]]], "lines": ["．．．おじさん", "いい人だった", "から．．．．．"]}, {"box": [586, 890, 678, 1120], "vertical": true, "font_size": 19, "lines_coords": [[[660.0, 895.0], [677.0, 895.0], [677.0, 1053.0], [660.0, 1053.0]], [[634.0, 891.0], [654.0, 891.0], [653.0, 1120.0], [633.0, 1120.0]], [[611.0, 891.0], [631.0, 891.0], [629.0, 1064.0], [609.0, 1064.0]], [[586.0, 892.0], [606.0, 892.0], [606.0, 1110.0], [586.0, 1110.0]]], "lines": ["「．．．親類だからって", "突然現れた刺し傷だらけの", "人間を何も聞かずに", "治療してくれるとでも？」"]}, {"box": [317, 1034, 360, 1129], "vertical": true, "font_size": 20, "lines_coords": [[[339.0, 1034.0], [360.0, 1034.0], [360.0, 1122.0], [339.0, 1122.0]], [[317.0, 1035.0], [337.0, 1035.0], [337.0, 1129.0], [317.0, 1129.0]]], "lines": ["「．．．いい人", "だからこそ"]}, {"box": [118, 887, 182, 976], "vertical": true, "font_size": 24, "lines_coords": [[[155.0, 887.0], [182.0, 887.0], [182.0, 945.0], [155.0, 945.0]], [[135.0, 887.0], [161.0, 887.0], [161.0, 946.0], [135.0, 946.0]], [[118.0, 888.0], [138.0, 888.0], [138.0, 976.0], [118.0, 976.0]]], "lines": ["事情を", "話せば", "きっと．．．"]}, {"box": [217, 1034, 284, 1157], "vertical": true, "font_size": 20, "lines_coords": [[[263.0, 1034.0], [284.0, 1034.0], [282.0, 1129.0], [261.0, 1129.0]], [[240.0, 1035.0], [261.0, 1035.0], [261.0, 1112.0], [240.0, 1112.0]], [[217.0, 1037.0], [234.0, 1037.0], [234.0, 1157.0], [217.0, 1157.0]]], "lines": ["もう僕らの", "味方では", "ないんだよ．．．」"]}], "img_path": "038.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [421, 59, 467, 138], "vertical": true, "font_size": 23, "lines_coords": [[[441.0, 59.0], [467.0, 59.0], [467.0, 123.0], [441.0, 123.0]], [[421.0, 60.0], [441.0, 60.0], [441.0, 138.0], [421.0, 138.0]]], "lines": ["運転手", "さん．．．"]}, {"box": [255, 196, 282, 295], "vertical": true, "font_size": 24, "lines_coords": [[[255.0, 196.0], [279.0, 196.0], [282.0, 295.0], [257.0, 295.0]]], "lines": ["遅いね．．．"]}, {"box": [514, 390, 582, 420], "vertical": false, "font_size": 17, "lines_coords": [[[514.0, 403.0], [578.0, 390.0], [582.0, 407.0], [517.0, 420.0]]], "lines": ["ド取扱車"]}, {"box": [408, 525, 585, 600], "vertical": false, "font_size": 18, "lines_coords": [[[425.0, 567.0], [517.0, 567.0], [517.0, 587.0], [425.0, 587.0]]], "lines": ["それを理解したのですが、何度も何も知らないのでしょうかもしれませんが、私は結婚相談をしているのではないで"]}, {"box": [245, 353, 303, 474], "vertical": true, "font_size": 20, "lines_coords": [[[278.0, 353.0], [303.0, 353.0], [303.0, 417.0], [278.0, 417.0]], [[247.0, 355.0], [263.0, 355.0], [263.0, 472.0], [247.0, 472.0]]], "lines": ["「急いで", "車を降りよう。」"]}, {"box": [686, 696, 704, 776], "vertical": true, "font_size": 18, "lines_coords": [[[686.0, 726.0], [704.0, 726.0], [704.0, 774.0], [686.0, 774.0]]], "lines": ["．．．え？"]}, {"box": [550, 717, 641, 793], "vertical": false, "font_size": 14.6, "lines_coords": [[[550.0, 723.0], [639.0, 717.0], [640.0, 732.0], [551.0, 738.0]], [[552.0, 735.0], [640.0, 728.0], [641.0, 745.0], [554.0, 752.0]], [[554.0, 751.0], [640.0, 745.0], [641.0, 758.0], [555.0, 764.0]], [[563.0, 765.0], [638.0, 759.0], [639.0, 772.0], [564.0, 778.0]], [[561.0, 778.0], [625.0, 773.0], [626.0, 788.0], [562.0, 793.0]]], "lines": ["ご真華頂き誠にうりりとうございます", "東務局の授業についてお", "え．．．俺え付けのいずれエント", "何．．．一番のカーとか", "今後とも恋愛いの"]}, {"box": [150, 626, 263, 667], "vertical": false, "font_size": 10, "lines_coords": [[[168.0, 626.0], [247.0, 624.0], [247.0, 638.0], [168.0, 639.0]], [[154.0, 634.0], [257.0, 633.0], [257.0, 648.0], [154.0, 650.0]], [[155.0, 644.0], [257.0, 642.0], [257.0, 653.0], [155.0, 655.0]], [[152.0, 649.0], [256.0, 649.0], [256.0, 661.0], [152.0, 661.0]], [[153.0, 660.0], [254.0, 660.0], [254.0, 668.0], [153.0, 668.0]]], "lines": ["カードさん市のお客様へありがとうございます。", "これは．．．これまではないのですが、「カード記録記事」を書いていますので、お客様のお願いをしてみました。", "これは．．．", "ありません。僕は一番もあったのですが、出来ずそんなことができますよね。これではない。", "これを確認する方法書になります。"]}, {"box": [598, 926, 730, 1101], "vertical": true, "font_size": 20, "lines_coords": [[[708.0, 928.0], [729.0, 928.0], [729.0, 1020.0], [708.0, 1020.0]], [[684.0, 928.0], [704.0, 928.0], [704.0, 1099.0], [684.0, 1099.0]], [[661.0, 928.0], [681.0, 928.0], [679.0, 1046.0], [659.0, 1046.0]], [[620.0, 928.0], [641.0, 928.0], [643.0, 1100.0], [622.0, 1100.0]], [[598.0, 928.0], [618.0, 928.0], [618.0, 1033.0], [598.0, 1033.0]]], "lines": ["「．．．運転手、", "君に気付いたのかも", "しれない．．．", "もう通報されてると", "したら．．．"]}], "img_path": "039.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [255, 63, 284, 128], "vertical": true, "font_size": 29, "lines_coords": [[[255.0, 63.0], [284.0, 63.0], [284.0, 128.0], [255.0, 128.0]]], "lines": ["ふぅ．．．"]}, {"box": [111, 438, 137, 500], "vertical": true