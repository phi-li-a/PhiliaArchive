318.0], [534.0, 399.0], [521.0, 399.0]]], "lines": ["退屈なら", "外に出てても", "いいけど？"]}, {"box": [128, 310, 188, 432], "vertical": true, "font_size": 19, "lines_coords": [[[167.0, 310.0], [187.0, 310.0], [187.0, 389.0], [167.0, 389.0]], [[148.0, 312.0], [168.0, 312.0], [168.0, 432.0], [148.0, 432.0]], [[128.0, 310.0], [145.0, 310.0], [145.0, 401.0], [128.0, 401.0]]], "lines": ["．．．ごめん。", "一人でゆっくり", "考えたいの"]}], "img_path": "239.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [294, 429, 359, 454], "vertical": false, "font_size": 15, "lines_coords": [[[301.0, 433.0], [350.0, 433.0], [350.0, 450.0], [301.0, 450.0]]], "lines": ["ＦＡＮＮ"]}], "img_path": "240.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [233, 241, 295, 285], "vertical": false, "font_size": 18, "lines_coords": [[[233.0, 269.0], [287.0, 241.0], [295.0, 257.0], [241.0, 285.0]]], "lines": ["お問い合わせ"]}, {"box": [545, 114, 615, 227], "vertical": true, "font_size": 21, "lines_coords": [[[590.0, 114.0], [615.0, 114.0], [615.0, 179.0], [590.0, 179.0]], [[568.0, 116.0], [588.0, 116.0], [588.0, 227.0], [568.0, 227.0]], [[545.0, 116.0], [562.0, 116.0], [562.0, 215.0], [545.0, 215.0]]], "lines": ["きっと、", "これが「普通」", "なんだろう。"]}, {"box": [125, 489, 161, 510], "vertical": false, "font_size": 10, "lines_coords": [[[125.0, 501.0], [158.0, 489.0], [161.0, 499.0], [128.0, 510.0]]], "lines": ["オーナ、"]}, {"box": [558, 557, 571, 577], "vertical": false, "font_size": 20, "lines_coords": [[[558.0, 557.0], [571.0, 557.0], [571.0, 577.0], [558.0, 577.0]]], "lines": ["思い"]}, {"box": [161, 962, 253, 1076], "vertical": true, "font_size": 20, "lines_coords": [[[233.0, 962.0], [253.0, 962.0], [253.0, 1076.0], [233.0, 1076.0]], [[208.0, 963.0], [228.0, 963.0], [228.0, 1058.0], [208.0, 1058.0]], [[185.0, 963.0], [205.0, 963.0], [205.0, 1076.0], [185.0, 1076.0]], [[161.0, 963.0], [181.0, 963.0], [181.0, 1065.0], [161.0, 1065.0]]], "lines": ["自分の人生が", "楽勝すぎて", "頭がどうにか", "なりそうだ。"]}], "img_path": "241.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [618, 87, 688, 202], "vertical": true, "font_size": 22, "lines_coords": [[[667.0, 89.0], [687.0, 89.0], [687.0, 202.0], [667.0, 202.0]], [[644.0, 89.0], [664.0, 89.0], [664.0, 183.0], [644.0, 183.0]], [[618.0, 87.0], [643.0, 87.0], [643.0, 151.0], [618.0, 151.0]]], "lines": ["今年の七夕は", "梅雨晴れの", "快晴で、"]}, {"box": [130, 271, 219, 430], "vertical": true, "font_size": 16, "lines_coords": [[[200.0, 273.0], [216.0, 273.0], [216.0, 404.0], [200.0, 404.0]], [[175.0, 271.0], [193.0, 271.0], [194.0, 428.0], [176.0, 428.0]], [[153.0, 273.0], [169.0, 273.0], [169.0, 423.0], [153.0, 423.0]], [[130.0, 271.0], [146.0, 271.0], [146.0, 430.0], [130.0, 430.0]]], "lines": ["僕はふと誰かを", "殺さなきゃと思い、", "買い物客で賑わう", "街を徘徊していた。"]}, {"box": [493, 957, 545, 1105], "vertical": true, "font_size": 24, "lines_coords": [[[518.0, 957.0], [543.0, 957.0], [545.0, 1095.0], [521.0, 1095.0]], [[493.0, 957.0], [516.0, 957.0], [516.0, 1105.0], [493.0, 1105.0]]], "lines": ["．．．そして僕は", "彼と再会した。"]}], "img_path": "242.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [636, 85, 725, 198], "vertical": true, "font_size": 19, "lines_coords": [[[704.0, 85.0], [725.0, 85.0], [725.0, 162.0], [704.0, 162.0]], [[681.0, 85.0], [701.0, 85.0], [701.0, 181.0], [681.0, 181.0]], [[656.0, 85.0], [675.0, 85.0], [678.0, 198.0], [658.0, 198.0]], [[636.0, 87.0], [652.0, 87.0], [652.0, 185.0], [636.0, 185.0]]], "lines": ["背格好は", "紛れもなく", "大人になって", "いたけれど、"]}, {"box": [46, 223, 79, 343], "vertical": true, "font_size": 30, "lines_coords": [[[46.0, 227.0], [76.0, 227.0], [76.0, 343.0], [46.0, 343.0]]], "lines": ["最終話"]}, {"box": [148, 241, 215, 382], "vertical": true, "font_size": 19, "lines_coords": [[[196.0, 242.0], [213.0, 242.0], [213.0, 375.0], [196.0, 375.0]], [[171.0, 241.0], [190.0, 241.0], [190.0, 335.0], [171.0, 335.0]], [[148.0, 241.0], [168.0, 241.0], [168.0, 382.0], [148.0, 382.0]]], "lines": ["目が合った瞬間", "間違いなく", "彼だとわかった。"]}, {"box": [315, 708, 385, 840], "vertical": true, "font_size": 22, "lines_coords": [[[364.0, 710.0], [385.0, 710.0], [385.0, 786.0], [364.0, 786.0]], [[339.0, 708.0], [359.0, 708.0], [359.0, 840.0], [339.0, 840.0]], [[315.0, 708.0], [340.0, 708.0], [340.0, 776.0], [315.0, 776.0]]], "lines": ["．．．それは", "彼も同じだった", "ようだ。"]}, {"box": [474, 1037, 523, 1059], "vertical": false, "font_size": 10, "lines_coords": [[[496.0, 1038.0], [517.0, 1038.0], [517.0, 1050.0], [496.0, 1050.0]]], "lines": ["ニコピ"]}], "img_path": "243.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [571, 69, 638, 203], "vertical": true, "font_size": 19, "lines_coords": [[[618.0, 69.0], [638.0, 69.0], [637.0, 203.0], [617.0, 203.0]], [[592.0, 69.0], [612.0, 69.0], [612.0, 182.0], [592.0, 182.0]], [[572.0, 72.0], [589.0, 72.0], [589.0, 191.0], [572.0, 191.0]]], "lines": ["途切れ塗切れで", "噛み合わない", "会話が続いた。"]}, {"box": [156, 843, 260, 1005], "vertical": true, "font_size": 17, "lines_coords": [[[242.0, 847.0], [258.0, 847.0], [258.0, 946.0], [242.0, 946.0]], [[220.0, 843.0], [240.0, 843.0], [240.0, 1004.0], [220.0, 1004.0]], [[199.0, 844.0], [215.0, 844.0], [215.0, 982.0], [199.0, 982.0]], [[179.0, 846.0], [195.0, 846.0], [195.0, 966.0], [179.0, 966.0]], [[156.0, 843.0], [174.0, 843.0], [175.0, 986.0], [158.0, 986.0]]], "lines": ["僕はもう彼の", "知ってる僕ではなく、", "それはきっと彼も", "同じなのだから", "仕方ない事だけど、"]}], "img_path": "244.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [694, 53, 757, 140], "vertical": true, "font_size": 21, "lines_coords": [[[735.0, 53.0], [757.0, 53.0], [757.0, 108.0], [735.0, 108.0]], [[715.0, 53.0], [735.0, 53.0], [735.0, 140.0], [715.0, 140.0]], [[694.0, 55.0], [714.0, 55.0], [714.0, 126.0], [694.0, 126.0]]], "lines": ["話題が", "天気の話に", "なった頃、"]}, {"box": [410, 201, 490, 345], "vertical": true, "font_size": 17, "lines_coords": [[[470.0, 201.0], [490.0, 201.0], [490.0, 271.0], [470.0, 271.0]], [[451.0, 201.0], [467.0, 201.0], [467.0, 342.0], [451.0, 342.0]], [[431.0, 202.0], [447.0, 202.0], [447.0, 339.0], [431.0, 339.0]], [[410.0, 202.0], [426.0, 202.0], [426.0, 329.0], [410.0, 329.0]]], "lines": ["お互いが", "それを悟ったのか、", "それとなく別れる", "雰囲気になった。"]}, {"box": [677, 475, 724, 590], "vertical": true, "font_size": 22, "lines_coords": [[[701.0, 475.0], [721.0, 475.0], [723.0, 590.0], [704.0, 590.0]], [[677.0, 475.0], [702.0, 475.0], [702.0, 542.0], [677.0, 542.0]]], "lines": ["少しの沈黙を", "挟んで、"]}, {"box": [176, 571, 268, 686], "vertical": true, "font_size": 20, "lines_coords": [[[247.0, 571.0], [268.0, 571.0], [268.0, 678.0], [247.0, 678.0]], [[223.0, 571.0], [243.0, 571.0], [243.0, 686.0], [223.0, 686.0]], [[200.0, 571.0], [220.0, 571.0], [220.0, 686.0], [200.0, 686.0]], [[176.0, 571.0], [196.0, 571.0], [196.0, 675.0], [176.0, 675.0]]], "lines": ["「ずっと伝え", "たかった事が", "あるんだ。」と", "彼が言った。"]}, {"box": [151, 967, 252, 1122], "vertical": true, "font_size": 16, "lines_coords": [[[234.0, 970.0], [250.0, 970.0], [250.0, 1064.0], [234.0, 1064.0]], [[213.0, 970.0], [229.0, 970.0], [229.0, 1122.0], [213.0, 1122.0]], [[190.0, 970.0], [207.0, 970.0], [207.0, 1108.0], [190.0, 1108.0]], [[171.0, 969.0], [187.0, 969.0], [187.0, 1071.0], [171.0, 1071.0]], [[151.0, 967.0], [167.0, 967.0], [167.0, 1089.0], [151.0, 1089.0]]], "lines": ["「僕たちが音", "ＥＢＪって呼んでた", "エロビテオ上映会", "あれ正しくは", "ＥＶＪだよね。」"]}], "img_path": "245.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [599, 86, 699, 242], "vertical": true, "font_size": 17, "lines_coords": [[[682.0, 89.0], [699.0, 89.0], [699.0, 175.0], [682.0, 175.0]], [[659.0, 87.0], [679.0, 87.0], [679.0, 234.0], [659.0, 234.0]], [[640.0, 90.0], [657.0, 90.0], [657.0, 241.0], [640.0, 241.0]], [[618.0, 86.0], [634.0, 86.0], [634.0, 212.0], [618.0, 212.0]], [[599.0, 89.0], [615.0, 89.0], [615.0, 182.0], [599.0, 182.0]]], "lines": ["．．．僕が内心", "「そんな事をずっと", "気にしてたのかよ。」", "と思っていると、", "彼は続けて！"]}, {"box": [128, 394, 214, 551], "vertical": true, "font_size": 21, "lines_coords": [[[187.0, 396.0], [212.0, 394.0], [214.0, 464.0], [189.0, 465.0]], [[171.0, 396.0], [190.0, 396.0], [190.0, 500.0], [171.0, 500.0]], [[149.0, 397.0], [169.0, 397.0], [169.0, 471.0], [149.0, 471.0]], [[128.0, 396.0], [148.0, 396.0], [148.0, 551.0], [128.0, 551.0]]], "lines": ["「．．．あと、", "君が転校して", "いった時、", "すごく寂しかった。」"]}], "img_path": "246.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [435, 70, 503, 192], "vertical": true, "font_size": 19, "lines_coords": [[[481.0, 70.0], [502.0, 70.0], [503.0, 152.0], [482.0, 152.0]], [[459.0, 70.0], [479.0, 70.0], [479.0, 183.0], [459.0, 183.0]], [[436.0, 71.0], [453.0, 71.0], [453.0, 191.0], [436.0, 191.0]]], "lines": ["．．．それは、", "僕だって同じ", "気持ちだった。"]}, {"box": [152, 324, 256, 520], "vertical": true, "font_size": 17, "lines_coords": [[[235.0, 324.0], [256.0, 324.0], [256.0, 385.0], [235.0, 385.0]], [[215.0, 324.0], [231.0, 324.0], [231.0, 461.0], [215.0, 461.0]], [[195.0, 324.0], [212.0, 324.0], [212.0, 469.0], [195.0, 469.0]], [[174.0, 325.0], [190.0, 325.0], [190.0, 496.0], [174.0, 496.0]], [[153.0, 324.0], [169.0, 324.0], [168.0, 520.0], [152.0, 520.0]]], "lines": ["．．．でも、", "そんな事を言った", "ところで、あの頃の", "僕達にはどうする事も", "できなかったじゃないか。"]}, {"box": [428, 745, 454, 846], "vertical": true, "font_size": 25, "lines_coords": [[[428.0, 745.0], [453.0, 745.0], [453.0, 846.0], [428.0, 846.0]]], "lines": ["おーい。"]}], "img_path": "247.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [619, 52, 686, 169], "vertical": true, "font_size": 19, "lines_coords": [[[665.0, 53.0], [686.0, 53.0], [686.0, 132.0], [665.0, 132.0]], [[640.0, 52.0], [660.0, 52.0], [663.0, 169.0], [643.0, 169.0]], [[619.0, 56.0], [636.0, 56.0], [636.0, 140.0], [619.0, 140.0]]], "lines": ["．．．勝手に", "うろつくなよ", "馬鹿やろー"]}, {"box": [441, 703, 503, 895], "vertical": true, "font_size": 20, "lines_coords": [[[485.0, 726.0], [502.0, 726.0], [502.0, 760.0], [485.0, 760.0]], [[463.0, 816.0], [485.0, 816.0], [485.0, 892.0], [463.0, 892.0]], [[441.0, 814.0], [461.0, 814.0], [461.0, 895.0], [441.0, 895.0]]], "lines": ["え？", "小学校の", "同級生？"]}, {"box": [311, 672, 354, 788], "vertical": true, "font_size": 18, "lines_coords": [[[335.0, 672.0], [354.0, 672.0], [354.0, 751.0], [335.0, 751.0]], [[311.0, 673.0], [328.0, 673.0], [328.0, 786.0], [311.0, 786.0]]], "lines": ["．．．ホラ！！", "もう行くよ！！"]}, {"box": [646, 958, 725, 1112], "vertical": true, "font_size": 16, "lines_coords": [[[708.0, 960.0], [725.0, 960.0], [725.0, 1062.0], [708.0, 1062.0]], [[688.0, 960.0], [704.0, 960.0], [704.0, 1112.0], [688.0, 1112.0]], [[666.0, 958.0], [682.0, 958.0], [684.0, 1112.0], [667.0, 1112.0]], [[647.0, 959.0], [663.0, 959.0], [663.0, 1112.0], [647.0, 1112.0]]], "lines": ["．．．わかった！！", "小五の時に女の子と", "半日だけ付き合って", "フラれた子でしょ？"]}, {"box": [454, 1074, 479, 1136], "vertical": true, "font_size": 25, "lines_coords": [[[454.0, 1074.0], [479.0, 1074.0], [479.0, 1136.0], [454.0, 1136.0]]], "lines": ["え．．．．．"]}, {"box": [115, 1003, 183, 1128], "vertical": true, "font_size": 22, "lines_coords": [[[158.0, 1003.0], [183.0, 1003.0], [183.0, 1066.0], [158.0, 1066.0]], [[137.0, 1003.0], [160.0, 1003.0], [158.0, 1128.0], [134.0, 1128.0]], [[115.0, 1005.0], [132.0, 1005.0], [132.0, 1119.0], [115.0, 1119.0]]], "lines": ["みんな", "君の事捜して", "たんだから！！"]}], "img_path": "248.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [668, 49, 736, 205], "vertical": true, "font_size": 19, "lines_coords": [[[714.0, 50.0], [735.0, 50.0], [735.0, 155.0], [714.0, 155.0]], [[692.0, 50.0], [708.0, 50.0], [708.0, 205.0], [692.0, 205.0]], [[668.0, 49.0], [688.0, 49.0], [688.0, 132.0], [668.0, 132.0]]], "lines": ["別れ際、僕が", "「結婚してたんだ」", "と聞くと、"]}, {"box": [401, 275, 515, 456], "vertical": true, "font_size": 19, "lines_coords": [[[495.0, 276.0], [515.0, 276.0], [515.0, 373.0], [495.0, 373.0]], [[470.0, 276.0], [490.0, 276.0], [490.0, 428.0], [470.0, 428.0]], [[445.0, 275.0], [468.0, 275.0], [468.0, 393.0], [445.0, 393.0]], [[425.0, 277.0], [441.0, 277.0], [441.0, 428.0], [425.0, 428.0]], [[401.0, 277.0], [418.0, 277.0], [418.0, 454.0], [401.0, 454.0]]], "lines": ["彼は表情で", "それとなくそれを", "否定し、僕も", "それ以上詮索する", "気にはならなかった。"]}, {"box": [140, 310, 231, 445], "vertical": true, "font_size": 19, "lines_coords": [[[209.0, 310.0], [229.0, 310.0], [229.0, 406.0], [209.0, 406.0]], [[187.0, 311.0], [207.0, 311.0], [207.0, 394.0], [187.0, 394.0]], [[162.0, 311.0], [182.0, 311.0], [182.0, 445.0], [162.0, 445.0]], [[140.0, 311.0], [156.0, 311.0], [156.0, 433.0], [140.0, 433.0]]], "lines": ["左目の傷に", "関しても、", "特に聞く必要は", "ないと思った。"]}, {"box": [101, 630, 260, 675], "vertical": false, "font_size": 12, "lines_coords": [[[103.0, 643.0], [192.0, 648.0], [192.0, 660.0], [103.0, 656.0]]], "lines": ["そんなことはないんですが、"]}, {"box": [181, 718, 264, 836], "vertical": true, "font_size": 25, "lines_coords": [[[240.0, 720.0], [264.0, 720.0], [264.0, 812.0], [240.0, 812.0]], [[208.0, 718.0], [233.0, 718.0], [235.0, 812.0], [210.0, 812.0]], [[181.0, 719.0], [207.0, 719.0], [207.0, 776.0], [181.0, 776.0]]], "lines": ["．．．だって", "君と僕は", "もう"]}], "img_path": "249.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "250.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "251.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "252.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [451, 430, 483, 480], "vertical": true, "font_size": 15, "lines_coords": [[[467.0, 430.0], [483.0, 430.0], [483.0, 480.0], [467.0, 480.0]], [[451.0, 430.0], [467.0, 430.0], [467.0, 478.0], [451.0, 478.0]]], "lines": ["歩行者", "目転車"]}, {"box": [461, 483, 475, 508], "vertical": true, "font_size": 15, "lines_coords": [[[461.0, 483.0], [475.0, 483.0], [475.0, 508.0], [461.0, 508.0]]], "lines": ["ッ用"]}, {"box": [434, 529, 536, 541], "vertical": false, "font_size": 14, "lines_coords": [[[434.0, 527.0], [536.0, 527.0], [536.0, 543.0], [434.0, 543.0]]], "lines": ["それからおまえもやりましたが、"]}], "img_path": "253.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "254.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "255.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "256.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [640, 89, 711, 198], "vertical": true, "font_size": 22, "lines_coords": [[[686.0, 89.0], [711.0, 89.0], [711.0, 153.0], [686.0, 153.0]], [[664.0, 91.0], [684.0, 91.0], [684.0, 198.0], [664.0, 198.0]], [[640.0, 92.0], [660.0, 92.0], [660.0, 194.0], [640.0, 194.0]]], "lines": ["．．．僕は", "「またね。」と", "言いながら、"]}, {"box": [91, 192, 182, 372], "vertical": true, "font_size": 19, "lines_coords": [[[162.0, 193.0], [182.0, 193.0], [182.0, 289.0], [162.0, 289.0]], [[138.0, 193.0], [158.0, 193.0], [158.0, 326.0], [138.0, 326.0]], [[115.0, 193.0], [132.0, 193.0], [132.0, 324.0], [115.0, 324.0]], [[91.0, 192.0], [108.0, 192.0], [110.0, 370.0], [92.0, 370.0]]], "lines": ["きっともう", "二度と会う事は", "ないんだろうと", "頭の隅で考えていた。"]}, {"box": [248, 875, 315, 1047], "vertical": true, "font_size": 18, "lines_coords": [[[294.0, 875.0], [313.0, 875.0], [315.0, 1042.0], [295.0, 1042.0]], [[270.0, 876.0], [290.0, 876.0], [290.0, 1047.0], [270.0, 1047.0]], [[248.0, 875.0], [264.0, 875.0], [264.0, 1031.0], [248.0, 1031.0]]], "lines": ["結局僕は最後まで、", "彼の名前を思い出す", "事はてきなかった。"]}], "img_path": "257.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [659, 85, 679, 193], "vertical": true, "font_size": 22, "lines_coords": [[[659.0, 85.0], [679.0, 85.0], [679.0, 193.0], [659.0, 193.0]]], "lines": ["俊太郎ってさ、"]}, {"box": [574, 208, 638, 300], "vertical": true, "font_size": 22, "lines_coords": [[[617.0, 210.0], [638.0, 210.0], [638.0, 300.0], [617.0, 300.0]], [[597.0, 210.0], [617.0, 210.0], [617.0, 300.0], [597.0, 300.0]], [[574.0, 208.0], [599.0, 208.0], [599.0, 258.0], [574.0, 258.0]]], "lines": ["会話に一瞬", "間があるん", "だよ。"]}, {"box": [173, 401, 233, 506], "vertical": true, "font_size": 17, "lines_coords": [[[213.0, 401.0], [233.0, 401.0], [233.0, 473.0], [213.0, 473.0]], [[193.0, 403.0], [209.0, 403.0], [209.0, 506.0], [193.0, 506.0]], [[173.0, 403.0], [189.0, 403.0], [189.0, 506.0], [173.0, 506.0]]], "lines": ["．．．本当は", "腹の底で何を", "考えてるの？"]}, {"box": [647, 956, 690, 1030], "vertical": true, "font_size": 18, "lines_coords": [[[667.0, 958.0], [690.0, 958.0], [690.0, 1012.0], [667.0, 1012.0]], [[647.0, 956.0], [668.0, 956.0], [668.0, 1030.0], [647.0, 1030.0]]], "lines": ["つまり", "それは．．．"]}, {"box": [521, 997, 599, 1117], "vertical": true, "font_size": 18, "lines_coords": [[[583.0, 998.0], [599.0, 998.0], [599.0, 1083.0], [583.0, 1083.0]], [[563.0, 998.0], [578.0, 998.0], [578.0, 1117.0], [563.0, 1117.0]], [[541.0, 997.0], [557.0, 997.0], [558.0, 1117.0], [542.0, 1117.0]], [[521.0, 998.0], [538.0, 998.0], [538.0, 1051.0], [521.0, 1051.0]]], "lines": ["僕の本心を", "君が受け入れる", "覚悟があるって", "こと？"]}, {"box": [137, 1026, 161, 1107], "vertical": true, "font_size": 24, "lines_coords": [[[137.0, 1026.0], [161.0, 1026.0], [161.0, 1107.0], [137.0, 1107.0]]], "lines": ["きっ．．．"]}], "img_path": "258.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [697, 86, 733, 172], "vertical": true, "font_size": 18, "lines_coords": [[[713.0, 86.0], [733.0, 86.0], [733.0, 157.0], [713.0, 157.0]], [[697.0, 89.0], [709.0, 89.0], [709.0, 172.0], [697.0, 172.0]]], "lines": ["聞がない", "ほうか〜．．．"]}, {"box": [606, 188, 686, 312], "vertical": true, "font_size": 18, "lines_coords": [[[666.0, 191.0], [686.0, 191.0], [686.0, 262.0], [666.0, 262.0]], [[646.0, 191.0], [666.0, 191.0], [666.0, 278.0], [646.0, 278.0]], [[623.0, 188.0], [643.0, 188.0], [645.0, 312.0], [625.0, 312.0]], [[606.0, 192.0], [623.0, 192.0], [623.0, 277.0], [606.0, 277.0]]], "lines": ["いい事も", "あるって事", "くらいわかって", "るけどっ．．．"]}, {"box": [220, 82, 264, 176], "vertical": true, "font_size": 19, "lines_coords": [[[241.0, 82.0], [264.0, 82.0], [264.0, 124.0], [241.0, 124.0]], [[220.0, 82.0], [240.0, 82.0], [242.0, 176.0], [222.0, 176.0]]], "lines": ["でも", "おたしはっ、"]}, {"box": [152, 228, 230, 332], "vertical": true, "font_size": 19, "lines_coords": [[[214.0, 229.0], [230.0, 229.0], [230.0, 315.0], [214.0, 315.0]], [[190.0, 228.0], [213.0, 228.0], [213.0, 284.0], [190.0, 284.0]], [[173.0, 229.0], [189.0, 229.0], [189.0, 317.0], [173.0, 317.0]], [[152.0, 229.0], [168.0, 229.0], [168.0, 332.0], [152.0, 332.0]]], "lines": ["高橋さんの", "横暴が", "どーしても", "許せない．．．！！"]}, {"box": [702, 458, 723, 535], "vertical": true, "font_size": 21, "lines_coords": [[[702.0, 458.0], [723.0, 458.0], [723.0, 535.0], [702.0, 535.0]]], "lines": ["．．．はっ！？"]}, {"box": [272, 448, 319, 527], "vertical": true, "font_size": 20, "lines_coords": [[[294.0, 448.0], [319.0, 448.0], [319.0, 510.0], [294.0, 510.0]], [[272.0, 448.0], [292.0, 448.0], [292.0, 527.0], [272.0, 527.0]]], "lines": ["なんだ", "そりゃ！？"]}, {"box": [155, 492, 221, 588], "vertical": true, "font_size": 20, "lines_coords": [[[205.0, 492.0], [221.0, 492.0], [221.0, 588.0], [205.0, 588.0]], [[179.0, 493.0], [199.0, 493.0], [199.0, 588.0], [179.0, 588.0]], [[155.0, 492.0], [175.0, 492.0], [175.0, 569.0], [155.0, 569.0]]], "lines": ["まだその話", "ひきずって", "たのっ！？"]}, {"box": [460, 700, 521, 788], "vertical": true, "font_size": 19, "lines_coords": [[[499.0, 700.0], [518.0, 700.0], [521.0, 788.0], [501.0, 788.0]], [[479.0, 701.0], [499.0, 701.0], [499.0, 788.0], [479.0, 788.0]], [[460.0, 703.0], [476.0, 703.0], [476.0, 771.0], [460.0, 771.0]]], "lines": ["．．．俺だって", "ムカついて", "るよ．．．．．"]}, {"box": [370, 829, 451, 915], "vertical": true, "font_size": 19, "lines_coords": [[[433.0, 830.0], [451.0, 830.0], [451.0, 884.0], [433.0, 884.0]], [