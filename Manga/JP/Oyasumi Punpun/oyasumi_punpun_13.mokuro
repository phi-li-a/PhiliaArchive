／ｗｗｗｉｋｉｒｃｏｒ）ｅメールｉｐｃ＿ｎｆｏ＠ｅｒｉｃａｔｐ．ＴＥＬＯＳ３０Ｌ－２８２", "●本書の電子データ化等の無情報製は著作権法上での例外を除き禁じられています。", "代行業者等の第三者による本書の電子書籍の電子供達も認められておりません。"]}], "img_path": "274.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [133, 840, 178, 884], "vertical": false, "font_size": 33, "lines_coords": [[[133.0, 857.0], [159.0, 840.0], [178.0, 867.0], [151.0, 884.0]]], "lines": ["芹香っ"]}, {"box": [120, 815, 194, 916], "vertical": true, "font_size": 27.0, "lines_coords": [[[165.0, 815.0], [194.0, 815.0], [194.0, 916.0], [165.0, 916.0]], [[120.0, 815.0], [145.0, 815.0], [145.0, 911.0], [120.0, 911.0]]], "lines": ["名名行", "書著発"]}, {"box": [210, 805, 459, 877], "vertical": false, "font_size": 34.5, "lines_coords": [[[210.0, 813.0], [458.0, 805.0], [459.0, 846.0], [212.0, 854.0]], [[214.0, 849.0], [336.0, 849.0], [336.0, 877.0], [214.0, 877.0]]], "lines": ["おやすみプンプン１８準眠いにょ", "浅野いにお"]}, {"box": [216, 888, 381, 908], "vertical": false, "font_size": 20, "lines_coords": [[[216.0, 888.0], [381.0, 888.0], [381.0, 908.0], [216.0, 908.0]]], "lines": ["株式会社小学館"]}, {"box": [124, 994, 570, 1018], "vertical": false, "font_size": 24, "lines_coords": [[[124.0, 994.0], [570.0, 994.0], [570.0, 1018.0], [124.0, 1018.0]]], "lines": ["電子書籍制作会社株式会社昭和ブライト"]}, {"box": [220, 919, 718, 946], "vertical": false, "font_size": 27, "lines_coords": [[[220.0, 919.0], [718.0, 919.0], [718.0, 946.0], [220.0, 946.0]]], "lines": ["〒１０１－８０１東京都千代田区一ツ橋２・３－１"]}], "img_path": "275.png"}]}