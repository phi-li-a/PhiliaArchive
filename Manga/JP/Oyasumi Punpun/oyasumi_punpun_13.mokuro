], [625.0, 776.0]], [[602.0, 683.0], [618.0, 683.0], [618.0, 793.0], [602.0, 793.0]]], "lines": ["こうなった", "のは全部．．．"]}, {"box": [148, 935, 193, 1050], "vertical": true, "font_size": 20, "lines_coords": [[[173.0, 937.0], [193.0, 937.0], [193.0, 1050.0], [173.0, 1050.0]], [[148.0, 935.0], [169.0, 935.0], [172.0, 1033.0], [151.0, 1033.0]]], "lines": ["あんたのせい", "でしょ．．．"]}], "img_path": "050.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [449, 45, 496, 186], "vertical": true, "font_size": 22, "lines_coords": [[[470.0, 45.0], [496.0, 45.0], [496.0, 118.0], [470.0, 118.0]], [[449.0, 46.0], [469.0, 46.0], [469.0, 186.0], [449.0, 186.0]]], "lines": ["「．．．約束", "したじゃないか。"]}, {"box": [377, 45, 424, 142], "vertical": true, "font_size": 22, "lines_coords": [[[400.0, 45.0], [421.0, 45.0], [424.0, 142.0], [402.0, 142.0]], [[377.0, 46.0], [398.0, 46.0], [400.0, 141.0], [379.0, 141.0]]], "lines": ["絶対に君を", "守るって。」"]}, {"box": [424, 974, 450, 1123], "vertical": true, "font_size": 23, "lines_coords": [[[425.0, 980.0], [448.0, 980.0], [448.0, 1120.0], [425.0, 1120.0]]], "lines": ["僕を信じて。」"]}], "img_path": "051.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [673, 348, 707, 398], "vertical": true, "font_size": 28, "lines_coords": [[[673.0, 348.0], [707.0, 348.0], [707.0, 398.0], [673.0, 398.0]]], "lines": ["フッ"]}, {"box": [631, 385, 654, 426], "vertical": true, "font_size": 28, "lines_coords": [[[631.0, 385.0], [654.0, 385.0], [654.0, 426.0], [631.0, 426.0]]], "lines": ["フッ"]}, {"box": [227, 598, 254, 642], "vertical": true, "font_size": 27, "lines_coords": [[[227.0, 598.0], [254.0, 598.0], [254.0, 642.0], [227.0, 642.0]]], "lines": ["フッ"]}, {"box": [124, 742, 152, 789], "vertical": true, "font_size": 23, "lines_coords": [[[124.0, 742.0], [152.0, 742.0], [152.0, 789.0], [124.0, 789.0]]], "lines": ["フッ"]}, {"box": [99, 805, 117, 853], "vertical": true, "font_size": 23, "lines_coords": [[[99.0, 805.0], [117.0, 805.0], [117.0, 853.0], [99.0, 853.0]]], "lines": ["フッ．．．"]}], "img_path": "052.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [589, 343, 694, 430], "vertical": true, "font_size": 18, "lines_coords": [[[673.0, 343.0], [694.0, 343.0], [694.0, 411.0], [673.0, 411.0]], [[653.0, 344.0], [670.0, 344.0], [670.0, 430.0], [653.0, 430.0]], [[632.0, 343.0], [649.0, 343.0], [649.0, 428.0], [632.0, 428.0]], [[611.0, 344.0], [627.0, 344.0], [627.0, 428.0], [611.0, 428.0]], [[589.0, 344.0], [610.0, 344.0], [610.0, 389.0], [589.0, 389.0]]], "lines": ["「．．．ああ、", "君は本当に", "どこまでも", "資馬鹿だな", "．．．．．．"]}, {"box": [520, 543, 543, 680], "vertical": true, "font_size": 23, "lines_coords": [[[520.0, 543.0], [543.0, 543.0], [543.0, 680.0], [520.0, 680.0]]], "lines": ["「．．．でもいいよ。"]}, {"box": [384, 544, 541, 680], "vertical": true, "font_size": 24, "lines_coords": [[[407.0, 548.0], [431.0, 548.0], [431.0, 666.0], [407.0, 666.0]]], "lines": ["すごくいいよ"]}, {"box": [383, 548, 430, 665], "vertical": true, "font_size": 20, "lines_coords": [[[383.0, 548.0], [402.0, 548.0], [405.0, 664.0], [385.0, 664.0]]], "lines": ["愛子ちゃん。」"]}], "img_path": "053.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [673, 77, 707, 154], "vertical": true, "font_size": 34, "lines_coords": [[[673.0, 77.0], [707.0, 77.0], [707.0, 154.0], [673.0, 154.0]]], "lines": ["ハァッ"]}, {"box": [194, 98, 233, 186], "vertical": true, "font_size": 39, "lines_coords": [[[194.0, 98.0], [233.0, 98.0], [233.0, 186.0], [194.0, 186.0]]], "lines": ["ハァッ"]}, {"box": [117, 466, 141, 555], "vertical": true, "font_size": 24, "lines_coords": [[[117.0, 466.0], [141.0, 466.0], [141.0, 555.0], [117.0, 555.0]]], "lines": ["ハァッ．．．"]}, {"box": [690, 801, 716, 832], "vertical": true, "font_size": 26, "lines_coords": [[[690.0, 801.0], [716.0, 801.0], [716.0, 832.0], [690.0, 832.0]]], "lines": ["あ、"]}, {"box": [464, 609, 483, 721], "vertical": true, "font_size": 16, "lines_coords": [[[465.0, 610.0], [481.0, 610.0], [481.0, 719.0], [465.0, 719.0]]], "lines": ["「だからこそ．．．"]}, {"box": [341, 607, 474, 737], "vertical": true, "font_size": 17, "lines_coords": [[[381.0, 609.0], [401.0, 609.0], [401.0, 680.0], [381.0, 680.0]], [[363.0, 610.0], [379.0, 610.0], [379.0, 730.0], [363.0, 730.0]], [[342.0, 610.0], [357.0, 610.0], [357.0, 737.0], [342.0, 737.0]]], "lines": ["僕は君に", "救われていたの", "かもしれない．．．"]}, {"box": [216, 820, 258, 941], "vertical": true, "font_size": 18, "lines_coords": [[[238.0, 820.0], [258.0, 820.0], [258.0, 900.0], [238.0, 900.0]], [[216.0, 820.0], [236.0, 820.0], [236.0, 941.0], [216.0, 941.0]]], "lines": ["「．．．きっと", "もう少しで．．．"]}, {"box": [137, 820, 194, 939], "vertical": true, "font_size": 18, "lines_coords": [[[178.0, 821.0], [194.0, 821.0], [194.0, 923.0], [178.0, 923.0]], [[156.0, 821.0], [173.0, 821.0], [173.0, 939.0], [156.0, 939.0]], [[137.0, 820.0], [153.0, 820.0], [153.0, 905.0], [137.0, 905.0]]], "lines": ["僕達は完全に", "わかり合えると", "思うんだ。」"]}, {"box": [654, 1034, 680, 1064], "vertical": true, "font_size": 26, "lines_coords": [[[654.0, 1034.0], [680.0, 1034.0], [680.0, 1064.0], [654.0, 1064.0]]], "lines": ["あ、"]}, {"box": [610, 1071, 637, 1101], "vertical": true, "font_size": 26, "lines_coords": [[[610.0, 1071.0], [637.0, 1071.0], [637.0, 1101.0], [610.0, 1101.0]]], "lines": ["あ、"]}, {"box": [349, 1069, 373, 1132], "vertical": true, "font_size": 24, "lines_coords": [[[349.0, 1069.0], [373.0, 1069.0], [373.0, 1132.0], [349.0, 1132.0]]], "lines": ["あ．．．"]}], "img_path": "054.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [500, 151, 560, 420], "vertical": true, "font_size": 20, "lines_coords": [[[540.0, 152.0], [559.0, 152.0], [559.0, 303.0], [540.0, 303.0]], [[500.0, 151.0], [521.0, 151.0], [522.0, 420.0], [501.0, 420.0]]], "lines": ["「．．．．．．愛子ちゃん。", "君はもう何も考えなくていい。」"]}, {"box": [495, 645, 515, 752], "vertical": true, "font_size": 20, "lines_coords": [[[495.0, 645.0], [515.0, 645.0], [515.0, 752.0], [495.0, 752.0]]], "lines": ["「考えるから、"]}, {"box": [415, 645, 462, 788], "vertical": true, "font_size": 20, "lines_coords": [[[441.0, 645.0], [462.0, 645.0], [460.0, 742.0], [439.0, 742.0]], [[417.0, 645.0], [436.0, 645.0], [435.0, 788.0], [415.0, 788.0]]], "lines": ["わかり合え", "なかったんだ．．．」"]}], "img_path": "055.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [668, 545, 701, 646], "vertical": true, "font_size": 33, "lines_coords": [[[668.0, 546.0], [701.0, 546.0], [701.0, 646.0], [668.0, 646.0]]], "lines": ["んっ！！"]}, {"box": [680, 821, 709, 897], "vertical": true, "font_size": 28, "lines_coords": [[[680.0, 821.0], [709.0, 821.0], [709.0, 897.0], [680.0, 897.0]]], "lines": ["あっ．．．"]}, {"box": [183, 596, 220, 659], "vertical": true, "font_size": 38, "lines_coords": [[[183.0, 596.0], [220.0, 596.0], [220.0, 659.0], [183.0, 659.0]]], "lines": ["んっ"]}, {"box": [120, 653, 158, 755], "vertical": true, "font_size": 38, "lines_coords": [[[120.0, 653.0], [158.0, 653.0], [158.0, 755.0], [120.0, 755.0]]], "lines": ["んっ！！"]}, {"box": [645, 922, 672, 973], "vertical": true, "font_size": 28, "lines_coords": [[[645.0, 922.0], [672.0, 922.0], [672.0, 973.0], [645.0, 973.0]]], "lines": ["あ．．．"]}, {"box": [385, 1004, 426, 1106], "vertical": true, "font_size": 33, "lines_coords": [[[385.0, 1006.0], [418.0, 1004.0], [426.0, 1103.0], [393.0, 1106.0]]], "lines": ["んぁ！！"]}], "img_path": "056.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [657, 142, 685, 263], "vertical": true, "font_size": 28, "lines_coords": [[[657.0, 142.0], [685.0, 142.0], [685.0, 263.0], [657.0, 263.0]]], "lines": ["あぁっ！！"]}], "img_path": "057.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "058.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [41, 222, 83, 344], "vertical": true, "font_size": 42, "lines_coords": [[[41.0, 223.0], [83.0, 223.0], [83.0, 344.0], [41.0, 344.0]]], "lines": ["第１３８話"]}], "img_path": "059.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [637, 673, 666, 747], "vertical": true, "font_size": 29, "lines_coords": [[[637.0, 673.0], [666.0, 673.0], [666.0, 747.0], [637.0, 747.0]]], "lines": ["あ．．．"]}, {"box": [120, 1007, 161, 1112], "vertical": true, "font_size": 20, "lines_coords": [[[140.0, 1007.0], [161.0, 1007.0], [161.0, 1078.0], [140.0, 1078.0]], [[120.0, 1007.0], [140.0, 1007.0], [140.0, 1112.0], [120.0, 1112.0]]], "lines": ["この景色", "知ってる．．．"]}], "img_path": "060.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [333, 95, 378, 225], "vertical": true, "font_size": 19, "lines_coords": [[[356.0, 97.0], [377.0, 97.0], [374.0, 223.0], [353.0, 223.0]], [[333.0, 99.0], [350.0, 99.0], [350.0, 201.0], [333.0, 201.0]]], "lines": ["「．．．病院の場所", "憶えてる？」"]}, {"box": [264, 434, 345, 537], "vertical": true, "font_size": 18, "lines_coords": [[[325.0, 435.0], [345.0, 435.0], [345.0, 514.0], [325.0, 514.0]], [[304.0, 434.0], [324.0, 434.0], [324.0, 522.0], [304.0, 522.0]], [[285.0, 435.0], [302.0, 435.0], [302.0, 537.0], [285.0, 537.0]], [[264.0, 434.0], [281.0, 434.0], [281.0, 523.0], [264.0, 523.0]]], "lines": ["「もし君の", "伯父さんが", "おかしな行動", "とった時は"]}, {"box": [106, 281, 152, 359], "vertical": true, "font_size": 23, "lines_coords": [[[127.0, 281.0], [152.0, 281.0], [152.0, 343.0], [127.0, 343.0]], [[106.0, 281.0], [127.0, 281.0], [127.0, 358.0], [106.0, 358.0]]], "lines": ["なんと", "なく．．．"]}, {"box": [183, 434, 246, 571], "vertical": true, "font_size": 18, "lines_coords": [[[226.0, 434.0], [246.0, 434.0], [246.0, 522.0], [226.0, 522.0]], [[205.0, 434.0], [221.0, 434.0], [221.0, 571.0], [205.0, 571.0]], [[183.0, 435.0], [200.0, 435.0], [200.0, 544.0], [183.0, 544.0]]], "lines": ["．．．その時は", "その人の自業自得", "だからね．．．"]}], "img_path": "061.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [506, 46, 684, 290], "vertical": true, "font_size": 25, "lines_coords": [[[651.0, 60.0], [680.0, 60.0], [684.0, 222.0], [654.0, 222.0]], [[619.0, 51.0], [644.0, 51.0], [644.0, 257.0], [619.0, 257.0]], [[595.0, 50.0], [618.0, 50.0], [618.0, 256.0], [595.0, 256.0]], [[570.0, 46.0], [593.0, 46.0], [596.0, 256.0], [572.0, 256.0]], [[547.0, 46.0], [571.0, 46.0], [576.0, 230.0], [551.0, 230.0]], [[528.0, 46.0], [551.0, 46.0], [554.0, 250.0], [530.0, 250.0]], [[506.0, 46.0], [530.0, 46.0], [530.0, 290.0], [506.0, 290.0]]], "lines": ["関係者様各位", "市町村合併および村の", "再開発計画にともない、", "当院は市内へ移転致し", "ました。長年に渡り", "当院を御利用くださり", "御礼申し上げます。織原区院"]}, {"box": [651, 667, 672, 742], "vertical": true, "font_size": 19, "lines_coords": [[[651.0, 667.0], [672.0, 667.0], [672.0, 742.0], [651.0, 742.0]]], "lines": ["．．．この町、"]}, {"box": [586, 778, 647, 882], "vertical": true, "font_size": 19, "lines_coords": [[[627.0, 779.0], [647.0, 779.0], [647.0, 851.0], [627.0, 851.0]], [[609.0, 780.0], [625.0, 780.0], [625.0, 882.0], [609.0, 882.0]], [[586.0, 778.0], [606.0, 778.0], [606.0, 849.0], [586.0, 849.0]]], "lines": ["もう誰も", "住んでないの", "かな．．．"]}], "img_path": "062.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [666, 206, 734, 304], "vertical": true, "font_size": 21, "lines_coords": [[[709.0, 206.0], [734.0, 206.0], [734.0, 270.0], [709.0, 270.0]], [[688.0, 208.0], [708.0, 208.0], [708.0, 304.0], [688.0, 304.0]], [[666.0, 208.0], [685.0, 208.0], [685.0, 268.0], [666.0, 268.0]]], "lines": ["．．．もう", "蝉が鳴いて", "る．．．．．"]}, {"box": [556, 717, 597, 842], "vertical": true, "font_size": 36, "lines_coords": [[[561.0, 717.0], [597.0, 718.0], [592.0, 842.0], [556.0, 841.0]]], "lines": ["それぞれの"]}, {"box": [187, 935, 248, 1055], "vertical": true, "font_size": 17, "lines_coords": [[[228.0, 935.0], [248.0, 935.0], [248.0, 1055.0], [228.0, 1055.0]], [[208.0, 936.0], [224.0, 936.0], [224.0, 1054.0], [208.0, 1054.0]], [[187.0, 937.0], [203.0, 937.0], [203.0, 1038.0], [187.0, 1038.0]]], "lines": ["もっとのんびり", "土の中にいれば", "いいのに．．．"]}], "img_path": "063.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [402, 933, 422, 1059], "vertical": true, "font_size": 16, "lines_coords": [[[404.0, 937.0], [420.0, 937.0], [420.0, 1057.0], [404.0, 1057.0]]], "lines": ["愛子ちゃん。"]}], "img_path": "064.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [131, 141, 171, 212], "vertical": true, "font_size": 18, "lines_coords": [[[151.0, 141.0], [171.0, 141.0], [171.0, 212.0], [151.0, 212.0]], [[131.0, 142.0], [148.0, 142.0], [148.0, 195.0], [131.0, 195.0]]], "lines": ["ポロボロ", "．．．．．．"]}, {"box": [663, 500, 708, 598], "vertical": true, "font_size": 20, "lines_coords": [[[687.0, 502.0], [708.0, 502.0], [708.0, 578.0], [687.0, 578.0]], [[663.0, 500.0], [682.0, 500.0], [685.0, 598.0], [665.0, 598.0]]], "lines": ["隠れたり", "探したり．．．"]}, {"box": [269, 280, 337, 403], "vertical": true, "font_size": 21, "lines_coords": [[[316.0, 280.0], [337.0, 280.0], [337.0, 367.0], [316.0, 367.0]], [[295.0, 282.0], [311.0, 282.0], [311.0, 393.0], [295.0, 393.0]], [[269.0, 281.0], [289.0, 281.0], [289.0, 403.0], [269.0, 403.0]]], "lines": ["「向こうに", "人が住んでる", "かもしれない。"]}, {"box": [196, 278, 243, 376], "vertical": true, "font_size": 21, "lines_coords": [[[217.0, 278.0], [243.0, 278.0], [243.0, 348.0], [217.0, 348.0]], [[196.0, 280.0], [216.0, 280.0], [216.0, 376.0], [196.0, 376.0]]], "lines": ["．．．ほら、", "あれ見て。」"]}, {"box": [154, 560, 200, 677], "vertical": true, "font_size": 21, "lines_coords": [[[178.0, 561.0], [199.0, 561.0], [200.0, 657.0], [179.0, 657.0]], [[154.0, 560.0], [175.0, 560.0], [176.0, 676.0], [155.0, 676.0]]], "lines": ["おかしいね", "あたし達．．．"]}], "img_path": "065.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "066.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [695, 72, 720, 187], "vertical": true, "font_size": 21, "lines_coords": [[[698.0, 72.0], [719.0, 72.0], [716.0, 187.0], [695.0, 187.0]]], "lines": ["だんだん．．．"]}, {"box": [169, 277, 192, 416], "vertical": true, "font_size": 20, "lines_coords": [[[169.0, 278.0], [189.0, 278.0], [189.0, 408.0], [169.0, 408.0]]], "lines": ["落ちてく．．．"]}], "img_path": "067.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [654, 103, 721, 223], "vertical": true, "font_size": 19, "lines_coords": [[[700.0, 103.0], [721.0, 103.0], [721.0, 180.0], [700.0, 180.0]], [[677.0, 104.0], [697.0, 104.0], [697.0, 199.0], [677.0, 199.0]], [[654.0, 104.0], [671.0, 104.0], [671.0, 220.0], [654.0, 220.0]]], "lines": ["．．．きっと", "無理し続け", "ようとしても、"]}, {"box": [324, 71, 549, 237], "vertical": false, "font_size": 24, "lines_coords": [[[385.0, 196.0], [485.0, 152.0], [493.0, 176.0], [393.0, 220.0]]], "lines": ["いいから"]}, {"box": [131, 317, 197, 432], "vertical": true, "font_size": 19, "lines_coords": [[[175.0, 317.0], [195.0, 317.0], [195.0, 432.0], [175.0, 432.0]], [[153.0, 318.0], [173.0, 318.0], [173.0, 432.0], [153.0, 432.0]], [[131.0, 318.0], [147.0, 318.0], [147.0, 401.0], [131.0, 401.0]]], "lines": ["．．．いつか必ず", "あるべき所に", "戻るんだ"]}, {"box": [637, 567, 694, 704], "vertical": true, "font_size": 16, "lines_coords": [[[678.0, 567.0], [694.0, 567.0], [694.0, 655.0], [678.0, 655.0]], [[657.0, 568.0], [673.0, 568.0], [673.0, 704.0], [657.0, 704.0]], [[637.0, 568.0], [653.0, 568.0], [653.0, 659.0], [637.0, 659.0]]], "lines": ["．．．君はもう", "何も考えるなって", "言ったけど、"]}, {"box": [633, 819, 693, 929], "vertical": true, "font_size": 17, "lines_coords": [[[675.0, 821.0], [692.0, 821.0], [692.0, 890.0], [675.0, 890.0]], [[654.0, 820.0], [671.0, 820.0], [671.0, 924.0], [654.0, 924.0]], [[633.0, 819.0], [650.0, 819.0], [650.0, 928.0], [633.0, 928.0]]], "lines": ["君が期待", "してるよりも", "ずっとずつと、"]}, {"box": [121, 617, 201, 737], "vertical": true, "font_size": 16, "lines_coords": [[[185.0, 617.0], [201.0, 617.0], [201.0, 737.0], [185.0, 737.0]], [[164.0, 617.0], [180.0, 617.0], [180.0, 720.0], [164.0, 720.0]], [[142.0, 617.0], [159.0, 617.0], [159.0, 719.0], [142.0, 719.0]], [[121.0, 617.0], [138.0, 617.0], [138.0, 687.0], [121.0, 687.0]]], "lines": ["そう言いきれる", "君は少し強く", "なりすぎたん", "だよ．．．"]}, {"box": [132, 1010, 202, 1108], "vertical": true, "font_size": 20, "lines_coords": [[[182.0, 1013.0], [202.0, 1013.0], [202.0, 1108.0], [182.0, 1108.0]], [[159.0, 1012.0], [179.0, 1012.0], [179.0, 1091.0], [159.0, 1091.0]], [[134.0, 1010.0], [155.0, 1010.0], [153.0, 1108.0], [132.0, 1108.0]]], "lines": ["．．．あたしは", "平凡な人", "なんだ．．．"]}], "img_path": "068.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [718, 110, 756, 195], "vertical": true, "font_size": 16, "lines_coords": [[[739.0, 111.0], [755.0, 111.0], [755.0, 179.0], [739.0, 179.0]], [[718.0, 110.0], [734.0, 110.0], [734.0, 195.0], [718.0, 195.0]]], "lines": ["なんだか", "どんどん．．．"]}, {"box": [349, 91, 391, 180], "vertical": true, "font_size": 19, "lines_coords": [[[369.0, 93.0], [388.0, 93.0], [391.0, 180.0], [371.0, 180.0]], [[349.0, 91.0], [370.0, 91.0], [371.0, 168.0], [350.0, 168.0]]], "lines": ["．．．少しだけ", "休んだら、"]}, {"box": [243, 150, 303, 270], "vertical": true, "font_size": 19, "lines_coords": [[[283.0, 150.0], [303.0, 150.0], [303.0, 270.0], [283.0, 270.0]], [[264.0, 151.0], [281.0, 151.0], [281.0, 270.0], [264.0, 270.0]], [[243.0, 151.0], [260.0, 151.0], [260.0, 237.0], [243.0, 237.0]]], "lines": ["病院じゃなくて", "あたしは交番を", "探すね．．．．．．"]}, {"box": [570, 418, 629, 537], "vertical": true, "font_size": 16, "lines_coords": [[[611.0, 418.0], [627.0, 418.0], [627.0, 536.0], [611.0, 536.0]], [[591.0, 418.0], [608.0, 418.0], [608.0, 537.0], [591.0, 537.0]], [[570.0, 418.0], [585.0, 418.0], [585.0, 519.0], [570.0, 519.0]]], "lines": ["寂しい気持ちに", "なってゆくのは", "なんでかな？"]}], "img_path": "069.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [565, 587, 631, 660], "vertical": true, "font_size": 23, "lines_coords": [[[605.0, 587.0], [631.0, 587.0], [631.0, 645.0], [605.0, 645.0]], [[586.0, 588.0], [609.0, 588.0], [609.0, 644.0], [586.0, 644.0]], [[565.0, 587.0], [586.0, 587.0], [588.0, 660.0], [567.0, 660.0]]], "lines": ["ここも", "空き家", "だね．．．．．"]}, {"box": [482, 850, 533, 921], "vertical": true, "font_size": 28, "lines_coords": [[[502.0, 850.0], [533.0, 850.0], [533.0, 915.0], [502.0, 915.0]], [[482.0, 851.0], [507.0, 851.0], [507.0, 921.0], [482.0, 921.0]]], "lines": ["．．．外で", "いいよ。"]}, {"box": [671, 896, 691, 1064], "vertical": true, "font_size": 18, "lines_coords": [[[671.0, 896.0], [691.0, 896.0], [691.0, 1064.0], [671.0, 1064.0]]], "lines": ["「．．．あがって来なよ。"]}, {"box": [631, 897, 647, 1076], "vertical": true, "font_size": 18, "lines_coords": [[[631.0, 897.0], [647.0, 897.0], [647.0, 1076.0], [631.0, 1076.0]]], "lines": ["中は随分涼しいよ？」"]}, {"box": [407, 1013, 434, 1134], "vertical": true, "font_size": 24, "lines_coords": [[[411.0, 1013.0], [434.0, 1013.0], [431.0, 1130.0], [407.0, 1130.0]]], "lines": ["「．．．出頭したら"]}, {"box": [311, 1016, 371, 1119], "vertical": true, "font_size": 18, "lines_coords": [[[354.0, 1017.0], [371.0, 1017.0], [371.0, 1119.0], [354.0, 1119.0]], [[331.0, 1017.0], [352.0, 1017.0], [352.0, 1087.0], [331.0, 1087.0]], [[311.0, 1016.0], [331.0, 1016.0], [331.0, 1092.0], [311.0, 1092.0]]], "lines": ["君のした事は", "全部僕が", "被るから。"]}, {"box": [115, 881, 176, 967], "vertical": true, "font_size": 18, "lines_coords": [[[155.0, 881.0], [175.0, 881.0], [175.0, 952.0], [155.0, 952.0]], [[137.0, 882.0], [153.0, 882.0], [153.0, 967.0], [137.0, 967.0]], [[115.0, 882.0], [132.0, 882.0], [132.0, 966.0], [115.0, 966.0]]], "lines": ["住んでた", "人になんか", "悪いし．．．"]}, {"box": [208, 1016, 268, 1153], "vertical": true, "font_size": 18, "lines_coords": [[[248.0, 1016.0], [268.0, 1016.0], [268.0, 1120.0], [248.0, 1120.0]], [[229.0, 1017.0], [246.0, 1017.0], [246.0, 1153.0], [229.0, 1153.0]], [[208.0, 1017.0], [223.0, 1017.0], [223.0, 1119.0], [208.0, 1119.0]]], "lines": ["愛子ちゃんは", "何も心配しなくて", "いいんだよ。"]}, {"box": [209, 1017, 267, 1154], "vertical": true, "font_size": 58, "lines_coords": [[[209.0, 1017.0], [267.0, 1017.0], [267.0, 1154.0], [209.0, 1154.0]]], "lines": ["愛子ちゃんは何も心配しなくていいんだよ。」"]}], "img_path": "070.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [135, 39, 346, 180], "vertical": true, "font_size": 21, "lines_coords": [[[328.0, 44.0], [344.0, 44.0], [344.0, 119.0], [328.0, 119.0]], [[302.0, 41.0], [326.0, 41.0], [326.0, 117.0], [302.0, 117.0]], [[271.0, 42.0], [292.0, 42.0], [292.0, 114.0], [271.0, 114.0]], [[251.0, 42.0], [271.0, 42.0], [271.0, 180.0], [251.0, 180.0]], [[227.0, 39.0], [254.0, 39.0], [254.0, 89.0], [227.0, 89.0]], [[199.0, 42.0], [219.0, 42.0], [219.0, 113.0], [199.0, 113.0]], [[176.0, 42.0], [196.0, 42.0], [199.0, 128.0], [179.0, 128.0]], [[155.0, 39.0], [176.0, 39.0], [178.0, 164.0], [156.0, 164.0]], [[135.0, 41.0], [156.0, 41.0], [156.0, 111.0], [135.0, 111.0]]], "lines": ["自分では", "されても、", "君が外で", "待っていてくれる", "なら、", "何年でも", "何十年でも", "僕は一人で平気", "だから。」"]}], "img_path": "071.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [620, 92, 690, 191], "vertical": true, "font_size": 22, "lines_coords": [[[670.0, 94.0], [690.0, 94.0], [690.0, 191.0], [670.0, 191.0]], [[645.0, 94.0], [665.0, 94.0], [665.0, 191.0], [645.0, 191.0]], [[620.0, 92.0], [645.0, 92.0], [645.0, 160.0], [620.0, 160.0]]], "lines": ["．．．あたしは", "本当の事を", "話すよ。"]}, {"box": [158, 405, 224, 537], "vertical": true, "font_size": 16, "lines_coords": [[[205.0, 406.0], [221.0, 406.0], [221.0, 519.0], [205.0, 519.0]], [[181.0, 405.0], [197.0, 405.0], [197.0, 537.0], [181.0, 537.0]], [[158.0, 405.0], [174.0, 405.0], [174.0, 481.0], [158.0, 481.0]]], "lines": ["嘘をつくのは", "もうおしまいに", "しよう？"]}, {"box": [591, 669, 615, 798], "vertical": true, "font_size": 24, "lines_coords": [[[591.0, 670.0], [615.0, 670.0], [615.0, 798.0], [591.0, 798.0]]], "lines": ["「．．．だったら。」"]}, {"box": [331, 664, 376, 817], "vertical": true, "font_size": 20, "lines_coords": [[[354.0, 664.0], [376.0, 664.0], [373.0, 772.0], [352.0, 772.0]], [[331.0, 666.0], [351.0, 666.0], [351.0, 817.0], [331.0, 817.0]]], "lines": ["「ずっと気に", "なってたんだ．．．"]}, {"box": [154, 664, 295, 819], "vertical": true, "font_size": 20, "lines_coords": [[[274.0, 666.0], [295.0, 666.0], [295.0, 742.0], [274.0, 742.0]], [[250.0, 666.0], [270.0, 666.0], [270.0, 781.0], [250.0, 781.0]], [[227.0, 666.0], [247.0, 666.0], [247.0, 782.0], [227.0, 782.0]], [[202.0, 664.0], [222.0, 664.0], [223.0, 819.0], [203.0, 819.0]], [[178.0, 665.0], [199.0, 665.0], [200.0, 817.0], [179.0, 817.0]], [[155.0, 665.0], [175.0, 665.0], [174.0, 808.0], [154.0, 808.0]]], "lines": ["君は僕が", "自殺するのを", "止めるために", "自分が殺したって", "嘘をついたんじゃ", "ないかって．．．．．．"]}, {"box": [427, 1023, 469, 1112], "vertical": true, "font_size": 20, "lines_coords": [[[446.0, 1023.0], [467.0, 1023.0], [469.0, 1094.0], [448.0, 1094.0]], [[427.0, 1024.0], [447.0, 1024.0], [447.0, 1112.0], [427.0, 1112.0]]], "lines": ["．．．嘘じゃ", "ないよ．．．"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [614, 58, 701, 210], "vertical": true, "font_size": 18, "lines_coords": [[[682.0, 58.0], [699.0, 58.0], [699.0, 178.0], [682.0, 178.0]], [[657.0, 58.0], [677.0, 58.0], [677.0, 210.0], [657.0, 210.0]], [[634.0, 59.0], [651.0, 59.0], [651.0, 153.0], [634.0, 153.0]]], "lines": ["．．．小学生の時、", "工場の帰りに見た", "あの流れ星"]}, {"box": [629, 482, 690, 555], "vertical": true, "font_size": 21, "lines_coords": [[[668.0, 482.0], [690.0, 482.0], [690.0, 555.0], [668.0, 555.0]], [[647.0, 483.0], [668.0, 483.0], [668.0, 554.0], [647.0, 554.0]], [[629.0, 482.0], [650.0, 482.0], [650.0, 539.0], [629.0, 539.0]]], "lines": ["ちゃんと", "叶ったん", "だ．．．．．"]}, {"box": [115, 225, 205, 377], "vertical": true, "font_size": 18, "lines_coords": [[[187.0, 227.0], [203.0, 227.0], [203.0, 359.0], [187.0, 359.0]], [[162.0, 228.0], [179.0, 228.0], [179.0, 359.0], [162.0, 359.0]], [[138.0, 225.0], [158.0, 225.0], [158.0, 377.0], [138.0, 377.0]], [[115.0, 227.0], [132.0, 227.0], [132.0, 341.0], [115.0, 341.0]]], "lines": ["．．．あたしは君と", "両想いになれる", "ようにってお願い", "したんだ．．．"]}, {"box": [167, 710, 213, 769], "vertical": true, "font_size": 22, "lines_coords": [[[182.0, 710.0], [213.0, 710.0], [213.0, 769.0], [182.0, 769.0]], [[167.0, 712.0], [189.0, 712.0], [189.0, 768.0], [167.0, 768.0]]], "lines": ["すごい", "ぞ．．．"]}, {"box": [124, 832, 189, 949], "vertical": true, "font_size": 22, "lines_coords": [[[169.0, 833.0], [189.0, 833.0], [189.0, 911.0], [169.0, 911.0]], [[145.0, 832.0], [166.0, 832.0], [167.0, 949.0], [146.0, 949.0]], [[124.0, 834.0], [140.0, 834.0], [140.0, 928.0], [124.0, 928.0]]], "lines": ["．．．こんな", "幸せな事って", "あるかな？"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [698, 60, 738, 164], "vertical": true, "font_size": 19, "lines_coords": [[[716.0, 60.0], [738.0, 60.0], [738.0, 116.0], [716.0, 116.0]], [[698.0, 62.0], [714.0, 62.0], [714.0, 164.0], [698.0, 164.0]]], "lines": ["．．．また", "見れるかな？"]}, {"box": [492, 220, 552, 308], "vertical": true, "font_size": 18, "lines_coords": [[[533.0, 221.0], [552.0, 221.0], [552.0, 308.0], [533.0, 308.0]], [[514.0, 222.0], [530.0, 222.0], [530.0, 307.0], [514.0, 307.0]], [[492.0, 220.0], [511.0, 220.0], [511.0, 308.0], [492.0, 308.0]]], "lines": ["同じ場所で", "あの大きな", "天の川．．．"]}, {"box": [627, 367, 647, 467], "vertical": true, "font_size": 20, "lines_coords": [[[627.0, 367.0], [647.0, 367.0], [647.0, 467.0], [627.0, 467.0]]], "lines": ["「．．．見れるよ、"]}, {"box": [586, 370, 606, 498], "vertical": true, "font_size": 20, "lines_coords": [[[586.0, 370.0], [606.0, 370.0], [606.0, 498.0], [586.0, 498.0]]], "lines": ["いつか必ず．．．"]}, {"box": [154, 418, 176, 515], "vertical": true, "font_size": 20, "lines_coords": [[[154.0, 418.0], [174.0, 418.0], [174.0, 514.0], [154.0, 514.0]]], "lines": ["嬉しい．．．"]}, {"box": [662, 584, 720, 722], "vertical": true, "font_size": 16, "lines_coords": [[[701.0, 584.0], [718.0, 584.0], [718.0, 720.0], [701.0, 720.0]], [[682.0, 585.0], [699.0, 585.0], [699.0, 671.0], [682.0, 671.0]], [[663.0, 584.0], [678.0, 584.0], [678.0, 721.0], [663.0, 721.0]]], "lines": ["．．．もしあたし達が", "離れ離れに", "なったとしても．．．"]}, {"box": [160, 791, 219, 910], "vertical": true, "font_size": 16, "lines_coords": [[[201.0, 791.0], [217.0, 791.0], [217.0, 875.0], [201.0, 875.0]], [[181.0, 792.0], [197.0, 792.0], [197.0, 894.0], [181.0, 894.0]], [[160.0, 791.0], [176.0, 791.0], [176.0, 910.0], [160.0, 910.0]]], "lines": ["七夕の日は", "お互いの事を", "思い出そうね．．．"]}, {"box": [452, 1019, 476, 1095], "vertical": true, "font_size": 22, "lines_coords": [[[452.0, 1019.0], [476.0, 1019.0], [476.0, 1095.0], [452.0, 1095.0]]], "lines": ["「．．．うん。"]}, {"box": [397, 1021, 417, 1117], "vertical": true, "font_size": 22, "lines_coords": [[[397.0, 1021.0], [417.0, 1021.0], [417.0, 1117.0], [397.0, 1117.0]]], "lines": ["約束する。」"]}], "img_path": "075.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [656, 296, 688, 393], "vertical": true, "font_size": 32, "lines_coords": [[[656.0, 296.0], [688.0, 296.0], [688.0, 393.0], [656.0, 393.0]]], "lines": ["ふふ．．．．．．"]}], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "077.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "078.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [38, 222, 83, 346], "vertical": true, "font_size": 42, "lines_coords": [[[38.0, 223.0], [80.0, 222.0], [83.0, 345.0], [41.0, 346.0]]], "lines": ["第１３９話"]}, {"box": [593, 418, 611, 464], "vertical": true, "font_size": 18, "lines_coords": [[[593.0, 418.0], [611.0, 418.0], [611.0, 464.0], [593.0, 464.0]]], "lines": ["さまに"]}, {"box": [608, 765, 704, 841], "vertical": false, "font_size": 24, "lines_coords": [[[613.0, 768.0], [697.0, 768.0], [697.0, 789.0], [613.0, 789.0]], [[608.0, 812.0], [704.0, 812.0], [704.0, 840.0], [608.0, 840.0]]], "lines": ["７月１日", "午後２時"]}], "img_path": "079.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "080.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "081.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "082.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "083.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "084.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "085.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "086.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [632, 419, 679, 550], "vertical": true, "font_size": 22, "lines_coords": [[[656.0, 420.0], [679.0, 420.0], [679.0, 549.0], [656.0, 549.0]], [[632.0, 419.0], [653.0, 419.0], [653.0, 498.0], [632.0, 498.0]]], "lines": ["「．．．愛子ちゃん、", "行こう。」"]}], "img_path": "087.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "088.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [711, 154, 732, 288], "vertical": true, "font_size": 19, "lines_coords": [[[712.0, 154.0], [732.0, 154.0], [731.0, 288.0], [711.0, 288.0]]], "lines": ["「．．．愛子ちゃん。"]}, {"box": [664, 159, 680, 407], "vertical": true, "font_size": 19, "lines_coords": [[[664.0, 159.0], [680.0, 159.0], [680.0, 407.0], [664.0, 407.0]]], "lines": ["僕はちょっと考えていたんだ"]}, {"box": [612, 158, 632, 349], "vertical": true, "font_size": 19, "lines_coords": [[[612.0, 158.0], [632.0, 158.0], [632.0, 349.0], [612.0, 349.0]]], "lines": ["これからの生活の事。」"]}, {"box": [387, 387, 410, 526], "vertical": true, "font_size": 22, "lines_coords": [[[387.0, 387.0], [408.0, 387.0], [410.0, 525.0], [388.0, 525.0]]], "lines": ["「．．．想像してみて。"]}, {"box": [287, 385, 354, 510], "vertical": true, "font_size": 20, "lines_coords": [[[335.0, 389.0], [354.0, 389.0], [354.0, 476.0], [335.0, 476.0]], [[312.0, 387.0], [333.0, 387.0], [330.0, 510.0], [309.0, 510.0]], [[287.0, 385.0], [318.0, 385.0], [318.0, 435.0], [287.0, 435.0]]], "lines": ["楽な生活は", "できないだろう", "けど、"]}, {"box": [205, 388, 264, 545], "vertical": true, "font_size": 59, "lines_coords": [[[205.0, 388.0], [264.0, 388.0], [264.0, 545.0], [205.0, 545.0]]], "lines": ["少しだけ楽しい生活くらいならできると思うんだ。」"]}, {"box": [202, 389, 262, 543], "vertical": true, "font_size": 20, "lines_coords": [[[246.0, 390.0], [262.0, 390.0], [262.0, 509.0], [246.0, 509.0]], [[226.0, 390.0], [242.0, 390.0], [242.0, 509.0], [226.0, 509.0]], [[203.0, 389.0], [221.0, 389.0], [220.0, 543.0], [202.0, 543.0]]], "lines": ["少しだけ楽しい", "生活くらいなら", "できると思うんだ。」"]}], "img_path": "089.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [690, 98, 727, 398], "vertical": true, "font_size": 16, "lines_coords": [[[711.0, 101.0], [727.0, 101.0], [727.0, 398.0], [711.0, 398.0]], [[690.0, 98.0], [706.0, 98.0], [706.0, 356.0], [690.0, 356.0]]], "lines": ["僕が夜勤に出るために夕方頃起きると", "ちょうど君は仕事から帰ってくる"]}, {"box": [583, 97, 661, 459], "vertical": true, "font_size": 16, "lines_coords": [[[645.0, 97.0], [661.0, 97.0], [661.0, 371.0], [645.0, 371.0]], [[623.0, 97.0], [639.0, 97.0], [639.0, 459.0], [623.0, 459.0]], [[603.0, 98.0], [619.0, 98.0], [619.0, 387.0], [603.0, 387.0]], [[583.0, 97.0], [599.0, 97.0], [599.0, 455.0], [583.0, 455.0]]], "lines": ["君は仕事先の人間関係について少し", "愚痴を漏らして、それはいつもの事なのだけど、", "僕は若干苛立ちながら、それで鬱憤が", "晴れるなら、我慢は仕方ないと僕は思うんだ。」"]}, {"box": [160, 596, 566, 755], "vertical": true, "font_size": 19, "lines_coords": [[[542.0, 600.0], [562.0, 600.0], [562.0, 713.0], [542.0, 713.0]], [[522.0, 598.0], [538.0, 598.0], [538.0, 754.0], [522.0, 754.0]], [[497.0, 598.0], [517.0, 598.0], [518.0, 738.0], [499.0, 738.0]], [[477.0, 598.0], [497.0, 598.0], [497.0, 673.0], [477.0, 673.0]], [[458.0, 600.0], [477.0, 600.0], [477.0, 721.0], [458.0, 721.0]], [[439.0, 600.0], [455.0, 600.0], [455.0, 753.0], [439.0, 753.0]], [[413.0, 598.0], [439.0, 598.0], [439.0, 662.0], [413.0, 662.0]], [[386.0, 600.0], [402.0, 600.0], [402.0, 703.0], [386.0, 703.0]], [[364.0, 600.0], [384.0, 600.0], [384.0, 687.0], [364.0, 687.0]], [[344.0, 602.0], [360.0, 602.0], [360.0, 735.0], [344.0, 735.0]], [[319.0, 598.0], [345.0, 598.0], [345.0, 660.0], [319.0, 660.0]], [[288.0, 598.0], [308.0, 598.0], [308.0, 740.0], [288.0, 740.0]], [[269.0, 601.0], [285.0, 601.0], [285.0, 719.0], [269.0, 719.0]], [[244.0, 597.0], [269.0, 597.0], [269.0, 662.0], [244.0, 662.0]], [[226.0, 600.0], [243.0, 600.0], [244.0, 735.0], [227.0, 735.0]], [[207.0, 600.0], [223.0, 600.0], [223.0, 708.0], [207.0, 708.0]], [[183.0, 598.0], [203.0, 598.0], [203.0, 670.0], [183.0, 670.0]], [[164.0, 598.0], [183.0, 598.0], [183.0, 754.0], [164.0, 754.0]]], "lines": ["「それは見事に", "すれ違いの生活だし", "貯金なんてできる", "訳ないし、", "もしどちらかが", "事故にでもあったら", "大変だ。", "僕はくたびれ", "今より更に", "つまらない人間に", "なって、", "きっと君はいずれ", "僕より少し背が", "高くて、", "少し朗らかな男を", "好きになって、", "僕を捨て", "出てゆくんだろう。」"]}, {"box": [464, 1028, 621, 1143], "vertical": true, "font_size": 18, "lines_coords": [[[597.0, 1030.0], [618.0, 1030.0], [618.0, 1109.0], [597.0, 1109.0]], [[567.0, 1031.0], [583.0, 1031.0], [583.0, 1117.0], [567.0, 1117.0]], [[545.0, 1031.0], [562.0, 1031.0], [562.0, 1140.0], [545.0, 1140.0]]], "lines": ["「．．．あれ？", "ごめん全然", "楽しくないね。"]}, {"box": [462, 1029, 501, 1119], "vertical": true, "font_size": 18, "lines_coords": [[[481.0, 1030.0], [501.0, 1030.0], [501.0, 1117.0], [481.0, 1117.0]], [[462.0, 1031.0], [479.0, 1031.0], [479.0, 1116.0], [462.0, 1116.0]]], "lines": ["．．．始めから", "やり直し。」"]}], "img_path": "090.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [669, 50, 688, 173], "vertical": true, "font_size": 19, "lines_coords": [[[669.0, 50.0], [688.0, 50.0], [688.0, 173.0], [669.0, 173.0]]], "lines": ["「．．．愛子ちゃん。"]}, {"box": [670, 53, 686, 171], "vertical": true, "font_size": 18, "lines_coords": [[[670.0, 53.0], [686.0, 53.0], [686.0, 171.0], [670.0, 171.0]]], "lines": ["「．．．愛子ちゃん。"]}, {"box": [598, 53, 637, 138], "vertical": true, "font_size": 18, "lines_coords": [[[620.0, 53.0], [637.0, 53.0], [637.0, 138.0], [620.0, 138.0]], [[598.0, 53.0], [618.0, 53.0], [618.0, 130.0], [598.0, 130.0]]], "lines": ["僕は考えて", "いたんだ。"]}, {"box": [485, 52, 568, 209], "vertical": true, "font_size": 18, "lines_coords": [[[548.0, 52.0], [568.0, 52.0], [568.0, 124.0], [548.0, 124.0]], [[527.0, 52.0], [547.0, 52.0], [547.0, 179.0], [527.0, 179.0]], [[508.0, 53.0], [524.0, 53.0], [524.0, 123.0], [508.0, 123.0]], [[487.0, 52.0], [503.0, 52.0], [503.0, 207.0], [487.0, 207.0]]], "lines": ["．．．自分は", "どうしたいのか。", "もしくは", "どうされたいのか。」"]}, {"box": [486, 322, 535, 425], "vertical": true, "font_size": 17, "lines_coords": [[[514.0, 323.0], [531.0, 323.0], [534.0, 423.0], [516.0, 423.0]], [[487.0, 324.0], [503.0, 324.0], [503.0, 418.0], [487.0, 418.0]]], "lines": ["「愛子ちゃん。", "僕はね．．．．．．"]}, {"box": [452, 540, 475, 629], "vertical": true, "font_size": 20, "lines_coords": [[[454.0, 540.0], [475.0, 540.0], [473.0, 629.0], [452.0, 629.0]]], "lines": ["「．．．．．．君に"]}, {"box": [412, 541, 432, 692], "vertical": true, "font_size": 20, "lines_coords": [[[412.0, 541.0], [432.0, 541.0], [432.0, 692.0], [412.0, 692.0]]], "lines": ["殺されたかった。」"]}], "img_path": "091.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "092.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "093.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "094.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [425, 941, 452, 1120], "vertical": true, "font_size": 23, "lines_coords": [[[425.0, 948.0], [448.0, 948.0], [448.0, 1119.0], [425.0, 1119.0]]], "lines": ["「．．．馬鹿か俺は。」"]}], "img_path": "095.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "096.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "097.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "098.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [38, 221, 84, 346], "vertical": true, "font_size": 42, "lines_coords": [[[38.0, 222.0], [80.0, 221.0], [84.0, 345.0], [42.0, 346.0]]], "lines": ["第１４０話"]}], "img_path": "099.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [649, 72, 713, 185], "vertical": true, "font_size": 21, "lines_coords": [[[686.0, 72.0], [713.0, 72.0], [713.0, 116.0], [686.0, 116.0]], [[668.0, 73.0], [688.0, 73.0], [688.0, 146.0], [668.0, 146.0]], [[649.0, 73.0], [665.0, 73.0], [665.0, 182.0], [649.0, 182.0]]], "lines": ["１１９番", "緊急医療", "センターです。"]}, {"box": [461, 322, 536, 338], "vertical": false, "font_size": 12, "lines_coords": [[[461.0, 326.0], [536.0, 322.0], [536.0, 333.0], [461.0, 338.0]]], "lines": ["６０年は、おつりがで"]}, {"box": [461, 355, 559, 483], "vertical": true, "font_size": 42.0, "lines_coords": [[[515.0, 356.0], [557.0, 355.0], [559.0, 480.0], [517.0, 481.0]], [[487.0, 355.0], [533.0, 356.0], [530.0, 483.0], [485.0, 482.0]], [[461.0, 360.0], [499.0, 360.0], [499.0, 483.0], [461.0, 483.0]]], "lines": ["．．．", "．．．", "１００８"]}, {"box": [477, 516, 554, 533], "vertical": false, "font_size": 12, "lines_coords": [[[477.0, 521.0], [554.0, 516.0], [554.0, 528.0], [477.0, 533.0]]], "lines": ["そのままダイヤルですから、"]}, {"box": [132, 404, 175, 519], "vertical": true, "font_size": 20, "lines_coords": [[[155.0, 404.0], [175.0, 404.0], [175.0, 500.0], [155.0, 500.0]], [[132.0, 405.0], [152.0, 405.0], [152.0, 519.0], [132.0, 519.0]]], "lines": ["消防ですか", "救急ですか？"]}, {"box": [706, 782, 749, 869], "vertical": true, "font_size": 21, "lines_coords": [[[726.0, 782.0], [749.0, 782.0], [749.0, 822.0], [726.0, 822.0]], [[706.0, 783.0], [726.0, 783.0], [726.0, 869.0], [706.0, 869.0]]], "lines": ["．．．．．", "もしもし？"]}, {"box": [653, 901, 695, 1006], "vertical": true, "font_size": 21, "lines_coords": [[[675.0, 903.0], [695.0, 903.0], [695.0, 975.0], [675.0, 975.0]], [[656.0, 901.0], [675.0, 901.0], [673.0, 1006.0], [653.0, 1006.0]]], "lines": ["聞こえて", "ますかーー？"]}, {"box": [337, 1001, 383, 1098], "vertical": true, "font_size": 18, "lines_coords": [[[363.0, 1003.0], [383.0, 1003.0], [383.0, 1098.0], [363.0, 1098.0]], [[339.0, 1001.0], [360.0, 1001.0], [358.0, 1098.0], [337.0, 1098.0]]], "lines": ["消防ですか", "救急ですか"]}, {"box": [318, 1046, 332, 1076], "vertical": true, "font_size": 18, "lines_coords": [[[318.0, 1046.0], [332.0, 1046.0], [332.0, 1076.0], [318.0, 1076.0]]], "lines": ["！？"]}], "img_path": "100.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [287, 371, 310, 493], "vertical": true, "font_size": 20, "lines_coords": [[[287.0, 371.0], [310.0, 371.0], [310.0, 493.0], [287.0, 493.0]]], "lines": ["「．．．すみません。"]}, {"box": [235, 372, 251, 492], "vertical": true, "font_size": 20, "lines_coords": [[[235.0, 372.0], [251.0, 372.0], [251.0, 492.0], [235.0, 492.0]]], "lines": ["間違えました。」"]}], "img_path": "101.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "102.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "103.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [639, 181, 659, 269], "vertical": true, "font_size": 20, "lines_coords": [[[639.0, 181.0], [659.0, 181.0], [659.0, 268.0], [639.0, 268.0]]], "lines": ["あのっ．．．"]}, {"box": [244, 1046, 266, 1120], "vertical": true, "font_size": 21, "lines_coords": [[[244.0, 1047.0], [265.0, 1047.0], [265.0, 1117.0], [244.0, 1117.0]]], "lines": ["「やあ。」"]}], "img_path": "104.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [331, 52, 400, 141], "vertical": true, "font_size": 24, "lines_coords": [[[371.0, 53.0], [400.0, 53.0], [400.0, 97.0], [371.0, 97.0]], [[354.0, 55.0], [376.0, 55.0], [376.0, 127.0], [354.0, 127.0]], [[333.0, 52.0], [353.0, 52.0], [351.0, 140.0], [331.0, 140.0]]], "lines": ["．．．何", "してるん", "ですか．．．？"]}, {"box": [466, 495, 506, 622], "vertical": true, "font_size": 18, "lines_coords": [[[485.0, 495.0], [506.0, 495.0], [506.0, 574.0], [485.0, 574.0]], [[466.0, 495.0], [482.0, 495.0], [482.0, 619.0], [466.0, 619.0]]], "lines": ["「遠くから", "歩いてきたんだ。"]}, {"box": [369, 492, 504, 642], "vertical": true, "font_size": 20, "lines_coords": [[[388.0, 493.0], [408.0, 493.0], [411.0, 600.0], [391.0, 600.0]], [[369.0, 494.0], [388.0, 494.0], [388.0, 639.0], [369.0, 639.0]]], "lines": ["少し休ませて", "くれないかな．．．"]}, {"box": [370, 494, 410, 639], "vertical": true, "font_size": 40, "lines_coords": [[[370.0, 494.0], [410.0, 494.0], [410.0, 639.0], [370.0, 639.0]]], "lines": ["少し休ませてくれないかな．．．"]}, {"box": [658, 794, 705, 874], "vertical": true, "font_size": 26, "lines_coords": [[[680.0, 794.0], [705.0, 794.0], [705.0, 874.0], [680.0, 874.0]], [[658.0, 794.0], [684.0, 794.0], [684.0, 873.0], [658.0, 873.0]]], "lines": ["遠くから", "って．．．"]}, {"box": [152, 1021, 221, 1101], "vertical": true, "font_size": 21, "lines_coords": [[[201.0, 1023.0], [221.0, 1023.0], [221.0, 1101.0], [201.0, 1101.0]], [[178.0, 1023.0], [197.0, 1023.0], [197.0, 1101.0], [178.0, 1101.0]], [[152.0, 1021.0], [176.0, 1021.0], [176.0, 1083.0], [152.0, 1083.0]]], "lines": ["．．．なんで", "こんな所", "に．．．．．"]}], "img_path": "105.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [654, 255, 671, 333], "vertical": true, "font_size": 17, "lines_coords": [[[654.0, 255.0], [671.0, 255.0], [671.0, 331.0], [654.0, 331.0]]], "lines": ["えっと．．．"]}, {"box": [441, 26, 482, 172], "vertical": true, "font_size": 17, "lines_coords": [[[463.0, 30.0], [480.0, 30.0], [480.0, 139.0], [463.0, 139.0]]], "lines": ["「行ける所まで"]}, {"box": [440, 25, 461, 172], "vertical": true, "font_size": 19, "lines_coords": [[[440.0, 25.0], [460.0, 25.0], [461.0, 172.0], [441.0, 172.0]]], "lines": ["行ってみようって、"]}, {"box": [335, 27, 376, 132], "vertical": true, "font_size": 41, "lines_coords": [[[335.0, 27.0], [376.0, 27.0], [376.0, 132.0], [335.0, 132.0]]], "lines": ["二人で歩いて来たんだ。」"]}, {"box": [336, 29, 376, 132], "vertical": true, "font_size": 19, "lines_coords": [[[356.0, 29.0], [376.0, 29.0], [376.0, 132.0], [356.0, 132.0]], [[336.0, 29.0], [352.0, 29.0], [352.0, 113.0], [336.0, 113.0]]], "lines": ["二人で歩いて", "来たんだ。"]}, {"box": [342, 807, 400, 926], "vertical": true, "font_size": 18, "lines_coords": [[[384.0, 808.0], [400.0, 808.0], [400.0, 910.0], [384.0, 910.0]], [[363.0, 807.0], [379.0, 807.0], [379.0, 894.0], [363.0, 894.0]], [[342.0, 808.0], [358.0, 808.0], [358.0, 926.0], [342.0, 926.0]]], "lines": ["ここからだと", "片道２０分は", "かかっちゃう．．．"]}, {"box": [178, 625, 214, 713], "vertical": true, "font_size": 21, "lines_coords": [[[178.0, 625.0], [199.0, 625.0], [199.0, 713.0], [178.0, 713.0]]], "lines": ["手ぶらで？"]}, {"box": [606, 1003, 649, 1081], "vertical": true, "font_size": 20, "lines_coords": [[[629.0, 1003.0], [649.0, 1003.0], [649.0, 1081.0], [629.0, 1081.0]], [[606.0, 1003.0], [631.0, 1003.0], [631.0, 1081.0], [606.0, 1081.0]]], "lines": ["「ああ．．．", "参ったな。"]}, {"box": [544, 1004, 582, 1154], "vertical": true, "font_size": 20, "lines_coords": [[[565.0, 1004.0], [582.0, 1004.0], [582.0, 1154.0], [565.0, 1154.0]], [[544.0, 1004.0], [561.0, 1004.0], [561.0, 1113.0], [544.0, 1113.0]]], "lines": ["さっきの公衆電話の", "ところだ．．．"]}, {"box": [296, 967, 379, 1091], "vertical": true, "font_size": 18, "lines_coords": [[[359.0, 969.0], [379.0, 969.0], [377.0, 1058.0], [357.0, 1058.0]], [[337.0, 970.0], [357.0, 970.0], [357.0, 1041.0], [337.0, 1041.0]], [[319.0, 971.0], [336.0, 971.0], [336.0, 1091.0], [319.0, 1091.0]], [[296.0, 967.0], [317.0, 967.0], [317.0, 1040.0], [296.0, 1040.0]]], "lines": ["無理したら", "熱中症に", "なっちゃいます", "よ．．．．．？"]}], "img_path": "106.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [650, 16, 671, 86], "vertical": true, "font_size": 21, "lines_coords": [[[650.0, 18.0], [671.0, 18.0], [671.0, 86.0], [650.0, 86.0]]], "lines": ["「．．．君達。"]}, {"box": [451, 17, 596, 154], "vertical": true, "font_size": 17, "lines_coords": [[[577.0, 18.0], [593.0, 18.0], [593.0, 121.0], [577.0, 121.0]], [[556.0, 18.0], [572.0, 18.0], [572.0, 154.0], [556.0, 154.0]], [[533.0, 18.0], [552.0, 18.0], [552.0, 123.0], [533.0, 123.0]], [[514.0, 18.0], [530.0, 18.0], [530.0, 121.0], [514.0, 121.0]], [[493.0, 18.0], [509.0, 18.0], [509.0, 120.0], [493.0, 120.0]], [[470.0, 17.0], [490.0, 17.0], [490.0, 104.0], [470.0, 104.0]], [[452.0, 18.0], [468.0, 18.0], [468.0, 139.0], [452.0, 139.0]]], "lines": ["他の人が来て", "この子に触ったり", "話しかけたり", "しないように", "このあたりを", "見張ってて", "くれないかな。」"]}, {"box": [221, 97, 281, 308], "vertical": true, "font_size": 17, "lines_coords": [[[261.0, 97.0], [281.0, 97.0], [281.0, 181.0], [261.0, 181.0]], [[242.0, 99.0], [258.0, 99.0], [258.0, 235.0], [242.0, 235.0]], [[221.0, 98.0], [237.0, 98.0], [237.0, 308.0], [221.0, 308.0]]], "lines": ["「．．．この子、", "くたくたに疲れて", "やっとゆっくり眠れたんだ。"]}, {"box": [151, 97, 189, 234], "vertical": true, "font_size": 17, "lines_coords": [[[173.0, 98.0], [189.0, 98.0], [189.0, 234.0], [173.0, 234.0]], [[152.0, 97.0], [168.0, 97.0], [167.0, 208.0], [151.0, 208.0]]], "lines": ["起こしちゃったら", "可哀相だろ？」"]}, {"box": [215, 466, 240, 529], "vertical": true, "font_size": 25, "lines_coords": [[[215.0, 466.0], [240.0, 466.0], [240.0, 529.0], [215.0, 529.0]]], "lines": ["別に．．．"]}, {"box": [153, 566, 202, 645], "vertical": true, "font_size": 25, "lines_coords": [[[176.0, 568.0], [202.0, 568.0], [202.0, 645.0], [176.0, 645.0]], [[153.0, 566.0], [178.0, 566.0], [178.0, 644.0], [153.0, 644.0]]], "lines": ["いいです", "けど．．．"]}, {"box": [713, 928, 729, 997], "vertical": true, "font_size": 16, "lines_coords": [[[713.0, 928.0], [729.0, 928.0], [729.0, 997.0], [713.0, 997.0]]], "lines": ["あのっ！！"]}, {"box": [650, 1023, 707, 1127], "vertical": true, "font_size": 16, "lines_coords": [[[691.0, 1024.0], [707.0, 1024.0], [707.0, 1110.0], [691.0, 1110.0]], [[670.0, 1023.0], [687.0, 1023.0], [685.0, 1127.0], [667.0, 1127.0]], [[650.0, 1024.0], [666.0, 1024.0], [666.0, 1110.0], [650.0, 1110.0]]], "lines": ["そこの神社", "通り抜けると", "近道です！！"]}, {"box": [273, 1031, 292, 1151], "vertical": true, "font_size": 19, "lines_coords": [[[273.0, 1031.0], [292.0, 1031.0], [292.0, 1151.0], [273.0, 1151.0]]], "lines": ["「．．．ありがとう。"]}, {"box": [271, 1030, 291, 1150], "vertical": true, "font_size": 21, "lines_coords": [[[271.0, 1030.0], [291.0, 1030.0], [291.0, 1150.0], [271.0, 1150.0]]], "lines": ["「．．．ありがとう。"]}, {"box": [200, 1028, 243, 1150], "vertical": true, "font_size": 21, "lines_coords": [[[216.0, 1028.0], [243.0, 1028.0], [243.0, 1073.0], [216.0, 1073.0]], [[200.0, 1032.0], [216.0, 1032.0], [216.0, 1150.0], [200.0, 1150.0]]], "lines": ["君達", "お似合いだね。」"]}], "img_path": "107.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "108.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "109.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "110.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "111.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [634, 42, 690, 143], "vertical": true, "font_size": 28, "lines_coords": [[[659.0, 42.0], [690.0, 42.0], [690.0, 116.0], [659.0, 116.0]], [[634.0, 43.0], [659.0, 43.0], [659.0, 142.0], [634.0, 142.0]]], "lines": ["．．．だが", "それでも、"]}, {"box": [133, 135, 218, 251], "vertical": true, "font_size": 25, "lines_coords": [[[194.0, 138.0], [215.0, 138.0], [215.0, 251.0], [194.0, 251.0]], [[166.0, 139.0], [187.0, 139.0], [187.0, 229.0], [166.0, 229.0]], [[133.0, 135.0], [165.0, 135.0], [165.0, 199.0], [133.0, 199.0]]], "lines": ["僕は世界を", "終わらせ", "ない。"]}], "img_path": "112.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [679, 84, 740, 171], "vertical": true, "font_size": 19, "lines_coords": [[[719.0, 84.0], [740.0, 84.0], [740.0, 138.0], [719.0, 138.0]], [[700.0, 85.0], [716.0, 85.0], [716.0, 171.0], [700.0, 171.0]], [[679.0, 86.0], [698.0, 86.0], [698.0, 121.0], [679.0, 121.0]]], "lines": ["つまり", "新世界とは", "．．．．．"]}, {"box": [398, 51, 440, 155], "vertical": true, "font_size": 18, "lines_coords": [[[419.0, 51.0], [440.0, 51.0], [440.0, 130.0], [419.0, 130.0]], [[398.0, 52.0], [414.0, 52.0], [414.0, 154.0], [398.0, 154.0]]], "lines": ["．．．そして", "ありがとう。"]}, {"box": [646, 507, 727, 652], "vertical": true, "font_size": 18, "lines_coords": [[[706.0, 507.0], [727.0, 507.0], [727.0, 562.0], [706.0, 562.0]], [[687.0, 508.0], [704.0, 508.0], [704.0, 628.0], [687.0, 628.0]], [[664.0, 507.0], [680.0, 507.0], [684.0, 611.0], [667.0, 611.0]], [[646.0, 509.0], [663.0, 509.0], [663.0, 652.0], [646.0, 652.0]]], "lines": ["．．．僕は", "君達に圧倒的な", "確信を持って", "こう申し述べたい。"]}, {"box": [538, 277, 578, 398], "vertical": true, "font_size": 18, "lines_coords": [[[558.0, 277.0], [578.0, 277.0], [578.0, 398.0], [558.0, 398.0]], [[538.0, 278.0], [555.0, 278.0], [555.0, 397.0], [538.0, 397.0]]], "lines": ["ラヴァーズへの", "試練なのだ．．．"]}, {"box": [110, 285, 182, 384], "vertical": true, "font_size": 21, "lines_coords": [[[159.0, 287.0], [180.0, 287.0], [182.0, 366.0], [161.0, 366.0]], [[135.0, 287.0], [156.0, 287.0], [158.0, 384.0], [137.0, 384.0]], [[110.0, 287.0], [132.0, 285.0], [134.0, 346.0], [112.0, 348.0]]], "lines": ["愛すべき", "魔法戦士達", "よ．．．．．．"]}, {"box": [152, 734, 233, 909], "vertical": true, "font_size": 18, "lines_coords": [[[210.0, 734.0], [230.0, 734.0], [233.0, 841.0], [213.0, 841.0]], [[192.0, 735.0], [212.0, 735.0], [212.0, 909.0], [192.0, 909.0]], [[172.0, 735.0], [187.0, 735.0], [187.0, 873.0], [172.0, 873.0]], [[152.0, 737.0], [167.0, 737.0], [167.0, 847.0], [152.0, 847.0]]], "lines": ["僕達のグッド", "ヴァイブレーションは", "必ず宇宙に調和を", "刻むだろうと。"]}, {"box": [682, 967, 709, 1059], "vertical": true, "font_size": 25, "lines_coords": [[[682.0, 967.0], [709.0, 967.0], [709.0, 1059.0], [682.0, 1059.0]]], "lines": ["．．．瞬間は"]}, {"box": [572, 996, 598, 1098], "vertical": true, "font_size": 25, "lines_coords": [[[572.0, 996.0], [596.0, 996.0], [598.0, 1098.0], [575.0, 1098.0]]], "lines": ["．．．満ちた。"]}], "img_path": "113.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [141, 535, 161, 630], "vertical": true, "font_size": 20, "lines_coords": [[[141.0, 535.0], [161.0, 535.0], [161.0, 624.0], [141.0, 624.0]]], "lines": ["つまり．．．"]}, {"box": [610, 900, 700, 1034], "vertical": true, "font_size": 43, "lines_coords": [[[658.0, 900.0], [700.0, 900.0], [700.0, 1019.0], [658.0, 1019.0]], [[610.0, 901.0], [653.0, 900.0], [656.0, 1033.0], [612.0, 1034.0]]], "lines": ["我々の", "勝利だ。"]}], "img_path": "114.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "115.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "116.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "117.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "118.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [41, 222, 80, 342], "vertical": true, "font_size": 37, "lines_coords": [[[41.0, 223.0], [78.0, 222.0], [80.0, 341.0], [43.0, 342.0]]], "lines": ["第１４１話"]}], "img_path": "119.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "120.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [592, 56, 634, 167], "vertical": true, "font_size": 35, "lines_coords": [[[592.0, 58.0], [626.0, 56.0], [634.0, 165.0], [599.0, 167.0]]], "lines": ["上原弓月"]}], "img_path": "121.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [358, -1, 414, 70], "vertical": true, "font_size": 27, "lines_coords": [[[378.0, 4.0], [412.0, 3.0], [414.0, 69.0], [380.0, 70.0]], [[358.0, 0.0], [378.0, 0.0], [383.0, 57.0], [363.0, 59.0]]], "lines": ["駅前", "ｉＰｕｒｅｓｔａ．"]}, {"box": [643, 271, 661, 315], "vertical": true, "font_size": 18, "lines_coords": [[[643.0, 271.0], [661.0, 271.0], [661.0, 315.0], [643.0, 315.0]]], "lines": ["だいぶか"]}, {"box": [178, 692, 303, 848], "vertical": true, "font_size": 18, "lines_coords": [[[284.0, 694.0], [301.0, 694.0], [301.0, 796.0], [284.0, 796.0]], [[261.0, 693.0], [281.0, 693.0], [281.0, 848.0], [261.0, 848.0]], [[241.0, 693.0], [258.0, 693.0], [257.0, 814.0], [240.0, 814.0]], [[219.0, 693.0], [238.0, 693.0], [238.0, 798.0], [219.0, 798.0]], [[200.0, 694.0], [216.0, 694.0], [216.0, 781.0], [200.0, 781.0]], [[178.0, 692.0], [195.0, 692.0], [197.0, 786.0], [180.0, 786.0]]], "lines": ["若い女の子が", "携帯で必死に遅刻の", "弁解をしながら", "小走りで横を", "通り過ぎて", "ゆきました。"]}, {"box": [260, 608, 333, 626], "vertical": false, "font_size": 16, "lines_coords": [[[260.0, 608.0], [333.0, 610.0], [333.0, 626.0], [260.0, 624.0]]], "lines": ["７月７日"]}, {"box": [407, 605, 455, 631], "vertical": false, "font_size": 26, "lines_coords": [[[407.0, 605.0], [455.0, 605.0], [455.0, 631.0], [407.0, 631.0]]], "lines": ["東京"]}, {"box": [526, 609, 564, 626], "vertical": false, "font_size": 17, "lines_coords": [[[526.0, 609.0], [564.0, 609.0], [564.0, 626.0], [526.0, 626.0]]], "lines": ["晴れ"]}], "img_path": "122.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [660, 46, 698, 153], "vertical": true, "font_size": 16, "lines_coords": [[[680.0, 48.0], [697.0, 48.0], [697.0, 150.0], [680.0, 150.0]], [[660.0, 48.0], [675.0, 48.0], [675.0, 150.0], [660.0, 150.0]]], "lines": ["目的や用件に", "恐られる事は"]}, {"box": [524, 37, 588, 160], "vertical": true, "font_size": 20, "lines_coords": [[[567.0, 38.0], [588.0, 38.0], [588.0, 93.0], [567.0, 93.0]], [[545.0, 37.0], [565.0, 37.0], [563.0, 159.0], [543.0, 159.0]], [[524.0, 38.0], [544.0, 38.0], [544.0, 132.0], [524.0, 132.0]]], "lines": ["とても", "不自由な事だと", "思いました。"]}, {"box": [599, 473, 735, 558], "vertical": false, "font_size": 36, "lines_coords": [[[599.0, 525.0], [721.0, 473.0], [735.0, 506.0], [615.0, 558.0]]], "lines": ["はぁぁぁあぁあああ"]}, {"box": [473, 247, 575, 408], "vertical": true, "font_size": 18, "lines_coords": [[[555.0, 248.0], [575.0, 248.0], [575.0, 338.0], [555.0, 338.0]], [[531.0, 247.0], [551.0, 247.0], [554.0, 336.0], [534.0, 336.0]], [[516.0, 250.0], [529.0, 250.0], [529.0, 333.0], [516.0, 333.0]], [[490.0, 247.0], [510.0, 247.0], [511.0, 404.0], [492.0, 404.0]], [[473.0, 248.0], [489.0, 248.0], [489.0, 404.0], [473.0, 404.0]]], "lines": ["ただそれが、", "かろうじて", "今の自分と", "明日の自分を繋いで", "いるのかもしれない"]}, {"box": [633, 753, 650, 800], "vertical": true, "font_size": 13, "lines_coords": [[[633.0, 754.0], [646.0, 753.0], [650.0, 799.0], [637.0, 800.0]]], "lines": ["じゃあ"]}, {"box": [470, 1003, 490, 1164], "vertical": true, "font_size": 20, "lines_coords": [[[470.0, 1003.0], [490.0, 1003.0], [490.0, 1164.0], [470.0, 1164.0]]], "lines": ["ここは静かでした。"]}, {"box": [386, 1001, 491, 1166], "vertical": true, "font_size": 20, "lines_coords": [[[469.0, 1001.0], [489.0, 1001.0], [487.0, 1161.0], [467.0, 1161.0]]], "lines": ["ここは静かでした。"]}, {"box": [383, 1002, 405, 1165], "vertical": true, "font_size": 20, "lines_coords": [[[385.0, 1003.0], [405.0, 1003.0], [402.0, 1161.0], [383.0, 1161.0]]], "lines": ["とても静かでした。"]}], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [475, 455, 496, 564], "vertical": true, "font_size": 18, "lines_coords": [[[476.0, 529.0], [494.0, 529.0], [494.0, 562.0], [476.0, 562.0]]], "lines": ["一瞬"]}, {"box": [323, 457, 383, 582], "vertical": true, "font_size": 17, "lines_coords": [[[364.0, 459.0], [380.0, 459.0], [380.0, 577.0], [364.0, 577.0]], [[342.0, 457.0], [361.0, 457.0], [361.0, 562.0], [342.0, 562.0]], [[323.0, 459.0], [339.0, 459.0], [339.0, 581.0], [323.0, 581.0]]], "lines": ["誰かに呼び止め", "られたような", "気がしましたが、"]}, {"box": [315, 666, 336, 845], "vertical": true, "font_size": 16, "lines_coords": [[[316.0, 666.0], [332.0, 666.0], [332.0, 841.0], [316.0, 841.0]]], "lines": ["．．．勿論そんな訳はなく、"]}, {"box": [189, 666, 268, 877], "vertical": true, "font_size": 17, "lines_coords": [[[251.0, 667.0], [268.0, 667.0], [268.0, 812.0], [251.0, 812.0]], [[231.0, 666.0], [248.0, 666.0], [246.0, 787.0], [229.0, 787.0]], [[208.0, 666.0], [228.0, 666.0], [228.0, 771.0], [208.0, 771.0]], [[189.0, 667.0], [206.0, 667.0], [206.0, 877.0], [189.0, 877.0]]], "lines": ["むしろ、もう自分に", "名前なんて必要", "ないのだから", "いっそ忘れてしまえばいい。"]}, {"box": [125, 665, 141, 767], "vertical": true, "font_size": 17, "lines_coords": [[[125.0, 665.0], [141.0, 665.0], [141.0, 767.0], [125.0, 767.0]]], "lines": ["そんなふうに"]}, {"box": [104, 667, 144, 768], "vertical": true, "font_size": 14, "lines_coords": [[[106.0, 669.0], [120.0, 669.0], [120.0, 759.0], [106.0, 759.0]]], "lines": ["思いました。"]}], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [693, 96, 752, 284], "vertical": true, "font_size": 17, "lines_coords": [[[735.0, 97.0], [752.0, 97.0], [752.0, 244.0], [735.0, 244.0]], [[714.0, 97.0], [731.0, 97.0], [731.0, 284.0], [714.0, 284.0]], [[693.0, 96.0], [709.0, 96.0], [709.0, 269.0], [693.0, 269.0]]], "lines": ["少しの間、目を閉じ", "改札に吸い込まれてゆく", "人の波に身を委ねれば"]}, {"box": [584, 94, 665, 318], "vertical": true, "font_size": 17, "lines_coords": [[[649.0, 98.0], [665.0, 98.0], [665.0, 268.0], [649.0, 268.0]], [[627.0, 97.0], [644.0, 97.0], [644.0, 318.0], [627.0, 318.0]], [[603.0, 94.0], [623.0, 94.0], [625.0, 303.0], [605.0, 303.0]], [[584.0, 96.0], [600.0, 96.0], [602.0, 288.0], [585.0, 288.0]]], "lines": ["次に目を開けた時には", "自分がまだ何者でもなかった", "数か月前のあの時に戻って", "いるのではないだろうが、"]}, {"box": [376, 90, 411, 208], "vertical": true, "font_size": 34, "lines_coords": [[[376.0, 90.0], [410.0, 90.0], [410.0, 200.0], [376.0, 200.0]]], "lines": ["ヨッス"]}, {"box": [175, 86, 254, 295], "vertical": true, "font_size": 17, "lines_coords": [[[237.0, 86.0], [254.0, 86.0], [254.0, 237.0], [237.0, 237.0]], [[217.0, 86.0], [234.0, 86.0], [234.0, 257.0], [217.0, 257.0]], [[196.0, 87.0], [213.0, 87.0], [213.0, 273.0], [196.0, 273.0]], [[175.0, 86.0], [192.0, 86.0], [192.0, 295.0], [175.0, 295.0]]], "lines": ["二度と帰る事のない", "八畳間の薄暗い部屋と", "無意味で退屈なあの街の", "景色を懐かしく感じました。"]}, {"box": [117, 84, 154, 321], "vertical": true, "font_size": 17, "lines_coords": [[[138.0, 85.0], [154.0, 85.0], [154.0, 321.0], [138.0, 321.0]], [[118.0, 84.0], [135.0, 84.0], [134.0, 247.0], [117.0, 247.0]]], "lines": ["けれど自分が向かうべき場所は", "そこではないのです。"]}, {"box": [466, 1011, 485, 1068], "vertical": true, "font_size": 19, "lines_coords": [[[466.0, 1011.0], [485.0, 1011.0], [485.0, 1068.0], [466.0, 1068.0]]], "lines": ["．．．彼は"]}, {"box": [460, 1008, 489, 1073], "vertical": true, "font_size": 24, "lines_coords": [[[460.0, 1008.0], [489.0, 1008.0], [489.0, 1073.0], [460.0, 1073.0]]], "lines": ["．．．彼は"]}, {"box": [389, 1011, 410, 1151], "vertical": true, "font_size": 21, "lines_coords": [[[389.0, 1011.0], [410.0, 1011.0], [410.0, 1151.0], [389.0, 1151.0]]], "lines": ["今日も元気です。"]}, {"box": [387, 1011, 410, 1153], "vertical": true, "font_size": 24, "lines_coords": [[[387.0, 1011.0], [407.0, 1011.0], [410.0, 1153.0], [390.0, 1153.0]]], "lines": ["今日も元気です。"]}], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [-2, 309, 94, 421], "vertical": false, "font_size": 123, "lines_coords": [[[0.0, 298.0], [94.0, 298.0], [94.0, 432.0], [0.0, 432.0]]], "lines": ["！！"]}, {"box": [405, 558, 576, 585], "vertical": false, "font_size": 20, "lines_coords": [[[405.0, 566.0], [576.0, 558.0], [576.0, 578.0], [405.0, 585.0]]], "lines": ["取り向くように、"]}], "img_path": "126.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [487, 294, 558, 349], "vertical": false, "font_size": 14.0, "lines_coords": [[[487.0, 305.0], [526.0, 294.0], [529.0, 307.0], [492.0, 318.0]], [[495.0, 318.0], [545.0, 305.0], [549.0, 318.0], [499.0, 331.0]], [[492.0, 335.0], [555.0, 318.0], [558.0, 332.0], [495.0, 349.0]]], "lines": ["！！！", "スンマフン", "すぐっ"]}, {"box": [788, 369, 846, 410], "vertical": false, "font_size": 45, "lines_coords": [[[788.0, 365.0], [846.0, 365.0], [846.0, 414.0], [788.0, 414.0]]], "lines": ["ＦＯＲ"]}], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [180, 176, 208, 276], "vertical": true, "font_size": 26, "lines_coords": [[[180.0, 176.0], [206.0, 176.0], [206.0, 266.0], [180.0, 266.0]]], "lines": ["大和証券"]}], "img_path": "130.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [537, 182, 583, 289], "vertical": true, "font_size": 21, "lines_coords": [[[557.0, 182.0], [582.0, 183.0], [576.0, 289.0], [551.0, 288.0]], [[540.0, 196.0], [556.0, 196.0], [554.0, 273.0], [537.0, 273.0]]], "lines": ["渋谷駅前", "ＳｈｉｂｕｙａＳｔａ"]}, {"box": [604, 475, 622, 520], "vertical": true, "font_size": 18, "lines_coords": [[[604.0, 475.0], [622.0, 475.0], [622.0, 520.0], [604.0, 520.0]]], "lines": ["ふんね"]}], "img_path": "131.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [442, 600, 485, 687], "vertical": true, "font_size": 20, "lines_coords": [[[462.0, 600.0], [482.0, 600.0], [485.0, 687.0], [465.0, 687.0]], [[442.0, 600.0], [463.0, 600.0], [463.0, 673.0], [442.0, 673.0]]], "lines": ["あの場所で", "もう一度、"]}, {"box": [333, 600, 352, 695], "vertical": true, "font_size": 17, "lines_coords": [[[333.0, 601.0], [350.0, 601.0], [350.0, 692.0], [333.0, 692.0]]], "lines": ["あの星空を。"]}], "img_path": "132.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "133.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [411, 925, 438, 1089], "vertical": true, "font_size": 24, "lines_coords": [[[411.0, 925.0], [435.0, 925.0], [435.0, 1086.0], [411.0, 1086.0]]], "lines": ["「僕は．．．．．．"]}], "img_path": "134.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [486, 578, 506, 662], "vertical": true, "font_size": 20, "lines_coords": [[[486.0, 578.0], [506.0, 578.0], [506.0, 662.0], [486.0, 662.0]]], "lines": ["「．．．．．．僕は、"]}, {"box": [485, 580, 504, 662], "vertical": true, "font_size": 20, "lines_coords": [[[485.0, 580.0], [504.0, 580.0], [504.0, 662.0], [485.0, 662.0]]], "lines": ["「．．．．．僕は、"]}, {"box": [374, 578, 395, 684], "vertical": true, "font_size": 21, "lines_coords": [[[374.0, 578.0], [395.0, 578.0], [395.0, 684.0], [374.0, 684.0]]], "lines": ["強くなった。」"]}, {"box": [372, 578, 394, 685], "vertical": true, "font_size": 20, "lines_coords": [[[374.0, 578.0], [394.0, 578.0], [392.0, 685.0], [372.0, 685.0]]], "lines": ["強くなった。」"]}], "img_path": "135.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [659, 733, 720, 914], "vertical": true, "font_size": 18, "lines_coords": [[[704.0, 735.0], [720.0, 735.0], [720.0, 897.0], [704.0, 897.0]], [[681.0, 734.0], [698.0, 734.0], [699.0, 861.0], [682.0, 861.0]], [[659.0, 733.0], [679.0, 733.0], [680.0, 914.0], [660.0, 914.0]]], "lines": ["「失うものもなければ", "守るものもない。", "不安も意藤も優しさも。"]}, {"box": [599, 733, 639, 923], "vertical": true, "font_size": 18, "lines_coords": [[[618.0, 733.0], [638.0, 733.0], [639.0, 923.0], [619.0, 923.0]], [[599.0, 737.0], [616.0, 737.0], [616.0, 870.0], [599.0, 870.0]]], "lines": ["これが自分が求めていた", "理想だったんだ。」"]}, {"box": [380, 1005, 423, 1099], "vertical": true, "font_size": 20, "lines_coords": [[[402.0, 1005.0], [422.0, 1005.0], [422.0, 1083.0], [402.0, 1083.0]], [[380.0, 1005.0], [400.0, 1005.0], [402.0, 1099.0], [383.0, 1099.0]]], "lines": ["「ひとつも", "後悔はなく、"]}, {"box": [230, 1005, 333, 1145], "vertical": true, "font_size": 18, "lines_coords": [[[312.0, 1007.0], [329.0, 1007.0], [329.0, 1092.0], [312.0, 1092.0]], [[292.0, 1007.0], [309.0, 1007.0], [309.0, 1125.0], [292.0, 1125.0]], [[270.0, 1005.0], [290.0, 1005.0], [290.0, 1080.0], [270.0, 1080.0]], [[249.0, 1005.0], [270.0, 1005.0], [270.0, 1076.0], [249.0, 1076.0]], [[230.0, 1006.0], [247.0, 1006.0], [247.0, 1142.0], [230.0, 1142.0]]], "lines": ["たとえ何度", "時間が巻き戻る", "としても、", "同じ事を", "繰り返すだろう。」"]}], "img_path": "136.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [147, 56, 266, 259], "vertical": true, "font_size": 26, "lines_coords": [[[240.0, 58.0], [264.0, 58.0], [264.0, 230.0], [240.0, 230.0]], [[189.0, 58.0], [214.0, 58.0], [214.0, 244.0], [189.0, 244.0]], [[147.0, 58.0], [175.0, 58.0], [175.0, 257.0], [147.0, 257.0]]], "lines": ["「僕は．．．．．．", "やっと手に入れ", "たんだ．．．．．．"]}], "img_path": "137.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [110, 10, 385, 260], "vertical": true, "font_size": 82, "lines_coords": [[[288.0, 36.0], [372.0, 28.0], [385.0, 155.0], [301.0, 164.0]], [[294.0, 36.0], [366.0, 234.0], [294.0, 260.0], [221.0, 63.0]], [[148.0, 33.0], [222.0, 10.0], [285.0, 210.0], [212.0, 234.0]], [[110.0, 30.0], [165.0, 25.0], [185.0, 226.0], [130.0, 230.0]]], "lines": ["本当に", "し、それに対して", "なかったの", "だろうか？"]}, {"box": [605, 1051, 653, 1156], "vertical": true, "font_size": 21, "lines_coords": [[[633.0, 1055.0], [650.0, 1055.0], [650.0, 1156.0], [633.0, 1156.0]], [[605.0, 1051.0], [630.0, 1051.0], [630.0, 1114.0], [605.0, 1114.0]]], "lines": ["「こんにちは", "神様。」"]}, {"box": [63, 821, 322, 1125], "vertical": true, "font_size": 101, "lines_coords": [[[256.0, 826.0], [322.0, 839.0], [269.0, 1115.0], [203.0, 1102.0]], [[142.0, 821.0], [205.0, 828.0], [169.0, 1125.0], [107.0, 1117.0]], [[85.0, 863.0], [133.0, 868.0], [111.0, 1100.0], [63.0, 1095.0]]], "lines": ["とはいえ内心、", "そんな君を僕は", "好きですよ。"]}, {"box": [140, 822, 274, 1181], "vertical": true, "font_size": 101, "lines_coords": [[[140.0, 1168.0], [209.0, 822.0], [274.0, 835.0], [205.0, 1181.0]]], "lines": ["そういう意味があるのですが、"]}], "img_path": "138.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [610, 40, 655, 135], "vertical": true, "font_size": 24, "lines_coords": [[[633.0, 41.0], [654.0, 41.0], [652.0, 135.0], [631.0, 135.0]], [[610.0, 41.0], [636.0, 41.0], [636.0, 101.0], [610.0, 101.0]]], "lines": ["「迷いなんて", "ないよ。"]}, {"box": [436, 40, 499, 181], "vertical": true, "font_size": 17, "lines_coords": [[[480.0, 41.0], [496.0, 41.0], [496.0, 126.0], [480.0, 126.0]], [[458.0, 41.0], [477.0, 41.0], [477.0, 162.0], [458.0, 162.0]], [[436.0, 41.0], [453.0, 41.0], [453.0, 176.0], [436.0, 176.0]]], "lines": ["最後に僕が", "何をすべきかは", "明白じゃないか。」"]}, {"box": [180, 189, 226, 220], "vertical": false, "font_size": 31, "lines_coords": [[[180.0, 189.0], [226.0, 189.0], [226.0, 220.0], [180.0, 220.0]]], "lines": ["（笑）"]}, {"box": [321, 253, 590, 425], "vertical": true, "font_size": 55, "lines_coords": [[[488.0, 260.0], [559.0, 254.0], [571.0, 386.0], [500.0, 392.0]], [[426.0, 266.0], [490.0, 253.0], [521.0, 410.0], [456.0, 423.0]], [[371.0, 254.0], [417.0, 254.0], [417.0, 331.0], [371.0, 331.0]], [[328.0, 262.0], [365.0, 263.0], [359.0, 421.0], [322.0, 420.0]]], "lines": ["あの退屈", "平凡な環境に", "さあ", "早く帰ろう？？"]}, {"box": [691, 707, 766, 912], "vertical": true, "font_size": 67, "lines_coords": [[[699.0, 707.0], [766.0, 710.0], [757.0, 912.0], [691.0, 910.0]]], "lines": ["じゃあ"]}, {"box": [90, 711, 210, 922], "vertical": true, "font_size": 112, "lines_coords": [[[90.0, 716.0], [202.0, 711.0], [210.0, 917.0], [98.0, 922.0]]], "lines": ["死ね。"]}, {"box": [407, 996, 467, 1102], "vertical": true, "font_size": 29, "lines_coords": [[[439.0, 996.0], [467.0, 996.0], [467.0, 1102.0], [439.0, 1102.0]], [[410.0, 996.0], [440.0, 997.0], [438.0, 1071.0], [407.0, 1069.0]]], "lines": ["「．．．お前が", "死ね。」"]}], "img_path": "139.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "140.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [704, 185, 732, 283], "vertical": true, "font_size": 21, "lines_coords": [[[704.0, 185.0], [725.0, 185.0], [725.0, 281.0], [704.0, 281.0]]], "lines": ["雄一君．．．"]}, {"box": [41, 223, 83, 345], "vertical": true, "font_size": 39, "lines_coords": [[[41.0, 225.0], [79.0, 223.0], [83.0, 344.0], [44.0, 345.0]]], "lines": ["第１４２話"]}, {"box": [152, 635, 217, 825], "vertical": true, "font_size": 23, "lines_coords": [[[176.0, 746.0], [201.0, 746.0], [201.0, 809.0], [176.0, 809.0]], [[154.0, 745.0], [175.0, 745.0], [173.0, 825.0], [152.0, 825.0]]], "lines": ["産まれ", "そう．．．．．"]}], "img_path": "141.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [142, 936, 349, 965], "vertical": false, "font_size": 14, "lines_coords": [[[149.0, 934.0], [344.0, 937.0], [344.0, 953.0], [149.0, 950.0]], [[149.0, 948.0], [310.0, 951.0], [310.0, 967.0], [149.0, 964.0]]], "lines": ["集団自殺を殴ったカルト教師．．．（？）教祖が残した", "素晴らしいコンパクターネットの頭のメンセージ・ニヤニヤを動かされて"]}, {"box": [182, 981, 255, 994], "vertical": false, "font_size": 15, "lines_coords": [[[182.0, 979.0], [255.0, 979.0], [255.0, 996.0], [182.0, 996.0]]], "lines": ["わからないのはどうしたもの"]}, {"box": [182, 1019, 257, 1030], "vertical": false, "font_size": 13, "lines_coords": [[[182.0, 1017.0], [257.0, 1017.0], [257.0, 1032.0], [182.0, 1032.0]]], "lines": ["すべてのコメント（２）"]}, {"box": [182, 1