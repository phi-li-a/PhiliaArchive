rue, "font_size": 20, "lines_coords": [[[169.0, 137.0], [189.0, 137.0], [189.0, 209.0], [169.0, 209.0]], [[148.0, 137.0], [168.0, 137.0], [168.0, 227.0], [148.0, 227.0]], [[130.0, 139.0], [146.0, 139.0], [146.0, 257.0], [130.0, 257.0]], [[107.0, 138.0], [127.0, 138.0], [127.0, 209.0], [107.0, 209.0]]], "lines": ["そろそろ", "寝なよ．．．", "アンタがんばり", "過ぎ．．．"]}, {"box": [576, 530, 622, 692], "vertical": true, "font_size": 20, "lines_coords": [[[600.0, 533.0], [620.0, 533.0], [620.0, 629.0], [600.0, 629.0]], [[578.0, 530.0], [598.0, 530.0], [596.0, 692.0], [576.0, 692.0]]], "lines": ["続きまして", "情報ヘッドライン。"]}, {"box": [180, 703, 224, 864], "vertical": true, "font_size": 20, "lines_coords": [[[201.0, 703.0], [221.0, 703.0], [224.0, 856.0], [205.0, 856.0]], [[180.0, 705.0], [200.0, 705.0], [200.0, 862.0], [180.0, 862.0]]], "lines": ["今日のお昼までの", "主なニュースです。"]}], "img_path": "008.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [720, 106, 735, 232], "vertical": true, "font_size": 18, "lines_coords": [[[720.0, 106.0], [735.0, 106.0], [735.0, 232.0], [720.0, 232.0]]], "lines": ["「警察によると"]}, {"box": [633, 69, 719, 225], "vertical": true, "font_size": 18, "lines_coords": [[[699.0, 69.0], [719.0, 69.0], [715.0, 208.0], [695.0, 208.0]], [[678.0, 69.0], [698.0, 69.0], [698.0, 225.0], [678.0, 225.0]], [[652.0, 70.0], [672.0, 70.0], [672.0, 192.0], [652.0, 192.0]], [[633.0, 70.0], [650.0, 70.0], [650.0, 144.0], [633.0, 144.0]]], "lines": ["発見された女性は", "東京都○○市に住む", "田中光子さん！！", "とみられ、"]}, {"box": [138, 114, 262, 269], "vertical": true, "font_size": 18, "lines_coords": [[[244.0, 116.0], [261.0, 116.0], [261.0, 251.0], [244.0, 251.0]], [[223.0, 116.0], [240.0, 116.0], [240.0, 234.0], [223.0, 234.0]], [[202.0, 116.0], [219.0, 116.0], [219.0, 269.0], [202.0, 269.0]], [[180.0, 116.0], [196.0, 116.0], [196.0, 269.0], [180.0, 269.0]], [[159.0, 114.0], [176.0, 114.0], [178.0, 269.0], [160.0, 269.0]], [[138.0, 116.0], [159.0, 116.0], [159.0, 176.0], [138.0, 176.0]]], "lines": ["首に絞め痕のほか", "腹部に数か所の", "刺し傷がある事から", "殺人の可能性がある", "として調査を進めて", "います。"]}, {"box": [250, 319, 397, 419], "vertical": false, "font_size": 15.0, "lines_coords": [[[271.0, 319.0], [394.0, 326.0], [393.0, 343.0], [270.0, 336.0]], [[257.0, 333.0], [397.0, 343.0], [395.0, 359.0], [256.0, 350.0]], [[250.0, 351.0], [378.0, 358.0], [378.0, 373.0], [250.0, 366.0]], [[287.0, 369.0], [363.0, 372.0], [363.0, 385.0], [287.0, 382.0]], [[272.0, 384.0], [390.0, 391.0], [388.0, 406.0], [271.0, 399.0]], [[271.0, 400.0], [391.0, 406.0], [391.0, 419.0], [271.0, 413.0]]], "lines": ["僕は海岸の", "う、うん、んぅぅぅんっ、んっ．．．ちゅっ、", "『浦田海水浴場に", "いいんじゃん、バロンのひ「ａｌａＢｅａｃｈ", "握子監宇宙センターーー", "このように、「あなたは自分の力」なんだから、今まではなくなったの"]}, {"box": [282, 432, 339, 448], "vertical": false, "font_size": 13, "lines_coords": [[[283.0, 432.0], [339.0, 435.0], [338.0, 448.0], [282.0, 445.0]]], "lines": ["ＣａｐｅＸａｄｏｋ"]}, {"box": [253, 370, 272, 378], "vertical": false, "font_size": 8, "lines_coords": [[[253.0, 370.0], [272.0, 370.0], [272.0, 378.0], [253.0, 378.0]]], "lines": ["またの"]}, {"box": [527, 595, 666, 655], "vertical": false, "font_size": 51, "lines_coords": [[[530.0, 595.0], [666.0, 604.0], [663.0, 655.0], [527.0, 645.0]]], "lines": ["やるぱぁぁぃ"]}, {"box": [178, 642, 282, 815], "vertical": true, "font_size": 20, "lines_coords": [[[262.0, 642.0], [282.0, 642.0], [282.0, 798.0], [262.0, 798.0]], [[242.0, 643.0], [258.0, 643.0], [258.0, 778.0], [242.0, 778.0]], [[219.0, 642.0], [238.0, 642.0], [240.0, 815.0], [220.0, 815.0]], [[196.0, 642.0], [216.0, 642.0], [219.0, 798.0], [199.0, 798.0]], [[178.0, 642.0], [200.0, 642.0], [200.0, 689.0], [178.0, 689.0]]], "lines": ["なお田中さんの車が", "鹿児島県○○市の", "山道に乗り捨てられて", "いるのが見つかって", "おり、"]}, {"box": [663, 882, 736, 1043], "vertical": true, "font_size": 18, "lines_coords": [[[709.0, 882.0], [729.0, 882.0], [729.0, 1034.0], [709.0, 1034.0]], [[687.0, 883.0], [704.0, 883.0], [704.0, 1035.0], [687.0, 1035.0]], [[663.0, 883.0], [679.0, 883.0], [679.0, 1040.0], [663.0, 1040.0]]], "lines": ["娘の愛子さんがの", "行方がわからなく", "なっている事から、"]}, {"box": [141, 949, 256, 1140], "vertical": true, "font_size": 20, "lines_coords": [[[231.0, 949.0], [256.0, 949.0], [256.0, 1011.0], [231.0, 1011.0]], [[210.0, 950.0], [230.0, 950.0], [230.0, 1085.0], [210.0, 1085.0]], [[185.0, 950.0], [205.0, 950.0], [207.0, 1103.0], [187.0, 1103.0]], [[165.0, 952.0], [181.0, 952.0], [181.0, 1140.0], [165.0, 1140.0]], [[141.0, 951.0], [158.0, 951.0], [158.0, 1130.0], [141.0, 1130.0]]], "lines": ["事件に", "巻き込まれたか", "なんらかの事情を", "知っているものとみて", "捜索を始めています。"]}], "img_path": "009.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [465, 622, 509, 646], "vertical": false, "font_size": 24, "lines_coords": [[[465.0, 622.0], [509.0, 622.0], [509.0, 646.0], [465.0, 646.0]]], "lines": ["正午"]}, {"box": [309, 623, 393, 647], "vertical": false, "font_size": 17, "lines_coords": [[[335.0, 626.0], [388.0, 626.0], [388.0, 643.0], [335.0, 643.0]]], "lines": ["．．．"]}, {"box": [190, 720, 274, 828], "vertical": true, "font_size": 22, "lines_coords": [[[248.0, 720.0], [274.0, 720.0], [274.0, 798.0], [248.0, 798.0]], [[216.0, 721.0], [236.0, 721.0], [236.0, 819.0], [216.0, 819.0]], [[193.0, 721.0], [213.0, 721.0], [210.0, 826.0], [190.0, 826.0]]], "lines": ["「．．．少し、", "落ちついて", "考えよう．．．」"]}, {"box": [353, 1065, 385, 1126], "vertical": true, "font_size": 32, "lines_coords": [[[353.0, 1069.0], [385.0, 1069.0], [385.0, 1126.0], [353.0, 1126.0]]], "lines": ["．．．ん。"]}], "img_path": "010.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [693, 351, 714, 447], "vertical": true, "font_size": 21, "lines_coords": [[[693.0, 351.0], [714.0, 351.0], [714.0, 405.0], [693.0, 405.0]]], "lines": ["あのー"]}, {"box": [399, 329, 438, 433], "vertical": true, "font_size": 18, "lines_coords": [[[418.0, 329.0], [438.0, 329.0], [438.0, 399.0], [418.0, 399.0]], [[399.0, 330.0], [415.0, 330.0], [415.0, 433.0], [399.0, 433.0]]], "lines": ["．．．あはッ", "すみません！！"]}, {"box": [153, 366, 199, 488], "vertical": true, "font_size": 18, "lines_coords": [[[169.0, 366.0], [189.0, 366.0], [192.0, 488.0], [172.0, 488.0]], [[153.0, 367.0], [169.0, 367.0], [169.0, 471.0], [153.0, 471.0]]], "lines": ["「織原愛子」さん", "．．．ですよね？"]}, {"box": [672, 805, 759, 976], "vertical": true, "font_size": 19, "lines_coords": [[[731.0, 805.0], [759.0, 805.0], [759.0, 850.0], [731.0, 850.0]], [[714.0, 805.0], [734.0, 805.0], [732.0, 976.0], [712.0, 976.0]], [[694.0, 806.0], [711.0, 806.0], [711.0, 942.0], [694.0, 942.0]], [[672.0, 805.0], [688.0, 805.0], [688.0, 890.0], [672.0, 890.0]]], "lines": ["．．．俺、", "ヤンマングランプリの", "時からずっと追い", "かけてて．．"]}, {"box": [584, 902, 643, 1020], "vertical": true, "font_size": 19, "lines_coords": [[[626.0, 902.0], [643.0, 902.0], [643.0, 972.0], [626.0, 972.0]], [[604.0, 903.0], [620.0, 903.0], [620.0, 1020.0], [604.0, 1020.0]], [[584.0, 903.0], [600.0, 903.0], [600.0, 1020.0], [584.0, 1020.0]]], "lines": ["ちょっと", "店ん中じゃアレ", "だったんで．．．"]}, {"box": [220, 871, 276, 994], "vertical": true, "font_size": 17, "lines_coords": [[[254.0, 871.0], [276.0, 871.0], [276.0, 923.0], [254.0, 923.0]], [[238.0, 873.0], [255.0, 873.0], [255.0, 979.0], [238.0, 979.0]], [[220.0, 871.0], [235.0, 871.0], [235.0, 994.0], [220.0, 994.0]]], "lines": ["なんか", "ミーハーぽくて", "アレなんスけど．．．"]}, {"box": [105, 984, 216, 1139], "vertical": true, "font_size": 17, "lines_coords": [[[200.0, 987.0], [216.0, 987.0], [216.0, 1053.0], [200.0, 1053.0]], [[181.0, 984.0], [197.0, 984.0], [195.0, 1139.0], [179.0, 1139.0]], [[161.0, 987.0], [178.0, 987.0], [178.0, 1126.0], [161.0, 1126.0]], [[138.0, 986.0], [158.0, 986.0], [160.0, 1051.0], [140.0, 1051.0]], [[121.0, 987.0], [139.0, 987.0], [140.0, 1100.0], [123.0, 1100.0]], [[105.0, 987.0], [120.0, 987.0], [120.0, 1095.0], [105.0, 1095.0]]], "lines": ["．．．あっ俺、", "「チェリーズ倶楽部」の", "デビューイベントも", "最前列で", "観てたんですよ。", "憶えてません！？"]}], "img_path": "011.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [663, 46, 741, 168], "vertical": true, "font_size": 17, "lines_coords": [[[725.0, 48.0], [741.0, 48.0], [741.0, 132.0], [725.0, 132.0]], [[705.0, 49.0], [721.0, 49.0], [721.0, 151.0], [705.0, 151.0]], [[681.0, 46.0], [699.0, 46.0], [700.0, 167.0], [682.0, 167.0]], [[663.0, 49.0], [679.0, 49.0], [679.0, 168.0], [663.0, 168.0]]], "lines": ["．．．あのあの", "長期休業って", "引退って事じゃ", "ないですよね？"]}, {"box": [593, 214, 697, 353], "vertical": true, "font_size": 17, "lines_coords": [[[677.0, 214.0], [697.0, 214.0], [694.0, 321.0], [674.0, 321.0]], [[657.0, 215.0], [673.0, 215.0], [671.0, 318.0], [654.0, 318.0]], [[636.0, 216.0], [652.0, 216.0], [652.0, 336.0], [636.0, 336.0]], [[612.0, 214.0], [632.0, 214.0], [632.0, 353.0], [612.0, 353.0]], [[593.0, 216.0], [610.0, 216.0], [610.0, 319.0], [593.0, 319.0]]], "lines": ["．．．やっぱ今も", "同じ事務所の", "ゆづきっちとは", "連絡取り合ったり", "してんすか？"]}, {"box": [246, 37, 265, 107], "vertical": true, "font_size": 17, "lines_coords": [[[246.0, 37.0], [265.0, 37.0], [265.0, 107.0], [246.0, 107.0]]], "lines": ["あはは．．．"]}, {"box": [124, 58, 205, 206], "vertical": true, "font_size": 17, "lines_coords": [[[188.0, 58.0], [205.0, 58.0], [205.0, 179.0], [188.0, 179.0]], [[167.0, 59.0], [182.0, 59.0], [182.0, 187.0], [167.0, 187.0]], [[146.0, 59.0], [162.0, 59.0], [162.0, 196.0], [146.0, 196.0]], [[124.0, 58.0], [140.0, 58.0], [141.0, 206.0], [125.0, 206.0]]], "lines": ["プライベートの", "詮索は止めます。", "もちろん隣の彼氏", "の事もオフレコで．．．"]}, {"box": [664, 546, 706, 633], "vertical": true, "font_size": 20, "lines_coords": [[[685.0, 546.0], [706.0, 546.0], [706.0, 617.0], [685.0, 617.0]], [[664.0, 546.0], [684.0, 546.0], [684.0, 633.0], [664.0, 633.0]]], "lines": ["．．．なんの", "事だか．．．"]}, {"box": [107, 358, 172, 464], "vertical": true, "font_size": 22, "lines_coords": [[[147.0, 358.0], [172.0, 358.0], [172.0, 432.0], [147.0, 432.0]], [[128.0, 359.0], [148.0, 359.0], [148.0, 464.0], [128.0, 464.0]], [[107.0, 360.0], [127.0, 360.0], [127.0, 464.0], [107.0, 464.0]]], "lines": ["俺、一応", "プロファンの", "つもりだし．．．"]}, {"box": [559, 568, 599, 671], "vertical": true, "font_size": 20, "lines_coords": [[[579.0, 568.0], [599.0, 568.0], [599.0, 656.0], [579.0, 656.0]], [[559.0, 569.0], [576.0, 569.0], [576.0, 671.0], [559.0, 671.0]]], "lines": ["人違いじゃ", "ないですか？"]}, {"box": [385, 769, 429, 885], "vertical": true, "font_size": 20, "lines_coords": [[[407.0, 769.0], [428.0, 769.0], [429.0, 885.0], [408.0, 885.0]], [[385.0, 771.0], [405.0, 771.0], [405.0, 853.0], [385.0, 853.0]]], "lines": ["だってさっき", "契約書に、"]}, {"box": [107, 823, 181, 923], "vertical": true, "font_size": 25, "lines_coords": [[[152.0, 823.0], [181.0, 823.0], [181.0, 888.0], [152.0, 888.0]], [[133.0, 825.0], [153.0, 825.0], [151.0, 923.0], [131.0, 923.0]], [[107.0, 827.0], [132.0, 827.0], [132.0, 907.0], [107.0, 907.0]]], "lines": ["本名の", "「田中愛子」", "って．．．"]}, {"box": [711, 914, 735, 976], "vertical": true, "font_size": 19, "lines_coords": [[[711.0, 914.0], [735.0, 914.0], [735.0, 976.0], [711.0, 976.0]]], "lines": ["．．．え？"]}, {"box": [610, 982, 675, 1078], "vertical": true, "font_size": 19, "lines_coords": [[[656.0, 982.0], [675.0, 982.0], [675.0, 1078.0], [656.0, 1078.0]], [[632.0, 983.0], [649.0, 983.0], [649.0, 1059.0], [632.0, 1059.0]], [[610.0, 983.0], [626.0, 983.0], [626.0, 1076.0], [610.0, 1076.0]]], "lines": ["えーっ！？", "うそうそ", "うそだぁ！！"]}, {"box": [255, 980, 279, 1131], "vertical": true, "font_size": 23, "lines_coords": [[[255.0, 982.0], [278.0, 982.0], [278.0, 1128.0], [255.0, 1128.0]]], "lines": ["「いや、だから。」"]}], "img_path": "012.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [647, 119, 722, 282], "vertical": true, "font_size": 22, "lines_coords": [[[701.0, 119.0], [722.0, 119.0], [721.0, 282.0], [700.0, 282.0]], [[675.0, 119.0], [699.0, 119.0], [699.0, 242.0], [675.0, 242.0]], [[647.0, 120.0], [668.0, 120.0], [670.0, 274.0], [649.0, 274.0]]], "lines": ["「．．．どっか行けって", "言ってんだよ。", "汲めよ馬鹿野郎。」"]}, {"box": [501, 268, 554, 332], "vertical": true, "font_size": 30, "lines_coords": [[[523.0, 268.0], [554.0, 268.0], [554.0, 332.0], [523.0, 332.0]], [[501.0, 268.0], [530.0, 268.0], [530.0, 332.0], [501.0, 332.0]]], "lines": ["あたし", "ね．．．．．"]}, {"box": [511, 445, 533, 549], "vertical": true, "font_size": 22, "lines_coords": [[[511.0, 446.0], [533.0, 446.0], [533.0, 547.0], [511.0, 547.0]]], "lines": ["「．．．でももう、"]}, {"box": [352, 446, 415, 560], "vertical": true, "font_size": 21, "lines_coords": [[[394.0, 447.0], [415.0, 447.0], [415.0, 517.0], [394.0, 517.0]], [[373.0, 446.0], [394.0, 446.0], [394.0, 502.0], [373.0, 502.0]], [[352.0, 446.0], [372.0, 446.0], [372.0, 560.0], [352.0, 560.0]]], "lines": ["この島は", "駄目だ", "愛子ちゃん．．．」"]}, {"box": [125, 324, 187, 445], "vertical": true, "font_size": 17, "lines_coords": [[[169.0, 325.0], [185.0, 325.0], [185.0, 444.0], [169.0, 444.0]], [[148.0, 325.0], [164.0, 325.0], [164.0, 445.0], [148.0, 445.0]], [[125.0, 324.0], [145.0, 324.0], [145.0, 412.0], [125.0, 412.0]]], "lines": ["仕事と住むとこ", "見つけて来たん", "だよ．．．．．？"]}], "img_path": "013.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [697, 66, 722, 152], "vertical": true, "font_size": 24, "lines_coords": [[[697.0, 66.0], [722.0, 66.0], [722.0, 152.0], [697.0, 152.0]]], "lines": ["フッ！！"]}, {"box": [656, 185, 680, 256], "vertical": true, "font_size": 24, "lines_coords": [[[656.0, 185.0], [680.0, 185.0], [680.0, 256.0], [656.0, 256.0]]], "lines": ["フッ！！"]}, {"box": [135, 179, 169, 271], "vertical": true, "font_size": 34, "lines_coords": [[[135.0, 179.0], [169.0, 179.0], [169.0, 271.0], [135.0, 271.0]]], "lines": ["フッ．．．"]}], "img_path": "014.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [186, 284, 248, 482], "vertical": true, "font_size": 54, "lines_coords": [[[186.0, 284.0], [240.0, 284.0], [240.0, 482.0], [186.0, 482.0]]], "lines": ["清水ッ！！"]}, {"box": [705, 625, 750, 874], "vertical": true, "font_size": 21, "lines_coords": [[[727.0, 625.0], [750.0, 625.0], [750.0, 848.0], [727.0, 848.0]], [[705.0, 629.0], [725.0, 629.0], [725.0, 874.0], [705.0, 874.0]]], "lines": ["「．．．関くんはいつも、つも", "僕のためにって言うけど．．．"]}, {"box": [707, 630, 749, 875], "vertical": true, "font_size": 42, "lines_coords": [[[707.0, 630.0], [749.0, 630.0], [749.0, 875.0], [707.0, 875.0]]], "lines": ["「．．．関くんはいつもいっも僕のためにって言うけど．．．"]}, {"box": [641, 628, 661, 799], "vertical": true, "font_size": 21, "lines_coords": [[[641.0, 628.0], [661.0, 628.0], [661.0, 799.0], [641.0, 799.0]]], "lines": ["：結局いつも自分の"]}, {"box": [620, 629, 665, 882], "vertical": true, "font_size": 17, "lines_coords": [[[620.0, 629.0], [637.0, 629.0], [637.0, 881.0], [620.0, 881.0]]], "lines": ["ことしか考えてないんだ．．．"]}], "img_path": "015.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [645, 536, 665, 652], "vertical": true, "font_size": 20, "lines_coords": [[[645.0, 536.0], [665.0, 536.0], [665.0, 651.0], [645.0, 651.0]]], "lines": ["清水は．．．．．．？"]}, {"box": [369, 757, 434, 851], "vertical": true, "font_size": 29, "lines_coords": [[[401.0, 759.0], [432.0, 758.0], [434.0, 849.0], [404.0, 850.0]], [[369.0, 757.0], [397.0, 757.0], [397.0, 851.0], [369.0, 851.0]]], "lines": ["あんた", "も．．．．．"]}, {"box": [87, 813, 160, 969], "vertical": true, "font_size": 31, "lines_coords": [[[131.0, 815.0], [160.0, 815.0], [158.0, 937.0], [128.0, 937.0]], [[91.0, 813.0], [124.0, 813.0], [120.0, 969.0], [87.0, 969.0]]], "lines": ["さっさと", "逃げろッ！！"]}], "img_path": "016.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [700, 96, 722, 231], "vertical": true, "font_size": 20, "lines_coords": [[[700.0, 96.0], [720.0, 96.0], [720.0, 222.0], [700.0, 222.0]]], "lines": ["「うんこ神がね"]}, {"box": [619, 94, 708, 277], "vertical": true, "font_size": 20, "lines_coords": [[[644.0, 97.0], [664.0, 97.0], [661.0, 213.0], [641.0, 213.0]], [[619.0, 97.0], [640.0, 97.0], [643.0, 277.0], [622.0, 277.0]]], "lines": ["僕はなんでも", "できるんだ！！って。」"]}, {"box": [255, 90, 302, 277], "vertical": true, "font_size": 22, "lines_coords": [[[278.0, 90.0], [302.0, 90.0], [301.0, 277.0], [277.0, 277.0]], [[255.0, 96.0], [275.0, 96.0], [275.0, 239.0], [255.0, 239.0]]], "lines": ["「．．．関くんを信じたい", "とは思ってるよ。"]}, {"box": [124, 91, 197, 280], "vertical": true, "font_size": 20, "lines_coords": [[[176.0, 99.0], [193.0, 99.0], [193.0, 229.0], [176.0, 229.0]], [[152.0, 96.0], [172.0, 96.0], [172.0, 212.0], [152.0, 212.0]], [[126.0, 91.0], [151.0, 91.0], [148.0, 280.0], [124.0, 280.0]]], "lines": ["．．．でも関くんは", "僕を信じては", "くれないんだよね？」"]}, {"box": [683, 951, 725, 1085], "vertical": true, "font_size": 16, "lines_coords": [[[707.0, 952.0], [723.0, 952.0], [723.0, 1046.0], [707.0, 1046.0]], [[684.0, 952.0], [700.0, 952.0], [700.0, 1085.0], [684.0, 1085.0]]], "lines": ["信じるとか", "信じないとか．．"]}, {"box": [162, 976, 236, 1110], "vertical": true, "font_size": 20, "lines_coords": [[[206.0, 977.0], [227.0, 977.0], [227.0, 1053.0], [206.0, 1053.0]], [[183.0, 976.0], [205.0, 976.0], [205.0, 1054.0], [183.0, 1054.0]], [[162.0, 979.0], [179.0, 979.0], [179.0, 1107.0], [162.0, 1107.0]]], "lines": ["んな事ぁ", "どうでも", "いいんだよ．．．"]}], "img_path": "017.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [646, 77, 692, 175], "vertical": true, "font_size": 21, "lines_coords": [[[667.0, 77.0], [692.0, 77.0], [692.0, 138.0], [667.0, 138.0]], [[646.0, 77.0], [666.0, 77.0], [666.0, 175.0], [646.0, 175.0]]], "lines": ["どうだ", "見やがれ"]}, {"box": [562, 182, 630, 278], "vertical": true, "font_size": 21, "lines_coords": [[[610.0, 182.0], [630.0, 182.0], [630.0, 260.0], [610.0, 260.0]], [[588.0, 183.0], [604.0, 183.0], [604.0, 278.0], [588.0, 278.0]], [[562.0, 186.0], [585.0, 186.0], [585.0, 225.0], [562.0, 225.0]]], "lines": ["俺は俺の", "意志だけで", "．．．．．"]}, {"box": [147, 438, 228, 577], "vertical": true, "font_size": 23, "lines_coords": [[[205.0, 440.0], [226.0, 440.0], [226.0, 554.0], [205.0, 554.0]], [[173.0, 438.0], [197.0, 438.0], [200.0, 577.0], [175.0, 577.0]], [[147.0, 441.0], [171.0, 441.0], [171.0, 577.0], [147.0, 577.0]]], "lines": ["なんだって", "できてるじゃ", "ねーか．．．．．．"]}, {"box": [388, 697, 410, 765], "vertical": true, "font_size": 22, "lines_coords": [[[388.0, 697.0], [410.0, 697.0], [410.0, 765.0], [388.0, 765.0]]], "lines": ["．．．清水"]}, {"box": [117, 833, 137, 917], "vertical": true, "font_size": 20, "lines_coords": [[[117.0, 833.0], [137.0, 833.0], [137.0, 917.0], [117.0, 917.0]]], "lines": ["．．．帰るぞ。"]}], "img_path": "018.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "019.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "020.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "021.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "022.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [39, 221, 85, 345], "vertical": true, "font_size": 46, "lines_coords": [[[39.0, 221.0], [85.0, 221.0], [85.0, 345.0], [39.0, 345.0]]], "lines": ["第１３６話"]}, {"box": [311, 60, 575, 87], "vertical": false, "font_size": 24, "lines_coords": [[[311.0, 62.0], [571.0, 62.0], [571.0, 86.0], [311.0, 86.0]]], "lines": ["．．．．．．いラヴァーズよ。"]}, {"box": [303, 542, 576, 566], "vertical": false, "font_size": 22, "lines_coords": [[[303.0, 542.0], [576.0, 542.0], [576.0, 566.0], [303.0, 566.0]]], "lines": ["私のこの行動、この言葉も"]}, {"box": [200, 537, 682, 642], "vertical": false, "font_size": 26, "lines_coords": [[[200.0, 575.0], [680.0, 575.0], [680.0, 603.0], [200.0, 603.0]]], "lines": ["連綿と続くアカシックレコードに刻まれている"]}, {"box": [257, 614, 640, 633], "vertical": false, "font_size": 22, "lines_coords": [[[257.0, 614.0], [640.0, 614.0], [640.0, 633.0], [257.0, 633.0]]], "lines": ["・つの学祭に満ぎないのかもしれない。"]}, {"box": [401, 1008, 483, 1039], "vertical": false, "font_size": 31, "lines_coords": [[[401.0, 1008.0], [483.0, 1008.0], [483.0, 1039.0], [401.0, 1039.0]]], "lines": ["．．．期待。"]}, {"box": [67, 1050, 816, 1073], "vertical": false, "font_size": 23, "lines_coords": [[[67.0, 1050.0], [816.0, 1050.0], [816.0, 1073.0], [67.0, 1073.0]]], "lines": ["．．．そう、それでも私は期待してしまうんだ。いくら愚かと思われようと。"]}, {"box": [309, 1086, 574, 1109], "vertical": false, "font_size": 23, "lines_coords": [[[309.0, 1086.0], [574.0, 1086.0], [574.0, 1109.0], [309.0, 1109.0]]], "lines": ["完全に調和した新世界を。"]}], "img_path": "023.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [129, 557, 701, 624], "vertical": false, "font_size": 22, "lines_coords": [[[208.0, 561.0], [618.0, 561.0], [618.0, 585.0], [208.0, 585.0]], [[133.0, 595.0], [692.0, 595.0], [692.0, 619.0], [133.0, 619.0]]], "lines": ["人知れず、この体が朽ち果てるとしても、", "我々城法戦士の振動は君達に響いていると信じていく。"]}, {"box": [186, 1042, 644, 1104], "vertical": false, "font_size": 22, "lines_coords": [[[246.0, 1042.0], [571.0, 1044.0], [571.0, 1068.0], [246.0, 1066.0]], [[186.0, 1077.0], [644.0, 1077.0], [644.0, 1101.0], [186.0, 1101.0]]], "lines": ["いつか再び時代が巡るとしても。", "．．．なぜなら私は今この瞬間を生きていたのだ。"]}], "img_path": "024.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [376, 495, 493, 519], "vertical": false, "font_size": 21, "lines_coords": [[[376.0, 495.0], [493.0, 498.0], [493.0, 519.0], [376.0, 516.0]]], "lines": ["．．．であれば、"]}, {"box": [227, 544, 673, 568], "vertical": false, "font_size": 24, "lines_coords": [[[227.0, 544.0], [673.0, 544.0], [673.0, 568.0], [227.0, 568.0]]], "lines": ["一番良い振動を。．．．．．．つまりそういう事だ。"]}], "img_path": "025.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [622, 298, 785, 857], "vertical": true, "font_size": 163, "lines_coords": [[[622.0, 298.0], [785.0, 298.0], [785.0, 857.0], [622.0, 857.0]]], "lines": ["ァドヴァ"]}], "img_path": "026.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "027.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": 