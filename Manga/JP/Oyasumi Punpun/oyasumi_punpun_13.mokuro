 411.0], [159.0, 411.0]]], "lines": ["七夕だね"]}, {"box": [640, 739, 701, 847], "vertical": true, "font_size": 20, "lines_coords": [[[680.0, 739.0], [701.0, 739.0], [701.0, 812.0], [680.0, 812.0]], [[660.0, 739.0], [680.0, 739.0], [680.0, 847.0], [660.0, 847.0]], [[640.0, 740.0], [658.0, 740.0], [658.0, 798.0], [640.0, 798.0]]], "lines": ["．．．去年は", "見れなかった", "けれど、"]}, {"box": [180, 860, 241, 990], "vertical": true, "font_size": 18, "lines_coords": [[[221.0, 861.0], [241.0, 861.0], [241.0, 950.0], [221.0, 950.0]], [[199.0, 860.0], [219.0, 860.0], [219.0, 932.0], [199.0, 932.0]], [[180.0, 861.0], [195.0, 861.0], [195.0, 987.0], [180.0, 987.0]]], "lines": ["今年こそは", "天の川を", "見れるだろうか。"]}], "img_path": "205.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [651, 101, 671, 205], "vertical": true, "font_size": 20, "lines_coords": [[[651.0, 101.0], [671.0, 101.0], [671.0, 205.0], [651.0, 205.0]]], "lines": ["愛子ちゃん。"]}, {"box": [281, 461, 298, 498], "vertical": true, "font_size": 17, "lines_coords": [[[281.0, 461.0], [298.0, 461.0], [298.0, 498.0], [281.0, 498.0]]], "lines": ["煙っ"]}, {"box": [248, 458, 267, 493], "vertical": false, "font_size": 35, "lines_coords": [[[248.0, 458.0], [267.0, 458.0], [267.0, 493.0], [248.0, 493.0]]], "lines": ["禁．．．なんですね"]}, {"box": [139, 493, 188, 575], "vertical": true, "font_size": 26, "lines_coords": [[[167.0, 498.0], [188.0, 498.0], [188.0, 575.0], [167.0, 575.0]], [[139.0, 493.0], [169.0, 493.0], [169.0, 549.0], [139.0, 549.0]]], "lines": ["久しぶり", "だね。"]}, {"box": [618, 930, 658, 1041], "vertical": true, "font_size": 16, "lines_coords": [[[640.0, 931.0], [657.0, 931.0], [657.0, 1034.0], [640.0, 1034.0]], [[618.0, 931.0], [634.0, 931.0], [634.0, 1039.0], [618.0, 1039.0]]], "lines": ["今年も色々と", "報告があるよ。"]}], "img_path": "206.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [678, 97, 718, 216], "vertical": true, "font_size": 18, "lines_coords": [[[701.0, 99.0], [718.0, 99.0], [718.0, 216.0], [701.0, 216.0]], [[678.0, 97.0], [699.0, 97.0], [699.0, 171.0], [678.0, 171.0]]], "lines": ["執行猶予期間が", "終わって、"]}, {"box": [540, 137, 619, 281], "vertical": true, "font_size": 18, "lines_coords": [[[599.0, 137.0], [619.0, 137.0], [619.0, 226.0], [599.0, 226.0]], [[582.0, 139.0], [598.0, 139.0], [598.0, 275.0], [582.0, 275.0]], [[561.0, 138.0], [577.0, 138.0], [577.0, 276.0], [561.0, 276.0]], [[540.0, 137.0], [556.0, 137.0], [557.0, 281.0], [541.0, 281.0]]], "lines": ["宍戸社長に", "紹介してもらった", "不動産管理会社で", "先月から働いてる。"]}, {"box": [248, 309, 289, 418], "vertical": true, "font_size": 20, "lines_coords": [[[267.0, 309.0], [289.0, 309.0], [289.0, 366.0], [267.0, 366.0]], [[248.0, 311.0], [264.0, 311.0], [264.0, 418.0], [248.0, 418.0]]], "lines": ["すごく", "月並みだけど、"]}, {"box": [166, 400, 207, 506], "vertical": true, "font_size": 20, "lines_coords": [[[185.0, 400.0], [205.0, 400.0], [207.0, 506.0], [187.0, 506.0]], [[166.0, 401.0], [186.0, 401.0], [186.0, 480.0], [166.0, 480.0]]], "lines": ["頑張ろうって", "思ってる。"]}, {"box": [672, 648, 712, 717], "vertical": true, "font_size": 17, "lines_coords": [[[695.0, 649.0], [712.0, 649.0], [712.0, 717.0], [695.0, 717.0]], [[672.0, 648.0], [693.0, 648.0], [693.0, 706.0], [672.0, 706.0]]], "lines": ["漫画家の", "友達は、"]}, {"box": [586, 754, 665, 892], "vertical": true, "font_size": 17, "lines_coords": [[[649.0, 755.0], [665.0, 755.0], [665.0, 875.0], [649.0, 875.0]], [[629.0, 755.0], [644.0, 755.0], [644.0, 857.0], [629.0, 857.0]], [[606.0, 754.0], [623.0, 754.0], [624.0, 892.0], [608.0, 892.0]], [[586.0, 755.0], [603.0, 755.0], [603.0, 866.0], [586.0, 866.0]]], "lines": ["僕が協力してる", "新作の連載が", "単行本になるって", "よろこんでた。"]}, {"box": [257, 914, 295, 1040], "vertical": true, "font_size": 17, "lines_coords": [[[278.0, 914.0], [295.0, 914.0], [295.0, 999.0], [278.0, 999.0]], [[257.0, 914.0], [274.0, 914.0], [274.0, 1040.0], [257.0, 1040.0]]], "lines": ["三村は来年", "結婚するらしい。"]}, {"box": [153, 996, 213, 1103], "vertical": true, "font_size": 17, "lines_coords": [[[193.0, 996.0], [213.0, 996.0], [213.0, 1066.0], [193.0, 1066.0]], [[173.0, 997.0], [189.0, 997.0], [189.0, 1081.0], [173.0, 1081.0]], [[153.0, 996.0], [168.0, 996.0], [168.0, 1103.0], [153.0, 1103.0]]], "lines": ["．．．うまく", "いってるよ", "僕もみんなも。"]}], "img_path": "207.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [654, 103, 690, 203], "vertical": true, "font_size": 17, "lines_coords": [[[674.0, 103.0], [690.0, 103.0], [690.0, 203.0], [674.0, 203.0]], [[654.0, 103.0], [671.0, 103.0], [671.0, 188.0], [654.0, 188.0]]], "lines": ["ちゃんと前に", "進んでる．．．"]}, {"box": [567, 214, 626, 339], "vertical": true, "font_size": 17, "lines_coords": [[[604.0, 214.0], [626.0, 214.0], [626.0, 270.0], [604.0, 270.0]], [[586.0, 216.0], [603.0, 216.0], [603.0, 335.0], [586.0, 335.0]], [[567.0, 215.0], [582.0, 215.0], [582.0, 339.0], [567.0, 339.0]]], "lines": ["それは", "そんなに難しい", "事じゃなかった。"]}, {"box": [670, 598, 695, 662], "vertical": true, "font_size": 21, "lines_coords": [[[670.0, 600.0], [692.0, 598.0], [695.0, 660.0], [673.0, 662.0]]], "lines": ["黙らず、"]}, {"box": [625, 694, 645, 773], "vertical": true, "font_size": 21, "lines_coords": [[[625.0, 694.0], [645.0, 694.0], [645.0, 773.0], [625.0, 773.0]]], "lines": ["欲張らず、"]}, {"box": [186, 836, 229, 908], "vertical": true, "font_size": 22, "lines_coords": [[[208.0, 837.0], [229.0, 837.0], [229.0, 908.0], [208.0, 908.0]], [[186.0, 836.0], [210.0, 836.0], [210.0, 897.0], [186.0, 897.0]]], "lines": ["真面目に", "働いて、"]}, {"box": [119, 952, 205, 1044], "vertical": true, "font_size": 22, "lines_coords": [[[176.0, 953.0], [202.0, 952.0], [205.0, 1012.0], [179.0, 1013.0]], [[160.0, 957.0], [181.0, 957.0], [181.0, 1028.0], [160.0, 1028.0]], [[141.0, 957.0], [158.0, 957.0], [158.0, 1044.0], [141.0, 1044.0]], [[119.0, 956.0], [140.0, 956.0], [140.0, 1017.0], [119.0, 1017.0]]], "lines": ["それで", "少しだけ", "誰かの役に", "たって、"]}], "img_path": "208.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [663, 147, 719, 249], "vertical": true, "font_size": 18, "lines_coords": [[[702.0, 148.0], [719.0, 148.0], [719.0, 227.0], [702.0, 227.0]], [[680.0, 147.0], [700.0, 147.0], [700.0, 214.0], [680.0, 214.0]], [[663.0, 147.0], [679.0, 147.0], [679.0, 249.0], [663.0, 249.0]]], "lines": ["．．．目の前に", "いる人が", "笑っていると、"]}, {"box": [599, 241, 638, 353], "vertical": true, "font_size": 18, "lines_coords": [[[617.0, 241.0], [638.0, 241.0], [638.0, 297.0], [617.0, 297.0]], [[599.0, 243.0], [616.0, 243.0], [616.0, 353.0], [599.0, 353.0]]], "lines": ["とても", "安心するんだ。"]}, {"box": [155, 447, 237, 568], "vertical": true, "font_size": 17, "lines_coords": [[[217.0, 447.0], [237.0, 447.0], [237.0, 568.0], [217.0, 568.0]], [[199.0, 448.0], [215.0, 448.0], [215.0, 540.0], [199.0, 540.0]], [[178.0, 447.0], [194.0, 447.0], [194.0, 568.0], [178.0, 568.0]], [[155.0, 447.0], [172.0, 447.0], [172.0, 523.0], [155.0, 523.0]]], "lines": ["．．．明日は仕事が", "休みだから、", "どこかにでかけ", "ようかな"]}, {"box": [623, 591, 681, 696], "vertical": true, "font_size": 17, "lines_coords": [[[661.0, 591.0], [681.0, 591.0], [681.0, 662.0], [661.0, 662.0]], [[643.0, 592.0], [659.0, 592.0], [659.0, 696.0], [643.0, 696.0]], [[623.0, 591.0], [639.0, 591.0], [639.0, 665.0], [623.0, 665.0]]], "lines": ["．．．ひとつ", "悩み事がある", "とすれば、"]}, {"box": [173, 921, 261, 1059], "vertical": true, "font_size": 18, "lines_coords": [[[241.0, 921.0], [258.0, 921.0], [260.0, 1041.0], [242.0, 1041.0]], [[215.0, 922.0], [233.0, 922.0], [234.0, 1042.0], [216.0, 1042.0]], [[196.0, 923.0], [213.0, 923.0], [213.0, 1059.0], [196.0, 1059.0]], [[173.0, 922.0], [194.0, 922.0], [194.0, 983.0], [173.0, 983.0]]], "lines": ["友達の娘が僕に", "懐いてしまって", "父親と思い込んで", "いる事。"]}], "img_path": "209.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [604, 87, 686, 225], "vertical": true, "font_size": 17, "lines_coords": [[[668.0, 90.0], [685.0, 90.0], [685.0, 178.0], [668.0, 178.0]], [[646.0, 87.0], [663.0, 87.0], [663.0, 174.0], [646.0, 174.0]], [[626.0, 89.0], [643.0, 89.0], [643.0, 225.0], [626.0, 225.0]], [[604.0, 89.0], [622.0, 89.0], [623.0, 212.0], [605.0, 212.0]]], "lines": ["．．．もちろん、", "その子には", "父親がいたほうが", "いいと思うけど、"]}, {"box": [134, 312, 195, 419], "vertical": true, "font_size": 18, "lines_coords": [[[179.0, 316.0], [195.0, 316.0], [195.0, 418.0], [179.0, 418.0]], [[158.0, 315.0], [174.0, 315.0], [174.0, 419.0], [158.0, 419.0]], [[134.0, 312.0], [156.0, 312.0], [156.0, 360.0], [134.0, 360.0]]], "lines": ["それはきっと", "僕ではないと", "思う。"]}, {"box": [650, 642, 693, 756], "vertical": true, "font_size": 23, "lines_coords": [[[667.0, 642.0], [693.0, 642.0], [693.0, 701.0], [667.0, 701.0]], [[650.0, 644.0], [670.0, 644.0], [670.0, 755.0], [650.0, 755.0]]], "lines": ["．．．僕は", "ひとりでいい。"]}, {"box": [445, 657, 561, 675], "vertical": false, "font_size": 13, "lines_coords": [[[445.0, 657.0], [561.0, 662.0], [561.0, 675.0], [445.0, 670.0]]], "lines": ["おおおーーーっっっ"]}, {"box": [172, 911, 235, 1034], "vertical": true, "font_size": 20, "lines_coords": [[[217.0, 914.0], [234.0, 914.0], [234.0, 999.0], [217.0, 999.0]], [[195.0, 912.0], [215.0, 912.0], [215.0, 1034.0], [195.0, 1034.0]], [[172.0, 911.0], [196.0, 911.0], [196.0, 975.0], [172.0, 975.0]]], "lines": ["それだけが", "唯一のわがまま", "なんだ。"]}], "img_path": "210.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [680, 147, 720, 225], "vertical": true, "font_size": 19, "lines_coords": [[[699.0, 147.0], [720.0, 147.0], [720.0, 203.0], [699.0, 203.0]], [[680.0, 148.0], [697.0, 148.0], [697.0, 225.0], [680.0, 225.0]]], "lines": ["とても", "楽なんだ。"]}, {"box": [209, 229, 247, 333], "vertical": true, "font_size": 17, "lines_coords": [[[230.0, 229.0], [247.0, 229.0], [247.0, 315.0], [230.0, 315.0]], [[209.0, 229.0], [226.0, 229.0], [226.0, 333.0], [209.0, 333.0]]], "lines": ["何も悩まず", "身軽でいれば"]}, {"box": [612, 244, 674, 358], "vertical": true, "font_size": 19, "lines_coords": [[[650.0, 246.0], [672.0, 244.0], [674.0, 301.0], [652.0, 302.0]], [[632.0, 248.0], [652.0, 248.0], [652.0, 352.0], [632.0, 352.0]], [[612.0, 248.0], [627.0, 248.0], [627.0, 358.0], [612.0, 358.0]]], "lines": ["まるで", "幽霊のような", "生き方だけど。"]}, {"box": [151, 353, 210, 474], "vertical": true, "font_size": 17, "lines_coords": [[[190.0, 353.0], [210.0, 353.0], [210.0, 474.0], [190.0, 474.0]], [[171.0, 355.0], [187.0, 355.0], [187.0, 440.0], [171.0, 440.0]], [[151.0, 355.0], [167.0, 355.0], [167.0, 430.0], [151.0, 430.0]]], "lines": ["風が吹くだけで", "自然と前に", "進むんだ。"]}, {"box": [661, 555, 723, 662], "vertical": true, "font_size": 20, "lines_coords": [[[702.0, 555.0], [723.0, 555.0], [723.0, 611.0], [702.0, 611.0]], [[682.0, 557.0], [702.0, 557.0], [702.0, 662.0], [682.0, 662.0]], [[661.0, 556.0], [681.0, 556.0], [681.0, 628.0], [661.0, 628.0]]], "lines": ["どこに", "向かっている", "かは．．．"]}, {"box": [649, 833, 736, 957], "vertical": true, "font_size": 22, "lines_coords": [[[711.0, 834.0], [736.0, 834.0], [736.0, 892.0], [711.0, 892.0]], [[692.0, 836.0], [712.0, 836.0], [712.0, 957.0], [692.0, 957.0]], [[671.0, 834.0], [691.0, 834.0], [691.0, 923.0], [671.0, 923.0]], [[649.0, 833.0], [673.0, 833.0], [673.0, 896.0], [649.0, 896.0]]], "lines": ["．．．でも", "いつか人知れず", "泡のように", "消えて、"]}, {"box": [154, 626, 214, 730], "vertical": true, "font_size": 18, "lines_coords": [[[196.0, 628.0], [213.0, 628.0], [213.0, 730.0], [196.0, 730.0]], [[173.0, 626.0], [193.0, 626.0], [193.0, 713.0], [173.0, 713.0]], [[154.0, 628.0], [172.0, 628.0], [172.0, 684.0], [154.0, 684.0]]], "lines": ["．．．そんな事に", "興味はない", "けれど、"]}, {"box": [149, 973, 234, 1095], "vertical": true, "font_size": 18, "lines_coords": [[[215.0, 975.0], [233.0, 975.0], [231.0, 1095.0], [214.0, 1095.0]], [[194.0, 977.0], [210.0, 977.0], [210.0, 1095.0], [194.0, 1095.0]], [[171.0, 975.0], [190.0, 975.0], [193.0, 1064.0], [173.0, 1064.0]], [[149.0, 973.0], [169.0, 973.0], [172.0, 1054.0], [152.0, 1054.0]]], "lines": ["誰の記憶からも", "いなくなれれば", "いいなって", "思ってる。"]}], "img_path": "211.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [620, 89, 699, 188], "vertical": true, "font_size": 18, "lines_coords": [[[682.0, 92.0], [699.0, 92.0], [699.0, 188.0], [682.0, 188.0]], [[663.0, 91.0], [679.0, 91.0], [679.0, 188.0], [663.0, 188.0]], [[643.0, 91.0], [659.0, 91.0], [659.0, 188.0], [643.0, 188.0]], [[620.0, 89.0], [643.0, 89.0], [643.0, 131.0], [620.0, 131.0]]], "lines": ["君と過ごした", "数か月間とか", "子供の頃の事", "とか、"]}, {"box": [536, 183, 617, 301], "vertical": true, "font_size": 18, "lines_coords": [[[595.0, 183.0], [617.0, 183.0], [617.0, 225.0], [595.0, 225.0]], [[577.0, 187.0], [593.0, 187.0], [593.0, 301.0], [577.0, 301.0]], [[557.0, 187.0], [574.0, 187.0], [574.0, 285.0], [557.0, 285.0]], [[536.0, 186.0], [552.0, 186.0], [554.0, 288.0], [537.0, 288.0]]], "lines": ["僕は", "振り返らなきゃ", "ならない時も", "あるんだけど、"]}, {"box": [142, 351, 225, 523], "vertical": true, "font_size": 17, "lines_coords": [[[207.0, 353.0], [223.0, 353.0], [223.0, 491.0], [207.0, 491.0]], [[186.0, 352.0], [202.0, 352.0], [202.0, 523.0], [186.0, 523.0]], [[164.0, 351.0], [181.0, 351.0], [180.0, 522.0], [162.0, 522.0]], [[142.0, 351.0], [162.0, 351.0], [162.0, 442.0], [142.0, 442.0]]], "lines": ["その時の気持ちを", "言葉にしようとしても", "それはとても断片的で", "あやふやで、"]}, {"box": [628, 745, 667, 856], "vertical": true, "font_size": 18, "lines_coords": [[[645.0, 745.0], [666.0, 745.0], [667.0, 816.0], [646.0, 816.0]], [[629.0, 747.0], [645.0, 747.0], [645.0, 856.0], [629.0, 856.0]]], "lines": ["．．．すごく", "みっともない。"]}, {"box": [134, 911, 193, 1052], "vertical": true, "font_size": 20, "lines_coords": [[[173.0, 912.0], [193.0, 912.0], [193.0, 985.0], [173.0, 985.0]], [[151.0, 911.0], [174.0, 911.0], [172.0, 1052.0], [148.0, 1052.0]], [[134.0, 915.0], [151.0, 915.0], [151.0, 1020.0], [134.0, 1020.0]]], "lines": ["生き恥を", "晒しているようで", "嫌なんだけど、"]}], "img_path": "212.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [655, 117, 715, 261], "vertical": true, "font_size": 18, "lines_coords": [[[697.0, 117.0], [714.0, 117.0], [711.0, 220.0], [693.0, 220.0]], [[674.0, 117.0], [694.0, 117.0], [694.0, 239.0], [674.0, 239.0]], [[656.0, 117.0], [672.0, 117.0], [672.0, 261.0], [656.0, 261.0]]], "lines": ["．．．てもそれが", "僕に与えられた", "唯一の役目だから、"]}, {"box": [161, 191, 222, 295], "vertical": true, "font_size": 18, "lines_coords": [[[205.0, 193.0], [221.0, 193.0], [221.0, 262.0], [205.0, 262.0]], [[183.0, 193.0], [200.0, 193.0], [200.0, 295.0], [183.0, 295.0]], [[161.0, 191.0], [183.0, 191.0], [183.0, 237.0], [161.0, 237.0]]], "lines": ["最後まで", "やりきろうと", "思う。"]}, {"box": [288, 387, 304, 476], "vertical": true, "font_size": 19, "lines_coords": [[[288.0, 387.0], [304.0, 387.0], [304.0, 476.0], [288.0, 476.0]]], "lines": ["愛子ちゃん"]}, {"box": [199, 444, 240, 553], "vertical": true, "font_size": 19, "lines_coords": [[[216.0, 444.0], [240.0, 444.0], [240.0, 483.0], [216.0, 483.0]], [[199.0, 445.0], [215.0, 445.0], [215.0, 553.0], [199.0, 553.0]]], "lines": ["僕は", "思うんだけど、"]}, {"box": [660, 616, 719, 730], "vertical": true, "font_size": 18, "lines_coords": [[[699.0, 616.0], [719.0, 616.0], [719.0, 684.0], [699.0, 684.0]], [[681.0, 617.0], [698.0, 617.0], [698.0, 730.0], [681.0, 730.0]], [[660.0, 616.0], [677.0, 616.0], [677.0, 698.0], [660.0, 698.0]]], "lines": ["僕たちが", "子供の頃に見た", "あの天の川"]}, {"box": [609, 740, 670, 862], "vertical": true, "font_size": 18, "lines_coords": [[[649.0, 740.0], [670.0, 740.0], [670.0, 796.0], [649.0, 796.0]], [[630.0, 742.0], [646.0, 742.0], [646.0, 862.0], [630.0, 862.0]], [[609.0, 741.0], [625.0, 741.0], [625.0, 846.0], [609.0, 846.0]]], "lines": ["あれを", "僕たちは本当に", "見たのかな？"]}, {"box": [220, 854, 295, 984], "vertical": true, "font_size": 17, "lines_coords": [[[279.0, 854.0], [295.0, 854.0], [295.0, 952.0], [279.0, 952.0]], [[258.0, 854.0], [276.0, 854.0], [274.0, 937.0], [256.0, 937.0]], [[240.0, 854.0], [256.0, 854.0], [256.0, 969.0], [240.0, 969.0]], [[220.0, 854.0], [236.0, 854.0], [236.0, 984.0], [220.0, 984.0]]], "lines": ["もしかしたら", "美化された", "ただの思い込み", "だったのかなって"]}, {"box": [162, 999, 202, 1092], "vertical": true, "font_size": 17, "lines_coords": [[[181.0, 999.0], [202.0, 999.0], [202.0, 1071.0], [181.0, 1071.0]], [[162.0, 1000.0], [179.0, 1000.0], [179.0, 1092.0], [162.0, 1092.0]]], "lines": ["．．．そんな", "気がしてる。"]}], "img_path": "213.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [617, 91, 679, 195], "vertical": true, "font_size": 20, "lines_coords": [[[658.0, 91.0], [679.0, 91.0], [679.0, 166.0], [658.0, 166.0]], [[638.0, 91.0], [658.0, 91.0], [658.0, 195.0], [638.0, 195.0]], [[617.0, 91.0], [637.0, 91.0], [637.0, 168.0], [617.0, 168.0]]], "lines": ["．．．この頃、", "君の声が少し", "遠いんだ。"]}, {"box": [209, 210, 226, 303], "vertical": true, "font_size": 17, "lines_coords": [[[209.0, 210.0], [226.0, 210.0], [226.0, 303.0], [209.0, 303.0]]], "lines": ["愛子ちゃん。"]}, {"box": [126, 326, 183, 438], "vertical": true, "font_size": 17, "lines_coords": [[[168.0, 328.0], [183.0, 328.0], [183.0, 431.0], [168.0, 431.0]], [[145.0, 326.0], [165.0, 326.0], [165.0, 398.0], [145.0, 398.0]], [[126.0, 328.0], [142.0, 328.0], [142.0, 438.0], [126.0, 438.0]]], "lines": ["そもそも君は", "そんな声", "だったのかな。"]}, {"box": [156, 815, 217, 935], "vertical": true, "font_size": 16, "lines_coords": [[[200.0, 815.0], [216.0, 815.0], [216.0, 901.0], [200.0, 901.0]], [[180.0, 815.0], [196.0, 815.0], [196.0, 935.0], [180.0, 935.0]], [[159.0, 815.0], [176.0, 815.0], [174.0, 884.0], [156.0, 884.0]]], "lines": ["本当に君は", "そんな顔だった", "のかな？"]}], "img_path": "214.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [659, 141, 705, 234], "vertical": true, "font_size": 24, "lines_coords": [[[677.0, 142.0], [705.0, 142.0], [705.0, 183.0], [677.0, 183.0]], [[659.0, 141.0], [679.0, 141.0], [679.0, 234.0], [659.0, 234.0]]], "lines": ["一年", "経つごとに、"]}, {"box": [253, 147, 294, 222], "vertical": true, "font_size": 19, "lines_coords": [[[270.0, 147.0], [294.0, 147.0], [294.0, 187.0], [270.0, 187.0]], [[253.0, 148.0], [269.0, 148.0], [269.0, 222.0], [253.0, 222.0]]], "lines": ["君が", "誰なのか"]}, {"box": [146, 243, 208, 331], "vertical": true, "font_size": 19, "lines_coords": [[[192.0, 246.0], [208.0, 246.0], [208.0, 331.0], [192.0, 331.0]], [[169.0, 246.0], [186.0, 246.0], [186.0, 331.0], [169.0, 331.0]], [[146.0, 244.0], [167.0, 243.0], [169.0, 305.0], [148.0, 307.0]]], "lines": ["僕は自信が", "なくなって", "しまう。"]}, {"box": [650, 482, 734, 501], "vertical": false, "font_size": 8.5, "lines_coords": [[[650.0, 482.0], [734.0, 482.0], [734.0, 491.0], [650.0, 491.0]], [[652.0, 493.0], [715.0, 493.0], [715.0, 501.0], [652.0, 501.0]]], "lines": ["そして人間をかけて考えてきた", "てこうだと声もなかっている"]}, {"box": [357, 532, 387, 544], "vertical": false, "font_size": 12, "lines_coords": [[[357.0, 532.0], [387.0, 532.0], [387.0, 544.0], [357.0, 544.0]]], "lines": ["．．．"]}, {"box": [312, 651, 392, 663], "vertical": false, "font_size": 12, "lines_coords": [[[312.0, 651.0], [392.0, 651.0], [392.0, 663.0], [312.0, 663.0]]], "lines": ["それにしてはいけないと思いますが"]}, {"box": [238, 651, 357, 734], "vertical": false, "font_size": 12, "lines_coords": [[[238.0, 651.0], [297.0, 652.0], [297.0, 664.0], [238.0, 663.0]], [[242.0, 665.0], [294.0, 665.0], [294.0, 673.0], [242.0, 673.0]], [[256.0, 718.0], [357.0, 713.0], [357.0, 730.0], [256.0, 734.0]]], "lines": ["それで、何度もそうですね。それはそれだけ", "１００３年３月１日に新しい日本語・株主", "私は自分の好きだったんだけど．．．それですか？"]}, {"box": [445, 915, 487, 1020], "vertical": true, "font_size": 16, "lines_coords": [[[468.0, 917.0], [485.0, 917.0], [485.0, 1003.0], [468.0, 1003.0]], [[445.0, 917.0], [461.0, 917.0], [461.0, 1016.0], [445.0, 1016.0]]], "lines": ["もしまた", "裏切ったら、"]}, {"box": [385, 914, 486, 1067], "vertical": true, "font_size": 20, "lines_coords": [[[386.0, 917.0], [406.0, 917.0], [406.0, 1067.0], [386.0, 1067.0]]], "lines": ["今度は殺すから。"]}, {"box": [386, 915, 407, 1068], "vertical": true, "font_size": 21, "lines_coords": [[[386.0, 915.0], [407.0, 915.0], [407.0, 1068.0], [386.0, 1068.0]]], "lines": ["今度は殺すから。」"]}], "img_path": "215.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [633, 108, 650, 200], "vertical": true, "font_size": 17, "lines_coords": [[[633.0, 108.0], [650.0, 108.0], [650.0, 200.0], [633.0, 200.0]]], "lines": ["愛子ちゃん。"]}, {"box": [523, 198, 561, 308], "vertical": true, "font_size": 17, "lines_coords": [[[544.0, 199.0], [561.0, 199.0], [561.0, 268.0], [544.0, 268.0]], [[523.0, 198.0], [540.0, 198.0], [540.0, 308.0], [523.0, 308.0]]], "lines": ["僕はもう", "知ってるんだ。"]}, {"box": [153, 889, 213, 983], "vertical": true, "font_size": 18, "lines_coords": [[[193.0, 889.0], [213.0, 889.0], [213.0, 962.0], [193.0, 962.0]], [[171.0, 889.0], [190.0, 889.0], [190.0, 959.0], [171.0, 959.0]], [[153.0, 890.0], [169.0, 890.0], [169.0, 983.0], [153.0, 983.0]]], "lines": ["君はもう", "僕を殺せ", "ないって事。"]}], "img_path": "216.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [702, 805, 734, 877], "vertical": true, "font_size": 16, "lines_coords": [[[712.0, 805.0], [732.0, 805.0], [734.0, 877.0], [714.0, 877.0]], [[702.0, 822.0], [715.0, 822.0], [715.0, 871.0], [702.0, 871.0]]], "lines": ["超えれるって", "いらいわ"]}, {"box": [408, 603, 465, 766], "vertical": true, "font_size": 20, "lines_coords": [[[440.0, 603.0], [461.0, 603.0], [463.0, 708.0], [442.0, 708.0]], [[408.0, 605.0], [428.0, 605.0], [428.0, 765.0], [408.0, 765.0]]], "lines": ["ブンプンは", "嘘つかないよね？」"]}, {"box": [546, 798, 690, 1017], "vertical": false, "font_size": 42, "lines_coords": [[[563.0, 978.0], [593.0, 805.0], [618.0, 809.0], [588.0, 983.0]], [[610.0, 959.0], [640.0, 799.0], [665.0, 803.0], [634.0, 964.0]], [[593.0, 921.0], [618.0, 799.0], [643.0, 803.0], [618.0, 925.0]], [[660.0, 798.0], [690.0, 802.0], [664.0, 951.0], [634.0, 946.0]]], "lines": ["サイズハーブジェクトさんの", "「一般的に関してみてはい", "。アンケートの", "オリアになっても"]}, {"box": [668, 1041, 756, 1114], "vertical": true, "font_size": 25, "lines_coords": [[[687.0, 1041.0], [712.0, 1041.0], [712.0, 1113.0], [687.0, 1113.0]]], "lines": ["ダロッ！！"]}, {"box": [386, 814, 530, 1081], "vertical": false, "font_size": 41, "lines_coords": [[[429.0, 839.0], [477.0, 1060.0], [433.0, 1069.0], [386.0, 848.0]], [[475.0, 814.0], [521.0, 1058.0], [483.0, 1065.0], [438.0, 821.0]]], "lines": ["ＪＲＲＡｐｒｉｇｈｔ", "４０代にそれ以来の"]}, {"box": [246, 891, 344, 1079], "vertical": false, "font_size": 27.0, "lines_coords": [[[246.0, 1053.0], [297.0, 891.0], [325.0, 901.0], [274.0, 1061.0]], [[267.0, 1072.0], [320.0, 900.0], [344.0, 907.0], [290.0, 1079.0]]], "lines": ["そういうわけで、", "う．．．うん、お兄ちゃん．"]}, {"box": [171, 1018, 191, 1141], "vertical": true, "font_size": 16, "lines_coords": [[[172.0, 1018.0], [188.0, 1018.0], [188.0, 1139.0], [172.0, 1139.0]]], "lines": ["．．．愛子ちゃん。"]}], "img_path": "217.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [691, 151, 711, 237], "vertical": true, "font_size": 16, "lines_coords": [[[692.0, 151.0], [708.0, 151.0], [708.0, 235.0], [692.0, 235.0]]], "lines": ["ごめんね"]}, {"box": [135, 494, 182, 600], "vertical": true, "font_size": 24, "lines_coords": [[[155.0, 494.0], [182.0, 494.0], [182.0, 537.0], [155.0, 537.0]], [[135.0, 498.0], [155.0, 498.0], [155.0, 598.0], [135.0, 598.0]]], "lines": ["僕は", "嘘つきだよ。"]}], "img_path": "218.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [193, 438, 214, 524], "vertical": true, "font_size": 20, "lines_coords": [[[193.0, 439.0], [213.0, 439.0], [213.0, 522.0], [193.0, 522.0]]], "lines": ["．．．きっと、"]}, {"box": [663, 644, 733, 760], "vertical": true, "font_size": 21, "lines_coords": [[[711.0, 644.0], [731.0, 644.0], [733.0, 759.0], [713.0, 759.0]], [[688.0, 644.0], [708.0, 644.0], [708.0, 760.0], [688.0, 760.0]], [[663.0, 644.0], [687.0, 644.0], [687.0, 712.0], [663.0, 712.0]]], "lines": ["今年も来年も", "天の川は見れ", "なくて、"]}, {"box": [162, 998, 231, 1114], "vertical": true, "font_size": 20, "lines_coords": [[[210.0, 999.0], [230.0, 999.0], [230.0, 1114.0], [210.0, 1114.0]], [[186.0, 999.0], [206.0, 999.0], [206.0, 1113.0], [186.0, 1113.0]], [[162.0, 998.0], [183.0, 998.0], [183.0, 1079.0], [162.0, 1079.0]]], "lines": ["この先ずっと", "七夕は永遠に", "曇り空で、"]}], "img_path": "219.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [615, 112, 693, 215], "vertical": true, "font_size": 16, "lines_coords": [[[677.0, 112.0], [693.0, 112.0], [693.0, 215.0], [677.0, 215.0]], [[656.0, 112.0], [672.0, 112.0], [672.0, 215.0], [656.0, 215.0]], [[633.0, 112.0], [650.0, 112.0], [650.0, 199.0], [633.0, 199.0]], [[616.0, 114.0], [630.0, 114.0], [630.0, 205.0], [616.0, 205.0]]], "lines": ["．．．ても世界は", "終わらないし", "人類は滅亡", "しないから。"]}, {"box": [66, 87, 220, 138], "vertical": false, "font_size": 33, "lines_coords": [[[66.0, 105.0], [216.0, 87.0], [220.0, 120.0], [70.0, 138.0]]], "lines": ["サンセルタウン"]}, {"box": [119, 447, 202, 535], "vertical": true, "font_size": 18, "lines_coords": [[[182.0, 448.0], [202.0, 448.0], [202.0, 519.0], [182.0, 519.0]], [[161.0, 447.0], [181.0, 447.0], [181.0, 535.0], [161.0, 535.0]], [[144.0, 450.0], [156.0, 450.0], [156.0, 533.0], [144.0, 533.0]], [[119.0, 447.0], [140.0, 447.0], [140.0, 502.0], [119.0, 502.0]]], "lines": ["僕は先に", "進まなきゃ", "ならないん", "だ．．．．．"]}, {"box": [578, 966, 593, 1073], "vertical": true, "font_size": 15, "lines_coords": [[[578.0, 966.0], [593.0, 966.0], [593.0, 1071.0], [578.0, 1071.0]]], "lines": ["ＰｐｐｐＰＰ：："]}], "img_path": "220.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [673, 168, 695, 276], "vertical": true, "font_size": 20, "lines_coords": [[[675.0, 168.0], [695.0, 168.0], [693.0, 276.0], [673.0, 276.0]]], "lines": ["．．．ごめんね。"]}, {"box": [584, 315, 599, 416], "vertical": true, "font_size": 15, "lines_coords": [[[584.0, 315.0], [599.0, 315.0], [599.0, 416.0], [584.0, 416.0]]], "lines": ["ＰＰＲＰＰＰ：："]}, {"box": [369, 532, 384, 633], "vertical": true, "font_size": 15, "lines_coords": [[[369.0, 533.0], [384.0, 533.0], [384.0,