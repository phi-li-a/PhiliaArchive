.0]], [[677.0, 873.0], [691.0, 871.0], [693.0, 911.0], [679.0, 912.0]], [[653.0, 867.0], [681.0, 866.0], [691.0, 1065.0], [663.0, 1066.0]]], "lines": ["昭和一大十一年度", "ヒン", "そういうことで、"]}], "img_path": "225.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [113, 183, 186, 308], "vertical": true, "font_size": 23, "lines_coords": [[[156.0, 183.0], [186.0, 183.0], [186.0, 248.0], [156.0, 248.0]], [[138.0, 185.0], [158.0, 185.0], [158.0, 282.0], [138.0, 282.0]], [[115.0, 183.0], [135.0, 183.0], [133.0, 308.0], [113.0, 308.0]]], "lines": ["長い間", "ありがとう", "ございました。"]}, {"box": [612, 60, 680, 201], "vertical": true, "font_size": 20, "lines_coords": [[[659.0, 60.0], [680.0, 60.0], [680.0, 138.0], [659.0, 138.0]], [[636.0, 62.0], [656.0, 62.0], [656.0, 195.0], [636.0, 195.0]], [[612.0, 63.0], [632.0, 63.0], [632.0, 201.0], [612.0, 201.0]]], "lines": ["みんなと", "過ごした時間は", "一生忘れません。"]}, {"box": [402, 533, 474, 549], "vertical": false, "font_size": 13, "lines_coords": [[[402.0, 533.0], [474.0, 536.0], [474.0, 549.0], [402.0, 546.0]]], "lines": ["．．．"]}, {"box": [164, 959, 183, 969], "vertical": false, "font_size": 10, "lines_coords": [[[164.0, 959.0], [183.0, 959.0], [183.0, 969.0], [164.0, 969.0]]], "lines": ["ありがとうございます"]}, {"box": [141, 1024, 200, 1144], "vertical": true, "font_size": 17, "lines_coords": [[[183.0, 1025.0], [200.0, 1025.0], [200.0, 1143.0], [183.0, 1143.0]], [[162.0, 1025.0], [179.0, 1025.0], [179.0, 1144.0], [162.0, 1144.0]], [[141.0, 1024.0], [158.0, 1024.0], [158.0, 1128.0], [141.0, 1128.0]]], "lines": ["来月の懇親会の", "予定表ってもう", "てきてます？"]}, {"box": [297, 979, 313, 1061], "vertical": true, "font_size": 17, "lines_coords": [[[297.0, 979.0], [313.0, 979.0], [313.0, 1061.0], [297.0, 1061.0]]], "lines": ["晴見先生"]}, {"box": [476, 1044, 502, 1064], "vertical": false, "font_size": 15, "lines_coords": [[[480.0, 1044.0], [502.0, 1050.0], [499.0, 1064.0], [476.0, 1059.0]]], "lines": ["．．．"]}, {"box": [446, 1069, 513, 1086], "vertical": false, "font_size": 17, "lines_coords": [[[446.0, 1069.0], [513.0, 1069.0], [513.0, 1086.0], [446.0, 1086.0]]], "lines": ["．．．"]}, {"box": [507, 1048, 533, 1085], "vertical": false, "font_size": 13.5, "lines_coords": [[[507.0, 1048.0], [533.0, 1048.0], [533.0, 1061.0], [507.0, 1061.0]], [[507.0, 1071.0], [531.0, 1071.0], [531.0, 1085.0], [507.0, 1085.0]]], "lines": ["．．．", "．．．"]}, {"box": [637, 980, 691, 1004], "vertical": false, "font_size": 14, "lines_coords": [[[639.0, 980.0], [687.0, 980.0], [687.0, 995.0], [639.0, 995.0]], [[639.0, 990.0], [687.0, 990.0], [687.0, 1006.0], [639.0, 1006.0]]], "lines": ["あなたはここまではないでしょうか。", "これからもうちょっとしていますが、"]}, {"box": [630, 1025, 658, 1038], "vertical": false, "font_size": 13, "lines_coords": [[[630.0, 1025.0], [658.0, 1025.0], [658.0, 1038.0], [630.0, 1038.0]]], "lines": ["．．．"]}], "img_path": "226.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [734, 37, 759, 117], "vertical": true, "font_size": 25, "lines_coords": [[[734.0, 37.0], [759.0, 37.0], [759.0, 117.0], [734.0, 117.0]]], "lines": ["あっ．．．"]}, {"box": [429, 36, 476, 104], "vertical": true, "font_size": 24, "lines_coords": [[[449.0, 36.0], [476.0, 36.0], [476.0, 89.0], [449.0, 89.0]], [[429.0, 36.0], [451.0, 36.0], [451.0, 104.0], [429.0, 104.0]]], "lines": ["．．．あ、", "これか。"]}, {"box": [118, 91, 184, 225], "vertical": true, "font_size": 18, "lines_coords": [[[162.0, 91.0], [182.0, 91.0], [182.0, 206.0], [162.0, 206.0]], [[141.0, 94.0], [158.0, 94.0], [158.0, 225.0], [141.0, 225.0]], [[118.0, 94.0], [134.0, 94.0], [134.0, 195.0], [118.0, 195.0]]], "lines": ["どうでした？", "初担任クラスの", "お別れ会は。"]}, {"box": [562, 297, 622, 425], "vertical": true, "font_size": 18, "lines_coords": [[[602.0, 298.0], [622.0, 298.0], [622.0, 369.0], [602.0, 369.0]], [[581.0, 297.0], [600.0, 297.0], [600.0, 420.0], [581.0, 420.0]], [[562.0, 300.0], [578.0, 300.0], [578.0, 425.0], [562.0, 425.0]]], "lines": ["先週末に", "書類とメールで", "お渡ししました。"]}, {"box": [711, 542, 731, 626], "vertical": true, "font_size": 20, "lines_coords": [[[711.0, 542.0], [731.0, 542.0], [731.0, 625.0], [711.0, 625.0]]], "lines": ["．．．本音は、"]}, {"box": [442, 270, 481, 372], "vertical": true, "font_size": 18, "lines_coords": [[[461.0, 270.0], [481.0, 270.0], [481.0, 341.0], [461.0, 341.0]], [[442.0, 271.0], [459.0, 271.0], [459.0, 372.0], [442.0, 372.0]]], "lines": ["いちおう", "つつがなく．．．"]}, {"box": [345, 324, 405, 445], "vertical": true, "font_size": 18, "lines_coords": [[[385.0, 325.0], [405.0, 325.0], [405.0, 397.0], [385.0, 397.0]], [[364.0, 324.0], [384.0, 324.0], [384.0, 445.0], [364.0, 445.0]], [[345.0, 325.0], [360.0, 325.0], [360.0, 428.0], [345.0, 428.0]]], "lines": ["とはいえ", "ちょっと寂しい", "てすよね．．．"]}, {"box": [117, 351, 185, 424], "vertical": true, "font_size": 22, "lines_coords": [[[164.0, 353.0], [185.0, 353.0], [185.0, 424.0], [164.0, 424.0]], [[137.0, 351.0], [161.0, 351.0], [161.0, 424.0], [137.0, 424.0]], [[117.0, 352.0], [138.0, 352.0], [138.0, 413.0], [117.0, 413.0]]], "lines": ["晴見先生", "感動しい", "だから。"]}, {"box": [181, 721, 262, 844], "vertical": true, "font_size": 18, "lines_coords": [[[243.0, 723.0], [261.0, 723.0], [258.0, 810.0], [241.0, 810.0]], [[223.0, 721.0], [240.0, 721.0], [240.0, 842.0], [223.0, 842.0]], [[200.0, 721.0], [220.0, 721.0], [220.0, 844.0], [200.0, 844.0]], [[181.0, 724.0], [197.0, 724.0], [197.0, 799.0], [181.0, 799.0]]], "lines": ["心の底から", "どうでもいいん", "じゃないですか", "晴見先生。"]}, {"box": [707, 953, 747, 1057], "vertical": true, "font_size": 18, "lines_coords": [[[729.0, 956.0], [746.0, 956.0], [746.0, 1057.0], [729.0, 1057.0]], [[707.0, 953.0], [727.0, 953.0], [727.0, 1026.0], [707.0, 1026.0]]], "lines": ["作文の授業の", "テーマ．．．"]}, {"box": [294, 946, 330, 1066], "vertical": true, "font_size": 16, "lines_coords": [[[313.0, 946.0], [330.0, 946.0], [330.0, 1066.0], [313.0, 1066.0]], [[294.0, 946.0], [309.0, 946.0], [309.0, 1052.0], [294.0, 1052.0]]], "lines": ["「友達の大切さ」", "なんですけど、"]}, {"box": [156, 1008, 215, 1129], "vertical": true, "font_size": 16, "lines_coords": [[[199.0, 1010.0], [215.0, 1010.0], [215.0, 1129.0], [199.0, 1129.0]], [[178.0, 1008.0], [194.0, 1008.0], [194.0, 1096.0], [178.0, 1096.0]], [[156.0, 1008.0], [173.0, 1008.0], [173.0, 1100.0], [156.0, 1100.0]]], "lines": ["学年主任として", "これは了承", "てきません。"]}], "img_path": "227.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [595, 50, 698, 205], "vertical": true, "font_size": 18, "lines_coords": [[[678.0, 50.0], [698.0, 50.0], [698.0, 121.0], [678.0, 121.0]], [[657.0, 51.0], [677.0, 51.0], [677.0, 172.0], [657.0, 172.0]], [[638.0, 51.0], [654.0, 51.0], [654.0, 205.0], [638.0, 205.0]], [[617.0, 51.0], [633.0, 51.0], [633.0, 172.0], [617.0, 172.0]], [[596.0, 50.0], [612.0, 50.0], [611.0, 171.0], [595.0, 171.0]]], "lines": ["まわりと", "馴染めない子が", "こういった題材だと", "傷つくって想像", "てきませんか？"]}, {"box": [132, 214, 192, 336], "vertical": true, "font_size": 18, "lines_coords": [[[172.0, 214.0], [192.0, 214.0], [189.0, 336.0], [169.0, 336.0]], [[152.0, 215.0], [169.0, 215.0], [168.0, 335.0], [151.0, 335.0]], [[132.0, 216.0], [148.0, 216.0], [148.0, 325.0], [132.0, 325.0]]], "lines": ["もう少し細かい", "気配りをお願い", "したいですね。"]}, {"box": [134, 377, 159, 471], "vertical": true, "font_size": 17, "lines_coords": [[[134.0, 377.0], [151.0, 377.0], [151.0, 471.0], [134.0, 471.0]]], "lines": ["．．．高橋先生。"]}, {"box": [663, 541, 722, 666], "vertical": true, "font_size": 16, "lines_coords": [[[705.0, 541.0], [721.0, 541.0], [721.0, 659.0], [705.0, 659.0]], [[682.0, 542.0], [699.0, 542.0], [699.0, 663.0], [682.0, 663.0]], [[663.0, 542.0], [679.0, 542.0], [679.0, 665.0], [663.0, 665.0]]], "lines": ["．．．僕のクラスの", "子たちはみんな", "仲は良いですし、"]}, {"box": [647, 765, 727, 909], "vertical": true, "font_size": 18, "lines_coords": [[[711.0, 766.0], [727.0, 766.0], [727.0, 902.0], [711.0, 902.0]], [[687.0, 765.0], [707.0, 765.0], [707.0, 869.0], [687.0, 869.0]], [[668.0, 766.0], [685.0, 766.0], [685.0, 869.0], [668.0, 869.0]], [[647.0, 766.0], [664.0, 766.0], [664.0, 909.0], [647.0, 909.0]]], "lines": ["．．．父兄から人気が", "あるからって", "思い上がると", "寝首をかかれるぞ。"]}, {"box": [91, 578, 171, 714], "vertical": true, "font_size": 16, "lines_coords": [[[153.0, 578.0], [169.0, 578.0], [169.0, 714.0], [153.0, 714.0]], [[133.0, 578.0], [149.0, 578.0], [149.0, 713.0], [133.0, 713.0]], [[112.0, 578.0], [128.0, 578.0], [128.0, 714.0], [112.0, 714.0]], [[91.0, 578.0], [107.0, 578.0], [107.0, 703.0], [91.0, 703.0]]], "lines": ["テーマについては", "先日の保護者会で", "意見交換した上で", "賛同を得てます。"]}, {"box": [168, 789, 193, 862], "vertical": true, "font_size": 19, "lines_coords": [[[168.0, 789.0], [193.0, 789.0], [193.0, 862.0], [168.0, 862.0]]], "lines": ["では．．．．．．"]}, {"box": [128, 887, 165, 1012], "vertical": true, "font_size": 19, "lines_coords": [[[148.0, 888.0], [165.0, 888.0], [165.0, 992.0], [148.0, 992.0]], [[128.0, 887.0], [144.0, 887.0], [144.0, 1012.0], [128.0, 1012.0]]], "lines": ["「将来の夢」は", "どうでしょうか。"]}], "img_path": "228.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [660, 48, 702, 142], "vertical": true, "font_size": 21, "lines_coords": [[[682.0, 48.0], [702.0, 48.0], [702.0, 138.0], [682.0, 138.0]], [[663.0, 48.0], [682.0, 48.0], [680.0, 142.0], [660.0, 142.0]]], "lines": ["．．．それなら", "平等ですね。"]}, {"box": [572, 93, 615, 199], "vertical": true, "font_size": 21, "lines_coords": [[[588.0, 93.0], [615.0, 93.0], [615.0, 137.0], [588.0, 137.0]], [[572.0, 96.0], [589.0, 96.0], [589.0, 199.0], [572.0, 199.0]]], "lines": ["了承", "しました．．．"]}, {"box": [100, 51, 313, 71], "vertical": false, "font_size": 20, "lines_coords": [[[100.0, 51.0], [313.0, 51.0], [313.0, 71.0], [100.0, 71.0]]], "lines": ["おやすみプンプン［Ｂ"]}, {"box": [651, 630, 671, 739], "vertical": true, "font_size": 19, "lines_coords": [[[651.0, 630.0], [671.0, 630.0], [671.0, 739.0], [651.0, 739.0]]], "lines": ["高橋さんって、"]}, {"box": [537, 738, 602, 860], "vertical": true, "font_size": 19, "lines_coords": [[[582.0, 739.0], [602.0, 739.0], [602.0, 844.0], [582.0, 844.0]], [[556.0, 738.