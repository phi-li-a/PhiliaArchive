", "大船に乗った", "もりてー"]}, {"box": [694, 645, 743, 711], "vertical": true, "font_size": 22, "lines_coords": [[[715.0, 645.0], [743.0, 645.0], [743.0, 694.0], [715.0, 694.0]], [[697.0, 645.0], [723.0, 646.0], [721.0, 711.0], [694.0, 710.0]]], "lines": ["．．．ん、", "スマン。"]}, {"box": [637, 720, 699, 832], "vertical": true, "font_size": 22, "lines_coords": [[[678.0, 720.0], [699.0, 720.0], [699.0, 776.0], [678.0, 776.0]], [[657.0, 721.0], [677.0, 721.0], [677.0, 827.0], [657.0, 827.0]], [[637.0, 721.0], [653.0, 721.0], [653.0, 832.0], [637.0, 832.0]]], "lines": ["本当は", "神奈川生まれ", "神奈川育ちだ。"]}, {"box": [366, 665, 426, 768], "vertical": true, "font_size": 18, "lines_coords": [[[406.0, 665.0], [426.0, 665.0], [426.0, 735.0], [406.0, 735.0]], [[386.0, 665.0], [402.0, 665.0], [402.0, 768.0], [386.0, 768.0]], [[366.0, 665.0], [383.0, 665.0], [383.0, 752.0], [366.0, 752.0]]], "lines": ["．．．えっ！？", "やっぱり来な", "くていい！？"]}, {"box": [152, 664, 194, 748], "vertical": true, "font_size": 18, "lines_coords": [[[172.0, 666.0], [194.0, 666.0], [194.0, 721.0], [172.0, 721.0]], [[152.0, 664.0], [172.0, 664.0], [172.0, 748.0], [152.0, 748.0]]], "lines": ["なんだ", "とォ～～"]}, {"box": [94, 787, 174, 910], "vertical": true, "font_size": 18, "lines_coords": [[[158.0, 789.0], [174.0, 789.0], [174.0, 876.0], [158.0, 876.0]], [[137.0, 789.0], [153.0, 789.0], [153.0, 876.0], [137.0, 876.0]], [[112.0, 787.0], [132.0, 787.0], [134.0, 910.0], [114.0, 910.0]], [[94.0, 789.0], [111.0, 789.0], [111.0, 892.0], [94.0, 892.0]]], "lines": ["．．．とんちが", "ききすぎて", "意味がさっぱり", "わからん．．．．．"]}, {"box": [506, 1039, 569, 1144], "vertical": true, "font_size": 20, "lines_coords": [[[542.0, 1039.0], [569.0, 1039.0], [569.0, 1098.0], [542.0, 1098.0]], [[527.0, 1041.0], [543.0, 1041.0], [543.0, 1144.0], [527.0, 1144.0]], [[506.0, 1042.0], [522.0, 1042.0], [522.0, 1135.0], [506.0, 1135.0]]], "lines": ["急いで", "今からそっち", "向かいます。"]}], "img_path": "162.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [6