0.0], [719.0, 760.0]], [[700.0, 691.0], [716.0, 691.0], [716.0, 793.0], [700.0, 793.0]]], "lines": ["今週分の", "原稿終わり！！"]}, {"box": [617, 782, 677, 903], "vertical": true, "font_size": 19, "lines_coords": [[[657.0, 782.0], [677.0, 782.0], [677.0, 888.0], [657.0, 888.0]], [[636.0, 783.0], [656.0, 783.0], [656.0, 903.0], [636.0, 903.0]], [[617.0, 783.0], [633.0, 783.0], [633.0, 870.0], [617.0, 870.0]]], "lines": ["炭水化物でも", "食い散らかしに", "行くかい！！"]}, {"box": [352, 594, 423, 681], "vertical": true, "font_size": 18, "lines_coords": [[[400.0, 596.0], [420.0, 596.0], [420.0, 680.0], [400.0, 680.0]], [[374.0, 595.0], [392.0, 595.0], [393.0, 680.0], [376.0, 680.0]], [[352.0, 594.0], [369.0, 594.0], [371.0, 680.0], [354.0, 680.0]]], "lines": ["初めてだけで", "売りてなんと", "思わなかった！！"]}, {"box": [342, 751, 400, 870], "vertical": true, "font_size": 18, "lines_coords": [[[380.0, 751.0], [400.0, 751.0], [400.0, 822.0], [380.0, 822.0]], [[361.0, 753.0], [378.0, 753.0], [378.0, 870.0], [361.0, 870.0]], [[342.0, 751.0], [358.0, 751.0], [358.0, 855.0], [342.0, 855.0]]], "lines": ["わあい！！", "みんなでデフリ", "ましょうー！！"]}, {"box": [158, 570, 186, 650], "vertical": true, "font_size": 25, "lines_coords": [[[158.0, 571.0], [182.0, 570.0], [186.0, 649.0], [161.0, 650.0]]], "lines": ["．．．よし。"]}], "img_path": "145.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [650, 495, 694, 592], "vertical": true, "font_size": 20, "lines_coords": [[[673.0, 496.0], [694.0, 496.0], [694.0, 574.0], [673.0, 574.0]], [[650.0, 495.0], [670.0, 495.0], [670.0, 592.0], [650.0, 592.0]]], "lines": ["あたしは", "ですねぇ！！"]}, {"box": [337, 332, 364, 390], "vertical": true, "font_size": 27, "lines_coords": [[[337.0, 332.0], [364.0, 332.0], [364.0, 390.0], [337.0, 390.0]]], "lines": ["ドンッ"]}, {"box": [115, 526, 206, 659], "vertical": true, "font_size": 18, "lines_coords": [[[186.0, 526.0], [206.0, 526.0], [206.0, 659.0], [186.0, 659.0]], [[161.0, 527.0], [181.0, 527.0], [181.0, 641.0], [161.0, 641.0]], [[139.0, 527.0], [155.0, 527.0], [155.0, 621.0], [139.0, 621.0]], [[115.0, 526.0], [132.0, 526.0], [132.0, 603.0], [115.0, 603.0]]], "lines": ["幸さんのような", "強く自立した", "女性に憧れ", "ますよ！！"]}, {"box": [682, 745, 742, 849], "vertical": true, "font_size": 18, "lines_coords": [[[721.0, 745.0], [742.0, 745.0], [742.0, 800.0], [721.0, 800.0]], [[702.0, 746.0], [719.0, 746.0], [719.0, 849.0], [702.0, 849.0]], [[682.0, 746.0], [698.0, 746.0], [698.0, 839.0], [682.0, 839.0]]], "lines": ["今日は", "荒れてますな", "この娘さん。"]}, {"box": [420, 733, 460, 851], "vertical": true, "font_size": 19, "lines_coords": [[[441.0, 733.0], [459.0, 733.0], [460.0, 851.0], [442.0, 851.0]], [[420.0, 733.0], [440.0, 733.0], [440.0, 820.0], [420.0, 820.0]]], "lines": ["スネちゃまじゃ", "ねーです！！"]}, {"box": [96, 759, 176, 897], "vertical": true, "font_size": 17, "lines_coords": [[[156.0, 759.0], [176.0, 759.0], [176.0, 880.0], [156.0, 880.0]], [[135.0, 759.0], [152.0, 759.0], [154.0, 897.0], [138.0, 897.0]], [[117.0, 760.0], [133.0, 760.0], [133.0, 896.0], [117.0, 896.0]], [[96.0, 759.0], [112.0, 759.0], [112.0, 880.0], [96.0, 880.0]]], "lines": ["守れないくせに", "約束をしてしまう", "三村の軽さに絶望", "してるんです！！"]}, {"box": [524, 965, 611, 1087], "vertical": true, "font_size": 18, "lines_coords": [[[584.0, 965.0], [605.0, 965.0], [606.0, 1087.0], [585.0, 1087.0]], [[567.0, 967.0], [583.0, 967.0], [583.0, 1069.0], [567.0, 1069.0]], [[545.0, 967.0], [562.0, 967.0], [562.0, 1053.0], [545.0, 1053.0]], [[524.0, 966.0], [541.0, 966.0], [542.0, 1061.0], [526.0, 1061.0]]], "lines": ["三村がかまって", "くれないから", "スネちゃま", "なんだって。"]}, {"box": [288, 940, 369, 1080], "vertical": true, "font_size": 17, "lines_coords": [[[349.0, 941.0], [369.0, 941.0], [369.0, 1014.0], [349.0, 1014.0]], [[329.0, 943.0], [345.0, 943.0], [345.0, 1080.0], [329.0, 1080.0]], [[308.0, 941.0], [324.0, 941.0], [324.0, 1060.0], [308.0, 1060.0]], [[288.0, 942.0], [304.0, 942.0], [304.0, 1033.0], [288.0, 1033.0]]], "lines": ["．．．この子、", "一日三回のメールを", "三村に強要して", "たんだって。"]}, {"box": [85, 1007, 145, 1119], "vertical": true, "font_size": 16, "lines_coords": [[[127.0, 1008.0], [144.0, 1008.0], [144.0, 1078.0], [127.0, 1078.0]], [[105.0, 1008.0], [121.0, 1008.0], [121.0, 1112.0], [105.0, 1112.0]], [[85.0, 1007.0], [100.0, 1007.0], [100.0, 1117.0], [85.0, 1117.0]]], "lines": ["なるほど", "それはとても", "ウザい女だぞ"]}], "img_path": "146.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [718, 46, 763, 105], "vertical": true, "font_size": 21, "lines_coords": [[[738.0, 46.0], [763.0, 46.0], [763.0, 104.0], [738.0, 104.0]], [[718.0, 46.0], [743.0, 46.0], [743.0, 105.0], [718.0, 105.0]]], "lines": ["幸さん", "は．．．．．"]}, {"box": [645, 105, 704, 193], "vertical": true, "font_size": 21, "lines_coords": [[[687.0, 107.0], [704.0, 107.0], [704.0, 193.0], [687.0, 193.0]], [[664.0, 105.0], [684.0, 105.0], [684.0, 193.0], [664.0, 193.0]], [[645.0, 106.0], [661.0, 106.0], [661.0, 193.0], [645.0, 193.0]]], "lines": ["言った事は", "必ず守る人", "てすよね？"]}, {"box": [426, 103, 515, 198], "vertical": true, "font_size": 20, "lines_coords": [[[489.0, 103.0], [515.0, 103.0], [515.0, 161.0], [489.0, 161.0]], [[470.0, 105.0], [490.0, 105.0], [490.0, 192.0], [470.0, 192.0]], [[446.0, 105.0], [466.0, 105.0], [466.0, 178.0], [446.0, 178.0]], [[426.0, 105.0], [442.0, 105.0], [442.0, 198.0], [426.0, 198.0]]], "lines": ["．．．お？", "なんか急に", "百合百合", "しだしたぞ"]}, {"box": [318, 46, 340, 136], "vertical": true, "font_size": 22, "lines_coords": [[[318.0, 46.0], [340.0, 46.0], [340.0, 80.0], [318.0, 80.0]]], "lines": ["昔ー"]}, {"box": [718, 267, 734, 352], "vertical": true, "font_size": 19, "lines_coords": [[[718.0, 267.0], [734.0, 267.0], [734.0, 352.0], [718.0, 352.0]]], "lines": ["いやいや．．．"]}, {"box": [596, 300, 679, 404], "vertical": true, "font_size": 19, "lines_coords": [[[657.0, 300.0], [677.0, 300.0], [679.0, 404.0], [659.0, 404.0]], [[640.0, 301.0], [657.0, 301.0], [657.0, 403.0], [640.0, 403.0]], [[617.0, 300.0], [637.0, 300.0], [637.0, 404.0], [617.0, 404.0]], [[596.0, 301.0], [616.0, 301.0], [616.0, 387.0], [596.0, 387.0]]], "lines": ["あたしだって", "守りきれない", "事もあります", "わな．．．．．．"]}, {"box": [687, 467, 740, 590], "vertical": true, "font_size": 18, "lines_coords": [[[723.0, 468.0], [740.0, 468.0], [740.0, 590.0], [723.0, 590.0]], [[705.0, 467.0], [721.0, 467.0], [722.0, 575.0], [706.0, 575.0]], [[687.0, 468.0], [702.0, 468.0], [702.0, 576.0], [687.0, 576.0]]], "lines": ["漫画が完成したら", "必ず見せるって", "約束したけど．．．"]}, {"box": [586, 528, 646, 631], "vertical": true, "font_size": 18, "lines_coords": [[[624.0, 528.0], [646.0, 528.0], [646.0, 582.0], [624.0, 582.0]], [[605.0, 528.0], [625.0, 528.0], [625.0, 598.0], [605.0, 598.0]], [[586.0, 528.0], [602.0, 528.0], [602.0, 631.0], [586.0, 631.0]]], "lines": ["．．．結局", "見せられ", "なかったな．．．"]}, {"box": [264, 476, 364, 618], "vertical": true, "font_size": 17, "lines_coords": [[[347.0, 478.0], [364.0, 478.0], [364.0, 616.0], [347.0, 616.0]], [[326.0, 478.0], [343.0, 478.0], [343.0, 618.0], [326.0, 618.0]], [[305.0, 476.0], [322.0, 476.0], [319.0, 597.0], [303.0, 597.0]], [[284.0, 478.0], [301.0, 478.0], [301.0, 614.0], [284.0, 614.0]], [[264.0, 478.0], [279.0, 478.0], [279.0, 588.0], [264.0, 588.0]]], "lines": ["あたしが中学の時", "偶然再会したのに、", "自意識と卑屈が", "邪魔して話しかけ", "られなかった。"]}, {"box": [125, 241, 206, 398], "vertical": true, "font_size": 18, "lines_coords": [[[186.0, 241.0], [206.0, 241.0], [206.0, 329.0], [186.0, 329.0]], [[165.0, 241.0], [185.0, 241.0], [185.0, 363.0], [165.0, 363.0]], [[145.0, 241.0], [165.0, 241.0], [165.0, 398.0], [145.0, 398.0]], [[125.0, 242.0], [141.0, 242.0], [141.0, 346.0], [125.0, 346.0]]], "lines": ["子供の頃に", "母親が働いてた", "工場でよく見かけた", "弁当屋の息子"]}, {"box": [106, 292, 118, 325], "vertical": true, "font_size": 18, "lines_coords": [[[106.0, 292.0], [118.0, 292.0], [118.0, 325.0], [106.0, 325.0]]], "lines": ["．．．"]}, {"box": [112, 514, 215, 669], "vertical": true, "font_size": 17, "lines_coords": [[[194.0, 514.0], [215.0, 514.0], [215.0, 576.0], [194.0, 576.0]], [[172.0, 514.0], [192.0, 514.0], [192.0, 587.0], [172.0, 587.0]], [[153.0, 515.0], [169.0, 515.0], [169.0, 652.0], [153.0, 652.0]], [[132.0, 514.0], [148.0, 514.0], [148.0, 669.0], [132.0, 669.0]], [[112.0, 514.0], [128.0, 514.0], [128.0, 633.0], [112.0, 633.0]]], "lines": ["．．．まぁ、", "むこうも", "あたしの事なんか", "憶えちゃいなかった", "だろうけど．．．"]}, {"box": [631, 761, 735, 882], "vertical": true, "font_size": 19, "lines_coords": [[[715.0, 761.0], [735.0, 761.0], [733.0, 871.0], [713.0, 871.0]], [[695.0, 762.0], [713.0, 762.0], [711.0, 849.0], [693.0, 849.0]], [[674.0, 762.0], [691.0, 762.0], [691.0, 866.0], [674.0, 866.0]], [[652.0, 762.0], [670.0, 762.0], [671.0, 882.0], [653.0, 882.0]], [[631.0, 761.0], [651.0, 761.0], [651.0, 833.0], [631.0, 833.0]]], "lines": ["．．．その男の子、", "今どこかで", "幸さんの漫画", "読んでるといい", "ですね！！"]}, {"box": [370, 759, 388, 847], "vertical": true, "font_size": 17, "lines_coords": [[[370.0, 760.0], [387.0, 760.0], [387.0, 812.0], [370.0, 812.0]]], "lines": ["別にー"]}, {"box": [101, 984, 183, 1088], "vertical": true, "font_size": 19, "lines_coords": [[[166.0, 985.0], [183.0, 985.0], [181.0, 1088.0], [164.0, 1088.0]], [[144.0, 984.0], [164.0, 984.0], [161.0, 1073.0], [141.0, 1073.0]], [[121.0, 985.0], [141.0, 985.0], [141.0, 1073.0], [121.0, 1073.0]], [[101.0, 985.0], [121.0, 985.0], [121.0, 1057.0], [101.0, 1057.0]]], "lines": ["とっくの昔に", "通り過ぎた", "出来事です", "けども．．．"]}], "img_path": "147.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [649, 42, 750, 201], "vertical": true, "font_size": 16, "lines_coords": [[[733.0, 43.0], [750.0, 43.0], [749.0, 199.0], [732.0, 199.0]], [[712.0, 43.0], [727.0, 43.0], [727.0, 201.0], [712.0, 201.0]], [[692.0, 44.0], [708.0, 44.0], [708.0, 198.0], [692.0, 198.0]], [[670.0, 44.0], [686.0, 44.0], [686.0, 181.0], [670.0, 181.0]], [[649.0, 42.0], [665.0, 42.0], [667.0, 113.0], [651.0, 113.0]]], "lines": ["．．．でも仮にもう一度", "再会できたとしても、", "自分が中途半端じゃ", "偶然がまた無駄に", "なる．．．．．"]}, {"box": [518, 117, 597, 255], "vertical": true, "font_size": 16, "lines_coords": [[[581.0, 118.0], [597.0, 118.0], [597.0, 220.0], [581.0, 220.0]], [[559.0, 118.0], [576.0, 118.0], [576.0, 255.0], [559.0, 255.0]], [[538.0, 118.0], [555.0, 118.0], [555.0, 253.0], [538.0, 253.0]], [[518.0, 117.0], [534.0, 117.0], [534.0, 221.0], [518.0, 221.0]]], "lines": ["偶然を奇跡に", "変えるのは、結局", "日頃の自分の行い", "なんだよな．．．"]}, {"box": [352, 1, 382, 97], "vertical": true, "font_size": 30, "lines_coords": [[[352.0, 1.0], [382.0, 1.0], [382.0, 97.0], [352.0, 97.0]]], "lines": ["．．．お兄ちゃんは、そうですか"]}, {"box": [650, 536, 692, 643], "vertical": true, "font_size": 17, "lines_coords": [[[672.0, 539.0], [692.0, 539.0], [692.0, 628.0], [672.0, 628.0]], [[650.0, 536.0], [670.0, 536.0], [672.0, 643.0], [652.0, 643.0]]], "lines": ["懐かしいな", "あの工場．．．"]}, {"box": [103, 314, 205, 452], "vertical": true, "font_size": 17, "lines_coords": [[[187.0, 315.0], [203.0, 315.0], [203.0, 434.0], [187.0, 434.0]], [[167.0, 315.0], [183.0, 315.0], [183.0, 419.0], [167.0, 419.0]], [[146.0, 315.0], [162.0, 315.0], [162.0, 452.0], [146.0, 452.0]], [[123.0, 314.0], [142.0, 314.0], [142.0, 403.0], [123.0, 403.0]], [[103.0, 314.0], [123.0, 314.0], [123.0, 392.0], [103.0, 392.0]]], "lines": ["．．．などと自分に", "言い聞かせて", "てきあがったのが", "今のあたし", "なのです。"]}, {"box": [529, 592, 618, 693], "vertical": true, "font_size": 17, "lines_coords": [[[602.0, 594.0], [618.0, 594.0], [618.0, 671.0], [602.0, 671.0]], [[583.0, 594.0], [599.0, 594.0], [599.0, 686.0], [583.0, 686.0]], [[564.0, 594.0], [581.0, 594.0], [581.0, 693.0], [564.0, 693.0]], [[545.0, 592.0], [562.0, 592.0], [562.0, 687.0], [545.0, 687.0]], [[529.0, 595.0], [542.0, 595.0], [542.0, 677.0], [529.0, 677.0]]], "lines": ["十代の頃は", "不思議ちゃん", "気取りでよく", "そこから夜空", "眺めてたわ。"]}, {"box": [687, 783, 725, 887], "vertical": true, "font_size": 16, "lines_coords": [[[708.0, 783.0], [725.0, 783.0], [725.0, 869.0], [708.0, 869.0]], [[687.0, 783.0], [704.0, 783.0], [704.0, 887.0], [687.0, 887.0]]], "lines": ["．．．すごい！！", "まさに偶然！！"]}, {"box": [103, 597, 206, 737], "vertical": true, "font_size": 20, "lines_coords": [[[186.0, 598.0], [206.0, 598.0], [206.0, 687.0], [186.0, 687.0]], [[167.0, 600.0], [183.0, 600.0], [183.0, 718.0], [167.0, 718.0]], [[145.0, 598.0], [165.0, 598.0], [165.0, 737.0], [145.0, 737.0]], [[124.0, 598.0], [144.0, 598.0], [141.0, 720.0], [121.0, 720.0]], [[103.0, 597.0], [125.0, 597.0], [125.0, 644.0], [103.0, 644.0]]], "lines": ["そこで見た", "星空がさっきの", "「天の川」って絵の", "モチーフなんだ", "よね。"]}, {"box": [588, 882, 680, 991], "vertical": true, "font_size": 16, "lines_coords": [[[664.0, 882.0], [680.0, 882.0], [680.0, 976.0], [664.0, 976.0]], [[644.0, 883.0], [660.0, 883.0], [660.0, 976.0], [644.0, 976.0]], [[625.0, 883.0], [641.0, 883.0], [641.0, 976.0], [625.0, 976.0]], [[606.0, 883.0], [623.0, 883.0], [623.0, 976.0], [606.0, 976.0]], [[588.0, 883.0], [603.0, 883.0], [603.0, 991.0], [588.0, 991.0]]], "lines": ["だって今日は", "七夕ですよ！？", "今日これから", "その男の子と", "奇跡の再会が！？"]}, {"box": [360, 982, 422, 1100], "vertical": true, "font_size": 18, "lines_coords": [[[401.0, 982.0], [422.0, 982.0], [422.0, 1053.0], [401.0, 1053.0]], [[383.0, 983.0], [399.0, 983.0], [399.0, 1100.0], [383.0, 1100.0]], [[360.0, 983.0], [378.0, 983.0], [379.0, 1059.0], [361.0, 1059.0]]], "lines": ["そういう", "キラキラしたの", "いらんて。"]}], "img_path": "148.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [685, 50, 735, 164], "vertical": true, "font_size": 21, "lines_coords": [[[711.0, 50.0], [735.0, 50.0], [735.0, 164.0], [711.0, 164.0]], [[685.0, 50.0], [706.0, 50.0], [706.0, 141.0], [685.0, 141.0]]], "lines": ["心配すんな", "ゲス美！！"]}, {"box": [577, 139, 681, 276], "vertical": true, "font_size": 21, "lines_coords": [[[660.0, 139.0], [681.0, 139.0], [681.0, 232.0], [660.0, 232.0]], [[633.0, 140.0], [654.0, 140.0], [654.0, 233.0], [633.0, 233.0]], [[605.0, 141.0], [625.0, 141.0], [625.0, 276.0], [605.0, 276.0]], [[577.0, 141.0], [598.0, 141.0], [598.0, 232.0], [577.0, 232.0]]], "lines": ["あたしは", "成功して", "社会の強者に", "なるっ！！"]}, {"box": [347, 48, 456, 187], "vertical": true, "font_size": 24, "lines_coords": [[[432.0, 49.0], [456.0, 49.0], [456.0, 141.0], [432.0, 141.0]], [[404.0, 49.0], [427.0, 49.0], [427.0, 187.0], [404.0, 187.0]], [[376.0, 49.0], [399.0, 49.0], [399.0, 187.0], [376.0, 187.0]], [[347.0, 48.0], [371.0, 48.0], [371.0, 187.0], [347.0, 187.0]]], "lines": ["ゲス美が", "行き遅れても", "あたしが面倒", "見てやるさ！！"]}, {"box": [118, 162, 168, 273], "vertical": true, "font_size": 22, "lines_coords": [[[144.0, 162.0], [168.0, 162.0], [168.0, 273.0], [144.0, 273.0]], [[118.0, 164.0], [139.0, 164.0], [139.0, 271.0], [118.0, 271.0]]], "lines": ["マジすか！！", "マジすか！！"]}, {"box": [653, 349, 739, 488], "vertical": true, "font_size": 17, "lines_coords": [[[714.0, 351.0], [731.0, 351.0], [731.0, 471.0], [714.0, 471.0]], [[692.0, 349.0], [708.0, 349.0], [708.0, 487.0], [692.0, 487.0]], [[673.0, 351.0], [690.0, 351.0], [690.0, 453.0], [673.0, 453.0]], [[653.0, 351.0], [670.0, 351.0], [670.0, 458.0], [653.0, 458.0]]], "lines": ["．．．昼江ちゃんも", "旦那に捨てられた", "時はあたしが", "養ってあげる。"]}, {"box": [141, 390, 226, 529], "vertical": true, "font_size": 20, "lines_coords": [[[197.0, 391.0], [223.0, 390.0], [226.0, 455.0], [200.0, 457.0]], [[181.0, 392.0], [201.0, 392.0], [201.0, 529.0], [181.0, 529.0]], [[161.0, 392.0], [179.0, 392.0], [176.0, 496.0], [159.0, 496.0]], [[141.0, 393.0], [158.0, 393.0], [158.0, 486.0], [141.0, 486.0]]], "lines": ["．．．フン。", "アンタの自己満の", "餌になるのは", "ゴメンだね。"]}, {"box": [686, 621, 736, 708], "vertical": true, "font_size": 25, "lines_coords": [[[715.0, 622.0], [736.0, 622.0], [736.0, 708.0], [715.0, 708.0]], [[686.0, 621.0], [711.0, 621.0], [711.0, 691.0], [686.0, 691.0]]], "lines": ["あっはっ", "はっ！！"]}, {"box": [639, 759, 668, 841], "vertical": true, "font_size": 25, "lines_coords": [[[639.0, 759.0], [668.0, 759.0], [668.0, 841.0], [639.0, 841.0]]], "lines": ["勝つ！！"]}, {"box": [598, 1028, 649, 1094], "vertical": true, "font_size": 29, "lines_coords": [[[618.0, 1028.0], [649.0, 1028.0], [649.0, 1094.0], [618.0, 1094.0]], [[598.0, 1030.0], [625.0, 1030.0], [625.0, 1083.0], [598.0, 1083.0]]], "lines": ["．．．何に", "だよ。"]}, {"box": [152, 882, 201, 962], "vertical": true, "font_size": 25, "lines_coords": [[[175.0, 882.0], [201.0, 882.0], [201.0, 944.0], [175.0, 944.0]], [[152.0, 882.0], [176.0, 882.0], [176.0, 962.0], [152.0, 962.0]]], "lines": ["ゲス美", "重い．．．"]}], "img_path": "149.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "150.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [673, 59, 727, 125], "vertical": true, "font_size": 29, "lines_coords": [[[694.0, 59.0], [727.0, 59.0], [727.0, 108.0], [694.0, 108.0]], [[673.0, 59.0], [704.0, 59.0], [704.0, 125.0], [673.0, 125.0]]], "lines": ["でわ", "でわ！！"]}, {"box": [582, 72, 631, 168], "vertical": true, "font_size": 29, "lines_coords": [[[600.0, 72.0], [631.0, 72.0], [631.0, 135.0], [600.0, 135.0]], [[582.0, 73.0], [602.0, 73.0], [602.0, 168.0], [582.0, 168.0]]], "lines": ["いって", "参ります！！"]}, {"box": [446, 59, 469, 146], "vertical": true, "font_size": 21, "lines_coords": [[[446.0, 59.0], [467.0, 59.0], [469.0, 146.0], [448.0, 146.0]]], "lines": ["ほーい。"]}, {"box": [168, 44, 189, 103], "vertical": true, "font_size": 21, "lines_coords": [[[168.0, 44.0], [189.0, 44.0], [189.0, 103.0], [168.0, 103.0]]], "lines": ["よし！！"]}, {"box": [103, 141, 167, 230], "vertical": true, "font_size": 21, "lines_coords": [[[145.0, 141.0], [167.0, 141.0], [167.0, 199.0], [145.0, 199.0]], [[125.0, 142.0], [145.0, 142.0], [145.0, 230.0], [125.0, 230.0]], [[103.0, 141.0], [125.0, 141.0], [125.0, 199.0], [103.0, 199.0]]], "lines": ["三村と", "決着つけて", "こい！！"]}, {"box": [666, 513, 724, 615], "vertical": true, "font_size": 16, "lines_coords": [[[706.0, 513.0], [722.0, 513.0], [722.0, 597.0], [706.0, 597.0]], [[687.0, 513.0], [702.0, 513.0], [702.0, 615.0], [687.0, 615.0]], [[666.0, 513.0], [682.0, 513.0], [682.0, 589.0], [666.0, 589.0]]], "lines": ["．．．すんなり", "仲直りすれば", "いいけど。"]}, {"box": [134, 315, 217, 438], "vertical": true, "font_size": 20, "lines_coords": [[[190.0, 315.0], [217.0, 315.0], [217.0, 357.0], [190.0, 357.0]], [[172.0, 316.0], [192.0, 316.0], [194.0, 438.0], [174.0, 438.0]], [[154.0, 319.0], [171.0, 319.0], [171.0, 438.0], [154.0, 438.0]], [[134.0, 318.0], [151.0, 318.0], [151.0, 421.0], [134.0, 421.0]]], "lines": ["内臓", "ひきずり出して", "奴の首にかけて", "やりますよ！！"]}, {"box": [221, 513, 267, 632], "vertical": true, "font_size": 21, "lines_coords": [[[238.0, 514.0], [264.0, 513.0], [267.0, 561.0], [241.0, 562.0]], [[221.0, 515.0], [241.0, 515.0], [243.0, 632.0], [223.0, 632.0]]], "lines": ["．．．ま", "大丈夫でしょ。"]}, {"box": [677, 792, 718, 919], "vertical": true, "font_size": 18, "lines_coords": [[[698.0, 793.0], [718.0, 793.0], [718.0, 868.0], [698.0, 868.0]], [[677.0, 792.0], [693.0, 792.0], [693.0, 919.0], [677.0, 919.0]]], "lines": ["．．．．．よし、", "じゃあ蟹江さん。"]}, {"box": [135, 582, 195, 703], "vertical": true, "font_size": 21, "lines_coords": [[[174.0, 582.0], [195.0, 582.0], [195.0, 652.0], [174.0, 652.0]], [[154.0, 582.0], [174.0, 582.0], [174.0, 703.0], [154.0, 703.0]], [[135.0, 583.0], [152.0, 583.0], [152.0, 691.0], [135.0, 691.0]]], "lines": ["あの二人", "なんだかんだで", "合ってるから。"]}, {"box": [563, 914, 647, 1035], "vertical": true, "font_size": 18, "lines_coords": [[[627.0, 914.0], [647.0, 914.0], [647.0, 1018.0], [627.0, 1018.0]], [[608.0, 915.0], [624.0, 915.0], [624.0, 1000.0], [608.0, 1000.0]], [[586.0, 914.0], [604.0, 914.0], [602.0, 1019.0], [584.0, 1019.0]], [[565.0, 914.0], [585.0, 914.0], [583.0, 1035.0], [563.0, 1035.0]]], "lines": ["我々は帰って", "次の原稿に", "取りかかりま", "しょうかね．．．"]}, {"box": [178, 952, 222, 1048], "vertical": true, "font_size": 20, "lines_coords": [[[200.0, 952.0], [221.0, 952.0], [222.0, 1048.0], [201.0, 1048.0]], [[178.0, 953.0], [197.0, 953.0], [197.0, 1031.0], [178.0, 1031.0]]], "lines": ["．．．あのさぁ", "南条．．．．．"]}], "img_path": "151.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [650, 74, 679, 147], "vertical": true, "font_size": 29, "lines_coords": [[[650.0, 75.0], [679.0, 75.0], [679.0, 147.0], [650.0, 147.0]]], "lines": ["．．．ん？"]}, {"box": [188, 186, 223, 273], "vertical": true, "font_size": 18, "lines_coords": [[[210.0, 188.0], [223.0, 188.0], [223.0, 270.0], [210.0, 270.0]], [[188.0, 186.0], [205.0, 186.0], [205.0, 273.0], [188.0, 273.0]]], "lines": ["あんま無理", "すんなよ？"]}, {"box": [124, 318, 206, 458], "vertical": true, "font_size": 18, "lines_coords": [[[186.0, 318.0], [206.0, 318.0], [206.0, 390.0], [186.0, 390.0]], [[165.0, 321.0], [181.0, 321.0], [181.0, 455.0], [165.0, 455.0]], [[144.0, 322.0], [164.0, 322.0], [164.0, 458.0], [144.0, 458.0]], [[124.0, 319.0], [145.0, 319.0], [145.0, 379.0], [124.0, 379.0]]], "lines": ["あんたは", "なんてもかんでも", "一人で抱えようと", "し過ぎ。"]}, {"box": [608, 557, 709, 713], "vertical": true, "font_size": 18, "lines_coords": [[[690.0, 558.0], [709.0, 558.0], [709.0, 663.0], [690.0, 663.0]], [[668.0, 557.0], [686.0, 557.0], [687.0, 683.0], [670.0, 683.0]], [[649.0, 558.0], [666.0, 558.0], [665.0, 713.0], [647.0, 713.0]], [[629.0, 560.0], [645.0, 560.0], [645.0, 662.0], [629.0, 662.0]], [[608.0, 561.0], [624.0, 561.0], [624.0, 696.0], [608.0, 696.0]]], "lines": ["来年になれば", "子持ちなんだし、", "もっとバランス感覚", "覚えたほうが", "いいんじゃない？"]}, {"box": [680, 787, 721, 864], "vertical": true, "font_size": 18, "lines_coords": [[[699.0, 787.0], [721.0, 787.0], [721.0, 843.0], [699.0, 843.0]], [[680.0, 788.0], [700.0, 788.0], [700.0, 864.0], [680.0, 864.0]]], "lines": ["．．．性分", "なんだよ。"]}, {"box": [559, 809, 640, 930], "vertical": true, "font_size": 18, "lines_coords": [[[620.0, 809.0], [640.0, 809.0], [640.0, 880.0], [620.0, 880.0]], [[602.0, 812.0], [618.0, 812.0], [618.0, 930.0], [602.0, 930.0]], [[582.0, 813.0], [598.0, 813.0], [598.0, 897.0], [582.0, 897.0]], [[559.0, 810.0], [576.0, 810.0], [577.0, 903.0], [561.0, 903.0]]], "lines": ["あたしが", "他人に甘えると", "ロクな事に", "ならないし"]}, {"box": [487, 594, 571, 718], "vertical": true, "font_size": 18, "lines_coords": [[[551.0, 598.0], [571.0, 598.0], [571.0, 700.0], [551.0, 700.0]], [[530.0, 597.0], [550.0, 597.0], [550.0, 667.0], [530.0, 667.0]], [[509.0, 596.0], [529.0, 596.0], [529.0, 718.0], [509.0, 718.0]], [[489.0, 594.0], [509.0, 594.0], [507.0, 659.0], [487.0, 659.0]]], "lines": ["いつかパンク", "しそうで", "見ててハラハラ", "するわ。"]}, {"box": [667, 977, 748, 1099], "vertical": true, "font_size": 18, "lines_coords": [[[732.0, 979.0], [748.0, 979.0], [748.0, 1064.0], [732.0, 1064.0]], [[709.0, 977.0], [729.0, 977.0], [727.0, 1099.0], [707.0, 1099.0]], [[687.0, 977.0], [707.0, 977.0], [707.0, 1089.0], [687.0, 1089.0]], [[667.0, 978.0], [684.0, 978.0], [686.0, 1069.0], [670.0, 1069.0]]], "lines": ["．．．あんたが", "ぶっ倒れるのは", "正直あんたの", "勝手だけど、"]}, {"box": [361, 979, 463, 1127], "vertical": true, "font_size": 18, "lines_coords": [[[444.0, 979.0], [463.0, 979.0], [463.0, 1051.0], [444.0, 1051.0]], [[424.0, 980.0], [440.0, 980.0], [440.0, 1101.0], [424.0, 1101.0]], [[401.0, 979.0], [421.0, 979.0], [421.0, 1127.0], [401.0, 1127.0]], [[383.0, 980.0], [399.0, 980.0], [399.0, 1101.0], [383.0, 1101.0]], [[361.0, 980.0], [378.0, 980.0], [378.0, 1072.0], [361.0, 1072.0]]], "lines": ["親切心で", "巻き込まれてる", "あたしはただただ", "迷惑だって事を", "忘れんなよ。"]}, {"box": [113, 807, 163, 1010], "vertical": true, "font_size": 18, "lines_coords": [[[142.0, 807.0], [162.0, 807.0], [162.0, 878.0], [142.0, 878.0]], [[134.0, 922.0], [151.0, 922.0], [151.0, 1007.0], [134.0, 1007.0]], [[113.0, 919.0], [130.0, 919.0], [130.0, 1006.0], [113.0, 1006.0]]], "lines": ["それは．．．", "気を付ける", "ごめん．．．．．"]}], "img_path": "152.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [486, 57, 571, 144], "vertical": true, "font_size": 18, "lines_coords": [[[550.0, 57.0], [571.0, 57.0], [571.0, 128.0], [550.0, 128.0]], [[524.0, 58.0], [544.0, 58.0], [544.0, 144.0], [524.0, 144.0]], [[506.0, 58.0], [522.0, 58.0], [522.0, 144.0], [506.0, 144.0]], [[486.0, 58.0], [502.0, 58.0], [502.0, 144.0], [486.0, 144.0]]], "lines": ["．．．あとは", "小野寺君の", "問題が解決", "すればね．．．"]}, {"box": [312, 73, 395, 194], "vertical": true, "font_size": 18, "lines_coords": [[[376.0, 75.0], [395.0, 75.0], [395.0, 145.0], [376.0, 145.0]], [[356.0, 76.0], [372.0, 76.0], [372.0, 193.0], [356.0, 193.0]], [[333.0, 73.0], [350.0, 73.0], [353.0, 193.0], [337.0, 193.0]], [[312.0, 73.0], [333.0, 73.0], [333.0, 127.0], [312.0, 127.0]]], "lines": ["．．．そんな", "一方的な責任感", "小野寺君は喜ぶ", "かね？"]}, {"box": [160, 130, 244, 250], "vertical": true, "font_size": 18, "lines_coords": [[[220.0, 130.0], [244.0, 130.0], [244.0, 193.0], [220.0, 193.0]], [[201.0, 132.0], [221.0, 132.0], [221.0, 236.0], [201.0, 236.0]], [[182.0, 132.0], [197.0, 132.0], [197.0, 250.0], [182.0, 250.0]], [[161.0, 130.0], [178.0, 130.0], [176.0, 237.0], [160.0, 237.0]]], "lines": ["．．．でも、", "いずれにせよ", "あの人は永遠に", "悩み続けるし、"]}, {"box": [695, 233, 760, 367], "vertical": true, "font_size": 18, "lines_coords": [[[735.0, 234.0], [760.0, 234.0], [760.0, 308.0], [735.0, 308.0]], [[716.0, 233.0], [736.0, 233.0], [734.0, 336.0], [714.0, 336.0]], [[695.0, 233.0], [715.0, 233.0], [716.0, 367.0], [697.0, 367.0]]], "lines": ["．．．帰って", "くるのを待つ", "しかないでしょ。"]}, {"box": [579, 310, 678, 414], "vertical": true, "font_size": 18, "lines_coords": [[[658.0, 310.0], [675.0, 310.0], [678.0, 399.0], [660.0, 399.0]], [[640.0, 312.0], [657.0, 312.0], [657.0, 413.0], [640.0, 413.0]], [[618.0, 311.0], [636.0, 311.0], [637.0, 406.0], [619.0, 406.0]], [[598.0, 312.0], [615.0, 312.0], [615.0, 414.0], [598.0, 414.0]], [[579.0, 314.0], [593.0, 314.0], [593.0, 404.0], [579.0, 404.0]]], "lines": ["これはもう", "恋愛感情じゃ", "ないけれど、", "全部あたしの", "責任だから"]}, {"box": [657, 498, 722, 619], "vertical": true, "font_size": 18, "lines_coords": [[[706.0, 498.0], [722.0, 498.0], [722.0, 594.0], [706.0, 594.0]], [[682.0, 499.0], [699.0, 499.0], [699.0, 592.0], [682.0, 592.0]], [[657.0, 498.0], [677.0, 498.0], [677.0, 616.0], [657.0, 616.0]]], "lines": ["．．．まともな", "幸せなんて", "望んでないし、"]}, {"box": [133, 300, 233, 420], "vertical": true, "font_size": 18, "lines_coords": [[[216.0, 300.0], [233.0, 300.0], [233.0, 419.0], [216.0, 419.0]], [[195.0, 300.0], [212.0, 300.0], [212.0, 403.0], [195.0, 403.0]], [[174.0, 300.0], [190.0, 300.0], [190.0, 420.0], [174.0, 420.0]], [[152.0, 300.0], [169.0, 300.0], [171.0, 419.0], [153.0, 419.0]], [[133.0, 300.0], [149.0, 300.0], [149.0, 377.0], [133.0, 377.0]]], "lines": ["だったら今度は", "その苦しみも", "全部受け入れて", "あげなきゃって", "思ってる。"]}, {"box": [144, 762, 214, 895], "vertical": true, "font_size": 20, "lines_coords": [[[193.0, 765.0], [213.0, 765.0], [213.0, 861.0], [193.0, 861.0]], [[171.0, 765.0], [187.0, 765.0], [187.0, 895.0], [171.0, 895.0]], [[144.0, 762.0], [168.0, 762.0], [168.0, 832.0], [144.0, 832.0]]], "lines": ["あたし達は", "それがお似合い", "なんだ。"]}, {"box": [677, 964, 723, 1061], "vertical": true, "font_size": 20, "lines_coords": [[[702.0, 965.0], [722.0, 965.0], [722.0, 1061.0], [702.0, 1061.0]], [[677.0, 964.0], [697.0, 964.0], [699.0, 1051.0], [679.0, 1051.0]]], "lines": ["歪んでるよ", "あんたら。"]}, {"box": [118, 1016, 163, 1116], "vertical": true, "font_size": 20, "lines_coords": [[[142.0, 1017.0], [162.0, 1017.0], [162.0, 1116.0], [142.0, 1116.0]], [[118.0, 1016.0], [138.0, 1016.0], [138.0, 1087.0], [118.0, 1087.0]]], "lines": ["望むところ", "ですよ。"]}], "img_path": "153.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [674, 82, 738, 153], "vertical": true, "font_size": 20, "lines_coords": [[[715.0, 83.0], [738.0, 83.0], [738.0, 138.0], [715.0, 138.0]], [[695.0, 82.0], [718.0, 83.0], [715.0, 153.0], [693.0, 152.0]], [[674.0, 83.0], [695.0, 83.0], [695.0, 142.0], [674.0, 142.0]]], "lines": ["．．．実は", "さっきの", "絵の話、"]}, {"box": [579, 151, 660, 264], "vertical": true, "font_size": 20, "lines_coords": [[[640.0, 151.0], [660.0, 151.0], [660.0, 264.0], [640.0, 264.0]], [[620.0, 153.0], [637.0, 153.0], [637.0, 256.0], [620.0, 256.0]], [[600.0, 154.0], [617.0, 154.0], [617.0, 256.0], [600.0, 256.0]], [[579.0, 154.0], [596.0, 154.0], [596.0, 261.0], [579.0, 261.0]]], "lines": ["あたし本当は", "天の川なんて", "一度も見た事", "ないんだよね。"]}, {"box": [208, 189, 269, 310], "vertical": true, "font_size": 20, "lines_coords": [[[247.0, 189.0], [267.0, 189.0], [269.0, 310.0], [249.0, 310.0]], [[228.0, 191.0], [248.0, 191.0], [248.0, 261.0], [228.0, 261.0]], [[208.0, 191.0], [228.0, 191.0], [228.0, 284.0], [208.0, 284.0]]], "lines": ["こんな郊外じゃ", "３等星が", "せいぜいで、"]}, {"box": [133, 344, 199, 483], "vertical": true, "font_size": 20, "lines_coords": [[[178.0, 344.0], [199.0, 344.0], [199.0, 423.0], [178.0, 423.0]], [[155.0, 344.0], [175.0, 344.0], [175.0, 479.0], [155.0, 479.0]], [[133.0, 344.0], [149.0, 344.0], [149.0, 483.0], [133.0, 483.0]]], "lines": ["あの絵に", "描いてあるのは", "全部大嘘なんだ。"]}, {"box": [625, 601, 708, 721], "vertical": true, "font_size": 18, "lines_coords": [[[690.0, 602.0], [706.0, 602.0], [706.0, 687.0], [690.0, 687.0]], [[668.0, 602.0], [685.0, 602.0], [685.0, 721.0], [668.0, 721.0]], [[647.0, 602.0], [664.0, 602.0], [664.0, 720.0], [647.0, 720.0]], [[625.0, 601.0], [646.0, 601.0], [646.0, 660.0], [625.0, 660.0]]], "lines": ["子供の頃は", "見えないものを", "見えるって言い", "張って、"]}, {"box": [112, 626, 194, 771], "vertical": true, "font_size": 17, "lines_coords": [[[176.0, 628.0], [193.0, 628.0], [193.0, 732.0], [176.0, 732.0]], [[155.0, 628.0], [172.0, 628.0], [172.0, 765.0], [155.0, 765.0]], [[134.0, 629.0], [151.0, 629.0], [151.0, 765.0], [134.0, 765.0]], [[112.0, 626.0], [130.0, 626.0], [131.0, 769.0], [113.0, 769.0]]], "lines": ["見えなくても", "どこかにあるって", "信じる事が唯一の", "希望の時もあって、"]}, {"box": [620, 863, 701, 991], "vertical": true, "font_size": 16, "lines_coords": [[[684.0, 864.0], [700.0, 864.0], [700.0, 984.0], [684.0, 984.0]], [[663.0, 864.0], [679.0, 864.0], [679.0, 951.0], [663.0, 951.0]], [[641.0, 867.0], [658.0, 867.0], [658.0, 984.0], [641.0, 984.0]], [[620.0, 863.0], [637.0, 863.0], [638.0, 991.0], [622.0, 991.0]]], "lines": ["今はその過去を", "捨てる事で", "一歩前に進んだ", "気分になってる。"]}, {"box": [110, 983, 190, 1137], "vertical": true, "font_size": 17, "lines_coords": [[[169.0, 983.0], [189.0, 983.0], [189.0, 1072.0], [1