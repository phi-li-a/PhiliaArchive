25.0], [654.0, 617.0], [638.0, 617.0]]], "lines": ["．．．そんなに", "緊張しなくて", "大丈夫だよ。"]}, {"box": [649, 788, 690, 897], "vertical": true, "font_size": 20, "lines_coords": [[[667.0, 788.0], [690.0, 788.0], [690.0, 842.0], [667.0, 842.0]], [[650.0, 789.0], [666.0, 789.0], [666.0, 895.0], [650.0, 895.0]]], "lines": ["．．．前の", "学校の先生も、"]}, {"box": [123, 569, 181, 706], "vertical": true, "font_size": 16, "lines_coords": [[[164.0, 569.0], [180.0, 569.0], [180.0, 672.0], [164.0, 672.0]], [[142.0, 569.0], [159.0, 569.0], [159.0, 706.0], [142.0, 706.0]], [[123.0, 569.0], [139.0, 569.0], [139.0, 664.0], [123.0, 664.0]]], "lines": ["すぐみんなと", "仲良くなれるから", "がんばって。"]}, {"box": [124, 937, 162, 1047], "vertical": true, "font_size": 16, "lines_coords": [[[144.0, 938.0], [160.0, 938.0], [160.0, 1024.0], [144.0, 1024.0]], [[124.0, 937.0], [140.0, 937.0], [140.0, 1047.0], [124.0, 1047.0]]], "lines": ["おんなじ事", "言ってました。"]}], "img_path": "264.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [697, 236, 756, 346], "vertical": true, "font_size": 17, "lines_coords": [[[736.0, 236.0], [756.0, 236.0], [756.0, 308.0], [736.0, 308.0]], [[718.0, 237.0], [734.0, 237.0], [734.0, 339.0], [718.0, 339.0]], [[697.0, 237.0], [713.0, 237.0], [713.0, 345.0], [697.0, 345.0]]], "lines": ["．．．そんな", "安易な励まし", "いらないです。"]}, {"box": [384, 33, 404, 110], "vertical": true, "font_size": 17, "lines_coords": [[[384.0, 33.0], [404.0, 33.0], [404.0, 110.0], [384.0, 110.0]]], "lines": ["．．．確かに、"]}, {"box": [287, 105, 367, 228], "vertical": true, "font_size": 17, "lines_coords": [[[351.0, 105.0], [367.0, 105.0], [367.0, 175.0], [351.0, 175.0]], [[330.0, 106.0], [346.0, 106.0], [346.0, 228.0], [330.0, 228.0]], [[308.0, 105.0], [324.0, 105.0], [324.0, 223.0], [308.0, 223.0]], [[288.0, 105.0], [304.0, 105.0], [303.0, 194.0], [287.0, 194.0]]], "lines": ["僕は君を", "よく知らないし。", "正直まだあまり", "興味もない"]}, {"box": [467, 277, 525, 404], "vertical": true, "font_size": 16, "lines_coords": [[[508.0, 278.0],