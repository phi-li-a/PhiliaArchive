4.0], [133.0, 344.0]]], "lines": ["この絵", "捨てんの？"]}, {"box": [665, 526, 711, 631], "vertical": true, "font_size": 18, "lines_coords": [[[694.0, 529.0], [711.0, 529.0], [711.0, 631.0], [694.0, 631.0]], [[667.0, 526.0], [687.0, 526.0], [685.0, 615.0], [665.0, 615.0]]], "lines": ["おつかれっす", "美雪さん！！"]}, {"box": [590, 576, 630, 663], "vertical": true, "font_size": 18, "lines_coords": [[[610.0, 576.0], [630.0, 576.0], [630.0, 648.0], [610.0, 648.0]], [[590.0, 578.0], [606.0, 578.0], [606.0, 663.0], [590.0, 663.0]]], "lines": ["ウィッス", "ウィッス！！"]}, {"box": [656, 769, 735, 874], "vertical": true, "font_size": 18, "lines_coords": [[[714.0, 769.0], [735.0, 769.0], [735.0, 841.0], [714.0, 841.0]], [[695.0, 771.0], [712.0, 771.0], [712.0, 874.0], [695.0, 874.0]], [[673.0, 769.0], [693.0, 769.0], [693.0, 842.0], [673.0, 842.0]], [[656.0, 772.0], [670.0, 772.0], [670.0, 862.0], [656.0, 862.0]]], "lines": ["来週から", "アシスタント", "呼ぶから", "場所の確保。"]}, {"box": [357, 744, 417, 865], "vertical": true, "font_size": 16, "lines_coords": [[[397.0, 744.0], [414.0, 744.0], [415.0, 864.0], [398.0, 864.0]], [[377.0, 744.0], [393.0, 744.0], [393.0, 828.0], [377.0, 828.0]], [[357.0, 745.0], [373.0, 745.0], [373.0, 864.0], [357.0, 864.0]]], "lines": ["卒業アルバムも", "捨てるたぁ", "大胆な奴だな．．．"]}, {"box": [119, 578, 186, 691], "vertical": true, "font_size": 19, "lines_coords": [[[164.0, 578.0], [185.0, 578.0], [186.0, 649.0], [165.0, 649.0]], [[141.0, 581.0], [158.0, 581.0], [158.0, 683.0], [141.0, 683.0]], [[119.0, 582.0], [139.0, 582.0], [139.0, 691.0], [119.0, 691.0]]], "lines": ["あれまァ", "ゲス美ちゃん", "一人で珍しい。"]}, {"box": [647, 931, 705, 1052], "vertical": true, "font_size": 18, "lines_coords": [[[688.0, 932.0], [705.0, 932.0], [705.0, 1052.0], [688.0, 1052.0]], [[667.0, 932.0], [684.0, 932.0], [684.0, 1052.0], [667.0, 1052.0]], [[647.0, 931.0], [664.0, 931.0], [664.0, 1042.0], [647.0, 1042.0]]], "lines": ["ゲス美ちゃんに", "片付け手伝って", "もらってんの。"]}, {"box": [235, 1098, 303, 1128], "vertical": false, "font_size": 22, "lines_coord