12.0, 60.0], [712.0, 146.0], [695.0, 146.0]]], "lines": ["変わってない", "ふりしてる", "だけだろ？"]}, {"box": [376, 62, 476, 199], "vertical": true, "font_size": 16, "lines_coords": [[[459.0, 62.0], [475.0, 62.0], [475.0, 165.0], [459.0, 165.0]], [[438.0, 63.0], [454.0, 63.0], [454.0, 182.0], [438.0, 182.0]], [[417.0, 62.0], [433.0, 62.0], [433.0, 182.0], [417.0, 182.0]], [[395.0, 63.0], [412.0, 63.0], [412.0, 199.0], [395.0, 199.0]], [[376.0, 62.0], [392.0, 62.0], [392.0, 165.0], [376.0, 165.0]]], "lines": ["どれだけ人生", "充実してるかを", "他人と比較する", "ために集まってん", "じゃねーの？"]}, {"box": [166, 205, 231, 309], "vertical": true, "font_size": 18, "lines_coords": [[[212.0, 205.0], [231.0, 205.0], [231.0, 277.0], [212.0, 277.0]], [[190.0, 205.0], [210.0, 205.0], [210.0, 309.0], [190.0, 309.0]], [[166.0, 205.0], [182.0, 205.0], [185.0, 298.0], [168.0, 298.0]]], "lines": ["．．．お前も", "そうなんだろ", "晴見センセ。"]}, {"box": [521, 322, 600, 428], "vertical": true, "font_size": 16, "lines_coords": [[[583.0, 324.0], [599.0, 324.0], [599.0, 426.0], [583.0, 426.0]], [[562.0, 323.0], [578.0, 323.0], [578.0, 408.0], [562.0, 408.0]], [[542.0, 322.0], [559.0, 322.0], [557.0, 427.0], [540.0, 427.0]], [[521.0, 324.0], [537.0, 324.0], [537.0, 413.0], [521.0, 413.0]]], "lines": ["こういう場所", "来れる奴は", "そういう余裕", "ある奴だけ"]}, {"box": [114, 332, 173, 437], "vertical": true, "font_size": 18, "lines_coords": [[[152.0, 332.0], [172.0, 332.0], [172.0, 420.0], [152.0, 420.0]], [[134.0, 333.0], [151.0, 333.0], [151.0, 419.0], [134.0, 419.0]], [[114.0, 335.0], [131.0, 335.0], [131.0, 437.0], [114.0, 437.0]]], "lines": ["相変わらず", "きっついな", "関くんは．．．"]}], "img_path": "237.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [616, 120, 685, 254], "vertical": true, "font_size": 20, "lines_coords": [[[667.0, 125.0], [684.0, 125.0], [684.0, 217.0], [667.0, 217.0]], [[640.0, 123.0], [660.0, 123.0], [660.0, 254.0], [640.0, 254.0]], [[616.0, 120.0], [640.0, 120.0], [640.0, 192.0], [616.0, 192.0]]], "lines": ["お二人とも", "