9.0, 954.0], [637.0, 977.0], [452.0, 953.0]], [[482.0, 1038.0], [563.0, 1045.0], [562.0, 1063.0], [481.0, 1056.0]], [[479.0, 1066.0], [507.0, 1066.0], [507.0, 1082.0], [479.0, 1082.0]], [[476.0, 1074.0], [613.0, 1092.0], [611.0, 1114.0], [474.0, 1096.0]], [[478.0, 1091.0], [585.0, 1104.0], [583.0, 1122.0], [475.0, 1109.0]]], "lines": ["集団体験を使ったから、教室（１７）教師が残りました。駅のメールージージャーマーケースですが、", "実際日段を語ったカルト教団（〇）教訓のメンセージ・ニャニヤニヤ動画から素敵", "もうもふお兄ちゃま今日が世界最後の夜です", "はははなくひとつ", "いくつもような〜「７月７日月の川と希望がすれ」ってコレ今まで活躍なのです。", "も・２５〜７月７日水の川と海城のってコレ今来てる池星群の事？"]}], "img_path": "167.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "168.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [460, 924, 479, 1051], "vertical": true, "font_size": 16, "lines_coords": [[[460.0, 924.0], [476.0, 924.0], [476.0, 1047.0], [460.0, 1047.0]]], "lines": ["彼は思いました。"]}, {"box": [309, 921, 412, 1061], "vertical": true, "font_size": 18, "lines_coords": [[[394.0, 924.0], [411.0, 924.0], [411.0, 1010.0], [394.0, 1010.0]], [[370.0, 921.0], [390.0, 921.0], [391.0, 1061.0], [371.0, 1061.0]], [[351.0, 924.0], [367.0, 924.0], [367.0, 1060.0], [351.0, 1060.0]], [[331.0, 924.0], [347.0, 924.0], [347.0, 1060.0], [331.0, 1060.0]], [[309.0, 923.0], [329.0, 923.0], [329.0, 1026.0], [309.0, 1026.0]]], "lines": ["ああやって", "燃え尽きるように", "一瞬で消える事が", "できたらとんなに", "楽だろう、と。"]}], "img_path": "169.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [473, 467, 514, 539], "vertical": true, "font_size": 21, "lines_coords": [[[492.0, 467.0], [513.0, 467.0], [514.0, 539.0], [493.0, 539.0]]], "lines": ["流れ星が"]}, {"box": [469, 467, 495, 527], "vertical": true, "font_size": 22, "lines_coords": [[[469.0, 467.0], [495.0, 467.0], [495.0, 527.0], [469.0, 527.0]]], "lines": ["ひとつ、"]}, {"box": [404, 467, 426, 575], "vertical": true, "font_size": 22, "lines_coords": [[[404.0, 467.0], [424.0, 467.0], [426.0, 575.0], [406.0, 575.0]]], "lines": ["またひとつと、"]}, {"box": [321, 467, 360, 546], "vertical": true, "font_size": 39, "lines_coords": [[[321.0, 467.0], [360.0, 467.0], [360.0, 546.0], [321.0, 546.0]]], "lines": ["流れてゆきます。"]}, {"box": [317, 466, 361, 547], "vertical": true, "font_size": 22, "lines_coords": [[[339.0, 468.0], [361.0, 468.0], [361.0, 522.0], [339.0, 522.0]], [[317.0, 466.0], [337.0, 466.0], [339.0, 547.0], [319.0, 547.0]]], "lines": ["流れて", "ゆきます。"]}, {"box": [452, 1011, 492, 1122], "vertical": true, "font_size": 18, "lines_coords": [[[469.0, 1012.0], [489.0, 1012.0], [492.0, 1117.0], [472.0, 1117.0]], [[452.0, 1013.0], [468.0, 1013.0], [468.0, 1120.0], [452.0, 1120.0]]], "lines": ["嬉しくもなく", "悲しくもなく、"]}, {"box": [323, 1011, 492, 1120], "vertical": true, "font_size": 19, "lines_coords": [[[342.0, 1012.0], [361.0, 1012.0], [361.0, 1101.0], [342.0, 1101.0]]], "lines": ["彼は疲れて"]}, {"box": [363, 1013, 383, 1088], "vertical": true, "font_size": 18, "lines_coords": [[[363.0, 1013.0], [383.0, 1013.0], [383.0, 1088.0], [363.0, 1088.0]]], "lines": ["ただただ、"]}, {"box": [323, 1013, 339, 1085], "vertical": true, "font_size": 18, "lines_coords": [[[323.0, 1013.0], [339.0, 1013.0], [339.0, 1085.0], [323.0, 1085.0]]], "lines": ["いました。"]}], "img_path": "170.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [577, 418, 637, 529], "vertical": true, "font_size": 20, "lines_coords": [[[619.0, 420.0], [636.0, 420.0], [636.0, 526.0], [619.0, 526.0]], [[593.0, 418.0], [619.0, 418.0], [619.0, 479.0], [593.0, 479.0]], [[577.0, 420.0], [593.0, 420.0], [593.0, 526.0], [577.0, 526.0]]], "lines": ["愛子ちゃんも、", "神様も、", "もういません。"]}, {"box": [501, 418, 540, 522], "vertical": true, "font_size": 16, "lines_coords": [[[522.0, 420.0], [538.0, 420.0], [538.0, 521.0], [522.0, 521.0]], [[501.0, 420.0], [517.0, 420.0], [517.0, 509.0], [501.0, 509.0]]], "lines": ["残った片方の", "目も閉じて、"]}, {"box": [375, 418, 456, 538], "vertical": true, "font_size": 16, "lines_coords": [[[438.0, 419.0], [455.0, 419.0], [453.0, 506.0], [435.0, 506.0]], [[415.0, 418.0], [432.0, 418.0], [434.0, 527.0], [418.0, 527.0]], [[397.0, 419.0], [413.0, 419.0], [413.0, 537.0], [397.0, 537.0]], [[376.0, 420.0], [392.0, 420.0], [392.0, 512.0], [376.0, 512.0]]], "lines": ["明日の事は", "何も気にせず、", "やっとゆっくり", "眠れるんだ。"]}, {"box": [241, 416, 305, 540], "vertical": true, "font_size": 20, "lines_coords": [[[287.0, 419.0], [303.0, 419.0], [303.0, 539.0], [287.0, 539.0]], [[265.0, 419.0], [282.0, 419.0], [282.0, 521.0], [265.0, 521.0]], [[241.0, 416.0], [267.0, 416.0], [267.0, 466.0], [241.0, 466.0]]], "lines": ["．．．そんなふうに", "彼は思ったの", "です。"]}, {"box": [426, 941, 449, 1086], "vertical": true, "font_size": 20, "lines_coords": [[[427.0, 943.0], [447.0, 943.0], [447.0, 1080.0], [427.0, 1080.0]]], "lines": ["．．．おやすみ"]}], "img_path": "171.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [586, 216, 639, 408], "vertical": true, "font_size": 50, "lines_coords": [[[586.0, 217.0], [636.0, 216.0], [639.0, 407.0], [590.0, 408.0]]], "lines": ["プンプン。"]}], "img_path": "172.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "173.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [449, 639, 512, 780], "vertical": true, "font_size": 18, "lines_coords": [[[494.0, 641.0], [510.0, 641.0], [510.0, 744.0], [494.0, 744.0]], [[470.0, 641.0], [487.0, 641.0], [489.0, 778.0], [473.0, 778.0]], [[449.0, 639.0], [470.0, 639.0], [470.0, 700.0], [449.0, 700.0]]], "lines": ["．．．なんて事は", "絶対に許せません", "でした。"]}, {"box": [303, 641, 363, 778], "vertical": true, "font_size": 16, "lines_coords": [[[344.0, 641.0], [360.0, 641.0], [360.0, 767.0], [344.0, 767.0]], [[324.0, 642.0], [340.0, 642.0], [340.0, 778.0], [324.0, 778.0]], [[303.0, 642.0], [319.0, 642.0], [319.0, 764.0], [303.0, 764.0]]], "lines": ["これはあたしの", "わがままなのかも", "しれないけれど"]}, {"box": [666, 1012, 687, 1117], "vertical": true, "font_size": 20, "lines_coords": [[[666.0, 1012.0], [686.0, 1012.0], [686.0, 1115.0], [666.0, 1115.0]]], "lines": ["．．．起きなよ。"]}], "img_path": "174.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [510, 33, 613, 173], "vertical": true, "font_size": 18, "lines_coords": [[[593.0, 36.0], [610.0, 36.0], [610.0, 171.0], [593.0, 171.0]], [[572.0, 36.0], [589.0, 36.0], [589.0, 157.0], [572.0, 157.0]], [[550.0, 33.0], [570.0, 33.0], [571.0, 173.0], [551.0, 173.0]], [[528.0, 33.0], [548.0, 33.0], [550.0, 155.0], [530.0, 155.0]], [[510.0, 36.0], [527.0, 36.0], [527.0, 125.0], [510.0, 125.0]]], "lines": ["プンフンが苦しみ", "続けている限り", "自分はもっと強く", "ならなきゃって", "思えるから。"]}, {"box": [266, 32, 348, 180], "vertical": true, "font_size": 18, "lines_coords": [[[325.0, 32.0], [345.0, 32.0], [347.0, 144.0], [328.0, 144.0]], [[308.0, 35.0], [325.0, 35.0], [323.0, 121.0], [305.0, 121.0]], [[285.0, 35.0], [305.0, 35.0], [305.0, 139.0], [285.0, 139.0]], [[267.0, 36.0], [283.0, 36.0], [283.0, 176.0], [267.0, 176.0]]], "lines": ["．．．もう二度と、", "あたしから", "逃げだす事は", "絶対に認めません。"]}, {"box": [427, 999, 449, 1121], "vertical": true, "font_size": 20, "lines_coords": [[[427.0, 1000.0], [447.0, 1000.0], [447.0, 1119.0], [427.0, 1119.0]]], "lines": ["．．．だからもう、"]}], "img_path": "175.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [627, 474, 647, 577], "vertical": true, "font_size": 20, "lines_coords": [[[627.0, 474.0], [647.0, 474.0], [647.0, 577.0], [627.0, 577.0]]], "lines": ["つかまえた。"]}, {"box": [441, 977, 461, 1041], "vertical": true, "font_size": 20, "lines_coords": [[[441.0, 977.0], [461.0, 977.0], [461.0, 1041.0], [441.0, 1041.0]]], "lines": ["．．．君は、"]}, {"box": [438, 977, 463, 1041], "vertical": true, "font_size": 22, "lines_coords": [[[438.0, 977.0], [463.0, 977.0], [463.0, 1041.0], [438.0, 1041.0]]], "lines": ["．．．君は、"]}, {"box": [383, 976, 404, 1135], "vertical": true, "font_size": 22, "lines_coords": [[[383.0, 976.0], [402.0, 976.0], [404.0, 1135.0], [384.0, 1135.0]]], "lines": ["あたしだけのもの。"]}, {"box": [383, 976, 404, 1136], "vertical": true, "font_size": 21, "lines_coords": [[[383.0, 976.0], [404.0, 976.0], [404.0, 1136.0], [383.0, 1136.0]]], "lines": ["あたしだけのもの。"]}], "img_path": "176.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "177.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "178.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [39, 221, 84, 345], "vertical": true, "font_size": 43, "lines_coords": [[[39.0, 222.0], [82.0, 221.0], [84.0, 344.0], [42.0, 345.0]]], "lines": ["第１４４話"]}], "img_path": "179.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [552, 80, 575, 150], "vertical": true, "font_size": 23, "lines_coords": [[[552.0, 106.0], [575.0, 106.0], [575.0, 150.0], [552.0, 150.0]]], "lines": ["．．あ。"]}, {"box": [285, 475, 330, 514], "vertical": true, "font_size": 20, "lines_coords": [[[305.0, 478.0], [330.0, 478.0], [330.0, 509.0], [305.0, 509.0]], [[285.0, 475.0], [313.0, 475.0], [313.0, 514.0], [285.0, 514.0]]], "lines": ["おー", "おー"]}, {"box": [690, 814, 714, 880], "vertical": true, "font_size": 24, "lines_coords": [[[690.0, 814.0], [714.0, 814.0], [714.0, 880.0], [690.0, 880.0]]], "lines": ["．．．左目、"]}, {"box": [178, 563, 258, 667], "vertical": true, "font_size": 20, "lines_coords": [[[242.0, 567.0], [258.0, 567.0], [258.0, 635.0], [242.0, 635.0]], [[221.0, 566.0], [237.0, 566.0], [237.0, 667.0], [221.0, 667.0]], [[199.0, 563.0], [215.0, 563.0], [217.0, 651.0], [201.0, 651.0]], [[178.0, 566.0], [197.0, 566.0], [197.0, 642.0], [178.0, 642.0]]], "lines": ["無理に体", "動かさないで", "そのままで", "いいから。"]}, {"box": [220, 821, 303, 937], "vertical": true, "font_size": 18, "lines_coords": [[[283.0, 825.0], [303.0, 825.0], [301.0, 930.0], [281.0, 930.0]], [[263.0, 828.0], [279.0, 828.0], [279.0, 928.0], [263.0, 928.0]], [[237.0, 821.0], [265.0, 821.0], [265.0, 933.0], [237.0, 933.0]], [[220.0, 825.0], [236.0, 825.0], [238.0, 937.0], [222.0, 937.0]]], "lines": ["終わってから", "一日半くらい", "ずーーっと", "眠りっぱなし。"]}, {"box": [615, 914, 664, 1013], "vertical": true, "font_size": 24, "lines_coords": [[[643.0, 915.0], [664.0, 915.0], [664.0, 1013.0], [643.0, 1013.0]], [[615.0, 915.0], [641.0, 914.0], [644.0, 966.0], [617.0, 967.0]]], "lines": ["手術したん", "だよ。"]}, {"box": [119, 897, 176, 1033], "vertical": true, "font_size": 18, "lines_coords": [[[160.0, 897.0], [176.0, 897.0], [176.0, 984.0], [160.0, 984.0]], [[139.0, 898.0], [155.0, 898.0], [155.0, 1033.0], [139.0, 1033.0]], [[119.0, 897.0], [135.0, 897.0], [135.0, 1006.0], [119.0, 1006.0]]], "lines": ["さっきまで", "三村とみすずさん", "来てたんだよ。"]}], "img_path": "180.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [671, 49, 709, 152], "vertical": true, "font_size": 17, "lines_coords": [[[690.0, 49.0], [709.0, 49.0], [709.0, 137.0], [690.0, 137.0]], [[671.0, 49.0], [686.0, 49.0], [686.0, 151.0], [671.0, 151.0]]], "lines": ["別にいいん", "だけどさ．．．"]}, {"box": [172, 147, 232, 269], "vertical": true, "font_size": 16, "lines_coords": [[[214.0, 150.0], [230.0, 150.0], [230.0, 268.0], [214.0, 268.0]], [[194.0, 150.0], [210.0, 150.0], [210.0, 269.0], [194.0, 269.0]], [[173.0, 147.0], [189.0, 147.0], [188.0, 269.0], [172.0, 269.0]]], "lines": ["あまりみんなに", "迷惑かけないで", "くださいよ．．．"]}, {"box": [386, 508, 445, 613], "vertical": true, "font_size": 18, "lines_coords": [[[425.0, 508.0], [445.0, 508.0], [445.0, 580.0], [425.0, 580.0]], [[405.0, 509.0], [422.0, 509.0], [424.0, 595.0], [406.0, 595.0]], [[386.0, 508.0], [402.0, 508.0], [402.0, 612.0], [386.0, 612.0]]], "lines": ["あたしも", "帰って仕事", "しなきゃ．．．"]}, {"box": [592, 854, 617, 915], "vertical": true, "font_size": 25, "lines_coords": [[[592.0, 854.0], [617.0, 854.0], [617.0, 915.0], [592.0, 915.0]]], "lines": ["．．．ん？"]}, {"box": [156, 1018, 182, 1079], "vertical": true, "font_size": 26, "lines_coords": [[[156.0, 1018.0], [182.0, 1018.0], [182.0, 1079.0], [156.0, 1079.0]]], "lines": ["コレ？"]}], "img_path": "181.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [624, 72, 682, 189], "vertical": true, "font_size": 17, "lines_coords": [[[666.0, 72.0], [682.0, 72.0], [682.0, 140.0], [666.0, 140.0]], [[645.0, 72.0], [661.0, 72.0], [661.0, 189.0], [645.0, 189.0]], [[624.0, 72.0], [640.0, 72.0], [640.0, 162.0], [624.0, 162.0]]], "lines": ["暇過ぎて", "次の漫画の構想", "メモしてた。"]}, {"box": [577, 227, 597, 304], "vertical": true, "font_size": 17, "lines_coords": [[[577.0, 227.0], [597.0, 227.0], [597.0, 304.0], [577.0, 304.0]]], "lines": ["見たい？"]}, {"box": [339, 270, 388, 301], "vertical": false, "font_size": 14, "lines_coords": [[[344.0, 270.0], [388.0, 288.0], [384.0, 301.0], [339.0, 283.0]]], "lines": ["Ｒｏ！！ｂａｈ！"]}, {"box": [639, 501, 688, 569], "vertical": true, "font_size": 24, "lines_coords": [[[663.0, 501.0], [688.0, 501.0], [688.0, 563.0], [663.0, 563.0]], [[639.0, 501.0], [665.0, 501.0], [665.0, 569.0], [639.0, 569.0]]], "lines": ["これが", "主人公。"]}, {"box": [511, 480, 533, 543], "vertical": true, "font_size": 15, "lines_coords": [[[518.0, 480.0], [533.0, 482.0], [526.0, 543.0], [511.0, 541.0]]], "lines": ["い々早"]}, {"box": [359, 481, 398, 600], "vertical": true, "font_size": 26, "lines_coords": [[[372.0, 481.0], [398.0, 485.0], [385.0, 600.0], [359.0, 596.0]]], "lines": ["構造なり"]}, {"box": [568, 577, 589, 638], "vertical": true, "font_size": 24, "lines_coords": [[[568.0, 577.0], [589.0, 577.0], [589.0, 638.0], [568.0, 638.0]]], "lines": ["どう？"]}, {"box": [144, 662, 192, 726], "vertical": true, "font_size": 25, "lines_coords": [[[167.0, 664.0], [192.0, 664.0], [192.0, 726.0], [167.0, 726.0]], [[144.0, 662.0], [169.0, 662.0], [169.0, 725.0], [144.0, 725.0]]], "lines": ["ふざけ", "すぎ？"]}, {"box": [599, 884, 679, 1021], "vertical": true, "font_size": 18, "lines_coords": [[[663.0, 885.0], [679.0, 885.0], [679.0, 978.0], [663.0, 978.0]], [[641.0, 885.0], [658.0, 885.0], [658.0, 1021.0], [641.0, 1021.0]], [[620.0, 885.0], [637.0, 885.0], [637.0, 972.0], [620.0, 972.0]], [[599.0, 884.0], [616.0, 884.0], [616.0, 996.0], [599.0, 996.0]]], "lines": ["．．．冗談だよ", "こんなんやったら", "編集さんに", "呆れられるわ。"]}, {"box": [517, 1001, 578, 1106], "vertical": true, "font_size": 18, "lines_coords": [[[556.0, 1001.0], [578.0, 1001.0], [578.0, 1058.0], [556.0, 1058.0]], [[537.0, 1004.0], [554.0, 1004.0], [554.0, 1106.0], [537.0, 1106.0]], [[517.0, 1003.0], [534.0, 1003.0], [534.0, 1080.0], [517.0, 1080.0]]], "lines": ["今のは", "三村が描いた", "らくがき。"]}], "img_path": "182.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [685, 44, 743, 165], "vertical": true, "font_size": 16, "lines_coords": [[[727.0, 45.0], [743.0, 45.0], [743.0, 164.0], [727.0, 164.0]], [[705.0, 44.0], [721.0, 44.0], [721.0, 165.0], [705.0, 165.0]], [[685.0, 45.0], [701.0, 45.0], [701.0, 165.0], [685.0, 165.0]]], "lines": ["．．．てもそろそろ", "次の連載の事も", "考えないとな．．．"]}, {"box": [586, 142, 665, 278], "vertical": true, "font_size": 16, "lines_coords": [[[649.0, 144.0], [665.0, 144.0], [665.0, 262.0], [649.0, 262.0]], [[629.0, 142.0], [645.0, 142.0], [645.0, 278.0], [629.0, 278.0]], [[608.0, 144.0], [624.0, 144.0], [624.0, 246.0], [608.0, 246.0]], [[586.0, 144.0], [603.0, 144.0], [603.0, 263.0], [586.0, 263.0]]], "lines": ["一度走りだして", "しまったからには", "止まる訳には", "いかない訳で．．．"]}, {"box": [706, 461, 727, 536], "vertical": true, "font_size": 17, "lines_coords": [[[706.0, 461.0], [727.0, 461.0], [727.0, 536.0], [706.0, 536.0]]], "lines": ["．．．なんて、"]}, {"box": [616, 535, 674, 641], "vertical": true, "font_size": 17, "lines_coords": [[[658.0, 535.0], [674.0, 535.0], [674.0, 614.0], [658.0, 614.0]], [[637.0, 536.0], [653.0, 536.0], [653.0, 641.0], [637.0, 641.0]], [[616.0, 537.0], [632.0, 537.0], [632.0, 625.0], [616.0, 625.0]]], "lines": ["ごめんね。", "こんな話は今", "関係ないか"]}, {"box": [133, 226, 214, 389], "vertical": true, "font_size": 16, "lines_coords": [[[194.0, 226.0], [210.0, 226.0], [210.0, 364.0], [194.0, 364.0]], [[173.0, 226.0], [190.0, 226.0], [192.0, 364.0], [174.0, 364.0]], [[153.0, 228.0], [168.0, 228.0], [168.0, 382.0], [153.0, 382.0]], [[133.0, 227.0], [149.0, 227.0], [149.0, 389.0], [133.0, 389.0]]], "lines": ["下衆てもいいから", "売れる漫画描いて", "この自意識地獄から", "逃げきってやるんだ。"]}, {"box": [144, 673, 188, 735], "vertical": true, "font_size": 22, "lines_coords": [[[166.0, 673.0], [188.0, 673.0], [188.0, 730.0], [166.0, 730.0]], [[144.0, 675.0], [166.0, 673.0], [168.0, 734.0], [146.0, 735.0]]], "lines": ["今日は", "帰るよ。"]}], "img_path": "183.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [645, 87, 658, 153], "vertical": true, "font_size": 15, "lines_coords": [[[645.0, 87.0], [658.0, 87.0], [658.0, 153.0], [645.0, 153.0]]], "lines": ["あたしは"]}, {"box": [533, 185, 610, 308], "vertical": true, "font_size": 15, "lines_coords": [[[593.0, 186.0], [610.0, 186.0], [610.0, 271.0], [593.0, 271.0]], [[572.0, 185.0], [589.0, 185.0], [589.0, 308.0], [572.0, 308.0]], [[551.0, 186.0], [568.0, 186.0], [568.0, 289.0], [551.0, 289.0]], [[533.0, 188.0], [545.0, 188.0], [545.0, 276.0], [533.0, 276.0]]], "lines": ["君がどこで", "何をしてたのか", "今はなんにも", "聞かないよ。"]}, {"box": [625, 502, 663, 603], "vertical": true, "font_size": 16, "lines_coords": [[[646.0, 502.0], [663.0, 502.0], [663.0, 603.0], [646.0, 603.0]], [[625.0, 502.0], [641.0, 502.0], [641.0, 591.0], [625.0, 591.0]]], "lines": ["君が話したい", "時が来たら、"]}, {"box": [142, 532, 207, 644], "vertical": true, "font_size": 20, "lines_coords": [[[186.0, 533.0], [207.0, 533.0], [207.0, 604.0], [186.0, 604.0]], [[166.0, 533.0], [186.0, 533.0], [186.0, 605.0], [166.0, 605.0]], [[142.0, 532.0], [162.0, 532.0], [165.0, 644.0], [145.0, 644.0]]], "lines": ["その時に", "全部聞く", "つもりだから。"]}, {"box": [605, 878, 686, 1016], "vertical": true, "font_size": 18, "lines_coords": [[[666.0, 878.0], [686.0, 878.0], [686.0, 1005.0], [666.0, 1005.0]], [[646.0, 878.0], [663.0, 878.0], [663.0, 1016.0], [646.0, 1016.0]], [[626.0, 880.0], [643.0, 880.0], [643.0, 999.0], [626.0, 999.0]], [[605.0, 880.0], [622.0, 880.0], [622.0, 951.0], [605.0, 951.0]]], "lines": ["君が考えてる事、", "もし他人に上手く", "言葉で伝えられ", "ない時は、"]}, {"box": [493, 969, 552, 1088], "vertical": true, "font_size": 18, "lines_coords": [[[531.0, 969.0], [552.0, 969.0], [552.0, 1039.0], [531.0, 1039.0]], [[514.0, 970.0], [530.0, 970.0], [530.0, 1088.0], [514.0, 1088.0]], [[493.0, 969.0], [508.0, 969.0], [508.0, 1062.0], [493.0, 1062.0]]], "lines": ["あたしが", "代わりに伝えて", "あげるから。"]}], "img_path": "184.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [680, 83, 697, 174], "vertical": true, "font_size": 21, "lines_coords": [[[680.0, 83.0], [697.0, 83.0], [697.0, 174.0], [680.0, 174.0]]], "lines": ["待ってるよ。"]}, {"box": [583, 172, 626, 263], "vertical": true, "font_size": 21, "lines_coords": [[[604.0, 174.0], [624.0, 174.0], [626.0, 263.0], [606.0, 263.0]], [[583.0, 172.0], [608.0, 172.0], [608.0, 236.0], [583.0, 236.0]]], "lines": ["その時まで", "ずっと。"]}, {"box": [611, 467, 632, 525], "vertical": true, "font_size": 19, "lines_coords": [[[611.0, 467.0], [632.0, 467.0], [632.0, 525.0], [611.0, 525.0]]], "lines": ["．．．また、"]}, {"box": [548, 532, 588, 609], "vertical": true, "font_size": 19, "lines_coords": [[[567.0, 532.0], [588.0, 532.0], [588.0, 588.0], [567.0, 588.0]], [[548.0, 534.0], [564.0, 534.0], [564.0, 609.0], [548.0, 609.0]]], "lines": ["明日も", "来るから"]}], "img_path": "185.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "186.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [695, 507, 714, 612], "vertical": true, "font_size": 17, "lines_coords": [[[695.0, 507.0], [712.0, 507.0], [712.0, 610.0], [695.0, 610.0]]], "lines": ["すみません。"]}, {"box": [166, 585, 207, 622], "vertical": false, "font_size": 16, "lines_coords": [[[166.0, 585.0], [203.0, 585.0], [203.0, 602.0], [166.0, 602.0]], [[167.0, 596.0], [207.0, 596.0], [207.0, 614.0], [167.0, 614.0]], [[169.0, 609.0], [205.0, 609.0], [205.0, 622.0], [169.0, 622.0]]], "lines": ["あなたの", "約２０１８年３月１１日午前１時３１時間", "はははっ、はっはああっけあいい"]}, {"box": [141, 686, 201, 789], "vertical": true, "font_size": 18, "lines_coords": [[[179.0, 686.0], [199.0, 686.0], [201.0, 789.0], [181.0, 789.0]], [[161.0, 686.0], [178.0, 686.0], [178.0, 774.0], [161.0, 774.0]], [[141.0, 686.0], [158.0, 686.0], [158.0, 773.0], [141.0, 773.0]]], "lines": ["小野寺さんの", "ご友人の方", "ですよね？"]}, {"box": [627, 919, 728, 1074], "vertical": true, "font_size": 17, "lines_coords": [[[711.0, 919.0], [728.0, 919.0], [727.0, 1073.0], [709.0, 1073.0]], [[690.0, 919.0], [707.0, 919.0], [706.0, 1041.0], [688.0, 1041.0]], [[668.0, 921.0], [686.0, 921.0], [685.0, 1074.0], [667.0, 1074.0]], [[647.0, 921.0], [664.0, 921.0], [664.0, 1058.0], [647.0, 1058.0]], [[627.0, 921.0], [644.0, 921.0], [644.0, 1057.0], [627.0, 1057.0]]], "lines": ["殺人死体遺薬事件の", "被害者の自宅に", "小野寺さんが出入り", "していたのが目撃", "されてまして．．．"]}, {"box": [128, 1010, 192, 1115], "vertical": true, "font_size": 22, "lines_coords": [[[167.0, 1010.0], [192.0, 1010.0], [192.0, 1071.0], [167.0, 1071.0]], [[149.0, 1011.0], [169.0, 1011.0], [169.0, 1115.0], [149.0, 1115.0]], [[128.0, 1010.0], [148.0, 1010.0], [148.0, 1088.0], [128.0, 1088.0]]], "lines": ["．．．少し、", "お話伺わせて", "ください。"]}], "img_path": "187.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "188.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [174, 14, 220, 32], "vertical": false, "font_size": 16, "lines_coords": [[[174.0, 16.0], [219.0, 14.0], [220.0, 30.0], [175.0, 32.0]]], "lines": ["心竜国家"]}, {"box": [336, 112, 360, 193], "vertical": true, "font_size": 24, "lines_coords": [[[336.0, 112.0], [360.0, 112.0], [360.0, 193.0], [336.0, 193.0]]], "lines": ["はい．．．"]}], "img_path": "189.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "190.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [640, 174, 701, 263], "vertical": true, "font_size": 19, "lines_coords": [[[679.0, 174.0], [699.0, 174.0], [701.0, 263.0], [681.0, 263.0]], [[659.0, 174.0], [679.0, 174.0], [679.0, 261.0], [659.0, 261.0]], [[640.0, 175.0], [657.0, 175.0], [657.0, 260.0], [640.0, 260.0]]], "lines": ["今日はまだ", "術後なので", "簡単に．．．"]}, {"box": [610, 448, 651, 542], "vertical": true, "font_size": 20, "lines_coords": [[[631.0, 450.0], [651.0, 450.0], [651.0, 520.0], [631.0, 520.0]], [[610.0, 448.0], [630.0, 448.0], [630.0, 542.0], [610.0, 542.0]]], "lines": ["．．．じゃあ", "とりあえず、"]}, {"box": [164, 592, 223, 711], "vertical": true, "font_size": 16, "lines_coords": [[[205.0, 594.0], [221.0, 594.0], [221.0, 679.0], [205.0, 679.0]], [[185.0, 592.0], [201.0, 592.0], [201.0, 711.0], [185.0, 711.0]], [[164.0, 592.0], [180.0, 592.0], [180.0, 697.0], [164.0, 697.0]]], "lines": ["お名前から", "伺ってよろしい", "てしょうか？"]}, {"box": [180, 1021, 227, 1120], "vertical": true, "font_size": 24, "lines_coords": [[[200.0, 1021.0], [227.0, 1021.0], [227.0, 1066.0], [200.0, 1066.0]], [[180.0, 1024.0], [200.0, 1024.0], [200.0, 1120.0], [180.0, 1120.0]]], "lines": ["僕の", "名前は．．．"]}], "img_path": "191.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "192.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "193.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "194.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [110, 263, 138, 284], "vertical": false, "font_size": 9.0, "lines_coords": [[[115.0, 263.0], [138.0, 263.0], [138.0, 273.0], [115.0, 273.0]], [[110.0, 276.0], [138.0, 276.0], [138.0, 284.0], [110.0, 284.0]]], "lines": ["それの方は、", "．．．"]}, {"box": [152, 250, 224, 327], "vertical": false, "font_size": 13, "lines_coords": [[[154.0, 248.0], [192.0, 248.0], [192.0, 260.0], [154.0, 260.0]], [[153.0, 256.0], [220.0, 256.0], [220.0, 272.0], [153.0, 272.0]], [[155.0, 268.0], [220.0, 268.0], [220.0, 284.0], [155.0, 284.0]], [[155.0, 280.0], [180.0, 280.0], [180.0, 297.0], [155.0, 297.0]], [[153.0, 295.0], [220.0, 295.0], [220.0, 311.0], [153.0, 311.0]], [[153.0, 306.0], [219.0, 307.0], [219.0, 320.0], [153.0, 319.0]], [[154.0, 315.0], [180.0, 315.0], [180.0, 328.0], [154.0, 328.0]]], "lines": ["．．．", "ありえまいません！！ＣＵにご用の方はこのポケットで", "気にしちゃんのおこのボタンを押して下さい", "してさい、", "Ｔｏｗｎｔｅｒ．ｐｅｒＰａｃｋｅｒ", "１０００年１１月２０日土１０月１０日になるためにも", "やめろおめげなさい"]}, {"box": [538, 121, 634, 150], "vertical": false, "font_size": 19, "lines_coords": [[[538.0, 131.0], [632.0, 121.0], [634.0, 140.0], [541.0, 150.0]]], "lines": ["出生証明書"]}, {"box": [554, 151, 681, 181], "vertical": false, "font_size": 19.0, "lines_coords": [[[554.0, 168.0], [602.0, 168.0], [602.0, 181.0], [554.0, 181.0]], [[582.0, 154.0], [680.0, 151.0], [681.0, 175.0], [583.0, 179.0]]], "lines": ["おまえが", "普通の！！"]}, {"box": [549, 178, 690, 213], "vertical": false, "font_size": 19, "lines_coords": [[[549.0, 194.0], [687.0, 178.0], [690.0, 196.0], [551.0, 213.0]]], "lines": ["ヤツキロック。このような"]}, {"box": [602, 234, 640, 249], "vertical": false, "font_size": 12, "lines_coords": [[[602.0, 237.0], [639.0, 234.0], [640.0, 246.0], [603.0, 249.0]]], "lines": ["まさか今までも"]}, {"box": [257, 257, 379, 401], "vertical": false, "font_size": 17, "lines_coords": [[[261.0, 256.0], [356.0, 256.0], [356.0, 277.0], [261.0, 277.0]], [[260.0, 279.0], [299.0, 279.0], [299.0, 300.0], [260.0, 300.0]], [[261.0, 300.0], [333.0, 300.0], [333.0, 316.0], [261.0, 316.0]], [[261.0, 313.0], [373.0, 313.0], [373.0, 332.0], [261.0, 332.0]], [[258.0, 331.0], [373.0, 334.0], [373.0, 354.0], [258.0, 352.0]], [[261.0, 350.0], [311.0, 350.0], [311.0, 371.0], [261.0, 371.0]], [[261.0, 370.0], [328.0, 370.0], [328.0, 387.0], [261.0, 387.0]], [[261.0, 384.0], [372.0, 387.0], [372.0, 403.0], [261.0, 401.0]]], "lines": ["ＬＯＲ１ＬＤＲ８", "ＮＣＵ", "新生児集中治療室では", "私はこんな時間の誕生日まではなかったからですね！！", "ＧｒｏｗｉｎｇＣａｐｌｌｉｎｔ（）は、", "ＧＣＵ", "未熟児童（ＧＯ）", "不倫のお願いはより早戸見室なのですが、日本ではなくては"]}, {"box": [576, 411, 634, 428], "vertical": false, "font_size": 13, "lines_coords": [[[576.0, 416.0], [633.0, 411.0], [634.0, 424.0], [577.0, 428.0]]], "lines": ["上記のとかりましても"]}, {"box": [153, 996, 200, 1110], "vertical": true, "font_size": 21, "lines_coords": [[[179.0, 997.0], [200.0, 997.0], [200.0, 1073.0], [179.0, 1073.0]], [[155.0, 996.0], [176.0, 996.0], [174.0, 1110.0], [153.0, 1110.0]]], "lines": ["こんなの", "やっぱり．．．"]}, {"box": [678, 910, 726, 1007], "vertical": true, "font_size": 24, "lines_coords": [[[700.0, 910.0], [726.0, 910.0], [726.0, 972.0], [700.0, 972.0]], [[680.0, 911.0], [701.0, 911.0], [699.0, 1007.0], [678.0, 1007.0]]], "lines": ["なんて", "こった．．．"]}], "img_path": "195.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [403, 52, 564, 159], "vertical": false, "font_size": 107, "lines_coords": [[[403.0, 52.0], [564.0, 52.0], [564.0, 159.0], [403.0, 159.0]]], "lines": ["それは．．．"]}, {"box": [547, 665, 615, 798], "vertical": true, "font_size": 20, "lines_coords": [[[595.0, 666.0], [615.0, 666.0], [615.0, 760.0], [595.0, 760.0]], [[571.0, 665.0], [591.0, 665.0], [591.0, 798.0], [571.0, 798.0]], [[547.0, 665.0], [567.0, 665.0], [567.0, 761.0], [547.0, 761.0]]], "lines": ["．．．こんなの", "ただの希望じゃ", "ないか．．．"]}], "img_path": "196.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [455, 385, 479, 450], "vertical": true, "font_size": 20, "lines_coords": [[[455.0, 386.0], [475.0, 385.0], [479.0, 448.0], [459.0, 450.0]]], "lines": ["ヨッス。"]}, {"box": [166, 926, 187, 1025], "vertical": true, "font_size": 21, "lines_coords": [[[166.0, 926.0], [187.0, 926.0], [187.0, 1025.0], [166.0, 1025.0]]], "lines": ["．．．"]}], "img_path": "197.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "198.png"}, {"version": "0.2.0-beta.6", "img_width": 847, "img_height": 1200, 