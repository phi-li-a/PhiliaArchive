], [621.0, 1067.0]]], "lines": ["ヌルってなって！！", "ヌルってなって！！", "ギュウーーって", "なって！！", "ファーーッって", "なって！！"]}, {"box": [432, 962, 460, 1064], "vertical": true, "font_size": 27, "lines_coords": [[[432.0, 962.0], [460.0, 962.0], [460.0, 1064.0], [432.0, 1064.0]]], "lines": ["アフッ！！"]}, {"box": [382, 1089, 400, 1137], "vertical": true, "font_size": 27, "lines_coords": [[[382.0, 1089.0], [400.0, 1089.0], [400.0, 1137.0], [382.0, 1137.0]]], "lines": ["ッ！！"]}, {"box": [315, 960, 404, 1167], "vertical": true, "font_size": 27, "lines_coords": [[[375.0, 962.0], [404.0, 962.0], [404.0, 995.0], [375.0, 995.0]], [[315.0, 960.0], [342.0, 960.0], [346.0, 1167.0], [320.0, 1167.0]]], "lines": ["ン", "カクガクーーって"]}, {"box": [284, 959, 317, 1067], "vertical": true, "font_size": 27, "lines_coords": [[[284.0, 959.0], [317.0, 959.0], [317.0, 1067.0], [284.0, 1067.0]]], "lines": ["なって！！"]}, {"box": [252, 1233, 829, 1613], "vertical": false, "font_size": 234, "lines_coords": [[[398.0, 1267.0], [800.0, 1353.0], [751.0, 1582.0], [350.0, 1496.0]]], "lines": ["ハハハ"]}], "img_path": "096.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [391, 898, 628, 1051], "vertical": false, "font_size": 23, "lines_coords": [[[442.0, 903.0], [510.0, 900.0], [512.0, 923.0], [443.0, 926.0]], [[400.0, 934.0], [564.0, 918.0], [565.0, 939.0], [401.0, 954.0]], [[400.0, 957.0], [529.0, 940.0], [534.0, 967.0], [403.0, 984.0]], [[403.0, 984.0], [562.0, 962.0], [565.0, 987.0], [406.0, 1009.0]], [[407.0, 1009.0], [523.0, 995.0], [526.0, 1015.0], [410.0, 1029.0]]], "lines": ["インポント", "やっぱり悩んだけどやっぱりこの勝", "一番外合うと思うのでの", "高校生になって。危険性は", "たまには私と遊んで"]}, {"box": [529, 1228, 620, 1486], "vertical": true, "font_size": 24, "lines_coords": [[[595.0, 1228.0], [620.0, 1228.0], [617.0, 1439.0], [592.0, 1439.0]], [[564.0, 1234.0], [585.0, 1234.0], [585.0, 1485.0], [564.0, 1485.0]], [[529.0, 1232.0], [556.0, 1232.0], [556.0, 1367.0], [529.0, 1367.0]]], "lines": ["：そのはずなのに", "台風が過ぎ去った後の", "空のように、"]}, {"box": [398, 1229, 495, 1463], "vertical": true, "font_size": 29, "lines_coords": [[[462.0, 1229.0], [495.0, 1231.0], [492.0, 1337.0], [459.0, 1335.0]], [[431.0, 1232.0], [457.0, 1232.0], [457.0, 1462.0], [431.0, 1462.0]], [[400.0, 1231.0], [426.0, 1231.0], [425.0, 1421.0], [398.0, 1421.0]]], "lines": ["なんだか", "フンフンの頭の中は", "からっほでした。"]}], "img_path": "097.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "098.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [612, 587, 739, 768], "vertical": true, "font_size": 30, "lines_coords": [[[710.0, 590.0], [737.0, 590.0], [737.0, 717.0], [710.0, 717.0]], [[679.0, 590.0], [706.0, 590.0], [706.0, 768.0], [679.0, 768.0]], [[648.0, 589.0], [675.0, 589.0], [673.0, 765.0], [646.0, 765.0]], [[612.0, 587.0], [650.0, 587.0], [650.0, 654.0], [612.0, 654.0]]], "lines": ["太陽が空を", "勝手にどんどん", "赤く染めてゆく", "ので、"]}, {"box": [335, 587, 492, 795], "vertical": true, "font_size": 26, "lines_coords": [[[460.0, 587.0], [489.0, 587.0], [490.0, 718.0], [462.0, 718.0]], [[431.0, 590.0], [457.0, 590.0], [457.0, 793.0], [431.0, 793.0]], [[401.0, 592.0], [423.0, 592.0], [423.0, 792.0], [401.0, 792.0]], [[370.0, 590.0], [392.0, 590.0], [392.0, 743.0], [370.0, 743.0]], [[335.0, 589.0], [364.0, 589.0], [364.0, 681.0], [335.0, 681.0]]], "lines": ["フンフンは", "なんて自分勝手な", "野郎なのだろうと", "憤りすら憶え", "ました。"]}, {"box": [701, 1343, 793, 1498], "vertical": true, "font_size": 27, "lines_coords": [[[765.0, 1346.0], [793.0, 1346.0], [793.0, 1448.0], [765.0, 1448.0]], [[732.0, 1345.0], [759.0, 1345.0], [759.0, 1498.0], [732.0, 1498.0]], [[701.0, 1343.0], [728.0, 1343.0], [728.0, 1454.0], [701.0, 1454.0]]], "lines": ["無責任に", "太陽が背中を", "押すので、"]}, {"box": [478, 1344, 631, 1473], "vertical": true, "font_size": 28, "lines_coords": [[[603.0, 1345.0], [631.0, 1345.0], [631.0, 1446.0], [603.0, 1446.0]], [[571.0, 1345.0], [600.0, 1345.0], [600.0, 1473.0], [571.0, 1473.0]], [[542.0, 1345.0], [568.0, 1345.0], [568.0, 1473.0], [542.0, 1473.0]], [[510.0, 1345.0], [537.0, 1345.0], [537.0, 1450.0], [510.0, 1450.0]], [[478.0, 1346.0], [506.0, 1346.0], [506.0, 1456.0], [478.0, 1456.0]]], "lines": ["長く長く", "伸びてゆく", "自分の影は", "行き場を", "見失って、"]}, {"box": [312, 1343, 405, 1550], "vertical": true, "font_size": 30, "lines_coords": [[[378.0, 1346.0], [404.0, 1346.0], [404.0, 1525.0], [378.0, 1525.0]], [[345.0, 1345.0], [376.0, 1345.0], [376.0, 1550.0], [345.0, 1550.0]], [[312.0, 1343.0], [345.0, 1343.0], [345.0, 1437.0], [312.0, 1437.0]]], "lines": ["ただゆらゆらと", "揺れているばかり", "でした。"]}], "img_path": "099.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [782, 707, 798, 765], "vertical": true, "font_size": 16, "lines_coords": [[[782.0, 707.0], [798.0, 707.0], [798.0, 765.0], [782.0, 765.0]]], "lines": ["．．．"]}, {"box": [627, 439, 686, 636], "vertical": true, "font_size": 26, "lines_coords": [[[659.0, 442.0], [685.0, 442.0], [685.0, 582.0], [659.0, 582.0]], [[628.0, 439.0], [654.0, 439.0], [654.0, 632.0], [628.0, 632.0]]], "lines": ["「そんな所で", "何やってるの？」"]}, {"box": [421, 437, 518, 595], "vertical": true, "font_size": 30, "lines_coords": [[[489.0, 442.0], [515.0, 442.0], [515.0, 570.0], [489.0, 570.0]], [[457.0, 442.0], [484.0, 442.0], [484.0, 595.0], [457.0, 595.0]], [[421.0, 437.0], [457.0, 437.0], [457.0, 507.0], [421.0, 507.0]]], "lines": ["フンフンは", "影に問いかけ", "ます。"]}, {"box": [625, 1353, 719, 1508], "vertical": true, "font_size": 29, "lines_coords": [[[692.0, 1354.0], [718.0, 1354.0], [718.0, 1482.0], [692.0, 1482.0]], [[657.0, 1353.0], [685.0, 1353.0], [687.0, 1507.0], [659.0, 1507.0]], [[625.0, 1353.0], [657.0, 1353.0], [657.0, 1442.0], [625.0, 1442.0]]], "lines": ["問いかけは", "むなしく宙を", "舞って、"]}, {"box": [410, 1354, 503, 1536], "vertical": true, "font_size": 25, "lines_coords": [[[475.0, 1354.0], [501.0, 1354.0], [501.0, 1534.0], [475.0, 1534.0]], [[445.0, 1357.0], [467.0, 1357.0], [467.0, 1534.0], [445.0, 1534.0]], [[410.0, 1354.0], [437.0, 1354.0], [437.0, 1493.0], [410.0, 1493.0]]], "lines": ["フンフンの心に", "ゆっくり染みて", "いきました。"]}], "img_path": "100.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [150, 137, 240, 493], "vertical": true, "font_size": 32.666666666666664, "lines_coords": [[[209.0, 178.0], [240.0, 178.0], [240.0, 493.0], [209.0, 493.0]], [[179.0, 137.0], [215.0, 137.0], [210.0, 476.0], [175.0, 476.0]], [[154.0, 159.0], [185.0, 159.0], [181.0, 420.0], [150.0, 420.0]]], "lines": ["そんなことになっていた", "．．．", "このようなことは"]}, {"box": [335, 153, 371, 553], "vertical": true, "font_size": 32, "lines_coords": [[[335.0, 153.0], [371.0, 153.0], [371.0, 553.0], [335.0, 553.0]]], "lines": ["そういうことですか"]}, {"box": [443, 153, 476, 570], "vertical": true, "font_size": 32, "lines_coords": [[[443.0, 153.0], [471.0, 153.0], [476.0, 570.0], [448.0, 570.0]]], "lines": ["そういうことですが、"]}, {"box": [651, 201, 693, 431], "vertical": true, "font_size": 31, "lines_coords": [[[651.0, 203.0], [682.0, 201.0], [693.0, 429.0], [662.0, 431.0]]], "lines": ["でも、そう言っても、"]}, {"box": [753, 142, 796, 379], "vertical": true, "font_size": 31, "lines_coords": [[[753.0, 143.0], [784.0, 142.0], [796.0, 378.0], [765.0, 379.0]]], "lines": ["この国の国内側であれば、"]}, {"box": [319, 760, 645, 820], "vertical": false, "font_size": 47, "lines_coords": [[[325.0, 763.0], [635.0, 763.0], [635.0, 814.0], [325.0, 814.0]]], "lines": ["８０３，０Ｎ０ＤＨＫＡ"]}, {"box": [240, 1388, 508, 1598], "vertical": false, "font_size": 231, "lines_coords": [[[240.0, 1367.0], [508.0, 1367.0], [508.0, 1599.0], [240.0, 1599.0]]], "lines": ["．．．"]}, {"box": [789, 1121, 917, 1395], "vertical": true, "font_size": 30, "lines_coords": [[[884.0, 1121.0], [917.0, 1121.0], [917.0, 1304.0], [884.0, 1304.0]], [[845.0, 1123.0], [876.0, 1123.0], [876.0, 1395.0], [845.0, 1395.0]], [[793.0, 1125.0], [820.0, 1125.0], [815.0, 1367.0], [789.0, 1367.0]]], "lines": ["友人のところに", "遊びに行ってきます。", "朝には帰ります。"]}], "img_path": "101.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [828, 60, 954, 395], "vertical": true, "font_size": 62, "lines_coords": [[[895.0, 67.0], [954.0, 67.0], [950.0, 395.0], [890.0, 395.0]], [[835.0, 60.0], [901.0, 64.0], [892.0, 298.0], [828.0, 295.0]]], "lines": ["「じゃあ今から", "行こう？」"]}, {"box": [195, 62, 254, 301], "vertical": true, "font_size": 59, "lines_coords": [[[195.0, 62.0], [254.0, 62.0], [254.0, 301.0], [195.0, 301.0]]], "lines": ["「鹿児島！！"]}, {"box": [845, 1156, 968, 1359], "vertical": true, "font_size": 27, "lines_coords": [[[942.0, 1157.0], [968.0, 1157.0], [968.0, 1285.0], [942.0, 1285.0]], [[909.0, 1157.0], [937.0, 1157.0], [937.0, 1273.0], [909.0, 1273.0]], [[876.0, 1156.0], [903.0, 1156.0], [903.0, 1359.0], [876.0, 1359.0]], [[845.0, 1157.0], [873.0, 1157.0], [873.0, 1264.0], [845.0, 1264.0]]], "lines": ["フンフンは", "今、自分が", "なんでこんな所に", "いるのか、"]}, {"box": [757, 1154, 815, 1360], "vertical": true, "font_size": 27, "lines_coords": [[[787.0, 1156.0], [814.0, 1156.0], [815.0, 1360.0], [789.0, 1360.0]], [[757.0, 1154.0], [784.0, 1154.0], [784.0, 1268.0], [757.0, 1268.0]]], "lines": ["わからなくなって", "きました。"]}, {"box": [340, 1154, 400, 1418], "vertical": true, "font_size": 26, "lines_coords": [[[371.0, 1154.0], [398.0, 1154.0], [400.0, 1387.0], [373.0, 1387.0]], [[340.0, 1154.0], [365.0, 1154.0], [368.0, 1418.0], [343.0, 1418.0]]], "lines": ["こんなくたらなくて", "退屈な場所じゃなくて、"]}, {"box": [284, 1154, 310, 1284], "vertical": true, "font_size": 26, "lines_coords": [[[284.0, 1154.0], [310.0, 1154.0], [310.0, 1284.0], [284.0, 1284.0]]], "lines": ["もっと別の"]}, {"box": [132, 1154, 253, 1412], "vertical": true, "font_size": 26, "lines_coords": [[[226.0, 1154.0], [253.0, 1154.0], [253.0, 1412.0], [226.0, 1412.0]], [[192.0, 1154.0], [223.0, 1154.0], [223.0, 1412.0], [192.0, 1412.0]], [[162.0, 1156.0], [189.0, 1156.0], [189.0, 1387.0], [162.0, 1387.0]], [[132.0, 1159.0], [154.0, 1159.0], [154.0, 1293.0], [132.0, 1293.0]]], "lines": ["どこか遠い所に自分は", "行くべきだったんじゃ", "ないかとフンフンは", "思いました。"]}], "img_path": "102.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [591, 801, 616, 909], "vertical": true, "font_size": 17, "lines_coords": [[[593.0, 806.0], [610.0, 806.0], [610.0, 901.0], [593.0, 901.0]]], "lines": ["もしくは"]}, {"box": [468, 798, 497, 837], "vertical": true, "font_size": 21, "lines_coords": [[[471.0, 803.0], [492.0, 803.0], [492.0, 829.0], [471.0, 829.0]]], "lines": ["何"]}, {"box": [551, 1165, 614, 1279], "vertical": true, "font_size": 26, "lines_coords": [[[578.0, 1165.0], [610.0, 1165.0], [614.0, 1276.0], [581.0, 1276.0]], [[551.0, 1171.0], [579.0, 1171.0], [579.0, 1279.0], [551.0, 1279.0]]], "lines": ["それなら", "なんだか、"]}, {"box": [465, 1171, 520, 1350], "vertical": true, "font_size": 26, "lines_coords": [[[498.0, 1171.0], [520.0, 1171.0], [520.0, 1350.0], [498.0, 1350.0]], [[465.0, 1173.0], [487.0, 1173.0], [487.0, 1335.0], [465.0, 1335.0]]], "lines": ["とっても簡単な", "気がしました。"]}, {"box": [312, 1362, 371, 1457], "vertical": true, "font_size": 31, "lines_coords": [[[342.0, 1362.0], [371.0, 1373.0], [342.0, 1457.0], [312.0, 1448.0]]], "lines": ["ＴＨＡＴＳ"]}], "img_path": "103.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [850, 89, 987, 393], "vertical": true, "font_size": 25, "lines_coords": [[[960.0, 89.0], [987.0, 89.0], [987.0, 320.0], [960.0, 320.0]], [[910.0, 89.0], [937.0, 89.0], [937.0, 393.0], [910.0, 393.0]], [[879.0, 92.0], [901.0, 92.0], [901.0, 239.0], [879.0, 239.0]], [[850.0, 92.0], [871.0, 92.0], [871.0, 293.0], [850.0, 293.0]]], "lines": ["．．．いいえ違います！！", "フンフンはこんなことじゃ", "へこたれない", "頑張りっ子です！！"]}, {"box": [796, 89, 823, 243], "vertical": true, "font_size": 25, "lines_coords": [[[796.0, 89.0], [823.0, 89.0], [823.0, 243.0], [796.0, 243.0]]], "lines": ["頭脳派です！！"]}, {"box": [745, 89, 771, 395], "vertical": true, "font_size": 25, "lines_coords": [[[745.0, 89.0], [771.0, 89.0], [771.0, 395.0], [745.0, 395.0]]], "lines": ["マイトガイ（小林旭）です！！"]}, {"box": [177, 87, 330, 294], "ve