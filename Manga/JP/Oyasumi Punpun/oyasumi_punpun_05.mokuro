, [164.0, 1379.0], [142.0, 1379.0]], [[107.0, 1250.0], [134.0, 1250.0], [134.0, 1409.0], [107.0, 1409.0]]], "lines": ["部屋の電気", "消えてるの", "嫌いなんだ．．．"]}], "img_path": "047.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [90, 64, 375, 85], "vertical": false, "font_size": 21, "lines_coords": [[[90.0, 64.0], [375.0, 64.0], [375.0, 85.0], [90.0, 85.0]]], "lines": ["おやすみプンプンに"]}, {"box": [373, 779, 815, 1237], "vertical": false, "font_size": 352, "lines_coords": [[[568.0, 779.0], [815.0, 943.0], [620.0, 1237.0], [373.0, 1071.0]]], "lines": ["．．．"]}, {"box": [112, 1365, 204, 1519], "vertical": true, "font_size": 24, "lines_coords": [[[178.0, 1365.0], [200.0, 1365.0], [200.0, 1518.0], [178.0, 1518.0]], [[146.0, 1365.0], [168.0, 1365.0], [168.0, 1492.0], [146.0, 1492.0]], [[112.0, 1365.0], [140.0, 1365.0], [140.0, 1443.0], [112.0, 1443.0]]], "lines": ["ちょっとだけ", "こうしてて", "いい？"]}, {"box": [906, 1284, 968, 1415], "vertical": true, "font_size": 28, "lines_coords": [[[940.0, 1285.0], [968.0, 1285.0], [968.0, 1398.0], [940.0, 1398.0]], [[909.0, 1284.0], [937.0, 1284.0], [934.0, 1415.0], [906.0, 1415.0]]], "lines": ["．．．ごめん、", "プンプン．．．"]}], "img_path": "048.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [903, 103, 961, 259], "vertical": true, "font_size": 24, "lines_coords": [[[935.0, 106.0], [957.0, 106.0], [957.0, 257.0], [935.0, 257.0]], [[903.0, 103.0], [929.0, 103.0], [929.0, 257.0], [903.0, 257.0]]], "lines": ["．．．おかしな話", "ですけど．．．"]}, {"box": [152, 453, 274, 634], "vertical": true, "font_size": 23, "lines_coords": [[[248.0, 454.0], [270.0, 454.0], [270.0, 634.0], [248.0, 634.0]], [[215.0, 456.0], [237.0, 456.0], [237.0, 606.0], [215.0, 606.0]], [[181.0, 454.0], [207.0, 454.0], [207.0, 607.0], [181.0, 607.0]], [[153.0, 453.0], [175.0, 453.0], [175.0, 590.0], [153.0, 590.0]]], "lines": ["僕は今の彼女と", "付き合う時に", "ひとつ約束を", "したんです。"]}, {"box": [878, 745, 968, 976], "vertical": true, "font_size": 24, "lines_coords": [[[940.0, 746.0], [967.0, 746.0], [967.0, 925.0], [940.0, 925.0]], [[910.0, 746.0], [932.0, 746.0], [932.0, 975.0], [910.0, 975.0]], [[878.0, 746.0], [900.0, 746.0], [900.0, 932.0], [878.0, 932.0]]], "lines": ["＞もし僕が、君を", "深く傷つけてしまう。", "ことがあったら、"]}, {"box": [928, 1084, 956, 1212], "vertical": true, "font_size": 26, "lines_coords": [[[928.0, 1084.0], [956.0, 1084.0], [956.0, 1212.0], [928.0, 1212.0]]], "lines": ["けれど．．．"]}, {"box": [156, 804, 250, 962], "vertical": true, "font_size": 28, "lines_coords": [[[220.0, 807.0], [246.0, 807.0], [246.0, 923.0], [220.0, 923.0]], [[189.0, 807.0], [215.0, 807.0], [215.0, 937.0], [189.0, 937.0]], [[156.0, 804.0], [187.0, 804.0], [187.0, 962.0], [156.0, 962.0]]], "lines": ["”その時は", "僕を殺して", "くれ．．．って。"]}, {"box": [815, 1217, 903, 1350], "vertical": true, "font_size": 26, "lines_coords": [[[876.0, 1217.0], [903.0, 1217.0], [903.0, 1350.0], [876.0, 1350.0]], [[843.0, 1218.0], [870.0, 1218.0], [870.0, 1348.0], [843.0, 1348.0]], [[815.0, 1218.0], [837.0, 1218.0], [837.0, 1345.0], [815.0, 1345.0]]], "lines": ["彼女は僕を", "殺しません", "てした．．．"]}, {"box": [248, 1203, 276, 1306], "vertical": true, "font_size": 26, "lines_coords": [[[248.0, 1203.0], [276.0, 1203.0], [276.0, 1306.0], [248.0, 1306.0]]], "lines": ["僕を．．．．．"]}, {"box": [151, 1309, 209, 1485], "vertical": true, "font_size": 26, "lines_coords": [[[182.0, 1309.0], [209.0, 1309.0], [209.0, 1439.0], [182.0, 1439.0]], [[151.0, 1309.0], [175.0, 1309.0], [176.0, 1485.0], [153.0, 1485.0]]], "lines": ["こんな僕を", "許したんです．．．"]}], "img_path": "049.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [906, 112, 931, 266], "vertical": true, "font_size": 22, "lines_coords": [[[906.0, 112.0], [928.0, 112.0], [928.0, 264.0], [906.0, 264.0]]], "lines": ["このことが．．．"]}, {"box": [167, 275, 222, 430], "vertical": true, "font_size": 22, "lines_coords": [[[198.0, 276.0], [220.0, 276.0], [220.0, 403.0], [198.0, 403.0]], [[167.0, 276.0], [189.0, 276.0], [189.0, 426.0], [167.0, 426.0]]], "lines": ["なによりも", "辛かった．．．"]}, {"box": [876, 579, 966, 773], "vertical": true, "font_size": 25, "lines_coords": [[[942.0, 581.0], [964.0, 581.0], [964.0, 748.0], [942.0, 748.0]], [[909.0, 579.0], [935.0, 579.0], [935.0, 737.0], [909.0, 737.0]], [[876.0, 579.0], [903.0, 579.0], [903.0, 773.0], [876.0, 773.0]]], "lines": ["僕は、姉と甥と", "彼女の四人で", "暮らしてました。"]}, {"box": [276, 565, 334, 778], "vertical": true, "font_size": 24, "lines_coords": [[[307.0, 565.0], [334.0, 565.0], [334.0, 778.0], [307.0, 778.0]], [[276.0, 568.0], [298.0, 568.0], [298.0, 732.0], [276.0, 732.0]]], "lines": ["．．．けど、今になって", "わかったんだ。"]}, {"box": [121, 648, 210, 828], "vertical": true, "font_size": 24, "lines_coords": [[[184.0, 648.0], [210.0, 648.0], [210.0, 817.0], [184.0, 817.0]], [[153.0, 650.0], [175.0, 650.0], [175.0, 828.0], [153.0, 828.0]], [[121.0, 650.0], [143.0, 650.0], [143.0, 803.0], [121.0, 803.0]]], "lines": ["僕は、あの家が", "好きなんだって", "ことを．．．．．．！！"]}, {"box": [859, 957, 918, 1114], "vertical": true, "font_size": 26, "lines_coords": [[[892.0, 957.0], [918.0, 957.0], [918.0, 1087.0], [892.0, 1087.0]], [[859.0, 957.0], [885.0, 957.0], [885.0, 1114.0], [859.0, 1114.0]]], "lines": ["僕は自分が", "嫌いです．．．"]}, {"box": [142, 1109, 238, 1267], "vertical": true, "font_size": 29, "lines_coords": [[[210.0, 1110.0], [237.0, 1110.0], [237.0, 1267.0], [210.0, 1267.0]], [[178.0, 1110.0], [204.0, 1110.0], [204.0, 1239.0], [178.0, 1239.0]], [[142.0, 1109.0], [175.0, 1109.0], [175.0, 1215.0], [142.0, 1215.0]]], "lines": ["人間はみんな", "優し過ぎる", "から．．．"]}], "img_path": "050.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [909, 73, 968, 203], "vertical": true, "font_size": 26, "lines_coords": [[[942.0, 73.0], [968.0, 73.0], [968.0, 201.0], [942.0, 201.0]], [[909.0, 73.0], [937.0, 73.0], [937.0, 203.0], [909.0, 203.0]]], "lines": ["．．．いやいや", "お客さん．．．"]}, {"box": [773, 143, 862, 303], "vertical": true, "font_size": 26, "lines_coords": [[[832.0, 143.0], [859.0, 143.0], [862.0, 281.0], [835.0, 281.0]], [[803.0, 143.0], [829.0, 143.0], [829.0, 303.0], [803.0, 303.0]], [[773.0, 145.0], [795.0, 145.0], [795.0, 281.0], [773.0, 281.0]]], "lines": ["あたしもね、", "昔はやくざ者", "てしたから、"]}, {"box": [875, 698, 963, 879], "vertical": true, "font_size": 23, "lines_coords": [[[940.0, 700.0], [962.0, 700.0], [962.0, 878.0], [940.0, 878.0]], [[906.0, 698.0], [932.0, 698.0], [932.0, 879.0], [906.0, 879.0]], [[876.0, 698.0], [898.0, 698.0], [898.0, 859.0], [876.0, 859.0]]], "lines": ["カミさんと結婚", "してなかったら", "今頃とっくに、"]}, {"box": [170, 400, 261, 582], "vertical": true, "font_size": 25, "lines_coords": [[[232.0, 400.0], [259.0, 400.0], [259.0, 582.0], [232.0, 582.0]], [[200.0, 400.0], [226.0, 400.0], [226.0, 582.0], [200.0, 582.0]], [[170.0, 400.0], [192.0, 400.0], [192.0, 537.0], [170.0, 537.0]]], "lines": ["あなたの１００倍は", "悪いことをして", "きましたよ。"]}, {"box": [879, 1049, 984, 1197], "vertical": true, "font_size": 22, "lines_coords": [[[962.0, 1050.0], [984.0, 1050.0], [984.0, 1170.0], [962.0, 1170.0]], [[935.0, 1050.0], [957.0, 1050.0], [957.0, 1189.0], [935.0, 1189.0]], [[907.0, 1050.0], [929.0, 1050.0], [929.0, 1189.0], [907.0, 1189.0]], [[879.0, 1050.0], [900.0, 1050.0], [900.0, 1196.0], [879.0, 1196.0]]], "lines": ["．．．もちろん、", "カミさんにも", "散々迷惑かけ", "ましたけどね。"]}, {"box": [154, 784, 248, 940], "vertical": true, "font_size": 29, "lines_coords": [[[215.0, 784.0], [248.0, 784.0], [248.0, 892.0], [215.0, 892.0]], [[185.0, 784.0], [212.0, 784.0], [212.0, 940.0], [185.0, 940.0]], [[154.0, 784.0], [181.0, 784.0], [181.0, 898.0], [154.0, 898.0]]], "lines": ["どこかで", "野垂れ死んで", "ましたよ。"]}, {"box": [307, 1057, 401, 1237], "vertical": true, "font_size": 30, "lines_coords": [[[373.0, 1060.0], [401.0, 1060.0], [401.0, 1165.0], [373.0, 1165.0]], [[342.0, 1057.0], [368.0, 1057.0], [368.0, 1237.0], [342.0, 1237.0]], [[307.0, 1057.0], [342.0, 1057.0], [342.0, 1100.0], [307.0, 1100.0]]], "lines": ["．．．人から", "もらった優しさ", "は、"]}, {"box": [503, 1337, 625, 1543], "vertical": true, "font_size": 26, "lines_coords": [[[595.0, 1337.0], [621.0, 1337.0], [625.0, 1490.0], [598.0, 1490.0]], [[564.0, 1337.0], [592.0, 1337.0], [593.0, 1525.0], [565.0, 1525.0]], [[532.0, 1337.0], [559.0, 1337.0], [560.0, 1543.0], [534.0, 1543.0]], [[503.0, 1337.0], [526.0, 1337.0], [528.0, 1531.0], [504.0, 1531.0]]], "lines": ["何も言わない", "女房でしたけど、", "あたしは運命の人", "だと思ってます。"]}, {"box": [137, 1326, 228, 1491], "vertical": true, "font_size": 24, "lines_coords": [[[200.0, 1326.0], [228.0, 1326.0], [228.0, 1429.0], [200.0, 1429.0]], [[170.0, 1328.0], [192.0, 1328.0], [192.0, 1479.0], [170.0, 1479.0]], [[139.0, 1329.0], [160.0, 1329.0], [160.0, 1489.0], [139.0, 1489.0]]], "lines": ["ゆっくり", "返していけば", "いいんですよ。"]}], "img_path": "051.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [882, 78, 917, 185], "vertical": true, "font_size": 32, "lines_coords": [[[882.0, 78.0], [917.0, 78.0], [917.0, 185.0], [882.0, 185.0]]], "lines": ["．．．．．でも、"]}, {"box": [776, 117, 842, 273], "vertical": true, "font_size": 32, "lines_coords": [[[809.0, 120.0], [842.0, 120.0], [842.0, 226.0], [809.0, 226.0]], [[779.0, 117.0], [806.0, 117.0], [803.0, 273.0], [776.0, 273.0]]], "lines": ["一体何を", "どうすれば．．．"]}, {"box": [610, 43, 699, 223], "vertical": true, "font_size": 24, "lines_coords": [[[671.0, 43.0], [698.0, 43.0], [696.0, 223.0], [670.0, 223.0]], [[639.0, 46.0], [665.0, 46.0], [665.0, 173.0], [639.0, 173.0]], [[610.0, 46.0], [631.0, 46.0], [631.0, 181.0], [610.0, 181.0]]], "lines": ["きっかけなんて", "いくらでも", "ありますよ。"]}, {"box": [346, 53, 405, 193], "vertical": true, "font_size": 26, "lines_coords": [[[378.0, 53.0], [404.0, 53.0], [404.0, 193.0], [378.0, 193.0]], [[346.0, 53.0], [373.0, 53.0], [373.0, 167.0], [346.0, 167.0]]], "lines": ["これ、渡して", "おきます。"]}, {"box": [236, 231, 368, 445], "vertical": true, "font_size": 31, "lines_coords": [[[340.0, 234.0], [364.0, 232.0], [368.0, 332.0], [345.0, 334.0]], [[282.0, 232.0], [320.0, 231.0], [329.0, 425.0], [292.0, 426.0]]], "lines": ["自動車交通", "エ十木〈俊夫〉"]}, {"box": [100, 262, 190, 454], "vertical": true, "font_size": 26, "lines_coords": [[[162.0, 262.0], [189.0, 262.0], [189.0, 442.0], [162.0, 442.0]], [[131.0, 264.0], [157.0, 264.0], [157.0, 445.0], [131.0, 445.0]], [[100.0, 262.0], [126.0, 262.0], [126.0, 454.0], [100.0, 454.0]]], "lines": ["こんな場末じゃ", "タクシーなんて", "走ってませんよ。"]}, {"box": [617, 509, 656, 617], "vertical": true, "font_size": 37, "lines_coords": [[[617.0, 509.0], [656.0, 509.0], [656.0, 617.0], [617.0, 617.0]]], "lines": ["いや．．．"]}, {"box": [550, 596, 585, 665], "vertical": true, "font_size": 37, "lines_coords": [[[550.0, 596.0], [585.0, 596.0], [585.0, 665.0], [550.0, 665.0]]], "lines": ["でも、"]}, {"box": [156, 618, 182, 725], "vertical": true, "font_size": 26, "lines_coords": [[[156.0, 618.0], [182.0, 618.0], [182.0, 723.0], [156.0, 723.0]]], "lines": ["僕は．．．"]}, {"box": [881, 1289, 973, 1425], "vertical": true, "font_size": 25, "lines_coords": [[[946.0, 1292.0], [973.0, 1292.0], [973.0, 1425.0], [946.0, 1425.0]], [[914.0, 1289.0], [940.0, 1289.0], [940.0, 1418.0], [914.0, 1418.0]], [[881.0, 1289.0], [907.0, 1289.0], [907.0, 1403.0], [881.0, 1403.0]]], "lines": ["いいんです、", "あたしは暇", "ですから。"]}, {"box": [784, 1345, 840, 1525], "vertical": true, "font_size": 25, "lines_coords": [[[814.0, 1346.0], [840.0, 1346.0], [840.0, 1525.0], [814.0, 1525.0]], [[784.0, 1345.0], [806.0, 1345.0], [806.0, 1456.0], [784.0, 1456.0]]], "lines": ["いつでも迎えに", "来ますよ。"]}, {"box": [106, 1329, 198, 1533], "vertical": true, "font_size": 25, "lines_coords": [[[171.0, 1329.0], [198.0, 1329.0], [198.0, 1434.0], [171.0, 1434.0]], [[142.0, 1329.0], [164.0, 1329.0], [164.0, 1509.0], [142.0, 1509.0]], [[107.0, 1329.0], [134.0, 1329.0], [132.0, 1532.0], [106.0, 1532.0]]], "lines": ["海なんて", "見てても、風邪", "ひくだけですよ？"]}], "img_path": "052.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [903, 137, 991, 278], "vertical": true, "font_size": 23, "lines_coords": [[[967.0, 139.0], [989.0, 139.0], [989.0, 264.0], [967.0, 264.0]], [[934.0, 137.0], [960.0, 137.0], [960.0, 278.0], [934.0, 278.0]], [[903.0, 137.0], [925.0, 137.0], [925.0, 246.0], [903.0, 246.0]]], "lines": ["．．．あなたは", "いずれ、帰る", "人だから"]}, {"box": [209, 212, 273, 367], "vertical": true, "font_size": 28, "lines_coords": [[[240.0, 212.0], [273.0, 212.0], [273.0, 320.0], [240.0, 320.0]], [[209.0, 212.0], [235.0, 212.0], [235.0, 367.0], [209.0, 367.0]]], "lines": ["．．．だって", "そうでしょ？"]}, {"box": [879, 678, 969, 895], "vertical": true, "font_size": 25, "lines_coords": [[[942.0, 678.0], [968.0, 678.0], [968.0, 832.0], [942.0, 832.0]], [[910.0, 678.0], [937.0, 678.0], [937.0, 895.0], [910.0, 895.0]], [[879.0, 678.0], [901.0, 678.0], [901.0, 842.0], [879.0, 842.0]]], "lines": ["あたしは馬鹿", "だから、よくわかり", "ませんけどね。"]}, {"box": [114, 376, 203, 542], "vertical": true, "font_size": 28, "lines_coords": [[[170.0, 376.0], [203.0, 376.0], [203.0, 460.0], [170.0, 460.0]], [[142.0, 379.0], [168.0, 379.0], [168.0, 532.0], [142.0, 532.0]], [[114.0, 381.0], [135.0, 381.0], [135.0, 542.0], [114.0, 542.0]]], "lines": ["帰りを", "待ってる人が", "いるんだもの。"]}, {"box": [257, 712, 379, 878], "vertical": true, "font_size": 26, "lines_coords": [[[357.0, 715.0], [379.0, 715.0], [379.0, 867.0], [357.0, 867.0]], [[323.0, 714.0], [350.0, 714.0], [350.0, 868.0], [323.0, 868.0]], [[293.0, 717.0], [315.0, 717.0], [315.0, 868.0], [293.0, 868.0]], [[257.0, 712.0], [284.0, 712.0], [287.0, 878.0], [260.0, 878.0]]], "lines": ["罪を背負った", "人間が本当に", "必要なものは", "罰じゃなくて、"]}, {"box": [617, 1025, 675, 1153], "vertical": true, "font_size": 26, "lines_coords": [[[648.0, 1025.0], [675.0, 1025.0], [675.0, 1153.0], [648.0, 1153.0]], [[617.0, 1025.0], [643.0, 1025.0], [643.0, 1134.0], [617.0, 1134.0]]], "lines": ["．．．あたしの", "カミさん、"]}, {"box": [109, 737, 232, 946], "vertical": true, "font_size": 26, "lines_coords": [[[210.0, 743.0], [232.0, 743.0], [232.0, 946.0], [210.0, 946.0]], [[176.0, 742.0], [203.0, 742.0], [203.0, 945.0], [176.0, 945.0]], [[145.0, 742.0], [171.0, 742.0], [171.0, 945.0], [145.0, 945.0]], [[109.0, 737.0], [145.0, 737.0], [145.0, 807.0], [109.0, 807.0]]], "lines": ["許される苦しみを", "知ることなんじゃ", "ないかって思うん", "です。"]}, {"box": [156, 1079, 213, 1219], "vertical": true, "font_size": 24, "lines_coords": [[[184.0, 1079.0], [210.0, 1079.0], [210.0, 1196.0], [184.0, 1196.0]], [[156.0, 1079.0], [178.0, 1079.0], [178.0, 1218.0], [156.0, 1218.0]]], "lines": ["先月、他界", "しましてね。"]}, {"box": [106, 1337, 199, 1495], "vertical": true, "font_size": 28, "lines_coords": [[[171.0, 1340.0], [198.0, 1340.0], [198.0, 1495.0], [171.0, 1495.0]], [[143.0, 1342.0], [165.0, 1342.0], [165.0, 1493.0], [143.0, 1493.0]], [[106.0, 1337.0], [142.0, 1337.0], [142.0, 1409.0], [106.0, 1409.0]]], "lines": ["．．．ひとつだけ", "後悔してるん", "です。"]}], "img_path": "053.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [915, 100, 937, 207], "vertical": true, "font_size": 26, "lines_coords": [[[915.0, 100.0], [937.0, 100.0], [937.0, 207.0], [915.0, 207.0]]], "lines": ["死に際に、"]}, {"box": [776, 209, 865, 389], "vertical": true, "font_size": 26, "lines_coords": [[[839.0, 210.0], [865.0, 210.0], [865.0, 389.0], [839.0, 389.0]], [[807.0, 209.0], [834.0, 209.0], [834.0, 367.0], [807.0, 367.0]], [[776.0, 210.0], [803.0, 210.0], [803.0, 375.0], [776.0, 375.0]]], "lines": ["ありがとうって", "言ってやれな", "かったことを。"]}, {"box": [234, 129, 295, 262], "vertical": true, "font_size": 28, "lines_coords": [[[268.0, 131.0], [295.0, 131.0], [295.0, 262.0], [268.0, 262.0]], [[234.0, 129.0], [270.0, 129.0], [270.0, 198.0], [234.0, 198.0]]], "lines": ["．．．あなたも", "まだ、"]}, {"box": [148, 293, 239, 509], "vertical": true, "font_size": 28, "lines_coords": [[[212.0, 293.0], [239.0, 293.0], [239.0, 500.0], [212.0, 500.0]], [[182.0, 296.0], [204.0, 296.0], [204.0, 509.0], [182.0, 509.0]], [[148.0, 295.0], [175.0, 295.0], [175.0, 451.0], [148.0, 451.0]]], "lines": ["何かやり残してる", "ことが、あるんじゃ", "ないですか？"]}, {"box": [234, 1060, 915, 1584], "vertical": false, "font_size": 465, "lines_coords": [[[234.0, 1121.0], [871.0, 1060.0], [915.0, 1523.0], [278.0, 1584.0]]], "lines": ["．．．"]}], "img_path": "054.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "055.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "056.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [318, 81, 862, 950], "vertical": true, "font_size": 363, "lines_coords": [[[318.0, 167.0], [671.0, 81.0], [862.0, 864.0], [509.0, 950.0]]], "lines": ["いや〜〜"]}], "img_path": "057.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [710, 87, 737, 222], "vertical": true, "font_size": 22, "lines_coords": [[[714.0, 129.0], [735.0, 129.0], [732.0, 215.0], [710.0, 215.0]]], "lines": ["―結局"]}, {"box": [532, 88, 624, 294], "vertical": true, "font_size": 21, "lines_coords": [[[600.0, 92.0], [620.0, 92.0], [620.0, 265.0], [600.0, 265.0]], [[567.0, 93.0], [589.0, 93.0], [589.0, 292.0], [567.0, 292.0]], [[532.0, 92.0], [554.0, 92.0], [557.0, 190.0], [535.0, 190.0]]], "lines": ["雄「おしさんが", "帰ってくることの", "ないまま"]}, {"box": [357, 91, 444, 227], "vertical": true, "font_size": 22, "lines_coords": [[[420.0, 93.0], [442.0, 93.0], [442.0, 189.0], [420.0, 189.0]], [[389.0, 92.0], [410.0, 92.0], [410.0, 215.0], [389.0, 215.0]], [[357.0, 93.0], [379.0, 93.0], [379.0, 223.0], [357.0, 223.0]]], "lines": ["白々しく", "夜は明けて", "ゆきました。"]}, {"box": [217, 354, 917, 1087], "vertical": true, "font_size": 558, "lines_coords": [[[364.0, 354.0], [906.0, 487.0], [759.0, 1087.0], [217.0, 954.0]]], "lines": ["．．．"]}], "img_path": "058.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [910, 185, 975, 301], "vertical": true, "font_size": 27, "lines_coords": [[[940.0, 185.0], [975.0, 185.0], [975.0, 295.0], [940.0, 295.0]], [[910.0, 189.0], [939.0, 189.0], [939.0, 301.0], [910.0, 301.0]]], "lines": ["．．．一度で", "いいから、"]}, {"box": [835, 376, 960, 589], "vertical": true, "font_size": 27, "lines_coords": [[[932.0, 376.0], [960.0, 376.0], [960.0, 460.0], [932.0, 460.0]], [[901.0, 381.0], [923.0, 381.0], [923.0, 585.0], [901.0, 585.0]], [[868.0, 379.0], [895.0, 379.0], [895.0, 589.0], [868.0, 589.0]], [[837.0, 379.0], [860.0, 379.0], [859.0, 573.0], [835.0, 573.0]]], "lines": ["あんな", "筋骨隆々の男達に", "激しく求められて", "みたいものだわ。"]}, {"box": [550, 1034, 643, 1192], "vertical": true, "font_size": 27, "lines_coords": [[[615.0, 1034.0], [642.0, 1034.0], [642.0, 1192.0], [615.0, 1192.0]], [[581.0, 1034.0], [607.0, 1034.0], [607.0, 1192.0], [581.0, 1192.0]], [[550.0, 1034.0], [578.0, 1034.0], [578.0, 1126.0], [550.0, 1126.0]]], "lines": ["家具が無いと", "案外広いのね", "この家。"]}, {"box": [142, 751, 171, 895], "vertical": true, "font_size": 26, "lines_coords": [[[142.0, 751.0], [168.0, 751.0], [168.0, 893.0], [142.0, 893.0]]], "lines": ["そうですか。"]}, {"box": [100, 1340, 192, 1525], "vertical": true, "font_size": 26, "lines_coords": [[[165.0, 1340.0], [192.0, 1340.0], [192.0, 1498.0], [165.0, 1498.0]], [[132.0, 1340.0], [160.0, 1340.0], [157.0, 1525.0], [129.0, 1525.0]], [[103.0, 1342.0], [125.0, 1342.0], [121.0, 1521.0], [100.0, 1521.0]]], "lines": ["．．．後で玄関で", "三人一緒に写真", "撮りませんか？"]}], "img_path": "059.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [909, 87, 964, 241], "vertical": true, "font_size": 22, "lines_coords": [[[940.0, 89.0], [962.0, 89.0], [962.0, 240.0], [940.0, 240.0]], [[909.0, 87.0], [931.0, 87.0], [931.0, 225.0], [909.0, 225.0]]], "lines": ["いらないわよ", "そんなもん。"]}, {"box": [675, 289, 745, 425], "vertical": true, "font_size": 36, "lines_coords": [[[701.0, 289.0], [745.0, 289.0], [745.0, 356.0], [701.0, 356.0]], [[675.0, 293.0], [703.0, 293.0], [706.0, 425.0], [678.0, 425.0]]], "lines": ["未練", "たらしい！！"]}, {"box": [93, 60, 381, 82], "vertical": false, "font_size": 22, "lines_coords": [[[93.0, 60.0], [381.0, 60.0], [381.0, 82.0], [93.0, 82.0]]], "lines": ["おやすみプンプンＥ"]}, {"box": [114, 229, 356, 464], "vertical": true, "font_size": 28, "lines_coords": [[[326.0, 231.0], [354.0, 231.0], [354.0, 362.0], [326.0, 362.0]], [[295.0, 232.0], [321.0, 232.0], [321.0, 464.0], [295.0, 464.0]], [[262.0, 232.0], [289.0, 232.0], [289.0, 462.0], [262.0, 462.0]], [[226.0, 229.0], [260.0, 229.0], [260.0, 321.0], [226.0, 321.0]], [[181.0, 232.0], [209.0, 232.0], [206.0, 364.0], [178.0, 364.0]], [[148.0, 232.0], [171.0, 232.0], [173.0, 412.0], [150.0, 412.0]], [[114.0, 229.0], [146.0, 229.0], [146.0, 325.0], [114.0, 325.0]]], "lines": ["フンフンは", "この家に引っ越して", "来てから今日までの", "ことを、", "なんとなく", "思い出してみた", "訳です。"]}, {"box": [892, 1239, 956, 1449], "vertical": true, "font_size": 30, "lines_coords": [[[917.0, 1239.0], [956.0, 1239.0], [956.0, 1325.0], [917.0, 1325.0]], [[893.0, 1243.0], [915.0, 1243.0], [915.0, 1448.0], [893.0, 1448.0]]], "lines": ["奥サン", "すいませーーん！！"]}, {"box": [100, 1306, 220, 1539], "vertical": true, "font_size": 26, "lines_coords": [[[192.0, 1307.0], [218.0, 1307.0], [218.0, 1440.0], [192.0, 1440.0]], [[157.0, 1306.0], [185.0, 1306.0], [187.0, 1515.0], [159.0, 1515.0]], [[126.0, 1309.0], [153.0, 1309.0], [153.0, 1539.0], [126.0, 1539.0]], [[100.0, 1309.0], [121.0, 1309.0], [121.0, 1462.0], [100.0, 1462.0]]], "lines": ["荷物の搬出", "終了しましたんで", "確認のサインお願い", "しまーす！！"]}], "img_path": "060.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [887, 123, 977, 334], "vertical": true, "font_size": 25, "lines_coords": [[[950.0, 125.0], [976.0, 125.0], [976.0, 278.0], [950.0, 278.0]], [[918.0, 125.0], [945.0, 125.0], [945.0, 306.0], [918.0, 306.0]], [[887.0, 123.0], [909.0, 123.0], [909.0, 329.0], [887.0, 329.0]]], "lines": ["．．．お父さんと", "ナイターを観た", "あの夏の晩たとか"]}, {"box": [257, 95, 381, 328], "vertical": true, "font_size": 27, "lines_coords": [[[353.0, 95.0], [381.0, 95.0], [378.0, 278.0], [350.0, 278.0]], [[321.0, 96.0], [348.0, 96.0], [348.0, 328.0], [321.0, 328.0]], [[289.0, 98.0], [315.0, 98.0], [315.0, 326.0], [289.0, 326.0]], [[257.0, 96.0], [284.0, 96.0], [284.0, 204.0], [257.0, 204.0]]], "lines": ["雄一おしさんが", "水ほうそうになって", "大騒ぎしたあの年の", "大晦日も、"]}, {"box": [731, 317, 851, 599], "vertical": true, "font_size": 25, "lines_coords": [[[825.0, 317.0], [851.0, 317.0], [851.0, 471.0], [825.0, 471.0]], [[796.0, 320.0], [823.0, 320.0], [823.0, 550.0], [796.0, 550.0]], [[765.0, 320.0], [787.0, 320.0], [787.0, 598.0], [765.0, 598.0]], [[731.0, 318.0], [757.0, 318.0], [757.0, 476.0], [731.0, 476.0]]], "lines": ["．．．お母さんが", "虫歯が痛いと言って", "暴れて窓カラスを割った", "あの朝だとか、"]}, {"box": [912, 691, 943, 834], "vertical": true, "font_size": 26, "lines_coords": [[[912.0, 693.0], [939.0, 693.0], [943.0, 832.0], [917.0, 832.0]]], "lines": ["．．．フンッ、"]}, {"box": [103, 354, 257, 614], "vertical": true, "font_size": 25, "lines_coords": [[[229.0, 354.0], [256.0, 354.0], [256.0, 482.0], [229.0, 482.0]], [[196.0, 354.0], [223.0, 354.0], [225.0, 610.0], [198.0, 610.0]], [[164.0, 354.0], [190.0, 354.0], [193.0, 614.0], [167.0, 614.0]], [[135.0, 357.0], [157.0, 357.0], [157.0, 584.0], [135.0, 584.0]], [[103.0, 356.0], [126.0, 356.0], [128.0, 512.0], [104.0, 512.0]]], "lines": ["翠ちゃんが", "トラマの再放送を観て", "涙が止まらなくなって", "みんなで大笑いした", "あの夕暮れも"]}, {"box": [125, 1064, 218, 1268], "vertical": true, "font_size": 28, "lines_coords": [[[187.0, 1064.0], [218.0, 1064.0], [218.0, 1248.0], [187.0, 1248.0]], [[157.0, 1067.0], [184.0, 1067.0], [184.0, 1268.0], [157.0, 1268.0]], [[125.0, 1064.0], [151.0, 1064.0], [151.0, 1170.0], [125.0, 1170.0]]], "lines": ["引っ越しなんて", "ホントあっけない", "わねっ！！"]}, {"box": [840, 1342, 869, 1535], "vertical": true, "font_size": 27, "lines_coords": [[[840.0, 1343.0], [867.0, 1343.0], [867.0, 1529.0], [840.0, 1529.0]]], "lines": ["．．．どれもこれも、"]}, {"box": [717, 1342, 782, 1526], "vertical": true, "font_size": 32, "lines_coords": [[[756.0, 1345.0], [782.0, 1345.0], [782.0, 1521.0], [756.0, 1521.0]], [[717.0, 1342.0], [756.0, 1342.0], [756.0, 1435.0], [717.0, 1435.0]]], "lines": ["きのうのことの", "ようで、"]}, {"box": [589, 1343, 651, 1522], "vertical": true, "font_size": 30, "lines_coords": [[[625.0, 1345.0], [651.0, 1345.0], [651.0, 1521.0], [625.0, 1521.0]], [[589.0, 1343.0], [623.0, 1343.0], [623.0, 1434.0], [589.0, 1434.0]]], "lines": ["遠い昔のことの", "ようで、"]}, {"box": [326, 1343, 448, 1531], "vertical": true, "font_size": 27, "lines_coords": [[[421.0, 1343.0], [448.0, 1343.0], [448.0, 1475.0], [421.0, 1475.0]], [[390.0, 1345.0], [417.0, 1345.0], [417.0, 1523.0], [390.0, 1523.0]], [[359.0, 1345.0], [385.0, 1345.0], [385.0, 1500.0], [359.0, 1500.0]], [[326.0, 1345.0], [353.0, 1345.0], [353.0, 1526.0], [326.0, 1526.0]]], "lines": ["こうやって", "訳もわからずに", "毎日は過ぎて", "ゆくのだな、と"]}, {"box": [212, 1343, 274, 1483], "vertical": true, "font_size": 25, "lines_coords": [[[246.0, 1345.0], [273.0, 1345.0], [273.0, 1475.0], [246.0, 1475.0]], [[215.0, 1343.0], [239.0, 1343.0], [235.0, 1482.0], [212.0, 1482.0]]], "lines": ["フンフンは", "思いました。"]}], "img_path": "061.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [912, 90, 943, 195], "vertical": true, "font_size": 28, "lines_coords": [[[912.0, 90.0], [940.0, 90.0], [943.0, 195.0], [915.0, 195.0]]], "lines": ["．．．じゃ、"]}, {"box": [751, 142, 875, 300], "vertical": true, "font_size": 28, "lines_coords": [[[846.0, 142.0], [875.0, 142.0], [875.0, 246.0], [846.0, 246.0]], [[815.0, 142.0], [842.0, 142.0], [842.0, 300.0], [815.0, 300.0]], [[782.0, 143.0], [809.0, 143.0], [809.0, 275.0], [782.0, 275.0]], [[751.0, 142.0], [778.0, 142.0], [778.0, 279.0], [751.0, 279.0]]], "lines": ["アタシは", "引っ越し屋と", "一緒に新居", "向かうけど、"]}, {"box": [142, 456, 271, 661], "vertical": true, "font_size": 26, "lines_coords": [[[245.0, 457.0], [271.0, 457.0], [271.0, 590.0], [245.0, 590.0]], [[210.0, 456.0], [237.0, 456.0], [237.0, 660.0], [210.0, 660.0]], [[175.0, 457.0], [201.0, 457.0], [201.0, 610.0], [175.0, 610.0]], [[142.0, 457.0], [168.0, 457.0], [168.0, 568.0], [142.0, 568.0]]], "lines": ["翠ちゃんと", "プンプンはゴミの", "後片付け諸々", "頼むわね。"]}, {"