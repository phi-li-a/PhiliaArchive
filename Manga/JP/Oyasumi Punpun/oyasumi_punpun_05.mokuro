, 285.0], [743.0, 285.0], [743.0, 332.0], [726.0, 332.0]]], "lines": ["．．．"]}, {"box": [934, 429, 964, 585], "vertical": true, "font_size": 27, "lines_coords": [[[937.0, 429.0], [964.0, 429.0], [960.0, 585.0], [934.0, 585.0]]], "lines": ["おーちゃん．．．"]}, {"box": [842, 554, 901, 684], "vertical": true, "font_size": 27, "lines_coords": [[[873.0, 554.0], [901.0, 554.0], [901.0, 659.0], [873.0, 659.0]], [[842.0, 554.0], [868.0, 554.0], [868.0, 684.0], [842.0, 684.0]]], "lines": ["服くらい", "着なよ．．．"]}, {"box": [256, 464, 364, 673], "vertical": true, "font_size": 23, "lines_coords": [[[342.0, 468.0], [364.0, 468.0], [364.0, 642.0], [342.0, 642.0]], [[312.0, 464.0], [339.0, 464.0], [337.0, 632.0], [310.0, 632.0]], [[284.0, 467.0], [310.0, 467.0], [310.0, 632.0], [284.0, 632.0]], [[256.0, 465.0], [278.0, 465.0], [278.0, 673.0], [256.0, 673.0]]], "lines": ["家売って、手元に", "ちょっとお金が", "残ったからって", "気休め程度でしょ？"]}, {"box": [637, 1012, 703, 1143], "vertical": true, "font_size": 29, "lines_coords": [[[667.0, 1012.0], [700.0, 1012.0], [703.0, 1134.0], [670.0, 1134.0]], [[640.0, 1015.0], [668.0, 1015.0], [665.0, 1143.0], [637.0, 1143.0]]], "lines": ["．．．あっ、", "何、その顔。"]}, {"box": [528, 1067, 617, 1242], "vertical": true, "font_size": 29, "lines_coords": [[[587.0, 1067.0], [615.0, 1067.0], [617.0, 1175.0], [589.0, 1175.0]], [[554.0, 1068.0], [587.0, 1068.0], [587.0, 1203.0], [554.0, 1203.0]], [[528.0, 1073.0], [550.0, 1073.0], [550.0, 1242.0], [528.0, 1242.0]]], "lines": ["ちょっと", "ヤダァー", "やめてよォー！！"]}, {"box": [157, 710, 264, 920], "vertical": true, "font_size": 23, "lines_coords": [[[242.0, 710.0], [264.0, 710.0], [264.0, 873.0], [242.0, 873.0]], [[214.0, 710.0], [235.0, 710.0], [235.0, 896.0], [214.0, 896.0]], [[185.0, 710.0], [207.0, 710.0], [207.0, 873.0], [185.0, 873.0]], [[157.0, 710.0], [179.0, 710.0], [179.0, 920.0], [157.0, 920.0]]], "lines": ["アタシもこんな", "しみったれた生活", "続ける気なんて", "サラサラないけど！！"]}, {"box": [139, 1078, 228, 1268], "vertical": true, "font_size": 25, "lines_coords": [[[200.0, 1079.0], [228.0, 1079.0], [228.0, 1196.0], [200.0, 1196.0]], [[168.0, 1078.0], [195.0, 1078.0], [195.0, 1268.0], [168.0, 1268.0]], [[139.0, 1081.0], [160.0, 1081.0], [160.0, 1259.0], [139.0, 1259.0]]], "lines": ["「奥サンと", "別れてーッ」とか", "言うと思った！？"]}, {"box": [131, 1325, 218, 1509], "vertical": true, "font_size": 25, "lines_coords": [[[192.0, 1326.0], [218.0, 1326.0], [218.0, 1481.0], [192.0, 1481.0]], [[159.0, 1325.0], [190.0, 1325.0], [190.0, 1509.0], [159.0, 1509.0]], [[131.0, 1328.0], [153.0, 1328.0], [153.0, 1506.0], [131.0, 1506.0]]], "lines": ["そこらへんの", "馬鹿女と一緒に", "しないでくれる"]}, {"box": [100, 1381, 123, 1431], "vertical": true, "font_size": 25, "lines_coords": [[[100.0, 1381.0], [123.0, 1381.0], [123.0, 1431.0], [100.0, 1431.0]]], "lines": ["！？"]}], "img_path": "111.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [401, 65, 428, 195], "vertical": true, "font_size": 22, "lines_coords": [[[403.0, 65.0], [425.0, 65.0], [425.0, 195.0], [403.0, 195.0]]], "lines": ["．．．だよね！！"]}, {"box": [868, 650, 956, 900], "vertical": true, "font_size": 25, "lines_coords": [[[934.0, 650.0], [956.0, 650.0], [956.0, 900.0], [934.0, 900.0]], [[900.0, 653.0], [926.0, 653.0], [926.0, 831.0], [900.0, 831.0]], [[868.0, 651.0], [895.0, 651.0], [895.0, 837.0], [868.0, 837.0]]], "lines": ["そういうおーちゃんの", "一人でも生きて", "いける強いトコ、"]}, {"box": [75, 421, 193, 625], "vertical": true, "font_size": 24, "lines_coords": [[[164.0, 421.0], [190.0, 421.0], [193.0, 578.0], [167.0, 578.0]], [[134.0, 421.0], [160.0, 421.0], [160.0, 579.0], [134.0, 579.0]], [[106.0, 425.0], [128.0, 425.0], [128.0, 625.0], [106.0, 625.0]], [[75.0, 423.0], [96.0, 423.0], [96.0, 551.0], [75.0, 551.0]]], "lines": ["おーちゃんは", "そんな小さく", "収まる器じゃない", "もんナァ！！"]}, {"box": [767, 779, 825, 950], "vertical": true, "font_size": 25, "lines_coords": [[[798.0, 779.0], [825.0, 779.0], [825.0, 896.0], [798.0, 896.0]], [[767.0, 779.0], [789.0, 779.0], [789.0, 950.0], [767.0, 950.0]]], "lines": ["俺、やっぱ", "好きだわ～～．．．"]}, {"box": [800, 1073, 835, 1205], "vertical": true, "font_size": 22, "lines_coords": [[[806.0, 1125.0], [828.0, 1125.0], [828.0, 1195.0], [806.0, 1195.0]]], "lines": ["手を"]}, {"box": [276, 1128, 298, 1267], "vertical": true, "font_size": 28, "lines_coords": [[[276.0, 1128.0], [298.0, 1128.0], [298.0, 1267.0], [276.0, 1267.0]]], "lines": ["．．．もういい。"]}, {"box": [360, 1387, 415, 1551], "vertical": true, "font_size": 55, "lines_coords": [[[360.0, 1387.0], [415.0, 1387.0], [415.0, 1551.0], [360.0, 1551.0]]], "lines": ["＞ゲーム"]}, {"box": [184, 1306, 246, 1462], "vertical": true, "font_size": 28, "lines_coords": [[[220.0, 1307.0], [246.0, 1307.0], [246.0, 1462.0], [220.0, 1462.0]], [[184.0, 1306.0], [220.0, 1306.0], [220.0, 1376.0], [184.0, 1376.0]]], "lines": ["今日はアタシ", "帰る。"]}, {"box": [268, 1559, 310, 1600], "vertical": false, "font_size": 41, "lines_coords": [[[268.0, 1559.0], [310.0, 1559.0], [310.0, 1600.0], [268.0, 1600.0]]], "lines": ["アパマまっ"]}], "img_path": "112.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [851, 86, 948, 300], "vertical": true, "font_size": 43, "lines_coords": [[[895.0, 89.0], [943.0, 87.0], [948.0, 298.0], [900.0, 300.0]], [[851.0, 87.0], [889.0, 87.0], [889.0, 293.0], [851.0, 293.0]]], "lines": ["アァ～～～", "～～～アッ！！"]}, {"box": [157, 384, 270, 626], "vertical": true, "font_size": 33, "lines_coords": [[[235.0, 384.0], [268.0, 384.0], [268.0, 556.0], [235.0, 556.0]], [[195.0, 384.0], [228.0, 384.0], [231.0, 626.0], [198.0, 626.0]], [[157.0, 384.0], [190.0, 384.0], [195.0, 570.0], [162.0, 570.0]]], "lines": ["明日、地球が", "無くなっちゃえば", "いいのにっ！！"]}], "img_path": "113.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "114.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "115.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [18, 290, 68, 456], "vertical": true, "font_size": 50, "lines_coords": [[[18.0, 290.0], [68.0, 290.0], [68.0, 456.0], [18.0, 456.0]]], "lines": ["第５２話"]}, {"box": [875, 1060, 903, 1178], "vertical": true, "font_size": 26, "lines_coords": [[[875.0, 1062.0], [901.0, 1062.0], [901.0, 1175.0], [875.0, 1175.0]]], "lines": ["．．．．．．退屈。"]}, {"box": [668, 1317, 764, 1509], "vertical": true, "font_size": 30, "lines_coords": [[[729.0, 1317.0], [764.0, 1317.0], [764.0, 1401.0], [729.0, 1401.0]], [[698.0, 1318.0], [729.0, 1318.0], [729.0, 1478.0], [698.0, 1478.0]], [[670.0, 1318.0], [693.0, 1318.0], [692.0, 1504.0], [668.0, 1504.0]]], "lines": ["今日は", "ハカみたいに", "天気がいいから"]}, {"box": [300, 1317, 426, 1527], "vertical": true, "font_size": 29, "lines_coords": [[[398.0, 1318.0], [426.0, 1318.0], [423.0, 1450.0], [395.0, 1450.0]], [[362.0, 1317.0], [396.0, 1317.0], [396.0, 1403.0], [362.0, 1403.0]], [[332.0, 1317.0], [359.0, 1317.0], [357.0, 1526.0], [331.0, 1526.0]], [[300.0, 1318.0], [326.0, 1318.0], [326.0, 1457.0], [300.0, 1457.0]]], "lines": ["いつもより", "多目に", "くだらないことを", "考えてみる。"]}], "img_path": "116.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [877, 168, 913, 368], "vertical": true, "font_size": 26, "lines_coords": [[[881.0, 171.0], [907.0, 171.0], [907.0, 360.0], [881.0, 360.0]]], "lines": ["人間は自由だ。"]}, {"box": [521, 235, 617, 402], "vertical": true, "font_size": 28, "lines_coords": [[[589.0, 242.0], [617.0, 242.0], [614.0, 368.0], [585.0, 368.0]], [[554.0, 239.0], [582.0, 239.0], [582.0, 368.0], [554.0, 368.0]], [[521.0, 235.0], [548.0, 235.0], [548.0, 401.0], [521.0, 401.0]]], "lines": ["一人で空を", "飛ぶことは", "できないけど、"]}, {"box": [214, 287, 310, 521], "vertical": true, "font_size": 27, "lines_coords": [[[278.0, 287.0], [306.0, 287.0], [307.0, 520.0], [279.0, 520.0]], [[248.0, 287.0], [275.0, 287.0], [275.0, 507.0], [248.0, 507.0]], [[214.0, 287.0], [240.0, 287.0], [243.0, 503.0], [217.0, 503.0]]], "lines": ["人が思いつくような", "ことだったら、大概", "なんだってできる。"]}, {"box": [271, 829, 363, 959], "vertical": true, "font_size": 27, "lines_coords": [[[334.0, 831.0], [360.0, 831.0], [360.0, 959.0], [334.0, 959.0]], [[303.0, 831.0], [329.0, 831.0], [329.0, 959.0], [303.0, 959.0]], [[271.0, 829.0], [300.0, 829.0], [300.0, 920.0], [271.0, 920.0]]], "lines": ["眠い時には", "眠ることが", "できる。"]}, {"box": [832, 1143, 962, 1387], "vertical": true, "font_size": 32, "lines_coords": [[[923.0, 1143.0], [962.0, 1143.0], [962.0, 1271.0], [923.0, 1271.0]], [[895.0, 1146.0], [926.0, 1146.0], [923.0, 1385.0], [892.0, 1385.0]], [[864.0, 1148.0], [895.0, 1148.0], [895.0, 1387.0], [864.0, 1387.0]], [[832.0, 1146.0], [859.0, 1146.0], [859.0, 1303.0], [832.0, 1303.0]]], "lines": ["人生で", "何かを始めることも", "何かをやめることも", "自由だ。！！"]}, {"box": [193, 1143, 352, 1381], "vertical": true, "font_size": 31, "lines_coords": [[[323.0, 1146.0], [350.0, 1146.0], [350.0, 1318.0], [323.0, 1318.0]], [[290.0, 1145.0], [323.0, 1145.0], [320.0, 1381.0], [287.0, 1381.0]], [[256.0, 1143.0], [289.0, 1143.0], [285.0, 1339.0], [253.0, 1339.0]], [[225.0, 1143.0], [257.0, 1143.0], [254.0, 1356.0], [221.0, 1356.0]], [[193.0, 1143.0], [221.0, 1143.0], [223.0, 1356.0], [195.0, 1356.0]]], "lines": ["ただ、常識とか", "ルールとか生活とか", "メンタリティー", "とかに邪魔されて", "やらないだけで。"]}], "img_path": "117.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [926, 34, 990, 251], "vertical": true, "font_size": 30, "lines_coords": [[[956.0, 34.0], [987.0, 34.0], [990.0, 192.0], [959.0, 192.0]], [[926.0, 34.0], [954.0, 34.0], [956.0, 251.0], [928.0, 251.0]]], "lines": ["全裸で街中を", "走りまわることも、"]}, {"box": [823, 32, 910, 217], "vertical": true, "font_size": 27.0, "lines_coords": [[[887.0, 107.0], [910.0, 107.0], [910.0, 179.0], [887.0, 179.0]], [[860.0, 34.0], [887.0, 34.0], [887.0, 217.0], [860.0, 217.0]], [[826.0, 32.0], [857.0, 32.0], [854.0, 215.0], [823.0, 215.0]]], "lines": ["お願いします。こちらのおまじをお客さまでも", "年寄りから金を", "騙し取ることも"]}, {"box": [754, 32, 788, 280], "vertical": true, "font_size": 31, "lines_coords": [[[756.0, 32.0], [787.0, 32.0], [785.0, 279.0], [754.0, 279.0]]], "lines": ["人を殺すことだって、"]}, {"box": [159, 34, 254, 268], "vertical": true, "font_size": 27, "lines_coords": [[[223.0, 34.0], [250.0, 34.0], [253.0, 192.0], [226.0, 192.0]], [[190.0, 34.0], [218.0, 34.0], [220.0, 268.0], [192.0, 268.0]], [[160.0, 35.0], [187.0, 35.0], [187.0, 256.0], [160.0, 256.0]]], "lines": ["倫理的問題を", "度外視してしまえば", "なんだってできる。"]}, {"box": [840, 562, 967, 806], "vertical": true, "font_size": 30, "lines_coords": [[[935.0, 587.0], [967.0, 587.0], [967.0, 800.0], [935.0, 800.0]], [[904.0, 592.0], [935.0, 592.0], [935.0, 775.0], [904.0, 775.0]], [[873.0, 590.0], [900.0, 590.0], [903.0, 775.0], [876.0, 775.0]], [[840.0, 562.0], [871.0, 562.0], [871.0, 760.0], [840.0, 760.0]]], "lines": ["だから子供の頃に", "しっこいくらい", "協調とか道徳を", "戦刷り込まれる。"]}, {"box": [670, 589, 804, 842], "vertical": true, "font_size": 36, "lines_coords": [[[770.0, 589.0], [801.0, 589.0], [804.0, 776.0], [773.0, 776.0]], [[735.0, 589.0], [773.0, 589.0], [776.0, 842.0], [739.0, 842.0]], [[703.0, 590.0], [742.0, 590.0], [746.0, 832.0], [707.0, 832.0]], [[670.0, 595.0], [706.0, 593.0], [714.0, 818.0], [678.0, 820.0]]], "lines": ["なのに世の中は", "当たり前に、人と人が", "争い、欺き、奪い合う", "ように作られてる。"]}, {"box": [303, 590, 398, 776], "vertical": true, "font_size": 30, "lines_coords": [[[364.0, 590.0], [395.0, 590.0], [398.0, 776.0], [367.0, 776.0]], [[335.0, 592.0], [364.0, 592.0], [365.0, 750.0], [337.0, 750.0]], [[306.0, 592.0], [334.0, 592.0], [331.0, 735.0], [303.0, 735.0]]], "lines": ["その矛盾の中で", "生きてるから", "人は苦しむ。"]}, {"box": [143, 590, 271, 870], "vertical": true, "font_size": 30, "lines_coords": [[[245.0, 593.0], [271.0, 593.0], [271.0, 776.0], [245.0, 776.0]], [[210.0, 592.0], [242.0, 592.0], [242.0, 778.0], [210.0, 778.0]], [[178.0, 590.0], [209.0, 590.0], [209.0, 870.0], [178.0, 870.0]], [[148.0, 590.0], [181.0, 590.0], [176.0, 842.0], [143.0, 842.0]]], "lines": ["今もあちこちで", "幸せと不幸が", "株みだいに目まぐるしく", "やり取りされてんだ。"]}, {"box": [151, 1120, 223, 1457], "vertical": true, "font_size": 30, "lines_coords": [[[190.0, 1121.0], [223.0, 1121.0], [223.0, 1307.0], [190.0, 1307.0]], [[151.0, 1120.0], [179.0, 1120.0], [181.0, 1457.0], [153.0, 1457.0]]], "lines": ["．．．どうすれば", "みんなが幸せになれる？"]}], "img_path": "118.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [943, 79, 970, 364], "vertical": true, "font_size": 28, "lines_coords": [[[943.0, 79.0], [970.0, 79.0], [970.0, 364.0], [943.0, 364.0]]], "lines": ["そんなもんわかるもんか。"]}, {"box": [832, 153, 925, 487], "vertical": true, "font_size": 28, "lines_coords": [[[898.0, 153.0], [925.0, 153.0], [925.0, 487.0], [898.0, 487.0]], [[867.0, 154.0], [893.0, 154.0], [893.0, 451.0], [867.0, 451.0]], [[832.0, 153.0], [864.0, 153.0], [864.0, 451.0], [832.0, 451.0]]], "lines": ["子供の浅知恵でどうにかなる", "くらいだったら、とっくに", "戦争なんて無くなってる。"]}, {"box": [532, 118, 625, 376], "vertical": true, "font_size": 22, "lines_coords": [[[598.0, 118.0], [620.0, 118.0], [620.0, 348.0], [598.0, 348.0]], [[564.0, 118.0], [585.0, 118.0], [585.0, 371.0], [564.0, 371.0]], [[532.0, 120.0], [554.0, 120.0], [554.0, 253.0], [532.0, 253.0]]], "lines": ["けど社会とか政治に", "責任を丸投げするのも", "なんか嫌だ"]}, {"box": [398, 289, 491, 610], "vertical": true, "font_size": 27, "lines_coords": [[[460.0, 289.0], [489.0, 289.0], [490.0, 550.0], [462.0, 550.0]], [[431.0, 290.0], [457.0, 290.0], [457.0, 601.0], [431.0, 601.0]], [[398.0, 289.0], [425.0, 289.0], [425.0, 610.0], [398.0, 610.0]]], "lines": ["だって偉い人達なんて", "結局は民意に踊らされてる", "ただのオッサンじゃないか。"]}, {"box": [95, 309, 225, 554], "vertical": true, "font_size": 30, "lines_coords": [[[187.0, 309.0], [220.0, 309.0], [223.0, 506.0], [190.0, 506.0]], [[159.0, 309.0], [190.0, 309.0], [190.0, 521.0], [159.0, 521.0]], [[126.0, 310.0], [157.0, 310.0], [157.0, 546.0], [126.0, 546.0]], [[95.0, 309.0], [121.0, 309.0], [125.0, 551.0], [98.0, 551.0]]], "lines": ["世の中だってのは、", "剥き出しになった", "人間の本質が具現化", "したものじゃねーか。"]}, {"box": [876, 789, 973, 1000], "vertical": true, "font_size": 30, "lines_coords": [[[948.0, 795.0], [970.0, 795.0], [970.0, 971.0], [948.0, 971.0]], [[914.0, 795.0], [940.0, 795.0], [940.0, 1000.0], [914.0, 1000.0]], [[876.0, 789.0], [917.0, 789.0], [917.0, 860.0], [876.0, 860.0]]], "lines": ["きっとみんなが", "幸せになることは", "無い。"]}, {"box": [229, 792, 292, 1006], "vertical": true, "font_size": 27, "lines_coords": [[[262.0, 795.0], [289.0, 795.0], [289.0, 975.0], [262.0, 975.0]], [[229.0, 792.0], [256.0, 792.0], [257.0, 1006.0], [231.0, 1006.0]]], "lines": ["幸福って感覚は", "相対的なもんだし、"]}, {"box": [112, 793, 172, 985], "vertical": true, "font_size": 25, "lines_coords": [[[143.0, 793.0], [171.0, 793.0], [171.0, 925.0], [143.0, 925.0]], [[112.0, 793.0], [134.0, 793.0], [134.0, 981.0], [112.0, 981.0]]], "lines": ["それを人は", "望んでいるから。"]}, {"box": [914, 1140, 973, 1300], "vertical": true, "font_size": 27, "lines_coords": [[[946.0, 1140.0], [973.0, 1140.0], [970.0, 1300.0], [943.0, 1300.0]], [[914.0, 1140.0], [940.0, 1140.0], [940.0, 1281.0], [914.0, 1281.0]]], "lines": ["悪って感覚も", "相対的だ。"]}, {"box": [782, 1137, 876, 1375], "vertical": true, "font_size": 27, "lines_coords": [[[845.0, 1137.0], [876.0, 1137.0], [876.0, 1328.0], [845.0, 1328.0]], [[814.0, 1142.0], [840.0, 1142.0], [840.0, 1375.0], [814.0, 1375.0]], [[782.0, 1140.0], [809.0, 1140.0], [809.0, 1293.0], [782.0, 1293.0]]], "lines": ["他人から子供を", "守るためなら母親は", "鬼になれる。"]}, {"box": [515, 1138, 579, 1389], "vertical": true, "font_size": 29, "lines_coords": [[[548.0, 1139.0], [579.0, 1139.0], [579.0, 1318.0], [548.0, 1318.0]], [[515.0, 1140.0], [542.0, 1140.0], [545.0, 1387.0], [518.0, 1387.0]]], "lines": ["そしてそれは", "美談として語られる。"]}, {"box": [212, 1139, 318, 1386], "vertical": true, "font_size": 31, "lines_coords": [[[285.0, 1140.0], [317.0, 1140.0], [317.0, 1350.0], [285.0, 1350.0]], [[254.0, 1140.0], [282.0, 1140.0], [279.0, 1303.0], [251.0, 1303.0]], [[221.0, 1142.0], [253.0, 1142.0], [253.0, 1382.0], [221.0, 1382.0]]], "lines": ["愛する人や祖国を", "守るだめなら", "国家は戦争ができる。"]}, {"box": [140, 1139, 176, 1345], "vertical": true, "font_size": 33, "lines_coords": [[[143.0, 1139.0], [176.0, 1139.0], [173.0, 1345.0], [140.0, 1345.0]]], "lines": ["同じじゃねーか。"]}], "img_path": "119.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [885, 39, 982, 328], "vertical": true, "font_size": 28, "lines_coords": [[[948.0, 39.0], [979.0, 39.0], [982.0, 328.0], [951.0, 328.0]], [[915.0, 39.0], [946.0, 39.0], [950.0, 257.0], [918.0, 257.0]], [[885.0, 42.0], [912.0, 42.0], [917.0, 225.0], [890.0, 225.0]]], "lines": ["善良なふりをしていても", "誰だって本質には", "負を抱えてる。"]}, {"box": [828, 112, 851, 154], "vertical": true, "font_size": 28, "lines_coords": [[[828.0, 112.0], [851.0, 112.0], [851.0, 154.0], [828.0, 154.0]]], "lines": ["．．．"]}, {"box": [735, 42, 825, 275], "vertical": true, "font_size": 28, "lines_coords": [[[798.0, 42.0], [825.0, 42.0], [825.0, 275.0], [798.0, 275.0]], [[765.0, 43.0], [792.0, 43.0], [792.0, 228.0], [765.0, 228.0]], [[735.0, 45.0], [762.0, 45.0], [762.0, 262.0], [735.0, 262.0]]], "lines": ["そして意外なくらい", "誰もそのごとに", "気付こうとしない。"]}, {"box": [646, 46, 673, 200], "vertical": true, "font_size": 27, "lines_coords": [[[646.0, 46.0], [673.0, 46.0], [673.0, 200.0], [646.0, 200.0]]], "lines": ["．．．なんでだ？"]}, {"box": [275, 40, 335, 282], "vertical": true, "font_size": 30, "lines_coords": [[[309.0, 42.0], [335.0, 42.0], [335.0, 276.0], [309.0, 276.0]], [[275.0, 40.0], [306.0, 40.0], [306.0, 282.0], [275.0, 282.0]]], "lines": ["言い訳とか責任転嫁", "ばかり上手になって、"]}, {"box": [115, 40, 245, 326], "vertical": true, "font_size": 30, "lines_coords": [[[212.0, 40.0], [245.0, 40.0], [245.0, 326.0], [212.0, 326.0]], [[178.0, 42.0], [210.0, 42.0], [209.0, 321.0], [176.0, 321.0]], [[146.0, 42.0], [178.0, 42.0], [178.0, 304.0], [146.0, 304.0]], [[115.0, 40.0], [143.0, 40.0], [145.0, 215.0], [117.0, 215.0]]], "lines": ["てめーが抱えてる問題は", "でも川目身が作り出し", "たんだっていう可能性", "すら考えない。"]}, {"box": [934, 623, 992, 856], "vertical": true, "font_size": 27, "lines_coords": [[[965.0, 623.0], [992.0, 623.0], [992.0, 831.0], [965.0, 831.0]], [[934.0, 625.0], [960.0, 625.0], [960.0, 856.0], [934.0, 856.0]]], "lines": ["．．．さっきから俺は", "何を考えてるんだ？"]}, {"box": [845, 618, 910, 959], "vertical": true, "font_size": 27, "lines_coords": [[[873.0, 618.0], [910.0, 618.0], [906.0, 959.0], [868.0, 959.0]], [[845.0, 621.0], [871.0, 621.0], [871.0, 923.0], [845.0, 923.0]]], "lines": ["俺一人が何を考えたところで", "世の中は何も変わらない。"]}, {"box": [820, 703, 837, 765], "vertical": true, "font_size": 27, "lines_coords": [[[820.0, 703.0], [837.0, 703.0], [837.0, 765.0], [820.0, 765.0]]], "lines": ["．．．"]}, {"box": [756, 621, 817, 829], "vertical": true, "font_size": 27, "lines_coords": [[[789.0, 621.0], [817.0, 621.0], [814.0, 779.0], [785.0, 779.0]], [[756.0, 623.0], [782.0, 623.0], [782.0, 829.0], [756.0, 829.0]]], "lines": ["．．．じゃあ俺は", "どうしたいんだ？"]}, {"box": [700, 618, 726, 750], "vertical": true, "font_size": 27, "lines_coords": [[[700.0, 618.0], [726.0, 618.0], [726.0, 750.0], [700.0, 750.0]]], "lines": ["俺個人は？"]}, {"box": [587, 623, 615, 753], "vertical": true, "font_size": 27, "lines_coords": [[[587.0, 623.0], [614.0, 623.0], [614.0, 753.0], [587.0, 753.0]]], "lines": ["だーれだ？"]}, {"box": [265, 618, 334, 809], "vertical": true, "font_size": 30, "lines_coords": [[[301.0, 618.0], [334.0, 620.0], [329.0, 770.0], [296.0, 768.0]], [[268.0, 620.0], [301.0, 620.0], [298.0, 809.0], [265.0, 809.0]]], "lines": ["．．．俺はただ", "何もしたくない。"]}, {"box": [134, 618, 226, 867], "vertical": true, "font_size": 30, "lines_coords": [[[195.0, 620.0], [226.0, 620.0], [226.0, 856.0], [195.0, 856.0]], [[162.0, 618.0], [195.0, 618.0], [192.0, 842.0], [159.0, 842.0]], [[134.0, 621.0], [156.0, 621.0], [156.0, 867.0], [134.0, 867.0]]], "lines": ["誰にも命令されない", "かわりに誰にも、", "迷惑をかけたくない。"]}, {"box": [751, 1142, 985, 1378], "vertical": true, "font_size": 29, "lines_coords": [[[959.0, 1143.0], [985.0, 1143.0], [985.0, 1275.0], [959.0, 1275.0]], [[923.0, 1142.0], [954.0, 1142.0], [957.0, 1331.0], [926.0, 1331.0]], [[870.0, 1143.0], [896.0, 1143.0], [896.0, 1303.0], [870.0, 1303.0]], [[837.0, 1148.0], [865.0, 1148.0], [865.0, 1289.0], [837.0, 1289.0]], [[787.0, 1143.0], [818.0, 1143.0], [820.0, 1378.0], [789.0, 1378.0]], [[751.0, 1142.0], [784.0, 1142.0], [787.0, 1289.0], [754.0, 1289.0]]], "lines": ["その結果が", "ただの怠け者だ。", "学校も行かず", "働きもせず。", "昼間からアテもなく", "ブラついで。"]}, {"box": [579, 1142, 726, 1389], "vertical": true, "font_size": 29, "lines_coords": [[[696.0, 1142.0], [725.0, 1142.0], [726.0, 1353.0], [698.0, 1353.0]], [[665.0, 1142.0], [693.0, 1142.0], [695.0, 1389.0], [667.0, 1389.0]], [[612.0, 1146.0], [639.0, 1146.0], [639.0, 1275.0], [612.0, 1275.0]], [[579.0, 1145.0], [610.0, 1145.0], [610.0, 1384.0], [579.0, 1384.0]]], "lines": ["人は自由だなんて", "強引に言い聞かせて。", "実際は街の", "不審者じゃねーか。"]}, {"box": [256, 1143, 325, 1353], "vertical": true, "font_size": 30, "lines_coords": [[[292.0, 1143.0], [325.0, 1143.0], [325.0, 1353.0], [292.0, 1353.0]], [[256.0, 1145.0], [282.0, 1145.0], [282.0, 1310.0], [256.0, 1310.0]]], "lines": ["結論はいつだって", "身も蓋もない。"]}, {"box": [129, 1142, 223, 1403], "vertical": true, "font_size": 30, "lines_coords": [[[195.0, 1145.0], [223.0, 1145.0], [220.0, 1323.0], [192.0, 1323.0]], [[162.0, 1146.0], [193.0, 1146.0], [193.0, 1403.0], [162.0, 1403.0]], [[129.0, 1142.0], [162.0, 1142.0], [162.0, 1295.0], [129.0, 1295.0]]], "lines": ["つまり俺が今、", "二番何を言いたいかと", "言うと．．．．．．"]}], "img_path": "120.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [906, 152, 933, 266], "vertical": true, "font_size": 26, "lines_coords": [[[906.0, 154.0], [932.0, 154.0], [932.0, 264.0], [906.0, 264.0]]], "lines": ["．．．俺は今、"]}, {"box": [162, 403, 223, 585], "vertical": true, "font_size": 29, "lines_coords": [[[192.0, 403.0], [223.0, 403.0], [223.0, 585.0], [192.0, 585.0]], [[162.0, 406.0], [189.0, 406.0], [189.0, 560.0], [162.0, 560.0]]], "lines": ["すっげー金が", "欲しいのな！！"]}, {"box": [867, 725, 958, 906], "vertical": true, "font_size": 27, "lines_coords": [[[929.0, 725.0], [957.0, 725.0], [957.0, 831.0], [929.0, 831.0]], [[900.0, 726.0], [926.0, 726.0], [926.0, 906.0], [900.0, 906.0]], [[867.0, 726.0], [893.0, 726.0], [893.0, 881.0], [867.0, 881.0]]], "lines": ["貧すれば", "鈍するって言う", "からなー．．．"]}, {"box": [954, 1043, 995, 1155], "vertical": true, "font_size": 35, "lines_coords": [[[954.0, 1043.0], [989.0, 1043.0], [989.0, 1154.0], [954.0, 1154.0]]], "lines": ["．．．清水、"]}, {"box": [556, 1035, 580, 1173], "vertical": true, "font_size": 22, "lines_coords": [[[556.0, 1035.0], [578.0, 1035.0], [578.0, 1168.0], [556.0, 1168.0]]], "lines": ["．．．あんまし"]}, {"box": [134, 760, 259, 967], "vertical": true, "font_size": 26, "lines_coords": [[[232.0, 764.0], [254.0, 764.0], [254.0, 940.0], [232.0, 940.0]], [[200.0, 760.0], [226.0, 760.0], [223.0, 893.0], [196.0, 893.0]], [[165.0, 762.0], [192.0, 762.0], [192.0, 967.0], [165.0, 967.0]], [[135.0, 760.0], [162.0, 760.0], [160.0, 956.0], [134.0, 956.0]]], "lines": ["腹が減りすぎて", "さっきから", "超くだらねーこと", "ばっか考えてる。"]}, {"box": [675, 1345, 734, 1500], "vertical": true, "font_size": 27, "lines_coords": [[[706.0, 1345.0], [734.0, 1345.0], [734.0, 1450.0], [706.0, 1450.0]], [[675.0, 1345.0], [701.0, 1345.0], [701.0, 1500.0], [675.0, 1500.0]]], "lines": ["お前、今", "金持ってる？"]}, {"box": [217, 1317, 250, 1410], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 1317.0], [250.0, 1317.0], [250.0, 1410.0], [217.0, 1410.0]]], "lines": ["．．．あそ。"]}, {"box": [90, 1335, 181, 1525], "vertical": true, "font_size": 26, "lines_coords": [[[151.0, 1335.0], [181.0, 1335.0], [181.0, 1490.0], [151.0, 1490.0]], [[121.0, 1337.0], [143.0, 1337.0], [143.0, 1465.0], [121.0, 1465.0]], [[90.0, 1337.0], [110.0, 1337.0], [110.0, 1525.0], [90.0, 1525.0]]], "lines": ["つーか平日の", "昼間なのに", "なんていんだよ。"]}], "img_path": "121.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [879, 64, 987, 206], "vertical": true, "font_size": 27, "lines_coords": [[[957.0, 64.0], [987.0, 64.0], [987.0, 137.0], [957.0, 137.0]], [[932.0, 67.0], [959.0, 67.0], [959.0, 206.0], [932.0, 206.0]], [[906.0, 65.0], [929.0, 65.0], [931.0, 204.0], [907.0, 204.0]], [[879.0, 65.0], [906.0, 65.0], [906.0, 159.0], [879.0, 159.0]]], "lines": ["今日は", "一学期の中間", "テストだった", "から．．．"]}, {"box": [670, 45, 776, 253], "vertical": true, "font_size": 22, "lines_coords": [[[754.0, 48.0], [776.0, 48.0], [776.0, 184.0], [754.0, 184.0]], [[726.0, 48.0], [748.0, 48.0], [748.0, 185.0], [726.0, 185.0]], [[696.0, 45.0], [720.0, 45.0], [718.0, 231.0], [695.0, 231.0]], [[670.0, 46.0], [692.0, 46.0], [692.0, 253.0], [670.0, 253.0]]], "lines": ["．．．もうそんな", "時期かよ．．．", "てか、お前、学校で", "上手くやってんの？"]}, {"box": [221, 123, 285, 220], "vertical": true, "font_size": 27, "lines_coords": [[[251.0, 123.0], [285.0, 123.0], [285.0, 207.0], [251.0, 207.0]], [[221.0, 125.0], [254.0, 125.0], [254.0, 220.0], [221.0, 220.0]]], "lines": ["．．．な訳", "ねーか。"]}, {"box": [115, 171, 200, 382], "vertical": true, "font_size": 27, "lines_coords": [[[178.0, 171.0], [200.0, 171.0], [200.0, 354.0], [178.0, 354.0]], [[143.0, 173.0], [170.0, 173.0], [170.0, 382.0], [143.0, 382.0]], [[115.0, 176.0], [132.0, 176.0], [132.0, 287.0], [115.0, 287.0]]], "lines": ["こんだけ頻繁に", "俺んとこ通ってん", "たもんな"]}, {"box": [254, 467, 281, 596], "vertical": true, "font_size": 27, "lines_coords": [[[254.0, 467.0], [281.0, 467.0], [281.0, 596.0], [254.0, 596.0]]], "lines": ["関くん．．．"]}, {"box": [146, 512, 204, 667], "vertical": true, "font_size": 27, "lines_coords": [[[178.0, 514.0], [204.0, 514.0], [204.0, 617.0], [178.0, 617.0]], [[146.0, 512.0], [173.0, 512.0], [173.0, 667.0], [146.0, 667.0]]], "lines": ["お父さん", "帰ってきた？"]}, {"box": [900, 739, 989, 926], "vertical": true, "font_size": 27, "lines_coords": [[[951.0, 739.0], [989.0, 740.0], [985.0, 803.0], [948.0, 801.0]], [[928.0, 745.0], [954.0, 745.0], [954.0, 926.0], [928.0, 926.0]], [[900.0, 743.0], [926.0, 743.0], [926.0, 834.0], [900.0, 834.0]]], "lines": ["全然", "帰ってくる気配", "ねーなー"]}, {"box": [762, 912, 906, 1146], "vertical": true, "font_size": 27, "lines_coords": [[[884.0, 912.0], [906.0, 912.0], [906.0, 1068.0], [884.0, 1068.0]], [[850.0, 912.0], [876.0, 912.0], [876.0, 1120.0], [850.0, 1120.0]], [[820.0, 914.0], [846.0, 914.0], [848.0, 1121.0], [821.0, 1121.0]], [[792.0, 915.0], [818.0, 915.0], [818.0, 1146.0], [792.0, 1146.0]], [[762.0, 914.0], [784.0, 914.0], [787.0, 1009.0], [765.0, 1009.0]]], "lines": ["今度の金策が", "上手くいかなきゃ", "いよいよ裁判所に", "家差し押さえられる", "かもなー"]}, {"box": [137, 1053, 258, 1231], "vertical": true, "font_size": 24, "lines_coords": [[[232.0, 1054.0], [254.0, 1054.0], [254.0, 1231.0], [232.0, 1231.0]], [[198.0, 1054.0], [225.0, 1054.0], [225.0, 1182.0], [198.0, 1182.0]], [[167.0, 1053.0], [193.0, 1053.0], [193.0, 1189.0], [167.0, 1189.0]], [[137.0, 1054.0], [159.0, 1054.0], [159.0, 1192.0], [137.0, 1192.0]]], "lines": ["そしたらついに", "一家総出で", "宿無しだな、", "あっはっは。"]}, {"box": [792, 1339, 928, 1485], "vertical": true, "font_size": 32, "lines_coords": [[[825.0, 1378.0], [857.0, 1378.0], [857.0, 1485.0], [825.0, 1485.0]], [[792.0, 1378.0], [825.0, 1378.0], [825.0, 1468.0], [792.0, 1468.0]]], "lines": ["ちょっと", "歩くか。"]}, {"box": [150, 1360, 273, 1517], "vertical": true, "font_size": 23, "lines_coords": [[[248.0, 1362.0], [270.0, 1362.0], [270.0, 1515.0], [248.0, 1515.0]], [[214.0, 1360.0], [240.0, 1360.0], [240.0, 1490.0], [214.0, 1490.0]], [[184.0, 1362.0], [206.0, 1362.0], [206.0, 1517.0], [184.0, 1517.0]], [[150.0, 1360.0], [173.0, 1360.0], [176.0, 1496.0], [153.0, 1496.0]]], "lines": ["もしかしたら", "サイフとか", "落ちてるかも", "しんねーし。"]}], "img_path": "122.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [323, 865, 425, 914], "vertical": false, "font_size": 39, "lines_coords": [[[326.0, 865.0], [425.0, 875.0], [421.0, 914.0], [323.0, 904.0]]], "lines": ["更利屋"]}, {"box": [300, 931, 464, 1100], "vertical": false, "font_size": 17.571428571428573, "lines_coords": [[[303.0, 931.0], [431.0, 931.0], [431.0, 951.0], [303.0, 951.0]], [[301.0, 965.0], [414.0, 965.0], [414.0, 982.0], [301.0, 982.0]], [[300.0, 987.0], [464.0, 984.0], [464.0, 1004.0], [300.0, 1007.0]], [[303.0, 1012.0], [451.0, 1012.0], [451.0, 1028.0], [303.0, 1028.0]], [[300.0, 1037.0], [453.0, 1037.0], [453.0, 1053.0], [300.0, 1053.0]], [[303.0, 1057.0], [434.0, 1056.0], [434.0, 1073.0], [303.0, 1075.0]], [[303.0, 1084.0], [440.0, 1084.0], [440.0, 1100.0], [303.0, 1100.0]]], "lines": ["本城もいたします！！", "・引越し・実動期休", "．．．ハウスク・ニッグ・草メリニング", "・不用品処理・ポット検査リ", "この他、なにもお付けください！！", "！！！わかりますからお客さん", "Ｔｅｌ．ｊｉｐｈｉｒｅｃｏｒｅに"]}, {"box": [924, 1329, 1003, 1468], "vertical": true, "font_size": 23, "lines_coords": [[[976.0, 1329.0], [1003.0, 1329.0], [1003.0, 1426.0], [976.0, 1426.0]], [[951.0, 1331.0], [973.0, 1331.0], [973.0, 1446.0], [951.0, 1446.0]], [[925.0, 1331.0], [945.0, 1331.0], [945.0, 1468.0], [925.0, 1468.0]]], "lines": ["．．．関くん", "そのコート", "暑くないの？"]}, {"box": [618, 1146, 646, 1262], "vertical": true, "font_size": 27, "lines_coords": [[[618.0, 1146.0], [645.0, 1146.0], [645.0, 1262.0], [618.0, 1262.0]]], "lines": ["．．．．．清水"]}, {"box": [350, 1426, 442, 1532], "vertical": true, "font_size": 29, "lines_coords": [[[409.0, 1426.0], [442.0, 1426.0], [442.0, 1509.0], [409.0, 1509.0]], [[381.0, 1429.0], [407.0, 1429.0], [407.0, 1532.0], [381.0, 1532.0]], [[350.0, 1428.0], [378.0, 1428.0], [378.0, 1520.0], [350.0, 1520.0]]], "lines": ["なんか", "書くもん", "貸して。"]}], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [814, 170, 923, 192], "vertical": false, "font_size": 22, "lines_coords": [[[814.0, 170.0], [923.0, 170.0], [923.0, 192.0], [814.0, 192.0]]], "lines": ["もいたします！！"]}, {"box": [765, 51, 801, 159], "vertical": true, "font_size": 30, "lines_coords": [[[765.0, 51.0], [798.0, 51.0], [801.0, 159.0], [768.0, 159.0]]], "lines": ["ちょ．．．"]}, {"box": [771, 201, 967, 323], "vertical": false, "font_size": 21.2, "lines_coords": [[[773.0, 204.0], [912.0, 201.0], [912.0, 223.0], [773.0, 226.0]], [[771.0, 231.0], [967.0, 228.0], [967.0, 248.0], [771.0, 251.0]], [[775.0, 256.0], [967.0, 256.0], [967.0, 276.0], [775.0, 276.0]], [[773.0, 279.0], [942.0, 279.0], [942.0, 301.0], [773.0, 301.0]], [[776.0, 301.0], [917.0, 300.0], [917.0, 321.0], [776.0, 323.0]]], "lines": ["・引越し・豊丸駅旅", "・ハウスウェング・草ダイエットは嫌われ", "・不用品の理・パン機塗り", "それはその他．．．かなせください！！", "見積り無いですねお客様の"]}, {"box": [669, 77, 698, 233], "vertical": true, "font_size": 29, "lines_coords": [[[669.0, 77.0], [698.0, 77.0], [698.0, 233.0], [669.0, 233.0]]], "lines": ["わっわっ．．"]}, {"box": [668, 79, 696, 231], "vertical": true, "font_size": 30, "lines_coords": [[[668.0, 79.0], [696.0, 79.0], [696.0, 231.0], [668.0, 231.0]]], "lines": ["わっわっ．．．"]}, {"box": [98, 32, 271, 323], "vertical": true, "font_size": 31, "lines_coords": [[[237.0, 34.0], [271.0, 34.0], [271.0, 134.0], [237.0, 134.0]], [[200.0, 32.0], [232.0, 32.0], [232.0, 189.0], [200.0, 189.0]], [[170.0, 184.0], [203.0, 184.0], [203.0, 323.0], [170.0, 323.0]], [[134.0, 185.0], [162.0, 185.0], [162.0, 309.0], [134.0, 309.0]], [[98.0, 184.0], [125.0, 184.0], [125.0, 307.0], [98.0, 307.0]]], "lines": ["やだよ、", "消してよ！！", "コレ、僕の", "電話番号", "じゃん！！"]}, {"box": [889, 710, 977, 881], "vertical": true, "font_size": 25, "lines_coords": [[[950.0, 710.0], [976.0, 710.0], [976.0, 881.0], [950.0, 881.0]], [[918.0, 710.0], [945.0, 710.0], [945.0, 842.0], [918.0, 842.0]], [[889.0, 714.0], [910.0, 714.0], [910.0, 840.0], [889.0, 840.0]]], "lines": ["関くん、もっと", "普通の仕事", "しようよ！！"]}, {"box": [635, 406, 659, 546], "vertical": true, "font_size": 22, "lines_coords": [[[635.0, 406.0], [657.0, 406.0], [657.0, 543.0], [635.0, 543.0]]], "lines": ["うるせーな。"]}, {"box": [125, 435, 250, 604], "vertical": true, "font_size": 26, "lines_coords": [[[220.0, 437.0], [246.0, 437.0], [246.0, 604.0], [220.0, 604.0]], [[189.0, 439.0], [215.0, 439.0], [215.0, 593.0], [189.0, 593.0]], [[157.0, 435.0], [184.0, 435.0], [181.0, 593.0], [154.0, 593.0]], [[125.0, 435.0], [151.0, 435.0], [151.0, 529.0], [125.0, 529.0]]], "lines": ["俺、携帯持って", "ねーんだから", "しょうがねー", "じゃん。"]}, {"box": [322, 657, 411, 889], "vertical": true, "font_size": 25, "lines_coords": [[[384.0, 657.0], [410.0, 657.0], [410.0, 864.0], [384.0, 864.0]], [[351.0, 657.0], [378.0, 657.0], [378.0, 889.0], [351.0, 889.0]], [[323.0, 659.0], [345.0, 659.0], [345.0, 889.0], [323.0, 889.0]]], "lines": ["お父さんみたいに", "お家でお弁当作って", "売ればいいじゃん！！"]}, {"box": [135, 775, 270, 937], "vertical": true, "font_size": 22, "lines_coords": [[[248.0, 778.0], [270.0, 778.0], [270.0, 920.0], [248.0, 920.0]], [[220.0, 776.0], [242.0, 776.0], [242.0, 937.0], [220.0, 937.0]], [[192.0, 776.0], [214.0, 776.0], [214.0, 935.0], [192.0, 935.0]], [[164.0, 775.0], [185.0, 775.0], [185.0, 917.0], [164.0, 917.0]], [[135.0, 775.0], [157.0, 775.0], [157.0, 878.0], [135.0, 878.0]]], "lines": ["バカだねお前、", "そーゆうのには", "面倒な資格とか", "手続きが必要", "なんだよ。"]}, {"box": [106, 1000, 212, 1189], "vertical": true, "font_size": 22, "lines_coords": [[[190.0, 1001.0], [212.0, 1001.0], [212.0, 1118.0], [190.0, 1118.0]], [[157.0, 1000.0], [184.0, 1000.0], [187.0, 1143.0], [160.0, 1143.0]], [[134.0, 1003.0], [156.0, 1003.0], [156.0, 1189.0], [134.0, 1189.0]], [[106.0, 1001.0], [128.0, 1001.0], [128.0, 1153.0], [106.0, 1153.0]]], "lines": ["しかも俺が", "業務用コンロ", "なんていじったら", "卒倒するって。"]}, {"box": [417, 1292, 842, 1457], "vertical": false, "font_size": 145, "lines_coords": [[[417.0, 1312.0], [835.0, 1292.0], [842.0, 1437.0], [423.0, 1457.0]]], "lines": ["．．．"]}, {"box": [278, 1265, 321, 1325], "vertical": true, "font_size": 32, "lines_coords": [[[282.0, 1265.0], [321.0, 1270.0], [317.0, 1325.0], [278.0, 1321.0]]], "lines": ["あー"]}, {"box": [165, 1334, 225, 1512], "vertical": true, "font_size": 32, "lines_coords": [[[196.0, 1334.0], [225.0, 1334.0], [225.0, 1443.0], [196.0, 1443.0]], [[165.0, 1339.0], [192.0, 1339.0], [192.0, 1512.0], [165.0, 1512.0]]], "lines": ["ちょっと", "いいかな、君達。"]}], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [910, 81, 975, 217], "vertical": true, "font_size": 32, "lines_coords": [[[948.0, 85.0], [975.0, 85.0], [975.0, 217.0], [948.0, 217.0]], [[914.0, 81.0], [951.0, 82.0], [948.0, 151.0], [910.0, 150.0]]], "lines": ["もしかして", "君達、"]}, {"box": [193, 278, 290, 434], "vertical": true, "font_size": 31, "lines_coords": [[[251.0, 278.0], [290.0, 278.0], [290.0, 364.0], [251.0, 364.0]], [[225.0, 282.0], [251.0, 282.0], [251.0, 434.0], [225.0, 434.0]], [[193.0, 281.0], [221.0, 281.0], [221.0, 384.0], [193.0, 384.0]]], "lines": ["お金に", "困ってる系の", "子供達？"]}, {"box": [151, 687, 179, 831], "vertical": true, "font_size": 27, "lines_coords": [[[151.0, 687.0], [178.0, 687.0], [178.0, 831.0], [151.0, 831.0]]], "lines": ["．．．ですけど。"]}, {"box": [943, 924, 971, 1068], "vertical": true, "font_size": 27, "lines_coords": [[[943.0, 929.0], [970.0, 929.0], [970.0, 1064.0], [943.0, 1064.0]]], "lines": ["．．．お仕事、"]}, {"box": [473, 1144, 495, 1245], "vertical": true, "font_size": 22, "lines_coords": [[[473.0, 1145.0], [495.0, 1145.0], [495.0, 1245.0], [473.0, 1245.0]]], "lines": ["あるよ？"]}, {"box": [245, 951, 365, 1132], "vertical": true, "font_size": 26, "lines_coords": [[[337.0, 951.0], [365.0, 951.0], [365.0, 1059.0], [337.0, 1059.0]], [[306.0, 951.0], [332.0, 951.0], [332.0, 1131.0], [306.0, 1131.0]], [[273.0, 951.0], [300.0, 951.0], [300.0, 1107.0], [273.0, 1107.0]], [[245.0, 953.0], [267.0, 953.0], [267.0, 1035.0], [245.0, 1035.0]]], "lines": ["．．．いやね", "ウチで扱ってる", "不動産なんだ", "けども、"]}, {"box": [90, 1331, 179, 1516], "vertical": true, "font_size": 25, "lines_coords": [[[151.0, 1334.0], [178.0, 1334.0], [178.0, 1489.0], [151.0, 1489.0]], [[118.0, 1331.0], [145.0, 1331.0], [146.0, 1515.0], [120.0, 1515.0]], [[90.0, 1335.0], [112.0, 1335.0], [112.0, 1495.0], [90.0, 1495.0]]], "lines": ["かなり豪快に", "汚されちゃって", "困ってたのよ。"]}], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [934, 56, 956, 232], "vertical": true, "font_size": 24, "lines_coords": [[[934.0, 56.0], [956.0, 56.0], [956.0, 232.0], [934.0, 232.0]]], "lines": ["．．．掃除っすか？"]}, {"box": [798, 145, 887, 315], "vertical": true, "font_size": 24, "lines_coords": [[[860.0, 145.0], [887.0, 145.0], [884.0, 278.0], [857.0, 278.0]], [[828.0, 148.0], [854.0, 148.0], [851.0, 281.0], [825.0, 281.0]], [[798.0, 150.0], [820.0, 150.0], [820.0, 315.0], [798.0, 315.0]]], "lines": ["．．．そんなの", "全然楽勝て", "やりますけど。"]}, {"box": [354, 70, 381, 210], "vertical": true, "font_size": 27, "lines_coords": [[[354.0, 70.0], [381.0, 70.0], [381.0, 210.0], [354.0, 210.0]]], "lines": ["あぁホント。"]}, {"box": [186, 279, 276, 439], "vertical": true, "font_size": 28, "lines_coords": [[[246.0, 279.0], [275.0, 279.0], [271.0, 435.0], [243.0, 435.0]]], "lines": ["専門の業者に"]}, {"box": [182, 281, 242, 437], "vertical": true, "font_size": 26, "lines_coords": [[[215.0, 282.0], [242.0, 282.0], [242.0, 437.0], [215.0, 437.0]], [[182.0, 281.0], [209.0, 281.0], [209.0, 393.0], [182.0, 393.0]]], "lines": ["頼むのも安く", "なくてね。"]}, {"box": [106, 496, 226, 706], "vertical": true, "font_size": 26, "lines_coords": [[[196.0, 496.0], [223.0, 496.0], [226.0, 631.0], [200.0, 631.0]], [[167.0, 498.0], [193.0, 498.0], [193.0, 706.0], [167.0, 706.0]], [[132.0, 496.0], [159.0, 496.0], [159.0, 690.0], [132.0, 690.0]], [[106.0, 500.0], [128.0, 500.0], [128.0, 653.0], [106.0, 653.0]]], "lines": ["だからって", "僕一人で片付ける", "のも、気が減入り", "そうでさ．．．"]}, {"box": [881, 1014, 971, 1169], "vertical": true, "font_size": 26, "lines_coords": [[[942.0, 1014.0], [968.0, 1014.0], [971.0, 1168.0], [945.0, 1168.0]], [[912.0, 1015.0], [939.0, 1015.0], [939.0, 1146.0], [912.0, 1146.0]], [[881.0, 1014.0], [907.0, 1014.0], [907.0, 1121.0], [881.0, 1121.0]]], "lines": ["．．．鳴ってんの", "お前の携帯", "じゃね？"]}, {"box": [519, 1293, 576, 1423], "vertical": true, "font_size": 25, "lines_coords": [[[548.0, 1293.0], [576.0, 1293.0], [576.0, 1400.0], [548.0, 1400.0]], [[520.0, 1295.0], [542.0, 1295.0], [542.0, 1421.0], [520.0, 1421.0]]], "lines": ["．．．なんで", "出ねーの？"]}, {"box": [120, 1352, 142, 1466], "vertical": true, "font_size": 22, "lines_coords": [[[120.0, 1353.0], [142.0, 1353.0], [142.0, 1464.0], [120.0, 1464.0]]], "lines": ["もしもし"]}], "img_path": "126.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [960, 123, 987, 235], "vertical": true, "font_size": 26, "lines_coords": [[[960.0, 123.0], [987.0, 123.0], [987.0, 235.0], [960.0, 235.0]]], "lines": ["ああハイ。"]}, {"box": [881, 229, 907, 370], "vertical": true, "font_size": 26, "lines_coords": [[[881.0, 229.0], [907.0, 229.0], [907.0, 370.0], [881.0, 370.0]]], "lines": ["そうですよ。"]}, {"box": [125, 248, 216, 431], "vertical": true, "font_size": 26, "lines_coords": [[[190.0, 251.0], [212.0, 251.0], [212.0, 404.0], [190.0, 404.0]], [[156.0, 250.0], [182.0, 250.0], [182.0, 431.0], [156.0, 431.0]], [[125.0, 248.0], [154.0, 248.0], [154.0, 318.0], [125.0, 318.0]]], "lines": ["大抵のことは", "やるつもりです", "けど。"]}, {"box": [903, 564, 962, 726], "vertical": true, "font_size": 27, "lines_coords": [[[940.0, 567.0], [962.0, 567.0], [962.0, 718.0], [940.0, 718.0]], [[906.0, 564.0], [934.0, 564.0], [931.0, 726.0], [903.0, 726.0]]], "lines": ["別に今日でも", "大丈夫ですよ。"]}, {"box": [750, 621, 876, 829], "vertical": true, "font_size": 27, "lines_coords": [[[845.0, 625.0], [876.0, 625.0], [876.0, 806.0], [845.0, 806.0]], [[817.0, 626.0], [839.0, 626.0], [839.0, 829.0], [817.0, 829.0]], [[779.0, 621.0], [810.0, 621.0], [810.0, 809.0], [779.0, 809.0]], [[750.0, 623.0], [778.0, 623.0], [778.0, 731.0], [750.0, 731.0]]], "lines": ["軽く打ち合わせ", "たいんで場所とか", "指定してもらえ", "れば．．．．．"]}, {"box": [135, 668, 228, 810], "vertical": true, "font_size": 27, "lines_coords": [[[200.0, 670.0], [228.0, 670.0], [228.0, 809.0], [200.0, 809.0]], [[167.0, 668.0], [193.0, 668.0], [193.0, 804.0], [167.0, 804.0]], [[135.0, 668.0], [162.0, 668.0], [162.0, 810.0], [135.0, 810.0]]], "lines": ["．．．あーハイ、", "わかります、", "わかります。"]}, {"box": [916, 917, 1004, 1070], "vertical": true, "font_size": 23, "lines_coords": [[[978.0, 917.0], [1004.0, 917.0], [1004.0, 1026.0], [978.0, 1026.0]], [[948.0, 918.0], [970.0, 918.0], [970.0, 1046.0], [948.0, 1046.0]], [[917.0, 918.0], [939.0, 918.0], [939.0, 1070.0], [917.0, 1070.0]]], "lines": ["．．．よし、", "お前の携帯", "借りてくぜ？"]}, {"box": [600, 937, 623, 1044], "vertical": true, "font_size": 23, "lines_coords": [[[600.0, 982.0], [623.0, 982.0], [623.0, 1043.0], [600.0, 1043.0]]], "lines": ["え？"]}, {"box": [151, 985, 241, 1139], "vertical": true, "font_size": 26, "lines_coords": [[[210.0, 985.0], [239.0, 985.0], [239.0, 1115.0], [210.0, 1115.0]], [[179.0, 985.0], [207.0, 985.0], [207.0, 1115.0], [179.0, 1115.0]], [[151.0, 985.0], [173.0, 985.0], [173.0, 1137.0], [151.0, 1137.0]]], "lines": ["掃除くれー", "お前一人で", "てきんだろ？"]}, {"box": [670, 1281, 796, 1462], "vertical": true, "font_size": 28, "lines_coords": [[[762.0, 1281.0], [796.0, 1281.0], [796.0, 1364.0], [762.0, 1364.0]], [[735.0, 1285.0], [757.0, 1285.0], [757.0, 1439.0], [735.0, 1439.0]], [[701.0, 1284.0], [728.0, 1284.0], [728.0, 1462.0], [701.0, 1462.0]], [[670.0, 1282.0], [698.0, 1282.0], [698.0, 1373.0], [670.0, 1373.0]]], "lines": ["お互い", "用が済んだら", "いつもの公園に", "集合な。"]}, {"box": [95, 1340, 187, 1548], "vertical": true, "font_size": 28, "lines_coords": [[[159.0, 1340.0], [185.0, 1340.0], [182.0, 1523.0], [156.0, 1523.0]], [[128.0, 1343.0], [154.0, 1343.0], [154.0, 1548.0], [128.0, 1548.0]], [[95.0, 1340.0], [126.0, 1340.0], [126.0, 1396.0], [95.0, 1396.0]]], "lines": ["清水もいい加減", "一人立ちしねーと", "な！！"]}], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [656, 21, 815, 129], "vertical": false, "font_size": 70, "lines_coords": [[[656.0, 62.0], [796.0, 21.0], [815.0, 89.0], [675.0, 129.0]]], "lines": ["建物"]}, {"box": [184, 435, 245, 618], "vertical": true, "font_size": 25, "lines_coords": [[[215.0, 437.0], [243.0, 437.0], [243.0, 546.0], [215.0, 546.0]], [[184.0, 435.0], [210.0, 435.0], [210.0, 562.0], [184.0, 562.0]], [[187.0, 557.0], [209.0, 557.0], [209.0, 614.0], [187.0, 614.0]]], "lines": ["君の友達、", "勝手だねー", "．．．"]}], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [562, 168, 706, 209], "vertical": false, "font_size": 19.0, "lines_coords": [[[590.0, 171.0], [675.0, 168.0], [675.0, 184.0], [590.0, 187.0]], [[562.0, 187.0], [706.0, 181.0], [706.0, 203.0], [562.0, 209.0]]], "lines": ["大きさんはスポイントの", "南風が吹いた"]}, {"box": [190, 723, 264, 864], "vertical": true, "font_size": 36, "lines_coords": [[[225.0, 723.0], [264.0, 723.0], [264.0, 821.0], [225.0, 821.0]], [[190.0, 725.0], [223.0, 725.0], [223.0, 864.0], [190.0, 864.0]]], "lines": ["報復が", "したいの。"]}, {"box": [610, 1094, 668, 1273], "vertical": true, "font_size": 24, "lines_coords": [[[642.0, 1095.0], [668.0, 1095.0], [668.0, 1273.0], [642.0, 1273.0]], [[612.0, 1096.0], [634.0, 1096.0], [634.0, 1257.0], [612.0, 1257.0]]], "lines": ["．．．とりあえずの", "相談料と経費。"]}, {"box": [148, 1148, 254, 1343], "vertical": true, "font_size": 22, "lines_coords": [[[232.0, 1150.0], [254.0, 1150.0], [254.0, 1287.0], [232.0, 1287.0]], [[204.0, 1150.0], [226.0, 1150.0], [226.0, 1312.0], [204.0, 1312.0]], [[176.0, 1148.0], [198.0, 1148.0], [198.0, 1332.0], [176.0, 1332.0]], [[148.0, 1148.0], [170.0, 1148.0], [170.0, 1343.0], [148.0, 1343.0]]], "lines": ["それと平日の", "行動パターンは", "その封筒に書いて", "入れておいたから、"]}, {"box": [115, 1387, 201, 1542], "vertical": true, "font_size": 22, "lines_coords": [[[175.0, 1387.0], [201.0, 1387.0], [201.0, 1492.0], [175.0, 1492.0]], [[145.0, 1390.0], [167.0, 1390.0], [167.0, 1542.0], [145.0, 1542.0]], [[115.0, 1389.0], [135.0, 1389.0], [135.0, 1526.0], [115.0, 1526.0]]], "lines": ["捜すのに", "時間はかから", "ないと思う。"]}], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [915, 84, 942, 187], "vertical": true, "font_size": 26, "lines_coords": [[[915.0, 84.0], [942.0, 84.0], [942.0, 187.0], [915.0, 187.0]]], "lines": ["えーと．．．"]}, {"box": [767, 96, 879, 270], "vertical": true, "font_size": 26, "lines_coords": [[[853.0, 98.0], [879.0, 98.0], [879.0, 253.0], [853.0, 253.0]], [[823.0, 96.0], [850.0, 96.0], [850.0, 270.0], [823.0, 270.0]], [[793.0, 96.0], [820.0, 96.0], [820.0, 254.0], [793.0, 254.0]], [[767.0, 100.0], [789.0, 100.0], [789.0, 226.0], [767.0, 226.0]]], "lines": ["報復と一口に", "言っても程度が", "あると思うん", "てすけど．．．"]}, {"box": [640, 120, 695, 278], "vertical": true, "font_size": 27, "lines_coords": [[[668.0, 120.0], [695.0, 120.0], [695.0, 225.0], [668.0, 225.0]], [[640.0, 120.0], [662.0, 120.0], [662.0, 278.0], [640.0, 278.0]]], "lines": ["後ろから", "ぶん殴るとか、"]}, {"box": [506, 184, 600, 368], "vertical": true, "font_size": 27, "lines_coords": [[[565.0, 184.0], [600.0, 184.0], [600.0, 268.0], [565.0, 268.0]], [[537.0, 189.0], [564.0, 189.0], [564.0, 368.0], [537.0, 368.0]], [[506.0, 189.0], [532.0, 189.0], [532.0, 320.0], [506.0, 320.0]]], "lines": ["弱味に", "つけ込んで金を", "ゆするとか。"]}, {"box": [107, 51, 401, 82], "vertical": false, "font_size": 31, "lines_coords": [[[107.0, 51.0], [401.0, 51.0], [401.0, 82.0], [107.0, 82.0]]], "lines": ["おやすみプンプン国"]}, {"box": [125, 189, 184, 382], "vertical": true, "font_size": 25, "lines_coords": [[[154.0, 189.0], [182.0, 189.0], [182.0, 296.0], [154.0, 296.0]], [[126.0, 192.0], [148.0, 192.0], [148.0, 382.0], [126.0, 382.0]]], "lines": ["屋上から", "つき落とすとか。"]}, {"box": [582, 434, 664, 612], "vertical": true, "font_size": 24, "lines_coords": [[[640.0, 435.0], [662.0, 435.0], [662.0, 562.0], [640.0, 562.0]], [[612.0, 435.0], [634.0, 435.0], [634.0, 612.0], [612.0, 612.0]], [[582.0, 434.0], [609.0, 434.0], [609.0, 539.0], [582.0, 539.0]]], "lines": ["具体的には", "まだ考えてない", "けど．．．"]}, {"box": [164, 504, 224, 637], "vertical": true, "font_size": 26, "lines_coords": [[[196.0, 506.0], [223.0, 506.0], [223.0, 637.0], [196.0, 637.0]], [[164.0, 504.0], [190.0, 504.0], [190.0, 610.0], [164.0, 610.0]]], "lines": ["てきること", "なら．．．"]}, {"box": [883, 718, 940, 914], "vertical": true, "font_size": 24, "lines_coords": [[[912.0, 718.0], [939.0, 718.0], [939.0, 914.0], [912.0, 914.0]], [[884.0, 720.0], [906.0, 720.0], [906.0, 900.0], [884.0, 900.0]]], "lines": ["二度と取り返しの", "つかないくらい"]}, {"box": [154, 934, 246, 1117], "vertical": true, "font_size": 27, "lines_coords": [[[218.0, 934.0], [245.0, 934.0], [243.0, 1117.0], [217.0, 1117.0]], [[185.0, 935.0], [212.0, 935.0], [212.0, 1117.0], [185.0, 1117.0]], [[154.0, 935.0], [181.0, 935.0], [181.0, 1100.0], [154.0, 1100.0]]], "lines": ["この人の人生を", "目茶苦茶にして", "やってほしい。"]}, {"box": [928, 1210, 982, 1389], "vertical": true, "font_size": 23, "lines_coords": [[[960.0, 1210.0], [982.0, 1210.0], [982.0, 1389.0], [960.0, 1389.0]], [[928.0, 1210.0], [954.0, 1210.0], [954.0, 1370.0], [928.0, 1370.0]]], "lines": ["．．．これは単なる", "好奇心なんで、"]}, {"box": [815, 1353, 901, 1517], "vertical": true, "font_size": 23, "lines_coords": [[[879.0, 1356.0], [901.0, 1356.0], [901.0, 1482.0], [879.0, 1482.0]], [[845.0, 1353.0], [868.0, 1353.0], [870.0, 1509.0], [846.0, 1509.0]], [[815.0, 1356.0], [837.0, 1356.0], [837.0, 1517.0], [815.0, 1517.0]]], "lines": ["別に答えて", "くれなくても", "いいんスけど、"]}, {"box": [135, 1331, 227, 1510], "vertical": true, "font_size": 26, "lines_coords": [[[198.0, 1331.0], [225.0, 1331.0], [225.0, 1468.0], [198.0, 1468.0]], [[165.0, 1331.0], [193.0, 1331.0], [193.0, 1437.0], [165.0, 1437.0]], [[135.0, 1331.0], [157.0, 1331.0], [157.0, 1510.0], [135.0, 1510.0]]], "lines": ["．．．お姉さん、", "この人と", "どういう関係？"]}], "img_path": "130.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [926, 535, 989, 642], "vertical": true, "font_size": 30, "lines_coords": [[[962.0, 537.0], [989.0, 537.0], [989.0, 642.0], [962.0, 642.0]], [[926.0, 535.0], [960.0, 535.0], [960.0, 628.0], [926.0, 628.0]]], "lines": ["．．．会社の", "元同僚。"]}, {"box": [842, 665, 904, 759], "vertical": true, "font_size": 30, "lines_coords": [[[871.0, 665.0], [904.0, 665.0], [904.0, 751.0], [871.0, 751.0]], [[842.0, 667.0], [870.0, 667.0], [870.0, 759.0], [842.0, 759.0]]], "lines": ["．．．．．で", "元恋人。"]}, {"box": [200, 582, 290, 743], "vertical": true, "font_size": 27, "lines_coords": [[[254.0, 582.0], [287.0, 582.0], [290.0, 692.0], [257.0, 692.0]], [[228.0, 584.0], [254.0, 584.0], [254.0, 739.0], [228.0, 739.0]], [[200.0, 587.0], [221.0, 587.0], [221.0, 743.0], [200.0, 743.0]]], "lines": ["婚約して", "式の日取りも", "決まってたのに、"]}, {"box": [902, 1042, 989, 1250], "vertical": true, "font_size": 24, "lines_coords": [[[965.0, 1043.0], [987.0, 1043.0], [987.0, 1196.0], [965.0, 1196.0]], [[932.0, 1042.0], [959.0, 1042.0], [959.0, 1250.0], [932.0, 1250.0]], [[903.0, 1043.0], [925.0, 1043.0], [925.0, 1228.0], [903.0, 1228.0]]], "lines": ["．．．私は自分を", "仕事のできる人間", "と思ってるけど、"]}, {"box": [376, 1059, 404, 1164], "vertical": true, "font_size": 24, "lines_coords": [[[376.0, 1059.0], [404.0, 1059.0], [404.0, 1164.0], [376.0, 1164.0]]], "lines": ["別に．．．"]}, {"box": [114, 779, 237, 987], "vertical": true, "font_size": 27, "lines_coords": [[[210.0, 779.0], [237.0, 779.0], [237.0, 937.0], [210.0, 937.0]], [[178.0, 781.0], [204.0, 781.0], [204.0, 987.0], [178.0, 987.0]], [[146.0, 781.0], [173.0, 781.0], [173.0, 962.0], [146.0, 962.0]], [[114.0, 779.0], [143.0, 779.0], [143.0, 848.0], [114.0, 848.0]]], "lines": ["半年前に突然", "婚約を破棄されて", "別れを告げられ", "たの。"]}, {"box": [207, 1075, 328, 1281], "vertical": true, "font_size": 24, "lines_coords": [[[306.0, 1078.0], [328.0, 1078.0], [328.0, 1281.0], [306.0, 1281.0]], [[273.0, 1076.0], [295.0, 1076.0], [295.0, 1281.0], [273.0, 1281.0]], [[242.0, 1076.0], [264.0, 1076.0], [264.0, 1253.0], [242.0, 1253.0]], [[207.0, 1075.0], [234.0, 1075.0], [234.0, 1254.0], [207.0, 1254.0]]], "lines": ["フラれたくらいで", "会社辞めなくても", "よかったんじゃ", "ないですか．．．"]}, {"box": [626, 1271, 771, 1481], "vertical": true, "font_size": 26, "lines_coords": [[[743.0, 1271.0], [770.0, 1271.0], [768.0, 1481.0], [742.0, 1481.0]], [[714.0, 1275.0], [740.0, 1275.0], [740.0, 1481.0], [714.0, 1481.0]], [[687.0, 1275.0], [709.0, 1275.0], [709.0, 1437.0], [687.0, 1437.0]], [[656.0, 1275.0], [682.0, 1275.0], [682.0, 1456.0], [656.0, 1456.0]], [[626.0, 1275.0], [653.0, 1275.0], [653.0, 1479.0], [626.0, 1479.0]]], "lines": ["会社を辞めてから", "再就職先も見つけ", "られないまま、", "何ひとつ上手く", "いかない毎日で："]}], "img_path": "131.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [873, 85, 996, 332], "vertical": true, "font_size": 24, "lines_coords": [[[971.0, 87.0], [993.0, 87.0], [993.0, 289.0], [971.0, 289.0]], [[937.0, 85.0], [964.0, 85.0], [964.0, 332.0], [937.0, 332.0]], [[907.0, 87.0], [929.0, 87.0], [929.0, 265.0], [907.0, 265.0]], [[873.0, 87.0], [900.0, 87.0], [900.0, 273.0], [873.0, 273.0]]], "lines": ["同じ部署の部下の", "女に寝取られたことを", "会社中の人間が", "知ってる状況で、"]}, {"box": [109, 56, 395, 82], "vertical": false, "font_size": 26, "lines_coords": [[[109.0, 56.0], [395.0, 56.0], [395.0, 82.0], [109.0, 82.0]]], "lines": ["おやすみプンプンＥ"]}, {"box": [140, 187, 289, 409], "vertical": true, "font_size": 25, "lines_coords": [[[262.0, 187.0], [289.0, 187.0], [289.0, 325.0], [262.0, 325.0]], [[231.0, 187.0], [259.0, 187.0], [256.0, 345.0], [228.0, 345.0]], [[200.0, 187.0], [226.0, 187.0], [226.0, 371.0], [200.0, 371.0]], [[171.0, 189.0], [193.0, 189.0], [193.0, 409.0], [171.0, 409.0]], [[140.0, 189.0], [162.0, 189.0], [162.0, 367.0], [140.0, 367.0]]], "lines": ["きっと今頃、", "何食わぬ顔で", "式場の相談でも", "してる時期なんじゃ", "ないかしら．．．"]}, {"box": [733, 435, 822, 617], "vertical": true, "font_size": 23, "lines_coords": [[[795.0, 435.0], [821.0, 435.0], [821.0, 567.0], [795.0, 567.0]], [[765.0, 435.0], [787.0, 435.0], [787.0, 615.0], [765.0, 615.0]], [[734.0, 439.0], [756.0, 439.0], [756.0, 575.0], [734.0, 575.0]]], "lines": ["平然として", "られると思う？", "．．．私は無理。"]}, {"box": [152, 463, 181, 579], "vertical": true, "font_size": 29, "lines_coords": [[[152.0, 463.0], [181.0, 463.0], [181.0, 579.0], [152.0, 579.0]]], "lines": ["．．．でもね。"]}, {"box": [153, 467, 179, 581], "vertical": true, "font_size": 25, "lines_coords": [[[153.0, 467.0], [179.0, 467.0], [179.0, 581.0], [153.0, 581.0]]], "lines": ["．．．てもね。"]}, {"box": [882, 729, 970, 909], "vertical": true, "font_size": 26, "lines_coords": [[[942.0, 729.0], [970.0, 729.0], [970.0, 832.0], [942.0, 832.0]], [[912.0, 729.0], [939.0, 729.0], [939.0, 909.0], [912.0, 909.0]], [[882.0, 731.0], [904.0, 731.0], [904.0, 834.0], [882.0, 834.0]]], "lines": ["もし私が", "この人と別れて", "なければ"]}, {"box": [220, 895, 329, 1084], "vertical": true, "font_size": 31, "lines_coords": [[[295.0, 895.0], [329.0, 895.0], [329.0, 989.0], [295.0, 989.0]], [[257.0, 896.0], [289.0, 896.0], [289.0, 1084.0], [257.0, 1084.0]], [[220.0, 898.0], [248.0, 898.0], [248.0, 1031.0], [220.0, 1031.0]]], "lines": ["今日が", "結婚式の当日", "だったの。"]}, {"box": [862, 1287, 951, 1521], "vertical": true, "font_size": 25, "lines_coords": [[[928.0, 1289.0], [950.0, 1289.0], [950.0, 1443.0], [928.0, 1443.0]], [[893.0, 1287.0], [920.0, 1287.0], [920.0, 1496.0], [893.0, 1496.0]], [[862.0, 1287.0], [889.0, 1287.0], [889.0, 1521.0], [862.0, 1521.0]]], "lines": ["．．．ホントなら", "今頃私がドレスを", "着てるはずなのに："]}], "img_path": "132.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [556, 167, 584, 284], "vertical": true, "font_size": 26, "lines_coords": [[[556.0, 167.0], [582.0, 167.0], [582.0, 282.0], [556.0, 282.0]]], "lines": ["．．．決めた"]}, {"box": [295, 110, 388, 318], "vertical": true, "font_size": 25, "lines_coords": [[[364.0, 114.0], [385.0, 114.0], [385.0, 267.0], [364.0, 267.0]], [[329.0, 114.0], [356.0, 114.0], [356.0, 318.0], [329.0, 318.0]], [[295.0, 110.0], [321.0, 110.0], [325.0, 256.0], [298.0, 256.0]]], "lines": ["．．．お金なんて", "出せる限り払って", "あげるわよ。"]}, {"box": [96, 481, 183, 686], "vertical": true, "font_size": 23, "lines_coords": [[[156.0, 481.0], [182.0, 481.0], [182.0, 614.0], [156.0, 614.0]], [[126.0, 482.0], [148.0, 482.0], [148.0, 685.0], [126.0, 685.0]], [[96.0, 482.0], [118.0, 482.0], [118.0, 648.0], [96.0, 648.0]]], "lines": ["どうせ私も", "長生きするつもり", "なんてないし。"]}, {"box": [873, 1129, 902, 1284], "vertical": true, "font_size": 27, "lines_coords": [[[873.0, 1129.0], [900.0, 1129.0], [900.0, 1282.0], [873.0, 1282.0]]], "lines": ["この人を．．"]}, {"box": [159, 1329, 204, 1460], "vertical": true, "font_size": 45, "lines_coords": [[[159.0, 1329.0], [204.0, 1329.0], [204.0, 1460.0], [159.0, 1460.0]]], "lines": ["殺して。"]}], "img_path": "133.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "134.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "135.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [900, 79, 926, 220], "vertical": true, "font_size": 26, "lines_coords": [[[900.0, 79.0], [926.0, 79.0], [926.0, 220.0], [900.0, 220.0]]], "lines": ["．．．お姉さん。"]}, {"box": [32, 285, 85, 451], "vertical": true, "font_size": 50, "lines_coords": [[[32.0, 287.0], [82.0, 285.0], [85.0, 450.0], [35.0, 451.0]]], "lines": ["第５３話"]}, {"box": [176, 510, 237, 615], "vertical": true, "font_size": 29, "lines_coords": [[[207.0, 510.0], [237.0, 510.0], [234.0, 615.0], [204.0, 615.0]], [[176.0, 512.0], [204.0, 512.0], [204.0, 615.0], [176.0, 615.0]]], "lines": ["ホントに", "いいの？"]}, {"box": [234, 809, 300, 993], "vertical": true, "font_size": 34, "lines_coords": [[[257.0, 809.0], [300.0, 809.0], [300.0, 881.0], [257.0, 881.0]], [[234.0, 814.0], [260.0, 814.0], [260.0, 993.0], [234.0, 993.0]]], "lines": ["．．．俺、", "やっちゃうよ？"]}, {"box": [854, 1159, 979, 1326], "vertical": true, "font_size": 30, "lines_coords": [[[945.0, 1159.0], [979.0, 1159.0], [979.0, 1243.0], [945.0, 1243.0]], [[917.0, 1164.0], [943.0, 1164.0], [943.0, 1293.0], [917.0, 1293.0]], [[882.0, 1160.0], [915.0, 1160.0], [915.0, 1243.0], [882.0, 1243.0]], [[854.0, 1162.0], [881.0, 1162.0], [881.0, 1323.0], [854.0, 1323.0]]], "lines": ["美人な", "お姉さんに", "昼間の", "ファミレスで、"]}, {"box": [198, 1328, 295, 1487], "vertical": true, "font_size": 32, "lines_coords": [[[253.0, 1328.0], [295.0, 1328.0], [295.0, 1393.0], [253.0, 1393.0]], [[226.0, 1332.0], [254.0, 1332.0], [257.0, 1487.0], [229.0, 1487.0]], [[198.0, 1334.0], [225.0, 1334.0], [225.0, 1448.0], [198.0, 1448.0]]], "lines": ["人を", "殺してくれと", "頼まれた。"]}], "img_path": "136.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [859, 131, 918, 272], "vertical": true, "font_size": 27, "lines_coords": [[[889.0, 131.0], [917.0, 131.0], [918.0, 260.0], [890.0, 260.0]], [[859.0, 132.0], [885.0, 132.0], [885.0, 271.0], [859.0, 271.0]]], "lines": ["実感なんて", "湧く訳ない。"]}, {"box": [150, 496, 277, 729], "vertical": true, "font_size": 26, "lines_coords": [[[248.0, 498.0], [275.0, 498.0], [275.0, 703.0], [248.0, 703.0]], [[217.0, 498.0], [243.0, 498.0], [243.0, 728.0], [217.0, 728.0]], [[184.0, 496.0], [210.0, 496.0], [210.0, 729.0], [184.0, 729.0]], [[150.0, 498.0], [176.0, 498.0], [179.0, 632.0], [153.0, 632.0]]], "lines": ["からかわれただけ", "なんじゃねーかって", "気持ちがあったのも", "確かだけど、"]}, {"box": [850, 878, 988, 1143], "vertical": true, "font_size": 30, "lines_coords": [[[945.0, 882.0], [976.0, 882.0], [976.0, 1143.0], [945.0, 1143.0]], [[914.0, 881.0], [945.0, 881.0], [945.0, 1115.0], [914.0, 1115.0]], [[876.0, 879.0], [909.0, 879.0], [914.0, 1115.0], [881.0, 1115.0]], [[850.0, 878.0], [876.0, 878.0], [876.0, 1078.0], [850.0, 1078.0]]], "lines": ["テレビとかニュースで", "やってる事件も案外", "こんなもんなのかも", "しれないと思う。"]}, {"box": [296, 867, 396, 1033], "vertical": true, "font_size": 32, "lines_coords": [[[364.0, 868.0], [396.0, 868.0], [396.0, 978.0], [364.0, 978.0]], [[334.0, 871.0], [360.0, 871.0], [360.0, 1031.0], [334.0, 1031.0]], [[296.0, 867.0], [335.0, 867.0], [335.0, 973.0], [296.0, 973.0]]], "lines": ["たいした", "意味も理由も", "無い。"]}, {"box": [723, 1305, 782, 1537], "vertical": true, "font_size": 29, "lines_coords": [[[751.0, 1307.0], [782.0, 1307.0], [782.0, 1490.0], [751.0, 1490.0]], [[723.0, 1309.0], [750.0, 1309.0], [750.0, 1493.0], [723.0, 1493.0]]], "lines": ["突然、ある日だ", "ポンと起こる。！"]}, {"box": [167, 1154, 203, 1404], "vertical": true, "font_size": 28, "lines_coords": [[[167.0, 1154.0], [198.0, 1154.0], [203.0, 1404.0], [171.0, 1404.0]]], "lines": ["．．．なんとなく流れで"]}, {"box": [106, 1190, 165, 1401], "vertical": true, "font_size": 28, "lines_coords": [[[139.0, 1190.0], [165.0, 1190.0], [165.0, 1393.0], [139.0, 1393.0]], [[106.0, 1190.0], [132.0, 1190.0], [132.0, 1401.0], [106.0, 1401.0]]], "lines": ["起きることが．．．", "起きるってだけ。"]}], "img_path": "137.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [653, 35, 688, 230], "vertical": true, "font_size": 28, "lines_coords": [[[653.0, 35.0], [681.0, 35.0], [685.0, 226.0], [657.0, 226.0]]], "lines": ["．．．つまりこれは、"]}, {"box": [120, 34, 178, 189], "vertical": true, "font_size": 26, "lines_coords": [[[148.0, 34.0], [175.0, 34.0], [178.0, 189.0], [151.0, 189.0]], [[120.0, 37.0], [146.0, 37.0], [146.0, 148.0], [120.0, 148.0]]], "lines": ["そういう運命", "ってこと。"]}, {"box": [164, 542, 223, 646], "vertical": true, "font_size": 27, "lines_coords": [[[195.0, 543.0], [223.0, 543.0], [223.0, 645.0], [195.0, 645.0]], [[164.0, 542.0], [190.0, 542.0], [190.0, 646.0], [164.0, 646.0]]], "lines": ["ホントに", "いた．．．"]}, {"box": [870, 837, 934, 929], "vertical": true, "font_size": 33, "lines_coords": [[[901.0, 839.0], [934.0, 839.0], [934.0, 921.0], [901.0, 921.0]], [[870.0, 837.0], [903.0, 837.0], [903.0, 929.0], [870.0, 929.0]]], "lines": ["今なら", "自分は、"]}, {"box": [196, 1315, 287, 1468], "vertical": true, "font_size": 26, "lines_coords": [[[259.0, 1315.0], [285.0, 1315.0], [285.0, 1443.0], [259.0, 1443.0]], [[228.0, 1315.0], [254.0, 1315.0], [254.0, 1468.0], [228.0, 1468.0]], [[196.0, 1315.0], [223.0, 1315.0], [223.0, 1429.0], [196.0, 1429.0]]], "lines": ["なんだって", "できるような", "気がした。"]}], "img_path": "138.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [764, 1114, 932, 1175], "vertical": false, "font_size": 57, "lines_coords": [[[765.0, 1114.0], [932.0, 1118.0], [931.0, 1175.0], [764.0, 1170.0]]], "lines": ["松翳象"]}, {"box": [479, 1324, 503, 1439], "vertical": true, "font_size": 22, "lines_coords": [[[479.0, 1326.0], [501.0, 1326.0], [501.0, 1434.0], [479.0, 1434.0]]], "lines": ["わかるよ。"]}, {"box": [289, 1318, 415, 1474], "vertical": true, "font_size": 28, "lines_coords": [[[389.0, 1320.0], [415.0, 1320.0], [415.0, 1473.0], [389.0, 1473.0]], [[356.0, 1320.0], [384.0, 1320.0], [384.0, 1425.0], [356.0, 1425.0]], [[328.0, 1321.0], [350.0, 1321.0], [350.0, 1450.0], [328.0, 1450.0]], [[289.0, 1318.0], [323.0, 1318.0], [323.0, 1410.0], [289.0, 1410.0]]], "lines": ["きっと普段は", "フツーに", "善良な市民", "なんだ。"]}, {"box": [204, 1323, 231, 1463], "vertical": true, "font_size": 22, "lines_coords": [[[206.0, 1325.0], [228.0, 1325.0], [228.0, 1457.0], [206.0, 1457.0]]], "lines": ["基本的には、"]}], "img_path": "139.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [878, 56, 1000, 250], "vertical": true, "font_size": 26, "lines_coords": [[[973.0, 59.0], [1000.0, 59.0], [1000.0, 187.0], [973.0, 187.0]], [[939.0, 56.0], [967.0, 56.0], [968.0, 239.0], [940.0, 239.0]], [[909.0, 59.0], [935.0, 59.0], [935.0, 240.0], [909.0, 240.0]], [[878.0, 59.0], [901.0, 59.0], [903.0, 248.0], [879.0, 248.0]]], "lines": ["だから別に", "このオッサンが", "特別悪い人間だ", "なんて思わない。"]}, {"box": [101, 64, 387, 85], "vertical": false, "font_size": 21, "lines_coords": [[[101.0, 64.0], [387.0, 64.0], [387.0, 85.0], [101.0, 85.0]]], "lines": ["おやすみプンプンＢ"]}, {"box": [684, 560, 807, 752], "vertical": true, "font_size": 27, "lines_coords": [[[779.0, 562.0], [806.0, 562.0], [806.0, 746.0], [779.0, 746.0]], [[746.0, 560.0], [773.0, 560.0], [775.0, 748.0], [748.0, 748.0]], [[715.0, 564.0], [742.0, 564.0], [742.0, 715.0], [715.0, 715.0]], [[684.0, 560.0], [710.0, 560.0], [712.0, 751.0], [685.0, 751.0]]], "lines": ["あのお姉さんも、", "もちろん自分も、", "一皮めくれば", "同じ様なもんだ。"]}, {"box": [92, 589, 217, 746], "vertical": true, "font_size": 28, "lines_coords": [[[190.0, 592.0], [217.0, 592.0], [217.0, 745.0], [190.0, 745.0]], [[153.0, 589.0], [185.0, 589.0], [189.0, 723.0], [156.0, 723.0]], [[126.0, 592.0], [153.0, 592.0], [153.0, 746.0], [126.0, 746.0]], [[92.0, 592.0], [118.0, 592.0], [121.0, 743.0], [95.0, 743.0]]], "lines": ["元々この世に", "正しい人間", "なんか一人も", "いないだろ？"]}, {"box": [878, 864, 935, 1015], "vertical": true, "font_size": 24, "lines_coords": [[[909.0, 864.0], [935.0, 864.0], [935.0, 1015.0], [909.0, 1015.0]], [[879.0, 865.0], [901.0, 865.0], [901.0, 971.0], [879.0, 971.0]]], "lines": ["きっとほんの", "少しだけ、"]}, {"box": [164, 1350, 256, 1479], "vertical": true, "font_size": 26, "lines_coords": [[[228.0, 1351.0], [254.0, 1351.0], [254.0, 1479.0], [228.0, 1479.0]], [[195.0, 1350.0], [221.0, 1350.0], [221.0, 1478.0], [195.0, 1478.0]], [[164.0, 1350.0], [190.0, 1350.0], [190.0, 1462.0], [164.0, 1462.0]]], "lines": ["バランスが", "崩れただけ", "なんだろ。"]}], "img_path": "140.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [289, 29, 320, 132], "vertical": true, "font_size": 28, "lines_coords": [[[289.0, 29.0], [317.0, 29.0], [320.0, 132.0], [292.0, 132.0]]], "lines": ["．．．"]}, {"box": [281, 318, 373, 406], "vertical": false, "font_size": 71.5, "lines_coords": [[[285.0, 339.0], [326.0, 340.0], [320.0, 406.0], [281.0, 403.0]], [[332.0, 318.0], [373.0, 318.0], [373.0, 396.0], [332.0, 396.0]]], "lines": ["．．．", "定期２７"]}, {"box": [705, 940, 829, 1106], "vertical": true, "font_size": 26, "lines_coords": [[[801.0, 940.0], [829.0, 940.0], [826.0, 1070.0], [798.0, 1070.0]], [[768.0, 940.0], [795.0, 940.0], [795.0, 1070.0], [768.0, 1070.0]], [[737.0, 940.0], [764.0, 940.0], [764.0, 1046.0], [737.0, 1046.0]], [[707.0, 943.0], [729.0, 943.0], [729.0, 1103.0], [707.0, 1103.0]]], "lines": ["人ってのは", "観察すれば", "するほど", "変な生き物だ。"]}, {"box": [473, 939, 598, 1121], "vertical": true, "font_size": 24, "lines_coords": [[[570.0, 939.0], [596.0, 939.0], [593.0, 1121.0], [567.0, 1121.0]], [[535.0, 939.0], [562.0, 939.0], [562.0, 1093.0], [535.0, 1093.0]], [[507.0, 942.0], [529.0, 942.0], [529.0, 1118.0], [507.0, 1118.0]], [[473.0, 940.0], [496.0, 940.0], [498.0, 1071.0], [475.0, 1071.0]]], "lines": ["誰かに操られた", "人形みたいに", "せわしなく動き", "まわったり"]}, {"box": [314, 945, 373, 1098], "vertical": true, "font_size": 22, "lines_coords": [[[346.0, 946.0], [368.0, 946.0], [368.0, 1096.0], [346.0, 1096.0]], [[315.0, 946.0], [337.0, 946.0], [337.0, 1082.0], [315.0, 1082.0]]], "lines": ["突然ひたって", "止まったり。"]}], "img_path": "141.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [723, 499, 752, 640], "vertical": true, "font_size": 27, "lines_coords": [[[723.0, 500.0], [750.0, 500.0], [750.0, 635.0], [723.0, 635.0]]], "lines": ["．．．なんだろ。"]}, {"box": [539, 492, 665, 700], "vertical": true, "font_size": 28, "lines_coords": [[[637.0, 493.0], [665.0, 493.0], [662.0, 685.0], [634.0, 685.0]], [[603.0, 493.0], [629.0, 493.0], [629.0, 700.0], [603.0, 700.0]], [[568.0, 492.0], [596.0, 492.0], [600.0, 648.0], [571.0, 648.0]], [[539.0, 493.0], [567.0, 493.0], [567.0, 581.0], [539.0, 581.0]]], "lines": ["今、この場所には", "こんなにたくさん", "人がいるはす", "なのに、"]}, {"box": [320, 496, 443, 651], "vertical": true, "font_size": 27, "lines_coords": [[[415.0, 496.0], [442.0, 496.0], [442.0, 651.0], [415.0, 651.0]], [[382.0, 498.0], [410.0, 498.0], [407.0, 651.0], [379.0, 651.0]], [[351.0, 498.0], [378.0, 498.0], [378.0, 626.0], [351.0, 626.0]], [[320.0, 496.0], [346.0, 496.0], [346.0, 609.0], [320.0, 609.0]]], "lines": ["本物の人間が", "一人もいない", "ような気が", "するのは。"]}, {"box": [856, 776, 982, 918], "vertical": true, "font_size": 30, "lines_coords": [[[950.0, 776.0], [982.0, 776.0], [982.0, 884.0], [950.0, 884.0]], [[918.0, 778.0], [951.0, 778.0], [951.0, 885.0], [918.0, 885.0]], [[890.0, 781.0], [917.0, 781.0], [917.0, 910.0], [890.0, 910.0]], [[856.0, 778.0], [884.0, 778.0], [887.0, 918.0], [859.0, 918.0]]], "lines": ["どいつも", "こいつも", "一人残らず", "からっぽで、"]}, {"box": [325, 932, 387, 985], "vertical": false, "font_size": 19.333333333333332, "lines_coords": [[[326.0, 946.0], [362.0, 950.0], [360.0, 967.0], [325.0, 964.0]], [[326.0, 932.0], [387.0, 932.0], [387.0, 950.0], [326.0, 950.0]], [[328.0, 960.0], [385.0, 964.0], [384.0, 985.0], [326.0, 982.0]]], "lines": ["その時にはお", "つの本口", "うブラザ"]}, {"box": [172, 885, 294, 1091], "vertical": true, "font_size": 25, "lines_coords": [[[267.0, 885.0], [293.0, 885.0], [293.0, 1015.0], [267.0, 1015.0]], [[234.0, 885.0], [260.0, 885.0], [260.0, 1042.0], [234.0, 1042.0]], [[203.0, 887.0], [229.0, 887.0], [229.0, 1090.0], [203.0, 1090.0]], [[173.0, 887.0], [195.0, 887.0], [195.0, 1090.0], [173.0, 1090.0]]], "lines": ["自分自身が", "誰なのかすら", "わからなくなって", "るんじゃないか？"]}], "img_path": "142.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [546, 126, 607, 344], "vertical": true, "font_size": 27, "lines_coords": [[[579.0, 128.0], [606.0, 128.0], [606.0, 256.0], [579.0, 256.0]], [[548.0, 126.0], [575.0, 126.0], [573.0, 340.0], [546.0, 340.0]]], "lines": ["でもそれは", "俺だって同じこと。"]}, {"box": [398, 126, 490, 334], "vertical": true, "font_size": 25, "lines_coords": [[[460.0, 126.0], [487.0, 126.0], [489.0, 332.0], [462.0, 332.0]], [[432.0, 128.0], [454.0, 128.0], [454.0, 331.0], [432.0, 331.0]], [[398.0, 126.0], [425.0, 126.0], [425.0, 282.0], [398.0, 282.0]]], "lines": ["自分が自分だって", "ことをとうやって", "証明できる？"]}, {"box": [259, 25, 282, 100], "vertical": true, "font_size": 26, "lines_coords": [[[259.0, 25.0], [282.0, 25.0], [282.0, 100.0], [259.0, 100.0]]], "lines": ["ごめんなさい"]}, {"box": [201, 29, 229, 93], "vertical": true, "font_size": 26, "lines_coords": [[[201.0, 29.0], [229.0, 29.0], [229.0, 93.0], [201.0, 93.0]]], "lines": ["すごい"]}, {"box": [479, 592, 570, 784], "vertical": true, "font_size": 26, "lines_coords": [[[543.0, 592.0], [570.0, 592.0], [570.0, 721.0], [543.0, 721.0]], [[510.0, 592.0], [539.0, 592.0], [539.0, 700.0], [510.0, 700.0]], [[479.0, 593.0], [503.0, 593.0], [504.0, 778.0], [481.0, 778.0]]], "lines": ["そういえば", "子供の頃、", "清水が言ってた。"]}, {"box": [346, 590, 409, 732], "vertical": true, "font_size": 30, "lines_coords": [[[376.0, 592.0], [409.0, 592.0], [409.0, 673.0], [376.0, 673.0]], [[346.0, 590.0], [373.0, 590.0], [376.0, 731.0], [350.0, 731.0]]], "lines": ["神様が", "見えるって。"]}, {"box": [131, 592, 254, 753], "vertical": true, "font_size": 24, "lines_coords": [[[226.0, 592.0], [253.0, 592.0], [250.0, 718.0], [223.0, 718.0]], [[195.0, 595.0], [217.0, 595.0], [217.0, 725.0], [195.0, 725.0]], [[160.0, 592.0], [187.0, 592.0], [187.0, 746.0], [160.0, 746.0]], [[131.0, 593.0], [153.0, 593.0], [153.0, 746.0], [131.0, 746.0]]], "lines": ["全知全能の", "何かなんて、", "とんだ与太話", "だと思うけど"]}, {"box": [935, 857, 993, 1037], "vertical": true, "font_size": 25, "lines_coords": [[[967.0, 857.0], [993.0, 857.0], [993.0, 1037.0], [967.0, 1037.0]], [[935.0, 857.0], [962.0, 857.0], [962.0, 981.0], [935.0, 981.0]]], "lines": ["．．．あ、もしもし", "俺だけどー"]}, {"box": [940, 985, 957, 1035], "vertical": true, "font_size": 25, "lines_coords": [[[940.0, 985.0], [957.0, 985.0], [957.0, 1035.0], [940.0, 1035.0]]], "lines": ["．．．"]}, {"box": [873, 925, 900, 1045], "vertical": true, "font_size": 25, "lines_coords": [[[873.0, 925.0], [900.0, 925.0], [900.0, 1045.0], [873.0, 1045.0]]], "lines": ["．．．ゴメン！！"]}, {"box": [792, 921, 873, 1134], "vertical": true, "font_size": 25, "lines_coords": [[[845.0, 921.0], [873.0, 921.0], [868.0, 1125.0], [840.0, 1125.0]], [[817.0, 923.0], [843.0, 923.0], [843.0, 1134.0], [817.0, 1134.0]], [[792.0, 925.0], [814.0, 925.0], [814.0, 1085.0], [792.0, 1085.0]]], "lines": ["今、ギリギリで電車", "乗り過ごしちゃって", "ごあ～～～．．．"]}, {"box": [225, 1064, 307, 1262], "vertical": true, "font_size": 22, "lines_coords": [[[276.0, 1064.0], [304.0, 1064.0], [307.0, 1170.0], [279.0, 1170.0]], [[253.0, 1064.0], [273.0, 1064.0], [273.0, 1250.0], [253.0, 1250.0]], [[225.0, 1064.0], [246.0, 1064.0], [246.0, 1262.0], [225.0, 1262.0]]], "lines": ["．．．えっ、", "もう着いてんの！？", "うわ、ホントごめん！！"]}, {"box": [134, 1292, 240, 1521], "vertical": true, "font_size": 22, "lines_coords": [[[218.0, 1292.0], [240.0, 1292.0], [240.0, 1518.0], [218.0, 1518.0]], [[189.0, 1293.0], [210.0, 1293.0], [210.0, 1521.0], [189.0, 1521.0]], [[162.0, 1292.0], [184.0, 1292.0], [184.0, 1456.0], [162.0, 1456.0]], [[134.0, 1295.0], [156.0, 1295.0], [156.0, 1454.0], [134.0, 1454.0]]], "lines": ["もしアレだったらホラ", "テキトーに喫茶店とか", "入っちゃってて", "いいからさ．．．"]}], "img_path": "143.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [715, 51, 773, 236], "vertical": true, "font_size": 24, "lines_coords": [[[745.0, 53.0], [771.0, 53.0], [771.0, 204.0], [745.0, 204.0]], [[715.0, 53.0], [737.0, 53.0], [737.0, 229.0], [715.0, 229.0]]], "lines": ["自分が誰だか", "わからないから"]}, {"box": [490, 48, 614, 230], "vertical": true, "font_size": 25, "lines_coords": [[[582.0, 50.0], [609.0, 50.0], [614.0, 228.0], [587.0, 228.0]], [[553.0, 50.0], [579.0, 50.0], [579.0, 209.0], [553.0, 209.0]], [[520.0, 48.0], [546.0, 48.0], [543.0, 203.0], [517.0, 203.0]], [[490.0, 51.0], [512.0, 51.0], [512.0, 181.0], [490.0, 181.0]]], "lines": ["神様をつくって", "すがりついて、", "不安も責任も", "擦り付けて"]}, {"box": [329, 48, 422, 202], "vertical": true, "font_size": 25, "lines_coords": [[[393.0, 50.0], [420.0, 50.0], [420.0, 153.0], [393.0, 153.0]], [[365.0, 51.0], [387.0, 51.0], [387.0, 201.0], [365.0, 201.0]], [[329.0, 48.0], [356.0, 48.0], [356.0, 176.0], [329.0, 176.0]]], "lines": ["とうにか", "生きてるのか", "人なのか？"]}, {"box": [767, 1351, 830, 1482], "vertical": true, "font_size": 30, "lines_coords": [[[800.0, 1353.0], [828.0, 1353.0], [829.0, 1481.0], [801.0, 1481.0]], [[767.0, 1353.0], [800.0, 1353.0], [800.0, 1437.0], [767.0, 1437.0]]], "lines": ["残念ながら", "今日は、"]}, {"box": [697, 1350, 723, 1540], "vertical": true, "font_size": 22, "lines_coords": [[[698.0, 1354.0], [720.0, 1354.0], [720.0, 1532.0], [698.0, 1532.0]]], "lines": ["少なくとも今は"]}, {"box": [504, 1351, 599, 1564], "vertical": true, "font_size": 27, "lines_coords": [[[570.0, 1351.0], [596.0, 1351.0], [595.0, 1531.0], [568.0, 1531.0]], [[537.0, 1353.0], [564.0, 1353.0], [564.0, 1482.0], [537.0, 1482.0]], [[506.0, 1353.0], [532.0, 1353.0], [531.0, 1562.0], [504.0, 1562.0]]], "lines": ["俺はポケットの", "中の手付金", "１２万の感触だけか"]}, {"box": [287, 1349, 381, 1558], "vertical": true, "font_size": 30, "lines_coords": [[[351.0, 1351.0], [378.0, 1351.0], [381.0, 1557.0], [354.0, 1557.0]], [[318.0, 1351.0], [353.0, 1351.0], [353.0, 1434.0], [318.0, 1434.0]], [[287.0, 1351.0], [315.0, 1351.0], [318.0, 1467.0], [290.0, 1467.0]]], "lines": ["気持ち悪いくらい", "鮮明で", "生々しい。"]}], "img_path": "144.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [585, 1050, 681, 1156], "vertical": true, "font_size": 30, "lines_coords": [[[653.0, 1053.0], [681.0, 1053.0], [681.0, 1131.0], [653.0, 1131.0]], [[623.0, 1053.0], [650.0, 1053.0], [650.0, 1156.0], [623.0, 1156.0]], [[585.0, 1050.0], [621.0, 1050.0], [621.0, 1120.0], [585.0, 1120.0]]], "lines": ["背中が", "あるから", "押す。"]}, {"box": [417, 1048, 515, 1180], "vertical": true, "font_size": 31, "lines_coords": [[[478.0, 1051.0], [515.0, 1051.0], [515.0, 1110.0], [478.0, 1110.0]], [[454.0, 1054.0], [476.0, 1054.0], [476.0, 1178.0], [454.0, 1178.0]], [[417.0, 1048.0], [451.0, 1048.0], [451.0, 1120.0], [417.0, 1120.0]]], "lines": ["ただ", "それだけの", "こと。"]}, {"box": [862, 1289, 956, 1431], "vertical": true, "font_size": 27, "lines_coords": [[[929.0, 1289.0], [956.0, 1289.0], [953.0, 1420.0], [926.0, 1420.0]], [[895.0, 1292.0], [921.0, 1292.0], [921.0, 1420.0], [895.0, 1420.0]], [[865.0, 1290.0], [892.0, 1290.0], [889.0, 1431.0], [862.0, 1431.0]]], "lines": ["１番ホーム", "急行列車が", "通過します。"]}, {"box": [137, 1340, 226, 1520], "vertical": true, "font_size": 25, "lines_coords": [[[198.0, 1340.0], [225.0, 1340.0], [225.0, 1495.0], [198.0, 1495.0]], [[167.0, 1340.0], [193.0, 1340.0], [193.0, 1520.0], [167.0, 1520.0]], [[137.0, 1340.0], [159.0, 1340.0], [159.0, 1492.0], [137.0, 1492.0]]], "lines": ["白線の内側に", "下がってお待ち", "ください．．．"]}], "img_path": "145.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [648, 64, 707, 253], "vertical": true, "font_size": 22, "lines_coords": [[[681.0, 68.0], [703.0, 68.0], [703.0, 164.0], [681.0, 164.0]], [[651.0, 65.0], [673.0, 65.0], [673.0, 246.0], [651.0, 246.0]]], "lines": ["たいした", "意味なんて無い。"]}, {"box": [487, 64, 513, 202], "vertical": true, "font_size": 20, "lines_coords": [[[489.0, 65.0], [509.0, 65.0], [509.0, 198.0], [489.0, 198.0]]], "lines": ["悪意も無い。"]}, {"box": [400, 64, 425, 227], "vertical": true, "font_size": 20, "lines_coords": [[[401.0, 67.0], [421.0, 67.0], [421.0, 221.0], [401.0, 221.0]]], "lines": ["正義感も無い"]}, {"box": [901, 371, 931, 435], "vertical": true, "font_size": 30, "lines_coords": [[[901.0, 371.0], [931.0, 371.0], [931.0, 435.0], [901.0, 435.0]]], "lines": ["ほら。"]}, {"box": [153, 631, 218, 789], "vertical": true, "font_size": 33, "lines_coords": [[[190.0, 635.0], [217.0, 635.0], [217.0, 789.0], [190.0, 789.0]], [[153.0, 631.0], [192.0, 631.0], [192.0, 678.0], [153.0, 678.0]]], "lines": ["やっちゃえよ", "俺。"]}, {"box": [853, 925, 910, 1054], "vertical": true, "font_size": 25, "lines_coords": [[[882.0, 925.0], [910.0, 925.0], [907.0, 1031.0], [879.0, 1031.0]], [[854.0, 928.0], [876.0, 928.0], [876.0, 1054.0], [854.0, 1054.0]]], "lines": ["人は自由", "なんだろ？"]}, {"box": [271, 1020, 800, 1054], "vertical": false, "font_size": 31, "lines_coords": [[[271.0, 1020.0], [800.0, 1023.0], [800.0, 1054.0], [271.0, 1051.0]]], "lines": ["体勢を見かけましたら、係員、巡回中の審"]}, {"box": [744, 1233, 779, 1406], "vertical": true, "font_size": 31, "lines_coords": [[[745.0, 1234.0], [776.0, 1234.0], [776.0, 1401.0], [745.0, 1401.0]]], "lines": ["．．．なんだよ。"]}, {"box": [317, 1279, 396, 1414], "vertical": true, "font_size": 40, "lines_coords": [[[356.0, 1279.0], [393.0, 1279.0], [396.0, 1410.0], [359.0, 1410.0]], [[317.0, 1279.0], [360.0, 1279.0], [360.0, 1414.0], [317.0, 1414.0]]], "lines": ["なんだよ", "畜生．．．"]}], "img_path": "146.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [803, 212, 901, 516], "vertical": true, "font_size": 44, "lines_coords": [[[854.0, 214.0], [898.0, 214.0], [898.0, 467.0], [854.0, 467.0]], [[804.0, 212.0], [848.0, 212.0], [848.0, 500.0], [804.0, 500.0]]], "lines": ["今日はホント", "馬鹿みたいに．．．"]}, {"box": [389, 293, 439, 431], "vertical": true, "font_size": 46, "lines_coords": [[[389.0, 295.0], [434.0, 293.0], [439.0, 423.0], [393.0, 425.0]]], "lines": ["．．．天気"]}, {"box": [282, 389, 331, 599], "vertical": true, "font_size": 44, "lines_coords": [[[282.0, 389.0], [326.0, 389.0], [331.0, 598.0], [287.0, 598.0]]], "lines": ["いいな．．．"]}], "img_path": "147.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "148.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [929, 1250, 956, 1354], "vertical": true, "font_size": 24, "lines_coords": [[[929.0, 1250.0], [956.0, 1250.0], [956.0, 1354.0], [929.0, 1354.0]]], "lines": ["なんか．．．"]}, {"box": [837, 1385, 893, 1515], "vertical": true, "font_size": 24, "lines_coords": [[[867.0, 1385.0], [893.0, 1385.0], [893.0, 1515.0], [867.0, 1515.0]], [[837.0, 1387.0], [859.0, 1387.0], [859.0, 1514.0], [837.0, 1514.0]]], "lines": ["君一人じゃ", "頼りないな"]}, {"box": [804, 1435, 826, 1489], "vertical": true, "font_size": 24, "lines_coords": [[[804.0, 1435.0], [826.0, 1435.0], [826.0, 1489.0], [804.0, 1489.0]]], "lines": ["．．．！？"]}, {"box": [156, 1346, 215, 1527], "vertical": true, "font_size": 23, "lines_coords": [[[190.0, 1348.0], [212.0, 1348.0], [212.0, 1526.0], [190.0, 1526.0]], [[157.0, 1346.0], [181.0, 1346.0], [179.0, 1526.0], [156.0, 1526.0]]], "lines": ["まぁ無理強いは", "しないけどね．．．"]}], "img_path": "149.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [893, 56, 1001, 263], "vertical": true, "font_size": 22, "lines_coords": [[[976.0, 56.0], [998.0, 56.0], [1000.0, 243.0], [978.0, 243.0]], [[950.0, 59.0], [971.0, 59.0], [971.0, 193.0], [950.0, 193.0]], [[920.0, 57.0], [942.0, 57.0], [942.0, 262.0], [920.0, 262.0]], [[893.0, 57.0], [915.0, 57.0], [915.0, 179.0], [893.0, 179.0]]], "lines": ["これから行く部屋", "身寄りの無い", "７０過ぎのジイさんが", "住んでてね。"]}, {"box": [350, 114, 434, 288], "vertical": true, "font_size": 26, "lines_coords": [[[404.0, 114.0], [434.0, 114.0], [434.0, 190.0], [404.0, 190.0]], [[381.0, 117.0], [403.0, 117.0], [403.0, 287.0], [381.0, 287.0]], [[350.0, 114.0], [376.0, 114.0], [376.0, 234.0], [350.0, 234.0]]], "lines": ["．．．けど", "四、五年前だった", "かな〜〜．．．"]}, {"box": [671, 432, 788, 629], "vertical": true, "font_size": 23, "lines_coords": [[[760.0, 432.0], [787.0, 432.0], [785.0, 621.0], [759.0, 621.0]], [[729.0, 435.0], [751.0, 435.0], [751.0, 628.0], [729.0, 628.0]], [[701.0, 434.0], [723.0, 434.0], [720.0, 621.0], [698.0, 621.0]], [[671.0, 434.0], [693.0, 434.0], [695.0, 607.0], [673.0, 607.0]]], "lines": ["金の無い人だった", "けど朴訥な人でね。", "僕も随分安く紹介", "してあげたんだ。"]}, {"box": [115, 421, 196, 657], "vertical": true, "font_size": 24, "lines_coords": [[[171.0, 421.0], [193.0, 421.0], [193.0, 656.0], [171.0, 656.0]], [[140.0, 421.0], [167.0, 421.0], [167.0, 653.0], [140.0, 653.0]], [[115.0, 421.0], [137.0, 421.0], [137.0, 643.0], [115.0, 643.0]]], "lines": ["突然ウチに満面の笑みで", "大量のペットボトルの", "水を持ってきてさァ。"]}, {"box": [900, 726, 1006, 912], "vertical": true, "font_size": 22, "lines_coords": [[[982.0, 726.0], [1006.0, 726.0], [1003.0, 867.0], [979.0, 867.0]], [[954.0, 728.0], [976.0, 728.0], [976.0, 889.0], [954.0, 889.0]], [[925.0, 726.0], [948.0, 726.0], [950.0, 912.0], [926.0, 912.0]], [[900.0, 726.0], [920.0, 726.0], [920.0, 854.0], [900.0, 854.0]]], "lines": ["パワーが注入", "されてて健康に", "いいから飲めって", "言われてね。"]}, {"box": [815, 898, 893, 1082], "vertical": true, "font_size": 22, "lines_coords": [[[871.0, 898.0], [893.0, 898.0], [893.0, 1082.0], [871.0, 1082.0]], [[843.0, 900.0], [865.0, 900.0], [865.0, 1060.0], [843.0, 1060.0]], [[815.0, 900.0], [837.0, 900.0], [837.0, 1045.0], [815.0, 1045.0]]], "lines": ["笑顔が足りないと", "不幸になるとも", "言ってたかな。"]}, {"box": [198, 792, 287, 1010], "vertical": true, "font_size": 28, "lines_coords": [[[260.0, 795.0], [287.0, 795.0], [287.0, 1010.0], [260.0, 1010.0]], [[226.0, 792.0], [257.0, 792.0], [254.0, 978.0], [223.0, 978.0]], [[198.0, 793.0], [220.0, 793.0], [220.0, 982.0], [198.0, 982.0]]], "lines": ["それ、宗教なんじゃ", "ないのって僕は", "言ったんだけど、"]}, {"box": [143, 1020, 237, 1179], "vertical": true, "font_size": 28, "lines_coords": [[[206.0, 1020.0], [237.0, 1020.0], [237.0, 1179.0], [206.0, 1179.0]], [[175.0, 1021.0], [201.0, 1021.0], [198.0, 1154.0], [171.0, 1154.0]], [[143.0, 1021.0], [171.0, 1021.0], [171.0, 1131.0], [143.0, 1131.0]]], "lines": ["本人は頑なに", "否定してた", "ねぇ～～"]}, {"box": [914, 1264, 970, 1451], "vertical": true, "font_size": 24, "lines_coords": [[[946.0, 1264.0], [970.0, 1264.0], [968.0, 1420.0], [945.0, 1420.0]], [[914.0, 1265.0], [935.0, 1265.0], [935.0, 1451.0], [914.0, 1451.0]]], "lines": ["まぁ僕の顔は", "生まれつきだし、"]}, {"box": [757, 1340, 879, 1548], "vertical": true, "font_size": 24, "lines_coords": [[[853.0, 1343.0], [879.0, 1343.0], [879.0, 1525.0], [853.0, 1525.0]], [[818.0, 1340.0], [845.0, 1340.0], [846.0, 1525.0], [820.0, 1525.0]], [[790.0, 1345.0], [812.0, 1345.0], [812.0, 1548.0], [790.0, 1548.0]], [[757.0, 1342.0], [784.0, 1342.0], [784.0, 1448.0], [757.0, 1448.0]]], "lines": ["酒が水みたいな", "もんだからって", "突き返しちゃった", "けど．．．"]}, {"box": [107, 1373, 170, 1516], "vertical": true, "font_size": 32, "lines_coords": [[[135.0, 1373.0], [170.0, 1373.0], [170.0, 1465.0], [135.0, 1465.0]], [[107.0, 1375.0], [135.0, 1375.0], [135.0, 1515.0], [107.0, 1515.0]]], "lines": ["．．．．．あ、", "ココ、ココ。"]}], "img_path": "150.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [931, 106, 990, 259], "vertical": true, "font_size": 25, "lines_coords": [[[965.0, 109.0], [989.0, 109.0], [990.0, 259.0], [967.0, 259.0]], [[934.0, 106.0], [960.0, 106.0], [957.0, 248.0], [931.0, 248.0]]], "lines": ["クモ膜下出血", "だったかな。"]}, {"box": [907, 357, 928, 385], "vertical": true, "font_size": 25, "lines_coords": [[[907.0, 357.0], [928.0, 357.0], [928.0, 385.0], [907.0, 385.0]]], "lines": ["ー"]}, {"box": [870, 304, 931, 473], "vertical": true, "font_size": 25, "lines_coords": [[[904.0, 304.0], [931.0, 304.0], [931.0, 356.0], [904.0, 356.0]], [[870.0, 304.0], [896.0, 304.0], [898.0, 473.0], [871.0, 473.0]]], "lines": ["まー", "孤独死だよね。"]}, {"box": [164, 246, 275, 432], "vertical": true, "font_size": 26, "lines_coords": [[[248.0, 248.0], [275.0, 248.0], [275.0, 432.0], [248.0, 432.0]], [[218.0, 246.0], [246.0, 246.0], [246.0, 378.0], [218.0, 378.0]], [[190.0, 246.0], [217.0, 246.0], [217.0, 410.0], [190.0, 410.0]], [[164.0, 246.0], [190.0, 246.0], [190.0, 351.0], [164.0, 351.0]]], "lines": ["ホラ、このところ", "天気良くて", "あったかかった", "でしょ？"]}, {"box": [104, 448, 226, 696], "vertical": true, "font_size": 26, "lines_coords": [[[196.0, 448.0], [223.0, 448.0], [226.0, 696.0], [200.0, 696.0]], [[170.0, 451.0], [192.0, 451.0], [192.0, 682.0], [170.0, 682.0]], [[137.0, 450.0], [159.0, 450.0], [159.0, 631.0], [137.0, 631.0]], [[104.0, 450.0], [131.0, 450.0], [131.0, 614.0], [104.0, 614.0]]], "lines": ["かなり腐乱しちゃって", "部屋中ワインゼリー", "まみれみたいな", "有様らしくて。"]}, {"box": [898, 750, 954, 930], "vertical": true, "font_size": 20, "lines_coords": [[[929.0, 751.0], [951.0, 751.0], [951.0, 879.0], [929.0, 879.0]], [[898.0, 750.0], [920.0, 750.0], [920.0, 885.0], [898.0, 885.0]], [[901.0, 879.0], [918.0, 879.0], [918.0, 926.0], [901.0, 926.0]]], "lines": ["なんか考え", "ちゃうねー", "．．．"]}, {"box": [950, 1090, 1003, 1243], "vertical": true, "font_size": 20, "lines_coords": [[[979.0, 1090.0], [1003.0, 1090.0], [1001.0, 1243.0], [978.0, 1243.0]], [[950.0, 1092.0], [971.0, 1092.0], [971.0, 1164.0], [950.0, 1164.0]]], "lines": ["信仰心なんて", "さァー"]}, {"box": [951, 1170, 968, 1217], "vertical": true, "font_size": 20, "lines_coords": [[[951.0, 1170.0], [968.0, 1170.0], [968.0, 1217.0], [951.0, 1217.0]]], "lines": ["．．．"]}, {"box": [323, 1078, 413, 1259], "vertical": true, "font_size": 23, "lines_coords": [[[384.0, 1082.0], [410.0, 1082.0], [410.0, 1209.0], [384.0, 1209.0]], [[353.0, 1078.0], [379.0, 1078.0], [379.0, 1259.0], [353.0, 1259.0]], [[323.0, 1078.0], [346.0, 1078.0], [348.0, 1157.0], [325.0, 1157.0]], [[326.0, 1157.0], [343.0, 1157.0], [343.0, 1204.0], [326.0, 1204.0]]], "lines": ["一人で笑顔", "振りまかれても", "ねェー", "．．．"]}, {"box": [131, 820, 221, 1001], "vertical": true, "font_size": 23, "lines_coords": [[[196.0, 821.0], [218.0, 821.0], [218.0, 1001.0], [196.0, 1001.0]], [[164.0, 821.0], [185.0, 821.0], [185.0, 1001.0], [164.0, 1001.0]], [[131.0, 820.0], [157.0, 820.0], [157.0, 976.0], [131.0, 976.0]]], "lines": ["何を信じるのも", "勝手だとは思う", "けれどーー．．．"]}, {"box": [637, 1345, 728, 1525], "vertical": true, "font_size": 25, "lines_coords": [[[703.0, 1346.0], [725.0, 1346.0], [725.0, 1500.0], [703.0, 1500.0]], [[668.0, 1345.0], [695.0, 1345.0], [695.0, 1525.0], [668.0, 1525.0]], [[637.0, 1345.0], [664.0, 1345.0], [664.0, 1500.0], [637.0, 1500.0]]], "lines": ["本来は生きる", "目的じゃなくて", "手段でしょ？"]}, {"box": [87, 1296, 178, 1529], "vertical": true, "font_size": 27, "lines_coords": [[[151.0, 1300.0], [178.0, 1300.0], [178.0, 1429.0], [151.0, 1429.0]], [[118.0, 1303.0], [145.0, 1303.0], [145.0, 1529.0], [118.0, 1529.0]], [[87.0, 1296.0], [114.0, 1296.0], [114.0, 1479.0], [87.0, 1479.0]]], "lines": ["．．．やっぱり", "一人ぼっちってのは", "悲し過ぎるよ．．．"]}], "img_path": "151.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [892, 10, 967, 529], "vertical": true, "font_size": 38, "lines_coords": [[[940.0, 184.0], [962.0, 184.0], [962.0, 390.0], [940.0, 390.0]], [[900.0, 70.0], [953.0, 71.0], [945.0, 431.0], [892.0, 429.0]]], "lines": ["そんなことは", "「これは、"]}, {"box": [192, 170, 284, 351], "vertical": true, "font_size": 26, "lines_coords": [[[256.0, 170.0], [282.0, 170.0], [284.0, 339.0], [257.0, 339.0]], [[228.0, 173.0], [250.0, 173.0], [250.0, 351.0], [228.0, 351.0]], [[192.0, 170.0], [225.0, 170.0], [225.0, 275.0], [192.0, 275.0]]], "lines": ["ひと言、普通に", "話しかけてくれ", "れば．．．"]}, {"box": [715, 389, 774, 570], "vertical": true, "font_size": 27, "lines_coords": [[[746.0, 389.0], [773.0, 389.0], [773.0, 545.0], [746.0, 545.0]], [[715.0, 389.0], [742.0, 389.0], [742.0, 570.0], [715.0, 570.0]]], "lines": ["．．．いやホント", "朴訥な男でね．．．"]}, {"box": [878, 639, 971, 931], "vertical": true, "font_size": 40, "lines_coords": [[[928.0, 639.0], [971.0, 639.0], [968.0, 923.0], [925.0, 923.0]], [[878.0, 640.0], [915.0, 640.0], [915.0, 931.0], [878.0, 931.0]]], "lines": ["こ、ご、ごっごめ、", "ごめんなさい！！"]}, {"box": [106, 345, 193, 525], "vertical": true, "font_size": 26, "lines_coords": [[[167.0, 346.0], [193.0, 346.0], [193.0, 523.0], [167.0, 523.0]], [[135.0, 345.0], [162.0, 345.0], [162.0, 525.0], [135.0, 525.0]], [[106.0, 345.0], [128.0, 345.0], [128.0, 473.0], [106.0, 473.0]]], "lines": ["一緒に酒くらい", "飲む仲になれた", "ものを．．．．．"]}, {"box": [115, 903, 211, 1151], "vertical": true, "font_size": 41, "lines_coords": [[[167.0, 903.0], [210.0, 903.0], [210.0, 1132.0], [167.0, 1132.0]], [[115.0, 903.0], [154.0, 903.0], [159.0, 1151.0], [120.0, 1151.0]]], "lines": ["や、やっぱり", "帰りますっ！！"]}, {"box": [904, 1230, 932, 1397], "vertical": true, "font_size": 27, "lines_coords": [[[904.0, 1231.0], [931.0, 1231.0], [931.0, 1395.0], [904.0, 1395.0]]], "lines": ["．．．それがいい。"]}, {"box": [101, 1296, 230, 1531], "vertical": true, "font_size": 26, "lines_coords": [[[201.0, 1300.0], [228.0, 1300.0], [228.0, 1531.0], [201.0, 1531.0]], [[159.0, 1296.0], [185.0, 1296.0], [189.0, 1531.0], [162.0, 1531.0]], [[128.0, 1296.0], [156.0, 1296.0], [159.0, 1529.0], [131.0, 1529.0]], [[101.0, 1300.0], [123.0, 1300.0], [123.0, 1439.0], [101.0, 1439.0]]], "lines": ["僕も大人用オムツを", "穿いてなければ今頃", "水たまりがもう一つ", "てきてるよ。"]}], "img_path": "152.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [300, 484, 321, 637], "vertical": true, "font_size": 29, "lines_coords": [[[300.0, 484.0], [321.0, 484.0], [321.0, 637.0], [300.0, 637.0]]], "lines": ["関くんの．．．"]}, {"box": [245, 704, 282, 842], "vertical": true, "font_size": 29, "lines_coords": [[[245.0, 704.0], [282.0, 704.0], [282.0, 842.0], [245.0, 842.0]]], "lines": ["．．．．．バカ。"]}], "img_path": "153.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "154.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "155.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [717, 73, 743, 229], "vertical": true, "font_size": 28, "lines_coords": [[[717.0, 73.0], [743.0, 73.0], [743.0, 229.0], [717.0, 229.0]]], "lines": ["もぉーーっ！！"]}, {"box": [621, 165, 650, 270], "vertical": true, "font_size": 28, "lines_coords": [[[621.0, 165.0], [650.0, 165.0], [650.0, 270.0], [621.0, 270.0]]], "lines": ["遅いっ！！"]}, {"box": [432, 112, 493, 221], "vertical": true, "font_size": 30, "lines_coords": [[[460.0, 112.0], [493.0, 112.0], [493.0, 204.0], [460.0, 204.0]], [[432.0, 114.0], [459.0, 114.0], [459.0, 221.0], [432.0, 221.0]]], "lines": ["ごめん、", "ごめん！！"]}, {"box": [39, 267, 78, 453], "vertical": true, "font_size": 39, "lines_coords": [[[39.0, 267.0], [78.0, 267.0], [78.0, 453.0], [39.0, 453.0]]], "lines": ["第５４話"]}, {"box": [892, 671, 975, 879], "vertical": true, "font_size": 23, "lines_coords": [[[951.0, 673.0], [975.0, 673.0], [973.0, 870.0], [950.0, 870.0]], [[923.0, 675.0], [945.0, 675.0], [945.0, 837.0], [923.0, 837.0]], [[892.0, 671.0], [918.0, 671.0], [920.0, 879.0], [893.0, 879.0]]], "lines": ["「もうすぐ孫の顔が", "見れると思うと", "夜も眠れない」って。"]}, {"box": [108, 418, 225, 625], "vertical": true, "font_size": 28, "lines_coords": [[[196.0, 423.0], [225.0, 423.0], [225.0, 525.0], [196.0, 525.0]], [[165.0, 421.0], [192.0, 421.0], [192.0, 625.0], [165.0, 625.0]], [[132.0, 418.0], [159.0, 418.0], [160.0, 623.0], [134.0, 623.0]]], "lines": ["いきなり", "入院中の親父から", "電話があってさぁ"]}, {"box": [748, 779, 850, 960], "vertical": true, "font_size": 23, "lines_coords": [[[829.0, 781.0], [850.0, 781.0], [850.0, 960.0], [829.0, 960.0]], [[803.0, 779.0], [825.0, 779.0], [825.0, 937.0], [803.0, 937.0]], [[775.0, 779.0], [796.0, 779.0], [796.0, 917.0], [775.0, 917.0]], [[748.0, 779.0], [770.0, 779.0], [770.0, 948.0], [748.0, 948.0]]], "lines": ["バカ言ってないで", "さっさと自分の", "病気治せって", "言っといたけど。"]}, {"box": [146, 1004, 228, 1168], "vertical": true, "font_size": 23, "lines_coords": [[[198.0, 1004.0], [226.0, 1004.0], [228.0, 1090.0], [200.0, 1090.0]], [[171.0, 1006.0], [195.0, 1006.0], [196.0, 1168.0], [173.0, 1168.0]], [[146.0, 1007.0], [168.0, 1007.0], [168.0, 1137.0], [146.0, 1137.0]]], "lines": ["あはは。", "頑張りますって", "伝えといてー"]}, {"box": [209, 1256, 289, 1456], "vertical": true, "font_size": 23, "lines_coords": [[[267.0, 1257.0], [289.0, 1257.0], [289.0, 1456.0], [267.0, 1456.0]], [[239.0, 1259.0], [260.0, 1259.0], [260.0, 1440.0], [239.0, 1440.0]], [[209.0, 1256.0], [231.0, 1256.0], [231.0, 1378.0], [209.0, 1378.0]]], "lines": ["．．．でも、お義父さん、", "ホント持ち直して", "よかったね"]}, {"box": [114, 1396, 143, 1514], "vertical": true, "font_size": 28, "lines_coords": [[[114.0, 1396.0], [142.0, 1396.0], [143.0, 1514.0], [115.0, 1514.0]]], "lines": ["奇跡だよ。"]}], "img_path": "156.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [873, 167, 900, 298], "vertical": true, "font_size": 22, "lines_coords": [[[873.0, 167.0], [900.0, 167.0], [900.0, 298.0], [873.0, 298.0]]], "lines": ["．．．くだらね"]}, {"box": [845, 232, 862, 293], "vertical": true, "font_size": 22, "lines_coords": [[[845.0, 232.0], [862.0, 232.0], [862.0, 293.0], [845.0, 293.0]]], "lines": ["．．．．．．"]}], "img_path": "157.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [832, 114, 859, 266], "vertical": true, "font_size": 27, "lines_coords": [[[832.0, 114.0], [859.0, 114.0], [859.0, 265.0], [832.0, 265.0]]], "lines": ["シミちゃん．．．"]}, {"box": [218, 146, 311, 275], "vertical": true, "font_size": 27, "lines_coords": [[[282.0, 148.0], [310.0, 148.0], [310.0, 251.0], [282.0, 251.0]], [[253.0, 148.0], [279.0, 148.0], [279.0, 275.0], [253.0, 275.0]], [[221.0, 146.0], [248.0, 146.0], [245.0, 250.0], [218.0, 250.0]]], "lines": ["あなたは", "なんだって", "できる！！"]}, {"box": [857, 443, 918, 598], "vertical": true, "font_size": 26, "lines_coords": [[[889.0, 443.0], [915.0, 443.0], [918.0, 595.0], [892.0, 595.0]], [[860.0, 443.0], [887.0, 443.0], [884.0, 598.0], [857.0, 598.0]]], "lines": ["．．．うんこ神の", "ウソつき．．．"]}, {"box": [270, 654, 296, 757], "vertical": true, "font_size": 26, "lines_coords": [[[270.0, 654.0], [296.0, 654.0], [296.0, 757.0], [270.0, 757.0]]], "lines": ["僕は．．．"]}, {"box": [176, 850, 265, 1004], "vertical": true, "font_size": 26, "lines_coords": [[[237.0, 854.0], [265.0, 854.0], [265.0, 953.0], [237.0, 953.0]], [[204.0, 850.0], [232.0, 850.0], [232.0, 956.0], [204.0, 956.0]], [[176.0, 850.0], [198.0, 850.0], [198.0, 1004.0], [176.0, 1004.0]]], "lines": ["一人じゃ", "なんにも", "てきないよ．．．"]}, {"box": [925, 1192, 960, 1306], "vertical": true, "font_size": 28, "lines_coords": [[[925.0, 1192.0], [957.0, 1192.0], [960.0, 1306.0], [928.0, 1306.0]]], "lines": ["．．．．．ねえ、"]}, {"box": [781, 1271, 875, 1470], "vertical": true, "font_size": 28, "lines_coords": [[[843.0, 1271.0], [875.0, 1271.0], [875.0, 1445.0], [843.0, 1445.0]], [[815.0, 1275.0], [837.0, 1275.0], [837.0, 1470.0], [815.0, 1470.0]], [[784.0, 1273.0], [810.0, 1273.0], [807.0, 1428.0], [781.0, 1428.0]]], "lines": ["関くんは、神様", "なんていないって", "言ってたよ？"]}, {"box": [268, 1187, 296, 1300], "vertical": true, "font_size": 26, "lines_coords": [[[268.0, 1187.0], [296.0, 1187.0], [296.0, 1300.0], [268.0, 1300.0]]], "lines": ["やっぱり、"]}, {"box": [153, 1343, 243, 1476], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 1343.0], [243.0, 1343.0], [243.0, 1476.0], [217.0, 1476.0]], [[184.0, 1345.0], [210.0, 1345.0], [210.0, 1450.0], [184.0, 1450.0]], [[153.0, 1348.0], [179.0, 1348.0], [179.0, 1476.0], [153.0, 1476.0]]], "lines": ["うんこ神も", "ほんとは", "いないの？"]}], "img_path": "158.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [867, 121, 895, 209], "vertical": true, "font_size": 28, "lines_coords": [[[867.0, 121.0], [895.0, 121.0], [895.0, 209.0], [867.0, 209.0]]], "lines": ["いるさ。"]}, {"box": [464, 512, 529, 556], "vertical": false, "font_size": 24.5, "lines_coords": [[[468.0, 512.0], [512.0, 515.0], [510.0, 540.0], [467.0, 537.0]], [[464.0, 532.0], [529.0, 532.0], [529.0, 556.0], [464.0, 556.0]]], "lines": ["宇宙が．．．", "泣いているのね"]}, {"box": [173, 356, 269, 510], "vertical": true, "font_size": 29, "lines_coords": [[[240.0, 357.0], [268.0, 357.0], [268.0, 487.0], [240.0, 487.0]], [[207.0, 356.0], [237.0, 356.0], [237.0, 510.0], [207.0, 510.0]], [[176.0, 356.0], [206.0, 357.0], [203.0, 437.0], [173.0, 435.0]]], "lines": ["誰にだって", "心のどこかに", "必ず！！"]}, {"box": [912, 901, 1005, 1108], "vertical": true, "font_size": 25, "lines_coords": [[[978.0, 903.0], [1004.0, 903.0], [1004.0, 1046.0], [978.0, 1046.0]], [[946.0, 903.0], [968.0, 903.0], [968.0, 1107.0], [946.0, 1107.0]], [[912.0, 901.0], [939.0, 901.0], [940.0, 1084.0], [914.0, 1084.0]]], "lines": ["しかし、目で", "見ることはとても", "難しいのだ．．．"]}, {"box": [520, 909, 609, 1089], "vertical": true, "font_size": 24, "lines_coords": [[[582.0, 909.0], [609.0, 909.0], [606.0, 1079.0], [579.0, 1079.0]], [[553.0, 912.0], [575.0, 912.0], [575.0, 1089.0], [553.0, 1089.0]], [[520.0, 912.0], [542.0, 912.0], [542.0, 1039.0], [520.0, 1039.0]]], "lines": ["今、君の目には", "何が見えている", "だろうか？"]}, {"box": [137, 1056, 164, 1159], "vertical": true, "font_size": 25, "lines_coords": [[[137.0, 1056.0], [164.0, 1056.0], [164.0, 1159.0], [137.0, 1159.0]]], "lines": ["僕には．．．"]}, {"box": [675, 1303, 731, 1482], "vertical": true, "font_size": 24, "lines_coords": [[[703.0, 1303.0], [729.0, 1303.0], [729.0, 1459.0], [703.0, 1459.0]], [[675.0, 1304.0], [696.0, 1304.0], [696.0, 1481.0], [675.0, 1481.0]]], "lines": ["だから君は", "．．．すごくいい！！"]}, {"box": [126, 1259, 246, 1460], "vertical": true, "font_size": 25, "lines_coords": [[[225.0, 1259.0], [246.0, 1259.0], [246.0, 1387.0], [225.0, 1387.0]], [[192.0, 1260.0], [214.0, 1260.0], [214.0, 1460.0], [192.0, 1460.0]], [[157.0, 1259.0], [184.0, 1259.0], [184.0, 1414.0], [157.0, 1414.0]], [[126.0, 1259.0], [154.0, 1259.0], [154.0, 1387.0], [126.0, 1387.0]]], "lines": ["空を駆ける", "無数のペガサスの", "群れが見えて", "いる．．．．．．！！"]}], "img_path": "159.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [920, 73, 979, 239], "vertical": true, "font_size": 26, "lines_coords": [[[953.0, 73.0], [979.0, 73.0], [976.0, 231.0], [950.0, 231.0]], [[920.0, 73.0], [946.0, 73.0], [946.0, 239.0], [920.0, 239.0]]], "lines": ["．．．ずっと君を", "捜していたよ。"]}, {"box": [431, 70, 488, 242], "vertical": true, "font_size": 24, "lines_coords": [[[464.0, 73.0], [485.0, 73.0], [485.0, 221.0], [464.0, 221.0]], [[431.0, 70.0], [457.0, 70.0], [457.0, 242.0], [431.0, 242.0]]], "lines": ["．．．としきって", "書いてあるよ？"]}, {"box": [698, 401, 788, 557], "vertical": true, "font_size": 27, "lines_coords": [[[760.0, 401.0], [787.0, 401.0], [784.0, 557.0], [757.0, 557.0]], [[729.0, 403.0], [756.0, 403.0], [756.0, 556.0], [729.0, 556.0]], [[698.0, 404.0], [725.0, 404.0], [725.0, 543.0], [698.0, 543.0]]], "lines": ["．．．僕のことは", "ペガサスって", "呼んでくれ。"]}, {"box": [879, 660, 987, 825], "vertical": true, "font_size": 25, "lines_coords": [[[960.0, 662.0], [987.0, 662.0], [984.0, 801.0], [957.0, 801.0]], [[932.0, 660.0], [959.0, 660.0], [956.0, 803.0], [929.0, 803.0]], [[904.0, 664.0], [931.0, 664.0], [931.0, 825.0], [904.0, 825.0]], [[879.0, 664.0], [901.0, 664.0], [901.0, 784.0], [879.0, 784.0]]], "lines": ["．．．僕が独自に", "研究している", "〝超ひも理論〟の", "応用により、"]}, {"box": [95, 394, 185, 550], "vertical": true, "font_size": 25, "lines_coords": [[[160.0, 396.0], [182.0, 396.0], [182.0, 548.0], [160.0, 548.0]], [[128.0, 396.0], [154.0, 396.0], [154.0, 550.0], [128.0, 550.0]], [[95.0, 395.0], [121.0, 395.0], [121.0, 550.0], [95.0, 550.0]]], "lines": ["ありがとう！！", "ペガサスって", "呼んでくれ！！"]}, {"box": [743, 840, 879, 1062], "vertical": true, "font_size": 25, "lines_coords": [[[853.0, 840.0], [879.0, 840.0], [876.0, 1004.0], [850.0, 1004.0]], [[825.0, 840.0], [851.0, 840.0], [851.0, 1062.0], [825.0, 1062.0]], [[796.0, 840.0], [818.0, 840.0], [821.0, 1004.0], [800.0, 1004.0]], [[768.0, 840.0], [795.0, 840.0], [795.0, 1028.0], [768.0, 1028.0]], [[743.0, 842.0], [765.0, 842.0], [765.0, 1007.0], [743.0, 1007.0]]], "lines": ["この世の物質の", "すべてがごく小さな", "弦とその振動で", "できているという", "学説を発展させ、"]}, {"box": [129, 688, 395, 1119], "vertical": true, "font_size": 25, "lines_coords": [[[356.0, 689.0], [389.0, 689.0], [389.0, 879.0], [356.0, 879.0]], [[321.0, 689.0], [354.0, 689.0], [354.0, 903.0], [321.0, 903.0]], [[290.0, 692.0], [317.0, 692.0], [317.0, 946.0], [290.0, 946.0]], [[264.0, 689.0], [285.0, 689.0], [284.0, 918.0], [262.0, 918.0]], [[246.0, 914.0], [264.0, 914.0], [264.0, 1031.0], [246.0, 1031.0]], [[215.0, 910.0], [237.0, 910.0], [237.0, 1050.0], [215.0, 1050.0]], [[187.0, 909.0], [209.0, 909.0], [209.0, 1117.0], [187.0, 1117.0]], [[159.0, 912.0], [181.0, 912.0], [181.0, 1075.0], [159.0, 1075.0]], [[129.0, 910.0], [156.0, 910.0], [156.0, 993.0], [129.0, 993.0]]], "lines": ["すべての物質には", "すべてに音階があり", "森羅万象には旋律がある", "ことがわかったんだ", "．．．っまり、", "宇宙の歴史は", "壮大な一つの組曲に", "置き換えられる", "のだよ。"]}, {"box": [915, 1201, 972, 1381], "vertical": true, "font_size": 24, "lines_coords": [[[945.0, 1201.0], [971.0, 1201.0], [971.0, 1306.0], [945.0, 1306.0]], [[917.0, 1203.0], [939.0, 1203.0], [939.0, 1379.0], [917.0, 1379.0]]], "lines": ["．．．君にも", "聴こえるかい？"]}, {"box": [167, 1315, 230, 1498], "vertical": true, "font_size": 24, "lines_coords": [[[204.0, 1318.0], [226.0, 1318.0], [226.0, 1496.0], [204.0, 1496.0]], [[170.0, 1315.0], [196.0, 1315.0], [193.0, 1498.0], [167.0, 1498.0]]], "lines": ["世界を包み込む", "不協和音が．．．"]}], "img_path": "160.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [956, 60, 995, 107], "vertical": true, "font_size": 28, "lines_coords": [[[956.0, 60.0], [995.0, 60.0], [995.0, 107.0], [956.0, 107.0]]], "lines": ["あー"]}, {"box": [925, 65, 951, 279], "vertical": true, "font_size": 28, "lines_coords": [[[925.0, 65.0], [951.0, 65.0], [951.0, 279.0], [925.0, 279.0]]], "lines": ["あっぁっあっ！！"]}, {"box": [848, 157, 992, 342], "vertical": true, "font_size": 28, "lines_coords": [[[967.0, 207.0], [992.0, 207.0], [992.0, 245.0], [967.0, 245.0]], [[848.0, 157.0], [875.0, 157.0], [875.0, 342.0], [848.0, 342.0]]], "lines": ["っ", "ちょっとまっ！！"]}, {"box": [818, 160, 840, 339], "vertical": true, "font_size": 28, "lines_coords": [[[818.0, 160.0], [840.0, 160.0], [840.0, 339.0], [818.0, 339.0]]], "lines": ["ちょっとまっ！！"]}, {"box": [143, 348, 266, 604], "vertical": true, "font_size": 26, "lines_coords": [[[237.0, 350.0], [264.0, 350.0], [264.0, 603.0], [237.0, 603.0]], [[204.0, 350.0], [231.0, 350.0], [231.0, 531.0], [204.0, 531.0]], [[173.0, 348.0], [200.0, 348.0], [200.0, 604.0], [173.0, 604.0]], [[143.0, 351.0], [165.0, 351.0], [165.0, 528.0], [143.0, 528.0]]], "lines": ["決して怪しいモンじゃ", "御座いません！！", "決して怪しいモンじゃ", "御座いません！！"]}, {"box": [806, 726, 895, 931], "vertical": true, "font_size": 26, "lines_coords": [[[867.0, 726.0], [895.0, 726.0], [895.0, 831.0], [867.0, 831.0]], [[835.0, 726.0], [862.0, 726.0], [862.0, 907.0], [835.0, 907.0]], [[807.0, 728.0], [829.0, 728.0], [829.0, 931.0], [807.0, 931.0]]], "lines": ["君にしか", "できないことを", "僕は知ってるよ！！"]}, {"box": [945, 1052, 972, 1206], "vertical": true, "font_size": 26, "lines_coords": [[[945.0, 1054.0], [971.0, 1054.0], [971.0, 1206.0], [945.0, 1206.0]]], "lines": ["．．．いいかな？"]}, {"box": [509, 1040, 630, 1245], "vertical": true, "font_size": 24, "lines_coords": [[[603.0, 1040.0], [629.0, 1040.0], [629.0, 1200.0], [603.0, 1200.0]], [[571.0, 1040.0], [593.0, 1040.0], [593.0, 1243.0], [571.0, 1243.0]], [[539.0, 1040.0], [565.0, 1040.0], [565.0, 1245.0], [539.0, 1245.0]], [[510.0, 1042.0], [532.0, 1042.0], [532.0, 1217.0], [510.0, 1217.0]]], "lines": ["．．．僕はある日、", "夢の中で不思議な", "旋律を聴くように", "なったんだ．．．"]}, {"box": [685, 1339, 775, 1495], "vertical": true, "font_size": 27, "lines_coords": [[[742.0, 1339.0], [775.0, 1339.0], [775.0, 1423.0], [742.0, 1423.0]], [[714.0, 1342.0], [740.0, 1342.0], [740.0, 1495.0], [714.0, 1495.0]], [[685.0, 1342.0], [706.0, 1342.0], [706.0, 1493.0], [685.0, 1493.0]]], "lines": ["僕達は", "選ばれた人間", "なんだよ．．．"]}, {"box": [112, 1293, 265, 1514], "vertical": true, "font_size": 26, "lines_coords": [[[237.0, 1296.0], [264.0, 1296.0], [264.0, 1450.0], [237.0, 1450.0]], [[206.0, 1296.0], [232.0, 1296.0], [232.0, 1478.0], [206.0, 1478.0]], [[171.0, 1293.0], [198.0, 1293.0], [200.0, 1514.0], [173.0, 1514.0]], [[142.0, 1295.0], [168.0, 1295.0], [168.0, 1501.0], [142.0, 1501.0]], [[112.0, 1296.0], [134.0, 1296.0], [134.0, 1475.0], [112.0, 1475.0]]], "lines": ["それを譜面に", "起こし解析する", "ことによって、僕は", "未来に触れられる", "ようになった．．"]}], "img_path": "161.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [810, 101, 920, 321], "vertical": true, "font_size": 28, "lines_coords": [[[892.0, 106.0], [918.0, 106.0], [918.0, 290.0], [892.0, 290.0]], [[853.0, 107.0], [881.0, 107.0], [881.0, 226.0], [853.0, 226.0]], [[810.0, 101.0], [842.0, 101.0], [845.0, 320.0], [814.0, 320.0]]], "lines": ["このままだと", "五年後の", "７月７日に．．．"]}, {"box": [173, 235, 255, 418], "vertical": true, "font_size": 36, "lines_coords": [[[215.0, 235.0], [253.0, 235.0], [253.0, 418.0], [215.0, 418.0]], [[173.0, 235.0], [206.0, 235.0], [206.0, 417.0], [173.0, 417.0]]], "lines": ["地球は消滅", "する．．．．．！！"]}, {"box": [865, 845, 955, 1026], "vertical": true, "font_size": 25, "lines_coords": [[[928.0, 848.0], [954.0, 848.0], [954.0, 1026.0], [928.0, 1026.0]], [[893.0, 845.0], [921.0, 845.0], [923.0, 1003.0], [895.0, 1003.0]], [[865.0, 848.0], [887.0, 848.0], [887.0, 950.0], [865.0, 950.0]]], "lines": ["少しずつ同志が", "集まり始めて", "いる．．．"]}, {"box": [201, 903, 259, 1057], "vertical": true, "font_size": 25, "lines_coords": [[[229.0, 903.0], [257.0, 903.0], [257.0, 1006.0], [229.0, 1006.0]], [[201.0, 904.0], [223.0, 904.0], [223.0, 1057.0], [201.0, 1057.0]]], "lines": ["君の力が", "必要なんだ．．．"]}, {"box": [890, 1225, 950, 1409], "vertical": true, "font_size": 24, "lines_coords": [[[923.0, 1225.0], [950.0, 1225.0], [946.0, 1407.0], [920.0, 1407.0]], [[890.0, 1225.0], [917.0, 1225.0], [917.0, 1409.0], [890.0, 1409.0]]], "lines": ["僕と一緒に来て", "くれないか．．．"]}, {"box": [746, 1296, 832, 1526], "vertical": true, "font_size": 24, "lines_coords": [[[810.0, 1296.0], [832.0, 1296.0], [832.0, 1475.0], [810.0, 1475.0]], [[778.0, 1296.0], [800.0, 1296.0], [800.0, 1526.0], [778.0, 1526.0]], [[746.0, 1296.0], [768.0, 1296.0], [768.0, 1526.0], [746.0, 1526.0]]], "lines": ["僕と君の振動は", "完全五度の関係性で", "強く結ばれている！？"]}, {"box": [151, 1331, 243, 1487], "vertical": true, "font_size": 27, "lines_coords": [[[215.0, 1334.0], [242.0, 1334.0], [242.0, 1464.0], [215.0, 1464.0]], [[181.0, 1331.0], [209.0, 1331.0], [210.0, 1487.0], [182.0, 1487.0]], [[151.0, 1334.0], [178.0, 1334.0], [178.0, 1462.0], [151.0, 1462.0]]], "lines": ["愛と平和と", "人間の追求の", "ために．．．"]}], "img_path": "162.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [859, 90, 896, 275], "vertical": true, "font_size": 37, "lines_coords": [[[859.0, 90.0], [896.0, 90.0], [896.0, 271.0], [859.0, 271.0]]], "lines": ["グッド．．．"]}, {"box": [160, 528, 250, 748], "vertical": true, "font_size": 42, "lines_coords": [[[206.0, 528.0], [250.0, 528.0], [250.0, 698.0], [206.0, 698.0]], [[167.0, 528.0], [206.0, 529.0], [200.0, 745.0], [160.0, 743.0]]], "lines": ["バイブレー", "ション．．．．．！！"]}], "img_path": "163.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [752, 119, 776, 202], "vertical": true, "font_size": 22, "lines_coords": [[[753.0, 135.0], [775.0, 135.0], [775.0, 195.0], [753.0, 195.0]]], "lines": ["別に"]}, {"box": [475, 117, 631, 306], "vertical": true, "font_size": 26, "lines_coords": [[[604.0, 117.0], [631.0, 117.0], [631.0, 220.0], [604.0, 220.0]], [[571.0, 118.0], [598.0, 118.0], [598.0, 296.0], [571.0, 296.0]], [[539.0, 117.0], [565.0, 117.0], [565.0, 301.0], [539.0, 301.0]], [[506.0, 118.0], [532.0, 118.0], [532.0, 246.0], [506.0, 246.0]], [[475.0, 117.0], [501.0, 117.0], [501.0, 284.0], [475.0, 284.0]]], "lines": ["このまま", "金だけ持ち逃げ", "することなんて、", "いくらでも", "てきたはすた。"]}, {"box": [259, 115, 356, 271], "vertical": true, "font_size": 30, "lines_coords": [[[328.0, 117.0], [356.0, 117.0], [356.0, 220.0], [328.0, 220.0]], [[293.0, 117.0], [321.0, 117.0], [323.0, 271.0], [295.0, 271.0]], [[259.0, 115.0], [292.0, 115.0], [292.0, 198.0], [259.0, 198.0]]], "lines": ["．．．じゃあ", "なんて戻って", "きた？"]}, {"box": [784, 432, 908, 614], "vertical": true, "font_size": 26, "lines_coords": [[[884.0, 435.0], [906.0, 435.0], [906.0, 562.0], [884.0, 562.0]], [[846.0, 432.0], [873.0, 432.0], [876.0, 590.0], [850.0, 590.0]], [[817.0, 434.0], [843.0, 434.0], [843.0, 614.0], [817.0, 614.0]], [[784.0, 434.0], [812.0, 434.0], [812.0, 539.0], [784.0, 539.0]]], "lines": ["どうせ近々", "自殺するって", "言ってるような", "女だろ？"]}, {"box": [181, 769, 306, 975], "vertical": true, "font_size": 26, "lines_coords": [[[278.0, 770.0], [304.0, 770.0], [304.0, 948.0], [278.0, 948.0]], [[245.0, 770.0], [271.0, 770.0], [271.0, 900.0], [245.0, 900.0]], [[212.0, 770.0], [239.0, 770.0], [239.0, 975.0], [212.0, 975.0]], [[181.0, 770.0], [207.0, 770.0], [207.0, 956.0], [181.0, 956.0]]], "lines": ["適当に嘘ついて", "有り金全部", "搾り取っちまえば", "いいじゃないか。"]}], "img_path": "164.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [903, 117, 960, 259], "vertical": true, "font_size": 24, "lines_coords": [[[939.0, 120.0], [960.0, 120.0], [960.0, 196.0], [939.0, 196.0]], [[903.0, 117.0], [929.0, 117.0], [929.0, 259.0], [903.0, 259.0]]], "lines": ["．．．．．．？", "すみません。"]}, {"box": [132, 373, 225, 554], "vertical": true, "font_size": 27, "lines_coords": [[[196.0, 373.0], [223.0, 373.0], [223.0, 503.0], [196.0, 503.0]], [[165.0, 373.0], [192.0, 373.0], [192.0, 554.0], [165.0, 554.0]], [[132.0, 373.0], [160.0, 373.0], [160.0, 464.0], [132.0, 464.0]]], "lines": ["なんか結局", "何もできません", "でした。"]}, {"box": [951, 1020, 975, 1129], "vertical": true, "font_size": 22, "lines_coords": [[[953.0, 1068.0], [975.0, 1068.0], [975.0, 1126.0], [953.0, 1126.0]]], "lines": ["よ．．．"]}, {"box": [682, 1371, 709, 1500], "vertical": true, "font_size": 24, "lines_coords": [[[682.0, 1371.0], [709.0, 1371.0], [709.0, 1500.0], [682.0, 1500.0]]], "lines": ["よかったァ"]}, {"box": [654, 1420, 675, 1450], "vertical": true, "font_size": 24, "lines_coords": [[[654.0, 1420.0], [675.0, 1420.0], [675.0, 1450.0], [654.0, 1450.0]]], "lines": ["．．．"]}, {"box": [82, 1343, 204, 1553], "vertical": true, "font_size": 26, "lines_coords": [[[171.0, 1343.0], [204.0, 1343.0], [204.0, 1428.0], [171.0, 1428.0]], [[143.0, 1345.0], [170.0, 1345.0], [170.0, 1553.0], [143.0, 1553.0]], [[114.0, 1345.0], [135.0, 1345.0], [135.0, 1525.0], [114.0, 1525.0]], [[82.0, 1346.0], [104.0, 1346.0], [104.0, 1473.0], [82.0, 1473.0]]], "lines": ["本当に", "死んじゃってたら", "どうしようかと", "思った．．．"]}], "img_path": "165.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [937, 92, 964, 221], "vertical": true, "font_size": 26, "lines_coords": [[[937.0, 92.0], [964.0, 92.0], [964.0, 221.0], [937.0, 221.0]]], "lines": ["．．．．．．はァ！？"]}, {"box": [815, 220, 906, 428], "vertical": true, "font_size": 26, "lines_coords": [[[879.0, 220.0], [906.0, 220.0], [906.0, 360.0], [879.0, 360.0]], [[846.0, 221.0], [873.0, 221.0], [873.0, 428.0], [846.0, 428.0]], [[815.0, 221.0], [837.0, 221.0], [837.0, 426.0], [815.0, 426.0]]], "lines": ["な．．．アンタ、", "バカじゃねーの？", "何泣いてんだよ！！"]}, {"box": [260, 129, 320, 260], "vertical": true, "font_size": 26, "lines_coords": [[[292.0, 129.0], [320.0, 129.0], [320.0, 235.0], [292.0, 235.0]], [[260.0, 129.0], [287.0, 129.0], [287.0, 260.0], [260.0, 260.0]]], "lines": ["．．．ごめん", "なさい．．．"]}, {"box": [156, 282, 212, 489], "vertical": true, "font_size": 26, "lines_coords": [[[185.0, 282.0], [212.0, 282.0], [212.0, 440.0], [185.0, 440.0]], [[156.0, 285.0], [178.0, 285.0], [178.0, 489.0], [156.0, 489.0]]], "lines": ["今日はホント", "気が動転してて．．．"]}, {"box": [140, 665, 262, 876], "vertical": true, "font_size": 26, "lines_coords": [[[235.0, 665.0], [262.0, 665.0], [260.0, 876.0], [234.0, 876.0]], [[203.0, 668.0], [231.0, 668.0], [226.0, 825.0], [198.0, 825.0]], [[171.0, 668.0], [198.0, 668.0], [198.0, 851.0], [171.0, 851.0]], [[140.0, 670.0], [162.0, 670.0], [162.0, 798.0], [140.0, 798.0]]], "lines": ["まさかあんなこと", "口走るなんて", "自分でも思って", "なくて．．．"]}, {"box": [882, 982, 968, 1192], "vertical": true, "font_size": 25, "lines_coords": [[[945.0, 985.0], [967.0, 985.0], [967.0, 1190.0], [945.0, 1190.0]], [[914.0, 984.0], [940.0, 984.0], [940.0, 1179.0], [914.0, 1179.0]], [[882.0, 982.0], [909.0, 982.0], [910.0, 1192.0], [884.0, 1192.0]]], "lines": ["あなたが店を出て", "行ってから、急に", "我にかえって．．．"]}, {"box": [451, 1070, 576, 1225], "vertical": true, "font_size": 27, "lines_coords": [[[548.0, 1071.0], [575.0, 1071.0], [575.0, 1189.0], [548.0, 1189.0]], [[515.0, 1070.0], [542.0, 1070.0], [542.0, 1201.0], [515.0, 1201.0]], [[482.0, 1071.0], [509.0, 1071.0], [509.0, 1225.0], [482.0, 1225.0]], [[451.0, 1070.0], [479.0, 1070.0], [479.0, 1200.0], [451.0, 1200.0]]], "lines": ["けど、電話", "しても全然", "携帯出てくれ", "ないし．．．"]}, {"box": [204, 1007, 226, 1121], "vertical": true, "font_size": 22, "lines_coords": [[[204.0, 1007.0], [226.0, 1007.0], [226.0, 1121.0], [204.0, 1121.0]]], "lines": ["ホントは．．"]}, {"box": [917, 1325, 945, 1418], "vertical": true, "font_size": 28, "lines_coords": [[[917.0, 1354.0], [945.0, 1354.0], [945.0, 1418.0], [917.0, 1418.0]]], "lines": ["は。は。"]}, {"box": [640, 1281, 762, 1414], "vertical": true, "font_size": 31.0, "lines_coords": [[[695.0, 1289.0], [723.0, 1285.0], [739.0, 1396.0], [710.0, 1401.0]], [[712.0, 1293.0], [740.0, 1287.0], [762.0, 1409.0], [734.0, 1414.0]], [[640.0, 1285.0], [675.0, 1281.0], [692.0, 1407.0], [657.0, 1412.0]]], "lines": ["通．．．通常の", "蜘Ｓ知染痴", "いいですか"]}, {"box": [473, 1340, 564, 1528], "vertical": true, "font_size": 23, "lines_coords": [[[539.0, 1342.0], [560.0, 1342.0], [560.0, 1526.0], [539.0, 1526.0]], [[503.0, 1342.0], [529.0, 1342.0], [529.0, 1520.0], [503.0, 1520.0]], [[473.0, 1340.0], [495.0, 1340.0], [495.0, 1443.0], [473.0, 1443.0]]], "lines": ["．．．俺も実は相当", "動転してたって", "ことか？"]}, {"box": [85, 1148, 192, 1331], "vertical": true, "font_size": 22, "lines_coords": [[[170.0, 1150.0], [192.0, 1150.0], [192.0, 1265.0], [170.0, 1265.0]], [[142.0, 1151.0], [164.0, 1151.0], [164.0, 1310.0], [142.0, 1310.0]], [[114.0, 1150.0], [134.0, 1150.0], [134.0, 1331.0], [114.0, 1331.0]], [[85.0, 1148.0], [107.0, 1148.0], [107.0, 1287.0], [85.0, 1287.0]]], "lines": ["私の苦労を", "あの人にも少し", "知ってほしかった", "だけなの．．．"]}], "img_path": "166.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [889, 120, 918, 257], "vertical": true, "font_size": 24, "lines_coords": [[[889.0, 120.0], [915.0, 120.0], [918.0, 257.0], [892.0, 257.0]]], "lines": ["．．．お姉さん、"]}, {"box": [762, 253, 851, 482], "vertical": true, "font_size": 24, "lines_coords": [[[825.0, 253.0], [851.0, 253.0], [851.0, 432.0], [825.0, 432.0]], [[795.0, 253.0], [817.0, 253.0], [817.0, 482.0], [795.0, 482.0]], [[762.0, 253.0], [784.0, 253.0], [784.0, 467.0], [762.0, 467.0]]], "lines": ["今回ばっかりは", "今日の天気を決めた", "神様に感謝しなよ。"]}, {"box": [167, 271, 290, 477], "vertical": true, "font_size": 27, "lines_coords": [[[262.0, 275.0], [289.0, 275.0], [289.0, 453.0], [262.0, 453.0]], [[229.0, 271.0], [257.0, 271.0], [254.0, 429.0], [226.0, 429.0]], [[196.0, 273.0], [223.0, 273.0], [223.0, 450.0], [196.0, 450.0]], [[167.0, 271.0], [193.0, 271.0], [193.0, 476.0], [167.0, 476.0]]], "lines": ["人の運命なんて", "天気ひとつで", "コロッと変わっ", "ちゃうみたいよ？"]}, {"box": [926, 875, 983, 1056], "vertical": true, "font_size": 26, "lines_coords": [[[956.0, 875.0], [982.0, 875.0], [982.0, 1056.0], [956.0, 1056.0]], [[926.0, 875.0], [953.0, 875.0], [953.0, 1031.0], [926.0, 1031.0]]], "lines": ["．．．封筒のお金は", "あげます．．．"]}, {"box": [587, 882, 615, 999], "vertical": true, "font_size": 28, "lines_coords": [[[587.0, 882.0], [615.0, 882.0], [615.0, 998.0], [587.0, 998.0]]], "lines": ["．．．いらね。"]}, {"box": [137, 904, 229, 1083], "vertical": true, "font_size": 26, "lines_coords": [[[201.0, 904.0], [228.0, 904.0], [228.0, 1034.0], [201.0, 1034.0]], [[171.0, 907.0], [193.0, 907.0], [193.0, 1082.0], [171.0, 1082.0]], [[137.0, 906.0], [165.0, 906.0], [165.0, 984.0], [137.0, 984.0]]], "lines": ["．．．十分勉強", "させてもらった", "し．．．．．"]}, {"box": [685, 1287, 776, 1481], "vertical": true, "font_size": 27, "lines_coords": [[[748.0, 1289.0], [775.0, 1289.0], [775.0, 1443.0], [748.0, 1443.0]], [[717.0, 1289.0], [743.0, 1289.0], [743.0, 1481.0], [717.0, 1481.0]], [[685.0, 1287.0], [712.0, 1287.0], [712.0, 1420.0], [685.0, 1420.0]]], "lines": ["だから今日の", "こと、全部忘れて", "くれない？"]}, {"box": [337, 1360, 457, 1540], "vertical": true, "font_size": 25, "lines_coords": [[[431.0, 1360.0], [457.0, 1360.0], [457.0, 1489.0], [431.0, 1489.0]], [[400.0, 1360.0], [426.0, 1360.0], [426.0, 1540.0], [400.0, 1540.0]], [[367.0, 1360.0], [393.0, 1360.0], [393.0, 1514.0], [367.0, 1514.0]], [[337.0, 1360.0], [359.0, 1360.0], [359.0, 1498.0], [337.0, 1498.0]]], "lines": ["．．．人なんて", "みんな強がって", "ばかりの弱い", "生き物だわ。"]}, {"box": [112, 1426, 140, 1520], "vertical": true, "font_size": 28, "lines_coords": [[[112.0, 1426.0], [140.0, 1426.0], [140.0, 1520.0], [112.0, 1520.0]]], "lines": ["．．．．．．ね。"]}], "img_path": "167.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [934, 32, 992, 187], "vertical": true, "font_size": 24, "lines_coords": [[[962.0, 32.0], [989.0, 32.0], [992.0, 178.0], [965.0, 178.0]], [[935.0, 37.0], [957.0, 37.0], [957.0, 187.0], [935.0, 187.0]]], "lines": ["．．．あなた、年", "いくつなの？"]}, {"box": [367, 78, 432, 170], "vertical": true, "font_size": 34, "lines_coords": [[[398.0, 78.0], [432.0, 79.0], [429.0, 162.0], [395.0, 160.0]], [[367.0, 79.0], [400.0, 79.0], [400.0, 170.0], [367.0, 170.0]]], "lines": ["．．．童顔", "なのね。"]}, {"box": [890, 679, 918, 779], "vertical": true, "font_size": 29, "lines_coords": [[[890.0, 679.0], [918.0, 679.0], [918.0, 779.0], [890.0, 779.0]]], "lines": ["ふふ．．．"]}, {"box": [492, 407, 523, 523], "vertical": true, "font_size": 28, "lines_coords": [[[495.0, 407.0], [523.0, 407.0], [520.0, 523.0], [492.0, 523.0]]], "lines": ["３５歳です。"]}, {"box": [126, 428, 189, 560], "vertical": true, "font_size": 30, "lines_coords": [[[162.0, 429.0], [189.0, 429.0], [189.0, 560.0], [162.0, 560.0]], [[126.0, 428.0], [160.0, 428.0], [160.0, 498.0], [126.0, 498.0]]], "lines": ["よく言われ", "ます。"]}, {"box": [806, 818, 865, 926], "vertical": true, "font_size": 29, "lines_coords": [[[839.0, 818.0], [865.0, 818.0], [865.0, 926.0], [839.0, 926.0]], [[806.0, 821.0], [839.0, 821.0], [839.0, 906.0], [806.0, 906.0]]], "lines": ["そうなん", "だ．．．"]}, {"box": [156, 934, 215, 1065], "vertical": true, "font_size": 27, "lines_coords": [[[187.0, 934.0], [215.0, 934.0], [215.0, 1015.0], [187.0, 1015.0]], [[156.0, 935.0], [182.0, 935.0], [182.0, 1065.0], [156.0, 1065.0]]], "lines": ["私より", "年上かぁ．．．"]}, {"box": [292, 1203, 353, 1420], "vertical": true, "font_size": 27, "lines_coords": [[[326.0, 1203.0], [353.0, 1203.0], [351.0, 1420.0], [325.0, 1420.0]], [[292.0, 1204.0], [323.0, 1204.0], [323.0, 1387.0], [292.0, 1387.0]]], "lines": ["．．．お金、気持ちだけ", "置いてくんで．．．"]}, {"box": [139, 1300, 229, 1509], "vertical": true, "font_size": 27, "lines_coords": [[[203.0, 1300.0], [229.0, 1300.0], [229.0, 1432.0], [203.0, 1432.0]], [[170.0, 1300.0], [196.0, 1300.0], [196.0, 1509.0], [170.0, 1509.0]], [[139.0, 1301.0], [165.0, 1301.0], [165.0, 1495.0], [139.0, 1495.0]]], "lines": ["良かったら", "これでゴハンでも", "食べてください。"]}], "img_path": "168.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [879, 106, 912, 322], "vertical": true, "font_size": 31, "lines_coords": [[[879.0, 106.0], [910.0, 106.0], [910.0, 321.0], [879.0, 321.0]]], "lines": ["．．．お姉さんっ！！"]}, {"box": [162, 348, 232, 618], "vertical": true, "font_size": 29, "lines_coords": [[[200.0, 348.0], [232.0, 348.0], [229.0, 567.0], [196.0, 567.0]], [[164.0, 350.0], [190.0, 350.0], [190.0, 618.0], [164.0, 618.0]]], "lines": ["笑ってるほうが", "全然かわいいよっ！！"]}, {"box": [268, 668, 328, 825], "vertical": true, "font_size": 27, "lines_coords": [[[301.0, 670.0], [328.0, 670.0], [328.0, 773.0], [301.0, 773.0]], [[268.0, 668.0], [295.0, 668.0], [295.0, 825.0], [268.0, 825.0]]], "lines": ["．．．なんか", "こういうの．．"]}, {"box": [884, 998, 1004, 1204], "vertical": true, "font_size": 24, "lines_coords": [[[978.0, 998.0], [1000.0, 998.0], [1000.0, 1201.0], [978.0, 1201.0]], [[945.0, 998.0], [971.0, 998.0], [970.0, 1204.0], [943.0, 1204.0]], [[914.0, 998.0], [940.0, 998.0], [940.0, 1181.0], [914.0, 1181.0]], [[884.0, 1000.0], [906.0, 1000.0], [906.0, 1153.0], [884.0, 1153.0]]], "lines": ["きっとお姉さんは", "家庭よりも仕事を", "優先させたい人", "なんでしょ？"]}, {"box": [515, 979, 639, 1187], "vertical": true, "font_size": 26, "lines_coords": [[[614.0, 982.0], [635.0, 982.0], [635.0, 1159.0], [614.0, 1159.0]], [[579.0, 981.0], [606.0, 981.0], [606.0, 1143.0], [579.0, 1143.0]], [[546.0, 981.0], [573.0, 981.0], [573.0, 1187.0], [546.0, 1187.0]], [[515.0, 979.0], [542.0, 979.0], [542.0, 1085.0], [515.0, 1085.0]]], "lines": ["人の生き方って", "色々なんだし、", "幸せも人それぞれ", "だから．．．"]}, {"box": [146, 739, 239, 893], "vertical": true, "font_size": 27, "lines_coords": [[[210.0, 739.0], [239.0, 739.0], [235.0, 868.0], [207.0, 868.0]], [[176.0, 740.0], [203.0, 740.0], [203.0, 893.0], [176.0, 893.0]], [[146.0, 739.0], [173.0, 739.0], [173.0, 843.0], [146.0, 843.0]]], "lines": ["おせっかい", "かもしれない", "けど．．．"]}, {"box": [667, 1326, 757, 1532], "vertical": true, "font_size": 23, "lines_coords": [[[729.0, 1326.0], [756.0, 1326.0], [756.0, 1506.0], [729.0, 1506.0]], [[700.0, 1329.0], [721.0, 1329.0], [721.0, 1532.0], [700.0, 1532.0]], [[670.0, 1331.0], [692.0, 1331.0], [689.0, 1506.0], [667.0, 1506.0]]], "lines": ["俺もそういうの", "なんとなくわかる", "っていうか．．．"]}, {"box": [113, 1146, 234, 1328], "vertical": true, "font_size": 24, "lines_coords": [[[206.0, 1146.0], [232.0, 1146.0], [231.0, 1328.0], [204.0, 1328.0]], [[176.0, 1150.0], [198.0, 1150.0], [198.0, 1303.0], [176.0, 1303.0]], [[142.0, 1148.0], [168.0, 1148.0], [168.0, 1303.0], 