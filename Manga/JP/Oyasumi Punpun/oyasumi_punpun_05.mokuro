4.0], [198.0, 1010.0], [176.0, 1010.0]]], "lines": ["．．．バーカ。", "そんな勇気なんて", "無いくせに．．．"]}, {"box": [939, 1175, 965, 1400], "vertical": true, "font_size": 30, "lines_coords": [[[939.0, 1175.0], [965.0, 1175.0], [965.0, 1400.0], [939.0, 1400.0]]], "lines": ["．．．そらみだことか。"]}, {"box": [809, 1178, 904, 1414], "vertical": true, "font_size": 30, "lines_coords": [[[873.0, 1178.0], [904.0, 1178.0], [904.0, 1340.0], [873.0, 1340.0]], [[840.0, 1178.0], [871.0, 1178.0], [871.0, 1414.0], [840.0, 1414.0]], [[809.0, 1181.0], [842.0, 1181.0], [842.0, 1295.0], [809.0, 1295.0]]], "lines": ["自由だなんだ", "でかいこと考えてる", "つもりで、"]}, {"box": [234, 1179, 298, 1410], "vertical": true, "font_size": 27, "lines_coords": [[[271.0, 1181.0], [298.0, 1181.0], [298.0, 1410.0], [271.0, 1410.0]], [[234.0, 1179.0], [267.0, 1179.0], [270.0, 1367.0], [237.0, 1367.0]]], "lines": ["こんな些細なことで", "〈コむんだ。"]}, {"box": [146, 1178, 203, 1385], "vertical": true, "font_size": 27, "lines_coords": [[[176.0, 1178.0], [203.0, 1178.0], [203.0, 1385.0], [176.0, 1385.0]], [[146.0, 1179.0], [168.0, 1179.0], [168.0, 1328.0], [146.0, 1328.0]]], "lines": ["．．．俺ってそういう", "奴なんだよ。"]}], "img_path": "171.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [827, 61, 910, 251], "vertical": true, "font_size": 32, "lines_coords": [[[875.0, 64.0], [909.0, 64.0], [909.0, 151.0], [875.0, 151.0]], [[845.0, 65.0], [876.0, 65.0], [876.0, 251.0], [845.0, 251.0]]], "lines": ["．．．清水", "戻ってこねーな"]}, {"box": [182, 64, 277, 251], "vertical": true, "font_size": 30, "lines_coords": [[[246.0, 65.0], [275.0, 65.0], [271.0, 248.0], [243.0, 248.0]], [[210.0, 67.0], [245.0, 67.0], [245.0, 176.0], [210.0, 176.0]], [[182.0, 67.0], [209.0, 67.0], [209.0, 251.0], [182.0, 251.0]]], "lines": ["俺が勝手ばかり", "するから", "怒ったかな．．．"]}, {"box": [923, 607, 951, 721], "vertical": true, "font_size": 30, "lines_coords": [[[923.0, 607.0], [951.0, 607.0], [951.0, 721.0], [923.0, 721.0]]], "lines": ["．．．なんか、"]}, {"box": [857, 606, 889, 818], "vert