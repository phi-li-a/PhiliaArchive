0], [442.0, 1348.0], [415.0, 1348.0]]], "lines": ["・さいとうひさし", "鳥渕佑紀", "佐藤五月", "くまつと", "岩間康正"]}, {"box": [326, 1237, 398, 1351], "vertical": true, "font_size": 28.0, "lines_coords": [[[370.0, 1237.0], [398.0, 1237.0], [398.0, 1351.0], [370.0, 1351.0]], [[326.0, 1239.0], [354.0, 1239.0], [354.0, 1346.0], [326.0, 1346.0]]], "lines": ["上原ゆう", "久米貴史"]}], "img_path": "218.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [759, 125, 950, 420], "vertical": false, "font_size": 295, "lines_coords": [[[759.0, 125.0], [950.0, 125.0], [950.0, 420.0], [759.0, 420.0]]], "lines": ["バッ"]}, {"box": [514, 120, 556, 423], "vertical": true, "font_size": 40, "lines_coords": [[[514.0, 120.0], [556.0, 120.0], [556.0, 423.0], [514.0, 423.0]]], "lines": ["二人に芽生える"]}, {"box": [459, 204, 503, 532], "vertical": true, "font_size": 40, "lines_coords": [[[459.0, 204.0], [498.0, 204.0], [503.0, 532.0], [464.0, 532.0]]], "lines": ["新たな恋の予感。"]}, {"box": [132, 523, 179, 1428], "vertical": true, "font_size": 44, "lines_coords": [[[135.0, 523.0], [179.0, 523.0], [176.0, 1428.0], [132.0, 1428.0]]], "lines": ["そして、ある決定的な事実に茫然自実のプンプン"]}, {"box": [895, 1042, 940, 1375], "vertical": true, "font_size": 42, "lines_coords": [[[895.0, 1042.0], [937.0, 1042.0], [940.0, 1375.0], [898.0, 1375.0]]], "lines": ["すれ違う母と子。"]}], "img_path": "219.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [537, 60, 815, 384], "vertical": false, "font_size": 277, "lines_coords": [[[614.0, 60.0], [815.0, 118.0], [739.0, 384.0], [537.0, 326.0]]], "lines": ["．．．"]}, {"box": [100, 69, 359, 485], "vertical": true, "font_size": 101, "lines_coords": [[[268.0, 71.0], [356.0, 70.0], [359.0, 278.0], [271.0, 279.0]], [[189.0, 175.0], [289.0, 179.0], [278.0, 485.0], [178.0, 481.0]], [[100.0, 125.0], [215.0, 125.0], [215.0, 373.0], [100.0, 373.0]]], "lines": ["暗黒の", "第６巻に", "続く！！"]}, {"box": [935, 160, 986, 1085], "vertical": true, "font_size": 38, "lines_coords": [[[945.0, 160.0], [982.0, 160.0], [978.0, 1085.0], [940.0, 1085.0]]], "lines": ["少年ブンプンに心の平和が訪れる日は来るのか！？"]}, {"box": [493, 618, 890, 967], "vertical": false, "font_size": 341, "lines_coords": [[[493.0, 626.0], [884.0, 618.0], [890.0, 959.0], [500.0, 967.0]]], "lines": ["へ"]}, {"box": [639, 1025, 684, 1521], "vertical": true, "font_size": 42, "lines_coords": [[[640.0, 1025.0], [682.0, 1025.0], [681.0, 1521.0], [639.0, 1521.0]]], "lines": ["グッドバイブレーション：！！"]}, {"box": [3, 1014, 35, 1551], "vertical": true, "font_size": 31, "lines_coords": [[[4.0, 1014.0], [35.0, 1014.0], [34.0, 1551.0], [3.0, 1551.0]]], "lines": ["第６巻は、２００９年末頃発売予定！！お楽しみに！！"]}], "img_path": "220.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [945, 31, 1000, 56], "vertical": false, "font_size": 22, "lines_coords": [[[946.0, 31.0], [1000.0, 34.0], [998.0, 56.0], [945.0, 53.0]]], "lines": ["ＹＯＵＮＧＷＯＡＹＣＯ"]}, {"box": [912, 39, 1057, 178], "vertical": false, "font_size": 63.0, "lines_coords": [[[942.0, 60.0], [1057.0, 75.0], [1046.0, 178.0], [929.0, 164.0]], [[915.0, 39.0], [1031.0, 56.0], [1028.0, 78.0], [912.0, 60.0]]], "lines": ["ＷｏｒｄＰｒｏｍｏｓおやすみプレブン第５巻", "ｓｕｒｉＯｕｎｅｓｕｎｄＡｒｒｃｏＭｉｃｓ"]}, {"box": [93, 95, 864, 762], "vertical": true, "font_size": 34.714285714285715, "lines_coords": [[[829.0, 128.0], [860.0, 128.0], [864.0, 759.0], [832.0, 759.0]], [[771.0, 100.0], [807.0, 100.0], [807.0, 512.0], [771.0, 512.0]], [[715.0, 128.0], [753.0, 128.0], [753.0, 759.0], [715.0, 759.0]], [[660.0, 121.0], [696.0, 121.0], [696.0, 759.0], [660.0, 759.0]], [[604.0, 100.0], [635.0, 100.0], [635.0, 757.0], [604.0, 757.0]], [[548.0, 100.0], [579.0, 100.0], [579.0, 732.0], [548.0, 732.0]], [[493.0, 103.0], [520.0, 103.0], [520.0, 350.0], [493.0, 350.0]], [[432.0, 129.0], [464.0, 129.0], [467.0, 759.0], [435.0, 759.0]], [[376.0, 98.0], [412.0, 98.0], [412.0, 757.0], [376.0, 757.0]], [[315.0, 98.0], [353.0, 98.0], [357.0, 762.0], [320.0, 762.0]], [[257.0, 96.0], [296.0, 96.0], [298.0, 762.0], [259.0, 762.0]], [[203.0, 95.0], [240.0, 95.0], [242.0, 760.0], [204.0, 760.0]], [[146.0, 96.0], [182.0, 96.0], [185.0, 760.0], [150.0, 760.0]], [[93.0, 100.0], [129.0, 100.0], [129.0, 759.0], [93.0, 759.0]]], "lines": ["浅野先生はじめまして！・僕は川崎市に住む", "小三のプンプンファンです！！", "最初、同じクラスのひろし君のお兄ちゃん", "〈角刈り〉にすすめられて読んだときは、正", "直どこがおもしろいのか分からなかったので", "すが、最近では、こういうのも悪くないな。", "と思ってますよ！", "ところで、ひとつだけ浅野先生に質問がある", "ります！『おやすみプシプン』はいつになって", "たらバトルファンタアジー漫画になるのです", "か？なかなかプンプシンが修行したり必殺技を", "覚えたりしないのでやきもきしていますよ！", "同じクラスのひろし君。このお兄ちゃん（角刈）", "り）は、「これは『ひっぱる』という漫画の"]}, {"box": [906, 259, 1005, 590], "vertical": true, "font_size": 40, "lines_coords": [[[959.0, 262.0], [1001.0, 262.0], [1001.0, 582.0], [959.0, 582.0]], [[909.0, 259.0], [946.0, 259.0], [943.0, 504.0], [906.0, 504.0]]], "lines": ["プンプンの今後が", "気になる．．．！！"]}, {"box": [204, 828, 925, 1493], "vertical": true, "font_size": 33.92307692307692, "lines_coords": [[[885.0, 828.0], [921.0, 828.0], [925.0, 1060.0], [889.0, 1060.0]], [[831.0, 831.0], [864.0, 831.0], [864.0, 1057.0], [831.0, 1057.0]], [[770.0, 828.0], [812.0, 828.0], [812.0, 1060.0], [770.0, 1060.0]], [[717.0, 828.0], [750.0, 828.0], [751.0, 1489.0], [718.0, 1489.0]], [[662.0, 829.0], [693.0, 829.0], [693.0, 1493.0], [662.0, 1493.0]], [[604.0, 829.0], [637.0, 829.0], [639.0, 1485.0], [606.0, 1485.0]], [[550.0, 829.0], [581.0, 829.0], [579.0, 1490.0], [548.0, 1490.0]], [[492.0, 832.0], [523.0, 832.0], [523.0, 1051.0], [492.0, 1051.0]], [[435.0, 864.0], [467.0, 864.0], [467.0, 1490.0], [435.0, 1490.0]], [[375.0, 829.0], [410.0, 829.0], [414.0, 1490.0], [378.0, 1490.0]], [[320.0, 829.0], [353.0, 829.0], [354.0, 1490.0], [321.0, 1490.0]], [[264.0, 829.0], [296.0, 829.0], [298.0, 1487.0], [265.0, 1487.0]], [[206.0, 828.0], [243.0, 828.0], [242.0, 1351.0], [204.0, 1351.0]]], "lines": ["ましたが、本当", "なのでしょう", "か？それとも", "違うのですか！？早くはつきりしてください！！", "携帯に直接かけてきて構わないので僕にだけ", "こっそり教えてください！畜生！！ハァハ", "ァ。ちょっと興奮してしまいました。浅野先", "生も人が悪い！", "もしかしたらアイデアに詰まってるのかな", "ーと思い、僕の考えた敵キャラを同封してお", "きました。もし使うときは一応使用許可の連", "絡をください。携帯に直接で構いませんの", "で。それでは取り急ぎ、失礼します。"]}, {"box": [945, 829, 1032, 1056], "vertical": true, "font_size": 31.0, "lines_coords": [[[1001.0, 829.0], [1032.0, 829.0], [1032.0, 1053.0], [1001.0, 1053.0]], [[945.0, 831.0], [976.0, 831.0], [976.0, 1056.0], [945.0, 1056.0]]], "lines": ["高等テクニック", "だ」と言ってい"]}, {"box": [98, 934, 125, 1492], "vertical": true, "font_size": 27, "lines_coords": [[[98.0, 934.0], [125.0, 934.0], [125.0, 1492.0], [98.0, 1492.0]]], "lines": ["神奈川県川崎市〈小学三年・８歳ご岡本順哉"]}], "img_path": "221.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [918, 34, 970, 57], "vertical": false, "font_size": 19, "lines_coords": [[[920.0, 34.0], [970.0, 39.0], [968.0, 57.0], [918.0, 53.0]]], "lines": ["ＹＯＵＭＧ"]}, {"box": [884, 39, 1026, 175], "vertical": false, "font_size": 62.0, "lines_coords": [[[917.0, 65.0], [1026.0, 75.0], [1018.0, 175.0], [909.0, 165.0]], [[887.0, 39.0], [1003.0, 57.0], [998.0, 81.0], [884.0, 62.0]]], "lines": ["１０／ｃｏｍｏｇおやすみブンブン第５巻", "ｓｕｒｙｏｕｎｅｓｕｎｕｂｉｒｃｏＭｉｃｓ"]}, {"box": [65, 409, 381, 765], "vertical": true, "font_size": 31.5, "lines_coords": [[[348.0, 415.0], [381.0, 415.0], [381.0, 757.0], [348.0, 757.0]], [[290.0, 409.0], [323.0, 409.0], [321.0, 757.0], [289.0, 757.0]], [[234.0, 409.0], [265.0, 409.0], [265.0, 765.0], [234.0, 765.0]], [[176.0, 421.0], [207.0, 421.0], [207.0, 762.0], [176.0, 762.0]], [[120.0, 410.0], [151.0, 410.0], [151.0, 728.0], [120.0, 728.0]], [[65.0, 432.0], [96.0, 432.0], [96.0, 757.0], [65.0, 757.0]]], "lines": ["バイクでビルからビルに", "飛び移るシーンは最高に", "アッかったもんねーッ！！", "（ってそんなシーンあります", "したっけ？やべっし！！", "んでもって一個だけしつ"]}, {"box": [464, 104, 490, 759], "vertical": true, "font_size": 26, "lines_coords": [[[464.0, 104.0], [490.0, 104.0], [490.0, 759.0], [464.0, 759.0]]], "lines": ["展開がマンネリ気味のような気が．．．「おそるおそ」"]}, {"box": [395, 404, 442, 765], "vertical": true, "font_size": 47, "lines_coords": [[[395.0, 404.0], [442.0, 404.0], [442.0, 765.0], [395.0, 765.0]]], "lines": ["る．．．。でもブンプンが"]}, {"box": [518, 100, 781, 762], "vertical": true, "font_size": 35.2, "lines_coords": [[[739.0, 100.0], [781.0, 100.0], [781.0, 760.0], [739.0, 760.0]], [[682.0, 100.0], [720.0, 100.0], [725.0, 732.0], [687.0, 732.0]], [[629.0, 103.0], [662.0, 103.0], [665.0, 496.0], [632.0, 496.0]], [[575.0, 115.0], [606.0, 115.0], [606.0, 760.0], [575.0, 760.0]], [[518.0, 103.0], [550.0, 103.0], [550.0, 762.0], [518.0, 762.0]]], "lines": ["ん〜〜僕は『おやすみブンブン』を毎回楽しみに", "している高二のチェリーボーイ・ヤングソウル", "ダイナマイトです！（汗ー！！）", "一番好きなキャラはサスケです！（ってそんな", "キャラいましたっけ．．．？いっけね！〕最近は若干"]}, {"box": [803, 140, 834, 757], "vertical": true, "font_size": 31, "lines_coords": [[[803.0, 140.0], [834.0, 140.0], [834.0, 757.0], [803.0, 757.0]]], "lines": ["．．．おい浅野ッ！！（いきなり呼び捨てですみませ"]}, {"box": [879, 254, 975, 670], "vertical": true, "font_size": 38, "lines_coords": [[[931.0, 262.0], [970.0, 262.0], [973.0, 584.0], [934.0, 584.0]], [[879.0, 260.0], [917.0, 260.0], [917.0, 623.0], [879.0, 623.0]]], "lines": ["漫画表現の地平に", "果てはあるのか．．．！？"]}, {"box": [121, 828, 1004, 1493], "vertical": true, "font_size": 32.4375, "lines_coords": [[[970.0, 828.0], [1001.0, 828.0], [1004.0, 1490.0], [973.0, 1490.0]], [[914.0, 831.0], [950.0, 831.0], [950.0, 1493.0], [914.0, 1493.0]], [[859.0, 832.0], [890.0, 832.0], [890.0, 1492.0], [859.0, 1492.0]], [[803.0, 832.0], [834.0, 832.0], [834.0, 1492.0], [803.0, 1492.0]], [[740.0, 828.0], [779.0, 828.0], [781.0, 1490.0], [742.0, 1490.0]], [[689.0, 832.0], [720.0, 832.0], [720.0, 1490.0], [689.0, 1490.0]], [[631.0, 834.0], [667.0, 834.0], [667.0, 1493.0], [631.0, 1493.0]], [[573.0, 834.0], [609.0, 834.0], [609.0, 1492.0], [573.0, 1492.0]], [[518.0, 834.0], [546.0, 834.0], [548.0, 1490.0], [520.0, 1490.0]], [[464.0, 834.0], [490.0, 834.0], [490.0, 1489.0], [464.0, 1489.0]], [[403.0, 831.0], [439.0, 831.0], [437.0, 1490.0], [401.0, 1490.0]], [[348.0, 860.0], [379.0, 860.0], [379.0, 1490.0], [348.0, 1490.0]], [[289.0, 832.0], [320.0, 832.0], [323.0, 1493.0], [292.0, 1493.0]], [[235.0, 831.0], [267.0, 831.0], [267.0, 1492.0], [235.0, 1492.0]], [[176.0, 831.0], [209.0, 831.0], [210.0, 1490.0], [178.0, 1490.0]], [[121.0, 834.0], [153.0, 834.0], [153.0, 1403.0], [121.0, 1403.0]]], "lines": ["もーんッ！（元気印！）この「プンプン」っていう", "キャラは、なんで変な形をしてるんですか？何", "かの暗号なんでしょうか！？気になって夜しか眠れ", "ません．．。この形は鳥．．．いや宇宙人：それともま", "さか！．．．いやいやこれ以上は聞きますまい！つ", "まり人の数だけそれぞれの解釈があるってことで", "いいよな！？なっ！？〈馴れ馴れしくてすみません", "．．．一ちなみに僕と同じく「おやプナー」「プンプ", "ジファンのことですよ！だーってある学校の先輩", "はそんな僕に対し、毎日かかさず狼煙で一フロイ", "トを読め」とメッセージを送ってきます。助けて！！", "それでは最後にアサノビッチ先生！！（つてそんな", "な名前でしたっけ．．．？解脱！〕今後も勝手に連", "載がんばってください！！僕も子供の頃からの夢", "である鷹匠になるべく、「日々ガンバリズムで遺進", "いたします！！それではまた！ボイーン！"]}, {"box": [67, 932, 98, 1492], "vertical": true, "font_size": 31, "lines_coords": [[[67.0, 932.0], [98.0, 932.0], [98.0, 1492.0], [67.0, 1492.0]]], "lines": ["東京都武蔵野市〈高校〉二年・１７歳ご前田一聖"]}], "img_path": "222.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [146, 237, 460, 267], "vertical": false, "font_size": 28, "lines_coords": [[[146.0, 237.0], [460.0, 239.0], [460.0, 267.0], [146.0, 265.0]]], "lines": ["ヤングサンデーコミックス"]}, {"box": [142, 101, 628, 162], "vertical": false, "font_size": 58, "lines_coords": [[[142.0, 101.0], [628.0, 104.0], [628.0, 162.0], [142.0, 159.0]]], "lines": ["おやすみプンプン回"]}, {"box": [229, 623, 317, 656], "vertical": false, "font_size": 30, "lines_coords": [[[284.0, 623.0], [317.0, 623.0], [317.0, 653.0], [284.0, 653.0]], [[229.0, 623.0], [262.0, 623.0], [262.0, 656.0], [229.0, 656.0]]], "lines": ["者", "著"]}, {"box": [229, 704, 318, 792], "vertical": false, "font_size": 30, "lines_coords": [[[229.0, 704.0], [318.0, 704.0], [318.0, 739.0], [229.0, 739.0]], [[231.0, 765.0], [312.0, 768.0], [312.0, 792.0], [231.0, 789.0]]], "lines": ["発行者", "ヒクルル"]}, {"box": [234, 465, 637, 492], "vertical": false, "font_size": 27, "lines_coords": [[[234.0, 465.0], [637.0, 465.0], [637.0, 492.0], [234.0, 492.0]]], "lines": ["２００９年７月５日初版第１刷発行"]}, {"box": [443, 573, 803, 799], "vertical": false, "font_size": 66, "lines_coords": [[[515.0, 653.0], [754.0, 653.0], [754.0, 685.0], [515.0, 685.0]], [[570.0, 707.0], [603.0, 707.0], [603.0, 735.0], [570.0, 735.0]], [[443.0, 573.0], [803.0, 573.0], [803.0, 793.0], [443.0, 793.0]], [[496.0, 768.0], [751.0, 768.0], [751.0, 790.0], [496.0, 790.0]], [[729.0, 701.0], [756.0, 706.0], [750.0, 735.0], [723.0, 731.0]]], "lines": ["ｉｎｉｏＡｓａｎｏ２００", "零", "浅野、いいにお電話のメールの中、普通の大日本円制限はあります。", "大日本印刷株式会社", "！！"]}, {"box": [526, 400, 987, 428], "vertical": false, "font_size": 26, "lines_coords": [[[526.0, 400.0], [987.0, 401.0], [987.0, 428.0], [526.0, 426.0]]], "lines": ["ＩＳＢＮ９７８－４－－０９－１５１４３０－１"]}, {"box": [881, 460, 993, 492], "vertical": false, "font_size": 28, "lines_coords": [[[881.0, 460.0], [993.0, 464.0], [993.0, 492.0], [881.0, 489.0]]], "lines": ["（検印廃止）"]}, {"box": [143, 946, 721, 1034], "vertical": false, "font_size": 25.333333333333332, "lines_coords": [[[143.0, 946.0], [340.0, 946.0], [340.0, 968.0], [143.0, 968.0]], [[143.0, 973.0], [409.0, 973.0], [409.0, 1000.0], [143.0, 1000.0]], [[145.0, 1007.0], [721.0, 1007.0], [721.0, 1034.0], [145.0, 1034.0]]], "lines": ["連載担当／荻野克展", "単行本編集責任／赤名英之", "単行本編集ノ荻野克展、立川久美子（アイブロダクション）"]}, {"box": [146, 845, 959, 879], "vertical": false, "font_size": 31, "lines_coords": [[[146.0, 848.0], [959.0, 845.0], [959.0, 876.0], [146.0, 879.0]]], "lines": ["「週刊ビッグコミックスピリッツ」（９８年第２号、第４１．．．５合併号、第８号、２０号、"]}, {"box": [139, 1051, 745, 1106], "vertical": false, "font_size": 36.0, "lines_coords": [[[140.0, 1051.0], [282.0, 1056.0], [281.0, 1106.0], [139.0, 1101.0]], [[268.0, 1059.0], [745.0, 1054.0], [745.0, 1076.0], [268.0, 1081.0]]], "lines": ["発行所", "（〒１０１－８０１）東京都千代田区一ツ橋二の三の"]}, {"box": [479, 881, 917, 935], "vertical": false, "font_size": 23.0, "lines_coords": [[[479.0, 881.0], [917.0, 881.0], [917.0, 907.0], [479.0, 907.0]], [[481.0, 915.0], [803.0, 915.0], [803.0, 935.0], [481.0, 935.0]]], "lines": ["第１２号、第１４号、舞１８号、第１８号、第２０号、", "第２２：２３合併号、第５５号掲載作品"]}, {"box": [504, 1089, 732, 1109], "vertical": false, "font_size": 20, "lines_coords": [[[504.0, 1089.0], [732.0, 1089.0], [732.0, 1109.0], [504.0, 1109.0]]], "lines": ["ＴＥＬ編集ＧＢ（３２３））５５０５"]}, {"box": [556, 1120, 734, 1140], "vertical": false, "font_size": 20, "lines_coords": [[[556.0, 1120.0], [734.0, 1120.0], [734.0, 1140.0], [556.0, 1140.0]]], "lines": ["販売１３：５２８１：３５６"]}, {"box": [823, 807, 989, 828], "vertical": false, "font_size": 21, "lines_coords": [[[823.0, 807.0], [989.0, 807.0], [989.0, 828.0], [823.0, 828.0]]], "lines": ["Ｐｒｉｎｔｅｄｉｎｊａｐａｎ"]}, {"box": [762, 1095, 928, 1145], "vertical": false, "font_size": 30.0, "lines_coords": [[[767.0, 1095.0], [829.0, 1095.0], [829.0, 1118.0], [767.0, 1118.0]], [[762.0, 1109.0], [926.0, 1098.0], [928.0, 1135.0], [765.0, 1145.0]]], "lines": ["株式ヘッ", "会社小学館"]}, {"box": [143, 1170, 990, 1442], "vertical": false, "font_size": 20.0, "lines_coords": [[[146.0, 1170.0], [987.0, 1170.0], [987.0, 1190.0], [146.0, 1190.0]], [[145.0, 1195.0], [990.0, 1195.0], [990.0, 1215.0], [145.0, 1215.0]], [[146.0, 1223.0], [293.0, 1223.0], [293.0, 1243.0], [146.0, 1243.0]], [[143.0, 1248.0], [985.0, 1250.0], [985.0, 1271.0], [143.0, 1270.0]], [[145.0, 1278.0], [871.0, 1278.0], [871.0, 1298.0], [145.0, 1298.0]], [[143.0, 1304.0], [426.0, 1304.0], [426.0, 1325.0], [143.0, 1325.0]], [[145.0, 1332.0], [990.0, 1332.0], [990.0, 1353.0], [145.0, 1353.0]], [[148.0, 1359.0], [750.0, 1359.0], [750.0, 1379.0], [148.0, 1379.0]], [[146.0, 1389.0], [771.0, 1389.0], [771.0, 1409.0], [146.0, 1409.0]], [[170.0, 1423.0], [326.0, 1426.0], [326.0, 1442.0], [170.0, 1439.0]]], "lines": ["●造本には十分注意しておりますが、落丁。乱丁（本のページの抜け落ちや順序の間違いの場合はお取り", "替えいたします。購入された書店名を明記して「制作同」あてにお送りください。送料小社負担にてお取り", "り替えいたします。", "●本書の一部あるいは全部を無断で複製・転載・上演・放送等をすることは、法律で認められた場合を除き、", "著作者および出版者の権利の侵害となります。あらかじめ小社あて許諾をお求めください。", "区〔日本複写権センター委託出版物〕", "本書を無断で複写複製（コピ一リすることは、著作権法上の例外を除き、禁じられています。本書をコピー", "される場合は、事前に日本複写権センター（ＩＲＲＣ）心の許諾を受けてください。", "ＪＲＲＣ／ｈｔｔｐ／／／ｗｗｗｉｒｃｃｒｉｐ．セメール・ｉｎｄｏ＠ｓｉｒｃｏｒｉｐＴＥＬＴＧ－３４０１－２８２", "アンケートのお願い"]}, {"box": [409, 1423, 537, 1442], "vertical": false, "font_size": 17, "lines_coords": [[[409.0, 1425.0], [537.0, 1423.0], [537.0, 1440.0], [409.0, 1442.0]]], "lines": ["小学館アンケート係"]}, {"box": [170, 1459, 857, 1562], "vertical": false, "font_size": 17.6, "lines_coords": [[[170.0, 1459.0], [801.0, 1460.0], [801.0, 1481.0], [170.0, 1479.0]], [[170.0, 1484.0], [600.0, 1484.0], [600.0, 1500.0], [170.0, 1500.0]], [[173.0, 1501.0], [598.0, 1503.0], [598.0, 1523.0], [173.0, 1521.0]], [[171.0, 1526.0], [857.0, 1526.0], [857.0, 1542.0], [171.0, 1542.0]], [[171.0, 1546.0], [789.0, 1546.0], [789.0, 1562.0], [171.0, 1562.0]]], "lines": ["●小学館のコミックス、書籍についてのアンケートをインターネットで受け付けています。", "ｈｔｔｐ／／ｗｗｗｉｔｉｏ．ｓｈｏｒｋｉｃｋｉｋｏｎｃｏｉｎにアクセスしていただき、", "このコミックスのキーコーＦ－ＳＥＲＯＴを入力してください。", "●全ご回答者の中から、毎月５８０名の方に抽選で、小学館特製国書カード（１８８０円）をさしあげます。", "●発行日より６か月間有効です。●発表は賞品の発送をもってかえさせていただきます。"]}, {"box": [757, 1223, 985, 1243], "vertical": false, "font_size": 20, "lines_coords": [[[757.0, 1223.0], [985.0, 1223.0], [985.0, 1243.0], [757.0, 1243.0]]], "lines": ["都作局・ＴＥＬ・ＯＬ２０－３６－８２"]}], "img_path": "223.png"}]}