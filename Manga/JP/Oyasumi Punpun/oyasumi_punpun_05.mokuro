, 412.0]], [[3267.0, 414.0], [3453.0, 414.0], [3453.0, 446.0], [3267.0, 446.0]], [[3635.0, 414.0], [3813.0, 414.0], [3813.0, 446.0], [3635.0, 446.0]], [[3267.0, 433.0], [3825.0, 433.0], [3825.0, 488.0], [3267.0, 488.0]], [[3244.0, 459.0], [3836.0, 459.0], [3836.0, 571.0], [3244.0, 571.0]], [[3263.0, 550.0], [3525.0, 550.0], [3525.0, 583.0], [3263.0, 583.0]], [[3256.0, 569.0], [3734.0, 565.0], [3734.0, 613.0], [3256.0, 617.0]], [[3267.0, 615.0], [3813.0, 615.0], [3813.0, 647.0], [3267.0, 647.0]], [[3267.0, 649.0], [3821.0, 649.0], [3821.0, 681.0], [3267.0, 681.0]], [[3271.0, 683.0], [3533.0, 683.0], [3533.0, 715.0], [3271.0, 715.0]], [[3711.0, 683.0], [3813.0, 683.0], [3813.0, 715.0], [3711.0, 715.0]], [[3256.0, 702.0], [3821.0, 698.0], [3821.0, 757.0], [3256.0, 761.0]], [[3271.0, 751.0], [3817.0, 751.0], [3817.0, 784.0], [3271.0, 784.0]], [[3267.0, 785.0], [3483.0, 785.0], [3483.0, 818.0], [3267.0, 818.0]], [[3722.0, 785.0], [3813.0, 785.0], [3813.0, 818.0], [3722.0, 818.0]], [[3267.0, 819.0], [3544.0, 819.0], [3544.0, 852.0], [3267.0, 852.0]], [[3703.0, 815.0], [3813.0, 815.0], [3813.0, 859.0], [3703.0, 859.0]], [[3586.0, 846.0], [3813.0, 853.0], [3813.0, 890.0], [3586.0, 882.0]], [[3267.0, 853.0], [3567.0, 853.0], [3567.0, 886.0], [3267.0, 886.0]], [[3259.0, 880.0], [3817.0, 876.0], [3817.0, 924.0], [3259.0, 928.0]], [[3259.0, 914.0], [3487.0, 910.0], [3487.0, 954.0], [3259.0, 958.0]], [[3263.0, 948.0], [3616.0, 941.0], [3616.0, 984.0], [3263.0, 992.0]]], "lines": ["おやすみプンプン・ニュー・ヘＣ＃", "浅野いにお洋服いにも", "２０１７年リラニン・全２巻", "浅野いにの浅野小にお首振の羊子", "コポンドの福音全４巻", "浅野いにの高橋留美子", "イベントの曲目、エーザーローコトー診療所、１〜２０巻", "『高田大』山田貴敏", "しかし、一般は２４日ＡＮＥＯＷ－二金大原のもとにそれでは、１～２０巻－安部泉二ノ補崎正澄", "鉄腕バーディー全２０１７年１０巻", "はーはーゆうきまさみ", "このつきまさみ室積光ノ猪熊しのぶ", "収納へ都立水商！全２２巻", "アンバル・エロクロサギ・全２０巻", "最近、追加して、黒丸ノ夏原市でも", "グラウザ・全国語・イベントが大きくなったことができないのですが、サーバーでもお客さんがございます。ご利用いただきますがお", "イヤだった。Ｈａｖａｍａｕｔｉｎｔｅは、１９５０万円もクラックス・コーナー一部のみなら、超高気力機能シリーズ・イング・生活・生産・投稿をさせていたときています。", "Ｑ．．．ｃｏ．．ｍａｎｄｉｓオッズ－キ「巻士へはヘッド", "Ｃｏｎｄｓオッズ・キリ巻さんが展ン外国ームなのかなります。全いコンピューターは", "ごくごめんねーイームムーツのタナトスかしけらの時、全日巻【主「ゴールド・竹原慎二ノ落合裕介", "メバ、スリック・エレをとめばねっ！！鈴里高校教道部－１０／１１／２０１１〜５巻一河合克敏", "ビーチスターズ全７巻", "バロルの森尾正博", "ビーチスターズ全てを考えることができます。逆方が表現されているのですが、その後には、全てのチェーチョックなどが", "あとヒールは、一人の山賊まつりは彼女の男の子は、全日巻きっと、ここで、「ロロロールズの一木根ヲサムノ国川光太郎", "８．２０１６年度ロケン・１〜２巻", "喜国雅彦", "第１３美晴♥ライジング・全５巻", "・普画補修大谷じろう〈藤原世末", "七月鏡一ノ藤原芳秀", "美術のイージス、全日巻、サービス", "暁のイーンへ、生日をあんころ。神奈川丁目駅先日のローバー（土）一七月鏡一ノ勝原芳秀全５巻一万乗大智", "あんころ。かわいい日は、ＧＯ・ＯＮ・全４巻ードライフーニング", "ＤＪＵＮＫ・主４巻トライブ・ライフ・全Ｇ巻"]}, {"box": [2072, 974, 2893, 1260], "vertical": false, "font_size": 114, "lines_coords": [[[2072.0, 1017.0], [2857.0, 964.0], [2868.0, 1143.0], [2083.0, 1196.0]], [[2591.0, 1066.0], [2891.0, 1078.0], [2887.0, 1173.0], [2588.0, 1162.0]], [[2284.0, 1146.0], [2838.0, 1165.0], [2838.0, 1261.0], [2284.0, 1242.0]]], "lines": ["リスン映画「メール", "全国１０００年８月１１日ショッピングのお", "主演官﨑あおい"]}, {"box": [2948, 1065, 3084, 1125], "vertical": false, "font_size": 66, "lines_coords": [[[2948.0, 1059.0], [3084.0, 1059.0], [3084.0, 1131.0], [2948.0, 1131.0]]], "lines": ["三木孝浩"]}, {"box": [2053, 1524, 2967, 1581], "vertical": false, "font_size": 54, "lines_coords": [[[2053.0, 1527.0], [2967.0, 1524.0], [2967.0, 1577.0], [2053.0, 1581.0]]], "lines": ["東京都府はお母さまの学校においておりますので、ン１全２巻、絶賛発売中！！"]}, {"box": [2299, 1421, 3005, 1509], "vertical": false, "font_size": 65, "lines_coords": [[[2299.0, 1444.0], [3005.0, 1421.0], [3005.0, 1486.0], [2299.0, 1509.0]]], "lines": ["お金をお願いします。本当には、"]}, {"box": [2883, 1421, 3006, 1494], "vertical": false, "font_size": 80, "lines_coords": [[[2883.0, 1414.0], [3006.0, 1414.0], [3006.0, 1501.0], [2883.0, 1501.0]]], "lines": ["高良健吾"]}, {"box": [3681, 1542, 3882, 1589], "vertical": false, "font_size": 51, "lines_coords": [[[3681.0, 1538.0], [3882.0, 1538.0], [3882.0, 1593.0], [3681.0, 1593.0]]], "lines": ["おやすみプンプンＧ"]}], "img_path": "002.png"}, {"version": "0.2.0-beta.6", "img_width": 2380, "img_height": 1600, "blocks": [{"box": [88, 787, 141, 1538], "vertical": true, "font_size": 32, "lines_coords": [[[95.0, 818.0], [127.0, 818.0], [127.0, 1518.0], [95.0, 1518.0]]], "lines": ["おやすみプンプン５．浅野、にお"]}, {"box": [1158, 87, 1230, 146], "vertical": false, "font_size": 44, "lines_coords": [[[1164.0, 100.0], [1190.0, 100.0], [1190.0, 148.0], [1164.0, 148.0]]], "lines": ["．．．"]}, {"box": [1138, 60, 1248, 941], "vertical": true, "font_size": 110, "lines_coords": [[[1138.0, 60.0], [1248.0, 60.0], [1248.0, 941.0], [1138.0, 941.0]]], "lines": ["選おやすみプランターネットで"]}, {"box": [1175, 109, 1218, 918], "vertical": true, "font_size": 43, "lines_coords": [[[1175.0, 109.0], [1218.0, 109.0], [1218.0, 918.0], [1175.0, 918.0]]], "lines": ["おやすみプンプン今回、浅野いにお"]}], "img_path": "003.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [876, 410, 925, 1128], "vertical": true, "font_size": 47, "lines_coords": [[[876.0, 410.0], [923.0, 410.0], [925.0, 1128.0], [878.0, 1128.0]]], "lines": ["おやすみプンプンの一浅野にお"]}, {"box": [74, 1506, 280, 1530], "vertical": false, "font_size": 20, "lines_coords": [[[79.0, 1507.0], [273.0, 1505.0], [273.0, 1527.0], [79.0, 1528.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹＣＯＭＣＳ"]}], "img_path": "004.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [803, 132, 895, 170], "vertical": false, "font_size": 35, "lines_coords": [[[803.0, 135.0], [893.0, 132.0], [895.0, 167.0], [804.0, 170.0]]], "lines": ["次日"]}, {"box": [126, 618, 257, 650], "vertical": false, "font_size": 28, "lines_coords": [[[126.0, 618.0], [257.0, 621.0], [257.0, 650.0], [126.0, 646.0]]], "lines": ["登場人物"]}, {"box": [198, 670, 528, 748], "vertical": false, "font_size": 23.333333333333332, "lines_coords": [[[198.0, 670.0], [370.0, 670.0], [370.0, 696.0], [198.0, 696.0]], [[201.0, 701.0], [528.0, 701.0], [528.0, 723.0], [201.0, 723.0]], [[200.0, 725.0], [439.0, 726.0], [439.0, 748.0], [200.0, 746.0]]], "lines": ["小野寺プンプン", "チョコパイ好きのヤンヤンレグガイ。中学３年。", "好きな決まり手は合掌捻り。"]}, {"box": [118, 301, 654, 550], "vertical": false, "font_size": 29.166666666666668, "lines_coords": [[[118.0, 301.0], [407.0, 301.0], [407.0, 334.0], [118.0, 334.0]], [[121.0, 357.0], [526.0, 360.0], [526.0, 387.0], [121.0, 384.0]], [[125.0, 400.0], [607.0, 400.0], [607.0, 426.0], [125.0, 426.0]], [[123.0, 440.0], [654.0, 442.0], [654.0, 468.0], [123.0, 467.0]], [[121.0, 479.0], [478.0, 476.0], [478.0, 507.0], [121.0, 510.0]], [[121.0, 518.0], [448.0, 518.0], [448.0, 550.0], [121.0, 550.0]]], "lines": ["４巻までのあらすじ", "小野寺プンプンは、胸キュンガール・", "田中愛子とのやり取りの中でアルやコレ等の", "何とも言えない気持ちがら心の距離を置くことに、", "二年後、中学三年のプンプンは、", "高校の合格発表に出かける。"]}, {"box": [195, 756, 732, 837], "vertical": false, "font_size": 33.333333333333336, "lines_coords": [[[195.0, 756.0], [418.0, 756.0], [418.0, 787.0], [195.0, 787.0]], [[201.0, 782.0], [607.0, 787.0], [607.0, 820.0], [201.0, 815.0]], [[196.0, 801.0], [732.0, 801.0], [732.0, 837.0], [196.0, 837.0]]], "lines": ["小野寺プンプンママ", "プラフィック・プランの円税・若い頃、実は相談メーカーナー・バージョールオーディションに応募するのは、", "ブンブンの母親。若い頃、イメージガールオーディシ某化粧品メーカーのコンに応募するか書類選考で落選。"]}, {"box": [760, 162, 993, 907], "vertical": true, "font_size": 98, "lines_coords": [[[921.0, 214.0], [968.0, 214.0], [971.0, 854.0], [925.0, 854.0]], [[770.0, 214.0], [807.0, 214.0], [807.0, 853.0], [770.0, 853.0]], [[768.0, 182.0], [920.0, 182.0], [920.0, 835.0], [768.0, 835.0]], [[760.0, 162.0], [993.0, 162.0], [993.0, 907.0], [760.0, 907.0]], [[840.0, 581.0], [862.0, 581.0], [862.0, 653.0], [840.0, 653.0]]], "lines": ["あ、あぁぁ、あああ、", "第１９９９第１第１２条第１５条第第１９第１第条第二第", "第４７話第４８話第３０話第５１番第５２話第９３話第６４話第１５４話発５５話☆中学", "一平成年４７月の第１８回金第４９回の第５１回の売り上記事第５３話会第５４話第５６回の祭りを", "－３"]}, {"box": [201, 851, 639, 901], "vertical": false, "font_size": 20.0, "lines_coords": [[[201.0, 851.0], [326.0, 851.0], [326.0, 871.0], [201.0, 871.0]], [[206.0, 881.0], [639.0, 881.0], [639.0, 901.0], [206.0, 901.0]]], "lines": ["小野寺雄一", "プンプンママの弟。陶芸教室の先生。現在失踪中。"]}, {"box": [200, 939, 628, 992], "vertical": false, "font_size": 24.0, "lines_coords": [[[200.0, 939.0], [303.0, 939.0], [303.0, 965.0], [200.0, 965.0]], [[200.0, 970.0], [628.0, 970.0], [628.0, 992.0], [200.0, 992.0]]], "lines": ["田中愛子", "プンプンの好きだった女の子。現在特に交流なし。"]}, {"box": [196, 1026, 642, 1171], "vertical": false, "font_size": 30.0, "lines_coords": [[[196.0, 1026.0], [279.0, 1026.0], [279.0, 1060.0], [196.0, 1060.0]], [[198.0, 1057.0], [634.0, 1057.0], [634.0, 1084.0], [198.0, 1084.0]], [[196.0, 1115.0], [281.0, 1115.0], [281.0, 1148.0], [196.0, 1148.0]], [[198.0, 1145.0], [642.0, 1145.0], [642.0, 1171.0], [198.0, 1171.0]]], "lines": ["大限理", "雄一の彼女。喫茶店経営。ブンブンとほぼ同居中。", "関真澄", "プンプンの同級生。中学卒業後は進学の予定とし。"]}, {"box": [200, 1387, 268, 1417], "vertical": false, "font_size": 30, "lines_coords": [[[200.0, 1387.0], [268.0, 1387.0], [268.0, 1417.0], [200.0, 1417.0]]], "lines": ["としき"]}, {"box": [200, 1418, 360, 1440], "vertical": false, "font_size": 22, "lines_coords": [[[200.0, 1418.0], [360.0, 1418.0], [360.0, 1440.0], [200.0, 1440.0]]], "lines": ["街に住み着く妖精。"]}, {"box": [178, 1189, 700, 1281], "vertical": false, "font_size": 92, "lines_coords": [[[178.0, 1189.0], [700.0, 1189.0], [700.0, 1281.0], [178.0, 1281.0]]], "lines": ["スタッフの時期にコースをしていたので、開発ブラウンの開催されていました。そのためには、"]}, {"box": [200, 1300, 700, 1350], "vertical": false, "font_size": 22.5, "lines_coords": [[[200.0, 1300.0], [253.0, 1300.0], [253.0, 1323.0], [200.0, 1323.0]], [[206.0, 1328.0], [700.0, 1328.0], [700.0, 1350.0], [206.0, 1350.0]]], "lines": ["湯上", "プンプンママの離婚問題を担当した弁護士。雄一の友人。"]}], "img_path": "005.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [29, 326, 68, 510], "vertical": true, "font_size": 39, "lines_coords": [[[29.0, 326.0], [68.0, 326.0], [68.0, 510.0], [29.0, 510.0]]], "lines": ["２０１７話と"]}], "img_path": "006.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "007.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [789, 54, 978, 512], "vertical": true, "font_size": 108, "lines_coords": [[[900.0, 89.0], [978.0, 89.0], [978.0, 365.0], [900.0, 365.0]], [[789.0, 54.0], [928.0, 54.0], [928.0, 512.0], [789.0, 512.0]]], "lines": ["高等学校", "般合格者発表"]}, {"box": [542, 331, 620, 418], "vertical": true, "font_size": 24, "lines_coords": [[[596.0, 331.0], [620.0, 331.0], [620.0, 385.0], [596.0, 385.0]], [[570.0, 332.0], [593.0, 332.0], [593.0, 409.0], [570.0, 409.0]], [[542.0, 332.0], [568.0, 332.0], [568.0, 418.0], [542.0, 418.0]]], "lines": ["いやいやかなかっ", "いやいやかなかわからない", "．．．わかったわけじゃないの？"]}, {"box": [416, 337, 493, 409], "vertical": true, "font_size": 26, "lines_coords": [[[465.0, 337.0], [493.0, 337.0], [493.0, 406.0], [465.0, 406.0]], [[440.0, 339.0], [464.0, 339.0], [464.0, 404.0], [440.0, 404.0]]], "lines": ["おかげさかわかったか？", "おいおいのおいっそいつおい？"]}, {"box": [160, 960, 400, 1290], "vertical": false, "font_size": 308, "lines_coords": [[[195.0, 960.0], [400.0, 984.0], [367.0, 1290.0], [160.0, 1267.0]]], "lines": ["おー"]}], "img_path": "008.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [503, 35, 594, 254], "vertical": true, "font_size": 27, "lines_coords": [[[567.0, 37.0], [593.0, 37.0], [593.0, 164.0], [567.0, 164.0]], [[532.0, 35.0], [560.0, 35.0], [562.0, 167.0], [534.0, 167.0]], [[503.0, 37.0], [529.0, 37.0], [529.0, 251.0], [503.0, 251.0]]], "lines": ["フンフンは", "別に嬉しく", "ありませんでした。"]}, {"box": [945, 337, 989, 523], "vertical": true, "font_size": 33, "lines_coords": [[[945.0, 337.0], [989.0, 337.0], [989.0, 523.0], [945.0, 523.0]]], "lines": ["はあぁ！！"]}, {"box": [835, 553, 934, 768], "vertical": true, "font_size": 33, "lines_coords": [[[903.0, 553.0], [934.0, 553.0], [934.0, 739.0], [903.0, 739.0]], [[871.0, 554.0], [898.0, 554.0], [898.0, 753.0], [871.0, 753.0]], [[835.0, 553.0], [864.0, 553.0], [865.0, 768.0], [837.0, 768.0]]], "lines": ["いくら頬擦り", "しても、まるで", "し足りないっ！！"]}, {"box": [224, 375, 370, 592], "vertical": true, "font_size": 33, "lines_coords": [[[335.0, 375.0], [370.0, 375.0], [370.0, 470.0], [335.0, 470.0]], [[298.0, 376.0], [329.0, 376.0], [329.0, 592.0], [298.0, 592.0]], [[260.0, 375.0], [292.0, 375.0], [292.0, 562.0], [260.0, 562.0]]], "lines": ["息子が", "こんなに優秀な", "進学校に合格"]}, {"box": [220, 371, 254, 585], "vertical": true, "font_size": 32, "lines_coords": [[[220.0, 371.0], [251.0, 371.0], [254.0, 585.0], [223.0, 585.0]]], "lines": ["したことをっ！！"]}, {"box": [173, 640, 284, 904], "vertical": true, "font_size": 32, "lines_coords": [[[251.0, 640.0], [284.0, 640.0], [281.0, 859.0], [248.0, 859.0]], [[212.0, 640.0], [245.0, 640.0], [242.0, 826.0], [209.0, 826.0]], [[173.0, 642.0], [204.0, 642.0], [204.0, 904.0], [173.0, 904.0]]], "lines": ["日本中の人間に", "自慢できない", "なんて、悲劇としか"]}, {"box": [137, 642, 283, 920], "vertical": true, "font_size": 26, "lines_coords": [[[139.0, 643.0], [165.0, 643.0], [165.0, 920.0], [139.0, 920.0]]], "lines": ["言い様がないわっ！！"]}, {"box": [939, 1127, 963, 1279], "vertical": true, "font_size": 20, "lines_coords": [[[940.0, 1128.0], [960.0, 1128.0], [960.0, 1275.0], [940.0, 1275.0]]], "lines": ["．．．この合格は"]}, {"box": [770, 1125, 893, 1304], "vertical": true, "font_size": 26, "lines_coords": [[[867.0, 1129.0], [889.0, 1129.0], [889.0, 1276.0], [867.0, 1276.0]], [[832.0, 1126.0], [859.0, 1126.0], [859.0, 1254.0], [832.0, 1254.0]], [[801.0, 1125.0], [828.0, 1125.0], [828.0, 1304.0], [801.0, 1304.0]], [[770.0, 1126.0], [796.0, 1126.0], [796.0, 1262.0], [770.0, 1262.0]]], "lines": ["ただひたすら", "勉強をした", "当然の結果だと", "思いました。"]}, {"box": [460, 1353, 522, 1542], "vertical": true, "font_size": 26, "lines_coords": [[[495.0, 1354.0], [521.0, 1354.0], [521.0, 1507.0], [495.0, 1507.0]], [[460.0, 1353.0], [487.0, 1353.0], [489.0, 1539.0], [462.0, 1539.0]]], "lines": ["この二年間の", "思い出といえば、"]}, {"box": [293, 1354, 415, 1535], "vertical": true, "font_size": 26, "lines_coords": [[[390.0, 1356.0], [412.0, 1356.0], [412.0, 1532.0], [390.0, 1532.0]], [[354.0, 1356.0], [382.0, 1356.0], [382.0, 1460.0], [354.0, 1460.0]], [[323.0, 1354.0], [350.0, 1354.0], [350.0, 1484.0], [323.0, 1484.0]], [[293.0, 1354.0], [320.0, 1354.0], [320.0, 1493.0], [293.0, 1493.0]]], "lines": ["ノートや黒板に", "書かれた", "数式や英文", "ばかりです。"]}], "img_path": "009.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [579, 40, 637, 201], "vertical": true, "font_size": 22, "lines_coords": [[[612.0, 43.0], [634.0, 43.0], [634.0, 189.0], [612.0, 189.0]], [[579.0, 42.0], [601.0, 42.0], [601.0, 192.0], [579.0, 192.0]]], "lines": ["他に憶えてる", "ことといえば"]}, {"box": [343, 40, 529, 355], "vertical": true, "font_size": 23, "lines_coords": [[[504.0, 43.0], [525.0, 43.0], [525.0, 245.0], [504.0, 245.0]], [[471.0, 43.0], [493.0, 43.0], [493.0, 348.0], [471.0, 348.0]], [[437.0, 42.0], [464.0, 42.0], [464.0, 353.0], [437.0, 353.0]], [[404.0, 40.0], [431.0, 40.0], [429.0, 351.0], [403.0, 351.0]], [[376.0, 43.0], [398.0, 43.0], [398.0, 318.0], [376.0, 318.0]], [[345.0, 43.0], [367.0, 43.0], [367.0, 246.0], [345.0, 246.0]]], "lines": ["学年で可愛い女子", "トッフ３に入る下関さんが", "１か月間不登校だったのは", "フリーターの彼氏との間に", "出来た子供を堕ろすため", "だったという噂と"]}, {"box": [138, 40, 292, 324], "vertical": true, "font_size": 24, "lines_coords": [[[264.0, 42.0], [289.0, 42.0], [292.0, 270.0], [267.0, 270.0]], [[231.0, 40.0], [257.0, 40.0], [259.0, 246.0], [232.0, 246.0]], [[203.0, 43.0], [225.0, 43.0], [225.0, 320.0], [203.0, 320.0]], [[167.0, 42.0], [193.0, 42.0], [196.0, 298.0], [170.0, 298.0]], [[139.0, 43.0], [160.0, 43.0], [160.0, 200.0], [139.0, 200.0]]], "lines": ["先生を突き飛ばして", "怪我をさせたりと", "問題の多かった倉本君が", "放火で補導されたこと", "くらいでした。"]}, {"box": [870, 717, 931, 883], "vertical": true, "font_size": 27, "lines_coords": [[[903.0, 720.0], [931.0, 720.0], [931.0, 831.0], [903.0, 831.0]], [[870.0, 717.0], [896.0, 717.0], [900.0, 882.0], [873.0, 882.0]]], "lines": ["．．．けれど、", "どれもこれも、"]}, {"box": [196, 792, 293, 1028], "vertical": true, "font_size": 30, "lines_coords": [[[259.0, 792.0], [290.0, 792.0], [293.0, 1028.0], [262.0, 1028.0]], [[229.0, 793.0], [256.0, 793.0], [256.0, 975.0], [229.0, 975.0]], [[196.0, 793.0], [229.0, 793.0], [229.0, 885.0], [196.0, 885.0]]], "lines": ["プンプンにとっては", "とっても他人事", "でした。"]}, {"box": [856, 1310, 950, 1478], "vertical": true, "font_size": 28, "lines_coords": [[[915.0, 1310.0], [950.0, 1310.0], [950.0, 1396.0], [915.0, 1396.0]], [[885.0, 1312.0], [912.0, 1312.0], [915.0, 1478.0], [889.0, 1478.0]], [[857.0, 1315.0], [879.0, 1315.0], [879.0, 1446.0], [857.0, 1446.0]]], "lines": ["そんな", "プンプンが今、", "思うことは"]}, {"box": [156, 1375, 222, 1506], "vertical": true, "font_size": 34, "lines_coords": [[[192.0, 1378.0], [220.0, 1378.0], [221.0, 1506.0], [193.0, 1506.0]], [[156.0, 1375.0], [196.0, 1375.0], [196.0, 1450.0], [156.0, 1450.0]]], "lines": ["ただひとつ", "です。"]}], "img_path": "010.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [515, 710, 590, 865], "vertical": true, "font_size": 31, "lines_coords": [[[559.0, 714.0], [585.0, 714.0], [585.0, 864.0], [559.0, 864.0]], [[515.0, 712.0], [550.0, 710.0], [553.0, 818.0], [518.0, 820.0]]], "lines": ["セックスが", "したい。"]}, {"box": [168, 1020, 295, 1229], "vertical": true, "font_size": 28, "lines_coords": [[[259.0, 1020.0], [292.0, 1020.0], [295.0, 1139.0], [262.0, 1139.0]], [[232.0, 1023.0], [259.0, 1023.0], [259.0, 1179.0], [232.0, 1179.0]], [[201.0, 1023.0], [228.0, 1023.0], [228.0, 1229.0], [201.0, 1229.0]], [[168.0, 1023.0], [195.0, 1023.0], [195.0, 1164.0], [168.0, 1164.0]]], "lines": ["．．．いや、", "ここはあえて", "下世話な言い方で", "宣言します。"]}, {"box": [515, 1382, 590, 1506], "vertical": true, "font_size": 38, "lines_coords": [[[556.0, 1385.0], [590.0, 1385.0], [590.0, 1504.0], [556.0, 1504.0]], [[515.0, 1382.0], [556.0, 1382.0], [556.0, 1490.0], [515.0, 1490.0]]], "lines": ["ハメハメ", "したい。"]}], "img_path": "011.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [371, 0, 778, 932], "vertical": false, "font_size": 410.5, "lines_coords": [[[445.0, 0.0], [778.0, 57.0], [707.0, 434.0], [375.0, 371.0]], [[371.0, 500.0], [595.0, 457.0], [678.0, 890.0], [454.0, 932.0]]], "lines": ["ぐっ", "うーんいっ"]}, {"box": [871, 987, 928, 1203], "vertical": true, "font_size": 24, "lines_coords": [[[900.0, 987.0], [926.0, 987.0], [928.0, 1170.0], [901.0, 1170.0]], [[871.0, 989.0], [893.0, 989.0], [893.0, 1196.0], [871.0, 1196.0]]], "lines": ["誰とだっつーの", "っていう話ですが、"]}, {"box": [415, 1006, 539, 1238], "vertical": true, "font_size": 24, "lines_coords": [[[514.0, 1009.0], [535.0, 1009.0], [535.0, 1185.0], [514.0, 1185.0]], [[481.0, 1009.0], [503.0, 1009.0], [503.0, 1139.0], [481.0, 1139.0]], [[446.0, 1006.0], [473.0, 1006.0], [475.0, 1237.0], [448.0, 1237.0]], [[415.0, 1007.0], [442.0, 1007.0], [442.0, 1193.0], [415.0, 1193.0]]], "lines": ["春らしい陽気に", "誘われてか、", "街全体が浮かれてる", "ような気がして、"]}, {"box": [209, 1007, 301, 1226], "vertical": true, "font_size": 26, "lines_coords": [[[273.0, 1010.0], [300.0, 1010.0], [300.0, 1112.0], [273.0, 1112.0]], [[242.0, 1009.0], [268.0, 1009.0], [268.0, 1189.0], [242.0, 1189.0]], [[209.0, 1007.0], [235.0, 1007.0], [237.0, 1221.0], [210.0, 1221.0]]], "lines": ["なんだか", "ブンブンは少し", "嫌気がさしました。"]}, {"box": [98, 1343, 192, 1509], "vertical": true, "font_size": 28, "lines_coords": [[[162.0, 1343.0], [190.0, 1343.0], [190.0, 1481.0], [162.0, 1481.0]], [[131.0, 1345.0], [159.0, 1345.0], [159.0, 1475.0], [131.0, 1475.0]], [[98.0, 1343.0], [126.0, 1343.0], [128.0, 1507.0], [100.0, 1507.0]]], "lines": ["けれど基本、", "プンプンは", "終始一貫して、"]}], "img_path": "012.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [861, 107, 951, 287], "vertical": true, "font_size": 25, "lines_coords": [[[925.0, 107.0], [951.0, 107.0], [951.0, 287.0], [925.0, 287.0]], [[892.0, 107.0], [918.0, 107.0], [918.0, 262.0], [892.0, 262.0]], [[862.0, 109.0], [884.0, 109.0], [884.0, 245.0], [862.0, 245.0]]], "lines": ["ぽっかりと穴が", "空いたような", "気分でした。"]}], "img_path": "013.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [770, 78, 801, 235], "vertical": true, "font_size": 30, "lines_coords": [[[773.0, 78.0], [801.0, 78.0], [798.0, 235.0], [770.0, 235.0]]], "lines": ["．．．ふーーん．．"]}, {"box": [665, 162, 726, 296], "vertical": true, "font_size": 30, "lines_coords": [[[700.0, 165.0], [726.0, 165.0], [726.0, 296.0], [700.0, 296.0]], [[665.0, 162.0], [700.0, 162.0], [700.0, 248.0], [665.0, 248.0]]], "lines": ["合格したん", "だ．．．"]}, {"box": [82, 54, 375, 81], "vertical": false, "font_size": 27, "lines_coords": [[[82.0, 54.0], [375.0, 54.0], [375.0, 81.0], [82.0, 81.0]]], "lines": ["おやすみプンプン回"]}, {"box": [125, 291, 197, 621], "vertical": true, "font_size": 23, "lines_coords": [[[167.0, 293.0], [193.0, 293.0], [193.0, 404.0], [167.0, 404.0]], [[157.0, 484.0], [179.0, 484.0], [179.0, 609.0], [157.0, 609.0]], [[126.0, 484.0], [148.0, 484.0], [148.0, 621.0], [126.0, 621.0]]], "lines": ["．．．あんた、", "ホントに頭", "いいんだね。"]}, {"box": [820, 784, 878, 914], "vertical": true, "font_size": 28, "lines_coords": [[[851.0, 787.0], [878.0, 787.0], [878.0, 914.0], [851.0, 914.0]], [[820.0, 784.0], [848.0, 784.0], [848.0, 857.0], [820.0, 857.0]]], "lines": ["．．．ほんじゃ", "まァー"]}, {"box": [751, 975, 814, 1165], "vertical": true, "font_size": 28, "lines_coords": [[[779.0, 978.0], [810.0, 978.0], [814.0, 1165.0], [782.0, 1165.0]], [[751.0, 975.0], [778.0, 975.0], [778.0, 1132.0], [751.0, 1132.0]]], "lines": ["一応、めでたいっ", "つーことで！！"]}, {"box": [179, 1204, 307, 1387], "vertical": true, "font_size": 28, "lines_coords": [[[279.0, 1207.0], [306.0, 1207.0], [306.0, 1334.0], [279.0, 1334.0]], [[246.0, 1207.0], [275.0, 1207.0], [275.0, 1312.0], [246.0, 1312.0]], [[215.0, 1206.0], [242.0, 1206.0], [242.0, 1387.0], [215.0, 1387.0]], [[184.0, 1204.0], [212.0, 1204.0], [207.0, 1337.0], [179.0, 1337.0]]], "lines": ["回ってない", "寿司でも", "食い散らかしに", "行くーー！？"]}], "img_path": "014.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "015.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [926, 53, 970, 125], "vertical": true, "font_size": 32, "lines_coords": [[[931.0, 53.0], [970.0, 56.0], [967.0, 125.0], [926.0, 123.0]]], "lines": ["．．．あ"]}, {"box": [821, 89, 881, 242], "vertical": true, "font_size": 32, "lines_coords": [[[853.0, 89.0], [881.0, 89.0], [881.0, 215.0], [853.0, 215.0]], [[821.0, 89.0], [848.0, 89.0], [848.0, 242.0], [821.0, 242.0]]], "lines": ["．．．プンプン", "おかえり．．．"]}, {"box": [579, 115, 640, 232], "vertical": true, "font_size": 28, "lines_coords": [[[612.0, 117.0], [640.0, 117.0], [640.0, 226.0], [612.0, 226.0]], [[579.0, 115.0], [607.0, 115.0], [609.0, 232.0], [581.0, 232.0]]], "lines": ["．．．．．．わぁ、", "合格だぁ。"]}, {"box": [525, 306, 562, 492], "vertical": true, "font_size": 27, "lines_coords": [[[525.0, 307.0], [551.0, 306.0], [562.0, 489.0], [535.0, 490.0]]], "lines": ["入学手続き書を中"]}, {"box": [73, 48, 368, 76], "vertical": false, "font_size": 26, "lines_coords": [[[73.0, 50.0], [368.0, 48.0], [368.0, 75.0], [73.0, 76.0]]], "lines": ["おやすみプンプン国"]}, {"box": [425, 465, 485, 648], "vertical": true, "font_size": 25, "lines_coords": [[[454.0, 465.0], [482.0, 465.0], [484.0, 634.0], [456.0, 634.0]], [[426.0, 470.0], [448.0, 470.0], [448.0, 584.0], [426.0, 584.0]]], "lines": ["すごぉーい、", "おめでとー"]}, {"box": [100, 545, 160, 686], "vertical": true, "font_size": 24, "lines_coords": [[[131.0, 545.0], [157.0, 545.0], [157.0, 657.0], [131.0, 657.0]], [[100.0, 545.0], [123.0, 545.0], [126.0, 684.0], [103.0, 684.0]]], "lines": ["．．．お祝い", "しなきゃね。"]}, {"box": [862, 1182, 892, 1324], "vertical": true, "font_size": 27, "lines_coords": [[[862.0, 1182.0], [889.0, 1182.0], [889.0, 1318.0], [862.0, 1318.0]]], "lines": ["プンプンは"]}, {"box": [142, 1309, 232, 1439], "vertical": true, "font_size": 25, "lines_coords": [[[203.0, 1309.0], [229.0, 1309.0], [229.0, 1439.0], [203.0, 1439.0]], [[171.0, 1309.0], [198.0, 1309.0], [198.0, 1414.0], [171.0, 1414.0]], [[142.0, 1310.0], [164.0, 1310.0], [164.0, 1420.0], [142.0, 1420.0]]], "lines": ["この春から", "高校生に", "なります。"]}], "img_path": "016.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [766, 825, 880, 903], "vertical": false, "f