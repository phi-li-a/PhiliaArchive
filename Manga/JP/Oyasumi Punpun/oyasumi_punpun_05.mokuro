], [242.0, 1262.0]], [[198.0, 1043.0], [232.0, 1043.0], [235.0, 1296.0], [201.0, 1296.0]], [[159.0, 1046.0], [187.0, 1046.0], [187.0, 1187.0], [159.0, 1187.0]]], "lines": ["あぁヤダヤダ", "そのくっだらねェ", "自己愛！！"]}, {"box": [921, 1225, 968, 1307], "vertical": false, "font_size": 82, "lines_coords": [[[921.0, 1225.0], [968.0, 1225.0], [968.0, 1307.0], [921.0, 1307.0]]], "lines": ["ア！？"]}, {"box": [731, 1222, 937, 1535], "vertical": true, "font_size": 39, "lines_coords": [[[868.0, 1240.0], [906.0, 1240.0], [906.0, 1442.0], [868.0, 1442.0]], [[821.0, 1240.0], [859.0, 1240.0], [859.0, 1503.0], [821.0, 1503.0]], [[778.0, 1242.0], [817.0, 1242.0], [812.0, 1506.0], [773.0, 1506.0]], [[731.0, 1239.0], [773.0, 1239.0], [773.0, 1535.0], [731.0, 1535.0]]], "lines": ["「繊細な心を", "傷つけられた僕」", "って顔、いっつも", "しやがってからに！！"]}, {"box": [116, 1342, 255, 1553], "vertical": true, "font_size": 43, "lines_coords": [[[212.0, 1343.0], [251.0, 1343.0], [251.0, 1507.0], [212.0, 1507.0]], [[162.0, 1342.0], [210.0, 1342.0], [210.0, 1510.0], [162.0, 1510.0]], [[117.0, 1343.0], [159.0, 1343.0], [159.0, 1553.0], [117.0, 1553.0]]], "lines": ["オホホホ", "おホホホ", "ゲホゲホ！！"]}], "img_path": "209.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [940, 57, 981, 143], "vertical": true, "font_size": 31, "lines_coords": [[[940.0, 57.0], [981.0, 57.0], [981.0, 143.0], [940.0, 143.0]]], "lines": ["ハァ．．．"]}, {"box": [853, 90, 912, 223], "vertical": true, "font_size": 31, "lines_coords": [[[885.0, 93.0], [912.0, 93.0], [912.0, 223.0], [885.0, 223.0]], [[853.0, 90.0], [879.0, 90.0], [879.0, 223.0], [853.0, 223.0]]], "lines": ["アンタの顔", "見てると．．．"]}, {"box": [771, 54, 806, 135], "vertical": true, "font_size": 31, "lines_coords": [[[771.0, 54.0], [806.0, 54.0], [806.0, 135.0], [771.0, 135.0]]], "lines": ["ハァ．．．"]}, {"box": [685, 131, 745, 282], "vertical": true, "font_size": 31, "lines_coords": [[[717.0, 131.0], [745.0, 131.0], [745.0, 234.0], [717.0, 234.0]], [[685.0, 131.0], [712.0, 131.0], [7