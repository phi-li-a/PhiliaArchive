0, 445.0], [118.0, 445.0], [118.0, 525.0], [90.0, 525.0]]], "lines": ["．．．こっそりと", "横取りしたん", "です！！"]}, {"box": [271, 745, 298, 850], "vertical": true, "font_size": 24, "lines_coords": [[[271.0, 745.0], [298.0, 745.0], [298.0, 850.0], [271.0, 850.0]]], "lines": ["僕は．．．"]}, {"box": [818, 789, 878, 954], "vertical": true, "font_size": 30, "lines_coords": [[[850.0, 790.0], [878.0, 790.0], [878.0, 893.0], [850.0, 893.0]], [[818.0, 789.0], [845.0, 789.0], [845.0, 954.0], [818.0, 954.0]]], "lines": ["今の僕の", "彼女なんです。"]}, {"box": [856, 1082, 989, 1289], "vertical": true, "font_size": 25, "lines_coords": [[[967.0, 1082.0], [989.0, 1082.0], [989.0, 1196.0], [967.0, 1196.0]], [[940.0, 1084.0], [962.0, 1084.0], [962.0, 1289.0], [940.0, 1289.0]], [[912.0, 1084.0], [934.0, 1084.0], [934.0, 1279.0], [912.0, 1279.0]], [[884.0, 1082.0], [906.0, 1082.0], [906.0, 1245.0], [884.0, 1245.0]], [[856.0, 1084.0], [878.0, 1084.0], [878.0, 1223.0], [856.0, 1223.0]]], "lines": ["．．．ても彼は", "その事実を知っても", "決して、僕に怒りを", "ぶつけたりしま", "せんでした．．．"]}, {"box": [464, 1064, 494, 1205], "vertical": true, "font_size": 26, "lines_coords": [[[464.0, 1078.0], [490.0, 1078.0], [493.0, 1181.0], [467.0, 1181.0]]], "lines": ["の夏、本"]}, {"box": [143, 809, 231, 998], "vertical": true, "font_size": 24, "lines_coords": [[[204.0, 809.0], [231.0, 809.0], [231.0, 990.0], [204.0, 990.0]], [[175.0, 810.0], [196.0, 810.0], [196.0, 989.0], [175.0, 989.0]], [[143.0, 810.0], [165.0, 810.0], [165.0, 998.0], [143.0, 998.0]]], "lines": ["今回の一件まで", "彼にそのことを", "隠してたんです。"]}, {"box": [795, 1309, 893, 1495], "vertical": true, "font_size": 25, "lines_coords": [[[867.0, 1312.0], [893.0, 1312.0], [893.0, 1443.0], [867.0, 1443.0]], [[826.0, 1310.0], [857.0, 1310.0], [857.0, 1495.0], [826.0, 1495.0]], [[795.0, 1309.0], [829.0, 1309.0], [829.0, 1392.0], [795.0, 1392.0]]], "lines": ["何も言わず", "ただ俯くばかり", "て．．．．．"]}, {"box": [159, 1131, 218, 1285], "vertical": true, "font_size": 25, "lines_coords": [[[192.0, 1131.0], [218.0, 1131.0], [218.0, 1259.0], 