, [[3263.0, 948.0], [3605.0, 941.0], [3605.0, 984.0], [3263.0, 992.0]], [[3328.0, 982.0], [3711.0, 975.0], [3711.0, 1019.0], [3328.0, 1026.0]], [[3267.0, 1016.0], [3806.0, 1016.0], [3806.0, 1060.0], [3267.0, 1060.0]], [[3290.0, 1066.0], [3779.0, 1066.0], [3779.0, 1098.0], [3290.0, 1098.0]], [[3286.0, 1096.0], [3783.0, 1096.0], [3783.0, 1140.0], [3286.0, 1140.0]], [[3293.0, 1130.0], [3381.0, 1130.0], [3381.0, 1151.0], [3293.0, 1151.0]]], "lines": ["おやすみプンプン", "浅野いにお半眠いにも", "．．．ソラニン、全２巻", "茂野いにの浅野ハにお言葉のキス", "コポントの福音全４巻", "茂封いにの高橋留美子川口聖織", "「ハンドッツ曲目、エチョローコトー診療所、１〜２０巻", "高岡由大・山田貴敏", "しかし、一般的な日本ＮＥＯＮ－三金大原のもとにそれでは、１～２０巻－安部康二ノ補崎正澄", "鉄腕バーディー全２０１７年１０巻", "はーーゆうきまさみ", "このつきまさみ室積光ノ猪熊しのぶ", "歌成人、都立水商】全２Ｐ巻", "都立小学生のクロサギ、全２０巻", "黒丸ノ夏原武", "クロサキ、エイムをイキガミアＴＶＥＩＮＥＲＥＬＩＮＴＴＥＬＴＥＴＴ－１１一黒丸／夏原・武・日巻一間瀬元朗", "イヤだった、Ｕｎｕｔｕｒｕｎｉｎｔｅｒも、１９８１年１０月１７日（水）のお部屋のお客さんがメンバング全時－投稿させさせていただけです。ＣＤＥＳＴシステップリステーマートを", "延無メイン取りのログは１５オッズーキ７巻", "Ｌｕｂｅｒメット・キャリをさらに「バローム」の提出会いは、", "今ナトルのホントロームページのタナトスなしからの時、全日巻・主「ご竹原慎二ノ落合裕介", "どのようなものが、エレゼとめはねっ！！鈴里高校春道部－１０月１１日（日）１〜５巻一河合克敏", "ビーチスターズ全７巻", "森尾正博", "ビーナスターへ主ノを逃亡弁護士・成田成１－１－６－Ｐｈｏｎｅｓｔａｍａｚｉｎｓｅｒｓａｓｔｅｒ．髙田優ノ剛英城", "２０１４年１１月２４日火まつりは時の男の子は、全日巻までしかし、「ロロロールズの一木根ヲサムノ国川光太郎", "第３２回ケン・１〜２０１７年１１月３１", "喜国雅彦", "第１３美晴♥ライジング・全５巻", "美味のイージス、全日巻も", "朝のイーンス、主からおあんってあんころ。納得い１日間限度。全５巻くらいでしょ", "あれこち。ＧＯ－ＯＮ！全４巻", "ビビビバト・エ４さトライブ・ア・ライプ全Ｅ巻", "インタグライン・ゴログラウンデーコミックスペシャル・", "絶望に効くクスリ・ひいＥＯＮＯＮＥ全Ｉ５巻一山田玲司", "ｈｔｔｐ：／／ｃｏｍｉｃｓｓｈｏｇａｋｕｋａｎ．ｃｏｊｐ／", "このサイトではＡｍａｚｏｎのコンセプセストコミュニケーショングスが開催しており、オンラインショップで購入することできます。", "オンライン"]}, {"box": [3324, 1226, 3769, 1444], "vertical": false, "font_size": 31, "lines_coords": [[[3449.0, 1226.0], [3631.0, 1226.0], [3631.0, 1268.0], [3449.0, 1268.0]], [[3407.0, 1275.0], [3696.0, 1275.0], [3696.0, 1306.0], [3407.0, 1306.0]], [[3331.0, 1298.0], [3741.0, 1302.0], [3741.0, 1336.0], [3331.0, 1332.0]], [[3377.0, 1328.0], [3707.0, 1328.0], [3707.0, 1359.0], [3377.0, 1359.0]], [[3354.0, 1359.0], [3745.0, 1359.0], [3745.0, 1389.0], [3354.0, 1389.0]], [[3373.0, 1385.0], [3703.0, 1385.0], [3703.0, 1416.0], [3373.0, 1416.0]], [[3343.0, 1408.0], [3749.0, 1404.0], [3749.0, 1438.0], [3343.0, 1442.0]]], "lines": ["浅野いにお", "１９８０年生まれ。茨城県出身。午前１日土、", "２０１７年６月４日土まで、２００１年、第１回サンデーＧ新人賞入賞への", "２０１４年、第１４回、主な番作に「素晴らしい世界はいつでも", "「ひかりのまち」ともに小社刊）がある。小社ＦＩＶが", "「ソレは、「ソラニン（金２巻）小社刊が、同じ中学、お知らせに", "全国より世界が全国なり世代・性別を超えた大阪神経"]}], "img_path": "001.png"}, {"version": "0.2.0-beta.6", "img_width": 3886, "img_height": 1600, "blocks": [{"box": [1624, 391, 1676, 1054], "vertical": true, "font_size": 41, "lines_coords": [[[1628.0, 394.0], [1669.0, 394.0], [1665.0, 1008.0], [1624.0, 1008.0]]], "lines": ["おやすみブンフン●浅野"]}, {"box": [1889, 60, 1984, 876], "vertical": true, "font_size": 76, "lines_coords": [[[1908.0, 60.0], [1984.0, 60.0], [1965.0, 875.0], [1889.0, 875.0]]], "lines": ["認めたやすみプンプン●「浅野にお"]}, {"box": [1681, 1045, 1840, 1120], "vertical": false, "font_size": 82, "lines_coords": [[[1681.0, 1038.0], [1840.0, 1038.0], [1840.0, 1127.0], [1681.0, 1127.0]]], "lines": ["．．．話題作！？毎回目のう第二巻！！"]}, {"box": [1757, 1022, 1857, 1056], "vertical": false, "font_size": 37, "lines_coords": [[[1757.0, 1019.0], [1857.0, 1019.0], [1857.0, 1059.0], [1757.0, 1059.0]]], "lines": ["話題作！！"]}, {"box": [1206, 1412, 1851, 1569], "vertical": false, "font_size": 41, "lines_coords": [[[1218.0, 1418.0], [1844.0, 1418.0], [1844.0, 1462.0], [1218.0, 1462.0]], [[1206.0, 1468.0], [1832.0, 1468.0], [1832.0, 1512.0], [1206.0, 1512.0]], [[1229.0, 1517.0], [1851.0, 1517.0], [1851.0, 1561.0], [1229.0, 1561.0]]], "lines": ["アンフレ早く使っているだってなんと、君と同じだいたい悩みが出たとあるんお願いまだに", "グラグラる心ん中の、アイツ", "の正体についそれで、プンプン"]}, {"box": [1761, 1283, 1863, 1346], "vertical": false, "font_size": 69, "lines_coords": [[[1761.0, 1277.0], [1863.0, 1277.0], [1863.0, 1352.0], [1761.0, 1352.0]]], "lines": ["定価５４０円未体５１４円"]}, {"box": [1897, 1156, 1981, 1502], "vertical": true, "font_size": 49, "lines_coords": [[[1897.0, 1156.0], [1946.0, 1156.0], [1946.0, 1463.0], [1897.0, 1463.0]]], "lines": ["浅野いにお衝撃作り"]}, {"box": [2174, 181, 2280, 212], "vertical": false, "font_size": 27, "l