600, "blocks": [{"box": [878, 637, 905, 804], "vertical": true, "font_size": 26, "lines_coords": [[[878.0, 637.0], [904.0, 637.0], [904.0, 801.0], [878.0, 801.0]]], "lines": ["．．．大好きだよ。"]}, {"box": [889, 1113, 915, 1231], "vertical": true, "font_size": 26, "lines_coords": [[[889.0, 1117.0], [915.0, 1117.0], [915.0, 1225.0], [889.0, 1225.0]]], "lines": ["．．．．．．また"]}, {"box": [179, 1284, 217, 1379], "vertical": true, "font_size": 35, "lines_coords": [[[179.0, 1285.0], [214.0, 1284.0], [217.0, 1378.0], [182.0, 1379.0]]], "lines": ["．．．．．．ね。"]}], "img_path": "092.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [559, 667, 620, 831], "vertical": true, "font_size": 24, "lines_coords": [[[589.0, 667.0], [615.0, 667.0], [615.0, 798.0], [589.0, 798.0]], [[559.0, 670.0], [581.0, 670.0], [581.0, 828.0], [559.0, 828.0]]], "lines": ["フンフンは", "何も言わずに、"]}, {"box": [447, 666, 504, 810], "vertical": true, "font_size": 24, "lines_coords": [[[478.0, 667.0], [504.0, 667.0], [504.0, 798.0], [478.0, 798.0]], [[448.0, 670.0], [470.0, 670.0], [470.0, 804.0], [448.0, 804.0]]], "lines": ["そっと扉を", "閉めました。"]}, {"box": [765, 1325, 826, 1566], "vertical": true, "font_size": 26, "lines_coords": [[[800.0, 1328.0], [826.0, 1328.0], [826.0, 1481.0], [800.0, 1481.0]], [[765.0, 1325.0], [792.0, 1325.0], [793.0, 1564.0], [767.0, 1564.0]]], "lines": ["何か一言でも", "漏らしてしまったら、"]}, {"box": [515, 1325, 641, 1531], "vertical": true, "font_size": 27, "lines_coords": [[[612.0, 1326.0], [640.0, 1326.0], [640.0, 1431.0], [612.0, 1431.0]], [[581.0, 1328.0], [607.0, 1328.0], [607.0, 1481.0], [581.0, 1481.0]], [[550.0, 1326.0], [576.0, 1326.0], [576.0, 1531.0], [550.0, 1531.0]], [[515.0, 1325.0], [542.0, 1325.0], [545.0, 1492.0], [518.0, 1492.0]]], "lines": ["いろんな", "大切なものが", "消えてなくなって", "しまいそうで、"]}, {"box": [296, 1325, 423, 1506], "vertical": true, "font_size": 27, "lines_coords": [[[395.0, 1326.0], [421.0, 1326.0], [421.0, 1457.0], [395.0, 1457.0]], [[364.0, 1325.0], [390.