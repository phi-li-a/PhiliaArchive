45.0, 1159.0], [318.0, 1159.0]]], "lines": ["まるで", "やる気が"]}, {"box": [134, 1412, 160, 1515], "vertical": true, "font_size": 22, "lines_coords": [[[134.0, 1412.0], [160.0, 1412.0], [160.0, 1515.0], [134.0, 1515.0]]], "lines": ["出ないな"]}, {"box": [107, 1459, 125, 1487], "vertical": true, "font_size": 22, "lines_coords": [[[107.0, 1459.0], [125.0, 1459.0], [125.0, 1487.0], [107.0, 1487.0]]], "lines": ["．．．"]}], "img_path": "069.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [832, 79, 1020, 387], "vertical": true, "font_size": 25, "lines_coords": [[[998.0, 81.0], [1020.0, 81.0], [1020.0, 204.0], [998.0, 204.0]], [[968.0, 82.0], [990.0, 82.0], [990.0, 264.0], [968.0, 264.0]], [[939.0, 79.0], [965.0, 79.0], [962.0, 220.0], [935.0, 220.0]], [[910.0, 79.0], [937.0, 79.0], [937.0, 206.0], [910.0, 206.0]], [[887.0, 195.0], [915.0, 195.0], [912.0, 293.0], [884.0, 293.0]], [[857.0, 196.0], [884.0, 196.0], [887.0, 375.0], [860.0, 375.0]], [[832.0, 198.0], [853.0, 198.0], [853.0, 384.0], [832.0, 384.0]]], "lines": ["．．．そうそう。", "この前プンプンが", "ココでケーキ", "食べてた時、", "二人組の", "お客さん、入って", "来たの憶えてる？"]}, {"box": [456, 295, 535, 460], "vertical": true, "font_size": 24, "lines_coords": [[[509.0, 296.0], [535.0, 296.0], [535.0, 396.0], [509.0, 396.0]], [[481.0, 295.0], [507.0, 295.0], [507.0, 460.0], [481.0, 460.0]], [[456.0, 296.0], [478.0, 296.0], [478.0, 423.0], [456.0, 423.0]]], "lines": ["あの人達、", "雑誌の編集の人", "だったんだ。"]}, {"box": [284, 112, 373, 281], "vertical": true, "font_size": 24, "lines_coords": [[[345.0, 112.0], [371.0, 112.0], [371.0, 281.0], [345.0, 281.0]], [[315.0, 115.0], [337.0, 115.0], [337.0, 267.0], [315.0, 267.0]], [[284.0, 115.0], [307.0, 115.0], [307.0, 192.0], [284.0, 192.0]]], "lines": ["．．．けど、なんか", "全然喜べない", "な．．．"]}, {"box": [414, 518, 493, 684], "vertical": true, "font_size": 24, "lines_coords": [[[471.0, 521.0], [493.0, 521.0], [493.0, 648.0], [471.0, 648.0]], [[440.0, 520.0], [467.0, 520.0], [467.0, 684.0], [440.0, 684.0]],