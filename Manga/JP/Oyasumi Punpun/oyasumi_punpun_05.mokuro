140.0], [612.0, 1225.0], [578.0, 1225.0]], [[554.0, 1142.0], [581.0, 1142.0], [581.0, 1237.0], [554.0, 1237.0]]], "lines": ["．．．あ、", "そうだ！！"]}, {"box": [104, 853, 216, 1068], "vertical": true, "font_size": 27, "lines_coords": [[[189.0, 856.0], [215.0, 856.0], [215.0, 1043.0], [189.0, 1043.0]], [[160.0, 856.0], [187.0, 856.0], [187.0, 1068.0], [160.0, 1068.0]], [[132.0, 853.0], [159.0, 853.0], [157.0, 1021.0], [131.0, 1021.0]], [[104.0, 854.0], [131.0, 854.0], [131.0, 975.0], [104.0, 975.0]]], "lines": ["けど私、今すでに", "一人で手一杯だから", "できるのか不安", "てさーー．．．"]}, {"box": [865, 1157, 970, 1351], "vertical": true, "font_size": 24, "lines_coords": [[[948.0, 1157.0], [970.0, 1157.0], [970.0, 1268.0], [948.0, 1268.0]], [[920.0, 1160.0], [946.0, 1160.0], [946.0, 1351.0], [920.0, 1351.0]], [[892.0, 1162.0], [914.0, 1162.0], [914.0, 1328.0], [892.0, 1328.0]], [[865.0, 1164.0], [887.0, 1164.0], [887.0, 1328.0], [865.0, 1328.0]]], "lines": ["なにそれ！", "ちょっとプンプン", "テキトー過ぎん", "じゃないのー？"]}, {"box": [665, 1373, 775, 1537], "vertical": true, "font_size": 22, "lines_coords": [[[751.0, 1375.0], [773.0, 1375.0], [773.0, 1512.0], [751.0, 1512.0]], [[720.0, 1373.0], [746.0, 1373.0], [746.0, 1537.0], [720.0, 1537.0]], [[695.0, 1373.0], [715.0, 1373.0], [715.0, 1534.0], [695.0, 1534.0]], [[667.0, 1373.0], [689.0, 1373.0], [687.0, 1512.0], [665.0, 1512.0]]], "lines": ["そりゃ、人間", "やろうと思えば", "なんでもできる", "けどォ～～．．．"]}, {"box": [145, 1210, 232, 1353], "vertical": true, "font_size": 26, "lines_coords": [[[204.0, 1214.0], [232.0, 1214.0], [232.0, 1309.0], [204.0, 1309.0]], [[176.0, 1214.0], [203.0, 1214.0], [203.0, 1353.0], [176.0, 1353.0]], [[145.0, 1210.0], [178.0, 1210.0], [178.0, 1295.0], [145.0, 1295.0]]], "lines": ["春休みの", "間だけでいい", "からさ、"]}, {"box": [84, 1387, 167, 1531], "vertical": true, "font_size": 26, "lines_coords": [[[140.0, 1389.0], [167.0, 1389.0], [167.0, 1507.0], [140.0, 1507.0]], [[115.0, 1390.0], [137.0, 1390.0], [137.0, 1529.0], [115.0, 1529.0]], [[85.0, 1387.0], [107.0, 1387.0], [106.0, 1531.0], [84.0, 1531.0]]], "lines": ["プンプンに", "お店手伝って", "もらおうか．．"]}], "img_path": "065.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [926, 168, 953, 277], "vertical": true, "font_size": 27, "lines_coords": [[[926.0, 192.0], [953.0, 192.0], [953.0, 276.0], [926.0, 276.0]]], "lines": ["．．．な．．．"]}, {"box": [176, 421, 203, 527], "vertical": true, "font_size": 27, "lines_coords": [[[176.0, 421.0], [203.0, 421.0], [203.0, 525.0], [176.0, 525.0]]], "lines": ["え．．．．．？"]}, {"box": [879, 1111, 946, 1459], "vertical": true, "font_size": 36, "lines_coords": [[[914.0, 1114.0], [946.0, 1114.0], [946.0, 1209.0], [914.0, 1209.0]], [[879.0, 1307.0], [918.0, 1306.0], [926.0, 1457.0], [887.0, 1459.0]]], "lines": ["あ．．．", "．．．ゆっ、"]}, {"box": [137, 1292, 212, 1556], "vertical": true, "font_size": 70, "lines_coords": [[[142.0, 1292.0], [212.0, 1293.0], [207.0, 1556.0], [137.0, 1554.0]]], "lines": ["雄一君っ！！"]}], "img_path": "066.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [229, 707, 343, 735], "vertical": false, "font_size": 28, "lines_coords": [[[229.0, 707.0], [343.0, 707.0], [343.0, 735.0], [229.0, 735.0]]], "lines": ["上手く、"]}, {"box": [625, 1017, 657, 1101], "vertical": true, "font_size": 29, "lines_coords": [[[625.0, 1017.0], [657.0, 1017.0], [657.0, 1101.0], [625.0, 1101.0]]], "lines": ["あ．．．"]}, {"box": [578, 1054, 604, 1185], "vertical": true, "font_size": 29, "lines_coords": [[[578.0, 1054.0], [604.0, 1054.0], [604.0, 1185.0], [578.0, 1185.0]]], "lines": ["すみません"]}, {"box": [107, 1112, 169, 1251], "vertical": true, "font_size": 27, "lines_coords": [[[140.0, 1112.0], [167.0, 1112.0], [167.0, 1251.0], [140.0, 1251.0]], [[107.0, 1112.0], [134.0, 1112.0], [134.0, 1239.0], [107.0, 1239.0]]], "lines": ["全然、人違い", "でした．．．．．"]}, {"box": [757, 1425, 921, 1537], "vertical": false, "font_size": 62, "lines_coords": [[[764.0, 1425.0], [879.0, 1425.0], [879.0, 1492.0], [764.0, 1492.0]], [[757.0, 1468.0], 