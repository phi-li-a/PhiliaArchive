6.0], [142.0, 1296.0], [139.0, 1503.0], [112.0, 1503.0]], [[82.0, 1296.0], [110.0, 1296.0], [106.0, 1459.0], [78.0, 1459.0]]], "lines": ["相手の女性は、僕の", "職場の陶芸教室に", "通っていた３０歳の", "既婚者でした。"]}], "img_path": "042.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [839, 109, 964, 293], "vertical": true, "font_size": 28, "lines_coords": [[[935.0, 110.0], [964.0, 110.0], [960.0, 275.0], [932.0, 275.0]], [[903.0, 109.0], [934.0, 109.0], [934.0, 293.0], [903.0, 293.0]], [[873.0, 109.0], [900.0, 109.0], [896.0, 290.0], [870.0, 290.0]], [[840.0, 109.0], [867.0, 109.0], [865.0, 290.0], [839.0, 290.0]]], "lines": ["．．．一悶着の末、", "向こうの夫妻は", "今、離婚協議中", "なんですが．．．"]}, {"box": [281, 157, 389, 345], "vertical": true, "font_size": 25, "lines_coords": [[[365.0, 159.0], [389.0, 159.0], [387.0, 317.0], [364.0, 317.0]], [[339.0, 159.0], [360.0, 159.0], [360.0, 345.0], [339.0, 345.0]], [[309.0, 157.0], [332.0, 157.0], [331.0, 323.0], [307.0, 323.0]], [[281.0, 157.0], [309.0, 157.0], [309.0, 239.0], [281.0, 239.0]]], "lines": ["あちらの旦那は", "プライドをひどく", "傷つけられたと", "言って、"]}, {"box": [926, 678, 978, 856], "vertical": true, "font_size": 23, "lines_coords": [[[956.0, 679.0], [978.0, 679.0], [978.0, 832.0], [956.0, 832.0]], [[926.0, 678.0], [946.0, 678.0], [946.0, 856.0], [926.0, 856.0]]], "lines": ["こう言ったら", "なんですけど．．．"]}, {"box": [185, 367, 275, 546], "vertical": true, "font_size": 25, "lines_coords": [[[246.0, 367.0], [275.0, 367.0], [275.0, 496.0], [246.0, 496.0]], [[215.0, 367.0], [242.0, 367.0], [242.0, 525.0], [215.0, 525.0]], [[185.0, 367.0], [207.0, 367.0], [207.0, 546.0], [185.0, 546.0]]], "lines": ["僕に２００万の", "慰謝料を請求", "してきました．．"]}, {"box": [793, 729, 882, 910], "vertical": true, "font_size": 23, "lines_coords": [[[856.0, 729.0], [882.0, 729.0], [882.0, 870.0], [856.0, 870.0]], [[823.0, 729.0], [850.0, 729.0], [850.0, 910.0], [823.0, 910.0]], [[793.0, 732.0], [815.0, 732.0], [815.0, 867.0], [793.0, 867.0]]], "lines": ["僕は、自分の", "理性を過信して", "いたんてす"]}, {"box": [637, 993, 670, 1100], "vertical": true, "font_size": 28, "lines_coords": [[[637.0, 993.0], [670.0, 993.0], [670.0, 1100.0], [637.0, 1100.0]]], "lines": ["けど．．．"]}, {"box": [512, 1032, 603, 1187], "vertical": true, "font_size": 28, "lines_coords": [[[576.0, 1034.0], [603.0, 1034.0], [603.0, 1139.0], [576.0, 1139.0]], [[543.0, 1032.0], [570.0, 1032.0], [570.0, 1187.0], [543.0, 1187.0]], [[512.0, 1032.0], [539.0, 1032.0], [539.0, 1137.0], [512.0, 1137.0]]], "lines": ["スケベな", "女性だったん", "ですね？"]}, {"box": [165, 715, 281, 928], "vertical": true, "font_size": 24, "lines_coords": [[[254.0, 715.0], [281.0, 715.0], [276.0, 904.0], [250.0, 904.0]], [[220.0, 717.0], [243.0, 717.0], [242.0, 910.0], [218.0, 910.0]], [[192.0, 715.0], [217.0, 715.0], [214.0, 928.0], [189.0, 928.0]], [[165.0, 717.0], [187.0, 717.0], [187.0, 926.0], [165.0, 926.0]]], "lines": ["心に決めた女性が", "側にいるんだから、", "二度と心が浮わつく", "ことはないんだって。"]}, {"box": [935, 1312, 962, 1417], "vertical": true, "font_size": 27, "lines_coords": [[[935.0, 1312.0], [962.0, 1312.0], [962.0, 1415.0], [935.0, 1415.0]]], "lines": ["けど．．．"]}, {"box": [84, 1282, 227, 1573], "vertical": true, "font_size": 42, "lines_coords": [[[187.0, 1284.0], [225.0, 1284.0], [225.0, 1453.0], [187.0, 1453.0]], [[134.0, 1285.0], [178.0, 1285.0], [178.0, 1573.0], [134.0, 1573.0]], [[84.0, 1282.0], [129.0, 1282.0], [129.0, 1410.0], [84.0, 1410.0]]], "lines": ["恐ろしく", "スケベだったん", "です！！"]}], "img_path": "043.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [871, 114, 901, 235], "vertical": true, "font_size": 26, "lines_coords": [[[871.0, 114.0], [898.0, 114.0], [901.0, 235.0], [875.0, 235.0]]], "lines": ["それはァー"]}, {"box": [765, 235, 821, 354], "vertical": true, "font_size": 26, "lines_coords": [[[793.0, 235.0], [821.0, 235.0], [821.0, 340.0], [793.0, 340.0]], [[765.0, 237.0], [787.0, 237.0], [787.0, 354.0], [765.0, 354.0]]], "lines": ["仕方ない", "ですよね。"]}, {"box": [521, 118, 643, 353], "vertical": true, "font_size": 2