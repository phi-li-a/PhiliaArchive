0, 934.0], [184.0, 1064.0], [157.0, 1064.0]]], "lines": ["．．．自由で！！"]}, {"box": [863, 1201, 952, 1331], "vertical": true, "font_size": 23, "lines_coords": [[[928.0, 1203.0], [950.0, 1203.0], [950.0, 1329.0], [928.0, 1329.0]], [[893.0, 1201.0], [920.0, 1201.0], [920.0, 1331.0], [893.0, 1331.0]], [[864.0, 1203.0], [885.0, 1203.0], [885.0, 1329.0], [864.0, 1329.0]]], "lines": ["そんな姉に", "情けをかけ", "られて．．．"]}, {"box": [131, 1301, 255, 1484], "vertical": true, "font_size": 25, "lines_coords": [[[229.0, 1304.0], [251.0, 1304.0], [251.0, 1432.0], [229.0, 1432.0]], [[195.0, 1303.0], [221.0, 1303.0], [221.0, 1484.0], [195.0, 1484.0]], [[162.0, 1301.0], [189.0, 1301.0], [189.0, 1471.0], [162.0, 1471.0]], [[131.0, 1303.0], [157.0, 1303.0], [157.0, 1459.0], [131.0, 1459.0]]], "lines": ["こんなにも", "胸が苦しくなる", "なんて、思わな", "かった．．．．．！！"]}], "img_path": "044.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [934, 701, 996, 831], "vertical": true, "font_size": 27, "lines_coords": [[[967.0, 701.0], [995.0, 701.0], [996.0, 831.0], [968.0, 831.0]], [[934.0, 701.0], [968.0, 701.0], [968.0, 790.0], [934.0, 790.0]]], "lines": ["僕の唯一の", "友人に、"]}, {"box": [807, 748, 896, 928], "vertical": true, "font_size": 27, "lines_coords": [[[870.0, 748.0], [896.0, 748.0], [896.0, 928.0], [870.0, 928.0]], [[837.0, 748.0], [864.0, 748.0], [864.0, 904.0], [837.0, 904.0]], [[807.0, 753.0], [829.0, 753.0], [829.0, 885.0], [807.0, 885.0]]], "lines": ["優しくて優秀な", "弁護士の男が", "いるんです"]}, {"box": [909, 1017, 997, 1225], "vertical": true, "font_size": 23, "lines_coords": [[[970.0, 1017.0], [996.0, 1017.0], [996.0, 1225.0], [970.0, 1225.0]], [[940.0, 1020.0], [962.0, 1020.0], [962.0, 1221.0], [940.0, 1221.0]], [[909.0, 1018.0], [931.0, 1018.0], [931.0, 1143.0], [909.0, 1143.0]]], "lines": ["．．．けど、まったく", "相手にされません", "てした．．．"]}, {"box": [575, 1004, 603, 1185], "vertical": true, "font_size": 27, "lines_coords": [[[576.0, 1004.0], [603.0, 1004.0], [601.0, 1185.0], [575.0, 1185.0]]], "lines": ["ご友人なのに？"]}, {"box": [470, 1098, 528, 1203], "vertical": true, "font_size": 27, "lines_coords": [[[500.0, 1098.0], [528.0, 1098.0], [528.0, 1203.0], [500.0, 1203.0]], [[470.0, 1098.0], [496.0, 1098.0], [496.0, 1203.0], [470.0, 1203.0]]], "lines": ["．．．それは", "ひどい！！"]}, {"box": [250, 710, 378, 923], "vertical": true, "font_size": 27, "lines_coords": [[[351.0, 715.0], [378.0, 715.0], [378.0, 896.0], [351.0, 896.0]], [[318.0, 715.0], [345.0, 715.0], [345.0, 923.0], [318.0, 923.0]], [[284.0, 712.0], [310.0, 712.0], [314.0, 870.0], [287.0, 870.0]], [[253.0, 710.0], [285.0, 712.0], [282.0, 801.0], [250.0, 800.0]]], "lines": ["．．．いや、決して", "訴訟に持ち込もう", "とした訳では", "なくて、"]}, {"box": [115, 764, 237, 946], "vertical": true, "font_size": 27, "lines_coords": [[[207.0, 765.0], [235.0, 765.0], [237.0, 895.0], [209.0, 895.0]], [[178.0, 764.0], [204.0, 764.0], [204.0, 946.0], [178.0, 946.0]], [[150.0, 767.0], [171.0, 767.0], [171.0, 945.0], [150.0, 945.0]], [[115.0, 767.0], [142.0, 767.0], [142.0, 868.0], [115.0, 868.0]]], "lines": ["純粋に友人", "としての意見を", "聞きたかったん", "てす．．．．．．"]}, {"box": [670, 1350, 758, 1530], "vertical": true, "font_size": 23, "lines_coords": [[[731.0, 1350.0], [757.0, 1350.0], [757.0, 1456.0], [731.0, 1456.0]], [[703.0, 1351.0], [725.0, 1351.0], [725.0, 1529.0], [703.0, 1529.0]], [[671.0, 1351.0], [693.0, 1351.0], [693.0, 1485.0], [671.0, 1485.0]]], "lines": ["２回ほど", "会いましたけど", "無駄でした。"]}, {"box": [235, 1370, 270, 1462], "vertical": true, "font_size": 29, "lines_coords": [[[235.0, 1370.0], [270.0, 1370.0], [270.0, 1462.0], [235.0, 1462.0]]], "lines": ["．．．いえ、"]}, {"box": [121, 1398, 179, 1514], "vertical": true, "font_size": 29, "lines_coords": [[[153.0, 1398.0], [179.0, 1398.0], [179.0, 1503.0], [153.0, 1503.0]], [[121.0, 1398.0], [148.0, 1398.0], [148.0, 1514.0], [121.0, 1514.0]]], "lines": ["自業自得", "なんです。"]}], "img_path": "045.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [905, 64, 962, 217], "vertical": true, "fon