], [992.0, 218.0], [965.0, 218.0]], [[935.0, 50.0], [962.0, 50.0], [962.0, 226.0], [935.0, 226.0]], [[904.0, 48.0], [931.0, 48.0], [931.0, 154.0], [904.0, 154.0]]], "lines": ["．．．あ、ゴメン", "名前憶えてない", "よね．．．．．"]}, {"box": [342, 118, 465, 323], "vertical": true, "font_size": 26, "lines_coords": [[[439.0, 118.0], [465.0, 118.0], [460.0, 276.0], [434.0, 276.0]], [[406.0, 118.0], [432.0, 118.0], [429.0, 300.0], [403.0, 300.0]], [[373.0, 120.0], [400.0, 120.0], [400.0, 300.0], [373.0, 300.0]], [[343.0, 120.0], [367.0, 120.0], [365.0, 323.0], [342.0, 323.0]]], "lines": ["．．．小野寺くん", "さっきから全然", "お酒飲まないし", "歌ってないよね？"]}, {"box": [731, 346, 793, 462], "vertical": true, "font_size": 29, "lines_coords": [[[759.0, 346.0], [793.0, 346.0], [793.0, 429.0], [759.0, 429.0]], [[731.0, 348.0], [759.0, 348.0], [759.0, 462.0], [731.0, 462.0]]], "lines": ["Ｃ組の", "蟹江です。"]}, {"box": [679, 504, 740, 662], "vertical": true, "font_size": 29, "lines_coords": [[[712.0, 504.0], [740.0, 504.0], [737.0, 625.0], [709.0, 625.0]], [[679.0, 506.0], [706.0, 506.0], [706.0, 662.0], [679.0, 662.0]]], "lines": ["あたし、影", "うすいから．．．"]}, {"box": [101, 487, 190, 690], "vertical": true, "font_size": 22, "lines_coords": [[[165.0, 487.0], [187.0, 487.0], [187.0, 640.0], [165.0, 640.0]], [[134.0, 487.0], [156.0, 487.0], [156.0, 690.0], [134.0, 690.0]], [[104.0, 509.0], [126.0, 509.0], [123.0, 642.0], [101.0, 642.0]]], "lines": ["もしかしたら", "つまんないのかな", "ーって．．．．．．"]}, {"box": [904, 764, 962, 919], "vertical": true, "font_size": 27, "lines_coords": [[[935.0, 764.0], [962.0, 764.0], [962.0, 879.0], [935.0, 879.0]], [[904.0, 764.0], [931.0, 764.0], [931.0, 918.0], [904.0, 918.0]]], "lines": ["もし、アレ", "だったら．．．"]}, {"box": [173, 989, 234, 1170], "vertical": true, "font_size": 28, "lines_coords": [[[204.0, 993.0], [232.0, 993.0], [232.0, 1100.0], [204.0, 1100.0]], [[173.0, 989.0], [200.0, 989.0], [200.0, 1170.0], [173.0, 1170.0]]], "lines": ["一緒に店、", "出ちゃわない？"]}, {"box": [254, 1265, 289, 1379], "vertical": true, "font_size": 28, "lines_coords": [[[254.0, 1265.0], [289.0, 1265.0], [289.0, 1379.0], [254.0, 1379.0]]], "lines": ["．．．いや、"]}, {"box": [120, 1337, 212, 1525], "vertical": true, "font_size": 28, "lines_coords": [[[181.0, 1337.0], [207.0, 1337.0], [212.0, 1481.0], [185.0, 1481.0]], [[151.0, 1343.0], [178.0, 1343.0], [178.0, 1498.0], [151.0, 1498.0]], [[120.0, 1340.0], [142.0, 1340.0], [145.0, 1525.0], [123.0, 1525.0]]], "lines": ["こんなこと、", "今更なのかも", "しんねーけどさ。"]}], "img_path": "182.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [948, 64, 998, 210], "vertical": true, "font_size": 22, "lines_coords": [[[976.0, 65.0], [998.0, 65.0], [998.0, 156.0], [976.0, 156.0]], [[948.0, 64.0], [968.0, 64.0], [968.0, 210.0], [948.0, 210.0]]], "lines": ["．．．なんか", "思い知ったよ。"]}, {"box": [854, 159, 906, 331], "vertical": true, "font_size": 22, "lines_coords": [[[884.0, 159.0], [906.0, 159.0], [906.0, 273.0], [884.0, 273.0]], [[854.0, 159.0], [876.0, 159.0], [879.0, 331.0], [857.0, 331.0]]], "lines": ["色んな人が", "いるんだなって。"]}, {"box": [214, 60, 320, 246], "vertical": true, "font_size": 22, "lines_coords": [[[296.0, 60.0], [318.0, 60.0], [320.0, 225.0], [298.0, 225.0]], [[270.0, 64.0], [292.0, 64.0], [292.0, 225.0], [270.0, 225.0]], [[240.0, 62.0], [262.0, 62.0], [262.0, 246.0], [240.0, 246.0]], [[214.0, 64.0], [235.0, 64.0], [235.0, 192.0], [214.0, 192.0]]], "lines": ["当たり前だけど", "それぞれの人に", "それぞれの人生が", "あるんだよ。"]}, {"box": [112, 221, 220, 432], "vertical": true, "font_size": 22, "lines_coords": [[[195.0, 221.0], [218.0, 221.0], [220.0, 384.0], [196.0, 384.0]], [[165.0, 223.0], [189.0, 223.0], [192.0, 370.0], [168.0, 370.0]], [[139.0, 223.0], [162.0, 223.0], [164.0, 432.0], [140.0, 432.0]], [[112.0, 223.0], [132.0, 223.0], [132.0, 373.0], [112.0, 373.0]]], "lines": ["それが、くだる、", "くだらねーは、", "それぞれ自分で決め", "りゃいいんだ"]}, {"box": [865, 489, 981, 710], "vertical": true, "font_size": 23, "lines_coords": [[[954.0, 490.0], [981.0, 490.0], [981.0, 609.0], [954.0, 609.0]], [[918.0, 