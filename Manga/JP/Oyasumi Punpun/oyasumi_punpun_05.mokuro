0], [217.0, 709.0]], [[214.0, 690.0], [612.0, 646.0], [617.0, 695.0], [218.0, 739.0]], [[220.0, 723.0], [614.0, 689.0], [618.0, 732.0], [225.0, 767.0]], [[228.0, 756.0], [642.0, 721.0], [646.0, 764.0], [232.0, 798.0]], [[231.0, 795.0], [645.0, 759.0], [648.0, 793.0], [234.0, 829.0]]], "lines": ["まずはお客様においては、お客さまとめできましたが、ご", "．．．", "．．．", "それでも、", "それは、", "．．．", "それでも、", "そういうことで、", "．．．", "それでも、", "そういえば、", "それでも、", "事故的に資格を持っていますので、"]}, {"box": [398, 521, 623, 576], "vertical": false, "font_size": 39, "lines_coords": [[[398.0, 537.0], [620.0, 521.0], [623.0, 560.0], [401.0, 576.0]]], "lines": ["．．．"]}, {"box": [417, 609, 559, 635], "vertical": false, "font_size": 26, "lines_coords": [[[417.0, 609.0], [559.0, 609.0], [559.0, 635.0], [417.0, 635.0]]], "lines": ["おはようやいや"]}, {"box": [646, 403, 870, 568], "vertical": false, "font_size": 32.0, "lines_coords": [[[670.0, 414.0], [778.0, 403.0], [781.0, 431.0], [673.0, 442.0]], [[646.0, 446.0], [851.0, 425.0], [854.0, 457.0], [650.0, 479.0]], [[654.0, 476.0], [839.0, 464.0], [840.0, 495.0], [656.0, 507.0]], [[725.0, 504.0], [851.0, 493.0], [854.0, 528.0], [728.0, 539.0]], [[751.0, 535.0], [867.0, 528.0], [870.0, 560.0], [754.0, 568.0]]], "lines": ["．．．", "そして、ここで", "そういうわけで", "いや、やっぱり", "．．．"]}, {"box": [700, 721, 934, 804], "vertical": false, "font_size": 30.5, "lines_coords": [[[740.0, 776.0], [909.0, 765.0], [910.0, 793.0], [742.0, 804.0]], [[700.0, 750.0], [929.0, 721.0], [934.0, 754.0], [704.0, 782.0]]], "lines": ["なぜならば、", "それでも、これからの"]}, {"box": [331, 895, 573, 967], "vertical": false, "font_size": 29.0, "lines_coords": [[[520.0, 932.0], [557.0, 948.0], [551.0, 967.0], [514.0, 951.0]], [[331.0, 918.0], [568.0, 895.0], [573.0, 932.0], [335.0, 956.0]]], "lines": ["あ、", "それは．．．"]}, {"box": [390, 1017, 495, 1050], "vertical": false, "font_size": 29, "lines_coords": [[[390.0, 1021.0], [493.0, 1017.0], [495.0, 1045.0], [392.0, 1050.0]]], "lines": ["．．．"]}, {"box": [359, 1057, 662, 1156], "vertical": false, "font_size": 35.5, "lines_coords": [[[359.0, 1085.0], [657.0, 1057.0], [662.0, 1100.0], [364.0, 1128.0]], [[417.0, 1128.0], [543.0, 1109.0], [548.0, 1137.0], [421.0, 1156.0]]], "lines": ["そういうことで、", "すぐに、"]}], "img_path": "021.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [345, 173, 646, 362], "vertical": false, "font_size": 173, "lines_coords": [[[345.0, 189.0], [637.0, 173.0], [646.0, 346.0], [354.0, 362.0]]], "lines": ["．．．"]}, {"box": [484, 1317, 611, 1525], "vertical": true, "font_size": 28, "lines_coords": [[[581.0, 1320.0], [609.0, 1320.0], [609.0, 1450.0], [581.0, 1450.0]], [[553.0, 1320.0], [575.0, 1320.0], [575.0, 1523.0], [553.0, 1523.0]], [[518.0, 1320.0], [545.0, 1320.0], [545.0, 1525.0], [518.0, 1525.0]], [[484.0, 1317.0], [517.0, 1317.0], [517.0, 1409.0], [484.0, 1409.0]]], "lines": ["フンフンは", "特にこれといった", "感慨は湧きません", "でした。"]}], "img_path": "022.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [121, 256, 167, 362], "vertical": true, "font_size": 19.5, "lines_coords": [[[150.0, 265.0], [167.0, 265.0], [167.0, 334.0], [150.0, 334.0]], [[121.0, 256.0], [143.0, 256.0], [146.0, 362.0], [125.0, 362.0]]], "lines": ["くたくは", "おまなさん"]}, {"box": [504, 231, 526, 334], "vertical": true, "font_size": 22, "lines_coords": [[[504.0, 231.0], [526.0, 231.0], [526.0, 334.0], [504.0, 334.0]]], "lines": ["楽しても"]}, {"box": [193, 1161, 285, 1343], "vertical": true, "font_size": 24, "lines_coords": [[[260.0, 1165.0], [282.0, 1165.0], [282.0, 1339.0], [260.0, 1339.0]], [[228.0, 1164.0], [250.0, 1164.0], [250.0, 1339.0], [228.0, 1339.0]], [[193.0, 1162.0], [221.0, 1162.0], [221.0, 1250.0], [193.0, 1250.0]]], "lines": ["思い残すことも", "特にありません", "でした。"]}], "img_path": "023.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "024.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "025.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "026.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [912, 151, 945, 235], "vertical": true, "font_size": 33, "lines_coords": [[[912.0, 151.0], [945.0, 151.0], [945.0, 235.0], [912.0, 235.0]]], "lines": ["あれ？"]}, {"box": [157, 245, 225, 400], "vertical": true, "font_size": 33, "lines_coords": [[[187.0, 245.0], [220.0, 245.0], [225.0, 400.0], [192.0, 400.0]], [[157.0, 245.0], [190.0, 245.0], [190.0, 364.0], [157.0, 364.0]]], "lines": ["いらっしゃい", "プンプン。"]}, {"box": [881, 537, 942, 718], "vertical": true, "font_size": 26, "lines_coords": [[[914.0, 537.0], [940.0, 537.0], [940.0, 695.0], [914.0, 695.0]], [[881.0, 537.0], [907.0, 537.0], [907.0, 718.0], [881.0, 718.0]]], "lines": ["卒業式、もう", "終わったんだ？"]}, {"box": [600, 1112, 662, 1228], "vertical": true, "font_size": 30, "lines_coords": [[[628.0, 1112.0], [662.0, 1112.0], [662.0, 1198.0], [628.0, 1198.0]], [[600.0, 1112.0], [626.0, 1112.0], [626.0, 1226.0], [600.0, 1226.0]]], "lines": ["．．．卒業", "おめでと。"]}, {"box": [131, 775, 255, 956], "vertical": true, "font_size": 25, "lines_coords": [[[229.0, 778.0], [251.0, 778.0], [251.0, 929.0], [229.0, 929.0]], [[192.0, 778.0], [218.0, 778.0], [221.0, 898.0], [195.0, 898.0]], [[164.0, 776.0], [190.0, 776.0], [190.0, 956.0], [164.0, 956.0]], [[131.0, 775.0], [157.0, 775.0], [157.0, 881.0], [131.0, 881.0]]], "lines": ["ゆっくりして", "いきなよー", "チョコのケーキ", "あるよ？"]}, {"box": [117, 1175, 200, 1496], "vertical": true, "font_size": 26, "lines_coords": [[[171.0, 1175.0], [200.0, 1175.0], [196.0, 1281.0], [168.0, 1281.0]], [[148.0, 1342.0], [175.0, 1342.0], [175.0, 1496.0], [148.0, 1496.0]], [[120.0, 1342.0], [142.0, 1342.0], [142.0, 1454.0], [120.0, 1454.0]]], "lines": ["なんか．．．", "あっという間", "だったね。"]}], "img_path": "027.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [890, 87, 1010, 270], "vertical": true, "font_size": 24, "lines_coords": [[[982.0, 87.0], [1009.0, 87.0], [1007.0, 270.0], [981.0, 270.0]], [[950.0, 90.0], [976.0, 90.0], [975.0, 268.0], [948.0, 268.0]], [[918.0, 87.0], [945.0, 87.0], [943.0, 270.0], [917.0, 270.0]], [[892.0, 93.0], [909.0, 93.0], [909.0, 181.0], [892.0, 181.0]]], "lines": ["私もこの一年は", "お店始めるので", "ドタバタだった", "からなー"]}, {"box": [326, 129, 414, 312], "vertical": true, "font_size": 26, "lines_coords": [[[387.0, 129.0], [414.0, 129.0], [414.0, 268.0], [387.0, 268.0]], [[354.0, 129.0], [381.0, 129.0], [381.0, 284.0], [354.0, 284.0]], [[326.0, 132.0], [350.0, 132.0], [350.0, 182.0], [326.0, 182.0]]], "lines": ["．．．引っ越し、", "もう来週かー", "．．．"]}, {"box": [667, 464, 759, 595], "vertical": true, "font_size": 27, "lines_coords": [[[729.0, 464.0], [757.0, 464.0], [759.0, 581.0], [731.0, 581.0]], [[700.0, 465.0], [726.0, 465.0], [726.0, 595.0], [700.0, 595.0]], [[667.0, 464.0], [695.0, 464.0], [695.0, 550.0], [667.0, 550.0]]], "lines": ["．．．だけど、", "なんか楽し", "かった"]}, {"box": [100, 450, 207, 667], "vertical": true, "font_size": 21, "lines_coords": [[[182.0, 450.0], [204.0, 450.0], [204.0, 612.0], [182.0, 612.0]], [[154.0, 450.0], [176.0, 450.0], [176.0, 656.0], [154.0, 656.0]], [[128.0, 451.0], [148.0, 451.0], [148.0, 667.0], [128.0, 667.0]], [[100.0, 451.0], [120.0, 451.0], [120.0, 576.0], [100.0, 576.0]]], "lines": ["早目に荷物整理", "しなきゃダメだよ？", "プンプン、のんびり屋", "なんだから。"]}, {"box": [867, 748, 985, 933], "vertical": true, "font_size": 21, "lines_coords": [[[950.0, 750.0], [971.0, 750.0], [971.0, 932.0], [950.0, 932.0]], [[921.0, 748.0], [943.0, 748.0], [943.0, 932.0], [921.0, 932.0]], [[895.0, 750.0], [917.0, 750.0], [917.0, 932.0], [895.0, 932.0]], [[867.0, 748.0], [887.0, 748.0], [887.0, 893.0], [867.0, 893.0]]], "lines": ["．．．雄一君の荷物は", "とりあえず大船の", "お家のほうに送る", "ことにしたよ。"]}, {"box": [257, 737, 365, 900], "vertical": true, "font_size": 23, "lines_coords": [[[343.0, 740.0], [365.0, 740.0], [365.0, 878.0], [343.0, 878.0]], [[315.0, 739.0], [337.0, 739.0], [337.0, 876.0], [315.0, 876.0]], [[287.0, 739.0], [309.0, 739.0], [309.0, 900.0], [287.0, 900.0]], [[260.0, 737.0], [284.0, 737.0], [281.0, 854.0], [257.0, 854.0]]], "lines": ["．．．私も当面は", "実家に戻って", "色々考えようか", "なって．．．"]}, {"box": [151, 909, 257, 1167], "vertical": true, "font_size": 23, "lines_coords": [[[235.0, 910.0], [257.0, 910.0], [257.0, 1110.0], [235.0, 1110.0]], [[204.0, 910.0], [231.0, 910.0], [231.0, 1167.0], [204.0, 1167.0]], [[178.0, 910.0], [200.0, 910.0], [200.0, 1117.0], [178.0, 1117.0]], [[151.0, 909.0], [171.0, 909.0], [171.0, 1093.0], [151.0, 1093.0]]], "lines": ["．．．けど、このお店も", "プンプンの引っ越し先も", "自転車で全然行ける", "距離だからね．．．"]}, {"box": [921, 1214, 943, 1371], "vertical": true, "font_size": 22, "lines_coords": [[[921.0, 1214.0], [943.0, 1214.0], [943.0, 1371.0], [921.0, 1371.0]]], "lines": ["お姉さんにも、"]}, {"box": [829, 1310, 851, 1464], "vertical": true, "font_size": 22, "lines_coords": [[[829.0, 1310.0], [851.0, 1310.0], [851.0, 1464.0], [829.0, 1464.0]]], "lines": ["プンプンにも"]}, {"box": [106, 1321, 193, 1503], "vertical": true, "font_size": 27, "lines_coords": [[[167.0, 1323.0], [193.0, 1323.0], [193.0, 1501.0], [167.0, 1501.0]], [[131.0, 1321.0], [162.0, 1321.0], [165.0, 1503.0], [134.0, 1503.0]], [[106.0, 1323.0], [129.0, 1323.0], [129.0, 1400.0], [106.0, 1400.0]]], "lines": ["会おうと思えば", "いつでも会える", "し．．．．．"]}], "img_path": "028.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [225, 334, 252, 447], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 335.0], [251.0, 335.0], [251.0, 446.0], [225.0, 446.0]]], "lines": ["．．．なんて、"]}, {"box": [853, 717, 945, 848], "vertical": true, "font_size": 28, "lines_coords": [[[918.0, 718.0], [945.0, 718.0], [945.0, 825.0], [918.0, 825.0]], [[887.0, 720.0], [914.0, 720.0], [914.0, 848.0], [887.0, 848.0]], [[856.0, 717.0], [884.0, 717.0], [881.0, 823.0], [853.0, 823.0]]], "lines": ["そういう", "距離の問題", "じゃ．．．．．"]}, {"box": [746, 771, 810, 903], "vertical": true, "font_size": 28, "lines_coords": [[[775.0, 771.0], [807.0, 771.0], [810.0, 881.0], [778.0, 881.0]], [[750.0, 773.0], [776.0, 773.0], [773.0, 903.0], [746.0, 903.0]]], "lines": ["ないんだ", "けどさ．．．"]}, {"box": [951, 1029, 978, 1145], "vertical": true, "font_size": 27, "lines_coords": [[[951.0, 1029.0], [978.0, 1029.0], [978.0, 1145.0], [951.0, 1145.0]]], "lines": ["．．．ごめん。"]}, {"box": [626, 1326, 689, 1459], "vertical": true, "font_size": 28, "lines_coords": [[[659.0, 1326.0], [687.0, 1326.0], [689.0, 1442.0], [660.0, 1442.0]], [[629.0, 1328.0], [656.0, 1328.0], [653.0, 1459.0], [626.0, 1459.0]]], "lines": ["ごめんね、", "なんか．．．"]}], "img_path": "029.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [946, 75, 975, 205], "vertical": true, "font_size": 23, "lines_coords": [[[953.0, 168.0], [970.0, 168.0], [970.0, 203.0], [953.0, 203.0]], [[946.0, 75.0], [975.0, 75.0], [975.0, 146.0], [946.0, 146.0]]], "lines": ["．．．", "あのー"]}, {"box": [593, 131, 665, 228], "vertical": true, "font_size": 33, "lines_coords": [[[626.0, 131.0], [665.0, 131.0], [665.0, 228.0], [626.0, 228.0]], [[593.0, 132.0], [632.0, 132.0], [632.0, 218.0], [593.0, 218.0]]], "lines": ["．．．あっ、", "ハイ！！"]}, {"box": [535, 257, 596, 418], "vertical": true, "font_size": 33, "lines_coords": [[[567.0, 259.0], [593.0, 259.0], [596.0, 393.0], [570.0, 393.0]], [[539.0, 257.0], [565.0, 257.0], [562.0, 418.0], [535.0, 418.0]]], "lines": ["ありがとう", "ございます！！"]}, {"box": [126, 145, 183, 301], "vertical": true, "font_size": 24, "lines_coords": [[[156.0, 145.0], [182.0, 145.0], [182.0, 301.0], [156.0, 301.0]], [[126.0, 145.0], [148.0, 145.0], [148.0, 234.0], [126.0, 234.0]]], "lines": ["お好きな席に", "どうぞー"]}, {"box": [681, 545, 774, 726], "vertical": true, "font_size": 26, "lines_coords": [[[746.0, 546.0], [773.0, 546.0], [773.0, 676.0], [746.0, 676.0]], [[714.0, 545.0], [740.0, 545.0], [740.0, 726.0], [714.0, 726.0]], [[682.0, 545.0], [706.0, 545.0], [704.0, 725.0], [681.0, 725.0]]], "lines": ["雑誌で紹介", "されてるの見て", "来たんですが．．．"]}, {"box": [215, 521, 279, 681], "vertical": true, "font_size": 29, "lines_coords": [[[253.0, 525.0], [279.0, 525.0], [279.0, 681.0], [253.0, 681.0]], [[218.0, 521.0], [251.0, 521.0], [248.0, 657.0], [215.0, 657.0]]], "lines": ["．．落ち込んで", "たって．．．"]}, {"box": [115, 618, 175, 725], "vertical": true, "font_size": 29, "lines_coords": [[[146.0, 618.0], [175.0, 618.0], [175.0, 725.0], [146.0, 725.0]], [[115.0, 620.0], [142.0, 620.0], [142.0, 725.0], [115.0, 725.0]]], "lines": ["しょうが", "ないか！！"]}, {"box": [876, 860, 970, 1018], "vertical": true, "font_size": 28, "lines_coords": [[[935.0, 860.0], [970.0, 860.0], [970.0, 946.0], [935.0, 946.0]], [[906.0, 864.0], [932.0, 864.0], [935.0, 995.0], [909.0, 995.0]], [[876.0, 865.0], [900.0, 865.0], [901.0, 1017.0], [878.0, 1017.0]]], "lines": ["．．．今は", "がんばって", "働かなきゃ！"]}, {"box": [145, 996, 236, 1181], "vertical": true, "font_size": 26, "lines_coords": [[[207.0, 1000.0], [234.0, 1000.0], [234.0, 1181.0], [207.0, 1181.0]], [[175.0, 996.0], [203.0, 996.0], [200.0, 1110.0], [171.0, 1110.0]], [[145.0, 1000.0], [167.0, 1000.0], [167.0, 1154.0], [145.0, 1154.0]]], "lines": ["やっと実現した", "夢だもん、", "このお店は！！"]}, {"box": [943, 1303, 970, 1414], "vertical": true, "font_size": 27, "lines_coords": [[[943.0, 1303.0], [970.0, 1303.0], [970.0, 1414.0], [943.0, 1414.0]]], "lines": ["よ～～し"]}, {"box": [807, 1337, 900, 1468], "vertical": true, "font_size": 27, "lines_coords": [[[867.0, 1337.0], [900.0, 1337.0], [900.0, 1421.0], [867.0, 1421.0]], [[837.0, 1339.0], [864.0, 1339.0], [864.0, 1468.0], [837.0, 1468.0]], [[807.0, 1339.0], [829.0, 1339.0], [829.0, 1440.0], [807.0, 1440.0]]], "lines": ["なんか", "やる気出て", "きたぞー"]}, {"box": [165, 1335, 258, 1535], "vertical": true, "font_size": 25, "lines_coords": [[[229.0, 1335.0], [256.0, 1335.0], [256.0, 1467.0], [229.0, 1467.0]], [[200.0, 1339.0], [221.0, 1339.0], [221.0, 1515.0], [200.0, 1515.0]], [[165.0, 1337.0], [192.0, 1337.0], [192.0, 1535.0], [165.0, 1535.0]]], "lines": ["プンプンも", "食べ終わったら", "お店手伝ってね！！"]}], "img_path": "030.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [634, 1, 843, 286], "vertical": false, "font_size": 85, "lines_coords": [[[640.0, 173.0], [843.0, 190.0], [837.0, 275.0], [634.0, 257.0]]], "lines": ["並員"]}, {"box": [858, 1131, 1006, 1182], "vertical": false, "font_size": 56, "lines_coords": [[[858.0, 1126.0], [1006.0, 1126.0], [1006.0, 1187.0], [858.0, 1187.0]]], "lines": ["島山弁護士事務"]}], "img_path": "031.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [109, 68, 392, 95], "vertical": false, "font_size": 27, "lines_coords": [[[109.0, 68.0], [392.0, 68.0], [392.0, 95.0], [109.0, 95.0]]], "lines": ["おやすみプンプンＥ"]}, {"box": [221, 1290, 263, 1432], "vertical": true, "font_size": 33, "lines_coords": [[[221.0, 1290.0], [254.0, 1290.0], [254.0, 1432.0], [221.0, 1432.0]]], "lines": ["．．．．．湯上君。"]}], "img_path": "032.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [928, 82, 954, 237], "vertical": true, "font_size": 26, "lines_coords": [[[928.0, 82.0], [954.0, 82.0], [954.0, 234.0], [928.0, 234.0]]], "lines": ["もうっ．．．．．．！！"]}, {"box": [521, 123, 612, 304], "vertical": true, "font_size": 26, "lines_coords": [[[585.0, 123.0], [612.0, 123.0], [612.0, 256.0], [585.0, 256.0]], [[553.0, 125.0], [579.0, 125.0], [579.0, 281.0], [553.0, 281.0]], [[521.0, 123.0], [545.0, 123.0], [546.0, 304.0], [523.0, 304.0]]], "lines": ["僕のことは", "好きなように", "してくれっ．．．！！"]}, {"box": [154, 598, 214, 806], "vertical": true, "font_size": 28, "lines_coords": [[[185.0, 598.0], [214.0, 598.0], [214.0, 701.0], [185.0, 701.0]], [[154.0, 598.0], [181.0, 598.0], [181.0, 806.0], [154.0, 806.0]]], "lines": ["君の気が", "済むようにっ．．．！！"]}, {"box": [876, 1239, 918, 1356], "vertical": true, "font_size": 28, "lines_coords": [[[876.0, 1239.0], [904.0, 1239.0], [907.0, 1356.0], [879.0, 1356.0]]], "lines": ["小野寺君。"]}, {"box": [132, 1314, 193, 1521], "vertical": true, "font_size": 26, "lines_coords": [[[164.0, 1314.0], [190.0, 1314.0], [193.0, 1521.0], [167.0, 1521.0]], [[132.0, 1315.0], [159.0, 1315.0], [162.0, 1459.0], [135.0, 1459.0]]], "lines": ["そういう問題じゃ", "ないでしょ。"]}], "img_path": "033.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [837, 106, 929, 260], "vertical": true, "font_size": 27, "lines_coords": [[[901.0, 106.0], [929.0, 106.0], [929.0, 212.0], [901.0, 212.0]], [[870.0, 106.0], [896.0, 106.0], [896.0, 260.0], [870.0, 260.0]], [[837.0, 107.0], [864.0, 107.0], [864.0, 217.0], [837.0, 217.0]]], "lines": ["別に君を", "恨んでなんか", "いないし、"]}, {"box": [853, 393, 971, 595], "vertical": true, "font_size": 28, "lines_coords": [[[939.0, 395.0], [971.0, 395.0], [971.0, 478.0], [939.0, 478.0]], [[910.0, 395.0], [937.0, 395.0], [937.0, 576.0], [910.0, 576.0]], [[879.0, 393.0], [906.0, 393.0], [904.0, 595.0], [878.0, 595.0]]], "lines": ["．．．ただ", "君みたいな男を", "構ってやれるほど"]}, {"box": [167, 673, 267, 833], "vertical": true, "font_size": 34, "lines_coords": [[[229.0, 676.0], [267.0, 676.0], [267.0, 737.0], [229.0, 737.0]], [[203.0, 679.0], [229.0, 679.0], [229.0, 832.0], [203.0, 832.0]], [[167.0, 673.0], [206.0, 673.0], [206.0, 726.0], [167.0, 726.0]]], "lines": ["僕は", "暇じゃないん", "だ。"]}, {"box": [245, 1014, 302, 1208], "vertical": true, "font_size": 24, "lines_coords": [[[273.0, 1014.0], [300.0, 1014.0], [300.0, 1121.0], [273.0, 1121.0]], [[246.0, 1017.0], [268.0, 1017.0], [268.0, 1207.0], [246.0, 1207.0]]], "lines": ["仕事なら", "話は別だけどね。"]}, {"box": [835, 1332, 925, 1510], "vertical": true, "font_size": 25, "lines_coords": [[[898.0, 1332.0], [925.0, 1332.0], [925.0, 1462.0], [898.0, 1462.0]], [[865.0, 1332.0], [892.0, 1332.0], [892.0, 1510.0], [865.0, 1510.0]], [[835.0, 1332.0], [857.0, 1332.0], [857.0, 1442.0], [835.0, 1442.0]]], "lines": ["．．．悪いけど", "先に失礼させて", "もらうよ。"]}, {"box": [162, 1334, 229, 1527], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 1334.0], [226.0, 1334.0], [226.0, 1490.0], [200.0, 1490.0]], [[162.0, 1335.0], [189.0, 1335.0], [189.0, 1526.0], [162.0, 1526.0]]], "lines": ["大事な仕事が", "山積してるんだ。"]}], "img_path": "034.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [914, 151, 975, 335], "vertical": true, "font_size": 30, "lines_coords": [[[942.0, 151.0], [975.0, 151.0], [975.0, 200.0], [942.0, 200.0]], [[914.0, 154.0], [940.0, 154.0], [940.0, 335.0], [914.0, 335.0]]], "lines": ["あー", "雨あがってる！！"]}, {"box": [246, 435, 307, 554], "vertical": true, "font_size": 29, "lines_coords": [[[275.0, 435.0], [307.0, 435.0], [307.0, 545.0], [275.0, 545.0]], [[246.0, 437.0], [275.0, 437.0], [275.0, 554.0], [246.0, 554.0]]], "lines": ["見て見て", "プンプン、"]}, {"box": [171, 600, 232, 754], "vertical": true, "font_size": 29, "lines_coords": [[[204.0, 600.0], [232.0, 600.0], [232.0, 703.0], [204.0, 703.0]], [[171.0, 600.0], [198.0, 600.0], [198.0, 754.0], [171.0, 754.0]]], "lines": ["すっごい", "星がきれい！！"]}, {"box": [920, 846, 1006, 1043], "vertical": true, "font_size": 29, "lines_coords": [[[979.0, 846.0], [1006.0, 846.0], [1006.0, 951.0], [979.0, 951.0]], [[950.0, 848.0], [976.0, 848.0], [976.0, 981.0], [950.0, 981.0]], [[920.0, 846.0], [946.0, 846.0], [946.0, 1043.0], [920.0, 1043.0]]], "lines": ["私、実は", "中学生の時", "天文部だったんだ"]}, {"box": [818, 940, 882, 1048], "vertical": true, "font_size": 29, "lines_coords": [[[845.0, 940.0], [882.0, 940.0], [882.0, 1001.0], [845.0, 1001.0]], [[818.0, 942.0], [845.0, 942.0], [845.0, 1048.0], [818.0, 1048.0]]], "lines": ["暗い", "でしょ？"]}, {"box": [664, 907, 753, 1085], "vertical": true, "font_size": 23, "lines_coords": [[[723.0, 907.0], [750.0, 907.0], [753.0, 1028.0], [726.0, 1028.0]], [[695.0, 909.0], [717.0, 909.0], [717.0, 1085.0], [695.0, 1085.0]], [[664.0, 910.0], [685.0, 910.0], [685.0, 1029.0], [664.0, 1029.0]]], "lines": ["でも、星を", "見るのは今でも", "好きだなー"]}, {"box": [554, 946, 609, 1123], "vertical": true, "font_size": 23, "lines_coords": [[[587.0, 946.0], [609.0, 946.0], [609.0, 1112.0], [587.0, 1112.0]], [[554.0, 946.0], [576.0, 946.0], [576.0, 1123.0], [554.0, 1123.0]]], "lines": ["だって、見てる", "間は現実を．．．："]}, {"box": [415, 871, 446, 1057], "vertical": true, "font_size": 27, "lines_coords": [[[415.0, 871.0], [446.0, 871.0], [446.0, 1057.0], [415.0, 1057.0]]], "lines": ["プンブンは正直"]}, {"box": [290, 870, 384, 1029], "vertical": true, "font_size": 27, "lines_coords": [[[356.0, 870.0], [384.0, 870.0], [381.0, 1026.0], [353.0, 1026.0]], [[321.0, 870.0], [350.0, 870.0], [346.0, 1028.0], [318.0, 1028.0]], [[290.0, 873.0], [317.0, 873.0], [317.0, 1029.0], [290.0, 1029.0]]], "lines": ["この二年間で", "ずいぶん目が", "悪くなったな"]}, {"box": [192, 873, 250, 1085], "vertical": true, "font_size": 27, "lines_coords": [[[228.0, 875.0], [250.0, 875.0], [250.0, 1001.0], [228.0, 1001.0]], [[192.0, 873.0], [218.0, 873.0], [220.0, 1085.0], [193.0, 1085.0]]], "lines": ["程度にしか", "思いませんでした。"]}, {"box": [195, 872, 250, 1090], "vertical": true, "font_size": 55, "lines_coords": [[[195.0, 872.0], [250.0, 872.0], [250.0, 1090.0], [195.0, 1090.0]]], "lines": ["程度にしか思いませんでした。"]}, {"box": [318, 1325, 412, 1534], "vertical": true, "font_size": 28, "lines_coords": [[[385.0, 1326.0], [412.0, 1326.0], [412.0, 1432.0], [385.0, 1432.0]], [[351.0, 1325.0], [382.0, 1325.0], [382.0, 1534.0], [351.0, 1534.0]], [[318.0, 1325.0], [345.0, 1325.0], [348.0, 1457.0], [321.0, 1457.0]]], "lines": ["．．．現実を", "忘れさせてくれる", "からね．．．．．"]}, {"box": [132, 1185, 298, 1419], "vertical": true, "font_size": 28, "lines_coords": [[[270.0, 1185.0], [298.0, 1185.0], [295.0, 1318.0], [267.0, 1318.0]], [[231.0, 1185.0], [259.0, 1185.0], [254.0, 1393.0], [226.0, 1393.0]], [[198.0, 1187.0], [225.0, 1187.0], [223.0, 1418.0], [196.0, 1418.0]], [[168.0, 1187.0], [196.0, 1187.0], [192.0, 1356.0], [164.0, 1356.0]], [[135.0, 1185.0], [164.0, 1185.0], [160.0, 1376.0], [132.0, 1376.0]]], "lines": ["それよりも", "翠ちゃんにかける", "言葉が見つからない", "歯痒さで、心は", "いっぱいでした。"]}], "img_path": "035.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [821, 46, 946, 268], "vertical": true, "font_size": 26, "lines_coords": [[[918.0, 50.0], [945.0, 50.0], [945.0, 229.0], [918.0, 229.0]], [[887.0, 46.0], [914.0, 46.0], [910.0, 268.0], [884.0, 268.0]], [[854.0, 50.0], [881.0, 50.0], [881.0, 256.0], [854.0, 256.0]], [[821.0, 50.0], [843.0, 50.0], [846.0, 184.0], [825.0, 184.0]]], "lines": ["雄一おじさんが", "帰ってこない理由は", "はっきり聞いては", "いませんが、"]}, {"box": [559, 631, 653, 814], "vertical": true, "font_size": 28, "lines_coords": [[[626.0, 632.0], [653.0, 632.0], [651.0, 801.0], [625.0, 801.0]], [[593.0, 631.0], [620.0, 631.0], [623.0, 787.0], [596.0, 787.0]], [[559.0, 631.0], [590.0, 631.0], [590.0, 814.0], [559.0, 814.0]]], "lines": ["「雄一おしさん", "きっとすぐに", "帰ってくるよ。」"]}, {"box": [464, 631, 525, 812], "vertical": true, "font_size": 28, "lines_coords": [[[495.0, 631.0], [523.0, 631.0], [525.0, 812.0], [496.0, 812.0]], [[464.0, 631.0], [490.0, 631.0], [490.0, 795.0], [464.0, 795.0]]], "lines": ["今はこの一言が", "精一杯でした。"]}, {"box": [125, 306, 285, 547], "vertical": true, "font_size": 26, "lines_coords": [[[260.0, 310.0], [282.0, 310.0], [282.0, 464.0], [260.0, 464.0]], [[226.0, 310.0], [248.0, 310.0], [248.0, 515.0], [226.0, 515.0]], [[193.0, 309.0], [220.0, 309.0], [220.0, 545.0], [193.0, 545.0]], [[159.0, 307.0], [187.0, 307.0], [189.0, 439.0], [160.0, 439.0]], [[125.0, 306.0], [156.0, 306.0], [159.0, 473.0], [128.0, 473.0]]], "lines": ["それはきっと", "ろくでもない事情", "なのであろうことは、", "察しのつく", "プンプンです。"]}, {"box": [314, 935, 342, 1029], "vertical": true, "font_size": 28, "lines_coords": [[[314.0, 935.0], [342.0, 935.0], [342.0, 1029.0], [314.0, 1029.0]]], "lines": ["．．．うん。"]}, {"box": [260, 1070, 287, 1164], "vertical": true, "font_size": 28, "lines_coords": [[[260.0, 1070.0], [287.0, 1070.0], [287.0, 1164.0], [260.0, 1164.0]]], "lines": ["だよね。"]}, {"box": [123, 1334, 149, 1476], "vertical": true, "font_size": 22, "lines_coords": [[[123.0, 1335.0], [145.0, 1335.0], [145.0, 1473.0], [123.0, 1473.0]]], "lines": ["．．．ありがと。"]}], "img_path": "036.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [925, 696, 950, 828], "vertical": true, "font_size": 25, "lines_coords": [[[928.0, 696.0], [950.0, 696.0], [946.0, 828.0], [925.0, 828.0]]], "lines": ["よーし！！"]}, {"box": [576, 440, 673, 633], "vertical": true, "font_size": 30, "lines_coords": [[[640.0, 440.0], [673.0, 440.0], [673.0, 531.0], [640.0, 531.0]], [[609.0, 442.0], [640.0, 442.0], [640.0, 625.0], [609.0, 625.0]], [[576.0, 440.0], [603.0, 440.0], [606.0, 631.0], [579.0, 631.0]]], "lines": ["．．．もし、", "知ったかぶりを", "するのか子供で、"]}, {"box": [407, 440, 501, 625], "vertical": true, "font_size": 28, "lines_coords": [[[470.0, 440.0], [501.0, 440.0], [501.0, 625.0], [470.0, 625.0]], [[440.0, 442.0], [467.0, 442.0], [467.0, 600.0], [440.0, 600.0]], [[407.0, 442.0], [434.0, 442.0], [434.0, 579.0], [407.0, 579.0]]], "lines": ["知らないふりを", "するのが大人", "だとしたら、"]}, {"box": [835, 839, 892, 1018], "vertical": true, "font_size": 25, "lines_coords": [[[865.0, 839.0], [892.0, 839.0], [892.0, 1018.0], [865.0, 1018.0]], [[835.0, 840.0], [862.0, 840.0], [862.0, 996.0], [835.0, 996.0]]], "lines": ["明日はたくさん", "洗濯しよっ！！"]}, {"box": [140, 1028, 235, 1207], "vertical": true, "font_size": 27, "lines_coords": [[[200.0, 1028.0], [232.0, 1028.0], [235.0, 1160.0], [203.0, 1160.0]], [[176.0, 1031.0], [198.0, 1031.0], [198.0, 1207.0], [176.0, 1207.0]], [[143.0, 1028.0], [170.0, 1028.0], [167.0, 1134.0], [140.0, 1134.0]]], "lines": ["引っ越しの", "準備もしなきゃ", "ねー！！"]}, {"box": [546, 1340, 641, 1520], "vertical": true, "font_size": 25, "lines_coords": [[[615.0, 1343.0], [637.0, 1343.0], [637.0, 1445.0], [615.0, 1445.0]], [[581.0, 1342.0], [607.0, 1342.0], [607.0, 1518.0], [581.0, 1518.0]], [[546.0, 1340.0], [573.0, 1340.0], [576.0, 1498.0], [550.0, 1498.0]]], "lines": ["まだまだ", "自分は子供なの", "かもしれない"]}, {"box": [431, 1339, 495, 1519], "vertical": true, "font_size": 26, "lines_coords": [[[467.0, 1342.0], [493.0, 1342.0], [493.0, 1518.0], [467.0, 1518.0]], [[434.0, 1339.0], [460.0, 1339.0], [457.0, 1475.0], [431.0, 1475.0]]], "lines": ["と、フンフンは", "思いました。"]}], "img_path": "037.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "038.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "039.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [896, 123, 923, 264], "vertical": true, "font_size": 26, "lines_coords": [[[896.0, 123.0], [923.0, 123.0], [923.0, 264.0], [896.0, 264.0]]], "lines": ["．．．お客さん、"]}, {"box": [739, 214, 828, 412], "vertical": true, "font_size": 26, "lines_coords": [[[801.0, 215.0], [828.0, 215.0], [828.0, 412.0], [801.0, 412.0]], [[768.0, 214.0], [796.0, 214.0], [793.0, 348.0], [765.0, 348.0]], [[739.0, 215.0], [760.0, 215.0], [760.0, 326.0], [739.0, 326.0]]], "lines": ["もしよかったらで", "構わないん", "てすかね"]}, {"box": [150, 259, 272, 484], "vertical": true, "font_size": 25, "lines_coords": [[[245.0, 262.0], [271.0, 262.0], [271.0, 484.0], [245.0, 484.0]], [[212.0, 259.0], [239.0, 259.0], [239.0, 453.0], [212.0, 453.0]], [[179.0, 260.0], [206.0, 260.0], [206.0, 443.0], [179.0, 443.0]], [[150.0, 262.0], [171.0, 262.0], [171.0, 468.0], [150.0, 468.0]]], "lines": ["何か思い悩むことが", "あるんだったら、", "あたしに話して", "もらえませんか？"]}, {"box": [21, 287, 70, 456], "vertical": true, "font_size": 49, "lines_coords": [[[21.0, 287.0], [70.0, 287.0], [70.0, 456.0], [21.0, 456.0]]], "lines": ["第４９話"]}, {"box": [929, 884, 957, 993], "vertical": true, "font_size": 25, "lines_coords": [[[929.0, 884.0], [957.0, 884.0], [957.0, 993.0], [929.0, 993.0]]], "lines": ["．．．．．．僕が、"]}, {"box": [775, 937, 867, 1096], "vertical": true, "font_size": 25, "lines_coords": [[[840.0, 937.0], [867.0, 937.0], [867.0, 1096.0], [840.0, 1096.0]], [[810.0, 937.0], [832.0, 937.0], [832.0, 1070.0], [810.0, 1070.0]], [[778.0, 937.0], [801.0, 937.0], [798.0, 1042.0], [775.0, 1042.0]]], "lines": ["思い悩んでる", "ように見え", "ますか？"]}, {"box": [568, 893, 700, 915], "vertical": false, "font_size": 22, "lines_coords": [[[568.0, 893.0], [700.0, 893.0], [700.0, 915.0], [568.0, 915.0]]], "lines": ["６５４３２１"]}, {"box": [540, 956, 717, 1048], "vertical": false, "font_size": 26.333333333333332, "lines_coords": [[[543.0, 956.0], [684.0, 956.0], [684.0, 976.0], [543.0, 976.0]], [[542.0, 976.0], [717.0, 976.0], [717.0, 1009.0], [542.0, 1009.0]], [[540.0, 1021.0], [717.0, 1020.0], [717.0, 1046.0], [540.0, 1048.0]]], "lines": ["実は、安全な運転を目指し一一", "五十木俊夫", "２０１０６・３１"]}, {"box": [304, 909, 362, 1014], "vertical": true, "font_size": 26, "lines_coords": [[[340.0, 910.0], [362.0, 910.0], [362.0, 1010.0], [340.0, 1010.0]], [[304.0, 909.0], [332.0, 909.0], [332.0, 1014.0], [304.0, 1014.0]]], "lines": ["見えるも", "何も．．．"]}, {"box": [143, 928, 265, 1142], "vertical": true, "font_size": 26, "lines_coords": [[[239.0, 928.0], [265.0, 928.0], [265.0, 1093.0], [239.0, 1093.0]], [[207.0, 932.0], [234.0, 932.0], [234.0, 1142.0], [207.0, 1142.0]], [[178.0, 934.0], [200.0, 934.0], [200.0, 1114.0], [178.0, 1114.0]], [[143.0, 932.0], [171.0, 932.0], [171.0, 1039.0], [143.0, 1039.0]]], "lines": ["こんな時間に", "タクシーつかまえて", "海までだなんて", "ねぇ．．．．．"]}, {"box": [179, 1364, 278, 1521], "vertical": true, "font_size": 31, "lines_coords": [[[239.0, 1364.0], [278.0, 1364.0], [278.0, 1453.0], [239.0, 1453.0]], [[212.0, 1365.0], [239.0, 1365.0], [239.0, 1521.0], [212.0, 1521.0]], [[179.0, 1365.0], [207.0, 1365.0], [207.0, 1471.0], [179.0, 1471.0]]], "lines": ["．．．不倫", "しちゃったん", "です．．．．．．"]}], "img_path": "040.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [912, 134, 940, 210], "vertical": true, "font_size": 28, "lines_coords": [[[912.0, 134.0], [940.0, 134.0], [940.0, 210.0], [912.0, 210.0]]], "lines": ["あァー"]}, {"box": [801, 215, 864, 375], "vertical": true, "font_size": 28, "lines_coords": [[[837.0, 217.0], [864.0, 217.0], [864.0, 375.0], [837.0, 375.0]], [[801.0, 215.0], [834.0, 215.0], [834.0, 300.0], [801.0, 300.0]], [[806.0, 293.0], [828.0, 293.0], [828.0, 348.0], [806.0, 348.0]]], "lines": ["やっちゃいまし", "たねー", "．．．"]}, {"box": [176, 235, 240, 421], "vertical": true, "font_size": 30, "lines_coords": [[[212.0, 239.0], [239.0, 239.0], [239.0, 421.0], [212.0, 421.0]], [[176.0, 235.0], [209.0, 235.0], [209.0, 346.0], [176.0, 346.0]]], "lines": ["やっちゃったん", "です．．．．．"]}, {"box": [701, 1020, 728, 1134], "vertical": true, "font_size": 28, "lines_coords": [[[701.0, 1020.0], [728.0, 1020.0], [728.0, 1134.0], [701.0, 1134.0]]], "lines": ["あああっ、"]}, {"box": [604, 1064, 635, 1181], "vertical": true, "font_size": 28, "lines_coords": [[[604.0, 1064.0], [632.0, 1064.0], [635.0, 1181.0], [607.0, 1181.0]]], "lines": ["わっわっ、"]}, {"box": [142, 1073, 200, 1229], "vertical": true, "font_size": 25, "lines_coords": [[[175.0, 1075.0], [198.0, 1075.0], [200.0, 1229.0], [176.0, 1229.0]], [[142.0, 1073.0], [168.0, 1073.0], [168.0, 1181.0], [142.0, 1181.0]]], "lines": ["ちょちょぢょ", "まっ．．．"]}, {"box": [592, 1315, 621, 1449], "vertical": true, "font_size": 28, "lines_coords": [[[592.0, 1315.0], [620.0, 1315.0], [620.0, 1448.0], [592.0, 1448.0]]], "lines": ["あーーっ！！"]}, {"box": [101, 1384, 167, 1517], "vertical": true, "font_size": 32, "lines_coords": [[[129.0, 1384.0], [167.0, 1384.0], [167.0, 1446.0], [129.0, 1446.0]], [[101.0, 1389.0], [128.0, 1389.0], [131.0, 1517.0], [104.0, 1517.0]]], "lines": ["また", "負けたっ！！"]}], "img_path": "041.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [912, 71, 971, 254], "vertical": true, "font_size": 26, "lines_coords": [[[945.0, 71.0], [971.0, 71.0], [971.0, 254.0], [945.0, 254.0]], [[912.0, 71.0], [939.0, 71.0], [939.0, 201.0], [912.0, 201.0]]], "lines": ["ちょっとォ～～", "プンプン！！"]}, {"box": [801, 139, 859, 309], "vertical": true, "font_size": 26, "lines_coords": [[[832.0, 139.0], [859.0, 139.0], [859.0, 309.0], [832.0, 309.0]], [[801.0, 139.0], [823.0, 139.0], [823.0, 306.0], [801.0, 306.0]]], "lines": ["強すぎなんじゃ", "ないのォ～～～？"]}, {"box": [217, 121, 304, 295], "vertical": true, "font_size": 23, "lines_coords": [[[27