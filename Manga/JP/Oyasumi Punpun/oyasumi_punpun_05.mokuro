rue, "font_size": 32, "lines_coords": [[[585.0, 1296.0], [612.0, 1296.0], [612.0, 1428.0], [585.0, 1428.0]]], "lines": ["アンタは．．．"]}, {"box": [421, 1334, 518, 1493], "vertical": true, "font_size": 32, "lines_coords": [[[484.0, 1337.0], [518.0, 1337.0], [518.0, 1421.0], [484.0, 1421.0]], [[454.0, 1335.0], [485.0, 1335.0], [485.0, 1493.0], [454.0, 1493.0]], [[421.0, 1334.0], [456.0, 1334.0], [456.0, 1420.0], [421.0, 1420.0]]], "lines": ["朝まで", "帰って来ない", "て．．．．．"]}], "img_path": "210.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [225, 4, 357, 156], "vertical": true, "font_size": 30.666666666666668, "lines_coords": [[[314.0, 34.0], [342.0, 29.0], [357.0, 151.0], [329.0, 156.0]], [[273.0, 7.0], [301.0, 4.0], [307.0, 93.0], [279.0, 95.0]], [[225.0, 12.0], [260.0, 9.0], [267.0, 89.0], [231.0, 90.0]]], "lines": ["宙の様に", "続やか", "父よ"]}, {"box": [190, 139, 287, 320], "vertical": true, "font_size": 31, "lines_coords": [[[253.0, 140.0], [287.0, 140.0], [287.0, 221.0], [253.0, 221.0]], [[225.0, 140.0], [251.0, 140.0], [251.0, 320.0], [225.0, 320.0]], [[190.0, 139.0], [223.0, 139.0], [223.0, 226.0], [190.0, 226.0]]], "lines": ["今月の", "お父さんからの", "手紙は、"]}, {"box": [395, 79, 423, 146], "vertical": true, "font_size": 23, "lines_coords": [[[395.0, 81.0], [418.0, 79.0], [423.0, 145.0], [400.0, 146.0]]], "lines": ["マイマ"]}, {"box": [343, 28, 423, 293], "vertical": false, "font_size": 39, "lines_coords": [[[382.0, 28.0], [423.0, 287.0], [384.0, 293.0], [343.0, 34.0]]], "lines": ["やって味わんない理由は、"]}, {"box": [409, 157, 426, 192], "vertical": true, "font_size": 17, "lines_coords": [[[409.0, 157.0], [426.0, 157.0], [426.0, 192.0], [409.0, 192.0]]], "lines": ["やっ"]}, {"box": [467, 95, 532, 300], "vertical": true, "font_size": 33, "lines_coords": [[[467.0, 100.0], [500.0, 95.0], [532.0, 295.0], [500.0, 300.0]]], "lines": ["しばだては思い"]}, {"box": [510, 150, 570, 306], "vertical": false, "font_size": 29, "lines_coords": [[[539.0, 150.0], [570.0, 300.0], [542.0, 306.0], [510.0, 156.0]]], "lines": ["すかわり来場と"]}, {"box": [525, 0, 850, 329], "vertical": false, "font_size": 33.857142857142854, "lines_coords": [[[557.0, 35.0], [601.0, 246.0], [568.0, 253.0], [525.0, 42.0]], [[595.0, 0.0], [645.0, 285.0], [607.0, 292.0], [557.0, 4.0]], [[631.0, 0.0], [675.0, 273.0], [642.0, 278.0], [598.0, 3.0]], [[665.0, 1.0], [718.0, 325.0], [687.0, 329.0], [634.0, 6.0]], [[706.0, 17.0], [750.0, 303.0], [718.0, 307.0], [675.0, 21.0]], [[735.0, 21.0], [775.0, 275.0], [742.0, 279.0], [703.0, 26.0]], [[801.0, 0.0], [850.0, 248.0], [812.0, 254.0], [765.0, 0.0]]], "lines": ["ネＭトナッ製製，", "ゆっくり飛車角ーっけんってん", "国際ローザールホテルに", "やれやがって！！きゃぁぁぁっ", "この場合はサービスによりお", "そのそんなのだけのね。", "その想像を認める"]}, {"box": [731, 0, 790, 184], "vertical": true, "font_size": 31, "lines_coords": [[[731.0, 3.0], [762.0, 0.0], [790.0, 179.0], [759.0, 184.0]]], "lines": ["の講師をやめて"]}, {"box": [806, 0, 907, 210], "vertical": true, "font_size": 31.5, "lines_coords": [[[851.0, 18.0], [879.0, 12.0], [907.0, 171.0], [879.0, 178.0]], [[806.0, 0.0], [840.0, 0.0], [871.0, 206.0], [837.0, 210.0]]], "lines": ["同意のスター", "様々失速ぶりで、"]}, {"box": [153, 639, 276, 796], "vertical": true, "font_size": 27, "lines_coords": [[[245.0, 639.0], [276.0, 639.0], [276.0, 796.0], [245.0, 796.0]], [[215.0, 639.0], [242.0, 639.0], [242.0, 793.0], [215.0, 793.0]], [[182.0, 640.0], [209.0, 640.0], [209.0, 768.0], [182.0, 768.0]], [[153.0, 640.0], [175.0, 640.0], [175.0, 778.0], [153.0, 778.0]]], "lines": ["今日ほど心底", "くだらないと", "思った日は", "ありません。"]}, {"box": [843, 473, 965, 688], "vertical": true, "font_size": 25, "lines_coords": [[[937.0, 475.0], [964.0, 475.0], [964.0, 612.0], [937.0, 612.0]], [[906.0, 475.0], [932.0, 475.0], [932.0, 656.0], [906.0, 656.0]], [[875.0, 475.0], [901.0, 475.0], [901.0, 631.0], [875.0, 631.0]], [[843.0, 473.0], [865.0, 473.0], [865.0, 681.0], [843.0, 681.0]]], "lines": ["いつも通り、", "ジャイアンツと", "宇宙の話題で", "もちきりでしたが、"]}, {"box": [118, 1175, 338, 1384], "vertical": true, "font_size": 25, "lines_coords": [[[312.0, 1176.0], [334.0, 1176.0], [334.0, 1303.0], [312.0, 1303.0]], [[278.0, 1175.0], [304.0, 1175.0], [303.0, 1384.0], [276.0, 1384.0]], [[245.0, 1178.0], [271.0, 1178.0], [271.0, 1331.0], [245.0, 1331.0]], [[212.0, 1176.0], [239.0, 1176.0], [237.0, 1359.0], [210.0, 1359.0]], [[182.0, 1179.0], [204.0, 1179.0], [204.0, 1379.0], [182.0, 1379.0]], [[146.0, 1175.0], [173.0, 1175.0], [175.0, 1379.0], [148.0, 1379.0]], [[118.0, 1178.0], [140.0, 1178.0], [140.0, 1337.0], [118.0, 1337.0]]], "lines": ["黒魔術でも", "大声で唱えなから", "全裸で駅前を", "全力疾走したら", "なんだかとっても", "気持ち良いのでは", "なかろうかと。"]}, {"box": [370, 1175, 401, 1445], "vertical": true, "font_size": 26, "lines_coords": [[[370.0, 1175.0], [396.0, 1175.0], [400.0, 1439.0], [373.0, 1439.0]]], "lines": ["フンフンは思いました。"]}, {"box": [776, 1176, 895, 1364], "vertical": true, "font_size": 24, "lines_coords": [[[873.0, 1176.0], [895.0, 1176.0], [895.0, 1354.0], [873.0, 1354.0]], [[839.0, 1176.0], [865.0, 1176.0], [865.0, 1331.0], [839.0, 1331.0]], [[804.0, 1176.0], [831.0, 1176.0], [831.0, 1354.0], [804.0, 1354.0]], [[776.0, 1176.0], [798.0, 1176.0], [798.0, 1360.0], [776.0, 1360.0]]], "lines": ["どうしてこうも", "大人のくせに", "みんな自分勝手", "なのだろう、と"]}, {"box": [948, 1175, 975, 1444], "vertical": true, "font_size": 22, "lines_coords": [[[948.0, 1175.0], [970.0, 1175.0], [970.0, 1435.0], [948.0, 1435.0]]], "lines": ["フンフンは思いました"]}], "img_path": "211.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [200, 73, 223, 207], "vertical": true, "font_size": 22, "lines_coords": [[[201.0, 73.0], [223.0, 73.0], [221.0, 207.0], [200.0, 207.0]]], "lines": ["．．．"]}, {"box": [318, 735, 345, 841], "vertical": true, "font_size": 27, "lines_coords": [[[318.0, 735.0], [345.0, 735.0], [345.0, 839.0], [318.0, 839.0]]], "lines": ["．．．そう！！"]}, {"box": [777, 732, 906, 940], "vertical": true, "font_size": 27, "lines_coords": [[[879.0, 732.0], [906.0, 732.0], [906.0, 867.0], [879.0, 867.0]], [[848.0, 734.0], [875.0, 734.0], [875.0, 940.0], [848.0, 940.0]], [[815.0, 735.0], [843.0, 735.0], [843.0, 839.0], [815.0, 839.0]], [[782.0, 735.0], [809.0, 735.0], [809.0, 892.0], [782.0, 892.0]]], "lines": ["．．．いえいえ", "そんな物騒なこと", "考えては", "いけません！！"]}, {"box": [675, 734, 733, 941], "vertical": true, "font_size": 24, "lines_coords": [[[704.0, 734.0], [729.0, 734.0], [732.0, 939.0], [707.0, 939.0]], [[676.0, 737.0], [698.0, 737.0], [698.0, 914.0], [676.0, 914.0]]], "lines": ["悪いのは、すべて", "自分なのです！！"]}, {"box": [534, 733, 627, 967], "vertical": true, "font_size": 22, "lines_coords": [[[601.0, 735.0], [623.0, 735.0], [623.0, 914.0], [601.0, 914.0]], [[568.0, 737.0], [590.0, 737.0], [590.0, 964.0], [568.0, 964.0]], [[535.0, 739.0], [557.0, 739.0], [557.0, 939.0], [535.0, 939.0]]], "lines": ["世の中はきっと", "優しさと喜びて溢れ", "かえっています！！"]}, {"box": [394, 734, 485, 917], "vertical": true, "font_size": 23, "lines_coords": [[[456.0, 735.0], [482.0, 735.0], [482.0, 892.0], [456.0, 892.0]], [[426.0, 737.0], [448.0, 737.0], [448.0, 914.0], [426.0, 914.0]], [[395.0, 737.0], [417.0, 737.0], [417.0, 890.0], [395.0, 890.0]]], "lines": ["もしかしたら", "明日はいいこと", "あるかもヨ！？"]}, {"box": [209, 736, 270, 968], "vertical": true, "font_size": 26, "lines_coords": [[[240.0, 737.0], [267.0, 737.0], [267.0, 942.0], [240.0, 942.0]], [[209.0, 737.0], [235.0, 737.0], [235.0, 965.0], [209.0, 965.0]]], "lines": ["テンション上げて", "いきまっっショイ！！"]}], "img_path": "212.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [301, 1156, 965, 1595], "vertical": false, "font_size": 296, "lines_coords": [[[301.0, 1309.0], [890.0, 1156.0], [965.0, 1442.0], [375.0, 1595.0]]], "lines": ["〈ぎ茶〉"]}], "img_path": "213.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [465, 82, 632, 187], "vertical": false, "font_size": 105, "lines_coords": [[[465.0, 82.0], [632.0, 82.0], [632.0, 187.0], [465.0, 187.0]]], "lines": ["そ、"]}], "img_path": "214.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height