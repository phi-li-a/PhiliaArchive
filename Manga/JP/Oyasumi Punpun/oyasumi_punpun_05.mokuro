x": [854, 1285, 907, 1448], "vertical": true, "font_size": 25, "lines_coords": [[[879.0, 1285.0], [907.0, 1285.0], [907.0, 1385.0], [879.0, 1385.0]], [[854.0, 1287.0], [876.0, 1287.0], [876.0, 1448.0], [854.0, 1448.0]]], "lines": ["今の発言、", "いい子すぎる？"]}, {"box": [207, 1232, 285, 1371], "vertical": true, "font_size": 22, "lines_coords": [[[265.0, 1232.0], [285.0, 1232.0], [285.0, 1371.0], [265.0, 1371.0]], [[235.0, 1232.0], [257.0, 1232.0], [257.0, 1371.0], [235.0, 1371.0]], [[207.0, 1232.0], [229.0, 1232.0], [229.0, 1371.0], [207.0, 1371.0]]], "lines": ["．．．そーだよ！！", "心の底からは", "思ってない！！"]}, {"box": [100, 1357, 178, 1518], "vertical": true, "font_size": 22, "lines_coords": [[[151.0, 1357.0], [178.0, 1357.0], [178.0, 1496.0], [151.0, 1496.0]], [[125.0, 1357.0], [146.0, 1357.0], [146.0, 1518.0], [125.0, 1518.0]], [[100.0, 1357.0], [120.0, 1357.0], [120.0, 1485.0], [100.0, 1485.0]]], "lines": ["ホントはまだ", "もやもやしてん", "だよ、俺は！！"]}], "img_path": "183.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [948, 90, 1006, 234], "vertical": true, "font_size": 24, "lines_coords": [[[979.0, 93.0], [1006.0, 93.0], [1006.0, 187.0], [979.0, 187.0]], [[951.0, 90.0], [978.0, 90.0], [975.0, 234.0], [948.0, 234.0]]], "lines": ["けど清水", "だってさ．．．"]}, {"box": [815, 187, 923, 334], "vertical": true, "font_size": 24, "lines_coords": [[[901.0, 187.0], [923.0, 187.0], [923.0, 329.0], [901.0, 329.0]], [[873.0, 187.0], [895.0, 187.0], [895.0, 328.0], [873.0, 328.0]], [[845.0, 187.0], [867.0, 187.0], [867.0, 303.0], [845.0, 303.0]], [[815.0, 187.0], [837.0, 187.0], [837.0, 334.0], [815.0, 334.0]]], "lines": ["なんつーか．．．", "こう、例えば", "好きな人が", "できたりして、"]}, {"box": [691, 0, 774, 87], "vertical": true, "font_size": 83, "lines_coords": [[[691.0, 0.0], [774.0, 0.0], [774.0, 87.0], [691.0, 87.0]]], "lines": ["．．．"]}, {"box": [109, 175, 217, 361], "vertical": true, "font_size": 23, "lines_coords": [[[190.0, 175.0], [217.0, 175.0], [217.0, 271.0], [190.0, 271.0]], [[165.0, 176.0], [187.0, 176.0], [187.0, 317.0], [165.0, 317.0]], [[135.0, 175.0], [157.0, 175.0], [157.0, 360.0], [135.0, 360.0]], [[109.0, 175.0], [131.0, 175.0], [131.0, 337.0], [109.0, 337.0]]], "lines": ["そのうち", "あんまり俺と", "遊ばなくなったり", "する訳じゃん？"]}, {"box": [893, 481, 975, 643], "vertical": true, "font_size": 24, "lines_coords": [[[946.0, 481.0], [975.0, 481.0], [975.0, 562.0], [946.0, 562.0]], [[921.0, 482.0], [943.0, 482.0], [943.0, 643.0], [921.0, 643.0]], [[893.0, 482.0], [915.0, 482.0], [915.0, 575.0], [893.0, 575.0]]], "lines": ["関くん、", "酔っぱらってる", "みたい！！"]}, {"box": [232, 532, 259, 635], "vertical": true, "font_size": 26, "lines_coords": [[[232.0, 532.0], [259.0, 532.0], [259.0, 635.0], [232.0, 635.0]]], "lines": ["バーカ。"]}, {"box": [129, 670, 209, 789], "vertical": true, "font_size": 26, "lines_coords": [[[185.0, 671.0], [209.0, 671.0], [206.0, 787.0], [182.0, 787.0]], [[154.0, 670.0], [181.0, 670.0], [181.0, 789.0], [154.0, 789.0]], [[129.0, 670.0], [153.0, 670.0], [153.0, 743.0], [129.0, 743.0]]], "lines": ["コーラしか", "飲んでねー", "よ．．．．．"]}, {"box": [682, 816, 765, 852], "vertical": false, "font_size": 39, "lines_coords": [[[682.0, 813.0], [765.0, 813.0], [765.0, 855.0], [682.0, 855.0]]], "lines": ["．．．"]}, {"box": [310, 885, 365, 968], "vertical": true, "font_size": 19.5, "lines_coords": [[[348.0, 887.0], [365.0, 887.0], [365.0, 942.0], [348.0, 942.0]], [[310.0, 885.0], [332.0, 885.0], [332.0, 968.0], [310.0, 968.0]]], "lines": ["チャーラ", "博物ラーメ"]}, {"box": [951, 1162, 973, 1281], "vertical": true, "font_size": 25, "lines_coords": [[[951.0, 1162.0], [973.0, 1162.0], [973.0, 1281.0], [951.0, 1281.0]]], "lines": ["．．．なぁ清水、"]}, {"box": [881, 1348, 909, 1432], "vertical": true, "font_size": 25, "lines_coords": [[[881.0, 1348.0], [909.0, 1348.0], [909.0, 1432.0], [881.0, 1432.0]]], "lines": ["俺達さ、"]}, {"box": [310, 1257, 328, 1309], "vertical": true, "font_size": 18, "lines_coords": [[[310.0, 1257.0], [328.0, 1257.0], [328.0, 1309.0], [310.0, 1309.0]]], "lines": ["待かっ"]}, {"box": [106, 1325, 184, 1464], "vertical": true, "font_size": 23, "lines_coords": [[[157.0, 1325.0], [184.0, 1325.0], [184.0, 1423.0], [157.0, 1423.0]], [[132.0, 1325.0], [154.0, 1325.0], [154.0, 1464.0], [132.0, 1464.0]], [[106.0, 1325.0], [126.0, 1325.0], [126.0, 1464.0], [106.0, 1464.0]]], "lines": ["これから", "どんな大人に", "なると思う？"]}], "img_path": "184.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [884, 67, 945, 253], "vertical": true, "font_size": 28, "lines_coords": [[[914.0, 67.0], [945.0, 67.0], [945.0, 253.0], [914.0, 253.0]], [[884.0, 70.0], [910.0, 70.0], [910.0, 250.0], [884.0, 250.0]]], "lines": ["：俺、全然想像", "つかねーわ．．．"]}, {"box": [135, 375, 225, 600], "vertical": true, "font_size": 25, "lines_coords": [[[195.0, 375.0], [221.0, 375.0], [221.0, 528.0], [195.0, 528.0]], [[164.0, 376.0], [190.0, 376.0], [190.0, 600.0], [164.0, 600.0]], [[135.0, 376.0], [157.0, 376.0], [157.0, 528.0], [135.0, 528.0]]], "lines": ["人生、運命の", "いたずらが多過ぎる", "と思わねぇ？"]}, {"box": [325, 745, 387, 909], "vertical": true, "font_size": 27, "lines_coords": [[[357.0, 745.0], [384.0, 745.0], [387.0, 909.0], [360.0, 909.0]], [[328.0, 746.0], [354.0, 746.0], [351.0, 885.0], [325.0, 885.0]]], "lines": ["．．．ありがとね、", "小野寺くん。"]}, {"box": [195, 826, 290, 1009], "vertical": true, "font_size": 27, "lines_coords": [[[260.0, 826.0], [289.0, 826.0], [290.0, 984.0], [262.0, 984.0]], [[228.0, 828.0], [254.0, 828.0], [257.0, 1009.0], [231.0, 1009.0]], [[195.0, 826.0], [221.0, 826.0], [226.0, 995.0], [200.0, 995.0]]], "lines": ["なんか一人で", "帰るのちょっと", "気まずくてさ。"]}, {"box": [882, 1329, 992, 1533], "vertical": true, "font_size": 22, "lines_coords": [[[968.0, 1329.0], [990.0, 1329.0], [990.0, 1478.0], [968.0, 1478.0]], [[940.0, 1329.0], [962.0, 1329.0], [962.0, 1532.0], [940.0, 1532.0]], [[912.0, 1329.0], [934.0, 1329.0], [934.0, 1468.0], [912.0, 1468.0]], [[882.0, 1329.0], [904.0, 1329.0], [904.0, 1475.0], [882.0, 1475.0]]], "lines": ["けど、みんなが", "盛り上がってるトコ", "水を差すのも", "なんか悪いし"]}, {"box": [540, 1104, 649, 1299], "vertical": true, "font_size": 23, "lines_coords": [[[626.0, 1107.0], [648.0, 1107.0], [648.0, 1223.0], [626.0, 1223.0]], [[598.0, 1107.0], [618.0, 1107.0], [618.0, 1270.0], [598.0, 1270.0]], [[565.0, 1104.0], [592.0, 1104.0], [593.0, 1293.0], [567.0, 1293.0]], [[540.0, 1106.0], [562.0, 1106.0], [564.0, 1293.0], [542.0, 1293.0]]], "lines": ["ウチの学校", "偏差値高いから", "真面目な人ばかり", "だと思ってたけど"]}, {"box": [484, 1201, 500, 1265], "vertical": true, "font_size": 16, "lines_coords": [[[484.0, 1201.0], [500.0, 1201.0], [500.0, 1265.0], [484.0, 1265.0]]], "lines": ["うー"]}, {"box": [171, 1157, 309, 1320], "vertical": true, "font_size": 23, "lines_coords": [[[256.0, 1159.0], [278.0, 1159.0], [278.0, 1298.0], [256.0, 1298.0]], [[282.0, 1157.0], [306.0, 1157.0], [309.0, 1273.0], [285.0, 1273.0]], [[228.0, 1159.0], [250.0, 1159.0], [250.0, 1320.0], [228.0, 1320.0]], [[200.0, 1157.0], [221.0, 1157.0], [221.0, 1296.0], [200.0, 1296.0]], [[171.0, 1157.0], [195.0, 1157.0], [195.0, 1234.0], [171.0, 1234.0]]], "lines": ["勉強も遊びも", "あんな風に", "器用にできる人", "目の当たりに", "すると"]}, {"box": [115, 1364, 307, 1556], "vertical": true, "font_size": 23, "lines_coords": [[[290.0, 1484.0], [307.0, 1484.0], [307.0, 1556.0], [290.0, 1556.0]], [[181.0, 1364.0], [207.0, 1364.0], [207.0, 1468.0], [181.0, 1468.0]], [[150.0, 1364.0], [171.0, 1364.0], [171.0, 1515.0], [150.0, 1515.0]], [[115.0, 1364.0], [142.0, 1364.0], [142.0, 1468.0], [115.0, 1468.0]]], "lines": ["マジか．．．", "ちょっと", "うらやましい", "よね．．．"]}], "img_path": "185.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [859, 56, 926, 176], "vertical": true, "font_size": 28, "lines_coords": [[[887.0, 56.0], [926.0, 56.0], [926.0, 142.0], [887.0, 142.0]], [[859.0, 57.0], [892.0, 57.0], [892.0, 176.0], [859.0, 176.0]]], "lines": ["．．．とか", "言いつつ。"]}, {"box": [696, 78, 817, 232], "vertical": true, "font_size": 28, "lines_coords": [[[789.0, 78.0], [817.0, 78.0], [817.0, 184.0], [789.0, 184.0]], [[757.0, 79.0], [784.0, 79.0], [784.0, 232.0], [757.0, 232.0]], [[728.0, 79.0], [750.0, 79.0], [750.0, 231.0], [728.0, 231.0]], [[696.0, 81.0], [718.0, 81.0], [718.0, 206.0], [696.0, 206.0]]], "lines": ["どこかで", "馬鹿にしてる", "自分もいるん", "だけど．．．"]}, {"box": [229, 79, 259, 143], "vertical": true, "font_size": 23, "lines_coords": [[[229.0, 79.0], [259.0, 79.0], [259.0, 143.0], [229.0, 143.0]]], "lines": ["あー"]}, {"box": [164, 165, 259, 354], "vertical": true, "font_size": 23, "lines_coords": [[[231.0, 168.0], [253.0, 165.0], [259.0, 215.0], [237.0, 218.0]], [[164.0, 178.0], [185.0, 178.0], [185.0, 354.0], [164.0, 354.0]]], "lines": ["あ", "融通の利かない"]}, {"box": [101, 178, 154, 381], "vertical": true, "font_size": 23, "lines_coords": [[[132.0, 178.0], [154.0, 178.0], [154.0, 381.0], [132.0, 381.0]], [[101.0, 178.0], [123.0, 178.0], [123.0, 343.0], [101.0, 343.0]]], "lines": ["自分の心の狭さに", "なんかヘコむ。"]}, {"box": [545, 456, 625, 604], "vertical": true, "font_size": 26, "lines_coords": [[[598.0, 456.0], [625.0, 456.0], [625.0, 604.0], [598.0, 604.0]], [[570.0, 456.0], [598.0, 456.0], [598.0, 595.0], [570.0, 595.0]], [[545.0, 457.0], [567.0, 457.0], [567.0, 601.0], [545.0, 601.0]]], "lines": ["．．．あ、ゴメン。", "この話、特に", "オチないから。"]}, {"box": [131, 478, 238, 653], "vertical": true, "font_size": 21, "lines_coords": [[[214.0, 478.0], [235.0, 478.0], [235.0, 595.0], [214.0, 595.0]], [[185.0, 479.0], [207.0, 479.0], [207.0, 595.0], [185.0, 595.0]], [[157.0, 479.0], [179.0, 479.0], [179.0, 595.0], [157.0, 595.0]], [[131.0, 481.0], [151.0, 481.0], [151.0, 650.0], [131.0, 650.0]]], "lines": ["よく言われ", "るんだー", "あたしの話", "つまんないって。"]}, {"box": [810, 1309, 905, 1491], "vertical": true, "font_size": 27, "lines_coords": [[[878.0, 1312.0], [904.0, 1312.0], [904.0, 1489.0], [878.0, 1489.0]], [[848.0, 1314.0], [870.0, 1314.0], [870.0, 1487.0], [848.0, 1487.0]], [[810.0, 1309.0], [843.0, 1309.0], [843.0, 1401.0], [810.0, 1401.0]]], "lines": ["別にオチなんて", "必要ありません", "でした。"]}, {"box": [581, 1309, 740, 1528], "vertical": true, "font_size": 27, "lines_coords": [[[714.0, 1312.0], [740.0, 1312.0], [740.0, 1415.0], [714.0, 1415.0]], [[678.0, 1309.0], [710.0, 1309.0], [707.0, 1440.0], [675.0, 1440.0]], [[651.0, 1312.0], [673.0, 1312.0], [673.0, 1464.0], [651.0, 1464.0]], [[609.0, 1309.0], [640.0, 1309.0], [637.0, 1492.0], [606.0, 1492.0]], [[582.0, 1314.0], [604.0, 1314.0], [604.0, 1521.0], [582.0, 1521.0]]], "lines": ["なぜなら", "フンフンも", "この娘さんと", "概ね同じ気持ち", "だったのですから、"]}, {"box": [112, 1401, 137, 1534], "vertical": true, "font_size": 22, "lines_coords": [[[112.0, 1404.0], [134.0, 1404.0], [134.0, 1531.0], [112.0, 1531.0]]], "lines": ["．．．あれ？"]}], "img_path": "186.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [910, 115, 975, 271], "vertical": true, "font_size": 31, "lines_coords": [[[940.0, 115.0], [975.0, 115.0], [975.0, 198.0], [940.0, 198.0]], [[914.0, 115.0], [940.0, 115.0], [937.0, 271.0], [910.0, 271.0]]], "lines": ["．．．何か", "聞こえない？"]}, {"box": [898, 498, 926, 603], "vertical": true, "font_size": 28, "lines_coords": [[[898.0, 498.0], [926.0, 498.0], [926.0, 603.0], [898.0, 603.0]]], "lines": ["ホラ．．．"]}, {"box": [228, 523, 287, 676], "vertical": true, "font_size": 26, "lines_coords": [[[257.0, 523.0], [285.0, 523.0], [287.0, 628.0], [259.0, 628.0]], [[228.0, 523.0], [254.0, 523.0], [254.0, 676.0], [228.0, 676.0]]], "lines": ["知らない", "曲だけど．．．"]}, {"box": [140, 659, 195, 826], "vertical": true, "font_size": 26, "lines_coords": [[[168.0, 659.0], [195.0, 659.0], [195.0, 767.0], [168.0, 767.0]], [[140.0, 662.0], [162.0, 662.0], [162.0, 826.0], [140.0, 826.0]]], "lines": ["きれいな", "メロディー．．．"]}, {"box": [875, 945, 933, 1109], "vertical": true, "font_size": 26, "lines_coords": [[[906.0, 946.0], [932.0, 946.0], [932.0, 1100.0], [906.0, 1100.0]], [[875.0, 945.0], [901.0, 945.0], [901.0, 1106.0], [875.0, 1106.0]]], "lines": ["なぜだか今の", "プンプンには、"]}, {"box": [123, 1026, 248, 1184], "vertical": true, "font_size": 25, "lines_coords": [[[220.0, 1029.0], [246.0, 1029.0], [246.0, 1182.0], [220.0, 1182.0]], [[190.0, 1031.0], [212.0, 1031.0], [212.0, 1182.0], [190.0, 1182.0]], [[156.0, 1029.0], [182.0, 1029.0], [182.0, 1184.0], [156.0, 1184.0]], [[123.0, 1026.0], [150.0, 1026.0], [150.0, 1118.0], [123.0, 1118.0]]], "lines": ["自分の心臓の", "鼓動の音しか", "聞こえません", "でした。"]}], "img_path": "187.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [739, 1145, 781, 1182], "vertical": false, "font_size": 19, "lines_coords": [[[739.0, 1165.0], [771.0, 1145.0], [781.0, 1162.0], [748.0, 1182.0]]], "lines": ["．．．"]}], "img_path": "188.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [300, 562, 770, 910], "vertical": false, "font_size": 342, "lines_coords": [[[304.0, 562.0], [770.0, 568.0], [765.0, 910.0], [300.0, 904.0]]], "lines": ["それは、"]}, {"box": [75, 907, 542, 1134], "vertical": false, "font_size": 135, "lines_coords": [[[392.0, 938.0], [445.0, 938.0], [445.0, 993.0], [392.0, 993.0]], [[81.0, 895.0], [542.0, 908.0], [535.0, 1146.0], [75.0, 1133.0]]], "lines": ["ちば、", "学園"]}], "img_path": "189.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [378, 217, 458, 620], "vertical": true, "font_size": 37, "lines_coords": [[[417.0, 243.0], [454.0, 245.0], [446.0, 415.0], [409.0, 414.0]]], "lines": ["うん、"]}, {"box": [228, 229, 332, 618], "vertical": true, "font_size": 104, "lines_coords": [[[228.0, 229.0], [332.0, 229.0], [332.0, 548.0], [228.0, 548.0]]], "lines": ["浅野いに"]}, {"box": [117, 639, 323, 665], "vertical": false, "font_size": 22, "lines_coords": [[[125.0, 638.0], [312.0, 640.0], [312.0, 664.0], [125.0, 662.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹＣＯＭＣＳ"]}], "img_path": "190.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [932, 117, 960, 198], "vertical": true, "font_size": 28, "lines_coords": [[[932.0, 118.0], [960.0, 118.0], [960.0, 198.0], [932.0, 198.0]]], "lines": ["．．．え？"]}, {"box": [129, 460, 195, 657], "vertical": true, "font_size": 27, "lines_coords": [[[167.0, 464.0], [193.0, 464.0], [193.0, 600.0], [167.0, 600.0]], [[132.0, 460.0], [160.0, 460.0], [157.0, 657.0], [129.0, 657.0]]], "lines": ["小野寺くん、", "今、何か言った？"]}, {"box": [859, 1051, 951, 1284], "vertical": true, "font_size": 22, "lines_coords": [[[925.0, 1056.0], [946.0, 1056.0], [946.0, 1193.0], [925.0, 1193.0]], [[892.0, 1056.0], [914.0, 1056.0], [914.0, 1281.0], [892.0, 1281.0]], [[859.0, 1054.0], [881.0, 1054.0], [881.0, 1243.0], [859.0, 1243.0]]], "lines": ["「今度の週末", "二人でどこか遊びに", "行きませんか！？」"]}, {"box": [720, 1051, 815, 1234], "vertical": true, "font_size": 30, "lines_coords": [[[789.0, 1053.0], [815.0, 1053.0], [814.0, 1231.0], [787.0, 1231.0]], [[753.0, 1053.0], [784.0, 1053.0], [784.0, 1234.0], [753.0, 1234.0]], [[720.0, 1051.0], [753.0, 1051.0], [753.0, 1145.0], [720.0, 1145.0]]], "lines": ["と、フンフンは", "力強く言い直し", "ました。"]}, {"box": [521, 771, 812, 926], "vertical": false, "font_size": 155, "lines_coords": [[[521.0, 771.0], [812.0, 771.0], [812.0, 926.0], [521.0, 926.0]]], "lines": ["いや、"]}, {"box": [365, 1009, 391, 1130], "vertical": true, "font_size": 22, "lines_coords": [[[365.0, 1015.0], [387.0, 1015.0], [387.0, 1125.0], [365.0, 1125.0]]], "lines": ["うん．．．うん"]}, {"box": [96, 1409, 126, 1525], "vertical": true, "font_size": 26, "lines_coords": [[[96.0, 1409.0], [123.0, 1409.0], [126.0, 1525.0], [100.0, 1525.0]]], "lines": ["いいけど。"]}], "img_path": "191.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [848, 73, 956, 214], "vertical": true, "font_size": 23, "lines_coords": [[[934.0, 76.0], [956.0, 76.0], [956.0, 135.0], [934.0, 135.0]], [[906.0, 76.0], [928.0, 76.0], [928.0, 212.0], [906.0, 212.0]], [[878.0, 76.0], [900.0, 76.0], [900.0, 214.0], [878.0, 214.0]], [[848.0, 73.0], [876.0, 73.0], [876.0, 156.0], [848.0, 156.0]]], "lines": ["．．．まー", "これ言っちゃ", "身も蓋もねー", "けどさ。"]}, {"box": [720, 92, 803, 285], "vertical": true, "font_size": 23, "lines_coords": [[[776.0, 92.0], [803.0, 92.0], [803.0, 278.0], [776.0, 278.0]], [[750.0, 93.0], [771.0, 93.0], [771.0, 231.0], [750.0, 231.0]], [[720.0, 92.0], [742.0, 92.0], [743.0, 285.0], [721.0, 285.0]]], "lines": ["人生、いつどこで", "何が起こるか", "わかんねーからな。"]}, {"box": [578, 113, 603, 276], "vertical": true, "font_size": 22, "lines_coords": [[[578.0, 115.0], [600.0, 115.0], [600.0, 268.0], [578.0, 268.0]]], "lines": ["．．．これからも"]}, {"box": [107, 60, 400, 87], "vertical": false, "font_size": 27, "lines_coords": [[[107.0, 60.0], [400.0, 60.0], [400.0, 87.0], [107.0, 87.0]]], "lines": ["おやすみプンプン国"]}, {"box": [96, 345, 191, 503], "vertical": true, "font_size": 28, "lines_coords": [[[164.0, 348.0], [190.0, 348.0], [190.0, 478.0], [164.0, 478.0]], [[134.0, 350.0], [156.0, 350.0], [156.0, 503.0], [134.0, 503.0]], [[96.0, 345.0], [132.0, 345.0], [132.0, 404.0], [96.0, 404.0]]], "lines": ["できるだけ", "仲良くしよう", "ぜ？"]}, {"box": [862, 750, 931, 987], "vertical": true, "font_size": 35, "lines_coords": [[[885.0, 753.0], [925.0, 750.0], [931.0, 837.0], [892.0, 840.0]], [[862.0, 754.0], [893.0, 754.0], [893.0, 987.0], [862.0, 987.0]]], "lines": ["グッド", "バイブレーション！！"]}, {"box": [200, 871, 259, 976], "vertical": true, "font_size": 28, "lines_coords": [[[231.0, 871.0], [259.0, 871.0], [259.0, 976.0], [231.0, 976.0]], [[200.0, 871.0], [228.0, 871.0], [228.0, 975.0], [200.0, 975.0]]], "lines": ["なんだよ", "ソレ．．．"]}, {"box": [973, 1246, 1012, 1470], "vertical": true, "font_size": 30, "lines_coords": [[[973.0, 1248.0], [1001.0, 1246.0], [1012.0, 1468.0], [984.0, 1470.0]]], "lines": ["一部、誰も見た"]}, {"box": [904, 1229, 951, 1515], "vertical": true, "font_size": 30, "lines_coords": [[[904.0, 1231.0], [935.0, 1229.0], [951.0, 1514.0], [920.0, 1515.0]]], "lines": ["「自分の思い出ではなく"]}, {"box": [810, 1328, 840, 1520], "vertical": true, "font_size": 25, "lines_coords": [[[810.0, 1328.0], [835.0, 1328.0], [840.0, 1520.0], [815.0, 1520.0]]], "lines": ["このような"]}, {"box": [590, 1220, 631, 1585], "vertical": true, "font_size": 31, "lines_coords": [[[590.0, 1220.0], [621.0, 1220.0], [631.0, 1585.0], [600.0, 1585.0]]], "lines": ["そういうことですが、"]}, {"box": [384, 1139, 442, 1269], "vertical": true, "font_size": 28, "lines_coords": [[[409.0, 1139.0], [442.0, 1139.0], [442.0, 1229.0], [409.0, 1229.0]], [[384.0, 1143.0], [406.0, 1143.0], [406.0, 1268.0], [384.0, 1268.0]]], "lines": ["．．．うん、", "そうね．．．．．"]}, {"box": [485, 1228, 518, 1560], "vertical": true, "font_size": 31, "lines_coords": [[[485.0, 1228.0], [517.0, 1228.0], [518.0, 1560.0], [487.0, 1560.0]]], "lines": ["そういうことで、"]}, {"box": [142, 1228, 334, 1264], "vertical": false, "font_size": 32, "lines_coords": [[[142.0, 1231.0], [334.0, 1228.0], [334.0, 1260.0], [142.0, 1264.0]]], "lines": ["８０３【ＮＯＤＥＫＡ"]}, {"box": [104, 1351, 191, 1557], "vertical": true, "font_size": 22, "lines_coords": [[[164.0, 1351.0], [187.0, 1351.0], [189.0, 1531.0], [165.0, 1531.0]], [[134.0, 1353.0], [156.0, 1353.0], [156.0, 1557.0], [134.0, 1557.0]], [[104.0, 1353.0], [126.0, 1353.0], [126.0, 1543.0], [104.0, 1543.0]]], "lines": ["あたしも明日は", "仕事早目にあがら", "せてもらうから。"]}], "img_path": "192.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [917, 80, 968, 207], "vertical": true, "font_size": 24, "lines_coords": [[[942.0, 81.0], [968.0, 81.0], [968.0, 196.0], [942.0, 196.0]], [[917.0, 81.0], [939.0, 81.0], [939.0, 206.0], [917.0, 206.0]]], "lines": ["．．．雄一は？", "．．．あぁそう。"]}, {"box": [410, 120, 492, 260], "vertical": true, "font_size": 22, "lines_coords": [[[465.0, 120.0], [492.0, 120.0], [489.0, 239.0], [462.0, 239.0]], [[439.0, 123.0], [460.0, 123.0], [460.0, 260.0], [439.0, 260.0]], [[410.0, 123.0], [432.0, 123.0], [432.0, 260.0], [410.0, 260.0]]], "lines": ["．．．ごめんね", "弱ちゃん．．．", "迷惑かけて．．．"]}, {"box": [285, 178, 364, 307], "vertical": true, "font_size": 22, "lines_coords": [[[342.0, 178.0], [364.0, 178.0], [364.0, 307.0], [342.0, 307.0]], [[314.0, 179.0], [335.0, 179.0], [335.0, 295.0], [314.0, 295.0]], [[285.0, 179.0], [307.0, 179.0], [307.0, 295.0], [285.0, 295.0]]], "lines": ["．．．いいのよ。", "じゃあまた", "明日ね．．．"]}, {"box": [909, 736, 937, 828], "vertical": true, "font_size": 28, "lines_coords": [[[909.0, 767.0], [937.0, 767.0], [937.0, 828.0], [909.0, 828.0]]], "lines": ["あ。"]}, {"box": [620, 443, 730, 628], "vertical": true, "font_size": 24, "lines_coords": [[[706.0, 446.0], [728.0, 446.0], [728.0, 585.0], [706.0, 585.0]], [[679.0, 445.0], [701.0, 445.0], [701.0, 606.0], [679.0, 606.0]], [[651.0, 443.0], [673.0, 443.0], [673.0, 626.0], [651.0, 626.0]], [[620.0, 443.0], [648.0, 443.0], [648.0, 526.0], [620.0, 526.0]]], "lines": ["夕方過ぎには", "プンプン連れて", "そっち着くように", "するわ。"]}, {"box": [139, 781, 195, 936], "vertical": true, "font_size": 24, "lines_coords": [[[164.0, 781.0], [192.0, 781.0], [195.0, 893.0], [167.0, 893.0]], [[139.0, 784.0], [160.0, 784.0], [160.0, 934.0], [139.0, 934.0]]], "lines": ["おかえり、", "フンフン．．．"]}, {"box": [170, 1318, 264, 1486], "vertical": true, "font_size": 30, "lines_coords": [[[225.0, 1318.0], [264.0, 1318.0], [264.0, 1404.0], [225.0, 1404.0]], [[196.0, 1320.0], [225.0, 1320.0], [226.0, 1484.0], [198.0, 1484.0]], [[170.0, 1325.0], [192.0, 1325.0], [192.0, 1485.0], [170.0, 1485.0]]], "lines": ["大船の", "おじいちゃん、", "死んだってさ。"]}], "img_path": "193.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "194.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "195.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [544, 109, 571, 265], "vertical": true, "font_size": 22, "lines_coords": [[[546.0, 112.0], [568.0, 112.0], [568.0, 265.0], [546.0, 265.0]]], "lines": ["小野寺くん！！"]}, {"box": [29, 295, 73, 459], "vertical": true, "font_size": 44, "lines_coords": [[[29.0, 295.0], [73.0, 295.0], [73.0, 459.0], [29.0, 459.0]]], "lines": ["第５６話"]}, {"box": [889, 442, 995, 628], "vertical": true, "font_size": 22, "lines_coords": [[[973.0, 442.0], [995.0, 442.0], [995.0, 557.0], [973.0, 557.0]], [[945.0, 443.0], [967.0, 443.0], [967.0, 606.0], [945.0, 606.0]], [[917.0, 443.0], [939.0, 443.0], [939.0, 604.0], [917.0, 604.0]], [[889.0, 442.0], [909.0, 442.0], [909.0, 628.0], [889.0, 628.0]]], "lines": ["．．．ちょうど", "良かったぁー", "教室まで捜しに", "行ったんだけど．．．"]}, {"box": [815, 639, 867, 801], "vertical": true, "font_size": 22, "lines_coords": [[[845.0, 639.0], [867.0, 639.0], [867.0, 801.0], [845.0, 801.0]], [[815.0, 639.0], [837.0, 639.0], [837.0, 757.0], [815.0, 757.0]]], "lines": ["ごめんね、帰り", "急いでた？"]}, {"box": [240, 457, 333, 646], "vertical": true, "font_size": 27, "lines_coords": [[[304.0, 457.0], [331.0, 457.0], [331.0, 642.0], [304.0, 642.0]], [[271.0, 457.0], [298.0, 457.0], [298.0, 639.0], [271.0, 639.0]], [[240.0, 457.0], [268.0, 457.0], [268.0, 587.0], [240.0, 587.0]]], "lines": ["愛江ちゃーん", "早く行こうって", "ばァー！！"]}, {"box": [635, 1071, 664, 1237], "vertical": true, "font_size": 27, "lines_coords": [[[635.0, 1071.0], [662.0, 1071.0], [662.0, 1237.0], [635.0, 1237.0]]], "lines": ["小野寺くんて、"]}, {"box": [164, 749, 220, 932], "vertical": true, "font_size": 21, "lines_coords": [[[195.0, 750.0], [217.0, 750.0], [217.0, 881.0], [195.0, 881.0]], [[164.0, 750.0], [184.0, 750.0], [184.0, 931.0], [164.0, 931.0]]], "lines": ["きのうの話", "なんだけどさ．．．"]}, {"box": [328, 1401, 481, 1560], "vertical": true, "font_size": 31, "lines_coords": [[[445.0, 1401.0], [481.0, 1401.0], [481.0, 1470.0], [445.0, 1470.0]], [[390.0, 1404.0], [423.0, 1404.0], [423.0, 1487.0], [390.0, 1487.0]], [[360.0, 1406.0], [387.0, 1406.0], [387.0, 1560.0], [360.0, 1560.0]], [[328.0, 1404.0], [356.0, 1404.0], [356.0, 1518.0], [328.0, 1518.0]]], "lines": ["正直、", "全っ然", "興味あったり", "しません。"]}, {"box": [140, 1168, 200, 1349], "vertical": true, "font_size": 24, "lines_coords": [[[171.0, 1170.0], [198.0, 1170.0], [198.0, 1301.0], [171.0, 1301.0]], [[140.0, 1168.0], [162.0, 1168.0], [162.0, 1346.0], [140.0, 1346.0]]], "lines": ["絵とか興味", "あったりする？"]}, {"box": [253, 1403, 277, 1509], "vertical": true, "font_size": 23, "lines_coords": [[[253.0, 1443.0], [276.0, 1443.0], [276.0, 1507.0], [253.0, 1507.0]]], "lines": ["．．．か！！"]}], "img_path": "196.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [923, 103, 984, 207], "vertical": true, "font_size": 26, "lines_coords": [[[956.0, 104.0], [984.0, 104.0], [984.0, 207.0], [956.0, 207.0]], [[923.0, 103.0], [956.0, 103.0], [956.0, 195.0], [923.0, 195.0]]], "lines": ["．．．今度の", "週末さ、"]}, {"box": [759, 173, 879, 389], "vertical": true, "font_size": 26, "lines_coords": [[[857.0, 175.0], [879.0, 175.0], [879.0, 382.0], [857.0, 382.0]], [[825.0, 173.0], [851.0, 173.0], [851.0, 304.0], [825.0, 304.0]], [[793.0, 176.0], [815.0, 176.0], [815.0, 389.0], [793.0, 389.0]], [[759.0, 173.0], [785.0, 173.0], [789.0, 290.0], [762.0, 290.0]]], "lines": ["ウチのお姉ちゃんが", "参加してる", "グループ展の展示が", "あるんだ。"]}, {"box": [278, 107, 300, 259], "vertical": true, "font_size": 23, "lines_coords": [[[278.0, 107.0], [300.0, 107.0], [300.0, 259.0], [278.0, 259.0]]], "lines": ["よかったら．．"]}, {"box": [153, 276, 207, 404], "vertical": true, "font_size": 23, "lines_coords": [[[181.0, 276.0], [207.0, 276.0], [207.0, 404.0], [181.0, 404.0]], [[153.0, 276.0], [175.0, 276.0], [175.0, 404.0], [153.0, 404.0]]], "lines": ["一緒に観に", "行かない？"]}, {"box": [903, 973, 993, 1125], "vertical": true, "font_size": 27, "lines_coords": [[[965.0, 975.0], [993.0, 975.0], [993.0, 1007.0], [965.0, 1007.0]], [[934.0, 973.0], [960.0, 973.0], [960.0, 1123.0], [934.0, 1123.0]], [[903.0, 975.0], [929.0, 975.0], [929.0, 1087.0], [903.0, 1087.0]]], "lines": ["あ", "メンゴメンズ", "お待たせ。"]}, {"box": [653, 1023, 681, 1128], "vertical": true, "font_size": 28, "lines_coords": [[[653.0, 1023.0], [681.0, 1023.0], [681.0, 1128.0], [653.0, 1128.0]]], "lines": ["待った？"]}, {"box": [534, 1053, 593, 1195], "vertical": true, "font_size": 28, "lines_coords": [[[565.0, 1054.0], [593.0, 1054.0], [593.0, 1195.0], [565.0, 1195.0]], [[534.0, 1053.0], [562.0, 1053.0], [562.0, 1156.0], [534.0, 1156.0]]], "lines": ["．．．何、ニヤけ", "てんの？"]}, {"box": [145, 1095, 173, 1210], "vertical": true, "font_size": 26, "lines_coords": [[[145.0, 1095.0], [171.0, 1095.0], [171.0, 1209.0], [145.0, 1209.0]]], "lines": ["気色悪い。"]}, {"box": [95, 1378, 191, 1511], "vertical": true, "font_size": 29, "lines_coords": [[[168.0, 1384.0], [190.0, 1384.0], [190.0, 1509.0], [168.0, 1509.0]], [[134.0, 1382.0], [160.0, 1382.0], [160.0, 1493.0], [134.0, 1493.0]], [[95.0, 1378.0], [135.0, 1378.0], [135.0, 1453.0], [95.0, 1453.0]]], "lines": ["．．．さっさと", "行くわよ、", "大船。"]}], "img_path": "197.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [881, 62, 971, 216], "vertical": true, "font_size": 27, "lines_coords": [[[943.0, 65.0], [971.0, 65.0], [971.0, 178.0], [943.0, 178.0]], [[910.0, 62.0], [937.0, 62.0], [937.0, 215.0], [910.0, 215.0]], [[881.0, 64.0], [907.0, 64.0], [907.0, 193.0], [881.0, 193.0]]], "lines": ["．．．アンタ、", "あの家行くの", "何年振り？"]}, {"box": [500, 79, 623, 298], "vertical": true, "font_size": 25, "lines_coords": [[[596.0, 79.0], [623.0, 79.0], [623.0, 218.0], [596.0, 218.0]], [[564.0, 81.0], [590.0, 81.0], [590.0, 287.0], [564.0, 287.0]], [[531.0, 79.0], [557.0, 79.0], [557.0, 298.0], [531.0, 298.0]], [[500.0, 79.0], [521.0, 79.0], [521.0, 284.0], [500.0, 284.0]]], "lines": ["．．．ていうか、", "おじいちゃんの顔", "なんて、もう憶えて", "ないんじゃない？"]}, {"box": [348, 123, 470, 331], "vertical": true, "font_size": 25, "lines_coords": [[[442.0, 126.0], [470.0, 126.0], [470.0, 239.0], [442.0, 239.0]], [[407.0, 123.0], [434.0, 123.0], [434.0, 331.0], [407.0, 331.0]], [[379.0, 125.0], [401.0, 125.0], [401.0, 304.0], [379.0, 304.0]], [[348.0, 125.0], [370.0, 125.0], [370.0, 279.0], [348.0, 279.0]]], "lines": ["．．．．．．まァ、", "真面目で面白くも", "なんともない人", "だったしね．．．"]}, {"box": [171, 115, 320, 203], "vertical": false, "font_size": 50, "lines_coords": [[[171.0, 126.0], [314.0, 115.0], [320.0, 192.0], [178.0, 203.0]], [[221.0, 176.0], [268.0, 176.0], [268.0, 198.0], [221.0, 198.0]]], "lines": ["駅船３０代大のＷｅｂの大の", "．．．"]}, {"box": [98, 451, 221, 658], "vertical": true, "font_size": 28, "lines_coords": [[[193.0, 453.0], [220.0, 453.0], [220.0, 634.0], [193.0, 634.0]], [[160.0, 451.0], [187.0, 451.0], [187.0, 657.0], [160.0, 657.0]], [[126.0, 451.0], [157.0, 451.0], [157.0, 648.0], [126.0, 648.0]], [[98.0, 451.0], [125.0, 451.0], [125.0, 620.0], [98.0, 620.0]]], "lines": ["．．．風呂場で倒れ", "でるの見つけた時", "には、もう手遅れ", "だったってさ。"]}, {"box": [875, 737, 935, 868], "vertical": true, "font_size": 29, "lines_coords": [[[903.0, 739.0], [935.0, 739.0], [935.0, 845.0], [903.0, 845.0]], [[875.0, 737.0], [901.0, 737.0], [901.0, 868.0], [875.0, 868.0]]], "lines": ["．．．．．．ねぇ", "アンタ．．．"]}, {"box": [243, 870, 316, 1001], "vertical": true, "font_size": 28, "lines_coords": [[[273.0, 870.0], [301.0, 870.0], [303.0, 1001.0], [275.0, 1001.0]], [[243.0, 871.0], [270.0, 871.0], [270.0, 1001.0], [243.0, 1001.0]]], "lines": ["相槌くらい", "打ったら？"]}], "img_path": "198.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [925, 135, 956, 176], "vertical": true, "font_size": 24, "lines_coords": [[[925.0, 135.0], [956.0, 135.0], [956.0, 176.0], [925.0, 176.0]]], "lines": ["ま、"]}, {"box": [804, 207, 882, 423], "vertical": true, "font_size": 24, "lines_coords": [[[860.0, 207.0], [882.0, 207.0], [882.0, 323.0], [860.0, 323.0]], [[832.0, 207.0], [854.0, 207.0], [854.0, 423.0], [832.0, 423.0]], [[804.0, 207.0], [826.0, 207.0], [826.0, 407.0], [804.0, 407.0]]], "lines": ["本人的には", "良かったんじゃない？", "案外ポックリ逝けて。"]}, {"box": [132, 720, 257, 928], "vertical": true, "font_size": 24, "lines_coords": [[[223.0, 721.0], [250.0, 721.0], [250.0, 914.0], [223.0, 914.0]], [[190.0, 721.0], [212.0, 721.0], [212.0, 928.0], [190.0, 928.0]], [[162.0, 721.0], [184.0, 721.0], [184.0, 906.0], [162.0, 906.0]], [[132.0, 721.0], [156.0, 721.0], [159.0, 825.0], [135.0, 825.0]]], "lines": ["若い時に癌やって、", "脳梗塞も２回やって", "体ボロボロだった", "からサア。"]}, {"box": [273, 1123, 382, 1309], "vertical": true, "font_size": 22, "lines_coords": [[[360.0, 1128.0], [382.0, 1128.0], [382.0, 1300.0], [360.0, 1300.0]], [[332.0, 1128.0], [354.0, 1128.0], [354.0, 1292.0], [332.0, 1292.0]], [[304.0, 1125.0], [326.0, 1125.0], [326.0, 1309.0], [304.0, 1309.0]], [[273.0, 1123.0], [300.0, 1123.0], [300.0, 1220.0], [273.0, 1220.0]]], "lines": ["そのくせ、子供に", "面倒みられたく", "ないって人だった", "てしょ？"]}, {"box": [145, 1289, 250, 1510], "vertical": true, "font_size": 22, "lines_coords": [[[228.0, 1289.0], [250.0, 1289.0], [250.0, 1510.0], [228.0, 1510.0]], [[198.0, 1290.0], [220.0, 1290.0], [220.0, 1500.0], [198.0, 1500.0]], [[170.0, 1289.0], [192.0, 1289.0], [192.0, 1496.0], [170.0, 1496.0]], [[145.0, 1289.0], [165.0, 1289.0], [165.0, 1495.0], [145.0, 1495.0]]], "lines": ["強がってんじゃねーよ", "って感じだったけど、", "手間かかんないのは", "ラッキーだったかな。"]}], "img_path": "199.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [853, 51, 962, 259], "vertical": true, "font_size": 23, "lines_coords": [[[935.0, 53.0], [962.0, 53.0], [962.0, 153.0], [935.0, 153.0]], [[910.0, 53.0], [932.0, 53.0], [932.0, 192.0], [910.0, 192.0]], [[881.0, 51.0], [903.0, 51.0], [903.0, 259.0], [881.0, 259.0]], [[853.0, 51.0], [875.0, 51.0], [875.0, 246.0], [853.0, 246.0]]], "lines": ["．．．なんか、", "結局最後まで", "すきま風が吹いてる", "親子関係だったわ。"]}, {"box": [715, 73, 801, 268], "vertical": true, "font_size": 23, "lines_coords": [[[775.0, 73.0], [801.0, 73.0], [801.0, 250.0], [775.0, 250.0]], [[742.0, 78.0], [764.0, 78.0], [764.0, 259.0], [742.0, 259.0]], [[715.0, 75.0], [735.0, 75.0], [735.0, 268.0], [715.0, 268.0]]], "lines": ["仕方無いわよね。", "血が繋がってても", "他人は他人だもの。"]}, {"box": [554, 56, 610, 220], "vertical": true, "font_size": 24, "lines_coords": [[[587.0, 59.0], [609.0, 59.0], [609.0, 220.0], [587.0, 220.0]], [[557.0, 56.0], [584.0, 56.0], [581.0, 195.0], [554.0, 195.0]]], "lines": ["ホントに申し訳", "ないです．．．"]}, {"box": [90, 167, 226, 356], "vertical": true, "font_size": 22, "lines_coords": [[[200.0, 170.0], [226.0, 170.0], [226.0, 310.0], [200.0, 310.0]], [[173.0, 170.0], [195.0, 170.0], [195.0, 356.0], [173.0, 356.0]], [[146.0, 167.0], [168.0, 167.0], [165.0, 356.0], [143.0, 356.0]], [[117.0, 170.0], [139.0, 170.0], [139.0, 331.0], [117.0, 331.0]], [[90.0, 168.0], [110.0, 168.0], [110.0, 309.0], [90.0, 309.0]]], "lines": ["私達が旅行で", "出かけてなければ", "もっと早く見つけ", "られたかもしれ", "ないのに．．．"]}, {"box": [926, 686, 956, 789], "vertical": true, "font_size": 28, "lines_coords": [[[926.0, 687.0], [954.0, 687.0], [954.0, 789.0], [926.0, 789.0]]], "lines": ["雄一は？"]}, {"box": [134, 439, 223, 571], "vertical": true, "font_size": 26, "lines_coords": [[[196.0, 443.0], [223.0, 443.0], [223.0, 556.0], [196.0, 556.0]], [[164.0, 439.0], [190.0, 439.0], [190.0, 571.0], [164.0, 571.0]], [[134.0, 439.0], [160.0, 439.0], [160.0, 542.0], [134.0, 542.0]]], "lines": ["いいのよ。", "これも寿命", "でしょ？"]}, {"box": [789, 837, 911, 992], "vertical": true, "font_size": 25, "lines_coords": [[[884.0, 837.0], [910.0, 837.0], [910.0, 981.0], [884.0, 981.0]], [[851.0, 839.0], [878.0, 839.0], [878.0, 992.0], [851.0, 992.0]], [[821.0, 839.0], [843.0, 839.0], [843.0, 964.0], [821.0, 964.0]], [[789.0, 837.0], [815.0, 837.0], [815.0, 951.0], [789.0, 951.0]]], "lines": ["．．．あ、２階で", "葬儀屋さんと", "打ち合わせ", "してます。"]}, {"box": [167, 873, 259, 1028], "vertical": true, "font_size": 25, "lines_coords": [[[231.0, 879.0], [259.0, 879.0], [256.0, 1017.0], [228.0, 1017.0]], [[200.0, 875.0], [226.0, 875.0], [226.0, 1028.0], [200.0, 1028.0]], [[167.0, 873.0], [195.0, 873.0], [195.0, 962.0], [167.0, 962.0]]], "lines": ["一応、あたし", "軽く顔出して", "くるわ。"]}, {"box": [125, 1101, 232, 1287], "vertical": true, "font_size": 25, "lines_coords": [[[210.0, 1103.0], [232.0, 1103.0], [232.0, 1275.0], [210.0, 1275.0]], [[179.0, 1103.0], [206.0, 1103.0], [206.0, 1287.0], [179.0, 1287.0]], [[153.0, 1101.0], [175.0, 1101.0], [176.0, 1262.0], [154.0, 1262.0]], [[125.0, 1101.0], [146.0, 1101.0], [148.0, 1251.0], [126.0, 1251.0]]], "lines": ["この後、ちょっと", "別の予定があって", "早目に出なきゃ", "なんないのよ。"]}, {"box": [615, 1340, 735, 1521], "vertical": true, "font_size": 25, "lines_coords": [[[706.0, 1340.0], [732.0, 1340.0], [735.0, 1493.0], [709.0, 1493.0]], [[675.0, 1342.0], [701.0, 1342.0], [704.0, 1470.0], [678.0, 1470.0]], [[645.0, 1342.0], [671.0, 1342.0], [671.0, 1520.0], [645.0, 1520.0]], [[615.0, 1343.0], [637.0, 1343.0], [637.0, 1506.0], [615.0, 1506.0]]], "lines": ["．．．フンフンは", "いまひとつ", "状況が飲み込め", "ませんでした。"]}, {"box": [314, 1337, 471, 1522], "vertical": true, "font_size": 28, "lines_coords": [[[442.0, 1343.0], [468.0, 1343.0], [468.0, 1521.0], [442.0, 1521.0]], [[410.0, 1342.0], [437.0, 1342.0], [437.0, 1521.0], [410.0, 1521.0]], [[378.0, 1342.0], [404.0, 1342.0], [404.0, 1495.0], [378.0, 1495.0]], [[346.0, 1342.0], [375.0, 1342.0], [375.0, 1446.0], [346.0, 1446.0]], [[314.0, 1337.0], [346.0, 1337.0], [346.0, 1384.0], [314.0, 1384.0]]], "lines": ["雄一おしさんは", "一体いつの間に", "帰ってきたの", "だろうか", "と。"]}], "img_path": "200.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [164, 129, 321, 389], "vertical": true, "font_size": 24, "lines_coords": [[[293.0, 131.0], [320.0, 131.0], [320.0, 337.0], [293.0, 337.0]], [[259.0, 129.0], [285.0, 129.0], [285.0, 337.0], [259.0, 337.0]], [[229.0, 129.0], [251.0, 129.0], [251.0, 335.0], [229.0, 335.0]], [[198.0, 131.0], [220.0, 131.0], [220.0, 389.0], [198.0, 389.0]], [[167.0, 131.0], [189.0, 131.0], [189.0, 373.0], [167.0, 373.0]]], "lines": ["二度と会うことは", "ないと思っていた", "翠ちゃんは、何故", "当然のようにこの家に", "居るのだろうか、と。"]}, {"box": [837, 681, 928, 848], "vertical": true, "font_size": 24, "lines_coords": [[[900.0, 681.0], [926.0, 681.0], [926.0, 814.0], [900.0, 814.0]], [[867.0, 682.0], [893.0, 682.0], [893.0, 839.0], [867.0, 839.0]], [[839.0, 684.0], [860.0, 684.0], [860.0, 846.0], [839.0, 846.0]]], "lines": ["ブンブンは", "ほのかに動揺", "していました。"]}], "img_path": "201.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [425, 104, 456, 162], "vertical": true, "font_size": 32, "lines_coords": [[[425.0, 104.0], [456.0, 104.0], [456.0, 162.0], [425.0, 162.0]]], "lines": ["．．．あ、"]}, {"box": [343, 117, 376, 228], "vertical": true, "font_size": 32, "lines_coords": [[[343.0, 117.0], [376.0, 117.0], [376.0, 228.0], [343.0, 228.0]]], "lines": ["そうそう"]}, {"box": [885, 678, 964, 885], "vertical": true, "font_size": 22, "lines_coords": [[[942.0, 681.0], [964.0, 681.0], [964.0, 885.0], [942.0, 885.0]], [[912.0, 678.0], [934.0, 678.0], [934.0, 875.0], [912.0, 875.0]], [[885.0, 678.0], [906.0, 678.0], [906.0, 868.0], [885.0, 868.0]]], "lines": ["お義父さんのことも", "あるから、式は当分", "しないと思うけど、"]}, {"box": [82, 445, 177, 589], "vertical": true, "font_size": 29, "lines_coords": [[[150.0, 446.0], [176.0, 446.0], [176.0, 576.0], [150.0, 576.0]], [[115.0, 445.0], [143.0, 445.0], [145.0, 589.0], [117.0, 589.0]], [[82.0, 445.0], [115.0, 445.0], [115.0, 526.0], [82.0, 526.0]]], "lines": ["プンプンに", "お土産、渡す", "ね．．．"]}, {"box": [829, 932, 907, 1096], "vertical": true, "font_size": 22, "lines_coords": [[[885.0, 934.0], [907.0, 934.0], [907.0, 1096.0], [885.0, 1096.0]], [[856.0, 934.0], [882.0, 934.0], [882.0, 1096.0], [856.0, 1096.0]], [[829.0, 932.0], [850.0, 932.0], [850.0, 1073.0], [829.0, 1073.0]]], "lines": ["．．．．．．一応、新婚", "旅行ってことに", "なるのかな？"]}, {"box": [134, 743, 244, 943], "vertical": true, "font_size": 22, "lines_coords": [[[220.0, 746.0], [242.0, 746.0], [242.0, 906.0], [220.0, 906.0]], [[190.0, 746.0], [212.0, 746.0], [212.0, 885.0], [190.0, 885.0]], [[164.0, 746.0], [184.0, 746.0], [184.0, 943.0], [164.0, 943.0]], [[135.0, 743.0], [157.0, 743.0], [156.0, 907.0], [134.0, 907.0]]], "lines": ["群馬のさびれた", "温泉宿だから", "そんな大それた感じ", "じゃないけど．．"]}, {"box": [152, 1029, 478, 1207], "vertical": false, "font_size": 195, "lines_coords": [[[152.0, 1012.0], [478.0, 1012.0], [478.0, 1224.0], [152.0, 1224.0]]], "lines": ["いや．．．"]}, {"box": [257, 1292, 284, 1412], "vertical": true, "font_size": 26, "lines_coords": [[[257.0, 1292.0], [284.0, 1292.0], [284.0, 1412.0], [257.0, 1412.0]]], "lines": ["．．．あれ？"]}, {"box": [107, 1357, 206, 1540], "vertical": true, "font_size": 26, "lines_coords": [[[178.0, 1359.0], [206.0, 1359.0], [206.0, 1489.0], [178.0, 1489.0]], [[143.0, 1362.0], [165.0, 1362.0], [165.0, 1540.0], [143.0, 1540.0]], [[110.0, 1357.0], [137.0, 1357.0], [134.0, 1515.0], [107.0, 1515.0]]], "lines": ["もしかして", "お義姉さんから", "聞いてない？"]}], "img_path": "202.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [881, 124, 932, 251], "vertical": true, "font_size": 40, "lines_coords": [[[881.0, 140.0], [921.0, 135.0], [932.0, 246.0], [892.0, 251.0]]], "lines": ["．．．私、"]}, {"box": [201, 335, 289, 535], "vertical": true, "font_size": 41, "lines_coords": [[[242.0, 335.0], [285.0, 335.0], [289.0, 487.0], [245.0, 487.0]], [[204.0, 335.0], [243.0, 335.0], [240.0, 535.0], [201.0, 535.0]]], "lines": ["雄一君と", "入籍したの。"]}, {"box": [925, 870, 953, 974], "vertical": true, "font_size": 28, "lines_coords": [[[925.0, 870.0], [953.0, 870.0], [953.0, 973.0], [925.0, 973.0]]], "lines": ["やだ．．．"]}, {"box": [165, 914, 226, 1095], "vertical": true, "font_size": 27, "lines_coords": [[[198.0, 915.0], [225.0, 915.0], [225.0, 1071.0], [198.0, 1071.0]], [[167.0, 914.0], [193.0, 914.0], [192.0, 1095.0], [165.0, 1095.0]]], "lines": ["ホントに何も", "聞いてないの？"]}, {"box": [909, 1206, 970, 1309], "vertical": true, "font_size": 28, "lines_coords": [[[942.0, 1206.0], [970.0, 1206.0], [970.0, 1307.0], [942.0, 1307.0]], [[909.0, 1206.0], [937.0, 1206.0], [937.0, 1309.0], [909.0, 1309.0]]], "lines": ["あの日の", "翌日．．．"]}, {"box": [810, 1306, 871, 1434], "vertical": true, "font_size": 28, "lines_coords": [[[843.0, 1306.0], [871.0, 1306.0], [871.0, 1434.0], [843.0, 1434.0]], [[810.0, 1307.0], [837.0, 1307.0], [837.0, 1434.0], [810.0, 1434.0]]], "lines": ["あの日って", "いうか．．．．．"]}, {"box": [257, 1193, 371, 1404], "vertical": true, "font_size": 29, "lines_coords": [[[335.0, 1193.0], [371.0, 1193.0], [368.0, 1404.0], [332.0, 1404.0]], [[296.0, 1196.0], [328.0, 1196.0], [328.0, 1403.0], [296.0, 1403.0]], [[260.0, 1195.0], [289.0, 1195.0], [285.0, 1350.0], [257.0, 1350.0]]], "lines": ["プンプンが最後に", "お店に遊びに来た", "日の翌日．．．"]}, {"box": [142, 1348, 232, 1531], "vertical": true, "font_size": 29, "lines_coords": [[[200.0, 1348.0], [232.0, 1348.0], [232.0, 1439.0], [200.0, 1439.0]], [[170.0, 1350.0], [196.0, 1350.0], [196.0, 1531.0], [170.0, 1531.0]], [[142.0, 1351.0], [164.0, 1351.0], [164.0, 1478.0], [142.0, 1478.0]]], "lines": ["雄一君、", "ふらっと帰って", "来てさ．．．"]}], "img_path": "203.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [956, 84, 987, 225], "vertical": true, "font_size": 30, "lines_coords": [[[956.0, 84.0], [984.0, 84.0], [987.0, 225.0], [959.0, 225.0]]], "lines": ["．．．雄一君ね、"]}, {"box": [792, 168, 920, 331], "vertical": true, "font_size": 30, "lines_coords": [[[878.0, 168.0], [920.0, 168.0], [920.0, 217.0], [878.0, 217.0]], [[850.0, 171.0], [881.0, 171.0], [881.0, 331.0], [850.0, 331.0]], [[820.0, 175.0], [846.0, 175.0], [846.0, 304.0], [820.0, 304.0]], [[792.0, 175.0], [814.0, 175.0], [814.0, 285.0], [792.0, 285.0]]], "lines": ["今、", "軽いうつ病で", "病院に通院", "してるの。"]}, {"box": [367, 60, 394, 217], "vertical": true, "font_size": 26, "lines_coords": [[[367.0, 62.0], [393.0, 62.0], [393.0, 215.0], [367.0, 215.0]]], "lines": ["なーんて．．．"]}, {"box": [142, 142, 198, 269], "vertical": true, "font_size": 22, "lines_coords": [[[173.0, 142.0], [195.0, 142.0], [195.0, 268.0], [173.0, 268.0]], [[142.0, 142.0], [164.0, 142.0], [164.0, 268.0], [142.0, 268.0]]], "lines": ["それは冗談", "だけど．．．"]}, {"box": [910, 439, 979, 586], "vertical": true, "font_size": 35, "lines_coords": [[[928.0, 443.0], [971.0, 439.0], [979.0, 514.0], [935.0, 518.0]], [[910.0, 445.0], [937.0, 445.0], [937.0, 585.0], [910.0, 585.0]]], "lines": ["．．．私、", "決めたんだ。"]}, {"box": [917, 725, 944, 863], "vertical": true, "font_size": 26, "lines_coords": [[[917.0, 726.0], [943.0, 726.0], [943.0, 860.0], [917.0, 860.0]]], "lines": ["．．．でも私ね、"]}, {"box": [507, 484, 614, 662], "vertical": true, "font_size": 23, "lines_coords": [[[592.0, 487.0], [614.0, 487.0], [614.0, 623.0], [592.0, 623.0]], [[560.0, 484.0], [584.0, 484.0], [585.0, 662.0], [562.0, 662.0]], [[532.0, 485.0], [556.0, 485.0], [557.0, 646.0], [534.0, 646.0]], [[507.0, 485.0], [529.0, 485.0], [529.0, 610.0], [507.0, 610.0]]], "lines": ["あの人は一生", "私の手の平の中で", "飼い殺しにして", "やろうって。"]}, {"box": [910, 1085, 940, 1240], "vertical": true, "font_size": 29, "lines_coords": [[[910.0, 1085.0], [939.0, 1085.0], [939.0, 1237.0], [910.0, 1237.0]]], "lines": ["だから．．．"]}, {"box": [164, 784, 225, 939], "vertical": true, "font_size": 28, "lines_coords": [[[195.0, 784.0], [225.0, 784.0], [225.0, 939.0], [195.0, 939.0]], [[164.0, 784.0], [190.0, 784.0], [190.0, 900.0], [164.0, 900.0]]], "lines": ["今、すっごく", "幸せなの。"]}, {"box": [142, 1292, 172, 1475], "vertical": true, "font_size": 26, "lines_coords": [[[142.0, 1293.0], [168.0, 1293.0], [168.0, 1473.0], [142.0, 1473.0]]], "lines": ["わかるよね？"]}], "img_path": "204.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [578, 810, 732, 1051], "vertical": true, "font_size": 25, "lines_coords": [[[707.0, 814.0], [729.0, 814.0], [729.0, 967.0], [707.0, 967.0]], [[671.0, 810.0], [698.0, 810.0], [700.0, 992.0], [673.0, 992.0]], [[639.0, 810.0], [667.0, 810.0], [668.0, 967.0], [640.0, 967.0]], [[609.0, 812.0], [635.0, 812.0], [635.0, 967.0], [609.0, 967.0]], [[579.0, 812.0], [601.0, 812.0], [601.0, 1046.0], [579.0, 1046.0]]], "lines": ["今、この瞬間", "この人の陰毛と", "クリトリスを", "むしり取って", "トフに投げ捨てたら"]}, {"box": [357, 810, 482, 1043], "vertical": true, "font_size": 28, "lines_coords": [[[454.0, 810.0], [482.0, 810.0], [482.0, 917.0], [454.0, 917.0]], [[423.0, 812.0], [450.0, 812.0], [450.0, 1043.0], [423.0, 1043.0]], [[392.0, 812.0], [418.0, 812.0], [418.0, 992.0], [392.0, 992.0]], [[357.0, 810.0], [390.0, 810.0], [390.0, 904.0], [357.0, 904.0]]], "lines": ["どんなに", "気持ちいいだろうと", "フンフンは思い", "ました。"]}, {"box": [382, 1135, 417, 1206], "vertical": true, "font_size": 35, "lines_coords": [[[382.0, 1135.0], [417.0, 1135.0], [417.0, 1206.0], [382.0, 1206.0]]], "lines": ["うん。"]}, {"box": [475, 1171, 600, 1406], "vertical": true, "font_size": 27, "lines_coords": [[[570.0, 1171.0], [596.0, 1171.0], [600.0, 1328.0], [573.0, 1328.0]], [[540.0, 1173.0], [567.0, 1173.0], [567.0, 1378.0], [540.0, 1378.0]], [[506.0, 1171.0], [534.0, 1171.0], [535.0, 1406.0], [507.0, 1406.0]], [[475.0, 1171.0], [501.0, 1171.0], [503.0, 1385.0], [476.0, 1385.0]]], "lines": ["けれど何故か", "口から出た言葉は", "「おめでとう」の一言", "だけだったのです。"]}, {"box": [120, 1407, 149, 1521], "vertical": true, "font_size": 26, "lines_coords": [[[120.0, 1407.0], [146.0, 1407.0], [146.0, 1520.0], [120.0, 1520.0]]], "lines": ["ありがと。"]}], "img_path": "205.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [179, 579, 239, 759], "vertical": true, "font_size": 27, "lines_coords": [[[212.0, 579.0], [239.0, 579.0], [239.0, 740.0], [212.0, 740.0]], [[179.0, 579.0], [206.0, 579.0], [206.0, 759.0], [179.0, 759.0]]], "lines": ["何やってんの、", "早く行くわよ！！"]}, {"box": [914, 1276, 978, 1412], "vertical": true, "font_size": 29, "lines_coords": [[[939.0, 1276.0], [978.0, 1276.0], [978.0, 1364.0], [939.0, 1364.0]], [[914.0, 1282.0], [940.0, 1282.0], [940.0, 1412.0], [914.0, 1412.0]]], "lines": ["．．．ねぇ", "プンプン．．．"]}, {"box": [782, 1331, 876, 1515], "vertical": true, "font_size": 29, "lines_coords": [[[850.0, 1331.0], [876.0, 1331.0], [876.0, 1515.0], [850.0, 1515.0]], [[818.0, 1331.0], [845.0, 1331.0], [845.0, 1473.0], [818.0, 1473.0]], [[785.0, 1331.0], [812.0, 1331.0], [809.0, 1460.0], [782.0, 1460.0]]], "lines": ["アンタさっきから", "何、カリカリ", "してんの？"]}, {"box": [95, 1332, 217, 1514], "vertical": true, "font_size": 23, "lines_coords": [[[190.0, 1334.0], [212.0, 1334.0], [212.0, 1487.0], [190.0, 1487.0]], [[156.0, 1332.0], [182.0, 1332.0], [182.0, 1464.0], [156.0, 1464.0]], [[126.0, 1334.0], [148.0, 1334.0], [148.0, 1514.0], [126.0, 1514.0]], [[95.0, 1335.0], [117.0, 1335.0], [117.0, 1512.0], [95.0, 1512.0]]], "lines": ["そういう態度", "とられると", "あたしまで気分", "悪いんだけど？"]}], "img_path": "206.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [926, 128, 1006, 326], "vertical": true, "font_size": 24, "lines_coords": [[[979.0, 128.0], [1006.0, 128.0], [1006.0, 315.0], [979.0, 315.0]], [[953.0, 128.0], [976.0, 128.0], [975.0, 326.0], [951.0, 326.0]], [[926.0, 129.0], [948.0, 129.0], [948.0, 270.0], [926.0, 270.0]]], "lines": ["雄一と翠ちゃんの", "こと、黙ってたから", "怒ってんの？"]}, {"box": [796, 289, 906, 479], "vertical": true, "font_size": 24, "lines_coords": [[[879.0, 289.0], [906.0, 289.0], [906.0, 479.0], [879.0, 479.0]], [[853.0, 290.0], [875.0, 290.0], [875.0, 464.0], [853.0, 464.0]], [[823.0, 289.0], [845.0, 289.0], [845.0, 473.0], [823.0, 473.0]], [[796.0, 289.0], [818.0, 289.0], [818.0, 403.0], [796.0, 403.0]]], "lines": ["隠してた訳じゃない", "わよ？アンタが", "訊かなかったから", "じゃない！！"]}, {"box": [228, 240, 335, 415], "vertical": true, "font_size": 24, "lines_coords": [[[314.0, 245.0], [335.0, 245.0], [335.0, 415.0], [314.0, 415.0]], [[285.0, 243.0], [307.0, 243.0], [307.0, 382.0], [285.0, 382.0]], [[256.0, 243.0], [278.0, 243.0], [278.0, 379.0], [256.0, 379.0]], [[229.0, 240.0], [251.0, 240.0], [250.0, 382.0], [228.0, 382.0]]], "lines": ["アンタ、昔っから", "他人事なんて", "全然興味無い", "くせしてさ！！"]}, {"box": [140, 398, 231, 607], "vertical": true, "font_size": 24, "lines_coords": [[[204.0, 398.0], [231.0, 398.0], [231.0, 607.0], [204.0, 607.0]], [[171.0, 398.0], [198.0, 398.0], [198.0, 581.0], [171.0, 581.0]], [[140.0, 398.0], [167.0, 398.0], [167.0, 581.0], [140.0, 581.0]]], "lines": ["．．．あたしに似て！！", "なんつってか！！", "キャハホホホ！！"]}, {"box": [907, 804, 965, 985], "vertical": true, "font_size": 26, "lines_coords": [[[939.0, 804.0], [965.0, 804.0], [965.0, 921.0], [939.0, 921.0]], [[907.0, 806.0], [934.0, 806.0], [934.0, 985.0], [907.0, 985.0]]], "lines": ["．．．冗談よ。", "笑いなさいよ！"]}, {"box": [759, 828, 851, 1009], "vertical": true, "font_size": 26, "lines_coords": [[[825.0, 828.0], [851.0, 828.0], [850.0, 1009.0], [823.0, 1009.0]], [[792.0, 829.0], [818.0, 829.0], [818.0, 1004.0], [792.0, 1004.0]], [[762.0, 832.0], [785.0, 832.0], [782.0, 957.0], [759.0, 957.0]]], "lines": ["さっきみたいに", "ニヤけやがれっ", "つーの！！"]}, {"box": [943, 1092, 1003, 1223], "vertical": true, "font_size": 27, "lines_coords": [[[978.0, 1093.0], [1000.0, 1093.0], [1000.0, 1220.0], [978.0, 1220.0]], [[943.0, 1092.0], [975.0, 1092.0], [975.0, 1150.0], [943.0, 1150.0]]], "lines": ["．．．それとも", "何？"]}, {"box": [568, 1081, 631, 1212], "vertical": true, "font_size": 31, "lines_coords": [[[596.0, 1081.0], [631.0, 1081.0], [631.0, 1167.0], [596.0, 1167.0]], [[568.0, 1085.0], [595.0, 1085.0], [595.0, 1212.0], [568.0, 1212.0]]], "lines": ["じゃあ", "アンタは．．"]}, {"box": [203, 1106, 264, 1273], "vertical": true, "font_size": 26, "lines_coords": [[[237.0, 1106.0], [264.0, 1106.0], [264.0, 1273.0], [237.0, 1273.0]], [[206.0, 1106.0], [234.0, 1106.0], [231.0, 1235.0], [203.0, 1235.0]]], "lines": ["もし、アタシが", "死んだ時．．"]}, {"box": [676, 1348, 785, 1559], "vertical": true, "font_size": 23, "lines_coords": [[[760.0, 1353.0], [782.0, 1353.0], [782.0, 1490.0], [760.0, 1490.0]], [[731.0, 1348.0], [757.0, 1348.0], [754.0, 1504.0], [728.0, 1504.0]], [[704.0, 1351.0], [726.0, 1351.0], [726.0, 1559.0], [704.0, 1559.0]], [[676.0, 1351.0], [698.0, 1351.0], [698.0, 1467.0], [676.0, 1467.0]]], "lines": ["親が死んだ時", "くらいは、多少", "湿っぽくしたほうが", "良かった？"]}, {"box": [125, 1290, 214, 1448], "vertical": true, "font_size": 26, "lines_coords": [[[185.0, 1292.0], [214.0, 1292.0], [214.0, 1400.0], [185.0, 1400.0]], [[151.0, 1290.0], [179.0, 1290.0], [181.0, 1448.0], [153.0, 1448.0]], [[125.0, 1296.0], [145.0, 1296.0], [145.0, 1446.0], [125.0, 1446.0]]], "lines": ["どれだけ", "悲しめるって", "いうのよ．．．"]}], "img_path": "207.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [829, 37, 856, 181], "vertical": true, "font_size": 30, "lines_coords": [[[829.0, 37.0], [856.0, 37.0], [856.0, 181.0], [829.0, 181.0]]], "lines": ["あー、コレ！！"]}, {"box": [700, 78, 798, 212], "vertical": true, "font_size": 30, "lines_coords": [[[765.0, 79.0], [798.0, 79.0], [798.0, 185.0], [765.0, 185.0]], [[735.0, 79.0], [762.0, 79.0], [762.0, 212.0], [735.0, 212.0]], [[700.0, 78.0], [735.0, 78.0], [735.0, 135.0], [700.0, 135.0]]], "lines": ["さっさと", "渡しておく", "わ！！"]}, {"box": [456, 68, 495, 154], "vertical": true, "font_size": 32, "lines_coords": [[[456.0, 68.0], [495.0, 68.0], [495.0, 154.0], [456.0, 154.0]]], "lines": ["．．．何？"]}, {"box": [548, 334, 642, 465], "vertical": true, "font_size": 26, "lines_coords": [[[614.0, 339.0], [642.0, 339.0], [642.0, 417.0], [614.0, 417.0]], [[581.0, 335.0], [609.0, 335.0], [609.0, 465.0], [581.0, 465.0]], [[548.0, 334.0], [576.0, 334.0], [579.0, 440.0], [551.0, 440.0]]], "lines": ["ハァー", "けったくそ", "悪いっ！！"]}, {"box": [367, 78, 393, 206], "vertical": true, "font_size": 32, "lines_coords": [[[367.0, 78.0], [393.0, 78.0], [393.0, 206.0], [367.0, 206.0]]], "lines": ["なんなの？"]}, {"box": [135, 62, 246, 260], "vertical": true, "font_size": 26, "lines_coords": [[[215.0, 62.0], [243.0, 62.0], [246.0, 167.0], [218.0, 167.0]], [[192.0, 65.0], [214.0, 65.0], [214.0, 228.0], [192.0, 228.0]], [[164.0, 64.0], [185.0, 64.0], [185.0, 226.0], [164.0, 226.0]], [[135.0, 64.0], [157.0, 64.0], [157.0, 260.0], [135.0, 260.0]]], "lines": ["．．．テメー、", "母親に向かって", "ガン飛ばすって", "どういう了見だよ。"]}, {"box": [100, 301, 137, 426], "vertical": true, "font_size": 26, "lines_coords": [[[100.0, 301.0], [137.0, 301.0], [137.0, 426.0], [100.0, 426.0]]], "lines": ["あぁ！？"]}, {"box": [618, 420, 639, 464], "vertical": true, "font_size": 26, "lines_coords": [[[618.0, 420.0], [639.0, 420.0], [639.0, 464.0], [618.0, 464.0]]], "lines": ["！！"]}, {"box": [929, 748, 956, 906], "vertical": true, "font_size": 24, "lines_coords": [[[929.0, 748.0], [956.0, 748.0], [956.0, 906.0], [929.0, 906.0]]], "lines": ["．．．アンタはね、"]}, {"box": [784, 885, 892, 1073], "vertical": true, "font_size": 24, "lines_coords": [[[865.0, 885.0], [892.0, 885.0], [892.0, 1073.0], [865.0, 1073.0]], [[840.0, 887.0], [862.0, 887.0], [862.0, 1060.0], [840.0, 1060.0]], [[812.0, 887.0], [834.0, 887.0], [834.0, 1070.0], [812.0, 1070.0]], [[784.0, 887.0], [804.0, 887.0], [804.0, 1073.0], [784.0, 1073.0]]], "lines": ["わかってるような", "顔して、ホントは", "何もわかってない", "子供なんだから．．．"]}, {"box": [231, 751, 307, 917], "vertical": true, "font_size": 26, "lines_coords": [[[285.0, 753.0], [307.0, 753.0], [307.0, 893.0], [285.0, 893.0]], [[256.0, 753.0], [278.0, 753.0], [278.0, 917.0], [256.0, 917.0]], [[231.0, 751.0], [251.0, 751.0], [251.0, 892.0], [231.0, 892.0]]], "lines": ["．．．これからは", "態度に気を付け", "なさいよ．．．？"]}, {"box": [148, 946, 253, 1189], "vertical": true, "font_size": 26, "lines_coords": [[[226.0, 946.0], [253.0, 946.0], [253.0, 1162.0], [226.0, 1162.0]], [[187.0, 946.0], [218.0, 946.0], [218.0, 1164.0], [187.0, 1164.0]], [[148.0, 950.0], [181.0, 950.0], [181.0, 1189.0], [148.0, 1189.0]]], "lines": ["アンタの家族は", "もうあたししか", "いないんだから！！"]}, {"box": [915, 1325, 976, 1456], "vertical": true, "font_size": 29, "lines_coords": [[[943.0, 1325.0], [976.0, 1325.0], [976.0, 1415.0], [943.0, 1415.0]], [[915.0, 1325.0], [942.0, 1325.0], [942.0, 1456.0], [915.0, 1456.0]]], "lines": ["アンタ、", "なによ．．．"]}, {"box": [853, 1451, 881, 1532], "vertical": true, "font_size": 29, "lines_coords": [[[853.0, 1451.0], [881.0, 1451.0], [881.0, 1532.0], [853.0, 1532.0]]], "lines": ["オイ．．．"]}, {"box": [190, 1296, 253, 1453], "vertical": true, "font_size": 28, "lines_coords": [[[218.0, 1296.0], [253.0, 1296.0], [253.0, 1379.0], [218.0, 1379.0]], [[190.0, 1298.0], [217.0, 1298.0], [217.0, 1453.0], [190.0, 1453.0]]], "lines": ["わっけ", "わかんない．．．"]}, {"box": [101, 1401, 159, 1528], "vertical": true, "font_size": 28, "lines_coords": [[[132.0, 1401.0], [159.0, 1401.0], [159.0, 1514.0], [132.0, 1514.0]], [[101.0, 1401.0], [125.0, 1401.0], [128.0, 1528.0], [104.0, 1528.0]]], "lines": ["．．．なによ、", "その目．．．"]}], "img_path": "208.png"}, {"version": "0.2.0-beta.6", "img_width