"lines": ["２００万もとられ", "ちゃってさ．．．", "バカみたい。"]}], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [921, 96, 1012, 262], "vertical": true, "font_size": 26, "lines_coords": [[[981.0, 96.0], [1007.0, 96.0], [1012.0, 262.0], [985.0, 262.0]], [[953.0, 100.0], [979.0, 100.0], [979.0, 228.0], [953.0, 228.0]], [[921.0, 96.0], [948.0, 96.0], [948.0, 209.0], [921.0, 209.0]]], "lines": ["．．．あの人はさ、", "いくら理屈", "こねても、"]}, {"box": [851, 253, 907, 417], "vertical": true, "font_size": 26, "lines_coords": [[[881.0, 253.0], [907.0, 253.0], [907.0, 393.0], [881.0, 393.0]], [[851.0, 254.0], [873.0, 254.0], [873.0, 417.0], [851.0, 417.0]]], "lines": ["結局、ただの", "女好きなんだ。"]}, {"box": [225, 239, 281, 367], "vertical": true, "font_size": 26, "lines_coords": [[[254.0, 239.0], [281.0, 239.0], [281.0, 367.0], [254.0, 367.0]], [[225.0, 240.0], [253.0, 240.0], [253.0, 329.0], [225.0, 329.0]]], "lines": ["．．．わかって", "たけど、"]}, {"box": [945, 729, 973, 832], "vertical": true, "font_size": 27, "lines_coords": [[[945.0, 729.0], [973.0, 729.0], [973.0, 832.0], [945.0, 832.0]]], "lines": ["．．．また、"]}, {"box": [135, 412, 223, 595], "vertical": true, "font_size": 26, "lines_coords": [[[196.0, 412.0], [223.0, 412.0], [223.0, 595.0], [196.0, 595.0]], [[165.0, 414.0], [192.0, 414.0], [189.0, 570.0], [162.0, 570.0]], [[135.0, 414.0], [157.0, 414.0], [157.0, 568.0], [135.0, 568.0]]], "lines": ["覚悟してたから", "一度くらいは", "許せるけど．．．"]}, {"box": [834, 768, 893, 907], "vertical": true, "font_size": 27, "lines_coords": [[[865.0, 768.0], [893.0, 768.0], [893.0, 875.0], [865.0, 875.0]], [[834.0, 768.0], [860.0, 768.0], [860.0, 907.0], [834.0, 907.0]]], "lines": ["あの人は", "逃げたんだ。"]}, {"box": [919, 1056, 1007, 1235], "vertical": true, "font_size": 22, "lines_coords": [[[982.0, 1056.0], [1004.0, 1056.0], [1004.0, 1207.0], [982.0, 1207.0]], [[951.0, 1056.0], [973.0, 1056.0], [973.0, 1234.0], [951.0, 1234.0]], [[920.0, 1056.0], [942.0, 1056.0], [942.0, 1207.0], [920.0, 1207.0]]], "lines": ["私はあの人を", "変えてあげられ", "なかった．．．"]}, {"box": [135, 823, 227, 950], "vertical": true, "font_size": 28, "lines_coords": [[[198.0, 823.0], [226.0, 823.0], [226.0, 950.0], [198.0, 950.0]], [[167.0, 823.0], [195.0, 823.0], [195.0, 929.0], [167.0, 929.0]], [[135.0, 823.0], [164.0, 823.0], [164.0, 937.0], [135.0, 937.0]]], "lines": ["．．．何ひとつ", "成長して", "なかった。"]}, {"box": [467, 1317, 556, 1446], "vertical": true, "font_size": 27, "lines_coords": [[[523.0, 1317.0], [556.0, 1317.0], [556.0, 1401.0], [523.0, 1401.0]], [[495.0, 1320.0], [521.0, 1320.0], [521.0, 1446.0], [495.0, 1446.0]], [[467.0, 1331.0], [490.0, 1331.0], [490.0, 1373.0], [467.0, 1373.0]]], "lines": ["それが", "一番悲しい", "．．．"]}, {"box": [104, 1379, 168, 1487], "vertical": true, "font_size": 34, "lines_coords": [[[129.0, 1379.0], [168.0, 1379.0], [168.0, 1467.0], [129.0, 1467.0]], [[104.0, 1382.0], [132.0, 1382.0], [132.0, 1485.0], [104.0, 1485.0]]], "lines": ["．．．違う", "かな．．．"]}], "img_path": "077.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [939, 54, 965, 165], "vertical": true, "font_size": 26, "lines_coords": [[[939.0, 54.0], [965.0, 54.0], [965.0, 165.0], [939.0, 165.0]]], "lines": ["ホントは、"]}, {"box": [704, 270, 768, 410], "vertical": true, "font_size": 27, "lines_coords": [[[704.0, 273.0], [731.0, 273.0], [731.0, 410.0], [704.0, 410.0]], [[728.0, 270.0], [768.0, 270.0], [768.0, 359.0], [728.0, 359.0]]], "lines": ["くやしくて、", "．．．ただ"]}, {"box": [388, 85, 443, 267], "vertical": true, "font_size": 24, "lines_coords": [[[414.0, 85.0], [440.0, 85.0], [443.0, 242.0], [417.0, 242.0]], [[389.0, 87.0], [410.0, 87.0], [410.0, 267.0], [389.0, 267.0]]], "lines": ["もしかしたら", "今もこうして．．．"]}, {"box": [928, 742, 954, 857], "vertical": true, "font_size": 28, "lines_coords": [[[928.0, 742.0], [954.0, 742.0], [954.0, 857.0], [928.0, 857.0]]], "lines": ["．．．ごめん。"]}, {"box": [642, 456, 759, 668], "vertical": true, "font_size": 27, "lines_coords": [[[737.0, 456.0], [759.0, 456.0], [759.0, 617.0], [737.0, 617.0]], [[703.0, 460.0], [729.0, 460.0], [729.0, 618.0], [703.0, 618.0]], [[671.0, 460.0], [698.0, 460.0], [698.0, 668.0], [671.0, 668.0]], [[642.0, 462.0], [664.0, 462.0], [664.0, 615.0], [642.0, 615.0]]], "lines": ["あの人が一番", "苦しむ方法で", "追い込もうとして", "たのかな．．．"]}, {"box": [86, 460, 208, 664], "vertical": true, "font_size": 22, "lines_coords": [[[182.0, 462.0], [204.0, 462.0], [204.0, 640.0], [182.0, 640.0]], [[150.0, 460.0], [171.0, 460.0], [171.0, 615.0], [150.0, 615.0]], [[118.0, 460.0], [140.0, 460.0], [140.0, 664.0], [118.0, 664.0]], [[87.0, 462.0], [109.0, 462.0], [109.0, 648.0], [87.0, 648.0]]], "lines": ["あの人がもっと", "苦しむ方法を", "どこかで考えてる", "のかもしれない。"]}, {"box": [796, 826, 892, 971], "vertical": true, "font_size": 28, "lines_coords": [[[865.0, 829.0], [892.0, 829.0], [892.0, 959.0], [865.0, 959.0]], [[832.0, 829.0], [859.0, 829.0], [859.0, 971.0], [832.0, 971.0]], [[804.0, 826.0], [834.0, 831.0], [826.0, 887.0], [796.0, 882.0]]], "lines": ["何言ってん", "だろうね、私", "．．．．．"]}, {"box": [287, 839, 326, 945], "vertical": true, "font_size": 28, "lines_coords": [[[287.0, 839.0], [326.0, 839.0], [326.0, 945.0], [287.0, 945.0]]], "lines": ["へへ．．．"]}, {"box": [142, 845, 229, 1051], "vertical": true, "font_size": 28, "lines_coords": [[[203.0, 846.0], [229.0, 846.0], [229.0, 1003.0], [203.0, 1003.0]], [[170.0, 845.0], [196.0, 845.0], [198.0, 1051.0], [171.0, 1051.0]], [[142.0, 845.0], [164.0, 845.0], [164.0, 1025.0], [142.0, 1025.0]]], "lines": ["．．．なんかよく", "わかんなくなって", "きちゃった．．．"]}, {"box": [867, 1168, 959, 1378], "vertical": true, "font_size": 27, "lines_coords": [[[932.0, 1173.0], [959.0, 1173.0], [959.0, 1328.0], [932.0, 1328.0]], [[901.0, 1171.0], [928.0, 1171.0], [928.0, 1378.0], [901.0, 1378.0]], [[870.0, 1168.0], [896.0, 1168.0], [893.0, 1301.0], [867.0, 1301.0]]], "lines": ["自分のことも", "よくわかってない", "くせに．．．"]}, {"box": [214, 1176, 242, 1285], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 1176.0], [242.0, 1176.0], [242.0, 1285.0], [214.0, 1285.0]]], "lines": ["一人前に、"]}, {"box": [79, 1329, 203, 1485], "vertical": true, "font_size": 26, "lines_coords": [[[173.0, 1329.0], [201.0, 1329.0], [203.0, 1462.0], [175.0, 1462.0]], [[142.0, 1331.0], [168.0, 1331.0], [168.0, 1485.0], [142.0, 1485.0]], [[114.0, 1332.0], [135.0, 1332.0], [135.0, 1484.0], [114.0, 1484.0]], [[79.0, 1329.0], [107.0, 1329.0], [107.0, 1412.0], [79.0, 1412.0]]], "lines": ["私は他人と", "わかり合える", "気がしてたん", "だ．．．"]}], "img_path": "078.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [948, 126, 1012, 284], "vertical": true, "font_size": 29, "lines_coords": [[[973.0, 126.0], [1012.0, 126.0], [1012.0, 221.0], [973.0, 221.0]], [[948.0, 126.0], [975.0, 126.0], [975.0, 284.0], [948.0, 284.0]]], "lines": ["．．．．．．ね、", "プンプン．．．"]}, {"box": [842, 237, 898, 390], "vertical": true, "font_size": 29, "lines_coords": [[[871.0, 239.0], [898.0, 239.0], [898.0, 367.0], [871.0, 367.0]], [[842.0, 237.0], [864.0, 237.0], [864.0, 390.0], [842.0, 390.0]]], "lines": ["一番大切な", "ものって何？"]}, {"box": [156, 535, 247, 741], "vertical": true, "font_size": 22, "lines_coords": [[[221.0, 537.0], [243.0, 537.0], [243.0, 665.0], [221.0, 665.0]], [[190.0, 537.0], [212.0, 537.0], [212.0, 740.0], [190.0, 740.0]], [[157.0, 535.0], [181.0, 535.0], [179.0, 690.0], [156.0, 690.0]]], "lines": ["これだけは", "絶対に信じられる", "ものって何？"]}, {"box": [915, 860, 975, 1043], "vertical": true, "font_size": 26, "lines_coords": [[[948.0, 860.0], [975.0, 860.0], [975.0, 1006.0], [948.0, 1006.0]], [[915.0, 862.0], [942.0, 862.0], [942.0, 1043.0], [915.0, 1043.0]]], "lines": ["もし、それを", "見失ったら．．．"]}, {"box": [781, 953, 870, 1135], "vertical": true, "font_size": 26, "lines_coords": [[[848.0, 954.0], [870.0, 954.0], [870.0, 1109.0], [848.0, 1109.0]], [[814.0, 953.0], [840.0, 953.0], [840.0, 1120.0], [814.0, 1120.0]], [[781.0, 953.0], [807.0, 953.0], [807.0, 1135.0], [781.0, 1135.0]]], "lines": ["きっと自分も", "見えなくなっ", "ちゃうから．．．"]}, {"box": [948, 1257, 1006, 1435], "vertical":