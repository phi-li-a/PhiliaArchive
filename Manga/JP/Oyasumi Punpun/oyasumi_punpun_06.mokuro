, 1500], "vertical": true, "font_size": 24, "lines_coords": [[[293.0, 1217.0], [315.0, 1217.0], [315.0, 1495.0], [293.0, 1495.0]], [[257.0, 1237.0], [284.0, 1237.0], [285.0, 1495.0], [259.0, 1495.0]]], "lines": ["．．．そっか、この子．．：", "晴見くんの彼女だ．．．"]}, {"box": [129, 1160, 193, 1320], "vertical": true, "font_size": 27, "lines_coords": [[[160.0, 1160.0], [193.0, 1160.0], [190.0, 1273.0], [157.0, 1273.0]], [[129.0, 1165.0], [156.0, 1165.0], [156.0, 1320.0], [129.0, 1320.0]]], "lines": ["ちょっと", "聞いていい？"]}, {"box": [79, 1375, 170, 1535], "vertical": true, "font_size": 27, "lines_coords": [[[148.0, 1376.0], [170.0, 1376.0], [170.0, 1535.0], [148.0, 1535.0]], [[114.0, 1375.0], [140.0, 1375.0], [140.0, 1506.0], [114.0, 1506.0]], [[82.0, 1375.0], [109.0, 1375.0], [106.0, 1532.0], [79.0, 1532.0]]], "lines": ["その顔の怪我", "どれくらい", "ひどいの．．．？"]}], "img_path": "086.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [912, 109, 975, 267], "vertical": true, "font_size": 26, "lines_coords": [[[948.0, 110.0], [975.0, 110.0], [975.0, 267.0], [948.0, 267.0]], [[915.0, 109.0], [943.0, 109.0], [940.0, 267.0], [912.0, 267.0]]], "lines": ["たいしたこと", "ないです．．．"]}, {"box": [829, 281, 887, 414], "vertical": true, "font_size": 26, "lines_coords": [[[857.0, 281.0], [885.0, 281.0], [887.0, 390.0], [859.0, 390.0]], [[829.0, 285.0], [851.0, 285.0], [851.0, 414.0], [829.0, 414.0]]], "lines": ["もうすぐ", "退院だし．．．"]}, {"box": [204, 140, 262, 332], "vertical": true, "font_size": 25, "lines_coords": [[[240.0, 145.0], [262.0, 145.0], [262.0, 298.0], [240.0, 298.0]], [[206.0, 140.0], [232.0, 140.0], [231.0, 332.0], [204.0, 332.0]]], "lines": ["縫合した跡は", "残るだろうって、"]}, {"box": [775, 598, 834, 792], "vertical": true, "font_size": 27, "lines_coords": [[[806.0, 600.0], [834.0, 600.0], [834.0, 731.0], [806.0, 731.0]], [[775.0, 598.0], [801.0, 598.0], [801.0, 790.0], [775.0, 790.0]]], "lines": ["なんか．．．", "なんかムカつく。"]}, {"box": [600, 598, 660, 790], "vertical": true, "font_size": 29, "lin