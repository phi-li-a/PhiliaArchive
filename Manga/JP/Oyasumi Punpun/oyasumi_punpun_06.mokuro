.0, 1220.0]]], "lines": ["へえー", "その時も気胸で", "入院ですか？"]}, {"box": [110, 792, 196, 959], "vertical": true, "font_size": 24, "lines_coords": [[[175.0, 792.0], [196.0, 792.0], [196.0, 959.0], [175.0, 959.0]], [[140.0, 792.0], [167.0, 792.0], [167.0, 925.0], [140.0, 925.0]], [[110.0, 793.0], [132.0, 793.0], [132.0, 946.0], [110.0, 946.0]]], "lines": ["あの人、ホント", "相変わらず", "手がかかる！！"]}, {"box": [742, 1468, 764, 1528], "vertical": true, "font_size": 23, "lines_coords": [[[742.0, 1468.0], [764.0, 1468.0], [764.0, 1528.0], [742.0, 1528.0]]], "lines": ["！？"]}, {"box": [643, 1348, 762, 1554], "vertical": true, "font_size": 23, "lines_coords": [[[745.0, 1356.0], [762.0, 1356.0], [762.0, 1471.0], [745.0, 1471.0]], [[707.0, 1348.0], [734.0, 1348.0], [734.0, 1504.0], [707.0, 1504.0]], [[675.0, 1348.0], [701.0, 1348.0], [701.0, 1554.0], [675.0, 1554.0]], [[643.0, 1348.0], [670.0, 1348.0], [670.0, 1503.0], [643.0, 1503.0]]], "lines": ["．．．そうよー", "非常階段から", "飛び降りたりして", "大変だったん"]}, {"box": [614, 1348, 635, 1451], "vertical": true, "font_size": 23, "lines_coords": [[[614.0, 1348.0], [635.0, 1348.0], [635.0, 1451.0], [614.0, 1451.0]]], "lines": ["だから！！"]}, {"box": [173, 1351, 240, 1445], "vertical": true, "font_size": 35, "lines_coords": [[[207.0, 1351.0], [240.0, 1351.0], [240.0, 1439.0], [207.0, 1439.0]], [[173.0, 1351.0], [212.0, 1351.0], [212.0, 1445.0], [173.0, 1445.0]]], "lines": ["ちがう", "ちがう、"]}, {"box": [81, 1418, 146, 1528], "vertical": true, "font_size": 35, "lines_coords": [[[112.0, 1418.0], [146.0, 1420.0], [143.0, 1528.0], [109.0, 1526.0]], [[81.0, 1420.0], [115.0, 1420.0], [115.0, 1490.0], [81.0, 1490.0]]], "lines": ["ダンナの", "ＤＶ。"]}], "img_path": "071.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [903, 110, 965, 318], "vertical": true, "font_size": 27, "lines_coords": [[[937.0, 110.0], [965.0, 110.0], [962.0, 214.0], [934.0, 214.0]], [[903.0, 110.0], [929.0, 110.0], [929.0, 314.0], [903.0, 314.0]]], "lines": ["さっきの", "晴見くんの眼．．．"]}, 