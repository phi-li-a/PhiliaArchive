673.0], [70.0, 673.0]]], "lines": ["おかげで", "マジメに受験勉強", "するかって気に", "なりました。"]}, {"box": [925, 1070, 979, 1236], "vertical": true, "font_size": 24, "lines_coords": [[[957.0, 1073.0], [979.0, 1073.0], [979.0, 1235.0], [957.0, 1235.0]], [[925.0, 1070.0], [951.0, 1070.0], [951.0, 1226.0], [925.0, 1226.0]]], "lines": ["じゃあ．．．キミは", "今、高校生だ？"]}, {"box": [629, 1071, 715, 1234], "vertical": true, "font_size": 27, "lines_coords": [[[689.0, 1071.0], [715.0, 1071.0], [715.0, 1167.0], [689.0, 1167.0]], [[662.0, 1073.0], [684.0, 1073.0], [684.0, 1234.0], [662.0, 1234.0]], [[629.0, 1071.0], [662.0, 1071.0], [662.0, 1154.0], [629.0, 1154.0]]], "lines": ["あら．．．．．", "あたしの息子と", "一緒だ。"]}, {"box": [328, 823, 354, 926], "vertical": true, "font_size": 29, "lines_coords": [[[328.0, 823.0], [354.0, 823.0], [354.0, 926.0], [328.0, 926.0]]], "lines": ["もう．．．"]}, {"box": [206, 870, 273, 981], "vertical": true, "font_size": 29, "lines_coords": [[[245.0, 873.0], [273.0, 873.0], [270.0, 979.0], [242.0, 979.0]], [[206.0, 870.0], [239.0, 870.0], [242.0, 981.0], [209.0, 981.0]]], "lines": ["お世辞が", "下手ねぇ"]}, {"box": [840, 1209, 900, 1317], "vertical": true, "font_size": 32, "lines_coords": [[[865.0, 1209.0], [900.0, 1209.0], [900.0, 1285.0], [865.0, 1285.0]], [[840.0, 1210.0], [868.0, 1210.0], [868.0, 1317.0], [840.0, 1317.0]]], "lines": ["１６歳の", "高一です。"]}, {"box": [510, 1318, 620, 1482], "vertical": true, "font_size": 23, "lines_coords": [[[595.0, 1320.0], [618.0, 1320.0], [617.0, 1481.0], [593.0, 1481.0]], [[567.0, 1320.0], [593.0, 1320.0], [593.0, 1439.0], [567.0, 1439.0]], [[539.0, 1318.0], [560.0, 1318.0], [560.0, 1456.0], [539.0, 1456.0]], [[510.0, 1318.0], [532.0, 1318.0], [532.0, 1459.0], [510.0, 1459.0]]], "lines": ["ホントですか？", "へぇー．．．", "全然見えない", "ですね〜〜．．．"]}, {"box": [193, 1279, 282, 1460], "vertical": true, "font_size": 26, "lines_coords": [[[254.0, 1279.0], [282.0, 1279.0], [282.0, 1362.0], [254.0, 1362.0]], [[223.0, 1282.0], [250.0, 1282.0], [250.0, 1460.0], [223.0, 1460.0]], [[193.0, 1282.0], [215.0, 1282.0], [215.0, 1410.0], [193.0, 1410.0]]], "lines": ["そんな", "つもりじゃない", "てすって！！"]}, {"box": [104, 1396, 133, 1538], "vertical": true, "font_size": 27, "lines_coords": [[[104.0, 1396.0], [131.0, 1396.0], [131.0, 1537.0], [104.0, 1537.0]]], "lines": ["．．．いいのよ。"]}], "img_path": "050.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [981, 93, 1003, 221], "vertical": true, "font_size": 23, "lines_coords": [[[981.0, 93.0], [1003.0, 93.0], [1003.0, 221.0], [981.0, 221.0]]], "lines": ["無様よね．．．"]}, {"box": [823, 229, 957, 393], "vertical": true, "font_size": 23, "lines_coords": [[[935.0, 229.0], [957.0, 229.0], [957.0, 371.0], [935.0, 371.0]], [[903.0, 229.0], [929.0, 229.0], [929.0, 378.0], [903.0, 378.0]], [[878.0, 229.0], [900.0, 229.0], [900.0, 393.0], [878.0, 393.0]], [[848.0, 231.0], [875.0, 231.0], [875.0, 371.0], [848.0, 371.0]], [[823.0, 232.0], [843.0, 232.0], [843.0, 371.0], [823.0, 371.0]]], "lines": ["どうせいつか", "枯れるんなら、", "さっさと枯れて", "ほしいくらい", "なんだから．．．"]}, {"box": [187, 245, 276, 401], "vertical": true, "font_size": 25, "lines_coords": [[[254.0, 250.0], [276.0, 250.0], [276.0, 400.0], [254.0, 400.0]], [[220.0, 245.0], [248.0, 245.0], [245.0, 401.0], [217.0, 401.0]], [[187.0, 246.0], [215.0, 246.0], [215.0, 331.0], [187.0, 331.0]]], "lines": ["捨て切れない", "余計な「女」の", "部分が"]}, {"box": [142, 459, 232, 665], "vertical": true, "font_size": 25, "lines_coords": [[[206.0, 460.0], [232.0, 460.0], [232.0, 643.0], [206.0, 643.0]], [[176.0, 459.0], [198.0, 459.0], [198.0, 665.0], [176.0, 665.0]], [[142.0, 460.0], [168.0, 460.0], [168.0, 593.0], [142.0, 593.0]]], "lines": ["あたしの人生を", "くるわせてる気が", "するもの．．．"]}, {"box": [913, 1018, 1004, 1204], "vertical": true, "font_size": 28, "lines_coords": [[[973.0, 1020.0], [1004.0, 1020.0], [1004.0, 1181.0], [973.0, 1181.0]], [[942.0, 1018.0], [973.0, 1018.0], [973.0, 1204.0], [942.0, 1204.0]], [[914.0, 1021.0], [935.0, 1021.0], [935.0, 1150.0], [914.0, 1150.0]]], "lines": ["．．．ヤダァ～～", "何言ってんだろ", "あたしィ！！"]}, {"box": [231, 1026, 264, 1112], "vertical": true, "font_size": 31, "lines_coords": [[[231.0, 1026.0], [264.0, 1026.0], [264.0, 1112.0], [231.0, 1112.0]]], "lines": ["あの．．．"]}, {"box": [132, 1093, 228, 1259], "vertical": true, "font_size": 31, "lines_coords": [[[185.0, 1093.0], [228.0, 1093.0], [228.0, 1162.0], [185.0, 1162.0]], [[162.0, 1098.0], [189.0, 1098.0], [189.0, 1206.0], [162.0, 1206.0]], [[132.0, 1103.0], [154.0, 1103.0], [154.0, 1259.0], [132.0, 1259.0]]], "lines": ["僕で", "よければ", "聞きますよ？"]}, {"box": [632, 1160, 740, 1326], "vertical": true, "font_size": 23, "lines_coords": [[[714.0, 1160.0], [740.0, 1160.0], [740.0, 1254.0], [714.0, 1254.0]], [[689.0, 1164.0], [710.0, 1164.0], [710.0, 1326.0], [689.0, 1326.0]], [[660.0, 1164.0], [682.0, 1164.0], [682.0, 1301.0], [660.0, 1301.0]], [[632.0, 1164.0], [654.0, 1164.0], [654.0, 1256.0], [632.0, 1256.0]]], "lines": ["年増女の", "身の上話なんて", "聞きたくない", "よねっ！？"]}, {"box": [606, 1395, 689, 1525], "vertical": true, "font_size": 23, "lines_coords": [[[659.0, 1395.0], [685.0, 1395.0], [689.0, 1525.0], [662.0, 1525.0]], [[634.0, 1398.0], [656.0, 1398.0], [656.0, 1514.0], [634.0, 1514.0]], [[606.0, 1400.0], [628.0, 1400.0], [628.0, 1493.0], [606.0, 1493.0]]], "lines": ["ごめんねェ、", "今のセリフ", "忘れて！？"]}, {"box": [239, 1321, 267, 1428], "vertical": true, "font_size": 26, "lines_coords": [[[239.0, 1321.0], [267.0, 1321.0], [267.0, 1428.0], [239.0, 1428.0]]], "lines": ["ううん．．．"]}, {"box": [106, 1387, 198, 1543], "vertical": true, "font_size": 26, "lines_coords": [[[171.0, 1387.0], [198.0, 1387.0], [198.0, 1526.0], [171.0, 1526.0]], [[140.0, 1390.0], [162.0, 1390.0], [162.0, 1543.0], [140.0, 1543.0]], [[106.0, 1392.0], [132.0, 1392.0], [132.0, 1481.0], [106.0, 1481.0]]], "lines": ["．．．いいのよ。", "そろそろ病室", "戻るね。"]}], "img_path": "051.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [884, 54, 979, 212], "vertical": true, "font_size": 30, "lines_coords": [[[951.0, 57.0], [979.0,