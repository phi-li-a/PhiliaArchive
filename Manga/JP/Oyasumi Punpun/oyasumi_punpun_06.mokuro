7.0], [846.0, 367.0]]], "lines": ["俺、なんか", "すげー変なトコ", "切っちゃったん", "ですけど！！"]}, {"box": [160, 129, 273, 318], "vertical": true, "font_size": 24, "lines_coords": [[[239.0, 129.0], [273.0, 129.0], [273.0, 209.0], [239.0, 209.0]], [[217.0, 132.0], [237.0, 132.0], [237.0, 295.0], [217.0, 295.0]], [[189.0, 134.0], [210.0, 134.0], [210.0, 318.0], [189.0, 318.0]], [[160.0, 135.0], [182.0, 135.0], [182.0, 318.0], [160.0, 318.0]]], "lines": ["．．．てか", "さっきから血圧", "下がりっぱなしで", "マジウケるゥー！！"]}, {"box": [33, 307, 74, 461], "vertical": true, "font_size": 28, "lines_coords": [[[39.0, 309.0], [67.0, 309.0], [67.0, 431.0], [39.0, 431.0]]], "lines": ["ずっと"]}, {"box": [763, 429, 845, 617], "vertical": true, "font_size": 23, "lines_coords": [[[815.0, 429.0], [842.0, 429.0], [845.0, 584.0], [818.0, 584.0]], [[790.0, 431.0], [812.0, 431.0], [814.0, 598.0], [792.0, 598.0]], [[764.0, 432.0], [784.0, 432.0], [784.0, 617.0], [764.0, 617.0]]], "lines": ["うわっ、つーか", "変な汁出てきた、", "変な汁出てきた！！"]}, {"box": [101, 439, 225, 620], "vertical": true, "font_size": 27, "lines_coords": [[[192.0, 439.0], [225.0, 439.0], [225.0, 548.0], [192.0, 548.0]], [[164.0, 442.0], [190.0, 442.0], [190.0, 570.0], [164.0, 570.0]], [[131.0, 440.0], [157.0, 440.0], [157.0, 595.0], [131.0, 595.0]], [[101.0, 440.0], [123.0, 440.0], [123.0, 618.0], [101.0, 618.0]]], "lines": ["先輩〜〜〜", "超～～～血が", "止まらないん", "ですけどォ〰〰"]}, {"box": [892, 720, 979, 923], "vertical": true, "font_size": 25, "lines_coords": [[[950.0, 720.0], [976.0, 720.0], [979.0, 923.0], [953.0, 923.0]], [[923.0, 723.0], [946.0, 723.0], [948.0, 840.0], [925.0, 840.0]], [[892.0, 721.0], [918.0, 721.0], [923.0, 900.0], [896.0, 900.0]]], "lines": ["まーー絆創膏でも", "貼っときゃ", "そのうち治んべ。"]}, {"box": [795, 845, 857, 950], "vertical": true, "font_size": 31, "lines_coords": [[[823.0, 845.0], [857.0, 845.0], [857.0, 929.0], [823.0, 929.0]], [[795.0, 846.0], [823.0, 846.0], [823.0, 950.0], [795.0, 950.0]]], "lines": ["内臓に", "ですか？"]}, {"box": [701, 1057, 779, 1185], "vertical": true, "font_size"