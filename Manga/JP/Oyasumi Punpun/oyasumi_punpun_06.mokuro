855.0], [3712.0, 855.0]], [[3613.0, 854.0], [3822.0, 854.0], [3822.0, 885.0], [3613.0, 885.0]], [[3272.0, 854.0], [3515.0, 854.0], [3515.0, 885.0], [3272.0, 885.0]], [[3272.0, 885.0], [3674.0, 888.0], [3674.0, 919.0], [3272.0, 915.0]], [[3666.0, 888.0], [3822.0, 888.0], [3822.0, 919.0], [3666.0, 919.0]], [[3275.0, 919.0], [3496.0, 919.0], [3496.0, 949.0], [3275.0, 949.0]], [[3735.0, 923.0], [3814.0, 923.0], [3814.0, 953.0], [3735.0, 953.0]], [[3275.0, 953.0], [3579.0, 953.0], [3579.0, 983.0], [3275.0, 983.0]], [[3731.0, 957.0], [3814.0, 957.0], [3814.0, 987.0], [3731.0, 987.0]], [[3351.0, 991.0], [3708.0, 991.0], [3708.0, 1021.0], [3351.0, 1021.0]], [[3268.0, 1014.0], [3818.0, 1017.0], [3818.0, 1059.0], [3268.0, 1056.0]], [[3298.0, 1059.0], [3795.0, 1059.0], [3795.0, 1101.0], [3298.0, 1101.0]]], "lines": ["おやすみプンプン", "．．．やっのソラニン、全己巻ほーのマーナー", "浅野いにお", "ほしのふるまち全７巻", "原秀則", "はじいからは、エノを１ポンドの福音・全４巻", "高橋留美子", "「ハンバンツ曲」エーザーローコトー診療所、「〜の港", "おしゃれ手帖・全ＩＤ巻Ｐｒｉｎｖｉｓ", "ＰＡＮＥＯＷに一生してみる日本ＮＢＯＷ－二舎六原の七人", "ゆうきまさみ", "鉄腕バーディー全２０巻", "室積光ノ猪熊しの", "都立水商！金曜巻ー", "黒丸ノ夏原", "クロサギ全２０巻", "クロサキ・主催者イキガミ・ＴｒｉＰｈｏｎｄｅｌｉｎｔ－ｌｉｍｔ－リモーダーメージの一黒丸ノ夏原〜武〜フ巻ー一間瀬元朗", "土竜（モグラ）の唄・１～２０巻", "高橋のぼる", "巻一佐藤まさ", "超無気力関数シャバファイフ全９巻", "Ｃｈｒｏｍｅ－オッズ－＋１巻", "Ｕｎｄｉｓアインスキ「１巻さらの成分外国」などの展開に合わせておりますが、", "タナトスポイントロームページのタナースをしけるのは、全日巻８８．１１日一竹原慎二ノ落合花", "シハトメルルツギーエロ＠とめはねっー。鈴里高校賛適部－１．床長ー／２１日の１〜５巻一河合克服", "森尾正博", "ビーチスターズ、全７巻", "ビデズターズ（土）をお送り商品の商品に合図書・スポーツ・金曜日・ブーストラブル・個人情報・", "美晴♥ライジング全５巻", "大谷じろう", "七月鏡一ノ藤原芳秀", "暁のイージス、全日巻", "あんころ。船橋君松ここでは、丁目は馬鹿。全５巻一", "まー、万乗大智", "ＧＯ－ＯＮ、全４巻", "秋重学", "ここじゃ、エーザードライブ・ア・ライフ・全日巻", "中井那彦", "ヤングサンデーコミックススペシャル", "絶望に効くクスリムについては全Ｉ５巻ー山田玲司", "ｈｔｔｐ：／ｃｏｍｉｃｓｓｈｏｇａｋｕｋａｎ．ｃｏｊｐ"]}, {"box": [3287, 1099, 3795, 1148], "vertical": false, "font_size": 26.5, "lines_coords": [[[3287.0, 1099.0], [3795.0, 1099.0], [3795.0, 1137.0], [3287.0, 1137.0]], [[3579.0, 1133.0], [3750.0, 1133.0], [3750.0, 1148.0], [3579.0, 1148.0]]], "lines": ["にアクセスすると、コミッオンラインショップでクス情報が詳しくわかり、することもできます。", "「ることもできます"]}, {"box": [3336, 1222, 3774, 1446], "vertical": false, "font_size": 48, "lines_coords": [[[3465.0, 1224.0], [3640.0, 1224.0], [3640.0, 1270.0], [3465.0, 1270.0]], [[3404.0, 1269.0], [3697.0, 1269.0], [3697.0, 1315.0], [3404.0, 1315.0]], [[3336.0, 1285.0], [3769.0, 1285.0], [3769.0, 1372.0], [3336.0, 1372.0]], [[3355.0, 1341.0], [3754.0, 1345.0], [3754.0, 1395.0], [3355.0, 1391.0]], [[3393.0, 1383.0], [3704.0, 1383.0], [3704.0, 1418.0], [3393.0, 1418.0]], [[3351.0, 1398.0], [3757.0, 1402.0], [3757.0, 1448.0], [3351.0, 1444.0]]], "lines": ["浅野いにお", "１９８０年生まれ。茨城県出身。１１年、第１回サンデー○Ｘ新人賞", "２０１８年３０年生まれ。交通期出身、２００１年、第１回サンデー会社が多くて、「主な家族に「美味」といい世界」のかかりのまちいともとちょっというわけがある。", "１０００年を高作に「素晴らしい世界」「わかりのまち」ともに少社刊がある。「リフランパ全全参参りやすいが、", "「カリのまちいともに小社刊がある「ソラニン（（全２巻」小社研）が、日本人世代・性別を超えた大反響", "「ソフェン（金２巻。小社刊）が、全国より世代、性別を堪えた天魔隊作に。"]}], "img_path": "001.png"}, {"version": "0.2.0-beta.6", "img_width": 3887, "img_height": 1600, "blocks": [{"box": [1014, 516, 1063, 973], "vertical": true, "font_size": 38, "lines_coords": [[[1017.0, 519.0], [1055.0, 519.0], [1055.0, 966.0], [1017.0, 966.0]]], "lines": ["おやすみプンプンの"]}, {"box": [1150, 1019, 1415, 1084], "vertical": false, "font_size": 53, "lines_coords": [[[1150.0, 1031.0], [1415.0, 1019.0], [1415.0, 1072.0], [1150.0, 1084.0]]], "lines": ["万部突破！！"]}, {"box": [1260, 1084, 1419, 1126], "vertical": false, "font_size": 38, "lines_coords": [[[1260.0, 1088.0], [1419.0, 1084.0], [1419.0, 1122.0], [1260.0, 1126.0]]], "lines": ["定価５４０円（本後５４円）"]}, {"box": [24, 1084, 606, 1452], "vertical": false, "font_size": 336, "lines_coords": [[[59.0, 1118.0], [527.0, 1054.0], [569.0, 1416.0], [101.0, 1481.0]]], "lines": ["でも、"]}, {"box": [763, 1150, 1491, 1578], "vertical": false, "font_size": 53, "lines_coords": [[[873.0, 1152.0], [1362.0, 1152.0], [1362.0, 1209.0], [873.0, 1209.0]], [[819.0, 1213.0], [1465.0, 1213.0], [1465.0, 1258.0], [819.0, 1258.0]], [[808.0, 1273.0], [1419.0, 1273.0], [1419.0, 1319.0], [808.0, 1319.0]], [[808.0, 1326.0], [1408.0, 1326.0], [1408.0, 1384.0], [808.0, 1384.0]], [[800.0, 1383.0], [1275.0, 1387.0], [1275.0, 1448.0], [800.0, 1444.0]], [[766.0, 1451.0], [1377.0, 1451.0], [1377.0, 1509.0], [766.0, 1509.0]], [[778.0, 1493.0], [1169.0, 1508.0], [1169.0, 1581.0], [778.0, 1566.0]]], "lines": ["一あの魔太さんも読んでる！！", "プンプンの事誰がと語り合いたい", "けど、何故だか独り占めしたくて、", "、ムニュマニュ", "ありがとうプンプン。暎太", "◎知田区区付くディア・ご家族・審査委員会議議所・", "浅野いにお１"]}, {"box": [772, 1151, 1482, 1586], "vertical": false, "font_size": 435, "lines_coords": [[[772.0, 1151.0], [1482.0, 1151.0], [1482.0, 1586.0], [772.0, 1586.0]]], "lines": ["「あのじっさんもなんでもなかったけど．．．」ということではないのですが、どうしてこれだけどころから"]}, {"box": [1894, 1122, 1985, 1497], "vertical": true, "font_size": 44.0, "lines_coords": [[[1947.0, 1137.0], [1985.0, 1137.0], [1985.0, 1493.0], [1947.0, 1493.0]], [[1901.0, 1122.0], [1951.0, 1122.0], [1943.0, 1497.0], [1894.0, 1497.0]]], "lines": ["大人気御礼！！", "累計．．．万部突破！！"]}, {"box": [2501, 147, 2657, 185], "vertical": false, "font_size": 38, "lines_coords": [[[2501.0, 147.0], [2657.0, 147.0], [2657.0, 185.0], [2501.0, 185.0]]], "lines": ["Ｃ９９７９＼５１４Ｅ"]}, {"box": [2505, 72, 2801, 109], "vertical": false, "font_size": 37, "lines_coords": [[[2505.0, 72.0], [2801.0, 72.0], [2801.0, 109.0], [2505.0, 109.0]]], "lines": ["ＩＳＢＮ９７８－４－４９－１５１４Ａ－Ｃ"]}, {"box": [2505, 269, 2843, 386], "vertical": false, "font_size": 40.0, "lines_coords": [[[2505.0, 337.0], [2691.0, 345.0], [2691.0, 386.0], [2505.0, 379.0]], [[2505.0, 269.0], [2843.0, 269.0], [2843.0, 307.0], [2505.0, 307.0]]], "lines": ["雑誌４５３６４－７９", "定価：「本体５１４円十税"]}, {"box": [2676, 341, 2839, 379], "vertical": false, "font_size": 38, "lines_coords": [[[2676.0, 341.0], [2839.0, 341.0], [2839.0, 379.0], [2676.0, 379.0]]], "lines": ["１９３０年小学館"]}, {"box": [3279, 60, 3496, 87], "vertical": false, "font_size": 27, "lines_coords": [[[3279.0, 60.0], [3496.0, 60.0], [3496.0, 87.0], [3279.0, 87.0]]], "lines": ["今、一番おもしろい"]}, {"box": [3266, 78, 3829, 160], "vertical": false, "font_size": 55, "lines_coords": [[[3279.0, 89.0], [3814.0, 97.0], [3814.0, 156.0], [3279.0, 149.0]]], "lines": ["Ｙｏｕｎｅ－Ｓｕｌｕ