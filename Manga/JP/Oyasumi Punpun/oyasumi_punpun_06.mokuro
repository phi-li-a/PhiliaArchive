t_size": 26, "lines_coords": [[[381.0, 50.0], [407.0, 50.0], [410.0, 179.0], [384.0, 179.0]], [[356.0, 51.0], [382.0, 51.0], [379.0, 196.0], [353.0, 196.0]], [[326.0, 51.0], [353.0, 51.0], [353.0, 250.0], [326.0, 250.0]], [[300.0, 53.0], [326.0, 53.0], [323.0, 217.0], [296.0, 217.0]], [[273.0, 56.0], [295.0, 56.0], [295.0, 179.0], [273.0, 179.0]]], "lines": ["．．．きのう僕、", "自転車で車と", "事故って、怪我した", "って言ったじゃ", "ないですか。"]}, {"box": [573, 445, 598, 526], "vertical": true, "font_size": 25, "lines_coords": [[[573.0, 446.0], [598.0, 446.0], [598.0, 526.0], [573.0, 526.0]]], "lines": ["．．．え？"]}, {"box": [271, 631, 332, 762], "vertical": true, "font_size": 28, "lines_coords": [[[306.0, 632.0], [332.0, 632.0], [332.0, 762.0], [306.0, 762.0]], [[271.0, 631.0], [304.0, 631.0], [304.0, 715.0], [271.0, 715.0]]], "lines": ["実はその時", "僕．．．．．"]}, {"box": [132, 681, 226, 840], "vertical": true, "font_size": 28, "lines_coords": [[[200.0, 684.0], [226.0, 684.0], [226.0, 815.0], [200.0, 815.0]], [[167.0, 684.0], [193.0, 684.0], [193.0, 840.0], [167.0, 840.0]], [[135.0, 681.0], [162.0, 681.0], [159.0, 815.0], [132.0, 815.0]]], "lines": ["二人乗りで", "彼女を後ろに", "乗せてて．．．"]}, {"box": [850, 1160, 940, 1343], "vertical": true, "font_size": 23, "lines_coords": [[[914.0, 1160.0], [940.0, 1160.0], [940.0, 1276.0], [914.0, 1276.0]], [[882.0, 1160.0], [904.0, 1160.0], [904.0, 1342.0], [882.0, 1342.0]], [[851.0, 1162.0], [873.0, 1162.0], [873.0, 1329.0], [851.0, 1329.0]]], "lines": ["．．．その子、", "まだここに入院", "してるんです。"]}, {"box": [157, 1325, 251, 1478], "vertical": true, "font_size": 24, "lines_coords": [[[226.0, 1326.0], [248.0, 1326.0], [248.0, 1478.0], [226.0, 1478.0]], [[193.0, 1326.0], [215.0, 1326.0], [215.0, 1451.0], [193.0, 1451.0]], [[157.0, 1325.0], [185.0, 1325.0], [187.0, 1442.0], [159.0, 1442.0]]], "lines": ["僕なんかより", "全然ひどい", "大怪我で。"]}], "img_path": "063.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [892, 132, 982, 265], "vertical": true, "font_size": 26,