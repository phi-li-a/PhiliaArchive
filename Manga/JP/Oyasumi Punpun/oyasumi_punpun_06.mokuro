335.0, 292.0], [357.0, 292.0], [357.0, 432.0], [335.0, 432.0]], [[309.0, 292.0], [331.0, 292.0], [328.0, 456.0], [306.0, 456.0]]], "lines": ["点滴とれた", "解放感を味わいたい", "この気持ちを", "汲めっつーの！！"]}, {"box": [762, 306, 854, 514], "vertical": true, "font_size": 27, "lines_coords": [[[825.0, 306.0], [851.0, 306.0], [854.0, 462.0], [828.0, 462.0]], [[796.0, 309.0], [818.0, 309.0], [818.0, 487.0], [796.0, 487.0]], [[762.0, 306.0], [789.0, 306.0], [789.0, 514.0], [762.0, 514.0]]], "lines": ["外に出る時は", "必ず外出許可を", "取ってください！！"]}, {"box": [190, 500, 311, 682], "vertical": true, "font_size": 24, "lines_coords": [[[287.0, 503.0], [309.0, 503.0], [309.0, 631.0], [287.0, 631.0]], [[251.0, 501.0], [278.0, 501.0], [278.0, 682.0], [251.0, 682.0]], [[220.0, 500.0], [246.0, 500.0], [246.0, 679.0], [220.0, 679.0]], [[190.0, 501.0], [212.0, 501.0], [212.0, 656.0], [190.0, 656.0]]], "lines": ["．．．どのみち", "今日の夕方には", "退院できるじゃ", "ないですか！！"]}, {"box": [956, 825, 982, 927], "vertical": true, "font_size": 23, "lines_coords": [[[956.0, 825.0], [979.0, 825.0], [982.0, 926.0], [959.0, 926.0]]], "lines": ["．．．あら？"]}, {"box": [539, 850, 634, 956], "vertical": true, "font_size": 30, "lines_coords": [[[601.0, 850.0], [634.0, 850.0], [634.0, 954.0], [601.0, 954.0]], [[573.0, 853.0], [601.0, 853.0], [601.0, 953.0], [573.0, 953.0]], [[539.0, 853.0], [567.0, 853.0], [567.0, 956.0], [539.0, 956.0]]], "lines": ["向かいの", "ベッドの", "女の子．．"]}, {"box": [156, 903, 218, 1059], "vertical": true, "font_size": 30, "lines_coords": [[[184.0, 903.0], [218.0, 903.0], [218.0, 985.0], [184.0, 985.0]], [[156.0, 904.0], [182.0, 904.0], [182.0, 1059.0], [156.0, 1059.0]]], "lines": ["．．．退院", "しちゃった？"]}, {"box": [715, 1307, 775, 1437], "vertical": true, "font_size": 27, "lines_coords": [[[748.0, 1307.0], [775.0, 1307.0], [775.0, 1437.0], [748.0, 1437.0]], [[715.0, 1307.0], [742.0, 1307.0], [742.0, 1414.0], [715.0, 1414.0]]], "lines": ["なんですか", "今度は！？"]}, {"box": [396, 1293, 456, 1451], "vertical": true, "font_size": 27, "lines_coords": [[[425.0, 1293.0], [456.0, 1293.0], [456.0, 1451.0], [425.0, 1451.0]], [[396.0, 1295.0], [423.0, 1295.0], [423.0, 1435.0], [396.0, 1435.0]]], "lines": ["．．．あぁ、ハイ", "ついさっき。"]}, {"box": [260, 1334, 350, 1525], "vertical": true, "font_size": 27, "lines_coords": [[[323.0, 1334.0], [350.0, 1334.0], [350.0, 1514.0], [323.0, 1514.0]], [[289.0, 1334.0], [315.0, 1334.0], [317.0, 1515.0], [290.0, 1515.0]], [[260.0, 1335.0], [282.0, 1335.0], [282.0, 1525.0], [260.0, 1525.0]]], "lines": ["同い年くらいの", "男の子が迎えに", "来てましたけど。"]}], "img_path": "168.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [518, 40, 561, 290], "vertical": true, "font_size": 42, "lines_coords": [[[518.0, 75.0], [560.0, 75.0], [560.0, 289.0], [518.0, 289.0]]], "lines": ["・晴見くん！？"]}], "img_path": "169.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "170.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "171.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "172.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [928, 71, 992, 145], "vertical": true, "font_size": 29, "lines_coords": [[[962.0, 75.0], [992.0, 75.0], [992.0, 135.0], [962.0, 135.0]], [[928.0, 71.0], [964.0, 71.0], [964.0, 145.0], [928.0, 145.0]]], "lines": ["あの", "先輩。"]}, {"box": [815, 137, 896, 350], "vertical": true, "font_size": 29, "lines_coords": [[[870.0, 139.0], [896.0, 139.0], [896.0, 350.0], [870.0, 350.0]], [[840.0, 137.0], [867.0, 137.0], [867.0, 350.0], [840.0, 350.0]], [[815.0, 139.0], [842.0, 139.0], [842.0, 314.0], [815.0, 314.0]]], "lines": ["．．．コレ小野寺さんが", "食べてくださいって", "シュークリーム。"]}, {"box": [123, 150, 212, 333], "vertical": true, "font_size": 24, "lines_coords": [[[181.0, 150.0], [209.0, 150.0], [212.0, 284.0], [184.0, 284.0]], [[154.0, 154.0], [176.0, 154.0], [176.0, 331.0], [154.0, 331.0]], [[123.0, 154.0], [145.0, 154.0], [145.0, 281.0], [123.0, 281.0]]], "lines": ["．．．どういう", "風の吹きまわし", "てすかね？"]}, {"box": [926, 425, 953, 520], "vertical": true, "font_size": 24, "lines_coords": [[[926.0, 425.0], [953.0, 425.0], [953.0, 520.0], [926.0, 520.0]]], "lines": ["あやしー"]}, {"box": [815, 564, 903, 715], "vertical": true, "font_size": 24, "lines_coords": [[[876.0, 564.0], [903.0, 564.0], [903.0, 693.0], [876.0, 693.0]], [[846.0, 564.0], [868.0, 564.0], [868.0, 715.0], [846.0, 715.0]], [[815.0, 564.0], [837.0, 564.0], [837.0, 667.0], [815.0, 667.0]]], "lines": ["金属片でも", "入ってんじゃ", "ないのー"]}, {"box": [815, 668, 837, 717], "vertical": true, "font_size": 24, "lines_coords": [[[815.0, 668.0], [837.0, 668.0], [837.0, 717.0], [815.0, 717.0]]], "lines": ["ー？"]}, {"box": [223, 542, 251, 646], "vertical": true, "font_size": 27, "lines_coords": [[[223.0, 542.0], [251.0, 542.0], [251.0, 646.0], [223.0, 646.0]]], "lines": ["婦長ォー"]}, {"box": [126, 685, 185, 796], "vertical": true, "font_size": 27, "lines_coords": [[[157.0, 689.0], [185.0, 689.0], [185.0, 796.0], [157.0, 796.0]], [[126.0, 685.0], [156.0, 685.0], [156.0, 743.0], [126.0, 743.0]]], "lines": ["内線２番", "でー"]}, {"box": [129, 745, 151, 806], "vertical": true, "font_size": 27, "lines_coords": [[[129.0, 745.0], [151.0, 745.0], [151.0, 806.0], [129.0, 806.0]]], "lines": ["す"]}, {"box": [504, 1012, 562, 1152], "vertical": true, "font_size": 25, "lines_coords": [[[534.0, 1012.0], [562.0, 1012.0], [562.0, 1126.0], [534.0, 1126.0]], [[506.0, 1015.0], [528.0, 1015.0], [528.0, 1148.0], [506.0, 1148.0]]], "lines": ["．．．．．アレ、", "小野寺さん。"]}, {"box": [876, 1256, 984, 1403], "vertical": true, "font_size": 24, "lines_coords": [[[957.0, 1257.0], [984.0, 1257.0], [984.0, 1373.0], [957.0, 1373.0]], [[932.0, 1257.0], [959.0, 1257.0], [959.0, 1373.0], [932.0, 1373.0]], [[903.0, 1256.0], [929.0, 1256.0], [929.0, 1376.0], [903.0, 1376.0]], [[876.0, 1257.0], [898.0, 1257.0], [898.0, 1403.0], [876.0, 1403.0]]], "lines": ["４時からの", "レントゲン", "終わったら", "退院ですから、"]}, {"box": [760, 1289, 839, 1498], "vertical": true, "font_size": 24, "lines_coords": [[[817.0, 1289.0], [839.0, 1289.0], [839.0, 1407.0], [817.0, 1407.0]], [[787.0, 1289.0], [809.0, 1289.0], [809.0, 1498.0], [787.0, 1498.0]], [[760.0, 1289.0], [782.0, 1289.0], [782.0, 1475.0], [760.0, 1475.0]]], "lines": ["荷物の準備", "早めにやっちゃって", "くださいよーー？"]}, {"box": [310, 1387, 369, 1542], "vertical": true, "font_size": 25, "lines_coords": [[[340.0, 1387.0], [368.0, 1387.0], [368.0, 1493.0], [340.0, 1493.0]], [[310.0, 1389.0], [332.0, 1389.0], [332.0, 1542.0], [310.0, 1542.0]]], "lines": ["この手紙", "なんですか？"]}], "img_path": "173.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [106, 65, 392, 87], "vertical": false, "font_size": 22, "lines_coords": [[[106.0, 65.0], [392.0, 65.0], [392.0, 87.0], [106.0, 87.0]]], "lines": ["おやすみプンプン＠"]}, {"box": [200, 334, 227, 499], "vertical": true, "font_size": 22, "lines_coords": [[[203.0, 368.0], [225.0, 368.0], [225.0, 492.0], [203.0, 492.0]]], "lines": ["：晴見くん。"]}, {"box": [360, 456, 503, 537], "vertical": false, "font_size": 29, "lines_coords": [[[360.0, 510.0], [490.0, 456.0], [503.0, 482.0], [371.0, 537.0]]], "lines": ["時見、後た明"]}, {"box": [310, 751, 465, 793], "vertical": false, "font_size": 30, "lines_coords": [[[310.0, 764.0], [462.0, 751.0], [465.0, 781.0], [314.0, 793.0]]], "lines": ["小野寺さんへ"]}, {"box": [292, 796, 846, 1117], "vertical": false, "font_size": 40.857142857142854, "lines_coords": [[[292.0, 825.0], [543.0, 796.0], [550.0, 846.0], [298.0, 875.0]], [[292.0, 870.0], [817.0, 806.0], [821.0, 843.0], [296.0, 907.0]], [[295.0, 914.0], [554.0, 881.0], [559.0, 918.0], [300.0, 951.0]], [[306.0, 946.0], [792.0, 884.0], [796.0, 926.0], [310.0, 989.0]], [[315.0, 987.0], [542.0, 962.0], [546.0, 1001.0], [320.0, 1026.0]], [[326.0, 1039.0], [840.0, 970.0], [846.0, 1012.0], [332.0, 1081.0]], [[339.0, 1079.0], [829.0, 1010.0], [834.0, 1048.0], [343.0, 1117.0]]], "lines": ["女性の手紙もすみません。いいけど、中へって", "当はお一度会っておくが言いたおたのですが、", "病室にいないようなので、", "もういいようなことができなければいいのが、決まったんだから", "でも、不思議な縁ですね。", "キロは本気なのでありますので、認められたんでしょう", "もちろんそんなことがなくても、今はこれから見えないと思いますが、"]}, {"box": [138, 1281, 291, 1512], "vertical": true, "font_size": 23, "lines_coords": [[[265.0, 1285.0], [287.0, 1285.0], [287.0, 1435.0], [265.0, 1435.0]], [[232.0, 1281.0], [260.0, 1281.0], [257.0, 1462.0], [229.0, 1462.0]], [[203.0, 1284.0], [225.0, 1284.0], [225.0, 1439.0], [203.0, 1439.0]], [[170.0, 1285.0], [192.0, 1285.0], [192.0, 1512.0], [170.0, 1512.0]], [[139.0, 1285.0], [160.0, 1285.0], [160.0, 1471.0], [139.0, 1471.0]]], "lines": ["あれから色々", "考えて、自分は", "まだまだ子供", "なんだなって改めて", "思い知りました。"]}, {"box": [843, 1146, 965, 1362], "vertical": true, "font_size": 27, "lines_coords": [[[932.0, 1146.0], [965.0, 1146.0], [965.0, 1228.0], [932.0, 1228.0]], [[904.0, 1148.0], [931.0, 1148.0], [931.0, 1351.0], [904.0, 1351.0]], [[873.0, 1148.0], [900.0, 1148.0], [900.0, 1303.0], [873.0, 1303.0]], [[843.0, 1150.0], [865.0, 1150.0], [865.0, 1362.0], [843.0, 1362.0]]], "lines": ["先日は", "失礼なことばかり", "言って申し訳", "ありませんでした。"]}], "img_path": "174.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [845, 106, 967, 340], "vertical": true, "font_size": 25, "lines_coords": [[[939.0, 106.0], [967.0, 106.0], [965.0, 314.0], [937.0, 314.0]], [[907.0, 106.0], [934.0, 106.0], [934.0, 340.0], [907.0, 340.0]], [[878.0, 109.0], [900.0, 109.0], [900.0, 289.0], [878.0, 289.0]], [[845.0, 109.0], [867.0, 109.0], [867.0, 323.0], [845.0, 323.0]]], "lines": ["今日、彼女に僕の", "気持ちをできるだけ", "正直にすべてを", "話そうと思います。"]}, {"box": [376, 185, 498, 393], "vertical": true, "font_size": 26, "lines_coords": [[[471.0, 190.0], [493.0, 190.0], [493.0, 367.0], [471.0, 367.0]], [[439.0, 189.0], [465.0, 189.0], [465.0, 350.0], [439.0, 350.0]], [[406.0, 185.0], [432.0, 185.0], [431.0, 393.0], [404.0, 393.0]], [[376.0, 187.0], [404.0, 187.0], [404.0, 275.0], [376.0, 275.0]]], "lines": ["何も結論なんて", "出てないけど、", "全然迷ってばかり", "だけど、"]}, {"box": [123, 465, 245, 673], "vertical": true, "font_size": 26, "lines_coords": [[[218.0, 467.0], [245.0, 467.0], [245.0, 596.0], [218.0, 596.0]], [[185.0, 467.0], [212.0, 467.0], [212.0, 673.0], [185.0, 673.0]], [[154.0, 465.0], [181.0, 465.0], [178.0, 671.0], [151.0, 671.0]], [[125.0, 465.0], [146.0, 465.0], [145.0, 631.0], [123.0, 631.0]]], "lines": ["もしこれで", "嫌われてしまった", "としても、それが", "僕の全てです。"]}, {"box": [873, 1042, 996, 1260], "vertical": true, "font_size": 27, "lines_coords": [[[968.0, 1042.0], [996.0, 1042.0], [992.0, 1225.0], [964.0, 1225.0]], [[935.0, 1045.0], [962.0, 1045.0], [962.0, 1260.0], [935.0, 1260.0]], [[906.0, 1042.0], [932.0, 1042.0], [929.0, 1196.0], [903.0, 1196.0]], [[873.0, 1043.0], [901.0, 1043.0], [901.0, 1182.0], [873.0, 1182.0]]], "lines": ["生意気な言い方", "かもしれませんが、", "小野寺さんと", "話していて、"]}, {"box": [564, 957, 870, 1042], "vertical": false, "font_size": 38, "lines_coords": [[[564.0, 1004.0], [864.0, 957.0], [870.0, 995.0], [570.0, 1042.0]]], "lines": ["電車はまんが、小野寺と"]}, {"box": [258, 1112, 376, 1278], "vertical": true, "font_size": 22, "lines_coords": [[[351.0, 1112.0], [373.0, 1112.0], [373.0, 1262.0], [351.0, 1262.0]]], "lines": ["強くて自信に"]}, {"box": [251, 1107, 342, 1289], "vertical": true, "font_size": 25, "lines_coords": [[[320.0, 1112.0], [342.0, 1112.0], [342.0, 1289.0], [320.0, 1289.0]], [[287.0, 1110.0], [309.0, 1110.0], [309.0, 1289.0], [287.0, 1289.0]], [[251.0, 1107.0], [284.0, 1107.0], [284.0, 1193.0], [251.0, 1193.0]]], "lines": ["溢れてる人には", "もちろん憧れる", "けれど、"]}, {"box": [771, 1273, 892, 1484], "vertical": true, "font_size": 27, "lines_coords": [[[865.0, 1276.0], [892.0, 1276.0], [892.0, 1484.0], [865.0, 1484.0]], [[832.0, 1275.0], [860.0, 1275.0], [862.0, 1468.0], [834.0, 1468.0]], [[801.0, 1273.0], [829.0, 1273.0], [828.0, 1481.0], [800.0, 1481.0]], [[771.0, 1276.0], [793.0, 1276.0], [793.0, 1439.0], [771.0, 1439.0]]], "lines": ["大人の人でも悩ん", "でるんだなって、", "ちょっと安心して", "しまいました。"]}, {"box": [228, 1318, 250, 1473], "vertical": true, "font_size": 25, "lines_coords": [[[228.0, 1318.0], [250.0, 1318.0], [250.0, 1473.0], [228.0, 1473.0]]], "lines": ["自分の弱さを"]}, {"box": [96, 1315, 251, 1525], "vertical": true, "font_size": 28, "lines_coords": [[[193.0, 1315.0], [220.0, 1315.0], [218.0, 1521.0], [192.0, 1521.0]], [[159.0, 1315.0], [190.0, 1315.0], [190.0, 1525.0], [159.0, 1525.0]], [[129.0, 1317.0], [156.0, 1317.0], [153.0, 1523.0], [126.0, 1523.0]], [[98.0, 1315.0], [125.0, 1315.0], [123.0, 1484.0], [96.0, 1484.0]]], "lines": ["素直に出せる人の", "ほうが、なんだか", "ずっと信用できる", "気がしました。"]}], "img_path": "175.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [878, 65, 968, 281], "vertical": true, "font_size": 23, "lines_coords": [[[942.0, 67.0], [968.0, 67.0], [968.0, 256.0], [942.0, 256.0]], [[907.0, 65.0], [934.0, 65.0], [937.0, 278.0], [910.0, 278.0]], [[878.0, 67.0], [900.0, 67.0], [903.0, 281.0], [881.0, 281.0]]], "lines": ["人は変わります。", "いつか年をとるし、", "環境も変わります。"]}, {"box": [750, 309, 867, 485], "vertical": true, "font_size": 23, "lines_coords": [[[845.0, 310.0], [867.0, 310.0], [867.0, 462.0], [845.0, 462.0]], [[812.0, 309.0], [835.0, 309.0], [837.0, 439.0], [814.0, 439.0]], [[782.0, 310.0], [804.0, 310.0], [804.0, 485.0], [782.0, 485.0]], [[750.0, 309.0], [771.0, 309.0], [773.0, 450.0], [751.0, 450.0]]], "lines": ["人の生き方に", "答えなんて", "無くてもいいと", "思うんです。"]}, {"box": [237, 98, 392, 317], "vertical": true, "font_size": 25, "lines_coords": [[[357.0, 98.0], [389.0, 98.0], [392.0, 282.0], [360.0, 282.0]], [[332.0, 103.0], [354.0, 103.0], [354.0, 279.0], [332.0, 279.0]], [[298.0, 101.0], [321.0, 101.0], [323.0, 260.0], [300.0, 260.0]], [[268.0, 103.0], [290.0, 103.0], [290.0, 306.0], [268.0, 306.0]], [[237.0, 103.0], [259.0, 103.0], [259.0, 317.0], [237.0, 317.0]]], "lines": ["たったひとつの", "答えに満足して", "しまうよりも、", "答えを求めて悩み", "苦しんでるほうが、"]}, {"box": [878, 635, 969, 868], "vertical": true, "font_size": 26, "lines_coords": [[[940.0, 637.0], [967.0, 637.0], [968.0, 817.0], [942.0, 817.0]], [[909.0, 635.0], [935.0, 635.0], [937.0, 868.0], [910.0, 868.0]], [[878.0, 637.0], [904.0, 637.0], [904.0, 818.0], [878.0, 818.0]]], "lines": ["なんかちょっと", "真面目な話になって", "しまいました笑"]}, {"box": [135, 331, 256, 548], "vertical": true, "font_size": 25, "lines_coords": [[[229.0, 331.0], [256.0, 331.0], [256.0, 489.0], [229.0, 489.0]], [[195.0, 334.0], [221.0, 334.0], [221.0, 540.0], [195.0, 540.0]], [[162.0, 334.0], [189.0, 334.0], [192.0, 518.0], [165.0, 518.0]], [[135.0, 335.0], [156.0, 335.0], [156.0, 548.0], [135.0, 548.0]]], "lines": ["すっとずっと", "真剣に生きてるん", "じゃないかって、", "そんな気がします。"]}, {"box": [145, 696, 265, 862], "vertical": true, "font_size": 26, "lines_coords": [[[235.0, 696.0], [262.0, 696.0], [262.0, 829.0], [235.0, 829.0]], [[204.0, 698.0], [231.0, 698.0], [231.0, 828.0], [204.0, 828.0]], [[173.0, 696.0], [200.0, 696.0], [200.0, 832.0], [173.0, 832.0]], [[145.0, 698.0], [167.0, 698.0], [167.0, 859.0], [145.0, 859.0]]], "lines": ["少なくとも、", "小野寺さん", "みたいな人、", "僕は好きです。"]}, {"box": [944, 963, 967, 1051], "vertical": true, "font_size": 23, "lines_coords": [[[944.0, 963.0], [967.0, 963.0], [967.0, 1051.0], [944.0, 1051.0]]], "lines": ["．．．．．う、"]}, {"box": [817, 962, 878, 1096], "vertical": true, "font_size": 26, "lines_coords": [[[851.0, 965.0], [878.0, 965.0], [878.0, 1070.0], [851.0, 1070.0]], [[817.0, 962.0], [843.0, 962.0], [846.0, 1095.0], [820.0, 1095.0]]], "lines": ["うるさい", "うるさい！！"]}, {"box": [696, 965, 760, 1119], "vertical": true, "font_size": 30, "lines_coords": [[[731.0, 967.0], [757.0, 967.0], [757.0, 1118.0], [731.0, 1118.0]], [[696.0, 965.0], [729.0, 965.0], [729.0, 1071.0], [696.0, 1071.0]]], "lines": ["わかってない", "わよ．．．"]}, {"box": [545, 965, 639, 1120], "vertical": true, "font_size": 28, "lines_coords": [[[610.0, 967.0], [639.0, 967.0], [639.0, 1096.0], [610.0, 1096.0]], [[576.0, 965.0], [604.0, 965.0], [607.0, 1118.0], [579.0, 1118.0]], [[545.0, 965.0], [573.0, 965.0], [573.0, 1068.0], [545.0, 1068.0]]], "lines": ["アンタ全然", "わかってない", "わよッ！！"]}, {"box": [432, 939, 460, 1065], "vertical": true, "font_size": 26, "lines_coords": [[[432.0, 939.0], [460.0, 939.0], [460.0, 1065.0], [432.0, 1065.0]]], "lines": ["．．．．．アレ？"]}, {"box": [343, 1079, 400, 1192], "vertical": true, "font_size": 26, "lines_coords": [[[371.0, 1079.0], [400.0, 1079.0], [400.0, 1159.0], [371.0, 1159.0]], [[343.0, 1079.0], [365.0, 1079.0], [365.0, 1192.0], [343.0, 1192.0]]], "lines": ["小野寺", "ごーん"]}, {"box": [923, 1182, 1012, 1348], "vertical": true, "font_size": 27, "lines_coords": [[[985.0, 1184.0], [1012.0, 1184.0], [1012.0, 1290.0], [985.0, 1290.0]], [[950.0, 1182.0], [982.0, 1182.0], [982.0, 1289.0], [950.0, 1289.0]], [[923.0, 1182.0], [945.0, 1182.0], [945.0, 1290.0], [923.0, 1290.0]]], "lines": ["はーい", "息止めて", "くださー"]}, {"box": [654, 1273, 682, 1433], "vertical": true, "font_size": 22, "lines_coords": [[[656.0, 1278.0], [678.0, 1278.0], [678.0, 1428.0], [656.0, 1428.0]]], "lines": ["結局アタシは"]}, {"box": [532, 1273, 592, 1441], "vertical": true, "font_size": 27, "lines_coords": [[[565.0, 1275.0], [592.0, 1275.0], [592.0, 1381.0], [565.0, 1381.0]], [[532.0, 1273.0], [559.0, 1273.0], [562.0, 1439.0], [535.0, 1439.0]]], "lines": ["．．．．．また", "ひとりぼっち。"]}, {"box": [101, 1321, 190, 1490], "vertical": true, "font_size": 27, "lines_coords": [[[164.0, 1321.0], [190.0, 1321.0], [190.0, 1429.0], [164.0, 1429.0]], [[131.0, 1323.0], [159.0, 1323.0], [159.0, 1428.0], [131.0, 1428.0]], [[101.0, 1323.0], [128.0, 1323.0], [128.0, 1490.0], [101.0, 1490.0]]], "lines": ["ちゃんと", "息止めて", "くださーい。"]}], "img_path": "176.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [884, 100, 945, 297], "vertical": true, "font_size": 23, "lines_coords": [[[884.0, 218.0], [907.0, 218.0], [907.0, 295.0], [884.0, 295.0]]], "lines": ["うァ．．．"]}, {"box": [537, 121, 565, 203], "vertical": true, "font_size": 28, "lines_coords": [[[537.0, 121.0], [565.0, 121.0], [565.0, 203.0], [537.0, 203.0]]], "lines": ["アァ．．．"]}, {"box": [245, 207, 279, 293], "vertical": true, "font_size": 30, "lines_coords": [[[245.0, 207.0], [279.0, 207.0], [279.0, 293.0], [245.0, 293.0]]], "lines": ["ひっ．．．"]}, {"box": [179, 284, 206, 390], "vertical": true, "font_size": 30, "lines_coords": [[[179.0, 284.0], [206.0, 284.0], [206.0, 390.0], [179.0, 390.0]]], "lines": ["ひぐっ．．．"]}, {"box": [865, 925, 987, 1133], "vertical": true, "font_size": 23, "lines_coords": [[[962.0, 926.0], [984.0, 926.0], [984.0, 1129.0], [962.0, 1129.0]], [[931.0, 926.0], [953.0, 926.0], [953.0, 1112.0], [931.0, 1112.0]], [[901.0, 928.0], [923.0, 928.0], [923.0, 1132.0], [901.0, 1132.0]], [[865.0, 925.0], [892.0, 925.0], [892.0, 1032.0], [865.0, 1032.0]]], "lines": ["もしもう一度会う", "機会があったら", "またお話聞かせて", "ください"]}, {"box": [399, 1323, 520, 1528], "vertical": true, "font_size": 26, "lines_coords": [[[493.0, 1323.0], [520.0, 1323.0], [520.0, 1453.0], [493.0, 1453.0]], [[462.0, 1323.0], [489.0, 1323.0], [489.0, 1453.0], [462.0, 1453.0]], [[428.0, 1323.0], [454.0, 1323.0], [454.0, 1528.0], [428.0, 1528.0]], [[401.0, 1323.0], [423.0, 1323.0], [423.0, 1453.0], [401.0, 1453.0]]], "lines": ["その時には", "僕も多少は", "大人になってると", "思うので笑"]}], "img_path": "177.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [890, 98, 920, 238], "vertical": true, "font_size": 27, "lines_coords": [[[890.0, 98.0], [917.0, 98.0], [920.0, 237.0], [893.0, 237.0]]], "lines": ["．．．ただいま。"]}, {"box": [170, 257, 195, 412], "vertical": true, "font_size": 22, "lines_coords": [[[170.0, 259.0], [192.0, 259.0], [192.0, 410.0], [170.0, 410.0]]], "lines": ["元気してた？"]}, {"box": [276, 645, 370, 776], "vertical": true, "font_size": 26, "lines_coords": [[[335.0, 645.0], [370.0, 645.0], [370.0, 714.0], [335.0, 714.0]], [[307.0, 646.0], [334.0, 646.0], [334.0, 776.0], [307.0, 776.0]], [[276.0, 646.0], [304.0, 646.0], [304.0, 718.0], [276.0, 718.0]]], "lines": ["あれー", "髪切ったん", "だァー"]}, {"box": [281, 725, 298, 775], "vertical": true, "font_size": 26, "lines_coords": [[[281.0, 725.0], [298.0, 725.0], [298.0, 775.0], [281.0, 775.0]]], "lines": ["！！"]}, {"box": [912, 967, 993, 1181], "vertical": true, "font_size": 25, "lines_coords": [[[967.0, 970.0], [993.0, 970.0], [993.0, 1178.0], [967.0, 1178.0]], [[939.0, 967.0], [965.0, 967.0], [964.0, 1181.0], [937.0, 1181.0]], [[912.0, 968.0], [934.0, 968.0], [934.0, 1132.0], [912.0, 1132.0]]], "lines": ["スーパー行くの久々", "だったから、いっぱい", "買っちゃった！！"]}, {"box": [585, 971, 665, 1154], "vertical": true, "font_size": 22, "lines_coords": [[[642.0, 973.0], [664.0, 973.0], [664.0, 1154.0], [642.0, 1154.0]], [[614.0, 971.0], [635.0, 971.0], [635.0, 1137.0], [614.0, 1137.0]], [[585.0, 975.0], [607.0, 975.0], [607.0, 1114.0], [585.0, 1114.0]]], "lines": ["．．．てかプンプンて", "好きな料理って", "なんだっけ？"]}, {"box": [153, 726, 242, 882], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 726.0], [242.0, 726.0], [242.0, 835.0], [214.0, 835.0]], [[181.0, 726.0], [207.0, 726.0], [207.0, 881.0], [181.0, 881.0]], [[153.0, 726.0], [175.0, 726.0], [175.0, 882.0], [153.0, 882.0]]], "lines": ["奇遇～～", "アタシも染め", "ちゃったァ～！！"]}, {"box": [135, 1006, 244, 1194], "vertical": true, "font_size": 22, "lines_coords": [[[220.0, 1007.0], [242.0, 1007.0], [242.0, 1193.0], [220.0, 1193.0]], [[189.0, 1006.0], [215.0, 1006.0], [215.0, 1171.0], [189.0, 1171.0]], [[164.0, 1006.0], [184.0, 1006.0], [184.0, 1193.0], [164.0, 1193.0]], [[135.0, 1007.0], [157.0, 1007.0], [157.0, 1170.0], [135.0, 1170.0]]], "lines": ["まァ１０代の男子は", "お腹いっぱいに", "なればいいのか！！", "ウフフーーッ！！"]}, {"box": [701, 1271, 809, 1458], "vertical": true, "font_size": 24, "lines_coords": [[[784.0, 1273.0], [806.0, 1273.0], [807.0, 1457.0], [785.0, 1457.0]], [[754.0, 1273.0], [781.0, 1273.0], [781.0, 1437.0], [754.0, 1437.0]], [[726.0, 1271.0], [753.0, 1271.0], [753.0, 1437.0], [726.0, 1437.0]], [[701.0, 1273.0], [723.0, 1273.0], [723.0, 1367.0], [701.0, 1367.0]]], "lines": ["たまには自炊して", "のんびり親子で", "夕食もいいわよ", "ねー！！"]}, {"box": [128, 1242, 618, 1606], "vertical": false, "font_size": 364, "lines_coords": [[[128.0, 1242.0], [618.0, 1242.0], [618.0, 