.0], [864.0, 1414.0]]], "lines": ["最後の最後に", "頼れるのは", "自分だけ。"]}, {"box": [182, 1310, 275, 1492], "vertical": true, "font_size": 26, "lines_coords": [[[242.0, 1310.0], [275.0, 1310.0], [275.0, 1395.0], [242.0, 1395.0]], [[215.0, 1314.0], [237.0, 1314.0], [237.0, 1492.0], [215.0, 1492.0]], [[182.0, 1314.0], [204.0, 1314.0], [204.0, 1492.0], [182.0, 1492.0]]], "lines": ["本当に", "信じられるのは", "自分だけなの！！"]}], "img_path": "206.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [862, 412, 987, 596], "vertical": true, "font_size": 24, "lines_coords": [[[950.0, 412.0], [987.0, 412.0], [987.0, 576.0], [950.0, 576.0]], [[925.0, 417.0], [948.0, 417.0], [946.0, 596.0], [923.0, 596.0]], [[893.0, 418.0], [915.0, 418.0], [915.0, 595.0], [893.0, 595.0]], [[862.0, 417.0], [885.0, 417.0], [885.0, 489.0], [862.0, 489.0]], [[864.0, 482.0], [881.0, 482.0], [881.0, 543.0], [864.0, 543.0]]], "lines": ["なァーんか", "自分で言うのも", "アレなんだけど", "サァー", "！！"]}, {"box": [773, 639, 892, 818], "vertical": true, "font_size": 24, "lines_coords": [[[867.0, 640.0], [890.0, 640.0], [892.0, 767.0], [868.0, 767.0]], [[834.0, 639.0], [860.0, 639.0], [860.0, 793.0], [834.0, 793.0]], [[803.0, 639.0], [826.0, 639.0], [828.0, 792.0], [804.0, 792.0]], [[773.0, 643.0], [795.0, 643.0], [795.0, 818.0], [773.0, 818.0]]], "lines": ["アタシほど", "自分に自信が", "ある人間って", "いないと思う！！"]}, {"box": [135, 621, 256, 856], "vertical": true, "font_size": 24, "lines_coords": [[[229.0, 623.0], [256.0, 623.0], [256.0, 804.0], [229.0, 804.0]], [[195.0, 621.0], [226.0, 621.0], [226.0, 856.0], [195.0, 856.0]], [[167.0, 625.0], [189.0, 625.0], [189.0, 779.0], [167.0, 779.0]], [[135.0, 626.0], [157.0, 626.0], [157.0, 767.0], [135.0, 767.0]]], "lines": ["はっきり言って", "欲しいものはすべて", "手に入る気が", "すんだよねー"]}, {"box": [877, 965, 998, 1173], "vertical": true, "font_size": 26, "lines_coords": [[[970.0, 965.0], [998.0, 965.0], [995.0, 1073.0], [967.0, 1073.0]], [[939.0, 970.0], [965.0, 970.0], [965.0, 1098.0], [939.0, 1098.0]], [[906