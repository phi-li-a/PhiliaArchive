4, 957, 1476], "vertical": true, "font_size": 40, "lines_coords": [[[917.0, 1364.0], [957.0, 1365.0], [954.0, 1476.0], [914.0, 1475.0]]], "lines": ["っ〜っっ"]}, {"box": [426, 1178, 703, 1437], "vertical": true, "font_size": 27, "lines_coords": [[[675.0, 1184.0], [701.0, 1184.0], [701.0, 1323.0], [675.0, 1323.0]], [[642.0, 1181.0], [668.0, 1181.0], [668.0, 1387.0], [642.0, 1387.0]], [[609.0, 1179.0], [635.0, 1179.0], [635.0, 1410.0], [609.0, 1410.0]], [[573.0, 1179.0], [606.0, 1179.0], [606.0, 1275.0], [573.0, 1275.0]], [[523.0, 1181.0], [550.0, 1181.0], [550.0, 1412.0], [523.0, 1412.0]], [[490.0, 1182.0], [517.0, 1182.0], [518.0, 1360.0], [492.0, 1360.0]], [[456.0, 1179.0], [484.0, 1179.0], [487.0, 1437.0], [459.0, 1437.0]], [[426.0, 1181.0], [453.0, 1181.0], [453.0, 1387.0], [426.0, 1387.0]]], "lines": ["「蟹江さんは", "休みの日とか普段", "どんなことしてるの", "カナ！？」", "と、斬新な切り口で", "会話を切り返す", "フンフンの頭の回転の", "速さといったら！！"]}, {"box": [92, 1359, 176, 1517], "vertical": true, "font_size": 27, "lines_coords": [[[146.0, 1359.0], [173.0, 1359.0], [176.0, 1515.0], [150.0, 1515.0]], [[118.0, 1359.0], [145.0, 1359.0], [142.0, 1489.0], [115.0, 1489.0]]], "lines": ["そうだなァ．．．", "普段かァー"]}], "img_path": "108.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [879, 85, 1004, 273], "vertical": true, "font_size": 25, "lines_coords": [[[973.0, 85.0], [1001.0, 85.0], [1004.0, 192.0], [976.0, 192.0]], [[948.0, 89.0], [970.0, 89.0], [970.0, 242.0], [948.0, 242.0]], [[914.0, 87.0], [940.0, 87.0], [940.0, 267.0], [914.0, 267.0]], [[879.0, 85.0], [906.0, 85.0], [906.0, 273.0], [879.0, 273.0]]], "lines": ["．．．あたし", "将来は海外で", "ボランティアの", "仕事したいんだ。"]}, {"box": [189, 79, 334, 289], "vertical": true, "font_size": 23, "lines_coords": [[[306.0, 82.0], [334.0, 82.0], [334.0, 187.0], [306.0, 187.0]], [[278.0, 84.0], [300.0, 84.0], [300.0, 287.0], [278.0, 287.0]], [[245.0, 79.0], [271.0, 79.0], [275.0, 239.0], [248.0, 239.0]], [[215.0, 79.0], [242.0, 79.0], [243.0, 289.0], [217.0, 289.0]], [[189.0, 84.0], [210.0, 84.0], [212.0, 235.0], [190.0, 235.0]]], "lines": ["貧しくて", "不自由な暮らしを", "してる人って", "世界中にたくさん", "いるでしょ？"]}, {"box": [817, 342, 937, 501], "vertical": true, "font_size": 25, "lines_coords": [[[915.0, 346.0], [937.0, 346.0], [937.0, 498.0], [915.0, 498.0]], [[879.0, 342.0], [907.0, 342.0], [904.0, 450.0], [876.0, 450.0]], [[848.0, 343.0], [875.0, 343.0], [875.0, 501.0], [848.0, 501.0]], [[817.0, 343.0], [840.0, 343.0], [843.0, 482.0], [820.0, 482.0]]], "lines": ["．．．と言っても", "まだ全然", "手探りな段階", "なんだけど。"]}, {"box": [100, 332, 250, 564], "vertical": true, "font_size": 23, "lines_coords": [[[223.0, 332.0], [250.0, 332.0], [250.0, 489.0], [223.0, 489.0]], [[193.0, 334.0], [215.0, 334.0], [215.0, 564.0], [193.0, 564.0]], [[160.0, 334.0], [182.0, 334.0], [182.0, 539.0], [160.0, 539.0]], [[126.0, 332.0], [153.0, 332.0], [153.0, 562.0], [126.0, 562.0]], [[100.0, 337.0], [117.0, 337.0], [117.0, 448.0], [100.0, 448.0]]], "lines": ["日本みたいな", "裕福な国にせっかく", "産まれたんだから", "他人の役にたちたい", "んだよねー"]}, {"box": [100, 470, 117, 529], "vertical": true, "font_size": 23, "lines_coords": [[[100.0, 470.0], [117.0, 470.0], [117.0, 529.0], [100.0, 529.0]]], "lines": ["．．．．．"]}, {"box": [729, 1037, 757, 1198], "vertical": true, "font_size": 24, "lines_coords": [[[731.0, 1037.0], [754.0, 1037.0], [753.0, 1193.0], [729.0, 1193.0]]], "lines": ["小野寺くんは"]}, {"box": [289, 704, 409, 912], "vertical": true, "font_size": 26, "lines_coords": [[[381.0, 706.0], [409.0, 706.0], [409.0, 812.0], [381.0, 812.0]], [[353.0, 707.0], [375.0, 707.0], [375.0, 860.0], [353.0, 860.0]], [[318.0, 704.0], [345.0, 704.0], [343.0, 887.0], [317.0, 887.0]], [[289.0, 707.0], [310.0, 707.0], [310.0, 912.0], [289.0, 912.0]]], "lines": ["．．．だから", "強いて言えば", "自主的に英語の", "勉強してるかな？"]}, {"box": [132, 756, 253, 990], "vertical": true, "font_size": 26, "lines_coords": [[[226.0, 757.0], [253.0, 757.0], [253.0, 889.0], [226.0, 889.0]], [[192.0, 756.0], [223.0, 756.0], [223.0, 965.0], [192.0, 965.0]], [[162.0, 757.0], [189.0, 757.0], [187.0, 990.0], [160.0, 990.0]], [[132.0, 760.0], [154.0, 760.0], [154.0, 912.0], [132.0, 912.0]]], "lines": ["人と関わる", "仕事って、言葉の", "コミュニケーションが", "必須でしょ？"]}, {"box": [834, 1095, 956, 1376], "vertical": true, "font_size": 25, "lines_coords": [[[932.0, 1098.0], [954.0, 1098.0], [954.0, 1353.0], [932.0, 1353.0]], [[898.0, 1096.0], [925.0, 1096.0], [925.0, 1281.0], [898.0, 1281.0]], [[864.0, 1095.0], [890.0, 1095.0], [890.0, 1376.0], [864.0, 1376.0]], [[834.0, 1098.0], [860.0, 1098.0], [860.0, 1335.0], [834.0, 1335.0]]], "lines": ["予想をはるかに超えた", "真面目な答えに", "フンフンは何も言えなく", "なってしまいました。"]}, {"box": [512, 1373, 569, 1554], "vertical": true, "font_size": 24, "lines_coords": [[[542.0, 1373.0], [568.0, 1373.0], [568.0, 1554.0], [542.0, 1554.0]], [[512.0, 1375.0], [534.0, 1375.0], [534.0, 1526.0], [512.0, 1526.0]]], "lines": ["普段はいっつも", "何してんの？"]}, {"box": [284, 1096, 315, 1338], "vertical": true, "font_size": 31, "lines_coords": [[[284.0, 1096.0], [315.0, 1096.0], [315.0, 1335.0], [284.0, 1335.0]]], "lines": ["よくよく考えた結果、"]}, {"box": [193, 1093, 257, 1337], "vertical": true, "font_size": 27, "lines_coords": [[[225.0, 1093.0], [257.0, 1093.0], [254.0, 1265.0], [221.0, 1265.0]], [[193.0, 1095.0], [220.0, 1095.0], [220.0, 1337.0], [193.0, 1337.0]]], "lines": ["「テレビ見たり", "ケームやったり．．．"]}, {"box": [104, 1095, 160, 1328], "vertical": true, "font_size": 27, "lines_coords": [[[134.0, 1095.0], [160.0, 1095.0], [160.0, 1301.0], [134.0, 1301.0]], [[104.0, 1096.0], [126.0, 1096.0], [126.0, 1328.0], [104.0, 1328.0]]], "lines": ["としか言いようか", "ありませんでしたか"]}], "img_path": "109.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [879, 51, 912, 233], "vertical": true, "font_size": 30, "lines_coords": [[[881.0, 51.0], [912.0, 51.0], [912.0, 109.0], [881.0, 109.0]], [[879.0, 128.0], [907.0, 128.0], [909.0, 232.0], [881.0, 232.0]]], "lines": ["ふー", "ん．．．．．．"]}, {"box": [434, 59, 467, 143], "vertical": true, "font_size": 30, "lines_coords": [[[434.0, 59.0], [467.0, 59.0], [467.0, 143.0], [434.0, 143.0]]], "lines": ["そう．．．"]}, {"box": [373, 157, 400, 251], "vertical": true, "font_size": 30, "lines_coords": [[[373.0, 157.0], [400.0, 157.0], [400.0, 251.0], [373.0, 251.0]]], "lines": ["なんだ。"]}, {"box": [553, 696, 679, 878], "vertical": true, "font_size": 30, "lines_coords": [[[653.0, 700.0], [679.0, 700.0], [679.0, 878.0], [653.0, 878.0]], [[615.0, 696.0], [650.0, 696.0], [650.0, 781.0], [615.0, 781.0]], [[585.0, 696.0], [614.0, 696.0], [617.0, 829.0], [589.0, 829.0]], [[553.0, 696.0], [587.0, 696.0], [587.0, 784.0], [553.0, 784.0]]], "lines": ["これじゃまるで", "自分が", "果てしなく", "低俗で、"]}, {"box": [192, 442, 219, 598], "vertical": true, "font_size": 22, "lines_coords": [[[192.0, 442.0], [214.0, 442.0], [214.0, 595.0], [192.0, 595.0]]], "lines": ["．．．それだけ？"]}, {"box": [935, 956, 995, 1087], "vertical": true, "font_size": 26, "lines_coords": [[[971.0, 1025.0], [993.0, 1025.0], [993.0, 1082.0], [971.0, 1082.0]], [[967.0, 956.0], [995.0, 956.0], [995.0, 1031.0], [967.0, 1031.0]], [[935.0, 957.0], [962.0, 957.0], [962.0, 1087.0], [935.0, 1087.0]]], "lines": ["ーっ", "あー", "やられた！！"]}, {"box": [487, 696, 520, 906], "vertical": true, "font_size": 30, "lines_coords": [[[492.0, 696.0], [520.0, 696.0], [515.0, 906.0], [487.0, 906.0]]], "lines": ["道徳心のかけらも"]}, {"box": [428, 698, 518, 905], "vertical": true, "font_size": 27, "lines_coords": [[[457.0, 698.0], [489.0, 698.0], [489.0, 882.0], [457.0, 882.0]], [[429.0, 701.0], [451.0, 701.0], [451.0, 904.0], [429.0, 904.0]]], "lines": ["ない人間のよう", "ではないですか！！"]}, {"box": [522, 982, 609, 1137], "vertical": true, "font_size": 22, "lines_coords": [[[587.0, 982.0], [609.0, 982.0], [609.0, 1048.0], [587.0, 1048.0]], [[554.0, 984.0], [576.0, 984.0], [576.0, 1110.0], [554.0, 1110.0]], [[523.0, 982.0], [545.0, 982.0], [545.0, 1137.0], [523.0, 1137.0]]], "lines": ["くそー", "お気に入り", "だったのに：："]}, {"box": [685, 1303, 746, 1459], "vertical": true, "font_size": 28, "lines_coords": [[[718.0, 1304.0], [746.0, 1304.0], [746.0, 1434.0], [718.0, 1434.0]], [[685.0, 1303.0], [712.0, 1303.0], [712.0, 1459.0], [685.0, 1459.0]]], "lines": ["傘、もって", "かれたー！！"]}, {"box": [109, 1110, 200, 1317], "vertical": true, "font_size": 20, "lines_coords": [[[175.0, 1110.0], [195.0, 1110.0], [195.0, 1315.0], [175.0, 1315.0]], [[142.0, 1112.0], [164.0, 1112.0], [164.0, 1237.0], [142.0, 1237.0]], [[112.0, 1112.0], [134.0, 1112.0], [131.0, 1232.0], [109.0, 1232.0]], [[112.0, 1232.0], [129.0, 1232.0], [129.0, 1289.0], [112.0, 1289.0]]], "lines": ["なんでこんなこと", "するかなー", "ひどいよー", "．．．"]}], "img_path": "110.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [834, 96, 884, 257], "vertical": true, "font_size": 24, "lines_coords": [[[862.0, 96.0], [884.0, 96.0], [884.0, 257.0], [862.0, 257.0]], [[834.0, 96.0], [856.0, 96.0], [856.0, 212.0], [834.0, 212.0]]], "lines": ["もっとちゃんと", "本入りなよ"]}, {"box": [801, 128, 832, 168], "vertical": true, "font_size": 24, "lines_coords": [[[809.0, 128.0], [832.0, 132.0], [825.0, 168.0], [801.0, 164.0]]], "lines": ["．．．"]}, {"box": [668, 159, 778, 325], "vertical": true, "font_size": 24, "lines_coords": [[[751.0, 159.0], [778.0, 159.0], [778.0, 303.0], [751.0, 303.0]], [[725.0, 159.0], [753.0, 159.0], [750.0, 257.0], [721.0, 257.0]], [[698.0, 162.0], [720.0, 162.0], [720.0, 301.0], [698.0, 301.0]], [[670.0, 160.0], [692.0, 160.0], [690.0, 325.0], [668.0, 325.0]]], "lines": ["そんなんじゃ", "バッグが", "びしょ濡れに", "なっちゃうよ？"]}, {"box": [441, 148, 499, 329], "vertical": true, "font_size": 24, "lines_coords": [[[471.0, 148.0], [498.0, 148.0], [498.0, 329.0], [471.0, 329.0]], [[442.0, 150.0], [464.0, 150.0], [464.0, 304.0], [442.0, 304.0]]], "lines": ["．．．小野寺くんて", "親切だよね．．．"]}, {"box": [520, 725, 546, 834], "vertical": true, "font_size": 30, "lines_coords": [[[520.0, 725.0], [546.0, 725.0], [546.0, 834.0], [520.0, 834.0]]], "lines": ["ううん、"]}, {"box": [107, 414, 196, 546], "vertical": true, "font_size": 26, "lines_coords": [[[167.0, 415.0], [195.0, 415.0], [195.0, 521.0], [167.0, 521.0]], [[135.0, 414.0], [162.0, 414.0], [162.0, 546.0], [135.0, 546.0]], [[107.0, 415.0], [129.0, 415.0], [129.0, 520.0], [107.0, 520.0]]], "lines": ["気遣いは", "うれしいん", "だけど．．．"]}, {"box": [890, 1098, 978, 1284], "vertical": true, "font_size": 24, "lines_coords": [[[950.0, 1098.0], [976.0, 1098.0], [978.0, 1284.0], [951.0, 1284.0]], [[920.0, 1100.0], [946.0, 1100.0], [946.0, 1231.0], [920.0, 1231.0]], [[890.0, 1100.0], [912.0, 1100.0], [912.0, 1231.0], [890.0, 1231.0]]], "lines": ["：なんか上手く", "話せなくて", "ごめんね．．．"]}, {"box": [421, 834, 485, 1004], "vertical": true, "font_size": 30, "lines_coords": [[[451.0, 834.0], [485.0, 834.0], [485.0, 928.0], [451.0, 928.0]], [[421.0, 834.0], [450.0, 834.0], [451.0, 1004.0], [423.0, 1004.0]]], "lines": ["いいや、", "なんでもない。"]}, {"box": [776, 1248, 882, 1450], "vertical": true, "font_size": 24, "lines_coords": [[[860.0, 1248.0], [882.0, 1248.0], [882.0, 1425.0], [860.0, 1425.0]], [[832.0, 1251.0], [854.0, 1251.0], [854.0, 1370.0], [832.0, 1370.0]], [[801.0, 1248.0], [828.0, 1248.0], [829.0, 1450.0], [803.0, 1450.0]], [[776.0, 1251.0], [798.0, 1251.0], [798.0, 1435.0], [776.0, 1435.0]]], "lines": ["あたし、姉妹しか", "いないから", "男の子のこと、よく", "わかんなくてさ．．．"]}, {"box": [250, 1143, 328, 1328], "vertical": true, "font_size": 23, "lines_coords": [[[306.0, 1143.0], [328.0, 1143.0], [328.0, 1328.0], [306.0, 1328.0]], [[278.0, 1143.0], [300.0, 1143.0], [300.0, 1307.0], [278.0, 1307.0]], [[250.0, 1145.0], [270.0, 1145.0], [270.0, 1282.0], [250.0, 1282.0]]], "lines": ["三村くんとかなら", "まだなんとなく", "わかるけど．．．"]}, {"box": [134, 1312, 223, 1518], "vertical": true, "font_size": 23, "lines_coords": [[[193.0, 1312.0], [220.0, 1312.0], [223.0, 1453.0], [196.0, 1453.0]], [[164.0, 1312.0], [190.0, 1312.0], [190.0, 1518.0], [164.0, 1518.0]], [[134.0, 1314.0], [156.0, 1314.0], [156.0, 1492.0], [134.0, 1492.0]]], "lines": ["小野寺くん、", "なんかつかみ所が", "ないというか．．．"]}], "img_path": "111.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [757, 23, 817, 242], "vertical": true, "font_size": 27, "lines_coords": [[[790.0, 23.0], [817.0, 23.0], [817.0, 179.0], [790.0, 179.0]], [[757.0, 25.0], [784.0, 25.0], [784.0, 235.0], [757.0, 235.0]]], "lines": ["．．．フンフンも", "同じ気持ちでした。"]}, {"box": [543, 23, 667, 208], "vertical": true, "font_size": 26, "lines_coords": [[[639.0, 25.0], [665.0, 25.0], [665.0, 129.0], [639.0, 129.0]], [[606.0, 23.0], [634.0, 23.0], [631.0, 179.0], [603.0, 179.0]], [[575.0, 25.0], [601.0, 25.0], [601.0, 154.0], [575.0, 154.0]], [[545.0, 26.0], [567.0, 26.0], [567.0, 206.0], [545.0, 206.0]]], "lines": ["今ひとつ", "噛み合わない", "この感じか", "歯痒いというか"]}, {"box": [414, 25, 478, 181], "vertical": true, "font_size": 30, "lines_coords": [[[450.0, 25.0], [476.0, 25.0], [476.0, 178.0], [450.0, 178.0]], [[414.0, 25.0], [448.0, 25.0], [448.0, 109.0], [414.0, 109.0]]], "lines": ["申し訳ないと", "いうか、"]}, {"box": [298, 21, 360, 233], "vertical": true, "font_size": 30, "lines_coords": [[[332.0, 25.0], [359.0, 25.0], [359.0, 228.0], [332.0, 228.0]], [[298.0, 21.0], [331.0, 21.0], [331.0, 114.0], [298.0, 114.0]]], "lines": ["不徳の致すところ", "でした。"]}, {"box": [856, 395, 947, 573], "vertical": true, "font_size": 25, "lines_coords": [[[921.0, 395.0], [943.0, 395.0], [943.0, 573.0], [921.0, 573.0]], [[889.0, 395.0], [915.0, 395.0], [915.0, 550.0], [889.0, 550.0]], [[856.0, 395.0], [882.0, 395.0], [882.0, 554.0], [856.0, 554.0]]], "lines": ["これでも必死に", "がんばってる", "つもりなのに、"]}, {"box": [174, 978, 273, 1160], "vertical": true, "font_size": 25, "lines_coords": [[[234.0, 978.0], [262.0, 978.0], [265.0, 1160.0], [237.0, 1160.0]], [[204.0, 979.0], [231.0, 979.0], [231.0, 1135.0], [204.0, 1135.0]], [[175.0, 981.0], [196.0, 981.0], [196.0, 1118.0], [175.0, 1118.0]]], "lines": ["なんか空回って", "とっても変な", "感じでした。"]}, {"box": [609, 1328, 896, 1520], "vertical": true, "font_size": 28, "lines_coords": [[[864.0, 1328.0], [896.0, 1328.0], [896.0, 1410.0], [864.0, 1410.0]], [[834.0, 1329.0], [860.0, 1329.0], [860.0, 1485.0], [834.0, 1485.0]], 