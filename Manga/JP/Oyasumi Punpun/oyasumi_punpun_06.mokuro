0, 981.0], [278.0, 1171.0], [246.0, 1171.0]], [[214.0, 984.0], [245.0, 984.0], [245.0, 1171.0], [214.0, 1171.0]], [[184.0, 984.0], [210.0, 984.0], [210.0, 1220.0], [184.0, 1220.0]]], "lines": ["どんな気持ちで", "会えばいいのか", "整理がつかなくて．．．"]}, {"box": [309, 1342, 375, 1451], "vertical": true, "font_size": 29, "lines_coords": [[[342.0, 1342.0], [375.0, 1342.0], [375.0, 1450.0], [342.0, 1450.0]], [[309.0, 1342.0], [342.0, 1342.0], [342.0, 1451.0], [309.0, 1451.0]]], "lines": ["．．．彼女の", "顔に．．．"]}, {"box": [142, 1375, 235, 1529], "vertical": true, "font_size": 29, "lines_coords": [[[203.0, 1375.0], [235.0, 1375.0], [235.0, 1459.0], [203.0, 1459.0]], [[176.0, 1376.0], [198.0, 1376.0], [198.0, 1529.0], [176.0, 1529.0]], [[142.0, 1376.0], [168.0, 1376.0], [168.0, 1479.0], [142.0, 1479.0]]], "lines": ["大怪我", "させちゃった", "から．．．"]}], "img_path": "064.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [904, 803, 965, 934], "vertical": true, "font_size": 28, "lines_coords": [[[939.0, 804.0], [965.0, 804.0], [965.0, 934.0], [939.0, 934.0]], [[904.0, 803.0], [937.0, 803.0], [937.0, 896.0], [904.0, 896.0]]], "lines": ["はじめての", "彼女で、"]}, {"box": [784, 896, 878, 1084], "vertical": true, "font_size": 28, "lines_coords": [[[848.0, 896.0], [875.0, 896.0], [878.0, 1084.0], [851.0, 1084.0]], [[817.0, 904.0], [843.0, 904.0], [843.0, 1056.0], [817.0, 1056.0]], [[784.0, 898.0], [810.0, 898.0], [812.0, 1067.0], [785.0, 1067.0]]], "lines": ["まだ付き合って", "か月くらい", "なんですけど、"]}, {"box": [92, 914, 219, 1135], "vertical": true, "font_size": 28, "lines_coords": [[[189.0, 914.0], [217.0, 914.0], [218.0, 1048.0], [190.0, 1048.0]], [[159.0, 914.0], [185.0, 914.0], [185.0, 1132.0], [159.0, 1132.0]], [[126.0, 914.0], [153.0, 914.0], [153.0, 1100.0], [126.0, 1100.0]], [[92.0, 915.0], [125.0, 915.0], [125.0, 1021.0], [92.0, 1021.0]]], "lines": ["微妙に憧れ", "だったんですよね、", "自転車二人乗り", "って．．．"]}, {"box": [239, 1207, 364, 1395], "vertical": true, "font_size": 28, "lines_coords": [[[337.0, 1207.0], [364.0, 1207.0], [362.0, 1393.0], [335.0, 1393.0]], [[304.0, 1209.0], [331.0, 1209.0], [331.0, 1395.0], [304.0, 1395.0]], [[271.0, 1209.0], [298.0, 1209.0], [298.0, 1370.0], [271.0, 1370.0]], [[239.0, 1209.0], [267.0, 1209.0], [267.0, 1323.0], [239.0, 1323.0]]], "lines": ["はじめは彼女に", "危ないからって", "止められたん", "ですけど、"]}, {"box": [92, 1328, 218, 1542], "vertical": true, "font_size": 28, "lines_coords": [[[192.0, 1329.0], [218.0, 1329.0], [218.0, 1437.0], [192.0, 1437.0]], [[157.0, 1329.0], [189.0, 1329.0], [189.0, 1542.0], [157.0, 1542.0]], [[125.0, 1329.0], [151.0, 1329.0], [151.0, 1514.0], [125.0, 1514.0]], [[96.0, 1328.0], [125.0, 1328.0], [120.0, 1487.0], [92.0, 1487.0]]], "lines": ["．．．なんか", "かっこつけたくて", "すっげー飛ばし", "ちゃって．．．"]}], "img_path": "065.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [939, 75, 965, 185], "vertical": true, "font_size": 28, "lines_coords": [[[939.0, 75.0], [965.0, 75.0], [965.0, 185.0], [939.0, 185.0]]], "lines": ["そしたら、"]}, {"box": [793, 68, 889, 257], "vertical": true, "font_size": 28, "lines_coords": [[[862.0, 71.0], [889.0, 71.0], [889.0, 203.0], [862.0, 203.0]], [[831.0, 71.0], [857.0, 71.0], [857.0, 231.0], [831.0, 231.0]], [[796.0, 68.0], [828.0, 68.0], [825.0, 257.0], [793.0, 257.0]]], "lines": ["横から車が", "出てきて一瞬", "やべって思って。"]}, {"box": [614, 98, 704, 229], "vertical": true, "font_size": 28, "lines_coords": [[[676.0, 98.0], [704.0, 98.0], [701.0, 229.0], [673.0, 229.0]], [[646.0, 98.0], [673.0, 98.0], [673.0, 229.0], [646.0, 229.0]], [[614.0, 100.0], [640.0, 100.0], [640.0, 209.0], [614.0, 209.0]]], "lines": ["気付いたら", "僕、地面で", "寝てるし、"]}, {"box": [501, 212, 592, 371], "vertical": true, "font_size": 28, "lines_coords": [[[560.0, 212.0], [592.0, 212.0], [592.0, 370.0], [560.0, 370.0]], [[528.0, 212.0], [559.0, 212.0], [559.0, 371.0], [528.0, 371.0]], [[501.0, 215.0], [523.0, 215.0], [523.0, 368.0], [501.0, 368.0]]], "lines": ["遠くで彼女の", "泣いてる声が", "聞こえて．．．"]}, {"box": [929, 734, 984, 917], "vertical": true, "font_size": 24, "lines_coords": [[[957.0, 734.0], [984.0, 734.0], [984.0, 917.0], [957.0, 917.0]], [[929.0, 735.0], [951.0, 735.0], [951.0, 839.0], [929.0, 839.0]]], "lines": ["：やめましょう", "この話！！"]}, {"box": [921, 957, 943, 1090], "vertical": true, "font_size": 24, "lines_coords": [[[921.0, 957.0], [943.0, 957.0], [943.0, 1090.0], [921.0, 1090.0]]], "lines": ["小野寺さん"]}, {"box": [823, 954, 946, 1112], "vertical": true, "font_size": 27, "lines_coords": [[[887.0, 956.0], [914.0, 956.0], [914.0, 1110.0], [887.0, 1110.0]], [[856.0, 954.0], [882.0, 954.0], [879.0, 1112.0], [853.0, 1112.0]], [[823.0, 956.0], [850.0, 956.0], [850.0, 1098.0], [823.0, 1098.0]]], "lines": ["さっきの話の", "続き聞かせて", "くださいよ。"]}, {"box": [276, 782, 332, 937], "vertical": true, "font_size": 24, "lines_coords": [[[306.0, 782.0], [332.0, 782.0], [332.0, 937.0], [306.0, 937.0]], [[276.0, 785.0], [298.0, 785.0], [298.0, 937.0], [276.0, 937.0]]], "lines": ["旦那さんとの", "出会いの話！！"]}, {"box": [274, 786, 332, 939], "vertical": true, "font_size": 58, "lines_coords": [[[274.0, 786.0], [332.0, 786.0], [332.0, 939.0], [274.0, 939.0]]], "lines": ["旦那さんとの出会いの話！！"]}, {"box": [182, 989, 300, 1254], "vertical": true, "font_size": 24, "lines_coords": [[[278.0, 992.0], [300.0, 992.0], [300.0, 1221.0], [278.0, 1221.0]], [[243.0, 989.0], [270.0, 989.0], [270.0, 1254.0], [243.0, 1254.0]], [[212.0, 989.0], [239.0, 989.0], [239.0, 1112.0], [212.0, 1112.0]], [[182.0, 990.0], [204.0, 990.0], [204.0, 1145.0], [182.0, 1145.0]]], "lines": ["旅行先のイタリアで", "スワッピングパーティーに", "潜入してー", "でしたっけ？"]}, {"box": [214, 1118, 235, 1195], "vertical": true, "font_size": 24, "lines_coords": [[[214.0, 1118.0], [235.0, 1118.0], [235.0, 1195.0], [214.0, 1195.0]]], "lines": ["．．．"]}, {"box": [942, 1345, 967, 1488], "vertical": true, "font_size": 22, "lines_coords": [[[943.0, 1346.0], [965.0, 1346.0], [965.0, 1485.0], [943.0, 1485.0]]], "lines": ["．．．やめない"]}, {"box": [182, 1385, 243, 1529], "vertical": true, "font_size": 24, "lines_coords": [[[21