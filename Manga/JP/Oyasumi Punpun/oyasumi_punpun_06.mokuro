 {"box": [126, 1334, 251, 1542], "vertical": true, "font_size": 27, "lines_coords": [[[223.0, 1334.0], [250.0, 1334.0], [250.0, 1492.0], [223.0, 1492.0]], [[190.0, 1335.0], [217.0, 1335.0], [217.0, 1518.0], [190.0, 1518.0]], [[157.0, 1334.0], [184.0, 1334.0], [184.0, 1542.0], [157.0, 1542.0]], [[126.0, 1335.0], [153.0, 1335.0], [153.0, 1465.0], [126.0, 1465.0]]], "lines": ["あたし、昔に", "別れた旦那から", "暴力受けたことが", "あってさ．．．"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [823, 115, 940, 271], "vertical": true, "font_size": 23, "lines_coords": [[[918.0, 117.0], [940.0, 117.0], [940.0, 245.0], [918.0, 245.0]], [[884.0, 115.0], [910.0, 115.0], [910.0, 271.0], [884.0, 271.0]], [[854.0, 117.0], [876.0, 117.0], [876.0, 268.0], [854.0, 268.0]], [[823.0, 117.0], [843.0, 117.0], [843.0, 270.0], [823.0, 270.0]]], "lines": ["今考えると", "事故みたいな", "出来事だった", "気もするし．．．"]}, {"box": [770, 337, 857, 493], "vertical": true, "font_size": 23, "lines_coords": [[[835.0, 340.0], [857.0, 340.0], [857.0, 493.0], [835.0, 493.0]], [[801.0, 337.0], [828.0, 337.0], [828.0, 470.0], [801.0, 470.0]], [[770.0, 339.0], [793.0, 339.0], [795.0, 493.0], [771.0, 493.0]]], "lines": ["なるべくして", "そうなった", "気もするし．．．"]}, {"box": [206, 384, 292, 493], "vertical": true, "font_size": 26, "lines_coords": [[[270.0, 385.0], [292.0, 385.0], [292.0, 487.0], [270.0, 487.0]], [[237.0, 384.0], [265.0, 384.0], [265.0, 467.0], [237.0, 467.0]], [[206.0, 384.0], [232.0, 384.0], [232.0, 493.0], [206.0, 493.0]]], "lines": ["もちろん", "理由は", "どうあれ、"]}, {"box": [148, 559, 237, 715], "vertical": true, "font_size": 26, "lines_coords": [[[209.0, 559.0], [237.0, 559.0], [237.0, 690.0], [209.0, 690.0]], [[176.0, 560.0], [203.0, 560.0], [203.0, 715.0], [176.0, 715.0]], [[148.0, 562.0], [170.0, 562.0], [170.0, 698.0], [148.0, 698.0]]], "lines": ["結果、今の", "現状がすべて", "なんだけど。"]}, {"box": [864, 862, 950, 1021], "vertical": true, "font_size": 24, "lines_coords": [[[928.0, 862.0], [950.0, 862.0], [950.0, 1014.0], [928.0, 1014.0]], [[895.0, 862.0], [917.0, 862.0], [917.0, 990.0], [895.0, 990.0]], [[864.0, 862.0], [885.0, 862.0], [885.0, 1021.0], [864.0, 1021.0]]], "lines": ["時間の流れに", "身を任せて", "ばかりいると、"]}, {"box": [846, 1125, 901, 1135], "vertical": false, "font_size": 10, "lines_coords": [[[846.0, 1125.0], [901.0, 1125.0], [901.0, 1135.0], [846.0, 1135.0]]], "lines": ["ＧＢＯＲＣＭ"]}, {"box": [845, 1146, 903, 1162], "vertical": false, "font_size": 16, "lines_coords": [[[845.0, 1146.0], [903.0, 1146.0], [903.0, 1162.0], [845.0, 1162.0]]], "lines": ["．．．"]}, {"box": [704, 926, 828, 1129], "vertical": true, "font_size": 24, "lines_coords": [[[801.0, 928.0], [828.0, 928.0], [828.0, 1079.0], [801.0, 1079.0]], [[767.0, 928.0], [793.0, 928.0], [795.0, 1129.0], [768.0, 1129.0]], [[735.0, 926.0], [759.0, 926.0], [760.0, 1079.0], [737.0, 1079.0]], [[704.0, 926.0], [731.0, 926.0], [731.0, 1014.0], [704.0, 1014.0]]], "lines": ["．．．とり返しの", "つかないことって", "たくさんある", "のよね。"]}, {"box": [617, 1062, 668, 1089], "vertical": false, "font_size": 27, "lines_coords": [[[617.0, 1062.0], [668.0, 1062.0], [668.0, 1089.0], [617.0, 1089.0]]], "lines": ["１００ちょスッキミクリーム"]}, {"box": [882, 1206, 981, 1339], "vertical": true, "font_size": 29, "lines_coords": [[[953.0, 1206.0], [981.0, 1206.0], [978.0, 1339.0], [950.0, 1339.0]], [[921.0, 1207.0], [948.0, 1207.0], [945.0, 1339.0], [918.0, 1339.0]], [[885.0, 1206.0], [918.0, 1206.0], [915.0, 1318.0], [882.0, 1318.0]]], "lines": ["「大丈夫」も", "「ごめん」も", "「好き」も、"]}, {"box": [764, 1345, 887, 1545], "vertical": true, "font_size": 29, "lines_coords": [[[860.0, 1348.0], [887.0, 1348.0], [887.0, 1479.0], [860.0, 1479.0]], [[826.0, 1348.0], [857.0, 1348.0], [857.0, 1534.0], [826.0, 1534.0]], [[800.0, 1350.0], [821.0, 1350.0], [821.0, 1545.0], [800.0, 1545.0]], [[764.0, 1345.0], [800.0, 1345.0], [800.0, 1418.0], [764.0, 1418.0]]], "lines": ["．．．ホントは", "あたしが旦那に", "言ってほしかった", "台詞。"]}, {"box": [248, 1206, 275, 1342], "vertical": true, "font_size": 27, "lines_coords": [[[248.0, 1206.0], [275.0, 1206.0], [275.0, 1342.0], [248.0, 1342.0]]], "lines": ["ホントはさ、"]}, {"box": [245, 1206, 275, 1342], "vertical": true, "font_size": 27, "lines_coords": [[[245.0, 1206.0], [271.0, 1206.0], [275.0, 1342.0], [248.0, 1342.0]]], "lines": ["ホントはさ、"]}, {"box": [190, 1357, 217, 1464], "vertical": true, "font_size": 27, "lines_coords": [[[190.0, 1357.0], [217.0, 1357.0], [217.0, 1464.0], [190.0, 1464.0]]], "lines": ["あたしは"]}, {"box": [157, 1359, 184, 1512], "vertical": true, "font_size": 30, "lines_coords": [[[157.0, 1359.0], [184.0, 1359.0], [184.0, 1512.0], [157.0, 1512.0]]], "lines": ["別れた旦那が"]}, {"box": [126, 1357, 153, 1490], "vertical": true, "font_size": 27, "lines_coords": [[[126.0, 1357.0], [153.0, 1357.0], [153.0, 1490.0], [126.0, 1490.0]]], "lines": ["今でも好き"]}, {"box": [92, 1357, 125, 1450], "vertical": true, "font_size": 30, "lines_coords": [[[92.0, 1357.0], [125.0, 1357.0], [125.0, 1450.0], [92.0, 1450.0]]], "lines": ["なんだ。"]}], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [846, 73, 940, 206], "vertical": true, "font_size": 30, "lines_coords": [[[914.0, 73.0], [940.0, 73.0], [940.0, 204.0], [914.0, 204.0]], [[881.0, 73.0], [909.0, 73.0], [906.0, 206.0], [878.0, 206.0]], [[846.0, 73.0], [879.0, 73.0], [879.0, 170.0], [846.0, 170.0]]], "lines": ["でも絶対に", "復縁なんて", "しない。"]}, {"box": [721, 121, 818, 281], "vertical": true, "font_size": 30, "lines_coords": [[[785.0, 123.0], [818.0, 123.0], [818.0, 207.0], [785.0, 207.0]], [[754.0, 121.0], [782.0, 121.0], [784.0, 281.0], [756.0, 281.0]], [[721.0, 121.0], [754.0, 121.0], [754.0, 217.0], [721.0, 217.0]]], "lines": ["これは", "あたしの意地", "だから。"]}, {"box": [273, 98, 339, 231], "vertical": true, "font_size": 34, "lines_coords": [[[298.0, 98.0], [339.0, 98.0], [339.0, 159.0], [298.0, 159.0]], [[273.0, 100.0], [300.0, 100.0], [300.0, 231.0], [273.0, 231.0]]], "lines": ["全然", "ないね．．．"]}, {"box": [387, 478, 477, 675], "vertical": true, "font_size": 25, "lines_coords": [[[450.0, 478.0], [476.0, 478.0], [473.0, 637.0], [446.0, 637.0]], [[417.0, 479.0], [443.0, 479.0], [443.0, 612.0], [417.0, 612.0]], [[387.0, 482.0], [409.0, 482.0], [409.0, 675.0], [387.0, 675.0]]], "lines": ["息子さんとは", "そういう話", "しないんですか？"]}, {"box": [120, 514, 182, 657], "vertical": true, "font_size": 30, "lines_coords": [[[148.0, 514.0], [182.0, 514.0], [182.0, 598.0], [148.0, 598.0]], [[120.0, 515.0], [146.0, 515.0], [146.0, 656.0], [120.0, 656.0]]], "lines": ["最悪に", "仲悪いもん。"]}, {"box": [912, 737, 934, 915], "vertical": true, "font_size": 23, "lines_coords": [[[912.0, 737.0], [934.0, 737.0], [934.0, 915.0], [912.0, 915.0]]], "lines": ["親子なのに．．．？"]}, {"box": [796, 903, 881, 1114], "vertical": true, "font_size": 23, "lines_coords": [[[850.0, 903.0], [876.0, 903.0], [881.0, 1071.0], [854.0, 1071.0]], [[825.0, 906.0], [846.0, 906.0], [846.0, 1114.0], [825.0, 1114.0]], [[798.0, 906.0], [820.0, 906.0], [818.0, 1070.0], [796.0, 1070.0]]], "lines": ["自分の子供って", "可愛いものなんじゃ", "ないんですか？"]}, {"box": [223, 756, 318, 940], "vertical": true, "font_size": 27, "lines_coords": [[[279.0, 757.0], [314.0, 756.0], [318.0, 842.0], [284.0, 843.0]], [[257.0, 762.0], [278.0, 762.0], [278.0, 940.0], [257.0, 940.0]], [[225.0, 760.0], [248.0, 760.0], [246.0, 929.0], [223.0, 929.0]]], "lines": ["そりゃ", "そんな風に思う", "時もあるわよ。"]}, {"box": [156, 970, 250, 1129], "vertical": true, "font_size": 27, "lines_coords": [[[217.0, 970.0], [250.0, 970.0], [250.0, 1065.0], [217.0, 1065.0]], [[190.0, 973.0], [212.0, 973.0], [212.0, 1101.0], [190.0, 1101.0]], [[156.0, 973.0], [182.0, 973.0], [182.0, 1129.0], [156.0, 1129.0]]], "lines": ["．．．けど、", "それ以上に", "大半が―．．．"]}, {"box": [927, 1245, 954, 1362], "vertical": true, "font_size": 26, "lines_coords": [[[928.0, 1245.0], [954.0, 1245.0], [954.0, 1362.0], [928.0, 1362.0]]], "lines": ["．．．嫌悪感。"]}, {"box": [296, 1231, 390, 1426], "vertical": true, "font_size": 26, "lines_coords": [[[364.0, 1232.0], [390.0, 1232.0], [390.0, 1370.0], [364.0, 1370.0]], [[332.0, 1232.0], [359.0, 1232.0], [359.0, 1370.0], [332.0, 1370.0]], [[296.0, 1231.0], [323.0, 1231.0], [326.0, 1426.0], [300.0, 1426.0]]], "lines": ["．．．やっぱね、", "似てるのよ、", "あたしや旦那に。"]}, {"box": [106, 1296, 260, 1507], "vertical": true, "font_size": 26, "lines_coords": [[[235.0, 1300.0], [259.0, 1300.0], [260.0, 1487.0], [237.0, 1487.0]], [[203.0, 1298.0], [229.0, 1298.0], [229.0, 1481.0], [203.0, 1481.0]], [[170.0, 1298.0], [196.0, 1298.0], [196.0, 1507.0], [170.0, 1507.0]], [[139.0, 1298.0], [165.0, 1298.0], [165.0, 1482.0], [139.0, 1482.0]], [[106.0, 1296.0], [132.0, 1296.0], [134.0, 1507.0], [107.0, 1507.0]]], "lines": ["親子だからこそ、", "あたしと旦那の", "嫌いなトコが凝縮", "してるみたいで", "とにかく憎いの．．．"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [878, 117, 967, 328], "vertical": true, "font_size": 25, "lines_coords": [[[940.0, 117.0], [967.0, 117.0], [967.0, 225.0], [940.0, 225.0]], [[909.0, 118.0], [932.0, 118.0], [934.0, 298.0], [910.0, 298.0]], [[878.0, 118.0], [900.0, 118.0], [900.0, 328.0], [878.0, 328.0]]], "lines": ["どれだけ", "解り合うことを", "望んでたとしても、"]}, {"box": [878, 329, 904, 437], "vertical": true, "font_size": 25, "lines_coords": [[[878.0, 329.0], [904.0, 329.0], [904.0, 437.0], [878.0, 437.0]]], "lines": ["たとえ"]}, {"box": [232, 242, 353, 453], "vertical": true, "font_size": 25, "lines_coords": [[[326.0, 242.0], [353.0, 242.0], [353.0, 371.0], [326.0, 371.0]], [[295.0, 242.0], [321.0, 242.0], [321.0, 453.0], [295.0, 453.0]], [[265.0, 242.0], [287.0, 242.0], [287.0, 420.0], [265.0, 420.0]], [[232.0, 242.0], [254.0, 242.0], [254.0, 432.0], [232.0, 432.0]]], "lines": ["受け入れる", "気持ちがない限り、", "解り合えること", "なんてないのよ。"]}, {"box": [784, 356, 873, 568], "vertical": true, "font_size": 25, "lines_coords": [[[846.0, 356.0], [873.0, 356.0], [873.0, 537.0], [846.0, 537.0]], [[814.0, 356.0], [840.0, 356.0], [840.0, 537.0], [814.0, 537.0]], [[784.0, 359.0], [806.0, 359.0], [806.0, 568.0], [784.0, 568.0]]], "lines": ["相手の気持ちが", "手に取るように", "わかったとしても、"]}, {"box": [164, 479, 284, 689], "vertical": true, "font_size": 25, "lines_coords": [[[257.0, 481.0], [284.0, 481.0], [284.0, 612.0], [257.0, 612.0]], [[225.0, 479.0], [251.0, 479.0], [251.0, 587.0], [225.0, 587.0]], [[192.0, 481.0], [220.0, 481.0], [221.0, 689.0], [193.0, 689.0]], [[164.0, 481.0], [185.0, 481.0], [185.0, 671.0], [164.0, 671.0]]], "lines": ["年をとれば", "とるほど", "譲れないものって", "増えてくるから。"]}, {"box": [864, 798, 954, 1006], "vertical": true, "font_size": 26, "lines_coords": [[[928.0, 801.0], [954.0, 801.0], [954.0, 906.0], [928.0, 906.0]], [[896.0, 800.0], [923.0, 800.0], [923.0, 1006.0], [896.0, 1006.0]], [[864.0, 798.0], [890.0, 798.0], [890.0, 909.0], [864.0, 909.0]]], "lines": ["．．．きっと", "わたしがあたしで", "ある以上、"]}, {"box": [129, 856, 218, 1010], "vertical": true, "font_size": 22, "lines_coords": [[[190.0, 856.0], [214.0, 856.0], [215.0, 1009.0], [192.0, 1009.0]], [[160.0, 856.0], [182.0, 856.0], [182.0, 1010.0], [160.0, 1010.0]], [[129.0, 856.0], [151.0, 856.0], [151.0, 993.0], [129.0, 993.0]]], "lines": ["この寂しさが", "埋まることは", "ないのよね。"]}, {"box": [896, 1164, 965, 1297], "vertical": true, "font_size": 40, "lines_coords": [[[921.0, 1164.0], [965.0, 1164.0], [965.0, 1235.0], [921.0, 1235.0]], [[896.0, 1165.0], [932.0, 1165.0], [932.0, 1245.0], [896.0, 1245.0]]], "lines": ["．．．雨、", "うぜー"]}, {"box": [125, 1351, 218, 1484], "vertical": true, "font_size": 28, "lines_coords": [[[179.0, 1353.0], [215.0, 1351.0], [218.0, 1434.0], [182.0, 1435.0]], [[153.0, 1354.0], [181.0, 1354.0], [181.0, 1484.0], [153.0, 1484.0]], [[125.0, 1354.0], [146.0, 1354.0], [146.0, 1481.0], [125.0, 1481.0]]], "lines": ["帰って", "筋トレでも", "するか．．．"]}], "img_path": "075.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [841, 82, 965, 289], "vertical": true, "font_size": 28, "lines_coords": [[[931.0, 82.0], [965.0, 82.0], [965.0, 175.0], [931.0, 175.0]], [[904.0, 85.0], [931.0, 85.0], [931.0, 289.0], [904.0, 289.0]], [[871.0, 84.0], [898.0, 84.0], [898.0, 264.0], [871.0, 264.0]], [[842.0, 84.0], [864.0, 84.0], [864.0, 237.0], [842.0, 237.0]]], "lines": ["．．．あれ、", "向こうから来んの", "ウチのクラスの", "女子じゃね？"]}, {"box": [175, 198, 203, 339], "vertical": true, "font_size": 26, "lines_coords": [[[175.0, 198.0], [201.0, 198.0], [201.0, 339.0], [175.0, 339.0]]], "lines": ["あ、マジだ。"]}, {"box": [904, 428, 982, 614], "vertical": true, "font_size": 22, "lines_coords": [[[960.0, 429.0], [982.0, 429.0], [982.0, 614.0], [960.0, 614.0]], [[932.0, 429.0], [954.0, 429.0], [954.0, 587.0], [932.0, 587.0]], [[904.0, 428.0], [926.0, 428.0], [926.0, 590.0], [904.0, 590.0]]], "lines": ["ナョイチョイ～～～", "そこのカワイコ", "ちゃん違～～！！"]}, {"box": [782, 576, 887, 762], "vertical": true, "font_size": 22, "lines_coords": [[[865.0, 579.0], [887.0, 579.0], [887.0, 717.0], [865.0, 717.0]], [[835.0, 576.0], [857.0, 576.0], [857.0, 762.0], [835.0, 762.0]], [[807.0, 576.0], [829.0, 576.0], [829.0, 739.0], [807.0, 739.0]], [[782.0, 578.0], [804.0, 578.0], [804.0, 693.0], [782.0, 693.0]]], "lines": ["金曜なんだし", "フリッとみんなで", "カラオケ行こう", "ぜぇ～～～！！"]}, {"box": [193, 562, 254, 701], "vertical": true, "font_size": 25, "lines_coords": [[[218.0, 562.0], [254.0, 562.0], [254.0, 629.0], [218.0, 629.0]], [[193.0, 565.0], [215.0, 565.0], [215.0, 701.0], [193.0, 701.0]]], "lines": ["．．．あーみむら", "三村だ―．．．"]}, {"box": [194, 567, 249, 707], "vertical": true, "font_size": 55, "lines_coords": [[[194.0, 567.0], [249.0, 567.0], [249.0, 707.0], [194.0, 707.0]]], "lines": ["．．．あ――三村だーー．．"]}, {"box": [601, 1007, 731, 1221], "vertical": true, "font_size": 26, "lines_coords": [[[704.0, 1009.0], [731.0, 1009.0], [731.0, 1117.0], [704.0, 1117.0]], [[678.0, 1007.0], [704.0, 1007.0], [704.0, 1153.0], [678.0, 1153.0]], [[651.0, 1009.0], [678.0, 1009.0], [678.0, 1178.0], [651.0, 1178.0]], [[628.0, 1009.0], [650.0, 1009.0], [650.0, 1171.0], [628.0, 1171.0]], [[601.0, 1009.0], [628.0, 1009.0], [628.0, 1221.0], [601.0, 1221.0]]], "lines": ["．．．バツ、", "ちげーよ！！", "見せてやろうか、", "俺の黒光りする", "ミニ・ウージーを！！"]}, {"box": [103, 760, 237, 925], "vertical": true, "font_size": 25, "lines_coords": [[[210.0, 760.0], [237.0, 760.0], [237.0, 925.0], [210.0, 925.0]], [[185.0, 762.0], [207.0, 762.0], [207.0, 923.0], [185.0, 923.0]], [[156.0, 760.0], [182.0, 760.0], [182.0, 881.0], [156.0, 881.0]], [[129.0, 762.0], [151.0, 762.0], [151.0, 901.0], [129.0, 901.0]], [[103.0, 762.0], [125.0, 762.0], [125.0, 892.0], [103.0, 892.0]]], "lines": ["アンタ、ただの", "高校デビューの", "童貞だって", "ガッコて噂ん", "なってるよー"]}, {"box": [337, 1329, 450, 1475], "vertical": true, "font_size": 29, "lines_coords": [[[426.0, 1334.0], [448.0, 1334.0], [448.0, 1428.0], [426.0, 1428.0]], [[393.0, 1329.0], [426.0, 1329.0], [426.0, 1475.0], [393.0, 1475.0]], [[368.0, 1332.0], [395.0, 1332.0], [395.0, 1450.0], [368.0, 1450.0]], [[337.0, 1329.0], [371.0, 1329.0], [371.0, 1396.0], [337.0, 1396.0]]], "lines": ["．．．なんか", "キモ〜〜〜．．．", "みんな行こ", "行こ。"]}], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [876, 84, 985, 300], "vertical": true, "font_size": 23, "lines_coords": [[[964.0, 85.0], [985.0, 85.0], [985.0, 275.0], [964.0, 275.0]], [[937.0, 85.0], [959.0, 85.0], [959.0, 300.0], [937.0, 300.0]], [[907.0, 85.0], [929.0, 85.0], [929.0, 253.0], [907.0, 253.0]], [[876.0, 84.0], [898.0, 84.0], [901.0, 259.0], [879.0, 259.0]]], "lines": ["．．．あたしが海外で", "遊びまわってる時に", "母親が乳がんて", "死んだんだけど、"]}, {"box": [731, 300, 875, 490], "vertical": true, "font_size": 23, "lines_coords": [[[846.0, 300.0], [875.0, 300.0], [875.0, 445.0], [846.0, 445.0]], [[820.0, 301.0], [842.0, 301.0], [842.0, 443.0], [820.0, 443.0]], [[790.0, 301.0], [812.0, 301.0], [812.0, 470.0], [790.0, 470.0]], [[760.0, 300.0], [782.0, 300.0], [782.0, 490.0], [760.0, 490.0]], [[731.0, 300.0], [753.0, 300.0], [753.0, 473.0], [731.0, 473.0]]], "lines": ["元々、親とは", "ソリが合わな", "かったとはいえ。", "拍子抜けするほど", "悲しくなくてさ。"]}, {"box": [176, 229, 289, 421], "vertical": true, "font_size": 22, "lines_coords": [[[259.0, 229.0], [287.0, 229.0], [289.0, 331.0], [260.0, 331.0]], [[234.0, 232.0], [256.0, 232.0], [256.0, 421.0], [234.0, 421.0]], [[204.0, 232.0], [226.0, 232.0], [226.0, 398.0], [204.0, 398.0]], [[176.0, 232.0], [196.0, 232.0], [196.0, 362.0], [176.0, 362.0]]], "lines": ["葬式にも", "行かなかったけど", "誰にも咎められ", "なかったな。"]}, {"box": [131, 479, 242, 668], "vertical": true, "font_size": 22, "lines_coords": [[[220.0, 482.0], [242.0, 482.0], [242.0, 601.0], [220.0, 601.0]], [[189.0, 481.0], [210.0, 481.0], [210.0, 668.0], [189.0, 668.0]], [[162.0, 481.0], [184.0, 481.0], [184.0, 650.0], [162.0, 650.0]], [[131.0, 479.0], [153.0, 479.0], [153.0, 656.0], [131.0, 656.0]]], "lines": ["父親も弟も", "ハナからあたしが", "薄情な人間って", "思ってたからね。"]}, {"box": [801, 784, 907, 995], "vertical": true, "font_size": 23, "lines_coords": [[[887.0, 787.0], [907.0, 787.0], [907.0, 970.0], [887.0, 970.0]], [[859.0, 785.0], [881.0, 785.0], [881.0, 995.0], [859.0, 995.0]], [[829.0, 784.0], [856.0, 784.0], [854.0, 973.0], [828.0, 973.0]], [[801.0, 784.0], [828.0, 784.0], [828.0, 893.0], [801.0, 893.0]]], "lines": ["あの頃のあたしは", "そういうことが自由", "ってことなんだと", "思ってた。"]}, {"box": [876, 1096, 965, 1287], "vertical": true, "font_size": 26, "lines_coords": [[[939.0, 1098.0], [965.0, 1098.0], [965.0, 1267.0], [939.0, 1267.0]], [[906.0, 1096.0], [932.0, 1096.0], [932.0, 1279.0], [906.0, 1279.0]], [[876.0, 1098.0], [898.0, 1098.0], [898.0, 1287.0], [876.0, 1287.0]]], "lines": ["．．．でもね、今は", "自分探しなんて", "言葉があるけど、"]}, {"box": [659, 800, 764, 1007], "vertical": true, "font_size": 23, "lines_coords": [[[742.0, 800.0], [764.0, 800.0], [764.0, 1007.0], [742.0, 1007.0]], [[714.0, 800.0], [735.0, 800.0], [735.0, 962.0], [714.0, 962.0]], [[685.0, 801.0], [707.0, 801.0], [707.0, 984.0], [685.0, 984.0]], [[659.0, 800.0], [681.0, 800.0], [681.0, 904.0], [659.0, 904.0]]], "lines": ["世の中のことなんて", "これっぽっちも", "わかっちゃいない", "くせにさ。"]}, {"box": [767, 1287, 859, 1448], "vertical": true, "font_size": 26, "lines_coords": [[[832.0, 1290.0], [859.0, 1290.0], [859.0, 1448.0], [832.0, 1448.0]], [[798.0, 1287.0], [826.0, 1287.0], [828.0, 1446.0], [800.0, 1446.0]], [[770.0, 1289.0], [796.0, 1289.0], [793.0, 1446.0], [767.0, 1446.0]]], "lines": ["あたしは自分", "なんて探して", "なかった．．．"]}, {"box": [264, 1156, 406, 1364], "vertical": true, "font_size": 25, "lines_coords": [[[381.0, 1157.0], [406.0, 1157.0], [406.0, 1237.0], [381.0, 1237.0]], [[350.0, 1156.0], [376.0, 1156.0], [376.0, 1364.0], [350.0, 1364.0]], [[320.0, 1157.0], [346.0, 1157.0], [346.0, 1362.0], [320.0, 1362.0]], [[290.0, 1157.0], [317.0, 1157.0], [317.0, 1342.0], [290.0, 1342.0]], [[264.0, 1159.0], [285.0, 1159.0], [285.0, 1323.0], [264.0, 1323.0]]], "lines": ["どうせ", "見つけたところで", "自分がくだらない", "人間なのは十分", "承知だったし。"]}, {"box": [106, 1296, 262, 1506], "vertical": true, "font_size": 25, "lines_coords": [[[231.0, 1296.0], [259.0, 1296.0], [262.0, 1440.0], [234.0, 1440.0]], [[203.0, 1301.0], [225.0, 1301.0], [225.0, 1479.0], [203.0, 1479.0]], [[171.0, 1300.0], [193.0, 1300.0], [193.0, 1506.0], [171.0, 1506.0]], [[137.0, 1298.0], [164.0, 1298.0], [164.0, 1482.0], [137.0, 1482.0]], [[106.0, 1300.0], [132.0, 1300.0], [132.0, 1415.0], [106.0, 1415.0]]], "lines": ["．．．おしろ、", "あたしは誰かに", "見つけられるのを", "待ってたのかも", "しれない。"]}], "img_path": "077.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [950, 70, 984, 159], "vertical": true, "font_size": 34, "lines_coords": [[[950.0, 70.0], [984.0, 70.0], [984.0, 157.0], [950.0, 157.0]]], "lines": ["．．．結局"]}, {"box": [360, 79, 418, 209], "vertical": true, "font_size": 26, "lines_coords": [[[392.0, 79.0], [418.0, 79.0], [418.0, 209.0], [392.0, 209.0]], [[360.0, 79.0], [387.0, 79.0], [387.0, 190.0], [360.0, 190.0]]], "lines": ["そして今も", "あたしは、"]}, {"box": [706, 409, 829, 592], "vertical": true, "font_size": 27, "lines_coords": [[[798.0, 409.0], [826.0, 409.0], [829.0, 515.0], [801.0, 515.0]], [[765.0, 409.0], [796.0, 409.0], [800.0, 592.0], [768.0, 592.0]], [[740.0, 412.0], [762.0, 412.0], [762.0, 592.0], [740.0, 592.0]], [[706.0, 409.0], [732.0, 409.0], [732.0, 550.0], [706.0, 550.0]]], "lines": ["あたしは", "居場所が無くて", "逃げまわってた", "だけなんだ。"]}, {"box": [943, 653, 975, 812], "vertical": true, "font_size": 29, "lines_coords": [[[943.0, 653.0], [975.0, 653.0], [975.0, 812.0], [943.0, 812.0]]], "lines": ["はァ〜〜ア．．．"]}, {"box": [109, 415, 221, 542], "vertical": true, "font_size": 32, "lines_coords": [[[190.0, 417.0], [218.0, 417.0], [218.0, 542.0], [190.0, 542.0]], [[153.0, 418.0], [181.0, 418.0], [181.0, 539.0], [153.0, 539.0]], [[109.0, 415.0], [150.0, 415.0], [150.0, 500.0], [109.0, 500.0]]], "lines": ["どこにも", "居場所が", "無い。"]}, {"box": [884, 837, 910, 993], "vertical": true, "font_size": 29, "lines_coords": [[[884.0, 837.0], [910.0, 837.0], [910.0, 993.0], [884.0, 993.0]]], "lines": ["明日の手術．．．"]}, {"box": [196, 793, 287, 956], "vertical": true, "font_size": 26, "lines_coords": [[[260.0, 795.0], [287.0, 795.0], [287.0, 950.0], [260.0, 950.0]], [[228.0, 795.0], [254.0, 795.0], [254.0, 925.0], [228.0, 925.0]], [[196.0, 793.0], [220.0, 793.0], [221.0, 956.0], [198.0, 956.0]]], "lines": ["医者は簡単な", "手術だとか", "言ってたけど、"]}, {"box": [156, 1018, 245, 1204], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 1020.0], [245.0, 1020.0], [245.0, 1151.0], [217.0, 1151.0]], [[184.0, 1018.0], [215.0, 1018.0], [215.0, 1204.0], [184.0, 1204.0]], [[156.0, 1020.0], [178.0, 1020.0], [178.0, 1176.0], [156.0, 1176.0]]], "lines": ["もしこれで", "死んじゃったら", "どうしよう？"]}, {"box": [272, 1290, 359, 1470], "vertical": true, "font_size": 87, "lines_coords": [[[272.0, 1290.0], [359.0, 1290.0], [359.0, 1470.0], [272.0, 1470.0]]], "lines": ["このまま生き続けられたとしても、"]}, {"box": [270, 1289, 357, 1468], "vertical": true, "font_size": 24, "lines_coords": [[[335.0, 1292.0], [357.0, 1292.0], [357.0, 1395.0], [335.0, 1395.0]], [[303.0, 1290.0], [325.0, 1290.0], [325.0, 1468.0], [303.0, 1468.0]], [[270.0, 1289.0], [296.0, 1289.0], [296.0, 1404.0], [270.0, 1404.0]]], "lines": ["このまま", "生き続けられた", "としても、"]}, {"box": [117, 1376, 203, 1534], "vertical": true, "font_size": 24, "lines_