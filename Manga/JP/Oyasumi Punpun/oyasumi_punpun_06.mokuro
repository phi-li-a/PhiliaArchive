632.0, 539.0], [632.0, 693.0], [606.0, 693.0]], [[575.0, 539.0], [601.0, 539.0], [601.0, 745.0], [575.0, 745.0]], [[543.0, 537.0], [570.0, 537.0], [570.0, 768.0], [543.0, 768.0]], [[509.0, 535.0], [535.0, 535.0], [539.0, 701.0], [512.0, 701.0]]], "lines": ["クラス中から", "パシリにされたり", "上履きを隠されたり", "することなく、"]}, {"box": [350, 535, 442, 667], "vertical": true, "font_size": 27, "lines_coords": [[[414.0, 539.0], [440.0, 539.0], [440.0, 665.0], [414.0, 665.0]], [[381.0, 537.0], [407.0, 537.0], [407.0, 667.0], [381.0, 667.0]], [[350.0, 535.0], [378.0, 535.0], [378.0, 629.0], [350.0, 629.0]]], "lines": ["至極平凡に", "過ぎてゆき", "ました。"]}, {"box": [876, 818, 935, 1026], "vertical": true, "font_size": 30, "lines_coords": [[[903.0, 818.0], [935.0, 818.0], [935.0, 953.0], [903.0, 953.0]], [[876.0, 821.0], [903.0, 821.0], [903.0, 1026.0], [876.0, 1026.0]]], "lines": ["あれーー？", "オノッティーは？"]}, {"box": [179, 1063, 205, 1214], "vertical": true, "font_size": 22, "lines_coords": [[[179.0, 1064.0], [201.0, 1064.0], [201.0, 1212.0], [179.0, 1212.0]]], "lines": ["ウンコだろ？"]}, {"box": [545, 1328, 765, 1543], "vertical": true, "font_size": 26, "lines_coords": [[[737.0, 1331.0], [764.0, 1331.0], [764.0, 1459.0], [737.0, 1459.0]], [[706.0, 1329.0], [732.0, 1329.0], [732.0, 1485.0], [706.0, 1485.0]], [[673.0, 1329.0], [700.0, 1329.0], [700.0, 1485.0], [673.0, 1485.0]], [[642.0, 1329.0], [668.0, 1329.0], [668.0, 1459.0], [642.0, 1459.0]], [[612.0, 1331.0], [634.0, 1331.0], [634.0, 1535.0], [612.0, 1535.0]], [[578.0, 1329.0], [604.0, 1329.0], [604.0, 1535.0], [578.0, 1535.0]], [[545.0, 1328.0], [571.0, 1328.0], [573.0, 1543.0], [546.0, 1543.0]]], "lines": ["フンフンが", "してしまった", "野蛮な行動を", "蟹江さんは", "心の奥底にそっと", "しまってくれたの", "だろうと思います。"]}, {"box": [351, 1328, 472, 1484], "vertical": true, "font_size": 23, "lines_coords": [[[446.0, 1331.0], [468.0, 1331.0], [468.0, 1481.0], [446.0, 1481.0]], [[410.0, 1328.0], [437.0, 1328.0], [440.0, 1484.0], [414.0, 1484.0]], [[382.0, 1331.0], [404.0, 1331.0], [404.0, 1482.0], [382.0, 1482.0]], [[351.0, 1331.0], [373.0, 1331.0], [373.0, 1468.0], [351.0, 1468.0]]], "lines": ["彼女は天使の", "生まれ変わり", "だったのかも", "しれません。"]}], "img_path": "193.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [564, 1129, 615, 1255], "vertical": false, "font_size": 22, "lines_coords": [[[585.0, 1129.0], [615.0, 1248.0], [593.0, 1254.0], [564.0, 1135.0]]], "lines": ["そんなわけかとき"]}, {"box": [859, 1001, 937, 1182], "vertical": false, "font_size": 33, "lines_coords": [[[890.0, 1001.0], [937.0, 1173.0], [904.0, 1182.0], [859.0, 1010.0]]], "lines": ["今朝からパンツを"]}], "img_path": "194.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [21, 452, 78, 629], "vertical": true, "font_size": 22, "lines_coords": [[[23.0, 462.0], [45.0, 462.0], [45.0, 562.0], [23.0, 562.0]]], "lines": ["説明会．．"]}, {"box": [748, 849, 790, 1039], "vertical": true, "font_size": 23, "lines_coords": [[[748.0, 854.0], [771.0, 853.0], [779.0, 1020.0], [756.0, 1021.0]]], "lines": ["レンタルショッ"]}, {"box": [37, 1071, 119, 1266], "vertical": true, "font_size": 37, "lines_coords": [[[75.0, 1100.0], [114.0, 1100.0], [117.0, 1246.0], [78.0, 1246.0]], [[37.0, 1079.0], [71.0, 1078.0], [78.0, 1257.0], [43.0, 1259.0]]], "lines": ["コシルバ", "人材センター"]}], "img_path": "195.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [850, 527, 876, 690], "vertical": true, "font_size": 22, "lines_coords": [[[851.0, 529.0], [873.0, 529.0], [873.0, 682.0], [851.0, 682.0]]], "lines": ["もしかしたら"]}, {"box": [676, 526, 820, 734], "vertical": true, "font_size": 26, "lines_coords": [[[776.0, 528.0], [803.0, 528.0], [803.0, 657.0], [776.0, 657.0]], [[743.0, 528.0], [770.0, 528.0], [770.0, 734.0], [743.0, 734.0]], [[715.0, 528.0], [737.0, 528.0], [737.0, 682.0], [715.0, 682.0]], [[681.0, 526.0], [707.0, 526.0], [707.0, 710.0], [681.0, 710.0]]], "lines": ["フンフンか", "思っているよりも", "すっとずっと", "たくさんの人が"]}, {"box": [542, 526, 635, 692], "vertical": true, "font_size": 27, "lines_coords": [[[607.0, 528.0], [635.0, 528.0], [635.0, 632.0], [607.0, 632.0]], [[573.0, 526.0], [601.0, 526.0], [603.0, 634.0], [575.0, 634.0]], [[542.0, 526.0], [568.0, 526.0], [571.0, 690.0], [545.0, 690.0]]], "lines": ["優しさと", "正しさを", "持ち合わせて、"]}, {"box": [377, 526, 501, 708], "vertical": true, "font_size": 27, "lines_coords": [[[468.0, 528.0], [501.0, 528.0], [501.0, 610.0], [468.0, 610.0]], [[437.0, 526.0], [464.0, 526.0], [467.0, 659.0], [440.0, 659.0]], [[406.0, 526.0], [432.0, 526.0], [434.0, 707.0], [407.0, 707.0]], [[378.0, 531.0], [400.0, 531.0], [400.0, 660.0], [378.0, 660.0]]], "lines": ["毎日を", "かんばって", "生きてるんじゃ", "ないかしら"]}, {"box": [272, 527, 332, 684], "vertical": true, "font_size": 22, "lines_coords": [[[306.0, 529.0], [328.0, 529.0], [328.0, 681.0], [306.0, 681.0]], [[273.0, 529.0], [295.0, 529.0], [295.0, 662.0], [273.0, 662.0]]], "lines": ["そんなことを", "考えました。"]}, {"box": [671, 1310, 762, 1466], "vertical": true, "font_size": 24, "lines_coords": [[[735.0, 1314.0], [757.0, 1314.0], [757.0, 1462.0], [735.0, 1462.0]], [[701.0, 1310.0], [728.0, 1310.0], [728.0, 1465.0], [701.0, 1465.0]], [[671.0, 1314.0], [693.0, 1314.0], [693.0, 1442.0], [671.0, 1442.0]]], "lines": ["馬鹿みたいに", "真っ青な空を", "見ていると"]}, {"box": [582, 1311, 612, 1553], "vertical": true, "font_size": 27, "lines_coords": [[[582.0, 1312.0], [609.0, 1312.0], [609.0, 1545.0], [582.0, 1545.0]]], "lines": ["フンフンはなんだか"]}, {"box": [429, 1312, 524, 1529], "vertical": true, "font_size": 27, "lines_coords": [[[495.0, 1312.0], [523.0, 1312.0], [523.0, 1417.0], [495.0, 1417.0]], [[464.0, 1312.0], [490.0, 1312.0], [490.0, 1493.0], [464.0, 1493.0]], [[429.0, 1315.0], [456.0, 1315.0], [456.0, 1526.0], [429.0, 1526.0]]], "lines": ["世界中に", "謝りたい気分で", "一杯になりました。"]}], "img_path": "196.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "197.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [884, 131, 973, 295], "vertical": true, "font_size": 21, "lines_coords": [[[950.0, 132.0], [971.0, 132.0], [971.0, 287.0], [950.0, 287.0]], [[917.0, 134.0], [939.0, 134.0], [939.0, 257.0], [917.0, 257.0]], [[885.0, 132.0], [906.0, 132.0], [906.0, 290.0], [885.0, 290.0]]], "lines": ["フンフンは今", "はっきりと", "わかりました。"]}, {"box": [729, 425, 785, 563], "vertical": true, "font_size": 20, "lines_coords": [[[760.0, 428.0], [782.0, 428.0], [782.0, 559.0], [760.0, 559.0]], [[731.0, 429.0], [748.0, 429.0], [748.0, 531.0], [731.0, 531.0]]], "lines": ["神様なんて、", "いません"]}, {"box": [548, 518, 575, 654], "vertical": true, "font_size": 27, "lines_coords": [[[548.0, 518.0], [575.0, 518.0], [575.0, 646.0], [548.0, 646.0]]], "lines": ["今ここには"]}, {"box": [393, 516, 452, 654], "vertical": true, "font_size": 24, "lines_coords": [[[425.0, 517.0], [451.0, 517.0], [451.0, 646.0], [425.0, 646.0]], [[395.0, 518.0], [417.0, 518.0], [417.0, 651.0], [395.0, 651.0]]], "lines": ["澱み腐った", "魂がひとつ、"]}, {"box": [173, 514, 301, 670], "vertical": true, "font_size": 29, "lines_coords": [[[265.0, 514.0], [301.0, 514.0], [301.0, 576.0], [265.0, 576.0]], [[234.0, 515.0], [262.0, 515.0], [264.0, 621.0], [235.0, 621.0]], [[203.0, 515.0], [229.0, 515.0], [232.0, 670.0], [206.0, 670.0]], [[173.0, 517.0], [200.0, 517.0], [200.0, 628.0], [173.0, 628.0]]], "lines": ["ただ", "無意味に", "転がっている", "だけです。"]}, {"box": [889, 792, 979, 948], "vertical": true, "font_size": 27, "lines_coords": [[[950.0, 792.0], [978.0, 792.0], [979.0, 946.0], [951.0, 946.0]], [[920.0, 792.0], [946.0, 792.0], [946.0, 948.0], [920.0, 948.0]], [[889.0, 792.0], [917.0, 792.0], [917.0, 896.0], [889.0, 896.0]]], "lines": ["オノッティー", "ウンコ長すぎ", "じゃね？"]}, {"box": [189, 1067, 231, 1187], "vertical": true, "font_size": 33, "lines_coords": [[[192.0, 1067.0], [231.0, 1068.0], [228.0, 1187.0], [189.0, 1185.0]]], "lines": ["ギュモー"]}, {"box": [159, 1129, 185, 1225], "vertical": true, "font_size": 33, "lines_coords": [[[159.0, 1129.0], [185.0, 1129.0], [185.0, 1225.0], [159.0, 1225.0]]], "lines": ["ーッ！！"]}, {"box": [846, 1332, 904, 1464], "vertical": true, "font_size": 25, "lines_coords": [[[876.0, 1332.0], [904.0, 1332.0], [901.0, 1460.0], [873.0, 1460.0]], [[846.0, 1334.0], [868.0, 1334.0], [868.0, 1464.0], [846.0, 1464.0]]], "lines": ["いいことも", "悪いことも"]}, {"box": [712, 1331, 773, 1538], "vertical": true, "font_size": 27, "lines_coords": [[[745.0, 1331.0], [771.0, 1331.0], [771.0, 1537.0], [745.0, 1537.0]], [[712.0, 1332.0], [740.0, 1332.0], [740.0, 1465.0], [712.0, 1465.0]]], "lines": ["世の中のすべての", "ものごとか、"]}, {"box": [545, 1332, 642, 1513], "vertical": true, "font_size": 30, "lines_coords": [[[614.0, 1334.0], [642.0, 1334.0], [642.0, 1439.0], [614.0, 1439.0]], [[581.0, 1332.0], [607.0, 1332.0], [606.0, 1512.0], [579.0, 1512.0]], [[545.0, 1332.0], [579.0, 1332.0], [579.0, 1417.0], [545.0, 1417.0]]], "lines": ["人の心で", "つくられている", "ならば、"]}, {"box": [417, 1332, 477, 1549], "vertical": true, "font_size": 26, "lines_coords": [[[448.0, 1334.0], [475.0, 1334.0], [475.0, 1514.0], [448.0, 1514.0]], [[417.0, 1334.0], [443.0, 1334.0], [443.0, 1546.0], [417.0, 1546.0]]], "lines": ["今のフンフンに", "てきることなんて、"]}, {"box": [253, 1331, 345, 1550], "vertical": true, "font_size": 26, "lines_coords": [[[318.0, 1331.0], [345.0, 1331.0], [345.0, 1435.0], [318.0, 1435.0]], [[284.0, 1331.0], [312.0, 1331.0], [310.0, 1539.0], [282.0, 1539.0]], [[253.0, 1332.0], [275.0, 1332.0], [275.0, 1543.0], [253.0, 1543.0]]], "lines": ["せいぜい", "ひとつくらいしか", "ありませんでした"]}], "img_path": "198.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "199.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "200.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [467, 518, 592, 673], "vertical": true, "font_size": 27, "lines_coords": [[[565.0, 520.0], [592.0, 520.0], [592.0, 660.0], [565.0, 660.0]], [[532.0, 518.0], [559.0, 518.0], [559.0, 673.0], [532.0, 673.0]], [[498.0, 520.0], [526.0, 520.0], [526.0, 623.0], [498.0, 623.0]], [[467.0, 518.0], [493.0, 518.0], [493.0, 662.0], [467.0, 662.0]]], "lines": ["「もう二度と", "誰かを好きに", "なるのは", "やめよう。」"]}, {"box": [712, 1198, 835, 1355], "vertical": true, "font_size": 27, "lines_coords": [[[807.0, 1200.0], [834.0, 1200.0], [834.0, 1329.0], [807.0, 1329.0]], [[776.0, 1200.0], [803.0, 1200.0], [803.0, 1329.0], [776.0, 1329.0]], [[743.0, 1200.0], [770.0, 1200.0], [770.0, 1354.0], [743.0, 1354.0]], [[712.0, 1200.0], [739.0, 1200.0], [739.0, 1335.0], [712.0, 1335.0]]], "lines": ["温かい風に", "包まれると", "涙が出そうに", "なったので、"]}, {"box": [568, 1197, 657, 1338], "vertical": true, "font_size": 25, "lines_coords": [[[631.0, 1198.0], [657.0, 1198.0], [657.0, 1328.0], [631.0, 1328.0]], [[598.0, 1198.0], [625.0, 1198.0], [625.0, 1328.0], [598.0, 1328.0]], [[568.0, 1200.0], [590.0, 1200.0], [590.0, 1335.0], [568.0, 1335.0]]], "lines": ["フンフンは", "そっと目を", "閉じました。"]}, {"box": [376, 1198, 437, 1446], "vertical": true, "font_size": 28, "lines_coords": [[[410.0, 1198.0], [437.0, 1198.0], [437.0, 1406.0], [410.0, 1406.0]], [[376.0, 1198.0], [404.0, 1198.0], [406.0, 1443.0], [378.0, 1443.0]]], "lines": ["．．．今日はひとまず", "それでいいでしょう。"]}, {"box": [254, 1198, 317, 1314], "vertical": true, "font_size": 27, "lines_coords": [[[289.0, 1200.0], [315.0, 1200.0], [315.0, 1307.0], [289.0, 1307.0]], [[254.0, 1200.0], [282.0, 1200.0], [282.0, 1314.0], [254.0, 1314.0]]], "lines": ["おやすみ", "フンフン。"]}], "img_path": "201.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "202.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "203.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [26, 287, 81, 451], "vertical": true, "font_size": 52, "lines_coords": [[[26.0, 289.0], [78.0, 287.0], [81.0, 450.0], [29.0, 451.0]]], "lines": ["第６７話"]}, {"box": [546, 940, 576, 1104], "vertical": true, "font_size": 27, "lines_coords": [[[546.0, 940.0], [573.0, 940.0], [573.0, 1034.0], [546.0, 1034.0]]], "lines": ["二年後ー"]}], "img_path": "204.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [934, 81, 982, 220], "vertical": true, "font_size": 22, "lines_coords": [[[960.0, 81.0], [982.0, 81.0], [982.0, 220.0], [960.0, 220.0]], [[934.0, 84.0], [951.0, 84.0], [951.0, 179.0], [934.0, 179.0]]], "lines": ["しょーじき", "俺はさァ"]}, {"box": [187, 84, 323, 318], "vertical": true, "font_size": 23, "lines_coords": [[[293.0, 84.0], [320.0, 84.0], [323.0, 204.0], [296.0, 204.0]], [[271.0, 89.0], [293.0, 89.0], [293.0, 307.0], [271.0, 307.0]], [[243.0, 90.0], [264.0, 90.0], [264.0, 318.0], [243.0, 318.0]], [[215.0, 89.0], [237.0, 89.0], [237.0, 250.0], [215.0, 250.0]], [[187.0, 89.0], [207.0, 89.0], [207.0, 248.0], [187.0, 248.0]]], "lines": ["．．．特にさァ", "近い未来、俺ら若者に", "介護されるハズなのに", "でかい顔してる", "年寄りとかよ！！"]}, {"box": [829, 289, 964, 523], "vertical": true, "font_size": 22, "lines_coords": [[[942.0, 292.0], [964.0, 292.0], [964.0, 429.0], [942.0, 429.0]], [[912.0, 289.0], [934.0, 289.0], [934.0, 473.0], [912.0, 473.0]], [[882.0, 289.0], [909.0, 289.0], [909.0, 523.0], [882.0, 523.0]], [[854.0, 290.0], [876.0, 290.0], [876.0, 475.0], [854.0, 475.0]], [[829.0, 292.0], [851.0, 292.0], [851.0, 364.0], [829.0, 364.0]]], "lines": ["子育て終えて", "仕事もほどほどの", "ジジババ達の生きてる", "理由がわかんねー", "ワケ！！"]}, {"box": [117, 340, 251, 553], "vertical": true, "font_size": 23, "lines_coords": [[[229.0, 345.0], [251.0, 345.0], [251.0, 550.0], [229.0, 550.0]], [[198.0, 345.0], [220.0, 345.0], [220.0, 529.0], [198.0, 529.0]], [[168.0, 340.0], [195.0, 340.0], [196.0, 543.0], [170.0, 543.0]], [[145.0, 345.0], [167.0, 345.0], [167.0, 553.0], [145.0, 553.0]], [[117.0, 346.0], [139.0, 346.0], [139.0, 531.0], [117.0, 531.0]]], "lines": ["パチンコとテレビで", "人生消費し続ける", "くらいなら、いっそ", "死んでくれたほうが", "１００％でエコだろ！！"]}, {"box": [240, 617, 293, 782], "vertical": true, "font_size": 22, "lines_coords": [[[270.0, 618.0], [292.0, 618.0], [292.0, 748.0], [270.0, 748.0]], [[240.0, 617.0], [262.0, 617.0], [264.0, 782.0], [242.0, 782.0]]], "lines": ["．．．バカ、お前", "聞かれるって．．．"]}, {"box": [200, 942, 231, 1050], "vertical": true, "font_size": 23, "lines_coords": [[[200.0, 942.0], [228.0, 942.0], [231.0, 1050.0], [203.0, 1050.0]]], "lines": ["．．．大丈夫。"]}, {"box": [104, 1032, 181, 1175], "vertical": true, "font_size": 23, "lines_coords": [[[159.0, 1034.0], [181.0, 1034.0], [181.0, 1175.0], [159.0, 1175.0]], [[128.0, 1032.0], [154.0, 1032.0], [154.0, 1129.0], [128.0, 1129.0]], [[104.0, 1035.0], [121.0, 1035.0], [121.0, 1146.0], [104.0, 1146.0]]], "lines": ["君はとっても", "強い女性", "たから．．．"]}, {"box": [571, 1204, 650, 1390], "vertical": true, "font_size": 22, "lines_coords": [[[626.0, 1204.0], [648.0, 1204.0], [648.0, 1348.0], [626.0, 1348.0]], [[598.0, 1204.0], [620.0, 1204.0], [620.0, 1367.0], [598.0, 1367.0]], [[571.0, 1206.0], [592.0, 1206.0], [592.0, 1390.0], [571.0, 1390.0]]], "lines": ["．．．小野寺さん、", "精密検査の結果", "から申しますと．．．"]}, {"box": [351, 1262, 428, 1400], "vertical": true, "font_size": 18, "lines_coords": [[[407.0, 1262.0], [425.0, 1262.0], [425.0, 1376.0], [407.0, 1376.0]], [[378.0, 1262.0], [400.0, 1262.0], [400.0, 1354.0], [378.0, 1354.0]], [[353.0, 1264.0], [368.0, 1264.0], [368.0, 1398.0], [353.0, 1398.0]]], "lines": ["．．．アンタは", "お姉さん", "なんだから！！"]}, {"box": [67, 1348, 175, 1509], "vertical": true, "font_size": 22, "lines_coords": [[[151.0, 1350.0], [173.0, 1350.0], [173.0, 1509.0], [151.0, 1509.0]], [[123.0, 1348.0], [145.0, 1348.0], [145.0, 1485.0], [123.0, 1485.0]], [[95.0, 1348.0], [117.0, 1348.0], [117.0, 1485.0], [95.0, 1485.0]], [[67.0, 1348.0], [87.0, 1348.0], [87.0, 1487.0], [67.0, 1487.0]]], "lines": ["なんでも一人で", "できるように", "ならなくちゃ", "だめなのよ？"]}], "img_path": "205.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [917, 51, 988, 235], "vertical": true, "font_size": 30, "lines_coords": [[[954.0, 51.0], [987.0, 51.0], [987.0, 235.0], [954.0, 235.0]], [