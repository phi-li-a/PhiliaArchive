{"box": [692, 98, 746, 201], "vertical": true, "font_size": 32, "lines_coords": [[[692.0, 98.0], [746.0, 98.0], [746.0, 201.0], [692.0, 201.0]]], "lines": ["わ！！"]}, {"box": [548, 107, 635, 320], "vertical": true, "font_size": 32, "lines_coords": [[[609.0, 107.0], [635.0, 107.0], [635.0, 296.0], [609.0, 296.0]], [[578.0, 107.0], [604.0, 107.0], [604.0, 279.0], [578.0, 279.0]], [[548.0, 110.0], [570.0, 110.0], [570.0, 320.0], [548.0, 320.0]]], "lines": ["脅かさないでよ、", "ちょっと漏らし", "ちゃったじゃない！！"]}, {"box": [109, 64, 393, 90], "vertical": false, "font_size": 26, "lines_coords": [[[109.0, 64.0], [393.0, 64.0], [393.0, 90.0], [109.0, 90.0]]], "lines": ["おやすみプンプンＩＧ"]}, {"box": [98, 284, 220, 451], "vertical": true, "font_size": 28, "lines_coords": [[[193.0, 285.0], [220.0, 285.0], [217.0, 448.0], [190.0, 448.0]], [[157.0, 284.0], [190.0, 284.0], [190.0, 393.0], [157.0, 393.0]], [[129.0, 285.0], [156.0, 285.0], [156.0, 440.0], [129.0, 440.0]], [[98.0, 287.0], [125.0, 287.0], [125.0, 415.0], [98.0, 415.0]]], "lines": ["ジャイアンツ、", "土壇場で", "逆転サヨナラ", "ツーラン！！"]}, {"box": [531, 551, 590, 682], "vertical": true, "font_size": 26, "lines_coords": [[[564.0, 551.0], [590.0, 551.0], [590.0, 681.0], [564.0, 681.0]], [[531.0, 551.0], [557.0, 551.0], [557.0, 682.0], [531.0, 682.0]]], "lines": ["さっきから", "呼んで．．．．．．"]}, {"box": [901, 776, 971, 959], "vertical": true, "font_size": 29, "lines_coords": [[[940.0, 778.0], [971.0, 778.0], [971.0, 959.0], [940.0, 959.0]], [[901.0, 776.0], [934.0, 776.0], [934.0, 931.0], [901.0, 931.0]]], "lines": ["小野寺さんが", "手紙～～～？"]}, {"box": [781, 932, 871, 1040], "vertical": true, "font_size": 29, "lines_coords": [[[843.0, 934.0], [871.0, 934.0], [871.0, 1025.0], [843.0, 1025.0]], [[812.0, 935.0], [839.0, 935.0], [839.0, 1039.0], [812.0, 1039.0]], [[781.0, 932.0], [807.0, 932.0], [807.0, 1040.0], [781.0, 1040.0]]], "lines": ["あはは、", "似合わな", "～～い！！"]}, {"box": [234, 746, 595, 1182], "vertical": false, "font_size": 34.4, "lines_coords": [[[360.0, 746.0], [548.0, 1165.0],