e": 18, "lines_coords": [[[559.0, 743.0], [621.0, 746.0], [621.0, 764.0], [559.0, 760.0]]], "lines": ["教えるかの"]}, {"box": [100, 454, 222, 662], "vertical": true, "font_size": 25, "lines_coords": [[[195.0, 456.0], [221.0, 456.0], [221.0, 662.0], [195.0, 662.0]], [[162.0, 456.0], [189.0, 456.0], [189.0, 639.0], [162.0, 639.0]], [[129.0, 456.0], [156.0, 456.0], [156.0, 662.0], [129.0, 662.0]], [[100.0, 454.0], [121.0, 454.0], [121.0, 643.0], [100.0, 643.0]]], "lines": ["特にこれといった", "原因は無いので、", "自然気胸と呼ばれ", "だりもしますね。"]}, {"box": [848, 745, 1000, 970], "vertical": true, "font_size": 26, "lines_coords": [[[976.0, 754.0], [1000.0, 754.0], [998.0, 926.0], [975.0, 926.0]], [[943.0, 748.0], [970.0, 748.0], [970.0, 954.0], [943.0, 954.0]], [[909.0, 745.0], [935.0, 745.0], [939.0, 970.0], [912.0, 970.0]], [[878.0, 748.0], [904.0, 748.0], [904.0, 931.0], [878.0, 931.0]], [[848.0, 746.0], [875.0, 746.0], [875.0, 887.0], [848.0, 887.0]]], "lines": ["一般に痩せ型の", "若い男性に起こり", "易いんですが、勿論", "女性にも起こる", "ものでして、"]}, {"box": [754, 968, 907, 1189], "vertical": true, "font_size": 26, "lines_coords": [[[885.0, 968.0], [907.0, 968.0], [907.0, 1109.0], [885.0, 1109.0]], [[848.0, 978.0], [876.0, 978.0], [878.0, 1189.0], [850.0, 1189.0]], [[817.0, 976.0], [843.0, 976.0], [843.0, 1185.0], [817.0, 1185.0]], [[784.0, 976.0], [812.0, 976.0], [814.0, 1162.0], [785.0, 1162.0]], [[754.0, 979.0], [781.0, 979.0], [781.0, 1173.0], [754.0, 1173.0]]], "lines": ["現在奥様は", "胸腔にチューブを", "挿入して溜まった", "空気を吸収器で", "排気しています。"]}, {"box": [206, 823, 298, 981], "vertical": true, "font_size": 28, "lines_coords": [[[265.0, 823.0], [298.0, 823.0], [298.0, 907.0], [265.0, 907.0]], [[235.0, 825.0], [262.0, 825.0], [262.0, 981.0], [235.0, 981.0]], [[206.0, 825.0], [228.0, 825.0], [228.0, 959.0], [206.0, 959.0]]], "lines": ["なぁに", "心配しないで", "ダンナさん。"]}, {"box": [140, 1042, 267, 1210], "vertical": true, "font_size": 28, "lines_coords": [[[232.0, 1042.0], [267.0, 1042.0], [267.0, 1126.0], [232.0, 1126.0]], [[204.0, 1043.0], [231.0, 1043.0], [231.0, 1200.0], [204.0, 1200.0]], [[171.0, 1043.0], [198.0, 1043.0], [198.0, 1173.0], [171.0, 1173.0]], [[140.0, 1043.0], [167.0, 1043.0], [167.0, 1210.0], [140.0, 1210.0]]], "lines": ["処置は", "施しましたし", "珍しくない", "病気ですから。"]}, {"box": [851, 1334, 973, 1514], "vertical": true, "font_size": 24, "lines_coords": [[[950.0, 1337.0], [971.0, 1337.0], [971.0, 1489.0], [950.0, 1489.0]], [[915.0, 1334.0], [942.0, 1334.0], [940.0, 1514.0], [914.0, 1514.0]], [[885.0, 1335.0], [907.0, 1335.0], [907.0, 1514.0], [885.0, 1514.0]], [[851.0, 1334.0], [879.0, 1334.0], [879.0, 1425.0], [851.0, 1425.0]]], "lines": ["ただ念のため", "再発予防のため", "手術をおすすめ", "します。"]}, {"box": [121, 1357, 243, 1549], "vertical": true, "font_size": 27, "lines_coords": [[[215.0, 1359.0], [242.0, 1359.0], [242.0, 1489.0], [215.0, 1489.0]], [[178.0, 1357.0], [210.0, 1357.0], [210.0, 1473.0], [178.0, 1473.0]], [[151.0, 1360.0], [178.0, 1360.0], [178.0, 1540.0], [151.0, 1540.0]], [[121.0, 1360.0], [143.0, 1360.0], [143.0, 1548.0], [121.0, 1548.0]]], "lines": ["簡単な手術", "ですから、", "一週間もあれば", "退院できますよ。"]}], "img_path": "032.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [909, 107, 953, 181], "vertical": true, "font_size": 31, "lines_coords": [[[909.0, 110.0], [946.0, 107.0], [953.0, 179.0], [915.0, 181.0]]], "lines": ["あっ、"]}, {"box": [803, 170, 860, 312], "vertical": true, "font_size": 31, "lines_coords": [[[828.0, 170.0], [860.0, 170.0], [860.0, 257.0], [828.0, 257.0]], [[803.0, 175.0], [825.0, 175.0], [825.0, 312.0], [803.0, 312.0]]], "lines": ["旦那様", "すみません。"]}, {"box": [562, 125, 648, 146], "vertical": false, "font_size": 21, "lines_coords": [[[562.0, 125.0], [648.0, 125.0], [648.0, 146.0], [562.0, 146.0]]], "lines": ["、院のてびき"]}, {"box": [137, 142, 259, 334], "vertical": true, "font_size": 23, "lines_coords": [[[232.0, 143.0], [254.0, 143.0], [254.0, 332.0], [232.0, 332.0]], [[200.0, 143.0], [221.0, 143.0], [221.0, 320.0], [200.0, 320.0]], [[165.0, 142.0], [192.0, 142.0], [192.0, 293.0], [165.0, 293.0]], [[137.0, 142.0], [159.0, 142.0], [159.0, 295.0], [137.0, 295.0]]], "lines": ["こちらの、入院と", "手術の承諾書に", "記入をお願い", "てきますか？"]}, {"box": [923, 509, 954, 565], "vertical": true, "font_size": 31, "lines_coords": [[[923.0, 509.0], [954.0, 509.0], [954.0, 565.0], [923.0, 565.0]]], "lines": ["え？"]}, {"box": [843, 709, 878, 795], "vertical": true, "font_size": 35, "lines_coords": [[[843.0, 709.0], [878.0, 709.0], [878.0, 795.0], [843.0, 795.0]]], "lines": ["あ．．．"]}, {"box": [162, 553, 239, 842], "vertical": true, "font_size": 27, "lines_coords": [[[210.0, 557.0], [239.0, 557.0], [239.0, 659.0], [210.0, 659.0]], [[190.0, 737.0], [218.0, 737.0], [218.0, 842.0], [190.0, 842.0]], [[162.0, 739.0], [185.0, 739.0], [185.0, 814.0], [162.0, 814.0]]], "lines": ["あの．．．", "えーっと", "．．．．．．．．"]}, {"box": [400, 1114, 426, 1245], "vertical": true, "font_size": 24, "lines_coords": [[[400.0, 1114.0], [423.0, 1114.0], [425.0, 1245.0], [401.0, 1245.0]]], "lines": ["この方は．．．"]}, {"box": [946, 1367, 976, 1513], "vertical": true, "font_size": 28, "lines_coords": [[[946.0, 1367.0], [975.0, 1367.0], [976.0, 1512.0], [948.0, 1512.0]]], "lines": ["．．．違います。"]}, {"box": [83, 1371, 175, 1526], "vertical": true, "font_size": 25, "lines_coords": [[[146.0, 1371.0], [173.0, 1371.0], [173.0, 1525.0], [146.0, 1525.0]], [[115.0, 1371.0], [142.0, 1371.0], [142.0, 1501.0], [115.0, 1501.0]], [[84.0, 1373.0], [106.0, 1373.0], [106.0, 1523.0], [84.0, 1523.0]]], "lines": ["通りすがりの", "ただの他人", "ですから．．．．．"]}], "img_path": "033.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [942, 101, 970, 204], "vertical": true, "font_size": 29, "lines_coords": [[[942.0, 101.0], [970.0, 101.0], [970.0, 204.0], [942.0, 204.0]]], "lines": ["あの．．．"]}, {"box": [837, 228, 934, 414], "vertical": true, "font_size": 29, "lines_coords": [[[901.0, 228.0], [934.0, 228.0], [934.0, 314.0], [901.0, 314.0]], [[871.0, 231.0], [898.0, 231.0], [898.0, 414.0], [871.0, 414.0]], [[837.0, 229.0], [864.0, 229.0], [867.0, 389.0], [840.0, 389.0]]], "lines": ["色々と", "ご迷惑をおかけ", "しました．．．"]}, {"box": [167, 343, 257, 526], "vertical": true, "font_size": 29, "lines_coords": [[[231.0, 343.0], [257.0, 343.0], [256.0, 526.0], [229.0, 526.0]], [[198.0, 343.0], [225.0, 343.0], [225.0, 501.0], [198.0, 501.0]], [[167.0, 343.0], [193.0, 343.0], [193.0, 525.0], [167.0, 525.0]]], "lines": ["もう二度と会う", "ことは無いと", "思いますけど．．"]}, {"box": [137, 585, 246, 806], "vertical": true, "font_size": 29, "lines_coords": [[[212.0, 590.0], [246.0, 590.0], [246.0, 685.0], [212.0, 685.0]], [[175.0, 589.0], [206.0, 589.0], [206.0, 748.0], [175.0, 748.0]], [[139.0, 585.0], [167.0, 585.0], [165.0, 806.0], [137.0, 806.0]]], "lines": ["本当に", "ありがとう", "ございました：："]}, {"box": [903, 950, 962, 1056], "vertical": true, "font_size": 24, "lines_coords": [[[939.0, 953.0], [960.0, 953.0], [960.0, 1054.0], [939.0, 1054.0]], [[903.0, 950.0], [929.0, 950.0], [929.0, 1056.0], [903.0, 1056.0]]], "lines": ["アタシは", "もう．．．"]}, {"box": [168, 1056, 270, 1165], "vertical": true, "font_size": 35, "lines_coords": [[[229.0, 1057.0], [270.0, 1057.0], [270.0, 1143.0], [229.0, 1143.0]], [[200.0, 1056.0], [232.0, 1056.0], [232.0, 1165.0], [200.0, 1165.0]], [[168.0, 1056.0], [201.0, 1056.0], [201.0, 1164.0], [168.0, 1164.0]]], "lines": ["一人で", "平気です", "から．．．"]}, {"box": [382, 1351, 409, 1534], "vertical": true, "font_size": 27, "lines_coords": [[[382.0, 1351.0], [409.0, 1351.0], [409.0, 1531.0], [382.0, 1531.0]]], "lines": ["さようなら．．．"]}], "img_path": "034.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "035.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [928, 124, 953, 253], "vertical": true, "font_size": 22, "lines_coords": [[[929.0, 125.0], [951.0, 125.0], [951.0, 251.0], [929.0, 251.0]]], "lines": ["なんか．．．．．"]}, {"box": [209, 218, 273, 360], "vertical": true, "font_size": 29, "lines_coords": [[[239.0, 218.0], [273.0, 218.0], [273.0, 304.0], [239.0, 304.0]], [[209.0, 218.0], [237.0, 218.0], [239.0, 360.0], [210.0, 360.0]]], "lines": ["昨日は", "色々言って、"]}, {"box": [343, 696, 401, 864], "vertical": true, "font_size": 26, "lines_coords": [[[373.0, 696.0], [401.0, 696.0], [401.0, 803.0], [373.0, 803.0]], [[343.0, 696.0], [370.0, 696.0], [370.0, 864.0], [343.0, 864.0]]], "lines": ["あァ．．．", "ボーっとする。"]}, {"box": [162, 443, 220, 575], "vertical": true, "font_size": 29, "lines_coords": [[[193.0, 443.0], [220.0, 443.0], [220.0, 575.0], [193.0, 575.0]], [[162.0, 443.0], [189.0, 443.0], [189.0, 550.0], [162.0, 550.0]]], "lines": ["．．．悪かった", "わね．．．．．．"]}, {"box": [928, 996, 1015, 1197], "vertical": true, "font_size": 24, "lines_coords": [[[985.0, 996.0], [1012.0, 996.0], [1015.0, 1143.0], [989.0, 1143.0]], [[956.0, 1001.0], [978.0, 1001.0], [978.0, 1165.0], [956.0, 1165.0]], [[928.0, 1000.0], [950.0, 1000.0], [950.0, 1195.0], [928.0, 1195.0]]], "lines": ["あとのことは", "翠ちゃんに全部", "やってもらうから。"]}, {"box": [546, 1010, 659, 1201], "vertical": true, "font_size": 25, "lines_coords": [[[637.0, 1014.0], [659.0, 1014.0], [659.0, 1151.0], [637.0, 1151.0]], [[606.0, 1012.0], [632.0, 1012.0], [632.0, 1156.0], [606.0, 1156.0]], [[576.0, 1010.0], [603.0, 1010.0], [604.0, 1201.0], [578.0, 1201.0]], [[546.0, 1012.0], [573.0, 1012.0], [576.0, 1118.0], [550.0, 1118.0]]], "lines": ["来たくもない", "見舞いなんて", "無理して来なくて", "いいわよ。"]}, {"box": [206, 784, 298, 917], "vertical": true, "font_size": 26, "lines_coords": [[[271.0, 787.0], [298.0, 787.0], [298.0, 917.0], [271.0, 917.0]], [[240.0, 789.0], [262.0, 789.0], [262.0, 915.0], [240.0, 915.0]], [[206.0, 784.0], [234.0, 784.0], [235.0, 915.0], [207.0, 915.0]]], "lines": ["痛み止めが", "効いてきた", "みたい．．．"]}, {"box": [521, 1250, 606, 1392], "vertical": true, "font_size": 25, "lines_coords": [[[579.0, 1250.0], [606.0, 1250.0], [606.0, 1346.0], [579.0, 1346.0]], [[553.0, 1250.0], [575.0, 1250.0], [575.0, 1392.0], [553.0, 1392.0]], [[525.0, 1250.0], [548.0, 1250.0], [545.0, 1392.0], [521.0, 1392.0]]