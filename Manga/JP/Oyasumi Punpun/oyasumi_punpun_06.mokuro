1407.0]]], "lines": ["キラキラ", "しつづけているの", "だろうと。"]}, {"box": [434, 1292, 495, 1506], "vertical": true, "font_size": 26.5, "lines_coords": [[[468.0, 1292.0], [495.0, 1292.0], [495.0, 1398.0], [468.0, 1398.0]], [[434.0, 1295.0], [460.0, 1295.0], [460.0, 1506.0], [434.0, 1506.0]]], "lines": ["昔も今も", "何ひとつ変わらず、"]}, {"box": [554, 1292, 589, 1379], "vertical": true, "font_size": 35, "lines_coords": [[[554.0, 1292.0], [589.0, 1292.0], [589.0, 1379.0], [554.0, 1379.0]]], "lines": ["星空は、"]}, {"box": [593, 1295, 615, 1470], "vertical": true, "font_size": 22, "lines_coords": [[[593.0, 1295.0], [615.0, 1295.0], [615.0, 1470.0], [593.0, 1470.0]]], "lines": ["きっとあの時の"]}, {"box": [681, 1292, 772, 1434], "vertical": true, "font_size": 25, "lines_coords": [[[743.0, 1293.0], [770.0, 1293.0], [770.0, 1423.0], [743.0, 1423.0]], [[710.0, 1293.0], [737.0, 1293.0], [737.0, 1425.0], [710.0, 1425.0]], [[681.0, 1295.0], [703.0, 1295.0], [703.0, 1431.0], [681.0, 1431.0]]], "lines": ["フンフンは", "ほんやりと", "考えました。"]}], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [163, 452, 220, 592], "vertical": true, "font_size": 22, "lines_coords": [[[165.0, 454.0], [187.0, 454.0], [187.0, 587.0], [165.0, 587.0]]], "lines": ["それなのに、"]}, {"box": [867, 859, 929, 965], "vertical": true, "font_size": 30, "lines_coords": [[[901.0, 864.0], [929.0, 864.0], [929.0, 964.0], [901.0, 964.0]], [[867.0, 859.0], [900.0, 859.0], [900.0, 903.0], [867.0, 903.0]]], "lines": ["ハルミン", "もー"]}, {"box": [948, 1062, 1012, 1243], "vertical": true, "font_size": 27, "lines_coords": [[[976.0, 1064.0], [1003.0, 1064.0], [1003.0, 1243.0], [976.0, 1243.0]]], "lines": ["小松っちゃんも"]}, {"box": [650, 1320, 676, 1483], "vertical": true, "font_size": 26, "lines_coords": [[[650.0, 1320.0], [676.0, 1320.0], [676.0, 1479.0], [650.0, 1479.0]]], "lines": ["シミちゃんも、"]}, {"box": [134, 1375, 173, 1487], "vertical": true, "font_size": 28, "lines_coords": [[[134.0, 1375.0], [162.0, 1375.0], [162.0, 1487.0], [134.0, 1487.0]]], "lines": ["関くんも、"]}], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [139, 1032, 213, 1190], "vertical": true, "font_size": 36, "lines_coords": [[[179.0, 1034.0], [212.0, 1034.0], [212.0, 1189.0], [179.0, 1189.0]], [[139.0, 1032.0], [178.0, 1032.0], [178.0, 1085.0], [139.0, 1085.0]]], "lines": ["愛子ちゃん", "もー"]}, {"box": [481, 1346, 576, 1527], "vertical": true, "font_size": 28, "lines_coords": [[[542.0, 1346.0], [576.0, 1346.0], [576.0, 1439.0], [542.0, 1439.0]], [[514.0, 1346.0], [540.0, 1346.0], [540.0, 1526.0], [514.0, 1526.0]], [[481.0, 1348.0], [504.0, 1348.0], [506.0, 1507.0], [482.0, 1507.0]]], "lines": ["みんな、", "どこかに行って", "しまいました。"]}], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [904, 63, 962, 201], "vertical": true, "font_size": 21, "lines_coords": [[[937.0, 65.0], [959.0, 65.0], [959.0, 187.0], [937.0, 187.0]], [[906.0, 67.0], [926.0, 67.0], [926.0, 196.0], [906.0, 196.0]]], "lines": ["フンフンは", "思いました。"]}, {"box": [707, 307, 835, 489], "vertical": true, "font_size": 28, "lines_coords": [[[803.0, 307.0], [835.0, 307.0], [835.0, 396.0], [803.0, 396.0]], [[773.0, 310.0], [800.0, 310.0], [800.0, 485.0], [773.0, 485.0]], [[742.0, 307.0], [768.0, 307.0], [765.0, 489.0], [739.0, 489.0]], [[707.0, 307.0], [735.0, 307.0], [737.0, 445.0], [709.0, 445.0]]], "lines": ["僕は今、", "こんなところで", "何をやってるん", "だろう、と。"]}, {"box": [543, 62, 635, 242], "vertical": true, "font_size": 25, "lines_coords": [[[609.0, 64.0], [631.0, 64.0], [631.0, 240.0], [609.0, 240.0]], [[575.0, 64.0], [601.0, 64.0], [601.0, 190.0], [575.0, 190.0]], [[543.0, 64.0], [570.0, 64.0], [570.0, 200.0], [543.0, 200.0]]], "lines": ["気心の知れない", "女の子との", "初デートで、"]}, {"box": [307, 63, 364, 215], "vertical": true, "font_size": 22, "lines_coords": [[[339.0, 64.0], [360.0, 64.0], [360.0, 210.0], [339.0, 210.0]], [[307.0, 65.0], [329.0, 65.0], [329.0, 192.0], [307.0, 192.0]]], "lines": ["勝手に陰茎を", "硬直させて"]}, {"box": [734, 696, 885, 900], "vertical": true, "font_size": 25, "lines_coords": [[[864.0, 698.0], [885.0, 698.0], [885.0, 900.0], [864.0, 900.0]], [[828.0, 696.0], [856.0, 696.0], [853.0, 826.0], [825.0, 826.0]], [[800.0, 698.0], [821.0, 698.0], [821.0, 826.0], [800.0, 826.0]], [[764.0, 696.0], [790.0, 696.0], [790.0, 900.0], [764.0, 900.0]], [[734.0, 698.0], [756.0, 698.0], [756.0, 825.0], [734.0, 825.0]]], "lines": ["子供の頃の自分は", "今の自分の", "こんな姿を", "想像できていたの", "だろうか？"]}, {"box": [407, 309, 562, 567], "vertical": true, "font_size": 25, "lines_coords": [[[539.0, 312.0], [560.0, 312.0], [560.0, 435.0], [539.0, 435.0]], [[503.0, 309.0], [531.0, 309.0], [529.0, 565.0], [501.0, 565.0]], [[471.0, 309.0], [498.0, 309.0], [498.0, 567.0], [471.0, 567.0]], [[439.0, 310.0], [465.0, 310.0], [465.0, 490.0], [439.0, 490.0]], [[409.0, 312.0], [431.0, 312.0], [431.0, 496.0], [409.0, 496.0]]], "lines": ["あわよくは", "先っほだけで良いから", "入れさせて頂きたいと", "思ってる自分は", "なんなんだろう。"]}, {"box": [675, 696, 703, 800], "vertical": true, "font_size": 25, "lines_coords": [[[675.0, 696.0], [703.0, 696.0], [703.0, 800.0], [675.0, 800.0]]], "lines": ["．．．さぁ？"]}, {"box": [553, 695, 643, 903], "vertical": true, "font_size": 25, "lines_coords": [[[620.0, 695.0], [643.0, 695.0], [640.0, 825.0], [617.0, 825.0]], [[584.0, 695.0], [610.0, 695.0], [612.0, 903.0], [585.0, 903.0]], [[553.0, 696.0], [579.0, 696.0], [579.0, 882.0], [553.0, 882.0]]], "lines": ["きっと何も", "考えてなかったに", "違いありません。"]}, {"box": [391, 696, 480, 852], "vertical": true, "font_size": 23, "lines_coords": [[[453.0, 700.0], [475.0, 700.0], [475.0, 848.0], [453.0, 848.0]], [[420.0, 696.0], [446.0, 696.0], [446.0, 803.0], [420.0, 803.0]], [[392.0, 698.0], [414.0, 698.0], [414.0, 826.0], [392.0, 826.0]]], "lines": ["ただひたすら", "だらだら", "くすくすと"]}, {"box": [128, 309, 254, 591], "vertical": true, "font_size": 26, "lines_coords": [[[228.0, 312.0], [248.0, 312.0], [248.0, 589.0], [228.0, 589.0]], [[192.0, 309.0], [218.0, 309.0], [220.0, 565.0], [193.0, 565.0]], [[159.0, 309.0], [192.0, 309.0], [192.0, 415.0], [159.0, 415.0]], [[128.0, 309.0], [154.0, 309.0], [156.0, 515.0], [129.0, 515.0]]], "lines": ["それを悟られないように", "必死に取り繕っている", "自分って", "なんなんだろう？"]}, {"box": [964, 1078, 985, 1307], "vertical": true, "font_size": 23, "lines_coords": [[[964.0, 1078.0], [985.0, 1078.0], [985.0, 1307.0], [964.0, 1307.0]]], "lines": ["あの時に見た星空は"]}, {"box": [881, 1075, 937, 1232], "vertical": true, "font_size": 23, "lines_coords": [[[910.0, 1075.0], [937.0, 1075.0], [937.0, 1179.0], [910.0, 1179.0]], [[881.0, 1076.0], [907.0, 1076.0], [907.0, 1232.0], [881.0, 1232.0]]], "lines": ["音も今も", "ずっと未来も"]}, {"box": [767, 1076, 853, 1284], "vertical": true, "font_size": 23, "lines_coords": [[[831.0, 1079.0], [853.0, 1079.0], [853.0, 1254.0], [831.0, 1254.0]], [[798.0, 1078.0], [820.0, 1078.0], [820.0, 1232.0], [798.0, 1232.0]], [[767.0, 1076.0], [789.0, 1076.0], [789.0, 1284.0], [767.0, 1284.0]]], "lines": ["きっと同じ様に", "変わらず輝き", "続けるはずなのに"]}, {"box": [553, 1075, 647, 1286], "vertical": true, "font_size": 26, "lines_coords": [[[620.0, 1078.0], [643.0, 1078.0], [642.0, 1279.0], [618.0, 1279.0]], [[587.0, 1075.0], [614.0, 1075.0], [610.0, 1231.0], [584.0, 1231.0]], [[554.0, 1076.0], [581.0, 1076.0], [579.0, 1259.0], [553.0, 1259.0]]], "lines": ["自分だけか着々と", "下衆な感じに", "なってゆくのは"]}, {"box": [443, 1076, 503, 1309], "vertical": true, "font_size": 24, "lines_coords": [[[479.0, 1078.0], [501.0, 1078.0], [501.0, 1304.0], [479.0, 1304.0]], [[443.0, 1076.0], [470.0, 1076.0], [470.0, 1217.0], [443.0, 1217.0]]], "lines": ["とっても不公平だと", "思いました。"]}, {"box": [246, 697, 336, 937], "vertical": true, "font_size": 21, "lines_coords": [[[312.0, 698.0], [332.0, 698.0], [332.0, 848.0], [312.0, 848.0]], [[279.0, 698.0], [301.0, 698.0], [301.0, 825.0], [279.0, 825.0]], [[248.0, 698.0], [270.0, 698.0], [270.0, 931.0], [248.0, 931.0]]], "lines": ["流されるまま", "生きてきた", "結果じゃないですか"]}, {"box": [296, 1075, 390, 1333], "vertical": true, "font_size": 27, "lines_coords": [[[360.0, 1075.0], [387.0, 1075.0], [387.0, 1331.0], [360.0, 1331.0]], [[329.0, 1076.0], [356.0, 1076.0], [356.0, 1257.0], [329.0, 1257.0]], [[296.0, 1076.0], [323.0, 1076.0], [323.0, 1192.0], [296.0, 1192.0]]], "lines": ["．．．なんだかフンフンは", "息苦しくなって", "きました。"]}, {"box": [147, 1257, 206, 1525], "vertical": true, "font_size": 22, "lines_coords": [[[179.0, 1257.0], [200.0, 1257.0], [203.0, 1409.0], [182.0, 1409.0]], [[148.0, 1259.0], [170.0, 1259.0], [170.0, 1518.0], [148.0, 1518.0]]], "lines": ["そして今一度", "フンフンは思いました。"]}], "img_path": "126.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [868, 101, 926, 282], "vertical": true, "font_size": 22, "lines_coords": [[[903.0, 103.0], [925.0, 103.0], [925.0, 279.0], [903.0, 279.0]], [[868.0, 103.0], [890.0, 103.0], [890.0, 278.0], [868.0, 278.0]]], "lines": ["こんなところで", "何やってんの？"]}, {"box": [679, 165, 771, 294], "vertical": true, "font_size": 25, "lines_coords": [[[743.0, 167.0], [770.0, 167.0], [770.0, 271.0], [743.0, 271.0]], [[714.0, 167.0], [735.0, 167.0], [735.0, 293.0], [714.0, 293.0]], [[679.0, 167.0], [706.0, 167.0], [706.0, 268.0], [679.0, 268.0]]], "lines": ["ホントに", "こんなんて", "いいの？"]}, {"box": [521, 340, 548, 558], "vertical": true, "font_size": 22, "lines_coords": [[[523.0, 342.0], [545.0, 342.0], [545.0, 551.0], [523.0, 551.0]]], "lines": ["ちゃんと頭使えよ。"]}, {"box": [242, 584, 397, 800], "vertical": true, "font_size": 27, "lines_coords": [[[370.0, 585.0], [396.0, 585.0], [396.0, 714.0], [370.0, 714.0]], [[339.0, 584.0], [365.0, 584.0], [365.0, 714.0], [339.0, 714.0]], [[303.0, 584.0], [334.0, 584.0], [334.0, 742.0], [303.0, 742.0]], [[273.0, 584.0], [300.0, 584.0], [298.0, 792.0], [271.0, 792.0]], [[242.0, 589.0], [268.0, 589.0], [268.0, 798.0], [242.0, 798.0]]], "lines": ["くだらねえ", "言い訳とか", "言い逃れとか", "話のすり換えとか", "たくさんなんだよ。"]}, {"box": [150, 863, 175, 1002], "vertical": true, "font_size": 22, "lines_coords": [[[151.0, 865.0], [173.0, 865.0], [171.0, 992.0], [150.0, 992.0]]], "lines": ["．．．バカ野郎"]}, {"box": [521, 1188, 545, 1328], "vertical": true, "font_size": 22, "lines_coords": [[[521.0, 1189.0], [543.0, 1189.0], [543.0, 1318.0], [521.0, 1318.0]]], "lines": ["．．．うるさい"]}, {"box": [396, 1189, 420, 1390], "vertical": true, "font_size": 24, "lines_coords": [[[396.0, 1189.0], [418.0, 1189.0], [420.0, 1390.0], [398.0, 1390.0]]], "lines": ["．．．うるさいな．．．"]}, {"box": [268, 1187, 357, 1390], "vertical": true, "font_size": 24, "lines_coords": [[[335.0, 1189.0], [357.0, 1189.0], [357.0, 1390.0], [335.0, 1390.0]], [[300.0, 1187.0], [326.0, 1187.0], [326.0, 1387.0], [300.0, 1387.0]], [[268.0, 1189.0], [295.0, 1189.0], [295.0, 1318.0], [268.0, 1318.0]]], "lines": ["自分は自分なりに", "がんばってるじゃ", "ないか．．．"]}, {"box": [114, 1296, 205, 1514], "vertical": true, "font_size": 22, "lines_coords": [[[179.0, 1300.0], [201.0, 1300.0], [201.0, 1423.0], [179.0, 1423.0]], [[148.0, 1298.0], [170.0, 1298.0], [170.0, 1423.0], [148.0, 1423.0]], [[114.0, 1298.0], [135.0, 1298.0], [135.0, 1507.0], [114.0, 1507.0]]], "lines": ["フンフンは", "きりきりで", "踏み止まりました"]}], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [937, 100, 965, 209], "vertical": true, "font_size": 28, "lines_coords": [[[937.0, 100.0], [965.0, 100.0], [965.0, 209.0], [937.0, 209.0]]], "lines": ["．．．この絵、"]}, {"box": [842, 243, 901, 348], "vertical": true, "font_size": 28, "lines_coords": [[[873.0, 245.0], [901.0, 245.0], [901.0, 348.0], [873.0, 348.0]], [[842.0, 243.0], [870.0, 243.0], [870.0, 334.0], [842.0, 334.0]]], "lines": ["あたしの", "なんだ。"]}, {"box": [240, 104, 268, 162], "vertical": true, "font_size": 24, "lines_coords": [[[240.0, 104.0], [268.0, 104.0], [268.0, 162.0], [240.0, 162.0]]], "lines": ["．．．ま"]}, {"box": [128, 203, 206, 398], "vertical": true, "font_size": 24, "lines_coords": [[[181.0, 203.0], [204.0, 203.0], [206.0, 387.0], [182.0, 387.0]], [[153.0, 203.0], [179.0, 203.0], [176.0, 368.0], [150.0, 368.0]], [[128.0, 204.0], [148.0, 204.0], [148.0, 398.0], [128.0, 398.0]]], "lines": ["絵の具の無駄使い", "って言われても", "言い返せないよね。"]}, {"box": [904, 512, 985, 712], "vertical": true, "font_size": 25, "lines_coords": [[[964.0, 515.0], [985.0, 515.0], [985.0, 678.0], [964.0, 678.0]], [[932.0, 512.0], [959.0, 512.0], [960.0, 712.0], [934.0, 712.0]], [[904.0, 514.0], [931.0, 514.0], [932.0, 685.0], [906.0, 685.0]]], "lines": ["このＯＧ展って", "毎回、参加者共通で", "お題があってさ。"]}, {"box": [789, 562, 875, 756], "vertical": true, "font_size": 25, "lines_coords": [[[840.0, 562.0], [875.0, 562.0], [875.0, 640.0], [840.0, 640.0]], [[818.0, 567.0], [840.0, 567.0], [840.0, 726.0], [818.0, 726.0]], [[789.0, 564.0], [810.0, 564.0], [812.0, 756.0], [790.0, 756.0]]], "lines": ["今回は", "「十代の記憶」が", "テーマなんだけど、"]}, {"box": [93, 612, 230, 796], "vertical": true, "font_size": 22, "lines_coords": [[[206.0, 612.0], [228.0, 612.0], [228.0, 750.0], [206.0, 750.0]], [[178.0, 612.0], [200.0, 612.0], [200.0, 796.0], [178.0, 796.0]], [[150.0, 612.0], [171.0, 612.0], [171.0, 796.0], [150.0, 796.0]], [[120.0, 612.0], [142.0, 612.0], [142.0, 775.0], [120.0, 775.0]], [[93.0, 612.0], [115.0, 612.0], [115.0, 751.0], [93.0, 751.0]]], "lines": ["昔の思い出に", "とらわれるのって", "なんか非生産的で", "好きじゃないん", "だよねー．．．"]}, {"box": [904, 882, 953, 978], "vertical": true, "font_size": 24, "lines_coords": [[[931.0, 882.0], [953.0, 882.0], [953.0, 978.0], [931.0, 978.0]], [[904.0, 885.0], [928.0, 885.0], [928.0, 959.0], [904.0, 959.0]]], "lines": ["．．．なんと", "言うか"]}, {"box": [828, 987, 881, 1150], "vertical": true, "font_size": 24, "lines_coords": [[[854.0, 987.0], [881.0, 987.0], [881.0, 1106.0], [854.0, 1106.0]], [[828.0, 989.0], [850.0, 989.0], [850.0, 1150.0], [828.0, 1150.0]]], "lines": ["深くは詮索", "しませんけど．．．"]}, {"box": [837, 1271, 945, 1460], "vertical": true, "font_size": 23, "lines_coords": [[[923.0, 1275.0], [945.0, 1275.0], [945.0, 1367.0], [923.0, 1367.0]], [[893.0, 1273.0], [915.0, 1273.0], [915.0, 1437.0], [893.0, 1437.0]], [[865.0, 1273.0], [887.0, 1273.0], [887.0, 1460.0], [865.0, 1460.0]], [[837.0, 1271.0], [864.0, 1271.0], [864.0, 1310.0], [837.0, 1310.0]]], "lines": ["じっくり", "見てくれんのは", "うれしいんだけど", "さー"]}, {"box": [223, 1250, 242, 1370], "vertical": true, "font_size": 22, "lines_coords": [[[223.0, 1250.0], [242.0, 1250.0], [242.0, 1370.0], [223.0, 1370.0]]], "lines": ["しょーじき、"]}, {"box": [123, 1382, 203, 1545], "vertical": true, "font_size": 22, "lines_coords": [[[181.0, 1384.0], [203.0, 1384.0], [203.0, 1478.0], [181.0, 1478.0]], [[153.0, 1384.0], [175.0, 1384.0], [175.0, 1523.0], [153.0, 1523.0]], [[125.0, 1382.0], [148.0, 1382.0], [146.0, 1545.0], [123.0, 1545.0]]], "lines": ["そんなに", "涙ぐまれると", "ちょっとひくわ"]}], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [926, 75, 1007, 217], "vertical": true, "font_size": 28, "lines_coords": [[[981.0, 75.0], [1007.0, 75.0], [1007.0, 217.0], [981.0, 217.0]], [[953.0, 76.0], [979.0, 76.0], [979.0, 214.0], [953.0, 214.0]], [[926.0, 76.0], [953.0, 76.0], [953.0, 181.0], [926.0, 181.0]]], "lines": ["あーそうだ。", "コレ、書いて", "いってよ。"]}, {"box": [829, 210, 887, 309], "vertical": true, "font_size": 28, "lines_coords": [[[850.0, 210.0], [887.0, 210.0], [887.0, 270.0], [850.0, 270.0]], [[829.0, 217.0], [851.0, 217.0], [851.0, 309.0], [829.0, 309.0]]], "lines": ["感想", "ノート！！"]}, {"box": [164, 134, 245, 298], "vertical": true, "font_size": 23, "lines_coords": [[[218.0, 134.0], [245.0, 134.0], [242.0, 253.0], [215.0, 253.0]], [[192.0, 137.0], [214.0, 137.0], [214.0, 254.0], [192.0, 254.0]], [[164.0, 135.0], [185.0, 135.0], [185.0, 298.0], [164.0, 298.0]]], "lines": ["もー全然", "誰も書いて", "くれなくてさ！！"]}, {"box": [939, 473, 990, 587], "vertical": true, "font_size": 25, "lines_coords": [[[968.0, 473.0], [990.0, 473.0], [990.0, 587.0], [968.0, 587.0]], [[939.0, 473.0], [970.0, 473.0], [970.0, 518.0], [939.0, 518.0]]], "lines": ["ここだけの", "話ー"]}, {"box": [792, 567, 901, 717], "vertical": true, "font_size": 25, "lines_coords": [[[873.0, 567.0], [901.0, 567.0], [901.0, 662.0], [873.0, 662.0]], [[845.0, 567.0], [871.0, 567.0], [871.0, 684.0], [845.0, 684.0]], [[817.0, 567.0], [839.0, 567.0], [839.0, 682.0], [817.0, 682.0]], [[792.0, 568.0], [812.0, 568.0], [812.0, 717.0], [792.0, 717.0]]], "lines": ["何ページ", "埋まるかて", "蟹江と勝負", "してんだよね。"]}, {"box": [146, 543, 255, 729], "vertical": true, "font_size": 22, "lines_coords": [[[231.0, 543.0], [253.0, 543.0], [253.0, 717.0], [231.0, 717.0]], [[204.0, 543.0], [226.0, 543.0], [226.0, 660.0], [204.0, 660.0]], [[175.0, 543.0], [196.0, 543.0], [196.0, 729.0], [175.0, 729.0]], [[146.0, 543.0], [168.0, 543.0], [168.0, 704.0], [146.0, 704.0]]], "lines": ["．．．もうさ、この際", "落書きても", "なんでもいいから", "書いちゃって！！"]}, {"box": [957, 825, 981, 945], "vertical": true, "font_size": 22, "lines_coords": [[[959.0, 825.0], [981.0, 825.0], [979.0, 945.0], [957.0, 945.0]]], "lines": ["．．．ちなみに"]}, {"box": [843, 926, 893, 1067], "vertical": true, "font_size": 22, "lines_coords": [[[871.0, 928.0], [893.0, 928.0], [893.0, 1067.0], [871.0, 1067.0]], [[843.0, 926.0], [865.0, 926.0], [865.0, 1045.0], [843.0, 1045.0]]], "lines": ["アズサちゃん", "処女だから"]}, {"box": [187, 893, 246, 1021], "vertical": true, "font_size": 27, "lines_coords": [[[218.0, 893.0], [245.0, 893.0], [245.0, 1021.0], [218.0, 1021.0]], [[187.0, 893.0], [214.0, 893.0], [214.0, 1021.0], [187.0, 1021.0]]], "lines": ["優しくして", "やってね♡"]}, {"box": [239, 1273, 306, 1379], "vertical": true, "font_size": 34, "lines_coords": [[[273.0, 1273.0], [306.0, 1273.0], [306.0, 1379.0], [273.0, 1379.0]], [[239.0, 1273.0], [273.0, 1273.0], [273.0, 1357.0], [239.0, 1357.0]]], "lines": ["ガンバレ", "少年！！"]}], "img_path": "130.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [628, 40, 687, 176], "vertical": true, "font_size": 26, "lines_coords": [[[660.0, 40.0], [687.0, 40.0], [687.0, 143.0], [660.0, 143.0]], [[628.0, 42.0], [654.0, 42.0], [654.0, 171.0], [628.0, 171.0]]], "lines": ["とはいえ", "フンフンは"]}, {"box": [418, 39, 597, 248], "vertical": true, "font_size": 29, "lines_coords": [[[551.0, 40.0], [578.0, 40.0], [578.0, 168.0], [551.0, 168.0]], [[518.0, 42.0], [545.0, 42.0], [545.0, 145.0], [518.0, 145.0]], [[485.0, 40.0], [514.0, 40.0], [514.0, 145.0], [485.0, 145.0]], [[453.0, 39.0], [479.0, 39.0], [481.0, 246.0], [454.0, 246.0]], [[418.0, 39.0], [453.0, 39.0], [453.0, 132.0], [418.0, 132.0]]], "lines": ["何を書けば", "いいのか", "はたして", "見当もつきません", "でした。"]}, {"box": [871, 343, 929, 497], "vertical": true, "font_size": 24, "lines_coords": [[[901.0, 343.0], [928.0, 343.0], [928.0, 496.0], [901.0, 496.0]], [[871.0, 343.0], [893.0, 343.0], [893.0, 478.0], [871.0, 478.0]]], "lines": ["ただひたすら", "非生産的に、"]}, {"box": [835, 540, 867, 629], "vertical": true, "font_size": 27, "lines_coords": [[[840.0, 540.0], [867.0, 542.0], [862.0, 629.0], [835.0, 628.0]]], "lines": ["．．．"]}, {"box": [143, 496, 236, 662], "vertical": true, "font_size": 26, "lines_coords": [[[207.0, 498.0], [234.0, 498.0], [234.0, 653.0], [207.0, 653.0]], [[175.0, 496.0], [201.0, 496.0], [201.0, 628.0], [175.0, 628.0]], [[145.0, 498.0], [168.0, 498.0], [167.0, 660.0], [143.0, 660.0]]], "lines": ["昔の思い出に", "とらわれる", "ばかりでした。"]}, {"box": [817, 1054, 907, 1236], "vertical": true, "font_size": 27, "lines_coords": [[[879.0, 1056.0], [907.0, 1056.0], [907.0, 1134.0], [879.0, 1134.0]], [[848.0, 1056.0], [875.0, 1056.0], [875.0, 1235.0], [848.0, 1235.0]], [[817.0, 1057.0], [843.0, 1057.0], [843.0, 1187.0], [817.0, 1187.0]]], "lines": ["宇宙を", "研究する学者に", "なるだとか"]}, {"box": [644, 1052, 765, 1244], "vertical": true, "font_size": 27, "lines_coords": [[[739.0, 1054.0], [765.0, 1054.0], [765.0, 1209.0], [739.0, 1209.0]], [[703.0, 1053.0], [737.0, 1053.0], [737.0, 1137.0], [703.0, 1137.0]], [[675.0, 1054.0], [701.0, 1054.0], [701.0, 1209.0], [675.0, 1209.0]], [[645.0, 1056.0], [667.0, 1056.0], [667.0, 1237.0], [645.0, 1237.0]]], "lines": ["ノーベル賞を", "とって", "フンフン星に", "移住するだとか"]}, {"box": [503, 1050, 595, 1240], "vertical": true, "font_size": 25, "lines_coords": [[[565.0, 1053.0], [592.0, 1053.0], [592.0, 1184.0], [565.0, 1184.0]], [[532.0, 1050.0], [559.0, 1050.0], [560.0, 1239.0], [534.0, 1239.0]], [[504.0, 1054.0], [526.0, 1054.0], [526.0, 1218.0], [504.0, 1218.0]]], "lines": ["子供の頃は", "どうかしてたな、", "と思いました。"]}, {"box": [271, 1053, 394, 1294], "vertical": true, "font_size": 25, "lines_coords": [[[367.0, 1053.0], [393.0, 1053.0], [393.0, 1157.0], [367.0, 1157.0]], [[334.0, 1053.0], [360.0, 1053.0], [359.0, 1234.0], [332.0, 1234.0]], [[303.0, 1054.0], [329.0, 1054.0], [329.0, 1206.0], [303.0, 1206.0]], [[271.0, 1056.0], [293.0, 1056.0], [293.0, 1285.0], [271.0, 1285.0]]], "lines": ["どこまで", "本気だったのか", "今となっては", "よくわかりませんが"]}, {"box": [99, 1331, 221, 1535], "vertical": true, "font_size": 24, "lines_coords": [[[195.0, 1334.0], [217.0, 1334.0], [217.0, 1535.0], [195.0, 1535.0]], [[160.0, 1332.0], [187.0, 1332.0], [187.0, 1535.0], [160.0, 1535.0]], [[129.0, 1331.0], [156.0, 1331.0], [154.0, 1510.0], [128.0, 1510.0]], [[100.0, 1332.0], [121.0, 1332.0], [121.0, 1467.0], [100.0, 1467.0]]], "lines": ["すいらんと自分は", "つまらない人間に", "なったな、とも", "思いました。"]}], "img_path": "131.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [668, 57, 692, 219], "vertical": true, "font_size": 22, "lines_coords": [[[668.0, 57.0], [690.0, 57.0], [690.0, 210.0], [668.0, 210.0]]], "lines": ["．．．でも、もし"]}, {"box": [592, 57, 615, 245], "vertical": true, "font_size": 22, "lines_coords": [[[592.0, 59.0], [614.0, 59.0], [614.0, 239.0], [592.0, 239.0]]], "lines": ["もし仮にですよ"]}, {"box": [481, 57, 545, 244], "vertical": true, "font_size": 24, "lines_coords": [[[512.0, 57.0], [539.0, 57.0], [539.0, 209.0], [512.0, 209.0]], [[482.0, 59.0], [504.0, 59.0], [504.0, 243.0], [482.0, 243.0]]], "lines": ["奇跡レベルの", "可能性でてすよ。"]}, {"box": [879, 432, 973, 615], "vertical": true, "font_size": 29, "lines_coords": [[[939.0, 432.0], [973.0, 432.0], [973.0, 517.0], [939.0, 517.0]], [[910.0, 434.0], [937.0, 434.0], [937.0, 615.0], [910.0, 615.0]], [[879.0, 432.0], [906.0, 432.0], [906.0, 593.0], [879.0, 593.0]]], "lines": ["あの時", "思い描いていた", "プンプン星が、"]}, {"box": [159, 959, 284, 1142], "vertical": true, "font_size": 26, "lines_coords": [[[256.0, 959.0], [282.0, 959.0], [282.0, 1064.0], [256.0, 1064.0]], [[225.0, 959.0], [251.0, 959.0], [251.0, 1142.0], [225.0, 1142.0]], [[192.0, 959.0], [218.0, 959.0], [218.0, 1117.0], [192.0, 1117.0]], [[159.0, 959.0], [187.0, 959.0], [187.0, 1046.0], [159.0, 1046.0]]], "lines": ["実は今も", "宇宙のどこかを", "漂っていると", "したら、"]}, {"box": [793, 1301, 822, 1421], "vertical": true, "font_size": 27, "lines_coords": [[[793.0, 1303.0], [820.0, 1303.0], [820.0, 1414.0], [793.0, 1414.0]]], "lines": ["．．．なんて、"]}, {"box": [651, 1303, 743, 1512], "vertical": true, "font_size": 25, "lines_coords": [[[715.0, 1303.0], [742.0, 1303.0], [743.0, 1510.0], [717.0, 1510.0]], [[685.0, 1304.0], [707.0, 1304.0], [707.0, 1457.0], [685.0, 1457.0]], [[651.0, 1304.0], [678.0, 1304.0], [679.0, 1510.0], [653.0, 1510.0]]], "lines": ["高校生にもなって", "こんなことを", "考えている自分は"]}, {"box": [514, 1301, 603, 1485], "vertical": true, "font_size": 25, "lines_coords": [[[576.0, 1303.0], [603.0, 1303.0], [603.0, 1409.0], [576.0, 1409.0]], [[543.0, 1301.0], [570.0, 1301.0], [570.0, 1482.0], [543.0, 1482.0]], [[514.0, 1304.0], [535.0, 1304.0], [535.0, 1439.0], [514.0, 1439.0]]], "lines": ["いよいよ", "どうかしてると", "思いました。"]}, {"box": [371, 1302, 462, 1443], "vertical": true, "font_size": 26, "lines_coords": [[[434.0, 1303.0], [462.0, 1303.0], [462.0, 1407.0], [434.0, 1407.0]], [[404.0, 1304.0], [426.0, 1304.0], [426.0, 1429.0], [404.0, 1429.0]], [[371.0, 1303.0], [398.0, 1303.0], [398.0, 1439.0], [371.0, 1439.0]]], "lines": ["ほとんど", "うんちだと", "思いました。"]}], "img_path": "132.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [873, 98, 964, 278], "vertical": true, "font_size": 27, "lines_coords": [[[937.0, 100.0], [964.0, 100.0], [964.0, 254.0], [937.0, 254.0]], [[906.0, 98.0], [932.0, 98.0], [932.0, 278.0], [906.0, 278.0]], [[873.0, 98.0], [900.0, 98.0], [900.0, 209.0], [873.0, 209.0]]], "lines": ["いっそのこと", "本当におかしく", "なれたら、"]}, {"box": [92, 217, 249, 410], "vertical": true, "font_size": 27, "lines_coords": [[[221.0, 221.0], [248.0, 221.0], [248.0, 325.0], [221.0, 325.0]], [[189.0, 221.0], [215.0, 221.0], [215.0, 410.0], [189.0, 410.0]], [[157.0, 220.0], [184.0, 220.0], [184.0, 350.0], [157.0, 350.0]], [[126.0, 220.0], [153.0, 220.0], [153.0, 376.0], [126.0, 376.0]], [[92.0, 217.0], [118.0, 217.0], [118.0, 407.0], [92.0, 407.0]]], "lines": ["いくらか", "楽かもしれない。", "そんな風に", "思ってしまう", "ブンフンでした。"]}, {"box": [839, 512, 950, 693], "vertical": true, "font_size": 24, "lines_coords": [[[920.0, 514.0], [950.0, 514.0], [950.0, 589.0], [920.0, 589.0]], [[893.0, 515.0], [920.0, 515.0], [920.0, 679.0], [893.0, 679.0]], [[868.0, 517.0], [889.0, 517.0], [889.0, 693.0], [868.0, 693.0]], [[839.0, 512.0], [859.0, 512.0], [859.0, 687.0], [839.0, 687.0]]], "lines": ["意外と", "アタシのほうが", "アンタよりモテる", "と思うんだよね。"]}, {"box": [510, 881, 553, 964], "vertical": true, "font_size": 43, "lines_coords": [[[510.0, 881.0], [553.0, 881.0], [553.0, 964.0], [510.0, 964.0]]], "lines": ["受付"]}, {"box": [170, 907, 198, 989], "vertical": true, "font_size": 28, "lines_coords": [[[170.0, 907.0], [198.0, 907.0], [198.0, 989.0], [170.0, 989.0]]], "lines": ["死ね！！"]}, {"box": [865, 1176, 926, 1383], "vertical": true, "font_size": 24, "lines_coords": [[[903.0, 1178.0], [925.0, 1178.0], [925.0, 1379.0], [903.0, 1379.0]], [[865.0, 1176.0], [892.0, 1176.0], [893.0, 1359.0], [867.0, 1359.0]]], "lines": ["．．．じゃあたとえは", "うんちついてに"]}, {"box": [728, 1175, 825, 1405], "vertical": true, "font_size": 27, "lines_coords": [[[790.0, 1178.0], [817.0, 1178.0], [817.0, 1403.0], [790.0, 1403.0]], [[757.0, 1175.0], [785.0, 1175.0], [787.0, 1332.0], [759.0, 1332.0]], [[728.0, 1175.0], [754.0, 1175.0], [754.0, 1382.0], [728.0, 1382.0]]], "lines": ["「天の川」という題で", "こんなお話は", "どうでしょうか？"]}, {"box": [442, 1221, 567, 1243], "vertical": false, "font_size": 22, "lines_coords": [[[442.0, 1221.0], [567.0, 1221.0], [567.0, 1243.0], [442.0, 1243.0]]], "lines": ["まずは前はせんでした"]}, {"box": [248, 1173, 375, 1381], "vertical": true, "font_size": 28, "lines_coords": [[[348.0, 1173.0], [375.0, 1173.0], [370.0, 1354.0], [343.0, 1354.0]], [[314.0, 1176.0], [340.0, 1176.0], [340.0, 1381.0], [314.0, 1381.0]], [[282.0, 1175.0], [309.0, 1175.0], [309.0, 1329.0], [282.0, 1329.0]], [[248.0, 1176.0], [281.0, 1176.0], [281.0, 1259.0], [248.0, 1259.0]]], "lines": ["どこか遠い遠い", "銀河の果てに住む", "普通の少年の", "「僕」は、"]}, {"box": [96, 1171, 220, 1391], "vertical": true, "font_size": 27, "lines_coords": [[[192.0, 1175.0], [220.0, 1175.0], [220.0, 1256.0], [192.0, 1256.0]], [[157.0, 1171.0], [190.0, 1171.0], [187.0, 1356.0], [154.0, 1356.0]], [[128.0, 1175.0], [154.0, 1175.0], [154.0, 1306.0], [128.0, 1306.0]], [[96.0, 1175.0], [118.0, 1175.0], [118.0, 1384.0], [96.0, 1384.0]]], "lines": ["その日、", "学校に行くのが", "憂鬱で仕方", "ありませんでした"]}], "img_path": "133.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [626, 118, 750, 376], "vertical": true, "font_size": 27, "lines_coords": [[[721.0, 121.0], [750.0, 121.0], [750.0, 225.0], [721.0, 225.0]], [[690.0, 120.0], [717.0, 120.0], [717.0, 350.0], [690.0, 350.0]], [[657.0, 118.0], [684.0, 118.0], [685.0, 376.0], [659.0, 376.0]], [[626.0, 121.0], [653.0, 121.0], [653.0, 335.0], [626.0, 335.0]]], "lines": ["なぜなら", "クラスのアイドルの", "ミヨちゃんが転校して", "しまったからです。"]}, {"box": [365, 115, 579, 254], "vertical": false, "font_size": 27.75, "lines_coords": [[[378.0, 115.0], [571.0, 120.0], [571.0, 146.0], [378.0, 142.0]], [[384.0, 148.0], [579.0, 156.0], [579.0, 182.0], [384.0, 175.0]], [[365.0, 181.0], [562.0, 189.0], [562.0, 215.0], [365.0, 207.0]], [[378.0, 212.0], [528.0, 221.0], [526.0, 254.0], [376.0, 245.0]]], "lines": ["それを言っておりも未経を", "の中身を満たし続けようと", "の内教室のドアーバラー人。", "すち止ったのです。"]}, {"box": [225, 121, 312, 432], "vertical": true, "font_size": 23, "lines_coords": [[[287.0, 121.0], [310.0, 121.0], [312.0, 325.0], [289.0, 325.0]], [[257.0, 123.0], [279.0, 123.0], [279.0, 325.0], [257.0, 325.0]], [[225.0, 121.0], [246.0, 121.0], [246.0, 432.0], [225.0, 432.0]]], "lines": ["けれどその数日後", "遠い星から一人の", "女の子が転校してきました"]}, {"box": [134, 126, 192, 307], "vertical": true, "font_size": 23, "lines_coords": [[[168.0, 126.0], [192.0, 126.0], [190.0, 300.0], [167.0, 300.0]], [[134.0, 128.0], [160.0, 128.0], [162.0, 307.0], [135.0, 307.0]]], "lines": ["「僕」はその子に", "一目惚れでした。"]}, {"box": [911, 735, 938, 1003], "vertical": true, "font_size": 22, "lines_coords": [[[912.0, 735.0], [934.0, 735.0], [935.0, 995.0], [914.0, 995.0]]], "lines": ["理由なんてありません"]}, {"box": [770, 734, 860, 1027], "vertical": true, "font_size": 26, "lines_coords": [[[834.0, 737.0], [860.0, 737.0], [860.0, 840.0], [834.0, 840.0]], [[803.0, 735.0], [829.0, 735.0], [829.0, 940.0], [803.0, 940.0]], [[770.0, 734.0], [796.0, 734.0], [798.0, 1026.0], [771.0, 1026.0]]], "lines": ["ただただ", "運命の人なのだと", "確信してしまったのです。"]}, {"box": [600, 734, 721, 993], "vertical": true, "font_size": 25, "lines_coords": [[[692.0, 734.0], [718.0, 734.0], [721.0, 890.0], [695.0, 890.0]], [[664.0, 737.0], [690.0, 737.0], [690.0, 915.0], [664.0, 915.0]], [[629.0, 734.0], [656.0, 734.0], [657.0, 990.0], [631.0, 990.0]], [[601.0, 739.0], [623.0, 739.0], [623.0, 898.0], [601.0, 898.0]]], "lines": ["何があっても", "「僕」はその子を", "守ってあげなくちゃと", "思ったのです。"]}, {"box": [457, 734, 550, 1004], "vertical": true, "font_size": 27, "lines_coords": [[[521.0, 734.0], [548.0, 734.0], [550.0, 939.0], [523.0, 939.0]], [[489.0, 735.0], [515.0, 735.0], [517.0, 990.0], [490.0, 990.0]], [[457.0, 735.0], [484.0, 735.0], [485.0, 998.0], [459.0, 998.0]]], "lines": ["それなのに「僕」は", "いつの間にかその子を", "見失ってしまいました。"]}, {"box": [285, 735, 409, 966], "vertical": true, "font_size": 25, "lines_coords": [[[382.0, 739.0], [409.0, 739.0], [409.0, 964.0], [382.0, 964.0]], [[350.0, 737.0], [376.0, 737.0], [376.0, 965.0], [350.0, 965.0]], [[317.0, 735.0], [343.0, 735.0], [345.0, 965.0], [318.0, 965.0]], [[287.0, 739.0], [309.0, 739.0], [309.0, 898.0], [287.0, 898.0]]], "lines": ["大人になった「僕」は", "失ったものを探して", "あてもなく天の川を", "漂っています。"]}, {"box": [212, 739, 238, 979], "vertical": true, "font_size": 20, "lines_coords": [[[214.0, 740.0], [234.0, 740.0], [234.0, 968.0], [214.0, 968.0]]], "lines": ["．．．たとえばこんな話"]}, {"box": [910, 1281, 966, 1469], "vertical": true, "font_size": 24, "lines_coords": [[[939.0, 1281.0], [965.0, 1281.0], [965.0, 1384.0], [939.0, 1384.0]], [[910.0, 1284.0], [932.0, 1284.0], [932.0, 1464.0], [910.0, 1464.0]]], "lines": ["こんなに", "つまらない話が、"]}, {"box": [139, 1342, 262, 1536], "vertical": true, "font_size": 26, "lines_coords": [[[232.0, 1345.0], [259.0, 1345.0], [262.0, 1473.0], [235.0, 1473.0]], [[203.0, 1345.0], [229.0, 1345.0], [229.0, 1475.0], [203.0, 1475.0]], [[167.0, 1342.0], [195.0, 1342.0], [196.0, 1475.0], [168.0, 1475.0]], [[139.0, 1342.0], [162.0, 1342.0], [164.0, 1534.0], [140.0, 1534.0]]], "lines": ["いくらでも", "溢れてきて", "ブンブンは", "泣きそうでした。"]}], "img_path": "134.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [942, 693, 971, 756], "vertical": true, "font_size": 27, "lines_coords": [[[942.0, 693.0], [971.0, 693.0], [971.0, 756.0], [942.0, 756.0]]], "lines": ["へえー"]}, {"box": [912, 737, 935, 792], "vertical": true, "font_size": 27, "lines_coords": [[[912.0, 737.0], [935.0, 737.0], [935.0, 792.0], [912.0, 792.0]]], "lines": ["．．．"]}, {"box": [840, 812, 900, 982], "vertical": true, "font_size": 27, "lines_coords": [[[871.0, 812.0], [900.0, 812.0], [900.0, 917.0], [871.0, 917.0]], [[840.0, 812.0], [868.0, 812.0], [870.0, 982.0], [842.0, 982.0]]], "lines": ["いっぱい", "書いてるねぇ。"]}, {"box": [576, 1085, 667, 1244], "vertical": true, "font_size": 27, "lines_coords": [[[635.0, 1085.0], [667.0, 1085.0], [667.0, 1134.0], [635.0, 1134.0]], [[607.0, 1089.0], [634.0, 1089.0], [634.0, 1218.0], [607.0, 1218.0]], [[578.0, 1089.0], [600.0, 1089.0], [600.0, 1210.0], [578.0, 1210.0]]], "lines": ["えー", "いいじゃん", "見せてよー"]}, {"box": [107, 839, 198, 1020], "vertical": true, "font_size": 25, "lines_coords": [[[170.0, 839.0], [196.0, 839.0], [196.0, 1020.0], [170.0, 1020.0]], [[140.0, 842.0], [162.0, 842.0], [162.0, 1018.0], [140.0, 1018.0]], [[107.0, 839.0], [134.0, 839.0], [134.0, 945.0], [107.0, 945.0]]], "lines": ["それ、幸さんの", "スケッチフック", "でしょ？"]}, {"box": [110, 1419, 137, 1524], "vertical": true, "font_size": 24, "lines_coords": [[[110.0, 1420.0], [134.0, 1420.0], [134.0, 1467.0], [110.0, 1467.0]]], "lines": ["んー"]}], "img_path": "135.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [946, 56, 973, 160], "vertical": true, "font_size": 25, "lines_coords": [[[946.0, 56.0], [973.0, 56.0], [973.0, 160.0], [946.0, 160.0]]], "lines": ["なんか．．．"]}, {"box": [837, 125, 895, 300], "vertical": true, "font_size": 25, "lines_coords": [[[868.0, 125.0], [895.0, 125.0], [895.0, 228.0], [868.0, 228.0]], [[837.0, 125.0], [859.0, 125.0], [859.0, 300.0], [837.0, 300.0]]], "lines": ["退屈させ", "ちゃったかな．．．"]}, {"box": [167, 164, 227, 293], "vertical": true, "font_size": 22, "lines_coords": [[[203.0, 165.0], [225.0, 165.0], [225.0, 268.0], [203.0, 268.0]], [[170.0, 164.0], [193.0, 164.0], [190.0, 293.0], [167.0, 293.0]]], "lines": ["そろそろ", "出ようか？"]}, {"box": [960, 1220, 989, 1312], "vertical": true, "font_size": 29, "lines_coords": [[[960.0, 1242.0], [989.0, 1242.0], [989.0, 1310.0], [960.0, 1310.0]]], "lines": ["．．．雨"]}, {"box": [432, 1373, 522, 1530], "vertical": true, "font_size": 26, "lines_coords": [[[495.0, 1373.0], [521.0, 1373.0], [521.0, 1478.0], [495.0, 1478.0]], [[464.0, 1375.0], [490.0, 1375.0], [490.0, 1529.0], [464.0, 1529.0]], [[432.0, 1375.0], [459.0, 1375.0], [459.0, 1478.0], [432.0, 1478.0]]], "lines": ["どんどん", "強くなってく", "ねー．．．"]}, {"box": [345, 1250, 373, 1381], "vertical": true, "font_size": 26, "lines_coords": [[[345.0, 1251.0], [371.0, 1251.0], [371.0, 1379.0], [345.0, 1379.0]]], "lines": ["．．．なんとも"]}, {"box": [231, 1248, 295, 1379], "vertical": true, "font_size": 32, "lines_coords": [[[267.0, 1253.0], [293.0, 1253.0], [293.0, 1379.0], [267.0, 1379.0]], [[231.0, 1248.0], [270.0, 1248.0], [270.0, 1337.0], [231.0, 1337.0]]], "lines": ["自分の感傷", "なんて、"]}, {"box": [162, 1250, 188, 1466], "vertical": true, "font_size": 21, "lines_coords": [[[164.0, 1253.0], [185.0, 1253.0], [185.0, 1460.0], [164.0, 1460.0]]], "lines": ["ちょろいもんです。"]}], "img_path": "136.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [890, 1098, 981, 1226], "vertical": true, "font_size": 28, "lines_coords": [[[948.0, 1098.0], [981.0, 1098.0], [981.0, 1182.0], [948.0, 1182.0]], [[918.0, 1098.0], [946.0, 1098.0], [946.0, 1226.0], [918.0, 1226.0]], [[890.0, 1101.0], [912.0, 1101.0], [912.0, 1203.0], [890.0, 1203.0]]], "lines": ["今度は", "天気のいい", "日に．．．"]}, {"box": [600, 837, 627, 997], "vertical": true, "font_size": 26, "lines_coords": [[[600.0, 837.0], [626.0, 837.0], [626.0, 995.0], [600.0, 995.0]]], "lines": ["やまない雨が、"]}, {"box": [394, 832, 588, 981], "vertical": true, "font_size": 31, "lines_coords": [[[517.0, 835.0], [556.0, 835.0], [556.0, 921.0], [517.0, 921.0]], [[490.0, 837.0], [517.0, 837.0], [517.0, 965.0], [490.0, 965.0]], [[451.0, 832.0], [490.0, 832.0], [490.0, 920.0], [451.0, 920.0]], [[426.0, 837.0], [453.0, 837.0], [453.0, 967.0], [426.0, 967.0]], [[396.0, 839.0], [418.0, 839.0], [418.0, 973.0], [396.0, 973.0]]], "lines": ["一気に", "フンフンを", "現実へ", "引き戻して", "くれました。"]}, {"box": [404, 1181, 492, 1311], "vertical": true, "font_size": 25, "lines_coords": [[[464.0, 1181.0], [490.0, 1181.0], [490.0, 1310.0], [464.0, 1310.0]], [[434.0, 1184.0], [460.0, 1184.0], [460.0, 1287.0], [434.0, 1287.0]], [[404.0, 1187.0], [426.0, 1187.0], [426.0, 1260.0], [404.0, 1260.0]]], "lines": ["またどっか", "行こうか", "．．．．．．？"]}, {"box": [304, 1147, 333, 1276], "vertical": true, "font_size": 24, "lines_coords": [[[307.0, 1148.0], [331.0, 1148.0], [328.0, 1273.0], [304.0, 1273.0]]], "lines": ["蟹江さんは"]}, {"box": [199, 1147, 254, 1365], "vertical": true, "font_size": 22, "lines_coords": [[[232.0, 1150.0], [254.0, 1150.0], [254.0, 1250.0], [232.0, 1250.0]], [[200.0, 1151.0], [221.0, 1151.0], [221.0, 1362.0], [200.0, 1362.0]]], "lines": ["真面目で", "本当に良い子です。"]}, {"box": [123, 1148, 145, 1309], "vertical": true, "font_size": 20, "lines_coords": [[[123.0, 1148.0], [143.0, 1148.0], [143.0, 1307.0], [123.0, 1307.0]]], "lines": ["どてもとても、"]}], "img_path": "137.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [842, 121, 970, 279], "vertical": true, "font_size": 28, "lines_coords": [[[931.0, 123.0], [967.0, 121.0], [970.0, 206.0], [934.0, 207.0]], [[909.0, 126.0], [931.0, 126.0], [931.0, 279.0], [909.0, 279.0]], [[875.0, 125.0], [901.0, 125.0], [901.0, 279.0], [875.0, 279.0]], [[842.0, 126.0], [871.0, 126.0], [871.0, 185.0], [842.0, 185.0]]], "lines": ["そして", "この娘さんは", "処女なのだと", "いう"]}, {"box": [196, 639, 287, 768], "vertical": true, "font_size": 27, "lines_coords": [[[260.0, 639.0], [287.0, 639.0], [287.0, 767.0], [260.0, 767.0]], [[228.0, 639.0], [256.0, 639.0], [256.0, 768.0], [228.0, 768.0]], [[196.0, 639.0], [223.0, 639.0], [223.0, 750.0], [196.0, 750.0]]], "lines": ["その事実で", "プンプンは", "図らずも、"]}, {"box": [868, 1010, 931, 1177], "vertical": true, "font_size": 29, "lines_coords": [[[900.0, 1010.0], [931.0, 1010.0], [931.0, 1067.0], [900.0, 1067.0]], [[871.0, 1012.0], [898.0, 1012.0], [895.0, 1171.0], [868.0, 1171.0]]], "lines": ["再び", "超勃起でした。"]}, {"box": [314, 1008, 375, 1203], "vertical": true, "font_size": 30, "lines_coords": [[[342.0, 1010.0], [375.0, 1010.0], [375.0, 1118.0], [342.0, 1118.0]], [[314.0, 1012.0], [340.0, 1012.0], [340.0, 1198.0], [314.0, 1198.0]]], "lines": ["不思議な", "間が流れました。"]}, {"box": [142, 1010, 266, 1171], "vertical": true, "font_size": 26, "lines_coords": [[[237.0, 1010.0], [264.0, 1010.0], [264.0, 1139.0], [237.0, 1139.0]], [[204.0, 1012.0], [231.0, 1012.0], [231.0, 1167.0], [204.0, 1167.0]], [[173.0, 1012.0], [200.0, 1012.0], [200.0, 1165.0], [173.0, 1165.0]], [[142.0, 1012.0], [164.0, 1012.0], [164.0, 1118.0], [142.0, 1118.0]]], "lines": ["フンフンは", "何かが起こる", "そんな予感が", "しました"]}], "img_path": "138.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [929, 96, 956, 203], "vertical": true, "font_size": 27, "lines_coords": [[[929.0, 98.0], [956.0, 98.0], [956.0, 203.0], [929.0, 203.0]]], "lines": ["．．．うん！！"]}, {"box": [465, 596, 556, 778], "vertical": true, "font_size": 24, "lines_coords": [[[531.0, 598.0], [553.0, 598.0], [553.0, 751.0], [531.0, 751.0]], [[496.0, 596.0], [523.0, 596.0], [523.0, 778.0], [496.0, 778.0]], [[465.0, 600.0], [487.0, 600.0], [487.0, 701.0], [465.0, 701.0]]], "lines": ["じゃああたし", "今日はそろそろ", "帰るね！！"]}, {"box": [103, 621, 225, 751], "vertical": true, "font_size": 27, "lines_coords": [[[198.0, 623.0], [225.0, 623.0], [225.0, 725.0], [198.0, 725.0]], [[165.0, 623.0], [192.0, 623.0], [192.0, 751.0], [165.0, 751.0]], [[132.0, 623.0], [159.0, 623.0], [159.0, 751.0], [132.0, 751.0]], [[103.0, 621.0], [131.0, 621.0], [131.0, 710.0], [103.0, 710.0]]], "lines": ["あんまり", "遅くなると", "ママが心配", "するし。"]}], "img_path": "139.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "140.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "141.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [784, 79, 955, 564], "vertical": true, "font_size": 171, "lines_coords": [[[784.0, 79.0], [955.0, 79.0], [955.0, 564.0], [784.0, 564.0]]], "lines": ["あっ！！なる！！まっまっ！？"]}, {"box": [640, 53, 728, 234], "vertical": true, "font_size": 25, "lines_coords": [[[700.0, 54.0], [726.0, 54.0], [726.0, 234.0], [700.0, 234.0]], [[667.0, 53.0], [693.0, 53.0], [696.0, 207.0], [670.0, 207.0]], [[640.0, 54.0], [662.0, 54.0], [662.0, 206.0], [640.0, 206.0]]], "lines": ["お互いこれから", "勉強で忙しく", "なるけど．．．"]}, {"box": [164, 107, 321, 423], "vertical": true, "font_size": 150, "lines_coords": [[[164.0, 110.0], [314.0, 107.0], [321.0, 420.0], [171.0, 423.0]]], "lines": ["あの！！"]}, {"box": [35, 298, 79, 456], "vertical": true, "font_size": 44, "lines_coords": [[[35.0, 298.0], [79.0, 298.0], [79.0, 456.0], [35.0, 456.0]]], "lines": ["第６４話"]}, {"box": [876, 671, 965, 856], "vertical": true, "font_size": 27, "lines_coords": [[[939.0, 671.0], [965.0, 671.0], [964.0, 854.0], [937.0, 854.0]], [[907.0, 673.0], [934.0, 673.0], [934.0, 829.0], [907.0, 829.0]], [[876.0, 673.0], [903.0, 673.0], [903.0, 856.0], [876.0, 856.0]]], "lines": ["．．．またそのうち", "タイミングが", "合うとき遊ぼ？"]}, {"box": [368, 418, 495, 604], "vertical": true, "font_size": 31, "lines_coords": [[[468.0, 420.0], [495.0, 420.0], [492.0, 578.0], [465.0, 578.0]], [[432.0, 420.0], [464.0, 420.0], [464.0, 604.0], [432.0, 604.0]], [[400.0, 420.0], [431.0, 420.0], [431.0, 603.0], [400.0, 603.0]], [[368.0, 418.0], [403.0, 418.0], [403.0, 504.0], [368.0, 504.0]]], "lines": ["期末が終わる", "頃には、梅雨も", "終わってるハズ", "だし．．"]}, {"box": [167, 950, 229, 1119], "vertical": true, "font_size": 30, "lines_coords": [[[196.0, 950.0], [229.0, 950.0], [229.0, 1034.0], [196.0, 1034.0]], [[167.0, 953.0], [193.0, 953.0], [193.0, 1118.0], [167.0, 1118.0]]], "lines": ["今日は", "楽しかったよ。"]}, {"box": [599, 1227, 743, 1596], "vertical": true, "font_size": 111, "lines_coords": [[[632.0, 1276.0], [743.0, 1292.0], [709.0, 1546.0], [600.0, 1531.0]]], "lines": ["ファンは、"]}], "img_path": "142.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [429, 1357, 521, 1592], "vertical": true, "font_size": 25, "lines_coords": [[[496.0, 1359.0], [518.0, 1359.0], [518.0, 1498.0], [496.0, 1498.0]], [[460.0, 1357.0], [487.0, 1357.0], [487.0, 1589.0], [460.0, 1589.0]], [[429.0, 1359.0], [456.0, 1359.0], [456.0, 1526.0], [429.0, 1526.0]]], "lines": ["「．．．もう少し", "ゆっくりしてっても", "いいと思う。」"]}, {"box": [185, 1356, 314, 1564], "vertical": true, "font_size": 25, "lines_coords": [[[287.0, 1359.0], [309.0, 1359.0], [309.0, 1484.0], [287.0, 1484.0]], [[253.0, 1357.0], [279.0, 1357.0], [279.0, 1487.0], [253.0, 1487.0]], [[220.0, 1357.0], [246.0, 1357.0], [246.0, 1564.0], [220.0, 1564.0]], [[189.0, 1356.0], [215.0, 1356.0], [212.0, 1496.0], [185.0, 1496.0]]], "lines": ["フンフンは", "できる限り", "落ちついた口調で", "言いました。"]}], "img_path": "143.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [314, 110, 342, 214], "vertical": true, "font_size": 28, "lines_coords": [[[314.0, 110.0], [342.0, 110.0], [342.0, 214.0], [314.0, 214.0]]], "lines": ["うん．．．"]}, {"box": [140, 502, 164, 644], "vertical": true, "font_size": 22, "lines_coords": [[[140.0, 504.0], [162.0, 504.0], [162.0, 642.0], [140.0, 642.0]]], "lines": ["．．．いいけど。"]}], "img_path": "144.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [553, 51, 582, 237], "vertical": true, "font_size": 22, "lines_coords": [[[553.0, 54.0], [575.0, 54.0], [578.0, 229.0], [556.0, 229.0]]], "lines": ["「ワレメちゃん」"]}, {"box": [885, 384, 950, 525], "vertical": true, "font_size": 30, "lines_coords": [[[917.0, 385.0], [950.0, 385.0], [950.0, 471.0], [917.0, 471.0]], [[885.0, 384.0], [912.0, 384.0], [915.0, 523.0], [889.0, 523.0]]], "lines": ["という", "フレーズが、"]}, {"box": [131, 801, 258, 982], "vertical": true, "font_size": 27, "lines_coords": [[[229.0, 803.0], [256.0, 803.0], [256.0, 907.0], [229.0, 907.0]], [[196.0, 803.0], [223.0, 803.0], [223.0, 982.0], [196.0, 982.0]], [[164.0, 801.0], [192.0, 801.0], [193.0, 931.0], [165.0, 931.0]], [[131.0, 803.0], [157.0, 803.0], [160.0, 918.0], [134.0, 918.0]]], "lines": ["先程から", "脈絡なく脳裏を", "駆け巡って", "いました。"]}, {"box": [473, 1184, 694, 1398], "vertical": true, "font_size": 28, "lines_coords": [[[667.0, 1187.0], [693.0, 1187.0], [693.0, 1392.0], [667.0, 1392.0]], [[632.0, 1185.0], [664.0, 1185.0], [664.0, 1345.0], [632.0, 1345.0]], [[595.0, 1184.0], [626.0, 1184.0], [631.0, 1396.0], [600.0, 1396.0]], [[570.0, 1187.0], [592.0, 1187.0], [592.0, 1390.0], [570.0, 1390.0]], [[539.0, 1184.0], [565.0, 1184.0], [564.0, 1368.0], [537.0, 1368.0]], [[503.0, 1185.0], [531.0, 1185.0], [532.0, 1392.0], [504.0, 1392.0]], [[473.0, 1187.0], [500.0, 1187.0], [500.0, 1300.0], [473.0, 1300.0]]], "lines": ["長い沈黙のせいで", "敏感になった", "フンフンの五感は", "蟹江さんの体温と", "匂いと息遣いを", "ありありと感じて", "いました。"]}], "img_path": "145.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [884, 639, 978, 833], "vertical": true, "font_size": 27, "lines_coords": [[[942.0, 639.0], [978.0, 639.0], [978.0, 701.0], [942.0, 701.0]], [[915.0, 642.0], [939.0, 642.0], [940.0, 798.0], [917.0, 798.0]], [[884.0, 643.0], [906.0, 643.0], [906.0, 831.0], [884.0, 831.0]]], "lines": ["何か", "言わなきゃと", "思えば思うほど、"]}, {"box": [946, 985, 1004, 1117], "vertical": true, "font_size": 26, "lines_coords": [[[976.0, 985.0], [1004.0, 985.0], [1004.0, 1092.0], [976.0, 1092.0]], [[946.0, 987.0], [968.0, 987.0], [968.0, 1117.0], [946.0, 1117.0]]], "lines": ["やっぱり", "そろそろ．．．"]}, {"box": [856, 1112, 915, 1220], "vertical": true, "font_size": 26, "lines_coords": [[[887.0, 1112.0], [915.0, 1112.0], [915.0, 1193.0], [887.0, 1193.0]], [[856.0, 1112.0], [882.0, 1112.0], [882.0, 1220.0], [856.0, 1220.0]]], "lines": ["冷えて", "きたし．．．"]}, {"box": [454, 1057, 545, 1214], "vertical": true, "font_size": 25, "lines_coords": [[[518.0, 1059.0], [545.0, 1059.0], [545.0, 1214.0], [518.0, 1214.0]], [[485.0, 1059.0], [512.0, 1059.0], [512.0, 1212.0], [485.0, 1212.0]], [[457.0, 1057.0], [479.0, 1057.0], [476.0, 1212.0], [454.0, 1212.0]]], "lines": ["小野寺くんも", "お母さんとか", "心配するよ？"]}, {"box": [129, 718, 253, 925], "vertical": true, "font_size": 27, "lines_coords": [[[226.0, 718.0], [253.0, 718.0], [253.0, 875.0], [226.0, 875.0]], [[193.0, 718.0], [220.0, 718.0], [220.0, 875.0], [193.0, 875.0]], [[162.0, 718.0], [189.0, 718.0], [189.0, 925.0], [162.0, 925.0]], [[129.0, 718.0], [156.0, 718.0], [156.0, 857.0], [129.0, 857.0]]], "lines": ["ワレメちゃん", "という言葉が", "頭の中を満たして", "いきました。"]}, {"box": [347, 1018, 372, 1127], "vertical": true, "font_size": 22, "lines_coords": [[[348.0, 1059.0], [370.0, 1059.0], [370.0, 1125.0], [348.0, 1125.0]]], "lines": ["．．．え？"]}, {"box": [781, 1285, 906, 1430], "vertical": true, "font_size": 26, "lines_coords": [[[878.0, 1290.0], [906.0, 1290.0], [906.0, 1379.0], [878.0, 1379.0]], [[850.0, 1290.0], [871.0, 1290.0], [871.0, 1415.0], [850.0, 1415.0]], [[815.0, 1289.0], [842.0, 1289.0], [842.0, 1417.0], [815.0, 1417.0]], [[782.0, 1285.0], [809.0, 1285.0], [809.0, 1428.0], [782.0, 1428.0]]], "lines": ["「母親は", "今日手術で", "病院なので", "平気ッス。」"]}, {"box": [553, 1285, 710, 1479], "vertical": true, "font_size": 26, "lines_coords": [[[682.0, 1285.0], [709.0, 1285.0], [709.0, 1415.0], [682.0, 1415.0]], [[650.0, 1287.0], [676.0, 1287.0], [676.0, 1442.0], [650.0, 1442.0]], [[617.0, 1287.0], [643.0, 1287.0], [643.0, 1470.0], [617.0, 1470.0]], [[585.0, 1287.0], [612.0, 1287.0], [612.0, 1443.0], [585.0, 1443.0]], [[553.0, 1285.0], [579.0, 1285.0], [581.0, 1476.0], [554.0, 1476.0]]], "lines": ["フンフンの", "聡明な頭脳は", "次の気の利いた", "一言を探して", "高速回転でした。"]}, {"box": [126, 1373, 154, 1529], "vertical": true, "font_size": 27, "lines_coords": [[[126.0, 1373.0], [153.0, 1373.0], [153.0, 1529.0], [126.0, 1529.0]]], "lines": ["ちょっと？"]}], "img_path": "146.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [932, 93, 964, 279], "vertical": true, "font_size": 32, "lines_coords": [[[932.0, 93.0], [964.0, 93.0], [964.0, 279.0], [932.0, 279.0]]], "lines": ["小野寺くん？"]}, {"box": [143, 284, 251, 471], "vertical": true, "font_size": 30, "lines_coords": [[[220.0, 287.0], [250.0, 287.0], [250.0, 442.0], [220.0, 442.0]], [[179.0, 285.0], [212.0, 285.0], [212.0, 414.0], [179.0, 414.0]], [[143.0, 285.0], [170.0, 285.0], [170.0, 470.0], [143.0, 470.0]]], "lines": ["なんでそれ", "前もって", "言わないの？"]}, {"box": [884, 781, 978, 939], "vertical": true, "font_size": 29, "lines_coords": [[[943.0, 781.0], [978.0, 781.0], [978.0, 865.0], [943.0, 865.0]], [[915.0, 784.0], [942.0, 784.0], [942.0, 912.0], [915.0, 912.0]], [[884.0, 782.0], [910.0, 782.0], [910.0, 937.0], [884.0, 937.0]]], "lines": ["．．．今日", "お母さんが", "手術って．．．"]}, {"box": [485, 1081, 641, 1264], "vertical": true, "font_size": 27, "lines_coords": [[[610.0, 1082.0], [637.0, 1082.0], [640.0, 1250.0], [614.0, 1250.0]], [[579.0, 1082.0], [607.0, 1082.0], [607.0, 1189.0], [579.0, 1189.0]], [[550.0, 1082.0], [576.0, 1082.0], [576.0, 1264.0], [550.0, 1264.0]], [[518.0, 1082.0], [545.0, 1082.0], [545.0, 1214.0], [518.0, 1214.0]], [[485.0, 1082.0], [512.0, 1082.0], [512.0, 1251.0], [485.0, 1251.0]]], "lines": ["「僕がいようが", "いまいか", "手術の結果には", "関係ないと", "思いますが。」"]}, {"box": [129, 837, 256, 996], "vertical": true, "font_size": 28, "lines_coords": [[[218.0, 837.0], [256.0, 837.0], [256.0, 900.0], [218.0, 900.0]], [[190.0, 840.0], [217.0, 840.0], [217.0, 945.0], [190.0, 945.0]], [[160.0, 840.0], [187.0, 840.0], [187.0, 996.0], [160.0, 996.0]], [[129.0, 840.0], [151.0, 840.0], [151.0, 943.0], [129.0, 943.0]]], "lines": ["それ", "遊んてる", "場合じゃない", "じゃん！！"]}, {"box": [204, 1079, 401, 1289], "vertical": true, "font_size": 29, "lines_coords": [[[368.0, 1082.0], [396.0, 1082.0], [396.0, 1212.0], [368.0, 1212.0]], [[337.0, 1079.0], [365.0, 1079.0], [362.0, 1212.0], [334.0, 1212.0]], [[306.0, 1081.0], [334.0, 1081.0], [329.0, 1289.0], [301.0, 1289.0]], [[273.0, 1082.0], [300.0, 1082.0], [300.0, 1214.0], [273.0, 1214.0]], [[240.0, 1084.0], [267.0, 1084.0], [267.0, 1239.0], [240.0, 1239.0]], [[204.0, 1081.0], [239.0, 1081.0], [239.0, 1173.0], [204.0, 1173.0]]], "lines": ["フンフンは", "蟹江さんの", "言っていることの", "意図がよく", "わかりません", "でした。"]}, {"box": [632, 1339, 687, 1521], "vertical": true, "font_size": 22, "lines_coords": [[[664.0, 1340.0], [685.0, 1340.0], [685.0, 1518.0], [664.0, 1518.0]], [[632.0, 1340.0], [654.0, 1340.0], [654.0, 1518.0], [632.0, 1518.0]]], "lines": ["．．．そういう問題", "じゃなくてっ！！"]}, {"box": [218, 1345, 276, 1475], "vertical": true, "font_size": 25, "lines_coords": [[[250.0, 1346.0], [273.0, 1346.0], [276.0, 1475.0], [253.0, 1475.0]], [[218.0, 1345.0], [246.0, 1345.0], [246.0, 1401.0], [218.0, 1401.0]]], "lines": ["なんかこう", "．．．"]}, {"box": [104, 1403, 164, 1531], "vertical": true, "font_size": 25, "lines_coords": [[[137.0, 1403.0], [164.0, 1403.0], [164.0, 1531.0], [137.0, 1531.0]], [[104.0, 1403.0], [128.0, 1403.0], [129.0, 1531.0], [106.0, 1531.0]]], "lines": ["心配したり", "しないの！？"]}], "img_path": "147.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [900, 131, 957, 423], "vertical": true, "font_size": 25, "lines_coords": [[[931.0, 132.0], [957.0, 132.0], [957.0, 307.0], [931.0, 307.0]], [[900.0, 131.0], [921.0, 131.0], [921.0, 423.0], [900.0, 423.0]]], "lines": ["「僕ァ、心配する", "必要性を感じないので、"]}, {"box": [778, 128, 868, 445], "vertical": true, "font_size": 25, "lines_coords": [[[842.0, 129.0], [868.0, 129.0], [868.0, 310.0], [842.0, 310.0]], [[810.0, 128.0], [837.0, 128.0], [837.0, 362.0], [810.0, 362.0]], [[779.0, 129.0], [803.0, 129.0], [801.0, 445.0], [778.0, 445.0]]], "lines": ["フンフンは正直", "そんなこと言われる", "筋合いはないと思いました。"]}, {"box": [657, 83, 685, 217], "vertical": true, "font_size": 28, "lines_coords": [[[657.0, 84.0], [685.0, 84.0], [685.0, 168.0], [657.0, 168.0]]], "lines": ["ん～～"]}, {"box": [185, 48, 212, 203], "vertical": true, "font_size": 25, "lines_coords": [[[185.0, 48.0], [212.0, 48.0], [212.0, 203.0], [185.0, 203.0]]], "lines": ["じゃなくて．．．"]}, {"box": [104, 228, 159, 384], "vertical": true, "font_size": 25, "lines_coords": [[[132.0, 228.0], [159.0, 228.0], [159.0, 384.0], [132.0, 384.0]], [[104.0, 229.0], [126.0, 229.0], [126.0, 382.0], [104.0, 382.0]]], "lines": ["血の繋がった", "家族でしょ？"]}, {"box": [468, 465, 629, 662], "vertical": true, "font_size": 26, "lines_coords": [[[600.0, 467.0], [626.0, 467.0], [623.0, 632.0], [596.0, 632.0]], [[567.0, 467.0], [593.0, 467.0], [593.0, 623.0], [567.0, 623.0]], [[534.0, 465.0], [560.0, 465.0], [560.0, 646.0], [534.0, 646.0]], [[503.0, 467.0], [529.0, 467.0], [529.0, 648.0], [503.0, 648.0]], [[468.0, 465.0], [495.0, 465.0], [498.0, 662.0], [471.0, 662.0]]], "lines": ["「肉親だろうか", "他人たろうが", "別個の生き物に", "変わりはないと", "思いますケド。」"]}, {"box": [266, 465, 357, 646], "vertical": true, "font_size": 25, "lines_coords": [[[329.0, 465.0], [356.0, 465.0], [356.0, 645.0], [329.0, 645.0]], [[296.0, 467.0], [323.0, 467.0], [323.0, 596.0], [296.0, 596.0]], [[267.0, 468.0], [289.0, 468.0], [289.0, 603.0], [267.0, 603.0]]], "lines": ["とんだ愚問だと", "フンフンは", "思いました。"]}, {"box": [910, 757, 970, 915], "vertical": true, "font_size": 27, "lines_coords": [[[943.0, 757.0], [970.0, 757.0], [970.0, 864.0], [943.0, 864.0]], [[910.0, 757.0], [937.0, 757.0], [937.0, 915.0], [910.0, 915.0]]], "lines": ["ちょっと", "小野寺くん．．．"]}, {"box": [217, 776, 276, 907], "vertical": true, "font_size": 29, "lines_coords": [[[254.0, 779.0], [276.0, 779.0], [276.0, 907.0], [254.0, 907.0]], [[220.0, 776.0], [248.0, 776.0], [245.0, 882.0], [217.0, 882.0]]], "lines": ["それって変", "だよ．．．"]}, {"box": [129, 971, 240, 1221], "vertical": true, "font_size": 29, "lines_coords": [[[210.0, 971.0], [239.0, 971.0], [240.0, 1218.0], [212.0, 1218.0]], [[171.0, 973.0], [203.0, 973.0], [203.0, 1221.0], [171.0, 1221.0]], [[132.0, 975.0], [165.0, 975.0], [162.0, 1100.0], [129.0, 1100.0]]], "lines": ["もう少し頭使って", "よく考えたほうが", "いいよ？"]}], "img_path": "148.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [470, 91, 627, 299], "vertical": true, "font_size": 25, "lines_coords": [[[600.0, 93.0], [626.0, 93.0], [623.0, 260.0], [596.0, 260.0]], [[567.0, 93.0], [593.0, 93.0], [593.0, 298.0], [567.0, 298.0]], [[534.0, 93.0], [560.0, 93.0], [560.0, 273.0], [534.0, 273.0]], [[500.0, 92.0], [526.0, 92.0], [526.0, 193.0], [500.0, 193.0]], [[471.0, 92.0], [493.0, 92.0], [493.0, 284.0], [471.0, 284.0]]], "lines": ["「蟹江さんこそ", "自分の尺度でしか", "ものを考えられ", "ないのは", "とうかと思う。」"]}, {"box": [964, 1059, 988, 1199], "vertical": true, "font_size": 20, "lines_coords": [[[965.0, 1060.0], [985.0, 1060.0], [985.0, 1198.0], [965.0, 1198.0]]], "lines": ["．．．ああそう。"]}, {"box": [609, 1112, 700, 1267], "vertical": true, "font_size": 27, "lines_coords": [[[673.0, 1112.0], [700.0, 1112.0], [700.0, 1217.0], [673.0, 1217.0]], [[640.0, 1112.0], [668.0, 1112.0], [670.0, 1267.0], [642.0, 1267.0]], [[609.0, 1112.0], [635.0, 1112.0], [635.0, 1215.0], [609.0, 1215.0]]], "lines": ["．．．じゃあ", "お互い様って", "ことで！！"]}], "img_path": "149.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [821, 139, 944, 306], "vertical": true, "font_size": 25, "lines_coords": [[[917.0, 140.0], [943.0, 140.0], [943.0, 270.0], [917.0, 270.0]], [[884.0, 140.0], [910.0, 140.0], [910.0, 295.0], [884.0, 295.0]], [[850.0, 140.0], [876.0, 140.0], [876.0, 295.0], [850.0, 295.0]], [[821.0, 142.0], [843.0, 142.0], [843.0, 301.0], [821.0, 301.0]]], "lines": ["フンフンは", "なんだか急に", "膝がカクガク", "してきました。"]}, {"box": [566, 81, 589, 237], "vertical": true, "font_size": 22, "lines_coords": [[[567.0, 81.0], [589.0, 81.0], [589.0, 234.0], [567.0, 234.0]]], "lines": ["じゃあさ．．．．．．"]}, {"box": [248, 48, 337, 228], "vertical": true, "font_size": 25, "lines_coords": [[[310.0, 48.0], [337.0, 48.0], [337.0, 228.0], [310.0, 228.0]], [[278.0, 50.0], [304.0, 50.0], [304.0, 178.0], [278.0, 178.0]], [[248.0, 50.0], [270.0, 50.0], [270.0, 201.0], [248.0, 201.0]]], "lines": ["．．．小野寺君でさ、", "ホントは何", "考えてんの？"]}, {"box": [104, 178, 225, 385], "vertical": true, "font_size": 25, "lines_coords": [[[198.0, 178.0], [225.0, 178.0], [225.0, 310.0], [198.0, 310.0]], [[165.0, 179.0], [192.0, 179.0], [192.0, 385.0], [165.0, 385.0]], [[132.0, 178.0], [159.0, 178.0], [159.0, 335.0], [132.0, 335.0]], [[104.0, 179.0], [126.0, 179.0], [126.0, 360.0], [104.0, 360.0]]], "lines": ["帰るなって", "引き止めたくせに", "ただ黙ってる", "ばっかりだし．．．"]}, {"box": [881, 479, 1001, 654], "vertical": true, "font_size": 23, "lines_coords": [[[975.0, 479.0], [1001.0, 479.0], [1001.0, 604.0], [975.0, 604.0]], [[945.0, 482.0], [967.0, 482.0], [967.0, 654.0], [945.0, 654.0]], [[914.0, 481.0], [935.0, 481.0], [935.0, 651.0], [914.0, 651.0]], [[881.0, 479.0], [903.0, 479.0], [903.0, 650.0], [881.0, 650.0]]], "lines": ["もしかして", "お姉ちゃんの絵", "くだらないって", "思って見てた？"]}, {"box": [520, 531, 609, 702], "vertical": true, "font_size": 22, "lines_coords": [[[582.0, 531.0], [604.0, 531.0], [604.0, 678.0], [582.0, 678.0]], [[551.0, 532.0], [573.0, 532.0], [573.0, 700.0], [551.0, 700.0]], [[520.0, 532.0], [542.0, 532.0], [542.0, 698.0], [520.0, 698.0]]], "lines": ["．．．ごめんね！？", "なんか変なもの", "見せちゃって！！"]}, {"box": [101, 507, 195, 692], "vertical": true, "font_size": 28, "lines_coords": [[[157.0, 509.0], [190.0, 507.0], [195.0, 625.0], [162.0, 626.0]], [[132.0, 510.0], [159.0, 510.0], [159.0, 692.0], [132.0, 692.0]], [[103.0, 510.0], [126.0, 510.0], [125.0, 665.0], [101.0, 665.0]]], "lines": ["．．．あたし、", "すっごい冷え症", "なんだよね．．．"]}, {"box": [934, 784, 968, 889], "vertical": true, "font_size": 38, "lines_coords": [[[934.0, 784.0], [968.0, 784.0], [968.0, 889.0], [934.0, 889.0]]], "lines": ["．．．ねえ、"]}, {"box": [851, 889, 892, 965], "vertical": true, "font_size": 38, "lines_coords": [[[851.0, 889.0], [892.0, 889.0], [892.0, 965.0], [851.0, 965.0]]], "lines": ["何！？"]}, {"box": [278, 773, 300, 923], "vertical": true, "font_size": 31, "lines_coords": [[[278.0, 773.0], [300.0, 773.0], [300.0, 923.0], [278.0, 923.0]]], "lines": ["なんなの！？"]}, {"box": [129, 850, 210, 1029], "vertical": true, "font_size": 31, "lines_coords": [[[173.0, 850.0], [210.0, 850.0], [210.0, 1029.0], [173.0, 1029.0]], [[129.0, 856.0], [162.0, 856.0], [162.0, 960.0], [129.0, 960.0]]], "lines": ["どうしたい", "ワケ！？"]}, {"box": [881, 1101, 970, 1351], "vertical": true, "font_size": 40, "lines_coords": [[[931.0, 1101.0], [968.0, 1101.0], [968.0, 1351.0], [931.0, 1351.0]], [[881.0, 1103.0], [923.0, 1103.0], [923.0, 1348.0], [881.0, 1348.0]]], "lines": ["言いたいこと", "あるんならっ、"]}, {"box": [95, 1253, 267, 1548], "vertical": true, "font_size": 54, "lines_coords": [[[214.0, 1257.0], [262.0, 1256.0], [267.0, 1454.0], [218.0, 1456.0]], [[151.0, 1253.0], [212.0, 1253.0], [212.0, 1414.0], [151.0, 1414.0]], [[95.0, 1256.0], [148.0, 1256.0], [148.0, 1548.0], [95.0, 1548.0]]], "lines": ["はっきり", "言えば", "いいじゃんっ！！"]}], "img_path": "150.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [532, 95, 563, 255], "vertical": true, "font_size": 28, "lines_coords": [[[532.0, 98.0], [560.0, 98.0], [560.0, 246.0], [532.0, 246.0]]], "lines": ["「僕と．．．．．"]}, {"box": [893, 396, 925, 532], "vertical": true, "font_size": 28, "lines_coords": [[[896.0, 396.0], [925.0, 396.0], [921.0, 531.0], [893.0, 531.0]]], "lines": ["「．．．．僕と」"]}, {"box": [959, 1031, 990, 1162], "vertical": true, "font_size": 28, "lines_coords": [[[959.0, 1031.0], [987.0, 1031.0], [990.0, 1160.0], [962.0, 1160.0]]], "lines": ["なんで．．．"]}, {"box": [531, 1044, 589, 1198], "vertical": true, "font_size": 24, "lines_coords": [[[562.0, 1045.0], [589.0, 1045.0], [589.0, 1179.0], [562.0, 1179.0]], [[532.0, 1046.0], [554.0, 1046.0], [554.0, 1198.0], [532.0, 1198.0]]], "lines": ["おかしいよ、", "小野寺くん．．．"]}, {"box": [182, 745, 243, 912], "vertical": true, "font_size": 27, "lines_coords": [[[215.0, 746.0], [242.0, 746.0], [242.0, 889.0], [215.0, 889.0]], [[182.0, 745.0], [209.0, 745.0], [209.0, 912.0], [182.0, 912.0]]], "lines": ["「付き合って", "ください．．．"]}, {"box": [645, 1367, 733, 1520], "vertical": true, "font_size": 23, "lines_coords": [[[706.0, 1367.0], [732.0, 1367.0], [732.0, 1495.0], [706.0, 1495.0]], [[676.0, 1367.0], [698.0, 1367.0], [698.0, 1495.0], [676.0, 1495.0]], [[645.0, 1367.0], [667.0, 1367.0], [667.0, 1517.0], [645.0, 1517.0]]], "lines": ["こんな時に", "そんなこと", "言えるの．．．"]}, {"box": [392, 1367, 479, 1545], "vertical": true, "font_size": 25, "lines_coords": [[[457.0, 1368.0], [479.0, 1368.0], [479.0, 1543.0], [457.0, 1543.0]], [[423.0, 1367.0], [445.0, 1367.0], [445.0, 1545.0], [423.0, 1545.0]], [[392.0, 1367.0], [418.0, 1367.0], [418.0, 1545.0], [392.0, 1545.0]]], "lines": ["なんかちかう！！", "なんかちかう！！", "なんかちかう！！"]}, {"box": [120, 1148, 179, 1303], "vertical": true, "font_size": 28, "lines_coords": [[[146.0, 1148.0], [179.0, 1148.0], [179.0, 1231.0], [146.0, 1231.0]], [[120.0, 1150.0], [142.0, 1150.0], [142.0, 1295.0], [120.0, 1295.0]]], "lines": ["身勝手", "すぎるよ．．．"]}, {"box": [243, 1365, 364, 1545], "vertical": true, "font_size": 25, "lines_coords": [[[337.0, 1365.0], [364.0, 1365.0], [364.0, 1495.0], [337.0, 1495.0]], [[304.0, 1367.0], [331.0, 1367.0], [331.0, 1545.0], [304.0, 1545.0]], [[271.0, 1365.0], [298.0, 1365.0], [298.0, 1545.0], [271.0, 1545.0]], [[243.0, 1365.0], [265.0, 1365.0], [265.0, 1503.0], [243.0, 1503.0]]], "lines": ["フンフンは", "はっきり言って", "おしっこ漏らし", "そうでした。"]}], "img_path": "151.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [964, 53, 985, 204], "vertical": true, "font_size": 25, "lines_coords": [[[964.0, 53.0], [985.0, 53.0], [985.0, 204.0], [964.0, 204.0]]], "lines": ["わかったよ．．"]}, {"box": [828, 206, 948, 415], "vertical": true, "font_size": 25, "lines_coords": [[[920.0, 206.0], [946.0, 206.0], [948.0, 376.0], [921.0, 376.0]], [[889.0, 207.0], [917.0, 207.0], [918.0, 392.0], [890.0, 392.0]], [[857.0, 209.0], [884.0, 209.0], [884.0, 415.0], [857.0, 415.0]], [[828.0, 210.0], [850.0, 210.0], [850.0, 389.0], [828.0, 389.0]]], "lines": ["今日一日、色々", "気遣って優しく", "してくれたつもり", "みたいだけど．．"]}, {"box": [421, 0, 573, 707], "vertical": true, "font_size": 29, "lines_coords": [[[537.0, 0.0], [565.0, 0.0], [567.0, 706.0], [539.0, 706.0]], [[500.0, 0.0], [531.0, 0.0], [531.0, 707.0], [500.0, 707.0]], [[464.0, 0.0], [490.0, 0.0], [490.0, 707.0], [464.0, 707.0]], [[421.0, 0.0], [453.0, 0.0], [454.0, 706.0], [423.0, 706.0]]], "lines": ["うちがうちかうちをうちのうちがうちかぅちかうちで", "つちがうちがぅちがラちがうちかうちがうちぶうちで", "つちがうちがつちかうちかうちかうちがうちおうちゃ", "うちがうちかうさがうぢがうちがうちかうろかうちで"]}, {"box": [301, 98, 392, 231], "vertical": true, "font_size": 27, "lines_coords": [[[365.0, 100.0], [392.0, 100.0], [392.0, 204.0], [365.0, 204.0]], [[332.0, 100.0], [359.0, 100.0], [359.0, 231.0], [332.0, 231.0]], [[301.0, 98.0], [328.0, 98.0], [328.0, 204.0], [301.0, 204.0]]], "lines": ["それって", "独善的だと", "思う．．．"]}, {"box": [610, 473, 701, 678], "vertical": true, "font_size": 22, "lines_coords": [[[676.0, 475.0], [698.0, 475.0], [698.0, 651.0], [676.0, 651.0]], [[645.0, 475.0], [667.0, 475.0], [667.0, 675.0], [645.0, 675.0]], [[610.0, 473.0], [632.0, 473.0], [635.0, 678.0], [614.0, 678.0]]], "lines": ["．．．それって結局", "自分が好かれたい", "からなんでしょ？"]}, {"box": [106, 514, 226, 668], "vertical": true, "font_size": 25, "lines_coords": [[[201.0, 514.0], [223.0, 514.0], [223.0, 665.0], [201.0, 665.0]], [[165.0, 514.0], [193.0, 514.0], [193.0, 618.0], [165.0, 618.0]], [[135.0, 514.0], [162.0, 514.0], [162.0, 642.0], [135.0, 642.0]], [[106.0, 515.0], [128.0, 515.0], [128.0, 667.0], [106.0, 667.0]]], "lines": ["もっと相手の", "気持ちを", "考えなきゃ", "ダメだよ．．．"]}, {"box": [946, 784, 973, 914], "vertical": true, "font_size": 26, "lines_coords": [[[946.0, 784.0], [973.0, 784.0], [973.0, 914.0], [946.0, 914.0]]], "lines": ["ごめん．．．"]}, {"box": [800, 862, 918, 1048], "vertical": true, "font_size": 26, "lines_coords": [[[892.0, 862.0], [918.0, 862.0], [918.0, 975.0], [892.0, 975.0]], [[862.0, 867.0], [889.0, 867.0], [889.0, 1048.0], [862.0, 1048.0]], [[831.0, 867.0], [857.0, 867.0], [857.0, 1020.0], [831.0, 1020.0]], [[800.0, 868.0], [826.0, 868.0], [826.0, 973.0], [800.0, 973.0]]], "lines": ["．．．あたし、", "小野寺くんとは", "付き合えない", "から．．．．．"]}, {"box": [178, 879, 236, 1059], "vertical": true, "font_size": 24, "lines_coords": [[[207.0, 879.0], [234.0, 879.0], [234.0, 1059.0], [207.0, 1059.0]], [[178.0, 879.0], [200.0, 879.0], [200.0, 1032.0], [178.0, 1032.0]]], "lines": ["変な勘違いとか", "しないで．．．"]}, {"box": [898, 1151, 973, 1349], "vertical": true, "font_size": 35, "lines_coords": [[[934.0, 1151.0], [973.0, 1151.0], [973.0, 1251.0], [934.0, 1251.0]], [[898.0, 1153.0], [929.0, 1153.0], [929.0, 1343.0], [898.0, 1343.0]]], "lines": ["だって", "小野寺くんは、"]}, {"box": [164, 1306, 274, 1493], "vertical": true, "font_size": 31, "lines_coords": [[[242.0, 1307.0], [273.0, 1307.0], [273.0, 1492.0], [242.0, 1492.0]], [[203.0, 1312.0], [235.0, 1312.0], [235.0, 1435.0], [203.0, 1435.0]], [[164.0, 1306.0], [195.0, 1306.0], [198.0, 1493.0], [167.0, 1493.0]]], "lines": ["自分のことが", "一番好き", "なんでしょ？"]}], "img_path": "152.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [253, 317, 465, 429], "vertical": false, "font_size": 80, "lines_coords": [[[265.0, 317.0], [465.0, 350.0], [453.0, 429.0], [253.0, 396.0]]], "lines": ["．．．"]}, {"box": [296, 403, 437, 514], "vertical": false, "font_size": 33.5, "lines_coords": [[[325.0, 403.0], [435.0, 442.0], [425.0, 476.0], [312.0, 437.0]], [[307.0, 432.0], [437.0, 485.0], [426.0, 514.0], [296.0, 460.0]]], "lines": ["．．．そりゃあああ", "そういうわけで、私は"]}, {"box": [118, 993, 536, 1204], "vertical": true, "font_size": 27, "lines_coords": [[[509.0, 996.0], [535.0, 996.0], [535.0, 1151.0], [509.0, 1151.0]], [[476.0, 996.0], [503.0, 996.0], [503.0, 1153.0], [476.0, 1153.0]], [[429.0, 995.0], [456.0, 995.0], [456.0, 1126.0], [429.0, 1126.0]], [[398.0, 996.0], [425.0, 996.0], [425.0, 1151.0], [398.0, 1151.0]], [[367.0, 995.0], [393.0, 995.0], [393.0, 1126.0], [367.0, 1126.0]], [[335.0, 995.0], [362.0, 995.0], [362.0, 1132.0], [335.0, 1132.0]], [[292.0, 996.0], [318.0, 996.0], [318.0, 1151.0], [292.0, 1151.0]], [[259.0, 993.0], [285.0, 993.0], [282.0, 1151.0], [256.0, 1151.0]], [[226.0, 995.0], [254.0, 995.0], [251.0, 1176.0], [223.0, 1176.0]], [[193.0, 995.0], [221.0, 995.0], [218.0, 1154.0], [190.0, 1154.0]], [[146.0, 993.0], [175.0, 993.0], [176.0, 1201.0], [148.0, 1201.0]], [[118.0, 995.0], [146.0, 995.0], [146.0, 1084.0], [118.0, 1084.0]]], "lines": ["日々、波風を", "たてぬように", "誰にも迷惑", "かけぬように", "生きている", "だけなのに、", "なぜここまで", "こてんはんに", "否定されなきゃ", "ならないのか、", "訳がわかりません", "でした。"]}, {"box": [320, 1269, 445, 1582], "vertical": true, "font_size": 108, "lines_coords": [[[337.0, 1300.0], [445.0, 1307.0], [428.0, 1559.0], [320.0, 1551.0]]], "lines": ["やっちゃえ"]}, {"box": [201, 1303, 295, 1507], "vertical": true, "font_size": 25, "lines_coords": [[[265.0, 1303.0], [292.0, 1303.0], [295.0, 1507.0], [268.0, 1507.0]], [[232.0, 1303.0], [259.0, 1303.0], [259.0, 1481.0], [232.0, 1481.0]], [[201.0, 1303.0], [228.0, 1303.0], [228.0, 1409.0], [201.0, 1409.0]]], "lines": ["蟹江さんはずっと", "何か言い続けて", "ましたが、"]}, {"box": [114, 1303, 168, 1542], "vertical": true, "font_size": 25, "lines_coords": [[[142.0, 1303.0], [168.0, 1303.0], [168.0, 1484.0], [142.0, 1484.0]], [[114.0, 1304.0], [134.0, 1304.0], [134.0, 1542.0], [114.0, 1542.0]]], "lines": ["フンフンは何も", "聞こえませんでした。"]}], "img_path": "153.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [578, 148, 733, 412], "vertical": true, "font_size": 29, "lines_coords": [[[704.0, 153.0], [732.0, 153.0], [732.0, 284.0], [704.0, 284.0]], [[671.0, 150.0], [703.0, 150.0], [700.0, 335.0], [668.0, 335.0]], [[640.0, 148.0], [671.0, 148.0], [671.0, 337.0], [640.0, 337.0]], [[609.0, 151.0], [637.0, 151.0], [635.0, 412.0], [607.0, 412.0]], [[578.0, 153.0], [604.0, 153.0], [604.0, 284.0], [578.0, 284.0]]], "lines": ["あああ．．．．．", "ついさっきまで", "火照った陰部を", "バシャバジャにしてた", "くせにっ！！"]}, {"box": [123, 130, 282, 453], "vertical": true, "font_size": 27, "lines_coords": [[[246.0, 151.0], [278.0, 151.0], [281.0, 414.0], [250.0, 414.0]], [[217.0, 150.0], [243.0, 150.0], [245.0, 389.0], [218.0, 389.0]], [[187.0, 146.0], [214.0, 146.0], [214.0, 453.0], [187.0, 453.0]], [[153.0, 150.0], [184.0, 150.0], [184.0, 439.0], [153.0, 439.0]], [[125.0, 154.0], [146.0, 154.0], [146.0, 437.0], [125.0, 437.0]]], "lines": ["ヒューマニスムを盾に", "正論ばかり振り回す", "ワレメちゃんのほうがっ！！", "すっとずっと独善的だし", "暴力的じゃないですか！！"]}, {"box": [907, 1134, 964, 1301], "vertical": true, "font_size": 24, "lines_coords": [[[937.0, 1134.0], [964.0, 1134.0], [964.0, 1267.0], [937.0, 1267.0]], [[907.0, 1139.0], [929.0, 1139.0], [929.0, 1296.0], [907.0, 1296.0]]], "lines": ["プンプンは", "わかりました"]}, {"box": [153, 1359, 248, 1490], "vertical": true, "font_size": 31, "lines_coords": [[[212.0, 1359.0], [248.0, 1359.0], [248.0, 1420.0], [212.0, 1420.0]], [[184.0, 1360.0], [212.0, 1360.0], [209.0, 1490.0], [181.0, 1490.0]], [[153.0, 1362.0], [181.0, 1362.0], [181.0, 1450.0], [153.0, 1450.0]]], "lines": ["大体", "全部わかり", "ました。"]}], "img_path": "154.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [346, 0, 823, 412], "vertical": false, "font_size": 249, "lines_coords": [[[487.0, 0.0], [823.0, 195.0], [681.0, 412.0], [346.0, 193.0]]], "lines": ["はっ"]}, {"box": [953, 931, 977, 1089], "vertical": true, "font_size": 22, "lines_coords": [[[953.0, 932.0], [975.0, 932.0], [975.0, 1084.0], [953.0, 1084.0]]], "lines": ["翠ちゃん．．．．．"]}, {"box": [325, 948, 360, 1015], "vertical": true, "font_size": 30, "lines_coords": [[[325.0, 948.0], [360.0, 948.0], [360.0, 1015.0], [325.0, 1015.0]]], "lines": ["．．．あ、"]}, {"box": [226, 993, 284, 1150], "vertical": true, "font_size": 30, "lines_coords": [[[257.0, 993.0], [284.0, 993.0], [284.0, 1131.0], [257.0, 1131.0]], [[226.0, 993.0], [253.0, 993.0], [253.0, 1150.0], [226.0, 1150.0]]], "lines": ["お義姉さん、", "起きました？"]}, {"box": [581, 1189, 645, 1319], "vertical": true, "font_size": 32, "lines_coords": [[[610.0, 1189.0], [645.0, 1189.0], [645.0, 1282.0], [610.0, 1282.0]], [[581.0, 1192.0], [609.0, 1192.0], [609.0, 1318.0], [581.0, 1318.0]]], "lines": ["．．．．．．今、", "何時．．．．．？"]}, {"box": [96, 1348, 185, 1503], "vertical": true, "font_size": 24, "lines_coords": [[[157.0, 1348.0], [184.0, 1348.0], [184.0, 1501.0], [157.0, 1501.0]], [[128.0, 1350.0], [150.0, 1350.0], [150.0, 1501.0], [128.0, 1501.0]], [[96.0, 1350.0], [118.0, 1350.0], [118.0, 1484.0], [96.0, 1484.0]]], "lines": ["ちょうど夜の", "９時まわった", "ところです。"]}], "img_path": "155.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [606, 170, 628, 229], "vertical": true, "font_size": 26, "lines_coords": [[[606.0, 170.0], [628.0, 170.0], [628.0, 229.0], [606.0, 229.0]]], "lines": ["．．．"]}, {"box": [570, 121, 632, 278], "vertical": true, "font_size": 26, "lines_coords": [[[604.0, 121.0], [632.0, 121.0], [632.0, 181.0], [604.0, 181.0]], [[570.0, 121.0], [596.0, 121.0], [600.0, 278.0], [573.0, 278.0]]], "lines": ["もー", "当たり前じゃ"]}, {"box": [540, 123, 567, 279], "vertical": true, "font_size": 26, "lines_coords": [[[540.0, 123.0], [567.0, 123.0], [567.0, 279.0], [540.0, 279.0]]], "lines": ["ないですか．．"]}, {"box": [356, 128, 385, 235], "vertical": true, "font_size": 28, "lines_coords": [[[356.0, 129.0], [384.0, 129.0], [384.0, 234.0], [356.0, 234.0]]], "lines": ["夢を．．．"]}, {"box": [892, 446, 985, 576], "vertical": true, "font_size": 28, "lines_coords": [[[957.0, 448.0], [985.0, 448.0], [985.0, 562.0], [957.0, 562.0]], [[929.0, 451.0], [951.0, 451.0], [951.0, 575.0], [929.0, 575.0]], [[892.0, 446.0], [926.0, 446.0], [926.0, 529.0], [892.0, 529.0]]], "lines": ["．．．アタシ、", "生きてるの", "ね．．．．．"]}, {"box": [132, 460, 161, 618], "vertical": true, "font_size": 27, "lines_coords": [[[132.0, 460.0], [159.0, 460.0], [159.0, 617.0], [132.0, 617.0]]], "lines": ["見てたの．．．"]}, {"box": [876, 704, 967, 914], "vertical": true, "font_size": 25, "lines_coords": [[[940.0, 707.0], [962.0, 707.0], [962.0, 912.0], [940.0, 912.0]], [[907.0, 704.0], [934.0, 704.0], [935.0, 914.0], [909.0, 914.0]], [[876.0, 706.0], [903.0, 706.0], [903.0, 815.0], [876.0, 815.0]]], "lines": ["普通の家族みたく", "楽しくおしゃべり", "しながら"]}, {"box": [168, 1015, 253, 1173], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 1017.0], [251.0, 1017.0], [251.0, 1150.0], [225.0, 1150.0]], [[192.0, 1015.0], [218.0, 1015.0], [218.0, 1173.0], [192.0, 1173.0]]], "lines": ["プンプンと", "夕飯食べてた"]}], "img_path": "156.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [634, 859, 988, 1486], "vertical": true, "font_size": 212, "lines_coords": [[[634.0, 985.0], [842.0, 946.0], [917.0, 1337.0], [709.0, 1378.0]]], "lines": ["．．．"]}, {"box": [343, 960, 372, 1070], "vertical": true, "font_size": 28, "lines_coords": [[[343.0, 960.0], [371.0, 960.0], [371.0, 1065.0], [343.0, 1065.0]]], "lines": ["早く．．．"]}, {"box": [126, 1323, 181, 1429], "vertical": true, "font_size": 26, "lines_coords": [[[153.0, 1323.0], [179.0, 1323.0], [179.0, 1429.0], [153.0, 1429.0]]], "lines": ["どいてよ"]}], "img_path": "157.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [690, 60, 718, 163], "vertical": true, "font_size": 28, "lines_coords": [[[690.0, 60.0], [718.0, 60.0], [718.0, 162.0], [690.0, 162.0]]], "lines": ["これ．．．"]}, {"box": [200, 57, 260, 162], "vertical": true, "font_size": 28, "lines_coords": [[[228.0, 57.0], [260.0, 57.0], [260.0, 145.0], [228.0, 145.0]], [[200.0, 59.0], [226.0, 59.0], [226.0, 162.0], [200.0, 162.0]]], "lines": ["．．．．．あ", "いいよ．．．"]}, {"box": [100, 179, 190, 335], "vertical": true, "font_size": 28, "lines_coords": [[[157.0, 179.0], [190.0, 179.0], [190.0, 264.0], [157.0, 264.0]], [[129.0, 181.0], [156.0, 181.0], [156.0, 335.0], [129.0, 335.0]], [[100.0, 184.0], [121.0, 184.0], [121.0, 334.0], [100.0, 334.0]]], "lines": ["濡れて", "帰ったほうが", "マシだから．．．"]}, {"box": [921, 712, 953, 871], "vertical": true, "font_size": 32, "lines_coords": [[[921.0, 712.0], [953.0, 712.0], [953.0, 871.0], [921.0, 871.0]]], "lines": ["あ～～～あ．．．"]}, {"box": [523, 464, 551, 556], "vertical": true, "font_size": 28, "lines_coords": [[[523.0, 464.0], [551.0, 464.0], [551.0, 556.0], [523.0, 556.0]]], "lines": ["返すね。"]}, {"box": [179, 878, 274, 1033], "vertical": true, "font_size": 28, "lines_coords": [[[245.0, 879.0], [273.0, 879.0], [273.0, 984.0], [245.0, 984.0]], [[214.0, 879.0], [242.0, 879.0], [242.0, 984.0], [214.0, 984.0]], [[179.0, 878.0], [206.0, 878.0], [209.0, 1032.0], [182.0, 1032.0]]], "lines": ["家で勉強", "してれば", "よかった．．．"]}, {"box": [520, 1382, 757, 1556], "vertical": false, "font_size": 174, "lines_coords": [[[520.0, 1382.0], [757.0, 1382.0], [757.0, 1556.0], [520.0, 1556.0]]], "lines": ["い、"]}], "img_path": "158.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [857, 98, 921, 231], "vertical": true, "font_size": 31, "lines_coords": [[[887.0, 101.0], [921.0, 101.0], [921.0, 184.0], [887.0, 184.0]], [[857.0, 98.0], [885.0, 98.0], [887.0, 231.0], [859.0, 231.0]]], "lines": ["小野寺", "くんて．．．"]}, {"box": [157, 168, 220, 276], "vertical": true, "font_size": 30, "lines_coords": [[[187.0, 168.0], [220.0, 168.0], [220.0, 276.0], [187.0, 276.0]], [[157.0, 168.0], [185.0, 168.0], [185.0, 275.0], [157.0, 275.0]]], "lines": ["寂しい人", "だね．．．"]}], "img_path": "159.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "160.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "161.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [40, 293, 95, 464], "vertical": true, "font_size": 55, "lines_coords": [[[40.0, 293.0], [95.0, 293.0], [95.0, 464.0], [40.0, 464.0]]], "lines": ["第６５話"]}, {"box": [931, 793, 961, 961], "vertical": true, "font_size": 26, "lines_coords": [[[931.0, 793.0], [957.0, 793.0], [960.0, 959.0], [934.0, 959.0]]], "lines": ["たとえばです。"]}, {"box": [192, 885, 251, 1015], "vertical": true, "font_size": 26, "lines_coords": [[[223.0, 887.0], [250.0, 887.0], [250.0, 1015.0], [223.0, 1015.0]], [[192.0, 885.0], [218.0, 885.0], [218.0, 993.0], [192.0, 993.0]]], "lines": ["たとえばの", "話ですが"]}, {"box": [763, 1125, 987, 1401], "vertical": true, "font_size": 27, "lines_coords": [[[959.0, 1129.0], [985.0, 1129.0], [985.0, 1362.0], [959.0, 1362.0]], [[925.0, 1128.0], [956.0, 1128.0], [956.0, 1289.0], [925.0, 1289.0]], [[895.0, 1129.0], [921.0, 1129.0], [921.0, 1314.0], [895.0, 1314.0]], [[862.0, 1129.0], [889.0, 1129.0], [889.0, 1396.0], [862.0, 1396.0]], [[826.0, 1128.0], [854.0, 1128.0], [856.0, 1259.0], [828.0, 1259.0]], [[796.0, 1128.0], [823.0, 1128.0], [825.0, 1337.0], [798.0, 1337.0]], [[768.0, 1131.0], [790.0, 1131.0], [790.0, 1315.0], [768.0, 1315.0]]], "lines": ["たとえば蟹江さんが", "今日のことを", "学校のみんなに", "大げさに言い触らして、", "強姦未遂の", "荒ぶる陰茎野郎と", "学校中で噂され"]}, {"box": [304, 1126, 429, 1362], "vertical": true, "font_size": 26, "lines_coords": [[[403.0, 1131.0], [429.0, 1131.0], [429.0, 1314.0], [403.0, 1314.0]], [[373.0, 1131.0], [395.0, 1131.0], [395.0, 1289.0], [373.0, 1289.0]], [[339.0, 1126.0], [365.0, 1126.0], [362.0, 1362.0], [335.0, 1362.0]], [[304.0, 1129.0], [332.0, 1129.0], [332.0, 1240.0], [304.0, 1240.0]]], "lines": ["白い目で見られ", "陰口を叩かれ", "上履きを隠されたり", "した場合、"]}, {"box": [123, 1126, 254, 1416], "vertical": true, "font_size": 30, "lines_coords": [[[228.0, 1128.0], [254.0, 1128.0], [251.0, 1375.0], [225.0, 1375.0]], [[193.0, 1128.0], [220.0, 1128.0], [218.0, 1389.0], [192.0, 1389.0]], [[157.0, 1126.0], [189.0, 1126.0], [190.0, 1415.0], [159.0, 1415.0]], [[123.0, 1128.0], [157.0, 1126.0], [160.0, 1218.0], [126.0, 1220.0]]], "lines": ["今後、どういった風に", "生きていけば良いのか", "ブンフンはわかりません", "でした。"]}], "img_path": "162.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [845, 1087, 968, 1323], "vertical": true, "font_size": 26, "lines_coords": [[[942.0, 1089.0], [968.0, 1089.0], [968.0, 1192.0], [942.0, 1192.0]], [[910.0, 1087.0], [937.0, 1087.0], [937.0, 1268.0], [910.0, 1268.0]], [[878.0, 1089.0], [904.0, 1089.0], [904.0, 1293.0], [878.0, 1293.0]], [[845.0, 1090.0], [871.0, 1090.0], [871.0, 1323.0], [845.0, 1323.0]]], "lines": ["．．．などと", "この期に及んで", "自身の心配はかり", "しているというのは"]}, {"box": [692, 1085, 814, 1357], "vertical": true, "font_size": 26, "lines_coords": [[[787.0, 1087.0], [814.0, 1087.0], [814.0, 1357.0], [787.0, 1357.0]], [[754.0, 1087.0], [781.0, 1087.0], [781.0, 1293.0], [754.0, 1293.0]], [[721.0, 1085.0], [750.0, 1085.0], [748.0, 1293.0], [720.0, 1293.0]], [[692.0, 1089.0], [714.0, 1089.0], [714.0, 1326.0], [692.0, 1326.0]]], "lines": ["やはり、いよいよ自分は", "うんちかもしくは", "その類いだな、と", "思わさるを得ません。"]}, {"box": [453, 1351, 511, 1484], "vertical": true, "font_size": 24, "lines_coords": [[[482.0, 1351.0], [509.0, 1351.0], [509.0, 1478.0], [482.0, 1478.0]], [[453.0, 1351.0], [475.0, 1351.0], [475.0, 1482.0], [453.0, 1482.0]]], "lines": ["蟹江さんを", "この雨の中、"]}, {"box": [345, 1351, 403, 1540], "vertical": true, "font_size": 24, "lines_coords": [[[376.0, 1354.0], [403.0, 1354.0], [403.0, 1506.0], [376.0, 1506.0]], [[345.0, 1354.0], [367.0, 1354.0], [367.0, 1534.0], [345.0, 1534.0]]], "lines": ["一人で帰して", "しまったことを"]}, {"box": [234, 1351, 295, 1542], "vertical": true, "font_size": 24, "lines_coords": [[[268.0, 1354.0], [290.0, 1354.0], [290.0, 1528.0], [268.0, 1528.0]], [[234.0, 1351.0], [260.0, 1351.0], [260.0, 1535.0], [234.0, 1535.0]]], "lines": ["一生後悔するに", "違いありません、"]}], "img_path": "163.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [606, 75, 666, 373], "vertical": true, "font_size": 24, "lines_coords": [[[640.0, 81.0], [662.0, 81.0], [662.0, 282.0], [640.0, 282.0]], [[606.0, 79.0], [632.0, 79.0], [632.0, 368.0], [606.0, 368.0]]], "lines": ["蟹江さんの言葉が", "何度もリフレインします。"]}, {"box": [486, 78, 545, 271], "vertical": true, "font_size": 22, "lines_coords": [[[520.0, 84.0], [542.0, 84.0], [542.0, 242.0], [520.0, 242.0]], [[487.0, 82.0], [509.0, 82.0], [509.0, 268.0], [487.0, 268.0]]], "lines": ["小野寺くんて", "寂しい人だね。」"]}, {"box": [324, 212, 353, 479], "vertical": true, "font_size": 22, "lines_coords": [[[326.0, 215.0], [348.0, 215.0], [348.0, 475.0], [326.0, 475.0]]], "lines": ["フンフンは思いました。"]}, {"box": [179, 210, 238, 445], "vertical": true, "font_size": 24, "lines_coords": [[[210.0, 210.0], [237.0, 210.0], [237.0, 404.0], [210.0, 404.0]], [[181.0, 214.0], [203.0, 214.0], [203.0, 440.0], [181.0, 440.0]]], "lines": ["「どうしていつも", "こうなのだろう」と。"]}, {"box": [603, 1329, 664, 1493], "vertical": true, "font_size": 61, "lines_coords": [[[603.0, 1329.0], [664.0, 1329.0], [664.0, 1493.0], [603.0, 1493.0]]], "lines": ["「なんで僕は何度も何度や、"]}, {"box": [604, 1332, 659, 1487], "vertical": true, "font_size": 25, "lines_coords": [[[637.0, 1332.0], [659.0, 1332.0], [659.0, 1470.0], [637.0, 1470.0]], [[604.0, 1332.0], [626.0, 1332.0], [626.0, 1487.0], [604.0, 1487.0]]], "lines": ["「なんで僕は", "何度も同度も"]}, {"box": [473, 1328, 565, 1534], "vertical": true, "font_size": 25, "lines_coords": [[[535.0, 1328.0], [564.0, 1328.0], [565.0, 1462.0], [537.0, 1462.0]], [[503.0, 1328.0], [529.0, 1328.0], [532.0, 1534.0], [506.0, 1534.0]], [[473.0, 1329.0], [500.0, 1329.0], [500.0, 1457.0], [473.0, 1457.0]]], "lines": ["好きな人を", "傷つけてしまうの", "だろう」と。"]}], "img_path": "164.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [479, 243, 1118, 814], "vertical": false, "font_size": 326, "lines_coords": [[[656.0, 243.0], [1118.0, 540.0], [942.0, 814.0], [479.0, 518.0]]], "lines": ["ダウン"]}, {"box": [248, 623, 710, 1314], "vertical": true, "font_size": 252, "lines_coords": [[[248.0, 712.0], [484.0, 623.0], [710.0, 1225.0], [475.0, 1314.0]]], "lines": ["ウォッ"]}], "img_path": "165.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [276, 74, 466, 818], "vertical": true, "font_size": 190, "lines_coords": [[[276.0, 74.0], [466.0, 74.0], [466.0, 818.0], [276.0, 818.0]]], "lines": ["うひゃあああは"]}, {"box": [210, 21, 531, 1181], "vertical": true, "font_size": 316, "lines_coords": [[[210.0, 23.0], [526.0, 21.0], [531.0, 1142.0], [215.0, 1143.0]]], "lines": ["うひゃああぁっはっひっ"]}, {"box": [329, 914, 459, 1530], "vertical": true, "font_size": 106, "lines_coords": [[[353.0, 1392.0], [459.0, 1392.0], [459.0, 1509.0], [353.0, 1509.0]]], "lines": ["★"]}], "img_path": "166.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [898, 98, 978, 237], "vertical": true, "font_size": 21, "lines_coords": [[[956.0, 100.0], [978.0, 100.0], [978.0, 217.0], [956.0, 217.0]], [[928.0, 100.0], [948.0, 100.0], [948.0, 237.0], [928.0, 237.0]], [[898.0, 98.0], [920.0, 98.0], [920.0, 190.0], [898.0, 190.0]]], "lines": ["．．．ねェねェ", "ホント大丈夫", "かしら！？"]}, {"box": [770, 195, 875, 381], "vertical": true, "font_size": 21, "lines_coords": [[[851.0, 196.0], [875.0, 196.0], [873.0, 359.0], [850.0, 359.0]], [[823.0, 195.0], [845.0, 195.0], [845.0, 381.0], [823.0, 381.0]], [[796.0, 196.0], [818.0, 196.0], [818.0, 381.0], [796.0, 381.0]], [[770.0, 200.0], [787.0, 200.0], [787.0, 310.0], [770.0, 310.0]]], "lines": ["年寄りの強引な", "若作りってやっぱ", "痛々しすぎるって", "いうかさ！！"]}, {"box": [335, -1, 701, 121], "vertical": false, "font_size": 134, "lines_coords": [[[335.0, 0.0], [701.0, 0.0], [701.0, 133.0], [335.0, 133.0]]], "lines": ["そういうことで、これから"]}, {"box": [206, 95, 282, 232], "vertical": true, "font_size": 23, "lines_coords": [[[260.0, 95.0], [282.0, 95.0], [282.0, 212.0], [260.0, 212.0]], [[234.0, 95.0], [256.0, 95.0], [256.0, 232.0], [234.0, 232.0]], [[206.0, 118.0], [228.0, 118.0], [228.0, 189.0], [206.0, 189.0]]], "lines": ["そんなこと", "ないですよォ", "ーッ！！"]}, {"box": [98, 240, 206, 400], "vertical": true, "font_size": 23, "lines_coords": [[[176.0, 240.0], [204.0, 240.0], [206.0, 337.0], [178.0, 337.0]], [[153.0, 243.0], [175.0, 243.0], [175.0, 382.0], [153.0, 382.0]], [[123.0, 240.0], [146.0, 240.0], [148.0, 400.0], [125.0, 400.0]], [[98.0, 243.0], [118.0, 243.0], [118.0, 381.0], [98.0, 381.0]]], "lines": ["２０代って", "言い張っても", "全然イケちゃい", "ますよォー！！"]}, {"box": [905, 509, 954, 627], "vertical": true, "font_size": 22, "lines_coords": [[[929.0, 509.0], [951.0, 509.0], [951.0, 626.0], [929.0, 626.0]]], "lines": ["じゃあさ！！"]}, {"box": [904, 512, 926, 628], "vertical": true, "font_size": 23, "lines_coords": [[[904.0, 512.0], [926.0, 512.0], [926.0, 628.0], [904.0, 628.0]]], "lines": ["じゃあさ！！"]}, {"box": [779, 645, 904, 856], "vertical": true, "font_size": 23, "lines_coords": [[[878.0, 645.0], [904.0, 645.0], [904.0, 787.0], [878.0, 787.0]], [[850.0, 645.0], [876.0, 645.0], [876.0, 856.0], [850.0, 856.0]], [[829.0, 646.0], [851.0, 646.0], [851.0, 831.0], [829.0, 831.0]], [[804.0, 648.0], [826.0, 648.0], 