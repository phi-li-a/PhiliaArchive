, "font_size": 30, "lines_coords": [[[945.0, 1309.0], [978.0, 1309.0], [978.0, 1418.0], [945.0, 1418.0]]], "lines": ["あっ．．．"]}, {"box": [859, 1392, 885, 1523], "vertical": true, "font_size": 30, "lines_coords": [[[859.0, 1392.0], [885.0, 1392.0], [885.0, 1523.0], [859.0, 1523.0]]], "lines": ["それと．．．"]}, {"box": [157, 1375, 186, 1507], "vertical": true, "font_size": 25, "lines_coords": [[[160.0, 1457.0], [182.0, 1457.0], [182.0, 1504.0], [160.0, 1504.0]], [[157.0, 1375.0], [185.0, 1375.0], [185.0, 1456.0], [157.0, 1456.0]]], "lines": ["．．．", "名前ー"]}], "img_path": "052.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [318, 209, 356, 350], "vertical": true, "font_size": 36, "lines_coords": [[[318.0, 209.0], [356.0, 209.0], [356.0, 350.0], [318.0, 350.0]]], "lines": ["晴見です。"]}, {"box": [235, 389, 268, 621], "vertical": true, "font_size": 36, "lines_coords": [[[235.0, 389.0], [268.0, 389.0], [268.0, 621.0], [235.0, 621.0]]], "lines": ["晴見俊太郎です。"]}], "img_path": "053.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [801, 75, 830, 202], "vertical": true, "font_size": 25, "lines_coords": [[[804.0, 75.0], [829.0, 75.0], [826.0, 198.0], [801.0, 198.0]]], "lines": ["１６歳か．．．"]}, {"box": [667, 76, 726, 226], "vertical": true, "font_size": 24, "lines_coords": [[[701.0, 76.0], [723.0, 76.0], [723.0, 225.0], [701.0, 225.0]], [[667.0, 76.0], [693.0, 76.0], [693.0, 201.0], [667.0, 201.0]]], "lines": ["フンフンとは", "大違い．．．"]}, {"box": [426, 73, 519, 285], "vertical": true, "font_size": 30, "lines_coords": [[[490.0, 75.0], [517.0, 75.0], [517.0, 228.0], [490.0, 228.0]], [[454.0, 73.0], [489.0, 73.0], [489.0, 164.0], [454.0, 164.0]], [[426.0, 73.0], [453.0, 73.0], [453.0, 281.0], [426.0, 281.0]]], "lines": ["喋ってるだけ", "なのに、", "言葉の一つ一つか"]}, {"box": [273, 74, 310, 266], "vertical": true, "font_size": 27, "lines_coords": [[[273.0, 78.0], [300.0, 78.0], [300.0, 260.0], [273.0, 260.0]]], "lines": ["．．．なんか眩しい。"]}, {"box": [865, 407, 962, 562], "vertical": true, "font_size": 27, "lines_coords": [[[932.0, 407.0], [960.0, 407.0], [962.0, 539.0], [934.0, 539.0]], [[900.0, 407.0], [926.0, 407.0], [926.0, 562.0], [900.0, 562.0]], [[868.0, 407.0], [896.0, 407.0], [893.0, 537.0], [865.0, 537.0]]], "lines": ["やっぱ．．．．．．", "彼女とかいる", "のかナ．．．"]}, {"box": [153, 459, 244, 617], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 464.0], [243.0, 464.0], [243.0, 593.0], [217.0, 593.0]], [[184.0, 462.0], [210.0, 462.0], [210.0, 617.0], [184.0, 617.0]], [[153.0, 459.0], [179.0, 459.0], [179.0, 565.0], [153.0, 565.0]]], "lines": ["．．．バカッ！！", "何考えてんの", "アタシ！！"]}, {"box": [918, 715, 978, 978], "vertical": true, "font_size": 60, "lines_coords": [[[918.0, 715.0], [978.0, 715.0], [978.0, 978.0], [918.0, 978.0]]], "lines": ["はァ～～～"]}, {"box": [928, 989, 965, 1234], "vertical": true, "font_size": 37, "lines_coords": [[[928.0, 989.0], [965.0, 989.0], [965.0, 1234.0], [928.0, 1234.0]]], "lines": ["＿，，ｏｏｏ．ｃｏｍｏｎ"]}, {"box": [131, 717, 207, 1243], "vertical": true, "font_size": 70, "lines_coords": [[[131.0, 718.0], [201.0, 718.0], [204.0, 1243.0], [134.0, 1243.0]]], "lines": ["オナニーしたい．．．"]}, {"box": [873, 1332, 951, 1495], "vertical": true, "font_size": 24, "lines_coords": [[[929.0, 1332.0], [951.0, 1332.0], [951.0, 1450.0], [929.0, 1450.0]], [[901.0, 1332.0], [923.0, 1332.0], [923.0, 1493.0], [901.0, 1493.0]], [[873.0, 1332.0], [895.0, 1332.0], [895.0, 1495.0], [873.0, 1495.0]]], "lines": ["．．．俺だって", "何も考えてない", "訳じゃないさ．．．"]}, {"box": [739, 1371, 826, 1532], "vertical": true, "font_size": 24, "lines_coords": [[[795.0, 1371.0], [823.0, 1371.0], [826.0, 1475.0], [798.0, 1475.0]], [[770.0, 1371.0], [792.0, 1371.0], [793.0, 1532.0], [771.0, 1532.0]], [[742.0, 1373.0], [768.0, 1373.0], [765.0, 1467.0], [739.0, 1467.0]]], "lines": ["いい加減、", "もう働かなきゃ", "って．．．"]}, {"box": [285, 1345, 365, 1462], "vertical": true, "font_size": 22, "lines_coords": [[[343.0, 1345.0], [365.0, 1345.0], [365.0, 1460.0], [343.0, 1460.0]], [[315.0, 1346.0], [337.0, 1346.0], [337.0, 1440.0], [315.0, 1440.0]], [[285.0, 1346.0], [307.0, 1346.0], [307.0, 1462.0], [285.0, 1462.0]]], "lines": ["とにかく．．．", "酒はもう", "やめるさ．．．"]}, {"box": [137, 1367, 243, 1532], "vertical": true, "font_size": 22, "lines_coords": [[[223.0, 1368.0], [243.0, 1368.0], [243.0, 1507.0], [223.0, 1507.0]], [[192.0, 1367.0], [218.0, 1367.0], [218.0, 1532.0], [192.0, 1532.0]], [[165.0, 1368.0], [187.0, 1368.0], [187.0, 1531.0], [165.0, 1531.0]], [[137.0, 1368.0], [159.0, 1368.0], [159.0, 1450.0], [137.0, 1450.0]]], "lines": ["仕事の質とか", "内容にいちいち", "ケチつけるのも", "やめる。"]}], "img_path": "054.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [964, 126, 990, 256], "vertical": true, "font_size": 25, "lines_coords": [[[964.0, 126.0], [990.0, 126.0], [990.0, 256.0], [964.0, 256.0]]], "lines": ["けどね．．．"]}, {"box": [812, 265, 937, 471], "vertical": true, "font_size": 25, "lines_coords": [[[909.0, 265.0], [937.0, 265.0], [934.0, 423.0], [906.0, 423.0]], [[876.0, 268.0], [898.0, 268.0], [898.0, 471.0], [876.0, 471.0]], [[842.0, 265.0], [868.0, 265.0], [870.0, 448.0], [843.0, 448.0]], [[812.0, 267.0], [834.0, 267.0], [834.0, 420.0], [812.0, 420.0]]], "lines": ["俺は十数年間", "ポントにホントは", "命懸けで働いて", "きたから．．．"]}, {"box": [257, 121, 348, 306], "vertical": true, "font_size": 25, "lines_coords": [[[321.0, 123.0], [348.0, 123.0], [348.0, 281.0], [321.0, 281.0]], [[287.0, 121.0], [318.0, 121.0], [318.0, 306.0], [287.0, 306.0]], [[257.0, 123.0], [279.0, 123.0], [279.0, 276.0], [257.0, 276.0]]], "lines": ["外に出るのが", "怖くてしょうが", "ないんだ．．．"]}, {"box": [903, 640, 965, 820], "vertical": true, "font_size": 24, "lines_coords": [[[940.0, 645.0], [962.0, 645.0], [962.0, 820.0], [940.0, 820.0]], [[906.0, 640.0], [932.0, 640.0], [929.0, 798.0], [903.0, 798.0]]], "lines": ["こんなハズじゃ", "なかった．．．"]}, {"box": [145, 345, 262, 581], "vertical": true, "font_size": 25, "lines_coords": [[[240.0, 348.0], [262.0, 348.0], [262.0, 526.0], [240