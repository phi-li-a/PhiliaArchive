1.0], [286.0, 1501.0], [286.0, 1670.0], [251.0, 1670.0]], [[209.0, 1501.0], [245.0, 1501.0], [245.0, 1736.0], [209.0, 1736.0]], [[168.0, 1501.0], [203.0, 1501.0], [203.0, 1670.0], [168.0, 1670.0]], [[128.0, 1501.0], [164.0, 1501.0], [164.0, 1653.0], [128.0, 1653.0]]], "lines": ["貯金なんか", "してもたいして", "使い道ない", "くせにさ。"]}], "img_path": "109.png"}, {"version": "0.2.0-beta.6", "img_width": 1439, "img_height": 2127, "blocks": [{"box": [1183, 112, 1293, 332], "vertical": true, "font_size": 32, "lines_coords": [[[1254.0, 112.0], [1293.0, 112.0], [1293.0, 211.0], [1254.0, 211.0]], [[1223.0, 114.0], [1252.0, 114.0], [1252.0, 330.0], [1223.0, 330.0]], [[1183.0, 112.0], [1212.0, 112.0], [1214.0, 330.0], [1185.0, 330.0]]], "lines": ["．．．ただ", "現場のバイトは", "辞めるかな．．．"]}, {"box": [882, 45, 934, 173], "vertical": true, "font_size": 29, "lines_coords": [[[905.0, 54.0], [934.0, 54.0], [934.0, 153.0], [905.0, 153.0]]], "lines": ["ロロッ．．．"]}, {"box": [664, 180, 822, 386], "vertical": true, "font_size": 32, "lines_coords": [[[786.0, 180.0], [822.0, 180.0], [822.0, 317.0], [786.0, 317.0]], [[749.0, 184.0], [778.0, 184.0], [778.0, 353.0], [749.0, 353.0]], [[706.0, 184.0], [735.0, 184.0], [735.0, 384.0], [706.0, 384.0]], [[664.0, 180.0], [699.0, 180.0], [699.0, 303.0], [664.0, 303.0]]], "lines": ["．．．あたし", "明日は一日", "仕事休みなん", "だけど、"]}, {"box": [911, 521, 1052, 750], "vertical": true, "font_size": 29, "lines_coords": [[[1021.0, 523.0], [1050.0, 523.0], [1050.0, 672.0], [1021.0, 672.0]], [[984.0, 523.0], [1013.0, 523.0], [1013.0, 735.0], [984.0, 735.0]], [[946.0, 523.0], [975.0, 523.0], [975.0, 737.0], [946.0, 737.0]], [[911.0, 521.0], [940.0, 521.0], [940.0, 747.0], [911.0, 747.0]]], "lines": ["．．．重機とか", "トラックとかが", "近く走るだけで", "ちょっと怖いわ。"]}, {"box": [1127, 882, 1270, 1069], "vertical": true, "font_size": 32, "lines_coords": [[[1237.0, 884.0], [1268.0, 884.0], [1270.0, 1067.0], [1239.0, 1067.0]], [[1200.0, 886.0], [1235.0, 886.0], [1235.0, 1069.0], [1200.0, 1069.0]], [[1162.0, 882.0], [1198.0, 882.0], 