.0], [431.0, 1715.0], [431.0, 1929.0], [404.0, 1929.0]], [[369.0, 1715.0], [398.0, 1715.0], [398.0, 2010.0], [369.0, 2010.0]], [[336.0, 1711.0], [365.0, 1711.0], [363.0, 1877.0], [334.0, 1877.0]]], "lines": ["．．．三週間も経って", "犯人が見つからないって", "どういう事？"]}], "img_path": "172.png"}, {"version": "0.2.0-beta.6", "img_width": 1433, "img_height": 2127, "blocks": [{"box": [1198, 143, 1283, 284], "vertical": true, "font_size": 37, "lines_coords": [[[1239.0, 145.0], [1283.0, 145.0], [1283.0, 284.0], [1239.0, 284.0]], [[1198.0, 143.0], [1241.0, 143.0], [1241.0, 284.0], [1198.0, 284.0]]], "lines": ["いやいや", "南条．．．"]}, {"box": [1013, 213, 1129, 450], "vertical": true, "font_size": 37, "lines_coords": [[[1094.0, 213.0], [1129.0, 213.0], [1129.0, 450.0], [1094.0, 450.0]], [[1052.0, 213.0], [1088.0, 213.0], [1088.0, 421.0], [1052.0, 421.0]], [[1013.0, 213.0], [1042.0, 213.0], [1042.0, 450.0], [1013.0, 450.0]]], "lines": ["そのオバサンが", "直接何かした", "訳じゃないし．．"]}, {"box": [722, 74, 772, 483], "vertical": true, "font_size": 42, "lines_coords": [[[731.0, 74.0], [772.0, 74.0], [764.0, 483.0], [722.0, 483.0]]], "lines": ["明るいより前早くっ間"]}, {"box": [635, 68, 683, 486], "vertical": true, "font_size": 42, "lines_coords": [[[635.0, 68.0], [677.0, 68.0], [683.0, 486.0], [641.0, 486.0]]], "lines": ["あ休みさせて戴きます。"]}, {"box": [421, 174, 488, 355], "vertical": true, "font_size": 29, "lines_coords": [[[458.0, 174.0], [488.0, 174.0], [483.0, 355.0], [454.0, 355.0]], [[421.0, 176.0], [450.0, 176.0], [450.0, 338.0], [421.0, 338.0]]], "lines": ["社長の怪我の", "原因だって、"]}, {"box": [176, 207, 315, 513], "vertical": true, "font_size": 29, "lines_coords": [[[286.0, 209.0], [315.0, 209.0], [315.0, 479.0], [286.0, 479.0]], [[249.0, 207.0], [278.0, 207.0], [278.0, 483.0], [249.0, 483.0]], [[211.0, 209.0], [240.0, 209.0], [240.0, 452.0], [211.0, 452.0]], [[176.0, 209.0], [203.0, 209.0], [203.0, 513.0], [176.0, 513.0]]], "lines": ["店員に倒された時か", "警備員に取り押さえ", "られた時かはまだ", "わかんないんだから．．．"]}, {"box": [741, 650, 858, 855], "vertical": true, "font_size": 30, "lines_coords": [[[824.0, 654.0], [853.0, 654.0], [853.0, 853.0], [824.0, 853.0]], [[780.0, 650.0], [812.0, 650.0], [814.0, 853.0], [782.0, 853.0]], [[741.0, 654.0], [770.0, 654.0], [770.0, 828.0], [741.0, 828.0]]], "lines": ["蟹江はなんて", "そんなに擁護", "するんだよ。"]}, {"box": [1181, 1699, 1286, 1969], "vertical": true, "font_size": 28, "lines_coords": [[[1256.0, 1703.0], [1285.0, 1703.0], [1285.0, 1852.0], [1256.0, 1852.0]], [[1219.0, 1701.0], [1248.0, 1701.0], [1248.0, 1969.0], [1219.0, 1969.0]], [[1181.0, 1699.0], [1208.0, 1699.0], [1208.0, 1917.0], [1181.0, 1917.0]]], "lines": ["商品持って", "店の外に出ちゃった", "社長も社長だし、"]}, {"box": [575, 1775, 717, 2012], "vertical": true, "font_size": 28, "lines_coords": [[[685.0, 1775.0], [714.0, 1775.0], [714.0, 2012.0], [685.0, 2012.0]], [[650.0, 1775.0], [679.0, 1775.0], [679.0, 1929.0], [650.0, 1929.0]], [[612.0, 1775.0], [641.0, 1775.0], [641.0, 1954.0], [612.0, 1954.0]], [[575.0, 1775.0], [602.0, 1775.0], [602.0, 1952.0], [575.0, 1952.0]]], "lines": ["あんたの気持ちも", "わかるけど、", "公平な意見も", "必要でしょ？"]}, {"box": [124, 1759, 265, 2006], "vertical": true, "font_size": 31, "lines_coords": [[[234.0, 1765.0], [263.0, 1765.0], [263.0, 1946.0], [234.0, 1946.0]], [[193.0, 1759.0], [228.0, 1759.0], [230.0, 2006.0], [195.0, 2006.0]], [[161.0, 1765.0], [191.0, 1765.0], [191.0, 1973.0], [161.0, 1973.0]], [[124.0, 1763.0], [153.0, 1763.0], [153.0, 1883.0], [124.0, 1883.0]]], "lines": ["．．．それに悪者", "吊るし上げたって", "時間は戻らない", "じゃん？"]}], "img_path": "173.png"}, {"version": "0.2.0-beta.6", "img_width": 1435, "img_height": 2127, "blocks": [{"box": [577, 83, 684, 298], "vertical": true, "font_size": 32, "lines_coords": [[[652.0, 85.0], [681.0, 85.0], [681.0, 297.0], [652.0, 297.0]], [[608.0, 83.0], [645.0, 83.0], [645.0, 211.0], [608.0, 211.0]], [[577.0, 85.0], [606.0, 85.0], [606.0, 280.0], [577.0, 280.0]]], "lines": ["．．．俺達、今日は", "帰ります", "ジェケシェケ。"]}, {"box": [265, 89, 334, 263], "vertical": true, "font_size": 33, "lines_coords": [[[299.0, 89.0], [334.0, 89.0],