, [[187.0, 1736.0], [216.0, 1736.0], [218.0, 2006.0], [189.0, 2006.0]], [[151.0, 1738.0], [178.0, 1738.0], [178.0, 2021.0], [151.0, 2021.0]]], "lines": ["そういう安易な", "助け合い精神を", "強要してくる奴らの", "ウザさったらないわ。"]}], "img_path": "080.png"}, {"version": "0.2.0-beta.6", "img_width": 1439, "img_height": 2127, "blocks": [{"box": [1223, 128, 1306, 338], "vertical": true, "font_size": 34, "lines_coords": [[[1264.0, 128.0], [1306.0, 128.0], [1306.0, 338.0], [1264.0, 338.0]], [[1227.0, 128.0], [1264.0, 128.0], [1260.0, 286.0], [1223.0, 286.0]]], "lines": ["はァーーア．．．", "呆れたよ。"]}, {"box": [1071, 263, 1179, 477], "vertical": true, "font_size": 34, "lines_coords": [[[1144.0, 263.0], [1179.0, 263.0], [1179.0, 390.0], [1144.0, 390.0]], [[1110.0, 265.0], [1139.0, 265.0], [1139.0, 448.0], [1110.0, 448.0]], [[1073.0, 263.0], [1102.0, 263.0], [1100.0, 477.0], [1071.0, 477.0]]], "lines": ["南条には", "胸が痛むって", "感覚はないの？"]}, {"box": [157, 263, 304, 508], "vertical": true, "font_size": 31, "lines_coords": [[[267.0, 263.0], [299.0, 263.0], [303.0, 506.0], [272.0, 506.0]], [[234.0, 265.0], [263.0, 265.0], [263.0, 448.0], [234.0, 448.0]], [[197.0, 265.0], [226.0, 265.0], [226.0, 448.0], [197.0, 448.0]], [[157.0, 263.0], [193.0, 263.0], [193.0, 400.0], [157.0, 400.0]]], "lines": ["あんたがそこまで", "身勝手で鬼畜", "だとは思わな", "かったわ。"]}, {"box": [1127, 639, 1281, 943], "vertical": true, "font_size": 29, "lines_coords": [[[1252.0, 639.0], [1281.0, 639.0], [1281.0, 874.0], [1252.0, 874.0]], [[1212.0, 641.0], [1241.0, 641.0], [1241.0, 878.0], [1212.0, 878.0]], [[1171.0, 641.0], [1200.0, 641.0], [1200.0, 943.0], [1171.0, 943.0]], [[1129.0, 639.0], [1160.0, 639.0], [1158.0, 843.0], [1127.0, 843.0]]], "lines": ["．．．じゃあお前の", "その行動の源は", "本当に善意なのか！？", "ちげーだろ！？"]}, {"box": [236, 783, 448, 1086], "vertical": true, "font_size": 31, "lines_coords": [[[421.0, 783.0], [448.0, 783.0], [448.0, 1086.0], [421.0, 1086.0]], [[384.0, 785.0], [413.0, 785.0], [413.0, 1028.0], [384.0, 1028.0]], [[344.0, 783.0], [379.0, 783.0], [379.0, 1057.0], [344.0, 1057.0]], [[307.0, 783.0], [336.0, 783.0], [336.0, 1055.0], [307.0, 1055.0]], [[274.0, 785.0], [303.0, 785.0], [303.0, 1026.0], [274.0, 1026.0]], [[236.0, 783.0], [265.0, 783.0], [265.0, 994.0], [236.0, 994.0]]], "lines": ["それとも募金箱の前を", "素通りしただけで", "悪人のような気分に", "させられる雰囲気を", "作ってるお前達が", "健全だとでも！？"]}, {"box": [1096, 978, 1162, 1223], "vertical": true, "font_size": 29, "lines_coords": [[[1133.0, 978.0], [1162.0, 978.0], [1162.0, 1161.0], [1133.0, 1161.0]], [[1096.0, 978.0], [1125.0, 978.0], [1125.0, 1223.0], [1096.0, 1223.0]]], "lines": ["なんだかんだ", "ぬくぬくと日常を"]}, {"box": [986, 972, 1165, 1251], "vertical": true, "font_size": 28, "lines_coords": [[[1056.0, 978.0], [1085.0, 978.0], [1085.0, 1250.0], [1056.0, 1250.0]], [[1021.0, 976.0], [1050.0, 976.0], [1050.0, 1250.0], [1021.0, 1250.0]], [[986.0, 976.0], [1013.0, 976.0], [1013.0, 1219.0], [986.0, 1219.0]]], "lines": ["送れる後ろめたさを", "払拭できる満足感が", "欲しいだけだろ！？"]}, {"box": [1166, 1485, 1246, 1657], "vertical": true, "font_size": 32, "lines_coords": [[[1216.0, 1487.0], [1245.0, 1487.0], [1245.0, 1618.0], [1216.0, 1618.0]], [[1171.0, 1485.0], [1206.0, 1485.0], [1202.0, 1657.0], [1166.0, 1657.0]]], "lines": ["まぁまぁ", "南条さん．．．"]}, {"box": [658, 1449, 735, 1688], "vertical": true, "font_size": 36, "lines_coords": [[[699.0, 1449.0], [735.0, 1449.0], [735.0, 1620.0], [699.0, 1620.0]], [[658.0, 1451.0], [693.0, 1451.0], [693.0, 1688.0], [658.0, 1688.0]]], "lines": ["．．．アンタは", "強がりだから！！"]}, {"box": [220, 1146, 301, 1354], "vertical": true, "font_size": 31, "lines_coords": [[[263.0, 1146.0], [301.0, 1146.0], [301.0, 1287.0], [263.0, 1287.0]], [[220.0, 1150.0], [255.0, 1150.0], [255.0, 1354.0], [220.0, 1354.0]]], "lines": ["どっちが", "おかしいのか"]}, {"box": [182, 1147, 302, 1352], "vertical": true, "font_size": 29, "lines_coords": [[[182.0, 1148.0], [211.0, 1148.0], [211.0, 1352.0], [182.0, 1352.0]]], "lines": ["よく考えろ！！"]}, {"box": [815, 1813, 991, 2062], "vertical": true, "font_size": 28, "lines_coords": [[[961.0, 1813.0], [990.0, 1813.0], [990.0, 1962.0], [961.0, 1962.0]], [[919.0, 1813.0], [951.0, 1813.0], [953.0, 2062.0], [921.0, 2062.0]], [[886.0, 1815.0], [915.0, 1815.0], [915.0, 2054.0], [886.0, 2054.0]], [[851.0, 1813.0], [878.0, 1813.0], [878.0, 2052.0], [851.0, 2052.0]], [[816.0, 1815.0], [838.0, 1815.0], [838.0, 1964.0], [816.0, 1964.0]]], "lines": ["俺にはよく", "わからないスけど、", "俺の腹筋は二人共", "落ちつけと言って", "ますが．．．．．"]}, {"box": [171, 1850, 246, 2018], "vertical": true, "font_size": 32, "lines_coords": [[[209.0, 1850.0], [245.0, 1850.0], [245.0, 1989.0], [209.0, 1989.0]], [[172.0, 1852.0], [199.0, 1852.0], [199.0, 2018.0], [172.0, 2018.0]]], "lines": ["．．．だから", "なんだよ！！"]}], "img_path": "081.png"}, {"version": "0.2.0-beta.6", "img_width": 1441, "img_height": 2127, "blocks": [{"box": [1164, 108, 1293, 327], "vertical": true, "font_size": 29, "lines_coords": [[[1264.0, 108.0], [1293.0, 108.0], [1293.0, 220.0], [1264.0, 220.0]], [[1229.0, 108.0], [1258.0, 108.0], [1260.0, 326.0], [1231.0, 326.0]], [[1195.0, 108.0], [1225.0, 108.0], [1227.0, 274.0], [1198.0, 274.0]], [[1164.0, 110.0], [1191.0, 110.0], [1191.0, 326.0], [1164.0, 326.0]]], "lines": ["．．．南条は", "明日は我が身って", "自覚が足りて", "ないんじゃない？"]}, {"box": [400, 152, 541, 365], "vertical": true, "font_size": 29, "lines_coords": [[[510.0, 153.0], [539.0, 153.0], [539.0, 307.0], [510.0, 307.0]], [[471.0, 153.0], [502.0, 153.0], [504.0, 307.0], [473.0, 307.0]], [[438.0, 155.0], [465.0, 155.0], [465.0, 365.0], [438.0, 365.0]], [[400.0, 153.0], [429.0, 153.0], [429.0, 338.0], [400.0, 338.0]]], "lines": ["．．．んなもん", "最終的には", "受け入れるしか", "ねーだろ．．．"]}, {"box": [1102, 862, 1285, 1125], "vertical": true, "font_size": 33, "lines_coords": [[[1245.0, 862.0], [1283.0, 862.0], [1285.0, 994.0], [1247.0, 994.0]], [[1210.0, 864.0], [1245.0, 864.0], [1249.0, 1053.0], [1214.0, 1053.0]], [[1173.0, 864.0], [1208.0, 864.0], [1214.0, 1111.0], [1179.0, 1111.0]], [[1135.0, 864.0], [1171.0, 864.0], [1175.0, 1113.0], [1139.0, 1113.0]], [[1102.0, 866.0], [1131.0, 866.0], [1133.0, 1125.0], [1104.0, 1125.0]]], "lines": ["．．．だから", "いつ死んでも", "後悔しないように", "必死でがんばって", "きたんじゃないか。"]}, {"box": [847, 481, 990, 729], "vertical": true, "font_size": 29, "lines_coords": [[[959.0, 486.0], [988.0, 486.0], [988.0, 727.0], [959.0, 727.0]], [[921.0, 488.0], [950.0, 488.0], [950.0, 729.0], [921.0, 729.0]], [[882.0, 481.0], [911.0, 481.0], [913.0, 699.0], [884.0, 699.0]], [[847.0, 486.0], [876.0, 486.0], [876.0, 623.0], [847.0, 623.0]]], "lines": ["東京だって危ない", "かもしれないのに", "恐怖心鈍ってん", "だよソレ。"]}, {"box": [128, 529, 269, 713], "vertical": true, "font_size": 30, "lines_coords": [[[234.0, 529.0], [269.0, 529.0], [269.0, 654.0], [234.0, 654.0]], [[201.0, 531.0], [230.0, 531.0], [230.0, 712.0], [201.0, 712.0]], [[166.0, 531.0], [195.0, 531.0], [195.0, 685.0], [166.0, 685.0]], [[128.0, 529.0], [157.0, 529.0], [157.0, 683.0], [128.0, 683.0]]], "lines": ["．．．なのに", "その恐怖から", "逃げ続けて", "どうなる？"]}, {"box": [967, 1200, 1152, 1478], "vertical": true, "font_size": 33, "lines_coords": [[[1121.0, 1204.0], [1150.0, 1204.0], [1152.0, 1420.0], [1123.0, 1420.0]], [[1083.0, 1204.0], [1112.0, 1204.0], [1115.0, 1420.0], [1085.0, 1420.0]], [[1046.0, 1206.0], [1075.0, 1206.0], [1079.0, 1478.0], [1050.0, 1478.0]], [[1009.0, 1206.0], [1038.0, 1206.0], [1042.0, 1449.0], [1013.0, 1449.0]], [[967.0, 1202.0], [1011.0, 1200.0], [1015.0, 1289.0], [971.0, 1291.0]]], "lines": ["あんたみたいに", "平和な世の中に", "生かされてた奴とは", "根本から考え方が", "違う。"]}, {"box": [218, 1285, 382, 1559], "vertical": true, "font_size": 35, "lines_coords": [[[340.0, 1285.0], [375.0, 1285.0], [379.0, 1522.0], [344.0, 1522.0]], [[301.0, 1287.0], [336.0, 1287.0], [336.0, 1559.0], [301.0, 1559.0]], [[257.0, 1285.0], [292.0, 1285.0], [296.0, 1557.0], [261.0, 1557.0]], [[218.0, 1287.0], [253.0, 1287.0], [255.0, 1539.0], [220.0, 1539.0]]], "lines": ["放射能なんかに", "ぴびって逃げだす", "くらいなら東京と", "心中してやるよ。"]}, {"box": [1220, 1742, 1256, 1888], "vertical": true, "font_size": 38, "lines_coords": [[[1220.0, 1742.0], [1256.0, 1742.0], [1256.0, 1888.0], [1220.0, 1888.0]]], "lines": ["．．．ふうん"]}, {"box": [1023, 1819, 1148, 2056], "vertical": true, "font_size": 38, "lines_coords": [[[1108.0, 1819.0], [1144.0, 1819.0], [1148.0, 2023.0], [1112.0, 2023.0]], [[1069.0, 1821.0], [1104.0, 1821.0], [1104.0, 2056.0], [1069.0, 2056.0]], [[1023.0, 1819.0], [1069.0, 1819.0], [1069.0, 1940.0], [1023.0, 1940.0]]], "lines": ["がんばってる", "とか言うわりに", "アンタ、"]}, {"box": [166, 1782, 313, 2054], "vertical": true, "font_size": 30, "lines_coords": [[[280.0, 1784.0], [309.0, 1784.0], [309.0, 1962.0], [280.0, 1962.0]], [[238.0, 1782.0], [269.0, 1782.0], [272.0, 2054.0], [240.0, 2054.0]], [[205.0, 1784.0], [234.0, 1784.0], [234.0, 1994.0], [205.0, 1994.0]], [[166.0, 1782.0], [195.0, 1782.0], [197.0, 1996.0], [168.0, 1996.0]]], "lines": ["年明けに漫画", "ダメ出しされてから", "全然進んでない", "らしいじゃん？"]}], "img_path": "082.png"}, {"version": "0.2.0-beta.6", "img_width": 1439, "img_height": 2127, "blocks": [{"box": [1148, 170, 1291, 413], "vertical": true, "font_size": 31, "lines_coords": [[[1262.0, 174.0], [1291.0, 174.0], [1289.0, 388.0], [1260.0, 388.0]], [[1223.0, 172.0], [1252.0, 172.0], [1252.0, 357.0], [1223.0, 357.0]], [[1189.0, 172.0], [1218.0, 172.0], [1218.0, 413.0], [1189.0, 413.0]], [[1148.0, 170.0], [1185.0, 170.0], [1185.0, 297.0], [1148.0, 297.0]]], "lines": ["．．．正直アンタも", "小野寺くんも", "煮詰まってんじゃ", "ないの？"]}, {"box": [990, 398, 1133, 679], "vertical": true, "font_size": 31, "lines_coords": [[[1104.0, 407.0], [1133.0, 407.0], [1133.0, 629.0], [1104.0, 629.0]], [[1067.0, 405.0], [1098.0, 405.0], [1096.0, 679.0], [1065.0, 679.0]], [[1032.0, 405.0], [1061.0, 405.0], [1061.0, 616.0], [1032.0, 616.0]], [[990.0, 400.0], [1027.0, 398.0], [1032.0, 508.0], [994.0, 510.0]]], "lines": ["．．．そりゃそうか。", "アンタの目指してる", "漫画なんて特に", "そうだ。"]}, {"box": [1123, 893, 1231, 1140], "vertical": true, "font_size": 36, "lines_coords": [[[1191.0, 893.0], [1231.0, 893.0], [1231.0, 990.0], [1191.0, 990.0]], [[1156.0, 893.0], [1191.0, 893.0], [1191.0, 1140.0], [1156.0, 1140.0]], [[1123.0, 895.0], [1152.0, 895.0], [1152.0, 1107.0], [1123.0, 1107.0]]], "lines": ["時代は", "どんどん変わって", "いくんだから．．．"]}, {"box": [184, 427, 333, 687], "vertical": true, "font_size": 30, "lines_coords": [[[301.0, 429.0], [330.0, 429.0], [328.0, 616.0], [299.0, 616.0]], [[261.0, 427.0], [296.0, 427.0], [290.0, 681.0], [255.0, 681.0]], [[226.0, 429.0], [255.0, 429.0], [251.0, 677.0], [222.0, 677.0]], [[191.0, 429.0], [220.0, 429.0], [213.0, 687.0], [184.0, 687.0]]], "lines": ["平凡な日常で", "退屈を嘆くような", "空気みたいな漫画", "もう意味ないしね。"]}, {"box": [963, 1013, 1073, 1213], "vertical": true, "font_size": 36, "lines_coords": [[[1027.0, 1013.0], [1073.0, 1013.0], [1073.0, 1115.0], [1027.0, 1115.0]], [[996.0, 1015.0], [1032.0, 1015.0], [1032.0, 1142.0], [996.0, 1142.0]], [[963.0, 1015.0], [992.0, 1015.0], [992.0, 1213.0], [963.0, 1213.0]]], "lines": ["南条も", "いい加減", "変わりなって。"]}, {"box": [962, 1017, 1068, 1213], "vertical": true, "font_size": 106, "lines_coords": [[[962.0, 1017.0], [1068.0, 1017.0], [1068.0, 1213.0], [962.0, 1213.0]]], "lines": ["南条もいい加減変わりなって。"]}, {"box": [1164, 1377, 1235, 1609], "vertical": true, "font_size": 29, "lines_coords": [[[1206.0, 1379.0], [1235.0, 1379.0], [1235.0, 1576.0], [1206.0, 1576.0]], [[1164.0, 1377.0], [1193.0, 1377.0], [1193.0, 1609.0], [1164.0, 1609.0]]], "lines": ["この程度じゃ", "変わんねーよ！！"]}, {"box": [313, 1443, 415, 1630], "vertical": true, "font_size": 29, "lines_coords": [[[386.0, 1445.0], [415.0, 1445.0], [415.0, 1628.0], [386.0, 1628.0]], [[350.0, 1443.0], [379.0, 1443.0], [375.0, 1630.0], [346.0, 1630.0]], [[313.0, 1445.0], [342.0, 1445.0], [342.0, 1597.0], [313.0, 1597.0]]], "lines": ["数か月後まで", "今言った事を", "憶えとけ！！"]}, {"box": [980, 1659, 1154, 1933], "vertical": true, "font_size": 29, "lines_coords": [[[1125.0, 1663.0], [1154.0, 1663.0], [1154.0, 1846.0], [1125.0, 1846.0]], [[1088.0, 1661.0], [1119.0, 1661.0], [1115.0, 1846.0], [1083.0, 1846.0]], [[1050.0, 1659.0], [1081.0, 1659.0], [1079.0, 1933.0], [1048.0, 1933.0]], [[1015.0, 1663.0], [1044.0, 1663.0], [1044.0, 1900.0], [1015.0, 1900.0]], [[980.0, 1661.0], [1007.0, 1661.0], [1007.0, 1844.0], [980.0, 1844.0]]], "lines": ["さらに言えば", "仮に世の中が", "どうなったとしても", "お前こそ何ひとつ", "変わらない！！"]}, {"box": [157, 1694, 338, 1969], "vertical": true, "font_size": 29, "lines_coords": [[[309.0, 1697.0], [338.0, 1697.0], [334.0, 1969.0], [305.0, 1969.0]], [[272.0, 1694.0], [301.0, 1694.0], [296.0, 1967.0], [267.0, 1967.0]], [[234.0, 1697.0], [263.0, 1697.0], [263.0, 1967.0], [234.0, 1967.0]], [[197.0, 1697.0], [226.0, 1697.0], [226.0, 1935.0], [197.0, 1935.0]], [[159.0, 1694.0], [188.0, 1694.0], [186.0, 1935.0], [157.0, 1935.0]]], "lines": ["たった今苦しんでる", "どこかの誰かなんて", "微塵も考える事なく", "飯をモリモリ食う", "お前がいるから！！"]}], "img_path": "083.png"}, {"version": "0.2.0-beta.6", "img_width": 1437, "img_height": 2127, "blocks": [{"box": [668, 132, 759, 380], "vertical": true, "font_size": 40, "lines_coords": [[[718.0, 132.0], [755.0, 132.0], [755.0, 336.0], [718.0, 336.0]], [[668.0, 135.0], [710.0, 135.0], [710.0, 380.0], [668.0, 380.0]]], "lines": ["うっせーよ", "この不感症！！"]}, {"box": [450, 130, 490, 314], "vertical": true, "font_size": 38, "lines_coords": [[[450.0, 130.0], [487.0, 130.0], [490.0, 313.0], [452.0, 313.0]]], "lines": ["．．．いやいや、"]}, {"box": [1133, 567, 1275, 812], "vertical": true, "font_size": 32, "lines_coords": [[[1239.0, 567.0], [1275.0, 567.0], [1275.0, 695.0], [1239.0, 695.0]], [[1200.0, 567.0], [1235.0, 567.0], [1241.0, 785.0], [1206.0, 785.0]], [[1171.0, 571.0], [1200.0, 571.0], [1200.0, 812.0], [1171.0, 812.0]], [[1133.0, 569.0], [1162.0, 569.0], [1162.0, 706.0], [1133.0, 706.0]]], "lines": ["．．．おうよ", "かかって来いよ", "ブヒブヒ言わせて", "やるから。"]}, {"box": [1196, 928, 1281, 1100], "vertical": true, "font_size": 39, "lines_coords": [[[1241.0, 928.0], [1279.0, 928.0], [1281.0, 1100.0], [1243.0, 1100.0]], [[1196.0, 930.0], [1245.0, 930.0], [1245.0, 1015.0], [1196.0, 1015.0]]], "lines": ["．．．それより", "ホラ、"]}, {"box": [139, 585, 256, 789], "vertical": true, "font_size": 34, "lines_coords": [[[218.0, 585.0], [255.0, 585.0], [255.0, 724.0], [218.0, 724.0]], [[178.0, 589.0], [213.0, 589.0], [213.0, 789.0], [178.0, 789.0]], [[139.0, 587.0], [168.0, 587.0], [168.0, 739.0], [139.0, 739.0]]], "lines": ["どうでも", "いいじゃない", "そんな事。"]}, {"box": [1081, 1144, 1202, 1314], "vertical": true, "font_size": 39, "lines_coords": [[[1167.0, 1146.0], [1202.0, 1146.0], [1202.0, 1283.0], [1167.0, 1283.0]], [[1123.0, 1144.0], [1158.0, 1144.0], [1158.0, 1314.0], [1123.0, 1314.0]], [[1081.0, 1146.0], [1119.0, 1146.0], [1119.0, 1262.0], [1081.0, 1262.0]]], "lines": ["もうじき", "桜が満開に", "なるよ。"]}, {"box": [209, 1306, 332, 1545], "vertical": true, "font_size": 36, "lines_coords": [[[292.0, 1310.0], [328.0, 1310.0], [330.0, 1543.0], [294.0, 1543.0]], [[249.0, 1306.0], [286.0, 1306.0], [288.0, 1545.0], [251.0, 1545.0]], [[209.0, 1308.0], [245.0, 1308.0], [245.0, 1487.0], [209.0, 1487.0]]], "lines": ["みんなで仲良く", "花見でもしよう", "じゃないか。"]}, {"box": [1206, 1709, 1275, 1890], "vertical": true, "font_size": 34, "lines_coords": [[[1245.0, 1709.0], [1275.0, 1709.0], [1275.0, 1890.0], [1245.0, 1890.0]], [[1206.0, 1709.0], [1237.0, 1709.0], [1239.0, 1871.0], [1208.0, 1871.0]]], "lines": ["．．．あら奥さん", "素敵なお肉。"]}, {"box": [1069, 1867, 1179, 2004], "vertical": true, "font_size": 34, "lines_coords": [[[1144.0, 1867.0], [1179.0, 1867.0], [1179.0, 1994.0], [1144.0, 1994.0]], [[1106.0, 1867.0], [1144.0, 1867.0], [1144.0, 1994.0], [1106.0, 1994.0]], [[1069.0, 1869.0], [1104.0, 1869.0], [1104.0, 2004.0], [1069.0, 2004.0]]], "lines": ["肉感的で", "とっても", "セクシー。"]}, {"box": [546, 1715, 593, 1802], "vertical": true, "font_size": 37, "lines_coords": [[[546.0, 1715.0], [593.0, 1715.0], [593.0, 1802.0], [546.0, 1802.0]]], "lines": ["お顔。"]}, {"box": [555, 1719, 660, 1901], "vertical": true, "font_size": 29, "lines_coords": [[[627.0, 1719.0], [656.0, 1719.0], [656.0, 1869.0], [627.0, 1869.0]], [[589.0, 1721.0], [618.0, 1721.0], [618.0, 1898.0], [589.0, 1898.0]]], "lines": ["あなたこそ", "この人工的な"]}, {"box": [419, 1811, 523, 2070], "vertical": true, "font_size": 37, "lines_coords": [[[485.0, 1811.0], [523.0, 