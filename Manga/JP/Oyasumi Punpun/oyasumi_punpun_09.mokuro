s": [[[1252.0, 922.0], [1282.0, 922.0], [1279.0, 1136.0], [1250.0, 1136.0]], [[1217.0, 924.0], [1246.0, 924.0], [1246.0, 1196.0], [1217.0, 1196.0]], [[1178.0, 920.0], [1207.0, 920.0], [1209.0, 1225.0], [1180.0, 1225.0]], [[1142.0, 922.0], [1174.0, 922.0], [1174.0, 1015.0], [1142.0, 1015.0]]], "lines": ["：その部屋の事", "父さんのバタバタで", "後回しになっちゃって", "て．．．．．"]}, {"box": [1024, 1279, 1163, 1495], "vertical": true, "font_size": 29, "lines_coords": [[[1138.0, 1283.0], [1163.0, 1283.0], [1163.0, 1443.0], [1138.0, 1443.0]], [[1099.0, 1281.0], [1128.0, 1281.0], [1128.0, 1493.0], [1099.0, 1493.0]], [[1057.0, 1279.0], [1092.0, 1279.0], [1092.0, 1495.0], [1057.0, 1495.0]], [[1024.0, 1285.0], [1051.0, 1285.0], [1051.0, 1462.0], [1024.0, 1462.0]]], "lines": ["小野寺くん、", "先月いっぱいで", "契約期間過ぎて", "るんだわ．．．"]}, {"box": [357, 951, 459, 1208], "vertical": true, "font_size": 32, "lines_coords": [[[428.0, 951.0], [459.0, 951.0], [457.0, 1196.0], [425.0, 1196.0]], [[392.0, 953.0], [421.0, 953.0], [421.0, 1138.0], [392.0, 1138.0]], [[357.0, 955.0], [386.0, 955.0], [386.0, 1208.0], [357.0, 1208.0]]], "lines": ["．．．小野寺くんだし", "更新料もらう", "つもりはないけど、"]}, {"box": [241, 1256, 363, 1530], "vertical": true, "font_size": 32, "lines_coords": [[[328.0, 1258.0], [363.0, 1258.0], [363.0, 1460.0], [328.0, 1460.0]], [[284.0, 1258.0], [319.0, 1258.0], [319.0, 1530.0], [284.0, 1530.0]], [[241.0, 1256.0], [276.0, 1256.0], [276.0, 1524.0], [241.0, 1524.0]]], "lines": ["．．．どうする？", "このまま契約更新", "しちゃっていい？"]}, {"box": [851, 1699, 979, 1935], "vertical": true, "font_size": 35, "lines_coords": [[[945.0, 1699.0], [974.0, 1699.0], [974.0, 1900.0], [945.0, 1900.0]], [[901.0, 1703.0], [930.0, 1703.0], [930.0, 1933.0], [901.0, 1933.0]], [[851.0, 1699.0], [897.0, 1699.0], [897.0, 1819.0], [851.0, 1819.0]]], "lines": ["．．．フンフンは", "忘れていません", "でした。"]}, {"box": [529, 1700, 754, 2004], "vertical": true, "font_size": 35, "lines_coords": [[[716.0, 1701.0], [754.0, 1701.0], [754.0, 1807.0], [716.0, 1807.0]], [[675.0, 1701.0], [710.0, 1701.0], [