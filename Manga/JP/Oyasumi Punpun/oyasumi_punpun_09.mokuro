0], [261.0, 1113.0], [261.0, 1271.0], [226.0, 1271.0]]], "lines": ["声は急激な", "ストレスが原因だから", "じきに戻るみたい", "だけど．．．"]}, {"box": [1190, 1543, 1225, 1724], "vertical": true, "font_size": 30, "lines_coords": [[[1190.0, 1543.0], [1225.0, 1543.0], [1225.0, 1724.0], [1190.0, 1724.0]]], "lines": ["小野寺くん。"]}, {"box": [1038, 1778, 1177, 2018], "vertical": true, "font_size": 30, "lines_coords": [[[1148.0, 1778.0], [1177.0, 1778.0], [1177.0, 1956.0], [1148.0, 1956.0]], [[1111.0, 1778.0], [1140.0, 1778.0], [1140.0, 2018.0], [1111.0, 2018.0]], [[1073.0, 1778.0], [1102.0, 1778.0], [1102.0, 1985.0], [1073.0, 1985.0]], [[1038.0, 1778.0], [1065.0, 1778.0], [1065.0, 1987.0], [1038.0, 1987.0]]], "lines": ["もうウチじゃ", "給料払えないから", "他で仕事探して", "もらえるかな．．．"]}, {"box": [311, 1580, 450, 1819], "vertical": true, "font_size": 30, "lines_coords": [[[421.0, 1582.0], [450.0, 1582.0], [450.0, 1819.0], [421.0, 1819.0]], [[386.0, 1580.0], [415.0, 1580.0], [415.0, 1819.0], [386.0, 1819.0]], [[348.0, 1580.0], [377.0, 1580.0], [377.0, 1819.0], [348.0, 1819.0]], [[311.0, 1580.0], [340.0, 1580.0], [340.0, 1794.0], [311.0, 1794.0]]], "lines": ["長期で半身不随の", "リハビリができる", "病院に再入院する", "ことにしたから、"]}, {"box": [141, 1811, 315, 2027], "vertical": true, "font_size": 30, "lines_coords": [[[286.0, 1813.0], [315.0, 1813.0], [315.0, 1964.0], [286.0, 1964.0]], [[249.0, 1813.0], [278.0, 1813.0], [278.0, 1996.0], [249.0, 1996.0]], [[213.0, 1813.0], [242.0, 1813.0], [242.0, 1994.0], [213.0, 1994.0]], [[174.0, 1811.0], [209.0, 1811.0], [209.0, 2027.0], [174.0, 2027.0]], [[141.0, 1815.0], [170.0, 1815.0], [170.0, 1969.0], [141.0, 1969.0]]], "lines": ["．．．あたしも", "もしかしたら", "病院の近くで", "部屋借りるかも", "しれないし、"]}], "img_path": "175.png"}, {"version": "0.2.0-beta.6", "img_width": 1436, "img_height": 2127, "blocks": [{"box": [694, 114, 739, 240], "vertical": true, "font_size": 31, "lines_coords": [[[694.0, 114.0], [739.0, 114.0], [739.0, 240.0], [694.0, 240.0]]], "lines": ["．．．あの。"]}, {"box": [515, 216, 652, 488], "vertical": true, "font_size": 31,