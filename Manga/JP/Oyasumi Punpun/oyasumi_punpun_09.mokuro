{"version": "0.2.0-beta.6", "title": "Oyasumi Punpun", "title_uuid": "3ab9ef9e-749f-4288-b92e-ad9d6908bb1b", "volume": "oyasumi_punpun_09", "volume_uuid": "37909ebb-8eee-4051-8fd7-bd25c9d1f8f5", "pages": [{"version": "0.2.0-beta.6", "img_width": 6381, "img_height": 4233, "blocks": [{"box": [438, 330, 1579, 1565], "vertical": false, "font_size": 201, "lines_coords": [[[492.0, 436.0], [1127.0, 342.0], [1152.0, 542.0], [517.0, 635.0]]], "lines": ["「やすみ〜。"]}, {"box": [3115, 411, 3240, 2300], "vertical": true, "font_size": 125, "lines_coords": [[[3115.0, 411.0], [3240.0, 411.0], [3240.0, 2300.0], [3115.0, 2300.0]]], "lines": ["おやすみ。プンプンの「浅野い」お"]}, {"box": [128, 4068, 679, 4141], "vertical": false, "font_size": 80, "lines_coords": [[[128.0, 4061.0], [679.0, 4061.0], [679.0, 4148.0], [128.0, 4148.0]]], "lines": ["ＹｏｕｔｅｓｕｎＡｘｃｏｌｉｃｓ"]}, {"box": [3102, 168, 3286, 364], "vertical": false, "font_size": 215, "lines_coords": [[[3102.0, 149.0], [3286.0, 149.0], [3286.0, 383.0], [3102.0, 383.0]]], "lines": ["メニューとＹｏｕｔｕｂｏｏｋｉｏ！！"]}, {"box": [3634, 469, 4408, 582], "vertical": false, "font_size": 68, "lines_coords": [[[3664.0, 505.0], [4386.0, 505.0], [4386.0, 579.0], [3664.0, 579.0]]], "lines": ["Ｐ７８４０９１５１５２９２"]}, {"box": [4648, 423, 5047, 492], "vertical": false, "font_size": 69, "lines_coords": [[[4648.0, 423.0], [5047.0, 423.0], [5047.0, 492.0], [4648.0, 492.0]]], "lines": ["Ｃ９９７９＼５２４Ｅ"]}, {"box": [4636, 211, 5446, 305], "vertical": false, "font_size": 88, "lines_coords": [[[4636.0, 211.0], [5446.0, 218.0], [5446.0, 305.0], [4636.0, 299.0]]], "lines": ["ＩＳＢＡ９７８－４－４９９－１５「５２９－２"]}, {"box": [4642, 741, 5577, 847], "vertical": false, "font_size": 106, "lines_coords": [[[4642.0, 741.0], [5577.0, 741.0], [5577.0, 847.0], [4642.0, 847.0]]], "lines": ["定価：【本体５４円十税"]}, {"box": [4629, 897, 5527, 1016], "vertical": false, "font_size": 93.5, "lines_coords": [[[5103.0, 897.0], [5527.0, 910.0], [5527.0, 1016.0], [5103.0, 1003.0]], [[4629.0, 922.0], [5122.0, 922.0], [5122.0, 1003.0], [4629.0, 1003.0]]], "lines": ["９．小学館", "雑誌，４５３６５－２９"]}], "img_path": "001.png"}, {"version": "0.2.0-beta.6", "img_width": 6379, "img_height": 4236, "blocks": [{"box": [386, 199, 735, 242], "vertical": false, "font_size": 43, "lines_coords": [[[386.0, 199.0], [735.0, 199.0], [735.0, 242.0], [386.0, 242.0]]], "lines": ["。一番おもし"]}, {"box": [274, 460, 1787, 2828], "vertical": false, "font_size": 72, "lines_coords": [[[292.0, 504.0], [1183.0, 504.0], [1183.0, 579.0], [292.0, 579.0]], [[1376.0, 504.0], [1750.0, 504.0], [1750.0, 585.0], [1376.0, 585.0]], [[1364.0, 567.0], [1756.0, 579.0], [1756.0, 678.0], [1364.0, 666.0]], [[280.0, 585.0], [959.0, 585.0], [959.0, 678.0], [280.0, 678.0]], [[292.0, 679.0], [1158.0, 679.0], [1158.0, 753.0], [292.0, 753.0]], [[1451.0, 679.0], [1750.0, 679.0], [1750.0, 753.0], [1451.0, 753.0]], [[305.0, 766.0], [1108.0, 766.0], [1108.0, 840.0], [305.0, 840.0]], [[1326.0, 766.0], [1738.0, 766.0], [1738.0, 840.0], [1326.0, 840.0]], [[1382.0, 866.0], [1744.0, 866.0], [1744.0, 921.0], [1382.0, 921.0]], [[292.0, 859.0], [1258.0, 859.0], [1258.0, 934.0], [292.0, 934.0]], [[292.0, 947.0], [1744.0, 947.0], [1744.0, 1021.0], [292.0, 1021.0]], [[1358.0, 1034.0], [1744.0, 1034.0], [1744.0, 1108.0], [1358.0, 1108.0]], [[292.0, 1034.0], [1152.0, 1034.0], [1152.0, 1108.0], [292.0, 1108.0]], [[292.0, 1121.0], [1750.0, 1121.0], [1750.0, 1195.0], [292.0, 1195.0]], [[1264.0, 1208.0], [1750.0, 1208.0], [1750.0, 1283.0], [1264.0, 1283.0]], [[292.0, 1208.0], [797.0, 1202.0], [797.0, 1283.0], [292.0, 1289.0]], [[299.0, 1289.0], [1750.0, 1289.0], [1750.0, 1382.0], [299.0, 1382.0]], [[286.0, 1376.0], [1750.0, 1376.0], [1750.0, 1469.0], [286.0, 1469.0]], [[292.0, 1476.0], [1738.0, 1476.0], [1738.0, 1550.0], [292.0, 1550.0]], [[292.0, 1563.0], [1102.0, 1563.0], [1102.0, 1638.0], [292.0, 1638.0]], [[1563.0, 1563.0], [1744.0, 1563.0], [1744.0, 1638.0], [1563.0, 1638.0]], [[286.0, 1651.0], [1744.0, 1651.0], [1744.0, 1725.0], [286.0, 1725.0]], [[286.0, 1732.0], [1750.0, 1732.0], [1750.0, 1824.0], [286.0, 1824.0]], [[292.0, 1831.0], [1744.0, 1831.0], [1744.0, 1905.0], [292.0, 1905.0]], [[1420.0, 1918.0], [1750.0, 1906.0], [1750.0, 1986.0], [1420.0, 1999.0]], [[292.0, 1918.0], [1146.0, 1918.0], [1146.0, 1993.0], [292.0, 1993.0]], [[280.0, 2006.0], [1750.0, 2006.0], [1750.0, 2080.0], [280.0, 2080.0]], [[292.0, 2093.0], [1071.0, 2093.0], [1071.0, 2167.0], [292.0, 2167.0]], [[1420.0, 2093.0], [1744.0, 2093.0], [1744.0, 2167.0], [1420.0, 2167.0]], [[280.0, 2174.0], [1139.0, 2180.0], [1139.0, 2261.0], [280.0, 2254.0]], [[1171.0, 2174.0], [1750.0, 2174.0], [1750.0, 2267.0], [1171.0, 2267.0]], [[292.0, 2273.0], [1738.0, 2273.0], [1738.0, 2348.0], [292.0, 2348.0]], [[1426.0, 2361.0], [1738.0, 2361.0], [1738.0, 2435.0], [1426.0, 2435.0]], [[299.0, 2361.0], [847.0, 2361.0], [847.0, 2435.0], [299.0, 2435.0]], [[1488.0, 2448.0], [1738.0, 2448.0], [1738.0, 2522.0], [1488.0, 2522.0]], [[299.0, 2448.0], [1127.0, 2448.0], [1127.0, 2522.0], [299.0, 2522.0]], [[286.0, 2535.0], [1650.0, 2535.0], [1650.0, 2609.0], [286.0, 2609.0]], [[286.0, 2622.0], [1744.0, 2622.0], [1744.0, 2697.0], [286.0, 2697.0]], [[1426.0, 2697.0], [1744.0, 2697.0], [1744.0, 2778.0], [1426.0, 2778.0]], [[299.0, 2703.0], [928.0, 2703.0], [928.0, 2778.0], [299.0, 2778.0]]], "lines": ["おやすみプンプン１〜９巻ー", "一浅野いにお", "まあいいこの浅野いにお", "ソラニン・全２巻ーーー", "ほしのふるまち、全７巻ーー", "ここの原秀則", "１ポンドの福音、全４巻ーーー", "ーー高橋留美子", "ーーー山田貴敬", "Ｄｒコトー診療所１〜２５巻ーーー", "ＦＡＮＥＯＷ二舎ホ開のヒル－全Ｐ巻ー安部譲二ノ柿崎正澄", "一ゆうぎまさみ", "鉄腕バーディー全２０巻ーーー", "都立水商！金曜巻ー一室積光ノ猪熊しのぷ", "一黒丸ノ夏原・武", "クロサギ、全２０巻", "イキガミーＴｉｅＵＪｉｎｄｉｎａｔｅｌｉｎｔ－１〜日巻一問瀬元朗", "土竜（モグラ）の唄・１～３０巻こちらは、高橋のぼる", "超無気力戦隊ジャパファイブ全日巻一佐藤まさき", "Ｏｎｄｉｏｎｅオッズ－＋１巻ーー", "石渡治", "さくらんぼシンドロームク１９６の悪助に全１１巻一北崎拓", "タナトスむけらの第一全日巻竹原慎二ノ落合裕介", "とめはねっ！－鈴里読教書道部－１〜日巻一河合克敏", "一森尾正博", "ビーチスターズ・全７巻ーー", "まっそれはその力が決まっ全日巻ー－木根ヲサムノ恒川光太郎", "美晴♥ライジング〈全５巻", "大谷じろう", "«時のイージス、全Ｇ巻ーーー", "七月鏡一ノ藤原芳秀！！", "あんころ。お橋おいて目は馬鹿も全５巻ーー万乗大智", "ー秋重学", "ＧＯ－ＯＮ！全４巻", "中井邦彦", "ドライブ・ティブ・全日巻", "また、スマートセングサンデー「コミックスペシャル」で", "絶望に効くクスリトＯＮＥＯＮＹＯＥ年金１５巻一山田玲司。", "長尾謙一郎", "おしゃれ手帖、全５巻"]}, {"box": [299, 2834, 1727, 3059], "vertical": false, "font_size": 68, "lines_coords": [[[348.0, 2828.0], [1657.0, 2828.0], [1657.0, 2902.0], [348.0, 2902.0]], [[330.0, 2903.0], [1669.0, 2903.0], [1669.0, 2977.0], [330.0, 2977.0]], [[323.0, 2971.0], [1588.0, 2971.0], [1588.0, 3045.0], [323.0, 3045.0]]], "lines": ["ｈｔｔｐ：／／ｅｏｍｉｃｓ．ｓｈｏｇａｋｕｋａｎ．ｃｏｊｐ／", "にアクセスすると、コミックス情報が詳しくわかり、キーヒー", "オンラインショップで購入することもできます。"]}, {"box": [459, 3239, 1612, 3809], "vertical": false, "font_size": 72, "lines_coords": [[[791.0, 3233.0], [1252.0, 3245.0], [1252.0, 3344.0], [791.0, 3332.0]], [[647.0, 3376.0], [1414.0, 3376.0], [1414.0, 3450.0], [647.0, 3450.0]], [[485.0, 3438.0], [1588.0, 3445.0], [1588.0, 3519.0], [485.0, 3513.0]], [[629.0, 3519.0], [1426.0, 3519.0], [1426.0, 3594.0], [629.0, 3594.0]], [[504.0, 3588.0], [1557.0, 3588.0], [1557.0, 3662.0], [504.0, 3662.0]], [[591.0, 3656.0], [1445.0, 3656.0], [1445.0, 3731.0], [591.0, 3731.0]], [[498.0, 3731.0], [1576.0, 3731.0], [1576.0, 3805.0], [498.0, 3805.0]]], "lines": ["浅野いにお", "１９８０年生まれ。茨城県出身。", "２００１３００４年１１回サンテー城宗山ヲ。ＧＸ新人賞入賞。", "「中、菊・自分の人物への主な著作に『素晴らしい世界』というわけではないが、", "『ひかりの言いに「茶隅」『ひがりのまち』ともに小社刊がある。", "カウンのようなこといいわね。『ソラニン』（全２巻っ小社利）が、", "全国より世代・性別を超うーんいい、えた大反響作に。"]}, {"box": [375, 4089, 1637, 4183], "vertical": false, "font_size": 103, "lines_coords": [[[375.0, 4080.0], [1637.0, 4080.0], [1637.0, 4192.0], [375.0, 4192.0]]], "lines": ["イラス・準備はオーディングスクリックスンが"]}], "img_path": "002.png"}, {"version": "0.2.0-beta.6", "img_width": 3198, "img_height": 798, "blocks": [{"box": [2991, 130, 3169, 657], "vertical": true, "font_size": 42, "lines_coords": [[[3129.0, 137.0], [3160.0, 137.0], [3160.0, 579.0], [3129.0, 579.0]], [[3057.0, 137.0], [3098.0, 137.0], [3101.0, 554.0], [3060.0, 554.0]], [[2991.0, 130.0], [3044.0, 130.0], [3044.0, 657.0], [2991.0, 657.0]]], "lines": ["あなたが思っている以上に", "世の中のほとんどの人は、", "あなたのことなんかに興味が"]}, {"box": [2667, 3, 2963, 564], "vertical": true, "font_size": 65, "lines_coords": [[[2879.0, 81.0], [2945.0, 77.0], [2963.0, 561.0], [2898.0, 564.0]], [[2835.0, 121.0], [2888.0, 118.0], [2898.0, 339.0], [2845.0, 342.0]], [[2773.0, 74.0], [2851.0, 77.0], [2838.0, 542.0], [2760.0, 539.0]], [[2667.0, 12.0], [2729.0, 12.0], [2729.0, 339.0], [2667.0, 339.0]]], "lines": ["「凡な日常", "手を繋ぐこと", "屈を嘆く", "ような"]}, {"box": [2426, 81, 2635, 573], "vertical": true, "font_size": 91.0, "lines_coords": [[[2535.0, 84.0], [2623.0, 81.0], [2635.0, 567.0], [2548.0, 570.0]], [[2432.0, 102.0], [2526.0, 102.0], [2520.0, 573.0], [2426.0, 573.0]]], "lines": ["うたいな漫画", "う意味な"]}, {"box": [1754, 56, 1934, 726], "vertical": true, "font_size": 44, "lines_coords": [[[1886.0, 59.0], [1930.0, 59.0], [1930.0, 635.0], [1886.0, 635.0]], [[1820.0, 59.0], [1864.0, 59.0], [1864.0, 723.0], [1820.0, 723.0]], [[1758.0, 62.0], [1801.0, 62.0], [1801.0, 533.0], [1758.0, 533.0]]], "lines": ["哀と絶望と僅かなる希望。", "同時代を生きる少年・プンプンの", "成長議・震撼の最新章。"]}, {"box": [2229, 168, 2417, 741], "vertical": true, "font_size": 50.0, "lines_coords": [[[2361.0, 168.0], [2414.0, 168.0], [2417.0, 741.0], [2364.0, 741.0]], [[2298.0, 193.0], [2342.0, 193.0], [2342.0, 741.0], [2298.0, 741.0]], [[2229.0, 190.0], [2282.0, 190.0], [2292.0, 735.0], [2239.0, 735.0]]], "lines": ["今日みたいにとるに足らない", "平穏な日が、毎日毎日いつま", "でも続けばいいと思ってる。"]}, {"box": [2663, 620, 2954, 651], "vertical": false, "font_size": 31, "lines_coords": [[[2663.0, 620.0], [2954.0, 620.0], [2954.0, 651.0], [2663.0, 651.0]]], "lines": ["だって生で買えない"]}, {"box": [2529, 657, 3098, 713], "vertical": false, "font_size": 50, "lines_coords": [[[2529.0, 657.0], [3098.0, 663.0], [3098.0, 713.0], [2529.0, 707.0]]], "lines": ["くらいの時にあった時というのは、"]}, {"box": [2585, 723, 3082, 763], "vertical": false, "font_size": 34, "lines_coords": [[[2585.0, 729.0], [3082.0, 723.0], [3082.0, 757.0], [2585.0, 763.0]]], "lines": ["そう思われないじゃないですか。"]}, {"box": [1524, 74, 1657, 670], "vertical": true, "font_size": 60, "lines_coords": [[[1608.0, 190.0], [1652.0, 190.0], [1652.0, 645.0], [1608.0, 645.0]], [[1539.0, 74.0], [1614.0, 74.0], [1599.0, 651.0], [1524.0, 651.0]]], "lines": ["大人気御礼！！", "ここで、累計一万部突破！！"]}, {"box": [1389, 27, 1482, 763], "vertical": true, "font_size": 88, "lines_coords": [[[1389.0, 99.0], [1477.0, 99.0], [1477.0, 757.0], [1389.0, 757.0]]], "lines": ["これゆく日常と"]}, {"box": [1049, 121, 1351, 627], "vertical": true, "font_size": 41, "lines_coords": [[[1305.0, 124.0], [1346.0, 124.0], [1346.0, 492.0], [1305.0, 492.0]], [[1239.0, 127.0], [1280.0, 127.0], [1280.0, 545.0], [1239.0, 545.0]], [[1174.0, 121.0], [1217.0, 121.0], [1214.0, 620.0], [1171.0, 620.0]], [[1108.0, 124.0], [1152.0, 124.0], [1152.0, 299.0], [1108.0, 299.0]], [[1049.0, 130.0], [1083.0, 130.0], [1083.0, 311.0], [1049.0, 311.0]]], "lines": ["幸との出会いによって、", "ようやく自分の居場所を", "見つけたかに思えたブンブン。", "そんな時、", "ある事件が"]}, {"box": [41, 6, 145, 686], "vertical": true, "font_size": 88, "lines_coords": [[[46.0, 134.0], [134.0, 134.0], [134.0, 673.0], [46.0, 673.0]]], "lines": ["世界の胎動"]}], "img_path": "003.png"}, {"version": "0.2.0-beta.6", "img_width": 3214, "img_height": 794, "blocks": [{"box": [75, 47, 376, 91], "vertical": false, "font_size": 44, "lines_coords": [[[75.0, 47.0], [376.0, 47.0], [376.0, 91.0], [75.0, 91.0]]], "lines": ["プンプン？"]}, {"box": [374, 551, 863, 714], "vertical": false, "font_size": 58, "lines_coords": [[[637.0, 566.0], [834.0, 566.0], [834.0, 629.0], [637.0, 629.0]]], "lines": ["お前が"]}], "img_path": "004.png"}, {"version": "0.2.0-beta.6", "img_width": 1436, "img_height": 2127, "blocks": [{"box": [1280, 306, 1326, 703], "vertical": true, "font_size": 35, "lines_coords": [[[1282.0, 307.0], [1317.0, 307.0], [1319.0, 687.0], [1284.0, 687.0]]], "lines": ["おやすみプンプン＠"]}, {"box": [64, 141, 417, 2016], "vertical": true, "font_size": 35.666666666666664, "lines_coords": [[[388.0, 145.0], [417.0, 145.0], [417.0, 2008.0], [388.0, 2008.0]], [[320.0, 143.0], [357.0, 143.0], [359.0, 2014.0], [322.0, 2014.0]], [[259.0, 143.0], [295.0, 143.0], [295.0, 2016.0], [259.0, 2016.0]], [[195.0, 143.0], [230.0, 143.0], [230.0, 2014.0], [195.0, 2014.0]], [[124.0, 141.0], [166.0, 141.0], [168.0, 2014.0], [126.0, 2014.0]], [[64.0, 141.0], [99.0, 141.0], [103.0, 2012.0], [68.0, 2012.0]]], "lines": ["は、いたたまれなくなり、見るとただ泥酔しているだけのようである。茶髪に少しずフトイレが覚醒してゆ", "く。何かが投函される音。一瞬ドキリとするが、声が鼓膜で電気信号に変換され、ようやく薄目を開けると", "素人そっくりさんコンテストの決意などその程度なのだということだ。愚鈍そうな可愛らしいうんこのよう", "な肩をつかみ裾という裾か、ち色んな毛をはみださせ、その様に一瞬死んでいるのかと思いバイトもそろそろ", "潮時かもしれないと思った。脳で襲うわれ初者の腹痛にとんが０ブーツ、トキドキしながら近づくが、「処女", "乱れ喰い」という言葉を「ブゴッ」と鳴らしてしまった。何かが投函される音。永久機関にどうやら１２時間"]}, {"box": [455, 139, 868, 2014], "vertical": true, "font_size": 33.42857142857143, "lines_coords": [[[839.0, 145.0], [868.0, 145.0], [868.0, 2010.0], [839.0, 2010.0]], [[773.0, 141.0], [808.0, 141.0], [808.0, 2014.0], [773.0, 2014.0]], [[708.0, 141.0], [743.0, 141.0], [743.0, 2014.0], [708.0, 2014.0]], [[642.0, 143.0], [677.0, 143.0], [679.0, 2012.0], [644.0, 2012.0]], [[577.0, 139.0], [613.0, 139.0], [617.0, 2014.0], [581.0, 2014.0]], [[513.0, 141.0], [548.0, 141.0], [550.0, 2014.0], [515.0, 2014.0]], [[455.0, 145.0], [484.0, 145.0], [484.0, 2012.0], [455.0, 2012.0]]], "lines": ["の尿を毎月毎月目分はいっそ本当に殺してしまえば良かったんじゃないかと思ったが、「丸顔の店員と付き", "合って奇跡が甘いパンを食べながら忙しすぎるし、何もしないと退屈すぎる。本を手にレジへ向かうと脳盤", "が飛び出るまで頭を「気にしないで全然大丈夫だから」と自分は目一杯の軽蔑の意を込めた。ぴくりともし", "ないその様にシナプスを伝い五日以内に延滞料金を振り込まないと自分の尿を飲みみ、飲みかけの尿を飲む永", "久機関についてドアの郵便受けに何度も何度や何度も殴りつける自分を妄想するが、勿論甘いパンを食べな", "がら国道へ探しにいったがもうその姿はなかった。アパートに戻って数時間後、お昼の顔である某司会者の", "別次元の未来人達の尿を排泄し、またその尿を飲む店員の知顔丸眼鏡の見るからに自然、する勇気があるなら"]}, {"box": [897, 137, 1197, 2018], "vertical": true, "font_size": 38.2, "lines_coords": [[[1151.0, 178.0], [1192.0, 178.0], [1197.0, 2018.0], [1155.0, 2018.0]], [[1086.0, 137.0], [1128.0, 137.0], [1132.0, 2016.0], [1091.0, 2016.0]], [[1028.0, 143.0], [1064.0, 143.0], [1064.0, 2012.0], [1028.0, 2012.0]], [[966.0, 145.0], [1001.0, 145.0], [1001.0, 2010.0], [966.0, 2010.0]], [[897.0, 141.0], [933.0, 141.0], [937.0, 2018.0], [901.0, 2018.0]]], "lines": ["何かが投函される音。一瞬ドキリとするが乾いた喉を潤そうとテーブルに目をやる、だから僕はずっと", "準備していた。どうやらドアノブを使ったものが都合が良さそうだ。セックスするまでの過程を想像する", "が、キャッキャウフフが開てこえ、バイト帰り、国道浴いの歩道の植え込みに処女喰いが急におおかた公共料", "金の請求書であろう。それ以外で自分に用のある人間なんて１０回くらい起きないとどうにもならなそうだっ", "た。丸顔の店員と付き合って奇跡が舌打ちを放ってその場を後にした。さっきの愚鈍そうな可愛らしい自分"]}, {"box": [1283, 1663, 1321, 1870], "vertical": true, "font_size": 29, "lines_coords": [[[1286.0, 1667.0], [1315.0, 1667.0], [1315.0, 1867.0], [1286.0, 1867.0]]], "lines": ["浅野いにお"]}], "img_path": "005.png"}, {"version": "0.2.0-beta.6", "img_width": 1435, "img_height": 2126, "blocks": [{"box": [114, 128, 1374, 2013], "vertical": true, "font_size": 36.15, "lines_coords": [[[1337.0, 139.0], [1374.0, 139.0], [1366.0, 2013.0], [1329.0, 2013.0]], [[1275.0, 139.0], [1310.0, 139.0], [1300.0, 2011.0], [1264.0, 2011.0]], [[1210.0, 141.0], [1248.0, 141.0], [1237.0, 2013.0], [1200.0, 2013.0]], [[1148.0, 141.0], [1183.0, 141.0], [1171.0, 2011.0], [1135.0, 2011.0]], [[1079.0, 137.0], [1115.0, 137.0], [1106.0, 2011.0], [1071.0, 2011.0]], [[1015.0, 143.0], [1050.0, 143.0], [1042.0, 2009.0], [1007.0, 2009.0]], [[953.0, 137.0], [988.0, 137.0], [978.0, 2009.0], [942.0, 2009.0]], [[888.0, 137.0], [924.0, 137.0], [913.0, 2009.0], [878.0, 2009.0]], [[826.0, 139.0], [861.0, 139.0], [851.0, 2011.0], [816.0, 2011.0]], [[762.0, 134.0], [797.0, 134.0], [787.0, 2009.0], [751.0, 2009.0]], [[697.0, 134.0], [730.0, 134.0], [720.0, 2007.0], [687.0, 2007.0]], [[633.0, 134.0], [668.0, 134.0], [660.0, 2009.0], [625.0, 2009.0]], [[573.0, 137.0], [602.0, 137.0], [591.0, 2003.0], [562.0, 2003.0]], [[506.0, 134.0], [542.0, 134.0], [531.0, 1947.0], [496.0, 1947.0]], [[444.0, 134.0], [473.0, 134.0], [465.0, 2003.0], [436.0, 2003.0]], [[375.0, 132.0], [413.0, 132.0], [402.0, 2005.0], [365.0, 2005.0]], [[313.0, 134.0], [348.0, 134.0], [338.0, 1999.0], [303.0, 1999.0]], [[247.0, 130.0], [288.0, 130.0], [278.0, 2001.0], [236.0, 2001.0]], [[180.0, 128.0], [222.0, 128.0], [213.0, 2003.0], [172.0, 2003.0]], [[116.0, 128.0], [159.0, 128.0], [157.0, 1164.0], [114.0, 1164.0]]], "lines": ["近く眠ってしまったらしいのは電気が止まる旨がつまり所詮自分の本を買わずに大外刈りで床を這わせた", "後、１０回ほど呪文のように繰り返し激しく動揺し、バイトの後輩にプタ鼻を直後に白いシャツからのぞくと", "んがりプーツ、さっきの男性あのような風貌の公園にて、人暮らしは自殺の指南書を何度も実行する勇気はな", "い。なぜこの程度のことまで何かをしようとすると缶コーヒーが人気のお笑いタレントの冗談で起きること", "を明らかに体が拒んでいるが、、素人そっくりさんコンテストの元ネタの割れた腹筋警定まらない視線のまま", "一瞬ちらつかせた後輩達のこのバイトもそろそろ潮時がもしれないと思った。一瞬ドキリとするが、既に定", "量が後回しにしてしまうのが。合コンのハフハフとご最終的に排泄していると事務室から面倒そうなテレビの", "中の有名人の指南書を立ち読みみする。バイトの前にチヤラチャラとした風貌を振り込まないと５月の丁度良", "い勇気を振り絞り埋まってしまったらしくハフハフと動悸が止まず男性のような風貌の世界の出来事よう", "だ。男性客に怒鳴りつけら礼結局店を見事な後輩の面倒そうな表情に大丈夫なのがわからないが、うんこを", "申し込むが、びくりともしないその連想を湧くやりとりは、遠い遠い世界の永久機関について並んでいる方が", "けだった。五日以内に心配になり合コンの参加を自分はなにがどう涙ぐんでおり、なぜか自分まで延滞料金", "を記されていたが、請求書にはあとバイトこの前に考えにそえ、なぜか自分まで泣きそうになってしまう。お", "もむろに後ろからその人間なんてこの世にはいないのだから。腐った考察をしていると、気候のせいか。", "うやく薄目を開けるとうんこのような顔がわからないと言う罠。まるで会話のように出来事のようだ。有名", "人のそれ以外で自分に用のある愚鈍そうな初者の女の子が涙ぐんでおり、可愛らしい風貌の書店でいたたま", "れなくなり、肩をつかみ出てしまった。何かが投函される音。一瞬ドキリとするが、バイトの後輩にトイレ", "『が覚醒してゆくコンテストのとんがりセックス。ドアノプを飲み、缶コＩヒＩがシナプスのようにそっくり", "さん、腹痛に電気信号で丸顔の店員とセックス。素人のセッタス。大外刈りで床を這わせた後セックス。ホ", "久にセックス。何かが投函される音。一瞬ドキリとするが。"]}, {"box": [498, 1937, 529, 2001], "vertical": true, "font_size": 25, "lines_coords": [[[498.0, 1939.0], [523.0, 1937.0], [529.0, 1999.0], [504.0, 2001.0]]], "lines": ["と"]}], "img_path": "006.png"}, {"version": "0.2.0-beta.6", "img_width": 1429, "img_height": 2123, "blocks": [], "img_path": "007.png"}, {"version": "0.2.0-beta.6", "img_width": 1438, "img_height": 2127, "blocks": [{"box": [552, 618, 706, 772], "vertical": false, "font_size": 50, "lines_coords": [[[552.0, 737.0], [671.0, 618.0], [706.0, 654.0], [588.0, 772.0]]], "lines": ["「コンクは"]}, {"box": [112, 1984, 386, 2015], "vertical": false, "font_size": 23, "lines_coords": [[[118.0, 1985.0], [378.0, 1987.0], [378.0, 2012.0], [118.0, 2010.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹＣＯＭＣＳ"]}], "img_path": "008.png"}, {"version": "0.2.0-beta.6", "img_width": 1431, "img_height": 2127, "blocks": [{"box": [1123, 330, 1304, 656], "vertical": true, "font_size": 65, "lines_coords": [[[1258.0, 371.0], [1304.0, 371.0], [1304.0, 517.0], [1258.0, 517.0]], [[1198.0, 330.0], [1242.0, 330.0], [1242.0, 656.0], [1198.0, 656.0]], [[1123.0, 382.0], [1192.0, 369.0], [1198.0, 407.0], [1129.0, 419.0]]], "lines": ["１４１１６３", "一話、話し話を話してきた。", "９６"]}, {"box": [1075, 292, 1244, 654], "vertical": true, "font_size": 65, "lines_coords": [[[1115.0, 292.0], [1244.0, 292.0], [1244.0, 344.0], [1115.0, 344.0]], [[1075.0, 294.0], [1111.0, 294.0], [1111.0, 654.0], [1075.0, 654.0]]], "lines": ["９５話", "第２０１８第１第１２第１３第１１第２６回第２３回第１８回第３０回第第１９条第第２第２８条第１６条第７第第第３第２２第３１第第６第１５第２１第３６第２９第２５第１０第２４第２項の第３２第一第２の第２条第２７第３項第３３第３条第３号の第１項第２号第１４第１７第２回第７６第３８２第二第１の第一策・第１号第３７第１発表第１"]}, {"box": [999, 442, 1190, 577], "vertical": true, "font_size": 65, "lines_coords": [[[1129.0, 525.0], [1190.0, 525.0], [1190.0, 577.0], [1129.0, 577.0]], [[999.0, 442.0], [1021.0, 442.0], [1021.0, 494.0], [999.0, 494.0]]], "lines": ["９８", "５３"]}, {"box": [762, 122, 1115, 652], "vertical": true, "font_size": 65, "lines_coords": [[[839.0, 284.0], [928.0, 284.0], [928.0, 508.0], [839.0, 508.0]], [[799.0, 211.0], [843.0, 211.0], [834.0, 652.0], [791.0, 652.0]], [[762.0, 189.0], [978.0, 122.0], [1115.0, 581.0], [899.0, 645.0]]], "lines": ["９０９１９２", "目第第１第１２第１３第１１第３１回第１６回第３回", "２０１７年００１年１９７３年０９月１６日"]}, {"box": [238, 155, 550, 255], "vertical": false, "font_size": 29.0, "lines_coords": [[[253.0, 155.0], [475.0, 155.0], [475.0, 184.0], [253.0, 184.0]], [[238.0, 195.0], [550.0, 193.0], [550.0, 222.0], [238.0, 224.0]], [[238.0, 224.0], [454.0, 226.0], [454.0, 255.0], [238.0, 253.0]]], "lines": ["小野寺プンプン", "とるに足らない、やり逃げ男。", "このニューン食・フリーター。２０歳。"]}, {"box": [128, 87, 301, 126], "vertical": false, "font_size": 37, "lines_coords": [[[128.0, 89.0], [301.0, 87.0], [301.0, 124.0], [128.0, 126.0]]], "lines": ["登場人物"]}, {"box": [224, 305, 555, 402], "vertical": false, "font_size": 28, "lines_coords": [[[257.0, 305.0], [351.0, 305.0], [351.0, 334.0], [257.0, 334.0]], [[255.0, 344.0], [548.0, 344.0], [548.0, 371.0], [255.0, 371.0]], [[224.0, 375.0], [421.0, 375.0], [421.0, 402.0], [224.0, 402.0]]], "lines": ["．．．", "漫画家を目指す強がり女", "塾講師。２４歳。"]}, {"box": [224, 450, 448, 552], "vertical": false, "font_size": 31.0, "lines_coords": [[[224.0, 450.0], [421.0, 450.0], [421.0, 479.0], [224.0, 479.0]], [[224.0, 488.0], [448.0, 488.0], [448.0, 517.0], [224.0, 517.0]], [[224.0, 517.0], [346.0, 517.0], [346.0, 552.0], [224.0, 552.0]]], "lines": ["３三村雪之進", "いなせな若大将。", "大学生。"]}, {"box": [994, 600, 1194, 652], "vertical": true, "font_size": 65, "lines_coords": [[[1129.0, 608.0], [1194.0, 608.0], [1194.0, 652.0], [1129.0, 652.0]], [[994.0, 600.0], [1026.0, 600.0], [1026.0, 650.0], [994.0, 650.0]]], "lines": ["９９", "９３"]}, {"box": [884, 409, 965, 656], "vertical": true, "font_size": 65, "lines_coords": [[[884.0, 409.0], [905.0, 409.0], [905.0, 492.0], [884.0, 492.0]], [[928.0, 571.0], [965.0, 571.0], [965.0, 656.0], [928.0, 656.0]]], "lines": ["・２", "「話"]}, {"box": [658, 795, 1030, 830], "vertical": false, "font_size": 29, "lines_coords": [[[658.0, 795.0], [1030.0, 795.0], [1030.0, 830.0], [658.0, 830.0]]], "lines": ["８巻までのあらすじ"]}, {"box": [662, 862, 1175, 1113], "vertical": false, "font_size": 29, "lines_coords": [[[662.0, 862.0], [1023.0, 862.0], [1023.0, 889.0], [662.0, 889.0]], [[664.0, 905.0], [1142.0, 905.0], [1142.0, 934.0], [664.0, 934.0]], [[666.0, 953.0], [1175.0, 953.0], [1175.0, 980.0], [666.0, 980.0]], [[662.0, 992.0], [1154.0, 997.0], [1154.0, 1026.0], [662.0, 1021.0]], [[662.0, 1040.0], [978.0, 1040.0], [978.0, 1067.0], [662.0, 1067.0]], [[664.0, 1086.0], [1161.0, 1086.0], [1161.0, 1113.0], [664.0, 1113.0]]], "lines": ["擦った揉んだ入れた出したの末", "やり逃げ黒チンポと化した小野寺ブンブン", "友達以上恋人未満の中途半端な関係のまま", "プンプンと幸の共同作業の漫画は完成した", "そして年が明け１月、二人は", "カニ歩きで出版社へ原稿を持ち込みに行く。"]}, {"box": [257, 596, 467, 691], "vertical": false, "font_size": 26.333333333333332, "lines_coords": [[[257.0, 596.0], [388.0, 596.0], [388.0, 625.0], [257.0, 625.0]], [[259.0, 635.0], [411.0, 635.0], [411.0, 658.0], [259.0, 658.0]], [[257.0, 664.0], [467.0, 664.0], [467.0, 691.0], [257.0, 691.0]]], "lines": ["蟹江美雪", "ふとめ座の女。", "幸の同級生。人妻。"]}, {"box": [229, 745, 539, 813], "vertical": false, "font_size": 25, "lines_coords": [[[259.0, 745.0], [386.0, 745.0], [386.0, 768.0], [259.0, 768.0]], [[257.0, 781.0], [529.0, 781.0], [529.0, 808.0], [257.0, 808.0]]], "lines": ["黒戸型の", "老人。宍戸不動産社長。"]}, {"box": [246, 886, 459, 985], "vertical": false, "font_size": 27, "lines_coords": [[[261.0, 886.0], [355.0, 886.0], [355.0, 918.0], [261.0, 918.0]], [[261.0, 928.0], [452.0, 926.0], [452.0, 953.0], [261.0, 955.0]], [[261.0, 959.0], [386.0, 959.0], [386.0, 982.0], [261.0, 982.0]]], "lines": ["関真通", "自由をはき違えた", "やさぐれ男。"]}, {"box": [739, 1177, 1065, 1277], "vertical": false, "font_size": 27.666666666666668, "lines_coords": [[[739.0, 1177.0], [1065.0, 1177.0], [1065.0, 1204.0], [739.0, 1204.0]], [[739.0, 1217.0], [1057.0, 1217.0], [1057.0, 1244.0], [739.0, 1244.0]], [[743.0, 1248.0], [888.0, 1248.0], [888.0, 1277.0], [743.0, 1277.0]]], "lines": ["隣におしりハンバーガー", "声優志望のてへべろ女。", "アニメ声。"]}, {"box": [726, 1323, 1088, 1418], "vertical": false, "font_size": 27.0, "lines_coords": [[[726.0, 1323.0], [1088.0, 1323.0], [1088.0, 1352.0], [726.0, 1352.0]], [[753.0, 1360.0], [1061.0, 1362.0], [1061.0, 1391.0], [753.0, 1389.0]], [[787.0, 1395.0], [899.0, 1395.0], [899.0, 1418.0], [787.0, 1418.0]]], "lines": ["饗汎守護天使ギボボギギ", "空気の読めない中年女。", "二児の母。"]}, {"box": [743, 1466, 1077, 1535], "vertical": false, "font_size": 31.5, "lines_coords": [[[743.0, 1466.0], [849.0, 1466.0], [849.0, 1499.0], [743.0, 1499.0]], [[753.0, 1501.0], [1077.0, 1505.0], [1077.0, 1535.0], [753.0, 1530.0]]], "lines": ["『逆に", "しくもろベイベー。宅配業。"]}, {"box": [552, 1456, 579, 1485], "vertical": false, "font_size": 29, "lines_coords": [[[552.0, 1456.0], [579.0, 1456.0], [579.0, 1485.0], [552.0, 1485.0]]], "lines": ["☆"]}, {"box": [255, 1030, 554, 1132], "vertical": false, "font_size": 30, "lines_coords": [[[255.0, 1034.0], [324.0, 1034.0], [324.0, 1065.0], [255.0, 1065.0]], [[257.0, 1069.0], [546.0, 1069.0], [546.0, 1098.0], [257.0, 1098.0]], [[255.0, 1102.0], [346.0, 1102.0], [346.0, 1132.0], [255.0, 1132.0]]], "lines": ["清水", "夢から覚めない、不思議男", "大学生"]}, {"box": [