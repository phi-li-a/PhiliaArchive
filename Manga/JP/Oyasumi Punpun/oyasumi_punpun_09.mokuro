, 984.0]]], "lines": ["．．．やっぱり", "お断りします。"]}, {"box": [1084, 1024, 1167, 1194], "vertical": true, "font_size": 36, "lines_coords": [[[1130.0, 1024.0], [1167.0, 1024.0], [1167.0, 1163.0], [1130.0, 1163.0]], [[1084.0, 1024.0], [1120.0, 1024.0], [1120.0, 1194.0], [1084.0, 1194.0]]], "lines": ["検討して", "もらえた？"]}, {"box": [1172, 1364, 1278, 1638], "vertical": true, "font_size": 28, "lines_coords": [[[1246.0, 1366.0], [1275.0, 1366.0], [1275.0, 1547.0], [1246.0, 1547.0]], [[1209.0, 1370.0], [1238.0, 1370.0], [1238.0, 1549.0], [1209.0, 1549.0]], [[1172.0, 1364.0], [1199.0, 1364.0], [1199.0, 1638.0], [1172.0, 1638.0]]], "lines": ["．．．今まで散々", "悪いことして", "きたんじゃないの？"]}, {"box": [187, 994, 326, 1244], "vertical": true, "font_size": 30, "lines_coords": [[[293.0, 994.0], [322.0, 994.0], [326.0, 1244.0], [297.0, 1244.0]], [[257.0, 999.0], [286.0, 999.0], [286.0, 1183.0], [257.0, 1183.0]], [[222.0, 1001.0], [251.0, 1001.0], [251.0, 1183.0], [222.0, 1183.0]], [[187.0, 999.0], [214.0, 999.0], [214.0, 1183.0], [187.0, 1183.0]]], "lines": ["何十万積まれても", "アングラに足", "突っ込むのは", "ちょっと．．．"]}, {"box": [964, 1676, 1070, 1944], "vertical": true, "font_size": 28, "lines_coords": [[[1039.0, 1676.0], [1068.0, 1676.0], [1068.0, 1832.0], [1039.0, 1832.0]], [[1001.0, 1680.0], [1030.0, 1680.0], [1030.0, 1944.0], [1001.0, 1944.0]], [[968.0, 1678.0], [993.0, 1678.0], [993.0, 1838.0], [968.0, 1838.0]]], "lines": ["．．．どうせ俺", "一線は越えられない", "性分なんで。"]}, {"box": [355, 1545, 390, 1688], "vertical": true, "font_size": 37, "lines_coords": [[[355.0, 1545.0], [390.0, 1545.0], [390.0, 1688.0], [355.0, 1688.0]]], "lines": ["．．．じゃあ、"]}, {"box": [211, 1740, 332, 1975], "vertical": true, "font_size": 37, "lines_coords": [[[303.0, 1744.0], [332.0, 1744.0], [332.0, 1975.0], [303.0, 1975.0]], [[257.0, 1744.0], [293.0, 1744.0], [293.0, 1946.0], [257.0, 1946.0]], [[211.0, 1740.0], [259.0, 1740.0], [259.0, 1829.0], [211.0, 1829.0]]], "lines": ["提案のしかたを", "変えてみよう", "かな。"]}], "img_path": "142.png"}, {"version": "0.2.0-beta.6", "img_