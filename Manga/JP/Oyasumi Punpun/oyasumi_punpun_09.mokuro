[301.0, 1821.0], [249.0, 1821.0]]], "lines": ["アイ・ラブ・", "ユー"]}], "img_path": "202.png"}, {"version": "0.2.0-beta.6", "img_width": 1439, "img_height": 2127, "blocks": [{"box": [1110, 190, 1188, 398], "vertical": true, "font_size": 36, "lines_coords": [[[1152.0, 193.0], [1187.0, 193.0], [1187.0, 330.0], [1152.0, 330.0]], [[1110.0, 191.0], [1146.0, 191.0], [1146.0, 398.0], [1110.0, 398.0]]], "lines": ["今日から", "君の名前は：："]}, {"box": [215, 645, 341, 969], "vertical": true, "font_size": 38, "lines_coords": [[[305.0, 648.0], [340.0, 648.0], [340.0, 835.0], [305.0, 835.0]], [[261.0, 648.0], [296.0, 648.0], [292.0, 967.0], [257.0, 967.0]], [[215.0, 645.0], [259.0, 645.0], [259.0, 787.0], [215.0, 787.0]]], "lines": ["「週刊ビッグ", "コミックスピリッツ」", "だ．．．．．．"]}, {"box": [693, 1541, 728, 1709], "vertical": true, "font_size": 35, "lines_coords": [[[693.0, 1541.0], [728.0, 1541.0], [728.0, 1709.0], [693.0, 1709.0]]], "lines": ["曲の前に．．．"]}, {"box": [564, 1732, 681, 1937], "vertical": true, "font_size": 35, "lines_coords": [[[643.0, 1736.0], [681.0, 1736.0], [681.0, 1842.0], [643.0, 1842.0]], [[600.0, 1732.0], [637.0, 1732.0], [639.0, 1937.0], [602.0, 1937.0]], [[564.0, 1738.0], [593.0, 1738.0], [593.0, 1902.0], [564.0, 1902.0]]], "lines": ["祝杯を", "挙げようじゃ", "ないか．．．"]}, {"box": [141, 1784, 233, 2037], "vertical": true, "font_size": 35, "lines_coords": [[[195.0, 1788.0], [230.0, 1788.0], [230.0, 2031.0], [195.0, 2031.0]], [[141.0, 1788.0], [176.0, 1788.0], [176.0, 1989.0], [141.0, 1989.0]]], "lines": ["チューペット君、", "杯を彼に．．．"]}], "img_path": "203.png"}, {"version": "0.2.0-beta.6", "img_width": 1437, "img_height": 2127, "blocks": [{"box": [442, 83, 552, 331], "vertical": true, "font_size": 36, "lines_coords": [[[517.0, 83.0], [552.0, 83.0], [552.0, 243.0], [517.0, 243.0]], [[479.0, 83.0], [514.0, 83.0], [514.0, 330.0], [479.0, 330.0]], [[442.0, 85.0], [479.0, 85.0], [479.0, 211.0], [442.0, 211.0]]], "lines": ["．．．こんなに", "嬉しいことったら", "ない．．．"]}, {"box": [1164, 857, 1243, 1134], "vertical": true, "font_size": 36, "lines_coords": [[[1206.0, 862.0], [1241.0, 862.0], [1241.0, 1030.0], [1206.0, 1030.0]], [[1164.0, 857.0], [1200.0, 857.0], [1200.0, 1134.0], [1164.0, 1134.0]]], "lines": ["我々の力で", "「黒点」を排除し．．．"]}, {"box": [909, 486, 988, 689], "vertical": true, "font_size": 35, "lines_coords": [[[951.0, 486.0], [986.0, 486.0], [986.0, 689.0], [951.0, 689.0]], [[909.0, 488.0], [944.0, 488.0], [944.0, 656.0], [909.0, 656.0]]], "lines": ["．．．ホラ急いで", "清水くん！！"]}, {"box": [170, 521, 247, 758], "vertical": true, "font_size": 32, "lines_coords": [[[211.0, 521.0], [247.0, 521.0], [247.0, 656.0], [211.0, 656.0]], [[172.0, 523.0], [201.0, 523.0], [201.0, 758.0], [172.0, 758.0]]], "lines": ["１２音階の", "魔法戦士達よ："]}, {"box": [230, 1267, 348, 1502], "vertical": true, "font_size": 29, "lines_coords": [[[315.0, 1267.0], [344.0, 1267.0], [344.0, 1466.0], [315.0, 1466.0]], [[272.0, 1269.0], [301.0, 1269.0], [301.0, 1501.0], [272.0, 1501.0]], [[230.0, 1269.0], [259.0, 1269.0], [259.0, 1501.0], [230.0, 1501.0]]], "lines": ["ラヴァーズを", "新世界に導こう", "じゃないか．．．"]}], "img_path": "204.png"}, {"version": "0.2.0-beta.6", "img_width": 1435, "img_height": 2127, "blocks": [{"box": [1174, 1511, 1213, 1747], "vertical": true, "font_size": 35, "lines_coords": [[[1175.0, 1512.0], [1210.0, 1512.0], [1210.0, 1744.0], [1175.0, 1744.0]]], "lines": ["ようこそ！！"]}, {"box": [168, 1767, 264, 1994], "vertical": true, "font_size": 43, "lines_coords": [[[218.0, 1767.0], [263.0, 1767.0], [259.0, 1954.0], [213.0, 1954.0]], [[168.0, 1771.0], [209.0, 1771.0], [209.0, 1994.0], [168.0, 1994.0]]], "lines": ["「ペガサス", "合奏団」へ！！"]}], "img_path": "205.png"}, {"version": "0.2.0-beta.6", "img_width": 1432, "img_height": 2127, "blocks": [], "img_path": "206.png"}, {"version": "0.2.0-beta.6", "img_width": 1437, "img_height": 2127, "blocks": [], "img_path": "207.png"}, {"version": "0.2.0-beta.6", "img_width": 1437, "img_height": 2127, "blocks": [{"box": [566, 118, 931, 794], "vertical": true, "font_size": 29, "lines_coords": [[[899.0, 153.0], [928.0, 153.0], [930.0, 791.0], [901.0, 791.0]], [[863.0, 124.0], [892.0, 124.0], [892.0, 791.0], [863.0, 791.0]], [[822.0, 122.0], [857.0, 122.0], [857.0, 791.0], [822.0, 791.0]], [[789.0, 126.0], [818.0, 126.0], [818.0, 791.0], [789.0, 791.0]], [[749.0, 124.0], [778.0, 124.0], [778.0, 789.0], [749.0, 789.0]], [[714.0, 124.0], [743.0, 124.0], [743.0, 791.0], [714.0, 791.0]], [[679.0, 124.0], [708.0, 124.0], [708.0, 793.0], [679.0, 793.0]], [[641.0, 124.0], [670.0, 124.0], [670.0, 793.0], [641.0, 793.0]], [[606.0, 126.0], [633.0, 126.0], [633.0, 793.0], [606.0, 793.0]], [[566.0, 124.0], [593.0, 124.0], [593.0, 371.0], [566.0, 371.0]]], "lines": ["お昼の顔である某司会者の声が鼓膜で電気信号", "に変換され、シナプスを伝い少しずつ脳が覚醒し", "てゆく。どうやら地時間近く眠ってしまったらし", "いのは５月の「度良い気候のせいか。起きることも", "を明らかに体が揺んでいるが、ようやく縛りを開け", "けると素人そっくりさんコンテストの元ネタの有", "名人の顔がわからないと言う段。人気のお笑いタ", "レントの冗談で湧くテレビの中のやりとりはまる", "で別次元の未来人達の会話のように遠い遠い世界", "の出来事のようだ"]}, {"box": [47, 419, 105, 645], "vertical": true, "font_size": 58, "lines_coords": [[[47.0, 419.0], [105.0, 419.0], [105.0, 645.0], [47.0, 645.0]]], "lines": ["第９９９話"]}, {"box": [307, 1321, 636, 1724], "vertical": true, "font_size": 34, "lines_coords": [[[600.0, 1354.0], [631.0, 1354.0], [633.0, 1717.0], [602.0, 1717.0]], [[568.0, 1329.0], [598.0, 1329.0], [598.0, 1719.0], [568.0, 1719.0]], [[529.0, 1327.0], [558.0, 1327.0], [558.0, 1719.0], [529.0, 1719.0]], [[490.0, 1325.0], [525.0, 1325.0], [525.0, 1721.0], [490.0, 1721.0]], [[452.0, 1327.0], [487.0, 1327.0], [487.0, 1721.0], [452.0, 1721.0]], [[419.0, 1329.0], [448.0, 1329.0], [448.0, 1719.0], [419.0, 1719.0]], [[382.0, 1329.0], [411.0, 1329.0], [411.0, 1717.0], [382.0, 1717.0]], [[334.0, 1321.0], [384.0, 1321.0], [384.0, 1724.0], [334.0, 1724.0]], [[307.0, 1329.0], [344.0, 1329.0], [344.0, 1372.0], [307.0, 1372.0]]], "lines": ["請求書にはあと５日以内に", "延滞料金を振り込まないと電", "気が止まる旨が記されていた", "が、なぜ毎月毎月自分はこの", "程度のことまで後回しにして", "しまうのか。一人暮らしは何", "かをしようとすると忙しすぎ", "るし、何もしないと退屈すぎ", "る。"]}, {"box": [951, 1333, 1204, 2062], "vertical": true, "font_size": 31, "lines_coords": [[[1164.0, 1364.0], [1200.0, 1364.0], [1204.0, 2058.0], [1169.0, 2058.0]], [[1127.0, 1333.0], [1162.0, 1333.0], [1164.0, 2062.0], [1129.0, 2062.0]], [[1094.0, 1335.0], [1123.0, 1335.0], [1123.0, 2058.0], [1094.0, 2058.0]], [[1056.0, 1337.0], [1086.0, 1337.0], [1086.0, 2056.0], [1056.0, 2056.0]], [[1019.0, 1335.0], [1048.0, 1335.0], [1052.0, 2058.0], [1023.0, 2058.0]], [[984.0, 1337.0], [1013.0, 1337.0], [1013.0, 2056.0], [984.0, 2056.0]], [[951.0, 1337.0], [978.0, 1337.0], [978.0, 1732.0], [951.0, 1732.0]]], "lines": ["乾いた喉を潤そうとテーＴブルに目をやるが、腐った", "飲みかけの缶コーヒーが並んでいるだけだった。自分が", "の尿を飲み尿を排泄し、またその尿を飲む水久機関に", "ついて考察していると、ドアの郵便受けに何かが投断", "される音。一瞬ドキリとするが、おおかた公共科金の", "請求書であろう。それ以外で自分に用のある人間なん", "てこの世にはいないのだから"]}], "img_path": "208.png"}, {"version": "0.2.0-beta.6", "img_width": 1441, "img_height": 2127, "blocks": [{"box": [751, 76, 1110, 510], "vertical": true, "font_size": 121, "lines_coords": [[[1081.0, 108.0], [1110.0, 108.0], [1110.0, 508.0], [1081.0, 508.0]], [[1040.0, 81.0], [1075.0, 81.0], [1075.0, 510.0], [1040.0, 510.0]], [[971.0, 78.0], [1000.0, 78.0], [996.0, 448.0], [967.0, 448.0]], [[934.0, 81.0], [963.0, 81.0], [963.0, 448.0], [934.0, 448.0]], [[859.0, 78.0], [888.0, 78.0], [886.0, 423.0], [857.0, 423.0]], [[824.0, 76.0], [853.0, 76.0], [849.0, 419.0], [820.0, 419.0]], [[786.0, 76.0], [816.0, 76.0], [813.0, 423.0], [784.0, 423.0]], [[751.0, 81.0], [778.0, 81.0], [778.0, 427.0], [751.0, 427.0]]], "lines": ["バイトの前に書店で自殺の指", "階書を立ち読みする。どうやら", "良きそうだ。本を手にレジ", "かつと店員の丸顔丸眼鏡の", "の子がうんこのような風", "その男性名に怒鳴りつけ", "ぐんでおり、なぜか自分の", "きそうになってしまう。お"]}, {"box": [379, 70, 1004, 508], "vertical": true, "font_size": 121, "lines_coords": [[[957.0, 450.0], [1004.0, 450.0], [1004.0, 475.0], [957.0, 475.0]], [[712.0, 81.0], [741.0, 81.0], [741.0, 423.0], [712.0, 423.0]], [[672.0, 81.0], [708.0, 81.0], [708.0, 423.0], [672.0, 423.0]], [[637.0, 81.0], [666.0, 81.0], [666.0, 417.0], [637.0, 417.0]], [[600.0, 78.0], [629.0, 78.0], [631.0, 417.0], [602.0, 417.0]], [[541.0, 72.0], [600.0, 70.0], [616.0, 461.0], [558.0, 463.0]], [[529.0, 81.0], [558.0, 81.0], [558.0, 454.0], [529.0, 454.0]], [[452.0, 76.0], [487.0, 76.0], [487.0, 479.0], [452.0, 479.0]], [[415.0, 78.0], [450.0, 78.0], [450.0, 506.0], [415.0, 506.0]], [[379.0, 81.0], [409.0, 81.0], [409.0, 508.0], [379.0, 508.0]]], "lines": ["へ", "そうに後ろからそのうんこ", "な肩をつかみ見事な人外", "床を這わせた後、脳角が", "るまで何度も何度モ何度", "も殴りつける自分を安想する", "勿論実行する勇気はない。", "ずに店を出てしまった。自決", "る勇気があるならば、いっそよ", "当に殺してしまえば良かったん"]}, {"box": [269, 0, 1260, 758], "vertical": true, "font_size": 121, "lines_coords": [[[438.0, 442.0], [899.0, 0.0], [1260.0, 234.0], [801.0, 758.0]], [[340.0, 76.0], [375.0, 76.0], [375.0, 508.0], [340.0, 508.0]], [[338.0, 0.0], [1115.0, 0.0], [1115.0, 621.0], [338.0, 621.0]], [[307.0, 78.0], [336.0, 78.0], [336.0, 504.0], [307.0, 504.0]], [[280.0, 0.0], [1210.0, 0.0], [1210.0, 677.0], [280.0, 677.0]], [[269.0, 78.0], [296.0, 78.0], [296.0, 328.0], [269.0, 328.0]]], "lines": ["．．．", "じゃないかと思ったが、つまり", "．．．", "所詮目分の決意などその程度な", "それはそうだな。", "のだということだ"]}], "img_path": "209.png"}, {"version": "0.2.0-beta.6", "img_width": 1438, "img_height": 2127, "blocks": [{"box": [1219, 118, 1248, 357], "vertical": true, "font_size": 30, "lines_coords": [[[1219.0, 118.0], [1248.0, 118.0], [1248.0, 357.0], [1219.0, 357.0]]], "lines": ["公園にて甘いパン"]}, {"box": [960, 85, 1209, 365], "vertical": true, "font_size": 30, "lines_coords": [[[1182.0, 85.0], [1209.0, 85.0], [1209.0, 355.0], [1182.0, 355.0]], [[1142.0, 87.0], [1172.0, 87.0], [1176.0, 359.0], [1147.0, 359.0]], [[1107.0, 87.0], [1136.0, 87.0], [1140.0, 361.0], [1111.0, 361.0]], [[1068.0, 85.0], [1103.0, 85.0], [1107.0, 365.0], [1072.0, 365.0]], [[1028.0, 85.0], [1063.0, 85.0], [1068.0, 363.0], [1032.0, 363.0]], [[995.0, 87.0], [1024.0, 87.0], [1028.0, 361.0], [999.0, 361.0]], [[960.0, 89.0], [989.0, 89.0], [991.0, 278.0], [962.0, 278.0]]], "lines": ["を食べながら丸顔の", "店員と付き合っても、", "ックスするまでの過", "程を想像するが、奇", "跡が１０回くらい起き", "ないとどうにもなら", "なそうだった。"]}, {"box": [735, 500, 1248, 1007], "vertical": true, "font_size": 40, "lines_coords": [[[1215.0, 552.0], [1244.0, 552.0], [1248.0, 980.0], [1219.0, 980.0]], [[1176.0, 523.0], [1211.0, 523.0], [1213.0, 982.0], [1178.0, 982.0]], [[1136.0, 523.0], [1180.0, 523.0], [1180.0, 984.0], [1136.0, 984.0]], [[1099.0, 525.0], [1134.0, 525.0], [1138.0, 959.0], [1103.0, 959.0]], [[1034.0, 502.0], [1157.0, 500.0], [1167.0, 1005.0], [1045.0, 1007.0]], [[1024.0, 523.0], [1066.0, 523.0], [1070.0, 986.0], [1028.0, 986.0]], [[984.0, 523.0], [1026.0, 523.0], [1032.0, 988.0], [991.0, 988.0]], [[947.0, 523.0], [989.0, 523.0], [997.0, 988.0], [955.0, 988.0]], [[918.0, 529.0], [947.0, 529.0], [953.0, 936.0], [924.0, 936.0]], [[879.0, 527.0], [914.0, 527.0], [920.0, 957.0], [885.0, 957.0]], [[841.0, 527.0], [876.0, 527.0], [881.0, 988.0], [845.0, 988.0]], [[804.0, 527.0], [847.0, 527.0], [847.0, 988.0], [804.0, 988.0]], [[770.0, 529.0], [806.0, 529.0], [808.0, 988.0], [773.0, 988.0]], [[735.0, 529.0], [764.0, 529.0], [766.0, 986.0], [737.0, 986.0]]], "lines": ["考えに考え明気を振り絞りバイ", "トの後輩に合コンの参加を出し込", "むが、既に定員が埋まってしまった", "たらしく、隣ちらつかせた後輩。", "せが出になりかりまってしまったらしく．．．勝ちらつかせた後半の印倒そうな表情に自分は激しく刺指して気にしないでよな大丈夫だ", "怪し「気にしないで全然大丈夫だ", "から」と何がどう大丈夫なのかわ", "からないが、定まらなり視線のま", "ま１０時ほど戦文のように繰りが", "ハフハフと動悸が止まず最終的", "プタ鼻をフゴッ」と鳴らしてしまう", "った。直後に腰痛に襲われトイレ", "で初老の男性のような風貌のうん", "こを排泄していると事務室から後"]}, {"box": [881, 926, 955, 986], "vertical": true, "font_size": 40, "lines_coords": [[[908.0, 926.0], [955.0, 926.0], [955.0, 951.0], [908.0, 951.0]], [[899.0, 949.0], [918.0, 967.0], [899.0, 986.0], [881.0, 967.0]]], "lines": ["と", "（）"]}, {"box": [623, 529, 733, 992], "vertical": true, "font_size": 40, "lines_coords": [[[694.0, 529.0], [729.0, 529.0], [733.0, 992.0], [698.0, 992.0]], [[656.0, 529.0], [691.0, 529.0], [691.0, 986.0], [656.0, 986.0]], [[623.0, 531.0], [654.0, 531.0], [656.0, 751.0], [625.0, 751.0]]], "lines": ["輩達のキャッキャウフフが聞こえ", "このパイトもそろそろ潮時かもし", "れないと思った。"]}, {"box": [176, 151, 467, 920], "vertical": true, "font_size": 33, "lines_coords": [[[434.0, 182.0], [463.0, 182.0], [467.0, 913.0], [438.0, 913.0]], [[394.0, 151.0], [430.0, 151.0], [432.0, 916.0], [396.0, 916.0]], [[357.0, 153.0], [392.0, 153.0], [394.0, 918.0], [359.0, 918.0]], [[320.0, 153.0], [355.0, 153.0], [359.0, 920.0], [324.0, 920.0]], [[284.0, 155.0], [315.0, 155.0], [320.0, 913.0], [288.0, 913.0]], [[245.0, 151.0], [280.0, 151.0], [284.0, 911.0], [249.0, 911.0]], [[209.0, 155.0], [245.0, 155.0], [247.0, 911.0], [211.0, 911.0]], [[176.0, 157.0], [205.0, 157.0], [207.0, 799.0], [178.0, 799.0]]], "lines": ["バイト帰り、国道沿いの歩道の横え込みに人が突き刺され", "さっていて驚く。ぴくりともしないその様に、瞬死んで", "いるのかと思いドキドキとしながら近づくが、見るとただ", "泥酔しているだけのようである。茶髪にとんがりブーツ。", "続くいう親から色んな毛をはみださせ白いシャツからの", "ぞく割れた腹筋等そのチャラチャラとした風貌は「処女", "乱れ喰い」という言葉を連想させ、自分は目。杯の軽蔑", "の意を込めた正打ちを放ってその場を後にした"]}, {"box": [355, 1823, 575, 2103], "vertical": true, "font_size": 32, "lines_coords": [[[546.0, 1852.0], [575.0, 1852.0], [575.0, 2099.0], [546.0, 2099.0]], [[502.0, 1823.0], [538.0, 1823.0], [536.0, 2097.0], [500.0, 2097.0]], [[469.0, 1827.0], [498.0, 1827.0], [498.0, 2097.0], [469.0, 2097.0]], [[432.0, 1829.0], [461.0, 1829.0], [461.0, 2099.0], [432.0, 2099.0]], [[390.0, 1827.0], [425.0, 1827.0], [428.0, 2102.0], [392.0, 2102.0]], [[355.0, 1827.0], [390.0, 1827.0], [390.0, 1985.0], [355.0, 1985.0]]], "lines": ["アパートに戻って", "数時間後、さっきの", "処女喰いが急に心配", "になり間道へ探しに", "いったがもうその姿", "はなかった。"]}], "img_path": "210.png"}, {"version": "0.2.0-beta.6", "img_width": 1439, "img_height": 2127, "blocks": [{"box": [988, 1618, 1100, 1860], "vertical": true, "font_size": 34, "lines_coords": [[[1063.0, 1618.0], [1100.0, 1618.0], [1100.0, 1721.0], [1063.0, 1721.0]], [[1029.0, 1622.0], [1059.0, 1622.0], [1059.0, 1859.0], [1029.0, 1859.0]], [[992.0, 1620.0], [1027.0, 1620.0], [1023.0, 1782.0], [988.0, 1782.0]]], "lines": ["これが、", "今日のフンフンの", "一日でした。"]}, {"box": [223, 1610, 327, 1853], "vertical": true, "font_size": 27, "lines_coords": [[[294.0, 1613.0], [323.0, 1613.0], [323.0, 1852.0], [294.0, 1852.0]], [[257.0, 1613.0], [286.0, 1613.0], [286.0, 1852.0], [257.0, 1852.0]], [[224.0, 1613.0], [247.0, 1613.0], [247.0, 1769.0], [224.0, 1769.0]]], "lines": ["正直、ブンブンは", "こんな自分にもう", "飽きました。"]}], "img_path": "211.png"}, {"version": "0.2.0-beta.6", "img_width": 1442, "img_height": 2127, "blocks": [{"box": [1200, 546, 1269, 758], "vertical": true, "font_size": 30, "lines_coords": [[[1234.0, 548.0], [1263.0, 548.0], [1267.0, 758.0], [1238.0, 758.0]], [[1200.0, 548.0], [1230.0, 548.0], [1230.0, 731.0], [1200.0, 731.0]]], "lines": ["部屋に散らかる", "物という物が"]}, {"box": [938, 547, 1117, 856], "vertical": true, "font_size": 30, "lines_coords": [[[1086.0, 552.0], [1115.0, 552.0], [1115.0, 789.0], [1086.0, 789.0]], [[1047.0, 548.0], [1082.0, 548.0], [1078.0, 764.0], [1043.0, 764.0]], [[1011.0, 550.0], [1040.0, 550.0], [1040.0, 762.0], [1011.0, 762.0]], [[972.0, 548.0], [1001.0, 548.0], [1005.0, 853.0], [976.0, 853.0]], [[939.0, 550.0], [966.0, 550.0], [966.0, 735.0], [939.0, 735.0]]], "lines": ["自分のくだらない", "人生を凝縮して", "茶こしでこした", "残りかすのようにしか", "思えなくなり"]}, {"box": [1198, 986, 1236, 1126], "vertical": true, "font_size": 38, "lines_coords": [[[1198.0, 986.0], [1236.0, 986.0], [1236.0, 1123.0], [1198.0, 1123.0]]], "lines": ["あの．．．"]}, {"box": [756, 544, 861, 893], "vertical": true, "font_size": 30, "lines_coords": [[[826.0, 546.0], [858.0, 546.0], [860.0, 891.0], [829.0, 891.0]], [[791.0, 546.0], [820.0, 546.0], [820.0, 731.0], [791.0, 731.0]], [[756.0, 548.0], [785.0, 548.0], [785.0, 737.0], [756.0, 737.0]]], "lines": ["全て処分してしまいたい。", "そんな衝動に", "駆られました。"]}, {"box": [376, 1086, 465, 1300], "vertical": true, "font_size": 34, "lines_coords": [[[425.0, 1088.0], [463.0, 1088.0], [465.0, 1258.0], [428.0, 1258.0]], [[376.0, 1086.0], [413.0, 1086.0], [415.0, 1300.0], [378.0, 1300.0]]], "lines": ["こんばんは", "隣の藤川です。"]}, {"box": [378, 1085, 468, 1309], "vertical": true, "font_size": 90, "lines_coords": [[[378.0, 1085.0], [468.0, 1085.0], [468.0, 1309.0], [378.0, 1309.0]]], "lines": ["こんばんは隣の藤川です。"]}, {"box": [274, 1306, 303, 1541], "vertical": true, "font_size": 34, "lines_coords": [[[274.0, 1306.0], [303.0, 1306.0], [303.0, 1541.0], [274.0, 1541.0]]], "lines": ["．．．重そうですね"]}, {"box": [1190, 1750, 1268, 1954], "vertical": true, "font_size": 36, "lines_coords": [[[1230.0, 1751.0], [1267.0, 1751.0], [1267.0, 1883.0], [1230.0, 1883.0]], [[1190.0, 1751.0], [1225.0, 1751.0], [1225.0, 1952.0], [1190.0, 1952.0]]], "lines": ["．．．手伝い", "ましょうか？"]}, {"box": [179, 1832, 255, 2002], "vertical": true, "font_size": 32, "lines_coords": [[[220.0, 1832.0], [255.0, 1832.0], [255.0, 2002.0], [220.0, 2002.0]], [[180.0, 1836.0], [209.0, 1836.0], [209.0, 2000.0], [180.0, 2000.0]]], "lines": ["．．．ちょっと", "たーくん？"]}], "img_path": "212.png"}, {"version": "0.2.0-beta.6", "img_width": 1438, "img_height": 2127, "blocks": [{"box": [1199, 193, 1238, 261], "vertical": true, "font_size": 39, "lines_coords": [[[1199.0, 193.0], [1238.0, 193.0], [1238.0, 261.0], [1199.0, 261.0]]], "lines": ["あっ"]}, {"box": [382, 321, 417, 390], "vertical": true, "font_size": 34, "lines_coords": [[[382.0, 321.0], [417.0, 321.0], [417.0, 390.0], [382.0, 390.0]]], "lines": ["やん"]}, {"box": [342, 375, 374, 429], "vertical": true, "font_size": 34, "lines_coords": [[[342.0, 375.0], [374.0, 375.0], [374.0, 429.0], [342.0, 429.0]]], "lines": ["やん"]}, {"box": [1012, 583, 1051, 656], "vertical": false, "font_size": 73, "lines_coords": [[[1012.0, 583.0], [1051.0, 583.0], [1051.0, 656.0], [1012.0, 656.0]]], "lines": ["あっ"]}, {"box": [1174, 1017, 1223, 1094], "vertical": true, "font_size": 49, "lines_coords": [[[1174.0, 1017.0], [1223.0, 1017.0], [1223.0, 1094.0], [1174.0, 1094.0]]], "lines": ["あっ"]}, {"box": [479, 788, 512, 828], "vertical": true, "font_size": 33, "lines_coords": [[[479.0, 788.0], [512.0, 788.0], [512.0, 828.0], [479.0, 828.0]]], "lines": ["あ"]}, {"box": [220, 787, 288, 940], "vertical": true, "font_size": 32, "lines_coords": [[[253.0, 789.0], [288.0, 789.0], [288.0, 913.0], [253.0, 913.0]], [[220.0, 791.0], [249.0, 791.0], [249.0, 940.0], [220.0, 940.0]]], "lines": ["たーくん", "たーくんっ"]}, {"box": [1230, 1441, 1269, 1485], "vertical": false, "font_size": 44, "lines_coords": [[[1230.0, 1441.0], [1269.0, 1441.0], [1269.0, 1485.0], [1230.0, 1485.0]]], "lines": ["あ"]}, {"box": [856, 1048, 890, 1298], "vertical": true, "font_size": 29, "lines_coords": [[[856.0, 1053.0], [885.0, 1053.0], [885.0, 1291.0], [856.0, 1291.0]]], "lines": ["．．．もしかしたら"]}, {"box": [535, 1048, 695, 1321], "vertical": true, "font_size": 34, "lines_coords": [[[658.0, 1053.0], [694.0, 1053.0], [694.0, 1221.0], [658.0, 1221.0]], [[615.0, 1051.0], [650.0, 1051.0], [648.0, 1321.0], [613.0, 1321.0]], [[575.0, 1048.0], [610.0, 1048.0], [606.0, 1318.0], [571.0, 1318.0]], [[536.0, 1048.0], [565.0, 1048.0], [565.0, 1202.0], [536.0, 1202.0]]], "lines": ["この世界は", "たーくんを中心に", "回っているのかも", "しれない。"]}, {"box": [226, 1154, 305, 1285], "vertical": true, "font_size": 37, "lines_coords": [[[268.0, 1154.0], [305.0, 1154.0], [305.0, 1258.0], [268.0, 1258.0]], [[226.0, 1154.0], [263.0, 1154.0], [263.0, 1285.0], [226.0, 1285.0]]], "lines": ["由利亜", "由利亜ッ"]}, {"box": [394, 1474, 436, 1549], "vertical": true, "font_size": 42, "lines_coords": [[[394.0, 1474.0], [436.0, 1474.0], [436.0, 1549.0], [394.0, 1549.0]]], "lines": ["あん"]}, {"box": [930, 1576, 970, 1618], "vertical": false, "font_size": 42, "lines_coords": [[[930.0, 1576.0], [970.0, 1576.0], [970.0, 1618.0], [930.0, 1618.0]]], "lines": ["あ"]}, {"box": [477, 1483, 788, 2031], "vertical": true, "font_size": 33, "lines_coords": [[[758.0, 1485.0], [787.0, 1485.0], [781.0, 1794.0], [752.0, 1794.0]], [[716.0, 1487.0], [752.0, 1487.0], [752.0, 1834.0], [716.0, 1834.0]], [[679.0, 1485.0], [714.0, 1485.0], [712.0, 1890.0], [677.0, 1890.0]], [[642.0, 1483.0], [677.0, 1483.0], [673.0, 1975.0], [637.0, 1975.0]], [[604.0, 1485.0], [640.0, 1485.0], [635.0, 2031.0], [600.0, 2031.0]], [[571.0, 1487.0], [600.0, 1487.0], [596.0, 2000.0], [567.0, 2000.0]], [[536.0, 1485.0], [565.0, 1485.0], [561.0, 1888.0], [531.0, 1888.0]], [[480.0, 1483.0], [515.0, 1483.0], [513.0, 1890.0], [477.0, 1890.0]]], "lines": ["そこそこの大学に入り、", "男友達からも評判が良く、", "休日はフットサルで汗を流し、", "柔らかな物腰は爽やかな風を吹かせ、", "査定日の彼女にも愛情をもって接するか", "酒に飲まれていきずりの女性と関係を", "もってしまった事が数回ほど。", "．．．言っとそんなたーくん。"]}, {"box": [791, 1944, 831, 2021], "vertical": true, "font_size": 40, "lines_coords": [[[791.0, 1944.0], [831.0, 1944.0], [831.0, 2021.0], [791.0, 2021.0]]], "lines": ["あん"]}, {"box": [145, 1591, 183, 1694], "vertical": true, "font_size": 37, "lines_coords": [[[145.0, 1591.0], [182.0, 1591.0], [182.0, 1694.0], [145.0, 1694.0]]], "lines": ["あっ．．．"]}], "img_path": "213.png"}, {"version": "0.2.0-beta.6", "img_width": 1437, "img_height": 2127, "blocks": [{"box": [1065, 207, 1271, 650], "vertical": true, "font_size": 34, "lines_coords": [[[1237.0, 211.0], [1266.0, 211.0], [1266.0, 477.0], [1237.0, 477.0]], [[1191.0, 207.0], [1227.0, 207.0], [1229.0, 446.0], [1194.0, 446.0]], [[1148.0, 207.0], [1183.0, 207.0], [1187.0, 650.0], [1152.0, 650.0]], [[1106.0, 207.0], [1142.0, 207.0], [1148.0, 585.0], [1113.0, 585.0]], [[1065.0, 207.0], [1100.0, 207.0], [1102.0, 650.0], [1067.0, 650.0]]], "lines": ["そんなたーくんが", "壁一枚むこうで", "一心不乱に腰を振っている！！", "長いチンコロを頑張って", "出したり入れたりしている！！"]}, {"box": [828, 145, 870, 222], "vertical": true, "font_size": 42, "lines_coords": [[[828.0, 145.0], [870.0, 145.0], [870.0, 222.0], [828.0, 222.0]]], "lines": ["あ．．．"]}, {"box": [914, 210, 991, 516], "vertical": true, "font_size": 29, "lines_coords": [[[959.0, 213.0], [988.0, 213.0], [988.0, 513.0], [959.0, 513.0]], [[915.0, 213.0], [944.0, 213.0], [944.0, 483.0], [915.0, 483.0]]], "lines": ["そう想像しただけで", "ブンブンは．．．；：：："]}, {"box": [537, 423, 575, 530], "vertical": true, "font_size": 38, "lines_coords": [[[537.0, 423.0], [575.0, 423.0], [575.0, 527.0], [537.0, 527.0]]], "lines": ["あ．．．"]}, {"box": [294, 218, 372, 573], "vertical": true, "font_size": 30, "lines_coords": [[[340.0, 220.0], [369.0, 220.0], [369.0, 454.0], [340.0, 454.0]], [[296.0, 220.0], [326.0, 220.0], [326.0, 562.0], [296.0, 562.0]]], "lines": ["不思議なことに", "超勃起でございました。"]}, {"box": [184, 558, 234, 633], "vertical": true, "font_size": 42, "lines_coords": [[[184.0, 558.0], [234.0, 558.0], [234.0, 633.0], [184.0, 633.0]]], "lines": ["あっ"]}, {"box": [143, 629, 182, 816], "vertical": true, "font_size": 42, "lines_coords": [[[143.0, 629.0], [178.0, 629.0], [182.0, 816.0], [147.0, 816.0]]], "lines": ["たーくんッ"]}, {"box": [930, 1734, 1007, 1861], "vertical": false, "font_size": 30, "lines_coords": [[[957.0, 1734.0], [1007.0, 1848.0], [980.0, 1861.0], [930.0, 1746.0]]], "lines": ["．．．そうだよ"]}, {"box": [942, 1896, 1052, 2023], "vertical": false, "font_size": 23.0, "lines_coords": [[[965.0, 1896.0], [998.0, 1981.0], [975.0, 1989.0], [942.0, 1904.0]], [[1011.0, 1910.0], [1052.0, 2014.0], [1032.0, 2023.0], [990.0, 1919.0]]], "lines": ["．．．", "．．．お姉ちゃん"]}, {"box": [930, 1942, 975, 2006], "vertical": false, "font_size": 24, "lines_coords": [[[953.0, 1942.0], [975.0, 1998.0], [953.0, 2006.0], [930.0, 1950.0]]], "lines": ["．．．"]}, {"box": [647, 1748, 836, 2016], "vertical": true, "font_size": 55, "lines_coords": [[[780.0, 1748.0], [836.0, 1748.0], [836.0, 2016.0], [780.0, 2016.0]], [[714.0, 1751.0], [772.0, 1751.0], [772.0, 2016.0], [714.0, 2016.0]], [[652.0, 1751.0], [703.0, 1751.0], [699.0, 2016.0], [647.0, 2016.0]]], "lines": ["たーくん！！", "たーくん！！", "たーくん！！"]}, {"box": [165, 1693, 317, 2085], "vertical": true, "font_size": 38, "lines_coords": [[[213.0, 1832.0], [251.0, 1832.0], [253.0, 2079.0], [215.0, 2079.0]]], "lines": ["いっちゃうゥ"]}], "img_path": "214.png"}, {"version": "0.2.0-beta.6", "img_width": 1436, "img_height": 2127, "blocks": [], "img_path": "215.png"}, {"version": "0.2.0-beta.6", "img_width": 1438, "img_height": 2127, "blocks": [{"box": [1188, 216, 1263, 550], "vertical": true, "font_size": 32, "lines_coords": [[[1226.0, 216.0], [1261.0, 216.0], [1263.0, 488.0], [1228.0, 488.0]], [[1188.0, 218.0], [1217.0, 218.0], [1217.0, 550.0], [1188.0, 550.0]]], "lines": ["たーくんに体中を", "舐めまわされたい．．．"]}, {"box": [1051, 218, 1126, 554], "vertical": true, "font_size": 32, "lines_coords": [[[1097.0, 222.0], [1126.0, 222.0], [1126.0, 486.0], [1097.0, 486.0]], [[1053.0, 218.0], [1088.0, 218.0], [1086.0, 554.0], [1051.0, 554.0]]], "lines": ["しつこいくらいの", "愛撫をちょうだい．．．"]}, {"box": [928, 218, 1005, 523], "vertical": true, "font_size": 32, "lines_coords": [[[970.0, 218.0], [1005.0, 218.0], [1005.0, 523.0], [970.0, 523.0]], [[928.0, 218.0], [964.0, 218.0], [964.0, 521.0], [928.0, 521.0]]], "lines": ["そしてしりっぺたを", "ひっぱたいてくれ！！"]}, {"box": [804, 220, 879, 486], "vertical": true, "font_size": 32, "lines_coords": [[[849.0, 222.0], [879.0, 222.0], [879.0, 421.0], [849.0, 421.0]], [[804.0, 220.0], [835.0, 220.0], [837.0, 486.0], [806.0, 486.0]]], "lines": ["中で出しても", "いいんだよ．．．？"]}, {"box": [245, 177, 502, 515], "vertical": true, "font_size": 257, "lines_coords": [[[245.0, 177.0], [502.0, 177.0], [502.0, 515.0], [245.0, 515.0]]], "lines": ["あ"]}, {"box": [725, 668, 849, 947], "vertical": true, "font_size": 35, "lines_coords": [[[810.0, 668.0], [845.0, 668.0], [849.0, 943.0], [814.0, 943.0]], [[768.0, 672.0], [804.0, 672.0], [804.0, 843.0], [768.0, 843.0]], [[725.0, 670.0], [760.0, 670.0], [764.0, 945.0], [729.0, 945.0]]], "lines": ["そのあとギュッと", "抱きしめて", "くれるのなら．．．"]}, {"box": [671, 1397, 821, 1721], "vertical": true, "font_size": 42, "lines_coords": [[[777.0, 1397.0], [818.0, 1397.0], [818.0, 1643.0], [777.0, 1643.0]], [[725.0, 1397.0], [766.0, 1397.0], [770.0, 1721.0], [729.0, 1721.0]], [[671.0, 1397.0], [714.0, 1397.0], [721.0, 1661.0], [677.0, 1661.0]]], "lines": ["そしてその晩", "小野寺プンプンは", "死んだのです。"]}], "img_path": "216.png"}, {"version": "0.2.0-beta.6", "img_width": 1435, "img_height": 2127, "blocks": [{"box": [1162, 1196, 1246, 1370], "vertical": true, "font_size": 44, "lines_coords": [[[1194.0, 1196.0], [1246.0, 1196.0], [1246.0, 1310.0], [1194.0, 1310.0]], [[1162.0, 1200.0], [1198.0, 1200.0], [1198.0, 1366.0], [1162.0, 1366.0]]], "lines": ["ごめん", "なさい．．．"]}, {"box": [631, 1183, 672, 1325], "vertical": true, 