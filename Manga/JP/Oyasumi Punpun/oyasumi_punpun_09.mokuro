[1255.0, 1273.0], [1219.0, 1273.0]]], "lines": ["それは", "そうと．．．"]}, {"box": [1109, 1289, 1192, 1460], "vertical": true, "font_size": 39, "lines_coords": [[[1151.0, 1289.0], [1192.0, 1289.0], [1192.0, 1354.0], [1151.0, 1354.0]], [[1113.0, 1291.0], [1149.0, 1291.0], [1144.0, 1460.0], [1109.0, 1460.0]]], "lines": ["あー", "関だっけ？"]}, {"box": [199, 1304, 342, 1512], "vertical": true, "font_size": 28, "lines_coords": [[[309.0, 1304.0], [338.0, 1304.0], [338.0, 1487.0], [309.0, 1487.0]], [[272.0, 1304.0], [301.0, 1304.0], [301.0, 1512.0], [272.0, 1512.0]], [[236.0, 1304.0], [263.0, 1304.0], [263.0, 1512.0], [236.0, 1512.0]], [[199.0, 1304.0], [228.0, 1304.0], [228.0, 1454.0], [199.0, 1454.0]]], "lines": ["若いんだから", "おもしろ小咄の", "ひとつやふたつ", "あんだろ？"]}, {"box": [1226, 1699, 1258, 1839], "vertical": true, "font_size": 32, "lines_coords": [[[1226.0, 1699.0], [1258.0, 1699.0], [1258.0, 1839.0], [1226.0, 1839.0]]], "lines": ["あー．．．"]}, {"box": [241, 1844, 278, 1996], "vertical": true, "font_size": 35, "lines_coords": [[[241.0, 1846.0], [276.0, 1846.0], [276.0, 1994.0], [241.0, 1994.0]]], "lines": ["わくわく。"]}], "img_path": "104.png"}, {"version": "0.2.0-beta.6", "img_width": 1431, "img_height": 2127, "blocks": [{"box": [1082, 184, 1181, 388], "vertical": true, "font_size": 30, "lines_coords": [[[1144.0, 184.0], [1181.0, 184.0], [1181.0, 301.0], [1144.0, 301.0]], [[1115.0, 186.0], [1144.0, 186.0], [1144.0, 380.0], [1115.0, 380.0]], [[1082.0, 184.0], [1109.0, 184.0], [1109.0, 388.0], [1082.0, 388.0]]], "lines": ["．．．なんで", "車って無くなら", "ないんですかね。"]}, {"box": [965, 411, 1094, 695], "vertical": true, "font_size": 30, "lines_coords": [[[1065.0, 411.0], [1094.0, 411.0], [1094.0, 604.0], [1065.0, 604.0]], [[1032.0, 413.0], [1061.0, 413.0], [1061.0, 552.0], [1032.0, 552.0]], [[999.0, 413.0], [1028.0, 413.0], [1028.0, 579.0], [999.0, 579.0]], [[965.0, 413.0], [992.0, 413.0], [992.0, 695.0], [965.0, 695.0]]], "lines": ["だって何千人も", "毎年事故で", "死んでるのに", "危ないじゃないですか。"]}, {"box": [195, 679, 337, 938], "vertical": true, "font_size": 28, "lines_coords": [[[305.0, 681.0], [334.0, 681.0], [334.0, 839.0], [305.0, 839.0]], [[270.0, 681.0], [297.0, 681.0], [297.0, 922.0], [270.0, 922.0]], [[232.0, 681.0], [259.0, 681.0], [259.0, 866.0], [232.0, 866.0]], [[195.0, 679.0], [224.0, 679.0], [224.0, 932.0], [195.0, 932.0]]], "lines": ["そりゃお前、", "車社会が世の中の", "物流と生活を", "支えてるからだろ。"]}, {"box": [1158, 1144, 1235, 1275], "vertical": true, "font_size": 34, "lines_coords": [[[1198.0, 1148.0], [1235.0, 1148.0], [1235.0, 1275.0], [1198.0, 1275.0]], [[1163.0, 1144.0], [1202.0, 1146.0], [1198.0, 1258.0], [1158.0, 1256.0]]], "lines": ["．．．必要悪", "ですか。"]}, {"box": [1001, 1275, 1146, 1464], "vertical": true, "font_size": 34, "lines_coords": [[[1117.0, 1281.0], [1146.0, 1281.0], [1146.0, 1462.0], [1117.0, 1462.0]], [[1082.0, 1281.0], [1109.0, 1281.0], [1109.0, 1464.0], [1082.0, 1464.0]], [[1044.0, 1279.0], [1073.0, 1279.0], [1073.0, 1464.0], [1044.0, 1464.0]], [[1001.0, 1275.0], [1044.0, 1275.0], [1044.0, 1383.0], [1001.0, 1383.0]]], "lines": ["原発も戦争も", "誰かの生活を", "支える必要悪", "ですか。"]}, {"box": [155, 1255, 265, 1498], "vertical": true, "font_size": 29, "lines_coords": [[[234.0, 1256.0], [263.0, 1256.0], [263.0, 1408.0], [234.0, 1408.0]], [[201.0, 1258.0], [224.0, 1258.0], [224.0, 1408.0], [201.0, 1408.0]], [[157.0, 1258.0], [193.0, 1258.0], [191.0, 1497.0], [155.0, 1497.0]]], "lines": ["うるせーよ", "風俗行って", "一回抜いてこい！！"]}, {"box": [226, 1794, 303, 1946], "vertical": true, "font_size": 36, "lines_coords": [[[267.0, 1794.0], [303.0, 1794.0], [303.0, 1933.0], [267.0, 1933.0]], [[226.0, 1794.0], [261.0, 1794.0], [261.0, 1946.0], [226.0, 1946.0]]], "lines": ["．．．じゃあ", "問題です。"]}], "img_path": "105.png"}, {"version": "0.2.0-beta.6", "img_width": 1437, "img_height": 2127, "blocks": [{"box": [1160, 149, 1299, 423], "vertical": true, "font_size": 28, "lines_coords": [[[1270.0, 149.0], [1299.0, 149.0], [1299.0, 309.0], [1270.0, 309.0]], [[1233.0, 151.0], [1262.0, 151.0], [1262.0, 423.0], [1233.0, 423.0]], [[1198.0, 153.0], [1227.0, 153.0], [1227.0, 396.0], [1198.0, 396.0]], [[1160.0, 151.0], [1189.0, 151.0], [1189.0, 317.0], [1160.0, 317.0]]], "lines": ["自分と友達", "それと友達の母親が", "一緒に横断歩道を", "渡ってます。"]}, {"box": [944, 249, 1117, 554], "vertical": true, "font_size": 28, "lines_coords": [[[1088.0, 249.0], [1117.0, 249.0], [1117.0, 506.0], [1088.0, 506.0]], [[1050.0, 249.0], [1079.0, 249.0], [1079.0, 432.0], [1050.0, 432.0]], [[1015.0, 249.0], [1042.0, 249.0], [1042.0, 552.0], [1015.0, 552.0]], [[978.0, 249.0], [1007.0, 249.0], [1007.0, 554.0], [978.0, 554.0]], [[944.0, 259.0], [967.0, 259.0], [967.0, 413.0], [944.0, 413.0]]], "lines": ["その時、自分だけが", "居眠り運転の", "トラックが突っ込んで", "来るのに気がついたと", "しましょう。"]}, {"box": [191, 315, 333, 572], "vertical": true, "font_size": 32, "lines_coords": [[[296.0, 317.0], [332.0, 317.0], [332.0, 442.0], [296.0, 442.0]], [[263.0, 315.0], [292.0, 315.0], [288.0, 500.0], [259.0, 500.0]], [[222.0, 315.0], [257.0, 315.0], [259.0, 571.0], [224.0, 571.0]], [[191.0, 317.0], [218.0, 317.0], [218.0, 498.0], [191.0, 498.0]]], "lines": ["状況的に", "どっちかしか", "助けられない場合、", "どうします？"]}, {"box": [791, 695, 863, 869], "vertical": true, "font_size": 32, "lines_coords": [[[828.0, 695.0], [863.0, 695.0], [863.0, 822.0], [828.0, 822.0]], [[791.0, 697.0], [820.0, 697.0], [820.0, 837.0], [791.0, 837.0]]], "lines": ["そりゃー", "．．．．．．まぁ"]}, {"box": [517, 905, 595, 1044], "vertical": true, "font_size": 36, "lines_coords": [[[556.0, 905.0], [593.0, 905.0], [593.0, 1042.0], [556.0, 1042.0]], [[517.0, 905.0], [552.0, 905.0], [552.0, 1044.0], [517.0, 1044.0]]], "lines": ["友達じゃ", "ねぇの？"]}, {"box": [195, 928, 272, 1088], "vertical": true, "font_size": 44, "lines_coords": [[[222.0, 928.0], [272.0, 928.0], [272.0, 1003.0], [222.0, 1003.0]], [[195.0, 932.0], [232.0, 932.0], [232.0, 1088.0], [195.0, 1088.0]]], "lines": ["いや", "いやぁ～～"]}, {"box": [799, 1188, 902, 1371], "vertical": true, "font_size": 29, "lines_coords": [[[872.0, 1190.0], [901.0, 1190.0], [901.0, 1370.0], [872.0, 1370.0]], [[834.0, 1190.0], [863.0, 1190.0], [863.0, 1370.0], [834.0, 1370.0]], [[799.0, 1190.0], [828.0, 1190.0], [828.0, 1370.0], [799.0, 1370.0]]], "lines": ["．．．わかった！！", "自分一人だけ", "逃げる、だ！！"]}, {"box": [195, 1308, 305, 1494], "vertical": true, "font_size": 30, "lines_coords": [[[276.0, 1316.0], [299.0, 1316.0], [299.0, 1462.0], [276.0, 1462.0]], [[236.0, 1314.0], [265.0, 1314.0], [265.0, 1493.0], [236.0, 1493.0]], [[195.0, 1308.0], [232.0, 1308.0], [232.0, 1466.0], [195.0, 1466.0]]], "lines": ["それも一生", "ひきずりそう", "だな～～～"]}, {"box": [1099, 1634, 1288, 1949], "vertical": true, "font_size": 35, "lines_coords": [[[1200.0, 1757.0], [1248.0, 1757.0], [1248.0, 1834.0], [1200.0, 1834.0]], [[1169.0, 1763.0], [1204.0, 1763.0], [1204.0, 1948.0], [1169.0, 1948.0]], [[1135.0, 1765.0], [1164.0, 1765.0], [1164.0, 1944.0], [1135.0, 1944.0]], [[1100.0, 1765.0], [1129.0, 1765.0], [1129.0, 1900.0], [1100.0, 1900.0]]], "lines": ["特に", "これといった", "答えはないん", "ですけど。"]}, {"box": [652, 1800, 781, 2045], "vertical": true, "font_size": 28, "lines_coords": [[[749.0, 1800.0], [778.0, 1800.0], [780.0, 1962.0], [751.0, 1962.0]], [[718.0, 1802.0], [745.0, 1802.0], [745.0, 2016.0], [718.0, 2016.0]], [[685.0, 1805.0], [712.0, 1805.0], [712.0, 2045.0], [685.0, 2045.0]], [[652.0, 1805.0], [679.0, 1805.0], [679.0, 2004.0], [652.0, 2004.0]]], "lines": ["実際とっさに", "どうするかなんて", "その時にならないと", "わかりませんし。"]}, {"box": [130, 1807, 255, 1979], "vertical": true, "font_size": 40, "lines_coords": [[[211.0, 1813.0], [249.0, 1811.0], [255.0, 1975.0], [218.0, 1977.0]], [[174.0, 1815.0], [211.0, 1815.0], [207.0, 1979.0], [170.0, 1979.0]], [[130.0, 1807.0], [174.0, 1807.0], [174.0, 1917.0], [130.0, 1917.0]]], "lines": ["風俗行って", "一回抜いて", "こい！！"]}], "img_path": "106.png"}, {"version": "0.2.0-beta.6", "img_width": 1435, "img_height": 2127, "blocks": [{"box": [1171, 172, 1235, 303], "vertical": true, "font_size": 29, "lines_coords": [[[1206.0, 172.0], [1235.0, 172.0], [1235.0, 292.0], [1206.0, 292.0]], [[1171.0, 172.0], [1206.0, 172.0], [1206.0, 303.0], [1171.0, 303.0]]], "lines": ["．．．しかし", "お前さぁ、"]}, {"box": [994, 253, 1129, 498], "vertical": true, "font_size": 29, "lines_coords": [[[1100.0, 253.0], [1129.0, 253.0], [1129.0, 409.0], [1100.0, 409.0]], [[1063.0, 255.0], [1092.0, 255.0], [1092.0, 409.0], [1063.0, 409.0]], [[1027.0, 255.0], [1057.0, 255.0], [1057.0, 498.0], [1027.0, 498.0]], [[994.0, 257.0], [1017.0, 257.0], [1017.0, 409.0], [994.0, 409.0]]], "lines": ["どうも随分", "斜に構えた", "性格でらっしゃる", "ようだけど"]}, {"box": [274, 114, 353, 286], "vertical": true, "font_size": 32, "lines_coords": [[[317.0, 114.0], [353.0, 114.0], [353.0, 286.0], [317.0, 286.0]], [[274.0, 116.0], [309.0, 116.0], [309.0, 255.0], [274.0, 255.0]]], "lines": ["生きてるの", "楽しい？"]}, {"box": [137, 292, 276, 508], "vertical": true, "font_size": 32, "lines_coords": [[[245.0, 292.0], [276.0, 292.0], [276.0, 392.0], [245.0, 392.0]], [[209.0, 297.0], [238.0, 297.0], [238.0, 479.0], [209.0, 479.0]], [[170.0, 297.0], [199.0, 297.0], [199.0, 448.0], [170.0, 448.0]], [[137.0, 297.0], [166.0, 297.0], [166.0, 508.0], [137.0, 508.0]]], "lines": ["どんな", "環境で育つと", "そんな風に", "出来あがるの？"]}, {"box": [1169, 608, 1256, 735], "vertical": true, "font_size": 39, "lines_coords": [[[1204.0, 608.0], [1256.0, 608.0], [1256.0, 724.0], [1204.0, 724.0]], [[1169.0, 610.0], [1214.0, 610.0], [1214.0, 735.0], [1169.0, 735.0]]], "lines": ["フツー", "ですよ。"]}, {"box": [1021, 662, 1127, 907], "vertical": true, "font_size": 39, "lines_coords": [[[1092.0, 662.0], [1127.0, 662.0], [1127.0, 787.0], [1092.0, 787.0]], [[1061.0, 666.0], [1090.0, 666.0], [1090.0, 907.0], [1061.0, 907.0]], [[1021.0, 662.0], [1057.0, 662.0], [1057.0, 799.0], [1021.0, 799.0]]], "lines": ["フツーに", "勉強できなかった", "だけです。"]}, {"box": [178, 911, 288, 1063], "vertical": true, "font_size": 34, "lines_coords": [[[251.0, 911.0], [288.0, 911.0], [288.0, 1009.0], [251.0, 1009.0]], [[218.0, 913.0], [247.0, 913.0], [247.0, 1063.0], [218.0, 1063.0]], [[178.0, 911.0], [213.0, 911.0], [213.0, 1036.0], [178.0, 1036.0]]], "lines": ["親とか", "どんな感じ", "なのよ？"]}, {"box": [1104, 1196, 1281, 1447], "vertical": true, "font_size": 28, "lines_coords": [[[1252.0, 1198.0], [1281.0, 1198.0], [1281.0, 1348.0], [1252.0, 1348.0]], [[1216.0, 1196.0], [1246.0, 1196.0], [1246.0, 1447.0], [1216.0, 1447.0]], [[1179.0, 1196.0], [1208.0, 1196.0], [1208.0, 1408.0], [1179.0, 1408.0]], [[1144.0, 1196.0], [1173.0, 1196.0], [1169.0, 1439.0], [1140.0, 1439.0]], [[1104.0, 1196.0], [1133.0, 1196.0], [1133.0, 1333.0], [1104.0, 1333.0]]], "lines": ["一度事業に", "失敗しましたけど、", "父も母も少ない", "年金で細々と生活", "してます。"]}, {"box": [953, 1308, 1090, 1582], "vertical": true, "font_size": 28, "lines_coords": [[[1061.0, 1308.0], [1090.0, 1308.0], [1090.0, 1551.0], [1061.0, 1551.0]], [[1023.0, 1310.0], [1052.0, 1310.0], [1052.0, 1551.0], [1023.0, 1551.0]], [[988.0, 1310.0], [1015.0, 1310.0], [1015.0, 1582.0], [988.0, 1582.0]], [[953.0, 1310.0], [976.0, 1310.0], [976.0, 1460.0], [953.0, 1460.0]]], "lines": ["パチンコ行っては", "時間と金を浪費し", "テレビに向かっては", "文句を垂れ"]}, {"box": [139, 1343, 317, 1589], "vertical": true, "font_size": 30, "lines_coords": [[[286.0, 1345.0], [313.0, 1345.0], [313.0, 1526.0], [286.0, 1526.0]], [[249.0, 1350.0], [278.0, 1350.0], [278.0, 1526.0], [249.0, 1526.0]], [[205.0, 1343.0], [240.0, 1343.0], [242.0, 1589.0], [207.0, 1589.0]], [[174.0, 1345.0], [203.0, 1345.0], [201.0, 1526.0], [172.0, 1526.0]], [[139.0, 1348.0], [168.0, 1348.0], [168.0, 1539.0], [139.0, 1539.0]]], "lines": ["見栄っ張りで", "ひがみっぽい", "無闇に長生きする", "日本人の悪い", "例の典型です。"]}, {"box": [1094, 1659, 1241, 1937], "vertical": true, "font_size": 34, "lines_coords": [[[1202.0, 1659.0], [1237.0, 1659.0], [1241.0, 1863.0], [1206.0, 1863.0]], [[1167.0, 1661.0], [1202.0, 1661.0], [1200.0, 1937.0], [1165.0, 1937.0]], [[1133.0, 1663.0], [1162.0, 1663.0], [1162.0, 1906.0], [1133.0, 1906.0]], [[1094.0, 1661.0], [1129.0, 1661.0], [1129.0, 1921.0], [1094.0, 1921.0]]], "lines": ["今度もしまた", "でかい地震が来たら", "どさくさに紛れて", "殺してやりますよ。"]}, {"box": [724, 1854, 768, 1964], "vertical": true, "font_size": 44, "lines_coords": [[[724.0, 1854.0], [768.0, 1854.0], [768.0, 1964.0], [724.0, 1964.0]]], "lines": ["おい！！"]}, {"box": [292, 1674, 328, 1838], "vertical": true, "font_size": 31, "lines_coords": [[[292.0, 1674.0], [328.0, 1674.0], [328.0, 1838.0], [292.0, 1838.0]]], "lines": ["わかった！！"]}, {"box": [107, 1780, 245, 1967], "vertical": true, "font_size": 31, "lines_coords": [[[215.0, 1780.0], [245.0, 1780.0], [245.0, 1908.0], [215.0, 1908.0]], [[178.0, 1786.0], [207.0, 1786.0], [207.0, 1937.0], [178.0, 1937.0]], [[143.0, 1786.0], [172.0, 1786.0], [172.0, 1967.0], [143.0, 1967.0]], [[107.0, 1786.0], [137.0, 1786.0], [137.0, 1967.0], [107.0, 1967.0]]], "lines": ["三人とも", "轢かれれば", "当事者は誰も", "悲しまない！！"]}], "img_path": "107.png"}, {"version": "0.2.0-beta.6", "img_width": 1438, "img_height": 2127, "blocks": [{"box": [1165, 112, 1277, 313], "vertical": true, "font_size": 35, "lines_coords": [[[1242.0, 114.0], [1277.0, 114.0], [1277.0, 243.0], [1242.0, 243.0]], [[1207.0, 114.0], [1242.0, 114.0], [1242.0, 243.0], [1207.0, 243.0]], [[1165.0, 112.0], [1201.0, 112.0], [1205.0, 313.0], [1169.0, 313.0]]], "lines": ["．．．じゃあ", "ひとまず", "そういう事で。"]}, {"box": [777, 288, 847, 446], "vertical": true, "font_size": 35, "lines_coords": [[[812.0, 288.0], [847.0, 288.0], [847.0, 446.0], [812.0, 446.0]], [[777.0, 288.0], [812.0, 288.0], [812.0, 417.0], [777.0, 417.0]]], "lines": ["．．．そういう", "事かぁ？"]}, {"box": [215, 217, 319, 448], "vertical": true, "font_size": 28, "lines_coords": [[[288.0, 222.0], [317.0, 222.0], [317.0, 373.0], [288.0, 373.0]], [[253.0, 220.0], [280.0, 220.0], [280.0, 434.0], [253.0, 434.0]], [[216.0, 218.0], [243.0, 218.0], [243.0, 448.0], [216.0, 448.0]]], "lines": ["．．．そういう", "事じゃないかも", "しれませんけど。"]}, {"box": [1172, 564, 1311, 872], "vertical": true, "font_size": 30, "lines_coords": [[[1282.0, 567.0], [1311.0, 567.0], [1311.0, 718.0], [1282.0, 718.0]], [[1240.0, 564.0], [1275.0, 564.0], [1275.0, 812.0], [1240.0, 812.0]], [[1205.0, 564.0], [1236.0, 564.0], [1238.0, 872.0], [1207.0, 872.0]], [[1172.0, 569.0], [1199.0, 569.0], [1199.0, 822.0], [1172.0, 822.0]]], "lines": ["．．．要するに", "数学でもない限り", "問いに答えがあるとは", "限らないんですよ。"]}, {"box": [762, 733, 871, 948], "vertical": true, "font_size": 31, "lines_coords": [[[837.0, 735.0], [866.0, 735.0], [866.0, 889.0], [837.0, 889.0]], [[800.0, 735.0], [829.0, 735.0], [829.0, 947.0], [800.0, 947.0]], [[762.0, 733.0], [797.0, 733.0], [797.0, 843.0], [762.0, 843.0]]], "lines": ["受け入れる", "しかないんです", "結局は。"]}, {"box": [280, 616, 355, 758], "vertical": true, "font_size": 34, "lines_coords": [[[320.0, 616.0], [355.0, 616.0], [355.0, 754.0], [320.0, 754.0]], [[280.0, 618.0], [315.0, 618.0], [315.0, 758.0], [280.0, 758.0]]], "lines": ["だはあぁ", "ああッ！！"]}, {"box": [128, 776, 288, 951], "vertical": true, "font_size": 34, "lines_coords": [[[259.0, 781.0], [288.0, 781.0], [288.0, 947.0], [259.0, 947.0]], [[216.0, 781.0], [251.0, 781.0], [251.0, 951.0], [216.0, 951.0]], [[176.0, 785.0], [205.0, 785.0], [205.0, 949.0], [176.0, 949.0]], [[128.0, 776.0], [172.0, 776.0], [172.0, 886.0], [128.0, 886.0]]], "lines": ["おごるから", "風俗行って", "一回抜いて", "こい！！"]}, {"box": [1117, 1445, 1207, 1603], "vertical": true, "font_size": 47, "lines_coords": [[[1151.0, 1445.0], [1207.0, 1445.0], [1207.0, 1543.0], [1151.0, 1543.0]], [[1117.0, 1451.0], [1155.0, 1451.0], [1155.0, 1599.0], [1117.0, 1599.0]]], "lines": ["．．．や、", "いいっす。"]}, {"box": [295, 1645, 377, 1866], "vertical": true, "font_size": 38, "lines_coords": [[[338.0, 1649.0], [376.0, 1649.0], [376.0, 1819.0], [338.0, 1819.0]], [[295.0, 1647.0], [332.0, 1647.0], [334.0, 1863.0], [297.0, 1863.0]]], "lines": ["．．．俺、一応", "彼女いるんで。"]}], "img_path": "108.png"}, {"version": "0.2.0-beta.6", "img_width": 1435, "img_height": 2127, "blocks": [{"box": [1208, 99, 1266, 263], "vertical": true, "font_size": 62, "lines_coords": [[[1208.0, 101.0], [1260.0, 99.0], [1266.0, 261.0], [1214.0, 263.0]]], "lines": ["あぁ！！"]}, {"box": [1059, 338, 1189, 506], "vertical": true, "font_size": 62, "lines_coords": [[[1115.0, 338.0], [1189.0, 338.0], [11