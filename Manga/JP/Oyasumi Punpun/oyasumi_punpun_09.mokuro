lines": ["親父がズボラで建物の名義を法人に変えなかったもんで相続でもめちゃって。"]}, {"box": [284, 186, 425, 473], "vertical": true, "font_size": 33, "lines_coords": [[[396.0, 191.0], [425.0, 191.0], [425.0, 402.0], [396.0, 402.0]], [[355.0, 186.0], [390.0, 186.0], [392.0, 461.0], [357.0, 461.0]], [[319.0, 189.0], [350.0, 189.0], [353.0, 463.0], [321.0, 463.0]], [[284.0, 186.0], [313.0, 186.0], [317.0, 473.0], [288.0, 473.0]]], "lines": ["親父がズボラで", "建物の名義を法人に", "変えなかったもんで", "相続でもめちゃって。"]}, {"box": [911, 396, 1092, 670], "vertical": true, "font_size": 32, "lines_coords": [[[1055.0, 396.0], [1092.0, 396.0], [1092.0, 496.0], [1055.0, 496.0]], [[1021.0, 400.0], [1050.0, 400.0], [1050.0, 612.0], [1021.0, 612.0]], [[984.0, 398.0], [1013.0, 398.0], [1013.0, 670.0], [984.0, 670.0]], [[949.0, 398.0], [978.0, 398.0], [978.0, 612.0], [949.0, 612.0]], [[911.0, 400.0], [940.0, 400.0], [940.0, 490.0], [911.0, 490.0]]], "lines": ["他にも", "練馬と八王子に", "道場みたいな施設が", "あるんですけど", "．．．．．．"]}, {"box": [170, 542, 336, 781], "vertical": true, "font_size": 33, "lines_coords": [[[301.0, 548.0], [336.0, 548.0], [336.0, 718.0], [301.0, 718.0]], [[263.0, 548.0], [292.0, 548.0], [292.0, 781.0], [263.0, 781.0]], [[220.0, 548.0], [249.0, 548.0], [249.0, 778.0], [220.0, 778.0]], [[170.0, 542.0], [215.0, 542.0], [215.0, 633.0], [170.0, 633.0]]], "lines": ["．．．とはいえ", "潰しますけどね", "こんな胡散臭い", "会社。"]}, {"box": [1147, 1358, 1291, 1628], "vertical": true, "font_size": 31, "lines_coords": [[[1254.0, 1358.0], [1291.0, 1358.0], [1291.0, 1483.0], [1254.0, 1483.0]], [[1217.0, 1358.0], [1248.0, 1358.0], [1250.0, 1599.0], [1219.0, 1599.0]], [[1181.0, 1358.0], [1210.0, 1358.0], [1212.0, 1628.0], [1183.0, 1628.0]], [[1148.0, 1360.0], [1175.0, 1360.0], [1175.0, 1613.0], [1148.0, 1613.0]]], "lines": ["．．．元々は", "気孔を取り入れた", "ただの整体院だった", "はずなんだけどね。"]}, {"box": [336, 1391, 502, 1595], "vertical": true, "font_size": 38, "lines_coords": [[[463.0, 1393.0], [502.0, 1393.0], [502.0, 1495.0], [463.0, 1495.0]], [[423.0, 1391.0], [461.0, 1391.0], [454.0, 1595.0], [417.0, 1595.0]], [[382.0, 1393.0], [417.0, 1393.0], [417.0, 1595.0], [382.0, 1595.0]], [[340.0, 1391.0], [380.0, 1393.0], [375.0, 1510.0], [336.0, 1508.0]]], "lines": ["．．．あぁ", "僕は親父とは", "無関係の仕事", "ですよ。"]}, {"box": [785, 1746, 963, 2017], "vertical": true, "font_size": 29, "lines_coords": [[[932.0, 1746.0], [961.0, 1746.0], [961.0, 1956.0], [932.0, 1956.0]], [[895.0, 1746.0], [924.0, 1746.0], [924.0, 1927.0], [895.0, 1927.0]], [[857.0, 1746.0], [886.0, 1746.0], [886.0, 1908.0], [857.0, 1908.0]], [[818.0, 1746.0], [849.0, 1746.0], [851.0, 2016.0], [820.0, 2016.0]], [[785.0, 1746.0], [814.0, 1746.0], [814.0, 1969.0], [785.0, 1969.0]]], "lines": ["．．．まぁ、誰かに", "乗せられたん", "でしょうね。", "「先生」なんて呼ばれ", "ちゃったりして。"]}, {"box": [150, 1629, 214, 1716], "vertical": true, "font_size": 64, "lines_coords": [[[150.0, 1629.0], [214.0, 1629.0], [214.0, 1716.0], [150.0, 1716.0]]], "lines": ["東京都目駅ＴＥＬＦＡＸ"]}, {"box": [128, 1742, 248, 2024], "vertical": true, "font_size": 33, "lines_coords": [[[209.0, 1742.0], [245.0, 1742.0], [245.0, 2010.0], [209.0, 2010.0]], [[168.0, 1742.0], [203.0, 1742.0], [203.0, 2010.0], [168.0, 2010.0]], [[130.0, 1744.0], [159.0, 1744.0], [159.0, 2023.0], [130.0, 2023.0]]], "lines": ["大学の時起業して", "今は携帯サイトの", "運営とかやってて。"]}], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 1436, "img_height": 2127, "blocks": [{"box": [1129, 112, 1308, 388], "vertical": true, "font_size": 28, "lines_coords": [[[1275.0, 116.0], [1305.0, 116.0], [1305.0, 357.0], [1275.0, 357.0]], [[1236.0, 116.0], [1265.0, 116.0], [1265.0, 388.0], [1236.0, 388.0]], [[1201.0, 116.0], [1228.0, 116.0], [1228.0, 328.0], [1201.0, 328.0]], [[1165.0, 112.0], [1194.0, 112.0], [1192.0, 357.0], [1163.0, 357.0]], [[1130.0, 114.0], [1157.0, 114.0], [1157.0, 282.0], [1130.0, 282.0]]], "lines": ["僕から言わせりゃ", "未知のバワーやらを", "売り文句に商売", "するなんてかなり", "下品だよね。"]}, {"box": [725, 97, 844, 334], "vertical": true, "font_size": 35, "lines_coords": [[[808.0, 99.0], [843.0, 99.0], [843.0, 301.0], [808.0, 301.0]], [[766.0, 97.0], [802.0, 97.0], [802.0, 332.0], [766.0, 332.0]], [[725.0, 99.0], [760.0, 99.0], [760.0, 303.0], [725.0, 303.0]]], "lines": ["．．．でっでも！！", "この水は本当に", "いい水です！！"]}, {"box": [243, 280, 278, 427], "vertical": true, "font_size": 33, "lines_coords": [[[243.0, 280.0], [278.0, 280.0], [278.0, 427.0], [243.0, 427.0]]], "lines": ["はいはい。"]}, {"box": [1215, 899, 1296, 1076], "vertical": true, "font_size": 40, "lines_coords": [[[1251.0, 899.0], [1296.0, 899.0], [1296.0, 957.0], [1251.0, 957.0]], [[1215.0, 903.0], [1251.0, 903.0], [1251.0, 1075.0], [1215.0, 1075.0]]], "lines": ["あー", "もしもし．．．"]}, {"box": [916, 560, 989, 808], "vertical": true, "font_size": 34, "lines_coords": [[[953.0, 562.0], [989.0, 562.0], [989.0, 720.0], [953.0, 720.0]], [[918.0, 560.0], [949.0, 560.0], [947.0, 808.0], [916.0, 808.0]]], "lines": ["．．．あ、失礼", "ちょっと電話が．．"]}, {"box": [174, 521, 332, 758], "vertical": true, "font_size": 33, "lines_coords": [[[297.0, 523.0], [332.0, 523.0], [328.0, 724.0], [293.0, 724.0]], [[255.0, 521.0], [290.0, 521.0], [288.0, 758.0], [253.0, 758.0]], [[216.0, 523.0], [245.0, 523.0], [245.0, 758.0], [216.0, 758.0]], [[174.0, 525.0], [203.0, 525.0], [203.0, 724.0], [174.0, 724.0]]], "lines": ["．．．実体の無い", "ものを売り買い", "してるのは俺も", "同じだけど．．"]}, {"box": [330, 972, 365, 1142], "vertical": true, "font_size": 34, "lines_coords": [[[330.0, 972.0], [365.0, 972.0], [365.0, 1142.0], [330.0, 1142.0]]], "lines": ["小坊ちゃん"]}, {"box": [290, 1013, 322, 1075], "vertical": true, "font_size": 34, "lines_coords": [[[290.0, 1013.0], [322.0, 1013.0], [322.0, 1075.0], [290.0, 1075.0]]], "lines": ["．．．"]}, {"box": [166, 1734, 270, 1966], "vertical": true, "font_size": 44, "lines_coords": [[[222.0, 1734.0], [266.0, 1734.0], [270.0, 1964.0], [226.0, 1964.0]], [[166.0, 1734.0], [209.0, 1734.0], [209.0, 1921.0], [166.0, 1921.0]]], "lines": ["．．．ＪＵＳＴ", "ＦＩＴ！！"]}], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 1434, "img_height": 2127, "blocks": [{"box": [1113, 103, 1240, 481], "vertical": true, "font_size": 38, "lines_coords": [[[1199.0, 103.0], [1240.0, 103.0], [1240.0, 481.0], [1199.0, 481.0]], [[1157.0, 105.0], [1195.0, 105.0], [1197.0, 479.0], [1159.0, 479.0]], [[1113.0, 105.0], [1149.0, 105.0], [1153.0, 479.0], [1118.0, 479.0]]], "lines": ["．．．グッドなヴァイヴスが", "君のシンコペーションと", "いなせにユニゾンした．．．"]}, {"box": [173, 635, 333, 974], "vertical": true, "font_size": 34, "lines_coords": [[[295.0, 635.0], [330.0, 635.0], [332.0, 938.0], [297.0, 938.0]], [[253.0, 637.0], [288.0, 637.0], [288.0, 974.0], [253.0, 974.0]], [[207.0, 635.0], [245.0, 635.0], [249.0, 943.0], [211.0, 943.0]], [[174.0, 639.0], [203.0, 639.0], [203.0, 907.0], [174.0, 907.0]]], "lines": ["．．．つまりこの再会は", "アカシックレコードに", "刻まれていたという", "事で相違ない．．．"]}, {"box": [1064, 1092, 1207, 1368], "vertical": true, "font_size": 30, "lines_coords": [[[1172.0, 1092.0], [1207.0, 1092.0], [1207.0, 1217.0], [1172.0, 1217.0]], [[1138.0, 1094.0], [1167.0, 1094.0], [1167.0, 1308.0], [1138.0, 1308.0]], [[1101.0, 1096.0], [1130.0, 1096.0], [1130.0, 1366.0], [1101.0, 1366.0]], [[1064.0, 1092.0], [1091.0, 1092.0], [1091.0, 1366.0], [1064.0, 1366.0]]], "lines": ["．．．やはり", "君と僕の振動は", "完全五度の関係性で", "強く結ばれている．．．"]}, {"box": [180, 1188, 257, 1392], "vertical": true, "font_size": 29, "lines_coords": [[[224.0, 1190.0], [253.0, 1190.0], [253.0, 1360.0], [224.0, 1360.0]], [[180.0, 1190.0], [209.0, 1190.0], [209.0, 1389.0], [180.0, 1389.0]]], "lines": ["．．．君もそう", "思わないか？"]}, {"box": [1140, 1555, 1219, 1759], "vertical": true, "font_size": 36, "lines_coords": [[[1184.0, 1557.0], [1219.0, 1557.0], [1219.0, 1726.0], [1184.0, 1726.0]], [[1140.0, 1555.0], [1176.0, 1555.0], [1176.0, 1759.0], [1140.0, 1759.0]]], "lines": ["．．．では僕は", "君に問う．．．"]}, {"box": [332, 1597, 432, 1761], "vertical": true, "font_size": 40, "lines_coords": [[[372.0, 1597.0], [432.0, 1597.0], [432.0, 1726.0], [372.0, 1726.0]], [[332.0, 1603.0], [369.0, 1603.0], [369.0, 1761.0], [332.0, 1761.0]]], "lines": ["．．．おい", "鼻提灯！！"]}, {"box": [203, 1746, 278, 1917], "vertical": true, "font_size": 40, "lines_coords": [[[243.0, 1746.0], [278.0, 1746.0], [278.0, 1886.0], [243.0, 1886.0]], [[203.0, 1748.0], [232.0, 1748.0], [232.0, 1917.0], [203.0, 1917.0]]], "lines": ["君はまだ", "この世界を"]}, {"box": [160, 1748, 279, 1950], "vertical": true, "font_size": 29, "lines_coords": [[[160.0, 1753.0], [189.0, 1753.0], [189.0, 1950.0], [160.0, 1950.0]]], "lines": ["愛せるかね！？"]}], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 1431, "img_height": 2127, "blocks": [{"box": [1200, 64, 1318, 355], "vertical": true, "font_size": 31, "lines_coords": [[[1271.0, 64.0], [1306.0, 64.0], [1306.0, 230.0], [1271.0, 230.0]], [[1237.0, 68.0], [1266.0, 68.0], [1266.0, 224.0], [1237.0, 224.0]], [[1200.0, 66.0], [1229.0, 66.0], [1231.0, 355.0], [1202.0, 355.0]]], "lines": ["．．．おい敏樹、", "ブラブラ油", "売ってんじゃねぇよ。"]}, {"box": [716, 93, 857, 367], "vertical": true, "font_size": 33, "lines_coords": [[[822.0, 93.0], [857.0, 93.0], [857.0, 338.0], [822.0, 338.0]], [[785.0, 93.0], [820.0, 93.0], [820.0, 353.0], [785.0, 353.0]], [[749.0, 95.0], [785.0, 95.0], [783.0, 367.0], [747.0, 367.0]], [[716.0, 95.0], [743.0, 95.0], [743.0, 338.0], [716.0, 338.0]]], "lines": ["今後は親父からの", "小遣いも無いんだ。", "ルンペンの真似事は", "もう出来ないぞ？"]}, {"box": [153, 305, 319, 508], "vertical": true, "font_size": 32, "lines_coords": [[[282.0, 305.0], [311.0, 305.0], [311.0, 438.0], [282.0, 438.0]], [[243.0, 307.0], [272.0, 307.0], [272.0, 440.0], [243.0, 440.0]], [[197.0, 305.0], [232.0, 305.0], [232.0, 508.0], [197.0, 508.0]], [[153.0, 305.0], [189.0, 305.0], [193.0, 490.0], [157.0, 490.0]]], "lines": ["都知事選", "出馬とか", "くだらん遊び", "しやがって。"]}, {"box": [947, 544, 1092, 791], "vertical": true, "font_size": 31, "lines_coords": [[[1055.0, 544.0], [1092.0, 544.0], [1092.0, 643.0], [1055.0, 643.0]], [[1021.0, 548.0], [1050.0, 548.0], [1050.0, 760.0], [1021.0, 760.0]], [[984.0, 544.0], [1013.0, 544.0], [1011.0, 791.0], [982.0, 791.0]], [[949.0, 546.0], [978.0, 546.0], [976.0, 760.0], [947.0, 760.0]]], "lines": ["こんな", "若い子達ですら", "こうして真面目に", "働いてんだぜ？"]}, {"box": [1212, 922, 1289, 1102], "vertical": true, "font_size": 34, "lines_coords": [[[1252.0, 924.0], [1289.0, 924.0], [1289.0, 1063.0], [1252.0, 1063.0]], [[1212.0, 922.0], [1248.0, 922.0], [1248.0, 1102.0], [1212.0, 1102.0]]], "lines": ["「あれ？」", "じゃねーよ。"]}, {"box": [1057, 1163, 1212, 1368], "vertical": true, "font_size": 34, "lines_coords": [[[1183.0, 1163.0], [1212.0, 1163.0], [1212.0, 1329.0], [1183.0, 1329.0]], [[1142.0, 1163.0], [1177.0, 1163.0], [1177.0, 1335.0], [1142.0, 1335.0]], [[1098.0, 1163.0], [1134.0, 1163.0], [1129.0, 1368.0], [1094.0, 1368.0]], [[1061.0, 1163.0], [1092.0, 1163.0], [1088.0, 1333.0], [1057.0, 1333.0]]], "lines": ["まさか当選", "するとでも", "思ってたか！？", "正気かよ！？"]}, {"box": [220, 1248, 363, 1489], "vertical": true, "font_size": 29, "lines_coords": [[[332.0, 1252.0], [361.0, 1252.0], [361.0, 1460.0], [332.0, 1460.0]], [[294.0, 1248.0], [324.0, 1248.0], [319.0, 1489.0], [290.0, 1489.0]], [[257.0, 1250.0], [286.0, 1250.0], [286.0, 1399.0], [257.0, 1399.0]], [[220.0, 1252.0], [249.0, 1252.0], [249.0, 1460.0], [220.0, 1460.0]]], "lines": ["お前がどれだけ", "ネットで笑い者に", "されてるか", "知ってんのか？"]}, {"box": [166, 1817, 247, 1958], "vertical": true, "font_size": 38, "lines_coords": [[[209.0, 1819.0], [247.0, 1819.0], [247.0, 1958.0], [209.0, 1958.0]], [[166.0, 1817.0], [203.0, 1817.0], [203.0, 1956.0], [166.0, 1956.0]]], "lines": ["．．．弟さん", "ですか？"]}], "img_path": "130.png"}, {"version": "0.2.0-beta.6", "img_width": 1431, "img_height": 2127, "blocks": [{"box": [1115, 105, 1260, 371], "vertical": true, "font_size": 34, "lines_coords": [[[1229.0, 108.0], [1258.0, 108.0], [1260.0, 371.0], [1231.0, 371.0]], [[1194.0, 112.0], [1223.0, 112.0], [1223.0, 324.0], [1194.0, 324.0]], [[1150.0, 105.0], [1185.0, 105.0], [1190.0, 297.0], [1154.0, 297.0]], [[1115.0, 108.0], [1152.0, 108.0], [1152.0, 216.0], [1115.0, 216.0]]], "lines": ["．．．あいつは昔ッから", "何考えてんだか", "わからないん", "ですよ。"]}, {"box": [1055, 446, 1217, 704], "vertical": true, "font_size": 34, "lines_coords": [[[1181.0, 450.0], [1217.0, 450.0], [1217.0, 685.0], [1181.0, 685.0]], [[1136.0, 448.0], [1171.0, 448.0], [1175.0, 656.0], [1140.0, 656.0]], [[1096.0, 448.0], [1131.0, 448.0], [1134.0, 687.0], [1098.0, 687.0]], [[1057.0, 446.0], [1092.0, 446.0], [1090.0, 704.0], [1055.0, 704.0]]], "lines": ["ただ、そのくせ", "親父と同じで", "ペテンが他人に", "効くんだよなァ。"]}, {"box": [197, 387, 357, 683], "vertical": true, "font_size": 160, "lines_coords": [[[197.0, 387.0], [357.0, 387.0], [357.0, 683.0], [197.0, 683.0]]], "lines": ["．．．現に今もおかしな仲間集めて珍妙な活動やってるみたいだし、"]}, {"box": [195, 386, 355, 691], "vertical": true, "font_size": 36, "lines_coords": [[[319.0, 386.0], [355.0, 386.0], [355.0, 556.0], [319.0, 556.0]], [[278.0, 388.0], [313.0, 388.0], [313.0, 691.0], [278.0, 691.0]], [[234.0, 386.0], [270.0, 386.0], [270.0, 691.0], [234.0, 691.0]], [[195.0, 388.0], [230.0, 388.0], [230.0, 567.0], [195.0, 567.0]]], "lines": ["．．．現に今も", "おかしな仲間集めて", "珍妙な活動やってる", "みたいだし、"]}, {"box": [153, 749, 315, 1088], "vertical": true, "font_size": 36, "lines_coords": [[[278.0, 749.0], [313.0, 749.0], [315.0, 1059.0], [280.0, 1059.0]], [[234.0, 751.0], [270.0, 751.0], [274.0, 1026.0], [238.0, 1026.0]], [[193.0, 751.0], [230.0, 751.0], [232.0, 1088.0], [195.0, 1088.0]], [[153.0, 756.0], [189.0, 756.0], [189.0, 972.0], [153.0, 972.0]]], "lines": ["親父の商才のほうは", "俺に引き継がれて", "兄弟で見事に真っ二つ", "って訳ですよ。"]}, {"box": [1119, 1171, 1198, 1444], "vertical": true, "font_size": 35, "lines_coords": [[[1163.0, 1171.0], [1198.0, 1171.0], [1196.0, 1443.0], [1161.0, 1443.0]], [[1119.0, 1175.0], [1154.0, 1175.0], [1154.0, 1410.0], [1119.0, 1410.0]]], "lines": ["「相模原三角事件」", "って知ってる？"]}, {"box": [803, 1298, 841, 1433], "vertical": true, "font_size": 38, "lines_coords": [[[803.0, 1298.0], [841.0, 1298.0], [841.0, 1429.0], [803.0, 1429.0]]], "lines": ["いや．．．"]}, {"box": [412, 1208, 591, 1512], "vertical": true, "font_size": 30, "lines_coords": [[[558.0, 1210.0], [587.0, 1210.0], [587.0, 1451.0], [558.0, 1451.0]], [[519.0, 1208.0], [550.0, 1208.0], [552.0, 1422.0], [521.0, 1422.0]], [[483.0, 1208.0], [513.0, 1208.0], [515.0, 1451.0], [486.0, 1451.0]], [[446.0, 1210.0], [475.0, 1210.0], [477.0, 1512.0], [448.0, 1512.0]], [[413.0, 1215.0], [442.0, 1215.0], [442.0, 1404.0], [413.0, 1404.0]]], "lines": ["たった一晩の間で", "中学校の校庭に", "巨大な三角錐状に", "机が積み上げられてた", "っていう事件。"]}, {"box": [679, 1778, 797, 2045], "vertical": true, "font_size": 34, "lines_coords": [[[760.0, 1778.0], [797.0, 1778.0], [797.0, 1927.0], [760.0, 1927.0]], [[716.0, 1778.0], [751.0, 1778.0], [756.0, 2045.0], [720.0, 2045.0]], [[679.0, 1780.0], [708.0, 1780.0], [708.0, 1960.0], [679.0, 1960.0]]], "lines": ["．．．当然か、", "あなたの生まれる", "前だよ多分。"]}, {"box": [110, 1742, 287, 2013], "vertical": true, "font_size": 29, "lines_coords": [[[255.0, 1744.0], [284.0, 1744.0], [284.0, 1954.0], [255.0, 1954.0]], [[216.0, 1742.0], [247.0, 1742.0], [249.0, 1989.0], [218.0, 1989.0]], [[178.0, 1742.0], [207.0, 1742.0], [211.0, 2012.0], [182.0, 2012.0]], [[143.0, 1742.0], [172.0, 1742.0], [174.0, 1985.0], [145.0, 1985.0]], [[110.0, 1746.0], [137.0, 1746.0], [137.0, 1991.0], [110.0, 1991.0]]], "lines": ["使われた教室の", "机の数は九百以上、", "そしてその三角錐は", "正確な正四面体に", "なってたんだとさ。"]}], "img_path": "131.png"}, {"version": "0.2.0-beta.6", "img_width": 1436, "img_height": 2127, "blocks": [{"box": [1197, 91, 1305, 307], "vertical": true, "font_size": 30, "lines_coords": [[[1275.0, 93.0], [1305.0, 93.0], [1305.0, 307.0], [1275.0, 307.0]], [[1238.0, 91.0], [1267.0, 91.0], [1265.0, 274.0], [1236.0, 274.0]], [[1201.0, 91.0], [1232.0, 91.0], [1228.0, 257.0], [1197.0, 257.0]]], "lines": ["：実行したのは", "当時中学生の", "男女十数人。"]}, {"box": [617, 83, 660, 226], "vertical": true, "font_size": 37, "lines_coords": [[[617.0, 83.0], [660.0, 83.0], [660.0, 226.0], [617.0, 226.0]]], "lines": ["あの．．．"]}, {"box": [446, 145, 594, 369], "vertical": true, "font_size": 37, "lines_coords": [[[550.0, 145.0], [594.0, 145.0], [594.0, 255.0], [550.0, 255.0]], [[517.0, 151.0], [552.0, 151.0], [552.0, 276.0], [517.0, 276.0]], [[480.0, 153.0], [515.0, 153.0], [515.0, 282.0], [480.0, 282.0]], [[446.0, 155.0], [473.0, 155.0], [473.0, 369.0], [446.0, 369.0]]], "lines": ["なんで", "わざわざ", "そんな事", "するんですか？"]}, {"box": [222, 336, 257, 467], "vertical": true, "font_size": 33, "lines_coords": [[[222.0, 336.0], [257.0, 336.0], [257.0, 467.0], [222.0, 467.0]]], "lines": ["さぁ．．．"]}, {"box": [916, 477, 1093, 751], "vertical": true, "font_size": 29, "lines_coords": [[[1061.0, 477.0], [1091.0, 477.0], [1091.0, 751.0], [1061.0, 751.0]], [[1024.0, 479.0], [1053.0, 479.0], [1053.0, 693.0], [1024.0, 693.0]], [[989.0, 479.0], [1018.0, 479.0], [1018.0, 691.0], [989.0, 691.0]], [[951.0, 477.0], [980.0, 477.0], [980.0, 691.0], [951.0, 691.0]], [[916.0, 479.0], [943.0, 479.0], [943.0, 704.0], [916.0, 704.0]]], "lines": ["それらを呼びかけて", "指示をした弟は", "学校の用務員を", "監禁した主犯で", "補導されたけど。"]}, {"box": [1203, 893, 1284, 1113], "vertical": true, "font_size": 36, "lines_coords": [[[1246.0, 895.0], [1284.0, 895.0], [1284.0, 1034.0], [1246.0, 1034.0]], [[1207.0, 893.0], [1242.0, 893.0], [1238.0, 1111.0], [1203.0, 1111.0]]], "lines": ["．．．それは", "解せませんね。"]}, {"box": [137, 544, 280, 791], "vertical": true, "font_size": 33, "lines_coords": [[[245.0, 544.0], [280.0, 544.0], [280.0, 702.0], [245.0, 702.0]], [[211.0, 548.0], [241.0, 548.0], [241.0, 791.0], [211.0, 791.0]], [[174.0, 546.0], [203.0, 546.0], [201.0, 731.0], [172.0, 731.0]], [[137.0, 546.0], [172.0, 546.0], [172.0, 656.0], [137.0, 656.0]]], "lines": ["意味なんて", "ないんじゃない？", "弟はそういう", "奴だよ。"]}, {"box": [214, 1264, 377, 1518], "vertical": true, "font_size": 34, "lines_coords": [[[338.0, 1269.0], [374.0, 1269.0], [374.0, 1439.0], [338.0, 1439.0]], [[295.0, 1267.0], [330.0, 1267.0], [330.0, 1503.0], [295.0, 1503.0]], [[255.0, 1264.0], [290.0, 1264.0], [290.0, 1437.0], [255.0, 1437.0]], [[216.0, 1267.0], [247.0, 1267.0], [245.0, 1518.0], [214.0, 1518.0]]], "lines": ["仮に理由が", "あったとしても", "常人が納得", "できるかどうか。"]}, {"box": [1169, 1686, 1292, 1898], "vertical": true, "font_size": 35, "lines_coords": [[[1257.0, 1688.0], [1292.0, 1688.0], [1292.0, 1859.0], [1257.0, 1859.0]], [[1215.0, 1690.0], [1251.0, 1690.0], [1251.0, 1827.0], [1215.0, 1827.0]], [[1174.0, 1686.0], [1209.0, 1686.0], [1205.0, 1898.0], [1169.0, 1898.0]]], "lines": ["．．．あぁでも", "こんな事", "言ってたかな、"]}, {"box": [955, 1734, 1080, 1985], "vertical": true, "font_size": 35, "lines_coords": [[[1045.0, 1734.0], [1080.0, 1734.0], [1076.0, 1923.0], [1041.0, 1923.0]], [[1001.0, 1736.0], [1036.0, 1736.0], [1036.0, 1937.0], [1001.0, 1937.0]], [[958.0, 1736.0], [993.0, 1736.0], [991.0, 1985.0], [955.0, 1985.0]]], "lines": ["「正四面体は", "最も安定した", "正多面体だから」"]}], "img_path": "132.png"}, {"version": "0.2.0-beta.6", "img_width": 1436, "img_height": 2127, "blocks": [{"box": [1047, 205, 1211, 448], "vertical": true, "font_size": 36, "lines_coords": [[[1167.0, 205.0], [1211.0, 205.0], [1211.0, 334.0], [1167.0, 334.0]], [[1130.0, 209.0], [1161.0, 209.0], [1163.0, 415.0], [1132.0, 415.0]], [[1088.0, 211.0], [1124.0, 211.0], [1124.0, 448.0], [1088.0, 448.0]], [[1047.0, 211.0], [1082.0, 211.0], [1082.0, 353.0], [1047.0, 353.0]]], "lines": ["「これで", "振動の乱れを", "安定させる事が", "できた。」"]}, {"box": [168, 492, 349, 768], "vertical": true, "font_size": 33, "lines_coords": [[[313.0, 492.0], [349.0, 492.0], [349.0, 693.0], [313.0, 693.0]], [[276.0, 494.0], [311.0, 494.0], [311.0, 618.0], [276.0, 618.0]], [[238.0, 494.0], [274.0, 494.0], [274.0, 768.0], [238.0, 768.0]], [[205.0, 496.0], [234.0, 496.0], [234.0, 706.0], [205.0, 706.0]], [[168.0, 496.0], [197.0, 496.0], [197.0, 762.0], [168.0, 762.0]]], "lines": ["「またこうして", "人知れず", "未曾有の大厄災から", "たくさんの命が", "救われたんだ」って。"]}, {"box": [1178, 1096, 1282, 1397], "vertical": true, "font_size": 32, "lines_coords": [[[1253.0, 1098.0], [1282.0, 1098.0], [1282.0, 1279.0], [1253.0, 1279.0]], [[1213.0, 1096.0], [1244.0, 1096.0], [1246.0, 1397.0], [1215.0, 1397.0]], [[1178.0, 1096.0], [1207.0, 1096.0], [1207.0, 1341.0], [1178.0, 1341.0]]], "lines": ["．．．だがしかし", "奴らはジャンプ方式に", "強大になり続ける"]}, {"box": [960, 1213, 1070, 1456], "vertical": true, "font_size": 32, "lines_coords": [[[1034.0, 1213.0], [1070.0, 1213.0], [1070.0, 1399.0], [1034.0, 1399.0]], [[995.0, 1215.0], [1030.0, 1215.0], [1032.0, 1454.0], [997.0, 1454.0]], [[960.0, 1217.0], [991.0, 1217.0], [993.0, 1456.0], [962.0, 1456.0]]], "lines": ["．．．今後の奴は", "かつてないほどの", "ホンマモンだ．．．"]}, {"box": [336, 1121, 423, 1264], "vertical": true, "font_size": 35, "lines_coords": [[[378.0, 1123.0], [423.0, 1123.0], [423.0, 1231.0], [378.0, 1231.0]], [[336.0, 1121.0], [382.0, 1121.0], [382.0, 1264.0], [336.0, 1264.0]]], "lines": ["．．．あと", "二人．．．"]}, {"box": [153, 1208, 293, 1481], "vertical": true, "font_size": 35, "lines_coords": [[[257.0, 1208.0], [293.0, 1208.0], [293.0, 1362.0], [257.0, 1362.0]], [[224.0, 1210.0], [253.0, 1210.0], [253.0, 1451.0], [224.0, 1451.0]], [[187.0, 1208.0], [216.0, 1208.0], [216.0, 1481.0], [187.0, 1481.0]], [[153.0, 1210.0], [176.0, 1210.0], [176.0, 1358.0], [153.0, 1358.0]]], "lines": ["あと二人で", "絶悪な不協和音に", "僕は立ち向かう事が", "てきる．．．"]}, {"box": [1165, 1591, 1282, 1796], "vertical": true, "font_size": 32, "lines_coords": [[[1246.0, 1593.0], [1282.0, 1593.0], [1282.0, 1761.0], [1246.0, 1761.0]], [[1207.0, 1591.0], [1244.0, 1591.0], [1240.0, 1796.0], [1203.0, 1796.0]], [[1165.0, 1593.0], [1201.0, 1593.0], [1201.0, 1730.0], [1165.0, 1730.0]]], "lines": ["それなのに", "ラヴァーズは", "何故ッ！！"]}, {"box": [972, 1690, 1113, 1962], "vertical": true, "font_size": 32, "lines_coords": [[[1084.0, 1690.0], [1113.0, 1690.0], [1113.0, 1900.0], [1084.0, 1900.0]], [[1047.0, 1692.0], [1076.0, 1692.0], [1076.0, 1931.0], [1047.0, 1931.0]], [[1009.0, 1692.0], [1039.0, 1692.0], [1039.0, 1962.0], [1009.0, 1962.0]], [[972.0, 1690.0], [1001.0, 1690.0], [1001.0, 1873.0], [972.0, 1873.0]]], "lines": ["．．．なぜ目の前の", "絶望に目も向けず", "破滅へ突き進もうと", "するのか．．．"]}, {"box": [184, 1721, 308, 1994], "vertical": true, "font_size": 36, "lines_coords": [[[272.0, 1724.0], [307.0, 1724.0], [307.0, 1994.0], [272.0, 1994.0]], [[230.0, 1724.0], [266.0, 1724.0], [266.0, 1929.0], [230.0, 1929.0]], [[184.0, 1721.0], [220.0, 1721.0], [224.0, 1960.0], [189.0, 1960.0]]], "lines": ["やはりこの世界は", "救う価値など", "ないのか．．．．！？"]}], "img_path": "133.png"}, {"version": "0.2.0-beta.6", "img_width": 1437, "img_height": 2127, "blocks": [{"box": [982, 128, 1061, 303], "vertical": true, "font_size": 36, "lines_coords": [[[1025.0, 128.0], [1061.0, 128.0], [1061.0, 303.0], [1025.0, 303.0]], [[982.0, 130.0], [1019.0, 130.0], [1019.0, 249.0], [982.0, 249.0]]], "lines": ["僕はとても", "悲しい。"]}, {"box": [525, 128, 569, 317], "vertical": true, "font_size": 37, "lines_coords": [[[529.0, 128.0], [566.0, 128.0], [562.0, 315.0], [525.0, 315.0]]], "lines": ["「黒点」だ。"]}, {"box": [1135, 955, 1297, 1127], "vertical": true, "font_size": 36, "lines_coords": [[[1260.0, 955.0], [1297.0, 955.0], [1297.0, 1094.0], [1260.0, 1094.0]], [[1218.0, 955.0], [1254.0, 955.0], [1254.0, 1127.0], [1218.0, 1127.0]], [[1177.0, 957.0], [1212.0, 957.0], [1212.0, 1094.0], [1177.0, 1094.0]], [[1135.0, 955.0], [1171.0, 955.0], [1171.0, 1096.0], [1135.0, 1096.0]]], "lines": ["どこかに", "潜んでいる", "圧倒的な", "「黒点」が"]}, {"box": [670, 596, 778, 782], "vertical": true, "font_size": 32, "lines_coords": [[[741.0, 596.0], [778.0, 596.0], [778.0, 695.0], [741.0, 695.0]], [[708.0, 598.0], [737.0, 598.0], [737.0, 781.0], [708.0, 781.0]], [[670.0, 600.0], [699.0, 600.0], [699.0, 778.0], [670.0, 778.0]]], "lines": ["みんな", "出来る子だと", "いうのに．．．"]}, {"box": [182, 573, 276, 802], "vertical": true, "font_size": 41, "lines_coords": [[[230.0, 573.0], [276.0, 573.0], [272.0, 743.0], [226.0, 743.0]], [[184.0, 579.0], [220.0, 579.0], [220.0, 797.0], [184.0, 797.0]]], "lines": ["「黒点」が", "潜んでいる。"]}, {"box": [213, 1040, 238, 1082], "vertical": true, "font_size": 32, "lines_coords": [[[213.0, 1040.0], [238.0, 1040.0], [238.0, 1082.0], [213.0, 1082.0]]], "lines": ["．．．"]}, {"box": [1154, 1391, 1275, 1628], "vertical": true, "font_size": 34, "lines_coords": [[[1237.0, 1393.0], [1275.0, 1393.0], [1275.0, 1530.0], [1237.0, 1530.0]], [[1196.0, 1391.0], [1231.0, 1391.0], [1231.0, 1628.0], [1196.0, 1628.0]], [[1154.0, 1391.0], [1189.0, 1391.0], [1189.0, 1564.0], [1154.0, 1564.0]]], "lines": ["でも僕は", "それでも世界を", "救いたい！！"]}, {"box": [249, 978, 369, 1215], "vertical": true, "font_size": 32, "lines_coords": [[[334.0, 978.0], [369.0, 978.0], [369.0, 1188.0], [334.0, 1188.0]], [[290.0, 980.0], [326.0, 980.0], [326.0, 1186.0], [290.0, 1186.0]], [[249.0, 978.0], [280.0, 978.0], [282.0, 1215.0], [251.0, 1215.0]]], "lines": ["ラヴァーズを", "狂わせている", "としか思えない"]}, {"box": [319, 1460, 384, 1670], "vertical": true, "font_size": 34, "lines_coords": [[[357.0, 1460.0], [384.0, 1460.0], [384.0, 1643.0], [357.0, 1643.0]], [[319.0, 1460.0], [346.0, 1460.0], [346.0, 1670.0], [319.0, 1670.0]]], "lines": ["君は見たいと", "思わないか．．．"]}, {"box": [986, 1564, 1100, 1832], "vertical": true, "font_size": 34, "lines_coords": [[[1065.0, 1564.0], [1100.0, 1564.0], [1100.0, 1767.0], [1065.0, 1767.0]], [[1027.0, 1568.0], [1056.0, 1568.0], [1056.0, 1798.0], [1027.0, 1798.0]], [[986.0, 1564.0], [1015.0, 1564.0], [1015.0, 1832.0], [986.0, 1832.0]]], "lines": ["なぜなら僕は", "君達を圧倒的に", "愛しているから！！"]}, {"box": [170, 1740, 313, 1981], "vertical": true, "font_size": 34, "lines_coords": [[[272.0, 1740.0], [313.0, 1740.0], [313.0, 1981.0], [272.0, 1981.0]], [[222.0, 1740.0], [259.0, 1740.0], [259.0, 1940.0], [222.0, 1940.0]], [[174.0, 1740.0], [211.0, 1740.0], [207.0, 1979.0], [170.0, 1979.0]]], "lines": ["笑顔と喜びに", "満ち溢れた", "新世界を．．．："]}], "img_path": "134.png"}, {"version": "0.2.0-beta.6", "img_width": 1430, "img_height": 2127, "blocks": [{"box": [1043, 189, 1232, 518], "vertical": true, "font_size": 56, "lines_coords": [[[1174.0, 189.0], [1232.0, 189.0], [1232.0, 359.0], [1174.0, 359.0]], [[1109.0, 189.0], [1168.0, 189.0], [1168.0, 517.0], [1109.0, 517.0]], [[1043.0, 191.0], [1093.0, 191.0], [1099.0, 465.0], [1049.0, 465.0]]], "lines": ["世界は", "もっと美しく", "なれるッ！！"]}, {"box": [1111, 1071, 1228, 1310], "vertical": true, "font_size": 40, "lines_coords": [[[1184.0, 1071.0], [1228.0, 1071.0], [1228.