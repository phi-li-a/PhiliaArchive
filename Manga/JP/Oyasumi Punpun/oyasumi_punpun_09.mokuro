l": true, "font_size": 42, "lines_coords": [[[1003.0, 205.0], [1045.0, 205.0], [1047.0, 510.0], [1005.0, 510.0]]], "lines": ["．．．さわんないで。"]}, {"box": [351, 1636, 459, 1915], "vertical": true, "font_size": 39, "lines_coords": [[[430.0, 1645.0], [459.0, 1645.0], [459.0, 1821.0], [430.0, 1821.0]], [[390.0, 1640.0], [426.0, 1640.0], [426.0, 1915.0], [390.0, 1915.0]], [[351.0, 1636.0], [394.0, 1636.0], [394.0, 1744.0], [351.0, 1744.0]]], "lines": ["こういう時に", "そういう事しちゃう", "君って、"]}, {"box": [160, 1832, 284, 1975], "vertical": true, "font_size": 39, "lines_coords": [[[241.0, 1832.0], [284.0, 1832.0], [284.0, 1975.0], [241.0, 1975.0]], [[201.0, 1836.0], [239.0, 1836.0], [239.0, 1971.0], [201.0, 1971.0]], [[160.0, 1832.0], [205.0, 1832.0], [205.0, 1923.0], [160.0, 1923.0]]], "lines": ["．．．すごく", "軽率だと", "思う。"]}], "img_path": "183.png"}, {"version": "0.2.0-beta.6", "img_width": 1438, "img_height": 2127, "blocks": [{"box": [1157, 124, 1296, 309], "vertical": true, "font_size": 29, "lines_coords": [[[1265.0, 128.0], [1294.0, 128.0], [1294.0, 307.0], [1265.0, 307.0]], [[1223.0, 124.0], [1259.0, 124.0], [1259.0, 280.0], [1223.0, 280.0]], [[1192.0, 128.0], [1221.0, 128.0], [1221.0, 309.0], [1192.0, 309.0]], [[1159.0, 132.0], [1182.0, 132.0], [1182.0, 280.0], [1159.0, 280.0]]], "lines": ["君の精一杯の", "気づかいの", "つもりなんだ", "ろうけど．．．"]}, {"box": [677, 128, 818, 371], "vertical": true, "font_size": 29, "lines_coords": [[[787.0, 130.0], [816.0, 130.0], [816.0, 280.0], [787.0, 280.0]], [[750.0, 130.0], [779.0, 130.0], [779.0, 371.0], [750.0, 371.0]], [[714.0, 128.0], [743.0, 128.0], [739.0, 313.0], [710.0, 313.0]], [[677.0, 130.0], [706.0, 130.0], [706.0, 282.0], [677.0, 282.0]]], "lines": ["．．．編集部の", "持ち込みの帰りに", "君が言った事", "憶えてる？"]}, {"box": [643, 117, 810, 696], "vertical": true, "font_size": 35, "lines_coords": [[[675.0, 429.0], [710.0, 429.0], [708.0, 670.0], [673.0, 670.0]]], "lines": ["「君は天才だから"]}, {"box": [714, 436, 781, 587], "vertical": true, "font_size": 30, "lines_coords": [[[748.0, 436.0], [779.0, 436.0], [781.0, 587.0], [750.0, 587.0]], [[714.0, 436.0], [743.0, 436.0], [743.0, 556.0], [714.0, 556.0]]], "lines": ["へコんでる", "あたしに"]}, {"box": [637, 436, 667, 610], "vertical": true, "font_size": 30, "lines_coords": [[[637.0, 436.0], [667.0, 436.0], [667.0, 610.0], [637.0, 610.0]]], "lines": ["大丈夫」って。"]}, {"box": [216, 299, 363, 483], "vertical": true, "font_size": 32, "lines_coords": [[[334.0, 301.0], [363.0, 301.0], [363.0, 481.0], [334.0, 481.0]], [[297.0, 301.0], [326.0, 301.0], [326.0, 483.0], [297.0, 483.0]], [[257.0, 301.0], [293.0, 301.0], [293.0, 483.0], [257.0, 483.0]], [[216.0, 299.0], [261.0, 299.0], [261.0, 405.0], [216.0, 405.0]]], "lines": ["そういう君の", "配慮に欠ける", "余計な一言の", "せいで、"]}, {"box": [906, 579, 1049, 828], "vertical": true, "font_size": 33, "lines_coords": [[[1009.0, 581.0], [1045.0, 581.0], [1049.0, 737.0], [1014.0, 737.0]], [[972.0, 579.0], [1007.0, 579.0], [1014.0, 828.0], [978.0, 828.0]], [[939.0, 583.0], [970.0, 583.0], [972.0, 826.0], [941.0, 826.0]], [[906.0, 585.0], [935.0, 585.0], [935.0, 706.0], [906.0, 706.0]]], "lines": ["そうやって", "今まで何人の人を", "無意識に傷つけて", "きたの？"]}, {"box": [126, 594, 303, 841], "vertical": true, "font_size": 32, "lines_coords": [[[274.0, 594.0], [303.0, 594.0], [303.0, 839.0], [274.0, 839.0]], [[238.0, 598.0], [268.0, 598.0], [268.0, 810.0], [238.0, 810.0]], [[203.0, 600.0], [232.0, 600.0], [232.0, 783.0], [203.0, 783.0]], [[166.0, 598.0], [195.0, 598.0], [195.0, 841.0], [166.0, 841.0]], [[126.0, 598.0], [157.0, 598.0], [160.0, 749.0], [128.0, 749.0]]], "lines": ["どれだけあたしが", "自分の凡才さに", "気付かされて", "更に落ち込んだか", "知ってる？"]}, {"box": [987, 988, 1112, 1167], "vertical": true, "font_size": 42, "lines_coords": [[[1076.0, 997.0], [1111.0, 997.0], [1111.0, 1134.0], [1076.0, 1134.0]], [[1036.0, 997.0], [1072.0, 997.0], [1072.0, 1167.0], [1036.0, 1167.0]], [[987.0, 988.0], [1041.0, 988.0], [1041.0, 1090.0], [987.0, 1090.0]]], "lines": ["．．．ホント", "馬鹿だよな", "君も。"]}, {"box": [236, 1462, 284, 1685], "vertical": true, "font_size": 44, "lines_coords": [[[236.0, 1462.0], [280.0, 1462.0], [284.0, 1680.0], [241.0, 1680.0]]], "lines": ["．．．謝ってよ。"]}], "img_path": "184.png"}, {"version": "0.2.0-beta.6", "img_width": 1437, "img_height": 2127, "blocks": [{"box": [717, 123, 768, 619], "vertical": true, "font_size": 30, "lines_coords": [[[726.0, 556.0], [751.0, 558.0], [747.0, 608.0], [722.0, 606.0]], [[724.0, 199.0], [760.0, 199.0], [753.0, 554.0], [718.0, 554.0]]], "lines": ["．．．", "．．．う、ごめん．．"]}, {"box": [253, 333, 299, 576], "vertical": true, "font_size": 37, "lines_coords": [[[253.0, 336.0], [290.0, 336.0], [294.0, 575.0], [257.0, 575.0]]], "lines": ["．．．だからッ！！"]}, {"box": [1102, 866, 1266, 1072], "vertical": true, "font_size": 34, "lines_coords": [[[1223.0, 866.0], [1266.0, 866.0], [1266.0, 976.0], [1223.0, 976.0]], [[1189.0, 870.0], [1218.0, 870.0], [1218.0, 1071.0], [1189.0, 1071.0]], [[1146.0, 866.0], [1177.0, 866.0], [1175.0, 1069.0], [1144.0, 1069.0]], [[1102.0, 866.0], [1137.0, 866.0], [1137.0, 1007.0], [1102.0, 1007.0]]], "lines": ["なんで", "そんな簡単に", "謝っちゃうん", "だよっ！！"]}, {"box": [377, 830, 413, 992], "vertical": true, "font_size": 36, "lines_coords": [[[377.0, 830.0], [413.0, 830.0], [413.0, 992.0], [377.0, 992.0]]], "lines": ["こんなのっ"]}, {"box": [170, 916, 292, 1156], "vertical": true, "font_size": 36, "lines_coords": [[[257.0, 916.0], [292.0, 916.0], [292.0, 1055.0], [257.0, 1055.0]], [[215.0, 918.0], [251.0, 918.0], [251.0, 1156.0], [215.0, 1156.0]], [[174.0, 916.0], [209.0, 916.0], [205.0, 1123.0], [170.0, 1123.0]]], "lines": ["あたしの", "ただの八つ当り", "じゃんっ．．．"]}, {"box": [1183, 1331, 1218, 1493], "vertical": true, "font_size": 34, "lines_coords": [[[1183.0, 1331.0], [1218.0, 1331.0], [1218.0, 1493.0], [1183.0, 1493.0]]], "lines": ["ごめん．．．"]}, {"box": [286, 1375, 392, 1616], "vertical": true, "font_size": 36, "lines_coords": [[[359.0, 1377.0], [390.0, 1377.0], [392.0, 1616.0], [361.0, 1616.0]], [[326.0, 1377.0], [355.0, 1377.0], [350.0, 1586.0], [321.0, 1586.0]], [[286.0, 1375.0], [321.0, 13