]], [[334.0, 313.0], [365.0, 313.0], [363.0, 527.0], [332.0, 527.0]], [[296.0, 313.0], [326.0, 313.0], [326.0, 475.0], [296.0, 475.0]]], "lines": ["今、君が", "焦って何かする", "必要ないし、"]}, {"box": [1077, 469, 1196, 631], "vertical": true, "font_size": 38, "lines_coords": [[[1150.0, 469.0], [1196.0, 469.0], [1196.0, 573.0], [1150.0, 573.0]], [[1119.0, 473.0], [1154.0, 473.0], [1154.0, 631.0], [1119.0, 631.0]], [[1077.0, 471.0], [1123.0, 471.0], [1123.0, 560.0], [1077.0, 560.0]]], "lines": ["．．．先に", "言っておく", "けど。"]}, {"box": [186, 591, 326, 774], "vertical": true, "font_size": 32, "lines_coords": [[[296.0, 594.0], [326.0, 594.0], [323.0, 774.0], [294.0, 774.0]], [[257.0, 591.0], [292.0, 591.0], [292.0, 747.0], [257.0, 747.0]], [[222.0, 594.0], [251.0, 594.0], [251.0, 774.0], [222.0, 774.0]], [[186.0, 594.0], [215.0, 594.0], [215.0, 756.0], [186.0, 756.0]]], "lines": ["泣きたいなら", "枯れるまで", "泣いてるのも", "いいと思う。"]}, {"box": [1110, 1137, 1250, 1331], "vertical": true, "font_size": 28, "lines_coords": [[[1221.0, 1138.0], [1250.0, 1138.0], [1250.0, 1262.0], [1221.0, 1262.0]], [[1183.0, 1138.0], [1212.0, 1138.0], [1212.0, 1321.0], [1183.0, 1321.0]], [[1146.0, 1138.0], [1175.0, 1138.0], [1175.0, 1321.0], [1146.0, 1321.0]], [[1110.0, 1138.0], [1137.0, 1138.0], [1137.0, 1327.0], [1110.0, 1327.0]]], "lines": ["その後で", "君がちゃんと", "悩んで考えて", "行動するなら、"]}, {"box": [164, 1399, 283, 1601], "vertical": true, "font_size": 29, "lines_coords": [[[249.0, 1402.0], [278.0, 1402.0], [278.0, 1599.0], [249.0, 1599.0]], [[205.0, 1402.0], [234.0, 1402.0], [234.0, 1597.0], [205.0, 1597.0]], [[164.0, 1402.0], [193.0, 1402.0], [193.0, 1582.0], [164.0, 1582.0]]], "lines": ["何があっても", "あたしは君の", "味方だから。"]}], "img_path": "091.png"}, {"version": "0.2.0-beta.6", "img_width": 1437, "img_height": 2127, "blocks": [{"box": [768, 124, 922, 313], "vertical": true, "font_size": 35, "lines_coords": [[[884.0, 128.0], [922.0, 128.0], [922.0, 209.0], [884.0, 209.0]], [[851.0, 126.0], [880.0, 126.0], [880.0, 280.0], [851.0, 280.0]], [[814.0, 128.0], [843.0, 128.0], [843.0, 313.0], [814.0, 313.0]], [[768.0, 124.0], [811.0, 124.0], [811.0, 236.0], [768.0, 236.0]]], "lines": ["「僕は", "この数週間", "ずっと考えて", "ました。"]}, {"box": [552, 128, 698, 373], "vertical": true, "font_size": 30, "lines_coords": [[[666.0, 130.0], [693.0, 130.0], [693.0, 340.0], [666.0, 340.0]], [[625.0, 128.0], [654.0, 128.0], [654.0, 369.0], [625.0, 369.0]], [[587.0, 128.0], [622.0, 128.0], [622.0, 290.0], [587.0, 290.0]], [[556.0, 128.0], [585.0, 128.0], [581.0, 267.0], [552.0, 267.0]]], "lines": ["どうして自分は", "こんなに役立たず", "なのだろう、", "って．．．．．．」"]}, {"box": [1200, 513, 1277, 714], "vertical": true, "font_size": 31, "lines_coords": [[[1241.0, 513.0], [1277.0, 513.0], [1277.0, 714.0], [1241.0, 714.0]], [[1200.0, 515.0], [1229.0, 515.0], [1229.0, 714.0], [1200.0, 714.0]]], "lines": ["．．．今はそれで", "いいじゃん．．"]}, {"box": [1071, 747, 1185, 951], "vertical": true, "font_size": 31, "lines_coords": [[[1152.0, 747.0], [1183.0, 747.0], [1185.0, 951.0], [1154.0, 951.0]], [[1113.0, 749.0], [1142.0, 749.0], [1142.0, 920.0], [1113.0, 920.0]], [[1071.0, 747.0], [1100.0, 747.0], [1100.0, 926.0], [1071.0, 926.0]]], "lines": ["だからもっと", "未来の事を", "考えようよ。"]}, {"box": [191, 720, 335, 968], "vertical": true, "font_size": 31, "lines_coords": [[[301.0, 722.0], [330.0, 722.0], [330.0, 872.0], [301.0, 872.0]], [[263.0, 720.0], [299.0, 720.0], [294.0, 934.0], [259.0, 934.0]], [[228.0, 724.0], [257.0, 724.0], [257.0, 907.0], [228.0, 907.0]], [[191.0, 724.0], [220.0, 724.0], [220.0, 967.0], [191.0, 967.0]]], "lines": ["君もいつか", "誰かの役に立つ", "日が来るかも", "しれないんだし．．．"]}, {"box": [625, 1137, 842, 1382], "vertical": true, "font_size": 30, "lines_coords": [[[811.0, 1140.0], [841.0, 1140.0], [841.0, 1341.0], [811.0, 1341.0]], [[774.0, 1140.0], [803.0, 1140.0], [803.0, 1381.0], [774.0, 1381.0]], [[739.0, 1140.0], [768.0, 1140.0], [768.0, 1381.0], [739.0, 1381.0]], [[697.0, 1138.0], [733.0, 1138.0], [733.0, 1267.0], [697.0, 1267.0]], [[664.0, 1142.0], [693.0, 1142.0], [693.0, 1352.0], [664.0, 1352.0]], [[625.0, 1140.0], [654.0, 1140.0], [654.0, 1250.0], [625.0, 1250.0]]], "lines": ["「それどころか、", "僕はさっちゃんの", "足を引っぱってる", "気がして", "ならないんです", "．．．．．．"]}, {"box": [1208, 1528, 1281, 1694], "vertical": true, "font_size": 33, "lines_coords": [[[1245.0, 1528.0], [1281.0, 1528.0], [1281.0, 1694.0], [1245.0, 1694.0]], [[1208.0, 1532.0], [1239.0, 1532.0], [1239.0, 1632.0], [1208.0, 1632.0]]], "lines": ["．．．あたしの", "こと？"]}, {"box": [1142, 1719, 1212, 1923], "vertical": true, "font_size": 33, "lines_coords": [[[1183.0, 1724.0], [1212.0, 1724.0], [1212.0, 1921.0], [1183.0, 1921.0]], [[1142.0, 1719.0], [1177.0, 1719.0], [1177.0, 1923.0], [1142.0, 1923.0]]], "lines": ["．．．それは別に", "気にする必要"]}, {"box": [1098, 1716, 1218, 1921], "vertical": true, "font_size": 35, "lines_coords": [[[1098.0, 1719.0], [1133.0, 1719.0], [1133.0, 1888.0], [1098.0, 1888.0]]], "lines": ["ないし．．．"]}, {"box": [323, 1549, 409, 1699], "vertical": true, "font_size": 35, "lines_coords": [[[357.0, 1549.0], [409.0, 1549.0], [409.0, 1665.0], [357.0, 1665.0]], [[323.0, 1553.0], [361.0, 1553.0], [361.0, 1699.0], [323.0, 1699.0]]], "lines": ["．．．君は", "とにかく、"]}, {"box": [203, 1765, 344, 1989], "vertical": true, "font_size": 35, "lines_coords": [[[307.0, 1765.0], [344.0, 1765.0], [344.0, 1890.0], [307.0, 1890.0]], [[274.0, 1767.0], [303.0, 1767.0], [303.0, 1950.0], [274.0, 1950.0]], [[238.0, 1767.0], [265.0, 1767.0], [265.0, 1979.0], [238.0, 1979.0]], [[203.0, 1767.0], [230.0, 1767.0], [230.0, 1989.0], [203.0, 1989.0]]], "lines": ["あたしの", "言うことさえ", "聞いてれば何も", "心配いらないよ。"]}], "img_path": "092.png"}, {"version": "0.2.0-beta.6", "img_width": 1434, "img_height": 2127, "blocks": [{"box": [741, 114, 781, 313], "vertical": true, "font_size": 36, "lines_coords": [[[746.0, 114.0], [781.0, 114.0], [777.0, 313.0], [741.0, 313.0]]], "lines": ["「．．．僕は結局、"]}, {"box": [575, 118, 654, 357], "vertical": true, "font_size": 36, "lines_coords": [[[615.0, 118.0], [650.0, 118.0], [654.0, 357.0], [619.0, 357.0]], [[575.0, 120.0], [611.0,