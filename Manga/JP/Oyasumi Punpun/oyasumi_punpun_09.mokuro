alse, "font_size": 32.5, "lines_coords": [[[768.0, 893.0], [1064.0, 893.0], [1064.0, 922.0], [768.0, 922.0]], [[784.0, 926.0], [1002.0, 934.0], [1002.0, 970.0], [784.0, 961.0]]], "lines": ["地下鉄神保田", "いや、小さなわけでもいいのか"]}, {"box": [265, 822, 415, 1073], "vertical": true, "font_size": 29, "lines_coords": [[[381.0, 822.0], [410.0, 822.0], [410.0, 1073.0], [381.0, 1073.0]], [[342.0, 826.0], [371.0, 826.0], [371.0, 1009.0], [342.0, 1009.0]], [[303.0, 822.0], [332.0, 822.0], [332.0, 1042.0], [303.0, 1042.0]], [[265.0, 822.0], [294.0, 822.0], [294.0, 1053.0], [265.0, 1053.0]]], "lines": ["漫画より魅力的な", "コンテンツが", "増えた事は否定", "しませんよ僕は。"]}, {"box": [1031, 1528, 1173, 1802], "vertical": true, "font_size": 29, "lines_coords": [[[1141.0, 1528.0], [1170.0, 1528.0], [1170.0, 1802.0], [1141.0, 1802.0]], [[1104.0, 1530.0], [1133.0, 1530.0], [1133.0, 1713.0], [1104.0, 1713.0]], [[1064.0, 1528.0], [1093.0, 1528.0], [1098.0, 1802.0], [1068.0, 1802.0]], [[1031.0, 1528.0], [1060.0, 1528.0], [1060.0, 1724.0], [1031.0, 1724.0]]], "lines": ["．．．けど、いい作品を", "作り続ければ", "漫画が無くなる事は", "ありませんよ。"]}, {"box": [750, 1782, 801, 1867], "vertical": true, "font_size": 51, "lines_coords": [[[750.0, 1782.0], [801.0, 1782.0], [801.0, 1867.0], [750.0, 1867.0]]], "lines": ["入学期頃の投資チェックはこの一冊で！！"]}, {"box": [151, 1842, 186, 2027], "vertical": true, "font_size": 31, "lines_coords": [[[151.0, 1842.0], [182.0, 1842.0], [186.0, 2025.0], [155.0, 2025.0]]], "lines": ["．．．なるほど。"]}], "img_path": "039.png"}, {"version": "0.2.0-beta.6", "img_width": 1431, "img_height": 2127, "blocks": [{"box": [1184, 145, 1304, 388], "vertical": true, "font_size": 36, "lines_coords": [[[1260.0, 145.0], [1304.0, 145.0], [1304.0, 292.0], [1260.0, 292.0]], [[1225.0, 149.0], [1260.0, 149.0], [1260.0, 321.0], [1225.0, 321.0]], [[1185.0, 151.0], [1215.0, 151.0], [1215.0, 388.0], [1185.0, 388.0]]], "lines": ["．．．二人で", "描くことに", "したんですか？"]}, {"box": [707, 159, 837, 334], "vertical": true, "font_size": 36, "lines_coords": [[[793.0, 159.0], [837.0, 159.0], [837.0, 270.0], [793.0, 270.0]], [[756.0, 159.0], [791.0, 159.0], [791.0, 334.0], [756.0, 334.0]], [[708.0, 164.0], [737.0, 164.0], [737.0, 311.0], [708.0, 311.0]]], "lines": ["いいと", "思いますよ", "南条さん。"]}, {"box": [186, 201, 294, 465], "vertical": true, "font_size": 27, "lines_coords": [[[265.0, 209.0], [288.0, 209.0], [288.0, 357.0], [265.0, 357.0]], [[224.0, 207.0], [253.0, 207.0], [253.0, 359.0], [224.0, 359.0]], [[189.0, 201.0], [218.0, 201.0], [216.0, 461.0], [186.0, 461.0]]], "lines": ["相変わらず", "絵も構成も", "ちゃんとしてるし。"]}, {"box": [1202, 905, 1248, 1015], "vertical": true, "font_size": 35, "lines_coords": [[[1202.0, 905.0], [1248.0, 905.0], [1248.0, 1015.0], [1202.0, 1015.0]]], "lines": ["．．．ただ"]}, {"box": [911, 607, 1028, 776], "vertical": true, "font_size": 32, "lines_coords": [[[990.0, 608.0], [1028.0, 608.0], [1028.0, 741.0], [990.0, 741.0]], [[953.0, 608.0], [982.0, 608.0], [982.0, 776.0], [953.0, 776.0]], [[911.0, 610.0], [940.0, 610.0], [940.0, 776.0], [911.0, 776.0]]], "lines": ["あ．．．はい", "彼は原案と", "いうか．．．"]}, {"box": [1067, 1044, 1181, 1252], "vertical": true, "font_size": 35, "lines_coords": [[[1146.0, 1046.0], [1181.0, 1046.0], [1181.0, 1188.0], [1146.0, 1188.0]], [[1107.0, 1044.0], [1138.0, 1044.0], [1136.0, 1252.0], [1104.0, 1252.0]], [[1067.0, 1051.0], [1096.0, 1051.0], [1096.0, 1237.0], [1067.0, 1237.0]]], "lines": ["面白いか", "どうかはまた", "別ですけど。"]}, {"box": [218, 1352, 344, 1526], "vertical": true, "font_size": 39, "lines_coords": [[[299.0, 1354.0], [344.0, 1354.0], [344.0, 1464.0], [299.0, 1464.0]], [[261.0, 1356.0], [297.0, 1356.0], [297.0, 1526.0], [261.0, 1526.0]], [[218.0, 1352.0], [253.0, 1352.0], [257.0, 1508.0], [222.0, 1508.0]]], "lines": ["これも", "相変わらず", "ですねぇ。"]}, {"box": [184, 1773, 274, 2011], "vertical": true, "font_size": 43, "lines_coords": [[[226.0, 1773.0], [274.0, 1773.0], [274.0, 1865.0], [226.0, 1865.0]], [[191.0, 1775.0], [228.0, 1775.0], [222.0, 2010.0], [184.0, 2010.0]]], "lines": ["．．．あ、", "何か飲みます？"]}], "img_path": "040.png"}, {"version": "0.2.0-beta.6", "img_width": 1428, "img_height": 2127, "blocks": [{"box": [1157, 101, 1207, 218], "vertical": true, "font_size": 38, "lines_coords": [[[1157.0, 103.0], [1201.0, 101.0], [1207.0, 216.0], [1164.0, 218.0]]], "lines": ["．．．あ、"]}, {"box": [1003, 180, 1082, 419], "vertical": true, "font_size": 38, "lines_coords": [[[1047.0, 180.0], [1082.0, 180.0], [1082.0, 419.0], [1047.0, 419.0]], [[1003.0, 180.0], [1039.0, 180.0], [1039.0, 332.0], [1003.0, 332.0]]], "lines": ["おつかれ様です", "深澤先生。"]}, {"box": [170, 552, 253, 771], "vertical": true, "font_size": 32, "lines_coords": [[[220.0, 554.0], [249.0, 554.0], [249.0, 754.0], [220.0, 754.0]], [[174.0, 552.0], [209.0, 552.0], [205.0, 768.0], [170.0, 768.0]]], "lines": ["この間の読切", "最高でしたよ。"]}, {"box": [216, 1051, 334, 1354], "vertical": true, "font_size": 31, "lines_coords": [[[301.0, 1053.0], [330.0, 1053.0], [330.0, 1254.0], [301.0, 1254.0]], [[255.0, 1053.0], [291.0, 1053.0], [291.0, 1221.0], [255.0, 1221.0]], [[218.0, 1055.0], [247.0, 1055.0], [247.0, 1354.0], [218.0, 1354.0]]], "lines": ["．．．南条さんて", "深澤先生の", "ファンでしたっけ？"]}, {"box": [1130, 1516, 1236, 1726], "vertical": true, "font_size": 29, "lines_coords": [[[1205.0, 1518.0], [1236.0, 1518.0], [1236.0, 1609.0], [1205.0, 1609.0]], [[1168.0, 1518.0], [1197.0, 1518.0], [1197.0, 1699.0], [1168.0, 1699.0]], [[1130.0, 1516.0], [1159.0, 1516.0], [1159.0, 1726.0], [1130.0, 1726.0]]], "lines": ["．．．まあ", "ここだけの話", "あの人もねぇ．．．"]}, {"box": [962, 1728, 1109, 1977], "vertical": true, "font_size": 29, "lines_coords": [[[1080.0, 1728.0], [1109.0, 1728.0], [1109.0, 1854.0], [1080.0, 1854.0]], [[1041.0, 1728.0], [1070.0, 1728.0], [1070.0, 1948.0], [1041.0, 1948.0]], [[1001.0, 1728.0], [1030.0, 1728.0], [1030.0, 1977.0], [1001.0, 1977.0]], [[962.0, 1730.0], [991.0, 1730.0], [991.0, 1923.0], [962.0, 1923.0]]], "lines": ["単行本は", "そこそこだけど", "雑誌案引するほど", "人気はないし、"]}, {"box": [241, 1495, 390, 1744], "vertical": true, "font_size": 30, "lines_coords": [[[359.0, 1495.0], [390.0, 1495.0], [388.0, 1744.0], [357.0, 1744.0]], [[320.0, 1499.0], [349.0, 1499.0], [349.0, 1688.0], [320.0, 1688.0]], [[276.0, 1495.0], [311.0, 1495.0], [313.0, 1719.0], [278.0, 1719.0]], [[241.0, 1497.0], [270.0, 1497.0], [270.0, 1715.0], [241.0, 1715.0]]], "lines": ["雰囲気でゴリ押し", "してるだけで", "中身は薄っぺら", "ですからねー．．．"]}, {"box": [164, 1775, 232, 2021], "vertical": true, "font_size": 30, "lines_coords": [[[203.0, 1775.0], [232.0, 1775.0], [232.0, 2021.0], [203.0, 2021.0]], [[164.0, 1775.0], [193.0, 1775.0], [193.0, 1991.0], [164.0, 1991.0]]], "lines": ["サブカルというか", "サブカル風味？"]}], "img_path": "041.png"}, {"version": "0.2.0-beta.6", "img_width": 1433, "img_height": 2127, "blocks": [{"box": [461, 76, 481, 232], "vertical": true, "font_size": 20, "lines_coords": [[[461.0, 76.0], [481.0, 76.0], [481.0, 232.0], [461.0, 232.0]]], "lines": ["自分には決定的な何"]}, {"box": [189, 197, 351, 469], "vertical": true, "font_size": 34, "lines_coords": [[[311.0, 197.0], [346.0, 197.0], [346.0, 400.0], [311.0, 400.0]], [[267.0, 199.0], [305.0, 199.0], [309.0, 402.0], [272.0, 402.0]], [[228.0, 199.0], [263.0, 199.0], [265.0, 469.0], [230.0, 469.0]], [[191.0, 199.0], [220.0, 199.0], [220.0, 398.0], [191.0, 398.0]]], "lines": ["その雰囲気に", "ハマる読者も", "一定数はいるって", "事ですよね？"]}, {"box": [782, 554, 859, 741], "vertical": true, "font_size": 36, "lines_coords": [[[824.0, 556.0], [859.0, 556.0], [855.0, 741.0], [820.0, 741.0]], [[782.0, 554.0], [826.0, 554.0], [826.0, 662.0], [782.0, 662.0]]], "lines": ["仮にあったと", "しても、"]}, {"box": [577, 585, 724, 803], "vertical": true, "font_size": 36, "lines_coords": [[[695.0, 589.0], [724.0, 589.0], [724.0, 803.0], [695.0, 803.0]], [[658.0, 594.0], [687.0, 594.0], [687.0, 774.0], [658.0, 774.0]], [[620.0, 591.0], [650.0, 591.0], [650.0, 803.0], [620.0, 803.0]], [[577.0, 585.0], [623.0, 585.0], [623.0, 675.0], [577.0, 675.0]]], "lines": ["そんな読者数が", "頭打ちの作家", "二人もいらない", "です。"]}, {"box": [1190, 1005, 1291, 1198], "vertical": true, "font_size": 29, "lines_coords": [[[1252.0, 1005.0], [1287.0, 1005.0], [1291.0, 1144.0], [1256.0, 1144.0]], [[1225.0, 1005.0], [1252.0, 1005.0], [1252.0, 1198.0], [1225.0, 1198.0]], [[1190.0, 1007.0], [1219.0, 1007.0], [1219.0, 1171.0], [1190.0, 1171.0]]], "lines": ["今回のこの", "「真昼の流れ星」", "ですけど．．．"]}, {"box": [1036, 1204, 1165, 1483], "vertical": true, "font_size": 29, "lines_coords": [[[1136.0, 1204.0], [1165.0, 1204.0], [1165.0, 1422.0], [1136.0, 1422.0]], [[1102.0, 1206.0], [1129.0, 1206.0], [1129.0, 1476.0], [1102.0, 1476.0]], [[1069.0, 1206.0], [1096.0, 1206.0], [1096.0, 1447.0], [1069.0, 1447.0]], [[1036.0, 1204.0], [1063.0, 1204.0], [1063.0, 1483.0], [1036.0, 1483.0]]], "lines": ["平板な生活を送る", "フリーターの主人公は", "上京先で高校時代の", "同級生女子と再会する。"]}, {"box": [641, 1075, 681, 1146], "vertical": true, "font_size": 30, "lines_coords": [[[641.0, 1075.0], [681.0, 1075.0], [681.0, 1146.0], [641.0, 1146.0]]], "lines": ["どもー"]}, {"box": [537, 1190, 631, 1395], "vertical": true, "font_size": 30, "lines_coords": [[[596.0, 1190.0], [631.0, 1190.0], [631.0, 1300.0], [596.0, 1300.0]], [[564.0, 1196.0], [593.0, 1196.0], [593.0, 1395.0], [564.0, 1395.0]], [[537.0, 1198.0], [560.0, 1198.0], [560.0, 1308.0], [537.0, 1308.0]]], "lines": ["１６ページ", "３コマ目のセリフ", "ですけど！"]}, {"box": [535, 1321, 562, 1370], "vertical": true, "font_size": 30, "lines_coords": [[[535.0, 1323.0], [558.0, 1321.0], [562.0, 1368.0], [539.0, 1370.0]]], "lines": ["．．．"]}, {"box": [255, 1385, 419, 1684], "vertical": true, "font_size": 29, "lines_coords": [[[390.0, 1387.0], [419.0, 1387.0], [417.0, 1657.0], [388.0, 1657.0]], [[357.0, 1385.0], [384.0, 1385.0], [384.0, 1661.0], [357.0, 1661.0]], [[323.0, 1389.0], [353.0, 1389.0], [353.0, 1684.0], [323.0, 1684.0]], [[288.0, 1387.0], [315.0, 1387.0], [315.0, 1603.0], [288.0, 1603.0]], [[257.0, 1387.0], [286.0, 1387.0], [284.0, 1578.0], [255.0, 1578.0]]], "lines": ["数日後、その女の子が", "自殺していた事を知り", "何も変わらない世の中で", "主人公は少しだけ", "前に進み出す："]}, {"box": [228, 1775, 392, 1994], "vertical": true, "font_size": 29, "lines_coords": [[[359.0, 1775.0], [388.0, 1775.0], [392.0, 1915.0], [363.0, 1915.0]], [[330.0, 1778.0], [359.0, 1778.0], [357.0, 1969.0], [328.0, 1969.0]], [[296.0, 1775.0], [326.0, 1775.0], [323.0, 1969.0], [294.0, 1969.0]], [[263.0, 1775.0], [292.0, 1775.0], [290.0, 1940.0], [261.0, 1940.0]], [[228.0, 1778.0], [257.0, 1778.0], [257.0, 1994.0], [228.0, 1994.0]]], "lines": ["．．．これって", "主人公が勝手に", "自己完結してて", "全然面白味に", "欠けるんですよね"]}], "img_path": "042.png"}, {"version": "0.2.0-beta.6", "img_width": 1427, "img_height": 2127, "blocks": [{"box": [1132, 124, 1260, 409], "vertical": true, "font_size": 28, "lines_coords": [[[1231.0, 124.0], [1260.0, 124.0], [1260.0, 344.0], [1231.0, 344.0]], [[1196.0, 124.0], [1223.0, 124.0], [1223.0, 369.0], [1196.0, 369.0]], [[1165.0, 124.0], [1192.0, 124.0], [1192.0, 371.0], [1165.0, 371.0]], [[1132.0, 124.0], [1159.0, 124.0], [1159.0, 409.0], [1132.0, 409.0]]], "lines": ["僕から言わせれば", "二十代の悩みなんて", "がむしゃらに働けば", "大概解決するんですよ。"]}, {"box": [934, 263, 1061, 540], "vertical": true, "font_size": 28, "lines_coords": [[[1034.0, 263.0], [1061.0, 263.0], [1061.0, 456.0], [1034.0, 456.0]], [[999.0, 265.0], [1028.0, 265.0], [1028.0, 486.0], [999.0, 486.0]], [[967.0, 265.0], [997.0, 265.0], [997.0, 540.0], [967.0, 540.0]], [[934.0, 263.0], [961.0, 263.0], [961.0, 442.0], [934.0, 442.0]]], "lines": ["仮に挫折しても", "頑張れたっていう", "自信がその後の行動に", "繋がるんです。"]}, {"box": [153, 332, 294, 580], "vertical": true, "font_size": 33, "lines_coords": [[[263.0, 338.0], [292.0, 338.0], [292.0, 517.0], [263.0, 517.0]], [[218.0, 332.0], [263.0, 332.0], [263.0, 434.0], [218.0, 434.0]], [[189.0, 338.0], [218.0, 338.0], [218.0, 577.0], [189.0, 577.0]], [[153.0, 336.0], [182.0, 336.0], [182.0, 473.0], [153.0, 473.0]]], "lines": ["こんなんじゃ", "ただの", "絶望ごっこにしか", "見えない。"]}, {"box": [1144, 708, 1215, 936], "vertical": true, "font_size": 32, "lines_coords": [[[1186.0, 708.0], [1215.0, 708.0], [1215.0, 895.0], [1186.0, 895.0]], [[1144.0, 708.0], [1179.0, 708.0], [1181.0, 936.0], [1146.0, 936.0]]], "lines": ["不幸自慢って", "ウザいんですよ。"]}, {"box": [288, 963, 392, 1148], "vertical": true, "font_size": 28, "lines_coords": [[[363.0, 965.0], [392.0, 965.0], [392.0, 1119.0], [363.0, 1119.0]], [[326.0, 963.0], [357.0, 963.0], [353.0, 1148.0], [321.0, 1148.0]], [[288.0, 965.0], [317.0, 965.0], [317.0, 1123.0], [288.0, 1123.0]]], "lines": ["世の中には", "もっと不幸な", "人もいるし、"]}, {"box": [1021, 961, 1129, 1208], "vertical": true, "font_size": 32, "lines_coords": [[[1092.0, 961.0], [1129.0, 961.0], [1129.0, 1100.0], [1092.0, 1100.0]], [[1059.0, 963.0], [1088.0, 963.0], [1088.0, 1208.0], [1059.0, 1208.0]], [[1021.0, 965.0], [1051.0, 965.0], [1051.0, 1121.0], [1021.0, 1121.0]]], "lines": ["まぁ一言、", "甘ったれんなって", "感じですね"]}, {"box": [182, 1244, 321, 1485], "vertical": true, "font_size": 28, "lines_coords": [[[294.0, 1244.0], [321.0, 1244.0], [321.0, 1424.0], [294.0, 1424.0]], [[257.0, 1244.0], [284.0, 1244.0], [284.0, 1485.0], [257.0, 1485.0]], [[222.0, 1246.0], [245.0, 1246.0], [245.0, 1393.0], [222.0, 1393.0]], [[182.0, 1244.0], [211.0, 1244.0], [211.0, 1366.0], [182.0, 1366.0]]], "lines": ["病気や障害に", "立ち向かっている", "人もいるん", "てすよ？"]}, {"box": [1154, 1605, 1237, 1744], "vertical": true, "font_size": 37, "lines_coords": [[[1200.0, 1607.0], [1237.0, 1607.0], [1237.0, 1744.0], [1200.0, 1744.0]], [[1154.0, 1605.0], [1200.0, 1605.0], [1200.0, 1728.0], [1154.0, 1728.0]]], "lines": ["．．．つまり", "それは、"]}, {"box": [1019, 1784, 1136, 1991], "vertical": true, "font_size": 37, "lines_coords": [[[1100.0, 1784.0], [1136.0, 1784.0], [1132.0, 1956.0], [1096.0, 1956.0]], [[1059.0, 1788.0], [1094.0, 1788.0], [1094.0, 1991.0], [1059.0, 1991.0]], [[1019.0, 1788.0], [1048.0, 1788.0], [1048.0, 1960.0], [1019.0, 1960.0]]], "lines": ["その本当に", "不幸な人達を", "ネタにして、"]}, {"box": [155, 1763, 276, 2000], "vertical": true, "font_size": 32, "lines_coords": [[[240.0, 1767.0], [270.0, 1767.0], [270.0, 1998.0], [240.0, 1998.0]], [[193.0, 1763.0], [230.0, 1763.0], [232.0, 2000.0], [195.0, 2000.0]], [[155.0, 1763.0], [184.0, 1763.0], [184.0, 1931.0], [155.0, 1931.0]]], "lines": ["感動的なお話を", "創作しろって事", "てすかね？"]}], "img_path": "043.png"}, {"version": "0.2.0-beta.6", "img_width": 1432, "img_height": 2127, "blocks": [{"box": [1109, 122, 1222, 282], "vertical": true, "font_size": 30, "lines_coords": [[[1192.0, 128.0], [1222.0, 128.0], [1222.0, 280.0], [1192.0, 280.0]], [[1157.0, 128.0], [1186.0, 128.0], [1186.0, 282.0], [1157.0, 282.0]], [[1109.0, 124.0], [1149.0, 122.0], [1155.0, 228.0], [1116.0, 230.0]]], "lines": ["．．．あたしは", "そんな資格", "ないし、"]}, {"box": [976, 286, 1076, 515], "vertical": true, "font_size": 30, "lines_coords": [[[1049.0, 286.0], [1076.0, 286.0], [1076.0, 473.0], [1049.0, 473.0]], [[1012.0, 290.0], [1041.0, 290.0], [1041.0, 471.0], [1012.0, 471.0]], [[976.0, 288.0], [1003.0, 288.0], [1003.0, 515.0], [976.0, 515.0]]], "lines": ["もし描いたら", "嘘をつく事に", "なると思います。"]}, {"box": [317, 116, 465, 334], "vertical": true, "font_size": 35, "lines_coords": [[[426.0, 118.0], [461.0, 118.0], [465.0, 245.0], [430.0, 245.0]], [[394.0, 120.0], [430.0, 120.0], [430.0, 247.0], [394.0, 247.0]], [[359.0, 122.0], [388.0, 122.0], [388.0, 334.0], [359.0, 334.0]], [[317.0, 116.0], [361.0, 116.0], [361.0, 226.0], [317.0, 226.0]]], "lines": ["そもそも", "幸不幸は", "相対的なもので", "あって、"]}, {"box": [151, 234, 307, 454], "vertical": true, "font_size": 35, "lines_coords": [[[278.0, 238.0], [307.0, 238.0], [307.0, 421.0], [278.0, 421.0]], [[241.0, 240.0], [270.0, 240.0], [270.0, 423.0], [241.0, 423.0]], [[195.0, 238.0], [224.0, 238.0], [224.0, 454.0], [195.0, 454.0]], [[151.0, 234.0], [197.0, 234.0], [197.0, 324.0], [151.0, 324.0]]], "lines": ["他人の不幸に", "同情するのは", "欺瞞だと思うん", "です。"]}, {"box": [1130, 843, 1236, 1121], "vertical": true, "font_size": 29, "lines_coords": [[[1207.0, 849.0], [1236.0, 849.0], [1236.0, 1030.0], [1207.0, 1030.0]], [[1170.0, 847.0], [1199.0, 847.0], [1199.0, 1121.0], [1170.0, 1121.0]], [[1132.0, 843.0], [1161.0, 843.0], [1159.0, 1121.0], [1130.0, 1121.0]]], "lines": ["．．．あたし達は", "みんなと同じ目線で", "描きたいんですよ！！"]}, {"box": [818, 530, 848, 716], "vertical": true, "font_size": 29, "lines_coords": [[[818.0, 531.0], [847.0, 531.0], [847.0, 610.0], [818.0, 610.0]]], "lines": ["．．．う"]}, {"box": [972, 1144, 1107, 1416], "vertical": true, "font_size": 29, "lines_coords": [[[1078.0, 1146.0], [1107.0, 1146.0], [1107.0, 1416.0], [1078.0, 1416.0]], [[1043.0, 1148.0], [1072.0, 1148.0], [1072.0, 1362.0], [1043.0, 1362.0]], [[1008.0, 1144.0], [1037.0, 1144.0], [1037.0, 1416.0], [1008.0, 1416.0]], [[972.0, 1144.0], [999.0, 1144.0], [999.0, 1416.0], [972.0, 1416.0]]], "lines": ["理想なんてなくても", "飢えることなく", "生きていける平板な", "世の中だからこそ！！"]}, {"box": [268, 1219, 431, 1555], "vertical": true, "font_size": 34, "lines_coords": [[[392.0, 1221.0], [428.0, 1221.0], [428.0, 1555.0], [392.0, 1555.0]], [[351.0, 1219.0], [386.0, 1219.0], [384.0, 1522.0], [349.0, 1522.0]], [[309.0, 1219.0], [345.0, 1219.0], [345.0, 1524.0], [309.0, 1524.0]], [[270.0, 1221.0], [301.0, 1221.0], [299.0, 1489.0], [268.0, 1489.0]]], "lines": ["飼い慣らされた状態で", "一歩踏み外す勇気が", "必要だってあたしは", "確信があるから！！"]}, {"box": [1176, 1686, 1240, 1902], "vertical": true, "font_size": 28, "lines_coords": [[[1213.0, 1686.0], [1240.0, 1686.0], [1240.0, 1869.0], [1213.0, 1869.0]], [[1176.0, 1686.0], [1205.0, 1686.0], [1205.0, 1902.0], [1176.0, 1902.0]]], "lines": ["．．．いやだから", "それが自虐自慢"]}, {"box": [999, 1771, 1064, 1950], "vertical": true, "font_size": 28, "lines_coords": [[[1035.0, 1773.0], [1064.0, 1773.0], [1064.0, 1950.0], [1035.0, 1950.0]], [[999.0, 1771.0], [1028.0, 1771.0], [1028.0, 1935.0], [999.0, 1935.0]]], "lines": ["オナニー漫画", "なんですよ。"]}, {"box": [1000, 1774, 1066, 1951], "vertical": true, "font_size": 66, "lines_coords": [[[1000.0, 1774.0], [1066.0, 1774.0], [1066.0, 1951.0], [1000.0, 1951.0]]], "lines": ["オナニー漫画なんですよ。"]}, {"box": [365, 1709, 434, 1904], "vertical": true, "font_size": 34, "lines_coords": [[[394.0, 1709.0], [430.0, 1709.0], [434.0, 1867.0], [399.0, 1867.0]], [[365.0, 1713.0], [394.0, 1713.0], [394.0, 1904.0], [365.0, 1904.0]]], "lines": ["．．．あたしは", "見たいですよ。"]}, {"box": [169, 1781, 274, 1998], "vertical": true, "font_size": 105, "lines_coords": [[[169.0, 1781.0], [274.0, 1781.0], [274.0, 1998.0], [169.0, 1998.0]]], "lines": ["意味があれば他人のオナニーだって。"]}, {"box": [160, 1778, 272, 1996], "vertical": true, "font_size": 34, "lines_coords": [[[239.0, 1782.0], [272.0, 1782.0], [268.0, 1964.0], [234.0, 1964.0]], [[203.0, 1786.0], [232.0, 1786.0], [232.0, 1996.0], [203.0, 1996.0]], [[160.0, 1778.0], [203.0, 1778.0], [203.0, 1894.0], [160.0, 1894.0]]], "lines": ["意味があれば", "他人のオナニー", "だって。"]}], "img_path": "044.png"}, {"version": "0.2.0-beta.6", "img_width": 1429, "img_height": 2127, "blocks": [{"box": [1235, 130, 1279, 251], "vertical": true, "font_size": 44, "lines_coords": [[[1235.0, 130.0], [1279.0, 130.0], [1279.0, 251.0], [1235.0, 251.0]]], "lines": ["．．．では、"]}, {"box": [270, 278, 340, 525], "vertical": true, "font_size": 31, "lines_coords": [[[299.0, 278.0], [340.0, 278.0], [340.0, 348.0], [299.0, 348.0]], [[270.0, 282.0], [299.0, 282.0], [299.0, 525.0], [270.0, 525.0]]], "lines": ["この", "リアリティーは？"]}, {"box": [1165, 897, 1202, 1075], "vertical": true, "font_size": 37, "lines_coords": [[[1165.0, 897.0], [1202.0, 897.0], [1202.0, 1073.0], [1165.0, 1073.0]]], "lines": ["．．．じゃあ、"]}, {"box": [845, 491, 948, 762], "vertical": true, "font_size": 28, "lines_coords": [[[918.0, 492.0], [947.0, 492.0], [947.0, 762.0], [918.0, 762.0]], [[880.0, 492.0], [909.0, 492.0], [909.0, 702.0], [880.0, 702.0]], [[845.0, 492.0], [872.0, 492.0], [872.0, 677.0], [845.0, 677.0]]], "lines": ["ヒロインの女の子が", "自殺する描写が", "ありますけど"]}, {"box": [199, 558, 301, 803], "vertical": true, "font_size": 31, "lines_coords": [[[274.0, 558.0], [301.0, 558.0], [301.0, 772.0], [274.0, 772.0]], [[236.0, 562.0], [265.0, 562.0], [265.0, 745.0], [236.0, 745.0]], [[199.0, 562.0], [228.0, 562.0], [228.0, 803.0], [199.0, 803.0]]], "lines": ["これはあなたが", "嘘をついてる", "事にはならない？"]}, {"box": [151, 1372, 358, 1640], "vertical": true, "font_size": 33, "lines_coords": [[[319.0, 1375.0], [355.0, 1375.0], [355.0, 1545.0], [319.0, 1545.0]], [[276.0, 1372.0], [311.0, 1372.0], [311.0, 1640.0], [276.0, 1640.0]], [[238.0, 1377.0], [267.0, 1377.0], [267.0, 1607.0], [238.0, 1607.0]], [[197.0, 1372.0], [226.0, 1372.0], [226.0, 1572.0], [197.0, 1572.0]], [[151.0, 1372.0], [189.0, 1372.0], [189.0, 1512.0], [151.0, 1512.0]]], "lines": ["あたしが今", "ここで首吊ったら", "この漫画を評価", "してくれるん", "ですか？"]}], "img_path": "045.png"}, {"version": "0.2.0-beta.6", "img_width": 1429, "img_height": 2127, "blocks": [{"box": [1214, 83, 1290, 324], "vertical": true, "font_size": 32, "lines_coords": [[[1254.0, 83.0], [1289.0, 83.0], [1287.0, 324.0], [1252.0, 324.0]], [[1217.0, 85.0], [1246.0, 85.0], [1246.0, 303.0], [1217.0, 303.0]]], "lines": ["．．．ちょっと話が", "飛躍してます。"]}, {"box": [783, 101, 824, 284], "vertical": true, "font_size": 38, "lines_coords": [[[783.0, 101.0], [820.0, 101.0], [824.0, 284.0], [787.0, 284.0]]], "lines": ["．．．とにかく、"]}, {"box": [583, 236, 706, 477], "vertical": true, "font_size": 38, "lines_coords": [[[670.0, 240.0], [706.0, 240.0], [706.0, 378.0], [670.0, 378.0]], [[629.0, 238.0], [664.0, 238.0], [664.0, 477.0], [629.0, 477.0]], [[583.0, 236.0], [629.0, 236.0], [629.0, 330.0], [583.0, 330.0]]], "lines": ["面白さは", "漫画の絶対条件", "です。"]}, {"box": [153, 211, 332, 459], "vertical": true, "font_size": 29, "lines_coords": [[[299.0, 213.0], [328.0, 213.0], [328.0, 367.0], [299.0, 367.0]], [[263.0, 213.0], [292.0, 213.0], [292.0, 375.0], [263.0, 375.0]], [[226.0, 213.0], [255.0, 213.0], [255.0, 425.0], [226.0, 425.0]], [[186.0, 211.0], [216.0, 211.0], [218.0, 459.0], [189.0, 459.0]], [[153.0, 213.0], [180.0, 213.0], [180.0, 378.0], [153.0, 378.0]]], "lines": ["暗い世の中", "だからこそ、", "読者は前向きで", "わかり易い共感を", "求めてます。"]}, {"box": [965, 610, 1005, 828], "vertical": true, "font_size": 36, "lines_coords": [[[965.0, 610.0], [1001.0, 610.0], [1005.0, 826.0], [969.0, 826.0]]], "lines": ["戻しましょう。"]}, {"box": [1179, 940, 1281, 1186], "vertical": true, "font_size": 28, "lines_coords": [[[1252.0, 940.0], [1281.0, 940.0], [1281.0, 1152.0], [1252.0, 1152.0]], [[1217.0, 940.0], [1244.0, 940.0], [1244.0, 1181.0], [1217.0, 1181.0]], [[1179.0, 943.0], [1208.0, 943.0], [1208.0, 1186.0], [1179.0, 1186.0]]], "lines": ["その場しのぎの", "感動なんて根本の", "解決にならない！！"]}, {"box": [228, 629, 371, 816], "vertical": true, "font_size": 31, "lines_coords": [[[336.0, 631.0], [371.0, 631.0], [371.0, 816.0], [336.0, 816.0]], [[301.0, 629.0], [332.0, 629.0], [328.0, 787.0], [297.0, 787.0]], [[265.0, 631.0], [294.0, 631.0], [294.0, 812.0], [265.0, 812.0]], [[228.0, 629.0], [257.0, 629.0], [257.0, 781.0], [228.0, 781.0]]], "lines": ["．．．そんなので", "喜んでたら", "馬鹿じゃない", "ですか．．．"]}, {"box": [1011, 1181, 1150, 1454], "vertical": true, "font_size": 28, "lines_coords": [[[1121.0, 1183.0], [1150.0, 1183.0], [1150.0, 1335.0], [1121.0, 1335.0]], [[1084.0, 1181.0], [1113.0, 1181.0], [1113.0, 1424.0], [1084.0, 1424.0]], [[1046.0, 1181.0], [1073.0, 1181.0], [1073.0, 1454.0], [1046.0, 1454.0]], [[1011.0, 1183.0], [1040.0, 1183.0], [1040.0, 1395.0], [1011.0, 1395.0]]], "lines": ["必要なのは", "それぞれの日常に", "還元できる具体的な", "価値観ですよ！！"]}, {"box": [195, 1061, 487, 1620], "vertical": true, "font_size": 30, "lines_coords": [[[450.0, 1061.0], [479.0, 1061.0], [481.0, 1304.0], [452.0, 1304.0]], [[417.0, 1063.0], [446.0, 1063.0], [446.0, 1246.0], [417.0, 1246.0]], [[375.0, 1061.0], [411.0, 1061.0], [411.0, 1308.0], [375.0, 1308.0]], [[342.0, 1063.0], [371.0, 1063.0], [371.0, 1246.0], [342.0, 1246.0]], [[305.0, 1065.0], [334.0, 1065.0], [334.0, 1318.0], [305.0, 1318.0]], [[305.0, 1304.0], [332.0, 1304.0], [332.0, 1584.0], [305.0, 1584.0]], [[270.0, 1318.0], [299.0, 1318.0], [299.0, 1620.0], [270.0, 1620.0]], [[232.0, 1316.0], [261.0, 1316.0], [261.0, 1497.0], [232.0, 1497.0]], [[195.0, 1318.0], [224.0, 1318.0], [224.0, 1497.0], [195.0, 1497.0]]], "lines": ["たとえ歪んでると", "言われようが", "死ぬその瞬間まで", "自分が自分で", "いられるって事、", "それがあたしの思う", "人としての尊厳なので、", "自己解決でも", "いいんです！！"]}, {"box": [1177, 1653, 1291, 1898], "vertical": true, "font_size": 34, "lines_coords": [[[1262.0, 1659.0], [1291.0, 1659.0], [1291.0, 1898.0], [1262.0, 1898.0]], [[1225.0, 1659.0], [1254.0, 1659.0], [1254.0, 1871.0], [1225.0, 1871.0]], [[1181.0, 1653.0], [1223.0, 1655.0], [1219.0, 1761.0], [1177.0, 1759.0]]], "lines": ["．．．今時、作り手が", "あまり傲慢な事", "言うと、"]}, {"box": [1050, 1809, 1125, 2002], "vertical": true, "font_size": 34, "lines_coords": [[[1088.0, 1809.0], [1125.0, 1809.0], [1125.0, 1933.0], [1088.0, 1933.0]], [[1050.0, 1809.0], [1082.0, 1809.0], [1086.0, 2002.0], [1055.0, 2002.0]]], "lines": ["白い目で", "見られますよ。"]}, {"box": [353, 1726, 456, 1881], "vertical": true, "font_size": 32, "lines_coords": [[[427.0, 1730.0], [456.0, 1730.0], [456.0, 1877.0], [427.0, 1877.0]], [[388.0, 1726.0], [423.0, 1726.0], [423.0, 1881.0], [388.0, 1881.0]], [[353.0, 1728.0], [382.0, 1728.0], [382.0, 1861.0], [353.0, 1861.0]]], "lines": ["．．．落ちつき", "ましょうよ", "南条さん。"]}, {"box": [170, 1792, 278, 2021], "vertical": true, "font_size": 32, "lines_coords": [[[240.0, 1792.0], [278.0, 1792.0], [278.0, 1919.0], [240.0, 1919.0]], [[201.0, 1792.0], [236.0, 1792.0], [240.0, 1977.0], [205.0, 1977.0]], [[170.0, 1796.0], [199.0, 1796.0], [199.0, 2021.0], [170.0, 2021.0]]], "lines": ["ずいぶん", "イラついてる", "みたいですけど。"]}], "img_path": "046.png"}, {"version": "0.2.0-beta.6", "img_width": 1429, "img_height": 2127, "blocks": [{"box": [1117, 136, 1237, 376], "vertical": true, "font_size": 34, "lines_coords": [[[1200.0, 137.0], [1237.0, 137.0], [1237.0, 245.0], [1200.0, 245.0]], [[1163.0, 139.0], [1192.0, 139.0], [1192.0, 375.0], [1163.0, 375.0]], [[1117.0, 137.0], [1154.0, 137.0], [1154.0, 278.0], [1117.0, 278.0]]], "lines": ["あなた", "何と戦ってるん", "ですか？"]}, {"box": [716, 145, 772, 245], "vertical": true, "font_size": 50, "lines_coords": [[[716.0, 145.0], [772.0, 145.0], [772.0, 245.0], [716.0, 245.0]]], "lines": ["僕？"]}, {"box": [596, 234, 641, 361], "vertical": true, "font_size": 50, "lines_coords": [[[596.0, 234.0], [641.0, 234.0], [641.0, 361.0], [596.0, 361.0]]], "lines": ["読者？"]}, {"box": [191, 365, 288, 533], "vertical": true, "font_size": 48, "lines_coords": [[[245.0, 367.0], [288.0, 367.0], [288.0, 533.0], [245.0, 533.0]], [[191.0, 365.0], [245.0, 365.0], [245.0, 496.0], [191.0, 496.0]]], "lines": ["それとも", "社会？"]}, {"box": [166, 1034, 311, 1293], "vertical": true, "font_size": 29, "lines_coords": [[[280.0, 1034.0], [307.0, 1034.0], [307.0, 1250.0], [280.0, 1250.0]], [[240.0, 1036.0], [270.0, 1036.0], [270.0, 1190.0], [240.0, 1190.0]], [[205.0, 1038.0], [234.0, 1038.0], [234.0, 1279.0], [205.0, 1279.0]], [[168.0, 1034.0], [197.0, 1034.0], [195.0, 1291.0], [166.0, 1291.0]]], "lines": ["：実は自分自身", "なんていう", "使い古された文脈", "よしてくださいね。"]}, {"box": [230, 1616, 376, 1861], "vertical": true, "font_size": 32, "lines_coords": [[[346.0, 1620.0], [373.0, 1620.0], [373.0, 1861.0], [346.0, 1861.0]], [[305.0, 1620.0], [340.0, 1620.0], [340.0, 1800.0], [305.0, 1800.0]], [[270.0, 1620.0], [299.0, 1620.0], [299.0, 1829.0], [270.0, 1829.0]], [[230.0, 1616.0], [265.0, 1616.0], [265.0, 1742.0], [230.0, 1742.0]]], "lines": ["．．．そんな未完成な", "理論武装じゃ", "ツッコミ所満載", "ですよ？"]}], "img_path": "047.png"}, {"version": "0.2.0-beta.6", "img_width": 1434, "img_height": 2127, "blocks": [{"box": [987, 95, 1108, 336], "vertical": true, "font_size": 36, "lines_coords": [[[1072.0, 97.0], [1107.0, 97.0], [1107.0, 336.0], [1072.0, 336.0]], [[1028.0, 97.0], [1064.0, 97.0], [1064.0, 303.0], [1028.0, 303.0]], [[987.0, 95.0], [1024.0, 95.0], [1024.0, 249.0], [987.0, 249.0]]], "lines": ["．．．もっと明確な", "メッセージを", "ください。"]}, {"box": [816, 103, 847, 182], "vertical": true, "font_size": 34, "lines_coords": [[[816.0, 103.0], [847.0, 103.0], [847.0, 182.0], [816.0, 182.0]]], "lines": ["まぁ"]}, {"box": [687, 228, 791, 459], "vertical": true, "font_size": 34, "lines_coords": [[[750.0, 228.0], [791.0, 228.0], [791.0, 294.0], [750.0, 294.0]], [[719.0, 230.0], [754.0, 230.0], [754.0, 346.0], [719.0, 346.0]], [[687.0, 230.0], [717.0, 230.0], [719.0, 459.0], [689.0, 459.0]]], "lines": ["一応", "新人賞に", "出しときましょう。"]}, {"box": [164, 221, 309, 474], "vertical": true, "font_size": 29, "lines_coords": [[[276.0, 222.0], [305.0, 222.0], [305.0, 402.0], [276.0, 402.0]], [[239.0, 222.0], [268.0, 222.0], [268.0, 471.0], [239.0, 471.0]], [[201.0, 222.0], [230.0, 222.0], [230.0, 465.0], [201.0, 465.0]], [[164.0, 222.0], [193.0, 222.0], [193.0, 444.0], [164.0, 444.0]]], "lines": ["別に悪いとは", "言ってませんから、", "作家が己の心情を", "吐露することは。"]}, {"box": [167, 593, 194, 642], "vertical": true, "font_size": 27, "lines_coords": [[[167.0, 593.0], [194.0, 593.0], [194.0, 642.0], [167.0, 642.0]]], "lines": ["こっ"]}, {"box": [243, 697, 282, 852], "vertical": true, "font_size": 37, "lines_coords": [[[243.0, 702.0], [280.0, 702.0], [280.0, 847.0], [243.0, 847.0]]], "lines": ["．．．．．ただ"]}, {"box": [1111, 1001, 1280, 1308], "vertical": true, "font_size": 40, "lines_coords": [[[1242.0, 1005.0], [1280.0, 1005.0], [1280.0, 1144.0], [1242.0, 1144.0]], [[1201.0, 1005.0], [1236.0, 1005.0], [1236.0, 1248.0], [1201.0, 1248.0]], [[1157.0, 1007.0], [1192.0, 1007.0], [1192.0, 1308.0], [1157.0, 1308.0]], [[1111.0, 1001.0], [1161.0, 1001.0], [1161.0, 1090.0], [1111.0, 1090.0]]], "lines": ["あなたが", "思ってる以上に", "世の中のほとんどの", "人は、"]}, {"box": [258, 1267, 376, 1480], "vertical": true, "font_size": 31, "lines_coords": [[[340.0, 1267.0], [376.0, 1267.0], [376.0, 1399.0], [340.0, 1399.0]], [[301.0, 1267.0], [330.0, 1267.0], [330.0, 1466.0], [301.0, 1466.0]], [[259.0, 1269.0], [288.0, 1269.0], [288.0, 1476.0], [259.0, 1476.0]]], "lines": ["あなたの", "ことなんかに", "興味ないです。"]}, {"box": [1190, 1734, 1294, 1863], "vertical": true, "font_size": 33, "lines_coords": [[[1251.0, 1736.0], [1290.0, 1734.0], [1294.0, 1817.0], [1255.0, 1819.0]], [[1228.0, 1736.0], [1259.0, 1736.0], [1255.0, 1863.0], [1224.0, 1863.0]], [[1190.0, 1734.0], [1228.0, 1734.0], [1228.0, 1852.0], [1190.0, 1852.0]]], "lines": ["．．．ええ", "１６ページの", "３コマ目、"]}, {"box": [1030, 1759, 1155, 1954], "vertical": true, "font_size": 33, "lines_coords": [[[1120.0, 1759.0], [1155.0, 1759.0], [1155.0, 1879.0], [1120.0, 1879.0]], [[1086.0, 1761.0], [1122.0, 1761.0], [1122.0, 1894.0], [1086.0, 1894.0]], [[1057.0, 1763.0], [1086.0, 1763.0], [1084.0, 1954.0], [1055.0, 1954.0]], [[1030.0, 1765.0], [1053.0, 1765.0], [1053.0, 1898.0], [1030.0, 1898.0]]], "lines": ["「あの娘の", "タテスジを", "クンクンしたい」", "ってセリフ、"]}, {"box": [197, 1730, 326, 2000], "vertical": true, "font_size": 30, "lines_coords": [[[290.0, 1732.0], [326.0, 1732.0], [326.0, 1850.0], [290.0, 1850.0]], [[261.0, 1734.0], [290.0, 1734.0], [290.0, 1937.0], [261.0, 1937.0]], [[230.0, 1736.0], [257.0, 1736.0], [257.0, 2000.0], [230.0, 2000.0]], [[197.0, 1730.0], [226.0, 1730.0], [228.0, 1896.0], [199.0, 1896.0]]], "lines": ["「あの娘の", "タテスジちゃんを", "クンカクンガしたい」に", "訂正だそうで。"]}], "img_path": "048.png"}, {"version": "0.2.0-beta.6", "img_width": 1428, "img_height": 2127, "blocks": [{"box": [881, 562, 920, 824], "vertical": true, "font_size": 37, "lines_coords": [[[881.0, 562.0], [918.0, 562.0], [918.0, 664.0], [881.0, 664.0]]], "lines": ["．．．え"]}, {"box": [1229, 1412, 1271, 1588], "vertical": true, "font_size": 37, "lines_coords": [[[1230.0, 1412.0], [1267.0, 1412.0], [1267.0, 1582.0], [1230.0, 1582.0]]], "lines": ["タンポン、"]}, {"box": [914, 1840, 1003, 2000], "vertical": true, "font_size": 39, "lines_coords": [[[960.0, 1840.0], [1003.0, 1840.0], [1003.0, 1964.0], [960.0, 1964.0]], [[914.0, 1840.0], [949.0, 1840.0], [949.0, 2000.0], [914.0, 2000.0]]], "lines": ["替えて", "きます！！"]}], "img_path": "049.png"}, {"version": "0.2.0-beta.6", "img_width": 1431, "img_height": 2127, "blocks": [{"box": [1154, 137, 1264, 330], "vertical": true, "font_size": 30, "lines_coords": [[[1235.0, 137.0], [1264.0, 137.0], [1264.0, 330.0], [1235.0, 330.0]], [[1192.0, 137.0], [1223.0, 137.0], [1225.0, 328.0], [1194.0, 328.0]], [[1154.0, 139.0], [1183.0, 139.0], [1183.0, 328.0], [1154.0, 328.0]]], "lines": ["．．．前はもっと", "冷静だったん", "だけどな．．．"]}, {"box": [719, 141, 797, 356], "vertical": true, "font_size": 31, "lines_coords": [[[764.0, 143.0], [797.0, 143.0], [797.0, 249.0], [764.0, 249.0]], [[722.0, 145.0], [751.0, 145.0], [751.0, 351.0], [722.0, 351.0]]], "lines": ["．．．．．．", "小野寺さんは"]}, {"box": [145, 247, 267, 488], "vertical": true, "font_size": 35, "lines_coords": [[[230.0, 249.0], [265.0, 249.0], [265.0, 421.0], [230.0, 421.0]], [[184.0, 247.0], [220.0, 247.0], [222.0, 488.0], [186.0, 488.0]], [[145.0, 249.0], [180.0, 249.0], [180.0, 386.0], [145.0, 386.0]]], "lines": ["南条さんと", "付き合ってるん", "ですか？"]}, {"box": [1183, 916, 1264, 1088], "vertical": true, "font_size": 34, "lines_coords": [[[1221.0, 916.0], [1264.0, 916.0], [1264.0, 1032.0], [1221.0, 1032.0]], [[1183.0, 916.0], [1212.0, 916.0], [1212.0, 1088.0], [1183.0, 1088.0]]], "lines": ["へえー", "そうですか"]}, {"box": [1225, 1017, 1256, 1078], "vertical": true, "font_size": 34, "lines_coords": [[[1225.0, 1017.0], [1256.0, 1017.0], [1256.0, 1078.0], [1225.0, 1078.0]]], "lines": ["．．．"]}, {"box": [220, 1397, 309, 1650], "vertical": true, "font_size": 44, "lines_coords": [[[255.0, 1397.0], [309.0, 1397.0], [309.0, 1478.0], [255.0, 1478.0]], [[220.0, 1399.0], [255.0, 1399.0], [259.0, 1649.0], [224.0, 1649.0]]], "lines": ["別に", "いいんですけど。"]}], "img_path": "050.png"}, {"version": "0.2.0-beta.6", "img_width": 1428, "img_height": 2127, "blocks": [{"box": [199, 274, 318, 479], "vertical": true, "font_size": 37, "lines_coords": [[[280.0, 276.0], [318.0, 276.0], [318.0, 415.0], [280.0, 415.0]], [[243.0, 274.0], [280.0, 276.0], [274.0, 448.0], [236.0, 446.0]], [[199.0, 274.0], [234.0, 274.0], [234.0, 479.0], [199.0, 479.0]]], "lines": ["．．．なんか", "食べてから", "帰ろうかね？"]}, {"box": [1116, 670, 1191, 838], "vertical": true, "font_size": 34, "lines_coords": [[[1151.0, 670.0], [1191.0, 670.0], [1191.0, 772.0], [1151.0, 772.0]], [[1116.0, 670.0], [1145.0, 670.0], [1145.0, 835.0], [1116.0, 835.0]]], "lines": ["鍋とか", "いいなー．．．"]}, {"box": [318, 1051, 401, 1221], "vertical": true, "font_size": 38, "lines_coords": [[[365.0, 1055.0], [401.0, 1055.0], [397.0, 1221.0], [361.0, 1221.0]], [[322.0, 1051.0], [367.0, 1053.0], [363.0, 1161.0], [318.0, 1159.0]]], "lines": ["モツ食うか", "モツ！！"]}, {"box": [195, 1235, 315, 1441], "vertical": true, "font_size": 38, "lines_coords": [[[280.0, 1237.0], [315.0, 1237.0], [315.0, 1441.0], [280.0, 1441.0]], [[239.0, 1235.0], [274.0, 1235.0], [274.0, 1439.0], [239.0, 1439.0]], [[195.0, 1235.0], [232.0, 1235.0], [232.0, 1358.0], [195.0, 1358.0]]], "lines": ["あたしが全部", "おごってやる", "からよー"]}], "img_path": "051.png"}, {"version": "0.2.0-beta.6", "img_width": 1431, "img_height": 2127, "blocks": [{"box": [1231, 107, 1262, 248], "vertical": true, "font_size": 31, "lines_coords": [[[1231.0, 174.0], [1262.0, 174.0], [1262.0, 247.0], [1231.0, 247.0]]], "lines": ["ん？"]}, {"box": [807, 614, 845, 751], "vertical": true, "font_size": 38, "lines_coords": [[[807.0, 614.0], [845.0, 614.0], [845.0, 751.0], [807.0, 751.0]]], "lines": ["．．．なに？"]}, {"box": [139, 664, 238, 832], "vertical": true, "font_size": 48, "lines_coords": [[[193.0, 668.0], [236.0, 668.0], [236.0, 832.0], [193.0, 832.0]], [[139.0, 664.0], [193.0, 664.0], [193.0, 760.0], [139.0, 760.0]]], "lines": ["．．．だから", "何？"]}, {"box": [657, 940, 805, 1252], "vertical": true, "font_size": 41, "lines_coords": [[[758.0, 940.0], [801.0, 940.0], [805.0, 1252.0], [762.0, 1252.0]], [[704.0, 945.0], [747.0, 945.0], [751.0, 1152.0], [708.0, 1152.0]], [[660.0, 951.0], [697.0, 951.0], [697.0, 1134.0], [660.0, 1134.0]]], "lines": ["「：さっちゃんは", "天才だから", "大丈夫。」"]}], "img_path": "052.png"}, {"version": "0.2.0-beta.6", "img_width": 1433, "img_height": 2127, "blocks": [{"box": [367, 1867, 413, 2125], "vertical": true, "font_size": 46, "lines_coords": [[[367.0, 1867.0], [413.0, 1867.0], [413.0, 2125.0], [367.0, 2125.0]]], "lines": ["それはそういうことでしょうか。"]}], "img_path": "053.png"}, {"version": "0.2.0-beta.6", "img_width": 1434, "img_height": 2127, "blocks": [{"box": [1195, 114, 1242, 296], "vertical": true, "font_size": 43, "lines_coords": [[[1195.0, 118.0], [1238.0, 118.0], [1238.0, 290.0], [1195.0, 290.0]]], "lines": ["．．．．．．少し"]}, {"box": [224, 447, 273, 632], "vertical": true, "font_size": 44, "lines_coords": [[[224.0, 448.0], [268.0, 448.0], [272.0, 629.0], [228.0, 629.0]]], "lines": ["黙ってて。"]}, {"box": [750, 1179, 822, 1354], "vertical": true, "font_size": 32, "lines_coords": [[[787.0, 1179.0], [822.0, 1179.0], [822.0, 1350.0], [787.0, 1350.0]], [[750.0, 1183.0], [779.0, 1183.0], [779.0, 1354.0], [750.0, 1354.0]]], "lines": ["．．．やるしか", "ないんだよ、"]}, {"box": [627, 1350, 660, 1530], "vertical": true, "font_size": 32, "lines_coords": [[[627.0, 1350.0], [658.0, 1350.0], [660.0, 1530.0], [629.0, 1530.0]]], "lines": ["．．．やるしか。"]}], "img_path": "054.png"}, {"version": "0.2.0-beta.6", "img_width": 1430, "img_height": 2127, "blocks": [], "img_path": "055.png"}, {"version": "0.2.0-beta.6", "img_width": 1433, "img_height": 2127, "blocks": [], "img_path": "056.png"}, {"version": "0.2.0-beta.6", "img_width": 1430, "img_height": 2127, "blocks": [], "img_path": "057.png"}, {"version": "0.2.0-beta.6", "img_width": 1431, "img_height": 2127, "blocks": [{"box": [274, 344, 419, 650], "vertical": true, "font_size": 42, "lines_coords": [[[373.0, 344.0], [415.0, 344.0], [415.0, 631.0], [373.0, 631.0]], [[324.0, 346.0], [367.0, 346.0], [367.0, 479.0], [324.0, 479.0]], [[274.0, 344.0], [315.0, 344.0], [315.0, 650.0], [274.0, 650.0]]], "lines": ["東京都知事候補", "無所属、", "星川としき３８歳。"]}, {"box": [49, 415, 110, 629], "vertical": true, "font_size": 61, "lines_coords": [[[49.0, 415.0], [110.0, 415.0], [110.0, 629.0], [49.0, 629.0]]], "lines": ["第９２話"]}, {"box": [1131, 961, 1281, 1244], "vertical": true, "font_size": 31, "lines_coords": [[[1248.0, 961.0], [1277.0, 961.0], [1281.0, 1213.0], [1252.0, 1213.0]], [[1208.0, 961.0], [1239.0, 961.0], [1242.0, 1150.0], [1210.0, 1150.0]], [[1171.0, 963.0], [1200.0, 963.0], [1200.0, 1244.0], [1171.0, 1244.0]], [[1131.0, 963.0], [1158.0, 963.0], [1158.0, 1196.0], [1131.0, 1196.0]]], "lines": ["早稲田大学中退後", "超ひも理論を", "独自に研究しながら", "日本各地を警備。"]}, {"box": [967, 1208, 1119, 1441], "vertical": true, "font_size": 31, "lines_coords": [[[1090.0, 1210.0], [1119.0, 1210.0], [1119.0, 1427.0], [1090.0, 1427.0]], [[1046.0, 1208.0], [1084.0, 1208.0], [1084.0, 1323.0], [1046.0, 1323.0]], [[1011.0, 1210.0], [1040.0, 1210.0], [1040.0, 1366.0], [1011.0, 1366.0]], [[969.0, 1208.0], [1005.0, 1208.0], [1003.0, 1441.0], [967.0, 1441.0]]], "lines": ["ペガサス合奏団", "楽団長、", "またの名を", "ペガサス楽団長。"]}, {"box": [234, 1215, 355, 1485], "vertical": true, "font_size": 32, "lines_coords": [[[321.0, 1219.0], [351.0, 1219.0], [351.0, 1385.0], [321.0, 1385.0]], [[274.0, 1215.0], [309.0, 1215.0], [309.0, 1485.0], [274.0, 1485.0]], [[234.0, 1219.0], [265.0, 1219.0], [267.0, 1429.0], [236.0, 1429.0]]], "lines": ["では続いて", "星川としきさんの", "政見放送です。"]}], "img_path": "058.png"}, {"version": "0.2.0-beta.6", "img_width": 1432, "img_height": 2127, "blocks": [{"box": [1094, 843, 1192, 1048], "vertical": true, "font_size": 48, "lines_coords": [[[1132.0, 843.0], [1192.0, 843.0], [1192.0, 976.0], [1132.0, 976.0]], [[1095.0, 847.0], [1132.0, 847.0], [1132.0, 1046.0], [1095.0, 1046.0]]], "lines": ["みんな", "おはよう！！"]}, {"box": [253, 950, 298, 1216], "vertical": true, "font_size": 42, "lines_coords": [[[253.0, 951.0], [295.0, 951.0], [295.0, 1215.0], [253.0, 1215.0]]], "lines": ["ペガサスだよ。"]}, {"box": [326, 1499, 419, 1632], "vertical": true, "font_size": 41, "lines_coords": [[[361.0, 1501.0], [415.0, 1499.0], [419.0, 1622.0], [365.0, 1624.0]], [[326.0, 1505.0], [369.0, 1505.0], [369.0, 1632.0], [326.0, 1632.0]]], "lines": ["．．．断言", "しよう。"]}, {"box": [332, 1503, 413, 1636], "vertical": true, "font_size": 81, "lines_coords": [[[332.0, 1503.0], [413.0, 1503.0], [413.0, 1636.0], [332.0, 1636.0]]], "lines": ["．．．断言しよう。"]}, {"box": [1020, 1476, 1220, 1846], "vertical": true, "font_size": 35, "lines_coords": [[[1184.0, 1476.0], [1220.0, 1476.0], [1220.0, 1746.0], [1184.0, 1746.0]], [[1141.0, 1476.0], [1178.0, 1476.0], [1180.0, 1680.0], [1143.0, 1680.0]], [[1101.0, 1478.0], [1136.0, 1478.0], [1136.0, 1846.0], [1101.0, 1846.0]], [[1059.0, 1476.0], [1095.0, 1476.0], [1095.0, 1815.0], [1059.0, 1815.0]], [[1020.0, 1478.0], [1049.0, 1478.0], [1049.0, 1751.0], [1020.0, 1751.0]]], "lines": ["僕が研究している", "超ひも理論の", "スペシャルな応用により", "僕は未来に触れられる", "ようになったんだ"]}, {"box": [170, 1729, 294, 1990], "vertical": true, "font_size": 124, "lines_coords": [[[170.0, 1729.0], [294.0, 1729.0], [294.0, 1990.0], [170.0, 1990.0]]], "lines": ["今年の七月七日に地球はドハッと消滅する。"]}, {"box": [170, 1721, 286, 1991], "vertical": true, "font_size": 41, "lines_coords": [[[257.0, 1728.0], [286.0, 1728.0], [286.0, 1991.0], [257.0, 1991.0]], [[209.0, 1721.0], [251.0, 1721.0], [247.0, 1962.0], [205.0, 1962.0]], [[170.0, 1724.0], [205.0, 1724.0], [205.0, 1875.0], [170.0, 1875.0]]], "lines": ["今年の七月七日に", "地球はドハッと", "消滅する。"]}], "img_path": "059.png"}, {"version": "0.2.0-beta.6", "img_width": 1433, "img_height": 2127, "blocks": [{"box": [1192, 81, 1291, 272], "vertical": true, "font_size": 30, "lines_coords": [[[1250.0, 83.0], [1287.0, 81.0], [1291.0, 195.0], [1254.0, 197.0]], [[1221.0, 81.0], [1256.0, 81.0], [1256.0, 195.0], [1221.0, 195.0]], [[1192.0, 83.0], [1219.0, 83.0], [1219.0, 272.0], [1192.0, 272.0]]], "lines": ["．．．それは", "なぜだか", "知りたいかい？"]}, {"box": [1036, 311, 1198, 612], "vertical": true, "font_size": 30, "lines_coords": [[[1171.0, 313.0], [1198.0, 313.0], [1198.0, 529.0], [1171.0, 529.0]], [[1136.0, 311.0], [1165.0, 311.0], [1163.0, 531.0], [1133.0, 531.0]], [[1102.0, 311.0], [1129.0, 311.0], [1129.0, 504.0], [1102.0, 504.0]], [[1067.0, 311.0], [1096.0, 311.0], [1098.0, 612.0], [1069.0, 612.0]], [[1036.0, 313.0], [1063.0, 313.0], [1063.0, 585.0], [1036.0, 585.0]]], "lines": ["便宜上例えるなら", "それは片目の無い", "目出しダルマが", "降ってくるからと言って", "差し支えないだろう．．．"]}, {"box": [299, 145, 415, 415], "vertical": true, "font_size": 33, "lines_coords": [[[386.0, 151.0], [415.0, 151.0], [415.0, 353.0], [386.0, 353.0]], [[342.0, 147.0], [371.0, 147.0], [371.0, 415.0], [342.0, 415.0]], [[299.0, 145.0], [336.0, 145.0], [336.0, 270.0], [299.0, 270.0]]], "lines": ["つまりそれは", "「約束された絶望」", "であり、"]}, {"box": [1138, 795, 1248, 1048], "vertical": true, "font_size": 30, "lines_coords": [[[1212.0, 795.0], [1248.0, 795.0], [1248.0, 957.0], [1212.0, 957.0]], [[1177.0, 797.0], [1204.0, 797.0], [1204.0, 986.0], [1177.0, 986.0]], [[1138.0, 797.0], [1167.0, 797.0], [1167.0, 1048.0], [1138.0, 1048.0]]], "lines": ["だから僕は", "ずっとすっと", "準備をしていた．．．"]}, {"box": [215, 429, 292, 685], "vertical": true, "font_size": 33, "lines_coords": [[[257.0, 429.0], [292.0, 429.0], [292.0, 635.0], [257.0, 635.0]], [[215.0, 429.0], [251.0, 429.0], [251.0, 685.0], [215.0, 685.0]]], "lines": ["不可避であり", "決定事項なのだ。"]}, {"box": [319, 845, 440, 1082], "vertical": true, "font_size": 31, "lines_coords": [[[396.0, 845.0], [440.0, 845.0], [440.0, 986.0], [396.0, 986.0]], [[359.0, 845.0], [394.0, 845.0], [392.0, 1082.0], [357.0, 1082.0]], [[319.0, 851.0], [348.0, 851.0], [348.0, 1053.0], [319.0, 1053.0]]], "lines": ["．．．そして", "その準備は整い", "つつある．．．．．．"]}, {"box": [1007, 1055, 1115, 1275], "vertical": true, "font_size": 30, "lines_coords": [[[1086.0, 1057.0], [1115.0, 1057.0], [1115.0, 1213.0], [1086.0, 1213.0]], [[1046.0, 1057.0], [1075.0, 1057.0], [1075.0, 1213.0], [1046.0, 1213.0]], [[1007.0, 1055.0], [1036.0, 1055.0], [1036.0, 1275.0], [1007.0, 1275.0]]], "lines": ["同志を募り", "その絶望を", "回避する術を．．．"]}, {"box": [218, 1142, 328, 1308], "vertical": true, "font_size": 31, "lines_coords": [[[299.0, 1142.0], [328.0, 1142.0], [328.0, 1308.0], [299.0, 1308.0]], [[255.0, 1142.0], [284.0, 1142.0], [284.0, 1308.0], [255.0, 1308.0]], [[218.0, 1144.0], [240.0, 1144.0], [240.0, 1240.0], [218.0, 1240.0]]], "lines": ["僕は世界を", "救えるんだ", "．．．．．．"]}, {"box": [1160, 1505, 1217, 1717], "vertical": true, "font_size": 52, "lines_coords": [[[1160.0, 1510.0], [1212.0, 1510.0], [1217.0, 1717.0], [1165.0, 1717.0]]], "lines": ["．．．グッド"]}, {"box": [170, 1661, 305, 1960], "vertical": true, "font_size": 70, "lines_coords": [[[230.0, 1663.0], [305.0, 1663.0], [305.0, 1834.0], [230.0, 1834.0]], [[170.0, 1661.0], [234.0, 1661.0], [238.0, 1960.0], [174.0, 1960.0]]], "lines": ["バイブ", "レーション。"]}], "img_path": "060.png"}, {"version": "0.2.0-beta.6", "img_width": 1430, "img_height": 2127, "blocks": [{"box": [1060, 143, 1165, 336], "vertical": true, "font_size": 31, "lines_coords": [[[1134.0, 149.0], [1163.0, 149.0], [1163.0, 303.0], [1134.0, 303.0]], [[1095.0, 143.0], [1130.0, 143.0], [1126.0, 336.0], [1091.0, 336.0]], [[1060.0, 149.0], [1089.0, 149.0], [1089.0, 334.0], [1060.0, 334.0]]], "lines": ["．．．けど僕は", "ずっと疑問に", "思っていた"]}, {"box": [216, 224, 394, 504], "vertical": true, "font_size": 31, "lines_coords": [[[355.0, 224.0], [390.0, 224.0], [394.0, 355.0], [359.0, 355.0]], [[324.0, 230.0], [353.0, 230.0], [353.0, 504.0], [324.0, 504.0]], [[288.0, 230.0], [318.0, 230.0], [318.0, 475.0], [288.0, 475.0]], [[251.0, 230.0], [280.0, 230.0], [280.0, 502.0], [251.0, 502.0]], [[216.0, 228.0], [247.0, 228.0], [247.0, 324.0], [216.0, 324.0]]], "lines": ["果たして", "この世界というのは", "救うほどの価値が", "あるのかということ", "を．．．"]}, {"box": [1058, 761, 1236, 1019], "vertical": true, "font_size": 178, "lines_coords": [[[1058.0, 761.0], [1236.0, 761.0], [1236.0, 1019.0], [1058.0, 1019.0]]], "lines": ["．．．この１０数年、世の中の停滞を感じてきたラヴァーズも多いと思う．．．"]}, {"box": [1053, 756, 1232, 1032], "vertical": true, "font_size": 30, "lines_coords": [[[1203.0, 762.0], [1232.0, 762.0], [1232.0, 953.0], [1203.0, 953.0]], [[1166.0, 762.0], [1195.0, 762.0], [1195.0, 974.0], [1166.0, 974.0]], [[1130.0, 762.0], [1159.0, 762.0], [1159.0, 913.0], [1130.0, 913.0]], [[1091.0, 758.0], [1120.0, 758.0], [1120.0, 1032.0], [1091.0, 1032.0]], [[1053.0, 756.0], [1089.0, 756.0], [1089.0, 882.0], [1053.0, 882.0]]], "lines": ["．．．この１０数年、", "世の中の停滞を", "感じてきた", "ラヴァーズも多いと", "思う．．．"]}, {"box": [251, 785, 432, 1061], "vertical": true, "font_size": 31, "lines_coords": [[[403.0, 789.0], [432.0, 789.0], [432.0, 911.0], [403.0, 911.0]], [[363.0, 785.0], [392.0, 785.0], [396.0, 986.0], [367.0, 986.0]], [[328.0, 787.0], [357.0, 787.0], [357.0, 1061.0], [328.0, 1061.0]], [[293.0, 789.0], [322.0, 789.0], [322.0, 1032.0], [293.0, 1032.0]], [[251.0, 785.0], [288.0, 785.0], [288.0, 893.0], [251.0, 893.0]]], "lines": ["．．．どこか", "満たされない、", "まるで真綿でクビを", "締められるように", "苦しい。"]}, {"box": [981, 1063, 1082, 1304], "vertical": true, "font_size": 30, "lines_coords": [[[1053.0, 1063.0], [1082.0, 1063.0], [1082.0, 1244.0], [1053.0, 1244.0]], [[1018.0, 1063.0], [1045.0, 1063.0], [1045.0, 1246.0], [1018.0, 1246.0]], [[981.0, 1063.0], [1010.0, 1063.0], [1010.0, 1304.0], [981.0, 1304.0]]], "lines": ["これだけ物が", "溢れていても", "これだけ情報網の"]}, {"box": [904, 1063, 1085, 1335], "vertical": true, "font_size": 29, "lines_coords": [[[943.0, 1063.0], [972.0, 1063.0], [972.0, 1333.0], [943.0, 1333.0]]], "lines": ["発達でみんなが常時"]}, {"box": [1145, 1470, 1220, 1651], "vertical": true, "font_size": 39, "lines_coords": [[[1184.0, 1470.0], [1215.0, 1470.0], [1220.0, 1638.0], [1188.0, 1638.0]], [[1145.0, 1474.0], [1174.0, 1474.0], [1178.0, 1651.0], [1149.0, 1651.0]]], "lines": ["．．．だが僕は", "こう思うよ。"]}, {"box": [906, 1063, 935, 1279], "vertical": true, "font_size": 30, "lines_coords": [[[906.0, 1063.0], [935.0, 1063.0], [935.0, 1279.0], [906.0, 1279.0]]], "lines": ["繋がっていても"]}, {"box": [174, 1102, 282, 1323], "vertical": true, "font_size": 31, "lines_coords": [[[243.0, 1102.0], [282.0, 1102.0], [282.0, 1200.0], [243.0, 1200.0]], [[212.0, 1105.0], [241.0, 1105.0], [241.0, 1316.0], [212.0, 1316.0]], [[174.0, 1105.0], [201.0, 1105.0], [201.0, 1323.0], [174.0, 1323.0]]], "lines": ["まるで", "世界の終わりの", "ように真っ暗だ。"]}, {"box": [175, 1102, 276, 1330], "vertical": true, "font_size": 101, "lines_coords": [[[175.0, 1102.0], [276.0, 1102.0], [276.0, 1330.0], [175.0, 1330.0]]], "lines": ["まるで世界の終わりのように真っ暗だ。"]}, {"box": [988, 1690, 1104, 1922], "vertical": true, "font_size": 116, "lines_coords": [[[988.0, 1690.0], [1104.0, 1690.0], [1104.0, 1922.0], [988.0, 1922.0]]], "lines": ["世界は終わったのではなく、"]}, {"box": [978, 1684, 1107, 1927], "vertical": true, "font_size": 39, "lines_coords": [[[1064.0, 1688.0], [1107.0, 1688.0], [1107.0, 1796.0], [1064.0, 1796.0]], [[1022.0, 1686.0], [1064.0, 1686.0], [1064.0, 1927.0], [1022.0, 1927.0]], [[978.0, 1684.0], [1028.0, 1684.0], [1028.0, 1773.0], [978.0, 1773.0]]], "lines": ["世界は", "終わったのでは", "なく、"]}, {"box": [170, 1651, 330, 1902], "vertical": true, "font_size": 32, "lines_coords": [[[295.0, 1651.0], [330.0, 1651.0], [330.0, 1788.0], [295.0, 1788.0]], [[251.0, 1653.0], [286.0, 1653.0], [286.0, 1788.0], [251.0, 1788.0]], [[214.0, 1653.0], [243.0, 1653.0], [243.0, 1819.0], [214.0, 1819.0]], [[172.0, 1653.0], [201.0, 1653.0], [201.0, 1902.0], [172.0, 1902.0]]], "lines": ["もっとも", "理想的な", "バランスで", "完成したのだと。"]}], "img_path": "061.png"}, {"version": "0.2.0-beta.6", "img_width": 1431, "img_height": 2127, "blocks": [{"box": [1121, 116, 1279, 359], "vertical": true, "font_size": 32, "lines_coords": [[[1250.0, 122.0], [1279.0, 122.0], [1279.0, 324.0], [1250.0, 324.0]], [[1208.0, 124.0], [1237.0, 124.0], [1237.0, 357.0], [1208.0, 357.0]], [[1163.0, 118.0], [1198.0, 118.0], [1198.0, 359.0], [1163.0, 359.0]], [[1121.0, 116.0], [1158.0, 116.0], [1158.0, 240.0], [1121.0, 240.0]]], "lines": ["科学も宗教も", "文明はたった今", "この瞬間が至高", "である。"]}, {"box": [957, 330, 1073, 618], "vertical": true, "font_size": 32, "lines_coords": [[[1038.0, 334.0], [1073.0, 334.0], [1073.0, 473.0], [1038.0, 473.0]], [[999.0, 336.0], [1028.0, 336.0], [1028.0, 573.0], [999.0, 573.0]], [[957.0, 330.0], [986.0, 330.0], [986.0, 618.0], [957.0, 618.0]]], "lines": ["．．．つまり", "世界はおいしく", "できあがったのだ。"]}, {"box": [284, 105, 407, 340], "vertical": true, "font_size": 36, "lines_coords": [[[363.0, 105.0], [407.0, 105.0], [407.0, 216.0], [363.0, 216.0]], [[326.0, 108.0], [361.0, 108.0], [361.0, 340.0], [326.0, 340.0]], [[284.0, 108.0], [319.0, 108.0], [319.0, 313.0], [284.0, 313.0]]], "lines": ["これは", "喜ぶべき事じゃ", "ないのかね？"]}, {"box": [201, 411, 321, 581], "vertical": true, "font_size": 36, "lines_coords": [[[292.0, 417.0], [321.0, 417.0], [321.0, 581.0], [292.0, 581.0]], [[247.0, 415.0], [284.0, 415.0], [284.0, 552.0], [247.0, 552.0]], [[205.0, 411.0], [243.0, 411.0], [238.0, 564.0], [201.0, 564.0]]], "lines": ["おめでとう", "みんな！！", "パチパチ。"]}, {"box": [1098, 857, 1239, 1067], "vertical": true, "font_size": 33, "lines_coords": [[[1210.0, 859.0], [1239.0, 859.0], [1239.0, 1011.0], [1210.0, 1011.0]], [[1171.0, 857.0], [1206.0, 857.0], [1206.0, 1044.0], [1171.0, 1044.0]], [[1134.0, 857.0], [1169.0, 857.0], [1169.0, 1067.0], [1134.0, 1067.0]], [[1098.0, 859.0], [1127.0, 859.0], [1127.0, 1011.0], [1098.0, 1011.0]]], "lines": ["．．．．．おや？", "なのにみんな", "悲しげな顔じゃ", "ないか．．．"]}, {"box": [1015, 1111, 1055, 1313], "vertical": true, "font_size": 40, "lines_coords": [[[1015.0, 1111.0], [1055.0, 1111.0], [1055.0, 1313.0], [1015.0, 1313.0]]], "lines": ["．．．なぜだい？"]}, {"box": [1013, 1111, 1053, 1314], "vertical": true, "font_size": 33, "lines_coords": [[[1013.0, 1111.0], [1048.0, 1111.0], [1053.0, 1314.0], [1017.0, 1314.0]]], "lines": ["．．．なぜだい？"]}, {"box": [267, 1144, 346, 1348], "vertical": true, "font_size": 36, "lines_coords": [[[311.0, 1144.0], [346.0, 1144.0], [346.0, 1314.0], [311.0, 1314.0]], [[267.0, 1148.0], [303.0, 1148.0], [303.0, 1348.0], [267.0, 1348.0]]], "lines": ["．．．お腹でも", "痛いのかい？"]}, {"box": [1133, 1559, 1176, 1780], "vertical": true, "font_size": 41, "lines_coords": [[[1134.0, 1564.0], [1175.0, 1564.0], [1175.0, 1778.0], [1134.0, 1778.0]]], "lines": ["．．．なぜなら、"]}, {"box": [211, 1653, 357, 1933], "vertical": true, "font_size": 41, "lines_coords": [[[309.0, 1653.0], [353.0, 1653.0], [357.0, 1821.0], [313.0, 1821.0]], [[265.0, 1657.0], [301.0, 1657.0], [301.0, 1933.0], [265.0, 1933.0]], [[211.0, 1655.0], [255.0, 1655.0], [255.0, 1794.0], [211.0, 1794.0]]], "lines": ["なぜなら", "君達はわがまま", "だから。"]}], "img_path": "062.png"}, {"version": "0.2.0-beta.6", "img_width": 1430, "img_height": 2127, "blocks": [{"box": [1134, 151, 1255, 371], "vertical": true, "font_size": 51, "lines_coords": [[[1203.0, 151.0], [1255.0, 151.0], [1251.0, 371.0], [1199.0, 371.0]], [[1134.0, 151.0], [1184.0, 151.0], [1184.0, 369.0], [1134.0, 369.0]]], "lines": ["．．．じゃあ", "僕はッ