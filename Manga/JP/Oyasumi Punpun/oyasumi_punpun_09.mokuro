s": [[[901.0, 716.0], [936.0, 716.0], [936.0, 853.0], [901.0, 853.0]], [[859.0, 716.0], [894.0, 716.0], [894.0, 886.0], [859.0, 886.0]], [[820.0, 714.0], [849.0, 714.0], [849.0, 913.0], [820.0, 913.0]]], "lines": ["時間なら", "全然大丈夫", "ですけど．．．"]}, {"box": [463, 685, 547, 889], "vertical": true, "font_size": 40, "lines_coords": [[[510.0, 687.0], [546.0, 687.0], [546.0, 889.0], [510.0, 889.0]], [[463.0, 685.0], [508.0, 685.0], [508.0, 774.0], [463.0, 774.0]]], "lines": ["：ひるまない", "勇気。"]}, {"box": [209, 727, 321, 979], "vertical": true, "font_size": 34, "lines_coords": [[[272.0, 729.0], [315.0, 727.0], [321.0, 859.0], [278.0, 862.0]], [[247.0, 733.0], [276.0, 733.0], [276.0, 889.0], [247.0, 889.0]], [[209.0, 733.0], [238.0, 733.0], [238.0, 976.0], [209.0, 976.0]]], "lines": ["．．．そっか", "今日が初日", "だったんですね．．．"]}, {"box": [1204, 1063, 1268, 1275], "vertical": true, "font_size": 28, "lines_coords": [[[1239.0, 1063.0], [1268.0, 1063.0], [1268.0, 1242.0], [1239.0, 1242.0]], [[1204.0, 1065.0], [1231.0, 1065.0], [1231.0, 1275.0], [1204.0, 1275.0]]], "lines": ["でも友達思い", "なんですねー．．．"]}, {"box": [1090, 1318, 1191, 1586], "vertical": true, "font_size": 28, "lines_coords": [[[1164.0, 1318.0], [1191.0, 1318.0], [1191.0, 1586.0], [1164.0, 1586.0]], [[1127.0, 1318.0], [1156.0, 1318.0], [1156.0, 1499.0], [1127.0, 1499.0]], [[1090.0, 1318.0], [1119.0, 1318.0], [1119.0, 1530.0], [1090.0, 1530.0]]], "lines": ["フットサルチームの", "遠征のために", "免許取るなんて"]}, {"box": [330, 1078, 431, 1325], "vertical": true, "font_size": 30, "lines_coords": [[[402.0, 1080.0], [431.0, 1080.0], [431.0, 1262.0], [402.0, 1262.0]], [[367.0, 1082.0], [396.0, 1082.0], [396.0, 1291.0], [367.0, 1291.0]], [[330.0, 1078.0], [357.0, 1078.0], [357.0, 1325.0], [330.0, 1325.0]]], "lines": ["あたしは親に", "取っておけって", "言われちゃって．．．"]}, {"box": [176, 1329, 357, 1645], "vertical": true, "font_size": 30, "lines_coords": [[[328.0, 1329.0], [357.0, 1329.0], [357.0, 1526.0], [328.0, 1526.0]], [[288.0, 1345.0], [317.0, 1345.0], [317.0, 1645.0], [288.0, 1645.