 1231.0]], [[562.0, 1063.0], [598.0, 1063.0], [598.0, 1281.0], [562.0, 1281.0]]], "lines": ["大学の友達は", "みんなそう", "呼んでるし！！」"]}, {"box": [591, 1493, 697, 1692], "vertical": true, "font_size": 34, "lines_coords": [[[660.0, 1493.0], [697.0, 1493.0], [697.0, 1622.0], [660.0, 1622.0]], [[625.0, 1495.0], [662.0, 1495.0], [662.0, 1622.0], [625.0, 1622.0]], [[591.0, 1497.0], [620.0, 1497.0], [620.0, 1692.0], [591.0, 1692.0]]], "lines": ["ちょっと", "待ってて", "すぐ済むから。"]}, {"box": [176, 1774, 206, 2009], "vertical": true, "font_size": 23, "lines_coords": [[[176.0, 1796.0], [199.0, 1796.0], [201.0, 2002.0], [178.0, 2002.0]]], "lines": ["．．．まんこ見せろ。"]}], "img_path": "219.png"}, {"version": "0.2.0-beta.6", "img_width": 1438, "img_height": 2127, "blocks": [{"box": [1183, 51, 1250, 267], "vertical": true, "font_size": 28, "lines_coords": [[[1219.0, 54.0], [1248.0, 54.0], [1248.0, 263.0], [1219.0, 263.0]], [[1184.0, 54.0], [1211.0, 54.0], [1211.0, 265.0], [1184.0, 265.0]]], "lines": ["次回もよろしく", "お願いします！！"]}, {"box": [380, 201, 449, 473], "vertical": true, "font_size": 29, "lines_coords": [[[415.0, 201.0], [444.0, 201.0], [444.0, 473.0], [415.0, 473.0]], [[380.0, 201.0], [409.0, 201.0], [409.0, 446.0], [380.0, 446.0]]], "lines": ["自分らしさなんかに", "こだわらなければ"]}, {"box": [244, 197, 445, 484], "vertical": true, "font_size": 201, "lines_coords": [[[244.0, 197.0], [445.0, 197.0], [445.0, 484.0], [244.0, 484.0]]], "lines": ["自分らしさなんかにこたわらなければ、笑っちゃうくらい楽勝じゃないですか。"]}, {"box": [245, 199, 316, 482], "vertical": true, "font_size": 29, "lines_coords": [[[284.0, 201.0], [313.0, 201.0], [313.0, 440.0], [284.0, 440.0]], [[247.0, 199.0], [276.0, 199.0], [276.0, 475.0], [247.0, 475.0]]], "lines": ["笑っちゃうくらい", "楽勝じゃないですか"]}, {"box": [583, 517, 712, 727], "vertical": true, "font_size": 42, "lines_coords": [[[664.0, 517.0], [712.0, 517.0], [712.0, 625.0], [664.0, 625.0]], [[629.0, 521.0], [664.0, 521.0], [664.0, 727.0], [629.0, 727.0]], [[583.0, 519.0], [627.0, 519.0], [627.0, 639.0], [583.0, 639.0]]], "lines": ["．．．は