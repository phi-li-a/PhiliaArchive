043.0]], [[151.0, 1809.0], [186.0, 1809.0], [186.0, 2010.0], [151.0, 2010.0]]], "lines": ["絶対的な", "「黒点」が潜んで", "いるとでも？"]}], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 1433, "img_height": 2127, "blocks": [{"box": [1191, 172, 1224, 345], "vertical": true, "font_size": 29, "lines_coords": [[[1192.0, 257.0], [1221.0, 257.0], [1221.0, 340.0], [1192.0, 340.0]], [[1192.0, 174.0], [1221.0, 174.0], [1221.0, 236.0], [1192.0, 236.0]]], "lines": ["と．．．", "えー"]}, {"box": [236, 284, 316, 518], "vertical": true, "font_size": 30, "lines_coords": [[[282.0, 286.0], [311.0, 286.0], [311.0, 515.0], [282.0, 515.0]], [[242.0, 284.0], [274.0, 284.0], [267.0, 486.0], [236.0, 486.0]]], "lines": ["ここにあるもの", "全部ですか？"]}, {"box": [1200, 685, 1283, 839], "vertical": true, "font_size": 42, "lines_coords": [[[1248.0, 689.0], [1283.0, 689.0], [1283.0, 835.0], [1248.0, 835.0]], [[1200.0, 685.0], [1248.0, 685.0], [1248.0, 774.0], [1200.0, 774.0]]], "lines": ["．．．そう、", "全部。"]}, {"box": [308, 795, 451, 1070], "vertical": true, "font_size": 143, "lines_coords": [[[308.0, 795.0], [451.0, 795.0], [451.0, 1070.0], [308.0, 1070.0]]], "lines": ["．．．ちょっと量が多過ぎるしウチは基本、家電の引き取りなんで．．．"]}, {"box": [307, 797, 446, 1069], "vertical": true, "font_size": 33, "lines_coords": [[[417.0, 797.0], [446.0, 797.0], [446.0, 1009.0], [417.0, 1009.0]], [[382.0, 797.0], [411.0, 797.0], [411.0, 951.0], [382.0, 951.0]], [[342.0, 797.0], [371.0, 797.0], [371.0, 1069.0], [342.0, 1069.0]], [[307.0, 797.0], [336.0, 797.0], [336.0, 1040.0], [307.0, 1040.0]]], "lines": ["．．．ちょっと量が", "多過ぎるし", "ウチは基本、家電の", "引き取りなんで．．．"]}, {"box": [1252, 1470, 1327, 1653], "vertical": true, "font_size": 32, "lines_coords": [[[1287.0, 1470.0], [1327.0, 1470.0], [1327.0, 1568.0], [1287.0, 1568.0]], [[1256.0, 1472.0], [1287.0, 1472.0], [1283.0, 1653.0], [1252.0, 1653.0]]], "lines": ["．．．あの", "大坊ちゃん．．．"]}, {"box": [228, 1117, 353, 1356], "vertical": true, "font_size": 33, "lines_coords": [[[301.0, 1117.0], [353.0, 1117.0], [353.0, 1231.0], [