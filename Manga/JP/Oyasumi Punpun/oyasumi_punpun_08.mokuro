.0, 271.0], [104.0, 271.0]]], "lines": ["お客様", "当店は初めて", "ですか？"]}, {"box": [126, 443, 245, 625], "vertical": true, "font_size": 27, "lines_coords": [[[217.0, 443.0], [243.0, 443.0], [240.0, 625.0], [214.0, 625.0]], [[185.0, 443.0], [214.0, 443.0], [210.0, 587.0], [182.0, 587.0]], [[153.0, 445.0], [179.0, 445.0], [179.0, 598.0], [153.0, 598.0]]], "lines": ["運転免許ないと", "会員証作れ", "ないんですよ"]}, {"box": [178, 1343, 206, 1510], "vertical": true, "font_size": 26, "lines_coords": [[[178.0, 1343.0], [204.0, 1343.0], [204.0, 1510.0], [178.0, 1510.0]]], "lines": ["．．．小野寺くん。"]}], "img_path": "134.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [900, 95, 998, 251], "vertical": true, "font_size": 27, "lines_coords": [[[960.0, 96.0], [993.0, 95.0], [998.0, 228.0], [965.0, 229.0]], [[932.0, 96.0], [959.0, 96.0], [959.0, 251.0], [932.0, 251.0]], [[900.0, 95.0], [928.0, 95.0], [928.0, 179.0], [900.0, 179.0]]], "lines": ["いやぁ～～", "便利になった", "よ～～"]}, {"box": [826, 279, 914, 446], "vertical": true, "font_size": 27, "lines_coords": [[[887.0, 279.0], [914.0, 279.0], [914.0, 410.0], [887.0, 410.0]], [[856.0, 281.0], [878.0, 281.0], [878.0, 446.0], [856.0, 446.0]], [[826.0, 281.0], [848.0, 281.0], [848.0, 409.0], [826.0, 409.0]]], "lines": ["これからは", "コンピュータの", "時代だね！！"]}, {"box": [823, 281, 914, 449], "vertical": true, "font_size": 91, "lines_coords": [[[823.0, 281.0], [914.0, 281.0], [914.0, 449.0], [823.0, 449.0]]], "lines": ["これからはコンピュータの時代だね！！"]}, {"box": [887, 673, 981, 848], "vertical": true, "font_size": 27, "lines_coords": [[[953.0, 673.0], [981.0, 673.0], [978.0, 809.0], [950.0, 809.0]], [[918.0, 675.0], [945.0, 675.0], [945.0, 848.0], [918.0, 848.0]], [[887.0, 673.0], [914.0, 673.0], [914.0, 782.0], [887.0, 782.0]]], "lines": ["小野寺くん、", "飲み込み早いん", "だからさ"]}, {"box": [142, 370, 235, 553], "vertical": true, "font_size": 28, "lines_coords": [[[203.0, 370.0], [235.0, 370.0], [235.0, 478.0], [203.0, 478.0]], [[173.0, 371.0], [200.0, 371.0], [200.0, 553.0], [173.0, 553.0]], [[142.0, 371.0], [165.0, 371.0], [167.0, 534.0], [143.0, 534.0]]], "lines": ["やっぱり", "若い力ってのは", "必要なんだな。"]}, {"box": [770, 743, 862, 928], "vertical": true, "font_size": 27, "lines_coords": [[[829.0, 743.0], [862.0, 745.0], [859.0, 851.0], [826.0, 850.0]], [[803.0, 750.0], [825.0, 750.0], [825.0, 901.0], [803.0, 901.0]], [[770.0, 746.0], [796.0, 746.0], [796.0, 928.0], [770.0, 928.0]]], "lines": ["ついでに", "宅建の資格も", "取っちゃいなよ。"]}, {"box": [885, 992, 1012, 1173], "vertical": true, "font_size": 26, "lines_coords": [[[985.0, 992.0], [1012.0, 992.0], [1012.0, 1131.0], [985.0, 1131.0]], [[956.0, 996.0], [978.0, 996.0], [978.0, 1173.0], [956.0, 1173.0]], [[923.0, 993.0], [945.0, 993.0], [945.0, 1143.0], [923.0, 1143.0]], [[885.0, 992.0], [918.0, 992.0], [918.0, 1073.0], [885.0, 1073.0]]], "lines": ["．．．どうだい、", "みすずちゃんも", "そう思わない", "かい？"]}, {"box": [118, 740, 239, 880], "vertical": true, "font_size": 26, "lines_coords": [[[212.0, 740.0], [239.0, 740.0], [239.0, 846.0], [212.0, 846.0]], [[179.0, 742.0], [206.0, 742.0], [206.0, 870.0], [179.0, 870.0]], [[148.0, 740.0], [175.0, 740.0], [175.0, 870.0], [148.0, 870.0]], [[118.0, 743.0], [140.0, 743.0], [140.0, 876.0], [118.0, 876.0]]], "lines": ["そのまま", "ウチに就職", "しちゃえば", "いいんだよ。"]}, {"box": [237, 985, 268, 1043], "vertical": true, "font_size": 31, "lines_coords": [[[237.0, 985.0], [268.0, 985.0], [268.0, 1043.0], [237.0, 1043.0]]], "lines": ["あ？"]}, {"box": [128, 1018, 193, 1164], "vertical": true, "font_size": 31, "lines_coords": [[[156.0, 1018.0], [193.0, 1018.0], [193.0, 1082.0], [156.0, 1082.0]], [[128.0, 1023.0], [154.0, 1023.0], [154.0, 1164.0], [128.0, 1164.0]]], "lines": ["何も", "聞こえない。"]}, {"box": [527, 1246, 647, 1402], "vertical": true, "font_size": 23, "lines_coords": [[[625.0, 1250.0], [646.0, 1250.0], [646.0, 1385.0], [625.0, 1385.0]], [[592.0, 1250.0], [614.0, 1250.0], [614.0, 1401.0], [592.0, 1401.0]], [[557.0, 1246.0], [584.0, 1246.0], [584.0, 1378.0], [557.0, 1378.0]], [[528.0, 1248.0], [550.0, 1248.0], [550.0, 1387.0], [528.0, 1387.0]]], "lines": ["．．．そうそう", "そのボスター", "捨てといて", "くれるかな。"]}, {"box": [87, 1415, 182, 1523], "vertical": true, "font_size": 30, "lines_coords": [[[146.0, 1415.0], [182.0, 1415.0], [182.0, 1482.0], [146.0, 1482.0]], [[120.0, 1417.0], [146.0, 1417.0], [146.0, 1523.0], [120.0, 1523.0]], [[87.0, 1415.0], [115.0, 1415.0], [115.0, 1507.0], [87.0, 1507.0]]], "lines": ["それ、", "今日まで", "なんだ。"]}], "img_path": "135.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [893, 359, 929, 378], "vertical": false, "font_size": 19, "lines_coords": [[[893.0, 359.0], [929.0, 359.0], [929.0, 378.0], [893.0, 378.0]]], "lines": ["．．．"]}, {"box": [387, 48, 414, 179], "vertical": true, "font_size": 27, "lines_coords": [[[387.0, 48.0], [414.0, 48.0], [414.0, 140.0], [387.0, 140.0]]], "lines": ["ほいさー"]}, {"box": [348, 353, 429, 417], "vertical": false, "font_size": 35, "lines_coords": [[[364.0, 353.0], [429.0, 385.0], [414.0, 417.0], [348.0, 384.0]]], "lines": ["最低１９９"]}, {"box": [893, 448, 928, 459], "vertical": false, "font_size": 11, "lines_coords": [[[893.0, 448.0], [928.0, 448.0], [928.0, 459.0], [893.0, 459.0]]], "lines": ["．．．"]}, {"box": [870, 611, 956, 900], "vertical": true, "font_size": 28, "lines_coords": [[[926.0, 612.0], [954.0, 612.0], [954.0, 717.0], [926.0, 717.0]], [[901.0, 795.0], [929.0, 795.0], [929.0, 900.0], [901.0, 900.0]], [[870.0, 795.0], [898.0, 795.0], [898.0, 885.0], [870.0, 885.0]]], "lines": ["．．．今夜？", "ずいぶん", "急だね。"]}, {"box": [345, 390, 398, 428], "vertical": false, "font_size": 16, "lines_coords": [[[353.0, 390.0], [398.0, 414.0], [390.0, 428.0], [345.0, 404.0]]], "lines": ["．．．"]}, {"box": [96, 385, 224, 531], "vertical": true, "font_size": 24, "lines_coords": [[[198.0, 392.0], [220.0, 392.0], [220.0, 523.0], [198.0, 523.0]], [[165.0, 390.0], [187.0, 390.0], [187.0, 517.0], [165.0, 517.0]], [[131.0, 389.0], [157.0, 389.0], [157.0, 518.0], [131.0, 518.0]], [[100.0, 385.0], [126.0, 385.0], [123.0, 531.0], [96.0, 531.0]]], "lines": ["大丈夫だよ。", "休み時間で", "画材買いに", "来てるトコ。"]}, {"box": [245, 818, 345, 954], "vertical": true, "font_size": 29, "lines_coords": [[[309.0, 820.0], [345.0, 820.0], [345.0, 879.0], [309.0, 879.0]], [[279.0, 823.0], [307.0, 823.0], [307.0, 954.0], [279.0, 954.0]], [[245.0, 818.0], [281.0, 818.0], [281.0, 889.0], [245.0, 889.0]]], "lines": ["でも", "いいなぁー", "花火。"]}, {"box": [137, 1029, 292, 1239], "vertical": true, "font_size": 29, "lines_coords": [[[265.0, 1031.0], [292.0, 1031.0], [292.0, 1164.0], [265.0, 1164.0]], [[234.0, 1031.0], [260.0, 1031.0], [260.0, 1214.0], [234.0, 1214.0]], [[201.0, 1032.0], [228.0, 1032.0], [228.0, 1239.0], [201.0, 1239.0]], [[171.0, 1034.0], [193.0, 1034.0], [193.0, 1187.0], [171.0, 1187.0]], [[137.0, 1029.0], [164.0, 1029.0], [164.0, 1112.0], [137.0, 1112.0]]], "lines": ["ちょうど今", "夏期講習期間で", "５時あがりだから", "駅に５時半で", "どう？"]}, {"box": [868, 1306, 912, 1381], "vertical": true, "font_size": 29, "lines_coords": [[[868.0, 1309.0], [906.0, 1306.0], [912.0, 1378.0], [875.0, 1381.0]]], "lines": ["へえ。"]}, {"box": [784, 1362, 842, 1523], "vertical": true, "font_size": 29, "lines_coords": [[[815.0, 1362.0], [842.0, 1362.0], [842.0, 1468.0], [815.0, 1468.0]], [[784.0, 1368.0], [806.0, 1368.0], [806.0, 1523.0], [784.0, 1523.0]]], "lines": ["なんだか", "ワクワクだね。"]}, {"box": [109, 1343, 198, 1550], "vertical": true, "font_size": 23, "lines_coords": [[[170.0, 1343.0], [196.0, 1343.0], [196.0, 1473.0], [170.0, 1473.0]], [[140.0, 1345.0], [162.0, 1345.0], [162.0, 1550.0], [140.0, 1550.0]], [[109.0, 1345.0], [131.0, 1345.0], [131.0, 1525.0], [109.0, 1525.0]]], "lines": ["．．．仕事場の", "予備校まで迎えに", "行っちゃえば？"]}], "img_path": "136.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [909, 418, 942, 503], "vertical": true, "font_size": 32, "lines_coords": [[[909.0, 418.0], [942.0, 418.0], [942.0, 503.0], [909.0, 503.0]]], "lines": ["来る．．．"]}, {"box": [835, 507, 898, 614], "vertical": true, "fon