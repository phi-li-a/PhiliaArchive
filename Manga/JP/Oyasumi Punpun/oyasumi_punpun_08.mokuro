白", "されつき合うことに！！そこに突然幼馴じ", "みの白鳥蘭子が転校してきて．．．！？空", "前のスケールで描かれるドキウキ学園", "ハートフル食パンパルファンタジー！！"]}, {"box": [1148, 1505, 1235, 1560], "vertical": false, "font_size": 60, "lines_coords": [[[1148.0, 1500.0], [1235.0, 1500.0], [1235.0, 1565.0], [1148.0, 1565.0]]], "lines": ["小学館"]}], "img_path": "003.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [889, 171, 954, 235], "vertical": true, "font_size": 51, "lines_coords": [[[917.0, 173.0], [954.0, 173.0], [954.0, 232.0], [917.0, 232.0]], [[889.0, 171.0], [926.0, 171.0], [926.0, 235.0], [889.0, 235.0]]], "lines": ["おま", "おま"]}, {"box": [806, 237, 885, 315], "vertical": true, "font_size": 51, "lines_coords": [[[806.0, 237.0], [885.0, 237.0], [885.0, 315.0], [806.0, 315.0]]], "lines": ["ちんちん"]}, {"box": [146, 245, 204, 346], "vertical": true, "font_size": 26, "lines_coords": [[[173.0, 245.0], [204.0, 245.0], [204.0, 303.0], [173.0, 303.0]], [[146.0, 245.0], [168.0, 245.0], [168.0, 346.0], [146.0, 346.0]]], "lines": ["おま", "ちんちん"]}, {"box": [898, 528, 964, 590], "vertical": true, "font_size": 36, "lines_coords": [[[928.0, 528.0], [964.0, 528.0], [964.0, 590.0], [928.0, 590.0]], [[898.0, 529.0], [934.0, 529.0], [934.0, 589.0], [898.0, 589.0]]], "lines": ["おま", "おま"]}, {"box": [36, 289, 78, 586], "vertical": true, "font_size": 33, "lines_coords": [[[40.0, 295.0], [73.0, 295.0], [73.0, 443.0], [40.0, 443.0]]], "lines": ["第７９話"]}, {"box": [220, 703, 276, 803], "vertical": true, "font_size": 26, "lines_coords": [[[245.0, 703.0], [276.0, 703.0], [276.0, 760.0], [245.0, 760.0]], [[220.0, 703.0], [242.0, 703.0], [242.0, 803.0], [220.0, 803.0]]], "lines": ["おま", "ちんちん"]}, {"box": [787, 821, 851, 885], "vertical": true, "font_size": 36, "lines_coords": [[[815.0, 823.0], [851.0, 823.0], [851.0, 885.0], [815.0, 885.0]], [[787.0, 821.0], [823.0, 821.0], [823.0, 885.0], [787.0, 885.0]]], "lines": ["ちん", "ちん"]}, {"box": [165, 1070, 190, 1171], "vertical": true, "font_size": 22, "lines_coords": [[[165.