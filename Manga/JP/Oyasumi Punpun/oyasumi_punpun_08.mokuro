309.0], [214.0, 1309.0]], [[201.0, 1373.0], [228.0, 1373.0], [228.0, 1504.0], [201.0, 1504.0]], [[170.0, 1375.0], [198.0, 1375.0], [198.0, 1479.0], [170.0, 1479.0]], [[139.0, 1375.0], [165.0, 1375.0], [165.0, 1489.0], [139.0, 1489.0]]], "lines": ["．．．小野寺くん。", "これからは", "サチって", "呼んでよ。"]}], "img_path": "117.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [917, 50, 945, 162], "vertical": true, "font_size": 28, "lines_coords": [[[917.0, 50.0], [945.0, 50.0], [945.0, 162.0], [917.0, 162.0]]], "lines": ["今度こそ、"]}, {"box": [750, 95, 843, 253], "vertical": true, "font_size": 28, "lines_coords": [[[810.0, 95.0], [843.0, 95.0], [843.0, 181.0], [810.0, 181.0]], [[784.0, 98.0], [806.0, 98.0], [806.0, 253.0], [784.0, 253.0]], [[750.0, 98.0], [778.0, 98.0], [778.0, 185.0], [750.0, 185.0]]], "lines": ["こんな", "くそったれな", "世の中、"]}, {"box": [156, 207, 283, 340], "vertical": true, "font_size": 30, "lines_coords": [[[254.0, 210.0], [282.0, 210.0], [282.0, 315.0], [254.0, 315.0]], [[221.0, 210.0], [250.0, 210.0], [250.0, 317.0], [221.0, 317.0]], [[190.0, 209.0], [218.0, 209.0], [215.0, 340.0], [187.0, 340.0]], [[156.0, 207.0], [190.0, 207.0], [190.0, 276.0], [156.0, 276.0]]], "lines": ["あたしが", "この手で", "ぶっ潰して", "やる。"]}, {"box": [854, 985, 909, 1164], "vertical": true, "font_size": 22, "lines_coords": [[[885.0, 987.0], [907.0, 987.0], [907.0, 1164.0], [885.0, 1164.0]], [[854.0, 985.0], [876.0, 985.0], [876.0, 1123.0], [854.0, 1123.0]]], "lines": ["．．．もしもの時は", "よろしくね。"]}, {"box": [214, 1165, 242, 1282], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 1165.0], [240.0, 1165.0], [240.0, 1282.0], [214.0, 1282.0]]], "lines": ["ブンフン。"]}], "img_path": "118.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [590, 28, 749, 262], "vertical": true, "font_size": 26, "lines_coords": [[[723.0, 31.0], [745.0, 31.0], [745.0, 207.0], [723.0, 207.0]], [[689.0, 29.0], [715.0, 29.0], [715.0, 262.0], [689.0, 262.0]], [[657.0, 29.0], [684.0, 29.0], [684.0, 212.0], [657.0, 212.0]], [[621.0, 28.0], [648.0, 28.0], [651.0, 184.0], [625.0, 184.0]], [[590.0, 28.0], [617.0, 28.0], [620.0, 240.0], [593.0, 240.0]]], "lines": ["突然の高気圧に", "軽々と舞い上げられ", "浮き足立ってる", "感は否めない", "ブンフンでしたが、"]}, {"box": [340, 29, 526, 260], "vertical": true, "font_size": 25, "lines_coords": [[[498.0, 29.0], [526.0, 29.0], [526.0, 140.0], [498.0, 140.0]], [[467.0, 29.0], [493.0, 29.0], [493.0, 160.0], [467.0, 160.0]], [[434.0, 29.0], [457.0, 29.0], [459.0, 260.0], [435.0, 260.0]], [[401.0, 31.0], [428.0, 31.0], [428.0, 235.0], [401.0, 235.0]], [[371.0, 31.0], [393.0, 31.0], [393.0, 157.0], [371.0, 157.0]], [[340.0, 31.0], [362.0, 31.0], [362.0, 142.0], [340.0, 142.0]]], "lines": ["今はただ、", "夏の訪れに", "身を任せるしかない", "のかもしれないと", "思うことに", "しました。"]}, {"box": [878, 921, 915, 1032], "vertical": true, "font_size": 34, "lines_coords": [[[878.0, 923.0], [912.0, 921.0], [915.0, 1031.0], [881.0, 1032.0]]], "lines": ["にひひ。"]}, {"box": [710, 1362, 738, 1569], "vertical": true, "font_size": 27, "lines_coords": [[[710.0, 1364.0], [737.0, 1364.0], [737.0, 1568.0], [710.0, 1568.0]]], "lines": ["．．．サチさんの手は"]}, {"box": [587, 1361, 686, 1561], "vertical": true, "font_size": 28, "lines_coords": [[[651.0, 1362.0], [679.0, 1362.0], [675.0, 1520.0], [646.0, 1520.0]]], "lines": ["思ったよりも"]}, {"box": [587, 1364, 646, 1550], "vertical": true, "font_size": 27, "lines_coords": [[[618.0, 1365.0], [646.0, 1365.0], [646.0, 1468.0], [618.0, 1468.0]], [[587.0, 1364.0], [614.0, 1364.0], [614.0, 1550.0], [587.0, 1550.0]]], "lines": ["大きくて", "こつごつしてて、"]}, {"box": [495, 1364, 553, 1570], "vertical": true, "font_size": 27, "lines_coords": [[[526.0, 1364.0], [553.0, 1364.0], [553.0, 1568.0], [526.0, 1568.0]], [[495.0, 1364.0], [521.0, 1364.0], [521.0, 1570.0], [495.0, 1570.0]]], "lines": ["誰かにそっくりな", "手だったのですが"]}, {"box": [370, 1360, 464, 1568], "vertical": true, "font_size": 27, "lines_coords": [[[437.0, 1362.0], [464.0, 1362.0], [464.0, 1568.0], [437.0, 1568.0]], [[404.0, 1364.0], [431.0, 1364.0], [431.0, 1518.0], [404.0, 1518.0]], [[370.0, 1360.0], [396.0, 1360.0], [398.0, 1551.0], [371.0, 1551.0]]], "lines": ["それが誰なのかは", "思い出せない", "フンフンでした。"]}], "img_path": "119.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "120.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "121.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [25, 287, 79, 451], "vertical": true, "font_size": 50, "lines_coords": [[[25.0, 289.0], [75.0, 287.0], [78.0, 450.0], [28.0, 451.0]]], "lines": ["第８５話"]}, {"box": [928, 729, 956, 820], "vertical": true, "font_size": 28, "lines_coords": [[[928.0, 731.0], [956.0, 731.0], [956.0, 818.0], [928.0, 818.0]]], "lines": ["．．．うん。"]}, {"box": [200, 759, 234, 828], "vertical": true, "font_size": 32, "lines_coords": [[[200.0, 759.0], [234.0, 759.0], [234.0, 828.0], [200.0, 828.0]]], "lines": ["うん、"]}, {"box": [787, 999, 840, 1115], "vertical": true, "font_size": 22, "lines_coords": [[[787.0, 1000.0], [809.0, 1000.0], [809.0, 1112.0], [787.0, 1112.0]]], "lines": ["なるほど。"]}, {"box": [139, 848, 168, 917], "vertical": true, "font_size": 32, "lines_coords": [[[139.0, 848.0], [168.0, 848.0], [168.0, 917.0], [139.0, 917.0]]], "lines": ["うん。"]}, {"box": [921, 1206, 954, 1296], "vertical": true, "font_size": 33, "lines_coords": [[[921.0, 1206.0], [954.0, 1206.0], [954.0, 1296.0], [921.0, 1296.0]]], "lines": ["．．．正直、"]}, {"box": [220, 1273, 280, 1432], "vertical": true, "font_size": 26, "lines_coords": [[[251.0, 1273.0], [278.0, 1273.0], [278.0, 1379.0], [251.0, 1379.0]], [[220.0, 1273.0], [246.0, 1273.0], [246.0, 1403.0], [220.0, 1403.0]]], "lines": ["道のりは", "険しいなー"]}], "img_path": "122.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [923, 114, 951, 206], "vertical": true, "font_size": 28, "lines_coords": [[[923.0, 114.0], [951.0, 114.0], [951.0, 206.0], [923.0, 206.0]]], "lines": ["．．．けど、"]}, {"box": [370, 217, 428, 389], "vertical": true, "font_size": 25, "lines_coords": [[[401.0, 220.0], [428.0, 220.0], [428.0, 389.0], [401.0, 389.0]], [[370.0, 217.0], [400.0, 217.0], [400.0, 285.0], [370.0, 285.0]]], "lines": ["がんばってると", "思う。"]}, {"box": [729, 376, 789, 514], "vertical": true, "font_size": 28, "lines_coords": [[[756.0, 376.0], [789.0, 376.0], [789.0, 484.0], [756.0, 484.0]], [[731.0, 379.0], [753.0, 379.0], [753.0, 510.0], [731.0, 510.0]]], "lines": ["プンプン", "偉いと思う。"]}, {"box": [820, 696, 960, 887], "vertical": true, "font_size": 24, "lines_coords": [[[932.0, 698.0], [960.0, 698.0], [960.0, 771.0], [932.0, 771.0]], [[904.0, 696.0], [931.0, 696.0], [931.0, 871.0], [904.0, 871.0]], [[876.0, 700.0], [898.0, 700.0], [898.0, 887.0], [876.0, 887.0]], [[851.0, 698.0], [873.0, 698.0], [873.0, 815.0], [851.0, 815.0]], [[823.0, 696.0], [846.0, 696.0], [843.0, 825.0], [820.0, 825.0]]], "lines": ["だから", "もうちょっとだけ", "あたしのわがままに", "付き合って", "ちょーだい。"]}, {"box": [265, 382, 351, 582], "vertical": true, "font_size": 25, "lines_coords": [[[329.0, 384.0], [351.0, 384.0], [351.0, 582.0], [329.0, 582.0]], [[295.0, 382.0], [321.0, 382.0], [321.0, 582.0], [295.0, 582.0]], [[265.0, 384.0], [287.0, 384.0], [287.0, 546.0], [265.0, 546.0]]], "lines": ["数週間でこんだけ", "アイディア練って", "来たんだもん。"]}, {"box": [170, 754, 229, 895], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 754.0], [226.0, 754.0], [229.0, 884.0], [203.0, 884.0]], [[170.0, 754.0], [196.0, 754.0], [196.0, 895.0], [170.0, 895.0]]], "lines": ["夏中の完成", "目指してさ。"]}], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [628, 246, 660, 364], "vertical": true, "font_size": 32, "lines_coords": [[[628.0, 246.0], [660.0, 246.0], [660.0, 362.0], [628.0, 362.0]]], "lines": ["あーーん。"]}], "img_path": "124.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [928, 53, 981, 207], "vertical": true, "font_size": 25, "lines_coords": [[[959.0, 53.0], [981.0, 53.0], [981.0, 181.0], [959.0, 181.0]], [[928.0, 54.0], [950.0, 54.0], [950.0, 207.0], [928.0, 207.0]]], "lines": ["どもっス！！", "お疲れっス！！"]}, {"box": [823, 231, 920, 410], "vertical": true, "font_size": 25, "lines_coords": [[[893.0, 232.0], [920.0, 232.0], [920.0, 410.0], [893.0, 410.0]], [[859.0, 232.0], [887.0, 232.0], [887.0, 337.0], [859.0, 337.0]], [[823.0, 231.0], [850.0, 231.0], [850.0, 362.0], [823.0, 362.0]]], "lines": ["オノッティーの", "同級生の", "三村っス！！"]}, {"box": [498, 53, 523, 185], "vertical": true, "font_size": 22, "lines_coords": [[[498.0, 53.0], [520.0, 53.0], [520.0, 143.0], [498.0, 143.0]]], "lines": ["こんち"]}, {"box": [139, 410, 228, 629], "vertical": true, "font_size": 23, "lines_coords": [[[203.0, 410.0], [225.0, 410.0], [225.0, 629.0], [203.0, 629.0]], [[167.0, 410.0], [193.0, 410.0], [193.0, 606.0], [167.0, 606.0]], [[139.0, 412.0], [160.0, 412.0], [160.0, 617.0], [139.0, 617.0]]], "lines": ["「むしろ腹筋の中に", "三村がいる」って", "呼んでください！！"]}, {"box": [935, 914, 1001, 1059], "vertical": true, "font_size": 27, "lines_coords": [[[965.0, 914.0], [998.0, 914.0], [1001.0, 1023.0], [968.0, 1023.0]], [[939.0, 915.0], [967.0, 915.0], [964.0, 1059.0], [935.0, 1059.0]]], "lines": ["．．．いやぁ", "僕はですね。"]}, {"box": [782, 989, 904, 1170], "vertical": true, "font_size": 27, "lines_coords": [[[878.0, 989.0], [904.0, 989.0], [904.0, 1168.0], [878.0, 1168.0]], [[846.0, 989.0], [873.0, 989.0], [873.0, 1145.0], [846.0, 1145.0]], [[817.0, 990.0], [839.0, 990.0], [839.0, 1170.0], [817.0, 1170.0]], [[782.0, 992.0], [809.0, 992.0], [809.0, 1146.0], [782.0, 1146.0]]], "lines": ["オノッティーが", "こーんなに", "ちぃこい時から", "知ってますが"]}, {"box": [307, 956, 432, 1165], "vertical": true, "font_size": 28, "lines_coords": [[[401.0, 957.0], [432.0, 957.0], [432.0, 1115.0], [401.0, 1115.0]], [[371.0, 959.0], [398.0, 959.0], [398.0, 1165.0], [371.0, 1165.0]], [[337.0, 956.0], [364.0, 956.0], [367.0, 1114.0], [340.0, 1114.0]], [[307.0, 959.0], [334.0, 959.0], [334.0, 1087.0], [307.0, 1087.0]]], "lines": ["．．．三村くんは", "ファンタジー系と", "萌え系が中心", "なのね．．．"]}, {"box": [900, 1251, 1007, 1435], "vertical": true, "font_size": 22, "lines_coords": [[[985.0, 1251.0], [1007.0, 1251.0], [1007.0, 1389.0], [985.0, 1389.0]], [[957.0, 1251.0], [979.0, 1251.0], [979.0, 1412.0], [957.0, 1412.0]], [[929.0, 1251.0], [951.0, 1251.0], [951.0, 1435.0], [929.0, 1435.0]], [[900.0, 1251.0], [920.0, 1251.0], [920.0, 1423.0], [900.0, 1423.0]]], "lines": ["彼がこんなに", "ひとつのことに", "興味を持つなんて", "はじめててすよ。"]}, {"box": [795, 1367, 876, 1531], "vertical": true, "font_size": 22, "lines_coords": [[[846.0, 1367.0], [873.0, 1367.0], [876.0, 1531.0], [850.0, 1531.0]], [[823.0, 1370.0], [845.0, 1370.0], [845.0, 1507.0], [823.0, 1507.0]], [[795.0, 1368.0], [817.0, 1368.0], [817.0, 1485.0], [795.0, 1485.0]]], "lines": ["なにかっつーと", "一人でゲーム", "ばっかり！！"]}, {"box": [465, 1357, 546, 1522], "vertical": true, "font_size": 23, "lines_coords": [[[517.0, 1357.0], [543.0, 1357.0], [546.0, 1476.0], [520.0, 1476.0]], [[493.0, 1362.0], [515.0, 1362.0], [515.0, 1500.0], [493.0, 1500.0]], [[467.0, 1360.0], [487.0, 1360.0], [487.0, 1521.0], [467.0, 1521.0]]], "lines": ["まさか僕の", "隠れ漫画狂が", "役に立つとは！！"]}, {"box": [114, 1342, 172, 1534], "vertical": true, "font_size": 22, "lines_coords": [[[146.0, 1343.0], [168.0, 1343.0], [168.0, 1534.0], [146.0, 1534.0]], [[115.0, 1343.0], [137.0, 1343.0], [137.0, 1523.0], [115.0, 1523.0]]], "lines": ["．．．あれ、僕なんか", "間違いました？"]}], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [914, 25, 993, 186], "vertical": true, "font_size": 21, "lines_coords": [[[970.0, 26.0], [992.0, 26.0], [992.0, 165.0], [970.0, 165.0]], [[942.0, 26.0], [964.0, 26.0], [964.0, 164.0], [942.0, 164.0]], [[914.0, 25.0], [934.0, 25.0], [934.0, 185.0], [914.0, 185.0]]], "lines": ["．．．じゃあ今度", "みんなで海に", "行きましょう！！"]}, {"box": [829, 145, 885, 242], "vertical": true, "font_size": 28, "lines_coords": [[[857.0, 145.0], [885.0, 145.0], [885.0, 242.0], [857.0, 242.0]], [[829.0, 146.0], [857.0, 146.0], [857.0, 240.0], [829.0, 240.0]]], "lines": ["「じゃあ」", "って何？"]}, {"box": [656, 17, 764, 215], "vertical": true, "font_size": 24, "lines_coords": [[[737.0, 17.0], [764.0, 17.0], [764.0, 129.0], [737.0, 129.0]], [[710.0, 18.0], [732.0, 18.0], [732.0, 171.0], [710.0, 171.0]], [[681.0, 17.0], [707.0, 17.0], [707.0, 215.0], [681.0, 215.0]], [[656.0, 18.0], [676.0, 18.0], [676.0, 193.0], [656.0, 193.0]]], "lines": ["夏ですよ！？", "ガンガン水着を", "股間にくい込ませて", "いきましょうよ！！"]}, {"box": [529, 26, 590, 158], "vertical": true, "font_size": 28, "lines_coords": [[[562.0, 26.0], [590.0, 26.0], [590.0, 134.0], [562.0, 134.0]], [[529.0, 29.0], [557.0, 29.0], [557.0, 128.0], [529.0, 128.0]]], "lines": ["ん～～～", "いいよー"]}, {"box": [114, 78, 175, 246], "vertical": true, "font_size": 26, "lines_coords": [[[142.0, 78.0], [175.0, 78.0], [175.0, 207.0], [142.0, 207.0]], [[114.0, 78.0], [140.0, 78.0], [140.0, 246.0], [114.0, 246.0]]], "lines": ["．．．あ、注文", "いいですかァ？"]}, {"box": [132, 296, 250, 479], "vertical": true, "font_size": 26, "lines_coords": [[[228.0, 300.0], [250.0, 300.0], [250.0, 464.0], [228.0, 464.0]], [[193.0, 298.0], [220.0, 298.0], [220.0, 479.0], [193.0, 479.0]], [[160.0, 296.0], [189.0, 296.0], [189.0, 426.0], [160.0, 426.0]], [[132.0, 298.0], [154.0, 298.0], [154.0, 435.0], [132.0, 435.0]]], "lines": ["あたし、前世が", "森の妖精なんで", "ミニサラダ", "くださいな。"]}, {"box": [887, 568, 981, 751], "vertical": true, "font_size": 28, "lines_coords": [[[953.0, 570.0], [981.0, 570.0], [981.0, 651.0], [953.0, 651.0]], [[921.0, 570.0], [950.0, 570.0], [945.0, 726.0], [917.0, 726.0]], [[887.0, 568.0], [914.0, 568.0], [914.0, 751.0], [887.0, 751.0]]], "lines": ["ここは", "お姉さん達が", "払ってやろう！！"]}, {"box": [221, 712, 248, 839], "vertical": true, "font_size": 29, "lines_coords": [[[221.0, 712.0], [248.0, 712.0], [248.0, 839.0], [221.0, 839.0]]], "lines": ["マジすか！？"]}, {"box": [467, 931, 495, 1012], "vertical": true, "font_size": 28, "lines_coords": [[[467.