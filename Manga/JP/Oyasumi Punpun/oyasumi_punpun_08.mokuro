15.0, 212.0], [217.0, 360.0], [195.0, 360.0]]], "lines": ["．．．職場の先輩が", "ストーカー状態で、", "家を突き止め", "られちゃって。"]}, {"box": [707, 440, 816, 601], "vertical": true, "font_size": 23, "lines_coords": [[[793.0, 442.0], [815.0, 442.0], [815.0, 579.0], [793.0, 579.0]], [[765.0, 442.0], [787.0, 442.0], [787.0, 601.0], [765.0, 601.0]], [[737.0, 442.0], [759.0, 442.0], [759.0, 581.0], [737.0, 581.0]], [[707.0, 440.0], [734.0, 440.0], [734.0, 534.0], [707.0, 534.0]]], "lines": ["早くしないと", "他のお客さんに", "取られちゃう", "かもよ！"]}, {"box": [935, 723, 964, 804], "vertical": true, "font_size": 24, "lines_coords": [[[935.0, 723.0], [964.0, 723.0], [964.0, 804.0], [935.0, 804.0]]], "lines": ["．．．けど、"]}, {"box": [142, 428, 251, 628], "vertical": true, "font_size": 22, "lines_coords": [[[229.0, 428.0], [251.0, 428.0], [251.0, 590.0], [229.0, 590.0]], [[203.0, 429.0], [225.0, 429.0], [225.0, 628.0], [203.0, 628.0]], [[168.0, 429.0], [190.0, 429.0], [190.0, 612.0], [168.0, 612.0]], [[142.0, 429.0], [164.0, 429.0], [164.0, 545.0], [142.0, 545.0]]], "lines": ["気持ち悪いけど", "それで引っ越すのも", "なんか癪なんだよ", "なぁ〜〜．．．"]}, {"box": [267, 720, 295, 814], "vertical": true, "font_size": 26, "lines_coords": [[[267.0, 720.0], [295.0, 720.0], [295.0, 814.0], [267.0, 814.0]]], "lines": ["．．．アレ？"]}, {"box": [807, 760, 887, 923], "vertical": true, "font_size": 24, "lines_coords": [[[865.0, 764.0], [887.0, 764.0], [887.0, 903.0], [865.0, 903.0]], [[837.0, 764.0], [859.0, 764.0], [859.0, 923.0], [837.0, 923.0]], [[810.0, 760.0], [834.0, 760.0], [831.0, 878.0], [807.0, 878.0]]], "lines": ["さっきの部屋", "仕事しやすそう", "だったな．．．"]}, {"box": [964, 1011, 987, 1092], "vertical": true, "font_size": 23, "lines_coords": [[[964.0, 1043.0], [987.0, 1043.0], [987.0, 1092.0], [964.0, 1092.0]]], "lines": ["．．．あ。"]}, {"box": [703, 1032, 789, 1173], "vertical": true, "font_size": 28, "lines_coords": [[[760.0, 1037.0], [789.0, 1037.0], [789.0, 1131.0], [760.0, 1131.0]], [[735.0, 1037.0], [757.0, 1037.0], [757.0, 1173.0], [735.0, 1173.0]], [[703.0, 1032.0], [737.0, 1032.0], [737.0, 1096.0], [703.0, 1096.0]]], "lines": ["いやいや", "なんでもない", "です。"]}, {"box": [398, 841, 440, 922], "vertical": true, "font_size": 42, "lines_coords": [[[398.0, 841.0], [440.0, 841.0], [440.0, 922.0], [398.0, 922.0]]], "lines": ["うううんわっ"]}, {"box": [153, 782, 232, 903], "vertical": true, "font_size": 26, "lines_coords": [[[206.0, 782.0], [232.0, 782.0], [232.0, 903.0], [206.0, 903.0]], [[179.0, 782.0], [206.0, 782.0], [203.0, 881.0], [176.0, 881.0]], [[153.0, 785.0], [175.0, 785.0], [175.0, 900.0], [153.0, 900.0]]], "lines": ["さっちゃん", "もう仕事", "変えるの？"]}, {"box": [610, 1212, 665, 1354], "vertical": true, "font_size": 26, "lines_coords": [[[639.0, 1212.0], [665.0, 1212.0], [665.0, 1307.0], [639.0, 1307.0]], [[610.0, 1214.0], [637.0, 1214.0], [637.0, 1354.0], [610.0, 1354.0]]], "lines": ["．．．そうだ", "仕事と言えば、"]}, {"box": [492, 1317, 575, 1459], "vertical": true, "font_size": 26, "lines_coords": [[[553.0, 1323.0], [575.0, 1323.0], [575.0, 1440.0], [553.0, 1440.0]], [[525.0, 1323.0], [546.0, 1323.0], [546.0, 1459.0], [525.0, 1459.0]], [[492.0, 1317.0], [526.0, 1317.0], [526.0, 1381.0], [492.0, 1381.0]]], "lines": ["小野寺くん", "前にも言った", "けど、"]}, {"box": [112, 1357, 195, 1523], "vertical": true, "font_size": 28, "lines_coords": [[[160.0, 1357.0], [195.0, 1357.0], [195.0, 1439.0], [160.0, 1439.0]], [[137.0, 1362.0], [164.0, 1362.0], [164.0, 1523.0], [137.0, 1523.0]], [[112.0, 1362.0], [134.0, 1362.0], [134.0, 1500.0], [112.0, 1500.0]]], "lines": ["ウチで", "アルバイトする", "気ないかい？"]}], "img_path": "085.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [840, 37, 975, 255], "vertical": true, "font_size": 25, "lines_coords": [[[953.0, 39.0], [975.0, 39.0], [975.0, 201.0], [953.0, 201.0]], [[921.0, 39.0], [948.0, 39.0], [950.0, 225.0], [923.0, 225.0]], [[895.0, 39.0], [921.0, 39.0], [921.0, 248.0], [895.0, 248.0]], [[867.0, 39.0], [893.0, 39.0], [892.0, 223.0], [865.0, 223.0]], [[840.0, 37.0], [862.0, 37.0], [864.0, 253.0], [842.0, 253.0]]], "lines": ["．．．どうも最近は", "パソコンで物件の", "データベース化．．．", "っていうのかな？", "するらしいんだけど、"]}, {"box": [656, 276, 739, 421], "vertical": true, "font_size": 26, "lines_coords": [[[706.0, 276.0], [739.0, 276.0], [739.0, 376.0], [706.0, 376.0]], [[681.0, 279.0], [707.0, 279.0], [707.0, 421.0], [681.0, 421.0]], [[656.0, 281.0], [676.0, 281.0], [676.0, 420.0], [656.0, 420.0]]], "lines": ["僕、全然", "わかんないん", "だよねーー．．．"]}, {"box": [356, 284, 467, 450], "vertical": true, "font_size": 25, "lines_coords": [[[442.0, 285.0], [464.0, 285.0], [464.0, 423.0], [442.0, 423.0]], [[410.0, 284.0], [439.0, 284.0], [439.0, 384.0], [410.0, 384.0]], [[384.0, 284.0], [410.0, 284.0], [410.0, 403.0], [384.0, 403.0]], [[356.0, 285.0], [379.0, 285.0], [381.0, 450.0], [357.0, 450.0]]], "lines": ["．．．小野寺くん", "若いから", "こういうの", "わかるでしょ？"]}, {"box": [171, 145, 265, 417], "vertical": true, "font_size": 24, "lines_coords": [[[240.0, 150.0], [262.0, 150.0], [262.0, 337.0], [240.0, 337.0]], [[206.0, 148.0], [228.0, 148.0], [228.0, 250.0], [206.0, 250.0]], [[171.0, 148.0], [198.0, 148.0], [201.0, 414.0], [175.0, 414.0]]], "lines": ["すみません．．．", "僕も全然", "わからないもんで．．．"]}, {"box": [895, 701, 973, 885], "vertical": true, "font_size": 22, "lines_coords": [[[951.0, 701.0], [973.0, 701.0], [973.0, 829.0], [951.0, 829.0]], [[923.0, 703.0], [943.0, 703.0], [943.0, 885.0], [923.0, 885.0]], [[895.0, 703.0], [917.0, 703.0], [917.0, 865.0], [895.0, 865.0]]], "lines": ["またお前は", "なんてもかんでも", "無理無理って．．．"]}, {"box": [784, 815, 864, 981], "vertical": true, "font_size": 22, "lines_coords": [[[837.0, 815.0], [864.0, 815.0], [864.0, 914.0], [837.0, 914.0]], [[809.0, 815.0], [831.0, 815.0], [831.0, 934.0], [809.0, 934.0]], [[784.0, 818.0], [804.0, 818.0], [804.0, 981.0], [784.0, 981.0]]], "lines": ["あんまり", "しつこいと", "ひっぱたくよ？"]}, {"box": [367, 1103, 429, 1231], "vertical": true, "font_size": 30, "lines_coords": [[[403.0, 1103.0], [429.0, 1103.0], [429.0, 1231.0], [403.0, 1231.0]], [[367.0, 1103.0], [400.0, 1103.0], [400.0, 1195.0], [367.0, 1195.0]]], "lines": ["．．．仲いいね", "二人共。"]}, {"box": [220, 731, 331, 893], "vertical": true, "font_size": 22, "lines_coords": [[[309.0, 731.0], [331.0, 731.0], [331.0, 857.0], [309.0, 857.0]], [[278.0, 732.0], [300.0, 732.0], [300.0, 893.0], [278.0, 893.0]], [[250.0, 731.0], [271.0, 731.0], [273.0, 893.0], [251.0, 893.0]], [[220.0, 731.0], [246.0, 731.0], [250.0, 834.0], [223.0, 834.0]]], "lines": ["今時、仕事が", "向こうから来る", "なんて有難いと", "思えって。"]}, {"box": [112, 859, 220, 1004], "vertical": true, "font_size": 22, "lines_coords": [[[198.0, 862.0], [220.0, 862.0], [220.0, 1004.0], [198.0, 1004.0]], [[170.0, 862.0], [192.0, 862.0], [192.0, 1000.0], [170.0, 1000.0]], [[142.0, 862.0], [164.0, 862.0], [164.0, 1000.0], [142.0, 1000.0]], [[112.0, 859.0], [134.0, 859.0], [135.0, 987.0], [114.0, 987.0]]], "lines": ["いいじゃんか、", "こんなジジイ", "ただの金づる", "だと思えば。"]}, {"box": [723, 1364, 750, 1524], "vertical": true, "font_size": 27, "lines_coords": [[[723.0, 1364.0], [750.0, 1364.0], [750.0, 1518.0], [723.0, 1518.0]]], "lines": ["「やります！！」"]}, {"box": [81, 1381, 175, 1497], "vertical": true, "font_size": 30, "lines_coords": [[[142.0, 1381.0], [175.0, 1381.0], [175.0, 1487.0], [142.0, 1487.0]], [[112.0, 1382.0], [140.0, 1382.0], [140.0, 1489.0], [112.0, 1489.0]], [[81.0, 1385.0], [109.0, 1385.0], [109.0, 1496.0], [81.0, 1496.0]]], "lines": ["付き合っ", "ちゃえば", "いいのに。"]}], "img_path": "086.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [832, 1100, 860, 1214], "vertical": true, "font_size": 27, "lines_coords": [[[832.0, 1100.0], [859.0, 1100.0], [859.0, 1212.0], [832.0, 1212.0]]], "lines": ["ないない"]}, {"box": [723, 1410, 747, 1523], "vertical": true, "font_size": 22, "lines_coords": [[[723.0, 1410.0], [745.0, 1410.0], [745.0, 1523.0], [723.0, 1523.0]]], "lines": ["ああそう。"]}, {"box": [156, 1357, 183, 1498], "vertical": true, "font_size": 26, "lines_coords": [[[156.0, 1357.0], [182.0, 1357.0], [182.0, 1496.0], [156.0, 1496.0]]], "lines": ["．．．おいコラ。"]}], "img_path": "087.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [831, 64, 967, 225], "vertical": true, "font_size": 22, "lines_coords": [[[945.0, 65.0], [967.0, 65.0], [967.0, 203.0], [945.0, 203.0]], [[917.0, 65.0], [939.0, 65.0], [939.0, 207.0], [917.0, 207.0]], [[889.0, 65.0], [910.0, 65.0], [910.0, 225.0], [889.0, 225.0]], [[860.0, 65.0], [882.0, 65.0], [882.0, 225.0], [860.0, 225.0]], [[834.0, 64.0], [857.0, 64.0], [854.0, 184.0], [831.0, 184.0]]], "lines": ["何度言ったら", "わかるんだよ、", "ウチにバイト代", "出す余裕なんて", "ないんだよ"]}, {"box": [700, 187, 804, 348], "vertical": true, "font_size": 22, "lines_coords": [[[782.0, 189.0], [804.0, 189.0], [804.0, 326.0], [782.0, 326.0]], [[754.0, 187.0], [776.0, 187.0], [776.0, 306.0], [754.0, 306.0]], [[726.0, 187.0], [748.0, 187.0], [748.0, 348.0], [726.0, 348.0]], [[700.0, 187.0], [720.0, 187.0], [720.0, 334.0], [700.0, 334.0]]], "lines": ["お前はいつも", "そうなんだ", "人が良過ぎるん", "だよ馬鹿野郎。"]}, {"box": [504, 117, 642, 317], "vertical": true, "font_size": 24, "lines_coords": [[[615.0, 117.0], [642.0, 117.0], [642.0, 256.0], [615.0, 256.0]], [[590.0, 118.0], [612.0, 118.0], [612.0, 301.0], [590.0, 301.0]], [[559.0, 117.0], [585.0, 117.0], [585.0, 317.0], [559.0, 317.0]], [[534.0, 118.0], [556.0, 118.0], [556.0, 256.0], [534.0, 256.0]], [[504.0, 117.0], [526.0, 117.0], [526.0, 232.0], [504.0, 232.0]]], "lines": ["散歩行くたび", "捨て猫拾ってきて", "家中ウンコだらけに", "なったことを", "忘れたか！？"]}, {"box": [418, 259, 496, 421], "vertical": true, "font_size": 24, "lines_coords": [[[475.0, 260.0], [496.0, 260.0], [496.0, 421.0], [475.0, 421.0]], [[443.0, 259.0], [470.0, 259.0], [470.0, 378.0], [443.0, 378.0]], [[418.0, 260.0], [440.0, 260.0], [440.0, 376.0], [418.0, 376.0]]], "lines": ["もう一度木槌で", "ぶっ叩かれ", "たいのか！？"]}, {"box": [901, 551, 959, 668], "vertical": true, "font_size": 30, "lines_coords": [[[926.0, 551.0], [959.0, 551.0], [959.0, 632.0], [926.0, 632.0]], [[901.0, 551.0], [928.0, 551.0], [928.0, 668.0], [901.0, 668.0]]], "lines": ["．．．あ、", "あれれ．．．？"]}, {"box": [140, 575, 250, 760], "vertical": true, "font_size": 22, "lines_coords": [[[226.0, 578.0], [248.0, 578.0], [248.0, 721.0], [226.0, 721.0]], [[198.0, 576.0], [220.0, 576.0], [220.0, 715.0], [198.0, 715.0]], [[170.0, 575.0], [192.0, 575.0], [192.0, 757.0], [170.0, 757.0]], [[142.0, 575.0], [164.0, 575.0], [162.0, 760.0], [140.0, 760.0]]], "lines": ["みすずちゃん、", "具合悪いから", "今日も寝てるって", "言ってなかった？"]}, {"box": [840, 828, 975, 1059], "vertical": true, "font_size": 23, "lines_coords": [[[953.0, 831.0], [975.0, 831.0], [975.0, 1012.0], [953.0, 1012.0]], [[923.0, 831.0], [945.0, 831.0], [945.0, 992.0], [923.0, 992.0]], [[895.0, 831.0], [917.0, 831.0], [917.0, 1059.0], [895.0, 1059.0]], [[867.0, 828.0], [887.0, 828.0], [887.0, 990.0], [867.0, 990.0]], [[840.0, 829.0], [862.0, 829.0], [862.0, 1014.0], [840.0, 1014.0]]], "lines": ["．．．やっと拾い癖が", "治ったと思えば", "今度はそこかしこから", "まねき猫はかり", "拾ってきやがる．．．"]}, {"box": [698, 968, 806, 1131], "vertical": true, "font_size": 23, "lines_coords": [[[782.0, 968.0], [806.0, 968.0], [804.0, 1131.0], [781.0, 1131.0]], [[756.0, 971.0], [778.0, 971.0], [778.0, 1107.0], [756.0, 1107.0]], [[726.0, 970.0], [753.0, 970.0], [753.0, 1107.0], [726.0, 1107.0]], [[698.0, 970.0], [726.0, 970.0], [726.0, 1043.0], [698.0, 1043.0]]], "lines": ["その割りに全然", "客が招かれて", "来ねェーなぁ", "オイ！！"]}, {"box": [518, 835, 623, 1018], "vertical": true, "font_size": 22, "lines_coords": [[[601.0, 837.0], [623.0, 837.0], [623.0, 996.0], [601.0, 996.0]], [[573.0, 837.0], [595.0, 837.0], [595.0, 976.0], [573.0, 976.0]], [[543.0, 835.0], [565.0, 835.0], [565.0, 1018.0], [543.0, 1018.0]], [[518.0, 837.0], [540.0, 837.0], [540.0, 976.0], [518.0, 976.0]]], "lines": ["この店は潰して", "駐車場にでも", "したほうがいいん", "だっつーの！！"]}, {"box": [429, 996, 482, 1123], "vertical": true, "font_size": 22, "lines_coords": [[[460.0, 998.0], [482.0, 998.0], [482.0, 1123.0], [460.0, 1123.0]], [[429.0, 996.0], [451.0, 996.0], [451.0, 1123.0], [429.0, 1123.0]]], "lines": ["わかったか", "この老害！！"]}, {"box": [898, 1260, 957, 1390], "vertical": true, "font_size": 24, "lines_coords": [[[932.0, 1264.0], [957.0, 1264.0], [957.0, 1343.0], [932.0, 1343.0]], [[901.0, 1260.0], [925.0, 1260.0], [921.0, 1390.0], [898.0, 1390.0]]], "lines": ["．．．．．．", "まあまあ．．．"]}, {"box": [151, 1293, 238, 1471], "vertical": true, "font_size": 26, "lines_coords": [[[209.0, 1293.0], [237.0, 1293.0], [237.0, 1396.0], [209.0, 1396.0]], [[179.0, 1293.0], [206.0, 1293.0], [206.0, 1471.0], [179.0, 1471.0]], [[151.0, 1293.0], [173.0, 1293.0], [173.0, 1431.0], [151.0, 1431.0]]], "lines": ["もう少し", "向こうで休んで", "なさいって。"]}], "img_path": "088.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [928, 82, 981, 196], "vertical": true, "font_size": 22, "lines_coords": [[[954.0, 82.0], [981.0, 82.0], [981.0, 178.0], [954.0, 178.0]], [[928.0, 84.0], [950.0, 84.0], [950.0, 196.0], [928.0, 196.0]]], "lines": ["アンタも", "アンタだ．．．"]}, {"box": [768, 131, 873, 315], "vertical": true, "font_size": 22, "lines_coords": [[[850.0, 131.0], [871.0, 131.0], [873.0, 314.0], [851.0, 314.0]], [[823.0, 132.0], [843.0, 132.0], [843.0, 271.0], [823.0, 271.0]], [[795.0, 131.0], [817.0, 131.0], [817.0, 315.0], [795.0, 315.0]], [[768.0, 131.0], [789.0, 131.0], [789.0, 292.0], [768.0, 292.0]]], "lines": ["ロクに職も探さず", "誰かが仕事を", "与えてくれるのを", "待ってるだけ．．．"]}, {"box": [298, 428, 403, 648], "vertical": true, "font_size": 22, "lines_coords": [[[381.0, 428.0], [403.0, 428.0], [403.0, 635.0], [381.0, 635.0]], [[351.0, 428.0], [375.0, 428.0], [376.0, 592.0], [353.0, 592.0]], [[326.0, 429.0], [348.0, 429.0], [348.0, 648.0], [326.0, 648.0]], [[298.0, 429.0], [320.0, 429.0], [320.0, 590.0], [298.0, 590.0]]], "lines": ["どんな理屈があれど", "目的意識持って", "汗水垂らして働くのは", "当然だろ．．．．？"]}, {"box": [126, 564, 260, 771], "vertical": true, "font_size": 22, "lines_coords": [[[239.0, 565.0], [260.0, 565.0], [260.0, 715.0], [239.0, 715.0]], [[210.0, 565.0], [231.0, 565.0], [231.0, 704.0], [210.0, 704.0]], [[182.0, 564.0], [204.0, 564.0], [204.0, 771.0], [182.0, 771.0]], [[151.0, 565.0], [178.0, 565.0], [178.0, 729.0], [151.0, 729.0]], [[126.0, 565.0], [148.0, 565.0], [148.0, 704.0], [126.0, 704.0]]], "lines": ["なのにまるで", "自分と世間は", "関係ありません的な", "死人みたいな顔", "しやがって．．．"]}, {"box": [870, 810, 923, 928], "vertical": true, "font_size": 26, "lines_coords": [[[895.0, 810.0], [923.0, 810.0], [923.0, 887.0], [895.0, 887.0]], [[870.0, 814.0], [892.0, 814.0], [892.0, 928.0], [870.0, 928.0]]], "lines": ["生意気", "なんだよ．．．"]}, {"box": [721, 864, 804, 1007], "vertical": true, "font_size": 26, "lines_coords": [[[778.0, 867.0], [804.0, 867.0], [804.0, 984.0], [778.0, 984.0]], [[751.0, 865.0], [778.0, 865.0], [778.0, 1007.0], [751.0, 1007.0]], [[721.0, 864.0], [750.0, 864.0], [750.0, 939.0], [721.0, 939.0]]], "lines": ["若い奴らは", "口ばかり達者", "て．．．"]}, {"box": [915, 1082, 993, 1268], "vertical": true, "font_size": 20, "lines_coords": [[[971.0, 1082.0], [993.0, 1082.0], [992.0, 1223.0], [970.0, 1223.0]], [[943.0, 1084.0], [965.0, 1084.0], [965.0, 1246.0], [943.0, 1246.0]], [[915.0, 1084.0], [935.0, 1084.0], [935.0, 1268.0], [915.0, 1268.0]]], "lines": ["．．．どうせ実際", "行き詰まったら", "こう言うんだろ？"]}, {"box": [253, 1120, 306, 1259], "vertical": true, "font_size": 23, "lines_coords": [[[276.0, 1120.0], [304.0, 1120.0], [306.0, 1217.0], [278.0, 1217.0]], [[253.0, 1125.0], [275.0, 1125.0], [275.0, 1259.0], [253.0, 1259.0]]], "lines": ["そうじゃ", "ねーだろ．．．"]}, {"box": [740, 1210, 870, 1376], "vertical": true, "font_size": 20, "lines_coords": [[[853.0, 1214.0], [870.0, 1214.0], [870.0, 1325.0], [853.0, 1325.0]], [[821.0, 1210.0], [843.0, 1210.0], [843.0, 1376.0], [821.0, 1376.0]], [[792.0, 1212.0], [814.0, 1212.0], [814.0, 1375.0], [792.0, 1375.0]], [[765.0, 1212.0], [787.0, 1212.0], [787.0, 1351.0], [765.0, 1351.0]], [[740.0, 1212.0], [757.0, 1212.0], [757.0, 1326.0], [740.0, 1326.0]]], "lines": ["雇用政策に", "問題があるとか、", "時代が悪いとか", "働いたら負け", "だとか．．．．．"]}, {"box": [110, 1309, 246, 1471], "vertical": true, "font_size": 23, "lines_coords": [[[225.0, 1310.0], [246.0, 1310.0], [246.0, 14