43.0], [292.0, 1243.0]]], "lines": ["うけるし。"]}, {"box": [607, 1367, 729, 1585], "vertical": true, "font_size": 25, "lines_coords": [[[701.0, 1367.0], [729.0, 1367.0], [729.0, 1473.0], [701.0, 1473.0]], [[668.0, 1368.0], [696.0, 1368.0], [696.0, 1475.0], [668.0, 1475.0]], [[640.0, 1368.0], [662.0, 1368.0], [662.0, 1548.0], [640.0, 1548.0]], [[607.0, 1368.0], [629.0, 1368.0], [629.0, 1584.0], [607.0, 1584.0]]], "lines": ["．．．こんな", "僕なんて", "さっさと殺して", "しまえば良いのに。"]}, {"box": [352, 1365, 513, 1549], "vertical": true, "font_size": 26, "lines_coords": [[[484.0, 1368.0], [512.0, 1368.0], [512.0, 1510.0], [484.0, 1510.0]], [[446.0, 1365.0], [475.0, 1365.0], [471.0, 1525.0], [443.0, 1525.0]], [[414.0, 1368.0], [440.0, 1368.0], [440.0, 1473.0], [414.0, 1473.0]], [[381.0, 1367.0], [407.0, 1367.0], [409.0, 1548.0], [382.0, 1548.0]], [[353.0, 1368.0], [375.0, 1368.0], [375.0, 1506.0], [353.0, 1506.0]]], "lines": ["なぜみんな", "そんな暢気な", "顔をして", "放っておくのだ", "この馬鹿者。"]}], "img_path": "018.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [118, 1184, 245, 1204], "vertical": false, "font_size": 20, "lines_coords": [[[118.0, 1184.0], [245.0, 1184.0], [245.0, 1204.0], [118.0, 1204.0]]], "lines": ["税連合組合"]}, {"box": [796, 1096, 855, 1314], "vertical": true, "font_size": 20, "lines_coords": [[[832.0, 1101.0], [850.0, 1101.0], [850.0, 1175.0], [832.0, 1175.0]], [[796.0, 1098.0], [818.0, 1098.0], [821.0, 1309.0], [800.0, 1309.0]]], "lines": ["．．．いや", "もう止めましょう。"]}, {"box": [473, 1387, 499, 1524], "vertical": true, "font_size": 21, "lines_coords": [[[475.0, 1387.0], [496.0, 1387.0], [496.0, 1515.0], [475.0, 1515.0]]], "lines": ["この数か月"]}, {"box": [366, 1386, 500, 1546], "vertical": true, "font_size": 28, "lines_coords": [[[404.0, 1390.0], [432.0, 1390.0], [432.0, 1504.0], [404.0, 1504.0]], [[371.0, 1390.0], [398.0, 1390.0], [398.0, 1542.0], [371.0, 1542.0]]], "lines": ["何度同じ", "ようなことを"]}, {"box": [176, 1386, 338, 1568], "vertical": true, "font_size": 29, "l