31.0, 723.0], [804.0, 723.0]], [[775.0, 542.0], [796.0, 542.0], [796.0, 656.0], [775.0, 656.0]]], "lines": ["そいつの人生", "そのものに影響", "したいの"]}, {"box": [170, 521, 296, 703], "vertical": true, "font_size": 29, "lines_coords": [[[264.0, 523.0], [296.0, 523.0], [296.0, 606.0], [264.0, 606.0]], [[234.0, 523.0], [260.0, 523.0], [260.0, 654.0], [234.0, 654.0]], [[201.0, 523.0], [228.0, 523.0], [228.0, 703.0], [201.0, 703.0]], [[170.0, 521.0], [196.0, 521.0], [196.0, 629.0], [170.0, 629.0]]], "lines": ["現実を", "忘れさせる", "ための漫画じゃ", "なくて！！"]}, {"box": [925, 1034, 988, 1164], "vertical": true, "font_size": 30, "lines_coords": [[[960.0, 1035.0], [987.0, 1035.0], [987.0, 1164.0], [960.0, 1164.0]], [[925.0, 1034.0], [957.0, 1034.0], [957.0, 1139.0], [925.0, 1139.0]]], "lines": ["プンプンは", "ねぇ．．．．．"]}, {"box": [526, 1073, 617, 1229], "vertical": true, "font_size": 27, "lines_coords": [[[584.0, 1073.0], [617.0, 1073.0], [617.0, 1157.0], [584.0, 1157.0]], [[556.0, 1073.0], [582.0, 1073.0], [582.0, 1229.0], [556.0, 1229.0]], [[526.0, 1078.0], [548.0, 1078.0], [548.0, 1217.0], [526.0, 1217.0]]], "lines": ["あんま", "賢くないのが", "いいところ。"]}, {"box": [410, 1025, 440, 1160], "vertical": true, "font_size": 25, "lines_coords": [[[410.0, 1025.0], [437.0, 1025.0], [440.0, 1160.0], [414.0, 1160.0]]], "lines": ["つまりねぇ．．．"]}, {"box": [143, 778, 253, 932], "vertical": true, "font_size": 29, "lines_coords": [[[214.0, 778.0], [253.0, 778.0], [253.0, 876.0], [214.0, 876.0]], [[179.0, 779.0], [207.0, 779.0], [207.0, 931.0], [179.0, 931.0]], [[143.0, 781.0], [170.0, 781.0], [170.0, 932.0], [143.0, 932.0]]], "lines": ["現実と", "戦うための", "漫画なの！！"]}, {"box": [318, 1059, 370, 1196], "vertical": true, "font_size": 25, "lines_coords": [[[343.0, 1059.0], [370.0, 1059.0], [370.0, 1156.0], [343.0, 1156.0]], [[318.0, 1060.0], [339.0, 1060.0], [339.0, 1196.0], [318.0, 1196.0]]], "lines": ["え～～～", "〜〜っとぉ．．．"]}, {"box": [118, 1076, 195, 1214], "vertical": true, "font_size": 23, "lines_coords": [[[171.0, 1076.0], [193.0, 1076.0], [