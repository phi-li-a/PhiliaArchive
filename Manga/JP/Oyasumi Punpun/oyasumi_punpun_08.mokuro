]}, {"box": [829, 798, 885, 967], "vertical": true, "font_size": 28, "lines_coords": [[[857.0, 798.0], [885.0, 798.0], [882.0, 956.0], [854.0, 956.0]], [[829.0, 801.0], [851.0, 801.0], [851.0, 967.0], [829.0, 967.0]]], "lines": ["母親はきっと", "今も元気だよ。"]}, {"box": [143, 817, 284, 1005], "vertical": true, "font_size": 23, "lines_coords": [[[251.0, 818.0], [281.0, 817.0], [284.0, 893.0], [254.0, 895.0]], [[226.0, 820.0], [248.0, 820.0], [248.0, 1003.0], [226.0, 1003.0]], [[200.0, 823.0], [221.0, 823.0], [221.0, 981.0], [200.0, 981.0]], [[171.0, 820.0], [192.0, 820.0], [192.0, 1004.0], [171.0, 1004.0]], [[143.0, 821.0], [165.0, 821.0], [165.0, 921.0], [143.0, 921.0]]], "lines": ["きっと", "自分の国に帰って", "のうのうと別の", "男と暮らしてるん", "だと思う"]}], "img_path": "115.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [225, 67, 314, 223], "vertical": true, "font_size": 26, "lines_coords": [[[287.0, 67.0], [314.0, 67.0], [310.0, 196.0], [284.0, 196.0]], [[254.0, 68.0], [281.0, 68.0], [281.0, 223.0], [254.0, 223.0]], [[225.0, 68.0], [246.0, 68.0], [246.0, 204.0], [225.0, 204.0]]], "lines": ["．．．今思えば", "母親は外国人", "だったから、"]}, {"box": [92, 214, 217, 400], "vertical": true, "font_size": 26, "lines_coords": [[[178.0, 215.0], [214.0, 214.0], [217.0, 276.0], [181.0, 278.0]], [[153.0, 220.0], [179.0, 220.0], [179.0, 400.0], [153.0, 400.0]], [[123.0, 220.0], [145.0, 220.0], [145.0, 400.0], [123.0, 400.0]], [[92.0, 220.0], [114.0, 220.0], [114.0, 384.0], [92.0, 384.0]]], "lines": ["多分", "日本語の勉強も", "兼ねてるつもり", "だったのかな。"]}, {"box": [682, 409, 822, 598], "vertical": true, "font_size": 22, "lines_coords": [[[800.0, 410.0], [820.0, 410.0], [820.0, 576.0], [800.0, 576.0]], [[770.0, 409.0], [792.0, 409.0], [792.0, 575.0], [770.0, 575.0]], [[740.0, 409.0], [762.0, 409.0], [762.0, 596.0], [740.0, 596.0]], [[710.0, 410.0], [732.0, 410.0], [732.0, 576.0], [710.0, 576.0]], [[682.0, 412.0], [704.0, 412.0], [704.0, 532.0], [682.0, 532.0]]], "lines": ["ケチだったけど", "漫画だけは沢山", "買ってくれるか