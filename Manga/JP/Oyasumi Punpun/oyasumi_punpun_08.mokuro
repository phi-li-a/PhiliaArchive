: true, "font_size": 22, "lines_coords": [[[304.0, 125.0], [326.0, 125.0], [326.0, 262.0], [304.0, 262.0]]], "lines": ["「．．．けど僕は"]}, {"box": [173, 121, 297, 438], "vertical": true, "font_size": 26, "lines_coords": [[[239.0, 121.0], [265.0, 121.0], [262.0, 434.0], [235.0, 434.0]], [[206.0, 123.0], [232.0, 123.0], [232.0, 353.0], [206.0, 353.0]], [[175.0, 121.0], [201.0, 121.0], [200.0, 365.0], [173.0, 365.0]]], "lines": ["やっぱり勘違い野郎なので、", "これ以上サチさんに", "優しくされたら．．．！」"]}, {"box": [515, 1320, 604, 1515], "vertical": true, "font_size": 22, "lines_coords": [[[579.0, 1325.0], [601.0, 1325.0], [601.0, 1482.0], [579.0, 1482.0]], [[548.0, 1323.0], [570.0, 1323.0], [570.0, 1471.0], [548.0, 1471.0]], [[517.0, 1321.0], [539.0, 1321.0], [539.0, 1507.0], [517.0, 1507.0]]], "lines": ["「．．．．．．僕は君を", "本気で好きに", "なってしまう。"]}], "img_path": "152.png"}, {"version": "0.2.0-beta.6", "img_width": 1092, "img_height": 1600, "blocks": [], "img_path": "153.png"}, {"version": "0.2.0-beta.6", "img_width": 1092, "img_height": 1600, "blocks": [{"box": [114, 870, 615, 1240], "vertical": false, "font_size": 284, "lines_coords": [[[170.0, 870.0], [615.0, 962.0], [559.0, 1240.0], [114.0, 1148.0]]], "lines": ["．．．"]}], "img_path": "154.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [831, 1193, 885, 1404], "vertical": true, "font_size": 22, "lines_coords": [[[864.0, 1193.0], [885.0, 1193.0], [885.0, 1320.0], [864.0, 1320.0]], [[831.0, 1195.0], [853.0, 1195.0], [853.0, 1404.0], [831.0, 1404.0]]], "lines": ["．．．言ったら", "スッキリしました。"]}, {"box": [768, 1195, 790, 1471], "vertical": true, "font_size": 22, "lines_coords": [[[768.0, 1195.0], [790.0, 1195.0], [790.0, 1471.0], [768.0, 1471.0]]], "lines": ["全部忘れてください．．．"]}, {"box": [767, 1198, 793, 1477], "vertical": true, "font_size": 26, "lines_coords": [[[767.0, 1198.0], [793.0, 1198.0], [793.0, 1477.0], [767.0, 1477.0]]], "lines": ["全部忘れてください．．．"]}, {"box": [205, 1189, 300, 1473], "vertical": true, "font_size": 26, "lines_