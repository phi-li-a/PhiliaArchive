76.0, 904.0]]], "lines": ["話、話し話しています。話してきたら、話し話します。", "次", "ぅ７９話＄６０話罪８１話義８？話阜＆３話再８４話輪８５話棒８６話第８７話第、８８７第１８８話第６９", "目．第第１第１２第一第二第四条第三第第１１第１２第１３第１６第１第３項の"]}, {"box": [940, 406, 968, 432], "vertical": false, "font_size": 26, "lines_coords": [[[940.0, 406.0], [968.0, 406.0], [968.0, 432.0], [940.0, 432.0]]], "lines": ["５９"]}, {"box": [945, 476, 967, 496], "vertical": false, "font_size": 20, "lines_coords": [[[945.0, 476.0], [967.0, 476.0], [967.0, 496.0], [945.0, 496.0]]], "lines": ["７９"]}, {"box": [937, 609, 970, 634], "vertical": false, "font_size": 25, "lines_coords": [[[937.0, 609.0], [970.0, 609.0], [970.0, 634.0], [937.0, 634.0]]], "lines": ["１１９"]}, {"box": [943, 679, 970, 701], "vertical": false, "font_size": 22, "lines_coords": [[[943.0, 679.0], [970.0, 679.0], [970.0, 701.0], [943.0, 701.0]]], "lines": ["１３７"]}, {"box": [942, 745, 968, 767], "vertical": false, "font_size": 22, "lines_coords": [[[942.0, 745.0], [968.0, 745.0], [968.0, 767.0], [942.0, 767.0]]], "lines": ["１５７"]}, {"box": [262, 918, 398, 953], "vertical": false, "font_size": 32, "lines_coords": [[[262.0, 918.0], [398.0, 921.0], [398.0, 953.0], [262.0, 950.0]]], "lines": ["登場人物"]}, {"box": [354, 970, 528, 1023], "vertical": false, "font_size": 22.0, "lines_coords": [[[354.0, 971.0], [528.0, 970.0], [528.0, 993.0], [354.0, 995.0]], [[360.0, 1003.0], [510.0, 1003.0], [510.0, 1023.0], [360.0, 1023.0]]], "lines": ["小野寺プンプン", "１８歳、フリーター・"]}, {"box": [354, 1029, 515, 1045], "vertical": false, "font_size": 16, "lines_coords": [[[354.0, 1029.0], [515.0, 1029.0], [515.0, 1045.0], [354.0, 1045.0]]], "lines": ["むかうところ敵なし。"]}, {"box": [364, 1083, 639, 1159], "vertical": false, "font_size": 20, "lines_coords": [[[367.0, 1085.0], [434.0, 1085.0], [434.0, 1103.0], [367.0, 1103.0]], [[364.0, 1112.0], [487.0, 1112.0], [487.0, 1132.0], [364.0, 1132.0]], [[364.0, 1135.0], [635.0, 1135.0], [635.0, 1156.0], [364.0, 1156.0]]], "lines": ["．．．", "２２歳、塾講師", "眼鏡がコアなので外れると死ぬ"]}, {"box": [803, 870, 975, 904], "vertical": false, "font_size": 28, "lines_coords": [[[803.0, 870.0], [975.0, 876.0], [975.0, 904.0], [803.0, 898.0]]], "lines": ["第８９話の"]}, {"box": [940, 810, 973, 835], "vertical": false, "font_size": 25, "lines_coords": [[[940.0, 810.0], [973.0, 810.0], [973.0, 835.0], [940.0, 835.0]]], "lines": ["１７９"]}, {"box": [361, 1191, 647, 1267], "vertical": false, "font_size": 20, "lines_coords": [[[365.0, 1193.0], [487.0, 1193.0], [487.0, 1215.0], [365.0, 1215.0]], [[362.0, 1223.0], [475.0, 1223.0], [475.0, 1240.0], [362.0, 1240.0]], [[362.0, 1245.0], [643.0, 1243.0], [643.0, 1265.0], [362.0, 1267.0]]], "lines": ["三村雪之進", "１８歳、大学生", "「今宵も月が赤く染まるぜ．．．！！"]}, {"box": [704, 1443, 725, 1465], "vertical": false, "font_size": 22, "lines_coords": [[[704.0, 1443.0], [725.0, 1443.0], [725.0, 1465.0], [704.0, 1465.0]]], "lines": ["☆"]}], "img_path": "025.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [23, 273, 76, 443], "vertical": true, "font_size": 50, "lines_coords": [[[23.0, 273.0], [73.0, 273.0], [76.0, 443.0], [26.0, 443.0]]], "lines": ["第８０話"]}], "img_path": "026.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "027.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [831, 43, 856, 179], "vertical": true, "font_size": 22, "lines_coords": [[[832.0, 46.0], [854.0, 46.0], [854.0, 173.0], [832.0, 173.0]]], "lines": ["今日もまた"]}, {"box": [670, 42, 761, 221], "vertical": true, "font_size": 27, "lines_coords": [[[734.0, 42.0], [760.0, 42.0], [757.0, 170.0], [731.0, 170.0]], [[703.0, 43.0], [729.0, 43.0], [729.0, 218.0], [703.0, 218.0]], [[670.0, 42.0], [698.0, 42.0], [698.0, 146.0], [670.0, 146.0]]], "lines": ["飽きもせず", "雨はずるずると", "降り続け"]}, {"box": [448, 42, 602, 220], "vertical": true, "font_size": 25, "lines_coords": [[[576.0, 45.0], [598.0, 45.0], [598.0, 218.0], [576.0, 218.0]], [[542.0, 43.0], [568.0, 43.0], [568.0, 170.0], [542.0, 170.0]], [[510.0, 42.0], [537.0, 42.0], [537.0, 196.0], [510.0, 196.0]], [[478.0, 43.0], [504.0, 43.0], [504.0, 196.0], [478.0, 196.0]], [[448.0, 45.0], [470.0, 45.0], [470.0, 201.0], [448.0, 201.0]]], "lines": ["まるで霧の中に", "いるような", "不快な湿度は", "しつこく体に", "まとわりつき、"]}, {"box": [250, 40, 382, 285], "vertical": true, "font_size": 26, "lines_coords": [[[351.0, 42.0], [378.0, 42.0], [378.0, 285.0], [351.0, 285.0]], [[314.0, 43.0], [340.0, 43.0], [340.0, 270.0], [314.0, 270.0]], [[282.0, 43.0], [309.0, 43.0], [309.0, 198.0], [282.0, 198.0]], [[250.0, 40.0], [275.0, 40.0], [278.0, 159.0], [253.0, 159.0]]], "lines": ["ブンプンのため息は", "街の苛立ちと諦めに", "飲み込まれて", "ゆきます。"]}, {"box": [903, 1155, 929, 1367], "vertical": true, "font_size": 26, "lines_coords": [[[903.0, 1155.0], [929.0, 1155.0], [929.0, 1367.0], [903.0, 1367.0]]], "lines": ["．．．ブンブンはもう、"]}, {"box": [900, 1153, 926, 1362], "vertical": true, "font_size": 28, "lines_coords": [[[900.0, 1153.0], [926.0, 1153.0], [926.0, 1362.0], [900.0, 1362.0]]], "lines": ["．．．フンフンはもう、"]}, {"box": [768, 1153, 862, 1356], "vertical": true, "font_size": 28, "lines_coords": [[[834.0, 1153.0], [860.0, 1153.0], [862.0, 1356.0], [835.0, 1356.0]], [[803.0, 1154.0], [829.0, 1154.0], [829.0, 1356.0], [803.0, 1356.0]], [[768.0, 1153.0], [801.0, 1153.0], [801.0, 1243.0], [768.0, 1243.0]]], "lines": ["何も考えることが", "出来なくなりそう", "でした。"]}, {"box": [271, 1154, 360, 1387], "vertical": true, "font_size": 25, "lines_coords": [[[339.0, 1156.0], [360.0, 1156.0], [360.0, 1332.0], [339.0, 1332.0]], [[304.0, 1154.0], [331.0, 1154.0], [331.0, 1309.0], [304.0, 1309.0]], [[271.0, 1154.0], [296.0, 1154.0], [300.0, 1387.0], [275.0, 1387.0]]], "lines": ["こうも毎日毎日", "亡霊のように", "街を彷徨っていると"]}, {"box": [117, 1154, 239, 1373], "vertical": true, "font_size": 25, "lines_coords": [[[207.0, 1156.0], [239.0, 1156.0], [235.0, 1373.0], [204.0, 1373.0]], [[179.0, 1156.0], [201.0, 1156.0], [201.0, 1357.0], [179.0, 1357.0]], [[146.0, 1154.0], [173.0, 1154.0], [173.0, 1359.0], [146.0, 1359.0]], [[117.0, 1156.0], [139.0, 1156.0], [139.0, 1284.0], [117.0, 1284.0]]], "lines": ["一体何をしようと", "していたのかすら", "思い出せなくなり", "そうで．．．．．"]}, {"box": [95, 1457, 139, 1517], "vertical": true, "font_size": 44, "lines_coords": [[[95.0, 1457.0], [139.0, 1457.0], [139.0, 1517.0], [95.0, 1517.0]]], "lines": ["あ。"]}], "img_path": "028.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [890, 140, 922, 325], "vertical": true, "font_size": 31, "lines_coords": [[[890.0, 142.0], [921.0, 142.0], [921.0, 325.0], [890.0, 325.0]]], "lines": ["小野寺くん！！"]}, {"box": [945, 960, 996, 1076], "vertical": true, "font_size": 23, "lines_coords": [[[970.0, 960.0], [996.0, 960.0], [996.0, 1053.0], [970.0, 1053.0]], [[945.0, 962.0], [967.0, 962.0], [967.0, 1076.0], [945.0, 1076.0]]], "lines": ["おーい", "オイオイ！！"]}, {"box": [873, 1065, 920, 1170], "vertical": true, "font_size": 23, "lines_coords": [[[898.0, 1065.0], [920.0, 1065.0], [920.0, 1150.0], [898.0, 1150.0]], [[873.0, 1067.0], [895.0, 1067.0], [895.0, 1170.0], [873.0, 1170.0]]], "lines": ["ちょいと", "ちょいと！！"]}, {"box": [175, 729, 215, 887], "vertical": true, "font_size": 37, "lines_coords": [[[178.0, 729.0], [215.0, 729.0], [212.0, 887.0], [175.0, 887.0]]], "lines": ["おーい！！"]}, {"box": [503, 1329, 557, 1445], "vertical": true, "font_size": 27, "lines_coords": [[[535.0, 1332.0], [557.0, 1332.0], [557.0, 1445.0], [535.0, 1445.0]], [[503.0, 1329.0], [531.0, 1329.0], [532.0, 1434.0], [504.0, 1434.0]]], "lines": ["無視すんな", "小野寺ッ。"]}, {"box": [450, 1450, 506, 1525], "vertical": true, "font_size": 27, "lines_coords": [[[476.0, 1450.0], [506.0, 1450.0], [506.0, 1523.0], [476.0, 1523.0]], [[450.0, 1450.0], [478.0, 1450.0], [478.0, 1525.0], [450.0, 1525.0]]], "lines": ["お前だ", "お前！！"]}, {"box": [167, 1128, 193, 1323], "vertical": true, "font_size": 21, "lines_coords": [[[168.0, 1129.0], [189.0, 1129.0], [189.0, 1315.0], [168.0, 1315.0]]], "lines": ["「．．．どーもです。"]}], "img_path": "029.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "