0], [617.0, 412.0]], [[617.0, 420.0], [759.0, 420.0], [759.0, 435.0], [617.0, 435.0]]], "lines": ["ほら変わるし", "自転車・バイブつは降りてるけ"]}, {"box": [546, 1345, 607, 1542], "vertical": true, "font_size": 26, "lines_coords": [[[578.0, 1348.0], [604.0, 1348.0], [604.0, 1462.0], [578.0, 1462.0]], [[546.0, 1346.0], [573.0, 1346.0], [573.0, 1537.0], [546.0, 1537.0]]], "lines": ["「．．．漫画は", "いいんですか？」"]}], "img_path": "109.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [923, 37, 987, 171], "vertical": true, "font_size": 32, "lines_coords": [[[945.0, 37.0], [987.0, 37.0], [987.0, 103.0], [945.0, 103.0]], [[923.0, 43.0], [945.0, 43.0], [945.0, 168.0], [923.0, 168.0]]], "lines": ["理想", "だけじゃ．．．"]}, {"box": [528, 149, 623, 457], "vertical": true, "font_size": 25, "lines_coords": [[[598.0, 151.0], [620.0, 151.0], [620.0, 368.0], [598.0, 368.0]], [[562.0, 150.0], [589.0, 150.0], [589.0, 457.0], [562.0, 457.0]], [[529.0, 150.0], [556.0, 150.0], [554.0, 393.0], [528.0, 393.0]]], "lines": ["「．．．言うだけ言って", "そこだけ矛盾してるなんて", "ずるくないですか？」"]}, {"box": [346, 56, 442, 190], "vertical": true, "font_size": 30, "lines_coords": [[[404.0, 56.0], [442.0, 56.0], [442.0, 117.0], [404.0, 117.0]], [[378.0, 60.0], [404.0, 60.0], [404.0, 190.0], [378.0, 190.0]], [[346.0, 59.0], [373.0, 59.0], [373.0, 190.0], [346.0, 190.0]]], "lines": ["君が", "原作書いて", "くれんの？"]}, {"box": [90, 64, 185, 262], "vertical": true, "font_size": 26, "lines_coords": [[[157.0, 67.0], [181.0, 67.0], [182.0, 262.0], [159.0, 262.0]], [[128.0, 68.0], [150.0, 68.0], [150.0, 260.0], [128.0, 260.0]], [[90.0, 64.0], [123.0, 64.0], [123.0, 146.0], [90.0, 146.0]]], "lines": ["漫画のことなんて", "何もわかってない", "君が？"]}, {"box": [693, 446, 782, 626], "vertical": true, "font_size": 23, "lines_coords": [[[756.0, 446.0], [782.0, 446.0], [782.0, 553.0], [756.0, 553.0]], [[725.0, 448.0], [746.0, 448.0], [746.0, 626.0], [725.0, 626.0]], [[693.0, 448.0], [715.0, 448.0], [715.0, 585.0], [693.0, 585.0]]], "lines": ["どーにも", "ならないことも"