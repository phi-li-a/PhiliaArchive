ん！！"]}, {"box": [915, 970, 1007, 1126], "vertical": true, "font_size": 26, "lines_coords": [[[975.0, 970.0], [1007.0, 970.0], [1007.0, 1126.0], [975.0, 1126.0]], [[948.0, 971.0], [970.0, 971.0], [970.0, 1098.0], [948.0, 1098.0]], [[915.0, 971.0], [939.0, 971.0], [939.0, 1048.0], [915.0, 1048.0]]], "lines": ["やだー何？", "水まわりは", "新品！？"]}, {"box": [618, 973, 653, 1042], "vertical": true, "font_size": 35, "lines_coords": [[[618.0, 973.0], [653.0, 973.0], [653.0, 1042.0], [618.0, 1042.0]]], "lines": ["おっ、"]}, {"box": [490, 1084, 576, 1189], "vertical": true, "font_size": 27, "lines_coords": [[[548.0, 1087.0], [575.0, 1087.0], [575.0, 1117.0], [548.0, 1117.0]]], "lines": ["と"]}, {"box": [170, 792, 197, 900], "vertical": true, "font_size": 26, "lines_coords": [[[170.0, 792.0], [196.0, 792.0], [196.0, 900.0], [170.0, 900.0]]], "lines": ["．．．むむ！？"]}, {"box": [693, 1381, 803, 1523], "vertical": true, "font_size": 25, "lines_coords": [[[773.0, 1381.0], [800.0, 1381.0], [803.0, 1498.0], [776.0, 1498.0]], [[748.0, 1382.0], [775.0, 1382.0], [775.0, 1523.0], [748.0, 1523.0]], [[721.0, 1384.0], [743.0, 1384.0], [743.0, 1521.0], [721.0, 1521.0]], [[693.0, 1382.0], [717.0, 1382.0], [717.0, 1454.0], [693.0, 1454.0]]], "lines": ["ウチの風呂", "バランス釜で", "最悪なんだよ", "ねー"]}, {"box": [392, 1384, 429, 1525], "vertical": true, "font_size": 37, "lines_coords": [[[392.0, 1384.0], [429.0, 1384.0], [429.0, 1525.0], [392.0, 1525.0]]], "lines": ["いてっ！！"]}], "img_path": "083.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [371, 909, 462, 1073], "vertical": true, "font_size": 27, "lines_coords": [[[429.0, 912.0], [462.0, 912.0], [462.0, 1020.0], [429.0, 1020.0]], [[398.0, 909.0], [431.0, 909.0], [431.0, 992.0], [398.0, 992.0]], [[371.0, 910.0], [393.0, 910.0], [393.0, 1073.0], [371.0, 1073.0]]], "lines": ["いや～～～", "なんか", "すんませんね。"]}, {"box": [223, 951, 334, 1117], "vertical": true, "font_size": 27, "lines_coords": [[[307.0, 951.0], [334.0, 951.0], [334.0, 1046.0],