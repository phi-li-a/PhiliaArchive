1, 1132], "vertical": true, "font_size": 26, "lines_coords": [[[253.0, 1026.0], [281.0, 1026.0], [281.0, 1106.0], [253.0, 1106.0]], [[221.0, 1026.0], [248.0, 1026.0], [248.0, 1132.0], [221.0, 1132.0]], [[193.0, 1028.0], [215.0, 1028.0], [215.0, 1128.0], [193.0, 1128.0]]], "lines": ["社長に", "怒られる", "けど．．．"]}, {"box": [896, 1334, 923, 1450], "vertical": true, "font_size": 27, "lines_coords": [[[896.0, 1334.0], [923.0, 1334.0], [923.0, 1450.0], [896.0, 1450.0]]], "lines": ["．．．おうい。"]}, {"box": [292, 1323, 354, 1460], "vertical": true, "font_size": 30, "lines_coords": [[[321.0, 1323.0], [354.0, 1323.0], [354.0, 1407.0], [321.0, 1407.0]], [[292.0, 1325.0], [320.0, 1325.0], [320.0, 1460.0], [292.0, 1460.0]]], "lines": ["．．．．．．", "プンプンも、"]}, {"box": [179, 1403, 240, 1518], "vertical": true, "font_size": 30, "lines_coords": [[[206.0, 1403.0], [240.0, 1403.0], [240.0, 1485.0], [206.0, 1485.0]], [[179.0, 1404.0], [206.0, 1404.0], [206.0, 1518.0], [179.0, 1518.0]]], "lines": ["なんか", "喋ってよ。"]}], "img_path": "160.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [778, 1134, 901, 1340], "vertical": true, "font_size": 24, "lines_coords": [[[876.0, 1137.0], [898.0, 1137.0], [898.0, 1300.0], [876.0, 1300.0]], [[842.0, 1135.0], [867.0, 1135.0], [864.0, 1335.0], [839.0, 1335.0]], [[810.0, 1134.0], [837.0, 1134.0], [837.0, 1264.0], [810.0, 1264.0]], [[779.0, 1135.0], [801.0, 1135.0], [801.0, 1335.0], [779.0, 1335.0]]], "lines": ["「．．．最近ずっと", "サチさんが誰かに", "似てるって", "考えてたんです。」"]}, {"box": [156, 1172, 183, 1264], "vertical": true, "font_size": 26, "lines_coords": [[[156.0, 1175.0], [182.0, 1175.0], [182.0, 1262.0], [156.0, 1262.0]]], "lines": ["．．．うん。"]}], "img_path": "161.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [898, 165, 958, 332], "vertical": true, "font_size": 24, "lines_coords": [[[932.0, 168.0], [954.0, 168.0], [954.0, 328.0], [932.0, 328.0]], [[898.0, 165.0], [925.0, 165.0], [925.0, 326.0], [898.0, 326.0]]], "lines": ["死んだ母親に", "似てるんです。"]}, {"box": [803, 164, 864, 393], "vertical": true, "font_size": 26, "lines_coords": [[[835.0, 164.0], [862.0, 164.0], [862.0, 392.0], [835.0, 392.0]], [[803.0, 165.0], [829.0, 165.0], [829.0, 293.0], [803.0, 293.0]]], "lines": ["サチさんの性格とか", "雰囲気は。」"]}, {"box": [442, 163, 504, 355], "vertical": true, "font_size": 27, "lines_coords": [[[476.0, 167.0], [503.0, 167.0], [503.0, 281.0], [476.0, 281.0]], [[443.0, 164.0], [470.0, 164.0], [468.0, 346.0], [442.0, 346.0]]], "lines": ["「僕は今も", "母親を嫌いだし"]}, {"box": [346, 163, 407, 393], "vertical": true, "font_size": 27, "lines_coords": [[[379.0, 165.0], [406.0, 165.0], [406.0, 392.0], [379.0, 392.0]], [[348.0, 164.0], [375.0, 164.0], [373.0, 370.0], [346.0, 370.0]]], "lines": ["今後も認めることは", "ないと思うけど、」"]}, {"box": [584, 665, 678, 829], "vertical": true, "font_size": 30, "lines_coords": [[[650.0, 667.0], [678.0, 667.0], [678.0, 784.0], [650.0, 784.0]], [[615.0, 667.0], [650.0, 667.0], [650.0, 748.0], [615.0, 748.0]], [[584.0, 667.0], [610.0, 667.0], [614.0, 828.0], [587.0, 828.0]]], "lines": ["「：なんか", "上手く", "言えないけど、"]}, {"box": [398, 667, 493, 823], "vertical": true, "font_size": 27, "lines_coords": [[[465.0, 667.0], [492.0, 667.0], [492.0, 823.0], [465.0, 823.0]], [[432.0, 668.0], [459.0, 668.0], [459.0, 821.0], [432.0, 821.0]], [[401.0, 668.0], [428.0, 668.0], [425.0, 796.0], [398.0, 796.0]]], "lines": ["結局そういう", "ことなんだな", "って思う。」"]}, {"box": [839, 1279, 870, 1370], "vertical": true, "font_size": 28, "lines_coords": [[[839.0, 1282.0], [867.0, 1281.0], [870.0, 1368.0], [842.0, 1370.0]]], "lines": ["．．．うん。"]}], "img_path": "162.png"}, {"version": "0.2.0-beta.6", "img_width": 1098, "img_height": 1600, "blocks": [{"box": [713, 1376, 1024, 1551], "vertical": false, "font_size": 166, "lines_coords": [[[718.0, 1376.0], [1024.0, 1385.0], [1019.0, 1551.0], [713.0, 1542.0]]], "lines": ["．．．"]}], "img_path": "163.png"}, {"version": "0.2.0-beta.6", "img_width": 1098, "img_height": 1600, "blocks": [], "img_path": "164.png"}, {"version": "0.2.0-beta.6", "img_width": 1098, "img_height": 1600, "blocks": [{"box": [716, 1378, 1005, 1545], "vertical": false, "font_size": 138, "lines_coords": [[[732.0, 1378.0], [1005.0, 1407.0], [990.0, 1545.0], [716.0, 1515.0]]], "lines": ["嘘"]}], "img_path": "165.png"}, {"version": "0.2.0-beta.6", "img_width": 1098, "img_height": 1600, "blocks": [], "img_path": "166.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [818, 710, 850, 768], "vertical": true, "font_size": 30, "lines_coords": [[[818.0, 710.0], [850.0, 710.0], [850.0, 768.0], [818.0, 768.0]]], "lines": ["あ．．．"]}, {"box": [129, 454, 160, 485], "vertical": false, "font_size": 29, "lines_coords": [[[129.0, 456.0], [160.0, 456.0], [160.0, 485.0], [129.0, 485.0]]], "lines": ["ん"]}, {"box": [787, 789, 814, 818], "vertical": true, "font_size": 30, "lines_coords": [[[787.0, 789.0], [814.0, 789.0], [814.0, 818.0], [787.0, 818.0]]], "lines": ["ん"]}, {"box": [281, 893, 317, 953], "vertical": true, "font_size": 36, "lines_coords": [[[281.0, 893.0], [317.0, 893.0], [317.0, 953.0], [281.0, 953.0]]], "lines": ["あ．．．"]}, {"box": [184, 1034, 212, 1103], "vertical": true, "font_size": 27, "lines_coords": [[[184.0, 1034.0], [212.0, 1034.0], [212.0, 1103.0], [184.0, 1103.0]]], "lines": ["もっと"]}, {"box": [134, 1110, 184, 1196], "vertical": true, "font_size": 27, "lines_coords": [[[157.0, 1110.0], [184.0, 1110.0], [184.0, 1196.0], [157.0, 1196.0]], [[134.0, 1117.0], [159.0, 1117.0], [159.0, 1157.0], [134.0, 1157.0]]], "lines": ["ゆっくり", "．．．"]}, {"box": [895, 1271, 950, 1362], "vertical": true, "font_size": 26, "lines_coords": [[[921.0, 1276.0], [950.0, 1276.0], [950.0, 1362.0], [921.0, 1362.0]], [[898.0, 1271.0], [926.0, 1273.0], [923.0, 1325.0], [895.0, 1323.0]]], "lines": ["プンプン", "も．．"]}, {"box": [826, 1357, 873, 1445], "vertical": true, "font_size": 26, "lines_coords": [[[846.0, 1357.0], [873.0, 1357.0], [873.0, 1445.0], [846.0, 1445.0]], [[826.0, 1370.0], [845.0, 1370.0], [845.0, 1403.0], [826.0, 1403.0]]], "lines": ["服脱いで", "．．．"]}], "img_path": "167.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [853, 184, 916, 339], "vertical": true, "font_size": 24, "lines_coords": [[[892.0, 187.0], [914.0, 187.0], [914.0, 334.0], [892.0, 334.0]], [[853.0, 185.0], [879.0, 185.0], [879.0, 298.0], [853.0, 298.0]]], "lines": ["．．．さようなら", "翠ちゃん。"]}, {"box": [203, 181, 261, 337], "vertical": true, "font_size": 25, "lines_coords": [[[237.0, 184.0], [259.0, 184.0], [259.0, 334.0], [237.0, 334.0]], [[203.0, 182.0], [231.0, 182.0], [231.0, 293.0], [203.0, 293.0]]], "lines": ["．．．さようなら", "蟹江さん。"]}, {"box": [523, 1375, 581, 1530], "vertical": true, "font_size": 27, "lines_coords": [[[554.0, 1375.0], [581.0, 1375.0], [578.0, 1529.0], [551.0, 1529.0]], [[523.0, 1379.0], [550.0, 1379.0], [550.0, 1515.0], [523.0, 1515.0]]], "lines": ["．．．さようなら", "愛子ちゃん。"]}], "img_path": "168.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [184, 167, 215, 256], "vertical": true, "font_size": 30, "lines_coords": [[[184.0, 167.0], [214.0, 167.0], [215.0, 256.0], [185.0, 256.0]]], "lines": ["．．．ねぇ。"]}, {"box": [917, 726, 944, 845], "vertical": true, "font_size": 26, "lines_coords": [[[917.0, 726.0], [943.0, 726.0], [943.0, 845.0], [917.0, 845.0]]], "lines": ["プンプン．．．"]}, {"box": [514, 381, 577, 513], "vertical": true, "font_size": 30, "lines_coords": [[[550.0, 381.0], [576.0, 381.0], [576.0, 512.0], [550.0, 512.0]], [[514.0, 381.0], [548.0, 381.0], [548.0, 473.0], [514.0, 473.0]]], "lines": ["．．．僕はもう", "大丈夫。"]}, {"box": [143, 1065, 168, 1179], "vertical": true, "font_size": 22, "lines_coords": [[[143.0, 1065.0], [165.0, 1065.0], [165.0, 1179.0], [143.0, 1179.0]]], "lines": ["チューは？"]}], "img_path": "169.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [889, 757, 917, 875], "vertical": true, "font_size": 26, "lines_coords": [[[889.0, 757.0], [915.0, 757.0], [915.0, 875.0], [889.0, 875.0]]], "lines": ["フンフン．．．"]}, {"box": [203, 843, 227, 982], "vertical": true, "font_size": 22, "lines_coords": [[[203.0, 843.0], [225.0, 843.0], [225.0, 982.0], [203.0, 982.0]]], "lines": ["．．．チューは？"]}, {"box": [534, 1343, 564, 1503], "vertical": true, "font_size": 26, "lines_coords": [[[534.0, 1343.0], [560.0, 1343.0], [564.0, 1500.0], [537.0, 1500.0]]], "lines": ["僕はもう．．．："]}], "img_path": "170.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [885, 190, 904, 217], "vertical": true, "font_size": 19, "lines_coords": [[[885.0, 190.0], [904.0, 190.0], [904.0, 217.0], [885.0, 217.0]]], "lines": ["ン？"]}], "img_path": "171.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [690, 1147, 717, 1319], "vertical": true, "font_size": 20, "lines_coords": [[[692.0, 1151.0], [712.0, 1151.0], [712.0, 1312.0], [692.0, 1312.0]]], "lines": ["．．．サチさん。"]}, {"box": [446, 1409, 479, 1504], "vertical": true, "font_size": 33, "lines_coords": [[[446.0, 1409.0], [479.0, 1409.0], [479.0, 1504.0], [446.0, 1504.0]]], "lines": ["．．．ほい。"]}, {"box": [173, 1192, 297, 1424], "vertical": true, "font_size": 24, "lines_coords": [[[271.0, 1195.0], [293.0, 1195.0], [293.0, 1331.0], [271.0, 1331.0]], [[237.0, 1193.0], [264.0, 1193.0], [264.0, 1321.0], [237.0, 1321.0]], [[207.0, 1193.0], [229.0, 1193.0], [229.0, 1420.0], [207.0, 1420.0]], [[173.0, 1193.0], [200.0, 1193.0], [200.0, 1396.0], [173.0, 1396.0]]], "lines": ["「これからは", "僕のことを", "やり逃げ黒チンボと", "呼んでください。」"]}], "img_path": "172.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [859, 1095, 952, 1248], "vertical": true, "font_size": 31, "lines_coords": [[[923.0, 1095.0], [950.0, 1095.0], [950.0, 1246.0], [923.0, 1246.0]], [[889.0, 1095.0], [921.0, 1095.0], [921.0, 1200.0], [889.0, 1200.0]], [[859.0, 1095.0], [892.0, 1095.0], [892.0, 1184.0], [859.0, 1184.0]]], "lines": ["前に言ってた", "女の子の", "ことが、"]}, {"box": [229, 892, 285, 1007], "vertical": true, "font_size": 25, "lines_coords": [[[257.0, 892.0], [285.0, 892.0], [285.0, 973.0], [257.0, 973.0]], [[229.0, 895.0], [251.0, 895.0], [251.0, 1006.0], [229.0, 1006.0]]], "lines": ["．．．．．．", "立ちなよ。"]}, {"box": [456, 1346, 643, 1576], "vertical": true, "font_size": 24, "lines_coords": [[[615.0, 1348.0], [642.0, 1348.0], [642.0, 1489.0], [615.0, 1489.0]], [[584.0, 1350.0], [606.0, 1350.0], [606.0, 1525.0], [584.0, 1525.0]], [[550.0, 1348.0], [576.0, 1348.0], [576.0, 1551.0], [550.0, 1551.0]], [[520.0, 1348.0], [542.0, 1348.0], [542.0, 1573.0], [520.0, 1573.0]], [[487.0, 1346.0], [514.0, 1346.0], [514.0, 1526.0], [487.0, 1526.0]], [[457.0, 1348.0], [479.0, 1348.0], [479.0, 1475.0], [457.0, 1475.0]]], "lines": ["「こんなにも", "いともあっさり", "セックスひとつで", "すべてのもんやりが", "解決してしまう", "としたら、」"]}, {"box": [140, 1168, 229, 1321], "vertical": true, "font_size": 25, "lines_coords": [[[201.0, 1168.0], [228.0, 1168.0], [225.0, 1321.0], [198.0, 1321.0]], [[168.0, 1168.0], [195.0, 1168.0], [195.0, 1296.0], [168.0, 1296.0]], [[140.0, 1168.0], [162.0, 1168.0], [162.0, 1270.0], [140.0, 1270.0]]], "lines": ["やっぱり忘れ", "られないん", "てしょ？"]}], "img_path": "173.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [606, 142, 665, 466], "vertical": true, "font_size": 26, "lines_coords": [[[639.0, 145.0], [665.0, 145.0], [664.0, 387.0], [637.0, 387.0]], [[606.0, 145.0], [632.0, 145.0], [632.0, 464.0], [606.0, 464.0]]], "lines": ["「僕の今までの人生は", "なんだったんでしょうか？」"]}, {"box": [148, 141, 241, 272], "vertical": true, "font_size": 27, "lines_coords": [[[214.0, 143.0], [240.0, 143.0], [240.0, 232.0], [214.0, 232.0]], [[179.0, 143.0], [206.0, 143.0], [206.0, 270.0], [179.0, 270.0]], [[148.0, 142.0], [175.0, 142.0], [175.0, 271.0], [148.0, 271.0]]], "lines": ["「１８年間", "生きてきて", "今日ほど、」"]}, {"box": [734, 810, 757, 922], "vertical": true, "font_size": 22, "lines_coords": [[[734.0, 812.0], [756.0, 812.0], [756.0, 918.0], [734.0, 918.0]]], "lines": ["ほんと、"]}, {"box": [150, 1071, 212, 1226], "vertical": true, "font_size": 29, "lines_coords": [[[184.0, 1073.0], [210.0, 1073.0], [210.0, 1226.0], [184.0, 1226.0]], [[150.0, 1071.0], [182.0, 1071.0], [182.0, 1156.0], [150.0, 1156.0]]], "lines": ["めんどくさい", "奴．．．．．"]}, {"box": [501, 1354, 595, 1521], "vertical": true, "font_size": 25, "lines_coords": [[[570.0, 1357.0], [592.0, 1357.0], [592.0, 1517.0], [570.0, 1517.0]], [[532.0, 1354.0], [559.0, 1354.0], [559.0, 1507.0], [532.0, 1507.0]], [[501.0, 1354.0], [528.0, 1354.0], [528.0, 1484.0], [501.0, 1484.0]]], "lines": ["「生きることに", "絶望した日は", "なかった。」"]}], "img_path": "174.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [929, 70, 964, 178], "vertical": true, "font_size": 29, "lines_coords": [[[929.0, 70.0], [964.0, 70.0], [964.0, 178.0], [929.0, 178.0]]], "lines": ["別に．．．"]}, {"box": [781, 92, 876, 267], "vertical": true, "font_size": 29, "lines_coords": [[[845.0, 92.0], [873.0, 92.0], [876.0, 248.0], [848.0, 248.0]], [[814.0, 92.0], [840.0, 92.0], [842.0, 267.0], [815.0, 267.0]], [[784.0, 93.0], [810.0, 93.0], [807.0, 228.0], [781.0, 228.0]]], "lines": ["あたしだって", "少し寂しかった", "ってだけで、"]}, {"box": [132, 114, 254, 295], "vertical": true, "font_size": 22, "lines_coords": [[[228.0, 115.0], [250.0, 115.0], [250.0, 268.0], [228.0, 268.0]], [[196.0, 115.0], [218.0, 115.0], [218.0, 295.0], [196.0, 295.0]], [[165.0, 114.0], [185.0, 114.0], [185.0, 293.0], [165.0, 293.0]], [[132.0, 115.0], [154.0, 115.0], [154.0, 273.0], [132.0, 273.0]]], "lines": ["君の顔が好み", "じゃなかったら", "こんなことには", "ならない訳で、"]}, {"box": [898, 354, 954, 514], "vertical": true, "font_size": 27, "lines_coords": [[[928.0, 360.0], [954.0, 360.0], [954.0, 509.0], [928.0, 509.0]], [[898.0, 354.0], [925.0, 354.0], [925.0, 514.0], [898.0, 514.0]]], "lines": ["一回セックス", "したくらいで、"]}, {"box": [792, 545, 915, 704], "vertical": true, "font_size": 27, "lines_coords": [[[882.0, 545.0], [915.0, 545.0]