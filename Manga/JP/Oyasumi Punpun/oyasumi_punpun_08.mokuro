, 496.0], [235.0, 496.0]], [[210.0, 321.0], [231.0, 321.0], [228.0, 510.0], [207.0, 510.0]], [[184.0, 323.0], [204.0, 323.0], [204.0, 467.0], [184.0, 467.0]]], "lines": ["．．．ちょっと", "二日酔い、酷いんて", "シャワーだけ浴びて", "きますけどー．．．"]}, {"box": [101, 475, 178, 645], "vertical": true, "font_size": 21, "lines_coords": [[[156.0, 475.0], [178.0, 475.0], [178.0, 645.0], [156.0, 645.0]], [[128.0, 475.0], [150.0, 475.0], [150.0, 612.0], [128.0, 612.0]], [[101.0, 475.0], [123.0, 475.0], [123.0, 612.0], [101.0, 612.0]]], "lines": ["その後、朝ごはん", "作るけど君も", "食べてけば？"]}, {"box": [157, 1062, 214, 1190], "vertical": true, "font_size": 24, "lines_coords": [[[187.0, 1062.0], [214.0, 1062.0], [214.0, 1190.0], [187.0, 1190.0]], [[157.0, 1065.0], [179.0, 1065.0], [179.0, 1189.0], [157.0, 1189.0]]], "lines": ["寝相悪いな", "コイツ．．．"]}], "img_path": "012.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [895, 100, 923, 181], "vertical": true, "font_size": 28, "lines_coords": [[[895.0, 101.0], [923.0, 101.0], [923.0, 181.0], [895.0, 181.0]]], "lines": ["お～～"]}, {"box": [165, 512, 198, 617], "vertical": true, "font_size": 33, "lines_coords": [[[165.0, 512.0], [198.0, 512.0], [198.0, 617.0], [165.0, 617.0]]], "lines": ["いてて．．．"]}, {"box": [532, 1056, 560, 1068], "vertical": false, "font_size": 12, "lines_coords": [[[532.0, 1056.0], [560.0, 1056.0], [560.0, 1068.0], [532.0, 1068.0]]], "lines": ["陽条"]}, {"box": [503, 1060, 862, 1303], "vertical": false, "font_size": 29.666666666666668, "lines_coords": [[[529.0, 1090.0], [676.0, 1060.0], [682.0, 1093.0], [535.0, 1123.0]], [[503.0, 1142.0], [729.0, 1092.0], [735.0, 1120.0], [509.0, 1170.0]], [[514.0, 1178.0], [750.0, 1123.0], [756.0, 1151.0], [520.0, 1206.0]], [[515.0, 1210.0], [792.0, 1153.0], [798.0, 1184.0], [521.0, 1242.0]], [[523.0, 1250.0], [856.0, 1175.0], [862.0, 1201.0], [529.0, 1276.0]], [[543.0, 1276.0], [748.0, 1235.0], [753.0, 1262.0], [548.0, 1303.0]]], "lines": ["そういう意味を思い出していたのですが、", "すっかり寝過ぎていなきましたよ", "友達．．．今度があったので、怖い", "サバの声ではあまり疲れないので", "何か改めた事をしていることでしょうね。", "ご迷惑おかけました。で"]}], "img_path": "013.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [390, 1423, 406, 1478], "vertical": true, "font_size": 16, "lines_coords": [[[390.0, 1423.0], [406.0, 1423.0], [406.0, 1478.0], [390.0, 1478.0]]], "lines": ["ごめん"]}, {"box": [403, 1392, 445, 1482], "vertical": true, "font_size": 18.5, "lines_coords": [[[409.0, 1392.0], [432.0, 1393.0], [426.0, 1482.0], [403.0, 1481.0]], [[431.0, 1403.0], [445.0, 1403.0], [445.0, 1442.0], [431.0, 1442.0]]], "lines": ["．．．そういう", "え"]}, {"box": [598, 1390, 684, 1435], "vertical": false, "font_size": 35, "lines_coords": [[[598.0, 1401.0], [679.0, 1390.0], [684.0, 1425.0], [603.0, 1435.0]]], "lines": ["南条"]}], "img_path": "014.png"}, {"version": "0.2.0-beta.6", "img_width": 1085, "img_height": 1600, "blocks": [], "img_path": "015.png"}, {"version": "0.2.0-beta.6", "img_width": 1085, "img_height": 1600, "blocks": [], "img_path": "016.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [660, 57, 720, 243], "vertical": true, "font_size": 22, "lines_coords": [[[693.0, 60.0], [715.0, 60.0], [715.0, 237.0], [693.0, 237.0]], [[660.0, 62.0], [682.0, 62.0], [682.0, 215.0], [660.0, 215.0]]], "lines": ["ブンフンはまた", "こんなふうに"]}, {"box": [415, 59, 509, 226], "vertical": true, "font_size": 26, "lines_coords": [[[481.0, 60.0], [507.0, 60.0], [507.0, 187.0], [481.0, 187.0]], [[450.0, 60.0], [476.0, 60.0], [476.0, 190.0], [450.0, 190.0]], [[415.0, 59.0], [442.0, 59.0], [445.0, 223.0], [418.0, 223.0]]], "lines": ["くだらない", "嘘をついて", "しまうのです。"]}], "img_path": "017.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [614, 0, 665, 125], "vertical": true, "font_size": 39, "lines_coords": [[[614.0, 3.0], [653.0, 0.0], [665.0, 120.0], [626.0, 125.0]]], "lines": ["食うなんの言ってるけど．．．"]}, {"box": [692, 243, 710, 340], "vertical": true, "font_size": 17, "lines_coo