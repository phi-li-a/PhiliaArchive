ords": [[[296.0, 914.0], [323.0, 914.0], [323.0, 1045.0], [296.0, 1045.0]], [[267.0, 915.0], [289.0, 915.0], [289.0, 1050.0], [267.0, 1050.0]]], "lines": ["なーんにも", "わかんない"]}], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [890, 71, 931, 234], "vertical": true, "font_size": 41, "lines_coords": [[[890.0, 71.0], [931.0, 71.0], [931.0, 160.0], [890.0, 160.0]]], "lines": ["ぶふー"]}, {"box": [660, 510, 710, 606], "vertical": true, "font_size": 24, "lines_coords": [[[684.0, 510.0], [710.0, 510.0], [710.0, 606.0], [684.0, 606.0]], [[660.0, 514.0], [682.0, 514.0], [682.0, 567.0], [660.0, 567.0]]], "lines": ["あちゅい", "．．．．．．"]}, {"box": [260, 1364, 293, 1534], "vertical": true, "font_size": 28, "lines_coords": [[[260.0, 1364.0], [289.0, 1364.0], [293.0, 1534.0], [265.0, 1534.0]]], "lines": ["えるにーにょ。"]}], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [816, 209, 908, 391], "vertical": true, "font_size": 22, "lines_coords": [[[882.0, 212.0], [904.0, 212.0], [904.0, 356.0], [882.0, 356.0]], [[848.0, 209.0], [871.0, 209.0], [873.0, 360.0], [850.0, 360.0]], [[818.0, 210.0], [840.0, 210.0], [840.0, 387.0], [818.0, 387.0]]], "lines": ["「駄目ですよ。", "あんまりお洒", "飲み過ぎちゃ。"]}, {"box": [621, 32, 682, 187], "vertical": true, "font_size": 27, "lines_coords": [[[654.0, 32.0], [682.0, 32.0], [682.0, 109.0], [654.0, 109.0]], [[621.0, 32.0], [648.0, 32.0], [651.0, 187.0], [625.0, 187.0]]], "lines": ["るせー", "この野郎ッ！！"]}, {"box": [350, 260, 441, 442], "vertical": true, "font_size": 24, "lines_coords": [[[414.0, 260.0], [440.0, 260.0], [440.0, 440.0], [414.0, 440.0]], [[384.0, 265.0], [406.0, 265.0], [406.0, 442.0], [384.0, 442.0]], [[353.0, 262.0], [376.0, 262.0], [373.0, 392.0], [350.0, 392.0]]], "lines": ["てめーは自分の", "心配だけしてろ", "っつーの！！"]}, {"box": [471, 490, 503, 644], "vertical": true, "font_size": 26, "lines_coords": [[[475.0, 490.0], [501.0, 490.0], [498.0, 637.0], [471.0, 637.0]]], "lines": ["「．．．サチさん。"]}, {"box": [278, 489, 371, 620], "vertical": true, "font_size": 27, "lines_coords": [[[342.0, 490.0], [368.0, 490.0], [368.0, 618.0], [342.0, 618.0]], [[307.0, 489.0], [335.0, 489.0], [337.0, 618.0], [309.0, 618.0]], [[278.0, 490.0], [304.0, 490.0], [304.0, 593.0], [278.0, 593.0]]], "lines": ["僕、もっと", "がんばって", "みるよ。」"]}, {"box": [171, 849, 197, 953], "vertical": true, "font_size": 23, "lines_coords": [[[171.0, 853.0], [195.0, 853.0], [195.0, 903.0], [171.0, 903.0]], [[171.0, 906.0], [193.0, 906.0], [193.0, 953.0], [171.0, 953.0]]], "lines": ["んー", "．．．"]}, {"box": [275, 1231, 301, 1318], "vertical": true, "font_size": 26, "lines_coords": [[[275.0, 1231.0], [301.0, 1231.0], [301.0, 1318.0], [275.0, 1318.0]]], "lines": ["またね、"]}, {"box": [190, 1337, 217, 1457], "vertical": true, "font_size": 26, "lines_coords": [[[190.0, 1337.0], [217.0, 1337.0], [217.0, 1457.0], [190.0, 1457.0]]], "lines": ["プンプン。"]}], "img_path": "130.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [667, 42, 728, 205], "vertical": true, "font_size": 27, "lines_coords": [[[700.0, 42.0], [728.0, 42.0], [725.0, 200.0], [696.0, 200.0]], [[667.0, 45.0], [693.0, 45.0], [693.0, 201.0], [667.0, 201.0]]], "lines": ["．．．フンフンは", "実際のところ"]}, {"box": [360, 40, 423, 148], "vertical": true, "font_size": 30, "lines_coords": [[[395.0, 42.0], [423.0, 42.0], [420.0, 146.0], [392.0, 146.0]], [[360.0, 40.0], [393.0, 40.0], [393.0, 135.0], [360.0, 135.0]]], "lines": ["拍子抜け", "でした。"]}, {"box": [414, 1015, 441, 1131], "vertical": true, "font_size": 21, "lines_coords": [[[414.0, 1017.0], [435.0, 1017.0], [435.0, 1123.0], [414.0, 1123.0]]], "lines": ["．．．なんだ"]}, {"box": [265, 1015, 355, 1195], "vertical": true, "font_size": 24, "lines_coords": [[[331.0, 1017.0], [353.0, 1017.0], [353.0, 1193.0], [331.0, 1193.0]], [[296.0, 1015.0], [323.0, 1015.0], [323.0, 1193.0], [296.0, 1193.0]], [[265.0, 1015.0], [287.0, 1015.0], [287.0, 1146.0], [265.0, 1146.0]]], "lines": ["自分もけっこう", "ちゃんとできる", "じゃないか"]}, {"box": [173, 1013, 201, 1206], "vertical": true, "font_size": 27, "lines_coords": [[[173.0, 1014.0], [200.0, 1014.0], [200.0, 1200.0], [173.0, 1200.0]]], "lines": ["そう思いました。"]}], "img_path": "131.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [789, 162, 950, 424], "vertical": true, "font_size": 29, "lines_coords": [[[915.0, 165.0], [950.0, 165.0], [950.0, 251.0], [915.0, 251.0]], [[885.0, 164.0], [914.0, 164.0], [912.0, 373.0], [884.0, 373.0]], [[854.0, 164.0], [881.0, 164.0], [879.0, 423.0], [853.0, 423.0]], [[823.0, 164.0], [850.0, 164.0], [850.0, 346.0], [823.0, 346.0]], [[789.0, 162.0], [815.0, 162.0], [817.0, 378.0], [790.0, 378.0]]], "lines": ["．．．結局、", "人に流されないと", "何も変わらない自分に", "残念な気持ちは", "払い切れませんし、"]}, {"box": [181, 154, 336, 426], "vertical": true, "font_size": 26, "lines_coords": [[[314.0, 156.0], [335.0, 156.0], [335.0, 289.0], [314.0, 289.0]], [[279.0, 156.0], [306.0, 156.0], [304.0, 389.0], [278.0, 389.0]], [[246.0, 157.0], [273.0, 157.0], [273.0, 389.0], [246.0, 389.0]], [[215.0, 157.0], [242.0, 157.0], [242.0, 364.0], [215.0, 364.0]], [[181.0, 154.0], [207.0, 154.0], [209.0, 417.0], [182.0, 417.0]]], "lines": ["．．．もちろん", "ちょっとつまずけば", "また暗くて深い穴に", "落っこちてゆくの", "だろうとも思いますが"]}, {"box": [278, 743, 306, 826], "vertical": true, "font_size": 28, "lines_coords": [[[278.0, 743.0], [306.0, 743.0], [306.0, 826.0], [278.0, 826.0]]], "lines": ["いひひ。"]}, {"box": [623, 973, 650, 1093], "vertical": true, "font_size": 21, "lines_coords": [[[625.0, 973.0], [646.0, 973.0], [646.0, 1087.0], [625.0, 1087.0]]], "lines": ["またね。"]}, {"box": [457, 971, 550, 1128], "vertical": true, "font_size": 28, "lines_coords": [[[521.0, 971.0], [550.0, 971.0], [546.0, 1128.0], [518.0, 1128.0]], [[489.0, 973.0], [518.0, 973.0], [518.0, 1128.0], [489.0, 1128.0]], [[457.0, 973.0], [484.0, 973.0], [484.0, 1106.0], [457.0, 1106.0]]], "lines": ["：今はそんな", "なんてことの", "ない一言が、"]}, {"box": [632, 1268, 665, 1314]