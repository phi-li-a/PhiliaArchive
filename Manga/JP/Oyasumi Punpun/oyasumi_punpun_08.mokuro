ines": ["もう一度", "持ち込みから", "やり直そうと", "思って。"]}], "img_path": "204.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "205.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [741, 31, 766, 193], "vertical": true, "font_size": 22, "lines_coords": [[[742.0, 31.0], [764.0, 31.0], [764.0, 185.0], [742.0, 185.0]]], "lines": ["．．．また今年も"]}, {"box": [514, 29, 604, 237], "vertical": true, "font_size": 23, "lines_coords": [[[576.0, 29.0], [603.0, 29.0], [601.0, 235.0], [575.0, 235.0]], [[545.0, 34.0], [567.0, 34.0], [567.0, 184.0], [545.0, 184.0]], [[514.0, 34.0], [535.0, 34.0], [535.0, 189.0], [514.0, 189.0]]], "lines": ["師走の街の人々は", "怠惰な一年を", "取り戻そうと"]}, {"box": [335, 31, 427, 210], "vertical": true, "font_size": 27, "lines_coords": [[[400.0, 31.0], [426.0, 31.0], [426.0, 210.0], [400.0, 210.0]], [[367.0, 31.0], [395.0, 31.0], [392.0, 160.0], [364.0, 160.0]], [[335.0, 31.0], [362.0, 31.0], [362.0, 145.0], [335.0, 145.0]]], "lines": ["急き足で喧喉を", "駆け抜けて", "ゆきます。"]}, {"box": [901, 1160, 960, 1340], "vertical": true, "font_size": 27, "lines_coords": [[[932.0, 1162.0], [959.0, 1162.0], [959.0, 1339.0], [932.0, 1339.0]], [[901.0, 1160.0], [928.0, 1160.0], [928.0, 1292.0], [901.0, 1292.0]]], "lines": ["いつかとは違い", "フンフンも"]}, {"box": [763, 1159, 851, 1443], "vertical": true, "font_size": 24, "lines_coords": [[[825.0, 1160.0], [851.0, 1160.0], [851.0, 1443.0], [825.0, 1443.0]], [[792.0, 1159.0], [818.0, 1159.0], [820.0, 1367.0], [793.0, 1367.0]], [[764.0, 1162.0], [785.0, 1162.0], [785.0, 1298.0], [764.0, 1298.0]]], "lines": ["まわりと歩調を合わせて", "街に溶け込む術を", "知りました。"]}, {"box": [281, 1162, 346, 1393], "vertical": true, "font_size": 33, "lines_coords": [[[318.0, 1167.0], [345.0, 1167.0], [345.0, 1389.0], [318.0, 1389.0]], [[281.0, 1164.0], [320.0, 1164.0], [320.0, 1253.0], [281.0, 1253.0]]], "lines": ["一人暮らしを始めて", "一年半。"]}, {"box": [157, 1157, 220, 1353], "vertical": true, "font_size": 26, "lines_coords": [[[192.0, 1159.0], [218.0, 1159.0], [215.0, 1287.0], [189.0, 1287.0]], [[159.0, 1159.0], [185.0, 1159.0], [184.0, 1345.0], [157.0, 1345.0]]], "lines": ["ブンブンは", "変わったのです。"]}], "img_path": "206.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [909, 82, 942, 200], "vertical": true, "font_size": 34, "lines_coords": [[[909.0, 82.0], [942.0, 82.0], [942.0, 200.0], [909.0, 200.0]]], "lines": ["プンプン、"]}, {"box": [820, 181, 856, 254], "vertical": true, "font_size": 34, "lines_coords": [[[820.0, 181.0], [856.0, 181.0], [856.0, 254.0], [820.0, 254.0]]], "lines": ["三村、"]}, {"box": [467, 70, 651, 120], "vertical": false, "font_size": 50, "lines_coords": [[[467.0, 70.0], [651.0, 70.0], [651.0, 120.0], [467.0, 120.0]]], "lines": ["ＶＤビテオレ"]}, {"box": [423, 235, 703, 291], "vertical": false, "font_size": 24, "lines_coords": [[[621.0, 235.0], [700.0, 235.0], [700.0, 264.0], [621.0, 264.0]], [[593.0, 265.0], [700.0, 265.0], [700.0, 287.0], [593.0, 287.0]], [[423.0, 264.0], [590.0, 268.0], [590.0, 290.0], [423.0, 285.0]]], "lines": ["わに夫", "〜２６：００", "年中無休１０：００"]}, {"box": [276, 179, 304, 285], "vertical": true, "font_size": 28, "lines_coords": [[[276.0, 179.0], [304.0, 179.0], [304.0, 285.0], [276.0, 285.0]]], "lines": ["やつけ子"]}, {"box": [173, 132, 231, 237], "vertical": true, "font_size": 28, "lines_coords": [[[203.0, 134.0], [231.0, 134.0], [231.0, 237.0], [203.0, 237.0]], [[173.0, 132.0], [201.0, 132.0], [201.0, 223.0], [173.0, 223.0]]], "lines": ["おつかれ", "ちゃま。"]}, {"box": [925, 398, 987, 584], "vertical": true, "font_size": 25, "lines_coords": [[[962.0, 470.0], [984.0, 470.0], [984.0, 554.0], [962.0, 554.0]], [[957.0, 400.0], [987.0, 400.0], [987.0, 468.0], [957.0, 468.0]], [[925.0, 398.0], [957.0, 398.0], [957.0, 584.0], [925.0, 584.0]]], "lines": ["ーッス", "オイ", "オイーッス！！"]}, {"box": [803, 575, 909, 757], "vertical": true, "font_size": 25, "lines_coords": [[[882.0, 575.0], [909.0, 575.0], [909.0, 670.0], [882.0, 670.0]], [[857.0, 576.0], [