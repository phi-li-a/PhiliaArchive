rds": [[[251.0, 1356.0], [278.0, 1356.0], [278.0, 1450.0], [251.0, 1450.0]], [[221.0, 1359.0], [243.0, 1359.0], [243.0, 1520.0], [221.0, 1520.0]]], "lines": ["「．．．．．．", "ウソですね。"]}], "img_path": "147.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [893, 64, 986, 192], "vertical": true, "font_size": 28, "lines_coords": [[[962.0, 67.0], [984.0, 67.0], [984.0, 192.0], [962.0, 192.0]], [[926.0, 67.0], [954.0, 67.0], [954.0, 170.0], [926.0, 170.0]], [[893.0, 64.0], [926.0, 64.0], [926.0, 148.0], [893.0, 148.0]]], "lines": ["てすねじゃ", "ねーーん", "だヨ！！"]}, {"box": [607, 87, 668, 220], "vertical": true, "font_size": 26, "lines_coords": [[[642.0, 90.0], [668.0, 90.0], [668.0, 195.0], [642.0, 195.0]], [[610.0, 87.0], [637.0, 87.0], [634.0, 220.0], [607.0, 220.0]]], "lines": ["なんなん", "だよオイ！！"]}, {"box": [601, 454, 710, 578], "vertical": true, "font_size": 29, "lines_coords": [[[679.0, 457.0], [707.0, 457.0], [707.0, 575.0], [679.0, 575.0]], [[639.0, 454.0], [671.0, 454.0], [671.0, 551.0], [639.0, 551.0]], [[601.0, 457.0], [629.0, 457.0], [631.0, 578.0], [603.0, 578.0]]], "lines": ["顔くらい", "出せよ", "コラァ！！"]}, {"box": [160, 400, 195, 471], "vertical": true, "font_size": 32, "lines_coords": [[[160.0, 400.0], [195.0, 400.0], [195.0, 471.0], [160.0, 471.0]]], "lines": ["はい。"]}, {"box": [118, 503, 146, 595], "vertical": true, "font_size": 32, "lines_coords": [[[118.0, 503.0], [146.0, 503.0], [146.0, 595.0], [118.0, 595.0]]], "lines": ["どーぞ。"]}, {"box": [592, 729, 713, 1115], "vertical": true, "font_size": 21, "lines_coords": [[[687.0, 732.0], [709.0, 732.0], [710.0, 995.0], [689.0, 995.0]], [[657.0, 734.0], [678.0, 734.0], [678.0, 1110.0], [657.0, 1110.0]], [[625.0, 734.0], [645.0, 734.0], [645.0, 1092.0], [625.0, 1092.0]], [[593.0, 732.0], [614.0, 732.0], [614.0, 982.0], [593.0, 982.0]]], "lines": ["い．．．いや、〈〈〉《．．．", "な、なんか、花火「あ、花火とか", "彼氏さんと行ったほうが、へへ", "いいと思いますよォ！？"]}, {"box": [329, 729, 515, 1117], "vertical": true, "font_size": 21, "lines_coor