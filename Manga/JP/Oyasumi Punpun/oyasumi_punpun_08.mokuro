ue, "font_size": 22, "lines_coords": [[[281.0, 139.0], [303.0, 139.0], [303.0, 314.0], [281.0, 314.0]], [[248.0, 139.0], [270.0, 139.0], [270.0, 364.0], [248.0, 364.0]], [[217.0, 137.0], [239.0, 137.0], [239.0, 314.0], [217.0, 314.0]], [[184.0, 139.0], [206.0, 139.0], [206.0, 265.0], [184.0, 265.0]]], "lines": ["再びこの部屋に", "舞い戻ってくるのが", "さためなのだと", "いうならば"]}, {"box": [923, 654, 950, 759], "vertical": true, "font_size": 27, "lines_coords": [[[923.0, 654.0], [950.0, 654.0], [950.0, 759.0], [923.0, 759.0]]], "lines": ["．．．あれ？"]}, {"box": [695, 404, 804, 578], "vertical": true, "font_size": 23, "lines_coords": [[[778.0, 404.0], [804.0, 404.0], [804.0, 501.0], [778.0, 501.0]], [[750.0, 404.0], [773.0, 404.0], [775.0, 578.0], [751.0, 578.0]], [[723.0, 406.0], [745.0, 406.0], [745.0, 568.0], [723.0, 568.0]], [[695.0, 404.0], [717.0, 404.0], [717.0, 503.0], [695.0, 503.0]]], "lines": ["ちょうど", "昨日、スーパーで", "まとめ買いして", "きたんだ"]}, {"box": [493, 1353, 615, 1560], "vertical": true, "font_size": 27, "lines_coords": [[[587.0, 1353.0], [615.0, 1353.0], [615.0, 1434.0], [587.0, 1434.0]], [[556.0, 1353.0], [582.0, 1353.0], [582.0, 1507.0], [556.0, 1507.0]], [[520.0, 1353.0], [553.0, 1353.0], [553.0, 1435.0], [520.0, 1435.0]], [[495.0, 1356.0], [517.0, 1356.0], [517.0, 1557.0], [495.0, 1557.0]]], "lines": ["生意気", "まんちょすに", "肉棒を", "ねし込まなきゃ！！"]}, {"box": [154, 1131, 214, 1287], "vertical": true, "font_size": 28, "lines_coords": [[[179.0, 1131.0], [214.0, 1131.0], [214.0, 1215.0], [179.0, 1215.0]], [[154.0, 1134.0], [176.0, 1134.0], [176.0, 1285.0], [154.0, 1285.0]]], "lines": ["たしか", "ここら辺に．．．"]}], "img_path": "032.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [951, 831, 1012, 981], "vertical": true, "font_size": 25, "lines_coords": [[[979.0, 831.0], [1012.0, 831.0], [1012.0, 912.0], [979.0, 912.0]], [[954.0, 832.0], [981.0, 832.0], [978.0, 981.0], [951.0, 981.0]]], "lines": ["．．．でも", "ごめんねー"]}, {"box": [840, 935, 942, 1064], "vertical": true, "f