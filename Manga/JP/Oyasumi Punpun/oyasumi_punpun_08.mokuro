 360.0], [148.0, 360.0], [148.0, 521.0], [110.0, 521.0]]], "lines": ["平和", "ボケッ！！"]}, {"box": [146, 656, 235, 810], "vertical": true, "font_size": 26, "lines_coords": [[[207.0, 656.0], [235.0, 656.0], [235.0, 762.0], [207.0, 762.0]], [[176.0, 657.0], [203.0, 657.0], [203.0, 809.0], [176.0, 809.0]], [[146.0, 659.0], [168.0, 659.0], [168.0, 809.0], [146.0, 809.0]]], "lines": ["すこーし", "言い過ぎじゃ", "ないですか？"]}, {"box": [512, 893, 602, 1050], "vertical": true, "font_size": 25, "lines_coords": [[[578.0, 896.0], [600.0, 896.0], [600.0, 1021.0], [578.0, 1021.0]], [[542.0, 893.0], [568.0, 893.0], [568.0, 1021.0], [542.0, 1021.0]], [[512.0, 893.0], [539.0, 893.0], [539.0, 1050.0], [512.0, 1050.0]]], "lines": ["言わなきや", "伝わんない", "でしょ．．．．．．！？"]}, {"box": [942, 1154, 995, 1270], "vertical": true, "font_size": 23, "lines_coords": [[[967.0, 1154.0], [995.0, 1154.0], [995.0, 1228.0], [967.0, 1228.0]], [[942.0, 1156.0], [964.0, 1156.0], [964.0, 1270.0], [942.0, 1270.0]]], "lines": ["．．．そう", "てすけど．．．"]}, {"box": [840, 1306, 945, 1493], "vertical": true, "font_size": 23, "lines_coords": [[[925.0, 1307.0], [945.0, 1307.0], [945.0, 1446.0], [925.0, 1446.0]], [[893.0, 1306.0], [920.0, 1306.0], [920.0, 1493.0], [893.0, 1493.0]], [[868.0, 1307.0], [889.0, 1307.0], [889.0, 1443.0], [868.0, 1443.0]], [[840.0, 1307.0], [860.0, 1307.0], [860.0, 1445.0], [840.0, 1445.0]]], "lines": ["あまり乱暴な", "言い方ばかりだと", "あなたの底が", "知れますよ？"]}, {"box": [539, 1156, 568, 1256], "vertical": true, "font_size": 25, "lines_coords": [[[539.0, 1156.0], [568.0, 1156.0], [568.0, 1204.0], [539.0, 1204.0]], [[540.0, 1206.0], [564.0, 1206.0], [564.0, 1256.0], [540.0, 1256.0]]], "lines": ["ふー", "ん"]}, {"box": [448, 1332, 556, 1473], "vertical": true, "font_size": 25, "lines_coords": [[[534.0, 1335.0], [556.0, 1335.0], [556.0, 1429.0], [534.0, 1429.0]], [[504.0, 1334.0], [528.0, 1334.0], [525.0, 1471.0], [501.0, 1471.0]], [[478.0, 1335.0], [500.0, 1335.0], [500.0, 1473.0], [478.0, 1473.0]], [[448.0, 1332.0], [476.0, 1332.0], [476.0,