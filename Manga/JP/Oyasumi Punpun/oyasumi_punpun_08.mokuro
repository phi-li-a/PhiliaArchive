0, 229.0]], [[864.0, 73.0], [890.0, 73.0], [890.0, 229.0], [864.0, 229.0]]], "lines": ["．．．どうも娘は", "最近ピリピリ", "しててね．．．"]}, {"box": [229, 43, 329, 228], "vertical": true, "font_size": 31, "lines_coords": [[[293.0, 43.0], [326.0, 43.0], [329.0, 178.0], [296.0, 178.0]], [[257.0, 43.0], [292.0, 43.0], [295.0, 228.0], [260.0, 228.0]], [[229.0, 46.0], [256.0, 46.0], [256.0, 175.0], [229.0, 175.0]]], "lines": ["もしかして", "あがっちゃった", "のかな．．．"]}, {"box": [121, 168, 215, 303], "vertical": true, "font_size": 31, "lines_coords": [[[181.0, 168.0], [215.0, 168.0], [215.0, 232.0], [181.0, 232.0]], [[153.0, 173.0], [179.0, 173.0], [179.0, 303.0], [153.0, 303.0]], [[121.0, 171.0], [150.0, 171.0], [150.0, 228.0], [121.0, 228.0]]], "lines": ["まだ", "未婚なのに", "．．．．．．"]}, {"box": [753, 385, 779, 471], "vertical": true, "font_size": 26, "lines_coords": [[[753.0, 385.0], [779.0, 385.0], [779.0, 470.0], [753.0, 470.0]]], "lines": ["今年は、"]}, {"box": [293, 645, 353, 750], "vertical": true, "font_size": 25, "lines_coords": [[[326.0, 645.0], [353.0, 645.0], [353.0, 750.0], [326.0, 750.0]], [[293.0, 645.0], [323.0, 645.0], [323.0, 715.0], [293.0, 715.0]]], "lines": ["長梅雨だ", "ねェー"]}, {"box": [298, 732, 315, 770], "vertical": true, "font_size": 25, "lines_coords": [[[298.0, 732.0], [315.0, 732.0], [315.0, 770.0], [298.0, 770.0]]], "lines": ["．．．"]}, {"box": [890, 1025, 996, 1175], "vertical": true, "font_size": 22, "lines_coords": [[[975.0, 1028.0], [995.0, 1028.0], [995.0, 1164.0], [975.0, 1164.0]], [[943.0, 1025.0], [970.0, 1025.0], [970.0, 1121.0], [943.0, 1121.0]], [[917.0, 1026.0], [939.0, 1026.0], [939.0, 1165.0], [917.0, 1165.0]], [[890.0, 1026.0], [910.0, 1026.0], [910.0, 1175.0], [890.0, 1175.0]]], "lines": ["．．．さっちゃん", "あの部屋", "考えておいて", "ちょうだいな。"]}, {"box": [632, 1076, 743, 1215], "vertical": true, "font_size": 26, "lines_coords": [[[720.0, 1078.0], [742.0, 1078.0], [742.0, 1215.0], [720.0, 1215.0]], [[689.0, 1076.0], [715.0, 1076.0], [715.0, 1193.0], [689.0, 1193.0]], [[660.0, 1076.0], [687.0, 1076.0], [687.0, 1215.0], [660.0, 1215.0]], [[632.0, 1076.0], [659.0, 1076.0], [659.0, 1176.0], [632.0, 1176.0]]], "lines": ["僕もなるべく", "お客さんに", "紹介しないで", "おくから"]}, {"box": [489, 1046, 568, 1208], "vertical": true, "font_size": 22, "lines_coords": [[[545.0, 1048.0], [567.0, 1048.0], [567.0, 1185.0], [545.0, 1185.0]], [[517.0, 1046.0], [539.0, 1046.0], [539.0, 1207.0], [517.0, 1207.0]], [[489.0, 1046.0], [510.0, 1046.0], [510.0, 1150.0], [489.0, 1150.0]]], "lines": ["小野寺くんも", "よかったらまた", "来てちょ。"]}, {"box": [126, 1112, 212, 1243], "vertical": true, "font_size": 30, "lines_coords": [[[173.0, 1112.0], [212.0, 1112.0], [212.0, 1170.0], [173.0, 1170.0]], [[150.0, 1117.0], [178.0, 1117.0], [178.0, 1235.0], [150.0, 1235.0]], [[126.0, 1118.0], [148.0, 1118.0], [148.0, 1243.0], [126.0, 1243.0]]], "lines": ["娘が", "いない日に", "呼ぶからさ。"]}, {"box": [490, 1335, 553, 1478], "vertical": true, "font_size": 31, "lines_coords": [[[518.0, 1335.0], [553.0, 1335.0], [553.0, 1426.0], [518.0, 1426.0]], [[490.0, 1339.0], [517.0, 1339.0], [517.0, 1476.0], [490.0, 1476.0]]], "lines": ["．．．社長、", "人が良すぎ。"]}, {"box": [145, 1418, 182, 1492], "vertical": true, "font_size": 34, "lines_coords": [[[145.0, 1420.0], [179.0, 1418.0], [182.0, 1490.0], [148.0, 1492.0]]], "lines": ["うん。"]}], "img_path": "093.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [351, 26, 407, 182], "vertical": true, "font_size": 25, "lines_coords": [[[379.0, 26.0], [407.0, 26.0], [407.0, 131.0], [379.0, 131.0]], [[351.0, 26.0], [373.0, 26.0], [373.0, 178.0], [351.0, 178.0]]], "lines": ["．．．なんか", "ごめんね．．．"]}, {"box": [107, 335, 198, 545], "vertical": true, "font_size": 25, "lines_coords": [[[171.0, 335.0], [198.0, 335.0], [198.0, 468.0], [171.0, 468.0]], [[139.0, 335.0], [165.0, 335.0], [165.0, 518.0], [139.0, 518.0]], [[107.0, 337.0], [129.0, 337.0], [129.0, 542.0], [107.0, 542.0]]], "lines": ["思いつきで", "部屋探しなんか", "誘ったはっかりに。"]}, {"box": [565, 1050, 721, 1135], "vertical": false, "font_size": 24.333333333333332, "lines_coords": [[[590.0, 1057.0], [696.0, 1050.0], [700.0, 1078.0], [592.0, 1085.0]], [[567.0, 1092.0], [695.0, 1076.0], [698.0, 1101.0], [570.0, 1117.0]], [[565.0, 1115.0], [718.0, 1098.0], [721.0, 1118.0], [568.0, 1135.0]]], "lines": ["歩行者専門", "台転車・バイクは１２のファン", "言われることに居りて通行して下さり、"]}, {"box": [635, 1363, 662, 1505], "vertical": true, "font_size": 27, "lines_coords": [[[635.0, 1368.0], [662.0, 1368.0], [662.0, 1501.0], [635.0, 1501.0]]], "lines": ["「僕こそ．．．"]}, {"box": [454, 1359, 550, 1544], "vertical": true, "font_size": 29, "lines_coords": [[[512.0, 1359.0], [550.0, 1359.0], [550.0, 1420.0], [512.0, 1420.0]], [[485.0, 1364.0], [512.0, 1364.0], [512.0, 1542.0], [485.0, 1542.0]], [[454.0, 1365.0], [476.0, 1365.0], [476.0, 1517.0], [454.0, 1517.0]]], "lines": ["何も", "言い返せなくて", "すみません。」"]}], "img_path": "094.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [175, 151, 239, 246], "vertical": true, "font_size": 34, "lines_coords": [[[204.0, 151.0], [239.0, 151.0], [239.0, 235.0], [204.0, 235.0]], [[175.0, 153.0], [207.0, 153.0], [207.0, 246.0], [175.0, 246.0]]], "lines": ["．．．もう", "いいよ。"]}, {"box": [846, 339, 939, 498], "vertical": true, "font_size": 27, "lines_coords": [[[903.0, 339.0], [939.0, 339.0], [939.0, 398.0], [903.0, 398.0]], [[878.0, 343.0], [900.0, 343.0], [900.0, 496.0], [878.0, 496.0]], [[846.0, 345.0], [868.0, 345.0], [868.0, 456.0], [846.0, 456.0]]], "lines": ["君の", "すみませんは", "安すぎる。"]}, {"box": [890, 679, 954, 796], "vertical": true, "font_size": 31, "lines_coords": [[[920.0, 679.0], [954.0, 679.0], [954.0, 762.0], [920.0, 762.0]], [[890.0, 681.0], [918.0, 681.0], [920.0, 796.0], [892.0, 796.0]]], "lines": ["勘違い", "しないで。"]}, {"box": [150, 1064, 239, 1193], "vertical": true, "font_size": 26, "lines_coords": [[[210.0, 1064.0], [239.0, 1064.0], [239.0, 1167.0], [210.0, 1167.0]], [[179.0, 1064.0], [206.0, 1064.0], [206.0, 1193.0], [179.0, 1193.0]], [[150.0, 1065.0], [171.0, 1065.0], [171.0, 1178.0], [150.0, 1178.0]]], "lines": ["君のため", "なんかじゃ", "ないから。"]}, {"box": [904, 1246, 962, 1423], "vertical": true, "font_size": 26, "lines_coords": [[[935.0, 1246.0], [962.0, 1246.0], [962.0, 1423.0], [935.0, 1423.0]], [[904.0, 1246.0], [931.0, 1246.0], [931.0, 1385.0], [904.0, 1385.0]]], "lines": ["我慢できなかっ", "たんだよね。"]}, {"box": [792, 1360, 882, 1515], "vertical": true, "font_size": 26, "lines_coords": [[[856.0, 1360.0], [882.0, 1360.0], [882.0, 1492.0], [856.0, 1492.0]], [[823.0, 1362.0], [845.0, 1362.0], [845.0, 1515.0], [823.0, 1515.0]], [[792.0, 1362.0], [818.0, 1362.0], [818.0, 1475.0], [792.0, 1475.0]]], "lines": ["昔の自分を", "批判されてる", "みたいで。"]}, {"box": [237, 1276, 340, 1432], "vertical": true, "font_size": 29, "lines_coords": [[[304.0, 1276.0], [340.0, 1276.0], [340.0, 1339.0], [304.0, 1339.0]], [[276.0, 1279.0], [303.0, 1279.0], [303.0, 1432.0], [276.0, 1432.0]], [[237.0, 1278.0], [271.0, 1276.0], [275.0, 1370.0], [240.0, 1371.0]]], "lines": ["何も", "言い返さない", "君にも、"]}, {"box": [148, 1396, 204, 1509], "vertical": true, "font_size": 29, "lines_coords": [[[178.0, 1396.0], [204.0, 1396.0], [204.0, 1501.0], [178.0, 1501.0]], [[148.0, 1396.0], [170.0, 1396.0], [170.0, 1509.0], [148.0, 1509.0]]], "lines": ["とっても", "落胆した。"]}], "img_path": "095.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [948, 43, 975, 157], "vertical": true, "font_size": 28, "lines_coords": [[[948.0, 43.0], [975.0, 43.0], [975.0, 157.0], [948.0, 157.0]]], "lines": ["．．．けどさ、"]}, {"box": [803, 110, 895, 295], "vertical": true, "font_size": 28, "lines_coords": [[[868.0, 114.0], [895.0, 114.0], [895.0, 270.0], [868.0, 270.0]], [[834.0, 110.0], [865.0, 110.0], [865.0, 270.0], [834.0, 270.0]], [[804.0, 110.0], [831.0, 110.0], [829.0, 295.0], [803.0, 295.0]]], "lines": ["なんだかんだ", "あのババアの", "言う通りなんだ。"]}, {"box": [437, 140, 535, 300], "vertical": true, "font_size": 30, "lines_coords": [[[507.0, 145.0], [534.0, 145.0], [534.0, 300.0], [507.0, 300.0]], [[478.0, 146.0], [500.0, 146.0], [500.0, 275.0], [478.0, 275.0]], [[437.0, 140.0], [478.0, 140.0], [478.0, 214.0], [437.0, 214.0]]], "lines": ["結局、世の中", "競争社会な", "訳で。"]}, {"box": [181, 35, 259, 243], "vertical": true, "font_size": 26, "lines_coords": [[[237.0, 35.0], [259.0, 35.0], [259.0, 150.0], [237.0, 150.0]], [[209.0, 35.0], [231.0, 35.0], [232.0, 243.0], [210.0, 243.0]], [[181.0, 35.0], [203.0, 35.0], [203.0, 154.0], [181.0, 154.0]]], "lines": ["君が人との", "コミュニケーションが", "苦手なのは、"]}, {"box": [123, 289, 185, 371], "vertical": true, "font_size": 26, "lines_coords": [[[153.0, 289.0], [185.0, 289.0], [185.0, 371.0], [153.0, 371.0]], [[123.0, 289.0], [153.0, 289.0], [153.0, 357.0], [123.0, 357.0]]], "lines": ["ただの", "甘え。"]}, {"box": [895, 376, 982, 542], "vertical": true, "font_size": 27, "lines_coords": [[[960.0, 378.0], [982.0, 378.0], [982.0, 529.0], [960.0, 529.0]], [[926.0, 378.0], [953.0, 378.0], [953.0, 507.0], [926.0, 507.0]], [[895.0, 376.0], [921.0, 376.0], [921.0, 542.0], [895.0, 542.0]]], "lines": ["負けたくない", "から勝負を", "しないなんて、"]}, {"box": [787, 457, 848, 551], "vertical": true, "font_size": 27, "lines_coords": [[[815.0, 457.0], [848.0, 457.0], [848.0, 543.0], [815.0, 543.0]], [[787.0, 459.0], [815.0, 459.0], [815.0, 551.0], [787.0, 551.0]]], "lines": ["情けな", "すぎる。"]}, {"box": [867, 640, 973, 850], "vertical": true, "font_size": 22, "lines_coords": [[[951.0, 642.0], [973.0, 642.0], [973.0, 804.0], [951.0, 804.0]], [[921.0, 642.0], [943.0, 642.0], [943.0, 759.0], [921.0, 759.0]], [[890.0, 640.0], [917.0, 640.0], [918.0, 850.0], [892.0, 850.0]], [[868.0, 643.0], [887.0, 643.0], [887.0, 764.0], [868.0, 764.0]]], "lines": ["それでも不遇な", "青春時代を", "言い訳にしたいって", "言うのなら、"]}, {"box": [145, 728, 239, 886], "vertical": true, "font_size": 27, "lines_coords": [[[206.0, 728.0], [239.0, 728.0], [239.0, 815.0], [206.0, 815.0]], [[179.0, 732.0], [201.0, 732.0], [201.0, 885.0], [179.0, 885.0]], [[145.0, 731.0], [171.0, 731.0], [171.0, 843.0], [145.0, 843.0]]], "lines": ["．．．もう", "それはどうぞ", "ご勝手に"]}, {"box": [885, 1121, 973, 1301], "vertical": true, "font_size": 24, "lines_coords": [[[951.0, 1125.0], [973.0, 1125.0], [973.0, 1278.0], [951.0, 1278.0]], [[918.0, 1121.0], [942.0, 1121.0], [940.0, 1301.0], [917.0, 1301.0]], [[885.0, 1121.0], [907.0, 1121.0], [907.0, 1257.0], [885.0, 1257.0]]], "lines": ["あたしは今を", "どう生きるかが", "重要だから、"]}, {"box": [768, 1298, 889, 1482], "vertical": true, "font_size": 24, "lines_coords": [[[862.0, 1298.0], [889.0, 1298.0], [889.0, 1456.0], [862.0, 1456.0]], [[832.0, 1301.0], [854.0, 1301.0], [854.0, 1454.0], [832.0, 1454.0]], [[798.0, 1300.0], [825.0, 1300.0], [825.0, 1482.0], [798.0, 1482.0]], [[768.0, 1301.0], [790.0, 1301.0], [790.0, 1415.0], [768.0, 1415.0]]], "lines": ["他人と競って", "負けることは", "死ぬことよりも", "無怖い。"]}, {"box": [225, 1143, 317, 1332], "vertical": true, "font_size": 25, "lines_coords": [[[282.0, 1145.0], [317.0, 1145.0], [317.0, 1228.0], [282.0, 1228.0]], [[251.0, 1143.0], [278.0, 1143.0], [281.0, 1273.0], [254.0, 1273.0]], [[225.0, 1146.0], [246.0, 1146.0], [246.0, 1332.0], [225.0, 1332.0]]], "lines": ["．．．でも", "やんなきゃ", "ならないんだよ。"]}, {"box": [114, 1342, 198, 1521], "vertical": true, "font_size": 25, "lines_coords": [[[176.0, 1343.0], [198.0, 1343.0], [198.0, 1521.0], [176.0, 1521.0]], [[142.0, 1343.0], [168.0, 1343.0], [168.0, 1521.0], [142.0, 1521.0]], [[114.0, 1342.0], [135.0, 1342.0], [135.0, 1482.0], [114.0, 1482.0]]], "lines": ["闘わない君には", "一生わからない", "だろうけど。"]}], "img_path": "096.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [417, 53, 587, 159], "vertical": false, "font_size": 22, "lines_coords": [[[453.0, 56.0], [543.0, 53.0], [543.0, 79.0], [453.0, 82.0]], [[418.0, 89.0], [517.0, 89.0], [517.0, 110.0], [418.0, 110.0]], [[421.0, 114.0], [582.0, 114.0], [582.0, 134.0], [421.0, 134.0]]], "lines": ["危", "接触事故多し", "自転車・バイクは降りて通り"]}, {"box": [514, 739, 578, 909], "vertical": true, "font_size": 30, "lines_coords": [[[545.0, 739.0], [578.0, 740.0], [573.0, 859.0], [540.0, 857.0]], [[514.0, 743.0], [540.0, 743.0], [540.0, 909.0], [514.0, 909.0]]], "lines": ["「．．．ちがく", "ないですか？」"]}, {"box": [521, 1356, 770, 1564], "vertical": true, "font_size": 26, "lines_coords": [[[743.0, 1359.0], [770.0, 1359.0], [770.0, 1475.0], [743.0, 1475.0]], [[710.0, 1357.0], [737.0, 1357.0], [737.0, 1512.0], [710.0, 1512.0]], [[678.0, 1357.0], [706.0, 1357.0], [706.0, 1490.0], [678.0, 1490.0]], [[646.0, 1356.0], [673.0, 1356.0], [675.0, 1562.0], [648.0, 1562.0]], [[617.0, 1359.0], [639.0, 1359.0], [639.0, 1562.0], [617.0, 1562.0]], [[582.0, 1357.0], [609.0, 1357.0], [609.0, 1464.0], [582.0, 1464.0]], [[551.0, 1359.0], [578.0, 1359.0], [578.0, 1525.0], [551.0, 1525.0]], [[521.0, 1360.0], [543.0, 1360.0], [543.0, 1515.0], [521.0, 1515.0]]], "lines": ["「あなたは", "美人さんだし", "頭もいいし、", "絵の才能もあって", "初めから恵まれた", "人だから", "自信が「おあり", "でしょうけど"]}, {"box": [359, 1355, 451, 1540], "vertical": true, "font_size": 26, "lines_coords": [[[420.0, 1357.0], [446.0, 1357.0], [450.0, 1487.0], [423.0, 1487.0]], [[390.0, 1357.0], [417.0, 1357.0], [417.0, 1537.0], [390.0, 1537.0]], [[359.0, 1359.0], [385.0, 1359.0], [385.0, 1512.0], [359.0, 1512.0]]], "lines": ["同じ自信を", "僕に求めるのは", "．．．：酷です。」"]}, {"box": [210, 1156, 239, 1260], "vertical": true, "font_size": 29, "lines_coords": [[[210.0, 1156.0], [239.0, 1156.0], [239.0, 1260.0], [210.0, 1260.0]]], "lines": ["．．．何が？"]}], "img_path": "097.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [162, 103, 189, 246], "vertical": true, "font_size": 22, "lines_coords": [[[162.0, 104.0], [184.0, 104.0], [184.0, 242.0], [162.0, 242.0]]], "lines": ["．．．ちがうよ。"]}, {"box": [635, 360, 698, 505], "vertical": true, "font_size": 27, "lines_coords": [[[671.0, 362.0], [698.0, 362.0], [698.0, 478.0], [671.0, 478.0]], [[635.0, 362.0], [662.0, 362.0], [665.0, 500.0], [639.0, 500.0]]], "lines": ["「いい気な", "もんですね。"]}, {"box": [540, 362, 601, 515], "vertical": true, "font_size": 26.5, "lines_coords": [[[575.0, 364.0], [601.0, 364.0], [601.0, 515.0], [575.0, 515.0]], [[540.0, 362.0], [567.0, 362.0], [567.0, 468.0], [540.0, 468.0]]], "lines": ["人の気持ちも", "考えずに"]}, {"box": [410, 360, 506, 519], "vertical": true, "font_size": 30, "lines_coords": [[[478.0, 360.0], [506.0, 360.0], [501.0, 517.0], [473.0, 517.0]], [[442.0, 360.0], [476.0, 360.0], [476.0, 467.0], [442.0, 467.0]], [[414.0, 360.0], [440.0, 360.0], [437.0, 515.0], [410.0, 515.0]]], "lines": ["上のほうから", "ズンズン", "スケスケと。」"]}, {"box": [204, 657, 237, 843], "vertical": true, "font_size": 28, "lines_coords": [[[204.0, 659.0], [232.0, 659.0], [234.0, 843.0], [206.0, 843.0]]], "lines": ["．．．だからっ！！"]}, {"box": [512, 942, 613, 1165], "vertical": true, "font_size": 27, "lines_coords": [[[582.0, 943.0], [610.0, 943.0], [612.0, 1121.0], [584.0, 1121.0]], [[548.0, 942.0], [575.0, 942.0], [571.0, 1126.0], [545.0, 1126.0]], [[515.0, 942.0], [542.0, 942.0], [539.0, 1160.0], [512.0, 1160.0]]], "lines": ["「もうこれ以上、", "僕を虐めるのは", "やめてください．．．"]}, {"box": [234, 1331, 262, 1501], "vertical": true, "font_size": 26, "lines_coords": [[[234.0, 1331.0], [260.0, 1331.0], [260.0, 1498.0], [234.0, 1498.0]]], "lines": ["．．．小野寺くん。"]}], "img_path": "098.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [915, 98, 937, 223], "vertical": true, "font_size": 28, "lines_coords": [[[915.0, 98.0], [937.0, 98.0], [937.0, 223.0], [915.0, 223.0]]], "lines": ["ホントは．．"]}, {"box": [792, 253, 889, 395], "vertical": true, "font_size": 28, "lines_coords": [[[851.0, 253.0], [889.0, 253.0], [889.0, 315.0], [851.0, 315.0]], [[826.0, 257.0], [853.0, 257.0], [853.0, 364.0], [826.0, 364.0]], [[792.0, 256.0], [818.0, 256.0], [821.0, 395.0], [795.0, 395.0]]], "lines": ["君に", "わざわざ", "こんなこと、"]}, {"box": [260, 181, 380, 278], "vertical": false, "font_size": 19, "lines_coords": [[[287.0, 182.0], [354.0, 182.0], [354.0, 192.0], [287.0, 192.0]], [[262.0, 183.0], [379.0, 188.0], [379.0, 214.0], [262.0, 209.0]], [[265.0, 207.0], [340.0, 207.0], [340.0, 228.0], [265.0, 228.0]], [[264.0, 218.0], [373.0, 212.0], [375.0, 236.0], [265.0, 242.0]], [[268.0, 258.0], [339.0, 252.0], [340.0, 273.0], [270.0, 280.0]]], "lines": ["．．．", "．．．知り合いがありませんでしょうかもしれないと思っていますのですが．．．私もそうですから", "はいはい．．．", "２０１８年６月２９日にショップされていただきました。", "まあそう思ったけれどうか無視にそれがありませんですが何度もし"]}, {"box": [131, 337, 221, 468], "vertical": true, "font_size": 25, "lines_coords": [[[193.0, 339.0], [221.0, 339.0], [221.0, 445.0], [193.0, 445.0]], [[165.0, 340.0], [187.0, 340.0], [187.0, 467.0], [165.0, 467.0]], [[131.0, 337.0], [157.0, 337.0], [157.0, 468.0], [131.0, 468.0]]], "lines": ["言いたく", "なかったん", "だけど．．．"]}, {"box": [232, 600, 260, 739], "vertical": true, "font_size": 27, "lines_coords": [[[232.0, 600.0], [259.0, 600.0], [259.0, 735.0], [232.0, 735.0]]], "lines": ["．．．あたしね、"]}, {"box": [881, 809, 914, 900], "vertical": true, "font_size": 33, "lines_coords": [[[881.0, 809.0], [914.0, 809.0], [914.0, 900.0], [881.0, 900.0]]], "lines": ["この顔、"]}, {"box": [315, 1054, 341, 1193], "vertical": true, "font_size": 22, "lines_coords": [[[315.0, 1056.0], [337.0, 1056.0], [337.0, 1193.0], [315.0, 1193.0]]], "lines": ["整形なんだ。"]}], "img_path": "099.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [830, 96, 920, 251], "vertical": true, "font_size": 25, "lines_coords": [[[893.0, 96.0], [920.0, 96.0], [920.0, 226.0], [893.0, 226.0]], [[860.0, 96.0], [887.0, 96.0], [887.0, 251.0], [860.0, 251.0]], [[831.0, 98.0], [853.0, 98.0], [853.0, 229.0], [831.0, 229.0]]], "lines": ["．．．あたしは", "母親の連れ子", "だったから、"]}, {"box": [18, 278, 81, 450], "vertical": true, "font_size": 57, "lines_coords": [[[18.0, 279.0], [75.0, 278.0], [81.0, 448.0], [25.0, 450.0]]], "lines": ["第８４話"]}, {"box": [932, 684, 978, 762], "vertical": true, "font_size": 44, "lines_coords": [[[932.0, 684.0], [978.0, 684.0], [978.0, 762.0], [932.0, 762.0]]], "lines": ["デブ、"]}, {"box": [854, 754, 896, 825], "vertical": true, "font_size": 44, "lines_coords": [[[854.0, 754.0], [896.0, 754.0], [896.0, 825.0], [854.0, 825.0]]], "lines": ["バカ、"]}, {"box": [142, 409, 263, 590], "vertical": true, "font_size": 25, "lines_coords": [[[235.0, 409.0], [262.0, 409.0], [262.0, 512.0], [235.0, 512.0]], [[203.0, 410.0], [229.0, 410.0], [229.0, 590.0], [203.0, 590.0]], [[171.0, 410.0], [195.0, 410.0], [196.0, 564.0], [173.0, 564.0]], [[142.0, 412.0], [164.0, 412.0], [164.0, 573.0], [142.0, 573.0]]], "lines": ["再婚先の", "父親と兄弟達と", "うまくやって", "いけなくてさ。"]}, {"box": [276, 657, 303, 767], "vertical": true, "font_size": 26, "lines_coords": [[[276.0, 657.0], [303.0, 657.0], [303.0, 767.0], [276.0, 767.0]]], "lines": ["ブスって、"]}, {"box": [135, 714, 228, 868], "vertical": true, "font_size": 26, "lines_coords": [[[201.0, 715.0], [228.0, 715.0], [228.0, 846.0], [201.0, 846.0]], [[171.0, 717.0], [193.0, 717.0], [193.0, 868.0], [171.0, 868.0]], [[139.0, 714.0], [165.0, 714.0], [162.0, 828.0], [135.0, 828.0]]], "lines": ["子供の頃に", "散々言われて", "きたから"]}, {"box": [893, 945, 987, 1076], "vertical": true, "font_size": 29, "lines_coords": [[[954.0, 945.0], [987.0, 945.0], [987.0, 1029.0], [954.0, 1029.0]], [[925.0, 946.0], [951.0, 946.0], [951.0, 1076.0], [925.0, 1076.0]], [[893.0, 948.0], [920.0, 948.0], [920.0, 1054.0], [893.0, 1054.0]]], "lines": ["ご飯は", "吐けるだけ", "吐いたし、"]}, {"box": [412, 1020, 538, 1190], "vertical": true, "font_size": 29, "lines_coords": [[[510.0, 1023.0], [537.0, 1023.0], [537.0, 1151.0], [510.0, 1151.0]], [[478.0, 1020.0], [506.0, 1020.0], [503.0, 1178.0], [475.0, 1178.0]], [[446.0, 1021.0], [473.0, 1021.0], [473.0, 1190.0], [446.0, 1190.0]], [[412.0, 1021.0], [445.0, 1021.0], [445.0, 1110.0], [412.0, 1110.0]]], "lines": ["大学入って", "すぐ水商売で", "ぬちゃめちゃに", "働いて、"]}, {"box": [321, 948, 356, 1015], "vertical": true, "font_size": 36, "lines_coords": [[[321.0, 948.0], [356.0, 948.0], [356.0, 1015.0], [321.0, 1015.0]]], "lines": ["目も、"]}, {"box": [273, 1071, 309, 1137], "vertical": true, "font_size": 36, "lines_coords": [[[273.0, 1071.0], [309.0, 1071.0], [309.0, 1137.0], [273.0, 1137.0]]], "lines": ["鼻も、"]}, {"box": [120, 1098, 147, 1185], "vertical": true, "font_size": 26, "lines_coords": [[[120.0, 1098.0], [146.0, 1098.0], [146.0, 1185.0], [120.0, 1185.0]]], "lines": ["輪郭も、"]}, {"box": [781, 1295, 872, 1451], "vertical": true, "font_size": 24, "lines_coords": [[[846.0, 1298.0], [868.0, 1298.0], [868.0, 1450.0], [846.0, 1450.0]], [[809.0, 1295.0], [835.0, 1295.0], [839.0, 1426.0], [812.0, 1426.0]], [[782.0, 1298.0], [804.0, 1298.0], [804.0, 1428.0], [782.0, 1428.0]]], "lines": ["頭がおかしく", "なるくらい", "勉強したし"]}, {"box": [100, 1334, 191, 1515], "vertical": true, "font_size": 27, "lines_coords": [[[164.0, 1334.0], [190.0, 1334.0], [190.0, 1515.0], [164.0, 1515.0]], [[131.0, 1334.0], [157.0, 1334.0], [157.0, 1515.0], [131.0, 1515.0]], [[100.0, 1335.0], [128.0, 1335.0], [128.0, 1426.0], [100.0, 1426.0]]], "lines": ["嫌いなところは", "全部作り直して", "やった。"]}], "img_path": "100.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [948, 217, 986, 282], "vertical": true, "font_size": 36, "lines_coords": [[[948.0, 217.0], [986.0, 217.0], [986.0, 282.0], [948.0, 282.0]]], "lines": ["顔も、"]}, {"box": [870, 307, 905, 378], "vertical": true, "font_size": 36, "lines_coords": [[[870.0, 307.0], [905.0, 307.0], [905.0, 378.0], [870.0, 378.0]]], "lines": ["体も、"]}, {"box": [509, 451, 599, 632], "vertical": true, "font_size": 23, "lines_coords": [[[572.0, 451.0], [598.0, 451.0], [598.0, 607.0], [572.0, 607.0]], [[542.0, 453.0], [564.0, 453.0], [564.0, 606.0], [542.0, 606.0]], [[511.0, 453.0], [533.0, 453.0], [533.0, 629.0], [511.0, 629.0]]], "lines": ["あたしは全部", "自分の意志で", "選択してきたし、"]}, {"box": [895, 1078, 925, 1191], "vertical": true, "font_size": 28, "lines_coords": [[[895.0, 1078.0], [923.0, 1078.0], [925.0, 1190.0], [897.0, 1190.0]]], "lines": ["生き方も、"]}, {"box": [391, 946, 448, 1127], "vertical": true, "font_size": 22, "lines_coords": [[[422.0, 946.0], [443.0, 946.0], [443.0, 1073.0], [422.0, 1073.0]], [[392.0, 946.0], [414.0, 946.0], [414.0, 1121.0], [392.0, 1121.0]]], "lines": ["誰にも命令", "されたくないし、"]}], "img_path": "101.png"}, {"version": "0.2.0-beta.6", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [762, 98, 822, 234], "vertical": true, "font_size": 26, "lines_coords": [[[800.0, 100.0], [822.0, 100.0], [822.0, 226.0], [800.0, 226.0]], [[762.0, 98.0], [790.0, 98.0], [794.0, 234.0], [765.0, 234.0]]], "lines": ["過去なんて", "いらないし、"]}, {"box": [665, 195, 725, 348], "vertical": true, "font_size": 26, "lines_coords": [[[698.0, 195.0], [725.0, 195.0], [725.0, 326.0], [698.0, 326.0]], [[665.0, 195.0], [692.0, 195.0], [692.0, 348.0], [665.0, 348.0]]], "lines": ["夢は叶える", "ためにあるし、"]}, {"box": [157, 179, 250, 339], "vertical": true, "font_size": 28, "lines_coords": [[[226.0, 182.0], [250.0, 182.0], [246.0, 310.0], [223.0, 310.0]], [[193.0, 179.0], [220.0, 179.0], [217.0, 339.0], [190.0, 339.0]], [[157.0, 179.0], [193.0, 179.0], [193.0, 250.0], [157.0, 250.0]]], "lines": ["お金と恋愛", "どっちも必要", "だし、"]}, {"box": [70, 345, 162, 475], "vertical": true, "font_size": 28, "lines_coords": [[[135.0, 346.0], [162.0, 346.0], [162.0, 451.0], [135.0, 451.0]], [[101.0, 346.0], [129.0, 346.0], [131.0, 475.0], [103.0, 475.0]], [[70.0, 345.0], [98.0, 345.0], [101.0, 460.0], [73.0, 460.0]]], "lines": ["もちろん", "成功だって", "したいし、"]}, {"box": [28, 1182, 182, 1404], "vertical": true, "font_size": 23, "lines_coords": [[[157.0, 1184.0], [179.0, 1184.0], [179.0, 1403.0], [157.0, 1403.0]], [[125.0, 1185.0], [146.0, 1185.0], [146.0, 1389.0], [125.0, 1389.0]], [[93.0, 1185.0], [115.0, 1185.0], [115.0, 1364.0], [93.0, 1364.0]], [[57.0, 1182.0], [84.0, 1182.0], [85.0, 1389.0], [59.0, 1389.0]], [[29.0, 1184.0], [53.0, 1184.0], [51.0, 1371.0], [28.0, 1371.0]]], "lines": ["そんな馬鹿みたいな", "単純な動機だけど", "前進し続けてる", "ことが、あたしの", "自信になってる。"]}], "img_path": "102.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [924, 107, 981, 299], "vertical": true, "font_size": 24, "lines_coords": [[[951.0, 107.0], [978.0, 107.0], [981.0, 240.0], [954.0, 240.0]], [[925.0, 110.0], [946.0, 110.0], [946.0, 296.0], [925.0, 296.0]]], "lines": ["あたしには", "理想があるから、"]}, {"box": [178, 325, 265, 487], "vertical": true, "font_size": 25, "lines_coords": [[[239.0, 325.0], [265.0, 325.0], [262.0, 482.0], [235.0, 482.0]], [[207.0, 326.0], [234.0, 326.0], [234.0, 459.0], [207.0, 459.0]], [[178.0, 328.0], [200.0, 328.0], [200.0, 487.0], [178.0, 487.0]]], "lines": ["どんな手段を", "使ってでも", "手に入れるし、"]}, {"box": [125, 590, 245, 746], "vertical": true, "font_size": 25, "lines_coords": [[[215.0, 590.0], [243.0, 590.0], [245.0, 696.0], [217.0, 696.0]], [[185.0, 592.0], [212.0, 592.0], [212.0, 746.0], [185.0, 746.0]], [[156.0, 596.0], [178.0, 596.0], [178.0, 745.0], [156.0, 745.0]], [[125.0, 593.0], [146.0, 593.0], [146.0, 706.0], [125.0, 706.0]]], "lines": ["あたしは", "そんな自分が", "一番正しいと", "思ってる。"]}, {"box": [846, 1193, 967, 1376], "vertical": true, "font_size": 26, "lines_coords": [[[945.0, 1195.0], [967.0, 1195.0], [967.0, 1373.0], [945.0, 1373.0]], [[909.0, 1193.0], [935.0, 1193.0], [935.0, 1376.0], [909.0, 1376.0]], [[878.0, 1193.0], [904.0, 1193.0], [904.0, 1351.0], [878.0, 1351.0]], [[846.0, 1195.0], [868.0, 1195.0], [868.0, 1304.0], [846.0, 1304.0]]], "lines": ["うじうじ悩んで", "身動きとれなく", "なってる君を", "見てると、"]}, {"box": [757, 1378, 845, 1485], "vertical": true, "font_size": 26, "lines_coords": [[[818.0, 1381.0], [845.0, 1381.0], [845.0, 1485.0], [818.0, 1485.0]], [[784.0, 1378.0], [817.0, 1378.0], [817.0, 1464.0], [784.0, 1464.0]], [[757.0, 1385.0], [781.0, 1385.0], [781.0, 1462.0], [757.0, 1462.0]]], "lines": ["イライラ", "すると", "いうか"]}, {"box": [229, 1171, 351, 1395], "vertical": true, "font_size": 26, "lines_coords": [[[325.0, 1173.0], [351.0, 1173.0], [351.0, 1278.0], [325.0, 1278.0]], [[293.0, 1173.0], [320.0, 1173.0], [320.0, 1395.0], [293.0, 1395.0]], [[262.0, 1171.0], [284.0, 1171.0], [284.0, 1378.0], [262.0, 1378.0]], [[229.0, 1173.0], [256.0, 1173.0], [256.0, 1354.0], [229.0, 1354.0]]], "lines": ["どこかに", "置き去りにしてきた", "子供の頃の自分を", "見てるみたいで、"]}, {"box": [112, 1354, 204, 1496], "vertical": true, "font_size": 26, "lines_coords": [[[176.0, 1356.0], [204.0, 1356.0], [204.0, 1435.0], [176.0, 1435.0]], [[145.0, 1356.0], [171.0, 1356.0], [171.0, 1462.0], [145.0, 1462.0]], [[112.0, 1354.0], [135.0, 1354.0], [139.0, 1496.0], [115.0, 1496.0]]], "lines": ["なんか", "罪悪感を", "感じるんだ。"]}], "img_path": "103.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [853, 65, 973, 217], "vertical": true, "font_size": 26, "lines_coords": [[[946.0, 68.0], [973.0, 68.0], [973.0, 217.0], [946.0, 217.0]], [[915.0, 65.0], [942.0, 65.0], [939.0, 198.0], [912.0, 198.0]], [[885.0, 68.0], [907.0, 68.0], [907.0, 195.0], [885.0, 195.0]], [[853.0, 67.0], [875.0, 67.0], [875.0, 212.0], [853.0, 212.0]]], "lines": ["君が悩んでる", "ことなんか", "実は中身は", "空っぽなのは、"]}, {"box": [795, 265, 917, 426], "vertical": true, "font_size": 26, "lines_coords": [[[887.0, 270.0], [914.0, 270.0], [917.0, 426.0], [890.0, 426.0]], [[851.0, 265.0], [890.0, 265.0], [890.0, 353.0], [851.0, 353.0]], [[825.0, 270.0], [851.0, 270.0], [851.0, 401.0], [825.0, 401.0]], [[795.0, 273.0], [817.0, 273.0], [817.0, 421.0], [795.0, 421.0]]], "lines": ["わかりすぎる", "くらい", "わかってる", "つもりだから"]}, {"box": [207, 132, 296, 289], "vertical": true, "font_size": 27, "lines_coords": [[[268.0, 132.0], [296.0, 132.0], [296.0, 239.0], [268.0, 239.0]], [[237.0, 134.0], [264.0, 134.0], [264.0, 289.0], [237.0, 289.0]], [[207.0, 135.0], [229.0, 135.0], [229.0, 267.0], [207.0, 267.0]]], "lines": ["．．．だから", "あたしは君を", "許せないし、"]}, {"box": [101, 310, 193, 492], "vertical": true, "font_size": 27, "lines_coords": [[[167.0, 310.0], [193.0, 310.0], [193.0, 443.0], [167.0, 443.0]], [[134.0, 312.0], [160.0, 312.0], [160.0, 492.0], [134.0, 492.0]], [[101.0, 310.0], [134.0, 310.0], [134.0, 356.0], [101.0, 356.0]]], "lines": ["どうしても", "放っておけない", "の。"]}, {"box": [880, 809, 973, 950], "vertical": true, "font_size": 27, "lines_coords": [[[940.0, 809.0], [973.0, 809.0],