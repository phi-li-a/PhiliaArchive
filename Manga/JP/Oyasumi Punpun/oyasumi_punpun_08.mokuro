e, "font_size": 29, "lines_coords": [[[221.0, 365.0], [257.0, 365.0], [257.0, 426.0], [221.0, 426.0]]], "lines": ["何？"]}, {"box": [168, 462, 190, 592], "vertical": true, "font_size": 29, "lines_coords": [[[168.0, 462.0], [190.0, 462.0], [190.0, 592.0], [168.0, 592.0]]], "lines": ["どしたの？"]}, {"box": [664, 1015, 789, 1200], "vertical": true, "font_size": 30, "lines_coords": [[[756.0, 1017.0], [789.0, 1017.0], [789.0, 1112.0], [756.0, 1112.0]], [[726.0, 1018.0], [753.0, 1018.0], [753.0, 1200.0], [726.0, 1200.0]], [[692.0, 1015.0], [725.0, 1015.0], [725.0, 1151.0], [692.0, 1151.0]], [[664.0, 1017.0], [690.0, 1017.0], [690.0, 1198.0], [664.0, 1198.0]]], "lines": ["「なにか", "手伝いましょう", "かァーー？", "ウェッヘッへ。」"]}, {"box": [954, 1248, 1014, 1378], "vertical": true, "font_size": 27, "lines_coords": [[[982.0, 1248.0], [1014.0, 1248.0], [1014.0, 1289.0], [982.0, 1289.0]], [[954.0, 1248.0], [987.0, 1248.0], [987.0, 1378.0], [954.0, 1378.0]]], "lines": ["あー", "いい、いい。"]}, {"box": [867, 1339, 917, 1476], "vertical": true, "font_size": 27, "lines_coords": [[[895.0, 1340.0], [917.0, 1340.0], [917.0, 1476.0], [895.0, 1476.0]], [[867.0, 1339.0], [889.0, 1339.0], [889.0, 1467.0], [867.0, 1467.0]]], "lines": ["一人のほうが", "効率いいし。"]}, {"box": [429, 1312, 509, 1520], "vertical": true, "font_size": 22, "lines_coords": [[[484.0, 1314.0], [506.0, 1314.0], [506.0, 1520.0], [484.0, 1520.0]], [[457.0, 1314.0], [479.0, 1314.0], [479.0, 1509.0], [457.0, 1509.0]], [[429.0, 1312.0], [451.0, 1312.0], [451.0, 1453.0], [429.0, 1453.0]]], "lines": ["ゆっくりしてけば？", "この後、深夜バイト", "なんでしょ？"]}], "img_path": "034.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [976, 85, 1004, 190], "vertical": true, "font_size": 34, "lines_coords": [[[976.0, 85.0], [1004.0, 85.0], [1004.0, 190.0], [976.0, 190.0]]], "lines": ["．．．ほい！！"]}, {"box": [853, 175, 931, 307], "vertical": true, "font_size": 34, "lines_coords": [[[889.0, 175.0], [931.0, 176.0], [926.0, 276.0], [884.0, 275.0]], [[853.0, 181.0], [885.0, 181.0], [885.0, 307.0], [853.0, 307.0]]], "lines": ["食べた", "食べた！！"]}, {"box": [193, 421, 287, 551], "vertical": true, "font_size": 27, "lines_coords": [[[253.0, 421.0], [287.0, 421.0], [287.0, 504.0], [253.0, 504.0]], [[225.0, 423.0], [251.0, 423.0], [251.0, 551.0], [225.0, 551.0]], [[193.0, 421.0], [221.0, 421.0], [221.0, 528.0], [193.0, 528.0]]], "lines": ["どーせ", "お金無いん", "でしょ？"]}, {"box": [145, 618, 265, 828], "vertical": true, "font_size": 27, "lines_coords": [[[237.0, 620.0], [265.0, 620.0], [265.0, 714.0], [237.0, 714.0]], [[206.0, 620.0], [232.0, 620.0], [232.0, 779.0], [206.0, 779.0]], [[171.0, 618.0], [198.0, 618.0], [203.0, 828.0], [176.0, 828.0]], [[145.0, 623.0], [167.0, 623.0], [167.0, 759.0], [145.0, 759.0]]], "lines": ["君顔色", "悪いんだもん。", "たまにはきちっと", "食べなきゃ。"]}, {"box": [951, 893, 1001, 1045], "vertical": true, "font_size": 23, "lines_coords": [[[979.0, 895.0], [1001.0, 895.0], [1001.0, 1045.0], [979.0, 1045.0]], [[951.0, 893.0], [973.0, 893.0], [973.0, 996.0], [951.0, 996.0]]], "lines": ["味薄かったら", "言ってね。"]}, {"box": [860, 1003, 934, 1193], "vertical": true, "font_size": 23, "lines_coords": [[[912.0, 1004.0], [934.0, 1004.0], [934.0, 1171.0], [912.0, 1171.0]], [[882.0, 1003.0], [909.0, 1003.0], [914.0, 1193.0], [887.0, 1193.0]], [[860.0, 1007.0], [884.0, 1007.0], [884.0, 1079.0], [860.0, 1079.0]]], "lines": ["苦手なもの入って", "たら、どけちゃって", "いいし。"]}, {"box": [339, 889, 420, 1053], "vertical": true, "font_size": 23, "lines_coords": [[[393.0, 889.0], [420.0, 889.0], [420.0, 1007.0], [393.0, 1007.0]], [[367.0, 889.0], [389.0, 889.0], [389.0, 1006.0], [367.0, 1006.0]], [[340.0, 890.0], [360.0, 890.0], [360.0, 1020.0], [340.0, 1020.0]]], "lines": ["．．．しっかし", "こういう奴", "不愉快だわー"]}, {"box": [479, 1040, 559, 1247], "vertical": true, "font_size": 22, "lines_coords": [[[534.0, 1040.0], [556.0, 1040.0], [556.0, 1246.0], [534.0, 1246.0]], [[507.0, 1043.0], [529.0, 1043.0], [529.0, 1203.0], [507.0, 1203.0]], [[479.0, 1040.0], [501.0, 1040.0], [501.0, 1187.0], [479.0, 1187.0]]], "lines": ["納豆とかキムチとか", "一通りあるんで", "適当にどーぞ。"]}, {"box": [941, 1299, 965, 1461], "vertical": true, "font_size": 22, "lines_coords": [[[942.0, 1300.0], [964.0, 1300.0], [964.0, 1460.0], [942.0, 1460.0]]], "lines": ["おしゃまんべ！！"]}, {"box": [456, 1389, 485, 1464], "vertical": true, "font_size": 29, "lines_coords": [[[456.0, 1389.0], [485.0, 1389.0], [485.0, 1464.0], [456.0, 1464.0]]], "lines": ["正解！！"]}, {"box": [115, 1356, 223, 1492], "vertical": true, "font_size": 20, "lines_coords": [[[200.0, 1357.0], [223.0, 1357.0], [220.0, 1492.0], [196.0, 1492.0]], [[170.0, 1357.0], [192.0, 1357.0], [192.0, 1492.0], [170.0, 1492.0]], [[145.0, 1357.0], [162.0, 1357.0], [162.0, 1468.0], [145.0, 1468.0]], [[115.0, 1357.0], [132.0, 1357.0], [132.0, 1467.0], [115.0, 1467.0]]], "lines": ["モデル出身で", "タレントとか", "欲張りすぎ", "だろーー？"]}], "img_path": "035.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [940, 38, 992, 208], "vertical": true, "font_size": 22, "lines_coords": [[[967.0, 40.0], [990.0, 40.0], [992.0, 176.0], [968.0, 176.0]], [[940.0, 39.0], [960.0, 39.0], [960.0, 206.0], [940.0, 206.0]]], "lines": ["いいですなぁ", "恵まれてる人は。"]}, {"box": [704, 207, 789, 376], "vertical": true, "font_size": 28, "lines_coords": [[[753.0, 207.0], [789.0, 207.0], [789.0, 271.0], [753.0, 271.0]], [[729.0, 210.0], [756.0, 210.0], [753.0, 376.0], [726.0, 376.0]], [[704.0, 212.0], [726.0, 212.0], [726.0, 371.0], [704.0, 371.0]]], "lines": ["．．．あ、", "チャンネル変え", "ちゃっていいよ。"]}, {"box": [537, 90, 636, 272], "vertical": true, "font_size": 27, "lines_coords": [[[601.0, 90.0], [628.0, 90.0], [628.0, 257.0], [601.0, 257.0]], [[568.0, 92.0], [595.0, 92.0], [595.0, 271.0], [568.0, 271.0]], [[537.0, 92.0], [564.0, 92.0], [564.0, 246.0], [537.0, 246.0]]], "lines": ["「．．．南条さんて", "意外と親切な人", "なんですね。」"]}, {"box": [179, 207, 338, 390], "vertical": true, "font_size": 27, "lines_coords": [[[310.0, 210.0], [337.0, 210.0], [337.0, 353.0], [310.0, 353.0]], [[278.0, 209.0], [304.0, 209.0], [301.0, 342.0], [275.0, 342.0]], [[246.0, 207.0], [273.0, 207.0], [271.0, 390.0], [245.0, 390.0]], [[214.0, 209.0], [240.0, 209.0], [239.0, 390.0], [212.0, 390.0]], [[182.0, 209.0], [209.0, 209.0], [206.0, 326.0], [179.0, 326.0]]], "lines": ["「人に優しく", "できるのは、", "それだけ自分に", "自信があるから", "ですか？」"]}, {"box": [946, 437, 982, 498], "vertical": true, "font_size": 36, "lines_coords": [[[946.0, 437.0], [982.0, 437.0], [982.0, 498.0], [946.0, 498.0]]], "lines": ["ん？"]}, {"box": [485, 551, 518, 634], "vertical": true, "font_size": 33, "lines_coords": [[[485.0, 551.0], [518.0, 551.0], [518.0, 634.0], [485.0, 634.0]]], "lines": ["そお？"]}, {"box": [875, 729, 989, 915], "vertical": true, "font_size": 25, "lines_coords": [[[962.0, 731.0], [989.0, 731.0], [989.0, 826.0], [962.0, 826.0]], [[931.0, 729.0], [957.0, 729.0], [960.0, 881.0], [934.0, 881.0]], [[900.0, 729.0], [921.0, 729.0], [921.0, 915.0], [900.0, 915.0]], [[875.0, 731.0], [896.0, 731.0], [896.0, 825.0], [875.0, 825.0]]], "lines": ["おーい", "なんだよ、その", "捻くれた考え方は", "よー！！"]}, {"box": [818, 937, 900, 1082], "vertical": true, "font_size": 25, "lines_coords": [[[871.0, 942.0], [900.0, 942.0], [900.0, 1015.0], [871.0, 1015.0]], [[845.0, 937.0], [871.0, 937.0], [868.0, 1082.0], [842.0, 1082.0]], [[818.0, 943.0], [840.0, 943.0], [840.0, 1068.0], [818.0, 1068.0]]], "lines": ["つーか", "「意外と」とか", "余計だしな。"]}, {"box": [210, 882, 264, 1001], "vertical": true, "font_size": 23, "lines_coords": [[[234.0, 882.0], [260.0, 882.0], [264.0, 1001.0], [237.0, 1001.0]], [[210.0, 884.0], [232.0, 884.0], [232.0, 984.0], [210.0, 984.0]]], "lines": ["普通でしょ", "こんなん"]}, {"box": [121, 1062, 229, 1250], "vertical": true, "font_size": 23, "lines_coords": [[[207.0, 1064.0], [229.0, 1064.0], [229.0, 1181.0], [207.0, 1181.0]], [[179.0, 1062.0], [201.0, 1062.0], [201.0, 1246.0], [179.0, 1246.0]], [[150.0, 1062.0], [171.0, 1062.0], [173.0, 1250.0], [151.0, 1250.0]], [[121.0, 1062.0], [143.0, 1062.0], [145.0, 1235.0], [123.0, 1235.0]]], "lines": ["そりゃまあ", "人並みに誰からも", "好かれたいっつー", "打算はあるけど。"]}, {"box": [744, 1347, 769, 1528], "vertical": true, "font_size": 21, "lines_coords": [[[746.0, 1350.0], [767.0, 1350.0], [767.0, 1521.0], [746.0, 1521.0]]], "lines": ["「．．．すみません。"]}, {"box": [565, 1346, 625, 1477], "vertical": true, "font_size": 25, "lines_coords": [[[601.0, 1350.0], [623.0, 1350.0], [623.0, 1475.0], [601.0, 1475.0]], [[565.0, 1348.0], [593.0, 1348.0], [593.0, 1454.0], [565.0, 1454.0]]], "lines": ["人と話すの", "苦手で。」"]}, {"box": [329, 1347, 453, 1487], "vertical": true, "font_size": 27, "lines_coords": [[[425.0, 1348.0], [451.0, 1348.0], [451.0, 1476.0], [425.0, 1476.0]], [[393.0, 1348.0], [420.0, 1348.0], [420.0, 1476.0], [393.0, 1476.0]], [[362.0, 1348.0], [389.0, 1348.0], [389.0, 1476.0], [362.0, 1476.0]], [[329.0, 1348.0], [356.0, 1348.0], [356.0, 1485.0], [329.0, 1485.0]]], "lines": ["ブンブンは", "言わなきゃ", "良かったと", "思いました。"]}], "img_path": "036.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [979, 89, 1006, 201], "vertical": true, "font_size": 26, "lines_coords": [[[979.0, 89.0], [1006.0, 89.0], [1006.0, 201.0], [979.0, 201.0]]], "lines": ["．．．ほーお。"]}, {"box": [845, 168, 937, 325], "vertical": true, "font_size": 26, "lines_coords": [[[910.0, 168.0], [937.0, 168.0], [937.0, 301.0], [910.0, 301.0]], [[878.0, 170.0], [904.0, 170.0], [904.0, 325.0], [878.0, 325.0]], [[845.0, 170.0], [871.0, 170.0], [871.0, 276.0], [845.0, 276.0]]], "lines": ["じゃあ君は", "自分に自信が", "無いの？"]}, {"box": [226, 117, 293, 226], "vertical": true, "font_size": 29, "lines_coords": [[[262.0, 121.0], [290.0, 121.0], [293.0, 226.0], [265.0, 226.0]], [[226.0, 118.0], [260.0, 117.0], [264.0, 203.0], [229.0, 204.0]]], "lines": ["無いなら", "作れ！！"]}, {"box": [121, 226, 214, 382], "vertical": true, "font_size": 29, "lines_coords": [[[187.0, 226.0], [214.0, 226.0], [214.0, 331.0], [187.0, 331.0]], [[154.0, 229.0], [181.0, 229.0], [181.0, 357.0], [154.0, 357.0]], [[125.0, 226.0], [151.0, 226.0], [148.0, 382.0], [121.0, 382.0]]], "lines": ["もしくは", "コンビニで", "買ってこい！！"]}, {"box": [907, 456, 959, 595], "vertical": true, "font_size": 24, "lines_coords": [[[937.0, 456.0], [959.0, 456.0], [959.0, 571.0], [937.0, 571.0]], [[907.0, 457.0], [929.0, 457.0], [929.0, 595.0], [907.0, 595.0]]], "lines": ["．．．というか", "なんというか"]}, {"box": [770, 632, 910, 820], "vertical": true, "font_size": 24, "lines_coords": [[[882.0, 632.0], [910.0, 632.0], [910.0, 729.0], [882.0, 729.0]], [[857.0, 634.0], [879.0, 634.0], [879.0, 775.0], [857.0, 775.0]], [[828.0, 634.0], [850.0, 634.0], [850.0, 817.0], [828.0, 817.0]], [[800.0, 635.0], [821.0, 635.0], [821.0, 820.0], [800.0, 820.0]], [[770.0, 632.0], [800.0, 632.0], [800.0, 678.0], [770.0, 678.0]]], "lines": ["喋ってて", "思うんだけど", "君はびとつひとつ", "力み過ぎなんだよ", "ねー"]}, {"box": [251, 554, 279, 628], "vertical": true, "font_size": 24, "lines_coords": [[[251.0, 554.0], [279.0, 554.0], [279.0, 628.0], [251.0, 628.0]]], "lines": ["なんか"]}, {"box": [200, 556, 278, 672], "vertical": true, "font_size": 22, "lines_coords": [[[226.0, 556.0], [248.0, 556.0], [248.0, 670.0], [226.0, 670.0]]], "lines": ["そういうの"]}, {"box": [120, 556, 228, 909], "vertical": true, "font_size": 24, "lines_coords": [[[198.0, 556.0], [220.0, 556.0], [220.0, 659.0], [198.0, 659.0]], [[206.0, 750.0], [228.0, 750.0], [228.0, 909.0], [206.0, 909.0]], [[178.0, 748.0], [200.0, 748.0], [200.0, 887.0], [178.0, 887.0]], [[150.0, 748.0], [171.0, 748.0], [171.0, 885.0], [150.0, 885.0]], [[120.0, 746.0], [146.0, 746.0], [146.0, 831.0], [120.0, 831.0]]], "lines": ["疲れそう。", "フツーに素直に", "思ったことを", "喋ればいいん", "だって。"]}, {"box": [300, 1043, 381, 1158], "vertical": true, "font_size": 24, "lines_coords": [[[351.0, 1045.0], [381.0, 1045.0], [381.0, 1120.0], [351.0, 1120.0]], [[328.0, 1043.0], [350.0, 1043.0], [350.0, 1157.0], [328.0, 1157.0]], [[300.0, 1043.0], [321.0, 1043.0], [321.0, 1143.0], [300.0, 1143.0]]], "lines": ["いいよ、", "あたし鈍感", "てすから"]}, {"box": [421, 1144, 543, 1402], "vertical": true, "font_size": 23, "lines_coords": [[[520.0, 1146.0], [543.0, 1146.0], [542.0, 1335.0], [518.0, 1335.0]], [[487.0, 1146.0], [509.0, 1146.0], [509.0, 1326.0], [487.0, 1326.0]], [[453.0, 1145.0], [479.0, 1145.0], [479.0, 1301.0], [453.0, 1301.0]], [[423.0, 1146.0], [445.0, 1146.0], [445.0, 1398.0], [423.0, 1398.0]]], "lines": ["「．．．そのフツーが", "相手を傷つけて", "しまいそうで", "怖いじゃないですか。"]}, {"box": [107, 1410, 165, 1525], "vertical": true, "font_size": 26, "lines_coords": [[[139.0, 1410.0], [165.0, 1410.0], [165.0, 1514.0], [139.0, 1514.0]], [[107.0, 1410.0], [134.0, 1410.0], [134.0, 1525.0], [107.0, 1525.0]]], "lines": ["フツーに", "どーぞー。"]}], "img_path": "037.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [338, 190, 429, 359], "vertical": true, "font_size": 24, "lines_coords": [[[400.0, 192.0], [426.0, 192.0], [426.0, 317.0], [400.0, 317.0]], [[368.0, 190.0], [395.0, 190.0], [393.0, 359.0], [367.0, 359.0]], [[339.0, 193.0], [360.0, 193.0], [360.0, 346.0], [339.0, 346.0]]], "lines": ["「．．．．．．いや、", "やめときます。", "すみません。"]}], "img_path": "038.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [931, 114, 957, 218], "vertical": true, "font_size": 26, "lines_coords": [[[931.0, 114.0], [957.0, 114.0], [957.0, 218.0], [931.0, 218.0]]], "lines": ["．．．どお？"]}, {"box": [173, 493, 196, 597], "vertical": true, "font_size": 22, "lines_coords": [[[173.0, 493.0], [195.0, 493.0], [195.0, 595.0], [173.0, 595.0]]], "lines": ["うまい？"]}, {"box": [626, 1046, 656, 1189], "vertical": true, "font_size": 28, "lines_coords": [[[626.0, 1046.0], [654.0, 1046.0], [656.0, 1189.0], [628.0, 1189.0]]], "lines": ["むっふっふ。"]}, {"box": [845, 1198, 872, 1396], "vertical": true, "font_size": 21, "lines_coords": [[[846.0, 1200.0], [867.0, 1200.0], [867.0, 1387.0], [846.0, 1387.0]]], "lines": ["「．．．。おいしい。"]}, {"box": [126, 1203, 193, 1289], "vertical": true, "font_size": 38, "lines_coords": [[[154.0, 1203.0], [193.0, 1204.0], [190.0, 1289.0], [151.0, 1287.0]], [[126.0, 1204.0], [162.0, 1204.0], [162.0, 1276.0], [126.0, 1276.0]]], "lines": ["よーし", "よし。"]}], "img_path": "039.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [868, 147, 898, 294], "vertical": true, "font_size": 27, "lines_coords": [[[868.0, 151.0], [895.0, 151.0], [895.0, 289.0], [868.0, 289.0]]], "lines": ["「．．．．．僕は。」"]}, {"box": [703, 82, 731, 164], "vertical": true, "font_size": 28, "lines_coords": [[[703.0, 82.0], [731.0, 82.0], [731.0, 164.0], [703.0, 164.0]]], "lines": ["うん？"]}, {"box": [204, 149, 297, 329], "vertical": true, "font_size": 23, "lines_coords": [[[271.0, 153.0], [293.0, 153.0], [293.0, 315.0], [271.0, 315.0]], [[239.0, 150.0], [260.0, 150.0], [260.0, 326.0], [239.0, 326.0]], [[204.0, 150.0], [231.0, 150.0], [231.0, 276.0], [204.0, 276.0]]], "lines": ["「彼女ところか", "気の合う友達も", "いません。」"]}, {"box": [603, 1340, 694, 1546], "vertical": true, "font_size": 26, "lines_coords": [[[667.0, 1343.0], [693.0, 1343.0], [693.0, 1484.0], [667.0, 1484.0]], [[634.0, 1340.0], [660.0, 1340.0], [662.0, 1546.0], [635.0, 1546.0]], [[603.0, 1342.0], [629.0, 1342.0], [629.0, 1503.0], [603.0, 1503.0]]], "lines": ["「先日の僕は", "なんだかとっても", "気まずくって、"]}, {"box": [410, 1340, 570, 1527], "vertical": true, "font_size": 29, "lines_coords": [[[532.0, 1340.0], [570.0, 1340.0], [570.0, 1398.0], [532.0, 1398.0]], [[506.0, 1342.0], [532.0, 1342.0], [532.0, 1523.0], [506.0, 1523.0]], [[473.0, 1342.0], [501.0, 1342.0], [501.0, 1473.0], [473.0, 1473.0]], [[443.0, 1342.0], [470.0, 1342.0], [470.0, 1525.0], [443.0, 1525.0]], [[410.0, 1342.0], [437.0, 1342.0], [437.0, 1498.0], [410.0, 1498.0]]], "lines": ["っぃ", "約束があるって", "嘘をついて", "帰ってしまった", "訳なんてす。」"]}], "img_path": "040.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [898, 71, 923, 224], "vertical": true, "font_size": 22, "lines_coords": [[[898.0, 71.0], [920.0, 71.0], [920.0, 223.0], [898.0, 223.0]]], "lines": ["．．．気まずいっ"]}, {"box": [184, 413, 213, 517], "vertical": true, "font_size": 28, "lines_coords": [[[184.0, 414.0], [212.0, 414.0], [212.0, 517.0], [184.0, 517.0]]], "lines": ["なんで？"]}, {"box": [438, 942, 661, 1138], "vertical": true, "font_size": 26, "lines_coords": [[[632.0, 945.0], [659.0, 945.0], [656.0, 1135.0], [629.0, 1135.0]], [[596.0, 943.0], [625.0, 943.0], [626.0, 1121.0], [598.0, 1121.0]], [[570.0, 946.0], [592.0, 946.0], [592.0, 1070.0], [570.0, 1070.0]], [[534.0, 942.0], [560.0, 942.0], [560.0, 1110.0], [534.0, 1110.0]], [[504.0, 942.0], [531.0, 942.0], [526.0, 1098.0], [500.0, 1098.0]], [[471.0, 942.0], [498.0, 942.0], [495.0, 1100.0], [468.0, 1100.0]], [[442.0, 943.0], [464.0, 943.0], [464.0, 1121.0], [442.0, 1121.0]]], "lines": ["「熟睡してるのを", "いいことに僕は", "南条さんの", "生足・及び股間", "というか主に", "陰部あたりを", "凝視しました。"]}], "img_path": "041.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [648, 37, 742, 191], "vertical": true, "font_size": 33, "lines_coords": [[[709.0, 40.0], [742.0, 40.0], [742.0, 131.0], [709.0, 131.0]]], "lines": ["「陰毛が"]}, {"box": [646, 39, 706, 192], "vertical": true, "font_size": 29, "lines_coords": [[[679.0, 39.0], [706.0, 39.0], [706.0, 192.0], [679.0, 192.0]], [[646.0, 40.0], [675.0, 40.0], [675.0, 150.0], [646.0, 150.0]]], "lines": ["飛び出してる", "のを見て、"]}, {"box": [489, 35, 610, 192], "vertical": true, "font_size": 29, "lines_coords": [[[584.0, 40.0], [610.0, 40.0], [610.0, 192.0], [584.0, 192.0]], [[546.0, 35.0], [585.0, 35.0], [585.0, 121.0], [546.0, 121.0]], [[517.0, 39.0], [543.0, 39.0], [546.0, 192.0], [520.0, 192.0]], [[489.0, 42.0], [515.0, 42.0], [515.0, 176.0], [489.0, 176.0]]], "lines": ["ウヒャッって", "なって", "もう駄目ェ！！", "ってなって、"]}, {"box": [357, 35, 452, 168], "vertical": true, "font_size": 26, "lines_coords": [[[423.0, 39.0], [450.0, 39.0], [450.0, 165.0], [423.0, 165.0]], [[393.0, 40.0], [415.0, 40.0], [415.0, 140.0], [393.0, 140.0]], [[360.0, 35.0], [389.0, 35.0], [385.0, 140.0], [357.0, 140.0]]], "lines": ["逃げ出して", "しまった", "訳です。」"]}, {"box": [517, 700, 578, 869], "vertical": true, "font_size": 24, "lines_coords": [[[551.0, 704.0], [573.0, 704.0], [573.0, 865.0], [551.0, 865.0]], [[517.0, 701.0], [543.0, 701.0], [543.0, 857.0], [517.0, 857.0]]], "lines": ["一正直ついてに", "申しますと。」"]}, {"box": [773, 990, 814, 1205], "vertical": true, "font_size": 37, "lines_coords": [[[775.0, 995.0], [812.0, 995.0], [812.0, 1196.0], [775.0, 1196.0]]], "lines": ["「僕は．．．．．．"]}], "img_path": "042.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [479, 454, 631, 612], "vertical": true, "font_size": 33, "lines_coords": [[[589.0, 454.0], [631.0, 454.0], [631.0, 537.0], [589.0, 537.0]], [[554.0, 457.0], [587.0, 457.0], [587.0, 612.0], [554.0, 612.0]], [[515.0, 457.0], [543.0, 457.0], [543.0, 607.0], [515.0, 607.0]], [[479.0, 457.0], [509.0, 457.0], [509.0, 612.0], [479.0, 612.0]]], "lines": ["「昨晩", "三年振りに", "オナニーを", "しました。」"]}], "img_path": "043.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [665, 57, 692, 157], "vertical": true, "font_size": 27, "lines_coords": [[[665.0, 57.0], [692.0, 57.0], [692.0, 157.0], [665.0, 157.0]]], "lines": ["「．．．いや、"]}, {"box": [537, 58, 630, 274], "vertical": true, "font_size": 23, "lines_coords": [[[603.0, 59.0], [625.0, 59.0], [625.0, 212.0], [603.0, 212.0]], [[568.0, 59.0], [595.0, 59.0], [595.0, 240.0], [568.0, 240.0]], [[539.0, 60.0], [560.0, 60.0], [560.0, 264.0], [539.0, 264.0]]], "lines": ["正確に言うと", "昨晩から今朝に", "かけての１０数時間"]}, {"box": [406, 56, 500, 238], "vertical": true, "font_size": 25, "lines_coords": [[[471.0, 57.0], [498.0, 57.0], [498.0, 237.0], [471.0, 237.0]], [[442.0, 60.0], [464.0, 60.0], [464.0, 212.0], [442.0, 212.0]], [[406.0, 56.0], [432.0, 56.0], [432.0, 225.0], [406.0, 225.0]]], "lines": ["ほほ絶え間なく", "手淫に夢中で", "ありました。」"]}, {"box": [21, 282, 67, 445], "vertical": true, "font_size": 46, "lines_coords": [[[21.0, 282.0], [67.0, 282.0], [67.0, 445.0], [21.0, 445.0]]], "lines": ["第８１話"]}, {"box": [825, 1048, 947, 1296], "vertical": true, "font_size": 26, "lines_coords": [[[918.0, 1053.0], [946.0, 1053.0], [943.0, 1229.0], [915.0, 1229.0]], [[887.0, 1048.0], [914.0, 1048.0], [914.0, 1229.0], [887.0, 1229.0]], [[854.0, 1051.0], [881.0, 1051.0], [881.0, 1256.0], [854.0, 1256.0]], [[825.0, 1050.0], [846.0, 1050.0], [846.0, 1287.0], [825.0, 1287.0]]], "lines": ["「僕は、訳あって", "高校の時分から", "オナニーを禁じて", "おりましたので．．．"]}, {"box": [170, 1046, 279, 1510], "vertical": true, "font_size": 50, "lines_coords": [[[231.0, 1050.0], [279.0, 1050.0], [279.0, 1315.0], [231.0, 1315.0]], [[170.0, 1046.0], [223.0, 1046.0], [223.0, 1509.0], [170.0, 1509.0]]], "lines": ["「その威力は", "凄まじかった．．．．！！」"]}], "img_path": "044.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [896, 170, 926, 264], "vertical": true, "font_size": 29, "lines_coords": [[[896.0, 170.0], [925.0, 170.0], [925.0, 264.0], [896.0, 264.0]]], "lines": ["．．．ぷ！！！"]}, {"box": [934, 398, 1012, 610], "vertical": true, "font_size": 35, "lines_coords": [[[976.0, 398.0], [1009.0, 398.0], [1012.0, 610.0], [979.0, 610.0]], [[934.0, 400.0], [968.0, 400.0], [968.0, 507.0], [934.0, 507.0]]], "lines": ["あっ、はっはっ", "はっ！！"]}, {"box": [850, 648, 889, 757], "vertical": true, "font_size": 35, "lines_coords": [[[850.0, 648.0], [889.0, 648.0], [889.0, 757.0], [850.0, 757.0]]], "lines": ["バカ！！"]}, {"box": [865, 1018, 1021, 1205], "vertical": true, "font_size": 28, "lines_coords": [[[993.0, 1023.0], [1021.0, 1023.0], [1021.0, 1065.0], [993.0, 1065.0]], [[960.0, 1018.0], [995.0, 1018.0], [995.0, 1104.0], [960.0, 1104.0]], [[995.0, 1064.0], [1017.0, 1064.0], [1017.0, 1114.0], [995.0, 1114.0]], [[917.0, 1060.0], [951.0, 1060.0], [951.0, 1146.0], [917.0, 1146.0]], [[895.0, 1065.0], [917.0, 1065.0], [917.0, 1204.0], [895.0, 1204.0]], [[865.0, 1062.0], [892.0, 1062.0], [892.0, 1160.0], [865.0, 1160.0]]], "lines": ["はー", "参った。", "．．．", "あたし、", "パンツ丸出し", "だった？"]}, {"box": [548, 1025, 629, 1165], "vertical": true, "font_size": 24, "lines_coords": [[[607.0, 1028.0], [629.0, 1028.0], [629.0, 1164.0], [607.0, 1164.0]], [[578.0, 1025.0], [604.0, 1025.0], [604.0, 1120.0], [578.0, 1120.0]], [[551.0, 1025.0], [575.0, 1025.0], [571.0, 1165.0], [548.0, 1165.0]]], "lines": ["なんだったら", "もう一回", "見せようか？"]}, {"box": [451, 1071, 504, 1214], "vertical": true, "font_size": 24, "lines_coords": [[[482.0, 1076.0], [504.0, 1076.0], [504.0, 1214.0], [482.0, 1214.0]], [[451.0, 1071.0], [478.0, 1071.0], [478.0, 1156.0], [451.0, 1156.0]]], "lines": ["減るもんでも", "ないし。"]}, {"box": [142, 739, 266, 918], "vertical": true, "font_size": 33, "lines_coords": [[[232.0, 739.0], [265.0, 739.0], [265.0, 884.0], [232.0, 884.0]], [[187.0, 742.0], [220.0, 742.0], [220.0, 917.0], [187.0, 917.0]], [[142.0, 743.0], [175.0, 743.0], [175.0, 884.0], [142.0, 884.0]]], "lines": ["そこまで", "言わなくて", "いいよ！！"]}, {"box": [679, 1373, 731, 1522], "vertical": true, "font_size": 25, "lines_coords": [[[703.0, 1373.0], [731.0, 1373.0], [731.0, 1470.0], [703.0, 1470.0]], [[679.0, 1373.0], [701.0, 1373.0], [701.0, 1520.0], [679.0, 1520.0]]], "lines": ["いや～～～", "失礼しました。"]}], "img_path": "045.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [846, 106, 926, 240], "vertical": true, "font_size": 23, "lines_coords": [[[900.0, 106.0], [926.0, 106.0], [926.0, 223.0], [900.0, 223.0]], [[875.0, 109.0], [896.0, 109.0], [896.0, 240.0], [875.0, 240.0]], [[846.0, 107.0], [868.0, 107.0], [868.0, 206.0], [846.0, 206.0]]], "lines": ["．．．さすがに", "冗談に決まっ", "てんだろ"]}, {"box": [495, 129, 601, 301], "vertical": true, "font_size": 21, "lines_coords": [[[578.0, 131.0], [601.0, 131.0], [601.0, 204.0], [578.0, 204.0]], [[551.0, 129.0], [573.0, 129.0], [573.0, 301.0], [551.0, 301.0]], [[523.0, 131.0], [545.0, 131.0], [545.0, 292.0], [523.0, 292.0]], [[495.0, 129.0], [515.0, 129.0], [515.0, 292.0], [495.0, 292.0]]], "lines": ["うーむ", "むしろ三年我慢", "してたってのが", "驚愕だわー．．．"]}, {"box": [240, 118, 303, 251], "vertical": true, "font_size": 32, "lines_coords": [[[267.0, 118.0], [303.0, 118.0], [303.0, 181.0], [267.0, 181.0]], [[240.0, 123.0], [267.0, 123.0], [267.0, 251.0], [240.0, 251.0]]], "lines": ["よ！", "夢精王子！！"]}, {"box": [107, 282, 231, 456], "vertical": true, "font_size": 22, "lines_coords": [[[209.0, 282.0], [231.0, 282.0], [231.0, 389.0], [209.0, 389.0]], [[184.0, 284.0], [206.0, 284.0], [206.0, 407.0], [184.0, 407.0]], [[159.0, 284.0], [179.0, 284.0], [179.0, 448.0], [159.0, 448.0]], [[132.0, 284.0], [154.0, 284.0], [154.0, 456.0], [132.0, 456.0]], [[107.0, 282.0], [128.0, 282.0], [128.0, 428.0], [107.0, 428.0]]], "lines": ["どことなく", "妖精な感じは", "醸し出してたけど", "そんなにこじらせ", "てるとはね～～"]}, {"box": [445, 354, 540, 479], "vertical": true, "font_size": 21, "lines_coords": [[[523.0, 356.0], [540.0, 356.0], [540.0, 467.0], [523.0, 467.0]], [[496.0, 354.0], [518.0, 354.0], [517.0, 479.0], [495.0, 479.0]], [[471.0, 356.0], [492.0, 356.0], [492.0, 479.0], [471.0, 479.0]], [[448.0, 356.0], [470.0, 356.0], [467.0, 445.0], [445.0, 445.0]]], "lines": ["まぁ、あえて", "聞きませんよ", "どんな事情か", "ってのは。"]}, {"box": [98, 531, 151, 626], "vertical": true, "font_size": 22, "lines_coords": [[[129.0, 534.0], [151.0, 534.0], [151.0, 626.0], [129.0, 626.0]], [[98.0, 531.0], [126.0, 531.0], [126.0, 607.0], [98.0, 607.0]]], "lines": ["なるほど", "ね〜〜〜"]}, {"box": [890, 743, 970, 867], "vertical": true, "font_size": 22, "lines_coords": [[[943.0, 743.0], [970.0, 743.0], [970.0, 835.0], [943.0, 835.0]], [[917.0, 743.0], [939.0, 743.0], [939.0, 857.0], [917.0, 857.0]], [[890.0, 743.0], [910.0, 743.0], [910.0, 867.0], [890.0, 867.0]]], "lines": ["いやはや", "ありがたや", "ありがたや。"]}, {"box": [887, 743, 970, 869], "vertical": true, "font_size": 83, "lines_coords": [[[887.0, 743.0], [970.0, 743.0], [970.0, 869.0], [887.0, 869.0]]], "lines": ["いやはやあリがたやありがたわ。"]}, {"box": [815, 907, 893, 1101], "vertical": true, "font_size": 22, "lines_coords": [[[871.0, 909.0], [893.0, 909.0], [893.0, 1070.0], [871.0, 1070.0]], [[843.0, 909.0], [865.0, 909.0], [865.0, 1070.0], [843.0, 1070.0]], [[815.0, 907.0], [837.0, 907.0], [837.0, 1101.0], [815.0, 1101.0]]], "lines": ["あたしなんかで", "やってもらえる", "なんて光栄ですわ。"]}, {"box": [212, 914, 239, 1006], "vertical": true, "font_size": 25, "lines_coords": [[[212.0, 914.0], [239.0, 914.0], [239.0, 1006.0], [212.0, 1006.0]]], "lines": ["あはは。"]}, {"box": [142, 1068, 195, 1210], "vertical": true, "font_size": 25, "lines_coords": [[[168.0, 1068.0], [195.0, 1068.0], [192.0, 1210.0], [165.0, 1210.0]], [[142.0, 1071.0], [164.0, 1071.0], [164.0, 1209.0], [142.0, 1209.0]]], "lines": ["．．．あ、烏龍茶", "もー本飲む？"]}, {"box": [101, 1370, 154, 1527], "vertical": true, "font_size": 22, "lines_coords": [[[101.0, 1371.0], [123.0, 1371.0], [123.0, 1485.0], [101.0, 1485.0]]], "lines": ["ところで"]}], "img_path": "046.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [964, 89, 985, 243], "vertical": true, "font_size": 23, "lines_coords": [[[964.0, 89.0], [985.0, 89.0], [985.0, 243.0], [964.0, 243.0]]], "lines": ["．．．憶えてる？"]}, {"box": [868, 259, 948, 421], "vertical": true, "font_size": 23, "lines_coords": [[[921.0, 259.0], [948.0, 259.0], [948.0, 379.0], [921.0, 379.0]], [[893.0, 259.0], [917.0, 259.0], [918.0, 421.0], [895.0, 421.0]], [[868.0, 262.0], [890.0, 262.0], [890.0, 385.0], [868.0, 385.0]]], "lines": ["絵本の原作", "書いてくれって", "頼んだこと。"]}, {"box": [547, 216, 794, 407], "vertical": false, "font_size": 92, "lines_coords": [[[560.0, 220.0], [786.0, 210.0], [789.0, 310.0], [564.0, 319.0]], [[603.0, 309.0], [772.0, 296.0], [778.0, 394.0], [609.0, 407.0]]], "lines": ["ＤＲＡＷＡＳ", "ＢＬＯＯＫ"]}, {"box": [139, 687, 220, 862], "vertical": true, "font_size": 22, "lines_coords": [[[195.0, 689.0], [217.0, 689.0], [218.0, 829.0], [196.0, 829.0]], [[168.0, 690.0], [189.0, 690.0], [189.0, 853.0], [168.0, 853.0]], [[139.0, 687.0], [160.0, 687.0], [162.0, 860.0], [140.0, 860.0]]], "lines": ["あたしはもう", "書いてもらう気", "満々なのだけど。"]}, {"box": [539, 996, 619, 1181], "vertical": true, "font_size": 22, "lines_coords": [[[595.0, 998.0], [617.0, 998.0], [617.0, 1181.0], [595.0, 1181.0]], [[567.0, 998.0], [589.0, 998.0], [589.0, 1137.0], [567.0, 1137.0]], [[539.0, 996.0], [560.0, 996.0], [560.0, 1167.0], [539.0, 1167.0]]], "lines": ["．．．才能のある無し", "なんて、気に", "しなくていいし。"]}, {"box": [534, 1357, 575, 1439], "vertical": false, "font_size": 82, "lines_coords": [[[534.0, 1357.0], [575.0, 1357.0], [575.0, 1439.0], [534.0, 1439.0]]], "lines": ["無理"]}, {"box": [493, 1378, 534, 1471], "vertical": true, "font_size": 41, "lines_coords": [[[493.0, 1378.0], [534.0, 1378.0], [534.0, 1471.0], [493.0, 1471.0]]], "lines": ["無理"]}, {"box": [126, 1151, 206, 1314], "vertical": true, "font_size": 21, "lines_coords": [[[181.0, 1153.0], [203.0, 1153.0], [203.0, 1268.0], [181.0, 1268.0]], [[153.0, 1151.0], [175.0, 1151.0], [175.0, 1312.0], [153.0, 1312.0]], [[126.0, 1153.0], [146.0, 1153.0], [146.0, 1304.0], [126.0, 1304.0]]], "lines": ["君に興味が", "あるから書いて", "ほしいんだよ。"]}], "img_path": "047.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [889, 65, 970, 228], "vertical": true, "font_size": 25, "lines_coords": [[[948.0, 67.0], [968.0, 67.0], [968.0, 201.0], [948.0, 201.0]], [[915.0, 65.0], [943.0, 65.0], [943.0, 143.0], [915.0, 143.0]], [[889.0, 65.0], [915.0, 65.0], [915.0, 228.0], [889.0, 228.0]]], "lines": ["無理無理じゃ", "ねーよ、", "暇人のくせに！！"]}, {"box": [676, 82, 782, 243], "vertical": true, "font_size": 22, "lines_coords": [[[760.0, 82.0], [782.0, 82.0], [782.0, 242.0], [760.0, 242.0]], [[731.0, 82.0], [753.0, 82.0], [753.0, 198.0], [731.0, 198.0]], [[704.0, 82.0], [725.0, 82.0], [725.0, 242.0], [704.0, 242.0]], [[676.0, 82.0], [698.0, 82.0], [698.0, 243.0], [676.0, 243.0]]], "lines": ["こっちは社長に", "聞いたから", "住所も連絡先も", "押さえてんだ！！"]}, {"box": [573, 179, 651, 342], "vertical": true, "font_size": 22, "lines_coords": [[[629.0, 179.0], [651.0, 179.0], [651.0, 275.0], [629.0, 275.0]], [[600.0, 179.0], [623.0, 179.0], [625.0, 342.0], [601.0, 342.0]], [[573.0, 181.0], [595.0, 181.0], [595.0, 296.0], [573.0, 296.0]]], "lines": ["どのみち", "逃げられねーぞ", "この野郎！！"]}, {"box": [900, 706, 976, 853], "vertical": true, "font_size": 22, "lines_coords": [[[954.0, 706.0], [976.0, 706.0], [976.0, 843.0], [954.0, 843.0]], [[928.0, 706.0], [950.0, 706.0], [950.0, 843.0], [928.0, 843.0]], [[900.0, 706.0], [921.0, 706.0], [921.0, 853.0], [900.0, 853.0]]], "lines": ["君が真面目な", "人ってことは", "よくわかった。"]}, {"box": [146, 499, 170, 645], "vertical": true, "font_size": 22, "lines_coords": [[[146.0, 500.0], [168.0, 500.0], [168.0, 643.0], [146.0, 643.0]]], "lines": ["．．．小野寺くん。"]}, {"box": [823, 875, 903, 1035], "vertical": true, "font_size": 22, "lines_coords": [[[876.0, 875.0], [903.0, 875.0], [903.0, 1017.0], [876.0, 1017.0]], [[848.0, 876.0], [871.0, 876.0], [873.0, 1035.0], [850.0, 1035.0]], [[823.0, 876.0], [843.0, 876.0], [843.0, 1035.0], [823.0, 1035.0]]], "lines": ["けど、一人で", "いじけてたって", "仕方なくない？"]}, {"box": [221, 785, 300, 960], "vertical": true, "font_size": 23, "lines_coords": [[[273.0, 785.0], [300.0, 785.0], [300.0, 882.0], [273.0, 882.0]], [[250.0, 787.0], [271.0, 787.0], [271.0, 960.0], [250.0, 960.0]], [[221.0, 789.0], [243.0, 789.0], [243.0, 909.0], [221.0, 909.0]]], "lines": ["君が何に", "こだわってるのか", "知らないし、"]}, {"box": [139, 1000, 246, 1182], "vertical": true, "font_size": 23, "lines_coords": [[[225.0, 1004.0], [246.0, 1004.0], [246.0, 1139.0], [225.0, 1139.0]], [[196.0, 1001.0], [218.0, 1001.0], [218.0, 1182.0], [196.0, 1182.0]], [[167.0, 1000.0], [193.0, 1000.0], [189.0, 1162.0], [162.0, 1162.0]], [[139.0, 1000.0], [160.0, 1000.0], [162.0, 1126.0], [140.0, 1126.0]]], "lines": ["人きりなら", "他人を傷つけない", "ってのも確かに", "わかるけど。"]}, {"box": [873, 1273, 951, 1456], "vertical": true, "font_size": 24, "lines_coords": [[[929.0, 1276.0], [951.0, 1276.0], [951.0, 1410.0], [929.0, 1410.0]], [[901.0, 1275.0], [923.0, 1275.0], [923.0, 1456.0], [901.0, 1456.0]], [[873.0, 1273.0], [895.0, 1273.0], [895.0, 1440.0], [873.0, 1440.0]]], "lines": ["一人で生きて", "いけるほど世の中", "単純じゃないし、"]}, {"box": [746, 1370, 831, 1510], "vertical": true, "font_size": 24, "lines_coords": [[[796.0, 1370.0], [831.0, 1370.0], [831.0, 1421.0], [796.0, 1421.0]], [[773.0, 1373.0], [795.0, 1373.0], [795.0, 1510.0], [773.0, 1510.0]], [[746.0, 1371.0], [768.0, 1371.0], [768.0, 1473.0], [746.0, 1473.0]]], "lines": ["第一", "君はそんなに", "強くない。"]}, {"box": [120, 1404, 145, 1533], "vertical": true, "font_size": 20, "lines_coords": [[[120.0, 1406.0], [140.0, 1406.0], [140.0, 1531.0], [120.0, 1531.0]]], "lines": ["．．．ちがう？"]}], "img_path": "048.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [445, 92, 467, 175], "vertical": true, "font_size": 22, "lines_coords": [[[445.0, 92.0], [467.0, 92.0], [467.0, 175.0], [445.0, 175.0]]], "lines": ["ふぬけ！！"]}, {"box": [217, 365, 245, 434], "vertical": true, "font_size": 28, "lines_coords": [[[217.0, 365.0], [245.0, 365.0], [245.0, 434.0], [217.0, 434.0]]], "lines": ["正解！！"]}, {"box": [494, 904, 620, 1086], "vertical": true, "font_size": 24, "lines_coords": [[[590.0, 904.0], [618.0, 904.0], [618.0, 996.0], [590.0, 996.0]], [[560.0, 906.0], [582.0, 906.0], [582.0, 1032.0], [560.0, 1032.0]], [[529.0, 906.0], [551.0, 906.0], [551.0, 1082.0], [529.0, 1082.0]], [[495.0, 904.0], [521.0, 904.0], [521.0, 1050.0], [495.0, 1050.0]]], "lines": ["「．．．僕は", "やらなきゃ", "ならないことが", "あるんで。」"]}, {"box": [182, 1170, 234, 1332], "vertical": true, "font_size": 22, "lines_coords": [[[210.0, 1171.0], [232.0, 1171.0], [232.0, 1284.0], [210.0, 1284.0]], [[182.0, 1170.0], [204.0, 1170.0], [204.0, 1331.0], [182.0, 1331.0]]], "lines": ["やんなきゃ", "ならないこと？"]}], "img_path": "049.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [501, 81, 623, 314], "vertical": true, "font_size": 25, "lines_coords": [[[596.0, 81.0], [623.0, 81.0], [623.0, 181.0], [596.0, 181.0]], [[565.0, 81.0], [592.0, 81.0], [590.0, 312.0], [564.0, 312.0]], [[531.0, 82.0], [557.0, 82.0], [557.0, 285.0], [531.0, 285.0]], [[501.0, 84.0], [521.0, 84.0], [521.0, 271.0], [501.0, 271.0]]], "lines": ["「．．．．．．昔、", "好きだった女の子と", "決着をつけなきゃ", "ならんのです。」"]}, {"box": [379, 81, 406, 185], "vertical": true, "font_size": 27, "lines_coords": [[[379.0, 81.0], [406.0, 81.0], [406.0, 185.0], [379.0, 185.0]]], "lines": ["．．．決着？"]}, {"box": [126, 325, 185, 456], "vertical": true, "font_size": 24, "lines_coords": [[[160.0, 326.0], [182.0, 326.0], [182.0, 456.0], [160.0, 456.0]], [[126.0, 325.0], [153.0, 325.0], [153.0, 432.0], [126.0, 432.0]]], "lines": ["．．．告白ても", "すんの？"]}, {"box": [948, 973, 973, 1006], "vertical": true, "font_size": 22, "lines_coords": [[[948.0, 973.0], [973.0, 973.0], [973.0, 1006.0], [948.0, 1006.0]]], "lines": ["ん"]}, {"box": [881, 1079, 929, 1242], "vertical": true, "font_size": 22, "lines_coords": [[[907.0, 1079.0], [929.0, 1079.0], [929.0, 1242.0], [907.0, 1242.0]], [[881.0, 1081.0], [901.0, 1081.0], [901.0, 1242.0], [881.0, 1242.0]]], "lines": ["単に諦めがつか", "ないってだけ？"]}, {"box": [689, 711, 750, 901], "vertical": true, "font_size": 61, "lines_coords": [[[689.0, 711.0], [750.0, 711.0], [750.0, 901.0], [689.0, 901.0]]], "lines": ["「そういう訳じゃないですけど．．．"]}, {"box": [690, 714, 748, 900], "vertical": true, "font_size": 26, "lines_coords": [[[726.0, 714.0], [748.0, 714.0], [748.0, 900.0], [726.0, 900.0]], [[690.0, 714.0], [717.0, 714.0], [717.0, 892.0], [690.0, 892.0]]], "lines": ["「そういう訳じゃ", "ないですけど．．．"]}, {"box": [526, 712, 654, 925], "vertical": true, "font_size": 26, "lines_coords": [[[626.0, 712.0], [654.0, 712.0], [654.0, 825.0], [626.0, 825.0]], [[596.0, 714.0], [618.0, 714.0], [618.0, 917.0], [596.0, 917.0]], [[562.0, 712.0], [589.0, 712.0], [589.0, 840.0], [562.0, 840.0]], [[526.0, 712.0], [554.0, 712.0], [556.0, 925.0], [528.0, 925.0]]], "lines": ["．．．．．．でも、", "とにかくもう一度", "会わなきゃ", "いけない気がして、"]}, {"box": [370, 709, 490, 920], "vertical": true, "font_size": 26, "lines_coords": [[[467.0, 714.0], [490.0, 714.0], [489.0, 865.0], [465.0, 865.0]], [[435.0, 714.0], [457.0, 714.0], [457.0, 868.0], [435.0, 868.0]], [[396.0, 709.0], [428.0, 709.0], [431.0, 920.0], [400.0, 920.0]], [[370.0, 710.0], [396.0, 710.0], [396.0, 893.0], [370.0, 893.0]]], "lines": ["今日みたいに", "街を毎日毎日", "捜し回っているん", "ですね、僕ァ。」"]}, {"box": [564, 1007, 618, 1150], "vertical": true, "font_size": 24, "lines_coords": [[[589.0, 1007.0], [615.0, 1007.0], [618.0, 1150.0], [592.0, 1150.0]], [[564.0, 1009.0], [590.0, 1009.0], [590.0, 1109.0], [564.0, 1109.0]]], "lines": ["そんな効率の", "悪いこと、"]}, {"box": [789, 1368, 821, 1490], "vertical": true, "font_size": 28, "lines_coords": [[[789.0, 1370.0], [817.0, 1368.0], [821.0, 1489.0], [793.0, 1490.0]]], "lines": ["「．．．二年後"]}, {"box": [470, 1126, 550, 1300], "vertical": true, "font_size": 24, "lines_coords": [[[528.0, 1126.0], [550.0, 1126.0], [550.0, 1245.0], [528.0, 1245.0]], [[496.0, 1126.0], [520.0, 1126.0], [523.0, 1267.0], [500.0, 1267.0]], [[470.0, 1128.0], [492.0, 1128.0], [495.0, 1300.0], [473.0, 1300.0]]], "lines": ["いつまでも", "続ける訳には", "いかないっしょ。"]}, {"box": [629, 1370, 753, 1546], "vertical": true, "font_size": 28, "lines_coords": [[[731.0, 1371.0], [753.0, 1371.0], [753.0, 1546.0], [731.0, 1546.0]], [[696.0, 1370.0], [723.0, 1370.0], [723.0, 1500.0], [696.0, 1500.0]], [[664.0, 1370.0], [690.0, 1370.0], [690.0, 1525.0], [664.0, 1525.0]], [[629.0, 1370.0], [664.0, 1370.0], [664.0, 1467.0], [629.0, 1467.0]]], "lines": ["今のアハートの", "契約期間が", "終わるまでは", "一応。」"]}, {"box": [75, 1367, 154, 1508], "vertical": true, "font_size": 24, "lines_coords": [[[131.0, 1370.0], [153.0, 1370.0], [153.0, 1507.0], [131.0, 1507.0]], [[100.0, 1367.0], [128.0, 1367.0], [128.0, 1465.0], [100.0, 1465.0]], [[75.0, 1370.0], [96.0, 1370.0], [96.0, 1507.0], [75.0, 1507.0]]], "lines": ["．．．それまでに", "見つから", "なかったら？"]}], "img_path": "050.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [884, 973, 912, 1078], "vertical": true, "font_size": 26, "lines_coords": [[[884.0, 973.0], [912.0, 973.0], [912.0, 1078.0], [884.0, 1078.0]]], "lines": ["．．．ふうん。"]}, {"box": [793, 1029, 845, 1148], "vertical": true, "font_size": 26, "lines_coords": [[[818.0, 1029.0], [845.0, 1029.0], [845.0, 1126.0], [818.0, 1126.0]], [[793.0, 1032.0], [815.0, 1032.0], [815.0, 1148.0], [793.0, 1148.0]]], "lines": ["だんまり", "ですか．．．"]}, {"box": [962, 1234, 1015, 1373], "vertical": true, "font_size": 23, "lines_coords": [[[992.0, 1234.0], [1015.0, 1234.0], [1012.0, 1373.0], [989.0, 1373.0]], [[962.0, 1235.0], [989.0, 1235.0], [989.0, 1335.0], [962.0, 1335.0]]], "lines": ["．．．その女の子", "ってさぁ、"]}, {"box": [853, 1350, 932, 1512], "vertical": true, "font_size": 23, "lines_coords": [[[910.0, 1351.0], [932.0, 1351.0], [932.0, 1489.0], [910.0, 1489.0]], [[881.0, 1351.0], [903.0, 1351.0], [903.0, 1512.0], [881.0, 1512.0]], [[853.0, 1350.0], [875.0, 1350.0], [876.0, 1490.0], [854.0, 1490.0]]], "lines": ["小野寺くんの", "昔の同級生とか", "なんでしょ？"]}, {"box": [142, 1310, 250, 1551], "vertical": true, "font_size": 23, "lines_coords": [[[226.0, 1312.0], [246.0, 1312.0], [246.0, 1518.0], [226.0, 1518.0]], [[196.0, 1310.0], [223.0, 1310.0], [223.0, 1551.0], [196.0, 1551.0]], [[170.0, 1314.0], [192.0, 1314.0], [192.0, 1540.0], [170.0, 1540.0]], [[142.0, 1314.0], [164.0, 1314.0], [164.0, 1496.0], [142.0, 1496.0]]], "lines": ["当時の名簿見るなり", "他の同級生辿るなりで、", "いくらでも連絡くらい", "つくはずだけど？"]}], "img_path": "051.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [910, 92, 939, 175], "vertical": true, "font_size": 29, "lines_coords": [[[910.0, 92.0], [939.0, 92.0], [939.0, 175.0], [910.0, 175.0]]], "lines": ["．．．君さ、"]}, {"box": [146, 101, 255, 265], "vertical": true, "font_size": 22, "lines_coords": [[[231.0, 103.0], [253.0, 103.0], [253.0, 220.0], [231.0, 220.0]], [[203.0, 103.0], [225.0, 103.0], [225.0, 240.0], [203.0, 240.0]], [[175.0, 101.0], [196.0, 101.0], [196.0, 265.0], [175.0, 265.0]], [[146.0, 101.0], [168.0, 101.0], [168.0, 217.0], [146.0, 217.0]]], "lines": ["本当は内心", "その女の子に", "会いたくないん", "じゃない？"]}, {"box": [842, 384, 946, 548], "vertical": true, "font_size": 21, "lines_coords": [[[925.0, 384.0], [946.0, 384.0], [945.0, 525.0], [923.0, 525.0]], [[896.0, 385.0], [918.0, 385.0], [918.0, 548.0], [896.0, 548.0]], [[868.0, 385.0], [889.0, 385.0], [889.0, 525.0], [868.0, 525.0]], [[842.0, 385.0], [862.0, 385.0], [862.0, 509.0], [842.0, 509.0]]], "lines": ["君はその子に", "運命的な再会を", "期待してるん", "だろうけど、"]}, {"box": [739, 529, 817, 670], "vertical": true, "font_size": 21, "lines_coords": [[[796.0, 531.0], [817.0, 531.0], [817.0, 670.0], [796.0, 670.0]], [[767.0, 531.0], [789.0, 531.0], [789.0, 670.0], [767.0, 670.0]], [[739.0, 529.0], [760.0, 529.0], [760.0, 623.0], [739.0, 623.0]]], "lines": ["そんなもんに", "なんの意味が", "あるの？"]}, {"box": [256, 396, 304, 510], "vertical": true, "font_size": 21, "lines_coords": [[[282.0, 396.0], [304.0, 396.0], [304.0, 510.0], [282.0, 510.0]], [[256.0, 396.0], [278.0, 396.0], [278.0, 492.0], [256.0, 492.0]]], "lines": ["あたしには", "ただ単に"]}, {"box": [137, 492, 214, 700], "vertical": true, "font_size": 21, "lines_coords": [[[192.0, 492.0], [214.0, 492.0], [214.0, 700.0], [192.0, 700.0]], [[164.0, 495.0], [185.0, 495.0], [185.0, 656.0], [164.0, 656.0]], [[137.0, 493.0], [157.0, 493.0], [157.0, 687.0], [137.0, 687.0]]], "lines": ["結論を先送りにする", "言い逃れにしか", "思えないんだけど。"]}, {"box": [867, 775, 943, 960], "vertical": true, "font_size": 21, "lines_coords": [[[923.0, 776.0], [943.0, 776.0], [943.0, 951.0], [923.0, 951.0]], [[895.0, 775.0], [917.0, 775.0], [917.0, 960.0], [895.0, 960.0]], [[867.0, 775.0], [889.0, 775.0], [889.0, 870.0], [867.0, 870.0]]], "lines": ["あたしの予想だと", "君の言う二年後は", "もちろん"]}, {"box": [740, 882, 843, 1068], "vertical": true, "font_size": 21, "lines_coords": [[[821.0, 882.0], [843.0, 882.0], [843.0, 1023.0], [821.0, 1023.0]], [[793.0, 884.0], [815.0, 884.0], [815.0, 1000.0], [793.0, 1000.0]], [[765.0, 884.0], [787.0, 884.0], [787.0, 1068.0], [765.0, 1068.0]], [[740.0, 885.0], [757.0, 885.0], [757.0, 985.0], [740.0, 985.0]]], "lines": ["十年後も君は", "同じように", "言い訳を探してる", "と思うな。"]}, {"box": [293, 792, 343, 964], "vertical": true, "font_size": 22, "lines_coords": [[[321.0, 795.0], [343.0, 795.0], [343.0, 964.0], [321.0, 964.0]], [[293.0, 792.0], [314.0, 792.0], [314.0, 934.0], [293.0, 934.0]]], "lines": ["一見苦悩してる", "ように見せて、"]}, {"box": [121, 889, 256, 1092], "vertical": true, "font_size": 22, "lines_coords": [[[234.0, 893.0], [256.0, 893.0], [256.0, 1032.0], [234.0, 1032.0]], [[206.0, 893.0], [228.0, 893.0], [228.0, 1031.0], [206.0, 1031.0]], [[175.0, 889.0], [201.0, 889.0], [201.0, 1064.0], [175.0, 1064.0]], [[150.0, 892.0], [171.0, 892.0], [171.0, 1092.0], [150.0, 1092.0]], [[121.0, 893.0], [143.0, 893.0], [143.0, 1017.0], [121.0, 1017.0]]], "lines": ["実はなんにも", "考えてないし", "行動もできない、", "不毛な人生を送るん", "てしょうよ。"]}, {"box": [917, 1150, 967, 1312], "vertical": true, "font_size": 22, "lines_coords": [[[943.0, 1150.0], [967.0, 1150.0], [965.0, 1312.0], [942.0, 1312.0]], [[917.0, 1151.0], [939.0, 1151.0], [939.0, 1270.0], [917.0, 1270.0]]], "lines": ["．．．いや別に構わ", "ないけどね"]}, {"box": [812, 1290, 892, 1507], "vertical": true, "font_size": 22, "lines_coords": [[[870.0, 1290.0], [892.0, 1290.0], [892.0, 1434.0], [870.0, 1434.0]], [[842.0, 1290.0], [864.0, 1290.0], [864.0, 1507.0], [842.0, 1507.0]], [[812.0, 1290.0], [834.0, 1290.0], [834.0, 1462.0], [812.0, 1462.0]]], "lines": ["沢山いるもん", "そういう絶望ごっこで", "満たされてる人。"]}, {"box": [235, 1171, 314, 1340], "vertical": true, "font_size": 22, "lines_coords": [[[292.0, 1171.0], [314.0, 1171.0], [314.0, 1296.0], [292.0, 1296.0]], [[264.0, 1171.0], [285.0, 1171.0], [285.0, 1309.0], [264.0, 1309.0]], [[235.0, 1171.0], [256.0, 1171.0], [256.0, 1340.0], [235.0, 1340.0]]], "lines": ["．．．ても、君の", "その絶望って", "無駄だと思うよ。"]}, {"box": [101, 1318, 209, 1517], "vertical": true, "font_size": 22, "lines_coords": [[[187.0, 1318.0], [209.0, 1318.0], [209.0, 1517.0], [187.0, 1517.0]], [[159.0, 1321.0], [181.0, 1321.0], [181.0, 1509.0], [159.0, 1509.0]], [[129.0, 1320.0], [151.0, 1320.0], [151.0, 1507.0], [129.0, 1507.0]], [[101.0, 1320.0], [123.0, 1320.0], [123.0, 1515.0], [101.0, 1515.0]]], "lines": ["．．．なんでって、君は", "孤独を望んでいて、", "その絶望を誰とも", "共有できない訳で。"]}], "img_path": "052.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [907, 92, 964, 218], "vertical": true, "font_size": 23, "lines_coords": [[[937.0, 92.0], [964.0, 92.0], [964.0, 212.0], [937.0, 212.0]], [[910.0, 92.0], [934.0, 92.0], [931.0, 218.0], [907.0, 218.0]]], "lines": ["．．．いいかな", "小野寺くん"]}, {"box": [756, 134, 864, 321], "vertical": true, "font_size": 23, "lines_coords": [[[842.0, 137.0], [864.0, 137.0], [864.0, 310.0], [842.0, 310.0]], [[812.0, 134.0], [834.0, 134.0], [835.0, 301.0], [814.0, 301.0]], [[785.0, 135.0], [807.0, 135.0], [807.0, 321.0], [785.0, 321.0]], [[756.0, 135.0], [778.0, 135.0], [779.0, 281.0], [757.0, 281.0]]], "lines": ["例えばあたしと", "再会したことも", "運命のひとつだと", "思うんだけど、"]}, {"box": [950, 696, 971, 835], "vertical": true, "font_size": 23, "lines_coords": [[[950.0, 696.0], [971.0, 696.0], [971.0, 835.0], [950.0, 835.0]]], "lines": ["．．．どうする？"]}, {"box": [576, 428, 713, 635], "vertical": true, "font_size": 22, "lines_coords": [[[689.0, 429.0], [710.0, 429.0], [710.0, 568.0], [689.0, 568.0]], [[660.0, 428.0], [682.0, 428.0], [682.0, 634.0], [660.0, 634.0]], [[632.0, 429.0], [654.0, 429.0], [654.0, 617.0], [632.0, 617.0]], [[604.0, 429.0], [625.0, 429.0], [625.0, 570.0], [604.0, 570.0]], [[576.0, 429.0], [598.0, 429.0], [598.0, 532.0], [576.0, 532.0]]], "lines": ["この出来事を", "単なる偶然ととるか", "運命と考えるかは", "君の意思次第", "なんだな。"]}, {"box": [800, 814, 906, 956], "vertical": true, "font_size": 23, "lines_coords": [[[879.0, 814.0], [906.0, 814.0], [906.0, 910.0], [879.0, 910.0]], [[854.0, 817.0], [876.0, 817.0], [876.0, 934.0], [854.0, 934.0]], [[826.0, 818.0], [848.0, 818.0], [848.0, 934.0], [826.0, 934.0]], [[800.0, 817.0], [821.0, 817.0], [821.0, 956.0], [800.0, 956.0]]], "lines": ["あたしが", "その女の子", "捜し出して", "あげようか？"]}, {"box": [162, 825, 271, 1011], "vertical": true, "font_size": 24, "lines_coords": [[[245.0, 826.0], [271.0, 826.0], [271.0, 923.0], [245.0, 923.0]], [[214.0, 825.0], [240.0, 825.0], [240.0, 967.0], [214.0, 967.0]], [[187.0, 825.0], [209.0, 825.0], [209.0, 1010.0], [187.0, 1010.0]], [[162.0, 825.0], [182.0, 825.0], [182.0, 973.0], [162.0, 973.0]]], "lines": ["君の言う", "決着ってのが", "どんなもんなのか", "見てみたいわ。"]}, {"box": [887, 1246, 968, 1419], "vertical": true, "font_size": 22, "lines_coords": [[[945.0, 1250.0], [967.0, 1250.0], [967.0, 1389.0], [945.0, 1389.0]], [[917.0, 1248.0], [939.0, 1248.0], [939.0, 1389.0], [917.0, 1389.0]], [[887.0, 1246.0], [909.0, 1246.0], [912.0, 1415.0], [890.0, 1415.0]]], "lines": ["そんな些細な", "思い出なんて", "片付けちゃって、"]}, {"box": [159, 1301, 267, 1509], "vertical": true, "font_size": 22, "lines_coords": [[[242.0, 1301.0], [264.0, 1301.0], [264.0, 1509.0], [242.0, 1509.0]], [[215.0, 1301.0], [237.0, 1301.0], [237.0, 1442.0], [215.0, 1442.0]], [[187.0, 1301.0], [209.0, 1301.0], [209.0, 1487.0], [187.0, 1487.0]], [[159.0, 1301.0], [181.0, 1301.0], [181.0, 1440.0], [159.0, 1440.0]]], "lines": ["新しい明日のために", "賢く頭使って", "おもしろおかしく", "暮らしたら？"]}], "img_path": "053.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [934, 350, 960, 442], "vertical": true, "font_size": 26, "lines_coords": [[[934.0, 350.0], [960.0, 350.0], [960.0, 442.0], [934.0, 442.0]]], "lines": ["．．．ほら。"]}, {"box": [509, 63, 569, 208], "vertical": true, "font_size": 26, "lines_coords": [[[542.0, 65.0], [568.0, 65.0], [568.0, 179.0], [542.0, 179.0]], [[509.0, 65.0], [535.0, 65.0], [535.0, 206.0], [509.0, 206.0]]], "lines": ["「：やめて", "ください。」"]}, {"box": [134, 481, 191, 646], "vertical": true, "font_size": 24, "lines_coords": [[[164.0, 481.0], [190.0, 481.0], [190.0, 634.0], [164.0, 634.0]], [[134.0, 484.0], [156.0, 484.0], [156.0, 645.0], [134.0, 645.0]]], "lines": ["その女の子の", "名前教えてよ。"]}, {"box": [320, 784, 409, 939], "vertical": true, "font_size": 25, "lines_coords": [[[381.0, 784.0], [407.0, 784.0], [407.0, 889.0], [381.0, 889.0]], [[350.0, 784.0], [376.0, 784.0], [376.0, 939.0], [350.0, 939.0]], [[320.0, 785.0], [342.0, 785.0], [342.0, 921.0], [320.0, 921.0]]], "lines": ["あたしが", "３日で連れて", "きてあげる"]}], "img_path": "054.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [873, 137, 984, 435], "vertical": true, "font_size": 54, "lines_coords": [[[929.0, 137.0], [984.0, 137.0], [984.0, 342.0], [929.0, 342.0]], [[873.0, 139.0], [926.0, 139.0], [926.0, 435.0], [873.0, 435.0]]], "lines": ["だったら", "今すぐ死ね！！"]}], "img_path": "055.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [647, 1017, 673, 1257], "vertical": true, "font_size": 20, "lines_coords": [[[650.0, 1021.0], [670.0, 1021.0], [670.0, 1248.0], [650.0, 1248.0]]], "lines": ["「．．．僕、帰ります。」"]}, {"box": [318, 900, 393, 979], "vertical": true, "font_size": 35, "lines_coords": [[[353.0, 904.0], [393.0, 904.0], [393.0, 979.0], [353.0, 979.0]], [[318.0, 904.0], [362.0, 900.0], [370.0, 970.0], [326.0, 975.0]]], "lines": ["．．．あ", "コレ、"]}, {"box": [237, 1010, 296, 1117], "vertical": true, "font_size": 35, "lines_coords": [[[268.0, 1010.0], [296.0, 1010.0], [296.0, 1117.0], [268.0, 1117.0]], [[237.0, 1010.0], [264.0, 1010.0], [264.0, 1100.0], [237.0, 1100.0]]], "lines": ["あたしの", "連絡先。"]}, {"box": [81, 1353, 171, 1510], "vertical": true, "font_size": 25, "lines_coords": [[[145.0, 1353.0], [171.0, 1353.0], [168.0, 1510.0], [142.0, 1510.0]], [[109.0, 1356.0], [135.0, 1356.0], [135.0, 1462.0], [109.0, 1462.0]], [[82.0, 1356.0], [104.0, 1356.0], [104.0, 1493.0], [82.0, 1493.0]]], "lines": ["ちょっとでも", "書けたら", "読ませてよ。"]}], "img_path": "056.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [837, 1144, 893, 1346], "vertical": true, "font_size": 21, "lines_coords": [[[868.0, 1148.0], [889.0, 1148.0], [889.0, 1337.0], [868.0, 1337.0]], [[839.0, 1148.0], [860.0, 1148.0], [860.0, 1234.0], [839.0, 1234.0]]], "lines": ["．．．書きませんよ", "僕は。"]}, {"box": [150, 1156, 207, 1295], "vertical": true, "font_size": 24, "lines_coords": [[[179.0, 1156.0], [206.0, 1156.0], [206.0, 1284.0], [179.0, 1284.0]], [[150.0, 1156.0], [171.0, 1156.0], [171.0, 1292.0], [150.0, 1292.0]]], "lines": ["：楽しみに", "してるから"]}], "img_path": "057.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [517, 65, 579, 210], "vertical": true, "font_size": 25, "lines_coords": [[[553.0, 68.0], [575.0, 68.0], [575.0, 204.0], [553.0, 204.0]], [[517.0, 65.0], [545.0, 65.0], [546.0, 181.0], [518.0, 181.0]]], "lines": ["「．．．強引な人", "ですね。」"]}, {"box": [928, 1015, 946, 1132], "vertical": true, "font_size": 17, "lines_coords": [[[928.0, 1015.0], [945.0, 1015.0], [945.0, 1131.0], [928.0, 1131.0]]], "lines": ["．．．小野寺くん。"]}, {"box": [400, 1051, 445, 1151], "vertical": true, "font_size": 22, "lines_coords": [[[423.0, 1051.0], [445.0, 1051.0], [445.0, 1132.0], [423.0, 1132.0]], [[400.0, 1053.0], [421.0, 1053.0], [421.0, 1151.0], [400.0, 1151.0]]], "lines": ["．．．なんか", "怒ってる？"]}], "img_path": "058.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [868, 120, 890, 201], "vertical": true, "font_size": 22, "lines_coords": [[[868.0, 120.0], [890.0, 120.0], [890.0, 200.0], [868.0, 200.0]]], "lines": ["ビビヒビ"]}, {"box": [689, 228, 710, 309], "vertical": true, "font_size": 21, "lines_coords": [[[689.0, 228.0], [710.0, 228.0], [710.0, 309.0], [689.0, 309.0]]], "lines": ["ピピヒピ"]}, {"box": [229, 239, 248, 312], "vertical": true, "font_size": 17, "lines_coords": [[[229.0, 239.0], [246.0, 239.0], [246.0, 312.0], [229.0, 312.0]]], "lines": ["ヒヒヒピ"]}, {"box": [390, 415, 407, 486], "vertical": true, "font_size": 17, "lines_coords": [[[390.0, 415.0], [407.0, 415.0], [407.0, 485.0], [390.0, 485.0]]], "lines": ["ビビヒビ"]}, {"box": [225, 640, 292, 665], "vertical": false, "font_size": 22, "lines_coords": [[[225.0, 643.0], [290.0, 640.0], [292.0, 662.0], [226.0, 665.0]]], "lines": ["．．．"]}, {"box": [939, 801, 960, 880], "vertical": true, "font_size": 21, "lines_coords": [[[939.0, 801.0], [960.0, 801.0], [960.0, 879.0], [939.0, 879.0]]], "lines": ["ピビピピ"]}, {"box": [173, 918, 192, 998], "vertical": true, "font_size": 17, "lines_coords": [[[173.0, 918.0], [190.0, 918.0], [190.0, 995.0], [173.0, 995.0]]], "lines": ["ビビビヒ"]}], "img_path": "059.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [329, 539, 493, 592], "vertical": false, "font_size": 26.5, "lines_coords": [[[329.0, 539.0], [493.0, 539.0], [493.0, 565.0], [329.0, 565.0]], [[335.0, 565.0], [490.0, 565.0], [490.0, 592.0], [335.0, 592.0]]], "lines": ["宿．．．あ、１０月", "ＦＸ、Ｋ２"]}], "img_path": "060.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [400, 382, 464, 513], "vertical": true, "font_size": 30, "lines_coords": [[[435.0, 385.0], [462.0, 385.0], [462.0, 512.0], [435.0, 512.0]], [[400.0, 382.0], [434.0, 382.0], [434.0, 470.0], [400.0, 470.0]]], "lines": ["フンフンは", "その日、"]}, {"box": [231, 382, 327, 565], "vertical": true, "font_size": 27, "lines_coords": [[[298.0, 389.0], [325.0, 389.0], [325.0, 564.0], [298.0, 564.0]], [[268.0, 387.0], [290.0, 387.0], [290.0, 539.0], [268.0, 539.0]], [[231.0, 382.0], [264.0, 382.0], [264.0, 475.0], [231.0, 475.0]]], "lines": ["一歩も部屋から", "出られません", "でした。"]}, {"box": [584, 1355, 644, 1494], "vertical": true, "font_size": 27, "lines_coords": [[[615.0, 1356.0], [643.0, 1356.0], [643.0, 1459.0], [615.0, 1459.0]], [[584.0, 1356.0], [610.0, 1356.0], [610.0, 1490.0], [584.0, 1490.0]]], "lines": ["なんだか", "不快でした。"]}, {"box": [393, 1354, 516, 1495], "vertical": true, "font_size": 27, "lines_coords": [[[487.0, 1356.0], [515.0, 1356.0], [515.0, 1457.0], [487.0, 1457.0]], [[456.0, 1354.0], [484.0, 1354.0], [484.0, 1459.0], [456.0, 1459.0]], [[425.0, 1354.0], [451.0, 1354.0], [451.0, 1459.0], [425.0, 1459.0]], [[393.0, 1356.0], [420.0, 1356.0], [420.0, 1492.0], [393.0, 1492.0]]], "lines": ["なんだか", "とっても", "とっても", "不快でした。"]}], "img_path": "061.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [932, 126, 973, 203], "vertical": false, "font_size": 19, "lines_coords": [[[932.0, 196.0], [956.0, 126.0], [973.0, 132.0], [950.0, 203.0]]], "lines": ["これにより"]}, {"box": [484, 107, 614, 267], "vertical": true, "font_size": 31, "lines_coords": [[[579.0, 107.0], [614.0, 107.0], [614.0, 192.0], [579.0, 192.0]], [[551.0, 110.0], [578.0, 110.0], [578.0, 253.0], [551.0, 253.0]], [[518.0, 110.0], [545.0, 110.0], [545.0, 267.0], [518.0, 267.0]], [[484.0, 109.0], [518.0, 109.0], [518.0, 178.0], [484.0, 178.0]]], "lines": ["．．．俺は", "数学講師だ。", "絶対を愛して", "いる。"]}, {"box": [23, 290, 70, 453], "vertical": true, "font_size": 45, "lines_coords": [[[23.0, 290.0], [68.0, 290.0], [68.0, 453.0], [23.0, 453.0]]], "lines": ["第８２話"]}, {"box": [860, 387, 967, 571], "vertical": true, "font_size": 22, "lines_coords": [[[945.0, 387.0], [967.0, 387.0], [967.0, 551.0], [945.0, 551.0]], [[917.0, 387.0], [939.0, 387.0], [939.0, 528.0], [917.0, 528.0]], [[887.0, 387.0], [909.0, 387.0], [909.0, 571.0], [887.0, 571.0]], [[860.0, 387.0], [882.0, 387.0], [882.0, 510.0], [860.0, 510.0]]], "lines": ["俺は学生の時分、", "文系と芸術と", "オカルトの奴らが", "嫌いだった"]}, {"box": [829, 642, 937, 828], "vertical": true, "font_size": 22, "lines_coords": [[[915.0, 643.0], [937.0, 643.0], [937.0, 828.0], [915.0, 828.0]], [[889.0, 643.0], [909.0, 643.0], [909.0, 807.0], [889.0, 807.0]], [[859.0, 642.0], [882.0, 642.0], [881.0, 806.0], [857.0, 806.0]], [[829.0, 645.0], [851.0, 645.0], [851.0, 810.0], [829.0, 810.0]]], "lines": ["人が作った曖昧で", "貧弱で刹那的な", "価値観なんかに", "興味は無かった"]}, {"box": [271, 404, 409, 612], "vertical": true, "font_size": 23, "lines_coords": [[[384.0, 407.0], [406.0, 407.0], [406.0, 596.0], [384.0, 596.0]], [[353.0, 404.0], [379.0, 404.0], [379.0, 570.0], [353.0, 570.0]], [[328.0, 406.0], [350.0, 406.0], [350.0, 612.0], [328.0, 612.0]], [[300.0, 406.0], [321.0, 406.0], [321.0, 567.0], [300.0, 567.0]], [[271.0, 407.0], [293.0, 407.0], [293.0, 504.0], [271.0, 504.0]]], "lines": ["だが数学は絶対だ。", "数式ほど完璧で", "エキサイティングな", "ものを俺は他に", "知らない"]}, {"box": [920, 1141, 989, 1246], "vertical": true, "font_size": 28, "lines_coords": [[[951.0, 1142.0], [979.0, 1142.0], [979.0, 1246.0], [951.0, 1246.0]], [[920.0, 1142.0], [948.0, 1142.0], [948.0, 1246.0], [920.0, 1246.0]]], "lines": ["俺は頑な", "だった．．．"]}, {"box": [153, 873, 261, 1069], "vertical": true, "font_size": 22, "lines_coords": [[[235.0, 873.0], [257.0, 873.0], [257.0, 1057.0], [235.0, 1057.0]], [[206.0, 873.0], [228.0, 873.0], [228.0, 1035.0], [206.0, 1035.0]], [[179.0, 873.0], [201.0, 873.0], [201.0, 1059.0], [179.0, 1059.0]], [[153.0, 875.0], [175.0, 875.0], [175.0, 1067.0], [153.0, 1067.0]]], "lines": ["理解できない奴は", "軟弱な文学でも", "読み漁っていれば", "いいと思っていた。"]}, {"box": [810, 1365, 823, 1401], "vertical": true, "font_size": 13, "lines_coords": [[[810.0, 1365.0], [823.0, 1365.0], [823.0, 1401.0], [810.0, 1401.0]]], "lines": ["．．．"]}, {"box": [767, 1420, 825, 1489], "vertical": true, "font_size": 19.0, "lines_coords": [[[807.0, 1421.0], [825.0, 1421.0], [825.0, 1476.0], [807.0, 1476.0]], [[784.0, 1420.0], [806.0, 1420.0], [806.0, 1478.0], [784.0, 1478.0]], [[767.0, 1423.0], [784.0, 1423.0], [784.0, 1489.0], [767.0, 1489.0]]], "lines": ["．．．", "コ１０１７年の", "あはははっはっ"]}, {"box": [485, 1166, 541, 1333], "vertical": true, "font_size": 22, "lines_coords": [[[517.0, 1167.0], [539.0, 1167.0], [539.0, 1295.0], [517.0, 1295.0]], [[485.0, 1168.0], [507.0, 1168.0], [507.0, 1331.0], [485.0, 1331.0]]], "lines": ["．．．あの男に", "出会うまでは。"]}, {"box": [93, 1325, 202, 1535], "vertical": true, "font_size": 24, "lines_coords": [[[178.0, 1326.0], [200.0, 1326.0], [200.0, 1515.0], [178.0, 1515.0]], [[143.0, 1325.0], [170.0, 1325.0], [173.0, 1442.0], [146.0, 1442.0]], [[118.0, 1325.0], [145.0, 1325.0], [145.0, 1535.0], [118.0, 1535.0]], [[93.0, 1326.0], [114.0, 1326.0], [114.0, 1535.0], [93.0, 1535.0]]], "lines": ["初めて出会った時", "奴は大学の", "キャンパスで全裸で", "鼻歌を歌っていた．．．"]}], "img_path": "062.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [842, 128, 979, 311], "vertical": true, "font_size": 23, "lines_coords": [[[956.0, 129.0], [976.0, 129.0], [976.0, 278.0], [956.0, 278.0]], [[926.0, 128.0], [948.0, 128.0], [948.0, 310.0], [926.0, 310.0]], [[898.0, 129.0], [920.0, 129.0], [920.0, 290.0], [898.0, 290.0]], [[870.0, 129.0], [892.0, 129.0], [892.0, 267.0], [870.0, 267.0]], [[842.0, 128.0], [870.0, 128.0], [870.0, 207.0], [842.0, 207.0]]], "lines": ["それは、音楽に", "興味の無い俺でも", "惹き付けられる", "不思議な旋律", "だった。"]}, {"box": [181, 120, 317, 309], "vertical": true, "font_size": 24, "lines_coords": [[[295.0, 123.0], [317.0, 123.0], [317.0, 284.0], [295.0, 284.0]], [[265.0, 121.0], [287.0, 121.0], [287.0, 309.0], [265.0, 309.0]], [[239.0, 125.0], [260.0, 125.0], [260.0, 307.0], [239.0, 307.0]], [[207.0, 120.0], [234.0, 120.0], [234.0, 306.0], [207.0, 306.0]], [[181.0, 120.0], [209.0, 120.0], [209.0, 195.0], [181.0, 195.0]]], "lines": ["それはなんの曲", "なのかと尋ねると", "奴は少年のような", "目でこう言ったん", "だ．．．．．"]}, {"box": [876, 659, 954, 820], "vertical": true, "font_size": 21, "lines_coords": [[[932.0, 660.0], [954.0, 660.0], [954.0, 818.0], [932.0, 818.0]], [[904.0, 659.0], [925.0, 659.0], [925.0, 820.0], [904.0, 820.0]], [[876.0, 660.0], [898.0, 660.0], [898.0, 796.0], [876.0, 796.0]]], "lines": ["初めは俺だって", "馬鹿げた話だと", "思ったさ．．．"]}, {"box": [681, 654, 814, 873], "vertical": true, "font_size": 21, "lines_coords": [[[792.0, 654.0], [814.0, 654.0], [814.0, 826.0], [792.0, 826.0]], [[765.0, 656.0], [785.0, 656.0], [785.0, 793.0], [765.0, 793.0]], [[735.0, 656.0], [757.0, 656.0], [757.0, 860.0], [735.0, 860.0]], [[709.0, 654.0], [731.0, 654.0], [731.0, 815.0], [709.0, 815.0]], [[681.0, 654.0], [703.0, 654.0], [703.0, 873.0], [681.0, 873.0]]], "lines": ["．．．だが翌日、俺は", "奴の予言通り", "激しく剃刀負けをし", "デートに遅刻し", "彼女に振られたのだ！！"]}, {"box": [484, 690, 617, 889], "vertical": true, "font_size": 21, "lines_coords": [[[596.0, 693.0], [617.0, 693.0], [617.0, 889.0], [596.0, 889.0]], [[567.0, 692.0], [587.0, 692.0], [587.0, 875.0], [567.0, 875.0]], [[539.0, 690.0], [559.0, 690.0], [559.0, 853.0], [539.0, 853.0]], [[509.0, 690.0], [532.0, 690.0], [534.0, 851.0], [510.0, 851.0]], [[484.0, 693.0], [504.0, 693.0], [504.0, 831.0], [484.0, 831.0]]], "lines": ["．．．それだけじゃない、", "オウムも９・１１も", "まりもっこりも", "的確に予言して", "みせたんだ．．．"]}, {"box": [142, 356, 251, 540], "vertical": true, "font_size": 24, "lines_coords": [[[225.0, 356.0], [251.0, 356.0], [248.0, 485.0], [221.0, 485.0]], [[195.0, 359.0], [221.0, 359.0], [221.0, 521.0], [195.0, 521.0]], [[170.0, 360.0], [192.0, 360.0], [192.0, 521.0], [170.0, 521.0]], [[142.0, 360.0], [164.0, 360.0], [164.0, 540.0], [142.0, 540.0]]], "lines": ["「これは僕が", "夢の中で聴いた", "明日の君を予言", "した曲なのさ」と。"]}, {"box": [917, 950, 968, 1134], "vertical": true, "font_size": 22, "lines_coords": [[[946.0, 953.0], [968.0, 953.0], [968.0, 1134.0], [946.0, 1134.0]], [[920.0, 950.0], [942.0, 950.0], [939.0, 1110.0], [917.0, 1110.0]]], "lines": ["．．．しかし奴の心は", "ピュアソウル．．．"]}, {"box": [746, 1003, 879, 1196], "vertical": true, "font_size": 22, "lines_coords": [[[857.0, 1003.0], [879.0, 1003.0], [879.0, 1118.0], [857.0, 1118.0]], [[829.0, 1004.0], [851.0, 1004.0], [851.0, 1162.0], [829.0, 1162.0]], [[803.0, 1003.0], [825.0, 1003.0], [825.0, 1185.0], [803.0, 1185.0]], [[775.0, 1003.0], [796.0, 1003.0], [796.0, 1185.0], [775.0, 1185.0]], [[746.0, 1004.0], [768.0, 1004.0], [768.0, 1196.0], [746.0, 1196.0]]], "lines": ["その才能を", "有効利用しない", "どころか、証明や", "誇示しようという", "発想すらないのだ。"]}, {"box": [118, 984, 282, 1215], "vertical": true, "font_size": 23, "lines_coords": [[[253.0, 984.0], [279.0, 984.0], [282.0, 1126.0], [256.0, 1126.0]], [[229.0, 987.0], [251.0, 987.0], [251.0, 1146.0], [229.0, 1146.0]], [[201.0, 985.0], [223.0, 985.0], [223.0, 1215.0], [201.0, 1215.0]], [[173.0, 985.0], [195.0, 985.0], [195.0, 1176.0], [173.0, 1176.0]], [[145.0, 984.0], [168.0, 984.0], [167.0, 1190.0], [143.0, 1190.0]], [[118.0, 987.0], [140.0, 987.0], [140.0, 1195.0], [118.0, 1195.0]]], "lines": ["俺は図らずも", "夢の中で女神が", "定理を教えてくれると", "言った天才数学者、", "ラマヌジャンを思い", "出してしまったよ："]}, {"box": [893, 1292, 975, 1442], "vertical": true, "font_size": 23, "lines_coords": [[[945.0, 1292.0], [975.0, 1292.0], [975.0, 1367.0], [945.0, 1367.0]], [[921.0, 1293.0], [943.0, 1293.0], [943.0, 1432.0], [921.0, 1432.0]], [[893.0, 1295.0], [915.0, 1295.0], [915.0, 1442.0], [893.0, 1442.0]]], "lines": ["そして", "俺は気付いて", "しまったんだ。"]}, {"box": [710, 1328, 842, 1512], "vertical": true, "font_size": 23, "lines_coords": [[[820.0, 1328.0], [842.0, 1328.0], [842.0, 1512.0], [820.0, 1512.0]], [[792.0, 1328.0], [814.0, 1328.0], [814.0, 1489.0], [792.0, 1489.0]], [[767.0, 1329.0], [787.0, 1329.0], [787.0, 1489.0], [767.0, 1489.0]], [[739.0, 1328.0], [760.0, 1328.0], [760.0, 1487.0], [739.0, 1487.0]], [[710.0, 1328.0], [732.0, 1328.0], [732.0, 1442.0], [710.0, 1442.0]]], "lines": ["俺のような凡才は", "天才の偉大さを", "証明するために", "存在しているの", "だと．．．．．．！！"]}], "img_path": "063.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [890, 62, 968, 250], "vertical": true, "font_size": 21, "lines_coords": [[[946.0, 64.0], [968.0, 64.0], [968.0, 248.0], [946.0, 248.0]], [[920.0, 65.0], [940.0, 65.0], [940.0, 250.0], [920.0, 250.0]], [[890.0, 62.0], [910.0, 62.0], [910.0, 246.0], [890.0, 246.0]]], "lines": ["神懸かった奇跡も", "証明さえできれば", "現実で科学なんだ。"]}, {"box": [779, 134, 829, 273], "vertical": true, "font_size": 21, "lines_coords": [[[807.0, 134.0], [829.0, 134.0], [829.0, 273.0], [807.0, 273.0]], [[779.0, 134.0], [801.0, 134.0], [801.0, 215.0], [779.0, 215.0]]], "lines": ["そしてそれは", "浪漫だ。"]}, {"box": [378, 37, 459, 217], "vertical": true, "font_size": 22, "lines_coords": [[[432.0, 37.0], [459.0, 37.0], [456.0, 181.0], [429.0, 181.0]], [[406.0, 42.0], [428.0, 42.0], [428.0, 179.0], [406.0, 179.0]], [[378.0, 39.0], [400.0, 39.0], [400.0, 217.0], [378.0, 217.0]]], "lines": ["．．．幸いながら", "奴は無邪気で", "すこぶる優しい．．．"]}, {"box": [257, 93, 335, 270], "vertical": true, "font_size": 22, "lines_coords": [[[314.0, 93.0], [335.0, 93.0], [335.0, 267.0], [314.0, 267.0]], [[287.0, 95.0], [304.0, 95.0], [304.0, 207.0], [287.0, 207.0]], [[257.0, 95.0], [279.0, 95.0], [279.0, 270.0], [257.0, 270.0]]], "lines": ["全人類を信頼する", "その姿勢は", "絶対的な許しだ．．．"]}, {"box": [106, 157, 213, 369], "vertical": true, "font_size": 107, "lines_coords": [[[106.0, 157.0], [213.0, 157.0], [213.0, 369.0], [106.0, 369.0]]], "lines": ["その許しの精神を人々に伝え説くのはもはや俺の責務だとすら思っている。"]}, {"box": [104, 160, 210, 370], "vertical": true, "font_size": 22, "lines_coords": [[[189.0, 160.0], [210.0, 160.0], [210.0, 346.0], [189.0, 346.0]], [[160.0, 160.0], [182.0, 160.0], [182.0, 370.0], [160.0, 370.0]], [[131.0, 160.0], [153.0, 160.0], [153.0, 368.0], [131.0, 368.0]], [[104.0, 160.0], [126.0, 160.0], [126.0, 332.0], [104.0, 332.0]]], "lines": ["その許しの精神を", "人々に伝え説くのは", "もはや俺の責務だと", "すら思っている。"]}, {"box": [904, 457, 982, 607], "vertical": true, "font_size": 23, "lines_coords": [[[960.0, 457.0], [982.0, 457.0], [982.0, 596.0], [960.0, 596.0]], [[932.0, 459.0], [954.0, 459.0], [954.0, 575.0], [932.0, 575.0]], [[904.0, 457.0], [926.0, 457.0], [926.0, 607.0], [904.0, 607.0]]], "lines": ["．．．ありがたい", "トンデモ話", "ご苦労様です。"]}, {"box": [767, 539, 851, 679], "vertical": true, "font_size": 23, "lines_coords": [[[829.0, 542.0], [851.0, 542.0], [851.0, 679.0], [829.0, 679.0]], [[801.0, 542.0], [821.0, 542.0], [821.0, 679.0], [801.0, 679.0]], [[767.0, 539.0], [800.0, 539.0], [800.0, 621.0], [767.0, 621.0]]], "lines": ["さすがウチの", "名物変態講師", "ですね。"]}, {"box": [539, 459, 704, 671], "vertical": true, "font_size": 23, "lines_coords": [[[678.0, 459.0], [704.0, 459.0], [704.0, 578.0], [678.0, 578.0]], [[651.0, 462.0], [673.0, 462.0], [673.0, 645.0], [651.0, 645.0]], [[623.0, 460.0], [645.0, 460.0], [645.0, 645.0], [623.0, 645.0]], [[595.0, 460.0], [617.0, 460.0], [617.0, 645.0], [595.0, 645.0]], [[567.0, 462.0], [589.0, 462.0], [589.0, 671.0], [567.0, 671.0]], [[539.0, 460.0], [560.0, 460.0], [560.0, 564.0], [539.0, 564.0]]], "lines": ["そういえば", "女子生徒の一人が", "和田先生の飛ばす", "ツバは毒汁だから", "顔が腐るって言って", "ましたよ。"]}, {"box": [940, 801, 968, 864], "vertical": true, "font_size": 28, "lines_coords": [[[940.0, 801.0], [968.0, 801.0], [968.0, 864.0], [940.0, 864.0]]], "lines": ["．．．ま。"]}, {"box": [250, 796, 360, 979], "vertical": true, "font_size": 23, "lines_coords": [[[334.0, 796.0], [360.0, 796.0], [360.0, 915.0], [334.0, 915.0]], [[307.0, 796.0], [329.0, 796.0], [329.0, 979.0], [307.0, 979.0]], [[279.0, 798.0], [301.0, 798.0], [301.0, 959.0], [279.0, 959.0]], [[250.0, 796.0], [278.0, 796.0], [278.0, 881.0], [250.0, 881.0]]], "lines": ["実のところ", "奴はある宗教家の", "息子で小金持ち", "なんだ。"]}, {"box": [107, 873, 215, 1057], "vertical": true, "font_size": 23, "lines_coords": [[[193.0, 875.0], [215.0, 875.0], [215.0, 992.0], [193.0, 992.0]], [[165.0, 873.0], [187.0, 873.0], [187.0, 1057.0], [165.0, 1057.0]], [[135.0, 873.0], [157.0, 873.0], [157.0, 1057.0], [135.0, 1057.0]], [[107.0, 875.0], [128.0, 875.0], [128.0, 1042.0], [107.0, 1042.0]]], "lines": ["凡人の俺は", "上手く取り入って", "ひと儲けてきない", "かとも思ってる"]}, {"box": [854, 1178, 984, 1342], "vertical": true, "font_size": 22, "lines_coords": [[[959.0, 1178.0], [981.0, 1178.0], [984.0, 1315.0], [962.0, 1315.0]], [[934.0, 1181.0], [956.0, 1181.0], [956.0, 1318.0], [934.0, 1318.0]], [[907.0, 1179.0], [929.0, 1179.0], [929.0, 1342.0], [907.0, 1342.0]], [[879.0, 1179.0], [901.0, 1179.0], [901.0, 1340.0], [879.0, 1340.0]], [[854.0, 1179.0], [876.0, 1179.0], [876.0, 1304.0], [854.0, 1304.0]]], "lines": ["．．．いいんじゃ", "ないですか？", "不景気だし宗教", "流行るかもしれ", "ないですし。"]}, {"box": [712, 1229, 818, 1368], "vertical": true, "font_size": 22, "lines_coords": [[[796.0, 1231.0], [818.0, 1231.0], [818.0, 1368.0], [796.0, 1368.0]], [[768.0, 1231.0], [790.0, 1231.0], [790.0, 1368.0], [768.0, 1368.0]], [[740.0, 1229.0], [762.0, 1229.0], [762.0, 1345.0], [740.0, 1345.0]], [[712.0, 1231.0], [734.0, 1231.0], [734.0, 1331.0], [712.0, 1331.0]]], "lines": ["あたし的には", "胡散臭すぎて", "お笑いの域", "てすけど。"]}, {"box": [100, 1281, 209, 1479], "vertical": true, "font_size": 23, "lines_coords": [[[185.0, 1282.0], [207.0, 1282.0], [207.0, 1450.0], [185.0, 1450.0]], [[154.0, 1281.0], [181.0, 1281.0], [181.0, 1423.0], [154.0, 1423.0]], [[128.0, 1282.0], [150.0, 1282.0], [150.0, 1479.0], [128.0, 1479.0]], [[100.0, 1282.0], [121.0, 1282.0], [123.0, 1478.0], [101.0, 1478.0]]], "lines": ["しかし和田先生、", "見た目以上に", "中身がゲスですね。", "逆に安心しました。"]}], "img_path": "064.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [905, 95, 956, 257], "vertical": true, "font_size": 21, "lines_coords": [[[934.0, 95.0], [954.0, 95.0], [954.0, 256.0], [934.0, 256.0]], [[906.0, 95.0], [928.0, 95.0], [928.0, 257.0], [906.0, 257.0]]], "lines": ["．．．それはつまり", "褒め言葉かい？"]}, {"box": [193, 635, 303, 795], "vertical": true, "font_size": 30, "lines_coords": [[[275.0, 643.0], [303.0, 643.0], [303.0, 795.0], [275.0, 795.0]], [[234.0, 642.0], [262.0, 642.0], [264.0, 795.0], [235.0, 795.0]], [[193.0, 637.0], [228.0, 635.0], [231.0, 729.0], [196.0, 731.0]]], "lines": ["じゃあ俺と", "付き合って", "ちょー"]}, {"box": [159, 679, 187, 795], "vertical": true, "font_size": 30, "lines_coords": [[[159.0, 679.0], [187.0, 679.0], [187.0, 795.0], [159.0, 795.0]]], "lines": ["ーだい！！"]}, {"box": [831, 926, 954, 1060], "vertical": true, "font_size": 28, "lines_coords": [[[928.0, 931.0], [954.0, 931.0], [954.0, 1060.0], [928.0, 1060.0]], [[890.0, 926.0], [929.0, 926.0], [929.0, 1015.0], [890.0, 1015.0]], [[864.0, 929.0], [890.0, 929.0], [890.0, 1059.0], [864.0, 1059.0]], [[831.0, 929.0], [859.0, 929.0], [859.0, 1034.0], [831.0, 1034.0]]], "lines": ["．．．どういう", "文脈で", "そうなるん", "ですか？"]}, {"box": [725, 987, 782, 1140], "vertical": true, "font_size": 28, "lines_coords": [[[754.0, 987.0], [782.0, 987.0], [782.0, 1068.0], [754.0, 1068.0]], [[725.0, 989.0], [746.0, 989.0], [746.0, 1140.0], [725.0, 1140.0]]], "lines": ["あほう", "なんですか？"]}, {"box": [914, 1221, 978, 1307], "vertical": true, "font_size": 35, "lines_coords": [[[934.0, 1225.0], [970.0, 1221.0], [978.0, 1303.0], [942.0, 1307.0]], [[914.0, 1221.0], [948.0, 1221.0], [948.0, 1289.0], [914.0, 1289.0]]], "lines": ["．．．．．．あ", "あと。"]}, {"box": [112, 1192, 327, 1526], "vertical": true, "font_size": 23, "lines_coords": [[[303.0, 1198.0], [325.0, 1198.0], [325.0, 1335.0], [303.0, 1335.0]], [[273.0, 1196.0], [296.0, 1196.0], [298.0, 1337.0], [275.0, 1337.0]], [[246.0, 1196.0], [268.0, 1196.0], [268.0, 1337.0], [246.0, 1337.0]], [[215.0, 1195.0], [242.0, 1195.0], [243.0, 1364.0], [217.0, 1364.0]], [[196.0, 1350.0], [218.0, 1350.0], [218.0, 1443.0], [196.0, 1443.0]], [[170.0, 1351.0], [192.0, 1351.0], [192.0, 1468.0], [170.0, 1468.0]], [[142.0, 1353.0], [164.0, 1353.0], [164.0, 1525.0], [142.0, 1525.0]], [[114.0, 1351.0], [135.0, 1351.0], [134.0, 1515.0], [112.0, 1515.0]]], "lines": ["毎日あたしの", "帰り際狙って", "出待ちするの", "やめてください。", "あんまり", "しつこいと", "ストーカー被害の", "届け出しますよ。"]}], "img_path": "065.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [462, 458, 519, 614], "vertical": true, "font_size": 24, "lines_coords": [[[492.0, 459.0], [518.0, 459.0], [518.0, 614.0], [492.0, 614.0]], [[462.0, 459.0], [484.0, 459.0], [484.0, 554.0], [462.0, 554.0]]], "lines": ["おつかれさま", "てしたー"]}, {"box": [192, 732, 257, 954], "vertical": true, "font_size": 33, "lines_coords": [[[220.0, 734.0], [254.0, 732.0], [257.0, 840.0], [223.0, 842.0]], [[192.0, 735.0], [223.0, 735.0], [223.0, 954.0], [192.0, 954.0]]], "lines": ["．．．グッド", "バイブレーション。"]}], "img_path": "066.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "067.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [217, 1153, 250, 1289], "vertical": true, "font_size": 28, "lines_coords": [[[217.0, 1154.0], [245.0, 1154.0], [245.0, 1282.0], [217.0, 1282.0]]], "lines": ["おーす"]}], "img_path": "068.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [882, 148, 943, 256], "vertical": true, "font_size": 30, "lines_coords": [[[915.0, 151.0], [943.0, 151.0], [943.0, 256.0], [915.0, 256.0]], [[882.0, 148.0], [915.0, 148.0], [915.0, 256.0], [882.0, 256.0]]], "lines": ["いや～～～", "正直．．．"]}, {"box": [852, 700, 940, 879], "vertical": true, "font_size": 25, "lines_coords": [[[912.0, 700.0], [939.0, 700.0], [939.0, 854.0], [912.0, 854.0]], [[881.0, 700.0], [907.0, 700.0], [907.0, 878.0], [881.0, 878.0]], [[853.0, 701.0], [875.0, 701.0], [875.0, 879.0], [853.0, 879.0]]], "lines": ["別に期待して", "なかった訳じゃ", "ないんだけど．．．"]}, {"box": [156, 392, 279, 573], "vertical": true, "font_size": 23, "lines_coords": [[[254.0, 395.0], [276.0, 395.0], [276.0, 548.0], [254.0, 548.0]], [[221.0, 393.0], [243.0, 393.0], [243.0, 573.0], [221.0, 573.0]], [[190.0, 393.0], [212.0, 393.0], [212.0, 521.0], [190.0, 521.0]], [[156.0, 392.0], [182.0, 392.0], [182.0, 560.0], [156.0, 560.0]]], "lines": ["君がこんなに", "早く書いてくる", "とは思って", "なかったなぁ。"]}, {"box": [132, 910, 227, 1095], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 912.0], [226.0, 912.0], [226.0, 1095.0], [200.0, 1095.0]], [[167.0, 912.0], [193.0, 912.0], [193.0, 1093.0], [167.0, 1093.0]], [[135.0, 910.0], [162.0, 910.0], [159.0, 1076.0], [132.0, 1076.0]]], "lines": ["．．．ちょっと強引", "だったかなって", "反省しててね。"]}, {"box": [907, 1242, 935, 1325], "vertical": true, "font_size": 26, "lines_coords": [[[907.0, 1242.0], [935.0, 1242.0], [935.0, 1325.0], [907.0, 1325.0]]], "lines": ["．．．うん。"]}, {"box": [810, 1315, 835, 1431], "vertical": true, "font_size": 26, "lines_coords": [[[810.0, 1315.0], [834.0, 1315.0], [835.0, 1431.0], [812.0, 1431.0]]], "lines": ["なるほど。"]}], "img_path": "069.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [879, 107, 921, 234], "vertical": true, "font_size": 39, "lines_coords": [[[879.0, 109.0], [918.0, 107.0], [921.0, 232.0], [882.0, 234.0]]], "lines": ["酷い！！"]}, {"box": [868, 635, 964, 745], "vertical": true, "font_size": 30, "lines_coords": [[[929.0, 635.0], [964.0, 635.0], [964.0, 698.0], [929.0, 698.0]], [[900.0, 639.0], [928.0, 639.0], [928.0, 745.0], [900.0, 745.0]], [[868.0, 639.0], [896.0, 639.0], [896.0, 720.0], [868.0, 720.0]]], "lines": ["まず", "日本語が", "ダメ！！"]}, {"box": [157, 337, 239, 520], "vertical": true, "font_size": 37, "lines_coords": [[[200.0, 337.0], [239.0, 337.0], [239.0, 520.0], [200.0, 520.0]], [[157.0, 339.0], [192.0, 339.0], [192.0, 448.0], [157.0, 448.0]]], "lines": ["ぜんっぜん", "駄目！！"]}, {"box": [142, 676, 263, 857], "vertical": true, "font_size": 24, "lines_coords": [[[235.0, 676.0], [262.0, 676.0], [260.0, 846.0], [234.0, 846.0]], [[203.0, 678.0], [229.0, 678.0], [229.0, 834.0], [203.0, 834.0]], [[173.0, 681.0], [195.0, 681.0], [195.0, 857.0], [173.0, 857.0]], [[142.0, 679.0], [164.0, 679.0], [164.0, 782.0], [142.0, 782.0]]], "lines": ["．．．君、ちゃんと", "あたしと同じ", "高校卒業したん", "だよね？"]}, {"box": [884, 959, 993, 1145], "vertical": true, "font_size": 22, "lines_coords": [[[970.0, 960.0], [992.0, 960.0], [992.0, 1145.0], [970.0, 1145.0]], [[940.0, 959.0], [960.0, 959.0], [960.0, 1143.0], [940.0, 1143.0]], [[912.0, 960.0], [934.0, 960.0], [934.0, 1123.0], [912.0, 1123.0]], [[884.0, 960.0], [906.0, 960.0], [906.0, 1123.0], [884.0, 1123.0]]], "lines": ["プロットとかなら", "まだしも、これが", "本文なら全部に", "直し入れるよ？"]}, {"box": [320, 937, 400, 1123], "vertical": true, "font_size": 23, "lines_coords": [[[378.0, 937.0], [400.0, 937.0], [400.0, 1100.0], [378.0, 1100.0]], [[351.0, 937.0], [373.0, 937.0], [373.0, 1098.0], [351.0, 1098.0]], [[321.0, 939.0], [345.0, 939.0], [343.0, 1123.0], [320.0, 1123.0]]], "lines": ["前に見たやつは", "もっと良かった", "ハズなのに～～～．．．"]}, {"box": [171, 981, 281, 1168], "vertical": true, "font_size": 23, "lines_coords": [[[259.0, 982.0], [281.0, 982.0], [281.0, 1168.0], [259.0, 1168.0]], [[229.0, 981.0], [251.0, 981.0], [253.0, 1168.0], [231.0, 1168.0]], [[203.0, 982.0], [225.0, 982.0], [225.0, 1143.0], [203.0, 1143.0]], [[171.0, 981.0], [200.0, 981.0], [200.0, 1078.0], [171.0, 1078.0]]], "lines": ["思い出フィルター", "補正かかり過ぎて", "美化されてたの", "か～～～？"]}, {"box": [676, 1229, 782, 1414], "vertical": true, "font_size": 24, "lines_coords": [[[760.0, 1229.0], [782.0, 1229.0], [782.0, 1414.0], [760.0, 1414.0]], [[732.0, 1229.0], [754.0, 1229.0], [754.0, 1414.0], [732.0, 1414.0]], [[704.0, 1231.0], [726.0, 1231.0], [726.0, 1414.0], [704.0, 1414.0]], [[676.0, 1229.0], [698.0, 1229.0], [698.0, 1354.0], [676.0, 1354.0]]], "lines": ["格好つけ過ぎだし", "キャラもセリフも", "ペラ過ぎて絵本に", "なんねーよ。"]}, {"box": [568, 1356, 650, 1453], "vertical": true, "font_size": 24, "lines_coords": [[[623.0, 1356.0], [650.0, 1356.0], [650.0, 1451.0], [623.0, 1451.0]], [[595.0, 1357.0], [621.0, 1357.0], [621.0, 1453.0], [595.0, 1453.0]], [[568.0, 1357.0], [592.0, 1357.0], [592.0, 1429.0], [568.0, 1429.0]]], "lines": ["これじゃ", "漫画だよ", "漫画！！"]}, {"box": [115, 1360, 145, 1514], "vertical": true, "font_size": 28, "lines_coords": [[[115.0, 1362.0], [143.0, 1362.0], [143.0, 1514.0], [115.0, 1514.0]]], "lines": ["．．．南条っ！！"]}], "img_path": "070.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [918, 81, 990, 243], "vertical": true, "font_size": 31, "lines_coords": [[[962.0, 85.0], [990.0, 85.0], [990.0, 207.0], [962.0, 207.0]], [[918.0, 81.0], [957.0, 81.0], [957.0, 243.0], [918.0, 243.0]]], "lines": ["キンキラ", "キーーン☆"]}, {"box": [881, 295, 907, 417], "vertical": true, "font_size": 31, "lines_coords": [[[881.0, 295.0], [907.0, 295.0], [907.0, 417.0], [881.0, 417.0]]], "lines": ["おまた"]}, {"box": [181, 306, 239, 434], "vertical": true, "font_size": 27, "lines_coords": [[[212.0, 306.0], [239.0, 306.0], [239.0, 434.0], [212.0, 434.0]], [[181.0, 306.0], [207.0, 306.0], [207.0, 434.0], [181.0, 434.0]]], "lines": ["おっせーよ", "この野郎！！"]}, {"box": [131, 496, 218, 631], "vertical": true, "font_size": 27, "lines_coords": [[[192.0, 500.0], [218.0, 500.0], [218.0, 631.0], [192.0, 631.0]], [[156.0, 496.0], [190.0, 496.0], [190.0, 582.0], [156.0, 582.0]], [[131.0, 501.0], [153.0, 501.0], [153.0, 610.0], [131.0, 610.0]]], "lines": ["早く座れよ", "目障り", "なんだよ"]}, {"box": [901, 723, 965, 882], "vertical": true, "font_size": 30, "lines_coords": [[[939.0, 725.0], [965.0, 725.0], [965.0, 853.0], [939.0, 853.0]], [[901.0, 723.0], [932.0, 723.0], [932.0, 882.0], [901.0, 882.0]]], "lines": ["小野寺くん", "お久し師～～～"]}, {"box": [765, 809, 859, 946], "vertical": true, "font_size": 30, "lines_coords": [[[820.0, 809.0], [859.0, 809.0], [859.0, 896.0], [820.0, 896.0]], [[792.0, 809.0], [825.0, 809.0], [825.0, 946.0], [792.0, 946.0]], [[765.0, 814.0], [787.0, 814.0], [787.0, 942.0], [765.0, 942.0]]], "lines": ["蟹江姉", "で～～～す", "ビュバッん"]}, {"box": [625, 1043, 715, 1212], "vertical": true, "font_size": 27, "lines_coords": [[[689.0, 1043.0], [715.0, 1043.0], [712.0, 1198.0], [685.0, 1198.0]], [[656.0, 1043.0], [684.0, 1043.0], [679.0, 1201.0], [651.0, 1201.0]], [[625.0, 1045.0], [651.0, 1045.0], [651.0, 1212.0], [625.0, 1212.0]]], "lines": ["．．．南条アンタ", "絵本作りまだ", "やってたのね。"]}, {"box": [543, 1135, 568, 1264], "vertical": true, "font_size": 22, "lines_coords": [[[543.0, 1135.0], [565.0, 1135.0], [565.0, 1264.0], [543.0, 1264.0]]], "lines": ["そうだよ！！"]}, {"box": [115, 1103, 176, 1271], "vertical": true, "font_size": 28, "lines_coords": [[[146.0, 1104.0], [175.0, 1104.0], [175.0, 1232.0], [146.0, 1232.0]], [[115.0, 1104.0], [142.0, 1104.0], [142.0, 1271.0], [115.0, 1271.0]]], "lines": ["．．．あ、注文", "いいですかァ？"]}, {"box": [134, 1354, 261, 1510], "vertical": true, "font_size": 27, "lines_coords": [[[232.0, 1357.0], [259.0, 1357.0], [259.0, 1485.0], [232.0, 1485.0]], [[200.0, 1357.0], [226.0, 1357.0], [226.0, 1510.0], [200.0, 1510.0]], [[168.0, 1356.0], [196.0, 1356.0], [193.0, 1485.0], [165.0, 1485.0]], [[134.0, 1354.0], [160.0, 1354.0], [164.0, 1495.0], [137.0, 1495.0]]], "lines": ["私、前世が", "ウサギなんて", "ミニサラダ", "くださいな。"]}], "img_path": "071.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [898, 46, 979, 220], "vertical": true, "font_size": 23, "lines_coords": [[[950.0, 46.0], [978.0, 46.0], [979.0, 143.0], [951.0, 143.0]], [[926.0, 48.0], [948.0, 48.0], [948.0, 207.0], [926.0, 207.0]], [[898.0, 46.0], [918.0, 46.0], [918.0, 215.0], [898.0, 215.0]]], "lines": ["蟹江こそ", "すっかり社畜に", "なり下がったな。"]}, {"box": [729, 204, 843, 406], "vertical": true, "font_size": 28, "lines_coords": [[[812.0, 204.0], [840.0, 204.0], [843.0, 353.0], [815.0, 353.0]], [[784.0, 204.0], [810.0, 204.0], [814.0, 370.0], [787.0, 370.0]], [[756.0, 204.0], [787.0, 204.0], [787.0, 406.0], [756.0, 406.0]], [[729.0, 204.0], [756.0, 204.0], [757.0, 403.0], [731.0, 403.0]]], "lines": ["．．．なんだよォ、", "クソ忙しい時間", "縫って久々会いに", "来てやったのにィ。"]}, {"box": [615, 59, 645, 137], "vertical": true, "font_size": 30, "lines_coords": [[[615.0, 62.0], [645.0, 62.0], [645.0, 137.0], [615.0, 137.0]]], "lines": ["．．．んで、"]}, {"box": [192, 45, 270, 207], "vertical": true, "font_size": 24, "lines_coords": [[[248.0, 48.0], [270.0, 48.0], [270.0, 162.0], [248.0, 162.0]], [[220.0, 46.0], [242.0, 46.0], [242.0, 207.0], [220.0, 207.0]], [[192.0, 45.0], [214.0, 45.0], [214.0, 207.0], [192.0, 207.0]]], "lines": ["磨けば光る", "原石君の調子は", "どうだったの？"]}, {"box": [98, 200, 179, 365], "vertical": true, "font_size": 24, "lines_coords": [[[153.0, 200.0], [176.0, 200.0], [179.0, 342.0], [156.0, 342.0]], [[126.0, 200.0], [153.0, 200.0], [153.0, 365.0], [126.0, 365.0]], [[98.0, 200.0], [126.0, 200.0], [126.0, 273.0], [98.0, 273.0]]], "lines": ["アンタの目に", "狂いはなかった", "ワケ？"]}, {"box": [939, 593, 965, 760], "vertical": true, "font_size": 23, "lines_coords": [[[939.0, 593.0], [965.0, 593.0], [965.0, 760.0], [939.0, 760.0]]], "lines": ["．．．小野寺くん。"]}, {"box": [200, 718, 290, 875], "vertical": true, "font_size": 25, "lines_coords": [[[264.0, 720.0], [290.0, 720.0], [290.0, 875.0], [264.0, 875.0]], [[237.0, 721.0], [259.0, 721.0], [259.0, 848.0], [237.0, 848.0]], [[203.0, 718.0], [229.0, 718.0], [226.0, 859.0], [200.0, 859.0]]], "lines": ["恥ずかしがる", "ことなんて", "ないんだよ。"]}, {"box": [798, 754, 906, 931], "vertical": true, "font_size": 23, "lines_coords": [[[884.0, 757.0], [906.0, 757.0], [906.0, 873.0], [884.0, 873.0]], [[851.0, 754.0], [875.0, 754.0], [878.0, 873.0], [854.0, 873.0]], [[825.0, 756.0], [846.0, 756.0], [846.0, 931.0], [825.0, 931.0]], [[798.0, 756.0], [818.0, 756.0], [818.0, 881.0], [798.0, 881.0]]], "lines": ["話を戻すと", "君はもっと", "いいものが書ける", "と思うんだ。"]}, {"box": [107, 935, 232, 1092], "vertical": true, "font_size": 25, "lines_coords": [[[206.0, 935.0], [232.0, 935.0], [232.0, 1067.0], [206.0, 1067.0]], [[176.0, 937.0], [198.0, 937.0], [198.0, 1090.0], [176.0, 1090.0]], [[139.0, 935.0], [165.0, 935.0], [168.0, 1092.0], [142.0, 1092.0]], [[107.0, 937.0], [137.0, 937.0], [139.0, 1028.0], [109.0, 1028.0]]], "lines": ["昔みたいに", "思ったままに", "素直に書きや", "いいの。"]}, {"box": [293, 1225, 320, 1343], "vertical": true, "font_size": 29, "lines_coords": [[[293.0, 1225.0], [320.0, 1225.0], [320.0, 1343.0], [293.0, 1343.0]]], "lines": ["．．．どう？"]}, {"box": [156, 1346, 226, 1512], "vertical": true, "font_size": 29, "lines_coords": [[[190.0, 1346.0], [223.0, 1346.0], [226.0, 1512.0], [193.0, 1512.0]], [[156.0, 1351.0], [184.0, 1351.0], [184.0, 1503.0], [156.0, 1503.0]]], "lines": ["書き直す気、", "．．．．．ある？"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [484, 471, 608, 679], "vertical": true, "font_size": 26, "lines_coords": [[[579.0, 471.0], [607.0, 471.0], [604.0, 640.0], [576.0, 640.0]], [[548.0, 473.0], [575.0, 473.0], [575.0, 653.0], [548.0, 653.0]], [[515.0, 473.0], [542.0, 473.0], [542.0, 679.0], [515.0, 679.0]], [[485.0, 473.0], [507.0, 473.0], [507.0, 601.0], [485.0, 601.0]]], "lines": ["「：これ以上は", "やらないほうが", "お互いのためだと", "思います。」"]}, {"box": [914, 745, 971, 901], "vertical": true, "font_size": 25, "lines_coords": [[[945.0, 746.0], [971.0, 746.0], [971.0, 901.0], [945.0, 901.0]], [[914.0, 745.0], [940.0, 745.0], [940.0, 851.0], [914.0, 851.0]]], "lines": ["だ～～か～～～", "ら～～！！"]}, {"box": [842, 973, 959, 1131], "vertical": true, "font_size": 25, "lines_coords": [[[903.0, 973.0], [929.0, 973.0], [926.0, 1106.0], [900.0, 1106.0]], [[937.0, 978.0], [959.0, 978.0], [959.0, 1104.0], [937.0, 1104.0]], [[870.0, 976.0], [896.0, 976.0], [896.0, 1106.0], [870.0, 1106.0]], [[842.0, 976.0], [864.0, 976.0], [864.0, 1131.0], [842.0, 1131.0]]], "lines": ["そうやって", "お前はまた", "前のめりに", "ウジウジと！！"]}, {"box": [228, 752, 318, 957], "vertical": true, "font_size": 24, "lines_coords": [[[290.0, 753.0], [317.0, 753.0], [317.0, 931.0], [290.0, 931.0]], [[260.0, 753.0], [282.0, 753.0], [282.0, 906.0], [260.0, 906.0]], [[229.0, 754.0], [251.0, 754.0], [251.0, 957.0], [229.0, 957.0]]], "lines": ["テメーは未来が", "見えるのか！？", "エスパーなのか！？"]}, {"box": [922, 1442, 1009, 1501], "vertical": false, "font_size": 20, "lines_coords": [[[945.0, 1444.0], [1006.0, 1466.0], [1000.0, 1486.0], [939.0, 1465.0]]], "lines": ["．．．"]}, {"box": [140, 1170, 201, 1239], "vertical": true, "font_size": 30, "lines_coords": [[[171.0, 1171.0], [201.0, 1171.0], [201.0, 1229.0], [171.0, 1229.0]], [[140.0, 1170.0], [170.0, 1170.0], [170.0, 1239.0], [140.0, 1239.0]]], "lines": ["まあ", "まあ。"]}], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [950, 41, 978, 156], "vertical": true, "font_size": 26, "lines_coords": [[[950.0, 42.0], [976.0, 42.0], [976.0, 154.0], [950.0, 154.0]]], "lines": ["．．．ふんむ"]}, {"box": [751, 59, 843, 225], "vertical": true, "font_size": 27, "lines_coords": [[[809.0, 59.0], [843.0, 59.0], [843.0, 142.0], [809.0, 142.0]], [[781.0, 59.0], [807.0, 59.0], [807.0, 215.0], [781.0, 215.0]], [[751.0, 60.0], [773.0, 60.0], [773.0, 225.0], [751.0, 225.0]]], "lines": ["今回は", "小野寺くんも", "災難だったね。"]}, {"box": [542, 67, 623, 237], "vertical": true, "font_size": 24, "lines_coords": [[[596.0, 67.0], [623.0, 67.0], [623.0, 185.0], [596.0, 185.0]], [[570.0, 68.0], [592.0, 68.0], [592.0, 207.0], [570.0, 207.0]], [[542.0, 68.0], [564.0, 68.0], [564.0, 237.0], [542.0, 237.0]]], "lines": ["南条は一度", "言いだしたら", "聞かないからね。"]}, {"box": [434, 118, 485, 235], "vertical": true, "font_size": 24, "lines_coords": [[[459.0, 118.0], [485.0, 118.0], [485.0, 235.0], [459.0, 235.0]], [[434.0, 118.0], [456.0, 118.0], [456.0, 220.0], [434.0, 220.0]]], "lines": ["自己実現の", "鬼だから。"]}, {"box": [881, 654, 992, 840], "vertical": true, "font_size": 24, "lines_coords": [[[964.0, 654.0], [992.0, 654.0], [992.0, 734.0], [964.0, 734.0]], [[937.0, 656.0], [959.0, 656.0], [959.0, 796.0], [937.0, 796.0]], [[909.0, 656.0], [931.0, 656.0], [931.0, 840.0], [909.0, 840.0]], [[881.0, 656.0], [903.0, 656.0], [903.0, 829.0], [881.0, 829.0]]], "lines": ["．．．でも、", "小野寺くんと", "再会出来てホント", "喜んでたんだよ。"]}, {"box": [737, 700, 850, 875], "vertical": true, "font_size": 24, "lines_coords": [[[818.0, 700.0], [850.0, 700.0], [850.0, 754.0], [818.0, 754.0]], [[793.0, 704.0], [815.0, 704.0], [815.0, 867.0], [793.0, 867.0]], [[767.0, 704.0], [789.0, 704.0], [789.0, 867.0], [767.0, 867.0]], [[737.0, 703.0], [759.0, 703.0], [760.0, 875.0], [739.0, 875.0]]], "lines": ["君に", "期待してるのは", "嘘じゃないから", "そこは信用して。"]}, {"box": [125, 429, 217, 560], "vertical": true, "font_size": 27, "lines_coords": [[[189.0, 429.0], [217.0, 429.0], [217.0, 535.0], [189.0, 535.0]], [[157.0, 429.0], [184.0, 429.0], [184.0, 560.0], [157.0, 560.0]], [[125.0, 431.0], [151.0, 431.0], [151.0, 545.0], [125.0, 545.0]]], "lines": ["強引だし", "偉そうだし", "口悪いし。"]}, {"box": [479, 1028, 586, 1214], "vertical": true, "font_size": 22, "lines_coords": [[[562.0, 1028.0], [584.0, 1028.0], [584.0, 1214.0], [562.0, 1214.0]], [[534.0, 1029.0], [556.0, 1029.0], [556.0, 1214.0], [534.0, 1214.0]], [[504.0, 1028.0], [526.0, 1028.0], [526.0, 1212.0], [504.0, 1212.0]], [[479.0, 1028.0], [500.0, 1028.0], [500.0, 1179.0], [479.0, 1179.0]]], "lines": ["．．．むしろあたしは", "君に南条を救って", "やって欲しいって", "思ってんだァ。"]}, {"box": [112, 740, 240, 935], "vertical": true, "font_size": 22, "lines_coords": [[[209.0, 742.0], [237.0, 740.0], [240.0, 814.0], [212.0, 815.0]], [[189.0, 743.0], [210.0, 743.0], [210.0, 906.0], [189.0, 906.0]], [[164.0, 743.0], [185.0, 743.0], [185.0, 935.0], [164.0, 935.0]], [[137.0, 745.0], [159.0, 745.0], [159.0, 907.0], [137.0, 907.0]], [[112.0, 745.0], [132.0, 745.0], [132.0, 892.0], [112.0, 892.0]]], "lines": ["．．．まぁ", "南条は君のこと", "救ってあげたいって", "つもりなのかも", "しれないけど、"]}, {"box": [917, 1332, 998, 1459], "vertical": true, "font_size": 25, "lines_coords": [[[970.0, 1332.0], [998.0, 1332.0], [998.0, 1407.0], [970.0, 1407.0]], [[945.0, 1334.0], [967.0, 1334.0], [967.0, 1450.0], [945.0, 1450.0]], [[917.0, 1334.0], [939.0, 1334.0], [939.0, 1459.0], [917.0, 1459.0]]], "lines": ["ヤツは", "例えるなら", "白鳥だから。"]}, {"box": [839, 1437, 895, 1534], "vertical": true, "font_size": 25, "lines_coords": [[[873.0, 1442.0], [895.0, 1442.0], [895.0, 1534.0], [873.0, 1534.0]], [[839.0, 1439.0], [868.0, 1437.0], [871.0, 1521.0], [842.0, 1523.0]]], "lines": ["いろんな", "意味で。"]}, {"box": [442, 1398, 523, 1535], "vertical": true, "font_size": 24, "lines_coords": [[[496.0, 1398.0], [523.0, 1398.0], [523.0, 1490.0], [496.0, 1490.0]], [[470.0, 1398.0], [492.0, 1398.0], [492.0, 1535.0], [470.0, 1535.0]], [[442.0, 1398.0], [464.0, 1398.0], [464.0, 1521.0], [442.0, 1521.0]]], "lines": ["みにくい", "アヒルの子の", "なれの果て。"]}, {"box": [129, 1162, 217, 1290], "vertical": true, "font_size": 26, "lines_coords": [[[182.0, 1162.0], [217.0, 1162.0], [217.0, 1262.0], [182.0, 1262.0]], [[154.0, 1162.0], [187.0, 1162.0], [187.0, 1260.0], [154.0, 1260.0]], [[129.0, 1164.0], [156.0, 1164.0], [156.0, 1290.0], [129.0, 1290.0]]], "lines": ["水面下で", "バタバタ", "もがいてさ。"]}, {"box": [65, 1364, 171, 1526], "vertical": true, "font_size": 26, "lines_coords": [[[148.0, 1364.0], [170.0, 1364.0], [171.0, 1504.0], [150.0, 1504.0]], [[121.0, 1364.0], [143.0, 1364.0], [143.0, 1504.0], [121.0, 1504.0]], [[92.0, 1364.0], [114.0, 1364.0], [114.0, 1526.0], [92.0, 1526.0]], [[65.0, 1364.0], [87.0, 1364.0], [87.0, 1445.0], [65.0, 1445.0]]], "lines": ["諷々としてる", "ように見えて", "相当強がってる", "からね"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [931, 67, 1010, 260], "vertical": true, "font_size": 22, "lines_coords": [[[987.0, 68.0], [1010.0, 68.0], [1007.0, 209.0], [984.0, 209.0]], [[959.0, 70.0], [981.0, 70.0], [981.0, 232.0], [959.0, 232.0]], [[931.0, 67.0], [953.0, 67.0], [953.0, 260.0], [931.0, 260.0]]], "lines": ["南条のことは", "小学生の頃から", "ずっと見てるけど、"]}, {"box": [801, 198, 909, 373], "vertical": true, "font_size": 22, "lines_coords": [[[887.0, 201.0], [909.0, 201.0], [909.0, 317.0], [887.0, 317.0]], [[859.0, 201.0], [881.0, 201.0], [881.0, 360.0], [859.0, 360.0]], [[831.0, 200.0], [853.0, 200.0], [853.0, 339.0], [831.0, 339.0]], [[803.0, 198.0], [826.0, 198.0], [825.0, 373.0], [801.0, 373.0]]], "lines": ["肌身離さず", "スケッチブック", "持ち歩いてる", "ような子供でさ。"]}, {"box": [128, 223, 239, 415], "vertical": true, "font_size": 25, "lines_coords": [[[212.0, 223.0], [239.0, 223.0], [239.0, 343.0], [212.0, 343.0]], [[185.0, 225.0], [207.0, 225.0], [207.0, 364.0], [185.0, 364.0]], [[156.0, 225.0], [182.0, 225.0], [182.0, 415.0], [156.0, 415.0]], [[128.0, 225.0], [154.0, 225.0], [154.0, 331.0], [128.0, 331.0]]], "lines": ["中高と絵で", "県知事賞とか", "バンバン取っちゃう", "カンジで。"]}, {"box": [857, 510, 993, 696], "vertical": true, "font_size": 23, "lines_coords": [[[971.0, 514.0], [993.0, 514.0], [993.0, 629.0], [971.0, 629.0]], [[942.0, 510.0], [964.0, 510.0], [964.0, 696.0], [942.0, 696.0]], [[915.0, 512.0], [935.0, 512.0], [935.0, 654.0], [915.0, 654.0]], [[885.0, 510.0], [906.0, 510.0], [906.0, 696.0], [885.0, 696.0]], [[859.0, 510.0], [881.0, 510.0], [879.0, 635.0], [857.0, 635.0]]], "lines": ["．．．完っ全に", "天才気取りだった", "からなー．．．", "実際才能はあった", "と思うけど"]}, {"box": [795, 740, 907, 940], "vertical": true, "font_size": 23, "lines_coords": [[[881.0, 740.0], [907.0, 740.0], [904.0, 882.0], [878.0, 882.0]], [[850.0, 742.0], [876.0, 742.0], [876.0, 940.0], [850.0, 940.0]], [[825.0, 740.0], [848.0, 740.0], [846.0, 906.0], [823.0, 906.0]], [[796.0, 740.0], [818.0, 740.0], [817.0, 935.0], [795.0, 935.0]]], "lines": ["要するに続か", "なかったんだよね。", "あっという間に", "枯渇したというか。"]}, {"box": [137, 882, 246, 1117], "vertical": true, "font_size": 23, "lines_coords": [[[223.0, 885.0], [245.0, 885.0], [245.0, 1048.0], [223.0, 1048.0]], [[193.0, 882.0], [215.0, 882.0], [215.0, 1068.0], [193.0, 1068.0]], [[164.0, 884.0], [190.0, 884.0], [189.0, 1117.0], [162.0, 1117.0]], [[137.0, 884.0], [159.0, 884.0], [159.0, 1078.0], [137.0, 1078.0]]], "lines": ["あたしと一緒に", "早稲田入ったけど", "色んなドタバタで結局", "中退しちゃったし。"]}, {"box": [867, 1212, 978, 1421], "vertical": true, "font_size": 24, "lines_coords": [[[951.0, 1212.0], [978.0, 1212.0], [978.0, 1310.0], [951.0, 1310.0]], [[923.0, 1214.0], [945.0, 1214.0], [945.0, 1421.0], [923.0, 1421.0]], [[895.0, 1214.0], [918.0, 1214.0], [917.0, 1376.0], [893.0, 1376.0]], [[867.0, 1212.0], [889.0, 1212.0], [889.0, 1357.0], [867.0, 1357.0]]], "lines": ["今でこそ", "趣味で絵本作るとか", "一線退いたこと", "言ってるけど、"]}, {"box": [956, 1507, 973, 1573], "vertical": true, "font_size": 17, "lines_coords": [[[956.0, 1507.0], [973.0, 1507.0], [973.0, 1573.0], [956.0, 1573.0]]], "lines": ["だからなんだ"]}, {"box": [776, 1375, 828, 1493], "vertical": true, "font_size": 24, "lines_coords": [[[801.0, 1375.0], [828.0, 1375.0], [828.0, 1473.0], [801.0, 1473.0]], [[776.0, 1376.0], [798.0, 1376.0], [798.0, 1493.0], [776.0, 1493.0]]], "lines": ["．．．本心は", "どうかな？"]}, {"box": [125, 1285, 262, 1500], "vertical": true, "font_size": 24, "lines_coords": [[[237.0, 1290.0], [259.0, 1290.0], [259.0, 1475.0], [237.0, 1475.0]], [[209.0, 1290.0], [231.0, 1290.0], [231.0, 1451.0], [209.0, 1451.0]], [[179.0, 1287.0], [206.0, 1287.0], [203.0, 1453.0], [176.0, 1453.0]], [[151.0, 1285.0], [178.0, 1285.0], [176.0, 1500.0], [150.0, 1500.0]], [[126.0, 1287.0], [148.0, 1287.0], [146.0, 1442.0], [125.0, 1442.0]]], "lines": ["あたしはそろそろ", "アイツの迷走に", "とどめを刺して", "やったほうがいいと", "思ってんのね。"]}], "img_path": "075.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [929, 39, 954, 162], "vertical": true, "font_size": 22, "lines_coords": [[[929.0, 43.0], [951.0, 43.0], [951.0, 157.0], [929.0, 157.0]]], "lines": ["．．．ところで"]}, {"box": [703, 39, 775, 220], "vertical": true, "font_size": 20, "lines_coords": [[[753.0, 39.0], [773.0, 39.0], [773.0, 220.0], [753.0, 220.0]], [[728.0, 39.0], [748.0, 39.0], [748.0, 178.0], [728.0, 178.0]], [[703.0, 40.0], [723.0, 40.0], [723.0, 192.0], [703.0, 192.0]]], "lines": ["南条の子供の頃の", "本当の夢って、", "なんだと思う？"]}, {"box": [576, 93, 603, 207], "vertical": true, "font_size": 27, "lines_coords": [[[576.0, 93.0], [603.0, 93.0], [603.0, 207.0], [576.0, 207.0]]], "lines": ["．．．漫画家。"]}, {"box": [90, 143, 227, 307], "vertical": true, "font_size": 22, "lines_coords": [[[203.0, 146.0], [225.0, 146.0], [225.0, 306.0], [203.0, 306.0]], [[173.0, 145.0], [196.0, 145.0], [198.0, 292.0], [175.0, 292.0]], [[146.0, 146.0], [168.0, 146.0], [168.0, 284.0], [146.0, 284.0]], [[118.0, 146.0], [140.0, 146.0], [140.0, 306.0], [118.0, 306.0]], [[92.0, 143.0], [114.0, 143.0], [112.0, 292.0], [90.0, 292.0]]], "lines": ["大学ん時は本腰", "入れてたけど、", "連載直前まで", "行って結局流れ", "ちゃったから。"]}, {"box": [890, 640, 965, 778], "vertical": true, "font_size": 20, "lines_coords": [[[948.0, 642.0], [965.0, 642.0], [965.0, 756.0], [948.0, 756.0]], [[917.0, 642.0], [939.0, 642.0], [939.0, 778.0], [917.0, 778.0]], [[890.0, 640.0], [912.0, 640.0], [912.0, 765.0], [890.0, 765.0]]], "lines": ["．．．アイツは", "話が作れない", "みたいでね。"]}, {"box": [109, 407, 223, 569], "vertical": true, "font_size": 26, "lines_coords": [[[196.0, 409.0], [223.0, 409.0], [223.0, 503.0], [196.0, 503.0]], [[168.0, 409.0], [196.0, 409.0], [196.0, 503.0], [168.0, 503.0]], [[142.0, 410.0], [164.0, 410.0], [164.0, 568.0], [142.0, 568.0]], [[109.0, 409.0], [137.0, 407.0], [140.0, 490.0], [112.0, 492.0]]], "lines": ["挫折感が", "強すぎて", "封印するつもり", "らしい。"]}, {"box": [815, 768, 864, 953], "vertical": true, "font_size": 20, "lines_coords": [[[843.0, 771.0], [864.0, 771.0], [864.0, 953.0], [843.0, 953.0]], [[815.0, 768.0], [835.0, 768.0], [835.0, 934.0], [815.0, 934.0]]], "lines": ["一時期は熱っぽく", "語ってたけどさ。"]}, {"box": [145, 962, 260, 1178], "vertical": true, "font_size": 37, "lines_coords": [[[228.0, 962.0], [259.0, 962.0], [256.0, 1148.0], [225.0, 1148.0]], [[190.0, 964.0], [223.0, 964.0], [220.0, 1178.0], [187.0, 1178.0]], [[145.0, 962.0], [192.0, 962.0], [192.0, 1046.0], [145.0, 1046.0]]], "lines": ["漫画で世界を", "ぶっ壊してやる", "って。"]}], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [913, 77, 939, 222], "vertical": true, "font_size": 21, "lines_coords": [[[914.0, 137.0], [935.0, 137.0], [935.0, 217.0], [914.0, 217.0]]], "lines": ["～～ん"]}, {"box": [928, 351, 956, 425], "vertical": true, "font_size": 26, "lines_coords": [[[928.0, 351.0], [956.0, 351.0], [956.0, 425.0], [928.0, 425.0]]], "lines": ["．．．あ"]}, {"box": [132, 104, 222, 285], "vertical": true, "font_size": 26, "lines_coords": [[[193.0, 107.0], [221.0, 107.0], [221.0, 235.0], [193.0, 235.0]], [[160.0, 104.0], [187.0, 104.0], [190.0, 285.0], [164.0, 285.0]], [[132.0, 106.0], [154.0, 106.0], [154.0, 259.0], [132.0, 259.0]]], "lines": ["ママの所で", "一杯だけ飲んで", "行こうかな．．"]}, {"box": [289, 321, 317, 404], "vertical": true, "font_size": 24, "lines_coords": [[[293.0, 321.0], [317.0, 323.0], [312.0, 404.0], [289.0, 403.0]]], "lines": ["う～あぁ"]}, {"box": [814, 442, 906, 625], "vertical": true, "font_size": 26, "lines_coords": [[[879.0, 445.0], [906.0, 445.0], [906.0, 601.0], [879.0, 601.0]], [[850.0, 446.0], [871.0, 446.0], [871.0, 625.0], [850.0, 625.0]], [[814.0, 442.0], [840.0, 442.0], [843.0, 559.0], [817.0, 559.0]]], "lines": ["コメンゴメン", "君は飲めないん", "でしたな。"]}, {"box": [582, 1075, 683, 1284], "vertical": true, "font_size": 27, "lines_coords": [[[582.0, 1167.0], [609.0, 1167.0], [609.0, 1284.0], [582.0, 1284.0]]], "lines": ["ホントに？"]}, {"box": [132, 750, 231, 860], "vertical": true, "font_size": 33, "lines_coords": [[[198.0, 750.0], [231.0, 750.0], [228.0, 860.0], [195.0, 860.0]], [[164.0, 753.0], [196.0, 753.0], [196.0, 860.0], [164.0, 860.0]], [[132.0, 751.0], [165.0, 751.0], [165.0, 834.0], [132.0, 834.0]]], "lines": ["どっかで", "お茶でも", "する？"]}, {"box": [822, 1134, 912, 1368], "vertical": true, "font_size": 23, "lines_coords": [[[885.0, 1135.0], [912.0, 1135.0], [912.0, 1250.0], [885.0, 1250.0]], [[854.0, 1135.0], [876.0, 1135.0], [876.0, 1285.0], [854.0, 1285.0]], [[825.0, 1137.0], [845.0, 1137.0], [845.0, 1362.0], [825.0, 1362.0]]], "lines": ["「：今日は", "早めに帰って", "書き直しをします。"]}, {"box": [149, 1157, 175, 1324], "vertical": true, "font_size": 21, "lines_coords": [[[150.0, 1157.0], [171.0, 1157.0], [171.0, 1321.0], [150.0, 1321.0]]], "lines": ["．．．ありがとう"]}], "img_path": "077.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [490, 15, 600, 219], "vertical": true, "font_size": 31, "lines_coords": [[[568.0, 18.0], [600.0, 18.0], [600.0, 190.0], [568.0, 190.0]], [[529.0, 17.0], [560.0, 17.0], [560.0, 200.0], [529.0, 200.0]], [[490.0, 17.0], [521.0, 17.0], [521.0, 215.0], [490.0, 215.0]]], "lines": ["「南条さんは、", "漫画じゃダメ", "なんですか？」"]}, {"box": [362, 337, 390, 432], "vertical": true, "font_size": 28, "lines_coords": [[[362.0, 337.0], [390.0, 337.0], [390.0, 432.0], [362.0, 432.0]]], "lines": ["．．．それ。"]}, {"box": [103, 879, 162, 1034], "vertical": true, "font_size": 26, "lines_coords": [[[134.0, 879.0], [160.0, 879.0], [160.0, 1034.0], [134.0, 1034.0]], [[103.0, 879.0], [129.0, 879.0], [129.0, 984.0], [103.0, 984.0]]], "lines": ["蟹江に聞いた", "でしょ？"]}, {"box": [928, 1152, 954, 1262], "vertical": true, "font_size": 26, "lines_coords": [[[928.0, 1153.0], [954.0, 1153.0], [954.0, 1242.0], [928.0, 1242.0]]], "lines": ["ん〜〜〜"]}, {"box": [168, 1360, 195, 1491], "vertical": true, "font_size": 27, "lines_coords": [[[168.0, 1360.0], [195.0, 1360.0], [195.0, 1454.0], [168.0, 1454.0]]], "lines": ["ん～～～"]}], "img_path": "078.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [910, 54, 939, 167], "vertical": true, "font_size": 29, "lines_coords": [[[910.0, 54.0], [939.0, 54.0], [939.0, 167.0], [910.0, 167.0]]], "lines": ["．．．やっぱ、"]}, {"box": [160, 175, 219, 304], "vertical": true, "font_size": 26, "lines_coords": [[[192.0, 176.0], [218.0, 176.0], [218.0, 281.0], [192.0, 281.0]], [[160.0, 176.0], [187.0, 176.0], [187.0, 304.0], [160.0, 304.0]]], "lines": ["今はまだ", "無理かな．．．"]}, {"box": [956, 409, 978, 509], "vertical": true, "font_size": 22, "lines_coords": [[[956.0, 409.0], [978.0, 409.0], [978.0, 509.0], [956.0, 509.0]]], "lines": ["．．．てもね"]}, {"box": [818, 468, 920, 643], "vertical": true, "font_size": 22, "lines_coords": [[[900.0, 468.0], [920.0, 468.0], [920.0, 610.0], [900.0, 610.0]], [[873.0, 470.0], [895.0, 470.0], [895.0, 610.0], [873.0, 610.0]], [[843.0, 468.0], [867.0, 468.0], [868.0, 643.0], [845.0, 643.0]], [[818.0, 471.0], [842.0, 471.0], [842.0, 546.0], [818.0, 546.0]]], "lines": ["今日はなんか", "ムキになって", "ダメ出ししちゃっ", "たけど、"]}, {"box": [307, 412, 384, 596], "vertical": true, "font_size": 23, "lines_coords": [[[362.0, 412.0], [384.0, 412.0], [384.0, 551.0], [362.0, 551.0]], [[334.0, 412.0], [356.0, 412.0], [356.0, 596.0], [334.0, 596.0]], [[307.0, 412.0], [328.0, 412.0], [328.0, 579.0], [307.0, 579.0]]], "lines": ["というか正直", "作品自体は２０点の", "出来なんだけど、"]}, {"box": [131, 478, 237, 642], "vertical": true, "font_size": 23, "lines_coords": [[[214.0, 478.0], [237.0, 478.0], [235.0, 642.0], [212.0, 642.0]], [[185.0, 479.0], [207.0, 479.0], [207.0, 596.0], [185.0, 596.0]], [[157.0, 478.0], [184.0, 478.0], [181.0, 620.0], [154.0, 620.0]], [[131.0, 481.0], [153.0, 481.0], [153.0, 606.0], [131.0, 606.0]]], "lines": ["君が書いてきて", "くれたのは", "すっごい嬉し", "かったんだ。"]}, {"box": [837, 818, 865, 906], "vertical": true, "font_size": 28, "lines_coords": [[[837.0, 818.0], [865.0, 818.0], [865.0, 906.0], [837.0, 906.0]]], "lines": ["だから、"]}, {"box": [217, 816, 277, 973], "vertical": true, "font_size": 24, "lines_coords": [[[250.0, 817.0], [276.0, 817.0], [276.0, 973.0], [250.0, 973.0]], [[220.0, 817.0], [243.0, 817.0], [240.0, 954.0], [217.0, 954.0]]], "lines": ["今日の君には", "１００点あげる"]}], "img_path": "079.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "080.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "081.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [907, 109, 989, 298], "vertical": true, "font_size": 23, "lines_coords": [[[967.0, 110.0], [989.0, 110.0], [989.0, 298.0], [967.0, 298.0]], [[939.0, 110.0], [960.0, 110.0], [960.0, 281.0], [939.0, 281.0]], [[907.0, 109.0], [935.0, 109.0], [935.0, 189.0], [907.0, 189.0]]], "lines": ["鉄筋コンクリート", "１０階建ての８階、", "築１５年、"]}, {"box": [829, 260, 881, 448], "vertical": true, "font_size": 23, "lines_coords": [[[859.0, 260.0], [881.0, 260.0], [881.0, 448.0], [859.0, 448.0]], [[831.0, 260.0], [854.0, 260.0], [853.0, 426.0], [829.0, 426.0]]], "lines": ["ワンルームだけど", "３５平米あるから"]}, {"box": [803, 260, 882, 473], "vertical": true, "font_size": 21, "lines_coords": [[[804.0, 260.0], [825.0, 260.0], [825.0, 473.0], [804.0, 473.0]]], "lines": ["生活はしやすいよね。"]}, {"box": [470, 87, 579, 276], "vertical": true, "font_size": 23, "lines_coords": [[[553.0, 87.0], [579.0, 87.0], [579.0, 253.0], [553.0, 253.0]], [[526.0, 89.0], [548.0, 89.0], [548.0, 276.0], [526.0, 276.0]], [[498.0, 87.0], [520.0, 87.0], [520.0, 253.0], [498.0, 253.0]], [[470.0, 89.0], [492.0, 89.0], [492.0, 215.0], [470.0, 215.0]]], "lines": ["ここら辺、低い", "建物ばかりだから", "眺めも抜けてて", "最高でしょ。"]}, {"box": [231, 239, 309, 382], "vertical": true, "font_size": 22, "lines_coords": [[[287.0, 240.0], [309.0, 240.0], [309.0, 382.0], [287.0, 382.0]], [[256.0, 239.0], [282.0, 239.0], [282.0, 337.0], [256.0, 337.0]], [[231.0, 239.0], [251.0, 239.0], [251.0, 368.0], [231.0, 368.0]]], "lines": ["駅徒歩５分で", "８万なら", "相場だよね。"]}, {"box": [17, 292, 67, 459], "vertical": true, "font_size": 50, "lines_coords": [[[17.0, 292.0], [67.0, 292.0], [67.0, 459.0], [17.0, 459.0]]], "lines": ["第８３話"]}, {"box": [160, 462, 239, 604], "vertical": true, "font_size": 22, "lines_coords": [[[217.0, 464.0], [239.0, 464.0], [239.0, 604.0], [217.0, 604.0]], [[1