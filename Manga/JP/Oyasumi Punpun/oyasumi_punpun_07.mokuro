0], [5256.0, 1480.0], [4909.0, 1480.0]]], "lines": ["おやすみブンフン", "美野いにお", "ソラニン全２巻", "えーいーの浅野いにお", "ほしのふるまち全７巻", "原秀見", "はしいかるより、エノセーボンドの福音。全４巻", "高橋留美子", "「ハンドレス・ローコトー診療所・１〜５５巻", "山田さん", "長尾謙", "おしゃれ手帖、全１０巻", "マンションは、土地の中小日の川にコンテンツというので、全部巻一安部課二ノ補領正", "ゆうきまで", "特別にして、鉄腕バーティー全２０巻", "室積光ノ猪熊しのふ", "鉄腕ハーブイーキの都立水商】全２２巻カード", "黒丸〈夏原", "クロサギ、全２０巻", "クロジャ・エール１キガミ・ＴｈｅｖｉｔｍｅｎｔｅｒＬｉｎｔ１〜２０１８年１－８巻ーー間瀬元期", "「「インニックラ」の買・１－１－０港", "高橋のまる", "上里、七、超無気力戦隊ジャパ「Ｙａｈｏｏ！！高橋のファイブ全日巻、佐藤まさき", "石渡治", "Ｏｄｄｅ－オッス．．．＋７巻", "しばらくパンペーキーをさらんぼジトロームなんか思いました。", "タナトスポイントロービーのタブトスでしたが、全日巻ーーー竹原慎二〈落合裕", "とめはねっ！！お里雨内書館が", "このコースは、コーフ巻、河合克服", "ビーチスターズ、全て巻", "森尾正博", "セーナスターメース、主催者の設定試合・金田巻・木駅ファム・", "美晴♥ライジング全５巻", "大谷じゃ", "夫婦．．．暁のイージス、全日巻", "あんころ。細君が下記映像を", "．．．本秋重", "ＧＯ－ＯＮ＿全４巻", "ＤＵ－ＵＮ．±４＠ドライブ・ア・ライフ・"]}, {"box": [3377, 1556, 4278, 1631], "vertical": false, "font_size": 62, "lines_coords": [[[3400.0, 1568.0], [3747.0, 1568.0], [3747.0, 1635.0], [3400.0, 1635.0]]], "lines": ["これは、あるフツーの"]}, {"box": [4845, 1532, 5644, 1668], "vertical": false, "font_size": 149, "lines_coords": [[[4845.0, 1519.0], [5644.0, 1519.0], [5644.0, 1681.0], [4845.0, 1681.0]]], "lines": ["「プンフン」グッズ・"]}, {"box": [4863, 1710, 5581, 1904], "vertical": false, "font_size": 71.5, "lines_coords": [[[4863.0, 1710.0], [5581.0, 1710.0], [5581.0, 1790.0], [4863.0, 1790.0]], [[4903.0, 1841.0], [5313.0, 1841.0], [5313.0, 1904.0], [4903.0, 1904.0]]], "lines": ["続々大好評発売", "詳しくは、下記サイトへ！"]}, {"box": [4846, 1879, 5579, 2337], "vertical": false, "font_size": 74, "lines_coords": [[[4846.0, 1898.0], [5524.0, 1898.0], [5524.0, 2046.0], [4846.0, 2046.0]], [[4863.0, 2023.0], [5199.0, 2023.0], [5199.0, 2092.0], [4863.0, 2092.0]], [[4863.0, 2051.0], [5359.0, 2051.0], [5359.0, 2138.0], [4863.0, 2138.0]], [[4869.0, 2126.0], [5439.0, 2126.0], [5439.0, 2195.0], [4869.0, 2195.0]], [[4858.0, 2165.0], [5216.0, 2177.0], [5216.0, 2246.0], [4858.0, 2234.0]], [[4858.0, 2228.0], [5490.0, 2234.0], [5490.0, 2303.0], [4858.0, 2297.0]], [[4886.0, 2291.0], [5336.0, 2291.0], [5336.0, 2343.0], [4886.0, 2343.0]]], "lines": ["「詳しくは、お盆のイベント・●タイプにデータを利用しております。お客様のお問い合わせでしょうから", "●ビームスＴＣＴシャツ", "●ビームスＴＹＴＹＯシャツＮｉｔｈｏｒ／／Ｗｉｎｄｏｗｓｈａｍｅｃｏ！アイドルクイメージャーチャーセンターの", "●ムービック（ボーチ指入形マスコット）", "●ムービック（ポーチ指ｈｔｔｐ：／／ｗｗｗ．ｍｏｒ）に、コーフパンセルジネス", "●コスパ（ぬいぐるみ「シャツキーホルター", "この人がいないくるみーーーダックキーボロンバックを作りますのですが、"]}], "img_path": "004.png"}, {"version": "0.2.0-beta.6", "img_width": 2380, "img_height": 1600, "blocks": [{"box": [118, 723, 170, 1449], "vertical": true, "font_size": 40, "lines_coords": [[[125.0, 725.0], [165.0, 725.0], [158.0, 1434.0], [118.0, 1434.0]]], "lines": ["おやすみプソブンこの浅野いにお"]}, {"box": [1159, 88, 1231, 146], "vertical": false, "font_size": 63, "lines_coords": [[[1159.0, 83.0], [1231.0, 83.0], [1231.0, 151.0], [1159.0, 151.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹＣＤＭＣＳ"]}, {"box": [1176, 144, 1210, 876], "vertical": true, "font_size": 32, "lines_coords": [[[1178.0, 144.0], [1210.0, 144.0], [1208.0, 876.0], [1176.0, 876.0]]], "lines": ["おやすみフンフシア、浅野いにお"]}], "img_path": "005.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [581, 706, 710, 825], "vertical": true, "font_size": 52, "lines_coords": [[[656.0, 706.0], [710.0, 706.0], [710.0, 804.0], [656.0, 804.0]], [[581.0, 707.0], [620.0, 707.0], [620.0, 825.0], [581.0, 825.0]]], "lines": ["浅野", "いにお"]}, {"box": [828, 706, 979, 914], "vertical": true, "font_size": 52, "lines_coords": [[[925.0, 706.0], [979.0, 707.0], [973.0, 914.0], [918.0, 912.0]], [[828.0, 706.0], [890.0, 706.0], [890.0, 893.0], [828.0, 893.0]]], "lines": ["おやすみ", "プンプン"]}, {"box": [68, 1493, 277, 1516], "vertical": false, "font_size": 20, "lines_coords": [[[73.0, 1493.0], [268.0, 1494.0], [268.0, 1516.0], [73.0, 1514.0]]], "lines": ["ＹＯＵＮＧＳＵＮＤＡＹＣＯＭＣＳ"]}], "img_path": "006.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [589, 253, 659, 307], "vertical": false, "font_size": 38, "lines_coords": [[[589.0, 271.0], [648.0, 253.0], [659.0, 289.0], [600.0, 307.0]]], "lines": ["なん"]}, {"box": [767, 131, 892, 176], "vertical": false, "font_size": 39, "lines_coords": [[[767.0, 137.0], [890.0, 131.0], [892.0, 170.0], [768.0, 176.0]]], "lines": ["次日"]}, {"box": [250, 700, 389, 739], "vertical": false, "font_size": 39, "lines_coords": [[[250.0, 700.0], [389.0, 700.0], [389.0, 739.0], [250.0, 739.0]]], "lines": ["登場人物"]}, {"box": [240, 475, 533, 575], "vertical": false, "font_size": 38, "lines_coords": [[[246.0, 481.0], [531.0, 481.0], [531.0, 514.0], [246.0, 514.0]], [[240.0, 531.0], [453.0, 528.0], [453.0, 571.0], [240.0, 575.0]]], "lines": ["６巻までのあらすじ", "とくになし"]}, {"box": [348, 748, 606, 807], "vertical": false, "font_size": 28.5, "lines_coords": [[[348.0, 748.0], [521.0, 748.0], [521.0, 779.0], [348.0, 779.0]], [[348.0, 781.0], [606.0, 781.0], [606.0, 807.0], [348.0, 807.0]]], "lines": ["小野寺プンプン", "小野寺のプンプン。高校三年。"]}, {"box": [696, 143, 981, 987], "vertical": true, "font_size": 156, "lines_coords": [[[909.0, 240.0], [978.0, 240.0], [971.0, 929.0], [903.0, 929.0]], [[696.0, 143.0], [981.0, 143.0], [981.0, 987.0], [696.0, 987.0]], [[800.0, 879.0], [914.0, 879.0], [914.0, 925.0], [800.0, 925.0]]], "lines": ["・ａａｇｏｅｎｏｎは、", "日人第６８号第００９年会第７０１７年度第７１項の第７２７条第六条第八条第４条第７５組第第７記事第７項第", "７８話"]}, {"box": [345, 854, 489, 915], "vertical": false, "font_size": 37.0, "lines_coords": [[[345.0, 854.0], [485.0, 854.0], [485.0, 900.0], [345.0, 900.0]], [[353.0, 887.0], [489.0, 887.0], [489.0, 915.0], [353.0, 915.0]]], "lines": ["小野寺雄一ブンブンの叔父。", "プンプンの叔父。"]}, {"box": [334, 951, 467, 1039], "vertical": false, "font_size": 88, "lines_coords": [[[334.0, 951.0], [467.0, 951.0], [467.0, 1039.0], [334.0, 1039.0]]], "lines": ["小野寺君。小一生"]}, {"box": [354, 1075, 639, 1129], "vertical": false, "font_size": 27.0, "lines_coords": [[[354.0, 1075.0], [478.0, 1075.0], [478.0, 1103.0], [354.0, 1103.0]], [[354.0, 1103.0], [639.0, 1103.0], [639.0, 1129.0], [354.0, 1129.0]]], "lines": ["三村雷之進", "３００年ぶりに復活した伝説の巨大"]}], "img_path": "007.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 160