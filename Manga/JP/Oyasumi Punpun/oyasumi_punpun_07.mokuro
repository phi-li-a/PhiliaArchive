じらせたから", "遅咲きの狂い咲きで", "毎晩やりまくって", "るな、きっと。"]}, {"box": [576, 1326, 635, 1500], "vertical": true, "font_size": 24, "lines_coords": [[[612.0, 1326.0], [634.0, 1326.0], [634.0, 1500.0], [612.0, 1500.0]], [[579.0, 1348.0], [606.0, 1348.0], [603.0, 1500.0], [576.0, 1500.0]]], "lines": ["●名前さくほど", "野暮じゃない"]}, {"box": [104, 1340, 168, 1495], "vertical": true, "font_size": 30, "lines_coords": [[[135.0, 1342.0], [168.0, 1342.0], [168.0, 1423.0], [135.0, 1423.0]], [[107.0, 1340.0], [134.0, 1340.0], [131.0, 1495.0], [104.0, 1495.0]]], "lines": ["まして", "身の上話など"]}], "img_path": "209.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [715, 84, 821, 250], "vertical": true, "font_size": 23, "lines_coords": [[[795.0, 87.0], [821.0, 87.0], [821.0, 250.0], [795.0, 250.0]], [[767.0, 84.0], [793.0, 84.0], [790.0, 250.0], [764.0, 250.0]], [[740.0, 87.0], [762.0, 87.0], [762.0, 246.0], [740.0, 246.0]], [[715.0, 89.0], [732.0, 89.0], [732.0, 198.0], [715.0, 198.0]]], "lines": ["．．．君達、あの日", "結局うまくいか", "なかったらしい", "じゃない？"]}, {"box": [623, 64, 650, 325], "vertical": true, "font_size": 28, "lines_coords": [[[623.0, 64.0], [650.0, 64.0], [650.0, 325.0], [623.0, 325.0]]], "lines": ["♥そうよたまたま"]}, {"box": [584, 93, 612, 214], "vertical": true, "font_size": 28, "lines_coords": [[[584.0, 93.0], [612.0, 93.0], [612.0, 214.0], [584.0, 214.0]]], "lines": ["居酒屋で"]}, {"box": [95, 62, 164, 246], "vertical": true, "font_size": 30, "lines_coords": [[[132.0, 62.0], [164.0, 62.0], [164.0, 246.0], [132.0, 246.0]], [[95.0, 62.0], [123.0, 62.0], [123.0, 212.0], [95.0, 212.0]]], "lines": ["横にすわった", "だけだもの"]}, {"box": [549, 596, 656, 757], "vertical": true, "font_size": 20, "lines_coords": [[[631.0, 600.0], [653.0, 600.0], [653.0, 735.0], [631.0, 735.0]], [[603.0, 598.0], [625.0, 598.0], [625.0, 757.0], [603.0, 757.0]], [[575.0, 596.0], [596.0, 596.0], [596.0, 734.0], [575.0, 734.0]], [[550.0, 598.0], [567.0, 598.0], [567.0, 714.0], [550.0, 714.0]]], "lines": ["二人共なんか", "もじもじしてて", "鬱陶しかった", "もんなぁ～"]}, {"box": [98, 634, 178, 796], "vertical": true, "font_size": 24, "lines_coords": [[[151.0, 635.0], [178.0, 635.0], [178.0, 731.0], [151.0, 731.0]], [[126.0, 635.0], [148.0, 635.0], [148.0, 796.0], [126.0, 796.0]], [[98.0, 634.0], [120.0, 634.0], [121.0, 760.0], [100.0, 760.0]]], "lines": ["いかにも", "処女と童貞って", "感じてさぁ。"]}, {"box": [815, 857, 961, 1041], "vertical": true, "font_size": 31, "lines_coords": [[[928.0, 857.0], [960.0, 857.0], [960.0, 1009.0], [928.0, 1009.0]], [[890.0, 887.0], [923.0, 887.0], [923.0, 1010.0], [890.0, 1010.0]], [[853.0, 889.0], [885.0, 889.0], [885.0, 1010.0], [853.0, 1010.0]], [[817.0, 892.0], [845.0, 892.0], [845.0, 1040.0], [817.0, 1040.0]]], "lines": ["♥絵もない", "花もない", "歌もない", "飾る言葉も"]}, {"box": [302, 860, 408, 1021], "vertical": true, "font_size": 21, "lines_coords": [[[384.0, 862.0], [406.0, 862.0], [406.0, 1021.0], [384.0, 1021.0]], [[356.0, 860.0], [378.0, 860.0], [378.0, 1000.0], [356.0, 1000.0]], [[328.0, 860.0], [350.0, 860.0], [350.0, 998.0], [328.0, 998.0]], [[303.0, 862.0], [320.0, 862.0], [320.0, 965.0], [303.0, 965.0]]], "lines": ["大抵童貞なんて", "自己完結型で", "うざったいん", "だよなぁー"]}, {"box": [451, 1245, 520, 1458], "vertical": true, "font_size": 28, "lines_coords": [[[490.0, 1248.0], [517.0, 1248.0], [517.0, 1396.0], [490.0, 1396.0]], [[451.0, 1245.0], [479.0, 1245.0], [481.0, 1457.0], [453.0, 1457.0]]], "lines": ["洒落もない", "そんな居酒屋で"]}, {"box": [184, 1185, 282, 1348], "vertical": true, "font_size": 22, "lines_coords": [[[259.0, 1185.0], [281.0, 1185.0], [282.0, 1337.0], [260.0, 1337.0]], [[232.0, 1185.0], [254.0, 1185.0], [254.0, 1348.0], [232.0, 1348.0]], [[209.0, 1187.0], [231.0, 1187.0], [231.0, 1310.0], [209.0, 1310.0]], [[184.0, 1187.0], [204.0, 1187.0], [204.0, 1315.0], [184.0, 1315.0]]], "lines": ["ほとんどの場合、", "自分が一番正しい", "って思ってる", "からな奴らは。"]}, {"box": [82, 1348, 179, 1534], "vertical": true, "font_size": 22, "lines_coords": [[[157.0, 1348.0], [179.0, 1348.0], [179.0, 1534.0], [157.0, 1534.0]], [[134.0, 1348.0], [154.0, 1348.0], [151.0, 1534.0], [131.0, 1534.0]], [[107.0, 1348.0], [128.0, 1348.0], [128.0, 1532.0], [107.0, 1532.0]], [[82.0, 1348.0], [106.0, 1348.0], [106.0, 1414.0], [82.0, 1414.0]]], "lines": ["自分の主張ばっかで", "人の話聞かない男に", "オンナが出来るかっ", "つの！！"]}], "img_path": "210.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [912, 84, 1017, 292], "vertical": true, "font_size": 23, "lines_coords": [[[995.0, 85.0], [1017.0, 85.0], [1017.0, 201.0], [995.0, 201.0]], [[965.0, 84.0], [987.0, 84.0], [987.0, 257.0], [965.0, 257.0]], [[937.0, 84.0], [964.0, 84.0], [962.0, 292.0], [935.0, 292.0]], [[912.0, 84.0], [932.0, 84.0], [932.0, 246.0], [912.0, 246.0]]], "lines": ["．．．とはいえ", "梓ちゃん、あの後", "けっこー落ち込んで", "だからねー．．．"]}, {"box": [834, 295, 914, 470], "vertical": true, "font_size": 23, "lines_coords": [[[892.0, 298.0], [914.0, 298.0], [914.0, 446.0], [892.0, 446.0]], [[862.0, 296.0], [889.0, 296.0], [889.0, 440.0], [862.0, 440.0]], [[837.0, 295.0], [859.0, 295.0], [856.0, 470.0], [834.0, 470.0]]], "lines": ["彼女、君のこと", "けっこー好き", "だったっぽいよ？"]}, {"box": [135, 475, 245, 663], "vertical": true, "font_size": 23, "lines_coords": [[[218.0, 476.0], [240.0, 476.0], [240.0, 659.0], [218.0, 659.0]], [[192.0, 476.0], [214.0, 476.0], [214.0, 642.0], [192.0, 642.0]], [[162.0, 475.0], [189.0, 475.0], [189.0, 593.0], [162.0, 593.0]], [[135.0, 479.0], [157.0, 479.0], [157.0, 662.0], [135.0, 662.0]]], "lines": ["つか、その状況で", "落とせないって", "どんなへマ", "やったんだよ～～"]}, {"box": [876, 732, 1003, 965], "vertical": true, "font_size": 29, "lines_coords": [[[976.0, 732.0], [1003.0, 732.0], [1003.0, 915.0], [976.0, 915.0]], [[945.0, 759.0], [971.0, 759.0], [971.0, 865.0], [945.0, 865.0]], [[910.0, 757.0], [945.0, 757.0], [945.0, 842.0], [910.0, 842.0]], [[881.0, 757.0], [909.0, 757.0], [904.0, 965.0], [876.0, 965.0]]], "lines": ["♣外へ出たなら", "雨だろう", "さっき", "小雨がパラついた"]}, {"box": [970, 1071, 1000, 1201], "vertical": true, "font_size": 27, "lines_coords": [[[970.0, 1071.0], [996.0, 1071.0], [1000.0, 1201.0], [973.0, 1201.0]]], "lines": ["♠それじゃ"]}, {"box": [112, 746, 235, 950], "vertical": true, "font_size": 27, "lines_coords": [[[201.0, 751.0], [232.0, 751.0], [235.0, 950.0], [204.0, 950.0]], [[173.0, 759.0], [201.0, 759.0], [201.0, 889.0], [173.0, 889.0]], [[140.0, 760.0], [167.0, 760.0], [167.0, 912.0], [140.0, 912.0]], [[112.0, 760.0], [134.0, 760.0], [134.0, 884.0], [112.0, 884.0]]], "lines": ["いいわやむまで", "此処にいて", "一人グイグイ", "のんでるわ"]}, {"box": [114, 1082, 178, 1293], "vertical": true, "font_size": 32, "lines_coords": [[[139.0, 1082.0], [178.0, 1082.0], [178.0, 1171.0], [139.0, 1171.0]], [[114.0, 1085.0], [140.0, 1085.0], [140.0, 1293.0], [114.0, 1293.0]]], "lines": ["あなた", "さっきと帰ってよ"]}, {"box": [940, 1100, 967, 1300], "vertical": true, "font_size": 27, "lines_coords": [[[940.0, 1100.0], [967.0, 1100.0], [967.0, 1300.0], [940.0, 1300.0]]], "lines": ["朝までつき合うか"]}, {"box": [406, 1087, 437, 1410], "vertical": true, "font_size": 28, "lines_coords": [[[407.0, 1087.0], [435.0, 1087.0], [434.0, 1410.0], [406.0, 1410.0]]], "lines": ["♥別に気にすることはない"]}, {"box": [509, 1356, 567, 1483], "vertical": true, "font_size": 25, "lines_coords": [[[539.0, 1356.0], [567.0, 1356.0], [567.0, 1459.0], [539.0, 1459.0]], [[509.0, 1357.0], [531.0, 1357.0], [531.0, 1481.0], [509.0, 1481.0]]], "lines": ["悪い女と", "知り合った"]}], "img_path": "211.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [935, 70, 965, 143], "vertical": true, "font_size": 29, "lines_coords": [[[935.0, 70.0], [965.0, 70.0], [965.0, 143.0], [935.0, 143.0]]], "lines": ["あ．．．．．"]}, {"box": [890, 153, 921, 260], "vertical": true, "font_size": 29, "lines_coords": [[[893.0, 153.0], [921.0, 153.0], [918.0, 260.0], [890.0, 260.0]]], "lines": ["ごめーん。"]}, {"box": [410, 18, 532, 171], "vertical": true, "font_size": 26, "lines_coords": [[[504.0, 18.0], [531.0, 18.0], [531.0, 146.0], [504.0, 146.0]], [[471.0, 42.0], [500.0, 42.0], [500.0, 146.0], [471.0, 146.0]], [[440.0, 43.0]