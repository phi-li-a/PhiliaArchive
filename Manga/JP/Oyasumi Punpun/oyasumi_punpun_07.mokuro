46, 970, 823], "vertical": true, "font_size": 32, "lines_coords": [[[942.0, 746.0], [970.0, 746.0], [970.0, 823.0], [942.0, 823.0]]], "lines": ["．．．ん？"]}, {"box": [134, 470, 226, 638], "vertical": true, "font_size": 27, "lines_coords": [[[193.0, 470.0], [226.0, 470.0], [226.0, 554.0], [193.0, 554.0]], [[164.0, 471.0], [190.0, 471.0], [190.0, 629.0], [164.0, 629.0]], [[134.0, 471.0], [156.0, 471.0], [156.0, 637.0], [134.0, 637.0]]], "lines": ["どうぞ", "適当に座って", "ちょうだいな。"]}, {"box": [815, 826, 920, 993], "vertical": true, "font_size": 32, "lines_coords": [[[878.0, 826.0], [920.0, 826.0], [920.0, 898.0], [878.0, 898.0]], [[853.0, 840.0], [879.0, 840.0], [879.0, 993.0], [853.0, 993.0]], [[818.0, 834.0], [851.0, 835.0], [848.0, 921.0], [815.0, 920.0]]], "lines": ["表の", "二万五千円の", "部屋？"]}, {"box": [143, 809, 231, 991], "vertical": true, "font_size": 24, "lines_coords": [[[206.0, 862.0], [229.0, 862.0], [229.0, 917.0], [206.0, 917.0]], [[206.0, 812.0], [229.0, 812.0], [229.0, 871.0], [206.0, 871.0]], [[173.0, 809.0], [200.0, 809.0], [198.0, 990.0], [171.0, 990.0]], [[143.0, 812.0], [165.0, 812.0], [165.0, 990.0], [143.0, 990.0]]], "lines": ["．．．", "んー", "まぁ一応紹介は", "できるけども．．．"]}], "img_path": "125.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [179, 798, 258, 825], "vertical": false, "font_size": 16, "lines_coords": [[[181.0, 799.0], [254.0, 796.0], [254.0, 816.0], [181.0, 819.0]], [[201.0, 812.0], [240.0, 810.0], [240.0, 825.0], [201.0, 827.0]]], "lines": ["どうもすまでできるものを言うとかのまま話し", "実際に私自身は予定的な事問題。"]}, {"box": [287, 802, 348, 826], "vertical": false, "font_size": 26, "lines_coords": [[[287.0, 800.0], [348.0, 800.0], [348.0, 828.0], [287.0, 828.0]]], "lines": ["そ！そのまず今回もできないの？"]}, {"box": [309, 1137, 325, 1176], "vertical": true, "font_size": 12, "lines_coords": [[[309.0, 1137.0], [321.0, 1137.0], [325.0, 1176.0], [312.0, 1176.0]]], "lines": ["最無限で"]}], "img_path": "126.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "127.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [918, 164, 967, 335], "vertical": true, "font_size": 20, "lines_coords": [[[946.0, 167.0], [967.0, 167.0], [967.0, 334.0], [946.0, 334.0]], [[918.0, 164.0], [945.0, 164.0], [946.0, 335.0], [920.0, 335.0]]], "lines": ["．．．メメ容疑者（３５）は", "警察の取り調べて"]}, {"box": [900, 209, 914, 229], "vertical": true, "font_size": 20, "lines_coords": [[[900.0, 209.0], [914.0, 209.0], [914.0, 229.0], [900.0, 229.0]]], "lines": ["．．．"]}, {"box": [171, 117, 204, 210], "vertical": true, "font_size": 33, "lines_coords": [[[171.0, 117.0], [204.0, 117.0], [204.0, 210.0], [171.0, 210.0]]], "lines": ["．．．"]}, {"box": [28, 293, 82, 464], "vertical": true, "font_size": 54, "lines_coords": [[[28.0, 293.0], [82.0, 293.0], [82.0, 464.0], [28.0, 464.0]]], "lines": ["第７４話"]}, {"box": [139, 620, 234, 789], "vertical": true, "font_size": 22, "lines_coords": [[[212.0, 620.0], [234.0, 620.0], [234.0, 776.0], [212.0, 776.0]], [[182.0, 620.0], [209.0, 620.0], [209.0, 789.0], [182.0, 789.0]], [[162.0, 621.0], [182.0, 621.0], [182.0, 746.0], [162.0, 746.0]], [[139.0, 621.0], [159.0, 621.0], [159.0, 760.0], [139.0, 760.0]]], "lines": ["「ついカッとなって", "刺した。殺す気は", "なかった。」と", "供述しておりー"]}, {"box": [901, 917, 973, 1107], "vertical": true, "font_size": 20, "lines_coords": [[[951.0, 917.0], [973.0, 917.0], [971.0, 1107.0], [950.0, 1107.0]], [[926.0, 918.0], [948.0, 918.0], [946.0, 1106.0], [925.0, 1106.0]], [[901.0, 918.0], [923.0, 918.0], [923.0, 996.0], [901.0, 996.0]]], "lines": ["．．．総理は定例会見で", "いち早い雇用問題の", "改善をー"]}, {"box": [904, 1009, 917, 1042], "vertical": true, "font_size": 20, "lines_coords": [[[904.0, 1009.0], [917.0, 1009.0], [917.0, 1042.0], [904.0, 1042.0]]], "lines": ["．．．"]}, {"box": [509, 935, 610, 1124], "vertical": true, "font_size": 20, "lines_coords": [[[589.0, 937.0], [610.0, 937.0], [610.0, 1053.0], [589.0, 1053.0]], [[564.0, 937.0], [584.0, 937.0], [584.0, 1071.0], [564.0, 1071.0]], [[537.0, 937.0], [557.0, 937.0], [557.0, 1084.0], [537.0, 1084.0]], [[509.0, 935.0], [529.0, 935.0], [529.0, 1123.0], [509.0, 1123.0]]], "lines": ["「どうしても", "触りたかった。", "被害者の方には", "申し訳ないとーー．．．"]}, {"box": [670, 1306, 770, 1493], "vertical": true, "font_size": 19, "lines_coords": [[[751.0, 1310.0], [768.0, 1310.0], [768.0, 1410.0], [751.0, 1410.0]], [[723.0, 1309.0], [743.0, 1309.0], [743.0, 1434.0], [723.0, 1434.0]], [[698.0, 1309.0], [718.0, 1309.0], [718.0, 1493.0], [698.0, 1493.0]], [[673.0, 1306.0], [693.0, 1306.0], [690.0, 1475.0], [670.0, 1475.0]]], "lines": ["メメ市では", "空から大量の", "カエルが降ってきたと", "住民から連絡が．．．"]}, {"box": [90, 1381, 162, 1548], "vertical": true, "font_size": 20, "lines_coords": [[[139.0, 1381.0], [159.0, 1381.0], [159.0, 1548.0], [139.0, 1548.0]], [[114.0, 1382.0], [134.0, 1382.0], [134.0, 1526.0], [114.0, 1526.0]], [[90.0, 1382.0], [110.0, 1382.0], [110.0, 1529.0], [90.0, 1529.0]]], "lines": ["．．．本日のグスト！！", "人気急上昇中の", "女性シンガー．．．"]}], "img_path": "128.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [162, 215, 274, 382], "vertical": true, "font_size": 19, "lines_coords": [[[253.0, 215.0], [273.0, 215.0], [273.0, 342.0], [253.0, 342.0]], [[229.0, 217.0], [250.0, 217.0], [250.0, 382.0], [229.0, 382.0]], [[206.0, 217.0], [226.0, 217.0], [226.0, 371.0], [206.0, 371.0]], [[184.0, 218.0], [203.0, 218.0], [203.0, 339.0], [184.0, 339.0]], [[162.0, 218.0], [179.0, 218.0], [179.0, 325.0], [162.0, 325.0]]], "lines": ["．．．先程放送中", "番組内で不適切な", "発言がありました", "ことをお詫び", "いたします。"]}, {"box": [935, 1006, 1009, 1140], "vertical": true, "font_size": 21, "lines_coords": [[[985.0, 1007.0], [1007.0, 1007.0], [1007.0, 1090.0], [985.0, 1090.0]], [[962.0, 1009.0], [982.0, 1009.0], [982.0, 1132.0], [962.0, 1132.0]], [[935.0, 1006.0], [957.0, 1006.0], [959.0, 1139.0], [937.0, 1139.0]]], "lines": ["全国的に", "暖かい陽気が", "続きそうです。"]}, {"box": [713, 1367, 782, 1473], "vertical": true, "font_size": 24, "lines_coords": [[[756.0, 1367.0], [782.0, 1367.0], [782.0, 1454.0], [756.0, 1454.0]], [[734.0, 1368.0], [756.0, 1368.0], [756.0, 1473.0], [734.0, 1473.0]]], "lines": ["それでは", "良い週末を"]}], "img_path": "129.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [237, 351, 332, 368], "vertical": false, "font_size": 17, "lines_coords": [[[237.0, 351.0], [332.0, 351.0], [332.0, 368.0], [237.0, 368.0]]], "lines": ["ご評価ありがとうございます"]}, {"box": [739, 0, 894, 25], "vertical": false, "font_size": 13, "lines_coords": [[[767.0, 12.0], [882.0, 12.0], [882.0, 27.0], [767.0, 27.0]]], "lines": ["ああ．．．うんっ、ああっ、そういうわけじゃねえよ"]}, {"box": [752, 61, 896, 104], "vertical": false, "font_size": 19, "lines_coords": [[[756.0, 63.0], [890.0, 63.0], [890.0, 83.0], [756.0, 83.0]], [[756.0, 83.0], [840.0, 85.0], [840.0, 106.0], [756.0, 105.0]]], "lines": ["ＣＡＲＤＳＥＲＶＩＣＥ", "カードサービスコーナー"]}, {"box": [751, 195, 893, 225], "vertical": false, "font_size": 24, "lines_coords": [[[752.0, 193.0], [889.0, 201.0], [887.0, 226.0], [750.0, 218.0]]], "lines": ["ローン契約機は審店"]}, {"box": [107, 898, 203, 936], "vertical": false, "font_size": 24, "lines_coords": [[[117.0, 904.0], [196.0, 904.0], [196.0, 930.0], [117.0, 930.0]]], "lines": ["ＭＥＲＥ"]}, {"box": [110, 1021, 228, 1078], "vertical": false, "font_size": 34, "lines_coords": [[[110.0, 1045.0], [221.0, 1021.0], [228.0, 1054.0], [117.0, 1078.0]]], "lines": ["このようになりましたが、"]}, {"box": [125, 1373, 153, 1498], "vertical": true, "font_size": 26, "lines_coords": [[[125.0, 1375.0], [151.0, 1375.0], [151.0, 1498.0], [125.0, 1498.0]]], "lines": ["．．．えっ！？"]}, {"box": [376, 1425, 414, 1440], "vertical": false, "font_size": 12, "lines_coords": [[[376.0, 1428.0], [412.0, 1425.0], [414.0, 1437.0], [378.0, 1440.0]]], "lines": ["オノデ"]}, {"box": [370, 1500, 418, 1517], "vertical": false, "font_size": 17, "lines_coords": [[[370.0, 1500.0], [418.0, 1500.0], [418.0, 1517.0], [370.0, 1517.0]]], "lines": ["．．．自動機"]}, {"box": [518, 1301, 598, 1323], "vertical": false, "font_size": 17, "