226.0]], [[925.0, 1129.0], [953.0, 1129.0], [953.0, 1210.0], [925.0, 1210.0]]], "lines": ["．．．それと", "同じく"]}, {"box": [125, 778, 234, 975], "vertical": true, "font_size": 22, "lines_coords": [[[210.0, 778.0], [232.0, 778.0], [232.0, 917.0], [210.0, 917.0]], [[182.0, 781.0], [204.0, 781.0], [204.0, 975.0], [182.0, 975.0]], [[154.0, 779.0], [176.0, 779.0], [176.0, 896.0], [154.0, 896.0]], [[125.0, 778.0], [146.0, 778.0], [150.0, 964.0], [128.0, 964.0]]], "lines": ["どうやら頭で", "いくら心配したって", "現実は何も", "変わらないらしい。"]}, {"box": [490, 1131, 597, 1318], "vertical": true, "font_size": 22, "lines_coords": [[[573.0, 1132.0], [595.0, 1132.0], [595.0, 1246.0], [573.0, 1246.0]], [[543.0, 1132.0], [567.0, 1132.0], [568.0, 1295.0], [545.0, 1295.0]], [[517.0, 1132.0], [539.0, 1132.0], [539.0, 1318.0], [517.0, 1318.0]], [[490.0, 1131.0], [510.0, 1131.0], [510.0, 1270.0], [490.0, 1270.0]]], "lines": ["．．．だが俺が", "いくら案じても", "世界は平和になら", "ないらしい："]}, {"box": [654, 1356, 734, 1518], "vertical": true, "font_size": 24, "lines_coords": [[[704.0, 1356.0], [731.0, 1356.0], [734.0, 1518.0], [707.0, 1518.0]], [[682.0, 1357.0], [704.0, 1357.0], [704.0, 1517.0], [682.0, 1517.0]], [[654.0, 1356.0], [676.0, 1356.0], [676.0, 1495.0], [654.0, 1495.0]]], "lines": ["いつだって俺は", "全人類の未来を", "案じていた．．．"]}, {"box": [90, 1304, 226, 1537], "vertical": true, "font_size": 22, "lines_coords": [[[204.0, 1306.0], [226.0, 1306.0], [225.0, 1468.0], [203.0, 1468.0]], [[176.0, 1309.0], [198.0, 1309.0], [198.0, 1492.0], [176.0, 1492.0]], [[146.0, 1306.0], [168.0, 1306.0], [170.0, 1512.0], [148.0, 1512.0]], [[120.0, 1307.0], [142.0, 1307.0], [142.0, 1537.0], [120.0, 1537.0]], [[90.0, 1304.0], [112.0, 1304.0], [114.0, 1517.0], [92.0, 1517.0]]], "lines": ["．．．それどころか", "目の前の地味〰な", "問題をひとつびとつ", "片付けないと生活すら", "ままならないのだ！！"]}], "img_path": "167.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [923, 93, 976, 253], "vertical": true, "font_size": 22, "lines_coords": [[[950.0, 93.0], [976.0, 93.0], 