], [298.0, 803.0], [265.0, 803.0]]], "lines": ["とっても", "当たり前のこと", "でした。"]}], "img_path": "122.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [289, 340, 367, 395], "vertical": false, "font_size": 11.25, "lines_coords": [[[290.0, 340.0], [348.0, 340.0], [348.0, 351.0], [290.0, 351.0]], [[289.0, 350.0], [367.0, 348.0], [367.0, 360.0], [289.0, 362.0]], [[290.0, 362.0], [364.0, 362.0], [364.0, 373.0], [290.0, 373.0]], [[290.0, 384.0], [364.0, 384.0], [364.0, 395.0], [290.0, 395.0]]], "lines": ["●専門医師だろ！！", "●第三十六十六条二郎は", "●家族教育．．．それにしても", "●保険．．．！！基盤人．．"]}, {"box": [292, 375, 354, 381], "vertical": false, "font_size": 6, "lines_coords": [[[292.0, 375.0], [354.0, 375.0], [354.0, 381.0], [292.0, 381.0]]], "lines": ["カスタカフリストを"]}, {"box": [275, 103, 651, 314], "vertical": false, "font_size": 34, "lines_coords": [[[279.0, 100.0], [651.0, 100.0], [651.0, 138.0], [279.0, 138.0]], [[284.0, 156.0], [503.0, 153.0], [503.0, 196.0], [284.0, 199.0]], [[381.0, 203.0], [498.0, 209.0], [496.0, 237.0], [379.0, 231.0]], [[278.0, 220.0], [518.0, 231.0], [517.0, 279.0], [276.0, 268.0]], [[328.0, 290.0], [490.0, 290.0], [490.0, 317.0], [328.0, 317.0]]], "lines": ["愛川ＫＩフパート２階角部屋", "ハイツ宍戸", "金１ヶ月、敷金１ケ月", "２５．０００円．．．", "いいじゃないでご願い待歩のか"]}, {"box": [682, 106, 734, 121], "vertical": false, "font_size": 15, "lines_coords": [[[682.0, 106.0], [734.0, 106.0], [734.0, 121.0], [682.0, 121.0]]], "lines": ["（２０１５室）"]}, {"box": [523, 673, 584, 828], "vertical": true, "font_size": 30, "lines_coords": [[[556.0, 675.0], [582.0, 675.0], [582.0, 826.0], [556.0, 826.0]], [[523.0, 673.0], [556.0, 673.0], [556.0, 712.0], [523.0, 712.0]]], "lines": ["愛子ちゃんは", "今、"]}, {"box": [389, 1312, 478, 1519], "vertical": true, "font_size": 25, "lines_coords": [[[451.0, 1314.0], [478.0, 1314.0], [478.0, 1517.0], [451.0, 1517.0]], [[420.0, 1314.0], [446.0, 1314.0], [446.0, 1492.0], [420.0, 1492.0]], [[390.0, 1317.0], [412.0, 1317.0], [412.0, 1471.0], [390.0, 1471.0]]], "lines": ["この街のどこかで", "暮らしているの", "かもしれない。"]}, {"box": [540, 1313, 600, 1478], "vertical": true, "font_size": 26, "lines_coords": [[[571.0, 1315.0], [598.0, 1315.0], [598.0, 1467.0], [571.0, 1467.0]], [[542.0, 1315.0], [568.0, 1315.0], [568.0, 1470.0], [542.0, 1470.0]]], "lines": ["キチンとした", "大人になって"]}, {"box": [662, 1313, 720, 1478], "vertical": true, "font_size": 28, "lines_coords": [[[692.0, 1314.0], [720.0, 1314.0], [720.0, 1417.0], [692.0, 1417.0]], [[662.0, 1314.0], [689.0, 1314.0], [689.0, 1473.0], [662.0, 1473.0]]], "lines": ["どこかの", "誰かと違って、"]}], "img_path": "123.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [450, 404, 543, 585], "vertical": true, "font_size": 27, "lines_coords": [[[510.0, 404.0], [543.0, 404.0], [543.0, 485.0], [510.0, 485.0]], [[484.0, 407.0], [506.0, 407.0], [506.0, 582.0], [484.0, 582.0]], [[450.0, 404.0], [476.0, 404.0], [476.0, 509.0], [450.0, 509.0]]], "lines": ["自分は", "何をしていたの", "だろう？"]}, {"box": [605, 404, 631, 542], "vertical": true, "font_size": 22, "lines_coords": [[[606.0, 404.0], [628.0, 404.0], [628.0, 534.0], [606.0, 534.0]]], "lines": ["この数年間"]}, {"box": [678, 760, 731, 778], "vertical": false, "font_size": 18, "lines_coords": [[[678.0, 760.0], [731.0, 760.0], [731.0, 778.0], [678.0, 778.0]]], "lines": ["（２０１号室）"]}, {"box": [282, 995, 368, 1053], "vertical": false, "font_size": 12.8, "lines_coords": [[[282.0, 995.0], [346.0, 995.0], [346.0, 1010.0], [282.0, 1010.0]], [[287.0, 1007.0], [362.0, 1007.0], [362.0, 1018.0], [287.0, 1018.0]], [[282.0, 1017.0], [359.0, 1017.0], [359.0, 1032.0], [282.0, 1032.0]], [[284.0, 1029.0], [351.0, 1028.0], [351.0, 1040.0], [284.0, 1042.0]], [[289.0, 1042.0], [368.0, 1042.0], [368.0, 1053.0], [289.0, 1053.0]]], "lines": ["●専門医院の５０代後継者", "●第三十八大会二郎は", "事務年前１００万円くらい", "●契約期限）２０１", "事故障った「実験人（１）」"]}, {"box": [267, 753, 645, 945], "vertical": false, "font_size": 35, "lines_coords": [[[300.0, 757.0], [645.0, 754.0], [645.0, 796.0], [300.0, 799.0]], [[279.0, 809.0],