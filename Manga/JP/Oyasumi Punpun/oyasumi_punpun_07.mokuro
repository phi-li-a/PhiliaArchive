, 678], "vertical": true, "font_size": 27, "lines_coords": [[[600.0, 498.0], [626.0, 498.0], [626.0, 676.0], [600.0, 676.0]], [[567.0, 498.0], [595.0, 498.0], [595.0, 631.0], [567.0, 631.0]]], "lines": ["慌ただしく鳴る", "靴箱の扉と"]}, {"box": [414, 495, 477, 703], "vertical": true, "font_size": 32, "lines_coords": [[[448.0, 496.0], [475.0, 496.0], [475.0, 701.0], [448.0, 701.0]], [[414.0, 495.0], [450.0, 495.0], [450.0, 565.0], [414.0, 565.0]]], "lines": ["階段を駆け上がる", "足音。"]}, {"box": [568, 1281, 631, 1421], "vertical": true, "font_size": 30, "lines_coords": [[[598.0, 1281.0], [631.0, 1281.0], [631.0, 1364.0], [598.0, 1364.0]], [[568.0, 1284.0], [595.0, 1284.0], [595.0, 1415.0], [568.0, 1415.0]]], "lines": ["鉛筆の", "擦れる音と"]}, {"box": [450, 1282, 478, 1372], "vertical": true, "font_size": 28, "lines_coords": [[[450.0, 1285.0], [478.0, 1285.0], [478.0, 1370.0], [450.0, 1370.0]]], "lines": ["冬の空。"]}], "img_path": "050.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [901, 104, 993, 285], "vertical": true, "font_size": 26, "lines_coords": [[[965.0, 104.0], [993.0, 104.0], [993.0, 232.0], [965.0, 232.0]], [[934.0, 106.0], [960.0, 106.0], [960.0, 260.0], [934.0, 260.0]], [[901.0, 104.0], [928.0, 104.0], [928.0, 285.0], [901.0, 285.0]]], "lines": ["おーれっの", "チッンポっは", "せっかいいちー"]}, {"box": [873, 146, 895, 232], "vertical": true, "font_size": 26, "lines_coords": [[[873.0, 146.0], [895.0, 146.0], [895.0, 232.0], [873.0, 232.0]]], "lines": ["ーッ！！"]}, {"box": [210, 121, 315, 306], "vertical": true, "font_size": 31, "lines_coords": [[[276.0, 121.0], [315.0, 121.0], [315.0, 209.0], [276.0, 209.0]], [[240.0, 123.0], [268.0, 123.0], [270.0, 306.0], [242.0, 306.0]], [[210.0, 125.0], [237.0, 125.0], [237.0, 304.0], [210.0, 304.0]]], "lines": ["．．．何？", "三村の奴、どー", "しちゃったの？"]}, {"box": [101, 278, 192, 457], "vertical": true, "font_size": 26, "lines_coords": [[[167.0, 279.0], [189.0, 279.0], [189.0, 457.0], [167.0, 457.0]], [[129.0, 278.0], [156.0, 278.0], [