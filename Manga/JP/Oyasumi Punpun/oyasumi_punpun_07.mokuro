 68, 357, 95], "vertical": false, "font_size": 27, "lines_coords": [[[92.0, 68.0], [357.0, 68.0], [357.0, 95.0], [92.0, 95.0]]], "lines": ["おやすみプンプン［"]}, {"box": [79, 496, 218, 705], "vertical": true, "font_size": 24, "lines_coords": [[[192.0, 498.0], [218.0, 498.0], [218.0, 684.0], [192.0, 684.0]], [[164.0, 496.0], [190.0, 496.0], [187.0, 642.0], [160.0, 642.0]], [[135.0, 496.0], [157.0, 496.0], [157.0, 682.0], [135.0, 682.0]], [[107.0, 496.0], [129.0, 496.0], [129.0, 704.0], [107.0, 704.0]], [[82.0, 496.0], [104.0, 496.0], [101.0, 660.0], [79.0, 660.0]]], "lines": ["僕も若い頃なんて", "年上の女性と", "下半身が乾く暇も", "無いって寸法だった", "もんナァー！！"]}, {"box": [912, 789, 976, 920], "vertical": true, "font_size": 27, "lines_coords": [[[942.0, 789.0], [976.0, 789.0], [976.0, 873.0], [942.0, 873.0]], [[912.0, 789.0], [940.0, 789.0], [942.0, 920.0], [914.0, 920.0]]], "lines": ["あ．．．．．", "あのっ．．．"]}, {"box": [828, 942, 915, 1121], "vertical": true, "font_size": 27, "lines_coords": [[[889.0, 942.0], [915.0, 942.0], [915.0, 1098.0], [889.0, 1098.0]], [[857.0, 942.0], [884.0, 942.0], [884.0, 1075.0], [857.0, 1075.0]], [[828.0, 943.0], [850.0, 943.0], [850.0, 1121.0], [828.0, 1121.0]]], "lines": ["プン山さんは", "今も仕事は", "福島のほうで？"]}, {"box": [150, 817, 242, 981], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 817.0], [242.0, 817.0], [242.0, 926.0], [214.0, 926.0]], [[181.0, 817.0], [207.0, 817.0], [207.0, 971.0], [181.0, 971.0]], [[150.0, 817.0], [176.0, 817.0], [176.0, 981.0], [150.0, 981.0]]], "lines": ["あ、ええ、", "夜警の仕事は", "辞めましたが。"]}, {"box": [89, 1031, 209, 1225], "vertical": true, "font_size": 26, "lines_coords": [[[182.0, 1034.0], [209.0, 1034.0], [209.0, 1162.0], [182.0, 1162.0]], [[151.0, 1031.0], [178.0, 1031.0], [178.0, 1137.0], [151.0, 1137.0]], [[121.0, 1032.0], [143.0, 1032.0], [143.0, 1212.0], [121.0, 1212.0]], [[89.0, 1032.0], [115.0, 1032.0], [115.0, 1225.0], [89.0, 1225.0]]], "lines": ["知り合いに", "頼まれて", "福祉関係の仕事", "手伝ってまして。"]}, {"box": [853, 1304, 975, 1487], "vertical": true, "font_size": 25, "lines_coords": [[[953.0, 1310.0], [975.0, 1310.0], [975.0, 1440.0], [953.0, 1440.0]], [[918.0, 1307.0], [945.0, 1307.0], [945.0, 1462.0], [918.0, 1462.0]], [[889.0, 1310.0], [910.0, 1310.0], [910.0, 1487.0], [889.0, 1487.0]], [[853.0, 1304.0], [885.0, 1304.0], [885.0, 1398.0], [853.0, 1398.0]]], "lines": ["．．．でもまぁ", "今じゃただの", "田舎のおじさん", "ですよ。"]}, {"box": [740, 1367, 831, 1546], "vertical": true, "font_size": 25, "lines_coords": [[[803.0, 1367.0], [831.0, 1367.0], [831.0, 1482.0], [803.0, 1482.0]], [[771.0, 1368.0], [795.0, 1368.0], [793.0, 1521.0], [770.0, 1521.0]], [[740.0, 1367.0], [762.0, 1367.0], [762.0, 1546.0], [740.0, 1546.0]]], "lines": ["．．．でもね。", "田舎は星空が", "きれいなんだ！！"]}, {"box": [85, 1353, 208, 1559], "vertical": true, "font_size": 27, "lines_coords": [[[179.0, 1353.0], [206.0, 1353.0], [206.0, 1559.0], [179.0, 1559.0]], [[148.0, 1354.0], [175.0, 1354.0], [175.0, 1534.0], [148.0, 1534.0]], [[114.0, 1353.0], [140.0, 1353.0], [143.0, 1515.0], [117.0, 1515.0]], [[85.0, 1353.0], [112.0, 1353.0], [112.0, 1448.0], [85.0, 1448.0]]], "lines": ["アカネさんも一度", "いらっしゃい！！", "いい所ですよ、", "福島はー"]}], "img_path": "020.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [521, 86, 614, 268], "vertical": true, "font_size": 28, "lines_coords": [[[587.0, 89.0], [614.0, 89.0], [614.0, 220.0], [587.0, 220.0]], [[554.0, 89.0], [581.0, 89.0], [581.0, 265.0], [554.0, 265.0]], [[521.0, 89.0], [550.0, 89.0], [550.0, 200.0], [521.0, 200.0]]], "lines": ["ブンフンは、", "なんだかひどく", "嫌でした。"]}, {"box": [923, 406, 946, 537], "vertical": true, "font_size": 22, "lines_coords": [[[923.0, 407.0], [945.0, 407.0], [945.0, 534.0], [923.0, 534.0]]], "lines": ["えーと．．．"]}, {"box": [750, 842, 842, 1036], "vertical": true, "font_size": 28, "lines_coords": [[[809.0, 842.0], [842.0, 842.0], [842.0, 925.0], [809.0, 925.0]], [[781.0, 842.0], [809.0, 842.0], [806.0, 975.0], [778.0, 975.0]], [[751.0, 843.0], [773.0, 843.0], [773.0, 1031.0], [751.0, 1031.0]]], "lines": ["数年間", "父親に放置", "されていたこと。"]}, {"box": [976, 1131, 1003, 1259], "vertical": true, "font_size": 26, "lines_coords": [[[976.0, 1131.0], [1003.0, 1131.0], [1003.0, 1259.0], [976.0, 1259.0]]], "lines": ["スミマセー"]}, {"box": [564, 842, 654, 997], "vertical": true, "font_size": 27, "lines_coords": [[[628.0, 842.0], [654.0, 842.0], [654.0, 995.0], [628.0, 995.0]], [[592.0, 842.0], [625.0, 842.0], [625.0, 946.0], [592.0, 946.0]], [[564.0, 842.0], [587.0, 842.0], [590.0, 982.0], [567.0, 982.0]]], "lines": ["それはさほど", "問題じゃ", "ありません。"]}, {"box": [259, 842, 432, 1023], "vertical": true, "font_size": 27, "lines_coords": [[[404.0, 845.0], [432.0, 845.0], [432.0, 973.0], [404.0, 973.0]], [[370.0, 843.0], [403.0, 843.0], [403.0, 953.0], [370.0, 953.0]], [[328.0, 845.0], [350.0, 845.0], [350.0, 1020.0], [328.0, 1020.0]], [[293.0, 843.0], [320.0, 843.0], [320.0, 1000.0], [293.0, 1000.0]], [[259.0, 842.0], [285.0, 842.0], [289.0, 1010.0], [262.0, 1010.0]]], "lines": ["大人達には", "大人達の、", "こしれた事情が", "あるのは理解", "したいのです。"]}, {"box": [945, 1167, 971, 1259], "vertical": true, "font_size": 26, "lines_coords": [[[945.0, 1167.0], [971.0, 1167.0], [971.0, 1259.0], [945.0, 1259.0]]], "lines": ["ーン！！"]}, {"box": [835, 1318, 926, 1453], "vertical": true, "font_size": 26, "lines_coords": [[[900.0, 1318.0], [926.0, 1318.0], [926.0, 1453.0], [900.0, 1453.0]], [[867.0, 1320.0], [893.0, 1320.0], [893.0, 1423.0], [867.0, 1423.0]], [[835.0, 1318.0], [862.0, 1318.0], [862.0, 1450.0], [835.0, 1450.0]]], "lines": ["店員さーん、", "コーヒー", "おかわり！！"]}], "img_path": "021.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [798, 70, 889, 202], "vertical": true, "font_size": 28, "lines_coords": [[[864.0, 73.0], [885.0, 73.0], [885.0, 198.0], [864.0, 198.0]], [[825.0, 70.0], [860.0, 70.0], [860.0, 132.0], [825.0, 132.0]], [[798.0, 71.0], [825.0, 71.0], [825.0, 181.0], [798.0, 181.0]]], "lines": ["父親の姿も", "声も、", "雰囲気も、"]}, {"box": [645, 68, 736, 303], "vertical": true, "font_size": 27, "lines_coords": [[[709.0, 68.0], [735.0, 68.0], [732.0, 301.0], [706.0, 301.0]], [[673.0, 70.0], [701.0, 70.0], [703.0, 226.0], [675.0, 226.0]], [[645.0, 73.0], [671.0, 73.0], [671.0, 210.0], [645.0, 210.0]]], "lines": ["どこがどう変わった", "という訳では", "ないのです。"]}, {"box": [512, 68, 573, 313], "vertical": true, "font_size": 27, "lines_coords": [[[543.0, 68.0], [570.0, 68.0], [573.0, 276.0], [546.0, 276.0]], [[512.0, 68.0], [539.0, 68.0], [540.0, 312.0], [514.0, 312.0]]], "lines": ["昔のまま楽しくて", "優しい父親なのです。"]}, {"box": [318, 70, 442, 285], "vertical": true, "font_size": 27, "lines_coords": [[[412.0, 71.0], [442.0, 71.0], [442.0, 148.0], [412.0, 148.0]], [[384.0, 71.0], [406.0, 71.0], [406.0, 223.0], [384.0, 223.0]], [[350.0, 70.0], [378.0, 70.0], [378.0, 175.0], [350.0, 175.0]], [[318.0, 70.0], [345.0, 70.0], [345.0, 282.0], [318.0, 282.0]]], "lines": ["なのに", "この致命的な", "違和感が", "苦しくて音してて、"]}, {"box": [152, 69, 273, 275], "vertical": true, "font_size": 26, "lines_coords": [[[246.0, 71.0], [273.0, 71.0], [273.0, 273.0], [246.0, 273.0]], [[215.0, 71.0], [242.0, 71.0], [242.0, 198.0], [215.0, 198.0]], [[182.0, 70.0], [210.0, 70.0], [207.0, 226.0], [179.0, 226.0]], [[153.0, 73.0], [175.0, 73.0], [175.0, 232.0], [153.0, 232.0]]], "lines": ["プンプンは原因を", "知るために", "必死に父親を", "観察しました。"]}, {"box": [658, 890, 683, 1028], "vertical": true, "font_size": 22, "lines_coords": [[[659.0, 890.0], [681.0, 890.0], [681.0, 1021.0], [659.0, 1021.0]]], "lines": ["．．．なるほど、"]}, {"box": [550, 885, 610, 1054], "vertical": true, "font_size": 25, "lines_coords": [[[582.0, 885.0], [610.0, 885.0], [607.0, 1017.0], [579.0, 1017.0]], [[551.0, 890.0], [573.0, 890.0], [573.0, 1046.0], [551.0, 1046.0]]], "lines": ["プンフンは", "わかりました"]}, {"box": [404, 888, 497, 1069], "vertical": true, "font_size": 27, "lines_coords": [[[468.0, 890.0], [495.0, 890.0], [495.0, 1042.0], [468.0, 1042.0]], [[437.0, 890.0], [464.0, 890.0], [464.0, 1068.0], [437.0, 1068.0]], [[404.0, 889.0], [431.0, 889.0], [431.0, 1023.0], [404.0, 1023.0]]], "lines": ["一番変わって", "しまったものが", "なんなのか。"]}, {"box": [904, 1190, 995, 1371], "vertical": true, "font_size": 25, "lines_coords": [[[968.0, 1190.0], [995.0, 1190.0], [995.0, 1346.0], [968.0, 1346.0]], [[935.0, 1192.0], [962.0, 1192.0], [962.0, 1371.0], [935.0, 1371.0]], [[904.0, 1192.0], [926.0, 1192.0], [926.0, 1359.0], [904.0, 1359.0]]], "lines": ["ドハーーッ！！", "喫茶店と勘違い", "しちゃったネ！！"]}, {"box": [795, 1373, 907, 1532], "vertical": true, "font_size": 25, "lines_coords": [[[881.0, 1373.0], [907.0, 1373.0], [907.0, 1531.0], [881.0, 1531.0]], [[851.0, 1376.0], [875.0, 1376.0], [876.0, 1532.0], [853.0, 1532.0]], [[821.0, 1378.0], [848.0, 1378.0], [848.0, 1481.0], [821.0, 1481.0]], [[795.0, 1378.0], [815.0, 1378.0], [815.0, 1531.0], [795.0, 1531.0]]], "lines": ["ごめんなさい", "アケミちゃん", "おかわり", "もらえます？"]}, {"box": [148, 1176, 207, 1326], "vertical": true, "font_size": 26, "lines_coords": [[[181.0, 1176.0], [207.0, 1176.0], [207.0, 1306.0], [181.0, 1306.0]], [[148.0, 1176.0], [175.0, 1176.0], [175.0, 1326.0], [148.0, 1326.0]]], "lines": ["．．．今、お湯", "沸かしますね。"]}, {"box": [93, 1359, 148, 1500], "vertical": true, "font_size": 26, "lines_coords": [[[121.0, 1359.0], [148.0, 1359.0], [148.0, 1443.0], [121.0, 1443.0]], [[93.0, 1364.0], [115.0, 1364.0], [115.0, 1500.0], [93.0, 1500.0]]], "lines": ["．．．あと", "翠ですから"]}], "img_path": "022.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [948, 1093, 970, 1217], "vertical": true, "font_size": 25, "lines_coords": [[[948.0, 1093.0], [970.0, 1093.0], [970.0, 1217.0], [948.0, 1217.0]]], "lines": ["さてと．．．"]}, {"box": [554, 857, 581, 971], "vertical": true, "font_size": 27, "lines_coords": [[[554.0, 857.0], [581.0, 857.0], [581.0, 970.0], [554.0, 970.0]]], "lines": ["自分です。"]}, {"box": [882, 1268, 910, 1375], "vertical": true, "font_size": 25, "lines_coords": [[[882.0, 1268.0], [910.0, 1268.0], [910.0, 1375.0], [882.0, 1375.0]]], "lines": ["うん．．．"]}, {"box": [181, 1164, 273, 1295], "vertical": true, "font_size": 25, "lines_coords": [[[245.0, 1165.0], [273.0, 1165.0], [273.0, 1270.0], [245.0, 1270.0]], [[215.0, 1167.0], [237.0, 1167.0], [237.0, 1295.0], [215.0, 1295.0]], [[181.0, 1164.0], [207.0, 1164.0], [207.0, 1268.0], [181.0, 1268.0]]], "lines": ["僕も明日", "朝から仕事", "だから．．．"]}, {"box": [132, 1364, 251, 1495], "vertical": true, "font_size": 25, "lines_coords": [[[229.0, 1365.0], [251.0, 1365.0], [251.0, 1493.0], [229.0, 1493.0]], [[195.0, 1364.0], [221.0, 1364.0], [221.0, 1495.0], [195.0, 1495.0]], [[162.0, 1364.0], [189.0, 1364.0], [189.0, 1492.0], [162.0, 1492.0]], [[132.0, 1364.0], [159.0, 1364.0], [159.0, 1468.0], [132.0, 1468.0]]], "lines": ["あまり長居", "する訳には", "いかないの", "だけど．．"]}], "img_path": "023.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [907, 68, 967, 232], "vertical": true, "font_size": 28, "lines_coords": [[[939.0, 70.0], [967.0, 70.0], [967.0, 212.0], [939.0, 212.0]], [[907.0, 68.0], [934.0, 68.0], [934.0, 232.0], [907.0, 232.0]]], "lines": ["．．．いや、でも", "今日はホント、"]}, {"box": [856, 225, 884, 328], "vertical": true, "font_size": 28, "lines_coords": [[[856.0, 225.0], [884.0, 225.0], [884.0, 328.0], [856.0, 328.0]]], "lines": ["暑いねー"]}, {"box": [337, 89, 365, 169], "vertical": true, "font_size": 28, "lines_coords": [[[337.0, 89.0], [365.0, 89.0], [365.0, 168.0], [337.0, 168.0]]], "lines": ["ん．．．"]}, {"box": [889, 706, 967, 867], "vertical": true, "font_size": 24, "lines_coords": [[[940.0, 706.0], [964.0, 706.0], [967.0, 823.0], [943.0, 823.0]], [[914.0, 706.0], [937.0, 706.0], [939.0, 867.0], [915.0, 867.0]], [[889.0, 707.0], [910.0, 707.0], [910.0, 800.0], [889.0, 800.0]]], "lines": ["これだけは", "わかってほしい", "んだ．．．．．"]}, {"box": [548, 431, 570, 562], "vertical": true, "font_size": 24, "lines_coords": [[[548.0, 431.0], [570.0, 431.0], [570.0, 562.0], [548.0, 562.0]]], "lines": ["．．．なんだか"]}, {"box": [439, 479, 495, 634], "vertical": true, "font_size": 24, "lines_coords": [[[467.0, 479.0], [495.0, 479.0], [495.0, 582.0], [467.0, 582.0]], [[439.0, 481.0], [460.0, 481.0], [460.0, 634.0], [439.0, 634.0]]], "lines": ["あの年の", "夏みたいだ．．．"]}, {"box": [79, 478, 170, 609], "vertical": true, "font_size": 29, "lines_coords": [[[140.0, 478.0], [168.0, 478.0], [170.0, 609.0], [142.0, 609.0]], [[107.0, 479.0], [140.0, 479.0], [140.0, 595.0], [107.0, 595.0]], [[79.0, 479.0], [106.0, 479.0], [106.0, 593.0], [79.0, 593.0]]], "lines": ["．．．ちょっと", "いいかい、", "プンプン。"]}, {"box": [801, 856, 892, 1040], "vertical": true, "font_size": 24, "lines_coords": [[[862.0, 856.0], [889.0, 856.0], [892.0, 1015.0], [865.0, 1015.0]], [[832.0, 856.0], [859.0, 856.0], [859.0, 1040.0], [832.0, 1040.0]], [[801.0, 859.0], [823.0, 859.0], [823.0, 1012.0], [801.0, 1012.0]]], "lines": ["お父さん、今", "すごい緊張して", "るんだけど．．．"]}, {"box": [129, 773, 221, 988], "vertical": true, "font_size": 25, "lines_coords": [[[193.0, 773.0], [220.0, 773.0], [220.0, 928.0], [193.0, 928.0]], [[160.0, 775.0], [187.0, 775.0], [187.0, 978.0], [160.0, 978.0]], [[129.0, 773.0], [151.0, 773.0], [151.0, 985.0], [129.0, 985.0]]], "lines": ["これは決して", "いい加減に考えた", "ことじゃないんだ。"]}, {"box": [143, 1334, 178, 1504], "vertical": true, "font_size": 33, "lines_coords": [[[143.0, 1335.0], [176.0, 1335.0], [176.0, 1504.0], [143.0, 1504.0]]], "lines": ["．．．プンプン。"]}], "img_path": "024.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [900, 140, 970, 290], "vertical": true, "font_size": 31, "lines_coords": [[[940.0, 140.0], [968.0, 140.0], [968.0, 290.0], [940.0, 290.0]], [[900.0, 142.0], [934.0, 142.0], [934.0, 245.0], [900.0, 245.0]]], "lines": ["お父さんと", "一緒に、"]}, {"box": [189, 443, 264, 660], "vertical": true, "font_size": 35, "lines_coords": [[[225.0, 443.0], [264.0, 443.0], [264.0, 542.0], [225.0, 542.0]], [[189.0, 445.0], [220.0, 445.0], [220.0, 660.0], [189.0, 660.0]]], "lines": ["福島で", "暮らさないか？"]}, {"box": [915, 1095, 953, 1250], "vertical": true, "font_size": 38, "lines_coords": [[[915.0, 1095.0], [953.0, 1095.0], [953.0, 1250.0], [915.0, 1250.0]]], "lines": ["二人で．．．"]}, {"box": [232, 1267, 303, 1433], "vertical": true, "font_size": 33, "lines_coords": [[[264.0, 1270.0], [303.0, 1270.0], [303.0, 1365.0], [264.0, 1365.0]], [[232.0, 1268.0], [259.0, 1268.0], [259.0, 1431.0], [232.0, 1431.0]]], "lines": ["一から", "やり直そう。"]}], "img_path": "025.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [843, 104, 937, 314], "vertical": true, "font_size": 31, "lines_coords": [[[903.0, 104.0], [937.0, 104.0], [937.0, 190.0], [903.0, 190.0]], [[871.0, 104.0], [903.0, 104.0], [903.0, 314.0], [871.0, 314.0]], [[843.0, 106.0], [870.0, 106.0], [870.0, 237.0], [843.0, 237.0]]], "lines": ["だって", "プンプンは昔から", "ずっと．．．"]}, {"box": [18, 292, 67, 462], "vertical": true, "font_size": 49, "lines_coords": [[[18.0, 292.0], [67.0, 292.0], [67.0, 462.0], [18.0, 462.0]]], "lines": ["第６９話"]}, {"box": [135, 326, 224, 529], "vertical": true, "font_size": 25, "lines_coords": [[[196.0, 326.0], [223.0, 326.0], [223.0, 457.0], [196.0, 457.0]], [[164.0, 326.0], [190.0, 326.0], [190.0, 529.0], [164.0, 529.0]], [[135.0, 328.0], [157.0, 328.0], [157.0, 454.0], [135.0, 454.0]]], "lines": ["お父さんと", "仲良しだったじゃ", "ないか．．．"]}, {"box": [892, 784, 950, 974], "vertical": true, "font_size": 24, "lines_coords": [[[920.0, 784.0], [946.0, 784.0], [950.0, 937.0], [923.0, 937.0]], [[892.0, 787.0], [914.0, 787.0], [914.0, 973.0], [892.0, 973.0]]], "lines": ["．．．悪い話じゃ", "ないと思うんだ。"]}, {"box": [406, 910, 496, 1087], "vertical": true, "font_size": 23, "lines_coords": [[[467.0, 910.0], [493.0, 910.0], [493.0, 1087.0], [467.0, 1087.0]], [[439.0, 914.0], [460.0, 914.0], [460.0, 1065.0], [439.0, 1065.0]], [[406.0, 910.0], [428.0, 910.0], [428.0, 1037.0], [406.0, 1037.0]]], "lines": ["のんびりしてて", "いいところさ", "福島は．．．"]}], "img_path": "026.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [640, 1276, 668, 1335], "vertical": true, "font_size": 28, "lines_coords": [[[640.0, 1276.0], [668.0, 1276.0], [668.0, 1335.0], [640.0, 1335.0]]], "lines": ["ジュク"]}], "img_path": "027.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [821, 56, 848, 215], "vertical": true, "font_size": 28, "lines_coords": [[[821.0, 56.0], [848.0, 56.0], [848.0, 215.0], [821.0, 215.0]]], "lines": ["フンフンは今、"]}, {"box": [693, 56, 782, 265], "vertical": true, "font_size": 28, "lines_coords": [[[756.0, 56.0], [782.0, 56.0], [782.0, 160.0], [756.0, 160.0]], [[728.0, 60.0], [750.0, 60.0], [750.0, 234.0], [728.0, 234.0]], [[693.0, 57.0], [720.0, 57.0], [720.0, 265.0], [693.0, 265.0]]], "lines": ["目の前に", "座っている人の", "言っていることが"]}, {"box": [620, 50, 665, 121], "vertical": true, "font_size": 28, "lines_coords": [[[625.0, 50.0], [665.0, 53.0], [660.0, 121.0], [620.0, 118.0]]], "lines": ["よく"]}, {"box": [562, 57, 655, 213], "vertical": true, "font_size": 30, "lines_coords": [[[598.0, 59.0], [625.0, 59.0], [625.0, 212.0], [598.0, 212.0]], [[562.0, 57.0], [595.0, 57.0], [595.0, 148.0], [562.0, 148.0]]], "lines": ["わかりません", "でした。"]}, {"box": [289, 123, 350, 328], "vertical": true, "font_size": 27, "lines_coords": [[[326.0, 129.0], [348.0, 129.0], [348.0, 325.0], [326.0, 325.0]], [[289.0, 123.0], [321.0, 123.0], [321.0, 232.0], [289.0, 232.0]]], "lines": ["「からやり直すと", "言っても、"]}, {"box": [135, 120, 228, 355], "vertical": true, "font_size": 27, "lines_coords": [[[201.0, 120.0], [228.0, 120.0], [228.0, 328.0], [201.0, 328.0]], [[168.0, 121.0], [195.0, 121.0], [195.0, 353.0], [168.0, 353.0]], [[135.0, 121.0], [162.0, 121.0], [162.0, 301.0], [135.0, 301.0]]], "lines": ["その一というのは", "果たしてどこのこと", "なのだろうか？"]}, {"box": [862, 656, 954, 767], "vertical": true, "font_size": 28, "lines_coords": [[[926.0, 656.0], [954.0, 656.0], [954.0, 759.0], [926.0, 759.0]], [[895.0, 656.0], [923.0, 656.0], [923.0, 759.0], [895.0, 759.0]], [[862.0, 656.0], [889.0, 656.0], [889.0, 764.0], [862.0, 764.0]]], "lines": ["なんだか", "とっても", "この人は、"]}, {"box": [141, 1103, 199, 1266], "vertical": true, "font_size": 22, "lines_coords": [[[175.0, 1103.0], [196.0, 1103.0], [196.0, 1228.0], [175.0, 1228.0]], [[142.0, 1103.0], [164.0, 1103.0], [164.0, 1262.0], [142.0, 1262.0]]], "lines": ["ふざけてる", "気がしました。"]}, {"box": [535, 1392, 564, 1522], "vertical": true, "font_size": 27, "lines_coords": [[[535.0, 1392.0], [562.0, 1392.0], [562.0, 1517.0], [535.0, 1517.0]]], "lines": ["「僕は．．．．．"]}], "img_path": "028.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [543, 770, 602, 944], "vertical": true, "font_size": 24, "lines_coords": [[[575.0, 773.0], [601.0, 773.0], [601.0, 912.0], [575.0, 912.0]], [[545.0, 771.0], [567.0, 771.0], [567.0, 937.0], [545.0, 937.0]]], "lines": ["「僕は一人で", "暮らします。」"]}, {"box": [620, 1289, 646, 1395], "vertical": true, "font_size": 27, "lines_coords": [[[620.0, 1289.0], [646.0, 1289.0], [646.0, 1395.0], [620.0, 1395.0]]], "lines": ["うん．．．"]}, {"box": [542, 1357, 573, 1487], "vertical": true, "font_size": 27, "lines_coords": [[[545.0, 1357.0], [573.0, 1357.0], [570.0, 1487.0], [542.0, 1487.0]]], "lines": ["そっか．．．"]}, {"box": [129, 1390, 157, 1529], "vertical": true, "font_size": 27, "lines_coords": [[[129.0, 1390.0], [156.0, 1390.0], [156.0, 1526.0], [129.0, 1526.0]]], "lines": ["．．．わかった。"]}], "img_path": "029.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [960, 56, 989, 151], "vertical": true, "font_size": 25, "lines_coords": [[[960.0, 56.0], [989.0, 56.0], [989.0, 151.0], [960.0, 151.0]]], "lines": ["．．．おや？"]}, {"box": [870, 159, 953, 348], "vertical": true, "font_size": 25, "lines_coords": [[[926.0, 159.0], [953.0, 159.0], [953.0, 306.0], [926.0, 306.0]], [[900.0, 162.0], [921.0, 162.0], [921.0, 348.0], [900.0, 348.0]], [[870.0, 162.0], [892.0, 162.0], [892.0, 325.0], [870.0, 325.0]]], "lines": ["このコーヒー", "カップは雄一君が", "作ったのかい？"]}, {"box": [104, 121, 164, 276], "vertical": true, "font_size": 28, "lines_coords": [[[135.0, 121.0], [164.0, 121.0], [164.0, 215.0], [135.0, 215.0]], [[104.0, 121.0], [131.0, 121.0], [131.0, 250.0], [104.0, 250.0]]], "lines": ["いやァー", "ははは．．．"]}, {"box": [921, 709, 950, 815], "vertical": true, "font_size": 29, "lines_coords": [[[921.0, 709.0], [950.0, 709.0], [950.0, 815.0], [921.0, 815.0]]], "lines": ["うん．．．"]}, {"box": [642, 457, 719, 598], "vertical": true, "font_size": 22, "lines_coords": [[[696.0, 457.0], [718.0, 457.0], [718.0, 573.0], [696.0, 573.0]], [[668.0, 459.0], [690.0, 459.0], [690.0, 596.0], [668.0, 596.0]], [[642.0, 468.0], [664.0, 468.0], [664.0, 529.0], [642.0, 529.0]]], "lines": ["相変わらず", "上手だねー", "．．．"]}, {"box": [157, 737, 188, 897], "vertical": true, "font_size": 27, "lines_coords": [[[157.0, 737.0], [184.0, 737.0], [187.0, 893.0], [160.0, 893.0]]], "lines": ["そうかぁ．．．"]}], "img_path": "030.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [937, 89, 995, 220], "vertical": true, "font_size": 29, "lines_coords": [[[967.0, 92.0], [995.0, 92.0], [995.0, 195.0], [967.0, 195.0]], [[937.0, 89.0], [964.0, 89.0], [964.0, 220.0], [937.0, 220.0]]], "lines": ["いや～～～", "しかし．．．"]}, {"box": [848, 243, 937, 403], "vertical": true, "font_size": 29, "lines_coords": [[[910.0, 248.0], [937.0, 248.0], [937.0, 403.0], [910.0, 403.0]], [[876.0, 243.0], [910.0, 243.0], [910.0, 307.0], [876.0, 307.0]], [[848.0, 248.0], [875.0, 248.0], [875.0, 379.0], [848.0, 379.0]]], "lines": ["なんというか", "まー", "プンプン．．．"]}, {"box": [168, 304, 227, 459], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 306.0], [226.0, 306.0], [226.0, 459.0], [200.0, 459.0]], [[168.0, 304.0], [195.0, 304.0], [195.0, 459.0], [168.0, 459.0]]], "lines": ["大きくなった", "なァーー．．．"]}, {"box": [884, 635, 974, 815], "vertical": true, "font_size": 22, "lines_coords": [[[950.0, 639.0], [971.0, 639.0], [971.0, 762.0], [950.0, 762.0]], [[918.0, 639.0], [940.0, 639.0], [940.0, 814.0], [918.0, 814.0]], [[887.0, 635.0], [909.0, 635.0], [906.0, 815.0], [884.0, 815.0]]], "lines": ["３倍くらい", "大きくなったん", "じ