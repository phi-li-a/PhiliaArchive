, "font_size": 33, "lines_coords": [[[164.0, 854.0], [196.0, 856.0], [193.0, 960.0], [160.0, 959.0]]], "lines": ["いやいや"]}, {"box": [92, 1287, 196, 1517], "vertical": true, "font_size": 74, "lines_coords": [[[92.0, 1298.0], [165.0, 1287.0], [196.0, 1506.0], [123.0, 1517.0]]], "lines": ["ジュクハンっ"]}], "img_path": "009.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [389, 862, 418, 879], "vertical": false, "font_size": 17, "lines_coords": [[[389.0, 862.0], [418.0, 862.0], [418.0, 879.0], [389.0, 879.0]]], "lines": ["．．．"]}, {"box": [387, 893, 468, 928], "vertical": false, "font_size": 14.5, "lines_coords": [[[387.0, 903.0], [467.0, 893.0], [468.0, 909.0], [389.0, 918.0]], [[415.0, 915.0], [440.0, 909.0], [443.0, 921.0], [418.0, 928.0]]], "lines": ["それはそうですね。", "．．．"]}, {"box": [153, 1210, 193, 1420], "vertical": true, "font_size": 29, "lines_coords": [[[160.0, 1210.0], [193.0, 1212.0], [185.0, 1420.0], [153.0, 1418.0]]], "lines": ["それでも、"]}, {"box": [209, 1353, 240, 1493], "vertical": true, "font_size": 29, "lines_coords": [[[209.0, 1353.0], [235.0, 1353.0], [240.0, 1493.0], [214.0, 1493.0]]], "lines": ["アメリカ"]}, {"box": [340, 1218, 373, 1587], "vertical": true, "font_size": 29, "lines_coords": [[[340.0, 1218.0], [373.0, 1218.0], [373.0, 1587.0], [340.0, 1587.0]]], "lines": ["いや、そういうことは"]}, {"box": [446, 1220, 476, 1589], "vertical": true, "font_size": 29, "lines_coords": [[[446.0, 1220.0], [471.0, 1220.0], [476.0, 1589.0], [451.0, 1589.0]]], "lines": ["そういえば．．．"]}, {"box": [601, 1221, 695, 1504], "vertical": true, "font_size": 29.5, "lines_coords": [[[604.0, 1221.0], [632.0, 1221.0], [629.0, 1357.0], [601.0, 1357.0]], [[654.0, 1248.0], [685.0, 1246.0], [695.0, 1503.0], [664.0, 1504.0]]], "lines": ["．．．", "自分ではないので、"]}, {"box": [765, 1279, 795, 1453], "vertical": true, "font_size": 21.0, "lines_coords": [[[765.0, 1281.0], [789.0, 1279.0], [795.0, 1414.0], [771.0, 1415.0]], [[771.0, 1407.0], [789.0, 1406.0], [792.0, 1451.0], [775.0, 1453.0]]], "lines": ["カテゴリーは", "．．"]}, {"box": [917, 1232, 973, 1521], "vertical": true, "font_size": 36, "lines_coords": [[[917.0, 1235.0], [953.0, 1232.0], [973.0, 1518.0], [937.0, 1521.0]]], "lines": ["これからは、ここで"]}], "img_path": "010.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [614, 904, 837, 1093], "vertical": true, "font_size": 27, "lines_coords": [[[804.0, 906.0], [837.0, 906.0], [837.0, 989.0], [804.0, 989.0]], [[776.0, 907.0], [803.0, 907.0], [803.0, 1093.0], [776.0, 1093.0]], [[743.0, 906.0], [770.0, 906.0], [770.0, 1035.0], [743.0, 1035.0]], [[712.0, 904.0], [739.0, 904.0], [739.0, 1009.0], [712.0, 1009.0]], [[678.0, 906.0], [704.0, 906.0], [704.0, 1085.0], [678.0, 1085.0]], [[650.0, 907.0], [671.0, 907.0], [671.0, 1085.0], [650.0, 1085.0]], [[617.0, 904.0], [643.0, 904.0], [640.0, 1068.0], [614.0, 1068.0]]], "lines": ["今日は", "全国的に晴天で、", "フンフンの", "住む街も", "今年の夏最高の", "３７度を記録した", "猛暑日でした。"]}, {"box": [260, 903, 414, 1118], "vertical": true, "font_size": 25, "lines_coords": [[[385.0, 904.0], [412.0, 904.0], [414.0, 1110.0], [387.0, 1110.0]], [[353.0, 903.0], [379.0, 903.0], [381.0, 1118.0], [354.0, 1118.0]], [[321.0, 904.0], [348.0, 904.0], [350.0, 1112.0], [323.0, 1112.0]], [[292.0, 907.0], [314.0, 907.0], [314.0, 1084.0], [292.0, 1084.0]], [[260.0, 907.0], [282.0, 907.0], [282.0, 1090.0], [260.0, 1090.0]]], "lines": ["蝉の声に混じって", "どこからともなく、", "夏休みにはしゃく", "小学生達の声か", "聞こえてきます。"]}], "img_path": "011.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [810, 76, 901, 230], "vertical": true, "font_size": 27, "lines_coords": [[[873.0, 78.0], [900.0, 78.0], [900.0, 206.0], [873.0, 206.0]], [[840.0, 78.0], [867.0, 78.0], [867.0, 229.0], [840.0, 229.0]], [[810.0, 76.0], [837.0, 76.0], [837.0, 192.0], [810.0, 192.0]]], "lines": ["フンフンは", "夏は暑いので", "嫌いです。"]}, {"box": [595, 75, 721, 231], "vertical": true, "font_size": 30, "lines_coords": [[[685.0, 75.0], [721.0, 75.0], [721.0, 142.0], [685.0, 142.0]], [[657.0, 76.0], [684.0, 76.0], [684.0, 231.0], [657.0, 231.0]], [[626.0, 76.0], [653.0, 76.0], [653.0, 229.0], [626.0, 229.0]], [[595.0, 78.0], [623.0, 78.0], [623.0, 190.0], [595.0, 190.0]]], "lines": ["けど、", "冬になったら", "冬は寒いので", "嫌いです。"]}, {"box": [440, 77, 465, 215], "vertical": true, "font_size": 22, "lines_coords": [[[440.0, 78.0], [462.0, 78.0], [462.0, 214.0], [440.0, 214.0]]], "lines": ["．．．そうです。"]}, {"box": [252, 75, 342, 239], "vertical": true, "font_size": 25, "lines_coords": [[[314.0, 76.0], [340.0, 76.0], [340.0, 176.0], [314.0, 176.0]], [[281.0, 76.0], [309.0, 76.0], [309.0, 179.0], [281.0, 179.0]], [[253.0, 76.0], [275.0, 76.0], [275.0, 237.0], [253.0, 237.0]]], "lines": ["要するに", "今が一番", "嫌いなのです。"]}, {"box": [660, 853, 750, 1060], "vertical": true, "font_size": 24, "lines_coords": [[[726.0, 856.0], [748.0, 856.0], [748.0, 1057.0], [726.0, 1057.0]], [[695.0, 854.0], [717.0, 854.0], [717.0, 1031.0], [695.0, 1031.0]], [[660.0, 853.0], [687.0, 853.0], [687.0, 1039.0], [660.0, 1039.0]]], "lines": ["もっと考えるべき", "ことはたくさん", "あるはずなのに、"]}, {"box": [328, 851, 483, 1082], "vertical": true, "font_size": 25, "lines_coords": [[[454.0, 853.0], [481.0, 853.0], [481.0, 956.0], [454.0, 956.0]], [[420.0, 851.0], [448.0, 851.0], [450.0, 993.0], [421.0, 993.0]], [[392.0, 854.0], [414.0, 854.0], [414.0, 1079.0], [392.0, 1079.0]], [[356.0, 853.0], [382.0, 853.0], [382.0, 1082.0], [356.0, 1082.0]], [[328.0, 854.0], [350.0, 854.0], [350.0, 1040.0], [328.0, 1040.0]]], "lines": ["今はただ", "ひたすらに、", "天気と季節にばかり", "気をとられていたい", "フンフンでした。"]}], "img_path": "012.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [900, 720, 957, 877], "vertical": true, "font_size": 24, "lines_coords": [[[931.0, 720.0], [957.0, 720.0], [957.0, 876.0], [931.0, 876.0]], [[900.0, 723.0], [921.0, 723.0], [921.0, 875.0], [900.0, 875.0]]], "lines": ["．．．元気ないね", "フンフン．．．"]}, {"box": [954, 1057, 979, 1196], "vertical": true, "font_size": 22, "lines_coords": [[[954.0, 1057.0], [976.0, 1057.0], [976.0, 1195.0], [954.0, 1195.0]]], "lines": ["．．．どうかな。"]}, {"box": [124, 784, 245, 965], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 784.0], [245.0, 784.0], [245.0, 892.0], [217.0, 892.0]], [[185.0, 784.0], [212.0, 784.0], [212.0, 940.0], [185.0, 940.0]], [[154.0, 784.0], [182.0, 784.0], [179.0, 965.0], [151.0, 965.0]], [[125.0, 785.0], [146.0, 785.0], [146.0, 914.0], [125.0, 914.0]]], "lines": ["．．．顔には", "出さないけど", "やっぱり辛いん", "だよね．．．"]}, {"box": [716, 1401, 773, 1529], "vertical": true, "font_size": 22, "lines_coords": [[[748.0, 1403.0], [770.0, 1403.0], [770.0, 1529.0], [748.0, 1529.0]], [[717.0, 1401.0], [739.0, 1401.0], [739.0, 1515.0], [717.0, 1515.0]]], "lines": ["僕は違うと", "思うけど。"]}, {"box": [181, 1399, 211, 1555], "vertical": true, "font_size": 26, "lines_coords": [[[181.0, 1403.0], [207.0, 1403.0], [207.0, 1554.0], [181.0, 1554.0]]], "lines": ["．．．フンフン？"]}], "img_path": "013.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [901, 81, 929, 187], "vertical": true, "font_size": 28, "lines_coords": [[[901.0, 81.0], [929.0, 81.0], [929.0, 185.0], [901.0, 185.0]]], "lines": ["これ．．．"]}, {"box": [139, 254, 231, 435], "vertical": true, "font_size": 25, "lines_coords": [[[203.0, 254.0], [229.0, 254.0], [229.0, 435.0], [203.0, 435.0]], [[173.0, 257.0], [195.0, 257.0], [195.0, 434.0], [173.0, 434.0]], [[139.0, 254.0], [167.0, 254.0], [167.0, 335.0], [139.0, 335.0]]], "lines": ["渡そうかどうか", "迷ってたんだけ", "ど．．．"]}, {"box": [859, 609, 917, 760], "vertical": true, "font_size": 28, "lines_coords": [[[890.0, 609.0], [917.0, 609.0], [917.0, 760.0], [890.0, 760.0]], [[859.0, 609.0], [885.0, 609.0], [885.0, 721.0], [859.0, 721.0]]], "lines": ["お義姉さんの", "鞄の中に、"]}, {"box": [729, 698, 789, 806], "vertical": true, "font_size": 28, "lines_coords": [[[760.0, 698.0], [789.0, 698.0], [789.0, 806.0], [760.0, 806.0]], [[729.0, 700.0], [757.0, 700.0], [757.0, 806.0], [729.0, 806.0]]], "lines": ["入ってた", "から．．．．．"]}, {"box": [291, 1021, 356, 1215], "vertical": true, "font_size": 32, "lines_coords": [[[312.0, 1023.0], [353.0, 1021.0], [356.0, 1118.0], [315.0, 1120.0]], [[293.0, 1029.0], [315.0, 1029.0], [315.0, 1204.0], [293.0, 1204.0]]], "lines": ["．．．ただ、", "いつもとは違い"]}, {"box": [134, 1025, 227, 1256], "vertical": true, "font_size": 24, "lines_coords": [[[201.0, 1025.0], [225.0, 1025.0], [223.0, 1253.0], [200.0, 1253.0]], [[170.0, 1028.0], [192.0, 1028.0], [192.0, 1204.0], [170.0, 1204.0]], [[134.0, 1025.0], [160.0, 1025.0], [162.0, 1239.0], [135.0, 1239.0]]], "lines": ["その封筒には切手と", "差出人の名前が", "ありませんでした。"]}, {"box": [909, 1201, 968, 1416], "vertical": true, "font_size": 27, "lines_coords": [[[940.0, 1201.0], [968.0, 1201.0], [968.0, 1307.0], [940.0, 1307.0]], [[909.0, 1203.0], [935.0, 1203.0], [935.0, 1412.0], [909.0, 1412.0]]], "lines": ["父親から", "毎月送られてくる"]}, {"box": [758, 1202, 849, 1356], "vertical": true, "font_size": 25, "lines_coords": [[[820.0, 1203.0], [848.0, 1203.0], [848.0, 1309.0], [820.0, 1309.0]], [[789.0, 1204.0], [815.0, 1204.0], [815.0, 1356.0], [789.0, 1356.0]], [[759.0, 1204.0], [781.0, 1204.0], [781.0, 1337.0], [759.0, 1337.0]]], "lines": ["見慣れた", "たわいもない", "封筒でした。"]}], "img_path": "014.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [354, 76, 797, 856], "vertical": false, "font_size": 212, "lines_coords": [[[395.0, 212.0], [523.0, 692.0], [482.0, 703.0], [354.0, 223.0]], [[389.0, 196.0], [492.0, 175.0], [590.0, 640.0], [487.0, 662.0]], [[384.0, 93.0], [684.0, 76.0], [729.0, 839.0], [429.0, 856.0]], [[571.0, 234.0], [687.0, 685.0], [651.0, 695.0], [535.0, 243.0]], [[628.0, 200.0], [671.0, 412.0], [629.0, 421.0], [585.0, 209.0]], [[681.0, 176.0], [782.0, 648.0], [729.0, 659.0], [628.0, 187.0]]], "lines": ["皆さんからふふふホートや", "ごめんなさいってよ！", "それは．．．これからもうちょっと", "くるのちゃんといや、まーいかやん", "ダメビャン。", "２０メ普通ルーシャうーーせずいー"]}, {"box": [521, 967, 576, 1101], "vertical": true, "font_size": 28, "lines_coords": [[[548.