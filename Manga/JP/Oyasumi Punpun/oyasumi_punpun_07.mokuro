": 341, "lines_coords": [[[326.0, 817.0], [635.0, 589.0], [839.0, 862.0], [528.0, 1092.0]]], "lines": ["！！"]}, {"box": [126, 853, 218, 1032], "vertical": true, "font_size": 27, "lines_coords": [[[189.0, 854.0], [215.0, 854.0], [215.0, 982.0], [189.0, 982.0]], [[157.0, 854.0], [184.0, 854.0], [184.0, 1032.0], [157.0, 1032.0]], [[126.0, 853.0], [154.0, 853.0], [154.0, 945.0], [126.0, 945.0]]], "lines": ["少しばかり", "センチメンタル", "なんだ。"]}, {"box": [828, 1228, 889, 1359], "vertical": true, "font_size": 27, "lines_coords": [[[862.0, 1229.0], [889.0, 1229.0], [889.0, 1334.0], [862.0, 1334.0]], [[831.0, 1228.0], [857.0, 1228.0], [854.0, 1359.0], [828.0, 1359.0]]], "lines": ["何年振り", "だろう．．．"]}, {"box": [112, 1267, 233, 1434], "vertical": true, "font_size": 27, "lines_coords": [[[204.0, 1267.0], [232.0, 1267.0], [232.0, 1398.0], [204.0, 1398.0]], [[175.0, 1267.0], [201.0, 1267.0], [201.0, 1398.0], [175.0, 1398.0]], [[143.0, 1268.0], [170.0, 1268.0], [170.0, 1398.0], [143.0, 1398.0]], [[112.0, 1267.0], [139.0, 1267.0], [139.0, 1434.0], [112.0, 1434.0]]], "lines": ["こうやって", "プンプンと", "二人きりて", "歩くのなんて。"]}], "img_path": "035.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [905, 58, 962, 239], "vertical": true, "font_size": 24, "lines_coords": [[[935.0, 59.0], [962.0, 59.0], [962.0, 215.0], [935.0, 215.0]], [[906.0, 62.0], [928.0, 62.0], [928.0, 239.0], [906.0, 239.0]]], "lines": ["ずっと前から", "思ってたんだ．．．"]}, {"box": [692, 90, 751, 269], "vertical": true, "font_size": 23, "lines_coords": [[[726.0, 92.0], [748.0, 92.0], [748.0, 268.0], [726.0, 268.0]], [[692.0, 90.0], [715.0, 90.0], [717.0, 243.0], [693.0, 243.0]]], "lines": ["僕とフンフンは", "似てるって．．．"]}, {"box": [509, 128, 616, 314], "vertical": true, "font_size": 21, "lines_coords": [[[593.0, 131.0], [615.0, 131.0], [615.0, 290.0], [593.0, 290.0]], [[562.0, 128.0], [584.0, 128.0], [584.0, 312.0], [562.0, 312.0]], [[535.0, 131.0], [557.0, 131.0], [557.0, 245.0], [535.0, 245.0]], [[509.0, 131.0], [526.0, 131.0], [526.0, 228.0], [509.0, 228.0]]], "lines": ["僕はプンプンの", "苛立ちを理解して", "あげられる", "つもりさ"]}, {"box": [96, 64, 381, 90], "vertical": false, "font_size": 26, "lines_coords": [[[96.0, 64.0], [381.0, 64.0], [381.0, 90.0], [96.0, 90.0]]], "lines": ["おやすみプンプン区"]}, {"box": [308, 171, 365, 311], "vertical": true, "font_size": 24, "lines_coords": [[[339.0, 171.0], [365.0, 171.0], [365.0, 303.0], [339.0, 303.0]], [[309.0, 171.0], [331.0, 171.0], [331.0, 310.0], [309.0, 310.0]]], "lines": ["人はみんな", "勝手過ぎる。"]}, {"box": [97, 556, 225, 737], "vertical": true, "font_size": 26, "lines_coords": [[[195.0, 556.0], [223.0, 556.0], [223.0, 665.0], [195.0, 665.0]], [[159.0, 557.0], [185.0, 557.0], [185.0, 720.0], [159.0, 720.0]], [[125.0, 557.0], [151.0, 557.0], [151.0, 737.0], [125.0, 737.0]], [[98.0, 559.0], [120.0, 559.0], [120.0, 695.0], [98.0, 695.0]]], "lines": ["姉さんも", "お義兄さんも、", "．．．もちろん自分", "自身だって。"]}, {"box": [843, 834, 929, 1014], "vertical": true, "font_size": 25, "lines_coords": [[[907.0, 834.0], [929.0, 834.0], [929.0, 1012.0], [907.0, 1012.0]], [[873.0, 834.0], [900.0, 834.0], [900.0, 1014.0], [873.0, 1014.0]], [[843.0, 835.0], [865.0, 835.0], [865.0, 987.0], [843.0, 987.0]]], "lines": ["．．．お義兄さんも", "根は真面目な人", "だからね．．．．．"]}, {"box": [737, 1000, 831, 1184], "vertical": true, "font_size": 25, "lines_coords": [[[804.0, 1001.0], [831.0, 1001.0], [831.0, 1089.0], [804.0, 1089.0]], [[773.0, 1000.0], [800.0, 1000.0], [796.0, 1184.0], [770.0, 1184.0]], [[740.0, 1001.0], [767.0, 1001.0], [764.0, 1168.0], [737.0, 1168.0]]], "lines": ["．．．まぁ、", "悪く思わないで", "やってくれよ。"]}, {"box": [246, 1312, 335, 1446], "vertical": true, "font_size": 25, "lines_coords": [[[315.0, 1315.0], [335.0, 1315.0], [335.0, 1446.0], [315.0, 1446.0]], [[281.0, 1314.0], [307.0, 1314.0], [307.0, 1443.0], [281.0, 1443.0]], [[246.0, 1312.0], [273.0, 1312.0], [276.0, 1432.0], [250.0, 1432.0]]], "lines": ["．．．もちろん", "同情なんて", "必要ない。"]}, {"box": [112, 1346, 203, 1554], "vertical": true, "font_size": 25, "lines_coords": [[[175.0, 1346.0], [201.0, 1346.0], [203.0, 1554.0], [176.0, 1554.0]], [[145.0, 1346.0], [167.0, 1346.0], [167.0, 1526.0], [145.0, 1526.0]], [[112.0, 1346.0], [139.0, 1346.0], [139.0, 1437.0], [112.0, 1437.0]]], "lines": ["お義兄さんだって", "そんなの望んで", "ないさ。"]}], "img_path": "036.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [863, 106, 953, 335], "vertical": true, "font_size": 24, "lines_coords": [[[926.0, 106.0], [953.0, 106.0], [953.0, 262.0], [926.0, 262.0]], [[893.0, 106.0], [917.0, 106.0], [918.0, 335.0], [895.0, 335.0]], [[864.0, 106.0], [885.0, 106.0], [885.0, 295.0], [864.0, 295.0]]], "lines": ["人生に於いて", "ほとんどの出来事は", "自業自得なんだ。"]}, {"box": [329, 184, 420, 339], "vertical": true, "font_size": 25, "lines_coords": [[[393.0, 185.0], [420.0, 185.0], [420.0, 314.0], [393.0, 314.0]], [[364.0, 185.0], [385.0, 185.0], [385.0, 339.0], [364.0, 339.0]], [[329.0, 184.0], [356.0, 184.0], [356.0, 320.0], [329.0, 320.0]]], "lines": ["自分で選び", "歩んできた道", "じゃないか。"]}, {"box": [951, 981, 979, 1136], "vertical": true, "font_size": 27, "lines_coords": [[[951.0, 981.0], [978.0, 981.0], [978.0, 1135.0], [951.0, 1135.0]]], "lines": ["プンプン．．．"]}, {"box": [479, 1007, 571, 1165], "vertical": true, "font_size": 29, "lines_coords": [[[542.0, 1009.0], [570.0, 1009.0], [571.0, 1145.0], [543.0, 1145.0]], [[509.0, 1007.0], [542.0, 1007.0], [542.0, 1115.0], [509.0, 1115.0]], [[479.0, 1009.0], [506.0, 1009.0], [506.0, 1162.0], [479.0, 1162.0]]], "lines": ["．．．お金、夢、", "他人への", "思いやり．．．"]}, {"box": [159, 760, 183, 914], "vertical": true, "font_size": 20, "lines_coords": [[[159.0, 760.0], [179.0, 760.0], [179.0, 914.0], [159.0, 914.0]]], "lines": ["そうだろう？"]}, {"box": [126, 1051, 215, 1235], "vertical": true, "font_size": 25, "lines_coords": [[[185.0, 1051.0], [212.0, 1051.0], [215.0, 1184.0], [189.0, 1184.0]], [[156.0, 1054.0], [182.0, 1054.0], [182.0, 1235.0], [156.0, 1235.0]], [[126.0, 1056.0], [148.0, 1056.0], [148.0, 1206.0], [126.0, 1206.0]]], "lines": ["．．．なるほど", "どれも大切かも", "しれない．．．"]}, {"box": [604, 1332, 706, 1496], "vertical": true, "font_size": 24, "lines_coords": [[[679.0, 1332.0], [706.0, 1332.0], [706.0, 1429.0], [679.0, 1429.0]], [[657.0, 1334.0], [679.0, 1334.0], [679.0, 1495.0], [657.0, 1495.0]], [[629.0, 1332.0], [653.0, 1332.0], [654.0, 1495.0], [631.0, 1495.0]], [[604.0, 1334.0], [626.0, 1334.0], [628.0, 1496.0], [606.0, 1496.0]]], "lines": ["人として", "生きてくうえて", "大切なものって", "なんだと思う？"]}, {"box": [129, 1368, 222, 1539], "vertical": true, "font_size": 27, "lines_coords": [[[193.0, 1373.0], [220.0, 1373.0], [220.0, 1503.0], [193.0, 1503.0]], [[162.0, 1373.0], [189.0, 1373.0], [189.0, 1503.0], [162.0, 1503.0]], [[131.0, 1368.0], [157.0, 1368.0], [156.0, 1539.0], [129.0, 1539.0]]], "lines": ["．．．けど一番", "大事なのは", "「覚悟」なのさ。"]}], "img_path": "037.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [917, 89, 1010, 250], "vertical": true, "font_size": 26, "lines_coords": [[[984.0, 89.0], [1010.0, 89.0], [1010.0, 215.0], [984.0, 215.0]], [[951.0, 92.0], [979.0, 92.0], [976.0, 243.0], [948.0, 243.0]], [[920.0, 89.0], [948.0, 89.0], [945.0, 250.0], [917.0, 250.0]]], "lines": ["フンフンが", "一人で暮らす", "って言った時、"]}, {"box": [821, 196, 912, 310], "vertical": true, "font_size": 26, "lines_coords": [[[884.0, 196.0], [912.0, 196.0], [912.0, 287.0], [884.0, 287.0]], [[853.0, 201.0], [879.0, 201.0], [879.0, 304.0], [853.0, 304.0]], [[821.0, 200.0], [843.0, 200.0], [843.0, 310.0], [821.0, 310.0]]], "lines": ["．．．正直、", "おじさん", "痺れたよ"]}, {"box": [314, 92, 427, 271], "vertical": true, "font_size": 24, "lines_coords": [[[400.0, 92.0], [426.0, 92.0], [426.0, 221.0], [400.0, 221.0]], [[373.0, 93.0], [395.0, 93.0], [395.0, 271.0], [373.0, 271.0]], [[342.0, 92.0], [368.0, 92.0], [368.0, 196.0], [342.0, 196.0]], [[315.0, 93.0], [337.0, 93.0], [337.0, 231.0], [315.0, 231.0]]], "lines": ["ブンブンが", "決めたことなら", "僕は何も", "言わないさ。"]}, {"box": [956, 660, 982, 764], "vertical": true, "font_size": 25, "lines_coords": [[[956.0, 660.0], [982.0, 660.0], [982.0, 764.0], [956.0, 764.0]]], "lines": ["ただもし"]}, {"box": [465, 396, 568, 566], "vertical": true, "font_size": 30, "lines_coords": [[[532.0, 396.0], [568.0, 396.0], [568.0, 457.0], [532.0, 457.0]], [[504.0, 400.0], [531.0, 400.0], [531.0, 554.0], [504.0, 554.0]], [[465.0, 400.0], [492.0, 400.0], [495.0, 562.0], [468.0, 562.0]]], "lines": ["正直", "おちんちんが", "捻れあがった。"]}, {"box": [98, 373, 222, 578], "vertical": true, "font_size": 25, "lines_coords": [[[195.0, 376.0], [217.0, 376.0], [217.0, 540.0], [195.0, 540.0]], [[164.0, 375.0], [187.0, 375.0], [185.0, 551.0], [162.0, 551.0]], [[129.0, 373.0], [156.0, 373.0], [156.0, 578.0], [129.0, 578.0]], [[98.0, 373.0], [125.0, 373.0], [125.0, 575.0], [98.0, 575.0]]], "lines": ["．．．たとえ、君が", "ひき込もろうが", "殺人犯になろうが", "知ったこっちゃない。"]}, {"box": [785, 785, 909, 940], "vertical": true, "font_size": 25, "lines_coords": [[[887.0, 785.0], [909.0, 785.0], [909.0, 939.0], [887.0, 939.0]], [[851.0, 785.0], [878.0, 785.0], [878.0, 940.0], [851.0, 940.0]], [[820.0, 785.0], [846.0, 785.0], [846.0, 940.0], [820.0, 940.0]], [[785.0, 787.0], [810.0, 785.0], [815.0, 875.0], [790.0, 876.0]]], "lines": ["ただもし君が", "それを他人や", "環境のせいに", "したら"]}, {"box": [143, 1001, 253, 1189], "vertical": true, "font_size": 31, "lines_coords": [[[220.0, 1001.0], [253.0, 1001.0], [250.0, 1176.0], [217.0, 1176.0]], [[179.0, 1004.0], [212.0, 1004.0], [212.0, 1131.0], [179.0, 1131.0]], [[143.0, 1006.0], [170.0, 1006.0], [170.0, 1189.0], [143.0, 1189.0]]], "lines": ["僕ァ、貴様を", "日本刀で", "たたっ切る！！"]}, {"box": [895, 1296, 982, 1453], "vertical": true, "font_size": 25, "lines_coords": [[[956.0, 1300.0], [982.0, 1300.0], [982.0, 1429.0], [956.0, 1429.0]], [[926.0, 1298.0], [953.0, 1298.0], [953.0, 1407.0], [926.0, 1407.0]], [[896.0, 1296.0], [920.0, 1296.0], [918.0, 1453.0], [895.0, 1453.0]]], "lines": ["．．．いいか！？", "よく聞け、", "この豚野郎！！"]}, {"box": [743, 1360, 857, 1568], "vertical": true, "font_size": 25, "lines_coords": [[[831.0, 1360.0], [857.0, 1360.0], [857.0, 1490.0], [831.0, 1490.0]], [[803.0, 1360.0], [829.0, 1360.0], [829.0, 1568.0], [803.0, 1568.0]], [[775.0, 1362.0], [796.0, 1362.0], [796.0, 1489.0], [775.0, 1489.0]], [[743.0, 1360.0], [770.0, 1360.0], [770.0, 1465.0], [743.0, 1465.0]]], "lines": ["人生なんて", "びっくりするほど", "フリータム", "なのさ！！"]}, {"box": [100, 1335, 221, 1568], "vertical": true, "font_size": 24, "lines_coords": [[[195.0, 1339.0], [217.0, 1339.0], [217.0, 1567.0], [195.0, 1567.0]], [[160.0, 1335.0], [187.0, 1335.0], [185.0, 1520.0], [159.0, 1520.0]], [[128.0, 1337.0], [154.0, 1337.0], [154.0, 1542.0], [128.0, 1542.0]], [[100.0, 1339.0], [121.0, 1339.0], [121.0, 1492.0], [100.0, 1492.0]]], "lines": ["けど自由には責任が", "あるってことを", "忘れちゃいけない", "のさ、ボーイ。"]}], "img_path": "038.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [901, 100, 990, 256], "vertical": true, "font_size": 26, "lines_coords": [[[964.0, 100.0], [990.0, 100.0], [990.0, 254.0], [964.0, 254.0]], [[931.0, 100.0], [957.0, 100.0], [957.0, 256.0], [931.0, 256.0]], [[901.0, 100.0], [923.0, 100.0], [923.0, 181.0], [901.0, 181.0]]], "lines": ["僕が翠さんに", "初めて中出し", "した時"]}, {"box": [765, 156, 857, 337], "vertical": true, "font_size": 26, "lines_coords": [[[829.0, 156.0], [857.0, 156.0], [857.0, 259.0], [829.0, 259.0]], [[798.0, 156.0], [825.0, 156.0], [825.0, 337.0], [798.0, 337.0]], [[765.0, 156.0], [793.0, 156.0], [793.0, 245.0], [765.0, 245.0]]], "lines": ["僕の中の", "僕のほとんどが", "死んだ。"]}, {"box": [871, 429, 964, 562], "vertical": true, "font_size": 26, "lines_coords": [[[940.0, 429.0], [964.0, 429.0], [960.0, 535.0], [937.0, 535.0]], [[906.0, 431.0], [932.0, 431.0], [932.0, 562.0], [906.0, 562.0]], [[871.0, 431.0], [898.0, 431.0], [898.0, 529.0], [871.0, 529.0]]], "lines": ["翠さんと", "結婚を決意", "した時ー"]}, {"box": [875, 432, 963, 589], "vertical": true, "font_size": 88, "lines_coords": [[[875.0, 432.0], [963.0, 432.0], [963.0, 589.0], [875.0, 589.0]]], "lines": ["翠さんと結婚を決意した時―．．．"]}, {"box": [846, 620, 906, 776], "vertical": true, "font_size": 26, "lines_coords": [[[879.0, 620.0], [906.0, 620.0], [903.0, 776.0], [876.0, 776.0]], [[846.0, 621.0], [873.0, 621.0], [873.0, 776.0], [846.0, 776.0]]], "lines": ["僕達は人生で", "起きたことを"]}, {"box": [782, 620, 904, 826], "vertical": true, "font_size": 27, "lines_coords": [[[815.0, 620.0], [842.0, 620.0], [842.0, 826.0], [815.0, 826.0]], [[782.0, 623.0], [809.0, 623.0], [809.0, 762.0], [782.0, 762.0]]], "lines": ["すべて洗いざらい", "話したんだ。"]}, {"box": [223, 609, 285, 715], "vertical": true, "font_size": 28, "lines_coords": [[[257.0, 610.0], [285.0, 610.0], [285.0, 715.0], [257.0, 715.0]], [[223.0, 609.0], [257.0, 609.0], [257.0, 676.0], [223.0, 676.0]]], "lines": ["．．．だから", "僕は、"]}, {"box": [597, 1093, 654, 1259], "vertical": true, "font_size": 24, "lines_coords": [[[628.0, 1093.0], [654.0, 1093.0], [651.0, 1250.0], [625.0, 1250.0]], [[598.0, 1095.0], [620.0, 1095.0], [620.0, 1256.0], [598.0, 1256.0]]], "lines": ["．．．けど怒りは", "湧かなかった。"]}, {"box": [156, 768, 242, 979], "vertical": true, "font_size": 28, "lines_coords": [[[220.0, 771.0], [242.0, 771.0], [242.0, 976.0], [220.0, 976.0]], [[182.0, 768.0], [214.0, 768.0], [210.0, 979.0], [179.0, 979.0]], [[156.0, 771.0], [178.0, 771.0], [178.0, 959.0], [156.0, 959.0]]], "lines": ["君と翠さんの間に", "何があったのかを", "よく知っている。"]}, {"box": [92, 1109, 179, 1289], "vertical": true, "font_size": 24, "lines_coords": [[[150.0, 1109.0], [178.0, 1109.0], [179.0, 1240.0], [151.0, 1240.0]], [[123.0, 1110.0], [145.0, 1110.0], [145.0, 1264.0], [123.0, 1264.0]], [[92.0, 1110.0], [114.0, 1110.0], [114.0, 1289.0], [92.0, 1289.0]]], "lines": ["むしろ君を", "愛していると", "言ってもいい！！"]}, {"box": [389, 1423, 416, 1563], "vertical": true, "font_size": 26, "lines_coords": [[[389.0, 1423.0], [415.0, 1423.0], [415.0, 1562.0], [389.0, 1562.0]]], "lines": ["．．．プンプン"]}], "img_path": "039.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [920, 146, 944, 303], "vertical": true, "font_size": 22, "lines_coords": [[[921.0, 148.0], [943.0, 148.0], [943.0, 301.0], [921.0, 301.0]]], "lines": ["僕は思うよ．．．"]}, {"box": [154, 318, 243, 501], "vertical": true, "font_size": 26, "lines_coords": [[[210.0, 321.0], [239.0, 320.0], [243.0, 423.0], [215.0, 425.0]], [[181.0, 318.0], [207.0, 318.0], [210.0, 501.0], [184.0, 501.0]], [[154.0, 321.0], [176.0, 321.0], [176.0, 432.0], [154.0, 432.0]]], "lines": ["人生って", "おもしろ過ぎる", "だろって。"]}, {"box": [321, 676, 410, 862], "vertical": true, "font_size": 24, "lines_coords": [[[381.0, 676.0], [407.0, 676.0], [410.0, 810.0], [384.0, 810.0]], [[351.0, 679.0], [378.0, 679.0], [378.0, 860.0], [351.0, 860.0]], [[321.0, 682.0], [343.0, 682.0], [343.0, 862.0], [321.0, 862.0]]], "lines": ["生きていて", "無駄な時なんて", "一瞬もなかった"]}, {"box": [931, 1001, 984, 1132], "vertical": true, "font_size": 26, "lines_coords": [[[962.0, 1001.0], [984.0, 1001.0], [984.0, 1129.0], [962.0, 1129.0]], [[931.0, 1001.0], [953.0, 1001.0], [953.0, 1132.0], [931.0, 1132.0]]], "lines": ["そうやって", "僕は今日も"]}, {"box": [798, 1096, 895, 1251], "vertical": true, "font_size": 26, "lines_coords": [[[868.0, 1096.0], [895.0, 1096.0], [895.0, 1229.0], [868.0, 1229.0]], [[834.0, 1098.0], [860.0, 1098.0], [860.0, 1251.0], [834.0, 1251.0]], [[798.0, 1098.0], [832.0, 1096.0], [835.0, 1167.0], [801.0, 1168.0]]], "lines": ["この平坦な", "毎日を生きて", "いる。"]}, {"box": [146, 731, 267, 935], "vertical": true, "font_size": 24, "lines_coords": [[[240.0, 731.0], [267.0, 731.0], [267.0, 862.0], [240.0, 862.0]], [[210.0, 732.0], [232.0, 732.0], [232.0, 887.0], [210.0, 887.0]], [[178.0, 731.0], [200.0, 731.0], [200.0, 935.0], [178.0, 935.0]], [[146.0, 732.0], [168.0, 732.0], [168.0, 842.0], [146.0, 842.0]]], "lines": ["僕みたいな", "人間の層でも", "そう思える瞬間が", "来るんだ"]}, {"box": [134, 1054, 257, 1260], "vertical": true, "font_size": 24, "lines_coords": [[[229.0, 1054.0], [256.0, 1054.0], [256.0, 1159.0], [229.0, 1159.0]], [[200.0, 1056.0], [221.0, 1056.0], [221.0, 1259.0], [200.0, 1259.0]], [[165.0, 1054.0], [192.0, 1054.0], [192.0, 1162.0], [165.0, 1162.0]], [[134.0, 1056.0], [156.0, 1056.0], [156.0, 1192.0], [134.0, 1192.0]]], "lines": ["翠さんに", "とどめを刺される", "その日を", "夢見ながら"]}, {"box": [904, 1345, 936, 1503], "vertical": true, "font_size": 28, "lines_coords": [[[907.0, 1345.0], [935.0, 1345.0], [932.0, 1500.0], [904.0, 1500.0]]], "lines": ["プンフン．．．"]}, {"box": [106, 1393, 200, 1526], "vertical": true, "font_size": 29, "lines_coords": [[[162.0, 1393.0], [200.0, 1393.0], [200.0, 1453.0], [162.0, 1453.0]], [[135.0, 1396.0], [162.0, 1396.0], [162.0, 1526.0], [135.0, 1526.0]], [[106.0, 1396.0], [128.0, 1396.0], [128.0, 1500.0], [106.0, 1500.0]]], "lines": ["君の", "死に場所は", "どこだ？"]}], "img_path": "040.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [493, 196, 602, 414], "vertical": true, "font_size": 33, "lines_coords": [[[568.0, 196.0], [601.0, 196.0], [601.0, 292.0], [568.0, 292.0]], [[532.0, 198.0], [565.0, 198.0], [565.0, 325.0], [532.0, 325.0]], [[493.0, 200.0], [525.0, 200.0], [525.0, 414.0], [493.0, 414.0]]], "lines": ["その時", "君の命は", "燃えているか？"]}], "img_path": "041.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [939, 95, 965, 248], "vertical": true, "font_size": 26, "lines_coords": [[[939.0, 95.0], [965.0, 95.0], [965.0, 248.0], [939.0, 248.0]]], "lines": ["プンプン．．．"]}, {"box": [865, 257, 892, 396], "vertical": true, "font_size": 26, "lines_coords": [[[865.0, 257.0], [892.0, 257.0], [892.0, 396.0], [865.0, 396.0]]], "lines": ["考えるんだ。"]}, {"box": [250, 121, 271, 275], "vertical": true, "font_size": 25, "lines_coords": [[[250.0, 121.0], [271.0, 121.0], [271.0, 275.0], [250.0, 275.0]]], "lines": ["そして悩め！！"]}, {"box": [135, 293, 229, 459], "vertical": true, "font_size": 25, "lines_coords": [[[203.0, 293.0], [229.0, 293.0], [229.0, 425.0], [203.0, 425.0]], [[170.0, 293.0], [196.0, 293.0], [196.0, 450.0], [170.0, 450.0]], [[139.0, 295.0], [165.0, 295.0], [162.0, 459.0], [135.0, 459.0]]], "lines": ["そうやって", "自分の意思で", "選択するんだ。"]}, {"box": [862, 656, 948, 835], "vertical": true, "font_size": 23, "lines_coords": [[[925.0, 657.0], [946.0, 657.0], [946.0, 785.0], [925.0, 785.0]], [[890.0, 656.0], [917.0, 656.0], [917.0, 835.0], [890.0, 835.0]], [[862.0, 656.0], [884.0, 656.0], [884.0, 765.0], [862.0, 765.0]]], "lines": ["たとえ何も", "わからなかった", "としても、"]}, {"box": [242, 676, 332, 809], "vertical": true, "font_size": 27, "lines_coords": [[[301.0, 676.0], [329.0, 676.0], [332.0, 807.0], [304.0, 807.0]], [[273.0, 678.0], [300.0, 678.0], [300.0, 809.0], [273.0, 809.0]], [[242.0, 681.0], [268.0, 681.0], [268.0, 793.0], [242.0, 793.0]]], "lines": ["わかろうと", "前に進んで", "いる限り、"]}, {"box": [890, 1017, 950, 1148], "vertical": true, "font_size": 28, "lines_coords": [[[928.0, 1020.0], [950.0, 1020.0], [950.0, 1148.0], [928.0, 1148.0]], [[890.0, 1017.0], [923.0, 1017.0], [923.0, 1109.0], [890.0, 1109.0]]], "lines": ["この退屈な", "日常も、"]}, {"box": [776, 1084, 837, 1218], "vertical": true, "font_size": 28, "lines_coords": [[[809.0, 1084.0], [837.0, 1084.0], [832.0, 1218.0], [804.0, 1218.0]], [[776.0, 1089.0], [804.0, 1089.0], [804.0, 1178.0], [776.0, 1178.0]]], "lines": ["くだらない", "景色も、"]}, {"box": [128, 754, 220, 923], "vertical": true, "font_size": 27, "lines_coords": [[[193.0, 754.0], [220.0, 754.0], [220.0, 885.0], [193.0, 885.0]], [[160.0, 756.0], [187.0, 756.0], [187.0, 912.0], [160.0, 912.0]], [[128.0, 757.0], [154.0, 757.0], [154.0, 923.0], [128.0, 923.0]]], "lines": ["かろうじて", "自分は自分で", "いられるんだ。"]}, {"box": [182, 1057, 272, 1237], "vertical": true, "font_size": 25, "lines_coords": [[[245.0, 1057.0], [271.0, 1057.0], [271.0, 1237.0], [245.0, 1237.0]], [[212.0, 1057.0], [239.0, 1057.0], [239.0, 1189.0], [212.0, 1189.0]], [[182.0, 1059.0], [204.0, 1059.0], [204.0, 1210.0], [182.0, 1210.0]]], "lines": ["作り変えられる", "のは、自分", "だけなんだ！！"]}, {"box": [856, 1346, 918, 1504], "vertical": true, "font_size": 30, "lines_coords": [[[885.0, 1346.0], [918.0, 1346.0], [918.0, 1431.0], [885.0, 1431.0]], [[856.0, 1348.0], [882.0, 1348.0], [882.0, 1503.0], [856.0, 1503.0]]], "lines": ["だから", "フンフン．．．"]}, {"box": [268, 1365, 329, 1520], "vertical": true, "font_size": 25, "lines_coords": [[[300.0, 1365.0], [328.0, 1365.0], [328.0, 1470.0], [300.0, 1470.0]], [[268.0, 1368.0], [290.0, 1368.0], [290.0, 1515.0], [268.0, 1515.0]]], "lines": ["君が君で", "いる限り．．．"]}], "img_path": "042.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [564, 75, 656, 293], "vertical": true, "font_size": 25, "lines_coords": [[[629.0, 78.0], [656.0, 78.0], [656.0, 231.0], [629.0, 231.0]], [[598.0, 75.0], [625.0, 75.0], [621.0, 232.0], [595.0, 232.0]], [[567.0, 78.0], [589.0, 78.0], [589.0, 287.0], [567.0, 287.0]]], "lines": ["タバコの煙は", "頼りなさ気に", "散り散りになって、"]}, {"box": [429, 76, 486, 257], "vertical": true, "font_size": 24, "lines_coords": [[[457.0, 76.0], [484.0, 76.0], [485.0, 254.0], [459.0, 254.0]], [[429.0, 78.0], [451.0, 78.0], [451.0, 210.0], [429.0, 210.0]]], "lines": ["夕焼けに溶けて", "ゆきました。"]}, {"box": [875, 420, 905, 587], "vertical": true, "font_size": 26, "lines_coords": [[[875.0, 420.0], [901.0, 420.0], [901.0, 581.0], [875.0, 581.0]]], "lines": ["この世界は、"]}, {"box": [182, 1051, 214, 1219], "vertical": true, "font_size": 32, "lines_coords": [[[182.0, 1051.0], [214.0, 1051.0], [214.0, 1212.0], [182.0, 1212.0]]], "lines": ["君のものだ。"]}, {"box": [598, 1337, 723, 1543], "vertical": true, "font_size": 25, "lines_coords": [[[698.0, 1343.0], [720.0, 1343.0], [720.0, 1468.0], [698.0, 1468.0]], [[667.0, 1342.0], [689.0, 1342.0], [689.0, 1517.0], [667.0, 1517.0]], [[632.0, 1339.0], [656.0, 1339.0], [657.0, 1542.0], [634.0, 1542.0]], [[598.0, 1337.0], [631.0, 1337.0], [631.0, 1429.0], [598.0, 1429.0]]], "lines": ["もう二度と", "元には戻れない", "気持ちを確かめる", "ように、"]}, {"box": [521, 1339, 550, 1477], "vertical": true, "font_size": 29, "lines_coords": [[[521.0, 1339.0], [550.0, 1339.0], [550.0, 1470.0], [521.0, 1470.0]]], "lines": ["フンフンは"]}, {"box": [414, 1339, 473, 1529], "vertical": true, "font_size": 24, "lines_coords": [[[445.0, 1340.0], [471.0, 1340.0], [471.0, 1493.0], [445.0, 1493.0]], [[415.0, 1342.0], [437.0, 1342.0], [437.0, 1523.0], [415.0, 1523.0]]], "lines": ["深く深く煙を", "吸い込みました。"]}], "img_path": "043.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "044.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "045.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [512, 472, 603, 678], "vertical": true, "font_size": 27, "lines_coords": [[[576.0, 473.0], [603.0, 473.0], [603.0, 578.0], [576.0, 578.0]], [[543.0, 473.0], [570.0, 473.0], [570.0, 678.0], [543.0, 678.0]], [[512.0, 473.0], [539.0, 473.0], [539.0, 584.0], [512.0, 584.0]]], "lines": ["耳の奥で", "響いているような", "秒針の音。"]}, {"box": [37, 298, 79, 510], "vertical": true, "font_size": 42, "lines_coords": [[[37.0, 298.0], [79.0, 298.0], [79.0, 510.0], [37.0, 510.0]]], "lines": ["第７０話し"]}, {"box": [525, 1293, 588, 1473], "vertical": true, "font_size": 24, "lines_coords": [[[562.0, 1295.0], [584.0, 1295.0], [584.0, 1470.0], [562.0, 1470.0]], [[528.0, 1293.0], [554.0, 1293.0], [551.0, 1451.0], [525.0, 1451.0]]], "lines": ["７時１０分に鳴る", "日覚まし時計。"]}], "img_path": "046.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [487, 510, 606, 666], "vertical": true, "font_size": 26, "lines_coords": [[[578.0, 510.0], [606.0, 510.0], [606.0, 615.0], [578.0, 615.0]], [[548.0, 512.0], [575.0, 512.0], [575.0, 665.0], [548.0, 665.0]], [[515.0, 512.0], [542.0, 512.0], [542.0, 640.0], [515.0, 640.0]], [[487.0, 514.0], [509.0, 514.0], [509.0, 623.0], [487.0, 623.0]]], "lines": ["どこかで", "聞いたことの", "あるような", "ニュース。"]}, {"box": [501, 1276, 590, 1532], "vertical": true, "font_size": 24, "lines_coords": [[[565.0, 1278.0], [587.0, 1278.0], [587.0, 1526.0], [565.0, 1526.0]], [[531.0, 1276.0], [559.0, 1276.0], [559.0, 1428.0], [531.0, 1428.0]], [[501.0, 1278.0], [523.0, 1278.0], 