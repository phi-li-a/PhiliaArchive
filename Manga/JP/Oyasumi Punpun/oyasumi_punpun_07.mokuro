 [954.0, 770.0], [956.0, 957.0], [934.0, 957.0]], [[906.0, 771.0], [928.0, 771.0], [928.0, 889.0], [906.0, 889.0]]], "lines": ["：俺は教員免許", "とるために猛勉強", "するぜよ！！"]}, {"box": [804, 820, 857, 957], "vertical": true, "font_size": 23, "lines_coords": [[[828.0, 820.0], [854.0, 820.0], [857.0, 957.0], [831.0, 957.0]], [[804.0, 821.0], [828.0, 821.0], [828.0, 893.0], [804.0, 893.0]]], "lines": ["めんどくせー", "けど！！"]}, {"box": [921, 1098, 975, 1235], "vertical": true, "font_size": 22, "lines_coords": [[[948.0, 1098.0], [975.0, 1098.0], [975.0, 1193.0], [948.0, 1193.0]], [[921.0, 1100.0], [943.0, 1100.0], [943.0, 1235.0], [921.0, 1235.0]]], "lines": ["おつかれ", "サンセット！！"]}, {"box": [648, 807, 753, 946], "vertical": true, "font_size": 23, "lines_coords": [[[731.0, 809.0], [753.0, 809.0], [753.0, 903.0], [731.0, 903.0]], [[703.0, 809.0], [725.0, 809.0], [725.0, 925.0], [703.0, 925.0]], [[673.0, 807.0], [700.0, 807.0], [700.0, 903.0], [673.0, 903.0]], [[648.0, 809.0], [668.0, 809.0], [668.0, 946.0], [648.0, 946.0]]], "lines": ["．．．ウン！！", "そんな俺も", "けっこー", "カッコいい！！"]}, {"box": [139, 807, 221, 993], "vertical": true, "font_size": 23, "lines_coords": [[[193.0, 807.0], [220.0, 807.0], [221.0, 979.0], [195.0, 979.0]], [[168.0, 807.0], [190.0, 807.0], [190.0, 993.0], [168.0, 993.0]], [[139.0, 807.0], [160.0, 807.0], [162.0, 948.0], [140.0, 948.0]]], "lines": ["俺のこの繊細さ、", "オノッティーには", "わかるまい！！"]}, {"box": [789, 1235, 895, 1421], "vertical": true, "font_size": 22, "lines_coords": [[[871.0, 1235.0], [895.0, 1235.0], [895.0, 1307.0], [871.0, 1307.0]], [[843.0, 1235.0], [865.0, 1235.0], [865.0, 1421.0], [843.0, 1421.0]], [[815.0, 1237.0], [835.0, 1237.0], [835.0, 1421.0], [815.0, 1421.0]], [[789.0, 1235.0], [809.0, 1235.0], [809.0, 1376.0], [789.0, 1376.0]]], "lines": ["今晩は", "泣きながら腹筋を", "痛めつけることに", "俺は決めた！！"]}, {"box": [125, 1224, 233, 1445], "vertical": true, "font_size": 23, "lines_coords": [[[207.0, 1226.0], [229.0, 1226.0], [229.0, 1410.0], [207.0, 1410.0]], [[178.0, 1225.0], [204.0, 1225.0], [204.0, 1343.0], [178.0, 1343.0]], [[153.0, 1225.0], [175.0, 1225.0], [175.0, 1435.0], [153.0, 1435.0]], [[125.0, 1225.0], [146.0, 1225.0], [146.0, 1445.0], [125.0, 1445.0]]], "lines": ["いつだって若者は", "夜と戯れて", "大きくなるんだぜ！！", "参ったかこの野郎！！"]}], "img_path": "168.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [473, 132, 523, 259], "vertical": true, "font_size": 24, "lines_coords": [[[496.0, 132.0], [523.0, 132.0], [523.0, 221.0], [496.0, 221.0]], [[473.0, 135.0], [493.0, 135.0], [493.0, 259.0], [473.0, 259.0]]], "lines": ["走ったら", "転ぶわよー！！"]}, {"box": [197, 1079, 288, 1364], "vertical": true, "font_size": 20, "lines_coords": [[[265.0, 1082.0], [282.0, 1082.0], [282.0, 1178.0], [265.0, 1178.0]], [[231.0, 1082.0], [253.0, 1082.0], [251.0, 1359.0], [229.0, 1359.0]], [[200.0, 1082.0], [220.0, 1082.0], [220.0, 1343.0], [200.0, 1343.0]]], "lines": ["コンビニの", "ギャハキャハと無邪気に", "駆け抜けてゆきました。"]}], "img_path": "169.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [653, 676, 710, 856], "vertical": true, "font_size": 27, "lines_coords": [[[689.0, 676.0], [710.0, 676.0], [710.0, 826.0], [689.0, 826.0]], [[653.0, 676.0], [679.0, 676.0], [679.0, 856.0], [653.0, 856.0]]], "lines": ["この子供達の", "丸い頭の中には"]}, {"box": [464, 675, 621, 876], "vertical": true, "font_size": 27, "lines_coords": [[[595.0, 676.0], [621.0, 676.0], [621.0, 804.0], [595.0, 804.0]], [[564.0, 676.0], [590.0, 676.0], [590.0, 856.0], [564.0, 856.0]], [[531.0, 676.0], [557.0, 676.0], [557.0, 806.0], [531.0, 806.0]], [[500.0, 675.0], [526.0, 675.0], [523.0, 876.0], [496.0, 876.0]], [[464.0, 675.0], [498.0, 675.0], [498.0, 764.0], [464.0, 764.0]]], "lines": ["夢や希望が", "水風船のように", "パンパンに", "つまっているかと", "思うと、"]}, {"box": [407, 676, 434, 856], "vertical": true, "font_size": 27, "lines_coords": [[[407.0, 676.0], [434.0, 676.0], [434.0, 856.0], [407.0, 856.0]]], "lines": ["ついブンフンは"]}, {"box": [589, 1340, 620, 1432], "vertical": true, "font_size": 28, "lines_coords": [[[589.0, 1340.0], [617.0, 1340.0], [620.0, 1431.0], [592.0, 1431.0]]], "lines": ["．．．いや、"]}, {"box": [465, 1341, 526, 1485], "vertical": true, "font_size": 26, "lines_coords": [[[500.0, 1343.0], [526.0, 1343.0], [526.0, 1446.0], [500.0, 1446.0]], [[465.0, 1342.0], [492.0, 1342.0], [495.0, 1484.0], [468.0, 1484.0]]], "lines": ["なんでも", "ありません。"]}], "img_path": "170.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [495, 476, 586, 611], "vertical": true, "font_size": 27, "lines_coords": [[[556.0, 476.0], [582.0, 476.0], [585.0, 610.0], [559.0, 610.0]], [[526.0, 479.0], [553.0, 479.0], [553.0, 604.0], [526.0, 604.0]], [[495.0, 479.0], [523.0, 479.0], [523.0, 560.0], [495.0, 560.0]]], "lines": ["とりあえず、", "フンフンの", "日常は"]}], "img_path": "171.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [879, 165, 967, 425], "vertical": true, "font_size": 26, "lines_coords": [[[945.0, 167.0], [967.0, 167.0], [967.0, 293.0], [945.0, 293.0]], [[910.0, 165.0], [937.0, 165.0], [937.0, 370.0], [910.0, 370.0]], [[879.0, 167.0], [906.0, 167.0], [906.0, 425.0], [879.0, 425.0]]], "lines": ["この梅雨が", "永遠に続くんじゃ", "なかろうかと思うほど"]}, {"box": [784, 164, 843, 367], "vertical": true, "font_size": 26, "lines_coords": [[[815.0, 164.0], [842.0, 164.0], [843.0, 367.0], [817.0, 367.0]], [[784.0, 165.0], [810.0, 165.0], [810.0, 300.0], [784.0, 300.0]]], "lines": ["変化も起伏もなく", "過ぎてゆき、"]}, {"box": [269, 163, 294, 299], "vertical": true, "font_size": 25, "lines_coords": [[[269.0, 163.0], [294.0, 163.0], [294.0, 299.0], [269.0, 299.0]]], "lines": ["さがせども、"]}, {"box": [268, 167, 290, 290], "vertical": true, "font_size": 20, "lines_coords": [[[268.0, 167.0], [290.0, 167.0], [290.0, 290.0], [268.0, 290.0]]], "lines": ["さかせとも"]}, {"box": [209, 168, 228, 289], "vertical": true, "font_size": 20, "lines_coords": [[[209.0, 168.0], [228.0, 168.0], [228.0, 289.0], [209.0, 289.0]]], "lines": ["さかせとも"]}, {"box": [207, 163, 229, 296], "vertical": true, "font_size": 22, "lines_coords": [[[207.0, 163.0], [229.0, 163.0], [229.0, 296.0], [207.0, 296.0]]], "lines": ["さかせとも、"]}, {"box": [609, 1304, 636, 1467], "vertical": true, "font_size": 26, "lines_coords": [[[609.0, 1304.0], [635.0, 1304.0], [635.0, 1460.0], [609.0, 1460.0]]], "lines": ["愛子ちゃんは"]}, {"box": [481, 1303, 541, 1485], "vertical": true, "font_size": 27, "lines_coords": [[[514.0, 1304.0], [540.0, 1304.0], [540.0, 1481.0], [514.0, 1481.0]], [[481.0, 1304.0], [509.0, 1304.0], [509.0, 1390.0], [481.0, 1390.0]]], "lines": ["見つかりません", "でした。"]}], "img_path": "172.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [945, 89, 967, 240], "vertical": true, "font_size": 24, "lines_coords": [[[945.0, 89.0], [967.0, 89.0], [967.0, 240.0], [945.0, 240.0]]], "lines": ["小野寺クン！！"]}, {"box": [781, 168, 889, 346], "vertical": true, "font_size": 24, "lines_coords": [[[862.0, 168.0], [889.0, 168.0], [889.0, 332.0], [862.0, 332.0]], [[835.0, 170.0], [857.0, 170.0], [857.0, 287.0], [835.0, 287.0]], [[806.0, 168.0], [832.0, 168.0], [832.0, 332.0], [806.0, 332.0]], [[781.0, 170.0], [803.0, 170.0], [803.0, 346.0], [781.0, 346.0]]], "lines": ["今日はいつもに", "輪をかけて", "覇気が無いじゃ", "ないかァーッ！！"]}, {"box": [140, 151, 221, 336], "vertical": true, "font_size": 23, "lines_coords": [[[195.0, 151.0], [221.0, 151.0], [221.0, 248.0], [195.0, 248.0]], [[168.0, 154.0], [190.0, 154.0], [190.0, 315.0], [168.0, 315.0]], [[140.0, 153.0], [162.0, 153.0], [164.0, 335.0], [142.0, 335.0]]], "lines": ["ちゃんと", "寝てるのかい！？", "ハァッハーーッ！！"]}, {"box": [915, 481, 937, 631], "vertical": true, "font_size": 27, "lines_coords": [[[915.0, 481.0], [937.0, 481.0], [937.0, 631.0], [915.0, 631.0]]], "lines": ["小野寺クン！！"]}, {"box": [826, 675, 889, 831], "vertical": true, "font_size": 27, "lines_coords": [[[853.0, 675.0], [889.0, 675.0], [889.0, 745.0], [853.0, 745.0]], [[826.0, 679.0], [848.0, 679.0], [848.0, 831.0], [826.0, 831.0]]], "lines": ["キミ、", "童貞だろう！？"]}, {"box": [206, 614, 314, 798], "vertical": true, "font_size": 23, "lines_coords": [[[287.0, 614.0], [314.0, 614.0], [314.0, 776.0], [287.0, 776.0]], [[260.0, 615.0], [281.0, 615.0], [281.0, 798.0], [260.0, 798.0]], [[234.0, 614.0], [256.0, 614.0], [256.0, 754.0], [234.0, 754.0]], [[206.0, 614.0], [228.0, 614.0], [228.0, 754.0], [206.0, 754.0]]], "lines": ["なァーに、その", "陰鬱な顔を見れば", "聞かなくても", "わかるさァ！！"]}, {"box": [123, 853, 284, 1100], "vertical": true, "font_size": 23, "lines_coords": [[[262.0, 856.0], [284.0, 856.0], [284.0, 970.0], [262.0, 970.0]], [[234.0, 853.0], [257.0, 853.0], [256.0, 1084.0], [232.0, 1084.0]], [[203.0, 853.0], [229.0, 853.0], [229.0, 1062.0], [203.0, 1062.0]], [[176.0, 854.0], [198.0, 854.0], [198.0, 1100.0], [176.0, 1100.0]], [[150.0, 854.0], [171.0, 854.0], [171.0, 1096.0], [150.0, 1096.0]], [[123.0, 853.0], [143.0, 853.0], [143.0, 1039.0], [123.0, 1039.0]]], "lines": ["いや決して", "臆する事はないんだ！！", "むしろキミにはまだ", "知らない世界があるって", "ことを、ボクは羨ましく", "思ってすらいる！！"]}, {"box": [890, 1232, 979, 1362], "vertical": true, "font_size": 25, "lines_coords": [[[951.0, 1232.0], [979.0, 1232.0], [979.0, 1314.0], [951.0, 1314.0]], [[920.0, 1234.0], [946.0, 1234.0], [946.0, 1362.0], [920.0, 1362.0]], [[890.0, 1234.0], [912.0, 1234.0], [912.0, 1360.0], [890.0, 1360.0]]], "lines": ["キミも", "セックスを", "したまえ！！"]}, {"box": [798, 1364, 854, 1493], "vertical": true, "font_size": 25, "lines_coords": [[[828.0, 1364.0], [854.0, 1364.0], [854.0, 1492.0], [828.0, 1492.0]], [[798.0, 1365.0], [825.0, 1365.0], [825.0, 1493.0], [798.0, 1493.0]]], "lines": ["セックスは", "いいぞぉー"]}, {"box": [767, 1414, 789, 1492], "vertical": true, "font_size": 25, "lines_coords": [[[767.0, 1414.0], [789.0, 1414.0], [789.0, 1492.0], [767.0, 1492.0]]], "lines": ["ーッ！！"]}, {"box": [232, 1200, 339, 1385], "vertical": true, "font_size": 24, "lines_coords": [[[315.0, 1201.0], [339.0, 1201.0], [339.0, 1271.0], [315.0, 1271.0]], [[285.0, 1200.0], [312.0, 1200.0], [312.0, 1385.0], [285.0, 1385.0]], [[257.0, 1200.0], [284.0, 1200.0], [284.0, 1385.0], [257.0, 1385.0]], [[232.0, 1200.0], [254.0, 1200.0], [254.0, 1360.0], [232.0, 1360.0]]], "lines": ["若者は", "チマチマした悩み", "なんて、セックス", "すれば治るッ！！"]}, {"box": [139, 1348, 185, 1509], "vertical": true, "font_size": 24, "lines_coords": [[[164.0, 1348.0], [185.0, 1348.0], [185.0, 1509.0], [164.0, 1509.0]], [[139.0, 1348.0], [159.0, 1348.0], [159.0, 1507.0], [139.0, 1507.0]]], "lines": ["アンダスタン！？", "ヒャフーーッ！！"]}], "img_path": "173.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [898, 48, 975, 248], "vertical": true, "font_size": 20, "lines_coords": [[[954.0, 50.0], [975.0, 50.0], [975.0, 234.0], [954.0, 234.0]], [[925.0, 48.0], [946.0, 48.0], [946.0, 245.0], [925.0, 245.0]], [[898.0, 48.0], [920.0, 48.0], [920.0, 248.0], [898.0, 248.0]]], "lines": ["特に十代の女子は", "我々人類が誇るべき", "至宝だと思ってる！！"]}, {"box": [795, 253, 898, 437], "vertical": true, "font_size": 20, "lines_coords": [[[881.0, 253.0], [898.0, 253.0], [898.0, 370.0], [881.0, 370.0]], [[850.0, 254.0], [871.0, 254.0], [871.0, 417.0], [850.0, 417.0]], [[820.0, 253.0], [840.0, 253.0], [840.0, 437.0], [820.0, 437.0]], [[795.0, 254.0], [815.0, 254.0], [815.0, 393.0], [795.0, 393.0]]], "lines": ["まぁボクは", "女子中学生でも", "小学生でもイイん", "だけどねッ！！"]}, {"box": [387, 73, 442, 214], "vertical": true, "font_size": 24, "lines_coords": [[[415.0, 75.0], [442.0, 75.0], [442.0, 190.0], [415.0, 190.0]], [[390.0, 73.0], [414.0, 73.0], [410.0, 214.0], [387.0, 214.0]]], "lines": ["小野寺クン", "まだ１８歳だろ"]}, {"box": [364, 106, 385, 168], "vertical": true, "font_size": 24, "lines_coords": [[[364.0, 106.0], [385.0, 106.0], [385.0, 168.0], [364.0, 168.0]]], "lines": ["ッ！？"]}, {"box": [159, 248, 265, 429], "vertical": true, "font_size": 22, "lines_coords": [[[243.0, 248.0], [265.0, 248.0], [265.0, 409.0], [243.0, 409.0]], [[215.0, 248.0], [237.0, 248.0], [237.0, 429.0], [215.0, 429.0]], [[187.0, 248.0], [209.0, 248.0], [209.0, 409.0], [187.0, 409.0]], [[159.0, 248.0], [181.0, 248.0], [181.0, 342.0], [159.0, 342.0]]], "lines": ["もし合コンとか", "やる時はゼヒゼヒ", "誘っておくれよ", "ーッ！！"]}, {"box": [103, 462, 209, 650], "vertical": true, "font_size": 22, "lines_coords": [[[187.0, 464.0], [209.0, 464.0], [209.0, 623.0], [187.0, 623.0]], [[159.0, 464.0], [181.0, 464.0], [181.0, 626.0], [159.0, 626.0]], [[128.0, 462.0], [154.0, 462.0], [154.0, 650.0], [128.0, 650.0]], [[103.0, 465.0], [125.0, 465.0], [125.0, 626.0], [103.0, 626.0]]], "lines": ["その時はボクの", "合コン必勝法を", "伝授しちゃうよ！！", "ハハーーンッ！！"]}, {"box": [942, 962, 990, 1078], "vertical": true, "font_size": 22, "lines_coords": [[[968.0, 964.0], [990.0, 964.0], [990.0, 1054.0], [968.0, 1054.0]], [[942.0, 962.0], [964.0, 962.0], [964.0, 1078.0], [942.0, 1078.0]]], "lines": ["．．．．．え？", "具合悪い？"]}, {"box": [825, 1062, 929, 1251], "vertical": true, "font_size": 22, "lines_coords": [[[907.0, 1062.0], [929.0, 1062.0], [929.0, 1229.0], [907.0, 1229.0]], [[882.0, 1068.0], [903.0, 1068.0], [903.0, 1251.0], [882.0, 1251.0]], [[851.0, 1065.0], [873.0, 1065.0], [873.0, 1228.0], [851.0, 1228.0]], [[825.0, 1068.0], [846.0, 1068.0], [846.0, 1243.0], [825.0, 1243.0]]], "lines": ["．．．よっしゃ、後は", "ボクに任せとけ！！", "キミは無理せず", "家て寝てたまえ！！"]}, {"box": [915, 1359, 993, 1512], "vertical": true, "font_size": 20, "lines_coords": [[[971.0, 1359.0], [992.0, 1359.0], [992.0, 1512.0], [971.0, 1512.0]], [[943.0, 1359.0], [965.0, 1359.0], [965.0, 1496.0], [943.0, 1496.0]], [[917.0, 1362.0], [934.0, 1362.0], [934.0, 1473.0], [917.0, 1473.0]]], "lines": ["店長にはボクが", "適当に言って", "おくから！！"]}, {"box": [492, 1371, 569, 1556], "vertical": true, "font_size": 22, "lines_coords": [[[546.0, 1371.0], [568.0, 1371.0], [568.0, 1514.0], [546.0, 1514.0]], [[518.0, 1371.0], [539.0, 1371.0], [539.0, 1556.0], [518.0, 1556.0]], [[492.0, 1373.0], [514.0, 1373.0], [514.0, 1510.0], [492.0, 1510.0]]], "lines": ["．．．さっきの話、", "よろしく頼むよ！！", "ハァーーッ！！"]}], "img_path": "174.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [178, 1335, 240, 1367], "vertical": false, "font_size": 19, "lines_coords": [[[178.0, 1348.0], [235.0, 1335.0], [240.0, 1353.0], [182.0, 1367.0]]], "lines": ["アンプンの"]}, {"box": [175, 1328, 525, 1532], "vertical": false, "font_size": 27.5, "lines_coords": [[[175.0, 1373.0], [360.0, 1328.0], [367.0, 1354.0], [181.0, 1400.0]], [[176.0, 1396.0], [382.0, 1346.0], [390.0, 1375.0], [184.0, 1425.0]], [[187.0, 1425.0], [518.0, 1339.0], [525.0, 1365.0], [193.0, 1451.0]], [[195.0, 1450.0], [439.0, 1385.0], [445.0, 1412.0], [201.0, 1476.0]], [[200.0, 1478.0], [498.0, 1400.0], [504.0, 1426.0], [206.0, 1504.0]], [[210.0, 1506.0], [339.0, 1471.0], [345.0, 1498.0], [217.0, 1532.0]]], "lines": ["おせしかいばかりでゴトンね。", "私を素で契約してきました。", "料金も私の口座から引き寄せしかれるようにいたから、", "家族のいきらりに対して、電話の良い思いには可愛ね（＊）", "それでもどうしてもいいのですが、私はそれくらいだが、何かあったら、", "連絡して下さい。"]}, {"box": [742, 1412, 928, 1457], "vertical": false, "font_size": 41, "lines_coords": [[[750.0, 1409.0], [921.0, 1412.0], [921.0, 1456.0], [750.0, 1453.0]]], "lines": ["ｋａｓｈｉｋｏｍｏ"]}], "img_path": "175.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [832, 160, 889, 403], "vertical": true, "font_size": 18, "lines_coords": [[[868.0, 164.0], [885.0, 164.0], [885.0, 259.0], [868.0, 259.0]], [[834.0, 164.0], [854.0, 164.0], [854.0, 393.0], [834.0, 393.0]]], "lines": ["そういう", "問題じゃないんです"]}, {"box": [309, 161, 371, 375], "vertical": true, "font_size": 24, "lines_coords": [[[345.0, 164.0], [367.0, 164.0], [367.0, 312.0], [345.0, 312.0]], [[309.0, 162.0], [335.0, 162.0], [337.0, 365.0], [310.0, 365.0]]], "lines": ["みんな悪気は", "ないんでしょうか"]}, {"box": [155, 161, 212, 400], "vertical": true, "font_size": 20, "lines_coords": [[[189.0, 164.0], [209.0, 164.0], [209.0, 312.0], [189.0, 312.0]], [[157.0, 164.0], [178.0, 164.0], [178.0, 395.0], [157.0, 395.0]]], "lines": ["でもそういう", "問題じゃないんです。"]}, {"box": [818, 756, 848, 818], "vertical": true, "font_size": 30, "lines_coords": [[[818.0, 756.0], [848.0, 756.0], [848.0, 818.0], [818.0, 818.0]]], "lines": ["ワハハ"]}, {"box": [700, 834, 731, 879], "vertical": true, "font_size": 27, "lines_coords": [[[700.0, 834.0], [731.0, 834.0], [731.0, 879.0], [700.0, 879.0]]], "lines": ["ワハ"]}, {"box": [659, 903, 682, 962], "vertical": true, "font_size": 27, "lines_coords": [[[659.0, 903.0], [682.0, 903.0], [682.0, 962.0], [659.0, 962.0]]], "lines": ["ワハハ"]}, {"box": [682, 1350, 706, 1508], "vertical": true, "font_size": 21, "lines_coords": [[[682.0, 1353.0], [703.0, 1353.0], [703.0, 1503.0], [682.0, 1503.0]]], "lines": ["．．．こんな時は"]}, {"box": [506, 1346, 603, 1515], "vertical": true, "font_size": 33, "lines_coords": [[[567.0, 1346.0], [603.0, 1346.0], [603.0, 1404.0], [567.0, 1404.0]], [[535.0, 1346.0], [573.0, 1346.0], [573.0, 1407.0], [535.0, 1407.0]], [[506.0, 1350.0], [532.0, 1350.0], [532.0, 1512.0], [506.0, 1512.0]]], "lines": ["神様", "神様", "チンクルホイ。"]}, {"box": [402, 1349, 427, 1487], "vertical": true, "font_size": 22, "lines_coords": [[[403.0, 1351.0], [425.0, 1351.0], [425.0, 1479.0], [403.0, 1479.0]]], "lines": ["と唱えると"]}], "img_path": "176.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [525, 1342, 590, 1474], "vertical": true, "font_size": 31, "lines_coords": [[[565.0, 1348.0], [587.0, 1348.0], [587.0, 1473.0], [565.0, 1473.0]], [[525.0, 1342.0], [565.0, 1342.0], [565.0, 1415.0], [525.0, 1415.0]]], "lines": ["馬鹿みたい", "です。"]}], "img_path": "177.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [540, 555, 565, 697], "vertical": true, "font_size": 22, "lines_coords": [[[540.0, 557.0], [562.0, 557.0], [562.0, 692.0], [540.0, 692.0]]], "lines": ["．．．自業自得。"]}, {"box": [539, 1437, 567, 1474], "vertical": true, "font_size": 23, "lines_coords": [[[539.0, 1442.0], [560.0, 1437.0], [567.0, 1462.0], [543.0, 1467.0]]], "lines": ["あ"]}], "img_path": "178.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "179.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "180.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "181.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "182.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "183.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "184.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [425, 398, 496, 442], "vertical": false, "font_size": 39, "lines_coords": [[[425.0, 403.0], [493.0, 398.0], [496.0, 437.0], [426.0, 442.0]]], "lines": ["＊"]}], "img_path": "185.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "186.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "187.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [31, 297, 79, 461], "vertical": true, "font_size": 44, "lines_coords": [[[31.0, 300.0], [75.0, 300.0], [75.0, 460.0], [31.0, 460.0]]], "lines": ["第７７話"]}], "img_path": "188.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [535, 125, 561, 184], "vertical": true, "font_size": 22, "lines_coords": [[[535.0, 128.0], [557.0, 128.0], [557.0, 179.0], [535.0, 179.0]]], "lines": ["日本の"]}, {"box": [532, 1109, 622, 1323], "vertical": true, "font_size": 24, "lines_coords": [[[598.0, 1114.0], [620.0, 1114.0], [620.0, 1262.0], [598.0, 1262.0]], [[562.0, 1109.0], [589.0, 1109.0], [592.0, 1262.0], [565.0, 1262.0]], [[532.0, 1112.0], [554.0, 1112.0], [554.0, 1314.0], [532.0, 1314.0]]], "lines": ["止みどころを", "忘れたんじゃ", "ないかと思うほど"]}, {"box": [421, 1109, 482, 1352], "vertical": true, "font_size": 27, "lines_coords": [[[454.0, 1110.0], [481.0, 1110.0], [481.0, 1264.0], [454.0, 1264.0]], [[423.0, 1109.0], [450.0, 1109.0], [448.0, 1350.0], [421.0, 1350.0]]], "lines": ["馬鹿みたいに", "降り続いていました。"]}], "img_path": "189.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [818, 140, 909, 323], "vertical": true, "font_size": 28, "lines_coords": [[[884.0, 143.0], [906.0, 143.0], [906.0, 317.0], [884.0, 317.0]], [[845.0, 140.0], [879.0, 140.0], [879.0, 221.0], [845.0, 221.0]], [[818.0, 142.0], [845.0, 142.0], [845.0, 251.0], [818.0, 251.0]]], "lines": ["外に出なきゃと", "思えば", "思うほど、"]}, {"box": [283, 135, 376, 324], "vertical": true, "font_size": 27, "lines_coords": [[[343.0, 137.0], [376.0, 137.0], [376.0, 220.0], [343.0, 220.0]], [[314.0, 135.0], [340.0, 135.0], [340.0, 289.0], [314.0, 289.0]], [[284.0, 140.0], [306.0, 140.0], [306.0, 320.0], [284.0, 320.0]]], "lines": ["自分を", "この六畳間に", "閉じ込めようと"]}, {"box": [144, 137, 232, 342], "vertical": true, "font_size": 23, "lines_coords": [[[207.0, 140.0], [229.0, 140.0], [229.0, 287.0], [207.0, 287.0]], [[175.0, 139.0], [201.0, 139.0], [201.0, 342.0], [175.0, 342.0]], [[145.0, 140.0], [167.0, 140.0], [167.0, 298.0], [145.0, 298.0]]], "lines": ["雨音が大きく", "なっていくような", "気がしました。"]}, {"box": [545, 1374, 568, 1477], "vertical": true, "font_size": 17, "lines_coords": [[[548.0, 1376.0], [565.0, 1376.0], [565.0, 1470.0], [548.0, 1470.0]]], "lines": ["ああ．．．"]}], "img_path": "190.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [713, 585, 848, 882], "vertical": true, "font_size": 135, "lines_coords": [[[713.0, 585.0], [848.0, 585.0], [848.0, 882.0], [713.0, 882.0]]], "lines": ["．．．"]}], "img_path": "191.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [540, 602, 570, 740], "vertical": true, "font_size": 28, "lines_coords": [[[540.0, 604.0], [568.0, 604.0], [568.0, 734.0], [540.0, 734.0]]], "lines": ["ブンフンは"]}, {"box": [526, 1379, 587, 1520], "vertical": true, "font_size": 30, "lines_coords": [[[554.0, 1379.0], [587.0, 1379.0], [587.0, 1460.0], [554.0, 1460.0]], [[526.0, 1382.0], [553.0, 1382.0], [553.0, 1515.0], [526.0, 1515.0]]], "lines": ["今日も", "大丈夫です。"]}], "img_path": "192.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [956, 121, 985, 154], "vertical": true, "font_size": 28, "lines_coords": [[[956.0, 121.0], [985.0, 121.0], [985.0, 154.0], [956.0, 154.0]]], "lines": ["あー"]}, {"box": [857, 235, 948, 412], "vertical": true, "font_size": 28, "lines_coords": [[[920.0, 235.0], [948.0, 235.0], [948.0, 314.0], [920.0, 314.0]], [[892.0, 237.0], [918.0, 237.0], [918.0, 357.0], [892.0, 357.0]], [[857.0, 237.0], [884.0, 237.0], [884.0, 412.0], [857.0, 412.0]]], "lines": ["どうも", "こんにちは", "大家の宍戸です。"]}, {"box": [939, 629, 967, 731], "vertical": true, "font_size": 24, "lines_coords": [[[939.0, 629.0], [967.0, 629.0], [967.0, 731.0], [939.0, 731.0]]], "lines": ["．．．いえね、"]}, {"box": [828, 700, 907, 846], "vertical": true, "font_size": 24, "lines_coords": [[[881.0, 700.0], [907.0, 700.0], [907.0, 818.0], [881.0, 818.0]], [[856.0, 703.0], [878.0, 703.0], [878.0, 840.0], [856.0, 840.0]], [[828.0, 701.0], [848.0, 701.0], [848.0, 846.0], [828.0, 846.0]]], "lines": ["取り立てて", "用って訳じゃ", "ないんだけど、"]}, {"box": [140, 339, 194, 542], "vertical": true, "font_size": 22, "lines_coords": [[[170.0, 343.0], [192.0, 343.0], [192.0, 481.0], [170.0, 481.0]], [[142.0, 339.0], [164.0, 339.0], [162.0, 542.0], [140.0, 542.0]]], "lines": ["：小野寺さん", "ちょっとやつれた？"]}, {"box": [148, 720, 200, 857], "vertical": true, "font_size": 22, "lines_coords": [[[176.0, 720.0], [198.0, 720.0], [198.0, 857.0], [176.0, 857.0]], [[148.0, 720.0], [170.0, 720.0], [170.0, 843.0], [148.0, 843.0]]], "lines": ["どうですかね", "住み心地は。"]}, {"box": [256, 1026, 339, 1171], "vertical": true, "font_size": 24, "lines_coords": [[[317.0, 1031.0], [339.0, 1031.0], [339.0, 1146.0], [317.0, 1146.0]], [[287.0, 1026.0], [314.0, 1026.0], [314.0, 1171.0], [287.0, 1171.0]], [[259.0, 1028.0], [285.0, 1028.0], [282.0, 1146.0], [256.0, 1146.0]]], "lines": ["．．．これから", "ちょっと時間", "あるかい？"]}, {"box": [920, 1234, 1000, 1431], "vertical": true, "font_size": 22, "lines_coords": [[[976.0, 1234.0], [998.0, 1234.0], [1000.0, 1382.0], [978.0, 1382.0]], [[950.0, 1235.0], [971.0, 1235.0], [971.0, 1421.0], [950.0, 1421.0]], [[920.0, 1235.0], [942.0, 1235.0], [942.0, 1429.0], [920.0, 1429.0]]], "lines": ["．．．ああホント、", "特に問題無いなら", "そりゃあ良かった。"]}, {"box": [454, 1359, 537, 1555], "vertical": true, "font_size": 24, "lines_coords": [[[507.0, 1359.0], [534.0, 1359.0], [537.0, 1521.0], [510.0, 1521.0]], [[482.0, 1360.0], [504.0, 1360.0], [504.0, 1521.0], [482.0, 1521.0]], [[454.0, 1362.0], [476.0, 1362.0], [476.0, 1554.0], [454.0, 1554.0]]], "lines": ["．．．いやちょっと", "勝手な老婆心で", "心配してたもんで。"]}, {"box": [173, 1137, 223, 1310], "vertical": true, "font_size": 24, "lines_coords": [[[201.0, 1137.0], [223.0, 1137.0], [223.0, 1256.0], [201.0, 1256.0]], [[175.0, 1139.0], [196.0, 1139.0], [195.0, 1310.0], [173.0, 1310.0]]], "lines": ["．．．少し君と", "話をしたくてね。"]}], "img_path": "193.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [873, 45, 951, 218], "vertical": true, "font_size": 23, "lines_coords": [[[929.0, 46.0], [951.0, 46.0], [951.0, 207.0], [929.0, 207.0]], [[903.0, 46.0], [923.0, 46.0], [923.0, 184.0], [903.0, 184.0]], [[873.0, 45.0], [895.0, 45.0], [896.0, 218.0], [875.0, 218.0]]], "lines": ["．．．ああ、たいした", "用じゃないよ", "ただの世間話さ。"]}, {"box": [750, 95, 832, 220], "vertical": true, "font_size": 23, "lines_coords": [[[804.0, 95.0], [832.0, 95.0], [832.0, 168.0], [804.0, 168.0]], [[776.0, 95.0], [803.0, 95.0], [803.0, 212.0], [776.0, 212.0]], [[750.0, 96.0], [771.0, 96.0], [771.0, 220.0], [750.0, 220.0]]], "lines": ["梅雨は", "不動産屋の", "閑散期でね。"]}, {"box": [957, 712, 979, 831], "vertical": true, "font_size": 21, "lines_coords": [[[957.0, 712.0], [979.0, 712.0], [979.0, 831.0], [957.0, 831.0]]], "lines": ["．．．なんだい"]}, {"box": [604, 446, 629, 573], "vertical": true, "font_size": 22, "lines_coords": [[[604.0, 446.0], [626.0, 446.0], [626.0, 573.0], [604.0, 573.0]]], "lines": ["．．．小野寺君。"]}, {"box": [118, 479, 198, 666], "vertical": true, "font_size": 21, "lines_coords": [[[176.0, 479.0], [196.0, 479.0], [196.0, 643.0], [176.0, 643.0]], [[146.0, 482.0], [168.0, 482.0], [168.0, 665.0], [146.0, 665.0]], [[118.0, 485.0], [140.0, 485.0], [140.0, 600.0], [118.0, 600.0]]], "lines": ["うなぎにしよう", "かと思うんだけど", "いいかな？"]}, {"box": [865, 809, 914, 950], "vertical": true, "font_size": 21, "lines_coords": [[[892.0, 809.0], [914.0, 809.0], [914.0, 950.0], [892.0, 950.0]], [[865.0, 810.0], [885.0, 810.0], [885.0, 934.0], [865.0, 934.0]]], "lines": ["若いのに随分", "遠慮深いね。"]}, {"box": [135, 984, 246, 1206], "vertical": true, "font_size": 22, "lines_coords": [[[221.0, 985.0], [243.0, 985.0], [243.0, 1206.0], [221.0, 1206.0]], [[193.0, 984.0], [214.0, 984.0], [214.0, 1193.0], [193.0, 1193.0]], [[165.0, 984.0], [187.0, 984.0], [187.0, 1170.0], [165.0, 1170.0]], [[135.0, 985.0], [157.0, 985.0], [157.0, 1173.0], [135.0, 1173.0]]], "lines": ["暇を持て余した老人の", "相手をするんだから", "それくらいの賛沢", "いいじゃあないか"]}, {"box": [821, 1451, 864, 1523], "vertical": false, "font_size": 72, "lines_coords": [[[821.0, 1451.0], [864.0, 1451.0], [864.0, 1523.0], [821.0, 1523.0]]], "lines": ["キニッ"]}], "img_path": "194.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [917, 81, 995, 240], "vertical": true, "font_size": 22, "lines_coords": [[[975.0, 82.0], [995.0, 82.0], [995.0, 218.0], [975.0, 218.0]], [[945.0, 81.0], [968.0, 81.0], [971.0, 196.0], [948.0, 196.0]], [[917.0, 81.0], [939.0, 81.0], [939.0, 240.0], [917.0, 240.0]]], "lines": ["．．．契約の時に", "した話って", "憶えてるかい？"]}, {"box": [817, 250, 923, 448], "vertical": true, "font_size": 22, "lines_coords": [[[900.0, 250.0], [921.0, 250.0], [923.0, 370.0], [901.0, 370.0]], [[870.0, 250.0], [893.0, 250.0], [895.0, 392.0], [871.0, 392.0]], [[843.0, 251.0], [865.0, 251.0], [865.0, 448.0], [843.0, 448.0]], [[817.0, 253.0], [839.0, 253.0], [839.0, 439.0], [817.0, 439.0]]], "lines": ["あの部屋は", "前に住んでた", "ジイさんがあそこで", "病気で死んでてね。"]}, {"box": [187, 220, 293, 417], "vertical": true, "font_size": 23, "lines_coords": [[[271.0, 223.0], [293.0, 223.0], [293.0, 406.0], [271.0, 406.0]], [[243.0, 223.0], [265.0, 223.0], [265.0, 406.0], [243.0, 406.0]], [[215.0, 221.0], [237.0, 221.0], [237.0, 362.0], [215.0, 362.0]], [[187.0, 220.0], [209.0, 220.0], [209.0, 417.0], [187.0, 417.0]]], "lines": ["素っ頓狂な宗教に", "入れ込んじゃって", "僕とは一悶着", "あったんだけれど、"]}, {"box": [140, 470, 256, 637], "vertical": true, "font_size": 23, "lines_coords": [[[229.0, 473.0], [256.0, 473.0], [256.0, 571.0], [229.0, 571.0]], [[200.0, 470.0], [226.0, 470.0], [223.0, 637.0], [196.0, 637.0]], [[168.0, 471.0], [190.0, 471.0], [187.0, 635.0], [165.0, 635.0]], [[140.0, 473.0], [162.0, 473.0], [162.0, 578.0], [140.0, 578.0]]], "lines": ["いや～～", "不器用過ぎる程", "真面目で朴認な", "男でねェ。"]}, {"box": [878, 729, 954, 871], "vertical": true, "font_size": 22, "lines_coords": [[[932.0, 731.0], [954.0, 731.0], [954.0, 848.0], [932.0, 848.0]], [[903.0, 729.0], [929.0, 729.0], [929.0, 871.0], [903.0, 871.0]], [[878.0, 729.0], [900.0, 729.0], [900.0, 834.0], [878.0, 834.0]]], "lines": ["．．．小野寺君", "似てるんだな", "その人に。"]}, {"box": [740, 762, 818, 934], "vertical": true, "font_size": 22, "lines_coords": [[[796.0, 762.0], [818.0, 762.0], [818.0, 928.0], [796.0, 928.0]], [[767.0, 764.0], [789.0, 764.0], [789.0, 879.0], [767.0, 879.0]], [[740.0, 762.0], [760.0, 762.0], [760.0, 934.0], [740.0, 934.0]]], "lines": ["なんというかな", "眼というか", "雰囲気というか。"]}, {"box": [342, 1060, 423, 1223], "vertical": true, "font_size": 23, "lines_coords": [[[400.0, 1064.0], [421.0, 1064.0], [421.0, 1201.0], [400.0, 1201.0]], [[373.0, 1064.0], [393.0, 1064.0], [393.0, 1223.0], [373.0, 1223.0]], [[342.0, 1060.0], [371.0, 1060.0], [371.0, 1135.0], [342.0, 1135.0]]], "lines": ["今更どうにも", "ならないけれど", "さ．．．"]}, {"box": [945, 1298, 1000, 1406], "vertical": true, "font_size": 27, "lines_coords": [[[970.0, 1298.0], [1000.0, 1298.0], [1000.0, 1375.0], [970.0, 1375.0]], [[945.0, 1300.0], [973.0, 1300.0], [973.0, 1406.0], [945.0, 1406.0]]], "lines": ["あ～～", "いやいや。"]}, {"box": [854, 1379, 935, 1523], "vertical": true, "font_size": 27, "lines_coords": [[[906.0, 1379.0], [935.0, 1379.0], [935.0, 1456.0], [906.0, 1456.0]], [[879.0, 1381.0], [906.0, 1381.0], [906.0, 1501.0], [879.0, 1501.0]], [[854.0, 1384.0], [876.0, 1384.0], [876.0, 1523.0], [854.0, 1523.0]]], "lines": ["気分を", "悪くしたら", "申し訳ない！！"]}, {"box": [456, 1340, 539, 1550], "vertical": true, "font_size": 26, "lines_coords": [[[512.0, 1340.0], [539.0, 1340.0], [539.0, 1482.0], [512.0, 1482.0]], [[484.0, 1342.0], [510.0, 1342.0], [510.0, 1550.0], [484.0, 1550.0]], [[457.0, 1342.0], [481.0, 1342.0], [479.0, 1535.0], [456.0, 1535.0]]], "lines": ["．．．ただずっと", "喉の奥にそのことが", "引っかかっててね。"]}, {"box": [118, 1315, 227, 1525], "vertical": true, "font_size": 22, "lines_coords": [[[204.0, 1318.0], [226.0, 1318.0], [226.0, 1459.0], [204.0, 1459.0]], [[175.0, 1317.0], [198.0, 1317.0], [196.0, 1525.0], [173.0, 1525.0]], [[148.0, 1318.0], [170.0, 1318.0], [170.0, 1504.0], [148.0, 1504.0]], [[121.0, 1315.0], [142.0, 1315.0], [139.0, 1504.0], [118.0, 1504.0]]], "lines": ["もしかしたら", "僕が彼を救ってやれ", "たんじゃないかと", "思うとどうもね．．．"]}], "img_path": "195.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [898, 92, 976, 232], "vertical": true, "font_size": 22, "lines_coords": [[[950.0, 92.0], [976.0, 92.0], [976.0, 209.0], [950.0, 209.0]], [[925.0, 92.0], [946.0, 92.0], [946.0, 232.0], [925.0, 232.0]], [[898.0, 93.0], [920.0, 93.0], [920.0, 154.0], [898.0, 154.0]]], "lines": ["．．．思い出し", "ちゃうんだよ", "なァー"]}, {"box": [900, 159, 917, 206], "vertical": true, "font_size": 22, "lines_coords": [[[900.0, 159.0], [917.0, 159.0], [917.0, 206.0], [900.0, 206.0]]], "lines": ["．．．"]}, {"box": [501, 203, 581, 365], "vertical": true, "font_size": 24, "lines_coords": [[[557.0, 204.0], [579.0, 204.0], [579.0, 365.0], [557.0, 365.0]], [[526.0, 203.0], [553.0, 203.0], [553.0, 321.0], [526.0, 321.0]], [[501.0, 204.0], [523.0, 204.0], [523.0, 320.0], [501.0, 320.0]]], "lines": ["あのジイさんの", "寂しそうな", "眼をねェ．．．"]}, {"box": [953, 1421, 976, 1459], "vertical": true, "font_size": 26, "lines_coords": [[[953.0, 1421.0], [976.0, 1421.0], [976.0, 1459.0], [953.0, 1459.0]]], "lines": ["ん。"]}, {"box": [831, 1390, 890, 1506], "vertical": true, "font_size": 26, "lines_coords": [[[862.0, 1390.0], [890.0, 1390.0], [890.0, 1495.0], [862.0, 1495.0]], [[831.0, 1392.0], [857.0, 1392.0], [857.0, 1506.0], [831.0, 1506.0]]], "lines": ["やっぱり", "同じ眼だ。"]}, {"box": [220, 1348, 310, 1487], "vertical": true, "font_size": 25, "lines_coords": [[[278.0, 1348.0], [310.0, 1348.0], [310.0, 1434.0], [278.0, 1434.0]], [[250.0, 1350.0], [276.0, 1350.0], [276.0, 1487.0], [250.0, 1487.0]], [[220.0, 1350.0], [242.0, 1350.0], [242.0, 1485.0], [220.0, 1485.0]]], "lines": ["意外と", "意志は強い、", "そんな眼だ。"]}, {"box": [117, 1390, 170, 1529], "vertical": true, "font_size": 25, "lines_coords": [[[148.0, 1392.0], [170.0, 1392.0], [170.0, 1493.0], [148.0, 1493.0]], [[117.0, 1390.0], [139.0, 1390.0], [139.0, 1529.0], [117.0, 1529.0]]], "lines": ["頑固とも", "言うけどね。"]}], "img_path": "196.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [860, 92, 953, 260], "vertical": true, "font_size": 28, "lines_coords": [[[918.0, 92.0], [953.0, 92.0], [953.0, 175.0], [918.0, 175.0]], [[890.0, 93.0], [917.0, 93.0], [917.0, 250.0], [890.0, 250.0]], [[860.0, 95.0], [882.0, 95.0], [882.0, 259.0], [860.0, 259.0]]], "lines": ["．．．ただ", "他人には絶対", "心を開かない。"]}, {"box": [170, 332, 261, 488], "vertical": true, "font_size": 26, "lines_coords": [[[235.0, 334.0], [257.0, 334.0], [257.0, 487.0], [235.0, 487.0]], [[201.0, 334.0], [228.0, 334.0], [228.0, 460.0], [201.0, 460.0]], [[170.0, 332.0], [198.0, 332.0], [198.0, 437.0], [170.0, 437.0]]], "lines": ["．．．そんな眼を", "してるなァ", "君は．．．"]}, {"box": [909, 842, 960, 981], "vertical": true, "font_size": 24, "lines_coords": [[[939.0, 843.0], [960.0, 843.0], [960.0, 981.0], [939.0, 981.0]], [[909.0, 842.0], [935.0, 842.0], [935.0, 935.0], [909.0, 935.0]]], "lines": ["．．．なんだろう", "ねェ．．．"]}, {"box": [795, 929, 878, 1096], "vertical": true, "font_size": 24, "lines_coords": [[[848.0, 929.0], [878.0, 929.0], [878.0, 1004.0], [848.0, 1004.0]], [[825.0, 931.0], [846.0, 931.0], [846.0, 1050.0], [825.0, 1050.0]], [[795.0, 932.0], [817.0, 932.0], [817.0, 1096.0], [795.0, 1096.0]]], "lines": ["誰かに", "こっぴどく", "裏切られたのか"]}, {"box": [237, 862, 317, 1026], "vertical": true, "font_size": 23, "lines_coords": [[[290.0, 862.0], [317.0, 862.0], [317.0, 960.0], [290.0, 960.0]], [[265.0, 865.0], [287.0, 865.0], [287.0, 1026.0], [265.0, 1026.0]], [[237.0, 865.0], [259.0, 865.0], [259.0, 1009.0], [237.0, 1009.0]]], "lines": ["それとも", "誰かを裏切って", "しまったのか、"]}, {"box": [128, 987, 206, 1104], "vertical": true, "font_size": 23, "lines_coords": [[[184.0, 987.0], [206.0, 987.0], [206.0, 1104.0], [184.0, 1104.0]], [[156.0, 987.0], [178.0, 987.0], [178.0, 1101.0], [156.0, 1101.0]], [[128.0, 987.0], [150.0, 987.0], [150.0, 1103.0], [128.0, 1103.0]]], "lines": ["まぁ深くは", "詮索しない", "けれど．．．"]}, {"box": [887, 1235, 967, 1375], "vertical": true, "font_size": 23, "lines_coords": [[[945.0, 1237.0], [967.0, 1237.0], [967.0, 1354.0], [945.0, 1354.0]], [[915.0, 1235.0], [939.0, 1235.0], [935.0, 1375.0], [912.0, 1375.0]], [[887.0, 1235.0], [910.0, 1235.0], [910.0, 1309.0], [887.0, 1309.0]]], "lines": ["もっと人を", "信用しなさい", "よ．．．"]}, {"box": [739, 1350, 873, 1535], "vertical": true, "font_size": 23, "lines_coords": [[[851.0, 1350.0], [873.0, 1350.0], [873.0, 1512.0], [851.0, 1512.0]], [[820.0, 1350.0], [846.0, 1350.0], [846.0, 1446.0], [820.0, 1446.0]], [[792.0, 1350.0], [818.0, 1350.0], [818.0, 1535.0], [792.0, 1535.0]], [[767.0, 1351.0], [787.0, 1351.0], [787.0, 1514.0], [767.0, 1514.0]], [[739.0, 1351.0], [760.0, 1351.0], [760.0, 1514.0], [739.0, 1514.0]]], "lines": ["どうせ年寄りに", "なったら", "思い出くらいしか", "生き甲斐なんて", "ないんだから．．．"]}, {"box": [281, 1239, 334, 1385], "vertical": true, "font_size": 24, "lines_coords": [[[307.0, 1240.0], [334.0, 1240.0], [334.0, 1359.0], [307.0, 1359.0]], [[282.0, 1239.0], [304.0, 1239.0], [303.0, 1385.0], [281.0, 1385.0]]], "lines": ["思い返して", "ごらんなさい。"]}, {"box": [125, 1332, 237, 1543], "vertical": true, "font_size": 24, "lines_coords": [[[210.0, 1332.0], [237.0, 1332.0], [234.0, 1451.0], [207.0, 1451.0]], [[181.0, 1332.0], [207.0, 1332.0], [207.0, 1543.0], [181.0, 1543.0]], [[154.0, 1334.0], [176.0, 1334.0], [176.0, 1495.0], [154.0, 1495.0]], [[128.0, 1334.0], [150.0, 1334.0], [146.0, 1518.0], [125.0, 1518.0]]], "lines": ["今まで君に", "関わってきた人達で", "そんなに悪い人", "なんていたかい？"]}], "img_path": "197.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [226, 1175, 410, 1387], "vertical": false, "font_size": 177, "lines_coords": [[[293.0, 1175.0], [410.0, 1223.0], [343.0, 1387.0], [226.0, 1339.0]]], "lines": ["んっ"]}], "img_path": "198.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [484, 0, 932, 362], "vertical": false, "font_size": 287, "lines_coords": [[[543.0, 0.0], [932.0, 79.0], [873.0, 362.0], [484.0, 279.0]]], "lines": ["え．．．"]}, {"box": [946, 1307, 968, 1404], "vertical": true, "font_size": 22, "lines_coords": [[[946.0, 1307.0], [968.0, 1307.0], [968.0, 1404.0], [946.0, 1404.0]]], "lines": ["．．．僕はね"]}, {"box": [807, 1367, 914, 1537], "vertical": true, "font_size": 22, "lines_coords": [[[892.0, 1367.0], [914.0, 1367.0], [914.0, 1507.0], [892.0, 1507.0]], [[864.0, 1368.0], [885.0, 1368.0], [885.0, 1531.0], [864.0, 1531.0]], [[835.0, 1368.0], [857.0, 1368.0], [857.0, 1507.0], [835.0, 1507.0]], [[807.0, 1371.0], [829.0, 1371.0], [829.0, 1537.0], [807.0, 1537.0]]], "lines": ["どんな人でも", "裏切られるまで", "信じることに", "してるんですよ。"]}, {"box": [242, 1298, 323, 1468], "vertical": true, "font_size": 24, "lines_coords": [[[301.0, 1301.0], [323.0, 1301.0], [323.0, 1440.0], [301.0, 1440.0]], [[270.0, 1298.0], [296.0, 1298.0], [296.0, 1442.0], [270.0, 1442.0]], [[242.0, 1300.0], [264.0, 1300.0], [264.0, 1468.0], [242.0, 1468.0]]], "lines": ["疑う気持ちは", "相手に悪意を", "生みつけるしね。"]}, {"box": [101, 1367, 209, 1543], "vertical": true, "font_size": 24, "lines_coords": [[[187.0, 1367.0], [209.0, 1367.0], [206.0, 1543.0], [184.0, 1543.0]], [[157.0, 1368.0], [181.0, 1368.0], [179.0, 1542.0], [156.0, 1542.0]], [[129.0, 1368.0], [151.0, 1368.0], [151.0, 1529.0], [129.0, 1529.0]], [[101.0, 1367.0], [128.0, 1367.0], [128.0, 1450.0], [101.0, 1450.0]]], "lines": ["．．．仮に裏切られた", "って、損するのは", "僕だけでいいん", "ですよ。"]}], "img_path": "199.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [900, 100, 981, 224], "vertical": true, "font_size": 24, "lines_coords": [[[950.0, 100.0], [981.0, 100.0], [981.0, 157.0], [950.0, 157.0]], [[925.0, 100.0], [948.0, 100.0], [945.0, 218.0], [921.0, 218.0]], [[901.0, 103.0], [918.0, 103.0], [918.0, 220.0], [901.0, 220.0]]], "lines": ["．．．君、", "そんな眼を", "してちゃあ"]}, {"box": [484, 176, 562, 339], "vertical": true, "font_size": 21, "lines_coords": [[[540.0, 179.0], [562.0, 179.0], [562.0, 293.0], [540.0, 293.0]], [[510.0, 176.0], [532.0, 176.0], [532.0, 339.0], [510.0, 339.0]], [[484.0, 176.0], [504.0, 176.0], [504.0, 315.0], [484.0, 315.0]]], "lines": ["いざって時", "誰も助けちゃあ", "くれないよ？"]}, {"box": [353, 157, 401, 271], "vertical": true, "font_size": 22, "lines_coords": [[[379.0, 157.0], [401.0, 157.0], [401.0, 271.0], [379.0, 271.0]], [[353.0, 157.0], [375.0, 157.0], [375.0, 254.0], [353.0, 254.0]]], "lines": ["．．．ところで", "小野寺君、"]}, {"box": [895, 675, 950, 793], "vertical": true, "font_size": 28, "lines_coords": [[[921.0, 676.0], [950.0, 676.0], [950.0, 750.0], [921.0, 750.0]], [[895.0, 675.0], [921.0, 675.0], [921.0, 793.0], [895.0, 793.0]]], "lines": ["お仕事", "なら―．．．"]}, {"box": [107, 382, 190, 589], "vertical": true, "font_size": 23, "lines_coords": [[[167.0, 384.0], [189.0, 384.0], [189.0, 545.0], [167.0, 545.0]], [[139.0, 385.0], [159.0, 385.0], [159.0, 589.0], [139.0, 589.0]], [[107.0, 382.0], [134.0, 382.0], [134.0, 478.0], [107.0, 478.0]]], "lines": ["もしかして君は", "お金に困ってる系の", "子かい？"]}, {"box": [125, 734, 238, 1090], "vertical": true, "font_size": 24, "lines_coords": [[[209.0, 740.0], [237.0, 740.0], [237.0, 860.0], [209.0, 860.0]], [[204.0, 923.0], [231.0, 923.0], [234.0, 1089.0], [207.0, 1089.0]], [[181.0, 928.0], [203.0, 928.0], [203.0, 1042.0], [181.0, 1042.0]], [[153.0, 926.0], [175.0, 926.0], [175.0, 1089.0], [153.0, 1089.0]], [[126.0, 928.0], [146.0, 928.0], [146.0, 1067.0], [126.0, 1067.0]]], "lines": ["．．．オイ！！", "またそうやって", "赤の他人に", "仕事くれてやる", "つもりかい！？"]}, {"box": [885, 1212, 962, 1351], "vertical": true, "font_size": 21, "lines_coords": [[[940.0, 1214.0], [962.0, 1214.0], [962.0, 1351.0], [940.0, 1351.0]], [[914.0, 1214.0], [934.0, 1214.0], [934.0, 1350.0], [914.0, 1350.0]], [[885.0, 1212.0], [907.0, 1212.0], [907.0, 1351.0], [885.0, 1351.0]]], "lines": ["そういうのを", "お人好しって", "言うんだよ！！"]}, {"box": [756, 1335, 860, 1546], "vertical": true, "font_size": 21, "lines_coords": [[[840.0, 1337.0], [860.0, 1337.0], [860.0, 1546.0], [840.0, 1546.0]], [[812.0, 1337.0], [832.0, 1337.0], [832.0, 1545.0], [812.0, 1545.0]], [[785.0, 1335.0], [807.0, 1335.0], [806.0, 1501.0], [784.0, 1501.0]], [[759.0, 1335.0], [779.0, 1335.0], [776.0, 1478.0], [756.0, 1478.0]]], "lines": ["そこにつけ込まれて", "どれだけくだらない", "借金してきたと", "思ってんだ！！"]}, {"box": [276, 1210, 326, 1371], "vertical": true, "font_size": 21, "lines_coords": [[[304.0, 1210.0], [326.0, 1210.0], [326.0, 1371.0], [304.0, 1371.0]], [[276.0, 1210.0], [296.0, 1210.0], [296.0, 1348.0], [276.0, 1348.0]]], "lines": ["そこのアンタも", "アンタだよ！！"]}, {"box": [103, 1332, 237, 1550], "vertical": true, "font_size": 21, "lines_coords": [[[214.0, 1332.0], [237.0, 1332.0], [234.0, 1473.0], [210.0, 1473.0]], [[184.0, 1334.0], [206.0, 1334.0], [206.0, 1518.0], [184.0, 1518.0]], [[157.0, 1335.0], [179.0, 1335.0], [179.0, 1518.0], [157.0, 1518.0]], [[131.0, 1335.0], [151.0, 1335.0], [151.0, 1550.0], [131.0, 1550.0]], [[103.0, 1334.0], [123.0, 1334.0], [123.0, 1495.0], [103.0, 1495.0]]], "lines": ["若いんだから", "年寄りのたわ言に", "いちいちまともに", "つき合うなんて時間の", "無駄なんだよ！！"]}], "img_path": "200.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [365, 275, 387, 296], "vertical": true, "font_size": 21, "lines_coords": [[[376.0, 275.0], [387.0, 285.0], [376.0, 296.0], [365.0, 285.0]]], "lines": ["！？"]}, {"box": [310, 304, 357, 375], "vertical": true, "font_size": 21, "lines_coords": [[[329.0, 304.0], [357.0, 304.0], [357.0, 371.0], [329.0, 371.0]], [[310.0, 314.0], [332.0, 314.0], [332.0, 375.0], [310.0, 375.0]]], "lines": ["こわい", "こわい。"]}, {"box": [929, 828, 976, 954], "vertical": true, "font_size": 24, "lines_coords": [[[950.0, 828.0], [976.0, 828.0], [976.0, 926.0], [950.0, 926.0]], [[929.0, 834.0], [948.0, 834.0], [948.0, 954.0], [929.0, 954.0]]], "lines": ["．．．僕の娘", "なんだけど、"]}, {"box": [784, 868, 892, 1032], "vertical": true, "font_size": 24, "lines_coords": [[[870.0, 870.0], [892.0, 870.0], [892.0, 964.0], [870.0, 964.0]], [[839.0, 868.0], [867.0, 868.0], [867.0, 1010.0], [839.0, 1010.0]], [[814.0, 871.0], [835.0, 871.0], [835.0, 1032.0], [814.0, 1032.0]], [[784.0, 868.0], [814.0, 868.0], [814.0, 931.0], [784.0, 931.0]]], "lines": ["僕に似て", "顔はいいのに", "性格がちょっと", "ねェ。"]}, {"box": [718, 1031, 798, 1171], "vertical": true, "font_size": 24, "lines_coords": [[[776.0, 1034.0], [798.0, 1034.0], [798.0, 1170.0], [776.0, 1170.0]], [[750.0, 1032.0], [771.0, 1032.0], [771.0, 1171.0], [750.0, 1171.0]], [[718.0, 1031.0], [745.0, 1031.0], [745.0, 1135.0], [718.0, 1135.0]]], "lines": ["つんけんした", "女性ってのは", "ヤだねェ。"]}, {"box": [579, 1081, 654, 1236], "vertical": true, "font_size": 22, "lines_coords": [[[632.0, 1081.0], [654.0, 1081.0], [654.0, 1164.0], [632.0, 1164.0]], [[606.0, 1085.0], [628.0, 1085.0], [628.0, 1226.0], [606.0, 1226.0]], [[579.0, 1084.0], [601.0, 1084.0], [603.0, 1231.0], [581.0, 1231.0]]], "lines": ["まァまァ", "いいじゃないか", "いいじゃないか。"]}, {"box": [137, 1167, 183, 1322], "vertical": true, "font_size": 21, "lines_coords": [[[160.0, 1168.0], [182.0, 1168.0], [182.0, 1293.0], [160.0, 1293.0]], [[137.0, 1167.0], [157.0, 1167.0], [157.0, 1321.0], [137.0, 1321.0]]], "lines": ["社会見学だと", "思いなさいって。"]}], "img_path": "201.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [614, 125, 693, 240], "vertical": true, "font_size": 22, "lines_coords": [[[671.0, 126.0], [693.0, 126.0], [693.0, 218.0], [671.0, 218.0]], [[643.0, 126.0], [665.0, 126.0], [665.0, 240.0], [643.0, 240.0]], [[614.0, 125.0], [637.0, 125.0], [637.0, 195.0], [614.0, 195.0]]], "lines": ["小野寺君", "お酒は好き", "なの？"]}, {"box": [537, 200, 617, 364], "vertical": true, "font_size": 22, "lines_coords": [[[593.0, 200.0], [617.0, 200.0], [617.0, 271.0], [593.0, 271.0]], [[565.0, 200.0], [585.0, 200.0], [585.0, 364.0], [565.0, 364.0]], [[537.0, 201.0], [560.0, 201.0], [560.0, 271.0], [537.0, 271.0]]], "lines": ["．．．え？", "まだ飲んだこと", "ない？"]}, {"box": [101, 65, 390, 92], "vertical": false, "font_size": 27, "lines_coords": [[[101.0, 65.0], [390.0, 65.0], [390.0, 92.0], [101.0, 92.0]]], "lines": ["おやすみプンプン□"]}, {"box": [153, 190, 232, 354], "vertical": true, "font_size": 23, "lines_coords": [[[210.0, 193.0], [232.0, 193.0], [232.0, 332.0], [210.0, 332.0]], [[182.0, 193.0], [204.0, 193.0], [204.0, 354.0], [182.0, 354.0]], [[156.0, 190.0], [176.0, 190.0], [173.0, 343.0], [153.0, 343.0]]], "lines": ["飲んでみたく", "なったら言って", "ちょうだいな。"]}, {"box": [901, 725, 954, 829], "vertical": true, "font_size": 24, "lines_coords": [[[926.0, 725.0], [954.0, 725.0], [954.0, 817.0], [926.0, 817.0]], [[901.0, 725.0], [923.0, 725.0], [923.0, 829.0], [901.0, 829.0]]], "lines": ["ねェママ", "聞いてよ。"]}, {"box": [107, 379, 193, 581], "vertical": true, "font_size": 23, "lines_coords": [[[164.0, 381.0], [190.0, 381.0], [193.0, 581.0], [167.0, 581.0]], [[140.0, 384.0], [162.0, 384.0], [162.0, 567.0], [140.0, 567.0]], [[107.0, 382.0], [135.0, 379.0], [140.0, 428.0], [112.0, 431.0]]], "lines": ["．．．ママ、お湯割りと", "ジンジャーエール", "ねー"]}, {"box": [778, 856, 887, 1