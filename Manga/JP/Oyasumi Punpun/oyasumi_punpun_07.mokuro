[1015.0, 96.0], [1015.0, 190.0], [967.0, 190.0]]], "lines": ["わっ、"]}, {"box": [901, 207, 939, 284], "vertical": true, "font_size": 41, "lines_coords": [[[901.0, 209.0], [935.0, 207.0], [939.0, 282.0], [904.0, 284.0]]], "lines": ["わっ、"]}, {"box": [139, 146, 199, 332], "vertical": true, "font_size": 27, "lines_coords": [[[171.0, 148.0], [198.0, 148.0], [198.0, 331.0], [171.0, 331.0]], [[139.0, 146.0], [165.0, 146.0], [167.0, 332.0], [140.0, 332.0]]], "lines": ["ちょーっい！！", "ちょ、いちょい！！"]}, {"box": [403, 412, 482, 554], "vertical": true, "font_size": 22, "lines_coords": [[[460.0, 414.0], [482.0, 414.0], [482.0, 531.0], [460.0, 531.0]], [[431.0, 412.0], [454.0, 412.0], [451.0, 554.0], [428.0, 554.0]], [[403.0, 412.0], [425.0, 412.0], [425.0, 507.0], [403.0, 507.0]]], "lines": ["ゴメンて！！", "悪気はないん", "だって！！"]}, {"box": [296, 521, 375, 682], "vertical": true, "font_size": 22, "lines_coords": [[[353.0, 521.0], [375.0, 521.0], [375.0, 637.0], [353.0, 637.0]], [[325.0, 521.0], [346.0, 521.0], [346.0, 682.0], [325.0, 682.0]], [[296.0, 521.0], [318.0, 521.0], [318.0, 682.0], [296.0, 682.0]]], "lines": ["口が悪いの", "あたしのホント", "悪い癖なんだ！！"]}, {"box": [973, 1010, 1003, 1168], "vertical": true, "font_size": 24, "lines_coords": [[[976.0, 1010.0], [1003.0, 1010.0], [1000.0, 1168.0], [973.0, 1168.0]]], "lines": ["感想ノート！！"]}, {"box": [431, 1057, 569, 1260], "vertical": true, "font_size": 22, "lines_coords": [[[543.0, 1059.0], [565.0, 1059.0], [565.0, 1220.0], [543.0, 1220.0]], [[515.0, 1059.0], [537.0, 1059.0], [537.0, 1260.0], [515.0, 1260.0]], [[487.0, 1059.0], [509.0, 1059.0], [509.0, 1220.0], [487.0, 1220.0]], [[459.0, 1057.0], [481.0, 1057.0], [481.0, 1220.0], [459.0, 1220.0]], [[431.0, 1059.0], [451.0, 1059.0], [451.0, 1196.0], [431.0, 1196.0]]], "lines": ["あたしが適当に", "書いてって言ったら", "君が馬鹿正直に", "びっしり埋めて", "くれたやつ！！"]}, {"box": [149, 734, 256, 939], "vertical": true, "font_size": 22, "lines_coords": [[[232.0, 734.0], [254.0, 734.0], [254.0, 851.0], [232.0, 851.0]], [[204.0, 734.0], [226.0, 734.0]