889.0], [925.0, 1035.0], [901.0, 1035.0]], [[870.0, 889.0], [892.0, 889.0], [892.0, 1050.0], [870.0, 1050.0]], [[843.0, 890.0], [865.0, 890.0], [865.0, 1051.0], [843.0, 1051.0]], [[817.0, 889.0], [837.0, 889.0], [837.0, 1025.0], [817.0, 1025.0]]], "lines": ["駅から近いし、", "相場で考えても", "かなり安くして", "あるからねー"]}, {"box": [234, 837, 289, 981], "vertical": true, "font_size": 23, "lines_coords": [[[262.0, 837.0], [289.0, 837.0], [289.0, 981.0], [262.0, 981.0]], [[234.0, 839.0], [262.0, 839.0], [262.0, 920.0], [234.0, 920.0]]], "lines": ["．．．あ、そこも", "判子ね。"]}, {"box": [137, 984, 240, 1217], "vertical": true, "font_size": 23, "lines_coords": [[[220.0, 984.0], [240.0, 984.0], [240.0, 1171.0], [220.0, 1171.0]], [[192.0, 985.0], [214.0, 985.0], [214.0, 1195.0], [192.0, 1195.0]], [[165.0, 985.0], [185.0, 985.0], [185.0, 1217.0], [165.0, 1217.0]], [[137.0, 984.0], [157.0, 984.0], [157.0, 1179.0], [137.0, 1179.0]]], "lines": ["あの部屋の管理は", "ウチでやってるから", "問題あればすぐ直すし", "便利だと思うけど、"]}, {"box": [946, 1289, 973, 1395], "vertical": true, "font_size": 25, "lines_coords": [[[946.0, 1289.0], [973.0, 1289.0], [973.0, 1395.0], [946.0, 1395.0]]], "lines": ["．．．てもね。"]}, {"box": [829, 1375, 910, 1537], "vertical": true, "font_size": 25, "lines_coords": [[[882.0, 1375.0], [910.0, 1375.0], [910.0, 1450.0], [882.0, 1450.0]], [[857.0, 1376.0], [879.0, 1376.0], [879.0, 1537.0], [857.0, 1537.0]], [[829.0, 1376.0], [851.0, 1376.0], [851.0, 1471.0], [829.0, 1471.0]]], "lines": ["何度も", "念を押すようで", "悪いけど"]}, {"box": [684, 1257, 712, 1268], "vertical": false, "font_size": 11, "lines_coords": [[[684.0, 1257.0], [712.0, 1257.0], [712.0, 1268.0], [684.0, 1268.0]]], "lines": ["こんな"]}, {"box": [253, 1240, 762, 1321], "vertical": false, "font_size": 20.25, "lines_coords": [[[356.0, 1240.0], [762.0, 1281.0], [760.0, 1303.0], [354.0, 1262.0]], [[256.0, 1246.0], [759.0, 1300.0], [757.0, 1321.0], [254.0, 1268.0]], [[254.0, 1264.0], [495.0, 1289.0], [493.0, 1309.0], [253.0, 1284.0]], [[260.0, 1287.0], [320.0, 1290.0], [320.0, 1307.0], [260.0, 1304.0]]], "lines": ["お前におかえらず、僕は人とも体の体操を食べるのは人の合意により、人は期間中の", "いつでは、自信人の状況になっていましたが、お父さんのお客さんにあることができましょう。それが人の言葉により、人格的なときに、保健人が手に入ればいいのです。", "い、いえ、いいんじゃねえかというわけですからここができるんですよね。", "おそっ"]}, {"box": [325, 1293, 592, 1340], "vertical": false, "font_size": 21, "lines_coords": [[[326.0, 1293.0], [592.0, 1320.0], [590.0, 1340.0], [325.0, 1314.0]]], "lines": ["人材中の小規模な技術をありがとては、意味、泣き打、ね"]}, {"box": [462, 1423, 612, 1468], "vertical": false, "font_size": 31, "lines_coords": [[[465.0, 1423.0], [612.0, 1437.0], [609.0, 1468.0], [462.0, 1454.0]]], "lines": ["小野寺乃"]}, {"box": [150, 1367, 207, 1521], "vertical": true, "font_size": 24, "lines_coords": [[[178.0, 1367.0], [206.0, 1367.0], [206.0, 1471.0], [178.0, 1471.0]], [[150.0, 1370.0], [171.0, 1370.0], [171.0, 1521.0], [150.0, 1521.0]]], "lines": ["．．．本当に", "いいのかい？"]}], "img_path": "134.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [867, 142, 926, 298], "vertical": true, "font_size": 24, "lines_coords": [[[898.0, 142.0], [925.0, 142.0], [925.0, 298.0], [898.0, 298.0]], [[868.0, 145.0], [890.0, 145.0], [890.0, 282.0], [868.0, 282.0]]], "lines": ["前に住んでた", "おじいさん。"]}, {"box": [165, 442, 225, 626], "vertical": true, "font_size": 27, "lines_coords": [[[196.0, 443.0], [223.0, 443.0], [223.0, 626.0], [196.0, 626.0]], [[165.0, 442.0], [192.0, 442.0], [192.0, 609.0], [165.0, 609.0]]], "lines": ["あの部屋で亡く", "なってるから。"]}, {"box": [621, 793, 749, 988], "vertical": true, "font_size": 28, "lines_coords": [[[720.0, 795.0], [746.0, 795.0], [746.0, 926.0], [720.0, 926.0]], [[685.0, 795.0], [714.0, 795.0], [715.0, 950.0], [687.0, 950.0]], [[656.0, 796.0], [682.0, 796.0], [682.0, 951.0], [656.0, 951.0]], [[621.0, 793.0], [653.0, 793.0], [653.0, 985.0], [621.0, 985.0]]], "lines": ["フンフンは", "お金と判子で", "初めて他人と", "契約をしました。"]}, {"box": [325, 793, 482, 951], "vertical": true, "font_size": 27, "lines_coords": [[[448.0, 793.0], [482.0, 793.0], [482.0, 878.0], [448.0, 878.0]], [[423.0, 796.0], [445.0, 796.0], [445.0, 948.0], [423.0, 948.0]], [[389.0, 795.0], [415.0, 795.0], [415.0, 950.0], [389.0, 950.0]], [[357.0, 795.0], [384.0, 795.0], [384.0, 951.0], [357.0, 951.0]], [[325.0, 795.0], [351.0, 795.0], [351.0, 934.0], [325.0, 934.0]]], "lines": ["こんな", "単純なことで", "またちょっと", "大人になった", "気分でした。"]}], "img_path": "135.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [925, 59, 995, 307], "vertical": true, "font_size": 31, "lines_coords": [[[957.0, 60.0], [992.0, 59.0], [995.0, 140.0], [960.0, 142.0]], [[926.0, 62.0], [953.0, 62.0], [951.0, 293.0], [925.0, 293.0]]], "lines": ["動機は", "不埒ではあるけれど"]}, {"box": [786, 63, 875, 343], "vertical": true, "font_size": 23, "lines_coords": [[[851.0, 65.0], [873.0, 65.0], [873.0, 242.0], [851.0, 242.0]], [[817.0, 64.0], [843.0, 64.0], [843.0, 343.0], [817.0, 343.0]], [[787.0, 65.0], [809.0, 65.0], [809.0, 276.0], [787.0, 276.0]]], "lines": ["自分がこんなに", "行動的になれるだなんて", "思いませんでした。"]}, {"box": [510, 59, 665, 266], "vertical": true, "font_size": 24, "lines_coords": [[[635.0, 62.0], [662.0, 62.0], [662.0, 171.0], [635.0, 171.0]], [[603.0, 60.0], [629.0, 60.0], [629.0, 240.0], [603.0, 240.0]], [[575.0, 62.0], [596.0, 62.0], [596.0, 264.0], [575.0, 264.0]], [[539.0, 59.0], [565.0, 59.0], [568.0, 265.0], [542.0, 265.0]], [[510.0, 62.0], [532.0, 62.0], [532.0, 196.0], [510.0, 196.0]]], "lines": ["けどもう、", "誰かに後ろ指を", "指されたとしても", "気にするつもりは", "ありません。"]}, {"box": [340, 110, 427, 396], "vertical": true, "font_size": 23, "lines_coords": [[[400.0, 110.0], [426.0, 110.0], [426.0, 239.0], [400.0, 239.0]], [[371.0, 112.0], [393.0, 112.0], [393.0, 289.0], [371.0, 289.0]], [[340.0, 112.0], [362.0, 112.0], [362.0, 390.0], [340.0, 390.0]]], "lines": ["青臭いとか", "気持ち悪いとか", "精神的痛がりさんだとか"]}, {"box": [264, 112, 288, 269], "vertical": true, "font_size": 20, "lines_coords": [[[265.0, 112.0], [285.0, 112.0], [285.0, 265.0], [265.0, 265.0]]], "lines": ["そんなことは"]}, {"box": [155, 111, 212, 389], "vertical": true, "font_size": 22, "lines_coords": [[[187.0, 114.0], [209.0, 114.0], [209.0, 387.0], [187.0, 387.0]], [[156.0, 114.0], [178.0, 114.0], [178.0, 317.0], [156.0, 317.0]]], "lines": ["いちいち言われなくても", "わかってますから"]}, {"box": [629, 1343, 718, 1532], "vertical": true, "font_size": 25, "lines_coords": [[[692.0, 1343.0], [718.0, 1343.0], [718.0, 1495.0], [692.0, 1495.0]], [[659.0, 1343.0], [685.0, 1343.0], [685.0, 1495.0], [659.0, 1495.0]], [[629.0, 1345.0], [651.0, 1345.0], [651.0, 1523.0], [629.0, 1523.0]]], "lines": ["二万五千円の", "安アパートの", "頼りないドアは"]}, {"box": [520, 1342, 579, 1478], "vertical": true, "font_size": 24, "lines_coords": [[[553.0, 1342.0], [579.0, 1342.0], [579.0, 1470.0], [553.0, 1470.0]], [[521.0, 1345.0], [543.0, 1345.0], [543.0, 1476.0], [521.0, 1476.0]]], "lines": ["ちっちゃな", "鍵ひとつで、"]}, {"box": [409, 1342, 470, 1548], "vertical": true, "font_size": 22, "lines_coords": [[[445.0, 1345.0], [467.0, 1345.0], [467.0, 1540.0], [445.0, 1540.0]], [[412.0, 1342.0], [435.0, 1342.0], [432.0, 1479.0], [409.0, 1479.0]]], "lines": ["いともあっけなく", "開きました。"]}], "img_path": "136.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [921, 64, 957, 157], "vertical": true, "font_size": 30, "lines_coords": [[[921.0, 65.0], [954.0, 64.0], [957.0, 156.0], [925.0, 157.0]]], "lines": ["．．．あっ、"]}, {"box": [853, 178, 881, 312], "vertical": true, "font_size": 30, "lines_coords": [[[853.0, 178.0], [881.0, 178.0], [881.0, 312.0], [853.0, 312.0]]], "lines": ["プンプン！！"]}, {"box": [178, 437, 231, 540], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 437.0], [226.0, 437.0], [226.0, 540.0], [200.0, 540.0]]], "lines": ["おかえり"]}], "img_path": "137.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [900, 142, 925, 302], "vertical": true, "font_size": 20, "lines_coords": [[[900.0, 142.0], [920.0, 142.0], [923.0, 295.0], [903.0, 295.0]]], "lines": ["・この部屋は"]}, {"box": [727, 143, 817, 296], "vertical": true, "font_size": 23, "lines_coords": [[[789.0, 143.0], [815.0, 143.0], [815.0, 296.0], [789.0, 296.0]], [[759.0, 145.0], [781.0, 145.0], [781.0, 293.0], [759.0, 293.0]], [[728.0, 145.0], [750.0, 145.0], [750.0, 256.0], [728.0, 256.0]]], "lines": ["愛子ちゃんと", "暮らすための", "部屋です。"]}, {"box": [153, 208, 178, 309], "vertical": true, "font_size": 22, "lines_coords": [[[153.0, 209.0], [175.0, 209.0], [175.0, 309.0], [153.0, 309.0]]], "lines": ["．．．あれ？"]}, {"box": [487, 400, 581, 606], "vertical": true, "font_size": 26, "lines_coords": [[[546.0, 400.0], [581.0, 400.0], [581.0, 482.0], [546.0, 482.0]], [[518.0, 400.0], [545.0, 400.0], [545.0, 556.0], [518.0, 556.0]], [[487.0, 400.0], [509.0, 400.0], [509.0, 606.0], [487.0, 606.0]]], "lines": ["たとえ", "愛子ちゃんを", "見つけたとしても"]}, {"box": [370, 398, 456, 601], "vertical": true, "font_size": 26, "lines_coords": [[[434.0, 403.0], [456.0, 403.0], [456.0, 601.0], [434.0, 601.0]], [[396.0, 398.0], [423.0, 398.0], [426.0, 554.0], [400.0, 554.0]], [[370.0, 400.0], [392.0, 400.0], [392.0, 582.0], [370.0, 582.0]]], "lines": ["結局何もできない", "自分を容易に", "想像できますが、"]}, {"box": [178, 398, 270, 614], "vertical": true, "font_size": 25, "lines_coords": [[[242.0, 400.0], [268.0, 400.0], [268.0, 554.0], [242.0, 554.0]], [[207.0, 398.0], [235.0, 398.0], [237.0, 501.0], [209.0, 501.0]], [[179.0, 400.0], [201.0, 400.0], [201.0, 609.0], [179.0, 609.0]]], "lines": ["それはさほど", "問題じゃ", "ありませんでした。"]}, {"box": [699, 1323, 725, 1460], "vertical": true, "font_size": 21, "lines_coords": [[[700.0, 1325.0], [721.0, 1325.0], [721.0, 1456.0], [700.0, 1456.0]]], "lines": ["なんかもう、"]}, {"box": [535, 1320, 632, 1452], "vertical": true, "font_size": 31, "lines_coords": [[[598.0, 1320.0], [632.0, 1320.0], [632.0, 1404.0], [598.0, 1404.0]], [[570.0, 1321.0], [596.0, 1321.0], [596.0, 1450.0], [570.0, 1450.0]], [[535.0, 1321.0], [568.0, 1321.0], [568.0, 1409.0], [535.0, 1409.0]]], "lines": ["うまく", "言えないん", "だけど、"]}, {"box": [410, 1318, 474, 1503], "vertical": true, "font_size": 32, "lines_coords": [[[446.0, 1321.0], [473.0, 1321.0], [473.0, 1500.0], [446.0, 1500.0]], [[410.0, 1318.0], [446.0, 1318.0], [446.0, 1389.0], [410.0, 1389.0]]], "lines": ["やるしかないん", "です。"]}, {"box": [125, 1354, 156, 1509], "vertical": true, "font_size": 28, "lines_coords": [[[125.0, 1354.0], [153.0, 1354.0], [154.0, 1509.0], [126.0, 1509.0]]], "lines": ["．．．うわっ！！"]}], "img_path": "138.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [921, 64, 948, 159], "vertical": true, "font_size": 26, "lines_coords": [[[921.0, 64.0], [948.0, 64.0], [948.0, 159.0], [921.0, 159.0]]], "lines": ["．．．あっ！！"]}, {"box": [817, 165, 901, 331], "vertical": true, "font_size": 26, "lines_coords": [[[868.0, 165.0], [901.0, 165.0], [901.0, 251.0], [868.0, 251.0]], [[843.0, 168.0], [865.0, 168.0], [865.0, 329.0], [843.0, 329.0]], [[820.0, 167.0], [840.0, 167.0], [837.0, 331.0], [817.0, 331.0]]], "lines": ["たー君、", "おかえりー！！", "びっくりした！？"]}, {"box": [146, 178, 235, 462], "vertical": true, "font_size": 22, "lines_coords": [[[207.0, 179.0], [231.0, 178.0], [235.0, 239.0], [212.0, 240.0]], [[196.0, 295.0], [218.0, 295.0], [217.0, 442.0], [195.0, 442.0]], [[170.0, 295.0], [192.0, 295.0], [193.0, 460.0], [171.0, 460.0]], [[146.0, 296.0], [167.0, 296.0], [167.0, 462.0], [146.0, 462.0]]], "lines": ["ちょ．．．", "びっくりした．．．", "来るなら来るって", "連絡してくれよ．．"]}, {"box": [921, 654, 951, 726], "vertical": true, "font_size": 28, "lines_coords": [[[921.0, 654.0], [951.0, 654.0], [951.0, 726.0], [921.0, 726.0]]], "lines": ["あ．．．"]}, {"box": [214, 701, 282, 825], "vertical": true, "font_size": 21, "lines_coords": [[[265.0, 703.0], [282.0, 703.0], [282.0, 803.0], [265.0, 803.0]], [[239.0, 701.0], [260.0, 701.0], [260.0, 803.0], [239.0, 803.0]], [[214.0, 701.0], [234.0, 701.0], [234.0, 825.0], [214.0, 825.0]]], "lines": ["もしかして", "飯とか作っ", "ちゃってた？"]}, {"box": [876, 771, 903, 871], "vertical": true, "font_size": 28, "lines_coords": [[[876.0, 771.0], [903.0, 771.0], [903.0, 871.0], [876.0, 871.0]]], "lines": ["ゴメン．．．"]}, {"box": [134, 839, 207, 984], "vertical": true, "font_size": 21, "lines_coords": [[[181.0, 839.0], [207.0, 839.0], [207.0, 940.0], [181.0, 940.0]], [[159.0, 840.0], [181.0, 840.0], [181.0, 984.0], [159.0, 984.0]], [[134.0, 840.0], [154.0, 840.0], [154.0, 984.0], [134.0, 984.0]]], "lines": ["あーー俺、", "斉藤達と食って", "来ちゃったよ．．．"]}, {"box": [831, 1121, 949, 1417], "vertical": true, "font_size": 23, "lines_coords": [[[882.0, 1292.0], [910.0, 1292.0], [910.0, 1371.0], [882.0, 1371.0]], [[857.0, 1293.0], [879.0, 1293.0], [879.0, 1407.0], [857.0, 1407.0]], [[831.0, 1293.0], [851.0, 1293.0], [851.0, 1417.0], [831.0, 1417.0]]], "lines": ["いいよ、", "じゃあ全部", "捨てるから。"]}, {"box": [209, 1187, 256, 1292], "vertical": true, "font_size": 21, "lines_coords": [[[234.0, 1187.0], [256.0, 1187.0], [256.0, 1292.0], [234.0, 1292.0]], [[209.0, 1189.0], [226.0, 1189.0], [226.0, 1289.0], [209.0, 1289.0]]], "lines": ["．．．なんだよ", "怒んなよ！！"]}, {"box": [132, 1337, 204, 1535], "vertical": true, "font_size": 21, "lines_coords": [[[182.0, 1337.0], [204.0, 1337.0], [203.0, 1503.0], [181.0, 1503.0]], [[157.0, 1340.0], [178.0, 1340.0], [178.0, 1535.0], [157.0, 1535.0]], [[132.0, 1339.0], [153.0, 1339.0], [153.0, 1526.0], [132.0, 1526.0]]], "lines": ["今日はフットサル", "だから、遅くなるって", "言っといたじゃん！！"]}], "img_path": "139.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [920, 85, 940, 223], "vertical": true, "font_size": 21, "lines_coords": [[[920.0, 85.0], [940.0, 85.0], [940.0, 223.0], [920.0, 223.0]]], "lines": ["そうだけど．．．"]}, {"box": [814, 237, 892, 403], "vertical": true, "font_size": 21, "lines_coords": [[[870.0, 237.0], [892.0, 237.0], [892.0, 379.0], [870.0, 379.0]], [[840.0, 239.0], [862.0, 239.0], [864.0, 403.0], [842.0, 403.0]], [[814.0, 240.0], [834.0, 240.0], [834.0, 403.0], [814.0, 403.0]]], "lines": ["こんなに遅く", "なるとは言って", "なかったもん．．．"]}, {"box": [232, 96, 337, 243], "vertical": true, "font_size": 22, "lines_coords": [[[309.0, 96.0], [337.0, 96.0], [337.0, 184.0], [309.0, 184.0]], [[281.0, 100.0], [303.0, 100.0], [303.0, 243.0], [281.0, 243.0]], [[254.0, 98.0], [276.0, 98.0], [276.0, 242.0], [254.0, 242.0]], [[232.0, 100.0], [253.0, 100.0], [253.0, 223.0], [232.0, 223.0]]], "lines": ["俺だって", "由利亜が勝手に", "来るとか思って", "なかったし．．"]}, {"box": [146, 271, 243, 468], "vertical": true, "font_size": 22, "lines_coords": [[[221.0, 273.0], [243.0, 273.0], [243.0, 468.0], [221.0, 468.0]], [[196.0, 271.0], [217.0, 271.0], [217.0, 418.0], [196.0, 418.0]], [[170.0, 271.0], [190.0, 271.0], [190.0, 456.0], [170.0, 456.0]], [[146.0, 271.0], [167.0, 271.0], [167.0, 435.0], [146.0, 435.0]]], "lines": ["つーかわかるっしょ？", "斉藤と遊んだら", "大抵飲みに流れんの", "知ってるっしょ？"]}, {"box": [817, 565, 965, 785], "vertical": true, "font_size": 24, "lines_coords": [[[943.0, 567.0], [965.0, 567.0], [965.0, 785.0], [943.0, 785.0]], [[909.0, 565.0], [935.0, 565.0], [935.0, 771.0], [909.0, 771.0]], [[878.0, 567.0], [904.0, 567.0], [904.0, 773.0], [878.0, 773.0]], [[848.0, 567.0], [870.0, 567.0], [870.0, 743.0], [848.0, 743.0]], [[817.0, 567.0], [839.0, 567.0], [839.0, 668.0], [817.0, 668.0]]], "lines": ["そうやっていっつも", "斎藤君斉藤君て．．．", "だったら斉藤君と", "付き合えばいい", "じゃん！！"]}, {"box": [225, 567, 315, 723], "vertical": true, "font_size": 26, "lines_coords": [[[279.0, 567.0], [312.0, 567.0], [315.0, 676.0], [282.0, 676.0]], [[256.0, 571.0], [278.0, 571.0], [278.0, 698.0], [256.0, 698.0]], [[225.0, 571.0], [246.0, 571.0], [246.0, 723.0], [225.0, 723.0]]], "lines": ["．．．はァ！？", "なんでそう", "なるんだよ！！"]}, {"box": [692, 742, 812, 948], "vertical": true, "font_size": 24, "lines_coords": [[[785.0, 742.0], [812.0, 742.0], [812.0, 948.0], [785.0, 948.0]], [[753.0, 742.0], [778.0, 742.0], [781.0, 946.0], [756.0, 946.0]], [[725.0, 743.0], [746.0, 743.0], [746.0, 945.0], [725.0, 945.0]], [[692.0, 742.0], [714.0, 742.0], [715.0, 946.0], [693.0, 946.0]]], "lines": ["その飲みってのも", "アレなんでしょ！？", "女の子とかも来る", "アレなんでしょ！？"]}, {"box": [934, 1117, 956, 1229], "vertical": true, "font_size": 26, "lines_coords": [[[934.0, 1117.0], [956.0, 1117.0], [956.0, 1229.0], [934.0, 1229.0]]], "lines": ["．．．証拠は？"]}, {"box": [135, 754, 257, 964], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 754.0], [257.0, 754.0], [257.0, 839.0], [225.0, 839.0]], [[193.0, 757.0], [221.0, 757.0], [223.0, 964.0], [195.0, 964.0]], [[165.0, 760.0], [187.0, 760.0], [187.0, 964.0], [165.0, 964.0]], [[135.0, 760.0], [157.0, 760.0], [157.0, 937.0], [135.0, 937.0]]], "lines": ["それに", "女の子っつっても", "お前の知ってる子", "しか来ねーよ！！"]}, {"box": [859, 1256, 915, 1351], "vertical": true, "font_size": 26, "lines_coords": [[[884.0, 1256.0], [915.0, 1256.0], [915.0, 1310.0], [884.0, 1310.0]], [[859.0, 1256.0], [885.0, 1256.0], [885.0, 1351.0], [859.0, 1351.0]]], "lines": ["証拠", "あんの？"]}, {"box": [212, 1154, 284, 1307], "vertical": true, "font_size": 21, "lines_coords": [[[267.0, 1157.0], [284.0, 1157.0], [284.0, 1257.0], [267.0, 1257.0]], [[239.0, 1156.0], [260.0, 1156.0], [260.0, 1307.0], [239.0, 1307.0]], [[214.0, 1154.0], [235.0, 1154.0], [234.0, 1298.0], [212.0, 1298.0]]], "lines": ["．．．証拠って", "お前、小学生じゃ", "ねーんだから．．．"]}, {"box": [157, 1339, 206, 1442], "vertical": true, "font_size": 21, "lines_coords": [[[184.0, 1339.0], [206.0, 1339.0], [206.0, 1442.0], [184.0, 1442.0]], [[157.0, 1339.0], [179.0, 1339.0], [179.0, 1425.0], [157.0, 1425.0]]], "lines": ["．．．バカじゃ", "ねーの？"]}], "img_path": "140.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [903, 104, 956, 243], "vertical": true, "font_size": 23, "lines_coords": [[[929.0, 104.0], [956.0, 104.0], [956.0, 243.0], [929.0, 243.0]], [[904.0, 104.0], [926.0, 104.0], [925.0, 242.0], [903.0, 242.0]]], "lines": ["．．．あ、バカ", "って言った"]}, {"box": [809, 285, 914, 425], "vertical": true, "font_size": 23, "lines_coords": [[[892.0, 287.0], [914.0, 287.0], [914.0, 425.0], [892.0, 425.0]], [[864.0, 285.0], [885.0, 285.0], [885.0, 425.0], [864.0, 425.0]], [[835.0, 285.0], [857.0, 285.0], [857.0, 403.0], [835.0, 403.0]], [[809.0, 285.0], [831.0, 285.0], [831.0, 381.0], [809.0, 381.0]]], "lines": ["由利亜が一番", "言われるのが", "嫌な言葉を", "言った．．"]}, {"box": [212, 167, 292, 304], "vertical": true, "font_size": 23, "lines_coords": [[[265.0, 167.0], [292.0, 167.0], [292.0, 267.0], [265.0, 267.0]], [[242.0, 168.0], [264.0, 168.0], [264.0, 304.0], [242.0, 304.0]], [[212.0, 167.0], [234.0, 167.0], [234.0, 264.0], [212.0, 264.0]]], "lines": ["．．．ゴメン", "ちょっと言い", "過ぎた．．．"]}, {"box": [115, 329, 226, 470], "vertical": true, "font_size": 23, "lines_coords": [[[198.0, 329.0], [226.0, 329.0], [226.0, 412.0], [198.0, 412.0]], [[175.0, 332.0], [192.0, 332.0], [192.0, 446.0], [175.0, 446.0]], [[145.0, 332.0], [167.0, 332.0], [167.0, 470.0], [145.0, 470.0]], [[115.0, 332.0], [137.0, 332.0], [137.0, 423.0], [115.0, 423.0]]], "lines": ["．．．ホラ、", "とりあえず", "持ってる包丁", "置こう？"]}, {"box": [925, 581, 995, 735], "vertical": true, "font_size": 30, "lines_coords": [[[962.0, 581.0], [995.0, 581.0], [995.0, 735.0], [962.0, 735.0]], [[926.0, 582.0], [954.0, 582.0], [954.0, 734.0], [926.0, 734.0]]], "lines": ["．．．ヤダッ！！", "触んなっ！！"]}, {"box": [264, 628, 332, 811], "vertical": true, "font_size": 37, "lines_coords": [[[295.0, 628.0], [332.0, 628.0], [332.0, 681.0], [295.0, 681.0]]], "lines": ["もー"]}, {"box": [300, 728, 332, 795], "vertical": true, "font_size": 26, "lines_coords": [[[300.0, 729.0], [329.0, 728.0], [332.0, 793.0], [303.0, 795.0]]], "lines": ["ーっ、"]}, {"box": [846, 807, 920, 904], "vertical": true, "font_size": 28, "lines_coords": [[[885.0, 809.0], [920.0, 809.0], [920.0, 904.0], [885.0, 904.0]], [[846.0, 807.0], [879.0, 807.0], [879.0, 904.0], [846.0, 904.0]]], "lines": ["気持ち", "悪い！！"]}, {"box": [631, 767, 812, 1051], "vertical": true, "font_size": 28, "lines_coords": [[[785.0, 770.0], [812.0, 770.0], [812.0, 975.0], [785.0, 975.0]], [[756.0, 768.0], [779.0, 768.0], [778.0, 1000.0], [754.0, 1000.0]], [[723.0, 768.0], [750.0, 768.0], [750.0, 1051.0], [723.0, 1051.0]], [[693.0, 768.0], [720.0, 768.0], [720.0, 1037.0], [693.0, 1037.0]], [[665.0, 770.0], [687.0, 770.0], [687.0, 1048.0], [665.0, 1048.0]], [[632.0, 767.0], [659.0, 767.0], [657.0, 1034.0], [631.0, 1034.0]]], "lines": ["たー君モテるから", "実は飲み会で女の子", "持ち帰りとかしてんだ！！", "だから、来る時は事前に", "連絡しろとかって言うん", "でしょォ、もーやだ！！"]}, {"box": [120, 632, 290, 1071], "vertical": true, "font_size": 26, "lines_coords": [[[264.0, 632.0], [290.0, 632.0], [290.0, 814.0], [264.0, 814.0]], [[250.0, 907.0], [271.0, 907.0], [271.0, 1071.0], [250.0, 1071.0]], [[217.0, 906.0], [243.0, 906.0], [243.0, 1062.0], [217.0, 1062.0]], [[185.0, 906.0], [212.0, 906.0], [212.0, 1062.0], [185.0, 1062.0]], [[154.0, 904.0], [181.0, 904.0], [181.0, 1070.0], [154.0, 1070.0]], [[120.0, 907.0], [146.0, 907.0], [150.0, 1035.0], [123.0, 1035.0]]], "lines": ["なんだよっ！！", "お前、どんだけ", "俺のこと信用", "してねーの！？", "俺、どーすりゃ", "いーのよ！？"]}, {"box": [126, 909, 277, 1073], "vertical": true, "font_size": 151, "lines_coords": [[[126.0, 909.0], [277.0, 909.0], [277.0, 1073.0], [126.0, 1073.0]]], "lines": ["お前、どんだけ俺のこと信用してねーの！？俺、どーすりゃいーのよ！？"]}, {"box": [928, 1214, 981, 1301], "vertical": true, "font_size": 23, "lines_coords": [[[959.0, 1217.0], [981.0, 1217.0], [981.0, 1301.0], [959.0, 1301.0]], [[928.0, 1214.0], [962.0, 1214.0], [962.0, 1284.0], [928.0, 1284.0]]], "lines": ["．．．ホント", "嫌．．．．．"]}, {"box": [840, 1301, 915, 1448], "vertical": true, "font_size": 23, "lines_coords": [[[893.0, 1301.0], [915.0, 1301.0], [915.0, 1429.0], [893.0, 1429.0]], [[867.0, 1304.0], [889.0, 1304.0], [889.0, 1448.0], [867.0, 1448.0]], [[840.0, 1304.0], [862.0, 1304.0], [864.0, 1429.0], [842.0, 1429.0]]], "lines": ["そういうコト", "自分で考えない", "のが一番嫌．．．"]}, {"box": [656, 1312, 803, 1503], "vertical": true, "font_size": 23, "lines_coords": [[[781.0, 1314.0], [803.0, 1314.0], [801.0, 1479.0], [779.0, 1479.0]], [[756.0, 1315.0], [778.0, 1315.0], [778.0, 1503.0], [756.0, 1503.0]], [[731.0, 1315.0], [751.0, 1315.0], [751.0, 1459.0], [731.0, 1459.0]], [[703.0, 1312.0], [725.0, 1312.0], [726.0, 1479.0], [704.0, 1479.0]], [[679.0, 1314.0], [701.0, 1314.0], [700.0, 1498.0], [678.0, 1498.0]], [[656.0, 1315.0], [676.0, 1315.0], [676.0, 1440.0], [656.0, 1440.0]]], "lines": ["昔はもっと好き」", "って言ってくれたし。", "頭なでなでして", "くれたのに最近は", "チューもアタシから", "ばっかだし．．．"]}, {"box": [220, 1223, 242, 1359], "vertical": true, "font_size": 22, "lines_coords": [[[220.0, 1223.0], [242.0, 1223.0], [242.0, 1359.0], [220.0, 1359.0]]], "lines": ["わかったよ．．"]}, {"box": [101, 1362, 207, 1481], "vertical": true, "font_size": 22, "lines_coords": [[[185.0, 1362.0], [207.0, 1362.0], [207.0, 1479.0], [185.0, 1479.0]], [[157.0, 1364.0], [179.0, 1364.0], [179.0, 1481.0], [157.0, 1481.0]], [[131.0, 1362.0], [153.0, 1362.0], [153.0, 1478.0], [131.0, 1478.0]], [[101.0, 1364.0], [123.0, 1364.0], [123.0, 1457.0], [101.0, 1457.0]]], "lines": ["これからは", "自分からも", "するように", "するよ．．"]}], "img_path": "141.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [925, 84, 976, 221], "vertical": true, "font_size": 21, "lines_coords": [[[954.0, 84.0], [976.0, 84.0], [976.0, 221.0], [954.0, 221.0]], [[925.0, 84.0], [946.0, 84.0], [946.0, 178.0], [925.0, 178.0]]], "lines": ["全然わかって", "ないよ．．．"]}, {"box": [821, 212, 900, 420], "vertical": true, "font_size": 21, "lines_coords": [[[878.0, 214.0], [900.0, 214.0], [900.0, 398.0], [878.0, 398.0]], [[848.0, 212.0], [870.0, 212.0], [871.0, 395.0], [850.0, 395.0]], [[821.0, 214.0], [843.0, 214.0], [843.0, 420.0], [821.0, 420.0]]], "lines": ["由利亜に言われて", "わかったってソレ", "全然意味ないもん．．．"]}, {"box": [696, 287, 760, 443], "vertical": true, "font_size": 21, "lines_coords": [[[740.0, 289.0], [760.0, 289.0], [760.0, 442.0], [740.0, 442.0]], [[718.0, 287.0], [739.0, 287.0], [739.0, 423.0], [718.0, 423.0]], [[696.0, 287.0], [717.0, 287.0], [717.0, 443.0], [696.0, 443.0]]], "lines": ["由利亜はこんなに", "たー君のことが", "好きなのになんで"]}, {"box": [678, 289, 693, 470], "vertical": true, "font_size": 15, "lines_coords": [[[678.0, 289.0], [693.0, 289.0], [693.0, 470.0], [678.0, 470.0]]], "lines": ["わかってくれないの："]}, {"box": [131, 342, 241, 482], "vertical": true, "font_size": 23, "lines_coords": [[[218.0, 345.0], [240.0, 345.0], [240.0, 460.0], [218.0, 460.0]], [[189.0, 345.0], [210.0, 345.0], [210.0, 481.0], [189.0, 481.0]], [[160.0, 343.0], [182.0, 343.0], [182.0, 462.0], [160.0, 462.0]], [[131.0, 342.0], [157.0, 342.0], [157.0, 439.0], [131.0, 439.0]]], "lines": ["．．．俺だって", "由利亜のこと", "すげー好き", "だよ．．．"]}, {"box": [926, 1068, 948, 1184], "vertical": true, "font_size": 24, "lines_coords": [[[926.0, 1068.0], [948.0, 1068.0], [948.0, 1184.0], [926.0, 1184.0]]], "lines": ["．．．ホント？"]}, {"box": [806, 1193, 917, 1332], "vertical": true, "font_size": 24, "lines_coords": [[[890.0, 1193.0], [914.0, 1193.0], [917.0, 1289.0], [893.0, 1289.0]], [[865.0, 1196.0], [887.0, 1196.0], [887.0, 1332.0], [865.0, 1332.0]], [[837.0, 1195.0], [859.0, 1195.0], [859.0, 1312.0], [837.0, 1312.0]], [[806.0, 1193.0], [834.0, 1193.0], [834.0, 1267.0], [806.0, 1267.0]]], "lines": ["たー君は", "由利亜のこと", "世界で一番", "好き？"]}, {"box": [115, 1186, 259, 1456], "vertical": true, "font_size": 21, "lines_coords": [[[232.0, 1198.0], [256.0, 1198.0], [256.0, 1271.0], [232.0, 1271.0]], [[214.0, 1332.0], [235.0, 1332.0], [235.0, 1417.0], [214.0, 1417.0]], [[189.0, 1332.0], [210.0, 1332.0], [210.0, 1456.0], [189.0, 1456.0]], [[165.0, 1331.0], [187.0, 1331.0], [187.0, 1456.0], [165.0, 1456.0]], [[143.0, 1334.0], [160.0, 1334.0], [160.0, 1437.0], [143.0, 1437.0]], [[115.0, 1331.0], [137.0, 1331.0], [140.0, 1425.0], [118.0, 1425.0]]], "lines": ["．．．うん。", "たー君は", "由利亜のこと", "世界っつーか", "宇宙で一番", "好きだよ。"]}], "img_path": "142.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [635, 114, 695, 249], "vertical": true, "font_size": 27, "lines_coords": [[[668.0, 115.0], [695.0, 115.0], [695.0, 243.0], [668.0, 243.0]], [[635.0, 115.0], [662.0, 115.0], [662.0, 243.0], [635.0, 243.0]]], "lines": ["フンフンは", "心の底から"]}, {"box": [398, 113, 555, 296], "vertical": true, "font_size": 26, "lines_coords": [[[526.0, 115.0], [553.0, 115.0], [553.0, 243.0], [526.0, 243.0]], [[490.0, 114.0