.0], [917.0, 317.0], [895.0, 317.0]], [[862.0, 112.0], [884.0, 112.0], [884.0, 317.0], [862.0, 317.0]], [[829.0, 114.0], [851.0, 114.0], [851.0, 290.0], [829.0, 290.0]]], "lines": ["．．．．．確かに！！", "指定校推薦で", "進学を決めた俺は", "安易な男に見える", "かもしれない．．．"]}, {"box": [78, 81, 230, 423], "vertical": true, "font_size": 26, "lines_coords": [[[198.0, 89.0], [225.0, 89.0], [225.0, 198.0], [198.0, 198.0]], [[176.0, 245.0], [198.0, 245.0], [198.0, 370.0], [176.0, 370.0]], [[142.0, 242.0], [168.0, 242.0], [168.0, 396.0], [142.0, 396.0]], [[109.0, 242.0], [135.0, 242.0], [137.0, 423.0], [110.0, 423.0]], [[78.0, 245.0], [106.0, 245.0], [106.0, 325.0], [78.0, 325.0]]], "lines": ["．．．しかし、", "それは俺の", "壮大な計画の", "布石に過ぎない", "のだ！！"]}, {"box": [510, 512, 603, 719], "vertical": true, "font_size": 27, "lines_coords": [[[576.0, 514.0], [603.0, 514.0], [603.0, 643.0], [576.0, 643.0]], [[542.0, 512.0], [568.0, 512.0], [571.0, 718.0], [545.0, 718.0]], [[510.0, 514.0], [537.0, 514.0], [537.0, 625.0], [510.0, 625.0]]], "lines": ["回し読みで", "ボロボロになった", "漫画雑誌。"]}, {"box": [884, 832, 973, 987], "vertical": true, "font_size": 25, "lines_coords": [[[950.0, 832.0], [973.0, 832.0], [970.0, 959.0], [946.0, 959.0]], [[915.0, 832.0], [942.0, 832.0], [942.0, 987.0], [915.0, 987.0]], [[884.0, 832.0], [907.0, 832.0], [909.0, 985.0], [885.0, 985.0]]], "lines": ["俺は渋谷に", "ピラミッドを", "建立するゼ！！"]}, {"box": [826, 1000, 853, 1153], "vertical": true, "font_size": 25, "lines_coords": [[[826.0, 1000.0], [853.0, 1000.0], [853.0, 1153.0], [826.0, 1153.0]]], "lines": ["ピュンッ！！"]}, {"box": [112, 873, 204, 1080], "vertical": true, "font_size": 25, "lines_coords": [[[178.0, 873.0], [204.0, 873.0], [200.0, 1031.0], [173.0, 1031.0]], [[145.0, 876.0], [167.0, 876.0], [167.0, 1079.0], [145.0, 1079.0]], [[112.0, 873.0], [139.0, 873.0], [139.0, 1006.0], [112.0, 1006.0]]], "lines": ["．．．さっきから", "うるっせえんだよ", "三村ァッ！！"]}, {"box": [506, 1301, 600, 1510], "vertical": true, "font_size": 28, "lines_coords": [[[571.0, 1304.0], [600.0, 1304.0], [600.0, 1409