0], [525.0, 312.0]]], "lines": ["．．．グッド", "バイブレーション。"]}, {"box": [862, 1150, 985, 1331], "vertical": true, "font_size": 23, "lines_coords": [[[959.0, 1151.0], [985.0, 1151.0], [985.0, 1331.0], [959.0, 1331.0]], [[929.0, 1151.0], [951.0, 1151.0], [951.0, 1279.0], [929.0, 1279.0]], [[898.0, 1153.0], [920.0, 1153.0], [920.0, 1329.0], [898.0, 1329.0]], [[865.0, 1150.0], [889.0, 1150.0], [885.0, 1287.0], [862.0, 1287.0]]], "lines": ["１５分の遅刻とは", "君はなんて", "のんびり屋さん", "なんだろう。"]}, {"box": [190, 1195, 251, 1301], "vertical": true, "font_size": 28, "lines_coords": [[[218.0, 1195.0], [251.0, 1195.0], [251.0, 1279.0], [218.0, 1279.0]], [[190.0, 1198.0], [217.0, 1198.0], [217.0, 1301.0], [190.0, 1301.0]]], "lines": ["しかし", "僕はね．．"]}, {"box": [98, 1320, 189, 1540], "vertical": true, "font_size": 28, "lines_coords": [[[162.0, 1320.0], [189.0, 1320.0], [189.0, 1540.0], [162.0, 1540.0]], [[129.0, 1321.0], [156.0, 1321.0], [156.0, 1531.0], [129.0, 1531.0]], [[98.0, 1321.0], [126.0, 1321.0], [126.0, 1428.0], [98.0, 1428.0]]], "lines": ["君のそのすべてをも", "愛してしまいそう", "だ．．．．．！！"]}], "img_path": "071.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [932, 84, 992, 198], "vertical": true, "font_size": 28, "lines_coords": [[[964.0, 85.0], [992.0, 85.0], [992.0, 198.0], [964.0, 198.0]], [[932.0, 84.0], [960.0, 84.0], [960.0, 189.0], [932.0, 189.0]]], "lines": ["．．．いや、", "むしろ．．．"]}, {"box": [296, 87, 387, 245], "vertical": true, "font_size": 27, "lines_coords": [[[354.0, 87.0], [387.0, 87.0], [387.0, 193.0], [354.0, 193.0]], [[325.0, 90.0], [351.0, 90.0], [351.0, 245.0], [325.0, 245.0]], [[296.0, 92.0], [318.0, 92.0], [318.0, 192.0], [296.0, 192.0]]], "lines": ["．．．僕達の", "新しい仲間に", "拍手を！！"]}, {"box": [448, 400, 540, 557], "vertical": true, "font_size": 26, "lines_coords": [[[515.0, 403.0], [537.0, 403.0], [537.0, 532.0], [515.0, 532.0]], [[484.0, 403.0], [506.0, 403.0], [506.0, 554.0], [484.0, 554.0]], [[448.0, 400.0], [481.0, 400.0], [481.0, 484.0], [448.0, 484.0]]], "lines": ["そんな君を", "丸ごと平らげ", "たい！！"]}], "img_path": "072.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [921, 87, 979, 268], "vertical": true, "font_size": 25, "lines_coords": [[[946.0, 87.0], [979.0, 87.0], [979.0, 179.0], [946.0, 179.0]], [[921.0, 93.0], [943.0, 93.0], [943.0, 268.0], [921.0, 268.0]]], "lines": ["．．．あ、", "はじめまして！！"]}, {"box": [784, 256, 870, 473], "vertical": true, "font_size": 25, "lines_coords": [[[848.0, 257.0], [870.0, 257.0], [870.0, 473.0], [848.0, 473.0]], [[812.0, 256.0], [839.0, 256.0], [839.0, 448.0], [812.0, 448.0]], [[784.0, 259.0], [806.0, 259.0], [806.0, 434.0], [784.0, 434.0]]], "lines": ["ここではパオパオ", "チャンネル」って", "呼ばれてます！！"]}, {"box": [176, 139, 296, 396], "vertical": true, "font_size": 25, "lines_coords": [[[275.0, 143.0], [296.0, 143.0], [296.0, 370.0], [275.0, 370.0]], [[242.0, 143.0], [264.0, 143.0], [264.0, 396.0], [242.0, 396.0]], [[207.0, 139.0], [234.0, 139.0], [234.0, 334.0], [207.0, 334.0]], [[176.0, 140.0], [203.0, 140.0], [203.0, 348.0], [176.0, 348.0]]], "lines": ["趣味はローティーン", "アイドルの追っかけ！！", "．．．あ、でも一線は", "越えないですよ！？"]}, {"box": [928, 717, 960, 804], "vertical": true, "font_size": 28, "lines_coords": [[[928.0, 717.0], [960.0, 717.0], [960.0, 804.0], [928.0, 804.0]]], "lines": ["．．．ウン、"]}, {"box": [125, 437, 217, 598], "vertical": true, "font_size": 25, "lines_coords": [[[187.0, 440.0], [214.0, 440.0], [217.0, 596.0], [190.0, 596.0]], [[157.0, 442.0], [184.0, 442.0], [184.0, 598.0], [157.0, 598.0]], [[128.0, 437.0], [154.0, 437.0], [151.0, 546.0], [125.0, 546.0]]], "lines": ["楽しく仲よく", "やっていきま", "しょう！！"]}, {"box": [778, 781, 898, 940], "vertical": true, "font_size": 28, "lines_coords": [[[871.0, 782.0], [898.0, 782.0], [898.0, 914.0], [871.0, 914.0]], [[839.0, 784.0], [865.0, 784.0], [865.0, 915.0], [839.0, 915.0]], [[804.0, 781.0], [835.0, 781.0], [835.0, 940.0], [804.0, 940.0]], [[778.0, 785.0], [800.0, 785.0], [800.0, 887.0], [778.0, 887.0]]], "lines": ["君は本当に", "ハキハキと", "喋れるように", "なった．．．"]}, {"box": [898, 1031, 999, 1207], "vertical": true, "font_size": 20, "lines_coords": [[[978.0, 1031.0], [998.0, 1031.0], [998.0, 1173.0], [978.0, 1173.0]], [[951.0, 1032.0], [971.0, 1032.0], [971.0, 1207.0], [951.0, 1207.0]], [[925.0, 1034.0], [946.0, 1034.0], [946.0, 1206.0], [925.0, 1206.0]], [[898.0, 1032.0], [918.0, 1032.0], [918.0, 1195.0], [898.0, 1195.0]]], "lines": ["．．．まさか！！", "僕が変われたのは", "ペガサス楽団長の", "おかげとでも！？"]}, {"box": [656, 1031, 734, 1217], "vertical": true, "font_size": 21, "lines_coords": [[[710.0, 1032.0], [732.0, 1032.0], [732.0, 1217.0], [710.0, 1217.0]], [[682.0, 1032.0], [704.0, 1032.0], [704.0, 1193.0], [682.0, 1193.0]], [[656.0, 1031.0], [676.0, 1031.0], [676.0, 1193.0], [656.0, 1193.0]]], "lines": ["やめてください！！", "これは僕自身の", "努力なんです！！"]}, {"box": [531, 1112, 558, 1242], "vertical": true, "font_size": 26, "lines_coords": [[[531.0, 1112.0], [557.0, 1112.0], [557.0, 1242.0], [531.0, 1242.0]]], "lines": ["．．．お拍手！！"]}, {"box": [110, 763, 232, 984], "vertical": true, "font_size": 24, "lines_coords": [[[204.0, 764.0], [231.0, 764.0], [231.0, 921.0], [204.0, 921.0]], [[171.0, 765.0], [198.0, 765.0], [198.0, 893.0], [171.0, 893.0]], [[142.0, 765.0], [164.0, 765.0], [164.0, 984.0], [142.0, 984.0]], [[110.0, 765.0], [132.0, 765.0], [132.0, 962.0], [110.0, 962.0]]], "lines": ["出会った頃は", "増やす前の", "増えるワカメみたい", "だったのになァ．．．"]}], "img_path": "073.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [907, 445, 964, 664], "vertical": true, "font_size": 24, "lines_coords": [[[935.0, 445.0], [964.0, 445.0], [962.0, 664.0], [934.0, 664.0]], [[907.0, 450.0], [929.0, 450.0], [929.0, 582.0], [907.0, 582.0]]], "lines": ["「エコバック」です。", "こんばんは。"]}, {"box": [789, 659, 876, 843], "vertical": true, "font_size": 24, "lines_coords": [[[848.0, 659.0], [875.0, 659.0], [876.0, 843.0], [850.0, 843.0]], [[818.0, 662.0], [840.0, 662.0], [840.0, 790.0], [818.0, 790.0]], [[789.0, 664.0], [810.0, 664.0], [810.0, 804.0], [789.0, 804.0]]], "lines": ["大学の農学部で", "客員教授を", "やってます。"]}, {"box": [195, 550, 304, 743], "vertical": true, "font_size": 23, "lines_coords": [[[278.0, 550.0], [304.0, 550.0], [303.0, 737.0], [276.0, 737.0]], [[251.0, 553.0], [273.0, 553.0], [273.0, 689.0], [251.0, 689.0]], [[223.0, 551.0], [245.0, 551.0], [245.0, 743.0], [223.0, 743.0]], [[195.0, 553.0], [217.0, 553.0], [217.0, 726.0], [195.0, 726.0]]], "lines": ["ペガサスさんとは", "創作ダンスの", "カルチャースクールで", "知り合いました。"]}, {"box": [940, 1071, 1003, 1156], "vertical": true, "font_size": 32, "lines_coords": [[[967.0, 1071.0], [1003.0, 1073.0], [1000.0, 1134.0], [964.0, 1132.0]], [[940.0, 1076.0], [968.0, 1076.0], [968.0, 1156.0], [940.0, 1156.0]]], "lines": ["ヨイ", "ヨイ！！"]}, {"box": [646, 1043, 674, 1175], "vertical": true, "font_size": 27, "lines_coords": [[[646.0, 1043.0], [673.0, 1043.0], [673.0, 1175.0], [646.0, 1175.0]]], "lines": ["．．．いいね！！"]}, {"box": [146, 781, 253, 968], "vertical": true, "font_size": 23, "lines_coords": [[[228.0, 781.0], [251.0, 781.0], [253.0, 878.0], [229.0, 878.0]], [[201.0, 784.0], [223.0, 784.0], [223.0, 945.0], [201.0, 945.0]], [[171.0, 782.0], [193.0, 782.0], [195.0, 968.0], [173.0, 968.0]], [[146.0, 782.0], [167.0, 782.0], [167.0, 968.0], [146.0, 968.0]]], "lines": ["．．．今日は", "あなたのために", "少しだけ踊らせて", "もらってよくて？"]}, {"box": [453, 1335, 515, 1490], "vertical": true, "font_size": 26, "lines_coords": [[[487.0, 1335.0], [514.0, 1335.0], [514.0, 1489.0], [487.0, 1489.0]], [[456.0, 1337.0], [482.0, 1337.0], [479.0, 1490.0], [453.0, 1490.0]]], "lines": ["さすが僕らの", "マドンナだ．．．"]}], "img_path": "074.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [912, 93, 971, 303], "vertical": true, "font_size": 26, "lines_coords": [[[943.0, 93.0], [971.0, 93.0], [968.0, 260.0], [940.0, 260.0]], [[912.0, 93.0], [939.0, 93.0], [939.0, 303.0], [912.0, 303.0]]], "lines": ["「白ブタ」です。", "ショップ店員です。"]}, {"box": [756, 253, 876, 460], "vertical": true, "font_size": 26, "lines_coords": [[[850.0, 253.0], [876.0, 253.0], [875.0, 448.0], [848.0, 448.0]], [[818.0, 254.0], [842.0, 254.0], [840.0, 409.0], [817.0, 409.0]], [[784.0, 254.0], [810.0, 254.0], [812.0, 460.0], [785.0, 460.0]], [[756.0, 257.0], [778.0, 257.0], [778.0, 432.0], [756.0, 432.0]]], "lines": ["君は、女の子なら", "誰でも素敵な", "魔法が使えるって", "知ってるカナ？"]}, {"box": [864, 615, 953, 834], "vertical": true, "font_size": 25, "lines_coords": [[[931.0, 618.0], [953.0, 618.0], [953.0, 834.0], [931.0, 834.0]], [[895.0, 615.0], [921.0, 615.0], [923.0, 798.0], [896.0, 798.0]], [[864.0, 617.0], [890.0, 617.0], [890.0, 743.0], [864.0, 743.0]]], "lines": ["「乾電池が一本だけ", "余るとちょっと", "困る」です。"]}, {"box": [123, 292, 213, 512], "vertical": true, "font_size": 27, "lines_coords": [[[184.0, 292.0], [210.0, 292.0], [210.0, 473.0], [184.0, 473.0]], [[150.0, 292.0], [182.0, 292.0], [182.0, 504.0], [150.0, 504.0]], [[123.0, 293.0], [145.0, 293.0], [145.0, 512.0], [123.0, 512.0]]], "lines": ["私主催の夏恒例", "パーベキュー大会、", "楽しみにしててね！！"]}, {"box": [707, 737, 829, 943], "vertical": true, "font_size": 25, "lines_coords": [[[801.0, 737.0], [829.0, 737.0], [828.0, 943.0], [800.0, 943.0]], [[771.0, 740.0], [793.0, 740.0], [793.0, 895.0], [771.0, 895.0]], [[737.0, 737.0], [764.0, 737.0], [764.0, 940.0], [737.0, 940.0]], [[707.0, 740.0], [729.0, 740.0], [729.0, 904.0], [707.0, 904.0]]], "lines": ["ウェブデザインの", "仕事しながら", "ミニュミ誌を作っ", "たりしてるよ。"]}, {"box": [892, 1103, 953, 1257], "vertical": true, "font_size": 31, "lines_coords": [[[925.0, 1103.0], [953.0, 1103.0], [948.0, 1246.0], [920.0, 1246.0]], [[892.0, 1107.0], [918.0, 1107.0], [918.0, 1257.0], [892.0, 1257.0]]], "lines": ["「ＬＯＶＥＣ", "無限大」です。"]}, {"box": [106, 785, 229, 1009], "vertical": true, "font_size": 24, "lines_coords": [[[200.0, 785.0], [226.0, 785.0], [226.0, 918.0], [200.0, 918.0]], [[168.0, 785.0], [195.0, 785.0], [195.0, 1009.0], [168.0, 1009.0]], [[139.0, 787.0], [160.0, 787.0], [160.0, 992.0], [139.0, 992.0]], [[107.0, 785.0], [129.0, 785.0], [128.0, 948.0], [106.0, 948.0]]], "lines": ["君とは是非", "オーパーツや未知の", "巨大生物について", "語り合いたい。"]}, {"box": [826, 1315, 925, 1473], "vertical": true, "font_size": 31, "lines_coords": [[[889.0, 1315.0], [925.0, 1315.0], [925.0, 1379.0], [889.0, 1379.0]], [[860.0, 1320.0], [887.0, 1320.0], [887.0, 1473.0], [860.0, 1473.0]], [[826.0, 1318.0], [862.0, 1318.0], [862.0, 1387.0], [826.0, 1387.0]]], "lines": ["現在", "フリーターの", "２６歳。"]}, {"box": [229, 1156, 348, 1337], "vertical": true, "font_size": 23, "lines_coords": [[[326.0, 1160.0], [348.0, 1160.0], [348.0, 1310.0], [326.0, 1310.0]], [[292.0, 1156.0], [318.0, 1156.0], [317.0, 1337.0], [290.0, 1337.0]], [[260.0, 1156.0], [287.0, 1156.0], [287.0, 1337.0], [260.0, 1337.0]], [[229.0, 1157.0], [251.0, 1157.0], [251.0, 1284.0], [229.0, 1284.0]]], "lines": ["こう見えても", "スポーツ全般に", "ちょっと自信が", "あるカナ？"]}, {"box": [134, 1340, 220, 1543], "vertical": true, "font_size": 23, "lines_coords": [[[198.0, 1343.0], [220.0, 1343.0], [220.0, 1468.0], [198.0, 1468.0]], [[165.0, 1342.0], [187.0, 1342.0], [187.0, 1543.0], [165.0, 1543.0]], [[134.0, 1340.0], [156.0, 1340.0], [156.0, 1454.0], [134.0, 1454.0]]], "lines": ["一応水泳で", "国体に出たことも", "あります。"]}], "img_path": "075.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [873, 118, 971, 292], "vertical": true, "font_size": 29, "lines_coords": [[[934.0, 120.0], [968.0, 118.0], [971.0, 215.0], [937.0, 217.0]], [[909.0, 123.0], [937.0, 123.0], [934.0, 292.0], [906.0, 292.0]], [[873.0, 120.0], [906.0, 120.0], [906.0, 226.0], [873.0, 226.0]]], "lines": ["「おしり", "ハンバーガー」", "です．．．"]}, {"box": [759, 245, 851, 453], "vertical": true, "font_size": 29, "lines_coords": [[[825.0, 246.0], [851.0, 246.0], [851.0, 453.0], [825.0, 453.0]], [[792.0, 246.0], [818.0, 246.0], [818.0, 453.0], [792.0, 453.0]], [[759.0, 245.0], [787.0, 245.0], [787.0, 326.0], [759.0, 326.0]]], "lines": ["声優になりたくて", "専門学校に通って", "ます．．．"]}, {"box": [892, 671, 984, 820], "vertical": true, "font_size": 28, "lines_coords": [[[956.0, 671.0], [984.0, 671.0], [981.0, 795.0], [953.0, 795.0]], [[925.0, 675.0], [951.0, 675.0], [948.0, 820.0], [921.0, 820.0]], [[892.0, 676.0], [920.0, 676.0], [920.0, 757.0], [892.0, 757.0]]], "lines": ["「守護天使", "ギボボギギ」", "です！！"]}, {"box": [129, 350, 251, 556], "vertical": true, "font_size": 24, "lines_coords": [[[223.0, 351.0], [250.0, 351.0], [250.0, 553.0], [223.0, 553.0]], [[193.0, 353.0], [215.0, 353.0], [215.0, 556.0], [193.0, 556.0]], [[159.0, 350.0], [185.0, 350.0], [185.0, 467.0], [159.0, 467.0]], [[129.0, 351.0], [151.0, 351.0], [151.0, 478.0], [129.0, 478.0]]], "lines": ["アニメ声でうざい", "かもしれないけど", "地声なの。", "コメンね．．．"]}, {"box": [250, 645, 306, 825], "vertical": true, "font_size": 24, "lines_coords": [[[279.0, 645.0], [306.0, 645.0], [306.0, 800.0], [279.0, 800.0]], [[250.0, 646.0], [271.0, 646.0], [271.0, 825.0], [250.0, 825.0]]], "lines": ["趣味は陶芸！！", "二児の母です！！"]}, {"box": [928, 1101, 957, 1259], "vertical": true, "font_size": 24, "lines_coords": [[[931.0, 1101.0], [957.0, 1101.0], [954.0, 1259.0], [928.0, 1259.0]]], "lines": ["「逆に」です！！"]}, {"box": [125, 859, 276, 1040], "vertical": true, "font_size": 24, "lines_coords": [[[254.0, 860.0], [276.0, 860.0], [276.0, 1039.0], [254.0, 1039.0]], [[220.0, 859.0], [246.0, 859.0], [246.0, 1040.0], [220.0, 1040.0]], [[187.0, 859.0], [210.0, 859.0], [212.0, 1014.0], [189.0, 1014.0]], [[156.0, 859.0], [182.0, 859.0], [182.0, 989.0], [156.0, 989.0]], [[125.0, 859.0], [146.0, 859.0], [146.0, 1007.0], [125.0, 1007.0]]], "lines": ["あなたみたいな", "若い子と友達に", "なれるなんて", "オバちゃん", "嬉しいワァ！！"]}, {"box": [753, 1237, 885, 1426], "vertical": true, "font_size": 24, "lines_coords": [[[865.0, 1239.0], [885.0, 1239.0], [885.0, 1423.0], [865.0, 1423.0]], [[835.0, 1237.0], [862.0, 1237.0], [860.0, 1426.0], [834.0, 1426.0]], [[810.0, 1237.0], [832.0, 1237.0], [829.0, 1379.0], [807.0, 1379.0]], [[781.0, 1237.0], [804.0, 1237.0], [801.0, 1356.0], [778.0, 1356.0]], [[753.0, 1237.0], [779.0, 1237.0], [779.0, 1381.0], [753.0, 1381.0]]], "lines": ["昔は族てやんちゃ", "やってたんスけど", "今は宅配業で", "超安全運転", "やってます！！"]}, {"box": [175, 1135, 262, 1310], "vertical": true, "font_size": 25, "lines_coords": [[[240.0, 1135.0], [262.0, 1135.0], [262.0, 1310.0], [240.0, 1310.0]], [[206.0, 1135.0], [232.0, 1135.0], [232.0, 1290.0], [206.0, 1290.0]], [[175.0, 1135.0], [201.0, 1135.0], [201.0, 1239.0], [175.0, 1239.0]]], "lines": ["ここにいる奴ら", "みんなイイ奴", "なんで！！"]}, {"box": [145, 1342, 203, 1525], "vertical": true, "font_size": 25, "lines_coords": [[[176.0, 1342.0], [203.0, 1342.0], [203.0, 1448.0], [176.0, 1448.0]], [[145.0, 1345.0], [171.0, 1345.0], [171.0, 1525.0], [145.0, 1525.0]]], "lines": ["しくよろ", "ベイベーです！！"]}], "img_path": "076.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [870, 81, 984, 331], "vertical": true, "font_size": 26, "lines_coords": [[[962.0, 85.0], [984.0, 85.0], [984.0, 325.0], [962.0, 325.0]], [[934.0, 87.0], [956.0, 87.0], [956.0, 265.0], [934.0, 265.0]], [[903.0, 85.0], [929.0, 85.0], [929.0, 331.0], [903.0, 331.0]], [[870.0, 81.0], [904.0, 81.0], [904.0, 151.0], [870.0, 151.0]]], "lines": ["「スウィートフリティー", "ロンリーハート", "もふもふお兄ちゃま」", "です。"]}, {"box": [154, 207, 243, 410], "vertical": true, "font_size": 24, "lines_coords": [[[221.0, 210.0], [243.0, 210.0], [243.0, 387.0], [221.0, 387.0]], [[187.0, 207.0], [214.0, 207.0], [214.0, 410.0], [187.0, 410.0]], [[157.0, 207.0], [179.0, 207.0], [176.0, 364.0], [154.0, 364.0]]], "lines": ["ペガサス君とは", "大学以来、旧知の", "仲なんだが．．．"]}, {"box": [785, 357, 876, 537], "vertical": true, "font_size": 26, "lines_coords": [[[850.0, 357.0], [876.0, 357.0], [876.0, 537.0], [850.0, 537.0]], [[820.0, 359.0], [842.0, 359.0], [842.0, 535.0], [820.0, 535.0]], [[785.0, 357.0], [812.0, 357.0], [812.0, 496.0], [785.0, 496.0]]], "lines": ["某有名進学塾で", "数学の塾講師を", "やってんだ。"]}, {"box": [106, 479, 246, 710], "vertical": true, "font_size": 24, "lines_coords": [[[220.0, 481.0], [246.0, 481.0], [246.0, 637.0], [220.0, 637.0]], [[190.0, 481.0], [217.0, 481.0], [217.0, 687.0], [190.0, 687.0]], [[164.0, 482.0], [185.