 2203.0], [7381.0, 2203.0]]], "lines": ["おやすみプンフンソーー、", "お野いにお", "ソラニン全２巻", "えーいーの浅野いにお", "原秀見", "ほしのふるまち全７巻", "はじいかるより、エノ＠１ボンドの福音。全４巷", "高橋留美子", "「ハンドングロープのローコトー診療所、１〜５０巻", "山田さん", "長尾諫一", "おしゃれ手帖，全１０巻", "ＧｏｏｇｌｅリューキャーＰＡＮＥＯＮＥコーニングラウンド、全部を一安部康二ノ柿崎正滋", "ゆうきまさ", "Ｆａｎｄｏｗｓは鉄腕バーティー全２０巻カーキャンペーン", "室積光ノ猪熊しのふ", "都立水商！全２２巻", "黒丸ノ夏原", "クロサギ、全２０巻", "クロジャ・エール１キガミ・ＴｈｅＣｌｉｔｍａｔｅｌｉｎｔ－１〜日巻ーー間新元期", "「ヤッシー．．．。」という、土竜（モグラ）の頃、「一般港」", "一高橋のぼる", "上阜超無気力戦隊シャバ「１０００ファイブ全日巻一佐藤まさき", "石渡治", "Ｏｄｄｅ－オッス．．．＋７巻", "しかしＳ－バンベーキーをさらんぼジトロームなの原則に全力を", "タナトスター・ローローンのタナーストレードの本、全日巻ーーー竹原慎二〈落合裕", "とめはねっ！？鈴里高校教道部－", "このコープ巻一河合克服", "ビーチスターズ、全て巻", "森尾正博", "ビーティスターへエノ宮もう時は初から放置。全日巻。木根ヲサム。", "美晴♥ライジング全５巻", "大谷じる", "夫婦・イージス、全日巻", "あんころ。納君が下記映画を", "．．．木秋重", "ＧＯ－ＯＮ・全４巻", "しこし、エーザードライブ・ア・ライフ・"]}, {"box": [7269, 2300, 8466, 2503], "vertical": false, "font_size": 223, "lines_coords": [[[7269.0, 2280.0], [8466.0, 2280.0], [8466.0, 2523.0], [7269.0, 2523.0]]], "lines": ["「プンプン」グッズ・"]}, {"box": [7295, 2565, 8320, 2856], "vertical": false, "font_size": 107.5, "lines_coords": [[[7295.0, 2565.0], [8320.0, 2565.0], [8320.0, 2685.0], [7295.0, 2685.0]], [[7355.0, 2761.0], [7970.0, 2761.0], [7970.0, 2856.0], [7355.0, 2856.0]]], "lines": ["続々大好評発売", "詳しくは、下記サイトへ！"]}, {"box": [7270, 2821, 8373, 3505], "vertical": false, "font_size": 114, "lines_coords": [[[7270.0, 2846.0], [8286.0, 2846.0], [8286.0, 3079.0], [7270.0, 3079.0]], [[7295.0, 3025.0], [7799.0, 3025.0], [7799.0, 3131.0], [7295.0, 3131.0]], [[7304.0, 3076.0], [8038.0, 3076.0], [8038.0, 3208.0], [7304.0, 3208.0]], [[7304.0, 3196.0], [8158.0, 3196.0], [8158.0, 3302.0], [7304.0, 3302.0]], [[7295.0, 3247.0], [7825.0, 3265.0], [7825.0, 3370.0], [7295.0, 3353.0]], [[7287.0, 3342.0], [8235.0, 3350.0], [8235.0, 3456.0], [7287.0, 3447.0]], [[7329.0, 3436.0], [8004.0, 3436.0], [8004.0, 3515.0], [7329.0, 3515.0]]], "lines": ["しかし、今は、「誰かイヤ・●タイプにデッカーズも」やはりバイクのために「Ａｎｄｒｏｎｄ」が開始してみました。", "●ビームスＴＣＴシャツ", "●ビームスＴＶＴシャツ）ｈｔｔｐ：／／ｗｗｗＷｉｎｄｏｗｓｔａｍａｎｓ．ｃｏ！！", "●ムービック（ボーチ）がススコット）", "●ムービック（ポーチ指定時）／／ｗｗｗＷｉｎｄｏｒｉｃ．", "●コスパイはいくるみ「シャツキーホルター", "こんな人はいくるメールアップですが、サロンバルを作っているので、"]}], "img_path": "003.png"}, {"version": "0.2.0-beta.6", "img_width": 5832, "img_height": 2400, "blocks": [{"box": [1156, 1522, 2796, 1653], "vertical": false, "font_size": 131, "lines_coords": [[[1156.0, 1522.0], [2796.0, 1522.0], [2796.0, 1653.0], [1156.0, 1653.0]]], "lines": ["女優水川あさみさんも愛読！！"]}, {"box": [1981, 1060, 2662, 1436], "vertical": true, "font_size": 181, "lines_coords": [[[2579.0, 1128.0], [2659.0, 1128.0], [2659.0, 1436.0], [2579.0, 1436.0]], [[2431.0, 1123.0], [2534.0, 1123.0], [2534.0, 1413.0], [2431.0, 1413.0]], [[2175.0, 1202.0], [2249.0, 1202.0], [2249.0, 1276.0], [2175.0, 1276.0]], [[1981.0, 1088.0], [2448.0, 1060.0], [2466.0, 1345.0], [1999.0, 1373.0]]], "lines": ["おやすみ", "プンプン", "野", "●浅野ひとえ"]}, {"box": [85, 1583, 1055, 2254], "vertical": false, "font_size": 84, "lines_coords": [[[837.0, 2057.0], [960.0, 2148.0], [915.0, 2222.0], [792.0, 2131.0]]], "lines": ["◆"]}, {"box": [1167, 1707, 2596, 2344], "vertical": false, "font_size": 86, "lines_coords": [[[1173.0, 1721.0], [2249.0, 1727.0], [2249.0, 1824.0], [1173.0, 1818.0]], [[1178.0, 1807.0], [2175.0, 1824.0], [2175.0, 1904.0], [1178.0, 1886.0]], [[1167.0, 1938.0], [2266.0, 1949.0], [2266.0, 2029.0], [1167.0, 2018.0]], [[1173.0, 2023.0], [1828.0, 2040.0], [1828.0, 2103.0], [1173.0, 2086.0]], [[1178.0, 2103.0], [1742.0, 2114.0], [1742.0, 2194.0], [1178.0, 2183.0]], [[1213.0, 2263.0], [2152.0, 2274.0], [2152.0, 2337.0], [1213.0, 2325.0]], [[2192.0, 2063.0], [2505.0, 2063.0], [2505.0, 2206.0], [2192.0, 2206.0]]], "lines": ["中学生の時、同じクラスにプシフシに似た", "子がいて、私はその子の事が好きでいた。", "プラグショ読むとなんだから、青くてジ食くそのなので、", "貴様のいい気持ちちになります。", "ソワソワドキドキします。", "でね、私、ランジンの事が好きです！！", "「この"]}, {"box": [2836, 1704, 2978, 2337], "vertical": true, "font_size": 65.5, "lines_coords": [[[2921.0, 1704.0], [2978.0, 1704.0], [2978.0, 2246.0], [2921.0, 2246.0]], [[2836.0, 1710.0], [2910.0, 1710.0], [2933.0, 2337.0], [2859.0, 2337.0]]], "lines": ["大人気御．．．", "累計「万部突破！！」"]}, {"