0.0]]], "lines": ["よーーッ", "平ちゃーん！！"]}, {"box": [146, 1315, 211, 1495], "vertical": true, "font_size": 27, "lines_coords": [[[182.0, 1317.0], [209.0, 1317.0], [209.0, 1495.0], [182.0, 1495.0]], [[150.0, 1315.0], [176.0, 1315.0], [173.0, 1446.0], [146.0, 1446.0]]], "lines": ["聞いてください", "『居酒屋』！！"]}], "img_path": "208.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [962, 85, 984, 237], "vertical": true, "font_size": 23, "lines_coords": [[[962.0, 85.0], [984.0, 85.0], [984.0, 237.0], [962.0, 237.0]]], "lines": ["．．．梓ちゃん？"]}, {"box": [817, 279, 953, 514], "vertical": true, "font_size": 23, "lines_coords": [[[931.0, 279.0], [953.0, 279.0], [953.0, 420.0], [931.0, 420.0]], [[900.0, 279.0], [926.0, 279.0], [926.0, 421.0], [900.0, 421.0]], [[873.0, 282.0], [895.0, 282.0], [895.0, 492.0], [873.0, 492.0]], [[845.0, 281.0], [867.0, 281.0], [867.0, 514.0], [845.0, 514.0]], [[817.0, 279.0], [839.0, 279.0], [839.0, 428.0], [817.0, 428.0]]], "lines": ["元気なんじゃ", "ないのー？", "最近会ってないけど", "大学入って一人暮らし", "始めたってさ。"]}, {"box": [129, 231, 264, 400], "vertical": true, "font_size": 23, "lines_coords": [[[242.0, 232.0], [264.0, 232.0], [264.0, 392.0], [242.0, 392.0]], [[215.0, 234.0], [237.0, 234.0], [237.0, 393.0], [215.0, 393.0]], [[187.0, 232.0], [209.0, 232.0], [209.0, 393.0], [187.0, 393.0]], [[159.0, 232.0], [181.0, 232.0], [181.0, 373.0], [159.0, 373.0]], [[129.0, 231.0], [151.0, 231.0], [151.0, 400.0], [129.0, 400.0]]], "lines": ["蟹江があたしを", "差し置いて就職", "しやがったから", "近況聞く機会", "あんまなくてね。"]}, {"box": [126, 496, 235, 657], "vertical": true, "font_size": 23, "lines_coords": [[[214.0, 498.0], [235.0, 498.0], [235.0, 650.0], [214.0, 650.0]], [[184.0, 496.0], [207.0, 496.0], [206.0, 657.0], [182.0, 657.0]], [[156.0, 498.0], [179.0, 498.0], [176.0, 635.0], [153.0, 635.0]], [[126.0, 496.0], [154.0, 496.0], [154.0, 582.0], [126.0, 582.0]]], "lines": ["．．．あ、蟹江って", "梓ちゃんの姉の", "メガネデフの", "ほうね。"]}, {"box": [900, 704, 975, 1007], "vertical": true, "font_size": 33, 