2, "lines_coords": [[[671.0, 1357.0], [693.0, 1357.0], [693.0, 1482.0], [671.0, 1482.0]], [[639.0, 1354.0], [660.0, 1354.0], [662.0, 1540.0], [640.0, 1540.0]]], "lines": ["理由なんて", "特にありません。"]}, {"box": [346, 1354, 470, 1534], "vertical": true, "font_size": 29, "lines_coords": [[[440.0, 1357.0], [467.0, 1357.0], [467.0, 1507.0], [440.0, 1507.0]], [[404.0, 1354.0], [439.0, 1354.0], [439.0, 1445.0], [404.0, 1445.0]], [[375.0, 1354.0], [401.0, 1354.0], [404.0, 1534.0], [378.0, 1534.0]], [[346.0, 1356.0], [373.0, 1356.0], [373.0, 1520.0], [346.0, 1520.0]]], "lines": ["ただとにかく", "闇雲に、", "気分かとっても", "だるいのです。"]}], "img_path": "091.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [565, 120, 656, 404], "vertical": true, "font_size": 26, "lines_coords": [[[629.0, 120.0], [656.0, 120.0], [654.0, 404.0], [628.0, 404.0]], [[598.0, 120.0], [625.0, 120.0], [621.0, 403.0], [595.0, 403.0]], [[565.0, 120.0], [592.0, 120.0], [592.0, 381.0], [565.0, 381.0]]], "lines": ["もし説明を求められれば", "搾取されたくないだとか", "花粉症がどうもだとか"]}, {"box": [445, 120, 534, 404], "vertical": true, "font_size": 26, "lines_coords": [[[507.0, 121.0], [534.0, 121.0], [534.0, 328.0], [507.0, 328.0]], [[476.0, 120.0], [503.0, 120.0], [501.0, 404.0], [475.0, 404.0]], [[445.0, 121.0], [467.0, 121.0], [467.0, 389.0], [445.0, 389.0]]], "lines": ["屁理屈で良ければ", "十でも百でも一千万でも", "言ってやれる所存です。"]}, {"box": [595, 1285, 656, 1527], "vertical": true, "font_size": 28, "lines_coords": [[[623.0, 1285.0], [656.0, 1285.0], [656.0, 1368.0], [623.0, 1368.0]], [[596.0, 1289.0], [618.0, 1289.0], [618.0, 1520.0], [596.0, 1520.0]]], "lines": ["．．．けど", "そういう人のことを"]}, {"box": [425, 1287, 484, 1477], "vertical": true, "font_size": 22, "lines_coords": [[[459.0, 1289.0], [481.0, 1289.0], [481.0, 1464.0], [459.0, 1464.0]], [[428.0, 1290.0], [450.0, 1290.0], [450.0, 1471.0], [428.0, 1471.0]]], "lines": ["世間ではクスと", "呼ぶのでしょう。"]}], "img_path": "092.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [910, 373, 998, 554], "vertical": true, "font_size": 25, "lines_coords": [[[976.0, 378.0], [998.0, 378.0], [998.0, 531.0], [976.0, 531.0]], [[945.0, 379.0], [967.0, 379.0], [967.0, 554.0], [945.0, 554.0]], [[914.0, 373.0], [940.0, 373.0], [937.0, 482.0], [910.0, 482.0]]], "lines": ["ウオォォォオ", "オノッティ～～", "～～ッ！！"]}, {"box": [867, 614, 928, 746], "vertical": true, "font_size": 25, "lines_coords": [[[901.0, 614.0], [928.0, 614.0], [928.0, 745.0], [901.0, 745.0]], [[870.0, 614.0], [896.0, 614.0], [893.0, 746.0], [867.0, 746.0]]], "lines": ["テメェ畜生", "この野郎！！"]}, {"box": [532, 439, 596, 550], "vertical": true, "font_size": 34, "lines_coords": [[[557.0, 439.0], [596.0, 439.0], [596.0, 528.0], [557.0, 528.0]], [[532.0, 445.0], [560.0, 445.0], [560.0, 550.0], [532.0, 550.0]]], "lines": ["ジーク", "ジオン！！"]}, {"box": [160, 573, 251, 728], "vertical": true, "font_size": 27, "lines_coords": [[[225.0, 573.0], [251.0, 573.0], [251.0, 726.0], [225.0, 726.0]], [[193.0, 573.0], [220.0, 573.0], [220.0, 728.0], [193.0, 728.0]], [[160.0, 575.0], [187.0, 575.0], [187.0, 704.0], [160.0, 704.0]]], "lines": ["卒業式以来の", "ご無沙汰じゃ", "ねーかッ！！"]}, {"box": [928, 1048, 1012, 1210], "vertical": true, "font_size": 26, "lines_coords": [[[979.0, 1048.0], [1012.0, 1048.0], [1012.0, 1131.0], [979.0, 1131.0]], [[954.0, 1050.0], [978.0, 1050.0], [976.0, 1210.0], [953.0, 1210.0]], [[928.0, 1050.0], [950.0, 1050.0], [950.0, 1142.0], [928.0, 1142.0]]], "lines": ["．．．は、", "毎日散歩ばかり", "してる！？"]}, {"box": [873, 1030, 901, 1065], "vertical": true, "font_size": 28, "lines_coords": [[[873.0, 1030.0], [901.0, 1030.0], [901.0, 1065.0], [873.0, 1065.0]]], "lines": ["４"]}, {"box": [582, 1037, 662, 1232], "vertical": true, "font_size": 21, "lines_coords": [[[640.0, 1040.0], [662.0, 1040.0], [662.0, 1201.0], [640.0, 1201.0]], [[612.0, 1039.0], [634.0, 1039.0], [634.0, 1232.0], [612.0, 1232.0]], [[582.0, 1037.0], [604.0, 1037.0], [604.0, 1198.0], [582.0, 1198.0]]], "lines": ["．．．俺なんて大学", "入ってから、陰茎の", "乾く暇が無い！！"]}, {"box": [115, 795, 206, 953], "vertical": true, "font_size": 27, "lines_coords": [[[179.0, 795.0], [206.0, 795.0], [203.0, 951.0], [176.0, 951.0]], [[146.0, 796.0], [173.0, 796.0], [173.0, 953.0], [146.0, 953.0]], [[115.0, 796.0], [142.0, 796.0], [142.0, 901.0], [115.0, 901.0]]], "lines": ["元気だった？", "顔色悪いけど", "大丈夫？"]}, {"box": [123, 1089, 231, 1253], "vertical": true, "font_size": 23, "lines_coords": [[[209.0, 1093.0], [231.0, 1093.0], [231.0, 1229.0], [209.0, 1229.0]], [[179.0, 1090.0], [203.0, 1090.0], [201.0, 1253.0], [178.0, 1253.0]], [[153.0, 1090.0], [175.0, 1090.0], [175.0, 1251.0], [153.0, 1251.0]], [[123.0, 1089.0], [150.0, 1089.0], [150.0, 1185.0], [123.0, 1185.0]]], "lines": ["オナ禁なんて", "さっさとやめて", "悟りは閉じよう", "ぜー！？"]}, {"box": [685, 1312, 766, 1495], "vertical": true, "font_size": 22, "lines_coords": [[[740.0, 1312.0], [762.0, 1312.0], [765.0, 1454.0], [743.0, 1454.0]], [[714.0, 1314.0], [735.0, 1314.0], [735.0, 1495.0], [714.0, 1495.0]], [[685.0, 1312.0], [707.0, 1312.0], [709.0, 1453.0], [687.0, 1453.0]]], "lines": ["なんだよ～～", "おじーちゃんじゃ", "ねーかよっ！！"]}, {"box": [467, 1117, 540, 1289], "vertical": true, "font_size": 21, "lines_coords": [[[520.0, 1117.0], [540.0, 1117.0], [540.0, 1289.0], [520.0, 1289.0]], [[495.0, 1117.0], [515.0, 1117.0], [515.0, 1240.0], [495.0, 1240.0]], [[468.0, 1117.0], [490.0, 1117.0], [489.0, 1262.0], [467.0, 1262.0]]], "lines": ["．．．という希望だけは", "捨てずに日々", "頑張っている！！"]}, {"box": [107, 1326, 243, 1560], "vertical": true, "font_size": 23, "lines_coords": [[[221.0, 1329.0], [243.0, 1329.0], [243.0, 1490.0], [221.0, 1490.0]], [[192.0, 1326.0], [218.0, 1326.0], [218.0, 1560.0], [192.0, 1560.0]], [[165.0, 1329.0], [187.0, 1329.0], [187.0, 1492.0], [165.0, 1492.0]], [[137.0, 1328.0], [159.0, 1328.0], [159.0, 1557.0], [137.0, 1557.0]], [[107.0, 1328.0], [129.0, 1328.0], [129.0, 1537.0], [107.0, 1537.0]]], "lines": ["せっかくバイト", "誘ってやったんだから", "ついでにイイ女", "見つけてギャシギャン", "言わせちゃおうぜ！！"]}], "img_path": "093.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [428, 117, 467, 210], "vertical": true, "font_size": 33, "lines_coords": [[[428.0, 118.0], [464.0, 117.0], [467.0, 209.0], [431.0, 210.0]]], "lines": ["．．．あっ、"]}, {"box": [339, 170, 401, 304], "vertical": true, "font_size": 33, "lines_coords": [[[367.0, 170.0], [401.0, 170.0], [401.0, 256.0], [367.0, 256.0]], [[339.0, 171.0], [367.0, 171.0], [367.0, 304.0], [339.0, 304.0]]], "lines": ["すいま", "せーーん！！"]}, {"box": [78, 126, 212, 314], "vertical": true, "font_size": 21, "lines_coords": [[[189.0, 126.0], [210.0, 126.0], [210.0, 220.0], [189.0, 220.0]], [[160.0, 128.0], [182.0, 128.0], [182.0, 312.0], [160.0, 312.0]], [[129.0, 126.0], [151.0, 126.0], [151.0, 270.0], [129.0, 270.0]], [[104.0, 129.0], [126.0, 129.0], [126.0, 314.0], [104.0, 314.0]], [[78.0, 128.0], [98.0, 128.0], [98.0, 314.0], [78.0, 314.0]]], "lines": ["目の前で", "反復横跳びしてる", "人がいる場合", "何回カウントする", "べきでしょうか？"]}, {"box": [879, 437, 1014, 625], "vertical": true, "font_size": 22, "lines_coords": [[[992.0, 443.0], [1012.0, 443.0], [1012.0, 578.0], [992.0, 578.0]], [[960.0, 437.0], [987.0, 437.0], [984.0, 579.0], [957.0, 579.0]], [[934.0, 437.0], [954.0, 437.0], [954.0, 621.0], [934.0, 621.0]], [[907.0, 440.0], [929.0, 440.0], [929.0, 625.0], [907.0, 625.0]], [[879.0, 440.0], [901.0, 440.0], [901.0, 589.0], [879.0, 589.0]]], "lines": ["．．．え〜〜ては", "通過した人を", "見逃さないように", "しっかりカウント", "してください。"]}, {"box": [479, 542, 562, 682], "vertical": true, "font_size": 24, "lines_coords": [[[535.0, 542.0], [562.0, 542.0], [562.0, 682.0], [535.0, 682.0]], [[509.0, 543.0], [531.0, 543.0], [531.0, 660.0], [509.0, 660.0]], [[479.0, 543.0], [501.0, 543.0], [504.0, 660.0], [482.0, 660.0]]], "lines": ["．．．以上、何か", "質問ある方", "いますか？"]}, {"box": [192, 521, 267, 665], "vertical": true, "font_size": 22, "lines_coords": [[[245.0, 557.0], [264.0, 557.0], [264.0, 585.0], [245.0, 585.0]], [[240.0, 523.0], [267.0, 523.0], [267.0, 554.0], [240.0, 554.0]], [[217.0, 521.0], [239.0, 521.0], [239.0, 665.0], [217.0, 665.0]], [[192.0, 521.0], [214.0, 521.0], [214.0, 654.0], [192.0, 654.0]]], "lines": ["―", "えー", "それでは皆さん", "所定の位置へ、"]}, {"box": [100, 560, 148, 709], "vertical": true, "font_size": 22, "lines_coords": [[[126.0, 560.0], [148.0, 560.0], [148.0, 656.0], [126.0, 656.0]], [[100.0, 560.0], [121.0, 560.0], [121.0, 709.0], [100.0, 709.0]]], "lines": ["よろしく", "お願いします。"]}, {"box": [617, 1361, 644, 1499], "vertical": true, "font_size": 26, "lines_coords": [[[617.0, 1364.0], [643.0, 1364.0], [643.0, 1492.0], [617.0, 1492.0]]], "lines": ["今日もまた"]}, {"box": [423, 1360, 516, 1539], "vertical": true, "font_size": 23, "lines_coords": [[[489.0, 1364.0], [510.0, 1364.0], [510.0, 1537.0], [489.0, 1537.0]], [[457.0, 1364.0], [479.0, 1364.0], [479.0, 1487.0], [457.0, 1487.0]], [[423.0, 1360.0], [450.0, 1360.0], [450.0, 1496.0], [423.0, 1496.0]]], "lines": ["たくさんの人が", "通り過ぎて", "ゆきました。"]}], "img_path": "094.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [990, 93, 1014, 131], "vertical": true, "font_size": 23, "lines_coords": [[[990.0, 93.0], [1014.0, 93.0], [1014.0, 131.0], [990.0, 131.0]]], "lines": ["まー"]}, {"box": [879, 248, 987, 412], "vertical": true, "font_size": 23, "lines_coords": [[[965.0, 251.0], [987.0, 251.0], [987.0, 409.0], [965.0, 409.0]], [[937.0, 251.0], [959.0, 251.0], [959.0, 412.0], [937.0, 412.0]], [[907.0, 248.0], [929.0, 248.0], [929.0, 410.0], [907.0, 410.0]], [[879.0, 248.0], [906.0, 248.0], [906.0, 346.0], [879.0, 346.0]]], "lines": ["オノッティーの", "人生観に口出し", "する気はないん", "だが．．．"]}, {"box": [218, 105, 299, 278], "vertical": true, "font_size": 81, "lines_coords": [[[218.0, 105.0], [299.0, 105.0], [299.0, 278.0], [218.0, 278.0]]], "lines": ["お袋さんの貯金を喰い潰す生活って心苦しくねーかい？"]}, {"box": [215, 98, 295, 287], "vertical": true, "font_size": 22, "lines_coords": [[[273.0, 101.0], [295.0, 101.0], [295.0, 285.0], [273.0, 285.0]], [[245.0, 101.0], [267.0, 101.0], [267.0, 285.0], [245.0, 285.0]], [[215.0, 98.0], [237.0, 98.0], [237.0, 287.0], [215.0, 287.0]]], "lines": ["お袋さんの貯金を", "喰い潰す生活って", "心苦しくねーかい？"]}, {"box": [663, 659, 759, 867], "vertical": true, "font_size": 29, "lines_coords": [[[726.0, 659.0], [759.0, 659.0], [759.0, 740.0], [726.0, 740.0]], [[696.0, 662.0], [723.0, 662.0], [723.0, 867.0], [696.0, 867.0]], [[665.0, 660.0], [692.0, 660.0], [692.0, 792.0], [665.0, 792.0]]], "lines": ["きっと", "通り過ぎていった", "人の中には"]}, {"box": [562, 656, 628, 817], "vertical": true, "font_size": 34, "lines_coords": [[[598.0, 659.0], [626.0, 659.0], [628.0, 812.0], [600.0, 812.0]], [[562.0, 656.0], [601.0, 656.0], [601.0, 748.0], [562.0, 748.0]]], "lines": ["重大な家庭の", "事情や、"]}, {"box": [503, 660, 529, 820], "vertical": true, "font_size": 26, "lines_coords": [[[503.0, 660.0], [529.0, 660.0], [529.0, 820.0], [503.0, 820.0]]], "lines": ["深刻な病気や、"]}, {"box": [310, 659, 465, 852], "vertical": true, "font_size": 27, "lines_coords": [[[439.0, 659.0], [465.0, 659.0], [464.0, 840.0], [437.0, 840.0]], [[406.0, 660.0], [434.0, 660.0], [431.0, 815.0], [403.0, 815.0]], [[375.0, 660.0], [401.0, 660.0], [401.0, 840.0], [375.0, 840.0]], [[342.0, 660.0], [368.0, 660.0], [368.0, 790.0], [342.0, 790.0]], [[310.0, 660.0], [337.0, 660.0], [337.0, 851.0], [310.0, 851.0]]], "lines": ["とり返しのつか", "ない罪悪感に", "心を曇らせてる", "人もいたに", "違いありません。"]}, {"box": [159, 337, 237, 523], "vertical": true, "font_size": 22, "lines_coords": [[[215.0, 337.0], [237.0, 337.0], [237.0, 451.0], [215.0, 451.0]], [[187.0, 337.0], [209.0, 337.0], [209.0, 521.0], [187.0, 521.0]], [[159.0, 337.0], [181.0, 337.0], [181.0, 523.0], [159.0, 523.0]]], "lines": ["俺のように", "自分で部屋借りて", "たった一人で生活"]}, {"box": [104, 337, 238, 550], "vertical": true, "font_size": 22, "lines_coords": [[[131.0, 337.0], [153.0, 337.0], [153.0, 550.0], [131.0, 550.0]], [[104.0, 337.0], [125.0, 337.0], [125.0, 498.0], [104.0, 498.0]]], "lines": ["してたもれ！！きっと", "人生変わるぜ？"]}, {"box": [976, 864, 998, 1010], "vertical": true, "font_size": 28, "lines_coords": [[[976.0, 864.0], [998.0, 864.0], [998.0, 1010.0], [976.0, 1010.0]]], "lines": ["．．．ムヒョッ！！"]}, {"box": [860, 1004, 950, 1171], "vertical": true, "font_size": 28, "lines_coords": [[[912.0, 1004.0], [950.0, 1004.0], [950.0, 1065.0], [912.0, 1065.0]], [[893.0, 1014.0], [914.0, 1014.0], [914.0, 1171.0], [893.0, 1171.0]], [[860.0, 1010.0], [889.0, 1010.0], [889.0, 1084.0], [860.0, 1084.0]]], "lines": ["極上", "モッコリギャル", "発見！！"]}, {"box": [182, 921, 264, 1112], "vertical": true, "font_size": 23, "lines_coords": [[[237.0, 923.0], [264.0, 923.0], [264.0, 1017.0], [237.0, 1017.0]], [[210.0, 921.0], [231.0, 921.0], [231.0, 1104.0], [210.0, 1104.0]], [[182.0, 921.0], [203.0, 921.0], [203.0, 1112.0], [182.0, 1112.0]]], "lines": ["．．．よし！！", "あのコには特別に", "２点あげちゃおう！！"]}, {"box": [740, 1368, 765, 1533], "vertical": true, "font_size": 22, "lines_coords": [[[740.0, 1370.0], [762.0, 1370.0], [762.0, 1526.0], [740.0, 1526.0]]], "lines": ["．．．それなのに"]}, {"box": [601, 1367, 693, 1549], "vertical": true, "font_size": 27, "lines_coords": [[[667.0, 1367.0], [693.0, 1367.0], [689.0, 1548.0], [662.0, 1548.0]], [[634.0, 1368.0], [660.0, 1368.0], [659.0, 1546.0], [632.0, 1546.0]], [[601.0, 1370.0], [628.0, 1370.0], [628.0, 1506.0], [601.0, 1506.0]]], "lines": ["理由もわからず", "もやもやしてる", "自分なんて。"]}, {"box": [429, 1367, 556, 1536], "vertical": true, "font_size": 28, "lines_coords": [[[529.0, 1367.0], [556.0, 1367.0], [556.0, 1501.0], [529.0, 1501.0]], [[493.0, 1367.0], [526.0, 1367.0], [526.0, 1476.0], [493.0, 1476.0]], [[464.0, 1368.0], [490.0, 1368.0], [490.0, 1496.0], [464.0, 1496.0]], [[429.0, 1368.0], [456.0, 1368.0], [459.0, 1534.0], [432.0, 1534.0]]], "lines": ["．．．いやいや、", "それ以上", "考えるのは", "止しましょう。"]}, {"box": [156, 1142, 209, 1282], "vertical": true, "font_size": 23, "lines_coords": [[[187.0, 1143.0], [209.0, 1143.0], [209.0, 1282.0], [187.0, 1282.0]], [[157.0, 1142.0], [179.0, 1142.0], [178.0, 1282.0], [156.0, 1282.0]]], "lines": ["両脇の二人は", "半人前だから"]}, {"box": [129, 1139, 212, 1308], "vertical": true, "font_size": 22, "lines_coords": [[[131.0, 1145.0], [153.0, 1145.0], [153.0, 1306.0], [131.0, 1306.0]]], "lines": ["二人で１点ね！！"]}, {"box": [296, 1369, 388, 1548], "vertical": true, "font_size": 25, "lines_coords": [[[360.0, 1370.0], [387.0, 1370.0], [387.0, 1521.0], [360.0, 1521.0]], [[328.0, 1370.0], [354.0, 1370.0], [354.0, 1548.0], [328.0, 1548.0]], [[298.0, 1373.0], [320.0, 1373.0], [320.0, 1532.0], [298.0, 1532.0]]], "lines": ["今はとにかく", "腑抜けのふりが", "一番なのです。"]}], "img_path": "095.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [920, 67, 1000, 282], "vertical": true, "font_size": 28, "lines_coords": [[[957.0, 67.0], [996.0, 67.0], [1000.0, 245.0], [960.0, 245.0]], [[920.0, 68.0], [953.0, 68.0], [953.0, 282.0], [920.0, 282.0]]], "lines": ["フンンギィ", "ヤアァアッ！！"]}, {"box": [779, 270, 900, 453], "vertical": true, "font_size": 28, "lines_coords": [[[878.0, 273.0], [900.0, 273.0], [900.0, 381.0], [878.0, 381.0]], [[845.0, 270.0], [871.0, 270.0], [868.0, 453.0], [842.0, 453.0]], [[812.0, 271.0], [839.0, 271.0], [839.0, 428.0], [812.0, 428.0]], [[781.0, 273.0], [804.0, 273.0], [803.0, 451.0], [779.0, 451.0]]], "lines": ["暇だ暇だ", "暇過ぎて何かが", "吹きこぼれて", "しまいそうだ！！"]}, {"box": [165, 125, 226, 309], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 128.0], [226.0, 128.0], [226.0, 309.0], [200.0, 309.0]], [[168.0, 125.0], [195.0, 125.0], [192.0, 282.0], [165.0, 282.0]]], "lines": ["オノッティング", "よォオ～～～！！"]}, {"box": [868, 540, 890, 695], "vertical": true, "font_size": 22, "lines_coords": [[[868.0, 540.0], [890.0, 540.0], [890.0, 695.0], [868.0, 695.0]]], "lines": ["．．．けどなぜか"]}, {"box": [682, 539, 839, 745], "vertical": true, "font_size": 28.8, "lines_coords": [[[812.0, 540.0], [839.0, 540.0], [839.0, 693.0], [812.0, 693.0]], [[779.0, 540.0], [807.0, 540.0], [807.0, 651.0], [779.0, 651.0]], [[750.0, 539.0], [776.0, 539.0], [776.0, 720.0], [750.0, 720.0]], [[717.0, 539.0], [745.0, 539.0], [743.0, 745.0], [715.0, 745.0]], [[682.0, 540.0], [717.0, 540.0], [717.0, 632.0], [682.0, 632.0]]], "lines": ["すがるような", "気持ちで、", "行きかう人達を", "目で追ってしまう", "のです。"]}, {"box": [623, 540, 650, 745], "vertical": true, "font_size": 27, "lines_coords": [[[623.0, 540.0], [650.0, 540.0], [650.0, 745.0], [623.0, 745.0]]], "lines": ["．．．誰を探してる？"]}, {"box": [407, 539, 587, 676], "vertical": true, "font_size": 27.0, "lines_coords": [[[560.0, 539.0], [587.0, 539.0], [587.0, 668.0], [560.0, 668.0]], [[528.0, 540.0], [556.0, 540.0], [556.0, 643.0], [528.0, 643.0]], [[495.0, 540.0], [521.0, 540.0], [521.0, 676.0], [495.0, 676.0]], [[442.0, 540.0], [468.0, 540.0], [468.0, 643.0], [442.0, 643.0]], [[407.0, 539.0], [435.0, 539.0], [437.0, 675.0], [409.0, 675.0]]], "lines": ["どうせ誰も", "助けては", "くれません。", "見向きも", "されません。"]}, {"box": [100, 356, 190, 485], "vertical": true, "font_size": 26, "lines_coords": [[[157.0, 356.0], [190.0, 356.0], [190.0, 439.0], [157.0, 439.0]], [[129.0, 359.0], [151.0, 359.0], [151.0, 462.0], [129.0, 462.0]], [[100.0, 359.0], [121.0, 359.0], [121.0, 485.0], [100.0, 485.0]]], "lines": ["なんか", "愉快な話", "しちくり！！"]}, {"box": [220, 537, 378, 745], "vertical": true, "font_size": 25, "lines_coords": [[[351.0, 539.0], [373.0, 539.0], [373.0, 729.0], [351.0, 729.0]], [[315.0, 540.0], [342.0, 540.0], [342.0, 732.0], [315.0, 732.0]], [[281.0, 537.0], [307.0, 537.0], [310.0, 695.0], [284.0, 695.0]], [[251.0, 539.0], [273.0, 539.0], [273.0, 742.0], [251.0, 742.0]], [[220.0, 540.0], [246.0, 540.0], [246.0, 653.0], [220.0, 653.0]]], "lines": ["そりゃそうです。", "みんな、あんなに", "前に向かって", "堂々と歩いてるん", "ですもの。"]}, {"box": [621, 825, 648, 856], "vertical": true, "font_size": 26, "lines_coords": [[[621.0, 825.0], [648.0, 825.0], [648.0, 856.0], [621.0, 856.0]]], "lines": ["ぐ"]}, {"box": [576, 912, 601, 945], "vertical": true, "font_size": 26, "lines_coords": [[[576.0, 912.0], [601.0, 912.0], [601.0, 945.0], [576.0, 945.0]]], "lines": ["ぐ"]}, {"box": [578, 1356, 735, 1539], "vertical": true, "font_size": 28, "lines_coords": [[[707.0, 1357.0], [735.0, 1357.0], [735.0, 1487.0], [707.0, 1487.0]], [[673.0, 1357.0], [706.0, 1357.0], [706.0, 1464.0], [673.0, 1464.0]], [[645.0, 1359.0], [671.0, 1359.0], [671.0, 1539.0], [645.0, 1539.0]], [[612.0, 1356.0], [640.0, 1356.0], [637.0, 1514.0], [609.0, 1514.0]], [[581.0, 1356.0], [607.0, 1356.0], [604.0, 1492.0], [578.0, 1492.0]]], "lines": ["．．．せっかく", "風の中に", "ほんのりと春が", "混ざり始めた", "というのに、"]}, {"box": [389, 1356, 517, 1549], "vertical": true, "font_size": 31, "lines_coords": [[[482.0, 1356.0], [517.0, 1356.0], [517.0, 1439.0], [482.0, 1439.0]], [[454.0, 1359.0], [481.0, 1359.0], [481.0, 1540.0], [454.0, 1540.0]], [[418.0, 1356.0], [453.0, 1356.0], [453.0, 1439.0], [418.0, 1439.0]], [[389.0, 1357.0], [415.0, 1357.0], [415.0, 1548.0], [389.0, 1548.0]]], "lines": ["北風の", "冷たさにばかり", "敏感な", "ブンフンでした。"]}], "img_path": "096.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [856, 1014, 915, 1357], "vertical": true, "font_size": 26, "lines_coords": [[[885.0, 1014.0], [912.0, 1014.0], [914.0, 1296.0], [887.0, 1296.0]], [[856.0, 1017.0], [882.0, 1017.0], [882.0, 1354.0], [856.0, 1354.0]]], "lines": ["あと一、二歩踏み出せば", "全部が解決するかもしれない。"]}, {"box": [778, 1015, 806, 1259], "vertical": true, "font_size": 22, "lines_coords": [[[781.0, 1015.0], [803.0, 1015.0], [803.0, 1253.0], [781.0, 1253.0]]], "lines": ["そんな気がしました。"]}, {"box": [268, 1012, 299, 1356], "vertical": true, "font_size": 27, "lines_coords": [[[268.0, 1012.0], [295.0, 1012.0], [295.0, 1356.0], [268.0, 1356.0]]], "lines": ["．．．けど白線すら越えられない。"]}, {"box": [157, 1012, 221, 1356], "vertical": true, "font_size": 28, "lines_coords": [[[195.0, 1015.0], [217.0, 1015.0], [217.0, 1350.0], [195.0, 1350.0]], [[157.0, 1012.0], [190.0, 1012.0], [190.0, 1104.0], [157.0, 1104.0]]], "lines": ["結局、その程度の人間なのだ", "自分は。"]}, {"box": [573, 1220, 626, 1334], "vertical": true, "font_size": 53, "lines_coords": [[[573.0, 1220.0], [626.0, 1220.0], [626.0, 1334.0], [573.0, 1334.0]]], "lines": ["いい"]}, {"box": [512, 1257, 539, 1296], "vertical": false, "font_size": 39, "lines_coords": [[[512.0, 1257.0], [539.0, 1257.0], [539.0, 1296.0], [512.0, 1296.0]]], "lines": ["３"]}], "img_path": "097.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [399, 82, 615, 298], "vertical": true, "font_size": 27, "lines_coords": [[[573.0, 84.0], [612.0, 82.0], [615.0, 176.0], [576.0, 178.0]], [[550.0, 87.0], [576.0, 87.0], [576.0, 292.0], [550.0, 292.0]], [[495.0, 85.0], [523.0, 85.0], [525.0, 292.0], [496.0, 292.0]], [[467.0, 89.0], [489.0, 89.0], [489.0, 290.0], [467.0, 290.0]], [[434.0, 89.0], [456.0, 89.0], [456.0, 290.0], [434.0, 290.0]], [[400.0, 87.0], [423.0, 87.0], [425.0, 276.0], [401.0, 276.0]]], "lines": ["．．．ただ、", "今日唯一の収穫は", "単純作業の仕事は", "どうやらとっても", "自分に向いてると", "いうことでした。"]}, {"box": [489, 478, 584, 662], "vertical": true, "font_size": 27, "lines_coords": [[[556.0, 478.0], [584.0, 478.0], [581.0, 610.0], [553.0, 610.0]], [[523.0, 479.0], [550.0, 479.0], [548.0, 662.0], [521.0, 662.0]], [[492.0, 479.0], [518.0, 479.0], [515.0, 643.0], [489.0, 643.0]]], "lines": ["．．．なんだか", "ちょっと元気が", "出てきました。"]}, {"box": [248, 479, 337, 687], "vertical": true, "font_size": 23, "lines_coords": [[[314.0, 479.0], [335.0, 479.0], [335.0, 634.0], [314.0, 634.0]], [[278.0, 481.0], [304.0, 481.0], [304.0, 685.0], [278.0, 685.0]], [[248.0, 482.0], [270.0, 482.0], [270.0, 643.0], [248.0, 643.0]]], "lines": ["：明日からは", "もう少し頑張れる", "かもしれない。"]}, {"box": [140, 481, 198, 662], "vertical": true, "font_size": 22, "lines_coords": [[[171.0, 482.0], [193.0, 482.0], [193.0, 659.0], [171.0, 659.0]], [[140.0, 482.0], [162.0, 482.0], [162.0, 620.0], [140.0, 620.0]]], "lines": ["そうフンフンは", "思いました。"]}, {"box": [652, 1333, 742, 1497], "vertical": true, "font_size": 25, "lines_coords": [[[714.0, 1334.0], [740.0, 1334.0], [740.0, 1439.0], [714.0, 1439.0]], [[681.0, 1334.0], [707.0, 1334.0], [707.0, 1464.0], [681.0, 1464.0]], [[653.0, 1335.0], [675.0, 1335.0], [675.0, 1489.0], [653.0, 1489.0]]], "lines": ["．．．昨日も", "おとといも", "その前の日も"]}, {"box": [476, 1333, 569, 1522], "vertical": true, "font_size": 25, "lines_coords": [[[545.0, 1337.0], [567.0, 1337.0], [567.0, 1487.0], [545.0, 1487.0]], [[510.0, 1335.0], [537.0, 1335.0], [537.0, 1465.0], [510.0, 1465.0]], [[478.0, 1334.0], [504.0, 1334.0], [503.0, 1515.0], [476.0, 1515.0]]], "lines": ["明日はきっと", "頑張れると", "思ってたことは"]}, {"box": [337, 1334, 397, 1463], "vertical": true, "font_size": 24, "lines_coords": [[[371.0, 1337.0], [393.0, 1337.0], [393.0, 1462.0], [371.0, 1462.0]], [[337.0, 1335.0], [364.0, 1335.0], [364.0, 1450.0], [337.0, 1450.0]]], "lines": ["みんなには", "秘密です。"]}], "img_path": "098.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [326, 370, 404, 403], "vertical": false, "font_size": 16.5, "lines_coords": [[[342.0, 382.0], [384.0, 385.0], [382.0, 403.0], [340.0, 400.0]], [[326.0, 370.0], [404.0, 370.0], [404.0, 385.0], [326.0, 385.0]]], "lines": ["ご注意", "ひらくドアに"]}, {"box": [942, 1268, 995, 1426], "vertical": true, "font_size": 26, "lines_coords": [[[967.0, 1268.0], [995.0, 1268.0], [995.0, 1343.0], [967.0, 1343.0]], [[943.0, 1268.0], [965.0, 1268.0], [964.0, 1426.0], [942.0, 1426.0]]], "lines": ["．．．あら", "ごめんなさい！！"]}, {"box": [873, 1389, 904, 1493], "vertical": true, "font_size": 26, "lines_coords": [[[876.0, 1389.0], [904.0, 1389.0], [901.0, 1493.0], [873.0, 1493.0]]], "lines": ["大丈夫？"]}, {"box": [468, 1171, 503, 1239], "vertical": true, "font_size": 35, "lines_coords": [[[468.0, 1171.0], [503.0, 1171.0], [503.0, 1239.0], [468.0, 1239.0]]], "lines": ["．．．あ、"]}], "img_path": "099.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [209, 271, 263, 410], "vertical": true, "font_size": 24, "lines_coords": [[[239.0, 273.0], [260.0, 273.0], [260.0, 410.0], [239.0, 410.0]], [[209.0, 271.0], [235.0, 271.0], [235.0, 376.0], [209.0, 376.0]]], "lines": ["ドアが閉まり", "まーす。"]}, {"box": [604, 1240, 658, 1414], "vertical": true, "font_size": 22, "lines_coords": [[[634.0, 1243.0], [656.0,