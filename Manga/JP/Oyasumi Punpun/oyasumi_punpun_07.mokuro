参加", "したりしてるん", "だけど．．．"]}, {"box": [706, 1165, 818, 1307], "vertical": true, "font_size": 25, "lines_coords": [[[792.0, 1165.0], [818.0, 1165.0], [818.0, 1285.0], [792.0, 1285.0]], [[765.0, 1168.0], [787.0, 1168.0], [787.0, 1307.0], [765.0, 1307.0]], [[737.0, 1170.0], [759.0, 1170.0], [759.0, 1307.0], [737.0, 1307.0]], [[706.0, 1167.0], [735.0, 1167.0], [735.0, 1240.0], [706.0, 1240.0]]], "lines": ["原作として", "ちゃんと続き", "書いてみる気", "ない？"]}, {"box": [103, 1351, 193, 1507], "vertical": true, "font_size": 27, "lines_coords": [[[160.0, 1351.0], [193.0, 1351.0], [193.0, 1443.0], [160.0, 1443.0]], [[131.0, 1354.0], [157.0, 1354.0], [157.0, 1507.0], [131.0, 1507.0]], [[103.0, 1353.0], [125.0, 1353.0], [125.0, 1507.0], [103.0, 1507.0]]], "lines": ["あたし、", "小野寺くんの", "才能買うよ？"]}], "img_path": "214.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [940, 1065, 1003, 1148], "vertical": true, "font_size": 32, "lines_coords": [[[975.0, 1067.0], [1003.0, 1067.0], [1003.0, 1146.0], [975.0, 1146.0]], [[940.0, 1065.0], [975.0, 1065.0], [975.0, 1148.0], [940.0, 1148.0]]], "lines": ["．．．え？", "お酒？"]}, {"box": [621, 1303, 701, 1465], "vertical": true, "font_size": 25, "lines_coords": [[[676.0, 1304.0], [698.0, 1304.0], [698.0, 1431.0], [676.0, 1431.0]], [[646.0, 1303.0], [676.0, 1303.0], [676.0, 1379.0], [646.0, 1379.0]], [[621.0, 1306.0], [643.0, 1306.0], [643.0, 1465.0], [621.0, 1465.0]]], "lines": ["これ、社長の", "だけど", "飲んじゃえば？"]}, {"box": [123, 1271, 182, 1375], "vertical": true, "font_size": 25, "lines_coords": [[[151.0, 1271.0], [179.0, 1271.0], [182.0, 1371.0], [154.0, 1371.0]], [[123.0, 1273.0], [145.0, 1273.0], [145.0, 1375.0], [123.0, 1375.0]]], "lines": ["おーーっ", "飲むね！！"]}], "img_path": "215.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [501, 238, 604, 329], "vertical": false, "font_size": 100, "lines_coords": [[[501.0, 229.0], [604.0, 229.0], [604.0, 338.0], [501.0, 338.0]]], "lines": ["．．．"]}, {"b