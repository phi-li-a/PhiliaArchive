, 512.0], [201.0, 512.0], [201.0, 651.0], [179.0, 651.0]], [[148.0, 510.0], [175.0, 510.0], [175.0, 629.0], [148.0, 629.0]], [[121.0, 510.0], [148.0, 510.0], [145.0, 653.0], [118.0, 653.0]]], "lines": ["まぁ気張らず", "仲良くやろう", "じゃないか", "ハッハー！！"]}, {"box": [607, 1029, 634, 1157], "vertical": true, "font_size": 26, "lines_coords": [[[607.0, 1029.0], [634.0, 1029.0], [634.0, 1157.0], [607.0, 1157.0]]], "lines": ["オイッス！！"]}, {"box": [503, 1092, 554, 1253], "vertical": true, "font_size": 26, "lines_coords": [[[526.0, 1092.0], [554.0, 1092.0], [554.0, 1185.0], [526.0, 1185.0]], [[503.0, 1092.0], [525.0, 1092.0], [525.0, 1253.0], [503.0, 1253.0]]], "lines": ["おつかれ", "サンシャイン！！"]}, {"box": [154, 1046, 232, 1231], "vertical": true, "font_size": 24, "lines_coords": [[[210.0, 1048.0], [232.0, 1048.0], [232.0, 1229.0], [210.0, 1229.0]], [[179.0, 1048.0], [206.0, 1048.0], [206.0, 1210.0], [179.0, 1210.0]], [[154.0, 1046.0], [176.0, 1046.0], [176.0, 1231.0], [154.0, 1231.0]]], "lines": ["まだ全然深夜だが", "いつか必ず陽は", "昇るんだぜー！！"]}, {"box": [68, 1285, 181, 1435], "vertical": true, "font_size": 24, "lines_coords": [[[153.0, 1287.0], [181.0, 1287.0], [181.0, 1382.0], [153.0, 1382.0]], [[123.0, 1285.0], [150.0, 1285.0], [154.0, 1435.0], [128.0, 1435.0]], [[101.0, 1289.0], [123.0, 1289.0], [123.0, 1426.0], [101.0, 1426.0]], [[71.0, 1287.0], [95.0, 1287.0], [92.0, 1381.0], [68.0, 1381.0]]], "lines": ["どうだい", "オノッティー、", "バイト初日の", "感想は！？"]}], "img_path": "152.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [918, 67, 1020, 231], "vertical": true, "font_size": 22, "lines_coords": [[[992.0, 67.0], [1020.0, 67.0], [1020.0, 134.0], [992.0, 134.0]], [[967.0, 67.0], [989.0, 67.0], [990.0, 214.0], [968.0, 214.0]], [[943.0, 68.0], [964.0, 68.0], [964.0, 231.0], [943.0, 231.0]], [[918.0, 68.0], [940.0, 68.0], [940.0, 153.0], [918.0, 153.0]]], "lines": ["．．．なぁ", "オノッティー．．．", "俺の悩みを聞いて", "くれよ．．．"]}, {"box": [860, 271, 967, 504], "vertical": true, "font_size": 22, "lines_coords": [[[945.0, 273.0], [967.0, 273.0], [967.0, 482.0], [945.0, 482.0]], [[918.0, 275.0], [939.0, 275.0], [939.0, 504.0], [918.0, 504.0]], [[887.0, 271.0], [909.0, 271.0], [909.0, 481.0], [887.0, 481.0]], [[860.0, 276.0], [882.0, 276.0], [882.0, 435.0], [860.0, 435.0]]], "lines": ["正直、今、俺の腹筋は", "世界で３番目くらいに", "カワイイと目負して", "いるんだが．．．"]}, {"box": [193, 114, 301, 323], "vertical": true, "font_size": 22, "lines_coords": [[[279.0, 115.0], [301.0, 115.0], [301.0, 318.0], [279.0, 318.0]], [[251.0, 115.0], [273.0, 115.0], [273.0, 300.0], [251.0, 300.0]], [[223.0, 115.0], [245.0, 115.0], [245.0, 323.0], [223.0, 323.0]], [[195.0, 114.0], [217.0, 114.0], [215.0, 254.0], [193.0, 254.0]]], "lines": ["この腹筋に見合った", "カワイコちゃんが", "大学に全く見当たら", "ないんだ．．．．．"]}, {"box": [956, 662, 982, 764], "vertical": true, "font_size": 25, "lines_coords": [[[956.0, 662.0], [982.0, 662.0], [982.0, 764.0], [956.0, 764.0]]], "lines": ["．．．えっ！！"]}, {"box": [728, 676, 789, 834], "vertical": true, "font_size": 28, "lines_coords": [[[754.0, 676.0], [789.0, 676.0], [789.0, 762.0], [754.0, 762.0]], [[729.0, 681.0], [751.0, 681.0], [751.0, 834.0], [729.0, 834.0]]], "lines": ["だから", "気にすんな！？"]}, {"box": [95, 378, 232, 564], "vertical": true, "font_size": 22, "lines_coords": [[[206.0, 378.0], [232.0, 378.0], [232.0, 475.0], [206.0, 475.0]], [[181.0, 381.0], [203.0, 381.0], [203.0, 495.0], [181.0, 495.0]], [[150.0, 379.0], [173.0, 379.0], [175.0, 564.0], [151.0, 564.0]], [[125.0, 381.0], [145.0, 381.0], [145.0, 518.0], [125.0, 518.0]], [[95.0, 381.0], [117.0, 381.0], [117.0, 471.0], [95.0, 471.0]]], "lines": ["．．．畜生！！", "これじゃあ", "いつまでたっても", "彼女が出来や", "しない！！"]}, {"box": [232, 715, 295, 850], "vertical": true, "font_size": 26, "lines_coords": [[[262.0, 715.0], [295.0, 715.0], [295.0, 845.0], [262.0, 845.0]], [[232.0, 721.0], [260.0, 721.0], [260.0, 850.0], [232.0, 850.0]]], "lines": ["すげ〜〜．．．", "マジか．．．"]}, {"box": [859, 820, 940, 1017], "vertical": true, "font_size": 25, "lines_coords": [[[918.0, 820.0], [940.0, 820.0], [940.0, 1017.0], [918.0, 1017.0]], [[890.0, 820.0], [912.0, 820.0], [912.0, 1006.0], [890.0, 1006.0]], [[859.0, 820.0], [889.0, 820.0], [889.0, 893.0], [859.0, 893.0]]], "lines": ["ギネスに認定された", "世界最大の巨乳は", "１５４０ｍ！？"]}, {"box": [154, 884, 232, 1085], "vertical": true, "font_size": 26, "lines_coords": [[[209.0, 885.0], [232.0, 885.0], [231.0, 1037.0], [207.0, 1037.0]], [[178.0, 884.0], [204.0, 884.0], [204.0, 1085.0], [178.0, 1085.0]], [[154.0, 887.0], [175.0, 887.0], [175.0, 1060.0], [154.0, 1060.0]]], "lines": ["１５４ｍってウチの", "かーちゃんの身長と", "同じじゃねーか！！"]}, {"box": [935, 1176, 984, 1293], "vertical": true, "font_size": 22, "lines_coords": [[[962.0, 1176.0], [984.0, 1176.0], [984.0, 1293.0], [962.0, 1293.0]], [[935.0, 1178.0], [957.0, 1178.0], [957.0, 1279.0], [935.0, 1279.0]]], "lines": ["．．．なるほど", "う～～む。"]}, {"box": [826, 1310, 931, 1557], "vertical": true, "font_size": 22, "lines_coords": [[[910.0, 1310.0], [931.0, 1310.0], [931.0, 1520.0], [910.0, 1520.0]], [[879.0, 1310.0], [906.0, 1310.0], [906.0, 1557.0], [879.0, 1557.0]], [[853.0, 1312.0], [875.0, 1312.0], [875.0, 1542.0], [853.0, 1542.0]], [[826.0, 1310.0], [846.0, 1310.0], [846.0, 1543.0], [826.0, 1543.0]]], "lines": ["はぐらかされた感で", "いっぱいなんだが確かに", "世の中まだまだ未知で", "溢れ返ってやがるぜ．．．"]}, {"box": [693, 1168, 743, 1369], "vertical": true, "font_size": 22, "lines_coords": [[[718.0, 1170.0], [740.0, 1170.0], [742.0, 1368.0], [720.0, 1368.0]], [[693.0, 1168.0], [714.0, 1168.0], [714.0, 1354.0], [693.0, 1354.0]]], "lines": ["．．．まさに摩訶不思議", "アドベンチャー！！"]}, {"box": [239, 1182, 343, 1323], "vertical": true, "font_size": 22, "lines_coords": [[[323.0, 1184.0], [343.0, 1184.0], [343.0, 1321.0], [323.0, 1321.0]], [[295.0, 1182.0], [317.0, 1182.0], [317.0, 1298.0], [295.0, 1298.0]], [[265.0, 1182.0], [287.0, 1182.0], [287.0, 1323.0], [265.0, 1323.0]], [[239.0, 1184.0], [259.0, 1184.0], [259.0, 1323.0], [239.0, 1323.0]]], "lines": ["．．．そういえば", "ついさっき", "不思議な夢を", "見ててだな．．．"]}, {"box": [140, 1334, 220, 1507], "vertical": true, "font_size": 22, "lines_coords": [[[198.0, 1335.0], [220.0, 1335.0], [220.0, 1507.0], [198.0, 1507.0]], [[170.0, 1334.0], [193.0, 1334.0], [190.0, 1475.0], [167.0, 1475.0]], [[142.0, 1335.0], [164.0, 1335.0], [162.0, 1496.0], [140.0, 1496.0]]], "lines": ["突然、俺の部屋が", "神々しい光に", "包まれたのだ！！"]}], "img_path": "153.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [871, 59, 979, 282], "vertical": true, "font_size": 22, "lines_coords": [[[953.0, 59.0], [979.0, 59.0], [978.0, 268.0], [951.0, 268.0]], [[925.0, 60.0], [946.0, 60.0], [946.0, 245.0], [925.0, 245.0]], [[898.0, 64.0], [920.0, 64.0], [920.0, 276.0], [898.0, 276.0]], [[871.0, 64.0], [893.0, 64.0], [893.0, 282.0], [871.0, 282.0]]], "lines": ["．．．気がつくと部屋に", "ピンク色の家が．．．", "いや、スケスケ水着の", "お姉さんだったかな．．．"]}, {"box": [193, 96, 301, 270], "vertical": true, "font_size": 22, "lines_coords": [[[279.0, 98.0], [301.0, 98.0], [301.0, 190.0], [279.0, 190.0]], [[253.0, 98.0], [275.0, 98.0], [275.0, 270.0], [253.0, 270.0]], [[225.0, 98.0], [246.0, 98.0], [246.0, 259.0], [225.0, 259.0]], [[195.0, 96.0], [218.0, 96.0], [217.0, 270.0], [193.0, 270.0]]], "lines": ["要するに", "「お前にはもっと", "やるべきことが", "ある！！」ってな．．．"]}, {"box": [721, 300, 884, 532], "vertical": true, "font_size": 22, "lines_coords": [[[862.0, 301.0], [884.0, 301.0], [884.0, 442.0], [862.0, 442.0]], [[834.0, 301.0], [854.0, 301.0], [854.0, 464.0], [834.0, 464.0]], [[806.0, 301.0], [828.0, 301.0], [828.0, 532.0], [806.0, 532.0]], [[776.0, 300.0], [803.0, 300.0], [803.0, 532.0], [776.0, 532.0]], [[750.0, 303.0], [771.0, 303.0], [771.0, 464.0], [750.0, 464.0]], [[721.0, 301.0], [742.0, 301.0], [742.0, 440.0], [721.0, 440.0]]], "lines": ["．．．とにかく！！", "姿形は忘れたが", "とにかくとんでもなく", "でっかい存在の何かが", "俺に語りかけて", "きたんだ．．．．．"]}, {"box": [904, 609, 959, 712], "vertical": true, "font_size": 25, "lines_coords": [[[931.0, 609.0], [959.0, 609.0], [959.0, 712.0], [931.0, 712.0]], [[904.0, 610.0], [926.0, 610.0], [926.0, 710.0], [904.0, 710.0]]], "lines": ["．．．なんて", "こった！！"]}, {"box": [145, 346, 223, 506], "vertical": true, "font_size": 22, "lines_coords": [[[201.0, 346.0], [223.0, 346.0], [223.0, 506.0], [201.0, 506.0]], [[171.0, 346.0], [193.0, 346.0], [193.0, 506.0], [171.0, 506.0]], [[145.0, 346.0], [167.0, 346.0], [167.0, 484.0], [145.0, 484.0]]], "lines": ["その瞬間、俺の", "ソウルに天啓が", "舞い降りた！！"]}, {"box": [203, 618, 340, 829], "vertical": true, "font_size": 23, "lines_coords": [[[314.0, 620.0], [340.0, 620.0], [340.0, 764.0], [314.0, 764.0]], [[287.0, 621.0], [309.0, 621.0], [309.0, 829.0], [287.0, 829.0]], [[257.0, 621.0], [279.0, 621.0], [279.0, 829.0], [257.0, 829.0]], [[232.0, 621.0], [254.0, 621.0], [254.0, 806.0], [232.0, 806.0]], [[204.0, 618.0], [226.0, 618.0], [225.0, 784.0], [203.0, 784.0]]], "lines": ["．．．ほら、耳を", "すませてごらんよ．．．", "今にも助けを求める", "民の声が聞こえて", "くるようだ．．．！！"]}, {"box": [806, 789, 889, 929], "vertical": true, "font_size": 25, "lines_coords": [[[862.0, 789.0], [889.0, 789.0], [889.0, 885.0], [862.0, 885.0]], [[832.0, 789.0], [859.0, 789.0], [859.0, 909.0], [832.0, 909.0]], [[809.0, 789.0], [831.0, 789.0], [828.0, 929.0], [806.0, 929.0]]], "lines": ["俺は神に", "選ばれし者", "だったのか．．"]}, {"box": [935, 1129, 967, 1185], "vertical": true, "font_size": 26, "lines_coords": [[[935.0, 1129.0], [967.0, 1129.0], [967.0, 1185.0], [935.0, 1185.0]]], "lines": ["．．あ、"]}, {"box": [123, 829, 231, 1001], "vertical": true, "font_size": 23, "lines_coords": [[[204.0, 829.0], [231.0, 829.0], [231.0, 926.0], [204.0, 926.0]], [[178.0, 831.0], [200.0, 831.0], [200.0, 970.0], [178.0, 970.0]], [[151.0, 832.0], [171.0, 832.0], [171.0, 970.0], [151.0, 970.0]], [[123.0, 831.0], [145.0, 831.0], [145.0, 1001.0], [123.0, 1001.0]]], "lines": ["バカバカ", "三村のバカ！！", "なぜ今日まで", "気付かなかった！？"]}, {"box": [829, 1207, 918, 1429], "vertical": true, "font_size": 26, "lines_coords": [[[889.0, 1207.0], [915.0, 1207.0], [918.0, 1367.0], [892.0, 1367.0]], [[859.0, 1212.0], [885.0, 1212.0], [885.0, 1429.0], [859.0, 1429.0]], [[829.0, 1214.0], [851.0, 1214.0], [851.0, 1390.0], [829.0, 1390.0]]], "lines": ["オノッティー", "なんだい、その凍り", "ついた笑顔は？"]}, {"box": [126, 1325, 217, 1506], "vertical": true, "font_size": 25, "lines_coords": [[[192.0, 1326.0], [214.0, 1326.0], [214.0, 1454.0], [192.0, 1454.0]], [[157.0, 1325.0], [184.0, 1325.0], [184.0, 1431.0], [157.0, 1431.0]], [[126.0, 1325.0], [153.0, 1325.0], [153.0, 1506.0], [126.0, 1506.0]]], "lines": ["そんな態度", "とると俺", "泣いちゃうよ？"]}], "img_path": "154.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [964, 75, 990, 176], "vertical": true, "font_size": 22, "lines_coords": [[[964.0, 75.0], [990.0, 75.0], [990.0, 176.0], [964.0, 176.0]]], "lines": ["．．．いや、"]}, {"box": [850, 196, 926, 335], "vertical": true, "font_size": 22, "lines_coords": [[[904.0, 196.0], [926.0, 196.0], [923.0, 314.0], [901.0, 314.0]], [[875.0, 198.0], [896.0, 198.0], [896.0, 335.0], [875.0, 335.0]], [[850.0, 200.0], [867.0, 200.0], [867.0, 298.0], [850.0, 298.0]]], "lines": ["まぁ冗談は", "これくらいに", "してだな。"]}, {"box": [207, 206, 290, 370], "vertical": true, "font_size": 23, "lines_coords": [[[267.0, 209.0], [290.0, 209.0], [287.0, 346.0], [264.0, 346.0]], [[237.0, 207.0], [260.0, 207.0], [259.0, 370.0], [235.0, 370.0]], [[207.0, 206.0], [235.0, 206.0], [235.0, 289.0], [207.0, 289.0]]], "lines": ["けっこう最近", "本気で悩んでん", "だよね。"]}, {"box": [943, 678, 990, 818], "vertical": true, "font_size": 21, "lines_coords": [[[973.0, 681.0], [990.0, 681.0], [990.0, 793.0], [973.0, 793.0]], [[943.0, 678.0], [965.0, 678.0], [965.0, 818.0], [943.0, 818.0]]], "lines": ["ウチ、両親", "教師じゃん？"]}, {"box": [154, 409, 260, 596], "vertical": true, "font_size": 23, "lines_coords": [[[239.0, 410.0], [260.0, 410.0], [257.0, 596.0], [235.0, 596.0]], [[207.0, 409.0], [229.0, 409.0], [229.0, 573.0], [207.0, 573.0]], [[181.0, 412.0], [203.0, 412.0], [203.0, 573.0], [181.0, 573.0]], [[154.0, 412.0], [175.0, 412.0], [175.0, 560.0], [154.0, 560.0]]], "lines": ["経済学部のくせに", "どうやら経済に", "全く興味がない", "らしいんだ俺。"]}, {"box": [203, 706, 310, 879], "vertical": true, "font_size": 22, "lines_coords": [[[289.0, 709.0], [310.0, 709.0], [310.0, 832.0], [289.0, 832.0]], [[259.0, 706.0], [282.0, 706.0], [281.0, 879.0], [257.0, 879.0]], [[229.0, 707.0], [251.0, 707.0], [251.0, 853.0], [229.0, 853.0]], [[203.0, 709.0], [226.0, 709.0], [226.0, 784.0], [203.0, 784.0]]], "lines": ["なんかこう、", "サァ〜〜ッと霧が", "晴れていったと", "いうか"]}, {"box": [843, 823, 921, 1015], "vertical": true, "font_size": 21, "lines_coords": [[[900.0, 823.0], [921.0, 823.0], [921.0, 1009.0], [900.0, 1009.0]], [[871.0, 825.0], [893.0, 825.0], [893.0, 1015.0], [871.0, 1015.0]], [[843.0, 825.0], [865.0, 825.0], [865.0, 1009.0], [843.0, 1009.0]]], "lines": ["めんどくせーけど", "教員免許とるかー", "って考え直したら、"]}, {"box": [121, 854, 229, 1050], "vertical": true, "font_size": 22, "lines_coords": [[[200.0, 854.0], [226.0, 854.0], [229.0, 978.0], [203.0, 978.0]], [[178.0, 856.0], [200.0, 856.0], [196.0, 1020.0], [175.0, 1020.0]], [[148.0, 859.0], [170.0, 859.0], [170.0, 996.0], [148.0, 996.0]], [[121.0, 859.0], [142.0, 859.0], [142.0, 1050.0], [121.0, 1050.0]]], "lines": ["おそろしく", "真っすぐな道が", "眼前に広がり", "たてまつった訳よ！！"]}, {"box": [926, 1126, 956, 1276], "vertical": true, "font_size": 24, "lines_coords": [[[926.0, 1126.0], [954.0, 1126.0], [956.0, 1276.0], [928.0, 1276.0]]], "lines": ["．．．だのに！！"]}, {"box": [807, 1303, 895, 1482], "vertical": true, "font_size": 24, "lines_coords": [[[868.0, 1303.0], [895.0, 1303.0], [895.0, 1434.0], [868.0, 1434.0]], [[839.0, 1303.0], [860.0, 1303.0], [860.0, 1468.0], [839.0, 1468.0]], [[807.0, 1303.0], [829.0, 1303.0], [829.0, 1482.0], [807.0, 1482.0]]], "lines": ["それだのに", "なんだい、この", "わだかまりは！！"]}, {"box": [268, 1135, 350, 1334], "vertical": true, "font_size": 23, "lines_coords": [[[323.0, 1137.0], [350.0, 1137.0], [346.0, 1253.0], [320.0, 1253.0]], [[298.0, 1137.0], [320.0, 1137.0], [320.0, 1321.0], [298.0, 1321.0]], [[268.0, 1135.0], [290.0, 1135.0], [290.0, 1334.0], [268.0, 1334.0]]], "lines": ["いいのか！！", "人の生きる道って", "そんなシンプルで！！"]}, {"box": [115, 1326, 248, 1535], "vertical": true, "font_size": 23, "lines_coords": [[[226.0, 1326.0], [248.0, 1326.0], [248.0, 1445.0], [226.0, 1445.0]], [[198.0, 1328.0], [220.0, 1328.0], [220.0, 1490.0], [198.0, 1490.0]], [[170.0, 1328.0], [192.0, 1328.0], [192.0, 1535.0], [170.0, 1535.0]], [[142.0, 1329.0], [164.0, 1329.0], [164.0, 1514.0], [142.0, 1514.0]], [[115.0, 1328.0], [137.0, 1328.0], [137.0, 1398.0], [115.0, 1398.0]]], "lines": ["もっとこう", "ダイナミズムに", "身を任せたい欲求を", "捨てられない俺も", "いる！！"]}], "img_path": "155.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [935, 70, 987, 237], "vertical": true, "font_size": 24, "lines_coords": [[[960.0, 70.0], [987.0, 70.0], [987.0, 185.0], [960.0, 185.0]], [[935.0, 70.0], [957.0, 70.0], [957.0, 237.0], [935.0, 237.0]]], "lines": ["．．．いいよな", "オノッティーは。"]}, {"box": [871, 276, 925, 381], "vertical": true, "font_size": 24, "lines_coords": [[[896.0, 276.0], [925.0, 276.0], [925.0, 354.0], [896.0, 354.0]], [[871.0, 279.0], [893.0, 279.0], [893.0, 381.0], [871.0, 381.0]]], "lines": ["昔から", "そうだよ。"]}, {"box": [767, 164, 817, 350], "vertical": true, "font_size": 24, "lines_coords": [[[795.0, 165.0], [817.0, 165.0], [817.0, 304.0], [795.0, 304.0]], [[767.0, 164.0], [789.0, 164.0], [789.0, 350.0], [767.0, 350.0]]], "lines": ["自由というか", "どこにも属さない"]}, {"box": [739, 164, 760, 264], "vertical": true, "font_size": 24, "lines_coords": [[[739.0, 164.0], [760.0, 164.0], [760.0, 264.0], [739.0, 264.0]]], "lines": ["というか"]}, {"box": [175, 106, 285, 268], "vertical": true, "font_size": 24, "lines_coords": [[[259.0, 109.0], [285.0, 109.0], [285.0, 225.0], [259.0, 225.0]], [[229.0, 106.0], [256.0, 106.0], [256.0, 223.0], [229.0, 223.0]], [[204.0, 109.0], [226.0, 109.0], [226.0, 268.0], [204.0, 268.0]], [[175.0, 106.0], [196.0, 106.0], [198.0, 257.0], [176.0, 257.0]]], "lines": ["シラーっと", "しちゃって", "なんか悩みとか", "なさそうだし。"]}, {"box": [884, 587, 962, 771], "vertical": true, "font_size": 23, "lines_coords": [[[940.0, 587.0], [962.0, 587.0], [962.0, 771.0], [940.0, 771.0]], [[912.0, 589.0], [934.0, 589.0], [934.0, 725.0], [912.0, 725.0]], [[884.0, 587.0], [906.0, 587.0], [906.0, 771.0], [884.0, 771.0]]], "lines": ["それがクールって", "やつなのかい", "オノッティ〜〜〜．．．"]}, {"box": [104, 339, 240, 479], "vertical": true, "font_size": 24, "lines_coords": [[[212.0, 339.0], [240.0, 339.0], [240.0, 414.0], [212.0, 414.0]], [[187.0, 342.0], [209.0, 342.0], [209.0, 478.0], [187.0, 478.0]], [[159.0, 342.0], [181.0, 342.0], [181.0, 479.0], [159.0, 479.0]], [[131.0, 340.0], [153.0, 340.0], [153.0, 479.0], [131.0, 479.0]], [[104.0, 340.0], [128.0, 340.0], [128.0, 410.0], [104.0, 410.0]]], "lines": ["不安は", "ないのかい？", "なぜそんなに", "自信があるん", "だい？"]}, {"box": [131, 698, 239, 889], "vertical": true, "font_size": 24, "lines_coords": [[[212.0, 700.0], [235.0, 700.0], [237.0, 875.0], [214.0, 875.0]], [[182.0, 698.0], [209.0, 698.0], [210.0, 889.0], [184.0, 889.0]], [[156.0, 700.0], [182.0, 700.0], [182.0, 820.0], [156.0, 820.0]], [[131.0, 703.0], [151.0, 703.0], [151.0, 840.0], [131.0, 840.0]]], "lines": ["．．．しかし！！俺の", "本音はいつだって", "夢追い人で", "いたいんだ！！"]}, {"box": [750, 729, 857, 917], "vertical": true, "font_size": 23, "lines_coords": [[[835.0, 731.0], [857.0, 731.0], [857.0, 875.0], [835.0, 875.0]], [[806.0, 731.0], [832.0, 731.0], [832.0, 851.0], [806.0, 851.0]], [[781.0, 732.0], [803.0, 732.0], [803.0, 917.0], [781.0, 917.0]], [[750.0, 729.0], [778.0, 729.0], [778.0, 848.0], [750.0, 848.0]]], "lines": ["そのスタンス", "鬼神の如く", "マジでリスペクト", "だぜ〜〜．．．"]}, {"box": [937, 1039, 957, 1165], "vertical": true, "font_size": 27, "lines_coords": [[[937.0, 1039.0], [957.0, 1039.0], [957.0, 1165.0], [937.0, 1165.0]]], "lines": ["．．．そうさ！！"]}, {"box": [150, 1106, 262, 1290], "vertical": true, "font_size": 23, "lines_coords": [[[240.0, 1106.0], [262.0, 1106.0], [262.0, 1243.0], [240.0, 1243.0]], [[210.0, 1106.0], [237.0, 1106.0], [237.0, 1290.0], [210.0, 1290.0]], [[178.0, 1106.0], [200.0, 1106.0], [200.0, 1289.0], [178.0, 1289.0]], [[150.0, 1106.0], [173.0, 1106.0], [173.0, 1178.0], [150.0, 1178.0]]], "lines": ["腹筋むき出し", "ルックを流行させ", "俺は裏原の帝王に", "なる！！"]}, {"box": [807, 1181, 903, 1364], "vertical": true, "font_size": 27, "lines_coords": [[[868.0, 1181.0], [903.0, 1181.0], [903.0, 1265.0], [868.0, 1265.0]], [[839.0, 1182.0], [865.0, 1182.0], [865.0, 1335.0], [839.0, 1335.0]], [[809.0, 1181.0], [835.0, 1181.0], [834.0, 1364.0], [807.0, 1364.0]]], "lines": ["やっぱ", "ヤングは夢が", "なくっちゃネ！！"]}, {"box": [71, 1309, 179, 1493], "vertical": true, "font_size": 23, "lines_coords": [[[153.0, 1309.0], [179.0, 1309.0], [179.0, 1429.0], [153.0, 1429.0]], [[125.0, 1309.0], [148.0, 1309.0], [150.0, 1493.0], [126.0, 1493.0]], [[100.0, 1310.0], [121.0, 1310.0], [121.0, 1482.0], [100.0, 1482.0]], [[71.0, 1310.0], [93.0, 1310.0], [93.0, 1450.0], [71.0, 1450.0]]], "lines": ["そして民放", "お昼の顔になって", "赤坂にちゃんこ", "鍋屋をーー．．．"]}], "img_path": "156.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [948, 51, 990, 123], "vertical": true, "font_size": 33, "lines_coords": [[[948.0, 51.0], [990.0, 51.0], [990.0, 123.0], [948.0, 123.0]]], "lines": ["．．．げ。"]}, {"box": [881, 115, 943, 235], "vertical": true, "font_size": 33, "lines_coords": [[[904.0, 117.0], [940.0, 115.0], [943.0, 181.0], [907.0, 182.0]], [[881.0, 126.0], [903.0, 126.0], [903.0, 235.0], [881.0, 235.0]]], "lines": ["もう", "朝じゃん"]}, {"box": [257, 35, 379, 240], "vertical": true, "font_size": 25, "lines_coords": [[[353.0, 35.0], [379.0, 35.0], [376.0, 190.0], [350.0, 190.0]], [[320.0, 35.0], [346.0, 35.0], [346.0, 215.0], [320.0, 215.0]], [[289.0, 35.0], [315.0, 35.0], [315.0, 240.0], [289.0, 240.0]], [[257.0, 37.0], [279.0, 37.0], [279.0, 217.0], [257.0, 217.0]]], "lines": ["叶う訳のない", "夢を持つことに", "どれだけの意味が", "あるのかなんて"]}, {"box": [134, 34, 220, 190], "vertical": true, "font_size": 25, "lines_coords": [[[193.0, 35.0], [220.0, 35.0], [220.0, 162.0], [193.0, 162.0]], [[162.0, 34.0], [189.0, 34.0], [189.0, 164.0], [162.0, 164.0]], [[134.0, 37.0], [156.0, 37.0], [156.0, 190.0], [134.0, 190.0]]], "lines": ["ブンブンは", "考えたくも", "ありませんが"]}, {"box": [841, 1135, 964, 1396], "vertical": true, "font_size": 25, "lines_coords": [[[935.0, 1135.0], [964.0, 1135.0], [964.0, 1215.0], [935.0, 1215.0]], [[904.0, 1135.0], [931.0, 1135.0], [929.0, 1392.0], [903.0, 1392.0]], [[875.0, 1139.0], [896.0, 1139.0], [896.0, 1342.0], [875.0, 1342.0]], [[842.0, 1139.0], [864.0, 1139.0], [864.0, 1289.0], [842.0, 1289.0]]], "lines": ["誰かに", "打ち明けられるような", "立派な夢や悩みが", "あるだけでも"]}, {"box": [706, 1134, 800, 1432], "vertical": true, "font_size": 28, "lines_coords": [[[771.0, 1137.0], [798.0, 1137.0], [798.0, 1342.0], [771.0, 1342.0]], [[734.0, 1134.0], [765.0, 1134.0], [770.0, 1370.0], [739.0, 1370.0]], [[706.0, 1135.0], [732.0, 1135.0], [734.0, 1429.0], [707.0, 1429.0]]], "lines": ["その人はある意味", "満たされてるんじゃ", "なかろうかと思いました。"]}, {"box": [185, 1168, 278, 1362], "vertical": true, "font_size": 28, "lines_coords": [[[248.0, 1168.0], [276.0, 1168.0], [278.0, 1325.0], [250.0, 1325.0]], [[218.0, 1170.0], [246.0, 1170.0], [246.0, 1276.0], [218.0, 1276.0]], [[187.0, 1168.0], [214.0, 1168.0], [212.0, 1359.0], [185.0, 1359.0]]], "lines": ["クールなんて", "空っぽと", "紙一重なんです。"]}], "img_path": "157.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [525, 361, 556, 502], "vertical": true, "font_size": 28, "lines_coords": [[[525.0, 364.0], [553.0, 364.0], [553.0, 493.0], [525.0, 493.0]]], "lines": ["ブンブンは"]}, {"box": [481, 1351, 607, 1557], "vertical": true, "font_size": 29, "lines_coords": [[[579.0, 1353.0], [607.0, 1353.0], [607.0, 1432.0], [579.0, 1432.0]], [[548.0, 1353.0], [575.0, 1353.0], [575.0, 1507.0], [548.0, 1507.0]], [[515.0, 1353.0], [542.0, 1353.0], [542.0, 1556.0], [515.0, 1556.0]], [[481.0, 1351.0], [514.0, 1351.0], [514.0, 1443.0], [481.0, 1443.0]]], "lines": ["今日も", "愛子ちゃんを", "見つけられません", "でした。"]}, {"box": [110, 1350, 200, 1518], "vertical": true, "font_size": 26, "lines_coords": [[[171.0, 1350.0], [200.0, 1350.0], [196.0, 1507.0], [168.0, 1507.0]], [[140.0, 