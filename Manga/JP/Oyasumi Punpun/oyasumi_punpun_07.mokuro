": ["んーと、"]}, {"box": [829, 1309, 907, 1428], "vertical": true, "font_size": 25, "lines_coords": [[[885.0, 1312.0], [907.0, 1312.0], [907.0, 1425.0], [885.0, 1425.0]], [[853.0, 1309.0], [882.0, 1309.0], [882.0, 1382.0], [853.0, 1382.0]], [[829.0, 1314.0], [851.0, 1314.0], [851.0, 1428.0], [829.0, 1428.0]]], "lines": ["隣の若いコ", "社長の", "知り合い？"]}, {"box": [154, 1295, 240, 1481], "vertical": true, "font_size": 25, "lines_coords": [[[212.0, 1295.0], [240.0, 1295.0], [240.0, 1375.0], [212.0, 1375.0]], [[189.0, 1298.0], [210.0, 1298.0], [210.0, 1479.0], [189.0, 1479.0]], [[154.0, 1296.0], [181.0, 1296.0], [184.0, 1396.0], [157.0, 1396.0]]], "lines": ["．．．ああ、", "ウチのお客さんで", "小野寺君。"]}], "img_path": "204.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [898, 91, 944, 275], "vertical": true, "font_size": 33, "lines_coords": [[[898.0, 92.0], [931.0, 92.0], [931.0, 275.0], [898.0, 275.0]]], "lines": ["南条幸です。"]}, {"box": [162, 528, 231, 650], "vertical": true, "font_size": 30, "lines_coords": [[[201.0, 528.0], [229.0, 528.0], [229.0, 650.0], [201.0, 650.0]], [[162.0, 528.0], [193.0, 528.0], [193.0, 582.0], [162.0, 582.0]]], "lines": ["こんばん", "はー"]}, {"box": [918, 786, 946, 887], "vertical": true, "font_size": 28, "lines_coords": [[[918.0, 787.0], [946.0, 787.0], [946.0, 887.0], [918.0, 887.0]]], "lines": ["．．．んん？"]}, {"box": [853, 1145, 893, 1218], "vertical": true, "font_size": 40, "lines_coords": [[[853.0, 1145.0], [893.0, 1145.0], [893.0, 1218.0], [853.0, 1218.0]]], "lines": ["．．．君、"]}, {"box": [256, 865, 283, 996], "vertical": true, "font_size": 26, "lines_coords": [[[256.0, 867.0], [282.0, 867.0], [282.0, 918.0], [256.0, 918.0]]], "lines": ["んー"]}, {"box": [176, 1268, 265, 1450], "vertical": true, "font_size": 26, "lines_coords": [[[237.0, 1270.0], [265.0, 1270.0], [265.0, 1375.0], [237.0, 1375.0]], [[207.0, 1268.0], [234.0, 1268.0], [234.0, 1450.0], [207.0, 1450.0]], [[176.0, 1270.0], [198.0, 1270.0], [198.0, 1396.0], [176.0, 1396.0]]], "lines": ["あたしと", "どっかで会った", "ことある？"]}], "img_path": "205.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [873, 192, 906, 295], "vertical": true, "font_size": 32, "lines_coords": [[[873.0, 192.0], [906.0, 192.0], [906.0, 295.0], [873.0, 295.0]]], "lines": ["ん～～～"]}, {"box": [840, 367, 871, 414], "vertical": true, "font_size": 32, "lines_coords": [[[840.0, 367.0], [871.0, 367.0], [871.0, 414.0], [840.0, 414.0]]], "lines": ["君、"]}, {"box": [23, 292, 67, 456], "vertical": true, "font_size": 44, "lines_coords": [[[23.0, 292.0], [67.0, 292.0], [67.0, 456.0], [23.0, 456.0]]], "lines": ["第７８話"]}, {"box": [907, 732, 942, 795], "vertical": true, "font_size": 35, "lines_coords": [[[907.0, 732.0], [942.0, 732.0], [942.0, 795.0], [907.0, 795.0]]], "lines": ["あ！"]}, {"box": [154, 337, 248, 473], "vertical": true, "font_size": 29, "lines_coords": [[[210.0, 337.0], [248.0, 337.0], [248.0, 398.0], [210.0, 398.0]], [[184.0, 340.0], [210.0, 340.0], [210.0, 473.0], [184.0, 473.0]], [[154.0, 342.0], [176.0, 342.0], [176.0, 470.0], [154.0, 470.0]]], "lines": ["絶対", "会ったこと", "あるって！！"]}, {"box": [150, 765, 181, 910], "vertical": true, "font_size": 26, "lines_coords": [[[153.0, 765.0], [179.0, 765.0], [176.0, 910.0], [150.0, 910.0]]], "lines": ["思い出した。"]}, {"box": [914, 1198, 971, 1326], "vertical": true, "font_size": 25, "lines_coords": [[[945.0, 1198.0], [971.0, 1198.0], [971.0, 1326.0], [945.0, 1326.0]], [[914.0, 1200.0], [940.0, 1200.0], [940.0, 1303.0], [914.0, 1303.0]]], "lines": ["．．．あれって", "いつだ？"]}, {"box": [807, 1332, 896, 1490], "vertical": true, "font_size": 25, "lines_coords": [[[870.0, 1332.0], [896.0, 1332.0], [896.0, 1440.0], [870.0, 1440.0]], [[837.0, 1332.0], [864.0, 1332.0], [860.0, 1490.0], [834.0, 1490.0]], [[807.0, 1334.0], [829.0, 1334.0], [829.0, 1439.0], [807.0, 1439.0]]], "lines": ["あたしが", "１９の時だから", "三年前？"]}, {"box": [114, 1351, 232, 1531], "vertical": true, "font_size": 22, "lines_coords": [[[200.0, 1351.0], [221.0, 1351.0], [221.0, 1470.0], [200.0, 1470.0]], [[171.0, 1351.0], [193.0, 1351.0], [193.0, 1492.0], [171.0, 1492.0]], [[143.0, 1353.0], [165.0, 1353.0], [165.0, 1531.0], [143.0, 1531.0]], [[114.0, 1351.0], [135.0, 1351.0], [135.0, 1468.0], [114.0, 1468.0]]], "lines": ["梓ちゃんと", "高校美術部の", "ＯＢ展見に来てた", "子てしょ！？"]}], "img_path": "206.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [931, 1007, 1013, 1161], "vertical": true, "font_size": 25, "lines_coords": [[[990.0, 1010.0], [1012.0, 1010.0], [1012.0, 1126.0], [990.0, 1126.0]], [[962.0, 1010.0], [984.0, 1010.0], [984.0, 1160.0], [962.0, 1160.0]], [[931.0, 1007.0], [962.0, 1007.0], [962.0, 1062.0], [931.0, 1062.0]]], "lines": ["．．．ホラホラ", "蟹江梓ちゃん", "と！！"]}, {"box": [664, 1310, 771, 1453], "vertical": true, "font_size": 24, "lines_coords": [[[745.0, 1312.0], [771.0, 1312.0], [771.0, 1409.0], [745.0, 1409.0]], [[718.0, 1312.0], [740.0, 1312.0], [740.0, 1453.0], [718.0, 1453.0]], [[689.0, 1310.0], [715.0, 1310.0], [715.0, 1431.0], [689.0, 1431.0]], [[664.0, 1312.0], [685.0, 1312.0], [685.0, 1407.0], [664.0, 1407.0]]], "lines": ["あん時も", "今日みたいに", "雨降ってた", "じゃん！！"]}, {"box": [293, 1274, 321, 1535], "vertical": true, "font_size": 28, "lines_coords": [[[293.0, 1274.0], [321.0, 1274.0], [321.0, 1535.0], [293.0, 1535.0]]], "lines": ["「．．．そうでしたっけ？」"]}, {"box": [292, 1275, 318, 1531], "vertical": true, "font_size": 26, "lines_coords": [[[292.0, 1275.0], [318.0, 1275.0], [318.0, 1531.0], [292.0, 1531.0]]], "lines": ["「．．．そうでしたっけ？」"]}, {"box": [121, 1273, 240, 1506], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 1275.0], [240.0, 1275.0], [240.0, 1506.0], [214.0, 1506.0]], [[182.0, 1275.0], [209.0, 1275.0], [209.0, 1406.0], [182.0, 1406.0]], [[151.0, 1273.0], [178.0, 1273.0], [178.0, 1506.0], [151.0, 1506.0]], [[121.0, 1275.0], [143.0, 1275.0], [143.0, 1385.0], [121.0, 1385.0]]], "lines": ["ブンフンはなんだか", "面倒なので", "すっとぼけることに", "しました。"]}], "img_path": "207.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [892, 71, 997, 211], "vertical": true, "font_size": 22, "lines_coords": [[[975.0, 73.0], [996.0, 73.0], [996.0, 164.0], [975.0, 164.0]], [[946.0, 71.0], [968.0, 71.0], [968.0, 190.0], [946.0, 190.0]], [[918.0, 71.0], [940.0, 71.0], [940.0, 209.0], [918.0, 209.0]], [[892.0, 71.0], [914.0, 71.0], [914.0, 210.0], [892.0, 210.0]]], "lines": ["そうだよ", "そうだよー", "だんだん思い", "出してきた！！"]}, {"box": [551, 157, 662, 325], "vertical": true, "font_size": 25, "lines_coords": [[[635.0, 159.0], [662.0, 159.0], [662.0, 301.0], [635.0, 301.0]], [[604.0, 157.0], [635.0, 157.0], [635.0, 325.0], [604.0, 325.0]], [[581.0, 160.0], [603.0, 160.0], [603.0, 301.0], [581.0, 301.0]], [[551.0, 160.0], [573.0, 160.0], [573.0, 325.0], [551.0, 325.0]]], "lines": ["君、髪立てて", "ブランドものの", "Ｔシャツとか", "着ちゃってさぁ。"]}, {"box": [346, 85, 452, 306], "vertical": true, "font_size": 22, "lines_coords": [[[429.0, 87.0], [451.0, 87.0], [451.0, 225.0], [429.0, 225.0]], [[401.0, 87.0], [423.0, 87.0], [423.0, 300.0], [401.0, 300.0]], [[375.0, 85.0], [396.0, 85.0], [396.0, 306.0], [375.0, 306.0]], [[346.0, 85.0], [368.0, 85.0], [368.0, 231.0], [346.0, 231.0]]], "lines": ["．．．ああ今日も", "ママの美貌に見とれ、", "小生早くも酔っ払って", "しまいました。"]}, {"box": [112, 210, 170, 289], "vertical": true, "font_size": 32, "lines_coords": [[[135.0, 210.0], [170.0, 210.0], [170.0, 289.0], [135.0, 289.0]], [[112.0, 212.0], [142.0, 212.0], [142.0, 289.0], [112.0, 289.0]]], "lines": ["嫌だワ", "社長！！"]}, {"box": [529, 375, 610, 551], "vertical": true, "font_size": 25, "lines_coords": [[[585.0, 376.0], [609.0, 376.0], [610.0, 534.0], [587.0, 534.0]], [[556.0, 375.0], [582.0, 375.0], [581.0, 551.0], [554.0, 551.0]], [[531.0, 378.0], [553.0, 378.0], [551.0, 548.0], [529.0, 548.0]]], "lines": ["はりきっちゃっ", "てるなー、この子", "って思ったもん。"]}, {"box": [78, 467, 187, 654], "vertical": true, "font_size": 26, "lines_coords": [[[160.0, 470.0], [187.0, 470.0], [187.0, 609.0], [160.0, 609.0]], [[132.0, 468.0], [159.0, 468.0], [1