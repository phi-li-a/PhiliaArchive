0, 35.0], [678.0, 35.0], [678.0, 167.0], [650.0, 167.0]], [[618.0, 35.0], [645.0, 35.0], [645.0, 237.0], [618.0, 237.0]], [[589.0, 35.0], [610.0, 35.0], [610.0, 170.0], [589.0, 170.0]]], "lines": ["「いやあ、", "心配ご無用、", "全然酔ってなんて", "いませんよ。"]}, {"box": [381, 29, 534, 215], "vertical": true, "font_size": 29, "lines_coords": [[[506.0, 31.0], [534.0, 31.0], [534.0, 135.0], [506.0, 135.0]], [[476.0, 29.0], [510.0, 31.0], [504.0, 142.0], [470.0, 140.0]], [[445.0, 31.0], [471.0, 31.0], [470.0, 214.0], [443.0, 214.0]], [[414.0, 31.0], [442.0, 31.0], [439.0, 187.0], [410.0, 187.0]], [[381.0, 32.0], [407.0, 32.0], [407.0, 200.0], [381.0, 200.0]]], "lines": ["ところで", "お姉さん、", "お姉さんの乳首", "引っぱっても", "いいですか？」"]}, {"box": [898, 418, 929, 475], "vertical": true, "font_size": 28, "lines_coords": [[[898.0, 418.0], [929.0, 418.0], [929.0, 475.0], [898.0, 475.0]]], "lines": ["え？"]}, {"box": [845, 462, 871, 559], "vertical": true, "font_size": 28, "lines_coords": [[[845.0, 462.0], [871.0, 462.0], [871.0, 559.0], [845.0, 559.0]]], "lines": ["なんて？"]}, {"box": [854, 1045, 910, 1174], "vertical": true, "font_size": 24, "lines_coords": [[[887.0, 1048.0], [909.0, 1048.0], [909.0, 1173.0], [887.0, 1173.0]], [[857.0, 1045.0], [884.0, 1045.0], [881.0, 1167.0], [854.0, 1167.0]]], "lines": ["「あの文章は", "まぐれだし、"]}, {"box": [718, 1045, 801, 1207], "vertical": true, "font_size": 24, "lines_coords": [[[775.0, 1046.0], [798.0, 1046.0], [800.0, 1207.0], [776.0, 1207.0]], [[748.0, 1048.0], [770.0, 1048.0], [770.0, 1164.0], [748.0, 1164.0]], [[718.0, 1045.0], [745.0, 1045.0], [745.0, 1167.0], [718.0, 1167.0]]], "lines": ["褒められたって", "調子に乗る", "だけですし、"]}, {"box": [521, 1046, 662, 1207], "vertical": true, "font_size": 25, "lines_coords": [[[634.0, 1046.0], [662.0, 1046.0], [662.0, 1126.0], [634.0, 1126.0]], [[606.0, 1046.0], [634.0, 1046.0], [631.0, 1184.0], [603.0, 1184.0]], [[576.0, 1046.0], [603.0, 1046.0], [603.0, 1142.0], [576.0, 1142.0]], [[551.0, 1048.0], [573.0, 1048.0], [573.0, 1206.0], [551.0, 1206.0]], [[521.0, 1046.0], [543.0, 1046.0], [543.0, 1193.0], [521.0, 1193.0]]], "lines": ["あと僕、", "一応童貞じゃ", "ないんで", "馬鹿にしないで", "もらえます？」"]}, {"box": [145, 809, 216, 931], "vertical": true, "font_size": 20, "lines_coords": [[[193.0, 809.0], [215.0, 809.0], [215.0, 931.0], [193.0, 931.0]], [[167.0, 809.0], [189.0, 809.0], [189.0, 893.0], [167.0, 893.0]], [[145.0, 809.0], [162.0, 809.0], [162.0, 912.0], [145.0, 912.0]]], "lines": ["ゴーョゴニョ", "聞きとれ", "ないって！！"]}, {"box": [912, 1300, 990, 1439], "vertical": true, "font_size": 22, "lines_coords": [[[967.0, 1300.0], [989.0, 1300.0], [989.0, 1439.0], [967.0, 1439.0]], [[940.0, 1300.0], [962.0, 1300.0], [962.0, 1417.0], [940.0, 1417.0]], [[912.0, 1300.0], [934.0, 1300.0], [934.0, 1415.0], [912.0, 1415.0]]], "lines": ["．．．いつだって", "本当の敵は", "己自身．．．"]}, {"box": [425, 1357, 535, 1543], "vertical": true, "font_size": 23, "lines_coords": [[[507.0, 1357.0], [535.0, 1357.0], [535.0, 1454.0], [507.0, 1454.0]], [[481.0, 1357.0], [504.0, 1357.0], [503.0, 1520.0], [479.0, 1520.0]], [[453.0, 1359.0], [473.0, 1359.0], [473.0, 1543.0], [453.0, 1543.0]], [[425.0, 1359.0], [445.0, 1359.0], [445.0, 1520.0], [425.0, 1520.0]]], "lines": ["しかして", "オノッティーに", "俺のこの裁紙さは", "わかるまい．．．"]}, {"box": [310, 1106, 395, 1316], "vertical": true, "font_size": 26, "lines_coords": [[[371.0, 1110.0], [393.0, 1110.0], [393.0, 1237.0], [371.0, 1237.0]], [[340.0, 1107.0], [367.0, 1107.0], [367.0, 1315.0], [340.0, 1315.0]], [[310.0, 1106.0], [339.0, 1106.0], [340.0, 1206.0], [312.0, 1206.0]]], "lines": ["「三村のこと", "別に嫌いじゃないん", "ですけど、"]}, {"box": [104, 1106, 271, 1339], "vertical": true, "font_size": 23, "lines_coords": [[[246.0, 1107.0], [268.0, 1107.0], [267.0, 1317.0], [245.0, 1317.0]], [[217.0, 1107.0], [239.0, 1107.0], [239.0, 1312.0], [217.0, 1312.0]], [[190.0, 1109.0], [212.0, 1109.0], [212.0, 1270.0], [190.0, 1270.0]], [[160.0, 1107.0], [187.0, 1107.0], [187.0, 1317.0], [160.0, 1317.0]], [[134.0, 1107.0], [156.0, 1107.0], [156.0, 1339.0], [134.0, 1339.0]], [[106.0, 1106.0], [128.0, 1106.0], [126.0, 1259.0], [104.0, 1259.0]]], "lines": ["彼に恋人ができた時", "妄想かフーちゃんで", "あってほしいと", "心から願ったことは", "是非秘密にしておいて", "もらえます？」"]}], "img_path": "217.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [790, 234, 851, 315], "vertical": false, "font_size": 32, "lines_coords": [[[820.0, 234.0], [851.0, 303.0], [823.0, 315.0], [790.0, 248.0]]], "lines": ["川本へ．．"]}, {"box": [679, 260, 796, 409], "vertical": false, "font_size": 25, "lines_coords": [[[701.0, 271.0], [775.0, 396.0], [753.0, 409.0], [679.0, 284.0]], [[728.0, 260.0], [796.0, 384.0], [775.0, 395.0], [706.0, 271.0]]], "lines": ["川安や料織．．", "．．．ご飯物〜と"]}, {"box": [590, 32, 673, 219], "vertical": true, "font_size": 22, "lines_coords": [[[648.0, 34.0], [670.0, 34.0], [670.0, 146.0], [648.0, 146.0]], [[620.0, 34.0], [642.0, 34.0], [642.0, 148.0], [620.0, 148.0]], [[590.0, 32.0], [612.0, 32.0], [614.0, 218.0], [592.0, 218.0]]], "lines": ["だから僕に", "関わるのは", "危険ですっては．．．"]}, {"box": [443, 31, 553, 297], "vertical": true, "font_size": 24, "lines_coords": [[[525.0, 31.0], [553.0, 31.0], [553.0, 112.0], [525.0, 112.0]], [[496.0, 34.0], [518.0, 34.0], [518.0, 237.0], [496.0, 237.0]], [[468.0, 34.0], [490.0, 34.0], [490.0, 203.0], [468.0, 203.0]], [[443.0, 34.0], [465.0, 34.0], [465.0, 295.0], [443.0, 295.0]]], "lines": ["実は僕、", "魔界神ケルタークの", "使い魔なんです。", "あ、やっは今のウソです。"]}, {"box": [321, 128, 382, 372], "vertical": true, "font_size": 26, "lines_coords": [[[353.0, 128.0], [379.0, 128.0], [382.0, 335.0], [356.0, 335.0]], [[321.0, 128.0], [348.0, 128.0], [350.0, 371.0], [323.0, 371.0]]], "lines": ["捜しても捜しでも", "見つからないんです。"]}, {"box": [223, 127, 279, 385], "vertical": true, "font_size": 22, "lines_coords": [[[254.0, 129.0], [276.0, 129.0], [276.0, 382.0], [254.0, 382.0]], [[223.0, 131.0], [245.0, 131.0], [245.0, 343.0], [223.0, 343.0]]], "lines": ["もうどうしたらいいか", "わからないんです。"]}, {"box": [120, 128, 176, 373], "vertical": true, "font_size": 24, "lines_coords": [[[150.0, 128.0], [176.0, 128.0], [176.0, 234.0], [150.0, 234.0]], [[120.0, 129.0], [142.0, 129.0], [143.0, 367.0], [121.0, 367.0]]], "lines": ["でももう", "やるしかないんです。"]}, {"box": [603, 425, 625, 564], "vertical": true, "font_size": 21, "lines_coords": [[[603.0, 425.0], [625.0, 425.0], [625.0, 564.0], [603.0, 564.0]]], "lines": ["．．．コミュニは影。"]}, {"box": [575, 403, 596, 564], "vertical": true, "font_size": 21, "lines_coords": [[[575.0, 403.0], [596.0, 403.0], [596.0, 564.0], [575.0, 564.0]]], "lines": ["そんなこと．．．"]}, {"box": [482, 479, 534, 662], "vertical": true, "font_size": 21, "lines_coords": [[[517.0, 520.0], [534.0, 520.0], [534.0, 562.0], [517.0, 562.0]], [[482.0, 479.0], [509.0, 479.0], [509.0, 662.0], [482.0, 662.0]]], "lines": ["．．．", "２０１７年４月３１日"]}, {"box": [459, 556, 535, 659], "vertical": true, "font_size": 21, "lines_coords": [[[514.0, 556.0], [535.0, 556.0], [535.0, 659.0], [514.0, 659.0]], [[459.0, 557.0], [476.0, 557.0], [476.0, 657.0], [459.0, 657.0]]], "lines": ["ーーン！！", "当ＦＹで"]}, {"box": [915, 734, 1006, 871], "vertical": false, "font_size": 25, "lines_coords": [[[937.0, 734.0], [1006.0, 860.0], [984.0, 871.0], [915.0, 745.0]]], "lines": ["．．．マーヘ４４リリー"]}, {"box": [845, 756, 917, 857], "vertical": false, "font_size": 25, "lines_coords": [[[867.0, 756.0], [917.0, 845.0], [895.0, 857.0], [845.0, 767.0]]], "lines": ["．．．だいたい"]}, {"box": [173, 848, 254, 953], "vertical": false, "font_size": 26, "lines_coords": [[[200.0, 848.0], [254.0, 937.0], [228.0, 953.0], [173.0, 864.0]]], "lines": ["バケーーッ"]}, {"box": [128, 925, 214, 1040], "vertical": false, "font_size": 26, "lines_coords": [[[162.0, 925.0], [214.0, 1017.0], [193.0, 1028.0], [142.0, 935.0]], [[148.0, 954.0], [192.0, 1028.0], [171.0, 1040.0], [128.0, 967.0]]], "lines": ["．．．おおお", "バッ！！"]}, {"box": [659, 1171, 751, 1354], "vertical": true, "font_size": 27, "lines_coords": [[[717.0, 1171.0], [751.0, 1171.0], [751.0, 1264.0], [717.0, 1264.0]], [[689.0, 1173.0], [715.0, 1173.0], [715.0, 1325.0], [689.0, 1325.0]], [[659.0, 1175.0], [681.0, 1175.0], [681.0, 1351.0], [659.0, 1351.0]]], "lines": ["この頃、", "おかしい人の", "ふりをしてると"]}, {"box": [505, 1171, 564, 1378], "vertical": true, "font_size": 24, "lines_coords": [[[534.0, 1171.0], [560.0, 1171.0], [560.0, 1375.0], [534.0, 1375.0]], [[506.0, 1175.0], [528.0, 1175.0], [528.0, 1335.0], [506.0, 1335.0]]], "lines": ["なんだかとっても", "落ちつきます。"]}, {"box": [353, 1172, 411, 1325], "vertical": true, "font_size": 22, "lines_coords": [[[384.0, 1175.0], [406.0, 1175.0], [406.0, 1323.0], [384.0, 1323.0]], [[353.0, 1173.0], [375.0, 1173.0], [375.0, 1275.0], [353.0, 1275.0]]], "lines": ["最低でしょ！？", "フフフ！！"]}, {"box": [157, 1365, 184, 1454], "vertical": true, "font_size": 27, "lines_coords": [[[157.0, 1365.0], [184.0, 1365.0], [184.0, 1451.0], [157.0, 1451.0]]], "lines": ["おーい"]}], "img_path": "218.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [740, 208, 763, 292], "vertical": true, "font_size": 17, "lines_coords": [[[743.0, 245.0], [760.0, 245.0], [760.0, 281.0], [743.0, 281.0]]], "lines": ["．．．"]}, {"box": [690, 472, 714, 636], "vertical": true, "font_size": 20, "lines_coords": [[[690.0, 473.0], [710.0, 473.0], [710.0, 629.0], [690.0, 629.0]]], "lines": ["愛子ちゃんた"]}, {"box": [636, 757, 662, 897], "vertical": true, "font_size": 20, "lines_coords": [[[639.0, 757.0], [659.0, 757.0], [659.0, 892.0], [639.0, 892.0]]], "lines": ["．．．遠いなぁ。"]}, {"box": [350, 1160, 373, 1227], "vertical": true, "font_size": 23, "lines_coords": [[[350.0, 1160.0], [373.0, 1160.0], [373.0, 1198.0], [350.0, 1198.0]]], "lines": ["おー"]}, {"box": [525, 1143, 615, 1410], "vertical": true, "font_size": 25, "lines_coords": [[[590.0, 1145.0], [612.0, 1145.0], [612.0, 1293.0], [590.0, 1293.0]], [[554.0, 1143.0], [581.0, 1143.0], [581.0, 1273.0], [554.0, 1273.0]], [[525.0, 1143.0], [551.0, 1143.0], [551.0, 1410.0], [525.0, 1410.0]]], "lines": ["愛子ちゃんは", "いつだって", "ちょっとだけ遠いなぁ。"]}], "img_path": "219.png"}, {"version": "0.2.0-beta.6", "img_width": 1100, "img_height": 1600, "b