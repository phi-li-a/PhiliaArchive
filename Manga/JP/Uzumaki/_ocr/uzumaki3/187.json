{"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [706, 107, 773, 222], "vertical": true, "font_size": 18, "lines_coords": [[[754.0, 107.0], [772.0, 107.0], [771.0, 221.0], [753.0, 221.0]], [[731.0, 108.0], [747.0, 108.0], [747.0, 222.0], [731.0, 222.0]], [[706.0, 107.0], [726.0, 107.0], [726.0, 222.0], [706.0, 222.0]]], "lines": ["ああ．．．何だ．．．", "あんたらか．．．", "覚えてるよ．．．"]}, {"box": [421, 93, 466, 292], "vertical": true, "font_size": 20, "lines_coords": [[[444.0, 93.0], [465.0, 93.0], [466.0, 292.0], [445.0, 292.0]], [[421.0, 94.0], [441.0, 94.0], [441.0, 235.0], [421.0, 235.0]]], "lines": ["何年ぶりだ？ちっとも", "変わってないな。"]}, {"box": [117, 96, 165, 247], "vertical": true, "font_size": 20, "lines_coords": [[[145.0, 96.0], [165.0, 96.0], [165.0, 210.0], [145.0, 210.0]], [[117.0, 97.0], [137.0, 97.0], [137.0, 247.0], [117.0, 247.0]]], "lines": ["．．．もう何年も", "経ったんですか？"]}, {"box": [680, 343, 770, 523], "vertical": true, "font_size": 20, "lines_coords": [[[750.0, 344.0], [770.0, 344.0], [770.0, 460.0], [750.0, 460.0]], [[724.0, 344.0], [744.0, 344.0], [746.0, 486.0], [726.0, 486.0]], [[700.0, 343.0], [724.0, 343.0], [724.0, 478.0], [700.0, 478.0]], [[680.0, 346.0], [697.0, 346.0], [697.0, 521.0], [680.0, 521.0]]], "lines": ["ああ．．．増築も", "かなり進んでる。", "だが、まだ所々", "つながってないがね。"]}, {"box": [223, 345, 339, 525], "vertical": true, "font_size": 22, "lines_coords": [[[319.0, 346.0], [339.0, 346.0], [339.0, 499.0], [319.0, 499.0]], [[294.0, 348.0], [317.0, 348.0], [317.0, 499.0], [294.0, 499.0]], [[273.0, 346.0], [293.0, 346.0], [293.0, 496.0], [273.0, 496.0]], [[247.0, 345.0], [268.0, 345.0], [270.0, 499.0], [249.0, 499.0]], [[223.0, 346.0], [247.0, 346.0], [247.0, 525.0], [223.0, 525.0]]], "lines": ["その上、露地には", "コンクリートだの", "土手の名残りだの", "障害物が残ってる", "から、まるで迷路だ。"]}, {"box": [123, 405, 193, 544], "vertical": true, "font_size": 22, "lines_coords": [[[171.0, 405.0], [192.0, 405.0], [193.0, 544.0], [172.0, 544.0]], [[146.0, 406.0], [167.0, 406.0], [169.0, 521.0], [148.0, 521.0]], [[123.0, 406.0], [147.0, 406.0], [147.0, 469.0], [123.0, 469.0]]], "lines": ["．．．だから俺は今、", "露地の整備で", "大変だ"]}, {"box": [631, 614, 768, 783], "vertical": true, "font_size": 19, "lines_coords": [[[750.0, 615.0], [766.0, 615.0], [766.0, 783.0], [750.0, 783.0]], [[726.0, 616.0], [743.0, 616.0], [743.0, 783.0], [726.0, 783.0]], [[700.0, 614.0], [721.0, 614.0], [721.0, 696.0], [700.0, 696.0]], [[673.0, 614.0], [697.0, 614.0], [699.0, 750.0], [676.0, 750.0]], [[653.0, 615.0], [673.0, 615.0], [673.0, 748.0], [653.0, 748.0]], [[631.0, 615.0], [648.0, 615.0], [648.0, 771.0], [631.0, 771.0]]], "lines": ["しかし、近いうちに", "増築は終わるだろう", "．．．今では、", "長屋の中にいる", "連中が内側から", "増築してるんだよ。"]}, {"box": [326, 616, 373, 748], "vertical": true, "font_size": 20, "lines_coords": [[[355.0, 617.0], [371.0, 617.0], [371.0, 747.0], [355.0, 747.0]], [[326.0, 616.0], [351.0, 616.0], [351.0, 684.0], [326.0, 684.0]]], "lines": ["まったく器用な", "連中だ。"]}, {"box": [278, 619, 303, 683], "vertical": true, "font_size": 25, "lines_coords": [[[278.0, 619.0], [303.0, 619.0], [303.0, 683.0], [278.0, 683.0]]], "lines": ["あの．．"]}, {"box": [345, 843, 388, 937], "vertical": true, "font_size": 16, "lines_coords": [[[369.0, 843.0], [385.0, 843.0], [385.0, 937.0], [369.0, 937.0]], [[345.0, 843.0], [362.0, 843.0], [362.0, 925.0], [345.0, 925.0]]], "lines": ["父は陶芸家", "なんです。"]}, {"box": [685, 833, 774, 1050], "vertical": true, "font_size": 19, "lines_coords": [[[753.0, 835.0], [773.0, 835.0], [773.0, 931.0], [753.0, 931.0]], [[726.0, 833.0], [751.0, 833.0], [753.0, 1050.0], [729.0, 1050.0]], [[709.0, 837.0], [725.0, 837.0], [725.0, 1025.0], [709.0, 1025.0]], [[685.0, 836.0], [702.0, 836.0], [702.0, 931.0], [685.0, 931.0]]], "lines": ["私、両親を", "捜してるんです．．．２人共、", "竜巻に巻き込まれたん", "ですけど．．"]}, {"box": [287, 857, 307, 952], "vertical": true, "font_size": 20, "lines_coords": [[[287.0, 857.0], [307.0, 857.0], [307.0, 952.0], [287.0, 952.0]]], "lines": ["．．．陶芸家？"]}]}