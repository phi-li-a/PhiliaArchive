{"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [622, 85, 720, 168], "vertical": true, "font_size": 25, "lines_coords": [[[693.0, 89.0], [718.0, 87.0], [720.0, 167.0], [696.0, 168.0]], [[673.0, 87.0], [693.0, 87.0], [693.0, 167.0], [673.0, 167.0]], [[651.0, 89.0], [672.0, 89.0], [672.0, 167.0], [651.0, 167.0]], [[622.0, 85.0], [653.0, 85.0], [653.0, 133.0], [622.0, 133.0]]], "lines": ["ケガして", "ますね．．．", "歩けます", "か？"]}, {"box": [626, 89, 716, 167], "vertical": false, "font_size": 78, "lines_coords": [[[626.0, 89.0], [716.0, 89.0], [716.0, 167.0], [626.0, 167.0]]], "lines": ["ゲガしてますね．．．歩けますか？"]}, {"box": [437, 94, 535, 203], "vertical": true, "font_size": 25, "lines_coords": [[[506.0, 94.0], [535.0, 94.0], [535.0, 159.0], [506.0, 159.0]], [[481.0, 94.0], [513.0, 94.0], [513.0, 161.0], [481.0, 161.0]], [[461.0, 98.0], [486.0, 98.0], [486.0, 176.0], [461.0, 176.0]], [[437.0, 98.0], [457.0, 98.0], [460.0, 203.0], [440.0, 203.0]]], "lines": ["満男！", "もっと", "ゆっくり", "歩きなさい。"]}, {"box": [307, 99, 403, 291], "vertical": true, "font_size": 19, "lines_coords": [[[382.0, 100.0], [402.0, 100.0], [402.0, 254.0], [382.0, 254.0]], [[356.0, 99.0], [377.0, 99.0], [378.0, 291.0], [357.0, 291.0]], [[328.0, 100.0], [348.0, 100.0], [349.0, 255.0], [329.0, 255.0]], [[308.0, 103.0], [323.0, 103.0], [323.0, 251.0], [308.0, 251.0]]], "lines": ["私：東洋テレビで", "リポーターをやってる", "丸山千恵という者", "なんですけど．．．"]}, {"box": [64, 91, 109, 389], "vertical": true, "font_size": 18, "lines_coords": [[[85.0, 91.0], [105.0, 91.0], [108.0, 389.0], [89.0, 389.0]], [[64.0, 91.0], [80.0, 91.0], [83.0, 365.0], [66.0, 365.0]]], "lines": ["東洋テレビ？やっぱり．．．どこかで", "見た事あるなって思ったんです。"]}, {"box": [672, 432, 722, 548], "vertical": true, "font_size": 18, "lines_coords": [[[693.0, 432.0], [713.0, 432.0], [713.0, 548.0], [693.0, 548.0]], [[672.0, 433.0], [689.0, 433.0], [689.0, 534.0], [672.0, 534.0]]], "lines": ["私は五島桐絵", "といいます。"]}, {"box": [439, 417, 554, 541], "vertical": true, "font_size": 21, "lines_coords": [[[528.0, 417.0], [554.0, 417.0], [554.0, 480.0], [528.0, 480.0]], [[507.0, 419.0], [527.0, 419.0], [527.0, 515.0], [507.0, 515.0]], [[485.0, 419.0], [506.0, 419.0], [506.0, 505.0], [485.0, 505.0]], [[460.0, 418.0], [481.0, 418.0], [481.0, 495.0], [460.0, 495.0]], [[439.0, 419.0], [455.0, 419.0], [455.0, 541.0], [439.0, 541.0]]], "lines": ["これは", "弟の満男．．．", "今２人で", "食料探し", "してたんです。"]}, {"box": [344, 419, 412, 571], "vertical": true, "font_size": 20, "lines_coords": [[[391.0, 419.0], [411.0, 419.0], [411.0, 535.0], [391.0, 535.0]], [[366.0, 420.0], [386.0, 420.0], [387.0, 571.0], [368.0, 571.0]], [[344.0, 419.0], [364.0, 419.0], [364.0, 498.0], [344.0, 498.0]]], "lines": ["私．．．今とても", "頭が混乱してるん", "だけど．．．"]}, {"box": [187, 413, 251, 494], "vertical": true, "font_size": 29, "lines_coords": [[[227.0, 414.0], [251.0, 414.0], [251.0, 494.0], [227.0, 494.0]], [[198.0, 413.0], [232.0, 413.0], [232.0, 461.0], [198.0, 461.0]]], "lines": ["この町は", "一体"]}, {"box": [58, 418, 127, 574], "vertical": true, "font_size": 21, "lines_coords": [[[107.0, 419.0], [127.0, 419.0], [127.0, 515.0], [107.0, 515.0]], [[84.0, 419.0], [104.0, 419.0], [104.0, 535.0], [84.0, 535.0]], [[58.0, 418.0], [82.0, 418.0], [82.0, 574.0], [58.0, 574.0]]], "lines": ["やっぱり．．．", "竜巻の被害に", "遭ったんですね？"]}, {"box": [573, 673, 713, 848], "vertical": true, "font_size": 20, "lines_coords": [[[692.0, 675.0], [712.0, 675.0], [712.0, 817.0], [692.0, 817.0]], [[668.0, 675.0], [689.0, 675.0], [690.0, 848.0], [669.0, 848.0]], [[645.0, 676.0], [665.0, 676.0], [665.0, 799.0], [645.0, 799.0]], [[622.0, 676.0], [642.0, 676.0], [642.0, 792.0], [622.0, 792.0]], [[596.0, 673.0], [617.0, 673.0], [618.0, 829.0], [597.0, 829.0]], [[573.0, 673.0], [594.0, 673.0], [596.0, 780.0], [575.0, 780.0]]], "lines": ["．．．今この町では", "人間のちょっとした", "素早い動作が、", "大きな竜巻を", "引き起こす状態に", "あるんです。"]}, {"box": [337, 677, 527, 851], "vertical": true, "font_size": 20, "lines_coords": [[[503.0, 678.0], [523.0, 678.0], [523.0, 812.0], [503.0, 812.0]], [[479.0, 677.