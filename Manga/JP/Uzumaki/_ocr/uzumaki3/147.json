{"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [706, 66, 777, 173], "vertical": true, "font_size": 23, "lines_coords": [[[755.0, 70.0], [777.0, 70.0], [774.0, 168.0], [753.0, 168.0]], [[729.0, 66.0], [760.0, 66.0], [760.0, 116.0], [729.0, 116.0]], [[709.0, 70.0], [730.0, 70.0], [727.0, 173.0], [706.0, 173.0]]], "lines": ["竹本さん達", "じゃ", "ないですか。"]}, {"box": [595, 72, 638, 168], "vertical": true, "font_size": 23, "lines_coords": [[[618.0, 72.0], [638.0, 72.0], [638.0, 168.0], [618.0, 168.0]], [[595.0, 72.0], [616.0, 72.0], [616.0, 150.0], [595.0, 150.0]]], "lines": ["どうしたん", "ですか？"]}, {"box": [343, 75, 371, 137], "vertical": true, "font_size": 26, "lines_coords": [[[343.0, 76.0], [369.0, 75.0], [371.0, 135.0], [345.0, 137.0]]], "lines": ["えっ？"]}, {"box": [703, 418, 773, 564], "vertical": true, "font_size": 21, "lines_coords": [[[748.0, 418.0], [772.0, 418.0], [772.0, 564.0], [748.0, 564.0]], [[729.0, 420.0], [748.0, 420.0], [748.0, 537.0], [729.0, 537.0]], [[703.0, 419.0], [723.0, 419.0], [725.0, 542.0], [705.0, 542.0]]], "lines": ["私達、今町から", "脱出しようと", "してるんです。"]}, {"box": [440, 432, 506, 594], "vertical": true, "font_size": 19, "lines_coords": [[[486.0, 432.0], [506.0, 432.0], [506.0, 573.0], [486.0, 573.0]], [[461.0, 433.0], [481.0, 433.0], [481.0, 585.0], [461.0, 585.0]], [[440.0, 433.0], [457.0, 433.0], [457.0, 591.0], [440.0, 591.0]]], "lines": ["もう少し行けば、", "隣町に続く山道に", "出るはずなんです。"]}, {"box": [335, 418, 401, 571], "vertical": true, "font_size": 18, "lines_coords": [[[379.0, 418.0], [398.0, 418.0], [400.0, 571.0], [382.0, 571.0]], [[357.0, 419.0], [377.0, 419.0], [377.0, 553.0], [357.0, 553.0]], [[335.0, 419.0], [351.0, 419.0], [351.0, 553.0], [335.0, 553.0]]], "lines": ["何を言ってる．．．？", "隣町への山道は", "そっちだろう．．．"]}, {"box": [220, 246, 309, 378], "vertical": true, "font_size": 20, "lines_coords": [[[291.0, 247.0], [308.0, 247.0], [308.0, 341.0], [291.0, 341.0]], [[264.0, 246.0], [290.0, 246.0], [290.0, 308.0], [264.0, 308.0]], [[242.0, 247.0], [262.0, 247.0], [262.0, 325.0], [242.0, 325.0]], [[220.0, 247.0], [236.0, 247.0], [236.0, 377.0], [220.0, 377.0]]], "lines": ["．．．どうした", "って．．．", "君達こそ", "どうしたんだ？"]}, {"box": [105, 411, 148, 591], "vertical": true, "font_size": 19, "lines_coords": [[[127.0, 411.0], [148.0, 411.0], [146.0, 548.0], [125.0, 548.0]], [[106.0, 413.0], [123.0, 413.0], [123.0, 589.0], [106.0, 589.0]]], "lines": ["俺達も今、町を", "出てきたところだぜ。"]}, {"box": [710, 664, 776, 839], "vertical": true, "font_size": 20, "lines_coords": [[[754.0, 664.0], [774.0, 664.0], [774.0, 819.0], [754.0, 819.0]], [[732.0, 665.0], [752.0, 665.0], [752.0, 839.0], [732.0, 839.0]], [[710.0, 665.0], [730.0, 665.0], [730.0, 686.0], [710.0, 686.0]]], "lines": ["えっ．．．どの道から", "山に入ったんですか", "？"]}, {"box": [460, 652, 534, 855], "vertical": true, "font_size": 22, "lines_coords": [[[513.0, 655.0], [534.0, 655.0], [530.0, 808.0], [509.0, 808.0]], [[489.0, 656.0], [509.0, 656.0], [507.0, 776.0], [487.0, 776.0]], [[465.0, 652.0], [488.0, 652.0], [484.0, 855.0], [460.0, 855.0]]], "lines": ["私達は黒渦高校の", "脇を通る道を、", "登ってきたんですけど。"]}, {"box": [700, 894, 767, 1085], "vertical": true, "font_size": 20, "lines_coords": [[[747.0, 896.0], [767.0, 896.0], [767.0, 993.0], [747.0, 993.0]], [[723.0, 894.0], [744.0, 894.0], [743.0, 1085.0], [721.0, 1085.0]], [[700.0, 896.0], [717.0, 896.0], [717.0, 1011.0], [700.0, 1011.0]]], "lines": ["同じだよ．．．", "君達が登っていくのが", "見えたから．．．"]}, {"box": [462, 900, 533, 1062], "vertical": true, "font_size": 20, "lines_coords": [[[512.0, 902.0], [532.0, 902.0], [532.0, 1026.0], [512.0, 1026.0]], [[488.0, 901.0], [508.0, 901.0], [508.0, 1057.0], [488.0, 1057.0]], [[465.0, 900.0], [485.0, 900.0], [482.0, 1058.0], [462.0, 1058.0]]], "lines": ["だから俺達も、", "そのあとを追って", "来たんじゃないか。"]}, {"box": [127, 912, 220, 1085], "vertical": true, "font_size": 19, "lines_coords": [[[200.0, 915.0], [220.0, 915.0], [220.0, 1012.0], [200.0, 1012.0]], [[178.0, 916.0], [194.0, 916.0], [194.0, 1085.0], [178.0, 1085.0]], [[152.0, 915.0], [172.0, 915.0], 