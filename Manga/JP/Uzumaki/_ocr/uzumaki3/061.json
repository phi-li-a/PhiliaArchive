.0], [378.0, 537.0]], [[356.0, 383.0], [376.0, 383.0], [376.0, 480.0], [356.0, 480.0]]], "lines": ["．．．まさか．．．", "じゃあ、さっきの", "子供達は．．．"]}, {"box": [110, 390, 155, 485], "vertical": true, "font_size": 20, "lines_coords": [[[133.0, 391.0], [153.0, 391.0], [153.0, 485.0], [133.0, 485.0]], [[110.0, 390.0], [131.0, 390.0], [131.0, 467.0], [110.0, 467.0]]], "lines": ["私の大声の", "せいで！？"]}, {"box": [617, 584, 755, 720], "vertical": true, "font_size": 22, "lines_coords": [[[734.0, 585.0], [755.0, 585.0], [755.0, 664.0], [734.0, 664.0]], [[711.0, 587.0], [730.0, 587.0], [730.0, 684.0], [711.0, 684.0]], [[687.0, 585.0], [707.0, 585.0], [707.0, 719.0], [687.0, 719.0]], [[664.0, 584.0], [684.0, 584.0], [684.0, 720.0], [664.0, 720.0]], [[640.0, 584.0], [660.0, 584.0], [660.0, 704.0], [640.0, 704.0]], [[617.0, 585.0], [638.0, 585.0], [638.0, 663.0], [617.0, 663.0]]], "lines": ["．．．何て事", "カしら．．．私", "とんでもない事", "してしまったわ", "．．．あの子達", "今頃．．．．．"]}, {"box": [482, 643, 552, 742], "vertical": true, "font_size": 22, "lines_coords": [[[524.0, 644.0], [552.0, 644.0], [552.0, 672.0], [524.0, 672.0]], [[503.0, 643.0], [528.0, 643.0], [525.0, 742.0], [501.0, 742.0]], [[482.0, 646.0], [502.0, 646.0], [502.0, 741.0], [482.0, 741.0]]], "lines": ["私", "どうしたら", "いいの．．．？"]}, {"box": [391, 589, 437, 686], "vertical": true, "font_size": 20, "lines_coords": [[[415.0, 590.0], [435.0, 590.0], [435.0, 686.0], [415.0, 686.0]], [[393.0, 589.0], [414.0, 589.0], [412.0, 667.0], [391.0, 667.0]]], "lines": ["どうしたん", "ですか？"]}, {"box": [94, 578, 260, 696], "vertical": true, "font_size": 23, "lines_coords": [[[234.0, 580.0], [260.0, 580.0], [260.0, 643.0], [234.0, 643.0]], [[208.0, 578.0], [238.0, 578.0], [238.0, 643.0], [208.0, 643.0]], [[189.0, 582.0], [209.0, 582.0], [209.0, 677.0], [189.0, 677.0]], [[167.0, 583.0], [183.0, 583.0], [183.0, 694.0], [167.0, 694.0]], [[139.0, 580.0], [165.0, 580.0], [165.0, 642.0], [139.0, 642.0]], [[119.0, 583.0], [139.0, 583.0], [139.0, 696.0], [119.0, 696.0]], [[94.0, 581.0], [115.0,