0, 703.0], [744.0, 703.0], [744.0, 834.0], [724.0, 834.0]], [[699.0, 701.0], [720.0, 701.0], [718.0, 805.0], [697.0, 805.0]]], "lines": ["それには、この町の", "トンボ池の土が", "必要なんだ。"]}, {"box": [520, 707, 634, 898], "vertical": true, "font_size": 19, "lines_coords": [[[614.0, 710.0], [634.0, 710.0], [634.0, 882.0], [614.0, 882.0]], [[589.0, 708.0], [609.0, 708.0], [609.0, 897.0], [589.0, 897.0]], [[566.0, 710.0], [586.0, 710.0], [586.0, 846.0], [566.0, 846.0]], [[542.0, 707.0], [562.0, 707.0], [560.0, 882.0], [540.0, 882.0]], [[520.0, 708.0], [536.0, 708.0], [536.0, 861.0], [520.0, 861.0]]], "lines": ["トンボ池の土って．．．", "それは無理よ、あなた。", "トンボ池は今．．．", "大渦を巻いてるから", "土を採るなんて．．．"]}]}