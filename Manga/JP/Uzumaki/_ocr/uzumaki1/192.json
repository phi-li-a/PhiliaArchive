.0], [91.0, 515.0], [75.0, 515.0]]], "lines": ["危険だわ．．．", "あまり", "見ないように", "しなきゃ！"]}, {"box": [692, 600, 737, 754], "vertical": true, "font_size": 20, "lines_coords": [[[716.0, 600.0], [736.0, 600.0], [736.0, 754.0], [716.0, 754.0]], [[692.0, 600.0], [712.0, 600.0], [712.0, 737.0], [692.0, 737.0]]], "lines": ["．．．でも、私だって", "負けないわよ．．．"]}, {"box": [491, 602, 558, 758], "vertical": true, "font_size": 18, "lines_coords": [[[538.0, 603.0], [555.0, 603.0], [556.0, 737.0], [539.0, 737.0]], [[512.0, 602.0], [532.0, 602.0], [534.0, 719.0], [514.0, 719.0]], [[491.0, 603.0], [507.0, 603.0], [510.0, 758.0], [493.0, 758.0]]], "lines": ["今にあなたより", "目立つ存在に", "なってみせる：！！！"]}, {"box": [352, 582, 445, 744], "vertical": true, "font_size": 20, "lines_coords": [[[424.0, 584.0], [440.0, 584.0], [440.0, 719.0], [424.0, 719.0]], [[398.0, 582.0], [423.0, 582.0], [423.0, 660.0], [398.0, 660.0]], [[376.0, 583.0], [396.0, 583.0], [396.0, 700.0], [376.0, 700.0]], [[352.0, 583.0], [372.0, 583.0], [372.0, 744.0], [352.0, 744.0]]], "lines": ["学校が終わると", "私は駅へ", "行かなければ", "なりませんでした。"]}, {"box": [719, 1036, 735, 1099], "vertical": true, "font_size": 16, "lines_coords": [[[719.0, 1036.0], [735.0, 1036.0], [735.0, 1099.0], [719.0, 1099.0]]], "lines": ["．．．．．．？"]}, {"box": [70, 960, 165, 1096], "vertical": true, "font_size": 22, "lines_coords": [[[144.0, 962.0], [164.0, 962.0], [164.0, 1096.0], [144.0, 1096.0]], [[120.0, 962.0], [140.0, 962.0], [140.0, 1080.0], [120.0, 1080.0]], [[93.0, 960.0], [114.0, 960.0], [116.0, 1078.0], [94.0, 1078.0]], [[70.0, 960.0], [96.0, 960.0], [96.0, 1012.0], [70.0, 1012.0]]], "lines": ["人の多く集まる", "所へ行く事を、", "髪が望むから", "です。"]}]}