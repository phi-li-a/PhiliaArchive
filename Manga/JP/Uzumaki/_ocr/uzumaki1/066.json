{"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [705, 80, 731, 144], "vertical": true, "font_size": 26, "lines_coords": [[[705.0, 80.0], [731.0, 80.0], [731.0, 144.0], [705.0, 144.0]]], "lines": ["桐絵．．．"]}, {"box": [419, 78, 492, 160], "vertical": true, "font_size": 25, "lines_coords": [[[463.0, 78.0], [492.0, 78.0], [492.0, 142.0], [463.0, 142.0]], [[442.0, 79.0], [467.0, 79.0], [467.0, 160.0], [442.0, 160.0]], [[419.0, 80.0], [440.0, 80.0], [440.0, 159.0], [419.0, 159.0]]], "lines": ["お袋は", "気づいて", "ないが．．．"]}, {"box": [362, 70, 386, 133], "vertical": true, "font_size": 24, "lines_coords": [[[362.0, 70.0], [386.0, 70.0], [386.0, 133.0], [362.0, 133.0]]], "lines": ["えっ．．．"]}, {"box": [68, 79, 89, 158], "vertical": true, "font_size": 21, "lines_coords": [[[68.0, 80.0], [89.0, 80.0], [89.0, 158.0], [68.0, 158.0]]], "lines": ["何の話？"]}, {"box": [640, 502, 738, 619], "vertical": true, "font_size": 22, "lines_coords": [[[717.0, 502.0], [737.0, 502.0], [737.0, 618.0], [717.0, 618.0]], [[685.0, 502.0], [710.0, 502.0], [708.0, 619.0], [683.0, 619.0]], [[664.0, 503.0], [684.0, 503.0], [684.0, 600.0], [664.0, 600.0]], [[640.0, 502.0], [661.0, 502.0], [661.0, 568.0], [640.0, 568.0]]], "lines": ["耳の奥にある", "「蝸牛」という", "音を感じる", "器官だ。"]}, {"box": [419, 270, 485, 453], "vertical": true, "font_size": 19, "lines_coords": [[[463.0, 270.0], [484.0, 270.0], [485.0, 370.0], [464.0, 370.0]], [[442.0, 273.0], [461.0, 273.0], [461.0, 426.0], [442.0, 426.0]], [[419.0, 273.0], [436.0, 273.0], [436.0, 451.0], [419.0, 451.0]]], "lines": ["これからも", "気づかないでいて", "もらわないと困るな。"]}, {"box": [291, 262, 383, 455], "vertical": true, "font_size": 19, "lines_coords": [[[362.0, 263.0], [382.0, 263.0], [382.0, 380.0], [362.0, 380.0]], [[337.0, 262.0], [357.0, 262.0], [358.0, 455.0], [338.0, 455.0]], [[314.0, 263.0], [334.0, 263.0], [334.0, 455.0], [314.0, 455.0]], [[291.0, 264.0], [308.0, 264.0], [308.0, 418.0], [291.0, 418.0]]], "lines": ["人間の体に．．．", "つむじや指紋の他には", "もううずまきはないと", "思っていたけど．．．"]}, {"box": [68, 268, 113, 405], "vertical": true, "font_size": 22, "lines_coords": [[[87.0, 268.0], [113.0, 268.0], [113.0, 330.0], [87.0, 330.0]], [[68.0, 269.0], [87.0, 269.0], [87.0, 405.0], [68.0, 405.0]]], "lines": ["．．．まだ", "あったんだよ！！"]}, {"box": [651, 781, 742, 955], "vertical": true, "font_size": 20, "lines_coords": [[[721.0, 782.0], [742.0, 782.0], [741.0, 955.0], [719.0, 955.0]], [[697.0, 782.0], [717.0, 782.0], [717.0, 937.0], [697.0, 937.0]], [[674.0, 782.0], [694.0, 782.0], [694.0, 881.0], [674.0, 881.0]], [[651.0, 782.0], [668.0, 782.0], [668.0, 936.0], [651.0, 936.0]]], "lines": ["．．．もし、お袋がこの", "うずまきの存在に", "気づいたら", "どうするだろう？"]}, {"box": [405, 608, 475, 744], "vertical": true, "font_size": 20, "lines_coords": [[[454.0, 608.0], [474.0, 608.0], [474.0, 744.0], [454.0, 744.0]], [[430.0, 609.0], [450.0, 609.0], [450.0, 725.0], [430.0, 725.0]], [[405.0, 608.0], [425.0, 608.0], [425.0, 710.0], [405.0, 710.0]]], "lines": ["今日、院長室の", "解剖図を見て", "気がついた。"]}, {"box": [327, 779, 419, 952], "vertical": true, "font_size": 19, "lines_coords": [[[400.0, 780.0], [417.0, 780.0], [417.0, 914.0], [400.0, 914.0]], [[375.0, 780.0], [395.0, 780.0], [395.0, 952.0], [375.0, 952.0]], [[351.0, 779.0], [369.0, 779.0], [370.0, 952.0], [352.0, 952.0]], [[327.0, 779.0], [347.0, 779.0], [347.0, 877.0], [327.0, 877.0]]], "lines": ["もちろんそれは", "わからない．．．しかし", "指紋を削ぎ落とした", "くらいだ．．"]}, {"box": [77, 630, 172, 738], "vertical": true, "font_size": 21, "lines_coords": [[[146.0, 630.0], [172.0, 630.0], [172.0, 692.0], [146.0, 692.0]], [[125.0, 631.0], [145.0, 631.0], [145.0, 727.0], [125.0, 727.0]], [[100.0, 631.0], [120.0, 631.0], [120.0, 730.0], [100.0, 730.0]], [[79.0, 631.0], [97.0, 631.0], [94.0, 738.0], [77.0, 738.0]]], "lines": ["たぶん", "人体の中で", "最も露骨な", "うずまきだ。"]}, {"box": [69, 772, 84, 816], "vertical": true, "font_size": 15, "lines_coords": [[[69.0, 772.0], [84.0, 772.0], [84.0, 816.0], [69.0, 816.0]]], "lines": ["．．．"]}]}