], [414.0, 525.0], [414.0, 642.0], [395.0, 642.0]], [[372.0, 527.0], [389.0, 527.0], [389.0, 684.0], [372.0, 684.0]]], "lines": ["うん．．．確かに", "そうかもしれない。"]}, {"box": [463, 789, 506, 890], "vertical": true, "font_size": 20, "lines_coords": [[[485.0, 789.0], [506.0, 789.0], [506.0, 864.0], [485.0, 864.0]], [[463.0, 789.0], [482.0, 789.0], [482.0, 890.0], [463.0, 890.0]]], "lines": ["つむじ風", "ってやつだ。"]}, {"box": [275, 574, 342, 749], "vertical": true, "font_size": 19, "lines_coords": [[[321.0, 575.0], [341.0, 575.0], [341.0, 748.0], [321.0, 748.0]], [[295.0, 574.0], [316.0, 574.0], [318.0, 748.0], [297.0, 748.0]], [[275.0, 575.0], [291.0, 575.0], [291.0, 710.0], [275.0, 710.0]]], "lines": ["でも隣の緑山市では", "こんなに沢山の渦を", "見た事がない"]}, {"box": [243, 782, 258, 824], "vertical": true, "font_size": 15, "lines_coords": [[[243.0, 782.0], [258.0, 782.0], [258.0, 824.0], [243.0, 824.0]]], "lines": ["．．．"]}, {"box": [71, 788, 92, 942], "vertical": true, "font_size": 20, "lines_coords": [[[71.0, 788.0], [91.0, 788.0], [91.0, 942.0], [71.0, 942.0]]], "lines": ["わからないが．．．"]}, {"box": [332, 975, 448, 1101], "vertical": true, "font_size": 18, "lines_coords": [[[429.0, 975.0], [446.0, 975.0], [444.0, 1072.0], [426.0, 1072.0]], [[406.0, 977.0], [423.0, 977.0], [423.0, 1069.0], [406.0, 1069.0]], [[381.0, 975.0], [400.0, 975.0], [400.0, 1101.0], [381.0, 1101.0]], [[358.0, 977.0], [375.0, 977.0], [375.0, 1069.0], [358.0, 1069.0]], [[332.0, 975.0], [352.0, 975.0], [352.0, 1054.0], [332.0, 1054.0]]], "lines": ["．．．それか．．", "おじさんの", "うずまき好きと", "何の関係が", "あるの？"]}]}