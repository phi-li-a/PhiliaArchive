{"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [652, 84, 721, 258], "vertical": true, "font_size": 20, "lines_coords": [[[694.0, 85.0], [718.0, 84.0], [721.0, 146.0], [696.0, 147.0]], [[673.0, 85.0], [692.0, 85.0], [695.0, 258.0], [675.0, 258.0]], [[653.0, 87.0], [669.0, 87.0], [669.0, 228.0], [653.0, 228.0]]], "lines": ["彼らは", "僕の住んでる長屋の", "同じ住人なんだ。"]}, {"box": [306, 82, 398, 182], "vertical": true, "font_size": 22, "lines_coords": [[[378.0, 85.0], [398.0, 85.0], [398.0, 180.0], [378.0, 180.0]], [[349.0, 82.0], [378.0, 82.0], [378.0, 147.0], [349.0, 147.0]], [[330.0, 85.0], [350.0, 85.0], [350.0, 182.0], [330.0, 182.0]], [[306.0, 85.0], [327.0, 85.0], [327.0, 165.0], [306.0, 165.0]]], "lines": ["同じ長屋の", "両端に", "住んでるん", "だけど．．．"]}, {"box": [70, 89, 162, 215], "vertical": true, "font_size": 21, "lines_coords": [[[141.0, 90.0], [161.0, 90.0], [161.0, 187.0], [141.0, 187.0]], [[118.0, 90.0], [138.0, 90.0], [138.0, 206.0], [118.0, 206.0]], [[91.0, 89.0], [116.0, 89.0], [116.0, 152.0], [91.0, 152.0]], [[70.0, 90.0], [90.0, 90.0], [90.0, 214.0], [70.0, 214.0]]], "lines": ["僕の家族と", "依子の家族は", "昔から", "仲が悪いんだ。"]}, {"box": [629, 528, 719, 664], "vertical": true, "font_size": 20, "lines_coords": [[[699.0, 529.0], [719.0, 529.0], [719.0, 609.0], [699.0, 609.0]], [[676.0, 528.0], [697.0, 528.0], [695.0, 664.0], [674.0, 664.0]], [[653.0, 530.0], [673.0, 530.0], [673.0, 646.0], [653.0, 646.0]], [[629.0, 530.0], [649.0, 530.0], [649.0, 628.0], [629.0, 628.0]]], "lines": ["でも僕と", "依子は、お互い", "好きになって", "しまった．．．"]}, {"box": [345, 523, 392, 649], "vertical": true, "font_size": 22, "lines_coords": [[[368.0, 523.0], [392.0, 523.0], [392.0, 585.0], [368.0, 585.0]], [[345.0, 523.0], [366.0, 523.0], [368.0, 649.0], [347.0, 649.0]]], "lines": ["本当に", "愛してるんだ。"]}, {"box": [641, 780, 729, 933], "vertical": true, "font_size": 16, "lines_coords": [[[711.0, 780.0], [729.0, 780.0], [728.0, 915.0], [710.0, 915.0]], [[688.0, 781.0], [704.0, 781.0], [704.0, 878.0], [688.0, 878.0]], [[664.0, 781.0], [681.0, 781.0], [681.0, 932.0], [664.0, 932.0]], [[641.0, 780.0], [656.0, 780.0], [656.0, 896.0], [641.0, 896.0]]], "lines": ["今までいろいろ", "努力した．．．", "２人の仲を認めて", "もらおうと．．．"]}, {"box": [490, 795, 537, 875], "vertical": true, "font_size": 22, "lines_coords": [[[517.0, 795.0], [537.0, 795.0], [537.0, 875.0], [517.0, 875.0]], [[492.0, 795.0], [517.0, 796.0], [514.0, 875.0], [490.0, 874.0]]], "lines": ["でも無駄", "だった．．"]}, {"box": [311, 791, 326, 834], "vertical": true, "font_size": 15, "lines_coords": [[[311.0, 791.0], [326.0, 791.0], [326.0, 834.0], [311.0, 834.0]]], "lines": ["．．．"]}, {"box": [67, 567, 133, 742], "vertical": true, "font_size": 19, "lines_coords": [[[111.0, 567.0], [132.0, 567.0], [133.0, 648.0], [112.0, 648.0]], [[87.0, 567.0], [107.0, 567.0], [109.0, 742.0], [89.0, 742.0]], [[68.0, 568.0], [84.0, 568.0], [84.0, 730.0], [68.0, 730.0]]], "lines": ["だけど．．．", "お互いの家がそれを", "認めるはずがない。"]}, {"box": [73, 810, 127, 1053], "vertical": true, "font_size": 22, "lines_coords": [[[97.0, 812.0], [120.0, 812.0], [120.0, 1005.0], [97.0, 1005.0]], [[73.0, 810.0], [93.0, 810.0], [96.0, 1052.0], [76.0, 1052.0]]], "lines": ["．．．西木和典君は、私の", "小・中学時代の同級生です。"]}]}