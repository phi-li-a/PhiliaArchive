], [93.0, 604.0]], [[69.0, 432.0], [86.0, 432.0], [87.0, 550.0], [70.0, 550.0]]], "lines": ["さっそく張り切って", "作り始めたわ"]}, {"box": [633, 638, 725, 813], "vertical": true, "font_size": 19, "lines_coords": [[[705.0, 639.0], [725.0, 639.0], [723.0, 800.0], [703.0, 800.0]], [[682.0, 638.0], [703.0, 638.0], [699.0, 813.0], [678.0, 813.0]], [[658.0, 641.0], [675.0, 641.0], [675.0, 792.0], [658.0, 792.0]], [[633.0, 639.0], [652.0, 639.0], [652.0, 725.0], [633.0, 725.0]]], "lines": ["でも考えてみたら、", "うずまきに凝るのは", "別に変じゃないと", "思うわよ。"]}, {"box": [370, 637, 464, 793], "vertical": true, "font_size": 21, "lines_coords": [[[436.0, 638.0], [461.0, 637.0], [464.0, 699.0], [438.0, 700.0]], [[414.0, 638.0], [436.0, 638.0], [438.0, 793.0], [417.0, 793.0]], [[395.0, 642.0], [411.0, 642.0], [411.0, 792.0], [395.0, 792.0]], [[370.0, 642.0], [390.0, 642.0], [390.0, 759.0], [370.0, 759.0]]], "lines": ["だって", "世の中にはもっと", "変な物集めてる人", "いるじゃない。"]}, {"box": [364, 830, 422, 937], "vertical": true, "font_size": 23, "lines_coords": [[[396.0, 830.0], [422.0, 830.0], [422.0, 905.0], [396.0, 905.0]], [[378.0, 833.0], [398.0, 833.0], [398.0, 937.0], [378.0, 937.0]]], "lines": ["タバコの", "吸いがらとか"]}, {"box": [194, 649, 334, 730], "vertical": true, "font_size": 22, "lines_coords": [[[307.0, 650.0], [334.0, 650.0], [334.0, 711.0], [307.0, 711.0]], [[284.0, 649.0], [309.0, 649.0], [309.0, 730.0], [284.0, 730.0]], [[262.0, 650.0], [283.0, 650.0], [283.0, 728.0], [262.0, 728.0]], [[236.0, 650.0], [261.0, 650.0], [261.0, 711.0], [236.0, 711.0]], [[216.0, 651.0], [237.0, 651.0], [235.0, 730.0], [214.0, 730.0]], [[194.0, 653.0], [214.0, 653.0], [214.0, 692.0], [194.0, 692.0]]], "lines": ["親父の", "凝り方が", "どんなに", "異常か", "って事を", "．．．？"]}, {"box": [72, 672, 165, 799], "vertical": true, "font_size": 22, "lines_coords": [[[145.0, 673.0], [165.0, 673.0], [165.0, 771.0], [145.0, 771.0]], [[121.0, 675.0], [141.0, 675.0], [141.0, 778.0], [121.0, 778.0]], [[94.0, 675.0], [116.0, 675.0], [117.0, 772.0], [96.0, 772.0]], [[72.0, 672.0], [