{"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [646, 87, 767, 231], "vertical": true, "font_size": 20, "lines_coords": [[[746.0, 90.0], [764.0, 90.0], [765.0, 225.0], [748.0, 225.0]], [[721.0, 87.0], [744.0, 87.0], [744.0, 229.0], [721.0, 229.0]], [[698.0, 89.0], [718.0, 89.0], [718.0, 225.0], [698.0, 225.0]], [[669.0, 89.0], [689.0, 89.0], [689.0, 203.0], [669.0, 203.0]], [[646.0, 90.0], [665.0, 90.0], [665.0, 171.0], [646.0, 171.0]]], "lines": ["彼の住んでいる", "長屋というのは、", "もともとは例の", "廃屋のひとつ", "でしたが"]}, {"box": [126, 125, 220, 290], "vertical": true, "font_size": 21, "lines_coords": [[[196.0, 125.0], [220.0, 125.0], [220.0, 290.0], [196.0, 290.0]], [[173.0, 125.0], [194.0, 125.0], [195.0, 248.0], [174.0, 248.0]], [[151.0, 127.0], [171.0, 127.0], [171.0, 242.0], [151.0, 242.0]], [[126.0, 125.0], [146.0, 125.0], [147.0, 288.0], [127.0, 288.0]]], "lines": ["比較的保存状態が", "良かったので、", "地主が貸家に", "改造したものです。"]}, {"box": [637, 345, 755, 527], "vertical": true, "font_size": 20, "lines_coords": [[[735.0, 349.0], [755.0, 349.0], [755.0, 464.0], [735.0, 464.0]], [[710.0, 349.0], [730.0, 349.0], [730.0, 483.0], [710.0, 483.0]], [[687.0, 349.0], [707.0, 349.0], [707.0, 486.0], [687.0, 486.0]], [[664.0, 346.0], [684.0, 346.0], [681.0, 483.0], [661.0, 483.0]], [[639.0, 345.0], [660.0, 345.0], [658.0, 523.0], [637.0, 523.0]]], "lines": ["小学生時代に", "和典君の家族が", "越してきたほか、", "何組かの家族が", "入っているのですが、"]}, {"box": [389, 563, 418, 616], "vertical": true, "font_size": 27, "lines_coords": [[[389.0, 564.0], [416.0, 563.0], [418.0, 615.0], [391.0, 616.0]]], "lines": ["えっ、"]}, {"box": [123, 352, 238, 515], "vertical": true, "font_size": 19, "lines_coords": [[[216.0, 355.0], [236.0, 355.0], [236.0, 491.0], [216.0, 491.0]], [[193.0, 353.0], [213.0, 353.0], [211.0, 512.0], [191.0, 512.0]], [[171.0, 356.0], [187.0, 356.0], [187.0, 451.0], [171.0, 451.0]], [[144.0, 352.0], [165.0, 352.0], [164.0, 509.0], [143.0, 509.0]], [[124.0, 352.0], [140.0, 352.0], [140.0, 438.0], [124.0, 438.0]]], "lines": ["町の人達からは", "貧乏長屋と呼ばれ", "特別な目で", "見られているのも", "事実です。"]}, {"box": [711, 573, 774, 658], "vertical": true, "font_size": 18, "lines_coords": [[[732.0, 573.0], [752.0, 573.0], [752.0, 651.0], [732.0, 651.0]], [[711.0, 573.0], [728.0, 573.0], [728.0, 656.0], [711.0, 656.0]]], "lines": ["ねじれて", "るんだよ"]}, {"box": [724, 775, 768, 880], "vertical": true, "font_size": 18, "lines_coords": [[[748.0, 775.0], [767.0, 775.0], [765.0, 873.0], [745.0, 873.0]], [[725.0, 778.0], [742.0, 778.0], [742.0, 877.0], [725.0, 877.0]]], "lines": ["僕と依子の", "家族の事さ。"]}, {"box": [413, 778, 459, 862], "vertical": true, "font_size": 23, "lines_coords": [[[433.0, 778.0], [459.0, 778.0], [459.0, 840.0], [433.0, 840.0]], [[413.0, 778.0], [433.0, 778.0], [433.0, 861.0], [413.0, 861.0]]], "lines": ["依子は", "別として、"]}, {"box": [307, 787, 376, 990], "vertical": true, "font_size": 20, "lines_coords": [[[354.0, 787.0], [375.0, 787.0], [376.0, 931.0], [355.0, 931.0]], [[330.0, 789.0], [350.0, 789.0], [350.0, 944.0], [330.0, 944.0]], [[307.0, 788.0], [327.0, 788.0], [327.0, 990.0], [307.0, 990.0]]], "lines": ["きっと．．．みんな、", "今の貧しい状態を", "受け入れられないんだ。"]}, {"box": [109, 672, 133, 737], "vertical": true, "font_size": 24, "lines_coords": [[[109.0, 672.0], [133.0, 672.0], [133.0, 737.0], [109.0, 737.0]]], "lines": ["何が？"]}, {"box": [411, 990, 478, 1095], "vertical": true, "font_size": 20, "lines_coords": [[[457.0, 990.0], [478.0, 990.0], [476.0, 1086.0], [454.0, 1086.0]], [[433.0, 990.0], [454.0, 990.0], [454.0, 1051.0], [433.0, 1051.0]], [[411.0, 990.0], [427.0, 990.0], [427.0, 1094.0], [411.0, 1094.0]]], "lines": ["みんな心が", "ひどく", "ねじれてる。"]}, {"box": [106, 903, 175, 1098], "vertical": true, "font_size": 21, "lines_coords": [[[152.0, 903.0], [175.0, 903.0], [173.0, 1098.0], [150.0, 1098.0]], [[130.0, 904.0], [150.0, 904.0], [147.0, 1059.0], [127.0, 1059.0]], [[106.0, 904.0], [126.0, 904.0], [126.0, 990.0], [106.0, 990.0]]], "lines": ["だから、ねじれるしか", "自分を守る方法が", "ないんだ。"]}]}