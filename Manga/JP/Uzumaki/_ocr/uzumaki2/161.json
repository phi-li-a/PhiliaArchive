ds": [[[552.0, 633.0], [568.0, 633.0], [568.0, 765.0], [552.0, 765.0]], [[527.0, 631.0], [545.0, 631.0], [543.0, 765.0], [526.0, 765.0]]], "lines": ["何という甘美な", "情景だろうか！！"]}, {"box": [209, 848, 264, 921], "vertical": true, "font_size": 27, "lines_coords": [[[236.0, 848.0], [264.0, 848.0], [264.0, 898.0], [236.0, 898.0]], [[209.0, 849.0], [235.0, 849.0], [235.0, 921.0], [209.0, 921.0]]], "lines": ["せ．．．", "先生！！"]}, {"box": [689, 851, 759, 1006], "vertical": true, "font_size": 20, "lines_coords": [[[737.0, 851.0], [758.0, 851.0], [759.0, 1006.0], [738.0, 1006.0]], [[712.0, 851.0], [732.0, 851.0], [735.0, 987.0], [715.0, 987.0]], [[689.0, 851.0], [709.0, 851.0], [709.0, 993.0], [689.0, 993.0]]], "lines": ["それも当然の事！！", "臍の緒と胎盤は", "生命の源なのだ。"]}, {"box": [457, 842, 547, 964], "vertical": true, "font_size": 20, "lines_coords": [[[526.0, 842.0], [547.0, 842.0], [547.0, 921.0], [526.0, 921.0]], [[501.0, 842.0], [525.0, 842.0], [525.0, 964.0], [501.0, 964.0]], [[479.0, 843.0], [499.0, 843.0], [499.0, 957.0], [479.0, 957.0]], [[457.0, 843.0], [473.0, 843.0], [473.0, 945.0], [457.0, 945.0]]], "lines": ["病人達に", "食べさせれば、", "必ずや元気に", "なるだろう。"]}]}