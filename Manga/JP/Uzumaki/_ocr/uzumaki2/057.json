{"version": "0.1.7", "img_width": 835, "img_height": 1200, "blocks": [{"box": [688, 123, 736, 277], "vertical": true, "font_size": 21, "lines_coords": [[[715.0, 123.0], [736.0, 123.0], [733.0, 240.0], [712.0, 240.0]], [[689.0, 123.0], [710.0, 123.0], [709.0, 277.0], [688.0, 277.0]]], "lines": ["見ろ．．．やつが", "這い回った跡だ．．．"]}, {"box": [644, 554, 696, 574], "vertical": false, "font_size": 18, "lines_coords": [[[644.0, 556.0], [695.0, 554.0], [696.0, 571.0], [645.0, 574.0]]], "lines": ["職員室"]}, {"box": [496, 519, 542, 642], "vertical": true, "font_size": 20, "lines_coords": [[[522.0, 520.0], [542.0, 520.0], [542.0, 635.0], [522.0, 635.0]], [[496.0, 519.0], [516.0, 519.0], [518.0, 642.0], [498.0, 642.0]]], "lines": ["片山の両親に", "知らせないと。"]}, {"box": [653, 679, 746, 806], "vertical": true, "font_size": 22, "lines_coords": [[[728.0, 683.0], [745.0, 683.0], [743.0, 779.0], [726.0, 779.0]], [[705.0, 682.0], [726.0, 683.0], [721.0, 796.0], [700.0, 795.0]], [[676.0, 679.0], [705.0, 679.0], [705.0, 725.0], [676.0, 725.0]], [[658.0, 680.0], [678.0, 680.0], [673.0, 806.0], [653.0, 806.0]]], "lines": ["．．．このまま", "ほっとくわけ", "には", "いきませんな。"]}, {"box": [112, 522, 204, 735], "vertical": true, "font_size": 20, "lines_coords": [[[181.0, 522.0], [202.0, 522.0], [203.0, 700.0], [182.0, 700.0]], [[158.0, 522.0], [179.0, 522.0], [180.0, 697.0], [159.0, 697.0]], [[135.0, 523.0], [155.0, 523.0], [155.0, 678.0], [135.0, 678.0]], [[112.0, 522.0], [132.0, 522.0], [132.0, 735.0], [112.0, 735.0]]], "lines": ["それについては今朝、", "家から電話があって", "数日前から片山は", "家に帰ってないとかで．．"]}, {"box": [696, 841, 764, 994], "vertical": true, "font_size": 19, "lines_coords": [[[744.0, 841.0], [764.0, 841.0], [764.0, 923.0], [744.0, 923.0]], [[720.0, 841.0], [740.0, 841.0], [740.0, 994.0], [720.0, 994.0]], [[697.0, 841.0], [715.0, 841.0], [714.0, 959.0], [696.0, 959.0]]], "lines": ["そりゃあ、", "あんな姿で家には", "帰れますまいっ"]}, {"box": [462, 854, 528, 987], "vertical": true, "font_size": 18, "lines_coords": [[[508.0, 855.0], [528.0, 855.0], [528.0, 951.0], [508.0, 951.0]], [[482.0, 854.0], [502.0, 854.0], [505.0, 987.0], [486.0, 987.0]], [[462.0, 855.0], [478.0, 855.0], [478.0, 969.0], [462.0, 969.0]]], "lines": ["裏山にでも", "隠れてたんじゃ", "ないですか？"]}, {"box": [329, 847, 418, 999], "vertical": true, "font_size": 17, "lines_coords": [[[399.0, 848.0], [415.0, 848.0], [415.0, 979.0], [399.0, 979.0]], [[375.0, 848.0], [392.0, 848.0], [392.0, 943.0], [375.0, 943.0]], [[350.0, 847.0], [370.0, 847.0], [370.0, 999.0], [350.0, 999.0]], [[329.0, 848.0], [345.0, 848.0], [345.0, 986.0], [329.0, 986.0]]], "lines": ["それで両親には", "とりあえず", "学校に来るように", "伝えましたので、"]}, {"box": [112, 849, 154, 991], "vertical": true, "font_size": 17, "lines_coords": [[[137.0, 849.0], [154.0, 849.0], [152.0, 928.0], [134.0, 928.0]], [[113.0, 850.0], [129.0, 850.0], [129.0, 990.0], [113.0, 990.0]]], "lines": ["もうすぐ", "到着する頃です。"]}]}