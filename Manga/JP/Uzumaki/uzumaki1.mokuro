21, 965], "vertical": true, "font_size": 22, "lines_coords": [[[201.0, 867.0], [221.0, 867.0], [221.0, 965.0], [201.0, 965.0]], [[176.0, 868.0], [198.0, 868.0], [198.0, 964.0], [176.0, 964.0]], [[149.0, 866.0], [176.0, 866.0], [176.0, 926.0], [149.0, 926.0]], [[128.0, 868.0], [149.0, 868.0], [149.0, 945.0], [128.0, 945.0]]], "lines": ["まったく．．", "今までとは", "作風が", "ガラッと"]}], "img_path": "119.jpg"}, {"version": "0.1.7", "img_width": 839, "img_height": 1200, "blocks": [{"box": [623, 80, 718, 254], "vertical": true, "font_size": 20, "lines_coords": [[[698.0, 83.0], [718.0, 83.0], [714.0, 254.0], [694.0, 254.0]], [[673.0, 82.0], [693.0, 82.0], [693.0, 219.0], [673.0, 219.0]], [[649.0, 80.0], [670.0, 80.0], [667.0, 196.0], [646.0, 196.0]], [[626.0, 80.0], [647.0, 80.0], [644.0, 236.0], [623.0, 236.0]]], "lines": ["いや．．．お恥ずかしい", "：実は焼く前は", "普通の壺や皿", "だったんですが．．．"]}, {"box": [248, 76, 365, 175], "vertical": true, "font_size": 23, "lines_coords": [[[344.0, 78.0], [365.0, 78.0], [365.0, 155.0], [344.0, 155.0]], [[318.0, 76.0], [343.0, 76.0], [343.0, 146.0], [318.0, 146.0]], [[295.0, 77.0], [316.0, 77.0], [317.0, 175.0], [296.0, 175.0]], [[274.0, 78.0], [294.0, 78.0], [294.0, 175.0], [274.0, 175.0]], [[248.0, 77.0], [275.0, 77.0], [275.0, 138.0], [248.0, 138.0]]], "lines": ["焼成中に", "溶けて、", "形が崩れて", "しまったん", "です．．"]}, {"box": [58, 375, 173, 515], "vertical": true, "font_size": 20, "lines_coords": [[[153.0, 376.0], [173.0, 376.0], [173.0, 491.0], [153.0, 491.0]], [[127.0, 375.0], [148.0, 375.0], [149.0, 515.0], [128.0, 515.0]], [[105.0, 376.0], [125.0, 376.0], [125.0, 473.0], [105.0, 473.0]], [[79.0, 375.0], [100.0, 375.0], [103.0, 512.0], [82.0, 512.0]], [[58.0, 376.0], [78.0, 376.0], [78.0, 462.0], [58.0, 462.0]]], "lines": ["今回は新しい", "土を使ったので、", "窯の温度が", "合わなかったの", "でしょう。"]}, {"box": [643, 568, 732, 730], "vertical": true, "font_size": 18, "lines_coords": [[[712.0, 569.0], [730.0, 569.0], [731.0, 720.0], [713.0, 720.0]], [[689.0, 568.0], [708.0, 568.0], [708.0, 651.0], [689.0, 651.0]], [[665.0, 569.0], [685.0, 569.0], [685.0, 724.0], [665.0, 724.0]], [[643.0, 570.0], [659.0, 570.0], [659.0, 730.0], [643.0, 730.0]]], "lines": ["しかし芸術として", "見た場合、", "逆に成功だったと", "自分では思います。"]}, {"box": [427, 564, 492, 717], "vertical": true, "font_size": 16, "lines_coords": [[[474.0, 564.0], [490.0, 564.0], [490.0, 660.0], [474.0, 660.0]], [[451.0, 564.0], [467.0, 564.0], [467.0, 717.0], [451.0, 717.0]], [[427.0, 564.0], [444.0, 564.0], [444.0, 679.0], [427.0, 679.0]]], "lines": ["なるほど．．．", "まるで生きている", "ようですな．．．"]}, {"box": [329, 834, 444, 951], "vertical": true, "font_size": 20, "lines_coords": [[[423.0, 836.0], [444.0, 836.0], [444.0, 914.0], [423.0, 914.0]], [[399.0, 836.0], [419.0, 836.0], [419.0, 933.0], [399.0, 933.0]], [[376.0, 835.0], [396.0, 835.0], [396.0, 951.0], [376.0, 951.0]], [[350.0, 834.0], [370.0, 834.0], [370.0, 912.0], [350.0, 912.0]], [[329.0, 834.0], [345.0, 834.0], [345.0, 921.0], [329.0, 921.0]]], "lines": ["窯の中で", "焼いている", "うちに自然に", "浮き出た", "ものです。"]}, {"box": [55, 568, 144, 762], "vertical": true, "font_size": 19, "lines_coords": [[[124.0, 569.0], [144.0, 569.0], [142.0, 762.0], [123.0, 762.0]], [[100.0, 570.0], [120.0, 570.0], [119.0, 741.0], [99.0, 741.0]], [[77.0, 568.0], [97.0, 568.0], [97.0, 742.0], [77.0, 742.0]], [[55.0, 569.0], [71.0, 569.0], [71.0, 683.0], [55.0, 683.0]]], "lines": ["えもいわれぬ色彩と．．．", "いたる所に描かれた", "うずまき模様がまた", "なんとも．．．．．．"]}, {"box": [194, 835, 296, 917], "vertical": true, "font_size": 25, "lines_coords": [[[271.0, 836.0], [296.0, 836.0], [296.0, 900.0], [271.0, 900.0]], [[246.0, 839.0], [271.0, 839.0], [271.0, 917.0], [246.0, 917.0]], [[214.0, 835.0], [246.0, 835.0], [246.0, 900.0], [214.0, 900.0]], [[194.0, 836.0], [219.0, 836.0], [219.0, 905.0], [194.0, 905.0]]], "lines": ["ほう．．．", "いわゆる", "黒変！！", "ですか。"]}, {"box": [58, 830, 155, 966], "vertical": true, "font_size": 25, "lines_coords": [[[126.0, 830.0], [155.0, 830.0], [155.0, 895.0], [126.0, 895.0]], [[107.0, 832.0], [127.0, 832.0], [127.0, 966.0], [107.0, 966.0]], [[83.0, 833.0], [104.0, 833.0], [104.0, 910.0], [83.0, 910.0]], [[58.0, 833.0], [79.0, 833.0], [79.0, 910.0], [58.0, 910.0]]], "lines": ["しかし", "うずまき模様の", "窯変とは", "珍しい．．．"]}, {"box": [664, 840, 733, 994], "vertical": true, "font_size": 20, "lines_coords": [[[710.0, 840.0], [733.0, 840.0], [733.0, 958.0], [710.0, 958.0]], [[687.0, 842.0], [707.0, 842.0], [707.0, 994.0], [687.0, 994.0]], [[665.0, 841.0], [683.0, 841.0], [681.0, 964.0], [664.0, 964.0]]], "lines": ["いや．．．それは", "私が描いたのでは", "ありませんよ。"]}, {"box": [332, 976, 447, 1099], "vertical": true, "font_size": 20, "lines_coords": [[[426.0, 983.0], [447.0, 983.0], [447.0, 1060.0], [426.0, 1060.0]], [[400.0, 979.0], [424.0, 979.0], [424.0, 1099.0], [400.0, 1099.0]], [[379.0, 976.0], [400.0, 976.0], [398.0, 1098.0], [377.0, 1098.0]], [[353.0, 980.0], [373.0, 980.0], [376.0, 1098.0], [356.0, 1098.0]], [[332.0, 984.0], [349.0, 984.0], [349.0, 1082.0], [332.0, 1082.0]]], "lines": ["焼成中に", "土が化学変化", "して、そんな", "ふうになった", "のでしょう。"]}], "img_path": "120.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [738, 92, 780, 168], "vertical": true, "font_size": 21, "lines_coords": [[[760.0, 92.0], [780.0, 92.0], [780.0, 168.0], [760.0, 168.0]], [[738.0, 93.0], [760.0, 93.0], [760.0, 132.0], [738.0, 132.0]]], "lines": ["ところで", "．．．"]}, {"box": [439, 92, 523, 270], "vertical": true, "font_size": 19, "lines_coords": [[[505.0, 94.0], [521.0, 94.0], [521.0, 266.0], [505.0, 266.0]], [[480.0, 92.0], [504.0, 92.0], [504.0, 269.0], [480.0, 269.0]], [[463.0, 96.0], [479.0, 96.0], [479.0, 228.0], [463.0, 228.0]], [[440.0, 93.0], [460.0, 93.0], [459.0, 248.0], [439.0, 248.0]]], "lines": ["さっき土を変えたと", "おっしゃいましたが、", "一体どんな土を", "使ったんですか？"]}, {"box": [389, 77, 413, 146], "vertical": true, "font_size": 24, "lines_coords": [[[389.0, 77.0], [413.0, 77.0], [413.0, 146.0], [389.0, 146.0]]], "lines": ["フフフ、"]}, {"box": [110, 80, 156, 273], "vertical": true, "font_size": 18, "lines_coords": [[[136.0, 83.0], [152.0, 83.0], [152.0, 273.0], [136.0, 273.0]], [[110.0, 80.0], [130.0, 80.0], [131.0, 246.0], [111.0, 246.0]]], "lines": ["それは秘密という事に", "しておきましょう。"]}, {"box": [721, 362, 762, 441], "vertical": true, "font_size": 21, "lines_coords": [[[721.0, 362.0], [742.0, 362.0], [743.0, 441.0], [722.0, 441.0]]], "lines": ["それで．．．"]}, {"box": [470, 330, 565, 408], "vertical": true, "font_size": 23, "lines_coords": [[[540.0, 331.0], [565.0, 331.0], [565.0, 394.0], [540.0, 394.0]], [[518.0, 330.0], [542.0, 330.0], [542.0, 393.0], [518.0, 393.0]], [[495.0, 332.0], [517.0, 332.0], [517.0, 408.0], [495.0, 408.0]], [[470.0, 330.0], [492.0, 330.0], [493.0, 398.0], [471.0, 398.0]]], "lines": ["ああ．．．", "世間は", "見る目が", "ないね。"]}, {"box": [124, 322, 242, 410], "vertical": true, "font_size": 24, "lines_coords": [[[216.0, 324.0], [242.0, 324.0], [242.0, 386.0], [216.0, 386.0]], [[194.0, 325.0], [215.0, 325.0], [215.0, 401.0], [194.0, 401.0]], [[168.0, 324.0], [194.0, 324.0], [194.0, 386.0], [168.0, 386.0]], [[143.0, 322.0], [172.0, 322.0], [172.0, 386.0], [143.0, 386.0]], [[124.0, 325.0], [144.0, 325.0], [144.0, 410.0], [124.0, 410.0]]], "lines": ["．．．でも", "無理ない", "かも．．．", "実用的", "でないし。"]}, {"box": [603, 555, 650, 719], "vertical": true, "font_size": 20, "lines_coords": [[[628.0, 555.0], [649.0, 555.0], [648.0, 719.0], [627.0, 719.0]], [[605.0, 555.0], [624.0, 555.0], [623.0, 704.0], [603.0, 704.0]]], "lines": ["全然売れなかった", "わけ？お父さん。"]}, {"box": [680, 810, 772, 928], "vertical": true, "font_size": 21, "lines_coords": [[[746.0, 810.0], [772.0, 810.0], [772.0, 873.0], [746.0, 873.0]], [[725.0, 812.0], [745.0, 812.0], [745.0, 928.0], [725.0, 928.0]], [[701.0, 810.0], [722.0, 810.0], [722.0, 890.0], [701.0, 890.0]], [[680.0, 812.0], [696.0, 812.0], [696.0, 895.0], [680.0, 895.0]]], "lines": ["桐絵は", "あいかわらず", "厳しい事", "言うなあ。"]}, {"box": [304, 808, 322, 883], "vertical": true, "font_size": 13, "lines_coords": [[[304.0, 808.0], [317.0, 808.0], [317.0, 882.0], [304.0, 882.0]]], "lines": ["さあな．．．"]}, {"box": [120, 697, 170, 767], "vertical": true, "font_size": 27, "lines_coords": [[[141.0, 697.0], [170.0, 697.0], [170.0, 742.0], [141.0, 742.0]], [[120.0, 697.0], [145.0, 697.0], [145.0, 767.0], [120.0, 767.0]]], "lines": ["形も", "変だし。"]}, {"box": [351, 805, 444, 998], "vertical": true, "font_size": 19, "lines_coords": [[[424.0, 806.0], [444.0, 806.0], [440.0, 924.0], [420.0, 924.0]], [[398.0, 805.0], [419.0, 805.0], [417.0, 998.0], [396.0, 998.0]], [[375.0, 806.0], [395.0, 806.0], [393.0, 978.0], [374.0, 978.0]], [[354.0, 806.0], [370.0, 806.0], [368.0, 921.0], [351.0, 921.0]]], "lines": ["でもお父さん", "自然にうずまき模様が", "浮き出てくる事って", "よくあるの？"]}, {"box": [105, 977, 149, 1080], "vertical": true, "font_size": 17, "lines_coords": [[[131.0, 977.0], [147.0, 977.0], [147.0, 1072.0], [131.0, 1072.0]], [[107.0, 977.0], [125.0, 977.0], [123.0, 1080.0], [105.0, 1080.0]]], "lines": ["こんなのは", "初めて見た。"]}], "img_path": "121.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [680, 76, 752, 160], "vertical": true, "font_size": 26, "lines_coords": [[[728.0, 78.0], [752.0, 78.0], [752.0, 160.0], [728.0, 160.0]], [[701.0, 76.0], [730.0, 76.0], [730.0, 142.0], [701.0, 142.0]], [[680.0, 79.0], [705.0, 79.0], [705.0, 140.0], [680.0, 140.0]]], "lines": ["あれっ？", "．．．これ", "何だ？"]}, {"box": [366, 70, 430, 243], "vertical": true, "font_size": 18, "lines_coords": [[[413.0, 71.0], [430.0, 71.0], [430.0, 165.0], [413.0, 165.0]], [[388.0, 70.0], [408.0, 70.0], [408.0, 243.0], [388.0, 243.0]], [[366.0, 71.0], [383.0, 71.0], [383.0, 203.0], [366.0, 203.0]]], "lines": ["こんな所に", "人の顔みたいなのが", "浮き出てるぞ！"]}, {"box": [309, 72, 336, 124], "vertical": true, "font_size": 27, "lines_coords": [[[309.0, 72.0], [336.0, 72.0], [336.0, 124.0], [309.0, 124.0]]], "lines": ["えっ、"]}, {"box": [68, 80, 87, 178], "vertical": true, "font_size": 19, "lines_coords": [[[68.0, 80.0], [87.0, 80.0], [87.0, 178.0], [68.0, 178.0]]], "lines": ["どこどこ？"]}, {"box": [221, 326, 245, 369], "vertical": true, "font_size": 24, "lines_coords": [[[221.0, 326.0], [245.0, 326.0], [245.0, 369.0], [221.0, 369.0]]], "lines": ["な？"]}, {"box": [63, 325, 113, 391], "vertical": true, "font_size": 26, "lines_coords": [[[84.0, 325.0], [113.0, 325.0], [113.0, 391.0], [84.0, 391.0]], [[63.0, 325.0], [87.0, 325.0], [87.0, 390.0], [63.0, 390.0]]], "lines": ["人の顔", "だろ？"]}, {"box": [218, 554, 245, 617], "vertical": true, "font_size": 25, "lines_coords": [[[218.0, 555.0], [242.0, 554.0], [245.0, 616.0], [220.0, 617.0]]], "lines": ["あっ．．．"]}, {"box": [359, 795, 380, 892], "vertical": true, "font_size": 20, "lines_coords": [[[359.0, 795.0], [379.0, 795.0], [379.0, 890.0], [359.0, 890.0]]], "lines": ["この顔．．．"]}, {"box": [198, 764, 295, 866], "vertical": true, "font_size": 24, "lines_coords": [[[262.0, 765.0], [293.0, 764.0], [295.0, 828.0], [264.0, 829.0]], [[246.0, 766.0], [267.0, 766.0], [264.0, 866.0], [243.0, 866.0]], [[219.0, 767.0], [243.0, 767.0], [243.0, 846.0], [219.0, 846.0]], [[198.0, 767.0], [218.0, 767.0], [218.0, 834.0], [198.0, 834.0]]], "lines": ["あっ．．．", "こっちにも", "別の顔が", "あるぞ。"]}, {"box": [72, 767, 98, 829], "vertical": true, "font_size": 26, "lines_coords": [[[72.0, 767.0], [98.0, 767.0], [98.0, 829.0], [72.0, 829.0]]], "lines": ["えっ！？"]}], "img_path": "122.jpg"}, {"version": "0.1.7", "img_width": 839, "img_height": 1200, "blocks": [{"box": [705, 72, 774, 170], "vertical": true, "font_size": 23, "lines_coords": [[[748.0, 73.0], [774.0, 73.0], [774.0, 135.0], [748.0, 135.0]], [[722.0, 73.0], [749.0, 72.0], [752.0, 134.0], [725.0, 135.0]], [[706.0, 77.0], [722.0, 77.0], [722.0, 169.0], [706.0, 169.0]]], "lines": ["これは", "女の人", "みたいだ！"]}, {"box": [748, 543, 768, 621], "vertical": true, "font_size": 20, "lines_coords": [[[748.0, 543.0], [768.0, 543.0], [768.0, 621.0], [748.0, 621.0]]], "lines": ["．．．ねえ．．．"]}, {"box": [526, 380, 554, 445], "vertical": true, "font_size": 26, "lines_coords": [[[526.0, 382.0], [551.0, 380.0], [554.0, 444.0], [528.0, 445.0]]], "lines": ["あっ．．．"]}, {"box": [653, 596, 699, 675], "vertical": true, "font_size": 22, "lines_coords": [[[679.0, 598.0], [699.0, 598.0], [699.0, 675.0], [679.0, 675.0]], [[653.0, 596.0], [678.0, 596.0], [678.0, 659.0], [653.0, 659.0]]], "lines": ["ちょっと", "これ．．"]}, {"box": [698, 733, 769, 867], "vertical": true, "font_size": 20, "lines_coords": [[[744.0, 733.0], [769.0, 733.0], [769.0, 795.0], [744.0, 795.0]], [[724.0, 734.0], [740.0, 734.0], [740.0, 867.0], [724.0, 867.0]], [[698.0, 733.0], [718.0, 733.0], [718.0, 829.0], [698.0, 829.0]]], "lines": ["．．．ねえ", "そう思わない？", "お母さん．．．"]}, {"box": [522, 738, 568, 823], "vertical": true, "font_size": 22, "lines_coords": [[[543.0, 738.0], [568.0, 738.0], [568.0, 800.0], [543.0, 800.0]], [[522.0, 739.0], [542.0, 739.0], [542.0, 822.0], [522.0, 822.0]]], "lines": ["．．．ほ．．．", "本当ねえ、"]}, {"box": [428, 738, 467, 834], "vertical": true, "font_size": 20, "lines_coords": [[[447.0, 740.0], [467.0, 740.0], [467.0, 834.0], [447.0, 834.0]]], "lines": ["よく似てる"]}, {"box": [363, 738, 401, 833], "vertical": true, "font_size": 16, "lines_coords": [[[383.0, 740.0], [399.0, 740.0], [399.0, 833.0], [383.0, 833.0]]], "lines": ["いやあねえ"]}, {"box": [158, 543, 226, 659], "vertical": true, "font_size": 21, "lines_coords": [[[205.0, 543.0], [226.0, 543.0], [226.0, 639.0], [205.0, 639.0]], [[181.0, 544.0], [201.0, 544.0], [201.0, 642.0], [181.0, 642.0]], [[158.0, 544.0], [178.0, 544.0], [178.0, 659.0], [158.0, 659.0]]], "lines": ["．．．秀一君の", "お父さんと", "お母さんに．．．"]}, {"box": [253, 738, 298, 819], "vertical": true, "font_size": 22, "lines_coords": [[[274.0, 738.0], [298.0, 738.0], [298.0, 819.0], [274.0, 819.0]], [[253.0, 738.0], [273.0, 738.0], [273.0, 817.0], [253.0, 817.0]]], "lines": ["何これ？", "あなた．．．"]}, {"box": [74, 550, 121, 705], "vertical": true, "font_size": 21, "lines_coords": [[[101.0, 553.0], [121.0, 553.0], [121.0, 705.0], [101.0, 705.0]], [[74.0, 550.0], [100.0, 550.0], [100.0, 577.0], [74.0, 577.0]]], "lines": ["似てると思わない", "？"]}, {"box": [111, 738, 205, 844], "vertical": true, "font_size": 20, "lines_coords": [[[178.0, 738.0], [205.0, 738.0], [205.0, 785.0], [178.0, 785.0]], [[155.0, 739.0], [176.0, 739.0], [178.0, 844.0], [157.0, 844.0]], [[134.0, 741.0], [151.0, 741.0], [151.0, 835.0], [134.0, 835.0]], [[111.0, 740.0], [127.0, 740.0], [127.0, 834.0], [111.0, 834.0]]], "lines": ["何？", "知らないぞ、", "単なる偶然", "だろう．．．"]}, {"box": [594, 1010, 663, 1098], "vertical": true, "font_size": 22, "lines_coords": [[[639.0, 1010.0], [660.0, 1010.0], [663.0, 1098.0], [642.0, 1098.0]], [[615.0, 1010.0], [639.0, 1010.0], [639.0, 1073.0], [615.0, 1073.0]], [[594.0, 1011.0], [615.0, 1011.0], [615.0, 1089.0], [594.0, 1089.0]]], "lines": ["えーーっ、", "そんな", "ばかな．．．"]}], "img_path": "123.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [695, 70, 769, 205], "vertical": true, "font_size": 20, "lines_coords": [[[749.0, 70.0], [769.0, 70.0], [769.0, 203.0], [749.0, 203.0]], [[718.0, 71.0], [738.0, 71.0], [738.0, 191.0], [718.0, 191.0]], [[695.0, 71.0], [715.0, 71.0], [715.0, 172.0], [695.0, 172.0]]], "lines": ["うそ！あなた、", "質の悪い冗談", "やめてよ！"]}, {"box": [576, 71, 649, 210], "vertical": true, "font_size": 21, "lines_coords": [[[626.0, 71.0], [649.0, 71.0], [649.0, 192.0], [626.0, 192.0]], [[602.0, 73.0], [622.0, 73.0], [622.0, 192.0], [602.0, 192.0]], [[576.0, 73.0], [596.0, 73.0], [600.0, 209.0], [580.0, 209.0]]], "lines": ["何言ってる！", "私は何も手を", "加えてないぞ！！"]}, {"box": [456, 77, 525, 201], "vertical": true, "font_size": 19, "lines_coords": [[[505.0, 77.0], [525.0, 77.0], [525.0, 200.0], [505.0, 200.0]], [[481.0, 77.0], [501.0, 77.0], [501.0, 193.0], [481.0, 193.0]], [[457.0, 77.0], [474.0, 77.0], [473.0, 198.0], [456.0, 198.0]]], "lines": ["調べてみると、", "全部で四つの", "顔が見つかり"]}, {"box": [220, 82, 289, 182], "vertical": true, "font_size": 22, "lines_coords": [[[268.0, 82.0], [288.0, 82.0], [288.0, 179.0], [268.0, 179.0]], [[242.0, 82.0], [267.0, 82.0], [267.0, 162.0], [242.0, 162.0]], [[220.0, 83.0], [240.0, 83.0], [240.0, 182.0], [220.0, 182.0]]], "lines": ["そうです．．", "この町で", "火葬され．．．"]}, {"box": [582, 393, 678, 515], "vertical": true, "font_size": 21, "lines_coords": [[[650.0, 394.0], [675.0, 393.0], [678.0, 459.0], [654.0, 460.0]], [[629.0, 396.0], [649.0, 396.0], [651.0, 515.0], [631.0, 515.0]], [[606.0, 397.0], [626.0, 397.0], [626.0, 478.0], [606.0, 478.0]], [[582.0, 397.0], [603.0, 397.0], [603.0, 458.0], [582.0, 458.0]]], "lines": ["あっ．．．", "ここにもまた", "別の顔を", "発見！！"]}, {"box": [303, 352, 425, 492], "vertical": true, "font_size": 23, "lines_coords": [[[396.0, 353.0], [423.0, 352.0], [425.0, 416.0], [398.0, 417.0]], [[375.0, 353.0], [399.0, 353.0], [402.0, 476.0], [377.0, 476.0]], [[351.0, 355.0], [372.0, 355.0], [374.0, 473.0], [352.0, 473.0]], [[327.0, 355.0], [347.0, 355.0], [349.0, 492.0], [329.0, 492.0]], [[306.0, 355.0], [327.0, 355.0], [324.0, 454.0], [303.0, 454.0]]], "lines": ["そして", "そのすべてが、", "最近この町で", "亡くなった人の", "顔でした．．"]}, {"box": [221, 537, 294, 619], "vertical": true, "font_size": 23, "lines_coords": [[[264.0, 539.0], [291.0, 537.0], [294.0, 601.0], [267.0, 602.0]], [[247.0, 539.0], [267.0, 539.0], [267.0, 618.0], [247.0, 618.0]], [[221.0, 539.0], [242.0, 539.0], [243.0, 619.0], [222.0, 619.0]]], "lines": ["ねえ．．．", "どうして", "かしら！？"]}, {"box": [69, 363, 160, 502], "vertical": true, "font_size": 20, "lines_coords": [[[138.0, 365.0], [158.0, 365.0], [158.0, 483.0], [138.0, 483.0]], [[116.0, 365.0], [132.0, 365.0], [132.0, 481.0], [116.0, 481.0]], [[89.0, 363.0], [112.0, 363.0], [110.0, 502.0], [86.0, 502.0]]], "lines": ["その煙が渦を", "巻いた人達の", "顔だったのです"]}, {"box": [615, 553, 758, 728], "vertical": true, "font_size": 20, "lines_coords": [[[732.0, 553.0], [758.0, 553.0], [758.0, 617.0], [732.0, 617.0]], [[712.0, 553.0], [732.0, 553.0], [732.0, 673.0], [712.0, 673.0]], [[690.0, 555.0], [707.0, 555.0], [707.0, 727.0], [690.0, 727.0]], [[663.0, 554.0], [683.0, 554.0], [683.0, 653.0], [663.0, 653.0]], [[640.0, 555.0], [656.0, 555.0], [656.0, 690.0], [640.0, 690.0]], [[615.0, 554.0], [633.0, 554.0], [634.0, 692.0], [616.0, 692.0]]], "lines": ["．．．ねえ", "どういう事！？", "どうしてお父さんの", "やきものに", "この人達の顔が", "浮き出てるの！？"]}, {"box": [641, 796, 752, 902], "vertical": true, "font_size": 20, "lines_coords": [[[732.0, 798.0], [752.0, 798.0], [752.0, 897.0], [732.0, 897.0]], [[710.0, 800.0], [726.0, 800.0], [726.0, 900.0], [710.0, 900.0]], [[682.0, 796.0], [707.0, 796.0], [707.0, 861.0], [682.0, 861.0]], [[660.0, 798.0], [681.0, 798.0], [678.0, 895.0], [657.0, 895.0]]], "lines": ["どうしてと", "言われても、", "私には", "わからんが"]}, {"box": [256, 796, 423, 936], "vertical": true, "font_size": 20, "lines_coords": [[[403.0, 798.0], [423.0, 798.0], [423.0, 876.0], [403.0, 876.0]], [[378.0, 798.0], [398.0, 798.0], [398.0, 900.0], [378.0, 900.0]], [[355.0, 798.0], [375.0, 798.0], [375.0, 916.0], [355.0, 916.0]], [[330.0, 798.0], [350.0, 798.0], [350.0, 916.0], [330.0, 916.0]], [[307.0, 796.0], [327.0, 796.0], [324.0, 915.0], [304.0, 915.0]], [[283.0, 799.0], [300.0, 799.0], [300.0, 915.0], [283.0, 915.0]], [[259.0, 798.0], [280.0, 798.0], [277.0, 936.0], [256.0, 936.0]]], "lines": ["やきもの", "というのは、", "土と炎の芸術", "．．．いうなれば", "大自然の神が", "作りあげると", "いってもいい"]}, {"box": [195, 800, 212, 846], "vertical": true, "font_size": 17, "lines_coords": [[[195.0, 800.0], [212.0, 800.0], [212.0, 846.0], [195.0, 846.0]]], "lines": ["．．．"]}, {"box": [245, 967, 385, 1143], "vertical": true, "font_size": 20, "lines_coords": [[[365.0, 969.0], [385.0, 969.0], [385.0, 1085.0], [365.0, 1085.0]], [[340.0, 967.0], [359.0, 967.0], [359.0, 1125.0], [340.0, 1125.0]], [[317.0, 970.0], [334.0, 970.0], [334.0, 1123.0], [317.0, 1123.0]], [[293.0, 969.0], [313.0, 969.0], [313.0, 1088.0], [293.0, 1088.0]], [[267.0, 967.0], [288.0, 967.0], [289.0, 1143.0], [268.0, 1143.0]], [[245.0, 969.0], [264.0, 969.0], [264.0, 1088.0], [245.0, 1088.0]]], "lines": ["人知の及ばぬ", "世界だ．．．時として", "我々の計り知れぬ", "結果が出ても", "不思議はないんじゃ", "ないのかな？"]}], "img_path": "124.jpg"}, {"version": "0.1.7", "img_width": 839, "img_height": 1200, "blocks": [{"box": [667, 371, 764, 507], "vertical": true, "f