83.0], [121.0, 359.0], [101.0, 359.0]], [[77.0, 185.0], [97.0, 185.0], [97.0, 291.0], [77.0, 291.0]]], "lines": ["この町は", "うずまきに呪われた", "町なのです。"]}, {"box": [655, 405, 725, 583], "vertical": true, "font_size": 21, "lines_coords": [[[702.0, 405.0], [725.0, 405.0], [723.0, 583.0], [699.0, 583.0]], [[678.0, 406.0], [698.0, 406.0], [698.0, 563.0], [678.0, 563.0]], [[655.0, 405.0], [675.0, 405.0], [675.0, 542.0], [655.0, 542.0]]], "lines": ["．．．でも、今の私には", "この町を逃げ出す", "気力がない．．．"]}, {"box": [75, 404, 166, 579], "vertical": true, "font_size": 19, "lines_coords": [[[145.0, 405.0], [165.0, 405.0], [165.0, 579.0], [145.0, 579.0]], [[122.0, 405.0], [142.0, 405.0], [142.0, 503.0], [122.0, 503.0]], [[98.0, 404.0], [118.0, 404.0], [118.0, 540.0], [98.0, 540.0]], [[75.0, 404.0], [91.0, 404.0], [91.0, 519.0], [75.0, 519.0]]], "lines": ["この髪のうずまきが", "私の気力を", "奪っているので", "しょうか．．．"]}, {"box": [716, 621, 737, 706], "vertical": true, "font_size": 20, "lines_coords": [[[716.0, 621.0], [736.0, 621.0], [736.0, 703.0], [716.0, 703.0]]], "lines": ["私の髪は"]}, {"box": [383, 623, 426, 759], "vertical": true, "font_size": 18, "lines_coords": [[[403.0, 623.0], [423.0, 623.0], [426.0, 759.0], [406.0, 759.0]], [[383.0, 625.0], [399.0, 625.0], [399.0, 706.0], [383.0, 706.0]]], "lines": ["日に日に大きく", "なります"]}, {"box": [293, 629, 337, 726], "vertical": true, "font_size": 20, "lines_coords": [[[317.0, 629.0], [337.0, 629.0], [337.0, 706.0], [317.0, 706.0]], [[293.0, 629.0], [313.0, 629.0], [313.0, 726.0], [293.0, 726.0]]], "lines": ["五島さん", "おはよう！！"]}, {"box": [72, 633, 117, 748], "vertical": true, "font_size": 21, "lines_coords": [[[95.0, 633.0], [115.0, 633.0], [117.0, 746.0], [97.0, 746.0]], [[72.0, 634.0], [94.0, 634.0], [94.0, 694.0], [72.0, 694.0]]], "lines": ["ねえ！！見て、", "私を！！"]}, {"box": [317, 911, 336, 967], "vertical": true, "font_size": 18, "lines_coords": [[[317.0, 911.0], [335.0, 911.0], [335.0, 967.0], [317.0, 967.0]]], "lines": ["おお！！"]}], "img_path": "194.jpg"}, {"version": "0.1.7", "img_width":