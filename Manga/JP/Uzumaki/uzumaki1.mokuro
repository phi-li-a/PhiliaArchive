 589.0]], [[101.0, 489.0], [121.0, 489.0], [121.0, 629.0], [101.0, 629.0]]], "lines": ["斎藤さんに", "頼まれてたものが", "できたから、", "届けてきてくれ。"]}, {"box": [566, 1040, 578, 1080], "vertical": true, "font_size": 12, "lines_coords": [[[566.0, 1040.0], [578.0, 1040.0], [578.0, 1080.0], [566.0, 1080.0]]], "lines": ["．．．"]}], "img_path": "039.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [343, 96, 390, 194], "vertical": true, "font_size": 23, "lines_coords": [[[364.0, 96.0], [390.0, 96.0], [390.0, 158.0], [364.0, 158.0]], [[343.0, 97.0], [363.0, 97.0], [363.0, 194.0], [343.0, 194.0]]], "lines": ["ごめん", "ください．．．"]}, {"box": [65, 101, 104, 179], "vertical": true, "font_size": 20, "lines_coords": [[[84.0, 101.0], [104.0, 101.0], [104.0, 179.0], [84.0, 179.0]]], "lines": ["五島です"]}, {"box": [532, 405, 546, 446], "vertical": true, "font_size": 14, "lines_coords": [[[532.0, 405.0], [546.0, 405.0], [546.0, 446.0], [532.0, 446.0]]], "lines": ["．．．．．"]}, {"box": [71, 420, 118, 584], "vertical": true, "font_size": 24, "lines_coords": [[[93.0, 420.0], [117.0, 420.0], [117.0, 581.0], [93.0, 581.0]], [[71.0, 423.0], [94.0, 423.0], [94.0, 583.0], [71.0, 583.0]]], "lines": ["やあ、桐絵君かね。", "秀一は留守だがね。"]}, {"box": [659, 629, 726, 747], "vertical": true, "font_size": 19, "lines_coords": [[[703.0, 629.0], [724.0, 629.0], [726.0, 734.0], [705.0, 734.0]], [[682.0, 631.0], [702.0, 631.0], [702.0, 747.0], [682.0, 747.0]], [[660.0, 632.0], [676.0, 632.0], [676.0, 727.0], [660.0, 727.0]]], "lines": ["あ．．．あのォ、", "ご注文の品を", "お届けに．．．"]}, {"box": [478, 622, 529, 686], "vertical": true, "font_size": 28, "lines_coords": [[[500.0, 622.0], [529.0, 622.0], [529.0, 686.0], [500.0, 686.0]], [[478.0, 623.0], [506.0, 623.0], [506.0, 669.0], [478.0, 669.0]]], "lines": ["注文の", "品？"]}, {"box": [242, 632, 289, 696], "vertical": true, "font_size": 25, "lines_coords": [[[264.0, 632.0], [289.0, 632.0], [289.0, 696.0], [264.0, 696.0]], [[242.0, 633.0], [267.0, 633.0], [267.0, 696.0], [242.0, 696.0]]], "lines": ["ああ．．．", "例の．．．"]}, {"box": [72, 632, 117, 814], "vertical": true, "font_size": 20, "lines_coords": [[[94.0, 633.0], [114.0, 633.0], [114.0, 793.0], [94.0, 793.0]], [[72.0, 632.0], [92.0, 632.0], [93.0, 814.0], [73.0, 814.0]]], "lines": ["．．．申し訳ないがね。", "もう必要ないんだよ。"]}, {"box": [634, 1001, 732, 1101], "vertical": true, "font_size": 24, "lines_coords": [[[708.0, 1003.0], [732.0, 1003.0], [732.0, 1067.0], [708.0, 1067.0]], [[688.0, 1003.0], [708.0, 1003.0], [705.0, 1101.0], [685.0, 1101.0]], [[663.0, 1005.0], [684.0, 1005.0], [684.0, 1083.0], [663.0, 1083.0]], [[634.0, 1001.0], [665.0, 1001.0], [665.0, 1050.0], [634.0, 1050.0]]], "lines": ["あの．．", "うずまきの", "お皿です", "が．．．"]}, {"box": [71, 943, 96, 1021], "vertical": true, "font_size": 25, "lines_coords": [[[71.0, 943.0], [96.0, 943.0], [96.0, 1021.0], [71.0, 1021.0]]], "lines": ["えっ．．．？"]}], "img_path": "040.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [719, 89, 765, 187], "vertical": true, "font_size": 23, "lines_coords": [[[744.0, 91.0], [765.0, 91.0], [765.0, 187.0], [744.0, 187.0]], [[719.0, 89.0], [744.0, 89.0], [744.0, 152.0], [719.0, 152.0]]], "lines": ["あの．．．でも", "これ．．"]}, {"box": [518, 76, 613, 175], "vertical": true, "font_size": 22, "lines_coords": [[[592.0, 78.0], [611.0, 78.0], [611.0, 157.0], [592.0, 157.0]], [[566.0, 77.0], [590.0, 77.0], [590.0, 157.0], [566.0, 157.0]], [[545.0, 78.0], [565.0, 78.0], [565.0, 175.0], [545.0, 175.0]], [[518.0, 76.0], [545.0, 76.0], [545.0, 119.0], [518.0, 119.0]]], "lines": ["桐絵君．．．", "この間も", "言ったよう", "に．．．"]}, {"box": [286, 66, 379, 160], "vertical": true, "font_size": 26, "lines_coords": [[[359.0, 71.0], [379.0, 71.0], [379.0, 160.0], [359.0, 160.0]], [[332.0, 70.0], [358.0, 70.0], [358.0, 131.0], [332.0, 131.0]], [[307.0, 66.0], [338.0, 66.0], [338.0, 116.0], [307.0, 116.0]], [[286.0, 69.0], [311.0, 69.0], [311.0, 140.0], [286.0, 140.0]]], "lines": ["うずまきは", "自分で", "作る", "ものだ。"]}, {"box": [113, 77, 205, 189], "vertical