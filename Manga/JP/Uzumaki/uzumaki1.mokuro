87.0], [344.0, 587.0], [344.0, 680.0], [328.0, 680.0]], [[303.0, 583.0], [323.0, 583.0], [321.0, 700.0], [301.0, 700.0]]], "lines": ["それで秀一君、", "あいかわらず", "家に閉じこ", "もってるの？"]}, {"box": [96, 594, 190, 711], "vertical": true, "font_size": 21, "lines_coords": [[[171.0, 596.0], [187.0, 596.0], [187.0, 711.0], [171.0, 711.0]], [[144.0, 596.0], [165.0, 596.0], [165.0, 691.0], [144.0, 691.0]], [[114.0, 595.0], [140.0, 594.0], [144.0, 662.0], [118.0, 663.0]], [[96.0, 595.0], [116.0, 595.0], [116.0, 673.0], [96.0, 673.0]]], "lines": ["ちゃんとご飯", "食べてるの", "かしら、", "心配ね．．．"]}, {"box": [101, 744, 116, 789], "vertical": true, "font_size": 15, "lines_coords": [[[101.0, 744.0], [116.0, 744.0], [116.0, 789.0], [101.0, 789.0]]], "lines": ["．．．"]}, {"box": [262, 991, 358, 1097], "vertical": true, "font_size": 22, "lines_coords": [[[331.0, 991.0], [358.0, 991.0], [358.0, 1042.0], [331.0, 1042.0]], [[311.0, 993.0], [331.0, 993.0], [331.0, 1091.0], [311.0, 1091.0]], [[285.0, 992.0], [307.0, 992.0], [309.0, 1089.0], [288.0, 1089.0]], [[262.0, 992.0], [282.0, 992.0], [285.0, 1096.0], [265.0, 1096.0]]], "lines": ["桐絵、", "今夜にでも", "家に連れて", "来なさいよ。"]}, {"box": [111, 1010, 131, 1088], "vertical": true, "font_size": 20, "lines_coords": [[[111.0, 1010.0], [131.0, 1010.0], [131.0, 1088.0], [111.0, 1088.0]]], "lines": ["そうね．．．"]}], "img_path": "125.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [486, 85, 533, 271], "vertical": true, "font_size": 24, "lines_coords": [[[510.0, 86.0], [533.0, 86.0], [533.0, 264.0], [510.0, 264.0]], [[486.0, 85.0], [510.0, 85.0], [510.0, 271.0], [486.0, 271.0]]], "lines": ["桐絵、やめてくれ．．．", "引っぱらないでくれ。"]}, {"box": [75, 80, 118, 371], "vertical": true, "font_size": 20, "lines_coords": [[[94.0, 80.0], [118.0, 80.0], [118.0, 314.0], [94.0, 314.0]], [[75.0, 82.0], [91.0, 82.0], [91.0, 371.0], [75.0, 371.0]]], "lines": ["だめよ、こうでもしなきゃ", "外に出ようともしないんだから！"]}, {"box": [661, 404, 731, 547], "vertical": true, "font_size": 20, "lines_coords": [[[709.