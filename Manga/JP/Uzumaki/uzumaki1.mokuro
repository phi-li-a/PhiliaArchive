, 466], "vertical": true, "font_size": 21, "lines_coords": [[[714.0, 365.0], [733.0, 365.0], [733.0, 465.0], [714.0, 465.0]], [[690.0, 364.0], [710.0, 364.0], [710.0, 461.0], [690.0, 461.0]], [[663.0, 363.0], [688.0, 360.0], [692.0, 397.0], [668.0, 400.0]]], "lines": ["おい母さん、", "もうやめて", "よ。"]}, {"box": [526, 365, 595, 446], "vertical": true, "font_size": 24, "lines_coords": [[[574.0, 366.0], [595.0, 366.0], [595.0, 445.0], [574.0, 445.0]], [[546.0, 365.0], [576.0, 365.0], [576.0, 430.0], [546.0, 430.0]], [[526.0, 366.0], [547.0, 366.0], [548.0, 446.0], [527.0, 446.0]]], "lines": ["あんたは", "黙って", "なさい！"]}, {"box": [266, 363, 430, 481], "vertical": true, "font_size": 22, "lines_coords": [[[409.0, 366.0], [429.0, 366.0], [429.0, 462.0], [409.0, 462.0]], [[385.0, 366.0], [405.0, 366.0], [405.0, 467.0], [385.0, 467.0]], [[358.0, 365.0], [383.0, 365.0], [383.0, 442.0], [358.0, 442.0]], [[336.0, 365.0], [357.0, 365.0], [357.0, 441.0], [336.0, 441.0]], [[308.0, 363.0], [337.0, 363.0], [337.0, 428.0], [308.0, 428.0]], [[290.0, 365.0], [311.0, 365.0], [309.0, 481.0], [288.0, 481.0]], [[266.0, 365.0], [287.0, 365.0], [287.0, 450.0], [266.0, 450.0]]], "lines": ["子が子なら", "親も親だよ、", "だいたい", "あんたの", "亭主は", "ギャンブルで", "借金して、"]}, {"box": [67, 527, 160, 625], "vertical": true, "font_size": 21, "lines_coords": [[[133.0, 528.0], [160.0, 528.0], [160.0, 589.0], [133.0, 589.0]], [[112.0, 528.0], [133.0, 528.0], [133.0, 624.0], [112.0, 624.0]], [[87.0, 527.0], [107.0, 527.0], [110.0, 624.0], [90.0, 624.0]], [[68.0, 529.0], [84.0, 529.0], [84.0, 625.0], [68.0, 625.0]]], "lines": ["一家で", "夜逃げして", "きたんじゃ", "ないのさ！！"]}, {"box": [527, 672, 713, 817], "vertical": true, "font_size": 20, "lines_coords": [[[691.0, 675.0], [712.0, 675.0], [712.0, 761.0], [691.0, 761.0]], [[668.0, 675.0], [689.0, 675.0], [689.0, 753.0], [668.0, 753.0]], [[643.0, 675.0], [664.0, 675.0], [665.0, 817.0], [644.0, 817.0]], [[621.0, 676.0], [641.0, 676.0], [641.0, 810.0], [621.0, 810.0]], [[596.0, 675.0], [616.0, 675.0], [616