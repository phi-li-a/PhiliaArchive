nes_coords": [[[264.0, 76.0], [281.0, 76.0], [281.0, 188.0], [264.0, 188.0]], [[239.0, 73.0], [256.0, 73.0], [257.0, 226.0], [240.0, 226.0]], [[215.0, 75.0], [235.0, 75.0], [235.0, 153.0], [215.0, 153.0]], [[191.0, 75.0], [211.0, 75.0], [211.0, 210.0], [191.0, 210.0]], [[166.0, 73.0], [186.0, 73.0], [187.0, 216.0], [167.0, 216.0]]], "lines": ["彼は以前から", "目立ちたかり屋で", "その時も", "人目を引こうと", "していたのです。"]}, {"box": [713, 540, 756, 662], "vertical": true, "font_size": 18, "lines_coords": [[[735.0, 540.0], [756.0, 540.0], [753.0, 637.0], [732.0, 637.0]], [[714.0, 541.0], [730.0, 541.0], [730.0, 659.0], [714.0, 659.0]]], "lines": ["大勢の人が", "見つめる中で、"]}, {"box": [690, 755, 765, 836], "vertical": true, "font_size": 27, "lines_coords": [[[735.0, 755.0], [765.0, 755.0], [765.0, 801.0], [735.0, 801.0]], [[714.0, 758.0], [738.0, 758.0], [738.0, 836.0], [714.0, 836.0]], [[690.0, 755.0], [716.0, 755.0], [716.0, 822.0], [690.0, 822.0]]], "lines": ["その", "死に顔は", "なぜか、"]}, {"box": [235, 537, 356, 673], "vertical": true, "font_size": 21, "lines_coords": [[[331.0, 537.0], [356.0, 537.0], [356.0, 618.0], [331.0, 618.0]], [[311.0, 539.0], [328.0, 539.0], [328.0, 672.0], [311.0, 672.0]], [[286.0, 539.0], [306.0, 539.0], [306.0, 633.0], [286.0, 633.0]], [[262.0, 537.0], [282.0, 537.0], [282.0, 673.0], [262.0, 673.0]], [[235.0, 539.0], [252.0, 539.0], [252.0, 635.0], [235.0, 635.0]]], "lines": ["いやだ．．．", "信じられない：", "いやなもの", "見ちゃったわね", "関野さん．．．"]}, {"box": [393, 759, 464, 839], "vertical": true, "font_size": 23, "lines_coords": [[[439.0, 759.0], [464.0, 759.0], [464.0, 822.0], [439.0, 822.0]], [[417.0, 760.0], [438.0, 760.0], [438.0, 839.0], [417.0, 839.0]], [[393.0, 759.0], [415.0, 759.0], [415.0, 828.0], [393.0, 828.0]]], "lines": ["とても", "満足そう", "でした。"]}, {"box": [99, 555, 192, 731], "vertical": true, "font_size": 21, "lines_coords": [[[171.0, 557.0], [191.0, 557.0], [192.0, 710.0], [172.0, 710.0]], [[145.0, 556.0], [168.0, 556.0], [172.0, 731.0], [148.0, 731.0]], [[121.0, 555.0], [148.0, 555.0], [148.0, 602.0], [121.0, 602.0]], [[99.0, 557.0], [119.0, 557.0], [119.0, 699.0], [99.0, 699.0]]], "lines": ["いくら目立ちたい", "からって、あんな事", "．．．．．", "気が知れないわ。"]}], "img_path": "179.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [685, 101, 730, 218], "vertical": true, "font_size": 21, "lines_coords": [[[708.0, 103.0], [730.0, 103.0], [730.0, 144.0], [708.0, 144.0]], [[685.0, 101.0], [705.0, 101.0], [705.0, 217.0], [685.0, 217.0]]], "lines": ["．．．．．", "そうかしら．．"]}, {"box": [419, 90, 462, 243], "vertical": true, "font_size": 17, "lines_coords": [[[442.0, 90.0], [459.0, 90.0], [460.0, 242.0], [443.0, 242.0]], [[419.0, 90.0], [436.0, 90.0], [436.0, 213.0], [419.0, 213.0]]], "lines": ["私は彼の気持ちが", "よくわかるわ。"]}, {"box": [351, 86, 376, 150], "vertical": true, "font_size": 25, "lines_coords": [[[351.0, 86.0], [376.0, 86.0], [376.0, 150.0], [351.0, 150.0]]], "lines": ["えっ？"]}, {"box": [68, 87, 162, 321], "vertical": true, "font_size": 20, "lines_coords": [[[141.0, 89.0], [162.0, 89.0], [162.0, 173.0], [141.0, 173.0]], [[118.0, 87.0], [138.0, 87.0], [136.0, 301.0], [116.0, 301.0]], [[93.0, 87.0], [113.0, 87.0], [112.0, 310.0], [92.0, 310.0]], [[71.0, 87.0], [90.0, 87.0], [86.0, 321.0], [68.0, 321.0]]], "lines": ["．．．だって、", "他人から注目されるって", "すごく幸せな事じゃない。", "五島さんもそう思わない？"]}, {"box": [711, 451, 731, 529], "vertical": true, "font_size": 20, "lines_coords": [[[711.0, 451.0], [731.0, 451.0], [731.0, 529.0], [711.0, 529.0]]], "lines": ["えーっ．．．"]}, {"box": [442, 455, 511, 632], "vertical": true, "font_size": 22, "lines_coords": [[[487.0, 455.0], [511.0, 455.0], [511.0, 632.0], [487.0, 632.0]], [[464.0, 455.0], [484.0, 455.0], [486.0, 611.0], [466.0, 611.0]], [[442.0, 457.0], [463.0, 457.0], [463.0, 525.0], [442.0, 525.0]]], "lines": ["：私は、目立つのは", "あんまり好きじゃ", "ないな。"]}, {"box": [172, 442, 201, 507], "vertical": true, "font_size": 22, "lines_coords": [[[172.0, 442.0], [201.0, 442.0], [201.0, 507.0], [172.0, 507.0]]], "lines": ["本当？"]}, {"box": [70, 485, 137, 643], "vertical": true, "font_size": 22, "lines_coords": [[[113.0, 485.0], [137.0, 485.0], [137.0, 643.0], [113.0, 643.0]], [[92.0, 486.0], [112.0, 486.0], [112.0, 623.0], [92.0, 623.0]], [[70.0, 487.0], [86.0, 487.0], [86.0, 611.0], [70.0, 611.0]]], "lines": ["私は目立ちたいと", "思ってるわよ．．．", "最近特に．．．！"]}, {"box": [685, 713, 732, 775], "vertical": true, "font_size": 24, "lines_coords": [[[711.0, 714.0], [732.0, 714.0], [732.0, 774.0], [711.0, 774.0]], [[685.0, 713.0], [711.0, 713.0], [711.0, 775.0], [685.0, 775.0]]], "lines": ["目立ち", "たい！！"]}, {"box": [594, 706, 641, 842], "vertical": true, "font_size": 20, "lines_coords": [[[620.0, 708.0], [640.0, 708.0], [640.0, 842.0], [620.0, 842.0]], [[594.0, 706.0], [614.0, 706.0], [616.0, 805.0], [596.0, 805.0]]], "lines": ["みんなの注目を", "集めたい！！"]}, {"box": [66, 706, 105, 783], "vertical": true, "font_size": 17, "lines_coords": [[[66.0, 706.0], [83.0, 706.0], [83.0, 782.0], [66.0, 782.0]]], "lines": ["ふうん．．．"]}, {"box": [446, 972, 563, 1091], "vertical": true, "font_size": 20, "lines_coords": [[[539.0, 972.0], [563.0, 972.0], [563.0, 1035.0], [539.0, 1035.0]], [[517.0, 975.0], [537.0, 975.0], [537.0, 1076.0], [517.0, 1076.0]], [[492.0, 973.0], [512.0, 973.0], [512.0, 1072.0], [492.0, 1072.0]], [[469.0, 975.0], [488.0, 975.0], [488.0, 1072.0], [469.0, 1072.0]], [[446.0, 976.0], [463.0, 976.0], [463.0, 1089.0], [446.0, 1089.0]]], "lines": ["．．．でも", "残念な事に、", "どうしたら", "目立つのか", "わからない．．．"]}, {"box": [227, 957, 349, 1106], "vertical": true, "font_size": 23, "lines_coords": [[[317.0, 957.0], [349.0, 957.0], [349.0, 1006.0], [317.0, 1006.0]], [[297.0, 960.0], [317.0, 960.0], [321.0, 1076.0], [301.0, 1076.0]], [[272.0, 960.0], [296.0, 959.0], [298.0, 1028.0], [274.0, 1030.0]], [[252.0, 962.0], [272.0, 962.0], [272.0, 1078.0], [252.0, 1078.0]], [[227.0, 960.0], [247.0, 960.0], [248.0, 1106.0], [228.0, 1106.0]]], "lines": ["ただ", "騒ぐとかじゃ", "なくて、", "本当の意味で", "注目されたいの。"]}], "img_path": "180.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [328, 78, 445, 233], "vertical": true, "font_size": 20, "lines_coords": [[[423.0, 79.0], [443.0, 79.0], [443.0, 180.0], [423.0, 180.0]], [[397.0, 78.0], [418.0, 78.0], [419.0, 178.0], [398.0, 178.0]], [[375.0, 79.0], [395.0, 79.0], [395.0, 233.0], [375.0, 233.0]], [[350.0, 78.0], [370.0, 78.0], [370.0, 214.0], [350.0, 214.0]], [[328.0, 79.0], [348.0, 79.0], [348.0, 198.0], [328.0, 198.0]]], "lines": ["確かに最近、", "この町では", "目立ちたがり屋が", "増えてるような", "気がするな．．．"]}, {"box": [646, 329, 772, 433], "vertical": true, "font_size": 26, "lines_coords": [[[744.0, 330.0], [772.0, 330.0], [772.0, 375.0], [744.0, 375.0]], [[722.0, 331.0], [748.0, 331.0], [748.0, 392.0], [722.0, 392.0]], [[697.0, 332.0], [718.0, 332.0], [719.0, 431.0], [698.0, 431.0]], [[673.0, 331.0], [698.0, 331.0], [698.0, 393.0], [673.0, 393.0]], [[646.0, 329.0], [678.0, 329.0], [678.0, 383.0], [646.0, 383.0]]], "lines": ["その", "転落死", "したやつが、", "最たる", "例だ。"]}, {"box": [401, 336, 517, 441], "vertical": true, "font_size": 22, "lines_coords": [[[492.0, 336.0], [517.0, 336.0], [517.0, 398.0], [492.0, 398.0]], [[469.0, 337.0], [494.0, 337.0], [494.0, 399.0], [469.0, 399.0]], [[446.0, 337.0], [467.0, 337.0], [469.0, 441.0], [447.0, 441.0]], [[424.0, 338.0], [444.0, 338.0], [444.0, 435.0], [424.0, 435.0]], [[402.0, 338.0], [418.0, 338.0], [418.0, 435.0], [402.0, 435.0]]], "lines": ["．．．なぜ", "危険を", "犯してまで、", "目立とうと", "するのか．．．"]}, {"box": [324, 343, 369, 479], "vertical": true, "font_size": 20, "lines_coords": [[[347.0, 343.0], [368.0, 343.0], [369.0, 479.0], [348.0, 479.0]], [[324.0, 344.0], [344.0, 344.0], [344.0, 441.0], [324.0, 441.0]]], "lines": ["その理由が最近", "わかった．．．"]}, {"box": [333, 537, 373, 655], "vertical": true, "font_size": 21, "lines_coords": [[[350.0, 537.0], [371.0, 537.0], [372.0, 655.0], [351.0, 655.0]]], "lines": ["それはやはり"]}, {"box": [97, 333, 145, 478], "vertical": true, "font_size": 20, "lines_coords": [[[124.0, 336.0], [144.0, 336.0], [143.0, 478.0], [123.0, 478.0]], [[99.0, 333.0], [120.0, 333.0], [118.0, 432.0], [97.0, 432.0]]], "lines": ["えっ、なぜなの？", "．．．秀一君．．．"]}, {"box": [696, 752, 766, 830], "vertical": true, "font_size": 24, "lines_coords": [[[742.0, 752.0], [766.0, 752.0], [766.0, 814.0], [742.0, 814.0]], [[719.0, 753.0], [741.0, 753.0], [741.0, 830.0], [719.0, 830.0]], [[696.0, 752.0], [721.0, 752.0], [721.0, 776.0], [696.0, 776.0]]], "lines": ["．．．また", "それなの", "？"]}, {"box": [498, 756, 617, 889], "vertical": true, "font_size": 19, "lines_coords": [[[593.0, 757.0], [617.0, 757.0], [617.0, 825.0], [593.0, 825.0]], [[569.0, 758.0], [589.0, 758.0], [588.0, 889.0], [568.0, 889.0]], [[547.0, 758.0], [563.0, 758.0], [563.0, 851.0], [547.0, 851.0]], [[520.0, 757.0], [540.0, 757.0], [540.0, 851.0], [520.0, 851.0]], [[499.0, 758.0], [515.0, 758.0], [515.0, 851.0], [499.0, 851.0]]], "lines": ["．．．でも、", "目立ちたがりと", "うすまきは", "何の関係が", "あるのよ？"]}, {"box": [412, 769, 455, 867], "vertical": true, "font_size": 19, "lines_coords": [[[433.0, 769.0], [454.0, 769.0], [454.0, 866.0], [433.0, 866.0]], [[412.0, 769.0], [429.0, 769.0], [429.0, 866.0], [412.0, 866.0]]], "lines": ["大いに関係", "あるとも！！"]}, {"box": [89, 529, 159, 712], "vertical": true, "font_size": 22, "lines_coords": [[[134.0, 529.0], [159.0, 529.0], [159.0, 609.0], [134.0, 609.0]], [[113.0, 529.0], [133.0, 529.0], [133.0, 667.0], [113.0, 667.0]], [[89.0, 529.0], [109.0, 529.0], [109.0, 712.0], [89.0, 712.0]]], "lines": ["この町が", "うずまきに汚染", "されているからだな。"]}, {"box": [111, 761, 177, 875], "vertical": true, "font_size": 18, "lines_coords": [[[157.0, 761.0], [177.0, 761.0], [177.0, 857.0], [157.0, 857.0]], [[134.0, 764.0], [151.0, 764.0], [151.0, 875.0], [134.0, 875.0]], [[111.0, 761.0], [127.0, 761.0], [127.0, 857.0], [111.0, 857.0]]], "lines": ["この両者に", "共通するもの", "．．．それは．．．"]}, {"box": [110, 955, 177, 1092], "vertical": true, "font_size": 19, "lines_coords": [[[155.0, 955.0], [177.0, 955.0], [174.0, 1037.0], [153.0, 1037.0]], [[132.0, 956.0], [152.0, 956.0], [152.0, 1092.0], [132.0, 1092.0]], [[110.0, 956.0], [126.0, 956.0], [126.0, 1091.0], [110.0, 1091.0]]], "lines": ["人の目を", "引きつけようと", "するところだ！！"]}], "img_path": "181.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [525, 80, 714, 217], "vertical": true, "font_size": 20, "lines_coords": [[[696.0, 83.0], [712.0, 83.0], [712.0, 178.0], [696.0, 178.0]], [[669.0, 82.0], [689.0, 82.0], [689.0, 215.0], [669.0, 215.0]], [[646.0, 82.0], [667.0, 82.0], [667.0, 161.0], [646.0, 161.0]], [[622.0, 83.0], [642.0, 83.0], [642.0, 180.0], [622.0, 180.0]], [[600.0, 83.0], [616.0, 83.0], [616.0, 186.0], [600.0, 186.0]], [[574.0, 83.0], [594.0, 83.0], [594.0, 215.0], [574.0, 215.0]], [[549.0, 82.0], [569.0, 82.0], [569.0, 216.0], [549.0, 216.0]], [[525.0, 80.0], [549.0, 80.0], [549.0, 142.0], [525.0, 142.0]]], "lines": ["うずまきは", "ものを吸い込む", "．．．それを", "図案化した", "模様もまた、", "人の目を中心へ", "引きつける力が", "ある．．"]}, {"box": [356, 114, 449, 349], "vertical": true, "font_size": 19, "lines_coords": [[[427.0, 116.0], [447.0, 116.0], [447.0, 290.0], [427.0, 290.0]], [[402.0, 114.0], [423.0, 114.0], [424.0, 291.0], [403.0, 291.0]], [[379.0, 116.0], [399.0, 116.0], [399.0, 349.0], [379.0, 349.0]], [[356.0, 117.0], [372.0, 117.0], [372.0, 271.0], [356.0, 271.0]]], "lines": ["従って、うずまきに", "とり憑かれた人間も", "他人の目を引きつけようと", "し始めるわけだ．．．"]}, {"box": [232, 84, 324, 241], "vertical": true, "font_size": 20, "lines_coords": [[[304.0, 85.0], [324.0, 85.0], [324.0, 171.0], [304.0, 171.0]], [[280.0, 86.0], [300.0, 86.0], [300.0, 221.0], [280.0, 221.0]], [[254.0, 84.0], [274.0, 84.0], [276.0, 241.0], [256.0, 241.0]], [[232.0, 86.0], [254.0, 86.0], [254.0, 107.0], [232.0, 107.0]]], "lines": ["．．．じゃあ、", "転落死した彼は", "うずまきのせいで", "？"]}, {"box": [295, 304, 320, 367], "vertical": true, "font_size": 25, "lines_coords": [[[295.0, 304.0], [320.0, 304.0], [320.0, 367.0], [295.0, 367.0]]], "lines": ["ああ．．．"]}, {"box": [59, 289, 128, 482], "vertical": true, "font_size": 20, "lines_coords": [[[105.0, 289.0], [125.0, 289.0], [127.0, 413.0], [107.0, 413.0]], 