.0], [121.0, 616.0], [118.0, 792.0], [98.0, 792.0]]], "lines": ["町の上空には再び", "．．．", "あの黒いうずまき模様が", "立ち上ったのです！"]}], "img_path": "081.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [102, 182, 118, 277], "vertical": true, "font_size": 16, "lines_coords": [[[102.0, 182.0], [118.0, 182.0], [118.0, 277.0], [102.0, 277.0]]], "lines": ["．．．第３話"]}, {"box": [65, 285, 157, 442], "vertical": false, "font_size": 154, "lines_coords": [[[71.0, 285.0], [157.0, 289.0], [151.0, 442.0], [65.0, 439.0]]], "lines": ["体験"]}, {"box": [194, 530, 261, 614], "vertical": true, "font_size": 20.0, "lines_coords": [[[202.0, 534.0], [222.0, 536.0], [214.0, 605.0], [194.0, 603.0]], [[241.0, 530.0], [261.0, 530.0], [259.0, 614.0], [239.0, 614.0]]], "lines": ["やはりね", "．．．"]}], "img_path": "082.jpg"}, {"version": "0.1.7", "img_width": 841, "img_height": 1200, "blocks": [{"box": [677, 98, 746, 195], "vertical": true, "font_size": 21, "lines_coords": [[[722.0, 98.0], [743.0, 98.0], [746.0, 194.0], [725.0, 194.0]], [[701.0, 99.0], [721.0, 99.0], [721.0, 195.0], [701.0, 195.0]], [[677.0, 99.0], [698.0, 99.0], [698.0, 179.0], [677.0, 179.0]]], "lines": ["私が地元の", "黒渦高校に", "入学して"]}, {"box": [325, 91, 495, 210], "vertical": true, "font_size": 23, "lines_coords": [[[470.0, 93.0], [495.0, 93.0], [495.0, 173.0], [470.0, 173.0]], [[449.0, 96.0], [469.0, 96.0], [469.0, 192.0], [449.0, 192.0]], [[425.0, 94.0], [445.0, 94.0], [445.0, 210.0], [425.0, 210.0]], [[394.0, 91.0], [427.0, 91.0], [427.0, 144.0], [394.0, 144.0]], [[375.0, 93.0], [397.0, 93.0], [398.0, 210.0], [377.0, 210.0]], [[347.0, 93.0], [367.0, 93.0], [370.0, 191.0], [350.0, 191.0]], [[325.0, 94.0], [346.0, 94.0], [346.0, 161.0], [325.0, 161.0]]], "lines": ["クラスで", "一番最初に", "親しくなった", "のが、", "席の近かった", "黒谷あざみ", "でした。"]}, {"box": [130, 97, 199, 194], "vertical": true, "font_size": 20, "lines_coords": [[[178.0, 97.0], [197.0, 97.0], [197.0, 194.0], [178.0, 194.0]], [[154.0, 98.0], [174.0, 98.0], [174.0, 194.0], [154.0, 194.0]], [[130.0, 97.0], [151.0, 97.0], [151.0, 181.0], [130.0, 181.0]]], "lines": ["緑山市から", "通っている", "子でした。"]}, {"box": [636, 544, 763, 649], "vertical": true, "font_size": 25, "lines_coords": [[[733.0, 549.0], [763.0, 549.0], [763.0, 612.0], [733.0, 612.0]], [[714.0, 551.0], [735.0, 551.0], [735.0, 649.0], [714.0, 649.0]], [[688.0, 550.0], [713.0, 550.0], [713.0, 639.0], [688.0, 639.0]], [[666.0, 551.0], [686.0, 551.0], [686.0, 646.0], [666.0, 646.0]], [[641.0, 544.0], [671.0, 548.0], [665.0, 592.0], [636.0, 589.0]]], "lines": ["彼女の", "第一印象は", "”きれいで", "おとなしい", "子”。"]}, {"box": [384, 550, 454, 712], "vertical": true, "font_size": 20, "lines_coords": [[[433.0, 550.0], [453.0, 550.0], [453.0, 685.0], [433.0, 685.0]], [[408.0, 550.0], [428.0, 550.0], [428.0, 705.0], [408.0, 705.0]], [[384.0, 550.0], [404.0, 550.0], [404.0, 712.0], [384.0, 712.0]]], "lines": ["．．．でも、今では", "彼女と親しくした", "事を後悔している。"]}, {"box": [112, 544, 179, 762], "vertical": true, "font_size": 19, "lines_coords": [[[158.0, 544.0], [179.0, 544.0], [178.0, 739.0], [156.0, 739.0]], [[134.0, 547.0], [154.0, 547.0], [154.0, 762.0], [134.0, 762.0]], [[112.0, 548.0], [128.0, 548.0], [128.0, 738.0], [112.0, 738.0]]], "lines": ["親しくしていなければ", "彼女と秀一君が出会う事も", "なかったと思うから．．．"]}, {"box": [103, 883, 187, 1096], "vertical": true, "font_size": 19, "lines_coords": [[[167.0, 883.0], [187.0, 883.0], [187.0, 999.0], [167.0, 999.0]], [[145.0, 884.0], [161.0, 884.0], [161.0, 1073.0], [145.0, 1073.0]], [[119.0, 883.0], [139.0, 883.0], [140.0, 1096.0], [120.0, 1096.0]]], "lines": ["そして彼女が", "あんな事にならなくて", "すんだかもしれないから"]}], "img_path": "083.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [651, 92, 719, 246], "vertical": true, "font_size": 18, "lines_coords": [[[698.0, 92.0], [719.0, 92.0], [717.0, 210.0], [696.0, 210.0]], [[677.0, 94.0], [694.0, 94.0], [694.0, 246.0], [677.0, 246.0]], [[654.0, 92.0], [671.0, 92.0], [669.0, 195.0], [651.0, 195.0]]], "lines": ["入学当時から", "彼女は異常なほど", "もてました。"]}, {"