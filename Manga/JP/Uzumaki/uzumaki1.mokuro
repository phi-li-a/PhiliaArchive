, 576, 534, 639], "vertical": true, "font_size": 24, "lines_coords": [[[510.0, 576.0], [534.0, 576.0], [534.0, 639.0], [510.0, 639.0]]], "lines": ["あっ！？"]}, {"box": [296, 679, 368, 815], "vertical": true, "font_size": 22, "lines_coords": [[[348.0, 679.0], [368.0, 679.0], [365.0, 815.0], [345.0, 815.0]], [[322.0, 680.0], [343.0, 680.0], [343.0, 776.0], [322.0, 776.0]], [[296.0, 680.0], [321.0, 680.0], [321.0, 760.0], [296.0, 760.0]]], "lines": ["すべてはこの町", "．．．黒渦町の", "せいだ！！"]}, {"box": [70, 679, 164, 854], "vertical": true, "font_size": 21, "lines_coords": [[[141.0, 679.0], [162.0, 679.0], [164.0, 759.0], [143.0, 759.0]], [[119.0, 679.0], [139.0, 679.0], [139.0, 854.0], [119.0, 854.0]], [[93.0, 679.0], [114.0, 679.0], [116.0, 815.0], [94.0, 815.0]], [[70.0, 679.0], [91.0, 679.0], [93.0, 759.0], [72.0, 759.0]]], "lines": ["なぜなら", "この町はうずまきに", "汚染されている", "からだ！！"]}, {"box": [397, 983, 488, 1101], "vertical": true, "font_size": 19, "lines_coords": [[[467.0, 984.0], [487.0, 984.0], [487.0, 1101.0], [467.0, 1101.0]], [[444.0, 985.0], [464.0, 985.0], [464.0, 1100.0], [444.0, 1100.0]], [[422.0, 983.0], [438.0, 983.0], [436.0, 1099.0], [419.0, 1099.0]], [[397.0, 984.0], [417.0, 984.0], [417.0, 1087.0], [397.0, 1087.0]]], "lines": ["しかし、その", "両端が伸びて", "うずまき状に", "なったんだ。"]}, {"box": [79, 972, 147, 1086], "vertical": true, "font_size": 19, "lines_coords": [[[126.0, 972.0], [147.0, 972.0], [147.0, 1050.0], [126.0, 1050.0]], [[103.0, 973.0], [119.0, 973.0], [119.0, 1086.0], [103.0, 1086.0]], [[79.0, 973.0], [99.0, 973.0], [99.0, 1050.0], [79.0, 1050.0]]], "lines": ["君は早く", "この町を去る", "べきだ！！"]}], "img_path": "098.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [660, 90, 751, 226], "vertical": true, "font_size": 19, "lines_coords": [[[730.0, 91.0], [751.0, 91.0], [751.0, 173.0], [730.0, 173.0]], [[709.0, 91.0], [725.0, 91.0], [725.0, 205.0], [709.0, 205.0]], [[683.0, 90.0], [703.0, 90.0], [703.0, 226.0], [683.0, 226.0]], [[660.0, 90.0], [680.0, 90.0], [680.0, 208.0], [660.0, 208.0]]], "lines": ["．．．しかし、", "黒谷あざみは", "秀一君の忠告を", "聞くどころか、"]}, {"box": [114, 86, 230, 243], "vertical": true, "font_size": 20, "lines_coords": [[[209.0, 89.0], [229.0, 89.0], [229.0, 226.0], [209.0, 226.0]], [[185.0, 90.0], [205.0, 90.0], [205.0, 212.0], [185.0, 212.0]], [[159.0, 87.0], [184.0, 87.0], [184.0, 167.0], [159.0, 167.0]], [[138.0, 86.0], [158.0, 86.0], [155.0, 243.0], [136.0, 243.0]], [[116.0, 87.0], [132.0, 87.0], [132.0, 210.0], [116.0, 210.0]]], "lines": ["しばらくすると", "親を説得して、", "この町で", "アパート暮らしを", "始めたのです。"]}, {"box": [695, 301, 763, 476], "vertical": true, "font_size": 19, "lines_coords": [[[743.0, 302.0], [763.0, 302.0], [763.0, 439.0], [743.0, 439.0]], [[719.0, 301.0], [739.0, 301.0], [737.0, 457.0], [717.0, 457.0]], [[696.0, 302.0], [714.0, 302.0], [712.0, 475.0], [695.0, 475.0]]], "lines": ["そして夜な夜な", "彼のもとを訪れる", "ようになりました"]}, {"box": [511, 318, 578, 417], "vertical": true, "font_size": 22, "lines_coords": [[[558.0, 321.0], [578.0, 321.0], [578.0, 417.0], [558.0, 417.0]], [[531.0, 318.0], [556.0, 318.0], [556.0, 382.0], [531.0, 382.0]], [[511.0, 318.0], [531.0, 318.0], [531.0, 397.0], [511.0, 397.0]]], "lines": ["秀一さん！！", "ここを", "開けて！！"]}, {"box": [317, 301, 454, 455], "vertical": true, "font_size": 19, "lines_coords": [[[432.0, 302.0], [453.0, 302.0], [453.0, 379.0], [432.0, 379.0]], [[412.0, 303.0], [429.0, 303.0], [429.0, 435.0], [412.0, 435.0]], [[386.0, 302.0], [406.0, 302.0], [406.0, 380.0], [386.0, 380.0]], [[364.0, 303.0], [381.0, 303.0], [381.0, 417.0], [364.0, 417.0]], [[338.0, 302.0], [358.0, 302.0], [358.0, 455.0], [338.0, 455.0]], [[317.0, 302.0], [334.0, 302.0], [334.0, 403.0], [317.0, 403.0]]], "lines": ["お願い！！", "こんな気持ちは", "初めて！！", "今までは男の", "ほうが私に夢中に", "なったのに、"]}, {"box": [94, 305, 163, 442], "vertical": true, "font_size": 19, "lines_coords": [[[143.0, 307.0], [162.0, 307.0], [160.0, 442.0], [140.0, 442.0]], [[119.0, 305.0], [140.0, 305.0], [138.0, 425.0], [117.0, 425.0]], [[94.0, 307.0], [111.0, 307.0], [111.0, 421.0], [94.0, 421.0]]], "lines": ["今は私のほうが", "あなたに夢中", "たなんて．．．"]}], "img_path": "099.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [563, 65, 655, 201], "vertical": true, "font_size": 21, "lines_coords": [[[635.0, 67.0], [655.0, 67.0], [653.0, 164.0], [633.0, 164.0]], [[610.0, 65.0], [631.0, 65.0], [631.0, 127.0], [610.0, 127.0]], [[587.0, 65.0], [608.0, 65.0], [605.0, 201.0], [583.0, 201.0]], [[563.0, 65.0], [583.0, 65.0], [583.0, 182.0], [563.0, 182.0]]], "lines": ["あざみさん", "．．．もう", "秀一君の所へは", "行かないで！！"]}, {"box": [361, 67, 527, 188], "vertical": true, "font_size": 24, "lines_coords": [[[506.0, 71.0], [527.0, 71.0], [527.0, 131.0], [506.0, 131.0]], [[483.0, 70.0], [504.0, 70.0], [501.0, 188.0], [480.0, 188.0]], [[454.0, 69.0], [484.0, 69.0], [484.0, 134.0], [454.0, 134.0]], [[432.0, 69.0], [457.0, 69.0], [454.0, 150.0], [430.0, 150.0]], [[409.0, 70.0], [433.0, 70.0], [433.0, 151.0], [409.0, 151.0]], [[386.0, 70.0], [406.0, 70.0], [406.0, 166.0], [386.0, 166.0]], [[361.0, 67.0], [388.0, 67.0], [388.0, 113.0], [361.0, 113.0]]], "lines": ["とても", "迷惑がってる", "のよ．．．", "それに．．．", "秀一君は", "私の彼なの", "よ！！"]}, {"box": [268, 77, 335, 213], "vertical": true, "font_size": 19, "lines_coords": [[[315.0, 78.0], [335.0, 78.0], [335.0, 155.0], [315.0, 155.0]], [[290.0, 77.0], [310.0, 77.0], [310.0, 213.0], [290.0, 213.0]], [[268.0, 78.0], [284.0, 78.0], [284.0, 193.0], [268.0, 193.0]]], "lines": ["いやよ！！", "私だって彼の事", "好きだもの！！"]}, {"box": [69, 60, 143, 181], "vertical": true, "font_size": 24, "lines_coords": [[[111.0, 60.0], [143.0, 60.0], [143.0, 110.0], [111.0, 110.0]], [[93.0, 65.0], [113.0, 65.0], [113.0, 181.0], [93.0, 181.0]], [[69.0, 65.0], [89.0, 65.0], [89.0, 145.0], [69.0, 145.0]]], "lines": ["絶対", "振り向かせて", "みせる！！"]}, {"box": [716, 454, 731, 497], "vertical": true, "font_size": 15, "lines_coords": [[[716.0, 454.0], [731.0, 454.0], [731.0, 497.0], [716.0, 497.0]]], "lines": ["．．．．．"]}, {"box": [370, 720, 398, 816], "vertical": 