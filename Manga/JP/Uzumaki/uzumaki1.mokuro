0], "vertical": true, "font_size": 30, "lines_coords": [[[705.0, 369.0], [735.0, 369.0], [735.0, 480.0], [705.0, 480.0]]], "lines": ["ウエッ！"]}, {"box": [597, 652, 739, 791], "vertical": true, "font_size": 23, "lines_coords": [[[718.0, 653.0], [739.0, 653.0], [739.0, 733.0], [718.0, 733.0]], [[692.0, 653.0], [716.0, 653.0], [716.0, 791.0], [692.0, 791.0]], [[665.0, 653.0], [691.0, 652.0], [694.0, 721.0], [668.0, 723.0]], [[646.0, 652.0], [669.0, 652.0], [669.0, 791.0], [646.0, 791.0]], [[621.0, 652.0], [642.0, 652.0], [643.0, 771.0], [622.0, 771.0]], [[597.0, 653.0], [619.0, 653.0], [619.0, 733.0], [597.0, 733.0]]], "lines": ["でもね．．．", "秀一君も気の毒", "だけど、", "ちょっと神経質", "すぎるんじゃ", "ないの？"]}, {"box": [499, 658, 545, 755], "vertical": true, "font_size": 21, "lines_coords": [[[524.0, 660.0], [545.0, 660.0], [545.0, 755.0], [524.0, 755.0]], [[499.0, 658.0], [524.0, 658.0], [524.0, 742.0], [499.0, 742.0]]], "lines": ["たかがお皿", "じゃない。"]}, {"box": [449, 686, 495, 794], "vertical": true, "font_size": 21, "lines_coords": [[[476.0, 687.0], [495.0, 687.0], [495.0, 786.0], [476.0, 786.0]], [[452.0, 686.0], [472.0, 686.0], [469.0, 794.0], [449.0, 794.0]]], "lines": ["お母さんは", "そう思うわ。"]}, {"box": [275, 652, 413, 792], "vertical": true, "font_size": 23, "lines_coords": [[[392.0, 655.0], [412.0, 655.0], [412.0, 734.0], [392.0, 734.0]], [[363.0, 652.0], [396.0, 652.0], [396.0, 701.0], [363.0, 701.0]], [[344.0, 656.0], [368.0, 656.0], [365.0, 792.0], [342.0, 792.0]], [[322.0, 657.0], [342.0, 657.0], [342.0, 773.0], [322.0, 773.0]], [[298.0, 657.0], [318.0, 657.0], [318.0, 773.0], [298.0, 773.0]], [[275.0, 656.0], [295.0, 656.0], [295.0, 735.0], [275.0, 735.0]]], "lines": ["．．．でも！！", "私も", "トンボ池の土で", "作ったお皿で", "食事するのは", "イヤよ！"]}, {"box": [65, 663, 184, 780], "vertical": true, "font_size": 22, "lines_coords": [[[158.0, 663.0], [184.0, 663.0], [184.0, 725.0], [158.0, 725.0]], [[137.0, 663.0], [158.0, 663.0], [155.0, 761.0], [134.0, 761.0]], [[113.0, 664.0], [133.0, 664.0], [133.0, 780.0], [113.0, 