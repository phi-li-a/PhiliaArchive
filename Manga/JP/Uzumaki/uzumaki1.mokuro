 20, "lines_coords": [[[90.0, 93.0], [113.0, 93.0], [113.0, 268.0], [90.0, 268.0]], [[69.0, 94.0], [86.0, 94.0], [85.0, 295.0], [68.0, 295.0]]], "lines": ["親父の、あの最期の", "姿に見えるというんだ。"]}, {"box": [607, 345, 657, 410], "vertical": true, "font_size": 28, "lines_coords": [[[626.0, 345.0], [657.0, 345.0], [657.0, 393.0], [626.0, 393.0]], [[607.0, 346.0], [631.0, 346.0], [631.0, 410.0], [607.0, 410.0]]], "lines": ["お袋", "には．．"]}, {"box": [694, 452, 736, 596], "vertical": true, "font_size": 18, "lines_coords": [[[718.0, 454.0], [735.0, 454.0], [735.0, 567.0], [718.0, 567.0]], [[694.0, 452.0], [714.0, 452.0], [714.0, 596.0], [694.0, 596.0]]], "lines": ["そして親父が", "こっちを向いて、"]}, {"box": [518, 454, 561, 571], "vertical": true, "font_size": 20, "lines_coords": [[[541.0, 455.0], [561.0, 455.0], [561.0, 534.0], [541.0, 534.0]], [[518.0, 454.0], [538.0, 454.0], [538.0, 571.0], [518.0, 571.0]]], "lines": ["こう言う", "らしいんだ．．．"]}, {"box": [445, 467, 481, 691], "vertical": true, "font_size": 36, "lines_coords": [[[445.0, 467.0], [481.0, 467.0], [481.0, 691.0], [445.0, 691.0]]], "lines": ["おい、おまえ～～"]}, {"box": [62, 458, 121, 703], "vertical": true, "font_size": 24, "lines_coords": [[[96.0, 459.0], [120.0, 459.0], [120.0, 617.0], [96.0, 617.0]], [[62.0, 458.0], [86.0, 458.0], [89.0, 701.0], [64.0, 701.0]]], "lines": ["おまえも早く", "うずまきになれ～～～"]}, {"box": [637, 862, 730, 1021], "vertical": true, "font_size": 20, "lines_coords": [[[710.0, 864.0], [730.0, 864.0], [730.0, 998.0], [710.0, 998.0]], [[687.0, 864.0], [704.0, 864.0], [705.0, 1021.0], [688.0, 1021.0]], [[663.0, 863.0], [683.0, 863.0], [683.0, 1000.0], [663.0, 1000.0]], [[640.0, 862.0], [658.0, 862.0], [656.0, 980.0], [637.0, 980.0]]], "lines": ["．．．そんな幻覚が", "見えるという事は", "もう普通の状態", "じゃない．．．"]}, {"box": [501, 910, 594, 1105], "vertical": true, "font_size": 20, "lines_coords": [[[572.0, 910.0], [593.0, 910.0], [594.0, 1085.0], [573.0, 1085.0]], [[547.0, 910.0], [568.0, 910.0], [569.0, 1014.0], [548.0, 1014.0]], [[524.0, 910.0], [544.0, 910.0]