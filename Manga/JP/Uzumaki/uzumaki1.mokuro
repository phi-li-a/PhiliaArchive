 171, 542], "vertical": true, "font_size": 26, "lines_coords": [[[141.0, 460.0], [171.0, 460.0], [171.0, 526.0], [141.0, 526.0]], [[118.0, 461.0], [147.0, 461.0], [147.0, 526.0], [118.0, 526.0]], [[99.0, 464.0], [119.0, 464.0], [119.0, 542.0], [99.0, 542.0]]], "lines": ["何でも", "ないよ", "母さん．．．"]}, {"box": [696, 796, 763, 893], "vertical": true, "font_size": 19, "lines_coords": [[[742.0, 798.0], [762.0, 798.0], [762.0, 874.0], [742.0, 874.0]], [[718.0, 796.0], [739.0, 796.0], [739.0, 875.0], [718.0, 875.0]], [[696.0, 798.0], [712.0, 798.0], [712.0, 892.0], [696.0, 892.0]]], "lines": ["何か壁に", "気になる", "ものでも？"]}, {"box": [483, 787, 546, 864], "vertical": true, "font_size": 34, "lines_coords": [[[512.0, 787.0], [546.0, 787.0], [546.0, 864.0], [512.0, 864.0]], [[483.0, 791.0], [517.0, 791.0], [517.0, 864.0], [483.0, 864.0]]], "lines": ["えっ！", "いや！！"]}, {"box": [267, 792, 352, 897], "vertical": true, "font_size": 28, "lines_coords": [[[322.0, 793.0], [352.0, 793.0], [352.0, 866.0], [322.0, 866.0]], [[295.0, 792.0], [323.0, 792.0], [323.0, 897.0], [295.0, 897.0]], [[267.0, 793.0], [293.0, 793.0], [293.0, 864.0], [267.0, 864.0]]], "lines": ["何でも", "ないです、", "先生！！"]}, {"box": [214, 793, 234, 872], "vertical": true, "font_size": 20, "lines_coords": [[[214.0, 793.0], [234.0, 793.0], [234.0, 871.0], [214.0, 871.0]]], "lines": ["．．．何よ．．．"]}, {"box": [99, 794, 150, 858], "vertical": true, "font_size": 26, "lines_coords": [[[124.0, 794.0], [150.0, 794.0], [150.0, 857.0], [124.0, 857.0]], [[99.0, 795.0], [126.0, 794.0], [128.0, 857.0], [102.0, 858.0]]], "lines": ["変な子", "ねえ．．．"]}], "img_path": "063.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [64, 79, 185, 179], "vertical": true, "font_size": 22, "lines_coords": [[[164.0, 82.0], [184.0, 82.0], [184.0, 162.0], [164.0, 162.0]], [[140.0, 83.0], [160.0, 83.0], [160.0, 179.0], [140.0, 179.0]], [[117.0, 82.0], [138.0, 82.0], [136.0, 161.0], [114.0, 161.0]], [[93.0, 83.0], [114.0, 83.0], [114.0, 161.0], [93.0, 161.0]], [[64.0, 80.0], [93.0, 79.0], [96.0, 150.0], [66.0, 151.0]]], "lines": ["あそこは", "お父さんが", "入る事に", "なってた", "病院よ。"]}, {"box": [571, 287, 663, 421], "vertical": true, "font_size": 20, "lines_coords": [[[642.0, 287.0], [663.0, 287.0], [661.0, 384.0], [640.0, 384.0]], [[616.0, 287.0], [640.0, 287.0], [640.0, 330.0], [616.0, 330.0]], [[593.0, 288.0], [613.0, 288.0], [613.0, 421.0], [593.0, 421.0]], [[572.0, 288.0], [588.0, 288.0], [588.0, 384.0], [572.0, 384.0]]], "lines": ["いやよ私は", "．．．？", "緑山市の病院に", "行くのは．．．"]}, {"box": [667, 468, 737, 660], "vertical": true, "font_size": 21, "lines_coords": [[[711.0, 468.0], [735.0, 468.0], [737.0, 660.0], [714.0, 660.0]], [[691.0, 472.0], [711.0, 472.0], [711.0, 625.0], [691.0, 625.0]], [[667.0, 471.0], [687.0, 471.0], [688.0, 633.0], [668.0, 633.0]]], "lines": ["だけど、専門の病院へ", "行ったほうが早く", "良くなると思うよ。"]}, {"box": [376, 461, 446, 578], "vertical": true, "font_size": 21, "lines_coords": [[[426.0, 464.0], [446.0, 464.0], [446.0, 578.0], [426.0, 578.0]], [[402.0, 462.0], [422.0, 462.0], [422.0, 577.0], [402.0, 577.0]], [[376.0, 461.0], [400.0, 461.0], [400.0, 530.0], [376.0, 530.0]]], "lines": ["母さんだって", "早く治りたい", "だろう。"]}, {"box": [290, 466, 336, 562], "vertical": true, "font_size": 18, "lines_coords": [[[317.0, 466.0], [334.0, 466.0], [334.0, 561.0], [317.0, 561.0]], [[290.0, 466.0], [310.0, 466.0], [310.0, 544.0], [290.0, 544.0]]], "lines": ["そりゃそう", "だけど．．．"]}, {"box": [76, 246, 119, 380], "vertical": true, "font_size": 18, "lines_coords": [[[96.0, 246.0], [117.0, 246.0], [118.0, 360.0], [97.0, 360.0]], [[77.0, 247.0], [93.0, 247.0], [93.0, 380.0], [77.0, 380.0]]], "lines": ["かわりに私に", "行けというの？"]}, {"box": [65, 462, 159, 580], "vertical": true, "font_size": 20, "lines_coords": [[[134.0, 462.0], [159.0, 462.0], [159.0, 563.0], [134.0, 563.0]], [[112.0, 465.0], [132.0, 465.0], [132.0, 580.0], [112.0, 580.0]], [[90.0, 466.0], [106.0, 466.0], [106.0, 560.0], [90.0, 560.0]], [[65.0, 464.0], [85.0, 464.0], [85.0, 550.0], [65.0, 550.0]]], "lines": ["でも、もう", "体を傷つける", "ような事は", "ないわよ。"]}, {"box": [619, 776, 739, 895], "vertical": true, "font_size": 23, "lines_coords": [[[718.0, 780.0], [738.0, 780.0], [738.0, 874.0], [718.0, 874.0]], [[691.0, 778.0], [711.0, 778.0], [711.0, 874.0], [691.0, 874.0]], [[665.0, 776.0], [695.0, 778.0], [692.0, 823.0], [663.0, 822.0]], [[647.0, 780.0], [667.0, 780.0], [667.0, 895.0], [647.0, 895.0]], [[619.0, 778.0], [643.0, 778.0], [643.0, 858.0], [619.0, 858.0]]], "lines": ["だって体の", "うずまきは", "全部", "取っちゃった", "もの．．．"]}, {"box": [485, 779, 560, 853], "vertical": true, "font_size": 30, "lines_coords": [[[527.0, 780.0], [558.0, 779.0], [560.0, 844.0], [529.0, 846.0]], [[504.0, 780.0], [537.0, 780.0], [537.0, 829.0], [504.0, 829.0]], [[485.0, 782.0], [510.0, 782.0], [510.0, 853.0], [485.0, 853.0]]], "lines": ["えっ．．．", "ああ", "そうか。"]}, {"box": [351, 617, 445, 755], "vertical": true, "font_size": 21, "lines_coords": [[[425.0, 618.0], [445.0, 618.0], [445.0, 698.0], [425.0, 698.0]], [[399.0, 617.0], [423.0, 617.0], [423.0, 755.0], [399.0, 755.0]], [[377.0, 618.0], [397.0, 618.0], [397.0, 733.0], [377.0, 733.0]], [[351.0, 618.0], [371.0, 618.0], [374.0, 696.0], [354.0, 696.0]]], "lines": ["もう体を", "傷つけるような", "事したくない", "だろう！？"]}, {"box": [414, 792, 431, 837], "vertical": true, "font_size": 17, "lines_coords": [[[414.0, 792.0], [431.0, 792.0], [431.0, 837.0], [414.0, 837.0]]], "lines": ["．．．"]}], "img_path": "064.jpg"}, {"version": "0.1.7", "img_width": 839, "img_height": 1200, "blocks": [{"box": [183, 78, 304, 158], "vertical": true, "font_size": 28, "lines_coords": [[[276.0, 78.0], [304.0, 78.0], [304.0, 124.0], [276.0, 124.0]], [[255.0, 79.0], [282.0, 79.0], [282.0, 124.0], [255.0, 124.0]], [[228.0, 78.0], [257.0, 78.0], [257.0, 142.0], [228.0, 142.0]], [[207.0, 79.0], [232.0, 79.0], [232.0, 158.0], [207.0, 158.0]], [[183.0, 79.0], [212.0, 79.0], [212.0, 124.0], [183.0, 124.0]]], "lines": ["ああ", "．．．", "５時の", "サイレン", "よ．．．"]}, {"box": [715, 406, 758, 521], "vertical": true, "font_size": 18, "lines_coords": [[[738.0, 406.0], [758.0, 406.0], [758.0, 521.0], [738.0, 521.0]], [[715.0, 406.0], [732.0, 406.0], [732.0, 521.0], [715.0, 521.0]]], "lines": ["いつ聞いても", "イヤな音ね！！"]}, {"box": [297, 404, 389, 546], "vertical": true, "font_size": 19, "lines_coords": [[[370.0, 404.0], [386.0, 404.0], [386.0, 542.0], [370.0, 542.0]], [[345.0, 404.0], [365.0, 404.0], [365.0, 541.0], [345.0, 541.0]], [[321.0, 405.0], [340.0, 405.0], [340.0, 540.0], [321.0, 540.0]], [[297.0, 405.0], [318.0, 405.0], [318.0, 482.0], [297.0, 482.0]]], "lines": ["まるで耳の中で、", "ぐるぐると渦を", "巻いているよう", "だわ．．！！"]}], "img_path": "065.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [705, 80, 731, 144], "vertical": true, "font_size": 26, "lines_coords": [[[705.0, 80.0], [731.0, 80.0], [731.0, 144.0], [705.0, 144.0]]], "lines": ["桐絵．．．"]}, {"box": [419, 78, 492, 160], "vertical": true, "font_size": 25, "lines_coords": [[[463.0, 78.0], [492.0, 78.0], [492.0, 142.0], [463.0, 142.0]], [[442.0, 79.0], [467.0, 79.0], [467.0, 160.0], [442.0, 160.0]], [[419.0, 80.0], [440.0, 80.0], [440.0, 159.0], [419.0, 159.0]]], "lines": ["お袋は", "気づいて", "ないが．．．"]}, {"box": [362, 70, 386, 133], "vertical": true, "font_size": 24, "lines_coords": [[[362.0, 70.0], [386.0, 70.0], [386.0, 133.0], [362.0, 133.0]]], "lines": ["えっ．．．"]}, {"box": [68, 79, 89, 158], "vertical": true, "font_size": 21, "lines_coords": [[[68.0, 80.0], [89.0, 80.0], [89.0, 158.0], [68.0, 158.0]]], "lines": ["何の話？"]}, {"box": [640, 502, 738, 619], "vertical": true, "font_size": 22, "lines_coords": [[[717.0, 502.0], [737.0, 502.0], [737.0, 618.0], [717.0, 618.0]], [[685.0, 502.0], [710.0, 502.0], [708.0, 619.0], [683.0, 619.0]], [[664.0, 503.0], [684.0, 503.0], [684.0, 600.0], [664.0, 600.0]], [[640.0, 502.0], [661.0, 502.0], [661.0, 568.0], [640.0, 568.0]]], "lines": ["耳の奥にある", "「蝸牛」という", "音を感じる", "器官だ。"]}, {"box": [419, 270, 485, 453], "vertical": true, "font_size": 19, "lines_coords": [[[463.0, 270.0], [484.0, 270.0], [485.0, 370.0], [464.0, 370.0]], [[442.0, 273.0], [461.0, 273.0], [461.0, 426.0], [442.0, 426.0]], [[419.0, 273.0], [436.0, 273.0], [436.0, 451.0], [419.0, 451.0]]], "lines": ["これからも", "気づかないでいて", "もらわないと困るな。"]}, {"box": [291, 262, 383, 455], "vertical": true, "font_size": 19, "lines_coords": [[[362.0, 263.0], [382.0, 263.0], [382.0, 380.0], [362.0, 380.0]], [[337.0, 262.0], [357.0, 262.0], [358.0, 455.0], [338.0, 455.0]], [[314.0, 263.0], [334.0, 263.0], [334.0, 455.0], [314.0, 455.0]], [[291.0, 264.0], [308.0, 264.0], [308.0, 418.0], [291.0, 418.0]]], "lines": ["人間の体に．．．", "つむじや指紋の他には", "もううずまきはないと", "思っていたけど．．．"]}, {"box": [68, 268, 113, 405], "vertical": true, "font_size": 22, "lines_coords": [[[87.0, 268.0], [113.0, 268.0], [113.0, 330.0], [87.0, 330.0]], [[68.0, 269.0], [87.0, 269.0], [87.0, 405.0], [68.0, 405.0]]], "lines": ["．．．まだ", "あったんだよ！！"]}, {"box": [651, 781, 742, 955], "vertical": true, "font_size": 20, "lines_coords": [[[721.0, 782.0], [742.0, 782.0], [741.0, 955.0], [719.0, 955.0]], [[697.0, 782.0], [717.0, 782.0], [717.0, 937.0], [697.0, 937.0]], [[674.0, 782.0], [694.0, 782.0], [694.0, 881.0], [674.0, 881.0]], [[651.0, 782.0], [668.0, 782.0], [668.0, 936.0], [651.0, 936.0]]], "lines": ["．．．もし、お袋がこの", "うずまきの存在に", "気づいたら", "どうするだろう？"]}, {"box": [405, 608, 475, 744], "vertical": true, "font_size": 20, "lines_coords": [[[454.0, 608.0], [474.0, 608.0], [474.0, 744.0], [454.0, 744.0]], [[430.0, 609.0], [450.0, 609.0], [450.0, 725.0], [430.0, 725.0]], [[405.0, 608.0], [425.0, 608.0], [425.0, 710.0], [405.0, 710.0]]], "lines": ["今日、院長室の", "解剖図を見て", "気がついた。"]}, {"box": [327, 779, 419, 952], "vertical": true, "font_size": 19, "lines_coords": [[[400.0, 780.0], [417.0, 780.0], [417.0, 914.0], [400.0, 914.0]], [[375.0, 780.0], [395.0, 780.0], [395.0, 952.0], [375.0, 952.0]], [[351.0, 779.0], [369.0, 779.0], [370.0, 952.0], [352.0, 952.0]], [[327.0, 779.0], [347.0, 779.0], [347.0, 877.0], [327.0, 877.0]]], "lines": ["もちろんそれは", "わからない．．．しかし", "指紋を