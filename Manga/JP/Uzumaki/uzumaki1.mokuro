, 734.0]]], "lines": ["しかし、", "私は彼を", "無理やり家に", "連れていった", "のです。"]}, {"box": [713, 954, 728, 998], "vertical": true, "font_size": 15, "lines_coords": [[[713.0, 954.0], [728.0, 954.0], [728.0, 998.0], [713.0, 998.0]]], "lines": ["．．．．．"]}], "img_path": "126.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [649, 59, 767, 150], "vertical": true, "font_size": 26, "lines_coords": [[[742.0, 62.0], [767.0, 62.0], [767.0, 128.0], [742.0, 128.0]], [[715.0, 59.0], [746.0, 59.0], [746.0, 110.0], [715.0, 110.0]], [[695.0, 64.0], [716.0, 64.0], [716.0, 141.0], [695.0, 141.0]], [[668.0, 60.0], [699.0, 60.0], [699.0, 108.0], [668.0, 108.0]], [[649.0, 65.0], [670.0, 65.0], [670.0, 150.0], [649.0, 150.0]]], "lines": ["秀一君、", "遠慮", "しないで", "沢山", "食べてね。"]}, {"box": [338, 77, 378, 118], "vertical": true, "font_size": 24, "lines_coords": [[[355.0, 77.0], [378.0, 78.0], [376.0, 118.0], [352.0, 117.0]]], "lines": ["はい"]}, {"box": [104, 83, 121, 180], "vertical": true, "font_size": 16, "lines_coords": [[[104.0, 84.0], [120.0, 84.0], [120.0, 179.0], [104.0, 179.0]]], "lines": ["頂きます．．．"]}, {"box": [335, 423, 454, 503], "vertical": true, "font_size": 24, "lines_coords": [[[430.0, 423.0], [454.0, 423.0], [454.0, 486.0], [430.0, 486.0]], [[408.0, 424.0], [433.0, 424.0], [433.0, 503.0], [408.0, 503.0]], [[384.0, 425.0], [405.0, 425.0], [405.0, 501.0], [384.0, 501.0]], [[358.0, 423.0], [383.0, 423.0], [383.0, 503.0], [358.0, 503.0]], [[335.0, 424.0], [361.0, 424.0], [361.0, 486.0], [335.0, 486.0]]], "lines": ["まあ．．．", "よっぽど", "おなかが", "すいてた", "のね．．"]}, {"box": [100, 418, 220, 519], "vertical": true, "font_size": 25, "lines_coords": [[[189.0, 418.0], [220.0, 418.0], [220.0, 483.0], [189.0, 483.0]], [[171.0, 420.0], [192.0, 420.0], [192.0, 519.0], [171.0, 519.0]], [[145.0, 419.0], [171.0, 418.0], [173.0, 481.0], [147.0, 482.0]], [[123.0, 419.0], [148.0, 419.0], [148.0, 482.0], [123.0, 482.0]], [[100.0, 420.0], [120.0, 420.0], [120.0, 507.0], [100.0, 507.0]]], "lin