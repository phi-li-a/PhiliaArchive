ont_size": 20, "lines_coords": [[[98.0, 87.0], [118.0, 87.0], [118.0, 165.0], [98.0, 165.0]]], "lines": ["黒谷君！"]}, {"box": [344, 411, 413, 489], "vertical": true, "font_size": 23, "lines_coords": [[[392.0, 412.0], [413.0, 412.0], [413.0, 489.0], [392.0, 489.0]], [[366.0, 411.0], [393.0, 411.0], [393.0, 472.0], [366.0, 472.0]], [[344.0, 411.0], [365.0, 411.0], [365.0, 476.0], [344.0, 476.0]]], "lines": ["オレだ．．．", "Ｃ組の", "岡田だ"]}, {"box": [187, 410, 260, 567], "vertical": true, "font_size": 25, "lines_coords": [[[234.0, 411.0], [260.0, 411.0], [260.0, 473.0], [234.0, 473.0]], [[212.0, 411.0], [235.0, 411.0], [235.0, 567.0], [212.0, 567.0]], [[187.0, 410.0], [212.0, 410.0], [212.0, 474.0], [187.0, 474.0]]], "lines": ["頼む．．．", "オレとつきあって", "くれ．．．"]}, {"box": [637, 788, 730, 925], "vertical": true, "font_size": 20, "lines_coords": [[[707.0, 788.0], [727.0, 788.0], [730.0, 907.0], [710.0, 907.0]], [[683.0, 789.0], [703.0, 789.0], [705.0, 905.0], [685.0, 905.0]], [[660.0, 791.0], [680.0, 791.0], [680.0, 923.0], [660.0, 923.0]], [[637.0, 791.0], [655.0, 791.0], [656.0, 924.0], [638.0, 924.0]]], "lines": ["わかってる．．．", "だけど君には", "言葉にできない", "吸引力がある．．．"]}, {"box": [282, 792, 373, 1006], "vertical": true, "font_size": 19, "lines_coords": [[[352.0, 793.0], [372.0, 793.0], [372.0, 889.0], [352.0, 889.0]], [[328.0, 792.0], [346.0, 792.0], [349.0, 985.0], [330.0, 985.0]], [[303.0, 792.0], [323.0, 792.0], [325.0, 1005.0], [305.0, 1005.0]], [[282.0, 792.0], [298.0, 792.0], [301.0, 1004.0], [284.0, 1004.0]]], "lines": ["オレは君に", "吸い寄せられるように", "君にもとへ来てしまう．．．", "どうしようもないんだ．．．"]}, {"box": [155, 643, 225, 767], "vertical": true, "font_size": 22, "lines_coords": [[[202.0, 643.0], [222.0, 643.0], [224.0, 767.0], [205.0, 767.0]], [[178.0, 643.0], [203.0, 643.0], [203.0, 706.0], [178.0, 706.0]], [[155.0, 643.0], [176.0, 643.0], [178.0, 723.0], [157.0, 723.0]]], "lines": ["しつこいわね！！", "断った", "はずよ！！"]}], "img_path": "102.jpg"}, {"version": "0.1.7", "img_width": 844, "img_height": 1200, "blocks": [{"box": [659, 100, 749, 217], "vertical": true, "font_size": 19, "lines_coords": [[[729.0, 100.0], [749.0, 100.0], [749.0, 179.0], [729.0, 179.0]], [[704.0, 100.0], [724.0, 100.0], [724.0, 215.0], [704.0, 215.0]], [[681.0, 101.0], [700.0, 101.0], [700.0, 217.0], [681.0, 217.0]], [[659.0, 103.0], [676.0, 103.0], [676.0, 202.0], [659.0, 202.0]]], "lines": ["翌日から", "黒谷あざみは", "学校に来なく", "なりました。"]}, {"box": [123, 83, 190, 259], "vertical": true, "font_size": 19, "lines_coords": [[[168.0, 83.0], [188.0, 83.0], [188.0, 255.0], [168.0, 255.0]], [[145.0, 83.0], [165.0, 83.0], [165.0, 180.0], [145.0, 180.0]], [[123.0, 84.0], [139.0, 84.0], [139.0, 256.0], [123.0, 256.0]]], "lines": ["アパートを訪ねても", "何の応答も", "ありませんでしたか"]}, {"box": [657, 419, 774, 520], "vertical": true, "font_size": 23, "lines_coords": [[[753.0, 423.0], [773.0, 423.0], [773.0, 520.0], [753.0, 520.0]], [[730.0, 424.0], [751.0, 424.0], [751.0, 503.0], [730.0, 503.0]], [[702.0, 419.0], [731.0, 419.0], [731.0, 483.0], [702.0, 483.0]], [[683.0, 423.0], [703.0, 423.0], [703.0, 519.0], [683.0, 519.0]], [[657.0, 420.0], [682.0, 420.0], [682.0, 483.0], [657.0, 483.0]]], "lines": ["部屋の中に", "いる事は、", "気配で", "わかりまし", "た．．．"]}, {"box": [392, 421, 459, 535], "vertical": true, "font_size": 20, "lines_coords": [[[437.0, 424.0], [458.0, 424.0], [458.0, 535.0], [437.0, 535.0]], [[413.0, 421.0], [434.0, 421.0], [434.0, 498.0], [413.0, 498.0]], [[392.0, 423.0], [410.0, 423.0], [410.0, 478.0], [392.0, 478.0]]], "lines": ["一体、彼女の", "あの額は", "．．．．．．？"]}, {"box": [316, 415, 339, 456], "vertical": true, "font_size": 23, "lines_coords": [[[316.0, 415.0], [339.0, 415.0], [339.0, 456.0], [316.0, 456.0]]], "lines": ["おまつを．．．で？"]}, {"box": [264, 414, 284, 444], "vertical": true, "font_size": 20, "lines_coords": [[[264.0, 414.0], [284.0, 414.0], [284.0, 444.0], [264.0, 444.0]]], "lines": ["でもしませんです？"]}, {"box": [119, 442, 186, 669], "vertical": true, "font_size": 17, "lines_coords": [[[166.0, 445.0], [182.0, 445.0], [182.0, 669.0], [166.0, 669.0]], [[140.0, 442.0], [160.0, 442.0], [160.0, 655.0], [140.0, 655.0]], [[119.0, 444.0], [134.0, 444.0], [134.0, 635.0], [119.0, 635.0]]], "lines": ["．．．私の目には、うずまきが", "額の奥に食い込んでいる", "ように見えたけど．．．"]}, {"box": [355, 704, 422, 820], "vertical": true, "font_size": 19, "lines_coords": [[[402.0, 705.0], [422.0, 705.0], [422.0, 801.0], [402.0, 801.0]], [[378.0, 704.0], [398.0, 704.0], [398.0, 801.0], [378.0, 801.0]], [[356.0, 704.0], [373.0, 704.0], [372.0, 820.0], [355.0, 820.0]]], "lines": ["そんなはず", "ないわ．．．", "目の錯覚よ．．"]}, {"box": [298, 704, 320, 768], "vertical": true, "font_size": 22, "lines_coords": [[[298.0, 704.0], [320.0, 704.0], [320.0, 768.0], [298.0, 768.0]]], "lines": ["そして、"]}, {"box": [727, 994, 780, 1075], "vertical": true, "font_size": 26, "lines_coords": [[[752.0, 994.0], [780.0, 994.0], [780.0, 1040.0], [752.0, 1040.0]], [[730.0, 994.0], [754.0, 996.0], [752.0, 1075.0], [727.0, 1074.0]]], "lines": ["でも", "まさか．．．"]}, {"box": [134, 966, 176, 1088], "vertical": true, "font_size": 18, "lines_coords": [[[155.0, 966.0], [175.0, 966.0], [175.0, 1042.0], [155.0, 1042.0]], [[134.0, 966.0], [151.0, 966.0], [151.0, 1085.0], [134.0, 1085.0]]], "lines": ["数日後の", "夜の事でした。"]}], "img_path": "103.jpg"}, {"version": "0.1.7", "img_width": 839, "img_height": 1200, "blocks": [{"box": [663, 188, 724, 301], "vertical": true, "font_size": 61, "lines_coords": [[[663.0, 188.0], [724.0, 188.0], [724.0, 301.0], [663.0, 301.0]]], "lines": ["ピロｏｃｏ"]}, {"box": [605, 111, 651, 300], "vertical": true, "font_size": 24, "lines_coords": [[[611.0, 152.0], [635.0, 150.0], [651.0, 297.0], [628.0, 300.0]]], "lines": ["ロロロックスの"]}, {"box": [332, 87, 378, 193], "vertical": true, "font_size": 20, "lines_coords": [[[357.0, 89.0], [378.0, 89.0], [378.0, 150.0], [357.0, 150.0]], [[335.0, 87.0], [355.0, 87.0], [352.0, 186.0], [332.0, 186.0]]], "lines": ["はい．．", "五島ですが"]}, {"box": [222, 84, 271, 164], "vertical": true, "font_size": 23, "lines_coords": [[[249.0, 86.0], [270.0, 86.0], [270.0, 164.0], [249.0, 164.0]], [[222.0, 85.0], [247.0, 84.0], [249.0, 153.0], [224.0, 154.0]]], "lines": ["桐絵か？", "オレだ。"]}, {"box": [48, 76, 167, 240], "vertical": true, "font_size": 22, "lines_coords": [[[138.0, 76.0], [167.0, 76.0], [167.0, 141.0], [138.0, 141.0]], [[119.0, 78.0], [139.0, 78.0], [139.0, 240.0], [119.0, 240.0]], [[94.0, 78.0], [116.0, 78.0], [116.0, 145.0], [94.0, 145.0]], [[70.0, 78.0], [91.0, 78.0], [93.0, 194.0], [72.0, 194.0]], [[48.0, 79.0], [67.0, 79.0], [67.0, 196.0], [48.0, 196.0]]], "lines": ["桐絵．．", "ちょっと聞きたいん", "だけど、", "岡田ってやつ", "知ってるか？"]}, {"box": [658, 431, 728, 527], "vertical": true, "font_size": 21, "lines_coords": [[[704.0, 431.0], [728.0, 431.0], [728.0, 493.0], [704.0, 493.0]], [[681.0, 431.0], [701.0, 431.0], [701.0, 527.0], [681.0, 527.0]], [[658.0, 431.0], [678.0, 431.0], [678.0, 510.0], [658.0, 510.0]]], "lines": ["岡田？", "知らない．．．", "誰なの？"]}, {"box": [399, 435, 489, 554], "vertical": true, "font_size": 21, "lines_coords": [[[469.0, 438.0], [489.0, 438.0], [489.0, 535.0], [469.0, 535.0]], [[444.0, 435.0], [469.0, 435.0], [469.0, 498.0], [444.0, 498.0]], [[424.0, 437.0], [444.0, 437.0], [444.0, 553.0], [424.0, 553.0]], [[399.0, 438.0], [419.0, 438.0], [419.0, 554.0], [399.0, 554.0]]], "lines": ["．．．そうか．．．", "．．．実は", "さっき電話で", "そいつがね．．．"]}, {"box": [235, 324, 256, 401], "vertical": true, "font_size": 21, "lines_coords": [[[235.0, 324.0], [256.0, 324.0], [256.0, 401.0], [235.0, 401.0]]], "lines": ["秀一君？"]}, {"box": [63, 430, 157, 574], "vertical": true, "font_size": 20, "lines_coords": [[[134.0, 430.0], [155.0, 430.0], [155.0, 508.0], [134.0, 508.0]], [[110.0, 430.0], [131.0, 430.0], [132.0, 528.0], [111.0, 528.0]], [[86.0, 431.0], [106.0, 431.0], [108.0, 546.0], [89.0, 546.0]], [[63.0, 430.0], [83.0, 430.0], [85.0, 574.0], [65.0, 574.0]]], "lines": ["君の事で", "オレと話を", "つけたいって", "言ってきたんだ。"]}, {"box": [665, 747, 732, 871], "vertical": true, "font_size": 20, "lines_coords": [[[712.0, 747.0], [732.0, 747.0], [732.0, 825.0], [712.0, 825.0]], [[686.0, 747.0], [707.0, 747.0], [707.0, 823.0], [686.0, 823.0]], [[665.0, 748.0], [685.0, 748.0], [685.0, 871.0], [665.0, 871.0]]], "lines": ["どうやら", "君の事が", "好きらしいな。"]}, {"box": [447, 751, 517, 878], "vertical": true, "font_size": 22, "lines_coords": [[[498.0, 752.0], [517.0, 752.0], [517.0, 869.0], [498.0, 869.0]], [[472.0, 752.0], [495.0, 752.0], [495.0, 878.0], [472.0, 878.0]], [[447.0, 751.0], [472.0, 751.0], [472.0, 821.0], [447.0, 821.0]]], "lines": ["どういう事？", "全然心当たり", "ないわ。"]}, {"box": [373, 751, 412, 829], "vertical": true, "font_size": 17, "lines_coords": [[[373.0, 751.0], [390.0, 751.0], [390.0, 829.0], [373.0, 829.0]]], "lines": ["そうか．．．"]}, {"box": [276, 752, 298, 836], "vertical": true, "font_size": 21, "lines_coords": [[[276.0, 752.0], [297.0, 752.0], [297.0, 835.0], [276.0, 835.0]]], "lines": ["わかった。"]}, {"box": [63, 610, 133, 726], "vertical": true, "font_size": 22, "lines_coords": [[[112.0, 610.0], [132.0, 610.0], [132.0, 726.0], [112.0, 726.0]], [[87.0, 611.0], [108.0, 611.0], [108.0, 689.0], [87.0, 689.0]], [[63.0, 610.0], [87.0, 610.0], [87.0, 672.0], [63.0, 672.0]]], "lines": ["近所の公園で", "待ってる", "って．．．"]}, {"box": [71, 1038, 99, 1093], "vertical": true, "font_size": 26, "lines_coords": [[[71.0, 1039.0], [97.0, 1038.0], [99.0, 1092.0], [73.0, 1093.0]]], "lines": ["あっ。"]}], "img_path": "104.jpg"}, {"version": "0.1.7", "img_width": 839, "img_height": 1200, "blocks": [{"box": [725, 89, 772, 268], "vertical": true, "font_size": 22, "lines_coords": [[[746.0, 89.0], [769.0, 89.0], [772.0, 268.0], [748.0, 268.0]], [[725.0, 91.0], [745.0, 91.0], [745.0, 229.0], [725.0, 229.0]]], "lines": ["えっ、どういう事？", "何なの一体．．．？"]}, {"box": [398, 76, 442, 211], "vertical": true, "font_size": 17, "lines_coords": [[[424.0, 77.0], [440.0, 77.0], [440.0, 210.0], [424.0, 210.0]], [[399.0, 76.0], [417.0, 76.0], [415.0, 192.0], [398.0, 192.0]]], "lines": ["話をつけるって", "どういう事！？"]}, {"box": [721, 454, 768, 617], "vertical": true, "font_size": 22, "lines_coords": [[[745.0, 454.0], [768.0, 454.0], [768.0, 574.0], [745.0, 574.0]], [[722.0, 455.0], [742.0, 455.0], [741.0, 617.0], [721.0, 617.0]]], "lines": ["近所の公園．．．", "たぶんあそこだわ。"]}, {"box": [563, 608, 631, 840], "vertical": true, "font_size": 20, "lines_coords": [[[610.0, 609.0], [630.0, 609.0], [630.0, 830.0], [610.0, 830.0]], [[583.0, 608.0], [606.0, 608.0], [606.0, 840.0], [583.0, 840.0]], [[563.0, 608.0], [580.0, 608.0], [580.0, 761.0], [563.0, 761.0]]], "lines": ["でもやっぱり、お父さんに", "ついてきてもらったほうが", "よかったかしら？"]}], "img_path": "105.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [671, 86, 721, 169], "vertical": true, "font_size": 24, "lines_coords": [[[694.0, 86.0], [721.0, 86.0], [721.0, 133.0], [694.0, 133.0]], [[671.0, 89.0], [692.0, 89.0], [694.0, 169.0], [673.0, 169.0]]], "lines": ["あ．．．", "あれは．．．"]}, {"box": [407, 79, 449, 233], "vertical": true, "font_size": 16, "lines_coords": [[[431.0, 79.0], [447.0, 79.0], [447.0, 213.0], [431.0, 213.0]], [[408.0, 79.0], [424.0, 79.0], [424.0, 233.0], [408.0, 233.0]]], "lines": ["あのうしろ姿は", "あぎみさんだわ！"]}, {"box": [348, 228, 366, 331], "vertical": true, "font_size": 16, "lines_coords": [[[348.0, 228.0], [364.0, 228.0], [364.0, 329.0], [348.0, 329.0]]], "lines": ["あざみさん、"]}, {"box": [63, 86, 107, 182], "vertical": true, "font_size": 20, "lines_coords": [[[86.0, 86.0], [106.0, 86.0], [106.0, 182.0], [86.0, 182.0]], [[63.0, 86.0], [84.0, 86.0], [84.0, 165.0], [63.0, 165.0]]], "lines": ["あざみさん", "でしょ！？"]}, {"box": [655, 738, 725, 817], "vertical": true, "font_size": 23, "lines_coords": [[[701.0, 738.0], [725.0, 738.0], [725.0, 817.0], [701.0, 817.0]], [[676.0, 738.0], [701.0, 738.0], [701.0, 800.0], [676.0, 800.0]], [[655.0, 739.0], [675.0, 739.0], [675.0, 817.0], [655.0, 817.0]]], "lines": ["やっぱり", "あざみ", "さんね！？"]}, {"box": [293, 734, 386, 853], "vertical": true, "font_size": 20, "lines_coords": [[[366.0, 734.0], [386.0, 734.0], [386.0, 853.0], [366.0, 853.0]], [[342.0, 735.0], [362.0, 735.0], [362.0, 833.0], [342.0, 833.0]], [[318.0, 735.0], [338.0, 735.0], [338.0, 851.0], [318.0, 851.0]], [[293.0, 734.0], [317.0, 734.0], [317.0, 815.0], [293.0, 815.0]]], "lines": ["．．．桐絵さん．．．", "何だか変な", "感じ．．．右目が", "変なの．．"]}, {"box": [230, 737, 272, 853], "vertical": true, "font_size": 20, "lines_coords": [[[252.0, 737.0], [272.0, 737.0], [272.0, 853.0], [252.0, 853.0]], [[230.0, 737.0], [247.0, 737.0], [247.0, 813.0], [230.0, 813.0]]], "lines": ["視点が定まら", "なくて．．．"]}, {"box": [53, 735, 150, 817], "vertical": true, "font_size": 25, "lines_coords": [[[128.0, 738.0], [150.0, 738.0], [150.0, 816.0], [128.0, 816.0]], [[98.0, 737.0], [125.0, 735.0], [127.0, 799.0], [100.0, 800.0]], [[77.0, 737.0], [102.0, 737.0], [102.0, 817.0], [77.0, 817.0]], [[53.0, 737.0], [79.0, 737.0], [79.0, 800.0], [53.0, 800.0]]], "lines": ["ちょっと", "私の顔", "見てくれ", "ない？"]}, {"box": [419, 951, 463, 1107], "vertical": true, "font_size": 20, "lines_coords": [[[439.0, 951.0], [463.0, 951.0], [463.0, 1107.0], [439.0, 1107.0]], [[419.0, 953.0], [436.0, 953.0], [436.0, 1106.0], [419.0, 1106.0]]], "lines": ["一体どうしたの！？", "心配してたのよ！！"]}], "img_path": "106.jpg"}, {"version": "0.1.7", "img_width": 841, "img_height": 1200, "blocks": [], "img_path": "107.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [560, 0, 764, 296], "vertical": false, "font_size": 79, "lines_coords": [[[560.0, 260.0], [692.0, 0.0], [764.0, 30.0], [631.0, 296.0]]], "lines": ["．．．いつかは"]}, {"box": [314, 88, 347, 188], "vertical": true, "font_size": 33, "lines_coords": [[[314.0, 88.0], [347.0, 88.0], [347.0, 188.0], [314.0, 188.0]]], "lines": ["ハナベナ"]}, {"box": [420, 457, 432, 498], "vertical": true, "font_size": 12, "lines_coords": [[[420.0, 457.0], [432.0, 457.0], [432.0, 498.0], [420.0, 498.0]]], "lines": ["．．．"]}, {"box": [282, 460, 332, 526], "vertical": true, "font_size": 28, "lines_coords": [[[302.0, 460.0], [332.0, 460.0], [332.0, 526.0], [302.0, 526.0]], [[282.0, 462.0], [307.0, 462.0], [307.0, 525.0], [282.0, 525.0]]], "lines": ["話って", "何だ？"]}, {"bo