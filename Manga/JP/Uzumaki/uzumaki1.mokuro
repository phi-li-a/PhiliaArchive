8.0], [504.0, 942.0], [487.0, 942.0]]], "lines": ["．．．何それ？", "駆け落ち？"]}, {"box": [120, 570, 188, 687], "vertical": true, "font_size": 19, "lines_coords": [[[166.0, 570.0], [188.0, 570.0], [188.0, 687.0], [166.0, 687.0]], [[142.0, 570.0], [162.0, 570.0], [162.0, 684.0], [142.0, 684.0]], [[120.0, 571.0], [136.0, 571.0], [136.0, 664.0], [120.0, 664.0]]], "lines": ["オレと一緒に", "この町を脱出", "しないか？"]}, {"box": [399, 836, 446, 1037], "vertical": true, "font_size": 20, "lines_coords": [[[425.0, 836.0], [446.0, 836.0], [446.0, 915.0], [425.0, 915.0]], [[402.0, 836.0], [422.0, 836.0], [419.0, 1037.0], [399.0, 1037.0]]], "lines": ["．．．冗談を", "言ってるんじゃないぞ。"]}, {"box": [116, 843, 160, 1082], "vertical": true, "font_size": 19, "lines_coords": [[[136.0, 845.0], [157.0, 845.0], [160.0, 1076.0], [139.0, 1076.0]], [[116.0, 846.0], [133.0, 846.0], [133.0, 1082.0], [116.0, 1082.0]]], "lines": ["オレは本気で、この町から", "逃げようって言ってるんだ。"]}], "img_path": "021.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [650, 82, 725, 278], "vertical": true, "font_size": 26, "lines_coords": [[[692.0, 82.0], [725.0, 82.0], [725.0, 131.0], [692.0, 131.0]], [[671.0, 84.0], [696.0, 84.0], [698.0, 277.0], [674.0, 277.0]], [[651.0, 84.0], [672.0, 84.0], [671.0, 244.0], [650.0, 244.0]]], "lines": ["最近", "オレ、この町がいやで", "しょうがないんだ。"]}, {"box": [359, 75, 401, 239], "vertical": true, "font_size": 18, "lines_coords": [[[381.0, 75.0], [400.0, 75.0], [400.0, 208.0], [381.0, 208.0]], [[359.0, 75.0], [376.0, 75.0], [376.0, 239.0], [359.0, 239.0]]], "lines": ["この町にいたら", "どうかなっちまうぜ。"]}, {"box": [242, 80, 311, 271], "vertical": true, "font_size": 20, "lines_coords": [[[289.0, 82.0], [309.0, 82.0], [310.0, 271.0], [290.0, 271.0]], [[264.0, 80.0], [286.0, 80.0], [287.0, 216.0], [266.0, 216.0]], [[242.0, 80.0], [262.0, 80.0], [263.0, 236.0], [243.0, 236.0]]], "lines": ["オレは昼間、この町を", "離れているから", "よけいに感じる．．．"]}, {"box": [65, 128, 134, 321], "vertical": true, "font_size": 19, "lines_coords": [[[112.0, 128.0], [132.0, 128.0], [134.0, 321.0], [114.0, 321.0]], [[87.0, 128.0], [107.0, 128.0], [110.0, 266.0], [90.0, 266.0]], [[65.0, 131.0], [83.0, 131.0], [85.0, 283.0], [67.0, 283.0]]], "lines": ["この町の駅のホームに", "降りたつたびに", "めまいを覚える．．．"]}, {"box": [701, 435, 724, 534], "vertical": true, "font_size": 21, "lines_coords": [[[701.0, 435.0], [722.0, 435.0], [724.0, 534.0], [703.0, 534.0]]], "lines": ["どうして？"]}, {"box": [356, 437, 424, 572], "vertical": true, "font_size": 19, "lines_coords": [[[402.0, 437.0], [422.0, 437.0], [424.0, 571.0], [404.0, 571.0]], [[379.0, 439.0], [399.0, 439.0], [399.0, 517.0], [379.0, 517.0]], [[356.0, 438.0], [373.0, 438.0], [375.0, 571.0], [357.0, 571.0]]], "lines": ["どうしてって．．", "君は何も", "感じないのか？"]}, {"box": [39, 491, 115, 626], "vertical": true, "font_size": 20, "lines_coords": [[[91.0, 491.0], [111.0, 491.0], [114.0, 626.0], [94.0, 626.0]], [[63.0, 492.0], [83.0, 492.0], [85.0, 608.0], [65.0, 608.0]], [[39.0, 492.0], [59.0, 492.0], [62.0, 609.0], [42.0, 609.0]]], "lines": ["この町はオレを", "眩惑しようと", "している．．．！！"]}, {"box": [623, 679, 718, 760], "vertical": true, "font_size": 26, "lines_coords": [[[688.0, 682.0], [718.0, 682.0], [718.0, 745.0], [688.0, 745.0]], [[667.0, 679.0], [698.0, 679.0], [698.0, 728.0], [667.0, 728.0]], [[647.0, 684.0], [667.0, 684.0], [667.0, 760.0], [647.0, 760.0]], [[623.0, 683.0], [644.0, 683.0], [644.0, 742.0], [623.0, 742.0]]], "lines": ["．．．私は", "何も", "感じない", "けど．．"]}], "img_path": "022.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1204, "blocks": [{"box": [716, 90, 764, 170], "vertical": true, "font_size": 25, "lines_coords": [[[741.0, 91.0], [763.0, 91.0], [764.0, 170.0], [743.0, 170.0]], [[716.0, 90.0], [745.0, 90.0], [745.0, 155.0], [716.0, 155.0]]], "lines": ["あ．．．もう", "５時．．．"]}, {"box": [440, 91, 461, 205], "vertical": true, "font_size": 20, "lines_coords": [[[440.0, 91.0], [460.0, 91.0], [460.0, 205.0], [440.0, 205.0]]], "lines": ["いやな音だ！"]}, {"box": [132, 85, 176, 182], "vertical": true, "font_size": 20, "lines_coords": [[[155.0, 85.0], [176.0, 85.0], [176.0, 164.0], [155.0, 164.0]], [[132.0, 85.0], [152.0, 85.0], [152.0, 182.0], [132.0, 182.0]]], "lines": ["あの音も", "大嫌いだ！"]}, {"box": [114, 206, 181, 342], "vertical": true, "font_size": 20, "lines_coords": [[[161.0, 206.0], [181.0, 206.0], [181.0, 342.0], [161.0, 342.0]], [[137.0, 206.0], [157.0, 206.0], [157.0, 284.0], [137.0, 284.0]], [[114.0, 206.0], [134.0, 206.0], [134.0, 304.0], [114.0, 304.0]]], "lines": ["オレの耳の中を", "かき回し", "やがる．．．！"]}, {"box": [713, 379, 759, 487], "vertical": true, "font_size": 20, "lines_coords": [[[736.0, 379.0], [757.0, 379.0], [759.0, 478.0], [738.0, 478.0]], [[713.0, 380.0], [733.0, 380.0], [737.0, 487.0], [717.0, 487.0]]], "lines": ["．．．私．．．もう", "帰らなきゃ。"]}, {"box": [115, 957, 160, 1075], "vertical": true, "font_size": 20, "lines_coords": [[[139.0, 959.0], [159.0, 959.0], [159.0, 1075.0], [139.0, 1075.0]], [[117.0, 957.0], [137.0, 957.0], [135.0, 1075.0], [115.0, 1075.0]]], "lines": ["あの陰うつな", "海がいやだ！！"]}], "img_path": "023.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1204, "blocks": [{"box": [591, 90, 682, 232], "vertical": true, "font_size": 20, "lines_coords": [[[661.0, 91.0], [681.0, 91.0], [681.0, 224.0], [661.0, 224.0]], [[638.0, 90.0], [658.0, 90.0], [658.0, 174.0], [638.0, 174.0]], [[613.0, 90.0], [634.0, 90.0], [634.0, 168.0], [613.0, 168.0]], [[591.0, 90.0], [611.0, 90.0], [611.0, 232.0], [591.0, 232.0]]], "lines": ["隣の緑山市から", "見る海は、", "こんなに", "陰うつじゃない。"]}, {"box": [88, 145, 164, 246], "vertical": true, "font_size": 25, "lines_coords": [[[132.0, 145.0], [164.0, 145.0], [164.0, 194.0], [132.0, 194.0]], [[112.0, 150.0], [132.0, 150.0], [135.0, 246.0], [115.0, 246.0]], [[88.0, 149.0], [112.0, 149.0], [112.0, 217.0], [88.0, 217.0]]], "lines": ["あの", "黒い灯台も", "邪悪だ。"]}, {"box": [633, 499, 705, 616], "vertical": true, "font_size": 22, "lines_coords": [[[680.0, 499.0], [705.0, 499.0], [705.0, 562.0], [680.0, 562.0]], [[660.0, 502.0], [677.0, 502.0], [677.0, 616.0], [660.0, 616.0]], [[633.0, 500.0], [658.0, 500.0], [658.0, 562.0], [633.0, 562.0]]], "lines": ["そして", "背後の陰険な", "山々．．"]}, {"box": [386, 345, 431, 500], "vertical": true, "font_size": 20, "lines_coords": [[[410.0, 345.0], [430.0, 345.0], [430.0, 500.0], [410.0, 500.0]], [[386.0, 346.0], [406.0, 346.0], [406.0, 463.0], [386.0, 463.0]]], "lines": ["そうだ．．．ひっかき", "回すんだ．．．"]}, {"box": [64, 350, 136, 563], "vertical": true, "font_size": 19, "lines_coords": [[[110.0, 350.0], [130.0, 350.0], [130.0, 563.0], [110.0, 563.0]], [[85.0, 350.0], [105.0, 350.0], [105.0, 543.0], [85.0, 543.0]], [[64.0, 351.0], [81.0, 351.0], [81.0, 560.0], [64.0, 560.0]]], "lines": ["渦：渦だ．．．うずまきだ．．．", "．．．この町はうずまきに", "汚染され始めている．．．"]}, {"box": [472, 647, 541, 843], "vertical": true, "font_size": 19, "lines_coords": [[[523.0, 651.0], [539.0, 651.0], [539.0, 824.0], [523.0, 824.0]], [[498.0, 647.0], [518.0, 647.0], [516.0, 843.0], [496.0, 843.0]], [[476.0, 649.0], [496.0, 649.0], [492.0, 786.0], [472.0, 786.0]]], "lines": ["それにこの町並も．．．", "すべてがオレの神経を", "ひっかき回す．．．"]}, {"box": [358, 605, 426, 702], "vertical": true, "font_size": 22, "lines_coords": [[[405.0, 605.0], [426.0, 605.0], [424.0, 701.0], [403.0, 701.0]], [[379.0, 605.0], [404.0, 605.0], [404.0, 683.0], [379.0, 683.0]], [[358.0, 605.0], [378.0, 605.0], [378.0, 701.0], [358.0, 701.0]]], "lines": ["えっ．．．何？", "今、何て", "言ったの！？"]}, {"box": [228, 609, 255, 670], "vertical": true, "font_size": 27, "lines_coords": [[[228.0, 609.0], [255.0, 609.0], [255.0, 670.0], [228.0, 670.0]]], "lines": ["いや．．．"]}, {"box": [59, 612, 132, 677], "vertical": true, "font_size": 27, "lines_coords": [[[106.0, 612.0], [132.0, 612.0], [132.0, 645.0], [106.0, 645.0]], [[81.0, 612.0], [110.0, 612.0], [110.0, 677.0], [81.0, 677.0]], [[59.0, 613.0], [85.0, 613.0], [85.0, 677.0], [59.0, 677.0]]], "lines": ["な、", "何でも", "ない．．．"]}, {"box": [405, 960, 424, 1020], "vertical": true, "font_size": 19, "lines_coords": [[[405.0, 960.0], [424.0, 960.0], [424.0, 1020.0], [405.0, 1020.0]]], "lines": ["．．．．．？"]}], "img_path": "024.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1204, "blocks": [{"box": [659, 98, 751, 250], "vertical": true, "font_size": 19, "lines_coords": [[[730.0, 98.0], [751.0, 98.0], [751.0, 181.0], [730.0, 181.0]], [[706.0, 98.0], [726.0, 98.0], [726.0, 232.0], [706.0, 232.0]], [[684.0, 101.0], [700.0, 101.0], [700.0, 250.0], [684.0, 250.0]], [[659.0, 99.0], [679.0, 99.0], [679.0, 203.0], [659.0, 203.0]]], "lines": ["その翌日、", "彼のお父さんが", "私の父の仕事場に", "やって来た。"]}, {"box": [422, 70, 516, 189], "vertical": true, "font_size": 22, "lines_coords": [[[495.0, 72.0], [516.0, 72.0], [516.0, 156.0], [495.0, 156.0]], [[471.0, 72.0], [491.0, 72.0], [491.0, 189.0], [471.0, 189.0]], [[447.0, 72.0], [469.0, 72.0], [469.0, 169.0], [447.0, 169.0]], [[422.0, 70.0], [449.0, 70.0], [449.0, 123.0], [422.0, 123.0]]], "lines": ["五島さん、", "あいかわらず", "精が出ます", "ねえ。"]}, {"box": [669, 522, 761, 619], "vertical": true, "font_size": 22, "lines_coords": [[[740.0, 524.0], [760.0, 524.0], [760.0, 619.0], [740.0, 619.0]], [[717.0, 524.0], [738.0, 524.0], [738.0, 600.0], [717.0, 600.0]], [[691.0, 523.0], [716.0, 523.0], [716.0, 602.0], [691.0, 602.0]], [[669.0, 522.0], [693.0, 522.0], [693.0, 591.0], [669.0, 591.0]]], "lines": ["ただ仕事に", "追われて", "いるだけ", "ですよ。"]}, {"box": [525, 511, 623, 613], "vertical": true, "font_size": 27, "lines_coords": [[[593.0, 513.0], [623.0, 513.0], [623.0, 579.0], [593.0, 579.0]], [[566.0, 513.0], [597.0, 511.0], [603.0, 576.0], [572.0, 579.0]], [[551.0, 516.0], [571.0, 516.0], [571.0, 613.0], [551.0, 613.0]], [[525.0, 514.0], [551.0, 514.0], [551.0, 547.0], [525.0, 547.0]]], "lines": ["職人も", "楽じゃ", "ありません", "な。"]}, {"box": [112, 413, 159, 476], "vertical": true, "font_size": 24, "lines_coords": [[[134.0, 415.0], [159.0, 415.0], [159.0, 476.0], [134.0, 476.0]], [[112.0, 413.0], [135.0, 413.0], [135.0, 456.0], [112.0, 456.0]]], "lines": ["いやあ", "．．．"]}, {"box": [743, 850, 766, 892], "vertical": true, "font_size": 23, "lines_coords": [[[743.0, 850.0], [766.0, 850.0], [766.0, 892.0], [743.0, 892.0]]], "lines": ["は？"]}, {"box": [416, 522, 488, 753], "vertical": true, "font_size": 21, "lines_coords": [[[464.0, 524.0], [487.0, 524.0], [487.0, 753.0], [464.0, 753.0]], [[438.0, 522.0], [459.0, 522.0], [458.0, 697.0], [437.0, 697.0]], [[416.0, 523.0], [436.0, 523.0], [436.0, 659.0], [416.0, 659.0]]], "lines": ["いやいや．．．何というかその", "．．．ろくろによる作陶", "というのは．．．"]}, {"box": [369, 839, 412, 954], "vertical": true, "font_size": 17, "lines_coords": [[[395.0, 840.0], [411.0, 840.0], [411.0, 935.0], [395.0, 935.0]], [[370.0, 839.0], [388.0, 839.0], [386.0, 953.0], [369.0, 953.0]]], "lines": ["．．．なるほど", "うずまきか．．．"]}, {"box": [110, 510, 158, 779], "vertical": true, "font_size": 22, "lines_coords": [[[135.0, 510.0], [158.0, 510.0], [156.0, 779.0], [132.0, 779.0]], [[112.0, 510.0], [134.0, 510.0], [131.0, 721.0], [110.0, 721.0]]], "lines": ["いわば、うずまきの芸術とでも", "いうべきものですなあ！！"]}, {"box": [453, 838, 497, 973], "vertical": true, "font_size": 20, "lines_coords": [[[477.0, 838.0], [497.0, 838.0], [497.0, 973.0], [477.0, 973.0]], [[453.0, 839.0], [473.0, 839.0], [473.0, 917.0], [453.0, 917.0]]], "lines": ["うずまきの芸術", "ですか？"]}, {"box": [105, 840, 173, 981], "vertical": true, "font_size": 21, "lines_coords": [[[151.0, 841.0], [172.0, 841.0], [172.0, 935.0], [151.0, 935.0]], [[128.0, 840.0], [148.0, 840.0], [149.0, 981.0], [129.0, 981.0]], [[105.0, 843.0], [126.0, 843.0], [126.0, 926.0], [105.0, 926.0]]], "lines": ["確かに時々", "目が回りますよ、", "かハハハ。"]}], "img_path": "025.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [651, 79, 719, 234], "vertical": true, "font_size": 20, "lines_coords": [[[699.0, 79.0], [719.0, 79.0], [719.0, 165.0], [699.0, 165.0]], [[674.0, 79.0], [694.0, 79.0], [696.0, 234.0], [676.0, 234.0]], [[651.0, 79.0], [671.0, 79.0], [671.0, 214.0], [651.0, 214.0]]], "lines": ["どうです、", "私にひとつ作って", "くれませんか？"]}, {"box": [321, 87, 392, 188], "vertical": true, "font_size": 23, "lines_coords": [[[364.0, 87.0], [392.0, 87.0], [392.0, 188.0], [364.0, 188.0]], [[343.0, 89.0], [363.0, 89.0], [363.0, 186.0], [343.0, 186.0]], [[321.0, 91.0], [341.0, 91.0], [341.0, 187.0], [321.0, 187.0]]], "lines": ["特別、目の", "回りそうな", "皿を一枚．．．"]}, {"box": [200, 80, 276, 226], "vertical": true, "font_size": 21, "lines_coords": [[[255.0, 84.0], [275.0, 84.0], [275.0, 180.0], [255.0, 180.0]], [[227.0, 82.0], [247.0, 82.0], [247.0, 217.0], [227.0, 217.0]], [[200.0, 80.0], [223.0, 80.0], [226.0, 226.0], [202.0, 226.0]]], "lines": ["皿の表には", "うずまき模様を", "描いてください。"]}, {"box": [63, 80, 158, 198], "vertical": true, "font_size": 21, "lines_coords": [[[137.0, 82.0], [158.0, 82.0], [155.0, 179.0], [134.0, 179.0]], [[113.0, 83.0], [133.0, 83.0], [133.0, 165.0], [113.0, 165.0]], [[91.0, 83.0], [107.0, 83.0], [107.0, 198.0], [91.0, 198.0]], [[63.0, 80.0], [89.0, 80.0], [89.0, 144.0], [63.0, 144.0]]], "lines": ["ここが大事", "なんです", "うずまき模様", "です！"]}, {"box": [650, 410, 716, 547], "vertical": true, "font_size": 23, "lines_coords": [[[691.0, 410.0], [716.0, 410.0], [716.0, 474.0], [691.0, 474.0]], [[669.0, 410.0], [690.0, 410.0], [692.0, 547.0], [671.0, 547.0]]], "lines": ["こう．．．", "ぐーるぐーーると"]}, {"box": [82, 413, 147, 550], "vertical": true, "font_size": 18, "lines_coords": [[[126.0, 413.0], [146.0, 413.0], [147.0, 550.0], [127.0, 550.0]], [[104.0, 416.0], [121.0, 416.0], [120.0, 547.0], [103.0, 547.0]], [[82.0, 417.0], [98.0, 417.0], [98.0, 529.0], [82.0, 529.0]]], "lines": ["そうですなァ．．．", "黒いうずまきが", "いいですな！！"]}, {"box": [651, 616, 728, 773], "vertical": true, "font_size": 22, "lines_coords": [[[699.0, 617.0], [725.0, 616.0], [728.0, 685.0], [702.0, 686.0]], [[677.0, 616.0], [701.0, 616.0], [701.0, 754.0], [677.0, 754.0]], [[651.0, 618.0], [671.0, 618.0], [671.0, 773.0], [651.0, 773.0]]], "lines": ["実は今、", "うずまき模様に", "凝ってましてね！"]}, {"box": [579, 644, 623, 876], "vertical": true, "font_size": 22, "lines_coords": [[[601.0, 644.0], [622.0, 644.0], [623.0, 876.0], [602.0, 876.0]], [[579.0, 644.0], [599.0, 644.0], [600.0, 808.0], [580.0, 808.0]]], "lines": ["あらゆるうずまき状の物を", "集めてるんですよ。"]}, {"box": [441, 618, 541, 799], "vertical": true, "font_size": 20, "lines_coords": [[[514.0, 619.0], [534.0, 619.0], [534.0, 794.0], [514.0, 794.0]], [[488.0, 619.0], [509.0, 619.0], [511.0, 742.0], [490.0, 742.0]], [[465.0, 619.0], [485.0, 619.0], [487.0, 798.0], [467.0, 798.0]], [[441.0, 618.0], [461.0, 618.0], [464.0, 798.0], [444.0, 798.0]]], "lines": ["古今の着物の渦紋を", "はじめとして、", "巻き貝や蝸牛の貝殻", "アンモナイトの化石、"]}, {"box": [71, 625, 192, 779], "vertical": true, "font_size": 20, "lines_coords": [[[168.0, 625.0], [188.0, 625.0], [191.0, 779.0], [171.0, 779.0]], [[145.0, 625.0], [165.0, 625.0], [167.0, 766.0], [147.0, 766.0]], [[123.0, 625.0], [143.0, 625.0], [143.0, 731.0], [123.0, 731.0]], [[99.0, 626.0], [119.0, 626.0], [119.0, 740.0], [99.0, 740.0]], [[71.0, 628.0], [91.0, 628.0], [91.0, 741.0], [71.0, 741.0]]], "lines": ["機械のゼンマイや", "セロハンテープ、", "蚊取り線香、", "はては植物の", "つるまで．．．．．．"]}, {"box": [76, 935, 145, 1089], "vertical": true, "font_size": 20, "lines_coords": [[[121.0, 935.0], [143.0, 935.0], [145.0, 1023.0], [124.0, 1023.0]], [[99.0, 936.0], [119.0, 936.0], [119.0, 1089.0], [99.0, 1089.0]], [[76.0, 936.0], [96.0, 936.0], [96.0, 1034.0], [76.0, 1034.0]]], "lines": ["いやはや、", "集めてみると実に", "奥が深い！"]}], "img_path": "026.jpg"}, {"version": "0.1.7", "img_width": 835, "img_height": 1200, "blocks": [{"box": [645, 152, 759, 324], "vertical": true, "font_size": 19, "lines_coords": [[[741.0, 153.0], [757.0, 153.0], [757.0, 271.0], [741.0, 271.0]], [[715.0, 153.0], [735.0, 153.0], [735.0, 324.0], [715.0, 324.0]], [[692.0, 152.0], [709.0, 152.0], [710.0, 304.0], [693.0, 304.0]], [[668.0, 152.0], [688.0, 152.0], [688.0, 287.0], [668.0, 287.0]], [[645.0, 153.0], [665.0, 153.0], [665.0, 237.0], [645.0, 237.0]]], "lines": ["そこで今度は、", "町内随一の陶芸家に", "渦紋の皿を作って", "もらおうという", "わけです。"]}, {"box": [108, 94, 153, 290], "vertical": true, "font_size": 20, "lines_coords": [[[132.0, 96.0], [152.0, 96.0], [152.0, 246.0], [132.0, 246.0]], [[108.0, 94.0], [128.0, 94.0], [128.0, 290.0], [108.0, 290.0]]], "lines": ["いやあ、お金なら", "いくらでも出しますよ。"]}, {"box": [659, 424, 750, 616], "vertical": true, "font_size": 18, "lines_coords": [[[729.0, 424.0], [749.0, 424.0], [749.0, 585.0], [729.0, 585.0]], [[708.0, 425.0], [724.0, 425.0], [724.0, 614.0], [708.0, 614.0]], [[682.0, 424.0], [702.0, 424.0], [702.0, 616.0], [682.0, 616.0]], [[659.0, 425.0], [676.0, 425.0], [678.0, 547.0], [660.0, 547.0]]], "lines": ["私はね、五島さん。", "うずまきというものに", "何やら神秘的なものを", "感じるんです。"]}, {"box": [112, 444, 203, 617], "vertical": true, "font_size": 20, "lines_coords": [[[181.0, 445.0], [202.0, 445.0], [203.0, 617.0], [182.0, 617.0]], [[158.0, 446.0], [178.0, 446.0], [178.0, 596.0], [158.0, 596.0]], [[133.0, 444.0], [154.0, 444.0], [155.0, 597.0], [134.0, 597.0]], [[112.0, 445.0], [132.0, 445.0], [132.0, 541.0], [112.0, 541.0]]], "lines": ["いや．．．絶対にある．．．", "何か不思議な力が", "秘められているに", "違いない！"]}, {"box": [586, 683, 748, 854], "vertical": true, "font_size": 19, "lines_coords": [[[728.0, 685.0], [748.0, 685.0], [748.0, 781.0], [728.0, 781.0]], [[705.0, 683.0], [726.0, 683.0], [722.0, 817.0], [701.0, 817.0]], [[680.0, 686.0], [700.0, 686.0], [700.0, 801.0], [680.0, 801.0]], [[659.0, 685.0], [675.0, 685.0], [675.0, 780.0], [659.0, 780.0]], [[633.0, 685.0], [653.0, 685.0], [653.0, 800.0], [633.0, 800.0]], [[611.0, 683.0], [628.0, 683.0], [627.0, 854.0], [610.0, 854.0]], [[586.0, 683.0], [606.0, 683.0], [606.0, 762.0], [586.0, 762.0]]], "lines": ["五島さんも", "きっと理解して", "いただける！", "うすまきは", "素晴らしい！！", "うすまきこそ最高の", "芸術だ！！"]}, {"box": [398, 690, 488, 843], "vertical": true, "font_size": 18, "lines_coords": [[[470.0, 691.0], [487.0, 691.0], [487.0, 828.0], [470.0, 828.0]], [[446.0, 690.0], [463.0, 690.0], [462.0, 843.0], [445.0, 843.0]], [[421.0, 690.0], [441.0, 690.0], [440.0, 822.0], [420.0, 822.0]], [[399.0, 690.0], [416.0, 690.0], [415.0, 822.0], [398.0, 822.0]]], "lines": ["そしてあなたは、", "その最高の芸術を", "生みだしている", "芸術家なんだ！！"]}, {"box": [321, 691, 337, 735], "vertical": true, "font_size": 16, "lines_coords": [[[321.0, 691.0], [337.0, 691.0], [337.0, 735.0], [321.0, 735.0]]], "lines": ["．．．．．"]}], "img_path": "027.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [608, 98, 701, 214], "vertical": true, "font_size": 20, "lines_coords": [[[681.0, 99.0], [701.0, 99.0], [701.0, 185.0], [681.0, 185.0]], [[655.0, 98.0], [675.0, 98.0], [675.0, 213.0], [655.0, 213.0]], [[631.0, 100.0], [652.0, 100.0], [652.0, 174.0], [631.0, 174.0]], [[610.0, 100.0], [630.0, 100.0], [628.0, 214.0], [608.0, 214.0]]], "lines": ["．．．きのう、", "うちの親父が", "君んちへ", "行っただろ？"]}, {"box": [407, 125, 480, 281], "vertical": true, "font_size": 24, "lines_coords": [[[451.0, 125.0], [480.0, 125.0], [480.0, 191.0], [451.0, 191.0]], [[431.0, 127.0], [454.0, 127.0], [454.0, 281.0], [431.0, 281.0]], [[407.0, 126.0], [429.0, 126.0], [430.0, 230.0], [409.0, 230.0]]], "lines": ["うん．．．", "ちょっとびっくり", "しちゃった。"]}, {"box": [296, 89, 365, 225], "vertical": true, "font_size": 20, "lines_coords": [[[344.0, 89.0], [364.0, 89.0], [364.0, 225.0], [344.0, 225.0]], [[320.0, 89.0], [339.0, 89.0], [337.0, 208.0], [317.0, 208.0]], [[296.0, 89.0], [316.0, 89.0], [316.0, 169.0], [296.0, 169.0]]], "lines": ["迷惑だったろ？", "最近変なんだ", "あの親父"]}, {"box": [62, 85, 185, 185], "vertical": true, "font_size": 24, "lines_coords": [[[161.0, 86.0], [185.0, 86.0], [185.0, 130.0], [161.0, 130.0]], [[139.0, 87.0], [159.0, 87.0], [159.0, 185.0], [139.0, 185.0]], [[114.0, 89.0], [135.0, 89.0], [135.0, 185.0], [114.0, 185.0]], [[86.0, 86.0], [111.0, 86.0], [113.0, 168.0], [89.0, 168.0]], [[62.0, 85.0], [93.0, 85.0], [93.0, 133.0], [62.0, 133.0]]], "lines": ["でも", "うずまきに", "凝るなんて", "珍しいわ", "ね．．．"]}, {"box": [301, 430, 368, 570], "vertical": true, "font_size": 19, "lines_coords": [[[348.0, 430.0], [368.0, 430.0], [368.0, 570.0], [348.0, 570.0]], [[323.0, 430.0], [343.0, 430.0], [345.0, 548.0], [325.0, 548.0]], [[301.0, 431.0], [318.0, 431.0], [320.0, 549.0], [302.0, 549.0]]], "lines": ["うちのお父さん、", "芸術家なんて", "言われたから"]}, {"box": [69, 431, 114, 604], "vertical": true, "font_size": 19, "lines_coords": [[[91.0, 431.0], [112.0, 431.0], [114.0, 604.0], [93.0, 604.0]], [[69.0, 432.0], [86.0, 432.0], [87.0, 550.0], [70.0, 550.0]]], "lines": ["さっそく張り切って", "作り始めたわ"]}, {"box": [633, 638, 725, 813], "vertical": true, "font_size": 19, "lines_coords": [[[705.0, 639.0], [725.0, 639.0], [723.0, 800.0], [703.0, 800.0]], [[682.0, 638.0], [703.0, 638.0], [699.0, 813.0], [678.0, 813.0]], [[658.0, 641.0], [675.0, 641.0], [675.0, 792.0], [658.0, 792.0]], [[633.0, 639.0], [652.0, 639.0], [652.0, 725.0], [633.0, 725.0]]], "lines": ["でも考えてみたら、", "うずまきに凝るのは", "別に変じゃないと", "思うわよ。"]}, {"box": [370, 637, 464, 793], "vertical": true, "font_size": 21, "lines_coords": [[[436.0, 638.0], [461.0, 637.0], [464.0, 699.0], [438.0, 700.0]], [[414.0, 638.0], [436.0, 638.0], [438.0, 793.0], [417.0, 793.0]], [[395.0, 642.0], [411.0, 642.0], [411.0, 792.0], [395.0, 792.0]], [[370.0, 642.0], [390.0, 642.0], [390.0, 759.0], [370.0, 759.0]]], "lines": ["だって", "世の中にはもっと", "変な物集めてる人", "いるじゃない。"]}, {"box": [364, 830, 422, 937], "vertical": true, "font_size": 23, "lines_coords": [[[396.0, 830.0], [422.0, 830.0], [422.0, 905.0], [396.0, 905.0]], [[378.0, 833.0], [398.0, 833.0], [398.0, 937.0], [378.0, 937.0]]], "lines": ["タバコの", "吸いがらとか"]}, {"box": [194, 649, 334, 730], "vertical": true, "font_size": 22, "lines_coords": [[[307.0, 650.0], [334.0, 650.0], [334.0, 711.0], [307.0, 711.0]], [[284.0, 649.0], [309.0, 649.0], [309.0, 730.0], [284.0, 730.0]], [[262.0, 650.0], [283.0, 650.0], [283.0, 728.0], [262.0, 728.0]], [[236.0, 650.0], [261.0, 650.0], [261.0, 711.0], [236.0, 711.0]], [[216.0, 651.0], [237.0, 651.0], [235.0, 730.0], [214.0, 730.0]], [[194.0, 653.0], [214.0, 653.0], [214.0, 692.0], [194.0, 692.0]]], "lines": ["親父の", "凝り方が", "どんなに", "異常か", "って事を", "．．．？"]}, {"box": [72, 672, 165, 799], "vertical": true, "font_size": 22, "lines_coords": [[[145.0, 673.0], [165.0, 673.0], [165.0, 771.0], [145.0, 771.0]], [[121.0, 675.0], [141.0, 675.0], [141.0, 778.0], [121.0, 778.0]], [[94.0, 675.0], [116.0, 675.0], [117.0, 772.0], [96.0, 772.0]], [[72.0, 672.0], [92.0, 672.0], [94.0, 799.0], [75.0, 799.0]]], "lines": ["最近は会社", "へも行かず、", "書斎に閉じ", "こもっている。"]}, {"box": [634, 976, 724, 1092], "vertical": true, "font_size": 20, "lines_coords": [[[704.0, 977.0], [724.0, 977.0], [724.0, 1054.0], [704.0, 1054.0]], [[678.0, 976.0], [699.0, 976.0], [701.0, 1092.0], [679.0, 1092.0]], [[656.0, 976.0], [676.0, 976.0], [676.0, 1055.0], [656.0, 1055.0]], [[634.0, 976.0], [654.0, 976.0], [654.0, 1079.0], [634.0, 1079.0]]], "lines": ["君は何も", "知らないから", "そんな事", "言えるんだ。"]}], "img_path": "028.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1204, "blocks": [{"box": [634, 101, 725, 312], "vertical": true, "font_size": 21, "lines_coords": [[[705.0, 102.0], [725.0, 102.0], [725.0, 218.0], [705.0, 218.0]], [[681.0, 102.0], [701.0, 102.0], [701.0, 312.0], [681.0, 312.0]], [[656.0, 102.0], [681.0, 102.0], [681.0, 164.0], [656.0, 164.0]], [[634.0, 102.0], [654.0, 102.0], [654.0, 242.0], [634.0, 242.0]]], "lines": ["そして書斎に", "あふれ返ったうずまきを", "一日中", "眺めているんだ。"]}], "img_path": "029.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [630, 71, 722, 284], "vertical": true, "font_size": 20, "lines_coords": [[[702.0, 71.0], [722.0, 71.0], [720.0, 283.0], [701.0, 283.0]], [[678.0, 73.0], [698.0, 73.0], [698.0, 172.0], [678.0, 172.0]], [[656.0, 73.0], [676.0, 73.0], [676.0, 228.0], [656.0, 228.0]], [[630.0, 71.0], [650.0, 71.0], [650.0, 193.0], [630.0, 193.0]]], "lines": ["うずまきに熱中しだすと、", "親父はもう", "呼びかけられても", "返事もしない。"]}, {"box": [297, 73, 367, 228], "vertical": true, "font_size": 20, "lines_coords": [[[345.0, 76.0], [365.0, 76.0], [365.0, 191.0], [345.0, 191.0]], [[324.0, 73.0], [344.0, 73.0], [339.0, 228.0], [320.0, 228.0]], [[300.0, 75.0], [320.0, 75.0], [317.0, 172.0], [297.0, 172.0]]], "lines": ["ただひたすら", "うずまきを見つめて", "いるんだ．．．"]}, {"box": [79, 83, 125, 198], "vertical": true, "font_size": 20, "lines_coords": [[[104.0, 83.0], [124.0, 83.0], [124.0, 198.0], [104.0, 198.0]], [[79.0, 83.0], [100.0, 83.0], [100.0, 161.0], [79.0, 161.0]]], "lines": ["そして奇妙な", "事だが．．．"]}, {"box": [587, 419, 728, 575], "vertical": true, "font_size": 22, "lines_coords": [[[706.0, 420.0], [728.0, 420.0], [728.0, 502.0], [706.0, 502.0]], [[682.0, 420.0], [703.0, 420.0], [704.0, 517.0], [683.0, 517.0]], [[658.0, 419.0], [678.0, 419.0], [681.0, 555.0], [661.0, 555.0]], [[633.0, 420.0], [656.0, 420.0], [658.0, 575.0], [635.0, 575.0]], [[606.0, 420.0], [629.0, 420.0], [629.0, 556.0], [606.0, 556.0]]], "lines": ["．．．その時、", "親父の目は", "ぐるぐる回って", "いるんだ．．．それも", "異様に滑らかに"]}, {"box": [79, 408, 104, 471], "vertical": true, "font_size": 25, "lines_coords": [[[79.0, 408.0], [104.0, 408.0], [104.0, 471.0], [79.0, 471.0]]], "lines": ["えっ．．．"]}, {"box": [691, 663, 732, 742], "vertical": true, "font_size": 26, "lines_coords": [[[706.0, 664.0], [732.0, 664.0], [732.0, 742.0], [706.0, 742.0]]], "lines": ["．．．目が？"]}, {"box": [426, 663, 520, 762], "vertical": true, "font_size": 22, "lines_coords": [[[493.0, 663.0], [520.0, 663.0], [520.0, 714.0], [493.0, 714.0]], [[474.0, 664.0], [495.0, 664.0], [493.0, 761.0], [472.0, 761.0]], [[450.0, 665.0], [470.0, 665.0], [470.0, 762.0], [450.0, 762.0]], [[426.0, 665.0], [446.0, 665.0], [446.0, 762.0], [426.0, 762.0]]], "lines": ["ああ、", "うずまきに", "影響された", "みたいに．．"]}, {"box": [73, 658, 167, 813], "vertical": true, "font_size": 20, "lines_coords": [[[146.0, 659.0], [166.0, 659.0], [166.0, 758.0], [146.0, 758.0]], [[123.0, 659.0], [143.0, 659.0], [143.0, 800.0], [123.0, 800.0]], [[97.0, 658.0], [117.0, 658.0], [119.0, 813.0], [99.0, 813.0]], [[76.0, 658.0], [96.0, 658.0], [93.0, 775.0], [73.0, 775.0]]], "lines": ["．．．秀一君を", "笑わそうとして、", "わざとやってるん", "じゃないの？"]}, {"box": [316, 902, 384, 1036], "vertical": true, "font_size": 20, "lines_coords": [[[358.0, 902.0], [384.0, 902.0], [384.0, 963.0], [358.0, 963.0]], [[339.0, 904.0], [356.0, 904.0], [356.0, 1000.0], [339.0, 1000.0]], [[316.0, 904.0], [332.0, 904.0], [332.0, 1035.0], [316.0, 1035.0]]], "lines": ["冗談で", "あんなまね", "できるもんか！"]}, {"box": [72, 905, 140, 1059], "vertical": true, "font_size": 20, "lines_coords": [[[118.0, 905.0], [139.0, 905.0], [139.0, 1001.0], [118.0, 1001.0]], [[96.0, 905.0], [116.0, 905.0], [116.0, 1040.0], [96.0, 1040.0]], [[72.0, 907.0], [92.0, 907.0], [92.0, 1059.0], [72.0, 1059.0]]], "lines": ["左右の目が", "まったく別々に", "動いてるんだぜ！"]}], "img_path": "030.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [686, 106, 733, 225], "vertical": true, "font_size": 20, "lines_coords": [[[711.0, 107.0], [731.0, 107.0], [731.0, 225.0], [711.0, 225.0]], [[689.0, 106.0], [709.0, 106.0], [706.0, 203.0], [686.0, 203.0]]], "lines": ["左右の目が．．．", "別々に．．．？"]}, {"box": [113, 100, 180, 263], "vertical": true, "font_size": 20, "lines_coords": [[[160.0, 101.0], [180.0, 101.0], [180.0, 199.0], [160.0, 199.0]], [[135.0, 100.0], [157.0, 100.0], [158.0, 263.0], [137.0, 263.0]], [[114.0, 101.0], [131.0, 101.0], [131.0, 258.0], [114.0, 258.0]]], "lines": ["．．．それから", "こんな事もあった。", "ある晩の夕食の時"]}, {"box": [616, 308, 757, 434], "vertical": true, "font_size": 24, "lines_coords": [[[729.0, 310.0], [754.0, 309.0], [757.0, 370.0], [731.0, 371.0]], [[710.0, 311.0], [731.0, 311.0], [731.0, 387.0], [710.0, 387.0]], [[685.0, 310.0], [710.0, 311.0], [706.0, 389.0], [682.0, 387.0]], [[662.0, 309.0], [685.0, 309.0], [685.0, 434.0], [662.0, 434.0]], [[635.0, 308.0], [665.0, 308.0], [665.0, 372.0], [635.0, 372.0]], [[616.0, 310.0], [636.0, 310.0], [636.0, 414.0], [616.0, 414.0]]], "lines": ["親父は", "みそ汁に", "鳴門巻が", "入っていないと", "言って", "怒りだした。"]}, {"box": [314, 319, 476, 437], "vertical": true, "font_size": 21, "lines_coords": [[[454.0, 321.0], [475.0, 321.0], [475.0, 386.0], [454.0, 386.0]], [[431.0, 321.0], [452.0, 321.0], [452.0, 398.0], [431.0, 398.0]], [[409.0, 322.0], [430.0, 322.0], [430.0, 399.0], [409.0, 399.0]], [[385.0, 321.0], [405.0, 321.0], [405.0, 437.0], [385.0, 437.0]], [[362.0, 319.0], [383.0, 319.0], [381.0, 434.0], [359.0, 434.0]], [[338.0, 319.0], [358.0, 319.0], [358.0, 424.0], [338.0, 424.0]], [[314.0, 319.0], [334.0, 319.0], [334.0, 405.0], [314.0, 405.0]]], "lines": ["お袋は、", "鳴門巻は", "切らして", "しまったから", "しょうがない", "じゃないの、", "と言った。"]}, {"box": [246, 317, 270, 378], "vertical": true, "font_size": 24, "lines_coords": [[[246.0, 317.0], [270.0, 317.0], [270.0, 378.0], [246.0, 378.0]]], "lines": ["ふん！"]}, {"box": [101, 324, 194, 439], "vertical": true, "font_size": 21, "lines_coords": [[[169.0, 324.0], [194.0, 324.0], [194.0, 403.0], [169.0, 403.0]], [[148.0, 325.0], [168.0, 325.0], [168.0, 420.0], [148.0, 420.0]], [[124.0, 325.0], [144.0, 325.0], [144.0, 439.0], [124.0, 439.0]], [[101.0, 324.0], [121.0, 324.0], [121.0, 421.0], [101.0, 421.0]]], "lines": ["鳴門巻の", "入ってない", "みそ汁なんか", "食えるか！！"]}, {"box": [663, 672, 758, 789], "vertical": true, "font_size": 22, "lines_coords": [[[736.0, 673.0], [758.0, 673.0], [758.0, 789.0], [736.0, 789.0]], [[712.0, 675.0], [733.0, 675.0], [733.0, 752.0], [712.0, 752.0]], [[688.0, 672.0], [709.0, 672.0], [709.0, 748.0], [688.0, 748.0]], [[663.0, 672.0], [688.0, 672.0], [688.0, 741.0], [663.0, 741.0]]], "lines": ["突然、親父は", "みそ汁を", "かき回し", "始めた。"]}, {"box": [120, 673, 189, 807], "vertical": true, "font_size": 20, "lines_coords": [[[168.0, 673.0], [188.0, 673.0], [188.0, 788.0], [168.0, 788.0]], [[144.0, 675.0], [164.0, 675.0], [164.0, 807.0], [144.0, 807.0]], [[120.0, 673.0], [140.0, 673.0], [140.0, 779.0], [120.0, 779.0]]], "lines": ["親父はそれで", "少し気がすんだ", "ようだった。"]}], "img_path": "031.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [613, 90, 706, 226], "vertical": true, "font_size": 21, "lines_coords": [[[683.0, 90.0], [703.0, 90.0], [705.0, 226.0], [685.0, 226.0]], [[661.0, 92.0], [681.0, 92.0], [681.0, 212.0], [661.0, 212.0]], [[635.0, 91.0], [658.0, 91.0], [658.0, 209.0], [635.0, 209.0]], [[613.0, 91.0], [633.0, 91.0], [633.0, 171.0], [613.0, 171.0]]], "lines": ["それから親父は", "風呂に入る時、", "必ず渦を作る", "らしい！"]}, {"box": [349, 83, 372, 181], "vertical": true, "font_size": 21, "lines_coords": [[[349.0, 83.0], [370.0, 83.0], [370.0, 176.0], [349.0, 176.0]]], "lines": ["うい～～"]}, {"box": [657, 701, 733, 801], "vertical": true, "font_size": 26, "lines_coords": [[[701.0, 701.0], [733.0, 701.0], [733.0, 747.0], [701.0, 747.0]], [[683.0, 705.0], [704.0, 705.0], [704.0, 801.0], [683.0, 801.0]], [[657.0, 703.0], [683.0, 703.0], [683.0, 766.0], [657.0, 766.0]]], "lines": ["何が", "おかしいん", "だよ！？"]}, {"box": [430, 700, 499, 817], "vertical": true, "font_size": 21, "lines_coords": [[[473.0, 700.0], [499.0, 700.0], [499.0, 764.0], [473.0, 764.0]], [[452.0, 701.0], [472.0, 701.0], [472.0, 798.0], [452.0, 798.0]], [[431.0, 703.0], [447.0, 703.0], [447.0, 816.0], [431.0, 816.0]]], "lines": ["ここは", "笑うところ", "じゃないぜ！！"]}, {"box": [350, 716, 391, 850], "vertical": true, "font_size": 16, "lines_coords": [[[373.0, 718.0], [390.0, 718.0], [390.0, 812.0], [373.0, 812.0]], [[350.0, 717.0], [365.0, 717.0], [365.0, 848.0], [350.0, 848.0]]], "lines": ["君は信じて", "ないんだろう？"]}, {"box": [69, 717, 114, 891], "vertical": true, "font_size": 18, "lines_coords": [[[94.0, 719.0], [111.0, 719.0], [111.0, 876.0], [94.0, 876.0]], [[69.0, 717.0], [89.0, 717.0], [91.0, 890.0], [71.0, 890.0]]], "lines": ["ご．．．ごめんなさい、", "そういうわけじゃ！！"]}, {"box": [418, 892, 440, 992], "vertical": true, "font_size": 21, "lines_coords": [[[418.0, 892.0], [439.0, 892.0], [440.0, 992.0], [419.0, 992.0]]], "lines": ["くっくっ．．．"]}, {"box": [275, 946, 389, 1083], "vertical": true, "font_size": 23, "lines_coords": [[[369.0, 951.0], [389.0, 951.0], [389.0, 1071.0], [369.0, 1071.0]], [[339.0, 946.0], [371.0, 946.0], [371.0, 996.0], [339.0, 996.0]], [[322.0, 949.0], [343.0, 949.0], [344.0, 1075.0], [323.0, 1075.0]], [[297.0, 949.0], [317.0, 949.0], [318.0, 1083.0], [298.0, 1083.0]], [[275.0, 950.0], [295.0, 950.0], [295.0, 1051.0], [275.0, 1051.0]]], "lines": ["無理もないな。", "実際", "見てみなきゃ、", "あの不気味さは", "わからない。"]}], "img_path": "032.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [690, 69, 758, 183], "vertical": true, "font_size": 20, "lines_coords": [[[737.0, 69.0], [758.0, 69.0], [758.0, 147.0], [737.0, 147.0]], [[713.0, 69.0], [733.0, 69.0], [733.0, 183.0], [713.0, 183.0]], [[690.0, 69.0], [710.0, 69.0], [710.0, 165.0], [690.0, 165.0]]], "lines": ["そうだ．．．", "これから家に", "来ないか？"]}, {"box": [335, 82, 404, 198], "vertical": true, "font_size": 20, "lines_coords": [[[384.0, 82.0], [404.0, 82.0], [404.0, 180.0], [384.0, 180.0]], [[361.0, 82.0], [381.0, 82.0], [378.0, 198.0], [358.0, 198.0]], [[337.0, 82.0], [357.0, 82.0], [355.0, 187.0], [335.0, 187.0]]], "lines": ["そうすれば", "事の深刻さが", "わかるだろ。"]}, {"box": [218, 75, 308, 210], "vertical": true, "font_size": 21, "lines_coords": [[[287.0, 76.0], [307.0, 76.0], [307.0, 192.0], [287.0, 192.0]], [[262.0, 75.0], [286.0, 75.0], [286.0, 209.0], [262.0, 209.0]], [[240.0, 75.0], [260.0, 75.0], [260.0, 210.0], [240.0, 210.0]], [[218.0, 75.0], [237.0, 75.0], [237.0, 159.0], [218.0, 159.0]]], "lines": ["もしかしたら", "君も、この町が", "嫌いになるかも", "しれない。"]}, {"box": [342, 314, 363, 393], "vertical": true, "font_size": 20, "lines_coords": [[[342.0, 314.0], [362.0, 314.0], [362.0, 392.0], [342.0, 392.0]]], "lines": ["それに．．．"]}, {"box": [664, 737, 759, 854], "vertical": true, "font_size": 22, "lines_coords": [[[739.0, 737.0], [759.0, 737.0], [759.0, 834.0], [739.0, 834.0]], [[715.0, 737.0], [735.0, 737.0], [735.0, 854.0], [715.0, 854.0]], [[691.0, 737.0], [711.0, 737.0], [711.0, 834.0], [691.0, 834.0]], [[664.0, 737.0], [692.0, 737.0], [692.0, 787.0], [664.0, 787.0]]], "lines": ["．．．どうして", "私がこの町を", "嫌いになる", "のよ。"]}, {"box": [537, 738, 551, 779], "vertical": true, "font_size": 14, "lines_coords": [[[537.0, 738.0], [551.0, 738.0], [551.0, 779.0], [537.0, 779.0]]], "lines": ["．．．"]}, {"box": [355, 735, 495, 870], "vertical": true, "font_size": 20, "lines_coords": [[[474.0, 737.0], [495.0, 737.0], [495.0, 816.0], [474.0, 816.0]], [[451.0, 738.0], [471.0, 738.0], [471.0, 834.0], [451.0, 834.0]], [[427.0, 738.0], [447.0, 738.0], [447.0, 840.0], [427.0, 840.0]], [[403.0, 738.0], [423.0, 738.0], [423.0, 870.0], [403.0, 870.0]], [[379.0, 737.0], [400.0, 737.0], [400.0, 816.0], [379.0, 816.0]], [[357.0, 735.0], [377.0, 735.0], [375.0, 861.0], [355.0, 861.0]]], "lines": ["．．．オレは", "親父が変に", "なったのは、", "この町の環境の", "せいだと", "思ってるんだ。"]}, {"box": [253, 738, 272, 836], "vertical": true, "font_size": 16, "lines_coords": [[[254.0, 739.0], [270.0, 739.0], [270.0, 835.0], [254.0, 835.0]]], "lines": ["どうして？"]}, {"box": [175, 738, 217, 822], "vertical": true, "font_size": 20, "lines_coords": [[[175.0, 738.0], [195.0, 738.0], [195.0, 821.0], [175.0, 821.0]]], "lines": ["そうだな、"]}, {"box": [99, 738, 120, 815], "vertical": true, "font_size": 20, "lines_coords": [[[99.0, 738.0], [119.0, 738.0], [119.0, 815.0], [99.0, 815.0]]], "lines": ["例えば．．．"]}], "img_path": "033.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [399, 78, 445, 175], "vertical": true, "font_size": 20, "lines_coords": [[[424.0, 80.0], [445.0, 80.0], [445.0, 175.0], [424.0, 175.0]], [[399.0, 78.0], [419.0, 78.0], [419.0, 157.0], [399.0, 157.0]]], "lines": ["何か気づか", "ないか？"]}, {"box": [323, 76, 368, 153], "vertical": true, "font_size": 20, "lines_coords": [[[347.0, 77.0], [366.0, 77.0], [366.0, 153.0], [347.0, 153.0]], [[323.0, 77.0], [345.0, 77.0], [345.0, 118.0], [323.0, 118.0]]], "lines": ["何かって", "．．．？"]}, {"box": [68, 85, 137, 201], "vertical": true, "font_size": 21, "lines_coords": [[[112.0, 85.0], [137.0, 85.0], [137.0, 182.0], [112.0, 182.0]], [[90.0, 85.0], [111.0, 85.0], [109.0, 201.0], [87.0, 201.0]], [[69.0, 86.0], [85.0, 86.0], [85.0, 200.0], [69.0, 200.0]]], "lines": ["最近、渦が", "やけに多いと", "思わないか？"]}, {"box": [691, 346, 733, 487], "vertical": true, "font_size": 16, "lines_coords": [[[715.0, 346.0], [731.0, 346.0], [731.0, 480.0], [715.0, 480.0]], [[691.0, 346.0], [708.0, 346.0], [708.0, 485.0], [691.0, 485.0]]], "lines": ["この川の流れを", "よく見てごらん。"]}, {"box": [665, 539, 737, 713], "vertical": true, "font_size": 21, "lines_coords": [[[713.0, 539.0], [737.0, 539.0], [737.0, 657.0], [713.0, 657.0]], [[691.0, 540.0], [711.0, 540.0], [711.0, 637.0], [691.0, 637.0]], [[665.0, 539.0], [685.0, 539.0], [689.0, 713.0], [669.0, 713.0]]], "lines": ["ええ．．．まあ．．．", "でもこれは", "流れのせいでしょ？"]}, {"box": [616, 794, 731, 896], "vertical": true, "font_size": 20, "lines_coords": [[[710.0, 794.0], [731.0, 794.0], [731.0, 873.0], [710.0, 873.0]], [[686.0, 794.0], [708.0, 794.0], [708.0, 873.0], [686.0, 873.0]], [[663.0, 794.0], [683.0, 794.0], [683.0, 873.0], [663.0, 873.0]], [[640.0, 794.0], [660.0, 794.0], [660.0, 890.0], [640.0, 890.0]], [[617.0, 794.0], [634.0, 794.0], [634.0, 895.0], [617.0, 895.0]]], "lines": ["それに．．．", "この頃は", "風までも", "やけに渦を", "巻きやがる。"]}, {"box": [372, 525, 416, 687], "vertical": true, "font_size": 18, "lines_coords": [[[395.0, 525.0], [414.0, 525.0], [414.0, 642.0], [395.0, 642.0]], [[372.0, 527.0], [389.0, 527.0], [389.0, 684.0], [372.0, 684.0]]], "lines": ["うん．．．確かに", "そうかもしれない。"]}, {"box": [463, 789, 506, 890], "vertical": true, "font_size": 20, "lines_coords": [[[485.0, 789.0], [506.0, 789.0], [506.0, 864.0], [485.0, 864.0]], [[463.0, 789.0], [482.0, 789.0], [482.0, 890.0], [463.0, 890.0]]], "lines": ["つむじ風", "ってやつだ。"]}, {"box": [275, 574, 342, 749], "vertical": true, "font_size": 19, "lines_coords": [[[321.0, 575.0], [341.0, 575.0], [341.0, 748.0], [321.0, 748.0]], [[295.0, 574.0], [316.0, 574.0], [318.0, 748.0], [297.0, 748.0]], [[275.0, 575.0], [291.0, 575.0], [291.0, 710.0], [275.0, 710.0]]], "lines": ["でも隣の緑山市では", "こんなに沢山の渦を", "見た事がない"]}, {"box": [243, 782, 258, 824], "vertical": true, "font_size": 15, "lines_coords": [[[243.0, 782.0], [258.0, 782.0], [258.0, 824.0], [243.0, 824.0]]], "lines": ["．．．"]}, {"box": [71, 788, 92, 942], "vertical": true, "font_size": 20, "lines_coords": [[[71.0, 788.0], [91.0, 788.0], [91.0, 942.0], [71.0, 942.0]]], "lines": ["わからないが．．．"]}, {"box": [332, 975, 448, 1101], "vertical": true, "font_size": 18, "lines_coords": [[[429.0, 975.0], [446.0, 975.0], [444.0, 1072.0], [426.0, 1072.0]], [[406.0, 977.0], [423.0, 977.0], [423.0, 1069.0], [406.0, 1069.0]], [[381.0, 975.0], [400.0, 975.0], [400.0, 1101.0], [381.0, 1101.0]], [[358.0, 977.0], [375.0, 977.0], [375.0, 1069.0], [358.0, 1069.0]], [[332.0, 975.0], [352.0, 975.0], [352.0, 1054.0], [332.0, 1054.0]]], "lines": ["．．．それか．．", "おじさんの", "うずまき好きと", "何の関係が", "あるの？"]}], "img_path": "034.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [279, 64, 425, 187], "vertical": true, "font_size": 32, "lines_coords": [[[390.0, 65.0], [425.0, 65.0], [425.0, 140.0], [390.0, 140.0]], [[352.0, 65.0], [385.0, 65.0], [385.0, 158.0], [352.0, 158.0]], [[315.0, 64.0], [348.0, 64.0], [348.0, 187.0], [315.0, 187.0]], [[280.0, 65.0], [308.0, 65.0], [308.0, 187.0], [280.0, 187.0]]], "lines": ["お前、", "何て事", "してくれ", "たんだ！！"]}, {"box": [102, 132, 127, 160], "vertical": true, "font_size": 25, "lines_coords": [[[102.0, 132.0], [127.0, 132.0], [127.0, 160.0], [102.0, 160.0]]], "lines": ["！？"]}, {"box": [746, 434, 765, 574], "vertical": true, "font_size": 17, "lines_coords": [[[746.0, 434.0], [763.0, 434.0], [763.0, 573.0], [746.0, 573.0]]], "lines": ["どうしたんだよ。"]}, {"box": [339, 266, 424, 380], "vertical": true, "font_size": 41, "lines_coords": [[[375.0, 267.0], [424.0, 267.0], [424.0, 348.0], [375.0, 348.0]], [[339.0, 266.0], [372.0, 266.0], [372.0, 380.0], [339.0, 380.0]]], "lines": ["キャ", "～～！！"]}, {"box": [440, 438, 534, 517], "vertical": true, "font_size": 22, "lines_coords": [[[508.0, 439.0], [534.0, 439.0], [534.0, 508.0], [508.0, 508.0]], [[487.0, 440.0], [508.0, 440.0], [508.0, 517.0], [487.0, 517.0]], [[464.0, 438.0], [484.0, 438.0], [484.0, 516.0], [464.0, 516.0]], [[440.0, 438.0], [463.0, 438.0], [463.0, 462.0], [440.0, 462.0]]], "lines": ["こいつ、", "ただじゃ", "済まんぞ", "！！"]}, {"box": [109, 432, 162, 526], "vertical": true, "font_size": 25, "lines_coords": [[[133.0, 432.0], [162.0, 432.0], [162.0, 506.0], [133.0, 506.0]], [[109.0, 434.0], [130.0, 434.0], [130.0, 526.0], [109.0, 526.0]]], "lines": ["やめて", "あなた！！"]}, {"box": [716, 761, 759, 839], "vertical": true, "font_size": 20, "lines_coords": [[[739.0, 761.0], [759.0, 761.0], [759.0, 839.0], [739.0, 839.0]], [[716.0, 761.0], [736.0, 761.0], [736.0, 839.0], [716.0, 839.0]]], "lines": ["やめろよ", "父さん！！"]}, {"box": [531, 582, 552, 717], "vertical": true, "font_size": 20, "lines_coords": [[[532.0, 582.0], [552.0, 582.0], [550.0, 717.0], [531.0, 717.0]]], "lines": ["父さん母さん！？"]}, {"box": [474, 761, 518, 857], "vertical": true, "font_size": 20, "lines_coords": [[[498.0, 764.0], [518.0, 764.0], [518.0, 840.0], [498.0, 840.0]], [[474.0, 761.0], [494.0, 761.0], [494.0, 857.0], [474.0, 857.0]]], "lines": ["一体どう", "したんだ！？"]}, {"box": [359, 771, 429, 964], "vertical": true, "font_size": 21, "lines_coords": [[[407.0, 772.0], [429.0, 772.0], [427.0, 946.0], [406.0, 946.0]], [[384.0, 772.0], [405.0, 772.0], [404.0, 964.0], [383.0, 964.0]], [[361.0, 771.0], [382.0, 771.0], [381.0, 925.0], [359.0, 925.0]]], "lines": ["こいつが私の大切な", "コレクションをすべて", "処分しやがった！！"]}, {"box": [107, 761, 178, 880], "vertical": true, "font_size": 23, "lines_coords": [[[154.0, 761.0], [178.0, 761.0], [178.0, 880.0], [154.0, 880.0]], [[130.0, 761.0], [155.0, 761.0], [155.0, 823.0], [130.0, 823.0]], [[110.0, 761.0], [130.0, 761.0], [127.0, 877.0], [107.0, 877.0]]], "lines": ["私がちょっと", "留守に", "してる間に．．．"]}], "img_path": "035.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [678, 77, 728, 255], "vertical": true, "font_size": 24, "lines_coords": [[[701.0, 77.0], [725.0, 77.0], [728.0, 255.0], [703.0, 255.0]], [[678.0, 79.0], [702.0, 79.0], [704.0, 217.0], [681.0, 217.0]]], "lines": ["あなた、いい加減に", "目を覚まして！！"]}, {"box": [381, 90, 474, 304], "vertical": true, "font_size": 20, "lines_coords": [[[453.0, 91.0], [473.0, 91.0], [473.0, 267.0], [453.0, 267.0]], [[430.0, 9