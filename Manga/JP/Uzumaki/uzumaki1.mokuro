ks": [{"box": [683, 452, 726, 630], "vertical": true, "font_size": 18, "lines_coords": [[[705.0, 452.0], [725.0, 452.0], [725.0, 548.0], [705.0, 548.0]], [[683.0, 453.0], [699.0, 453.0], [699.0, 630.0], [683.0, 630.0]]], "lines": ["全然わけが", "わからないんですよ。"]}, {"box": [379, 450, 447, 701], "vertical": true, "font_size": 19, "lines_coords": [[[426.0, 450.0], [446.0, 450.0], [445.0, 625.0], [425.0, 625.0]], [[403.0, 450.0], [423.0, 450.0], [422.0, 701.0], [402.0, 701.0]], [[382.0, 451.0], [398.0, 451.0], [396.0, 587.0], [379.0, 587.0]]], "lines": ["．．．何もしてないのに", "髪がこんなふうになる事って", "あるんですか？"]}, {"box": [310, 457, 352, 612], "vertical": true, "font_size": 19, "lines_coords": [[[331.0, 457.0], [352.0, 457.0], [352.0, 520.0], [331.0, 520.0]], [[310.0, 460.0], [327.0, 460.0], [327.0, 612.0], [310.0, 612.0]]], "lines": ["さあ．．．", "わからないけど．．．"]}, {"box": [58, 455, 128, 653], "vertical": true, "font_size": 23, "lines_coords": [[[104.0, 455.0], [128.0, 455.0], [128.0, 527.0], [104.0, 527.0]], [[80.0, 457.0], [104.0, 457.0], [104.0, 653.0], [80.0, 653.0]], [[58.0, 459.0], [78.0, 459.0], [78.0, 614.0], [58.0, 614.0]]], "lines": ["じゃあ、", "ストレートパーマでも", "かけましょうか？"]}, {"box": [659, 739, 724, 876], "vertical": true, "font_size": 20, "lines_coords": [[[707.0, 740.0], [723.0, 740.0], [723.0, 834.0], [707.0, 834.0]], [[681.0, 739.0], [705.0, 739.0], [705.0, 819.0], [681.0, 819.0]], [[660.0, 740.0], [680.0, 740.0], [680.0, 876.0], [660.0, 876.0]]], "lines": ["．．．うーん．．．", "やっぱり", "切ってください"]}, {"box": [519, 750, 566, 847], "vertical": true, "font_size": 24, "lines_coords": [[[545.0, 752.0], [566.0, 752.0], [566.0, 847.0], [545.0, 847.0]], [[519.0, 750.0], [545.0, 750.0], [545.0, 812.0], [519.0, 812.0]]], "lines": ["バッサリと", "短く．．．"]}, {"box": [315, 748, 363, 885], "vertical": true, "font_size": 23, "lines_coords": [[[335.0, 750.0], [361.0, 748.0], [363.0, 817.0], [337.0, 819.0]], [[315.0, 751.0], [335.0, 751.0], [335.0, 885.0], [315.0, 885.0]]], "lines": ["えーっ、", "いいんですか？"]}, {"box": [165, 748, 259, 835], "vertical": true, "font_size": 22, "lines_coords": [[[239.0, 751.0], [259.0, 751.0], [259.0, 832.0], [239.0, 832.0]], [[215.0, 753.0], [236.0, 753.0], [236.0, 829.0], [215.0, 829.0]], [[191.0, 752.0], [212.0, 752.0], [212.0, 829.0], [191.0, 829.0]], [[165.0, 748.0], [193.0, 748.0], [193.0, 788.0], [165.0, 788.0]]], "lines": ["．．．じゃあ、", "バッサリ", "いきます", "よ。"]}, {"box": [511, 955, 558, 1110], "vertical": true, "font_size": 20, "lines_coords": [[[538.0, 956.0], [558.0, 956.0], [555.0, 1110.0], [535.0, 1110.0]], [[513.0, 955.0], [534.0, 955.0], [532.0, 1041.0], [511.0, 1041.0]]], "lines": ["だって気味悪いん", "ですもの。"]}], "img_path": "186.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [], "img_path": "187.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [692, 91, 738, 138], "vertical": true, "font_size": 34, "lines_coords": [[[704.0, 91.0], [738.0, 91.0], [738.0, 138.0], [704.0, 138.0]]], "lines": ["ばっ"]}, {"box": [488, 71, 518, 193], "vertical": true, "font_size": 30, "lines_coords": [[[488.0, 71.0], [518.0, 71.0], [518.0, 193.0], [488.0, 193.0]]], "lines": ["ばけもの"]}, {"box": [452, 104, 481, 196], "vertical": true, "font_size": 30, "lines_coords": [[[452.0, 104.0], [481.0, 104.0], [481.0, 196.0], [452.0, 196.0]]], "lines": ["ーっ！！"]}, {"box": [707, 525, 727, 667], "vertical": true, "font_size": 16, "lines_coords": [[[708.0, 527.0], [724.0, 527.0], [724.0, 663.0], [708.0, 663.0]]], "lines": ["．．．私の髪の毛は"]}, {"box": [458, 516, 550, 652], "vertical": true, "font_size": 21, "lines_coords": [[[529.0, 519.0], [549.0, 519.0], [549.0, 635.0], [529.0, 635.0]], [[504.0, 516.0], [528.0, 516.0], [528.0, 635.0], [504.0, 635.0]], [[481.0, 519.0], [501.0, 519.0], [501.0, 652.0], [481.0, 652.0]], [[458.0, 517.0], [478.0, 517.0], [478.0, 621.0], [458.0, 621.0]]], "lines": ["異常に伸びた", "髪は、まるで", "生きているかの", "ように動き、"]}, {"box": [267, 506, 360, 643], "vertical": true, "font_size": 23, "lines_coords": [[[338.0, 509.0], [358.0, 509.0], [358.0, 608.0], [338.0, 608.0]], [[308.0, 506.0], [338.0, 506.0], [338.0, 569.0], [308.0, 569.0]], [[290.0, 509.0], [310.0, 509.0], [310.0, 643.0], [290.0, 643.0]], [[267.0, 508.0], [288.0, 508.0], [288.0, 571.0], [267.0, 571.0]]], "lines": ["家族が私を", "病院へ", "連れていこうと", "すると、"]}, {"box": [121, 535, 141, 629], "vertical": true, "font_size": 22, "lines_coords": [[[121.0, 535.0], [141.0, 535.0], [141.0, 629.0], [121.0, 629.0]]], "lines": ["あああ．．．"]}, {"box": [73, 594, 98, 700], "vertical": true, "font_size": 22, "lines_coords": [[[73.0, 594.0], [98.0, 594.0], [98.0, 700.0], [73.0, 700.0]]], "lines": ["苦しい！！"]}, {"box": [582, 896, 630, 1109], "vertical": true, "font_size": 20, "lines_coords": [[[610.0, 896.0], [630.0, 896.0], [628.0, 1052.0], [608.0, 1052.0]], [[586.0, 897.0], [607.0, 897.0], [603.0, 1109.0], [582.0, 1109.0]]], "lines": ["うずまきの呪いに", "かかったのでしょうか？"]}, {"box": [329, 977, 423, 1102], "vertical": true, "font_size": 20, "lines_coords": [[[403.0, 979.0], [423.0, 979.0], [420.0, 1093.0], [400.0, 1093.0]], [[378.0, 978.0], [399.0, 978.0], [399.0, 1044.0], [378.0, 1044.0]], [[354.0, 979.0], [374.0, 979.0], [374.0, 1058.0], [354.0, 1058.0]], [[329.0, 977.0], [349.0, 977.0], [351.0, 1102.0], [331.0, 1102.0]]], "lines": ["切られそうに", "なると、", "私の首を", "絞めるのです。"]}, {"box": [64, 952, 133, 1088], "vertical": true, "font_size": 22, "lines_coords": [[[113.0, 952.0], [133.0, 952.0], [132.0, 1088.0], [112.0, 1088.0]], [[89.0, 952.0], [109.0, 952.0], [107.0, 1088.0], [87.0, 1088.0]], [[64.0, 952.0], [89.0, 952.0], [89.0, 1020.0], [64.0, 1020.0]]], "lines": ["さらに私の首を", "強く絞めあげる", "のです。"]}], "img_path": "188.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [236, 78, 302, 178], "vertical": true, "font_size": 19, "lines_coords": [[[282.0, 78.0], [302.0, 78.0], [300.0, 160.0], [280.0, 160.0]], [[257.0, 82.0], [277.0, 82.0], [277.0, 178.0], [257.0, 178.0]], [[236.0, 82.0], [254.0, 82.0], [254.0, 123.0], [236.0, 123.0]]], "lines": ["どうして", "こんな事に", "．．．"]}, {"box": [99, 84, 167, 200], "vertical": true, "font_size": 19, "lines_coords": [[[147.0, 84.0], [164.0, 84.0], [164.0, 181.0], [147.0, 181.0]], [[123.0, 84.0], [143.0, 84.0], [143.0, 200.0], [123.0, 200.0]], [[99.0, 84.0], [120.0, 84.0], [120.0, 145.0], [99.0, 145.0]]], "lines": ["どうしたら", "いいんだろう", "．．．．．？"]}, {"box": [697, 520, 767, 658], "vertical": true, "font_size": 22, "lines_coords": [[[748.0, 522.0], [767.0, 522.0], [764.0, 639.0], [744.0, 639.0]], [[723.0, 521.0], [743.0, 521.0], [739.0, 658.0], [719.0, 658.0]], [[697.0, 520.0], [722.0, 520.0], [722.0, 587.0], [697.0, 587.0]]], "lines": ["そして私達が", "抵抗をやめると", "今度は、"]}, {"box": [341, 521, 432, 639], "vertical": true, "font_size": 20, "lines_coords": [[[411.0, 522.0], [432.0, 522.0], [432.0, 619.0], [411.0, 619.0]], [[388.0, 522.0], [408.0, 522.0], [408.0, 619.0], [388.0, 619.0]], [[364.0, 521.0], [384.0, 521.0], [382.0, 639.0], [362.0, 639.0]], [[341.0, 523.0], [361.0, 523.0], [361.0, 607.0], [341.0, 607.0]]], "lines": ["誇らしげに", "渦を巻いて", "ポーズをとる", "のでした。"]}, {"box": [758, 941, 772, 983], "vertical": true, "font_size": 14, "lines_coords": [[[758.0, 941.0], [772.0, 941.0], [772.0, 983.0], [758.0, 983.0]]], "lines": ["．．．"]}, {"box": [596, 939, 611, 978], "vertical": true, "font_size": 15, "lines_coords": [[[596.0, 939.0], [611.0, 939.0], [611.0, 978.0], [596.0, 978.0]]], "lines": ["．．．"]}], "img_path": "189.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [630, 82, 725, 164], "vertical": true, "font_size": 24, "lines_coords": [[[698.0, 83.0], [725.0, 83.0], [725.0, 131.0], [698.0, 131.0]], [[677.0, 85.0], [698.0, 85.0], [698.0, 164.0], [677.0, 164.0]], [[650.0, 82.0], [678.0, 82.0], [678.0, 130.0], [650.0, 130.0]], [[630.0, 84.0], [650.0, 84.0], [650.0, 164.0], [630.0, 164.0]]], "lines": ["．．．．．", "どうした", "の？", "みんな．．．"]}, {"box": [307, 87, 369, 145], "vertical": true, "font_size": 36, "lines_coords": [[[332.0, 87.0], [369.0, 87.0], [369.0, 145.0], [332.0, 145.0]], [[307.0, 89.0], [343.0, 89.0], [343.0, 145.0], [307.0, 145.0]]], "lines": ["ねえ", "．．．！？"]}, {"box": [599, 376, 715, 502], "vertical": true, "font_size": 20, "lines_coords": [[[695.0, 378.0], [715.0, 378.0], [715.0, 457.0], [695.0, 457.0]], [[673.0, 379.0], [689.0, 379.0], [689.0, 494.0], [673.0, 494.0]], [[647.0, 378.0], [667.0, 378.0], [667.0, 494.0], [647.0, 494.0]], [[621.0, 376.0], [644.0, 376.0], [644.0, 496.0], [621.0, 496.0]], [[599.0, 378.0], [619.0, 378.0], [619.0, 502.0], [599.0, 502.0]]], "lines": ["この髪に", "見る者を圧倒", "する力がある", "事は、すぐに", "わかりました。"]}, {"box": [75, 379, 218, 494], "vertical": true, "font_size": 22, "lines_coords": [[[196.0, 382.0], [216.0, 382.0], [216.0, 480.0], [196.0, 480.0]], [[173.0, 380.0], [193.0, 380.0], [193.0, 494.0], [173.0, 494.0]], [[145.0, 379.0], [172.0, 379.0], [172.0, 439.0], [145.0, 439.0]], [[123.0, 380.0], [144.0, 380.0], [144.0, 459.0], [123.0, 459.0]], [[99.0, 380.0], [119.0, 380.0], [119.0, 476.0], [99.0, 476.0]], [[75.0, 380.0], [96.0, 380.0], [96.0, 458.0], [75.0, 458.0]]], "lines": ["そして髪が、", "人の大勢いる", "場所へ", "行くのを", "望んでいる", "事も．．．"]}, {"box": [493, 915, 516, 1011], "vertical": true, "font_size": 20, "lines_coords": [[[495.0, 915.0], [515.0, 915.0], [513.0, 1011.0], [493.0, 1011.0]]], "lines": ["五島さん．．．"]}], "img_path": "190.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [112, 179, 208, 298], "vertical": true, "font_size": 24, "lines_coords": [[[184.0, 181.0], [208.0, 181.0], [208.0, 244.0], [184.0, 244.0]], [[162.0, 182.0], [182.0, 182.0], [182.0, 298.0], [162.0, 298.0]], [[132.0, 179.0], [165.0, 179.0], [165.0, 228.0], [132.0, 228.0]], [[114.0, 182.0], [134.0, 182.0], [132.0, 285.0], [112.0, 285.0]]], "lines": ["絶えず", "そのポーズを", "変化", "させました。"]}, {"box": [692, 219, 764, 392], "vertical": true, "font_size": 20, "lines_coords": [[[741.0, 219.0], [764.0, 219.0], [764.0, 357.0], [741.0, 357.0]], [[719.0, 221.0], [736.0, 221.0], [736.0, 392.0], [719.0, 392.0]], [[692.0, 220.0], [712.0, 220.0], [712.0, 378.0], [692.0, 378.0]]], "lines": ["髪は、その姿を", "人々にまんべんなく", "見せつけるために、"]}, {"box": [685, 675, 756, 773], "vertical": true, "font_size": 23, "lines_coords": [[[736.0, 675.0], [756.0, 675.0], [756.0, 773.0], [736.0, 773.0]], [[709.0, 675.0], [733.0, 675.0], [733.0, 773.0], [709.0, 773.0]], [[685.0, 675.0], [710.0, 675.0], [710.0, 737.0], [685.0, 737.0]]], "lines": ["きっ．．．君！！", "何だ、その", "頭は！？"]}, {"box": [355, 671, 398, 787], "vertical": true, "font_size": 16, "lines_coords": [[[379.0, 672.0], [396.0, 672.0], [396.0, 767.0], [379.0, 767.0]], [[356.0, 672.0], [372.0, 672.0], [372.0, 786.0], [356.0, 786.0]]], "lines": ["早くもとに", "戻しなさい！！"]}], "img_path": "191.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [662, 84, 730, 201], "vertical": true, "font_size": 20, "lines_coords": [[[710.0, 85.0], [730.0, 85.0], [730.0, 201.0], [710.0, 201.0]], [[685.0, 84.0], [705.0, 84.0], [705.0, 201.0], [685.0, 201.0]], [[662.0, 84.0], [682.0, 84.0], [682.0, 169.0], [662.0, 169.0]]], "lines": ["．．．五島さん．．．", "あなた、案外", "やるわね。"]}, {"box": [415, 90, 478, 195], "vertical": true, "font_size": 20, "lines_coords": [[[458.0, 90.0], [478.0, 90.0], [478.0, 195.0], [458.0, 195.0]], [[435.0, 91.0], [454.0, 91.0], [454.0, 188.0], [435.0, 188.0]]], "lines": ["．．．いいわね、", "注目されて"]}, {"box": [75, 217, 93, 353], "vertical": true, "font_size": 16, "lines_coords": [[[75.0, 217.0], [91.0, 217.0], [91.0, 353.0], [75.0, 353.0]]], "lines": ["うらやましい．．．"]}, {"box": [514, 376, 608, 559], "vertical": true, "font_size": 20, "lines_coords": [[[587.0, 377.0], [608.0, 377.0], [605.0, 512.0], [583.0, 512.0]], [[562.0, 376.0], [582.0, 376.0], [582.0, 537.0], [562.0, 537.0]], [[538.0, 378.0], [558.0, 378.0], [558.0, 471.0], [538.0, 471.0]], [[515.0, 376.0], [535.0, 376.0], [534.0, 558.0], [514.0, 558.0]]], "lines": ["目立つのは嫌い", "とか言ってたのに、", "今や学校", "目立ってるじゃない。"]}, {"box": [403, 401, 477, 556], "vertical": true, "font_size": 19, "lines_coords": [[[458.0, 403.0], [474.0, 403.0], [474.0, 556.0], [458.0, 556.0]], [[427.0, 403.0], [447.0, 403.0], [447.0, 499.0], [427.0, 499.0]], [[403.0, 401.0], [423.0, 401.0], [423.0, 483.0], [403.0, 483.0]]], "lines": ["おまけに見た人を", "虜にしてる", "みたいね"]}, {"box": [174, 579, 287, 603], "vertical": false, "font_size": 16, "lines_coords": [[[177.0, 582.0], [281.0, 582.0], [281.0, 598.0], [177.0, 598.0]]], "lines": ["朝練黒源"]}, {"box": [72, 417, 164, 534], "vertical": true, "font_size": 19, "lines_coords": [[[143.0, 419.0], [162.0, 419.0], [162.0, 516.0], [143.0, 516.0]], [[117.0, 417.0], [141.0, 417.0], [141.0, 481.0], [117.0, 481.0]], [[97.0, 420.0], [113.0, 420.0], [113.0, 534.0], [97.0, 534.0]], [[72.0, 419.0], [89.0, 419.0], [91.0, 515.0], [75.0, 515.0]]], "lines": ["危険だわ．．．", "あまり", "見ないように", "しなきゃ！"]}, {"box": [692, 600, 737, 754], "vertical": true, "font_size": 20, "lines_coords": [[[716.0, 600.0], [736.0, 600.0], [736.0, 754.0], [716.0, 754.0]], [[692.0, 600.0], [712.0, 600.0], [712.0, 737.0], [692.0, 737.0]]], "lines": ["．．．でも、私だって", "負けないわよ．．．"]}, {"box": [491, 602, 558, 758], "vertical": true, "font_size": 18, "lines_coords": [[[538.0, 603.0], [555.0, 603.0], [556.0, 737.0], [539.0, 737.0]], [[512.0, 602.0], [532.0, 602.0], [534.0, 719.0], [514.0, 719.0]], [[491.0, 603.0], [507.0, 603.0], [510.0, 758.0], [493.0, 758.0]]], "lines": ["今にあなたより", "目立つ存在に", "なってみせる：！！！"]}, {"box": [352, 582, 445, 744], "vertical": true, "font_size": 20, "lines_coords": [[[424.0, 584.0], [440.0, 584.0], [440.0, 719.0], [424.0, 719.0]], [[398.0, 582.0], [423.0, 582.0], [423.0, 660.0], [398.0, 660.0]], [[376.0, 583.0], [396.0, 583.0], [396.0, 700.0], [376.0, 700.0]], [[352.0, 583.0], [372.0, 583.0], [372.0, 744.0], [352.0, 744.0]]], "lines": ["学校が終わると", "私は駅へ", "行かなければ", "なりませんでした。"]}, {"box": [719, 1036, 735, 1099], "vertical": true, "font_size": 16, "lines_coords": [[[719.0, 1036.0], [735.0, 1036.0], [735.0, 1099.0], [719.0, 1099.0]]], "lines": ["．．．．．．？"]}, {"box": [70, 960, 165, 1096], "vertical": true, "font_size": 22, "