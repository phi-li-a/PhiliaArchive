6.0, 84.0], [416.0, 161.0], [399.0, 161.0]]], "lines": ["そうか！！"]}, {"box": [234, 63, 334, 162], "vertical": true, "font_size": 22, "lines_coords": [[[313.0, 63.0], [334.0, 63.0], [334.0, 162.0], [313.0, 162.0]], [[283.0, 65.0], [304.0, 65.0], [304.0, 161.0], [283.0, 161.0]], [[260.0, 63.0], [281.0, 63.0], [279.0, 160.0], [257.0, 160.0]], [[234.0, 63.0], [260.0, 63.0], [260.0, 125.0], [234.0, 125.0]]], "lines": ["きっ．．．君", "額だ．．．額に", "何を隠して", "いる！？"]}, {"box": [725, 437, 753, 482], "vertical": true, "font_size": 28, "lines_coords": [[[725.0, 437.0], [753.0, 437.0], [753.0, 482.0], [725.0, 482.0]]], "lines": ["額？"]}, {"box": [478, 420, 499, 499], "vertical": true, "font_size": 21, "lines_coords": [[[478.0, 420.0], [499.0, 420.0], [499.0, 499.0], [478.0, 499.0]]], "lines": ["傷の事？"]}, {"box": [463, 541, 508, 655], "vertical": true, "font_size": 20, "lines_coords": [[[487.0, 541.0], [507.0, 541.0], [507.0, 637.0], [487.0, 637.0]], [[465.0, 541.0], [485.0, 541.0], [483.0, 655.0], [463.0, 655.0]]], "lines": ["五島さんに", "聞いたのね？"]}, {"box": [383, 439, 430, 588], "vertical": true, "font_size": 22, "lines_coords": [[[406.0, 439.0], [430.0, 439.0], [427.0, 588.0], [404.0, 588.0]], [[385.0, 440.0], [406.0, 440.0], [404.0, 540.0], [383.0, 540.0]]], "lines": ["違う！傷なんか", "じゃない！！"]}, {"box": [80, 438, 149, 594], "vertical": true, "font_size": 20, "lines_coords": [[[128.0, 438.0], [148.0, 438.0], [148.0, 555.0], [128.0, 555.0]], [[105.0, 438.0], [125.0, 438.0], [125.0, 594.0], [105.0, 594.0]], [[80.0, 438.0], [100.0, 438.0], [100.0, 517.0], [80.0, 517.0]]], "lines": ["うずまきだ．．．", "うずまきの気配を", "感じる！！"]}, {"box": [692, 689, 755, 814], "vertical": true, "font_size": 19, "lines_coords": [[[735.0, 690.0], [755.0, 690.0], [752.0, 814.0], [732.0, 814.0]], [[714.0, 690.0], [733.0, 690.0], [731.0, 776.0], [711.0, 776.0]], [[692.0, 689.0], [714.0, 689.0], [714.0, 745.0], [692.0, 745.0]]], "lines": ["何言ってるの？", "三日月形の", "傷よ．．．"]}, {"box": [585, 689, 647, 834], "vertical": true, "font_size": 19, "line