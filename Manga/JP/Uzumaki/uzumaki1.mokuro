, "作作品は"]}], "img_path": "210.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [532, 114, 551, 135], "vertical": false, "font_size": 18, "lines_coords": [[[532.0, 117.0], [547.0, 114.0], [551.0, 132.0], [535.0, 135.0]]], "lines": ["え"]}, {"box": [456, 90, 476, 188], "vertical": true, "font_size": 17, "lines_coords": [[[456.0, 90.0], [473.0, 90.0], [474.0, 187.0], [457.0, 187.0]]], "lines": ["うずまき．．．"]}, {"box": [653, 329, 745, 467], "vertical": true, "font_size": 19, "lines_coords": [[[725.0, 330.0], [745.0, 330.0], [743.0, 430.0], [723.0, 430.0]], [[702.0, 331.0], [718.0, 331.0], [718.0, 466.0], [702.0, 466.0]], [[677.0, 332.0], [697.0, 332.0], [697.0, 450.0], [677.0, 450.0]], [[655.0, 329.0], [675.0, 329.0], [673.0, 430.0], [653.0, 430.0]]], "lines": ["それは何と", "ミステリアスな", "模様である事", "でしょう．．"]}, {"box": [109, 319, 229, 535], "vertical": true, "font_size": 20, "lines_coords": [[[209.0, 322.0], [229.0, 322.0], [226.0, 515.0], [206.0, 515.0]], [[184.0, 322.0], [205.0, 322.0], [202.0, 450.0], [181.0, 450.0]], [[157.0, 321.0], [177.0, 321.0], [177.0, 522.0], [157.0, 522.0]], [[134.0, 319.0], [154.0, 319.0], [152.0, 496.0], [132.0, 496.0]], [[110.0, 319.0], [130.0, 319.0], [128.0, 534.0], [109.0, 534.0]]], "lines": ["漫画『うずまき』の中で", "私、伊藤潤二は", "このミステリーに迫り、", "うずまきの謎を解明", "しょうと試みたのです！！"]}, {"box": [650, 630, 766, 774], "vertical": true, "font_size": 19, "lines_coords": [[[749.0, 633.0], [766.0, 633.0], [764.0, 727.0], [746.0, 727.0]], [[723.0, 632.0], [743.0, 632.0], [741.0, 774.0], [721.0, 774.0]], [[699.0, 630.0], [719.0, 630.0], [717.0, 767.0], [697.0, 767.0]], [[675.0, 631.0], [695.0, 631.0], [692.0, 767.0], [673.0, 767.0]], [[653.0, 631.0], [670.0, 631.0], [668.0, 711.0], [650.0, 711.0]]], "lines": ["うずまきの", "意味を知るには、", "うずまきをよく", "観察しなければ", "ならない"]}, {"box": [449, 626, 540, 803], "vertical": true, "font_size": 20, "lines_coords": [[[519.0, 630.0], [540.0, 630.0], [538.0, 752.0], [517.0, 752.0]], [[497.0, 626.0], [517.0, 626.0], [513.0, 766.0], [493.0, 766.0]], [[473.0, 628.0], [493.0, 628.0], [490.0, 803.0], [470.0, 803.0]], [[449.0, 629.0], [469.0, 629.0], [469.0, 726.0], [449.0, 726.0]]], "lines": ["手始めに私は、", "うずまき模様を", "じっと見つめてみる", "事にした！"]}, {"box": [270, 633, 397, 754], "vertical": true, "font_size": 22, "lines_coords": [[[377.0, 639.0], [393.0, 639.0], [393.0, 720.0], [377.0, 720.0]], [[354.0, 637.0], [371.0, 637.0], [369.0, 734.0], [351.0, 734.0]], [[328.0, 637.0], [348.0, 637.0], [348.0, 754.0], [328.0, 754.0]], [[297.0, 636.0], [321.0, 636.0], [321.0, 754.0], [297.0, 754.0]], [[270.0, 633.0], [301.0, 633.0], [301.0, 691.0], [270.0, 691.0]]], "lines": ["次に私は", "うずまきに", "関する文献を", "読み漁る事に", "した。"]}, {"box": [352, 796, 393, 860], "vertical": false, "font_size": 64, "lines_coords": [[[352.0, 796.0], [393.0, 796.0], [393.0, 860.0], [352.0, 860.0]]], "lines": ["ああはあはははいはいけないの"]}, {"box": [160, 744, 198, 776], "vertical": false, "font_size": 12, "lines_coords": [[[168.0, 744.0], [198.0, 767.0], [189.0, 776.0], [160.0, 753.0]]], "lines": ["みんなが"]}, {"box": [99, 692, 151, 734], "vertical": false, "font_size": 16.5, "lines_coords": [[[109.0, 721.0], [139.0, 693.0], [151.0, 706.0], [121.0, 734.0]], [[99.0, 710.0], [126.0, 692.0], [134.0, 705.0], [107.0, 723.0]]], "lines": ["それは．．．", "でも"]}, {"box": [208, 837, 218, 853], "vertical": false, "font_size": 16, "lines_coords": [[[208.0, 837.0], [218.0, 837.0], [218.0, 853.0], [208.0, 853.0]]], "lines": ["する"]}, {"box": [444, 965, 514, 1085], "vertical": true, "font_size": 21, "lines_coords": [[[491.0, 965.0], [514.0, 965.0], [512.0, 1085.0], [488.0, 1085.0]], [[469.0, 965.0], [488.0, 965.0], [486.0, 1064.0], [466.0, 1064.0]], [[444.0, 965.0], [465.0, 965.0], [465.0, 1045.0], [444.0, 1045.0]]], "lines": ["目がくらくら", "しただけで", "あった．．．"]}, {"box": [112, 935, 182, 1071], "vertical": true, "font_size": 22, "lines_coords": [[[159.0, 937.0], [182.0, 937.0], [182.0, 977.0], [159.0, 977.0]], [[134.0, 936.0], [157.0, 936.0], [157.0, 1052.0], [134.0, 1052.0]], [[112.0, 935.0], [132.0, 935.0], [132.0, 1071.0], [112.0, 1071.0]]], "lines": ["．．．？", "いつも途中で", "寝てしまった"]}], "img_path": "211.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [634, 83, 727, 215], "vertical": true, "font_size": 18, "lines_coords": [[[708.0, 84.0], [724.0, 84.0], [724.0, 195.0], [708.0, 195.0]], [[684.0, 84.0], [701.0, 84.0], [701.0, 179.0], [684.0, 179.0]], [[658.0, 84.0], [678.0, 84.0], [678.0, 215.0], [658.0, 215.0]], [[634.0, 83.0], [654.0, 83.0], [654.0, 202.0], [634.0, 202.0]]], "lines": ["やはり実際に", "うずまきを", "作ってみるしか", "ないようです。"]}, {"box": [396, 98, 429, 206], "vertical": true, "font_size": 29, "lines_coords": [[[396.0, 98.0], [425.0, 98.0], [427.0, 202.0], [398.0, 202.0]]], "lines": ["スッホ、"]}, {"box": [269, 87, 361, 264], "vertical": true, "font_size": 21, "lines_coords": [[[340.0, 90.0], [359.0, 90.0], [359.0, 187.0], [340.0, 187.0]], [[314.0, 87.0], [337.0, 87.0], [338.0, 264.0], [315.0, 264.0]], [[290.0, 89.0], [311.0, 89.0], [313.0, 246.0], [291.0, 246.0]], [[269.0, 90.0], [289.0, 90.0], [289.0, 206.0], [269.0, 206.0]]], "lines": ["風呂の水は", "ゴーッと渦を巻いて", "ただ流れ去るのみ", "であった．．．"]}, {"box": [658, 400, 704, 574], "vertical": true, "font_size": 20, "lines_coords": [[[682.0, 400.0], [703.0, 400.0], [704.0, 574.0], [683.0, 574.0]], [[658.0, 400.0], [678.0, 400.0], [680.0, 561.0], [660.0, 561.0]]], "lines": ["何もわからないので", "今度は食ってみた。"]}, {"box": [79, 391, 199, 473], "vertical": true, "font_size": 26, "lines_coords": [[[172.0, 391.0], [196.0, 391.0], [199.0, 473.0], [174.0, 473.0]], [[148.0, 392.0], [174.0, 392.0], [174.0, 454.0], [148.0, 454.0]], [[126.0, 392.0], [152.0, 392.0], [152.0, 452.0], [126.0, 452.0]], [[102.0, 391.0], [127.0, 392.0], [125.0, 471.0], [99.0, 469.0]], [[79.0, 392.0], [106.0, 392.0], [106.0, 451.0], [79.0, 451.0]]], "lines": ["ナルト巻", "守ロ巻", "ワラビ", "ゼンマイ", "サザエ"]}, {"box": [678, 754, 722, 870], "vertical": true, "font_size": 20, "lines_coords": [[[702.0, 755.0], [722.0, 755.0], [722.0, 870.0], [702.0, 870.0]], [[678.0, 754.0], [698.0, 754.0], [698.0, 857.0], [678.0, 857.0]]], "lines": ["カタツムリを", "飼ってみた。"]}, {"box": [518, 746, 588, 869], "vertical": true, "font_size": 21, "lines_coords": [[[567.0, 748.0], [588.0, 748.0], [585.0, 863.0], [563.0, 863.0]], [[542.0, 746.0], [563.0, 746.0], [561.0, 864.0], [540.0, 864.0]], [[520.0, 746.0], [540.0, 746.0], [538.0, 869.0], [518.0, 869.0]]], "lines": ["ニンジン色の", "うんこをした", "のみであった。"]}, {"box": [355, 774, 448, 987], "vertical": true, "font_size": 18, "lines_coords": [[[430.0, 778.0], [446.0, 778.0], [446.0, 987.0], [430.0, 987.0]], [[406.0, 778.0], [423.0, 778.0], [423.0, 973.0], [406.0, 973.0]], [[381.0, 775.0], [400.0, 775.0], [398.0, 933.0], [378.0, 933.0]], [[357.0, 774.0], [377.0, 774.0], [375.0, 951.0], [355.0, 951.0]]], "lines": ["そんなわけで謎の解明に", "着実に近づきつつあり、", "いずれ結果が報告", "できる事でしょう！"]}, {"box": [69, 528, 186, 685], "vertical": true, "font_size": 19, "lines_coords": [[[167.0, 530.0], [184.0, 530.0], [184.0, 664.0], [167.0, 664.0]], [[141.0, 529.0], [161.0, 529.0], [161.0, 685.0], [141.0, 685.0]], [[119.0, 532.0], [136.0, 532.0], [136.0, 645.0], [119.0, 645.0]], [[93.0, 530.0], [113.0, 530.0], [113.0, 665.0], [93.0, 665.0]], [[71.0, 528.0], [91.0, 528.0], [89.0, 651.0], [69.0, 651.0]]], "lines": ["うずまきアイス", "うずまきクッキー", "ねじりんぼう", "．．．．．．．いずれも", "うまかったあ。"]}, {"box": [116, 735, 136, 833], "vertical": true, "font_size": 20, "lines_coords": [[[116.0, 735.0], [136.0, 735.0], [136.0, 833.0], [116.0, 833.0]]], "lines": ["ほど遠い！！"]}, {"box": [34, 833, 77, 889], "vertical": true, "font_size": 23, "lines_coords": [[[53.0, 833.0], [77.0, 833.0], [77.0, 873.0], [53.0, 873.0]], [[34.0, 833.0], [56.0, 833.0], [56.0, 889.0], [34.0, 889.0]]], "lines": ["担当", "中熊氏"]}], "img_path": "212.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [400, 416, 413, 471], "vertical": true, "font_size": 13, "lines_coords": [[[400.0, 416.0], [413.0, 416.0], [413.0, 471.0], [400.0, 471.0]]], "lines": ["【印刷所】．．．"]}, {"box": [