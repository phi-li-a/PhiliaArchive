 [[20.0, 195.0], [796.0, 59.0], [856.0, 402.0], [80.0, 538.0]], [[310.0, 463.0], [1418.0, 467.0], [1418.0, 525.0], [310.0, 521.0]]], "lines": ["まぁ、", "林檎湖しく", "ヒックエックストリック調査をご完了アステムア"]}, {"box": [982, 169, 1639, 418], "vertical": false, "font_size": 214, "lines_coords": [[[982.0, 204.0], [1628.0, 169.0], [1639.0, 383.0], [993.0, 418.0]]], "lines": ["。美しい"]}, {"box": [1771, 608, 1879, 667], "vertical": false, "font_size": 23, "lines_coords": [[[1775.0, 610.0], [1878.0, 610.0], [1878.0, 636.0], [1775.0, 636.0]], [[1781.0, 644.0], [1865.0, 644.0], [1865.0, 664.0], [1781.0, 664.0]]], "lines": ["．．．", "．．．"]}], "img_path": "005.jpg"}, {"version": "0.1.7", "img_width": 1728, "img_height": 700, "blocks": [{"box": [258, 80, 1360, 188], "vertical": false, "font_size": 60.0, "lines_coords": [[[855.0, 80.0], [983.0, 80.0], [983.0, 109.0], [855.0, 109.0]], [[258.0, 97.0], [1360.0, 97.0], [1360.0, 188.0], [258.0, 188.0]]], "lines": ["当日、", "美しい女子高生五島桐絵のまわりで"]}, {"box": [227, 204, 1356, 646], "vertical": false, "font_size": 90.66666666666667, "lines_coords": [[[732.0, 215.0], [918.0, 220.0], [918.0, 251.0], [732.0, 246.0]], [[366.0, 209.0], [1277.0, 204.0], [1277.0, 306.0], [366.0, 312.0]], [[268.0, 312.0], [1356.0, 305.0], [1356.0, 413.0], [268.0, 420.0]], [[227.0, 425.0], [1112.0, 430.0], [1112.0, 522.0], [227.0, 517.0]], [[1093.0, 423.0], [1353.0, 423.0], [1353.0, 519.0], [1093.0, 519.0]], [[381.0, 531.0], [1236.0, 516.0], [1238.0, 630.0], [383.0, 646.0]]], "lines": ["る異常な", "次々に起こる異常な惨劇．．．", "そう、突然行うまきが襲ってるのだ．．．", "新感覚ホラーの鬼才「伊藤潤", "朝一が描く、", "出にも不思議な恐怖の世界。"]}], "img_path": "006.jpg"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [], "img_path": "007.jpg"}, {"version": "0.1.7", "img_width": 827, "img_height": 1200, "blocks": [{"box": [367, 188, 435, 702], "vertical": true, "font_size": 61, "lines_coords": [[[367.0, 189.0], [428.0, 188.0], [435.0, 600.0], [374.0, 601.0]]], "lines": ["うずき「伊藤"]}], "img_path": "008.jpg"}, {"version": "0.1.7", "img_width": 81