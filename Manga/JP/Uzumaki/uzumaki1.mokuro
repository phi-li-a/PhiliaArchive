, [239.0, 780.0], [239.0, 844.0], [214.0, 844.0]], [[192.0, 781.0], [213.0, 781.0], [213.0, 860.0], [192.0, 860.0]], [[168.0, 781.0], [188.0, 781.0], [188.0, 896.0], [168.0, 896.0]], [[144.0, 781.0], [164.0, 781.0], [164.0, 895.0], [144.0, 895.0]], [[121.0, 780.0], [141.0, 780.0], [141.0, 867.0], [121.0, 867.0]]], "lines": ["今にも", "崩れ落ち", "そうになって", "いるものまで", "様々です。"]}], "img_path": "147.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [72, 94, 154, 260], "vertical": true, "font_size": 24, "lines_coords": [[[128.0, 97.0], [154.0, 97.0], [154.0, 168.0], [128.0, 168.0]], [[102.0, 97.0], [123.0, 97.0], [123.0, 189.0], [102.0, 189.0]], [[72.0, 94.0], [96.0, 94.0], [96.0, 260.0], [72.0, 260.0]]], "lines": ["二度と", "会うなと", "言ったはずだ！！"]}, {"box": [369, 433, 466, 554], "vertical": true, "font_size": 23, "lines_coords": [[[435.0, 433.0], [466.0, 433.0], [466.0, 482.0], [435.0, 482.0]], [[416.0, 437.0], [436.0, 437.0], [436.0, 536.0], [416.0, 536.0]], [[392.0, 437.0], [412.0, 437.0], [412.0, 554.0], [392.0, 554.0]], [[369.0, 437.0], [389.0, 437.0], [389.0, 554.0], [369.0, 554.0]]], "lines": ["今度", "うちの娘を", "連れ出したら", "承知せんぞ！！"]}, {"box": [166, 425, 288, 544], "vertical": true, "font_size": 22, "lines_coords": [[[266.0, 427.0], [287.0, 427.0], [287.0, 529.0], [266.0, 529.0]], [[242.0, 426.0], [263.0, 426.0], [263.0, 503.0], [242.0, 503.0]], [[218.0, 426.0], [241.0, 426.0], [241.0, 544.0], [218.0, 544.0]], [[195.0, 428.0], [216.0, 428.0], [216.0, 506.0], [195.0, 506.0]], [[170.0, 425.0], [194.0, 426.0], [191.0, 527.0], [166.0, 526.0]]], "lines": ["お願いです、", "もう少し", "彼女と一緒に", "いさせて", "ください！"]}, {"box": [65, 437, 111, 515], "vertical": true, "font_size": 22, "lines_coords": [[[91.0, 439.0], [111.0, 439.0], [111.0, 515.0], [91.0, 515.0]], [[65.0, 437.0], [90.0, 437.0], [90.0, 500.0], [65.0, 500.0]]], "lines": ["ふざける", "なっ！！"]}, {"box": [563, 773, 726, 889], "vertical": true, "font_size": 23, "lines_coords": [[[707.0, 775.0], [726.0, 775.0], [726.0, 888.0], [707.0, 888.0]], [[683.0, 775.0], [703.0, 775.0], [703.0, 887.0], [683.0, 887.0]], [[658.0, 775.0], [680.0, 775.0], [680.0, 855.0], [658.0, 855.0]], [[636.0, 774.0], [656.0, 774.0], [656.0, 889.0], [636.0, 889.0]], [[610.0, 773.0], [630.0, 773.0], [630.0, 887.0], [610.0, 887.0]], [[586.0, 774.0], [610.0, 774.0], [610.0, 853.0], [586.0, 853.0]], [[563.0, 775.0], [585.0, 775.0], [585.0, 850.0], [563.0, 850.0]]], "lines": ["お前のような", "小汚い家族の", "せがれに、", "うちの大事な", "娘を近づける", "わけには", "いかん！！"]}, {"box": [447, 775, 527, 856], "vertical": true, "font_size": 23, "lines_coords": [[[500.0, 775.0], [527.0, 775.0], [527.0, 823.0], [500.0, 823.0]], [[479.0, 778.0], [500.0, 778.0], [500.0, 856.0], [479.0, 856.0]], [[447.0, 776.0], [478.0, 776.0], [478.0, 832.0], [447.0, 832.0]]], "lines": ["さあ", "帰るんだ", "依子。"]}, {"box": [350, 779, 418, 864], "vertical": true, "font_size": 22, "lines_coords": [[[393.0, 781.0], [418.0, 781.0], [418.0, 858.0], [393.0, 858.0]], [[369.0, 779.0], [393.0, 779.0], [393.0, 858.0], [369.0, 858.0]], [[350.0, 780.0], [366.0, 780.0], [366.0, 861.0], [350.0, 861.0]]], "lines": ["いやっ．．．", "放してよ", "お父さん"]}, {"box": [86, 1027, 113, 1098], "vertical": true, "font_size": 26, "lines_coords": [[[86.0, 1027.0], [112.0, 1027.0], [112.0, 1098.0], [86.0, 1098.0]]], "lines": ["依子！！"]}], "img_path": "148.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [660, 89, 751, 208], "vertical": true, "font_size": 20, "lines_coords": [[[731.0, 91.0], [751.0, 91.0], [751.0, 173.0], [731.0, 173.0]], [[708.0, 89.0], [729.0, 89.0], [726.0, 208.0], [705.0, 208.0]], [[684.0, 89.0], [705.0, 89.0], [702.0, 207.0], [681.0, 207.0]], [[662.0, 89.0], [682.0, 89.0], [680.0, 188.0], [660.0, 188.0]]], "lines": ["この野郎、", "俺の妹の名を", "気安く呼ぶん", "じゃねえ！！"]}, {"box": [701, 660, 771, 741], "vertical": true, "font_size": 24, "lines_coords": [[[746.0, 660.0], [771.0, 660.0], [771.0, 724.0], [746.0, 724.0]], [[722.0, 660.0], [746.0, 660.0], [746.0, 741.0], [722.0, 741.0]], [[701.0, 660.0], [725.0, 660.0], [725.0, 685.0], [701.0, 685.0]]], "lines": ["大丈夫", "ですか．．．", "？"]}, {"box": [543, 667, 558, 695], "vertical": true, "font_size": 15, "lines_coords": [[[543.0, 667.0], [558.0, 667.0], [558.0, 695.0], [543.0, 695.0]]], "lines": ["！"]}, {"box": [415, 663, 439, 725], "vertical": true, "font_size": 24, "lines_coords": [[[415.0, 663.0], [439.0, 663.0], [439.0, 725.0], [415.0, 725.0]]], "lines": ["あっ．．．"]}, {"box": [719, 877, 771, 1023], "vertical": true, "font_size": 22, "lines_coords": [[[746.0, 877.0], [771.0, 877.0], [771.0, 945.0], [746.0, 945.0]], [[719.0, 878.0], [739.0, 878.0], [739.0, 1021.0], [719.0, 1021.0]]], "lines": ["あなた、", "和典君じゃない。"]}, {"box": [418, 861, 513, 958], "vertical": true, "font_size": 24, "lines_coords": [[[487.0, 862.0], [513.0, 862.0], [513.0, 925.0], [487.0, 925.0]], [[461.0, 862.0], [491.0, 862.0], [491.0, 926.0], [461.0, 926.0]], [[443.0, 861.0], [463.0, 861.0], [460.0, 958.0], [440.0, 958.0]], [[418.0, 866.0], [439.0, 866.0], [439.0, 942.0], [418.0, 942.0]]], "lines": ["私よ．．", "桐絵．．．", "どうしたの", "一体．．．？"]}], "img_path": "149.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [652, 84, 721, 258], "vertical": true, "font_size": 20, "lines_coords": [[[694.0, 85.0], [718.0, 84.0], [721.0, 146.0], [696.0, 147.0]], [[673.0, 85.0], [692.0, 85.0], [695.0, 258.0], [675.0, 258.0]], [[653.0, 87.0], [669.0, 87.0], [669.0, 228.0], [653.0, 228.0]]], "lines": ["彼らは", "僕の住んでる長屋の", "同じ住人なんだ。"]}, {"box": [306, 82, 398, 182], "vertical": true, "font_size": 22, "lines_coords": [[[378.0, 85.0], [398.0, 85.0], [398.0, 180.0], [378.0, 180.0]], [[349.0, 82.0], [378.0, 82.0], [378.0, 147.0], [349.0, 147.0]], [[330.0, 85.0], [350.0, 85.0], [350.0, 182.0], [330.0, 182.0]], [[306.0, 85.0], [327.0, 85.0], [327.0, 165.0], [306.0, 165.0]]], "lines": ["同じ長屋の", "両端に", "住んでるん", "だけど．．．"]}, {"box": [70, 89, 162, 215], "vertical": true, "font_size": 21, "lines_coords": [[[141.0, 90.0], [161.0, 90.0], [161.0, 187.0], [141.0, 187.0]], [[118.0, 90.0], [138.0, 90.0], [138.0, 206.0], [118.0, 206.0]], [[91.0, 89.0], [116.0, 89.0], [116.0, 152.0], [91.0, 152.0]], [[70.0, 90.0], [90.0, 90.0], [90.0, 214.0], [70.0, 214.0]]], "lines": ["僕の家族と", "依子の家族は", "昔から", "仲が悪いんだ。"]}, {"box": [629, 528, 719, 664], "vertical": true, "font_size": 20, "lines_coords": [[[699.0, 529.0], [719.0, 529.0], [719.0, 609.0], [699.0, 609.0]], [[676.0, 528.0], [697.0, 528.0], [695.0, 664.0], [674.0, 664.0]], [[653.0, 530.0], [673.0, 530.0], [673.0, 646.0], [653.0, 646.0]], [[629.0, 530.0], [649.0, 530.0], [649.0, 628.0], [629.0, 628.0]]], "lines": ["でも僕と", "依子は、お互い", "好きになって", "しまった．．．"]}, {"box": [345, 523, 392, 649], "vertical": true, "font_size": 22, "lines_coords": [[[368.0, 523.0], [392.0, 523.0], [392.0, 585.0], [368.0, 585.0]], [[345.0, 523.0], [366.0, 523.0], [368.0, 649.0], [347.0, 649.0]]], "lines": ["本当に", "愛してるんだ。"]}, {"box": [641, 780, 729, 933], "vertical": true, "font_size": 16, "lines_coords": [[[711.0, 780.0], [729.0, 780.0], [728.0, 915.0], [710.0, 915.0]], [[688.0, 781.0], [704.0, 781.0], [704.0, 878.0], [688.0, 878.0]], [[664.0, 781.0], [681.0, 781.0], [681.0, 932.0], [664.0, 932.0]], [[641.0, 780.0], [656.0, 780.0], [656.0, 896.0], [641.0, 896.0]]], "lines": ["今までいろいろ", "努力した．．．", "２人の仲を認めて", "もらおうと．．．"]}, {"box": [490, 795, 537, 875], "vertical": true, "font_size": 22, "lines_coords": [[[517.0, 795.0], [537.0, 795.0], [537.0, 875.0], [517.0, 875.0]], [[492.0, 795.0], [517.0, 796.0], [514.0, 875.0], [490.0, 874.0]]], "lines": ["でも無駄", "だった．．"]}, {"box": [311, 791, 326, 834], "vertical": true, "font_size": 15, "lines_coords": [[[311.0, 791.0], [326.0, 791.0], [326.0, 834.0], [311.0, 834.0]]], "lines": ["．．．"]}, {"box": [67, 567, 133, 742], "vertical": true, "font_size": 19, "lines_coords": [[[111.0, 567.0], [132.0, 567.0], [133.0, 648.0], [112.0, 648.0]], [[87.0, 567.0], [107.0, 567.0], [109.0, 742.0], [89.0, 742.0]], [[68.0, 568.0], [84.0, 568.0], [84.0, 730.0], [68.0, 730.0]]], "lines": ["だけど．．．", "お互いの家がそれを", "認めるはずがない。"]}, {"box": [73, 810, 127, 1053], "vertical": true, "font_size": 22, "lines_coords": [[[97.0, 812.0], [120.0, 812.0], [120.0, 1005.0], [97.0, 1005.0]], [[73.0, 810.0], [93.0, 810.0], [96.0, 1052.0], [76.0, 1052.0]]], "lines": ["．．．西木和典君は、私の", "小・中学時代の同級生です。"]}], "img_path": "150.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [646, 87, 767, 231], "vertical": true, "font_size": 20, "lines_coords": [[[746.0, 90.0], [764.0, 90.0], [765.0, 225.0], [748.0, 225.0]], [[721.0, 87.0], [744.0, 87.0], [744.0, 229.0], [721.0, 229.0]], [[698.0, 89.0], [718.0, 89.0], [718.0, 225.0], [698.0, 225.0]], [[669.0, 89.0], [689.0, 89.0], [689.0, 203.0], [669.0, 203.0]], [[646.0, 90.0], [665.0, 90.0], [665.0, 171.0], [646.0, 171.0]]], "lines": ["彼の住んでいる", "長屋というのは、", "もともとは例の", "廃屋のひとつ", "でしたが"]}, {"box": [126, 125, 220, 290], "vertical": true, "font_size": 21, "lines_coords": [[[196.0, 125.0], [220.0, 125.0], [220.0, 290.0], [196.0, 290.0]], [[173.0, 125.0], [194.0, 125.0], [195.0, 248.0], [174.0, 248.0]], [[151.0, 127.0], [171.0, 127.0], [171.0, 242.0], [151.0, 242.0]], [[126.0, 125.0], [146.0, 125.0], [147.0, 288.0], [127.0, 288.0]]], "lines": ["比較的保存状態が", "良かったので、", "地主が貸家に", "改造したものです。"]}, {"box": [637, 345, 755, 527], "vertical": true, "font_size": 20, "lines_coords": [[[735.0, 349.0], [755.0, 349.0], [755.0, 464.0], [735.0, 464.0]], [[710.0, 349.0], [730.0, 349.0], [730.0, 483.0], [710.0, 483.0]], [[687.0, 349.0], [707.0, 349.0], [707.0, 486.0], [687.0, 486.0]], [[664.0, 346.0], [684.0, 346.0], [681.0, 483.0], [661.0, 483.0]], [[639.0, 345.0], [660.0, 345.0], [658.0, 523.0], [637.0, 523.0]]], "lines": ["小学生時代に", "和典君の家族が", "越してきたほか、", "何組かの家族が", "入っているのですが、"]}, {"box": [389, 563, 418, 616], "vertical": true, "font_size": 27, "lines_coords": [[[389.0, 564.0], [416.0, 563.0], [418.0, 615.0], [391.0, 616.0]]], "lines": ["えっ、"]}, {"box": [123, 352, 238, 515], "vertical": true, "font_size": 19, "lines_coords": [[[216.0, 355.0], [236.0, 355.0], [236.0, 491.0], [216.0, 491.0]], [[193.0, 353.0], [213.0, 353.0], [211.0, 512.0], [191.0, 512.0]], [[171.0, 356.0], [187.0, 356.0], [187.0, 451.0], [171.0, 451.0]], [[144.0, 352.0], [165.0, 352.0], [164.0, 509.0], [143.0, 509.0]], [[124.0, 352.0], [140.0, 352.0], [140.0, 438.0], [124.0, 438.0]]], "lines": ["町の人達からは", "貧乏長屋と呼ばれ", "特別な目で", "見られているのも", "事実です。"]}, {"box": [711, 573, 774, 658], "vertical": true, "font_size": 18, "lines_coords": [[[732.0, 573.0], [752.0, 573.0], [752.0, 651.0], [732.0, 651.0]], [[711.0, 573.0], [728.0, 573.0], [728.0, 656.0], [711.0, 656.0]]], "lines": ["ねじれて", "るんだよ"]}, {"box": [724, 775, 768, 880], "vertical": true, "font_size": 18, "lines_coords": [[[748.0, 775.0], [767.0, 775.0], [765.0, 873.0], [745.0, 873.0]], [[725.0, 778.0], [742.0, 778.0], [742.0, 877.0], [725.0, 877.0]]], "lines": ["僕と依子の", "家族の事さ。"]}, {"box": [413, 778, 459, 862], "vertical": true, "font_size": 23, "lines_coords": [[[433.0, 778.0], [459.0, 778.0], [459.0, 840.0], [433.0, 840.0]], [[413.0, 778.0], [433.0, 778.0], [433.0, 861.0], [413.0, 861.0]]], "lines": ["依子は", "別として、"]}, {"box": [307, 787, 376, 990], "vertical": true, "font_size": 20, "lines_coords": [[[354.0, 787.0], [375.0, 787.0], [376.0, 931.0], [355.0, 931.0]], [[330.0, 789.0], [350.0, 789.0], [350.0, 944.0], [330.0, 944.0]], [[307.0, 788.0], [327.0, 788.0], [327.0, 990.0], [307.0, 990.0]]], "lines": ["きっと．．．みんな、", "今の貧しい状態を", "受け入れられないんだ。"]}, {"box": [109, 672, 133, 737], "vertical": true, "font_size": 24, "lines_coords": [[[109.0, 672.0], [133.0, 672.0], [133.0, 737.0], [109.0, 737.0]]], "lines": ["何が？"]}, {"box": [411, 990, 478, 1095], "vertical": true, "font_size": 20, "lines_coords": [[[457.0, 990.0], [478.0, 990.0], [476.0, 1086.0], [454.0, 1086.0]], [[433.0, 990.0], [454.0, 990.0], [454.0, 1051.0], [433.0, 1051.0]], [[411.0, 990.0], [427.0, 990.0], [427.0, 1094.0], [411.0, 1094.0]]], "lines": ["みんな心が", "ひどく", "ねじれてる。"]}, {"box": [106, 903, 175, 1098], "vertical": true, "font_size": 21, "lines_coords": [[[152.0, 903.0], [175.0, 903.0], [173.0, 1098.0], [150.0, 1098.0]], [[130.0, 904.0], [150.0, 904.0], [147.0, 1059.0], [127.0, 1059.0]], [[106.0, 904.0], [126.0, 904.0], [126.0, 990.0], [106.0, 990.0]]], "lines": ["だから、ねじれるしか", "自分を守る方法が", "ないんだ。"]}], "img_path": "151.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [627, 85, 719, 281], "vertical": true, "font_size": 20, "lines_coords": [[[699.0, 86.0], [719.0, 86.0], [719.0, 182.0], [699.0, 182.0]], [[676.0, 86.0], [696.0, 86.0], [696.0, 240.0], [676.0, 240.0]], [[650.0, 85.0], [670.0, 85.0], [670.0, 228.0], [650.0, 228.0]], [[627.0, 85.0], [647.0, 85.0], [648.0, 281.0], [628.0, 281.0]]], "lines": ["そして心の", "ねじれた者同士が", "ぶつかり合うと、", "お互いからみ合って．．．"]}, {"box": [316, 87, 409, 300], "vertical": true, "font_size": 20, "lines_coords": [[[389.0, 87.0], [409.0, 87.0], [409.0, 244.0], [389.0, 244.0]], [[364.0, 87.0], [384.0, 87.0], [384.0, 263.0], [364.0, 263.0]], [[340.0, 87.0], [359.0, 87.0], [359.0, 300.0], [340.0, 300.0]], [[316.0, 89.0], [336.0, 89.0], [336.0, 214.0], [316.0, 214.0]]], "lines": ["くんずほぐれつ．．．", "もう収拾がつかなく", "なって、ときはぐすのは", "不可能なんだ。"]}, {"box": [71, 96, 138, 289], "vertical": true, "font_size": 19, "lines_coords": [[[116.0, 96.0], [137.0, 96.0], [138.0, 289.0], [117.0, 289.0]], [[93.0, 97.0], [113.0, 97.0], [113.0, 271.0], [93.0, 271.0]], [[71.0, 98.0], [87.0, 98.0], [87.0, 270.0], [71.0, 270.0]]], "lines": ["でも；ねじれてるって", "．．．和典君はねじれて", "なんかいないわよ！！"]}, {"box": [504, 383, 720, 500], "vertical": true, "font_size": 24, "lines_coords": [[[698.0, 386.0], [719.0, 386.0], [719.0, 469.0], [698.0, 469.0]], [[676.0, 386.0], [697.0, 386.0], [697.0, 465.0], [676.0, 465.0]], [[650.0, 385.0], [670.0, 385.0], [673.0, 500.0], [653.0, 500.0]], [[626.0, 385.0], [651.0, 385.0], [651.0, 447.0], [626.0, 447.0]], [[605.0, 387.0], [624.0, 387.0], [624.0, 487.0], [605.0, 487.0]], [[574.0, 383.0], [607.0, 383.0], [607.0, 431.0], [574.0, 431.0]], [[552.0, 384.0], [576.0, 384.0], [579.0, 466.0], [554.0, 466.0]], [[533.0, 387.0], [553.0, 387.0], [553.0, 485.0], [533.0, 485.0]], [[504.0, 384.0], [535.0, 384.0], [535.0, 419.0], [504.0, 419.0]]], "lines": ["それに昔、", "秀一君と", "あなたの家へ", "遊びに", "行ったけど、", "別に", "家族の人", "普通だった", "わ。"]}, {"box": [370, 398, 441, 574], "vertical": true, "font_size": 20, "lines_coords": [[[418.0, 398.0], [439.0, 398.0], [440.0, 553.0], [419.0, 553.0]], [[393.0, 399.0], [413.0, 399.0], [412.0, 574.0], [392.0, 574.0]], [[370.0, 399.0], [390.0, 399.0], [390.0, 523.0], [370.0, 523.0]]], "lines": ["子供には、大人の", "ドロドロしたものは", "見えないのさ。"]}, {"box": [68, 399, 137, 575], "vertical": true, "font_size": 20, "lines_coords": [[[112.0, 399.0], [137.0, 399.0], [137.0, 462.0], [112.0, 462.0]], [[90.0, 400.0], [110.0, 400.0], [111.0, 575.0], [91.0, 575.0]], [[69.0, 403.0], [85.0, 403.0], [85.0, 562.0], [69.0, 562.0]]], "lines": ["それに", "最近になってさらに", "ひどくなったんだ。"]}, {"box": [633, 697, 728, 781], "vertical": true, "font_size": 24, "lines_coords": [[[702.0, 697.0], [728.0, 698.0], [725.0, 762.0], [699.0, 761.0]], [[681.0, 700.0], [702.0, 700.0], [702.0, 780.0], [681.0, 780.0]], [[655.0, 699.0], [680.0, 699.0], [680.0, 781.0], [655.0, 781.0]], [[633.0, 699.0], [658.0, 699.0], [658.0, 753.0], [633.0, 753.0]]], "lines": ["さあ．．．", "そろそろ", "帰らなく", "ちゃ。"]}, {"box": [506, 699, 552, 780], "vertical": true, "font_size": 23, "lines_coords": [[[527.0, 699.0], [552.0, 699.0], [552.0, 780.0], [527.0, 780.0]], [[506.0, 699.0], [527.0, 699.0], [527.0, 778.0], [506.0, 778.0]]], "lines": ["大丈夫？", "立てる？"]}, {"box": [288, 693, 337, 775], "vertical": true, "font_size": 24, "lines_coords": [[[309.0, 693.0], [337.0, 693.0], [337.0, 740.0], [309.0, 740.0]], [[288.0, 696.0], [309.0, 696.0], [310.0, 775.0], [289.0, 775.0]]], "lines": ["あ．．．", "危ない！"]}, {"box": [501, 1031, 521, 1097], "vertical": true, "font_size": 20, "lines_coords": [[[501.0, 1032.0], [521.0, 1032.0], [521.0, 1096.0], [501.0, 1096.0]]], "lines": ["．．．ああ。"]}, {"box": [76, 969, 170, 1107], "vertical": true, "font_size": 22, "lines_coords": [[[145.0, 969.0], [170.0, 969.0], [170.0, 1069.0], [145.0, 1069.0]], [[121.0, 971.0], [143.0, 971.0], [145.0, 1068.0], [124.0, 1068.0]], [[97.0, 970.0], [120.0, 970.0], [123.0, 1107.0], [99.0, 1107.0]], [[76.0, 972.0], [93.0, 972.0], [94.0, 1057.0], [77.0, 1057.0]]], "lines": ["結局、私は", "彼を家まで", "送っていく事に", "しました"]}], "img_path": "152.jpg"}, {"version": "0.1.7", "img_width": 841, "img_height": 1200, "blocks": [{"box": [678, 83, 768, 220], "vertical": true, "font_size": 19, "lines_coords": [[[748.0, 85.0], [768.0, 85.0], [768.0, 191.0], [748.0, 191.0]], [[722.0, 85.0], [742.0, 85.0], [744.0, 201.0], [725.0, 201.0]], [[699.0, 83.0], [719.0, 83.0], [722.0, 220.0], [702.0, 220.0]], [[678.0, 85.0], [694.0, 85.0], [694.0, 161.0], [678.0, 161.0]]], "lines": ["和典！もう", "遠藤の娘には", "会うなと言った", "だろう！！"]}, {"box": [281, 63, 375, 132], "vertical": true, "font_size": 26, "lines_coords": [[[350.0, 64.0], [375.0, 64.0], [375.0, 127.0], [350.0, 127.0]], [[325.0, 63.0], [354.0, 63.0], [354.0, 128.0], [325.0, 128.0]], [[303.0, 64.0], [329.0, 64.0], [329.0, 126.0], [303.0, 126.0]], [[281.0, 64.0], [305.0, 64.0], [305.0, 132.0], [281.0, 132.0]]], "lines": ["それに", "しても", "遠藤の", "やつら、"]}, {"box": [113, 55, 183, 173], "vertical": true, "font_size": 20, "lines_coords": [[[161.0, 57.0], [182.0, 57.0], [182.0, 135.0], [161.0, 135.0]], [[139.0, 55.0], [159.0, 55.0], [159.0, 134.0], [139.0, 134.0]], [[115.0, 55.0], [135.0, 55.0], [133.0, 173.0], [113.0, 173.0]]], "lines": ["おのれ．．", "どうして", "くれようか．．．"]}, {"box": [695, 451, 766, 548], "vertical": true, "font_size": 23, "lines_coords": [[[744.0, 451.0], [766.0, 451.0], [766.0, 529.0], [744.0, 529.0]], [[720.0, 452.0], [741.0, 452.0], [741.0, 548.0], [720.0, 548.0]], [[695.0, 451.0], [720.0, 451.0], [720.0, 513.0], [695.0, 513.0]]], "lines": ["痛かった", "だろうねえ", "和典．．．"]}, {"box": [566, 451, 637, 566], "vertical": true, "font_size": 25, "lines_coords": [[[610.0, 451.0], [637.0, 451.0], [637.0, 512.0], [610.0, 512.0]], [[586.0, 451.0], [613.0, 451.0], [613.0, 512.0], [586.0, 512.0]], [[566.0, 452.0], [586.0, 452.0], [586.0, 566.0], [566.0, 566.0]]], "lines": ["遠藤の", "長男が", "殴ったのね！？"]}, {"box": [627, 558, 685, 619], "vertical": true, "font_size": 19, "lines_coords": [[[662.0, 558.0], [685.0, 558.0], [685.0, 597.0], [662.0, 597.0]], [[646.0, 558.0], [662.0, 558.0], [662.0, 619.0], [646.0, 619.0]], [[627.0, 558.0], [645.0, 558.0], [645.0, 614.0], [627.0, 614.0]]], "lines": ["イテ、", "イタイヨ", "母さん。"]}, {"box": [525, 276, 591, 411], "vertical": true, "font_size": 19, "lines_coords": [[[570.0, 276.0], [590.0, 276.0], [591.0, 411.0], [571.0, 411.0]], [[544.0, 276.0], [564.0, 276.0], [566.0, 373.0], [547.0, 373.0]], [[525.0, 278.0], [542.0, 278.0], [542.0, 411.0], [525.0, 411.0]]], "lines": ["それで殴られて", "無抵抗とは", "情けない奴だ！！"]}, {"box": [398, 464, 517, 562], "vertical": true, "font_size": 23, "lines_coords": [[[493.0, 465.0], [517.0, 465.0], [517.0, 544.0], [493.0, 544.0]], [[472.0, 466.0], [491.0, 466.0], [491.0, 562.0], [472.0, 562.0]], [[445.0, 464.0], [470.0, 464.0], [470.0, 526.0], [445.0, 526.0]], [[425.0, 465.0], [445.0, 465.0], [445.0, 542.0], [425.0, 542.0]], [[398.0, 464.0], [424.0, 464.0], [424.0, 530.0], [398.0, 530.0]]], "lines": ["ホントに", "あの遠藤ん", "とこの", "ゴロツキ", "息子は、"]}, {"box": [115, 471, 230, 588], "vertical": true, "font_size": 20, "lines_coords": [[[209.0, 472.0], [229.0, 472.0], [229.0, 569.0], [209.0, 569.0]], [[185.0, 472.0], [206.0, 472.0], [206.0, 550.0], [185.0, 550.0]], [[160.0, 471.0], [181.0, 471.0], [182.0, 557.0], [161.0, 557.0]], [[138.0, 472.0], [158.0, 472.0], [158.0, 588.0], [138.0, 588.0]], [[115.0, 473.0], [132.0, 473.0], [132.0, 568.0], [115.0, 568.0]]], "lines": ["昼間っから", "ろくな事", "しないで、", "害虫みたいな", "やっだね！！"]}, {"box": [714, 801, 762, 942], "vertical": true, "font_size": 22, "lines_coords": [[[740.0, 801.0], [761.0, 801.0], [762.0, 942.0], [741.0, 942.0]], [[714.0, 801.0], [736.0, 801.0], [737.0, 880.0], [715.0, 880.0]]], "lines": ["るっせーババア、",