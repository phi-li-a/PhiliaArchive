.0], [330.0, 878.0]]], "lines": ["無視の", "しかたも", "堂に入った", "ものでした。"]}, {"box": [59, 548, 132, 667], "vertical": true, "font_size": 24, "lines_coords": [[[104.0, 548.0], [132.0, 548.0], [132.0, 595.0], [104.0, 595.0]], [[82.0, 549.0], [105.0, 549.0], [105.0, 667.0], [82.0, 667.0]], [[59.0, 550.0], [79.0, 550.0], [79.0, 667.0], [59.0, 667.0]]], "lines": ["でも", "きれいだから", "当然かしら．．"]}, {"box": [215, 1017, 284, 1103], "vertical": true, "font_size": 21, "lines_coords": [[[262.0, 1017.0], [284.0, 1017.0], [284.0, 1064.0], [262.0, 1064.0]], [[239.0, 1018.0], [260.0, 1018.0], [260.0, 1096.0], [239.0, 1096.0]], [[215.0, 1018.0], [235.0, 1018.0], [235.0, 1103.0], [215.0, 1103.0]]], "lines": ["あら、", "そんな事", "ないわよ。"]}], "img_path": "084.jpg"}, {"version": "0.1.7", "img_width": 841, "img_height": 1200, "blocks": [{"box": [666, 91, 758, 295], "vertical": true, "font_size": 19, "lines_coords": [[[736.0, 92.0], [756.0, 92.0], [756.0, 295.0], [736.0, 295.0]], [[713.0, 93.0], [733.0, 93.0], [733.0, 285.0], [713.0, 285.0]], [[688.0, 91.0], [709.0, 91.0], [708.0, 246.0], [687.0, 246.0]], [[668.0, 92.0], [685.0, 92.0], [682.0, 289.0], [666.0, 289.0]]], "lines": ["しかし、しばらくすると", "彼女に対する、あまり", "よくない噂が耳に", "入るようになりました。"]}, {"box": [651, 464, 769, 587], "vertical": true, "font_size": 21, "lines_coords": [[[750.0, 467.0], [767.0, 467.0], [767.0, 587.0], [750.0, 587.0]], [[726.0, 464.0], [746.0, 464.0], [743.0, 573.0], [723.0, 573.0]], [[701.0, 466.0], [721.0, 466.0], [721.0, 563.0], [701.0, 563.0]], [[678.0, 467.0], [698.0, 467.0], [698.0, 581.0], [678.0, 581.0]], [[651.0, 464.0], [678.0, 464.0], [678.0, 508.0], [651.0, 508.0]]], "lines": ["ねえ桐絵さん、", "あなたまだ", "黒谷さんと", "つきあってる", "の？"]}, {"box": [547, 468, 599, 533], "vertical": true, "font_size": 28, "lines_coords": [[[573.0, 469.0], [599.0, 469.0], [599.0, 533.0], [573.0, 533.0]], [[547.0, 468.0], [576.0, 468.0], [576.0, 533.0], [547.0, 533.0]]], "lines": ["えっ．．．", "ええ．．"]}, {"box": [270, 464, 385, 561], "vertical": true, "font_size": 22, "lines_coords": [[[365.0, 465.0], [385.0, 465.0], [385.0, 543.0], [365.0, 543.0]], [[337.0, 464.0], [365.0, 464.0], [365.0, 514.0], [337.0, 514.0]], [[317.0, 466.0], [337.0, 466.0], [337.0, 543.0], [317.0, 543.0]], [[292.0, 466.0], [313.0, 466.0], [313.0, 561.0], [292.0, 561.0]], [[270.0, 467.0], [290.0, 467.0], [290.0, 553.0], [270.0, 553.0]]], "lines": ["もう彼女", "とは、", "つきあわ", "ないほうが", "いいわよ。"]}, {"box": [184, 465, 222, 543], "vertical": true, "font_size": 20, "lines_coords": [[[202.0, 465.0], [222.0, 465.0], [222.0, 543.0], [202.0, 543.0]]], "lines": ["どうして"]}, {"box": [708, 776, 775, 863], "vertical": true, "font_size": 23, "lines_coords": [[[755.0, 779.0], [775.0, 779.0], [775.0, 855.0], [755.0, 855.0]], [[728.0, 776.0], [756.0, 776.0], [756.0, 823.0], [728.0, 823.0]], [[708.0, 780.0], [729.0, 780.0], [729.0, 863.0], [708.0, 863.0]]], "lines": ["よくない", "評判", "聞くもの。"]}, {"box": [401, 786, 491, 938], "vertical": true, "font_size": 20, "lines_coords": [[[470.0, 787.0], [491.0, 787.0], [491.0, 864.0], [470.0, 864.0]], [[446.0, 786.0], [467.0, 786.0], [468.0, 938.0], [447.0, 938.0]], [[421.0, 786.0], [442.0, 786.0], [445.0, 936.0], [424.0, 936.0]], [[401.0, 788.0], [418.0, 788.0], [418.0, 889.0], [401.0, 889.0]]], "lines": ["彼女って", "あの美貌で数々の", "男を惑わせてるっ", "ていうもの"]}, {"box": [234, 780, 371, 877], "vertical": true, "font_size": 20, "lines_coords": [[[354.0, 781.0], [371.0, 781.0], [371.0, 862.0], [354.0, 862.0]], [[329.0, 781.0], [349.0, 781.0], [349.0, 857.0], [329.0, 857.0]], [[304.0, 781.0], [324.0, 781.0], [324.0, 858.0], [304.0, 858.0]], [[278.0, 781.0], [303.0, 781.0], [303.0, 858.0], [278.0, 858.0]], [[257.0, 780.0], [277.0, 780.0], [277.0, 876.0], [257.0, 876.0]], [[234.0, 781.0], [255.0, 781.0], [255.0, 849.0], [234.0, 849.0]]], "lines": ["そうそう、", "彼女には", "不思議な", "パワーが", "あるんです", "ってよ。"]}, {"box": [120, 792, 164, 869], "vertical": true, "font_size": 20, "lines_coords": [[[142.0, 792.0], [163.0, 792.0], [163.0, 869.0], [142.0, 869.0]], [[120.0, 793.0], [140.0, 793.0], [140.0, 869.0], [120.0, 869.0]]], "lines": ["不思議な", "パワー？"]}, {"box": [400, 1001, 466, 1143], "vertical": true, "font_size": 17, "lines_coords": [[[448.0, 1001.0], [465.0, 1001.0], [465.0, 1095.0], [448.0, 1095.0]], [[425.0, 1001.0], [441.0, 1001.0], [441.0, 1134.0], [425.0, 1134.0]], [[401.0, 1001.0], [418.0, 1001.0], [418.0, 1143.0], [401.0, 1143.0]]], "lines": ["そして男は", "ふぬけにされて", "捨てられるって。"]}], "img_path": "085.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [675, 73, 749, 212], "vertical": true, "font_size": 20, "lines_coords": [[[728.0, 75.0], [749.0, 75.0], [749.0, 135.0], [728.0, 135.0]], [[703.0, 73.0], [723.0, 73.0], [724.0, 212.0], [704.0, 212.0]], [[677.0, 73.0], [702.0, 73.0], [699.0, 155.0], [675.0, 155.0]]], "lines": ["そう！", "男を引きつける", "パワー．．．"]}, {"box": [583, 65, 648, 240], "vertical": true, "font_size": 20, "lines_coords": [[[631.0, 67.0], [648.0, 67.0], [648.0, 240.0], [631.0, 240.0]], [[607.0, 65.0], [627.0, 65.0], [624.0, 185.0], [605.0, 185.0]], [[583.0, 66.0], [600.0, 66.0], [600.0, 172.0], [583.0, 172.0]]], "lines": ["その秘密はどうやら", "おでこにある", "らしいわよ。"]}, {"box": [423, 70, 541, 227], "vertical": true, "font_size": 20, "lines_coords": [[[517.0, 70.0], [540.0, 70.0], [540.0, 189.0], [517.0, 189.0]], [[494.0, 70.0], [514.0, 70.0], [514.0, 215.0], [494.0, 215.0]], [[470.0, 71.0], [490.0, 71.0], [490.0, 150.0], [470.0, 150.0]], [[445.0, 70.0], [466.0, 70.0], [465.0, 227.0], [444.0, 227.0]], [[424.0, 72.0], [440.0, 72.0], [440.0, 198.0], [424.0, 198.0]]], "lines": ["彼女、前髪で", "わからないけど、", "おでこに", "ちょっとした傷が", "あるらしいの。"]}, {"box": [239, 66, 315, 176], "vertical": true, "font_size": 23, "lines_coords": [[[286.0, 66.0], [315.0, 66.0], [315.0, 132.0], [286.0, 132.0]], [[262.0, 71.0], [283.0, 71.0], [283.0, 169.0], [262.0, 169.0]], [[239.0, 70.0], [259.0, 70.0], [259.0, 175.0], [239.0, 175.0]]], "lines": ["それが", "パワーの源", "らしいのよ。"]}, {"box": [58, 266, 73, 310], "vertical": true, "font_size": 15, "lines_coords": [[[58.0, 266.0], [73.0, 266.0], [73.0, 310.0], [58.0, 310.0]]], "lines": ["．．．"]}, {"box": [386, 461, 455, 568], "vertical": true, "font_size": 22, "lines_coords": [[[432.0, 462.0], [453.0, 462.0], [453.0, 546.0], [432.0, 546.0]], [[409.0, 461.0], [433.0, 461.0], [433.0, 541.0], [409.0, 541.0]], [[386.0, 462.0], [406.0, 462.0], [406.0, 568.0], [386.0, 568.0]]], "lines": ["五島さん、", "チャイム", "鳴ったわよ。"]}, {"box": [105, 294, 228, 419], "vertical": true, "font_size": 22, "lines_coords": [[[202.0, 295.0], [228.0, 295.0], [228.0, 358.0], [202.0, 358.0]], [[181.0, 296.0], [201.0, 296.0], [201.0, 419.0], [181.0, 419.0]], [[158.0, 295.0], [178.0, 295.0], [178.0, 414.0], [158.0, 414.0]], [[132.0, 294.0], [153.0, 294.0], [154.0, 414.0], [133.0, 414.0]], [[105.0, 295.0], [130.0, 294.0], [132.0, 364.0], [107.0, 365.0]]], "lines": ["だから", "気をつけないと、", "あなたも彼氏", "とられちゃう", "かもよ。"]}, {"box": [69, 466, 116, 574], "vertical": true, "font_size": 23, "lines_coords": [[[91.0, 467.0], [116.0, 467.0], [116.0, 529.0], [91.0, 529.0]], [[69.0, 466.0], [90.0, 466.0], [92.0, 574.0], [71.0, 574.0]]], "lines": ["教室に", "戻りましょ。"]}, {"box": [69, 757, 111, 863], "vertical": true, "font_size": 16, "lines_coords": [[[93.0, 759.0], [110.0, 759.0], [110.0, 842.0], [93.0, 842.0]], [[69.0, 759.0], [85.0, 759.0], [85.0, 860.0], [69.0, 860.0]]], "lines": ["え．．．ええ、", "あざみさん。"]}], "img_path": "086.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [746, 92, 772, 145], "vertical": true, "font_size": 26, "lines_coords": [[[746.0, 92.0], [772.0, 92.0], [772.0, 145.0], [746.0, 145.0]]], "lines": ["ふう。"]}, {"box": [612, 77, 663, 160], "vertical": true, "font_size": 27, "lines_coords": [[[640.0, 79.0], [663.0, 79.0], [661.0, 160.0], [637.0, 160.0]], [[612.0, 77.0], [642.0, 77.0], [642.0, 132.0], [612.0, 132.0]]], "lines": ["さっぱり", "した。"]}, {"box": [754, 482, 769, 526], "vertical": true, "font_size": 15, "lines_coords": [[[754.0, 482.0], [769.0, 482.0], [769.0, 526.0], [754.0, 526.0]]], "lines": ["．．．．．"]}, {"box": [420, 476, 464, 526], "vertical": true, "font_size": 32, "lines_coords": [[[432.0, 476.0], [464.0, 476.0], [464.0, 526.0], [432.0, 526.0]]], "lines": ["ああ"]}, {"box": [293, 465, 340, 546], "vertical": true, "font_size": 24, "lines_coords": [[[318.0, 468.0], [340.0, 468.0], [340.0, 546.0], [318.0, 546.0]], [[293.0, 465.0], [320.0, 465.0], [320.0, 517.0], [293.0, 517.0]]], "lines": ["この傷の", "事ね。"]}, {"box": [730, 639, 771, 758], "vertical": true, "font_size": 18, "lines_coords": [[[751.0, 639.0], [771.0, 639.0], [771.0, 758.0], [751.0, 758.0]], [[730.0, 643.0], [746.0, 643.0], [746.0, 725.0], [730.0, 725.0]]], "lines": ["どうしたの？", "五島さん"]}, {"box": [492, 643, 513, 703], "vertical": true, "font_size": 21, "lines_coords": [[[492.0, 643.0], [513.0, 643.0], [513.0, 703.0], [492.0, 703.0]]], "lines": ["えっ．．．"]}, {"box": [284, 869, 310, 921], "vertical": true, "font_size": 26, "lines_coords": [[[284.0, 869.0], [310.0, 869.0], [310.0, 921.0], [284.0, 921.0]]], "lines": ["えっ、"]}, {"box": [676, 875, 767, 996], "vertical": true, "font_size": 20, "lines_coords": [[[749.0, 876.0], [766.0, 876.0], [765.0, 996.0], [748.0, 996.0]], [[723.0, 876.0], [743.0, 876.0], [743.0, 973.0], [723.0, 973.0]], [[699.0, 876.0], [719.0, 876.0], [719.0, 992.0], [699.0, 992.0]], [[676.0, 875.0], [697.0, 875.0], [697.0, 936.0], [676.0, 936.0]]], "lines": ["さっき彼女達", "この傷の事", "話してたんで", "しょ？"]}, {"box": [377, 863, 446, 989], "vertical": true, "font_size": 20, "lines_coords": [[[425.0, 866.0], [446.0, 866.0], [444.0, 960.0], [423.0, 960.0]], [[402.0, 863.0], [422.0, 863.0], [419.0, 962.0], [399.0, 962.0]], [[378.0, 864.0], [396.0, 864.0], [395.0, 989.0], [377.0, 989.0]]], "lines": ["バカみたい", "．．．あんな話", "信じないでね。"]}, {"box": [105, 862, 150, 966], "vertical": true, "font_size": 20, "lines_coords": [[[125.0, 862.0], [150.0, 862.0], [150.0, 924.0], [125.0, 924.0]], [[105.0, 863.0], [121.0, 863.0], [121.0, 966.0], [105.0, 966.0]]], "lines": ["ええ．．．", "もちろんよ。"]}], "img_path": "087.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [594, 82, 710, 239], "vertical": true, "font_size": 19, "lines_coords": [[[690.0, 83.0], [710.0, 83.0], [710.0, 182.0], [690.0, 182.0]], [[668.0, 84.0], [684.0, 84.0], [684.0, 219.0], [668.0, 219.0]], [[640.0, 82.0], [661.0, 82.0], [662.0, 239.0], [641.0, 239.0]], [[620.0, 84.0], [636.0, 84.0], [636.0, 217.0], [620.0, 217.0]], [[594.0, 83.0], [614.0, 83.0], [614.0, 205.0], [594.0, 205.0]]], "lines": ["．．．でもね．．．", "確かにこの傷は", "私にとって特別な", "意味を持つもの", "ではあるのよ。"]}, {"box": [422, 59, 490, 234], "vertical": true, "font_size": 20, "lines_coords": [[[470.0, 60.0], [490.0, 60.0], [490.0, 178.0], [470.0, 178.0]], [[446.0, 60.0], [466.0, 60.0], [466.0, 234.0], [446.0, 234.0]], [[423.0, 59.0], [443.0, 59.0], [442.0, 216.0], [422.0, 216.0]]], "lines": ["小さい頃ね．．．", "好きだった男の子の", "気を引きたくて．．"]}, {"box": [73, 66, 165, 233], "vertical": true, "font_size": 19, "lines_coords": [[[145.0, 69.0], [165.0, 69.0], [165.0, 146.0], [145.0, 146.0]], [[121.0, 67.0], [141.0, 67.0], [141.0, 175.0], [121.0, 175.0]], [[98.0, 66.0], [118.0, 66.0], [116.0, 166.0], [96.0, 166.0]], [[75.0, 67.0], [92.0, 67.0], [91.0, 233.0], [73.0, 233.0]]], "lines": ["綱渡りの", "まねをして、", "落ちた時に", "ケガしたものなの。"]}, {"box": [590, 448, 731, 590], "vertical": true, "font_size": 20, "lines_coords": [[[710.0, 452.0], [730.0, 452.0], [730.0, 549.0], [710.0, 549.0]], [[687.0, 450.0], [707.0, 450.0], [707.0, 534.0], [687.0, 534.0]], [[662.0, 448.0], [682.0, 448.0], [681.0, 590.0], [661.0, 590.0]], [[639.0, 450.0], [658.0, 450.0], [658.0, 567.0], [639.0, 567.0]], [[614.0, 451.0], [634.0, 451.0], [634.0, 548.0], [614.0, 548.0]], [[590.0, 451.0], [612.0, 451.0], [612.0, 556.0], [590.0, 556.0]]], "lines": ["ケガの功名", "というか、", "それがきっかけで", "その男の子と", "仲よくなる", "事ができた。"]}, {"box": [376, 454, 415, 540], "vertical": true, "font_size": 17, "lines_coords": [[[397.0, 455.0], [413.0, 455.0], [413.0, 525.0], [397.0, 525.0]], [[378.0, 454.0], [396.0, 454.0], [393.0, 540.0], [376.0, 540.0]]], "lines": ["そらろろ", "大丈夫か！？"]}, {"box": [274, 458, 344, 601], "vertical": true, "font_size": 20, "lines_coords": [[[322.0, 459.0], [343.0, 459.0], [344.0, 580.0], [323.0, 580.0]], [[298.0, 458.0], [318.0, 458.0], [321.0, 557.0], [301.0, 557.0]], [[274.0, 458.0], [294.0, 458.0], [297.0, 601.0], [277.0, 601.0]]], "lines": ["だから私自身、", "この傷には", "好きな男の子を、"]}, {"box": [79, 321, 120, 424], "vertical": true, "font_size": 20, "lines_coords": [[[98.0, 321.0], [120.0, 321.0], [120.0, 375.0], [98.0, 375.0]], [[79.0, 322.0], [96.0, 322.0], [96.0, 424.0], [79.0, 424.0]]], "lines": ["おーい", "降りてこい！"]}, {"box": [677, 630, 732, 727], "vertical": true, "font_size": 23, "lines_coords": [[[711.0, 632.0], [732.0, 632.0], [732.0, 725.0], [711.0, 725.0]], [[681.0, 630.0], [705.0, 631.0], [702.0, 727.0], [677.0, 726.0]]], "lines": ["うぎゃあ", "くくく～～"]}, {"box": [662, 758, 730, 896], "vertical": true, "font_size": 20, "lines_coords": [[[709.0, 758.0], [730.0, 758.0], [728.0, 896.0], [707.0, 896.0]], [[685.0, 760.0], [705.0, 760.0], [705.0, 877.0], [685.0, 877.0]], [[663.0, 759.0], [681.0, 759.0], [680.0, 881.0], [662.0, 881.0]]], "lines": ["実際、それ以来", "私の恋は必ず", "実ってるのよ。"]}, {"box": [374, 612, 413, 732], "vertical": true, "font_size": 16, "lines_coords": [[[396.0, 612.0], [412.0, 612.0], [412.0, 732.0], [396.0, 732.0]], [[374.0, 612.0], [390.0, 612.0], [390.0, 679.0], [374.0, 679.0]]], "lines": ["先生呼んでくる", "からな！！"]}, {"box": [260, 755, 346, 928], "vertical": true, "font_size": 17, "lines_coords": [[[328.0, 758.0], [344.0, 758.0], [344.0, 912.0], [328.0, 912.0]], [[306.0, 757.0], [322.0, 757.0], [322.0, 928.0], [306.0, 928.0]], [[283.0, 757.0], [300.0, 757.0], [300.0, 851.0], [283.0, 851.0]], [[260.0, 755.0], [280.0, 755.0], [280.0, 891.0], [260.0, 891.0]]], "lines": ["でも単なる偶然よ。", "そんなバワーなんて", "本当なわけ", "ないじゃない！"]}, {"box": [222, 765, 237, 809], "vertical": true, "font_size": 15, "lines_coords": [[[222.0, 765.0], [237.0, 765.0], [237.0, 809.0], [222.0, 809.0]]], "lines": ["．．．"]}, {"box": [56, 556, 124, 732], "vertical": true, "font_size": 20, "lines_coords": [[[100.0, 556.0], [124.0, 556.0], [124.0, 732.0], [100.0, 732.0]], [[78.0, 557.0], [98.0, 557.0], [98.0, 732.0], [78.0, 732.0]], [[56.0, 558.0], [72.0, 558.0], [72.0, 680.0], [56.0, 680.0]]], "lines": ["引きつけるパワーが", "あるんじゃないかと", "時々思うわけ。"]}], "img_path": "088.jpg"}, {"version": "0.1.7", "img_width": 845, "img_height": 1200, "blocks": [{"box": [288, 77, 331, 197], "vertical": true, "font_size": 18, "lines_coords": [[[315.0, 157.0], [329.0, 158.0], [326.0, 193.0], [312.0, 192.0]], [[311.0, 77.0], [331.0, 77.0], [331.0, 145.0], [311.0, 145.0]], [[288.0, 77.0], [308.0, 77.0], [308.0, 192.0], [288.0, 192.0]]], "lines": ["ーん", "五島さー", "待ってよー！！"]}, {"box": [707, 450, 772, 583], "vertical": true, "font_size": 18, "lines_coords": [[[754.0, 450.0], [771.0, 450.0], [771.0, 568.0], [754.0, 568.0]], [[730.0, 450.0], [750.0, 450.0], [750.0, 583.0], [730.0, 583.0]], [[707.0, 451.0], [724.0, 451.0], [724.0, 553.0], [707.0, 553.0]]], "lines": ["どうしたのよ、", "今日はひとりで", "帰るなんて。"]}, {"box": [411, 453, 454, 596], "vertical": true, "font_size": 18, "lines_coords": [[[434.0, 453.0], [454.0, 453.0], [452.0, 589.0], [432.0, 589.0]], [[412.0, 455.0], [428.0, 455.0], [428.0, 594.0], [412.0, 594.0]]], "lines": ["ごめん．．．今日は", "用事があるから。"]}, {"box": [307, 455, 374, 570], "vertical": true, "font_size": 20, "lines_coords": [[[353.0, 455.0], [373.0, 455.0], [373.0, 553.0], [353.0, 553.0]], [[329.0, 455.0], [349.0, 455.0], [349.0, 570.0], [329.0, 570.0]], [[307.0, 455.0], [328.0, 455.0], [328.0, 533.0], [307.0, 533.0]]], "lines": ["わかった！！", "彼氏に会うん", "でしょ！？"]}, {"box": [111, 446, 135, 498], "vertical": true, "font_size": 22, "lines_coords": [[[111.0, 447.0], [133.0, 446.0], [135.0, 496.0], [113.0, 498.0]]], "lines": ["えっ。"]}, {"box": [682, 672, 773, 852], "vertical": true, "font_size": 21, "lines_coords": [[[753.0, 673.0], [773.0, 673.0], [773.0, 751.0], [753.0, 751.0]], [[727.0, 672.0], [747.0, 672.0], [750.0, 851.0], [730.0, 851.0]], [[704.0, 673.0], [725.0, 673.0], [726.0, 805.0], [705.0, 805.0]], [[682.0, 673.0], [705.0, 673.0], [705.0, 848.0], [682.0, 848.0]]], "lines": ["図星ね！？", "秀一君．．．て名前よね、", "緑山市の高校へ", "通ってるんでしょ？"]}, {"box": [377, 679, 468, 821], "vertical": true, "font_size": 21, "lines_coords": [[[448.0, 679.0], [468.0, 679.0], [466.0, 821.0], [446.0, 821.0]], [[424.0, 680.0], [445.0, 680.0], [443.0, 796.0], [421.0, 796.0]], [[399.0, 679.0], [420.0, 679.0], [421.0, 795.0], [400.0, 795.0]], [[377.0, 682.0], [398.0, 682.0], [398.0, 758.0], [377.0, 758.0]]], "lines": ["もしかしたら私、", "駅で知らずに", "すれ違ってる", "かもね！"]}, {"box": [298, 685, 339, 779], "vertical": true, "font_size": 16, "lines_coords": [[[322.0, 685.0], [338.0, 685.0], [338.0, 779.0], [322.0, 779.0]], [[298.0, 686.0], [315.0, 686.0], [315.0, 779.0], [298.0, 779.0]]], "lines": ["え．．．ええ．．．", "いいけど．．．"]}, {"box": [116, 683, 137, 742], "vertical": true, "font_size": 21, "lines_coords": [[[116.0, 683.0], [137.0, 683.0], [137.0, 742.0], [116.0, 742.0]]], "lines": ["でも．．"]}, {"box": [371, 945, 463, 1080], "vertical": true, "font_size": 19, "lines_coords": [[[445.0, 948.0], [461.0, 948.0], [461.0, 1080.0], [445.0, 1080.0]], [[420.0, 946.0], [440.0, 946.0], [440.0, 1062.0], [420.0, 1062.0]], [[396.0, 945.0], [416.0, 945.0], [416.0, 1062.0], [396.0, 1062.0]], [[373.0, 945.0], [393.0, 945.0], [391.0, 1044.0], [371.0, 1044.0]]], "lines": ["ねえどんな人！？", "紹介してよ！！", "これから私も", "行くから！！"]}, {"box": [118, 912, 139, 1050], "vertical": true, "font_size": 20, "lines_coords": [[[119.0, 912.0], [139.0, 912.0], [138.0, 1050.0], [118.0, 1050.0]]], "lines": ["でも．．．何なの？"]}], "img_path": "089.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [606, 96, 699, 251], "vertical": true, "font_size": 20, "lines_coords": [[[678.0, 96.0], [698.0, 96.0], [698.0, 215.0], [678.0, 215.0]], [[653.0, 96.0], [674.0, 96.0], [675.0, 251.0], [654.0, 251.0]], [[630.0, 97.0], [650.0, 97.0], [650.0, 233.0], [630.0, 233.0]], [[606.0, 98.0], [627.0, 98.0], [627.0, 176.0], [606.0, 176.0]]], "lines": ["．．．実は彼、今", "学校を休んでるの", "．．．もうずいぶん", "長い間．．"]}, {"box": [453, 116, 495, 214], "vertical": true, "font_size": 19, "lines_coords": [[[474.0, 116.0], [495.0, 116.0], [495.0, 179.0], [474.0, 179.0]], [[453.0, 118.0], [470.0, 118.0], [470.0, 214.0], [453.0, 214.0]]], "lines": ["まあ．．．", "どうして？"]}, {"box": [358, 92, 417, 232], "vertical": true, "font_size": 19, "lines_coords": [[[397.0, 93.0], [417.0, 93.0], [417.0, 232.0], [397.0, 232.0]], [[377.0, 92.0], [397.0, 92.0], [397.0, 215.0], [377.0, 215.0]], [[358.0, 92.0], [375.0, 92.0], [375.0, 196.0], [358.0, 196.0]]], "lines": ["いろいろ精神的に", "ショックな事が", "あってね．．．．．．"]}, {"box": [60, 79, 142, 183], "vertical": true, "font_size": 18, "lines_coords": [[[121.0, 79.0], [141.0, 79.0], [141.0, 150.0], [121.0, 150.0]], [[103.0, 82.0], [119.0, 82.0], [119.0, 167.0], [103.0, 167.0]], [[82.0, 82.0], [98.0, 82.0], [98.0, 183.0], [82.0, 183.0]], [[60.0, 84.0], [79.0, 84.0], [79.0, 119.0], [60.0, 119.0]]], "lines": ["ご両親が", "たて続けに", "亡くなったり", "．．．"]}, {"box": [75, 216, 114, 261], "vertical": true, "font_size": 22, "lines_coords": [[[92.0, 216.0], [114.0, 216.0], [114.0, 261.0], [92.0, 261.0]]], "lines": ["まあ"]}, {"box": [349, 288, 416, 442], "vertical": true, "font_size": 20, "lines_coords": [[[396.0, 288.0], [416.0, 288.0], [416.0, 406.0], [396.0, 406.0]], [[372.0, 288.0], [392.0, 288.0], [392.0, 442.0], [372.0, 442.0]], [[349.0, 288.0], [369.0, 288.0], [369.0, 366.0], [349.0, 366.0]]], "lines": ["私は何となく", "気が進まなかった", "けれど．．．"]}, {"box": [68, 289, 133, 502], "vertical": true, "font_size": 18, "lines_coords": [[[114.0, 290.0], [131.0, 290.0], [131.0, 464.0], [114.0, 464.0]], [[90.0, 289.0], [110.0, 289.0], [110.0, 502.0], [90.0, 502.0]], [[68.0, 290.0], [84.0, 290.0], [84.0, 501.0], [68.0, 501.0]]], "lines": ["押しきられるように", "彼女を秀一君に会わせる", "事になってしまった．．．"]}, {"box": [330, 801, 352, 919], "vertical": true, "font_size": 20, "lines_coords": [[[330.0, 801.0], [350.0, 801.0], [352.0, 919.0], [332.0, 919.0]]], "l