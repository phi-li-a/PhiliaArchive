size": 21, "lines_coords": [[[554.0, 428.0], [575.0, 428.0], [576.0, 546.0], [555.0, 546.0]]], "lines": ["えっ、何で？"]}, {"box": [274, 447, 367, 546], "vertical": true, "font_size": 20, "lines_coords": [[[347.0, 447.0], [366.0, 447.0], [366.0, 543.0], [347.0, 543.0]], [[323.0, 448.0], [343.0, 448.0], [343.0, 544.0], [323.0, 544.0]], [[298.0, 450.0], [318.0, 450.0], [318.0, 546.0], [298.0, 546.0]], [[274.0, 447.0], [294.0, 447.0], [296.0, 529.0], [276.0, 529.0]]], "lines": ["あの長屋の", "住人同士が", "いがみあう", "．．．それは"]}, {"box": [622, 683, 765, 803], "vertical": true, "font_size": 23, "lines_coords": [[[744.0, 687.0], [765.0, 687.0], [765.0, 765.0], [744.0, 765.0]], [[721.0, 686.0], [741.0, 686.0], [741.0, 789.0], [721.0, 789.0]], [[697.0, 686.0], [717.0, 686.0], [717.0, 782.0], [697.0, 782.0]], [[668.0, 683.0], [698.0, 684.0], [696.0, 748.0], [665.0, 747.0]], [[648.0, 687.0], [670.0, 687.0], [670.0, 803.0], [648.0, 803.0]], [[622.0, 686.0], [647.0, 686.0], [647.0, 755.0], [622.0, 755.0]]], "lines": ["あの長屋", "そのものに、", "うずまきの", "呪いが", "かかっている", "からだ。"]}, {"box": [443, 700, 535, 799], "vertical": true, "font_size": 20, "lines_coords": [[[514.0, 700.0], [534.0, 700.0], [534.0, 798.0], [514.0, 798.0]], [[491.0, 701.0], [511.0, 701.0], [511.0, 799.0], [491.0, 799.0]], [[466.0, 701.0], [486.0, 701.0], [486.0, 799.0], [466.0, 799.0]], [[443.0, 700.0], [463.0, 700.0], [463.0, 785.0], [443.0, 785.0]]], "lines": ["うずまきが", "彼らの心を", "ねじ曲げて", "いるんだ。"]}, {"box": [118, 685, 258, 794], "vertical": true, "font_size": 21, "lines_coords": [[[236.0, 690.0], [257.0, 690.0], [257.0, 786.0], [236.0, 786.0]], [[208.0, 685.0], [239.0, 686.0], [236.0, 751.0], [206.0, 750.0]], [[189.0, 689.0], [209.0, 689.0], [209.0, 771.0], [189.0, 771.0]], [[167.0, 690.0], [184.0, 690.0], [184.0, 783.0], [167.0, 783.0]], [[144.0, 691.0], [160.0, 691.0], [160.0, 786.0], [144.0, 786.0]], [[118.0, 690.0], [138.0, 690.0], [138.0, 794.0], [118.0, 794.0]]], "lines": ["オレの目に", "狂いが", "なければ、", "あの長屋の", "廃屋は相当", "禍々しいぜ。"]}, {"box": [309, 947, 327, 1083], "vertical": true, "font_size": 16, "lines_coords": [[[309.0, 948.0], [325.0, 948.0], [325.0, 1082.0], [309.0, 1082.0]]], "lines": ["．．．何ですって？"]}], "img_path": "157.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [613, 90, 726, 207], "vertical": true, "font_size": 20, "lines_coords": [[[710.0, 92.0], [726.0, 92.0], [726.0, 206.0], [710.0, 206.0]], [[682.0, 90.0], [707.0, 90.0], [707.0, 153.0], [682.0, 153.0]], [[660.0, 91.0], [681.0, 91.0], [681.0, 188.0], [660.0, 188.0]], [[636.0, 91.0], [656.0, 91.0], [656.0, 207.0], [636.0, 207.0]], [[613.0, 91.0], [633.0, 91.0], [633.0, 189.0], [613.0, 189.0]]], "lines": ["そんな事より", "桐絵．．", "早く２人で", "この町を脱出", "しないか？"]}, {"box": [555, 181, 597, 296], "vertical": true, "font_size": 20, "lines_coords": [[[581.0, 181.0], [597.0, 181.0], [597.0, 296.0], [581.0, 296.0]], [[555.0, 181.0], [575.0, 181.0], [575.0, 261.0], [555.0, 261.0]]], "lines": ["この呪われた", "町から．．．"]}, {"box": [378, 91, 401, 172], "vertical": true, "font_size": 21, "lines_coords": [[[378.0, 91.0], [399.0, 91.0], [400.0, 171.0], [379.0, 171.0]]], "lines": ["秀一君！！"]}, {"box": [154, 98, 202, 179], "vertical": true, "font_size": 20, "lines_coords": [[[175.0, 98.0], [202.0, 98.0], [202.0, 142.0], [175.0, 142.0]], [[154.0, 103.0], [175.0, 103.0], [175.0, 179.0], [154.0, 179.0]]], "lines": ["もう", "いいわ！！"]}, {"box": [68, 100, 110, 233], "vertical": true, "font_size": 20, "lines_coords": [[[93.0, 101.0], [110.0, 101.0], [110.0, 233.0], [93.0, 233.0]], [[68.0, 100.0], [84.0, 100.0], [86.0, 215.0], [70.0, 215.0]]], "lines": ["あなたなんかに", "相談しない！！"]}, {"box": [681, 539, 727, 619], "vertical": true, "font_size": 22, "lines_coords": [[[707.0, 541.0], [726.0, 541.0], [726.0, 619.0], [707.0, 619.0]], [[681.0, 539.0], [705.0, 539.0], [705.0, 603.0], [681.0, 603.0]]], "lines": ["数日後．．．", "私は．．"]}, {"box": [577, 933, 644, 1096], "vertical": true, "font_size": 20, "lines_coords": [[[621.0, 933.0], [644.0, 933.0], [644.0, 1072.0], 