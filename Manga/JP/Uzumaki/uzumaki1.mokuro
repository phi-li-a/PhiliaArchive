[[658.0, 60.0], [675.0, 60.0], [675.0, 194.0], [658.0, 194.0]], [[633.0, 59.0], [653.0, 59.0], [653.0, 155.0], [633.0, 155.0]], [[610.0, 59.0], [630.0, 59.0], [627.0, 157.0], [607.0, 157.0]], [[586.0, 58.0], [607.0, 58.0], [605.0, 180.0], [583.0, 180.0]]], "lines": ["ああ．．それは", "比較的歪みが", "少なかったから、", "秀一君に使って", "もらおうと", "思って私が", "用意したんだ。"]}, {"box": [398, 66, 491, 183], "vertical": true, "font_size": 20, "lines_coords": [[[470.0, 69.0], [490.0, 69.0], [490.0, 183.0], [470.0, 183.0]], [[445.0, 69.0], [466.0, 69.0], [466.0, 145.0], [445.0, 145.0]], [[422.0, 66.0], [442.0, 66.0], [442.0, 182.0], [422.0, 182.0]], [[398.0, 66.0], [418.0, 66.0], [418.0, 182.0], [398.0, 182.0]]], "lines": ["何ですって！？", "お父さん", "こんな気味の", "悪いお皿．．．！！"]}, {"box": [250, 230, 343, 364], "vertical": true, "font_size": 19, "lines_coords": [[[322.0, 230.0], [342.0, 230.0], [342.0, 364.0], [322.0, 364.0]], [[297.0, 230.0], [317.0, 230.0], [317.0, 326.0], [297.0, 326.0]], [[275.0, 230.0], [291.0, 230.0], [291.0, 325.0], [275.0, 325.0]], [[250.0, 230.0], [270.0, 230.0], [270.0, 315.0], [250.0, 315.0]]], "lines": ["気味が悪いって", "おまえ．．．", "これは芸術", "なんだぞ。"]}, {"box": [103, 213, 197, 369], "vertical": true, "font_size": 20, "lines_coords": [[[177.0, 215.0], [196.0, 215.0], [196.0, 331.0], [177.0, 331.0]], [[152.0, 214.0], [172.0, 214.0], [172.0, 317.0], [152.0, 317.0]], [[128.0, 214.0], [148.0, 214.0], [148.0, 369.0], [128.0, 369.0]], [[105.0, 213.0], [125.0, 213.0], [123.0, 332.0], [103.0, 332.0]]], "lines": ["そしてきっと", "秀一君なら、", "私の芸術がわかる", "と思ってね！"]}, {"box": [695, 401, 764, 614], "vertical": true, "font_size": 19, "lines_coords": [[[743.0, 401.0], [763.0, 401.0], [762.0, 614.0], [742.0, 614.0]], [[722.0, 403.0], [738.0, 403.0], [738.0, 612.0], [722.0, 612.0]], [[696.0, 401.0], [716.0, 401.0], [715.0, 546.0], [695.0, 546.0]]], "lines": ["なぜなら、彼のお父さん", "という人が芸術のわかる", "人だったからだ。"]}, {"box": [429, 407, 499, 651], "vertical": true, "font_size": 20, "lines_coords": [[[478.0, 410.0], [498.0, 410.0], [498.0, 651.0], [478.0, 651.0]], [[453.0, 408.0], [473.0, 408.0], [473.0, 614.0], [453.0, 614.0]], [[429.0, 407.0], [449.0, 407.0], [451.0, 651.0], [431.0, 651.0]]], "lines": ["彼のお父さんは、やきものは", "うずまきの芸術である」", "という名言を残したほどだ。"]}, {"box": [277, 406, 391, 623], "vertical": true, "font_size": 21, "lines_coords": [[[368.0, 406.0], [391.0, 406.0], [391.0, 590.0], [368.0, 590.0]], [[345.0, 408.0], [369.0, 408.0], [369.0, 623.0], [345.0, 623.0]], [[322.0, 410.0], [343.0, 410.0], [344.0, 611.0], [323.0, 611.0]], [[298.0, 410.0], [318.0, 410.0], [320.0, 604.0], [300.0, 604.0]], [[277.0, 411.0], [294.0, 411.0], [294.0, 526.0], [277.0, 526.0]]], "lines": ["そして私も影響され、", "真の芸術を生みだすため", "試行錯誤を重ねるうち、", "ついに素晴らしい土を", "発見した．．．"]}, {"box": [103, 401, 145, 612], "vertical": true, "font_size": 18, "lines_coords": [[[124.0, 401.0], [144.0, 401.0], [144.0, 612.0], [124.0, 612.0]], [[103.0, 405.0], [119.0, 405.0], [119.0, 539.0], [103.0, 539.0]]], "lines": ["そしてできあがったのが", "この作品達だ！！"]}, {"box": [701, 711, 771, 791], "vertical": true, "font_size": 23, "lines_coords": [[[744.0, 711.0], [771.0, 711.0], [771.0, 757.0], [744.0, 757.0]], [[723.0, 713.0], [743.0, 713.0], [743.0, 791.0], [723.0, 791.0]], [[701.0, 712.0], [723.0, 712.0], [723.0, 754.0], [701.0, 754.0]]], "lines": ["お．．．", "おじさん", "．．．．．"]}, {"box": [622, 713, 667, 869], "vertical": true, "font_size": 18, "lines_coords": [[[649.0, 717.0], [665.0, 717.0], [665.0, 849.0], [649.0, 849.0]], [[623.0, 713.0], [643.0, 713.0], [642.0, 869.0], [622.0, 869.0]]], "lines": ["一体どんな土を", "使ったんですか？"]}, {"box": [559, 714, 576, 764], "vertical": true, "font_size": 17, "lines_coords": [[[559.0, 714.0], [576.0, 714.0], [576.0, 764.0], [559.0, 764.0]]], "lines": ["．．．．．"]}, {"box": [291, 714, 308, 764], "vertical": true, "font_size": 17, "lines_coords": [[[291.0, 714.0], [308.0, 714.0], [308.0, 764.0], [291.0, 764.0]]], "lines": ["ト．．．"]}, {"box": [93, 711, 180, 785], "vertical": true, "font_size": 31, "lines_coords": [[[150.0, 712.0], [180.0, 712.0], [180.0, 785.0], [150.