 [96, 807, 116, 1044], "vertical": true, "font_size": 16, "lines_coords": [[[98.0, 807.0], [114.0, 807.0], [112.0, 1044.0], [96.0, 1044.0]]], "lines": ["突然動画的なケートが動かされております。"]}, {"box": [97, 811, 115, 1043], "vertical": true, "font_size": 18, "lines_coords": [[[97.0, 811.0], [115.0, 811.0], [115.0, 1043.0], [97.0, 1043.0]]], "lines": ["【変更】図令と十星野ゆきおｒ百ころう"]}, {"box": [222, 1033, 249, 1042], "vertical": false, "font_size": 9, "lines_coords": [[[222.0, 1033.0], [249.0, 1033.0], [249.0, 1042.0], [222.0, 1042.0]]], "lines": ["．．．"]}], "img_path": "009.jpg"}, {"version": "0.1.7", "img_width": 813, "img_height": 1200, "blocks": [{"box": [645, 94, 722, 213], "vertical": true, "font_size": 24, "lines_coords": [[[692.0, 94.0], [722.0, 94.0], [722.0, 140.0], [692.0, 140.0]], [[673.0, 97.0], [693.0, 97.0], [693.0, 213.0], [673.0, 213.0]], [[645.0, 98.0], [666.0, 98.0], [666.0, 176.0], [645.0, 176.0]]], "lines": ["私の", "生まれ育った", "黒渦町．．．"]}, {"box": [106, 488, 171, 618], "vertical": true, "font_size": 22, "lines_coords": [[[146.0, 488.0], [171.0, 488.0], [171.0, 564.0], [146.0, 564.0]], [[124.0, 488.0], [142.0, 488.0], [145.0, 618.0], [126.0, 618.0]]], "lines": ["これから", "お話しするのは"]}], "img_path": "010.jpg"}, {"version": "0.1.7", "img_width": 837, "img_height": 1200, "blocks": [], "img_path": "011.jpg"}, {"version": "0.1.7", "img_width": 837, "img_height": 1200, "blocks": [{"box": [473, 2, 496, 153], "vertical": true, "font_size": 23, "lines_coords": [[[473.0, 2.0], [496.0, 2.0], [496.0, 153.0], [473.0, 153.0]]], "lines": ["．．．．．．【第１話】"]}, {"box": [448, 26, 519, 656], "vertical": true, "font_size": 65, "lines_coords": [[[448.0, 26.0], [513.0, 26.0], [519.0, 656.0], [454.0, 656.0]]], "lines": ["．．．？？？"]}, {"box": [158, 732, 229, 885], "vertical": true, "font_size": 20, "lines_coords": [[[206.0, 732.0], [226.0, 732.0], [229.0, 885.0], [209.0, 885.0]], [[181.0, 733.0], [201.0, 733.0], [203.0, 829.0], [184.0, 829.0]], [[158.0, 732.0], [179.0, 732.0], [180.0, 832.0], [159.0, 832.0]]], "lines": ["この町で起こった", "奇妙な話の", "数々です．．"]}], "img_path": "012.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [], "img_path": "013.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [648, 116, 697, 213], "vertical": true, "font_size": 20, "lines_coords": [[[674.0, 116.0], [695.0, 116.0], [697.0, 213.0], [676.0, 213.0]], [[648.0, 117.0], [668.0, 117.0], [668.0, 202.0], [648.0, 202.0]]], "lines": ["私の名前は", "五島桐絵。"]}, {"box": [89, 333, 178, 467], "vertical": true, "font_size": 19, "lines_coords": [[[158.0, 336.0], [178.0, 336.0], [178.0, 451.0], [158.0, 451.0]], [[133.0, 336.0], [153.0, 336.0], [153.0, 466.0], [133.0, 466.0]], [[111.0, 333.0], [132.0, 333.0], [130.0, 432.0], [109.0, 432.0]], [[89.0, 337.0], [105.0, 337.0], [105.0, 435.0], [89.0, 435.0]]], "lines": ["町を見おろす", "山の中腹に建つ", "黒渦高校に", "通っている。"]}, {"box": [637, 575, 708, 710], "vertical": true, "font_size": 21, "lines_coords": [[[685.0, 575.0], [706.0, 575.0], [708.0, 676.0], [686.0, 676.0]], [[663.0, 577.0], [683.0, 577.0], [683.0, 710.0], [663.0, 710.0]], [[637.0, 576.0], [658.0, 576.0], [661.0, 677.0], [640.0, 677.0]]], "lines": ["陶芸家の父、", "そして母と弟の", "４人家族で、"]}, {"box": [437, 582, 479, 697], "vertical": true, "font_size": 18, "lines_coords": [[[458.0, 582.0], [478.0, 582.0], [478.0, 697.0], [458.0, 697.0]], [[437.0, 583.0], [453.0, 583.0], [453.0, 682.0], [437.0, 682.0]]], "lines": ["町の中心部に", "住んでいる"]}, {"box": [275, 755, 371, 941], "vertical": true, "font_size": 22, "lines_coords": [[[351.0, 758.0], [371.0, 758.0], [371.0, 896.0], [351.0, 896.0]], [[325.0, 755.0], [349.0, 755.0], [350.0, 941.0], [327.0, 941.0]], [[297.0, 757.0], [321.0, 757.0], [321.0, 895.0], [297.0, 895.0]], [[276.0, 757.0], [296.0, 757.0], [295.0, 912.0], [275.0, 912.0]]], "lines": ["あっ．．．いけない、", "早く駅に行かなきゃ。", "秀一君の乗った", "電車が来ちゃう！！"]}], "img_path": "014.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [450, 92, 472, 171], "vertical": true, "f