: true, "font_size": 23, "lines_coords": [[[119.0, 567.0], [137.0, 566.0], [139.0, 605.0], [121.0, 607.0]]], "lines": ["．．．？"]}, {"box": [702, 669, 746, 767], "vertical": true, "font_size": 21, "lines_coords": [[[725.0, 669.0], [746.0, 669.0], [744.0, 767.0], [723.0, 767.0]], [[702.0, 671.0], [723.0, 671.0], [723.0, 748.0], [702.0, 748.0]]], "lines": ["どうしたん", "ですか？"]}], "img_path": "059.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [622, 85, 720, 168], "vertical": true, "font_size": 25, "lines_coords": [[[693.0, 89.0], [718.0, 87.0], [720.0, 167.0], [696.0, 168.0]], [[673.0, 87.0], [693.0, 87.0], [693.0, 167.0], [673.0, 167.0]], [[651.0, 89.0], [672.0, 89.0], [672.0, 167.0], [651.0, 167.0]], [[622.0, 85.0], [653.0, 85.0], [653.0, 133.0], [622.0, 133.0]]], "lines": ["ケガして", "ますね．．．", "歩けます", "か？"]}, {"box": [626, 89, 716, 167], "vertical": false, "font_size": 78, "lines_coords": [[[626.0, 89.0], [716.0, 89.0], [716.0, 167.0], [626.0, 167.0]]], "lines": ["ゲガしてますね．．．歩けますか？"]}, {"box": [437, 94, 535, 203], "vertical": true, "font_size": 25, "lines_coords": [[[506.0, 94.0], [535.0, 94.0], [535.0, 159.0], [506.0, 159.0]], [[481.0, 94.0], [513.0, 94.0], [513.0, 161.0], [481.0, 161.0]], [[461.0, 98.0], [486.0, 98.0], [486.0, 176.0], [461.0, 176.0]], [[437.0, 98.0], [457.0, 98.0], [460.0, 203.0], [440.0, 203.0]]], "lines": ["満男！", "もっと", "ゆっくり", "歩きなさい。"]}, {"box": [307, 99, 403, 291], "vertical": true, "font_size": 19, "lines_coords": [[[382.0, 100.0], [402.0, 100.0], [402.0, 254.0], [382.0, 254.0]], [[356.0, 99.0], [377.0, 99.0], [378.0, 291.0], [357.0, 291.0]], [[328.0, 100.0], [348.0, 100.0], [349.0, 255.0], [329.0, 255.0]], [[308.0, 103.0], [323.0, 103.0], [323.0, 251.0], [308.0, 251.0]]], "lines": ["私：東洋テレビで", "リポーターをやってる", "丸山千恵という者", "なんですけど．．．"]}, {"box": [64, 91, 109, 389], "vertical": true, "font_size": 18, "lines_coords": [[[85.0, 91.0], [105.0, 91.0], [108.0, 389.0], [89.0, 389.0]], [[64.0, 91.0], [80.0, 91.0], [83.0, 365.0], [66.0, 365.0]]], "lines": ["東洋テレビ？やっぱり．．．どこかで", "見た事あるなって思ったんです。"]}, {"box": [672, 432, 722, 548], "vertical": true, "font_size": 18, "lines_coords": [[[693.0, 432.0], [713.0, 432.0], [713.0, 548.0], [693.0, 548.0]], [[672.0, 433.0], [689.0, 433.0], [689.0, 534.0], [672.0, 534.0]]], "lines": ["私は五島桐絵", "といいます。"]}, {"box": [439, 417, 554, 541], "vertical": true, "font_size": 21, "lines_coords": [[[528.0, 417.0], [554.0, 417.0], [554.0, 480.0], [528.0, 480.0]], [[507.0, 419.0], [527.0, 419.0], [527.0, 515.0], [507.0, 515.0]], [[485.0, 419.0], [506.0, 419.0], [506.0, 505.0], [485.0, 505.0]], [[460.0, 418.0], [481.0, 418.0], [481.0, 495.0], [460.0, 495.0]], [[439.0, 419.0], [455.0, 419.0], [455.0, 541.0], [439.0, 541.0]]], "lines": ["これは", "弟の満男．．．", "今２人で", "食料探し", "してたんです。"]}, {"box": [344, 419, 412, 571], "vertical": true, "font_size": 20, "lines_coords": [[[391.0, 419.0], [411.0, 419.0], [411.0, 535.0], [391.0, 535.0]], [[366.0, 420.0], [386.0, 420.0], [387.0, 571.0], [368.0, 571.0]], [[344.0, 419.0], [364.0, 419.0], [364.0, 498.0], [344.0, 498.0]]], "lines": ["私．．．今とても", "頭が混乱してるん", "だけど．．．"]}, {"box": [187, 413, 251, 494], "vertical": true, "font_size": 29, "lines_coords": [[[227.0, 414.0], [251.0, 414.0], [251.0, 494.0], [227.0, 494.0]], [[198.0, 413.0], [232.0, 413.0], [232.0, 461.0], [198.0, 461.0]]], "lines": ["この町は", "一体"]}, {"box": [58, 418, 127, 574], "vertical": true, "font_size": 21, "lines_coords": [[[107.0, 419.0], [127.0, 419.0], [127.0, 515.0], [107.0, 515.0]], [[84.0, 419.0], [104.0, 419.0], [104.0, 535.0], [84.0, 535.0]], [[58.0, 418.0], [82.0, 418.0], [82.0, 574.0], [58.0, 574.0]]], "lines": ["やっぱり．．．", "竜巻の被害に", "遭ったんですね？"]}, {"box": [573, 673, 713, 848], "vertical": true, "font_size": 20, "lines_coords": [[[692.0, 675.0], [712.0, 675.0], [712.0, 817.0], [692.0, 817.0]], [[668.0, 675.0], [689.0, 675.0], [690.0, 848.0], [669.0, 848.0]], [[645.0, 676.0], [665.0, 676.0], [665.0, 799.0], [645.0, 799.0]], [[622.0, 676.0], [642.0, 676.0], [642.0, 792.0], [622.0, 792.0]], [[596.0, 673.0], [617.0, 673.0], [618.0, 829.0], [597.0, 829.0]], [[573.0, 673.0], [594.0, 673.0], [596.0, 780.0], [575.0, 780.0]]], "lines": ["．．．今この町では", "人間のちょっとした", "素早い動作が、", "大きな竜巻を", "引き起こす状態に", "あるんです。"]}, {"box": [337, 677, 527, 851], "vertical": true, "font_size": 20, "lines_coords": [[[503.0, 678.0], [523.0, 678.0], [523.0, 812.0], [503.0, 812.0]], [[479.0, 677.0], [499.0, 677.0], [501.0, 850.0], [481.0, 850.0]], [[457.0, 678.0], [477.0, 678.0], [477.0, 812.0], [457.0, 812.0]], [[432.0, 678.0], [452.0, 678.0], [452.0, 796.0], [432.0, 796.0]], [[411.0, 679.0], [427.0, 679.0], [427.0, 813.0], [411.0, 813.0]], [[384.0, 677.0], [404.0, 677.0], [406.0, 850.0], [386.0, 850.0]], [[360.0, 677.0], [382.0, 677.0], [384.0, 851.0], [363.0, 851.0]], [[337.0, 677.0], [357.0, 677.0], [359.0, 803.0], [339.0, 803.0]]], "lines": ["多分、あの池が", "呑み込んでしまった", "台風のもの凄い", "エネルギーが、", "町全体にそんな", "現象を引き起こさせ", "てるんじゃないか．．．", "という事です。"]}, {"box": [193, 673, 287, 848], "vertical": true, "font_size": 22, "lines_coords": [[[266.0, 675.0], [287.0, 675.0], [284.0, 810.0], [263.0, 810.0]], [[242.0, 675.0], [262.0, 675.0], [261.0, 848.0], [241.0, 848.0]], [[217.0, 675.0], [237.0, 675.0], [237.0, 774.0], [217.0, 774.0]], [[193.0, 673.0], [217.0, 673.0], [217.0, 755.0], [193.0, 755.0]]], "lines": ["なにしろ６つの", "台風を呑み込んだん", "ですからね", "あの池．．．"]}, {"box": [21, 693, 162, 808], "vertical": true, "font_size": 22, "lines_coords": [[[140.0, 694.0], [161.0, 694.0], [162.0, 792.0], [141.0, 792.0]], [[117.0, 697.0], [138.0, 697.0], [138.0, 776.0], [117.0, 776.0]], [[94.0, 694.0], [116.0, 694.0], [113.0, 792.0], [92.0, 792.0]], [[67.0, 694.0], [93.0, 694.0], [93.0, 774.0], [67.0, 774.0]], [[46.0, 693.0], [67.0, 693.0], [65.0, 808.0], [44.0, 808.0]], [[21.0, 694.0], [45.0, 694.0], [45.0, 762.0], [21.0, 762.0]]], "lines": ["あの池って", "いうのは、", "今、大渦を", "巻いてる", "「トンボ池」の", "事です。"]}, {"box": [1, 1118, 73, 1143], "vertical": false, "font_size": 10, "lines_coords": [[[15.0, 1118.0], [67.0, 1120.0], [67.0, 1132.0], [15.0, 1130.0]], [[11.0, 1131.0], [66.0, 1131.0], [66.0, 1143.0], [11.0, 1143.0]]], "lines": ["そういうことだったのですが、", "これまではなぜなので、"]}], "img_path": "060.jpg"}, {"version": "0.1.7", "img_width": 834, "img_height": 1200, "blocks": [{"box": [666, 86, 757, 284], "vertical": true, "font_size": 20, "lines_coords": [[[734.0, 86.0], [757.0, 86.0], [757.0, 208.0], [734.0, 208.0]], [[712.0, 87.0], [732.0, 87.0], [730.0, 276.0], [711.0, 276.0]], [[689.0, 86.0], [709.0, 86.0], [708.0, 278.0], [688.0, 278.0]], [[666.0, 86.0], [682.0, 86.0], [682.0, 283.0], [666.0, 283.0]]], "lines": ["だから私達は、", "風を起こさないように", "ゆっくり動かなくては", "ならなくなったんです。"]}, {"box": [431, 83, 476, 302], "vertical": true, "font_size": 20, "lines_coords": [[[454.0, 85.0], [474.0, 85.0], [474.0, 274.0], [454.0, 274.0]], [[431.0, 83.0], [450.0, 83.0], [450.0, 302.0], [431.0, 302.0]]], "lines": ["いつまでこんな状態が", "続くのか、わかりません。"]}, {"box": [323, 85, 392, 295], "vertical": true, "font_size": 20, "lines_coords": [[[370.0, 85.0], [390.0, 85.0], [390.0, 295.0], [370.0, 295.0]], [[346.0, 85.0], [367.0, 85.0], [366.0, 257.0], [345.0, 257.0]], [[323.0, 86.0], [343.0, 86.0], [343.0, 276.0], [323.0, 276.0]]], "lines": ["えっ．．．ちょっと待って．．．", "じゃあ私でも、あの", "大竜巻を起こせるの！？"]}, {"box": [110, 101, 129, 242], "vertical": true, "font_size": 16, "lines_coords": [[[111.0, 101.0], [127.0, 101.0], [127.0, 241.0], [111.0, 241.0]]], "lines": ["．．．誰でも．．．です。"]}, {"box": [694, 385, 762, 520], "vertical": true, "font_size": 19, "lines_coords": [[[742.0, 387.0], [759.0, 387.0], [759.0, 517.0], [742.0, 517.0]], [[718.0, 387.0], [737.0, 387.0], [737.0, 520.0], [718.0, 520.0]], [[694.0, 385.0], [714.0, 385.0], [714.0, 472.0], [694.0, 472.0]]], "lines": ["だから、あまり", "大声出さないで", "ください。"]}, {"box": [457, 382, 502, 526], "vertical": true, "font_size": 20, "lines_coords": [[[482.0, 384.0], [502.0, 384.0], [502.0, 480.0], [482.0, 480.0]], [[459.0, 382.0], [479.0, 382.0], [477.0, 526.0], [457.0, 526.0]]], "lines": ["吐く息でも", "発生しますから。"]}, {"box": [356, 382, 422, 537], "vertical": true, "font_size": 20, "lines_coords": [[[404.0, 384.0], [420.0, 384.0], [420.0, 479.0], [404.0, 479.0]], [[378.0, 382.0], [401.0, 382.0], [401.0, 537.0], [378.0, 537.0]], [[356.0, 383.0], [376.0, 383.0], [376.0, 480.0], [356.0, 480.0]]], "lines": ["．．．まさか．．．", "じゃあ、さっきの", "子供達は．．．"]}, {"box": [110, 390, 155, 485], "vertical": true, "font_size": 20, "lines_coords": [[[133.0, 391.0], [153.0, 391.0], [153.0, 485.0], [133.0, 485.0]], [[110.0, 390.0], [131.0, 390.0], [131.0, 467.0], [110.0, 467.0]]], "lines": ["私の大声の", "せいで！？"]}, {"box": [617, 584, 755, 720], "vertical": true, "font_size": 22, "lines_coords": [[[734.0, 585.0], [755.0, 585.0], [755.0, 664.0], [734.0, 664.0]], [[711.0, 587.0], [730.0, 587.0], [730.0, 684.0], [711.0, 684.0]], [[687.0, 585.0], [707.0, 585.0], [707.0, 719.0], [687.0, 719.0]], [[664.0, 584.0], [684.0, 584.0], [684.0, 720.0], [664.0, 720.0]], [[640.0, 584.0], [660.0, 584.0], [660.0, 704.0], [640.0, 704.0]], [[617.0, 585.0], [638.0, 585.0], [638.0, 663.0], [617.0, 663.0]]], "lines": ["．．．何て事", "カしら．．．私", "とんでもない事", "してしまったわ", "．．．あの子達", "今頃．．．．．"]}, {"box": [482, 643, 552, 742], "vertical": true, "font_size": 22, "lines_coords": [[[524.0, 644.0], [552.0, 644.0], [552.0, 672.0], [524.0, 672.0]], [[503.0, 643.0], [528.0, 643.0], [525.0, 742.0], [501.0, 742.0]], [[482.0, 646.0], [502.0, 646.0], [502.0, 741.0], [482.0, 741.0]]], "lines": ["私", "どうしたら", "いいの．．．？"]}, {"box": [391, 589, 437, 686], "vertical": true, "font_size": 20, "lines_coords": [[[415.0, 590.0], [435.0, 590.0], [435.0, 686.0], [415.0, 686.0]], [[393.0, 589.0], [414.0, 589.0], [412.0, 667.0], [391.0, 667.0]]], "lines": ["どうしたん", "ですか？"]}, {"box": [94, 578, 260, 696], "vertical": true, "font_size": 23, "lines_coords": [[[234.0, 580.0], [260.0, 580.0], [260.0, 643.0], [234.0, 643.0]], [[208.0, 578.0], [238.0, 578.0], [238.0, 643.0], [208.0, 643.0]], [[189.0, 582.0], [209.0, 582.0], [209.0, 677.0], [189.0, 677.0]], [[167.0, 583.0], [183.0, 583.0], [183.0, 694.0], [167.0, 694.0]], [[139.0, 580.0], [165.0, 580.0], [165.0, 642.0], [139.0, 642.0]], [[119.0, 583.0], [139.0, 583.0], [139.0, 696.0], [119.0, 696.0]], [[94.0, 581.0], [115.0, 581.0], [115.0, 642.0], [94.0, 642.0]]], "lines": ["ああ．．．", "それに", "車の中には", "私の同僚が．．．", "それに", "ヘリコプター", "も．．．．．"]}, {"box": [299, 895, 388, 1096], "vertical": true, "font_size": 19, "lines_coords": [[[366.0, 896.0], [387.0, 896.0], [387.0, 992.0], [366.0, 992.0]], [[344.0, 895.0], [364.0, 895.0], [361.0, 1096.0], [342.0, 1096.0]], [[320.0, 896.0], [340.0, 896.0], [338.0, 1065.0], [318.0, 1065.0]], [[299.0, 897.0], [316.0, 897.0], [316.0, 1017.0], [299.0, 1017.0]]], "lines": ["．．．しっかり", "してください。とにかく", "私達の住んでる所へ", "行きましょう。"]}, {"box": [108, 921, 150, 1043], "vertical": true, "font_size": 18, "lines_coords": [[[130.0, 921.0], [149.0, 921.0], [149.0, 1037.0], [130.0, 1037.0]], [[108.0, 922.0], [125.0, 922.0], [125.0, 1038.0], [108.0, 1038.0]]], "lines": ["外にいるのは", "危険ですから"]}], "img_path": "061.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [672, 87, 713, 191], "vertical": true, "font_size": 18, "lines_coords": [[[693.0, 87.0], [713.0, 87.0], [713.0, 165.0], [693.0, 165.0]], [[672.0, 89.0], [689.0, 89.0], [689.0, 186.0], [672.0, 186.0]]], "lines": ["もうすぐ", "ですからね"]}, {"box": [405, 75, 500, 184], "vertical": true, "font_size": 25, "lines_coords": [[[479.0, 78.0], [500.0, 78.0], [500.0, 155.0], [479.0, 155.0]], [[455.0, 77.0], [477.0, 77.0], [474.0, 182.0], [453.0, 182.0]], [[425.0, 75.0], [457.0, 75.0], [457.0, 130.0], [425.0, 130.0]], [[405.0, 77.0], [432.0, 77.0], [432.0, 138.0], [405.0, 138.0]]], "lines": ["．．．まるで", "”バタフライ", "効果”", "だわ．．．"]}, {"box": [205, 87, 321, 205], "vertical": true, "font_size": 22, "lines_coords": [[[301.0, 87.0], [321.0, 87.0], [318.0, 194.0], [298.0, 194.0]], [[276.0, 89.0], [296.0, 89.0], [296.0, 187.0], [276.0, 187.0]], [[251.0, 90.0], [271.0, 90.0], [271.0, 205.0], [251.0, 205.0]], [[226.0, 89.0], [251.0, 89.0], [251.0, 152.0], [226.0, 152.0]], [[205.0, 90.0], [225.0, 90.0], [225.0, 196.0], [205.0, 196.0]]], "lines": ["「小さな蝶の", "羽ばたきが", "地球の裏側に", "大嵐を", "引き起こす」"]}, {"box": [58, 148, 152, 246], "vertical": true, "font_size": 22, "lines_coords": [[[132.0, 150.0], [152.0, 150.0], [152.0, 246.0], [132.0, 246.0]], [[108.0, 150.0], [128.0, 150.0], [128.0, 244.0], [108.0, 244.0]], [[82.0, 148.0], [107.0, 148.0], [107.0, 209.0], [82.0, 209.0]], [[58.0, 150.0], [83.0, 150.0], [83.0, 215.0], [58.0, 215.0]]], "lines": ["．．．この町は", "バタフライ", "効果の", "町だわ。"]}, {"box": [376, 383, 399, 424], "vertical": true, "font_size": 23, "lines_coords": [[[376.0, 383.0], [399.0, 383.0], [399.0, 424.0], [376.0, 424.0]]], "lines": ["え？"]}, {"box": [643, 806, 713, 891], "vertical": true, "font_size": 23, "lines_coords": [[[687.0, 806.0], [713.0, 806.0], [713.0, 867.0], [687.0, 867.0]], [[666.0, 807.0], [687.0, 807.0], [687.0, 884.0], [666.0, 884.0]], [[643.0, 806.0], [664.0, 806.0], [664.0, 891.0], [643.0, 891.0]]], "lines": ["私達が", "住んでる", "長屋です。"]}, {"box": [447, 799, 519, 889], "vertical": true, "font_size": 28, "lines_coords": [[[488.0, 799.0], [519.0, 799.0], [519.0, 854.0], [488.0, 854.0]], [[466.0, 800.0], [498.0, 800.0], [498.0, 864.0], [466.0, 864.0]], [[447.0, 802.0], [467.0, 802.0], [467.0, 888.0], [447.0, 888.0]]], "lines": ["さあ、", "入って", "ください。"]}, {"box": [349, 814, 417, 950], "vertical": true, "font_size": 20, "lines_coords": [[[396.0, 815.0], [416.0, 815.0], [416.0, 950.0], [396.0, 950.0]], [[372.0, 814.0], [392.0, 814.0], [393.0, 950.0], [373.0, 950.0]], [[349.0, 816.0], [369.0, 816.0], [369.0, 912.0], [349.0, 912.0]]], "lines": ["これは、ここに", "昔から建ってる", "廃屋で．．．"]}, {"box": [72, 902, 162, 1075], "vertical": true, "font_size": 19, "lines_coords": [[[139.0, 902.0], [160.0, 902.0], [161.0, 1057.0], [140.0, 1057.0]], [[116.0, 903.0], [135.0, 903.0], [137.0, 1075.0], [117.0, 1075.0]], [[92.0, 903.0], [112.0, 903.0], [113.0, 1057.0], [93.0, 1057.0]], [[72.0, 905.0], [89.0, 905.0], [89.0, 999.0], [72.0, 999.0]]], "lines": ["この町には、他に", "いくつも同じような", "建物が残ってるん", "ですけど．．"]}], "img_path": "062.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [668, 72, 764, 269], "vertical": true, "font_size": 22, "lines_coords": [[[744.0, 78.0], [764.0, 78.0], [764.0, 199.0], [744.0, 199.0]], [[719.0, 78.0], [739.0, 78.0], [739.0, 251.0], [719.0, 251.0]], [[696.0, 78.0], [716.0, 78.0], [716.0, 269.0], [696.0, 269.0]], [[668.0, 75.0], [695.0, 72.0], [699.0, 128.0], [672.0, 131.0]]], "lines": ["不思議な事に、", "あれだけの台風でも", "びくともしなかったん", "です。"]}, {"box": [329, 96, 420, 285], "vertical": true, "font_size": 18, "lines_coords": [[[400.0, 98.0], [417.0, 98.0], [417.0, 230.0], [400.0, 230.0]], [[376.0, 97.0], [396.0, 97.0], [396.0, 240.0], [376.0, 240.0]], [[353.0, 98.0], [370.0, 98.0], [370.0, 285.0], [353.0, 285.0]], [[329.0, 97.0], [345.0, 97.0], [345.0, 210.0], [329.0, 210.0]]], "lines": ["他の同じ建物も", "全部無事でした。", "．．．こんなボロ屋なのに", "なぜかしら？"]}, {"box": [127, 82, 149, 166], "vertical": true, "font_size": 20, "lines_coords": [[[127.0, 82.0], [147.0, 82.0], [147.0, 165.0], [127.0, 165.0]]], "lines": ["ただいま。"]}, {"box": [733, 370, 777, 437], "vertical": true, "font_size": 21, "lines_coords": [[[755.0, 371.0], [777.0, 371.0], [777.0, 431.0], [755.0, 431.0]], [[733.0, 370.0], [753.0, 370.0], [753.0, 437.0], [733.0, 437.0]]], "lines": ["．．．さあ", "どうぞ。"]}, {"box": [384, 364, 501, 527], "vertical": true, "font_size": 20, "lines_coords": [[[480.0, 364.0], [500.0, 364.0], [500.0, 462.0], [480.0, 462.0]], [[457.0, 365.0], [477.0, 365.0], [477.0, 471.0], [457.0, 471.0]], [[431.0, 364.0], [451.0, 364.0], [453.0, 519.0], [433.0, 519.0]], [[409.0, 366.0], [428.0, 366.0], [428.0, 481.0], [409.0, 481.0]], [[384.0, 364.0], [404.0, 364.0], [406.0, 527.0], [386.0, 527.0]]], "lines": ["この長屋は", "安全ですよ。", "前の所とは違って", "病原菌とかも", "いないみたいです。"]}, {"box": [389, 565, 405, 591], "vertical": true, "font_size": 16, "lines_coords": [[[389.0, 565.0], [405.0, 565.0], [405.0, 591.0], [389.0, 591.0]]], "lines": ["？"]}, {"box": [627, 645, 750, 728], "vertical": true, "font_size": 29, "lines_coords": [[[719.0, 646.0], [750.0, 646.0], [750.0, 700.0], [719.0, 700.0]], [[697.0, 646.0], [727.0, 646.0], [727.0, 711.0], [697.0, 711.0]], [[672.0, 645.0], [704.0, 645.0], [704.0, 696.0], [672.0, 696.0]], [[651.0, 649.0], [676.0, 649.0], [676.0, 728.0], [651.0, 728.0]], [[627.0, 649.0], [652.0, 649.0], [652.0, 712.0], [627.0, 712.0]]], "lines": ["桐絵、", "お帰り", "．．．", "お客さん", "かい？"]}], "img_path": "063.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [656, 91, 725, 284], "vertical": true, "font_size": 20, "lines_coords": [[[705.0, 93.0], [725.0, 93.0], [725.0, 247.0], [705.0, 247.0]], [[682.0, 91.0], [702.0, 91.0], [699.0, 284.0], [679.0, 284.0]], [[657.0, 91.0], [677.0, 91.0], [676.0, 229.0], [656.0, 229.0]]], "lines": ["大勢いるでしょ？", "なにしろ家をなくした", "人が多くて．．．"]}, {"box": [343, 78, 439, 214], "vertical": true, "font_size": 20, "lines_coords": [[[419.0, 78.0], [439.0, 78.0], [439.0, 182.0], [419.0, 182.0]], [[397.0, 82.0], [413.0, 82.0], [413.0, 193.0], [397.0, 193.0]], [[373.0, 82.0], [390.0, 82.0], [390.0, 214.0], [373.0, 214.0]], [[343.0, 78.0], [371.0, 78.0], [371.0, 124.0], [343.0, 124.0]]], "lines": ["．．．あの．．．私、", "東洋テレビの", "丸山と申します", "が．．．"]}, {"box": [67, 85, 187, 210], "vertical": true, "font_size": 23, "lines_coords": [[[161.0, 86.0], [187.0, 86.0], [187.0, 148.0], [161.0, 148.0]], [[140.0, 87.0], [160.0, 87.0], [160.0, 183.0], [140.0, 183.0]], [[112.0, 85.0], [141.0, 85.0], [141.0, 151.0], [112.0, 151.0]], [[93.0, 89.0], [113.0, 89.0], [113.0, 207.0], [93.0, 207.0]], [[70.0, 86.0], [90.0, 86.0], [87.0, 185.0], [67.0, 185.0]]], "lines": ["先ほど", "私共の車が", "事故を", "起こしまして、", "ケガ人が．．．"]}, {"box": [596, 411, 709, 508], "vertical": true, "font_size": 21, "lines_coords": [[[689.0, 411.0], [709.0, 411.0], [709.0, 495.0], [689.0, 495.0]], [[663.0, 411.0], [689.0, 411.0], [689.0, 473.0], [663.0, 473.0]], [[642.0, 411.0], [663.0, 411.0], [661.0, 507.0], [639.0, 507.0]], [[616.0, 411.0], [637.0, 411.0], [637.0, 488.0], [616.0, 488.0]], [[596.0, 411.0], [612.0, 411.0], [612.0, 507.0], [596.0, 507.0]]], "lines": ["どなたか、", "救助に", "手を貸して", "いただけ", "ませんか？"]}, {"box": [246, 396, 261, 456], "vertical": true, "font_size": 15, "lines_coords": [[[246.0, 396.0], [261.0, 396.0], [261.0, 456.0], [246.0, 456.0]]], "lines": ["．．．"]}, {"box": [640, 684, 727, 800], "vertical": true, "font_size": 20, "lines_coords": [[[705.0, 684.0], [726.0, 684.0], [727.0, 762.0], [706.0, 762.0]], [[683.0, 685.0], [703.0, 685.0], [703.0, 800.0], [683.0, 800.0]], [[658.0, 684.0], [678.0, 684.0], [678.0, 780.0], [658.0, 780.0]]], "lines": ["．．．それは", "いかんな．．．", "私が行こう"]}, {"box": [488, 679, 537, 748], "vertical": true, "font_size": 25, "lines_coords": [[[509.0, 679.0], [537.0, 679.0], [537.0, 726.0], [509.0, 726.0]], [[491.0, 680.0], [513.0, 682.0], [511.0, 745.0], [488.0, 744.0]]], "lines": ["私も", "行くわ"]}, {"box": [396, 686, 445, 750], "vertical": true, "font_size": 26, "lines_coords": [[[419.0, 686.0], [445.0, 686.0], [445.0, 748.0], [419.0, 748.0]], [[396.0, 686.0], [421.0, 686.0], [421.0, 750.0], [396.0, 750.0]]], "lines": ["．．．無駄", "だよ．．"]}, {"box": [77, 679, 126, 747], "vertical": true, "font_size": 26, "lines_coords": [[[101.0, 679.0], [126.0, 679.0], [126.0, 745.0], [101.0, 745.0]], [[77.0, 679.0], [103.0, 679.0], [103.0, 745.0], [77.0, 745.0]]], "lines": ["そうだ、", "無駄だ。"]}, {"box": [343, 948, 435, 1101], "vertical": true, "font_size": 20, "lines_coords": [[[414.0, 950.0], [434.0, 950.0], [434.0, 1045.0], [414.0, 1045.0]], [[390.0, 948.0], [411.0, 948.0], [412.0, 1055.0], [391.0, 1055.0]], [[366.0, 948.0], [386.0, 948.0], [385.0, 1101.0], [365.0, 1101.0]], [[344.0, 949.0], [362.0, 949.0], [360.0, 1083.0], [343.0, 1083.0]]], "lines": ["マスコミの", "連中だって、", "生きてこの町から", "出られるものが"]}], "img_path": "064.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [626, 77, 767, 232], "vertical": true, "font_size": 22, "lines_coords": [[[740.0, 77.0], [767.0, 77.0], [767.0, 127.0], [740.0, 127.0]], [[719.0, 78.0], [740.0, 78.0], [741.0, 194.0], [720.0, 194.0]], [[695.0, 78.0], [714.0, 78.0], [717.0, 232.0], [697.0, 232.0]], [[670.0, 78.0], [696.0, 78.0], [696.0, 146.0], [670.0, 146.0]], [[648.0, 78.0], [669.0, 78.0], [670.0, 213.0], [649.0, 213.0]], [[627.0, 80.0], [646.0, 80.0], [646.0, 215.0], [627.0, 215.0]]], "lines": ["実際、", "今度の台風で", "多くのマスコミや", "救助隊、", "ボランティアが", "やって来たが．．．"]}, {"box": [295, 85, 310, 128], "vertical": true, "font_size": 15, "lines_coords": [[[295.0, 85.0], [310.0, 85.0], [310.0, 128.0], [295.0, 128.0]]], "lines": ["．．．．．"]}, {"box": [345, 195, 435, 370], "vertical": true, "font_size": 19, "lines_coords": [[[413.0, 196.0], [433.0, 196.0], [433.0, 331.0], [413.0, 331.0]], [[390.0, 195.0], [410.0, 195.0], [411.0, 370.0], [391.0, 370.0]], [[365.0, 195.0], [385.0, 195.0], [385.0, 310.0], [365.0, 310.0]], [[345.0, 198.0], [362.0, 198.0], [362.0, 309.0], [345.0, 309.0]]], "lines": ["誰ひとりとして", "この町から無事には", "抜け出せない", "らしいぜ．．．"]}, {"box": [112, 112, 131, 266], "vertical": true, "font_size": 16, "lines_coords": [[[112.0, 113.0], [128.0, 113.0], [128.0, 266.0], [112.0, 266.0]]], "lines": ["抜け出せない．．．！？"]}, {"box": [620, 400, 761, 575], "vertical": true, "font_size": 19, "lines_coords": [[[740.0, 400.0], [761.0, 400.0], [761.0, 498.0], [740.0, 498.0]], [[711.0, 400.0], [734.0, 400.0], [734.0, 519.0], [711.0, 519.0]], [[689.0, 401.0], [709.0, 401.0], [709.0, 575.0], [689.0, 575.0]], [[665.0, 400.0], [685.0, 400.0], [685.0, 535.0], [665.0, 535.0]], [[643.0, 401.0], [659.0, 401.0], [659.0, 515.0], [643.0, 515.0]], [[620.0, 401.0], [636.0, 401.0], [636.0, 522.0], [620.0, 522.0]]], "lines": ["この町には", "恐ろしい力が", "働いているんだよ．．．", "我々はその渦に", "呑み込まれて", "しまったんだ。"]}, {"box": [114, 418, 228, 551], "vertical": true, "font_size": 20, "lines_coords": [[[207.0, 420.0], [228.0, 420.0], [228.0, 499.0], [207.0, 499.0]], [[182.0, 420.0], [203.0, 420.0], [203.0, 515.0], [182.0, 515.0]], [[160.0, 419.0], [180.0, 419.