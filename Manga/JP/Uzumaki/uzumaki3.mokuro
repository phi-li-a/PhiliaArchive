ox": [717, 577, 785, 779], "vertical": true, "font_size": 20, "lines_coords": [[[764.0, 577.0], [784.0, 577.0], [785.0, 712.0], [765.0, 712.0]], [[740.0, 578.0], [760.0, 578.0], [761.0, 779.0], [741.0, 779.0]], [[717.0, 580.0], [737.0, 580.0], [737.0, 657.0], [717.0, 657.0]]], "lines": ["．．．すみません．．．", "どなたかいらっしゃるん", "ですか？"]}, {"box": [679, 806, 777, 903], "vertical": true, "font_size": 27, "lines_coords": [[[747.0, 806.0], [777.0, 806.0], [777.0, 849.0], [747.0, 849.0]], [[724.0, 806.0], [753.0, 806.0], [753.0, 870.0], [724.0, 870.0]], [[704.0, 808.0], [725.0, 808.0], [725.0, 903.0], [704.0, 903.0]], [[679.0, 806.0], [706.0, 806.0], [706.0, 858.0], [679.0, 858.0]]], "lines": ["私の", "両親を", "捜してるん", "です。"]}, {"box": [513, 578, 557, 787], "vertical": true, "font_size": 18, "lines_coords": [[[537.0, 578.0], [557.0, 578.0], [555.0, 787.0], [535.0, 787.0]], [[514.0, 581.0], [530.0, 581.0], [530.0, 748.0], [514.0, 748.0]]], "lines": ["ちょっと、お聞きしたい", "事があるんですが．．．"]}, {"box": [519, 823, 593, 939], "vertical": true, "font_size": 21, "lines_coords": [[[564.0, 825.0], [586.0, 825.0], [586.0, 938.0], [564.0, 938.0]], [[541.0, 823.0], [561.0, 823.0], [561.0, 939.0], [541.0, 939.0]], [[519.0, 825.0], [539.0, 825.0], [539.0, 939.0], [519.0, 939.0]]], "lines": ["父は五島泰雄", "という陶芸家", "なんですが．．．"]}], "img_path": "181.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [666, 87, 709, 237], "vertical": true, "font_size": 16, "lines_coords": [[[690.0, 89.0], [706.0, 89.0], [706.0, 237.0], [690.0, 237.0]], [[666.0, 87.0], [683.0, 87.0], [683.0, 200.0], [666.0, 200.0]]], "lines": ["あんたの親なんか", "知らないよ！"]}, {"box": [406, 86, 472, 260], "vertical": true, "font_size": 21, "lines_coords": [[[450.0, 86.0], [471.0, 86.0], [472.0, 258.0], [451.0, 258.0]], [[425.0, 87.0], [450.0, 87.0], [450.0, 152.0], [425.0, 152.0]], [[406.0, 89.0], [423.0, 89.0], [423.0, 260.0], [406.0, 260.0]]], "lines": ["それより、こっちの", "頼みを", "きいてくれないか？"]}, {"box": [351, 86, 373, 128], "vertical": true, "font_size": 22, "lines_coords": [[[351.0, 86.0], [373.0, 86.0], [373.0, 128.0], [351.0, 128.0]]], "lines": ["え？"]}, {"box": [184, 90, 251, 266], "vertical": true, "font_size": 21, "lines_coords": [[[228.0, 90.0], [251.0, 90.0], [251.0, 266.0], [228.0, 266.0]], [[205.0, 91.0], [225.0, 91.0], [227.0, 263.0], [207.0, 263.0]], [[184.0, 92.0], [203.0, 92.0], [203.0, 215.0], [184.0, 215.0]]], "lines": ["今、外に出すものを", "どこかに捨ててきて", "ほしいんだよ。"]}], "img_path": "182.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [411, 94, 479, 200], "vertical": true, "font_size": 24, "lines_coords": [[[454.0, 94.0], [479.0, 94.0], [479.0, 175.0], [454.0, 175.0]], [[430.0, 96.0], [458.0, 96.0], [458.0, 142.0], [430.0, 142.0]], [[411.0, 97.0], [431.0, 97.0], [431.0, 199.0], [411.0, 199.0]]], "lines": ["そいつは", "今朝", "死んだんだ。"]}, {"box": [137, 85, 303, 183], "vertical": true, "font_size": 24, "lines_coords": [[[282.0, 90.0], [303.0, 90.0], [303.0, 168.0], [282.0, 168.0]], [[255.0, 90.0], [281.0, 90.0], [281.0, 157.0], [255.0, 157.0]], [[235.0, 90.0], [255.0, 90.0], [255.0, 166.0], [235.0, 166.0]], [[213.0, 90.0], [229.0, 90.0], [229.0, 183.0], [213.0, 183.0]], [[182.0, 89.0], [208.0, 87.0], [210.0, 150.0], [185.0, 151.0]], [[160.0, 86.0], [185.0, 86.0], [185.0, 166.0], [160.0, 166.0]], [[137.0, 85.0], [168.0, 85.0], [168.0, 133.0], [137.0, 133.0]]], "lines": ["まったく", "死体を、", "我々から", "ときほぐす", "のには", "苦労した", "よ．．．"]}, {"box": [755, 447, 780, 526], "vertical": true, "font_size": 25, "lines_coords": [[[755.0, 447.0], [780.0, 447.0], [780.0, 526.0], [755.0, 526.0]]], "lines": ["ひいっ．．．"]}, {"box": [541, 451, 561, 604], "vertical": true, "font_size": 20, "lines_coords": [[[541.0, 451.0], [561.0, 451.0], [561.0, 602.0], [541.0, 602.0]]], "lines": ["先へ行きましょ！"]}, {"box": [120, 301, 331, 418], "vertical": true, "font_size": 24, "lines_coords": [[[305.0, 305.0], [331.0, 305.0], [331.0, 369.0], [305.0, 369.0]], [[283.0, 305.0], [308.0, 305.0], [308.0, 383.0], [283.0, 383.0]], [[261.0, 307.0], [282.0, 307.0], [282.0, 403.0], [261.0, 403.0]], [[235.0, 301.0], [264.0, 303.0], [260.0, 370.0], [230.0, 367.0]], [[212.0, 305.0], [237.0, 305.0], [237.0, 367.0], [212.0, 367.0]], [[191.0, 307.0], [210.0, 307.0], [210.0, 403.0], [191.0, 403.0]], [[166.0, 305.0], [191.0, 305.0], [191.0, 385.0], [166.0, 385.0]], [[142.0, 307.0], [164.0, 307.0], [165.0, 418.0], [144.0, 418.0]], [[120.0, 307.0], [140.0, 307.0], [140.0, 385.0], [120.0, 385.0]]], "lines": ["それを", "どこかへ", "持ってって", "くれ．．．", "腐ると", "かなわん．．．", "どっかで", "焼いてしまっ", "てくれ．．"]}, {"box": [808, 733, 825, 794], "vertical": true, "font_size": 17, "lines_coords": [[[808.0, 733.0], [825.0, 733.0], [825.0, 794.0], [808.0, 794.0]]], "lines": ["ひそひそ"]}, {"box": [818, 857, 834, 925], "vertical": true, "font_size": 16, "lines_coords": [[[818.0, 857.0], [834.0, 857.0], [834.0, 925.0], [818.0, 925.0]]], "lines": ["フッフッ"]}, {"box": [615, 921, 635, 999], "vertical": true, "font_size": 20, "lines_coords": [[[615.0, 921.0], [635.0, 921.0], [635.0, 999.0], [615.0, 999.0]]], "lines": ["ひそひそ"]}, {"box": [552, 1042, 571, 1120], "vertical": true, "font_size": 19, "lines_coords": [[[552.0, 1042.0], [571.0, 1042.0], [571.0, 1120.0], [552.0, 1120.0]]], "lines": ["ひそひそ"]}, {"box": [415, 924, 435, 1044], "vertical": true, "font_size": 16, "lines_coords": [[[416.0, 924.0], [432.0, 924.0], [432.0, 1042.0], [416.0, 1042.0]]], "lines": ["何か臭うわね。"]}, {"box": [113, 914, 160, 1048], "vertical": true, "font_size": 20, "lines_coords": [[[139.0, 915.0], [159.0, 915.0], [159.0, 1030.0], [139.0, 1030.0]], [[114.0, 914.0], [134.0, 914.0], [133.0, 1048.0], [113.0, 1048.0]]], "lines": ["何かが腐った", "ような臭い．．．"]}], "img_path": "183.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [374, 646, 416, 759], "vertical": true, "font_size": 16, "lines_coords": [[[398.0, 646.0], [414.0, 646.0], [414.0, 759.0], [398.0, 759.0]], [[375.0, 646.0], [391.0, 646.0], [391.0, 740.0], [375.0, 740.0]]], "lines": ["こんな所にも", "死体力．．．？"]}, {"box": [298, 807, 412, 932], "vertical": true, "font_size": 21, "lines_coords": [[[391.0, 807.0], [411.0, 807.0], [411.0, 922.0], [391.0, 922.0]], [[369.0, 809.0], [389.0, 809.0], [389.0, 904.0], [369.0, 904.0]], [[343.0, 807.0], [363.0, 807.0], [365.0, 904.0], [345.0, 904.0]], [[319.0, 807.0], [345.0, 807.0], [345.0, 868.0], [319.0, 868.0]], [[298.0, 808.0], [318.0, 808.0], [318.0, 932.0], [298.0, 932.0]]], "lines": ["死んでやがる", "．．．．．．みんな", "うずまきに", "なって", "死んでやがる。"]}, {"box": [243, 823, 261, 880], "vertical": true, "font_size": 18, "lines_coords": [[[243.0, 823.0], [261.0, 823.0], [261.0, 880.0], [243.0, 880.0]]], "lines": ["ねえ．．．"]}, {"box": [56, 632, 79, 749], "vertical": true, "font_size": 20, "lines_coords": [[[56.0, 632.0], [76.0, 632.0], [79.0, 748.0], [59.0, 748.0]]], "lines": ["腐乱してる．．．"]}, {"box": [55, 825, 96, 902], "vertical": true, "font_size": 18, "lines_coords": [[[76.0, 825.0], [96.0, 825.0], [96.0, 902.0], [76.0, 902.0]], [[55.0, 825.0], [72.0, 825.0], [72.0, 863.0], [55.0, 863.0]]], "lines": ["あなた達", "．．．．．"]}], "img_path": "184.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [705, 80, 773, 221], "vertical": true, "font_size": 20, "lines_coords": [[[752.0, 82.0], [772.0, 82.0], [772.0, 217.0], [752.0, 217.0]], [[729.0, 82.0], [748.0, 82.0], [748.0, 215.0], [729.0, 215.0]], [[705.0, 80.0], [725.0, 80.0], [725.0, 178.0], [705.0, 178.0]]], "lines": ["その腐った死体", "どこかへ運んで", "くれない？"]}, {"box": [458, 76, 503, 217], "vertical": true, "font_size": 21, "lines_coords": [[[475.0, 77.0], [501.0, 76.0], [503.0, 138.0], [478.0, 139.0]], [[459.0, 80.0], [475.0, 80.0], [475.0, 217.0], [459.0, 217.0]]], "lines": ["臭くて", "がなわないのよ。"]}, {"box": [380, 87, 425, 228], "vertical": true, "font_size": 19, "lines_coords": [[[403.0, 87.0], [424.0, 87.0], [425.0, 222.0], [404.0, 222.0]], [[380.0, 89.0], [398.0, 89.0], [399.0, 228.0], [382.0, 228.0]]], "lines": ["あの．．．私、人を", "捜してるんです。"]}, {"box": [126, 78, 168, 211], "vertical": true, "font_size": 18, "lines_coords": [[[147.0, 79.0], [167.0, 79.0], [167.0, 157.0], [147.0, 157.0]], [[126.0, 78.0], [142.0, 78.0], [142.0, 209.0], [126.0, 209.0]]], "lines": ["私の両親", "なんですけど．．"]}, {"box": [733, 319, 779, 500], "vertical": true, "font_size": 20, "lines_coords": [[[757.0, 319.0], [777.0, 319.0], [779.0, 440.0], [759.0, 440.0]], [[733.0, 319.0], [753.0, 319.0], [755.0, 499.0], [736.0, 499.0]]], "lines": ["知らないわよ、", "あなたの両親なんて。"]}, {"box": [574, 465, 590, 527], "vertical": true, "font_size": 16, "lines_coords": [[[574.0, 465.0], [590.0, 465.0], [590.0, 527.0], [574.0, 527.0]]], "lines": ["．．．．．．"]}], "img_path": "185.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [266, 96, 365, 178], "vertical": true, "font_size": 23, "lines_coords": [[[337.0, 99.0], [360.0, 96.0], [365.0, 125.0], [342.0, 128.0]], [[311.0, 97.0], [336.0, 97.0], [336.0, 178.0], [311.0, 178.0]], [[289.0, 98.0], [310.0, 98.0], [310.0, 176.0], [289.0, 176.0]], [[266.0, 97.0], [289.0, 97.0], [289.0, 140.0], [266.0, 140.0]]], "lines": ["や、", "また屍を", "見つけた", "ぞ！"]}, {"box": [53, 92, 121, 206], "vertical": true, "font_size": 20, "lines_coords": [[[100.0, 93.0], [121.0, 93.0], [121.0, 188.0], [100.0, 188.0]], [[77.0, 92.0], [97.0, 92.0], [97.0, 206.0], [77.0, 206.0]], [[53.0, 92.0], [73.0, 92.0], [73.0, 169.0], [53.0, 169.0]]], "lines": ["やれやれ．．．", "これも一緒に", "運ぶか．．．"]}, {"box": [686, 812, 713, 862], "vertical": true, "font_size": 27, "lines_coords": [[[686.0, 812.0], [713.0, 812.0], [713.0, 862.0], [686.0, 862.0]]], "lines": ["あっ、"]}, {"box": [428, 810, 503, 875], "vertical": true, "font_size": 30, "lines_coords": [[[471.0, 810.0], [503.0, 810.0], [503.0, 858.0], [471.0, 858.0]], [[447.0, 812.0], [480.0, 812.0], [480.0, 860.0], [447.0, 860.0]], [[428.0, 814.0], [454.0, 814.0], [454.0, 875.0], [428.0, 875.0]]], "lines": ["谷崎", "さん", "．．．！！"]}, {"box": [232, 801, 307, 887], "vertical": true, "font_size": 30, "lines_coords": [[[274.0, 801.0], [307.0, 805.0], [303.0, 853.0], [270.0, 849.0]], [[250.0, 803.0], [283.0, 803.0], [283.0, 853.0], [250.0, 853.0]], [[232.0, 807.0], [256.0, 807.0], [256.0, 887.0], [232.0, 887.0]]], "lines": ["谷崎", "さん", "でしょ！？"]}], "img_path": "186.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [706, 107, 773, 222], "vertical": true, "font_size": 18, "lines_coords": [[[754.0, 107.0], [772.0, 107.0], [771.0, 221.0], [753.0, 221.0]], [[731.0, 108.0], [747.0, 108.0], [747.0, 222.0], [731.0, 222.0]], [[706.0, 107.0], [726.0, 107.0], [726.0, 222.0], [706.0, 222.0]]], "lines": ["ああ．．．何だ．．．", "あんたらか．．．", "覚えてるよ．．．"]}, {"box": [421, 93, 466, 292], "vertical": true, "font_size": 20, "lines_coords": [[[444.0, 93.0], [465.0, 93.0], [466.0, 292.0], [445.0, 292.0]], [[421.0, 94.0], [441.0, 94.0], [441.0, 235.0], [421.0, 235.0]]], "lines": ["何年ぶりだ？ちっとも", "変わってないな。"]}, {"box": [117, 96, 165, 247], "vertical": true, "font_size": 20, "lines_coords": [[[145.0, 96.0], [165.0, 96.0], [165.0, 210.0], [145.0, 210.0]], [[117.0, 97.0], [137.0, 97.0], [137.0, 247.0], [117.0, 247.0]]], "lines": ["．．．もう何年も", "経ったんですか？"]}, {"box": [680, 343, 770, 523], "vertical": true, "font_size": 20, "lines_coords": [[[750.0, 344.0], [770.0, 344.0], [770.0, 460.0], [750.0, 460.0]], [[724.0, 344.0], [744.0, 344.0], [746.0, 486.0], [726.0, 486.0]], [[700.0, 343.0], [724.0, 343.0], [724.0, 478.0], [700.0, 478.0]], [[680.0, 346.0], [697.0, 346.0], [697.0, 521.0], [680.0, 521.0]]], "lines": ["ああ．．．増築も", "かなり進んでる。", "だが、まだ所々", "つながってないがね。"]}, {"box": [223, 345, 339, 525], "vertical": true, "font_size": 22, "lines_coords": [[[319.0, 346.0], [339.0, 346.0], [339.0, 499.0], [319.0, 499.0]], [[294.0, 348.0], [317.0, 348.0], [317.0, 499.0], [294.0, 499.0]], [[273.0, 346.0], [293.0, 346.0], [293.0, 496.0], [273.0, 496.0]], [[247.0, 345.0], [268.0, 345.0], [270.0, 499.0], [249.0, 499.0]], [[223.0, 346.0], [247.0, 346.0], [247.0, 525.0], [223.0, 525.0]]], "lines": ["その上、露地には", "コンクリートだの", "土手の名残りだの", "障害物が残ってる", "から、まるで迷路だ。"]}, {"box": [123, 405, 193, 544], "vertical": true, "font_size": 22, "lines_coords": [[[171.0, 405.0], [192.0, 405.0], [193.0, 544.0], [172.0, 544.0]], [[146.0, 406.0], [167.0, 406.0], [169.0, 521.0], [148.0, 521.0]], [[123.0, 406.0], [147.0, 406.0], [147.0, 469.0], [123.0, 469.0]]], "lines": ["．．．だから俺は今、", "露地の整備で", "大変だ"]}, {"box": [631, 614, 768, 783], "vertical": true, "font_size": 19, "lines_coords": [[[750.0, 615.0], [766.0, 615.0], [766.0, 783.0], [750.0, 783.0]], [[726.0, 616.0], [743.0, 616.0], [743.0, 783.0], [726.0, 783.0]], [[700.0, 614.0], [721.0, 614.0], [721.0, 696.0], [700.0, 696.0]], [[673.0, 614.0], [697.0, 614.0], [699.0, 750.0], [676.0, 750.0]], [[653.0, 615.0], [673.0, 615.0], [673.0, 748.0], [653.0, 748.0]], [[631.0, 615.0], [648.0, 615.0], [648.0, 771.0], [631.0, 771.0]]], "lines": ["しかし、近いうちに", "増築は終わるだろう", "．．．今では、", "長屋の中にいる", "連中が内側から", "増築してるんだよ。"]}, {"box": [326, 616, 373, 748], "vertical": true, "font_size": 20, "lines_coords": [[[355.0, 617.0], [371.0, 617.0], [371.0, 747.0], [355.0, 747.0]], [[326.0, 616.0], [351.0, 616.0], [351.0, 684.0], [326.0, 684.0]]], "lines": ["まったく器用な", "連中だ。"]}, {"box": [278, 619, 303, 683], "vertical": true, "font_size": 25, "lines_coords": [[[278.0, 619.0], [303.0, 619.0], [303.0, 683.0], [278.0, 683.0]]], "lines": ["あの．．"]}, {"box": [345, 843, 388, 937], "vertical": true, "font_size": 16, "lines_coords": [[[369.0, 843.0], [385.0, 843.0], [385.0, 937.0], [369.0, 937.0]], [[345.0, 843.0], [362.0, 843.0], [362.0, 925.0], [345.0, 925.0]]], "lines": ["父は陶芸家", "なんです。"]}, {"box": [685, 833, 774, 1050], "vertical": true, "font_size": 19, "lines_coords": [[[753.0, 835.0], [773.0, 835.0], [773.0, 931.0], [753.0, 931.0]], [[726.0, 833.0], [751.0, 833.0], [753.0, 1050.0], [729.0, 1050.0]], [[709.0, 837.0], [725.0, 837.0], [725.0, 1025.0], [709.0, 1025.0]], [[685.0, 836.0], [702.0, 836.0], [702.0, 931.0], [685.0, 931.0]]], "lines": ["私、両親を", "捜してるんです．．．２人共、", "竜巻に巻き込まれたん", "ですけど．．"]}, {"box": [287, 857, 307, 952], "vertical": true, "font_size": 20, "lines_coords": [[[287.0, 857.0], [307.0, 857.0], [307.0, 952.0], [287.0, 952.0]]], "lines": ["．．．陶芸家？"]}], "img_path": "187.jpg"}, {"version": "0.1.7", "img_width": 842, "img_height": 1200, "blocks": [{"box": [561, 82, 699, 262], "vertical": true, "font_size": 18, "lines_coords": [[[678.0, 84.0], [697.0, 84.0], [697.0, 180.0], [678.0, 180.0]], [[654.0, 83.0], [672.0, 83.0], [673.0, 198.0], [655.0, 198.0]], [[631.0, 83.0], [651.0, 83.0], [651.0, 262.0], [631.0, 262.0]], [[607.0, 82.0], [627.0, 82.0], [627.0, 254.0], [607.0, 254.0]], [[585.0, 84.0], [601.0, 84.0], [601.0, 234.0], [585.0, 234.0]], [[563.0, 84.0], [579.0, 84.0], [579.0, 183.0], [563.0, 183.0]]], "lines": ["ああ．．．陶芸", "といえば．．．", "トンボ池のほとりで、", "今も夫婦でやってる", "という話を聞いた", "事があるな。"]}, {"box": [368, 80, 396, 154], "vertical": true, "font_size": 26, "lines_coords": [[[368.0, 82.0], [394.0, 80.0], [396.0, 153.0], [371.0, 154.0]]], "lines": ["えっ！？"]}, {"box": [262, 78, 310, 157], "vertical": true, "font_size": 26, "lines_coords": [[[278.0, 78.0], [310.0, 78.0], [310.0, 126.0], [278.0, 126.0]], [[262.0, 80.0], [282.0, 80.0], [282.0, 157.0], [262.0, 157.0]]], "lines": ["本当", "ですか！？"]}, {"box": [166, 110, 193, 162], "vertical": true, "font_size": 22, "lines_coords": [[[166.0, 110.0], [193.0, 110.0], [193.0, 162.0], [166.0, 162.0]]], "lines": ["ああ。"]}, {"box": [63, 114, 129, 192], "vertical": true, "font_size": 22, "lines_coords": [[[110.0, 114.0], [129.0, 114.0], [129.0, 192.0], [110.0, 192.0]], [[85.0, 114.0], [106.0, 114.0], [107.0, 191.0], [86.0, 191.0]], [[63.0, 114.0], [83.0, 114.0], [83.0, 192.0], [63.0, 192.0]]], "lines": ["俺が見た", "わけじゃ", "ないが．．．"]}, {"box": [624, 445, 717, 603], "vertical": true, "font_size": 21, "lines_coords": [[[693.0, 445.0], [717.0, 445.0], [717.0, 506.0], [693.0, 506.0]], [[672.0, 446.0], [692.0, 446.0], [690.0, 603.0], [671.0, 603.0]], [[648.0, 446.0], [668.0, 446.0], [668.0, 587.0], [648.0, 587.0]], [[625.0, 445.0], [645.0, 445.0], [644.0, 584.0], [624.0, 584.0]]], "lines": ["何でも", "「陶芸はうずまきの", "芸術だ」と言って", "やってるそうだ。"]}, {"box": [316, 435, 359, 568], "vertical": true, "font_size": 17, "lines_coords": [[[341.0, 437.0], [358.0, 437.0], [358.0, 567.0], [341.0, 567.0]], [[317.0, 435.0], [334.0, 435.0], [333.0, 548.0], [316.0, 548.0]]], "lines": ["そ．．．そうです！！", "その人です！！"]}, {"box": [208, 432, 278, 527], "vertical": true, "font_size": 22, "lines_coords": [[[257.0, 434.0], [278.0, 434.0], [278.0, 527.0], [257.0, 527.0]], [[234.0, 434.0], [254.0, 434.0], [254.0, 527.0], [234.0, 527.0]], [[208.0, 432.0], [233.0, 432.0], [233.0, 494.0], [208.0, 494.0]]], "lines": ["．．．やっぱり", "生きてたん", "だわ！！"]}, {"box": [57, 428, 148, 512], "vertical": true, "font_size": 28, "lines_coords": [[[124.0, 431.0], [148.0, 431.0], [148.0, 512.0], [124.0, 512.0]], [[93.0, 428.0], [129.0, 428.0], [129.0, 468.0], [93.0, 468.0]], [[72.0, 431.0], [105.0, 431.0], [105.0, 479.0], [72.0, 479.0]], [[57.0, 433.0], [77.0, 433.0], [77.0, 510.0], [57.0, 510.0]]], "lines": ["よかった", "ね、", "桐絵", "ちゃん！"]}, {"box": [598, 692, 712, 814], "vertical": true, "font_size": 20, "lines_coords": [[[692.0, 692.0], [712.0, 692.0], [712.0, 774.0], [692.0, 774.0]], [[668.0, 692.0], [688.0, 692.0], [688.0, 787.0], [668.0, 787.0]], [[645.0, 692.0], [666.0, 692.0], [666.0, 806.0], [645.0, 806.0]], [[621.0, 693.0], [641.0, 693.0], [641.0, 788.0], [621.0, 788.0]], [[598.0, 692.0], [618.0, 692.0], [618.0, 814.0], [598.0, 814.0]]], "lines": ["谷崎さん、", "ありがとう", "ございます！", "私、今から", "行ってみます。"]}, {"box": [509, 703, 528, 788], "vertical": true, "font_size": 16, "lines_coords": [[[509.0, 704.0], [525.0, 704.0], [525.0, 787.0], [509.0, 787.0]]], "lines": ["そうかい。"]}, {"box": [300, 689, 467, 823], "vertical": true, "font_size": 20, "lines_coords": [[[437.0, 689.0], [467.0, 689.0], [467.0, 757.0], [437.0, 757.0]], [[421.0, 692.0], [437.0, 692.0], [437.0, 785.0], [421.0, 785.0]], [[395.0, 692.0], [415.0, 692.0], [415.0, 823.0], [395.0, 823.0]], [[372.0, 691.0], [392.0, 691.0], [392.0, 805.0], [372.0, 805.0]], [[351.0, 692.0], [367.0, 692.0], [367.0, 803.0], [351.0, 803.0]], [[324.0, 690.0], [344.0, 690.0], [344.0, 782.0], [324.0, 782.0]], [[300.0, 690.0], [320.0, 690.0], [320.0, 773.0], [300.0, 773.0]]], "lines": ["しかし、", "トンボ池に", "たどり着くのは", "大変だと思う", "ぜ．．．なにしろ", "迷路みたい", "だからな"]}, {"box": [71, 701, 165, 802], "vertical": true, "font_size": 24, "lines_coords": [[[142.0, 705.0], [163.0, 705.0], [163.0, 787.0], [142.0, 787.0]], [[115.0, 701.0], [140.0, 701.0], [142.0, 802.0], [118.0, 802.0]], [[94.0, 704.0], [119.0, 704.0], [119.0, 783.0], [94.0, 783.0]], [[71.0, 704.0], [97.0, 704.0], [97.0, 774.0], [71.0, 774.0]]], "lines": ["俺でさえ、", "まだ一度も", "行った事", "ないぜ。"]}], "img_path": "188.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [382, 78, 473, 284], "vertical": true, "font_size": 17, "lines_coords": [[[452.0, 78.0], [472.0, 78.0], [472.0, 214.0], [452.0, 214.0]], [[430.0, 79.0], [446.0, 79.0], [446.0, 232.0], [430.0, 232.0]], [[405.0, 78.0], [421.0, 78.0], [421.0, 284.0], [405.0, 284.0]], [[384.0, 78.0], [402.0, 78.0], [399.0, 179.0], [382.0, 179.0]]], "lines": ["奥に進むにつれ、", "増築途中の部分を", "たくさん見かけるように", "なりました"]}, {"box": [120, 101, 142, 164], "vertical": true, "font_size": 21, "lines_coords": [[[120.0, 101.0], [141.0, 101.0], [141.0, 161.0], [120.0, 161.0]]], "lines": ["しかも"]}, {"box": [519, 404, 773, 505], "vertical": true, "font_size": 21, "lines_coords": [[[751.0, 405.0], [772.0, 405.0], [773.0, 483.0], [752.0, 483.0]], [[730.0, 406.0], [750.0, 406.0], [750.0, 501.0], [730.0, 501.0]], [[706.0, 406.0], [726.0, 406.0], [726.0, 501.0], [706.0, 501.0]], [[680.0, 404.0], [705.0, 404.0], [705.0, 466.0], [680.0, 466.0]], [[658.0, 406.0], [679.0, 406.0], [679.0, 482.0], [658.0, 482.0]], [[631.0, 404.0], [661.0, 404.0], [661.0, 472.0], [631.0, 472.0]], [[610.0, 406.0], [630.0, 406.0], [632.0, 502.0], [612.0, 502.0]], [[588.0, 407.0], [609.0, 407.0], [609.0, 482.0], [588.0, 482.0]], [[562.0, 406.0], [587.0, 406.0], [587.0, 467.0], [562.0, 467.0]], [[544.0, 408.0], [561.0, 408.0], [561.0, 502.0], [544.0, 502.0]], [[520.0, 406.0], [536.0, 406.0], [536.0, 502.0], [520.0, 502.0]]], "lines": ["露地には", "いたる所に", "切り立った", "ような", "障害物が", "あって、", "疲れきった", "私達には", "これを", "乗り越える", "気力がなく"]}, {"box": [516, 256, 558, 370], "vertical": true, "font_size": 16, "lines_coords": [[[540.0, 256.0], [556.0, 256.0], [556.0, 350.0], [540.0, 350.0]], [[516.0, 256.0], [533.0, 256.0], [533.0, 370.0], [516.0, 370.0]]], "lines": ["谷崎さんの", "言った通り．．．"]}, {"box": [110, 400, 229, 514], "vertical": true, "font_size": 23, "lines_coords": [[[202.0, 403.0], [227.0, 401.0], [229.0, 469.0], [205.0, 471.0]], [[182.0, 404.0], [202.0, 404.0], [202.0, 514.0], [182.0, 514.0]], [[153.0, 400.0], [182.0, 400.0], [182.0, 466.0], [153.0, 466.0]], [[134.0, 403.0], [155.0, 403.0], [155.0, 480.0], [134.0, 480.0]], [[112.0, 401.0], [132.0, 401.0], [130.0, 505.0], [110.0, 505.0]]], "lines": ["私達は、", "迷路のような", "露地を", "進む事に", "なりました。"]}, {"box": [730, 775, 774, 907], "vertical": true, "font_size": 19, "lines_coords": [[[754.0, 776.0], [771.0, 776.0], [771.0, 904.0], [754.0, 904.0]], [[730.0, 775.0], [751.0, 775.0], [751.0, 853.0], [730.0, 853.0]]], "lines": ["また行き止まり", "だわ．．．"]}, {"box": [373, 768, 465, 850], "vertical": true, "font_size": 25, "lines_coords": [[[437.0, 769.0], [462.0, 768.0], [465.0, 849.0], [439.0, 850.0]], [[414.0, 768.0], [444.0, 768.0], [444.0, 833.0], [414.0, 833.0]], [[392.0, 771.0], [418.0, 771.0], [418.0, 830.0], [392.0, 830.0]], [[373.0, 773.0], [390.0, 773.0], [390.0, 846.0], [373.0, 846.0]]], "lines": ["私達、今", "どこに", "いるの", "かしら？"]}, {"box": [240, 771, 311, 851], "vertical": true, "font_size": 25, "lines_coords": [[[284.0, 772.0], [309.0, 771.0], [311.0, 850.0], [287.0, 851.0]], [[263.0, 773.0], [288.0, 773.0], [288.0, 851.0], [263.0, 851.0]], [[240.0, 772.0], [264.0, 771.0], [267.0, 841.0], [242.0, 842.0]]], "lines": ["あそこを", "通り抜け", "ましょ。"]}], "img_path": "189.jpg"}, {"version": "0.1.7", "img_width": 842, "img_height": 1200, "blocks": [{"box": [112, 472, 180, 605], "vertical": true, "font_size": 22, "lines_coords": [[[159.0, 472.0], [180.0, 472.0], [178.0, 605.0], [156.0, 605.0]], [[133.0, 472.0], [158.0, 472.0], [158.0, 551.0], [133.0, 551.0]], [[112.0, 473.0], [133.0, 473.0], [133.0, 569.0], [112.0, 569.0]]], "lines": ["ねえ．．．この町の", "建物の中", "全部に．．．"]}, {"box": [78, 953, 143, 1088], "vertical": true, "font_size": 17, "lines_coords": [[[125.0, 955.0], [141.0, 955.0], [141.0, 1068.0], [125.0, 1068.0]], [[100.0, 953.0], [120.0, 953.0], [120.0, 1088.0], [100.0, 1088.0]], [[78.0, 956.0], [94.0, 956.0], [94.0, 1069.0], [78.0, 1069.0]]], "lines": ["あんなふうに", "人が詰まってる", "のかしらね？"]}], "img_path": "190.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [645, 716, 758, 848], "vertical": true, "font_size": 20, "lines_coords": [[[741.0, 717.0], [758.0, 717.0], [758.0, 848.0], [741.0, 848.0]], [[716.0, 717.0], [736.0, 717.0], [736.0, 813.0], [716.0, 813.0]], [[691.0, 716.0], [711.0, 716.0], [711.0, 829.0], [691.0, 829.0]], [[668.0, 717.0], [687.0, 717.0], [687.0, 794.0], [668.0, 794.0]], [[645.0, 716.0], [662.0, 716.0], [662.0, 793.0], [645.0, 793.0]]], "lines": ["．．．でも秀一君の", "言った通り", "この町が昔の", "再現だと", "すると．．．"]}, {"box": [503, 731, 596, 847], "vertical": true, "font_size": 20, "lines_coords": [[[576.0, 731.0], [596.0, 731.0], [596.0, 847.0], [576.0, 847.0]], [[553.0, 732.0], [573.0, 732.0], [573.0, 829.0], [553.0, 829.0]], [[527.0, 731.0], [552.0, 731.0], [552.0, 810.0], [527.0, 810.0]], [[503.0, 731.0], [525.0, 731.0], [526.0, 810.0], [505.0, 810.0]]], "lines": ["昔の人はなぜ", "こんな町を", "作ったの", "かしら？"]}, {"box": [251, 732, 393, 850], "vertical": true, "font_size": 21, "lines_coords": [[[368.0, 732.0], [393.0, 732.0], [393.0, 794.0], [368.0, 794.0]], [[348.0, 733.0], [368.0, 733.0], [368.0, 817.0], [348.0, 817.0]], [[322.0, 732.0], [345.0, 732.0], [345.0, 850.0], [322.0, 850.0]], [[300.0, 733.0], [319.0, 733.0], [319.0, 829.0], [300.0, 829.0]], [[276.0, 733.0], [296.0, 733.0], [296.0, 849.0], [276.0, 849.0]], [[251.0, 734.0], [271.0, 734.0], [271.0, 812.0], [251.0, 812.0]]], "lines": ["それを", "言うなら、", "なぜ今、また", "こんな町が", "作られている", "のカ．．．．．"]}, {"box": [116, 721, 162, 802], "vertical": true, "font_size": 23, "lines_coords": [[[135.0, 721.0], [162.0, 723.0], [160.0, 785.0], [133.0, 783.0]], [[116.0, 724.0], [135.0, 724.0], [135.0, 802.0], [116.0, 802.0]]], "lines": ["もしか", "したら．．．"]}, {"box": [256, 976, 325, 1083], "vertical": true, "font_size": 22, "lines_coords": [[[296.0, 977.0], [321.0, 976.0], [325.0, 1074.0], [301.0, 1075.0]], [[278.0, 979.0], [300.0, 979.0], [300.0, 1074.0], [278.0, 1074.0]], [[256.0, 979.0], [276.0, 979.0], [276.0, 1079.0], [256.0, 1079.0]]], "lines": ["それだって", "わからない", "じゃないか"]}], "img_path": "191.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [601, 78, 718, 193], "vertical": true, "font_size": 20, "lines_coords": [[[692.0, 78.0], [718.0, 78.0], [718.0, 140.0], [692.0, 140.0]], [[671.0, 79.0], [691.0, 79.0], [691.0, 157.0], [671.0, 157.0]], [[646.0, 78.0], [666.0, 78.0], [666.0, 193.0], [646.0, 193.0]], [[624.0, 79.0], [644.0, 79.0], [644.0, 175.0], [624.0, 175.0]], [[602.0, 79.0], [618.0, 79.0], [618.0, 183.0], [602.0, 183.0]]], "lines": ["これは", "大昔から", "繰り返されて", "いる事力も", "しれないな。"]}, {"box": [369, 69, 482, 229], "vertical": true, "font_size": 20, "lines_coords": [[[461.0, 70.0], [481.0, 70.0], [482.0, 205.0], [462.0, 205.0]], [[437.0, 70.0], [458.0, 70.0], [460.0, 228.0], [439.0, 228.0]], [[413.0, 70.0], [434.0, 70.0], [434.0, 147.0], [413.0, 147.0]], [[390.0, 69.0], [410.0, 69.0], [411.0, 222.0], [391.0, 222.0]], [[369.0, 73.0], [385.0, 73.0], [385.0, 186.0], [369.0, 186.0]]], "lines": ["百年．．．あるいは", "何百年かの周期で、", "この町に", "うずまきの呪いが", "ふりかかり．．．"]}, {"box": [72, 63, 166, 200], "vertical": true, "font_size": 23, "lines_coords": [[[144.0, 64.0], [165.0, 64.0], [166.0, 168.0], [145.0, 168.0]], [[119.0, 64.0], [145.0, 64.0], [145.0, 127.0], [119.0, 127.0]], [[97.0, 64.0], [117.0, 64.0], [118.0, 200.0], [98.0, 200.0]], [[72.0, 63.0], [97.0, 63.0], [97.0, 127.0], [72.0, 127.0]]], "lines": ["そのたびに、", "人々は", "うずまきの町を", "築く．．．"]}, {"box": [702, 353, 723, 413], "vertical": true, "font_size": 21, "lines_coords": [[[702.0, 353.0], [723.0, 353.0], [723.0, 413.0], [702.0, 413.0]]], "lines": ["えっ？"]}, {"box": [628, 439, 721, 614], "vertical": true, "font_size": 20, "lines_coords": [[[698.0, 439.0], [721.0, 439.0], [717.0, 614.0], [693.0, 614.0]], [[675.0, 440.0], [695.0, 440.0], [695.0, 594.0], [675.0, 594.0]], [[651.0, 439.0], [671.0, 439.0], [670.0, 576.0], [650.0, 576.0]], [[629.0, 440.0], [646.0, 440.0], [645.0, 581.0], [628.0, 581.0]]], "lines": ["でも、そうだったら", "この町の言い伝え", "とか残ってても", "よさそうなのに。"]}, {"box": [312, 453, 357, 588], "vertical": true, "font_size": 20, "lines_coords": [[[337.0, 454.0], [357.0, 454.0], [355.0, 570.0], [335.0, 570.0]], [[314.0, 453.0], [334.0, 453.0], [332.0, 588.0], [312.0, 588.0]]], "lines": ["よほど昔の事", "だからかしら？"]}, {"box": [60, 457, 87, 517], "vertical": true, "font_size": 27, "lines_coords": [[[60.0, 457.0], [87.0, 457.0], [87.0, 517.0], [60.0, 517.0]]], "lines": ["いや．．．"]}, {"box": [560, 675, 721, 829], "vertical": true, "font_size": 21, "lines_coords": [[[702.0, 678.0], [721.0, 678.0], [719.0, 793.0], [699.0, 793.0]], [[676.0, 676.0], [700.0, 676.0], [698.0, 812.0], [673.0, 812.0]], [[651.0, 677.0], [676.0, 677.0], [676.0, 748.0], [651.0, 748.0]], [[631.0, 678.0], [648.0, 678.0], [648.0, 829.0], [631.0, 829.0]], [[607.0, 676.0], [627.0, 676.0], [627.0, 775.0], [607.0, 775.0]], [[582.0, 676.0], [602.0, 676.0], [600.0, 812.0], [580.0, 812.0]], [[560.0, 675.0], [581.0, 675.0], [581.0, 717.0], [560.0, 717.0]]], "lines": ["木造の建物が", "残ってたくらい", "だから、", "忘れ去られるほど", "昔の事でも", "ないはずだよな", "．．．．．"]}, {"box": [477, 737, 546, 891], "vertical": true, "font_size": 21, "lines_coords": [[[526.0, 739.0], [546.0, 739.0], [546.0, 844.0], [526.0, 844.0]], [[502.0, 739.0], [522.0, 739.0], [522.0, 855.0], [502.0, 855.0]], [[478.0, 737.0], [498.0, 737.0], [496.0, 891.0], [477.0, 891.0]]], "lines": ["それなのに、", "なぜ言い伝え", "られなかったのか"]}, {"box": [337, 670, 430, 813], "vertical": true, "font_size": 20, "lines_coords": [[[407.0, 670.0], [427.0, 670.0], [427.0, 813.0], [407.0, 813.0]], [[384.0, 671.0], [405.0, 671.0], [403.0, 786.0], [382.0, 786.0]], [[362.0, 670.0], [382.0, 670.0], [379.0, 788.0], [359.0, 788.0]], [[337.0, 671.0], [357.0, 671.0], [357.0, 757.0], [337.0, 757.0]]], "lines": ["どこかの時点で、", "伝承の断絶が", "起きたのかも", "しれない。"]}, {"box": [71, 672, 185, 834], "vertical": true, "font_size": 19, "lines_coords": [[[165.0, 672.0], [185.0, 672.0], [185.0, 788.0], [165.0, 788.0]], [[140.0, 672.0], [160.0, 672.0], [160.0, 788.0], [140.0, 788.0]], [[117.0, 672.0], [137.0, 672.0], [137.0, 830.0], [117.0, 830.0]], [[92.0, 673.0], [112.0, 673.0], [112.0, 787.0], [92.0, 787.0]], [[71.0, 675.0], [87.0, 675.0], [87.0, 787.0], [71.0, 787.0]]], "lines": ["．．．たとえば．．．", "記憶を後世に", "伝えるべき人々が、", "一度に消えて", "しまうとか．．．"]}, {"box": [232, 975, 253, 1089], "vertical": true, "font_size": 19, "lines_coords": [[[232.0, 975.0], [251.0, 975.0], [251.0, 1089.0], [232.0, 1089.0]]], "lines": ["伝承の断絶？"]}], "img_path": "192.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [704, 77, 773, 213], "vertical": true, "font_size": 19, "lines_coords": [[[748.0, 77.0], [770.0, 77.0], [773.0, 212.0], [752.0, 212.0]], [[725.0, 78.0], [745.0, 78.0], [748.0, 212.0], [729.0, 212.0]], [[704.0, 78.0], [720.0, 78.0], [723.0, 180.0], [706.0, 180.0]]], "lines": ["その後も私達は", "迷路をさまよい", "続けました。"]}, {"box": [518, 67, 589, 167], "vertical": true, "font_size": 22, "lines_coords": [[[560.0, 69.0], [586.0, 67.0], [589.0, 166.0], [563.0, 167.0]], [[540.0, 70.0], [561.0, 70.0], [561.0, 147.0], [540.0, 147.0]], [[518.0, 71.0], [537.0, 71.0], [537.0, 147.0], [518.0, 147.0]]], "lines": ["一体、私達", "今どこに", "いるの！？"]}, {"box": [263, 67, 331, 168], "vertical": true, "font_size": 22, "lines_coords": [[[310.0, 72.0], [330.0, 72.0], [330.0, 147.0], [