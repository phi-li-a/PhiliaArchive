6.0], [739.0, 134.0], [705.0, 131.0]]], "lines": ["いやな", "音！"]}, {"box": [629, 99, 671, 196], "vertical": true, "font_size": 26, "lines_coords": [[[650.0, 99.0], [671.0, 99.0], [671.0, 176.0], [650.0, 176.0]], [[629.0, 100.0], [649.0, 100.0], [649.0, 196.0], [629.0, 196.0]]], "lines": ["耳の中で", "渦を巻く！"]}, {"box": [324, 87, 394, 225], "vertical": true, "font_size": 20, "lines_coords": [[[371.0, 87.0], [391.0, 87.0], [393.0, 225.0], [374.0, 225.0]], [[348.0, 87.0], [369.0, 87.0], [370.0, 206.0], [349.0, 206.0]], [[324.0, 89.0], [344.0, 89.0], [347.0, 189.0], [327.0, 189.0]]], "lines": ["町が崩壊しても", "不定期に鳴る", "サイレンは、"]}, {"box": [100, 84, 221, 222], "vertical": true, "font_size": 22, "lines_coords": [[[195.0, 86.0], [219.0, 86.0], [221.0, 201.0], [198.0, 201.0]], [[174.0, 87.0], [194.0, 87.0], [194.0, 222.0], [174.0, 222.0]], [[150.0, 87.0], [171.0, 87.0], [171.0, 164.0], [150.0, 164.0]], [[123.0, 84.0], [146.0, 84.0], [148.0, 222.0], [125.0, 222.0]], [[100.0, 86.0], [125.0, 86.0], [125.0, 155.0], [100.0, 155.0]]], "lines": ["まるで囚人の", "脱走を知らせる", "刑務所の", "サイレンのよう", "でした。"]}, {"box": [440, 295, 488, 403], "vertical": true, "font_size": 24, "lines_coords": [[[461.0, 295.0], [488.0, 295.0], [488.0, 341.0], [461.0, 341.0]], [[440.0, 296.0], [460.0, 296.0], [463.0, 403.0], [443.0, 403.0]]], "lines": ["早く", "行きましょ。"]}, {"box": [329, 455, 422, 556], "vertical": true, "font_size": 25, "lines_coords": [[[396.0, 455.0], [422.0, 455.0], [422.0, 519.0], [396.0, 519.0]], [[372.0, 457.0], [397.0, 457.0], [397.0, 537.0], [372.0, 537.0]], [[345.0, 455.0], [375.0, 455.0], [375.0, 522.0], [345.0, 522.0]], [[329.0, 458.0], [349.0, 458.0], [349.0, 556.0], [329.0, 556.0]]], "lines": ["見て．．．", "杉の木が", "微妙な", "らせんに．．．"]}, {"box": [159, 762, 201, 895], "vertical": true, "font_size": 18, "lines_coords": [[[180.0, 762.0], [201.0, 762.0], [201.0, 840.0], [180.0, 840.0]], [[159.0, 762.0], [175.0, 762.0], [175.0, 894.0], [159.0, 894.0]]], "lines": ["いつから", "こんなふうに？"]}], "img_path": "145.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [687, 94, 731, 189], "vertical": true, "font_size": 22, "lines_coords": [[[711.0, 96.0], [731.0, 96.0], [731.0, 189.0], [711.0, 189.0]], [[687.0, 94.0], [710.0, 94.0], [710.0, 137.0], [687.0, 137.0]]], "lines": ["無理もない", "．．．"]}, {"box": [530, 86, 599, 191], "vertical": true, "font_size": 19, "lines_coords": [[[577.0, 86.0], [598.0, 86.0], [598.0, 169.0], [577.0, 169.0]], [[556.0, 86.0], [573.0, 86.0], [573.0, 180.0], [556.0, 180.0]], [[530.0, 86.0], [550.0, 86.0], [550.0, 191.0], [530.0, 191.0]]], "lines": ["この町は、", "うずまきの", "町だからな。"]}, {"box": [398, 80, 494, 199], "vertical": true, "font_size": 22, "lines_coords": [[[472.0, 84.0], [492.0, 84.0], [492.0, 199.0], [472.0, 199.0]], [[447.0, 84.0], [467.0, 84.0], [467.0, 179.0], [447.0, 179.0]], [[421.0, 82.0], [447.0, 82.0], [447.0, 162.0], [421.0, 162.0]], [[400.0, 80.0], [420.0, 80.0], [418.0, 198.0], [398.0, 198.0]]], "lines": ["ねえ．．．ずっと", "こんな道が", "続くの？", "桐絵ちゃん．．．"]}, {"box": [73, 71, 164, 207], "vertical": true, "font_size": 20, "lines_coords": [[[142.0, 73.0], [164.0, 73.0], [164.0, 152.0], [142.0, 152.0]], [[118.0, 71.0], [138.0, 71.0], [140.0, 207.0], [120.0, 207.0]], [[98.0, 75.0], [114.0, 75.0], [114.0, 168.0], [98.0, 168.0]], [[73.0, 73.0], [93.0, 73.0], [93.0, 196.0], [73.0, 196.0]]], "lines": ["いいえ．．．", "しばらくすると", "山の車道に", "出るはずです。"]}, {"box": [696, 475, 723, 521], "vertical": true, "font_size": 27, "lines_coords": [[[696.0, 475.0], [723.0, 475.0], [723.0, 521.0], [696.0, 521.0]]], "lines": ["はあ"]}, {"box": [352, 462, 445, 567], "vertical": true, "font_size": 23, "lines_coords": [[[424.0, 466.0], [445.0, 466.0], [443.0, 562.0], [421.0, 562.0]], [[397.0, 462.0], [426.0, 462.0], [426.0, 528.0], [397.0, 528.0]], [[377.0, 464.0], [398.0, 464.0], [396.0, 567.0], [375.0, 567.0]], [[352.0, 464.0], [373.0, 464.0], [373.0, 542.0], [352.0, 542.0]]], "lines": ["．．．なかなか", "車道に", "出ないわね、", "変だわ．．．"]}, {"box": [133, 475, 160, 522], "vertical": true, "font_size": 27, "lines_coords": [[[133.0, 475.0], [160.0, 475.0], [160.0, 522.0], [133.0, 522.0]]], "lines": ["はあ"]}, {"box": [355, 684, 382, 730], "vertical": true, "font_size": 27, "lines_coords": [[[355.0, 684.0], [382.0, 684.0], [382.0, 730.0], [355.0, 730.0]]], "lines": ["はあ"]}, {"box": [317, 775, 409, 878], "vertical": true, "font_size": 21, "lines_coords": [[[387.0, 775.0], [407.0, 775.0], [407.0, 874.0], [387.0, 874.0]], [[364.0, 775.0], [385.0, 775.0], [385.0, 853.0], [364.0, 853.0]], [[341.0, 775.0], [362.0, 775.0], [362.0, 871.0], [341.0, 871.0]], [[317.0, 775.0], [338.0, 775.0], [338.0, 854.0], [317.0, 854.0]]], "lines": ["また誰かが", "この町に", "入ってきた", "みたい．．"]}, {"box": [78, 616, 121, 731], "vertical": true, "font_size": 16, "lines_coords": [[[103.0, 617.0], [119.0, 617.0], [119.0, 728.0], [103.0, 728.0]], [[78.0, 617.0], [94.0, 617.0], [94.0, 698.0], [78.0, 698.0]]], "lines": ["おねえちゃん", "疲れたよ"]}, {"box": [75, 778, 96, 839], "vertical": true, "font_size": 21, "lines_coords": [[[75.0, 778.0], [96.0, 778.0], [96.0, 839.0], [75.0, 839.0]]], "lines": ["あっ！？"]}], "img_path": "146.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [706, 66, 777, 173], "vertical": true, "font_size": 23, "lines_coords": [[[755.0, 70.0], [777.0, 70.0], [774.0, 168.0], [753.0, 168.0]], [[729.0, 66.0], [760.0, 66.0], [760.0, 116.0], [729.0, 116.0]], [[709.0, 70.0], [730.0, 70.0], [727.0, 173.0], [706.0, 173.0]]], "lines": ["竹本さん達", "じゃ", "ないですか。"]}, {"box": [595, 72, 638, 168], "vertical": true, "font_size": 23, "lines_coords": [[[618.0, 72.0], [638.0, 72.0], [638.0, 168.0], [618.0, 168.0]], [[595.0, 72.0], [616.0, 72.0], [616.0, 150.0], [595.0, 150.0]]], "lines": ["どうしたん", "ですか？"]}, {"box": [343, 75, 371, 137], "vertical": true, "font_size": 26, "lines_coords": [[[343.0, 76.0], [369.0, 75.0], [371.0, 135.0], [345.0, 137.0]]], "lines": ["えっ？"]}, {"box": [703, 418, 773, 564], "vertical": true, "font_size": 21, "lines_coords": [[[748.0, 418.0], [772.0, 418.0], [772.0, 564.0], [748.0, 564.0]], [[729.0, 420.0], [748.0, 420.0], [748.0, 537.0], [729.0, 537.0]], [[703.0, 419.0], [723.0, 419.0], [725.0, 542.0], [705.0, 542.0]]], "lines": ["私達、今町から", "脱出しようと", "してるんです。"]}, {"box": [440, 432, 506, 594], "vertical": true, "font_size": 19, "lines_coords": [[[486.0, 432.0], [506.0, 432.0], [506.0, 573.0], [486.0, 573.0]], [[461.0, 433.0], [481.0, 433.0], [481.0, 585.0], [461.0, 585.0]], [[440.0, 433.0], [457.0, 433.0], [457.0, 591.0], [440.0, 591.0]]], "lines": ["もう少し行けば、", "隣町に続く山道に", "出るはずなんです。"]}, {"box": [335, 418, 401, 571], "vertical": true, "font_size": 18, "lines_coords": [[[379.0, 418.0], [398.0, 418.0], [400.0, 571.0], [382.0, 571.0]], [[357.0, 419.0], [377.0, 419.0], [377.0, 553.0], [357.0, 553.0]], [[335.0, 419.0], [351.0, 419.0], [351.0, 553.0], [335.0, 553.0]]], "lines": ["何を言ってる．．．？", "隣町への山道は", "そっちだろう．．．"]}, {"box": [220, 246, 309, 378], "vertical": true, "font_size": 20, "lines_coords": [[[291.0, 247.0], [308.0, 247.0], [308.0, 341.0], [291.0, 341.0]], [[264.0, 246.0], [290.0, 246.0], [290.0, 308.0], [264.0, 308.0]], [[242.0, 247.0], [262.0, 247.0], [262.0, 325.0], [242.0, 325.0]], [[220.0, 247.0], [236.0, 247.0], [236.0, 377.0], [220.0, 377.0]]], "lines": ["．．．どうした", "って．．．", "君達こそ", "どうしたんだ？"]}, {"box": [105, 411, 148, 591], "vertical": true, "font_size": 19, "lines_coords": [[[127.0, 411.0], [148.0, 411.0], [146.0, 548.0], [125.0, 548.0]], [[106.0, 413.0], [123.0, 413.0], [123.0, 589.0], [106.0, 589.0]]], "lines": ["俺達も今、町を", "出てきたところだぜ。"]}, {"box": [710, 664, 776, 839], "vertical": true, "font_size": 20, "lines_coords": [[[754.0, 664.0], [774.0, 664.0], [774.0, 819.0], [754.0, 819.0]], [[732.0, 665.0], [752.0, 665.0], [752.0, 839.0], [732.0, 839.0]], [[710.0, 665.0], [730.0, 665.0], [730.0, 686.0], [710.0, 686.0]]], "lines": ["えっ．．．どの道から", "山に入ったんですか", "？"]}, {"box": [460, 652, 534, 855], "vertical": true, "font_size": 22, "lines_coords": [[[513.0, 655.0], [534.0, 655.0], [530.0, 808.0], [509.0, 808.0]], [[489.0, 656.0], [509.0, 656.0], [507.0, 776.0], [487.0, 776.0]], [[465.0, 652.0], [488.0, 652.0], [484.0, 855.0], [460.0, 855.0]]], "lines": ["私達は黒渦高校の", "脇を通る道を、", "登ってきたんですけど。"]}, {"box": [700, 894, 767, 1085], "vertical": true, "font_size": 20, "lines_coords": [[[747.0, 896.0], [767.0, 896.0], [767.0, 993.0], [747.0, 993.0]], [[723.0, 894.0], [744.0, 894.0], [743.0, 1085.0], [721.0, 1085.0]], [[700.0, 896.0], [717.0, 896.0], [717.0, 1011.0], [700.0, 1011.0]]], "lines": ["同じだよ．．．", "君達が登っていくのが", "見えたから．．．"]}, {"box": [462, 900, 533, 1062], "vertical": true, "font_size": 20, "lines_coords": [[[512.0, 902.0], [532.0, 902.0], [532.0, 1026.0], [512.0, 1026.0]], [[488.0, 901.0], [508.0, 901.0], [508.0, 1057.0], [488.0, 1057.0]], [[465.0, 900.0], [485.0, 900.0], [482.0, 1058.0], [462.0, 1058.0]]], "lines": ["だから俺達も、", "そのあとを追って", "来たんじゃないか。"]}, {"box": [127, 912, 220, 1085], "vertical": true, "font_size": 19, "lines_coords": [[[200.0, 915.0], [220.0, 915.0], [220.0, 1012.0], [200.0, 1012.0]], [[178.0, 916.0], [194.0, 916.0], [194.0, 1085.0], [178.0, 1085.0]], [[152.0, 915.0], [172.0, 915.0], [172.0, 1012.0], [152.0, 1012.0]], [[127.0, 912.0], [147.0, 912.0], [148.0, 1075.0], [128.0, 1075.0]]], "lines": ["．．．どうやら", "君達は知らない間に", "逆戻りして", "しまったようだな。"]}], "img_path": "147.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [608, 93, 721, 248], "vertical": true, "font_size": 18, "lines_coords": [[[702.0, 93.0], [721.0, 93.0], [721.0, 209.0], [702.0, 209.0]], [[677.0, 94.0], [697.0, 94.0], [697.0, 248.0], [677.0, 248.0]], [[653.0, 94.0], [673.0, 94.0], [673.0, 198.0], [653.0, 198.0]], [[631.0, 96.0], [648.0, 96.0], [648.0, 248.0], [631.0, 248.0]], [[608.0, 97.0], [624.0, 97.0], [624.0, 191.0], [608.0, 191.0]]], "lines": ["．．．どうする？", "このまま進んでも", "俺達も結局、", "逆戻りしてしまう", "わけだろ？"]}, {"box": [421, 79, 467, 158], "vertical": true, "font_size": 23, "lines_coords": [[[446.0, 79.0], [467.0, 79.0], [467.0, 158.0], [446.0, 158.0]], [[421.0, 79.0], [446.0, 79.0], [446.0, 148.0], [421.0, 148.0]]], "lines": ["そういう", "事だな。"]}, {"box": [336, 82, 379, 275], "vertical": true, "font_size": 18, "lines_coords": [[[358.0, 82.0], [379.0, 82.0], [378.0, 257.0], [357.0, 257.0]], [[337.0, 84.0], [353.0, 84.0], [353.0, 275.0], [337.0, 275.0]]], "lines": ["くそっ．．．またしても", "脱出は無理なのかっ．．．"]}, {"box": [50, 67, 120, 312], "vertical": true, "font_size": 19, "lines_coords": [[[98.0, 67.0], [118.0, 67.0], [119.0, 311.0], [99.0, 311.0]], [[77.0, 71.0], [93.0, 71.0], [93.0, 222.0], [77.0, 222.0]], [[50.0, 67.0], [70.0, 67.0], [71.0, 243.0], [51.0, 243.0]]], "lines": ["きっとこの町のすべての道は、", "完全に閉じられて", "しまっているんだ！！"]}, {"box": [657, 360, 724, 514], "vertical": true, "font_size": 19, "lines_coords": [[[704.0, 360.0], [724.0, 360.0], [724.0, 458.0], [704.0, 458.0]], [[679.0, 360.0], [699.0, 360.0], [699.0, 513.0], [679.0, 513.0]], [[657.0, 362.0], [673.0, 362.0], [673.0, 514.0], [657.0, 514.0]]], "lines": ["もう俺達は", "この町から永久に", "出られないんだ．．．"]}, {"box": [380, 372, 446, 469], "vertical": true, "font_size": 19, "lines_coords": [[[426.0, 373.0], [446.0, 373.0], [446.0, 469.0], [426.0, 469.0]], [[403.0, 372.0], [423.0, 372.0], [423.0, 469.0], [403.0, 469.0]], [[380.0, 373.0], [397.0, 373.0], [397.0, 468.0], [380.0, 468.0]]], "lines": ["落ち着け！！", "諦めるのは", "まだ早い！"]}, {"box": [77, 582, 143, 704], "vertical": true, "font_size": 18, "lines_coords": [[[123.0, 582.0], [142.0, 582.0], [142.0, 698.0], [123.0, 698.0]], [[98.0, 582.0], [118.0, 582.0], [118.0, 660.0], [98.0, 660.0]], [[77.0, 583.0], [93.0, 583.0], [93.0, 704.0], [77.0, 704.0]]], "lines": ["とにかく．．．", "このまま", "進んでみよう。"]}], "img_path": "148.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [371, 94, 415, 248], "vertical": true, "font_size": 20, "lines_coords": [[[394.0, 94.0], [414.0, 94.0], [414.0, 230.0], [394.0, 230.0]], [[371.0, 96.0], [391.0, 96.0], [391.0, 248.0], [371.0, 248.0]]], "lines": ["あの、その人を", "なぜ縛ってるの？"]}, {"box": [119, 86, 142, 128], "vertical": true, "font_size": 23, "lines_coords": [[[119.0, 86.0], [142.0, 86.0], [142.0, 128.0], [119.0, 128.0]]], "lines": ["ん？"]}, {"box": [726, 455, 768, 578], "vertical": true, "font_size": 18, "lines_coords": [[[748.0, 455.0], [768.0, 455.0], [768.0, 571.0], [748.0, 571.0]], [[726.0, 458.0], [743.0, 458.0], [743.0, 578.0], [726.0, 578.0]]], "lines": ["これは大切な", "食料だからな。"]}, {"box": [121, 302, 192, 398], "vertical": true, "font_size": 22, "lines_coords": [[[171.0, 303.0], [192.0, 303.0], [192.0, 398.0], [171.0, 398.0]], [[147.0, 304.0], [168.0, 304.0], [168.0, 382.0], [147.0, 382.0]], [[121.0, 302.0], [146.0, 302.0], [146.0, 364.0], [121.0, 364.0]]], "lines": ["ああ．．．この", "岡本の事", "かい？"]}, {"box": [124, 442, 166, 577], "vertical": true, "font_size": 18, "lines_coords": [[[146.0, 444.0], [166.0, 444.0], [166.0, 577.0], [146.0, 577.0]], [[124.0, 444.0], [140.0, 444.0], [140.0, 547.0], [124.0, 547.0]]], "lines": ["逃げないように", "してるんだ。"]}, {"box": [311, 617, 406, 734], "vertical": true, "font_size": 23, "lines_coords": [[[380.0, 617.0], [406.0, 617.0], [406.0, 679.0], [380.0, 679.0]], [[359.0, 619.0], [379.0, 619.0], [379.0, 714.0], [359.0, 714.0]], [[335.0, 618.0], [355.0, 618.0], [357.0, 734.0], [337.0, 734.0]], [[311.0, 617.0], [336.0, 617.0], [336.0, 680.0], [311.0, 680.0]]], "lines": ["ほら．．．", "殻もだいぶ", "大きくなった", "ろう？"]}, {"box": [117, 612, 259, 748], "vertical": true, "font_size": 21, "lines_coords": [[[236.0, 615.0], [257.0, 615.0], [257.0, 693.0], [236.0, 693.0]], [[213.0, 612.0], [233.0, 612.0], [232.0, 748.0], [212.0, 748.0]], [[189.0, 615.0], [209.0, 615.0], [209.0, 728.0], [189.0, 728.0]], [[164.0, 612.0], [188.0, 612.0], [188.0, 676.0], [164.0, 676.0]], [[141.0, 614.0], [162.0, 614.0], [162.0, 692.0], [141.0, 692.0]], [[119.0, 614.0], [139.0, 614.0], [137.0, 698.0], [117.0, 698.0]]], "lines": ["こいつは", "もうすぐ完全に", "カタツムリに", "なる．．．", "そしたら", "食うんだ。"]}], "img_path": "149.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [323, 140, 350, 185], "vert