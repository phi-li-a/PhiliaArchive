], [462.0, 718.0]]], "lines": ["いくら見張ってても、", "夜中のうちに侵入", "してくる奴もいる。"]}, {"box": [75, 730, 142, 815], "vertical": true, "font_size": 25, "lines_coords": [[[121.0, 737.0], [142.0, 737.0], [142.0, 815.0], [121.0, 815.0]], [[94.0, 730.0], [127.0, 735.0], [120.0, 771.0], [87.0, 765.0]], [[75.0, 738.0], [96.0, 738.0], [96.0, 815.0], [75.0, 815.0]]], "lines": ["その結果", "が、", "これだ．．．"]}, {"box": [622, 979, 736, 1099], "vertical": true, "font_size": 20, "lines_coords": [[[714.0, 979.0], [736.0, 979.0], [733.0, 1078.0], [712.0, 1078.0]], [[691.0, 982.0], [712.0, 982.0], [712.0, 1057.0], [691.0, 1057.0]], [[666.0, 982.0], [686.0, 982.0], [686.0, 1095.0], [666.0, 1095.0]], [[644.0, 980.0], [664.0, 980.0], [664.0, 1083.0], [644.0, 1083.0]], [[622.0, 980.0], [638.0, 980.0], [638.0, 1099.0], [622.0, 1099.0]]], "lines": ["俺達の体は", "押し合い", "へしあいして", "いるうちに、", "ねじり絡まり、"]}, {"box": [329, 885, 372, 1020], "vertical": true, "font_size": 17, "lines_coords": [[[355.0, 885.0], [371.0, 885.0], [371.0, 1019.0], [355.0, 1019.0]], [[330.0, 885.0], [348.0, 885.0], [346.0, 1006.0], [329.0, 1006.0]]], "lines": ["もうときほぐす", "事もできない"]}], "img_path": "123.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [], "img_path": "124.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [], "img_path": "125.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [293, 560, 336, 754], "vertical": true, "font_size": 41, "lines_coords": [[[293.0, 560.0], [334.0, 560.0], [336.0, 754.0], [295.0, 754.0]]], "lines": ["ウォオオオ"]}], "img_path": "126.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [365, 78, 434, 194], "vertical": true, "font_size": 21, "lines_coords": [[[410.0, 78.0], [434.0, 78.0], [434.0, 112.0], [410.0, 112.0]], [[387.0, 80.0], [407.0, 80.0], [407.0, 193.0], [387.0, 193.0]], [[365.0, 82.0], [385.0, 82.0], [385.0, 159.0], [365.0, 159.0]]], "lines": ["な、", "何やってるの", "かしら？"]}, {"box": [637, 403, 780, 539], "vertical": true, "font_size": 21, "lines_coords": [[[760.0, 406.0], [780.0, 406.0], [780.0, 503.0], [760.0, 503.0]], [[736.0, 405.0], [757.0, 405.0], [754.0, 527.0], [733.0, 527.0]], [[707.0, 405.0], [729.0, 405.0], [726.0, 501.0], [705.0, 501.0]], [[684.0, 405.0], [704.0, 405.0], [704.0, 483.0], [684.0, 483.0]], [[661.0, 404.0], [682.0, 404.0], [679.0, 539.0], [658.0, 539.0]], [[637.0, 403.0], [657.0, 403.0], [657.0, 483.0], [637.0, 483.0]]], "lines": ["はみだした", "自分達の体を、", "廃材で覆い", "隠そうと", "しているように", "見える．．．"]}, {"box": [703, 787, 768, 922], "vertical": true, "font_size": 18, "lines_coords": [[[748.0, 787.0], [768.0, 787.0], [768.0, 922.0], [748.0, 922.0]], [[726.0, 788.0], [743.0, 788.0], [743.0, 902.0], [726.0, 902.0]], [[703.0, 787.0], [719.0, 787.0], [719.0, 890.0], [703.0, 890.0]]], "lines": ["多分、そうだ．．．", "増築しようと", "してるんだ"]}, {"box": [751, 983, 771, 1061], "vertical": true, "font_size": 20, "lines_coords": [[[751.0, 983.0], [771.0, 983.0], [771.0, 1061.0], [751.0, 1061.0]]], "lines": ["そうか．．．"]}, {"box": [486, 978, 529, 1095], "vertical": true, "font_size": 18, "lines_coords": [[[507.0, 978.0], [527.0, 978.0], [527.0, 1055.0], [507.0, 1055.0]], [[486.0, 979.0], [502.0, 979.0], [502.0, 1094.0], [486.0, 1094.0]]], "lines": ["その手が", "あったかな．．．"]}], "img_path": "127.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [391, 87, 411, 155], "vertical": true, "font_size": 20, "lines_coords": [[[391.0, 87.0], [411.0, 87.0], [411.0, 155.0], [391.0, 155.0]]], "lines": ["まさか、"]}, {"box": [94, 80, 134, 192], "vertical": true, "font_size": 16, "lines_coords": [[[118.0, 80.0], [134.0, 80.0], [134.0, 174.0], [118.0, 174.0]], [[94.0, 80.0], [111.0, 80.0], [111.0, 192.0], [94.0, 192.0]]], "lines": ["他の長屋も", "あんなふうに"]}, {"box": [71, 98, 87, 137], "vertical": true, "font_size": 16, "lines_coords": [[[71.0, 98.0], [87.0, 98.0], [87.0, 137.0], [71.0, 137.0]]], "lines": ["．．．？"]}, {"box": [680, 371, 726, 507], "vertical": true, "font_size": 21, "lines_coords": [[[705.0, 371.0], [725.0, 371.0], [726.0, 507.0], [706.0, 507.0]], [[680.0, 371.0], [702.0, 371.0], [703.0, 507.0], [682.0, 507.0]]], "lines": ["なあ．．．俺さっき", "考えたんだが．．"]}, {"box": [489, 369, 554, 485], "vertical": true, "font_size": 19, "lines_coords": [[[534.0, 370.0], [554.0, 370.0], [554.0, 466.0], [534.0, 466.0]], [[511.0, 369.0], [530.0, 369.0], [530.0, 467.0], [511.0, 467.0]], [[489.0, 369.0], [506.0, 369.0], [506.0, 485.0], [489.0, 485.0]]], "lines": ["あの長屋を", "増築したら", "どうだろう．．．"]}, {"box": [71, 399, 187, 571], "vertical": true, "font_size": 19, "lines_coords": [[[166.0, 399.0], [186.0, 399.0], [186.0, 571.0], [166.0, 571.0]], [[144.0, 400.0], [160.0, 400.0], [160.0, 570.0], [144.0, 570.0]], [[120.0, 400.0], [137.0, 400.0], [137.0, 570.0], [120.0, 570.0]], [[94.0, 399.0], [114.0, 399.0], [113.0, 569.0], [93.0, 569.0]], [[71.0, 401.0], [91.0, 401.0], [91.0, 495.0], [71.0, 495.0]]], "lines": ["あの長屋、古いのに", "竜巻に対して頑丈だ", "．．．それに横付けする", "ように建て増しして", "いけば．．．"]}, {"box": [623, 644, 714, 805], "vertical": true, "font_size": 19, "lines_coords": [[[691.0, 644.0], [711.0, 644.0], [711.0, 803.0], [691.0, 803.0]], [[669.0, 644.0], [689.0, 644.0], [689.0, 805.0], [669.0, 805.0]], [[645.0, 644.0], [665.0, 644.0], [665.0, 779.0], [645.0, 779.0]], [[623.0, 646.0], [639.0, 646.0], [639.0, 779.0], [623.0, 779.0]]], "lines": ["おい．．．待ってくれ、", "谷崎さん．．．あんた、", "ずっとこの町に", "いるつもりか？"]}, {"box": [308, 854, 378, 936], "vertical": true, "font_size": 26, "lines_coords": [[[357.0, 856.0], [378.0, 856.0], [378.0, 933.0], [357.0, 933.0]], [[326.0, 855.0], [356.0, 854.0], [358.0, 935.0], [329.0, 936.0]], [[308.0, 855.0], [334.0, 855.0], [334.0, 925.0], [308.0, 925.0]]], "lines": ["どのみち", "地獄じゃ", "ないか。"]}, {"box": [77, 657, 214, 794], "vertical": true, "font_size": 19, "lines_coords": [[[194.0, 657.0], [214.0, 657.0], [214.0, 764.0], [194.0, 764.0]], [[169.0, 659.0], [189.0, 659.0], [189.0, 757.0], [169.0, 757.0]], [[145.0, 658.0], [165.0, 658.0], [167.0, 774.0], [147.0, 774.0]], [[124.0, 659.0], [140.0, 659.0], [140.0, 792.0], [124.0, 792.0]], [[98.0, 659.0], [118.0, 659.0], [118.0, 775.0], [98.0, 775.0]], [[77.0, 662.0], [93.0, 662.0], [93.0, 794.0], [77.0, 794.0]]], "lines": ["まったくだ。", "長屋を増築", "するなんて．．．", "それより脱出の", "方法を考える", "のが先だろう．．．"]}, {"box": [632, 844, 723, 1057], "vertical": true, "font_size": 20, "lines_coords": [[[699.0, 844.0], [720.0, 844.0], [723.0, 1019.0], [702.0, 1019.0]], [[673.0, 844.0], [697.0, 844.0], [699.0, 987.0], [676.0, 987.0]], [[652.0, 847.0], [672.0, 847.0], [675.0, 1057.0], [655.0, 1057.0]], [[632.0, 848.0], [649.0, 848.0], [649.0, 1020.0], [632.0, 1020.0]]], "lines": ["それにもし、長屋に", "入れたとしても、", "あんなバケモノみたいに", "なってしまったら．．．"]}], "img_path": "128.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [768, 144, 789, 202], "vertical": true, "font_size": 21, "lines_coords": [[[768.0, 144.0], [789.0, 144.0], [789.0, 202.0], [768.0, 202.0]]], "lines": ["はっ！？"]}, {"box": [451, 78, 487, 226], "vertical": true, "font_size": 36, "lines_coords": [[[451.0, 79.0], [487.0, 79.0], [487.0, 226.0], [451.0, 226.0]]], "lines": ["わああ！！"]}, {"box": [690, 500, 764, 621], "vertical": true, "font_size": 25, "lines_coords": [[[743.0, 505.0], [764.0, 505.0], [764.0, 584.0], [743.0, 584.0]], [[720.0, 503.0], [740.0, 503.0], [738.0, 621.0], [718.0, 621.0]], [[690.0, 500.0], [724.0, 500.0], [724.0, 541.0], [690.0, 541.0]]], "lines": ["そうだ．．．", "どのみち地獄", "だ。"]}, {"box": [543, 370, 563, 447], "vertical": true, "font_size": 20, "lines_coords": [[[543.0, 370.0], [563.0, 370.0], [563.0, 447.0], [543.0, 447.0]]], "lines": ["伏せろ！！"]}, {"box": [113, 493, 253, 618], "vertical": true, "font_size": 21, "lines_coords": [[[228.0, 493.0], [253.0, 493.0], [253.0, 574.0], [228.0, 574.0]], [[207.0, 493.0], [227.0, 493.0], [227.0, 573.0], [207.0, 573.0]], [[184.0, 494.0], [203.0, 494.0], [203.0, 591.0], [184.0, 591.0]], [[160.0, 494.0], [180.0, 494.0], [180.0, 612.0], [160.0, 612.0]], [[133.0, 493.0], [159.0, 493.0], [159.0, 555.0], [133.0, 555.0]], [[114.0, 495.0], [131.0, 495.0], [131.0, 615.0], [114.0, 615.0]]], "lines": ["だったら", "どちらを", "選ぶかだ．．．", "竜巻で死ぬか。", "長屋で", "生き延びるか。"]}, {"box": [723, 678, 765, 772], "vertical": true, "font_size": 16, "lines_coords": [[[747.0, 679.0], [764.0, 679.0], [764.0, 772.0], [747.0, 772.0]], [[724.0, 678.0], [740.0, 678.0], [740.0, 762.0], [724.0, 762.0]]], "lines": ["俺は脱出の", "道を探る。"]}, {"box": [693, 826, 767, 892], "vertical": true, "font_size": 29, "lines_coords": [[[738.0, 826.0], [767.0, 826.0], [767.0, 860.0], [738.0, 860.0]], [[714.0, 826.0], [745.0, 826.0], [745.0, 892.0], [714.0, 892.0]], [[693.0, 827.0], [719.0, 827.0], [719.0, 880.0], [693.0, 880.0]]], "lines": ["あ、", "あれを", "見ろ。"]}, {"box": [455, 665, 522, 782], "vertical": true, "font_size": 19, "lines_coords": [[[502.0, 665.0], [522.0, 665.0], [520.0, 782.0], [500.0, 782.0]], [[478.0, 666.0], [498.0, 666.0], [498.0, 762.0], [478.0, 762.0]], [[455.0, 667.0], [472.0, 667.0], [472.0, 766.0], [455.0, 766.0]]], "lines": ["そうだ、まだ", "脱出方法が", "あるはずだ"]}, {"box": [376, 663, 423, 726], "vertical": true, "font_size": 24, "lines_coords": [[[397.0, 663.0], [423.0, 663.0], [423.0, 711.0], [397.0, 711.0]], [[376.0, 666.0], [397.0, 666.0], [397.0, 726.0], [376.0, 726.0]]], "lines": ["どう", "した！？"]}, {"box": [116, 659, 184, 759], "vertical": true, "font_size": 24, "lines_coords": [[[162.0, 662.0], [184.0, 662.0], [184.0, 739.0], [162.0, 739.0]], [[134.0, 659.0], [164.0, 659.0], [164.0, 730.0], [134.0, 730.0]], [[116.0, 662.0], [135.0, 662.0], [135.0, 759.0], [116.0, 759.0]]], "lines": ["海を見ろ", "．．．船だ、", "船が来た！"]}], "img_path": "129.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [686, 80, 737, 145], "vertical": true, "font_size": 28, "lines_coords": [[[711.0, 82.0], [737.0, 82.0], [737.0, 142.0], [711.0, 142.0]], [[686.0, 80.0], [716.0, 80.0], [716.0, 145.0], [686.0, 145.0]]], "lines": ["救助の", "船だ！"]}, {"box": [684, 455, 727, 616], "vertical": true, "font_size": 19, "lines_coords": [[[706.0, 455.0], [727.0, 455.0], [725.0, 576.0], [704.0, 576.0]], [[685.0, 458.0], [702.0, 458.0], [702.0, 616.0], [685.0, 616.0]]], "lines": ["海上保安庁か、", "自衛隊の船だろう。"]}, {"box": [371, 454, 440, 590], "vertical": true, "font_size": 21, "lines_coords": [[[414.0, 454.0], [438.0, 454.0], [440.0, 573.0], [417.0, 573.0]], [[394.0, 457.0], [414.0, 457.0], [414.0, 590.0], [394.0, 590.0]], [[371.0, 457.0], [391.0, 457.0], [391.0, 573.0], [371.0, 573.0]]], "lines": ["それにしても", "随分、遅かった", "じゃないか！！"]}, {"box": [93, 295, 164, 391], "vertical": true, "font_size": 23, "lines_coords": [[[138.0, 295.0], [164.0, 295.0], [164.0, 357.0], [138.0, 357.0]], [[114.0, 295.0], [139.0, 295.0], [139.0, 373.0], [114.0, 373.0]], [[96.0, 296.0], [113.0, 296.0], [111.0, 390.0], [93.0, 390.0]]], "lines": ["我々を", "救助しに", "来たんだ！！"]}, {"box": [662, 716, 733, 803], "vertical": true, "font_size": 26, "lines_coords": [[[704.0, 716.0], [733.0, 716.0], [733.0, 786.0], [704.0, 786.0]], [[680.0, 716.0], [710.0, 716.0], [710.0, 781.0], [680.0, 781.0]], [[662.0, 718.0], [682.0, 718.0], [682.0, 803.0], [662.0, 803.0]]], "lines": ["しかし、", "これで", "助かるぞ。"]}, {"box": [561, 768, 604, 854], "vertical": true, "font_size": 20, "lines_coords": [[[583.0, 768.0], [604.0, 768.0], [604.0, 848.0], [583.0, 848.0]], [[561.0, 768.0], [581.0, 768.0], [581.0, 854.0], [561.0, 854.0]]], "lines": ["よかった", "よかった。"]}, {"box": [484, 560, 504, 663], "vertical": true, "font_size": 19, "lines_coords": [[[484.0, 560.0], [503.0, 560.0], [503.0, 663.0], [484.0, 663.0]]], "lines": ["大きな船だ。"]}, {"box": [485, 703, 528, 822], "vertical": true, "font_size": 18, "lines_coords": [[[509.0, 704.0], [526.0, 704.0], [526.0, 819.0], [509.0, 819.0]], [[485.0, 704.0], [505.0, 704.0], [505.0, 806.0], [485.0, 806.0]]], "lines": ["よかったわね", "桐絵ちゃん。"]}, {"box": [64, 585, 134, 665], "vertical": true, "font_size": 24, "lines_coords": [[[108.0, 585.0], [134.0, 585.0], [134.0, 648.0], [108.0, 648.0]], [[86.0, 585.0], [111.0, 585.0], [111.0, 665.0], 