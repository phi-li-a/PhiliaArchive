288.0], [123.0, 288.0]]], "lines": ["私達が山を彷徨って", "いたのは、ほんの．．．"]}, {"box": [646, 489, 761, 622], "vertical": true, "font_size": 18, "lines_coords": [[[743.0, 492.0], [759.0, 492.0], [759.0, 603.0], [743.0, 603.0]], [[718.0, 489.0], [738.0, 489.0], [738.0, 604.0], [718.0, 604.0]], [[696.0, 489.0], [712.0, 489.0], [712.0, 621.0], [696.0, 621.0]], [[670.0, 491.0], [690.0, 491.0], [690.0, 622.0], [670.0, 622.0]], [[646.0, 491.0], [666.0, 491.0], [666.0, 614.0], [646.0, 614.0]]], "lines": ["オレ達が山を", "彷徨っている", "うちに、ひどく", "時間が過ぎたの", "かもしれない。"]}, {"box": [390, 310, 480, 465], "vertical": true, "font_size": 22, "lines_coords": [[[460.0, 312.0], [480.0, 312.0], [480.0, 427.0], [460.0, 427.0]], [[433.0, 311.0], [458.0, 311.0], [458.0, 465.0], [433.0, 465.0]], [[409.0, 310.0], [438.0, 310.0], [438.0, 376.0], [409.0, 376.0]], [[391.0, 314.0], [407.0, 314.0], [407.0, 464.0], [391.0, 464.0]]], "lines": ["．．．そういえば", "私達、どれだけの", "時間を", "彷徨っていたの？"]}, {"box": [414, 502, 461, 582], "vertical": true, "font_size": 24, "lines_coords": [[[432.0, 502.0], [461.0, 502.0], [461.0, 567.0], [432.0, 567.0]], [[414.0, 506.0], [434.0, 506.0], [434.0, 582.0], [414.0, 582.0]]], "lines": ["これも", "呪いか？"]}, {"box": [120, 328, 165, 460], "vertical": true, "font_size": 20, "lines_coords": [[[145.0, 328.0], [165.0, 328.0], [165.0, 460.0], [145.0, 460.0]], [[120.0, 328.0], [140.0, 328.0], [140.0, 405.0], [120.0, 405.0]]], "lines": ["すっかり時間の", "感覚が．．．"]}], "img_path": "175.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [642, 455, 709, 537], "vertical": true, "font_size": 25, "lines_coords": [[[687.0, 460.0], [709.0, 460.0], [709.0, 537.0], [687.0, 537.0]], [[659.0, 455.0], [691.0, 455.0], [691.0, 506.0], [659.0, 506.0]], [[642.0, 461.0], [662.0, 461.0], [662.0, 537.0], [642.0, 537.0]]], "lines": ["見わたす", "限り", "長屋．．．"]}, {"box": [307, 581, 400, 659], "vertical": true, "font_size": 26, "lines_coords": [[[379.0, 583.0], [400.0, 583.0], [400.0, 659.0], [379.0, 659.0]], [[355.0, 582.0], [380.0, 582.0], [380.0, 651.0], [355.0, 651.0]], [[328.0, 581.0], [358.0, 581.0], [358.0, 644.0], [328.0, 644.0]], [[307.0, 581.0], [334.0, 581.0], [334.0, 635.0], [307.0, 635.0]]], "lines": ["．．．やはり", "そうだ。", "間違い", "ない。"]}, {"box": [63, 580, 84, 639], "vertical": true, "font_size": 21, "lines_coords": [[[63.0, 580.0], [84.0, 580.0], [84.0, 639.0], [63.0, 639.0]]], "lines": ["見ろ！"]}, {"box": [635, 989, 724, 1108], "vertical": true, "font_size": 17, "lines_coords": [[[706.0, 990.0], [723.0, 990.0], [723.0, 1083.0], [706.0, 1083.0]], [[683.0, 990.0], [699.0, 990.0], [699.0, 1103.0], [683.0, 1103.0]], [[658.0, 990.0], [678.0, 990.0], [678.0, 1085.0], [658.0, 1085.0]], [[636.0, 990.0], [652.0, 990.0], [652.0, 1088.0], [636.0, 1088.0]]], "lines": ["あそこから", "あそこまでが", "元々あった", "古い長屋だ。"]}, {"box": [33, 1005, 101, 1103], "vertical": true, "font_size": 23, "lines_coords": [[[79.0, 1006.0], [100.0, 1006.0], [98.0, 1103.0], [77.0, 1103.0]], [[52.0, 1005.0], [80.0, 1005.0], [80.0, 1052.0], [52.0, 1052.0]], [[33.0, 1006.0], [53.0, 1006.0], [53.0, 1092.0], [33.0, 1092.0]]], "lines": ["その両端を", "増築", "したんだ。"]}], "img_path": "176.jpg"}, {"version": "0.1.7", "img_width": 839, "img_height": 1200, "blocks": [{"box": [679, 79, 768, 232], "vertical": true, "font_size": 18, "lines_coords": [[[749.0, 83.0], [766.0, 83.0], [766.0, 214.0], [749.0, 214.0]], [[722.0, 79.0], [742.0, 79.0], [742.0, 232.0], [722.0, 232.0]], [[699.0, 80.0], [719.0, 80.0], [721.0, 214.0], [701.0, 214.0]], [[679.0, 83.0], [696.0, 83.0], [696.0, 214.0], [679.0, 214.0]]], "lines": ["でも不思議ね．．．", "あちこちの長屋が", "それぞれ勝手に", "増築したのに．．．"]}, {"box": [208, 75, 342, 172], "vertical": true, "font_size": 21, "lines_coords": [[[322.0, 75.0], [342.0, 75.0], [342.0, 152.0], [322.0, 152.0]], [[298.0, 75.0], [319.0, 75.0], [319.0, 157.0], [298.0, 157.0]], [[275.0, 76.0], [299.0, 76.0], [299.0, 153.0], [275.0, 153.0]], [[251.0, 76.0], [271.0, 76.0], [274.0, 172.0], [254.0, 172.0]], [[227.0, 75.0], [251.0, 76.0], [249.0, 154.0], [224.0, 153.0]], [[208.0, 76.0], [229.0, 76.0], [229.0, 97.0], [208.0, 97.0]]], "lines": ["どうして", "こんなに", "ぴったり", "つながった", "のかしら", "？"]}, {"box": [120, 165, 234, 298], "vertical": true, "font_size": 21, "lines_coords": [[[213.0, 165.0], [234.0, 165.0], [234.0, 230.0], [213.0, 230.0]], [[192.0, 167.0], [208.0, 167.0], [208.0, 280.0], [192.0, 280.0]], [[165.0, 165.0], [186.0, 165.0], [187.0, 298.0], [166.0, 298.0]], [[141.0, 165.0], [162.0, 165.0], [165.0, 262.0], [144.0, 262.0]], [[120.0, 167.0], [140.0, 167.0], [140.0, 262.0], [120.0, 262.0]]], "lines": ["まるで、", "うずまき形に", "増築される事を", "予想してた", "みたい．．．"]}, {"box": [681, 339, 775, 420], "vertical": true, "font_size": 24, "lines_coords": [[[746.0, 341.0], [773.0, 339.0], [775.0, 406.0], [748.0, 407.0]], [[726.0, 342.0], [752.0, 342.0], [752.0, 404.0], [726.0, 404.0]], [[705.0, 343.0], [726.0, 343.0], [726.0, 420.0], [705.0, 420.0]], [[681.0, 343.0], [703.0, 343.0], [703.0, 420.0], [681.0, 420.0]]], "lines": ["．．．逆に、", "こうは", "考えられ", "ないか？"]}, {"box": [498, 330, 589, 483], "vertical": true, "font_size": 20, "lines_coords": [[[568.0, 331.0], [588.0, 331.0], [588.0, 464.0], [568.0, 464.0]], [[542.0, 330.0], [562.0, 330.0], [564.0, 483.0], [544.0, 483.0]], [[519.0, 330.0], [540.0, 330.0], [542.0, 465.0], [521.0, 465.0]], [[498.0, 332.0], [519.0, 332.0], [519.0, 398.0], [498.0, 398.0]]], "lines": ["例の長屋の廃屋", "自体が、そもそも", "昔は渦を巻いて", "いたと。"]}, {"box": [371, 341, 466, 438], "vertical": true, "font_size": 21, "lines_coords": [[[440.0, 341.0], [466.0, 341.0], [466.0, 404.0], [440.0, 404.0]], [[419.0, 343.0], [440.0, 343.0], [440.0, 420.0], [419.0, 420.0]], [[397.0, 343.0], [417.0, 343.0], [417.0, 438.0], [397.0, 438.0]], [[371.0, 342.0], [397.0, 342.0], [397.0, 403.0], [371.0, 403.0]]], "lines": ["．．．昔．．．", "この町は", "渦を巻いて", "いて．．．"]}, {"box": [132, 335, 316, 468], "vertical": true, "font_size": 21, "lines_coords": [[[296.0, 336.0], [316.0, 336.0], [316.0, 431.0], [296.0, 431.0]], [[274.0, 337.0], [294.0, 337.0], [294.0, 438.0], [274.0, 438.0]], [[248.0, 335.0], [269.0, 335.0], [270.0, 451.0], [249.0, 451.0]], [[226.0, 336.0], [246.0, 336.0], [246.0, 468.0], [226.0, 468.0]], [[202.0, 336.0], [222.0, 336.0], [222.0, 413.0], [202.0, 413.0]], [[181.0, 337.0], [198.0, 337.0], [198.0, 431.0], [181.0, 431.0]], [[155.0, 337.0], [176.0, 337.0], [176.0, 450.0], [155.0, 450.0]], [[132.0, 336.0], [153.0, 336.0], [153.0, 414.0], [132.0, 414.0]]], "lines": ["それが長い", "年月の間に、", "徐々に朽ちて", "いき、わずかな", "名残りが", "あちこちに", "残っていたの", "だと．．．"]}, {"box": [704, 699, 772, 822], "vertical": true, "font_size": 19, "lines_coords": [[[748.0, 699.0], [769.0, 699.0], [772.0, 801.0], [751.0, 801.0]], [[727.0, 701.0], [747.0, 701.0], [747.0, 796.0], [727.0, 796.0]], [[704.0, 701.0], [721.0, 701.0], [722.0, 817.0], [705.0, 817.0]]], "lines": ["したがって、", "むしろ今の", "この町の姿は"]}, {"box": [614, 604, 635, 662], "vertical": true, "font_size": 21, "lines_coords": [[[614.0, 604.0], [635.0, 604.0], [635.0, 662.0], [614.0, 662.0]]], "lines": ["えっ！？"]}, {"box": [462, 708, 531, 863], "vertical": true, "font_size": 21, "lines_coords": [[[509.0, 710.0], [529.0, 710.0], [528.0, 863.0], [508.0, 863.0]], [[485.0, 708.0], [508.0, 708.0], [506.0, 847.0], [482.0, 847.0]], [[462.0, 711.0], [482.0, 711.0], [482.0, 825.0], [462.0, 825.0]]], "lines": ["昔の時代の再現に", "すぎないのでは", "ないかと．．．"]}, {"box": [407, 710, 422, 752], "vertical": true, "font_size": 15, "lines_coords": [[[407.0, 710.0], [422.0, 710.0], [422.0, 752.0], [407.0, 752.0]]], "lines": ["．．．．．"]}, {"box": [246, 712, 290, 810], "vertical": true, "font_size": 23, "lines_coords": [[[270.0, 713.0], [290.0, 713.0], [290.0, 808.0], [270.0, 808.0]], [[246.0, 712.0], [265.0, 712.0], [268.0, 810.0], [248.0, 810.0]]], "lines": ["何が何だか", "わからない"]}, {"box": [118, 710, 214, 807], "vertical": true, "font_size": 23, "lines_coords": [[[183.0, 710.0], [214.0, 710.0], [214.0, 766.0], [183.0, 766.0]], [[164.0, 710.0], [188.0, 710.0], [188.0, 791.0], [164.0, 791.0]], [[142.0, 710.0], [162.0, 710.0], [160.0, 807.0], [140.0, 807.0]], [[118.0, 713.0], [139.0, 713.0], [139.0, 789.0], [118.0, 789.0]]], "lines": ["私達、", "これから", "どうすれば", "いいの？"]}], "img_path": "177.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [652, 80, 724, 199], "vertical": true, "font_size": 22, "lines_coords": [[[695.0, 80.0], [724.0, 80.0], [724.0, 146.0], [695.0, 146.0]], [[676.0, 84.0], [692.0, 84.0], [692.0, 192.0], [676.0, 192.0]], [[652.0, 84.0], [672.0, 84.0], [672.0, 199.0], [652.0, 199.0]]], "lines": ["．．．私．．．", "この町の中へ", "入ってみる．．．"]}, {"box": [486, 87, 557, 193], "vertical": true, "font_size": 20, "lines_coords": [[[536.0, 89.0], [557.0, 90.0], [554.0, 183.0], [533.0, 182.0]], [[511.0, 90.0], [530.0, 90.0], [530.0, 185.0], [511.0, 185.0]], [[486.0, 87.0], [506.0, 87.0], [508.0, 193.0], [488.0, 193.0]]], "lines": ["お父さんと", "お母さんを", "捜さなきゃ。"]}, {"box": [358, 94, 450, 215], "vertical": true, "font_size": 22, "lines_coords": [[[430.0, 96.0], [450.0, 96.0], [450.0, 215.0], [430.0, 215.0]], [[405.0, 96.0], [425.0, 96.0], [425.0, 210.0], [405.0, 210.0]], [[384.0, 97.0], [400.0, 97.0], [400.0, 191.0], [384.0, 191.0]], [[358.0, 94.0], [379.0, 94.0], [379.0, 173.0], [358.0, 173.0]]], "lines": ["だから２人共、", "私にかまわず", "脱出の道を", "探して！"]}, {"box": [247, 94, 321, 176], "vertical": true, "font_size": 22, "lines_coords": [[[288.0, 94.0], [321.0, 94.0], [321.0, 142.0], [288.0, 142.0]], [[269.0, 96.0], [294.0, 97.0], [291.0, 176.0], [267.0, 175.0]], [[247.0, 98.0], [268.0, 98.0], [268.0, 161.0], [247.0, 161.0]]], "lines": ["私は", "あとから", "行くわ"]}, {"box": [443, 402, 486, 521], "vertical": true, "font_size": 18, "lines_coords": [[[465.0, 403.0], [485.0, 403.0], [485.0, 521.0], [465.0, 521.0]], [[444.0, 404.0], [460.0, 404.0], [460.0, 502.0], [444.0, 502.0]]], "lines": ["何を言うのよ、", "桐絵ちゃん。"]}, {"box": [73, 417, 117, 532], "vertical": true, "font_size": 18, "lines_coords": [[[94.0, 418.0], [114.0, 418.0], [114.0, 532.0], [94.0, 532.0]], [[73.0, 418.0], [90.0, 418.0], [90.0, 512.0], [73.0, 512.0]]], "lines": ["私達も一緒に", "捜すわよ！"]}, {"box": [351, 677, 412, 755], "vertical": true, "font_size": 18, "lines_coords": [[[394.0, 678.0], [411.0, 678.0], [411.0, 753.0], [394.0, 753.0]], [[370.0, 677.0], [390.0, 677.0], [390.0, 755.0], [370.0, 755.0]]], "lines": ["行けども", "行けども"]}, {"box": [64, 669, 132, 828], "vertical": true, "font_size": 20, "lines_coords": [[[111.0, 669.0], [131.0, 669.0], [131.0, 802.0], [111.0, 802.0]], [[87.0, 670.0], [107.0, 670.0], [107.0, 822.0], [87.0, 822.0]], [[64.0, 670.0], [84.0, 670.0], [84.0, 828.0], [64.0, 828.0]]], "lines": ["だが、どこかに", "長屋の露地に入る", "入口があるはずだ。"]}, {"box": [290, 957, 404, 1072], "vertical": true, "font_size": 20, "lines_coords": [[[383.0, 957.0], [403.0, 957.0], [403.0, 1057.0], [383.0, 1057.0]], [[359.0, 957.0], [380.0, 957.0], [382.0, 1072.0], [360.0, 1072.0]], [[339.0, 957.0], [356.0, 957.0], [356.0, 1069.0], [339.0, 1069.0]], [[315.0, 958.0], [335.0, 958.0], [335.0, 1072.0], [315.0, 1072.0]], [[290.0, 957.0], [310.0, 957.0], [310.0, 1040.0], [290.0, 1040.0]]], "lines": ["その露地も、", "長屋に沿って", "うずまき状に", "なっているん", "だからな"]}], "img_path": "178.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [698, 60, 788, 143], "vertical": true, "font_size": 22, "lines_coords": [[[767.0, 63.0], [788.0, 63.0], [788.0, 140.0], [767.0, 140.0]], [[741.0, 60.0], [767.0, 60.0], [767.0, 107.0], [741.0, 107.0]], [[720.0, 63.0], [741.0, 63.0], [741.0, 140.0], [720.0, 140.0]], [[698.0, 63.0], [718.0, 63.0], [718.0, 142.0], [698.0, 142.0]]], "lines": ["しばらく", "歩き", "続けると", "ようやく"]}, {"box": [111, 55, 180, 264], "vertical": true, "font_size": 20, "lines_coords": [[[157.0, 57.0], [176.0, 57.0], [176.0, 263.0], [157.0, 263.0]], [[135.0, 56.0], [155.0, 56.0], [152.0, 228.0], [132.0, 228.0]], [[112.0, 55.0], [132.0, 55.0], [131.0, 199.0], [111.0, 199.0]]], "lines": ["露地の入口が、ほっかり", "口を開けているのが", "見つかりました。"]}], "img_path": "179.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [688, 194, 