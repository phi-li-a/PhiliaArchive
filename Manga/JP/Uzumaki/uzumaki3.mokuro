.0, 1085.0], [575.0, 1086.0]], [[559.0, 1046.0], [574.0, 1046.0], [574.0, 1065.0], [559.0, 1065.0]]], "lines": ["これは", "．．．"]}, {"box": [488, 862, 535, 942], "vertical": true, "font_size": 22, "lines_coords": [[[511.0, 862.0], [535.0, 862.0], [535.0, 942.0], [511.0, 942.0]], [[488.0, 862.0], [509.0, 862.0], [509.0, 939.0], [488.0, 939.0]]], "lines": ["何なの？", "これ．．．"]}, {"box": [348, 862, 395, 998], "vertical": true, "font_size": 20, "lines_coords": [[[375.0, 862.0], [394.0, 862.0], [392.0, 998.0], [372.0, 998.0]], [[350.0, 862.0], [371.0, 862.0], [369.0, 960.0], [348.0, 960.0]]], "lines": ["さっき、確かに", "動いてた．．．"]}, {"box": [72, 850, 171, 969], "vertical": true, "font_size": 28, "lines_coords": [[[139.0, 851.0], [171.0, 851.0], [171.0, 916.0], [139.0, 916.0]], [[118.0, 850.0], [150.0, 850.0], [150.0, 902.0], [118.0, 902.0]], [[97.0, 854.0], [118.0, 854.0], [119.0, 969.0], [98.0, 969.0]], [[72.0, 853.0], [98.0, 853.0], [98.0, 916.0], [72.0, 916.0]]], "lines": ["これは", "．．．．．．", "ヒトマイマイ", "だわ．．．"]}], "img_path": "082.jpg"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [536, 73, 584, 154], "vertical": true, "font_size": 24, "lines_coords": [[[555.0, 75.0], [582.0, 73.0], [584.0, 126.0], [557.0, 127.0]], [[536.0, 76.0], [557.0, 76.0], [557.0, 154.0], [536.0, 154.0]]], "lines": ["あっ、", "見てっ！！"]}, {"box": [680, 657, 771, 735], "vertical": true, "font_size": 21, "lines_coords": [[[749.0, 657.0], [770.0, 657.0], [770.0, 735.0], [749.0, 735.0]], [[726.0, 658.0], [747.0, 658.0], [747.0, 735.0], [726.0, 735.0]], [[702.0, 657.0], [724.0, 657.0], [724.0, 734.0], [702.0, 734.0]], [[680.0, 657.0], [701.0, 657.0], [701.0, 699.0], [680.0, 699.0]]], "lines": ["あれは．．．", "元は人間", "なんです", "．．．．．"]}, {"box": [580, 673, 647, 890], "vertical": true, "font_size": 19, "lines_coords": [[[626.0, 673.0], [646.0, 673.0], [646.0, 890.0], [626.0, 890.0]], [[601.0, 673.0], [622.0, 673.0], [623.0, 866.0], [602.0, 866.0]], [[581.0, 675.0], [597.0, 675.0], [597.0, 847.0], [581.0, 847.0]]], "lines": ["この町は呪われてるから、", "人がカタツムリに変身", "したりするんです．．．"]}, {"box": [474, 656, 545, 753], "vertical": true, "font_size": 23, "lines_coords": [[[521.0, 656.0], [545.0, 656.0], [545.0, 738.0], [521.0, 738.0]], [[500.0, 658.0], [521.0, 658.0], [521.0, 753.0], [500.0, 753.0]], [[474.0, 656.0], [499.0, 656.0], [499.0, 726.0], [474.0, 726.0]]], "lines": ["でも．．．", "久しぶりに", "見たわ。"]}, {"box": [125, 652, 216, 733], "vertical": true, "font_size": 23, "lines_coords": [[[195.0, 655.0], [216.0, 655.0], [216.0, 732.0], [195.0, 732.0]], [[168.0, 652.0], [196.0, 652.0], [196.0, 700.0], [168.0, 700.0]], [[149.0, 656.0], [171.0, 656.0], [171.0, 731.0], [149.0, 731.0]], [[125.0, 656.0], [146.0, 656.0], [146.0, 733.0], [125.0, 733.0]]], "lines": ["どうして", "また", "現れたの", "かしら．．．"]}, {"box": [743, 950, 765, 1085], "vertical": true, "font_size": 20, "lines_coords": [[[743.0, 950.0], [763.0, 950.0], [763.0, 1085.0], [743.0, 1085.0]]], "lines": ["．．．何ですって？"]}], "img_path": "083.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [688, 584, 708, 679], "vertical": true, "font_size": 16, "lines_coords": [[[690.0, 584.0], [706.0, 584.0], [706.0, 679.0], [690.0, 679.0]]], "lines": ["押すなよ！"]}, {"box": [363, 672, 409, 753], "vertical": true, "font_size": 24, "lines_coords": [[[379.0, 673.0], [406.0, 672.0], [409.0, 735.0], [382.0, 737.0]], [[363.0, 675.0], [383.0, 675.0], [383.0, 753.0], [363.0, 753.0]]], "lines": ["押して", "ねーよ！"]}, {"box": [53, 1005, 128, 1108], "vertical": true, "font_size": 27, "lines_coords": [[[96.0, 1005.0], [128.0, 1005.0], [128.0, 1108.0], [96.0, 1108.0]], [[77.0, 1008.0], [101.0, 1008.0], [101.0, 1106.0], [77.0, 1106.0]], [[53.0, 1006.0], [78.0, 1006.0], [78.0, 1076.0], [53.0, 1076.0]]], "lines": ["おい、また", "人が入って", "きたぞ。"]}], "img_path": "084.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [726, 79, 772, 255], "vertical": true, "font_size": 20, "lines_coords": [[[751.0, 82.0], [771.0, 82.0], [771.0, 251.0], [751.0, 251.0]], [[729.0, 79.0], [748.0, 79.0], [746.0, 255.0], [726.0, 255.0]]], "lines": ["これ以上入れないっ", "ちゅーの、出てけ！！"]}, {"box": [276, 91, 342, 245], "vertical": true, "font_size": 19, "lines_coords": [[[321.0, 92.0], [341.0, 92.0], [341.0, 193.0], [321.0, 193.0]], [[298.0, 91.0], [318.0, 91.0], [318.0, 208.0], [298.0, 208.0]], [[276.0, 93.0], [293.0, 93.0], [293.0, 244.0], [276.0, 244.0]]], "lines": ["．．．でも私達", "前からここに", "住んでるんです！"]}, {"box": [678, 333, 772, 464], "vertical": true, "font_size": 24, "lines_coords": [[[745.0, 335.0], [770.0, 335.0], [772.0, 417.0], [747.0, 417.0]], [[726.0, 337.0], [747.0, 337.0], [747.0, 421.0], [726.0, 421.0]], [[697.0, 335.0], [726.0, 333.0], [729.0, 396.0], [699.0, 397.0]], [[678.0, 338.0], [699.0, 338.0], [700.0, 464.0], [679.0, 464.0]]], "lines": ["桐絵．．．．．．", "こっちよ、", "ここへ", "いらっしゃい。"]}, {"box": [595, 344, 615, 428], "vertical": true, "font_size": 20, "lines_coords": [[[595.0, 344.0], [615.0, 344.0], [615.0, 428.0], [595.0, 428.0]]], "lines": ["お母さん。"]}, {"box": [343, 508, 484, 609], "vertical": true, "font_size": 25, "lines_coords": [[[459.0, 510.0], [484.0, 510.0], [484.0, 577.0], [459.0, 577.0]], [[439.0, 512.0], [459.0, 512.0], [459.0, 609.0], [439.0, 609.0]], [[414.0, 512.0], [434.0, 512.0], [434.0, 590.0], [414.0, 590.0]], [[386.0, 509.0], [417.0, 509.0], [417.0, 574.0], [386.0, 574.0]], [[362.0, 509.0], [392.0, 508.0], [394.0, 573.0], [364.0, 574.0]], [[343.0, 510.0], [364.0, 510.0], [364.0, 598.0], [343.0, 598.0]]], "lines": ["あ～あ", "まったく．．", "どんどん", "人間が", "入って", "きやがる。"]}, {"box": [707, 653, 774, 808], "vertical": true, "font_size": 20, "lines_coords": [[[754.0, 655.0], [774.0, 655.0], [774.0, 808.0], [754.0, 808.0]], [[730.0, 653.0], [751.0, 653.0], [748.0, 771.0], [727.0, 771.0]], [[707.0, 653.0], [727.0, 653.0], [727.0, 771.0], [707.0, 771.0]]], "lines": ["このボロ屋だけは", "竜巻の被害を", "受けないし．．"]}, {"box": [404, 646, 495, 844], "vertical": true, "font_size": 18, "lines_coords": [[[473.0, 646.0], [493.0, 646.0], [494.0, 844.0], [474.0, 844.0]], [[452.0, 649.0], [468.0, 649.0], [468.0, 781.0], [452.0, 781.0]], [[428.0, 648.0], [445.0, 648.0], [445.0, 837.0], [428.0, 837.0]], [[404.0, 646.0], [424.0, 646.0], [424.0, 771.0], [404.0, 771.0]]], "lines": ["この中では外と違って、", "普通に動いても", "竜巻が起こりにくくて", "安全だからだ。"]}, {"box": [297, 639, 367, 757], "vertical": true, "font_size": 24, "lines_coords": [[[345.0, 642.0], [365.0, 642.0], [365.0, 757.0], [345.0, 757.0]], [[317.0, 639.0], [348.0, 639.0], [348.0, 685.0], [317.0, 685.0]], [[297.0, 639.0], [317.0, 639.0], [319.0, 726.0], [300.0, 726.0]]], "lines": ["他のボロ屋も", "同じ", "だろうな。"]}, {"box": [116, 656, 188, 734], "vertical": true, "font_size": 24, "lines_coords": [[[162.0, 658.0], [188.0, 658.0], [188.0, 718.0], [162.0, 718.0]], [[139.0, 656.0], [160.0, 656.0], [160.0, 734.0], [139.0, 734.0]], [[116.0, 657.0], [140.0, 657.0], [140.0, 719.0], [116.0, 719.0]]], "lines": ["おや？", "．．．これは", "何だ？"]}, {"box": [730, 882, 774, 1075], "vertical": true, "font_size": 20, "lines_coords": [[[751.0, 882.0], [774.0, 882.0], [774.0, 1075.0], [751.0, 1075.0]], [[731.0, 883.0], [748.0, 883.0], [747.0, 1045.0], [730.0, 1045.0]]], "lines": ["しかし、こんなに人が", "入ってきちゃあな。"]}, {"box": [405, 883, 494, 1098], "vertical": true, "font_size": 20, "lines_coords": [[[473.0, 884.0], [493.0, 884.0], [493.0, 1058.0], [473.0, 1058.0]], [[450.0, 884.0], [471.0, 884.0], [468.0, 1098.0], [447.0, 1098.0]], [[426.0, 883.0], [447.0, 883.0], [446.0, 1075.0], [425.0, 1075.0]], [[405.0, 885.0], [421.0, 885.0], [421.0, 1006.0], [405.0, 1006.0]]], "lines": ["そのうち人間が積み", "重なるんじゃないのか？", "昔、そんな喜劇映画が", "あっただろう。"]}], "img_path": "085.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [246, 83, 313, 187], "vertical": true, "font_size": 20, "lines_coords": [[[293.0, 84.0], [312.0, 84.0], [312.0, 179.0], [293.0, 179.0]], [[269.0, 83.0], [289.0, 83.0], [289.0, 178.0], [269.0, 178.0]], [[246.0, 84.0], [266.0, 84.0], [266.0, 187.0], [246.0, 187.0]]], "lines": ["土壁の中に", "こんな物が", "入ってたぞ。"]}, {"box": [49, 207, 94, 332], "vertical": true, "font_size": 20, "lines_coords": [[[71.0, 207.0], [91.0, 207.0], [93.0, 323.0], [73.0, 323.0]], [[49.0, 208.0], [69.0, 208.0], [69.0, 328.0], [49.0, 328.0]]], "lines": ["塗り込められ", "てたみたいだ。"]}, {"box": [657, 386, 721, 465], "vertical": true, "font_size": 22, "lines_coords": [[[696.0, 386.0], [721.0, 386.0], [721.0, 447.0], [696.0, 447.0]], [[676.0, 389.0], [696.0, 389.0], [696.0, 465.0], [676.0, 465.0]]], "lines": ["巻物の", "ようだな"]}, {"box": [622, 519, 716, 624], "vertical": true, "font_size": 22, "lines_coords": [[[689.0, 519.0], [716.0, 519.0], [716.0, 564.0], [689.0, 564.0]], [[669.0, 521.0], [689.0, 521.0], [689.0, 623.0], [669.0, 623.0]], [[644.0, 521.0], [665.0, 521.0], [665.0, 600.0], [644.0, 600.0]], [[622.0, 522.0], [643.0, 522.0], [643.0, 587.0], [622.0, 587.0]]], "lines": ["随分", "古そうだな。", "中を見て", "みろよ。"]}, {"box": [321, 573, 343, 621], "vertical": true, "font_size": 22, "lines_coords": [[[321.0, 573.0], [343.0, 573.0], [343.0, 621.0], [321.0, 621.0]]], "lines": ["ああ。"]}, {"box": [60, 377, 90, 440], "vertical": true, "font_size": 27, "lines_coords": [[[60.0, 378.0], [87.0, 377.0], [90.0, 439.0], [63.0, 440.0]]], "lines": ["あっ．．．"]}, {"box": [441, 679, 512, 802], "vertical": true, "font_size": 20, "lines_coords": [[[491.0, 680.0], [511.0, 680.0], [511.0, 799.0], [491.0, 799.0]], [[467.0, 682.0], [487.0, 682.0], [487.0, 769.0], [467.0, 769.0]], [[441.0, 679.0], [461.0, 679.0], [464.0, 796.0], [444.0, 796.0]]], "lines": ["痛えなてめえ、", "このヤロー", "降りてこい！！"]}, {"box": [169, 667, 240, 765], "vertical": true, "font_size": 23, "lines_coords": [[[210.0, 669.0], [237.0, 667.0], [240.0, 733.0], [213.0, 734.0]], [[192.0, 670.0], [213.0, 670.0], [213.0, 765.0], [192.0, 765.0]], [[169.0, 670.0], [189.0, 670.0], [189.0, 747.0], [169.0, 747.0]]], "lines": ["何だと、", "このヤロー", "殺すぞ！！"]}, {"box": [48, 696, 117, 832], "vertical": true, "font_size": 20, "lines_coords": [[[97.0, 697.0], [117.0, 697.0], [117.0, 794.0], [97.0, 794.0]], [[73.0, 697.0], [93.0, 697.0], [93.0, 794.0], [73.0, 794.0]], [[50.0, 696.0], [71.0, 696.0], [69.0, 832.0], [48.0, 832.0]]], "lines": ["殺せるもん", "なら殺して", "みろっつーの！！"]}, {"box": [548, 902, 573, 963], "vertical": true, "font_size": 25, "lines_coords": [[[548.0, 902.0], [573.0, 902.0], [573.0, 963.0], [548.0, 963.0]]], "lines": ["いて！！"]}, {"box": [276, 993, 373, 1081], "vertical": true, "font_size": 26, "lines_coords": [[[345.0, 994.0], [370.0, 993.0], [373.0, 1080.0], [349.0, 1081.0]], [[323.0, 996.0], [349.0, 996.0], [349.0, 1075.0], [323.0, 1075.0]], [[297.0, 996.0], [326.0, 996.0], [326.0, 1076.0], [297.0, 1076.0]], [[276.0, 997.0], [302.0, 997.0], [302.0, 1060.0], [276.0, 1060.0]]], "lines": ["うるせー、", "てめーが", "上がって", "こい！！"]}], "img_path": "086.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [713, 93, 779, 173], "vertical": true, "font_size": 21, "lines_coords": [[[737.0, 96.0], [758.0, 96.0], [758.0, 173.0], [737.0, 173.0]], [[713.0, 93.0], [734.0, 93.0], [734.0, 157.0], [713.0, 157.0]]], "lines": ["何かしら", "これ？"]}, {"box": [736, 549, 781, 665], "vertical": true, "font_size": 20, "lines_coords": [[[760.0, 549.0], [781.0, 549.0], [781.0, 646.0], [760.0, 646.0]], [[736.0, 549.0], [755.0, 549.0], [758.0, 665.0], [738.0, 665.0]]], "lines": ["．．．地図．．．", "のようね．．．"]}, {"box": [650, 737, 771, 837], "vertical": true, "font_size": 27, "lines_coords": [[[744.0, 738.0], [771.0, 738.0], [771.0, 782.0], [744.0, 782.0]], [[723.0, 741.0], [744.0, 741.0], [744.0, 837.0], [723.0, 837.0]], [[695.0, 737.0], [725.0, 737.0], [725.0, 793.0], [695.0, 793.0]], [[670.0, 738.0], [700.0, 738.0], [700.0, 803.0], [670.0, 803.0]], [[650.0, 739.0], [675.0, 739.0], [675.0, 802.0], [650.0, 802.0]]], "lines": ["ねえ", "お父さん．．．", "これ、", "何だと", "思う？"]}, {"box": [452, 550, 524, 686], "vertical": true, "font_size": 19, "lines_coords": [[[501.0, 551.0], [522.0, 551.0], [522.0, 630.0], [501.0, 630.0]], [[473.0, 550.0], [493.0, 550.0], [495.0, 686.0], [475.0, 686.0]], [[452.0, 554.0], [468.0, 554.0], [468.0, 673.0], [452.0, 673.0]]], "lines": ["でも墨が", "滲んでて、よく", "わからないわ。"]}, {"box": [486, 739, 509, 782], "vertical": true, "font_size": 23, "lines_coords": [[[486.0, 739.0], [509.0, 739.0], [509.0, 782.0], [486.0, 782.0]]], "lines": ["あ．．．"]}, {"box": [285, 738, 307, 816], "vertical": true, "font_size": 22, "lines_coords": [[[285.0, 738.0], [307.0, 738.0], [307.0, 815.0], [285.0, 815.0]]], "lines": ["ああ．．．"]}, {"box": [127, 548, 174, 701], "vertical": true, "font_size": 20, "lines_coords": [[[152.0, 548.0], [172.0, 548.0], [172.0, 701.0], [152.0, 701.0]], [[128.0, 548.0], [148.0, 548.0], [147.0, 683.0], [127.0, 683.0]]], "lines": ["この．．．渦巻模様は", "何なのかしら？"]}, {"box": [434, 937, 505, 1093], "vertical": true, "font_size": 21, "lines_coords": [[[482.0, 939.0], [502.0, 939.0], [505.0, 1037.0], [485.0, 1037.0]], [[457.0, 937.0], [480.0, 937.0], [482.0, 1093.0], [459.0, 1093.0]], [[434.0, 939.0], [454.0, 939.0], [457.0, 1060.0], [437.0, 1060.0]]], "lines": ["お母さん．．．", "この頃、お父さん", "元気ないわね。"]}, {"box": [111, 943, 151, 1029], "vertical": true, "font_size": 16, "lines_coords": [[[111.0, 944.0], [127.0, 944.0], [127.0, 1027.0], [111.0, 1027.0]]], "lines": ["そうなの"]}], "img_path": "087.jpg"}, {"version": "0.1.7", "img_width": 836, "img_height": 1200, "blocks": [{"box": [623, 85, 715, 203], "vertical": true, "font_size": 21, "lines_coords": [[[695.0, 89.0], [715.0, 89.0], [715.0, 185.0], [695.0, 185.0]], [[668.0, 85.0], [692.0, 85.0], [695.0, 174.0], [670.0, 174.0]], [[648.0, 89.0], [668.0, 89.0], [668.0, 203.0], [648.0, 203.0]], [[623.0, 87.0], [643.0, 87.0], [646.0, 186.0], [626.0, 186.0]]], "lines": ["おいこら！！", "それ返せ、", "オレが見つけ", "たんだぞ！！"]}, {"box": [383, 86, 453, 201], "vertical": true, "font_size": 23, "lines_coords": [[[426.0, 87.0], [453.0, 87.0], [453.0, 147.0], [426.0, 147.0]], [[405.0, 87.0], [426.0, 87.0], [429.0, 188.0], [408.0, 188.0]], [[383.0, 86.0], [403.0, 86.0], [405.0, 201.0], [385.0, 201.0]]], "lines": ["オレの", "お宝を返せ、", "ドロボー！！"]}, {"box": [306, 215, 349, 346], "vertical": true, "font_size": 20, "lines_coords": [[[329.0, 216.0], [349.0, 216.0], [349.0, 346.0], [329.0, 346.0]], [[308.0, 215.0], [328.0, 215.0], [325.0, 295.0], [306.0, 295.0]]], "lines": ["もう．．．やんなっ", "ちゃう．．．"]}, {"box": [67, 86, 84, 149], "vertical": true, "font_size": 17, "lines_coords": [[[67.0, 86.0], [84.0, 86.0], [84.0, 149.0], [67.0, 149.0]]], "lines": ["．．．．．．"]}, {"box": [59, 200, 107, 373], "vertical": true, "font_size": 22, "lines_coords": [[[85.0, 202.0], [105.0, 202.0], [105.0, 373.0], [85.0, 373.0]], [[59.0, 200.0], [84.0, 200.0], [84.0, 268.0], [59.0, 268.0]]], "lines": ["みんな、イラ立って", "るのよ。"]}, {"box": [571, 462, 710, 588], "vertical": true, "font_size": 22, "lines_coords": [[[688.0, 462.0], [709.0, 462.0], [710.0, 578.0], [689.0, 578.0]], [[664.0, 464.0], [685.0, 464.0], [685.0, 542.0], [664.0, 542.0]], [[640.0, 462.0], [664.0, 462.0], [664.0, 542.0], [640.0, 542.0]], [[616.0, 464.0], [640.0, 464.0], [640.0, 588.0], [616.0, 588.0]], [[594.0, 464.0], [614.0, 464.0], [614.0, 580.0], [594.0, 580.0]], [[571.0, 464.0], [590.0, 464.0], [590.0, 561.0], [571.0, 561.0]]], "lines": ["あ～腹減った", "．．．おい！！", "新入りの", "ボランティア、", "もう食い物は", "ないのか？"]}, {"box": [379, 460, 472, 568], "vertical": true, "font_size": 22, "lines_coords": [[[449.0, 461.0], [470.0, 461.0], [472.0, 568.0], [451.0, 568.0]], [[424.0, 460.0], [450.0, 460.0], [450.0, 523.0], [424.0, 523.0]], [[403.0, 464.0], [424.0, 464.0], [424.0, 558.0], [403.0, 558.0]], [[379.0, 462.0], [399.0, 462.0], [399.0, 547.0], [379.0, 547.0]]], "lines": ["ないですよ。", "きのう", "配ったのが", "最後です。"]}, {"box": [241, 471, 333, 607], "vertical": true, "font_size": 22, "lines_coords": [[[310.0, 471.0], [331.0, 471.0], [332.0, 568.0], [311.0, 568.0]], [[286.0, 471.0], [310.0, 471.0], [310.0, 607.0], [286.0, 607.0]], [[263.0, 472.0], [286.0, 472.0], [286.0, 588.0], [263.0, 588.0]], [[241.0, 472.0], [261.0, 472.0], [261.0, 578.0], [241.0, 578.0]]], "lines": ["何だとっ！？", "貴様、それでも", "ボランティア", "か！！ボケ！！"]}, {"box": [69, 466, 162, 602], "vertical": true, "font_size": 21, "lines_coords": [[[141.0, 467.0], [161.0, 467.0], [161.0, 564.0], [141.0, 564.0]], [[116.0, 466.0], [139.0, 466.0], [139.0, 584.0], [116.0, 584.0]], [[93.0, 468.0], [113.0, 468.0], [113.0, 602.0], [93.0, 602.0]], [[69.0, 467.0], [89.0, 467.0], [91.0, 566.0], [71.0, 566.0]]], "lines": ["何ですか！", "そんな言い方", "される筋合いは", "ないぞっ！！"]}, {"box": [661, 777, 724, 874], "vertical": true, "font_size": 20, "lines_coords": [[[704.0, 778.0], [724.0, 778.0], [724.0, 873.0], [704.0, 873.0]], [[680.0, 779.0], [701.0, 779.0], [701.0, 874.0], [680.0, 874.0]]], "lines": ["．．．狂ってる", "．．．狂ってる"]}, {"box": [417, 774, 461, 867], "vertical": true, "font_size": 20, "lines_coords": [[[439.0, 774.0], [460.0, 774.0], [460.0, 849.0], [439.0, 849.0]], [[417.0, 774.0], [437.0, 774.0], [437.0, 867.0], [417.0, 867.0]]], "lines": ["この町は", "狂ってる．．．"]}, {"box": [239, 769, 359, 889], "vertical": true, "font_size": 21, "lines_coords": [[[337.0, 772.0], [357.0, 772.0], [357.0, 889.0], [337.0, 889.0]], [[314.0, 773.0], [335.0, 773.0], [335.0, 869.0], [314.0, 869.0]], [[290.0, 773.0], [311.0, 773.0], [311.0, 869.0], [290.0, 869.0]], [[269.0, 773.0], [286.0, 773.0], [286.0, 869.0], [269.0, 869.0]], [[241.0, 769.0], [268.0, 771.0], [266.0, 816.0], [239.0, 815.0]]], "lines": ["おい、お前！", "この間から", "ブツブツと", "うるさいん", "だ！！"]}, {"box": [63, 658, 113, 740], "vertical": true, "font_size": 26, "lines_coords": [[[86.0, 658.0], [113.0, 658.0], [113.0, 708.0], [86.0, 708.0]], [[63.0, 660.0], [87.0, 660.0], [87.0, 740.0], [63.0, 740.0]]], "lines": ["もう、", "いやっ．．．"]}, {"box": [56, 786, 139, 883], "vertical": true, "font_size": 31, "lines_coords": [[[111.0, 788.0], [139.0, 788.0], [139.0, 883.0], [111.0, 883.0]], [[77.0, 786.0], [117.0, 786.0], [117.0, 853.0], [77.0, 853.0]], [[56.0, 788.0], [80.0, 788.0], [80.0, 860.0], [56.0, 860.0]]], "lines": ["聞いてる", "のか、", "こら！？"]}], "img_path": "088.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [752, 98, 772, 195], "vertical": true, "font_size": 20, "lines_coords": [[[752.0, 98.0], [772.0, 98.0], [772.0, 195.0], [752.0, 195.0]]], "lines": ["狂ってる．．．"]}, {"box": [570, 89, 593, 184], "vertical": true, "font_size": 20, "lines_coords": [[[573.0, 89.0], [593.0, 89.0], [590.0, 183.0], [570.0, 183.0]]], "lines": ["狂ってる．．"]}, {"box": [464, 69, 533, 183], "vertical": true, "font_size": 20, "lines_coords": [[[511.0, 69.0], [532.0, 69.0], [532.0, 182.0], [511.0, 182.0]], [[487.0, 69.0], [507.0, 69.0], [507.0, 151.0], [487.0, 151.0]], [[464.0, 69.0], [484.0, 69.0], [484.0, 147.0], [464.0, 147.0]]], "lines": ["お前、目障り", "なんだよ", "うせろ！！"]}, {"box": [750, 305, 769, 400], "vertical": true, "font_size": 16, "lines_coords": [[[751.0, 305.0], [767.0, 305.0], [767.0, 399.0], [751.0, 399.0]]], "lines": ["何だとお？"]}, {"box": [764, 473, 785, 551], "vertical": true, "font_size": 21, "lines_coords": [[[764.0, 473.0], [785.0, 473.0], [785.0, 551.0], [764.0, 551.0]]], "lines": ["秀一君！！"]}, {"box": [727, 773, 774, 851], "vertical": true, "font_size": 22, "lines_coords": [[[750.0, 773.0], [774.0, 773.0], [774.0, 835.0], [750.0, 835.0]], [[730.0, 773.0], [751.0, 773.0], [748.0, 851.0], [727.0, 851.0]]], "lines": ["ねえ．．．", "大丈夫？"]}, {"box": [248, 656, 296, 738], "vertical": true, "font_size": 25, "lines_coords": [[[271.0, 656.0], [296.0, 656.0], [296.0, 721.0], [271.0, 721.0]], [[248.0, 658.0], [273.0, 658.0], [273.0, 738.0], [248.0, 738.0]]], "lines": ["秀一君、", "大丈夫？"]}, {"box": [303, 935, 369, 1038], "vertical": true, "font_size": 19, "lines_coords": [[[346.0, 935.0], [366.0, 935.0], [366.0, 1014.0], [346.0, 1014.0]], [[324.0, 935.0], [345.0, 935.0], [345.0, 1008.0], [324.0, 1008.0]], [[303.0, 936.0], [319.0, 936.0], [319.0, 1035.0], [303.0, 1035.0]]], "lines": ["あいつら", "もう中へ", "入れるなよ。"]}, {"box": [118, 921, 165, 1064], "vertical": true, "font_size": 20, "lines_coords": [[[141.0, 921.0], [162.0, 921.0], [165.0, 1054.0], [144.0, 1054.0]], [[118.0, 921.0], [138.0, 921.0], [140.0, 1064.0], [120.0, 1064.0]]], "lines": ["やれやれ、少し", "余裕ができたぞ。"]}], "img_path": "089.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [241, 91, 262, 156], "vertical": true, "font_size": 20, "lines_coords": [[[241.0, 91.0], [261.0, 91.0], [261.0, 120.0], [241.0, 120.0]]], "lines": ["ねー"]}, {"box": [652, 461, 721, 597], "vertical": true, "font_size": 20, "lines_coords": [[[702.0, 462.0], [721.0, 462.0], [721.0, 560.0], [702.0, 560.0]], [[677.0, 462.0], [697.0, 462.0], [697.0, 560.0], [677.0, 560.0]], [[652.0, 461.0], [672.0, 461.0], [673.0, 596.0], [653.0, 596.0]]], "lines": ["別の長屋を", "探すのよ．．．", "空いてる所を．．．"]}, {"box": [312, 457, 379, 649], "vertical": true, "font_size": 19, "lines_coords": [[[357.0, 457.0], [378.0, 457.0], [379.0, 536.0], [358.0, 536.0]], [[334.0, 457.0], [353.0, 457.0], [356.0, 649.0], [336.0, 649.0]], [[312.0, 460.0], [329.0, 460.0], [329.0, 591.0], [312.0, 591.0]]], "lines": ["皆さん．．．", "こんな町にいつまでも", "いられないわ．．"]}, {"box": [66, 316, 134, 411], "vertical": true, "font_size": 19, "lines_coords": [[[113.0, 316.0], [133.0, 316.0], [133.0, 393.0], [113.0, 393.0]], [[92.0, 317.0], [108.0, 317.0], [108.0, 411.0], [92.0, 411.0]], [[66.0, 316.0], [86.0, 316.0], [86.0, 396.0], [66.0, 396.0]]], "lines": ["これから", "どうするん", "だよ～～"]}, {"box": [66, 473, 109, 614], "vertical": true, "font_size": 18, "lines_coords": [[[89.0, 473.0], [108.0, 473.0], [108.0, 611.0], [89.0, 611.0]], [[66.0, 474.0], [83.0, 474.0], [83.0, 607.0], [66.0, 607.0]]], "lines": ["脱出すべきです、", "この町から．．．"]}, {"box": [546, 717, 725, 939], "vertical": true, "font_size": 20, "lines_coords": [[[704.0, 719.0], [725.0, 719.0], [725.0, 799.0], [704.0, 799.0]], [[680.0, 719.0], [700.0, 719.0], [700.0, 834.0], [680.0, 834.0]], [[657.0, 719.0], [677.0, 719.0], [677.0, 871.0], [657.0, 871.0]], [[634.0, 717.0], [653.0, 717.0], [651.0, 849.0], [631.0, 849.0]], [[593.0, 730.0], [612.0, 730.0], [612.0, 925.0], [593.0, 925.0]], [[569.0, 730.0], [589.0, 730.0], [587.0, 939.0], [567.0, 939.0]], [[546.0, 730.0], [566.0, 730.0], [566.0, 808.0], [546.0, 808.0]]], "lines": ["．．．でも．．．", "この町からは", "脱出できないって", "皆言ってるわ。", "それに千恵さんだって、", "一度脱出しようとしたん", "でしょ？"]}, {"box": [413, 521, 481, 684], "vertical": true, "font_size": 20, "lines_coords": [[[460.0, 521.0], [481.0, 521.0], [479.0, 637.0], [458.0, 637.0]], [[437.0, 522.0], [457.0, 522.0], [457.0, 619.0], [437.0, 619.0]], [[413.0, 522.0], [433.0, 522.0], [433.0, 684.0], [413.0, 684.0]]], "lines": ["でも、どこも", "同じだって", "言ってたじゃんか。"]}, {"box": [472, 724, 516, 820], "vertical": true, "font_size": 21, "lines_coords": [[[500.0, 725.0], [516.0, 725.0], [516.0, 820.0], [500.0, 820.0]], [[472.0, 724.0], [496.0, 724.0], [496.0, 805.0], [472.0, 805.0]]], "lines": ["え．．．ええ．．．", "確かに．．．"]}, {"box": [423, 774, 468, 875], "vertical": true, "font_size": 21, "lines_coords": [[[440.0, 774.0], [468.0, 774.0], [468.0, 823.0], [440.0, 823.0]], [[423.0, 780.0], [439.0, 780.0], [439.0, 875.0], [423.0, 875.0]]], "lines": ["一度", "試みたわ．．．"]}, {"box": [241, 723, 386, 877], "vertical": true, "font_size": 20, "lines_coords": [[[364.0, 723.0], [385.0, 723.0], [383.0, 839.0], [362.0, 839.0]], [[338.0, 724.0], [362.0, 724.0], [362.0, 843.0], [338.0, 843.0]], [[318.0, 726.0], [335.0, 726.0], [335.0, 856.0], [318.0, 856.0]], [[293.0, 723.0], [314.0, 723.0], [310.0, 842.0], [289.0, 842.0]], [[264.0, 724.0], [284.0, 724.0], [284.0, 877.0], [264.0, 877.0]], [[241.0, 723.0], [261.0, 723.0], [261.0, 819.0], [241.0, 819.0]]], "lines": ["東洋テレビの", "同僚の死や．．．", "町の状況を外に", "伝えるために", "元来たトンネルを", "通って．．．"]}, {"box": [46, 760, 117, 849], "vertical": true, "font_size": 24, "lines_coords": [[[96.0, 764.0], [116.0, 764.0], [116.0, 844.0], [96.0, 844.0]], [[66.0, 760.0], [98.0, 760.0], [98.0, 808.0], [66.0, 808.0]], [[49.0, 762.0], [70.0, 762.0], [67.0, 849.0], [46.0, 849.0]]], "lines": ["でも結局、", "無理", "だったの。"]}], "img_path": "090.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [677, 79, 769, 233], "vertical": true, "font_size": 19, "lines_coords": [[[747.0, 82.0], [768.0, 82.0], [768.0, 167.0], [747.0, 167.0]], [[723.0, 79.0], [743.0, 79.0], [743.0, 232.0], [723.0, 232.0]], [[703.0, 83.0], [719.0, 83.0], [719.0, 196.0], [703.0, 196.0]], [[677.0, 82.0], [697.0, 82.0], [697.0, 215.0], [677.0, 215.0]]], "lines": ["やっぱり、", "うずまきの呪いが", "脱出の邪魔を", "してるんだわ．．．"]}, {"box": [377, 64, 468, 147], "vertical": true, "font_size": 23, "lines_coords": [[[444.0, 65.0], [468.0, 65.0], [468.0, 147.0], [444.0, 147.0]], [[419.0, 64.0], [445.0, 64.0], [445.0, 126.0], [419.0, 126.0]], [[396.0, 64.0], [421.0, 64.0], [421.0, 127.0], [396.0, 127.0]], [[377.0, 66.0], [393.0, 66.0], [393.0, 142.0], [377.0, 142.0]]], "lines": ["．．．でも．．．", "脱出の", "方法は", "他にも．．"]}, {"box": [275, 92, 323, 154], "vertical": true, "font_size": 26, "lines_coords": [[[297.0, 92.0], [323.0, 92.0], [323.0, 154.0], [297.0, 154.0]], [[275.0, 93.0], [301.0, 93.0], [301.0, 154.0], [275.0, 154.0]]], "lines": ["．．．私は", "いい．．"]}, {"box": [117, 83, 139, 199], "vertical": true, "font_size": 20, "lines_coords": [[[117.0, 83.0], [137.0, 83.0], [139.0, 199.0], [119.0, 199.0]]], "lines": ["ここに残る．．．"]}, {"box": [372, 440, 418, 614], "vertical": true, "font_size": 22, "lines_coords": [[[394.0, 440.0], [418.0, 440.0], [418.0, 614.0], [394.0, 614.0]], [[372.0, 441.0], [392.0, 441.0], [392.0, 582.0], [372.0, 582.0]]], "lines": ["私は、この町で再び", "陶芸をやりたい。"]}, {"box": [98, 442, 170, 652], "vertical": true, "font_size": 17, "lines_coords": [[[145.0, 442.0], [165.0, 442.0], [165.0, 605.0], [145.0, 605.0]], [[123.0, 442.0], [139.0, 442.0], [139.0, 650.0], [123.0, 650.0]], [[98.0, 442.0], [114.0, 442.0], [114.0, 633.0], [98.0, 633.0]]], "lines": ["また窯を再建して、", "私なりの芸術を極めたい", "．．．うすまきの芸術を．．．"]}, {"box": [697, 701, 769, 864], "vertical": true, "font_size": 20, "lines_coords": [[[748.0, 701.0], [768.0, 701.0], [768.0, 864.0], [748.0, 864.0]], [[724.0, 703.0], [744.0, 703.0], [744.0, 834.0], [724.0, 834.0]], [[699.0, 701.0], [720.0, 701.0], [718.0, 805.0], [697.0, 805.0]]], "lines": ["それには、この町の", "トンボ池の土が", "必要なんだ。"]}, {"box": [520, 707, 634, 898], "vertical": true, "font_size": 19, "lines_coords": [[[614.0, 710.0], [634.0, 710.0], [634.0, 882.0], [614.0, 882.0]], [[589.0, 708.0], [609.0, 708.0], [609.0, 897.0], [589.0, 897.0]], [[566.0, 710.0], [586.0, 710.0], [586.0, 846.0], [566.0, 846.0]], [[542.0, 707.0], [562.0, 707.0], [560.0, 882.0], [540.0, 882.0]], [[520.0, 708.0], [536.0, 708.0], [536.0, 861.0], [520.0, 861.0]]], "lines": ["トンボ池の土って．．．", "それは無理よ、あなた。", "トンボ池は今．．．", "大渦を巻いてるから", "土を採るなんて．．．"]}], "img_path": "091.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [677, 89, 723, 187], "vertical": true, "font_size": 23, "lines_coords": [[[693.0, 89.0], [723.0, 89.0], [723.0, 158.0], [693.0, 158.0]], [[677.0, 92.0], [693.0, 92.0], [693.0, 187.0], [677.0, 187.0]]], "lines": ["．．．何だ、", "この匂い？"]}, {"box": [376, 86, 420, 185], "vertical": true, "font_size": 20, "lines_coords": [[[400.0, 86.0], [420.0, 86.0], [420.0, 185.0], [400.0, 185.0]], [[376.0, 87.0], [397.0, 87.0], [397.0, 166.0], [376.0, 166.0]]], "lines": ["うまそうな", "匂いだ．．．"]}, {"box": [69, 97, 135, 270], "vertical": true, "font_size": 19, "lines_coords": [[[114.0, 97.0], [134.0, 97.0], [134.0, 232.0], [114.0, 232.0]], [[91.0, 99.0], [111.0, 99.0], [111.0, 270.0], [91.0, 270.0]], [[69.0, 99.0], [85.0, 99.0], [85.0, 250.0], [69.0, 250.0]]], "lines": ["肉を焼くような", "匂いだぞ．．．どこかで", "焼いてるんだ．．．"]}, {"box": [567, 362, 588, 421], "vertical": true, "font_size": 21, "lines_coords": [[[567.0, 362.0], [588.0, 362.0], [588.0, 421.0], [567.0, 421.0]]], "lines": ["満男！？"]}, {"box": [323, 459, 376, 525], "vertical": true, "font_size": 28, "lines_coords": [[[346.0, 461.0], [373.0, 460.0], [376.0, 522.0], [349.0, 523.0]], [[323.0, 459.0], [352.0, 459.0], [352.0, 525.0], [323.0, 525.0]]], "lines": ["あっち", "だ．．．"]}, {"box": [182, 564, 204, 646], "vertical": true, "font_size": 21, "lines_coords": [[[182.0, 564.0], [203.0, 564.0], [203.0, 646.0], [182.0, 646.0]]], "lines": ["やっぱり、"]}, {"box": [73, 623, 119, 746], "vertical": true, "font_size": 23, "lines_coords": [[[93.0, 623.0], [119.0, 623.0], [119.0, 685.0], [93.0, 685.0]], [[73.0, 624.0], [93.0, 624.0], [93.0, 746.0], [73.0, 746.0]]], "lines": ["何かを", "焼いてるんだ。"]}], "img_path": "092.jpg"}, {"version": "0.1.7", "img_width": 833, "img_height": 1200, "blocks": [{"box": [724, 97, 769, 233], "vertical": true, "font_size": 20, "lines_coords": [[[746.0, 98.0], [766.0, 98.0], [769.0, 233.0], [749.0, 233.0]], [[724.0, 97.0], [743.0, 97.0], [746.0, 201.0], [726.0, 201.0]]], "lines": ["オレ達も分けて", "もらおうよ。"]}, {"box": [540, 76, 612, 138], "vertical": true, "font_size": 27, "lines_coords": [[[584.0, 77.0], [612.0, 77.0], [612.0, 121.0], [584.0, 121.0]], [[563.0, 76.0], [589.0, 77.0], [586.0, 138.0], [561.0, 137.0]], [[540.0, 77.0], [567.0, 77.0], [567.0, 123.0], [540.0, 123.0]]], "lines": ["待ち", "なさい", "よ！"]}, {"box": [427, 76, 500, 146], "vertical": true, "font_size": 26, "lines_coords": [[[474.0, 78.0], [500.0, 78.0], [500.0, 141.0], [474.0, 141.0]], [[442.0, 77.0], [473.0, 76.0], [475.0, 141.0], [445.0, 142.0]], [[427.0, 80.0], [448.0, 80.0], [448.0, 145.0], [427.0, 145.0]]], "lines": ["あれは", "蝶族の", "連中よ。"]}, {"box": [323, 71, 370, 195], "vertical": true, "font_size": 20, "lines_coords": [[[349.0, 72.0], [369.0, 72.0], [369.0, 168.0], [349.0, 168.0]], [[323.0, 71.0], [343.0, 71.0], [345.0, 195.0], [325.0, 195.0]]], "lines": ["近づかない", "ほうがいいわ。"]}, {"box": [241, 258, 297, 332], "vertical": true, "font_size": 27, "lines_coords": [[[272.0, 260.0], [297.0, 260.0], [297.0, 331.0], [272.0, 331.0]], [[241.0, 258.0], [270.0, 258.0], [270.0, 332.0], [241.0, 332.0]]], "lines": ["大丈夫", "だよ！！"]}, {"box": [720, 383, 767, 464], "vertical": true, "font_size": 23, "lines_coords": [[[739.0, 384.0], [765.0, 383.0], [767.0, 452.0], [741.0, 453.0]], [[720.0, 384.0], [740.0, 384.0], [740.0, 464.0], [720.0, 464.0]]], "lines": ["満男っ、", "．．．もう！！"]}, {"box": [686, 689, 773, 805], "vertical": true, "font_size": 19, "lines_coords": [[[753.0, 690.0], [773.0, 690.0], [773.0, 805.0], [753.0, 805.0]], [[729.0, 689.0], [750.0, 689.0], [748.0, 805.0], [727.0, 805.0]], [[705.0, 689.0], [726.0, 689.0], [724.0, 803.0], [702.0, 803.0]], [[686.0, 708.0], [699.0, 708.0], [699.0, 747.0], [686.0, 747.0]]], "lines": ["もしもし．．．", "僕達にも少し", "お肉ください", "．．．"]}, {"box": [750, 908, 765, 968], "vertical": true, "font_size": 15, "lines_coords": [[[750.0, 908.0], [765.0, 908.0], [765.0, 968.0], [750.0, 968.0]]], "lines": ["．．．"]}, {"box": [244, 908, 269, 980], "vertical": true, "font_size": 25, "lines_coords": [[[244.0, 908.0], [269.0, 908.0], [269.0, 980.0], [244.0, 980.0]]], "lines": ["あっ！？"]}], "img_path": "093.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [667, 614, 736, 727], "vertical": true, "font_size": 20, "lines_coords": [[[712.0, 614.0], [736.0, 614.0], [736.0, 656.0], [712.0, 656.0]], [[690.0, 614.0], [710.0, 614.0], [710.0, 727.0], [690.0, 727.0]], [[668.0, 615.0], [684.0, 615.0], [684.0, 711.0], [668.0, 711.0]]], "lines": ["もう", "焼けたんじゃ", "ないのか？"]}, {"box": [364, 612, 385, 672], "vertical": true, "font_size": 21, "lines_coords": [[[364.0, 612.0], [385.0, 612.0], [385.0, 672.0], [364.0, 672.0]]], "lines": ["ああ．．．"]}], "img_path": "094.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [734, 637, 756, 740], "vertical": true, "font_size": 18, "lines_coords": [[[737.0, 637.0], [754.0, 637.0], [752.0, 737.0], [734.0, 737.0]]], "lines": ["たまんねえ"]}, {"box": [743, 785, 761, 908], "vertical": true, "font_size": 16, "lines_coords": [[[743.0, 785.0], [759.0, 785.0], [759.0, 907.0], [743.0, 907.0]]], "lines": ["おねえちゃん、"]}, {"box": [409, 570, 430, 675], "vertical": true, "font_size": 21, "lines_coords": [[[409.0, 570.0], [430.0, 570.0], [430.0, 675.0], [409.0, 675.0]]], "lines": ["食べようぜ。"]}, {"box": [506, 795, 547, 929], "vertical": true, "font_size": 18, "lines_coords": [[[527.0, 795.0], [547.0, 795.0], [547.0, 929.0], [