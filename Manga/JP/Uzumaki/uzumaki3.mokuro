0, 554.0], [668.0, 554.0]]], "lines": ["この奇妙な", "町並みは、やがて", "時の流れと共に", "朽ちていき"]}, {"box": [119, 460, 259, 582], "vertical": true, "font_size": 22, "lines_coords": [[[233.0, 460.0], [256.0, 460.0], [259.0, 580.0], [235.0, 580.0]], [[212.0, 461.0], [233.0, 461.0], [234.0, 582.0], [213.0, 582.0]], [[186.0, 461.0], [212.0, 461.0], [212.0, 522.0], [186.0, 522.0]], [[166.0, 462.0], [186.0, 462.0], [186.0, 577.0], [166.0, 577.0]], [[140.0, 461.0], [161.0, 461.0], [164.0, 558.0], [142.0, 558.0]], [[119.0, 461.0], [137.0, 461.0], [138.0, 556.0], [120.0, 556.0]]], "lines": ["新しい町へと", "生まれ変わり、", "そして", "人々が幸せに", "暮らす事で", "しょう．．．"]}, {"box": [366, 1135, 521, 1164], "vertical": false, "font_size": 19, "lines_coords": [[[369.0, 1139.0], [515.0, 1139.0], [515.0, 1158.0], [369.0, 1158.0]]], "lines": ["うずまきおわ"]}, {"box": [137, 933, 228, 1087], "vertical": true, "font_size": 20, "lines_coords": [[[203.0, 933.0], [228.0, 933.0], [228.0, 997.0], [203.0, 997.0]], [[182.0, 935.0], [202.0, 935.0], [202.0, 1014.0], [182.0, 1014.0]], [[158.0, 935.0], [179.0, 935.0], [179.0, 1032.0], [158.0, 1032.0]], [[137.0, 936.0], [153.0, 936.0], [153.0, 1087.0], [137.0, 1087.0]]], "lines": ["そう．．．", "また再び", "あの道跡が", "目覚めるまでは．．．"]}], "img_path": "225.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [392, 290, 415, 403], "vertical": true, "font_size": 20, "lines_coords": [[[393.0, 292.0], [413.0, 292.0], [413.0, 396.0], [393.0, 396.0]]], "lines": ["初山掲載"]}, {"box": [336, 420, 466, 592], "vertical": true, "font_size": 54, "lines_coords": [[[451.0, 423.0], [466.0, 423.0], [466.0, 591.0], [451.0, 591.0]], [[430.0, 421.0], [450.0, 421.0], [450.0, 592.0], [430.0, 592.0]], [[412.0, 421.0], [432.0, 421.0], [432.0, 522.0], [412.0, 522.0]], [[375.0, 424.0], [394.0, 424.0], [394.0, 514.0], [375.0, 514.0]], [[356.0, 423.0], [377.0, 423.0], [377.0, 527.0], [356.0, 527.0]], [[336.0, 420.0], [359.0, 420.0], [359.0, 553.0], [336.0, 553.0]]], "lines": ["第１２話で、週刊ビッグスピリック", "第１４話・週刊ビッグスピリップ", "第１５話．．２０１６年に", "第１７話・巡刊は", "第１８話・週刊ビッ", "最終話．．．週刊ヒックス"]}, {"box": [296, 536, 512, 759], "vertical": true, "font_size": 54, "lines_coords": [[[414.0, 588.0], [427.0, 588.0], [427.0, 651.0], [414.0, 651.0]], [[308.0, 536.0], [512.0, 548.0], [500.0, 759.0], [296.0, 747.0]], [[339.0, 567.0], [355.0, 567.0], [355.0, 691.0], [339.0, 691.0]], [[378.0, 596.0], [390.0, 596.0], [390.0, 677.0], [378.0, 677.0]], [[358.0, 587.0], [371.0, 587.0], [371.0, 671.0], [358.0, 671.0]]], "lines": ["ツ９９年年第", "ああ、", "リッツ９科年第３９号", "今年第２６", "ゾ９９年－第３０"]}, {"box": [339, 712, 465, 768], "vertical": true, "font_size": 54, "lines_coords": [[[339.0, 712.0], [465.0, 712.0], [465.0, 732.0], [339.0, 732.0]], [[339.0, 733.0], [464.0, 733.0], [464.0, 750.0], [339.0, 750.0]], [[341.0, 753.0], [464.0, 753.0], [464.0, 768.0], [341.0, 768.0]]], "lines": ["あ、あ、でもいいですよ。", "．．．", "お兄ちゃんは、お"]}], "img_path": "226.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [504, 109, 525, 205], "vertical": true, "font_size": 16, "lines_coords": [[[505.0, 111.0], [521.0, 111.0], [521.0, 205.0], [505.0, 205.0]]], "lines": ["恐ろしい．．．"]}, {"box": [113, 105, 160, 239], "vertical": true, "font_size": 22, "lines_coords": [[[135.0, 105.0], [160.0, 105.0], [160.0, 166.0], [135.0, 166.0]], [[113.0, 105.0], [133.0, 105.0], [134.0, 239.0], [114.0, 239.0]]], "lines": ["なんて", "恐ろしいんだ．．．"]}, {"box": [729, 336, 774, 471], "vertical": true, "font_size": 20, "lines_coords": [[[753.0, 336.0], [773.0, 336.0], [773.0, 471.0], [753.0, 471.0]], [[730.0, 336.0], [750.0, 336.0], [748.0, 471.0], [729.0, 471.0]]], "lines": ["トゥルルル．．．", "トゥルルル．．．"]}, {"box": [499, 349, 570, 487], "vertical": true, "font_size": 24, "lines_coords": [[[546.0, 350.0], [570.0, 350.0], [570.0, 433.0], [546.0, 433.0]], [[523.0, 351.0], [543.0, 351.0], [543.0, 487.0], [523.0, 487.0]], [[499.0, 349.0], [526.0, 349.0], [526.0, 400.0], [499.0, 400.0]]], "lines": ["．．．はい．．．", "スピリッツ中熊", "です。"]}, {"box": [404, 342, 471, 493], "vertical": true, "font_size": 18, "lines_coords": [[[451.0, 342.0], [468.0, 342.0], [471.0, 493.0], [453.0, 493.0]], [[427.0, 342.0], [447.0, 342.0], [447.0, 458.0], [427.0, 458.0]], [[404.0, 342.0], [421.0, 342.0], [423.0, 476.0], [405.0, 476.0]]], "lines": ["あ．．．ああ中熊さん", "．．．困った事に", "なりましたよ．．"]}, {"box": [189, 326, 209, 406], "vertical": true, "font_size": 20, "lines_coords": [[[189.0, 326.0], [209.0, 326.0], [209.0, 406.0], [189.0, 406.0]]], "lines": ["カッカッ"]}, {"box": [108, 337, 158, 505], "vertical": true, "font_size": 24, "lines_coords": [[[134.0, 338.0], [158.0, 338.0], [155.0, 505.0], [132.0, 505.0]], [[111.0, 337.0], [135.0, 337.0], [133.0, 502.0], [108.0, 502.0]]], "lines": ["えっ？どうしたん", "ですか、伊藤さん。"]}, {"box": [751, 562, 771, 641], "vertical": true, "font_size": 20, "lines_coords": [[[751.0, 562.0], [771.0, 562.0], [771.0, 641.0], [751.0, 641.0]]], "lines": ["．．．実は．．．"]}, {"box": [495, 555, 562, 767], "vertical": true, "font_size": 19, "lines_coords": [[[541.0, 555.0], [561.0, 555.0], [559.0, 691.0], [539.0, 691.0]], [[515.0, 556.0], [536.0, 556.0], [537.0, 767.0], [516.0, 767.0]], [[495.0, 558.0], [512.0, 558.0], [512.0, 635.0], [495.0, 635.0]]], "lines": ["うずまき仙人が", "私の家に来てしまったん", "ですよ！"]}, {"box": [411, 573, 455, 746], "vertical": true, "font_size": 18, "lines_coords": [[[434.0, 573.0], [454.0, 573.0], [454.0, 708.0], [434.0, 708.0]], [[411.0, 573.0], [427.0, 573.0], [430.0, 746.0], [413.0, 746.0]]], "lines": ["うずまき仙人？", "なんてすかそりゃ？"]}, {"box": [103, 557, 195, 760], "vertical": true, "font_size": 22, "lines_coords": [[[174.0, 558.0], [194.0, 558.0], [194.0, 730.0], [174.0, 730.0]], [[148.0, 557.0], [172.0, 557.0], [172.0, 751.0], [148.0, 751.0]], [[125.0, 557.0], [148.0, 557.0], [148.0, 760.0], [125.0, 760.0]], [[103.0, 558.0], [123.0, 558.0], [123.0, 751.0], [103.0, 751.0]]], "lines": ["ほら．．．この間Ｇ県の", "山奥へ２人で行ったで", "しょう！？そこで仙人に", "会ったじゃないすか！！"]}, {"box": [114, 822, 140, 938], "vertical": true, "font_size": 25, "lines_coords": [[[114.0, 822.0], [139.0, 822.0], [139.0, 938.0], [114.0, 938.0]]], "lines": ["ガチャン！！"]}, {"box": [691, 833, 760, 1083], "vertical": true, "font_size": 21, "lines_coords": [[[739.0, 834.0], [759.0, 834.0], [759.0, 1082.0], [739.0, 1082.0]], [[713.0, 833.0], [737.0, 833.0], [737.0, 1075.0], [713.0, 1075.0]], [[692.0, 834.0], [712.0, 834.0], [711.0, 989.0], [691.0, 989.0]]], "lines": ["何言ってるんですか．．．あれは", "夢でしょう？夢オチだった", "じゃないですか！！"]}, {"box": [341, 830, 411, 1062], "vertical": true, "font_size": 20, "lines_coords": [[[387.0, 830.0], [411.0, 830.0], [406.0, 1026.0], [383.0, 1026.0]], [[364.0, 832.0], [384.0, 832.0], [383.0, 975.0], [363.0, 975.0]], [[343.0, 833.0], [359.0, 833.0], [357.0, 1062.0], [341.0, 1062.0]]], "lines": ["夢じゃなかったんだ．．．", "現実だったんだ、", "現実オチだったんだよお！！！"]}, {"box": [253, 823, 296, 985], "vertical": true, "font_size": 18, "lines_coords": [[[277.0, 826.0], [294.0, 826.0], [294.0, 944.0], [277.0, 944.0]], [[253.0, 823.0], [273.0, 823.0], [273.0, 983.0], [253.0, 983.0]]], "lines": ["もー伊藤さん、", "からかわないでよ。"]}], "img_path": "227.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [652, 103, 719, 256], "vertical": true, "font_size": 20, "lines_coords": [[[699.0, 103.0], [719.0, 103.0], [719.0, 256.0], [699.0, 256.0]], [[676.0, 103.0], [696.0, 103.0], [696.0, 199.0], [676.0, 199.0]], [[652.0, 103.0], [672.0, 103.0], [672.0, 217.0], [652.0, 217.0]]], "lines": ["．．．ついに担当にも", "見放されて", "しまった．．．"]}, {"box": [602, 754, 715, 930], "vertical": true, "font_size": 25, "lines_coords": [[[690.0, 754.0], [713.0, 754.0], [713.0, 918.0], [690.0, 918.0]], [[662.0, 758.0], [686.0, 758.0], [686.0, 874.0], [662.0, 874.0]], [[632.0, 757.0], [657.0, 757.0], [659.0, 919.0], [635.0, 919.0]], [[602.0, 754.0], [630.0, 754.0], [632.0, 930.0], [604.0, 930.0]]], "lines": ["うずまきの謎を", "知りたいと", "いうのじゃな！？", "お安いご用じゃ。"]}, {"box": [234, 754, 343, 1007], "vertical": true, "font_size": 24, "lines_coords": [[[316.0, 754.0], [341.0, 754.0], [343.0, 849.0], [318.0, 849.0]], [[288.0, 754.0], [312.0, 754.0], [315.0, 942.0], [290.0, 942.0]], [[263.0, 755.0], [284.0, 755.0], [283.0, 1007.0], [262.0, 1007.0]], [[234.0, 754.0], [259.0, 754.0], [259.0, 916.0], [234.0, 916.0]]], "lines": ["その前に", "腹ごしらえじゃ！！", "もっと美味なうずまきを", "持ってまいれ！！"]}, {"box": [183, 742, 198, 804], "vertical": true, "font_size": 15, "lines_coords": [[[183.0, 742.0], [198.0, 742.0], [198.0, 804.0], [183.0, 804.0]]], "lines": ["．．．"]}, {"box": [59, 746, 106, 939], "vertical": true, "font_size": 22, "lines_coords": [[[83.0, 746.0], [106.0, 746.0], [106.0, 882.0], [83.0, 882.0]], [[60.0, 746.0], [80.0, 746.0], [79.0, 939.0], [59.0, 939.0]]], "lines": ["今回は、とくに", "オチはございません．．．"]}], "img_path": "228.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [407, 417, 424, 472], "vertical": true, "font_size": 17, "lines_coords": [[[407.0, 417.0], [424.0, 417.0], [424.0, 472.0], [407.0, 472.0]]], "lines": ["【印刷所】．．"]}, {"box": [226, 414, 393, 765], "vertical": true, "font_size": 15, "lines_coords": [[[372.0, 417.0], [384.0, 417.0], [384.0, 757.0], [372.0, 757.0]], [[355.0, 416.0], [370.0, 416.0], [370.0, 760.0], [355.0, 760.0]], [[341.0, 417.0], [356.0, 417.0], [356.0, 642.0], [341.0, 642.0]], [[326.0, 418.0], [338.0, 418.0], [338.0, 760.0], [326.0, 760.0]], [[309.0, 417.0], [324.0, 417.0], [324.0, 760.0], [309.0, 760.0]], [[293.0, 416.0], [308.0, 416.0], [308.0, 629.0], [293.0, 629.0]], [[277.0, 417.0], [293.0, 417.0], [293.0, 608.0], [277.0, 608.0]], [[260.0, 416.0], [276.0, 416.0], [278.0, 761.0], [262.0, 761.0]], [[244.0, 416.0], [261.0, 416.0], [263.0, 762.0], [247.0, 762.0]], [[228.0, 414.0], [244.0, 414.0], [247.0, 742.0], [230.0, 742.0]]], "lines": ["●本書の一部または全部を無断の複数転載上演が必要をすることは", "法律で認められた場合を除き、著作者及び出版者の権利の侵害となります。", "す。あらかじめ小社会で時間をお求めください。", "●過去には十分注意しておりますが、万一流丁・乱丁などの不良品がある", "りましたら、制作部」（＊０１２０）３３６．０８２一あでにお送りくださ", "い、透料小社負担にお取り替えいたします。", "●Ｒ：日本狼写権センター英託出版物", "本書の＞部または全部を無断で複写「コピーすることは、著作権法上で", "の例外を除き禁じられています。本書から複写を希望される場合は、日", "本複写権センター（４０３－３４０）１２３８２」にご連絡ください。"]}, {"box": [48