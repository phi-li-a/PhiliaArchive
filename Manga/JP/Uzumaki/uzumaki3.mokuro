{"version": "0.2.0-beta.6", "title": "Uzumaki", "title_uuid": "b05f321a-de4f-47b5-887f-751e3b1505e5", "volume": "uzumaki3", "volume_uuid": "be3d9bd6-3ad0-4c3c-beb4-a0b331bbe4bb", "pages": [{"version": "0.1.7", "img_width": 1374, "img_height": 1200, "blocks": [{"box": [72, 128, 250, 146], "vertical": false, "font_size": 18, "lines_coords": [[[72.0, 128.0], [250.0, 128.0], [250.0, 146.0], [72.0, 146.0]]], "lines": ["９７．１８．９７８４０９１８年４月９日４日９月１９日"]}, {"box": [65, 247, 254, 274], "vertical": false, "font_size": 29, "lines_coords": [[[65.0, 245.0], [254.0, 245.0], [254.0, 276.0], [65.0, 276.0]]], "lines": ["１０月１１日開催１１月１９日、１９２９９７９年９月２９日７０３５７４"]}, {"box": [311, 104, 465, 123], "vertical": false, "font_size": 19, "lines_coords": [[[311.0, 104.0], [465.0, 104.0], [465.0, 123.0], [311.0, 123.0]]], "lines": ["Ｃ９９７９¥８５７Ｅ"]}, {"box": [311, 57, 552, 76], "vertical": false, "font_size": 19, "lines_coords": [[[311.0, 57.0], [552.0, 57.0], [552.0, 76.0], [311.0, 76.0]]], "lines": ["ＩＳＢＮ４－０９－１８５７２３－Ｘ"]}, {"box": [308, 182, 507, 208], "vertical": false, "font_size": 23, "lines_coords": [[[308.0, 185.0], [507.0, 182.0], [507.0, 205.0], [308.0, 208.0]]], "lines": ["定価：「本体８５７円＋税"]}, {"box": [308, 225, 536, 248], "vertical": false, "font_size": 20.0, "lines_coords": [[[433.0, 225.0], [536.0, 225.0], [536.0, 248.0], [433.0, 248.0]], [[308.0, 229.0], [440.0, 229.0], [440.0, 246.0], [308.0, 246.0]]], "lines": ["３．小学館", "雑誌４５６９７－２３"]}], "img_path": "001.jpg"}, {"version": "0.1.7", "img_width": 851, "img_height": 1200, "blocks": [{"box": [740, 14, 833, 106], "vertical": false, "font_size": 88, "lines_coords": [[[745.0, 14.0], [833.0, 18.0], [828.0, 106.0], [740.0, 101.0]]], "lines": ["藤"]}], "img_path": "002.jpg"}, {"version": "0.1.7", "img_width": 930, "img_height": 1200, "blocks": [{"box": [858, 19, 922, 83], "vertical": false, "font_size": 70, "lines_coords": [[[858.0, 13.0], [922.0, 13.0], [922.0, 89.0], [858.0, 89.0]]], "lines": ["スピリッツ性コミックス"]}, {"box": [846, 154, 920, 424], "vertical": true, "font_size": 57, "lines_coords": [[[846.0, 158.0], [903.0, 154.0], [920.0, 420.0], [864.0, 424.0]]], "lines": ["「す、き、"]}, {"box": [38, 1101, 90, 1175], "vertical": true, "font_size": 52, "lines_coords": [[[38.0, 1101.0], [90.0, 1101.0], [90.0, 1175.0], [38.0, 1175.0]]], "lines": ["ま"]}, {"box": [857, 1150, 917, 1170], "vertical": false, "font_size": 20, "lines_coords": [[[857.0, 1150.0], [917.0, 1150.0], [917.0, 1170.0], [857.0, 1170.0]]], "lines": ["小学館"]}], "img_path": "003.jpg"}, {"version": "0.1.7", "img_width": 3289, "img_height": 1200, "blocks": [{"box": [102, 718, 2903, 1078], "vertical": false, "font_size": 123.5, "lines_coords": [[[282.0, 718.0], [2717.0, 718.0], [2717.0, 837.0], [282.0, 837.0]], [[102.0, 949.0], [2903.0, 943.0], [2903.0, 1071.0], [102.0, 1078.0]]], "lines": ["ピッグコミックスピリッツが増るスパイラルファンタジー完結編！！", "西暦２０００年２の月・映画うずまぎ１全国公開決定！！"]}, {"box": [1771, 183, 2879, 676], "vertical": false, "font_size": 493, "lines_coords": [[[1771.0, 183.0], [2879.0, 183.0], [2879.0, 676.0], [1771.0, 676.0]]], "lines": ["いいよ。"]}, {"box": [3043, 1026, 3236, 1131], "vertical": false, "font_size": 48, "lines_coords": [[[3048.0, 1029.0], [3231.0, 1029.0], [3231.0, 1091.0], [3048.0, 1091.0]], [[3064.0, 1090.0], [3211.0, 1090.0], [3211.0, 1133.0], [3064.0, 1133.0]]], "lines": ["小学館", "ＢＣＳ５７２８"]}, {"box": [3045, 1024, 3234, 1133], "vertical": false, "font_size": 109, "lines_coords": [[[3045.0, 1024.0], [3234.0, 1024.0], [3234.0, 1133.0], [3045.0, 1133.0]]], "lines": ["小学館"]}], "img_path": "004.jpg"}, {"version": "0.1.7", "img_width": 3046, "img_height": 1200, "blocks": [{"box": [413, 110, 2581, 1063], "vertical": false, "font_size": 160, "lines_coords": [[[681.0, 119.0], [2302.0, 96.0], [2302.0, 264.0], [681.0, 287.0]], [[1790.0, 248.0], [2046.0, 248.0], [2046.0, 326.0], [1790.0, 326.0]], [[2067.0, 259.0], [2147.0, 259.0], [2147.0, 320.0], [2067.0, 320.0]], [[663.0, 271.0], [2346.0, 271.0], [2346.0, 493.0], [663.0, 493.0]], [[467.0, 462.0], [2549.0, 447.0], [2549.0, 669.0], [467.0, 683.0]], [[413.0, 655.0], [2581.0, 635.0], [2581.0, 865.0], [413.0, 886.0]], [[699.0, 843.0], [2352.0, 834.0], [2352.0, 1068.0], [699.0, 1077.0]]], "lines": ["呪われた町から脱出をせる。", "２０１８年１１月２３日", "．．．", "２０１６年１０月２９日、美しい女子高生・五島開発はこっちゃったのですが、", "「スピース」は、１１時間からついに、バッチキーの秘密に遭遇する！！", "スマートフォンはＧｏｏｇｌｅなどの新人工ボラーの旗子・伊藤君二次郎く", "メルバッグはすっかり時間。ファンタステックな悪夢の世界。"]}], "img_path": "005.jpg"}, {"version": "0.1.7", "img_width": 833, "img_height": 1200, "blocks": [], "img_path": "006.jpg"}, {"version": "0.1.7", "img_width": 1466, "img_height": 1200, "blocks": [{"box": [22, 1143, 193, 1175], "vertical": false, "font_size": 12, "lines_coords": [[[100.0, 1145.0], [186.0, 1145.0], [186.0, 1159.0], [100.0, 1159.0]], [[100.0, 1159.0], [184.0, 1159.0], [184.0, 1173.0], [100.0, 1173.0]]], "lines": ["．．．", "．．．"]}, {"box": [558, 0, 1022, 316], "vertical": false, "font_size": 162.0, "lines_coords": [[[558.0, 209.0], [791.0, 209.0], [791.0, 286.0], [558.0, 286.0]], [[645.0, 74.0], [901.0, 0.0], [1022.0, 189.0], [767.0, 316.0]]], "lines": ["伊藤潤二", "でき"]}, {"box": [1390, 219, 1431, 492], "vertical": true, "font_size": 33, "lines_coords": [[[1390.0, 220.0], [1423.0, 219.0], [1431.0, 491.0], [1398.0, 492.0]]], "lines": ["いつまでは、"]}, {"box": [1397, 515, 1445, 621], "vertical": true, "font_size": 36, "lines_coords": [[[1410.0, 515.0], [1445.0, 519.0], [1433.0, 621.0], [1397.0, 617.0]]], "lines": ["．．．"]}], "img_path": "007.jpg"}, {"version": "0.1.7", "img_width": 810, "img_height": 1200, "blocks": [{"box": [357, 216, 453, 718], "vertical": true, "font_size": 92, "lines_coords": [[[361.0, 216.0], [453.0, 216.0], [450.0, 718.0], [357.0, 718.0]]], "lines": ["うず：き○伊藤潤"]}], "img_path": "008.jpg"}, {"version": "0.1.7", "img_width": 816, "img_height": 1200, "blocks": [{"box": [182, 128, 208, 205], "vertical": true, "font_size": 21, "lines_coords": [[[185.0, 128.0], [206.0, 128.0], [203.0, 205.0], [182.0, 205.0]]], "lines": ["．．．そうですね"]}, {"box": [274, 126, 296, 203], "vertical": true, "font_size": 20, "lines_coords": [[[275.0, 128.0], [295.0, 128.0], [295.0, 200.0], [275.0, 200.0]]], "lines": ["「第８５回"]}, {"box": [403, 53, 424, 83], "vertical": true, "font_size": 21, "lines_coords": [[[403.0, 53.0], [424.0, 53.0], [424.0, 83.0], [403.0, 83.0]]], "lines": ["三"]}, {"box": [359, 120, 379, 201], "vertical": true, "font_size": 20, "lines_coords": [[[359.0, 120.0], [379.0, 120.0], [379.0, 201.0], [359.0, 201.0]]], "lines": ["【第１話"]}, {"box": [445, 128, 466, 201], "vertical": true, "font_size": 21, "lines_coords": [[[445.0, 128.0], [466.0, 128.0], [466.0, 201.0], [445.0, 201.0]]], "lines": ["【第６話"]}, {"box": [531, 125, 554, 210], "vertical": true, "font_size": 20, "lines_coords": [[[531.0, 130.0], [551.0, 130.0], [551.0, 210.0], [531.0, 210.0]]], "lines": ["２０１５年１２月"]}, {"box": [617, 126, 639, 205], "vertical": true, "font_size": 20, "lines_coords": [[[617.0, 126.0], [637.0, 126.0], [637.0, 201.0], [617.0, 201.0]]], "lines": ["【第１話"]}, {"box": [704, 128, 726, 210], "vertical": true, "font_size": 20, "lines_coords": [[[704.0, 128.0], [724.0, 128.0], [724.0, 210.0], [704.0, 210.0]]], "lines": ["おっ．．．"]}, {"box": [423, 328, 497, 502], "vertical": true, "font_size": 50, "lines_coords": [[[447.0, 328.0], [497.0, 335.0], [472.0, 502.0], [423.0, 495.0]]], "lines": ["兄さんとん"]}, {"box": [529, 294, 551, 391], "vertical": true, "font_size": 22, "lines_coords": [[[529.0, 294.0], [551.0, 294.0], [551.0, 391.0], [529.0, 391.0]]], "lines": ["こんとん"]}, {"box": [615, 292, 642, 367], "vertical": true, "font_size": 23, "lines_coords": [[[615.0, 294.0], [638.0, 292.0], [642.0, 366.0], [619.0, 367.0]]], "lines": ["ちょう"]}, {"box": [689, 385, 755, 601], "vertical": true, "font_size": 66, "lines_coords": [[[689.0, 385.0], [755.0, 385.0], [755.0, 601.0], [689.0, 601.0]]], "lines": ["る長屋"]}, {"box": [60, 810, 79, 1047], "vertical": true, "font_size": 15, "lines_coords": [[[62.0, 810.0], [77.0, 810.0], [77.0, 1033.0], [62.0, 1033.0]]], "lines": ["【交戦国際と一旦町ゆきおようにお"]}, {"box": [60, 812, 79, 1049], "vertical": true, "font_size": 19, "lines_coords": [[[60.0, 812.0], [79.0, 812.0], [79.0, 1049.0], [60.0, 1049.0]]], "lines": ["突然動画など上が動かされているので、"]}, {"box": [93, 1031, 214, 1046], "vertical": false, "font_size": 15, "lines_coords": [[[93.0, 1031.0], [214.0, 1031.0], [214.0, 1046.0], [93.0, 1046.0]]], "lines": ["２２０"]}, {"box": [273, 1031, 420, 1047], "vertical": false, "font_size": 16, "lines_coords": [[[273.0, 1031.0], [420.0, 1031.0], [420.0, 1047.0], [273.0, 1047.0]]], "lines": ["１６３．１３１．"]}, {"box": [451, 1032, 463, 1042], "vertical": false, "font_size": 10, "lines_coords": [[[451.0, 1032.0], [463.0, 1032.0], [463.0, 1042.0], [451.0, 1042.0]]], "lines": ["．．"]}], "img_path": "009.jpg"}, {"version": "0.1.7", "img_width": 813, "img_height": 1200, "blocks": [{"box": [388, -1, 415, 183], "vertical": true, "font_size": 17, "lines_coords": [[[393.0, 91.0], [410.0, 91.0], [410.0, 181.0], [393.0, 181.0]]], "lines": ["．．．おっちは"]}, {"box": [360, 192, 439, 574], "vertical": true, "font_size": 79, "lines_coords": [[[360.0, 212.0], [439.0, 212.0], [439.0, 546.0], [360.0, 546.0]]], "lines": ["鬼のいる長屋"]}], "img_path": "010.jpg"}, {"version": "0.1.7", "img_width": 837, "img_height": 1200, "blocks": [{"box": [634, 85, 750, 222], "vertical": true, "font_size": 21, "lines_coords": [[[729.0, 86.0], [750.0, 86.0], [746.0, 222.0], [725.0, 222.0]], [[704.0, 87.0], [724.0, 87.0], [724.0, 183.0], [704.0, 183.0]], [[679.0, 85.0], [704.0, 85.0], [702.0, 205.0], [677.0, 205.0]], [[657.0, 86.0], [677.0, 86.0], [675.0, 203.0], [655.0, 203.0]], [[634.0, 87.0], [654.0, 87.0], [654.0, 187.0], [634.0, 187.0]]], "lines": ["先日、襲来した", "台風１号に", "よって、町は", "大きな被害を", "受けました。"]}, {"box": [407, 78, 531, 219], "vertical": true, "font_size": 23, "lines_coords": [[[500.0, 78.0], [531.0, 78.0], [531.0, 124.0], [500.0, 124.0]], [[480.0, 79.0], [501.0, 79.0], [502.0, 217.0], [481.0, 217.0]], [[456.0, 79.0], [477.0, 79.0], [478.0, 196.0], [457.0, 196.0]], [[434.0, 79.0], [454.0, 79.0], [454.0, 214.0], [434.0, 214.0]], [[410.0, 80.0], [430.0, 80.0], [427.0, 198.0], [407.0, 198.0]]], "lines": ["特に", "ひどかったのは", "町の中心部に", "あるトンボ池の", "周辺の家々で、"]}, {"box": [114, 86, 229, 186], "vertical": true, "font_size": 22, "lines_coords": [[[207.0, 90.0], [228.0, 90.0], [228.0, 168.0], [207.0, 168.0]], [[181.0, 87.0], [207.0, 87.0], [207.0, 151.0], [181.0, 151.0]], [[160.0, 90.0], [180.0, 90.0], [180.0, 186.0], [160.0, 186.0]], [[132.0, 86.0], [160.0, 86.0], [160.0, 133.0], [132.0, 133.0]], [[114.0, 89.0], [131.0, 89.0], [131.0, 173.0], [114.0, 173.0]]], "lines": ["私の家を", "含めて", "ほとんどが", "崩壊", "しました"]}, {"box": [672, 563, 765, 740], "vertical": true, "font_size": 20, "lines_coords": [[[742.0, 563.0], [765.0, 563.0], [763.0, 740.0], [739.0, 740.0]], [[719.0, 564.0], [740.0, 564.0], [738.0, 662.0], [717.0, 662.0]], [[695.0, 564.0], [715.0, 564.0], [715.0, 699.0], [695.0, 699.0]], [[672.0, 566.0], [689.0, 566.0], [689.0, 718.0], [672.0, 718.0]]], "lines": ["原因は、あの巨大な", "台風１号が", "トンボ池に吸い", "込まれたためで："]}, {"box": [352, 557, 422, 719], "vertical": true, "font_size": 19, "lines_coords": [[[400.0, 557.0], [422.0, 557.0], [419.0, 675.0], [398.0, 675.0]], [[379.0, 561.0], [396.0, 561.0], [396.0, 675.0], [379.0, 675.0]], [[354.0, 558.0], [373.0, 558.0], [372.0, 718.0], [352.0, 718.0]]], "lines": ["周辺の家々が", "そのあおりを", "受けたためでした。"]}, {"box": [211, 569, 303, 666], "vertical": true, "font_size": 21, "lines_coords": [[[282.0, 570.0], [302.0, 570.0], [302.0, 666.0], [282.0, 666.0]], [[257.0, 569.0], [279.0, 569.0], [279.0, 646.0], [257.0, 646.0]], [[235.0, 570.0], [255.0, 570.0], [255.0, 649.0], [235.0, 649.0]], [[211.0, 570.0], [232.0, 570.0], [232.0, 648.0], [211.0, 648.0]]], "lines": ["私の家族は", "奇跡的に", "全員無事", "でしたが"]}, {"box": [121, 939, 189, 1101], "vertical": true, "font_size": 18, "lines_coords": [[[168.0, 941.0], [188.0, 941.0], [187.0, 1074.0], [167.0, 1074.0]], [[146.0, 942.0], [162.0, 942.0], [162.0, 1054.0], [146.0, 1054.0]], [[123.0, 939.0], [139.0, 939.0], [138.0, 1101.0], [121.0, 1101.0]]], "lines": ["私達は住む家を", "探さなくては", "なりませんでした。"]}], "img_path": "011.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [623, 78, 720, 181], "vertical": true, "font_size": 22, "lines_coords": [[[699.0, 83.0], [720.0, 83.0], [720.0, 161.0], [699.0, 161.0]], [[676.0, 83.0], [696.0, 83.0], [696.0, 180.0], [676.0, 180.0]], [[652.0, 84.0], [672.0, 84.0], [672.0, 181.0], [652.0, 181.0]], [[623.0, 82.0], [651.0, 78.0], [656.0, 117.0], [628.0, 120.0]]], "lines": ["まったく", "このたびは", "大変でした", "ね。"]}, {"box": [378, 72, 519, 178], "vertical": true, "font_size": 22, "lines_coords": [[[491.0, 72.0], [519.0, 72.0], [519.0, 118.0], [491.0, 118.0]], [[472.0, 73.0], [493.0, 73.0], [493.0, 158.0], [472.0, 158.0]], [[448.0, 75.0], [468.0, 75.0], [468.0, 172.0], [448.0, 172.0]], [[420.0, 72.0], [447.0, 72.0], [447.0, 119.0], [420.0, 119.0]], [[400.0, 73.0], [421.0, 73.0], [419.0, 152.0], [398.0, 152.0]], [[378.0, 75.0], [394.0, 75.0], [394.0, 178.0], [378.0, 178.0]]], "lines": ["でも", "よかった。", "この町には", "結構", "空き家が", "あるんです。"]}, {"box": [251, 97, 345, 278], "vertical": true, "font_size": 19, "lines_coords": [[[326.0, 99.0], [343.0, 99.0], [343.0, 250.0], [326.0, 250.0]], [[301.0, 98.0], [321.0, 98.0], [321.0, 250.0], [301.0, 250.0]], [[276.0, 98.0], [296.0, 98.0], [296.0, 199.0], [276.0, 199.0]], [[251.0, 97.0], [271.0, 97.0], [274.0, 278.0], [254.0, 278.0]]], "lines": ["被災された世帯に", "見合う分の空家が", "あったのは、", "不幸中の幸いですよ。"]}, {"box": [331, 322, 351, 428], "vertical": true, "font_size": 20, "lines_coords": [[[331.0, 322.0], [351.0, 322.0], [351.0, 424.0], [331.0, 424.0]]], "lines": ["よかったね。"]}, {"box": [392, 502, 406, 545], "vertical": true, "font_size": 14, "lines_coords": [[[392.0, 502.0], [406.0, 502.0], [406.0, 545.0], [392.0, 545.0]]], "lines": ["．．．．．．"]}, {"box": [60, 316, 81, 384], "vertical": true, "font_size": 20, "lines_coords": [[[60.0, 316.0], [80.0, 316.0], [80.0, 380.0], [60.0, 380.0]]], "lines": ["そうね"]}, {"box": [182, 495, 241, 548], "vertical": false, "font_size": 53, "lines_coords": [[[182.0, 495.0], [241.0, 495.0], [241.0, 548.0], [182.0, 548.0]]], "lines": ["えっ．．．"]}, {"box": [549, 628, 597, 683], "vertical": true, "font_size": 27, "lines_coords": [[[570.0, 628.0], [597.0, 628.0], [597.0, 672.0], [570.0, 672.0]], [[549.0, 628.0], [576.0, 628.0], [576.0, 683.0], [549.0, 683.0]]], "lines": ["ここ", "です。"]}], "img_path": "012.jpg"}, {"version": "0.1.7", "img_width": 837, "img_height": 1200, "blocks": [{"box": [676, 92, 771, 173], "vertical": true, "font_size": 22, "lines_coords": [[[751.0, 94.0], [771.0, 94.0], [771.0, 172.0], [751.0, 172.0]], [[725.0, 92.0], [751.0, 92.0], [751.0, 121.0], [725.0, 121.0]], [[702.0, 93.0], [723.0, 93.0], [723.0, 173.0], [702.0, 173.0]], [[678.0, 93.0], [699.0, 93.0], [697.0, 173.0], [676.0, 173.0]]], "lines": ["空家って", "．．．", "これの事", "ですか！？"]}, {"box": [518, 79, 567, 133], "vertical": true, "font_size": 28, "lines_coords": [[[539.0, 79.0], [567.0, 79.0], [567.0, 126.0], [539.0, 126.0]], [[518.0, 79.0], [545.0, 79.0], [545.0, 133.0], [518.0, 133.0]]], "lines": ["そう", "です。"]}, {"box": [297, 93, 368, 289], "vertical": true, "font_size": 20, "lines_coords": [[[344.0, 93.0], [368.0, 93.0], [368.0, 289.0], [344.0, 289.0]], [[322.0, 96.0], [342.0, 96.0], [342.0, 268.0], [322.0, 268.0]], [[300.0, 94.0], [317.0, 94.0], [315.0, 271.0], [297.0, 271.0]]], "lines": ["だってこれは、昔から", "放置されてる長屋の", "廃屋じゃないですか"]}, {"box": [109, 85, 201, 201], "vertical": true, "font_size": 20, "lines_coords": [[[177.0, 85.0], [201.0, 85.0], [201.0, 151.0], [177.0, 151.0]], [[155.0, 87.0], [175.0, 87.0], [175.0, 183.0], [155.0, 183.0]], [[133.0, 89.0], [150.0, 89.0], [150.0, 201.0], [133.0, 201.0]], [[109.0, 86.0], [128.0, 86.0], [128.0, 165.0], [109.0, 165.0]]], "lines": ["こんな", "あばら屋に", "住めというん", "ですか！？"]}, {"box": [750, 439, 771, 596], "vertical": true, "font_size": 20, "lines_coords": [[[750.0, 439.0], [770.0, 439.0], [771.0, 596.0], [751.0, 596.0]]], "lines": ["それにこの長屋．．．"]}, {"box": [476, 432, 496, 623], "vertical": true, "font_size": 16, "lines_coords": [[[477.0, 432.0], [493.0, 432.0], [493.0, 623.0], [477.0, 623.0]]], "lines": ["そうだよ、お母さん．．．"]}, {"box": [356, 452, 446, 615], "vertical": true, "font_size": 27, "lines_coords": [[[412.0, 452.0], [446.0, 452.0], [446.0, 526.0], [412.0, 526.0]], [[383.0, 453.0], [407.0, 453.0], [407.0, 615.0], [383.0, 615.0]], [[356.0, 452.0], [379.0, 452.0], [379.0, 615.0], [356.0, 615.0]]], "lines": ["ここは．．．", "あの噂のある家", "じゃないか．．．！？"]}, {"box": [699, 706, 767, 841], "vertical": true, "font_size": 19, "lines_coords": [[[747.0, 707.0], [767.0, 707.0], [767.0, 805.0], [747.0, 805.0]], [[724.0, 706.0], [744.0, 706.0], [742.0, 841.0], [722.0, 841.0]], [[702.0, 707.0], [719.0, 707.0], [717.0, 803.0], [699.0, 803.0]]], "lines": ["．．．以前にも", "少し触れた事が", "ありますが"]}, {"box": [113, 693, 258, 830], "vertical": true, "font_size": 22, "lines_coords": [[[235.0, 694.0], [256.0, 694.0], [257.0, 812.0], [236.0, 812.0]], [[213.0, 694.0], [233.0, 694.0], [233.0, 830.0], [213.0, 830.0]], [[187.0, 694.0], [211.0, 694.0], [211.0, 814.0], [187.0, 814.0]], [[164.0, 696.0], [185.0, 696.0], [186.0, 812.0], [165.0, 812.0]], [[140.0, 696.0], [160.0, 696.0], [162.0, 812.0], [143.0, 812.0]], [[116.0, 693.0], [143.0, 694.0], [140.0, 747.0], [113.0, 746.0]]], "lines": ["私達がその日", "連れてこられた", "のも、そんな", "廃屋のうちの", "一軒だったの", "です。"]}, {"box": [361, 930, 451, 1088], "vertical": true, "font_size": 18, "lines_coords": [[[432.0, 932.0], [448.0, 932.0], [448.0, 1086.0], [432.0, 1086.0]], [[406.0, 931.0], [426.0, 931.0], [426.0, 1065.0], [406.0, 1065.0]], [[383.0, 930.0], [403.0, 930.0], [400.0, 1047.0], [380.0, 1047.0]], [[361.0, 932.0], [377.0, 932.0], [377.0, 1047.0], [361.0, 1047.0]]], "lines": ["この町には昔から", "あちこちに古い", "長屋の廃墟が", "点在しており"]}], "img_path": "013.jpg"}, {"version": "0.1.7", "img_width": 832, "img_height": 1200, "blocks": [{"box": [636, 93, 730, 174], "vertical": true, "font_size": 23, "lines_coords": [[[705.0, 94.0], [730.0, 94.0], [730.0, 157.0], [705.0, 157.0]], [[682.0, 94.0], [706.0, 94.0], [706.0, 174.0], [682.0, 174.0]], [[659.0, 94.0], [679.0, 94.0], [679.0, 172.0], [659.0, 172.0]], [[636.0, 93.0], [660.0, 93.0], [660.0, 124.0], [636.0, 124.0]]], "lines": ["しかも", "三丁目の", "この廃屋", "は、"]}, {"box": [73, 140, 189, 274], "vertical": true, "font_size": 20, "lines_coords": [[[167.0, 141.0], [188.0, 141.0], [188.0, 239.0], [167.0, 239.0]], [[144.0, 141.0], [164.0, 141.0], [162.0, 274.0], [142.0, 274.0]], [[119.0, 140.0], [140.0, 140.0], [141.0, 244.0], [120.0, 244.0]], [[96.0, 140.0], [116.0, 140.0], [116.0, 236.0], [96.0, 236.0]], [[73.0, 144.0], [90.0, 144.0], [90.0, 255.0], [73.0, 255.0]]], "lines": ["毎夜、鬼が", "出没するという", "噂があって、", "恐れられて", "いるのです．．"]}, {"box": [573, 319, 714, 432], "vertical": true, "font_size": 21, "lines_coords": [[[693.0, 319.0], [714.0, 319.0], [714.0, 413.0], [693.0, 413.0]], [[670.0, 321.0], [691.0, 321.0], [691.0, 397.0], [670.0, 397.0]], [[645.0, 319.0], [666.0, 319.0], [666.0, 423.0], [645.0, 423.0]], [[621.0, 321.0], [640.0, 321.0], [640.0, 396.0], [621.0, 396.0]], [[596.0, 319.0], [616.0, 319.0], [616.0, 431.0], [596.0, 431.0]], [[573.0, 321.0], [597.0, 321.0], [597.0, 385.0], [573.0, 385.0]]], "lines": ["実際、この", "近所では", "度々飼犬が", "何者かに", "食い殺されて", "います。"]}, {"box": [413, 317, 533, 424], "vertical": true, "font_size": 22, "lines_coords": [[[512.0, 319.0], [532.0, 319.0], [532.0, 424.0], [512.0, 424.0]], [[487.0, 319.0], [508.0, 319.0], [508.0, 398.0], [487.0, 398.0]], [[462.0, 321.0], [483.0, 321.0], [483.0, 398.0], [462.0, 398.0]], [[438.0, 319.0], [459.0, 319.0], [461.0, 398.0], [440.0, 398.0]], [[413.0, 317.0], [441.0, 317.0], [441.0, 353.0], [413.0, 353.0]]], "lines": ["アハハ坊や、", "鬼なんて", "この世に", "いるもん", "か。"]}, {"box": [212, 326, 303, 504], "vertical": true, "font_size": 18, "lines_coords": [[[283.0, 329.0], [299.0, 329.0], [299.0, 502.0], [283.0, 502.0]], [[257.0, 328.0], [277.0, 328.0], [277.0, 481.0], [257.0, 481.0]], [[234.0, 326.0], [254.0, 326.0], [254.0, 461.0], [234.0, 461.0]], [[212.0, 328.0], [228.0, 328.0], [228.0, 461.0], [212.0, 461.0]]], "lines": ["冗談じゃありません", "鬼の事はともかく", "こんな廃屋には", "住めませんよ！！"]}, {"box": [620, 649, 710, 802], "vertical": true, "font_size": 18, "lines_coords": [[[690.0, 649.0], [710.0, 649.0], [707.0, 802.0], [687.0, 802.0]], [[667.0, 651.0], [684.0, 651.0], [684.0, 782.0], [667.0, 782.0]], [[643.0, 649.0], [663.0, 649.0], [660.0, 766.0], [640.0, 766.0]], [[621.0, 650.0], [637.0, 650.0], [637.0, 772.0], [621.0, 772.0]]], "lines": ["．．．しかし、これが", "被災者のために", "町が用意した", "ものなんです。"]}, {"box": [62, 646, 155, 806], "vertical": true, "font_size": 20, "lines_coords": [[[133.0, 646.0], [154.0, 646.0], [154.0, 707.0], [133.0, 707.0]], [[111.0, 646.0], [131.0, 646.0], [128.0, 803.0], [108.0, 803.0]], [[87.0, 649.0], [104.0, 649.0], [104.0, 761.0], [87.0, 761.0]], [[62.0, 646.0], [82.0, 646.0], [83.0, 788.0], [63.0, 788.0]]], "lines": ["ここは", "３世帯入れますが、", "両側２世帯は", "入居済みですよ。"]}, {"box": [621, 967, 713, 1087], "vertical": true, "font_size": 18, "lines_coords": [[[694.0, 969.0], [711.0, 969.0], [711.0, 1082.0], [694.0, 1082.0]], [[669.0, 967.0], [689.0, 967.0], [689.0, 1086.0], [669.0, 1086.0]], [[648.0, 969.0], [664.0, 969.0], [664.0, 1062.0], [648.0, 1062.0]], [[621.0, 967.0], [642.0, 967.0], [642.0, 1035.0], [621.0, 1035.0]]], "lines": ["建物の補修も", "済んでますし、", "電気もひき", "ました。"]}, {"box": [220, 976, 313, 1117], "vertical": true, "font_size": 18, "lines_coords": [[[295.0, 978.0], [311.0, 978.0], [311.0, 1092.0], [295.0, 1092.0]], [[268.0, 976.0], [288.0, 976.0], [289.0, 1115.0], [269.0, 1115.0]], [[247.0, 978.0], [263.0, 978.0], [263.0, 1053.0], [247.0, 1053.0]], [[220.0, 976.0], [240.0, 976.0], [242.0, 1080.0], [222.0, 1080.0]]], "lines": ["簡易トイレも", "設置しましたし、", "不自由は", "ないですよ。"]}], "img_path": "014.jpg"}, {"version": "0.1.7", "img_width": 832, "img_height": 1200, "blocks": [{"box": [690, 87, 757, 241], "vertical": true, "font_size": 20, "lines_coords": [[[737.0, 89.0], [757.0, 89.0], [757.0, 205.0], [737.0, 205.0]], [[714.0, 89.0], [734.0, 89.0], [732.0, 240.0], [712.0, 240.0]], [[692.0, 87.0], [712.0, 87.0], [710.0, 210.0], [690.0, 210.0]]], "lines": ["他の空家にも", "どんどん被災者が", "入ってますし、"]}, {"box": [362, 140, 456, 332], "vertical": true, "font_size": 20, "lines_coords": [[[434.0, 142.0], [454.0, 142.0], [454.0, 280.0], [434.0, 280.0]], [[412.0, 140.0], [432.0, 140.0], [431.0, 332.0], [411.0, 332.0]], [[387.0, 141.0], [407.0, 141.0], [407.0, 315.0], [387.0, 315.0]], [[362.0, 140.0], [382.0, 140.0], [385.0, 247.0], [365.0, 247.0]]], "lines": ["早く決めないと、", "もっと条件の悪い所に", "入らなきゃならなく", "なりますよ。"]}, {"box": [113, 173, 159, 353], "vertical": true, "font_size": 20, "lines_coords": [[[137.0, 173.0], [157.0, 173.0], [159.0, 328.0], [139.0, 328.0]], [[113.0, 174.0], [133.0, 174.0], [134.0, 353.0], [114.0, 353.0]]], "lines": ["有無を言わせぬ．．．", "といった感じでした。"]}, {"box": [113, 719, 135, 822], "vertical": true, "font_size": 20, "lines_coords": [[[113.0, 719.0], [133.0, 719.0], [133.0, 822.0], [113.0, 822.0]]], "lines": ["ネズミだわ"]}, {"box": [715, 877, 762, 1012], "vertical": true, "font_size": 21, "lines_coords": [[[744.0, 881.0], [760.0, 881.0], [760.0, 1012.0], [744.0, 1012.0]], [[715.0, 877.0], [741.0, 877.0], [741.0, 930.0], [715.0, 930.0]]], "lines": ["やになっちゃう", "わね。"]}, {"box": [407, 882, 495, 1075], "vertical": true, "font_size": 22, "lines_coords": [[[469.0, 882.0], [495.0, 882.0], [495.0, 962.0], [469.0, 962.0]], [[449.0, 884.0], [469.0, 884.0], [469.0, 1075.0], [449.0, 1075.0]], [[425.0, 884.0], [445.0, 884.0], [445.0, 1055.0], [425.0, 1055.0]]], "lines": ["補修って", "いったって、壁の穴を", "塞いであるだけだし"]}, {"box": [107, 926, 201, 1080], "vertical": true, "font_size": 20, "lines_coords": [[[178.0, 926.0], [199.0, 926.0], [201.0, 1079.0], [180.0, 1079.0]], [[154.0, 928.0], [174.0, 928.0], [174.0, 1079.0], [154.0, 1079.0]], [[132.0, 928.0], [152.0, 928.0], [152.0, 1080.0], [132.0, 1080.0]], [[107.0, 926.0], [128.0, 926.0], [128.0, 1011.0], [107.0, 1011.0]]], "lines": ["電気をひいたって", "いうけど、水道が", "ないからやっぱり", "不便だわ。"]}], "img_path": "015.jpg"}, {"version": "0.1.7", "img_width": 832, "img_height": 1200, "blocks": [{"box": [567, 84, 706, 256], "vertical": true, "font_size": 19, "lines_coords": [[[686.0, 86.0], [703.0, 86.0], [703.0, 202.0], [686.0, 202.0]], [[660.0, 84.0], [680.0, 84.0], [680.0, 201.0], [660.0, 201.0]], [[636.0, 84.0], [656.0, 84.0], [656.0, 256.0], [636.0, 256.0]], [[612.0, 84.0], [632.0, 84.0], [632.0, 220.0], [612.0, 220.0]], [[589.0, 85.0], [609.0, 85.0], [609.0, 219.0], [589.0, 219.0]], [[567.0, 85.0], [583.0, 85.0], [583.0, 180.0], [567.0, 180.0]]], "lines": ["ねえお父さん", "電気も水道も", "トイレもないなんて", "この長屋、一体", "いつ建てられた", "ものなの？"]}, {"box": [386, 93, 503, 230], "vertical": true, "font_size": 21, "lines_coords": [[[483.0, 96.0], [501.0, 96.0], [502.0, 191.0], [485.0, 191.0]], [[460.0, 94.0], [480.0, 94.0], [480.0, 209.0], [460.0, 209.0]], [[435.0, 96.0], [455.0, 96.0], [455.0, 212.0], [435.0, 212.0]], [[413.0, 94.0], [433.0, 94.0], [433.0, 230.0], [413.0, 230.0]], [[386.0, 93.0], [412.0, 93.0], [412.0, 155.0], [386.0, 155.0]]], "lines": ["さあな．．．", "聞いた話では", "明治以前から", "立ってるって事", "だが．．"]}, {"box": [67, 98, 139, 179], "vertical": true, "font_size": 26, "lines_coords": [[[114.0, 98.0], [139.0, 98.0], [139.0, 168.0], [114.0, 168.0]], [[87.0, 98.0], [117.0, 98.0], [117.0, 164.0], [87.0, 164.0]], [[67.0, 100.0], [89.0, 100.0], [89.0, 179.0], [67.0, 179.0]]], "lines": ["えーっ、", "そんな", "昔から？"]}, {"box": [648, 495, 716, 640], "vertical": true, "font_size": 18, "lines_coords": [[[696.0, 499.0], [715.0, 499.0], [715.0, 618.0], [696.0, 618.0]], [[673.0, 499.0], [690.0, 499.0], [690.0, 592.0], [673.0, 592.0]], [[648.0, 495.0], [667.0, 495.0], [669.0, 638.0], [649.0, 638.0]]], "lines": ["オレやだよー、", "こんな所に", "住みたくないよ。"]}, {"box": [335, 503, 402, 665], "vertical": true, "font_size": 18, "lines_coords": [[[382.0, 503.0], [401.0, 503.0], [401.0, 657.0], [382.0, 657.0]], [[357.0, 505.0], [377.0, 505.0], [377.0, 657.0], [357.0, 657.0]], [[335.0, 503.0], [350.0, 503.0], [350.0, 663.0], [335.0, 663.0]]], "lines": ["ぜいたく言うな！！", "雨風しのげるだけ", "ありがたいと思えば"]}, {"box": [65, 336, 160, 443], "vertical": true, "font_size": 22, "lines_coords": [[[135.0, 336.0], [160.0, 336.0], [160.0, 397.0], [135.0, 397.0]], [[114.0, 337.0], [134.0, 337.0], [134.0, 433.0], [114.0, 433.0]], [[90.0, 337.0], [111.0, 337.0], [111.0, 416.0], [90.0, 416.0]], [[65.0, 336.0], [85.0, 336.0], [87.0, 442.0], [67.0, 442.0]]], "lines": ["．．．鬼が", "住んでても", "不思議は", "ないかもね。"]}, {"box": [565, 714, 708, 849], "vertical": true, "font_size": 22, "lines_coords": [[[689.0, 716.0], [708.0, 716.0], [708.0, 796.0], [689.0, 796.0]], [[664.0, 717.0], [685.0, 717.0], [685.0, 792.0], [664.0, 792.0]], [[639.0, 714.0], [663.0, 714.0], [663.0, 833.0], [639.0, 833.0]], [[616.0, 717.0], [636.0, 717.0], [636.0, 849.0], [616.0, 849.0]], [[592.0, 716.0], [612.0, 716.0], [612.0, 794.0], [592.0, 794.0]], [[565.0, 716.0], [590.0, 716.0], [590.0, 783.0], [565.0, 783.0]]], "lines": ["．．．さてと", "俺は家へ", "行ってくる．．．", "残骸の後始末が", "残ってる", "からな。"]}, {"box": [308, 716, 421, 841], "vertical": true, "font_size": 21, "lines_coords": [[[398.0, 716.0], [420.0, 716.0], [420.0, 832.0], [398.0, 832.0]], [[374.0, 716.0], [399.0, 716.0], [399.0, 785.0], [374.0, 785.0]], [[352.0, 717.0], [373.0, 717.0], [373.0, 794.0], [352.0, 794.0]], [[329.0, 717.0], [349.0, 717.0], [349.0, 814.0], [329.0, 814.0]], [[308.0, 718.0], [324.0, 718.0], [324.0, 837.0], [308.0, 837.0]]], "lines": ["私もあとから", "行くわ。", "その前に", "両隣に挨拶", "しとかないと、"]}, {"box": [173, 719, 225, 881], "vertical": true, "font_size": 20, "lines_coords": [[[195.0, 719.0], [216.0, 719.0], [217.0, 798.0], [196.0, 798.0]], [[173.0, 719.0], [193.0, 719.0], [194.0, 881.0], [174.0, 881.0]]], "lines": ["桐絵達も", "ついてらっしゃい。"]}], "img_path": "016.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [635, 80, 757, 184], "vertical": true, "font_size": 22, "lines_coords": [[[737.0, 84.0], [757.0, 84.0], [757.0, 181.0], [737.0, 181.0]], [[713.0, 83.0], [734.0, 83.0], [732.0, 171.0], [711.0, 171.0]], [[689.0, 84.0], [709.0, 84.0], [709.0, 180.0], [689.0, 180.0]], [[656.0, 80.0], [685.0, 80.0], [685.0, 146.0], [656.0, 146.0]], [[635.0, 82.0], [656.0, 82.0], [657.0, 168.0], [636.0, 168.0]]], "lines": ["こんにちは", "今度隣に", "越してきた", "五島と", "申します。"]}, {"box": [435, 100, 500, 201], "vertical": true, "font_size": 18, "lines_coords": [[[482.0, 100.0], [499.0, 100.0], [499.0, 199.0], [482.0, 199.0]], [[457.0, 100.0], [477.0, 100.0], [477.0, 196.0], [457.0, 196.0]], [[435.0, 100.0], [452.0, 100.0], [452.0, 182.0], [435.0, 182.0]]], "lines": ["ああどうも、", "私は若林と", "申します"]}, {"box": [121, 101, 165, 245], "vertical": true, "font_size": 18, "lines_coords": [[[145.0, 103.0], [165.0, 103.0], [165.0, 219.0], [145.0, 219.0]], [[123.0, 101.0], [139.0, 101.0], [139.0, 241.0], [123.0, 241.0]]], "lines": ["今度の台風は", "大変でしたよね。"]}, {"box": [704, 486, 769, 638], "vertical": true, "font_size": 17, "lines_coords": [[[751.0, 487.0], [767.0, 487.0], [767.0, 638.0], [751.0, 638.0]], [[725.0, 486.0], [745.0, 486.0], [745.0, 612.0], [725.0, 612.0]], [[704.0, 487.0], [720.0, 487.0], [720.0, 625.0], [704.0, 625.0]]], "lines": ["あ：向こうの人は", "多分呼んでも", "出てきませんよ。"]}, {"box": [311, 488, 378, 726], "vertical": true, "font_size": 19, "lines_coords": [[[357.0, 488.0], [377.0, 488.0], [377.0, 705.0], [357.0, 705.0]], [[334.0, 488.0], [353.0, 488.0], [351.0, 680.0], [331.0, 680.0]], [[311.0, 489.0], [328.0, 489.0], [328.0, 726.0], [311.0, 726.0]]], "lines": ["どうやら被災者じゃなく、", "以前からここに勝手に", "佳みついてた人のようです。"]}, {"box": [121, 1032, 138, 1095], "vertical": true, "font_size": 17, "lines_coords": [[[121.0, 1032.0], [138.0, 1032.0], [138.0, 1095.0], [121.0, 1095.0]]], "lines": ["．．．．．．"]}], "img_path": "017.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [298, 90, 317, 183], "vertical": true, "font_size": 17, "lines_coords": [[[298.0, 90.0], [315.0, 90.0], [315.0, 183.0], [298.0, 183.0]]], "lines": ["お母さん．．．"]}, {"box": [39, 83, 106, 224], "vertical": true, "font_size": 19, "lines_coords": [[[84.0, 83.0], [104.0, 83.0], [105.0, 222.0], [85.0, 222.0]], [[60.0, 83.0], [80.0, 83.0], [83.0, 180.0], [63.0, 180.0]], [[39.0, 85.0], [56.0, 85.0], [56.0, 181.0], [39.0, 181.0]]], "lines": ["隣に住んでるの、", "鬼なんじゃ", "ないのか！？"]}, {"box": [693, 404, 736, 574], "vertical": true, "font_size": 18, "lines_coords": [[[716.0, 405.0], [736.0, 405.0], [736.0, 481.0], [716.0, 481.0]], [[693.0, 404.0], [710.0, 404.0], [710.0, 574.0], [693.0, 574.0]]], "lines": ["バカな事", "言うんじゃないの！！"]}, {"box": [288, 396, 333, 510], "vertical": true, "font_size": 20, "lines_coords": [[[311.0, 397.0], [331.0, 397.0], [331.0, 509.0], [311.0, 509.0]], [[290.0, 396.0], [310.0, 396.0], [308.0, 494.0], [288.0, 494.0]]], "lines": ["だって怪しい", "じゃんか！！"]}, {"box": [131, 387, 248, 485], "vertical": true, "font_size": 23, "lines_coords": [[[228.0, 391.0], [248.0, 391.0], [248.0, 485.0], [228.0, 485.0]], [[200.0, 387.0], [228.0, 387.0], [228.0, 416.0], [200.0, 416.0]], [[176.0, 390.0], [202.0, 390.0], [202.0, 452.0], [176.0, 452.0]], [[155.0, 391.0], [175.0, 391.0], [175.0, 467.0], [155.0, 467.0]], [[131.0, 390.0], [152.0, 390.0], [153.0, 468.0], [132.0, 468.0]]], "lines": ["やめなさい", "！！", "お隣に", "聞こえる", "でしょ！！"]}, {"box": [530, 706, 727, 807], "vertical": true, "font_size": 26, "lines_coords": [[[695.0, 707.0], [726.0, 707.0], [726.0, 772.0], [695.0, 772.0]], [[668.0, 707.0], [699.0, 706.0], [702.0, 769.0], [670.0, 771.0]], [[648.0, 707.0], [672.0, 707.0], [672.0, 787.0], [648.0, 787.0]], [[621.0, 706.0], [653.0, 706.0], [653.0, 754.0], [621.0, 754.0]], [[578.0, 713.0], [598.0, 713.0], [598.0, 807.0], [578.0, 807.0]], [[555.0, 712.0], [575.0, 712.0], [573.0, 791.0], [553.0, 791.0]], [[530.0, 712.0], [550.0, 712.0], [550.0, 789.0], [530.0, 789.0]]], "lines": ["痛っ．．．", "こりゃ", "うおの目", "だ．．", "いつの間に", "できたん", "だろう．．"]}, {"box": [427, 704, 501, 772], "vertical": true, "font_size": 30, "lines_coords": [[[469.0, 707.0], [501.0, 707.0], [501.0, 755.0], [469.0, 755.0]], [[450.0, 704.0], [481.0, 706.0], [478.0, 755.0], [446.0, 753.0]], [[427.0, 708.0], [453.0, 708.0], [453.0, 772.0], [427.0, 772.0]]], "lines": ["え．．", "どれ", "どれ？"]}, {"box": [297, 704, 359, 761], "vertical": false, "font_size": 57, "lines_coords": [[[297.0, 704.0], [359.0, 704.0], [359.0, 761.0], [297.0, 761.0]]], "lines": ["これだ。"]}, {"box": [234, 713, 257, 755], "vertical": true, "font_size": 23, "lines_coords": [[[234.0, 713.0], [257.0, 713.0], [257.0, 755.0], [234.0, 755.0]]], "lines": ["な？"]}], "img_path": "018.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [212, 689, 392, 746], "vertical": false, "font_size": 54, "lines_coords": [[[212.0, 692.0], [391.0, 689.0], [392.0, 742.0], [213.0, 746.0]]], "lines": ["ゥウウゥ"]}, {"box": [437, 812, 506, 911], "vertical": false, "font_size": 90, "lines_coords": [[[461.0, 812.0], [506.0, 825.0], [481.0, 911.0], [437.0, 900.0]]], "lines": ["ウゥウ"]}, {"box": [702, 711, 781, 911], "vertical": true, "font_size": 66, "lines_coords": [[[702.0, 761.0], [767.0, 760.0], [770.0, 902.0], [704.0, 903.0]]], "lines": ["ウ、ウ"]}, {"box": [125, 951, 317, 1083], "vertical": false, "font_size": 105, "lines_coords": [[[125.0, 979.0], [301.0, 951.0], [317.0, 1055.0], [141.0, 1083.0]]], "lines": ["オオオ"]}, {"box": [580, 945, 643, 1093], "vertical": true, "font_size": 55, "lines_coords": [[[588.0, 945.0], [643.0, 949.0], [635.0, 1093.0], [580.0, 1089.0]]], "lines": ["ウウゥ"]}], "img_path": "019.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [563, 22, 714, 106], "vertical": false, "font_size": 56, "lines_coords": [[[563.0, 51.0], [703.0, 22.0], [714.0, 77.0], [575.0, 106.0]]], "lines": ["ウウ？"]}, {"box": [278, 50, 503, 128], "vertical": false, "font_size": 62, "lines_coords": [[[283.0, 50.0], [503.0, 66.0], [499.0, 128.0], [278.0, 112.0]]], "lines": ["アウゥウ"]}, {"box": [-1, 86, 232, 179], "vertical": false, "font_size": 80, "lines_coords": [[[0.0, 99.0], [227.0, 86.0], [232.0, 166.0], [0.0, 179.0]]], "lines": ["オォオォォ"]}, {"box": [679, 434, 724, 532], "vertical": true,