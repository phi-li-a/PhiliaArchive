], [[614.0, 760.0], [634.0, 760.0], [631.0, 861.0], [611.0, 861.0]]], "lines": ["こんなに", "うまいなら、", "もっと早く", "食っときゃ", "よかったな。"]}, {"box": [523, 762, 546, 814], "vertical": true, "font_size": 23, "lines_coords": [[[523.0, 762.0], [546.0, 762.0], [546.0, 814.0], [523.0, 814.0]]], "lines": ["ああ。"]}, {"box": [419, 769, 485, 942], "vertical": true, "font_size": 20, "lines_coords": [[[462.0, 769.0], [484.0, 769.0], [485.0, 942.0], [464.0, 942.0]], [[439.0, 769.0], [460.0, 769.0], [461.0, 942.0], [440.0, 942.0]], [[419.0, 772.0], [435.0, 772.0], [435.0, 871.0], [419.0, 871.0]]], "lines": ["おい、岡本のやつが", "完全にカタツムリに", "なったらさ、"]}, {"box": [66, 783, 87, 924], "vertical": true, "font_size": 18, "lines_coords": [[[66.0, 783.0], [84.0, 783.0], [85.0, 922.0], [67.0, 922.0]]], "lines": ["食料にしようぜ。"]}, {"box": [475, 985, 490, 1047], "vertical": true, "font_size": 15, "lines_coords": [[[475.0, 985.0], [490.0, 985.0], [490.0, 1047.0], [475.0, 1047.0]]], "lines": ["．．．．．．"]}], "img_path": "134.jpg"}, {"version": "0.1.7", "img_width": 841, "img_height": 1200, "blocks": [{"box": [700, 92, 771, 162], "vertical": true, "font_size": 27, "lines_coords": [[[744.0, 92.0], [771.0, 92.0], [771.0, 142.0], [744.0, 142.0]], [[720.0, 92.0], [750.0, 92.0], [750.0, 157.0], [720.0, 157.0]], [[700.0, 93.0], [725.0, 93.0], [725.0, 162.0], [700.0, 162.0]]], "lines": ["さあ、", "君達も", "食えよ。"]}, {"box": [262, 97, 280, 154], "vertical": true, "font_size": 17, "lines_coords": [[[262.0, 97.0], [279.0, 97.0], [279.0, 154.0], [262.0, 154.0]]], "lines": ["さあ！！"]}, {"box": [482, 271, 551, 388], "vertical": true, "font_size": 21, "lines_coords": [[[529.0, 275.0], [549.0, 275.0], [551.0, 371.0], [531.0, 371.0]], [[509.0, 277.0], [525.0, 277.0], [525.0, 387.0], [509.0, 387.0]], [[482.0, 271.0], [510.0, 271.0], [510.0, 308.0], [482.0, 308.0]]], "lines": ["食わなきゃ", "生き残れない", "ぞ。"]}, {"box": [719, 866, 773, 931], "vertical": true, "font_size": 32, "lines_coords": [[[739.0, 866.0], [773.0, 866.0], [773.0, 911.0], [739.0, 911.0]], [[719.0, 867.0], [748.0, 867.0], [748.0, 931.0], [719.0, 931.0]]], "lines": ["秀一", "君．．．．．"]}, {"box": [535, 876, 584, 942], "vertical": true, "font_size": 27, "lines_coords": [[[555.0, 877.0], [582.0, 876.0], [584.0, 941.0], [557.0, 942.0]], [[535.0, 878.0], [561.0, 878.0], [561.0, 941.0], [535.0, 941.0]]], "lines": ["その夜", "私は．．"]}, {"box": [128, 956, 174, 1091], "vertical": true, "font_size": 20, "lines_coords": [[[153.0, 957.0], [173.0, 957.0], [173.0, 1091.0], [153.0, 1091.0]], [[131.0, 956.0], [151.0, 956.0], [148.0, 1073.0], [128.0, 1073.0]]], "lines": ["ヒトマイマイを", "食べました．．．"]}], "img_path": "135.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [639, 125, 707, 267], "vertical": true, "font_size": 20, "lines_coords": [[[687.0, 126.0], [707.0, 126.0], [707.0, 243.0], [687.0, 243.0]], [[662.0, 125.0], [683.0, 125.0], [684.0, 223.0], [663.0, 223.0]], [[639.0, 125.0], [659.0, 125.0], [659.0, 263.0], [639.0, 263.0]]], "lines": ["翌朝、私達は", "谷崎さんの", "グループを離れ"]}, {"box": [298, 96, 365, 337], "vertical": true, "font_size": 19, "lines_coords": [[[346.0, 98.0], [363.0, 98.0], [363.0, 230.0], [346.0, 230.0]], [[319.0, 96.0], [343.0, 96.0], [343.0, 337.0], [319.0, 337.0]], [[300.0, 98.0], [316.0, 98.0], [316.0, 307.0], [300.0, 307.0]]], "lines": ["母と満男のいる", "バラックへと向かいました。", "あの肉の残りを持って．．．"]}, {"box": [53, 98, 93, 159], "vertical": true, "font_size": 27, "lines_coords": [[[66.0, 98.0], [93.0, 98.0], [93.0, 159.0], [66.0, 159.0]]], "lines": ["あれっ"]}, {"box": [614, 391, 707, 491], "vertical": true, "font_size": 21, "lines_coords": [[[680.0, 391.0], [705.0, 391.0], [707.0, 474.0], [683.0, 474.0]], [[659.0, 393.0], [679.0, 393.0], [679.0, 488.0], [659.0, 488.0]], [[637.0, 394.0], [657.0, 394.0], [657.0, 491.0], [637.0, 491.0]], [[614.0, 396.0], [634.0, 396.0], [634.0, 472.0], [614.0, 472.0]]], "lines": ["．．．変ね．．．", "このあたり", "だと思った", "けど．．．"]}, {"box": [215, 387, 231, 431], "vertical": true, "font_size": 16, "lines_coords": [[[215.0, 387.0], [231.0, 387.0], [231.0, 431.0], [215.0, 431.0]]], "lines": ["．．．"]}, {"box": [658, 786, 704, 873], "vertical": true, "font_size": 22, "lines_coords": [[[679.0, 787.0], [704.0, 787.0], [704.0, 849.0], [679.0, 849.0]], [[661.0, 786.0], [680.0, 786.0], [678.0, 871.0], [658.0, 871.0]]], "lines": ["おねえ", "ちゃ～ん"]}, {"box": [519, 766, 589, 843], "vertical": true, "font_size": 23, "lines_coords": [[[563.0, 766.0], [589.0, 766.0], [589.0, 828.0], [563.0, 828.0]], [[543.0, 766.0], [563.0, 766.0], [563.0, 843.0], [543.0, 843.0]], [[519.0, 768.0], [542.0, 768.0], [542.0, 808.0], [519.0, 808.0]]], "lines": ["おねえ", "ちゃ～ん", "．．．"]}, {"box": [264, 636, 329, 734], "vertical": true, "font_size": 23, "lines_coords": [[[308.0, 638.0], [328.0, 638.0], [328.0, 734.0], [308.0, 734.0]], [[278.0, 637.0], [304.0, 636.0], [307.0, 698.0], [281.0, 699.0]]], "lines": ["バラックが", "ないわ"]}, {"box": [152, 765, 221, 841], "vertical": true, "font_size": 24, "lines_coords": [[[200.0, 765.0], [221.0, 765.0], [221.0, 841.0], [200.0, 841.0]], [[174.0, 765.0], [201.0, 765.0], [201.0, 826.0], [174.0, 826.0]], [[152.0, 765.0], [179.0, 765.0], [179.0, 808.0], [152.0, 808.0]]], "lines": ["今出して", "あげる", "．．．"]}, {"box": [55, 660, 119, 723], "vertical": true, "font_size": 24, "lines_coords": [[[97.0, 660.0], [119.0, 660.0], [119.0, 705.0], [97.0, 705.0]], [[72.0, 662.0], [98.0, 662.0], [98.0, 723.0], [72.0, 723.0]]], "lines": ["ま．．", "まさか"]}, {"box": [42, 774, 112, 855], "vertical": true, "font_size": 24, "lines_coords": [[[86.0, 774.0], [112.0, 774.0], [112.0, 837.0], [86.0, 837.0]], [[65.0, 776.0], [86.0, 776.0], [86.0, 855.0], [65.0, 855.0]], [[42.0, 776.0], [63.0, 776.0], [63.0, 837.0], [42.0, 837.0]]], "lines": ["竜巻に", "やられた", "のね！？"]}, {"box": [273, 1034, 294, 1094], "vertical": true, "font_size": 21, "lines_coords": [[[273.0, 1034.0], [294.0, 1034.0], [294.0, 1094.0], [273.0, 1094.0]]], "lines": ["満男！"]}], "img_path": "136.jpg"}, {"version": "0.1.7", "img_width": 841, "img_height": 1200, "blocks": [{"box": [760, 97, 785, 160], "vertical": true, "font_size": 25, "lines_coords": [[[760.0, 97.0], [785.0, 97.0], [785.0, 160.0], [760.0, 160.0]]], "lines": ["ねえ．．．"]}, {"box": [554, 89, 598, 185], "vertical": true, "font_size": 19, "lines_coords": [[[579.0, 92.0], [596.0, 92.0], [596.0, 185.0], [579.0, 185.0]], [[554.0, 89.0], [575.0, 89.0], [575.0, 150.0], [554.0, 150.0]]], "lines": ["お母さんは", "どこ！？"]}, {"box": [452, 98, 525, 176], "vertical": true, "font_size": 27, "lines_coords": [[[501.0, 99.0], [525.0, 99.0], [525.0, 161.0], [501.0, 161.0]], [[475.0, 100.0], [502.0, 100.0], [503.0, 176.0], [476.0, 176.0]], [[452.0, 98.0], [483.0, 98.0], [483.0, 147.0], [452.0, 147.0]]], "lines": ["な．．．", "何ですっ", "て！？"]}, {"box": [127, 86, 267, 185], "vertical": true, "font_size": 23, "lines_coords": [[[237.0, 87.0], [264.0, 86.0], [267.0, 139.0], [240.0, 140.0]], [[219.0, 90.0], [240.0, 90.0], [240.0, 185.0], [219.0, 185.0]], [[189.0, 93.0], [212.0, 89.0], [220.0, 128.0], [197.0, 133.0]], [[153.0, 103.0], [174.0, 103.0], [174.0, 179.0], [153.0, 179.0]], [[130.0, 99.0], [153.0, 99.0], [151.0, 181.0], [127.0, 181.0]]], "lines": ["あっ、", "桐絵ちゃん", "．．．．．", "満男君の", "背中．．．．．．"]}, {"box": [559, 289, 606, 440], "vertical": true, "font_size": 22, "lines_coords": [[[580.0, 289.0], [604.0, 289.0], [606.0, 440.0], [583.0, 440.0]], [[561.0, 289.0], [580.0, 289.0], [579.0, 426.0], [559.0, 426.0]]], "lines": ["どっかへ飛んでっ", "ちゃったよ～～"]}, {"box": [217, 491, 265, 553], "vertical": true, "font_size": 26, "lines_coords": [[[241.0, 491.0], [265.0, 491.0], [265.0, 553.0], [241.0, 553.0]], [[217.0, 491.0], [245.0, 491.0], [245.0, 541.0], [217.0, 541.0]]], "lines": ["その時", "私は、"]}, {"box": [303, 1026, 319, 1041], "vertical": false, "font_size": 15, "lines_coords": [[[303.0, 1026.0], [319.0, 1026.0], [319.0, 1041.0], [303.0, 1041.0]]], "lines": ["あ"]}, {"box": [140, 923, 183, 1095], "vertical": true, "font_size": 18, "lines_coords": [[[163.0, 924.0], [181.0, 924.0], [180.0, 1095.0], [162.0, 1095.0]], [[141.0, 923.0], [159.0, 923.0], [158.0, 1044.0], [140.0, 1044.0]]], "lines": ["この町からの脱出を", "決意しました。"]}], "img_path": "137.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [369, -1, 397, 186], "vertical": true, "font_size": 17, "lines_coords": [[[373.0, 100.0], [390.0, 100.0], [390.0, 182.0], [373.0, 182.0]]], "lines": ["ダイエット"]}, {"box": [347, 201, 420, 352], "vertical": true, "font_size": 73, "lines_coords": [[[347.0, 201.0], [420.0, 201.0], [420.0, 352.0], [347.0, 352.0]]], "lines": ["脱出"]}], "img_path": "138.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [761, 103, 783, 200], "vertical": true, "font_size": 20, "lines_coords": [[[761.0, 103.0], [781.0, 103.0], [781.0, 199.0], [761.0, 199.0]]], "lines": ["とにかく．．"]}, {"box": [484, 91, 552, 283], "vertical": true, "font_size": 19, "lines_coords": [[[532.0, 92.0], [552.0, 92.0], [552.0, 208.0], [532.0, 208.0]], [[507.0, 91.0], [527.0, 91.0], [526.0, 283.0], [506.0, 283.0]], [[485.0, 91.0], [502.0, 91.0], [501.0, 225.0], [484.0, 225.0]]], "lines": ["満男が完全な", "ヒトマイマイになって", "しまう前に．．．"]}, {"box": [603, 318, 649, 537], "vertical": true, "font_size": 20, "lines_coords": [[[629.0, 318.0], [649.0, 318.0], [646.0, 530.0], [627.0, 530.0]], [[605.0, 318.0], [625.0, 318.0], [623.0, 536.0], [603.0, 536.0]]], "lines": ["早く満男を、この町から", "出さなければならないの。"]}, {"box": [124, 332, 194, 455], "vertical": true, "font_size": 20, "lines_coords": [[[171.0, 333.0], [194.0, 333.0], [192.0, 451.0], [168.0, 451.0]], [[148.0, 332.0], [168.0, 332.0], [166.0, 430.0], [146.0, 430.0]], [[125.0, 333.0], [142.0, 333.0], [141.0, 455.0], [124.0, 455.0]]], "lines": ["町から出せば", "きっと元に", "戻ると思うの。"]}, {"box": [707, 600, 776, 735], "vertical": true, "font_size": 20, "lines_coords": [[[754.0, 600.0], [774.0, 600.0], [775.0, 735.0], [755.0, 735.0]], [[733.0, 602.0], [750.0, 602.0], [750.0, 733.0], [733.0, 733.0]], [[707.0, 601.0], [729.0, 601.0], [729.0, 666.0], [707.0, 666.0]]], "lines": ["私はそのあとで", "また、この町に", "戻るわ。"]}, {"box": [452, 812, 494, 946], "vertical": true, "font_size": 18, "lines_coords": [[[474.0, 812.0], [494.0, 812.0], [493.0, 946.0], [473.0, 946.0]], [[452.0, 814.0], [468.0, 814.0], [468.0, 945.0], [452.0, 945.0]]], "lines": ["トンネルも海も", "だめとなると．．．"]}, {"box": [120, 577, 189, 769], "vertical": true, "font_size": 20, "lines_coords": [[[162.0, 577.0], [187.0, 577.0], [189.0, 666.0], [165.0, 666.0]], [[142.0, 578.0], [162.0, 578.0], [160.0, 769.0], [140.0, 769.0]], [[120.0, 581.0], [137.0, 581.0], [137.0, 682.0], [120.0, 682.0]]], "lines": ["．．．戻って、", "お父さんとお母さんを", "捜さなきゃ。"]}, {"box": [704, 887, 774, 1079], "vertical": true, "font_size": 22, "lines_coords": [[[753.0, 887.0], [774.0, 887.0], [773.0, 1061.0], [752.0, 1061.0]], [[730.0, 887.0], [750.0, 887.0], [747.0, 1079.0], [727.0, 1079.0]], [[704.0, 887.0], [730.0, 887.0], [730.0, 953.0], [704.0, 953.0]]], "lines": ["．．．でも、どうやって", "この町を脱出するかが", "問題よ。"]}, {"box": [368, 966, 412, 1083], "vertical": true, "font_size": 20, "lines_coords": [[[391.0, 966.0], [411.0, 966.0], [409.0, 1083.0], [389.0, 1083.0]], [[368.0, 967.0], [387.0, 967.0], [387.0, 1083.0], [368.0, 1083.0]]], "lines": ["．．．山を越える", "というのは？"]}], "img_path": "139.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [651, 98, 721, 239], "vertical": true, "font_size": 20, "lines_coords": [[[700.0, 98.0], [721.0, 98.0], [719.0, 239.0], [698.0, 239.0]], [[676.0, 99.0], [696.0, 99.0], [696.0, 198.0], [676.0, 198.0]], [[651.0, 98.0], [671.0, 98.0], [672.0, 233.0], [652.0, 233.0]]], "lines": ["山？．．．でも当然", "誰かがもう", "試したのでは？"]}, {"box": [452, 98, 495, 270], "vertical": true, "font_size": 18, "lines_coords": [[[474.0, 98.0], [494.0, 98.0], [494.0, 250.0], [474.0, 250.0]], [[453.0, 101.0], [469.0, 101.0], [469.0, 270.0], [453.0, 270.0]]], "lines": ["．．．誰も試してない", "山道はないがしら？"]}, {"box": [255, 101, 273, 235], "vertical": true, "font_size": 16, "lines_coords": [[[255.0, 101.0], [271.0, 101.0], [271.0, 234.0], [255.0, 234.0]]], "lines": ["どうせ無駄だ．．．"]}, {"box": [66, 101, 110, 272], "vertical": true, "font_size": 16, "lines_coords": [[[91.0, 103.0], [107.0, 103.0], [107.0, 271.0], [91.0, 271.0]], [[67.0, 101.0], [84.0, 101.0], [84.0, 271.0], [67.0, 271.0]]], "lines": ["オレ達はうずまきに", "呪われているんだ．．．"]}, {"box": [621, 335, 714, 489], "vertical": true, "font_size": 21, "lines_coords": [[[695.0, 336.0], [714.0, 336.0], [712.0, 457.0], [692.0, 457.0]], [[671.0, 335.0], [691.0, 335.0], [689.0, 452.0], [669.0, 452.0]], [[646.0, 336.0], [666.0, 336.0], [666.0, 489.0], [646.0, 489.0]], [[621.0, 335.0], [645.0, 335.0], [645.0, 401.0], [621.0, 401.0]]], "lines": ["私達にはもう、", "議論している", "時間はありません", "でした。"]}, {"box": [352, 326, 373, 408], "vertical": true, "font_size": 20, "lines_coords": [[[352.0, 326.0], [372.0, 326.0], [372.0, 408.0], [352.0, 408.0]]], "lines": ["いくわよ。"]}, {"box": [268, 665, 360, 782], "vertical": true, "font_size": 20, "lines_coords": [[[339.0, 667.0], [360.0, 667.0], [360.0, 732.0], [339.0, 732.0]], [[314.0, 665.0], [334.0, 665.0], [336.0, 782.0], [316.0, 782.0]], [[291.0, 666.0], [311.0, 666.0], [311.0, 761.0], [291.0, 761.0]], [[268.0, 665.0], [289.0, 665.0], [289.0, 731.0], [268.0, 731.0]]], "lines": ["．．．また、", "よりによって", "険しい山の", "方向ね。"]}, {"box": [67, 662, 135, 836], "vertical": true, "font_size": 20, "lines_coords": [[[113.0, 663.0], [134.0, 663.0], [134.0, 767.0], [113.0, 767.0]], [[90.0, 662.0], [110.0, 662.0], [112.0, 836.0], [92.0, 836.0]], [[67.0, 663.0], [85.0, 663.0], [86.0, 783.0], [69.0, 783.0]]], "lines": ["仕方ないわ。", "とにかく北へ北へと", "行きましょう。"]}, {"box": [63, 1030, 103, 1092], "vertical": true, "font_size": 26, "lines_coords": [[[77.0, 1030.0], [103.0, 1030.0], [103.0, 1092.0], [77.0, 1092.0]]], "lines": ["無駄だ"]}], "img_path": "140.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [693, 505, 761, 641], "vertical": true, "font_size": 20, "lines_coords": [[[741.0, 506.0], [761.0, 506.0], [761.0, 626.0], [741.0, 626.0]], [[717.0, 505.0], [737.0, 505.0], [737.0, 641.0], [717.0, 641.0]], [[693.0, 505.0], [713.0, 505.0], [713.0, 605.0], [693.0, 605.0]]], "lines": ["おねえちゃん、", "背中がむずむず", "するよ～～"]}, {"box": [452, 492, 480, 610], "vertical": true, "font_size": 23, "lines_coords": [[[452.0, 492.0], [475.0, 492.0], [475.0, 610.0], [452.0, 610.0]]], "lines": ["掻いてよ～～"]}, {"box": [378, 491, 421, 632], "vertical": true, "font_size": 18, "lines_coords": [[[400.0, 491.0], [420.0, 491.0], [420.0, 608.0], [400.0, 608.0]], [[378.0, 492.0], [394.0, 492.0], [394.0, 628.0], [378.0, 628.0]]], "lines": ["これから町を", "出るんだからね"]}, {"box": [103, 482, 145, 585], "vertical": true, "font_size": 18, "lines_coords": [[[124.0, 482.0], [145.0, 482.0], [145.0, 560.0], [124.0, 560.0]], [[103.0, 482.0], [119.0, 482.0], [119.0, 584.0], [103.0, 584.0]]], "lines": ["そしたら", "治るからね。"]}], "img_path": "141.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [627, 87, 717, 246], "vertical": true, "font_size": 18, "lines_coords": [[[698.0, 89.0], [714.0, 89.0], [714.0, 243.0], [698.0, 243.0]], [[673.0, 87.0], [695.0, 87.0], [693.0, 243.0], [672.0, 243.0]], [[650.0, 89.0], [670.0, 89.0], [670.0, 222.0], [650.0, 222.0]], [[627.0, 89.0], [643.0, 89.0], [643.0, 228.0], [627.0, 228.0]]], "lines": ["．．．こうして見ると", "長屋だけが壊れず", "残ってることが", "よくわかるわね。"]}, {"box": [239, 100, 282, 235], "vertical": true, "font_size": 20, "lines_coords": [[[262.0, 101.0], [282.0, 101.0], [282.0, 235.0], [262.0, 235.0]], [[239.0, 100.0], [259.0, 100.0], [259.0, 215.0], [239.0, 215.0]]], "lines": ["おねえちゃん．．．", "長屋って．．．"]}, {"box": [46, 80, 93, 290], "vertical": true, "font_size": 20, "lines_coords": [[[71.0, 80.0], [91.0, 80.0], [91.0, 290.0], [71.0, 290.0]], [[48.0, 80.0], [69.0, 80.0], [67.0, 253.0], [46.0, 253.0]]], "lines": ["みんなトンボ池のほうを", "向いてるんだね．．．"]}, {"box": [670, 385, 698, 459], "vertical": true, "font_size": 26, "lines_coords": [[[670.0, 386.0], [696.0, 385.0], [698.0, 458.0], [672.0, 459.0]]], "lines": ["えっ？"]}, {"box": [473, 636, 512, 773], "vertical": true, "font_size": 16, "lines_coords": [[[494.0, 637.0], [511.0, 637.0], [511.0, 773.0], [494.0, 773.0]], [[473.0, 637.0], [489.0, 637.0], [489.0, 723.0], [473.0, 723.0]]], "lines": ["トンボ池のほうを", "向いてる？"]}, {"box": [679, 1007, 725, 1105], "vertical": true, "font_size": 22, "lines_coords": [[[697.0, 1007.0], [725.0, 1007.0], [725.0, 1053.0], [697.0, 1053.0]], [[679.0, 1011.0], [696.0, 1011.0], [696.0, 1105.0], [679.0, 1105.0]]], "lines": ["あ．．．", "あれ見て！"]}], "img_path": "142.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [679, 110, 772, 271], "vertical": true, "font_size": 20, "lines_coords": [[[750.0, 110.0], [768.0, 110.0], [771.0, 227.0], [752.0, 227.0]], [[726.0, 110.0], [746.0, 110.0], [748.0, 271.0], [729.0, 271.0]], [[703.0, 111.0], [723.0, 111.0], [724.0, 264.0], [704.0, 264.0]], [[679.0, 112.0], [700.0, 112.0], [700.0, 171.0], [679.0, 171.0]]], "lines": ["誰かが竜巻を", "まき散らしながら、", "長屋を増築してる", "わ．．．"]}, {"box": [116, 92, 136, 206], "vertical": true, "font_size": 16, "lines_coords": [[[116.0, 92.0], [132.0, 92.0], [134.0, 206.0], [118.0, 206.0]]], "lines": ["あ．．．あれは．．．"]}, {"box": [726, 389, 771, 503], "vertical": true, "font_size": 20, "lines_coords": [[[751.0, 390.0], [771.0, 390.0], [771.0, 503.0], [751.0, 503.0]], [[726.0, 389.0], [747.0, 389.0], [747.0, 468.0], [726.0, 468.0]]], "lines": ["谷崎さんじゃ", "ないの！"]}, {"box": [671, 687, 768, 785], "vertical": true, "font_size": 22, "lines_coords": [[[739.0, 687.0], [768.0, 687.0], [768.0, 754.0], [739.0, 754.0]], [[718.0, 687.0], [744.0, 687.0], [744.0, 738.0], [718.0, 738.0]], [[696.0, 689.0], [717.0, 689.0], [717.0, 766.0], [696.0, 766.0]], [[671.0, 689.0], [693.0, 689.0], [693.0, 744.0], [671.0, 744.0]], [[675.0, 735.0], [691.0, 735.0], [691.0, 785.0], [675.0, 785.0]]], "lines": ["おーい", "君達ー", "脱出する", "のかー", "！？"]}, {"box": [519, 684, 612, 801], "vertical": true, "font_size": 22, "lines_coords": [[[587.0, 684.0], [612.0, 684.0], [612.0, 746.0], [587.0, 746.0]], [[567.0, 687.0],