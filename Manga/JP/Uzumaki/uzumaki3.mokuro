.0], [216.0, 328.0], [216.0, 404.0], [195.0, 404.0]], [[171.0, 328.0], [195.0, 328.0], [195.0, 394.0], [171.0, 394.0]]], "lines": ["ゆっくり", "歩けよ。"]}, {"box": [368, 788, 479, 864], "vertical": false, "font_size": 28, "lines_coords": [[[380.0, 788.0], [479.0, 840.0], [466.0, 864.0], [368.0, 813.0]]], "lines": ["うわああ！！"]}], "img_path": "107.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [666, 84, 737, 185], "vertical": true, "font_size": 26, "lines_coords": [[[706.0, 85.0], [737.0, 85.0], [737.0, 139.0], [706.0, 139.0]], [[684.0, 84.0], [714.0, 85.0], [712.0, 150.0], [682.0, 148.0]], [[666.0, 90.0], [683.0, 90.0], [683.0, 185.0], [666.0, 185.0]]], "lines": ["また、", "何人か", "やられた．．．"]}, {"box": [628, 251, 725, 332], "vertical": true, "font_size": 25, "lines_coords": [[[697.0, 251.0], [725.0, 251.0], [725.0, 302.0], [697.0, 302.0]], [[670.0, 253.0], [697.0, 253.0], [697.0, 314.0], [670.0, 314.0]], [[649.0, 254.0], [673.0, 254.0], [673.0, 332.0], [649.0, 332.0]], [[628.0, 251.0], [648.0, 251.0], [648.0, 319.0], [628.0, 319.0]]], "lines": ["多分、", "蝶族の", "起こした", "竜巻だ。"]}, {"box": [349, 89, 376, 141], "vertical": true, "font_size": 27, "lines_coords": [[[349.0, 89.0], [376.0, 89.0], [376.0, 141.0], [349.0, 141.0]]], "lines": ["おい、"]}, {"box": [65, 236, 138, 337], "vertical": true, "font_size": 28, "lines_coords": [[[108.0, 236.0], [138.0, 236.0], [138.0, 301.0], [108.0, 301.0]], [[85.0, 236.0], [117.0, 236.0], [117.0, 303.0], [85.0, 303.0]], [[67.0, 240.0], [89.0, 240.0], [86.0, 337.0], [65.0, 337.0]]], "lines": ["そこの", "人達．．．", "大丈夫か？"]}, {"box": [243, 480, 317, 547], "vertical": true, "font_size": 29, "lines_coords": [[[288.0, 481.0], [317.0, 481.0], [317.0, 546.0], [288.0, 546.0]], [[264.0, 480.0], [295.0, 480.0], [295.0, 547.0], [264.0, 547.0]], [[243.0, 480.0], [270.0, 480.0], [270.0, 534.0], [243.0, 534.0]]], "lines": ["はい．．．", "大丈夫", "です。"]}, {"box": [397, 589, 490, 745], "vertical": true, "font_size": 21, "lines_coords": [[[469.0, 592.0], [489.0, 592.0], [489.0, 707.0], [469.0, 707.0]], [[445.0, 591.0], [466.0, 591.0], [467.0, 717.0], [446.0, 717.0]], [[421.0, 591.0], [441.0, 591.0], [441.0, 745.0], [421.0, 745.0]], [[397.0, 589.0], [421.0, 589.0], [421.0, 622.0], [397.0, 622.0]]], "lines": ["俺は５日前に", "緑山市経由で、", "この町に入ったん", "だ。"]}, {"box": [59, 583, 149, 776], "vertical": true, "font_size": 20, "lines_coords": [[[128.0, 584.0], [148.0, 584.0], [148.0, 700.0], [128.0, 700.0]], [[103.0, 584.0], [124.0, 584.0], [125.0, 775.0], [104.0, 775.0]], [[79.0, 583.0], [103.0, 583.0], [103.0, 776.0], [79.0, 776.0]], [[59.0, 585.0], [76.0, 585.0], [76.0, 742.0], [59.0, 742.0]]], "lines": ["この黒渦町で", "何かが起きたらしいと", "聞いて、ボランティア", "活動するためにね、"]}, {"box": [390, 898, 481, 1108], "vertical": true, "font_size": 20, "lines_coords": [[[460.0, 900.0], [480.0, 900.0], [480.0, 1021.0], [460.0, 1021.0]], [[437.0, 898.0], [458.0, 898.0], [455.0, 1033.0], [434.0, 1033.0]], [[411.0, 900.0], [431.0, 900.0], [431.0, 1108.0], [411.0, 1108.0]], [[390.0, 898.0], [410.0, 898.0], [410.0, 976.0], [390.0, 976.0]]], "lines": ["俺は４日前だ。", "この町に親類が", "いるんで、やって来たん", "だけど．．"]}, {"box": [46, 918, 114, 1062], "vertical": true, "font_size": 20, "lines_coords": [[[92.0, 919.0], [111.0, 919.0], [113.0, 1057.0], [94.0, 1057.0]], [[69.0, 918.0], [89.0, 918.0], [90.0, 1054.0], [70.0, 1054.0]], [[46.0, 919.0], [66.0, 919.0], [66.0, 1062.0], [46.0, 1062.0]]], "lines": ["こんな状態では", "自分の身を守る", "だけで精一杯だ。"]}], "img_path": "108.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [618, 79, 761, 179], "vertical": true, "font_size": 24, "lines_coords": [[[736.0, 80.0], [761.0, 80.0], [761.0, 141.0], [736.0, 141.0]], [[710.0, 79.0], [739.0, 79.0], [739.0, 147.0], [710.0, 147.0]], [[691.0, 82.0], [711.0, 82.0], [711.0, 179.0], [691.0, 179.0]], [[666.0, 82.0], [687.0, 82.0], [687.0, 142.0], [666.0, 142.0]], [[643.0, 82.0], [664.0, 82.0], [664.0, 159.0], [643.0, 159.0]], [[618.0, 79.0], [643.0, 79.0], [643.0, 145.0], [618.0, 145.0]]], "lines": ["僕達は", "何度も、", "この町から", "脱出を", "試みたん", "だけど、"]}, {"box": [412, 77, 507, 166], "vertical": true, "font_size": 26, "lines_coords": [[[480.0, 77.0], [507.0, 77.0], [507.0, 124.0], [480.0, 124.0]], [[457.0, 79.0], [481.0, 79.0], [481.0, 141.0], [457.0, 141.0]], [[430.0, 77.0], [461.0, 77.0], [461.0, 126.0], [430.0, 126.0]], [[412.0, 80.0], [432.0, 80.0], [432.0, 166.0], [412.0, 166.0]]], "lines": ["どう", "しても", "脱出", "できない。"]}, {"box": [325, 84, 372, 154], "vertical": true, "font_size": 24, "lines_coords": [[[345.0, 84.0], [372.0, 84.0], [372.0, 132.0], [345.0, 132.0]], [[325.0, 87.0], [346.0, 87.0], [346.0, 154.0], [325.0, 154.0]]], "lines": ["そう", "なんだ。"]}, {"box": [120, 82, 165, 322], "vertical": true, "font_size": 20, "lines_coords": [[[142.0, 82.0], [162.0, 82.0], [165.0, 258.0], [145.0, 258.0]], [[120.0, 84.0], [140.0, 84.0], [140.0, 322.0], [120.0, 322.0]]], "lines": ["どの道をたどっても", "この町に舞い戻ってしまう。"]}, {"box": [661, 390, 776, 564], "vertical": true, "font_size": 19, "lines_coords": [[[755.0, 390.0], [775.0, 390.0], [773.0, 507.0], [753.0, 507.0]], [[732.0, 392.0], [752.0, 392.0], [752.0, 533.0], [732.0, 533.0]], [[710.0, 392.0], [726.0, 392.0], [726.0, 563.0], [710.0, 563.0]], [[683.0, 390.0], [703.0, 390.0], [705.0, 526.0], [685.0, 526.0]], [[661.0, 391.0], [680.0, 391.0], [680.0, 473.0], [661.0, 473.0]]], "lines": ["方向感覚には", "自信があるのに、", "まるで道が空間ごと", "ねじ曲がってる", "みたいだ"]}, {"box": [382, 375, 451, 461], "vertical": true, "font_size": 23, "lines_coords": [[[426.0, 375.0], [451.0, 375.0], [451.0, 438.0], [426.0, 438.0]], [[403.0, 375.0], [428.0, 375.0], [428.0, 437.0], [403.0, 437.0]], [[382.0, 376.0], [402.0, 376.0], [402.0, 461.0], [382.0, 461.0]]], "lines": ["そう．．．", "．．．そう", "なんです。"]}, {"box": [283, 379, 350, 573], "vertical": true, "font_size": 19, "lines_coords": [[[329.0, 379.0], [349.0, 379.0], [349.0, 480.0], [329.0, 480.0]], [[305.0, 379.0], [325.0, 379.0], [325.0, 573.0], [305.0, 573.0]], [[283.0, 382.0], [300.0, 382.0], [300.0, 495.0], [283.0, 495.0]]], "lines": ["私はこの間、", "トンネルからの脱出を", "試みたけど．．．"]}, {"box": [109, 399, 154, 573], "vertical": true, "font_size": 22, "lines_coords": [[[127.0, 399.0], [154.0, 399.0], [154.0, 452.0], [127.0, 452.0]], [[110.0, 403.0], [126.0, 403.0], [126.0, 573.0], [110.0, 573.0]]], "lines": ["全然、", "出口が見えなくて．．．"]}, {"box": [663, 649, 776, 841], "vertical": true, "font_size": 18, "lines_coords": [[[758.0, 650.0], [774.0, 650.0], [774.0, 820.0], [758.0, 820.0]], [[732.0, 650.0], [752.0, 650.0], [752.0, 827.0], [732.0, 827.0]], [[709.0, 650.0], [729.0, 650.0], [729.0, 841.0], [709.0, 841.0]], [[686.0, 650.0], [703.0, 650.0], [703.0, 802.0], [686.0, 802.0]], [[663.0, 650.0], [679.0, 650.0], [679.0, 731.0], [663.0, 731.0]]], "lines": ["そのうちトンネルが", "異常にねじれてきて、", "地下の間にくねくねと", "伸びているように", "見えたの"]}, {"box": [112, 628, 252, 801], "vertical": true, "font_size": 20, "lines_coords": [[[232.0, 631.0], [251.0, 631.0], [251.0, 744.0], [232.0, 744.0]], [[207.0, 628.0], [227.0, 628.0], [227.0, 707.0], [207.0, 707.0]], [[184.0, 629.0], [203.0, 629.0], [203.0, 782.0], [184.0, 782.0]], [[160.0, 628.0], [180.0, 628.0], [180.0, 764.0], [160.0, 764.0]], [[134.0, 628.0], [155.0, 628.0], [157.0, 801.0], [135.0, 801.0]], [[112.0, 630.0], [133.0, 630.0], [133.0, 726.0], [112.0, 726.0]]], "lines": ["いくら何でも", "そんな事", "あるはずないと．．", "．．．気のせいだと", "自分に言いきかせて", "いたの．．．"]}, {"box": [355, 970, 446, 1127], "vertical": true, "font_size": 22, "lines_coords": [[[425.0, 973.0], [446.0, 973.0], [446.0, 1071.0], [425.0, 1071.0]], [[400.0, 970.0], [425.0, 970.0], [421.0, 1109.0], [397.0, 1109.0]], [[378.0, 973.0], [399.0, 973.0], [399.0, 1071.0], [378.0, 1071.0]], [[355.0, 973.0], [375.0, 973.0], [375.0, 1127.0], [355.0, 1127.0]]], "lines": ["私、危うく", "すべり落ちそう", "で、すぐに", "ひき返したけど．．．"]}], "img_path": "109.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [600, 90, 717, 168], "vertical": true, "font_size": 24, "lines_coords": [[[692.0, 91.0], [717.0, 91.0], [717.0, 158.0], [692.0, 158.0]], [[666.0, 90.0], [696.0, 90.0], [696.0, 154.0], [666.0, 154.0]], [[646.0, 92.0], [666.0, 92.0], [666.0, 168.0], [646.0, 168.0]], [[621.0, 91.0], [646.0, 91.0], [646.0, 153.0], [621.0, 153.0]], [[600.0, 92.0], [621.0, 92.0], [621.0, 158.0], [600.0, 158.0]]], "lines": ["その後、", "俺達は", "海からの", "脱出も", "試みた。"]}, {"box": [414, 72, 532, 227], "vertical": true, "font_size": 21, "lines_coords": [[[508.0, 72.0], [532.0, 72.0], [532.0, 227.0], [508.0, 227.0]], [[487.0, 75.0], [507.0, 75.0], [507.0, 208.0], [487.0, 208.0]], [[462.0, 73.0], [485.0, 73.0], [485.0, 189.0], [462.0, 189.0]], [[439.0, 72.0], [459.0, 72.0], [459.0, 189.0], [439.0, 189.0]], [[414.0, 72.0], [434.0, 72.0], [434.0, 213.0], [414.0, 213.0]]], "lines": ["しかし、この町の", "小さな漁港には", "台風のせいで", "まともな船は", "残ってなかった。"]}, {"box": [64, 79, 160, 195], "vertical": true, "font_size": 19, "lines_coords": [[[140.0, 79.0], [160.0, 79.0], [160.0, 195.0], [140.0, 195.0]], [[112.0, 80.0], [132.0, 80.0], [132.0, 181.0], [112.0, 181.0]], [[89.0, 79.0], [106.0, 79.0], [105.0, 194.0], [87.0, 194.0]], [[64.0, 79.0], [84.0, 79.0], [84.0, 165.0], [64.0, 165.0]]], "lines": ["それで俺達は", "筏を作って、", "脱出する事に", "したんだ。"]}, {"box": [635, 459, 724, 576], "vertical": true, "font_size": 19, "lines_coords": [[[707.0, 461.0], [724.0, 461.0], [724.0, 537.0], [707.0, 537.0]], [[680.0, 459.0], [702.0, 459.0], [703.0, 576.0], [682.0, 576.0]], [[658.0, 460.0], [679.0, 460.0], [679.0, 557.0], [658.0, 557.0]], [[635.0, 460.0], [655.0, 460.0], [655.0, 564.0], [635.0, 564.0]]], "lines": ["ちょうど", "その時、他の", "グループが", "ひと足先に、"]}, {"box": [70, 457, 141, 564], "vertical": true, "font_size": 26, "lines_coords": [[[111.0, 457.0], [141.0, 457.0], [141.0, 513.0], [111.0, 513.0]], [[87.0, 458.0], [118.0, 458.0], [118.0, 523.0], [87.0, 523.0]], [[70.0, 461.0], [86.0, 461.0], [86.0, 560.0], [70.0, 560.0]]], "lines": ["よし、", "俺達も", "早く作ろう"]}, {"box": [561, 547, 624, 671], "vertical": true, "font_size": 19, "lines_coords": [[[604.0, 548.0], [624.0, 548.0], [624.0, 643.0], [604.0, 643.0]], [[582.0, 547.0], [602.0, 547.0], [602.0, 625.0], [582.0, 625.0]], [[561.0, 548.0], [577.0, 548.0], [577.0, 671.0], [561.0, 671.0]]], "lines": ["手製の筏で", "出発する", "ところだった。"]}, {"box": [673, 710, 724, 774], "vertical": true, "font_size": 27, "lines_coords": [[[695.0, 710.0], [724.0, 710.0], [724.0, 774.0], [695.0, 774.0]], [[673.0, 711.0], [698.0, 711.0], [698.0, 772.0], [673.0, 772.0]]], "lines": ["ところ", "が．．．．．"]}, {"box": [546, 703, 596, 757], "vertical": true, "font_size": 28, "lines_coords": [[[564.0, 703.0], [596.0, 703.0], [596.0, 757.0], [564.0, 757.0]], [[546.0, 704.0], [571.0, 704.0], [571.0, 757.0], [546.0, 757.0]]], "lines": ["あっ、", "見ろ。"]}, {"box": [378, 711, 451, 806], "vertical": false, "font_size": 38, "lines_coords": [[[378.0, 788.0], [417.0, 711.0], [451.0, 728.0], [412.0, 806.0]]], "lines": ["！？みさ"]}], "img_path": "110.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [724, 540, 769, 655], "vertical": true, "font_size": 18, "lines_coords": [[[751.0, 542.0], [767.0, 542.0], [767.0, 655.0], [751.0, 655.0]], [[727.0, 540.0], [747.0, 540.0], [744.0, 638.0], [724.0, 638.0]]], "lines": ["とにかく脱出", "できない．．．"]}, {"box": [103, 323, 266, 459], "vertical": true, "font_size": 20, "lines_coords": [[[241.0, 323.0], [266.0, 323.0], [266.0, 384.0], [241.0, 384.0]], [[222.0, 325.0], [239.0, 325.0], [239.0, 442.0], [222.0, 442.0]], [[196.0, 324.0], [216.0, 324.0], [216.0, 403.0], [196.0, 403.0]], [[172.0, 323.0], [193.0, 323.0], [191.0, 459.0], [169.0, 459.0]], [[148.0, 324.0], [168.0, 324.0], [168.0, 420.0], [148.0, 420.0]], [[126.0, 324.0], [146.0, 324.0], [146.0, 439.0], [126.0, 439.0]], [[103.0, 324.0], [123.0, 324.0], [123.0, 407.0], [103.0, 407.0]]], "lines": ["俺達が", "見ている前で、", "筏は突然", "海面に出現した", "巨大な渦に", "呑み込まれて", "しまった。"]}, {"box": [670, 738, 761, 855], "vertical": true, "font_size": 21, "lines_coords": [[[741.0, 741.0], [761.0, 741.0], [761.0, 836.0], [741.0, 836.0]], [[712.0, 739.0], [738.0, 738.0], [740.0, 820.0], [714.0, 821.0]], [[695.0, 740.0], [714.0, 740.0], [714.0, 855.0], [695.0, 855.0]], [[670.0, 741.0], [690.0, 741.0], [690.0, 819.0], [670.0, 819.0]]], "lines": ["．．．ところで", "君達、今", "どこに住んで", "るんだ？"]}, {"box": [455, 536, 523, 675], "vertical": true, "font_size": 18, "lines_coords": [[[505.0, 537.0], [521.0, 537.0], [521.0, 672.0], [505.0, 672.0]], [[479.0, 536.0], [495.0, 536.0], [498.0, 671.0], [481.0, 671.0]], [[455.0, 537.0], [475.0, 537.0], [475.0, 615.0], [455.0, 615.0]]], "lines": ["でも俺達なんか", "またましなほう", "力もな．．．"]}, {"box": [293, 525, 405, 705], "vertical": true, "font_size": 19, "lines_coords": [[[385.0, 525.0], [405.0, 525.0], [405.0, 678.0], [385.0, 678.0]], [[359.0, 525.0], [383.0, 525.0], [383.0, 663.0], [359.0, 663.0]], [[336.0, 525.0], [357.0, 525.0], [358.0, 705.0], [337.0, 705.0]], [[315.0, 527.0], [331.0, 527.0], [331.0, 641.0], [315.0, 641.0]], [[293.0, 526.0], [309.0, 526.0], [309.0, 684.0], [293.0, 684.0]]], "lines": ["ああ．．．他の連中の", "中には、もっと", "恐ろしい目に遭って、", "精神に異常を", "きたした者もいる。"]}, {"box": [180, 738, 323, 874], "vertical": true, "font_size": 20, "lines_coords": [[[303.0, 741.0], [323.0, 741.0], [323.0, 856.0], [303.0, 856.0]], [[280.0, 740.0], [297.0, 740.0], [298.0, 874.0], [281.0, 874.0]], [[257.0, 742.0], [274.0, 742.0], [274.0, 855.0], [257.0, 855.0]], [[232.0, 741.0], [251.0, 741.0], [251.0, 836.0], [232.0, 836.0]], [[208.0, 741.0], [228.0, 741.0], [228.0, 836.0], [208.0, 836.0]], [[182.0, 738.0], [208.0, 739.0], [206.0, 802.0], [180.0, 801.0]]], "lines": ["いえ．．．長屋は", "どこも一杯で．．．", "今は仕方なく", "倒れた家の", "下に住んで", "ます．．．"]}, {"box": [108, 781, 152, 916], "vertical": true, "font_size": 20, "lines_coords": [[[132.0, 782.0], [152.0, 782.0], [152.0, 916.0], [132.0, 916.0]], [[108.0, 781.0], [128.0, 781.0], [128.0, 904.0], [108.0, 904.0]]], "lines": ["今、帰るところ", "だったんです。"]}, {"box": [367, 958, 504, 1094], "vertical": true, "font_size": 18, "lines_coords": [[[484.0, 959.0], [503.0, 959.0], [503.0, 1037.0], [484.0, 1037.0]], [[460.0, 959.0], [478.0, 959.0], [479.0, 1073.0], [461.0, 1073.0]], [[434.0, 958.0], [455.0, 958.0], [457.0, 1075.0], [435.0, 1075.0]], [[411.0, 958.0], [431.0, 958.0], [433.0, 1075.0], [413.0, 1075.0]], [[391.0, 960.0], [407.0, 960.0], [407.0, 1093.0], [391.0, 1093.0]], [[368.0, 962.0], [384.0, 962.0], [384.0, 1078.0], [368.0, 1078.0]]], "lines": ["長屋か？", "もしそうなら", "俺達も入れて", "くれないか？", "もう安全な所は", "長屋しかない。"]}], "img_path": "111.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [600, 107, 692, 250], "vertical": true, "font_size": 18, "lines_coords": [[[672.0, 110.0], [689.0, 110.0], [689.0, 240.0], [672.0, 240.0]], [[646.0, 107.0], [666.0, 107.0], [666.0, 247.0], [646.0, 247.0]], [[623.0, 107.0], [643.0, 107.0], [643.0, 205.0], [623.0, 205.0]], [[602.0, 110.0], [618.0, 110.0], [618.0, 249.0], [602.0, 249.0]]], "lines": ["私の母が竜巻の", "あおりを受けて、", "ケガして今", "動けないんです。"]}, {"box": [635, 424, 703, 520], "vertical": true, "font_size": 20, "lines_coords": [[[680.0, 424.0], [702.0, 424.0], [703.0, 501.0], [682.0, 501.0]], [[656.0, 424.0], [680.0, 424.0], [680.0, 503.0], [656.0, 503.0]], [[635.0, 425.0], [651.0, 425.0], [653.0, 520.0], [637.0, 520.0]]], "lines": ["お母さん", "大丈夫？", "傷は痛む？"]}, {"box": [398, 424, 469, 511], "vertical": true, "font_size": 23, "lines_coords": [[[443.0, 424.0], [469.0, 424.0], [469.0, 475.0], [443.0, 475.0]], [[423.0, 428.0], [444.0, 428.0], [444.0, 506.0], [423.0, 506.0]], [[398.0, 426.0], [419.0, 426.0], [419.0, 509.0], [398.0, 509.0]]], "lines": ["うん、", "大丈夫．．．", "それより"]}, {"box": [80, 426, 133, 506], "vertical": true, "font_size": 29, "lines_coords": [[[106.0, 428.0], [131.0, 427.0], [133.0, 505.0], [108.0, 506.0]], [[80.0, 426.0], [112.0, 426.0], [112.0, 474.0], [80.0, 474.0]]], "lines": ["お父さん", "は？"]}, {"box": [636, 782, 725, 862], "vertical": true, "font_size": 25, "lines_coords": [[[685.0, 785.0], [705.0, 785.0], [705.0, 862.0], [685.0, 862.0]], [[656.0, 782.0], [685.0, 782.0], [685.0, 848.0], [656.0, 848.0]], [[636.0, 783.0], [661.0, 783.0], [661.0, 846.0], [636.0, 846.0]]], "lines": ["あちこち", "捜した", "けど．．．"]}, {"box": [521, 788, 569, 868], "vertical": true, "font_size": 25, "lines_coords": [[[544.0, 788.0], [569.0, 788.0], [569.0, 868.0], [544.0, 868.0]], [[521.0, 788.0], [546.0, 788.0], [546.0, 851.0], [521.0, 851.0]]], "lines": ["見つから", "ない．．．"]}, {"box": [369, 785, 485, 900], "vertical": true, "font_size": 21, "lines_coords": [[[464.0, 787.0], [485.0, 787.0], [485.0, 881.0], [464.0, 881.0]], [[439.0, 786.0], [459.0, 786.0], [459.0, 900.0], [439.0, 900.0]], [[412.0, 785.0], [438.0, 785.0], [438.0, 847.0], [412.0, 847.0]], [[392.0, 787.0], [412.0, 787.0], [412.0, 882.0], [392.0, 882.0]], [[369.0, 787.0], [389.0, 787.0], [389.0, 864.0], [369.0, 864.0]]], "lines": ["．．．やっぱり", "あんなふうに", "竜巻に", "巻き込まれ", "たら．．．！！"]}, {"box": [65, 786, 157, 929], "vertical": true, "font_size": 20, "lines_coords": [[[135.0, 787.0], [157.0, 787.0], [157.0, 864.0], [135.0, 864.0]], [[112.0, 787.0], [132.0, 787.0], [132.0, 885.0], [112.0, 885.0]], [[87.0, 786.0], [108.0, 786.0], [110.0, 901.0], [89.0, 901.0]], [[65.0, 788.0], [82.0, 788.0], [84.0, 924.0], [67.0, 924.0]]], "lines": ["大丈夫よ", "お母さん．．．", "絶対どこかで", "無事でいるわよ"]}], "img_path": "112.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [654, 79, 768, 183], "vertical": true, "font_size": 20, "lines_coords": [[[748.0, 79.0], [768.0, 79.0], [766.0, 176.0], [746.0, 176.0]], [[724.0, 80.0], [744.0, 80.0], [744.0, 176.0], [724.0, 176.0]], [[699.0, 80.0], [720.0, 80.0], [720.0, 159.0], [699.0, 159.0]], [[676.0, 80.0], [697.0, 80.0], [697.0, 157.0], [676.0, 157.0]], [[655.0, 82.0], [671.0, 82.0], [671.0, 182.0], [655.0, 182.0]]], "lines": ["こんな所に", "住んでるん", "ですか？", "これじゃ", "危ないなあ。"]}, {"box": [472, 86, 563, 239], "vertical": true, "font_size": 20, "lines_coords": [[[543.0, 86.0], [563.0, 86.0], [561.0, 205.0], [541.0, 205.0]], [[518.0, 87.0], [539.0, 87.0], [539.0, 173.0], [518.0, 173.0]], [[496.0, 89.0], [513.0, 89.0], [513.0, 239.0], [496.0, 239.0]], [[472.0, 87.0], [492.0, 87.0], [492.0, 153.0], [472.0, 153.0]]], "lines": ["竜巻の直撃を", "受けたら、", "ひとたまりもない", "ですよ。"]}, {"box": [373, 90, 440, 302], "vertical": true, "font_size": 19, "lines_coords": [[[419.0, 90.0], [439.0, 90.0], [439.0, 290.0], [419.0, 290.0]], [[394.0, 90.0], [414.0, 90.0], [413.0, 302.0], [393.0, 302.0]], [[373.0, 92.0], [390.0, 92.0], [390.0, 251.0], [373.0, 251.0]]], "lines": ["とにかく長屋が安全だ。", "まだどこか空いてる所が", "あるかもしれない。"]}, {"box": [112, 92, 155, 223], "vertical": true, "font_size": 20, "lines_coords": [[[134.0, 93.0], [154.0, 93.0], [154.0, 223.0], [134.0, 223.0]], [[112.0, 92.0], [132.0, 92.0], [132.0, 159.0], [112.0, 159.0]]], "lines": ["これから探しに", "行こう。"]}, {"box": [506, 421, 597, 594], "vertical": true, "font_size": 20, "lines_coords": [[[576.0, 421.0], [596.0, 421.0], [596.0, 574.0], [576.0, 574.0]], [[553.0, 423.0], [573.0, 423.0], [573.0, 555.0], [553.0, 555.0]], [[529.0, 421.0], [549.0, 421.0], [549.0, 594.0], [529.0, 594.0]], [[506.0, 421.0], [526.0, 421.0], [526.0, 526.0], [506.0, 526.0]]], "lines": ["しかし、この町で", "例の長屋だけが", "どうして無事なのか", "不思議だな。"]}, {"box": [117, 423, 208, 615], "vertical": true, "font_size": 19, "lines_coords": [[[189.0, 426.0], [206.0, 426.0], [206.0, 556.0], [189.0, 556.0]], [[162.0, 423.0], [182.0, 423.0], [185.0, 594.0], [165.0, 594.0]], [[140.0, 423.0], [158.0, 423.0], [159.0, 615.0], [141.0, 615.0]], [[117.0, 423.0], [137.0, 423.0], [137.0, 595.0], [117.0, 595.0]]], "lines": ["コンクリートの", "建物さえ崩壊しつつ", "あるのに、なぜあんな", "オンボロの家が．．．？"]}, {"box": [651, 782, 770, 898], "vertical": true, "font_size": 21, "lines_coords": [[[745.0, 782.0], [770.0, 782.0], [770.0, 846.0], [745.0, 846.0]], [[723.0, 783.0], [743.0, 783.0], [743.0, 898.0], [723.0, 898.0]], [[699.0, 785.0], [719.0, 785.0], [719.0, 881.0], [699.0, 881.0]], [[677.0, 785.0], [693.0, 785.0], [693.0, 880.0], [677.0, 880.0]], [[651.0, 782.0], [676.0, 782.0], [676.0, 813.0], [651.0, 813.0]]], "lines": ["ええ．．．", "それも大昔に", "建てられた", "家なんです", "よ。"]}, {"box": [544, 780, 618, 878], "vertical": true, "font_size": 24, "lines_coords": [[[595.0, 783.0], [616.0, 783.0], [616.0, 870.0], [595.0, 870.0]], [[574.0, 783.0], [594.0, 783.0], [594.0, 878.0], [574.0, 878.0]], [[544.0, 780.0], [574.0, 780.0], [574.0, 844.0], [544.0, 844.0]]], "lines": ["一体何軒", "立ってるん", "だい？"]}, {"box": [424, 931, 517, 1093], "vertical": true, "font_size": 20, "lines_coords": [[[495.0, 931.0], [515.0, 931.0], [516.0, 1086.0], [496.0, 1086.0]], [[472.0, 932.0], [492.0, 932.0], [492.0, 1087.0], [472.0, 1087.0]], [[448.0, 932.0], [468.0, 932.0], [468.0, 1087.0], [448.0, 1087.0]], [[424.0, 933.0], [444.0, 933.0], [444.0, 1092.0], [424.0, 1092.0]]], "lines": ["数えた事ないけど", "．．．町の中心部にも", "あるし、周辺にも", "たくさんあります。"]}, {"box": [108, 822, 178, 1016], "vertical": true, "font_size": 20, "lines_coords": [[[155.0, 822.0], [176.0, 822.0], [178.0, 948.0], [157.0, 948.0]], [[132.0, 822.0], [152.0, 822.0], [154.0, 1016.0], [134.0, 1016.0]], [[108.0, 822.0], [128.0, 822.0], [130.0, 987.0], [110.0, 987.0]]], "lines": ["じゃあ郊外に、", "どこか空いてる長屋が", "きっとあるはずだ。"]}], "img_path": "113.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [605, 93, 723, 247], "vertical": true, "font_size": 20, "lines_coords": [[[702.0, 94.0], [721.0, 94.0], [721.0, 247.0], [702.0, 247.0]], [[678.0, 96.0], [698.0, 96.0], [698.0, 229.0], [678.0, 229.0]], [[655.0, 94.0], [675.0, 94.0], [675.0, 247.0], [655.0, 247.0]], [[631.0, 94.0], [651.0, 94.0], [651.0, 229.0], [631.0, 229.0]], [[605.0, 93.0], [625.0, 93.0], [628.0, 219.0], [608.0, 219.0]]], "lines": ["しかし、こんなに", "ノロノロと移動", "してたら、郊外に", "たどりつく前に", "日が暮れるな。"]}, {"box": [486, 87, 512, 140], "vertical": true, "font_size": 26, "lines_coords": [[[486.0, 87.0], [512.0, 87.0], [512.0, 140.0], [486.0, 140.0]]], "lines": ["フフ。"]}, {"box": [392, 175, 458, 318], "vertical": true, "font_size": 18, "lines_coords": [[[437.0, 175.0], [457.0, 175.0], [458.0, 309.0], [438.0, 309.0]], [[416.0, 176.0], [432.0, 176.0], [432.0, 294.0], [416.0, 294.0]], [[392.0, 176.0], [409.0, 176.0], [409.0, 316.0], [392.0, 316.0]]], "lines": ["あ．．．自己紹介が", "遅れたけど俺", "谷崎という者だ。"]}, {"box": [205, 90, 259, 146], "vertical": true, "font_size": 32, "lines_coords": [[[227.0, 90.0], [259.0, 90.0], [259.0, 139.0], [227.0, 139.0]], [[205.0, 90.0], [236.0, 90.0], [236.0, 146.0], [205.0, 146.0]]], "lines": ["僕は", "竹本。"]}, {"box": [134, 84, 154, 168], "vertical": true, "font_size": 20, "lines_coords": [[[134.0, 84.0], [154.0, 84.0], [154.0, 168.0], [134.0, 168.0]]], "lines": ["よろしく。"]}, {"box": [600, 363, 716, 444], "vertical": true, "font_size": 24, "lines_coords": [[[695.0, 364.0], [716.0, 364.0], [716.0, 440.0], [695.0, 440.0]], [[669.0, 363.0], [695.0, 363.0], [695.0, 432.0], [669.0, 432.0]], [[645.0, 363.0], [670.0, 363.0], [670.0, 444.0], [645.0, 444.0]], [[620.0, 364.0], [645.0, 363.0], [648.0, 440.0], [622.0, 441.0]], [[600.0, 364.0], [620.0, 364.0], [620.0, 430.0], [600.0, 430.0]]], "lines": ["うしろの", "連中も、", "この町で", "知り合っ", "たんだ"]}, {"box": [447, 358, 495, 446], "vertical": true, "font_size": 23, "lines_coords": [[[471.0, 358.0], [495.0, 358.0], [495.0, 421.0], [471.0, 421.0]], [[447.0, 359.0], [468.0, 358.0], [472.0, 445.0], [451.0, 446.0]]], "lines": ["みんな", "疲れてる。"]}, {"box": [284, 424, 344, 512], "vertical": true, "font_size": 31, "lines_coords": [[[309.0, 424.0], [344.0, 424.0], [344.0, 488.0], [309.0, 488.0]], [[284.0, 455.0], [311.0, 455.0], [311.0, 512.0], [284.0, 512.0]]], "lines": ["ヨロ", "ゴロ"]}, {"box": [634, 694, 726, 793], "vertical": true, "font_size": 24, "lines_coords": [[[704.0, 696.0], [725.0, 696.0], [726.0, 793.0], [705.0, 793.0]], [[676.0, 694.0], [706.0, 694.0], [706.0, 759.0], [676.0, 759.0]], [[655.0, 696.0], [680.0, 696.0], [680.0, 758.0], [655.0, 758.0]], [[634.0, 697.0], [653.0, 697.0], [653.0, 793.0], [634.0, 793.0]]], "lines": ["大丈夫か？", "岡本．．．", "気分が", "悪いのか？"]}, {"box": [413, 685, 481, 781], "vertical": true, "font_size": 21, "lines_coords": [[[455.0, 685.0], [481.0, 685.0], [481.0, 748.0], [455.0, 748.0]], [[434.0, 686.0], [454.0, 686.0], [454.0, 781.0], [434.0, 781.0]], [[413.0, 687.0], [430.0, 687.0], [430.0, 781.0], [413.0, 781.0]]], "lines": ["いや．．．", "ただ背中が", "変なんだ．．．"]}, {"box": [274, 683, 343, 762], "vertical": true, "font_size": 22, "lines_coords": [[[322.0, 684.0], [343.0, 684.0], [343.0, 762.0], [322.0, 762.0]], [[295.0, 683.0], [319.0, 683.0], [319.0, 762.0], [295.0, 762.0]], [[274.0, 684.0], [294.0, 684.0], [294.0, 762.0], [274.0, 762.0]]], "lines": ["ちょっと", "見てくれ", "ないか？"]}, {"box": [451, 945, 471, 1024], "vertical": true, "font_size": 20, "lines_coords": [[[451.0, 945.0], [471.0, 945.0], [471.0, 1024.0], [451.0, 1024.0]]], "lines": ["背中が？"]}], "img_path": "114.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [160, 92, 185, 162], "vertical": true, "font_size": 25, "lines_coords": [[[160.0, 92.0], [185.0, 92.0], [185.0, 162.0], [160.0, 162.0]]], "lines": ["あっ！？"]}, {"box": [638, 766, 779, 902], "vertical": true, "font_size": 22, "lines_coords": [[[755.0, 766.0], [779.0, 766.0], [779.0, 902.0], [755.0, 902.0]], [[732.0, 767.0], [753.0, 767.0], [753.0, 854.0], [732.0, 854.0]], [[710.0, 769.0], [730.0, 769.0], [730.0, 902.0], [710.0, 902.0]], [[683.0, 767.0], [707.0, 767.0], [707.0, 847.0], [683.0, 847.0]], [[662.0, 767.0], [682.0, 767.0], [682.0, 863.0], [662.0, 863.0]], [[638.0, 767.0], [659.0, 767.0], [659.0, 846.0], [638.0, 846.0]]], "lines": ["でも．．．どうして", "最近急に", "ヒトマイマイに", "なる人が", "増えたの？", "秀一君．．．"]}, {"box": [377, 589, 419, 730], "vertical": true, "font_size": 18, "lines_coords": [[[398.0, 589.0], [418.0, 589.0], [419.0, 721.0], [399.0, 721.0]], [[377.0, 590.0], [393.0, 590.0], [393.0, 728.0], [377.0, 728.0]]], "lines": ["カタツムリ化が", "始まってるんだ。"]}, {"box": [514, 766, 580, 936], "vertical": true, "font_size": 19, "lines_coords": [[[561.0, 767.0], [577.0, 767.0], [580.0, 878.0], [563.0, 878.0]], [[537.0, 766.0], [557.0, 766.0], [559.0, 917.0], [539.0, 917.0]], [[514.0, 767.0], [534.0, 767.0], [536.0, 936.0], [516.0, 936.0]]], "lines": ["知らないよ．．", "ノロノロ動いてる", "からじゃないのか？"]}, {"box": [417, 772, 483, 935], "vertical": true, "font_size": 19, "lines_coords": [[[462.0, 774.0], [482.0, 774.0], [482.0, 929.0], [462.0, 929.0]], [[438.0, 772.0], [458.0, 772.0], [459.0, 926.0], [439.0, 926.0]], [[417.0, 776.0], [433.0, 776.0], [433.0, 930.0], [417.0, 930.0]]], "lines": ["動きがノロいから", "うずまきの呪いに", "つけこまれるんだ。"]}, {"box": [112, 591, 179, 727], "vertical": true, "font_size": 18, "lines_coords": [[[153.0, 591.0], [176.0, 591.0], [179.0, 727.0], [155.0, 727.0]], [[134.0, 595.0], [151.0, 595.0], [151.0, 726.0], [134.0, 726.0]], [[112.0, 595.0], [127.0, 595.0], [127.0, 707.0], [112.0, 707.0]]], "lines": ["近いうちに彼は", "ヒトマイマイに", "なるだろう．．．"]}, {"box": [170, 772, 235, 851], "vertical": true, "font_size": 25, "lines_coords": [[[209.0, 772.0], [235.0, 772.0], [235.0, 819.0], [209.0, 819.0]], [[186.0, 774.0], [210.0, 774.0], [210.0, 851.0], [186.0, 851.0]]], "lines": ["な．．．", "何だって"]}, {"box": [266, 977, 335, 1074], "vertical": true, "font_size": 22, "lines_coords": [[[315.0, 979.0], [335.0, 979.0], [335.0, 1057.0], [315.0, 1057.0]], [[289.0, 978.0], [310.0, 978.0], [312.0, 1074.0], [291.0, 1074.0]], [[266.0, 977.0], [290.0, 977.0], [290.0, 1045.0], [266.0, 1045.0]]], "lines": ["オレ達も", "他人事じゃ", "ないぜ。"]}], "img_path": "115.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [658, 91, 724, 187], "vertical": true, "font_size": 19, "lines_coords": [[[703.0, 91.0], [724.0, 91.0], [724.0, 172.0], [703.0, 172.0]], [[679.0, 91.0], [699.0, 91.0], [699.0, 187.0], [679.0, 187.0]], [[658.0, 92.0], [675.0, 92.0], [675.0, 187.0], [658.0, 187.0]]], "lines": ["お．．．おい", "俺の背中も", "見てくれ．．"]}, {"box": [359, 90, 379, 183], "vertical": true, "font_size": 20, "lines_coords": [[[359.0, 90.0], [379.0, 90.0], [379.0, 183.0], [359.0, 183.0]]], "lines": ["お．．．俺も！"]}, {"box": [300, 101, 319, 245], "vertical": true, "font_size": 16, "lines_coords": [[[300.0, 101.0], [316.0, 101.0], [318.0, 241.0], [302.0, 241.0]]], "lines": ["．．．何ともないよ。"]}, {"box": [110, 77, 138, 131], "vertical": true, "font_size": 26, "lines_coords": [[[110.0, 78.0], [135.0, 77.0], [138.0, 130.0], [112.0, 131.0]]], "lines": ["ふう。"]}, {"box": [705, 469, 725, 590], "vertical": true, "font_size": 17, "lines_coords": [[[706.0, 469.0], [723.0, 469.0], [723.0, 589.0], [706.0, 589.0]]], "lines": ["俺も見てくれ"]}, {"box": [655, 744, 726, 860], "vertical": true, "font_size": 22, "lines_coords": [[[706.0, 745.0], [726.0, 745.0], [726.0, 844.0], [706.0, 844.0]], [[683.0, 745.0], [703.0, 745.0], [703.0, 860.0], [683.0, 860.0]], [[655.0, 744.0], [680.0, 744.0], [680.0, 807.0], [655.0, 807.0]]], "lines": ["戸川．．．お前", "うずまき模様", "が．．．．．"]}, {"box": [437, 750, 479, 846], "vertical": true, "font_size": 18, "lines_coords": [[[459.0, 750.0], [479.0, 750.0], [479.0, 846.0], [459.0, 846.0]], [[437.0, 751.0], [453.0, 751.0], [453.0, 844.0], [437.0, 844.0]]], "lines": ["何だって！？", "うそだろ！？"]}, {"box": [283, 744, 399, 897], "vertical": true, "font_size": 21, "lines_coords": [[[378.0, 744.0], [398.0, 744.0], [398.0, 860.0], [378.0, 860.0]], [[356.0, 746.0], [372.0, 746.0], [372.0, 857.0], [356.0, 857.0]], [[329.0, 744.0], [350.0, 744.0], [351.0, 897.0], [330.0, 897.0]], [[302.0, 744.0], [331.0, 744.0], [331.0, 810.0], [302.0, 810.0]], [[283.0, 745.0], [301.0, 745.0], [302.0, 877.0], [284.0, 877.0]]], "lines": ["じゃあ、俺も", "カタツムリに", "なるというのか！？", "いやだ、", "冗談じゃない！！"]}, {"box": [41, 754, 160, 835], "vertical": true, "font_size": 25, "lines_coords": [[[134.0, 754.0], [160.0, 754.0], [160.0, 817.0], [134.0, 817.0]], [[113.0, 758.0], [134.0, 758.0], [134.0, 835.0], [113.0, 835.0]], [[86.0, 754.0], [116.0, 754.0], [116.0, 819.0], [86.0, 819.0]], [[66.0, 758.0], [87.0, 758.0], [87.0, 834.0], [66.0, 834.0]], [[41.0, 755.0], [67.0, 755.0], [67.0, 807.0], [41.0, 807.0]]], "lines": ["大声を", "出すな！", "竜巻が", "起きるだ", "ろう。"]}, {"box": [432, 979, 475, 1095], "vertical": true, "font_size": 20, "lines_coords": [[[454.0, 980.0], [475.0, 980.0], [475.0, 1059.0], [454.0, 1059.0]], [[434.0, 979.0], [454.0, 979.0], [452.0, 1095.0], [432.0, 1095.0]]], "lines": ["うそだと", "言ってくれ！！"]}], "img_path": "116.jpg"}, {"version": "0.1.7", "img_width": 839, "img_height": 1200, "blocks": [{"box": [662, 64, 754, 201], "vertical": true, "font_size": 22, "lines_coords": [[[732.0, 65.0], [753.0, 65.0], [754.0, 162.0], [733.0, 162.0]], [[706.0, 64.0], [734.0, 64.0], [734.0, 111.0], [706.0, 111.0]], [[685.0, 66.0], [705.0, 66.0], [707.0, 201.0], [687.0, 201.0]], [[662.0, 67.0], [681.0, 67.0], [681.0, 151.0], [662.0, 151.0]]], "lines": ["とにかく．．", "早く", "空いてる長屋を", "探すんだ"]}, {"box": [169, 123, 288, 205], "vertical": true, "font_size": 25, "lines_coords": [[[267.0, 127.0], [288.0, 127.0], [288.0, 205.0], [267.0, 205.0]], [[237.0, 123.0], [268.0, 123.0], [268.0, 180.0], [237.0, 180.0]], [[217.0, 126.0], [242.0, 126.0], [242.0, 205.0], [217.0, 205.0]], [[195.0, 127.0], [216.0, 127.0], [216.0, 205.0], [195.0, 205.0]], [[169.0, 125.0], [196.0, 125.0], [196.0, 175.0], [169.0, 175.0]]], "lines": ["長屋の中", "なら、", "ノロノロ", "動かずに", "すむ。"]}, {"box": [690, 329, 780, 465], "vertical": true, "font_size": 19, "lines_coords": [[[759.0, 329.0], [780.0, 329.0], [780.0, 410.0], [759.0, 410.0]], [[734.0, 330.0], [754.0, 330.0], [754.0, 445.0], [734.0, 445.0]], [[712.0, 330.0], [732.0, 330.0], [732.0, 446.0], [712.0, 446.0]], [[690.0, 332.0], [706.0, 332.0], [706.0, 465.0], [690.0, 465.0]]], "lines": ["．．．でも．．．", "長屋の中なら", "本当に安全と", "いえるのかな？"]}, {"box": [404, 328, 493, 537], "vertical": true, "font_size": 19, "lines_coords": [[[473.0, 329.0], [493.0, 329.0], [493.0, 501.0], [473.0, 501.0]], [[449.0, 328.0], [469.0, 328.0], [469.0, 537.0], [449.0, 537.0]], [[426.0, 328.0], [446.0, 328.0], [444.0, 482.0], [424.0, 482.0]], [[404.0, 329.0], [420.0, 329.0], [420.0, 527.0], [404.0, 527.0]]], "lines": ["だってカタツムリに", "変身する本当のところの", "原因なんて、まだ", "わからないじゃないか。"]}, {"box": [345, 349, 367, 398], "vertical": true, "font_size": 22, "lines_coords": [[[345.0, 349.0], [367.0, 349.0], [367.0, 398.0], [345.0, 398.0]]], "lines": ["ああ。"]}, {"box": [117, 323, 186, 539], "vertical": true, "font_size": 24, "lines_coords": [[[159.0, 324.0], [183.0, 324.0], [186.0, 516.0], [161.0, 516.0]], [[137.0, 323.0], [165.0, 323.0], [165.0, 539.0], [137.0, 539.0]], [[117.0, 325.0], [137.0, 325.0], [137.0, 461.0], [117.0, 461.0]]], "lines": ["だが、長屋がこの町の", "中で、一番安全な所には", "違いないだろ？"]}, {"box": [605, 575, 771, 696], "vertical": true, "font_size": 21, "lines_coords": [[[753.0, 580.0], [769.0, 580.0], [769.0, 673.0], [753.0, 673.0]], [[730.0, 580.0], [746.0, 580.0], [746.0, 694.0], [730.0, 694.0]], [[703.0, 577.0], [724.0, 577.0], [724.0, 655.0], [703.0, 655.0]], [[679.0, 575.0], [700.0, 575.0], [698.0, 693.0], [677.0, 693.0]], [[657.0, 577.0], [677.0, 577.0], [677.0, 693.0], [657.0, 693.0]], [[630.0, 577.0], [656.0, 577.0], [656.0, 643.0], [630.0, 643.0]], [[605.0, 575.0], [635.0, 575.0], [635.0, 639.0], [605.0, 639.0]]], "lines": ["な．．．なあ．．．", "長屋に入れば", "俺のこの", "うずまき模様", "消えるかな？", "．．．なあ、", "谷崎．．．"]}, {"box": [345, 585, 391, 682], "vertical": true, "font_size": 23, "lines_coords": [[[365.0, 585.0], [391.0, 585.0], [391.0, 664.0], [365.0, 664.0]], [[345.0, 587.0], [365.0, 587.0], [365.0, 682.0], [345.0, 682.0]]], "lines": ["いやだ．．．", "いやだっ！！"]}, {"box": [420, 774, 488, 858], "vertical": true, "font_size": 21, "lines_coords": [[[466.0, 774.0], [488.0, 774.0], [488.0, 816.0], [466.0, 816.0]], [[444.0, 775.0], [465.0, 775.0], [465.0, 853.0], [444.0, 853.0]], [[420.0, 775.0], [441.0, 775.0], [441.0, 858.0], [420.0, 858.0]]], "lines": ["．．．", "わからん", "よ、戸川。"]}, {"box": [124, 575, 172, 672], "vertical": true, "font_size": 23, "lines_coords": [[[146.0, 576.0], [172.0, 576.0], [172.0, 639.0], [146.0, 639.0]], [[126.0, 575.0], [146.0, 575.0], [144.0, 672.0], [124.0, 672.0]]], "lines": ["おい．．．", "落ち着け！"]}, {"box": [707, 892, 772, 1064], "vertical": true, "font_size": 18, "lines_coords": [[[751.0, 892.0], [771.0, 892.0], [772.0, 1047.0], [752.0, 1047.0]], [[731.0, 895.0], [747.0, 895.0], [747.0, 