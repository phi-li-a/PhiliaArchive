.0], [566.0, 885.0]]], "lines": ["怪しい奴の住んでる", "部屋のほうから．．．！！！"]}, {"box": [33, 627, 400, 1042], "vertical": false, "font_size": 34, "lines_coords": [[[78.0, 925.0], [119.0, 908.0], [133.0, 939.0], [92.0, 957.0]]], "lines": ["＊"]}], "img_path": "020.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [753, 92, 784, 146], "vertical": true, "font_size": 31, "lines_coords": [[[753.0, 92.0], [784.0, 92.0], [784.0, 146.0], [753.0, 146.0]]], "lines": ["翌朝"]}, {"box": [377, 90, 448, 168], "vertical": true, "font_size": 25, "lines_coords": [[[423.0, 91.0], [448.0, 91.0], [448.0, 151.0], [423.0, 151.0]], [[397.0, 90.0], [426.0, 90.0], [426.0, 154.0], [397.0, 154.0]], [[377.0, 91.0], [397.0, 91.0], [397.0, 168.0], [377.0, 168.0]]], "lines": ["縁側の", "お掃除", "ですか？"]}, {"box": [735, 486, 780, 573], "vertical": true, "font_size": 22, "lines_coords": [[[754.0, 486.0], [780.0, 486.0], [780.0, 548.0], [754.0, 548.0]], [[736.0, 486.0], [755.0, 486.0], [755.0, 573.0], [736.0, 573.0]]], "lines": ["ええ．．．", "若林さん。"]}, {"box": [294, 480, 385, 561], "vertical": true, "font_size": 27, "lines_coords": [[[344.0, 483.0], [365.0, 483.0], [365.0, 561.0], [344.0, 561.0]], [[312.0, 480.0], [346.0, 480.0], [346.0, 529.0], [312.0, 529.0]], [[294.0, 481.0], [321.0, 481.0], [321.0, 534.0], [294.0, 534.0]]], "lines": ["ところで", "桐絵", "さん。"]}, {"box": [118, 391, 142, 453], "vertical": true, "font_size": 24, "lines_coords": [[[118.0, 391.0], [142.0, 391.0], [142.0, 453.0], [118.0, 453.0]]], "lines": ["えっ？"]}, {"box": [665, 708, 786, 792], "vertical": true, "font_size": 24, "lines_coords": [[[760.0, 710.0], [786.0, 710.0], [786.0, 761.0], [760.0, 761.0]], [[738.0, 708.0], [762.0, 708.0], [760.0, 792.0], [736.0, 792.0]], [[712.0, 711.0], [737.0, 711.0], [737.0, 789.0], [712.0, 789.0]], [[691.0, 712.0], [711.0, 712.0], [711.0, 789.0], [691.0, 789.0]], [[665.0, 708.0], [692.0, 708.0], [692.0, 755.0], [665.0, 755.0]]], "lines": ["でも、", "ちっとも", "きれいに", "ならなく", "て．．"]}, {"box": [682, 835, 772, 951], "vertical": true, "font_size": 19, "lines_coords": [[[750.0, 835.0], [770.0, 835.0], [772.0, 951.0], [752.0, 951.0]], [[727.0, 837.0], [747.0, 837.0], [747.0, 950.0], [727.0, 950.0]], [[703.0, 835.0], [723.0, 835.0], [723.0, 931.0], [703.0, 931.0]], [[682.0, 837.0], [698.0, 837.0], [698.0, 935.0], [682.0, 935.0]]], "lines": ["あれはどうも", "右端の住人の", "うめき声の", "ようですね"]}, {"box": [439, 700, 482, 795], "vertical": true, "font_size": 20, "lines_coords": [[[462.0, 701.0], [482.0, 701.0], [482.0, 795.0], [462.0, 795.0]], [[439.0, 700.0], [460.0, 700.0], [460.0, 768.0], [439.0, 768.0]]], "lines": ["無理もない", "ですね。"]}, {"box": [112, 550, 157, 686], "vertical": true, "font_size": 20, "lines_coords": [[[137.0, 551.0], [157.0, 551.0], [157.0, 648.0], [137.0, 648.0]], [[113.0, 550.0], [133.0, 550.0], [132.0, 686.0], [112.0, 686.0]]], "lines": ["ゆうべの声", "聞きましたか？"]}, {"box": [434, 848, 501, 1001], "vertical": true, "font_size": 19, "lines_coords": [[[480.0, 848.0], [500.0, 848.0], [500.0, 1000.0], [480.0, 1000.0]], [[457.0, 849.0], [478.0, 849.0], [478.0, 944.0], [457.0, 944.0]], [[434.0, 848.0], [451.0, 848.0], [451.0, 989.0], [434.0, 989.0]]], "lines": ["．．．いえね、この間", "役場の人に", "聞いたんですよ。"]}, {"box": [123, 851, 189, 1053], "vertical": true, "font_size": 19, "lines_coords": [[[168.0, 851.0], [188.0, 851.0], [188.0, 1010.0], [168.0, 1010.0]], [[147.0, 854.0], [164.0, 854.0], [164.0, 1044.0], [147.0, 1044.0]], [[123.0, 851.0], [142.0, 851.0], [142.0, 1053.0], [123.0, 1053.0]]], "lines": ["あそこには老婆と、", "その息子が生活保護を", "受けて住んでるってね。"]}], "img_path": "021.jpg"}, {"version": "0.1.7", "img_width": 833, "img_height": 1200, "blocks": [{"box": [576, 103, 715, 277], "vertical": true, "font_size": 20, "lines_coords": [[[693.0, 104.0], [713.0, 104.0], [713.0, 256.0], [693.0, 256.0]], [[671.0, 105.0], [691.0, 105.0], [690.0, 277.0], [670.0, 277.0]], [[643.0, 104.0], [668.0, 103.0], [671.0, 169.0], [645.0, 171.0]], [[624.0, 104.0], [644.0, 104.0], [642.0, 276.0], [622.0, 276.0]], [[602.0, 104.0], [618.0, 104.0], [616.0, 237.0], [599.0, 237.0]], [[576.0, 103.0], [596.0, 103.0], [596.0, 244.0], [576.0, 244.0]]], "lines": ["息子はかなり重い", "病気にかかっている", "ようで、", "ゆうべのうめき声は", "その苦しむ声に", "違いないですね。"]}, {"box": [68, 100, 233, 244], "vertical": true, "font_size": 21, "lines_coords": [[[205.0, 100.0], [233.0, 100.0], [233.0, 145.0], [205.0, 145.0]], [[185.0, 104.0], [205.0, 104.0], [205.0, 236.0], [185.0, 236.0]], [[162.0, 104.0], [179.0, 104.0], [179.0, 219.0], [162.0, 219.0]], [[133.0, 100.0], [156.0, 100.0], [159.0, 244.0], [135.0, 244.0]], [[113.0, 103.0], [133.0, 103.0], [133.0, 199.0], [113.0, 199.0]], [[87.0, 100.0], [107.0, 100.0], [110.0, 217.0], [90.0, 217.0]], [[69.0, 103.0], [85.0, 103.0], [85.0, 203.0], [69.0, 203.0]]], "lines": ["ただ", "何の病気なのか", "わからない．．．", "婆さんが息子を、", "他人に絶対", "見せないそう", "なんですよ。"]}, {"box": [611, 349, 705, 485], "vertical": true, "font_size": 20, "lines_coords": [[[685.0, 350.0], [705.0, 350.0], [705.0, 485.0], [685.0, 485.0]], [[659.0, 350.0], [680.0, 350.0], [678.0, 467.0], [657.0, 467.0]], [[636.0, 350.0], [656.0, 350.0], [656.0, 483.0], [636.0, 483.0]], [[611.0, 349.0], [631.0, 349.0], [633.0, 474.0], [613.0, 474.0]]], "lines": ["どうやら息子は", "かなり異様な", "風貌をしている", "らしいですよ。"]}, {"box": [195, 345, 263, 461], "vertical": true, "font_size": 21, "lines_coords": [[[242.0, 345.0], [263.0, 345.0], [263.0, 423.0], [242.0, 423.0]], [[219.0, 345.0], [239.0, 345.0], [239.0, 440.0], [219.0, 440.0]], [[195.0, 345.0], [215.0, 345.0], [215.0, 461.0], [195.0, 461.0]]], "lines": ["もちろん", "病気のせい", "でしょうが．．．"]}, {"box": [67, 365, 160, 491], "vertical": true, "font_size": 21, "lines_coords": [[[134.0, 365.0], [160.0, 365.0], [160.0, 428.0], [134.0, 428.0]], [[113.0, 367.0], [133.0, 367.0], [133.0, 445.0], [113.0, 445.0]], [[90.0, 367.0], [110.0, 367.0], [110.0, 483.0], [90.0, 483.0]], [[67.0, 369.0], [84.0, 369.0], [84.0, 491.0], [67.0, 491.0]]], "lines": ["それが", "鬼の噂に", "なったんでは", "ないですかね。"]}, {"box": [263, 854, 311, 933], "vertical": true, "font_size": 24, "lines_coords": [[[283.0, 854.0], [311.0, 854.0], [311.0, 900.0], [283.0, 900.0]], [[263.0, 855.0], [284.0, 855.0], [284.0, 933.0], [263.0, 933.0]]], "lines": ["噂を", "すれば．．．"]}, {"box": [71, 874, 115, 998], "vertical": true, "font_size": 18, "lines_coords": [[[94.0, 874.0], [114.0, 874.0], [114.0, 970.0], [94.0, 970.0]], [[71.0, 874.0], [87.0, 874.0], [90.0, 994.0], [73.0, 994.0]]], "lines": ["あれがその", "婆さんですよ。"]}], "img_path": "022.jpg"}, {"version": "0.1.7", "img_width": 832, "img_height": 1200, "blocks": [{"box": [261, 497, 315, 600], "vertical": true, "font_size": 54, "lines_coords": [[[261.0, 497.0], [315.0, 497.0], [315.0, 600.0], [261.0, 600.0]]], "lines": ["よろっ"]}, {"box": [568, 758, 592, 821], "vertical": true, "font_size": 24, "lines_coords": [[[568.0, 758.0], [592.0, 758.0], [592.0, 821.0], [568.0, 821.0]]], "lines": ["あっ！"]}, {"box": [302, 769, 353, 821], "vertical": true, "font_size": 29, "lines_coords": [[[321.0, 769.0], [353.0, 769.0], [353.0, 817.0], [321.0, 817.0]], [[302.0, 771.0], [328.0, 771.0], [328.0, 821.0], [302.0, 821.0]]], "lines": ["お婆", "さん、"]}, {"box": [135, 765, 182, 842], "vertical": true, "font_size": 22, "lines_coords": [[[157.0, 765.0], [182.0, 765.0], [182.0, 826.0], [157.0, 826.0]], [[135.0, 765.0], [155.0, 765.0], [155.0, 842.0], [135.0, 842.0]]], "lines": ["大丈夫", "ですか！？"]}], "img_path": "023.jpg"}, {"version": "0.1.7", "img_width": 837, "img_height": 1200, "blocks": [{"box": [668, 90, 716, 169], "vertical": true, "font_size": 26, "lines_coords": [[[695.0, 93.0], [716.0, 93.0], [716.0, 169.0], [695.0, 169.0]], [[668.0, 90.0], [698.0, 90.0], [698.0, 135.0], [668.0, 135.0]]], "lines": ["立てます", "か？"]}, {"box": [460, 383, 486, 455], "vertical": true, "font_size": 26, "lines_coords": [[[460.0, 383.0], [486.0, 383.0], [486.0, 455.0], [460.0, 455.0]]], "lines": ["あっ！？"]}, {"box": [696, 786, 720, 852], "vertical": true, "font_size": 24, "lines_coords": [[[696.0, 786.0], [720.0, 786.0], [720.0, 851.0], [696.0, 851.0]]], "lines": ["何だい、"]}, {"box": [406, 795, 426, 890], "vertical": true, "font_size": 20, "lines_coords": [[[406.0, 795.0], [426.0, 795.0], [426.0, 890.0], [406.0, 890.0]]], "lines": ["い．．．いえ"]}, {"box": [459, 977, 505, 1088], "vertical": true, "font_size": 22, "lines_coords": [[[485.0, 977.0], [505.0, 977.0], [505.0, 1088.0], [485.0, 1088.0]], [[459.0, 977.0], [484.0, 977.0], [484.0, 1038.0], [459.0, 1038.0]]], "lines": ["どうかしたの", "かい？"]}, {"box": [63, 982, 109, 1098], "vertical": true, "font_size": 21, "lines_coords": [[[80.0, 983.0], [106.0, 982.0], [109.0, 1044.0], [83.0, 1045.0]], [[63.0, 985.0], [79.0, 985.0], [79.0, 1098.0], [63.0, 1098.0]]], "lines": ["何でも", "ありません．．．"]}], "img_path": "024.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [709, 96, 777, 232], "vertical": true, "font_size": 20, "lines_coords": [[[757.0, 98.0], [777.0, 98.0], [774.0, 219.0], [754.0, 219.0]], [[733.0, 98.0], [753.0, 98.0], [751.0, 232.0], [731.0, 232.0]], [[711.0, 96.0], [731.0, 96.0], [729.0, 195.0], [709.0, 195.0]]], "lines": ["そしてそれは、", "その日の午後の", "事でした．．．"]}, {"box": [113, 117, 345, 162], "vertical": false, "font_size": 38, "lines_coords": [[[116.0, 121.0], [212.0, 121.0], [212.0, 159.0], [116.0, 159.0]]], "lines": ["ウォー"]}, {"box": [733, 413, 775, 512], "vertical": true, "font_size": 20, "lines_coords": [[[755.0, 413.0], [775.0, 413.0], [775.0, 492.0], [755.0, 492.0]], [[733.0, 414.0], [753.0, 414.0], [753.0, 512.0], [733.0, 512.0]]], "lines": ["また鬼が", "吠えてる！！"]}, {"box": [390, 424, 503, 575], "vertical": true, "font_size": 18, "lines_coords": [[[482.0, 424.0], [503.0, 424.0], [503.0, 502.0], [482.0, 502.0]], [[460.0, 424.0], [480.0, 424.0], [480.0, 540.0], [460.0, 540.0]], [[438.0, 425.0], [454.0, 425.0], [454.0, 575.0], [438.0, 575.0]], [[414.0, 425.0], [431.0, 425.0], [431.0, 575.0], [414.0, 575.0]], [[390.0, 424.0], [406.0, 424.0], [406.0, 519.0], [390.0, 519.0]]], "lines": ["．．．違う！", "ゆうべの声と", "違うもの．．．あれは", "お婆さんの声だわ", "．．．それに．．．"]}, {"box": [112, 411, 159, 548], "vertical": true, "font_size": 20, "lines_coords": [[[138.0, 412.0], [158.0, 412.0], [158.0, 510.0], [138.0, 510.0]], [[114.0, 411.0], [134.0, 411.0], [132.0, 548.0], [112.0, 548.0]]], "lines": ["あの叫びは", "普通じゃない！！"]}, {"box": [710, 628, 777, 783], "vertical": true, "font_size": 21, "lines_coords": [[[757.0, 630.0], [777.0, 630.0], [777.0, 725.0], [757.0, 725.0]], [[731.0, 628.0], [754.0, 628.0], [752.0, 783.0], [729.0, 783.0]], [[710.0, 628.0], [730.0, 628.0], [730.0, 712.0], [710.0, 712.0]]], "lines": ["お婆さんに", "何かあったのかも", "しれない。"]}, {"box": [413, 633, 434, 711], "vertical": true, "font_size": 20, "lines_coords": [[[413.0, 633.0], [433.0, 633.0], [433.0, 711.0], [413.0, 711.0]]], "lines": ["桐絵っ！！"]}, {"box": [62, 663, 371, 714], "vertical": false, "font_size": 48, "lines_coords": [[[65.0, 666.0], [349.0, 663.0], [349.0, 711.0], [65.0, 714.0]]], "lines": ["ウォオオオン"]}, {"box": [135, 841, 159, 939], "vertical": true, "font_size": 22, "lines_coords": [[[138.0, 841.0], [159.0, 841.0], [157.0, 938.0], [135.0, 938.0]]], "lines": ["お婆さん！"]}, {"box": [758, 895, 815, 1164], "vertical": true, "font_size": 48, "lines_coords": [[[767.0, 895.0], [815.0, 896.0], [806.0, 1164.0], [758.0, 1163.0]]], "lines": ["ウオオオ．．．"]}], "img_path": "025.jpg"}, {"version": "0.1.7", "img_width": 832, "img_height": 1200, "blocks": [{"box": [669, 91, 715, 377], "vertical": true, "font_size": 44, "lines_coords": [[[671.0, 91.0], [715.0, 91.0], [713.0, 377.0], [669.0, 377.0]]], "lines": ["ウォオオオン"]}, {"box": [663, 457, 720, 620], "vertical": true, "font_size": 24, "lines_coords": [[[694.0, 458.0], [719.0, 458.0], [719.0, 619.0], [694.0, 619.0]], [[663.0, 458.0], [687.0, 458.0], [687.0, 619.0], [663.0, 619.0]]], "lines": ["息子があ～～", "息子があ〜〜"]}, {"box": [278, 280, 348, 377], "vertical": true, "font_size": 20, "lines_coords": [[[328.0, 281.0], [348.0, 281.0], [348.0, 365.0], [328.0, 365.0]], [[304.0, 280.0], [324.0, 280.0], [324.0, 377.0], [304.0, 377.0]], [[281.0, 280.0], [302.0, 280.0], [299.0, 359.0], [278.0, 359.0]]], "lines": ["お婆さん、", "どうしたん", "ですか！？"]}, {"box": [230, 833, 303, 1051], "vertical": true, "font_size": 32, "lines_coords": [[[266.0, 833.0], [303.0, 833.0], [303.0, 929.0], [266.0, 929.0]], [[234.0, 833.0], [262.0, 833.0], [258.0, 1051.0], [230.0, 1051.0]]], "lines": ["死んで", "しまったあ～～～"]}], "img_path": "026.jpg"}, {"version": "0.1.7", "img_width": 832, "img_height": 1200, "blocks": [{"box": [751, 86, 774, 246], "vertical": true, "font_size": 18, "lines_coords": [[[751.0, 86.0], [774.0, 86.0], [774.0, 246.0], [751.0, 246.0]]], "lines": ["死んでしまった"]}, {"box": [727, 174, 741, 201], "vertical": true, "font_size": 18, "lines_coords": [[[727.0, 174.0], [741.0, 174.0], [741.0, 201.0], [727.0, 201.0]]], "lines": ["くく"]}, {"box": [407, 172, 444, 383], "vertical": true, "font_size": 37, "lines_coords": [[[407.0, 172.0], [444.0, 172.0], [444.0, 383.0], [407.0, 383.0]]], "lines": ["ウオオオ．．．"]}, {"box": [114, 408, 293, 517], "vertical": false, "font_size": 49, "lines_coords": [[[135.0, 408.0], [271.0, 473.0], [250.0, 517.0], [114.0, 453.0]]], "lines": ["きゃあっ"]}, {"box": [405, 773, 549, 897], "vertical": true, "font_size": 21, "lines_coords": [[[528.0, 774.0], [549.0, 774.0], [549.0, 870.0], [528.0, 870.0]], [[494.0, 773.0], [523.0, 773.0], [523.0, 839.0], [494.0, 839.0]], [[475.0, 774.0], [495.0, 774.0], [495.0, 853.0], [475.0, 853.0]], [[453.0, 776.0], [469.0, 776.0], [469.0, 890.0], [453.0, 890.0]], [[427.0, 774.0], [448.0, 774.0], [446.0, 862.0], [425.0, 862.0]], [[405.0, 775.0], [425.0, 775.0], [425.0, 897.0], [405.0, 897.0]]], "lines": ["息子さんの", "亡骸を", "長屋から", "運び出すのは", "大変苦労", "したそうです。"]}, {"box": [147, 773, 239, 851], "vertical": false, "font_size": 21.0, "lines_coords": [[[165.0, 773.0], [239.0, 810.0], [228.0, 832.0], [154.0, 794.0]], [[154.0, 799.0], [235.0, 834.0], [228.0, 851.0], [147.0, 815.0]]], "lines": ["山田病院", "整形外科・皮フ科"]}, {"box": [287, 926, 355, 1099], "vertical": true, "font_size": 18, "lines_coords": [[[336.0, 929.0], [352.0, 929.0], [352.0, 1078.0], [336.0, 1078.0]], [[311.0, 926.0], [330.0, 926.0], [328.0, 1099.0], [309.0, 1099.0]], [[287.0, 926.0], [307.0, 926.0], [307.0, 1007.0], [287.0, 1007.0]]], "lines": ["お婆さんは病院で", "原因不明の皮膚病と", "診断され、"]}, {"box": [86, 936, 155, 1089], "vertical": true, "font_size": 20, "lines_coords": [[[133.0, 936.0], [154.0, 936.0], [152.0, 1089.0], [131.0, 1089.0]], [[110.0, 937.0], [130.0, 937.0], [130.0, 1089.0], [110.0, 1089.0]], [[86.0, 936.0], [106.0, 936.0], [106.0, 1058.0], [86.0, 1058.0]]], "lines": ["親子で同じ病気に", "冒されていた事が", "わかりました。"]}], "img_path": "027.jpg"}, {"version": "0.1.7", "img_width": 832, "img_height": 1200, "blocks": [{"box": [616, 98, 689, 195], "vertical": true, "font_size": 25, "lines_coords": [[[663.0, 99.0], [689.0, 99.0], [689.0, 160.0], [663.0, 160.0]], [[640.0, 99.0], [662.0, 99.0], [662.0, 195.0], [640.0, 195.0]], [[616.0, 98.0], [642.0, 98.0], [642.0, 161.0], [616.0, 161.0]]], "lines": ["いやあ", "残念だった", "なあ！"]}, {"box": [86, 128, 156, 244], "vertical": true, "font_size": 20, "lines_coords": [[[134.0, 130.0], [154.0, 130.0], [154.0, 244.0], [134.0, 244.0]], [[111.0, 130.0], [131.0, 130.0], [131.0, 208.0], [111.0, 208.0]], [[86.0, 128.0], [107.0, 128.0], [108.0, 215.0], [87.0, 215.0]]], "lines": ["僕もその場に", "居合わせ", "たかった。"]}, {"box": [597, 287, 716, 424], "vertical": true, "font_size": 22, "lines_coords": [[[696.0, 290.0], [715.0, 290.0], [715.0, 407.0], [696.0, 407.0]], [[672.0, 288.0], [692.0, 288.0], [691.0, 424.0], [671.0, 424.0]], [[649.0, 290.0], [669.0, 290.0], [667.0, 424.0], [648.0, 424.0]], [[625.0, 288.0], [646.0, 288.0], [644.0, 403.0], [623.0, 403.0]], [[597.0, 287.0], [625.0, 287.0], [625.0, 331.0], [597.0, 331.0]]], "lines": ["：で桐絵さん", "その息子の姿は", "一体どんなふう", "だったんです", "か？"]}, {"box": [400, 284, 498, 389], "vertical": true, "font_size": 24, "lines_coords": [[[473.0, 285.0], [498.0, 285.0], [498.0, 348.0], [473.0, 348.0]], [[451.0, 287.0], [472.0, 287.0], [473.0, 389.0], [452.0, 389.0]], [[428.0, 288.0], [449.0, 288.0], [449.0, 365.0], [428.0, 365.0]], [[400.0, 284.0], [431.0, 284.0], [431.0, 338.0], [400.0, 338.0]]], "lines": ["教えて", "くださいよ、", "気になる", "なあ。"]}, {"box": [349, 292, 370, 369], "vertical": true, "font_size": 20, "lines_coords": [[[349.0, 292.0], [369.0, 292.0], [369.0, 369.0], [349.0, 369.0]]], "lines": ["いえね．．．"]}, {"box": [220, 471, 359, 607], "vertical": true, "font_size": 21, "lines_coords": [[[338.0, 472.0], [359.0, 472.0], [357.0, 569.0], [336.0, 569.0]], [[315.0, 472.0], [335.0, 472.0], [333.0, 607.0], [314.0, 607.0]], [[290.0, 471.0], [314.0, 471.0], [314.0, 590.0], [290.0, 590.0]], [[268.0, 473.0], [288.0, 473.0], [288.0, 589.0], [268.0, 589.0]], [[243.0, 473.0], [263.0, 473.0], [263.0, 588.0], [243.0, 588.0]], [[220.0, 473.0], [241.0, 473.0], [241.0, 550.0], [220.0, 550.0]]], "lines": ["その息子が", "寝ていたという", "床に、小さな", "丸い穴が沢山", "開いていたん", "ですよ．．．"]}, {"box": [60, 294, 155, 428], "vertical": true, "font_size": 20, "lines_coords": [[[134.0, 295.0], [154.0, 295.0], [154.0, 397.0], [134.0, 397.0]], [[110.0, 296.0], [130.0, 296.0], [130.0, 411.0], [110.0, 411.0]], [[86.0, 296.0], [106.0, 296.0], [106.0, 428.0], [86.0, 428.0]], [[63.0, 294.0], [83.0, 294.0], [80.0, 410.0], [60.0, 410.0]]], "lines": ["実はさっき、", "無断で部屋を", "のぞいてきたん", "ですけどね．．．"]}, {"box": [71, 475, 117, 571], "vertical": true, "font_size": 20, "lines_coords": [[[94.0, 475.0], [114.0, 475.0], [114.0, 571.0], [94.0, 571.0]], [[71.0, 476.0], [92.0, 476.0], [92.0, 553.0], [71.0, 553.0]]], "lines": ["ありゃー体", "何です？"]}, {"box": [655, 839, 723, 944], "vertical": true, "font_size": 21, "lines_coords": [[[701.0, 841.0], [723.0, 841.0], [723.0, 937.0], [701.0, 937.0]], [[676.0, 839.0], [701.0, 839.0], [701.0, 903.0], [676.0, 903.0]], [[656.0, 841.0], [672.0, 841.0], [672.0, 944.0], [656.0, 944.0]]], "lines": ["．．．私、何も", "話す事", "ありません。"]}, {"box": [352, 919, 396, 1092], "vertical": true, "font_size": 20, "lines_coords": [[[376.0, 919.0], [396.0, 919.0], [396.0, 1035.0], [376.0, 1035.0]], [[352.0, 919.0], [372.0, 919.0], [372.0, 1092.0], [352.0, 1092.0]]], "lines": ["でも普通じゃ", "なかったんでしょ？"]}, {"box": [70, 857, 112, 1056], "vertical": true, "font_size": 18, "lines_coords": [[[90.0, 857.0], [110.0, 857.0], [112.0, 1037.0], [92.0, 1037.0]], [[70.0, 858.0], [86.0, 858.0], [86.0, 1054.0], [70.0, 1054.0]]], "lines": ["いいじゃないですか、", "誰にも言いませんから、"]}], "img_path": "028.jpg"}, {"version": "0.1.7", "img_width": 832, "img_height": 1200, "blocks": [{"box": [746, 143, 790, 325], "vertical": true, "font_size": 20, "lines_coords": [[[769.0, 144.0], [789.0, 144.0], [789.0, 244.0], [769.0, 244.0]], [[746.0, 144.0], [766.0, 144.0], [766.0, 325.0], [746.0, 325.0]]], "lines": ["すみません、", "話したくないんです。"]}, {"box": [367, 86, 392, 148], "vertical": true, "font_size": 25, "lines_coords": [[[367.0, 86.0], [392.0, 86.0], [392.0, 148.0], [367.0, 148.0]]], "lines": ["ふん．．．"]}, {"box": [108, 77, 179, 222], "vertical": true, "font_size": 22, "lines_coords": [[[151.0, 77.0], [179.0, 77.0], [179.0, 123.0], [151.0, 123.0]], [[132.0, 80.0], [152.0, 80.0], [152.0, 214.0], [132.0, 214.0]], [[108.0, 79.0], [126.0, 79.0], [127.0, 220.0], [110.0, 220.0]]], "lines": ["案外", "生意気なとこが", "あるじゃないか"]}, {"box": [118, 359, 259, 533], "vertical": true, "font_size": 20, "lines_coords": [[[240.0, 362.0], [256.0, 362.0], [256.0, 454.0], [240.0, 454.0]], [[213.0, 359.0], [233.0, 359.0], [234.0, 499.0], [214.0, 499.0]], [[191.0, 359.0], [210.0, 359.0], [210.0, 532.0], [191.0, 532.0]], [[165.0, 359.0], [185.0, 359.0], [187.0, 533.0], [167.0, 533.0]], [[140.0, 359.0], [161.0, 359.0], [164.0, 475.0], [142.0, 475.0]], [[118.0, 360.0], [139.0, 360.0], [140.0, 478.0], [119.0, 478.0]]], "lines": ["なお今回も", "台風１号と同様", "うずまき状の「目」が", "地上からはっきりと", "確認できると", "いう事です．．．"]}, {"box": [724, 556, 768, 735], "vertical": true, "font_size": 18, "lines_coords": [[[749.0, 557.0], [766.0, 557.0], [766.0, 690.0], [749.0, 690.0]], [[724.0, 556.0], [744.0, 556.0], [744.0, 735.0], [724.0, 735.0]]], "lines": ["台風２号は現在", "九州に上陸しており、"]}, {"box": [701, 781, 769, 916], "vertical": true, "font_size": 20, "lines_coords": [[[748.0, 783.0], [768.0, 783.0], [768.0, 916.0], [748.0, 916.0]], [[725.0, 781.0], [745.0, 781.0], [742.0, 877.0], [723.0, 877.0]], [[701.0, 781.0], [721.0, 781.0], [721.0, 860.0], [701.0, 860.0]]], "lines": ["いやだ．．．私にも", "うおの目が", "できた．．．"]}, {"box": [408, 560, 475, 731], "vertical": true, "font_size": 18, "lines_coords": [[[454.0, 560.0], [474.0, 560.0], [474.0, 731.0], [454.0, 731.0]], [[432.0, 561.0], [448.0, 561.0], [448.0, 692.0], [432.0, 692.0]], [[408.0, 560.0], [425.0, 560.0], [425.0, 659.0], [408.0, 659.0]]], "lines": ["このあと日本列島を", "縦断するものと", "思われます。"]}, {"box": [444, 772, 515, 908], "vertical": true, "font_size": 22, "lines_coords": [[[489.0, 772.0], [515.0, 772.0], [515.0, 835.0], [489.0, 835.0]], [[468.0, 774.0], [488.0, 774.0], [488.0, 908.0], [468.0, 908.0]], [[444.0, 775.0], [464.0, 775.0], [466.0, 869.0], [446.0, 869.0]]], "lines": ["それも", "ひとつじゃなく", "いくつも．．．"]}, {"box": [339, 767, 410, 871], "vertical": true, "font_size": 22, "lines_coords": [[[387.0, 769.0], [407.0, 769.0], [410.0, 871.0], [390.0, 871.0]], [[364.0, 768.0], [385.0, 768.0], [386.0, 866.0], [365.0, 866.0]], [[339.0, 767.0], [364.0, 767.0], [364.0, 836.0], [339.0, 836.0]]], "lines": ["オレもだよ、", "ねえちゃん", "痛えよ。"]}, {"box": [255, 773, 301, 841], "vertical": true, "font_size": 22, "lines_coords": [[[275.0, 773.0], [301.0, 773.0], [301.0, 835.0], [275.0, 835.0]], [[255.0, 773.0], [275.0, 773.0], [275.0, 841.0], [255.0, 841.0]]], "lines": ["手にも", "できた。"]}, {"box": [110, 973, 155, 1095], "vertical": true, "font_size": 18, "lines_coords": [[[134.0, 973.0], [151.0, 973.0], [153.0, 1087.0], [137.0, 1087.0]], [[110.0, 973.0], [128.0, 973.0], [131.0, 1094.0], [112.0, 1094.0]]], "lines": ["あなた達も？", "お母さんもよ。"]}], "img_path": "029.jpg"}, {"version": "0.1.7", "img_width": 838, "img_height": 1200, "blocks": [{"box": [672, 80, 721, 142], "vertical": true, "font_size": 26, "lines_coords": [[[695.0, 82.0], [721.0, 82.0], [721.0, 142.0], [695.0, 142.0]], [[672.0, 82.0], [698.0, 80.0], [700.0, 133.0], [675.0, 134.0]]], "lines": ["ただい", "まァ。"]}, {"box": [356, 77, 404, 157], "vertical": true, "font_size": 26, "lines_coords": [[[373.0, 77.0], [404.0, 77.0], [404.0, 139.0], [373.0, 139.0]], [[356.0, 79.0], [377.0, 79.0], [377.0, 157.0], [356.0, 157.0]]], "lines": ["いてて", "ててて．．．"]}, {"box": [267, 83, 313, 225], "vertical": true, "font_size": 20, "lines_coords": [[[293.0, 83.0], [312.0, 83.0], [312.0, 179.0], [293.0, 179.0]], [[269.0, 83.0], [289.0, 83.0], [287.0, 225.0], [267.0, 225.0]]], "lines": ["うおの目が", "痛くてかなわん。"]}, {"box": [506, 427, 548, 506], "vertical": true, "font_size": 21, "lines_coords": [[[508.0, 427.0], [529.0, 427.0], [527.0, 506.0], [506.0, 506.0]]], "lines": ["やあね．．．"]}, {"box": [69, 250, 140, 396], "vertical": true, "font_size": 24, "lines_coords": [[[108.0, 250.0], [140.0, 250.0], [140.0, 298.0], [108.0, 298.0]], [[90.0, 254.0], [110.0, 254.0], [112.0, 351.0], [92.0, 351.0]], [[69.0, 255.0], [89.0, 255.0], [89.0, 393.0], [69.0, 393.0]]], "lines": ["体の", "あちこちに", "出てきやがった。"]}, {"box": [695, 725, 736, 788], "vertical": true, "font_size": 26, "lines_coords": [[[710.0, 725.0], [736.0, 725.0], [736.0, 788.0], [710.0, 788.0]]], "lines": ["フフフ"]}, {"box": [472, 720, 593, 865], "vertical": true, "font_size": 22, "lines_coords": [[[563.0, 720.0], [593.0, 723.0], [588.0, 788.0], [559.0, 786.0]], [[542.0, 723.0], [562.0, 723.0], [560.0, 863.0], [540.0, 863.0]], [[519.0, 723.0], [539.0, 723.0], [537.0, 857.0], [518.0, 857.0]], [[493.0, 723.0], [516.0, 723.0], [516.0, 860.0], [493.0, 860.0]], [[473.0, 725.0], [489.0, 725.0], [489.0, 864.0], [473.0, 864.0]]], "lines": ["お前が", "越してきてから、", "ずっとこうして", "のぞいてる事を", "お前は知るまい。"]}, {"box": [278, 719, 438, 856], "vertical": true, "font_size": 22, "lines_coords": [[[417.0, 721.0], [438.0, 721.0], [438.0, 801.0], [417.0, 801.0]], [[392.0, 721.0], [417.0, 721.0], [417.0, 803.0], [392.0, 803.0]], [[369.0, 721.0], [393.0, 721.0], [393.0, 785.0], [369.0, 785.0]], [[348.0, 723.0], [368.0, 723.0], [36