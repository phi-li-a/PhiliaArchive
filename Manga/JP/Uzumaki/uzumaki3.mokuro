.0], [698.0, 507.0]]], "lines": ["何だっていいさ。"]}, {"box": [428, 365, 521, 567], "vertical": true, "font_size": 20, "lines_coords": [[[496.0, 365.0], [520.0, 365.0], [521.0, 543.0], [498.0, 543.0]], [[474.0, 366.0], [495.0, 366.0], [496.0, 567.0], [475.0, 567.0]], [[452.0, 366.0], [472.0, 366.0], [472.0, 539.0], [452.0, 539.0]], [[428.0, 369.0], [446.0, 369.0], [447.0, 521.0], [430.0, 521.0]]], "lines": ["なあ、ねえちゃん達", "オレ達の仲間になれよ。", "うまいもんいっぱい", "食わせてやるぜ！！"]}, {"box": [336, 375, 388, 557], "vertical": true, "font_size": 22, "lines_coords": [[[358.0, 375.0], [383.0, 375.0], [380.0, 532.0], [356.0, 532.0]], [[337.0, 376.0], [357.0, 376.0], [356.0, 557.0], [336.0, 557.0]]], "lines": ["．．．私達、蝶族の", "仲間にはなれません。"]}, {"box": [70, 359, 107, 434], "vertical": true, "font_size": 30, "lines_coords": [[[70.0, 359.0], [100.0, 359.0], [100.0, 434.0], [70.0, 434.0]]], "lines": ["蝶族？"]}, {"box": [564, 616, 710, 751], "vertical": true, "font_size": 21, "lines_coords": [[[685.0, 616.0], [710.0, 616.0], [710.0, 697.0], [685.0, 697.0]], [[657.0, 616.0], [678.0, 616.0], [679.0, 750.0], [658.0, 750.0]], [[634.0, 616.0], [653.0, 616.0], [656.0, 733.0], [636.0, 733.0]], [[611.0, 617.0], [631.0, 617.0], [631.0, 751.0], [611.0, 751.0]], [[588.0, 616.0], [608.0, 616.0], [608.0, 733.0], [588.0, 733.0]], [[564.0, 616.0], [584.0, 616.0], [584.0, 739.0], [564.0, 739.0]]], "lines": ["オレ達は", "蝶族はとっくに", "卒業したぜ！", "お花の蜜なんか", "吸ってる場合", "じゃないしな。"]}, {"box": [357, 628, 454, 750], "vertical": true, "font_size": 26, "lines_coords": [[[430.0, 631.0], [454.0, 631.0], [454.0, 710.0], [430.0, 710.0]], [[402.0, 628.0], [434.0, 628.0], [434.0, 683.0], [402.0, 683.0]], [[380.0, 629.0], [410.0, 629.0], [410.0, 694.0], [380.0, 694.0]], [[357.0, 633.0], [377.0, 633.0], [377.0, 750.0], [357.0, 750.0]]], "lines": ["オレ達は", "今や、", "肉食の", "トンボ族だ！"]}, {"box": [256, 629, 301, 765], "vertical": true, "font_size": 20, "lines_coords": [[[280.0, 629.0], [300.0, 629.0], [298.0, 765.0], [278.0, 765.0]], [[256.0, 630.0], [276.0, 630.0