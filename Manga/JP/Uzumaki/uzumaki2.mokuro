 656.0], [242.0, 656.0], [242.0, 814.0], [222.0, 814.0]], [[201.0, 658.0], [218.0, 658.0], [218.0, 768.0], [201.0, 768.0]], [[174.0, 656.0], [195.0, 656.0], [196.0, 789.0], [175.0, 789.0]], [[152.0, 657.0], [172.0, 657.0], [172.0, 788.0], [152.0, 788.0]], [[128.0, 657.0], [148.0, 657.0], [148.0, 751.0], [128.0, 751.0]], [[104.0, 655.0], [124.0, 655.0], [126.0, 771.0], [106.0, 771.0]]], "lines": ["それがよくわから", "ないんですよ！！", "わかっているのは、", "Ｇ県の山奥に", "ひとりで住んで", "いる謎の人物と", "いう事だけ", "なんですよ！！"]}, {"box": [688, 869, 767, 1031], "vertical": true, "font_size": 23, "lines_coords": [[[743.0, 870.0], [767.0, 870.0], [767.0, 966.0], [743.0, 966.0]], [[715.0, 869.0], [738.0, 869.0], [738.0, 1028.0], [715.0, 1028.0]], [[688.0, 869.0], [711.0, 869.0], [711.0, 1031.0], [688.0, 1031.0]]], "lines": ["伊藤さん、", "これから会いに", "行きませんか！？"]}, {"box": [419, 864, 474, 1102], "vertical": true, "font_size": 24, "lines_coords": [[[445.0, 864.0], [470.0, 864.0], [474.0, 1102.0], [450.0, 1102.0]], [[419.0, 864.0], [443.0, 864.0], [445.0, 1094.0], [422.0, 1094.0]]], "lines": ["わかりました！！すぐに", "Ｇ県へ飛びましょう！！"]}, {"box": [318, 867, 385, 1025], "vertical": true, "font_size": 19, "lines_coords": [[[364.0, 867.0], [384.0, 867.0], [384.0, 1024.0], [364.0, 1024.0]], [[342.0, 868.0], [359.0, 868.0], [358.0, 999.0], [341.0, 999.0]], [[318.0, 868.0], [338.0, 868.0], [338.0, 1001.0], [318.0, 1001.0]]], "lines": ["というわけだから、", "あとは頼んだよ", "Ｋ・ミナミ君！"]}, {"box": [113, 1026, 165, 1093], "vertical": true, "font_size": 29, "lines_coords": [[[133.0, 1026.0], [165.0, 1030.0], [160.0, 1076.0], [128.0, 1073.0]], [[113.0, 1031.0], [138.0, 1031.0], [138.0, 1093.0], [113.0, 1093.0]]], "lines": ["はい", "先生！！"]}], "img_path": "203.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [203, 96, 391, 212], "vertical": true, "font_size": 21, "lines_coords": [[[371.0, 97.0], [391.0, 97.0], [391.0, 175.0], [371.0, 175.0]], [[348.0, 98.0], [368.0, 98.0], [368.0, 193.0], [348.0, 193.0]], [[323.0, 97.0], [344.0, 97.0],