, 427.0], [169.0, 427.0], [169.0, 562.0], [149.0, 562.0]], [[127.0, 427.0], [144.0, 427.0], [144.0, 597.0], [127.0, 597.0]], [[101.0, 427.0], [122.0, 427.0], [122.0, 493.0], [101.0, 493.0]]], "lines": ["この間、裏庭で", "見つかった変死体と", "同じだ。"]}, {"box": [279, 706, 422, 826], "vertical": true, "font_size": 22, "lines_coords": [[[397.0, 706.0], [422.0, 706.0], [422.0, 769.0], [397.0, 769.0]], [[374.0, 706.0], [398.0, 706.0], [398.0, 826.0], [374.0, 826.0]], [[352.0, 707.0], [372.0, 707.0], [372.0, 802.0], [352.0, 802.0]], [[327.0, 708.0], [347.0, 708.0], [347.0, 785.0], [327.0, 785.0]], [[306.0, 708.0], [323.0, 708.0], [323.0, 803.0], [306.0, 803.0]], [[279.0, 707.0], [303.0, 707.0], [303.0, 750.0], [279.0, 750.0]]], "lines": ["先生．．．", "それにしても", "この体中の", "刺し傷の", "ような跡は", "．．．？"]}, {"box": [98, 713, 213, 830], "vertical": true, "font_size": 19, "lines_coords": [[[193.0, 713.0], [213.0, 713.0], [213.0, 830.0], [193.0, 830.0]], [[169.0, 714.0], [189.0, 714.0], [189.0, 793.0], [169.0, 793.0]], [[145.0, 714.0], [165.0, 714.0], [165.0, 810.0], [145.0, 810.0]], [[124.0, 716.0], [140.0, 716.0], [140.0, 829.0], [124.0, 829.0]], [[100.0, 716.0], [118.0, 716.0], [115.0, 812.0], [98.0, 812.0]]], "lines": ["．．．わからん．．．", "どうやら", "体中の血が", "抜きとられて", "いるようだ"]}, {"box": [100, 975, 145, 1091], "vertical": true, "font_size": 20, "lines_coords": [[[124.0, 975.0], [145.0, 975.0], [142.0, 1091.0], [121.0, 1091.0]], [[100.0, 976.0], [120.0, 976.0], [120.0, 1054.0], [100.0, 1054.0]]], "lines": ["と、とにかく", "警察を！"]}], "img_path": "115.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [623, 107, 694, 243], "vertical": true, "font_size": 22, "lines_coords": [[[672.0, 107.0], [694.0, 107.0], [691.0, 232.0], [670.0, 232.0]], [[648.0, 110.0], [668.0, 110.0], [668.0, 243.0], [648.0, 243.0]], [[623.0, 108.0], [648.0, 108.0], [648.0, 169.0], [623.0, 169.0]]], "lines": ["どういう事だ、", "誰かに殺された", "のか！？"]}, {"box": [473, 226, 540, 349], "vertical": true, "font_size": 19, "lines_coords"