[132.0, 735.0], [112.0, 735.0]]], "lines": ["それについては今朝、", "家から電話があって", "数日前から片山は", "家に帰ってないとかで．．"]}, {"box": [696, 841, 764, 994], "vertical": true, "font_size": 19, "lines_coords": [[[744.0, 841.0], [764.0, 841.0], [764.0, 923.0], [744.0, 923.0]], [[720.0, 841.0], [740.0, 841.0], [740.0, 994.0], [720.0, 994.0]], [[697.0, 841.0], [715.0, 841.0], [714.0, 959.0], [696.0, 959.0]]], "lines": ["そりゃあ、", "あんな姿で家には", "帰れますまいっ"]}, {"box": [462, 854, 528, 987], "vertical": true, "font_size": 18, "lines_coords": [[[508.0, 855.0], [528.0, 855.0], [528.0, 951.0], [508.0, 951.0]], [[482.0, 854.0], [502.0, 854.0], [505.0, 987.0], [486.0, 987.0]], [[462.0, 855.0], [478.0, 855.0], [478.0, 969.0], [462.0, 969.0]]], "lines": ["裏山にでも", "隠れてたんじゃ", "ないですか？"]}, {"box": [329, 847, 418, 999], "vertical": true, "font_size": 17, "lines_coords": [[[399.0, 848.0], [415.0, 848.0], [415.0, 979.0], [399.0, 979.0]], [[375.0, 848.0], [392.0, 848.0], [392.0, 943.0], [375.0, 943.0]], [[350.0, 847.0], [370.0, 847.0], [370.0, 999.0], [350.0, 999.0]], [[329.0, 848.0], [345.0, 848.0], [345.0, 986.0], [329.0, 986.0]]], "lines": ["それで両親には", "とりあえず", "学校に来るように", "伝えましたので、"]}, {"box": [112, 849, 154, 991], "vertical": true, "font_size": 17, "lines_coords": [[[137.0, 849.0], [154.0, 849.0], [152.0, 928.0], [134.0, 928.0]], [[113.0, 850.0], [129.0, 850.0], [129.0, 990.0], [113.0, 990.0]]], "lines": ["もうすぐ", "到着する頃です。"]}], "img_path": "057.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [312, 91, 380, 188], "vertical": true, "font_size": 21, "lines_coords": [[[356.0, 92.0], [377.0, 92.0], [378.0, 169.0], [357.0, 169.0]], [[331.0, 91.0], [356.0, 91.0], [356.0, 172.0], [331.0, 172.0]], [[313.0, 93.0], [329.0, 93.0], [329.0, 188.0], [313.0, 188.0]]], "lines": ["校長先生", "：息子は", "どこです？"]}, {"box": [121, 73, 172, 157], "vertical": true, "font_size": 27, "lines_coords": [[[137.0, 75.0], [169.0, 73.0], [172.0, 130.0], [139.0, 131.0]], [[121.0, 77.0], [143.0, 77.0], [143.0, 157.0], [121.0, 157.0]]], "lines": ["はい、", "それが．．．"]}, {"box": [682, 435, 724, 557], "vertical": true, "font_size": 18, "lines_coords": [[[704.0, 435.0], [724.0, 435.0], [724.0, 512.0], [704.0, 512.0]], [[683.0, 438.0], [699.0, 438.0], [699.0, 556.0], [683.0, 556.0]]], "lines": ["．．．あれが", "そうなんです。"]}, {"box": [245, 682, 273, 789], "vertical": true, "font_size": 26, "lines_coords": [[[245.0, 682.0], [270.0, 682.0], [273.0, 789.0], [247.0, 789.0]]], "lines": ["ばかな！？"]}, {"box": [69, 987, 151, 1081], "vertical": true, "font_size": 27, "lines_coords": [[[120.0, 987.0], [151.0, 987.0], [151.0, 1059.0], [120.0, 1059.0]], [[92.0, 987.0], [121.0, 987.0], [121.0, 1060.0], [92.0, 1060.0]], [[69.0, 990.0], [90.0, 990.0], [90.0, 1081.0], [69.0, 1081.0]]], "lines": ["あれが", "息子だ", "などと！！"]}], "img_path": "058.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [705, 96, 749, 229], "vertical": true, "font_size": 18, "lines_coords": [[[729.0, 96.0], [749.0, 96.0], [749.0, 212.0], [729.0, 212.0]], [[705.0, 96.0], [722.0, 96.0], [722.0, 228.0], [705.0, 228.0]]], "lines": ["認めませんぞ", "はかはかしい！！"]}, {"box": [558, 92, 604, 171], "vertical": true, "font_size": 24, "lines_coords": [[[575.0, 93.0], [604.0, 93.0], [604.0, 137.0], [575.0, 137.0]], [[558.0, 92.0], [577.0, 92.0], [577.0, 171.0], [558.0, 171.0]]], "lines": ["おい", "帰るぞ！！"]}, {"box": [431, 82, 500, 295], "vertical": true, "font_size": 22, "lines_coords": [[[474.0, 82.0], [500.0, 82.0], [500.0, 142.0], [474.0, 142.0]], [[453.0, 82.0], [477.0, 82.0], [477.0, 220.0], [453.0, 220.0]], [[432.0, 83.0], [450.0, 83.0], [448.0, 295.0], [431.0, 295.0]]], "lines": ["そして", "結局、片山君は", "どうなったかというと．．．"]}, {"box": [709, 363, 735, 410], "vertical": true, "font_size": 26, "lines_coords": [[[709.0, 363.0], [735.0, 363.0], [735.0, 410.0], [709.0, 410.0]]], "lines": ["あ．．．"]}, {"box": [97, 305, 163, 411], "vertical": true, "font_size": 19, "lines_coords": [[[141.0, 305.0], [162.0, 305.0], [160.0, 389.0], [139.0, 389.0]], [[118.0, 