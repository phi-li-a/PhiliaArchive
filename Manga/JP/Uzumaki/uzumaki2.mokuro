": [84, 848, 114, 902], "vertical": true, "font_size": 30, "lines_coords": [[[84.0, 848.0], [114.0, 848.0], [114.0, 902.0], [84.0, 902.0]]], "lines": ["はあ"]}, {"box": [623, 1013, 720, 1089], "vertical": true, "font_size": 23, "lines_coords": [[[696.0, 1014.0], [720.0, 1014.0], [720.0, 1075.0], [696.0, 1075.0]], [[674.0, 1017.0], [695.0, 1017.0], [695.0, 1089.0], [674.0, 1089.0]], [[647.0, 1013.0], [674.0, 1013.0], [674.0, 1058.0], [647.0, 1058.0]], [[623.0, 1016.0], [644.0, 1014.0], [647.0, 1079.0], [626.0, 1080.0]]], "lines": ["火傷を", "負ったの", "よ．．．", "私もよ。"]}, {"box": [398, 894, 430, 948], "vertical": true, "font_size": 32, "lines_coords": [[[398.0, 894.0], [430.0, 894.0], [430.0, 948.0], [398.0, 948.0]]], "lines": ["はあ"]}, {"box": [468, 998, 538, 1098], "vertical": true, "font_size": 24, "lines_coords": [[[509.0, 998.0], [538.0, 998.0], [538.0, 1045.0], [509.0, 1045.0]], [[488.0, 1000.0], [514.0, 1000.0], [514.0, 1062.0], [488.0, 1062.0]], [[468.0, 1001.0], [485.0, 1001.0], [485.0, 1096.0], [468.0, 1096.0]]], "lines": ["早く", "帰って", "手当てを．．．"]}], "img_path": "104.jpg"}, {"version": "0.1.7", "img_width": 840, "img_height": 1204, "blocks": [{"box": [661, 104, 755, 223], "vertical": true, "font_size": 22, "lines_coords": [[[728.0, 104.0], [755.0, 104.0], [755.0, 154.0], [728.0, 154.0]], [[708.0, 106.0], [728.0, 106.0], [728.0, 223.0], [708.0, 223.0]], [[683.0, 105.0], [703.0, 105.0], [705.0, 203.0], [685.0, 203.0]], [[661.0, 108.0], [681.0, 108.0], [681.0, 188.0], [661.0, 188.0]]], "lines": ["翌日、", "少年ひとりを", "各む６体の", "地区本地ダイカ"]}, {"box": [115, 106, 160, 249], "vertical": true, "font_size": 19, "lines_coords": [[[138.0, 106.0], [158.0, 106.0], [158.0, 224.0], [138.0, 224.0]], [[115.0, 108.0], [132.0, 108.0], [134.0, 244.0], [116.0, 244.0]]], "lines": ["灯台の中から", "発見されました。"]}, {"box": [671, 921, 741, 1096], "vertical": true, "font_size": 22, "lines_coords": [[[717.0, 921.0], [741.0, 921.0], [741.0, 1040.0], [717.0, 1040.0]], [[694.0, 921.0], [717.0, 921.0], [717.0, 1040.0], [694.0, 1040.0]], [[671.0, 922.0], [690.0, 922.0], [692.0, 1094.0], [674.0, 1094.0]]], "lines": ["灯台は未だに", "禍々しい光を", "放ち続けています："]}, {"box": [122, 908, 191, 1062], "vertical": true, "font_size": 19, "lines_coords": [[[171.0, 912.0], [188.0, 912.0], [188.0, 1042.0], [171.0, 1042.0]], [[144.0, 910.0], [164.0, 910.0], [164.0, 1062.0], [144.0, 1062.0]], [[122.0, 908.0], [142.0, 908.0], [142.0, 1006.0], [122.0, 1006.0]]], "lines": ["この黒い灯台は", "近々とり壊される", "予定です．．．"]}], "img_path": "105.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [116, 0, 143, 155], "vertical": true, "font_size": 17, "lines_coords": [[[121.0, 56.0], [138.0, 56.0], [138.0, 153.0], [121.0, 153.0]]], "lines": ["．．．第１話"]}, {"box": [117, 227, 141, 333], "vertical": true, "font_size": 24, "lines_coords": [[[117.0, 227.0], [141.0, 227.0], [141.0, 333.0], [117.0, 333.0]]], "lines": ["かばしら"]}], "img_path": "106.jpg"}, {"version": "0.1.7", "img_width": 834, "img_height": 1200, "blocks": [{"box": [663, 130, 730, 233], "vertical": true, "font_size": 19, "lines_coords": [[[709.0, 130.0], [729.0, 130.0], [729.0, 226.0], [709.0, 226.0]], [[685.0, 130.0], [705.0, 130.0], [705.0, 227.0], [685.0, 227.0]], [[664.0, 131.0], [680.0, 131.0], [680.0, 233.0], [664.0, 233.0]]], "lines": ["今年の夏は", "異常に文が", "多いのです。"]}, {"box": [206, 517, 269, 530], "vertical": false, "font_size": 13, "lines_coords": [[[206.0, 517.0], [269.0, 517.0], [269.0, 530.0], [206.0, 530.0]]], "lines": ["五島桐絵"]}, {"box": [645, 648, 763, 785], "vertical": true, "font_size": 21, "lines_coords": [[[732.0, 648.0], [763.0, 648.0], [763.0, 696.0], [732.0, 696.0]], [[714.0, 650.0], [734.0, 650.0], [734.0, 785.0], [714.0, 785.0]], [[692.0, 651.0], [708.0, 651.0], [708.0, 764.0], [692.0, 764.0]], [[665.0, 649.0], [689.0, 649.0], [689.0, 710.0], [665.0, 710.0]], [[645.0, 651.0], [661.0, 651.0], [661.0, 752.0], [645.0, 752.0]]], "lines": ["私は", "その夏の半分を", "病院で過ごす", "はめに", "なりました。"]}, {"box": [374, 641, 472, 785], "vertical": true, "font_size": 20, "lines_coords": [[[452.0, 643.0], [472.0, 643.0], [472.0, 757.0], [452.0, 757.0]], [[427.0, 643.0], [447.0, 643.0], [447.0, 760.0], [427.0, 760.0]], [[405.0, 641.0], [425.0, 641.0], [422.0, 740.0], [402.0, 740.0]], [[374.0, 641.0], [394.0, 641.0], [397.0, 785.0], [377.0, 785.0]]], "lines": ["灯台で負った", "火傷と打撲が", "思ったより", "酷かったのです。"]}, {"box": [193, 972, 307, 1091], "vertical": true, "font_size": 21, "lines_coords": [[[285.0, 975.0], [305.0, 975.0], [305.0, 1071.0], [285.0, 1071.0]], [[260.0, 972.0], [284.0, 972.0], [284.0, 1091.0], [260.0, 1091.0]], [[238.0, 973.0], [260.0, 973.0], [260.0, 1071.0], [238.0, 1071.0]], [[214.0, 975.0], [235.0, 975.0], [235.0, 1052.0], [214.0, 1052.0]], [[193.0, 977.0], [209.0, 977.0], [209.0, 1074.0], [193.0, 1074.0]]], "lines": ["弟の満男は", "私よりケガが", "軽く、先日", "退院して", "いきました。"]}], "img_path": "107.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [658, 92, 710, 154], "vertical": true, "font_size": 29, "lines_coords": [[[678.0, 92.0], [710.0, 92.0], [710.0, 154.0], [678.0, 154.0]], [[658.0, 92.0], [684.0, 92.0], [684.0, 153.0], [658.0, 153.0]]], "lines": ["いやだ", "な．．．"]}, {"box": [417, 304, 465, 366], "vertical": true, "font_size": 26, "lines_coords": [[[438.0, 304.0], [465.0, 304.0], [465.0, 349.0], [438.0, 349.0]], [[417.0, 305.0], [441.0, 305.0], [441.0, 366.0], [417.0, 366.0]]], "lines": ["また", "蚊．．．．．"]}, {"box": [668, 700, 713, 805], "vertical": true, "font_size": 20, "lines_coords": [[[692.0, 701.0], [712.0, 701.0], [712.0, 798.0], [692.0, 798.0]], [[670.0, 700.0], [690.0, 700.0], [688.0, 805.0], [668.0, 805.0]]], "lines": ["今年の蚊は", "変なのです。"]}, {"box": [327, 691, 399, 810], "vertical": true, "font_size": 24, "lines_coords": [[[368.0, 691.0], [399.0, 691.0], [399.0, 739.0], [368.0, 739.0]], [[350.0, 694.0], [370.0, 694.0], [370.0, 810.0], [350.0, 810.0]], [[327.0, 696.0], [347.0, 696.0], [347.0, 799.0], [327.0, 799.0]]], "lines": ["時々", "うずまき状に", "飛ぶのです。"]}, {"box": [146, 603, 162, 647], "vertical": true, "font_size": 16, "lines_coords": [[[146.0, 603.0], [162.0, 603.0], [162.0, 647.0], [146.0, 647.0]]], "lines": ["．．．．．"]}, {"box": [85, 691, 176, 891], "vertical": true, "font_size": 22, "lines_coords": [[[154.0, 691.0], [174.0, 691.0], [175.0, 847.0], [155.0, 847.0]], [[130.0, 692.0], [153.0, 692.0], [153.0, 850.0], [130.0, 850.0]], [[106.0, 691.0], [130.0, 691.0], [127.0, 828.0], [104.0, 828.0]], [[85.0, 692.0], [105.0, 692.0], [105.0, 891.0], [85.0, 891.0]]], "lines": ["それを見ていると", "頭がボーッとして、", "気がつくともう", "刺されたあとなのです。"]}], "img_path": "108.jpg"}, {"version": "0.1.7", "img_width": 834, "img_height": 1200, "blocks": [{"box": [687, 106, 734, 242], "vertical": true, "font_size": 20, "lines_coords": [[[709.0, 108.0], [729.0, 107.0], [734.0, 214.0], [714.0, 215.0]], [[687.0, 106.0], [707.0, 106.0], [709.0, 240.0], [689.0, 240.0]]], "lines": ["桐絵ちゃん、", "どう？調子は。"]}, {"box": [491, 105, 559, 227], "vertical": true, "font_size": 20, "lines_coords": [[[538.0, 105.0], [558.0, 105.0], [556.0, 221.0], [536.0, 221.0]], [[515.0, 106.0], [535.0, 106.0], [535.0, 227.0], [515.0, 227.0]], [[491.0, 106.0], [511.0, 106.0], [511.0, 205.0], [491.0, 205.0]]], "lines": ["うん．．．だいぶ", "よくなったわ、", "志穂ちゃん"]}, {"box": [117, 104, 160, 258], "vertical": true, "font_size": 18, "lines_coords": [[[139.0, 104.0], [159.0, 104.0], [159.0, 257.0], [139.0, 257.0]], [[118.0, 106.0], [134.0, 106.0], [134.0, 239.0], [118.0, 239.0]]], "lines": ["でも、まだ歩くと", "足が痛くて．．．"]}, {"box": [714, 469, 764, 534], "vertical": true, "font_size": 28, "lines_coords": [[[739.0, 472.0], [764.0, 472.0], [764.0, 534.0], [739.0, 534.0]], [[714.0, 469.0], [746.0, 469.0], [746.0, 517.0], [714.0, 517.0]]], "lines": ["それに", "蚊！！"]}, {"box": [600, 478, 671, 641], "vertical": true, "font_size": 19, "lines_coords": [[[651.0, 479.0], [671.0, 479.0], [668.0, 578.0], [648.0, 578.0]], [[627.0, 480.0], [645.0, 480.0], [643.0, 576.0], [625.0, 576.0]], [[603.0, 478.0], [623.0, 478.0], [620.0, 641.0], [600.0, 641.0]]], "lines": ["火傷の上を", "刺されると", "たまんないのよね。"]}, {"box": [686, 836, 762, 903], "vertical": true, "font_size": 31, "lines_coords": [[[733.0, 837.0], [762.0, 837.0], [762.0, 903.0], [733.0, 903.0]], [[708.0, 836.0], [740.0, 836.0], [740.0, 884.0], [708.0, 884.0]], [[686.0, 836.0], [718.0, 836.0], [718.0, 892.0], [686.0, 892.0]]], "lines": ["ねえ！", "あれ", "見て。"]}, {"box": [479, 685, 525, 783], "vertical": true, "font_size": 20, "lines_coords": [[[504.0, 685.0], [525.0, 686.0], [522.0, 783.0], [501.0, 782.0]], [[479.0, 687.0], [498.0, 687.0], [498.0, 765.0], [479.0, 765.0]]], "lines": ["えっ．．．あ．．", "何あれ？"]}, {"box": [115, 939, 191, 1100], "vertical": true, "font_size": 20, "lines_coords": [[[169.0, 939.0], [189.0, 939.0], [189.0, 1055.0], [169.0, 1055.0]], [[141.0, 941.0], [161.0, 941.0], [161.0, 1099.0], [141.0, 1099.0]], [[115.0, 939.0], [135.0, 939.0], [138.0, 1041.0], [118.0, 1041.0]]], "lines": ["あれって確か", "蚊柱っていうのよ、", "桐絵ちゃん。"]}], "img_path": "109.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [688, 119, 713, 182], "vertical": true, "font_size": 25, "lines_coords": [[[688.0, 119.0], [713.0, 119.0], [713.0, 182.0], [688.0, 182.0]]], "lines": ["蚊柱？"]}, {"box": [310, 97, 353, 219], "vertical": true, "font_size": 18, "lines_coords": [[[332.0, 97.0], [352.0, 97.0], [352.0, 174.0], [332.0, 174.0]], [[310.0, 97.0], [327.0, 97.0], [327.0, 217.0], [310.0, 217.0]]], "lines": ["最近よく", "見かけるわよ。"]}, {"box": [73, 104, 92, 226], "vertical": true, "font_size": 16, "lines_coords": [[[73.0, 104.0], [89.0, 104.0], [89.0, 222.0], [73.0, 222.0]]], "lines": ["異常発生よね、"]}, {"box": [398, 248, 472, 545], "vertical": true, "font_size": 20, "lines_coords": [[[451.0, 249.0], [471.0, 249.0], [471.0, 479.0], [451.0, 479.0]], [[424.0, 250.0], [444.0, 250.0], [444.0, 537.0], [424.0, 537.0]], [[398.0, 249.0], [418.0, 249.0], [418.0, 544.0], [398.0, 544.0]]], "lines": ["そうよ。蚊が群れになって", "飛んで柱のように見える現象よ．．．", "交尾の前のオスの群れなんだって。"]}, {"box": [286, 322, 353, 479], "vertical": true, "font_size": 21, "lines_coords": [[[335.0, 326.0], [351.0, 326.0], [351.0, 478.0], [335.0, 478.0]], [[304.0, 322.0], [332.0, 322.0], [332.0, 369.0], [304.0, 369.0]], [[286.0, 324.0], [305.0, 324.0], [305.0, 479.0], [286.0, 479.0]]], "lines": ["でも志穂ちゃん．．．", "あれ", "柱っていうより．．．"]}, {"box": [66, 326, 88, 461], "vertical": true, "font_size": 18, "lines_coords": [[[67.0, 326.0], [85.0, 326.0], [84.0, 460.0], [66.0, 460.0]]], "lines": ["らせん状よね．．．"]}, {"box": [656, 587, 720, 673], "vertical": true, "font_size": 25, "lines_coords": [[[675.0, 587.0], [705.0, 587.0], [705.0, 653.0], [675.0, 653.0]], [[656.0, 590.0], [676.0, 590.0], [676.0, 672.0], [656.0, 672.0]]], "lines": ["あれも", "やっぱり、"]}, {"box": [651, 767, 718, 909], "vertical": true, "font_size": 19, "lines_coords": [[[697.0, 767.0], [717.0, 767.0], [718.0, 908.0], [698.0, 908.0]], [[674.0, 767.0], [694.0, 767.0], [694.0, 866.0], [674.0, 866.0]], [[651.0, 768.0], [668.0, 768.0], [668.0, 866.0], [651.0, 866.0]]], "lines": ["さあ桐絵ちゃん、", "もう病室に", "戻ろうか．．．"]}, {"box": [481, 752, 502, 819], "vertical": true, "font_size": 21, "lines_coords": [[[481.0, 752.0], [502.0, 752.0], [502.0, 817.0], [481.0, 817.0]]], "lines": ["そうね。"]}, {"box": [70, 589, 139, 686], "vertical": true, "font_size": 20, "lines_coords": [[[118.0, 589.0], [138.0, 589.0], [138.0, 685.0], [118.0, 685.0]], [[94.0, 590.0], [114.0, 590.0], [114.0, 685.0], [94.0, 685.0]], [[70.0, 591.0], [90.0, 591.0], [90.0, 686.0], [70.0, 686.0]]], "lines": ["うずまきの", "呪いのせい", "かしら．．．！？"]}, {"box": [177, 744, 208, 827], "vertical": true, "font_size": 29, "lines_coords": [[[177.0, 745.0], [206.0, 744.0], [208.0, 826.0], [179.0, 827.0]]], "lines": ["あっ！？"]}], "img_path": "110.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [596, 740, 735, 857], "vertical": true, "font_size": 20, "lines_coords": [[[713.0, 742.0], [735.0, 742.0], [735.0, 855.0], [713.0, 855.0]], [[685.0, 741.0], [711.0, 740.0], [713.0, 806.0], [688.0, 807.0]], [[667.0, 744.0], [686.0, 744.0], [686.0, 857.0], [667.0, 857.0]], [[643.0, 744.0], [663.0, 744.0], [663.0, 841.0], [643.0, 841.0]], [[621.0, 745.0], [637.0, 745.0], [637.0, 839.0], [621.0, 839.0]], [[596.0, 745.0], [616.0, 745.0], [616.0, 821.0], [596.0, 821.0]]], "lines": ["その変死体の", "発見は、", "今回の事件の", "はじまりを", "告げるもの", "でした．．"]}], "img_path": "111.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [640, 469, 732, 591], "vertical": true, "font_size": 21, "lines_coords": [[[711.0, 471.0], [731.0, 471.0], [731.0, 585.0], [711.0, 585.0]], [[686.0, 471.0], [706.0, 471.0], [706.0, 589.0], [686.0, 589.0]], [[660.0, 469.0], [688.0, 469.0], [688.0, 514.0], [660.0, 514.0]], [[641.0, 469.0], [658.0, 469.0], [657.0, 584.0], [640.0, 584.0]]], "lines": ["変死体騒ぎで", "騒々しいのに、", "一体", "今度は何だ？"]}, {"box": [478, 454, 546, 553], "vertical": true, "font_size": 23, "lines_coords": [[[525.0, 457.0], [545.0, 457.0], [545.0, 553.0], [525.0, 553.0]], [[497.0, 454.0], [526.0, 454.0], [526.0, 519.0], [497.0, 519.0]], [[478.0, 457.0], [498.0, 457.0], [498.0, 542.0], [478.0, 542.0]]], "lines": ["あれはまた", "妊婦の", "ようだぞ。"]}, {"box": [375, 448, 443, 542], "vertical": true, "font_size": 21, "lines_coords": [[[420.0, 451.0], [440.0, 451.0], [440.0, 542.0], [420.0, 542.0]], [[398.0, 448.0], [419.0, 448.0], [417.0, 529.0], [396.0, 529.0]], [[375.0, 448.0], [396.0, 448.0], [396.0, 471.0], [375.0, 471.0]]], "lines": ["何だって？", "またか．．．", "？"]}, {"box": [33, 480, 151, 673], "vertical": true, "font_size": 21, "lines_coords": [[[126.0, 481.0], [151.0, 481.0], [151.0, 543.0], [126.0, 543.0]], [[103.0, 480.0], [126.0, 480.0], [127.0, 662.0], [104.0, 662.0]], [[80.0, 481.0], [100.0, 481.0], [98.0, 673.0], [78.0, 673.0]], [[57.0, 482.0], [77.0, 482.0], [76.0, 655.0], [56.0, 655.0]], [[35.0, 481.0], [52.0, 481.0], [51.0, 598.0], [33.0, 598.0]]], "lines": ["何でも", "大量の蚊に刺されて、", "気分を悪くした妊婦が", "もう十人以上も入院", "してるそうだ"]}, {"box": [228, 765, 331, 846], "vertical": true, "font_size": 24, "lines_coords": [[[298.0, 766.0], [329.0, 765.0], [331.0, 829.0], [301.0, 830.0]], [[282.0, 768.0], [303.0, 768.0], [303.0, 844.0], [282.0, 844.0]], [[254.0, 768.0], [274.0, 768.0], [274.0, 846.0], [254.0, 846.0]], [[228.0, 767.0], [253.0, 767.0], [253.0, 830.0], [228.0, 830.0]]], "lines": ["あれは", "いとこの", "恵子さん", "だわ！！"]}, {"box": [688, 1018, 717, 1101], "vertical": true, "font_size": 29, "lines_coords": [[[688.0, 1018.0], [717.0, 1018.0], [717.0, 1101.0], [688.0, 1101.0]]], "lines": ["あっ！？"]}], "img_path": "112.jpg"}, {"version": "0.1.7", "img_width": 834, "img_height": 1200, "blocks": [{"box": [632, 138, 762, 194], "vertical": false, "font_size": 20, "lines_coords": [[[638.0, 138.0], [762.0, 175.0], [756.0, 194.0], [632.0, 157.0]]], "lines": ["産婦人科病棟"]}, {"box": [637, 241, 685, 304], "vertical": true, "font_size": 25, "lines_coords": [[[659.0, 242.0], [685.0, 242.0], [685.0, 304.0], [659.0, 304.0]], [[637.0, 241.0], [661.0, 241.0], [661.0, 304.0], [637.0, 304.0]]], "lines": ["うっ．．．", "うっ．．．"]}, {"box": [121, 99, 142, 159], "vertical": true, "font_size": 21, "lines_coords": [[[121.0, 99.0], [142.0, 99.0], [142.0, 159.0], [121.0, 159.0]]], "lines": ["うう．．．"]}, {"box": [667, 440, 758, 526], "vertical": true, "font_size": 24, "lines_coords": [[[737.0, 442.0], [757.0, 442.0], [757.0, 523.0], [737.0, 523.0]], [[709.0, 441.0], [739.0, 441.0], [739.0, 506.0], [709.0, 506.0]], [[687.0, 440.0], [714.0, 440.0], [714.0, 489.0], [687.0, 489.0]], [[667.0, 444.0], [687.0, 444.0], [687.0, 522.0], [667.0, 522.0]]], "lines": ["恵子さん", "具合は", "どう", "ですか？"]}, {"box": [531, 312, 582, 396], "vertical": true, "font_size": 24, "lines_coords": [[[552.0, 315.0], [578.0, 312.0], [582.0, 357.0], [556.0, 359.0]], [[531.0, 316.0], [552.0, 316.0], [555.0, 396.0], [534.0, 396.0]]], "lines": ["うっ", "ううっ．．．"]}, {"box": [282, 337, 306, 399], "vertical": true, "font_size": 24, "lines_coords": [[[282.0, 337.0], [306.0, 337.0], [306.0, 399.0], [282.0, 399.0]]], "lines": ["うっ．．．"]}, {"box": [324, 439, 392, 510], "vertical": true, "