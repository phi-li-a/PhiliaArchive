2.0, 417.0], [432.0, 550.0], [412.0, 550.0]]], "lines": ["恵子さんが", "いるんですか！？"]}, {"box": [331, 446, 378, 562], "vertical": true, "font_size": 22, "lines_coords": [[[358.0, 450.0], [378.0, 450.0], [378.0, 562.0], [358.0, 562.0]], [[331.0, 446.0], [359.0, 446.0], [359.0, 492.0], [331.0, 492.0]]], "lines": ["マキオちゃん", "は！？"]}, {"box": [745, 618, 760, 679], "vertical": true, "font_size": 15, "lines_coords": [[[745.0, 618.0], [760.0, 618.0], [760.0, 679.0], [745.0, 679.0]]], "lines": ["．．．"]}, {"box": [685, 816, 755, 929], "vertical": true, "font_size": 20, "lines_coords": [[[735.0, 819.0], [755.0, 819.0], [755.0, 912.0], [735.0, 912.0]], [[709.0, 816.0], [729.0, 816.0], [729.0, 929.0], [709.0, 929.0]], [[685.0, 816.0], [706.0, 816.0], [706.0, 878.0], [685.0, 878.0]]], "lines": ["．．．赤ん坊は", "その可愛さが", "武器だ"]}, {"box": [435, 608, 479, 747], "vertical": true, "font_size": 19, "lines_coords": [[[459.0, 608.0], [479.0, 608.0], [479.0, 684.0], [459.0, 684.0]], [[436.0, 608.0], [454.0, 608.0], [453.0, 744.0], [435.0, 744.0]]], "lines": ["赤ん坊は", "可愛いものだな。"]}, {"box": [112, 631, 129, 661], "vertical": true, "font_size": 17, "lines_coords": [[[112.0, 631.0], [129.0, 631.0], [129.0, 661.0], [112.0, 661.0]]], "lines": ["？"]}, {"box": [147, 801, 243, 938], "vertical": true, "font_size": 21, "lines_coords": [[[222.0, 805.0], [243.0, 805.0], [243.0, 882.0], [222.0, 882.0]], [[199.0, 803.0], [220.0, 803.0], [221.0, 938.0], [200.0, 938.0]], [[174.0, 803.0], [195.0, 803.0], [195.0, 900.0], [174.0, 900.0]], [[147.0, 801.0], [178.0, 801.0], [178.0, 858.0], [147.0, 858.0]]], "lines": ["可愛さに", "よって、大人を", "意のままに", "操る。"]}, {"box": [103, 964, 193, 1103], "vertical": true, "font_size": 21, "lines_coords": [[[172.0, 964.0], [193.0, 964.0], [193.0, 1061.0], [172.0, 1061.0]], [[148.0, 964.0], [169.0, 964.0], [169.0, 1045.0], [148.0, 1045.0]], [[126.0, 965.0], [142.0, 965.0], [142.0, 1095.0], [126.0, 1095.0]], [[103.0, 965.0], [119.0, 965.0], [119.0, 1103.0], [103.0, 1103.0]]], "lines": ["大人の助け", "なしでは、", "赤ん坊は生きて", "いけないからだ。"]}], "img_path": "159.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [640, 117, 711, 299], "vertical": true, "font_size": 21, "lines_coords": [[[690.0, 117.0], [711.0, 117.0], [709.0, 253.0], [688.0, 253.0]], [[665.0, 118.0], [685.0, 118.0], [685.0, 273.0], [665.0, 273.0]], [[642.0, 117.0], [663.0, 117.0], [661.0, 298.0], [640.0, 298.0]]], "lines": ["しかし、やがて", "成長と共に子供は", "自立していくものだ。"]}, {"box": [262, 108, 379, 303], "vertical": true, "font_size": 20, "lines_coords": [[[355.0, 108.0], [375.0, 108.0], [377.0, 264.0], [357.0, 264.0]], [[331.0, 110.0], [351.0, 110.0], [351.0, 226.0], [331.0, 226.0]], [[307.0, 108.0], [328.0, 108.0], [329.0, 290.0], [308.0, 290.0]], [[283.0, 111.0], [303.0, 111.0], [303.0, 303.0], [283.0, 303.0]], [[262.0, 111.0], [279.0, 111.0], [279.0, 233.0], [262.0, 233.0]]], "lines": ["ところが彼らは．．", "自立どころか", "永久に赤ん坊．．．いや、", "胎児のままでいようと", "しているのだ。"]}, {"box": [64, 93, 87, 210], "vertical": true, "font_size": 20, "lines_coords": [[[64.0, 93.0], [84.0, 93.0], [86.0, 210.0], [66.0, 210.0]]], "lines": ["その証拠に．．．"]}, {"box": [662, 480, 715, 567], "vertical": true, "font_size": 21, "lines_coords": [[[688.0, 480.0], [715.0, 481.0], [712.0, 542.0], [685.0, 541.0]], [[662.0, 481.0], [683.0, 481.0], [683.0, 567.0], [662.0, 567.0]]], "lines": ["彼らの", "臍の緒は、"]}, {"box": [520, 489, 611, 646], "vertical": true, "font_size": 21, "lines_coords": [[[590.0, 489.0], [611.0, 489.0], [608.0, 645.0], [587.0, 645.0]], [[566.0, 489.0], [586.0, 489.0], [586.0, 632.0], [566.0, 632.0]], [[540.0, 489.0], [563.0, 489.0], [563.0, 646.0], [540.0, 646.0]], [[520.0, 492.0], [536.0, 492.0], [536.0, 631.0], [520.0, 631.0]]], "lines": ["切っても切ったも", "また伸びてきて、", "やがて胎盤までも", "形成してしまう。"]}, {"box": [405, 476, 474, 632], "vertical": true, "font_size": 23, "lines_coords": [[[452.0, 480.0], [472.0, 480.0], [472.0, 614.0], [452.0, 614.0]], [[424.0, 476.0], [453.0, 476.0], [453.0, 541.0], [424.0, 541.0]], [[405.0, 479.0], [425.0, 479.0], [425.0, 632.0], [405.0, 632.0]]], "lines": ["臍の緒と胎盤．．．", "それは", "子宮退行の象徴！"]}, {"box": [67, 476, 138, 669], "vertical": true, "font_size": 21, "lines_coords": [[[113.0, 476.0], [138.0, 476.0], [138.0, 539.0], [113.0, 539.0]], [[93.0, 480.0], [110.0, 480.0], [110.0, 669.0], [93.0, 669.0]], [[67.0, 479.0], [87.0, 479.0], [87.0, 632.0], [67.0, 632.0]]], "lines": ["彼らは", "母親の子宮に戻る事を", "望んでいるのだ！！"]}, {"box": [423, 840, 461, 898], "vertical": true, "font_size": 21, "lines_coords": [[[440.0, 841.0], [461.0, 841.0], [461.0, 898.0], [440.0, 898.0]]], "lines": ["．．．先生"]}, {"box": [205, 843, 226, 911], "vertical": true, "font_size": 21, "lines_coords": [[[205.0, 843.0], [226.0, 843.0], [226.0, 911.0], [205.0, 911.0]]], "lines": ["そうだ。"]}, {"box": [257, 841, 323, 1016], "vertical": true, "font_size": 18, "lines_coords": [[[304.0, 843.0], [321.0, 843.0], [321.0, 958.0], [304.0, 958.0]], [[279.0, 841.0], [298.0, 841.0], [297.0, 1016.0], [277.0, 1016.0]], [[257.0, 843.0], [274.0, 843.0], [274.0, 938.0], [257.0, 938.0]]], "lines": ["もしかして．．．", "このキノコのような", "ものは．．．？"]}, {"box": [62, 835, 109, 979], "vertical": true, "font_size": 21, "lines_coords": [[[84.0, 835.0], [109.0, 835.0], [109.0, 897.0], [84.0, 897.0]], [[63.0, 837.0], [80.0, 837.0], [79.0, 971.0], [62.0, 971.0]]], "lines": ["それは", "キノコではない"]}], "img_path": "160.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [650, 114, 743, 293], "vertical": true, "font_size": 19, "lines_coords": [[[723.0, 114.0], [743.0, 114.0], [742.0, 270.0], [722.0, 270.0]], [[701.0, 117.0], [717.0, 117.0], [717.0, 289.0], [701.0, 289.0]], [[675.0, 114.0], [695.0, 114.0], [694.0, 287.0], [674.0, 287.0]], [[650.0, 114.0], [670.0, 114.0], [670.0, 257.0], [650.0, 257.0]]], "lines": ["この部屋で彼らを", "分娩しているうちに", "自然発生するように", "なってしまった。"]}, {"box": [141, 98, 213, 251], "vertical": true, "font_size": 23, "lines_coords": [[[189.0, 98.0], [213.0, 98.0], [213.0, 216.0], [189.0, 216.0]], [[166.0, 98.0], [186.0, 98.0], [188.0, 251.0], [168.0, 251.0]], [[141.0, 99.0], [166.0, 99.0], [166.0, 183.0], [141.0, 183.0]]], "lines": ["捨てた胎盤が", "繁殖していったに", "違いない。"]}, {"box": [250, 393, 317, 481], "vertical": true, "font_size": 25, "lines_coords": [[[296.0, 396.0], [317.0, 396.0], [317.0, 472.0], [296.0, 472.0]], [[268.0, 393.0], [300.0, 393.0], [300.0, 458.0], [268.0, 458.0]], [[250.0, 396.0], [271.0, 396.0], [271.0, 481.0], [250.0, 481.0]]], "lines": ["たまらず", "食べて", "しまった。"]}, {"box": [354, 566, 381, 629], "vertical": true, "font_size": 25, "lines_coords": [[[354.0, 567.0], [378.0, 566.0], [381.0, 628.0], [356.0, 629.0]]], "lines": ["私は："]}, {"box": [104, 448, 194, 602], "vertical": true, "font_size": 20, "lines_coords": [[[173.0, 450.0], [193.0, 450.0], [193.0, 547.0], [173.0, 547.0]], [[148.0, 448.0], [173.0, 448.0], [173.0, 512.0], [148.0, 512.0]], [[126.0, 450.0], [146.0, 450.0], [146.0, 602.0], [126.0, 602.0]], [[104.0, 451.0], [120.0, 451.0], [120.0, 566.0], [104.0, 566.0]]], "lines": ["この上なく", "美味！！", "しかも体中に力が", "わいてくる！！"]}, {"box": [711, 598, 758, 677], "vertical": true, "font_size": 24, "lines_coords": [[[731.0, 600.0], [758.0, 600.0], [758.0, 659.0], [731.0, 659.0]], [[711.0, 598.0], [732.0, 598.0], [732.0, 677.0], [711.0, 677.0]]], "lines": ["それに", "しても．．．"]}, {"box": [526, 631, 570, 765], "vertical": true, "font_size": 17, "lines_coords": [[[552.0, 633.0], [568.0, 633.0], [568.0, 765.0], [552.0, 765.0]], [[527.0, 631.0], [545.0, 631.0], [543.0, 765.0], [526.0, 765.0]]], "lines": ["何という甘美な", "情景だろうか！！"]}, {"box": [209, 848, 264, 921], "vertical": true, "font_size": 27, "lines_coords": [[[236.0, 848.0], [264.0, 848.0], [264.0, 898.0], [236.0, 898.0]], [[209.0, 849.0], [235.0, 849.0], [235.0, 921.0], [209.0, 921.0]]], "lines": ["せ．．．", "先生！！"]}, {"box": [689, 851, 759, 1006], "vertical": true, "font_size": 20, "lines_coords": [[[737.0, 851.0], [758.0, 851.0], [759.0, 1006.0], [738.0, 1006.0]], [[712.0, 851.0], [732.0, 851.0], [735.0, 987.0], [715.0, 987.0]], [[689.0, 851.0], [709.0, 851.0], [709.0, 993.0], [689.0, 993.0]]], "lines": ["それも当然の事！！", "臍の緒と胎盤は", "生命の源なのだ。"]}, {"box": [457, 842, 547, 964], "vertical": true, "font_size": 20, "lines_coords": [[[526.0, 842.0], [547.0, 842.0], [547.0, 921.0], [526.0, 921.0]], [[501.0, 842.0], [525.0, 842.0], [525.0, 964.0], [501.0, 964.0]], [[479.0, 843.0], [499.0, 843.0], [499.0, 957.0], [479.0, 957.0]], [[457.0, 843.0], [473.0, 843.0], [473.0, 945.0], [457.0, 945.0]]], "lines": ["病人達に", "食べさせれば、", "必ずや元気に", "なるだろう。"]}], "img_path": "161.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [681, 92, 724, 207], "vertical": true, "font_size": 18, "lines_coords": [[[703.0, 92.0], [724.0, 92.0], [724.0, 171.0], [703.0, 171.0]], [[682.0, 93.0], [698.0, 93.0], [698.0, 207.0], [682.0, 207.0]]], "lines": ["先生．．．", "恵子さんは！？"]}, {"box": [77, 92, 169, 197], "vertical": true, "font_size": 21, "lines_coords": [[[145.0, 92.0], [169.0, 92.0], [169.0, 154.0], [145.0, 154.0]], [[124.0, 93.0], [144.0, 93.0], [144.0, 187.0], [124.0, 187.0]], [[100.0, 93.0], [120.0, 93.0], [120.0, 171.0], [100.0, 171.0]], [[77.0, 93.0], [97.0, 93.0], [97.0, 196.0], [77.0, 196.0]]], "lines": ["ああ．．．", "このドアの", "向こうに", "親子はいる。"]}, {"box": [648, 483, 718, 656], "vertical": true, "font_size": 22, "lines_coords": [[[692.0, 483.0], [718.0, 483.0], [718.0, 564.0], [692.0, 564.0]], [[671.0, 485.0], [691.0, 485.0], [691.0, 600.0], [671.0, 600.0]], [[648.0, 485.0], [668.0, 485.0], [668.0, 656.0], [648.0, 656.0]]], "lines": ["．．．一体．．．", "恵子さん達に", "何をしたんですか！？"]}, {"box": [362, 491, 383, 663], "vertical": true, "font_size": 17, "lines_coords": [[[364.0, 492.0], [381.0, 492.0], [381.0, 662.0], [364.0, 662.0]]], "lines": ["さっきの叫び声は！？"]}, {"box": [305, 500, 325, 622], "vertical": true, "font_size": 20, "lines_coords": [[[305.0, 500.0], [325.0, 500.0], [325.0, 619.0], [305.0, 619.0]]], "lines": ["心配いらない。"]}, {"box": [219, 278, 287, 452], "vertical": true, "font_size": 20, "lines_coords": [[[266.0, 278.0], [286.0, 278.0], [286.0, 452.0], [266.0, 452.0]], [[240.0, 280.0], [261.0, 280.0], [263.0, 377.0], [242.0, 377.0]], [[219.0, 280.0], [239.0, 280.0], [239.0, 397.0], [219.0, 397.0]]], "lines": ["そのドアの向こうに", "いるんじゃ", "ないですか！？"]}, {"box": [65, 487, 87, 629], "vertical": true, "font_size": 20, "lines_coords": [[[65.0, 487.0], [85.0, 487.0], [87.0, 629.0], [67.0, 629.0]]], "lines": ["手術は終わった。"]}, {"box": [701, 733, 721, 846], "vertical": true, "font_size": 19, "lines_coords": [[[701.0, 733.0], [720.0, 733.0], [720.0, 846.0], [701.0, 846.0]]], "lines": ["手術って．．．？"]}, {"box": [70, 726, 99, 809], "vertical": true, "font_size": 29, "lines_coords": [[[70.0, 726.0], [99.0, 726.0], [99.0, 809.0], [70.0, 809.0]]], "lines": ["あっ！？"]}, {"box": [293, 867, 339, 966], "vertical": true, "font_size": 24, "lines_coords": [[[310.0, 867.0], [339.0, 867.0], [339.0, 931.0], [310.0, 931.0]], [[293.0, 869.0], [313.0, 869.0], [313.0, 966.0], [293.0, 966.0]]], "lines": ["どいて", "ください！！"]}], "img_path": "162.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [740, 705, 774, 760], "vertical": true, "font_size": 32, "lines_coords": [[[743.0, 705.0], [774.0, 706.0], [772.0, 760.0], [740.0, 759.0]]], "lines": ["はあ"]}, {"box": [472, 701, 504, 755], "vertical": true, "font_size": 32, "lines_coords": [[[472.0, 701.0], [504.0, 701.0], [504.0, 755.0], [472.0, 755.0]]], "lines": ["はあ"]}, {"box": [79, 703, 110, 757], "vertical": true, "font_size": 31, "lines_coords": [[[79.0, 703.0], [110.0, 703.0], [110.0, 757.0], [79.0, 757.0]]], "lines": ["はあ"]}, {"box": [385, 1012, 417, 1065], "vertical": true, "font_size": 32, "lines_coords": [[[385.0, 1012.0], [417.0, 1012.0], [417.0, 1065.0], [385.0, 1065.0]]], "lines": ["はあ"]}], "img_path": "163.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [526, 43, 574, 106], "vertical": true, "font_size": 24, "lines_coords": [[[546.0, 43.0], [574.0, 43.0], [574.0, 90.0], [546.0, 90.0]], [[526.0, 46.0], [547.0, 46.0], [547.0, 106.0], [526.0, 106.0]]], "lines": ["恵子", "さん！！"]}, {"box": [317, 97, 338, 221], "vertical": true, "font_size": 20, "lines_coords": [[[317.0, 97.0], [337.0, 97.0], [337.0, 221.0], [317.0, 221.0]]], "lines": ["手術は成功だ。"]}, {"box": [53, 155, 100, 280], "vertical": true, "font_size": 20, "lines_coords": [[[77.0, 155.0], [97.0, 155.0], [99.0, 271.0], [79.0, 271.0]], [[53.0, 155.0], [72.0, 155.0], [76.0, 280.0], [57.0, 280.0]]], "lines": ["赤ん坊は再び", "子宮に戻った。"]}, {"box": [657, 349, 725, 588], "vertical": true, "font_size": 19, "lines_coords": [[[703.0, 350.0], [724.0, 350.0], [723.0, 581.0], [702.0, 581.0]], [[681.0, 349.0], [701.0, 349.0], [698.0, 566.0], [678.0, 566.0]], [[657.0, 350.0], [674.0, 350.0], [674.0, 588.0], [657.0, 588.0]]], "lines": ["赤ん坊が胎内で、これから", "どうなるのか．．．どう変化", "するのか私にはわからない。"]}, {"box": [330, 359, 423, 630], "vertical": true, "font_size": 20, "lines_coords": [[[400.0, 359.0], [420.0, 359.0], [423.0, 590.0], [403.0, 590.0]], [[377.0, 359.0], [398.0, 359.0], [399.0, 591.0], [378.0, 591.0]], [[354.0, 359.0], [373.0, 359.0], [376.0, 630.0], [356.0, 630.0]], [[330.0, 359.0], [350.0, 359.0], [350.0, 462.0], [330.0, 462.0]]], "lines": ["ひとつ言える事は、彼女は", "再び胎内の赤ん坊に栄養を", "与えなければならなくなった", "という事だ。"]}, {"box": [261, 506, 303, 604], "vertical": true, "font_size": 18, "lines_coords": [[[282.0, 506.0], [303.0, 506.0], [303.0, 587.0], [282.0, 587.0]], [[261.0, 507.0], [277.0, 507.0], [277.0, 603.0], [261.0, 603.0]]], "lines": ["先生．．．", "川本先生．．．"]}, {"box": [39, 487, 84, 605], "vertical": true, "font_size": 20, "lines_coords": [[[63.0, 488.0], [84.0, 488.0], [84.0, 585.0], [63.0, 585.0]], [[39.0, 487.0], [59.0, 487.0], [59.0, 604.0], [39.0, 604.0]]], "lines": ["血を．．．血を", "ちょうだい．．．"]}, {"box": [405, 679, 453, 778], "vertical": true, "font_size": 23, "lines_coords": [[[424.0, 679.0], [453.0, 679.0], [453.0, 744.0], [424.0, 744.0]], [[406.0, 684.0], [423.0, 684.0], [423.0, 778.0], [406.0, 778.0]]], "lines": ["なっ．．．", "何するの！？"]}, {"box": [422, 828, 442, 925], "vertical": true, "font