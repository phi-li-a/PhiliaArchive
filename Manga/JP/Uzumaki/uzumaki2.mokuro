font_size": 30, "lines_coords": [[[543.0, 854.0], [573.0, 854.0], [573.0, 928.0], [543.0, 928.0]]], "lines": ["キャ！！"]}, {"box": [264, 991, 289, 1064], "vertical": true, "font_size": 25, "lines_coords": [[[264.0, 991.0], [289.0, 991.0], [289.0, 1064.0], [264.0, 1064.0]]], "lines": ["あっ．．．"]}], "img_path": "176.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [717, 713, 769, 786], "vertical": true, "font_size": 26, "lines_coords": [[[739.0, 713.0], [769.0, 713.0], [769.0, 786.0], [739.0, 786.0]], [[717.0, 730.0], [739.0, 730.0], [739.0, 764.0], [717.0, 764.0]]], "lines": ["あれが", "．．．"]}, {"box": [114, 713, 168, 785], "vertical": true, "font_size": 25, "lines_coords": [[[139.0, 713.0], [168.0, 713.0], [168.0, 785.0], [139.0, 785.0]], [[114.0, 714.0], [135.0, 714.0], [135.0, 783.0], [114.0, 783.0]]], "lines": ["台風の", "目．．．！？"]}], "img_path": "177.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [704, 103, 730, 174], "vertical": true, "font_size": 26, "lines_coords": [[[704.0, 103.0], [730.0, 103.0], [730.0, 174.0], [704.0, 174.0]]], "lines": ["その夜"]}], "img_path": "178.jpg"}, {"version": "0.1.7", "img_width": 834, "img_height": 1200, "blocks": [{"box": [541, 113, 651, 135], "vertical": false, "font_size": 20, "lines_coords": [[[541.0, 113.0], [651.0, 116.0], [651.0, 135.0], [541.0, 133.0]]], "lines": ["チュンチェン"]}, {"box": [120, 441, 166, 503], "vertical": true, "font_size": 24, "lines_coords": [[[139.0, 442.0], [166.0, 442.0], [166.0, 503.0], [139.0, 503.0]], [[120.0, 441.0], [141.0, 441.0], [141.0, 502.0], [120.0, 502.0]]], "lines": ["ふあ～", "くく～～"]}, {"box": [507, 632, 529, 675], "vertical": true, "font_size": 22, "lines_coords": [[[507.0, 632.0], [529.0, 632.0], [529.0, 675.0], [507.0, 675.0]]], "lines": ["ん．．"]}, {"box": [489, 721, 507, 783], "vertical": true, "font_size": 18, "lines_coords": [[[489.0, 726.0], [507.0, 726.0], [507.0, 779.0], [489.0, 779.0]]], "lines": ["．．．ああ"]}, {"box": [94, 776,