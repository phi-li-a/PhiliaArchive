{"box": [73, 751, 192, 888], "vertical": true, "font_size": 20, "lines_coords": [[[171.0, 752.0], [192.0, 752.0], [189.0, 888.0], [168.0, 888.0]], [[148.0, 755.0], [165.0, 755.0], [165.0, 867.0], [148.0, 867.0]], [[123.0, 753.0], [144.0, 753.0], [144.0, 829.0], [123.0, 829.0]], [[99.0, 752.0], [119.0, 752.0], [119.0, 832.0], [99.0, 832.0]], [[76.0, 751.0], [96.0, 751.0], [93.0, 875.0], [73.0, 875.0]]], "lines": ["そうよ、土葬．．．", "つまり死体を", "焼かずに", "そのまま", "埋めてるのよ。"]}], "img_path": "012.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [737, 105, 763, 168], "vertical": true, "font_size": 26, "lines_coords": [[[737.0, 105.0], [763.0, 105.0], [763.0, 168.0], [737.0, 168.0]]], "lines": ["本当？"]}, {"box": [420, 180, 470, 280], "vertical": true, "font_size": 24, "lines_coords": [[[441.0, 180.0], [470.0, 180.0], [470.0, 226.0], [441.0, 226.0]], [[420.0, 181.0], [440.0, 181.0], [443.0, 280.0], [423.0, 280.0]]], "lines": ["でも", "どうして？"]}, {"box": [289, 93, 383, 197], "vertical": true, "font_size": 22, "lines_coords": [[[357.0, 93.0], [383.0, 93.0], [383.0, 155.0], [357.0, 155.0]], [[336.0, 96.0], [357.0, 96.0], [357.0, 196.0], [336.0, 196.0]], [[311.0, 93.0], [332.0, 93.0], [334.0, 193.0], [313.0, 193.0]], [[289.0, 94.0], [310.0, 94.0], [310.0, 182.0], [289.0, 182.0]]], "lines": ["やだな", "桐絵ちゃん、", "決まってる", "じゃない。"]}, {"box": [665, 324, 758, 498], "vertical": true, "font_size": 20, "lines_coords": [[[737.0, 326.0], [757.0, 326.0], [757.0, 479.0], [737.0, 479.0]], [[711.0, 324.0], [731.0, 324.0], [733.0, 498.0], [713.0, 498.0]], [[689.0, 325.0], [709.0, 325.0], [709.0, 460.0], [689.0, 460.0]], [[665.0, 326.0], [685.0, 326.0], [685.0, 461.0], [665.0, 461.0]]], "lines": ["火葬の煙が原因よ", "．．．最近、この町では", "どういうわけか", "火葬場の煙が．．．"]}, {"box": [101, 414, 198, 571], "vertical": true, "font_size": 22, "lines_coords": [[[169.0, 414.0], [198.0, 414.0], [198.0, 460.0], [169.0, 460.0]], [[148.0, 417.0], [169.0, 417.0], [171.0, 570.0], [150.0, 570.0]], [[126.0, 417.0], [