[[370.0, 502.0], [390.0, 502.0], [390.0, 636.0], [370.0, 636.0]], [[349.0, 502.0], [366.0, 502.0], [365.0, 616.0], [348.0, 616.0]]], "lines": ["はたして我々は", "生きて帰る事が", "できるのが！？"]}, {"box": [91, 430, 229, 542], "vertical": true, "font_size": 25, "lines_coords": [[[203.0, 430.0], [229.0, 430.0], [229.0, 506.0], [203.0, 506.0]], [[179.0, 432.0], [200.0, 432.0], [200.0, 521.0], [179.0, 521.0]], [[151.0, 432.0], [172.0, 432.0], [172.0, 541.0], [151.0, 541.0]], [[120.0, 431.0], [146.0, 431.0], [146.0, 500.0], [120.0, 500.0]], [[91.0, 432.0], [120.0, 432.0], [120.0, 502.0], [91.0, 502.0]]], "lines": ["そして、", "そもそも", "うずまきの", "謎とは", "一体！？"]}, {"box": [229, 727, 250, 787], "vertical": true, "font_size": 21, "lines_coords": [[[229.0, 727.0], [250.0, 727.0], [250.0, 787.0], [229.0, 787.0]]], "lines": ["はっ！"]}, {"box": [169, 815, 222, 881], "vertical": false, "font_size": 58, "lines_coords": [[[192.0, 815.0], [222.0, 828.0], [200.0, 881.0], [169.0, 868.0]]], "lines": ["ってはほほほう"]}, {"box": [636, 861, 704, 977], "vertical": true, "font_size": 20, "lines_coords": [[[682.0, 863.0], [703.0, 863.0], [703.0, 977.0], [682.0, 977.0]], [[657.0, 861.0], [677.0, 861.0], [677.0, 975.0], [657.0, 975.0]], [[636.0, 862.0], [656.0, 862.0], [656.0, 941.0], [636.0, 941.0]]], "lines": ["我々が目指す", "場所は目前に", "迫った！"]}, {"box": [302, 895, 345, 1085], "vertical": true, "font_size": 18, "lines_coords": [[[323.0, 895.0], [343.0, 895.0], [345.0, 1085.0], [325.0, 1085.0]], [[302.0, 896.0], [318.0, 896.0], [318.0, 1028.0], [302.0, 1028.0]]], "lines": ["低くたれこめる暗雲は", "不吉の前兆か！？"]}, {"box": [60, 989, 86, 1060], "vertical": true, "font_size": 26, "lines_coords": [[[60.0, 989.0], [86.0, 989.0], [86.0, 1060.0], [60.0, 1060.0]]], "lines": ["夢か！！"]}, {"box": [17, 981, 42, 1157], "vertical": true, "font_size": 20, "lines_coords": [[[17.0, 987.0], [37.0, 987.0], [41.0, 1154.0], [21.0, 1154.0]]], "lines": ["ご夢オチですか！！！"]}], "img_path": "204.jpg"}, {"version": "0.1.7", "img_width": 806, "img_height": 1200, "blocks": [{"box": [371, 430, 390, 495], "vertical": true, "font_size": 16, "lines_coords": [[[373.0, 430.0], [390.0, 430.0], [387.0, 495.0], [371.0, 495.0]]], "lines": ["【印刷所】．．．"]}, {"box": [447, 431, 493, 483], "vertical": true, "font_size": 16.5, "lines_coords": [[[476.0, 431.0], [493.0, 431.0], [493.0, 483.0], [476.0, 483.0]], [[447.0, 432.0], [463.0, 432.0], [463.0, 480.0], [447.0, 480.0]]], "lines": ["【発行者】", "【発行所】"]}, {"box": [521, 432, 537, 481], "vertical": true, "font_size": 16, "lines_coords": [[[521.0, 432.0], [537.0, 432.0], [537.0, 481.0], [521.0, 481.0]]], "lines": ["【若者】"]}, {"box": [152, 515, 185, 774], "vertical": true, "font_size": 15, "lines_coords": [[[154.0, 515.0], [171.0, 515.0], [168.0, 774.0], [152.0, 774.0]], [[169.0, 645.0], [185.0, 645.0], [185.0, 772.0], [169.0, 772.0]]], "lines": ["ＣａｓｔｏｏｋｋｉｋｉｚｙｐｙＰｒｉｎｄａｒｉｇｈｔ", "ＩＳＢＺＡ－Ｏ９－Ｊ８Ｓ７Ｚ２－１"]}, {"box": [197, 430, 353, 776], "vertical": true, "font_size": 15, "lines_coords": [[[338.0, 430.0], [353.0, 430.0], [351.0, 775.0], [336.0, 775.0]], [[322.0, 430.0], [337.0, 430.0], [336.0, 776.0], [320.0, 776.0]], [[308.0, 431.0], [320.0, 431.0], [319.0, 656.0], [306.0, 656.0]], [[291.0, 430.0], [306.0, 430.0], [304.0, 775.0], [289.0, 775.0]], [[275.0, 430.0], [290.0, 430.0], [290.0, 773.0], [275.0, 773.0]], [[260.0, 432.0], [275.0, 432.0], [274.0, 643.0], [258.0, 643.0]], [[246.0, 432.0], [257.0, 432.0], [257.0, 622.0], [246.0, 622.0]], [[228.0, 431.0], [243.0, 431.0], [243.0, 775.0], [228.0, 775.0]], [[213.0, 431.0], [228.0, 431.0], [228.0, 775.0], [213.0, 775.0]], [[197.0, 430.0], [213.0, 430.0], [213.0, 755.0], [197.0, 755.0]]], "lines": ["●本書の一部または全部を無断で複製転載、上演放送等をすることは、", "法律で認められた場合を除き、著作者及び出版者の権利の促害となります。", "す。あらかじめ小社あて許諾をお求めください。", "●過去には十分注意しておりますが、万一流丁・乱丁などの不良品があ", "りましたら、制作部」（＊０１２０）３３６，０８２〜あでにお送りくださ", "い、透料小社負担にそお取り替えいたします。", "●１３一日本被写権センター委託出版物", "本書のこ部または全部を無断で複写コピーすることは、著作権法上で", "の例外を除き禁じられています。本書から複写を希望される場合は、日", "本複写権センター（＊ｏ３，３４０）１，２３８２）にご連絡ください。"]}, {"box": [370, 566, 465, 776], "vertical": true, "font_si