], [481.0, 536.0], [482.0, 670.0], [461.0, 670.0]], [[436.0, 536.0], [456.0, 536.0], [459.0, 714.0], [439.0, 714.0]]], "lines": ["ああ．．．もう", "あの２人は完全に", "人間以外の別の", "生き物になっている。"]}, {"box": [98, 556, 190, 693], "vertical": true, "font_size": 20, "lines_coords": [[[166.0, 557.0], [187.0, 557.0], [189.0, 655.0], [168.0, 655.0]], [[145.0, 556.0], [165.0, 556.0], [165.0, 693.0], [145.0, 693.0]], [[119.0, 556.0], [139.0, 556.0], [141.0, 692.0], [121.0, 692.0]], [[98.0, 560.0], [115.0, 560.0], [115.0, 617.0], [98.0, 617.0]]], "lines": ["私は彼らを", "〝ヒトマイマイ〟", "と名付けようと", "思う！！"]}], "img_path": "071.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [650, 80, 720, 199], "vertical": true, "font_size": 22, "lines_coords": [[[699.0, 83.0], [719.0, 83.0], [719.0, 199.0], [699.0, 199.0]], [[676.0, 84.0], [696.0, 84.0], [696.0, 180.0], [676.0, 180.0]], [[650.0, 80.0], [675.0, 80.0], [675.0, 144.0], [650.0, 144.0]]], "lines": ["あっ．．．先生！！", "何をするん", "です！？"]}, {"box": [456, 71, 531, 207], "vertical": true, "font_size": 22, "lines_coords": [[[505.0, 72.0], [531.0, 72.0], [531.0, 133.0], [505.0, 133.0]], [[481.0, 71.0], [501.0, 71.0], [504.0, 195.0], [484.0, 195.0]], [[456.0, 72.0], [475.0, 72.0], [475.0, 207.0], [456.0, 207.0]]], "lines": ["見れば", "わかるだろう、", "潰してるんだ！！"]}, {"box": [57, 82, 129, 200], "vertical": true, "font_size": 20, "lines_coords": [[[109.0, 82.0], [128.0, 82.0], [128.0, 196.0], [109.0, 196.0]], [[79.0, 82.0], [100.0, 82.0], [101.0, 181.0], [80.0, 181.0]], [[57.0, 84.0], [77.0, 84.0], [77.0, 200.0], [57.0, 200.0]]], "lines": ["こんなものが", "孵化したら", "えらい事だ！！"]}, {"box": [443, 499, 470, 543], "vertical": true, "font_size": 27, "lines_coords": [[[443.0, 499.0], [470.0, 499.0], [470.0, 543.0], [443.0, 543.0]]], "lines": ["はあ"]}, {"box": [343, 503, 366, 546], "vertical": true, "font_size": 23, "lines_coords": [[[343.0, 503.0], [366.0, 503.0], [366.0, 546.0], [343.0, 546.0]]], "lines": ["はあ"]}, {"box": [242, 493, 309, 591], "vertical": true, "font_s