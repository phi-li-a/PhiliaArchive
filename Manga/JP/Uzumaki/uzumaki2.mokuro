.0], [322.0, 558.0], [320.0, 631.0], [289.0, 630.0]], [[261.0, 557.0], [295.0, 557.0], [295.0, 632.0], [261.0, 632.0]]], "lines": ["台風が", "来るぞ"]}, {"box": [58, 567, 106, 630], "vertical": true, "font_size": 26, "lines_coords": [[[80.0, 567.0], [106.0, 567.0], [106.0, 628.0], [80.0, 628.0]], [[58.0, 568.0], [83.0, 568.0], [83.0, 630.0], [58.0, 630.0]]], "lines": ["変な人", "ねえ．．．"]}, {"box": [580, 676, 720, 833], "vertical": true, "font_size": 20, "lines_coords": [[[698.0, 678.0], [718.0, 678.0], [718.0, 793.0], [698.0, 793.0]], [[675.0, 678.0], [695.0, 678.0], [695.0, 754.0], [675.0, 754.0]], [[651.0, 678.0], [671.0, 678.0], [671.0, 782.0], [651.0, 782.0]], [[627.0, 677.0], [647.0, 677.0], [647.0, 812.0], [627.0, 812.0]], [[601.0, 676.0], [624.0, 676.0], [624.0, 833.0], [601.0, 833.0]], [[580.0, 676.0], [600.0, 676.0], [600.0, 759.0], [580.0, 759.0]]], "lines": ["今年はなぜか", "例のない", "異常気象で、", "台風がひとつも", "発生していません", "でしたが、"]}, {"box": [330, 679, 422, 853], "vertical": true, "font_size": 20, "lines_coords": [[[400.0, 679.0], [422.0, 679.0], [422.0, 758.0], [400.0, 758.0]], [[376.0, 679.0], [397.0, 679.0], [398.0, 799.0], [377.0, 799.0]], [[354.0, 679.0], [373.0, 679.0], [373.0, 853.0], [354.0, 853.0]], [[330.0, 679.0], [350.0, 679.0], [350.0, 781.0], [330.0, 781.0]]], "lines": ["ところで", "この台風には、", "もうひとつ変わった", "特徴があり、"]}, {"box": [69, 682, 162, 799], "vertical": true, "font_size": 22, "lines_coords": [[[140.0, 683.0], [160.0, 683.0], [160.0, 778.0], [140.0, 778.0]], [[114.0, 682.0], [140.0, 682.0], [140.0, 745.0], [114.0, 745.0]], [[92.0, 683.0], [113.0, 683.0], [116.0, 799.0], [94.0, 799.0]], [[69.0, 683.0], [89.0, 683.0], [91.0, 786.0], [71.0, 786.0]]], "lines": ["台風の目の", "直径が", "異常に小さい", "という事で、"]}, {"box": [637, 964, 729, 1117], "vertical": true, "font_size": 18, "lines_coords": [[[709.0, 966.0], [725.0, 966.0], [725.0, 1115.0], [709.0, 1115.0]], [[684.0, 964.0], [704.0, 964.0], [704.0, 1042.0], [684.0, 1042.0]], [[661.0, 964.0], [681.0, 964.0], [681.0, 1079.0], [661.0, 1079.0]], [[638.0, 965.0], [655.0, 965.0], [655.0, 1083.0], [638.0, 1083.0]]], "lines": ["この時期になって", "ようやく", "第１号台風が", "発生しました。"]}, {"box": [437, 892, 505, 1134], "vertical": true, "font_size": 20, "lines_coords": [[[484.0, 892.0], [504.0, 892.0], [505.0, 1134.0], [485.0, 1134.0]], [[460.0, 892.0], [480.0, 892.0], [481.0, 1125.0], [461.0, 1125.0]], [[437.0, 894.0], [457.0, 894.0], [457.0, 1073.0], [437.0, 1073.0]]], "lines": ["この超大型の台風第１号は、", "数日後には日本に上陸する", "恐れも出てきました。"]}, {"box": [70, 918, 138, 1091], "vertical": true, "font_size": 20, "lines_coords": [[[114.0, 918.0], [135.0, 918.0], [138.0, 1091.0], [117.0, 1091.0]], [[93.0, 919.0], [113.0, 919.0], [113.0, 1072.0], [93.0, 1072.0]], [[70.0, 919.0], [90.0, 919.0], [90.0, 1021.0], [70.0, 1021.0]]], "lines": ["地上から台風の目が", "はっきり見えると", "いう事です。"]}], "img_path": "174.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [650, 87, 764, 207], "vertical": true, "font_size": 20, "lines_coords": [[[744.0, 91.0], [764.0, 91.0], [764.0, 205.0], [744.0, 205.0]], [[718.0, 89.0], [743.0, 89.0], [743.0, 166.0], [718.0, 166.0]], [[697.0, 90.0], [713.0, 90.0], [713.0, 164.0], [697.0, 164.0]], [[672.0, 87.0], [692.0, 87.0], [690.0, 182.0], [670.0, 182.0]], [[650.0, 90.0], [667.0, 90.0], [667.0, 164.0], [650.0, 164.0]]], "lines": ["おねえちゃん、", "台風って", "どんな目", "してるんだ", "ろうな？"]}, {"box": [404, 86, 519, 240], "vertical": true, "font_size": 20, "lines_coords": [[[499.0, 87.0], [519.0, 87.0], [519.0, 187.0], [499.0, 187.0]], [[475.0, 86.0], [495.0, 86.0], [495.0, 239.0], [475.0, 239.0]], [[451.0, 89.0], [471.0, 89.0], [471.0, 183.0], [451.0, 183.0]], [[426.0, 87.0], [447.0, 87.0], [448.0, 240.0], [427.0, 240.0]], [[404.0, 87.0], [424.0, 87.0], [424.0, 173.0], [404.0, 173.0]]], "lines": ["バカね満男、", "目っていったって", "本当に目が", "ついてるわけじゃ", "ないわよ。"]}, {"box": [280, 546, 420, 628], "vertical": true, "font_size": 29, "lines_coords": [[[398.0, 549.0], [419.0, 549.0], [419.0, 628.0], [398.0, 628.0]], [[369.0, 547.0], [399.0, 5