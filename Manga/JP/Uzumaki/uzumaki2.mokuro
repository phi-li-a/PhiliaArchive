: [651, 563, 744, 698], "vertical": true, "font_size": 20, "lines_coords": [[[721.0, 563.0], [741.0, 563.0], [741.0, 642.0], [721.0, 642.0]], [[699.0, 564.0], [719.0, 564.0], [719.0, 678.0], [699.0, 678.0]], [[675.0, 564.0], [695.0, 564.0], [695.0, 660.0], [675.0, 660.0]], [[652.0, 564.0], [672.0, 564.0], [671.0, 698.0], [651.0, 698.0]]], "lines": ["彼女達は", "出産のために", "生血が必要", "だったのです！！"]}, {"box": [135, 581, 225, 716], "vertical": true, "font_size": 18, "lines_coords": [[[204.0, 582.0], [224.0, 582.0], [224.0, 696.0], [204.0, 696.0]], [[180.0, 581.0], [200.0, 581.0], [200.0, 714.0], [180.0, 714.0]], [[158.0, 582.0], [174.0, 582.0], [174.0, 694.0], [158.0, 694.0]], [[135.0, 581.0], [151.0, 581.0], [151.0, 716.0], [135.0, 716.0]]], "lines": ["吸血によって", "育った赤ん坊が", "生まれる日は", "もう間近です！！"]}], "img_path": "137.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [386, 0, 412, 161], "vertical": true, "font_size": 16, "lines_coords": [[[389.0, 51.0], [405.0, 51.0], [407.0, 158.0], [391.0, 158.0]]], "lines": ["．．．第１話"]}, {"box": [390, 256, 412, 332], "vertical": true, "font_size": 21, "lines_coords": [[[390.0, 256.0], [411.0, 256.0], [411.0, 332.0], [390.0, 332.0]]], "lines": ["さいたい"]}], "img_path": "138.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [647, 124, 742, 278], "vertical": true, "font_size": 22, "lines_coords": [[[722.0, 124.0], [742.0, 124.0], [742.0, 260.0], [722.0, 260.0]], [[696.0, 124.0], [719.0, 124.0], [719.0, 278.0], [696.0, 278.0]], [[674.0, 126.0], [694.0, 126.0], [694.0, 241.0], [674.0, 241.0]], [[647.0, 124.0], [672.0, 124.0], [672.0, 187.0], [647.0, 187.0]]], "lines": ["黒渦病院に入院", "していた妊婦達が", "一斉に臨月を", "むかえ"]}, {"box": [103, 48, 425, 98], "vertical": false, "font_size": 43, "lines_coords": [[[104.0, 48.0], [407.0, 55.0], [406.0, 98.0], [103.0, 91.0]]], "lines": ["キャアァアアア"]}, {"box": [601, 452, 708, 502], "vertical": false, "font_size": 29, "lines_coords": [[[608.0, 452.0], [708.0, 474.0], [702.0, 502.0], [601.0, 480.0]]], "lines": ["分娩室"]}, {"box": [471, 404, 541, 616], "vertical": true, "font_size": 20, "lines_coords": [[[521.0, 405.0], [541.0, 405.0], [541.0, 519.0], [521.0, 519.0]], [[495.0, 404.0], [515.0, 404.0], [514.0, 616.0], [494.0, 616.0]], [[472.0, 406.0], [492.0, 406.0], [491.0, 601.0], [471.0, 601.0]]], "lines": ["先陣をきって", "私のいとこの恵子さんが", "分娩台にのぞみました。"]}, {"box": [99, 500, 262, 616], "vertical": false, "font_size": 38, "lines_coords": [[[119.0, 502.0], [247.0, 582.0], [227.0, 614.0], [99.0, 534.0]]], "lines": ["シ入入入"]}, {"box": [716, 676, 759, 781], "vertical": true, "font_size": 18, "lines_coords": [[[738.0, 676.0], [758.0, 676.0], [758.0, 772.0], [738.0, 772.0]], [[716.0, 677.0], [732.0, 677.0], [732.0, 779.0], [716.0, 779.0]]], "lines": ["私は不安で", "なりません。"]}, {"box": [252, 667, 389, 790], "vertical": true, "font_size": 20, "lines_coords": [[[369.0, 670.0], [389.0, 670.0], [389.0, 786.0], [369.0, 786.0]], [[345.0, 670.0], [365.0, 670.0], [365.0, 786.0], [345.0, 786.0]], [[321.0, 667.0], [344.0, 667.0], [344.0, 788.0], [321.0, 788.0]], [[298.0, 670.0], [318.0, 670.0], [318.0, 785.0], [298.0, 785.0]], [[275.0, 669.0], [295.0, 669.0], [295.0, 785.0], [275.0, 785.0]], [[252.0, 670.0], [271.0, 670.0], [271.0, 783.0], [252.0, 783.0]]], "lines": ["．．．つまり、今", "生まれようと", "しているのは", "吸血によって", "育った赤ん坊", "なのです．．．"]}, {"box": [110, 669, 177, 814], "vertical": true, "font_size": 19, "lines_coords": [[[155.0, 669.0], [175.0, 669.0], [175.0, 748.0], [155.0, 748.0]], [[133.0, 671.0], [153.0, 671.0], [153.0, 768.0], [133.0, 768.0]], [[111.0, 670.0], [127.0, 670.0], [127.0, 812.0], [111.0, 812.0]]], "lines": ["．．．でも．．．", "誰も信じて", "くれないのです。"]}, {"box": [438, 956, 554, 1092], "vertical": true, "font_size": 19, "lines_coords": [[[533.0, 957.0], [553.0, 957.0], [553.0, 1040.0], [533.0, 1040.0]], [[509.0, 957.0], [529.0, 957.0], [527.0, 1073.0], [507.0, 1073.0]], [[488.0, 958.0], [505.0, 958.0], [505.0, 1053.0], [488.0, 1053.0]], [[463.0, 957.0], [482.0, 957.0], [482.0, 1055.0], [463.0, 1055.0]], [[440.0, 956.0], [460.0, 956.0], [458.0, 1092.0], [438.0, 1092.0]]], "lines": ["なぜなら、", "あの妊婦達は", "人を襲って", "その生血を", "吸ったのです！！"]}], "img_path": "139.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [640, 114, 708, 325], "vertical": true, "font_size": 20, "lines_coords": [[[686.0, 114.0], [706.0, 114.0], [708.0, 325.0], [688.0, 325.0]], [[664.0, 116.0], [684.0, 116.0], [684.0, 270.0], [664.0, 270.0]], [[640.0, 116.0], [660.0, 116.0], [660.0, 233.0], [640.0, 233.0]]], "lines": ["病院内で、あの恐ろしい", "大量殺人が起きた", "翌日、私は．．．"]}, {"box": [270, 116, 336, 308], "vertical": true, "font_size": 18, "lines_coords": [[[314.0, 116.0], [334.0, 116.0], [335.0, 307.0], [315.0, 307.0]], [[294.0, 118.0], [310.0, 118.0], [310.0, 308.0], [294.0, 308.0]], [[270.0, 118.0], [287.0, 118.0], [287.0, 237.0], [270.0, 237.0]]], "lines": ["院長先生や産婦人科の", "川本先生に、見た事を", "話したのです。"]}, {"box": [594, 396, 709, 588], "vertical": true, "font_size": 19, "lines_coords": [[[691.0, 398.0], [708.0, 398.0], [708.0, 529.0], [691.0, 529.0]], [[665.0, 397.0], [685.0, 397.0], [685.0, 588.0], [665.0, 588.0]], [[641.0, 396.0], [661.0, 396.0], [661.0, 512.0], [641.0, 512.0]], [[617.0, 396.0], [637.0, 396.0], [637.0, 532.0], [617.0, 532.0]], [[594.0, 396.0], [614.0, 396.0], [614.0, 494.0], [594.0, 494.0]]], "lines": ["本当なんです！！", "彼女達がやったんです", "．．．早く何とか", "しないと、また", "犠牲者が．．．"]}, {"box": [311, 418, 354, 573], "vertical": true, "font_size": 18, "lines_coords": [[[332.0, 418.0], [352.0, 418.0], [354.0, 573.0], [334.0, 573.0]], [[311.0, 420.0], [328.0, 420.0], [328.0, 540.0], [311.0, 540.0]]], "lines": ["．．．まさか．．．夢でも", "見たんだろう。"]}, {"box": [649, 644, 718, 818], "vertical": true, "font_size": 19, "lines_coords": [[[695.0, 644.0], [715.0, 644.0], [717.0, 762.0], [697.0, 762.0]], [[674.0, 646.0], [691.0, 646.0], [692.0, 817.0], [675.0, 817.0]], [[649.0, 646.0], [670.0, 646.0], [670.0, 712.0], [649.0, 712.0]]], "lines": ["誰に話しても", "信じてもらえません", "でした。"]}, {"box": [56, 651, 148, 808], "vertical": true, "font_size": 22, "lines_coords": [[[125.0, 651.0], [148.0, 651.0], [148.0, 772.0], [125.0, 772.0]], [[101.0, 651.0], [125.0, 651.0], [125.0, 808.0], [101.0, 808.0]], [[79.0, 652.0], [99.0, 652.0], [99.0, 768.0], [79.0, 768.0]], [[56.0, 652.0], [76.0, 652.0], [77.0, 795.0], [57.0, 795.0]]], "lines": ["それどころか、", "訴えれば訴える程", "私は白い目で", "見られるのです。"]}, {"box": [670, 867, 714, 964], "vertical": true, "font_size": 18, "lines_coords": [[[692.0, 868.0], [712.0, 868.0], [712.0, 945.0], [692.0, 945.0]], [[671.0, 867.0], [688.0, 867.0], [686.0, 963.0], [670.0, 963.0]]], "lines": ["私の家族", "でさえも．．．"]}, {"box": [525, 853, 641, 950], "vertical": true, "font_size": 21, "lines_coords": [[[615.0, 853.0], [641.0, 853.0], [641.0, 915.0], [615.0, 915.0]], [[594.0, 855.0], [615.0, 855.0], [615.0, 932.0], [594.0, 932.0]], [[569.0, 853.0], [589.0, 853.0], [592.0, 949.0], [572.0, 949.0]], [[549.0, 856.0], [566.0, 856.0], [566.0, 950.0], [549.0, 950.0]], [[525.0, 854.0], [547.0, 854.0], [547.0, 876.0], [525.0, 876.0]]], "lines": ["桐絵！", "ばかな事", "言うんじゃ", "ありません", "！"]}, {"box": [327, 848, 417, 984], "vertical": true, "font_size": 19, "lines_coords": [[[397.0, 848.0], [417.0, 848.0], [414.0, 962.0], [395.0, 962.0]], [[371.0, 848.0], [391.0, 848.0], [391.0, 925.0], [371.0, 925.0]], [[349.0, 849.0], [370.0, 849.0], [370.0, 926.0], [349.0, 926.0]], [[327.0, 849.0], [343.0, 849.0], [343.0, 984.0], [327.0, 984.0]]], "lines": ["恵子ちゃんが", "そんな事", "するわけ", "ないでしょう！！"]}, {"box": [60, 850, 128, 972], "vertical": true, "font_size": 19, "lines_coords": [[[109.0, 850.0], [128.0, 850.0], [126.0, 948.0], [106.0, 948.0]], [[84.0, 851.0], [105.0, 851.0], [105.0, 930.0], [84.0, 930.0]], [[62.0, 851.0], [79.0, 851.0], [78.0, 971.0], [60.0, 971.0]]], "lines": ["私は完全に", "孤立して", "しまいました。"]}], "img_path": "140.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [643, 123, 760, 240], "vertical": true, "font_size": 19, "lines_coords": [[[738.0, 123.0], [7