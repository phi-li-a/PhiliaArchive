": true, "font_size": 18, "lines_coords": [[[130.0, 896.0], [150.0, 896.0], [150.0, 1087.0], [130.0, 1087.0]], [[107.0, 897.0], [124.0, 897.0], [124.0, 1031.0], [107.0, 1031.0]]], "lines": ["怪しい光を放つように", "なったのです："]}], "img_path": "077.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [603, 423, 723, 546], "vertical": true, "font_size": 22, "lines_coords": [[[694.0, 423.0], [723.0, 423.0], [723.0, 466.0], [694.0, 466.0]], [[675.0, 426.0], [695.0, 426.0], [695.0, 544.0], [675.0, 544.0]], [[650.0, 425.0], [671.0, 425.0], [671.0, 503.0], [650.0, 503.0]], [[628.0, 425.0], [648.0, 425.0], [648.0, 520.0], [628.0, 520.0]], [[603.0, 424.0], [624.0, 424.0], [624.0, 485.0], [603.0, 485.0]]], "lines": ["おい", "おねえちゃん、", "あの灯台", "かっこいい", "よな！！"]}, {"box": [273, 421, 391, 556], "vertical": true, "font_size": 21, "lines_coords": [[[365.0, 421.0], [391.0, 421.0], [391.0, 491.0], [365.0, 491.0]], [[342.0, 421.0], [365.0, 421.0], [365.0, 556.0], [342.0, 556.0]], [[318.0, 423.0], [339.0, 423.0], [339.0, 500.0], [318.0, 500.0]], [[295.0, 423.0], [315.0, 423.0], [315.0, 537.0], [295.0, 537.0]], [[274.0, 423.0], [290.0, 423.0], [290.0, 544.0], [274.0, 544.0]]], "lines": ["だって、", "巨大ロボットが", "殺人光線", "吐きだしてる", "みたいじゃん。"]}, {"box": [184, 426, 206, 531], "vertical": true, "font_size": 20, "lines_coords": [[[184.0, 426.0], [203.0, 426.0], [206.0, 530.0], [186.0, 530.0]]], "lines": ["こうやって．．．"]}, {"box": [87, 423, 132, 546], "vertical": true, "font_size": 20, "lines_coords": [[[111.0, 424.0], [131.0, 424.0], [131.0, 519.0], [111.0, 519.0]], [[87.0, 423.0], [107.0, 423.0], [107.0, 543.0], [87.0, 543.0]]], "lines": ["バカな真似", "やめなさいよ。"]}, {"box": [658, 760, 726, 896], "vertical": true, "font_size": 19, "lines_coords": [[[708.0, 764.0], [724.0, 764.0], [724.0, 896.0], [708.0, 896.0]], [[683.0, 760.0], [703.0, 760.0], [701.0, 877.0], [681.0, 877.0]], [[658.0, 762.0], [678.0, 762.0], [678.0, 848.0], [658.0, 848.0]]], "lines": ["あんまりあの光", "見ないほうが", "いいわよ。"]}, {"box": 