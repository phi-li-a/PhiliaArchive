, [67.0, 444.0]]], "lines": ["ううん、", "何でもない。"]}, {"box": [513, 544, 604, 698], "vertical": true, "font_size": 20, "lines_coords": [[[584.0, 544.0], [604.0, 544.0], [604.0, 679.0], [584.0, 679.0]], [[560.0, 546.0], [580.0, 546.0], [580.0, 698.0], [560.0, 698.0]], [[538.0, 546.0], [554.0, 546.0], [554.0, 679.0], [538.0, 679.0]], [[513.0, 544.0], [534.0, 544.0], [534.0, 607.0], [513.0, 607.0]]], "lines": ["まあ、火葬して", "煙が渦を巻くより", "ましなんだろう", "けど．．．"]}, {"box": [467, 750, 487, 836], "vertical": true, "font_size": 20, "lines_coords": [[[467.0, 750.0], [487.0, 750.0], [487.0, 836.0], [467.0, 836.0]]], "lines": ["早く帰ろ。"]}, {"box": [64, 525, 180, 700], "vertical": true, "font_size": 20, "lines_coords": [[[153.0, 525.0], [180.0, 525.0], [180.0, 575.0], [153.0, 575.0]], [[132.0, 526.0], [152.0, 526.0], [154.0, 700.0], [134.0, 700.0]], [[110.0, 528.0], [127.0, 528.0], [128.0, 663.0], [111.0, 663.0]], [[85.0, 527.0], [105.0, 527.0], [107.0, 680.0], [87.0, 680.0]], [[64.0, 529.0], [80.0, 529.0], [80.0, 643.0], [64.0, 643.0]]], "lines": ["でも、", "この基地のどこかに", "死体がそのまま", "埋まってるなんて", "イヤよね．．．"]}, {"box": [588, 990, 724, 1108], "vertical": true, "font_size": 24, "lines_coords": [[[699.0, 992.0], [724.0, 992.0], [724.0, 1072.0], [699.0, 1072.0]], [[674.0, 990.0], [703.0, 990.0], [703.0, 1054.0], [674.0, 1054.0]], [[654.0, 992.0], [675.0, 992.0], [675.0, 1071.0], [654.0, 1071.0]], [[628.0, 991.0], [654.0, 991.0], [654.0, 1054.0], [628.0, 1054.0]], [[608.0, 992.0], [628.0, 992.0], [628.0, 1108.0], [608.0, 1108.0]]], "lines": ["いやだ．．．", "墓地の", "真ん中で", "変な話", "しちゃったね"]}], "img_path": "014.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [222, 85, 313, 257], "vertical": true, "font_size": 41, "lines_coords": [[[267.0, 90.0], [313.0, 90.0], [313.0, 228.0], [267.0, 228.0]], [[225.0, 85.0], [261.0, 85.0], [259.0, 257.0], [222.0, 257.0]]], "lines": ["キャ～", "～～ッ！！"]}, {"box": [676, 562, 746, 641], "vertical": true, "font_size": 22, "lines_coords": [[[722.0, 562.0], [746.0, 562.0], [746.0, 641.0], [722.0, 641.0]], [[698.0, 564.0], [719.0, 564.0], [719.0, 638.0], [698.0, 638.0]], [[676.0, 563.0], [697.0, 563.0], [697.0, 585.0], [676.0, 585.0]]], "lines": ["びっくり", "したかい", "？"]}, {"box": [625, 583, 647, 694], "vertical": true, "font_size": 12, "lines_coords": [[[630.0, 591.0], [642.0, 591.0], [642.0, 659.0], [630.0, 659.0]]], "lines": ["いやあの"]}, {"box": [466, 568, 560, 666], "vertical": true, "font_size": 22, "lines_coords": [[[534.0, 568.0], [560.0, 568.0], [560.0, 631.0], [534.0, 631.0]], [[513.0, 569.0], [534.0, 569.0], [534.0, 666.0], [513.0, 666.0]], [[490.0, 569.0], [511.0, 569.0], [511.0, 646.0], [490.0, 646.0]], [[466.0, 569.0], [486.0, 569.0], [486.0, 666.0], [466.0, 666.0]]], "lines": ["山口君", "じゃない！！", "おどかさ", "ないでよ！！"]}, {"box": [321, 782, 415, 880], "vertical": true, "font_size": 24, "lines_coords": [[[391.0, 783.0], [412.0, 783.0], [412.0, 861.0], [391.0, 861.0]], [[369.0, 785.0], [389.0, 785.0], [389.0, 880.0], [369.0, 880.0]], [[339.0, 782.0], [370.0, 782.0], [370.0, 837.0], [339.0, 837.0]], [[321.0, 786.0], [345.0, 786.0], [345.0, 853.0], [321.0, 853.0]]], "lines": ["びっくり", "したみたい", "だね、", "五島君。"]}, {"box": [168, 567, 241, 665], "vertical": true, "font_size": 23, "lines_coords": [[[214.0, 567.0], [241.0, 567.0], [241.0, 612.0], [214.0, 612.0]], [[193.0, 570.0], [214.0, 570.0], [214.0, 665.0], [193.0, 665.0]], [[168.0, 568.0], [188.0, 568.0], [191.0, 646.0], [171.0, 646.0]]], "lines": ["もう", "いい加減に", "してよ！！"]}, {"box": [715, 932, 758, 1068], "vertical": true, "font_size": 20, "lines_coords": [[[735.0, 932.0], [758.0, 932.0], [758.0, 1068.0], [735.0, 1068.0]], [[715.0, 935.0], [731.0, 935.0], [731.0, 1047.0], [715.0, 1047.0]]], "lines": ["怒ったのかい？", "ごめんよ．．．"]}, {"box": [124, 933, 194, 1071], "vertical": true, "font_size": 22, "lines_coords": [[[171.0, 933.0], [194.0, 933.0], [194.0, 1071.0], [171.0, 1071.0]], [[145.0, 935.0], [169.0, 935.0], [169.0, 1033.0], [145.0, 1033.0]], [[124.0, 936.0], [141.0, 936.0], [143.0, 1038.0], [125.0, 1038.0]]], "lines": ["びっくりさせる", "のは、俺の", "趣味なんだ。"]}], "img_path": "015.jpg"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [647, 101, 714, 300], "vertical": true, "font_size": 18, "lines_coords": [[[694.0, 101.0], [713.0, 101.0], [713.0, 292.0], [694.0, 292.0]], [[670.0, 101.0], [690.0, 101.0], [690.0, 256.0], [670.0, 256.0]], [[648.0, 101.0], [664.0, 101.0], [664.0, 300.0], [648.0, 300.0]]], "lines": ["山口君、そんな事して", "桐絵ちゃんの気を", "ひこうとしてもだめよ。"]}, {"box": [412, 92, 459, 274], "vertical": true, "font_size": 22, "lines_coords": [[[436.0, 92.0], [459.0, 92.0], [459.0, 249.0], [436.0, 249.0]], [[413.0, 92.0], [433.0, 92.0], [432.0, 274.0], [412.0, 274.0]]], "lines": ["彼女にはちゃんと", "彼氏がいるんだから。"]}, {"box": [335, 106, 382, 240], "vertical": true, "font_size": 16, "lines_coords": [[[365.0, 107.0], [382.0, 107.0], [382.0, 208.0], [365.0, 208.0]], [[336.0, 106.0], [352.0, 106.0], [352.0, 240.0], [336.0, 240.0]]], "lines": ["知ってるよ、", "斎藤秀一だろ？"]}, {"box": [71, 83, 143, 189], "vertical": true, "font_size": 22, "lines_coords": [[[117.0, 83.0], [143.0, 84.0], [140.0, 146.0], [114.0, 145.0]], [[96.0, 86.0], [117.0, 86.0], [117.0, 169.0], [96.0, 169.0]], [[73.0, 85.0], [93.0, 85.0], [91.0, 189.0], [71.0, 189.0]]], "lines": ["あんな", "暗いやつ、", "ほっとけよ。"]}, {"box": [594, 391, 710, 533], "vertical": true, "font_size": 20, "lines_coords": [[[690.0, 392.0], [710.0, 392.0], [706.0, 527.0], [686.0, 527.0]], [[664.0, 391.0], [688.0, 391.0], [688.0, 510.0], [664.0, 510.0]], [[642.0, 392.0], [662.0, 392.0], [662.0, 498.0], [642.0, 498.0]], [[617.0, 392.0], [637.0, 392.0], [637.0, 527.0], [617.0, 527.0]], [[595.0, 392.0], [613.0, 392.0], [611.0, 533.0], [594.0, 533.0]]], "lines": ["俺、君みたいに", "きれいなコを", "彼女にして、", "みんなをアッと", "言わせたいんだ。"]}, {"box": [419, 401, 493, 501], "vertical": true, "font_size": 24, "lines_coords": [[[467.0, 403.0], [493.0, 403.0], [493.0, 481.0], [467.0, 481.0]], [[445.0, 403.0], [465.0, 403.0], [465.0, 501.0], [445.0, 501.0]], [[41