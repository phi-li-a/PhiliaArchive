{"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [851, 115, 978, 321], "vertical": true, "font_size": 27, "lines_coords": [[[945.0, 115.0], [978.0, 115.0], [978.0, 198.0], [945.0, 198.0]], [[915.0, 117.0], [942.0, 117.0], [942.0, 271.0], [915.0, 271.0]], [[886.0, 117.0], [908.0, 117.0], [908.0, 292.0], [886.0, 292.0]], [[853.0, 115.0], [879.0, 115.0], [878.0, 321.0], [851.0, 321.0]]], "lines": ["あんた", "頑張ることを", "カッコ悪いとか", "思ってんでしょ？"]}, {"box": [482, 103, 575, 279], "vertical": true, "font_size": 24, "lines_coords": [[[548.0, 104.0], [572.0, 104.0], [573.0, 279.0], [550.0, 279.0]], [[518.0, 106.0], [540.0, 106.0], [540.0, 254.0], [518.0, 254.0]], [[482.0, 103.0], [509.0, 103.0], [512.0, 232.0], [486.0, 232.0]]], "lines": ["人気とるために", "努力して何が", "悪いのよ？"]}, {"box": [281, 240, 368, 418], "vertical": true, "font_size": 26, "lines_coords": [[[346.0, 243.0], [368.0, 243.0], [368.0, 418.0], [346.0, 418.0]], [[312.0, 240.0], [339.0, 240.0], [339.0, 392.0], [312.0, 392.0]], [[281.0, 240.0], [307.0, 240.0], [307.0, 356.0], [281.0, 356.0]]], "lines": ["アタシたちには", "時間がないん", "だからさ。"]}, {"box": [804, 360, 897, 515], "vertical": true, "font_size": 27, "lines_coords": [[[870.0, 362.0], [897.0, 362.0], [897.0, 515.0], [870.0, 515.0]], [[839.0, 365.0], [865.0, 365.0], [865.0, 492.0], [839.0, 492.0]], [[807.0, 360.0], [836.0, 360.0], [832.0, 476.0], [804.0, 476.0]]], "lines": ["そういうのが", "一番ダセー", "っつうの。"]}, {"box": [248, 462, 371, 646], "vertical": true, "font_size": 26, "lines_coords": [[[343.0, 462.0], [371.0, 462.0], [371.0, 565.0], [343.0, 565.0]], [[312.0, 462.0], [339.0, 462.0], [339.0, 646.0], [312.0, 646.0]], [[279.0, 464.0], [306.0, 464.0], [306.0, 565.0], [279.0, 565.0]], [[248.0, 462.0], [275.0, 462.0], [275.0, 576.0], [248.0, 576.0]]], "lines": ["ウダウダ", "理屈こねないで、", "サクサク", "やろーよ。"]}, {"box": [854, 759, 922, 890], "vertical": true, "font_size": 36, "lines_coords": [[[879.0, 759.0], [922.0, 759.0], [922.0, 832.0], [879.0, 832.0]], [[854.0, 762.0], [883.0, 762.0], [883.0, 890.0], [854.0, 890.0]]], "lines": ["何よ、", "その顔．．．．．"]}, {"box": [903, 993, 995, 1208], "vertical": true, "font_size": 32, "lines_coords": [[[951.0, 998.0], [989.0, 996.0], [995.0, 1173.0], [958.0, 1175.0]], [[903.0, 993.0], [929.0, 993.0], [929.0, 1206.0], [903.0, 1206.0]]], "lines": ["いーよ！", "じゃあ賭けようよ。"]}, {"box": [425, 1007, 517, 1198], "vertical": true, "font_size": 26, "lines_coords": [[[489.0, 1009.0], [515.0, 1009.0], [515.0, 1121.0], [489.0, 1121.0]], [[457.0, 1009.0], [484.0, 1009.0], [484.0, 1145.0], [457.0, 1145.0]], [[426.0, 1007.0], [453.0, 1007.0], [451.0, 1198.0], [425.0, 1198.0]]], "lines": ["次の電車、", "各停か急行、", "どっちが来るか。"]}, {"box": [184, 760, 273, 926], "vertical": true, "font_size": 26, "lines_coords": [[[245.0, 760.0], [271.0, 760.0], [271.0, 903.0], [245.0, 903.0]], [[210.0, 760.0], [239.0, 760.0], [240.0, 926.0], [212.0, 926.0]], [[184.0, 762.0], [206.0, 762.0], [206.0, 887.0], [184.0, 887.0]]], "lines": ["「このクソ女", "死ね」とかって", "思ってる？"]}, {"box": [115, 1276, 241, 1489], "vertical": true, "font_size": 27, "lines_coords": [[[210.0, 1276.0], [239.0, 1276.0], [240.0, 1489.0], [212.0, 1489.0]], [[179.0, 1278.0], [206.0, 1278.0], [207.0, 1484.0], [181.0, 1484.0]], [[150.0, 1279.0], [173.0, 1279.0], [175.0, 1482.0], [151.0, 1482.0]], [[115.0, 1279.0], [143.0, 1279.0], [143.0, 1370.0], [115.0, 1370.0]]], "lines": ["あんたが勝ったら、", "アタシはここから", "電車に飛び込んで", "あげる。"]}]}