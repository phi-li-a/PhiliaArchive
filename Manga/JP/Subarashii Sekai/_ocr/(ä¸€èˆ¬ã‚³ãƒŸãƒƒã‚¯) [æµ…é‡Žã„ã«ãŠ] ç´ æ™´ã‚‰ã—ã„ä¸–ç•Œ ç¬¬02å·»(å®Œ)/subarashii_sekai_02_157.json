{"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [931, 112, 1022, 292], "vertical": true, "font_size": 24, "lines_coords": [[[998.0, 118.0], [1020.0, 118.0], [1020.0, 267.0], [998.0, 267.0]], [[965.0, 115.0], [989.0, 115.0], [987.0, 292.0], [964.0, 292.0]], [[934.0, 112.0], [961.0, 112.0], [958.0, 268.0], [931.0, 268.0]]], "lines": ["つまり地道に", "コツコツやりな", "さいってか？"]}, {"box": [481, 139, 601, 345], "vertical": true, "font_size": 26, "lines_coords": [[[573.0, 140.0], [600.0, 140.0], [600.0, 296.0], [573.0, 296.0]], [[542.0, 140.0], [568.0, 140.0], [568.0, 321.0], [542.0, 321.0]], [[507.0, 139.0], [536.0, 139.0], [537.0, 345.0], [509.0, 345.0]], [[481.0, 142.0], [503.0, 142.0], [503.0, 279.0], [481.0, 279.0]]], "lines": ["こんな腐れた", "世の中で、んな", "だるいことやって", "らんねーよ。"]}, {"box": [140, 110, 259, 339], "vertical": true, "font_size": 26, "lines_coords": [[[232.0, 110.0], [259.0, 110.0], [257.0, 339.0], [231.0, 339.0]], [[201.0, 112.0], [228.0, 112.0], [228.0, 314.0], [201.0, 314.0]], [[170.0, 112.0], [196.0, 112.0], [196.0, 279.0], [170.0, 279.0]], [[140.0, 112.0], [162.0, 112.0], [162.0, 325.0], [140.0, 325.0]]], "lines": ["借りもんの格好いい", "言葉やらスタイル", "真似ても、結局", "中身はその単純さ。"]}, {"box": [964, 390, 990, 479], "vertical": true, "font_size": 25, "lines_coords": [[[964.0, 390.0], [990.0, 390.0], [990.0, 479.0], [964.0, 479.0]]], "lines": ["出たね。"]}, {"box": [854, 435, 909, 589], "vertical": true, "font_size": 25, "lines_coords": [[[883.0, 435.0], [909.0, 435.0], [909.0, 589.0], [883.0, 589.0]], [[854.0, 440.0], [876.0, 440.0], [876.0, 548.0], [854.0, 548.0]]], "lines": ["それが堀田の", "本性だよ。"]}, {"box": [123, 410, 182, 520], "vertical": true, "font_size": 26, "lines_coords": [[[156.0, 410.0], [182.0, 410.0], [182.0, 520.0], [156.0, 520.0]], [[123.0, 412.0], [151.0, 412.0], [151.0, 493.0], [123.0, 493.0]]], "lines": ["どうなの", "それ？"]}, {"box": [987, 983, 1014, 1148], "vertical": true, "font_size": 22, "lines_coords": [[[989.0, 985.0], [1011.0, 985.0], [1011.0, 1145.0], [989.0, 1145.0]]], "lines": ["早く気付けよ。"]}, {"box": [496, 792, 528, 909], "vertical": true, "font_size": 28, "lines_coords": [[[496.0, 792.0], [525.0, 792.0], [528.0, 909.0], [500.0, 909.0]]], "lines": ["．．．うっせ。"]}, {"box": [707, 1198, 798, 1367], "vertical": true, "font_size": 26, "lines_coords": [[[776.0, 1203.0], [798.0, 1203.0], [798.0, 1351.0], [776.0, 1351.0]], [[742.0, 1201.0], [768.0, 1201.0], [768.0, 1329.0], [742.0, 1329.0]], [[707.0, 1198.0], [736.0, 1198.0], [739.0, 1367.0], [711.0, 1367.0]]], "lines": ["おまえはまだ", "人生で何も", "しちゃいねぇ。"]}, {"box": [615, 1348, 706, 1501], "vertical": true, "font_size": 26, "lines_coords": [[[679.0, 1348.0], [706.0, 1348.0], [706.0, 1489.0], [679.0, 1489.0]], [[647.0, 1348.0], [675.0, 1348.0], [672.0, 1450.0], [643.0, 1450.0]], [[615.0, 1348.0], [642.0, 1348.0], [642.0, 1501.0], [615.0, 1501.0]]], "lines": ["今、死んだら", "何ひとつ", "残らないぜ？"]}, {"box": [121, 1268, 214, 1521], "vertical": true, "font_size": 28, "lines_coords": [[[184.0, 1270.0], [212.0, 1270.0], [212.0, 1376.0], [184.0, 1376.0]], [[153.0, 1268.0], [181.0, 1268.0], [181.0, 1420.0], [153.0, 1420.0]], [[121.0, 1268.0], [148.0, 1268.0], [150.0, 1521.0], [123.0, 1521.0]]], "lines": ["２３歳の時、", "就職先蹴って", "パンドとかやって．．．"]}]}