861.0, 1021.0], [861.0, 1106.0], [828.0, 1106.0]]], "lines": ["高知君、", "大学の調子は", "どお？"]}, {"box": [493, 1079, 620, 1310], "vertical": true, "font_size": 27, "lines_coords": [[[589.0, 1079.0], [620.0, 1079.0], [620.0, 1237.0], [589.0, 1237.0]], [[557.0, 1081.0], [584.0, 1081.0], [584.0, 1310.0], [557.0, 1310.0]], [[523.0, 1081.0], [551.0, 1081.0], [554.0, 1223.0], [526.0, 1223.0]], [[493.0, 1081.0], [520.0, 1081.0], [520.0, 1198.0], [493.0, 1198.0]]], "lines": ["どお？って、", "まだ始まったばっか", "だからなぁ。", "ま、普通？"]}, {"box": [232, 785, 290, 939], "vertical": true, "font_size": 24, "lines_coords": [[[260.0, 785.0], [287.0, 785.0], [290.0, 939.0], [264.0, 939.0]], [[232.0, 790.0], [254.0, 790.0], [254.0, 920.0], [232.0, 920.0]]], "lines": ["あのコの家は", "ココだもん。"]}, {"box": [411, 1276, 500, 1429], "vertical": true, "font_size": 27, "lines_coords": [[[468.0, 1276.0], [496.0, 1276.0], [500.0, 1381.0], [471.0, 1381.0]], [[442.0, 1276.0], [468.0, 1276.0], [468.0, 1429.0], [442.0, 1429.0]], [[411.0, 1279.0], [432.0, 1279.0], [432.0, 1404.0], [411.0, 1404.0]]], "lines": ["タエこそ", "ちゃんと勉強", "してんの？"]}, {"box": [204, 1318, 230, 1456], "vertical": true, "font_size": 22, "lines_coords": [[[204.0, 1318.0], [226.0, 1318.0], [226.0, 1456.0], [204.0, 1456.0]]], "lines": ["してないス。"]}]}