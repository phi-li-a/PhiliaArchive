{"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [698, 78, 788, 305], "vertical": true, "font_size": 25, "lines_coords": [[[765.0, 81.0], [787.0, 81.0], [787.0, 304.0], [765.0, 304.0]], [[728.0, 78.0], [754.0, 78.0], [757.0, 304.0], [731.0, 304.0]], [[698.0, 81.0], [725.0, 81.0], [725.0, 218.0], [698.0, 218.0]]], "lines": ["たとえ今日が雨でも", "そのうち晴れの日が", "くるワケて"]}, {"box": [315, 78, 468, 379], "vertical": true, "font_size": 26, "lines_coords": [[[442.0, 78.0], [468.0, 78.0], [468.0, 301.0], [442.0, 301.0]], [[409.0, 79.0], [436.0, 79.0], [436.0, 285.0], [409.0, 285.0]], [[376.0, 78.0], [404.0, 78.0], [406.0, 379.0], [378.0, 379.0]], [[346.0, 78.0], [373.0, 78.0], [373.0, 310.0], [346.0, 310.0]], [[315.0, 81.0], [337.0, 81.0], [337.0, 273.0], [315.0, 273.0]]], "lines": ["だから今のあたしの", "このローな気分も、", "いつか晴れやかになるって", "信じてるんだけどね", "信じてるんだけどさ"]}, {"box": [925, 404, 948, 534], "vertical": true, "font_size": 22, "lines_coords": [[[925.0, 404.0], [947.0, 404.0], [947.0, 531.0], [925.0, 531.0]]], "lines": ["うーん．．．"]}, {"box": [628, 742, 725, 850], "vertical": true, "font_size": 33, "lines_coords": [[[686.0, 742.0], [725.0, 742.0], [725.0, 828.0], [686.0, 828.0]], [[656.0, 743.0], [689.0, 742.0], [692.0, 848.0], [659.0, 850.0]], [[628.0, 745.0], [656.0, 745.0], [656.0, 850.0], [628.0, 850.0]]], "lines": ["あれ？", "兄ちゃん", "大学は？"]}, {"box": [182, 509, 240, 686], "vertical": true, "font_size": 28, "lines_coords": [[[212.0, 510.0], [240.0, 510.0], [240.0, 610.0], [212.0, 610.0]], [[182.0, 509.0], [209.0, 509.0], [209.0, 612.0], [182.0, 612.0]]], "lines": ["ユーウツ", "なりぃー"]}, {"box": [843, 798, 993, 1039], "vertical": true, "font_size": 27, "lines_coords": [[[965.0, 800.0], [992.0, 800.0], [992.0, 976.0], [965.0, 976.0]], [[933.0, 798.0], [961.0, 798.0], [964.0, 939.0], [936.0, 939.0]], [[900.0, 798.0], [931.0, 798.0], [931.0, 1039.0], [900.0, 1039.0]], [[872.0, 801.0], [898.0, 801.0], [898.0, 987.0], [872.0, 987.0]], [[843.0, 803.0], [865.0, 803.0], [865.0, 985.0], [843.0, 985.0]]], "lines": ["なぜかイライラ", "するワケさ。", "特に、ねーちゃんとか", "ねーちゃんとか、", "ねーちゃんとか。"]}, {"box": [164, 810, 220, 950], "vertical": true, "font_size": 27, "lines_coords": [[[193.0, 810.0], [220.0, 810.0], [220.0, 926.0], [193.0, 926.0]], [[164.0, 810.0], [190.0, 810.0], [190.0, 950.0], [164.0, 950.0]]], "lines": ["おう、今日", "休講ってさ。"]}, {"box": [145, 998, 237, 1150], "vertical": true, "font_size": 27, "lines_coords": [[[203.0, 1001.0], [237.0, 1001.0], [237.0, 1092.0], [203.0, 1092.0]], [[175.0, 1000.0], [201.0, 1000.0], [201.0, 1129.0], [175.0, 1129.0]], [[145.0, 998.0], [167.0, 998.0], [167.0, 1150.0], [145.0, 1150.0]]], "lines": ["つーか、", "おまえこそ", "予備校はよ？"]}, {"box": [753, 1168, 877, 1431], "vertical": true, "font_size": 25, "lines_coords": [[[851.0, 1171.0], [873.0, 1171.0], [873.0, 1320.0], [851.0, 1320.0]], [[820.0, 1171.0], [842.0, 1171.0], [842.0, 1429.0], [820.0, 1429.0]], [[787.0, 1170.0], [814.0, 1170.0], [814.0, 1407.0], [787.0, 1407.0]], [[753.0, 1168.0], [781.0, 1168.0], [782.0, 1420.0], [754.0, 1420.0]]], "lines": ["なんてだろ？", "一感謝してるつもりだけどさ、", "きっと雨が悪いんだ。", "梅雨、死ねってことで。"]}, {"box": [156, 1328, 251, 1493], "vertical": true, "font_size": 28, "lines_coords": [[[218.0, 1328.0], [251.0, 1328.0], [251.0, 1420.0], [218.0, 1420.0]], [[189.0, 1329.0], [215.0, 1329.0], [215.0, 1459.0], [189.0, 1459.0]], [[156.0, 1328.0], [182.0, 1328.0], [185.0, 1493.0], [159.0, 1493.0]]], "lines": ["んー、", "だるいから", "今日はパスで。"]}]}