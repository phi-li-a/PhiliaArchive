{"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [990, 109, 1018, 220], "vertical": true, "font_size": 25, "lines_coords": [[[990.0, 109.0], [1018.0, 109.0], [1018.0, 220.0], [990.0, 220.0]]], "lines": ["やーだよ"]}, {"box": [958, 254, 1042, 475], "vertical": true, "font_size": 25, "lines_coords": [[[1017.0, 259.0], [1040.0, 259.0], [1042.0, 475.0], [1018.0, 475.0]], [[986.0, 254.0], [1012.0, 254.0], [1014.0, 462.0], [987.0, 462.0]], [[958.0, 260.0], [979.0, 260.0], [979.0, 385.0], [958.0, 385.0]]], "lines": ["おまえと会社作って", "どうのこうのって", "ヤツだろ？"]}, {"box": [565, 148, 623, 323], "vertical": true, "font_size": 26, "lines_coords": [[[593.0, 148.0], [622.0, 148.0], [623.0, 276.0], [595.0, 276.0]], [[565.0, 150.0], [587.0, 150.0], [587.0, 323.0], [565.0, 323.0]]], "lines": ["．．．いやっ？", "わかんねーよ？"]}, {"box": [104, 273, 198, 495], "vertical": true, "font_size": 27, "lines_coords": [[[167.0, 273.0], [193.0, 273.0], [198.0, 443.0], [171.0, 443.0]], [[134.0, 275.0], [162.0, 275.0], [167.0, 495.0], [139.0, 495.0]], [[104.0, 276.0], [131.0, 276.0], [134.0, 493.0], [107.0, 493.0]]], "lines": ["「自分はきっと", "やればできる」って", "思ってるヤツほど、"]}, {"box": [737, 509, 794, 673], "vertical": true, "font_size": 24, "lines_coords": [[[767.0, 509.0], [793.0, 509.0], [793.0, 673.0], [767.0, 673.0]], [[737.0, 512.0], [759.0, 512.0], [759.0, 670.0], [737.0, 670.0]]], "lines": ["だって、おまえ", "ハカじゃんよ。"]}, {"box": [534, 373, 625, 556], "vertical": true, "font_size": 26, "lines_coords": [[[598.0, 373.0], [625.0, 373.0], [625.0, 550.0], [598.0, 550.0]], [[567.0, 373.0], [589.0, 373.0], [589.0, 556.0], [567.0, 556.0]], [[534.0, 373.0], [562.0, 373.0], [562.0, 453.0], [534.0, 453.0]]], "lines": ["やってやれない", "ことはないかも", "だろ？"]}, {"box": [118, 537, 212, 670], "vertical": true, "font_size": 27, "lines_coords": [[[184.0, 542.0], [212.0, 542.0], [212.0, 659.0], [184.0, 659.0]], [[151.0, 540.0], [179.0, 540.0], [176.0, 670.0], [148.0, 670.0]], [[118.0, 537.0], [145.0, 537.0], [148.0, 656.0], [121.0, 65