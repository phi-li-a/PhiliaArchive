{"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [815, 85, 970, 262], "vertical": true, "font_size": 27, "lines_coords": [[[943.0, 87.0], [970.0, 87.0], [970.0, 225.0], [943.0, 225.0]], [[909.0, 85.0], [940.0, 85.0], [940.0, 251.0], [909.0, 251.0]], [[878.0, 87.0], [904.0, 87.0], [904.0, 212.0], [878.0, 212.0]], [[847.0, 85.0], [873.0, 85.0], [873.0, 262.0], [847.0, 262.0]], [[815.0, 85.0], [842.0, 85.0], [842.0, 193.0], [815.0, 193.0]]], "lines": ["援交やって、", "クスリやって、", "ホームレス", "ボコボコに殴り", "まわして、"]}, {"box": [689, 282, 843, 448], "vertical": true, "font_size": 27, "lines_coords": [[[811.0, 284.0], [843.0, 284.0], [843.0, 367.0], [811.0, 367.0]], [[776.0, 282.0], [809.0, 282.0], [809.0, 439.0], [776.0, 439.0]], [[750.0, 285.0], [776.0, 285.0], [776.0, 392.0], [750.0, 392.0]], [[720.0, 287.0], [742.0, 287.0], [742.0, 410.0], [720.0, 410.0]], [[689.0, 285.0], [711.0, 285.0], [711.0, 448.0], [689.0, 448.0]]], "lines": ["最高に", "楽しいんじゃ", "ねぇの？", "おまえらの", "年頃なんてよ。"]}, {"box": [150, 98, 240, 274], "vertical": true, "font_size": 23, "lines_coords": [[[210.0, 98.0], [237.0, 98.0], [237.0, 226.0], [210.0, 226.0]], [[181.0, 100.0], [203.0, 100.0], [203.0, 273.0], [181.0, 273.0]], [[150.0, 100.0], [171.0, 100.0], [171.0, 195.0], [150.0, 195.0]]], "lines": ["それが案外", "そうでもないん", "だよねー"]}, {"box": [442, 387, 567, 577], "vertical": true, "font_size": 25, "lines_coords": [[[540.0, 392.0], [562.0, 392.0], [562.0, 540.0], [540.0, 540.0]], [[507.0, 389.0], [534.0, 389.0], [532.0, 575.0], [506.0, 575.0]], [[475.0, 392.0], [501.0, 392.0], [501.0, 568.0], [475.0, 568.0]], [[445.0, 387.0], [471.0, 387.0], [468.0, 543.0], [442.0, 543.0]]], "lines": ["好きほうだい", "やってるくせに、", "一人前に悩みも", "あるってか？"]}, {"box": [840, 1071, 962, 1301], "vertical": true, "font_size": 26, "lines_coords": [[[936.0, 1073.0], [962.0, 1073.0], [962.0, 1251.0], [936.0, 1251.0]], [[903.0, 1075.0], [929.0, 1075.0], [928.0, 1300.0], [901.0, 1300.0]], [[870.0, 1071.0], [897.0, 1071.0], [897.0, 1301.0], [870.0, 1301.0]], [[840.0, 1073.0], [867.0, 1073.0], [867.0, 1237.0], [840.0, 1237.0]]], "lines": ["あたしの友達で", "自分の親と同い年の", "先生とつき合ってる", "コがいるんだ。"]}, {"box": [276, 746, 368, 917], "vertical": true, "font_size": 27, "lines_coords": [[[331.0, 748.0], [364.0, 746.0], [368.0, 842.0], [336.0, 843.0]], [[304.0, 751.0], [331.0, 751.0], [334.0, 909.0], [307.0, 909.0]], [[276.0, 751.0], [298.0, 751.0], [300.0, 917.0], [278.0, 917.0]]], "lines": ["そうだ。", "おもしろい話", "してあげるよ。"]}, {"box": [718, 1245, 839, 1462], "vertical": true, "font_size": 26, "lines_coords": [[[817.0, 1246.0], [839.0, 1246.0], [839.0, 1348.0], [817.0, 1348.0]], [[781.0, 1245.0], [807.0, 1245.0], [811.0, 1462.0], [784.0, 1462.0]], [[751.0, 1248.0], [778.0, 1248.0], [778.0, 1428.0], [751.0, 1428.0]], [[718.0, 1246.0], [745.0, 1246.0], [745.0, 1435.0], [718.0, 1435.0]]], "lines": ["まんまと", "子供できちゃって、", "もちろん相手は", "妻子持ちなワケ。"]}, {"box": [123, 1254, 276, 1496], "vertical": true, "font_size": 26, "lines_coords": [[[248.0, 1254.0], [275.0, 1254.0], [275.0, 1393.0], [248.0, 1393.0]], [[215.0, 1254.0], [242.0, 1254.0], [242.0, 1495.0], [215.0, 1495.0]], [[182.0, 1254.0], [209.0, 1254.0], [209.0, 1460.0], [182.0, 1460.0]], [[151.0, 1254.0], [178.0, 1254.0], [178.0, 1434.0], [151.0, 1434.0]], [[123.0, 1257.0], [145.0, 1257.0], [145.0, 1412.0], [123.0, 1412.0]]], "lines": ["でもそのコ、", "怖くて言い出せなくて", "先生の部屋の前を", "行ったり来たり", "しちゃってさ。"]}]}