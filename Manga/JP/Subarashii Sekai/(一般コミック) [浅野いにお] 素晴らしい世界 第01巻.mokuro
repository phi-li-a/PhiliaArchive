, 92, 1001, 307], "vertical": true, "font_size": 26, "lines_coords": [[[975.0, 92.0], [1001.0, 92.0], [1001.0, 218.0], [975.0, 218.0]], [[945.0, 93.0], [967.0, 93.0], [967.0, 307.0], [945.0, 307.0]], [[912.0, 92.0], [934.0, 92.0], [934.0, 268.0], [912.0, 268.0]], [[878.0, 93.0], [904.0, 93.0], [904.0, 271.0], [878.0, 271.0]], [[848.0, 92.0], [872.0, 92.0], [873.0, 267.0], [850.0, 267.0]]], "lines": ["そしてその", "女王様は、みんなを", "まとめるために", "おまえみたいな", "悪役を作る、と。"]}, {"box": [487, 100, 517, 265], "vertical": true, "font_size": 28, "lines_coords": [[[487.0, 100.0], [515.0, 100.0], [517.0, 262.0], [489.0, 262.0]]], "lines": ["くだらねぇよ。"]}, {"box": [206, 95, 293, 257], "vertical": true, "font_size": 27, "lines_coords": [[[265.0, 95.0], [293.0, 95.0], [293.0, 195.0], [265.0, 195.0]], [[235.0, 95.0], [264.0, 95.0], [264.0, 198.0], [235.0, 198.0]], [[206.0, 96.0], [228.0, 96.0], [228.0, 257.0], [206.0, 257.0]]], "lines": ["やり方が", "いちいち", "ガキ臭いしな。"]}, {"box": [820, 332, 945, 492], "vertical": true, "font_size": 26, "lines_coords": [[[923.0, 342.0], [945.0, 342.0], [945.0, 492.0], [923.0, 492.0]], [[887.0, 335.0], [920.0, 335.0], [920.0, 420.0], [887.0, 420.0]], [[859.0, 339.0], [881.0, 339.0], [881.0, 489.0], [859.0, 489.0]], [[820.0, 334.0], [854.0, 332.0], [858.0, 406.0], [823.0, 407.0]]], "lines": ["ガキの社会は", "まるで", "世の中の縮図", "だな。"]}, {"box": [883, 635, 978, 789], "vertical": true, "font_size": 30, "lines_coords": [[[950.0, 635.0], [978.0, 635.0], [978.0, 743.0], [950.0, 743.0]], [[915.0, 635.0], [943.0, 635.0], [947.0, 789.0], [918.0, 789.0]], [[883.0, 635.0], [915.0, 635.0], [915.0, 743.0], [883.0, 743.0]]], "lines": ["ぎゃは！", "丁度いいじゃ", "ないの！"]}, {"box": [93, 296, 253, 515], "vertical": true, "font_size": 27, "lines_coords": [[[221.0, 296.0], [248.0, 296.0], [253.0, 504.0], [226.0, 504.0]], [[189.0, 298.0], [217.0, 298.0], [218.0, 429.0], [190.0, 429.0]], [[159.0, 298.0], [185.0, 298.0], [187.0, 515.0], [160.0, 515.0]], [[126.0, 300.0], [153.0, 300.0], [156.0, 435.0], [129.0, 435.0]