7.0, 95.0], [187.0, 278.0], [156.0, 278.0]], [[121.0, 93.0], [160.0, 93.0], [160.0, 145.0], [121.0, 145.0]]], "lines": ["じゃ、そーとー", "嫌われてんのな", "俺。"]}, {"box": [540, 385, 634, 501], "vertical": true, "font_size": 28, "lines_coords": [[[606.0, 389.0], [634.0, 389.0], [634.0, 467.0], [606.0, 467.0]], [[573.0, 387.0], [601.0, 387.0], [603.0, 501.0], [575.0, 501.0]], [[540.0, 385.0], [568.0, 385.0], [570.0, 493.0], [542.0, 493.0]]], "lines": ["．．．．．．", "おまえ、曲", "聴いた？"]}, {"box": [203, 485, 231, 575], "vertical": true, "font_size": 25, "lines_coords": [[[203.0, 485.0], [231.0, 485.0], [231.0, 575.0], [203.0, 575.0]]], "lines": ["聴いた。"]}, {"box": [167, 589, 189, 728], "vertical": true, "font_size": 25, "lines_coords": [[[167.0, 589.0], [189.0, 589.0], [189.0, 728.0], [167.0, 728.0]]], "lines": ["よかったよ。"]}, {"box": [781, 790, 970, 971], "vertical": true, "font_size": 28, "lines_coords": [[[937.0, 792.0], [970.0, 792.0], [970.0, 882.0], [937.0, 882.0]], [[908.0, 792.0], [934.0, 792.0], [934.0, 948.0], [908.0, 948.0]], [[876.0, 790.0], [903.0, 790.0], [900.0, 971.0], [873.0, 971.0]], [[843.0, 793.0], [872.0, 793.0], [872.0, 895.0], [843.0, 895.0]], [[814.0, 792.0], [840.0, 792.0], [840.0, 970.0], [814.0, 970.0]], [[781.0, 792.0], [807.0, 792.0], [807.0, 907.0], [781.0, 907.0]]], "lines": ["あれな、", "作詞も作曲も", "演奏もぜーんぶ", "スタジオ", "ミュージシャン", "だってよ。"]}, {"box": [275, 821, 337, 928], "vertical": true, "font_size": 26, "lines_coords": [[[304.0, 821.0], [337.0, 821.0], [337.0, 928.0], [304.0, 928.0]], [[275.0, 823.0], [301.0, 823.0], [301.0, 928.0], [275.0, 928.0]]], "lines": ["プロって", "怖いねー"]}, {"box": [165, 951, 287, 1140], "vertical": true, "font_size": 26, "lines_coords": [[[259.0, 951.0], [287.0, 951.0], [284.0, 1107.0], [256.0, 1107.0]], [[228.0, 956.0], [250.0, 956.0], [250.0, 1079.0], [228.0, 1079.0]], [[193.0, 954.0], [220.0, 954.0], [220.0, 1056.0], [193.0, 1056.0]], [[165.0, 954.0], [187.0, 954.0], [187.0, 1140.0], [165.0, 1140.0]]], "lines": ["言っちゃえば", "あのＣＤは", "カラオケ", "みたいなもんよ。"]}, {"box": [739, 1181, 895, 1387], "vertical": true, "font_size": 26, "lines_coords": [[[862.0, 1181.0], [895.0, 1181.0], [895.0, 1270.0], [862.0, 1270.0]], [[836.0, 1184.0], [858.0, 1184.0], [858.0, 1309.0], [836.0, 1309.0]], [[801.0, 1182.0], [828.0, 1182.0], [828.0, 1310.0], [801.0, 1310.0]], [[772.0, 1184.0], [793.0, 1184.0], [793.0, 1356.0], [772.0, 1356.0]], [[739.0, 1182.0], [767.0, 1182.0], [767.0, 1271.0], [739.0, 1271.0]]], "lines": ["だから、", "おまえには", "情けなくて", "聴かせらんねー", "ってさ。"]}], "img_path": "subarashii_sekai_01_108.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [823, 168, 945, 308], "vertical": true, "font_size": 26, "lines_coords": [[[915.0, 170.0], [943.0, 170.0], [943.0, 271.0], [915.0, 271.0]], [[883.0, 168.0], [915.0, 168.0], [915.0, 251.0], [883.0, 251.0]], [[853.0, 170.0], [879.0, 170.0], [876.0, 298.0], [850.0, 298.0]], [[823.0, 170.0], [843.0, 170.0], [843.0, 303.0], [823.0, 303.0]]], "lines": ["メンバー", "みんな", "口そろえて", "言うワケよ。"]}, {"box": [112, 50, 357, 85], "vertical": false, "font_size": 32, "lines_coords": [[[112.0, 50.0], [357.0, 53.0], [357.0, 85.0], [112.0, 82.0]]], "lines": ["素晴らしい世界で"]}, {"box": [231, 198, 354, 360], "vertical": true, "font_size": 28, "lines_coords": [[[326.0, 200.0], [354.0, 200.0], [351.0, 315.0], [323.0, 315.0]], [[295.0, 200.0], [321.0, 200.0], [321.0, 360.0], [295.0, 360.0]], [[259.0, 198.0], [293.0, 198.0], [293.0, 279.0], [259.0, 279.0]], [[231.0, 200.0], [257.0, 200.0], [257.0, 340.0], [231.0, 340.0]]], "lines": ["「夢なんて", "手に入れたら、", "ただの", "現実だった」"]}, {"box": [215, 409, 243, 496], "vertical": true, "font_size": 28, "lines_coords": [[[215.0, 409.0], [243.0, 409.0], [243.0, 496.0], [215.0, 496.0]]], "lines": ["ってな。"]}, {"box": [818, 1164, 854, 1223], "vertical": true, "font_size": 36, "lines_coords": [[[818.0, 1164.0], [854.0, 1164.0], [854.0, 1223.0], [818.0, 1223.0]]], "lines": ["ん？"]}, {"box": [290, 867, 318, 968], "vertical": true, "font_size": 28, "lines_coords": [[[290.0, 867.0], [318.0, 867.0], [318.0, 965.0], [290.0, 965.0]]], "lines": ["ファ．．．"]}], "img_path": "subarashii_sekai_01_109.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [564, 867, 626, 1021], "vertical": true, "font_size": 28, "lines_coords": [[[597.0, 868.0], [623.0, 868.0], [626.0, 1021.0], [600.0, 1021.0]], [[564.0, 867.0], [590.0, 867.0], [595.0, 1009.0], [568.0, 1009.0]]], "lines": ["なんだろうね", "この感じは。"]}, {"box": [439, 868, 531, 1042], "vertical": true, "font_size": 28, "lines_coords": [[[500.0, 870.0], [528.0, 870.0], [531.0, 1042.0], [503.0, 1042.0]], [[467.0, 868.0], [500.0, 868.0], [500.0, 962.0], [467.0, 962.0]], [[439.0, 870.0], [465.0, 870.0], [465.0, 1010.0], [439.0, 1010.0]]], "lines": ["やりきれないっ", "つうか、", "なんつうか。"]}, {"box": [232, 1381, 278, 1442], "vertical": true, "font_size": 38, "lines_coords": [[[232.0, 1385.0], [270.0, 1381.0], [278.0, 1437.0], [240.0, 1442.0]]], "lines": ["あ。"]}], "img_path": "subarashii_sekai_01_110.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [876, 110, 906, 203], "vertical": true, "font_size": 28, "lines_coords": [[[876.0, 110.0], [904.0, 110.0], [906.0, 203.0], [878.0, 203.0]]], "lines": ["あはは。"]}, {"box": [115, 51, 343, 84], "vertical": false, "font_size": 33, "lines_coords": [[[115.0, 51.0], [343.0, 51.0], [343.0, 84.0], [115.0, 84.0]]], "lines": ["素晴らしい世界"]}, {"box": [157, 278, 248, 431], "vertical": true, "font_size": 27, "lines_coords": [[[220.0, 279.0], [246.0, 279.0], [246.0, 392.0], [220.0, 392.0]], [[189.0, 279.0], [215.0, 279.0], [215.0, 431.0], [189.0, 431.0]], [[157.0, 278.0], [185.0, 278.0], [185.0, 389.0], [157.0, 389.0]]], "lines": ["なーんだ、", "戻ってきてん", "じゃーん。"]}, {"box": [851, 521, 915, 638], "vertical": true, "font_size": 32, "lines_coords": [[[876.0, 523.0], [912.0, 521.0], [915.0, 603.0], [879.0, 604.0]], [[851.0, 523.0], [878.0, 523.0], [878.0, 637.0], [851.0, 637.0]]], "lines": ["だって", "あたしさ。"]}, {"box": [182, 576, 270, 740], "vertical": true, "font_size": 27, "lines_coords": [[[240.0, 578.0], [267.0, 578.0], [270.0, 726.0], [243.0, 726.0]], [[209.0, 576.0], [242.0, 576.0], [242.0, 667.0], [209.0, 667.0]], [[182.0, 579.0], [204.0, 579.0], [204.0, 734.0], [182.0, 734.0]]], "lines": ["他に帰るトコ", "なんて、", "ないじゃんか"]}, {"box": [603, 795, 665, 884], "vertical": true, "font_size": 31, "lines_coords": [[[631.0, 795.0], [665.0, 795.0], [665.0, 878.0], [631.0, 878.0]], [[603.0, 796.0], [631.0, 796.0], [631.0, 884.0], [603.0, 884.0]]], "lines": ["なんも", "言わん。"]}, {"box": [148, 870, 175, 984], "vertical": true, "font_size": 27, "lines_coords": [[[148.0, 870.0], [175.0, 870.0], [175.0, 984.0], [148.0, 984.0]]], "lines": ["さぁ来い。"]}], "img_path": "subarashii_sekai_01_111.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [734, 139, 825, 453], "vertical": true, "font_size": 23, "lines_coords": [[[800.0, 142.0], [822.0, 142.0], [822.0, 421.0], [800.0, 421.0]], [[764.0, 139.0], [790.0, 139.0], [793.0, 293.0], [767.0, 293.0]], [[734.0, 140.0], [756.0, 140.0], [759.0, 448.0], [737.0, 448.0]]], "lines": ["夢は見ている時だけが夢", "目が覚めれば", "そこにあるのはただの現実"]}, {"box": [545, 138, 604, 503], "vertical": true, "font_size": 24, "lines_coords": [[[578.0, 139.0], [600.0, 139.0], [603.0, 264.0], [581.0, 264.0]], [[545.0, 139.0], [570.0, 139.0], [573.0, 501.0], [548.0, 501.0]]], "lines": ["そんなこと", "わかってたつもりだったのにさ。"]}, {"box": [384, 139, 444, 453], "vertical": true, "font_size": 22, "lines_coords": [[[420.0, 142.0], [442.0, 142.0], [442.0, 337.0], [420.0, 337.0]], [[384.0, 139.0], [406.0, 139.0], [411.0, 446.0], [389.0, 446.0]]], "lines": ["ちょっと油断して", "うたた寝しちゃったワケさ"]}, {"box": [195, 442, 315, 693], "vertical": true, "font_size": 23, "lines_coords": [[[289.0, 442.0], [312.0, 442.0], [314.0, 684.0], [290.0, 684.0]], [[257.0, 442.0], [284.0, 442.0], [284.0, 568.0], [257.0, 568.0]], [[228.0, 443.0], [250.0, 443.0], [250.0, 590.0], [228.0, 590.0]], [[195.0, 442.0], [215.0, 442.0], [215.0, 637.0], [195.0, 637.0]]], "lines": ["でも、よーく考えてみ", "今の俺って", "すっごく幸せ", "なんじゃないの？"]}, {"box": [664, 878, 691, 992], "vertical": true, "font_size": 26, "lines_coords": [[[664.0, 878.0], [690.0, 878.0], [690.0, 992.0], [664.0, 992.0]]], "lines": ["あ、いく♡"]}, {"box": [349, 749, 470, 953], "vertical": true, "font_size": 25, "lines_coords": [[[442.0, 751.0], [468.0, 751.0], [468.0, 907.0], [442.0, 907.0]], [[411.0, 751.0], [437.0, 751.0], [437.0, 951.0], [411.0, 951.0]], [[378.0, 751.0], [404.0, 751.0], [404.0, 853.0], [378.0, 853.0]], [[350.0, 753.0], [371.0, 753.0], [371.0, 884.0], [350.0, 884.0]]], "lines": ["騎乗位の最中、", "ぽんやりと天井を", "見ながら", "そう思った。"]}, {"box": [242, 1357, 293, 1423], "vertical": true, "font_size": 44, "lines_coords": [[[242.0, 1364.0], [286.0, 1357.0], [293.0, 1417.0], [250.0, 1423.0]]], "lines": ["む。"]}], "img_path": "subarashii_sekai_01_112.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [858, 132, 920, 260], "vertical": true, "font_size": 31, "lines_coords": [[[893.0, 135.0], [920.0, 135.0], [920.0, 260.0], [893.0, 260.0]], [[858.0, 132.0], [893.0, 132.0], [893.0, 203.0], [858.0, 203.0]]], "lines": ["素晴らしい", "朝だ。"]}, {"box": [206, 131, 307, 262], "vertical": true, "font_size": 30, "lines_coords": [[[264.0, 131.0], [307.0, 131.0], [307.0, 193.0], [264.0, 193.0]], [[240.0, 137.0], [267.0, 137.0], [267.0, 262.0], [240.0, 262.0]], [[206.0, 134.0], [232.0, 134.0], [232.0, 248.0], [206.0, 248.0]]], "lines": ["かつ", "素晴らしい", "目覚めた。"]}, {"box": [826, 692, 920, 873], "vertical": true, "font_size": 29, "lines_coords": [[[892.0, 696.0], [918.0, 696.0], [918.0, 846.0], [892.0, 846.0]], [[861.0, 695.0], [887.0, 695.0], [887.0, 873.0], [861.0, 873.0]], [[826.0, 692.0], [861.0, 692.0], [861.0, 762.0], [826.0, 762.0]]], "lines": ["そしてひとつ", "わかったことが", "ある。"]}, {"box": [181, 315, 240, 493], "vertical": true, "font_size": 30, "lines_coords": [[[212.0, 315.0], [239.0, 315.0], [240.0, 493.0], [214.0, 493.0]], [[181.0, 317.0], [207.0, 317.0], [207.0, 429.0], [181.0, 429.0]]], "lines": ["生まれ変わった", "気分だね。"]}, {"box": [150, 840, 302, 1067], "vertical": true, "font_size": 24, "lines_coords": [[[275.0, 842.0], [301.0, 842.0], [301.0, 968.0], [275.0, 968.0]], [[242.0, 840.0], [268.0, 840.0], [268.0, 1043.0], [242.0, 1043.0]], [[210.0, 840.0], [237.0, 840.0], [237.0, 953.0], [210.0, 953.0]], [[181.0, 842.0], [203.0, 842.0], [203.0, 1065.0], [181.0, 1065.0]], [[150.0, 842.0], [171.0, 842.0], [171.0, 1026.0], [150.0, 1026.0]]], "lines": ["問題なのは", "どこで生きるのか", "じゃなく、", "そこでどう生きるか", "ってことなのな。"]}, {"box": [856, 1223, 950, 1363], "vertical": true, "font_size": 27, "lines_coords": [[[922.0, 1225.0], [950.0, 1225.0], [950.0, 1340.0], [922.0, 1340.0]], [[889.0, 1225.0], [915.0, 1225.0], [915.0, 1326.0], [889.0, 1326.0]], [[859.0, 1223.0], [886.0, 1223.0], [883.0, 1359.0], [856.0, 1359.0]]], "lines": ["ホレ、これ", "ライブの", "チケットな。"]}, {"box": [195, 1306, 253, 1429], "vertical": true, "font_size": 25, "lines_coords": [[[226.0, 1307.0], [250.0, 1307.0], [253.0, 1428.0], [229.0, 1428.0]], [[195.0, 1306.0], [221.0, 1306.0], [221.0, 1393.0], [195.0, 1393.0]]], "lines": ["行きたきゃ", "行きな。"]}], "img_path": "subarashii_sekai_01_113.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [800, 114, 980, 395], "vertical": true, "font_size": 28, "lines_coords": [[[948.0, 117.0], [975.0, 117.0], [975.0, 228.0], [948.0, 228.0]], [[931.0, 242.0], [959.0, 243.0], [953.0, 368.0], [925.0, 367.0]], [[898.0, 242.0], [922.0, 242.0], [920.0, 395.0], [897.0, 395.0]], [[864.0, 243.0], [890.0, 243.0], [890.0, 370.0], [864.0, 370.0]], [[834.0, 240.0], [861.0, 240.0], [858.0, 392.0], [831.0, 392.0]], [[800.0, 240.0], [834.0, 237.0], [839.0, 284.0], [804.0, 287.0]]], "lines": ["つーかさ。", "カッコいい", "今のおまえを", "あいつらに", "見せてやれっ", "て。"]}, {"box": [784, 671, 814, 762], "vertical": true, "font_size": 28, "lines_coords": [[[784.0, 671.0], [812.0, 671.0], [814.0, 762.0], [786.0, 762.0]]], "lines": ["おうよ。"]}, {"box": [661, 982, 790, 1210], "vertical": 