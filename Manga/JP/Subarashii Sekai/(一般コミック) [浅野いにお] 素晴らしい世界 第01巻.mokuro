332.0], [889.0, 332.0]]], "lines": ["よいしょい！！"]}, {"box": [740, 582, 868, 799], "vertical": true, "font_size": 30, "lines_coords": [[[840.0, 587.0], [867.0, 587.0], [867.0, 714.0], [840.0, 714.0]], [[809.0, 585.0], [837.0, 585.0], [832.0, 793.0], [804.0, 793.0]], [[773.0, 582.0], [804.0, 582.0], [801.0, 789.0], [770.0, 789.0]], [[743.0, 582.0], [776.0, 582.0], [773.0, 696.0], [740.0, 696.0]]], "lines": ["俺が彼女と", "セックスしてる時、", "アメリカでヒルが", "崩壊した。"]}, {"box": [673, 584, 703, 827], "vertical": true, "font_size": 26, "lines_coords": [[[675.0, 584.0], [701.0, 584.0], [700.0, 821.0], [673.0, 821.0]]], "lines": ["もうだいぶ前の話だ。"]}, {"box": [315, 582, 504, 839], "vertical": true, "font_size": 29, "lines_coords": [[[476.0, 584.0], [503.0, 584.0], [500.0, 839.0], [473.0, 839.0]], [[442.0, 585.0], [470.0, 585.0], [470.0, 714.0], [442.0, 714.0]], [[407.0, 582.0], [439.0, 582.0], [439.0, 800.0], [407.0, 800.0]], [[378.0, 582.0], [409.0, 582.0], [406.0, 765.0], [375.0, 765.0]], [[346.0, 584.0], [375.0, 584.0], [371.0, 739.0], [343.0, 739.0]], [[315.0, 585.0], [342.0, 585.0], [342.0, 820.0], [315.0, 820.0]]], "lines": ["今でもどっかの国では", "ミサイルが", "バリバリ飛んでて、", "どっかの国では", "飢餓で子供が", "バタバタ死んでんだ。"]}, {"box": [872, 1109, 908, 1179], "vertical": true, "font_size": 36, "lines_coords": [[[872.0, 1109.0], [908.0, 1109.0], [908.0, 1179.0], [872.0, 1179.0]]], "lines": ["あ？"]}, {"box": [203, 820, 236, 1001], "vertical": true, "font_size": 32, "lines_coords": [[[203.0, 820.0], [235.0, 820.0], [235.0, 932.0], [203.0, 932.0]]], "lines": ["ホズミー"]}, {"box": [500, 1492, 1009, 1528], "vertical": false, "font_size": 32, "lines_coords": [[[500.0, 1496.0], [1009.0, 1492.0], [1009.0, 1523.0], [500.0, 1528.0]]], "lines": ["５ｔｈｐｒｏｇｒａｍ白い星、黒い星"]}, {"box": [184, 1315, 279, 1477], "vertical": true, "font_size": 29, "lines_coords": [[[248.0, 1318.0], [275.0, 1318.0], [275.0, 1473.0], [248.0, 1473.0]], [[217.0, 1317.0], [243.0, 1317.0], [246.0, 1468.0], [220.0, 1468.0]], [[184.0, 1315.0], [217.0, 1315.0], [217.0, 1398.0], [184.0, 1398.0]]], "lines": ["ノダくんの腕", "折っちゃって", "いい？"]}], "img_path": "subarashii_sekai_01_117.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [803, 84, 890, 249], "vertical": true, "font_size": 24, "lines_coords": [[[862.0, 84.0], [890.0, 84.0], [890.0, 165.0], [862.0, 165.0]], [[834.0, 87.0], [856.0, 87.0], [856.0, 237.0], [834.0, 237.0]], [[803.0, 87.0], [825.0, 87.0], [825.0, 248.0], [803.0, 248.0]]], "lines": ["あんま", "目立つことは", "やめとけって。"]}, {"box": [604, 689, 662, 905], "vertical": true, "font_size": 24, "lines_coords": [[[636.0, 689.0], [662.0, 689.0], [662.0, 800.0], [636.0, 800.0]], [[604.0, 690.0], [626.0, 690.0], [629.0, 898.0], [607.0, 898.0]]], "lines": ["というか、", "どうしようもない。"]}, {"box": [536, 689, 562, 841], "vertical": true, "font_size": 26, "lines_coords": [[[536.0, 689.0], [562.0, 689.0], [562.0, 839.0], [536.0, 839.0]]], "lines": ["というか．．．"]}, {"box": [156, 393, 316, 573], "vertical": true, "font_size": 27, "lines_coords": [[[287.0, 396.0], [314.0, 396.0], [314.0, 559.0], [287.0, 559.0]], [[254.0, 396.0], [281.0, 396.0], [281.0, 501.0], [254.0, 501.0]], [[221.0, 395.0], [248.0, 395.0], [248.0, 531.0], [221.0, 531.0]], [[193.0, 400.0], [215.0, 400.0], [215.0, 573.0], [193.0, 573.0]], [[156.0, 393.0], [190.0, 393.0], [190.0, 464.0], [156.0, 464.0]]], "lines": ["だってコイツ、", "全然抵抗", "しねぇから、", "つまんねえんだ", "もん。"]}, {"box": [245, 685, 336, 864], "vertical": true, "font_size": 27, "lines_coords": [[[307.0, 685.0], [334.0, 685.0], [334.0, 862.0], [307.0, 862.0]], [[276.0, 687.0], [303.0, 687.0], [303.0, 815.0], [276.0, 815.0]], [[245.0, 685.0], [271.0, 685.0], [271.0, 846.0], [245.0, 846.0]]], "lines": ["とにかく俺は今", "自分だけで", "精いっぱいだ。"]}, {"box": [707, 682, 860, 926], "vertical": true, "font_size": 30, "lines_coords": [[[832.0, 689.0], [859.0, 689.0], [859.0, 814.0], [832.0, 814.0]], [[800.0, 689.0], [826.0, 689.0], [826.0, 814.0], [800.0, 814.0]], [[770.0, 689.0], [797.0, 689.0], [797.0, 917.0], [770.0, 917.0]], [[731.0, 682.0], [772.0, 682.0], [772.0, 756.0], [731.0, 756.0]], [[707.0, 689.0], [734.0, 689.0], [734.0, 926.0], [707.0, 926.0]]], "lines": ["そんなこと", "あんなこと", "いろいろ考えてみた", "結果、", "どうでもよくなった。"]}, {"box": [889, 934, 1013, 1112], "vertical": true, "font_size": 26, "lines_coords": [[[983.0, 934.0], [1011.0, 934.0], [1012.0, 1095.0], [984.0, 1095.0]], [[951.0, 934.0], [979.0, 934.0], [979.0, 1046.0], [951.0, 1046.0]], [[923.0, 935.0], [945.0, 935.0], [945.0, 1112.0], [923.0, 1112.0]], [[889.0, 934.0], [917.0, 934.0], [917.0, 1021.0], [889.0, 1021.0]]], "lines": ["大丈夫だって、", "ノダくん", "右手は残しとく", "からさ。"]}, {"box": [711, 1292, 832, 1506], "vertical": true, "font_size": 26, "lines_coords": [[[806.0, 1293.0], [832.0, 1293.0], [829.0, 1473.0], [803.0, 1473.0]], [[773.0, 1292.0], [801.0, 1292.0], [798.0, 1471.0], [770.0, 1471.0]], [[740.0, 1295.0], [767.0, 1295.0], [767.0, 1421.0], [740.0, 1421.0]], [[712.0, 1295.0], [734.0, 1295.0], [734.0, 1504.0], [712.0, 1504.0]]], "lines": ["今日も大好きな", "アニメキャラの", "パンチラで", "ショショーってな。"]}, {"box": [125, 1014, 234, 1418], "vertical": true, "font_size": 26, "lines_coords": [[[207.0, 1014.0], [234.0, 1014.0], [234.0, 1098.0], [207.0, 1098.0]], [[179.0, 1014.0], [206.0, 1014.0], [206.0, 1107.0], [179.0, 1107.0]], [[150.0, 1014.0], [176.0, 1014.0], [179.0, 1418.0], [153.0, 1418.0]], [[125.0, 1017.0], [146.0, 1017.0], [146.0, 1142.0], [125.0, 1142.0]]], "lines": ["てかさー", "僕ら来週", "メメ中のコたちといくらまで出せる？", "遊ぶわけよ。"]}, {"box": [181, 1209, 295, 1421], "vertical": true, "font_size": 26, "lines_coords": [[[265.0, 1209.0], [292.0, 1209.0], [295.0, 1421.0], [268.0, 1421.0]], [[237.0, 1210.0], [264.0, 1210.0], [264.0, 1375.0], [237.0, 1375.0]], [[209.0, 1210.0], [235.0, 1210.0], [235.0, 1309.0], [209.0, 1309.0]], [[181.0, 1209.0], [207.0, 1209.0], [207.0, 1310.0], [181.0, 1310.0]]], "lines": ["やっぱ遊ぶからには", "楽しくいきたい", "じゃん？", "ノダくん、"]}], "img_path": "subarashii_sekai_01_118.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [670, 117, 711, 277], "vertical": true, "font_size": 41, "lines_coords": [[[670.0, 117.0], [711.0, 117.0], [711.0, 196.0], [670.0, 196.0]]], "lines": ["おー"]}, {"box": [159, 75, 195, 145], "vertical": true, "font_size": 30, "lines_coords": [[[159.0, 75.0], [195.0, 75.0], [195.0, 145.0], [159.0, 145.0]]], "lines": ["ノダ。"]}, {"box": [139, 220, 200, 362], "vertical": true, "font_size": 30, "lines_coords": [[[173.0, 221.0], [200.0, 221.0], [200.0, 326.0], [173.0, 326.0]], [[139.0, 220.0], [165.0, 220.0], [168.0, 362.0], [142.0, 362.0]]], "lines": ["ちょっと", "こっち来い。"]}, {"box": [286, 592, 311, 770], "vertical": true, "font_size": 22, "lines_coords": [[[286.0, 592.0], [307.0, 592.0], [311.0, 765.0], [289.0, 765.0]]], "lines": ["おまえさぁ．．．"]}, {"box": [478, 976, 986, 1009], "vertical": false, "font_size": 31, "lines_coords": [[[478.0, 978.0], [986.0, 976.0], [986.0, 1007.0], [478.0, 1009.0]]], "lines": ["５ｔｈｐｒｏｇｒａｍ白い星、黒い星"]}, {"box": [217, 1004, 276, 1159], "vertical": true, "font_size": 28, "lines_coords": [[[242.0, 1004.0], [276.0, 1004.0], [276.0, 1087.0], [242.0, 1087.0]], [[217.0, 1007.0], [239.0, 1007.0], [239.0, 1159.0], [217.0, 1159.0]]], "lines": ["なんで", "生きてんの？"]}, {"box": [890, 1366, 931, 1397], "vertical": false, "font_size": 31, "lines_coords": [[[890.0, 1366.0], [931.0, 1366.0], [931.0, 1397.0], [890.0, 1397.0]]], "lines": ["．．．"]}, {"box": [223, 1335, 818, 1487], "vertical": false, "font_size": 119, "lines_coords": [[[229.0, 1335.0], [818.0, 1368.0], [812.0, 1487.0], [223.0, 1454.0]]], "lines": ["素晴らしいぜ。"]}], "img_path": "subarashii_sekai_01_119.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [500, 546, 625, 596], "vertical": false, "font_size": 33, "lines_coords": [[[500.0, 564.0], [620.0, 546.0], [625.0, 579.0], [504.0, 596.0]]], "lines": ["だって"]}, {"box": [518, 650, 567, 671], "vertical": false, "font_size": 21, "lines_coords": [[[518.0, 650.0], [567.0, 650.0], [567.0, 671.0], [518.0, 671.0]]], "lines": ["、"]}, {"box": [828, 740, 918, 901], "vertical": true, "font_size": 25, "lines_coords": [[[889.0, 743.0], [915.0, 743.0], [915.0, 864.0], [889.0, 864.0]], [[858.0, 742.0], [884.0, 742.0], [884.0, 887.0], [858.0, 887.0]], [[828.0, 740.0], [851.0, 740.0], [853.0, 896.0], [829.0, 896.0]]], "lines": ["いつからか", "ノタは学校に", "来なくなった"]}, {"box": [922, 1012, 946, 1148], "vertical": true, "font_size": 21, "lines_coords": [[[922.0, 1012.0], [943.0, 1012.0], [943.0, 1145.0], [922.0, 1145.0]]], "lines": ["ホズミくん"]}, {"box": [712, 735, 776, 928], "vertical": true, "font_size": 32, "lines_coords": [[[739.0, 735.0], [776.0, 735.0], [776.0, 803.0], [739.0, 803.0]], [[714.0, 737.0], [740.0, 737.0], [739.0, 925.0], [712.0, 925.0]]], "lines": ["当然、", "といえば当然か。"]}, {"box": [471, 734, 632, 967], "vertical": true, "font_size": 30, "lines_coords": [[[601.0, 739.0], [632.0, 739.0], [632.0, 793.0], [601.0, 793.0]], [[575.0, 742.0], [597.0, 742.0], [597.0, 965.0], [575.0, 965.0]], [[540.0, 742.0], [562.0, 742.0], [565.0, 915.0], [543.0, 915.0]], [[506.0, 739.0], [537.0, 739.0], [537.0, 942.0], [506.0, 942.0]], [[471.0, 734.0], [514.0, 734.0], [514.0, 809.0], [471.0, 809.0]]], "lines": ["でも", "わざわざ呼び出して", "金をせひるほど", "俺たちはヒマじゃ", "ない。"]}, {"box": [573, 996, 635, 1163], "vertical": true, "font_size": 27, "lines_coords": [[[607.0, 1001.0], [634.0, 1001.0], [634.0, 1159.0], [607.0, 1159.0]], [[573.0, 996.0], [600.0, 996.0], [603.0, 1162.0], [576.0, 1162.0]]], "lines": ["毎日遅くまで", "ごくろうさま。"]}, {"box": [228, 739, 318, 898], "vertical": true, "font_size": 27, "lines_coords": [[[290.0, 739.0], [317.0, 739.0], [314.0, 890.0], [287.0, 890.0]], [[256.0, 739.0], [284.0, 739.0], [281.0, 889.0], [253.0, 889.0]], [[228.0, 740.0], [254.0, 740.0], [254.0, 871.0], [228.0, 871.0]]], "lines": ["中学二年川月", "寒さが厳しく", "なってきた"]}, {"box": [132, 1106, 223, 1216], "vertical": true, "font_size": 28, "lines_coords": [[[196.0, 1106.0], [223.0, 1106.0], [223.0, 1209.0], [196.0, 1209.0]], [[160.0, 1106.0], [189.0, 1106.0], [192.0, 1214.0], [164.0, 1214.0]], [[132.0, 1107.0], [160.0, 1107.0], [160.0, 1193.0], [132.0, 1193.0]]], "lines": ["もうすぐ", "だもんね、", "文化祭。"]}, {"box": [165, 1339, 228, 1520], "vertical": true, "font_size": 30, "lines_coords": [[[200.0, 1342.0], [226.0, 1342.0], [226.0, 1520.0], [200.0, 1520.0]], [[165.0, 1339.0], [198.0, 1339.0], [198.0, 1423.0], [165.0, 1423.0]]], "lines": ["何か用ですか？", "先生？"]}], "img_path": "subarashii_sekai_01_120.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [879, 118, 1003, 325], "vertical": true, "font_size": 26, "lines_coords": [[[975.0, 121.0], [1003.0, 121.0], [1000.0, 257.0], [972.0, 257.0]], [[940.0, 118.0], [973.0, 118.0], [973.0, 201.0], [940.0, 201.0]], [[911.0, 120.0], [939.0, 120.0], [940.0, 276.0], [912.0, 276.0]], [[879.0, 123.0], [903.0, 123.0], [904.0, 325.0], [881.0, 325.0]]], "lines": ["ノダくんが", "学校に", "来なくなって", "だいぶ経つよね？"]}, {"box": [315, 118, 503, 323], "vertical": true, "font_size": 27, "lines_coords": [[[473.0, 118.0], [500.0, 118.0], [503.0, 273.0], [476.0, 273.0]], [[443.0, 120.0], [470.0, 120.0], [470.0, 257.0], [443.0, 257.0]], [[412.0, 118.0], [439.0, 118.0], [439.0, 273.0], [412.0, 273.0]], [[379.0, 120.0], [406.0, 120.0], [406.0, 248.0], [379.0, 248.0]], [[346.0, 118.0], [373.0, 118.0], [376.0, 323.0], [350.0, 323.0]], [[315.0, 121.0], [342.0, 121.0], [342.0, 234.0], [315.0, 234.0]]], "lines": ["だから理由も", "聞けないし。", "もしかしたら", "先生だから", "ダメなのかなって", "思うんだ。"]}, {"box": [861, 362, 983, 590], "vertical": true, "font_size": 26, "lines_coords": [[[953.0, 362.0], [979.0, 362.0], [983.0, 503.0], [956.0, 503.0]], [[925.0, 364.0], [947.0, 364.0], [950.0, 590.0], [928.0, 590.0]], [[892.0, 364.0], [918.0, 364.0], [918.0, 546.0], [892.0, 546.0]], [[861.0, 362.0], [883.0, 362.0], [886.0, 526.0], [864.0, 526.0]]], "lines": ["先生、何度も", "お宅に伺ってるけど", "全然取りあって", "もらえなくて。"]}, {"box": [884, 715, 920, 787], "vertical": true, "font_size": 36, "lines_coords": [[[884.0, 715.0], [920.0, 715.0], [920.0, 787.0], [884.0, 787.0]]], "lines": ["はい。"]}, {"box": [106, 475, 230, 653], "vertical": true, "font_size": 26, "lines_coords": [[[203.0, 476.0], [229.0, 476.0], [229.0, 606.0], [203.0, 606.0]], [[170.0, 475.0], [196.0, 475.0], [196.0, 651.0], [170.0, 651.0]], [[139.0, 475.0], [165.0, 475.0], [165.0, 634.0], [139.0, 634.0]], [[106.0, 475.0], [132.0, 475.0], [132.0, 653.0], [106.0, 653.0]]], "lines": ["ホズミくん、", "生徒会長として", "様子見てきて", "くれないかな？"]}, {"box": [672, 1006, 795, 1185], "vertical": true, "font_size": 28, "lines_coords": [[[770.0, 1009.0], [792.0, 1009.0], [792.0, 1156.0], [770.0, 1156.0]], [[732.0, 1006.0], [765.0, 1006.0], [765.0, 1118.0], [732.0, 1118.0]], [[701.0, 1007.0], [728.0, 1007.0], [731.0, 1185.0], [704.0, 1185.0]], [[672.0, 1009.0], [700.0, 1009.0], [700.0, 1145.0], [672.0, 1145.0]]], "lines": ["自分の意志に", "関係なく、", "これが言えれば", "人間合格だ。"]}, {"box": [217, 768, 244, 930], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 768.0], [243.0, 768.0], [243.0, 929.0], [217.0, 929.0]]], "lines": ["わかりました。"]}, {"box": [231, 1007, 388, 1225], "vertical": true, "font_size": 27, "lines_coords": [[[359.0, 1007.0], [386.0, 1007.0], [386.0, 1223.0], [359.0, 1223.0]], [[328.0, 1007.0], [356.0, 1007.0], [356.0, 1137.0], [328.0, 1137.0]], [[293.0, 1007.0], [321.0, 1007.0], [325.0, 1192.0], [296.0, 1192.0]], [[262.0, 1007.0], [289.0, 1007.0], [293.0, 1160.0], [267.0, 1160.0]], [[231.0, 1007.0], [257.0, 1007.0], [260.0, 1218.0], [234.0, 1218.0]]], "lines": ["決められたレールに", "そっている", "フリがてきれば、", "この社会では", "楽に生きていける。"]}, {"box": [153, 1300, 216, 1506], "vertical": true, "font_size": 27, "lines_coords": [[[185.0, 1300.0], [212.0, 1300.0], [215.0, 1462.0], [189.0, 1462.0]], [[153.0, 1301.0], [181.0, 1301.0], [182.0, 1506.0], [154.0, 1506.0]]], "lines": ["．．．．．．ってか、", "それってさぁ．．．"]}], "img_path": "subarashii_sekai_01_121.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [926, 117, 992, 274], "vertical": true, "font_size": 31, "lines_coords": [[[953.0, 117.0], [992.0, 117.0], [992.0, 204.0], [953.0, 204.0]], [[928.0, 121.0], [951.0, 121.0], [950.0, 273.0], [926.0, 273.0]]], "lines": ["すっげ", "だるくない？"]}, {"box": [264, 109, 326, 225], "vertical": true, "font_size": 30, "lines_coords": [[[292.0, 109.0], [326.0, 109.0], [326.0, 192.0], [292.0, 192.0]], [[264.0, 112.0], [290.0, 112.0], [290.0, 225.0], [264.0, 225.0]]], "lines": ["そりゃ", "だるいさ。"]}, {"box": [168, 296, 326, 454], "vertical": true, "font_size": 30, "lines_coords": [[[296.0, 296.0], [325.0, 296.0], [326.0, 428.0], [298.0, 428.0]], [[264.0, 298.0], [292.0, 298.0], [295.0, 454.0], [267.0, 454.0]], [[228.0, 298.0], [260.0, 296.0], [265.0, 389.0], [232.0, 390.0]], [[200.0, 298.0], [228.0, 298.0], [229.0, 429.0], [201.0, 429.0]], [[168.0, 298.0], [201.0, 298.0], [201.0, 392.0], [168.0, 392.0]]], "lines": ["でもやっぱ", "行っとくべき", "でしょ、", "生徒会長と", "しては。"]}, {"box": [548, 650, 610, 785], "vertical": true, "font_size": 30, "lines_coords": [[[579.0, 650.0], [607.0, 650.0], [609.0, 785.0], [581.0, 785.0]], [[548.0, 650.0], [581.0, 650.0], [581.0, 739.0], [548.0, 739.0]]], "lines": ["念には念を、", "ってな。"]}, {"box": [753, 651, 1004, 1028], "vertical": true, "font_size": 24, "lines_coords": [[[978.0, 653.0], [1000.0, 653.0], [1000.0, 789.0], [978.0, 789.0]], [[945.0, 651.0], [968.0, 651.0], [972.0, 765.0], [948.0, 765.0]], [[920.0, 653.0], [942.0, 653.0], [942.0, 810.0], [920.0, 810.0]], [[890.0, 654.0], [912.0, 654.0], [912.0, 835.0], [890.0, 835.0]], [[868.0, 818.0], [892.0, 818.0], [892.0, 870.0], [868.0, 870.0]], [[836.0, 821.0], [862.0, 821.0], [867.0, 1007.0], [840.0, 1007.0]], [[809.0, 821.0], [832.0, 821.0], [834.0, 995.0], [811.0, 995.0]], [[776.0, 821.0], [803.0, 821.0], [809.0, 1028.0], [782.0, 1028.0]], [[754.0, 823.0], [776.0, 823.0], [775.0, 985.0], [753.0, 985.0]]], "lines": ["ひき込もりを", "連れ戻せば", "先生らのウケも", "バッチリってか？", "もう", "十分じゃないの？", "おまえ、学校中の", "先生に愛されちゃっ", "てるって話よ？"]}, {"box": [124, 739, 220, 925], "vertical": true, "font_size": 23, "lines_coords": [[[195.0, 742.0], [217.0, 742.0], [217.0, 917.0], [195.0, 917.0]], [[160.0, 739.0], [187.0, 739.0], [187.0, 918.0], [160.0, 918.0]], [[125.0, 740.0], [146.0, 740.0], [146.0, 921.0], [125.0, 921.0]]], "lines": ["メメ高の推薦は", "オレの人生から", "外せないワケさ。"]}, {"box": [282, 939, 444, 1312], "vertical": true, "font_size": 28, "lines_coords": [[[414.0, 943.0], [440.0, 943.0], [440.0, 1095.0], [414.0, 1095.0]], [[384.0, 946.0], [406.0, 946.0], [406.0, 1095.0], [384.0, 1095.0]], [[345.0, 939.0], [382.0, 939.0], [376.0, 1206.0], [339.0, 1206.0]], [[312.0, 1123.0], [339.0, 1123.0], [340.0, 1307.0], [314.0, 1307.0]], [[282.0, 1125.0], [309.0, 1125.0], [309.0, 1304.0], [282.0, 1304.0]]], "lines": ["しかしホント", "おまえ上手く", "やってるよなぁ。なんで", "気付かないかね。", "大人ってのは？"]}, {"box": [132, 1371, 167, 1476], "vertical": true, "font_size": 35, "lines_coords": [[[132.0, 1371.0], [167.0, 1371.0], [167.0, 1476.0], [132.0, 1476.0]]], "lines": ["ホント、"]}], "img_path": "subarashii_sekai_01_122.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [98, 54, 321, 84], "vertical": false, "font_size": 28, "lines_coords": [[[98.0, 54.0], [321.0, 56.0], [321.0, 84.0], [98.0, 82.0]]], "lines": ["素晴らしい世界"]}, {"box": [232, 145, 265, 337], "vertical": true, "font_size": 27, "lines_coords": [[[232.0, 145.0], [259.0, 145.0], [264.0, 335.0], [237.0, 335.0]]], "lines": ["どこ見てんだか。"]}, {"box": [853, 821, 943, 960], "vertical": true, "font_size": 25, "lines_coords": [[[920.0, 826.0], [942.0, 826.0], [942.0, 956.0], [920.0, 956.0]], [[886.0, 823.0], [914.0, 823.0], [911.0, 928.0], [883.0, 928.0]], [[853.0, 821.0], [879.0, 821.0], [879.0, 910.0], [853.0, 910.0]]], "lines": ["すいません、", "こんな夜", "遅くに。"]}, {"box": [772, 1028, 831, 1165], "vertical": true, "font_size": 22, "lines_coords": [[[804.0, 1029.0], [828.0, 1029.0], [829.0, 1131.0], [806.0, 1131.0]], [[772.0, 1028.0], [793.0, 1028.0], [798.0, 1162.0], [776.0, 1162.0]]], "lines": ["いえいえ", "こちらこそ。"]}, {"box": [328, 914, 387, 1090], "vertical": true, "font_size": 26, "lines_coords": [[[361.0, 914.0], [387.0, 914.0], [387.0, 1090.0], [361.0, 1090.0]], [[328.0, 914.0], [354.0, 914.0], [354.0, 1025.0], [328.0, 1025.0]]], "lines": ["この奥の部屋が", "そうです。"]}, {"box": [173, 1114, 200, 1204], "vertical": true, "font_size": 27, "lines_coords": [[[173.0, 1114.0], [200.0, 1114.0], [200.0, 1203.0], [173.0, 1203.0]]], "lines": ["どうも。"]}, {"box": [826, 1250, 956, 1287], "vertical": false, "font_size": 37, "lines_coords": [[[826.0, 1250.0], [956.0, 1250.0], [956.0, 1287.0], [826.0, 1287.0]]], "lines": ["ＮＯＤＡ"]}], "img_path": "subarashii_sekai_01_123.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [845, 582, 883, 740], "vertical": true, "font_size": 38, "lines_coords": [[[845.0, 582.0], [883.0, 582.0], [883.0, 740.0], [845.0, 740.0]]], "lines": ["鏡．．．．．．？"]}, {"box": [595, 939, 625, 1043], "vertical": true, "font_size": 27, "lines_coords": [[[595.0, 939.0], [622.0, 939.0], [625.0, 1043.0], [598.0, 1043.0]]], "lines": ["あの．．．"]}, {"box": [384, 888, 414, 1004], "vertical": true, "font_size": 28, "lines_coords": [[[384.0, 889.0], [412.0, 889.0], [412.0, 1004.0], [384.0, 1004.0]]], "lines": ["．．．．．．！！"]}, {"box": [131, 1360, 191, 1451], "vertical": true, "font_size": 30, "lines_coords": [[[164.0, 1362.0], [190.0, 1362.0], [190.0, 1445.0], [164.0, 1445.0]], [[131.0, 1360.0], [164.0, 1360.0], [164.0, 1451.0], [131.0, 1451.0]]], "lines": ["俺だよ、", "ホズミ。"]}], "img_path": "subarashii_sekai_01_124.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [909, 101, 1001, 293], "vertical": true, "font_size": 27, "lines_coords": [[[973.0, 104.0], [1000.0, 104.0], [1000.0, 231.0], [973.0, 231.0]], [[940.0, 104.0], [967.0, 104.0], [967.0, 257.0], [940.0, 257.0]], [[909.0, 101.0], [936.0, 101.0], [937.0, 293.0], [911.0, 293.0]]], "lines": ["先生が俺に", "おまえの様子", "見てこいってさ。"]}, {"box": [546, 256, 609, 373], "vertical": true, "font_size": 30, "lines_coords": [[[575.0, 256.0], [609.0, 256.0], [609.0, 337.0], [575.0, 337.0]], [[546.0, 257.0], [573.0, 257.0], [573.0, 373.0], [546.0, 373.0]]], "lines": ["ホント", "笑うよな。"]}, {"box": [231, 93, 254, 221], "vertical": true, "font_size": 22, "lines_coords": [[[231.0, 93.0], [253.0, 93.0], [253.0, 220.0], [231.0, 220.0]]], "lines": ["どうする？"]}, {"box": [698, 423, 820, 625], "vertical": true, "font_size": 28, "lines_coords": [[[793.0, 423.0], [820.0, 423.0], [820.0, 589.0], [793.0, 589.0]], [[762.0, 423.0], [789.0, 423.0], [789.0, 625.0], [762.0, 625.0]], [[728.0, 425.0], [754.0, 425.0], [756.0, 601.0], [729.0, 601.0]], [[698.0, 423.0], [726.0, 423.0], [726.0, 514.0], [698.0, 514.0]]], "lines": ["まぁ、フツーに", "呼びに来たとこで", "無理だとは思う", "けどさ。"]}, {"box": [521, 507, 647, 712], "vertical": true, "font_size": 28, "lines_coords": [[[620.0, 510.0], [647.0, 510.0], [647.0, 662.0], [620.0, 662.0]], [[586.0, 507.0], [612.0, 507.0], [614.0, 712.0], [587.0, 712.0]], [[553.0, 507.0], [586.0, 507.0], [586.0, 600.0], [553.0, 600.0]], [[521.0, 509.0], [548.0, 509.0], [551.0, 650.0], [525.0, 650.0]]], "lines": ["明日からでも", "学校に来てほしい", "ワケだ。", "俺としては。"]}, {"box": [167, 331, 287, 487], "vertical": true, "font_size": 26, "lines_coords": [[[265.0, 332.0], [287.0, 332.0], [287.0, 482.0], [265.0, 482.0]], [[229.0, 331.0], [257.0, 331.0], [257.0, 437.0], [229.0, 437.0]], [[195.0, 331.0], [223.0, 331.0], [226.0, 487.0], [198.0, 487.0]], [[167.0, 332.0], [195.0, 332.0], [195.0, 418.0], [167.0, 418.0]]], "lines": ["おまえの家も", "親の顔も", "わかっちまった", "からな。"]}, {"box": [118, 495, 239, 695], "vertical": true, "font_size": 26, "lines_coords": [[[207.0, 495.0], [234.0, 495.0], [239.0, 681.0], [212.0, 681.0]], [[178.0, 504.0], [206.0, 504.0], [206.0, 607.0], [178.0, 607.0]], [[145.0, 503.0], [171.0, 503.0], [173.0, 695.0], [146.0, 695.0]], [[118.0, 506.0], [140.0, 506.0], [140.0, 617.0], [118.0, 617.0]]], "lines": ["やろうと思えば", "いろいろ", "おもしろいことが", "できるぜ。"]}, {"box": [840, 1028, 922, 1139], "vertical": true, "font_size": 41, "lines_coords": [[[875.0, 1028.0], [922.0, 1028.0], [922.0, 1114.0], [875.0, 1114.0]], [[840.0, 1032.0], [875.0, 1032.0], [875.0, 1139.0], [840.0, 1139.0]]], "lines": ["はは、", "バーカ。"]}, {"box": [173, 1140, 289, 1437], "vertical": true, "font_size": 27, "lines_coords": [[[257.0, 1140.0], [286.0, 1140.0], [287.0, 1253.0], [259.0, 1253.0]], [[234.0, 1298.0], [262.0, 1298.0], [262.0, 1400.0], [234.0, 1400.0]], [[201.0, 1298.0], [229.0, 1298.0], [231.0, 1426.0], [203.0, 1426.0]], [[173.0, 1300.0], [195.0, 1300.0], [195.0, 1435.0], [173.0, 1435.0]]], "lines": ["冗談だよ。", "するワケ", "ねえじゃん", "そんなこと。"]}], "img_path": "subarashii_sekai_01_125.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [822, 101, 945, 320], "vertical": true, "font_size": 28, "lines_coords": [[[909.0, 104.0], [942.0, 103.0], [945.0, 187.0], [912.0, 189.0]], [[889.0, 104.0], [915.0, 104.0], [915.0, 256.0], [889.0, 256.0]], [[856.0, 103.0], [883.0, 103.0], [883.0, 320.0], [856.0, 320.0]], [[822.0, 101.0], [848.0, 101.0], [853.0, 293.0], [826.0, 293.0]]], "lines": ["つーか、", "ホズミ天下も", "そろそろ下火っつー", "雰囲気だよなぁ。"]}, {"box": [191, 115, 248, 300], "vertical": true, "font_size": 25, "lines_coords": [[[220.0, 115.0], [248.0, 115.0], [248.0, 253.0], [220.0, 253.0]], [[192.0, 117.0], [214.0, 117.0], [214.0, 298.0], [192.0, 298.0]]], "lines": ["てか、あいつ", "上手くやりすぎ。"]}, {"box": [850, 596, 965, 725], "vertical": true, "font_size": 34, "lines_coords": [[[912.0, 601.0], [959.0, 596.0], [965.0, 682.0], [918.0, 687.0]], [[886.0, 604.0], [914.0, 604.0], [914.0, 725.0], [886.0, 725.0]], [[850.0, 603.0], [876.0, 603.0], [876.0, 725.0], [850.0, 725.0]]], "lines": ["おい、", "おまえら", "ドコ中？"]}, {"box": [182, 399, 239, 587], "vertical": true, "font_size": 22, "lines_coords": [[[214.0, 400.0], [235.0, 400.0], [235.0, 573.0], [214.0, 573.0]], [[182.0, 401.0], [204.0, 401.0], [204.0, 581.0], [182.0, 581.0]]], "lines": ["とりあえず１回", "シメときますが、"]}, {"box": [157, 731, 203, 804], "vertical": true, "font_size": 43, "lines_coords": [[[160.0, 731.0], [203.0, 732.0], [200.0, 804.0], [157.0, 803.0]]], "lines": ["あ！？"]}, {"box": [828, 864, 936, 1171], "vertical": true, "font_size": 28, "lines_coords": [[[904.0, 868.0], [936.0, 868.0], [936.0, 926.0], [904.0, 926.0]], [[890.0, 978.0], [917.0, 978.0], [917.0, 1168.0], [890.0, 1168.0]], [[861.0, 982.0], [887.0, 982.0], [887.0, 1135.0], [861.0, 1135.0]], [[828.0, 982.0], [854.0, 982.0], [854.0, 1160.0], [828.0, 1160.0]]], "lines": ["ノダ。", "おまえ、いつまで", "そうやってる", "つもりなんだ？"]}, {"box": [217, 939, 371, 1129], "vertical": true, "font_size": 27, "lines_coords": [[[345.0, 943.0], [371.0, 943.0], [371.0, 1117.0], [345.0, 1117.0]], [[314.0, 942.0], [340.0, 942.0], [340.0, 1114.0], [314.0, 1114.0]], [[279.0, 939.0], [306.0, 939.0], [306.0, 1129.0], [279.0, 1129.0]], [[248.0, 940.0], [276.0, 940.0], [273.0, 1043.0], [245.0, 1043.0]], [[217.0, 942.0], [243.0, 942.0], [243.0, 1070.0], [217.0, 1070.0]]], "lines": ["一生その部屋で", "マンガ、アニメ、", "ゲーム、オナニー", "って生活", "続けんの？"]}, {"box": [106, 1050, 201, 1232], "vertical": true, "font_size": 27, "lines_coords": [[[164.0, 1050.0], [196.0, 1050.0], [201.0, 1231.0], [168.0, 1231.0]], [[140.0, 1054.0], [162.0, 1054.0], [162.0, 1232.0], [140.0, 1232.0]], [[106.0, 1053.0], [132.0, 1053.0], [132.0, 1160.0], [106.0, 1160.0]]], "lines": ["はは、気色悪ぃ。", "正気じゃないね", "そんなの"]}, {"box": [146, 1292, 242, 1498], "vertical": true, "font_size": 29, "lines_coords": [[[215.0, 1293.0], [239.0, 1293.0], [240.0, 1470.0], [217.0, 1470.0]], [[182.0, 1292.0], [209.0, 1292.0], [210.0, 1498.0], [184.0, 1498.0]], [[146.0, 1293.0], [182.0, 1293.0], [182.0, 1353.0], [146.0, 1353.0]]], "lines": ["それとも俺らが", "そんなに怖かった", "か？"]}], "img_path": "subarashii_sekai_01_126.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [881, 107, 1008, 314], "vertical": true, "font_size": 26, "lines_coords": [[[981.0, 110.0], [1008.0, 110.0], [1008.0, 303.0], [981.0, 303.0]], [[947.0, 107.0], [973.0, 107.0], [972.0, 314.0], [945.0, 314.0]], [[917.0, 107.0], [943.0, 107.0], [940.0, 289.0], [914.0, 289.0]], [[886.0, 109.0], [912.0, 109.0], [908.0, 298.0], [881.0, 298.0]]], "lines": ["しょうがねぇよ。", "おまえはつけ入る", "スキがアリアリ", "だったんだから。"]}, {"box": [628, 143, 717, 301], "vertical": true, "font_size": 25, "lines_coords": [[[684.0, 143.0], [717.0, 143.0], [717.0, 225.0], [684.0, 225.0]], [[656.0, 145.0], [682.0, 145.0], [682.0, 296.0], [656.0, 296.0]], [[628.0, 146.0], [650.0, 146.0], [650.0, 301.0], [628.0, 301.0]]], "lines": ["他人に", "スキを見せる", "ヤツってのは"]}, {"box": [545, 315, 632, 476], "vertical": true, "font_size": 25, "lines_coords": [[[611.0, 318.0], [632.0, 318.0], [632.0, 468.0], [611.0, 468.0]], [[576.0, 315.0], [603.0, 315.0], [600.0, 470.0], [573.0, 470.0]], [[546.0, 317.0], [570.0, 317.0], [568.0, 476.0], [545.0, 476.0]]], "lines": ["生きることを", "甘く考えてる", "ヤツなんだよ。"]}, {"box": [265, 134, 300, 193], "vertical": true, "font_size": 28, "lines_coords": [[[268.0, 134.0], [300.0, 135.0], [296.0, 193.0], [265.0, 192.0]]], "lines": ["ノダ"]}, {"box": [210, 253, 298, 429], "vertical": true, "font_size": 28, "lines_coords": [[[276.0, 253.0], [298.0, 253.0], [298.0, 403.0], [276.0, 403.0]], [[240.0, 253.0], [268.0, 253.0], [271.0, 429.0], [243.0, 429.0]], [[210.0, 254.0], [239.0, 254.0], [239.0, 343.0], [210.0, 343.0]]], "lines": ["俺はおまえを", "嫌いなワケじゃ", "ないさ。"]}, {"box": [168, 534, 195, 662], "vertical": true, "font_size": 24, "lines_coords": [[[168.0, 535.0], [192.0, 535.0], [192.0, 609.0], [168.0, 609.0]]], "lines": ["ただー"]}, {"box": [304, 701, 336, 863], "vertical": true, "font_size": 32, "lines_coords": [[[304.0, 701.0], [336.0, 701.0], [336.0, 862.0], [304.0, 862.0]]], "lines": ["強い人間と、"]}, {"box": [865, 984, 898, 1147], "vertical": true, "font_size": 32, "lines_coords": [[[865.0, 984.0], [897.0, 984.0], [897.0, 1145.0], [865.0, 1145.0]]], "lines": ["弱い人間の、"]}, {"box": [182, 1231, 272, 1407], "vertical": true, "font_size": 26, "lines_coords": [[[245.0, 1231.0], [271.0, 1231.0], [271.0, 1407.0], [245.0, 1407.0]], [[214.0, 1231.0], [240.0, 1231.0], [240.0, 1407.0], [214.0, 1407.0]], [[182.0, 1231.0], [209.0, 1231.0], [209.0, 1354.0], [182.0, 1354.0]]], "lines": ["区別をはっきり", "させたかったん", "だよ、俺は。"]}], "img_path": "subarashii_sekai_01_127.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [865, 103, 995, 285], "vertical": true, "font_size": 29, "lines_coords": [[[968.0, 109.0], [995.0, 109.0], [995.0, 237.0], [968.0, 237.0]], [[939.0, 110.0], [961.0, 110.0], [961.0, 285.0], [939.0, 285.0]], [[904.0, 107.0], [931.0, 107.0], [931.0, 285.0], [904.0, 285.0]], [[865.0, 103.0], [906.0, 103.0], [906.0, 153.0], [865.0, 153.0]]], "lines": ["そうやって", "自分の居場所を", "自分で作ってん", "だ。"]}, {"box": [296, 478, 323, 582], "vertical": true, "font_size": 27, "lines_coords": [[[296.0, 478.0], [323.0, 478.0], [323.0, 582.0], [296.0, 582.0]]], "lines": ["はは．．．"]}, {"box": [240, 614, 267, 760], "vertical": true, "font_size": 27, "lines_coords": [[[240.0, 614.0], [267.0, 614.0], [267.0, 760.0], [240.0, 760.0]]], "lines": ["勝った．．．．．．"]}, {"box": [889, 951, 914, 1068], "vertical": true, "font_size": 22, "lines_coords": [[[890.0, 996.0], [912.0, 996.0], [912.0, 1065.0], [890.0, 1065.0]]], "lines": ["って。"]}, {"box": [561, 918, 653, 1074], "vertical": true, "font_size": 28, "lines_coords": [[[622.0, 920.0], [653.0, 920.0], [653.0, 948.0], [622.0, 948.0]], [[592.0, 918.0], [620.0, 918.0], [617.0, 1073.0], [589.0, 1073.0]], [[561.0, 920.0], [587.0, 920.0], [587.0, 1031.0], [561.0, 1031.0]]], "lines": ["何", "言ってんだ俺。", "アホ臭え。"]}, {"box": [228, 909, 318, 1101], "vertical": true, "font_size": 29, "lines_coords": [[[290.0, 912.0], [318.0, 912.0], [318.0, 1015.0], [290.0, 1015.0]], [[259.0, 910.0], [286.0, 910.0], [286.0, 1039.0], [259.0, 1039.0]], [[228.0, 909.0], [254.0, 909.0], [254.0, 1101.0], [228.0, 1101.0]]], "lines": ["いじめを", "正当化して", "どうするってな。"]}, {"box": [100, 1082, 225, 1229], "vertical": true, "font_size": 29, "lines_coords": [[[192.0, 1082.0], [225.0, 1082.0], [225.0, 1179.0], [192.0, 1179.0]], [[164.0, 1087.0], [192.0, 1087.0], [187.0, 1229.0], [159.0, 1229.0]], [[128.0, 1085.0], [160.0, 1085.0], [160.0, 1176.0], [128.0, 1176.0]], [[100.0, 1087.0], [128.0, 1087.0], [128.0, 1179.0], [100.0, 1179.0]]], "lines": ["「イジメ", "カッコ悪い」", "だよな、", "やっぱ。"]}, {"box": [598, 1257, 640, 1329], "vertical": true, "font_size": 42, "lines_coords": [[[598.0, 1257.0], [640.0, 1257.0], [640.0, 1329.0], [598.0, 1329.0]]], "lines": ["ノダ。"]}, {"box": [90, 1328, 243, 1482], "vertical": true, "font_size": 27, "lines_coords": [[[212.0, 1328.0], [240.0, 1328.0], [243.0, 1470.0], [215.0, 1470.0]], [[182.0, 1329.0], [209.0, 1329.0], [209.0, 1459.0], [182.0, 1459.0]], [[148.0, 1328.0], [181.0, 1328.0], [181.0, 1410.0], [148.0, 1410.0]], [[120.0, 1331.0], [146.0, 1331.0], [146.0, 1482.0], [120.0, 1482.0]], [[90.0, 1332.0], [112.0, 1332.0], [112.0, 1467.0], [90.0, 1467.0]]], "lines": ["もういいよ。", "おまえ一生", "部屋で", "シコってれば", "いいじゃん。"]}], "img_path": "subarashii_sekai_01_128.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [203, 223, 234, 328], "vertical": true, "font_size": 30, "lines_coords": [[[203.0, 223.0], [232.0, 223.0], [234.0, 328.0], [204.0, 328.0]]], "lines": ["ホズミ。"]}, {"box": [895, 454, 931, 584], "vertical": true, "font_size": 33, "lines_coords": [[[898.0, 454.0], [931.0, 454.0], [928.0, 584.0], [895.0, 584.0]]], "lines": ["ノダ．．．．．？"]}, {"box": [246, 737, 320, 950], "vertical": true, "font_size": 32, "lines_coords": [[[286.0, 737.0], [317.0, 737.0], [320.0, 950.0], [289.0, 950.0]], [[250.0, 737.0], [282.0, 737.0], [279.0, 923.0], [246.0, 923.0]]], "lines": ["おまえ生きてて", "辛くないの？"]}, {"box": [204, 1204, 261, 1332], "vertical": true, "font_size": 25, "lines_coords": [[[232.0, 1204.0], [260.0, 1204.0], [260.0, 1309.0], [232.0, 1309.0]], [[204.0, 1206.0], [226.0, 1206.0], [226.0, 1331.0], [204.0, 1331.0]]], "lines": ["なんだよ", "ソレ．．．．．．？"]}], "img_path": "subarashii_sekai_01_129.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [707, 123, 820, 307], "vertical": true, "font_size": 34, "lines_coords": [[[782.0, 123.0],