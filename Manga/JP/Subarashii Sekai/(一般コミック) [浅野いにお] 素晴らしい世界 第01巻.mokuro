0], [501.0, 1157.0], [473.0, 1157.0]]], "lines": ["バンド名も", "決めてるんです。", "「電気虫」", "いいでしょ？"]}, {"box": [131, 700, 220, 904], "vertical": true, "font_size": 23, "lines_coords": [[[190.0, 700.0], [218.0, 700.0], [220.0, 809.0], [192.0, 809.0]], [[160.0, 703.0], [182.0, 703.0], [182.0, 851.0], [160.0, 851.0]], [[131.0, 701.0], [151.0, 701.0], [151.0, 900.0], [131.0, 900.0]]], "lines": ["プロって、", "あんた簡単に", "言うけどさぁ．．．"]}, {"box": [670, 1278, 781, 1462], "vertical": true, "font_size": 25, "lines_coords": [[[751.0, 1279.0], [781.0, 1279.0], [781.0, 1335.0], [751.0, 1335.0]], [[720.0, 1278.0], [748.0, 1278.0], [751.0, 1376.0], [723.0, 1376.0]], [[697.0, 1282.0], [718.0, 1282.0], [718.0, 1462.0], [697.0, 1462.0]], [[670.0, 1282.0], [690.0, 1282.0], [690.0, 1450.0], [670.0, 1450.0]]], "lines": ["はは、", "あたしは", "ポーカルってガラ", "じゃないでしょ。"]}, {"box": [546, 1329, 607, 1444], "vertical": true, "font_size": 30, "lines_coords": [[[575.0, 1329.0], [607.0, 1329.0], [607.0, 1412.0], [575.0, 1412.0]], [[546.0, 1332.0], [573.0, 1332.0], [573.0, 1443.0], [546.0, 1443.0]]], "lines": ["それは", "やめとけ。"]}, {"box": [139, 1287, 220, 1442], "vertical": true, "font_size": 36, "lines_coords": [[[179.0, 1287.0], [220.0, 1287.0], [220.0, 1364.0], [179.0, 1364.0]], [[139.0, 1290.0], [171.0, 1290.0], [171.0, 1428.0], [139.0, 1428.0]]], "lines": ["おー", "堀田ぁ！"]}], "img_path": "subarashii_sekai_01_018.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [881, 123, 991, 284], "vertical": true, "font_size": 25, "lines_coords": [[[968.0, 128.0], [990.0, 128.0], [990.0, 284.0], [968.0, 284.0]], [[937.0, 123.0], [964.0, 123.0], [961.0, 240.0], [934.0, 240.0]], [[906.0, 125.0], [934.0, 125.0], [934.0, 196.0], [906.0, 196.0]], [[881.0, 126.0], [903.0, 126.0], [903.0, 246.0], [881.0, 246.0]]], "lines": ["外でイカニモな", "オッサンが", "お前を", "捜してたぞ。"]}, {"box": [628, 123, 662, 226], "vertical": true, "font_size": 34, "lines_coords": [[[628.0, 123.0], [662.0, 123.0], [662.0, 226.0], [628.0, 226.0]]], "l