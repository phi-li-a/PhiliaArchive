.0, 958.0], [3761.0, 988.0], [3633.0, 988.0]], [[3637.0, 984.0], [3769.0, 984.0], [3769.0, 1026.0], [3637.0, 1026.0]], [[3208.0, 991.0], [3487.0, 991.0], [3487.0, 1022.0], [3208.0, 1022.0]], [[3528.0, 1018.0], [3769.0, 1018.0], [3769.0, 1059.0], [3528.0, 1059.0]], [[3204.0, 1025.0], [3517.0, 1025.0], [3517.0, 1056.0], [3204.0, 1056.0]], [[3682.0, 1063.0], [3757.0, 1063.0], [3757.0, 1082.0], [3682.0, 1082.0]], [[3204.0, 1059.0], [3630.0, 1059.0], [3630.0, 1090.0], [3204.0, 1090.0]], [[3212.0, 1089.0], [3517.0, 1089.0], [3517.0, 1120.0], [3212.0, 1120.0]]], "lines": ["「美女で野獣！イダタツヒコ", "【シャジャ】えのあきら．．．", "［ワイルダネス］伊藤明弘", "【ブラック・ラグーン］広江礼威", "【ガールズサウルスＤＸ】補桂", "［ラバーズフ］犬上すくね．．．", "「ＰＥＯ」花見沢Ｑ太郎・", "「新吼えろペン］島本和彦．．．", "［貧乏姉妹物語］かすという", "【コイネコ】真島悦也．．．", "【デス・プリ吉田蛇作．．．", "第０", "［正義審官モンジュ］宮下裕樹：", "【渋谷ガーディアンガー「はぁルズ」こいずみまり．．．", "．．．．．．．．第の集", "．．．いいのよ．．．！第０集", "「ＦＡＤＥＯＵＴＩＮけだから", "．．．．．．！！．．", "［現界戦線］やまむらはじめ．．．", "．．．全＠巻", "［ＣＤＭＯ．ＢＯＭＢＥＦ吼えろペン］島本和彦・", "逆境ナイン島本和彦．．．"]}, {"box": [1907, 1114, 1948, 1392], "vertical": true, "font_size": 41, "lines_coords": [[[1907.0, 1114.0], [1948.0, 1114.0], [1948.0, 1392.0], [1907.0, 1392.0]]], "lines": ["浅野いに"]}, {"box": [2200, 1272, 2900, 1310], "vertical": false, "font_size": 38, "lines_coords": [[[2200.0, 1272.0], [2900.0, 1272.0], [2900.0, 1310.0], [2200.0, 1310.0]]], "lines": ["いつかどこかでいいことがある。"]}, {"box": [2050, 1381, 3039, 1430], "vertical": false, "font_size": 49, "lines_coords": [[[2050.0, 1381.0], [3039.0, 1381.0], [3039.0, 1430.0], [2050.0, 1430.0]]], "lines": ["僕らの生きる優しくも悲しく、楽しくも明なく、"]}, {"box": [2046, 1502, 3058, 1539], "vertical": false, "font_size": 37, "lines_coords": [[[2046.0, 1502.0], [3058.0, 1502.0], [3058.0, 1539.0], [2046.0, 1539.0]]], "lines": ["そして強くはかないこの素晴らしい世界に．．．"]}, {"box": [3503, 1520, 3697, 1562], "vertical": false, "font_size": 46, "lines_coords": [[[3503.0, 1516.0], [3697.0, 1516.0], [3697.0, 1566.0], [3503.0, 1566.0]]], "lines": ["素晴らしい世界の"]}], "img_path": "subarashii_sekai_01_#002.jpg"}, {"version": "0.1.7", "img_width": 