[212.0, 818.0], [185.0, 818.0]], [[154.0, 662.0], [181.0, 662.0], [181.0, 826.0], [154.0, 826.0]]], "lines": ["あのあと学校を辞め", "バンドも辞めた", "あたしは、", "それっきり", "堀田とも", "他の連中とも", "会っていない。"]}, {"box": [286, 957, 343, 1135], "vertical": true, "font_size": 25, "lines_coords": [[[314.0, 957.0], [340.0, 957.0], [343.0, 1135.0], [317.0, 1135.0]], [[286.0, 960.0], [307.0, 960.0], [307.0, 1092.0], [286.0, 1092.0]]], "lines": ["堀田とバンドは", "できないよ。"]}, {"box": [157, 1040, 184, 1165], "vertical": true, "font_size": 25, "lines_coords": [[[157.0, 1040.0], [184.0, 1040.0], [184.0, 1165.0], [157.0, 1165.0]]], "lines": ["だって．．．"]}, {"box": [886, 1248, 976, 1437], "vertical": true, "font_size": 28, "lines_coords": [[[950.0, 1251.0], [976.0, 1251.0], [976.0, 1381.0], [950.0, 1381.0]], [[915.0, 1248.0], [948.0, 1248.0], [948.0, 1407.0], [915.0, 1407.0]], [[887.0, 1248.0], [914.0, 1248.0], [912.0, 1437.0], [886.0, 1437.0]]], "lines": ["なーんてね、", "なーんてね、", "ホホ甘酸っぱい。"]}, {"box": [590, 1262, 614, 1398], "vertical": true, "font_size": 22, "lines_coords": [[[590.0, 1262.0], [612.0, 1262.0], [614.0, 1398.0], [592.0, 1398.0]]], "lines": ["．．．"]}, {"box": [362, 1496, 502, 1552], "vertical": false, "font_size": 24, "lines_coords": [[[393.0, 1498.0], [489.0, 1494.0], [489.0, 1520.0], [393.0, 1523.0]], [[412.0, 1526.0], [471.0, 1526.0], [471.0, 1552.0], [412.0, 1552.0]]], "lines": ["ＫＳＲＯＭＳＡＮＡ", "ＴＩＲＯ"]}, {"box": [114, 1310, 155, 1514], "vertical": true, "font_size": 37, "lines_coords": [[[114.0, 1310.0], [151.0, 1310.0], [154.0, 1514.0], [117.0, 1514.0]]], "lines": ["トガさん！！"]}], "img_path": "subarashii_sekai_01_019.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [917, 103, 976, 304], "vertical": true, "font_size": 26, "lines_coords": [[[950.0, 103.0], [976.0, 103.0], [976.0, 262.0], [950.0, 262.0]], [[917.0, 103.0], [943.0, 103.0], [943.0, 304.0], [917.0, 304.0]]], "lines": ["ニョホホって、", "何やってんすか？"]}, {"box": [951, 671, 978, 795], "vertical": true, "font_size": 27, "lines_