12.0, 1404.0], [190.0, 1404.0]]], "lines": ["そうだよね、", "もう春なんだ。"]}], "img_path": "subarashii_sekai_01_170.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [849, 118, 874, 229], "vertical": true, "font_size": 22, "lines_coords": [[[850.0, 118.0], [872.0, 118.0], [872.0, 226.0], [850.0, 226.0]]], "lines": ["ただいま。"]}, {"box": [181, 103, 206, 228], "vertical": true, "font_size": 22, "lines_coords": [[[181.0, 103.0], [203.0, 103.0], [203.0, 226.0], [181.0, 226.0]]], "lines": ["ただいま？"]}, {"box": [200, 1307, 229, 1436], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 1307.0], [226.0, 1307.0], [226.0, 1435.0], [200.0, 1435.0]]], "lines": ["あ．．．．．れ？"]}], "img_path": "subarashii_sekai_01_171.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [875, 90, 908, 229], "vertical": true, "font_size": 28, "lines_coords": [[[879.0, 90.0], [908.0, 90.0], [903.0, 229.0], [875.0, 229.0]]], "lines": ["何、その頭？"]}, {"box": [911, 915, 979, 1034], "vertical": true, "font_size": 33, "lines_coords": [[[939.0, 915.0], [979.0, 915.0], [979.0, 990.0], [939.0, 990.0]], [[914.0, 918.0], [940.0, 918.0], [937.0, 1034.0], [911.0, 1034.0]]], "lines": ["はは、", "変な前髪。"]}, {"box": [546, 909, 611, 1040], "vertical": true, "font_size": 28, "lines_coords": [[[582.0, 910.0], [611.0, 910.0], [607.0, 1028.0], [579.0, 1028.0]], [[550.0, 909.0], [576.0, 909.0], [573.0, 1040.0], [546.0, 1040.0]]], "lines": ["何？何？", "どーした？"]}, {"box": [171, 1021, 234, 1178], "vertical": true, "font_size": 27, "lines_coords": [[[201.0, 1021.0], [234.0, 1021.0], [231.0, 1178.0], [198.0, 1178.0]], [[171.0, 1023.0], [198.0, 1023.0], [198.0, 1150.0], [171.0, 1150.0]]], "lines": ["．．．びっくり", "したぁ．．．"]}, {"box": [750, 1287, 811, 1456], "vertical": true, "font_size": 27, "lines_coords": [[[784.0, 1290.0], [811.0, 1290.0], [811.0, 1395.0], [784.0, 1395.0]], [[754.0, 1287.0], [781.0, 1287.0], [776.0, 1456.0], [750.0, 1456.0]]], "lines": ["お姉さん", "そっくりだよ。"]}, {"box