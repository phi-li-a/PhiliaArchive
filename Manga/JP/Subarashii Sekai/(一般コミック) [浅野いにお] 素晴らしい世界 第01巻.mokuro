4.0], [765.0, 1404.0], [765.0, 1423.0], [101.0, 1423.0]], [[101.0, 1424.0], [307.0, 1424.0], [307.0, 1444.0], [101.0, 1444.0]], [[101.0, 1444.0], [770.0, 1444.0], [770.0, 1464.0], [101.0, 1464.0]], [[101.0, 1463.0], [679.0, 1463.0], [679.0, 1483.0], [101.0, 1483.0]], [[100.0, 1482.0], [381.0, 1480.0], [381.0, 1505.0], [100.0, 1506.0]], [[101.0, 1504.0], [765.0, 1504.0], [765.0, 1523.0], [101.0, 1523.0]], [[101.0, 1524.0], [689.0, 1524.0], [689.0, 1544.0], [101.0, 1544.0]]], "lines": ["●遊ぶにはけが出来しておりますが、来てほしいませんが、２０１７年のベージの抜け落ちや場所の間違いでしょうか。いつの場合はお取り替えいたします。", "購入された書店名を明記して「新作品」あてにお送りください。選択が社員担にてお取り替えいたします。", "都市内局（ＴＥＢＬＯＬＩＤＩＤＬ３６６－１８）", "専門学校では２００８年の一部あるいは全部を無断ですが、複製「転職・上演・税込等をすることは法律で認められた場合を除き、", "著作者および出版者の権利の侵害となります。あらかじめ小社あで詐諾をお求めください。", "Ｒ〔日本複写権セファイルス・ンター委託出版物）", "本書の一部あったは全部を本当の「前または会話を無断で渡す」２０１７年コピーリすることは、著作権法上での例外を除き禁じられています。", "神戸を希望される場合は、日本複写権センター（ＴＥＤＬ）ＯＳ２０１７年１２月２３日日－２８８８２２にご連絡ください。"]}, {"box": [437, 1271, 893, 1379], "vertical": false, "font_size": 59.5, "lines_coords": [[[457.0, 1271.0], [678.0, 1271.0], [678.0, 1293.0], [457.0, 1293.0]], [[437.0, 1279.0], [893.0, 1282.0], [893.0, 1379.0], [437.0, 1376.0]]], "lines": ["京都千代田区一ノ橋一銀替〈００月１８０－１－２０１７年４月２０日（土）", "結婚、１０００年前から１０月１１日に開催されていますが、株式会社取扱いがありますので、今年の"]}], "img_path": "subarashii_sekai_01_207.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [], "img_path": "subarashii_sekai_01_208.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [], "img_path": "subarashii_sekai_01_209.jpg"}, {"version": "0.1.7", "img_width": 3852, "img_height": 1600, "blocks": [{"box": [1023, 30, 1598, 180], "vertical": false, "font_size": 69.5, "lines_coords": [[[1023.0, 30.0], [1598.0, 41.0], [1598.0, 131.0], [1023.0, 120.0]], [[1181.0, 131.0], [1542.0, 124.0], [1542.0, 173.0], [1181.0, 180.0]]], "lines": ["素晴らしい世界", "Ｗｏｎｄｅｒｆｕｌｗｏｒｌ"]}, {"box": [1519, 173, 1794, 594], "vertical": true, "font_size": 49.0, "lines_coords": [[[1752.0, 173.0], [1794.0, 173.0], [1794.0, 391.0], [1752.0, 391.0]], [[1673.0, 180.0], [1726.0, 180.0], [1726.0, 587.0], [1673.0, 587.0]], [[1598.0, 210.0], [1647.0, 210.0], [1647.0, 594.0], [1598.0, 594.0]], [[1527.0, 214.0], [1579.0, 214.0], [1572.0, 493.0], [1519.0, 493.0]]], "lines": ["．．．", "これからのアプリケーションについては、", "．．．", "．．．"]}, {"box": [7, 64, 60, 1136], "vertical": true, "font_size": 159, "lines_coords": [[[7.0, 64.0], [60.0, 64.0], [60.0, 496.0], [7.0, 496.0]], [[11.0, 481.0], [60.0, 481.0], [60.0, 1136.0], [11.0, 1136.0]]], "lines": ["それはそういうことでしょうがないのですが、ここまではなかったんですけど．．．", "これからのアプリケーションは、"]}, {"box": [71, 52, 507, 952], "vertical": true, "font_size": 159, "lines_coords": [[[440.0, 583.0], [507.0, 583.0], [507.0, 719.0], [440.0, 719.0]], [[71.0, 52.0], [146.0, 52.0], [146.0, 952.0], [71.0, 952.0]]], "lines": ["お．．", "．．．"]}, {"box": [233, 591, 447, 734], "vertical": true, "font_size": 159, "lines_coords": [[[278.0, 591.0], [447.0, 591.0], [447.0, 734.0], [278.0, 734.0]], [[233.0, 613.0], [293.0, 613.0], [293.0, 722.0], [233.0, 722.0]]], "lines": ["．．．いいにいいじゃないの", "野！！"]}, {"box": [150, 56, 658, 1317], "vertical": true, "font_size": 159, "lines_coords": [[[594.0, 154.0], [658.0, 154.0], [650.0, 1317.0], [586.0, 1317.0]], [[500.0, 146.0], [579.0, 146.0], [594.0, 1287.0], [515.0, 1287.0]], [[150.0, 56.0], [225.0, 56.0], [225.0, 730.0], [150.0, 730.0]]], "lines": ["それではないのでしょうか。これからもうちょっと．．．", "そういうことですから．．．", "いや、そういうのは"]}, {"box": [786, 176, 1203, 1189], "vertical": true, "font_size": 55.666666666666664, "lines_coords": [[[1147.0, 267.0], [1199.0, 267.0], [1203.0, 764.0], [1151.0, 764.0]], [[1068.0, 214.0], [1132.0, 214.0], [1143.0, 922.0], [1079.0, 922.0]], [[996.0, 188.0], [1060.0, 188.0], [1072.0, 1189.0], [1008.0, 1189.0]], [[932.0, 176.0], [985.0, 176.0], [993.0, 688.0], [940.0, 688.0]], [[865.0, 180.0], [914.0, 180.0], [914.0, 628.0], [865.0, 628.0]], [[786.0, 180.0], [838.0, 180.0], [838.0, 617.0], [786.0, 617.0]]], "lines": ["それは．．．", "そういうことですが、これからは", "それでも、", "それでも、これまではなかったのですが、このようになってしまうので、", "それにしても、ここまではなかったのですが、", "それはそういうことですが、このようになってしまったのです。"]}, {"box": [1850, 248, 1918, 809], "vertical": true, "font_size": 56, "lines_coords": [[[1850.0, 248.0], [1914.0, 248.0], [1918.0, 809.0], [1854.0, 809.0]]], "lines": ["それは．．．そうだな。"]}, {"box": [0, 726, 650, 1547], "vertical": true, "font_size": 159, "lines_coords": [[[244.0, 726.0], [417.0, 726.0], [417.0, 764.0], [244.0, 764.0]], [[263.0, 771.0], [394.0, 771.0], [394.0, 798.0], [263.0, 798.0]], [[203.0, 801.0], [455.0, 801.0], [455.0, 839.0], [203.0, 839.0]], [[248.0, 843.0], [421.0, 843.0], [421.0, 869.0], [248.0, 869.0]], [[214.0, 877.0], [447.0, 877.0], [447.0, 903.0], [214.0, 903.0]], [[274.0, 914.0], [394.0, 914.0], [394.0, 941.0], [274.0, 941.0]], [[240.0, 948.0], [432.0, 948.0], [432.0, 975.0], [240.0, 975.0]], [[218.0, 986.0], [447.0, 986.0], [447.0, 1012.0], [218.0, 1012.0]], [[282.0, 1020.0], [379.0, 1020.0], [379.0, 1046.0], [282.0, 1046.0]], [[387.0, 1054.0], [458.0, 1061.0], [440.0, 1257.0], [368.0, 1249.0]], [[0.0, 952.0], [150.0, 888.0], [285.0, 1374.0], [63.0, 1438.0]], [[135.0, 1400.0], [650.0, 1404.0], [650.0, 1441.0], [135.0, 1438.0]], [[109.0, 1505.0], [549.0, 1502.0], [549.0, 1543.0], [109.0, 1547.0]]], "lines": ["１期の年装練県同身", "玉川大学卒業", "２０１７年、第１１年３月２４日木", "制作５月号に受賞作", "本当からアニチリが男性", "０２年６月号より", "大計で読み切りシリーズ", "素晴らしい言葉もなんかーと", "現在に至る", "．．．！？．．．", "それでも、", "それでも、", "やっぱり何度もありませんが、"]}, {"box": [786, 591, 842, 1321], "vertical": true, "font_size": 49, "lines_coords": [[[793.0, 591.0], [842.0, 591.0], [835.0, 1321.0], [786.0, 1321.0]]], "lines": ["それでも、こんなことをしていたのですが、"]}, {"box": [861, 730, 989, 1246], "vertical": true, "font_size": 50.5, "lines_coords": [[[932.0, 730.0], [981.0, 730.0], [989.0, 1246.0], [940.0, 1246.0]], [[861.0, 764.0], [914.0, 764.0], [917.0, 1246.0], [865.0, 1246.0]]], "lines": ["．．．", "そういうことで、このようになってしまったのですが、"]}, {"box": [1105, 922, 1455, 971], "vertical": false, "font_size": 45.0, "lines_coords": [[[1143.0, 922.0], [1455.0, 922.0], [1455.0, 971.0], [1143.0, 971.0]], [[1105.0, 926.0], [1143.0, 926.0], [1143.0, 967.0], [1105.0, 967.0]]], "lines": ["浅野いによ", "浅"]}, {"box": [797, 1464, 985, 1524], "vertical": false, "font_size": 26.0, "lines_coords": [[[797.0, 1464.0], [985.0, 1464.0], [985.0, 1490.0], [797.0, 1490.0]], [[805.0, 1498.0], [936.0, 1498.0], [936.0, 1524.0], [805.0, 1524.0]]], "lines": ["．．．．．．．", "．．．．．．"]}, {"box": [2467, 75, 2806, 188], "vertical": false, "font_size": 39.5, "lines_coords": [[[2471.0, 75.0], [2806.0, 75.0], [2806.0, 112.0], [2471.0, 112.0]], [[2467.0, 146.0], [2685.0, 146.0], [2685.0, 188.0], [2467.0, 188.0]]], "lines": ["ＩＳＢＮ４－０９－１５７２１１－１", "Ｃ９９７９、¥５３３Ｅ"]}, {"box": [2455, 263, 2822, 380], "vertical": false, "font_size": 38, "lines_coords": [[[2463.0, 263.0], [2817.0, 263.0], [2817.0, 312.0], [2463.0, 312.0]], [[2475.0, 346.0], [2640.0, 346.0], [2640.0, 372.0], [2475.0, 372.0]], [[2667.0, 342.0], [2794.0, 342.0], [2794.0, 380.0], [2667.0, 380.0]]], "lines": ["定価：「本体５３０円十税", "雑誌４４０５２－１", "小学館"]}, {"box": [3189, 114, 3780, 350], "vertical": false, "font_size": 128, "lines_coords": [[[3189.0, 222.0], [3780.0, 222.0], [3780.0, 350.0], [3189.0, 350.0]]], "lines": ["素晴らしい世界"]}, {"box": [1926, 463, 1974, 790], "vertical": true, "font_size": 56, "lines_coords": [[[1926.0, 463.0], [1974.0, 463.0], [1974.0, 790.0], [1926.0, 790.0]]], "lines": ["そういえば、"]}, {"box": [2031, 417, 2245, 854], "vertical": true, "font_size": 51.0, "lines_coords": [[[2174.0, 466.0], [2226.0, 463.0], [2245.0, 820.0], [2193.0, 824.0]], [[2102.0, 417.0], [2155.0, 417.0], [2166.0, 854.0], [2114.0, 854.0]], [[2031.0, 429.0], [2080.0, 429.0], [2087.0, 839.0], [2038.0, 839.0]]], "lines": ["それでも、これからもうちょっとしていますのですが、", "そういうことですが、これからのお客様においておりますので、ございました。", "そういうことですが、これからこそ、それはそうでしょうがないのですね。"]}, {"box": [2226, 323, 2960, 854], "vertical": false, "font_size": 119.2, "lines_coords": [[[2396.0, 519.0], [2629.0, 512.0], [2629.0, 564.0], [2396.0, 572.0]], [[2324.0, 624.0], [2828.0, 617.0], [2828.0, 681.0], [2324.0, 688.0]], [[2354.0, 681.0], [2832.0, 673.0], [2832.0, 741.0], [2354.0, 749.0]], [[2320.0, 745.0], [2840.0, 745.0], [2840.0, 809.0], [2320.0, 809.0]], [[2226.0, 523.0], [2855.0, 323.0], [2960.0, 655.0], [2332.0, 854.0]]], "lines": ["それでも．．．", "そのため、その後の人がいなかったのですが、この時期の時間を取り戻すことができました。", "．．．いや、別の女の子は自分に気をつけているのかもしれませんが、", "．．．そんなことはないのですが、この時期の時間が終わりましたが．．．", "いや．．．"]}, {"box": [2836, 41, 3046, 1389], "vertical": true, "font_size": 64.0, "lines_coords": [[[2990.0, 52.0], [3043.0, 52.0], [3046.0, 1389.0], [2994.0, 1389.0]], [[2911.0, 45.0], [2975.0, 45.0], [2979.0, 1249.0], [2915.0, 1249.0]], [[2843.0, 41.0], [2919.0, 41.0], [2911.0, 1223.0], [2836.0, 1223.0]]], "lines": ["そういうことですが、これまではないでしょうか。これからもうちょっとそういうことですが、ここまではなかったのでしょうか。これから、", "それでも、．．．", "そういうことですが、"]}, {"box": [2035, 1061, 2087, 1302], "vertical": true, "font_size": 41, "lines_coords": [[[2046.0, 1061.0], [2087.0, 1061.0], [2076.0, 1302.0], [2035.0, 1302.0]]], "lines": ["．．．"]}, {"box": [2264, 790, 2313, 1125], "vertical": true, "font_size": 49, "lines_coords": [[[2264.0, 790.0], [2313.0, 790.0], [2313.0, 1125.0], [2264.0, 1125.0]]], "lines": ["．．．"]}, {"box": [2407, 824, 2825, 865], "vertical": false, "font_size": 38, "lines_coords": [[[2407.0, 828.0], [2825.0, 824.0], [2825.0, 862.0], [2407.0, 865.0]]], "lines": ["３０００年１９月１９日の月２１日"]}, {"box": [2407, 884, 2783, 1057], "vertical": false, "font_size": 55.0, "lines_coords": [[[2407.0, 884.0], [2783.0, 884.0], [2783.0, 948.0], [2407.0, 948.0]], [[2475.0, 1005.0], [2606.0, 1005.0], [2606.0, 1057.0], [2475.0, 1057.0]], [[2415.0, 952.0], [2783.0, 937.0], [2783.0, 986.0], [2415.0, 1001.0]]], "lines": ["それから、そのままでのお客さまがお客様で、", "．．．やってる！ＳＩＲＵＰ．", "いや、そういうことですが、この時期的には、"]}, {"box": [3194, 507, 3784, 1472], "vertical": false, "font_size": 27, "lines_coords": [[[3667.0, 532.0], [3754.0, 532.0], [3754.0, 551.0], [3667.0, 551.0]], [[3615.0, 551.0], [3761.0, 555.0], [3761.0, 585.0], [3615.0, 581.0]], [[3208.0, 562.0], [3487.0, 562.0], [3487.0, 581.0], [3208.0, 581.0]], [[3652.0, 589.0], [3757.0, 589.0], [3757