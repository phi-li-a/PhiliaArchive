6.0], [190.0, 776.0]], [[167.0, 720.0], [189.0, 720.0], [189.0, 832.0], [167.0, 832.0]]], "lines": ["ハイ", "そこまで。"]}, {"box": [364, 803, 728, 1081], "vertical": false, "font_size": 22.625, "lines_coords": [[[364.0, 931.0], [690.0, 803.0], [698.0, 823.0], [371.0, 950.0]], [[368.0, 950.0], [704.0, 817.0], [714.0, 840.0], [376.0, 971.0]], [[371.0, 970.0], [714.0, 837.0], [723.0, 859.0], [379.0, 992.0]], [[379.0, 989.0], [718.0, 856.0], [728.0, 879.0], [389.0, 1012.0]], [[387.0, 1007.0], [679.0, 893.0], [687.0, 915.0], [396.0, 1031.0]], [[403.0, 1034.0], [676.0, 929.0], [686.0, 953.0], [412.0, 1057.0]], [[409.0, 1059.0], [675.0, 956.0], [681.0, 973.0], [415.0, 1076.0]], [[451.0, 1064.0], [665.0, 982.0], [672.0, 1000.0], [457.0, 1081.0]]], "lines": ["．．．いや、いや．．．なんだ", "そんなことを言ってもいいでしょうかまた、来てください", "．．．いいじゃないでしょうか。そういうのは．．．いいじゃないの", "そんなことを言っていたのは、それでもいいのですが、また、見てくれているので、", "それにしても、それが悪いということは無理です。そういうことで", "これからもうちょっとしていますが、このようにしても", "いやいや、いいじゃないのいいでしょ、このように、", "そういえばいいんじゃないんだからこういうことですが、"]}, {"box": [507, 1006, 670, 1082], "vertical": false, "font_size": 18.0, "lines_coords": [[[507.0, 1065.0], [664.0, 1006.0], [670.0, 1023.0], [514.0, 1082.0]], [[565.0, 1064.0], [654.0, 1029.0], [661.0, 1046.0], [572.0, 1081.0]]], "lines": ["これは１０００ｍｂｉｏｋの", "．．．"]}, {"box": [257, 1323, 332, 1564], "vertical": true, "font_size": 72, "lines_coords": [[[257.0, 1325.0], [329.0, 1323.0], [332.0, 1562.0], [260.0, 1564.0]]], "lines": ["飛べっ！！"]}], "img_path": "subarashii_sekai_01_179.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [793, 129, 908, 284], "vertical": true, "font_size": 54, "lines_coords": [[[850.0, 129.0], [908.0, 129.0], [908.0, 284.0], [850.0, 284.0]], [[793.0, 131.0], [843.0, 131.0], [843.0, 281.0], [793.0, 281.0]]], "lines": ["飛べ！！", "遠藤！！"]}, {"box": [190, 598, 245, 750], "vertical": true, "font_size": 52, "lines_coords": [[[190.0, 600.0], [242.0, 598.0], [245.0, 748.0], [193.0, 750.0]]], "lines": ["痛っ！！"]}, {"box": [909, 856, 1001, 1035], "vertical": true, "font_size": 28, "lines_coords": [[[973.0, 857.0], [1001.0, 857.0], [997.0, 1025.0], [968.0, 1025.0]], [[940.0, 859.0], [967.0, 859.0], [967.0, 1010.0], [940.0, 1010.0]], [[909.0, 856.0], [936.0, 856.0], [936.0, 1035.0], [909.0, 1035.0]]], "lines": ["バッカおまえ、", "何回やったら", "成功すんだよ！"]}, {"box": [518, 848, 582, 1014], "vertical": true, "font_size": 33, "lines_coords": [[[543.0, 848.0], [582.0, 848.0], [582.0, 896.0], [543.0, 896.0]], [[518.0, 851.0], [545.0, 851.0], [545.0, 1014.0], [518.0, 1014.0]]], "lines": ["あ、", "言っちゃった。"]}, {"box": [117, 943, 212, 1109], "vertical": true, "font_size": 29, "lines_coords": [[[179.0, 945.0], [212.0, 945.0], [212.0, 1051.0], [179.0, 1051.0]], [[153.0, 945.0], [181.0, 945.0], [176.0, 1109.0], [148.0, 1109.0]], [[121.0, 943.0], [148.0, 943.0], [143.0, 1107.0], [117.0, 1107.0]]], "lines": ["デブって", "言っちゃった。", "ぜってー殺す。"]}, {"box": [691, 1278, 751, 1481], "vertical": true, "font_size": 25, "lines_coords": [[[723.0, 1278.0], [751.0, 1278.0], [748.0, 1459.0], [720.0, 1459.0]], [[692.0, 1281.0], [714.0, 1281.0], [714.0, 1481.0], [692.0, 1481.0]]], "lines": ["飛べないデブは", "ただのデフだぜ！？"]}, {"box": [162, 1287, 195, 1484], "vertical": true, "font_size": 31, "lines_coords": [[[162.0, 1287.0], [193.0, 1287.0], [193.0, 1484.0], [162.0, 1484.0]]], "lines": ["お、やるかぁ？"]}], "img_path": "subarashii_sekai_01_180.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [546, 81, 676, 289], "vertical": true, "font_size": 30, "lines_coords": [[[639.0, 84.0], [673.0, 82.0], [676.0, 175.0], [642.0, 176.0]], [[611.0, 81.0], [642.0, 81.0], [639.0, 289.0], [607.0, 289.0]], [[579.0, 81.0], [607.0, 81.0], [606.0, 287.0], [578.0, 287.0]], [[551.0, 82.0], [578.0, 82.0], [573.0, 245.0], [546.0, 245.0]]], "lines": ["タモツ。", "おまえとはいつか", "やり合う時が来る", "と思ってたさ。"]}, {"box": [125, 89, 183, 250], "vertical": true, "font_size": 25, "lines_coords": [[[153.0, 90.0], [181.0, 90.0], [181.0, 196.0], [153.0, 196.0]], [[126.0, 90.0], [148.0, 90.0], [148.0, 250.0], [126.0, 250.0]]], "lines": ["っつーか、", "ちょい待った。"]}, {"box": [858, 648, 949, 854], "vertical": true, "font_size": 26, "lines_coords": [[[923.0, 650.0], [947.0, 650.0], [945.0, 851.0], [922.0, 851.0]], [[890.0, 650.0], [917.0, 650.0], [917.0, 854.0], [890.0, 854.0]], [[858.0, 648.0], [886.0, 648.0], [886.0, 739.0], [858.0, 739.0]]], "lines": ["あ、あいつ、ウチの", "予備校で見たこと", "あるぜ。"]}, {"box": [143, 446, 204, 612], "vertical": true, "font_size": 29, "lines_coords": [[[173.0, 446.0], [204.0, 446.0], [204.0, 612.0], [173.0, 612.0]], [[143.0, 448.0], [170.0, 448.0], [170.0, 600.0], [143.0, 600.0]]], "lines": ["アレ、なーんか", "ヤバくねぇ？"]}, {"box": [403, 1129, 747, 1159], "vertical": false, "font_size": 28, "lines_coords": [[[403.0, 1131.0], [747.0, 1129.0], [747.0, 1157.0], [403.0, 1159.0]]], "lines": ["ｈｐｒｏｇｒａｍシロップ"]}, {"box": [189, 965, 245, 1039], "vertical": true, "font_size": 46, "lines_coords": [[[189.0, 973.0], [234.0, 965.0], [245.0, 1031.0], [200.0, 1039.0]]], "lines": ["あ。"]}, {"box": [881, 1357, 926, 1401], "vertical": false, "font_size": 44, "lines_coords": [[[881.0, 1357.0], [926.0, 1357.0], [926.0, 1401.0], [881.0, 1401.0]]], "lines": ["．．"]}, {"box": [171, 1343, 764, 1468], "vertical": false, "font_size": 82.33333333333333, "lines_coords": [[[412.0, 1346.0], [764.0, 1357.0], [761.0, 1446.0], [409.0, 1435.0]], [[225.0, 1346.0], [457.0, 1343.0], [459.0, 1428.0], [226.0, 1431.0]], [[171.0, 1395.0], [242.0, 1389.0], [248.0, 1462.0], [178.0, 1468.0]]], "lines": ["「らしいぜ", "ニョキら", "秦"]}], "img_path": "subarashii_sekai_01_181.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [537, 120, 632, 251], "vertical": true, "font_size": 30, "lines_coords": [[[606.0, 125.0], [632.0, 125.0], [632.0, 251.0], [606.0, 251.0]], [[573.0, 125.0], [601.0, 125.0], [601.0, 251.0], [573.0, 251.0]], [[537.0, 120.0], [573.0, 120.0], [573.0, 181.0], [537.0, 181.0]]], "lines": ["おまえ．．．", "何やってん", "の？"]}, {"box": [509, 460, 537, 612], "vertical": true, "font_size": 28, "lines_coords": [[[509.0, 460.0], [537.0, 460.0], [537.0, 612.0], [509.0, 612.0]]], "lines": ["シロップ．．．"]}, {"box": [154, 612, 195, 684], "vertical": true, "font_size": 41, "lines_coords": [[[154.0, 612.0], [195.0, 612.0], [195.0, 684.0], [154.0, 684.0]]], "lines": ["ん？"]}, {"box": [837, 812, 897, 1015], "vertical": true, "font_size": 27, "lines_coords": [[[868.0, 814.0], [895.0, 814.0], [897.0, 1015.0], [870.0, 1015.0]], [[837.0, 812.0], [864.0, 812.0], [864.0, 954.0], [837.0, 954.0]]], "lines": ["セキ止めシロップ", "ちょうだい。"]}, {"box": [887, 1121, 914, 1260], "vertical": true, "font_size": 27, "lines_coords": [[[887.0, 1121.0], [914.0, 1121.0], [914.0, 1260.0], [887.0, 1260.0]]], "lines": ["助かったよ。"]}, {"box": [437, 821, 528, 1049], "vertical": true, "font_size": 28, "lines_coords": [[[500.0, 821.0], [528.0, 821.0], [528.0, 926.0], [500.0, 926.0]]], "lines": ["こうして"]}, {"box": [436, 820, 496, 1050], "vertical": true, "font_size": 27, "lines_coords": [[[467.0, 820.0], [495.0, 820.0], [496.0, 1050.0], [468.0, 1050.0]], [[436.0, 821.0], [464.0, 821.0], [464.0, 960.0], [436.0, 960.0]]], "lines": ["俺たちはシロップと", "知り合った。"]}, {"box": [276, 821, 400, 1051], "vertical": true, "font_size": 27, "lines_coords": [[[371.0, 821.0], [398.0, 821.0], [400.0, 1051.0], [373.0, 1051.0]], [[339.0, 821.0], [365.0, 821.0], [368.0, 975.0], [342.0, 975.0]], [[307.0, 821.0], [334.0, 821.0], [334.0, 951.0], [307.0, 951.0]], [[276.0, 823.0], [303.0, 823.0], [303.0, 960.0], [276.0, 960.0]]], "lines": ["セキ止めシロップを", "常飲している", "挙動不振な", "困ったヤツ。"]}, {"box": [178, 823, 239, 1062], "vertical": true, "font_size": 28, "lines_coords": [[[210.0, 823.0], [239.0, 823.0], [239.0, 926.0], [210.0, 926.0]], [[178.0, 823.0], [204.0, 823.0], [209.0, 1059.0], [182.0, 1059.0]]], "lines": ["社会から", "はみ出ちゃったヤツ。"]}, {"box": [389, 1145, 480, 1284], "vertical": true, "font_size": 28, "lines_coords": [[[453.0, 1146.0], [479.0, 1146.0], [479.0, 1284.0], [453.0, 1284.0]], [[417.0, 1145.0], [450.0, 1145.0], [450.0, 1250.0], [417.0, 1250.0]], [[389.0, 1146.0], [415.0, 1146.0], [415.0, 1273.0], [389.0, 1273.0]]], "lines": ["てか、なんで", "セキ止め", "シロップ？"]}, {"box": [210, 1173, 273, 1338], "vertical": true, "font_size": 24, "lines_coords": [[[248.0, 1178.0], [270.0, 1178.0], [270.0, 1301.0], [248.0, 1301.0]], [[210.0, 1173.0], [237.0, 1173.0], [240.0, 1337.0], [214.0, 1337.0]]], "lines": ["飲まないと", "魂が離れてく。"]}, {"box": [164, 1357, 229, 1492], "vertical": true, "font_size": 34, "lines_coords": [[[184.0, 1359.0], [226.0, 1357.0], [229.0, 1432.0], [187.0, 1434.0]], [[164.0, 1362.0], [190.0, 1362.0], [190.0, 1456.0], [164.0, 1456.0]]], "lines": ["はは、", "アブねー"]}], "img_path": "subarashii_sekai_01_182.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [876, 81, 969, 283], "vertical": true, "font_size": 25, "lines_coords": [[[942.0, 82.0], [968.0, 82.0], [968.0, 235.0], [942.0, 235.0]], [[912.0, 84.0], [934.0, 84.0], [934.0, 282.0], [912.0, 282.0]], [[876.0, 81.0], [904.0, 81.0], [904.0, 171.0], [876.0, 171.0]]], "lines": ["飲んでる間は", "３倍のスピードで", "動ける。"]}, {"box": [767, 234, 830, 375], "vertical": true, "font_size": 30, "lines_coords": [[[803.0, 237.0], [829.0, 237.0], [829.0, 375.0], [803.0, 375.0]], [[770.0, 234.0], [803.0, 234.0], [800.0, 343.0], [767.0, 343.0]]], "lines": ["シャア・ザク", "じゃん！"]}, {"box": [553, 112, 586, 156], "vertical": true, "font_size": 27, "lines_coords": [[[553.0, 112.0], [586.0, 112.0], [586.0, 156.0], [553.0, 156.0]]], "lines": ["あー"]}, {"box": [476, 243, 532, 368], "vertical": true, "font_size": 27, "lines_coords": [[[511.0, 245.0], [532.0, 245.0], [532.0, 368.0], [511.0, 368.0]], [[476.0, 243.0], [503.0, 243.0], [503.0, 337.0], [476.0, 337.0]]], "lines": ["次は私大の", "試験かー"]}, {"box": [309, 84, 404, 262], "vertical": true, "font_size": 28, "lines_coords": [[[370.0, 85.0], [404.0, 85.0], [404.0, 178.0], [370.0, 178.0]], [[339.0, 84.0], [365.0, 84.0], [367.0, 262.0], [340.0, 262.0]], [[309.0, 85.0], [331.0, 85.0], [336.0, 250.0], [314.0, 250.0]]], "lines": ["バーカ。", "だりーこと思い", "出さすなって。"]}, {"box": [839, 718, 1000, 873], "vertical": true, "font_size": 28, "lines_coords": [[[965.0, 718.0], [1000.0, 718.0], [1000.0, 785.0], [965.0, 785.0]], [[942.0, 721.0], [968.0, 721.0], [968.0, 834.0], [942.0, 834.0]], [[915.0, 720.0], [942.0, 720.0], [942.0, 823.0], [915.0, 823.0]], [[887.0, 718.0], [915.0, 718.0], [917.0, 850.0], [889.0, 850.0]], [[865.0, 718.0], [893.0, 718.0], [890.0, 873.0], [862.0, 873.0]], [[839.0, 720.0], [865.0, 720.0], [865.0, 856.0], [839.0, 856.0]]], "lines": ["はは、", "なめんな。", "ここらで", "本気出して", "プルッと合格", "してやるよ。"]}, {"box": [107, 459, 200, 640], "vertical": true, "font_size": 25, "lines_coords": [[[175.0, 460.0], [196.0, 460.0], [196.0, 631.0], [175.0, 631.0]], [[140.0, 462.0], [167.0, 462.0], [167.0, 589.0], [140.0, 589.0]], [[107.0, 459.0], [134.0, 459.0], [137.0, 640.0], [110.0, 640.0]]], "lines": ["どーせ、おまえ、", "勉強なんて", "しないっしょ？"]}, {"box": [589, 1001, 773, 1231], "vertical": true, "font_size": 26, "lines_coords": [[[750.0, 1004.0], [772.0, 1004.0], [772.0, 1154.0], [750.0, 1154.0]], [[715.0, 1004.0], [742.0, 1004.0], [742.0, 1156.0], [715.0, 1156.0]], [[681.0, 1001.0], [707.0, 1001.0], [711.0, 1231.0], [684.0, 1231.0]], [[648.0, 1001.0], [675.0, 1001.0], [678.0, 1134.0], [651.0, 1134.0]], [[617.0, 1003.0], [643.0, 1003.0], [647.0, 1231.0], [620.0, 1231.0]], [[589.0, 1003.0], [615.0, 1003.0], [615.0, 1142.0], [589.0, 1142.0]]], "lines": ["まあそもそも", "俺らみたいな", "落ちこぼれ予備校生", "なんてのは、", "社会に居場所なんて", "ないワケて"]}, {"box": [398, 1003, 550, 1209], "vertical": true, "font_size": 27, "lines_coords": [[[523.0, 1004.0], [550.0, 1004.0], [550.0, 1160.0], [523.0, 1160.0]], [[490.0, 1004.0], [518.0, 1004.0], [518.0, 1106.0], [490.0, 1106.0]], [[459.0, 1004.0], [486.0, 1004.0], [486.0, 1206.0], [459.0, 1206.0]], [[428.0, 1004.0], [454.0, 1004.0], [454.0, 1162.0], [428.0, 1162.0]]], "lines": ["夢はあれとも、", "ただ毎日", "ぽんやりまったり", "生きてるだけ"]}, {"box": [200, 817, 226, 969], "vertical": true, "font_size": 22, "lines_coords": [[[201.0, 817.0], [223.0, 817.0], [223.0, 968.0], [201.0, 968.0]]], "lines": ["どうやって？"]}, {"box": [302, 1004, 393, 1218], "vertical": true, "font_size": 28, "lines_coords": [[[359.0, 1004.0], [393.0, 1004.0], [393.0, 1095.0], [359.0, 1095.0]], [[329.0, 1006.0], [356.0, 1006.0], [359.0, 1209.0], [332.0, 1209.0]], [[303.0, 1007.0], [325.0, 1007.0], [325.0, 1214.0], [303.0, 1214.0]]], "lines": ["どーせ、", "バカなヤツらって", "思われてんだろな"]}, {"box": [193, 1337, 225, 1471], "vertical": true, "font_size": 28, "lines_coords": [[[193.0, 1337.0], [221.0, 1337.0], [221.0, 1468.0], [193.0, 1468.0]]], "lines": ["気合いで。"]}], "img_path": "subarashii_sekai_01_183.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [515, 128, 636, 281], "vertical": true, "font_size": 28, "lines_coords": [[[609.0, 129.0], [636.0, 129.0], [636.0, 257.0], [609.0, 257.0]], [[578.0, 128.0], [606.0, 128.0], [601.0, 281.0], [573.0, 281.0]], [[546.0, 131.0], [573.0, 131.0], [573.0, 281.0], [546.0, 281.0]], [[515.0, 129.0], [543.0, 129.0], [543.0, 214.0], [515.0, 214.0]]], "lines": ["．．．．．．なんて", "言ってたのが", "大昔のことの", "ようで、"]}, {"box": [661, 354, 992, 535], "vertical": false, "font_size": 128, "lines_coords": [[[682.0, 354.0], [992.0, 409.0], [970.0, 535.0], [661.0, 481.0]]], "lines": ["ＮＥＴセミナー"]}, {"box": [640, 512, 870, 579], "vertical": false, "font_size": 44, "lines_coords": [[[645.0, 512.0], [870.0, 535.0], [865.0, 579.0], [640.0, 556.0]]], "lines": ["前項のように"]}, {"box": [115, 482, 267, 664], "vertical": true, "font_size": 27, "lines_coords": [[[240.0, 484.0], [267.0, 484.0], [267.0, 664.0], [240.0, 664.0]], [[209.0, 482.0], [235.0, 482.0], [234.0, 660.0], [207.0, 660.0]], [[178.0, 482.0], [206.0, 482.0], [203.0, 660.0], [175.0, 660.0]], [[145.0, 484.0], [171.0, 484.0], [170.0, 659.0], [143.0, 659.0]], [[115.0, 484.0], [142.0, 484.0], [142.0, 596.0], [115.0, 596.0]]], "lines": ["４月になった今、", "不思議なことに", "俺らはいまだに", "模試だ偏差値だ", "言ってる。"]}, {"box": [740, 745, 839, 950], "vertical": true, "font_size": 30, "lines_coords": [[[804.0, 746.0], [839.0, 746.0], [839.0, 839.0], [804.0, 839.0]], [[775.0, 746.0], [803.0, 746.0], [800.0, 950.0], [772.0, 950.0]], [[743.0, 745.0], [770.0, 745.0], [767.0, 912.0], [740.0, 912.0]]], "lines": ["やっぱ、", "現実ってリアルで", "キビシーのな。"]}, {"box": [200, 1088, 228, 1217], "vertical": true, "font_size": 28, "lines_coords": [[[200.0, 1089.0], [228.0, 1089.0], [228.0, 1170.0], [200.0, 1170.0]]], "lines": ["笑えね"]}, {"box": [736, 1235, 770, 1300], "vertical": true, "font_size": 34, "lines_coords": [[[736.0, 1235.0], [770.0, 1235.0], [770.0, 1300.0], [736.0, 1300.0]]], "lines": ["全滅。"]}, {"box": [673, 1235, 751, 1449], "vertical": true, "font_size": 27, "lines_coords": [[[673.0, 1235.0], [700.0, 1235.0], [703.0, 1440.0], [676.0, 1440.0]]], "lines": ["そして浪人２年目"]}, {"box": [536, 1235, 596, 1438], "vertical": true, "font_size": 25, "lines_coords": [[[570.0, 1239.0], [592.0, 1239.0], [592.0, 1437.0], [570.0, 1437.0]], [[536.0, 1235.0], [564.0, 1235.0], [564.0, 1350.0], [536.0, 1350.0]]], "lines": ["俺たち相変わらず", "予備校生。"]}, {"box": [303, 1240, 331, 1352], "vertical": true, "font_size": 23, "lines_coords": [[[303.0, 1240.0], [326.0, 1240.0], [329.0, 1346.0], [306.0, 1346.0]]], "lines": ["キャフン"]}], "img_path": "subarashii_sekai_01_184.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [867, 132, 960, 298], "vertical": true, "font_size": 29, "lines_coords": [[[933.0, 134.0], [959.0, 134.0], [959.0, 298.0], [933.0, 298.0]], [[898.0, 132.0], [926.0, 132.0], [928.0, 292.0], [900.0, 292.0]], [[867.0, 132.0], [900.0, 132.0], [900.0, 223.0], [867.0, 223.0]]], "lines": ["てか、実際問題", "やばいでしょ、", "マジで。"]}, {"box": [109, 100, 202, 281], "vertical": true, "font_size": 28, "lines_coords": [[[175.0, 103.0], [201.0, 103.0], [201.0, 231.0], [175.0, 231.0]], [[139.0, 101.0], [170.0, 101.0], [170.0, 281.0], [139.0, 281.0]], [[109.0, 100.0], [135.0, 100.0], [139.0, 253.0], [112.0, 253.0]]], "lines": ["年々確実に", "頭が悪くなって", "るって、絶対。"]}, {"box": [751, 410, 822, 439], "vertical": false, "font_size": 24, "lines_coords": [[[753.0, 410.0], [822.0, 415.0], [820.0, 439.0], [751.0, 434.0]]], "lines": ["一方適行"]}, {"box": [826, 617, 983, 931], "vertical": true, "font_size": 24, "lines_coords": [[[950.0, 618.0], [983.0, 618.0], [983.0, 710.0], [950.0, 710.0]], [[917.0, 617.0], [943.0, 617.0], [947.0, 770.0], [920.0, 770.0]], [[890.0, 620.0], [912.0, 620.0], [912.0, 904.0], [890.0, 904.0]], [[858.0, 618.0], [879.0, 618.0], [879.0, 779.0], [858.0, 779.0]], [[859.0, 773.0], [881.0, 773.0], [881.0, 929.0], [859.0, 929.0]], [[828.0, 776.0], [850.0, 776.0], [850.0, 892.0], [828.0, 892.0]]], "lines": ["バッカ。", "おまえだって", "同じような、もう諦めて", "もんたろが。", "みんなで３浪", "しようぜ。"]}, {"box": [118, 428, 277, 629], "vertical": true, "font_size": 26, "lines_coords": [[[250.0, 429.0], [276.0, 429.0], [271.0, 607.0], [245.0, 607.0]], [[217.0, 429.0], [243.0, 429.0], [242.0, 606.0], [215.0, 606.0]], [[185.0, 429.0], [212.0, 429.0], [212.0, 590.0], [185.0, 590.0]], [[153.0, 428.0], [179.0, 428.0], [179.0, 629.0], [153.0, 629.0]], [[118.0, 429.0], [145.0, 429.0], [148.0, 542.0], [121.0, 542.0]]], "lines": ["って言いながら", "毎日飲んだくれ", "てるタモツは、", "なかなか終わって", "るかもな。"]}, {"box": [251, 656, 373, 834], "vertical": true, "font_size": 27, "lines_coords": [[[346.0, 656.0], [373.0, 656.0], [373.0, 825.0], [346.0, 825.0]], [[314.0, 656.0], [340.0, 656.0], [340.0, 834.0], [314.0, 834.0]], [[282.0, 656.0], [309.0, 656.0], [309.0, 832.0], [282.0, 832.0]], [[251.0, 656.0], [278.0, 656.0], [278.0, 759.0], [251.0, 759.0]]], "lines": ["つーか、タモツ、", "写真で食ってく", "つもりなんじゃ", "ねぇの？"]}, {"box": [930, 970, 987, 1148], "vertical": true, "font_size": 24, "lines_coords": [[[961.0, 970.0], [987.0, 970.0], [986.0, 1148.0], [959.0, 1148.0]], [[931.0, 973.0], [953.0, 973.0], [953.0, 1100.0], [931.0, 1100.0]]], "lines": ["もしものための", "学歴だろ？"]}, {"box": [525, 1096, 582, 1260], "vertical": true, "font_size": 24, "lines_coords": [[[553.0, 1096.0], [581.0, 1096.0], [581.0, 1201.0], [553.0, 1201.0]], [[525.0, 1096.0], [546.0, 1096.0], [546.0, 1260.0], [525.0, 1260.0]]], "lines": ["逃げかも", "しんないけど。"]}, {"box": [164, 764, 221, 906], "vertical": true, "font_size": 27, "lines_coords": [[[192.0, 764.0], [220.0, 764.0], [221.0, 892.0], [193.0, 892.0]], [[164.0, 765.0], [190.0, 765.0], [190.0, 906.0], [164.0, 906.0]]], "lines": ["専門行きゃ", "いいじゃん。"]}, {"box": [110, 962, 203, 1193], "vertical": true, "font_size": 26, "lines_coords": [[[175.0, 962.0], [201.0, 962.0], [200.0, 1193.0], [173.0, 1193.0]], [[143.0, 965.0], [170.0, 965.0], [170.0, 1143.0], [143.0, 1143.0]], [[112.0, 964.0], [135.0, 964.0], [134.0, 1154.0], [110.0, 1154.0]]], "lines": ["そういやシロップは", "何か目指してる", "もんて、あんの？"]}], "img_path": "subarashii_sekai_01_185.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [831, 168, 863, 218], "vertical": true, "font_size": 32, "lines_coords": [[[831.0, 168.0], [863.0, 168.0], [863.0, 218.0], [831.0, 218.0]]], "lines": ["鳥。"]}, {"box": [817, 156, 875, 231], "vertical": false, "font_size": 69, "lines_coords": [[[817.0, 162.0], [867.0, 156.0], [875.0, 225.0], [825.0, 231.0]]], "lines": ["鳥。"]}, {"box": [804, 707, 831, 796], "vertical": true, "font_size": 27, "lines_coords": [[[804.0, 707.0], [831.0, 707.0], [831.0, 796.0], [804.0, 796.0]]], "lines": ["そうか。"]}, {"box": [606, 1042, 640, 1084], "vertical": true, "font_size": 34, "lines_coords": [[[606.0, 1042.0], [640.0, 1042.0], [640.0, 1084.0], [606.0, 1084.0]]], "lines": ["あ。"]}, {"box": [175, 828, 239, 948], "vertical": true, "font_size": 30, "lines_coords": [[[204.0, 828.0], [239.0, 828.0], [239.0, 900.0], [204.0, 900.0]], [[175.0, 832.0], [201.0, 832.0], [201.0, 948.0], [175.0, 948.0]]], "lines": ["まぁ、", "がんばれ。"]}, {"box": [134, 1293, 232, 1485], "vertical": true, "font_size": 26, "lines_coords": [[[203.0, 1298.0], [229.0, 1298.0], [229.0, 1482.0], [203.0, 1482.0]], [[171.0, 1293.0], [198.0, 1293.0], [195.0, 1450.0], [168.0, 1450.0]], [[134.0, 1295.0], [160.0, 1295.0], [160.0, 1485.0], [134.0, 1485.0]]], "lines": ["つーか、シロップ", "そこで寝たら", "繋かれるっしょ。"]}], "img_path": "subarashii_sekai_01_186.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [918, 131, 984, 261], "vertical": true, "font_size": 30, "lines_coords": [[[951.0, 131.0], [984.0, 132.0], [981.0, 237.0], [948.0, 235.0]], [[918.0, 132.0], [945.0, 132.0], [945.0, 259.0], [918.0, 259.0]]], "lines": ["しょうが", "ねぇな．．．"]}, {"box": [550, 123, 614, 240], "vertical": true, "font_size": 31, "lines_coords": [[[576.0, 125.0], [609.0, 123.0], [614.0, 239.0], [581.0, 240.0]], [[550.0, 125.0], [578.0, 125.0], [578.0, 215.0], [550.0, 215.0]]], "lines": ["．．．．．なぁ、", "タモツ。"]}, {"box": [376, 164, 412, 226], "vertical": true, "font_size": 36, "lines_coords": [[[376.0, 164.0], [412.0, 164.0], [412.0, 226.0], [376.0, 226.0]]], "lines": ["ん？"]}, {"box": [103, 45, 331, 87], "vertical": false, "font_size": 37, "lines_coords": [[[103.0, 45.0], [331.0, 50.0], [331.0, 87.0], [103.0, 82.0]]], "lines": ["素晴らしい世界"]}, {"box": [878, 640, 908, 795], "vertical": true, "font_size": 26, "lines_coords": [[[881.0, 640.0], [908.0, 640.0], [904.0, 795.0], [878.0, 795.0]]], "lines": ["急にどした？"]}, {"box": [311, 667, 409, 718], "vertical": false, "font_size": 29.5, "lines_coords": [[[314.0, 687.0], [404.0, 698.0], [401.0, 718.0], [311.0, 707.0]], [[318.0, 667.0], [409.0, 667.0], [409.0, 706.0], [318.0, 706.0]]], "lines": ["．．．", "．．．"]}, {"box": [112, 421, 237, 585], "vertical": true, "font_size": 26, "lines_coords": [[[203.0, 421.0], [237.0, 421.0], [237.0, 503.0], [203.0, 503.0]], [[171.0, 423.0], [200.0, 423.0], [203.0, 526.0], [175.0, 526.0]], [[145.0, 425.0], [167.0, 425.0], [167.0, 550.0], [145.0, 550.0]], [[112.0, 423.0], [134.0, 423.0], [135.0, 582.0], [114.0, 582.0]]], "lines": ["俺たち", "いつまで", "こんな生活", "してんだろな。"]}, {"box": [153, 681, 275, 885], "vertical": true, "font_size": 27, "lines_coords": [[[246.0, 681.0], [273.0, 681.0], [273.0, 812.0], [246.0, 812.0]], [[215.0, 681.0], [242.0, 681.0], [242.0, 835.0], [215.0, 835.0]], [[181.0, 681.0], [207.0, 681.0], [209.0, 885.0], [182.0, 885.0]], [[153.0, 681.0], [179.0, 681.0], [179.0, 795.0], [153.0, 795.0]]], "lines": ["勉強しねえ", "予備校生ほど", "タチの悪いもんは", "ねぇよな。"]}, {"box": [908, 951, 973, 1067], "vertical": true, "font_size": 30, "lines_coords": [[[939.0, 953.0], [973.0, 953.0], [973.0, 1034.0], [939.0, 1034.0]], [[908.0, 951.0], [934.0, 951.0], [937.0, 1067.0], [911.0, 1067.0]]], "lines": ["やっぱ", "甘えすぎ。"]}, {"box": [556, 1009, 616, 1170], "vertical": true, "font_size": 27, "lines_coords": [[[589.0, 1010.0], [615.0, 1010.0], [615.0, 1168.0], [589.0, 1168.0]], [[556.0, 1009.0], [584.0, 1009.0], [584.0, 1098.0], [556.0, 1098.0]]], "lines": ["甘えすぎだな、", "俺らは。"]}, {"box": [207, 1028, 270, 1120], "vertical": true, "font_size": 32, "lines_coords": [[[242.0, 1029.0], [270.0, 1029.0], [270.0, 1120.0], [242.0, 1120.0]], [[207.0, 1028.0], [242.0, 1028.0], [242.0, 1117.0], [207.0, 1117.0]]], "lines": ["俺、実家", "継ぐわ。"]}, {"box": [570, 1304, 662, 1488], "vertical": true, "font_size": 24, "lines_coords": [[[637.0, 1306.0], [659.0, 1306.0], [659.0, 1479.0], [637.0, 1479.0]], [[604.0, 1306.0], [626.0, 1306.0], [626.0, 1484.0], [604.0, 1484.0]], [[570.0, 1304.0], [597.0, 1304.0], [597.0, 1392.0], [570.0, 1392.0]]], "lines": ["ブツブツ言って", "ねぇで手伝えよ", "おまえ。"]}, {"box": [179, 1196, 217, 1259], "vertical": true, "font_size": 38, "lines_coords": [[[179.0, 1196.0], [217.0, 1196.0], [217.0, 1259.0], [179.0, 1259.0]]], "lines": ["は！？"]}], "img_path": "subarashii_sekai_01_187.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [918, 107, 1008, 271], "vertical": true, "font_size": 26, "lines_coords": [[[981.0, 107.0], [1008.0, 107.0], [1008.0, 271.0], [981.0, 271.0]], [[950.0, 109.0], [973.0, 109.0], [972.0, 259.0], [948.0, 259.0]], [[918.0, 110.0], [940.0, 110.0], [940.0, 235.0], [918.0, 235.0]]], "lines": ["実家って、あの", "滅びる寸前の", "魚屋だろ？"]}, {"box": [826, 271, 915, 453], "vertical": true, "font_size": 26, "lines_coords": [[[889.0, 275.0], [915.0, 275.0], [915.0, 437.0], [889.0, 437.0]], [[854.0, 271.0], [887.0, 271.0], [884.0, 453.0], [851.0, 453.0]], [[829.0, 273.0], [853.0, 273.0], [850.0, 378.0], [826.0, 378.0]]], "lines": ["大学は？プロ", "スケーターへの", "道はよ！？"]}, {"box": [647, 100, 705, 297], "vertical": true, "font_size": 58, "lines_coords": [[[647.0, 100.0], [705.0, 100.0], [705.0, 297.0], [647.0, 297.0]]], "lines": ["大学行かなくても魚屋は継げる。"]}, {"box": [645, 98, 704, 300], "vertical": true, "font_size": 26, "lines_coords": [[[676.0, 98.0], [703.0, 98.0], [704.0, 300.0], [678.0, 300.0]], [[645.0, 98.0], [668.0, 98.0], [670.0, 259.0], [647.0, 259.0]]], "lines": ["大学行かなくても", "魚屋は継げる。"]}, {"box": [475, 168, 562, 366], "vertical": true, "font_size": 87, "lines_coords": [[[475.0, 168.0], [562.0, 168.0], [562.0, 366.0], [475.0, 366.0]]], "lines": ["プロスケーターになるなんて、ネタだよネタ。"]}, {"box": [470, 164, 562, 368], "vertical": true, "font_size": 26, "lines_coords": [[[536.0, 164.0], [562.0, 164.0], [561.0, 368.0], [534.0, 368.0]], [[504.0, 167.0], [531.0, 167.0], [531.0, 301.0], [504.0, 301.0]], [[470.0, 165.0], [496.0, 165.0], [500.0, 331.0], [473.0, 331.0]]], "lines": ["プロスケーターに", "なるなんて、", "ネタだよネタ。"]}, {"box": [305, 112, 395, 317], "vertical": true, "font_size": 25, "lines_coords": [[[367.0, 114.0], [393.0, 114.0], [393.0, 287.0], [367.0, 287.0]], [[336.0, 112.0], [362.0, 112.0], [361.0, 317.0], [334.0, 317.0]], [[306.0, 114.0], [328.0, 114.0], [328.0, 250.0], [306.0, 250.0]]], "lines": ["ネタ！？嘘だね。", "おまえはけっこー", "本気だった。"]}, {"box": [889, 676, 950, 792], "vertical": true, "font_size": 27, "lines_coords": [[[920.0, 676.0], [948.0, 676.0], [950.0, 792.0], [922.0, 792.0]], [[889.0, 676.0], [922.0, 676.0], [922.0, 765.0], [889.0, 765.0]]], "lines": ["そうだよ。", "でもな、"]}, {"box": [110, 460, 266, 614], "vertical": true, "font_size": 27, "lines_coords": [[[235.0, 460.0], [262.0, 460.0], [262.0, 612.0], [235.0, 612.0]], [[203.0, 460.0], [229.0, 460.0], [229.0, 587.0], [203.0, 587.0]], [[173.0, 462.0], [201.0, 462.0], [201.0, 564.0], [173.0, 564.0]], [[142.0, 462.0], [170.0, 462.0], [170.0, 601.0], [142.0, 601.0]], [[110.0, 462.0], [137.0, 462.0], [137.0, 614.0], [110.0, 614.0]]], "lines": ["遠藤もついに", "夢を捨てて", "落ちつい", "ちゃったか。", "はは、だせぇ。"]}, {"box": [734, 770, 823, 934], "vertical": true, "font_size": 27, "lines_coords": [[[797.0, 770.0], [823.0, 770.0], [823.0, 875.0], [797.0, 875.0]], [[765.0, 770.0], [792.0, 770.0], [792.0, 921.0], [765.0, 921.0]], [[734.0, 770.0], [761.0, 770.0], [761.0, 934.0], [734.0, 934.0]]], "lines": ["重い夢を", "捨てたら体が", "軽くなったね。"]}, {"box": [844, 953, 965, 1182], "vertical": true, "font_size": 27, "lines_coords": [[[906.0, 953.0], [933.0, 953.0], [931.0, 1182.0], [904.0, 1182.0]]], "lines": ["とっちゃ大学なんて"]}, {"box": [840, 953, 964, 1182], "vertical": true, "font_size": 27, "lines_coords": [[[937.0, 954.0], [964.0, 954.0], [964.0, 1131.0], [937.0, 1131.0]], [[875.0, 954.0], [897.0, 954.0], [897.0, 1165.0], [875.0, 1165.0]], [[843.0, 953.0], [870.0, 953.0], [867.0, 1182.0], [840.0, 1182.0]]], "lines": ["俺たち劣等生に", "単なるステータス、", "ファッションだろ？"]}, {"box": [387, 1015, 495, 1196], "vertical": true, "font_size": 32, "lines_coords": [[[461.0, 1017.0], [495.0, 1017.0], [492.0, 1142.0], [457.0, 1142.0]], [[418.0, 1015.0], [451.0, 1015.0], [456.0, 1196.0], [423.0, 1196.0]], [[387.0, 1017.0], [414.0, 1017.0], [414.0, 1137.0], [387.0, 1137.0]]], "lines": ["バッカ！", "格好だけじゃ", "ねえよ！！"]}, {"box": [875, 1262, 996, 1414], "vertical": true, "font_size": 22, "lines_coords": [[[972.0, 1264.0], [993.0, 1264.0], [993.0, 1414.0], [972.0, 1414.0]], [[940.0, 1265.0], [962.0, 1265.0], [962.0, 1414.0], [940.0, 1414.0]], [[908.0, 1264.0], [929.0, 1264.0], [929.0, 1389.0], [908.0, 1389.0]], [[875.0, 1262.0], [901.0, 1262.0], [901.0, 1375.0], [875.0, 1375.0]]], "lines": ["おまえが年中", "ぶらさげてる", "そのカメラ", "みてぇに、"]}, {"box": [553, 1310, 684, 1470], "vertical": true, "font_size": 30, "lines_coords": [[[656.0, 1317.0], [682.0, 1317.0], [682.0, 1445.0], [656.0, 1445.0]], [[625.0, 1315.0], [653.0, 1315.0], [650.0, 1470.0], [622.0, 1470.0]], [[595.0, 1317.0], [622.0, 1317.0], [622.0, 1468.0], [595.0, 1468.0]], [[553.0, 1312.0], [593.0, 1310.0], [597.0, 1385.0], [556.0, 1387.0]]], "lines": ["格好だけの", "中身空っぽの", "ファッション", "だよ。"]}, {"box": [161, 1307, 229, 1490], "vertical": true, "font_size": 29, "lines_coords": [[[198.0, 1309.0], [229.0, 1309.0], [229.0, 1487.0], [198.0, 1487.0]], [[162.0, 1307.0], [189.0, 1307.0], [189.0, 1490.0], [162.0, 1490.0]]], "lines": ["コレは本当に", "俺の夢なん．．．"]}], "img_path": "subarashii_sekai_01_188.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [872, 93, 997, 375], "vertical": true, "font_size": 33, "lines_coords": [[[959.0, 93.0], [993.0, 93.0], [997.0, 342.0], [962.0, 342.0]], [[917.0, 96.0], [950.0, 96.0], [950.0, 375.0], [917.0, 375.0]], [[872.0, 95.0], [904.0, 95.0], [908.0, 273.0], [875.0, 273.0]]], "lines": ["オレらみたいな", "ただの落ちこばれ", "にはなぁ！！"]}, {"box": [114, 159, 242, 410], "vertical": true, "font_size": 36, "lines_coords": [[[203.0, 159.0], [237.0, 159.0], [239.0, 375.0], [204.0, 375.0]], [[159.0, 160.0], [196.0, 160.0], [196.0, 362.0], [159.0, 362.0]], [[114.0, 159.0], [150.0, 159.0], [153.0, 410.0], [117.0, 410.0]]], "lines": ["夢を語る資格", "なんざ、もう", "ねぇんだよっ！！"]}, {"box": [865, 540, 959, 670], "vertical": true, "font_size": 30, "lines_coords": [[[922.0, 542.0], [956.0, 540.0], [959.0, 623.0], [925.0, 625.0]], [[895.0, 545.0], [922.0, 545.0], [922.0, 670.0], [895.0, 670.0]], [[865.0, 543.0], [893.0, 543.0], [893.0, 628.0], [865.0, 628.0]]], "lines": ["俺たち", "ロ先だけの", "クズは、"]}, {"box": [156, 640, 245, 831], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 640.0], [245.0, 640.0], [242.0, 768.0], [214.0, 768.0]], [[185.0, 640.0], [212.0, 640.0], [212.0, 831.0], [185.0, 831.0]], [[156.0, 640.0], [178.0, 640.0], [178.0, 792.0], [156.0, 792.0]]], "lines": ["クズなりの", "考えを持とうぜ。", "そろそろ、さ。"]}, {"box": [160, 1345, 223, 1475], "vertical": true, "font_size": 31, "lines_coords": [[[184.0, 1346.0], [218.0, 1345.0], [223.0, 1435.0], [189.0, 1437.0]], [[160.0, 1346.0], [187.0, 1346.0], [187.0, 1475.0], [160.0, 1475.0]]], "lines": ["タモツ、", "てめぇ．．．"]}], "img_path": "subarashii_sekai_01_189.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [358, 580, 753, 675], "vertical": false, "font_size": 22, "lines_coords": [[[364.0, 585.0], [748.0, 585.0], [748.0, 607.0], [364.0, 607.0]], [[387.0, 617.0], [725.0, 617.0], [725.0, 639.0], [387.0, 639.0]], [[417.0, 648.0], [690.0, 648.0], [690.0, 670.0], [417.0, 670.0]]], "lines": ["わかってんた！わかってんだよ！！", "俺、こんなんていいいのかなんて", "いっつも思ってんだよ！！"]}, {"box": [334, 975, 810, 1066], "vertical": false, "font_size": 26, "lines_coords": [[[426.0, 975.0], [706.0, 975.0], [706.0, 1001.0], [426.0, 1001.0]], [[436.0, 1037.0], [704.0, 1039.0], [704.0, 1065.0], [436.0, 1064.0]], [[334.0, 1006.0], [807.0, 1007.0], [807.0, 1034.0], [334.0, 1032.0]]], "lines": ["ても考えれば考えるほど", "気付きそうになってさ、", "自分がかなり終わってるヤツだってことに"]}, {"box": [185, 1195, 237, 1248], "vertical": false, "font_size": 24, "lines_coords": [[[203.0, 1195.0], [237.0, 1232.0], [218.0, 1248.0], [185.0, 1210.0]]], "lines": ["へ"]}, {"box": [370, 1367, 754, 1389], "vertical": false, "font_size": 22, "lines_coords": [[[370.0, 1367.0], [754.0, 1367.0], [754.0, 1389.0], [370.0, 1389.0]]], "lines": ["そんなん、気付きたくないじゃん！"]}, {"box": [218, 1400, 908, 1421], "vertical": false, "font_size": 21, "lines_coords": [[[218.0, 1400.0], [908.0, 1400.0], [908.0, 1421.0], [218.0, 1421.0]]], "lines": ["ゴマかしたっていいじゃん！いい加減でいさせてくれって！！"]}, {"box": [428, 1440, 693, 1470], "vertical": false, "font_size": 27, "lines_coords": [[[428.0, 1443.0], [693.0, 1440.0], [693.0, 1467.0], [428.0, 1470.0]]], "lines": ["俺の未来なんて．．．"]}], "img_path": "subarashii_sekai_01_190.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [98, 59, 357, 90], "vertical": false, "font_size": 31, "lines_coords": [[[98.0, 59.0], [357.0, 59.0], [357.0, 90.0], [98.0, 90.0]]], "lines": ["素晴らしい世界１"]}, {"box": [457, 465, 639, 564], "vertical": false, "font_size": 63, "lines_coords": [[[482.0, 478.0], [634.0, 465.0], [639.0, 517.0], [487.0, 529.0]], [[457.0, 476.0], [504.0, 475.0], [507.0, 560.0], [461.0, 562.0]], [[484.0, 512.0], [636.0, 507.0], [637.0, 559.0], [486.0, 564.0]]], "lines": ["真っ暗だ！", "真真", "真っ暗だ！"]}, {"box": [406, 1268, 686, 1317], "vertical": false, "font_size": 49, "lines_coords": [[[406.0, 1268.0], [686.0, 1268.0], [686.0, 1317.0], [406.0, 1317.0]]], "lines": ["真っ暗闇だ！！"]}], "img_path": "subarashii_sekai_01_191.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [734, 257, 1022, 428], "vertical": false, "font_size": 116, "lines_coords": [[[757.0, 257.0], [1022.0, 314.0], [998.0, 428.0], [734.0, 371.0]]], "lines": ["下田ゼ"]}, {"box": [765, 426, 939, 484], "vertical": false, "font_size": 42, "lines_coords": [[[770.0, 426.0], [939.0, 442.0], [934.0, 484.0], [765.0, 468.0]]], "lines": ["前期は"]}, {"box": [786, 987, 859, 1107], "vertical": true, "font_size": 30, "lines_coords": [[[826.0, 987.0], [854.0, 987.0], [854.0, 1104.0], [826.0, 1104.0]], [[786.0, 995.0], [818.0, 995.0], [818.0, 1107.0], [786.0, 1107.0]]], "lines": ["関係者以外", "立ヘ禁止"]}], "img_path": "subarashii_sekai_01_192.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [106, 54, 364, 85], "vertical": false, "font_size": 31, "lines_coords": [[[106.0, 54.0], [364.0, 54.0], [364.0, 85.0], [106.0, 85.0]]], "lines": ["素晴らしい世界１"]}, {"box": [179, 693, 203, 772], "vertical": true, "font_size": 24, "lines_coords": [[[179.0, 693.0], [203.0, 693.0], [203.0, 770.0], [179.0, 770.0]]], "lines": ["う．．．"]}, {"box": [520, 908, 551, 1050], "vertical": true, "font_size": 26, "lines_coords": [[[520.0, 929.0], [546.0, 928.0], [551.0, 1048.0], [525.0, 1050.0]]], "lines": ["．．．くそっ。"]}, {"box": [148, 1314, 177, 1417], "vertical": true, "font_size": 28, "lines_coords": [[[148.0, 1314.0], [176.0, 1314.0], [176.0, 1415.0], [148.0, 1415.0]]], "lines": ["タモツ。"]}], "img_path": "subarashii_sekai_01_193.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [895, 116, 921, 252], "vertical": true, "font_size": 21, "lines_coords": [[[897.0, 117.0], [918.0, 117.0], [918.0, 251.0], [897.0, 251.0]]], "lines": ["無理すんな。"]}, {"box": [867, 720, 925, 923], "vertical": true, "font_size": 26, "lines_coords": [[[897.0, 721.0], [923.0, 721.0], [923.0, 923.0], [897.0, 923.0]], [[867.0, 720.0], [893.0, 720.0], [893.0, 906.0], [867.0, 906.0]]], "lines": ["みんなそれぞれの", "生き方があって、"]}, {"box": [870, 978, 960, 1179], "vertical": true, "font_size": 24, "lines_coords": [[[936.0, 979.0], [958.0, 979.0], [958.0, 1179.0], [936.0, 1179.0]], [[904.0, 981.0], [926.0, 981.0], [926.0, 1156.0], [904.0, 1156.0]], [[870.0, 978.0], [897.0, 978.0], [898.0, 1168.0], [872.0, 1168.0]]], "lines": ["もちろん生き方に", "正解も間違いも", "ないんだろうが。"]}, {"box": [640, 1000, 762, 1176], "vertical": true, "font_size": 24, "lines_coords": [[[734.0, 1000.0], [762.0, 1000.0], [762.0, 1112.0], [734.0, 1112.0]], [[701.0, 1001.0], [728.0, 1001.0], [728.0, 1176.0], [701.0, 1176.0]], [[673.0, 1000.0], [693.0, 1000.0], [693.0, 1153.0], [673.0, 1153.0]], [[640.0, 1001.0], [662.0, 1001.0], [662.0, 1112.0], [640.0, 1112.0]]], "lines": ["シロップ、", "今日はずいぶん", "まともなこと", "言うのな。"]}, {"box": [167, 750, 290, 959], "vertical": true, "font_size": 28, "lines_coords": [[[260.0, 753.0], [287.0, 753.0], [287.0, 959.0], [260.0, 959.0]], [[229.0, 753.0], [256.0, 753.0], [256.0, 907.0], [229.0, 907.0]], [[193.0, 750.0], [225.0, 750.0], [228.0, 946.0], [196.0, 946.0]], [[167.0, 753.0], [193.0, 753.0], [193.0, 893.0], [167.0, 893.0]]], "lines": ["それが正しいのか", "どうか不安で", "不安で、しょうが", "ないワケさ。"]}, {"box": [146, 1025, 240, 1142], "vertical": true, "font_size": 32, "lines_coords": [[[212.0, 1028.0], [240.0, 1028.0], [240.0, 1131.0], [212.0, 1131.0]], [[175.0, 1026.0], [209.0, 1025.0], [214.0, 1140.0], [179.0, 1142.0]], [[146.0, 1026.0], [179.0, 1026.0], [179.0, 1118.0], [146.0, 1118.0]]], "lines": ["コイツが", "効いてて、", "覚醒中。"]}, {"box": [534, 1221, 582, 1310], "vertical": true, "font_size": 41, "lines_coords": [[[534.0, 1226.0], [575.0, 1221.0], [582.0, 1307.0], [542.0, 1310.0]]], "lines": ["おっ。"]}, {"box": [160, 1385, 192, 1443], "vertical": true, "font_size": 32, "lines_coords": [[[160.0, 1385.0], [192.0, 1385.0], [192.0, 1443.0], [160.0, 1443.0]]], "lines": ["ん？"]}], "img_path": "subarashii_sekai_01_194.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [725, 131, 753, 220], "vertical": true, "font_size": 26, "lines_coords": [[[725.0, 131.0], [753.0, 131.0], [753.0, 220.0], [725.0, 220.0]]], "lines": ["遠藤だ。"]}, {"box": [579, 215, 673, 332], "vertical": true, "font_size": 26, "lines_coords": [[[642.0, 215.0], [670.0, 215.0], [673.0, 332.0], [645.0, 332.0]], [[614.0, 221.0], [636.0, 221.0], [636.0, 320.0], [614.0, 320.0]], [[579.0, 215.0], [606.0, 215.0], [606.0, 307.0], [579.0, 307.0]]], "lines": ["．．．．．まぁ、", "そんな顔", "するな。"]}, {"box": [337, 129, 395, 238], "vertical": true, "font_size": 27, "lines_coords": [[[368.0, 129.0], [395.0, 129.0], [395.0, 232.0], [368.0, 232.0]], [[337.0, 129.0], [364.0, 129.0], [364.0, 237.0], [337.0, 237.0]]], "lines": ["おまえら", "二人とも、"]}, {"box": [842, 679, 943, 835], "vertical": true, "font_size": 34, "lines_coords": [[[903.0, 679.0], [943.0, 679.0], [943.0, 754.0], [903.0, 754.0]], [[875.0, 682.0], [903.0, 682.0], [904.0, 835.0], [876.0, 835.0]], [[842.0, 681.0], [876.0, 681.0], [876.0, 751.0], [842.0, 751.0]]], "lines": ["見ろ。", "この汚い街の", "眺め。"]}, {"box": [143, 460, 205, 650], "vertical": true, "font_size": 27, "lines_coords": [[[176.0, 460.0], [204.0, 460.0], [204.0, 565.0], [176.0, 565.0]], [[143.0, 460.0], [170.0, 460.0], [171.0, 650.0], [145.0, 650.0]]], "lines": ["それぞれ", "それでいいのさ。"]}, {"box": [246, 723, 343, 878], "vertical": true, "font_size": 28, "lines_coords": [[[314.0, 726.0], [342.0, 726.0], [343.0, 829.0], [315.0, 829.0]], [[282.0, 726.0], [309.0, 726.0], [309.0, 878.0], [282.0, 878.0]], [[246.0, 725.0], [279.0, 723.0], [282.0, 817.0], [250.0, 818.0]]], "lines": ["理不尽で", "矛盾だらけの", "社会だ。"]}, {"box": [156, 921, 315, 1101], "vertical": true, "font_size": 28, "lines_coords": [[[279.0, 921.0], [315.0, 921.0], [315.0, 982.0], [279.0, 982.0]], [[253.0, 926.0], [279.0, 926.0], [279.0, 1054.0], [253.0, 1054.0]], [[218.0, 923.0], [245.0, 923.0], [246.0, 1101.0], [220.0, 1101.0]], [[190.0, 926.0], [212.0, 926.0], [212.0, 1076.0], [190.0, 1076.0]], [[156.0, 928.0], [184.0, 928.0], [184.0, 1014.0], [156.0, 1014.0]]], "lines": ["俺は", "鳥になって", "ここから飛んで", "逃げ出したい", "のだよ。"]}, {"box": [814, 1189, 904, 1343], "vertical": true, "font_size": 26, "lines_coords": [[[878.0, 1189.0], [904.0, 1189.0], [901.0, 1343.0], [875.0, 1343.0]], [[845.0, 1192.0], [872.0, 1192.0], [872.0, 1318.0], [845.0, 1318.0]], [[814.0, 1190.0], [840.0, 1190.0], [840.0, 1331.0], [814.0, 1331.0]]], "lines": ["でも逃げられ", "ないことは", "わかってる。"]}, {"box": [204, 1314, 292, 1492], "vertical": true, "font_size": 25, "lines_coords": [[[265.0, 1315.0], [292.0, 1315.0], [292.0, 1418.0], [265.0, 1418.0]], [[232.0, 1314.0], [259.0, 1314.0], [260.0, 1492.0], [234.0, 1492.0]], [[204.0, 1317.0], [226.0, 1317.0], [226.0, 1492.0], [204.0, 1492.0]]], "lines": ["俺はもう", "夢は夢のままで", "かまわないさ！"]}], "img_path": "subarashii_sekai_01_195.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [879, 125, 973, 326], "vertical": true, "font_size": 43, "lines_coords": [[[933.0, 128.0], [970.0, 128.0], [970.0, 326.0], [933.0, 326.0]], [[879.0, 125.0], [928.0, 125.0], [928.0, 215.0], [879.0, 215.0]]], "lines": ["大事なのは", "今！！"]}, {"box": [137, 159, 308, 409], "vertical": true, "font_size": 37, "lines_coords": [[[267.0, 160.0], [306.0, 160.0], [306.0, 303.0], [267.0, 303.0]], [[223.0, 159.0], [260.0, 159.0], [260.0, 376.0], [223.0, 376.0]], [[176.0, 159.0], [215.0, 159.0], [218.0, 409.0], [179.0, 409.0]], [[137.0, 162.0], [170.0, 162.0], [170.0, 375.0], [137.0, 375.0]]], "lines": ["俺の目が", "しっかり前を", "見ているかって", "ことなのだ！！！"]}, {"box": [900, 770, 992, 1028], "vertical": true, "font_size": 40, "lines_coords": [[[947.0, 770.0], [989.0, 770.0], [992.0, 1028.0], [950.0, 1028.0]], [[901.0, 771.0], [939.0, 771.0], [939.0, 1015.0], [901.0, 1015.0]]], "lines": ["飛ぶで飛ぶぞ、", "俺は飛ぶぞ！！！"]}, {"box": [168, 948, 262, 1193], "vertical": true, "font_size": 42, "lines_coords": [[[218.0, 948.0], [260.0, 948.0], [260.0, 1193.0], [218.0, 1193.0]], [[168.0, 950.0], [210.0, 950.0], [210.0, 1154.0], [168.0, 1154.0]]], "lines": ["あの真っ赤な", "太陽へぇ！！！"]}, {"box": [815, 1259, 844, 1411], "vertical": true, "font_size": 27, "lines_coords": [[[815.0, 1259.0], [842.0, 1259.0], [842.0, 1409.0], [815.0, 1409.0]]], "lines": ["シロップ．．．"]}], "img_path": "subarashii_sekai_01_196.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [93, 51, 348, 87], "vertical": false, "font_size": 33, "lines_coords": [[[93.0, 51.0], [348.0, 54.0], [348.0, 87.0], [93.0, 84.0]]], "lines": ["素晴らしい世界で"]}, {"box": [373, 567, 397, 604], "vertical": true, "font_size": 24, "lines_coords": [[[373.0, 567.0], [397.0, 567.0], [397.0, 604.0], [373.0, 604.0]]], "lines": ["あ。"]}, {"box": [361, 557, 406, 614], "vertical": false, "font_size": 51, "lines_coords": [[[361.0, 564.0], [398.0, 557.0], [406.0, 607.0], [368.0, 614.0]]], "lines": ["あ。"]}, {"box": [870, 817, 979, 1032], "vertical": true, "font_size": 47, "lines_coords": [[[922.0, 820.0], [979.0, 820.0], [979.0, 951.0], [922.0, 951.0]], [[870.0, 817.0], [929.0, 817.0], [929.0, 1032.0], [870.0, 1032.0]]], "lines": ["わ、わ、", "わーっ！！！"]}, {"box": [873, 1095, 947, 1284], "vertical": true, "font_size": 47, "lines_coords": [[[906.0, 1095.0], [947.0, 1095.0], [947.0, 1195.0], [906.0, 1195.0]], [[873.0, 1098.0], [904.0, 1098.0], [904.0, 1284.0], [873.0, 1284.0]]], "lines": ["やばい", "やばいって！！"]}, {"box": [153, 1198, 206, 1468], "vertical": true, "font_size": 53, "lines_coords": [[[153.0, 1198.0], [206.0, 1198.0], [206.0, 1468.0], [153.0, 1468.0]]], "lines": ["遠藤おーっ！！"]}], "img_path": "subarashii_sekai_01_197.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [353, 198, 456, 507], "vertical": true, "font_size": 25, "lines_coords": [[[434.0, 206.0], [456.0, 206.0], [456.0, 303.0], [434.0, 303.0]], [[403.0, 203.0], [425.0, 203.0], [425.0, 326.0], [403.0, 326.0]], [[367.0, 198.0], [400.0, 200.0], [386.0, 507.0], [353.0, 506.0]]], "lines": ["いきなり", "あんな大声", "出すからさ。あそこで失神"]}, {"box": [901, 536, 931, 700], "vertical": true, "font_size": 27, "lines_coords": [[[904.0, 539.0], [931.0, 539.0], [928.0, 700.0], [901.0, 700.0]]], "lines": ["．．．．．つーかさ。"]}, {"box": [450, 575, 486, 635], "vertical": true, "font_size": 36, "lines_coords": [[[450.0, 575.0], [486.0, 575.0], [486.0, 635.0], [450.0, 635.0]]], "lines": ["ん？"]}, {"box": [300, 350, 356, 515], "vertical": true, "font_size": 25, "lines_coords": [[[329.0, 350.0], [356.0, 350.0], [353.0, 456.0], [326.0, 456.0]], [[300.0, 353.0], [321.0, 353.0], [321.0, 515.0], [300.0, 515.0]]], "lines": ["されたら", "たまんねぇよ。"]}, {"box": [192, 635, 281, 789], "vertical": true, "font_size": 25, "lines_coords": [[[251.0, 635.0], [278.0, 635.0], [281.0, 789.0], [254.0, 789.0]], [[223.0, 637.0], [250.0, 637.0], [250.0, 740.0], [223.0, 740.0]], [[192.0, 639.0], [214.0, 639.0], [214.0, 789.0], [192.0, 789.0]]], "lines": ["あんなトコで", "二人で何", "してたのよ？"]}, {"box": [675, 912, 698, 1039], "vertical": true, "font_size": 25, "lines_coords": [[[675.0, 982.0], [698.0, 982.0], [698.0, 1039.0], [675.0, 1039.0]], [[675.0, 912.0], [698.0, 912.0], [698.0, 957.0], [675.0, 957.0]]], "lines": ["．．．．．．", "んー"]}, {"box": [581, 1029, 614, 1232], "vertical": true, "font_size": 25, "lines_coords": [[[586.0, 1029.0], [614.0, 1029.0], [609.0, 1232.0], [581.0, 1232.0]]], "lines": ["「大事な話」っーか"]}, {"box": [520, 1028, 612, 1235], "vertical": true, "font_size": 30, "lines_coords": [[[556.0, 1029.0], [582.0, 1029.0], [576.0, 1235.0], [550.0, 1235.0]], [[520.0, 1029.0], [553.0, 1029.0], [553.0, 1120.0], [520.0, 1120.0]]], "lines":