ize": 24, "lines_coords": [[[767.0, 1463.0], [953.0, 1460.0], [953.0, 1486.0], [767.0, 1489.0]]], "lines": ["．．．。。。、。。"]}], "img_path": "subarashii_sekai_01_004.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [185, 340, 264, 495], "vertical": true, "font_size": 38, "lines_coords": [[[218.0, 342.0], [256.0, 340.0], [264.0, 490.0], [226.0, 492.0]], [[185.0, 360.0], [223.0, 360.0], [223.0, 495.0], [185.0, 495.0]]], "lines": ["飛び出し", "注意！！"]}, {"box": [128, 842, 504, 870], "vertical": false, "font_size": 26, "lines_coords": [[[128.0, 843.0], [504.0, 842.0], [504.0, 868.0], [128.0, 870.0]]], "lines": ["１ｓｔｐｒｏｇｒａｍ脱兎さん"]}, {"box": [171, 1351, 462, 1446], "vertical": false, "font_size": 74.0, "lines_coords": [[[176.0, 1351.0], [262.0, 1359.0], [257.0, 1415.0], [171.0, 1407.0]], [[237.0, 1351.0], [462.0, 1354.0], [461.0, 1446.0], [235.0, 1443.0]]], "lines": ["キュ", "ちょっと"]}, {"box": [484, 1375, 784, 1456], "vertical": false, "font_size": 72, "lines_coords": [[[486.0, 1375.0], [784.0, 1384.0], [782.0, 1456.0], [484.0, 1446.0]]], "lines": ["らしいぜ"]}, {"box": [895, 1365, 942, 1404], "vertical": false, "font_size": 39, "lines_coords": [[[895.0, 1365.0], [942.0, 1365.0], [942.0, 1404.0], [895.0, 1404.0]]], "lines": ["．．"]}], "img_path": "subarashii_sekai_01_005.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [846, 207, 1017, 409], "vertical": true, "font_size": 25, "lines_coords": [[[989.0, 209.0], [1015.0, 209.0], [1015.0, 404.0], [989.0, 404.0]], [[959.0, 207.0], [986.0, 207.0], [986.0, 360.0], [959.0, 360.0]], [[931.0, 210.0], [958.0, 210.0], [958.0, 359.0], [931.0, 359.0]], [[900.0, 207.0], [928.0, 207.0], [929.0, 345.0], [901.0, 345.0]], [[875.0, 210.0], [897.0, 210.0], [897.0, 384.0], [875.0, 384.0]], [[847.0, 210.0], [867.0, 210.0], [867.0, 365.0], [847.0, 365.0]]], "lines": ["築２５年、フロなし。", "窓を開ければ", "小田急線．．．の", "安アパート。", "その日暮らしの", "目堕落な生活"]}, {"box": [203, 379, 268, 547], "vertical": true, "font_size": 31, "lines_coords": [[[229.0, 381.0], [265.0, 379.0], [268.0, 450.0], [232.0, 451.0]], [[203.0, 384.0], [229.0, 384.0], [229.0, 542.0], [203.0, 542.0]]], "lines": ["まぁ、", "それもいいさ。"]}, {"box": [814, 735, 969, 951], "vertical": true, "font_size": 27, "lines_coords": [[[940.0, 739.0], [967.0, 739.0], [967.0, 917.0], [940.0, 917.0]], [[908.0, 735.0], [936.0, 735.0], [937.0, 951.0], [909.0, 951.0]], [[875.0, 735.0], [901.0, 735.0], [901.0, 851.0], [875.0, 851.0]], [[845.0, 735.0], [872.0, 735.0], [872.0, 840.0], [845.0, 840.0]], [[814.0, 735.0], [840.0, 735.0], [840.0, 914.0], [814.0, 914.0]]], "lines": ["ホントに気持ち", "よさそうに寝るぜ、", "アンタは。", "どんな夢", "見てんだか．．．"]}, {"box": [351, 1092, 508, 1281], "vertical": true, "font_size": 26, "lines_coords": [[[481.0, 1093.0], [507.0, 1093.0], [506.0, 1281.0], [479.0, 1281.0]], [[450.0, 1093.0], [476.0, 1093.0], [476.0, 1270.0], [450.0, 1270.0]], [[418.0, 1095.0], [445.0, 1095.0], [445.0, 1231.0], [418.0, 1231.0]], [[390.0, 1095.0], [412.0, 1095.0], [412.0, 1220.0], [390.0, 1220.0]], [[354.0, 1092.0], [382.0, 1092.0], [379.0, 1217.0], [351.0, 1217.0]]], "lines": ["でも、いつまでも", "寝てるわけには", "いかねぇぜ。", "そうだろ？", "トガさん"]}, {"box": [185, 1265, 223, 1478], "vertical": true, "font_size": 30, "lines_coords": [[[193.0, 1425.0], [218.0, 1425.0], [218.0, 1473.0], [193.0, 1473.0]], [[185.0, 1265.0], [221.0, 1265.0], [221.0, 1325.0], [185.0, 1325.0]]], "lines": ["！", "えー"]}], "img_path": "subarashii_sekai_01_006.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [853, 128, 980, 283], "vertical": true, "font_size": 31, "lines_coords": [[[951.0, 128.0], [978.0, 128.0], [978.0, 237.0], [951.0, 237.0]], [[915.0, 128.0], [953.0, 128.0], [953.0, 190.0], [915.0, 190.0]], [[889.0, 131.0], [915.0, 131.0], [915.0, 282.0], [889.0, 282.0]], [[853.0, 128.0], [887.0, 128.0], [887.0, 210.0], [853.0, 210.0]]], "lines": ["トカさん", "学校", "辞めちゃうん", "すか？"]}, {"box": [479, 137, 507, 237], "vertical": true, "font_size": 28, "lines_coords": [[[479.0, 137.0], [507.0, 137.0], [507.0, 237.0], [479.0, 237.0]]], "lines": ["イエス！"]}, {"box": [292, 125, 413, 301], "vertical": true, "font_size": 24, "lines_coords": [[[386.0, 126.0], [412.0, 126.0], [412.0, 256.0], [386.0, 256.0]], [[354.0, 128.0], [376.0, 128.0], [376.0, 278.0], [354.0, 278.0]], [[321.0, 125.0], [348.0, 125.0], [348.0, 301.0], [321.0, 301.0]], [[292.0, 126.0], [314.0, 126.0], [314.0, 260.0], [292.0, 260.0]]], "lines": ["なんつーか", "あたしも結構", "悩みがあったり", "するのよね。"]}, {"box": [910, 667, 995, 843], "vertical": true, "font_size": 22, "lines_coords": [[[972.0, 667.0], [993.0, 667.0], [990.0, 843.0], [968.0, 843.0]], [[937.0, 668.0], [964.0, 668.0], [964.0, 793.0], [937.0, 793.0]], [[911.0, 670.0], [928.0, 670.0], [928.0, 767.0], [911.0, 767.0]]], "lines": ["まぁトカさんが", "決めたこと", "なら．．．"]}, {"box": [636, 668, 729, 776], "vertical": true, "font_size": 33, "lines_coords": [[[697.0, 670.0], [729.0, 670.0], [729.0, 776.0], [697.0, 776.0]], [[662.0, 668.0], [701.0, 668.0], [701.0, 754.0], [662.0, 754.0]], [[636.0, 671.0], [664.0, 671.0], [664.0, 775.0], [636.0, 775.0]]], "lines": ["トガさん", "強い人", "だし．．．"]}, {"box": [481, 443, 539, 597], "vertical": true, "font_size": 24, "lines_coords": [[[512.0, 445.0], [539.0, 445.0], [539.0, 575.0], [512.0, 575.0]], [[482.0, 443.0], [504.0, 443.0], [503.0, 596.0], [481.0, 596.0]]], "lines": ["なーんて", "急にまた．．．"]}, {"box": [418, 667, 482, 810], "vertical": true, "font_size": 30, "lines_coords": [[[446.0, 667.0], [479.0, 667.0], [482.0, 795.0], [450.0, 795.0]], [[418.0, 667.0], [446.0, 667.0], [450.0, 810.0], [421.0, 810.0]]], "lines": ["いいんじゃ", "ないすかね。"]}, {"box": [139, 464, 171, 589], "vertical": true, "font_size": 32, "lines_coords": [[[139.0, 464.0], [171.0, 464.0], [171.0, 506.0], [139.0, 506.0]]], "lines": ["ほー"]}, {"box": [150, 682, 179, 831], "vertical": true, "font_size": 24, "lines_coords": [[[151.0, 756.0], [175.0, 756.0], [175.0, 831.0], [151.0, 831.0]], [[150.0, 684.0], [175.0, 684.0], [175.0, 725.0], [150.0, 725.0]]], "l