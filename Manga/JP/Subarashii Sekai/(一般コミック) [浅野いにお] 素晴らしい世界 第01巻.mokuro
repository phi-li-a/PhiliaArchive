[739.0, 484.0], [739.0, 662.0], [712.0, 662.0]]], "lines": ["それより", "トガさん、", "こんな所で何", "やってんすか？"]}, {"box": [548, 517, 572, 652], "vertical": true, "font_size": 24, "lines_coords": [[[548.0, 517.0], [572.0, 517.0], [572.0, 652.0], [548.0, 652.0]]], "lines": ["．．．．．．"]}, {"box": [454, 717, 548, 860], "vertical": true, "font_size": 27, "lines_coords": [[[515.0, 717.0], [548.0, 717.0], [548.0, 800.0], [515.0, 800.0]], [[486.0, 720.0], [512.0, 720.0], [512.0, 850.0], [486.0, 850.0]], [[454.0, 723.0], [476.0, 723.0], [479.0, 857.0], [457.0, 857.0]]], "lines": ["ビール", "くらいなら", "出しますよ。"]}, {"box": [129, 712, 193, 831], "vertical": true, "font_size": 34, "lines_coords": [[[153.0, 712.0], [193.0, 712.0], [193.0, 784.0], [153.0, 784.0]], [[129.0, 717.0], [156.0, 717.0], [156.0, 831.0], [129.0, 831.0]]], "lines": ["おう、", "行く行く。"]}, {"box": [868, 1059, 992, 1264], "vertical": true, "font_size": 25, "lines_coords": [[[964.0, 1062.0], [992.0, 1062.0], [992.0, 1164.0], [964.0, 1164.0]], [[933.0, 1062.0], [959.0, 1062.0], [959.0, 1264.0], [933.0, 1264.0]], [[903.0, 1064.0], [925.0, 1064.0], [925.0, 1189.0], [903.0, 1189.0]], [[868.0, 1059.0], [893.0, 1059.0], [898.0, 1228.0], [873.0, 1228.0]]], "lines": ["トガさん", "いなくなってから", "みんな気が", "抜けちゃって。"]}, {"box": [340, 1053, 434, 1220], "vertical": true, "font_size": 29, "lines_coords": [[[392.0, 1054.0], [431.0, 1053.0], [434.0, 1145.0], [395.0, 1146.0]], [[368.0, 1057.0], [395.0, 1057.0], [395.0, 1210.0], [368.0, 1210.0]], [[340.0, 1059.0], [362.0, 1059.0], [362.0, 1217.0], [340.0, 1217.0]]], "lines": ["こいつ、", "こんなイイ所", "住んでたのか。"]}, {"box": [121, 1279, 242, 1481], "vertical": true, "font_size": 28, "lines_coords": [[[212.0, 1281.0], [239.0, 1281.0], [239.0, 1464.0], [212.0, 1464.0]], [[182.0, 1281.0], [209.0, 1281.0], [209.0, 1481.0], [182.0, 1481.0]], [[146.0, 1279.0], [181.0, 1279.0], [181.0, 1370.0], [146.0, 1370.0]], [[121.0, 1282.0], [143.0, 1282.0], [143.0, 1442.0], [121.0, 1442.0]]], "lines": ["今じゃそれぞれ、", "キッチリ学生とか", "社会人、", "やってますよ。"]}], "img_path": "subarashii_sekai_01_021.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [858, 131, 1005, 285], "vertical": true, "font_size": 27, "lines_coords": [[[978.0, 131.0], [1004.0, 131.0], [1004.0, 240.0], [978.0, 240.0]], [[948.0, 132.0], [975.0, 132.0], [975.0, 257.0], [948.0, 257.0]], [[917.0, 131.0], [945.0, 131.0], [945.0, 234.0], [917.0, 234.0]], [[887.0, 132.0], [915.0, 132.0], [915.0, 232.0], [887.0, 232.0]], [[858.0, 131.0], [884.0, 131.0], [884.0, 243.0], [858.0, 243.0]]], "lines": ["なんだよ、", "気持ち悪い", "くらいに", "キレイに", "してんなー"]}, {"box": [128, 128, 249, 339], "vertical": true, "font_size": 24, "lines_coords": [[[223.0, 129.0], [245.0, 129.0], [245.0, 231.0], [223.0, 231.0]], [[190.0, 129.0], [212.0, 129.0], [212.0, 334.0], [190.0, 334.0]], [[157.0, 129.0], [184.0, 129.0], [184.0, 332.0], [157.0, 332.0]], [[128.0, 128.0], [154.0, 128.0], [154.0, 218.0], [128.0, 218.0]]], "lines": ["ナイスな", "社会人になるには", "ナイスな生活から", "ですよ。"]}, {"box": [948, 614, 983, 707], "vertical": true, "font_size": 35, "lines_coords": [[[948.0, 614.0], [983.0, 614.0], [983.0, 707.0], [948.0, 707.0]]], "lines": ["おっ！？"]}, {"box": [890, 910, 980, 1077], "vertical": true, "font_size": 26, "lines_coords": [[[951.0, 910.0], [978.0, 910.0], [978.0, 1053.0], [951.0, 1053.0]], [[917.0, 912.0], [945.0, 912.0], [948.0, 1065.0], [920.0, 1065.0]], [[890.0, 917.0], [912.0, 917.0], [912.0, 1073.0], [890.0, 1073.0]]], "lines": ["あんた、一応", "音楽捨てちゃ", "いないんだね。"]}, {"box": [457, 909, 613, 1134], "vertical": true, "font_size": 28, "lines_coords": [[[584.0, 909.0], [612.0, 909.0], [612.0, 1020.0], [584.0, 1020.0]], [[553.0, 910.0], [579.0, 910.0], [579.0, 1134.0], [553.0, 1134.0]], [[521.0, 910.0], [548.0, 910.0], [548.0, 1046.0], [521.0, 1046.0]], [[490.0, 910.0], [518.0, 910.0], [518.0, 1037.0], [490.0, 1037.0]], [[457.0, 910.0], [486.0, 910.0], [486.0, 1020.0], [457.0, 1020.0]]], "lines": ["トガさん、", "そのＳＧほしがって", "ましたよね、", "持ってって", "いいすよ。"]}, {"box": [643, 1292, 784, 1473], "vertical": true, "font_size": 24, "lines_coords": [[[753.0, 1292.0], [784.0, 1292.0], [784.0, 1462.0], [753.0, 1462.0]], [[728.0, 1295.0], [750.0, 1295.0], [750.0, 1471.0], [728.0, 1471.0]], [[697.0, 1295.0], [718.0, 1295.0], [718.0, 1396.0], [697.0, 1396.0]], [[667.0, 1295.0], [689.0, 1295.0], [689.0, 1471.0], [667.0, 1471.0]]], "lines": ["あー、それは", "売ろうとしたら", "安く値段", "付けられちゃって"]}, {"box": [123, 1295, 215, 1460], "vertical": true, "font_size": 28, "lines_coords": [[[184.0, 1296.0], [215.0, 1296.0], [215.0, 1459.0], [184.0, 1459.0]], [[153.0, 1296.0], [179.0, 1296.0], [179.0, 1398.0], [153.0, 1398.0]], [[123.0, 1295.0], [150.0, 1295.0], [150.0, 1434.0], [123.0, 1434.0]]], "lines": ["いや．．．いいよ。", "あんたが", "持ってなよ。"]}], "img_path": "subarashii_sekai_01_022.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [762, 131, 828, 337], "vertical": true, "font_size": 29, "lines_coords": [[[790.0, 132.0], [822.0, 131.0], [828.0, 271.0], [797.0, 273.0]], [[762.0, 132.0], [789.0, 132.0], [790.0, 337.0], [764.0, 337.0]]], "lines": ["．．．．．．まぁ、", "なんだかんだで．．．"]}, {"box": [567, 135, 697, 315], "vertical": true, "font_size": 29, "lines_coords": [[[668.0, 140.0], [697.0, 140.0], [697.0, 256.0], [668.0, 256.0]], [[640.0, 142.0], [662.0, 142.0], [662.0, 315.0], [640.0, 315.0]], [[603.0, 139.0], [629.0, 139.0], [632.0, 275.0], [606.0, 275.0]], [[567.0, 135.0], [607.0, 135.0], [607.0, 184.0], [567.0, 184.0]]], "lines": ["２、３就職", "できそうなとこ", "あるんすよ、", "俺。"]}, {"box": [103, 64, 354, 93], "vertical": false, "font_size": 26, "lines_coords": [[[103.0, 64.0], [354.0, 67.0], [354.0, 93.0], [103.0, 90.0]]], "lines": ["素晴らしい世界で"]}, {"box": [112, 143, 232, 300], "vertical": true, "font_size": 31, "lines_coords": [[[201.0, 146.0], [232.0, 146.0], [232.0, 196.0], [201.0, 196.0]], [[167.0, 145.0], [203.0, 143.0], [206.0, 226.0], [170.0, 228.0]], [[142.0, 145.0], [170.0, 145.0], [171.0, 300.0], [143.0, 300.0]], [[112.0, 146.0], [140.0, 146.0], [140.0, 237.0], [112.0, 237.0]]], "lines": ["ほー", "そりゃ", "よかったじゃ", "ないの。"]}, {"box": [912, 637, 954, 845], "vertical": true, "font_size": 42, "lines_coords": [[[912.0, 637.0], [954.0, 637.0], [954.0, 845.0], [912.0, 845.0]]], "lines": ["トガさん！！"]}, {"box": [657, 437, 684, 540], "vertical": true, "font_size": 27, "lines_coords": [[[657.0, 437.0], [684.0, 437.0], [684.0, 537.0], [657.0, 537.0]]], "lines": ["でも．．．"]}, {"box": [131, 481, 159, 560], "vertical": true, "font_size": 28, "lines_coords": [[[131.0, 481.0], [159.0, 481.0], [159.0, 560.0], [131.0, 560.0]]], "lines": ["でも？"]}, {"box": [134, 696, 176, 864], "vertical": true, "font_size": 39, "lines_coords": [[[134.0, 696.0], [173.0, 696.0], [176.0, 864.0], [137.0, 864.0]]], "lines": ["うっす！"]}, {"box": [868, 939, 979, 1093], "vertical": true, "font_size": 32, "lines_coords": [[[943.0, 939.0], [976.0, 939.0], [979.0, 1064.0], [947.0, 1064.0]], [[904.0, 940.0], [939.0, 940.0], [939.0, 1035.0], [904.0, 1035.0]], [[868.0, 943.0], [897.0, 943.0], [897.0, 1093.0], [868.0, 1093.0]]], "lines": ["ちょっと", "甘えて", "いいすか？"]}, {"box": [501, 932, 534, 1059], "vertical": true, "font_size": 33, "lines_coords": [[[501.0, 932.0], [534.0, 932.0], [534.0, 1053.0], [501.0, 1053.0]]], "lines": ["へっ．．．．．．"]}], "img_path": "subarashii_sekai_01_023.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [271, 89, 301, 242], "vertical": true, "font_size": 29, "lines_coords": [[[271.0, 89.0], [298.0, 89.0], [301.0, 242.0], [275.0, 242.0]]], "lines": ["トガさん．．．"]}, {"box": [164, 265, 226, 384], "vertical": true, "font_size": 29, "lines_coords": [[[193.0, 265.0], [226.0, 267.0], [223.0, 364.0], [190.0, 362.0]], [[164.0, 267.0], [190.0, 267.0], [190.0, 384.0], [164.0, 384.0]]], "lines": ["俺、不安", "なんすよ。"]}, {"box": [859, 503, 982, 668], "vertical": true, "font_size": 29, "lines_coords": [[[953.0, 506.0], [981.0, 506.0], [981.0, 632.0], [953.0, 632.0]], [[920.0, 504.0], [948.0, 504.0], [950.0, 665.0], [922.0, 665.0]], [[887.0, 503.0], [920.