[275.0, 539.0], [248.0, 542.0]]], "lines": ["っ", "ーか。"]}, {"box": [156, 529, 215, 723], "vertical": true, "font_size": 25, "lines_coords": [[[185.0, 529.0], [212.0, 529.0], [215.0, 692.0], [189.0, 692.0]], [[156.0, 534.0], [179.0, 534.0], [181.0, 723.0], [157.0, 723.0]]], "lines": ["トラック自体、", "ないんですけど。"]}, {"box": [931, 878, 968, 1018], "vertical": true, "font_size": 34, "lines_coords": [[[931.0, 878.0], [965.0, 878.0], [968.0, 1018.0], [934.0, 1018.0]]], "lines": ["ははっ！"]}, {"box": [168, 1042, 203, 1183], "vertical": true, "font_size": 33, "lines_coords": [[[168.0, 1042.0], [201.0, 1042.0], [201.0, 1182.0], [168.0, 1182.0]]], "lines": ["やった！"]}, {"box": [148, 1343, 223, 1559], "vertical": true, "font_size": 36, "lines_coords": [[[182.0, 1343.0], [220.0, 1343.0], [223.0, 1559.0], [185.0, 1559.0]], [[148.0, 1346.0], [181.0, 1346.0], [181.0, 1500.0], [148.0, 1500.0]]], "lines": ["やってやったぜ", "俺ってば！！"]}], "img_path": "subarashii_sekai_01_065.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [322, 104, 801, 146], "vertical": false, "font_size": 36, "lines_coords": [[[326.0, 106.0], [797.0, 101.0], [797.0, 140.0], [326.0, 145.0]]], "lines": ["３ｒｄｐｒｙｇｒａｍ，森のクマさん"]}, {"box": [700, 906, 887, 1164], "vertical": true, "font_size": 28, "lines_coords": [[[859.0, 909.0], [886.0, 909.0], [886.0, 1087.0], [859.0, 1087.0]], [[826.0, 909.0], [858.0, 909.0], [858.0, 1139.0], [826.0, 1139.0]], [[793.0, 907.0], [820.0, 907.0], [823.0, 1160.0], [797.0, 1160.0]], [[762.0, 907.0], [789.0, 907.0], [792.0, 1120.0], [765.0, 1120.0]], [[729.0, 906.0], [756.0, 906.0], [759.0, 1142.0], [732.0, 1142.0]], [[700.0, 907.0], [726.0, 907.0], [726.0, 1164.0], [700.0, 1164.0]]], "lines": ["この巨大な分譲", "マンションの中には", "たくさんのヒトという", "動物が住んでいて、", "それぞれ勝手に考え、", "生活していると思うと"]}, {"box": [540, 905, 634, 1174], "vertical": true, "font_size": 28, "lines_coords": [[[606.0, 909.0], [632.0, 909.0], [632.0, 1110.0], [606.0, 1110.0]], [[570.0, 906.0], [601.0, 906.0], [601.0, 1151.0], [570.0, 1151.0]], [[540.0, 907.0], [567.0, 907.0], [568.0, 1171.0], [542.0, 1171.0]]], "lines": ["「なるほど、ここは", "現代のシャングルだ」", "なんて思ってしまった。"]}, {"box": [348, 904, 473, 1160], "vertical": true, "font_size": 29, "lines_coords": [[[445.0, 907.0], [471.0, 907.0], [471.0, 1034.0], [445.0, 1034.0]], [[407.0, 906.0], [442.0, 904.0], [445.0, 1010.0], [411.0, 1012.0]], [[381.0, 909.0], [407.0, 909.0], [407.0, 1160.0], [381.0, 1160.0]], [[351.0, 909.0], [379.0, 909.0], [376.0, 1071.0], [348.0, 1071.0]]], "lines": ["じゃあ私は", "さながら", "森に迷い込んだ少女？", "っつーワケだ。"]}, {"box": [154, 907, 259, 1085], "vertical": true, "font_size": 26, "lines_coords": [[[223.0, 909.0], [245.0, 909.0], [245.0, 1059.0], [223.0, 1059.0]], [[187.0, 909.0], [215.0, 909.0], [218.0, 1085.0], [190.0, 1085.0]], [[157.0, 909.0], [185.0, 909.0], [182.0, 1042.0], [154.0, 1042.0]]], "lines": ["私はかなりの", "ヒマ人なんじゃ", "なかろーか"]}, {"box": [865, 1142, 962, 1332], "vertical": true, "font_size": 30, "lines_coords": [[[922.0, 1143.0], [959.0, 1142.0], [962.0, 1207.0], [925.0, 1209.0]], [[897.0, 1146.0], [923.0, 1146.0], [923.0, 1332.0], [897.0, 1332.0]], [[865.0, 1143.0], [893.0, 1143.0], [893.0, 1235.0], [865.0, 1235.0]]], "lines": ["はは、", "何やってんだろ、", "あたし。"]}, {"box": [154, 1320, 214, 1460], "vertical": true, "font_size": 24, "lines_coords": [[[184.0, 1320.0], [210.0, 1320.0], [214.0, 1428.0], [187.0, 1428.0]], [[154.0, 1321.0], [176.0, 1321.0], [179.0, 1456.0], [157.0, 1456.0]]], "lines": ["毎日毎日、", "こんな所で。"]}], "img_path": "subarashii_sekai_01_066.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [948, 117, 975, 232], "vertical": true, "font_size": 27, "lines_coords": [[[948.0, 117.0], [975.0, 117.0], [975.0, 231.0], [948.0, 231.0]]], "lines": ["．．．．．帰ろ。"]}, {"box": [117, 98, 242, 329], "vertical": true, "font_size": 27, "lines_coords": [[[212.0, 100.0], [240.0, 100.0], [242.0, 203.0], [214.0, 203.0]], [[182.0, 100.0], [209.0, 100.0], [212.0, 281.0], [185.0, 281.0]], [[150.0, 98.0], [176.0, 98.0], 