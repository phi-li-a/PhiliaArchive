, 954.0], [196.0, 1025.0], [159.0, 1026.0]]], "lines": ["俺らなんも", "シロップのこと", "知らなかった", "のな。"]}, {"box": [174, 1162, 201, 1201], "vertical": true, "font_size": 27, "lines_coords": [[[174.0, 1162.0], [201.0, 1162.0], [201.0, 1201.0], [174.0, 1201.0]]], "lines": ["な。"]}, {"box": [314, 1239, 440, 1421], "vertical": true, "font_size": 29, "lines_coords": [[[411.0, 1242.0], [439.0, 1242.0], [440.0, 1356.0], [412.0, 1356.0]], [[379.0, 1240.0], [406.0, 1240.0], [403.0, 1420.0], [376.0, 1420.0]], [[348.0, 1240.0], [376.0, 1240.0], [373.0, 1421.0], [345.0, 1421.0]], [[314.0, 1239.0], [348.0, 1239.0], [348.0, 1328.0], [314.0, 1328.0]]], "lines": ["でもまぁ、", "どんだけ輝ける", "過去があったと", "しても、"]}, {"box": [210, 1359, 275, 1537], "vertical": true, "font_size": 29, "lines_coords": [[[248.0, 1359.0], [275.0, 1359.0], [271.0, 1537.0], [245.0, 1537.0]], [[214.0, 1359.0], [242.0, 1359.0], [239.0, 1525.0], [210.0, 1525.0]]], "lines": ["今のシロップが", "俺は好きだぜ。"]}], "img_path": "subarashii_sekai_01_202.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [881, 117, 908, 232], "vertical": true, "font_size": 27, "lines_coords": [[[881.0, 117.0], [908.0, 117.0], [908.0, 232.0], [881.0, 232.0]]], "lines": ["それにさ。"]}, {"box": [104, 57, 351, 87], "vertical": false, "font_size": 27, "lines_coords": [[[104.0, 57.0], [351.0, 60.0], [351.0, 87.0], [104.0, 84.0]]], "lines": ["素晴らしい世界で"]}, {"box": [904, 560, 936, 676], "vertical": true, "font_size": 28, "lines_coords": [[[908.0, 560.0], [936.0, 560.0], [933.0, 676.0], [904.0, 676.0]]], "lines": ["．．．．．．だな。"]}, {"box": [182, 360, 279, 500], "vertical": true, "font_size": 30, "lines_coords": [[[245.0, 360.0], [279.0, 360.0], [279.0, 464.0], [245.0, 464.0]], [[215.0, 362.0], [243.0, 362.0], [243.0, 489.0], [215.0, 489.0]], [[182.0, 360.0], [209.0, 360.0], [212.0, 500.0], [185.0, 500.0]]], "lines": ["シロップ", "笑いながら", "飛んでたよ。"]}, {"box": [187, 679, 220, 762], "vertical": true, "font_size": 33, "lines_coords": [[[187.0, 679.0], [220.0, 679.0], [220.0, 762.0], [187.0, 762.0]]], "lines": ["だろ？"]}, {"box": [151, 967, 521, 1059], "vertical": false, "font_size": 28, "lines_coords": [[[154.0, 967.0], [256.0, 967.0], [256.0, 993.0], [154.0, 993.0]], [[151.0, 995.0], [468.0, 995.0], [468.0, 1026.0], [151.0, 1026.0]], [[201.0, 1029.0], [512.0, 1029.0], [512.0, 1056.0], [201.0, 1056.0]]], "lines": ["．．．実際", "そんなもん見えるはずない。", "でも笑ってたと思う。多分。"]}], "img_path": "subarashii_sekai_01_203.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [698, 732, 820, 939], "vertical": true, "font_size": 26, "lines_coords": [[[793.0, 732.0], [820.0, 732.0], [817.0, 887.0], [790.0, 887.0]], [[761.0, 734.0], [787.0, 734.0], [787.0, 837.0], [761.0, 837.0]], [[726.0, 734.0], [757.0, 734.0], [757.0, 939.0], [726.0, 939.0]], [[700.0, 735.0], [722.0, 735.0], [722.0, 895.0], [700.0, 895.0]]], "lines": ["夢はあれども", "ただ毎日", "ぽんやりまったり", "生きてるだけ。"]}, {"box": [570, 731, 665, 946], "vertical": true, "font_size": 28, "lines_coords": [[[629.0, 731.0], [665.0, 732.0], [661.0, 814.0], [625.0, 812.0]], [[601.0, 734.0], [628.0, 734.0], [628.0, 937.0], [601.0, 937.0]], [[570.0, 734.0], [592.0, 734.0], [592.0, 940.0], [570.0, 940.0]]], "lines": ["どーせ", "バカなヤツらって", "思われてんだろな"]}, {"box": [420, 728, 517, 907], "vertical": true, "font_size": 29, "lines_coords": [[[489.0, 731.0], [515.0, 731.0], [515.0, 882.0], [489.0, 882.0]], [[456.0, 731.0], [482.0, 731.0], [482.0, 907.0], [456.0, 907.0]], [[420.0, 728.0], [454.0, 728.0], [454.0, 820.0], [420.0, 820.0]]], "lines": ["でも今の俺は", "前に進むことを", "知った。"]}, {"box": [364, 731, 389, 945], "vertical": true, "font_size": 22, "lines_coords": [[[364.0, 731.0], [386.0, 731.0], [386.0, 939.0], [364.0, 939.0]]], "lines": ["とにかく進むんだ"]}, {"box": [296, 728, 326, 967], "vertical": true, "font_size": 27, "lines_coords": [[[296.0, 731.0], [323.0, 731.0], [323.0, 967.0], [296.0, 967.0]]], "lines": ["あの真っ赤な太陽に"]}, {"box": [232, 726, 259, 949], "vertical": true, "font_size": 27, "lines_coords": [[[232.