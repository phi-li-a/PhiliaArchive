 26, "lines_coords": [[[720.0, 421.0], [748.0, 421.0], [748.0, 510.0], [720.0, 510.0]]], "lines": ["あらら。"]}, {"box": [700, 557, 790, 751], "vertical": true, "font_size": 26, "lines_coords": [[[762.0, 560.0], [790.0, 560.0], [787.0, 751.0], [759.0, 751.0]], [[726.0, 557.0], [753.0, 557.0], [756.0, 689.0], [729.0, 689.0]], [[700.0, 562.0], [722.0, 562.0], [722.0, 698.0], [700.0, 698.0]]], "lines": ["へーーっ、なんか", "頼りなさ気", "だったけど。"]}, {"box": [135, 360, 193, 514], "vertical": true, "font_size": 25, "lines_coords": [[[171.0, 362.0], [193.0, 362.0], [193.0, 514.0], [171.0, 514.0]], [[135.0, 360.0], [164.0, 360.0], [164.0, 440.0], [135.0, 440.0]]], "lines": ["とり込し苦労", "か．．．．．"]}, {"box": [823, 828, 917, 982], "vertical": true, "font_size": 29, "lines_coords": [[[889.0, 829.0], [917.0, 829.0], [917.0, 932.0], [889.0, 932.0]], [[854.0, 829.0], [887.0, 829.0], [887.0, 914.0], [854.0, 914.0]], [[826.0, 828.0], [853.0, 828.0], [850.0, 981.0], [823.0, 981.0]]], "lines": ["なーんか", "みんな", "どんどん．．．．．"]}, {"box": [237, 921, 330, 1075], "vertical": true, "font_size": 25, "lines_coords": [[[304.0, 925.0], [326.0, 925.0], [326.0, 1050.0], [304.0, 1050.0]], [[271.0, 923.0], [298.0, 923.0], [298.0, 1075.0], [271.0, 1075.0]], [[237.0, 921.0], [264.0, 921.0], [264.0, 1073.0], [237.0, 1073.0]]], "lines": ["前に進んで", "行っちゃうん", "だよなぁ．．．"]}, {"box": [282, 1221, 373, 1400], "vertical": true, "font_size": 27, "lines_coords": [[[345.0, 1221.0], [373.0, 1221.0], [373.0, 1326.0], [345.0, 1326.0]], [[315.0, 1221.0], [342.0, 1221.0], [342.0, 1400.0], [315.0, 1400.0]], [[282.0, 1221.0], [309.0, 1221.0], [309.0, 1325.0], [282.0, 1325.0]]], "lines": ["あたしも", "ちゃんと働こう", "かな．．．"]}], "img_path": "subarashii_sekai_01_167.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [584, 448, 634, 532], "vertical": true, "font_size": 42, "lines_coords": [[[592.0, 448.0], [634.0, 453.0], [626.0, 532.0], [584.0, 528.0]]], "lines": ["ポトッ"]}, {"box": [918, 804, 986, 890], "vertical": true, "f