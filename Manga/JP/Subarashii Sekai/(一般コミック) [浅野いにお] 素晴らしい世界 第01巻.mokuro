 964.0], [601.0, 1087.0], [573.0, 1087.0]]], "lines": ["スン詰めの"]}, {"box": [642, 962, 764, 1141], "vertical": true, "font_size": 27, "lines_coords": [[[737.0, 964.0], [764.0, 964.0], [764.0, 1115.0], [737.0, 1115.0]], [[703.0, 962.0], [736.0, 962.0], [736.0, 1073.0], [703.0, 1073.0]], [[676.0, 965.0], [698.0, 965.0], [698.0, 1139.0], [676.0, 1139.0]], [[642.0, 965.0], [668.0, 965.0], [668.0, 1100.0], [642.0, 1100.0]]], "lines": ["適当に朝刊を", "読み流し、", "栄養ドリンクを", "飲みくだす。"]}, {"box": [801, 962, 862, 1176], "vertical": true, "font_size": 26, "lines_coords": [[[836.0, 965.0], [862.0, 965.0], [862.0, 1151.0], [836.0, 1151.0]], [[803.0, 965.0], [829.0, 965.0], [829.0, 1176.0], [803.0, 1176.0]]], "lines": ["朝、８時２６分発の", "小田急線新宿行き。"]}, {"box": [256, 1395, 292, 1475], "vertical": true, "font_size": 36, "lines_coords": [[[256.0, 1395.0], [292.0, 1395.0], [292.0, 1475.0], [256.0, 1475.0]]], "lines": ["あっ。"]}], "img_path": "subarashii_sekai_01_097.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [309, 255, 507, 364], "vertical": false, "font_size": 28, "lines_coords": [[[323.0, 260.0], [454.0, 265.0], [453.0, 315.0], [321.0, 310.0]], [[314.0, 321.0], [495.0, 321.0], [495.0, 337.0], [314.0, 337.0]], [[315.0, 342.0], [418.0, 342.0], [418.0, 359.0], [315.0, 359.0]]], "lines": ["．．．", "ＮＥＴＳＩＭＧＬＥ「素晴らしい世界", "ＮＯＷＯＮＳＡＬＥ"]}, {"box": [879, 1220, 950, 1350], "vertical": true, "font_size": 28, "lines_coords": [[[912.0, 1220.0], [940.0, 1220.0], [937.0, 1350.0], [909.0, 1350.0]], [[879.0, 1221.0], [906.0, 1221.0], [906.0, 1326.0], [879.0, 1326.0]]], "lines": ["「ＤＡＴ３」", "聴いた？"]}, {"box": [264, 1306, 387, 1509], "vertical": true, "font_size": 26, "lines_coords": [[[359.0, 1306.0], [387.0, 1306.0], [387.0, 1448.0], [359.0, 1448.0]], [[328.0, 1306.0], [354.0, 1306.0], [354.0, 1509.0], [328.0, 1509.0]], [[296.0, 1307.0], [323.0, 1307.0], [323.0, 1485.0], [296.0, 1485.0]], [[264.0, 1306.0], [292.0, 1306.0], [292.0, 1412.0], [264.0, 1412.0]]], "lines": ["あーー、女が", "ギターボーカルの", "３ピースバンド", "でしょ？"]}, {"box": [154, 1389, 242, 1518], "vertical": true, "font_size": 26, "lines_coords": [[[215.0, 1392.0], [242.0, 1392.0], [242.0, 1518.0], [215.0, 1518.0]], [[182.0, 1389.0], [209.0, 1389.0], [209.0, 1493.0], [182.0, 1493.0]], [[154.0, 1392.0], [176.0, 1392.0], [176.0, 1506.0], [154.0, 1506.0]]], "lines": ["一応試聴は", "しといた", "けどさぁ。"]}], "img_path": "subarashii_sekai_01_098.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [898, 95, 983, 288], "vertical": true, "font_size": 25, "lines_coords": [[[956.0, 95.0], [983.0, 95.0], [979.0, 271.0], [953.0, 271.0]], [[925.0, 95.0], [951.0, 95.0], [950.0, 287.0], [923.0, 287.0]], [[898.0, 98.0], [920.0, 98.0], [920.0, 243.0], [898.0, 243.0]]], "lines": ["ま、なんつうの？", "ありがちっつうか、", "普通っつうか。"]}, {"box": [511, 293, 626, 521], "vertical": true, "font_size": 26, "lines_coords": [[[593.0, 293.0], [626.0, 293.0], [626.0, 378.0], [593.0, 378.0]], [[568.0, 295.0], [595.0, 295.0], [595.0, 521.0], [568.0, 521.0]], [[540.0, 298.0], [562.0, 298.0], [562.0, 521.0], [540.0, 521.0]], [[511.0, 296.0], [531.0, 296.0], [531.0, 501.0], [511.0, 501.0]]], "lines": ["確かに、", "インディーズあがりの", "パンドって飽きたって", "感じもあるよねー"]}, {"box": [203, 410, 231, 531], "vertical": true, "font_size": 25, "lines_coords": [[[209.0, 495.0], [228.0, 495.0], [228.0, 531.0], [209.0, 531.0]], [[203.0, 410.0], [231.0, 410.0], [231.0, 475.0], [203.0, 475.0]]], "lines": ["いい", "ファー"]}, {"box": [232, 581, 260, 637], "vertical": true, "font_size": 25, "lines_coords": [[[232.0, 581.0], [260.0, 581.0], [260.0, 637.0], [232.0, 637.0]]], "lines": ["キュー"]}, {"box": [889, 1365, 933, 1400], "vertical": false, "font_size": 35, "lines_coords": [[[889.0, 1365.0], [933.0, 1365.0], [933.0, 1400.0], [889.0, 1400.0]]], "lines": ["．．"]}, {"box": [437, 1368, 811, 1456], "vertical": false, "font_size": 88, "lines_coords": [[[437.0, 1368.0], [811.0, 1368.0], [811.0, 1456.0], [437.0, 1456.0]]], "lines": ["らしいぜ"]}, {"box": [117, 1232, 411, 1314], "vertical": false, "font_size": 32, "lines_coords": [[[118.0, 1232.0], [361.0, 1234.0], [361.0, 1265.0], [118.0, 1264.0]], [[120.0, 1278.0], [406.0, 1278.0], [406.0, 1310.0], [120.0, 1310.0]]], "lines": ["４ｔｈ．ｐｒｏｇｒａｍｐ", "ワンダーフォーゲル"]}, {"box": [221, 1342, 407, 1445], "vertical": false, "font_size": 75, "lines_coords": [[[221.0, 1371.0], [395.0, 1342.0], [407.0, 1415.0], [234.0, 1445.0]]], "lines": ["まぁ、"]}], "img_path": "subarashii_sekai_01_099.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [906, 145, 993, 304], "vertical": true, "font_size": 25, "lines_coords": [[[967.0, 145.0], [993.0, 145.0], [993.0, 257.0], [967.0, 257.0]], [[934.0, 145.0], [961.0, 145.0], [961.0, 293.0], [934.0, 293.0]], [[906.0, 146.0], [928.0, 146.0], [928.0, 304.0], [906.0, 304.0]]], "lines": ["ま、俺にも", "こんな時代が", "あったワケさ。"]}, {"box": [498, 704, 626, 894], "vertical": true, "font_size": 31, "lines_coords": [[[598.0, 710.0], [625.0, 710.0], [625.0, 885.0], [598.0, 885.0]], [[567.0, 707.0], [593.0, 707.0], [592.0, 893.0], [565.0, 893.0]], [[534.0, 706.0], [565.0, 706.0], [565.0, 885.0], [534.0, 885.0]], [[498.0, 704.0], [537.0, 704.0], [537.0, 798.0], [498.0, 798.0]]], "lines": ["バイトしながら", "下北沢でコツコツ", "ライブやったり", "してね。"]}, {"box": [328, 487, 357, 599], "vertical": true, "font_size": 26, "lines_coords": [[[331.0, 487.0], [357.0, 487.0], [354.0, 598.0], [328.0, 598.0]]], "lines": ["ファック"]}, {"box": [281, 706, 370, 845], "vertical": true, "font_size": 25, "lines_coords": [[[343.0, 707.0], [370.0, 707.0], [370.0, 807.0], [343.0, 807.0]], [[311.0, 709.0], [337.0, 709.0], [337.0, 831.0], [311.0, 831.0]], [[281.0, 707.0], [303.0, 707.0], [303.0, 840.0], [281.0, 840.0]]], "lines": ["よくいる", "バンド青年", "だったのさ"]}, {"box": [961, 957, 989, 1094], "vertical": true, "font_size": 23, "lines_coords": [[[964.0, 957.0], [987.0, 957.0], [984.0, 1092.0], [961.0, 1092.0]]], "lines": ["思うにだな。"]}, {"box": [695, 704, 854, 898], "vertical": true, "font_size": 28, "lines_coords": [[[822.0, 706.0], [854.0, 706.0], [854.0, 800.0], [822.0, 800.0]], [[792.0, 709.0], [820.0, 709.0], [820.0, 815.0], [792.0, 815.0]], [[759.0, 707.0], [786.0, 707.0], [786.0, 884.0], [759.0, 884.0]], [[728.0, 704.0], [754.0, 704.0], [751.0, 839.0], [725.0, 839.0]], [[695.0, 706.0], [723.0, 706.0], [723.0, 842.0], [695.0, 842.0]]], "lines": ["「音楽で", "食ってこ", "なーんて本気で", "思ってたし、", "言ってたし。"]}, {"box": [618, 935, 709, 1099], "vertical": true, "font_size": 27, "lines_coords": [[[682.0, 937.0], [709.0, 937.0], [709.0, 1060.0], [682.0, 1060.0]], [[648.0, 935.0], [681.0, 935.0], [681.0, 1023.0], [648.0, 1023.0]], [[620.0, 937.0], [642.0, 937.0], [640.0, 1095.0], [618.0, 1095.0]]], "lines": ["ネクタイっ", "てのは、", "首輪なワケだ。"]}, {"box": [173, 1106, 200, 1209], "vertical": true, "font_size": 27, "lines_coords": [[[173.0, 1106.0], [200.0, 1106.0], [200.0, 1134.0], [173.0, 1134.0]]], "lines": ["ほ"]}, {"box": [126, 1298, 250, 1479], "vertical": true, "font_size": 27, "lines_coords": [[[220.0, 1301.0], [250.0, 1301.0], [250.0, 1378.0], [220.0, 1378.0]], [[190.0, 1301.0], [217.0, 1301.0], [217.0, 1479.0], [190.0, 1479.0]], [[157.0, 1298.0], [185.0, 1298.0], [182.0, 1439.0], [154.0, 1439.0]], [[126.0, 1300.0], [154.0, 1300.0], [154.0, 1365.0], [126.0, 1365.0]]], "lines": ["社会に", "組み込まれたら", "人間、終わり", "だぜー"]}, {"box": [131, 1384, 151, 1428], "vertical": true, "font_size": 27, "lines_coords": [[[131.0, 1384.0], [151.0, 1384.0], [151.0, 1428.0], [131.0, 1428.0]]], "lines": ["！？"]}], "img_path": "subarashii_sekai_01_100.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [90, 56, 345, 87], "vertical": false, "font_size": 31, "lines_coords": [[[90.0, 56.0], [345.0, 56.0], [345.0, 87.0], [90.0, 87.0]]], "lines": ["素晴らしい世界で"]}, {"box": [122, 123, 318, 451], "vertical": true, "font_size": 80, "lines_coords": [[[242.0, 128.0], [314.0, 126.0], [318.0, 450.0], [246.0, 451.0]], [[168.0, 123.0], [256.0, 123.0], [256.0, 290.0], [168.0, 290.0]]], "lines": ["オラみんな", "飛べー"]}, {"box": [712, 1051, 773, 1267], "vertical": true, "font_size": 24, "lines_coords": [[[748.0, 1054.0], [770.0, 1054.0], [770.0, 1235.0], [748.0, 1235.0]], [[712.0, 1051.0], [739.0, 1051.0], [740.0, 1267.0], [714.0, 1267.0]]], "lines": ["でも俺は辞めた", "かなりあっさりと。"]}, {"box": [489, 1051, 650, 1282], "vertical": true, "font_size": 28, "lines_coords": [[[615.0, 1051.0], [650.0, 1053.0], [647.0, 1137.0], [612.0, 1135.0]], [[586.0, 1054.0], [612.0, 1054.0], [612.0, 1278.0], [586.0, 1278.0]], [[551.0, 1053.0], [579.0, 1053.0], [581.0, 1240.0], [553.0, 1240.0]], [[518.0, 1053.0], [545.0, 1053.0], [545.0, 1257.0], [518.0, 1257.0]], [[489.0, 1056.0], [512.0, 1056.0], [514.0, 1267.0], [490.0, 1267.0]]], "lines": ["理由は、", "「音楽性の違いが～」", "なんてじゃなく、", "単純に親のコネで", "内定が取れたから。"]}, {"box": [292, 1050, 423, 1270], "vertical": true, "font_size": 32, "lines_coords": [[[389.0, 1053.0], [423.0, 1053.0], [423.0, 1143.0], [389.0, 1143.0]], [[361.0, 1054.0], [387.0, 1054.0], [387.0, 1234.0], [361.0, 1234.0]], [[329.0, 1053.0], [356.0, 1053.0], [356.0, 1267.0], [329.0, 1267.0]], [[292.0, 1050.0], [332.0, 1050.0], [332.0, 1125.0], [292.0, 1125.0]]], "lines": ["つまり、", "夢よりも現実を", "選んだってワケだ。", "俺は"]}, {"box": [390, 1404, 467, 1440], "vertical": false, "font_size": 36, "lines_coords": [[[390.0, 1404.0], [467.0, 1404.0], [467.0, 1440.0], [390.0, 1440.0]]], "lines": ["いや"]}], "img_path": "subarashii_sekai_01_101.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [437, 132, 478, 217], "vertical": true, "font_size": 41, "lines_coords": [[[437.0, 132.0], [478.0, 132.0], [478.0, 217.0], [437.0, 217.0]]], "lines": ["夢ね。"]}, {"box": [286, 703, 378, 866], "vertical": true, "font_size": 27, "lines_coords": [[[351.0, 704.0], [378.0, 704.0], [378.0, 865.0], [351.0, 865.0]], [[317.0, 703.0], [343.0, 703.0], [343.0, 851.0], [317.0, 851.0]], [[286.0, 703.0], [314.0, 703.0], [314.0, 815.0], [286.0, 815.0]]], "lines": ["いい曲だった。", "好きな感じの", "曲だった。"]}, {"box": [151, 702, 182, 866], "vertical": true, "font_size": 27, "lines_coords": [[[154.0, 703.0], [181.0, 703.0], [178.0, 860.0], [151.0, 860.0]]], "lines": ["くやしかった。"]}, {"box": [731, 701, 984, 917], "vertical": true, "font_size": 27, "lines_coords": [[[956.0, 703.0], [984.0, 703.0], [984.0, 831.0], [956.0, 831.0]], [[925.0, 703.0], [953.0, 703.0], [950.0, 831.0], [922.0, 831.0]], [[890.0, 704.0], [918.0, 704.0], [918.0, 856.0], [890.0, 856.0]], [[859.0, 701.0], [890.0, 701.0], [890.0, 917.0], [859.0, 917.0]], [[829.0, 703.0], [856.0, 703.0], [856.0, 881.0], [829.0, 881.0]], [[795.0, 701.0], [826.0, 701.0], [826.0, 907.0], [795.0, 907.0]], [[767.0, 703.0], [789.0, 703.0], [789.0, 903.0], [767.0, 903.0]], [[731.0, 701.0], [757.0, 701.0], [757.0, 854.0], [731.0, 854.0]]], "lines": ["俺が脱けて", "バンド名を", "「電気虫」から", "「ＤＡＴ３」に変え、", "インティースて", "テビテビやってん", "だろうと思ってた", "そのバンドは"]}, {"box": [966, 981, 992, 1160], "vertical": true, "font_size": 22, "lines_coords": [[[967.0, 984.0], [989.0, 984.0], [989.0, 1098.0], [967.0, 1098.0]]], "lines": ["ただいまー"]}, {"box": [601, 700, 692, 901], "vertical": true, "font_size": 27, "lines_coords": [[[670.0, 706.0], [692.0, 706.0], [692.0, 851.0], [670.0, 851.0]], [[636.0, 701.0], [662.0, 701.0], [662.0, 901.0], [636.0, 901.0]], [[601.0, 700.0], [634.0, 700.0], [634.0, 789.0], [601.0, 789.0]]], "lines": ["いつの間にか", "メシャーテビュー", "してた。"]}, {"box": [478, 701, 536, 938], "vertical": true, "font_size": 24, "lines_coords": [[[507.0, 701.0], [534.0, 701.0], [534.0, 937.0], [507.0, 937.0]], [[478.0, 701.0], [500.0, 701.0], [500.0, 832.0], [478.0, 832.0]]], "lines": ["シングルも出してた。", "しかも２枚"]}, {"box": [589, 1004, 651, 1112], "vertical": true, "font_size": 31, "lines_coords": [[[615.0, 1004.0], [651.0, 1004.0], [651.0, 1073.0], [615.0, 1073.0]], [[589.0, 1007.0], [615.0, 1007.0], [615.0, 1112.0], [589.0, 1112.0]]], "lines": ["あれ、", "仕事は？"]}, {"box": [184, 1109, 311, 1275], "vertical": true, "font_size": 30, "lines_coords": [[[276.0, 1112.0], [311.0, 1112.0], [311.0, 1195.0], [276.0, 1195.0]], [[245.0, 1114.0], [273.0, 1114.0], [276.0, 1275.0], [248.0, 1275.0]], [[209.0, 1109.0], [250.0, 1109.0], [250.0, 1184.0], [209.0, 1184.0]], [[184.0, 1117.0], [210.0, 1117.0], [210.0, 1251.0], [184.0, 1251.0]]], "lines": ["言って", "なかったっけ、", "今日、", "創立記念日。"]}, {"box": [131, 1290, 254, 1473], "vertical": true, "font_size": 30, "lines_coords": [[[228.0, 1290.0], [254.0, 1290.0], [253.0, 1471.0], [226.0, 1471.0]], [[193.0, 1292.0], [220.0, 1292.0], [220.0, 1473.0], [193.0, 1473.0]], [[162.0, 1292.0], [189.0, 1292.0], [189.0, 1421.0], [162.0, 1421.0]], [[131.0, 1292.0], [157.0, 1292.0], [157.0, 1445.0], [131.0, 1445.0]]], "lines": ["やっぱこーゆー", "日に休めるのが", "教師の特権", "よねーー．．．"]}], "img_path": "subarashii_sekai_01_102.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [870, 107, 939, 214], "vertical": true, "font_size": 30, "lines_coords": [[[897.0, 107.0], [939.0, 107.0], [939.0, 181.0], [897.0, 181.0]], [[870.0, 110.0], [897.0, 110.0], [897.0, 214.0], [870.0, 214.0]]], "lines": ["って、", "なんで！？"]}, {"box": [768, 175, 825, 354], "vertical": true, "font_size": 30, "lines_coords": [[[798.0, 175.0], [825.0, 175.0], [825.0, 307.0], [798.0, 307.0]], [[768.0, 178.0], [790.0, 178.0], [790.0, 354.0], [768.0, 354.0]]], "lines": ["どーして", "ここにいんの！？"]}, {"box": [198, 135, 256, 265], "vertical": true, "font_size": 27, "lines_coords": [[[226.0, 135.0], [253.0, 135.0], [256.0, 265.0], [229.0, 265.0]], [[198.0, 137.0], [225.0, 137.0], [225.0, 240.0], [198.0, 240.0]]], "lines": ["あんたこそ", "仕事は？"]}, {"box": [812, 707, 839, 796], "vertical": true, "font_size": 27, "lines_coords": [[[812.0, 707.0], [839.0, 707.0], [839.0, 796.0], [812.0, 796.0]]], "lines": ["辞めた。"]}, {"box": [551, 960, 614, 1115], "vertical": true, "font_size": 31, "lines_coords": [[[579.0, 960.0], [614.0, 960.0], [614.0, 1042.0], [579.0, 1042.0]], [[551.0, 960.0], [578.0, 960.0], [578.0, 1057.0], [551.0, 1057.0]]], "lines": ["ウッソ", "でしょー"]}, {"box": [792, 1431, 884, 1453], "vertical": false, "font_size": 22, "lines_coords": [[[792.0, 1431.0], [884.0, 1431.0], [884.0, 1453.0], [792.0, 1453.0]]], "lines": ["ＰＲＥＳＩＣＴ"]}, {"box": [167, 1198, 225, 1304], "vertical": true, "font_size": 28, "lines_coords": [[[198.0, 1201.0], [225.0, 1201.0], [225.0, 1304.0], [198.0, 1304.0]], [[167.0, 1198.0], [196.0, 1198.0], [196.0, 1268.0], [167.0, 1268.0]]], "lines": ["ていうか", "まぁ、"]}, {"box": [182, 1350, 304, 1485], "vertical": true, "font_size": 28, "lines_coords": [[[278.0, 1353.0], [304.0, 1353.0], [304.0, 1453.0], [278.0, 1453.0]], [[242.0, 1350.0], [275.0, 1350.0], [275.0, 1432.0], [242.0, 1432.0]], [[210.0, 1350.0], [239.0, 1350.0], [240.0, 1479.0], [212.0, 1479.0]], [[182.0, 1350.0], [209.0, 1350.0], [209.0, 1485.0], [182.0, 1485.0]]], "lines": ["ムリヤリ", "辞表を", "ねじ込んで", "きてやった。"]}], "img_path": "subarashii_sekai_01_103.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [908, 115, 1000, 320], "vertical": true, "font_size": 25, "lines_coords": [[[976.0, 117.0], [998.0, 117.0], [998.0, 293.0], [976.0, 293.0]], [[940.0, 115.0], [968.0, 115.0], [970.0, 320.0], [942.0, 320.0]], [[908.0, 115.0], [934.0, 115.0], [937.0, 256.0], [911.0, 256.0]]], "lines": ["さすがに部長は", "ウヒャーーッって", "顔してたね。"]}, {"box": [736, 740, 831, 921], "vertical": true, "font_size": 31, "lines_coords": [[[793.0, 740.0], [831.0, 740.0], [831.0, 801.0], [793.0, 801.0]], [[767.0, 743.0], [793.0, 743.0], [792.0, 921.0], [765.0, 921.0]], [[736.0, 743.0], [764.0, 743.0], [764.0, 832.0], [736.0, 832.0]]], "lines": ["俺は", "ロックスターに", "なるよ。"]}, {"box": [391, 754, 448, 906], "vertical": true, "font_size": 24, "lines_coords": [[[421.0, 754.0], [448.0, 754.0], [448.0, 879.0], [421.0, 879.0]], [[392.0, 754.0], [412.0, 754.0], [412.0, 906.0], [392.0, 906.0]]], "lines": ["バッカじゃ", "なかろーか！！"]}, {"box": [159, 1103, 282, 1257], "vertical": true, "font_size": 30, "lines_coords": [[[256.0, 1107.0], [282.0, 1107.0], [282.0, 1257.0], [256.0, 1257.0]], [[217.0, 1103.0], [257.0, 1103.0], [257.0, 1176.0], [217.0, 1176.0]], [[192.0, 1107.0], [218.0, 1107.0], [218.0, 1257.0], [192.0, 1257.0]], [[159.0, 1107.0], [189.0, 1107.0], [189.0, 1184.0], [159.0, 1184.0]]], "lines": ["ナニ言ってん", "だよ、", "おまえ中学生", "かよ？"]}, {"box": [528, 1346, 592, 1488], "vertical": true, "font_size": 30, "lines_coords": [[[557.0, 1346.0], [592.0, 1346.0], [592.0, 1426.0], [557.0, 1426.0]], [[531.0, 1346.0], [557.0, 1346.0], [554.0, 1485.0], [528.0, 1485.0]]], "lines": ["クロス", "カウンター。"]}, {"box": [148, 1332, 242, 1439], "vertical": true, "font_size": 30, "lines_coords": [[[207.0, 1332.0], [242.0, 1332.0], [242.0, 1426.0], [207.0, 1426.0]], [[178.0, 1334.0], [206.0, 1334.0], [206.0, 1439.0], [178.0, 1439.0]], [[148.0, 1334.0], [175.0, 1334.0], [175.0, 1437.0], [148.0, 1437.0]]], "lines": ["バカだ、", "あんたは", "バカだ！！"]}], "img_path": "subarashii_sekai_01_104.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [900, 117, 989, 300], "vertical": true, "font_size": 26, "lines_coords": [[[962.0, 117.0], [989.0, 117.0], [989.0, 221.0], [962.0, 221.0]], [[933.0, 118.0], [959.0, 118.0], [959.0, 260.0], [933.0, 260.0]], [[900.0, 117.0], [926.0, 117.0], [926.0, 300.0], [900.0, 300.0]]], "lines": ["家賃は？", "そう、家賃は", "どーすんの？"]}, {"box": [125, 107, 248, 262], "vertical": true, "font_size": 26, "lines_coords": [[[215.0, 107.0], [248.0, 107.0], [248.0, 192.0], [215.0, 192.0]], [[184.0, 109.0], [210.0, 109.0], [215.0, 239.0], [189.0, 239.0]], [[153.0, 110.0], [179.0, 110.0], [179.0, 262.0], [153.0, 262.0]], [[125.0, 110.0], [146.0, 110.0], [146.0, 223.0], [125.0, 223.0]]], "lines": ["男には", "やらなきゃ", "ならない時が", "あるのさ。"]}, {"box": [740, 575, 831, 781], "vertical": true, "font_size": 27, "lines_coords": [[[801.0, 575.0], [828.0, 575.0], [831.0, 779.0], [804.0, 779.0]], [[770.0, 576.0], [797.0, 576.0], [798.0, 781.0], [772.0, 781.0]], [[740.0, 578.0], [767.0, 578.0], [767.0, 731.0], [740.0, 731.0]]], "lines": ["あたしの給料じゃ", "このマンションは", "無理でしょ！！"]}, {"box": [562, 373, 589, 496], "vertical": true, "font_size": 27, "lines_coords": [[[562.0, 373.0], [589.0, 373.0], [589.0, 496.0], [562.0, 496.0]]], "lines": ["マジすか？"]}, {"box": [184, 645, 217, 735], "vertical": true, "font_size": 33, "lines_coords": [[[184.0, 645.0], [217.0, 645.0], [217.0, 735.0], [184.0, 735.0]]], "lines": ["マジで。"]}, {"box": [892, 810, 984, 1015], "vertical": true, "font_size": 28, "lines_coords": [[[953.0, 810.0], [984.0, 810.0], [984.0, 976.0], [953.0, 976.0]], [[923.0, 812.0], [950.0, 812.0], [950.0, 1015.0], [923.0, 1015.0]], [[892.0, 812.0], [918.0, 812.0], [918.0, 925.0], [892.0, 925.0]]], "lines": ["出ていきます。", "そしてあんたとは", "別れます。"]}, {"box": [204, 890, 260, 1029], "vertical": true, "font_size": 27, "lines_coords": [[[231.0, 890.0], [257.0, 890.0], [260.0, 1028.0], [234.0, 1028.0]], [[204.0, 893.0], [226.0, 893.0], [226.0, 1029.0], [204.0, 1029.0]]], "lines": ["ありがとう、", "さようなら。"]}, {"box": [148, 1078, 256, 1260], "vertical": true, "font_size": 27, "lines_coords": [[[226.0, 1078.0], [253.0, 1078.0], [256.0, 1260.0], [229.0, 1260.0]], [[187.0, 1079.0], [215.0, 1079.0], [217.0, 1203.0], [189.0, 1203.0]], [[148.0, 1079.0], [182.0, 1079.0], [182.0, 1176.0], [148.0, 1176.0]]], "lines": ["ほんでもって", "おまえは", "死ね！"]}], "img_path": "subarashii_sekai_01_105.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [350, 115, 438, 240], "vertical": true, "font_size": 35, "lines_coords": [[[379.0, 115.0], [418.0, 118.0], [415.0, 178.0], [375.0, 175.0]], [[350.0, 118.0], [381.0, 118.0], [381.0, 168.0], [350.0, 168.0]]], "lines": ["「あー", "あー"]}, {"box": [801, 431, 899, 601], "vertical": true, "font_size": 30, "lines_coords": [[[870.0, 434.0], [897.0, 434.0], [897.0, 601.0], [870.0, 601.0]], [[834.0, 431.0], [870.0, 431.0], [870.0, 493.0], [834.0, 493.0]], [[804.0, 432.0], [832.0, 432.0], [829.0, 601.0], [801.0, 601.0]]], "lines": ["「わかってくれ", "とは", "言わないがー」"]}, {"box": [187, 681, 214, 718], "vertical": true, "font_size": 27, "lines_coords": [[[187.0, 681.0], [214.0, 681.0], [214.0, 718.0], [187.0, 718.0]]], "lines": ["か。"]}, {"box": [834, 860, 925, 972], "vertical": true, "font_size": 28, "lines_coords": [[[898.0, 860.0], [925.0, 860.0], [925.0, 970.0], [898.0, 970.0]], [[865.0, 862.0], [893.0, 862.0], [893.0, 964.0], [865.0, 964.0]], [[834.0, 860.0], [862.0, 860.0], [862.0, 953.0], [834.0, 953.0]]], "lines": ["すまんね、", "急に呼び", "出して。"]}, {"box": [253, 942, 314, 1054], "vertical": true, "font_size": 28, "lines_coords": [[[275.0, 943.0], [309.0, 942.0], [314.0, 1031.0], [279.0, 1032.0]], [[253.0, 943.0], [275.0, 943.0], [275.0, 1053.0], [253.0, 1053.0]]], "lines": ["ホント、", "急なのな。"]}, {"box": [868, 1137, 929, 1269], "vertical": true, "font_size": 26, "lines_coords": [[[903.0, 1140.0], [929.0, 1140.0], [929.0, 1243.0], [903.0, 1243.0]], [[872.0, 1137.0], [898.0, 1137.0], [895.0, 1242.0], [868.0, 1242.0]]], "lines": ["ありあと", "やしたー"]}, {"box": [105, 1292, 264, 1507], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 1292.0], [264.0, 1292.0], [264.0, 1384.0], [225.0, 1384.0]], [[201.0, 1293.0], [223.0, 1293.0], [223.0, 1495.0], [201.0, 1495.0]], [[167.0, 1292.0], [193.0, 1292.0], [193.0, 1478.0], [167.0, 1478.0]], [[137.0, 1293.0], [159.0, 1293.0], [159.0, 1507.0], [137.0, 1507.0]], [[106.0, 1295.0], [128.0, 1295.0], [128.0, 1479.0], [106.0, 1479.0]]], "lines": ["つーか、", "ウチの大学の軽音", "サークルＯＢで、", "ブラブラやってんの", "おまえだけでさ。"]}], "img_path": "subarashii_sekai_01_106.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [941, 115, 967, 256], "vertical": true, "font_size": 22, "lines_coords": [[[943.0, 115.0], [965.0, 115.0], [965.0, 256.0], [943.0, 256.0]]], "lines": ["うるせぇよ。"]}, {"box": [507, 262, 562, 390], "vertical": true, "font_size": 24, "lines_coords": [[[536.0, 262.0], [562.0, 262.0], [562.0, 390.0], [536.0, 390.0]], [[507.0, 264.0], [529.0, 264.0], [529.0, 389.0], [507.0, 389.0]]], "lines": ["おまえこそ", "仕事はよ？"]}, {"box": [106, 45, 361, 82], "vertical": false, "font_size": 32, "lines_coords": [[[106.0, 45.0], [361.0, 50.0],