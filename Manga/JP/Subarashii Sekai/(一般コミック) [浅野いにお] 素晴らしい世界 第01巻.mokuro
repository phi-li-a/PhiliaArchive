, 268.0], [312.0, 268.0]], [[281.0, 143.0], [307.0, 143.0], [307.0, 318.0], [281.0, 318.0]]], "lines": ["まぁ．．．", "なんつえば", "いいのかな．．．"]}, {"box": [776, 614, 903, 817], "vertical": true, "font_size": 28, "lines_coords": [[[870.0, 614.0], [900.0, 614.0], [903.0, 717.0], [873.0, 717.0]], [[839.0, 614.0], [865.0, 614.0], [868.0, 768.0], [842.0, 768.0]], [[809.0, 614.0], [836.0, 614.0], [839.0, 817.0], [812.0, 817.0]], [[776.0, 617.0], [803.0, 617.0], [806.0, 790.0], [779.0, 790.0]]], "lines": ["あ、うん。", "だから出席は", "ちょーっと難しい", "かなー、なんて。"]}, {"box": [444, 645, 512, 740], "vertical": true, "font_size": 38, "lines_coords": [[[471.0, 645.0], [512.0, 645.0], [512.0, 720.0], [471.0, 720.0]], [[445.0, 648.0], [479.0, 648.0], [479.0, 740.0], [445.0, 740.0]]], "lines": ["めまで", "エキ．．．"]}, {"box": [225, 356, 350, 515], "vertical": true, "font_size": 27, "lines_coords": [[[320.0, 360.0], [346.0, 360.0], [350.0, 490.0], [323.0, 490.0]], [[292.0, 364.0], [318.0, 364.0], [318.0, 490.0], [292.0, 490.0]], [[262.0, 364.0], [284.0, 364.0], [284.0, 515.0], [262.0, 515.0]], [[225.0, 359.0], [257.0, 356.0], [262.0, 404.0], [229.0, 407.0]]], "lines": ["とりあえず", "会社員じゃ", "ないんだけど", "さ。"]}, {"box": [193, 695, 328, 875], "vertical": true, "font_size": 35, "lines_coords": [[[290.0, 696.0], [328.0, 696.0], [328.0, 764.0], [290.0, 764.0]], [[260.0, 695.0], [289.0, 695.0], [293.0, 875.0], [265.0, 875.0]], [[228.0, 696.0], [260.0, 696.0], [260.0, 864.0], [228.0, 864.0]], [[193.0, 695.0], [234.0, 695.0], [234.0, 767.0], [193.0, 767.0]]], "lines": ["ハイ。", "そういう感じで", "お願いします。", "ハイ。"]}, {"box": [554, 934, 582, 1021], "vertical": true, "font_size": 28, "lines_coords": [[[554.0, 934.0], [582.0, 934.0], [582.0, 1021.0], [554.0, 1021.0]]], "lines": ["センセ。"]}, {"box": [146, 968, 209, 1078], "vertical": true, "font_size": 28, "lines_coords": [[[179.0, 970.0], [207.0, 970.0], [207.0, 1076.0], [179.0, 1076.0]], [[150.0, 968.0], [178.0, 968.0], [175.0, 1073.0], [146.0, 1073.0]]], "lines": ["今の電話、", "誰スか？"]}, {"box": [492, 1153, 554, 1281], "vertical": true, "font_size": 30, "lines_coords": [[[525.0, 1153.0], [553.0, 1153.0], [554.0, 1281.0], [526.0, 1281.0]], [[492.0, 1153.0], [525.0, 1153.0], [525.0, 1245.0], [492.0, 1245.0]]], "lines": ["中学ん時の", "同級生。"]}, {"box": [182, 1331, 246, 1496], "vertical": true, "font_size": 30, "lines_coords": [[[214.0, 1332.0], [246.0, 1332.0], [246.0, 1414.0], [214.0, 1414.0]], [[182.0, 1331.0], [209.0, 1331.0], [214.0, 1496.0], [187.0, 1496.0]]], "lines": ["同窓会", "やんだってさ。"]}], "img_path": "subarashii_sekai_01_140.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [901, 100, 997, 281], "vertical": true, "font_size": 28, "lines_coords": [[[967.0, 101.0], [995.0, 101.0], [997.0, 240.0], [968.0, 240.0]], [[934.0, 100.0], [962.0, 100.0], [965.0, 217.0], [937.0, 217.0]], [[901.0, 100.0], [928.0, 100.0], [933.0, 281.0], [906.0, 281.0]]], "lines": ["お、いいじゃ", "ないスか。", "行くんでしょ？"]}, {"box": [125, 82, 246, 298], "vertical": true, "font_size": 25, "lines_coords": [[[217.0, 82.0], [243.0, 82.0], [246.0, 246.0], [220.0, 246.0]], [[187.0, 82.0], [210.0, 82.0], [212.0, 262.0], [189.0, 262.0]], [[156.0, 82.0], [182.0, 82.0], [182.0, 298.0], [156.0, 298.0]], [[125.0, 84.0], [146.0, 84.0], [146.0, 268.0], [125.0, 268.0]]], "lines": ["３５歳になって、", "売れない漫画家", "やってます、なんて", "言えるかっつの。"]}, {"box": [745, 335, 776, 475], "vertical": true, "font_size": 27, "lines_coords": [[[745.0, 335.0], [772.0, 335.0], [775.0, 475.0], [748.0, 475.0]]], "lines": ["行かねーよ。"]}, {"box": [795, 610, 851, 752], "vertical": true, "font_size": 25, "lines_coords": [[[823.0, 610.0], [851.0, 610.0], [851.0, 703.0], [823.0, 703.0]], [[795.0, 614.0], [817.0, 614.0], [817.0, 746.0], [795.0, 746.0]]], "lines": ["あらら。", "なんでまた"]}, {"box": [178, 312, 268, 517], "vertical": true, "font_size": 25, "lines_coords": [[[237.0, 312.0], [265.0, 312.0], [268.0, 465.0], [240.0, 465.0]], [[206.0, 314.0], [232.0, 314.0], [235.0, 517.0], [209.0, 517.0]], [[178.0, 315.0], [200.0, 315.0], [200.0, 457.0], [178.0, 457.0]]], "lines": ["中堅になって", "バリバリ働いてる", "ヤツらによー"]}, {"box": [135, 576, 196, 726], "vertical": true, "font_size": 26, "lines_coords": [[[170.0, 578.0], [196.0, 578.0], [196.0, 726.0], [170.0, 726.0]], [[139.0, 576.0], [165.0, 576.0], [162.0, 715.0], [135.0, 715.0]]], "lines": ["そーゆーモン", "なんスかね。"]}, {"box": [843, 823, 936, 974], "vertical": true, "font_size": 27, "lines_coords": [[[906.0, 823.0], [933.0, 823.0], [936.0, 965.0], [909.0, 965.0]], [[879.0, 826.0], [901.0, 826.0], [898.0, 973.0], [876.0, 973.0]], [[843.0, 823.0], [875.0, 823.0], [875.0, 881.0], [843.0, 881.0]]], "lines": ["あれ、どっか", "出かけるんス", "か？"]}, {"box": [306, 820, 365, 971], "vertical": true, "font_size": 25, "lines_coords": [[[340.0, 823.0], [362.0, 823.0], [362.0, 971.0], [340.0, 971.0]], [[306.0, 820.0], [334.0, 820.0], [334.0, 907.0], [306.0, 907.0]]], "lines": ["今日は子供と", "会う日。"]}, {"box": [640, 1168, 697, 1307], "vertical": true, "font_size": 24, "lines_coords": [[[670.0, 1168.0], [697.0, 1168.0], [697.0, 1307.0], [670.0, 1307.0]], [[640.0, 1170.0], [662.0, 1170.0], [662.0, 1281.0], [640.0, 1281.0]]], "lines": ["あ、奥さんに", "よろしく。"]}, {"box": [170, 1376, 207, 1471], "vertical": true, "font_size": 34, "lines_coords": [[[173.0, 1376.0], [207.0, 1378.0], [204.0, 1471.0], [170.0, 1470.0]]], "lines": ["“元”な。"]}], "img_path": "subarashii_sekai_01_141.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [836, 779, 870, 862], "vertical": true, "font_size": 34, "lines_coords": [[[836.0, 779.0], [870.0, 779.0], [870.0, 862.0], [836.0, 862.0]]], "lines": ["お．．．．．"]}, {"box": [902, 931, 959, 1083], "vertical": true, "font_size": 25, "lines_coords": [[[931.0, 931.0], [959.0, 931.0], [959.0, 1009.0], [931.0, 1009.0]], [[903.0, 932.0], [925.0, 932.0], [925.0, 1046.0], [903.0, 1046.0]]], "lines": ["大きく", "なったなー"]}, {"box": [568, 978, 668, 1157], "vertical": true, "font_size": 31, "lines_coords": [[[623.0, 979.0], [662.0, 978.0], [668.0, 1093.0], [631.0, 1096.