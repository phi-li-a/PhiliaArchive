762, 1429], "vertical": true, "font_size": 16, "lines_coords": [[[743.0, 1295.0], [759.0, 1295.0], [762.0, 1429.0], [747.0, 1429.0]]], "lines": ["．．．．．"]}, {"box": [895, 1082, 911, 1432], "vertical": true, "font_size": 16.0, "lines_coords": [[[895.0, 1082.0], [911.0, 1082.0], [911.0, 1262.0], [895.0, 1262.0]], [[895.0, 1257.0], [911.0, 1257.0], [911.0, 1432.0], [895.0, 1432.0]]], "lines": ["．．．", "．．．"]}], "img_path": "subarashii_sekai_01_148.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [664, 53, 790, 205], "vertical": true, "font_size": 30, "lines_coords": [[[754.0, 53.0], [790.0, 53.0], [790.0, 112.0], [754.0, 112.0]], [[726.0, 56.0], [753.0, 56.0], [753.0, 204.0], [726.0, 204.0]], [[695.0, 56.0], [722.0, 56.0], [722.0, 181.0], [695.0, 181.0]], [[664.0, 54.0], [692.0, 54.0], [692.0, 167.0], [664.0, 167.0]]], "lines": ["今日、", "あたしの中の", "いろいろが", "終わった。"]}, {"box": [311, 51, 468, 284], "vertical": true, "font_size": 29, "lines_coords": [[[437.0, 53.0], [464.0, 53.0], [467.0, 256.0], [440.0, 256.0]], [[400.0, 51.0], [439.0, 51.0], [439.0, 142.0], [400.0, 142.0]], [[375.0, 54.0], [401.0, 54.0], [401.0, 281.0], [375.0, 281.0]], [[343.0, 53.0], [370.0, 53.0], [370.0, 242.0], [343.0, 242.0]], [[311.0, 54.0], [337.0, 54.0], [337.0, 284.0], [311.0, 284.0]]], "lines": ["終わりってもんは", "突然に、", "そして淡々と起こる", "もんなんだなぁ。", "などと思いつつ．．．"]}, {"box": [298, 707, 353, 819], "vertical": true, "font_size": 24, "lines_coords": [[[326.0, 707.0], [353.0, 707.0], [353.0, 809.0], [326.0, 809.0]], [[298.0, 709.0], [320.0, 709.0], [320.0, 818.0], [298.0, 818.0]]], "lines": ["フロでも", "入るかぁ"]}, {"box": [904, 809, 936, 867], "vertical": true, "font_size": 32, "lines_coords": [[[904.0, 809.0], [936.0, 809.0], [936.0, 867.0], [904.0, 867.0]]], "lines": ["ぶっ。"]}, {"box": [127, 989, 383, 1070], "vertical": false, "font_size": 30, "lines_coords": [[[135.0, 987.0], [375.0, 993.0], [375.0, 1028.0], [135.0, 1022.0]], [[135.0, 1037.0], [378.0, 1037.0], [378.0, 1067.0], [135.0, 1067.0]]], "lines": ["７ｔｈｐｒｏｇｒａｍ", "ｍｉｎｉｇｒａｍｎｅｒ"]}], "img_path": "subarashii_sekai_01_149.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [858, 809, 917, 996], "vertical": true, "font_size": 26, "lines_coords": [[[890.0, 809.0], [917.0, 809.0], [917.0, 976.0], [890.0, 976.0]], [[858.0, 809.0], [884.0, 809.0], [884.0, 996.0], [858.0, 996.0]]], "lines": ["あ、引っ越し？", "あたしは５日後。"]}, {"box": [767, 1010, 861, 1245], "vertical": true, "font_size": 26, "lines_coords": [[[834.0, 1015.0], [861.0, 1015.0], [861.0, 1142.0], [834.0, 1142.0]], [[804.0, 1015.0], [826.0, 1015.0], [826.0, 1245.0], [804.0, 1245.0]], [[772.0, 1010.0], [800.0, 1012.0], [795.0, 1126.0], [767.0, 1125.0]]], "lines": ["いやマジで", "相当めんどくさいよ。", "荷作りが。"]}, {"box": [100, 996, 257, 1200], "vertical": true, "font_size": 28, "lines_coords": [[[221.0, 1000.0], [254.0, 1000.0], [257.0, 1112.0], [225.0, 1112.0]], [[195.0, 1001.0], [221.0, 1001.0], [221.0, 1200.0], [195.0, 1200.0]], [[164.0, 996.0], [192.0, 996.0], [192.0, 1146.0], [164.0, 1146.0]], [[131.0, 998.0], [157.0, 998.0], [157.0, 1176.0], [131.0, 1176.0]], [[100.0, 998.0], [131.0, 998.0], [131.0, 1040.0], [100.0, 1040.0]]], "lines": ["一応さぁ、", "いらないものとか", "ちょっとずつ", "捨ててんだけど", "さ。"]}, {"box": [134, 1260, 256, 1400], "vertical": true, "font_size": 28, "lines_coords": [[[228.0, 1262.0], [256.0, 1262.0], [256.0, 1390.0], [228.0, 1390.0]], [[196.0, 1262.0], [225.0, 1262.0], [225.0, 1367.0], [196.0, 1367.0]], [[165.0, 1260.0], [192.0, 1260.0], [192.0, 1400.0], [165.0, 1400.0]], [[134.0, 1262.0], [156.0, 1262.0], [156.0, 1362.0], [134.0, 1362.0]]], "lines": ["．．．．．．えっ？", "手伝って", "もらえって、", "誰にさ？"]}], "img_path": "subarashii_sekai_01_150.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [878, 57, 967, 290], "vertical": true, "font_size": 25, "lines_coords": [[[940.0, 60.0], [967.0, 60.0], [967.0, 189.0], [940.0, 189.0]], [[908.0, 57.0], [934.0, 57.0], [934.0, 234.0], [908.0, 234.0]], [[878.0, 62.0], [900.0, 62.0], [900.0, 290.0], [878.0, 290.0]]], "lines": ["横山くん？", "だはっ、無理だ。", "だって別れたもん。"]}, {"box": [743, 201, 832, 360], "vertical": true, "font_size": 25, "lines_coords": [[[806.0, 201.0], [832.0, 201.0], [832.0, 342.0], [806.0, 342.0]], [[775.0, 203.0], [801.0, 203.0], [801.0, 331.0], [775.0, 331.0]], [[743.0, 203.0], [767.0, 203.0], [768.0, 360.0], [745.0, 360.0]]], "lines": ["てか、ホント", "ついさっき", "別れたばっか。"]}, {"box": [597, 129, 650, 232], "vertical": true, "font_size": 25, "lines_coords": [[[597.0, 129.0], [622.0, 129.0], [622.0, 173.0], [597.0, 173.0]]], "lines": ["まー"]}, {"box": [151, 82, 296, 364], "vertical": true, "font_size": 24, "lines_coords": [[[275.0, 87.0], [296.0, 87.0], [296.0, 298.0], [275.0, 298.0]], [[242.0, 84.0], [268.0, 84.0], [271.0, 364.0], [245.0, 364.0]], [[210.0, 82.0], [237.0, 82.0], [240.0, 314.0], [214.0, 314.0]], [[179.0, 84.0], [207.0, 84.0], [209.0, 290.0], [181.0, 290.0]], [[151.0, 85.0], [173.0, 85.0], [176.0, 321.0], [154.0, 321.0]]], "lines": ["ホラ、あたし春から", "実家のほうでＯＬじゃん？", "横山くんはこっちで", "漫画家になるとか", "なんとか言ってるし。"]}, {"box": [809, 662, 900, 864], "vertical": true, "font_size": 29, "lines_coords": [[[878.0, 665.0], [900.0, 665.0], [900.0, 864.0], [878.0, 864.0]], [[842.0, 662.0], [870.0, 662.0], [872.0, 814.0], [843.0, 814.0]], [[809.0, 662.0], [843.0, 662.0], [843.0, 754.0], [809.0, 754.0]]], "lines": ["もうだいぶ前から", "わかってたっ", "つーか。"]}, {"box": [154, 373, 243, 575], "vertical": true, "font_size": 24, "lines_coords": [[[221.0, 376.0], [243.0, 376.0], [243.0, 500.0], [221.0, 500.0]], [[190.0, 375.0], [212.0, 375.0], [212.0, 575.0], [190.0, 575.0]], [[154.0, 373.0], [181.0, 373.0], [184.0, 514.0], [157.0, 514.0]]], "lines": ["お互い、遠恋", "できるタイプでも", "ないっしょ。"]}, {"box": [768, 900, 864, 1079], "vertical": true, "font_size": 29, "lines_coords": [[[836.0, 900.0], [864.0, 900.0], [859.0, 1079.0], [831.0, 1079.0]], [[798.0, 903.0], [834.0, 903.0], [834.0, 970.0], [798.0, 970.0]], [[768.0, 901.0], [795.0, 901.0], [798.0, 1040.0], [772.0, 1040.0]]], "lines": ["「しょーがない」", "って、", "雰囲気でさ。"]}], "img_path": "subarashii_sekai_01_151.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [233, 999, 261, 1116], "vertical": true, "font_size": 23, "lines_coords": [[[234.0, 1056.0], [257.0, 1056.0], [257.0, 1112.0], [234.0, 1112.0]]], "lines": ["．．．ア"]}, {"box": [922, 1173, 950, 1260], "vertical": true, "font_size": 28, "lines_coords": [[[922.0, 1173.0], [950.0, 1173.0], [950.0, 1260.0], [922.0, 1260.0]]], "lines": ["ごめん。"]}, {"box": [326, 1207, 387, 1335], "vertical": true, "font_size": 27, "lines_coords": [[[361.0, 1207.0], [387.0, 1207.0], [387.0, 1335.0], [361.0, 1335.0]], [[326.0, 1207.0], [353.0, 1207.0], [356.0, 1320.0], [329.0, 1320.0]]], "lines": ["なんか一瞬", "トんでた。"]}, {"box": [260, 1337, 287, 1429], "vertical": true, "font_size": 27, "lines_coords": [[[260.0, 1337.0], [287.0, 1337.0], [287.0, 1429.0], [260.0, 1429.0]]], "lines": ["うはは。"]}], "img_path": "subarashii_sekai_01_152.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [797, 130, 950, 398], "vertical": true, "font_size": 27, "lines_coords": [[[923.0, 132.0], [950.0, 132.0], [950.0, 282.0], [923.0, 282.0]], [[892.0, 132.0], [920.0, 132.0], [917.0, 310.0], [889.0, 310.0]], [[856.0, 132.0], [884.0, 132.0], [886.0, 310.0], [858.0, 310.0]], [[826.0, 132.0], [853.0, 132.0], [853.0, 396.0], [826.0, 396.0]], [[797.0, 135.0], [823.0, 135.0], [823.0, 315.0], [797.0, 315.0]]], "lines": ["もうちょっと", "安っちいドラマ", "みたいなことが", "起きたらよかったのに。", "「めんどくさいけど"]}, {"box": [193, 95, 281, 284], "vertical": true, "font_size": 24, "lines_coords": [[[254.0, 95.0], [281.0, 95.0], [281.0, 193.0], [254.0, 193.0]], [[223.0, 95.0], [246.0, 95.0], [245.0, 271.0], [221.0, 271.0]], [[193.0, 95.0], [215.0, 95.0], [215.0, 284.0], [193.0, 284.0]]], "lines": ["んじゃー", "湯冷めする前に", "あたしは寝るス。"]}, {"box": [129, 195, 276, 493], "vertical": true, "font_size": 24, "lines_coords": [[[259.0, 195.0], [276.0, 195.0], [276.0, 223.0], [259.0, 223.0]], [[189.0, 298.0], [218.0, 298.0], [218.0, 373.0], [189.0, 373.0]], [[156.0, 315.0], [182.0, 315.0], [187.0, 493.0], [160.0, 493.0]], [[129.0, 318.0], [151.0, 318.0], [151.0, 454.0], [129.0, 454.0]]], "lines": ["！", "明日", "早起きしなきゃ", "ならんのさ。"]}, {"box": [651, 439, 772, 718], "vertical": true, "font_size": 26, "lines_coords": [[[743.0, 442.0], [770.0, 442.0], [770.0, 578.0], [743.0, 578.0]], [[712.0, 439.0], [739.0, 439.0], [737.0, 717.0], [711.0, 717.0]], [[679.0, 440.0], [707.0, 440.0], [706.0, 700.0], [678.0, 700.0]], [[654.0, 442.0], [676.0, 442.0], [673.0, 587.0], [651.0, 587.0]]], "lines": ["今、あいつが", "泣きながら戻ってきたら", "ちょっとうれしいのに、", "実際、困るけど"]}, {"box": [257, 685, 289, 743], "vertical": true, "font_size": 32, "lines_coords": [[[257.0, 685.0], [289.0, 685.0], [289.0, 743.0], [257.0, 743.0]]], "lines": ["え？"]}, {"box": [798, 948, 828, 1004], "vertical": true, "font_size": 30, "lines_coords": [[[798.0, 948.0], [828.0, 948.0], [828.0, 1004.0], [798.0, 1004.0]]], "lines": ["外？"]}, {"box": [226, 1263, 254, 1382], "vertical": true, "font_size": 28, "lines_coords": [[[226.0, 1317.0], [254.0, 1317.0], [254.0, 1382.0], [226.0, 1382.0]]], "lines": ["．．．ワ。"]}], "img_path": "subarashii_sekai_01_153.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [270, 875, 298, 1068], "vertical": true, "font_size": 26, "lines_coords": [[[270.0, 876.0], [296.0, 876.0], [296.0, 1068.0], [270.0, 1068.0]]], "lines": ["今、外に出れば．．．"]}], "img_path": "subarashii_sekai_01_154.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [839, 107, 935, 287], "vertical": true, "font_size": 26, "lines_coords": [[[909.0, 109.0], [931.0, 109.0], [931.0, 265.0], [909.0, 265.0]], [[875.0, 110.0], [897.0, 110.0], [897.0, 287.0], [875.0, 287.0]], [[839.0, 107.0], [873.0, 107.0], [873.0, 170.0], [839.0, 170.0]]], "lines": ["足跡のない雪、", "独り占めできる", "かも。"]}, {"box": [90, 50, 317, 85], "vertical": false, "font_size": 32, "lines_coords": [[[90.0, 50.0], [317.0, 53.0], [317.0, 85.0], [90.0, 82.0]]], "lines": ["素晴らしい世界"]}, {"box": [548, 1296, 768, 1475], "vertical": true, "font_size": 28, "lines_coords": [[[742.0, 1298.0], [768.0, 1298.0], [768.0, 1446.0], [742.0, 1446.0]], [[709.0, 1298.0], [740.0, 1298.0], [740.0, 1475.0], [709.0, 1475.0]], [[679.0, 1298.0], [706.0, 1298.0], [706.0, 1473.0], [679.0, 1473.0]], [[645.0, 1296.0], [672.0, 1296.0], [675.0, 1431.0], [648.0, 1431.0]], [[614.0, 1298.0], [643.0, 1298.0], [643.0, 1375.0], [614.0, 1375.0]], [[586.0, 1300.0], [607.0, 1300.0], [607.0, 1420.0], [586.0, 1420.0]], [[548.0, 1296.0], [582.0, 1296.0], [582.0, 1384.0], [548.0, 1384.0]]], "lines": ["ドアの前には", "ついさっきまで", "いたのであろう", "彼の足跡と、", "小さな", "雪たるまが", "あった"]}, {"box": [303, 1295, 459, 1499], "vertical": true, "font_size": 27, "lines_coords": [[[432.0, 1296.0], [459.0, 1296.0], [456.0, 1448.0], [429.0, 1448.0]], [[400.0, 1298.0], [426.0, 1298.0], [426.0, 1498.0], [400.0, 1498.0]], [[367.0, 1298.0], [393.0, 1298.0], [393.0, 1446.0], [367.0, 1446.0]], [[336.0, 1296.0], [362.0, 1296.0], [362.0, 1471.0], [336.0, 1471.0]], [[303.0, 1298.0], [331.0, 1298.0], [331.0, 1425.0], [303.0, 1425.0]]], "lines": ["そして溶けた", "雪だるまの中から", "あたしの指に", "ぴったりはまる", "指輪が．．．："]}], "img_path": "subarashii_sekai_01_155.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [384, 67, 477, 269], "vertical": true, "font_size": 25, "lines_coords": [[[451.0, 67.0], [473.0, 67.0], [473.0, 267.0], [451.0, 267.0]], [[418.0, 71.0], [445.0, 71.0], [445.0, 232.0], [418.0, 232.0]], [[384.0, 68.0], [411.0, 68.0], [415.0, 210.0], [389.0, 210.0]]], "lines": ["．．．なんてことは", "やっぱりなく、", "〈そりゃそうだ〉"]}, {"box": [200, 70, 350, 333], "vertical": true, "font_size": 25, "lines_coords": [[[323.0, 71.0], [350.0, 71.0], [350.0, 243.0], [323.0, 243.0]], [[292.0, 70.0], [318.0, 70.0], [318.0, 198.0], [292.0, 198.0]], [[259.0, 70.0], [286.0, 70.0], [287.0, 282.0], [260.0, 282.0]], [[231.0, 73.0], [253.0, 73.0], [253.0, 329.0], [231.0, 329.0]], [[200.0, 73.0], [221.0, 73.0], [221.0, 187.0], [200.0, 187.0]]], "lines": ["むしろベッドが", "持ち帰った", "雪だるまのせいで、", "ピショビショに濡れた。", "ふさけんな"]}, {"box": [886, 487, 912, 601], "vertical": true, "font_size": 26, "lines_coords": [[[886.0, 487.0], [912.0, 487.0], [912.0, 601.0], [886.0, 601.0]]], "lines": ["バカヤロ。"]}, {"box": [692, 795, 722, 853], "vertical": true, "font_size": 30, "lines_coords": [[[692.0, 795.0], [722.0, 795.0], [722.0, 853.0], [692.0, 853.0]]], "lines": ["ぶっ。"]}, {"box": [582, 1234, 676, 1476], "vertical": true, "font_size": 30, "lines_coords": [[[648.0, 1237.0], [676.0, 1237.0], [676.0, 1348.0], [648.0, 1348.0]], [[612.0, 1234.0], [647.0, 1234.0], [647.0, 1317.0], [612.0, 1317.0]], [[582.0, 1235.0], [609.0, 1235.0], [612.0, 1473.0], [586.0, 1473.0]]], "lines": ["でも案外、", "気分は", "晴れやかなのだった"]}, {"box": [425, 1235, 515, 1452], "vertical": true, "font_size": 27, "lines_coords": [[[487.0, 1237.0], [514.0, 1237.0], [514.0, 1387.0], [487.0, 1387.0]], [[454.0, 1235.0], [482.0, 1235.0], [484.0, 1440.0], [456.0, 1440.0]], [[425.0, 1237.0], [451.0, 1237.0], [453.0, 1450.0], [426.0, 1450.0]]], "lines": ["何より今日は", "何かを始めるには", "いい日だと思った。"]}], "img_path": "subarashii_sekai_01_156.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [46, 50, 65, 179], "vertical": true, "font_size": 18, "lines_coords": [[[48.0, 50.0], [65.0, 50.0], [64.0, 179.0], [46.0, 179.0]]], "lines": ["．．．"]}, {"box": [68, 51, 79, 181], "vertical": true, "font_size": 11, "lines_coords": [[[68.0, 51.0], [79.0, 51.0], [79.0, 181.0], [68.0, 181.0]]], "lines": ["．．．"]}, {"box": [125, 51, 157, 332], "vertical": true, "font_size": 13.5, "lines_coords": [[[143.0, 51.0], [156.0, 51.0], [157.0, 332.0], [145.0, 332.0]], [[125.0, 51.0], [140.0, 51.0], [140.0, 220.0], [125.0, 220.0]]], "lines": ["．．．．．．", "．．．．．"]}, {"box": [221, 53, 232, 184], "vertical": true, "font_size": 11, "lines_coords": [[[221.0, 53.0], [232.0, 53.0], [232.0, 184.0], [221.0, 184.0]]], "lines": ["．．．"]}, {"box":