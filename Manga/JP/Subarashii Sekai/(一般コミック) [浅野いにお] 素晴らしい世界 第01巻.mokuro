, 1479.0]], [[526.0, 1276.0], [550.0, 1276.0], [546.0, 1417.0], [523.0, 1417.0]]], "lines": ["俺も夜になったら", "出発するわ。"]}, {"box": [148, 1301, 240, 1479], "vertical": true, "font_size": 27, "lines_coords": [[[209.0, 1301.0], [237.0, 1301.0], [240.0, 1415.0], [212.0, 1415.0]], [[178.0, 1301.0], [204.0, 1301.0], [207.0, 1479.0], [181.0, 1479.0]], [[148.0, 1303.0], [175.0, 1303.0], [175.0, 1453.0], [148.0, 1453.0]]], "lines": ["なんだよ、", "うれしくねぇの", "かよ、おまえ。"]}], "img_path": "subarashii_sekai_01_082.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [192, 112, 317, 242], "vertical": true, "font_size": 28, "lines_coords": [[[289.0, 112.0], [317.0, 112.0], [317.0, 201.0], [289.0, 201.0]], [[256.0, 114.0], [282.0, 114.0], [282.0, 218.0], [256.0, 218.0]], [[221.0, 114.0], [250.0, 114.0], [253.0, 242.0], [225.0, 242.0]], [[192.0, 114.0], [220.0, 114.0], [220.0, 218.0], [192.0, 218.0]]], "lines": ["じゃあ、", "おまえも", "いっしょに", "行くか？"]}, {"box": [228, 767, 256, 878], "vertical": true, "font_size": 26, "lines_coords": [[[228.0, 767.0], [254.0, 767.0], [254.0, 878.0], [228.0, 878.0]]], "lines": ["冗談だよ。"]}, {"box": [275, 1125, 314, 1178], "vertical": true, "font_size": 39, "lines_coords": [[[275.0, 1125.0], [314.0, 1125.0], [314.0, 1178.0], [275.0, 1178.0]]], "lines": ["あ。"]}], "img_path": "subarashii_sekai_01_083.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [926, 123, 964, 265], "vertical": true, "font_size": 38, "lines_coords": [[[926.0, 123.0], [964.0, 123.0], [964.0, 265.0], [926.0, 265.0]]], "lines": ["やばい！！"]}, {"box": [373, 103, 437, 259], "vertical": true, "font_size": 29, "lines_coords": [[[406.0, 104.0], [436.0, 104.0], [437.0, 198.0], [407.0, 198.0]], [[376.0, 103.0], [404.0, 103.0], [401.0, 259.0], [373.0, 259.0]]], "lines": ["ちょっ、", "ちょっと何？"]}, {"box": [170, 443, 286, 631], "vertical": true, "font_size": 42, "lines_coords": [[[239.0, 443.0], [286.0, 443.0], [286.0, 542.0], [239.0, 542.0]], [[201.0, 443.0]