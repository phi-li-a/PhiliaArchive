["素晴らしい世界１"]}, {"box": [891, 1004, 958, 1181], "vertical": true, "font_size": 26, "lines_coords": [[[929.0, 1004.0], [956.0, 1004.0], [956.0, 1179.0], [929.0, 1179.0]], [[892.0, 1006.0], [918.0, 1006.0], [918.0, 1165.0], [892.0, 1165.0]]], "lines": ["先生はひたすら", "謝りつづけた。"]}, {"box": [773, 1003, 840, 1256], "vertical": true, "font_size": 27, "lines_coords": [[[811.0, 1003.0], [837.0, 1003.0], [839.0, 1256.0], [812.0, 1256.0]], [[773.0, 1004.0], [800.0, 1004.0], [800.0, 1142.0], [773.0, 1142.0]]], "lines": ["お母さんは泣きながら", "怒っていた。"]}, {"box": [653, 1001, 722, 1182], "vertical": true, "font_size": 28, "lines_coords": [[[693.0, 1004.0], [720.0, 1004.0], [720.0, 1179.0], [693.0, 1179.0]], [[656.0, 1001.0], [684.0, 1001.0], [681.0, 1137.0], [653.0, 1137.0]]], "lines": ["お父さんはただ", "黙っていた。"]}, {"box": [496, 1002, 602, 1255], "vertical": true, "font_size": 27, "lines_coords": [[[573.0, 1004.0], [600.0, 1004.0], [600.0, 1229.0], [573.0, 1229.0]], [[536.0, 1003.0], [562.0, 1003.0], [562.0, 1254.0], [536.0, 1254.0]], [[496.0, 1006.0], [525.0, 1006.0], [525.0, 1114.0], [496.0, 1114.0]]], "lines": ["あたしは右足の骨に", "ヒビが入って夏休みが", "つぶれた。"]}, {"box": [376, 1043, 404, 1229], "vertical": true, "font_size": 27, "lines_coords": [[[376.0, 1043.0], [403.0, 1043.0], [404.0, 1229.0], [378.0, 1229.0]]], "lines": ["「それはどうでも"]}, {"box": [340, 1006, 367, 1139], "vertical": true, "font_size": 27, "lines_coords": [[[340.0, 1006.0], [367.0, 1006.0], [367.0, 1139.0], [340.0, 1139.0]]], "lines": ["いいとして、"]}, {"box": [140, 997, 285, 1281], "vertical": true, "font_size": 28, "lines_coords": [[[256.0, 1000.0], [284.0, 1000.0], [284.0, 1135.0], [256.0, 1135.0]], [[214.0, 1000.0], [245.0, 1000.0], [250.0, 1281.0], [218.0, 1281.0]], [[178.0, 1000.0], [204.0, 1000.0], [207.0, 1229.0], [181.0, 1229.0]], [[140.0, 998.0], [167.0, 998.0], [170.0, 1240.0], [143.0, 1240.0]]], "lines": ["その日の夜、", "病院の硬いベッドの上で", "あたしはポンヤリと", "思いを巡らせていた。"]}], "img_path": "subarashii_sekai_01_059.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [560, 151, 593, 416], "vertical": true, "font_size": 27, "lines_coords": [[[562.0, 151.0], [589.0, 151.0], [589.0, 410.0], [562.0, 410.0]]], "lines": ["死ななくてよかった。"]}, {"box": [495, 823, 584, 960], "vertical": true, "font_size": 25, "lines_coords": [[[556.0, 823.0], [582.0, 823.0], [582.0, 951.0], [556.0, 951.0]], [[525.0, 823.0], [551.0, 823.0], [551.0, 925.0], [525.0, 925.0]], [[495.0, 826.0], [517.0, 826.0], [517.0, 957.0], [495.0, 957.0]]], "lines": ["なんでまだ", "おまえが", "いるんだよ。"]}, {"box": [185, 1307, 246, 1440], "vertical": true, "font_size": 30, "lines_coords": [[[214.0, 1307.0], [246.0, 1307.0], [246.0, 1392.0], [214.0, 1392.0]], [[185.0, 1309.0], [212.0, 1309.0], [212.0, 1431.0], [185.0, 1431.0]]], "lines": ["あ．．．", "あの．．．．．．"]}], "img_path": "subarashii_sekai_01_060.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [870, 107, 893, 258], "vertical": true, "font_size": 22, "lines_coords": [[[870.0, 107.0], [892.0, 107.0], [892.0, 253.0], [870.0, 253.0]]], "lines": ["おはよう．．．"]}, {"box": [132, 120, 196, 275], "vertical": true, "font_size": 28, "lines_coords": [[[170.0, 121.0], [193.0, 121.0], [192.0, 273.0], [168.0, 273.0]], [[132.0, 120.0], [165.0, 120.0], [165.0, 204.0], [132.0, 204.0]]], "lines": ["〝ございます〟", "だろ？"]}, {"box": [243, 667, 316, 851], "vertical": true, "font_size": 30, "lines_coords": [[[286.0, 668.0], [314.0, 668.0], [314.0, 792.0], [286.0, 792.0]], [[246.0, 667.0], [278.0, 667.0], [275.0, 851.0], [243.0, 851.0]]], "lines": ["おはよう", "ございます！！"]}], "img_path": "subarashii_sekai_01_061.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [918, 107, 989, 298], "vertical": true, "font_size": 34, "lines_coords": [[[947.0, 107.0], [989.0, 107.0], [989.0, 181.0], [947.0, 181.0]], [[918.0, 109.0], [945.0, 109.0], [945.0, 298.0], [918.0, 298.0]]], "lines": ["へっ、", "くだらねーーっ。"]}, {"box": [286, 142, 370, 242], "vertical": true, "font_size": 23, "lines_coords": [[[346.0, 142.0], [370.0, 143.0], [367.0, 214.0], [343.0, 212.0]], [[317.0, 145.0], [334.0, 145.0], [334.0, 237.0], [317.0, 237.0]], [[286.0, 146.0], [303.0, 146.0], [303.0, 242.0], [286.0, 242.0]]], "lines": ["これか", "クラスの", "キンク！？"]}, {"box": [176, 301, 296, 457], "vertical": true, "font_size": 23, "lines_coords": [[[275.0, 301.0], [296.0, 301.0], [296.0, 432.0], [275.0, 432.0]], [[240.0, 306.0], [267.0, 306.0], [267.0, 409.0], [240.0, 409.0]], [[206.0, 304.0], [232.0, 304.0], [235.0, 457.0], [209.0, 457.0]], [[176.0, 306.0], [203.0, 306.0], [203.0, 418.0], [176.0, 418.0]]], "lines": ["こんなもん", "あんたに", "くれてやるっ", "つーの"]}, {"box": [876, 628, 943, 714], "vertical": true, "font_size": 37, "lines_coords": [[[904.0, 628.0], [943.0, 628.0], [943.0, 714.0], [904.0, 714.0]], [[876.0, 629.0], [911.0, 629.0], [911.0, 712.0], [876.0, 712.0]]], "lines": ["えっ！？", "えっ！？"]}, {"box": [807, 937, 959, 1117], "vertical": true, "font_size": 25, "lines_coords": [[[933.0, 940.0], [959.0, 940.0], [959.0, 1076.0], [933.0, 1076.0]], [[903.0, 940.0], [925.0, 940.0], [925.0, 1092.0], [903.0, 1092.0]], [[868.0, 939.0], [895.0, 939.0], [893.0, 1115.0], [867.0, 1115.0]], [[836.0, 937.0], [862.0, 937.0], [864.0, 1117.0], [837.0, 1117.0]], [[807.0, 942.0], [829.0, 942.0], [829.0, 1098.0], [807.0, 1098.0]]], "lines": ["その日の朝、", "通学路の途中", "あのタンポポが", "綿毛を飛ばして", "いるのを見た。"]}, {"box": [210, 768, 273, 937], "vertical": true, "font_size": 26, "lines_coords": [[[242.0, 770.0], [268.0, 770.0], [273.0, 937.0], [246.0, 937.0]], [[210.0, 768.0], [237.0, 768.0], [240.0, 910.0], [214.0, 910.0]]], "lines": ["ホラ、さっさと", "学校行くよ。"]}, {"box": [779, 1198, 839, 1325], "vertical": true, "font_size": 25, "lines_coords": [[[812.0, 1198.0], [839.0, 1198.0], [839.0, 1325.0], [812.0, 1325.0]], [[779.0, 1200.0], [806.0, 1200.0], [806.0, 1301.0], [779.0, 1301.0]]], "lines": ["気がつくと", "カラスは"]}, {"box": [748, 1198, 839, 1335], "vertical": true, "font_size": 27, "lines_coords": [[[748.0, 1198.0], [775.0, 1198.0], [775.0, 13