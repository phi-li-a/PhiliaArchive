165, 348, 286, 554], "vertical": true, "font_size": 27, "lines_coords": [[[254.0, 348.0], [286.0, 348.0], [286.0, 543.0], [254.0, 543.0]], [[225.0, 348.0], [251.0, 348.0], [253.0, 531.0], [226.0, 531.0]], [[192.0, 348.0], [220.0, 348.0], [223.0, 554.0], [195.0, 554.0]], [[165.0, 351.0], [187.0, 351.0], [187.0, 489.0], [165.0, 489.0]]], "lines": ["だから、おまえを", "生かすも殺すも", "俺の気分次第って", "ワケなのな。"]}, {"box": [876, 851, 1000, 1029], "vertical": true, "font_size": 28, "lines_coords": [[[968.0, 851.0], [1000.0, 851.0], [1000.0, 909.0], [968.0, 909.0]], [[939.0, 854.0], [965.0, 854.0], [965.0, 1010.0], [939.0, 1010.0]], [[906.0, 851.0], [934.0, 851.0], [936.0, 1029.0], [908.0, 1029.0]], [[876.0, 853.0], [903.0, 853.0], [903.0, 993.0], [876.0, 993.0]]], "lines": ["ん？", "おまえの住所", "このマンション", "じゃねーな。"]}, {"box": [607, 848, 636, 954], "vertical": true, "font_size": 29, "lines_coords": [[[607.0, 848.0], [636.0, 848.0], [636.0, 954.0], [607.0, 954.0]]], "lines": ["あの．．．"]}, {"box": [178, 845, 276, 1018], "vertical": true, "font_size": 29, "lines_coords": [[[243.0, 845.0], [276.0, 845.0], [273.0, 993.0], [240.0, 993.0]], [[214.0, 850.0], [242.0, 850.0], [237.0, 1018.0], [209.0, 1018.0]], [[181.0, 851.0], [209.0, 851.0], [206.0, 957.0], [178.0, 957.0]]], "lines": ["ぐえ、しかも", "バッグの中から", "バイフか"]}, {"box": [121, 1026, 212, 1204], "vertical": true, "font_size": 29, "lines_coords": [[[185.0, 1026.0], [212.0, 1026.0], [212.0, 1131.0], [185.0, 1131.0]], [[151.0, 1026.0], [179.0, 1026.0], [181.0, 1204.0], [153.0, 1204.0]], [[121.0, 1028.0], [150.0, 1028.0], [150.0, 1143.0], [121.0, 1143.0]]], "lines": ["怖いねー", "最近の女子高生", "ってのは。"]}, {"box": [890, 1312, 989, 1468], "vertical": true, "font_size": 31, "lines_coords": [[[961.0, 1314.0], [989.0, 1314.0], [986.0, 1456.0], [958.0, 1456.0]], [[929.0, 1317.0], [956.0, 1317.0], [956.0, 1468.0], [929.0, 1468.0]], [[890.0, 1314.0], [928.0, 1312.0], [931.0, 1382.0], [893.0, 1384.0]]], "lines": ["じゃ、ここで", "何やってたん", "だよ。"]}, {"box": [121, 1303, 196, 1495], "vertical": true, "font_size": 32, "lines_coords": [[[164.0, 1303.0], [195.0, 1303.0], [195.0, 1490.0], [164.0, 1490.0]], [[121.0, 1304.0], [154.0, 1304.0], [154.0, 1398.0], [121.0, 1398.0]]], "lines": ["聞いてんのか。", "コラ！！"]}], "img_path": "subarashii_sekai_01_068.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [867, 131, 1028, 287], "vertical": true, "font_size": 28, "lines_coords": [[[995.0, 132.0], [1028.0, 132.0], [1028.0, 228.0], [995.0, 228.0]], [[965.0, 132.0], [993.0, 132.0], [990.0, 285.0], [962.0, 285.0]], [[933.0, 134.0], [959.0, 134.0], [959.0, 270.0], [933.0, 270.0]], [[900.0, 134.0], [926.0, 134.0], [926.0, 287.0], [900.0, 287.0]], [[867.0, 131.0], [893.0, 131.0], [897.0, 273.0], [870.0, 273.0]]], "lines": ["はっは。", "金髪ギャルの", "お嬢ちゃん、", "そうカリカリ", "すんなって。"]}, {"box": [126, 95, 251, 310], "vertical": true, "font_size": 27, "lines_coords": [[[221.0, 95.0], [250.0, 95.0], [251.0, 223.0], [223.0, 223.0]], [[189.0, 95.0], [217.0, 95.0], [220.0, 306.0], [192.0, 306.0]], [[162.0, 96.0], [184.0, 96.0], [184.0, 309.0], [162.0, 309.0]], [[126.0, 96.0], [154.0, 96.0], [154.0, 250.0], [126.0, 250.0]]], "lines": ["出会い系で", "援交相手探すより、", "よっぽど割りのいい", "バイトだぜ？"]}, {"box": [639, 631, 759, 859], "vertical": true, "font_size": 26, "lines_coords": [[[732.0, 631.0], [759.0, 631.0], [759.0, 859.0], [732.0, 859.0]], [[700.0, 631.0], [726.0, 631.0], [725.0, 859.0], [698.0, 859.0]], [[668.0, 631.0], [695.0, 631.0], [695.0, 837.0], [668.0, 837.0]], [[639.0, 632.0], [661.0, 632.0], [661.0, 784.0], [639.0, 784.0]]], "lines": ["考えようによっちゃ", "俺とおまえの出会いは", "メチャラッキーな", "ことなのよ？"]}, {"box": [379, 440, 407, 542], "vertical": true, "font_size": 27, "lines_coords": [[[379.0, 440.0], [406.0, 440.0], [406.0, 542.0], [379.0, 542.0]]], "lines": ["何それ？"]}, {"box": [150, 746, 178, 850], "vertical": true, "font_size": 28, "lines_coords": [[[150.0, 746.0], [178.0, 746.0], [178.0, 850.0], [150.0, 850.0]]], "lines": ["いいか？"]}, {"box": [882, 906, 970, 1096], "vertical": true, "font_size": 23, "lines_coords": [[[945.0, 909.0], [967.0, 909.0], [967.0, 1087.0], [945.0, 1087.0]], [[912.0, 906.0], [939.0, 906.0], [939.0, 1037.0], [912.0, 1037.0]], [[883.0, 909.0], [904.0, 909.0], [904.0, 1095.0], [883.0, 1095.0]]], "lines": ["これから１週間", "俺のことを", "手伝ってもらう。"]}, {"box": [162, 1146, 255, 1325], "vertical": true, "font_size": 26, "lines_coords": [[[229.0, 1151.0], [251.0, 1151.0], [251.0, 1325.0], [229.0, 1325.0]], [[193.0, 1148.0], [221.0, 1148.0], [223.0, 1292.0], [195.0, 1292.0]], [[162.0, 1146.0], [189.0, 1146.0], [189.0, 1251.0], [162.0, 1251.0]]], "lines": ["やってくれたら", "３０万出すぜ。", "どうだ？"]}], "img_path": "subarashii_sekai_01_069.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [404, 37, 643, 225], "vertical": false, "font_size": 50.833333333333336, "lines_coords": [[[412.0, 60.0], [440.0, 60.0], [440.0, 90.0], [412.0, 90.0]], [[429.0, 57.0], [592.0, 37.0], [598.0, 85.0], [436.0, 106.0]], [[476.0, 93.0], [615.0, 85.0], [617.0, 118.0], [478.0, 126.0]], [[404.0, 71.0], [626.0, 40.0], [643.0, 160.0], [421.0, 192.0]], [[429.0, 156.0], [614.0, 137.0], [618.0, 175.0], [434.0, 193.0]], [[450.0, 192.0], [603.0, 173.0], [607.0, 206.0], [454.0, 225.0]]], "lines": ["買って", "買ってくるものリスト．．．オレギリーだくと", "にぎりーたくさん", "言ってくるものリスト・あたぎりったくさん．．．わがパートくらしいでしょうか", "・カッパーたくん．．．おかしったくさんが", "おめしました．．．かいちゃうでしょー"]}, {"box": [487, 204, 642, 257], "vertical": false, "font_size": 33, "lines_coords": [[[487.0, 225.0], [637.0, 204.0], [642.0, 237.0], [492.0, 257.0]]], "lines": ["江ビアンサたくさん"]}, {"box": [590, 287, 673, 326], "vertical": false, "font_size": 24, "lines_coords": [[[590.0, 303.0], [668.0, 287.0], [673.0, 310.0], [595.0, 326.0]]], "lines": ["つの店で"]}, {"box": [826, 404, 895, 558], "vertical": true, "font_size": 30, "lines_coords": [[[862.0, 404.0], [895.0, 404.0], [895.0, 528.0], [862.0, 528.0]], [[826.0, 406.0], [854.0, 406.0], [854.0, 518.0], [826.0, 518.0]]], "lines": ["ありやと", "やしたー"]}, {"box": [678, 854, 775, 1054], "vertical": true, "font_size": 67, "lines_coords": [[[697.0, 854.0], [764.0, 860.0], [745.0, 1054.0], [678.0, 1048.0]]], "lines": ["ガチャ"]}], "img_path": "subarashii_sekai_01_070.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [603, 109, 693, 287], "vertical": true, "font_size": 26, "lines_coords": [[[665.0, 109.0], [692.0, 109.0], [692.0, 217.0], [665.0, 217.0]], [[631.0, 109.0], [659.0, 109.0], [659.0, 212.0], [631.0, 212.0]], [[603.0, 110.0], [625.0, 110.0], [625.0, 287.0], [603.0, 287.0]]], "lines": ["兄ちゃん、", "この男に", "見覚えないか？"]}, {"box": [184, 101, 245, 293], "vertical": true, "font_size": 27, "lines_coords": [[[218.0, 104.0], [245.0, 104.0], [245.0, 279.0], [218.0, 279.0]], [[184.0, 101.0], [210.0, 101.0], [212.0, 293.0], [185.0, 293.0]]], "lines": ["っさぁー．．．．．．", "見てないスねぇ。"]}, {"box": [168, 410, 228, 587], "vertical": true, "font_size": 24, "lines_coords": [[[206.0, 548.0], [223.0, 548.0], [223.0, 584.0], [206.0, 584.0]], [[201.0, 410.0], [228.0, 410.0], [225.0, 537.0], [198.0, 537.0]], [[168.0, 410.0], [195.0, 410.0], [195.0, 550.0], [168.0, 550.0]]], "lines": ["？", "ホントかー", "兄ちゃーん。"]}, {"box": [784, 782, 942, 972], "vertical": true, "font_size": 28, "lines_coords": [[[909.0, 782.0], [942.0, 782.0], [942.0, 890.0], [909.0, 890.0]], [[876.0, 784.0], [904.0, 784.0], [908.0, 910.0], [879.0, 910.0]], [[848.0, 785.0], [870.0, 785.0], [870.0, 968.0], [848.0, 968.0]], [[815.0, 785.0], [842.0, 785.0], [842.0, 889.0], [815.0, 889.0]], [[784.0, 785.0], [811.0, 785.0], [811.0, 887.0], [784.0, 887.0]]], "lines": ["兄ちゃん", "がんばって", "思い出さないと、", "あとあと", "怖いよー"]}, {"box": [210, 945, 337, 1126], "vertical": true, "font_size": 31, "lines_coords": [[[301.0, 948.0], [334.0, 946.0], [337.0, 1053.0], [304.0, 1054.0]], [[270.0, 946.0], [304.0, 946.0], [304.0, 1039.0], [270.0, 1039.0]], [[240.0, 946.0], [268.0, 946.0], [270.0, 1100.0], [242.0, 1100.0]], [[210.0, 945.0], [237.0, 945.0], [237.0, 1082.0], [210.0, 1082.0]]], "lines": ["いや、もー", "ホント、", "カンベンして", "くださいよ"]}, {"box": [148, 1312, 232, 1470], "vertical": true, "font_size": 22, "lines_coords": [[[206.0, 1312.0], [232.0, 1312.0], [232.0, 1407.0], [206.0, 1407.0]], [[176.0, 1312.0], [203.0, 1312.0], [203.0, 1418.0], [176.0, 1418.0]], [[148.0, 1314.0], [170.0, 1314.0], [170.0, 1470.0], [148.0, 1470.0]]], "lines": ["オーケー", "オーケー", "ごくろうさん、"]}, {"box": [184, 1421, 196, 1437], "vertical": true, "font_size": 22, "lines_coords": [[[184.0, 1421.0], [196.0, 1421.0], [196.0, 1437.0], [184.0, 1437.0]]], "lines": ["．．．"]}], "img_path": "subarashii_sekai_01_071.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [873, 110, 1002, 315], "vertical": true, "font_size": 28, "lines_coords": [[[975.0, 114.0], [1001.0, 114.0], [1001.0, 279.0], [975.0, 279.0]], [[942.0, 112.0], [968.0, 112.0], [968.0, 315.0], [942.0, 315.0]], [[909.0, 112.0], [936.0, 112.0], [936.0, 315.0], [909.0, 315.0]], [[873.0, 112.0], [906.0, 110.0], [909.0, 200.0], [876.0, 201.0]]], "lines": ["つーか、おまえ", "逃げようと思えば", "いつでも逃げられた", "のにな。"]}, {"box": [140, 75, 232, 290], "vertical": true, "font_size": 25, "lines_coords": [[[207.0, 78.0], [229.0, 78.0], [229.0, 228.0], [207.0, 228.0]], [[170.0, 75.0], [196.0, 75.0], [200.0, 179.0], [173.0, 179.0]], [[140.0, 76.0], [167.0, 76.0], [171.0, 289.0], [145.0, 289.0]]], "lines": ["もらえんなら", "もらうに", "決まってんじゃん。"]}, {"box": [668, 493, 759, 620], "vertical": true, "font_size": 28, "lines_coords": [[[732.0, 495.0], [759.0, 495.0], [756.0, 595.0], [729.0, 595.0]], [[701.0, 495.0], [728.0, 495.0], [728.0, 620.0], [701.0, 620.0]], [[668.0, 493.0], [697.0, 493.0], [697.0, 573.0], [668.0, 573.0]]], "lines": ["そんなに", "金が欲しい", "ワケ？"]}, {"box": [153, 442, 177, 569], "vertical": true, "font_size": 22, "lines_coords": [[[153.0, 442.0], [175.0, 442.0], [175.0, 568.0], [153.0, 568.0]]], "lines": ["なんでよ？"]}, {"box": [229, 717, 351, 823], "vertical": true, "font_size": 28, "lines_coords": [[[323.0, 720.0], [351.0, 720.0], [351.0, 823.0], [323.0, 823.0]], [[289.0, 717.0], [323.0, 717.0], [323.0, 809.0], [289.0, 809.0]], [[259.0, 720.0], [287.0, 720.0], [287.0, 821.0], [259.0, 821.0]], [[229.0, 721.0], [257.0, 721.0], [257.0, 807.0], [229.0, 807.0]]], "lines": ["だんまり", "ですか。", "別にいい", "けどね。"]}, {"box": [879, 975, 1034, 1179], "vertical": true, "font_size": 26, "lines_coords": [[[1004.0, 975.0], [1033.0, 975.0], [1034.0, 1106.0], [1006.0, 1106.0]], [[978.0, 979.0], [1000.0, 979.0], [1000.0, 1157.0], [978.0, 1157.0]], [[943.0, 978.0], [970.0, 978.0], [970.0, 1103.0], [943.0, 1103.0]], [[909.0, 975.0], [940.0, 975.0], [940.0, 1179.0], [909.0, 1179.0]], [[879.0, 978.0], [901.0, 978.0], [901.0, 1175.0], [879.0, 1175.0]]], "lines": ["あんたこそ", "ナニモンなのか、", "少しくらい", "教えてくれたって", "いいんじゃない？"]}, {"box": [170, 820, 264, 1018], "vertical": true, "font_size": 28, "lines_coords": [[[237.0, 820.0], [264.0, 820.0], [264.0, 1018.0], [237.0, 1018.0]], [[201.0, 839.0], [228.0, 839.0], [231.0, 978.0], [204.0, 978.0]], [[170.0, 839.0], [196.0, 839.0], [200.0, 956.0], [173.0, 956.0]]], "lines": ["フツー誰だって", "欲しいわな、", "金なんて。"]}, {"box": [964, 1265, 990, 1431], "vertical": true, "font_size": 22, "lines_coords": [[[965.0, 1265.0], [987.0, 1265.0], [987.0, 1429.0], [965.0, 1429.0]]], "lines": ["そりゃ無理だ。"]}, {"box": [470, 1248, 595, 1426], "vertical": true, "font_size": 26, "lines_coords": [[[567.0, 1251.0], [593.0, 1251.0], [593.0, 1426.0], [567.0, 1426.0]], [[534.0, 1251.0], [561.0, 1251.0], [561.0, 1412.0], [534.0, 1412.0]], [[503.0, 1250.0], [529.0, 1250.0], [529.0, 1379.0], [503.0, 1379.0]], [[470.0, 1248.0], [496.0, 1248.0], [500.0, 1367.0], [473.0, 1367.0]]], "lines": ["なんせ俺の命が", "かかってんだ、", "減多なこと", "言えねぇ。"]}, {"box": [253, 1181, 281, 1300], "vertical": true, "font_size": 27, "lines_coords": [[[253.0, 1181.0], [281.0, 1181.0], [281.0, 1300.0], [253.0, 1300.0]]], "lines": ["命ねぇ．．．"]}, {"box": [140, 1315, 235, 1482], "vertical": true, "font_size": 27, "lines_coords": [[[209.0, 1317.0], [235.0, 1317.0], [235.0, 1479.0], [209.0, 1479.0]], [[178.0, 1320.0], [200.0, 1320.0], [200.0, 1482.0], [178.0, 1482.0]], [[140.0, 1315.0], [173.0, 1315.0], [173.0, 1409.0], [140.0, 1409.0]]], "lines": ["じゃあやっぱ", "あんた、狙われ", "てんだ。"]}], "img_path": "subarashii_sekai_01_072.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [861, 125, 903, 207], "vertical": true, "font_size": 42, "lines_coords": [[[861.0, 125.0], [903.0, 125.0], [903.0, 207.0], [861.0, 207.0]]], "lines": ["ぐえ。"]}, {"box": [232, 114, 287, 264], "vertical": true, "font_size": 26, "lines_coords": [[[265.0, 117.0], [287.0, 117.0], [287.0, 264.0], [265.0, 264.0]], [[232.0, 114.0], [259.0, 114.0], [259.0, 228.0], [232.0, 228.0]]], "lines": ["なんとなーく", "わかった。"]}, {"box": [143, 281, 201, 393], "vertical": true, "font_size": 26, "lines_coords": [[[175.0, 282.0], [201.0, 282.0], [201.0, 390.0], [175.0, 390.0]], [[143.0, 281.0], [170.0, 281.0], [170.0, 393.0], [143.0, 393.0]]], "lines": ["大変だね、", "あんたも。"]}, {"box": [898, 542, 962, 680], "vertical": true, "font_size": 29, "lines_coords": [[[926.0, 542.0], [962.0, 542.0], [962.0, 609.0], [926.0, 609.0]], [[898.0, 543.0], [920.0, 543.0], [920.0, 678.0], [898.0, 678.0]]], "lines": ["へっ、", "まぁいいさ。"]}, {"box": [296, 518, 390, 696], "vertical": true, "font_size": 26, "lines_coords": [[[357.0, 518.0], [390.0, 518.0], [390.0, 600.0], [357.0, 600.0]], [[328.0, 518.0], [354.0, 518.0], [354.0, 696.0], [328.0, 696.0]], [[296.0, 518.0], [323.0, 518.0], [323.0, 631.0], [296.0, 631.0]]], "lines": ["明日は", "逃げる車の準備", "だからな。"]}, {"box": [185, 645, 239, 798], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 645.0], [239.0, 645.0], [239.0, 773.0], [217.0, 773.0]], [[185.0, 646.0], [207.0, 646.0], [207.0, 798.0], [185.0, 798.0]]], "lines": ["今日はもう", "食って寝ろ！"]}, {"box": [592, 1092, 625, 1189], "vertical": true, "font_size": 33, "lines_coords": [[[592.0, 1092.0], [625.0, 1092.0], [625.0, 1187.0], [592.0, 1187.0]]], "lines": ["スピード"]}, {"box": [270, 868, 429, 1075], "vertical": true, "font_size": 28, "lines_coords": [[[392.0, 896.0], [423.0, 893.0], [429.0, 956.0], [398.0, 959.0]], [[365.0, 870.0], [393.0, 870.0], [390.0, 975.0], [362.0, 975.0]], [[334.0, 870.0], [361.0, 870.0], [361.0, 1075.0], [334.0, 1075.0]], [[301.0, 870.0], [328.0, 870.0], [328.0, 1006.0], [301.0, 1006.0]], [[270.0, 868.0], [296.0, 868.0], [296.0, 1048.0], [270.0, 1048.0]]], "lines": ["ーで、", "おまえは", "ツナマヨネーズと", "しそわかめ、", "どっちが好き？"]}, {"box": [115, 1251, 187, 1414], "vertical": true, "font_size": 20, "lines_coords": [[[167.0, 1251.0], [187.0, 1251.0], [187.0, 1395.0], [167.0, 1395.0]], [[139.0, 1253.0], [159.0, 1253.0], [159.0, 1414.0], [139.0, 1414.0]], [[115.0, 1253.0], [132.0, 1253.0], [132.0, 1364.0], [115.0, 1364.0]]], "lines": ["．．．．．．妖怪戦争は", "ムリがあるでしょ", "．．．．．．たはっ。"]}, {"box": [148, 1462, 171, 1528], "vertical": true, "font_size": 20, "lines_coords": [[[148.0, 1462.0], [171.0, 1462.0], [171.0, 1528.0], [148.0, 1528.0]]], "lines": ["クゥ。"]}], "img_path": "subarashii_sekai_01_073.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [834, 1070, 964, 1248], "vertical": true, "font_size": 29, "lines_coords": [[[929.0, 1070.0], [964.0, 1070.0], [964.0, 1164.0], [929.0, 1164.0]], [[900.0, 1073.0], [926.0, 1073.0], [926.0, 1248.0], [900.0, 1248.0]], [[865.0, 1070.0], [892.0, 1070.0], [895.0, 1231.0], [868.0, 1231.0]], [[837.0, 1070.0], [865.0, 1070.0], [862.0, 1184.0], [834.0, 1184.0]]], "lines": ["ははっ、", "カギのスペアも", "手に入ったし、", "順調順調。"]}, {"box": [165, 1171, 353, 1499], "vertical": true, "font_size": 30, "lines_coords": [[[315.0, 1171.0], [353.0, 1171.0], [353.0, 1229.0], [315.0, 1229.0]], [[289.0, 1175.0], [315.0, 1175.0], [315.0, 1331.0], [289.0, 1331.0]], [[256.0, 1175.0], [282.0, 1175.0], [282.0, 1339.0], [256.0, 1339.0]], [[229.0, 1326.0], [262.0, 1326.0], [262.0, 1412.0], [229.0, 1412.0]], [[200.0, 1332.0], [228.0, 1332.0], [228.0, 1445.0], [200.0, 1445.0]], [[168.0, 1331.0], [195.0, 1331.0], [192.0, 1498.0], [165.0, 1498.0]]], "lines": ["この", "隠遁生活にも", "オサラバだな。", "どこに", "行くかな、", "北か？南か？"]}], "img_path": "subarashii_sekai_01_074.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [873, 123, 967, 313], "vertical": true, "font_size": 27, "lines_coords": [[[936.0, 125.0], [964.0, 125.0], [967.0, 293.0], [939.0, 293.0]], [[904.0, 125.0], [931.0, 125.0], [934.0, 312.0], [908.0, 312.0]], [[873.0, 123.0], [900.0, 123.0], [903.0, 237.0], [876.0, 237.0]]], "lines": ["しかし、おまえ", "怖くないのかよ、", "この状況。"]}, {"box": [309, 87, 378, 257], "vertical": true, "font_size": 27, "lines_coords": [[[339.0, 87.0], [378.0, 87.0], [378.0, 173.0], [339.0, 173.0]], [[309.0, 89.0], [337.0, 89.0], [340.0, 257.0], [312.0, 257.0]]], "lines": ["だって", "考えてみろよ。"]}, {"box": [153, 209, 301, 410], "vertical": true, "font_size": 27, "lines_coords": [[[279.0, 212.0], [301.0, 212.0], [301.0, 362.0], [279.0, 362.0]], [[242.0, 209.0], [270.0, 209.0], [275.0, 400.0], [246.0, 400.0]], [[215.0, 210.0], [237.0, 210.0], [237.0, 410.0], [215.0, 410.0]], [[182.0, 212.0], [209.0, 212.0], [209.0, 340.0], [182.0, 340.0]], [[153.0, 210.0], [175.0, 210.0], [175.0, 389.0], [153.0, 389.0]]], "lines": ["用が済んだら", "おまえを殺して、", "さっさとトンズラ", "ってことも", "ありえんだぜ？"]}, {"box": [215, 571, 243, 671], "vertical": true, "font_size": 27, "lines_coords": [[[215.0, 571.0], [243.0, 571.0], [243.0, 671.0], [215.0, 671.0]]], "lines": ["別に．．．"]}, {"box": [196, 710, 284, 875], "vertical": true, "font_size": 27, "lines_coords": [[[257.0, 714.0], [284.0, 714.0], [284.0, 868.0], [257.0, 868.0]], [[221.0, 712.0], [251.0, 710.0], [254.0, 792.0], [225.0, 793.0]], [[196.0, 717.0], [218.0, 717.0], [218.0, 875.0], [196.0, 875.0]]], "lines": ["そうなったら", "そうで", "がまわないし。"]}, {"box": [917, 1121, 947, 1179], "vertical": true, "font_size": 30, "lines_coords": [[[917.0, 1121.0], [947.0, 1121.0], [947.0, 1179.0], [917.0, 1179.0]]], "lines": ["え？"]}, {"box": [482, 1115, 546, 1268], "vertical": true, "font_size": 34, "lines_coords": [[[517.0, 1118.0], [543.0, 1118.0], [543.0, 1268.0], [517.0, 1268.0]], [[482.0, 1115.0], [523.0, 1115.0], [523.0, 1164.0], [482.0, 1164.0]]], "lines": ["なんでもない", "よ。"]}, {"box": [110, 1071, 234, 1237], "vertical": true, "font_size": 27, "lines_coords": [[[204.0, 1073.0], [232.0, 1073.0], [232.0, 1185.0], [204.0, 1185.0]], [[175.0, 1071.0], [201.0, 1071.0], [201.0, 1203.0], [175.0, 1203.0]], [[140.0, 1071.0], [167.0, 1071.0], [170.0, 1187.0], [143.0, 1187.0]], [[110.0, 1071.0], [137.0, 1071.0], [137.0, 1237.0], [110.0, 1237.0]]], "lines": ["おいおい、", "もっと執着", "しようぜ。", "生きることに。"]}, {"box": [107, 1354, 232, 1520], "vertical": true, "font_size": 29, "lines_coords": [[[200.0, 1357.0], [232.0, 1357.0], [232.0, 1439.0], [200.0, 1439.0]], [[173.0, 1360.0], [195.0, 1360.0], [195.0, 1515.0], [173.0, 1515.0]], [[135.0, 1354.0], [170.0, 1354.0], [170.0, 1437.0], [135.0, 1437.0]], [[107.0, 1357.0], [134.0, 1357.0], [134.0, 1517.0], [107.0, 1517.0]]], "lines": ["ホント", "わかんねーわ、", "最近の", "ガキってのは。"]}], "img_path": "subarashii_sekai_01_075.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [815, 85, 970, 262], "vertical": true, "font_size": 27, "lines_coords": [[[943.0, 87.0], [970.0, 87.0], [970.0, 225.0], [943.0, 225.0]], [[909.0, 85.0], [940.0, 85.0], [940.0, 251.0], [909.0, 251.0]], [[878.0, 87.0], [904.0, 87.0], [904.0, 212.0], [878.0, 212.0]], [[847.0, 85.0], [873.0, 85.0], [873.0, 262.0], [847.0, 262.0]], [[815.0, 85.0], [842.0, 85.0], [842.0, 193.0], [815.0, 193.0]]], "lines": ["援交やって、", "クスリやって、", "ホームレス", "ボコボコに殴り", "まわして、"]}, {"box": [689, 282, 843, 448], "vertical": true, "font_size": 27, "lines_coords": [[[811.0, 284.0], [843.0, 284.0], [843.0, 367.0], [811.0, 367.0]], [[776.0, 282.0], [809.0, 282.0], [809.0, 439.0], [776.0, 439.0]], [[750.0, 285.0], [776.0, 285.0], [776.0, 392.0], [750.0, 392.0]], [[720.0, 287.0], [742.0, 287.0], [742.0, 410.0], [720.0, 410.0]], [[689.0, 285.0], [711.0, 285.0], [711.0, 448.0], [689.0, 448.0]]], "lines": ["最高に", "楽しいんじゃ", "ねぇの？", "おまえらの", "年頃なんてよ。"]}, {"box": [150, 98, 240, 274], "vertical": true, "font_size": 23, "lines_coords": [[[210.0, 98.0], [237.0, 98.0], [237.0, 226.0], [210.0, 226.0]], [[181.0, 100.0], [203.0, 100.0], [203.0, 273.0], [181.0, 273.0]], [[150.0, 100.0], [171.0, 100.0], [171.0, 195.0], [150.0, 195.0]]], "lines": ["それが案外", "そうでもないん", "だよねー"]}, {"box": [442, 387, 567, 577], "vertical": true, "font_size": 25, "lines_coords": [[[540.0, 392.0], [562.0, 392.0], [562.0, 540.0], [540.0, 540.0]], [[507.0, 389.0], [534.0, 389.0], [532.0, 575.0], [506.0, 575.0]], [[475.0, 392.0], [501.0, 392.0], [501.0, 568.0], [475.0, 568.0]], [[445.0, 387.0], [471.0, 387.0], [468.0, 543.0], [442.0, 543.0]]], "lines": ["好きほうだい", "やってるくせに、", "一人前に悩みも", "あるってか？"]}, {"box": [840, 1071, 962, 1301], "vertical": true, "font_size": 26, "lines_coords": [[[936.0, 1073.0], [962.0, 1073.0], [962.0, 1251.0], [936.0, 1251.0]], [[903.0, 1075.0], [929.0, 1075.0], [928.0, 1300.0], [901.0, 1300.0]], [[870.0, 1071.0], [897.0, 1071.0], [897.0, 1301.0], [870.0, 1301.0]], [[840.0, 1073.0], [867.0, 1073.0], [867.0, 1237.0], [840.0, 1237.0]]], "lines": ["あたしの友達で", "自分の親と同い年の", "先生とつき合ってる", "コがいるんだ。"]}, {"box": [276, 746, 368, 917], "vertical": true, "font_size": 27, "lines_coords": [[[331.0, 748.0], [364.0, 746.0], [368.0, 842.0], [336.0, 843.0]], [[304.0, 751.0], [331.0, 751.0], [334.0, 909.0], [307.0, 909.0]], [[276.0, 751.0], [298.0, 751.0], [300.0, 917.0], [278.0, 917.0]]], "lines": ["そうだ。", "おもしろい話", "してあげるよ。"]}, {"box": [718, 1245, 839, 1462], "vertical": true, "font_size": 26, "lines_coords": [[[817.0, 1246.0], [839.0, 1246.0], [839.0, 1348.0], [817.0, 1348.0]], [[781.0, 1245.0], [807.0, 1245.0], [811.0, 1462.0], [784.0, 1462.0]], [[751.0, 1248.0], [778.0, 1248.0], [778.0, 1428.0], [751.0, 1428.0]], [[718.0, 1246.0], [745.0, 1246.0], [745.0, 1435.0], [718.0, 1435.0]]], "lines": ["まんまと", "子供できちゃって、", "もちろん相手は", "妻子持ちなワケ。"]}, {"box": [123, 1254, 276, 1496], "vertical": true, "font_size": 26, "lines_coords": [[[248.0, 1254.0], [275.0, 1254.0], [275.0, 1393.0], [248.0, 1393.0]], [[215.0, 1254.0], [242.0, 1254.0], [242.0, 1495.0], [215.0, 1495.0]], [[182.0, 1254.0], [209.0, 1254.0], [209.0, 1460.0], [182.0, 1460.0]], [[151.0, 1254.0], [178.0, 1254.0], [178.0, 1434.0], [151.0, 1434.0]], [[123.0, 1257.0], [145.0, 1257.0], [145.0, 1412.0], [123.0, 1412.0]]], "lines": ["でもそのコ、", "怖くて言い出せなくて", "先生の部屋の前を", "行ったり来たり", "しちゃってさ。"]}], "img_path": "subarashii_sekai_01_076.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [842, 89, 996, 320], "vertical": true, "font_size": 26, "lines_coords": [[[968.0, 89.0], [995.0, 89.0], [995.0, 293.0], [968.0, 293.0]], [[936.0, 90.0], [962.0, 90.0], [962.0, 320.0], [936.0, 320.0]], [[904.0, 90.0], [931.0, 90.0], [931.0, 307.0], [904.0, 307.0]], [[875.0, 90.0], [897.0, 90.0], [897.0, 268.0], [875.0, 268.0]], [[842.0, 90.0], [868.0, 90.0], [868.0, 268.0], [842.0, 268.0]]], "lines": ["「どうしよー」って", "あれこれ考えてる間", "にも、お腹の子供は", "どんどん大きく", "なってって．．．"]}, {"box": [514, 303, 640, 493], "vertical": true, "font_size": 29, "lines_coords": [[[606.0, 303.0], [640.0, 303.0], [640.0, 396.0], [606.0, 396.0]], [[576.0, 304.0], [604.0, 304.0], [601.0, 459.0], [573.0, 459.0]], [[545.0, 306.0], [573.0, 306.0], [570.0, 489.0], [542.0, 489.0]], [[517.0, 304.0], [542.0, 304.0], [539.0, 457.0], [514.0, 457.0]]], "lines": ["じゃあ、", "いっそのこと", "バレないうちに、", "．．．ってか？"]}, {"box": [126, 93, 215, 234], "vertical": true, "font_size": 26, "lines_coords": [[[193.0, 96.0], [215.0, 96.0], [215.0, 234.0], [193.0, 234.0]], [[159.0, 93.0], [185.0, 93.0], [185.0, 196.0], [159.0, 196.0]], [[126.0, 96.0], [154.0, 96.0], [154.0, 182.0], [126.0, 182.0]]], "lines": ["まー、それも", "考えてる", "かもね。"]}, {"box": [832, 689, 925, 817], "vertical": true, "font_size": 27, "lines_coords": [[[897.0, 689.0], [925.0, 689.0], [925.0, 792.0], [897.0, 792.0]], [[865.0, 690.0], [892.0, 690.0], [892.0, 817.0], [865.0, 817.0]], [[832.0, 689.0], [859.0, 689.0], [859.0, 779.0], [832.0, 779.0]]], "lines": ["．．．．．．全然", "おもしろく", "ねーよ。"]}, {"box": [110, 285, 262, 540], "vertical": true, "font_size": 26, "lines_coords": [[[235.0, 285.0], [262.0, 285.0], [262.0, 476.0], [235.0, 476.0]], [[204.0, 287.0], [232.0, 287.0], [234.0, 451.0], [206.0, 451.0]], [[175.0, 289.0], [201.0, 289.0], [201.0, 540.0], [175.0, 540.0]], [[142.0, 289.0], [168.0, 289.0], [168.0, 492.0], [142.0, 492.0]], [[110.0, 287.0], [137.0, 287.0], [137.0, 378.0], [110.0, 378.0]]], "lines": ["とにかく、かなり", "キちゃってて、", "手首切っちゃったりで", "大騒ぎになったり", "してさ。"]}, {"box": [270, 700, 337, 790], "vertical": true, "font_size": 30, "lines_coords": [[[301.0, 700.0], [337.0, 700.0], [337.0, 768.0], [301.0, 768.0]], [[270.0, 700.0], [303.0, 700.0], [303.0, 790.0], [270.0, 790.0]]], "lines": ["はは、", "ですね。"]}, {"box": [115, 792, 275, 1014], "vertical": true, "font_size": 30, "lines_coords": [[[245.0, 793.0], [275.0, 793.0], [275.0, 860.0], [245.0, 860.0]], [[214.0, 792.0], [242.0, 792.0], [237.0, 935.0], [209.0, 935.0]], [[181.0, 796.0], [209.0, 796.0], [206.0, 925.0], [178.0, 925.0]], [[150.0, 796.0], [176.0, 796.0], [176.0, 1014.0], [150.0, 1014.0]], [[118.0, 796.0], [145.0, 796.0], [142.0, 934.0], [115.0, 934.0]]], "lines": ["まぁ、", "「いまどきの", "女子高生の", "意外と純情な素顔」", "ってことで。"]}, {"box": [267, 1178, 359, 1284], "vertical": true, "font_size": 29, "lines_coords": [[[326.0, 1179.0], [359.0, 1179.0], [359.0, 1284.0], [326.0, 1284.0]], [[293.0, 1178.0], [326.0, 1179.0], [323.0, 1284.0], [290.0, 1282.0]], [[267.0, 1181.0], [289.0, 1181.0], [289.0, 1257.0], [267.0, 1257.0]]], "lines": ["へっ．．．", "なーにが", "．．．？？"]}, {"box": [79, 1368, 239, 1560], "vertical": true, "font_size": 30, "lines_coords": [[[206.0, 1368.0], [239.0, 1368.0], [239.0, 1451.0], [206.0, 1451.0]], [[178.0, 1370.0], [206.0, 1370.0], [206.0, 1520.0], [178.0, 1520.0]], [[150.0, 1371.0], [171.0, 1371.0], [171.0, 1560.0], [150.0, 1560.0]], [[112.0, 1368.0], [143.0, 1368.0], [143.0, 1546.0], [112.0, 1546.0]], [[79.0, 1368.0], [114.0, 1368.0], [114.0, 1446.0], [79.0, 1446.0]]], "lines": ["あんな", "トラックじゃ", "すぐアシがつくに", "決まってんじゃ", "ない！！"]}], "img_path": "subarashii_sekai_01_077.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [883, 95, 1003, 298], "vertical": true, "font_size": 29, "lines_coords": [[[981.0, 100.0], [1003.0, 100.0], [1003.0, 298.0], [981.0, 298.0]], [[948.0, 98.0], [976.0, 98.0], [972.0, 253.0], [943.0, 253.0]], [[909.0, 95.0], [951.0, 95.0], [951.0, 160.0], [909.0, 160.0]], [[887.0, 100.0], [915.0, 100.0], [911.0, 275.0], [883.0, 275.0]]], "lines": ["トラックはすぐに", "乗り捨てる！", "ナニ、", "大丈夫だって！"]}, {"box": [229, 218, 286, 368], "vertical": true, "font_size": 28, "lines_coords": [[[265.0, 221.0], [286.0, 221.0], [286.0, 368.0], [265.0, 368.0]], [[229.0, 218.0], [257.0, 218.0], [259.0, 321.0], [231.0, 321.0]]], "lines": ["５年は遊べる", "金だぜ！？"]}, {"box": [856, 326, 950, 479], "vertical": true, "font_size": 29, "lines_coords": [[[914.0, 326.0], [950.0, 326.0], [950.0, 385.0], [914.0, 385.0]], [[887.0, 329.0], [914.0, 329.0], [914.0, 456.0], [887.0, 456.0]], [[856.0, 331.0], [878.0, 331.0], [878.0, 479.0], [856.0, 479.0]]], "lines": ["俺に", "任せときゃ", "上手くいく！"]}, {"box": [879, 615, 1001, 840], "vertical": true, "font_size": 24, "lines_coords": [[[976.0, 615.0], [1001.0, 615.0], [998.0, 770.0], [973.0, 770.0]], [[945.0, 618.0], [967.0, 618.0], [967.0, 840.0], [945.0, 840.0]], [[909.0, 615.0], [936.0, 615.0], [937.0, 818.0], [911.0, 818.0]], [[879.0, 615.0], [901.0, 615.0], [903.0, 818.0], [881.0, 818.0]]], "lines": ["だってあんた", "組の金に手ぇ付けて", "生きて逃げられる", "ワケないじゃん！！"]}, {"box": [153, 395, 217, 550], "vertical": true, "font_size": 28, "lines_coords": [[[182.0, 395.0], [217.0, 395.0], [217.0, 476.0], [182.0, 476.0]], [[153.0, 395.0], [179.0, 395.0], [182.0, 550.0], [156.0, 550.0]]], "lines": ["へマは", "しないって！！"]}, {"box": [146, 654, 239, 782], "vertical": true, "font_size": 30, "lines_coords": [[[203.0, 654.0], [239.0, 654.0], [239.0, 735.0], [203.0, 735.0]], [[176.0, 657.0], [204.0, 657.0], [204.0, 760.0], [176.0, 760.0]], [[146.0, 656.0], [173.0, 656.0], [173.0, 782.0], [146.0, 782.0]]], "lines": ["それに", "お腹の子", "だって．．．"]}, {"box": [767, 734, 823, 885], "vertical": true, "font_size": 24, "lines_coords": [[[795.0, 734.0], [823.0, 734.0], [823.0, 839.0], [795.0, 839.0]], [[767.0, 735.0], [789.0, 735.0], [789.0, 885.0], [767.0, 885.0]]], "lines": ["ぁいつら", "フロでしょ！？"]}, {"box": [951, 956, 978, 1082], "vertical": true, "font_size": 27, "lines_coords": [[[951.0, 956.0], [978.0, 956.0], [978.0, 1082.0], [951.0, 1082.0]]], "lines": ["だ・か・ら！！"]}, {"box": [626, 1081, 667, 1157], "vertical": true, "font_size": 29, "lines_coords": [[[626.0, 1081.0], [667.0, 1081.0], [667.0, 1157.0], [626.0, 1157.0]]], "lines": ["な！？"]}, {"box": [831, 1109, 986, 1315], "vertical": true, "font_size": 27, "lines_coords": [[[959.0, 1109.0], [986.0, 1109.0], [986.0, 1239.0], [959.0, 1239.0]], [[928.0, 1112.0], [954.0, 1112.0], [954.0, 1215.0], [928.0, 1215.0]], [[895.0, 1112.0], [922.0, 1112.0], [922.0, 1267.0], [895.0, 1267.0]], [[864.0, 1112.0], [892.0, 1112.0], [892.0, 1220.0], [864.0, 1220.0]], [[832.0, 1114.0], [859.0, 1114.0], [858.0, 1315.0], [831.0, 1315.0]]], "lines": ["俺らの子の", "ためにも", "この世界から", "足洗って、", "やり直すんだよ！"]}, {"box": [567, 1203, 623, 1376], "vertical": true, "font_size": 29, "lines_coords": [[[601.0, 1204.0], [623.0, 1204.0], [623.0, 1376.0], [601.0, 1376.0]], [[568.0, 1203.0], [592.0, 1203.0], [590.0, 1354.0], [567.0, 1354.0]]], "lines": ["俺といっしょに", "逃げようぜ！！"]}], "img_path": "subarashii_sekai_01_078.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [864, 813, 884, 936], "vertical": true, "font_size": 19, "lines_coords": [[[865.0, 814.0], [884.0, 814.0], [884.0, 934.0], [865.0, 934.0]]], "lines": ["おまえ．．．．．"]}, {"box": [218, 1001, 246, 1141], "vertical": true, "font_size": 22, "lines_coords": [[[218.0, 1007.0], [240.0, 1007.0], [240.0, 1134.0], [218.0, 1134.0]]], "lines": ["．．．．．．ごめん"]}], "img_path": "subarashii_sekai_01_079.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blo