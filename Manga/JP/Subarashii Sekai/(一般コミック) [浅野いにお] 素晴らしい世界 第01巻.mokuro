98, 1109, 909, 1426], "vertical": true, "font_size": 11, "lines_coords": [[[898.0, 1109.0], [909.0, 1109.0], [909.0, 1426.0], [898.0, 1426.0]]], "lines": ["．．．．．．"]}], "img_path": "subarashii_sekai_01_036.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [862, 138, 951, 314], "vertical": true, "font_size": 24, "lines_coords": [[[923.0, 139.0], [951.0, 139.0], [951.0, 239.0], [923.0, 239.0]], [[895.0, 139.0], [917.0, 139.0], [917.0, 314.0], [895.0, 314.0]], [[864.0, 139.0], [886.0, 139.0], [886.0, 298.0], [864.0, 298.0]]], "lines": ["あたしが", "住んでいる街は", "坂の多い街だ。"]}, {"box": [140, 71, 551, 101], "vertical": false, "font_size": 26, "lines_coords": [[[140.0, 75.0], [551.0, 71.0], [551.0, 98.0], [140.0, 101.0]]], "lines": ["ｍｄｐｒｏｇｒａｍ坂の多い街"]}, {"box": [715, 1093, 793, 1202], "vertical": true, "font_size": 40, "lines_coords": [[[745.0, 1093.0], [793.0, 1093.0], [793.0, 1182.0], [745.0, 1182.0]], [[715.0, 1098.0], [748.0, 1098.0], [748.0, 1201.0], [715.0, 1201.0]]], "lines": ["おい、", "おまえ。"]}, {"box": [151, 835, 312, 1062], "vertical": true, "font_size": 27, "lines_coords": [[[286.0, 835.0], [312.0, 835.0], [312.0, 971.0], [286.0, 971.0]], [[251.0, 835.0], [278.0, 835.0], [281.0, 996.0], [254.0, 996.0]], [[214.0, 837.0], [242.0, 837.0], [242.0, 964.0], [214.0, 964.0]], [[184.0, 837.0], [210.0, 837.0], [210.0, 1062.0], [184.0, 1062.0]], [[151.0, 835.0], [178.0, 835.0], [178.0, 998.0], [151.0, 998.0]]], "lines": ["その日の朝、", "通学路の途中、", "車に轢かれ", "破裂した猫の死体が", "転がっていた。"]}, {"box": [881, 1142, 1008, 1368], "vertical": true, "font_size": 28, "lines_coords": [[[978.0, 1143.0], [1008.0, 1143.0], [1008.0, 1218.0], [978.0, 1218.0]], [[947.0, 1142.0], [973.0, 1142.0], [973.0, 1267.0], [947.0, 1267.0]], [[914.0, 1142.0], [940.0, 1142.0], [942.0, 1368.0], [915.0, 1368.0]], [[881.0, 1142.0], [909.0, 1142.0], [911.0, 1304.0], [883.0, 1304.0]]], "lines": ["そして", "その横には", "カラスの格好をした", "死に神がいて、"]}, {"box": [140, 1289, 231, 1464], "vertical": true, "font_size": 26, "lines_coords": [[[206.0, 1293.0], [228.0, 1293.0], [228.0, 1462.0], [206.0, 1462.0]], [[171.0, 1290.0], [198.0, 1290.0], [198.0, 1464.0], [171.0, 1464.0]], [[140.0, 1289.0], [168.0, 1289.0], [168.0, 1378.0], [140.0, 1378.0]]], "lines": ["唐突にあたしに", "語りはじめたの", "だった。"]}], "img_path": "subarashii_sekai_01_037.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [903, 109, 990, 328], "vertical": true, "font_size": 27, "lines_coords": [[[964.0, 110.0], [990.0, 110.0], [990.0, 215.0], [964.0, 215.0]], [[931.0, 109.0], [958.0, 109.0], [958.0, 262.0], [931.0, 262.0]], [[903.0, 112.0], [925.0, 112.0], [925.0, 328.0], [903.0, 328.0]]], "lines": ["世界は今", "暴力と欲望で", "溢れかえっている。"]}, {"box": [790, 281, 884, 409], "vertical": true, "font_size": 27, "lines_coords": [[[851.0, 281.0], [884.0, 281.0], [884.0, 364.0], [851.0, 364.0]], [[820.0, 281.0], [847.0, 281.0], [847.0, 409.0], [820.0, 409.0]], [[790.0, 284.0], [817.0, 284.0], [817.0, 395.0], [790.0, 395.0]]], "lines": ["なんて", "くだらない", "世の中だ。"]}, {"box": [106, 234, 232, 438], "vertical": true, "font_size": 25, "lines_coords": [[[200.0, 235.0], [229.0, 235.0], [232.0, 340.0], [203.0, 340.0]], [[173.0, 239.0], [195.0, 239.0], [195.0, 412.0], [173.0, 412.0]], [[142.0, 237.0], [164.0, 237.0], [164.0, 437.0], [142.0, 437.0]], [[109.0, 234.0], [135.0, 234.0], [132.0, 373.0], [106.0, 373.0]]], "lines": ["いずれは", "この猫のように", "朽ち果ててしまう", "というのに。"]}, {"box": [588, 450, 676, 611], "vertical": true, "font_size": 25, "lines_coords": [[[650.0, 450.0], [676.0, 450.0], [676.0, 610.0], [650.0, 610.0]], [[617.0, 451.0], [643.0, 451.0], [643.0, 607.0], [617.0, 607.0]], [[589.0, 453.0], [611.0, 453.0], [611.0, 589.0], [589.0, 589.0]]], "lines": ["そしてなんて", "愚かなのかね", "人間てのは。"]}, {"box": [245, 828, 365, 1006], "vertical": true, "font_size": 29, "lines_coords": [[[339.0, 828.0], [365.0, 828.0], [365.0, 957.0], [339.0, 957.0]], [[309.0, 831.0], [331.0, 831.0], [331.0, 1006.0], [309.0, 1006.0]], [[276.0, 829.0], [298.0, 829.0], [298.0, 956.0], [276.0, 956.0]], [[245.0, 829.0], [267.0, 829.0], [267.0, 957.0], [245.0, 957.0]]], "lines": ["なぜ人間は", "そんなに必死に", "生きようと", "するのか！？"]}, {"box": [220, 1062, 312, 1268], "vertical": true, "font_size": 29, "lines_coords": [[[267.0, 1062.0], [312.0, 1062.0], [312.0, 1189.0], [267.0, 1189.0]], [[220.0, 1065.0], [257.0, 1065.0], [257.0, 1268.0], [220.0, 1268.0]]], "lines": ["そして", "おまえも！！"]}], "img_path": "subarashii_sekai_01_038.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [364, 376, 784, 414], "vertical": false, "font_size": 32, "lines_coords": [[[364.0, 382.0], [784.0, 376.0], [784.0, 407.0], [364.0, 414.0]]], "lines": ["ｎｄｐｒｏｇｒａｍ坂の多い街"]}, {"box": [890, 400, 987, 564], "vertical": true, "font_size": 46, "lines_coords": [[[939.0, 400.0], [987.0, 400.0], [987.0, 484.0], [939.0, 484.0]], [[890.0, 401.0], [934.0, 400.0], [940.0, 562.0], [897.0, 564.0]]], "lines": ["コラ", "ガキッ！！"]}, {"box": [651, 720, 679, 848], "vertical": true, "font_size": 27, "lines_coords": [[[651.0, 721.0], [678.0, 721.0], [678.0, 848.0], [651.0, 848.0]]], "lines": ["．．．．．．おい？"]}, {"box": [162, 427, 205, 671], "vertical": true, "font_size": 42, "lines_coords": [[[162.0, 428.0], [204.0, 428.0], [204.0, 671.0], [162.0, 671.0]]], "lines": ["危ねぇだろ！！"]}, {"box": [886, 1020, 1006, 1281], "vertical": true, "font_size": 26, "lines_coords": [[[979.0, 1020.0], [1006.0, 1020.0], [1006.0, 1256.0], [979.0, 1256.0]], [[948.0, 1020.0], [975.0, 1020.0], [975.0, 1196.0], [948.0, 1196.0]], [[915.0, 1020.0], [942.0, 1020.0], [942.0, 1271.0], [915.0, 1271.0]], [[886.0, 1021.0], [908.0, 1021.0], [908.0, 1279.0], [886.0, 1279.0]]], "lines": ["ふと目の前を見ると、", "コンクリートを", "突き破って無理矢理に", "タンポポが咲いていた。"]}, {"box": [101, 1073, 223, 1287], "vertical": true, "font_size": 24, "lines_coords": [[[198.0, 1078.0], [220.0, 1078.0], [220.0, 1251.0], [198.0, 1251.0]], [[164.0, 1073.0], [190.0, 1073.0], [190.0, 1275.0], [164.0, 1275.0]], [[131.0, 1075.0], [157.0, 1075.0], [157.0, 1204.0], [131.0, 1204.0]], [[101.0, 1075.0], [125.0, 1075.0], [126.0, 1285.0], [103.0, 1285.0]]], "lines": ["なぜかあたしは", "その季節はずれの", "タンポポに", "見入ってしまった。"]}, {"box": [890, 1365, 937, 1407], "vertical": false, "font_size": 42, "lines_coords": [[[890.0, 1365.0], [937.0, 1365.0], [937.0, 1407.0], [890.0, 1407.0]]], "lines": ["．．"]}, {"box": [515, 1368, 773, 1462], "vertical": false, "font_size": 74, "lines_coords": [[[521.0, 1368.0], [773.0, 1389.0], [767.0, 1462.0], [515.0, 1442.0]]], "lines": ["しいぜ"]}, {"box": [225, 1335, 493, 1471], "vertical": false, "font_size": 108, "lines_coords": [[[237.0, 1335.0], [493.0, 1364.0], [481.0, 1471.0], [225.0, 1443.0]]], "lines": ["素晴ら"]}], "img_path": "subarashii_sekai_01_039.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [972, 1192, 1006, 1350], "vertical": true, "font_size": 31, "lines_coords": [[[975.0, 1192.0], [1006.0, 1192.0], [1003.0, 1350.0], [972.0, 1350.0]]], "lines": ["ぎゃはは！"]}], "img_path": "subarashii_sekai_01_040.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [895, 120, 953, 297], "vertical": true, "font_size": 27, "lines_coords": [[[926.0, 120.0], [953.0, 120.0], [951.0, 296.0], [925.0, 296.0]], [[895.0, 120.0], [922.0, 120.0], [922.0, 275.0], [895.0, 275.0]]], "lines": ["クラス全員から", "総シカトか！"]}, {"box": [226, 98, 281, 253], "vertical": true, "font_size": 25, "lines_coords": [[[254.0, 100.0], [281.0, 100.0], [281.0, 253.0], [254.0, 253.0]], [[226.0, 98.0], [248.0, 98.0], [248.0, 225.0], [226.0, 225.0]]], "lines": ["みじめだね！", "ぎゃはっ！"]}, {"box": [109, 240, 228, 420], "vertical": true, "font_size": 25, "lines_coords": [[[198.0, 240.0], [225.0, 240.0], [228.0, 370.0], [201.0, 370.0]], [[170.0, 243.0], [196.0, 243.0], [196.0, 420.0], [170.0, 420.0]], [[139.0, 242.0], [165.0, 242.0], [165.0, 370.0], [139.0, 370.0]], [[109.0, 243.0], [131.0, 243.0], [131.0, 393.0], [109.0, 393.0]]], "lines": ["幼少時代の", "いじめは一生の", "トラウマに", "なるんだぜ！"]}, {"box": [887, 659, 983, 867], "vertical": true, "font_size": 28, "lines_coords": [[[954.0, 662.0], [983.0, 662.0], [983.0, 751.0], [954.0, 751.0]], [[923.0, 662.0], [950.0, 662.0], [950.0, 867.0], [923.0, 867.0]], [[890.0, 659.0], [918.0, 659.0], [915.0, 800.0], [887.0, 800.0]]], "lines": ["おまえ、", "今朝は惜しかった", "じゃないの。"]}, {"box": [539, 656, 597, 790], "vertical": true, "font_size": 25, "lines_coords": [[[572.0, 656.0], [595.0, 656.0], [597.0, 790.0], [573.0, 790.0]], [[539.0, 656.0], [565.0, 656.0], [565.0, 745.0], [539.0, 745.0]]], "lines": ["うるせえよ、", "おまえ。"]}, {"box": [446, 1009, 492, 1067], "vertical": true, "font_size": 46, "lines_coords": [[[446.0, 1009.0], [492.0, 1009.0], [492.0, 1067.0], [446.0, 1067.0]]], "lines": ["あ。"]}, {"box": [125, 731, 190, 922], "vertical": true, "font_size": 30, "lines_coords": [[[150.0, 731.0], [190.0, 731.0], [190.0, 817.0], [150.0, 817.0]], [[125.0, 735.0], [146.0, 735.0], [146.0, 921.0], [125.0, 921.0]]], "lines": ["ついて", "くんじゃねえよ。"]}, {"box": [668, 1251, 795, 1429], "vertical": true, "font_size": 29, "lines_coords": [[[762.0, 1251.0], [795.0, 1251.0], [795.0, 1356.0], [762.0, 1356.0]], [[731.0, 1251.0], [759.0, 1251.0], [759.0, 1379.0], [731.0, 1379.0]], [[701.0, 1251.0], [728.0, 1251.0], [728.0, 1429.0], [701.0, 1429.0]], [[668.0, 1254.0], [697.0, 1254.0], [697.0, 1340.0], [668.0, 1340.0]]], "lines": ["せっかく", "楽になれる", "チャンスだった", "のによ。"]}, {"box": [506, 1275, 534, 1329], "vertical": true, "font_size": 28, "lines_coords": [[[506.0, 1275.0], [534.0, 1275.0], [534.0, 1329.0], [506.0, 1329.0]]], "lines": ["ポロッ"]}], "img_path": "subarashii_sekai_01_041.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [690, 680, 728, 776], "vertical": true, "font_size": 38, "lines_coords": [[[690.0, 680.0], [728.0, 680.0], [728.0, 776.0], [690.0, 776.0]]], "lines": ["がりっ"]}, {"box": [536, 895, 572, 965], "vertical": true, "font_size": 30, "lines_coords": [[[536.0, 895.0], [572.0, 895.0], [572.0, 965.0], [536.0, 965.0]]], "lines": ["おい。"]}, 