5, 951, 1215], "vertical": true, "font_size": 25, "lines_coords": [[[925.0, 990.0], [951.0, 990.0], [951.0, 1125.0], [925.0, 1125.0]], [[893.0, 987.0], [920.0, 987.0], [917.0, 1215.0], [890.0, 1215.0]], [[864.0, 990.0], [886.0, 990.0], [886.0, 1140.0], [864.0, 1140.0]], [[829.0, 985.0], [856.0, 985.0], [854.0, 1175.0], [828.0, 1175.0]]], "lines": ["ホラ勤務先、", "決まったら今週中に", "連絡来るって", "言ってたじゃん。"]}, {"box": [353, 745, 449, 1094], "vertical": true, "font_size": 25, "lines_coords": [[[420.0, 745.0], [446.0, 745.0], [446.0, 1093.0], [420.0, 1093.0]], [[390.0, 746.0], [412.0, 746.0], [412.0, 1060.0], [390.0, 1060.0]], [[353.0, 745.0], [381.0, 745.0], [382.0, 1006.0], [354.0, 1006.0]]], "lines": ["つきあって１年、同棲して半年", "彼の定位置、私の足位置．．．", "いつもの何気ない会話"]}, {"box": [572, 1268, 662, 1384], "vertical": true, "font_size": 30, "lines_coords": [[[631.0, 1268.0], [662.0, 1268.0], [662.0, 1320.0], [631.0, 1320.0]], [[600.0, 1268.0], [632.0, 1268.0], [632.0, 1376.0], [600.0, 1376.0]], [[572.0, 1270.0], [598.0, 1270.0], [598.0, 1382.0], [572.0, 1382.0]]], "lines": ["あー", "なかった", "なかった。"]}, {"box": [206, 1125, 295, 1282], "vertical": true, "font_size": 24, "lines_coords": [[[267.0, 1125.0], [295.0, 1125.0], [295.0, 1215.0], [267.0, 1215.0]], [[237.0, 1126.0], [259.0, 1126.0], [259.0, 1275.0], [237.0, 1275.0]], [[206.0, 1126.0], [228.0, 1126.0], [228.0, 1282.0], [206.0, 1282.0]]], "lines": ["あ、でも", "お姉さんから", "電話あったよ。"]}, {"box": [151, 1320, 209, 1457], "vertical": true, "font_size": 24, "lines_coords": [[[181.0, 1320.0], [209.0, 1320.0], [206.0, 1425.0], [178.0, 1425.0]], [[151.0, 1323.0], [173.0, 1323.0], [173.0, 1457.0], [151.0, 1457.0]]], "lines": ["就職祝い", "くれってさ。"]}], "img_path": "subarashii_sekai_01_160.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [889, 112, 1012, 295], "vertical": true, "font_size": 26, "lines_coords": [[[984.0, 112.0], [1012.0, 112.0], [1012.0, 254.0], [984.0, 254.0]], [[953.0, 115.0], [979.0, 115.0], [979.0, 295.0], [953.0, 295.0]], [[925.0, 114.0], [947.0, 114.0], [947.0, 292.0], [925.0, 292.0]], [[889.0, 112.0], [917.0, 112.0], [917.0, 203.0], [889.0, 203.0]]], "lines": ["あー、キミ", "お姉ちゃんから", "もらっちゃった", "もんね。"]}, {"box": [201, 121, 260, 250], "vertical": true, "font_size": 28, "lines_coords": [[[232.0, 121.0], [260.0, 121.0], [257.0, 250.0], [229.0, 250.0]], [[201.0, 123.0], [228.0, 123.0], [228.0, 235.0], [201.0, 235.0]]], "lines": ["チャンネル", "変えるよ。"]}, {"box": [593, 489, 715, 667], "vertical": true, "font_size": 25, "lines_coords": [[[687.0, 490.0], [715.0, 490.0], [715.0, 593.0], [687.0, 593.0]], [[656.0, 489.0], [684.0, 489.0], [681.0, 615.0], [653.0, 615.0]], [[625.0, 492.0], [647.0, 492.0], [647.0, 665.0], [625.0, 665.0]], [[593.0, 492.0], [615.0, 492.0], [615.0, 617.0], [593.0, 617.0]]], "lines": ["つっても", "引っ越しで", "いらなくなった", "家具だろ？"]}, {"box": [286, 614, 320, 682], "vertical": true, "font_size": 34, "lines_coords": [[[286.0, 614.0], [320.0, 614.0], [320.0, 682.0], [286.0, 682.0]]], "lines": ["おう。"]}, {"box": [771, 734, 829, 973], "vertical": true, "font_size": 24, "lines_coords": [[[801.0, 737.0], [828.0, 737.0], [828.0, 887.0], [801.0, 887.0]], [[772.0, 737.0], [793.0, 737.0], [793.0, 971.0], [772.0, 971.0]]], "lines": ["なんか空気に", "話しかけてるような"]}, {"box": [551, 735, 642, 939], "vertical": true, "font_size": 27, "lines_coords": [[[614.0, 735.0], [642.0, 735.0], [642.0, 887.0], [614.0, 887.0]], [[584.0, 735.0], [611.0, 735.0], [607.0, 939.0], [581.0, 939.0]], [[551.0, 735.0], [578.0, 735.0], [578.0, 937.0], [551.0, 937.0]]], "lines": ["それはそれで", "いいことなのかも", "しれないけど．．．"]}, {"box": [436, 1128, 683, 1214], "vertical": false, "font_size": 30, "lines_coords": [[[440.0, 1133.0], [678.0, 1137.0], [678.0, 1169.0], [440.0, 1166.0]], [[478.0, 1177.0], [634.0, 1176.0], [634.0, 1208.0], [478.0, 1209.0]]], "lines": ["８ｔｈｐｒｏｇｒａｍ", "Ｕｎｔｉｔｌｅｃｌ"]}, {"box": [307, 735, 339, 973], "vertical": true, "font_size": 26, "lines_coords": [[[311.0, 735.0], [337.0, 735.0], [336.0, 973.0], [309.0, 973.0]]], "lines": ["ちょっと物足りない。"]}, {"box": [237, 1343, 867, 1462], "vertical": false, "font_size": 98.5, "lines_coords": [[[237.0, 1359.0], [382.0, 1359.0], [382.0, 1437.0], [237.0, 1437.0]], [[353.0, 1343.0], [867.0, 1343.0], [867.0, 1462.0], [353.0, 1462.0]]], "lines": ["１０万", "寄らしいぜと"]}], "img_path": "subarashii_sekai_01_161.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [851, 106, 908, 257], "vertical": true, "font_size": 24, "lines_coords": [[[879.0, 106.0], [906.0, 106.0], [906.0, 257.0], [879.0, 257.0]], [[851.0, 106.0], [873.0, 106.0], [873.0, 217.0], [851.0, 217.0]]], "lines": ["おつかれさん", "でーす"]}, {"box": [715, 304, 743, 459], "vertical": true, "font_size": 27, "lines_coords": [[[715.0, 304.0], [742.0, 304.0], [742.0, 425.0], [715.0, 425.0]]], "lines": ["おつかれー"]}, {"box": [482, 126, 509, 253], "vertical": true, "font_size": 27, "lines_coords": [[[482.0, 126.0], [509.0, 126.0], [509.0, 253.0], [482.0, 253.0]]], "lines": ["飲みます？"]}, {"box": [164, 304, 185, 418], "vertical": true, "font_size": 25, "lines_coords": [[[164.0, 304.0], [185.0, 304.0], [185.0, 418.0], [164.0, 418.0]]], "lines": ["ありがとー"]}, {"box": [170, 487, 260, 681], "vertical": true, "font_size": 25, "lines_coords": [[[232.0, 489.0], [259.0, 489.0], [260.0, 681.0], [234.0, 681.0]], [[201.0, 492.0], [228.0, 492.0], [228.0, 670.0], [201.0, 670.0]], [[170.0, 487.0], [196.0, 487.0], [196.0, 645.0], [170.0, 645.0]]], "lines": ["そうだ、遠藤くん", "大学の合格発表", "どうだった？"]}, {"box": [908, 956, 970, 1095], "vertical": true, "font_size": 28, "lines_coords": [[[945.0, 1032.0], [965.0, 1029.0], [968.0, 1062.0], [948.0, 1064.0]], [[942.0, 959.0], [970.0, 959.0], [970.0, 1035.0], [942.0, 1035.0]], [[911.0, 956.0], [939.0, 956.0], [936.0, 1095.0], [908.0, 1095.0]]], "lines": ["ん", "いやー", "ダメでした。"]}, {"box": [876, 954, 912, 1023], "vertical": true, "font_size": 28, "lines_coords": [[[876.0, 954.0], [912.0, 954.0], [912.0, 1023.0], [876.0, 1023.0]]], "lines": ["全滅。"]}, {"box": [917, 1131, 943, 1260], "vertical": true, "font_size": 28, "lines_coords": [[[917.0, 1131.0], [943.0, 1131.0], [943.0, 1260.0], [917.0, 1260.0]]], "lines": ["２浪確定。"]}, {"box": [414, 793, 438, 956], "vertical": true, "font_size": 22, "lines_coords": [[[414.0, 793.0], [436.0, 793.0], [436.0, 953.0], [414.0, 953.0]]], "lines": ["．．．そっかぁ．．．．．"]}, {"box": [586, 1305, 675, 1491], "vertical": true, "font_size": 22, "lines_coords": [[[650.0, 1306.0], [672.0, 1306.0], [672.0, 1457.0], [650.0, 1457.0]], [[618.0, 1306.0], [640.0, 1306.0], [640.0, 1485.0], [618.0, 1485.0]], [[587.0, 1307.0], [609.0, 1307.0], [609.0, 1467.0], [587.0, 1467.0]]], "lines": ["きのう親父に", "言われましたよ", "実家継げって。"]}, {"box": [242, 1110, 304, 1406], "vertical": true, "font_size": 28, "lines_coords": [[[276.0, 1112.0], [304.0, 1112.0], [304.0, 1210.0], [276.0, 1210.0]], [[242.0, 1110.0], [270.0, 1110.0], [276.0, 1406.0], [248.0, 1406.0]]], "lines": ["悩むトコ", "なんすよね。ホラ、やっぱ"]}, {"box": [153, 1264, 243, 1470], "vertical": true, "font_size": 28, "lines_coords": [[[212.0, 1264.0], [243.0, 1264.0], [243.0, 1470.0], [212.0, 1470.0]], [[181.0, 1264.0], [207.0, 1264.0], [210.0, 1418.0], [184.0, 1418.0]], [[153.0, 1265.0], [179.0, 1265.0], [179.0, 1381.0], [153.0, 1381.0]]], "lines": ["現実ってリアルで", "キビシーじゃ", "ないスか。"]}], "img_path": "subarashii_sekai_01_162.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [889, 140, 984, 370], "vertical": true, "font_size": 26, "lines_coords": [[[956.0, 142.0], [984.0, 142.0], [979.0, 370.0], [951.0, 370.0]], [[926.0, 143.0], [953.0, 143.0], [950.0, 321.0], [923.0, 321.0]], [[893.0, 140.0], [922.0, 140.0], [917.0, 346.0], [889.0, 346.0]]], "lines": ["さすがにフリーター", "一直線ってのは", "怖いっつーか．．．"]}, {"box": [220, 96, 343, 290], "vertical": true, "font_size": 29, "lines_coords": [[[321.0, 101.0], [343.0, 101.0], [343.0, 290.0], [321.0, 290.0]], [[287.0, 101.0], [314.0, 101.0], [314.0, 279.0], [287.0, 279.0]], [[256.0, 100.0], [284.0, 100.0], [281.0, 279.0], [253.0, 279.0]], [[220.0, 96.0], [256.0, 96.0], [256.0, 157.0], [220.0, 157.0]]], "lines": ["あ、でも彼氏さん", "内定取れたって", "言ってましたよ", "ね？"]}, {"box": [204, 310, 268, 478], "vertical": true, "font_size": 29, "lines_coords": [[[237.0, 310.0], [268.0, 310.0], [268.0, 478.0], [237.0, 478.0]], [[207.0, 310.0], [235.0, 310.0], [232.0, 425.0], [204.0, 425.0]]], "lines": ["なら、いいじゃ", "ないスか。"]}, {"box": [945, 437, 967, 484], "vertical": true, "font_size": 26, "lines_coords": [[[945.0, 437.0], [967.0, 437.0], [967.0, 484.0], [945.0, 484.0]]], "lines": ["．．．あ"]}, {"box": [895, 704, 953, 856], "vertical": true, "font_size": 25, "lines_coords": [[[925.0, 704.0], [953.0, 704.0], [950.0, 807.0], [922.0, 807.0]], [[895.0, 706.0], [917.0, 706.0], [917.0, 856.0], [895.0, 856.0]]], "lines": ["全然問題", "なしっすよ！！"]}, {"box": [561, 504, 651, 641], "vertical": true, "font_size": 26, "lines_coords": [[[626.0, 507.0], [648.0, 507.0], [648.0, 640.0], [626.0, 640.0]], [[593.0, 506.0], [622.0, 506.0], [622.0, 607.0], [593.0, 607.0]], [[561.0, 504.0], [589.0, 504.0], [589.0, 593.0], [561.0, 593.0]]], "lines": ["すいません、", "モロっす", "もんね。"]}, {"box": [209, 989, 367, 1168], "vertical": true, "font_size": 28, "lines_coords": [[[329.0, 989.0], [367.0, 989.0], [367.0, 1028.0], [329.0, 1028.0]], [[303.0, 990.0], [331.0, 990.0], [331.0, 1140.0], [303.0, 1140.0]], [[270.0, 989.0], [296.0, 989.0], [296.0, 1140.0], [270.0, 1140.0]], [[242.0, 992.0], [264.0, 992.0], [264.0, 1167.0], [242.0, 1167.0]], [[209.0, 990.0], [235.0, 990.0], [235.0, 1093.0], [209.0, 1093.0]]], "lines": ["ま、", "強いて言えば", "問題ないのが", "問題なんだろう", "けど．．．"]}, {"box": [243, 1340, 270, 1451], "vertical": true, "font_size": 22, "lines_coords": [[[243.0, 1342.0], [265.0, 1342.0], [265.0, 1448.0], [243.0, 1448.0]]], "lines": ["ただいま"]}], "img_path": "subarashii_sekai_01_163.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [609, 132, 643, 203], "vertical": true, "font_size": 34, "lines_coords": [[[609.0, 132.0], [643.0, 132.0], [643.0, 203.0], [609.0, 203.0]]], "lines": ["おう。"]}, {"box": [133, 543, 189, 646], "vertical": true, "font_size": 33, "lines_coords": [[[156.0, 543.0], [189.0, 543.0], [189.0, 646.0], [156.0, 646.0]]], "lines": ["機嫌悪い"]}, {"box": [861, 782, 953, 973], "vertical": true, "font_size": 25, "lines_coords": [[[926.0, 784.0], [953.0, 784.0], [950.0, 935.0], [923.0, 935.0]], [[893.0, 784.0], [920.0, 784.0], [918.0, 971.0], [892.0, 971.0]], [[864.0, 782.0], [886.0, 782.0], [883.0, 971.0], [861.0, 971.0]]], "lines": ["じゃあ実家に", "２、３目泊まって", "くると思うから。"]}, {"box": [543, 779, 582, 850], "vertical": true, "font_size": 36, "lines_coords": [[[543.0, 781.0], [579.0, 779.0], [582.0, 848.0], [546.0, 850.0]]], "lines": ["ホイ。"]}, {"box": [578, 1062, 604, 1162], "vertical": true, "font_size": 26, "lines_coords": [[[578.0, 1062.0], [604.0, 1062.0], [604.0, 1162.0], [578.0, 1162.0]]], "lines": ["何コレ？"]}, {"box": [175, 790, 239, 931], "vertical": true, "font_size": 32, "lines_coords": [[[200.0, 790.0], [239.0, 790.0], [239.0, 846.0], [200.0, 846.0]], [[175.0, 792.0], [201.0, 792.0], [201.0, 931.0], [175.0, 931.0]]], "lines": ["コレ", "持ってって。"]}, {"box": [145, 1323, 239, 1451], "vertical": true, "font_size": 27, "lines_coords": [[[207.0, 1325.0], [235.0, 1325.0], [235.0, 1440.0], [207.0, 1440.0]], [[178.0, 1323.0], [204.0, 1323.0], [201.0, 1451.0], [175.0, 1451.0]], [[145.0, 1323.0], [173.0, 1323.0], [173.0, 1437.0], [145.0, 1437.0]]], "lines": ["フレステ。", "お姉さんに", "就職祝い。"]}], "img_path": "subarashii_sekai_01_164.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [898, 114, 992, 243], "vertical": true, "font_size": 31, "lines_coords": [[[954.0, 114.0], [992.0, 114.0], [992.0, 176.0], [954.0, 176.0]], [[929.0, 117.0], [958.0, 117.0], [954.0, 243.0], [926.0, 243.0]], [[898.0, 115.0], [925.0, 115.0], [925.0, 218.0], [898.0, 218.0]]], "lines": ["多分", "いらないと", "思う．．．"]}, {"box": [170, 128, 264, 257], "vertical": true, "font_size": 30, "lines_coords": [[[228.0, 128.0], [264.0, 128.0], [264.0, 207.0], [228.0, 207.0]], [[201.0, 131.0], [228.0, 131.0], [228.0, 257.0], [201.0, 257.0]], [[170.0, 129.0], [196.0, 129.0], [196.0, 243.0], [170.0, 243.0]]], "lines": ["実家の", "ご両親にも", "よろしく。"]}, {"box": [711, 565, 803, 677], "vertical": true, "font_size": 29, "lines_coords": [[[775.0, 567.0], [803.0, 567.0], [803.0, 654.0], [775.0, 654.0]], [[739.0, 565.0], [773.0, 565.0], [773.0, 646.0], [739.0, 646.0]], [[711.0, 567.0], [737.0, 567.0], [737.0, 676.0], [711.0, 676.0]]], "lines": ["ははは。", "それは", "お互い様。"]}, {"box": [851, 1109, 924, 1268], "vertical": true, "font_size": 32, "lines_coords": [[[892.0, 1109.0], [923.0, 1109.0], [923.0, 1267.0], [892.0, 1267.0]], [[851.0, 1109.0], [884.0, 1109.0], [884.0, 1232.0], [851.0, 1232.0]]], "lines": ["川の流れよ、", "止まれ！"]}, {"box": [403, 765, 461, 918], "vertical": true, "font_size": 26, "lines_coords": [[[434.0, 765.0], [461.0, 765.0], [457.0, 918.0], [431.0, 918.0]], [[403.0, 768.0], [429.0, 768.0], [429.0, 895.0], [403.0, 895.0]]], "lines": ["今日は機嫌の", "いい日．．．"]}, {"box": [145, 1301, 229, 1513], "vertical": true, "font_size": 38, "lines_coords": [[[185.0, 1301.0], [229.0, 1301.0], [229.0, 1460.0], [185.0, 1460.0]], [[146.0, 1303.0], [179.0, 1303.0], [179.0, 1512.0], [146.0, 1512.0]]], "lines": ["つーか、", "あんた遅っ！！"]}], "img_path": "subarashii_sekai_01_165.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [890, 87, 978, 267], "vertical": true, "font_size": 27, "lines_coords": [[[951.0, 87.0], [978.0, 87.0], [978.0, 193.0], [951.0, 193.0]], [[920.0, 90.0], [947.0, 90.0], [947.0, 264.0], [920.0, 264.0]], [[890.0, 89.0], [912.0, 89.0], [912.0, 267.0], [890.0, 267.0]]], "lines": ["２時間！！", "飲み屋でひとり", "２時間待った！！"]}, {"box": [797, 296, 920, 478], "vertical": true, "font_size": 27, "lines_coords": [[[893.0, 296.0], [920.0, 296.0], [920.0, 429.0], [893.0, 429.0]], [[859.0, 296.0], [887.0, 296.0], [889.0, 454.0], [861.0, 454.0]], [[829.0, 298.0], [856.0, 298.0], [858.0, 478.0], [831.0, 478.0]], [[797.0, 301.0], [826.0, 300.0], [829.0, 379.0], [800.0, 381.0]]], "lines": ["どーせまた", "ブラブラ道草", "くってきたんで", "しょ？"]}, {"box": [620, 103, 647, 250], "vertical": true, "font_size": 22, "lines_coords": [[[620.0, 103.0], [647.0, 103.0], [647.0, 250.0], [620.0, 250.0]]], "lines": ["ごめんなさい"]}, {"box": [593, 157, 611, 204], "vertical": true, "font_size": 22, "lines_coords": [[[593.0, 157.0], [611.0, 157.0], [611.0, 204.0], [593.0, 204.0]]], "lines": ["．．．"]}, {"box": [139, 226, 168, 364], "vertical": true, "font_size": 26, "lines_coords": [[[139.0, 226.0], [165.0, 226.0], [168.0, 364.0], [142.0, 364.0]]], "lines": ["許さねーよ。"]}, {"box": [800, 695, 858, 846], "vertical": true, "font_size": 27, "lines_coords": [[[828.0, 695.0], [856.0, 695.0], [858.0, 846.0], [829.0, 846.0]], [[800.0, 695.0], [826.0, 695.0], [826.0, 809.0], [800.0, 809.0]]], "lines": ["心がこもって", "ないけど。"]}, {"box": [609, 445, 632, 501], "vertical": true, "font_size": 25, "lines_coords": [[[609.0, 445.0], [632.0, 445.0], [632.0, 501.0], [609.0, 501.0]]], "lines": ["ーと"]}, {"box": [579, 401, 636, 531], "vertical": true, "font_size": 25, "lines_coords": [[[609.0, 401.0], [636.0, 401.0], [636.0, 453.0], [609.0, 453.0]], [[579.0, 401.0], [601.0, 401.0], [601.0, 531.0], [579.0, 531.0]]], "lines": ["えー", "お姉ちゃん、"]}, {"box": [453, 465, 546, 645], "vertical": true, "font_size": 25, "lines_coords": [[[520.0, 465.0], [546.0, 465.0], [543.0, 596.0], [517.0, 596.0]], [[487.0, 468.0], [514.0, 468.0], [514.0, 645.0], [487.0, 645.0]], [[456.0, 467.0], [482.0, 467.0], [479.0, 607.0], [453.0, 607.0]]], "lines": ["大学卒業と", "就職オメデトウ", "ゴザイマス。"]}, {"box": [886, 1007, 944, 1159], "vertical": true, "font_size": 24, "lines_coords": [[[920.0, 1009.0], [942.0, 1009.0], [942.0, 1132.0], [920.0, 1132.0]], [[886.0, 1007.0], [912.0, 1007.0], [912.0, 1159.0], [886.0, 1159.0]]], "lines": ["お姉ちゃん", "横山くんは？"]}, {"box": [542, 1007, 634, 1150], "vertical": true, "font_size": 32, "lines_coords": [[[601.0, 1010.0], [634.0, 1010.0], [634.0, 1103.0], [601.0, 1103.0]], [[567.0, 1007.