: ["先輩って、", "もしや", "親バカ？"]}, {"box": [724, 1267, 845, 1480], "vertical": true, "font_size": 26, "lines_coords": [[[815.0, 1267.0], [842.0, 1267.0], [845.0, 1479.0], [818.0, 1479.0]], [[786.0, 1268.0], [812.0, 1268.0], [812.0, 1446.0], [786.0, 1446.0]], [[753.0, 1268.0], [781.0, 1268.0], [781.0, 1420.0], [753.0, 1420.0]], [[725.0, 1270.0], [747.0, 1270.0], [747.0, 1421.0], [725.0, 1421.0]]], "lines": ["娘さんが生まれて、", "気持ち保守的に", "なったんじゃ", "ないスかぁ？"]}, {"box": [506, 1267, 534, 1384], "vertical": true, "font_size": 28, "lines_coords": [[[506.0, 1270.0], [534.0, 1270.0], [534.0, 1381.0], [506.0, 1381.0]]], "lines": ["．．．フン。"]}, {"box": [218, 1265, 246, 1405], "vertical": true, "font_size": 22, "lines_coords": [[[225.0, 1345.0], [242.0, 1345.0], [242.0, 1403.0], [225.0, 1403.0]], [[218.0, 1265.0], [245.0, 1265.0], [245.0, 1350.0], [218.0, 1350.0]]], "lines": ["ーよ", "ちげー"]}], "img_path": "subarashii_sekai_02_068.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [903, 95, 935, 276], "vertical": true, "font_size": 31, "lines_coords": [[[903.0, 95.0], [934.0, 95.0], [934.0, 275.0], [903.0, 275.0]]], "lines": ["．．．．．．つーか．．．"]}, {"box": [296, 296, 390, 426], "vertical": true, "font_size": 30, "lines_coords": [[[356.0, 296.0], [390.0, 296.0], [390.0, 379.0], [356.0, 379.0]], [[328.0, 298.0], [354.0, 298.0], [354.0, 426.0], [328.0, 426.0]], [[296.0, 296.0], [325.0, 296.0], [325.0, 425.0], [296.0, 425.0]]], "lines": ["むしろ", "カミさんも", "娘も．．．．．．"]}, {"box": [275, 629, 398, 758], "vertical": true, "font_size": 27, "lines_coords": [[[370.0, 629.0], [398.0, 629.0], [398.0, 728.0], [370.0, 728.0]], [[337.0, 631.0], [364.0, 631.0], [364.0, 756.0], [337.0, 756.0]], [[306.0, 629.0], [332.0, 629.0], [332.0, 739.0], [306.0, 739.0]], [[275.0, 629.0], [303.0, 629.0], [303.0, 757.0], [275.0, 757.0]]], "lines": ["すっげー", "遠くに感じ", "てんのよ、", "俺は．．．．．．"]}, {"box": [129, 879, 397, 962], "vertical": false, "font_size": 31, "lines_coords": [[[131.0, 879.0], [395.0, 882.0], [395.0, 914.0], [131.0, 910.0]], [[139.0, 928.0], [382.0, 928.0], [382.0, 959.0], [139.0, 959.0]]], "lines": ["３ｔｈＤｒｏｇｒａｍ", "おやすみなさい"]}, {"box": [895, 1354, 937, 1389], "vertical": false, "font_size": 35, "lines_coords": [[[895.0, 1354.0], [933.0, 1354.0], [933.0, 1389.0], [895.0, 1389.0]]], "lines": ["．．"]}, {"box": [520, 1364, 779, 1443], "vertical": false, "font_size": 73, "lines_coords": [[[521.0, 1364.0], [779.0, 1370.0], [778.0, 1443.0], [520.0, 1437.0]]], "lines": ["しいぜ"]}], "img_path": "subarashii_sekai_02_069.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [903, 117, 993, 232], "vertical": true, "font_size": 29, "lines_coords": [[[964.0, 118.0], [990.0, 118.0], [993.0, 232.0], [967.0, 232.0]], [[931.0, 117.0], [965.0, 117.0], [965.0, 198.0], [931.0, 198.0]], [[903.0, 118.0], [929.0, 118.0], [929.0, 232.0], [903.0, 232.0]]], "lines": ["おかえり。", "今日は", "早いんだ。"]}, {"box": [570, 129, 597, 256], "vertical": true, "font_size": 29, "lines_coords": [[[570.0, 129.0], [597.0, 129.0], [597.0, 256.0], [570.0, 256.0]]], "lines": ["ふうん．．．"]}, {"box": [487, 260, 518, 304], "vertical": true, "font_size": 29, "lines_coords": [[[487.0, 260.0], [518.0, 260.0], [518.0, 304.0], [487.0, 304.0]]], "lines": ["そ。"]}, {"box": [118, 214, 220, 323], "vertical": true, "font_size": 38, "lines_coords": [[[178.0, 214.0], [220.0, 214.0], [220.0, 279.0], [178.0, 279.0]], [[148.0, 217.0], [182.0, 215.0], [185.0, 321.0], [151.0, 323.0]], [[118.0, 215.0], [157.0, 215.0], [157.0, 264.0], [118.0, 264.0]]], "lines": ["また", "忙しいん", "だ。"]}, {"box": [718, 550, 806, 749], "vertical": true, "font_size": 24, "lines_coords": [[[779.0, 550.0], [806.0, 550.0], [806.0, 664.0], [779.0, 664.0]], [[750.0, 550.0], [772.0, 550.0], [772.0, 746.0], [750.0, 746.0]], [[718.0, 550.0], [740.0, 550.0], [740.0, 710.0], [718.0, 710.0]]], "lines": ["いや、資料", "取りに来ただけで", "すぐ会社戻る。"]}, {"box": [361, 603, 452, 731], "vertical": true, "font_size": 30, "lines_coords": [[[396.0, 604.0], [423.0, 604.0], [423.0, 731.0], [396.0, 731.0]], [[361.0, 603.0], [393.0, 603.0], [393.0, 685.0], [361.0, 685.0]]], "lines": ["何か作って", "たの？"]}, {"box": [129, 610, 196, 749], "vertical": true, "font_size": 28, "lines_coords": [[[157.0, 610.0], [185.0, 610.0], [189.0, 740.0], [160.0, 740.0]], [[129.0, 614.0], [156.0, 614.0], [156.0, 748.0], [129.0, 748.0]]], "lines": ["折り紙で鎖", "作ってたの。"]}, {"box": [912, 834, 936, 961], "vertical": true, "font_size": 22, "lines_coords": [[[912.0, 835.0], [934.0, 835.0], [934.0, 960.0], [912.0, 960.0]]], "lines": ["なんでよ？"]}, {"box": [889, 1062, 950, 1212], "vertical": true, "font_size": 27, "lines_coords": [[[923.0, 1064.0], [950.0, 1064.0], [950.0, 1212.0], [923.0, 1212.0]], [[889.0, 1062.0], [915.0, 1062.0], [918.0, 1176.0], [892.0, 1176.0]]], "lines": ["おお、そーだ。", "だよだよ。"]}, {"box": [376, 831, 403, 970], "vertical": true, "font_size": 27, "lines_coords": [[[376.0, 831.0], [403.0, 831.0], [403.0, 970.0], [376.0, 970.0]]], "lines": ["なんでって。"]}, {"box": [214, 893, 309, 1071], "vertical": true, "font_size": 27, "lines_coords": [[[276.0, 893.0], [309.0, 893.0], [309.0, 978.0], [276.0, 978.0]], [[250.0, 896.0], [271.0, 896.0], [271.0, 1071.0], [250.0, 1071.0]], [[217.0, 895.0], [243.0, 895.0], [240.0, 1006.0], [214.0, 1006.0]]], "lines": ["今週は", "この子の誕生日", "じゃんか"]}, {"box": [790, 1259, 912, 1465], "vertical": true, "font_size": 27, "lines_coords": [[[886.0, 1259.0], [912.0, 1259.0], [911.0, 1453.0], [884.0, 1453.0]], [[853.0, 1260.0], [879.0, 1260.0], [879.0, 1421.0], [853.0, 1421.0]], [[820.0, 1262.0], [847.0, 1262.0], [850.0, 1414.0], [823.0, 1414.0]], [[790.0, 1260.0], [817.0, 1260.0], [817.0, 1465.0], [790.0, 1465.0]]], "lines": ["じゃあ、今週仕事", "鬼忙しいけど、", "無理してでも", "祝わなきゃだな！"]}, {"box": [289, 1167, 315, 1273], "vertical": true, "font_size": 25, "lines_coords": [[[292.0, 1167.0], [315.0, 1167.0], [312.0, 1273.0], [289.0, 1273.0]]], "lines": ["なーんて"]}, {"box": [159, 1298, 215, 1473], "vertical": true, "font_size": 25, "lines_coords": [[[189.0, 1298.0], [215.0, 1298.0], [215.0, 1434.0], [189.0, 1434.0]], [[159.0, 1298.0], [185.0, 1298.0], [185.0, 1473.0], [159.0, 1473.0]]], "lines": ["別にいいよ。", "気、遣わなくて。"]}], "img_path": "subarashii_sekai_02_070.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [881, 121, 1004, 309], "vertical": true, "font_size": 26, "lines_coords": [[[976.0, 121.0], [1003.0, 121.0], [1003.0, 309.0], [976.0, 309.0]], [[945.0, 121.0], [972.0, 121.0], [972.0, 262.0], [945.0, 262.0]], [[915.0, 123.0], [937.0, 123.0], [937.0, 298.0], [915.0, 298.0]], [[881.0, 121.0], [908.0, 121.0], [908.0, 251.0], [881.0, 251.0]]], "lines": ["キミ、中途半端に", "家庭と仕事、", "天秤にかけたり", "しない．．．"]}, {"box": [87, 57, 336, 87], "vertical": false, "font_size": 27, "lines_coords": [[[87.0, 57.0], [336.0, 60.0], [336.0, 87.0], [87.0, 84.0]]], "lines": ["素晴らしい世界２"]}, {"box": [620, 414, 744, 631], "vertical": true, "font_size": 26, "lines_coords": [[[717.0, 415.0], [743.0, 415.0], [743.0, 593.0], [717.0, 593.0]], [[682.0, 414.0], [709.0, 414.0], [712.0, 601.0], [686.0, 601.0]], [[648.0, 414.0], [676.0, 414.0], [681.0, 631.0], [653.0, 631.0]], [[620.0, 418.0], [643.0, 418.0], [645.0, 579.0], [622.0, 579.0]]], "lines": ["ちゃんと働いて", "くれさえいれば、", "あたしたち、生きて", "いけるんだし。"]}, {"box": [98, 332, 191, 469], "vertical": true, "font_size": 27, "lines_coords": [[[162.0, 334.0], [189.0, 334.0], [189.0, 465.0], [162.0, 465.0]], [[128.0, 332.0], [156.0, 332.0], [157.0, 460.0], [129.0, 460.0]], [[98.0, 334.0], [125.0, 334.0], [125.0, 460.0], [98.0, 460.0]]], "lines": ["なーんか", "寂しいこと", "言う．．．．．．"]}, {"box": [895, 871, 925, 1026], "vertical": true, "font_size": 27, "lines_coords": [[[895.0, 871.0], [922.0, 871.0], [925.0, 1025.0], [898.0, 1025.0]]], "lines": ["なんだよ．．．"]}, {"box": [164, 993, 257, 1150], "vertical": true, "font_size": 28, "lines_coords": [[[221.0, 993.0], [257.0, 993.0], [257.0, 1053.0], [221.0, 1053.0]], [[196.0, 1000.0], [218.0, 1000.0], [218.0, 1150.0], [196.0, 1150.0]], [[164.0, 998.0], [190.0, 998.0], [190.0, 1101.0], [164.0, 1101.0]]], "lines": ["その", "物言いたげな", "目は．．．．．"]}, {"box": [764, 1271, 831, 1424], "vertical": true, "font_size": 27, "lines_coords": [[[801.0, 1273.0], [829.0, 1273.0], [829.0, 1421.0], [801.0, 1421.0]], [[764.0, 1273.0], [790.0, 1273.0], [790.0, 1398.0], [764.0, 1398.0]]], "lines": ["そんな目で", "見るなよ"]}, {"box": [298, 1276, 387, 1454], "vertical": true, "font_size": 25, "lines_coords": [[[361.0, 1276.0], [387.0, 1276.0], [387.0, 1428.0], [361.0, 1428.0]], [[328.0, 1276.0], [354.0, 1276.0], [353.0, 1454.0], [326.0, 1454.0]], [[298.0, 1279.0], [320.0, 1279.0], [320.0, 1453.0], [298.0, 1453.0]]], "lines": ["しかしなんで", "この時期に雑誌", "創刊さすがね？"]}, {"box": [115, 1337, 237, 1514], "vertical": true, "font_size": 25, "lines_coords": [[[209.0, 1337.0], [237.0, 1337.0], [234.0, 1490.0], [206.0, 1490.0]], [[176.0, 1340.0], [203.0, 1340.0], [201.0, 1514.0], [175.0, 1514.0]], [[146.0, 1337.0], [173.0, 1337.0], [170.0, 1479.0], [143.0, 1479.0]], [[115.0, 1339.0], [137.0, 1339.0], [137.0, 1473.0], [115.0, 1473.0]]], "lines": ["サブカル系の", "エロ雑誌なんて", "今、腐るほど", "あんのにさ。"]}], "img_path": "subarashii_sekai_02_071.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [915, 118, 1006, 352], "vertical": true, "font_size": 27, "lines_coords": [[[978.0, 120.0], [1004.0, 120.0], [1006.0, 351.0], [979.0, 351.0]], [[947.0, 118.0], [975.0, 118.0], [976.0, 323.0], [948.0, 323.0]], [[915.0, 118.0], [942.0, 118.0], [942.0, 317.0], [915.0, 317.0]]], "lines": ["たとえ本が売れても", "俺らにはメリット", "ないってのにさー"]}, {"box": [228, 264, 322, 418], "vertical": true, "font_size": 29, "lines_coords": [[[293.0, 267.0], [320.0, 267.0], [320.0, 418.0], [293.0, 418.0]], [[259.0, 264.0], [292.0, 264.0], [292.0, 371.0], [259.0, 371.0]], [[231.0, 264.0], [257.0, 264.0], [254.0, 418.0], [228.0, 418.0]]], "lines": ["鉄の編集長も", "年で勘が", "鈍ったかな？"]}, {"box": [883, 551, 1008, 754], "vertical": true, "font_size": 26, "lines_coords": [[[981.0, 554.0], [1003.0, 554.0], [1003.0, 703.0], [981.0, 703.0]], [[948.0, 553.0], [975.0, 553.0], [975.0, 754.0], [948.0, 754.0]], [[917.0, 554.0], [943.0, 554.0], [943.0, 679.0], [917.0, 679.0]], [[883.0, 551.0], [911.0, 551.0], [914.0, 668.0], [886.0, 668.0]]], "lines": ["春日部先輩も", "これから編集長の", "尻ぬぐいで", "大変だぁ。"]}, {"box": [128, 659, 225, 829], "vertical": true, "font_size": 31, "lines_coords": [[[193.0, 662.0], [225.0, 662.0], [225.0, 829.0], [193.0, 829.0]], [[164.0, 664.0], [190.0, 664.0], [190.0, 815.0], [164.0, 815.0]], [[128.0, 660.0], [162.0, 659.0], [165.0, 731.0], [131.0, 732.0]]], "lines": ["先輩、編集長に", "恩があるから", "なぁ。"]}, {"box": [903, 839, 997, 1004], "vertical": true, "font_size": 27, "lines_coords": [[[959.0, 840.0], [992.0, 839.0], [997.0, 932.0], [964.0, 934.0]], [[933.0, 842.0], [959.0, 842.0], [959.0, 971.0], [933.0, 971.0]], [[903.0, 840.0], [925.0, 840.0], [925.0, 1004.0], [903.0, 1004.0]]], "lines": ["コラッ、", "聞こえたら", "どーすんだよ。"]}, {"box": [759, 915, 817, 1056], "vertical": true, "font_size": 27, "lines_coords": [[[790.0, 917.0], [817.0, 917.0], [817.0, 1056.0], [790.0, 1056.0]], [[759.0, 915.0], [786.0, 915.0], [786.0, 1045.0], [759.0, 1045.0]]], "lines": ["おい、ハゲ丸", "写真はよ？"]}, {"box": [178, 954, 205, 1117], "vertical": true, "font_size": 26, "lines_coords": [[[178.0, 954.0], [204.0, 954.0], [204.0, 1117.0], [178.0, 1117.0]]], "lines": ["春日部ちゃん。"]}, {"box": [992, 1243, 1028, 1314], "vertical": true, "font_size": 36, "lines_coords": [[[992.0, 1243.0], [1028.0, 1243.0], [1028.0, 1314.0], [992.0, 1314.0]]], "lines": ["いて。"]}, {"box": [647, 1284, 707, 1477], "vertical": true, "font_size": 30, "lines_coords": [[[673.0, 1284.0], [707.0, 1284.0], [707.0, 1357.0], [673.0, 1357.0]], [[647.0, 1287.0], [673.0, 1287.0], [673.0, 1476.0], [647.0, 1476.0]]], "lines": ["あ、今", "持ってきま〜す。"]}, {"box": [121, 1331, 214, 1440], "vertical": true, "font_size": 31, "lines_coords": [[[181.0, 1332.0], [214.0, 1332.0], [214.0, 1440.0], [181.0, 1440.0]], [[150.0, 1331.0], [182.0, 1331.0], [185.0, 1440.0], [153.0, 1440.0]], [[121.0, 1332.0], [150.0, 1332.0], [150.0, 1415.0], [121.0, 1415.0]]], "lines": ["これから", "ちょっと", "どう？"]}], "img_path": "subarashii_sekai_02_072.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [842, 103, 963, 280], "vertical": true, "font_size": 26, "lines_coords": [[[939.0, 106.0], [961.0, 106.0], [961.0, 279.0], [939.0, 279.0]], [[904.0, 104.0], [931.0, 104.0], [931.0, 232.0], [904.0, 232.0]], [[873.0, 103.0], [900.0, 103.0], [900.0, 256.0], [873.0, 256.0]], [[842.0, 103.0], [868.0, 103.0], [868.0, 215.0], [842.0, 215.0]]], "lines": ["僕のわがままで", "仕事忙しく", "させちゃって", "ごめんね。"]}, {"box": [542, 123, 697, 354], "vertical": true, "font_size": 27, "lines_coords": [[[667.0, 123.0], [693.0, 123.0], [697.0, 278.0], [670.0, 278.0]], [[637.0, 123.0], [664.0, 123.0], [664.0, 354.0], [637.0, 354.0]], [[604.0, 123.0], [631.0, 123.0], [631.0, 303.0], [604.0, 303.0]], [[573.0, 123.0], [600.0, 123.0], [600.0, 303.0], [573.0, 303.0]], [[542.0, 123.0], [568.0, 123.0], [568.0, 253.0], [542.0, 253.0]]], "lines": ["そうかぁ．．．", "僕が春日部ちゃんを", "ウチの編集部に", "引っぱってきて", "何年経つ？"]}, {"box": [336, 110, 395, 225], "vertical": true, "font_size": 27, "lines_coords": [[[367.0, 112.0], [395.0, 112.0], [395.0, 204.0], [367.0, 204.0]], [[336.0, 110.0], [362.0, 110.0], [362.0, 225.0], [336.0, 225.0]]], "lines": ["５、６年", "ですかね。"]}, {"box": [137, 329, 170, 446], "vertical": true, "font_size": 30, "lines_coords": [[[137.0, 329.0], [167.0, 329.0], [170.0, 446.0], [140.0, 446.0]]], "lines": ["早いなぁ。"]}, {"box": [809, 346, 933, 545], "vertical": true, "font_size": 26, "lines_coords": [[[906.0, 348.0], [933.0, 348.0], [933.0, 487.0], [906.0, 487.0]], [[876.0, 348.0], [898.0, 348.0], [898.0, 504.0], [876.0, 504.0]], [[840.0, 346.0], [867.0, 346.0], [867.0, 545.0], [840.0, 545.0]], [[809.0, 346.0], [837.0, 346.0], [837.0, 435.0], [809.0, 435.0]]], "lines": ["いえ、俺が今", "食えてんのは、", "編集長のおかげっ", "スから。"]}, {"box": [552, 521, 640, 726], "vertical": true, "font_size": 25, "lines_coords": [[[614.0, 521.0], [640.0, 521.0], [640.0, 673.0], [614.0, 673.0]], [[581.0, 523.0], [607.0, 523.0], [607.0, 631.0], [581.0, 631.0]], [[553.0, 526.0], [575.0, 526.0], [575.0, 726.0], [553.0, 726.0]]], "lines": ["春日部ちゃん", "トコの娘", "いくつになった？"]}, {"box": [142, 618, 240, 776], "vertical": true, "font_size": 32, "lines_coords": [[[200.0, 618.0], [240.0, 618.0], [240.0, 704.0], [200.0, 704.0]], [[175.0, 621.0], [204.0, 621.0], [204.0, 776.0], [175.0, 776.0]], [[142.0, 621.0], [170.0, 621.0], [171.0, 735.0], [143.0, 735.0]]], "lines": ["今週の", "木曜で一歳に", "なります。"]}, {"box": [887, 834, 1014, 1073], "vertical": true, "font_size": 26, "lines_coords": [[[976.0, 835.0], [1009.0, 834.0], [1014.0, 951.0], [981.0, 953.0]], [[950.0, 835.0], [976.0, 835.0], [976.0, 1037.0], [950.0, 1037.0]], [[922.0, 837.0], [943.0, 837.0], [943.0, 1050.0], [922.0, 1050.0]], [[889.0, 835.0], [912.0, 835.0], [911.0, 1073.0], [887.0, 1073.0]]], "lines": ["そうかぁ。", "じゃあ仕事早めに", "片付けて、ゆっくり", "祝いたいとこだよね。"]}, {"box": [477, 846, 568, 1028], "vertical": true, "font_size": 27, "lines_coords": [[[536.0, 846.0], [568.0, 846.0], [568.0, 931.0], [536.0, 931.0]], [[506.0, 851.0], [532.0, 851.0], [532.0, 978.0], [506.0, 978.0]], [[478.0, 853.0], [500.0, 853.0], [500.0, 1028.0], [478.0, 1028.0]]], "lines": ["どう？", "父親一年間", "やった感想は？"]}, {"box": [823, 1320, 848, 1472], "vertical": true, "font_size": 22, "lines_coords": [[[823.0, 1320.0], [845.0, 1320.0], [845.0, 1468.0], [823.0, 1468.0]]], "lines": ["そっすね．．．"]}, {"box": [148, 1286, 175, 1443], "vertical": true, "font_size": 27, "lines_coords": [[[148.0, 1286.0], [175.0, 1286.0], [175.0, 1443.0], [148.0, 1443.0]]], "lines": ["．．．．．．"]}], "img_path": "subarashii_sekai_02_073.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [848, 130, 873, 304], "vertical": true, "font_size": 22, "lines_coords": [[[848.0, 131.0], [870.0, 131.0], [870.0, 303.0], [848.0, 303.0]]], "lines": ["孤独じゃない？"]}, {"box": [364, 1001, 454, 1217], "vertical": true, "font_size": 29, "lines_coords": [[[428.0, 1004.0], [454.0, 1004.0], [454.0, 1179.0], [428.0, 1179.0]], [[396.0, 1003.0], [423.0, 1003.0], [423.0, 1165.0], [396.0, 1165.0]], [[364.0, 1001.0], [390.0, 1001.0], [392.0, 1217.0], [365.0, 1217.0]]], "lines": ["気付けば女房は", "太って、ただの", "オバサンになって。"]}, {"box": [126, 1068, 248, 1275], "vertical": true, "font_size": 29, "lines_coords": [[[221.0, 1070.0], [248.0, 1070.0], [248.0, 1273.0], [221.0, 1273.0]], [[189.0, 1068.0], [220.0, 1068.0], [220.0, 1275.0], [189.0, 1275.0]], [[159.0, 1070.0], [187.0, 1071.0], [181.0, 1223.0], [153.0, 1221.0]], [[126.0, 1071.0], [154.0, 1071.0], [154.0, 1182.0], [126.0, 1182.0]]], "lines": ["息子はアメリカの", "ギャング真似して", "「ＹＯ！！」だの", "言ってる。"]}, {"box": [915, 1223, 973, 1437], "vertical": true, "font_size": 25, "lines_coords": [[[945.0, 1223.0], [973.0, 1223.0], [973.0, 1335.0], [945.0, 1335.0]], [[915.0, 1223.0], [942.0, 1223.0], [942.0, 1437.0], [915.0, 1437.0]]], "lines": ["ごめんね、", "ヘンなコト言って。"]}, {"box": [729, 1306, 786, 1467], "vertical": true, "font_size": 25, "lines_coords": [[[764.0, 1307.0], [786.0, 1307.0], [786.0, 1457.0], [764.0, 1457.0]], [[731.0, 1306.0], [754.0, 1306.0], [753.0, 1467.0], [729.0, 1467.0]]], "lines": ["ただ僕は．．．", "僕は孤独だよ。"]}, {"box": [162, 1332, 289, 1515], "vertical": true, "font_size": 29, "lines_coords": [[[259.0, 1335.0], [287.0, 1335.0], [289.0, 1464.0], [260.0, 1464.0]], [[228.0, 1337.0], [256.0, 1337.0], [256.0, 1442.0], [228.0, 1442.0]], [[196.0, 1332.0], [225.0, 1332.0], [226.0, 1515.0], [198.0, 1515.0]], [[162.0, 1332.0], [198.0, 1332.0], [198.0, 1406.0], [162.0, 1406.0]]], "lines": ["いつの間に", "外国人に", "なっちゃったん", "だか。"]}], "img_path": "subarashii_sekai_02_074.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [911, 93, 1001, 285], "vertical": true, "font_size": 25, "lines_coords": [[[975.0, 95.0], [1001.0, 95.0], [998.0, 225.0], [972.0, 225.0]], [[940.0, 93.0], [967.0, 93.0], [967.0, 259.0], [940.0, 259.0]], [[912.0, 96.0], [934.0, 96.0], [934.0, 282.0], [912.0, 282.0]]], "lines": ["家族のはず", "なのに、まるで", "他人のようだよ。"]}, {"box": [617, 98, 742, 328], "vertical": true, "font_size": 26, "lines_coords": [[[712.0, 101.0], [739.0, 101.0], [742.0, 253.0], [715.0, 253.0]], [[684.0, 98.0], [707.0, 98.0], [709.0, 276.0], [686.0, 276.0]], [[651.0, 100.0], [678.0, 100.0], [678.0, 328.0], [651.0, 328.0]], [[617.0, 98.0], [643.0, 98.0], [647.0, 265.0], [620.0, 265.0]]], "lines": ["一応これでも", "それなりに父親", "頑張ってきたつもり", "なんだけども。"]}, {"box": [468, 181, 557, 362], "vertical": true, "font_size": 26, "lines_coords": [[[531.0, 181.0], [557.0, 181.0], [557.0, 346.0], [531.0, 346.0]], [[500.0, 182.0], [526.0, 182.0], [526.0, 362.0], [500.0, 362.0]], [[468.0, 182.0], [495.0, 182.0], [495.0, 318.0], [468.0, 318.0]]], "lines": ["ま、これが今の", "リアルな父親像", "なのかもね。"]}, {"box": [92, 56, 336, 82], "vertical": false, "font_size": 26, "lines_coords": [[[92.0, 56.0], [336.0, 56.0], [336.0, 82.0], [92.0, 82.0]]], "lines": ["素晴らしい世界って"]}, {"box": [854, 728, 912, 854], "vertical": true, "font_size": 26, "lines_coords": [[[886.0, 728.0], [912.0, 728.0], [912.0, 854.0], [886.0, 854.0]], [[854.0, 728.0], [881.0, 728.0], [881.0, 832.0], [854.0, 832.0]]], "lines": ["思えば僕の", "長い人生"]}, {"box": [667, 426, 756, 579], "vertical": true, "font_size": 26, "lines_coords": [[[729.0, 428.0], [756.0, 428.0], [756.0, 579.0], [729.0, 579.0]], [[697.0, 426.0], [723.0, 426.0], [726.0, 554.0], [700.0, 554.0]], [[667.0, 429.0], [693.0, 429.0], [693.0, 565.0], [667.0, 565.0]]], "lines": ["きのう息子に", "思いっきり", "殴られてさ。"]}, {"box": [107, 471, 198, 650], "vertical": true, "font_size": 27, "lines_coords": [[[168.0, 473.0], [196.0, 473.0], [198.0, 601.0], [170.0, 601.0]], [[135.0, 471.0], [162.0, 471.0], [165.0, 650.0], [139.0, 650.0]], [[107.0, 473.0], [134.0, 473.0], [134.0, 564.0], [107.0, 564.0]]], "lines": ["理由はよく", "わからないんだ", "けども。"]}, {"box": [185, 951, 245, 1103], "vertical": true, "font_size": 24, "lines_coords": [[[220.0, 953.0], [242.0, 953.0], [242.0, 1103.0], [220.0, 1103.0]], [[185.0, 951.0], [212.0, 951.0], [212.0, 1065.0], [185.0, 1065.0]]], "lines": ["なんだったん", "だろうね。"]}, {"box": [839, 1176, 931, 1354], "vertical": true, "font_size": 27, "lines_coords": [[[904.0, 1178.0], [931.0, 1178.0], [931.0, 1354.0], [904.0, 1354.0]], [[873.0, 1178.0], [900.0, 1178.0], [900.0, 1314.0], [873.0, 1314.0]], [[839.0, 1176.0], [867.0, 1176.0], [868.0, 1281.0], [840.0, 1281.0]]], "lines": ["ホントひとりで", "帰れますか、", "編集長？"]}, {"box": [135, 1292, 194, 1470], "vertical": true, "font_size": 24, "lines_coords": [[[164.0, 1292.0], [190.0, 1292.0], [193.0, 1453.0], [167.0, 1453.0]], [[135.0, 1295.0], [157.0, 1295.0], [157.0, 1470.0], [135.0, 1470.0]]], "lines": ["だいじょーぶ、", "だーいじょぶ！！"]}], "img_path": "subarashii_sekai_02_075.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [890, 71, 1014, 259], "vertical": true, "font_size": 27, "lines_coords": [[[987.0, 73.0], [1014.0, 73.0], [1014.0, 259.0], [987.0, 259.0]], [[956.0, 71.0], [983.0, 71.0], [979.0, 251.0], [953.0, 251.0]], [[923.0, 73.0], [950.0, 73.0], [950.0, 200.0], [923.0, 200.0]], [[892.0, 71.0], [918.0, 71.0], [917.0, 251.0], [890.0, 251.0]]], "lines": ["とにかくだなぁ、", "今回の新創刊は", "僕の最後の", "悪あがきなの！"]}, {"box": [757, 229, 793, 310], "vertical": true, "font_size": 33, "lines_coords": [[[757.0, 231.0], [790.0, 229.0], [793.0, 309.0], [761.0, 310.0]]], "lines": ["最後？"]}, {"box": [528, 135, 614, 286], "vertical": true, "font_size": 22, "lines_coords": [[[589.0, 135.0], [612.0, 135.0], [614.0, 237.0], [590.0, 237.0]], [[559.0, 137.0], [581.0, 137.0], [581.0, 285.0], [559.0, 285.0]], [[528.0, 137.0], [550.0, 137.0], [550.0, 270.0], [528.0, 270.0]]], "lines": ["もうじき", "僕は解雇され", "ちゃうのさ。"]}, {"box": [364, 354, 429, 532], "vertical": true, "font_size": 28, "lines_coords": [[[387.0, 356.0], [426.0, 354.0], [429.0, 450.0], [390.0, 451.0]], [[364.0, 359.0], [390.0, 359.0], [390.0, 532.0], [364.0, 532.0]]], "lines": ["ホント、", "トホホだよ．．．"]}, {"box": [273, 593, 393, 800], "vertical": true, "font_size": 28, "lines_coords": [[[367.0, 593.0], [393.0, 593.0], [390.0, 773.0], [364.0, 773.0]], [[332.0, 593.0], [359.0, 593.0], [359.0, 800.0], [332.0, 800.0]], [[301.0, 595.0], [328.0, 595.0], [328.0, 698.0], [301.0, 698.0]], [[273.0, 595.0], [295.0, 595.0], [295.0, 754.0], [273.0, 754.0]]], "lines": ["春日部ちゃんに", "こんな情けない姿", "見せたく", "なかったけど、"]}, {"box": [923, 814, 983, 995], "vertical": true, "font_size": 27, "lines_coords": [[[951.0, 814.0], [983.0, 814.0], [983.0, 995.0], [951.0, 995.0]], [[925.0, 817.0], [947.0, 817.0], [947.0, 950.0], [925.0, 950.0]]], "lines": ["まぁ僕ら二人の", "最後の仕事、"]}, {"box": [165, 1007, 235, 1264], "vertical": true, "font_size": 32, "lines_coords": [[[203.0, 1007.0], [235.0, 1007.0], [235.0, 1190.0], [203.0, 1190.0]], [[165.0, 1009.0], [196.0, 1009.0], [196.0, 1264.0], [165.0, 1264.0]]], "lines": ["満足いくまで", "ガッツリやろーよ。"]}], "img_path": "subarashii_sekai_02_076.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [240, 371, 304, 514], "vertical": true, "font_size": 30, "lines_coords": [[[270.0, 371.0], [304.0, 371.0], [304.0, 440.0], [270.0, 440.0]], [[243.0, 373.0], [270.0, 373.0], [267.0, 514.0], [240.0, 514.0]]], "lines": ["ああ、", "風がぬるい。"]}, {"box": [701, 932, 856, 1135], "vertical": true, "font_size": 29, "lines_coords": [[[823.0, 932.0], [856.0, 932.0], [856.0, 1021.0], [823.0, 1021.0]], [[790.0, 932.0], [825.0, 932.0], [825.0, 1020.0], [790.0, 1020.0]], [[761.0, 934.0], [789.0, 934.0], [789.0, 1060.0], [761.0, 1060.0]], [[729.0, 932.0], [756.0, 932.0], [757.0, 1135.0], [731.0, 1135.0]], [[701.0, 937.0], [723.0, 937.0], [723.0, 1093.0], [701.0, 1093.0]]], "lines": ["つまり、", "それは、", "俺もいずれ", "そうなるってコト", "なんだろうか"]}, {"box": [471, 934, 534, 1098], "vertical": true, "font_size": 26, "lines_coords": [[[506.0, 935.0], [532.0, 935.0], [532.0, 1067.0], [506.0, 1067.0]], [[471.0, 934.0], [498.0, 934.0], [503.0, 1098.0], [476.0, 1098.0]]], "lines": ["正解もない", "逃げ場もない。"]}, {"box": [336, 935, 429, 1064], "vertical": true, "font_size": 29, "lines_coords": [[[395.0, 935.0], [429.0, 935.0], [429.0, 1017.0], [395.0, 1017.0]], [[367.0, 937.0], [393.0, 937.0], [393.0, 1064.0], [367.0, 1064.0]], [[336.0, 939.0], [362.0, 939.0], [362.0, 1064.0], [336.0, 1064.0]]], "lines": ["それが", "父親の運命", "なのかよ？"]}, {"box": [901, 1179, 944, 1343], "vertical": true, "font_size": 39, "lines_coords": [[[901.0, 1179.0], [940.0, 1179.0], [943.0, 1343.0], [904.0, 1343.0]]], "lines": ["先輩っ！！"]}, {"box": [153, 1260, 248, 1465], "vertical": true, "font_size": 40, "lines_coords": [[[204.0, 1260.0], [248.0, 1260.0], [248.0, 1465.0], [204.0, 1465.0]], [[156.0, 1262.0], [193.0, 1262.0], [190.0, 1465.0], [153.0, 1465.0]]], "lines": ["どこ行って", "たんスか！？"]}], "img_path": "subarashii_sekai_02_077.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [950, 123, 1009, 260], "vertical": true, "font_size": 24, "lines_coords": [[[979.0, 123.0], [1006.0, 123.0], [1009.0, 259.0], [983.0, 259.0]], [[950.0, 125.0], [972.0, 125.0], [972.0, 234.0], [950.0, 234.0]]], "lines": ["うるせーよ、", "散歩だよ。"]}, {"box": [523, 95, 612, 295], "vertical": true, "font_size": 25, "lines_coords": [[[586.0, 95.0], [612.0, 95.0], [612.0, 223.0], [586.0, 223.0]], [[551.0, 96.0], [578.0, 96.0], [578.0, 295.0], [551.0, 295.0]], [[523.0, 96.0], [545.0, 96.0], [545.0, 245.0], [523.0, 245.0]]], "lines": ["編集長なら", "一時間くらい前に", "別れたけど？"]}, {"box": [759, 498, 806, 703], "vertical": true, "font_size": 44, "lines_coords": [[[759.0, 498.0], [803.0, 498.0], [806.0, 703.0], [762.0, 703.0]]], "lines": ["編集長が！！"]}, {"box": [132, 457, 242, 672], "vertical": true, "font_size": 31, "lines_coords": [[[209.0, 457.0], [242.0, 457.0], [242.0, 584.0], [209.0, 584.0]], [[167.0, 457.0], [200.0, 457.0], [203.0, 582.0], [170.0, 582.0]], [[132.0, 457.0], [160.0, 457.0], [162.0, 671.0], [134.0, 671.0]]], "lines": ["今さっき", "救急車で", "運ばれたって！！"]}, {"box": [937, 724, 972, 900], "vertical": true, "font_size": 33, "lines_coords": [[[937.0, 726.0], [970.0, 726.0], [970.0, 900.0], [937.0, 900.0]]], "lines": ["なんでよ！？"]}, {"box": [904, 1049, 964, 1203], "vertical": true, "font_size": 28, "lines_coords": [[[936.0, 1050.0], [964.0, 1050.0], [964.0, 1160.0], [936.0, 1160.0]], [[904.0, 1050.0], [931.0, 1050.0], [931.0, 1196.0], [904.0, 1196.0]]], "lines": ["．．．．．．．な、", "なんか．．．．．．"]}, {"box": [209, 803, 251, 965], "vertical": true, "font_size": 39, "lines_coords": [[[209.0, 803.0], [248.0, 803.0], [251.0, 965.0], [212.0, 965.0]]], "lines": ["おうっ！！"]}, {"box": [264, 1054, 353, 1307], "vertical": true, "font_size": 26, "lines_coords": [[[325.0, 1054.0], [351.0, 1054.0], [353.0, 1307.0], [326.0, 1307.0]], [[292.0, 1054.0], [318.0, 1054.0], [321.0, 1182.0], [295.0, 1182.0]], [[264.0, 1056.0], [290.0, 1056.0], [290.0, 1242.0], [264.0, 1242.0]]], "lines": ["街のガキンチョたちに", "からまれて", "フクロにされて、"]}, {"box": [150, 1309, 243, 1465], "vertical": true, "font_size": 26, "lines_coords": [[[215.0, 1312.0], [243.0, 1312.0], [243.0, 1414.0], [215.0, 1414.0]], [[184.0, 1314.0], [210.0, 1314.0], [210.0, 1442.0], [184.0, 1442.0]], [[150.0, 1309.0], [176.0, 1309.0], [179.0, 1465.0], [153.0, 1465.0]]], "lines": ["イロイロ", "ヤバイ状態", "らしいス．．．"]}], "img_path": "subarashii_sekai_02_078.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [904, 153, 1031, 395], "vertical": true, "font_size": 29, "lines_coords": [[[1001.0, 154.0], [1031.0, 154.0], [1031.0, 309.0], [1001.0, 309.0]], [[970.0, 153.0], [997.0, 153.0], [997.0, 395.0], [970.0, 395.0]], [[936.0, 153.0], [967.0, 153.0], [967.0, 342.0], [936.0, 342.0]], [[904.0, 154.0], [933.0, 154.0], [933.0, 307.0], [904.0, 307.0]]], "lines": ["最近そーゆー", "事件、多かったけど．．．", "編集長、運悪いっ", "つーか．．．．．．"]}, {"box": [594, 110, 716, 342], "vertical": true, "font_size": 26, "lines_coords": [[[687.0, 115.0], [715.0, 115.0], [715.0, 229.0], [687.0, 229.0]], [[654.0, 112.0], [682.0, 112.0], [681.0, 342.0], [653.0, 342.0]], [[623.0, 110.0], [650.0, 110.0], [650.0, 321.0], [623.0, 321.0]], [[595.0, 114.0], [617.0, 114.0], [617.0, 248.0], [595.0, 248.0]]], "lines": ["いや、でも", "死んではいないんで", "それはよかったね。", "なんスけど。"]}, {"box": [104, 65, 346, 92], "vertical": false, "font_size": 27, "lines_coords": [[[104.0, 65.0], [346.0, 65.0], [346.0, 92.0], [104.0, 92.0]]], "lines": ["素晴らしい世界の"]}, {"box": [121, 190, 213, 368], "vertical": true, "font_size": 25, "lines_coords": [[[185.0, 190.0], [212.0, 190.0], [212.0, 320.0], [185.0, 320.0]], [[153.0, 190.0], [179.0, 190.0], [179.0, 318.0], [153.0, 318.0]], [[121.0, 190.0], [143.0, 190.0], [146.0, 367.0], [125.0, 367.0]]], "lines": ["とりあえず", "雑誌創刊は", "無理ですね．．．"]}, {"box": [181, 484, 246, 601], "vertical": true, "font_size": 34, "lines_coords": [[[214.0, 487.0], [246.0, 487.0], [246.0, 601.0], [214.0, 601.0]], [[181.0, 484.0], [217.0, 484.0], [217.0, 557.0], [181.0, 557.0]]], "lines": ["．．．いや、", "やる。"]}, {"box": [231, 950, 268, 1143], "vertical": true, "font_size": 37, "lines_coords": [[[231.0, 950.0], [268.0, 950.0], [268.0, 1142.0], [231.0, 1142.0]]], "lines": ["やってやる。"]}, {"box": [799, 1283, 883, 1475], "vertical": true, "font_size": 84, "lines_coords": [[[799.0, 1283.0], [883.0, 1283.0], [883.0, 1475.0], [799.0, 1475.0]]], "lines": ["わォわタ"]}, {"box": [187, 1338, 215, 1479], "vertical": true, "font_size": 27, "lines_coords": [[[187.0, 1340.0], [214.0, 1340.0], [214.0, 1478.0], [187.0, 1478.0]]], "lines": ["．．．．．．って。"]}], "img_path": "subarashii_sekai_02_079.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [933, 117, 993, 254], "vertical": true, "font_size": 29, "lines_coords": [[[961.0, 117.0], [993.0, 117.0], [993.0, 204.0], [961.0, 204.0]], [[933.0, 118.0], [959.0, 118.0], [959.0, 251.0], [933.0, 251.0]]], "lines": ["凄いね、", "春日部さん。"]}, {"box": [545, 117, 640, 296], "vertical": true, "font_size": 30, "lines_coords": [[[607.0, 117.0], [640.0, 117.0], [637.0, 248.0], [604.0, 248.0]], [[579.0, 118.0], [607.0, 118.0], [603.0, 296.0], [575.0, 296.0]], [[548.0, 118.0], [576.0, 118.0], [573.0, 221.0], [545.0, 221.0]]], "lines": ["「