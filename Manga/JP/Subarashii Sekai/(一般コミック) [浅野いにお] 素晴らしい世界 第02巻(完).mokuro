 "どーにかしてよ。"]}, {"box": [150, 546, 243, 653], "vertical": true, "font_size": 26, "lines_coords": [[[215.0, 550.0], [243.0, 550.0], [243.0, 629.0], [215.0, 629.0]], [[182.0, 550.0], [210.0, 550.0], [210.0, 653.0], [182.0, 653.0]], [[150.0, 546.0], [181.0, 546.0], [181.0, 593.0], [150.0, 593.0]]], "lines": ["今日も", "雨だから", "なー"]}, {"box": [104, 693, 221, 871], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 695.0], [221.0, 695.0], [221.0, 868.0], [200.0, 868.0]], [[167.0, 693.0], [193.0, 693.0], [193.0, 871.0], [167.0, 871.0]], [[134.0, 693.0], [160.0, 693.0], [160.0, 870.0], [134.0, 870.0]], [[104.0, 695.0], [126.0, 695.0], [126.0, 798.0], [104.0, 798.0]]], "lines": ["タエのいつもの", "ヤッ、そろそろ", "始まったんじゃ", "ないの？"]}, {"box": [198, 971, 231, 1054], "vertical": true, "font_size": 28, "lines_coords": [[[198.0, 971.0], [231.0, 971.0], [231.0, 1054.0], [198.0, 1054.0]]], "lines": ["タエ！"]}, {"box": [192, 1104, 279, 1284], "vertical": true, "font_size": 28, "lines_coords": [[[253.0, 1106.0], [279.0, 1106.0], [279.0, 1284.0], [253.0, 1284.0]], [[217.0, 1104.0], [250.0, 1104.0], [250.0, 1189.0], [217.0, 1189.0]], [[192.0, 1107.0], [214.0, 1107.0], [214.0, 1284.0], [192.0, 1284.0]]], "lines": ["今日はちゃんと", "予備校", "行きなさいよ！"]}], "img_path": "subarashii_sekai_02_023.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [698, 78, 788, 305], "vertical": true, "font_size": 25, "lines_coords": [[[765.0, 81.0], [787.0, 81.0], [787.0, 304.0], [765.0, 304.0]], [[728.0, 78.0], [754.0, 78.0], [757.0, 304.0], [731.0, 304.0]], [[698.0, 81.0], [725.0, 81.0], [725.0, 218.0], [698.0, 218.0]]], "lines": ["たとえ今日が雨でも", "そのうち晴れの日が", "くるワケて"]}, {"box": [315, 78, 468, 379], "vertical": true, "font_size": 26, "lines_coords": [[[442.0, 78.0], [468.0, 78.0], [468.0, 301.0], [442.0, 301.0]], [[409.0, 79.0], [436.0, 79.0], [436.0, 285.0], [409.0, 285.0]], [[376.0, 78.0], [404.0, 78.0], [406.0, 379.0], [378.0, 379.0]], [[346.0, 78.0], [373.0, 78.0], [373.0, 310.0], [346.0, 310.0]], [[315.0, 81.0], [337.0, 81.0], [337.0, 273.0], [315.0, 273.0]]], "lines": ["だから今のあたしの", "このローな気分も、", "いつか晴れやかになるって", "信じてるんだけどね", "信じてるんだけどさ"]}, {"box": [925, 404, 948, 534], "vertical": true, "font_size": 22, "lines_coords": [[[925.0, 404.0], [947.0, 404.0], [947.0, 531.0], [925.0, 531.0]]], "lines": ["うーん．．．"]}, {"box": [628, 742, 725, 850], "vertical": true, "font_size": 33, "lines_coords": [[[686.0, 742.0], [725.0, 742.0], [725.0, 828.0], [686.0, 828.0]], [[656.0, 743.0], [689.0, 742.0], [692.0, 848.0], [659.0, 850.0]], [[628.0, 745.0], [656.0, 745.0], [656.0, 850.0], [628.0, 850.0]]], "lines": ["あれ？", "兄ちゃん", "大学は？"]}, {"box": [182, 509, 240, 686], "vertical": true, "font_size": 28, "lines_coords": [[[212.0, 510.0], [240.0, 510.0], [240.0, 610.0], [212.0, 610.0]], [[182.0, 509.0], [209.0, 509.0], [209.0, 612.0], [182.0, 612.0]]], "lines": ["ユーウツ", "なりぃー"]}, {"box": [843, 798, 993, 1039], "vertical": true, "font_size": 27, "lines_coords": [[[965.0, 800.0], [992.0, 800.0], [992.0, 976.0], [965.0, 976.0]], [[933.0, 798.0], [961.0, 798.0], [964.0, 939.0], [936.0, 939.0]], [[900.0, 798.0], [931.0, 798.0], [931.0, 1039.0], [900.0, 1039.0]], [[872.0, 801.0], [898.0, 801.0], [898.0, 987.0], [872.0, 987.0]], [[843.0, 803.0], [865.0, 803.0], [865.0, 985.0], [843.0, 985.0]]], "lines": ["なぜかイライラ", "するワケさ。", "特に、ねーちゃんとか", "ねーちゃんとか、", "ねーちゃんとか。"]}, {"box": [164, 810, 220, 950], "vertical": true, "font_size": 27, "lines_coords": [[[193.0, 810.0], [220.0, 810.0], [220.0, 926.0], [193.0, 926.0]], [[164.0, 810.0], [190.0, 810.0], [190.0, 950.0], [164.0, 950.0]]], "lines": ["おう、今日", "休講ってさ。"]}, {"box": [145, 998, 237, 1150], "vertical": true, "font_size": 27, "lines_coords": [[[203.0, 1001.0], [237.0, 1001.0], [237.0, 1092.0], [203.0, 1092.0]], [[175.0, 1000.0], [201.0, 1000.0], [201.0, 1129.0], [175.0, 1129.0]], [[145.0, 998.0], [167.0, 998.0], [167.0, 1150.0], [145.0, 1150.0]]], "lines": ["つーか、", "おまえこそ", "予備校はよ？"]}, {"box": [753, 1168, 877, 1431], "vertical": true, "font_size": 25, "lines_coords": [[[851.0, 1171.0], [873.0, 1171.0], [873.0, 1320.0], [851.0, 1320.0]], [[820.0, 1171.0], [842.0, 1171.0], [842.0, 1429.0], [820.0, 1429.0]], [[787.0, 1170.0], [814.0, 1170.0], [814.0, 1407.0], [787.0, 1407.0]], [[753.0, 1168.0], [781.0, 1168.0], [782.0, 1420.0], [754.0, 1420.0]]], "lines": ["なんてだろ？", "一感謝してるつもりだけどさ、", "きっと雨が悪いんだ。", "梅雨、死ねってことで。"]}, {"box": [156, 1328, 251, 1493], "vertical": true, "font_size": 28, "lines_coords": [[[218.0, 1328.0], [251.0, 1328.0], [251.0, 1420.0], [218.0, 1420.0]], [[189.0, 1329.0], [215.0, 1329.0], [215.0, 1459.0], [189.0, 1459.0]], [[156.0, 1328.0], [182.0, 1328.0], [185.0, 1493.0], [159.0, 1493.0]]], "lines": ["んー、", "だるいから", "今日はパスで。"]}], "img_path": "subarashii_sekai_02_024.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [253, 572, 270, 608], "vertical": true, "font_size": 17, "lines_coords": [[[253.0, 572.0], [270.0, 572.0], [270.0, 608.0], [253.0, 608.0]]], "lines": ["コテッ"]}, {"box": [828, 692, 921, 921], "vertical": true, "font_size": 25, "lines_coords": [[[897.0, 695.0], [918.0, 695.0], [918.0, 870.0], [897.0, 870.0]], [[862.0, 693.0], [889.0, 693.0], [889.0, 921.0], [862.0, 921.0]], [[828.0, 692.0], [856.0, 692.0], [859.0, 801.0], [831.0, 801.0]]], "lines": ["こんな赤す日は", "どーでもいいことを", "考えよう"]}, {"box": [682, 693, 779, 1011], "vertical": true, "font_size": 30, "lines_coords": [[[745.0, 695.0], [779.0, 695.0], [779.0, 775.0], [745.0, 775.0]], [[714.0, 693.0], [742.0, 693.0], [743.0, 896.0], [715.0, 896.0]], [[682.0, 695.0], [709.0, 695.0], [712.0, 1006.0], [686.0, 1006.0]]], "lines": ["例えば", "オタマシャクシが", "カエルになることについて、"]}, {"box": [414, 692, 568, 931], "vertical": true, "font_size": 27, "lines_coords": [[[537.0, 692.0], [564.0, 692.0], [565.0, 871.0], [539.0, 871.0]], [[504.0, 692.0], [531.0, 692.0], [534.0, 821.0], [507.0, 821.0]], [[471.0, 693.0], [498.0, 693.0], [503.0, 929.0], [476.0, 929.0]], [[440.0, 693.0], [468.0, 693.0], [471.0, 848.0], [443.0, 848.0]], [[414.0, 693.0], [440.0, 693.0], [445.0, 846.0], [418.0, 846.0]]], "lines": ["だってアレって", "どー見ても", "別の生き物じゃんか。", "〈やべー、ホント", "とーてもいいわ"]}, {"box": [151, 894, 176, 1006], "vertical": true, "font_size": 17, "lines_coords": [[[154.0, 898.0], [171.0, 898.0], [171.0, 998.0], [154.0, 998.0]]], "lines": ["はちゃお"]}, {"box": [130, 1077, 409, 1167], "vertical": false, "font_size": 30, "lines_coords": [[[139.0, 1084.0], [400.0, 1084.0], [400.0, 1110.0], [139.0, 1110.0]], [[132.0, 1126.0], [306.0, 1129.0], [306.0, 1162.0], [132.0, 1159.0]]], "lines": ["「ｉｔｈｏｎ．．．", "雨のち晴れ"]}, {"box": [892, 1351, 950, 1398], "vertical": false, "font_size": 40, "lines_coords": [[[898.0, 1351.0], [950.0, 1359.0], [943.0, 1398.0], [892.0, 1390.0]]], "lines": ["．．"]}, {"box": [453, 1179, 496, 1259], "vertical": true, "font_size": 37, "lines_coords": [[[453.0, 1182.0], [490.0, 1179.0], [496.0, 1256.0], [459.0, 1259.0]]], "lines": ["ゲコッ"]}, {"box": [248, 1329, 840, 1484], "vertical": false, "font_size": 88.5, "lines_coords": [[[298.0, 1329.0], [840.0, 1354.0], [834.0, 1484.0], [292.0, 1459.0]], [[248.0, 1373.0], [334.0, 1370.0], [336.0, 1417.0], [250.0, 1420.0]]], "lines": ["声らしいぜ。", "．．．"]}], "img_path": "subarashii_sekai_02_025.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [909, 143, 995, 278], "vertical": true, "font_size": 25, "lines_coords": [[[972.0, 148.0], [993.0, 148.0], [993.0, 254.0], [972.0, 254.0]], [[934.0, 143.0], [967.0, 143.0], [967.0, 226.0], [934.0, 226.0]], [[909.0, 148.0], [931.0, 148.0], [931.0, 275.0], [909.0, 275.0]]], "lines": ["いや、まぁ", "我々も", "大変ですよ。"]}, {"box": [267, 96, 431, 285], "vertical": true, "font_size": 26, "lines_coords": [[[396.0, 98.0], [425.0, 98.0], [425.0, 250.0], [396.0, 250.0]], [[368.0, 98.0], [395.0, 98.0], [392.0, 250.0], [365.0, 250.0]], [[334.0, 98.0], [362.0, 98.0], [359.0, 209.0], [331.0, 209.0]], [[304.0, 100.0], [326.0, 100.0], [326.0, 225.0], [304.0, 225.0]], [[271.0, 96.0], [298.0, 96.0], [293.0, 285.0], [267.0, 285.0]]], "lines": ["車に轢かれて", "ペシャンコに", "なったり、", "子供に爆竹", "突っ込まれたり。"]}, {"box": [318, 326, 362, 400], "vertical": true, "font_size": 36, "lines_coords": [[[318.0, 331.0], [354.0, 326.0], [362.0, 395.0], [326.0, 400.0]]], "lines": ["ハァ。"]}, {"box": [908, 367, 947, 437], "vertical": true, "font_size": 36, "lines_coords": [[[908.0, 368.0], [943.0, 367.0], [947.0, 435.0], [911.0, 437.0]]], "lines": ["ハァ。"]}, {"box": [868, 662, 993, 915], "vertical": true, "font_size": 26, "lines_coords": [[[965.0, 662.0], [992.0, 662.0], [993.0, 854.0], [967.0, 854.0]], [[937.0, 667.0], [959.0, 667.0], [959.0, 890.0], [937.0, 890.0]], [[904.0, 667.0], [926.0, 667.0], [926.0, 915.0], [904.0, 915.0]], [[868.0, 662.0], [900.0, 662.0], [900.0, 828.0], [868.0, 828.0]]], "lines": ["とはいえ、やはり", "ひとり立ちするには", "外の世界の厳しさにも", "触れませんと。"]}, {"box": [123, 428, 277, 655], "vertical": true, "font_size": 23, "lines_coords": [[[251.0, 429.0], [273.0, 429.0], [273.0, 645.0], [251.0, 645.0]], [[218.0, 429.0], [240.0, 429.0], [240.0, 654.0], [218.0, 654.0]], [[185.0, 428.0], [212.0, 428.0], [212.0, 607.0], [185.0, 607.0]], [[156.0, 428.0], [178.0, 428.0], [178.0, 590.0], [156.0, 590.0]], [[123.0, 428.0], [145.0, 428.0], [146.0, 587.0], [125.0, 587.0]]], "lines": ["オタマジャクシ時代に", "水の中で仲間たちと", "泳ぎまわってた", "頃を、懐かしむ", "時もあります。"]}, {"box": [482, 945, 623, 1125], "vertical": true, "font_size": 27, "lines_coords": [[[575.0, 951.0], [597.0, 951.0], [597.0, 1123.0], [575.0, 1123.0]], [[532.0, 946.0], [568.0, 945.0], [572.0, 1035.0], [536.0, 1037.0]], [[512.0, 948.0], [534.0, 948.0], [534.0, 1079.0], [512.0, 1079.0]], [[482.0, 946.0], [509.0, 946.0], [512.0, 1078.0], [486.0, 1078.0]]], "lines": ["とうてすかって", "アンタ", "くだらない夢", "見ちゃったよ"]}, {"box": [223, 768, 280, 919], "vertical": true, "font_size": 24, "lines_coords": [[[253.0, 768.0], [279.0, 768.0], [279.0, 870.0], [253.0, 870.0]], [[223.0, 768.0], [245.0, 768.0], [245.0, 918.0], [223.0, 918.0]]], "lines": ["あなたは", "どうですか？"]}, {"box": [153, 1248, 225, 1434], "vertical": true, "font_size": 32, "lines_coords": [[[189.0, 1248.0], [221.0, 1248.0], [225.0, 1415.0], [192.0, 1415.0]], [[153.0, 1250.0], [184.0, 1250.0], [184.0, 1434.0], [153.0, 1434.0]]], "lines": ["タエーーっ、", "ゆうはーん！！"]}], "img_path": "subarashii_sekai_02_026.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [720, 85, 811, 289], "vertical": true, "font_size": 26, "lines_coords": [[[782.0, 87.0], [809.0, 87.0], [809.0, 228.0], [782.0, 228.0]], [[751.0, 87.0], [778.0, 87.0], [778.0, 215.0], [751.0, 215.0]], [[720.0, 85.0], [743.0, 85.0], [745.0, 289.0], [722.0, 289.0]]], "lines": ["タエ、あんた", "また一日中", "寝てたんでしょ？"]}, {"box": [604, 207, 642, 281], "vertical": true, "font_size": 35, "lines_coords": [[[604.0, 209.0], [639.0, 207.0], [642.0, 279.0], [607.0, 281.0]]], "lines": ["ウス。"]}, {"box": [156, 104, 284, 309], "vertical": true, "font_size": 30, "lines_coords": [[[254.0, 106.0], [284.0, 106.0], [284.0, 260.0], [254.0, 260.0]], [[223.0, 106.0], [250.0, 106.0], [250.0, 273.0], [223.0, 273.0]], [[192.0, 106.0], [218.0, 106.0], [218.0, 309.0], [192.0, 309.0]], [[156.0, 104.0], [192.0, 104.0], [192.0, 173.0], [156.0, 173.0]]], "lines": ["あんた縁側で", "寝てた時、顔に", "カエル乗っかってた", "わよ。"]}, {"box": [132, 332, 200, 439], "vertical": true, "font_size": 34, "lines_coords": [[[160.0, 332.0], [200.0, 332.0], [200.0, 429.0], [160.0, 429.0]], [[132.0, 337.0], [160.0, 337.0], [160.0, 439.0], [132.0, 439.0]]], "lines": ["うっそ、", "マジで？"]}, {"box": [589, 515, 682, 645], "vertical": true, "font_size": 28, "lines_coords": [[[650.0, 518.0], [682.0, 518.0], [682.0, 629.0], [650.0, 629.0]], [[622.0, 518.0], [648.0, 518.0], [648.0, 645.0], [622.0, 645.0]], [[589.0, 515.0], [615.0, 515.0], [615.0, 643.0], [589.0, 643.0]]], "lines": ["つーかさ、", "ねーちゃん", "なんで．．．"]}, {"box": [112, 584, 207, 737], "vertical": true, "font_size": 29, "lines_coords": [[[179.0, 584.0], [206.0, 584.0], [206.0, 710.0], [179.0, 710.0]], [[148.0, 585.0], [175.0, 585.0], [175.0, 737.0], [148.0, 737.0]], [[112.0, 584.0], [146.0, 584.0], [146.0, 673.0], [112.0, 673.0]]], "lines": ["今日の夕飯", "こんなゴウカ", "なのさ。"]}, {"box": [881, 768, 975, 945], "vertical": true, "font_size": 25, "lines_coords": [[[947.0, 770.0], [973.0, 770.0], [973.0, 923.0], [947.0, 923.0]], [[918.0, 771.0], [940.0, 771.0], [940.0, 945.0], [918.0, 945.0]], [[884.0, 768.0], [911.0, 768.0], [908.0, 931.0], [881.0, 931.0]]], "lines": ["今日ちょっと", "イイことあって", "機嫌いいのだ。"]}, {"box": [476, 889, 542, 975], "vertical": true, "font_size": 31, "lines_coords": [[[506.0, 892.0], [542.0, 892.0], [542.0, 973.0], [506.0, 973.0]], [[476.0, 889.0], [511.0, 889.0], [511.0, 975.0], [476.0, 975.0]]], "lines": ["マージ", "すか？"]}, {"box": [487, 1003, 548, 1168], "vertical": true, "font_size": 31, "lines_coords": [[[518.0, 1003.0], [545.0, 1003.0], [548.0, 1168.0], [521.0, 1168.0]], [[487.0, 1004.0], [514.0, 1004.0], [514.0, 1095.0], [487.0, 1095.0]]], "lines": ["ちょっとって", "何よ？"]}, {"box": [282, 789, 340, 942], "vertical": true, "font_size": 24, "lines_coords": [[[314.0, 789.0], [340.0, 789.0], [340.0, 926.0], [314.0, 926.0]], [[282.0, 792.0], [304.0, 792.0], [304.0, 942.0], [282.0, 942.0]]], "lines": ["．．．．．．ったく、", "あんたは．．．"]}, {"box": [859, 1214, 976, 1388], "vertical": true, "font_size": 24, "lines_coords": [[[920.0, 1214.0], [947.0, 1214.0], [950.0, 1351.0], [923.0, 1351.0]], [[890.0, 1214.0], [914.0, 1214.0], [912.0, 1387.0], [889.0, 1387.0]], [[859.0, 1217.0], [881.0, 1217.0], [881.0, 1317.0], [859.0, 1317.0]]], "lines": ["ねーちゃん、", "おでこのニキビ", "増えた？"]}, {"box": [84, 1295, 240, 1481], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 1296.0], [240.0, 1296.0], [240.0, 1400.0], [214.0, 1400.0]], [[179.0, 1296.0], [207.0, 1296.0], [209.0, 1479.0], [181.0, 1479.0]], [[150.0, 1298.0], [176.0, 1298.0], [176.0, 1401.0], [150.0, 1401.0]], [[117.0, 1296.0], [143.0, 1296.0], [143.0, 1448.0], [117.0, 1448.0]], [[84.0, 1295.0], [110.0, 1295.0], [114.0, 1410.0], [87.0, 1410.0]]], "lines": ["なーんで", "機嫌のいい時に、", "わざわざ", "突っかかって", "くるかな。"]}], "img_path": "subarashii_sekai_02_027.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [926, 93, 986, 279], "vertical": true, "font_size": 26, "lines_coords": [[[959.0, 95.0], [986.0, 95.0], [986.0, 246.0], [959.0, 246.0]], [[926.0, 93.0], [953.0, 93.0], [953.0, 279.0], [926.0, 279.0]]], "lines": ["だってホント", "増えてんじゃん。"]}, {"box": [839, 237, 897, 426], "vertical": true, "font_size": 26, "lines_coords": [[[868.0, 237.0], [895.0, 237.0], [897.0, 426.0], [870.0, 426.0]], [[839.0, 237.0], [861.0, 237.0], [861.0, 340.0], [839.0, 340.0]]], "lines": ["２６歳にもなって、", "悲しーね"]}, {"box": [554, 107, 713, 285], "vertical": true, "font_size": 27, "lines_coords": [[[684.0, 110.0], [711.0, 110.0], [711.0, 273.0], [684.0, 273.0]], [[651.0, 109.0], [678.0, 109.0], [678.0, 259.0], [651.0, 259.0]], [[620.0, 109.0], [647.0, 109.0], [647.0, 285.0], [620.0, 285.0]], [[587.0, 107.0], [614.0, 107.0], [617.0, 262.0], [590.0, 262.0]], [[554.0, 109.0], [581.0, 109.0], [584.0, 262.0], [557.0, 262.0]]], "lines": ["つーか、だって", "ねーちゃんの", "イイことなんて", "ちーっちゃい", "ことでしょ？"]}, {"box": [139, 201, 264, 389], "vertical": true, "font_size": 29, "lines_coords": [[[232.0, 203.0], [260.0, 203.0], [264.0, 354.0], [235.0, 354.0]], [[201.0, 201.0], [229.0, 201.0], [231.0, 329.0], [203.0, 329.0]], [[167.0, 203.0], [200.0, 203.0], [203.0, 389.0], [170.0, 389.0]], [[139.0, 203.0], [165.0, 203.0], [168.0, 364.0], [142.0, 364.0]]], "lines": ["いいトシして", "んなことで", "一喜一憂すんの、", "ムナシイっす。"]}, {"box": [825, 584, 881, 713], "vertical": true, "font_size": 25, "lines_coords": [[[853.0, 584.0], [881.0, 584.0], [881.0, 689.0], [853.0, 689.0]], [[825.0, 589.0], [847.0, 589.0], [847.0, 712.0], [825.0, 712.0]]], "lines": ["ほっとき", "なさいよ！"]}, {"box": [540, 353, 662, 559], "vertical": true, "font_size": 24, "lines_coords": [[[636.0, 354.0], [662.0, 354.0], [662.0, 507.0], [636.0, 507.0]], [[601.0, 353.0], [626.0, 353.0], [629.0, 509.0], [604.0, 509.0]], [[570.0, 353.0], [597.0, 353.0], [600.0, 546.0], [573.0, 546.0]], [[540.0, 357.0], [562.0, 357.0], [562.0, 559.0], [540.0, 559.0]]], "lines": ["苦しいウチの", "家計を支える", "ために、あくせく", "働いてる姉を．．．"]}, {"box": [415, 450, 501, 625], "vertical": true, "font_size": 86, "lines_coords": [[[415.0, 450.0], [501.0, 450.0], [501.0, 625.0], [415.0, 625.0]]], "lines": ["あんた少しはねぎらおうって気はないの？"]}, {"box": [415, 448, 500, 628], "vertical": true, "font_size": 24, "lines_coords": [[[478.0, 451.0], [500.0, 451.0], [500.0, 601.0], [478.0, 601.0]], [[442.0, 448.0], [468.0, 448.0], [473.0, 628.0], [446.0, 628.0]], [[415.0, 451.0], [437.0, 451.0], [437.0, 604.0], [415.0, 604.0]]], "lines": ["あんた少しは", "ねぎらおうって", "気はないの？"]}, {"box": [121, 675, 243, 828], "vertical": true, "font_size": 26, "lines_coords": [[[215.0, 675.0], [242.0, 675.0], [242.0, 814.0], [215.0, 814.0]], [[179.0, 675.0], [206.0, 675.0], [209.0, 828.0], [182.0, 828.0]], [[150.0, 676.0], [176.0, 676.0], [176.0, 804.0], [150.0, 804.0]], [[121.0, 679.0], [143.0, 679.0], [143.0, 804.0], [121.0, 804.0]]], "lines": ["じゃ、あたし", "予備校辞めて", "おミズでも", "しよっか？"]}, {"box": [747, 900, 786, 1059], "vertical": true, "font_size": 39, "lines_coords": [[[747.0, 900.0], [786.0, 900.0], [786.0, 1059.0], [747.0, 1059.0]]], "lines": ["タエッ！！"]}, {"box": [756, 1132, 910, 1413], "vertical": true, "font_size": 24, "lines_coords": [[[884.0, 1132.0], [906.0, 1132.0], [909.0, 1409.0], [887.0, 1409.0]], [[851.0, 1134.0], [873.0, 1134.0], [876.0, 1332.0], [854.0, 1332.0]], [[818.0, 1132.0], [847.0, 1132.0], [847.0, 1268.0], [818.0, 1268.0]], [[787.0, 1134.0], [811.0, 1134.0], [812.0, 1282.0], [789.0, 1282.0]], [[756.0, 1135.0], [779.0, 1135.0], [781.0, 1340.0], [757.0, 1340.0]]], "lines": ["父はあたしが生まれると", "ほぼ同時に海外に", "単身赴任し、", "その３年後に", "母は事故で死んだ"]}, {"box": [524, 1135, 645, 1426], "vertical": true, "font_size": 23, "lines_coords": [[[620.0, 1137.0], [642.0, 1137.0], [642.0, 1334.0], [620.0, 1334.0]], [[589.0, 1135.0], [611.0, 1135.0], [611.0, 1412.0], [589.0, 1412.0]], [[553.0, 1135.0], [579.0, 1135.0], [579.0, 1284.0], [553.0, 1284.0]], [[525.0, 1137.0], [546.0, 1137.0], [546.0, 1393.0], [525.0, 1393.0]]], "lines": ["姉・兄・私が住む", "築４５年のホロい一軒家は", "あちこちから", "すき間風が吹いている。"]}, {"box": [318, 1137, 343, 1267], "vertical": true, "font_size": 25, "lines_coords": [[[318.0, 1137.0], [342.0, 1137.0], [343.0, 1267.0], [320.0, 1267.0]]], "lines": ["ねーちゃん、"]}, {"box": [196, 1270, 287, 1485], "vertical": true, "font_size": 25, "lines_coords": [[[257.0, 1270.0], [286.0, 1270.0], [287.0, 1485.0], [259.0, 1485.0]], [[228.0, 1275.0], [250.0, 1275.0], [250.0, 1425.0], [228.0, 1425.0]], [[196.0, 1273.0], [223.0, 1273.0], [223.0, 1460.0], [196.0, 1460.0]]], "lines": ["やっぱタエのヤツ、", "様子おかしく", "なってきてるわ。"]}], "img_path": "subarashii_sekai_02_028.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [908, 123, 999, 276], "vertical": true, "font_size": 26, "lines_coords": [[[976.0, 126.0], [998.0, 126.0], [998.0, 251.0], [976.0, 251.0]], [[942.0, 123.0], [965.0, 123.0], [967.0, 276.0], [943.0, 276.0]], [[908.0, 123.0], [940.0, 123.0], [940.0, 217.0], [908.0, 217.0]]], "lines": ["つーことは", "そろそろって", "ワケだ。"]}, {"box": [470, 121, 625, 278], "vertical": true, "font_size": 27, "lines_coords": [[[597.0, 123.0], [625.0, 123.0], [625.0, 250.0], [597.0, 250.0]], [[565.0, 121.0], [593.0, 121.0], [593.0, 226.0], [565.0, 226.0]], [[532.0, 123.0], [562.0, 123.0], [562.0, 278.0], [532.0, 278.0]], [[504.0, 125.0], [526.0, 125.0], [526.0, 273.0], [504.0, 273.0]], [[470.0, 123.0], [496.0, 123.0], [496.0, 250.0], [470.0, 250.0]]], "lines": ["ホント．．．", "あのコは", "梅雨になると", "毎年ああなん", "だから．．．"]}, {"box": [93, 57, 337, 87], "vertical": false, "font_size": 28, "lines_coords": [[[93.0, 57.0], [337.0, 59.0], [337.0, 87.0], [93.0, 85.0]]], "lines": ["素晴らしい世界って"]}, {"box": [153, 390, 243, 578], "vertical": true, "font_size": 25, "lines_coords": [[[217.0, 390.0], [243.0, 390.0], [243.0, 553.0], [217.0, 553.0]], [[182.0, 390.0], [209.0, 390.0], [209.0, 543.0], [182.0, 543.0]], [[153.0, 390.0], [175.0, 390.0], [176.0, 575.0], [154.0, 575.0]]], "lines": ["ま、今日はまだ", "家にいるから", "ひと安心だけど。"]}, {"box": [266, 584, 291, 725], "vertical": true, "font_size": 22, "lines_coords": [[[267.0, 585.0], [289.0, 585.0], [289.0, 723.0], [267.0, 723.0]]], "lines": ["まあ、ね．．．"]}, {"box": [858, 1267, 987, 1446], "vertical": true, "font_size": 31, "lines_coords": [[[951.0, 1268.0], [987.0, 1268.0], [987.0, 1350.0], [951.0, 1350.0]], [[923.0, 1268.0], [951.0, 1268.0], [948.0, 1446.0], [920.0, 1446.0]], [[893.0, 1270.0], [920.0, 1270.0], [920.0, 1446.0], [893.0, 1446.0]], [[858.0, 1267.0], [890.0, 1267.0], [890.0, 1357.0], [858.0, 1357.0]]], "lines": ["台所の", "テーブルの上に", "置きっばのはず", "だから、"]}, {"box": [143, 1307, 231, 1512], "vertical": true, "font_size": 26, "lines_coords": [[[203.0, 1307.0], [231.0, 1307.0], [231.0, 1446.0], [203.0, 1446.0]], [[170.0, 1307.0], [196.0, 1307.0], [200.0, 1512.0], [173.0, 1512.0]], [[143.0, 1310.0], [165.0, 1310.0], [165.0, 1467.0], [143.0, 1467.0]]], "lines": ["タエ、どうせ", "ヒマなんてしょ？", "持ってきてよ。"]}], "img_path": "subarashii_sekai_02_029.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [620, 135, 654, 203], "vertical": true, "font_size": 34, "lines_coords": [[[620.0, 135.0], [654.0, 135.0], [654.0, 203.0], [620.0, 203.0]]], "lines": ["ホイ。"]}, {"box": [532, 226, 562, 342], "vertical": true, "font_size": 26, "lines_coords": [[[532.0, 226.0], [559.0, 226.0], [562.0, 342.0], [536.0, 342.0]]], "lines": ["ありがと。"]}, {"box": [209, 284, 268, 459], "vertical": true, "font_size": 24, "lines_coords": [[[240.0, 284.0], [267.0, 284.0], [267.0, 421.0], [240.0, 421.0]], [[209.0, 284.0], [231.0, 284.0], [231.0, 459.0], [209.0, 459.0]]], "lines": ["つーか、弁当", "くらい買えは？"]}, {"box": [940, 743, 964, 792], "vertical": true, "font_size": 26, "lines_coords": [[[940.0, 743.0], [964.0, 743.0], [964.0, 792.0], [940.0, 792.0]]], "lines": ["．．．"]}, {"box": [906, 692, 933, 817], "vertical": true, "font_size": 26, "lines_coords": [[[906.0, 692.0], [933.0, 692.0], [933.0, 817.0], [906.0, 817.0]]], "lines": ["ふーん．．．．．"]}, {"box": [126, 509, 226, 601], "vertical": true, "font_size": 41, "lines_coords": [[[192.0, 512.0], [226.0, 512.0], [226.0, 601.0], [192.0, 601.0]], [[154.0, 509.0], [200.0, 509.0], [200.0, 575.0], [154.0, 575.0]], [[126.0, 509.0], [168.0, 509.0], [168.0, 584.0], [126.0, 584.0]]], "lines": ["バカね、", "節約", "節約。"]}, {"box": [929, 959, 989, 1061], "vertical": true, "font_size": 30, "lines_coords": [[[962.0, 959.0], [989.0, 959.0], [989.0, 1060.0], [962.0, 1060.0]], [[929.0, 959.0], [962.0, 959.0], [962.0, 1053.0], [929.0, 1053.0]]], "lines": ["イメクラ", "みたい。"]}, {"box": [195, 787, 223, 865], "vertical": true, "font_size": 28, "lines_coords": [[[195.0, 787.0], [223.0, 787.0], [223.0, 865.0], [195.0, 865.0]]], "lines": ["何よ？"]}, {"box": [182, 1023, 275, 1198], "vertical": true, "font_size": 26, "lines_coords": [[[246.0, 1026.0], [275.0, 1026.0], [275.0, 1126.0], [246.0, 1126.0]], [[212.0, 1023.0], [239.0, 1023.0], [239.0, 1198.0], [212.0, 1198.0]], [[184.0, 1023.0], [207.0, 1023.0], [206.0, 1178.0], [182.0, 1178.0]]], "lines": ["病院じゃ", "あたしは白衣の", "天使なのよ？"]}, {"box": [784, 1356, 845, 1470], "vertical": true, "font_size": 28, "lines_coords": [[[817.0, 1356.0], [845.0, 1357.0], [840.0, 1467.0], [812.0, 1465.0]], [[784.0, 1356.0], [811.0, 1356.0], [811.0, 1468.0], [784.0, 1468.0]]], "lines": ["っさいな、", "あんたは。"]}, {"box": [153, 1257, 242, 1389], "vertical": true, "font_size": 26, "lines_coords": [[[212.0, 1259.0], [240.0, 1259.0], [242.0, 1389.0], [214.0, 1389.0]], [[179.0, 1257.0], [207.0, 1257.0], [212.0, 1389.0], [184.0, 1389.0]], [[153.0, 1262.0], [175.0, 1262.0], [175.0, 1364.0], [153.0, 1364.0]]], "lines": ["他人様の命", "預かってん", "だから！！"]}], "img_path": "subarashii_sekai_02_030.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [873, 117, 995, 304], "vertical": true, "font_size": 29, "lines_coords": [[[967.0, 121.0], [995.0, 121.0], [995.0, 223.0], [967.0, 223.0]], [[929.0, 118.0], [962.0, 117.0], [967.0, 234.0], [934.0, 235.0]], [[903.0, 118.0], [929.0, 118.0], [933.0, 304.0], [906.0, 304.0]], [[873.0, 121.0], [900.0, 121.0], [900.0, 235.0], [873.0, 235.0]]], "lines": ["．．．．．とか", "言いつつ、", "実際雑用ばっか", "だけどさー"]}, {"box": [768, 282, 864, 464], "vertical": true, "font_size": 29, "lines_coords": [[[837.0, 289.0], [864.0, 289.0], [864.0, 448.0], [837.0, 448.0]], [[806.0, 287.0], [832.0, 287.0], [829.0, 464.0], [803.0, 464.0]], [[768.0, 284.0], [803.0, 282.0], [806.0, 357.0], [772.0, 359.0]]], "lines": ["給料出なきゃ", "やってらんない", "すよ。"]}, {"box": [564, 125, 670, 237], "vertical": true, "font_size": 38, "lines_coords": [[[625.0, 126.0], [667.0, 125.0], [670.0, 200.0], [628.0, 201.0]], [[598.0, 131.0], [631.0, 131.0], [631.0, 237.0], [598.0, 237.0]], [[564.0, 126.0], [604.0, 126.0], [604.0, 200.0], [564.0, 200.0]]], "lines": ["わぁ、", "キタナイ", "本音。"]}, {"box": [104, 68, 346, 95], "vertical": false, "font_size": 27, "lines_coords": [[[104.0, 68.0], [346.0, 68.0], [346.0, 95.0], [104.0, 95.0]]], "lines": ["素晴らしい世界の"]}, {"box": [112, 195, 234, 421], "vertical": true, "font_size": 25, "lines_coords": [[[201.0, 195.0], [228.0, 195.0], [232.0, 329.0], [206.0, 329.0]], [[171.0, 195.0], [198.0, 195.0], [200.0, 421.0], [173.0, 421.0]], [[139.0, 195.0], [165.0, 195.0], [168.0, 348.0], [142.0, 348.0]], [[112.0, 198.0], [134.0, 198.0], [134.0, 384.0], [112.0, 384.0]]], "lines": ["ただでさえ、", "あたしはあんたらの", "面倒みなきゃ", "なんないのにさ。"]}, {"box": [451, 417, 508, 572], "vertical": true, "font_size": 27, "lines_coords": [[[479.0, 417.0], [506.0, 417.0], [506.0, 520.0], [479.0, 520.0]], [[451.0, 417.0], [478.0, 417.0], [478.0, 531.0], [451.0, 531.0]]], "lines": ["加藤さん", "ちょっと"]}, {"box": [168, 534, 201, 621], "vertical": true, "font_size": 29, "lines_coords": [[[168.0, 534.0], [201.0, 534.0], [201.0, 621.0], [168.0, 621.0]]], "lines": ["んじゃ、"]}, {"box": [121, 678, 214, 842], "vertical": true, "font_size": 29, "lines_coords": [[[182.0, 679.0], [210.0, 679.0], [214.0, 820.0], [185.0, 820.0]], [[150.0, 678.0], [182.0, 678.0], [182.0, 760.0], [150.0, 760.0]], [[121.0, 679.0], [145.0, 679.0], [146.0, 842.0], [123.0, 842.0]]], "lines": ["仕事戻るね。", "お弁当", "ありがとさん。"]}, {"box": [864, 937, 958, 1118], "vertical": true, "font_size": 27, "lines_coords": [[[933.0, 943.0], [954.0, 943.0], [954.0, 1117.0], [933.0, 1117.0]], [[900.0, 940.0], [926.0, 940.0], [926.0, 1118.0], [900.0, 1118.0]], [[864.0, 937.0], [898.0, 937.0], [898.0, 1026.0], [864.0, 1026.0]]], "lines": ["．．．とかなんとか", "文句は言ってる", "ものの、"]}, {"box": [215, 1001, 306, 1131], "vertical": true, "font_size": 28, "lines_coords": [[[279.0, 1003.0], [306.0, 1003.0], [306.0, 1106.0], [279.0, 1106.0]], [[245.0, 1001.0], [273.0, 1001.0], [276.0, 1131.0], [248.0, 1131.0]], [[215.0, 1003.0], [243.0, 1003.0], [243.0, 1089.0], [215.0, 1089.0]]], "lines": ["キッチリ", "仕事してん", "じゃん。"]}, {"box": [209, 1315, 272, 1467], "vertical": true, "font_size": 24, "lines_coords": [[[245.0, 1320.0], [267.0, 1320.0], [267.0, 1465.0], [245.0, 1465.0]], [[209.0, 1315.0], [235.0, 1315.0], [239.0, 1456.0], [212.0, 1456.0]]], "lines": ["．．．．．．．なんか", "つまんない。"]}], "img_path": "subarashii_sekai_02_031.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [564, 135, 622, 289], "vertical": true, "font_size": 25, "lines_coords": [[[590.0, 135.0], [618.0, 135.0], [622.0, 235.0], [593.0, 235.0]], [[564.0, 139.0], [586.0, 139.0], [586.0, 289.0], [564.0, 289.0]]], "lines": ["おーーっ", "タエじゃん！！"]}, {"box": [362, 124, 390, 241], "vertical": true, "font_size": 27, "lines_coords": [[[362.0, 126.0], [389.0, 126.0], [389.0, 240.0], [362.0, 240.0]]], "lines": ["．．．．．．っス。"]}, {"box": [103, 193, 225, 390], "vertical": true, "font_size": 27, "lines_coords": [[[198.0, 195.0], [225.0, 195.0], [225.0, 371.0], [198.0, 371.0]], [[160.0, 195.0], [195.0, 193.0], [198.0, 276.0], [164.0, 278.0]], [[132.0, 195.0], [159.0, 195.0], [164.0, 384.0], [137.0, 384.0]], [[103.0, 195.0], [129.0, 195.0], [129.0, 390.0], [103.0, 390.0]]], "lines": ["学生のイベント", "なんて", "くだんねーって、", "言ってたの誰よ！？"]}, {"box": [100, 434, 221, 589], "vertical": true, "font_size": 27, "lines_coords": [[[192.0, 435.0], [218.0, 435.0], [221.0, 589.0], [195.0, 589.0]], [[162.0, 434.0], [189.0, 434.0], [189.0, 587.0], [162.0, 587.0]], [[129.0, 434.0], [156.0, 434.0], [156.0, 560.0], [129.0, 560.0]], [[100.0, 434.0], [121.0, 434.0], [121.0, 537.0], [100.0, 537.0]]], "lines": ["いいのかぁ？", "ローニン生が", "こんなトコ", "来てて？"]}, {"box": [914, 985, 1011, 1082], "vertical": true, "font_size": 31, "lines_coords": [[[976.0, 987.0], [1011.0, 987.0], [1011.0, 1078.0], [976.0, 1078.0]], [[942.0, 985.0], [981.0, 985.0], [981.0, 1071.0], [942.0, 1071.0]], [[914.0, 987.0], [947.0, 987.0], [947.0, 1082.0], [914.0, 1082.0]]], "lines": ["あはは、", "そーか", "そーか。"]}, {"box": [551, 738, 608, 900], "vertical": true, "font_size": 24, "lines_coords": [[[579.0, 739.0], [606.0, 739.0], [606.0, 873.0], [579.0, 873.0]], [[551.0, 739.0], [573.0, 739.0], [573.0, 898.0], [551.0, 898.0]]], "lines": ["いーんだよ、", "激ヒマだもん。"]}, {"box": [898, 1145, 1026, 1298], "vertical": true, "font_size": 31, "lines_coords": [[[993.0, 1145.0], [1026.0, 1145.0], [1026.0, 1226.0], [993.0, 1226.0]], [[964.0, 1146.0], [990.0, 1146.0], [990.0, 1298.0], [964.0, 1298.0]], [[931.0, 1146.0], [958.0, 1146.0], [958.0, 1287.0], [931.0, 1287.0]], [[898.0, 1145.0], [925.0, 1145.0], [925.0, 1232.0], [898.0, 1232.0]]], "lines": ["ま、ま、", "久々なんだし", "ホラ、飲みな", "飲みな。"]}], "img_path": "subarashii_sekai_02_032.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [942, 1054, 975, 1160], "vertical": true, "font_size": 33, "lines_coords": [[[942.0, 1054.0], [975.0, 1054.0], [975.0, 1160.0], [942.0, 1160.0]]], "lines": ["タエ．．．．．"]}, {"box": [514, 821, 545, 943], "vertical": true, "font_size": 27, "lines_coords": [[[514.0, 823.0], [540.0, 821.0], [545.0, 939.0], [518.0, 940.0]]], "lines": ["うーす。"]}, {"box": [421, 1096, 524, 1239], "vertical": true, "font_size": 31, "lines_coords": [[[479.0, 1096.0], [518.0, 1096.0], [518.0, 1190.0], [479.0, 1190.0]], [[453.0, 1098.0], [481.0, 1098.0], [478.0, 1228.0], [450.0, 1228.0]], [[421.0, 1100.0], [448.0, 1100.0], [448.0, 1239.0], [421.0, 1239.0]]], "lines": ["高知君、", "ＤＪなんか", "やってんだ。"]}, {"box": [181, 1089, 257, 1185], "vertical": true, "font_size": 31, "lines_coords": [[[209.0, 1093.0], [251.0, 1089.0], [257.0, 1164.0], [215.0, 1167.0]], [[181.0, 1092.0], [215.0, 1090.0], [220.0, 1184.0], [185.0, 1185.0]]], "lines": ["へへ、", "まーな。"]}, {"box": [145, 1273, 203, 1434], "vertical": true, "font_size": 31, "lines_coords": [[[176.0, 1273.0], [203.0, 1273.0], [200.0, 1423.0], [173.0, 1423.0]], [[145.0, 1275.0], [167.0, 1275.0], [167.0, 1434.0], [145.0, 1434.0]]], "lines": ["つってもまだ", "全然だけどな。"]}], "img_path": "subarashii_sekai_02_033.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [829, 612, 865, 715], "vertical": true, "font_size": 33, "lines_coords": [[[829.0, 614.0], [862.0, 612.0], [865.0, 714.0], [832.0, 715.0]]], "lines": ["タエ．．．"]}, {"box": [661, 900, 751, 1050], "vertical": true, "font_size": 25, "lines_coords": [[[725.0, 901.0], [751.0, 901.0], [751.0, 1028.0], [725.0, 1028.0]], [[695.0, 901.0], [717.0, 901.0], [717.0, 1050.0], [695.0, 1050.0]], [[661.0, 900.0], [689.0, 900.0], [689.0, 968.0], [661.0, 968.0]]], "lines": ["タエのヤツ", "帰ってこない", "スねー"]}, {"box": [176, 751, 245, 859], "vertical": true, "font_size": 36, "lines_coords": [[[209.0, 753.0], [242.0, 751.0], [245.0, 857.0], [212.0, 859.0]], [[176.0, 751.0], [215.0, 751.0], [215.0, 837.0], [176.0, 837.0]]], "lines": ["酔ってん", "のか？"]}, {"box": [128, 1004, 226, 1184], "vertical": true, "font_size": 27, "lines_coords": [[[192.0, 1004.0], [223.0, 1004.0], [226.0, 1159.0], [195.0, 1159.0]], [[160.0, 1006.0], [189.0, 1006.0], [193.0, 1184.0], [165.0, 1184.0]], [[128.0, 1007.0], [159.0, 1007.0], [159.0, 1053.0], [128.0, 1053.0]], [[134.0, 1045.0], [153.0, 1045.0], [153.0, 1085.0], [134.0, 1085.0]]], "lines": ["今年もやっぱ", "失踪しちゃった", "かー", "！"]}, {"box": [212, 1354, 303, 1494], "vertical": true, "font_size": 27, "lines_coords": [[[271.0, 1354.0], [303.0, 1354.0], [303.0, 1412.0], [271.0, 1412.0]], [[240.0, 1357.0], [268.0, 1357.0], [270.0, 1484.0], [242.0, 1484.0]], [[212.0, 1356.0], [234.0, 1356.0], [237.0, 1490.0], [215.0, 1490.0]]], "lines": ["もう", "いいかげん", "慣れたわよ。"]}], "img_path": "subarashii_sekai_02_034.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [883, 90, 1006, 296], "vertical": true, "font_size": 27, "lines_coords": [[[975.0, 90.0], [1001.0, 90.0], [1006.0, 276.0], [979.0, 276.0]], [[943.0, 90.0], [972.0, 90.0], [973.0, 220.0], [945.0, 220.0]], [[914.0, 92.0], [940.0, 92.0], [940.0, 296.0], [914.0, 296.0]], [[883.0, 93.0], [911.0, 93.0], [911.0, 196.0], [883.0, 196.0]]], "lines": ["高２の時だっけ、", "年齢偽って", "キャバで働いてた", "のって？"]}, {"box": [745, 192, 865, 385], "vertical": true, "font_size": 27, "lines_coords": [[[839.0, 192.0], [865.0, 192.0], [864.0, 375.0], [837.0, 375.0]], [[807.0, 193.0], [834.0, 193.0], [834.0, 348.0], [807.0, 348.0]], [[776.0, 193.0], [803.0, 193.0], [801.0, 375.0], [775.0, 375.0]], [[745.0, 195.0], [772.0, 195.0], [772.0, 385.0], [745.0, 385.0]]], "lines": ["あん時も何事も", "なかったかの", "ようにフラっと", "帰ってきたけど。"]}, {"box": [500, 114, 653, 348], "vertical": true, "font_size": 28, "lines_coords": [[[626.0, 117.0], [653.0, 117.0], [653.0, 270.0], [626.0, 270.0]], [[595.0, 117.0], [623.0, 117.0], [623.0, 209.0], [595.0, 209.0]], [[561.0, 115.0], [589.0, 115.0], [590.0, 287.0], [562.0, 287.0]], [[528.0, 114.0], [559.0, 114.0], [561.0, 348.0], [529.0, 348.0]], [[500.0, 118.0], [523.0, 118.0], [525.0, 282.0], [501.0, 282.0]]], "lines": ["毎回ヒヤヒヤ", "するよ。", "今年こそ、もう", "帰ってこないんじゃ", "ないかってさ。"]}, {"box": [106, 60, 356, 92], "vertical": false, "font_size": 32, "lines_coords": [[[106.0, 60.0], [356.0, 60.0], [356.0, 92.0], [106.0, 92.0]]], "lines": ["素晴らしい世界２"]}, {"box": [861, 698, 923, 814], "vertical": true, "font_size": 30, "lines_coords": [[[884.0, 698.0], [923.0, 698.0], [923.0, 784.0], [884.0, 784.0]], [[861.0, 701.0], [883.0, 701.0], [883.0, 812.0], [861.0, 812.0]]], "lines": ["帰って", "くるわよ。"]}, {"box": [828, 1021, 923, 1178], "vertical": true, "font_size": 31, "lines_coords": [[[890.0, 1021.0], [923.0, 1021.0], [923.0, 1112.0], [890.0, 1112.0]], [[862.0, 1023.0], [889.0, 1023.0], [889.0, 1178.0], [862.0, 1178.0]], [[828.0, 1021.0], [861.0, 1021.0], [861.0, 1106.0], [828.0, 1106.0]]], "lines": ["高知君、", "大学の調子は", "どお？"]}, {"box": [493, 1079, 620, 1310], "vertical": true, "font_size": 27, "lines_coords": [[[589.0, 1079.0], [620.0, 1079.0], [620.0, 1237.0], [589.0, 1237.0]], [[557.0, 1081.0], [584.0, 1081.0], [584.0, 1310.0], [557.0, 1310.0]], [[523.0, 1081.0], [551.0, 1081.0], [554.0, 1223.0], [526.0, 1223.0]], [[493.0, 1081.0], [520.0, 1081.0], [520.0, 1198.0], [493.0, 1198.0]]], "lines": ["どお？って、", "まだ始まったばっか", "だからなぁ。", "ま、普通？"]}, {"box": [232, 785, 290, 939], "vertical": true, "font_size": 24, "lines_coords": [[[260.0, 785.0], [287.0, 785.0], [290.0, 939.0], [264.0, 939.0]], [[232.0, 790.0], [254.0, 790.0], [254.0, 920.0], [232.0, 920.0]]], "lines": ["あのコの家は", "ココだもん。"]}, {"box": [411, 1276, 500, 1429], "vertical": true, "font_size": 27, "lines_coords": [[[468.0, 1276.0], [496.0, 1276.0], [500.0, 1381.0], [471.0, 1381.0]], [[442.0, 1276.0], [468.0, 1276.0], [468.0, 1429.0], [442.0, 1429.0]], [[411.0, 1279.0], [432.0, 1279.0], [432.0, 1404.0], [411.0, 1404.0]]], "lines": ["タエこそ", "ちゃんと勉強", "してんの？"]}, {"box": [204, 1318, 230, 1456], "vertical": true, "font_size": 22, "lines_coords": [[[204.0, 1318.0], [226.0, 1318.0], [226.0, 1456.0], [204.0, 1456.0]]], "lines": ["してないス。"]}], "img_path": "subarashii_sekai_02_035.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [939, 98, 997, 297], "vertical": true, "font_size": 24, "lines_coords": [[[972.0, 100.0], [993.0, 100.0], [993.0, 293.0], [972.0, 293.0]], [[939.0, 98.0], [965.0, 98.0], [965.0, 270.0], [939.0, 270.0]]], "lines": ["てゆーか、おまえ、", "髪伸びたなぁ。"]}, {"box": [556, 118, 618, 282], "vertical": true, "font_size": 28, "lines_coords": [[[587.0, 118.0], [615.0, 118.0], [617.0, 268.0], [589.0, 268.0]], [[556.0, 118.0], [584.0, 118.0], [586.0, 282.0], [557.0, 282.0]]], "lines": ["前髪パッツン", "だったのにさ。"]}, {"box": [140, 198, 200, 389], "vertical": true, "font_size": 23, "lines_coords": [[[171.0, 200.0], [195.0, 200.0], [196.0, 385.0], [173.0, 385.0]], [[140.0, 198.0], [162.0, 198.0], [162.0, 384.0], [140.0, 384.0]]], "lines": ["当たり前じゃん、", "もう３か月だよ。"]}, {"box": [861, 746, 925, 840], "vertical": true, "font_size": 32, "lines_coords": [[[887.0, 748.0], [922.0, 746.0], [925.0, 839.0], [890.0, 840.0]], [[861.0, 750.0], [889.0, 750.0], [889.0, 839.0], [861.0, 839.0]]], "lines": ["あーー、", "そうか。"]}, {"box": [306, 507, 404, 661], "vertical": true, "font_size": 27, "lines_coords": [[[378.0, 512.0], [400.0, 512.0], [400.0, 660.0], [378.0, 660.0]], [[345.0, 512.0], [371.0, 512.0], [371.0, 640.0], [345.0, 640.0]], [[306.0, 509.0], [340.0, 507.0], [343.0, 600.0], [309.0, 601.0]]], "lines": ["あたしたちが", "別れてから", "３か月。"]}, {"box": [214, 431, 241, 534], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 431.0], [240.0, 431.0], [240.0, 534.0], [214.0, 534.0]]], "lines": ["３か月？"]}, {"box": [940, 1029, 1003, 1143], "vertical": true, "font_size": 28, "lines_coords": [[[967.0, 1031.0], [1000.0, 1029.0], [1003.0, 1118.0], [970.0, 1120.0]], [[940.0, 1031.0], [967.0, 1031.0], [967.0, 1143.0], [940.0, 1143.0]]], "lines": ["たはは。", "無理無理。"]}, {"box": [162, 770, 250, 1014], "vertical": true, "font_size": 26, "lines_coords": [[[220.0, 771.0], [246.0, 771.0], [250.0, 864.0], [223.0, 864.0]], [[189.0, 770.0], [217.0, 770.0], [218.0, 1014.0], [190.0, 1014.0]], [[162.0, 771.0], [184.0, 771.0], [184.0, 948.0], [162.0, 948.0]]], "lines": ["いいなー", "あたしもひとり暮らし", "しよっかなぁ？"]}, {"box": [943, 1178, 1004, 1373], "vertical": true, "font_size": 28, "lines_coords": [[[978.0, 1184.0], [1004.0, 1184.0], [1004.0, 1310.0], [978.0, 1310.0]], [[947.0, 1178.0], [972.0, 1178.0], [968.0, 1373.0], [943.0, 1373.0]]], "lines": ["おまえじゃ", "３日もたないね。"]}, {"box": [412, 1210, 505, 1393], "vertical": true, "font_size": 29, "lines_coords": [[[476.0, 1212.0], [504.0, 1212.0], [501.0, 1348.0], [473.0, 1348.0]], [[445.0, 1214.0], [471.0, 1214.0], [471.0, 1393.0], [445.0, 1393.0]], [[412.0, 1210.0], [445.0, 1210.0], [445.0, 1306.0], [412.0, 1306.0]]], "lines": ["ズボラだし、", "ちょー寂しがり", "じゃん。"]}], "img_path": "subarashii_sekai_02_036.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [819, 112, 945, 339], "vertical": true, "font_size": 28, "lines_coords": [[[909.0, 112.0], [945.0, 112.0], [945.0, 193.0], [909.0, 193.0]], [[881.0, 114.0], [908.0, 114.0], [908.0, 339.0], [881.0, 339.0]], [[847.0, 112.0], [875.0, 112.0], [878.0, 251.0], [850.0, 251.0]], [[820.0, 115.0], [842.0, 115.0], [842.0, 232.0], [820.0, 232.0]]], "lines": ["やっぱ", "愛のないセックスは", "ムナシイね。", "気楽だけど"]}, {"box": [640, 110, 729, 325], "vertical": true, "font_size": 26, "lines_coords": [[[700.0, 112.0], [728.0, 112.0], [729.0, 240.0], [701.0, 240.0]], [[668.0, 110.0], [695.0, 110.0], [697.0, 320.0], [670.0, 320.0]], [[640.0, 112.0], [662.0, 112.0], [662.0, 309.0], [640.0, 309.0]]], "lines": ["なーんにも", "満たされないもん。", "「気持ちはいいけどさ"]}, {"box": [428, 110, 520, 268], "vertical": true, "font_size": 27, "lines_coords": [[[489.0, 110.0], [520.0, 110.0], [520.0, 268.0], [489.0, 268.0]], [[454.0, 110.0], [487.0, 110.0], [487.0, 220.0], [454.0, 220.0]], [[428.0, 112.0], [453.0, 112.0], [453.0, 156.0], [428.0, 156.0]]], "lines": ["何やってんだ、", "あたしは", "んー"]}, {"box": [431, 189, 450, 226], "vertical": true, "font_size": 27, "lines_coords": [[[431.0, 189.0], [450.0, 189.0], [450.0, 226.0], [431.0, 226.0]]], "lines": ["―？"]}, {"box": [159, 110, 342, 314], "vertical": true, "font_size": 26, "lines_coords": [[[315.0, 110.0], [342.0, 110.0], [339.0, 239.0], [312.0, 239.0]], [[284.0, 110.0], [311.0, 110.0], [309.0, 289.0], [282.0, 289.0]], [[251.0, 112.0], [279.0, 112.0], [279.0, 220.0], [251.0, 220.0]], [[220.0, 112.0], [248.0, 112.0], [243.0, 312.0], [215.0, 312.0]], [[189.0, 112.0], [215.0, 112.0], [215.0, 240.0], [189.0, 240.0]], [[159.0, 114.0], [181.0, 114.0], [181.0, 267.0], [159.0, 267.0]]], "lines": ["とりあえず", "鼻息を荒くした", "ＤＪ男に、", "つぶれたカエルの", "よーな姿を", "さらしてます"]}, {"box": [795, 656, 823, 888], "vertical": true, "font_size": 27, "lines_coords": [[[795.0, 659.0], [822.0, 659.0], [822.0, 884.0], [795.0, 884.0]]], "lines": ["この時期、多いよね。"]}, {"box": [613, 659, 707, 925], "vertical": true, "font_size": 27, "lines_coords": [[[672.0, 659.0], [703.0, 659.0], [707.0, 890.0], [676.0, 890.0]], [[643.0, 660.0], [670.0, 660.0], [670.0, 873.0], [643.0, 873.0]], [[615.0, 662.0], [637.0, 662.0], [637.0, 921.0], [615.0, 921.0]]], "lines": ["あれって死ぬことを", "理解できないまま、", "死んじゃうんだろうな"]}, {"box": [453, 660, 520, 800], "vertical": true, "font_size": 33, "lines_coords": [[[487.0, 662.0], [520.0, 662.0], [520.0, 767.0], [487.0, 767.0]], [[456.0, 660.0], [489.0, 660.0], [486.0, 800.0], [453.0, 800.0]]], "lines": ["いきなり", "バーンって"]}, {"box": [303, 661, 363, 800], "vertical": true, "font_size": 27, "lines_coords": [[[334.0, 664.0], [362.0, 664.0], [362.0, 795.0], [334.0, 795.0]], [[303.0, 662.0], [329.0, 662.0], [329.0, 792.0], [303.0, 792.0]]], "lines": ["．．．．．．やたな、", "そういうの"]}, {"box": [140, 660, 226, 874], "vertical": true, "font_size": 21, "lines_coords": [[[207.0, 665.0], [225.0, 665.0], [225.0, 760.0], [207.0, 760.0]], [[175.0, 664.0], [196.0, 664.0], [196.0, 789.0], [175.0, 789.0]], [[142.0, 660.0], [165.0, 660.0], [164.0, 867.0], [140.0, 867.0]]], "lines": ["．．．．．．", "お母さんも", "そうだったのかな"]}, {"box": [888, 658, 916, 942], "vertical": true, "font_size": 22, "lines_coords": [[[890.0, 662.0], [912.0, 662.0], [912.0, 934.0], [890.0, 934.0]]], "lines": ["つぶれたカエルかぁ．．．"]}, {"box": [315, 1279, 400, 1408], "vertical": true, "font_size": 26, "lines_coords": [[[346.0, 1282.0], [371.0, 1282.0], [371.0, 1329.0], [346.0, 1329.0]], [[315.0, 1281.0], [342.0, 1281.0], [342.0, 1406.0], [315.0, 1406.0]]], "lines": ["あー", "お母さん．．．"]}, {"box": [190, 1278, 218, 1461], "vertical": true, "font_size": 27, "lines_coords": [[[190.0, 1279.0], [217.0, 1279.0], [217.0, 1457.0], [190.0, 1457.0]]], "lines": ["ゴメン．．．．．．"]}], "img_path": "subarashii_sekai_02_037.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [266, 905, 295, 1068], "vertical": true, "font_size": 22, "lines_coords": [[[267.0, 906.0], [289.0, 906.0], [289.0, 1057.0], [267.0, 1057.0]]], "lines": ["おかあさん"]}, {"box": [884, 1168, 940, 1436], "vertical": true, "font_size": 24, "lines_coords": [[[912.0, 1168.0], [939.0, 1168.0], [940.0, 1423.0], [914.0, 1423.0]], [[884.0, 1171.0], [906.0, 1171.0], [906.0, 1429.0], [884.0, 1429.0]]], "lines": ["．．．そうだ。もうすぐ", "お母さんの命日なんだ"]}, {"box": [719, 1171, 807, 1460], "vertical": true, "font_size": 25, "lines_coords": [[[781.0, 1171.0], [807.0, 1171.0], [807.0, 1400.0], [781.0, 1400.0]], [[750.0, 1171.0], [776.0, 1171.0], [776.0, 1348.0], [750.0, 1348.0]], [[720.0, 1171.0], [742.0, 1171.0], [742.0, 1456.0], [720.0, 1456.0]]], "lines": ["あたしはお母さんを", "写真の顔でしか", "思い出せないんだけどね"]}, {"box": [530, 1165, 620, 1447], "vertical": true, "font_size": 25, "lines_coords": [[[592.0, 1167.0], [618.0, 1167.0], [618.0, 1367.0], [592.0, 1367.0]], [[559.0, 1165.0], [586.0, 1165.0], [586.0, 1442.0], [559.0, 1442.0]], [[531.0, 1170.0], [553.0, 1170.0], [553.0, 1328.0], [531.0, 1328.0]]], "lines": ["あたしが３歳の時", "事故で死んだお母さんの", "年は確か２９歳"]}, {"box": [353, 1165, 446, 1307], "vertical": true, "font_size": 32, "lines_coords": [[[411.0, 1165.0], [446.0, 1165.0], [446.0, 1206.0], [411.0, 1206.0]], [[382.0, 1167.0], [411.0, 1167.0], [414.0, 1307.0], [386.0, 1307.0]], [[353.0, 1167.0], [386.0, 1167.0], [386.0, 1259.0], [353.0, 1259.0]]], "lines": ["２９、", "短いよなぁ、", "やっぱ。"]}, {"box": [170, 1165, 265, 1347], "vertical": true, "font_size": 32, "lines_coords": [[[231.0, 1165.0], [265.0, 1165.0], [265.0, 1275.0], [231.0, 1275.0]], [[198.0, 1167.0], [231.0, 1167.0], [231.0, 1343.0], [198.0, 1343.0]], [[170.0, 1170.0], [198.0, 1170.0], [198.0, 1296.0], [170.0, 1296.0]]], "lines": ["．．．？？？", "ねーちゃんは今", "２６歳だ．．．"]}], "img_path": "subarashii_sekai_02_038.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [465, 101, 492, 287], "vertical": true, "font_size": 20, "lines_coords": [[[467.0, 103.0], [487.0, 103.0], [487.0, 281.0], [467.0, 281.0]]], "lines": ["なんかヘンなの"]}, {"box": [296, 100, 417, 342], "vertical": true, "font_size": 26, "lines_coords": [[[390.0, 103.0], [417.0, 103.0], [417.0, 228.0], [390.0, 228.0]], [[357.0, 101.0], [386.0, 101.0], [387.0, 254.0], [359.0, 254.0]], [[331.0, 104.0], [353.0, 104.0], [353.0, 228.0], [331.0, 228.0]], [[296.0, 100.0], [323.0, 100.0], [325.0, 342.0], [298.0, 342.0]]], "lines": ["あと数年で", "ねーちゃんは", "お母さんを", "追い越しちゃうんだ。"]}, {"box": [167, 510, 229, 714], "vertical": true, "font_size": 30, "lines_coords": [[[201.0, 510.0], [228.0, 510.0], [226.0, 714.0], [200.0, 714.0]], [[167.0, 510.0], [200.0, 510.0], [200.0, 600.0], [167.0, 600.0]]], "lines": ["：：：ねーちゃんも", "大変だ。"]}, {"box": [756, 1264, 782, 1415], "vertical": true, "font_size": 22, "lines_coords": [[[757.0, 1267.0], [779.0, 1267.0], [779.0, 1409.0], [757.0, 1409.0]]], "lines": ["蒸し暑い．．．"]}, {"box": [595, 1262, 684, 1518], "vertical": true, "font_size": 25, "lines_coords": [[[656.0, 1264.0], [684.0, 1264.0], [684.0, 1365.0], [656.0, 1365.0]], [[625.0, 1262.0], [651.0, 1262.0], [651.0, 1439.0], [625.0, 1439.0]], [[595.0, 1264.0], [617.0, 1264.0], [617.0, 1514.0], [595.0, 1514.0]]], "lines": ["なんだか", "心も体も空気に", "溶けちゃうような．．．"]}, {"box": [185, 1264, 309, 1454], "vertical": true, "font_size": 28, "lines_coords": [[[281.0, 1265.0], [307.0, 1265.0], [307.0, 1453.0], [281.0, 1453.0]], [[246.0, 1265.0], [275.0, 1265.0], [275.0, 1400.0], [246.0, 1400.0]], [[214.0, 1264.0], [242.0, 1264.0], [245.0, 1401.0], [217.0, 1401.0]], [[185.0, 1265.0], [212.0, 1265.0], [212.0, 1398.0], [185.0, 1398.0]]], "lines": ["ああ、ごめん．．．", "ねーちゃん、", "あたしは今、", "腐ってます。"]}], "img_path": "subarashii_sekai_02_039.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [811, 600, 834, 709], "vertical": true, "font_size": 21, "lines_coords": [[[811.0, 600.0], [832.0, 600.0], [832.0, 709.0], [811.0, 709.0]]], "lines": ["おはよう。"]}, {"box": [914, 807, 1006, 965], "vertical": true, "font_size": 29, "lines_coords": [[[979.0, 810.0], [1006.0, 810.0], [1006.0, 943.0], [979.0, 943.0]], [[943.0, 807.0], [978.0, 807.0], [978.0, 892.0], [943.0, 892.0]], [[914.0, 809.0], [940.0, 809.0], [940.0, 932.0], [914.0, 932.0]]], "lines": ["ねーちゃん、", "朝から", "偉いすねー"]}, {"box": [709, 896, 801, 1081], "vertical": true, "font_size": 29, "lines_coords": [[[767.0, 896.0], [801.0, 896.0], [801.0, 979.0], [767.0, 979.0]], [[740.0, 898.0], [767.0, 898.0], [767.0, 1081.0], [740.0, 1081.0]], [[709.0, 896.0], [736.0, 896.0], [736.0, 985.0], [709.0, 985.0]]], "lines": ["洗濯物", "メチャたまってん", "のよね。"]}, {"box": [187, 812, 307, 965], "vertical": true, "font_size": 26, "lines_coords": [[[286.0, 814.0], [307.0, 814.0], [307.0, 965.0], [286.0, 965.0]], [[251.0, 814.0], [279.0, 814.0], [279.0, 956.0], [251.0, 956.0]], [[220.0, 814.0], [246.0, 814.0], [246.0, 943.0], [220.0, 943.0]], [[187.0, 812.0], [217.0, 812.0], [217.0, 860.0], [187.0, 860.0]]], "lines": ["結局きのうも", "タエ、帰って", "こなかった", "なー"]}, {"box": [137, 953, 229, 1139], "vertical": true, "font_size": 26, "lines_coords": [[[203.0, 953.0], [229.0, 953.0], [226.0, 1087.0], [200.0, 1087.0]], [[171.0, 960.0], [193.0, 960.0], [193.0, 1109.0], [171.0, 1109.0]], [[137.0, 957.0], [164.0, 957.0], [165.0, 1139.0], [139.0, 1139.0]]], "lines": ["．．．ってもう", "一週間くらい", "経つんじゃね？"]}, {"box": [614, 1315, 638, 1446], "vertical": true, "font_size": 23, "lines_coords": [[[614.0, 1315.0], [637.0, 1315.0], [637.0, 1392.0], [614.0, 1392.0]]], "lines": ["．．．ねー"]}, {"box": [134, 1325, 225, 1456], "vertical": true, "font_size": 27, "lines_coords": [[[192.0, 1326.0], [225.0, 1326.0], [225.0, 1407.0], [192.0, 1407.0]], [[160.0, 1326.0], [187.0, 1325.0], [193.0, 1454.0], [167.0, 1456.0]], [[134.0, 1328.0], [156.0, 1328.0], [156.0, 1456.0], [134.0, 1456.0]]], "lines": ["あれ？", "ねーちゃん", "その指輪？"]}], "img_path": "subarashii_sekai_02_040.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [568, 96, 634, 228], "vertical": true, "font_size": 30, "lines_coords": [[[601.0, 96.0], [634.0, 96.0], [634.0, 179.0], [601.0, 179.0]], [[572.0, 96.0], [598.0, 96.0], [595.0, 228.0], [568.0, 228.0]]], "lines": ["やっと", "気付いた？"]}, {"box": [179, 128, 207, 207], "vertical": true, "font_size": 28, "lines_coords": [[[179.0, 128.0], [207.0, 128.0], [207.0, 207.0], [179.0, 207.0]]], "lines": ["あら？"]}, {"box": [918, 379, 978, 506], "vertical": true, "font_size": 28, "lines_coords": [[[951.0, 379.0], [978.0, 379.0], [978.0, 506.0], [951.0, 506.0]], [[918.0, 381.0], [945.0, 381.0], [945.0, 506.0], [918.0, 506.0]]], "lines": ["ねーちゃん", "マジすか！？"]}, {"box": [887, 568, 950, 700], "vertical": true, "font_size": 28, "lines_coords": [[[914.0, 568.0], [947.0, 568.0], [950.0, 689.0], [917.0, 689.0]], [[887.0, 570.0], [914.0, 570.0], [914.0, 700.0], [887.0, 700.0]]], "lines": ["へーっ、", "そうかぁ！！"]}, {"box": [403, 746, 439, 807], "vertical": true, "font_size": 36, "lines_coords": [[[403.0, 746.0], [439.0, 746.0], [439.0, 807.0], [403.0, 807.0]]], "lines": ["ん？"]}, {"box": [847, 1262, 881, 1370], "vertical": true, "font_size": 34, "lines_coords": [[[847.0, 1262.0], [881.0, 1262.0], [881.0, 1370.0], [847.0, 1370.0]]], "lines": ["あ．．．．．．"]}], "img_path": "subarashii_sekai_02_041.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [926, 696, 987, 801], "vertical": true, "font_size": 28, "lines_coords": [[[959.0, 698.0], [987.0, 698.0], [987.0, 801.0], [959.0, 801.0]], [[926.0, 696.0], [959.0, 696.0], [959.0, 785.0], [926.0, 785.0]]], "lines": ["ふふ．．．", "大丈夫。"]}, {"box": [593, 707, 664, 845], "vertical": true, "font_size": 30, "lines_coords": [[[618.0, 712.0], [654.0, 707.0], [664.0, 778.0], [628.0, 782.0]], [[593.0, 712.0], [620.0, 712.0], [623.0, 845.0], [597.0, 845.0]]], "lines": ["ねぇ、", "憶えてる？"]}, {"box": [865, 846, 923, 1014], "vertical": true, "font_size": 28, "lines_coords": [[[901.0, 850.0], [923.0, 850.0], [923.0, 1014.0], [901.0, 1014.0]], [[865.0, 846.0], [892.0, 846.0], [892.0, 1012.0], [865.0, 1012.0]]], "lines": ["タエ、そろそろ", "帰ってくるよ。"]}, {"box": [479, 800, 575, 979], "vertical": true, "font_size": 30, "lines_coords": [[[548.0, 804.0], [575.0, 804.0], [575.0, 906.0], [548.0, 906.0]], [[517.0, 803.0], [543.0, 803.0], [543.0, 979.0], [517.0, 979.0]], [[479.0, 801.0], [514.0, 800.0], [517.0, 870.0], [482.0, 871.0]]], "lines": ["母さんが", "亡くなった日の", "こと。"]}, {"box": [762, 1295, 793, 1353], "vertical": true, "font_size": 31, "lines_coords": [[[762.0, 1295.0], [793.0, 1295.0], [793.0, 1353.0], [762.0, 1353.0]]], "lines": ["え？"]}, {"box": [350, 1132, 470, 1317], "vertical": true, "font_size": 26, "lines_coords": [[[443.0, 1135.0], [470.0, 1135.0], [470.0, 1260.0], [443.0, 1260.0]], [[412.0, 1132.0], [439.0, 1132.0], [440.0, 1317.0], [414.0, 1317.0]], [[379.0, 1134.0], [406.0, 1134.0], [406.0, 1264.0], [379.0, 1264.0]], [[350.0, 1134.0], [376.0, 1134.0], [376.0, 1271.0], [350.0, 1271.0]]], "lines": ["６月の雨が", "降ってる日でさ、", "タエが家を", "飛び出して、"]}, {"box": [184, 1298, 336, 1478], "vertical": true, "font_size": 26, "lines_coords": [[[306.0, 1298.0], [332.0, 1298.0], [336.0, 1454.0], [309.0, 1454.0]], [[276.0, 1300.0], [303.0, 1300.0], [304.0, 1478.0], [278.0, 1478.0]], [[242.0, 1303.0], [268.0, 1303.0], [271.0, 1429.0], [245.0, 1429.0]], [[210.0, 1301.0], [237.0, 1301.0], [240.0, 1456.0], [214.0, 1456.0]], [[184.0, 1304.0], [206.0, 1304.0], [206.0, 1429.0], [184.0, 1429.0]]], "lines": ["あたしたちと", "母さんの３人で", "手分けして", "捜そうとした", "じゃない？"]}], "img_path": "subarashii_sekai_02_042.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [864, 92, 985, 360], "vertical": true, "font_size": 26, "lines_coords": [[[958.0, 93.0], [984.0, 93.0], [984.0, 323.0], [958.0, 323.0]], [[926.0, 93.0], [953.0, 93.0], [953.0, 346.0], [926.0, 346.0]], [[892.0, 92.0], [918.0, 92.0], [922.0, 235.0], [895.0, 235.0]], [[864.0, 93.0], [890.0, 93.0], [890.0, 360.0], [864.0, 360.0]]], "lines": ["その途中で母さんは", "スリップしたクルマに", "はねられて、", "亡くなっちゃったけど。"]}, {"box": [515, 296, 639, 503], "vertical": true, "font_size": 28, "lines_coords": [[[609.0, 296.0], [637.0, 296.0], [639.0, 437.0], [611.0, 437.0]], [[579.0, 298.0], [606.0, 298.0], [606.0, 500.0], [579.0, 500.0]], [[546.0, 298.0], [573.0, 298.0], [573.0, 503.0], [546.0, 503.0]], [[515.0, 298.0], [543.0, 298.0], [543.0, 387.0], [515.0, 387.0]]], "lines": ["タエのヤツ、", "自分でちゃっかり", "家に戻ってきてた", "のよね。"]}, {"box": [92, 53, 339, 84], "vertical": false, "font_size": 31, "lines_coords": [[[92.0, 53.0], [339.0, 53.0], [339.0, 84.0], [92.0, 84.0]]], "lines": ["素晴らしい世界２"]}, {"box": [178, 206, 268, 393], "vertical": true, "font_size": 25, "lines_coords": [[[239.0, 206.0], [265.0, 206.0], [268.0, 387.0], [242.0, 387.0]], [[209.0, 207.0], [235.0, 207.0], [235.0, 387.0], [209.0, 387.0]], [[178.0, 209.0], [201.0, 209.0], [203.0, 393.0], [179.0, 393.0]]], "lines": ["そしたらあのコ", "キョトンとした", "顔で言うワケよ。"]}, {"box": [517, 565, 675, 792], "vertical": true, "font_size": 28, "lines_coords": [[[648.0, 568.0], [675.0, 568.0], [675.0, 723.0], [648.0, 723.0]], [[615.0, 570.0], [643.0, 570.0], [643.0, 706.0], [615.0, 706.0]], [[582.0, 565.0], [611.0, 565.0], [612.0, 792.0], [584.0, 792.0]], [[550.0, 567.0], [576.0, 567.0], [576.0, 759.0], [550.0, 759.0]], [[517.0, 567.0], [551.0, 567.0], [551.0, 635.0], [517.0, 635.0]]], "lines": ["あたし聞いて", "やったわよ、", "「あんたどうやって", "帰ってきたの？」", "って。"]}, {"box": [117, 454, 235, 620], "vertical": true, "font_size": 25, "lines_coords": [[[209.0, 454.0], [235.0, 454.0], [235.0, 620.0], [209.0, 620.0]], [[178.0, 456.0], [204.0, 456.0], [204.0, 587.0], [178.0, 587.0]], [[146.0, 456.0], [170.0, 456.0], [171.0, 607.0], [148.0, 607.0]], [[117.0, 457.0], [139.0, 457.0], [139.0, 595.0], [117.0, 595.0]]], "lines": ["「虹がどこから", "出てるのか、", "見ようとして", "歩いてたら」"]}, {"box": [153, 778, 217, 981], "vertical": true, "font_size": 31, "lines_coords": [[[189.0, 778.0], [217.0, 778.0], [214.0, 981.0], [185.0, 981.0]], [[156.0, 778.0], [189.0, 779.0], [185.0, 870.0], [153.0, 868.0]]], "lines": ["「この家があった」", "ってさ。"]}], "img_path": "subarashii_sekai_02_043.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [], "img_path": "subarashii_sekai_02_044.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [790, 104, 914, 348], "vertical": true, "font_size": 28, "lines_coords": [[[886.0, 106.0], [914.0, 106.0], [914.0, 207.0], [886.0, 207.0]], [[854.0, 106.0], [886.0, 106.0], [886.0, 312.0], [854.0, 312.0]], [[825.0, 107.0], [851.0, 107.0], [851.0, 295.0], [825.0, 295.0]], [[790.0, 104.0], [818.0, 104.0], [822.0, 348.0], [793.0, 348.0]]], "lines": ["あの日の", "タエが出ていった", "理由って、ホント", "くだらなかったなぁ。"]}, {"box": [622, 170, 745, 403], "vertical": true, "font_size": 28, "lines_coords": [[[718.0, 173.0], [745.0, 173.0], [745.0, 376.0], [718.0, 376.0]], [[684.0, 170.0], [711.0, 170.0], [714.0, 401.0], [687.0, 401.0]], [[654.0, 173.0], [681.0, 173.0], [681.0, 381.0], [654.0, 381.0]], [[622.0, 173.0], [648.0, 173.0], [650.0, 403.0], [623.0, 403.0]]], "lines": ["オタマジャクシが", "成長するとカエルに", "なるっていうのを、", "タエが信じなくて．．．"]}, {"box": [185, 131, 226, 181], "vertical": true, "font_size": 30, "lines_coords": [[[185.0, 137.0], [217.0, 131.0], [226.0, 175.0], [195.0, 181.0]]], "lines": ["そ。"]}, {"box": [104, 232, 231, 453], "vertical": true, "font_size": 30, "lines_coords": [[[198.0, 232.0], [231.0, 232.0], [231.0, 326.0], [198.0, 326.0]], [[165.0, 232.0], [196.0, 232.0], [201.0, 442.0], [170.0, 442.0]], [[131.0, 234.0], [162.0, 232.0], [170.0, 451.0], [139.0, 453.0]], [[104.0, 235.0], [131.0, 235.0], [135.0, 417.0], [109.0, 417.0]]], "lines": ["「大人の", "オタマジャクシを", "探してくるー」って", "出てっちゃった"]}, {"box": [73, 237, 101, 328], "vertical": true, "font_size": 30, "lines_coords": [[[73.0, 237.0], [101.0, 237.0], [101.0, 328.0], [73.0, 328.0]]], "lines": ["のよね。"]}, {"box": [600, 593, 690, 786], "vertical": true, "font_size": 25, "lines_coords": [[[664.0, 596.0], [690.0, 596.0], [690.0, 785.0], [664.0, 785.0]], [[631.0, 595.0], [659.0, 595.0], [659.0, 700.0], [631.0, 700.0]], [[600.0, 593.0], [622.0, 593.0], [625.0, 782.0], [603.0, 782.0]]], "lines": ["ホント、あのコは", "昔っから", "ああなんだから。"]}, {"box": [848, 829, 971, 1016], "vertical": true, "font_size": 26, "lines_coords": [[[943.0, 831.0], [970.0, 831.0], [970.0, 957.0], [943.0, 957.0]], [[912.0, 831.0], [939.0, 831.0], [939.0, 1015.0], [912.0, 1015.0]], [[883.0, 831.0], [904.0, 831.0], [904.0, 954.0], [883.0, 954.0]], [[848.0, 829.0], [876.0, 829.0], [876.0, 918.0], [848.0, 918.0]]], "lines": ["体ばっかり", "大きくなっても、", "中身は昔の", "まんま。"]}, {"box": [104, 1004, 234, 1218], "vertical": true, "font_size": 29, "lines_coords": [[[203.0, 1006.0], [229.0, 1006.0], [232.0, 1218.0], [206.0, 1218.0]], [[170.0, 1006.0], [196.0, 1006.0], [200.0, 1212.0], [173.0, 1212.0]], [[137.0, 1007.0], [165.0, 1007.0], [168.0, 1162.0], [140.0, 1162.0]], [[104.0, 1006.0], [139.0, 1004.0], [142.0, 1075.0], [107.0, 1076.0]]], "lines": ["やっぱりあたしは", "あのコの母親には", "なれなかった", "なぁ。"]}, {"box": [290, 1323, 378, 1498], "vertical": true, "font_size": 22, "lines_coords": [[[354.0, 1325.0], [376.0, 1325.0], [376.0, 1475.0], [354.0, 1475.0]], [[321.0, 1323.0], [343.0, 1323.0], [343.0, 1498.0], [321.0, 1498.0]], [[290.0, 1325.0], [312.0, 1325.0], [312.0, 1434.0], [290.0, 1434.0]]], "lines": ["ねーちゃんは", "よくやってると", "思うすよ。"]}], "img_path": "subarashii_sekai_02_045.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [898, 90, 1018, 253], "vertical": true, "font_size": 26, "lines_coords": [[[992.0, 93.0], [1018.0, 93.0], [1018.0, 231.0], [992.0, 231.0]], [[961.0, 90.0], [989.0, 90.0], [986.0, 245.0], [958.0, 245.0]], [[926.0, 92.0], [953.0, 92.0], [956.0, 245.0], [929.0, 245.0]], [[898.0, 93.0], [920.0, 93.0], [920.0, 253.0], [898.0, 253.0]]], "lines": ["よし、タエが", "帰ってきたら", "久々にきつく", "言ってやるか。"]}, {"box": [767, 196, 825, 323], "vertical": true, "font_size": 26, "lines_coords": [[[798.0, 196.0], [825.0, 196.0], [825.0, 323.0], [798.0, 323.0]], [[767.0, 198.0], [793.0, 198.0], [793.0, 300.0], [767.0, 300.0]]], "lines": ["もうこれが", "最後かも"]}, {"box": [732, 195, 824, 335], "vertical": true, "font_size": 26, "lines_coords": [[[732.0, 195.0], [759.0, 195.0], [762.0, 334.0], [736.0, 334.0]]], "lines": ["しれないし。"]}, {"box": [470, 95, 596, 260], "vertical": true, "font_size": 27, "lines_coords": [[[568.0, 96.0], [595.0, 96.0], [595.0, 223.0], [568.0, 223.0]], [[537.0, 95.0], [564.0, 95.0], [564.0, 225.0], [537.0, 225.0]], [[504.0, 95.0], [532.0, 95.0], [532.0, 198.0], [504.0, 198.0]], [[470.0, 95.0], [496.0, 95.0], [503.0, 260.0], [476.0, 260.0]]], "lines": ["これからは", "あんたにも", "頑張って", "もらわなきゃ。"]}, {"box": [695, 570, 728, 662], "vertical": true, "font_size": 33, "lines_coords": [[[695.0, 570.0], [728.0, 570.0], [728.0, 662.0], [695.0, 662.0]]], "lines": ["ですね。"]}, {"box": [418, 579, 448, 645], "vertical": true, "font_size": 30, "lines_coords": [[[418.0, 579.0], [448.0, 579.0], [448.0, 645.0], [418.0, 645.0]]], "lines": ["うす。"]}, {"box": [270, 1259, 314, 1464], "vertical": true, "font_size": 44, "lines_coords": [[[270.0, 1259.0], [314.0, 1259.0], [314.0, 1464.0], [270.0, 1464.0]]], "lines": ["ただいま！"]}], "img_path": "subarashii_sekai_02_046.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [145, 92, 156, 196], "vertical": true, "font_size": 11, "lines_coords": [[[145.0, 92.0], [156.0, 92.0], [156.0, 196.0], [145.0, 196.0]]], "lines": ["．．．"]}, {"box": [223, 95, 229, 106], "vertical": false, "font_size": 11, "lines_coords": [[[223.0, 95.0], [229.0, 95.0], [229.0, 106.0], [223.0, 106.0]]], "lines": ["．．．"]}, {"box": [278, 67, 289, 85], "vertical": false, "font_size": 18, "lines_coords": [[[278.0, 67.0], [289.0, 67.0], [289.0, 85.0], [278.0, 85.0]]], "l