っ．．．"]}, {"box": [642, 937, 668, 1042], "vertical": true, "font_size": 26, "lines_coords": [[[642.0, 937.0], [668.0, 937.0], [668.0, 1040.0], [642.0, 1040.0]]], "lines": ["はは．．．"]}, {"box": [154, 996, 242, 1160], "vertical": true, "font_size": 25, "lines_coords": [[[215.0, 998.0], [242.0, 998.0], [242.0, 1160.0], [215.0, 1160.0]], [[181.0, 996.0], [215.0, 996.0], [215.0, 1078.0], [181.0, 1078.0]], [[154.0, 1000.0], [176.0, 1000.0], [176.0, 1159.0], [154.0, 1159.0]]], "lines": ["もう２年だよ。", "ホント", "久し振りだよ。"]}, {"box": [373, 1212, 511, 1285], "vertical": false, "font_size": 25, "lines_coords": [[[382.0, 1212.0], [511.0, 1262.0], [501.0, 1285.0], [373.0, 1235.0]]], "lines": ["ｍｅｎｔＳｔｏｒｅ"]}, {"box": [146, 1245, 200, 1423], "vertical": true, "font_size": 25, "lines_coords": [[[178.0, 1245.0], [200.0, 1245.0], [200.0, 1354.0], [178.0, 1354.0]], [[146.0, 1245.0], [168.0, 1245.0], [168.0, 1423.0], [146.0, 1423.0]]], "lines": ["どうなの、", "最近の調子は？"]}], "img_path": "subarashii_sekai_02_136.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [886, 125, 977, 329], "vertical": true, "font_size": 25, "lines_coords": [[[953.0, 129.0], [975.0, 129.0], [975.0, 329.0], [953.0, 329.0]], [[918.0, 128.0], [945.0, 128.0], [945.0, 281.0], [918.0, 281.0]], [[889.0, 125.0], [915.0, 125.0], [912.0, 268.0], [886.0, 268.0]]], "lines": ["別に．．．．．．フツーに", "中学校の教師", "やってるよ。"]}, {"box": [248, 96, 308, 300], "vertical": true, "font_size": 27, "lines_coords": [[[279.0, 96.0], [306.0, 96.0], [306.0, 250.0], [279.0, 250.0]], [[248.0, 96.0], [275.0, 96.0], [275.0, 300.0], [248.0, 300.0]]], "lines": ["そうかぁ．．．", "ホントよかっ．．．"]}, {"box": [178, 254, 204, 350], "vertical": true, "font_size": 26, "lines_coords": [[[178.0, 254.0], [204.0, 254.0], [204.0, 350.0], [178.0, 350.0]]], "lines": ["．．．あの"]}, {"box": [898, 472, 920, 568], "vertical": true, "font_size": 22, "lines_coords": [[[898.0, 475.0], [920.0, 475.0], [920.0, 568.0], [898.0, 568.0]]], "lines": ["左右確認・"]}, {"box": [754, 507,