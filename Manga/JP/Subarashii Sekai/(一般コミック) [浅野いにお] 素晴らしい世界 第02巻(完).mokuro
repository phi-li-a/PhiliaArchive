 1414.0], [440.0, 1471.0], [425.0, 1471.0]]], "lines": ["．．．"]}, {"box": [500, 1414, 515, 1468], "vertical": true, "font_size": 15, "lines_coords": [[[500.0, 1414.0], [515.0, 1414.0], [515.0, 1468.0], [500.0, 1468.0]]], "lines": ["．．．"]}, {"box": [653, 1410, 664, 1432], "vertical": false, "font_size": 22, "lines_coords": [[[653.0, 1410.0], [664.0, 1410.0], [664.0, 1432.0], [653.0, 1432.0]]], "lines": ["！"]}, {"box": [665, 1356, 686, 1482], "vertical": true, "font_size": 18, "lines_coords": [[[665.0, 1356.0], [682.0, 1356.0], [686.0, 1482.0], [668.0, 1482.0]]], "lines": ["．．．"]}], "img_path": "subarashii_sekai_02_194.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [109, 59, 520, 89], "vertical": false, "font_size": 26, "lines_coords": [[[109.0, 62.0], [520.0, 59.0], [520.0, 85.0], [109.0, 89.0]]], "lines": ["Ｌａｓｔｐｒｏｇｒａｍ桜の季節"]}, {"box": [204, 325, 531, 346], "vertical": false, "font_size": 25, "lines_coords": [[[204.0, 325.0], [531.0, 325.0], [531.0, 346.0], [204.0, 346.0]]], "lines": ["一年中つけられたままの風俗"]}, {"box": [203, 390, 559, 450], "vertical": false, "font_size": 25, "lines_coords": [[[203.0, 390.0], [559.0, 392.0], [559.0, 418.0], [203.0, 417.0]], [[300.0, 423.0], [459.0, 423.0], [459.0, 450.0], [300.0, 450.0]]], "lines": ["それは、僕の季師感が薄れている", "何よりの証拠。"]}, {"box": [264, 881, 294, 999], "vertical": true, "font_size": 30, "lines_coords": [[[264.0, 881.0], [294.0, 881.0], [294.0, 999.0], [264.0, 999.0]]], "lines": ["プッーっ"]}], "img_path": "subarashii_sekai_02_195.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [121, 117, 479, 139], "vertical": false, "font_size": 23, "lines_coords": [[[121.0, 117.0], [479.0, 117.0], [479.0, 139.0], [121.0, 139.0]]], "lines": ["彼女もついいに発病してしまった"]}, {"box": [176, 220, 481, 306], "vertical": false, "font_size": 23, "lines_coords": [[[176.0, 220.0], [446.0, 220.0], [446.0, 242.0], [176.0, 242.0]], [[251.0, 248.0], [403.0, 248.0], [403.0, 275.0], [251.0, 275.0]], [[329.0, 284.0], [481.0, 284.0], [481.0, 306.0], [329.0, 306.0]]], "lines": ["考えろことのいっさいを", "やめてしまう", "新しい流行病"]}, {"box": [876, 571, 936, 759], "vertical": true, "font_size": 28, "lines_coords": [[[908.0, 571.0], [936.0, 571.0], [936.0, 682.0], [908.0, 682.0]], [[876.0, 571.0], [903.0, 571.0], [903.0, 759.0], [876.0, 759.0]]], "lines": ["じゃあ俺、", "行ってくるから。"]}, {"box": [235, 434, 480, 529], "vertical": false, "font_size": 36, "lines_coords": [[[239.0, 434.0], [417.0, 434.0], [417.0, 473.0], [239.0, 473.0]], [[235.0, 459.0], [417.0, 464.0], [417.0, 501.0], [235.0, 496.0]], [[287.0, 496.0], [476.0, 496.0], [476.0, 529.0], [287.0, 529.0]]], "lines": ["現代人にとって", "ある意味とても", "都合のいい病気。"]}, {"box": [178, 745, 268, 871], "vertical": true, "font_size": 24, "lines_coords": [[[245.0, 748.0], [267.0, 748.0], [267.0, 871.0], [245.0, 871.0]], [[210.0, 745.0], [237.0, 745.0], [237.0, 871.0], [210.0, 871.0]], [[181.0, 745.0], [204.0, 745.0], [201.0, 856.0], [178.0, 856.0]]], "lines": ["今日こそは", "仕事見つけ", "ないとな。"]}, {"box": [178, 970, 382, 1073], "vertical": false, "font_size": 34, "lines_coords": [[[178.0, 975.0], [307.0, 970.0], [309.0, 1004.0], [179.0, 1009.0]], [[178.0, 1006.0], [379.0, 1006.0], [379.0, 1039.0], [178.0, 1039.0]], [[240.0, 1034.0], [332.0, 1039.0], [331.0, 1073.0], [239.0, 1068.0]]], "lines": ["その病気が", "流行りだしたのは", "一年前。"]}], "img_path": "subarashii_sekai_02_196.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [517, 185, 740, 247], "vertical": false, "font_size": 27, "lines_coords": [[[523.0, 187.0], [690.0, 187.0], [690.0, 214.0], [523.0, 214.0]], [[550.0, 218.0], [737.0, 218.0], [737.0, 245.0], [550.0, 245.0]]], "lines": ["原因も治療法も", "わからないまま。"]}, {"box": [85, 60, 336, 90], "vertical": false, "font_size": 26, "lines_coords": [[[85.0, 60.0], [336.0, 64.0], [336.0, 90.0], [85.0, 87.0]]], "lines": ["素晴らしい世界２"]}, {"box": [559, 696, 975, 731], "vertical": false, "font_size": 32, "lines_coords": [[[559.0, 700.0], [975.0, 696.0], [975.0, 728.0], [559.0, 731.0]]], "lines": ["Ｌａｓｔｐｒｏｇｒａｍ桜の季節"]}, {"box": [240, 410, 411, 432], "vertical": false, "font_size": 30, "lines_coords": [[[240.0, 410.0], [411.0, 410.0], [411.0, 432.0], [240.0, 432.0]]], "lines": ["そして一か月前"]}, {"box": [151, 476, 445, 573], "vertical": false, "font_size": 30, "lines_coords": [[[204.0, 507.0], [367.0, 507.0], [367.0, 539.0], [204.0, 539.0]], [[151.0, 476.0], [407.0, 478.0], [407.0, 509.0], [151.0, 507.0]], [[256.0, 537.0], [445.0, 540.0], [445.0, 573.0], [256.0, 570.0]]], "lines": ["人形のように", "彼女はリモコンで動く", "なってしまった。"]}, {"box": [560, 961, 583, 1058], "vertical": true, "font_size": 17, "lines_coords": [[[562.0, 962.0], [579.0, 962.0], [579.0, 1054.0], [562.0, 1054.0]]], "lines": ["左右確認"]}], "img_path": "subarashii_sekai_02_197.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [902, 278, 945, 570], "vertical": true, "font_size": 32, "lines_coords": [[[908.0, 281.0], [940.0, 281.0], [945.0, 570.0], [912.0, 570.0]]], "lines": ["出前持ち冬事"]}, {"box": [839, 346, 875, 543], "vertical": true, "font_size": 33, "lines_coords": [[[839.0, 346.0], [872.0, 346.0], [875.0, 543.0], [842.0, 543.0]]], "lines": ["時給応相談"]}, {"box": [772, 409, 798, 556], "vertical": true, "font_size": 26, "lines_coords": [[[772.0, 409.0], [798.0, 409.0], [798.0, 556.0], [772.0, 556.0]]], "lines": ["そばベジル"]}, {"box": [582, 709, 610, 837], "vertical": true, "font_size": 27, "lines_coords": [[[582.0, 709.0], [609.0, 709.0], [609.0, 837.0], [582.0, 837.0]]], "lines": ["やるかい？"]}, {"box": [931, 1012, 989, 1165], "vertical": true, "font_size": 27, "lines_coords": [[[962.0, 1014.0], [989.0, 1014.0], [989.0, 1117.0], [962.0, 1117.0]], [[931.0, 1012.0], [958.0, 1012.0], [958.0, 1165.0], [931.0, 1165.0]]], "lines": ["原付免許", "持ってるか？"]}, {"box": [526, 1095, 567, 1170], "vertical": true, "font_size": 41, "lines_coords": [[[526.0, 1095.0], [567.0, 1095.0], [567.0, 1170.0], [526.0, 1170.0]]], "lines": ["はい。"]}, {"box": [590, 1332, 653, 1472], "vertical": true, "font_size": 30, "lines_coords": [[[620.0, 1332.0], [653.0, 1332.0], [653.0, 1425.0], [620.0, 1425.0]], [[590.0, 1334.0], [617.0, 1334.0], [617.0, 1471.0], [590.0, 1471.0]]], "lines": ["じゃあ、", "決まりだな。"]}, {"box": [185, 1128, 276, 1315], "vertical": true, "font_size": 24, "lines_coords": [[[251.0, 1129.0], [273.0, 1129.0], [273.0, 1304.0], [251.0, 1304.0]], [[217.0, 1128.0], [243.0, 1128.0], [243.0, 1256.0], [217.0, 1256.0]], [[185.0, 1128.0], [209.0, 1128.0], [210.0, 1314.0], [187.0, 1314.0]]], "lines": ["婆さんも息子も", "あの病気で", "使えねぇからよ。"]}], "img_path": "subarashii_sekai_02_198.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [835, 103, 987, 325], "vertical": true, "font_size": 27, "lines_coords": [[[961.0, 104.0], [987.0, 104.0], [987.0, 248.0], [961.0, 248.0]], [[928.0, 106.0], [954.0, 106.0], [954.0, 259.0], [928.0, 259.0]], [[890.0, 103.0], [923.0, 103.0], [926.0, 312.0], [893.0, 312.0]], [[862.0, 104.0], [890.0, 104.0], [893.0, 325.0], [865.0, 325.0]], [[836.0, 107.0], [858.0, 107.0], [858.0, 243.0], [836.0, 243.0]]], "lines": ["まあ、こんな", "ご時勢だから", "仕事もとりたてて", "忙しいってワケじゃ", "ないけどな。"]}, {"box": [284, 156, 311, 269], "vertical": true, "font_size": 27, "lines_coords": [[[284.0, 156.0], [311.0, 156.0], [311.0, 268.0], [284.0, 268.0]]], "lines": ["そうだな。"]}, {"box": [822, 704, 862, 787], "vertical": true, "font_size": 40, "lines_coords": [[[822.0, 704.0], [862.0, 704.0], [862.0, 787.0], [822.0, 787.0]]], "lines": ["へっ！"]}, {"box": [611, 503, 734, 666], "vertical": true, "font_size": 26, "lines_coords": [[[706.0, 503.0], [732.0, 503.0], [732.0, 637.0], [706.0, 637.0]], [[673.0, 503.0], [700.0, 503.0], [700.0, 656.0], [673.0, 656.0]], [[642.0, 503.0], [668.0, 503.0], [668.0, 654.0], [642.0, 654.0]], [[611.0, 503.0], [637.0, 503.0], [637.0, 665.0], [611.0, 665.0]]], "lines": ["そういえば、", "ここの通りも", "ずいぶん人が", "減りましたね。"]}, {"box": [134, 954, 259, 1133], "vertical": true, "font_size": 29, "lines_coords": [[[225.0, 954.0], [259.0, 954.0], [259.0, 1037.0], [225.0, 1037.0]], [[200.0, 956.0], [221.0, 956.0], [221.0, 1132.0], [200.0, 1132.0]], [[160.0, 954.0], [195.0, 954.0], [195.0, 1045.0], [160.0, 1045.0]], [[134.0, 956.0], [160.0, 956.0], [160.0, 1068.0], [134.0, 1068.0]]], "lines": ["この先", "どうなっちまう", "のかね、", "世の中は。"]}], "img_path": "subarashii_sekai_02_199.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [958, 79, 1026, 293], "vertical": true, "font_size": 29, "lines_coords": [[[984.0, 79.0], [1026.0, 79.0], [1026.0, 151.0], [984.0, 151.0]], [[959.0, 81.0], [987.0, 81.0], [986.0, 293.0], [958.0, 293.0]]], "lines": ["ふふ、", "ラッキーだったよ。"]}, {"box": [612, 129, 702, 344], "vertical": true, "font_size": 26, "lines_coords": [[[675.0, 131.0], [701.0, 131.0], [701.0, 257.0], [675.0, 257.0]], [[640.0, 129.0], [668.0, 129.0], [672.0, 343.0], [643.0, 343.0]], [[612.0, 129.0], [636.0, 129.0], [637.0, 340.0], [614.0, 340.0]]], "lines": ["これからは", "夕飯も、もうちょい", "ゴウカにできるよ。"]}, {"box": [917, 307, 1006, 521], "vertical": true, "font_size": 29, "lines_coords": [[[978.0, 307.0], [1006.0, 307.0], [1006.0, 410.0], [978.0, 410.0]], [[947.0, 307.0], [973.0, 307.0], [973.0, 489.0], [947.0, 489.0]], [[917.0, 310.0], [939.0, 310.0], [939.0, 521.0], [917.0, 521.0]]], "lines": ["最近じゃ", "ロクにバイトも", "できないんだから。"]}, {"box": [193, 601, 223, 731], "vertical": true, "font_size": 27, "lines_coords": [[[193.0, 617.0], [220.0, 617.0], [220.0, 731.0], [193.0, 731.0]]], "lines": ["．．．服い？"]}, {"box": [875, 731, 965, 871], "vertical": true, "font_size": 25, "lines_coords": [[[939.0, 732.0], [965.0, 732.0], [965.0, 871.0], [939.0, 871.0]], [[909.0, 734.0], [931.0, 734.0], [931.0, 859.0], [909.0, 859.0]], [[875.0, 731.0], [903.0, 731.0], [903.0, 823.0], [875.0, 823.0]]], "lines": ["よし、じゃあ", "今日はもう", "寝よう。"]}, {"box": [851, 921, 909, 1073], "vertical": true, "font_size": 25, "lines_coords": [[[887.0, 921.0], [909.0, 921.0], [909.0, 1073.0], [887.0, 1073.0]], [[851.0, 921.0], [879.0, 921.0], [881.0, 1057.0], [853.0, 1057.0]]], "lines": ["俺も明日から", "バイトだし。"]}, {"box": [137, 981, 228, 1132], "vertical": true, "font_size": 27, "lines_coords": [[[201.0, 981.0], [228.0, 981.0], [228.0, 1132.0], [201.0, 1132.0]], [[167.0, 981.0], [193.0, 981.0], [196.0, 1132.0], [170.0, 1132.0]], [[137.0, 982.0], [164.0, 982.0], [164.0, 1090.0], [137.0, 1090.0]]], "lines": ["でも寝る前に", "トイレ行って", "おこうな。"]}, {"box": [200, 1275, 467, 1370], "vertical": false, "font_size": 30, "lines_coords": [[[201.0, 1275.0], [461.0, 1275.0], [461.0, 1306.0], [201.0, 1306.0]], [[228.0, 1307.0], [403.0, 1307.0], [403.0, 1339.0], [228.0, 1339.0]], [[279.0, 1340.0], [368.0, 1340.0], [368.0, 1368.0], [279.0, 1368.0]]], "lines": ["促せば食事もトイレも", "歩くことだって", "できる。"]}], "img_path": "subarashii_sekai_02_200.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [100, 65, 342, 93], "vertical": false, "font_size": 25, "lines_coords": [[[100.0, 65.0], [342.0, 68.0], [342.0, 93.0], [100.0, 90.0]]], "lines": ["素晴らしい世界って"]}, {"box": [129, 195, 461, 260], "vertical": false, "font_size": 32, "lines_coords": [[[210.0, 196.0], [264.0, 196.0], [264.0, 228.0], [210.0, 228.0]], [[134.0, 223.0], [448.0, 226.0], [448.0, 257.0], [134.0, 254.0]]], "lines": ["でも", "意志も感情もほったくない"]}, {"box": [136, 360, 403, 396], "vertical": false, "font_size": 26, "lines_coords": [[[139.0, 364.0], [390.0, 364.0], [390.0, 390.0], [139.0, 390.0]]], "lines": ["返事すらしてくれない"]}, {"box": [115, 532, 412, 635], "vertical": false, "font_size": 34, "lines_coords": [[[190.0, 532.0], [282.0, 540.0], [279.0, 571.0], [187.0, 564.0]], [[115.0, 568.0], [395.0, 568.0], [395.0, 600.0], [115.0, 600.0]], [[117.0, 595.0], [407.0, 595.0], [407.0, 632.0], [117.0, 632.0]]], "lines": ["だから、", "彼女はここにいながらも", "もうここにはいないのだ。"]}, {"box": [179, 838, 449, 873], "vertical": false, "font_size": 22, "lines_coords": [[[185.0, 843.0], [443.0, 843.0], [443.0, 865.0], [185.0, 865.0]]], "lines": ["そう思うと僕は．．．"]}], "img_path": "subarashii_sekai_02_201.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [], "img_path": "subarashii_sekai_02_202.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [886, 126, 918, 246], "vertical": true, "font_size": 32, "lines_coords": [[[886.0, 126.0], [918.0, 126.0], [918.0, 246.0], [886.0, 246.0]]], "lines": ["桜．．．．．か。"]}, {"box": [98, 67, 342, 93], "vertical": false, "font_size": 26, "lines_coords": [[[98.0, 67.0], [342.0, 67.0], [342.0, 93.0], [98.0, 93.0]]], "lines": ["素晴らしい世界２"]}, {"box": [125, 704, 214, 869], "vertical": true, "font_size": 26, "lines_coords": [[[184.0, 704.0], [210.0, 704.0], [214.0, 840.0], [187.0, 840.0]], [[153.0, 704.0], [184.0, 704.0], [184.0, 762.0], [153.0, 762.0]], [[126.0, 707.0], [148.0, 707.0], [148.0, 867.0], [126.0, 867.0]]], "lines": ["そうだよな、", "もう", "春なんだよな。"]}, {"box": [795, 1168, 822, 1305], "vertical": true, "font_size": 22, "lines_coords": [[[795.0, 1170.0], [817.0, 1170.0], [817.0, 1298.0], [795.0, 1298.0]]], "lines": ["キレイだね"]}, {"box": [268, 1353, 294, 1464], "vertical": true, "font_size": 22, "lines_coords": [[[268.0, 1354.0], [290.0, 1354.0], [290.0, 1460.0], [268.0, 1460.0]]], "lines": ["そうだな。"]}], "img_path": "subarashii_sekai_02_203.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [886, 150, 975, 300], "vertical": true, "font_size": 25, "lines_coords": [[[948.0, 151.0], [975.0, 151.0], [975.0, 251.0], [948.0, 251.0]], [[918.0, 151.0], [940.0, 151.0], [940.0, 300.0], [918.0, 300.0]], [[886.0, 150.0], [912.0, 150.0], [912.0, 260.0], [886.0, 260.0]]], "lines": ["なんだか", "すごく幸せな", "気分だよ。"]}, {"box": [661, 596, 749, 775], "vertical": true, "font_size": 24, "lines_coords": [[[722.0, 600.0], [748.0, 600.0], [748.0, 725.0], [722.0, 725.0]], [[689.0, 596.0], [715.0, 596.0], [718.0, 775.0], [692.0, 775.0]], [[661.0, 600.0], [682.0, 600.0], [682.0, 732.0], [661.0, 732.0]]], "lines": ["二人でただ", "桜を見てるって", "だけなのに。"]}, {"box": [179, 679, 306, 834], "vertical": true, "font_size": 27, "lines_coords": [[[281.0, 682.0], [303.0, 682.0], [303.0, 831.0], [281.0, 831.0]], [[246.0, 681.0], [273.0, 681.0], [273.0, 809.0], [246.0, 809.0]], [[212.0, 682.0], [239.0, 682.0], [239.0, 834.0], [212.0, 834.0]], [[179.0, 679.0], [212.0, 679.0], [212.0, 765.0], [179.0, 765.0]]], "lines": ["でもこの花も", "すぐに全部", "散っちゃうん", "だよね"]}, {"box": [926, 945, 1017, 1118], "vertical": true, "font_size": 25, "lines_coords": [[[984.0, 945.0], [1017.0, 945.0], [1017.0, 1026.0], [984.0, 1026.0]], [[958.0, 946.0], [979.0, 946.0], [979.0, 1118.0], [958.0, 1118.0]], [[926.0, 950.0], [948.0, 950.0], [948.0, 1089.0], [926.0, 1089.0]]], "lines": ["時間が", "止まっちゃえば", "いいのになー"]}, {"box": [867, 1184, 923, 1348], "vertical": true, "font_size": 25, "lines_coords": [[[892.0, 1184.0], [920.0, 1184.0], [923.0, 1290.0], [895.0, 1290.0]], [[867.0, 1187.0], [887.0, 1187.0], [887.0, 1348.0], [867.0, 1348.0]]], "lines": ["．．．なんて", "無理だけどさ。"]}, {"box": [212, 1351, 239, 1439], "vertical": true, "font_size": 27, "lines_coords": [[[212.0, 1351.0], [239.0, 1351.0], [239.0, 1439.0], [212.0, 1439.0]]], "lines": ["ははは。"]}], "img_path": "subarashii_sekai_02_204.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [865, 82, 959, 220], "vertical": true, "font_size": 28, "lines_coords": [[[931.0, 84.0], [959.0, 84.0], [954.0, 220.0], [926.0, 220.0]], [[900.0, 84.0], [926.0, 84.0], [926.0, 209.0], [900.0, 209.0]], [[865.0, 82.0], [898.0, 82.0], [898.0, 170.0], [865.0, 170.0]]], "lines": ["でも確かに", "幸せな時っ", "てのは、"]}, {"box": [246, 126, 303, 263], "vertical": true, "font_size": 24, "lines_coords": [[[276.0, 126.0], [303.0, 126.0], [303.0, 237.0], [276.0, 237.0]], [[246.0, 128.0], [268.0, 128.0], [268.0, 262.0], [246.0, 262.0]]], "lines": ["そうだね。", "寂しいけど。"]}, {"box": [806, 307, 929, 495], "vertical": true, "font_size": 28, "lines_coords": [[[895.0, 307.0], [929.0, 307.0], [929.0, 390.0], [895.0, 390.0]], [[865.0, 309.0], [892.0, 309.0], [895.0, 464.0], [868.0, 464.0]], [[836.0, 310.0],