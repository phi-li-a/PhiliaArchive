path": "subarashii_sekai_02_139.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [939, 124, 996, 313], "vertical": true, "font_size": 24, "lines_coords": [[[972.0, 126.0], [993.0, 126.0], [993.0, 273.0], [972.0, 273.0]], [[939.0, 125.0], [965.0, 125.0], [965.0, 312.0], [939.0, 312.0]]], "lines": ["ホームレスか", "持っていったよ。"]}, {"box": [767, 615, 858, 796], "vertical": true, "font_size": 28, "lines_coords": [[[829.0, 617.0], [858.0, 617.0], [858.0, 743.0], [829.0, 743.0]], [[800.0, 617.0], [826.0, 617.0], [826.0, 796.0], [800.0, 796.0]], [[767.0, 615.0], [795.0, 615.0], [798.0, 720.0], [770.0, 720.0]]], "lines": ["もう食われ", "てんじゃない？", "だはっ！！"]}, {"box": [603, 346, 697, 565], "vertical": true, "font_size": 29, "lines_coords": [[[667.0, 346.0], [693.0, 346.0], [697.0, 565.0], [670.0, 565.0]], [[636.0, 346.0], [664.0, 346.0], [665.0, 540.0], [637.0, 540.0]], [[603.0, 346.0], [636.0, 346.0], [636.0, 439.0], [603.0, 439.0]]], "lines": ["あとキミ、明日から", "来なくていいや。", "クビね。"]}, {"box": [367, 464, 461, 603], "vertical": true, "font_size": 29, "lines_coords": [[[426.0, 464.0], [461.0, 464.0], [461.0, 546.0], [426.0, 546.0]], [[396.0, 465.0], [423.0, 465.0], [423.0, 568.0], [396.0, 568.0]], [[367.0, 467.0], [393.0, 467.0], [393.0, 603.0], [367.0, 603.0]]], "lines": ["やっぱ", "勤務態度", "悪すぎだわ。"]}, {"box": [368, 468, 458, 608], "vertical": true, "font_size": 90, "lines_coords": [[[368.0, 468.0], [458.0, 468.0], [458.0, 608.0], [368.0, 608.0]]], "lines": ["やっぱ勤務態度悪すぎだわ。"]}, {"box": [340, 671, 406, 851], "vertical": true, "font_size": 29, "lines_coords": [[[379.0, 671.0], [406.0, 671.0], [403.0, 825.0], [376.0, 825.0]], [[346.0, 673.0], [378.0, 675.0], [371.0, 851.0], [340.0, 850.0]]], "lines": ["今日も余裕の", "大遅刻だし．．．"]}, {"box": [268, 1246, 301, 1421], "vertical": true, "font_size": 44, "lines_coords": [[[268.0, 1246.0], [301.0, 1246.0], [301.0, 1421.0], [268.0, 1421.0]]], "lines": ["食われた！？"]}, {"box": [148, 1339, 204, 1539], "vertical": true, "font_size": 44, "lines_coords": [[[148.0, 1339.0], [204.0, 1339.0], [204.0, 1539.0], [148.0, 1539.0]]], "lines": ["駄目だ！！"]}], "img_path": "subarashii_sekai_02_140.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [961, 73, 989, 221], "vertical": true, "font_size": 28, "lines_coords": [[[961.0, 73.0], [989.0, 73.0], [989.0, 221.0], [961.0, 221.0]]], "lines": ["生きろっ！！"]}, {"box": [890, 215, 917, 365], "vertical": true, "font_size": 28, "lines_coords": [[[890.0, 215.0], [917.0, 215.0], [917.0, 365.0], [890.0, 365.0]]], "lines": ["生きろっ！！"]}, {"box": [618, 635, 645, 810], "vertical": true, "font_size": 28, "lines_coords": [[[618.0, 635.0], [645.0, 635.0], [645.0, 810.0], [618.0, 810.0]]], "lines": ["ひゃあーーっ！！"]}, {"box": [551, 634, 582, 812], "vertical": true, "font_size": 28, "lines_coords": [[[551.0, 634.0], [582.0, 634.0], [582.0, 812.0], [551.0, 812.0]]], "lines": ["ひゃあーーっ！！"]}, {"box": [490, 634, 517, 809], "vertical": true, "font_size": 28, "lines_coords": [[[490.0, 634.0], [517.0, 634.0], [517.0, 809.0], [490.0, 809.0]]], "lines": ["ひゃあーーっ！！"]}, {"box": [165, 356, 248, 604], "vertical": true, "font_size": 34, "lines_coords": [[[210.0, 356.0], [243.0, 356.0], [246.0, 498.0], [214.0, 498.0]], [[165.0, 357.0], [201.0, 357.0], [204.0, 604.0], [168.0, 604.0]]], "lines": ["意地でも", "生き延びろっ！！"]}, {"box": [637, 860, 671, 1036], "vertical": true, "font_size": 33, "lines_coords": [[[637.0, 860.0], [670.0, 860.0], [670.0, 1035.0], [637.0, 1035.0]]], "lines": ["生きっ．．．．．"]}, {"box": [126, 1104, 182, 1260], "vertical": true, "font_size": 50, "lines_coords": [[[126.0, 1106.0], [176.0, 1104.0], [182.0, 1259.0], [132.0, 1260.0]]], "lines": ["うっ！！"]}], "img_path": "subarashii_sekai_02_141.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [878, 417, 1002, 648], "vertical": true, "font_size": 28, "lines_coords": [[[975.0, 417.0], [1001.0, 417.0], [1001.0, 646.0], [975.0, 646.0]], [[942.0, 420.0], [970.0, 420.0], [970.0, 534.0], [942.0, 534.0]], [[911.0, 418.0], [937.0, 418.0], [937.0, 648.0], [911.0, 648.0]], [[878.0, 417.0], [909.0, 417.0], [909.0, 582.0], [878.0, 582.0]]], "lines": ["．．．う、知ってたさ．．．", "何ひとつ、", "思いどおりになんて", "なりゃしない。"]}, {"box": [151, 473, 275, 701], "vertical": true, "font_size": 26, "lines_coords": [[[246.0, 478.0], [273.0, 478.0], [273.0, 637.0], [246.0, 637.0]], [[215.0, 475.0], [242.0, 475.0], [239.0, 700.0], [212.0, 700.0]], [[181.0, 473.0], [207.0, 473.0], [207.0, 675.0], [181.0, 675.0]], [[153.0, 473.0], [176.0, 473.0], [175.0, 650.0], [151.0, 650.0]]], "lines": ["いずれにせよ、", "俺やあいつは悲しく", "野垂れ死んてゆく", "運命なんだ．．．"]}, {"box": [981, 931, 1009, 1108], "vertical": true, "font_size": 26, "lines_coords": [[[983.0, 931.0], [1009.0, 931.0], [1008.0, 1106.0], [981.0, 1106.0]]], "lines": ["無心になれ、俺。"]}, {"box": [709, 1064, 764, 1240], "vertical": true, "font_size": 26, "lines_coords": [[[737.0, 1065.0], [764.0, 1065.0], [764.0, 1240.0], [737.0, 1240.0]], [[709.0, 1064.0], [731.0, 1064.0], [731.0, 1217.0], [709.0, 1217.0]]], "lines": ["何も期待なんて", "するな．．．．．．"]}, {"box": [204, 968, 296, 1236], "vertical": true, "font_size": 26, "lines_coords": [[[270.0, 968.0], [296.0, 968.0], [296.0, 1082.0], [270.0, 1082.0]], [[239.0, 968.0], [265.0, 968.0], [262.0, 1234.0], [235.0, 1234.0]], [[206.0, 970.0], [232.0, 970.0], [231.0, 1232.0], [204.0, 1232.0]]], "lines": ["．．．そうさ", "だから、いつもどおりの", "退屈な毎日に戻るんだ。"]}, {"box": [130, 969, 157, 1233], "vertical": true, "font_size": 22, "lines_coords": [[[131.0, 971.0], [153.0, 971.0], [153.0, 1228.0], [131.0, 1228.0]]], "lines": ["感情なんか捨てちまえ"]}, {"box": [606, 1271, 698, 1425], "vertical": true, "font_size": 26, "lines_coords": [[[672.0, 1271.0], [698.0, 1271.0], [698.0, 1400.0], [672.0, 1400.0]], [[637.0, 1271.0], [665.0, 1271.0], [668.0, 1425.0], [640.0, 1425.0]], [[609.0, 1271.0], [636.0, 1271.0], [632.0, 1401.0], [606.0, 1401.0]]], "lines": ["それが俺の", "心の平和じゃ", "ないか．．．"]}], "img_path": "subarashii_sekai_02_142.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [454, 165, 512, 330], "vertical": true, "font_size": 28, "lines_coords": [[[484.0, 167.0], [512.0, 167.0], [512.0, 276.0], [484.0, 276.0]], [[454.0, 167.0], [481.0, 167.0], [481.0, 326.0], [454.0, 326.0]]], "lines": ["うん．．．うん", "しょうがない。"]}, {"box": [260, 165, 323, 319], "vertical": true, "font_size": 27, "lines_coords": [[[293.0, 167.0], [321.0, 167.0], [321.0, 293.0], [293.0, 293.0]], [[264.0, 165.0], [290.0, 165.0], [287.0, 317.0], [260.0, 317.0]]], "lines": ["俺はそれで", "いいんだ．．．"]}, {"box": [565, 473, 581, 531], "vertical": true, "font_size": 16, "lines_coords": [[[565.0, 473.0], [581.0, 473.0], [581.0, 531.0], [565.0, 531.0]]], "lines": ["ヤチキ．．．"]}, {"box": [876, 748, 903, 879], "vertical": true, "font_size": 27, "lines_coords": [[[876.0, 748.0], [903.0, 748.0], [903.0, 876.0], [876.0, 876.0]]], "lines": ["それで．．．．．．"]}, {"box": [250, 860, 279, 1015], "vertical": true, "font_size": 26, "lines_coords": [[[250.0, 860.0], [276.0, 860.0], [276.0, 1010.0], [250.0, 1010.0]]], "lines": ["いいんだ．．．"]}], "img_path": "subarashii_sekai_02_143.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [], "img_path": "subarashii_sekai_02_144.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [425, 1127, 694, 1218], "vertical": false, "font_size": 32, "lines_coords": [[[426.0, 1131.0], [692.0, 1134.0], [692.0, 1165.0], [426.0, 1162.0]], [[432.0, 1179.0], [678.0, 1179.0], [678.0, 1212.0], [432.0, 1212.0]]], "lines": ["１６ｔｈｐｒｏｇｒａｍ", "素晴らしき世界"]}, {"box": [893, 1362, 943, 1401], "vertical": false, "font_size": 39, "lines_coords": [[[893.0, 1362.0], [943.0, 1362.0], [943.0, 1401.0], [893.0, 1401.0]]], "lines": ["．．"]}, {"box": [150, 1339, 795, 1467], "vertical": false, "font_size": 87.0, "lines_coords": [[[228.0, 1343.0], [795.0, 1368.0], [790.0, 1467.0], [223.0, 1442.0]], [[150.0, 1354.0], [243.0, 1339.0], [256.0, 1412.0], [162.0, 1428.0]]], "lines": ["素晴らしいぜ", "素"]}], "img_path": "subarashii_sekai_02_1