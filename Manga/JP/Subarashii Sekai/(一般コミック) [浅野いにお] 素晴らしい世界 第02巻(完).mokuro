], "vertical": true, "font_size": 28, "lines_coords": [[[722.0, 479.0], [750.0, 479.0], [751.0, 593.0], [723.0, 593.0]]], "lines": ["寂しいな。"]}, {"box": [925, 735, 952, 889], "vertical": true, "font_size": 26, "lines_coords": [[[925.0, 735.0], [951.0, 735.0], [951.0, 889.0], [925.0, 889.0]]], "lines": ["今年の冬は．．．"]}, {"box": [193, 935, 220, 1074], "vertical": true, "font_size": 27, "lines_coords": [[[193.0, 935.0], [220.0, 935.0], [220.0, 1073.0], [193.0, 1073.0]]], "lines": ["冷えそうだ。"]}, {"box": [184, 1351, 239, 1434], "vertical": true, "font_size": 35, "lines_coords": [[[204.0, 1351.0], [239.0, 1351.0], [239.0, 1434.0], [204.0, 1434.0]]], "lines": ["．．．あ？"]}], "img_path": "subarashii_sekai_02_099.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [943, 609, 982, 771], "vertical": true, "font_size": 38, "lines_coords": [[[943.0, 612.0], [981.0, 612.0], [981.0, 771.0], [943.0, 771.0]]], "lines": ["ヴフッ！！"]}, {"box": [248, 657, 290, 806], "vertical": true, "font_size": 36, "lines_coords": [[[248.0, 657.0], [287.0, 657.0], [290.0, 806.0], [251.0, 806.0]]], "lines": ["ゲホッ！"]}, {"box": [718, 1012, 778, 1151], "vertical": true, "font_size": 28, "lines_coords": [[[750.0, 1012.0], [778.0, 1012.0], [778.0, 1143.0], [750.0, 1143.0]], [[718.0, 1014.0], [745.0, 1014.0], [745.0, 1148.0], [718.0, 1148.0]]], "lines": ["．．．．．．", "時間切れか。"]}, {"box": [443, 1014, 473, 1204], "vertical": true, "font_size": 25, "lines_coords": [[[443.0, 1014.0], [468.0, 1014.0], [473.0, 1204.0], [448.0, 1204.0]]], "lines": ["．．．わかってるさ。"]}, {"box": [164, 787, 196, 931], "vertical": true, "font_size": 36, "lines_coords": [[[164.0, 787.0], [196.0, 787.0], [196.0, 931.0], [164.0, 931.0]]], "lines": ["ゲホッ！！"]}, {"box": [164, 1123, 190, 1234], "vertical": true, "font_size": 26, "lines_coords": [[[164.0, 1123.0], [190.0, 1123.0], [190.0, 1234.0], [164.0, 1234.0]]], "lines": ["俺の人生、"]}, {"box": [129, 1320, 217, 1476], "vertical": true, "font_size": 26, "lines_coords": [[[195.0, 1323.0], [217.0, 1323.0], [217.0, 1471.0], [195.0, 1471.0]], [[157.0, 1320.0], [184.0, 1320.0], [187.0, 1476.0], [160.0, 1476.0]], [[129.0, 1321.0], [156.0, 1321.0], [156.0, 1437.0], [129.0, 1437.0]]], "lines": ["もうまとめの", "段階ってこと", "くらいは。"]}], "img_path": "subarashii_sekai_02_100.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [704, 117, 770, 248], "vertical": true, "font_size": 34, "lines_coords": [[[734.0, 117.0], [770.0, 117.0], [770.0, 178.0], [734.0, 178.0]], [[704.0, 117.0], [737.0, 117.0], [737.0, 248.0], [704.0, 248.0]]], "lines": ["もう", "すべて．．．"]}, {"box": [146, 348, 237, 501], "vertical": true, "font_size": 26, "lines_coords": [[[210.0, 348.0], [237.0, 348.0], [237.0, 501.0], [210.0, 501.0]], [[179.0, 350.0], [206.0, 350.0], [206.0, 500.0], [179.0, 500.0]], [[146.0, 350.0], [173.0, 350.0], [173.0, 453.0], [146.0, 453.0]]], "lines": ["キレイに清算", "してもいい頃", "だよな？"]}, {"box": [129, 581, 153, 656], "vertical": true, "font_size": 26, "lines_coords": [[[129.0, 581.0], [153.0, 581.0], [153.0, 656.0], [129.0, 656.0]]], "lines": ["．．うん。"]}, {"box": [240, 806, 334, 1055], "vertical": true, "font_size": 26, "lines_coords": [[[306.0, 806.0], [332.0, 806.0], [332.0, 904.0], [306.0, 904.0]]], "lines": ["３０年．．．．．"]}, {"box": [881, 1201, 925, 1275], "vertical": true, "font_size": 38, "lines_coords": [[[881.0, 1204.0], [918.0, 1201.0], [925.0, 1273.0], [887.0, 1275.0]]], "lines": ["おい。"]}, {"box": [281, 1192, 339, 1368], "vertical": true, "font_size": 26, "lines_coords": [[[311.0, 1192.0], [337.0, 1192.0], [339.0, 1368.0], [312.0, 1368.0]], [[281.0, 1195.0], [303.0, 1195.0], [303.0, 1298.0], [281.0, 1298.0]]], "lines": ["それは先々代の", "包丁だぞ"]}, {"box": [157, 1326, 214, 1454], "vertical": true, "font_size": 26, "lines_coords": [[[187.0, 1326.0], [214.0, 1326.0], [214.0, 1429.0], [187.0, 1429.0]], [[157.0, 1329.0], [184.0, 1329.0], [184.0, 1454.0], [157.0, 1454.0]]], "lines": ["どうする", "つもりだ？"]}], "img_path": "subarashii_sekai_02_101.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [976, 152, 1004, 378], "vertical": true, "font_size": 27, "lines_coords": [[[976.0, 153.0], [1003.0, 153.0], [1003.0, 376.0], [976.0, 376.0]]], "lines": ["．．．出ていくのか？"]}, {"box": [681, 154, 708, 256], "vertical": true, "font_size": 26, "lines_coords": [[[681.0, 154.0], [707.0, 154.0], [707.0, 256.0], [681.0, 256.0]]], "lines": ["なぜだ？"]}, {"box": [926, 700, 961, 879], "vertical": true, "font_size": 33, "lines_coords": [[[926.0, 723.0], [959.0, 723.0], [959.0, 879.0], [926.0, 879.0]]], "lines": ["．．．女か！？"]}, {"box": [478, 384, 562, 559], "vertical": true, "font_size": 25, "lines_coords": [[[540.0, 384.0], [562.0, 384.0], [562.0, 482.0], [540.0, 482.0]], [[506.0, 384.0], [532.0, 384.0], [532.0, 559.0], [506.0, 559.0]], [[478.0, 385.0], [500.0, 385.0], [500.0, 518.0], [478.0, 518.0]]], "lines": ["おまえの", "料理人としての", "腕は一流だ。"]}, {"box": [331, 465, 421, 645], "vertical": true, "font_size": 25, "lines_coords": [[[395.0, 467.0], [421.0, 467.0], [421.0, 645.0], [395.0, 645.0]], [[362.0, 465.0], [389.0, 465.0], [389.0, 643.0], [362.0, 643.0]], [[331.0, 467.0], [359.0, 467.0], [359.0, 575.0], [331.0, 575.0]]], "lines": ["親父もおまえを", "後継者に選ぶに", "違いない。"]}, {"box": [289, 721, 359, 967], "vertical": true, "font_size": 31, "lines_coords": [[[323.0, 721.0], [356.0, 721.0], [359.0, 965.0], [326.0, 965.0]], [[289.0, 723.0], [315.0, 723.0], [318.0, 967.0], [292.0, 967.0]]], "lines": ["あのあばずれ女の", "ためにおまえは．．．"]}, {"box": [185, 990, 307, 1167], "vertical": true, "font_size": 31, "lines_coords": [[[275.0, 990.0], [307.0, 990.0], [307.0, 1132.0], [275.0, 1132.0]], [[231.0, 993.0], [264.0, 993.0], [264.0, 1167.0], [231.0, 1167.0]], [[185.0, 993.0], [218.0, 993.0], [218.0, 1165.0], [185.0, 1165.0]]], "lines": ["この家を", "捨てるって", "いうのか！？"]}, {"box": [287, 1263, 318, 1491], "vertical": true, "font_size": 27, "lines_coords": [[[287.0, 1265.0], [314.0, 1265.0], [314.0, 1487.0], [287.0, 1487.0]]], "lines": ["．．．．．失礼します。"]}], "img_path": "subarashii_sekai_02_102.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [933, 89, 975, 351], "vertical": true, "font_size": 29, "lines_coords": [[[937.0, 89.0], [975.0, 89.0], [970.0, 351.0], [933.0, 351.0]]], "lines": ["待てっ！！俺は貴様の"]}, {"box": [870, 218, 931, 398], "vertical": true, "font_size": 29, "lines_coords": [[[904.0, 218.0], [931.0, 218.0], [928.0, 398.0], [901.0, 398.0]], [[870.0, 221.0], [893.0, 221.0], [897.0, 348.0], [873.0, 348.0]]], "lines": ["考えてることが", "わからん！！"]}, {"box": [121, 115, 244, 395], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 115.0], [242.0, 115.0], [243.0, 268.0], [215.0, 268.0]], [[182.0, 115.0], [210.0, 115.0], [212.0, 346.0], [184.0, 346.0]], [[153.0, 117.0], [179.0, 117.0], [179.0, 300.0], [153.0, 300.0]], [[121.0, 117.0], [143.0, 117.0], [143.0, 393.0], [121.0, 393.0]]], "lines": ["俺たち二人で", "伝統あるこの料亭を", "守っていく．．．", "それていいじゃないか！！"]}, {"box": [650, 475, 763, 704], "vertical": true, "font_size": 31, "lines_coords": [[[731.0, 476.0], [762.0, 476.0], [762.0, 704.0], [731.0, 704.0]], [[693.0, 478.0], [722.0, 478.0], [720.0, 689.0], [692.0, 689.0]], [[653.0, 475.0], [686.0, 475.0], [682.0, 596.0], [650.0, 596.0]]], "lines": ["単身、包丁一本で", "生きていけると", "思うか！？"]}, {"box": [203, 546, 248, 693], "vertical": true, "font_size": 45, "lines_coords": [[[203.0, 546.0], [248.0, 546.0], [248.0, 693.0], [203.0, 693.0]]], "lines": ["うっ！！"]}, {"box": [937, 762, 964, 867], "vertical": true, "font_size": 26, "lines_coords": [[[937.0, 762.0], [964.0, 762.0], [964.0, 867.0], [937.0, 867.0]]], "lines": ["兄貴．．．"]}, {"box": [784, 825, 875, 1028], "vertical": true, "font_size": 26, "lines_coords": [[[848.0, 825.0], [875.0, 825.0], [875.0, 1003.0], [848.0, 1003.0]], [[820.0, 829.0], [842.0, 829.0], [842.0, 951.0], [820.0, 951.0]], [[786.0, 825.0], [812.0, 825.0], [811.0, 1028.0], [784.0, 1028.0]]], "lines": ["一流とか家柄で", "人の価値は", "決まらないよ．．．"]}, {"box": [267, 795, 321, 920], "vertical": true, "font_size": 24, "lines_coords": [[[300.0, 796.0], [321.0, 796.0], [321.0, 920.0], [300.0, 920.0]], [[267.0, 795.0], [293.0, 795.0], [293.0, 896.0], [267.0, 896.0]]], "lines": ["少なくとも", "俺は．．．"]}, {"box": [168, 951, 225, 1076], "vertical": true, "font_size": 24, "lines_coords": [[[200.0, 951.0], [221.0, 951.0], [225.0, 1076.0], [203.0, 1076.0]], [[168.0, 953.0], [195.0, 953.0], [195.0, 1060.0], [168.0, 1060.0]]], "lines": ["俺の生きる", "道を行く。"]}], "img_path": "subarashii_sekai_02_103.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [290, 153, 318, 253], "vertical": true, "font_size": 31, "lines_coords": [[[290.0, 153.0], [318.0, 153.0], [318.0, 253.0], [290.0, 253.0]]], "lines": ["３０年．．．"]}, {"box": [206, 267, 251, 353], "vertical": true, "font_size": 31, "lines_coords": [[[217.0, 267.0], [251.0, 271.0], [240.0, 353.0], [206.0, 348.0]]], "lines": ["か．．．．．"]}, {"box": [856, 518, 912, 650], "vertical": true, "font_size": 22, "lines_coords": [[[890.0, 521.0], [912.0, 521.0], [912.0, 646.0], [890.0, 646.0]], [[856.0, 518.0], [883.0, 518.0], [883.0, 650.0], [856.0, 650.0]]], "lines": ["ウワサには", "聞いてたが、"]}, {"box": [884, 782, 939, 967], "vertical": true, "font_size": 22, "lines_coords": [[[918.0, 784.0], [939.0, 784.0], [939.0, 962.0], [918.0, 962.0]], [[884.0, 782.0], [904.0, 782.0], [904.0, 967.0], [884.0, 967.0]]], "lines": ["貧相なもんだな。", "おまえも屋台も、"]}, {"box": [356, 845, 430, 942], "vertical": true, "font_size": 48, "lines_coords": [[[356.0, 845.0], [404.0, 845.0], [404.0, 934.0], [356.0, 934.0]]], "lines": ["帰れ。"]}, {"box": [137, 1253, 232, 1456], "vertical": true, "font_size": 26, "lines_coords": [[[207.0, 1257.0], [229.0, 1257.0], [229.0, 1456.0], [207.0, 1456.0]], [[173.0, 1256.0], [196.0, 1256.0], [198.0, 1454.0], [175.0, 1454.0]], [[137.0, 1253.0], [171.0, 1253.0], [171.0, 1320.0], [137.0, 1320.0]]], "lines": ["おまえは今ここに", "いられる人間じゃ", "ない。"]}], "img_path": "subarashii_sekai_02_104.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [534, 123, 558, 261], "vertical": true, "font_size": 22, "lines_coords": [[[534.0, 123.0], [556.0, 123.0], [556.0, 259.0], [534.0, 259.0]]], "lines": ["ふざけるな。"]}, {"box": [239, 114, 331, 281], "vertical": true, "font_size": 29, "lines_coords": [[[301.0, 114.0], [329.0, 114.0], [331.0, 220.0], [303.0, 220.0]], [[270.0, 115.0], [298.0, 115.0], [300.0, 270.0], [271.0, 270.0]], [[239.0, 115.0], [267.0, 115.0], [270.0, 281.0], [242.0, 281.0]]], "lines": ["だらだら", "料理にしがみ", "つきやがって。"]}, {"box": [958, 700, 983, 860], "vertical": true, "font_size": 25, "lines_coords": [[[958.0, 700.0], [981.0, 700.0], [983.0, 860.0], [959.0, 860.0]]], "lines": ["俺は許さんぞ。"]}, {"box": [746, 489, 832, 652], "vertical": true, "font_size": 23, "lines_coords": [[[812.0, 492.0], [832.0, 492.0], [832.0, 642.0], [812.0, 642.0]], [[775.0, 489.0], [803.0, 489.0], [800.0, 640.0], [772.0, 640.0]], [[747.0, 493.0], [768.0, 493.0], [768.0, 650.0], [747.0, 650.0]]], "lines": ["．．．．．．", "俺のラーメン", "食べてくれよ。"]}, {"box": [173, 370, 267, 500], "vertical": true, "font_size": 29, "lines_coords": [[[240.0, 373.0], [267.0, 373.0], [267.0, 498.0], [240.0, 498.0]], [[207.0, 371.0], [235.0, 371.0], [237.0, 500.0], [209.0, 500.0]], [[173.0, 371.0], [206.0, 370.0], [209.0, 460.0], [176.0, 462.0]]], "lines": ["誰が貴様の", "料理なんぞ", "食うか。"]}, {"box": [790, 840, 914, 1081], "vertical": true, "font_size": 25, "lines_coords": [[[887.0, 840.0], [914.0, 840.0], [911.0, 1070.0], [884.0, 1070.0]], [[854.0, 842.0], [881.0, 842.0], [881.0, 1018.0], [854.0, 1018.0]], [[822.0, 842.0], [848.0, 842.0], [848.0, 1071.0], [822.0, 1071.0]], [[792.0, 842.0], [815.0, 842.0], [814.0, 1081.0], [790.0, 1081.0]]], "lines": ["貴様さえいれば．．．", "ウチは商店街の", "ソバ屋に落ちぶれる", "こともなかったんだ。"]}, {"box": [278, 759, 336, 937], "vertical": true, "font_size": 26, "lines_coords": [[[309.0, 759.0], [336.0, 759.0], [336.0, 937.0], [309.0, 937.0]], [[278.0, 760.0], [304.0, 760.0], [304.0, 898.0], [278.0, 898.0]]], "lines": ["それがいまさら", "なんの用だ。"]}, {"box": [209, 962, 235, 1100], "vertical": true, "font_size": 26, "lines_coords": [[[209.0, 962.0], [235.0, 962.0], [235.0, 1100.0], [209.0, 1100.0]]], "lines": ["消えてくれ"]}, {"box": [895, 1189, 931, 1384], "vertical": true, "font_size": 33, "lines_coords": [[[895.0, 1189.0], [928.0, 1189.0], [928.0, 1384.0], [895.0, 1384.0]]], "lines": ["食べてくれよ。"]}, {"box": [200, 1335, 242, 1420], "vertical": true, "font_size": 42, "lines_coords": [[[200.0, 1335.0], [242.0, 1335.0], [242.0, 1420.0], [200.0, 1420.0]]], "lines": ["兄貴。"]}], "img_path": "subarashii_sekai_02_105.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [945, 153, 972, 288], "vertical": true, "font_size": 21, "lines_coords": [[[947.0, 154.0], [968.0, 154.0], [968.0, 282.0], [947.0, 282.0]]], "lines": ["昨年の暮れ、"]}, {"box": [268, 220, 296, 406], "vertical": true, "font_size": 25, "lines_coords": [[[268.0, 220.0], [295.0, 220.0], [296.0, 406.0], [270.0, 406.0]]], "lines": ["妻が死んでから、"]}, {"box": [153, 407, 240, 609], "vertical": true, "font_size": 25, "lines_coords": [[[218.0, 410.0], [240.0, 410.0], [240.0, 609.0], [218.0, 609.0]], [[184.0, 407.0], [210.0, 407.0], [210.0, 564.0], [184.0, 564.0]], [[153.0, 407.0], [179.0, 407.0], [179.0, 559.0], [153.0, 559.0]]], "lines": ["屋台を閉めること", "ばかり考えて", "いたよ、俺は。"]}, {"box": [265, 670, 325, 898], "vertical": true, "font_size": 25, "lines_coords": [[[298.0, 670.0], [325.0, 670.0], [325.0, 898.0], [298.0, 898.0]], [[267.0, 670.0], [290.0, 670.0], [289.0, 823.0], [265.0, 823.0]]], "lines": ["兄貴はなんのために", "包丁を持つ？"]}, {"box": [898, 845, 931, 954], "vertical": true, "font_size": 28, "lines_coords": [[[898.0, 845.0], [931.0, 845.0], [931.0, 954.0], [898.0, 954.0]]], "lines": ["いや．．．"]}, {"box": [743, 959, 831, 1107], "vertical": true, "font_size": 28, "lines_coords": [[[803.0, 960.0], [831.0, 960.0], [831.0, 1073.0], [803.0, 1073.0]], [[773.0, 959.0], [800.0, 959.0], [800.0, 1085.0], [773.0, 1085.0]], [[743.0, 960.0], [765.0, 960.0], [765.0, 1107.0], [743.0, 1107.0]]], "lines": ["いいんだ。", "答えてくれ", "なくても．．．"]}, {"box": [351, 1302, 387, 1458], "vertical": true, "font_size": 36, "lines_coords": [[[351.0, 1303.0], [387.0, 1303.0], [387.0, 1382.0], [351.0, 1382.0]]], "lines": ["ただー"]}], "img_path": "subarashii_sekai_02_106.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [862, 118, 951, 255], "vertical": true, "font_size": 26, "lines_coords": [[[925.0, 118.0], [951.0, 118.0], [951.0, 245.0], [925.0, 245.0]], [[892.0, 118.0], [918.0, 118.0], [918.0, 248.0], [892.0, 248.0]], [[862.0, 118.0], [889.0, 118.0], [889.0, 254.0], [862.0, 254.0]]], "lines": ["俺の最後の", "ラーメンを", "食べるのは、"]}, {"box": [184, 145, 241, 323], "vertical": true, "font_size": 24, "lines_coords": [[[212.0, 145.0], [239.0, 145.0], [240.0, 323.0], [214.0, 323.0]], [[184.0, 148.0], [206.0, 148.0], [206.0, 282.0], [184.0, 282.0]]], "lines": ["兄貴じゃないと", "駄目なんだ。"]}, {"box": [868, 431, 929, 619], "vertical": true, "font_size": 28, "lines_coords": [[[898.0, 431.0], [926.0, 431.0], [926.0, 546.0], [898.0, 546.0]], [[868.0, 432.0], [895.0, 432.0], [895.0, 618.0], [868.0, 618.0]]], "lines": ["今、ここで", "終わらせてくれ。"]}, {"box": [157, 615, 234, 742], "vertical": true, "font_size": 40, "lines_coords": [[[196.0, 617.0], [234.0, 617.0], [234.0, 742.0], [196.0, 742.0]], [[157.0, 615.0], [200.0, 615.0], [200.0, 696.0], [157.0, 696.0]]], "lines": ["料理人の", "俺を。"]}], "img_path": "subarashii_sekai_02_107.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [667, 118, 753, 310], "vertical": true, "font_size": 25, "lines_coords": [[[695.0, 118.0], [723.0, 118.0], [725.0, 250.0], [697.0, 250.0]], [[667.0, 121.0], [689.0, 121.0], [689.0, 307.0], [667.0, 307.0]]], "lines": ["うまかった", "なんて言わんぞ。"]}, {"box": [257, 90, 282, 273], "vertical": true, "font_size": 22, "lines_coords": [[[257.0, 90.0], [279.0, 90.0], [279.0, 270.0], [257.0, 270.0]]], "lines": ["おまえは最低だ。"]}, {"box": [903, 657, 937, 850], "vertical": true, "font_size": 31, "lines_coords": [[[903.0, 659.0], [934.0, 659.0], [937.0, 850.0], [906.0, 850.0]]], "lines": ["．．．．なぁ、弟．．．"]}, {"box": [126, 365, 216, 578], "vertical": true, "font_size": 25, "lines_coords": [[[189.0, 367.0], [215.0, 367.0], [215.0, 521.0], [189.0, 521.0]], [[156.0, 365.0], [182.0, 365.0], [184.0, 578.0], [157.0, 578.0]], [[126.0, 370.0], [148.0, 370.0], [148.0, 545.0], [126.0, 545.0]]], "lines": ["料理人として", "最低の男だったよ、", "おまえは．．．．．．"]}, {"box": [204, 976, 298, 1156], "vertical": true, "font_size": 31, "lines_coords": [[[270.0, 981.0], [296.0, 981.0], [296.0, 1156.0], [270.0, 1156.0]], [[234.0, 976.0], [265.0, 976.0], [265.0, 1156.0], [234.0, 1156.0]], [[204.0, 978.0], [239.0, 978.0], [239.0, 1046.0], [204.0, 1046.0]]], "lines": ["俺らもずいぶん", "年くっちまった", "なぁ。"]}, {"box": [179, 1334, 218, 1493], "vertical": true, "font_size": 39, "lines_coords": [[[179.0, 1334.0], [218.0, 1334.0], [218.0, 1421.0], [179.0, 1421.0]]], "lines": ["俺はー"]}], "img_path": "subarashii_sekai_02_108.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [893, 140, 956, 248], "vertical": true, "font_size": 26, "lines_coords": [[[928.0, 142.0], [956.0, 142.0], [956.0, 220.0], [928.0, 220.0]], [[893.0, 140.0], [926.0, 140.0], [926.0, 248.0], [893.0, 248.0]]], "lines": ["今まで", "俺は．．．"]}, {"box": [773, 228, 826, 379], "vertical": true, "font_size": 26, "lines_coords": [[[804.0, 228.0], [826.0, 228.0], [826.0, 379.0], [804.0, 379.0]], [[773.0, 229.0], [795.0, 229.0], [795.0, 362.0], [773.0, 362.0]]], "lines": ["自分を信じて", "生きてきた。"]}, {"box": [262, 159, 390, 342], "vertical": true, "font_size": 29, "lines_coords": [[[356.0, 159.0], [390.0, 159.0], [390.0, 242.0], [356.0, 242.0]], [[326.0, 159.0], [354.0, 159.0], [351.0, 342.0], [323.0, 342.0]], [[296.0, 159.0], [323.0, 159.0], [320.0, 315.0], [293.0, 315.0]], [[262.0, 162.0], [290.0, 162.0], [290.0, 265.0], [262.0, 265.0]]], "lines": ["それで", "どれだけの人を", "傷つけてきた", "カ．．．．．．．"]}, {"box": [190, 418, 257, 526], "vertical": true, "font_size": 30, "lines_coords": [[[225.0, 421.0], [257.0, 421.0], [257.0, 526.0], [225.0, 526.0]], [[190.0, 420.0], [223.0, 418.0], [226.0, 507.0], [193.0, 509.0]]], "lines": ["今にして", "思えば、"]}, {"box": [239, 592, 331, 745], "vertical": true, "font_size": 30, "lines_coords": [[[303.0, 595.0], [331.0, 595.0], [331.0, 745.0], [303.0, 745.0]], [[271.0, 593.0], [298.0, 593.0], [298.0, 723.0], [271.0, 723.0]], [[239.0, 592.0], [267.0, 592.0], [268.0, 710.0], [240.0, 710.0]]], "lines": ["俺は世界一の", "幸せ者かも", "しれない。"]}, {"box": [931, 845, 1019, 968], "vertical": true, "font_size": 25, "lines_coords": [[[992.0, 845.0], [1018.0, 845.0], [1018.0, 968.0], [992.0, 968.0]], [[959.0, 845.0], [987.0, 845.0], [987.0, 946.0], [959.0, 946.0]], [[931.0, 845.0], [953.0, 845.0], [953.0, 945.0], [931.0, 945.0]]], "lines": ["俺と二人で", "旅にでも", "出るか？"]}, {"box": [693, 881, 788, 1084], "vertical": true, "font_size": 29, "lines_coords": [[[761.0, 884.0], [787.0, 884.0], [787.0, 1010.0], [761.0, 1010.0]], [[729.0, 881.0], [756.0, 881.0], [753.0, 1084.0], [726.0, 1084.0]], [[693.0, 881.0], [728.0, 881.0], [728.0, 975.0], [693.0, 975.0]]], "lines": ["そこに何が", "あるってワケじゃ", "ないが。"]}, {"box": [64, 845, 186, 1024], "vertical": true, "font_size": 26, "lines_coords": [[[156.0, 845.0], [182.0, 845.0], [185.0, 981.0], [159.0, 981.0]], [[126.0, 848.0], [153.0, 848.0], [153.0, 950.0], [126.0, 950.0]], [[93.0, 848.0], [120.0, 848.0], [120.0, 948.0], [93.0, 948.0]], [[64.0, 846.0], [90.0, 846.0], [90.0, 1023.0], [64.0, 1023.0]]], "lines": ["．．．そうか、", "おまえは", "おまえの", "道を行くか．．．"]}], "img_path": "subarashii_sekai_02_109.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [404, 209, 431, 335], "vertical": true, "font_size": 29, "lines_coords": [[[404.0, 209.0], [428.0, 209.0], [431.0, 335.0], [407.0, 335.0]]], "lines": ["．．．．．．包丁は"]}, {"box": [232, 295, 331, 423], "vertical": true, "font_size": 29, "lines_coords": [[[304.0, 296.0], [331.0, 296.0], [331.0, 423.0], [304.0, 423.0]], [[271.0, 296.0], [