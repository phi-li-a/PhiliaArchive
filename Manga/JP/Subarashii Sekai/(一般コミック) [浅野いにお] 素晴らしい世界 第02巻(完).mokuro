5.0, 335.0], [543.0, 335.0]]], "lines": ["．．．．．．なワケ", "ないだろ．．．"]}, {"box": [103, 53, 342, 84], "vertical": false, "font_size": 26, "lines_coords": [[[103.0, 53.0], [342.0, 57.0], [342.0, 84.0], [103.0, 79.0]]], "lines": ["素晴らしい世界って"]}, {"box": [182, 590, 212, 773], "vertical": true, "font_size": 27, "lines_coords": [[[182.0, 590.0], [209.0, 590.0], [209.0, 762.0], [182.0, 762.0]]], "lines": ["．．．．．暑い．．．．．"]}, {"box": [900, 1112, 925, 1270], "vertical": true, "font_size": 26, "lines_coords": [[[903.0, 1112.0], [925.0, 1112.0], [922.0, 1270.0], [900.0, 1270.0]]], "lines": ["将来のために、"]}, {"box": [623, 826, 809, 1063], "vertical": true, "font_size": 26, "lines_coords": [[[781.0, 828.0], [807.0, 828.0], [807.0, 954.0], [781.0, 954.0]], [[748.0, 826.0], [775.0, 826.0], [775.0, 1014.0], [748.0, 1014.0]], [[717.0, 828.0], [743.0, 828.0], [743.0, 954.0], [717.0, 954.0]], [[686.0, 828.0], [712.0, 828.0], [712.0, 1015.0], [686.0, 1015.0]], [[654.0, 828.0], [681.0, 828.0], [681.0, 1054.0], [654.0, 1054.0]], [[625.0, 828.0], [647.0, 828.0], [647.0, 1059.0], [625.0, 1059.0]]], "lines": ["気が付けば", "私は中学２年で、", "この暑い中", "この狭い教室で、", "古語やら数式やらを", "毎日暗記してるんだ"]}, {"box": [270, 825, 328, 1002], "vertical": true, "font_size": 25, "lines_coords": [[[304.0, 828.0], [328.0, 828.0], [328.0, 904.0], [304.0, 904.0]], [[271.0, 825.0], [298.0, 825.0], [296.0, 1000.0], [270.0, 1000.0]]], "lines": ["．．．", "なんのために？"]}, {"box": [826, 1331, 884, 1421], "vertical": true, "font_size": 26, "lines_coords": [[[856.0, 1331.0], [884.0, 1331.0], [884.0, 1409.0], [856.0, 1409.0]], [[826.0, 1332.0], [853.0, 1332.0], [853.0, 1421.0], [826.0, 1421.0]]], "lines": ["そりゃ", "そーだ。"]}, {"box": [181, 1121, 301, 1300], "vertical": true, "font_size": 25, "lines_coords": [[[275.0, 1125.0], [301.0, 1125.0], [301.0, 1250.0], [275.0, 1250.0]], [[242.0, 1123.0], [268.0, 1123.0], [268.0, 1228.0], [242.0, 1228.0]], [[210.0, 1121.0], [237.0, 1121.0], [237.0, 1300.0], [210.0, 1300.0]], [[181.0, 1123.0], [203.0, 1123.0], [203.0, 1232.0], [181.0, 1232.0]]], "lines": ["でも未来は", "誰にでも", "平等にあるワケ", "じゃない"]}, {"box": [151, 1343, 270, 1493], "vertical": true, "font_size": 25, "lines_coords": [[[248.0, 1346.0], [270.0, 1346.0], [267.0, 1493.0], [245.0, 1493.0]], [[214.0, 1343.0], [242.0, 1343.0], [242.0, 1470.0], [214.0, 1470.0]], [[184.0, 1345.0], [206.0, 1345.0], [206.0, 1492.0], [184.0, 1492.0]], [[151.0, 1343.0], [178.0, 1343.0], [178.0, 1432.0], [151.0, 1432.0]]], "lines": ["ストーカーに", "バラバラに", "されたＯＬの", "ように。"]}], "img_path": "subarashii_sekai_02_055.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [290, 200, 315, 356], "vertical": true, "font_size": 22, "lines_coords": [[[292.0, 256.0], [314.0, 256.0], [314.0, 353.0], [292.0, 353.0]], [[290.0, 201.0], [312.0, 201.0], [312.0, 253.0], [290.0, 253.0]]], "lines": ["え．．．．．．", "うー"]}, {"box": [847, 831, 904, 982], "vertical": true, "font_size": 24, "lines_coords": [[[876.0, 831.0], [904.0, 831.0], [904.0, 918.0], [876.0, 918.0]], [[847.0, 832.0], [868.0, 832.0], [868.0, 981.0], [847.0, 981.0]]], "lines": ["あんた、", "何してんの？"]}, {"box": [176, 1075, 204, 1202], "vertical": true, "font_size": 27, "lines_coords": [[[176.0, 1075.0], [203.0, 1075.0], [203.0, 1201.0], [176.0, 1201.0]]], "lines": ["別に．．．．．．"]}], "img_path": "subarashii_sekai_02_056.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [883, 139, 972, 317], "vertical": true, "font_size": 25, "lines_coords": [[[947.0, 140.0], [970.0, 140.0], [968.0, 317.0], [945.0, 317.0]], [[914.0, 140.0], [940.0, 140.0], [940.0, 295.0], [914.0, 295.0]], [[883.0, 139.0], [909.0, 139.0], [909.0, 254.0], [883.0, 254.0]]], "lines": ["今日は午後から", "体育祭の予行", "だってさ。"]}, {"box": [578, 115, 645, 248], "vertical": true, "font_size": 32, "lines_coords": [[[606.0, 117.0], [642.0, 115.0], [645.0, 200.0], [609.0, 201.0]], [[581.0, 117.0], [609.0, 117.0], [606.0, 246.0], [578.0, 246.0]]], "lines": ["あ．．．", "そうか．．．．．"]}, {"box": [101, 53, 326, 81], "vertical": false, "font_size": 26, "lines_coords": [[[101.0, 53.0], [326.0, 54.0], [326.0, 81.0], [101.0, 79.0]]], "lines": ["素晴らしい世界って"]}, {"box": [142, 159, 203, 275], "vertical": true, "font_size": 31, "lines_coords": [[[175.0, 160.0], [203.0, 160.0], [203.0, 275.0], [175.0, 275.0]], [[142.0, 159.0], [178.0, 159.0], [178.0, 228.0], [142.0, 228.0]]], "lines": ["あ、そうか", "って。"]}, {"box": [107, 329, 235, 509], "vertical": true, "font_size": 31, "lines_coords": [[[201.0, 329.0], [235.0, 329.0], [235.0, 420.0], [201.0, 420.0]], [[171.0, 331.0], [198.0, 331.0], [198.0, 509.0], [171.0, 509.0]], [[135.0, 329.0], [170.0, 329.0], [170.0, 414.0], [135.0, 414.0]], [[107.0, 334.0], [134.0, 334.0], [134.0, 460.0], [107.0, 460.0]]], "lines": ["あんた、", "起こしてくれる", "友達も", "いないの？"]}, {"box": [132, 585, 255, 788], "vertical": true, "font_size": 26, "lines_coords": [[[226.0, 585.0], [254.0, 585.0], [251.0, 781.0], [223.0, 781.0]], [[193.0, 587.0], [220.0, 587.0], [220.0, 787.0], [193.0, 787.0]], [[162.0, 587.0], [189.0, 587.0], [189.0, 778.0], [162.0, 778.0]], [[132.0, 589.0], [154.0, 589.0], [154.0, 700.0], [132.0, 700.0]]], "lines": ["まー、アタシは", "日焼けしたくない", "から、サボらせて", "もらうわ。"]}, {"box": [865, 821, 954, 948], "vertical": true, "font_size": 25, "lines_coords": [[[929.0, 823.0], [951.0, 823.0], [951.0, 923.0], [929.0, 923.0]], [[895.0, 821.0], [922.0, 821.0], [922.0, 948.0], [895.0, 948.0]], [[865.0, 821.0], [892.0, 821.0], [892.0, 925.0], [865.0, 925.0]]], "lines": ["あんたも", "もう帰るん", "でしょ？"]}, {"box": [440, 930, 467, 1084], "vertical": true, "font_size": 27, "lines_coords": [[[440.0, 930.0], [467.0, 930.0], [467.0, 1084.0], [440.0, 1084.0]]], "lines": ["どーする？"]}, {"box": [439, 931, 465, 1084], "vertical": true, "font_size": 30, "lines_coords": [[[439.0, 931.0], [465.0, 931.0], [465.0, 1084.0], [439.0, 1084.0]]], "lines": ["どーする？"]}, {"box": [328, 1048, 364, 1234], "vertical": true, "font_size": 30, "lines_coords": [[[331.0, 1048.0], [364.0, 1048.0], [361.0, 1234.0], [328.0, 1234.0]]], "lines": ["久々に一緒に"]}, {"box": [293, 1048, 363, 1232], "vertical": true, "font_size": 33, "lines_coords": [[[293.0, 1048.0], [326.0, 1048.0], [326.0, 1143.0], [293.0, 1143.0]]], "lines": ["帰る？"]}], "img_path": "subarashii_sekai_02_057.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [914, 104, 972, 259], "vertical": true, "font_size": 26, "lines_coords": [[[945.0, 104.0], [972.0, 104.0], [968.0, 259.0], [942.0, 259.0]], [[914.0, 104.0], [940.0, 104.0], [940.0, 245.0], [914.0, 245.0]]], "lines": ["サト．．．あんた", "変わったね。"]}, {"box": [562, 95, 690, 300], "vertical": true, "font_size": 29, "lines_coords": [[[659.0, 98.0], [687.0, 98.0], [690.0, 207.0], [662.0, 207.0]], [[628.0, 100.0], [654.0, 100.0], [656.0, 285.0], [629.0, 285.0]], [[597.0, 96.0], [623.0, 96.0], [625.0, 300.0], [598.0, 300.0]], [[562.0, 95.0], [597.0, 95.0], [597.0, 167.0], [562.0, 167.0]]], "lines": ["やめてよ、", "名前で呼ぶのは。", "そんなカッコ悪い", "名前。"]}, {"box": [135, 172, 195, 362], "vertical": true, "font_size": 27, "lines_coords": [[[168.0, 173.0], [195.0, 173.0], [195.0, 300.0], [168.0, 300.0]], [[135.0, 173.0], [162.0, 173.0], [162.0, 362.0], [135.0, 362.0]]], "lines": ["今は岡崎で", "通してんだから。"]}, {"box": [926, 557, 953, 645], "vertical": true, "font_size": 26, "lines_coords": [[[926.0, 557.0], [953.0, 557.0], [953.0, 645.0], [926.0, 645.0]]], "lines": ["あはは。"]}, {"box": [811, 696, 901, 826], "vertical": true, "font_size": 26, "lines_coords": [[[875.0, 696.0], [901.0, 696.0], [901.0, 826.0], [875.0, 826.0]], [[842.0, 696.0], [872.0, 696.0], [872.0, 748.0], [842.0, 748.0]], [[811.0, 696.0], [837.0, 696.0], [837.0, 809.0], [811.0, 809.0]]], "lines": ["やーめてよ", "ねー", "昔の話は。"]}, {"box": [842, 740, 868, 782], "vertical": true, "font_size": 26, "lines_coords": [[[842.0, 743.0], [864.0, 740.0], [868.0, 779.0], [847.0, 782.0]]], "lines": ["ん"]}, {"box": [190, 434, 312, 614], "vertical": true, "font_size": 26, "lines_coords": [[[256.0, 439.0], [282.0, 439.0], [282.0, 589.0], [256.0, 589.0]], [[223.0, 435.0], [250.0, 435.0], [250.0, 589.0], [223.0, 589.0]], [[190.0, 434.0], [217.0, 434.0], [218.0, 614.0], [192.0, 614.0]]], "lines": ["一年前までは", "ただのメガネ", "だったのに．．．"]}, {"box": [192, 693, 284, 893], "vertical": true, "font_size": 26, "lines_coords": [[[254.0, 693.0], [284.0, 693.0], [284.0, 848.0], [254.0, 848.0]], [[226.0, 693.0], [248.0, 693.0], [248.0, 893.0], [226.0, 893.0]], [[192.0, 693.0], [218.0, 693.0], [218.0, 806.0], [192.0, 806.0]]], "lines": ["前のアタシは", "もう死んだことに", "しといて。"]}, {"box": [897, 984, 961, 1089], "vertical": true, "font_size": 31, "lines_coords": [[[926.0, 984.0], [961.0, 985.0], [956.0, 1089.0], [922.0, 1087.0]], [[897.0, 987.0], [925.0, 987.0], [925.0, 1087.0], [897.0, 1087.0]]], "lines": ["死んだ？", "何ソレ？"]}, {"box": [664, 1157, 790, 1439], "vertical": true, "font_size": 27, "lines_coords": [[[762.0, 1160.0], [789.0, 1160.0], [790.0, 1362.0], [764.0, 1362.0]], [[728.0, 1157.0], [761.0, 1157.0], [762.0, 1439.0], [729.0, 1439.0]], [[701.0, 1164.0], [723.0, 1164.0], [723.0, 1287.0], [701.0, 1287.0]], [[664.0, 1160.0], [690.0, 1160.0], [695.0, 1339.0], [668.0, 1339.0]]], "lines": ["泣き虫のあんたを", "さんさんかまってやった", "私の立場は", "どうなんのよ？"]}], "img_path": "subarashii_sekai_02_058.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [575, 173, 597, 277], "vertical": true, "font_size": 17, "lines_coords": [[[576.0, 178.0], [593.0, 178.0], [593.0, 267.0], [576.0, 267.0]]], "lines": ["左右には"]}, {"box": [892, 601, 953, 781], "vertical": true, "font_size": 27, "lines_coords": [[[923.0, 603.0], [950.0, 603.0], [953.0, 756.0], [926.0, 756.0]], [[893.0, 601.0], [920.0, 601.0], [918.0, 779.0], [892.0, 779.0]]], "lines": ["中学デビュー", "とかいって．．．"]}, {"box": [206, 696, 232, 808], "vertical": true, "font_size": 26, "lines_coords": [[[206.0, 696.0], [232.0, 696.0], [232.0, 806.0], [206.0, 806.0]]], "lines": ["カッコ悪。"]}, {"box": [908, 887, 970, 1028], "vertical": true, "font_size": 30, "lines_coords": [[[936.0, 887.0], [970.0, 887.0], [970.0, 967.0], [936.0, 967.0]], [[908.0, 889.0], [934.0, 889.0], [934.0, 1028.0], [908.0, 1028.0]]], "lines": ["岡崎の", "つくり笑い。"]}, {"box": [517, 926, 553, 1014], "vertical": true, "font_size": 33, "lines_coords": [[[517.0, 928.0], [550.0, 926.0], [553.0, 1012.0], [520.0, 1014.0]]], "lines": ["なんか、"]}, {"box": [639, 1317, 762, 1465], "vertical": true, "font_size": 27, "lines_coords": [[[736.0, 1320.0], [762.0, 1320.0], [762.0, 1465.0], [736.0, 1465.0]], [[703.0, 1320.0], [729.0, 1320.0], [729.0, 1445.0], [703.0, 1445.0]], [[668.0, 1317.0], [697.0, 1317.0], [698.0, 1456.0], [670.0, 1456.0]], [[639.0, 1318.0], [665.0, 1318.0], [665.0, 1457.0], [639.0, 1457.0]]], "lines": ["メチャクチャ", "頑張ってる", "感があって、", "時々ひくよ。"]}, {"box": [348, 1353, 387, 1462], "vertical": true, "font_size": 34, "lines_coords": [[[348.0, 1354.0], [382.0, 1353.0], [387.0, 1460.0], [353.0, 1462.0]]], "lines": ["うざっ。"]}], "img_path": "subarashii_sekai_02_059.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [851, 115, 978, 321], "vertical": true, "font_size": 27, "lines_coords": [[[945.0, 115.0], [978.0, 115.0], [978.0, 198.0], [945.0, 198.0]], [[915.0, 117.0], [942.0, 117.0], [942.0, 271.0], [915.0, 271.0]], [[886.0, 117.0], [908.0, 117.0], [908.0, 292.0], [886.0, 292.0]], [[853.0, 115.0], [879.0, 115.0], [878.0, 321.0], [851.0, 321.0]]], "lines": ["あんた", "頑張ることを", "カッコ悪いとか", "思ってんでしょ？"]}, {"box": [482, 103, 575, 279], "vertical": true, "font_size": 24, "lines_coords": [[[548.0, 104.0], [572.0, 104.0], [573.0, 279.0], [550.0, 279.0]], [[518.0, 106.0], [540.0, 106.0], [540.0, 254.0], [518.0, 254.0]], [[482.0, 103.0], [509.0, 103.0], [512.0, 232.0], [486.0, 232.0]]], "lines": ["人気とるために", "努力して何が", "悪いのよ？"]}, {"box": [281, 240, 368, 418], "vertical": true, "font_size": 26, "lines_coords": [[[346.0, 243.0], [368.0, 243.0], [368.0, 418.0], [346.0, 418.0]], [[312.0, 240.0], [339.0, 240.0], [339.0, 392.0], [312.0, 392.0]], [[281.0, 240.0], [307.0, 240.0], [307.0, 356.0], [281.0, 356.0]]], "lines": ["アタシたちには", "時間がないん", "だからさ。"]}, {"box": [804, 360, 897, 515], "vertical": true, "font_size": 27, "lines_coords": [[[870.0, 362.0], [897.0, 362.0], [897.0, 515.0], [870.0, 515.0]], [[839.0, 365.0], [865.0, 365.0], [865.0, 492.0], [839.0, 492.0]], [[807.0, 360.0], [836.0, 360.0], [832.0, 476.0], [804.0, 476.0]]], "lines": ["そういうのが", "一番ダセー", "っつうの。"]}, {"box": [248, 462, 371, 646], "vertical": true, "font_size": 26, "lines_coords": [[[343.0, 462.0], [371.0, 462.0], [371.0, 565.0], [343.0, 565.0]], [[312.0, 462.0], [339.0, 462.0], [339.0, 646.0], [312.0, 646.0]], [[279.0, 464.0], [306.0, 464.0], [306.0, 565.0], [279.0, 565.0]], [[248.0, 462.0], [275.0, 462.0], [275.0, 576.0], [248.0, 576.0]]], "lines": ["ウダウダ", "理屈こねないで、", "サクサク", "やろーよ。"]}, {"box": [854, 759, 922, 890], "vertical": true, "font_size": 36, "lines_coords": [[[879.0, 759.0], [922.0, 759.0], [922.0, 832.0], [879.0, 832.0]], [[854.0, 762.0], [883.0, 762.0], [883.0, 890.0], [854.0, 890.0]]], "lines": ["何よ、", "その顔．．．．．"]}, {"box": [903, 993, 995, 1208], "vertical": true, "font_size": 32, "lines_coords": [[[951.0, 998.0], [989.0, 996.0], [995.0, 1173.0], [958.0, 1175.0]], [[903.0, 993.0], [929.0, 993.0], [929.0, 1206.0], [903.0, 1206.0]]], "lines": ["いーよ！", "じゃあ賭けようよ。"]}, {"box": [425, 1007, 517, 1198], "vertical": true, "font_size": 26, "lines_coords": [[[489.0, 1009.0], [515.0, 1009.0], [515.0, 1121.0], [489.0, 1121.0]], [[457.0, 1009.0], [484.0, 1009.0], [484.0, 1145.0], [457.0, 1145.0]], [[426.0, 1007.0], [453.0, 1007.0], [451.0, 1198.0], [425.0, 1198.0]]], "lines": ["次の電車、", "各停か急行、", "どっちが来るか。"]}, {"box": [184, 760, 273, 926], "vertical": true, "font_size": 26, "lines_coords": [[[245.0, 760.0], [271.0, 760.0], [271.0, 903.0], [245.0, 903.0]], [[210.0, 760.0], [239.0, 760.0], [240.0, 926.0], [212.0, 926.0]], [[184.0, 762.0], [206.0, 762.0], [206.0, 887.0], [184.0, 887.0]]], "lines": ["「このクソ女", "死ね」とかって", "思ってる？"]}, {"box": [115, 1276, 241, 1489], "vertical": true, "font_size": 27, "lines_coords": [[[210.0, 1276.0], [239.0, 1276.0], [240.0, 1489.0], [212.0, 1489.0]], [[179.0, 1278.0], [206.0, 1278.0], [207.0, 1484.0], [181.0, 1484.0]], [[150.0, 1279.0], [173.0, 1279.0], [175.0, 1482.0], [151.0, 1482.0]], [[115.0, 1279.0], [143.0, 1279.0], [143.0, 1370.0], [115.0, 1370.0]]], "lines": ["あんたが勝ったら、", "アタシはここから", "電車に飛び込んで", "あげる。"]}], "img_path": "subarashii_sekai_02_060.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [933, 137, 997, 288], "vertical": true, "font_size": 26, "lines_coords": [[[970.0, 137.0], [997.0, 137.0], [992.0, 287.0], [965.0, 287.0]], [[933.0, 139.0], [959.0, 139.0], [959.0, 267.0], [933.0, 267.0]]], "lines": ["じゃあ岡崎が", "勝ったら？"]}, {"box": [681, 245, 740, 368], "vertical": true, "font_size": 26, "lines_coords": [[[714.0, 246.0], [740.0, 246.0], [740.0, 368.0], [714.0, 368.0]], [[681.0, 245.0], [707.0, 245.0], [711.0, 357.0], [684.0, 357.0]]], "lines": ["．．．．．．アイス", "おごって。"]}, {"box": [884, 680, 915, 847], "vertical": true, "font_size": 27, "lines_coords": [[[884.0, 729.0], [911.0, 729.0], [911.0, 846.0], [884.0, 846.0]]], "lines": ["．．．．．．各停。"]}, {"box": [400, 396, 426, 534], "vertical": true, "font_size": 26, "lines_coords": [[[400.0, 396.0], [426.0, 396.0], [426.0, 534.0], [400.0, 534.0]]], "lines": ["バカみたい。"]}, {"box": [104, 414, 196, 604], "vertical": true, "font_size": 26, "lines_coords": [[[165.0, 414.0], [192.0, 414.0], [195.0, 568.0], [168.0, 568.0]], [[137.0, 415.0], [160.0, 415.0], [162.0, 592.0], [139.0, 592.0]], [[104.0, 414.0], [131.0, 414.0], [132.0, 604.0], [106.0, 604.0]]], "lines": ["今のアタシは", "あんたに負ける", "気がしないから。"]}, {"box": [189, 903, 254, 1070], "vertical": true, "font_size": 34, "lines_coords": [[[226.0, 906.0], [253.0, 906.0], [253.0, 1070.0], [226.0, 1070.0]], [[189.0, 903.0], [229.0, 903.0], [229.0, 975.0], [189.0, 975.0]]], "lines": ["じゃ、アタシは", "急行。"]}], "img_path": "subarashii_sekai_02_061.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [334, 609, 428, 735], "vertical": true, "font_size": 27, "lines_coords": [[[401.0, 609.0], [428.0, 609.0], [428.0, 718.0], [401.0, 718.0]], [[368.0, 609.0], [395.0, 609.0], [395.0, 735.0], [368.0, 735.0]], [[337.0, 609.0], [365.0, 609.0], [362.0, 718.0], [334.0, 718.0]]], "lines": ["そうそう、", "あの公園に", "いるから、"]}, {"box": [182, 698, 275, 878], "vertical": true, "font_size": 27, "lines_coords": [[[248.0, 700.0], [275.0, 700.0], [275.0, 842.0], [248.0, 842.0]], [[214.0, 698.0], [240.0, 698.0], [243.0, 878.0], [217.0, 878.0]], [[182.0, 700.0], [209.0, 700.0], [209.0, 814.0], [182.0, 814.0]]], "lines": ["あー、じゃあ", "これからそっち", "向かうわ。"]}, {"box": [947, 939, 979, 1023], "vertical": true, "font_size": 32, "lines_coords": [[[947.0, 939.0], [979.0, 939.0], [979.0, 1023.0], [947.0, 1023.0]]], "lines": ["彼氏？"]}, {"box": [131, 1028, 223, 1157], "vertical": true, "font_size": 27, "lines_coords": [[[196.0, 1029.0], [223.0, 1029.0], [223.0, 1157.0], [196.0, 1157.0]], [[164.0, 1028.0], [190.0, 1028.0], [190.0, 1131.0], [164.0, 1131.0]], [[131.0, 1029.0], [159.0, 1029.0], [159.0, 1115.0], [131.0, 1115.0]]], "lines": ["電話の時も", "その笑顔", "なんだ。"]}, {"box": [742, 1389, 772, 1456], "vertical": true, "font_size": 30, "lines_coords": [[[742.0, 1389.0], [772.0, 1389.0], [772.0, 1456.0], [742.0, 1456.0]]], "lines": ["うん。"]}, {"box": [156, 1279, 246, 1495], "vertical": true, "font_size": 23, "lines_coords": [[[218.0, 1279.0], [245.0, 1279.0], [245.0, 1443.0], [218.0, 1443.0]], [[189.0, 1281.0], [210.0, 1281.0], [210.0, 1457.0], [189.0, 1457.0]], [[156.0, 1279.0], [176.0, 1279.0], [179.0, 1493.0], [159.0, 1493.0]]], "lines": ["毎日、鏡の前で", "練習してるから", "クセになっててさ。"]}], "img_path": "subarashii_sekai_02_062.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [786, 146, 847, 338], "vertical": true, "font_size": 25, "lines_coords": [[[820.0, 146.0], [847.0, 146.0], [842.0, 314.0], [815.0, 314.0]], [[787.0, 148.0], [811.0, 148.0], [809.0, 334.0], [786.0, 334.0]]], "lines": ["じゃあ、アタシ", "そろそろ行くわ。"]}, {"box": [564, 153, 631, 259], "vertical": true, "font_size": 34, "lines_coords": [[[600.0, 156.0], [628.0, 156.0], [631.0, 259.0], [603.0, 259.0]], [[564.0, 153.0], [604.0, 153.0], [604.0, 225.0], [564.0, 225.0]]], "lines": ["．．．．．．ねぇ", "岡崎、"]}, {"box": [134, 179, 233, 359], "vertical": true, "font_size": 25, "lines_coords": [[[195.0, 179.0], [221.0, 179.0], [221.0, 334.0], [195.0, 334.0]], [[164.0, 181.0], [190.0, 181.0], [190.0, 310.0], [164.0, 310.0]], [[134.0, 181.0], [156.0, 181.0], [156.0, 359.0], [134.0, 359.0]]], "lines": ["さっきの賭で", "負けてたら", "どうしてたの？"]}, {"box": [552, 409, 605, 599], "vertical": true, "font_size": 22, "lines_coords": [[[553.0, 410.0], [575.0, 410.0], [575.0, 598.0], [553.0, 598.0]]], "lines": ["どうもしないよ。"]}, {"box": [146, 542, 234, 696], "vertical": true, "font_size": 25, "lines_coords": [[[206.0, 542.0], [234.0, 542.0], [234.0, 645.0], [206.0, 645.0]], [[175.0, 542.0], [201.0, 542.0], [201.0, 643.0], [175.0, 643.0]], [[146.0, 543.0], [168.0, 543.0], [168.0, 695.0], [146.0, 695.0]]], "lines": ["そんなん", "するワケ", "ないじゃん！"]}, {"box": [875, 742, 906, 870], "vertical": true, "font_size": 28, "lines_coords": [[[878.0, 742.0], [906.0, 742.0], [903.0, 870.0], [875.0, 870.0]]], "lines": ["何それ．．．"]}, {"box": [868, 984, 909, 1054], "vertical": true, "font_size": 30, "lines_coords": [[[868.0, 985.0], [906.0, 984.0], [909.0, 1053.0], [872.0, 1054.0]]], "lines": ["はは、"]}, {"box": [210, 792, 275, 925], "vertical": true, "font_size": 33, "lines_coords": [[[234.0, 793.0], [270.0, 792.0], [275.0, 875.0], [239.0, 876.0]], [[210.0, 796.0], [239.0, 796.0], [239.0, 925.0], [210.0, 925.0]]], "lines": ["ずるい", "じゃん．．．"]}, {"box": [848, 1123, 937, 1303], "vertical": true, "font_size": 30, "lines_coords": [[[911.0, 1123.0], [937.0, 1123.0], [936.0, 1301.0], [909.0, 1301.0]], [[881.0, 1123.0], [908.0, 1123.0], [903.0, 1303.0], [876.0, 1303.0]], [[848.0, 1125.0], [876.0, 1125.0], [876.0, 1217.0], [848.0, 1217.0]]], "lines": ["ずるいくらいで", "ちょうどいいん", "だって。"]}, {"box": [231, 1265, 320, 1442], "vertical": true, "font_size": 24, "lines_coords": [[[295.0, 1267.0], [317.0, 1267.0], [317.0, 1442.0], [295.0, 1442.0]], [[260.0, 1265.0], [287.0, 1265.0], [287.0, 1418.0], [260.0, 1418.0]], [[231.0, 1267.0], [253.0, 1267.0], [253.0, 1378.0], [231.0, 1378.0]]], "lines": ["アタシたちには", "時間がないん", "だからさ。"]}], "img_path": "subarashii_sekai_02_063.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [873, 129, 967, 295], "vertical": true, "font_size": 27, "lines_coords": [[[939.0, 131.0], [965.0, 131.0], [965.0, 295.0], [939.0, 295.0]], [[906.0, 131.0], [934.0, 131.0], [934.0, 257.0], [906.0, 257.0]], [[873.0, 129.0], [900.0, 129.0], [903.0, 270.0], [876.0, 270.0]]], "lines": ["つーか、あんた", "その笑い顔", "キモいって。"]}, {"box": [254, 223, 345, 403], "vertical": true, "font_size": 28, "lines_coords": [[[315.0, 225.0], [345.0, 225.0], [345.0, 379.0], [315.0, 379.0]], [[286.0, 223.0], [312.0, 223.0], [312.0, 403.0], [286.0, 403.0]], [[254.0, 223.0], [281.0, 223.0], [281.0, 379.0], [254.0, 379.0]]], "lines": ["笑いたい時は", "もっとちゃんと", "笑っときな？"]}, {"box": [889, 688, 950, 903], "vertical": true, "font_size": 24, "lines_coords": [[[922.0, 690.0], [948.0, 690.0], [948.0, 892.0], [922.0, 892.0]], [[892.0, 690.0], [914.0, 690.0], [914.0, 896.0], [892.0, 896.0]]], "lines": ["例の事件の公園で", "私とサトは別れた"]}, {"box": [601, 690, 756, 879], "vertical": true, "font_size": 26, "lines_coords": [[[725.0, 690.0], [753.0, 690.0], [756.0, 817.0], [728.0, 817.0]], [[698.0, 693.0], [720.0, 693.0], [720.0, 817.0], [698.0, 817.0]], [[661.0, 690.0], [689.0, 690.0], [692.0, 845.0], [664.0, 845.0]], [[632.0, 692.0], [659.0, 692.0], [659.0, 845.0], [632.0, 845.0]], [[601.0, 693.0], [628.0, 693.0], [628.0, 875.0], [601.0, 875.0]]], "lines": ["私にとって", "この公園は", "サトと二人で", "昔よく遊んだ", "公園なのだけど"]}, {"box": [345, 685, 406, 908], "vertical": true, "font_size": 22, "lines_coords": [[[381.0, 685.0], [403.0, 685.0], [400.0, 884.0], [378.0, 884.0]], [[348.0, 690.0], [370.0, 690.0], [367.0, 906.0], [345.0, 906.0]]], "lines": ["サトはそのことに", "一言も触れなかった"]}, {"box": [162, 434, 284, 628], "vertical": true, "font_size": 28, "lines_coords": [[[257.0, 435.0], [284.0, 435.0], [284.0, 590.0], [257.0, 590.0]], [[223.0, 435.0], [256.0, 435.0], [256.0, 518.0], [223.0, 518.0]], [[195.0, 435.0], [221.0, 435.0], [221.0, 615.0], [195.0, 615.0]], [[162.0, 434.0], [189.0, 434.0], [190.0, 628.0], [164.0, 628.0]]], "lines": ["世の中なんて", "最後に", "笑ったもん勝ち", "なんだからさぁ。"]}, {"box": [178, 682, 401, 897], "vertical": true, "font_size": 36, "lines_coords": [[[232.0, 684.0], [268.0, 682.0], [271.0, 750.0], [235.0, 751.0]]], "lines": ["もう、"]}, {"box": [177, 686, 266, 875], "vertical": true, "font_size": 24, "lines_coords": [[[207.0, 689.0], [234.0, 689.0], [234.0, 865.0], [207.0, 865.0]], [[178.0, 690.0], [200.0, 690.0], [200.0, 870.0], [178.0, 870.0]]], "lines": ["忘れてしまった", "のかもしれない。"]}, {"box": [803, 921, 831, 1026], "vertical": true, "font_size": 25, "lines_coords": [[[803.0, 921.0], [831.0, 921.0], [831.0, 1026.0], [803.0, 1026.0]]], "lines": ["そうか．．．"]}, {"box": [718, 976, 740, 1112], "vertical": true, "font_size": 25, "lines_coords": [[[718.0, 976.0], [740.0, 976.0], [740.0, 1112.0], [718.0, 1112.0]]], "lines": ["そうだよね。"]}, {"box": [204, 1003, 233, 1110], "vertical": true, "font_size": 27, "lines_coords": [[[204.0, 1003.0], [231.0, 1003.0], [231.0, 1106.0], [204.0, 1106.0]]], "lines": ["うん．．．"]}, {"box": [814, 1176, 875, 1405], "vertical": true, "font_size": 26, "lines_coords": [[[848.0, 1176.0], [875.0, 1176.0], [875.0, 1403.0], [848.0, 1403.0]], [[817.0, 1176.0], [843.0, 1176.0], [840.0, 1385.0], [814.0, 1385.0]]], "lines": ["私たちは砂場でよく", "城を作って遊んだ"]}, {"box": [612, 1173, 733, 1453], "vertical": true, "font_size": 23, "lines_coords": [[[709.0, 1173.0], [731.0, 1173.0], [731.0, 1448.0], [709.0, 1448.0]], [[676.0, 1175.0], [698.0, 1175.0], [698.0, 1379.0], [676.0, 1379.0]], [[642.0, 1173.0], [668.0, 1173.0], [668.0, 1353.0], [642.0, 1353.0]], [[612.0, 1173.0], [634.0, 1173.0], [634.0, 1379.0], [612.0, 1379.0]]], "lines": ["二人でトンネルを掘って", "指と指が触れた時", "なんだかすごく", "うれしかったんだ"]}, {"box": [332, 1173, 425, 1354], "vertical": true, "font_size": 30, "lines_coords": [[[393.0, 1173.0], [425.0, 1173.0], [425.0, 1353.0], [393.0, 1353.0]], [[362.0, 1173.0], [392.0, 1173.0], [392.0, 1328.0], [362.0, 1328.0]], [[332.0, 1173.0], [359.0, 1173.0], [359.0, 1310.0], [332.0, 1310.0]]], "lines": ["その時の笑顔を", "私は少しだけ", "思い出した"]}], "img_path": "subarashii_sekai_02_064.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [742, 101, 757, 231], "vertical": true, "font_size": 15, "lines_coords": [[[742.0, 101.0], [757.0, 101.0], [757.0, 231.0], [742.0, 231.0]]], "lines": ["．．．"]}, {"box": [875, 59, 887, 76], "vertical": false, "font_size": 17, "lines_coords": [[[875.0, 59.0], [887.0, 59.0], [887.0, 76.0], [875.0, 76.0]]], "lines": ["．．"]}, {"box": [817, 57, 847, 253], "vertical": true, "font_size": 14.666666666666666, "lines_coords": [[[832.0, 57.0], [845.0, 57.0], [847.0, 114.0], [834.0, 114.0]], [[817.0, 57.0], [832.0, 57.0], [832.0, 139.0], [817.0, 139.0]], [[817.0, 134.0], [832.0, 134.0], [834.0, 253.0], [818.0, 253.0]]], "lines": ["．．", "．．．", "．．．"]}, {"box": [834, 159, 848, 189], "vertical": true, "font_size": 11, "lines_coords": [[[834.0, 160.0], [845.0, 159.0], [848.0, 187.0], [837.0, 189.0]]], "lines": ["．．"]}, {"box": [951, 59, 962, 76], "vertical": false, "font_size": 17, "lines_coords": [[[951.0, 59.0], [962.0, 59.0], [962.0, 76.0], [951.0, 76.0]]], "lines": ["．．"]}, {"box": [890, 56, 925, 246], "vertical": true, "font_size": 16.0, "lines_coords": [[[906.0, 56.0], [922.0, 56.0], [925.0, 135.0], [909.0, 135.0]], [[890.0, 56.0], [906.0, 56.0], [906.0, 246.0], [890.0, 246.0]]], "lines": ["．．．", "．．．"]}, {"box": [911, 140, 922, 189], "vertical": true, "font_size": 11, "lines_coords": [[[911.0, 140.0], [922.0, 140.0], [922.0, 189.0], [911.0, 189.0]]], "lines": ["．．．"]}, {"box": [745, 345, 756, 401], "vertical": true, "font_size": 