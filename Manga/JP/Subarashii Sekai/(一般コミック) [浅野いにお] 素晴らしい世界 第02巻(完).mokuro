 true, "font_size": 26, "lines_coords": [[[978.0, 984.0], [1006.0, 984.0], [1006.0, 1092.0], [978.0, 1092.0]], [[948.0, 981.0], [975.0, 981.0], [975.0, 1096.0], [948.0, 1096.0]]], "lines": ["．．．なんだ", "くだらん"]}, {"box": [531, 1032, 651, 1212], "vertical": true, "font_size": 27, "lines_coords": [[[625.0, 1032.0], [651.0, 1032.0], [651.0, 1145.0], [625.0, 1145.0]], [[592.0, 1034.0], [618.0, 1034.0], [618.0, 1187.0], [592.0, 1187.0]], [[557.0, 1032.0], [584.0, 1032.0], [587.0, 1212.0], [561.0, 1212.0]], [[531.0, 1037.0], [553.0, 1037.0], [553.0, 1171.0], [531.0, 1171.0]]], "lines": ["でも先生、", "あのヒナが今", "巣立とうとして", "るんですよ。"]}, {"box": [426, 1182, 490, 1290], "vertical": true, "font_size": 27, "lines_coords": [[[453.0, 1184.0], [487.0, 1182.0], [490.0, 1276.0], [456.0, 1278.0]], [[426.0, 1185.0], [453.0, 1185.0], [453.0, 1290.0], [426.0, 1290.0]]], "lines": ["ほらっ、", "今にも！"]}, {"box": [135, 1292, 170, 1432], "vertical": true, "font_size": 33, "lines_coords": [[[135.0, 1292.0], [168.0, 1292.0], [168.0, 1432.0], [135.0, 1432.0]]], "lines": ["ほらっ！"]}], "img_path": "subarashii_sekai_02_013.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [818, 428, 942, 582], "vertical": true, "font_size": 26, "lines_coords": [[[914.0, 429.0], [940.0, 429.0], [940.0, 557.0], [914.0, 557.0]], [[881.0, 429.0], [908.0, 429.0], [908.0, 582.0], [881.0, 582.0]], [[853.0, 431.0], [875.0, 431.0], [875.0, 579.0], [853.0, 579.0]], [[818.0, 428.0], [845.0, 428.0], [845.0, 535.0], [818.0, 535.0]]], "lines": ["俺の父親は", "医者で確かに", "エリートでは", "あるんだ"]}, {"box": [836, 734, 923, 860], "vertical": true, "font_size": 26, "lines_coords": [[[897.0, 734.0], [923.0, 734.0], [923.0, 848.0], [897.0, 848.0]], [[867.0, 735.0], [889.0, 735.0], [889.0, 860.0], [867.0, 860.0]], [[836.0, 735.0], [858.0, 735.0], [858.0, 842.0], [836.0, 842.0]]], "lines": ["ただ、あの", "鬼の仮面を", "はずせは、"]}, {"box": [693, 868, 817, 1076], "vertical": true, "font_size": 26, "lines_coords": [[[795.0, 873.0], [817.0, 873.0], [817.0, 1075.0], [795.0, 1075.0]], [[761.0, 870.0], [787.0, 870.0], [787.0, 1051.0], [761.0, 1051.0]], [[725.0, 871.0], [756.0, 871.0], [756.0, 1076.0], [725.0, 1076.0]], [[693.0, 868.0], [728.0, 868.0], [728.0, 939.0], [693.0, 939.0]]], "lines": ["自分のブライドを", "守るのに必死な", "ただのビビリ野郎", "だよ。"]}, {"box": [262, 807, 353, 993], "vertical": true, "font_size": 27, "lines_coords": [[[326.0, 809.0], [353.0, 809.0], [353.0, 960.0], [326.0, 960.0]], [[295.0, 809.0], [317.0, 809.0], [317.0, 957.0], [295.0, 957.0]], [[262.0, 807.0], [289.0, 807.0], [289.0, 993.0], [262.0, 993.0]]], "lines": ["気付けば俺は", "おかしな塾に", "入れられてたし、"]}, {"box": [157, 995, 251, 1148], "vertical": true, "font_size": 27, "lines_coords": [[[218.0, 995.0], [251.0, 995.0], [251.0, 1076.0], [218.0, 1076.0]], [[187.0, 996.0], [215.0, 996.0], [217.0, 1148.0], [189.0, 1148.0]], [[157.0, 998.0], [184.0, 998.0], [184.0, 1107.0], [157.0, 1107.0]]], "lines": ["母親は", "いつの間にか", "消えてた"]}, {"box": [173, 1290, 261, 1493], "vertical": true, "font_size": 25, "lines_coords": [[[234.0, 1290.0], [260.0, 1290.0], [260.0, 1445.0], [234.0, 1445.0]], [[201.0, 1292.0], [228.0, 1292.0], [228.0, 1493.0], [201.0, 1493.0]], [[173.0, 1293.0], [195.0, 1293.0], [195.0, 1425.0], [173.0, 1425.0]]], "lines": ["どれもこれも", "父親の身勝手さが", "原因なのさ。"]}], "img_path": "subarashii_sekai_02_014.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [875, 148, 967, 253], "vertical": true, "font_size": 27, "lines_coords": [[[940.0, 150.0], [967.0, 150.0], [967.0, 253.0], [940.0, 253.0]], [[909.0, 148.0], [936.0, 148.0], [936.0, 253.0], [909.0, 253.0]], [[875.0, 150.0], [901.0, 150.0], [901.0, 237.0], [875.0, 237.0]]], "lines": ["アイツを", "見てると", "思うね"]}, {"box": [150, 290, 240, 493], "vertical": true, "font_size": 27, "lines_coords": [[[209.0, 290.0], [235.0, 290.0], [240.0, 443.0], [214.0, 443.0]], [[179.0, 290.0], [206.0, 290.0], [209.0, 493.0], [182.0, 493.0]], [[150.0, 290.0], [178.0, 290.0], [178.0, 406.0], [150.0, 406.0]]], "lines": ["なんのために", "人って生きてんの", "かってさ。"]}, {"box": [182, 526, 309, 709], "vertical": true, "font_size": 27, "lines_coords": [[[281.0, 529.0], [309.0, 529.0], [309.0, 642.0], [281.0, 642.0]], [[246.0, 528.0], [273.0, 528.0], [278.0, 709.0], [251.0, 709.0]], [[215.0, 529.0], [242.0, 529.0], [242.0, 706.0], [215.0, 706.0]], [[182.0, 528.0], [209.0, 526.0], [214.0, 642.0], [187.0, 643.0]]], "lines": ["．．．なんて、", "キミに言っても", "理解できないと", "思うけど。"]}, {"box": [945, 742, 1004, 895], "vertical": true, "font_size": 26, "lines_coords": [[[976.0, 742.0], [1004.0, 742.0], [1004.0, 845.0], [976.0, 845.0]], [[945.0, 742.0], [972.0, 742.0], [972.0, 895.0], [945.0, 895.0]]], "lines": ["キミって", "子供だねー"]}, {"box": [858, 907, 914, 1059], "vertical": true, "font_size": 26, "lines_coords": [[[887.0, 907.0], [914.0, 907.0], [914.0, 1059.0], [887.0, 1059.0]], [[858.0, 909.0], [879.0, 909.0], [879.0, 1035.0], [858.0, 1035.0]]], "lines": ["大人は大人で", "必死なのよ"]}, {"box": [135, 942, 258, 1143], "vertical": true, "font_size": 26, "lines_coords": [[[228.0, 945.0], [254.0, 945.0], [256.0, 1143.0], [229.0, 1143.0]], [[196.0, 943.0], [223.0, 943.0], [223.0, 1048.0], [196.0, 1048.0]], [[162.0, 942.0], [189.0, 942.0], [192.0, 1095.0], [165.0, 1095.0]], [[135.0, 946.0], [157.0, 946.0], [157.0, 1054.0], [135.0, 1054.0]]], "lines": ["辛いことだらけの", "世の中を", "やりぬいてく", "ためにさ。"]}, {"box": [854, 1204, 974, 1409], "vertical": true, "font_size": 25, "lines_coords": [[[950.0, 1207.0], [972.0, 1207.0], [972.0, 1357.0], [950.0, 1357.0]], [[915.0, 1204.0], [943.0, 1204.0], [940.0, 1407.0], [912.0, 1407.0]], [[883.0, 1204.0], [909.0, 1204.0], [911.0, 1409.0], [884.0, 1409.0]], [[854.0, 1207.0], [876.0, 1207.0], [876.0, 1382.0], [854.0, 1382.0]]], "lines": ["そんな大人に", "合わせてやるのが", "子供の甲斐性って", "もんじゃない？"]}, {"box": [201, 1256, 235, 1326], "vertical": true, "font_size": 30, "lines_coords": [[[201.0, 1256.0], [235.0, 1256.0], [235.0, 1326.0], [201.0, 1326.0]]], "lines": ["な．．．"]}, {"box": [139, 1371, 200, 1484], "vertical": true, "font_s