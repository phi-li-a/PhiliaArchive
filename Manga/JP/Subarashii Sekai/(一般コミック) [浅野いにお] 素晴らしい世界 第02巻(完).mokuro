nt_size": 31, "lines_coords": [[[582.0, 471.0], [611.0, 471.0], [611.0, 596.0], [582.0, 596.0]], [[546.0, 468.0], [579.0, 468.0], [582.0, 601.0], [550.0, 601.0]], [[520.0, 470.0], [546.0, 470.0], [546.0, 670.0], [520.0, 670.0]], [[482.0, 465.0], [520.0, 467.0], [517.0, 532.0], [479.0, 531.0]]], "lines": ["二日酔いの", "頭にひびく", "暴力的にまぶしい", "朝日"]}, {"box": [370, 470, 428, 607], "vertical": true, "font_size": 24, "lines_coords": [[[403.0, 473.0], [425.0, 473.0], [425.0, 595.0], [403.0, 595.0]], [[370.0, 470.0], [396.0, 470.0], [396.0, 606.0], [370.0, 606.0]]], "lines": ["出勤時間は", "せまってる。"]}, {"box": [204, 470, 263, 619], "vertical": true, "font_size": 27, "lines_coords": [[[235.0, 470.0], [262.0, 470.0], [262.0, 595.0], [235.0, 595.0]], [[204.0, 471.0], [231.0, 471.0], [231.0, 618.0], [204.0, 618.0]]], "lines": ["あなたなら", "どーします？"]}, {"box": [893, 737, 919, 915], "vertical": true, "font_size": 22, "lines_coords": [[[893.0, 737.0], [915.0, 737.0], [915.0, 831.0], [893.0, 831.0]]], "lines": ["こりゃー"]}, {"box": [670, 1085, 985, 1177], "vertical": false, "font_size": 35, "lines_coords": [[[695.0, 1087.0], [965.0, 1092.0], [965.0, 1125.0], [695.0, 1120.0]], [[673.0, 1134.0], [983.0, 1134.0], [983.0, 1171.0], [673.0, 1171.0]]], "lines": ["「５ｔｈｐｒｏｇｒａｍ", "ウイスキー－ボンボン"]}, {"box": [328, 1048, 390, 1201], "vertical": true, "font_size": 27, "lines_coords": [[[361.0, 1048.0], [389.0, 1048.0], [390.0, 1201.0], [362.0, 1201.0]], [[328.0, 1050.0], [354.0, 1050.0], [357.0, 1190.0], [331.0, 1190.0]]], "lines": ["サボるっきゃ", "ないでしょ。"]}, {"box": [895, 1367, 939, 1401], "vertical": false, "font_size": 37, "lines_coords": [[[895.0, 1364.0], [939.0, 1364.0], [939.0, 1404.0], [895.0, 1404.0]]], "lines": ["．．．"]}, {"box": [209, 1335, 823, 1492], "vertical": false, "font_size": 125, "lines_coords": [[[215.0, 1335.0], [823.0, 1367.0], [817.0, 1492.0], [209.0, 1460.0]]], "lines": ["素晴らしいぜ"]}], "img_path": "subarashii_sekai_02_115.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [816, 174, 841, 283], "vertical": true, "font_size": 22, "lines_coords": [[[818.0, 176.0], [840.0, 176.0], [840.0, 281.0], [818.0, 281.0]]], "lines": ["３９９円です。"]}, {"box": [490, 279, 590, 312], "vertical": false, "font_size": 33, "lines_coords": [[[490.0, 279.0], [590.0, 279.0], [590.0, 312.0], [490.0, 312.0]]], "lines": ["Ｓｏｏｇｏｎｔｅ"]}, {"box": [933, 491, 1000, 675], "vertical": true, "font_size": 28, "lines_coords": [[[972.0, 492.0], [1000.0, 492.0], [1000.0, 612.0], [972.0, 612.0]], [[934.0, 492.0], [962.0, 492.0], [962.0, 600.0], [934.0, 600.0]]], "lines": ["ありやと", "やしたー"]}, {"box": [181, 325, 276, 482], "vertical": true, "font_size": 28, "lines_coords": [[[250.0, 326.0], [276.0, 326.0], [276.0, 479.0], [250.0, 479.0]], [[212.0, 325.0], [243.0, 325.0], [246.0, 482.0], [215.0, 482.0]], [[181.0, 326.0], [215.0, 326.0], [215.0, 414.0], [181.0, 414.0]]], "lines": ["それでもまだ", "飲もうってん", "だから、"]}, {"box": [178, 540, 234, 725], "vertical": true, "font_size": 28, "lines_coords": [[[206.0, 540.0], [234.0, 540.0], [234.0, 645.0], [206.0, 645.0]], [[178.0, 543.0], [200.0, 543.0], [200.0, 725.0], [178.0, 725.0]]], "lines": ["あたしも", "たいしたもんだ。"]}, {"box": [927, 859, 984, 1021], "vertical": true, "font_size": 22, "lines_coords": [[[959.0, 859.0], [981.0, 859.0], [981.0, 1007.0], [959.0, 1007.0]], [[928.0, 862.0], [950.0, 862.0], [950.0, 1017.0], [928.0, 1017.0]]], "lines": ["近頃めっきり", "酒量が増えた"]}, {"box": [539, 1082, 599, 1234], "vertical": true, "font_size": 27, "lines_coords": [[[572.0, 1082.0], [598.0, 1082.0], [595.0, 1234.0], [568.0, 1234.0]], [[539.0, 1084.0], [567.0, 1084.0], [567.0, 1165.0], [539.0, 1165.0]]], "lines": ["酒で忘れたい", "ほどに、"]}, {"box": [659, 1098, 818, 1451], "vertical": true, "font_size": 28, "lines_coords": [[[792.0, 1101.0], [818.0, 1101.0], [818.0, 1375.0], [792.0, 1375.0]], [[759.0, 1100.0], [786.0, 1100.0], [786.0, 1356.0], [759.0, 1356.0]], [[726.0, 1100.0], [753.0, 1100.0], [753.0, 1451.0], [726.0, 1451.0]], [[693.0, 1098.0], [720.0, 1098.0], [720.0, 1276.0], [693.0, 1276.0]], [[659.0, 1098.0], [692.0, 1098.0], [692.0, 1185.0], [659.0, 1185.0]]], "lines": ["てっとり早く酔おうって", "この発想も悲しいけど、", "コンビニでウイスキーの小瓶を", "買う癖ってのも", "なんか"]}, {"box": [115, 1296, 203, 1471], "vertical": true, "font_size": 24, "lines_coords": [[[176.0, 1296.0], [203.0, 1296.0], [203.0, 1471.0], [176.0, 1471.0]], [[146.0, 1296.0], [168.0, 1296.0], [168.0, 1471.0], [146.0, 1471.0]], [[115.0, 1296.0], [137.0, 1296.0], [137.0, 1387.0], [115.0, 1387.0]]], "lines": ["辛いことなんて", "ないハズなんだ", "けどなー"]}], "img_path": "subarashii_sekai_02_116.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [830, 140, 986, 445], "vertical": true, "font_size": 25, "lines_coords": [[[958.0, 143.0], [984.0, 143.0], [984.0, 445.0], [958.0, 445.0]], [[928.0, 143.0], [950.0, 143.0], [950.0, 301.0], [928.0, 301.0]], [[892.0, 140.0], [920.0, 140.0], [922.0, 445.0], [893.0, 445.0]], [[861.0, 140.0], [887.0, 140.0], [887.0, 443.0], [861.0, 443.0]], [[832.0, 143.0], [854.0, 143.0], [854.0, 403.0], [832.0, 403.0]]], "lines": ["確かに、この春から移った", "営業促進部は、", "おおげさな部署名のワリに", "あたしの仕事はバンコンに", "伝票打ち込むだけだし、"]}, {"box": [120, 131, 278, 365], "vertical": true, "font_size": 31, "lines_coords": [[[245.0, 131.0], [278.0, 131.0], [278.0, 287.0], [245.0, 287.0]], [[212.0, 132.0], [245.0, 132.0], [245.0, 365.0], [212.0, 365.0]], [[181.0, 132.0], [209.0, 132.0], [212.0, 289.0], [184.0, 289.0]], [[151.0, 132.0], [182.0, 132.0], [182.0, 339.0], [151.0, 339.0]], [[120.0, 131.0], [148.0, 131.0], [148.0, 246.0], [120.0, 246.0]]], "lines": ["まぁ、部長は", "ハゲでチョビヒゲで", "顔の造り自体", "セクハラなような", "気もする。"]}, {"box": [591, 503, 627, 678], "vertical": true, "font_size": 23, "lines_coords": [[[595.0, 631.0], [618.0, 631.0], [618.0, 673.0], [595.0, 673.0]]], "lines": ["で、"]}, {"box": [125, 509, 284, 742], "vertical": true, "font_size": 30, "lines_coords": [[[248.0, 510.0], [281.0, 510.0], [284.0, 742.0], [251.0, 742.0]], [[217.0, 509.0], [248.0, 509.0], [248.0, 676.0], [217.0, 676.0]], [[187.0, 510.0], [218.0, 510.0], [218.0, 718.0], [187.0, 718.0]], [[151.0, 509.0], [182.0, 509.0], [185.0, 692.0], [154.0, 692.0]], [[128.0, 515.0], [150.0, 515.0], [150.0, 703.0], [128.0, 703.0]]], "lines": ["同僚の女の子たちに", "なじめなくて、", "お昼は自分の机で", "お弁当を食べて", "いるのだけれど、"]}, {"box": [958, 1120, 983, 1278], "vertical": true, "font_size": 26, "lines_coords": [[[961.0, 1120.0], [983.0, 1120.0], [979.0, 1278.0], [958.0, 1278.0]]], "lines": ["ふと考えると、"]}, {"box": [118, 907, 246, 1142], "vertical": true, "font_size": 31, "lines_coords": [[[212.0, 910.0], [243.0, 910.0], [243.0, 1142.0], [212.0, 1142.0]], [[179.0, 907.0], [210.0, 907.0], [209.0, 1139.0], [178.0, 1139.0]], [[146.0, 907.0], [179.0, 907.0], [182.0, 1114.0], [150.0, 1114.0]], [[118.0, 909.0], [146.0, 909.0], [146.0, 1039.0], [118.0, 1039.0]]], "lines": ["酔っててきあがって", "「会社辞めたる！！」と", "大口だだいてみる", "ものの．．．"]}, {"box": [834, 1168, 898, 1401], "vertical": true, "font_size": 26, "lines_coords": [[[867.0, 1168.0], [898.0, 1168.0], [895.0, 1401.0], [864.0, 1401.0]], [[837.0, 1171.0], [864.0, 1171.0], [861.0, 1384.0], [834.0, 1384.0]]], "lines": ["「まぁ、いいか」って", "思ってるんだよね。"]}, {"box": [293, 1175, 353, 1337], "vertical": true, "font_size": 25, "lines_coords": [[[325.0, 1175.0], [348.0, 1175.0], [350.0, 1335.0], [326.0, 1335.0]], [[293.0, 1175.0], [320.0, 1175.0], [320.0, 1312.0], [293.0, 1312.0]]], "lines": ["氣楽に気楽に。", "それが一番。"]}, {"box": [101, 1331, 128, 1469], "vertical": true, "font_size": 22, "lines_coords": [[[103.0, 1331.0], [125.0, 1331.0], [125.0, 1407.0], [103.0, 1407.0]], [[101.0, 1407.0], [123.0, 1407.0], [123.0, 1462.0], [101.0, 1462.0]]], "lines": ["ごめー", "ん"]}], "img_path": "subarashii_sekai_02_117.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [978, 89, 1009, 292], "vertical": true, "font_size": 26, "lines_coords": [[[983.0, 89.0], [1009.0, 89.0], [1004.0, 292.0], [978.0, 292.0]]], "lines": ["１５分遅れくらい？"]}, {"box": [712, 170, 772, 398], "vertical": true, "font_size": 24, "lines_coords": [[[747.0, 173.0], [768.0, 173.0], [768.0, 398.0], [747.0, 398.0]], [[712.0, 170.0], [739.0, 170.0], [739.0, 334.0], [712.0, 334.0]]], "lines": ["急に呼んだ割りには", "早いじゃない。"]}, {"box": [509, 104, 598, 279], "vertical": true, "font_size": 24, "lines_coords": [[[575.0, 104.0], [597.0, 104.0], [597.0, 204.0], [575.0, 204.0]], [[542.0, 106.0], [564.0, 106.0], [564.0, 279.0], [542.0, 279.0]], [[509.0, 104.0], [536.0, 104.0], [536.0, 207.0], [509.0, 207.0]]], "lines": ["そんなに", "あたしに会いた", "かった？"]}, {"box": [595, 460, 629, 553], "vertical": true, "font_size": 34, "lines_coords": [[[595.0, 460.0], [629.0, 460.0], [629.0, 553.0], [595.0, 553.0]]], "lines": ["へっへ。"]}, {"box": [142, 562, 203, 743], "vertical": true, "font_size": 29, "lines_coords": [[[167.0, 562.0], [203.0, 562.0], [203.0, 623.0], [167.0, 623.0]], [[143.0, 568.0], [165.0, 568.0], [165.0, 743.0], [143.0, 743.0]]], "lines": ["また", "飲んでるんだ？"]}, {"box": [778, 789, 801, 942], "vertical": true, "font_size": 22, "lines_coords": [[[778.0, 789.0], [800.0, 789.0], [800.0, 942.0], [778.0, 942.0]]], "lines": ["どこ行こう？"]}, {"box": [622, 890, 679, 1101], "vertical": true, "font_size": 24, "lines_coords": [[[651.0, 890.0], [678.0, 890.0], [678.0, 1092.0], [651.0, 1092.0]], [[622.0, 892.0], [643.0, 892.0], [643.0, 1100.0], [622.0, 1100.0]]], "lines": ["俺、金かからない", "トコならどこでも、"]}, {"box": [253, 820, 346, 973], "vertical": true, "font_size": 29, "lines_coords": [[[318.0, 823.0], [346.0, 823.0], [346.0, 923.0], [318.0, 923.0]], [[286.0, 820.0], [312.0, 820.0], [315.0, 971.0], [289.0, 971.0]], [[253.0, 820.0], [286.0, 820.0], [286.0, 910.0], [253.0, 910.0]]], "lines": ["私の彼は", "５歳も年下の", "学生だ。"]}, {"box": [307, 1150, 428, 1357], "vertical": true, "font_size": 25, "lines_coords": [[[401.0, 1151.0], [428.0, 1151.0], [428.0, 1290.0], [401.0, 1290.0]], [[368.0, 1150.0], [395.0, 1150.0], [395.0, 1306.0], [368.0, 1306.0]], [[336.0, 1151.0], [362.0, 1151.0], [362.0, 1304.0], [336.0, 1304.0]], [[307.0, 1153.0], [328.0, 1153.0], [328.0, 1281.0], [307.0, 1281.0]]], "lines": ["あっはっは。", "さびれてるー", "誰が来んだろ", "こんなトコ"]}, {"box": [146, 1331, 173, 1418], "vertical": true, "font_size": 27, "lines_coords": [[[146.0, 1331.0], [173.0, 1331.0], [173.0, 1418.0], [146.0, 1418.0]]], "lines": ["ははは。"]}], "img_path": "subarashii_sekai_02_118.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [925, 92, 1017, 334], "vertical": true, "font_size": 25, "lines_coords": [[[990.0, 93.0], [1017.0, 93.0], [1017.0, 296.0], [990.0, 296.0]], [[961.0, 95.0], [983.0, 95.0], [983.0, 220.0], [961.0, 220.0]], [[925.0, 92.0], [951.0, 92.0], [951.0, 334.0], [925.0, 334.0]]], "lines": ["ところで大丈夫？", "会社休んで", "遊んじゃったりして。"]}, {"box": [689, 134, 718, 271], "vertical": true, "font_size": 26, "lines_coords": [[[689.0, 134.0], [715.0, 134.0], [715.0, 270.0], [689.0, 270.0]]], "lines": ["いーんだよ。"]}, {"box": [279, 139, 402, 368], "vertical": true, "font_size": 26, "lines_coords": [[[375.0, 140.0], [401.0, 140.0], [401.0, 251.0], [375.0, 251.0]], [[342.0, 140.0], [368.0, 140.0], [368.0, 368.0], [342.0, 368.0]], [[309.0, 139.0], [336.0, 139.0], [339.0, 368.0], [312.0, 368.0]], [[279.0, 143.0], [303.0, 143.0], [304.0, 345.0], [281.0, 345.0]]], "lines": ["時々思う", "彼の目にはあたしが", "どんなふうに映って", "いるんだろう、と"]}, {"box": [165, 140, 223, 344], "vertical": true, "font_size": 22, "lines_coords": [[[196.0, 142.0], [218.0, 142.0], [218.0, 339.0], [196.0, 339.0]], [[165.0, 140.0], [187.0, 140.0], [187.0, 290.0], [165.0, 290.0]]], "lines": ["酒飲みて自堕落な", "ＯＬ、とか？"]}, {"box": [437, 403, 527, 631], "vertical": true, "font_size": 24, "lines_coords": [[[503.0, 404.0], [525.0, 404.0], [525.0, 629.0], [503.0, 629.0]], [[468.0, 404.0], [495.0, 404.0], [495.0, 631.0], [468.0, 631.0]], [[437.0, 403.0], [459.0, 403.0], [459.0, 587.0], [437.0, 587.0]]], "lines": ["あたしがいなくても", "会社はいつもどおり", "動いてんだから。"]}, {"box": [268, 495, 295, 681], "vertical": true, "font_size": 28, "lines_coords": [[[268.0, 495.0], [295.0, 495.0], [295.0, 681.0], [268.0, 681.0]]], "lines": ["．．．なーんてな。"]}, {"box": [159, 640, 221, 850], "vertical": true, "font_size": 28, "lines_coords": [[[185.0, 640.0], [217.0, 640.0], [221.0, 850.0], [190.0, 850.0]], [[159.0, 643.0], [185.0, 643.0], [185.0, 757.0], [159.0, 757.0]]], "lines": ["年くっちゃったね", "あたしも。"]}, {"box": [964, 967, 993, 1025], "vertical": true, "font_size": 29, "lines_coords": [[[964.0, 967.0], [993.0, 967.0], [993.0, 1025.0], [964.0, 1025.0]]], "lines": ["え？"]}, {"box": [198, 908, 288, 1136], "vertical": true, "font_size": 22, "lines_coords": [[[198.0, 981.0], [220.0, 981.0], [220.0, 1134.0], [198.0, 1134.0]]], "lines": ["どうしたの？"]}, {"box": [779, 1198, 879, 1420], "vertical": true, "font_size": 34, "lines_coords": [[[847.0, 1201.0], [879.0, 1201.0], [879.0, 1331.0], [847.0, 1331.0]], [[812.0, 1201.0], [845.0, 1201.0], [848.0, 1381.0], [815.0, 1381.0]], [[779.0, 1198.0], [817.0, 1198.0], [817.0, 1420.0], [779.0, 1420.0]]], "lines": ["．．．．．なんか", "つまんないこと", "言っちゃったかな。"]}, {"box": [278, 1301, 340, 1418], "vertical": true, "font_size": 29, "lines_coords": [[[301.0, 1303.0], [337.0, 1301.0], [340.0, 1373.0], [304.0, 1375.0]], [[278.0, 1306.0], [300.0, 1306.0], [300.0, 1415.0], [278.0, 1415.0]]], "lines": ["あっ。", "そうそう。"]}], "img_path": "subarashii_sekai_02_119.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [900, 203, 948, 289], "vertical": true, "font_size": 42, "lines_coords": [[[900.0, 206.0], [942.0, 203.0], [948.0, 284.0], [906.0, 289.0]]], "lines": ["コレ。"]}, {"box": [947, 725, 1004, 952], "vertical": true, "font_size": 24, "lines_coords": [[[978.0, 726.0], [1004.0, 726.0], [1004.0, 893.0], [978.0, 893.0]], [[947.0, 725.0], [968.0, 725.0], [968.0, 951.0], [947.0, 951.0]]], "lines": ["何？なんで？", "どーしちゃったの？"]}, {"box": [689, 729, 817, 1148], "vertical": true, "font_size": 27, "lines_coords": [[[790.0, 735.0], [817.0, 735.0], [817.0, 854.0], [790.0, 854.0]], [[757.0, 732.0], [784.0, 732.0], [784.0, 910.0], [757.0, 910.0]], [[725.0, 732.0], [751.0, 732.0], [751.0, 935.0], [725.0, 935.0]], [[693.0, 729.0], [720.0, 729.0], [715.0, 1148.0], [689.0, 1148.0]]], "lines": ["いや、ホラ、", "クリスマス周辺", "仕事でキツいって", "言ってたじゃん？がわりっつーか。"]}, {"box": [723, 923, 784, 1140], "vertical": true, "font_size": 27, "lines_coords": [[[757.0, 923.0], [784.0, 923.0], [784.0, 1104.0], [757.0, 1104.0]], [[723.0, 929.0], [750.0, 929.0], [750.0, 1140.0], [723.0, 1140.0]]], "lines": ["で、ちょっと", "、早いけどケーキ"]}, {"box": [515, 767, 575, 1005], "vertical": true, "font_size": 27, "lines_coords": [[[548.0, 767.0], [575.0, 767.0], [575.0, 1004.0], [548.0, 1004.0]], [[515.0, 768.0], [542.0, 768.0], [542.0, 975.0], [515.0, 975.0]]], "lines": ["ウイスキーボンボン、", "お酒好きでしょ？"]}, {"box": [129, 853, 206, 1135], "vertical": true, "font_size": 33, "lines_coords": [[[170.0, 853.0], [206.0, 853.0], [206.0, 921.0], [170.0, 921.0]], [[162.0, 1009.0], [190.0, 1009.0], [190.0, 1135.0], [162.0, 1135.0]], [[129.0, 1006.0], [164.0, 1006.0], [164.0, 1073.0], [129.0, 1073.0]]], "lines": ["スキ。", "甘いものも", "スキ。"]}, {"box": [377, 1188, 402, 1313], "vertical": true, "font_size": 22, "lines_coords": [[[378.0, 1189.0], [400.0, 1189.0], [400.0, 1312.0], [378.0, 1312.0]]], "lines": ["おいしい？"]}, {"box": [279, 1334, 307, 1447], "vertical": true, "font_size": 27, "lines_coords": [[[279.0, 1334.0], [306.0, 1334.0], [306.0, 1446.0], [279.0, 1446.0]]], "lines": ["おいちい。"]}], "img_path": "subarashii_sekai_02_120.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [918, 98, 1039, 329], "vertical": true, "font_size": 26, "lines_coords": [[[1009.0, 98.0], [1037.0, 98.0], [1039.0, 237.0], [1011.0, 237.0]], [[979.0, 101.0], [1006.0, 101.0], [1006.0, 317.0], [979.0, 317.0]], [[945.0, 98.0], [976.0, 98.0], [976.0, 329.0], [945.0, 329.0]], [[918.0, 101.0], [940.0, 101.0], [940.0, 257.0], [918.0, 257.0]]], "lines": ["．．．あのさ、", "さっきの話、なんか", "年のこと気にしてる", "みたいだけど、"]}, {"box": [707, 104, 734, 256], "vertical": true, "font_size": 26, "lines_coords": [[[707.0, 104.0], [734.0, 104.0], [734.0, 256.0], [707.0, 256.0]]], "lines": ["何それー！？"]}, {"box": [543, 165, 664, 371], "vertical": true, "font_size": 26, "lines_coords": [[[637.0, 165.0], [664.0, 165.0], [664.0, 314.0], [637.0, 314.0]], [[606.0, 167.0], [632.0, 167.0], [632.0, 371.0], [606.0, 371.0]], [[573.0, 167.0], [600.0, 167.0], [600.0, 331.0], [573.0, 331.0]], [[543.0, 167.0], [565.0, 167.0], [565.0, 270.0], [543.0, 270.0]]], "lines": ["やーーだよー", "シワシワじゃん！！", "相当悲惨だよ、", "あたし！！"]}, {"box": [861, 362, 983, 617], "vertical": true, "font_size": 26, "lines_coords": [[[956.0, 365.0], [983.0, 365.0], [983.0, 518.0], [956.0, 518.0]], [[926.0, 367.0], [948.0, 367.0], [948.0, 617.0], [926.0, 617.0]], [[892.0, 365.0], [918.0, 365.0], [918.0, 556.0], [892.0, 556.0]], [[861.0, 362.0], [887.0, 362.0], [889.0, 579.0], [862.0, 579.0]]], "lines": ["６０歳過ぎれば", "みんな同じよーなもん", "なんだから、気に", "することないって。"]}, {"box": [107, 451, 165, 604], "vertical": true, "font_size": 24, "lines_coords": [[[135.0, 451.0], [162.0, 451.0], [165.0, 604.0], [139.0, 604.0]], [[107.0, 454.0], [129.0, 454.0], [129.0, 584.0], [107.0, 584.0]]], "lines": ["それでも俺は", "たぶん好き"]}, {"box": [917, 1051, 943, 1156], "vertical": true, "font_size": 26, "lines_coords": [[[917.0, 1051.0], [943.0, 1051.0], [943.0, 1156.0], [917.0, 1156.0]]], "lines": ["ごめん．．．"]}, {"box": [218, 1034, 256, 1128], "vertical": true, "font_size": 31, "lines_coords": [[[218.0, 1035.0], [253.0, 1034.0], [256.0, 1126.0], [221.0, 1128.0]]], "lines": ["何それ、"]}, {"box": [151, 1131, 178, 1242], "vertical": true, "font_size": 31, "lines_coords": [[[151.0, 1131.0], [178.0, 1131.0], [178.0, 1242.0], [151.0, 1242.0]]], "lines": ["マイク？"]}, {"box": [876, 1198, 903, 1360], "vertical": true, "font_size": 26, "lines_coords": [[[876.0, 1198.0], [903.0, 1198.0], [903.0, 1360.0], [876.0, 1360.0]]], "lines": ["も一回言って。"]}, {"box": [318, 1290, 506, 1523], "vertical": true, "font_size": 26, "lines_coords": [[[478.0, 1292.0], [506.0, 1292.0], [506.0, 1395.0], [478.0, 1395.0]], [[448.0, 1293.0], [475.0, 1293.0], [475.0, 1493.0], [448.0, 1493.0]], [[415.0, 1292.0], [443.0, 1292.0], [443.0, 1395.0], [415.0, 1395.0]], [[384.0, 1292.0], [411.0, 1292.0], [411.0, 1523.0], [384.0, 1523.0]], [[353.0, 1293.0], [379.0, 1293.0], [379.0, 1495.0], [353.0, 1495.0]], [[318.0, 1290.0], [345.0, 1290.0], [346.0, 1479.0], [320.0, 1479.0]]], "lines": ["こういう", "根処のないことを", "さらっと", "言ってしまうことに", "やっぱり年の差を", "感じてしまって、"]}, {"box": [214, 1290, 271, 1514], "vertical": true, "font_size": 26, "lines_coords": [[[245.0, 1292.0], [271.0, 1292.0], [271.0, 1443.0], [245.0, 1443.0]], [[217.0, 1290.0], [239.0, 1290.0], [235.0, 1514.0], [214.0, 1514.0]]], "lines": ["少し嫉妬して", "しまうのだけど．．．"]}], "img_path": "subarashii_sekai_02_121.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [981, 134, 1008, 269], "vertical": true, "font_size": 27, "lines_coords": [[[981.0, 134.0], [1008.0, 134.0], [1008.0, 262.0], [981.0, 262.0]]], "lines": ["ホイ、封印"]}, {"box": [707, 76, 737, 266], "vertical": true, "font_size": 27, "lines_coords": [[[709.0, 76.0], [736.0, 76.0], [734.0, 265.0], [707.0, 265.0]]], "lines": ["なんなの、ソレ？"]}, {"box": [453, 226, 475, 384], "vertical": true, "font_size": 23, "lines_coords": [[[453.0, 226.0], [475.0, 226.0], [475.0, 384.0], [453.0, 384.0]]], "lines": ["ひっひっぴっ。"]}, {"box": [865, 445, 970, 487], "vertical": false, "font_size": 39, "lines_coords": [[[867.0, 445.0], [970.0, 448.0], [968.0, 487.0], [865.0, 484.0]]], "lines": ["２０００年前に"]}, {"box": [345, 348, 401, 526], "vertical": true, "font_size": 23, "lines_coords": [[[375.0, 348.0], [401.0, 348.0], [401.0, 501.0], [375.0, 501.0]], [[345.0, 350.0], [367.0, 350.0], [367.0, 526.0], [345.0, 526.0]]], "lines": ["今言ったこと", "忘れないでよ！？"]}, {"box": [131, 367, 170, 557], "vertical": true, "font_size": 30, "lines_coords": [[[131.0, 489.0], [160.0, 487.0], [165.0, 556.0], [135.0, 557.0]]], "lines": ["うん。"]}, {"box": [825, 731, 883, 921], "vertical": true, "font_size": 24, "lines_coords": [[[856.0, 731.0], [883.0, 731.0], [879.0, 910.0], [853.0, 910.0]], [[826.0, 735.0], [848.0, 735.0], [848.0, 920.0], [826.0, 920.0]]], "lines": ["今日からあたし", "お酒を控えます。"]}, {"box": [300, 854, 326, 945], "vertical": true, "font_size": 26, "lines_coords": [[[300.0, 854.0], [326.0, 854.0], [326.0, 945.0], [300.0, 945.0]]], "lines": ["あはは。"]}, {"box": [257, 984, 284, 1095], "vertical": true, "font_size": 26, "lines_coords": [[[257.0, 984.0], [284.0, 984.0], [284.0, 1095.0], [257.0, 1095.0]]], "lines": ["ムリムリ"]}, {"box": [689, 1182, 809, 1462], "vertical": true, "font_size": 25, "lines_coords": [[[782.0, 1185.0], [809.0, 1185.0], [809.0, 1362.0], [782.0, 1362.0]], [[750.0, 1185.0], [776.0, 1185.0], [776.0, 1437.0], [750.0, 1437.0]], [[717.0, 1182.0], [743.0, 1182.0], [745.0, 1440.0], [718.0, 1440.0]], [[689.0, 1185.0], [711.0, 1185.0], [711.0, 1459.0], [689.0, 1459.0]]], "lines": ["あたしがいつか", "涙を流したりしながら", "そのウイスキーの蓋を", "あけるその日までは．．．"]}, {"box": [500, 1189, 525, 1325], "vertical": true, "font_size": 22, "lines_coords": [[[500.0, 1189.0], [521.0, 1189.0], [523.0, 1320.0], [501.0, 1320.0]]], "lines": ["とりあえず"]}, {"box": [334, 1184, 427, 1387], "vertical": true, "font_size": 27, "lines_coords": [[[400.0, 1187.0], [426.0, 1187.0], [426.0, 1312.0], [400.0, 1312.0]], [[370.0, 1187.0], [392.0, 1187.0], [392.0, 1384.0], [370.0, 1384.0]], [[334.0, 1184.0], [367.0, 1184.0], [367.0, 1275.0], [334.0, 1275.0]]], "lines": ["彼の言葉を", "信じてあけようと", "思った"]}], "img_path": "subarashii_sekai_02_122.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [60, 50, 70, 64], "vertical": false, "font_size": 14, "lines_coords": [[[60.0, 50.0], [70.0, 50.0], [70.0, 64.0], [60.0, 64.0]]], "lines": ["．．"]}, {"box": [62, 67, 68, 98], "vertical": true, "font_size": 6, "lines_coords": [[[62.0, 67.0], [68.0, 67.0], [68.0, 98.0], [62.0, 98.0]]], "lines": ["．．．"]}, {"box": [73, 48, 87, 151], "vertical": true, "font_size": 12, "lines_coords": [[[75.0, 48.0], [87.0, 48.0], [85.0, 151.0], [73.0, 151.0]]], "lines": ["．．．"]}, {"box": [206, 45, 223