0, 270.0]], [[1056.0, 268.0], [1530.0, 268.0], [1530.0, 312.0], [1056.0, 312.0]], [[1120.0, 310.0], [1496.0, 310.0], [1496.0, 342.0], [1120.0, 342.0]], [[988.0, 340.0], [1601.0, 340.0], [1601.0, 384.0], [988.0, 384.0]], [[1003.0, 381.0], [1601.0, 381.0], [1601.0, 414.0], [1003.0, 414.0]], [[1218.0, 415.0], [1376.0, 415.0], [1376.0, 459.0], [1218.0, 459.0]]], "lines": ["優しくも悲しい次世代読み切りシリーズ、", "ーテレホ行", "２００７年０００年０９月２０日からの", "「バードウィーク」「雨のお晴れ」「砂の城」「あの城", "「おやすみなさい」「月となると", "「素晴らしき世界」「あおそら」「春風」桜の季節」", "そして描き下ろし短編「ウイスキーボンボン」を含む", "１０編を収録。"]}, {"box": [24, 369, 605, 446], "vertical": false, "font_size": 53, "lines_coords": [[[30.0, 365.0], [594.0, 377.0], [594.0, 434.0], [30.0, 422.0]]], "lines": ["インターネットで紹介することができましたが、まずは自分自身の中ではありません。"]}, {"box": [785, 382, 886, 436], "vertical": false, "font_size": 59, "lines_coords": [[[785.0, 377.0], [886.0, 377.0], [886.0, 441.0], [785.0, 441.0]]], "lines": ["定価５６０円本体５００円"]}, {"box": [2342, 49, 2740, 75], "vertical": false, "font_size": 33, "lines_coords": [[[2342.0, 49.0], [2740.0, 49.0], [2740.0, 75.0], [2342.0, 75.0]]], "lines": ["良きではればきっと"]}, {"box": [1897, 16, 1954, 361], "vertical": true, "font_size": 37, "lines_coords": [[[1906.0, 49.0], [1943.0, 49.0], [1943.0, 347.0], [1906.0, 347.0]]], "lines": ["は、聞いてお"]}, {"box": [2308, 132, 2793, 169], "vertical": false, "font_size": 33, "lines_coords": [[[2308.0, 132.0], [2793.0, 132.0], [2793.0, 169.0], [2308.0, 169.0]]], "lines": ["いいことがありますよ。"]}, {"box": [2252, 215, 2849, 252], "vertical": false, "font_size": 33, "lines_coords": [[[2252.0, 215.0], [2849.0, 215.0], [2849.0, 252.0], [2252.0, 252.0]]], "lines": ["だから明日を怖がらないで"]}, {"box": [2105, 396, 3000, 433], "vertical": false, "font_size": 37, "lines_coords": [[[2105.0, 396.0], [3000.0, 396.0], [3000.0, 433.0], [2105.0, 433.0]]], "lines": ["今日もアナタの住む街が幸せでありますように．．．"]}], "img_path": "subarashii_sekai_02_#003.jpg"}, {"version": "0.1.7", "img_width": 2357, "img_height": 1600, "blocks": [], "img_path": "subarashii_sekai_02_#004.jpg"}]}