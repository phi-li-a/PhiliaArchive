ds": [[[586.0, 1435.0], [592.0, 1435.0], [592.0, 1489.0], [586.0, 1489.0]]], "lines": ["．．．"]}, {"box": [715, 1256, 732, 1385], "vertical": true, "font_size": 16, "lines_coords": [[[715.0, 1256.0], [731.0, 1256.0], [732.0, 1385.0], [717.0, 1385.0]]], "lines": ["．．．"]}], "img_path": "subarashii_sekai_02_150.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [797, 103, 915, 407], "vertical": true, "font_size": 24, "lines_coords": [[[893.0, 103.0], [915.0, 103.0], [912.0, 278.0], [890.0, 278.0]], [[854.0, 103.0], [886.0, 103.0], [886.0, 265.0], [854.0, 265.0]], [[828.0, 106.0], [850.0, 106.0], [850.0, 279.0], [828.0, 279.0]], [[797.0, 106.0], [818.0, 106.0], [818.0, 406.0], [797.0, 406.0]]], "lines": ["ちょっと目線を", "変えただけで、", "見慣れたものも", "違って見えるってのは．．．"]}, {"box": [687, 105, 744, 343], "vertical": true, "font_size": 22, "lines_coords": [[[722.0, 106.0], [743.0, 106.0], [743.0, 340.0], [722.0, 340.0]], [[687.0, 106.0], [709.0, 106.0], [712.0, 214.0], [690.0, 214.0]]], "lines": ["まぁ、よくある話では", "あるけど。"]}, {"box": [533, 103, 559, 344], "vertical": true, "font_size": 20, "lines_coords": [[[534.0, 106.0], [554.0, 106.0], [554.0, 335.0], [534.0, 335.0]]], "lines": ["確かに言えてるのな"]}, {"box": [200, 104, 324, 332], "vertical": true, "font_size": 25, "lines_coords": [[[300.0, 107.0], [321.0, 107.0], [321.0, 281.0], [300.0, 281.0]], [[265.0, 106.0], [289.0, 106.0], [290.0, 331.0], [267.0, 331.0]], [[231.0, 104.0], [259.0, 104.0], [262.0, 232.0], [234.0, 232.0]], [[200.0, 104.0], [226.0, 104.0], [229.0, 218.0], [203.0, 218.0]]], "lines": ["だらだらと長年", "住んできたこの街も", "全然違って", "見えるわ。"]}, {"box": [346, 904, 764, 939], "vertical": false, "font_size": 32, "lines_coords": [[[346.0, 907.0], [764.0, 904.0], [764.0, 935.0], [346.0, 939.0]]], "lines": ["１７ｔｈｐｒｏｇｒａｍあおぞら"]}], "img_path": "subarashii_sekai_02_151.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [904, 160, 937, 256], "vertical": true, "font_size": 33, "lines_coords": [[[904.0, 160.0], [937.0, 160.0], [937.0, 256.0], [904.0, 256.0]]], "lines": ["えっ！？"]}, {"box": [196, 800, 223, 931], "vertical": true, "font_size": 27, "lines_coords": [[[196.0, 800.0], [223.0, 800.0], [223.0, 931.0], [196.0, 931.0]]], "lines": ["ぎゃはっ！！"]}, {"box": [109, 1104, 206, 1240], "vertical": true, "font_size": 28, "lines_coords": [[[167.0, 1106.0], [203.0, 1104.0], [206.0, 1187.0], [170.0, 1189.0]], [[140.0, 1107.0], [168.0, 1107.0], [168.0, 1240.0], [140.0, 1240.0]], [[109.0, 1106.0], [135.0, 1106.0], [139.0, 1218.0], [112.0, 1218.0]]], "lines": ["やっと", "気付いたな、", "兄ちゃん。"]}, {"box": [754, 1323, 790, 1530], "vertical": true, "font_size": 32, "lines_coords": [[[754.0, 1323.0], [786.0, 1323.0], [790.0, 1529.0], [759.0, 1529.0]]], "lines": ["えぇーーっ．．．！！"]}, {"box": [179, 1290, 265, 1493], "vertical": true, "font_size": 28, "lines_coords": [[[239.0, 1290.0], [265.0, 1290.0], [265.0, 1493.0], [239.0, 1493.0]], [[207.0, 1290.0], [234.0, 1290.0], [234.0, 1445.0], [207.0, 1445.0]], [[179.0, 1293.0], [201.0, 1293.0], [201.0, 1493.0], [179.0, 1493.0]]], "lines": ["ずいぶんと長い間", "ぼんやり景色", "眺めてたんだぜ？"]}], "img_path": "subarashii_sekai_02_152.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [902, 121, 1025, 352], "vertical": true, "font_size": 26, "lines_coords": [[[998.0, 121.0], [1025.0, 121.0], [1022.0, 250.0], [995.0, 250.0]], [[962.0, 121.0], [989.0, 121.0], [989.0, 351.0], [962.0, 351.0]], [[931.0, 123.0], [958.0, 123.0], [958.0, 340.0], [931.0, 340.0]], [[903.0, 125.0], [925.0, 125.0], [925.0, 350.0], [903.0, 350.0]]], "lines": ["まぁ人間が", "ここから景色を望む", "機会なんて、減多に", "ないだろうから．．．"]}, {"box": [678, 165, 700, 281], "vertical": true, "font_size": 22, "lines_coords": [[[678.0, 165.0], [700.0, 165.0], [700.0, 281.0], [678.0, 281.0]]], "lines": ["え？え？"]}, {"box": [754, 567, 781, 695], "vertical": true, "font_size": 27, "lines_coords": [[[754.0, 567.0], [781.0, 567.0], [781.0, 695.0], [754.0, 695.0]]], "lines": ["新鮮だろ？"]}, {"box": [457, 501, 517, 654], "vertical": true, "font_size": 28, "lines_coords": [[[484.0, 501.0], [517.0, 501.0], [517.0, 590.0], [484.0, 590.0]], [[457.0, 503.0], [479.0, 503.0], [479.0, 654.0], [457.0, 654.0]]], "lines": ["つーか、", "あんたら何？"]}, {"box": [81, 459, 237, 703], "vertical": true, "font_size": 26, "lines_coords": [[[203.0, 459.0], [234.0, 459.0], [237.0, 654.0], [206.0, 654.0]], [[175.0, 462.0], [201.0, 462.0], [201.0, 615.0], [175.0, 615.0]], [[140.0, 460.0], [168.0, 460.0], [170.0, 700.0], [142.0, 700.0]], [[109.0, 460.0], [135.0, 460.0], [137.0, 703.0], [110.0, 703.0]], [[81.0, 462.0], [103.0, 462.0], [103.0, 614.0], [81.0, 614.0]]], "lines": ["ただ、街が違って", "見える理由は", "それだけじゃないぜ。", "なんせ、お前の見てる", "この世界は．．．"]}, {"box": [528, 1052, 560, 1296], "vertical": true, "font_size": 31, "lines_coords": [[[528.0, 1054.0], [559.0, 1054.0], [559.0, 1295.0], [528.0, 1295.0]]], "lines": ["俺のいない世界？"]}, {"box": [179, 753, 234, 962], "vertical": true, "font_size": 26, "lines_coords": [[[207.0, 753.0], [234.0, 753.0], [234.0, 903.0], [207.0, 903.0]], [[179.0, 753.0], [201.0, 753.0], [201.0, 962.0], [179.0, 962.0]]], "lines": ["お前のいない", "世界なんだからな。"]}, {"box": [226, 1389, 309, 1429], "vertical": false, "font_size": 40, "lines_coords": [[[226.0, 1389.0], [309.0, 1389.0], [309.0, 1429.0], [226.0, 1429.0]]], "lines": ["一日、"]}], "img_path": "subarashii_sekai_02_153.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [796, 140, 954, 327], "vertical": true, "font_size": 27, "lines_coords": [[[918.0, 140.0], [954.0, 140.0], [954.0, 206.0], [918.0, 206.0]], [[890.0, 142.0], [917.0, 142.0], [917.0, 275.0], [890.0, 275.0]], [[858.0, 142.0], [886.0, 142.0], [886.0, 243.0], [858.0, 243.0]], [[828.0, 142.0], [850.0, 142.0], [850.0, 325.0], [828.0, 325.0]], [[797.0, 143.0], [818.0, 143.0], [818.0, 296.0], [797.0, 296.0]]], "lines": ["いや、", "待て待て俺", "夢だろ？", "どーせ夢だから、", "夢オチだから、"]}, {"box": [623, 142, 683, 354], "vertical": true, "font_size": 24, "lines_coords": [[[657.0, 142.0], [679.0, 142.0], [679.0, 328.0], [657.0, 328.0]], [[623.0, 143.0], [650.0, 143.0], [650.0, 351.0], [623.0, 351.0]]], "lines": ["今、俺はどこかで", "寝てるに違いない。"]}, {"box": [451, 141, 509, 318], "vertical": true, "font_size": 58, "lines_coords": [[[451.0, 141.0], [509.0, 141.0], [509.0, 318.0], [451.0, 318.0]]], "lines": ["記憶をたどってみよう．．．"]}, {"box": [446, 140, 504, 314], "vertical": true, "font_size": 27, "lines_coords": [[[482.0, 143.0], [504.0, 143.0], [504.0, 314.0], [482.0, 314.0]], [[446.0, 140.0], [473.0, 140.0], [473.0, 267.0], [446.0, 267.0]]], "lines": ["記憶をたどって", "みよう．．．"]}, {"box": [315, 139, 406, 368], "vertical": true, "font_size": 27, "lines_coords": [[[379.0, 142.0], [406.0, 142.0], [406.0, 328.0], [379.0, 328.0]], [[342.0, 139.0], [375.0, 139.0], [378.0, 271.0], [345.0, 271.0]], [[315.0, 142.0], [342.0, 142.0], [342.0, 368.0], [315.0, 368.0]]], "lines": ["．．．そうだ、彼女に", "思いっきり", "ひっぱたかれて．．．"]}, {"box": [214, 243, 240, 406], "vertical": true, "font_size": 28, "lines_coords": [[[214.0, 243.0], [240.0, 243.0], [240.0, 406.0], [214.0, 406.0]]], "lines": ["．．．やっぱりね。"]}, {"box": [959, 621, 1059, 757], "vertical": true, "font_size": 28, "lines_coords": [[[1018.0, 621.0], [1059.0, 621.0], [1059.0, 682.0], [1018.0, 682.0]], [[993.0, 623.0], [1020.0, 623.0], [1020.0, 757.0], [993.0, 757.0]], [[959.0, 623.0], [989.0, 621.0], [992.0, 701.0], [962.0, 703.0]]], "lines": ["何が", "結婚しよう、", "だよ！"]}, {"box": [214, 473, 307, 654], "vertical": true, "font_size": 28, "lines_coords": [[[276.0, 473.0], [307.0, 473.0], [307.0, 654.0], [276.0, 654.0]], [[243.0, 475.0], [271.0, 475.0], [273.0, 604.0], [245.0, 604.0]], [[214.0, 473.0], [240.0, 473.0], [240.0, 581.0], [214.0, 581.0]]], "lines": ["やっぱり今度も", "無理だった", "じゃん！！"]}, {"box": [934, 828, 1056, 1020], "vertical": true, "font_size": 28, "lines_coords": [[[1028.0, 828.0], [1056.0, 828.0], [1051.0, 995.0], [1023.0, 995.0]], [[998.0, 831.0], [1020.0, 831.0], [1020.0, 1004.0], [998.0, 1004.0]], [[962.0, 829.0], [989.0, 829.0], [990.0, 1020.0], [964.0, 1020.0]], [[934.0, 831.0], [956.0, 831.0], [956.0, 957.0], [934.0, 957.0]]], "lines": ["「再就職なんて", "その気になりゃ", "余裕」とか言って", "全然だし！！"]}, {"box": [584, 790, 675, 1005], "vertical": true, "font_size": 25, "lines_coords": [[[648.0, 790.0], [675.0, 790.0], [675.0, 946.0], [648.0, 946.0]], [[615.0, 792.0], [642.0, 792.0], [642.0, 968.0], [615.0, 968.0]], [[584.0, 792.0], [606.0, 792.0], [609.0, 1003.0], [587.0, 1003.0]]], "lines": ["ま．．．しばらく", "就職はキビしい", "かもしれないけど、"]}, {"box": [421, 1084, 481, 1300], "vertical": true, "font_size": 26, "lines_coords": [[[451.0, 1084.0], [479.0, 1084.0], [481.0, 1218.0], [453.0, 1218.0]], [[421.0, 1084.0], [448.0, 1084.0], [450.0, 1300.0], [423.0, 1300.0]]], "lines": ["もういいよ、", "当てにしてないよ。"]}, {"box": [118, 881, 217, 1040], "vertical": true, "font_size": 33, "lines_coords": [[[184.0, 884.0], [217.0, 884.0], [217.0, 976.0], [184.0, 976.0]], [[154.0, 882.0], [185.0, 882.0], [185.0, 1040.0], [154.0, 1040.0]], [[118.0, 882.0], [153.0, 881.0], [156.0, 951.0], [121.0, 953.0]]], "lines": ["大丈夫、", "俺にも考えは", "ある。"]}, {"box": [698, 1264, 823, 1445], "vertical": true, "font_size": 27, "lines_coords": [[[795.0, 1270.0], [822.0, 1270.0], [822.0, 1395.0], [795.0, 1395.0]], [[764.0, 1267.0], [790.0, 1267.0], [790.0, 1426.0], [764.0, 1426.0]], [[731.0, 1265.0], [757.0, 1265.0], [756.0, 1445.0], [729.0, 1445.0]], [[701.0, 1264.0], [728.0, 1264.0], [725.0, 1396.0], [698.0, 1396.0]]], "lines": ["ロばっかで", "もう一年以上、", "プラブラしてる", "じゃんか！！"]}, {"box": [395, 1331, 417, 1462], "vertical": true, "font_size": 26, "lines_coords": [[[395.0, 1331.0], [417.0, 1331.0], [417.0, 1462.0], [395.0, 1462.0]]], "lines": ["．．．出てって。"]}], "img_path": "subarashii_sekai_02_154.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [973, 134, 1006, 321], "vertical": true, "font_size": 31, "lines_coords": [[[973.0, 135.0], [1004.0, 135.0], [1004.0, 321.0], [973.0, 321.0]]], "lines": ["．．．バーカ！！"]}, {"box": [889, 690, 987, 909], "vertical": true, "font_size": 24, "lines_coords": [[[959.0, 692.0], [987.0, 692.0], [987.0, 831.0], [959.0, 831.0]], [[925.0, 692.0], [947.0, 692.0], [947.0, 842.0], [925.0, 842.0]], [[893.0, 690.0], [915.0, 690.0], [911.0, 909.0], [889.0, 909.0]]], "lines": ["いや、最近は", "ホント酷くて", "ほとんどヒステリー。"]}, {"box": [864, 940, 923, 1117], "vertical": true, "font_size": 24, "lines_coords": [[[901.0, 943.0], [923.0, 943.0], [923.0, 1117.0], [901.0, 1117.0]], [[868.0, 940.0], [895.0, 940.0], [890.0, 1070.0], [864.0, 1070.0]]], "lines": ["マリッジブルー", "っつうの？"]}, {"box": [569, 739, 659, 968], "vertical": true, "font_size": 25, "lines_coords": [[[631.0, 742.0], [657.0, 742.0], [657.0, 920.0], [631.0, 920.0]], [[598.0, 739.0], [625.0, 739.0], [626.0, 968.0], [600.0, 968.0]], [[570.0, 743.0], [592.0, 743.0], [592.0, 925.0], [570.0, 925.0]]], "lines": ["今月中に再就職", "することが条件って", "彼女が言うから。"]}, {"box": [70, 754, 158, 993], "vertical": true, "font_size": 26, "lines_coords": [[[131.0, 754.0], [157.0, 754.0], [157.0, 946.0], [131.0, 946.0]], [[95.0, 754.0], [126.0, 754.0], [129.0, 962.0], [98.0, 962.0]], [[70.0, 757.0], [92.0, 757.0], [92.0, 992.0], [70.0, 992.0]]], "lines": ["まー、超必死に", "頑張ってみたけど", "なかなかキビしくて。"]}, {"box": [303, 1009, 379, 1382], "vertical": true, "font_size": 26, "lines_coords": [[[346.0, 1009.0], [373.0, 1009.0], [373.0, 1151.0], [346.0, 1151.0]], [[336.0, 1204.0], [362.0, 1204.0], [362.0, 1343.0], [336.0, 1343.0]], [[303.0, 1204.0], [329.0, 1204.0], [329.0, 1382.0], [303.0, 1382.0]]], "lines": ["そこで、だ！！", "この前の話、", "考えてくれた？"]}, {"box": [697, 1225, 787, 1464], "vertical": true, "font_size": 26, "lines_coords": [[[757.0, 1225.0], [786.0, 1225.0], [787.0, 1368.0], [759.0, 1368.0]], [[726.0, 1226.0], [753.0, 1226.0], [753.0, 1381.0], [726.0, 1381.0]], [[697.0, 1228.0], [720.0, 1228.0], [722.0, 1464.0], [698.0, 1464.0]]], "lines": ["堀田、おまえ", "まだ籍入れた", "ワケじゃないじゃん。"]}], "img_path": "subarashii_sekai_02_155.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [990, 109, 1018, 220], "vertical": true, "font_size": 25, "lines_coords": [[[990.0, 109.0], [1018.0, 109.0], [1018.0, 220.0], [990.0, 220.0]]], "lines": ["やーだよ"]}, {"box": [958, 254, 1042, 475], "vertical": true, "font_size": 25, "lines_coords": [[[1017.0, 259.0], [1040.0, 259.0], [1042.0, 475.0], [1018.0, 475.0]], [[986.0, 254.0], [1012.0, 254.0], [1014.0, 462.0], [987.0, 462.0]], [[958.0, 260.0], [979.0, 260.0], [979.0, 385.0], [958.0, 385.0]]], "lines": ["おまえと会社作って", "どうのこうのって", "ヤツだろ？"]}, {"box": [565, 148, 623, 323], "vertical": true, "font_size": 26, "lines_coords": [[[593.0, 148.0], [622.0, 148.0], [623.0, 276.0], [595.0, 276.0]], [[565.0, 150.0], [587.0, 150.0], [587.0, 323.0], [565.0, 323.0]]], "lines": ["．．．いやっ？", "わかんねーよ？"]}, {"box": [104, 273, 198, 495], "vertical": true, "font_size": 27, "lines_coords": [[[167.0, 273.0], [193.0, 273.0], [198.0, 443.0], [171.0, 443.0]], [[134.0, 275.0], [162.0, 275.0], [167.0, 495.0], [139.0, 495.0]], [[104.0, 276.0], [131.0, 276.0], [134.0, 493.0], [107.0, 493.0]]], "lines": ["「自分はきっと", "やればできる」って", "思ってるヤツほど、"]}, {"box": [737, 509, 794, 673], "vertical": true, "font_size": 24, "lines_coords": [[[767.0, 509.0], [793.0, 509.0], [793.0, 673.0], [767.0, 673.0]], [[737.0, 512.0], [759.0, 512.0], [759.0, 670.0], [737.0, 670.0]]], "lines": ["だって、おまえ", "ハカじゃんよ。"]}, {"box": [534, 373, 625, 556], "vertical": true, "font_size": 26, "lines_coords": [[[598.0, 373.0], [625.0, 373.0], [625.0, 550.0], [598.0, 550.0]], [[567.0, 373.0], [589.0, 373.0], [589.0, 556.0], [567.0, 556.0]], [[534.0, 373.0], [562.0, 373.0], [562.0, 453.0], [534.0, 453.0]]], "lines": ["やってやれない", "ことはないかも", "だろ？"]}, {"box": [118, 537, 212, 670], "vertical": true, "font_size": 27, "lines_coords": [[[184.0, 542.0], [212.0, 542.0], [212.0, 659.0], [184.0, 659.0]], [[151.0, 540.0], [179.0, 540.0], [176.0, 670.0], [148.0, 670.0]], [[118.0, 537.0], [145.0, 537.0], [148.0, 656.0], [121.0, 656.0]]], "lines": ["結局、何も", "できないん", "だよなぁ。"]}, {"box": [1004, 979, 1036, 1093], "vertical": true, "font_size": 27, "lines_coords": [[[1004.0, 979.0], [1033.0, 979.0], [1036.0, 1093.0], [1008.0, 1093.0]]], "lines": ["．．．ははは。"]}, {"box": [443, 1003, 531, 1248], "vertical": true, "font_size": 25, "lines_coords": [[[500.0, 1003.0], [528.0, 1003.0], [531.0, 1139.0], [503.0, 1139.0]], [[470.0, 1003.0], [496.0, 1003.0], [501.0, 1248.0], [475.0, 1248.0]], [[443.0, 1006.0], [465.0, 1006.0], [465.0, 1167.0], [443.0, 1167.0]]], "lines": ["話そらすな。", "おまえのためを思って", "言ってやるよ。"]}, {"box": [131, 992, 250, 1271], "vertical": true, "font_size": 28, "lines_coords": [[[228.0, 993.0], [250.0, 993.0], [250.0, 1218.0], [228.0, 1218.0]], [[195.0, 992.0], [221.0, 992.0], [223.0, 1271.0], [196.0, 1271.0]], [[160.0, 993.0], [187.0, 993.0], [192.0, 1128.0], [165.0, 1128.0]], [[131.0, 993.0], [157.0, 993.0], [162.0, 1234.0], [135.0, 1234.0]]], "lines": ["とりあえず目の前に", "あったもんに手ぇつけて", "放り出して、", "何も結果出してねぇ。"]}, {"box": [915, 1120, 1036, 1301], "vertical": true, "font_size": 27, "lines_coords": [[[1008.0, 1120.0], [1036.0, 1120.0], [1036.0, 1209.0], [1008.0, 1209.0]], [[975.0, 1121.0], [1003.0, 1121.0], [1004.0, 1278.0], [976.0, 1278.0]], [[942.0, 1121.0], [968.0, 1121.0], [972.0, 1278.0], [945.0, 1278.0]], [[915.0, 1126.0], [937.0, 1126.0], [937.0, 1301.0], [915.0, 1301.0]]], "lines": ["見ろよ、", "隣の部屋．．．", "冬なのに風鈴", "つけっぱたせ？"]}, {"box": [398, 1214, 453, 1420], "vertical": true, "font_size": 25, "lines_coords": [[[425.0, 1214.0], [451.0, 1214.0], [453.0, 1420.0], [426.0, 1420.0]], [[398.0, 1214.0], [420.0, 1214.0], [420.0, 1367.0], [398.0, 1367.0]]], "lines": ["おまえは行動力は", "あるけど．．．"]}, {"box": [98, 1314, 195, 1470], "vertical": true, "font_size": 28, "lines_coords": [[[157.0, 1314.0], [195.0, 1314.0], [195.0, 1376.0], [157.0, 1376.0]], [[128.0, 1317.0], [156.0, 1317.0], [159.0, 1448.0], [131.0, 1448.0]], [[98.0, 1315.0], [125.0, 1315.0], [128.0, 1470.0], [101.0, 1470.0]]], "lines": ["早く", "落ちついて", "くれよ、堀田。"]}], "img_path": "subarashii_sekai_02_156.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [931, 112, 1022, 292], "vertical": true, "font_size": 24, "lines_coords": [[[998.0, 118.0], [1020.0, 118.0], [1020.0, 267.0], [998.0, 267.0]], [[965.0, 115.0], [989.0, 115.0], [987.0, 292.0], [964.0, 292.0]], [[934.0, 112.0], [961.0, 112.0], [958.0, 268.0], [931.0, 268.0]]], "lines": ["つまり地道に", "コツコツやりな", "さいってか？"]}, {"box": [481, 139, 601, 345], "vertical": true, "font_size": 26, "lines_coords": [[[573.0, 140.0], [600.0, 140.0], [600.0, 296.0], [573.0, 296.0]], [[542.0, 140.0], [568.0, 140.0], [568.0, 321.0], [542.0, 321.0]], [[507.0, 139.0], [536.0, 139.0], [537.0, 345.0], [509.0, 345.0]], [[481.0, 142.0], [503.0, 142.0], [503.0, 279.0], [481.0, 279.0]]], "lines": ["こんな腐れた", "世の中で、んな", "だるいことやって", "らんねーよ。"]}, {"box": [140, 110, 259, 339], "vertical": true, "font_size": 26, "lines_coords": [[[232.0, 110.0], [259.0, 110.0], [257.0, 339.0], [231.0, 339.0]], [[201.0, 112.0], [228.0, 112.0], [228.0, 314.0], [201.0, 314.0]], [[170.0, 112.0], [196.0, 112.0], [196.0, 279.0], [170.0, 279.0]], [[140.0, 112.0], [162.0, 112.0], [162.0, 325.0], [140.0, 325.0]]], "lines": ["借りもんの格好いい", "言葉やらスタイル", "真似ても、結局", "中身はその単純さ。"]}, {"box": [964, 390, 990, 479], "vertical": true, "font_size": 25, "lines_coords": [[[964.0, 390.0], [990.0, 390.0], [990.0, 479.0], [964.0, 479.0]]], "lines": ["出たね。"]}, {"box": [854, 435, 909, 589], "vertical": true, "font_size": 25, "lines_coords": [[[883.0, 435.0], [909.0, 435.0], [909.0, 589.0], [883.0, 589.0]], [[854.0, 440.0], [876.0, 440.0], [876.0, 548.0], [854.0, 548.0]]], "lines": ["それが堀田の", "本性だよ。"]}, {"box": [123, 410, 182, 520], "vertical": true, "font_size": 26, "lines_coords": [[[156.0, 410.0], [182.0, 410.0], [182.0, 520.0], [156.0, 520.0]], [[123.0, 412.0], [151.0, 412.0], [151.0, 493.0], [123.0, 493.0]]], "lines": ["どうなの", "それ？"]}, {"box": [987, 983, 1014, 1148], "vertical": true, "font_size": 22, "lines_coords": [[[989.0, 985.0], [1011.0, 985.0], [1011.0, 1145.0], [989.0, 1145.0]]], "lines": ["早く気付けよ。"]}, {"box": [496, 792, 528, 909], "vertical": true, "font_size": 28, "lines_coords": [[[496.0, 792.0], [525.0, 792.0], [528.0, 909.0], [500.0, 909.0]]], "lines": ["．．．うっせ。"]}, {"box": [707, 1198, 798, 1367], "vertical": true, "font_size": 26, "lines_coords": [[[776.0, 1203.0], [798.0, 1203.0], [798.0, 1351.0], [776.0, 1351.0]], [[742.0, 1201.0], [768.0, 1201.0], [768.0, 1329.0], [742.0, 1329.0]], [[707.0, 1198.0], [736.0, 1198.0], [739.0, 1367.0], [711.0, 1367.0]]], "lines": ["おまえはまだ", "人生で何も", "しちゃいねぇ。"]}, {"box": [615, 1348, 706, 1501], "vertical": true, "font_size": 26, "lines_coords": [[[679.0, 1348.0], [706.0, 1348.0], [706.0, 1489.0], [679.0, 1489.0]], [[647.0, 1348.0], [675.0, 1348.0], [672.0, 1450.0], [643.0, 1450.0]], [[615.0, 1348.0], [642.0, 1348.0], [642.0, 1501.0], [615.0, 1501.0]]], "lines": ["今、死んだら", "何ひとつ", "残らないぜ？"]}, {"box": [121, 1268, 214, 1521], "vertical": true, "font_size": 28, "lines_coords": [[[184.0, 1270.0], [212.0, 1270.0], [212.0, 1376.0], [184.0, 1376.0]], [[153.0, 1268.0], [181.0, 1268.0], [181.0, 1420.0], [153.0, 1420.0]], [[121.0, 1268.0], [148.0, 1268.0], [150.0, 1521.0], [123.0, 1521.0]]], "lines": ["２３歳の時、", "就職先蹴って", "パンドとかやって．．．"]}], "img_path": "subarashii_sekai_02_157.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [873, 81, 1001, 262], "vertical": true, "font_size": 30, "lines_coords": [[[973.0, 84.0], [1000.0, 84.0], [1000.0, 246.0], [973.0, 246.0]], [[939.0, 84.0], [965.0, 84.0], [965.0, 209.0], [939.0, 209.0]], [[903.0, 81.0], [937.0, 81.0], [940.0, 260.0], [906.0, 260.0]], [[873.0, 82.0], [908.0, 82.0], [908.0, 176.0], [873.0, 176.0]]], "lines": ["結局、脱退して", "親のコネで", "サラリーマンに", "なった。"]}, {"box": [576, 134, 640, 240], "vertical": true, "font_size": 28, "lines_coords": [[[607.0, 135.0], [640.0, 135.0], [640.0, 240.0], [607.0, 240.0]], [[576.0, 134.0], [609.0, 134.0], [609.0, 226.0], [576.0, 226.0]]], "lines": ["．．．そして", "今の俺。"]}, {"box": [489, 231, 607, 498], "vertical": true, "font_size": 28, "lines_coords": [[[581.0, 231.0], [607.0, 231.0], [607.0, 414.0], [581.0, 414.0]], [[550.0, 259.0], [576.0, 259.0], [576.0, 437.0], [550.0, 437.0]], [[517.0, 259.0], [543.0, 259.0], [543.0, 465.0], [517.0, 465.0]], [[489.0, 262.0], [511.0, 262.0], [511.0, 498.0], [489.0, 498.0]]], "lines": ["．．．確かに俺は", "人生の中で人に", "誉められるような", "ことは「して」ないさ。"]}, {"box": [731, 582, 831, 768], "vertical": true, "font_size": 37, "lines_coords": [[[790.0, 582.0], [831.0, 582.0], [831.0, 671.0], [790.0, 671.0]], [[759.0, 587.0], [797.0, 585.0], [801.0, 742.0], [764.0, 743.0]], [[731.0, 585.0], [762.0, 585.0], [762.0, 768.0], [731.0, 768.0]]], "lines": ["そこも", "しばらくして", "辞めたけど．．．"]}, {"box": [115, 331, 239, 568], "vertical": true, "font_size": 27, "lines_coords": [[[201.0, 331.0], [234.0, 331.0], [239.0, 490.0], [206.0, 490.0]], [[173.0, 332.0], [201.0, 332.0], [203.0, 568.0], [175.0, 568.0]], [[143.0, 332.0], [171.0, 332.0], [171.0, 462.0], [143.0, 462.0]], [[115.0, 335.0], [137.0, 335.0], [137.0, 487.0], [115.0, 487.0]]], "lines": ["でも誰だって", "たいしたことなんて、", "「して」ない", "じゃんか．．．"]}, {"box": [190, 656, 214, 717], "vertical": true, "font_size": 27, "lines_coords": [[[190.0, 656.0], [214.0, 656.0], [214.0, 717.0], [190.0, 717.0]]], "lines": ["ん？"]}, {"box": [739, 901, 766, 1052], "vertical": true, "font_size": 26, "lines_coords": [[[739.0, 901.0], [765.0, 901.0], [765.0, 1051.0], [739.0, 1051.0]]], "lines": ["何よ、おまえ。"]}, {"box": [956, 1154, 978, 1248], "vertical": true, "font_size": 17, "lines_coords": [[[956.0, 1154.0], [973.0, 1154.0], [973.0, 1245.0], [956.0, 1245.0]]], "lines": ["方も確認"]}], "img_path": "subarashii_sekai_02_158.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [564, 376, 593, 529], "vertical": true, "font_size": 27, "lines_coords": [[[564.0, 376.0], [590.0, 376.0], [593.0, 529.0], [567.0, 529.0]]], "lines": ["例えば――．．．"]}, {"box": [498, 573, 557, 707], "vertical": true, "font_size": 27, "lines_coords": [[[529.0, 573.0], [557.0, 573.0], [557.0, 706.0], [529.0, 706.0]], [[498.0, 579.0], [525.0, 579.0], [525.0, 707.0], [498.0, 707.0]]], "lines": ["「する」って", "のは．．．．．．"]}, {"box": [762, 785, 791, 1030], "vertical": true, "font_size": 27, "lines_coords": [[[762.0, 785.0], [789.0, 785.0], [789.0, 1028.0], [762.0, 1028.0]]], "lines": ["こーゆうことか？"]}, {"box": [215, 1291, 243, 1470], "vertical": true, "font_size": 22, "lines_coords": [[[217.0, 1318.0], [239.0, 1318.0], [239.0, 1468.0], [217.0, 1468.0]]], "lines": ["．．．違うか？"]}], "img_path": "subarashii_sekai_02_159.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [867, 175, 895, 354], "vertical": true, "font_size": 26, "lines_coords": [[[868.0, 175.0], [895.0, 175.0], [893.0, 353.0], [867.0, 353.0]]], "lines": ["違うかもな．．．"]}, {"box": [201, 212, 325, 415], "vertical": true, "font_size": 26, "lines_coords": [[[298.0, 215.0], [320.0, 215.0], [320.0, 348.0], [298.0, 348.0]], [[265.0, 212.0], [292.0, 212.0], [292.0, 415.0], [265.0, 415.0]], [[232.0, 212.0], [262.0, 212.0], [262.0, 367.0], [232.0, 367.0]], [[201.0, 212.0], [228.0, 212.0], [228.0, 317.0], [201.0, 317.0]]], "lines": ["あれはただ、", "人を殴りたかった", "だけなんじゃ", "ないか？"]}, {"box": [770, 564, 889, 716], "vertical": true, "font_size": 24, "lines_coords": [[[865.0, 565.0], [887.0, 565.0], [887.0, 714.0], [865.0, 714.0]], [[831.0, 565.0], [858.0, 565.0], [858.0, 700.0], [831.0, 700.0]], [[800.0, 564.0], [826.0, 564.0], [826.0, 715.0], [800.0, 715.0]], [[770.0, 565.0], [792.0, 565.0], [792.0, 715.0], [770.0, 715.0]]], "lines": ["さらに相手に", "落とされて、", "気付けばこの", "有様だよ．．．"]}, {"box": [922, 1156, 947, 1335], "vertical": true, "font_size": 21, "lines_coords": [[[922.0, 1156.0], [943.0, 1156.0], [943.0, 1332.0], [922.0, 1332.0]]], "lines": ["もういいよ．．．"]}, {"box": [286, 1153, 342, 1337], "vertical": true, "font_size": 26, "lines_coords": [[[312.0, 1153.0], [340.0, 1153.0], [342.0, 1256.0], [314.0, 1256.0]], [[286.0, 1154.0], [307.0, 1154.0], [307.0, 1337.0], [286.0, 1337.0]]], "lines": ["いろいろ", "どーでもいいよ。"]}, {"box": [179, 1296, 242, 1471], "vertical": true, "font_size": 26, "lines_coords": [[[210.0, 1296.0], [239.0, 1296.0], [242.0, 1426.0], [214.0, 1426.0]], [[179.0, 1296.0], [206.0, 1296.0], [207.0, 1471.0], [181.0, 1471.0]]], "lines": ["やっぱバカ", "なのかもな、俺。"]}], "img_path": "subarashii_sekai_02_160.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [959, 156, 1020, 285], "vertical": true, "font_size": 30, "lines_coords": [[[986.0, 156.0], [1020.0, 156.0], [1020.0, 239.0], [986.0, 239.0]], [[959.0, 157.0], [986.0, 157.0], [986.0, 285.0], [959.0, 285.0]]], "lines": ["メガネ", "メガネ．．．"]}, {"box": [592, 117, 629, 179], "vertical": true, "font_size": 37, "lines_coords": [[[592.0, 117.0], [629.0, 117.0], [629.0, 179.0], [592.0, 179.0]]], "lines": ["ん？"]}, {"box": [828, 618, 854, 750], "vertical": true, "font_size": 26, "lines_coords": [[[828.0, 618.0], [854.0, 618.0], [854.0, 750.0], [828.0, 750.0]]], "lines": ["ぎゃはっ！！"]}, {"box": [415, 273, 481, 584], "vertical": true, "font_size": 23, "lines_coords": [[[450.0, 273.0], [476.0, 273.0], [476.0, 384.0], [450.0, 384.0]], [[448.0, 459.0], [470.0, 459.0], [470.0, 582.0], [448.0, 582.0]], [[417.0, 459.0], [439.0, 459.0], [439.0, 568.0], [417.0, 568.0]]], "lines": ["なんだよ。", "そんな目で", "見るなよ。"]}, {"box": [250, 520, 312, 609], "vertical": true, "font_size": 38, "lines_coords": [[[250.0, 532.0], [286.0, 520.0], [312.0, 596.0], [276.0, 609.0]]], "lines": ["いっ！？"]}, {"box": [171, 487, 346, 695], "vertical": false, "font_size": 46.666666666666664, "lines_coords": [[[204.0, 489.0], [260.0, 678.0], [228.0, 687.0], [171.0, 500.0]], [[253.0, 487.0], [346.0, 656.0], [276.0, 695.0], [184.0, 526.0]], [[232.0, 515.0], [279.0, 670.0], [254.0, 678.0], [207.0, 523.0]]], "lines": ["Ｇｏｏｇｌｅｓｅｒ", "．．．えええっ！？", "だからなあなたの人のサーバー"]}, {"box": [942, 839, 1004, 1020], "vertical": true, "font_size": 28, "lines_coords": [[[972.0, 840.0], [1004.0, 840.0], [1004.0, 921.0], [972.0, 921.0]], [[943.0, 839.0], [970.0, 839.0], [968.0, 1020.0], [942.0, 1020.0]]], "lines": ["彼女が", "「ごめん」と言い"]}, {"box": [839, 965, 897, 1146], "vertical": true, "font_size": 28, "lines_coords": [[[870.0, 967.0], [897.0, 967.0], [897.0, 1146.0], [870.0, 1146.0]], [[839.0, 965.0], [867.0, 965.0], [867.0, 1057.0], [839.0, 1057.0]]], "lines": ["俺がなぁなぁに", "許して。"]}, {"box": [201, 1000, 257, 1203], "vertical": true, "font_size": 23, "lines_coords": [[[231.0, 1001.0], [257.0, 1001.0], [257.0, 1131.0], [231.0, 1131.0]], [[201.0, 1000.0], [223.0, 1000.0], [223.0, 1203.0], [201.0, 1203.0]]], "lines": ["またそれを", "繰り返すのが．．．"]}, {"box": [192, 1246, 214, 1421], "vertical": true, "font_size": 23, "lines_coords": [[[192.0, 1246.0], [214.0, 1246.0], [214.0, 1421.0], [192.0, 1421.0]]], "lines": ["くだらねぇ．．．"]}], "img_path": "subarashii_sekai_02_161.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [232, 836, 256, 942], "vertical": true, "font_size": 24, "lines_coords": [[[232.0, 887.0], [256.0, 887.0], [256.0, 940.0], [232.0, 940.0]]], "lines": ["え？"]}, {"box": [728, 1254, 816, 1457], "vertical": true, "font_size": 24, "lines_coords": [[[787.0, 1254.0], [814.0, 1254.0], [814.0, 1454.0], [787.0, 1454.0]], [[759.0, 1257.0], [781.0, 1257.0], [781.0, 1404.0], [759.0, 1404.0]], [[729.0, 1256.0], [751.0, 1256.0], [751.0, 1392.0], [729.0, 1392.0]]], "lines": ["その一瞬のうちに", "やたら冷静に", "俺は思った。"]}, {"box": [300, 1251, 395, 1431], "vertical": true, "font_size": 29, "lines_coords": [[[361.0, 1251.0], [395.0, 1251.0], [395.0, 1329.0], [361.0, 1329.0]], [[332.0, 1254.0], [359.0, 1254.0], [359.0, 1429.0], [332.0, 1429.0]], [[300.0, 1256.0], [326.0, 1256.0], [326.0, 1375.0], [300.0, 1375.0]]], "lines": ["「ああ、", "今が俺の人生の", "岐路た」と"]}], "img_path": "subarashii_sekai_02_162.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [270, 217, 330, 519], "vertical": true, "font_size": 26, "lines_coords": [[[303.0, 218.0], [329.0, 218.0], [329.0, 507.0], [303.0, 507.0]], [[270.0, 220.0], [296.0, 220.0], [296.0, 504.0], [270.0, 504.0]]], "lines": ["「この場面で子供を助ける", "べきかの是非は別として、"]}, {"box": [140, 217, 203, 596], "vertical": true, "font_size": 27, "lines_coords": [[[173.0, 217.0], [200.0, 217.0], [203.0, 546.0], [176.0, 546.0]], [[140.0, 218.0], [167.0, 218.0], [171.0, 590.0], [145.0, 590.0]]], "lines": ["今ここで何もできなかったら", "一生何もできねーよなぁ」なんて"]}, {"box": [473, 1325, 603, 1470], "vertical": true, "font_size": 52, "lines_coords": [[[553.0, 1328.0], [603.0, 1328.0], [603.0, 1470.0], [553.0, 1470.0]], [[473.0, 1325.0], [526.0, 1325.0], [526.0, 1425.0], [473.0, 1425.0]]], "lines": ["おい！！", "俺！！"]}], "img_path": "subarashii_sekai_02_163.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [961, 684, 978, 764], "vertical": true, "font_size": 25, "lines_coords": [[[961.0, 684.0], [978.0, 684.0], [978.0, 764.0], [961.0, 764.0]]], "lines": ["まさま。"]}, {"box": [232, 343, 357, 657], "vertical": true, "font_size": 31, "lines_coords": [[[328.0, 423.0], [353.0, 423.0], [353.0, 459.0], [328.0, 459.0]], [[300.0, 471.0], [336.0, 471.0], [336.0, 512.0], [300.0, 512.0]], [[271.0, 479.0], [298.0, 479.0], [298.0, 657.0], [271.0, 657.0]], [[232.0, 481.0], [268.0, 476.0], [276.0, 548.0], [240.0, 551.0]]], "lines": ["で、", "俺", "死んじゃったの", "かあ。"]}, {"box": [829, 793, 920, 950], "vertical": true, "font_size": 25, "lines_coords": [[[890.0, 793.0], [918.0, 793.0], [920.0, 950.0], [892.0, 950.0]], [[861.0, 796.0], [889.0, 796.0], [889.0, 934.0], [861.0, 934.0]], [[829.0, 798.0], [856.0, 798.0], [856.0, 945.0], [829.0, 945.0]]], "lines": ["子供かばって", "死ぬなんて、", "ベタだね、俺。"]}, {"box": [943, 1065, 1034, 1196], "vertical": true, "font_size": 28, "lines_coords": [[[1004.0, 1065.0], [1033.0, 1065.0], [1034.0, 1178.0], [1006.0, 1178.0]], [[972.0, 1065.0], [1004.0, 1065.0], [1004.0, 1168.0], [972.0, 1168.0]], [[943.0, 1065.0], [972.0, 1065.0], [972.0, 1196.0], [943.0, 1196.0]]], "lines": ["兄ちゃん、", "カン違い", "してねぇ？"]}, {"box": [182, 760, 241, 965], "vertical": true, "font_size": 26, "lines_coords": [[[214.0, 760.0], [240.0, 760.0], [240.0, 965.0], [214.0, 965.0]], [[182.0, 760.0], [209.0, 760.0], [209.0, 925.0], [182.0, 925.0]]], "lines": ["ガラじゃないこと", "しちゃったよ。"]}, {"box": [832, 1181, 925, 1348], "vertical": true, "font_size": 28, "lines_coords": [[[898.0, 1181.0], [925.0, 1181.0], [925.0, 1348.0], [898.0, 1348.0]], [[867.0, 1182.0], [893.0, 1182.0], [893.0, 1309.0], [867.0, 1309.0]], [[836.0, 1181.0], [864.0, 1181.0], [861.0, 1287.0], [832.0, 1287.0]]], "lines": ["あんた、あの時", "なんもして", "ねぇぜ？"]}, {"box": [118, 1325, 154, 1392], "vertical": true, "font_size": 36, "lines_coords": [[[118.0, 1325.0], [154.0, 1325.0], [154.0, 1392.0], [118.0, 1392.0]]], "lines": ["え？"]}], "img_path": "subarashii_sekai_02_164.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [942, 154, 999, 346], "vertical": true, "font_size": 26, "lines_coords": [[[970.0, 154.0], [997.0, 154.0], [998.0, 334.0], [972.0, 334.0]], [[942.0, 159.0], [968.0, 159.0], [968.0, 345.0], [942.0, 345.0]]], "lines": ["あんたは茫然と", "つっ立ったまま。"]}, {"box": [618, 175, 709, 404], "vertical": true, "font_size": 25, "lines_coords": [[[682.0, 176.0], [709.0, 176.0], [709.0, 404.0], [682.0, 404.0]], [[653.0, 178.0], [675.0, 178.0], [675.0, 379.0], [653.0, 379.0]], [[618.0, 175.0], [642.0, 175.0], [643.0, 339.0], [620.0, 339.0]]], "lines": ["急ハンドルを切った", "トラックは這悪く", "あんたに命中。"]}, {"box": [517, 309, 543, 471], "vertical": true, "font_size": 25, "lines_coords": [[[517.0, 309.0], [543.0, 309.0], [543.0, 471.0], [517.0, 471.0]]], "lines": ["ぺっちゃんこ。"]}, {"box": [109, 370, 203, 546], "vertical": true, "font_size": 27, "lines_coords": [[[175.0, 370.0], [203.0, 370.0], [200.0, 473.0], [171.0, 473.0]], [[145.0, 373.0], [167.0, 373.0], [167.0, 546.0], [145.0, 546.0]], [[109.0, 370.0], [137.0, 370.0], [139.0, 459.0], [110.0, 459.0]]], "lines": ["結果的に", "ガキは助かった", "けどよ。"]}, {"box": [157, 581, 246, 796], "vertical": true, "font_size": 27, "lines_coords": [[[220.0, 582.0], [246.0, 582.0], [246.0, 785.0], [220.0, 785.0]], [[187.0, 581.0], [214.0, 581.0], [215.0, 796.0], [189.0, 796.0]], [[157.0, 581.0], [185.0, 581.0], [185.0, 670.0], [157.0, 670.0]]], "lines": ["むしろダッシュで", "逃げてったけどな。", "ぎゃは。"]}, {"box": [865, 950, 893, 1077], "vertical": true, "font_size": 27, "lines_coords": [[[865.0, 950.0], [892.0, 950.0], [892.0, 1073.0], [865.0, 1073.0]]], "lines": ["ふうん．．．"]}, {"box": [589, 1140, 617, 1243], "vertical": true, "font_size": 28, "lines_coords": [[[589.0, 1140.0], [617.0, 1140.0], [617.0, 1243.0], [589.0, 1243.0]]], "lines": ["別に．．．"]}, {"box": [192, 998, 316, 1207], "vertical": true, "font_size": 28, "lines_coords": [[[286.0, 1000.0], [312.0, 1000.0], [315.0, 1204.0], [289.0, 1204.0]], [[256.0, 1000.0], [282.0, 1000.0], [282.0, 1156.0], [256.0, 1156.0]], [[221.0, 998.0], [254.0, 998.0], [254.0, 1089.0], [221.0, 1089.0]], [[192.0, 1000.0], [218.0, 1000.0], [221.0, 1109.0], [195.0, 1109.0]]], "lines": ["死神たちに憑かれ", "堀田トモツグ、", "事故死。", "享年２６歳"]}, {"box": [537, 1287, 570, 1400], "vertical": true, "font_size": 28, "lines_coords": [[[537.0, 1289.0], [565.0, 1287.0], [570.0, 1398.0], [542.0, 1400.0]]], "lines": ["いいけど。"]}], "img_path": "subarashii_sekai_02_165.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [923, 114, 1047, 357], "vertical": true, "font_size": 28, "lines_coords": [[[1012.0, 114.0], [1047.0, 114.0], [1047.0, 154.0], [1012.0, 154.0]], [[983.0, 118.0], [1012.0, 118.0], [1012.0, 273.0], [983.0, 273.0]], [[950.0, 115.0], [983.0, 115.0], [983.0, 357.0], [950.0, 357.0]], [[923.0, 118.0], [945.0, 118.0], [945.0, 220.0], [923.0, 220.0]]], "lines": ["ま、", "死ぬ時なんて", "人間あっけない案外", "もんよ？"]}, {"box": [200, 98, 292, 311], "vertical": true, "font_size": 28, "lines_coords": [[[260.0, 98.0], [292.0, 98.0], [292.0, 276.0], [260.0, 276.0]], [[231.0, 98.0], [257.0, 98.0], [257.0, 279.0], [231.0, 279.0]], [[200.0, 98.0], [226.0, 98.0], [226.0, 309.0], [200.0, 309.0]]], "lines": ["死はニュースの", "中の出来事だと", "思ってるようだが、"]}, {"box": [859, 301, 950, 535], "vertical": true, "font_size": 28, "lines_coords": [[[923.0, 301.0], [950.0, 301.0], [950.0, 490.0], [923.0, 490.0]], [[893.0, 304.0], [915.0, 304.0], [915.0, 431.0], [893.0, 431.0]], [[859.0, 304.0], [886.0, 304.0], [886.0, 535.0], [859.0, 535.0]]], "lines": ["きっかけなんて、", "そこら中に", "転がってるのにな．．．"]}, {"box": [260, 400, 315, 564], "vertical": true, "font_size": 25, "lines_coords": [[[293.0, 404.0], [315.0, 404.0], [315.0, 553.0], [293.0, 553.0]], [[260.0, 400.0], [287.0, 400.0], [287.0, 564.0], [260.0, 564.0]]], "lines": ["事故とか災害", "とかテロとか。"]}, {"box": [96, 528, 251, 754], "vertical": true, "font_size": 25, "lines_coords": [[[229.0, 528.0], [251.0, 528.0], [251.0, 631.0], [229.0, 631.0]], [[196.0, 528.0], [223.0, 528.0], [223.0, 707.0], [196.0, 707.0]], [[164.0, 529.0], [187.0, 529.0], [189.0, 754.0], [165.0, 754.0]], [[131.0, 529.0], [157.0, 529.0], [157.0, 707.0], [131.0, 707.0]], [[96.0, 528.0], [125.0, 528.0], [128.0, 620.0], [100.0, 620.0]]], "lines": ["あんたも", "知ってるだろ？", "新しい病気が世界に", "蔓延しつつある", "ことを。"]}, {"box": [925, 853, 983, 968], "vertical": true, "font_size": 28, "lines_coords": [[[956.0, 854.0], [983.0, 854.0], [983.0, 956.0], [956.0, 956.0]], [[925.0, 853.0], [951.0, 853.0], [951.0, 968.0], [925.0, 968.0]]], "lines": ["危機感が", "足りねぇ。"]}, {"box": [889, 1017, 983, 1273], "vertical": true, "font_size": 28, "lines_coords": [[[951.0, 1017.0], [983.0, 1017.0], [983.0, 1273.0], [951.0, 1273.0]], [[920.0, 1020.0], [947.0, 1020.0], [950.0, 1271.0], [923.0, 1271.0]], [[889.0, 1018.0], [915.0, 1018.0], [918.0, 1259.0], [892.0, 1259.0]]], "lines": ["誰ひとり自分がいずれ", "世界から消えるなんて", "考えてもいないのよ。"]}, {"box": [248, 948, 306, 1126], "vertical": true, "font_size": 27, "lines_coords": [[[279.0, 948.0], [306.0, 948.0], [306.0, 1126.0], [279.0, 1126.0]], [[248.0, 948.0], [275.0, 948.0], [275.0, 1059.0], [248.0, 1059.0]]], "lines": ["残ったヤツらは", "ヤツらで、"]}, {"box": [131, 1070, 225, 1301], "vertical": true, "font_size": 27, "lines_coords": [[[198.0, 1073.0], [225.0, 1073.0], [225.0, 1301.0], [198.0, 1301.0]], [[167.0, 1073.0], [193.0, 1073.0], [193.0, 1253.0], [167.0, 1253.0]], [[134.0, 1070.0], [162.0, 1070.0], [159.0, 1212.0], [131.0, 1212.0]]], "lines": ["いなくなって初めて", "そいつの存在に", "気付くんだ。"]}], "img_path": "subarashii_sekai_02_166.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [712, 131, 803, 308], "vertical": true, "font_size": 23, "lines_coords": [[[778.0, 131.0], [800.0, 131.0], [800.0, 307.0], [778.0, 307.0]], [[742.0, 131.0], [768.0, 131.0], [768.0, 281.0], [742.0, 281.0]], [[712.0, 131.0], [734.0, 131.0], [734.0, 292.0], [712.0, 292.0]]], "lines": ["．．．最後の最後で", "堀田には言い", "すぎたかもな。"]}, {"box": [90, 125, 221, 559], "vertical": true, "font_size": 30, "lines_coords": [[[185.0, 126.0], [215.0, 125.0], [221.0, 228.0], [192.0, 229.0]], [[157.0, 125.0], [190.0, 125.0], [184.0, 559.0], [151.0, 559.0]], [[187.0, 329.0], [214.0, 329.0], [214.0, 481.0], [187.0, 481.0]], [[125.0, 329.0], [151.0, 329.0], [151.0, 482.0], [125.0, 482.0]], [[90.0, 326.0], [123.0, 326.0], [123.0, 415.0], [90.0, 415.0]]], "lines": ["ただ嘘は", "ついちゃいない。友人でいるためには", "あいつと長く", "それでいいと", "思った。"]}, {"box": [279, 657, 309, 846], "vertical": true, "font_size": 24, "lines_coords": [[[279.0, 657.0], [303.0, 657.0], [304.0, 840.0], [281.0, 840.0]]], "lines": ["：死んだけどな"]}, {"box": [986, 929, 1015, 1034], "vertical": true, "font_size": 23, "lines_coords": [[[986.0, 931.0], [1009.0, 929.0], [1015.0, 1032.0], [992.0, 1034.0]]], "lines": ["ー．．．まぁ、"]}, {"box": [954, 900, 979, 1076], "vertical": true, "font_size": 23, "lines_coords": [[[956.0, 900.0], [979.0, 900.0], [978.0, 1076.0], [954.0, 1076.0]]], "lines": ["なんつうか．．．"]}, {"box": [398, 1073, 465, 1192], "vertical": true, "font_size": 33, "lines_coords": [[[429.0, 1073.0], [462.0, 1073.0], [465.0, 1192.0], [432.0, 1192.0]], [[398.0, 1076.0], [431.0, 1076.0], [431.0, 1165.0], [398.0, 1165.0]]], "lines": ["．．．．．って、", "無理か。"]}, {"box": [926, 1134, 948, 1268], "vertical": true, "font_size": 23, "lines_coords": [[[926.0, 1134.0], [948.0, 1134.0], [948.0, 1268.0], [926.0, 1268.0]]], "lines": ["元気出せよ。"]}, {"box": [114, 1304, 172, 1483], "vertical": true, "font_size": 24, "lines_coords": [[[140.0, 1304.0], [167.0, 1304.0], [171.0, 1482.0], [145.0, 1482.0]], [[114.0, 1309.0], [135.0, 1309.0], [135.0, 1415.0], [114.0, 1415.0]]], "lines": ["俺もしばらくは", "辛そうだ。"]}], "img_path": "subarashii_sekai_02_167.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [134, 1109, 200, 1275], "vertical": true, "font_size": 27, "lines_coords": [[[168.0, 1110.0], [196.0, 1110.0], [200.0, 1225.0], [171.0, 1225.0]], [[134.0, 1109.0], [160.0, 1109.0], [165.0, 1275.0], [139.0, 1275.0]]], "lines": ["兄ちゃん、", "もう時間だぜ。"]}], "img_path": "subarashii_sekai_02_168.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [765, 225, 801, 334], "vertical": true, "font_size": 33, "lines_coords": [[[768.0, 225.0], [801.0, 225.0], [798.0, 334.0], [765.0, 334.0]]], "lines": ["あ．．．．．．"]}, {"box": [307, 567, 343, 626], "vertical": true, "font_size": 36, "lines_coords": [[[307.0, 567.0], [343.0, 567.0], [343.0, 626.0], [307.0, 626.0]]], "lines": ["ん？"]}, {"box": [901, 875, 970, 989], "vertical": true, "font_size": 36, "lines_coords": [[[934.0, 875.0], [967.0, 875.0], [970.0, 989.0], [937.0, 989.0]], [[901.0, 876.0], [940.0, 876.0], [940.0, 967.0], [901.0, 967.0]]], "lines": ["．．．いや、", "いいや。"]}, {"box": [564, 918, 590, 1057], "vertical": true, "font_size": 26, "lines_coords": [[[564.0, 921.0], [590.0, 921.0], [590.0, 1057.0], [564.0, 1057.0]]], "lines": ["．．．．．そうか。"]}, {"box": [673, 1278, 737, 1415], "vertical": true, "font_size": 26, "lines_coords": [[[707.0, 1278.0], [736.0, 1278.0], [736.0, 1387.0], [707.0, 1387.0]], [[673.0, 1279.0], [695.0, 1279.0], [695.0, 1412.0], [673.0, 1412.0]]], "lines": ["あの眼鏡、", "伊達なんだ。"]}, {"box": [356, 1120, 417, 1336], "vertical": true, "font_size": 27, "lines_coords": [[[390.0, 1120.0], [417.0, 1120.0], [414.0, 1309.0], [387.0, 1309.0]], [[357.0, 1120.0], [384.0, 1120.0], [382.0, 1335.0], [356.0, 1335.0]]], "lines": ["じゃ、自分の目で", "ちゃんと見ときな。"]}, {"box": [121, 1271, 179, 1477], "vertical": true, "font_size": 24, "lines_coords": [[[150.0, 1271.0], [176.0, 1271.0], [179.0, 1476.0], [153.0, 1476.0]], [[121.0, 1275.0], [143.0, 1275.0], [143.0, 1434.0], [121.0, 1434.0]]], "lines": ["これでこの景色も", "もう見納めだ。"]}], "img_path": "subarashii_sekai_02_169.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [900, 709, 959, 862], "vertical": true, "font_size": 27, "lines_coords": [[[931.0, 709.0], [959.0, 709.0], [956.0, 851.0], [928.0, 851.0]], [[901.0, 710.0], [925.0, 710.0], [923.0, 862.0], [900.0, 862.0]]], "lines": ["何？これで", "俺は終わり？"]}, {"box": [304, 400, 332, 510], "vertical": true, "font_size": 29, "lines_coords": [[[304.0, 400.0], [332.0, 400.0], [332.0, 510.0], [304.0, 510.0]]], "lines": ["．．．．．．やだ、"]}, {"box": [336, 562, 396, 692], "vertical": true, "font_size": 29, "lines_coords": [[[362.0, 562.0], [396.0, 562.0], [396.0, 645.0], [362.0, 645.0]], [[336.0, 565.0], [362.0, 565.0], [362.0, 692.0], [336.0, 692.0]]], "lines": ["なんか", "いやだ．．．"]}, {"box": [815, 904, 879, 1060], "vertical": true, "font_size": 27, "lines_coords": [[[842.0, 906.0], [876.0, 904.0], [879.0, 1000.0], [845.0, 1001.0]], [[815.0, 907.0], [839.0, 907.0], [840.0, 1060.0], [817.0, 1060.0]]], "lines": ["俺って、", "こんなもん？"]}, {"box": [270, 810, 329, 992], "vertical": true, "font_size": 27, "lines_coords": [[[303.0, 812.0], [329.0, 812.0], [329.0, 954.0], [303.0, 954.0]], [[270.0, 810.0], [296.0, 810.0], [298.0, 992.0], [271.0, 992.0]]], "lines": ["まだ俺、何も", "してねーよ．．．"]}, {"box": [251, 1017, 279, 1120], "vertical": true, "font_size": 27, "lines_coords": [[[251.0, 1017.0], [279.0, 1017.0], [279.0, 1120.0], [251.0, 1120.0]]], "lines": ["やだ．．．"]}, {"box": [806, 1192, 1089, 1590], "vertical": true, "font_size": 266, "lines_coords": [[[823.0, 1192.0], [1089.0, 1204.0], [1072.0, 1557.0], [806.0, 1545.0]]], "lines": ["やだーっ！！"]}, {"box": [195, 1212, 256, 1328], "vertical": true, "font_size": 26, "lines_coords": [[[229.0, 1212.0], [256.0, 1212.0], [256.0, 1321.0], [229.0, 1321.0]], [[195.0, 1212.0], [221.0, 1212.0], [221.0, 1328.0], [195.0, 1328.0]]], "lines": ["ぎゃはは、", "駄目駄目。"]}, {"box": [146, 1309, 176, 1504], "vertical": true, "font_size": 26, "lines_coords": [[[146.0, 1309.0], [173.0, 1309.0], [176.0, 1504.0], [150.0, 1504.0]]], "lines": ["ルールだからよ。"]}], "img_path": "subarashii_sekai_02_170.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [109, 303, 151, 357], "vertical": true, "font_size": 31, "lines_coords": [[[109.0, 310.0], [139.0, 303.0], [151.0, 350.0], [121.0, 357.0]]], "lines": ["あ。"]}, {"box": [878, 1233, 903, 1388], "vertical": true, "font_size": 22, "lines_coords": [[[878.0, 1237.0], [900.0, 1237.0], [900.0, 1385.0], [878.0, 1385.0]]], "lines": ["堀田さん．．．"]}, {"box": [157, 1376, 222, 1481], "vertical": true, "font_size": 28, "lines_coords": [[[193.0, 1378.0], [221.0, 1378.0], [221.0, 1481.0], [193.0, 1481.0]], [[157.0, 1376.0], [185.0, 1376.0], [185.0, 1467.0], [157.0, 1467.0]]], "lines": ["あんたは", "甘ぇよ。"]}], "img_path": "subarashii_sekai_02_171.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [473, 75, 600, 253], "vertical": true, "font_size": 28, "lines_coords": [[[572.0, 76.0], [600.0, 76.0], [600.0, 200.0], [572.0, 200.0]], [[539.0, 76.0], [565.0, 76.0], [565.0, 251.0], [539.0, 251.0]], [[506.0, 76.0], [534.0, 76.0], [534.0, 206.0], [506.0, 206.0]], [[473.0, 75.0], [501.0, 75.0], [501.0, 193.0], [473.0, 193.0]]], "lines": ["「堀田さん", "じゃあ一度だけ", "チャンスを", "あげます」"]}, {"box": [291, 226, 348, 380], "vertical": true, "font_size": 25, "lines_coords": [[[320.0, 228.0], [348.0, 228.0], [348.0, 318.0], [320.0, 318.0]], [[292.0, 226.0], [314.0, 226.0], [314.0, 373.0], [292.0, 373.0]]], "lines": ["いてぇー", "頭いてぇ．．．"]}, {"box": [789, 435, 887, 571], "vertical": true, "font_size": 31, "lines_coords": [[[847.0, 435.0], [887.0, 435.0], [887.0, 520.0], [847.0, 520.0]], [[822.0, 437.0], [848.0, 437.0], [848.0, 571.0], [822.0, 571.0]], [[789.0, 437.0], [817.0, 437.0], [817.0, 539.0], [789.0, 539.0]]], "lines": ["．．．何", "やってんだ、", "俺．．．．．．"]}, {"box": [920, 823, 1013, 1053], "vertical": true, "font_size": 26, "lines_coords": [[[984.0, 825.0], [1011.0, 825.0], [1011.0, 1015.0], [984.0, 1015.0]], [[953.0, 826.0], [979.0, 826.0], [979.0, 953.0], [953.0, 953.0]], [[920.0, 823.0], [947.0, 823.0], [948.0, 1050.0], [922.0, 1050.0]]], "lines": ["そうだ、犬連れの", "ホームレス", "助けようとして．．．"]}, {"box": [484, 1059, 641, 1339], "vertical": true, "font_size": 28, "lines_coords": [[[614.0, 1059.0], [640.0, 1059.0], [636.0, 1276.0], [609.0, 1276.0]], [[579.0, 1060.0], [611.0, 1060.0], [611.0, 1271.0], [579.0, 1271.0]], [[546.0, 1060.0], [573.0, 1060.0], [573.0, 1337.0], [546.0, 1337.0]], [[515.0, 1060.0], [542.0, 1060.0], [542.0, 1339.0], [515.0, 1339.0]], [[484.0, 1062.0], [511.0, 1062.0], [511.0, 1178.0], [484.0, 1178.0]]], "lines": ["「あなたやみんなが", "思っているように、", "この世の中は言うほどに", "素敵なものではないかも", "しれない」"]}, {"box": [346, 990, 407, 1119], "vertical": true, "font_size": 30, "lines_coords": [[[375.0, 990.0], [407.0, 990.0], [407.0, 1073.0], [375.0, 1073.0]], [[346.0, 992.0], [373.0, 992.0], [373.0, 1118.0], [346.0, 1118.0]]], "lines": ["メガネ", "メガネ．．．"]}, {"box": [679, 1239, 769, 1443], "vertical": true, "font_size": 25, "lines_coords": [[[742.0, 1240.0], [768.0, 1240.0], [768.0, 1343.0], [742.0, 1343.0]], [[712.0, 1240.0], [734.0, 1240.0], [734.0, 1443.0], [712.0, 1443.0]], [[679.0, 1239.0], [706.0, 1239.0], [706.0, 1345.0], [679.0, 1345.0]]], "lines": ["中学生に", "しめ落とされたん", "だ．．．．．．"]}, {"box": [230, 1421, 261, 1574], "vertical": true, "font_size": 28, "lines_coords": [[[231.0, 1421.0], [259.0, 1421.0], [259.0, 1573.0], [231.0, 1573.0]]], "lines": ["ぎゃはっ！！"]}], "img_path": "subarashii_sekai_02_172.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [489, 146, 650, 379], "vertical": true, "font_size": 29, "lines_coords": [[[615.0, 146.0], [650.0, 146.0], [650.0, 228.0], [615.0, 228.0]], [[584.0, 150.0], [611.0, 150.0], [611.0, 328.0], [584.0, 328.0]], [[551.0, 151.0], [578.0, 151.0], [578.0, 304.0], [551.0, 304.0]], [[521.0, 150.0], [548.0, 150.0], [548.0, 379.0], [521.0, 379.0]], [[489.0, 151.0], [517.0, 151.0], [517.0, 235.0], [489.0, 235.0]]], "lines": ["「でも、", "見慣れた景色も", "空から見ると", "まるで違って見える", "ように"]}, {"box": [326, 148, 451, 353], "vertical": true, "font_size": 28, "lines_coords": [[[420.0, 150.0], [446.0, 150.0], [450.0, 303.0], [423.0, 303.0]], [[390.0, 151.0], [417.0, 151.0], [417.0, 279.0], [390.0, 279.0]], [[356.0, 148.0], [384.0, 148.0], [386.0, 351.0], [357.0, 351.0]], [[326.0, 150.0], [354.0, 150.0], [354.0, 239.0], [326.0, 239.0]]], "lines": ["雨が降っても", "雲の上には", "青空が広がってる", "ように。"]}, {"box": [132, 149, 289, 343], "vertical": true, "font_size": 26, "lines_coords": [[[260.0, 150.0], [287.0, 150.0], [287.0, 251.0], [260.0, 251.0]], [[231.0, 150.0], [257.0, 150.0], [257.0, 328.0], [231.0, 328.0]], [[200.0, 151.0], [226.0, 151.0], [226.0, 329.0], [200.0, 329.0]], [[167.0, 151.0], [193.0, 151.0], [193.0, 329.0], [167.0, 329.0]], [[135.0, 150.0], [162.0, 150.0], [159.0, 340.0], [132.0, 340.0]]], "lines": ["あなたが", "どう促えるかで", "世界の見え方も", "変わってくると", "思いませんか？」"]}, {"box": [740, 542, 778, 837], "vertical": true, "font_size": 28, "lines_coords": [[[745.0, 685.0], [772.0, 685.0], [772.0, 834.0], [745.0, 834.0]], [[740.0, 542.0], [768.0, 542.0], [768.0, 620.0], [740.0, 620.0]]], "lines": ["いいか．．．．．．", "ま．．．"]}, {"box": [576, 589, 625, 659], "vertical": false, "font_size": 37.5, "lines_coords": [[[595.0, 637.0], [622.0, 637.0], [622.0, 659.0], [595.0, 659.0]], [[576.0, 600.0], [606.0, 589.0], [625.0, 639.0], [595.0, 650.0]]], "lines": ["いっ", "リコリコ"]}, {"box": [492, 556, 654, 757], "vertical": false, "font_size": 37.6, "lines_coords": [[[572.0, 559.0], [654.0, 678.0], [592.0, 721.0], [509.0, 603.0]], [[529.0, 556.0], [582.0, 748.0], [545.0, 757.0], [492.0, 567.0]], [[554.0, 581.0], [601.0, 739.0], [575.0, 748.0], [528.0, 590.0]], [[586.0, 692.0], [634.0, 682.0], [639.0, 706.0], [590.0, 715.0]], [[586.0, 715.0], [640.0, 703.0], [645.0, 725.0], [590.0, 737.0]]], "lines": ["んふふふん．．．ちゃん．", "自ら出ることから", "！！！？！！", "アリコマリコ", "マリュマリコ"]}, {"box": [263, 697, 308, 799], "vertical": true, "font_size": 45, "lines_coords": [[[263.0, 697.0], [308.0, 697.0], [308.0, 799.0], [263.0, 799.0]]], "lines": ["ブログ。"]}, {"box": [648, 923, 709, 1140], "vertical": true, "font_size": 26, "lines_coords": [[[681.0, 923.0], [707.0, 923.0], [704.0, 1090.0], [678.0, 1090.0]], [[648.0, 923.0], [675.0, 923.0], [675.0, 1137.0], [648.0, 1137.0]]], "lines": ["「ああ、なんて", "素晴らしい世界だ"]}, {"box": [523, 923, 584, 1135], "vertical": true, "font_size": 27, "lines_coords": [[[556.0, 923.0], [584.0, 923.0], [579.0, 1103.0], [551.0, 1103.0]], [[525.0, 923.0], [551.0, 923.0], [550.0, 1129.0], [523.0, 1129.0]]], "lines": ["嘘でもいいから", "そう思ってみれば"]}, {"box": [375, 925, 473, 1156], "vertical": true, "font_size": 30, "lines_coords": [[[440.0, 925.0], [468.0, 925.0], [470.0, 1156.0], [442.0, 1156.0]], [[406.0, 925.0], [437.0, 925.0], [440.0, 1067.0], [409.0, 1067.0]], [[375.0, 925.0], [406.0, 925.0], [406.0, 1106.0], [375.0, 1106.0]]], "lines": ["昨日よりちょっとは", "楽しい気分。", "かも、ですよね」"]}], "img_path": "subarashii_sekai_02_173.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [895, 134, 988, 547], "vertical": true, "font_size": 25, "lines_coords": [[[961.0, 134.0], [987.0, 134.0], [986.0, 462.0], [959.0, 462.0]], [[929.0, 139.0], [951.0, 139.0], [951.0, 540.0], [929.0, 540.0]], [[895.0, 135.0], [922.0, 135.0], [923.0, 485.0], [897.0, 485.0]]], "lines": ["「いいこととか悪いこよとか。", "自分はこんなすごいことをしたとか", "なんか、そういうんじゃなくて、"]}, {"box": [650, 110, 682, 203], "vertical": true, "font_size": 32, "lines_coords": [[[650.0, 110.0], [682.0, 110.0], [682.0, 203.0], [650.0, 203.0]]], "lines": ["おっと。"]}, {"box": [715, 300, 740, 528], "vertical": true, "font_size": 22, "lines_coords": [[[715.0, 406.0], [737.0, 406.0], [737.0, 520.0], [715.0, 520.0]]], "lines": ["とにかく」"]}, {"box": [237, 323, 298, 540], "vertical": true, "font_size": 27, "lines_coords": [[[275.0, 326.0], [296.0, 326.0], [296.0, 537.0], [275.0, 537.0]], [[237.0, 323.0], [270.0, 323.0], [270.0, 414.0], [237.0, 414.0]]], "lines": ["「後悔のないように", "生きて。"]}, {"box": [141, 327, 166, 493], "vertical": true, "font_size": 22, "lines_coords": [[[142.0, 328.0], [164.0, 328.0], [164.0, 489.0], [142.0, 489.0]]], "lines": ["それだけです」"]}, {"box": [267, 896, 736, 1150], "vertical": false, "font_size": 185, "lines_coords": [[[296.0, 896.0], [736.0, 967.0], [706.0, 1150.0], [267.0, 1079.0]]], "lines": ["．．．"]}], "img_path": "subarashii_sekai_02_174.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [85, 85, 92, 100], "vertical": true, "font_size": 7, "lines_coords": [[[85.0, 85.0], [92.0, 85.0], [92.0, 100.0], [85.0, 100.0]]], "lines": ["．．．"]}, {"box": [123, 59, 134, 79], "vertical": false, "font_size": 20, "lines_coords": [[[123.0, 59.0], [134.0, 59.0], [134.0, 79.0], [123.0, 79.0]]], "lines": ["．．"]}, {"box": [84, 109, 95, 128], "vertical": false, "font_size": 19, "lines_coords": [[[84.0, 109.0], [95.0, 109.0], [95.0, 128.0], [84.0, 128.0]]], "lines": ["・"]}, {"box": [159, 60, 170, 87], "vertical": true, "font_size": 11, "lines_coords": [[[159.0, 60.0], [170.0, 60.0], [170.0, 87.0], [159.0, 87.0]]], "lines": ["あ．．．"]}, {"box": [121, 100, 157, 278], "vertical": true, "font_size": 16.5, "lines_coords": [[[139.0, 100.0], [156.0, 100.0], [157.0, 228.0], [140.0, 228.0]], [[121.0, 101.0], [137.0, 101.0], [137.0, 278.0], [121.0, 278.0]]], "lines": ["．．．", "．．．．．．"]}, {"box": [235, 62, 245, 76], "vertical": false, "font_size": 14, "lines_coords": [[[235.0, 62.0], [245.0, 62.0], [245.0, 76.0], [235.0, 76.0]]], "lines": ["．．"]}, {"box": [312, 92, 318, 100], "vertical": false, "font_size": 8, "lines_coords": [[[312.0, 92.0], [318.0, 92.0], [318.0, 100.0],