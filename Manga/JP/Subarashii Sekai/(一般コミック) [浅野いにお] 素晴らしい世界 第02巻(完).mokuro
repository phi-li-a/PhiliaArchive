 22, "lines_coords": [[[789.0, 1229.0], [811.0, 1229.0], [809.0, 1357.0], [787.0, 1357.0]]], "lines": ["．．．"]}, {"box": [884, 1215, 895, 1239], "vertical": true, "font_size": 11, "lines_coords": [[[884.0, 1215.0], [895.0, 1215.0], [895.0, 1239.0], [884.0, 1239.0]]], "lines": ["．．"]}], "img_path": "subarashii_sekai_02_048.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [54, 115, 90, 512], "vertical": true, "font_size": 36, "lines_coords": [[[54.0, 115.0], [90.0, 115.0], [90.0, 512.0], [54.0, 512.0]]], "lines": ["１２ｈｈｐｒｏｇｒａｍｐなのが"]}, {"box": [639, 609, 767, 814], "vertical": true, "font_size": 30, "lines_coords": [[[734.0, 609.0], [767.0, 609.0], [767.0, 696.0], [734.0, 696.0]], [[706.0, 610.0], [732.0, 610.0], [732.0, 812.0], [706.0, 812.0]], [[673.0, 612.0], [700.0, 612.0], [700.0, 814.0], [673.0, 814.0]], [[639.0, 610.0], [673.0, 610.0], [673.0, 695.0], [639.0, 695.0]]], "lines": ["先月末、", "雨があがったあと", "大きな虹ができた", "あの日、"]}, {"box": [357, 610, 514, 815], "vertical": true, "font_size": 28, "lines_coords": [[[484.0, 610.0], [511.0, 610.0], [514.0, 765.0], [487.0, 765.0]], [[453.0, 612.0], [484.0, 612.0], [484.0, 815.0], [453.0, 815.0]], [[421.0, 614.0], [448.0, 614.0], [448.0, 740.0], [421.0, 740.0]], [[390.0, 614.0], [417.0, 614.0], [417.0, 764.0], [390.0, 764.0]], [[357.0, 612.0], [384.0, 612.0], [384.0, 750.0], [357.0, 750.0]]], "lines": ["私が通学路に", "使っている公園の", "ゴミ箱から", "女の人の頭が", "見つかった。"]}, {"box": [373, 868, 627, 1083], "vertical": true, "font_size": 28, "lines_coords": [[[598.0, 870.0], [625.0, 870.0], [625.0, 1021.0], [598.0, 1021.0]], [[564.0, 868.0], [590.0, 868.0], [593.0, 1071.0], [567.0, 1071.0]], [[531.0, 871.0], [564.0, 871.0], [564.0, 975.0], [531.0, 975.0]], [[500.0, 871.0], [531.0, 871.0], [531.0, 1050.0], [500.0, 1050.0]], [[471.0, 871.0], [493.0, 871.0], [493.0, 1078.0], [471.0, 1078.0]], [[439.0, 873.0], [465.0, 873.0], [465.0, 1048.0], [439.0, 1048.0]], [[407.0, 870.0], [434.0, 870.0], [432.0, 1050.0], [406.0, 1050.0]], [[373.0, 870.0], [406.0, 870.0], [406.0, 960.0], [373.0, 960.0]]], "lines": ["その女の人は", "高そうなスーツと", "バックの", "いかにも仕事が", "てきる感じの人で、", "私が通学途中に", "よく見かける人", "だった。"]}, {"box": [196, 870, 289, 1074], "vertical": true, "font_size": 28, "lines_coords": [[[260.0, 871.0], [287.0, 871.0], [287.0, 1039.0], [260.0, 1039.0]], [[225.0, 870.0], [256.0, 870.0], [256.0, 1073.0], [225.0, 1073.0]], [[196.0, 875.0], [223.0, 875.0], [223.0, 1059.0], [196.0, 1059.0]]], "lines": ["まぁ、まったく", "関係のない人では", "あるのだけれど、"]}, {"box": [140, 1185, 200, 1427], "vertical": true, "font_size": 27, "lines_coords": [[[171.0, 1185.0], [198.0, 1185.0], [200.0, 1373.0], [173.0, 1373.0]], [[140.0, 1187.0], [167.0, 1187.0], [168.0, 1425.0], [142.0, 1425.0]]], "lines": ["．．．．．なんだろう、", "この心のモヤモヤは"]}], "img_path": "subarashii_sekai_02_049.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [937, 432, 965, 564], "vertical": true, "font_size": 28, "lines_coords": [[[937.0, 432.0], [965.0, 432.0], [965.0, 500.0], [937.0, 500.0]]], "lines": ["あぢー"]}, {"box": [851, 606, 913, 720], "vertical": true, "font_size": 28, "lines_coords": [[[883.0, 606.0], [911.0, 606.0], [911.0, 720.0], [883.0, 720.0]], [[851.0, 606.0], [879.0, 606.0], [879.0, 709.0], [851.0, 709.0]]], "lines": ["てか、宿題", "やった？"]}, {"box": [687, 448, 748, 576], "vertical": true, "font_size": 30, "lines_coords": [[[715.0, 448.0], [748.0, 448.0], [748.0, 531.0], [715.0, 531.0]], [[687.0, 450.0], [714.0, 450.0], [714.0, 576.0], [687.0, 576.0]]], "lines": ["なんか", "臭くねぇ？"]}, {"box": [365, 453, 459, 607], "vertical": true, "font_size": 28, "lines_coords": [[[431.0, 453.0], [459.0, 453.0], [456.0, 606.0], [428.0, 606.0]], [[398.0, 456.0], [426.0, 456.0], [426.0, 582.0], [398.0, 582.0]], [[365.0, 453.0], [393.0, 453.0], [395.0, 607.0], [367.0, 607.0]]], "lines": ["ジャンケンで", "負けたヤツ", "ダッシュで．．．"]}, {"box": [325, 657, 426, 767], "vertical": true, "font_size": 33, "lines_coords": [[[398.0, 664.0], [426.0, 664.0], [426.0, 765.0], [398.0, 765.0]], [[362.0, 662.0], [395.0, 662.0], [395.0, 767.0], [362.0, 767.0]], [[332.0, 657.0], [370.0, 664.0], [362.0, 709.0], [325.0, 703.0]]], "lines": ["ちょっと", "やめてよ", "ねー"]}, {"box": [870, 935, 930, 1173], "vertical": true, "font_size": 27, "lines_coords": [[[901.0, 935.0], [928.0, 935.0], [928.0, 1060.0], [901.0, 1060.0]], [[870.0, 935.0], [897.0, 935.0], [898.0, 1173.0], [872.0, 1173.0]]], "lines": ["今日も私の", "モヤモヤは晴れない。"]}, {"box": [686, 721, 748, 880], "vertical": true, "font_size": 30, "lines_coords": [[[711.0, 723.0], [745.0, 721.0], [748.0, 804.0], [714.0, 806.0]], [[686.0, 725.0], [712.0, 725.0], [712.0, 834.0], [686.0, 834.0]]], "lines": ["午後は", "さぼるか"]}, {"box": [620, 932, 804, 1162], "vertical": true, "font_size": 26, "lines_coords": [[[776.0, 935.0], [804.0, 935.0], [804.0, 1037.0], [776.0, 1037.0]], [[747.0, 935.0], [773.0, 935.0], [773.0, 1162.0], [747.0, 1162.0]], [[715.0, 934.0], [742.0, 934.0], [742.0, 1084.0], [715.0, 1084.0]], [[682.0, 934.0], [709.0, 934.0], [709.0, 1143.0], [682.0, 1143.0]], [[653.0, 934.0], [675.0, 934.0], [675.0, 1157.0], [653.0, 1157.0]], [[620.0, 932.0], [647.0, 932.0], [647.0, 1121.0], [620.0, 1121.0]]], "lines": ["私の顔は", "リアリスムで溢れて", "いる割りには", "感情が出ないから、", "誰にもこの気持ちは", "伝わらないけど、"]}, {"box": [420, 931, 512, 1141], "vertical": true, "font_size": 26, "lines_coords": [[[486.0, 931.0], [512.0, 931.0], [512.0, 1035.0], [486.0, 1035.0]], [[453.0, 932.0], [479.0, 932.0], [479.0, 1056.0], [453.0, 1056.0]], [[421.0, 931.0], [448.0, 931.0], [446.0, 1140.0], [420.0, 1140.0]]], "lines": ["そもそも", "友達らしい", "友達もいないけど"]}, {"box": [125, 746, 193, 877], "vertical": true, "font_size": 34, "lines_coords": [[[153.0, 746.0], [193.0, 746.0], [193.0, 820.0], [153.0, 820.0]], [[125.0, 751.0], [153.0, 751.0], [154.0, 876.0], [126.0, 876.0]]], "lines": ["あっ、", "岡崎来た。"]}, {"box": [187, 929, 345, 1132], "vertical": true, "font_size": 27, "lines_coords": [[[314.0, 929.0], [339.0, 929.0], [343.0, 1132.0], [318.0, 1132.0]], [[282.0, 929.0], [309.0, 929.0], [312.0, 1107.0], [286.0, 1107.0]], [[251.0, 931.0], [279.0, 931.0], [281.0, 1109.0], [253.0, 1109.0]], [[220.0, 934.0], [246.0, 934.0], [250.0, 1067.0], [223.0, 1067.0]], [[187.0, 932.0], [215.0, 932.0], [220.0, 1114.0], [192.0, 1114.0]]], "lines": ["クラスのみんなが", "陰で私のことを", "「能面」と呼んで", "いることを、", "私は知っている"]}, {"box": [361, 1195, 390, 1361], "vertical": true, "font_size": 22, "lines_coords": [[[370.0, 1307.0], [387.0, 1307.0], [387.0, 1356.0], [370.0, 1356.0]], [[361.0, 1195.0], [389.0, 1195.0], [389.0, 1298.0], [361.0, 1298.0]]], "lines": ["ーっ", "おはよー"]}, {"box": [184, 1287, 283, 1507], "vertical": true, "font_size": 25, "lines_coords": [[[245.0, 1287.0], [276.0, 1287.0], [273.0, 1507.0], [242.0, 1507.0]], [[217.0, 1292.0], [239.0, 1292.0], [239.0, 1504.0], [217.0, 1504.0]], [[184.0, 1292.0], [206.0, 1292.0], [206.0, 1442.0], [184.0, 1442.0]]], "lines": ["岡崎、遅えって．．．", "おはようって、もう", "昼休みだぜ？"]}], "img_path": "subarashii_sekai_02_050.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [784, 620, 901, 751], "vertical": true, "font_size": 31, "lines_coords": [[[872.0, 623.0], [900.0, 623.0], [900.0, 734.0], [872.0, 734.0]], [[836.0, 620.0], [873.0, 620.0], [873.0, 679.0], [836.0, 679.0]], [[809.0, 621.0], [837.0, 623.0], [832.0, 750.0], [804.0, 748.0]]], "lines": ["なんだよ、", "あの", "つくり笑顔"]}, {"box": [440, 370, 471, 554], "vertical": true, "font_size": 31, "lines_coords": [[[440.0, 370.0], [471.0, 370.0], [471.0, 553.0], [440.0, 553.0]]], "lines": ["岡崎サト．．．"]}, {"box": [209, 623, 267, 739], "vertical": true, "font_size": 28, "lines_coords": [[[240.0, 623.0], [267.0, 623.0], [267.0, 728.0], [240.0, 728.0]], [[209.0, 625.0], [237.0, 625.0], [237.0, 735.0], [209.0, 735.0]]], "lines": ["．．．．．．", "むかつく"]}, {"box": [628, 846, 997, 878], "vertical": false, "font_size": 32, "lines_coords": [[[628.0, 846.0], [997.0, 846.0], [997.0, 878.0], [628.0, 878.0]]], "lines": ["２ｔｈ．ｐｒｏｇｒａｍ，砂の城"]}, {"box": [892, 1360, 942, 1403], "vertical": false, "font_size": 43, "lines_coords": [[[892.0, 1360.0], [942.0, 1360.0], [942.0, 1403.0], [892.0, 1403.0]]], "lines": ["．．．"]}, {"box": [220, 1348, 789, 1460], "vertical": false, "font_size": 91, "lines_coords": [[[223.0, 1348.0], [789.0, 1370.0], [786.0, 1460.0], [220.0, 1439.0]]], "lines": ["素晴らしいぜ"]}, {"box": [225, 1160, 264, 1289], "vertical": true, "font_size": 39, "lines_coords": [[[225.0, 1160.0], [264.0, 1160.0], [264.0, 1284.0], [225.0, 1284.0]]], "lines": ["暑．．．．．．"]}], "img_path": "subarashii_sekai_02_051.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [918, 110, 1008, 313], "vertical": true, "font_size": 25, "lines_coords": [[[981.0, 112.0], [1008.0, 112.0], [1004.0, 239.0], [978.0, 239.0]], [[948.0, 110.0], [975.0, 110.0], [976.0, 290.0], [950.0, 290.0]], [[918.0, 110.0], [940.0, 110.0], [940.0, 309.0], [918.0, 309.0]]], "lines": ["別れた男が", "嫉妬にくるって", "とうのこうのって。"]}, {"box": [776, 256, 839, 371], "vertical": true, "font_size": 28, "lines_coords": [[[807.0, 256.0], [836.0, 256.0], [839.0, 368.0], [811.0, 368.0]], [[776.0, 257.0], [804.0, 257.0], [806.0, 371.0], [778.0, 371.0]]], "lines": ["あっらぁ、", "怖いわぁ。"]}, {"box": [286, 134, 405, 310], "vertical": true, "font_size": 25, "lines_coords": [[[378.0, 135.0], [404.0, 135.0], [404.0, 287.0], [378.0, 287.0]], [[343.0, 134.0], [370.0, 134.0], [373.0, 287.0], [346.0, 287.0]], [[312.0, 134.0], [339.0, 134.0], [340.0, 310.0], [314.0, 310.0]], [[286.0, 137.0], [307.0, 137.0], [307.0, 159.0], [286.0, 159.0]]], "lines": ["最近この辺も", "おかしな人が", "増えたじゃない", "？"]}, {"box": [107, 79, 243, 225], "vertical": true, "font_size": 61, "lines_coords": [[[170.0, 84.0], [235.0, 79.0], [243.0, 200.0], [178.0, 204.0]], [[107.0, 131.0], [164.0, 118.0], [184.0, 212.0], [128.0, 225.0]]], "lines": ["ここっ", "ミン"]}, {"box": [182, 320, 304, 500], "vertical": true, "font_size": 27, "lines_coords": [[[271.0, 321.0], [304.0, 321.0], [304.0, 406.0], [271.0, 406.0]], [[242.0, 320.0], [268.0, 320.0], [268.0, 500.0], [242.0, 500.0]], [[209.0, 320.0], [235.0, 320.0], [239.0, 476.0], [212.0, 476.0]], [[182.0, 323.0], [203.0, 323.0], [203.0, 482.0], [182.0, 482.0]]], "lines": ["あたし、", "テレビ局の人に", "インタビュー", "されちゃった。"]}, {"box": [841, 901, 994, 1154], "vertical": true, "font_size": 26, "lines_coords": [[[965.0, 901.0], [992.0, 901.0], [993.0, 1078.0], [967.0, 1078.0]], [[931.0, 901.0], [962.0, 901.0], [965.0, 1103.0], [934.0, 1103.0]], [[906.0, 903.0], [928.0, 903.0], [928.0, 1035.0], [906.0, 1035.0]], [[870.0, 901.0], [897.0, 901.0], [898.0, 1151.0], [872.0, 1151.0]], [[843.0, 903.0], [865.0, 903.0], [865.0, 1085.0], [843.0, 1085.0]]], "lines": ["今やこの公園は", "例の事件の話題で", "もちきりて、", "ヒマなオバサン連中の", "たまり場だった。"]}, {"box": [339, 917, 372, 1070], "vertical": true, "font_size": 32, "lines_coords": [[[339.0, 917.0], [371.0, 917.0], [371.0, 1070.0], [339.0, 1070.0]]], "lines": ["岡崎．．．．．？"]}, {"box": [759, 1298, 852, 1553], "vertical": true, "font_size": 25, "lines_coords": [[[826.0, 1303.0], [848.0, 1303.0], [848.0, 1510.0], [826.0, 1510.0]], [[793.0, 1303.0], [820.0, 1303.0], [820.0, 1553.0], [793.0, 1553.0]], [[762.0, 1298.0], [789.0, 1298.0], [786.0, 1429.0], [759.0, 1429.0]]], "lines": ["う．．．終わってるわ。", "人が死ぬのがそんなに", "楽しいか？"]}], "img_path": "subarashii_sekai_02_052.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [909, 106, 953, 190], "vertical": true, "font_size": 41, "lines_coords": [[[909.0, 107.0], [950.0, 106.0], [953.0, 189.0], [912.0, 190.0]]], "lines": ["えっ。"]}, {"box": [195, 292, 228, 385], "vertical": true, "font_size": 28, "lines_coords": [[[195.0, 292.0], [228.0, 292.0], [228.0, 385.0], [195.0, 385.0]]], "lines": ["サト！"]}, {"box": [135, 442, 257, 645], "vertical": true, "font_size": 28, "lines_coords": [[[229.0, 442.0], [256.0, 442.0], [257.0, 645.0], [231.0, 645.0]], [[200.0, 443.0], [226.0, 443.0], [226.0, 545.0], [200.0, 545.0]], [[168.0, 443.0], [195.0, 443.0], [195.0, 592.0], [168.0, 592.0]], [[135.0, 442.0], [164.0, 442.0], [164.0, 543.0], [135.0, 543.0]]], "lines": ["あんたいつまでも", "メソメソ", "泣いてんじゃ", "ないよ！"]}, {"box": [376, 1100, 440, 1229], "vertical": true, "font_size": 28, "lines_coords": [[[406.0, 1100.0], [440.0, 1100.0], [440.0, 1184.0], [406.0, 1184.0]], [[376.0, 1100.0], [404.0, 1100.0], [406.0, 1229.0], [378.0, 1229.0]]], "lines": ["こっち", "おいでっ！"]}, {"box": [323, 879, 418, 1059], "vertical": true, "font_size": 28, "lines_coords": [[[382.0, 881.0], [415.0, 879.0], [418.0, 970.0], [386.0, 971.0]], [[354.0, 882.0], [381.0, 882.0], [381.0, 1059.0], [354.0, 1059.0]], [[326.0, 882.0], [346.0, 882.0], [343.0, 1032.0], [323.0, 1032.0]]], "lines": ["ほらっ、", "あたしが遊んで", "あけるから！"]}, {"box": [934, 1226, 959, 1390], "vertical": true, "font_size": 22, "lines_coords": [[[934.0, 1229.0], [956.0, 1229.0], [958.0, 1384.0], [936.0, 1384.0]]], "lines": ["．．．．．そうだよ"]}, {"box": [687, 1223, 845, 1413], "vertical": true, "font_size": 28, "lines_coords": [[[815.0, 1226.0], [843.0, 1226.0], [845.0, 1356.0], [817.0, 1356.0]], [[784.0, 1226.0], [812.0, 1226.0], [812.0, 1354.0], [784.0, 1354.0]], [[750.0, 1223.0], [782.0, 1223.0], [779.0, 1381.0], [747.0, 1381.0]], [[720.0, 1225.0], [748.0, 1225.0], [745.0, 1381.0], [717.0, 1381.0]], [[689.0, 1226.0], [715.0, 1226.0], [714.0, 1410.0], [687.0, 1410.0]]], "lines": ["私にとって", "この公園は", "サトと二人で", "昔よく遊んだ", "公園なんだから、"]}, {"box": [137, 1218, 295, 1471], "vertical": true, "font_size": 29, "lines_coords": [[[264.0, 1220.0], [290.0, 1220.0], [295.0, 1459.0], [268.0, 1459.0]], [[232.0, 1218.0], [264.0, 1218.0], [264.0, 1400.0], [232.0, 1400.0]], [[198.0, 1220.0], [229.0, 1220.0], [232.0, 1381.0], [201.0, 1381.0]], [[167.0, 1220.0], [195.0, 1220.0], [198.0, 1448.0], [170.0, 1448.0]], [[137.0, 1221.0], [164.0, 1221.0], [164.0, 1471.0], [137.0, 1471.0]]], "lines": ["どのみち、この公園も", "今年いっぱいで", "取り壊されて、", "市営のマンションが", "建つらしいけどさ．．．"]}], "img_path": "subarashii_sekai_02_053.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [870, 215, 928, 328], "vertical": true, "font_size"