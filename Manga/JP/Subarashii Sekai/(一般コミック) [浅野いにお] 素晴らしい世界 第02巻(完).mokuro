, "lines": ["何？おまえ、"]}, {"box": [218, 623, 312, 803], "vertical": true, "font_size": 27, "lines_coords": [[[284.0, 623.0], [312.0, 623.0], [309.0, 803.0], [281.0, 803.0]], [[251.0, 626.0], [278.0, 626.0], [278.0, 753.0], [251.0, 753.0]], [[221.0, 623.0], [248.0, 623.0], [245.0, 779.0], [218.0, 779.0]]], "lines": ["思春期のガキの", "標的にされ", "ちゃった系？"]}, {"box": [926, 862, 1020, 1028], "vertical": true, "font_size": 28, "lines_coords": [[[990.0, 862.0], [1017.0, 862.0], [1020.0, 993.0], [993.0, 993.0]], [[959.0, 862.0], [987.0, 862.0], [989.0, 1026.0], [961.0, 1026.0]], [[926.0, 862.0], [954.0, 862.0], [956.0, 1026.0], [928.0, 1026.0]]], "lines": ["ははは．．．", "しょうがねぇ、", "しょうがねぇ。"]}, {"box": [536, 1029, 606, 1306], "vertical": true, "font_size": 30, "lines_coords": [[[568.0, 1029.0], [606.0, 1029.0], [606.0, 1089.0], [568.0, 1089.0]], [[567.0, 1176.0], [593.0, 1176.0], [597.0, 1306.0], [570.0, 1306.0]], [[536.0, 1175.0], [562.0, 1175.0], [565.0, 1295.0], [539.0, 1295.0]]], "lines": ["ん？", "そんな目で", "見んなよ。"]}, {"box": [686, 1265, 809, 1481], "vertical": true, "font_size": 24, "lines_coords": [[[781.0, 1267.0], [807.0, 1267.0], [807.0, 1481.0], [781.0, 1481.0]], [[750.0, 1265.0], [776.0, 1265.0], [776.0, 1420.0], [750.0, 1420.0]], [[717.0, 1267.0], [740.0, 1267.0], [742.0, 1468.0], [718.0, 1468.0]], [[686.0, 1267.0], [707.0, 1267.0], [711.0, 1429.0], [689.0, 1429.0]]], "lines": ["おまえ、見るからに", "不幸背負って", "生まれてきたって", "感じだもんな。"]}, {"box": [132, 1307, 225, 1472], "vertical": true, "font_size": 27, "lines_coords": [[[198.0, 1309.0], [225.0, 1309.0], [225.0, 1462.0], [198.0, 1462.0]], [[165.0, 1309.0], [192.0, 1309.0], [192.0, 1462.0], [165.0, 1462.0]], [[132.0, 1307.0], [159.0, 1307.0], [162.0, 1471.0], [135.0, 1471.0]]], "lines": ["俺はおまえを", "助けるなんて", "言ってねぇよ。"]}], "img_path": "subarashii_sekai_02_128.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [862, 121, 958, 281], "vertical": true, "font_size": 28, "lines_coords": [[[931.0, 126.0], [958.0, 126.0], [958.0, 281.0], [931.0, 281.0]], [[901.0, 126.0], [923.0, 126.0], [923.0, 278.0], [901.0, 278.0]], [[862.0, 123.0], [897.0, 121.0], [900.0, 193.0], [865.0, 195.0]]], "lines": ["悪いが俺には", "そんな余裕は", "ねぇ。"]}, {"box": [175, 146, 266, 366], "vertical": true, "font_size": 28, "lines_coords": [[[237.0, 151.0], [264.0, 151.0], [264.0, 329.0], [237.0, 329.0]], [[201.0, 148.0], [235.0, 146.0], [239.0, 243.0], [204.0, 245.0]], [[175.0, 151.0], [198.0, 151.0], [200.0, 364.0], [176.0, 364.0]]], "lines": ["運が悪かったと", "思って、", "野垂れ死んでくれ。"]}, {"box": [878, 500, 908, 652], "vertical": true, "font_size": 26, "lines_coords": [[[878.0, 501.0], [904.0, 501.0], [904.0, 651.0], [878.0, 651.0]]], "lines": ["ドゥフッ！！"]}, {"box": [182, 696, 215, 803], "vertical": true, "font_size": 33, "lines_coords": [[[182.0, 696.0], [215.0, 696.0], [215.0, 803.0], [182.0, 803.0]]], "lines": ["諦めろ。"]}, {"box": [781, 885, 811, 1119], "vertical": true, "font_size": 26, "lines_coords": [[[784.0, 885.0], [811.0, 885.0], [807.0, 1064.0], [781.0, 1064.0]]], "lines": ["例えば俺の場合"]}, {"box": [593, 884, 765, 1114], "vertical": true, "font_size": 24, "lines_coords": [[[718.0, 885.0], [745.0, 885.0], [742.0, 1039.0], [715.0, 1039.0]], [[687.0, 885.0], [714.0, 885.0], [714.0, 1075.0], [687.0, 1075.0]], [[656.0, 885.0], [678.0, 885.0], [678.0, 1085.0], [656.0, 1085.0]], [[622.0, 887.0], [645.0, 887.0], [647.0, 1110.0], [623.0, 1110.0]], [[593.0, 887.0], [615.0, 887.0], [615.0, 1087.0], [593.0, 1087.0]]], "lines": ["自分が物語の", "主人公ではなく、", "その他大勢の中の", "ひとりでしかないと", "気付いてから．．．"]}, {"box": [311, 881, 501, 1114], "vertical": true, "font_size": 29, "lines_coords": [[[473.0, 885.0], [500.0, 885.0], [496.0, 1114.0], [470.0, 1114.0]], [[442.0, 887.0], [468.0, 887.0], [465.0, 1062.0], [439.0, 1062.0]], [[406.0, 885.0], [439.0, 885.0], [439.0, 1000.0], [406.0, 1000.0]], [[376.0, 887.0], [403.0, 887.0], [403.0, 1062.0], [376.0, 1062.0]], [[345.0, 887.0], [371.0, 887.0], [371.0, 1062.0], [345.0, 1062.0]], [[311.0, 881.0], [345.0, 881.0], [345.0, 950.0], [311.0, 950.0]]], "lines": ["決して思いとおりに", "なってくれない", "世の中を、", "受け入れられる", "ようになったと", "思う"]}], "img_path": "subarashii_sekai_02_129.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [529, 137, 617, 345], "vertical": true, "font_size": 23, "lines_coords": [[[595.0, 139.0], [617.0, 139.0], [617.0, 337.0], [595.0, 337.0]], [[561.0, 137.0], [587.0, 137.0], [587.0, 250.0], [561.0, 250.0]], [[529.0, 139.0], [551.0, 139.0], [551.0, 335.0], [529.0, 335.0]]], "lines": ["フリーターになり", "もう３年", "孤独で退屈な毎日"]}, {"box": [446, 415, 471, 615], "vertical": true, "font_size": 22, "lines_coords": [[[446.0, 417.0], [468.0, 417.0], [468.0, 612.0], [446.0, 612.0]]], "lines": ["でも、もう慣れた"]}, {"box": [267, 860, 353, 1166], "vertical": true, "font_size": 20, "lines_coords": [[[329.0, 862.0], [351.0, 862.0], [351.0, 1117.0], [329.0, 1117.0]], [[298.0, 864.0], [320.0, 864.0], [320.0, 1160.0], [298.0, 1160.0]], [[267.0, 862.0], [284.0, 862.0], [284.0, 962.0], [267.0, 962.0]]], "lines": ["見えない大きな力とか", "弱者が徹底的に淘汰される", "流れとか"]}, {"box": [185, 1109, 206, 1310], "vertical": true, "font_size": 21, "lines_coords": [[[185.0, 1109.0], [206.0, 1109.0], [206.0, 1310.0], [185.0, 1310.0]]], "lines": ["理不尽とか矛盾も"]}, {"box": [121, 1108, 145, 1394], "vertical": true, "font_size": 20, "lines_coords": [[[123.0, 1110.0], [143.0, 1110.0], [143.0, 1389.0], [123.0, 1389.0]]], "lines": ["受け入れるようになった"]}], "img_path": "subarashii_sekai_02_130.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [354, 96, 512, 303], "vertical": true, "font_size": 27, "lines_coords": [[[486.0, 101.0], [512.0, 101.0], [512.0, 301.0], [486.0, 301.0]], [[453.0, 96.0], [484.0, 98.0], [476.0, 303.0], [445.0, 301.0]], [[418.0, 100.0], [446.0, 100.0], [446.0, 214.0], [418.0, 214.0]], [[390.0, 103.0], [412.0, 103.0], [412.0, 300.0], [390.0, 300.0]], [[357.0, 100.0], [386.0, 100.0], [382.0, 209.0], [354.0, 209.0]]], "lines": ["すべての出来事は", "「しょーがない」の", "ひと言って、", "解決できるのかも", "しれない"]}, {"box": [686, 967, 776, 1120], "vertical": true, "font_size": 26, "lines_coords": [[[748.0, 967.0], [775.0, 967.0], [775.0, 1117.0], [748.0, 1117.0]], [[717.0, 968.0], [743.0, 968.0], [743.0, 1093.0], [717.0, 1093.0]], [[686.0, 967.0], [712.0, 967.0], [712.0, 1093.0], [686.0, 1093.0]]], "lines": ["それに退屈な", "毎日だって", "ホラッ．．．．．"]}, {"box": [562, 965, 592, 1210], "vertical": true, "font_size": 27, "lines_coords": [[[562.0, 967.0], [589.0, 967.0], [592.0, 1206.0], [565.0, 1206.0]]], "lines": ["言いようによっちゃ、"]}, {"box": [364, 964, 487, 1143], "vertical": true, "font_size": 30, "lines_coords": [[[459.0, 967.0], [486.0, 967.0], [486.0, 1143.0], [459.0, 1143.0]], [[423.0, 964.0], [461.0, 964.0], [461.0, 1021.0], [423.0, 1021.0]], [[393.0, 965.0], [420.0, 965.0], [420.0, 1092.0], [393.0, 1092.0]], [[364.0, 967.0], [390.0, 967.0], [390.0, 1100.0], [364.0, 1100.0]]], "lines": ["怒りも悲しみも", "ない", "平和な毎日", "じゃないか"]}, {"box": [140, 1316, 169, 1500], "vertical": true, "font_size": 27, "lines_coords": [[[140.0, 1329.0], [167.0, 1329.0], [167.0, 1498.0], [140.0, 1498.0]]], "lines": ["．．．ねえ．．．．．"]}], "img_path": "subarashii_sekai_02_131.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [939, 146, 1004, 326], "vertical": true, "font_size": 26, "lines_coords": [[[976.0, 148.0], [1003.0, 148.0], [1003.0, 326.0], [976.0, 326.0]], [[939.0, 148.0], [965.0, 148.0], [965.0, 296.0], [939.0, 296.0]]], "lines": ["あたしのこと", "愛してる？"]}, {"box": [840, 560, 865, 710], "vertical": true, "font_size": 22, "lines_coords": [[[840.0, 560.0], [862.0, 560.0], [862.0, 698.0], [840.0, 698.0]]], "lines": ["「愛してるよ"]}, {"box": [748, 556, 779, 688], "vertical": true, "font_size": 27, "lines_coords": [[[751.0, 556.0], [778.0, 556.0], [775.0, 685.0], [748.0, 685.0]]], "lines": ["「本当に？」"]}, {"box": [676, 556, 708, 670], "vertical": true, "font_size": 28, "lines_coords": [[[676.0, 557.0], [704.0, 557.0], [704.0, 659.0], [676.0, 659.0]]], "lines": ["「本当に」"]}, {"box": [548, 555, 609, 784], "vertical": true, "font_size": 24, "lines_coords": [[[584.0, 560.0], [606.0, 560.0], [606.0, 781.0], [584.0, 781.0]], [[548.0, 559.0], [575.0, 559.0], [575.0, 721.0], [548.0, 721.0]]], "lines": ["「あたしたち、ずっと", "一緒だよね？」"]}, {"box": [453, 557, 481, 762], "vertical": true, "font_size": 26, "lines_coords": [[[454.0, 559.0], [481.0, 559.0], [479.0, 762.0], [453.0, 762.0]]], "lines": ["「すっと一緒だよ」"]}, {"box": [250, 559, 342, 738], "vertical": true, "font_size": 31, "lines_coords": [[[309.0, 559.0], [342.0, 559.0], [342.0, 650.0], [309.0, 650.0]], [[278.0, 565.0], [311.0, 565.0], [311.0, 651.0], [278.0, 651.0]], [[250.0, 567.0], [276.0, 567.0], [276.0, 718.0], [250.0, 718.0]]], "lines": ["「ずっと", "ずっと", "ずっと．．．．．．"]}], "img_path": "subarashii_sekai_02_132.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [112, 515, 207, 694], "vertical": true, "font_size": 29, "lines_coords": [[[179.0, 517.0], [206.0, 517.0], [206.0, 693.0], [179.0, 693.0]], [[139.0, 517.0], [171.0, 515.0], [176.0, 617.0], [143.0, 618.0]], [[112.0, 515.0], [140.0, 515.0], [143.0, 628.0], [115.0, 628.0]]], "lines": ["別れた女の夢で", "夢精する", "２５歳の冬、"]}], "img_path": "subarashii_sekai_02_133.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [267, 696, 300, 804], "vertical": true, "font_size": 33, "lines_coords": [[[267.0, 696.0], [300.0, 696.0], [300.0, 804.0], [267.0, 804.0]]], "lines": ["あ．．．．．．"]}], "img_path": "subarashii_sekai_02_134.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [493, 429, 584, 743], "vertical": true, "font_size": 26, "lines_coords": [[[554.0, 429.0], [582.0, 429.0], [582.0, 542.0], [554.0, 542.0]], [[521.0, 431.0], [548.0, 431.0], [551.0, 615.0], [525.0, 615.0]], [[493.0, 431.0], [515.0, 431.0], [515.0, 735.0], [493.0, 735.0]]], "lines": ["待て待て", "いまさら会って、", "どうしようっていうんだよ"]}, {"box": [267, 514, 392, 609], "vertical": false, "font_size": 43.25, "lines_coords": [[[328.0, 525.0]