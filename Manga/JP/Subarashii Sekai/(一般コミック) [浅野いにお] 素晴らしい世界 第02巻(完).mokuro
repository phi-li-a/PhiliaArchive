.0], [682.0, 906.0], [682.0, 1035.0], [654.0, 1035.0]]], "lines": ["早いね．．．"]}, {"box": [179, 857, 245, 968], "vertical": true, "font_size": 32, "lines_coords": [[[200.0, 859.0], [242.0, 857.0], [245.0, 932.0], [203.0, 934.0]], [[179.0, 865.0], [206.0, 865.0], [206.0, 968.0], [179.0, 968.0]]], "lines": ["あっ、", "野良犬！！"]}, {"box": [101, 998, 165, 1160], "vertical": true, "font_size": 32, "lines_coords": [[[129.0, 998.0], [160.0, 998.0], [165.0, 1160.0], [134.0, 1160.0]], [[101.0, 1000.0], [128.0, 1000.0], [128.0, 1104.0], [101.0, 1104.0]]], "lines": ["危ないですよ、", "キング！！"]}], "img_path": "subarashii_sekai_02_184.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [457, 137, 490, 231], "vertical": true, "font_size": 33, "lines_coords": [[[457.0, 137.0], [490.0, 137.0], [490.0, 231.0], [457.0, 231.0]]], "lines": ["ははっ。"]}, {"box": [98, 471, 129, 585], "vertical": true, "font_size": 28, "lines_coords": [[[98.0, 471.0], [126.0, 471.0], [129.0, 585.0], [101.0, 585.0]]], "lines": ["かわいい。"]}, {"box": [650, 961, 679, 1126], "vertical": true, "font_size": 26, "lines_coords": [[[650.0, 965.0], [676.0, 965.0], [679.0, 1123.0], [653.0, 1123.0]]], "lines": ["．．．．．よかった"]}, {"box": [448, 960, 540, 1139], "vertical": true, "font_size": 29, "lines_coords": [[[517.0, 965.0], [539.0, 965.0], [539.0, 1137.0], [517.0, 1137.0]], [[479.0, 960.0], [512.0, 960.0], [512.0, 1067.0], [479.0, 1067.0]], [[448.0, 960.0], [481.0, 960.0], [481.0, 1051.0], [448.0, 1051.0]]], "lines": ["今日もどうにか", "この街は", "平和だ"]}, {"box": [868, 1190, 911, 1289], "vertical": true, "font_size": 32, "lines_coords": [[[868.0, 1192.0], [908.0, 1190.0], [911.0, 1287.0], [872.0, 1289.0]]], "lines": ["やべっ。"]}, {"box": [759, 1270, 822, 1434], "vertical": true, "font_size": 32, "lines_coords": [[[793.0, 1271.0], [822.0, 1271.0], [822.0, 1398.0], [793.0, 1398.0]], [[759.0, 1270.0], [786.0, 1270.0], [789.0, 1434.0], [762.0, 1434.0]]], "lines": ["紅ショウガ", "もらい忘れた。"]}, {"box": [370, 1248, 429, 1387], "vertical": true, "font_size": 26, "lines_coords": [[[401.0, 1250.0], [428.0, 1250.0], [428.0, 1289.0], [401.0, 1289.0]], [[370.0, 1250.0], [396.0, 1250.0], [396.0, 1385.0], [370.0, 1385.0]]], "lines": ["えー", "いいよ別に。"]}, {"box": [146, 1312, 243, 1520], "vertical": true, "font_size": 33, "lines_coords": [[[200.0, 1314.0], [240.0, 1312.0], [243.0, 1407.0], [203.0, 1409.0]], [[173.0, 1315.0], [206.0, 1315.0], [209.0, 1445.0], [176.0, 1445.0]], [[146.0, 1318.0], [173.0, 1318.0], [173.0, 1520.0], [146.0, 1520.0]]], "lines": ["ややや、", "ダッシュで", "取ってくるから！！"]}], "img_path": "subarashii_sekai_02_185.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [933, 170, 1059, 350], "vertical": true, "font_size": 29, "lines_coords": [[[1033.0, 171.0], [1059.0, 171.0], [1056.0, 323.0], [1029.0, 323.0]], [[1000.0, 173.0], [1026.0, 173.0], [1026.0, 312.0], [1000.0, 312.0]], [[967.0, 171.0], [998.0, 171.0], [998.0, 350.0], [967.0, 350.0]], [[933.0, 170.0], [967.0, 170.0], [967.0, 262.0], [933.0, 262.0]]], "lines": ["冷めるとアレ", "だから、先に", "食べちゃってて", "いいし。"]}, {"box": [625, 135, 656, 291], "vertical": true, "font_size": 28, "lines_coords": [[[625.0, 137.0], [653.0, 135.0], [656.0, 206.0], [628.0, 207.0]]], "lines": ["もぉー"]}, {"box": [139, 448, 203, 679], "vertical": true, "font_size": 26, "lines_coords": [[[171.0, 450.0], [198.0, 450.0], [203.0, 653.0], [176.0, 653.0]], [[139.0, 448.0], [165.0, 448.0], [168.0, 678.0], [142.0, 678.0]]], "lines": ["ひとりで食べても", "おいしくないよ．．．"]}, {"box": [929, 811, 959, 901], "vertical": true, "font_size": 30, "lines_coords": [[[929.0, 842.0], [959.0, 842.0], [959.0, 900.0], [929.0, 900.0]]], "lines": ["あ。"]}, {"box": [567, 971, 664, 1125], "vertical": true, "font_size": 30, "lines_coords": [[[628.0, 973.0], [661.0, 971.0], [664.0, 1075.0], [631.0, 1076.0]], [[598.0, 971.0], [625.0, 971.0], [628.0, 1125.0], [601.0, 1125.0]], [[567.0, 971.0], [595.0, 971.0], [597.0, 1082.0], [568.0, 1082.0]]], "lines": ["食べる？", "あたしの分で", "よければ"]}, {"box": [453, 1178, 484, 1328], "vertical": true, "font_size": 27, "lines_coords": [[[453.0, 1178.0], [481.0, 1178.0], [484.0, 1328.0], [456.0, 1328.0]]], "lines": ["あ、ダメかぁ、"]}, {"box": [364, 1273, 421, 1501], "vertical": true, "font_size": 27, "lines_coords": [[[393.0, 1273.0], [421.0, 1273.0], [421.0, 1378.0], [393.0, 1378.0]], [[364.0, 1275.0], [390.0, 1275.0], [390.0, 1501.0], [364.0, 1501.0]]], "lines": ["タマネギ", "入ってるもんね．．．"]}], "img_path": "subarashii_sekai_02_186.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [145, 403, 174, 606], "vertical": true, "font_size": 22, "lines_coords": [[[145.0, 437.0], [167.0, 437.0], [168.0, 601.0], [146.0, 601.0]]], "lines": ["．．．こんにちは"]}, {"box": [940, 721, 1034, 935], "vertical": true, "font_size": 27, "lines_coords": [[[1006.0, 723.0], [1033.0, 723.0], [1033.0, 839.0], [1006.0, 839.0]], [[975.0, 725.0], [1001.0, 725.0], [1001.0, 850.0], [975.0, 850.0]], [[943.0, 721.0], [970.0, 721.0], [967.0, 935.0], [940.0, 935.0]]], "lines": ["「あなたは", "とても心が", "やさしい人ですね」"]}, {"box": [203, 988, 226, 1088], "vertical": true, "font_size": 23, "lines_coords": [[[203.0, 1031.0], [226.0, 1031.0], [226.0, 1087.0], [203.0, 1087.0]]], "lines": ["え？"]}, {"box": [937, 1153, 1000, 1331], "vertical": true, "font_size": 29, "lines_coords": [[[973.0, 1154.0], [1000.0, 1154.0], [1000.0, 1331.0], [973.0, 1331.0]], [[937.0, 1153.0], [965.0, 1153.0], [967.0, 1265.0], [939.0, 1265.0]]], "lines": ["「そしてとても", "幸せそう。"]}, {"box": [812, 1314, 940, 1470], "vertical": true, "font_size": 29, "lines_coords": [[[904.0, 1314.0], [940.0, 1314.0], [940.0, 1379.0], [904.0, 1379.0]], [[876.0, 1317.0], [903.0, 1317.0], [903.0, 1453.0], [876.0, 1453.0]], [[843.0, 1318.0], [870.0, 1318.0], [870.0, 1470.0], [843.0, 1470.0]], [[812.0, 1317.0], [839.0, 1317.0], [839.0, 1432.0], [812.0, 1432.0]]], "lines": ["でも、", "なぜだろう。", "大きな不安も", "抱えてる」"]}, {"box": [100, 1307, 224, 1485], "vertical": true, "font_size": 29, "lines_coords": [[[196.0, 1310.0], [223.0, 1310.0], [223.0, 1425.0], [196.0, 1425.0]], [[165.0, 1312.0], [192.0, 1312.0], [192.0, 1485.0], [165.0, 1485.0]], [[126.0, 1307.0], [165.0, 1307.0], [165.0, 1393.0], [126.0, 1393.0]], [[101.0, 1312.0], [125.0, 1312.0], [123.0, 1475.0], [100.0, 1475.0]]], "lines": ["「私に何か", "してあげられる", "ことは", "ないかしら？」"]}], "img_path": "subarashii_sekai_02_187.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [992, 140, 1021, 317], "vertical": true, "font_size": 26, "lines_coords": [[[993.0, 140.0], [1020.0, 140.0], [1018.0, 317.0], [992.0, 317.0]]], "lines": ["あなた．．．．．．誰？"]}, {"box": [578, 132, 674, 360], "vertical": true, "font_size": 26, "lines_coords": [[[647.0, 134.0], [673.0, 134.0], [672.0, 360.0], [645.0, 360.0]], [[614.0, 132.0], [640.0, 132.0], [637.0, 337.0], [611.0, 337.0]], [[582.0, 132.0], [609.0, 132.0], [604.0, 350.0], [578.0, 350.0]]], "lines": ["「私にもわからない。", "神様と呼ばれたり", "死神と呼ばれたり」"]}, {"box": [96, 185, 221, 412], "vertical": true, "font_size": 28, "lines_coords": [[[192.0, 185.0], [218.0, 185.0], [218.0, 376.0], [192.0, 376.0]], [[159.0, 185.0], [190.0, 185.0], [190.0, 367.0], [159.0, 367.0]], [[128.0, 187.0], [154.0, 187.0], [154.0, 412.0], [128.0, 412.0]], [[96.0, 187.0], [123.0, 187.0], [123.0, 326.0], [96.0, 326.0]]], "lines": ["「とにかく私には", "あなたの願いを", "かなえられるだけの", "力があるわ」"]}, {"box": [942, 1081, 1000, 1239], "vertical": true, "font_size": 27, "lines_coords": [[[973.0, 1082.0], [1000.0, 1082.0], [1000.0, 1218.0], [973.0, 1218.0]], [[942.0, 1081.0], [968.0, 1081.0], [968.0, 1239.0], [942.0, 1239.0]]], "lines": ["あたしは今、", "とても幸せで、"]}, {"box": [246, 829, 372, 1009], "vertical": true, "font_size": 27, "lines_coords": [[[342.0, 831.0], [368.0, 831.0], [371.0, 993.0], [345.0, 993.0]], [[311.0, 829.0], [337.0, 829.0], [340.0, 1009.0], [314.0, 1009.0]], [[279.0, 829.0], [307.0, 829.0], [309.0, 1007.0], [281.0, 1007.0]], [[246.0, 829.0], [275.0, 829.0], [278.0, 945.0], [250.0, 945.0]]], "lines": ["．．．．．．あたしは、", "時間が止まって", "しまえばいいと", "思ってる。"]}, {"box": [811, 1204, 868, 1356], "vertical": true, "font_size": 27, "lines_coords": [[[840.0, 1204.0], [868.0, 1204.0], [868.0, 1331.0], [840.0, 1331.0]], [[811.0, 1204.0], [837.0, 1204.0], [837.0, 1356.0], [811.0, 1356.0]]], "lines": ["今がとても", "大切で．．．．．．"]}, {"box": [137, 1221, 264, 1477], "vertical": true, "font_size": 28, "lines_coords": [[[232.0, 1221.0], [264.0, 1221.0], [264.0, 1389.0], [232.0, 1389.0]], [[200.0, 1225.0], [226.0, 1225.0], [229.0, 1401.0], [203.0, 1401.0]], [[171.0, 1225.0], [198.0, 1225.0], [198.0, 1390.0], [171.0, 1390.0]], [[137.0, 1221.0], [162.0, 1221.0], [165.0, 1475.0], [140.0, 1475.0]]], "lines": ["そしてそれが", "いつか終わって", "しまうことが、", "とても怖いんです．．．"]}], "img_path": "subarashii_sekai_02_188.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [139, 255, 169, 413], "vertical": true, "font_size": 17, "lines_coords": [[[143.0, 307.0], [160.0, 307.0], [160.0, 404.0], [143.0, 404.0]]], "lines": ["．．．"]}, {"box": [820, 468, 945, 676], "vertical": true, "font_size": 26, "lines_coords": [[[917.0, 470.0], [945.0, 470.0], [942.0, 664.0], [914.0, 664.0]], [[879.0, 468.0], [911.0, 468.0], [911.0, 676.0], [879.0, 676.0]], [[853.0, 473.0], [875.0, 473.0], [875.0, 659.0], [853.0, 659.0]], [[822.0, 471.0], [845.0, 471.0], [843.0, 662.0], [820.0, 662.0]]], "lines": ["「これが果たして", "正しいことなのか", "どうか、私は何も", "言わないけれど」"]}, {"box": [720, 724, 879, 928], "vertical": true, "font_size": 28, "lines_coords": [[[848.0, 725.0], [879.0, 725.0], [876.0, 842.0], [845.0, 842.0]], [[817.0, 728.0], [843.0, 728.0], [843.0, 917.0], [817.0, 917.0]], [[782.0, 725.0], [811.0, 725.0], [812.0, 928.0], [784.0, 928.0]], [[751.0, 726.0], [778.0, 726.0], [779.0, 926.0], [753.0, 926.0]], [[720.0, 726.0], [748.0, 726.0], [748.0, 837.0], [720.0, 837.0]]], "lines": ["．．．．．．ホラ、", "今、この瞬間から", "あなたの心と体は", "完全に離れ離れに", "なったわ。"]}, {"box": [578, 728, 640, 890], "vertical": true, "font_size": 26, "lines_coords": [[[609.0, 728.0], [636.0, 728.0], [639.0, 881.0], [612.0, 881.0]], [[578.0, 728.0], [604.0, 728.0], [607.0, 889.0], [581.0, 889.0]]], "lines": ["あなたの体は", "もうからっぽ"]}, {"box": [318, 721, 504, 927], "vertical": true, "font_size": 28, "lines_coords": [[[476.0, 723.0], [504.0, 723.0], [504.0, 828.0], [476.0, 828.0]], [[445.0, 725.0], [471.0, 725.0], [471.0, 882.0], [445.0, 882.0]], [[412.0, 723.0], [439.0, 723.0], [439.0, 825.0], [412.0, 825.0]], [[381.0, 723.0], [407.0, 723.0], [407.0, 925.0], [381.0, 925.0]], [[345.0, 721.0], [379.0, 721.0], [379.0, 803.0], [345.0, 803.0]], [[318.0, 723.0], [345.0, 723.0], [345.0, 882.0], [318.0, 882.0]]], "lines": ["これから", "あなたの心は、", "あなたの", "思い出の中だけで", "永遠に", "生き続けるの"]}, {"box": [476, 1017, 505, 1145], "vertical": true, "font_size": 27, "lines_coords": [[[476.0, 1017.0], [503.0, 1017.0], [503.0, 1145.0], [476.0, 1145.0]]], "lines": ["おーい？"]}], "img_path": "subarashii_sekai_02_189.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [678, 543, 834, 732], "vertical": true, "font_size": 28, "lines_coords": [[[803.0, 543.0], [834.0, 543.0], [834.0, 598.0], [803.0, 598.0]], [[773.0, 545.0], [801.0, 545.0], [801.0, 696.0], [773.0, 696.0]], [[740.0, 546.0], [768.0, 546.0], [768.0, 651.0], [740.0, 651.0]], [[709.0, 545.0], [736.0, 545.0], [736.0, 695.0], [709.0, 695.0]], [[678.0, 545.0], [704.0, 545.0], [704.0, 728.0], [678.0, 728.0]]], "lines": ["この", "坂の多い街の", "中心には、", "大きな太きな", "桜の木があって、"]}, {"box": [467, 542, 591, 759], "vertical": true, "font_size": 26, "lines_coords": [[[564.0, 545.0], [590.0, 545.0], [590.0, 646.0], [564.0, 646.0]], [[531.0, 543.0], [557.0, 543.0], [557.0, 695.0], [531.0, 695.0]], [[500.0, 543.0], [526.0, 543.0], [526.0, 682.0], [500.0, 682.0]], [[467.0, 542.0], [493.0, 542.0], [495.0, 759.0], [468.0, 759.0]]], "lines": ["これまで", "何度も同度も", "花を咲かせ、", "花を散らせてきた。"]}, {"box": [279, 542, 372, 795], "vertical": true, "font_size": 25, "lines_coords": [[[345.0, 543.0], [367.0, 543.0], [367.0, 701.0], [345.0, 701.0]], [[311.0, 542.0], [337.0, 542.0], [336.0, 795.0], [309.0, 795.0]], [[279.0, 543.0], [306.0, 543.0], [306.0, 781.0], [279.0, 781.0]]], "lines": ["人も木も本来、", "そういう運命のもとに", "生まれてきてるんだ。"]}, {"box": [581, 1282, 671, 1436], "vertical": true, "font_size": 27, "lines_coords": [[[643.0, 1282.0], [670.0, 1282.0], [670.0, 1435.0], [643.0, 1435.0]], [[612.0, 1284.0], [639.0, 1284.0], [639.0, 1409.0], [612.0, 1409.0]], [[581.0, 1282.0], [609.0, 1282.0], [609.0, 1420.0], [581.0, 1420.0]]], "lines": ["時間はいつも", "同じ方向に", "流れている。"]}, {"box": [478, 1282, 535, 1493], "vertical": true, "font_size": 22, "lines_coords": [[[509.0, 1284.0], [531.0, 1284.0], [531.0, 1432.0], [509.0, 1432.0]], [[478.0, 1282.0], [500.0, 1282.0], [500.0, 1493.0], [478.0, 1493.0]]], "lines": ["時間の流れは", "残酷かもしれない。"]}, {"box": [400, 1279, 434, 1345], "vertical": false, "font_size": 66, "lines_coords": [[[400.0, 1279.0], [434.0, 1279.0], [434.0, 1345.0], [400.0, 1345.0]]], "lines": ["けど、"]}, {"box": [329, 1279, 356, 1417], "vertical": true, "font_size": 27, "lines_coords": [[[329.0, 1279.0], [356.0, 1279.0], [356.0, 1417.0], [329.0, 1417.0]]], "lines": ["だからって、"]}, {"box": [164, 1278, 294, 1459], "vertical": true, "font_size": 32, "lines_coords": [[[257.0, 1278.0], [286.0, 1278.0], [282.0, 1457.0], [254.0, 1457.0]], [[220.0, 1278.0], [259.0, 1278.0], [259.0, 1371.0], [220.0, 1371.0]], [[192.0, 1279.0], [225.0, 1279.0], [225.0, 1398.0], [192.0, 1398.0]], [[164.0, 1281.0], [190.0, 1281.0], [190.0, 1415.0], [164.0, 1415.0]]], "lines": ["明日を怖がって", "いたら、", "今日、何も", "できないよ"]}], "img_path": "subarashii_sekai_02_190.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [948, 163, 978, 320], "vertical": true, "font_size": 27, "lines_coords": [[[951.0, 203.0], [978.0, 203.0], [975.0, 320.0], [948.0, 320.0]]], "lines": ["．．．大か？"]}, {"box": [200, 185, 234, 292], "vertical": true, "font_size": 30, "lines_coords": [[[200.0, 185.0], [234.0, 185.0], [234.0, 292.0], [200.0, 292.0]]], "lines": ["寒い．．．"]}, {"box": [84, 310, 143, 440]