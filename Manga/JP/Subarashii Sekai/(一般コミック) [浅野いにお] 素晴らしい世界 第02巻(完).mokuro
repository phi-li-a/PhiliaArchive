], [[936.0, 162.0], [976.0, 164.0], [972.0, 259.0], [931.0, 257.0]]], "lines": ["お、戻って", "きたか。"]}, {"box": [822, 267, 909, 437], "vertical": true, "font_size": 28, "lines_coords": [[[881.0, 267.0], [909.0, 267.0], [906.0, 437.0], [878.0, 437.0]], [[851.0, 268.0], [875.0, 268.0], [873.0, 420.0], [850.0, 420.0]], [[822.0, 270.0], [843.0, 270.0], [843.0, 421.0], [822.0, 421.0]]], "lines": ["おまえ、いつも", "どこフラフラ", "してんだぁ？"]}, {"box": [640, 90, 700, 228], "vertical": true, "font_size": 29, "lines_coords": [[[673.0, 90.0], [700.0, 90.0], [700.0, 228.0], [673.0, 228.0]], [[640.0, 90.0], [668.0, 90.0], [668.0, 198.0], [640.0, 198.0]]], "lines": ["ホレ、見てみ", "この新聞"]}, {"box": [512, 162, 611, 342], "vertical": true, "font_size": 29, "lines_coords": [[[582.0, 162.0], [611.0, 162.0], [607.0, 314.0], [579.0, 314.0]], [[551.0, 167.0], [575.0, 167.0], [573.0, 342.0], [550.0, 342.0]], [[515.0, 162.0], [553.0, 164.0], [550.0, 234.0], [512.0, 232.0]]], "lines": ["「ナゾの奇病、", "発病者は昨年の", "数倍」"]}, {"box": [278, 631, 628, 687], "vertical": false, "font_size": 36, "lines_coords": [[[278.0, 651.0], [626.0, 631.0], [628.0, 667.0], [279.0, 687.0]]], "lines": ["結者は昨年の数倍"]}, {"box": [100, 307, 226, 498], "vertical": true, "font_size": 27, "lines_coords": [[[195.0, 307.0], [221.0, 307.0], [226.0, 498.0], [200.0, 498.0]], [[164.0, 307.0], [190.0, 307.0], [193.0, 475.0], [167.0, 475.0]], [[131.0, 307.0], [159.0, 307.0], [164.0, 464.0], [135.0, 464.0]], [[100.0, 309.0], [128.0, 309.0], [128.0, 379.0], [100.0, 379.0]]], "lines": ["「感染症の疑いは", "なし、厚生省は", "原因の究明を", "急ぐ」"]}, {"box": [123, 548, 215, 754], "vertical": true, "font_size": 27, "lines_coords": [[[185.0, 548.0], [214.0, 548.0], [215.0, 665.0], [187.0, 665.0]], [[154.0, 551.0], [181.0, 551.0], [181.0, 754.0], [154.0, 754.0]], [[123.0, 548.0], [150.0, 548.0], [151.0, 743.0], [125.0, 743.0]]], "lines": ["．．．．．って、", "おかしな世の中に", "なってきたなぁ。"]}, {"box": [940, 789, 1004, 1139], "vertical": true, "font_size": 27, "lines_coords": [[[978.0, 790.0], [1004.0, 790.0], [1001.0, 956.0], [975.0, 956.0]], [[945.0, 789.0], [973.0, 789.0], [968.0, 1139.0], [940.0, 1139.0]]], "lines": ["．．．．．．ま、どんな", "世の中だろうと、俺みたいな"]}, {"box": [876, 1009, 937, 1187], "vertical": true, "font_size": 27, "lines_coords": [[[911.0, 1009.0], [937.0, 1009.0], [937.0, 1187.0], [911.0, 1187.0]], [[876.0, 1009.0], [903.0, 1009.0], [906.0, 1145.0], [879.0, 1145.0]]], "lines": ["やつらには関係", "ないけどな。"]}, {"box": [132, 1309, 171, 1428], "vertical": true, "font_size": 33, "lines_coords": [[[132.0, 1310.0], [165.0, 1309.0], [171.0, 1426.0], [139.0, 1428.0]]], "lines": ["．．．．．．寒っ。"]}], "img_path": "subarashii_sekai_02_178.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [881, 125, 1004, 361], "vertical": true, "font_size": 27, "lines_coords": [[[978.0, 125.0], [1004.0, 125.0], [1001.0, 356.0], [975.0, 356.0]], [[945.0, 128.0], [972.0, 128.0], [972.0, 360.0], [945.0, 360.0]], [[912.0, 125.0], [940.0, 125.0], [939.0, 340.0], [911.0, 340.0]], [[881.0, 126.0], [909.0, 126.0], [909.0, 215.0], [881.0, 215.0]]], "lines": ["あったかいメシでも", "食いたいとこだけど、", "今日は収穫なしだ。", "悪いな。"]}, {"box": [600, 112, 661, 304], "vertical": true, "font_size": 27, "lines_coords": [[[629.0, 114.0], [661.0, 114.0], [661.0, 304.0], [629.0, 304.0]], [[601.0, 114.0], [623.0, 114.0], [623.0, 275.0], [601.0, 275.0]]], "lines": ["へへ．．．、なんだか", "体もだりぃや。"]}, {"box": [87, 306, 151, 446], "vertical": true, "font_size": 30, "lines_coords": [[[120.0, 306.0], [148.0, 306.0], [151.0, 446.0], [123.0, 446.0]], [[87.0, 306.0], [120.0, 306.0], [120.0, 396.0], [87.0, 396.0]]], "lines": ["俺、ちょっと", "寝るわ。"]}, {"box": [731, 587, 853, 825], "vertical": true, "font_size": 26, "lines_coords": [[[826.0, 587.0], [853.0, 587.0], [850.0, 742.0], [823.0, 742.0]], [[793.0, 589.0], [820.0, 589.0], [820.0, 825.0], [793.0, 825.0]], [[762.0, 589.0], [789.0, 589.0], [789.0, 815.0], [762.0, 815.0]], [[731.0, 589.0], [753.0, 589.0], [753.0, 793.0], [731.0, 793.0]]], "lines": ["最近はゴミを", "キッチリ分別回収で、", "ホームレスに厳しい", "行政ときてやがる"]}, {"box": [239, 573, 267, 685], "vertical": true, "font_size": 27, "lines_coords": [[[239.0, 573.0], [267.0, 573.0], [267.0, 685.0], [239.0, 685.0]]], "lines": ["．．．そうだ"]}, {"box": [106, 718, 231, 943], "vertical": true, "font_size": 27, "lines_coords": [[[204.0, 718.0], [231.0, 718.0], [229.0, 920.0], [203.0, 920.0]], [[171.0, 718.0], [198.0, 718.0], [198.0, 932.0], [171.0, 932.0]], [[137.0, 718.0], [165.0, 718.0], [167.0, 943.0], [139.0, 943.0]], [[106.0, 718.0], [132.0, 718.0], [135.0, 857.0], [109.0, 857.0]]], "lines": ["起きたらおまえの", "包帯かえてやるよ。", "いいかげんボロボロ", "だもんなぁ。"]}, {"box": [557, 1214, 684, 1391], "vertical": true, "font_size": 29, "lines_coords": [[[650.0, 1214.0], [684.0, 1214.0], [684.0, 1301.0], [650.0, 1301.0]], [[623.0, 1215.0], [650.0, 1215.0], [650.0, 1390.0], [623.0, 1390.0]], [[590.0, 1215.0], [617.0, 1215.0], [617.0, 1343.0], [590.0, 1343.0]], [[557.0, 1217.0], [584.0, 1217.0], [584.0, 1350.0], [557.0, 1350.0]]], "lines": ["この日、", "今年はじめての", "春を告げる", "風が吹いた。"]}, {"box": [337, 1214, 395, 1430], "vertical": true, "font_size": 24, "lines_coords": [[[371.0, 1217.0], [393.0, 1217.0], [393.0, 1426.0], [371.0, 1426.0]], [[337.0, 1215.0], [364.0, 1215.0], [364.0, 1426.0], [337.0, 1426.0]]], "lines": ["もう、すぐそこまで", "春がきているのだ。"]}], "img_path": "subarashii_sekai_02_179.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [486, 134, 629, 345], "vertical": true, "font_size": 31, "lines_coords": [[[595.0, 135.0], [629.0, 135.0], [629.0, 228.0], [595.0, 228.0]], [[559.0, 134.0], [590.0, 134.0], [587.0, 345.0], [556.0, 345.0]], [[521.0, 134.0], [553.0, 134.0], [553.0, 345.0], [521.0, 345.0]], [[486.0, 137.0], [514.0, 137.0], [514.0, 237.0], [486.0, 237.0]]], "lines": ["今日も", "この街がどうか", "幸せであります", "ように、"]}, {"box": [414, 629, 678, 662], "vertical": false, "font_size": 33, "lines_coords": [[[414.0, 629.0], [678.0, 629.0], [678.0, 662.0], [414.0, 662.0]]], "lines": ["１８ｔｈ，ｐｒｏｇｒａｍ"]}, {"box": [503, 678, 582, 714], "vertical": false, "font_size": 36, "lines_coords": [[[503.0, 678.0], [582.0, 678.0], [582.0, 714.0], [503.0, 714.0]]], "lines": ["春風"]}, {"box": [192, 1321, 798, 1478], "vertical": false, "font_size": 104.5, "lines_coords": [[[207.0, 1321.0], [496.0, 1359.0], [481.0, 1478.0], [192.0, 1440.0]], [[462.0, 1362.0], [798.0, 1370.0], [797.0, 1459.0], [461.0, 1451.0]]], "lines": ["素晴ら", "らしいぜ"]}, {"box": [904, 1364, 950, 1404], "vertical": false, "font_size": 44, "lines_coords": [[[904.0, 1360.0], [950.0, 1360.0], [950.0, 1408.0], [904.0, 1408.0]]], "lines": ["：？"]}], "img_path": "subarashii_sekai_02_180.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [860, 168, 948, 322], "vertical": true, "font_size": 25, "lines_coords": [[[922.0, 168.0], [948.0, 168.0], [948.0, 321.0], [922.0, 321.0]], [[889.0, 168.0], [917.0, 168.0], [917.0, 273.0], [889.0, 273.0]], [[861.0, 170.0], [881.0, 170.0], [881.0, 320.0], [861.0, 320.0]]], "lines": ["タエーーっ！！", "大学合格", "おめでとう！"]}, {"box": [647, 106, 709, 307], "vertical": true, "font_size": 27, "lines_coords": [[[682.0, 107.0], [709.0, 107.0], [706.0, 307.0], [679.0, 307.0]], [[650.0, 106.0], [676.0, 106.0], [673.0, 235.0], [647.0, 235.0]]], "lines": ["へっへっ、まぁね。", "見直した？"]}, {"box": [576, 246, 606, 376], "vertical": true, "font_size": 27, "lines_coords": [[[579.0, 246.0], [606.0, 246.0], [603.0, 376.0], [576.0, 376.0]]], "lines": ["タモツは？"]}, {"box": [357, 82, 375, 153], "vertical": true, "font_size": 18, "lines_coords": [[[357.0, 82.0], [375.0, 82.0], [375.0, 153.0], [357.0, 153.0]]], "lines": ["左右縫"]}, {"box": [100, 195, 128, 312], "vertical": true, "font_size": 29, "lines_coords": [[[100.0, 195.0], [128.0, 195.0], [128.0, 312.0], [100.0, 312.0]]], "lines": ["ん？俺？"]}, {"box": [89, 370, 150, 501], "vertical": true, "font_size": 29, "lines_coords": [[[128.0, 376.0], [150.0, 376.0], [150.0, 501.0], [128.0, 501.0]], [[89.0, 370.0], [125.0, 370.0], [125.0, 440.0], [89.0, 440.0]]], "lines": ["伝説の３浪", "突入。"]}, {"box": [246, 507, 276, 804], "vertical": true, "font_size": 27, "lines_coords": [[[248.0, 507.0], [276.0, 507.0], [275.0, 804.0], [246.0, 804.0]]], "lines": ["うぇっ。あんた、これから"]}, {"box": [185, 607, 243, 740], "vertical": true, "font_size": 27, "lines_coords": [[[217.0, 607.0], [243.0, 607.0], [240.0, 740.0], [214.0, 740.0]], [[185.0, 609.0], [212.0, 609.0], [212.0, 715.0], [185.0, 715.0]]], "lines": ["どうすんの", "さーー？"]}, {"box": [920, 806, 1012, 957], "vertical": true, "font_size": 26, "lines_coords": [[[984.0, 809.0], [1012.0, 809.0], [1012.0, 918.0], [984.0, 918.0]], [[953.0, 807.0], [979.0, 807.0], [979.0, 957.0], [953.0, 957.0]], [[923.0, 806.0], [947.0, 806.0], [943.0, 932.0], [920.0, 932.0]]], "lines": ["いやいや、", "意外に俺って", "前向きよ？"]}, {"box": [806, 887, 898, 1076], "vertical": true, "font_size": 26, "lines_coords": [[[872.0, 887.0], [898.0, 887.0], [895.0, 1043.0], [868.0, 1043.0]], [[839.0, 890.0], [865.0, 890.0], [865.0, 1018.0], [839.0, 1018.0]], [[809.0, 887.0], [836.0, 887.0], [832.0, 1076.0], [806.0, 1076.0]]], "lines": ["まだいろんな", "道が俺には", "残ってるってな。"]}, {"box": [204, 896, 230, 1060], "vertical": true, "font_size": 22, "lines_coords": [[[204.0, 906.0], [226.0, 906.0], [226.0, 1059.0], [204.0, 1059.0]]], "lines": ["．．．そうだね。"]}], "img_path": "subarashii_sekai_02_181.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [997, 126, 1018, 328], "vertical": true, "font_size": 24, "lines_coords": [[[997.0, 126.0], [1018.0, 126.0], [1018.0, 328.0], [997.0, 328.0]]], "lines": ["このとーりです！！"]}, {"box": [840, 251, 931, 426], "vertical": true, "font_size": 24, "lines_coords": [[[904.0, 251.0], [931.0, 251.0], [931.0, 381.0], [904.0, 381.0]], [[872.0, 253.0], [898.0, 253.0], [895.0, 404.0], [868.0, 404.0]], [[840.0, 253.0], [862.0, 253.0], [862.0, 426.0], [840.0, 426.0]]], "lines": ["男、春日部。", "編集者生命に", "かえてでも．．．"]}, {"box": [143, 293, 235, 473], "vertical": true, "font_size": 27, "lines_coords": [[[207.0, 295.0], [234.0, 295.0], [234.0, 448.0], [207.0, 448.0]], [[173.0, 293.0], [201.0, 293.0], [203.0, 473.0], [175.0, 473.0]], [[143.0, 295.0], [170.0, 295.0], [170.0, 448.0], [143.0, 448.0]]], "lines": ["先生に漫画を", "描いていただき", "たいんです！！"]}, {"box": [961, 800, 1021, 976], "vertical": true, "font_size": 23, "lines_coords": [[[993.0, 801.0], [1015.0, 801.0], [1015.0, 970.0], [993.0, 970.0]], [[962.0, 801.0], [986.0, 801.0], [984.0, 953.0], [961.0, 953.0]]], "lines": ["．．．で、センセ、", "やるんスカ？"]}, {"box": [572, 846, 698, 1029], "vertical": true, "font_size": 29, "lines_coords": [[[662.0, 846.0], [693.0, 846.0], [698.0, 1014.0], [667.0, 1014.0]], [[634.0, 850.0], [665.0, 850.0], [665.0, 1029.0], [634.0, 1029.0]], [[604.0, 850.0], [631.0, 850.0], [631.0, 987.0], [604.0, 987.0]], [[572.0, 848.0], [598.0, 848.0], [598.0, 978.0], [572.0, 978.0]]], "lines": ["えぇ？だって", "エロ本でしょ？", "センセ、エロ", "描けんの？"]}, {"box": [100, 903, 222, 1081], "vertical": true, "font_size": 26, "lines_coords": [[[192.0, 904.0], [220.0, 904.0], [221.0, 1064.0], [193.0, 1064.0]], [[162.0, 906.0], [190.0, 906.0], [190.0, 1046.0], [162.0, 1046.0]], [[128.0, 903.0], [156.0, 903.0], [157.0, 1081.0], [129.0, 1081.0]], [[100.0, 907.0], [121.0, 907.0], [121.0, 1032.0], [100.0, 1032.0]]], "lines": ["つーかセンセ、", "この頃仕事", "増やしすぎじゃ", "ないスカ？"]}, {"box": [712, 1309, 775, 1440], "vertical": true, "font_size": 32, "lines_coords": [[[745.0, 1309.0], [773.0, 1309.0], [775.0, 1439.0], [747.0, 1439.0]], [[712.0, 1309.0], [748.0, 1309.0], [748.0, 1379.0], [712.0, 1379.0]]], "lines": ["うーん．．．", "やる。"]}, {"box": [354, 1151, 442, 1503], "vertical": true, "font_size": 25, "lines_coords": [[[420.0, 1154.0], [442.0, 1154.0], [442.0, 1328.0], [420.0, 1328.0]], [[386.0, 1151.0], [412.0, 1151.0], [412.0, 1335.0], [386.0, 1335.0]], [[354.0, 1154.0], [381.0, 1154.0], [381.0, 1503.0], [354.0, 1503.0]]], "lines": ["娘の養育費とか", "老後のこととか、", "いろいろあんの。積山君だって"]}, {"box": [260, 1348, 348, 1554], "vertical": true, "font_size": 25, "lines_coords": [[[318.0, 1348.0], [345.0, 1348.0], [348.0, 1528.0], [321.0, 1528.0]], [[287.0, 1348.0], [314.0, 1348.0], [318.0, 1553.0], [292.0, 1553.0]], [[260.0, 1353.0], [282.0, 1353.0], [282.0, 1554.0], [260.0, 1554.0]]], "lines": ["いつまでも俺の", "アシスタントって", "ワケいかないよ？"]}], "img_path": "subarashii_sekai_02_182.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box": [918, 104, 1025, 371], "vertical": true, "font_size": 24, "lines_coords": [[[992.0, 112.0], [1017.0, 107.0], [1025.0, 148.0], [1000.0, 153.0]], [[983.0, 231.0], [1004.0, 231.0], [1004.0, 359.0], [983.0, 359.0]], [[948.0, 228.0], [975.0, 228.0], [972.0, 335.0], [945.0, 335.0]], [[918.0, 234.0], [940.0, 234.0], [940.0, 370.0], [918.0, 370.0]]], "lines": ["ま。", "きっと俺は", "どーにか", "なりますよ。"]}, {"box": [196, 137, 226, 256], "vertical": true, "font_size": 29, "lines_coords": [[[196.0, 137.0], [225.0, 137.0], [226.0, 256.0], [198.0, 256.0]]], "lines": ["若いなぁ。"]}, {"box": [481, 391, 508, 545], "vertical": true, "font_size": 26, "lines_coords": [[[481.0, 442.0], [507.0, 442.0], [507.0, 543.0], [481.0, 543.0]]], "lines": ["ーん．．．"]}, {"box": [104, 328, 234, 496], "vertical": true, "font_size": 29, "lines_coords": [[[200.0, 328.0], [234.0, 328.0], [234.0, 418.0], [200.0, 418.0]], [[168.0, 329.0], [196.0, 329.0], [198.0, 496.0], [170.0, 496.0]], [[139.0, 329.0], [165.0, 329.0], [165.0, 457.0], [139.0, 457.0]], [[104.0, 329.0], [132.0, 329.0], [137.0, 468.0], [109.0, 468.0]]], "lines": ["横山君、", "それ、なんだか", "すごくいい", "感じだなぁ。"]}, {"box": [879, 1056, 912, 1181], "vertical": true, "font_size": 33, "lines_coords": [[[879.0, 1056.0], [912.0, 1056.0], [912.0, 1181.0], [879.0, 1181.0]]], "lines": ["キング！！"]}, {"box": [281, 1082, 314, 1296], "vertical": true, "font_size": 28, "lines_coords": [[[282.0, 1196.0], [311.0, 1196.0], [314.0, 1296.0], [286.0, 1296.0]], [[281.0, 1082.0], [309.0, 1082.0], [309.0, 1209.0], [281.0, 1209.0]]], "lines": ["ーっ！！", "キングー"]}], "img_path": "subarashii_sekai_02_183.jpg"}, {"version": "0.1.7", "img_width": 1119, "img_height": 1600, "blocks": [{"box":