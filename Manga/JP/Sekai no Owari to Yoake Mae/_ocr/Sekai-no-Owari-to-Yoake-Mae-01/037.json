{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [660, 498, 703, 608], "vertical": true, "font_size": 18.0, "lines": ["結局飯田から", "連絡は来ず、"]}, {"box": [541, 367, 656, 399], "vertical": false, "font_size": 32.0, "lines": ["＂６：１５"]}, {"box": [517, 494, 611, 679], "vertical": true, "font_size": 22.0, "lines": ["僕らはポーリング場で", "無駄な時間を", "どーでもいい会話で", "潰した。"]}, {"box": [361, 494, 474, 643], "vertical": true, "font_size": 18.0, "lines": ["始発が動き出して", "その帰り際", "飯田の彼女は", "こう言い置いて", "去っていった。"]}, {"box": [790, 759, 858, 886], "vertical": true, "font_size": 20.0, "lines": ["なんかだいぶ", "ふっきれたよ。", "ありがとう。"]}, {"box": [286, 711, 328, 847], "vertical": true, "font_size": 18.0, "lines": ["．．．時間ってのは", "残酷だ．．．"]}, {"box": [221, 815, 263, 913], "vertical": true, "font_size": 18.0, "lines": ["それでも", "朝乃来る．．．"]}, {"box": [613, 1082, 659, 1189], "vertical": true, "font_size": 19.0, "lines": ["！", "あー", "そうですか。"]}, {"box": [313, 1104, 380, 1225], "vertical": true, "font_size": 18.0, "lines": ["今から企画書", "なんて無理", "だよな．．．"]}]}