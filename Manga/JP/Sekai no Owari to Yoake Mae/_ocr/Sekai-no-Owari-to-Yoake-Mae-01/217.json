{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [828, 146, 873, 266], "vertical": true, "font_size": 18.0, "lines": ["あ．．．え～と、", "高山．．．くん？"]}, {"box": [486, 190, 555, 311], "vertical": true, "font_size": 19.0, "lines": ["．．．ま、あだ名", "なんて忘れち", "まうかぁ。"]}, {"box": [377, 214, 468, 375], "vertical": true, "font_size": 19.0, "lines": ["晴は中学から", "私立行っちまった", "から１５年振り", "だもんなァ。"]}, {"box": [642, 465, 713, 572], "vertical": true, "font_size": 24.0, "lines": ["なんだよ、", "「くん」って", "オイ！！"]}, {"box": [218, 490, 269, 594], "vertical": true, "font_size": 24.0, "lines": ["．．．今", "仕事帰り？"]}, {"box": [708, 706, 867, 946], "vertical": true, "font_size": 22.0, "lines": ["輸入車の", "ディーラー", "やってんの。", "クソ暑い中、", "ネクタイして", "金持ちに頭", "下げてんだ"]}, {"box": [218, 681, 341, 969], "vertical": true, "font_size": 21.0, "lines": ["．．．いいなぁ晴は、", "ヒゲなんか", "生やしちゃって。アレだろ？", "東京で", "漫画家だろ？"]}, {"box": [757, 1055, 848, 1194], "vertical": true, "font_size": 17.0, "lines": ["お前はホント", "ガキん時から", "絵は達者だった", "もんなァー"]}, {"box": [211, 1072, 304, 1234], "vertical": true, "font_size": 20.0, "lines": ["今もずっと", "続けてるってのは", "まー、たいした", "もんだよ。"]}]}