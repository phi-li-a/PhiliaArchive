{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [795, 203, 820, 324], "vertical": true, "font_size": 22.0, "lines": ["あー", "あ！！"]}, {"box": [259, 273, 326, 373], "vertical": true, "font_size": 18.0, "lines": ["早くこんな", "狭い村から", "出たいよ。"]}, {"box": [739, 547, 898, 728], "vertical": true, "font_size": 21.0, "lines": ["この村の", "高速道路の", "高架橋、", "見てるとあたし", "体がゾワゾワ", "するんだよね。"]}, {"box": [318, 547, 392, 693], "vertical": true, "font_size": 20.0, "lines": ["この橋は", "東京にまで", "繋がってるのに、"]}, {"box": [218, 573, 285, 741], "vertical": true, "font_size": 20.0, "lines": ["こんな場所で", "あたしは何を", "してるんだろって。"]}, {"box": [734, 818, 892, 981], "vertical": true, "font_size": 21.0, "lines": ["あたし進路、", "◯◯高校希望", "なんだ。", "学区外で", "校則少なくて", "私服だし"]}, {"box": [512, 817, 537, 938], "vertical": true, "font_size": 22.0, "lines": ["杉崎くんは？"]}, {"box": [180, 817, 303, 1018], "vertical": true, "font_size": 23.0, "lines": ["僕は．．．", "母ちゃん一人に", "できないし、", "地元の高校", "行くよ。"]}, {"box": [619, 1100, 711, 1219], "vertical": true, "font_size": 19.0, "lines": ["それで東京の", "大学行って、", "やりたいこと", "やるんだ。"]}, {"box": [285, 1094, 332, 1195], "vertical": true, "font_size": 22.0, "lines": ["もしかして", "マザコン？"]}, {"box": [212, 1170, 234, 1240], "vertical": true, "font_size": 22.0, "lines": ["違うよ。"]}]}