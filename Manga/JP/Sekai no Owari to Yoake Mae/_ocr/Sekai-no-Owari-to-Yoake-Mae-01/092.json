{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [768, 119, 860, 258], "vertical": true, "font_size": 19.0, "lines": ["アメリカに", "右向け右で", "みんな健康指向", "だけど、"]}, {"box": [521, 150, 567, 240], "vertical": true, "font_size": 21.0, "lines": ["よく見て", "ごらんよ。"]}, {"box": [205, 216, 325, 376], "vertical": true, "font_size": 22.0, "lines": ["今さら", "説明の必要が", "ないくらい", "世の中終わってる", "じゃないか。"]}, {"box": [630, 463, 723, 601], "vertical": true, "font_size": 20.0, "lines": ["長生きに", "どれだけ価値が", "あるんだって", "思わない？"]}, {"box": [777, 676, 845, 795], "vertical": true, "font_size": 20.0, "lines": ["こんな社会を", "作っておいて", "大人達は、"]}, {"box": [667, 739, 735, 878], "vertical": true, "font_size": 20.0, "lines": ["俺らの世代に", "丸投げしようと", "してるんだ。"]}, {"box": [259, 748, 279, 873], "vertical": true, "font_size": 18.0, "lines": ["いい迷惑だよ。"]}, {"box": [743, 991, 837, 1110], "vertical": true, "font_size": 22.0, "lines": ["やっぱ勉強", "できる人って", "変なの", "かなー"]}, {"box": [279, 968, 345, 1135], "vertical": true, "font_size": 19.0, "lines": ["実はこの場所も", "下界から漫食", "されつつあってさ。"]}, {"box": [158, 1064, 250, 1239], "vertical": true, "font_size": 19.0, "lines": ["バカな大学生が", "ここを見つけて", "セックスドラッグの", "無法地帯でね。"]}]}