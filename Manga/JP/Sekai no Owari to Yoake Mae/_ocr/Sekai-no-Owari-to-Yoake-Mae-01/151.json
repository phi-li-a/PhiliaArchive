{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [826, 171, 876, 297], "vertical": true, "font_size": 24.0, "lines": ["一方、", "私はというと、"]}, {"box": [303, 149, 419, 333], "vertical": true, "font_size": 19.0, "lines": ["あなたも", "いいトシなんだし、", "そろそろ夢なんて", "諦めてこっち", "帰ってらっしゃいな。"]}, {"box": [237, 399, 306, 556], "vertical": true, "font_size": 18.0, "lines": ["いや～叔母さん、", "あたしもともと", "夢なんてないし．．．"]}, {"box": [811, 634, 854, 733], "vertical": true, "font_size": 19.0, "lines": ["んー．．．", "まぁでも．．．"]}, {"box": [689, 674, 780, 838], "vertical": true, "font_size": 19.0, "lines": ["今の仕事が", "続かなくなったら、", "その時はちょっと", "検討してみます。"]}, {"box": [519, 896, 611, 1055], "vertical": true, "font_size": 20.0, "lines": ["叶わない夢なんて", "悲しすぎるから", "初めから", "持たなかった。"]}, {"box": [225, 643, 318, 846], "vertical": true, "font_size": 18.0, "lines": ["子供の頃好きだった", "外国のおもちゃの", "輸入代理店で", "それなりに働いている。"]}, {"box": [210, 1078, 326, 1255], "vertical": true, "font_size": 19.0, "lines": ["あまり先のことを", "考えると", "へコんでしまうので", "休みの日は洗濯", "ばかりしている。"]}]}