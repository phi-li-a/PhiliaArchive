{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [795, 159, 845, 328], "vertical": true, "font_size": 22.0, "lines": ["族車もパンチラも", "金持ちの教祖様も。"]}, {"box": [532, 150, 603, 268], "vertical": true, "font_size": 19.0, "lines": ["だからお前、", "大沢さんに", "告白すれば？"]}, {"box": [193, 151, 264, 292], "vertical": true, "font_size": 21.0, "lines": ["バッカ、お前", "そーゆうんじゃ", "ねえって！！"]}, {"box": [755, 455, 781, 528], "vertical": true, "font_size": 24.0, "lines": ["自由も。"]}, {"box": [678, 500, 700, 589], "vertical": true, "font_size": 24.0, "lines": ["女の子も。"]}, {"box": [381, 364, 452, 485], "vertical": true, "font_size": 20.0, "lines": ["．．．じゃあ", "俺が告白して", "いい？"]}, {"box": [741, 676, 811, 824], "vertical": true, "font_size": 21.0, "lines": ["なんだ、そりゃ！？", "マジ訳わかん", "ねぇって！！"]}, {"box": [223, 785, 292, 925], "vertical": true, "font_size": 20.0, "lines": ["だって別に", "そーゆうんじゃ", "ないんでしょ？"]}, {"box": [734, 1042, 780, 1164], "vertical": true, "font_size": 20.0, "lines": ["じゃあコレで", "決める？"]}, {"box": [215, 1079, 286, 1200], "vertical": true, "font_size": 21.0, "lines": ["勝ったほうが", "大沢さんに", "コクる。"]}]}