{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [660, 107, 729, 267], "vertical": true, "font_size": 21.0, "lines": ["．．．あのさー．．．", "俺ちょっと大事な", "話が．．．"]}, {"box": [502, 145, 597, 323], "vertical": true, "font_size": 21.0, "lines": ["今日午後六時頃、", "メメ市のコンビニに", "黒ずくめの男", "３人が押し入り、"]}, {"box": [181, 231, 251, 367], "vertical": true, "font_size": 18.0, "lines": ["レシにあった", "数十万円を奪い", "逃走しました"]}, {"box": [198, 455, 293, 633], "vertical": true, "font_size": 20.0, "lines": ["ホラホラ、ここ、", "あんたがいつも", "寄ってくるコンビニ", "じゃない？"]}, {"box": [717, 695, 835, 882], "vertical": true, "font_size": 21.0, "lines": ["勇敢なアルバイト", "店員が激しく抵抗し、", "もみ合いになりまし", "たが怪我は軽傷", "ぐ．．．．．"]}]}