{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [795, 154, 909, 321], "vertical": true, "font_size": 23.0, "lines": ["お前があたしに", "話しかけよう", "なんて百億年", "はえーんだよ！！"]}, {"box": [708, 206, 751, 297], "vertical": true, "font_size": 32.0, "lines": ["コッス"]}, {"box": [502, 149, 618, 319], "vertical": true, "font_size": 26.0, "lines": ["それが嫌なら", "死ぬ気で自分を", "ツルッツルに", "磨いてこい！！"]}, {"box": [616, 417, 705, 593], "vertical": true, "font_size": 23.0, "lines": ["もしまた来たら、", "てめえん家", "燃やすからな！！"]}, {"box": [214, 343, 260, 445], "vertical": true, "font_size": 22.0, "lines": ["法に訴えて", "やるー"]}, {"box": [754, 676, 848, 815], "vertical": true, "font_size": 20.0, "lines": ["爽子は", "パートなので、", "昼過ぎに仕事が", "終わります"]}, {"box": [224, 780, 344, 949], "vertical": true, "font_size": 20.0, "lines": ["午後は歩道橋で", "手下のハトと共に、", "外国車に呪いを", "かけたりして", "時間を潰します。"]}, {"box": [763, 1101, 809, 1241], "vertical": true, "font_size": 20.0, "lines": ["ホンット、マジ", "へコんだよー"]}]}