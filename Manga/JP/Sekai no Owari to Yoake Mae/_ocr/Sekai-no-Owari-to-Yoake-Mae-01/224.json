{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [778, 668, 850, 798], "vertical": true, "font_size": 21.0, "lines": ["．．．子供、", "もうけっこう", "てかいんだね。"]}, {"box": [201, 755, 359, 999], "vertical": true, "font_size": 21.0, "lines": ["来年小学校", "だからな", "．．．ただ、別れた", "前のダンナが", "チンピラみたいな", "奴でさ。"]}, {"box": [773, 1081, 842, 1198], "vertical": true, "font_size": 19.0, "lines": ["奈月ん家は", "昔から男運が", "な．．．"]}, {"box": [183, 1109, 254, 1249], "vertical": true, "font_size": 20.0, "lines": ["あいつの親父も", "昔は暴力が", "酷かったし。"]}]}