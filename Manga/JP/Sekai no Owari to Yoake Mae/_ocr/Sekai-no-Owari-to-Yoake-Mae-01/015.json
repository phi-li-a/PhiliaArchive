{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [460, 314, 621, 336], "vertical": false, "font_size": 22.0, "lines": ["Ｗｏｏ．４５"]}, {"box": [733, 522, 807, 728], "vertical": true, "font_size": 21.0, "lines": ["飯田の野郎が", "なんか彼女との", "別れ話がもめまくって、"]}, {"box": [573, 524, 669, 708], "vertical": true, "font_size": 22.0, "lines": ["もー２人じゃ", "収拾つかねーから", "お前が仲介してくれ。", "とか言い出して、"]}, {"box": [460, 526, 509, 690], "vertical": true, "font_size": 22.0, "lines": ["まぁ引き受ける", "俺も俺なんだけど、"]}, {"box": [302, 529, 395, 707], "vertical": true, "font_size": 20.0, "lines": ["当の飯田は", "連絡がつかず", "待ち合わせ場所にも", "現れない"]}, {"box": [481, 1099, 552, 1258], "vertical": true, "font_size": 23.0, "lines": ["さらに", "今日初めて会った", "飯田の彼女が、"]}, {"box": [346, 1101, 416, 1263], "vertical": true, "font_size": 21.0, "lines": ["けっこう俺の", "好みな感じ", "だったりするから"]}, {"box": [233, 1104, 280, 1241], "vertical": true, "font_size": 18.0, "lines": ["よりビミョーな", "気持ちになる。"]}]}