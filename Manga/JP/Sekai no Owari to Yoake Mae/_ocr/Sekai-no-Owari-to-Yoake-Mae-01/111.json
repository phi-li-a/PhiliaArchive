{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [764, 160, 857, 280], "vertical": true, "font_size": 20.0, "lines": ["この建物は", "バブルの頃に", "建てられた", "ホテルでな"]}, {"box": [305, 201, 401, 341], "vertical": true, "font_size": 20.0, "lines": ["家族全員が", "揃って旅行した", "最後の場所", "なんだ。"]}, {"box": [761, 548, 856, 689], "vertical": true, "font_size": 20.0, "lines": ["ここに来れば", "昔の幸せだった", "頃を思い出せる", "と思ったが．．．"]}, {"box": [228, 341, 272, 467], "vertical": true, "font_size": 20.0, "lines": ["もう１５年も", "前のことだよ。"]}, {"box": [236, 603, 305, 721], "vertical": true, "font_size": 19.0, "lines": ["思い出すのは", "辛い記憶", "ばかりだな。"]}, {"box": [755, 787, 872, 987], "vertical": true, "font_size": 19.0, "lines": ["やっとの思いで", "家を建てた矢先、", "会社のプロジェクトで", "私は海外に", "飛ばされた"]}, {"box": [220, 833, 314, 1000], "vertical": true, "font_size": 22.0, "lines": ["日本に", "戻ってくれば", "妻は病気で", "あっけなく逝った。"]}, {"box": [599, 1064, 668, 1222], "vertical": true, "font_size": 19.0, "lines": ["結局ある", "事情で計画は", "打ち切られたが．．．"]}, {"box": [179, 1096, 299, 1236], "vertical": true, "font_size": 20.0, "lines": ["いつの間にか", "大きくなった", "子供達は", "私に言わせりゃ", "宇宙人だ。"]}]}