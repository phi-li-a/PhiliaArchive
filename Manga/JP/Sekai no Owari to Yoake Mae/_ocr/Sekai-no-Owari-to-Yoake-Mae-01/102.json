{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [746, 142, 842, 302], "vertical": true, "font_size": 23.0, "lines": ["あんまり喋んない", "ほうがいいって！", "早く病院", "行こ？"]}, {"box": [621, 517, 690, 617], "vertical": true, "font_size": 22.0, "lines": ["．．．もう少し", "このままで", "いさせて。"]}, {"box": [186, 203, 313, 599], "vertical": true, "font_size": 19.0, "lines": ["この場所だけは", "絶対に守らないと", "きのう．．．あの後", "いけない気が", "僕はあれこれ", "したんだ。", "考えていたん", "だけど．．．"]}, {"box": [819, 674, 841, 756], "vertical": true, "font_size": 19.0, "lines": ["僕は．．．"]}, {"box": [686, 744, 754, 903], "vertical": true, "font_size": 19.0, "lines": ["ずっと前から", "信じられる何かを", "探してたのかな。"]}, {"box": [251, 1038, 296, 1205], "vertical": true, "font_size": 18.0, "lines": ["．．．もしかしたら、", "それは君なのかな。"]}]}