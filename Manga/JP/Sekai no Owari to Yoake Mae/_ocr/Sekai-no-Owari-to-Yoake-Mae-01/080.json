{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [755, 301, 779, 443], "vertical": true, "font_size": 22.0, "lines": ["．．．うれしい！！"]}, {"box": [625, 604, 694, 709], "vertical": true, "font_size": 21.0, "lines": ["．．．あの時", "映画が完成", "していたら"]}, {"box": [206, 401, 325, 546], "vertical": true, "font_size": 19.0, "lines": ["その後香田と", "付き合うことに", "なったが、", "結局脚本は", "終わらなかった。"]}, {"box": [430, 603, 501, 739], "vertical": true, "font_size": 22.0, "lines": ["俺達は", "どうなって", "いたんだろう？"]}, {"box": [516, 839, 588, 978], "vertical": true, "font_size": 22.0, "lines": ["親父は", "俺の何を", "信じてたんだ？"]}, {"box": [710, 978, 763, 1083], "vertical": true, "font_size": 22.0, "lines": ["お前達を", "信じてる。"]}, {"box": [178, 1081, 260, 1220], "vertical": true, "font_size": 20.0, "lines": ["そして俺は", "何を信じて", "たんだっけ？"]}]}