{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [817, 129, 886, 266], "vertical": true, "font_size": 18.0, "lines": ["．．．お姉ちゃんは", "いつもお気楽で", "いいよねー"]}, {"box": [706, 120, 789, 201], "vertical": false, "font_size": 22.0, "lines": ["おもしろあの", "こちらが作って", "みんな"]}, {"box": [556, 112, 629, 251], "vertical": true, "font_size": 24.0, "lines": ["あー", "あのバカなんか", "ほっとけ。"]}, {"box": [375, 89, 438, 225], "vertical": true, "font_size": 32.0, "lines": ["ふぬぁ"]}, {"box": [215, 186, 262, 288], "vertical": true, "font_size": 22.0, "lines": ["ねみーから", "俺は寝る。"]}, {"box": [663, 398, 735, 519], "vertical": true, "font_size": 25.0, "lines": ["今、ウチ", "ピンチだって", "のに。"]}, {"box": [815, 607, 864, 678], "vertical": true, "font_size": 26.0, "lines": ["．．．あ、", "俺、今、"]}, {"box": [499, 381, 567, 500], "vertical": true, "font_size": 20.0, "lines": ["人のことまで", "かまって", "られないよ。"]}, {"box": [251, 380, 346, 499], "vertical": true, "font_size": 23.0, "lines": ["自分のことで", "いっぱい", "いっぱい", "ですから。"]}, {"box": [516, 619, 612, 777], "vertical": true, "font_size": 21.0, "lines": ["帰り遅くなる", "かもしれないから", "Ｊｒにゴハン", "あげといてね。"]}, {"box": [251, 825, 295, 942], "vertical": true, "font_size": 21.0, "lines": ["自分に嘘", "ついてねー？"]}, {"box": [769, 1047, 863, 1207], "vertical": true, "font_size": 21.0, "lines": ["自分のことで", "必死になったこと", "なんて．．．今まで", "あったっけ？"]}, {"box": [208, 1085, 300, 1220], "vertical": true, "font_size": 19.0, "lines": ["．．．お父さん", "大丈夫かな？", "けっこう心配に", "なってきた。"]}]}