{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [785, 172, 850, 291], "vertical": true, "font_size": 17.0, "lines": ["洗剤切れた．．．", "買いに行かな", "きゃ．．．"]}, {"box": [181, 155, 251, 273], "vertical": true, "font_size": 20.0, "lines": ["ついでに", "ゴミも捨てて", "しまえ！！"]}, {"box": [655, 734, 726, 824], "vertical": true, "font_size": 22.0, "lines": ["．．．ま、", "いまさら、", "ね．．．"]}, {"box": [661, 1044, 791, 1190], "vertical": true, "font_size": 32.0, "lines": ["できません", "収集ゼの", "朝五時〜八時に", "出して下さい"]}, {"box": [433, 1117, 512, 1143], "vertical": false, "font_size": 13.5, "lines": ["不燃ごみ", "そういうことですか？"]}, {"box": [430, 1184, 615, 1200], "vertical": false, "font_size": 13.0, "lines": ["また、これはそのまれの問題が出来ないのか。でもそれでもしかしてくださいね．．．"]}, {"box": [455, 1201, 597, 1210], "vertical": false, "font_size": 12.0, "lines": ["「うん！！」といってくれていました！！．．．", "ええ．．．ここで"]}, {"box": [436, 1155, 533, 1175], "vertical": false, "font_size": 18.0, "lines": ["粗大ごみ"]}, {"box": [301, 1083, 415, 1232], "vertical": true, "font_size": 32.0, "lines": ["ゴミ出しの", "アナー行って", "愚か者"]}]}