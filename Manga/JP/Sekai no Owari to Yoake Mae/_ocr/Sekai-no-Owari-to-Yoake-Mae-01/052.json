{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [623, 311, 730, 522], "vertical": true, "font_size": 20.0, "lines": ["なんかさ、", "キミのその", "素朴な感じ", "好感が持てる。"]}, {"box": [742, 595, 841, 716], "vertical": true, "font_size": 21.0, "lines": ["僕は夢中で", "高速道路で", "立ち漕ぎして", "いた。"]}, {"box": [450, 378, 473, 486], "vertical": true, "font_size": 22.0, "lines": ["その日の晩"]}, {"box": [260, 377, 309, 481], "vertical": true, "font_size": 22.0, "lines": ["僕はこんな", "夢を見た。"]}, {"box": [236, 780, 334, 899], "vertical": true, "font_size": 19.0, "lines": ["気づくと僕は", "自転車ごと", "浮き上がって", "空を舞った。"]}, {"box": [706, 1077, 778, 1206], "vertical": true, "font_size": 23.0, "lines": ["果てには", "宇宙まで", "飛んでいって、"]}, {"box": [515, 1079, 565, 1201], "vertical": true, "font_size": 25.0, "lines": ["頭が真っ白に", "なって、"]}, {"box": [303, 1082, 377, 1202], "vertical": true, "font_size": 20.0, "lines": ["僕はなんだか", "真理に触れた", "気がした"]}]}