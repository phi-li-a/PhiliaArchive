{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [752, 145, 860, 292], "vertical": true, "font_size": 18.0, "lines": ["でも漫画家って", "売れないと不安定", "って言うじゃん、", "ちゃんと生活でき", "ー？", "てんのー"]}, {"box": [507, 159, 590, 317], "vertical": true, "font_size": 18.0, "lines": ["もしかしてジャンプ", "だったりする？", "だったら弟が", "読んでるかも"]}, {"box": [442, 258, 481, 365], "vertical": true, "font_size": 18.0, "lines": ["どんな漫画", "描いてんの？"]}, {"box": [184, 203, 267, 368], "vertical": true, "font_size": 18.0, "lines": ["んー．．．青年誌で", "地味な青春ものとか", "．．．．．ってなんか説明", "し辛いんだけど．．．"]}, {"box": [619, 458, 700, 620], "vertical": true, "font_size": 18.0, "lines": ["．．．いやーー．．", "これでも一応", "それなりはやってる", "つもりだけど．．．"]}, {"box": [215, 486, 260, 625], "vertical": true, "font_size": 20.0, "lines": ["．．．それって", "おもしろいの？"]}, {"box": [680, 703, 844, 912], "vertical": true, "font_size": 22.0, "lines": ["とりあえず", "サインもらっちゃ", "おうかな～～！！", "あ、でも", "単行本持って", "ないや。"]}, {"box": [321, 765, 343, 847], "vertical": true, "font_size": 20.0, "lines": ["あはは．．．"]}, {"box": [215, 764, 285, 931], "vertical": true, "font_size": 20.0, "lines": ["ぃいよいいよ、", "ペンさえあれば", "なんにでも描くよ。"]}, {"box": [758, 1033, 837, 1196], "vertical": true, "font_size": 22.0, "lines": ["おばちゃん", "マッキー", "ある〜〜〜っ！？"]}, {"box": [277, 1000, 305, 1104], "vertical": true, "font_size": 21.0, "lines": ["．．．お、何？"]}, {"box": [180, 1101, 245, 1232], "vertical": true, "font_size": 21.0, "lines": ["晴来てんの？", "珍しいなぁ", "くくくさく！！"]}]}