{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [743, 108, 787, 249], "vertical": true, "font_size": 18.0, "lines": ["ただ生きてゆく", "だけならば、"]}, {"box": [620, 105, 689, 302], "vertical": true, "font_size": 21.0, "lines": ["世の中には", "知らなくていいことが", "多すぎる。"]}, {"box": [469, 101, 565, 319], "vertical": true, "font_size": 21.0, "lines": ["でも、それを知ることが", "大人だと言うならば", "私はずいぶん", "大人になった。"]}, {"box": [258, 94, 378, 260], "vertical": true, "font_size": 22.0, "lines": ["少なくとも", "虹の橋を渡ろうと", "夢見ていた", "子供の頃の自分は、", "もういない。"]}, {"box": [429, 879, 575, 1069], "vertical": true, "font_size": 21.0, "lines": ["引っ越しの", "荷造りをしていたら、", "机の引き出しの", "なんかずいぶんと", "奥のほうから", "子紙が出てきた。"]}, {"box": [151, 1078, 185, 1218], "vertical": true, "font_size": 32.0, "lines": ["前略ー"]}]}