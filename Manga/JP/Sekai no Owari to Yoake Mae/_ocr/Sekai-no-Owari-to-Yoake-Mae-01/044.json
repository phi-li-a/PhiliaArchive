{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [786, 132, 882, 281], "vertical": true, "font_size": 22.0, "lines": ["母さん今晩", "集まり”が", "あるから夕飯", "一人で食べてね。"]}, {"box": [514, 144, 642, 332], "vertical": true, "font_size": 21.0, "lines": ["あ、あと．．．", "本田くん、茶髪に", "なってたけど、", "どうしちゃった", "の？"]}, {"box": [755, 530, 847, 713], "vertical": true, "font_size": 19.0, "lines": ["母の言う。集まり、は", "近所のオバサン達を", "中心に信者を持つ", "新興宗教の集まりで、"]}, {"box": [201, 384, 246, 492], "vertical": true, "font_size": 20.0, "lines": ["．．．いって", "きまーす"]}, {"box": [658, 621, 726, 746], "vertical": true, "font_size": 19.0, "lines": ["僕の母親は", "月に２回ほど", "会に出席する"]}, {"box": [817, 916, 869, 1021], "vertical": true, "font_size": 28.0, "lines": ["ウィーース", "杉崎。"]}, {"box": [455, 878, 616, 1069], "vertical": true, "font_size": 20.0, "lines": ["本田：お前", "日に日に金髪に", "近づいてくなぁ。", "そろそろ", "先生に怒られ", "るよ？"]}, {"box": [224, 624, 319, 830], "vertical": true, "font_size": 20.0, "lines": ["そこの教祖様は", "僕が通った小学校の", "校長先生らしいけど、", "これはどうでもいい話"]}, {"box": [167, 1079, 238, 1202], "vertical": true, "font_size": 22.0, "lines": ["パーカ、", "そんなの上等", "だよ。"]}]}