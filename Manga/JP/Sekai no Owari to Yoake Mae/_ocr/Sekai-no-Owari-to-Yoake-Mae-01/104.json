{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [600, 145, 650, 246], "vertical": true, "font_size": 21.0, "lines": ["思い返せば", "その日、"]}, {"box": [482, 146, 575, 284], "vertical": true, "font_size": 21.0, "lines": ["起きる必要も", "ないのに", "いつもの時間に", "目が覚めて、"]}, {"box": [407, 145, 456, 268], "vertical": true, "font_size": 21.0, "lines": ["確かに", "私は変だった"]}, {"box": [407, 143, 454, 274], "vertical": true, "font_size": 32.0, "lines": ["確かに私は変だった。"]}, {"box": [748, 398, 819, 539], "vertical": true, "font_size": 21.0, "lines": ["気がつくと", "私はネクタイを", "締め、"]}, {"box": [214, 559, 283, 668], "vertical": true, "font_size": 23.0, "lines": ["馴れない", "朝食を", "作っていた。"]}, {"box": [767, 770, 862, 938], "vertical": true, "font_size": 19.0, "lines": ["玄関に立った時、", "もう行く場所が", "ない事実を", "改めて実感すると、"]}, {"box": [190, 787, 251, 1048], "vertical": true, "font_size": 21.0, "lines": ["俺は．．", "お前達を", "信じてるよ。"]}, {"box": [572, 1072, 615, 1178], "vertical": true, "font_size": 18.0, "lines": ["情けなく", "膝が笑った。"]}]}