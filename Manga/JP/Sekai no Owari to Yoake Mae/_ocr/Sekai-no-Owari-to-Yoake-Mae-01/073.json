{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [851, 116, 872, 224], "vertical": true, "font_size": 18.0, "lines": ["あぁアレな"]}, {"box": [404, 153, 473, 290], "vertical": true, "font_size": 20.0, "lines": ["．．．マジ？", "お前そんなこと", "やってんの？"]}, {"box": [534, 425, 604, 583], "vertical": true, "font_size": 18.0, "lines": ["素人モンのＡＶを", "全国まわって", "撮影してんだよ。"]}, {"box": [219, 481, 294, 628], "vertical": true, "font_size": 21.0, "lines": ["おっと俺は", "カメラ担当だぜ。", "あと汁な。"]}, {"box": [827, 665, 895, 790], "vertical": true, "font_size": 20.0, "lines": ["最終日の女が", "土壇場で", "渋りだしてよ。"]}, {"box": [469, 743, 537, 843], "vertical": true, "font_size": 19.0, "lines": ["予定狂って", "えれー大変", "だったぜ。"]}, {"box": [242, 832, 268, 922], "vertical": true, "font_size": 24.0, "lines": ["．．．へぇ。"]}, {"box": [831, 903, 880, 1176], "vertical": true, "font_size": 21.0, "lines": ["それでその子", "はは．．．", "どうしたの？"]}, {"box": [408, 1057, 504, 1216], "vertical": true, "font_size": 21.0, "lines": ["ちょっと怖い目に", "あってもらって", "山道に置いて", "きた。"]}]}