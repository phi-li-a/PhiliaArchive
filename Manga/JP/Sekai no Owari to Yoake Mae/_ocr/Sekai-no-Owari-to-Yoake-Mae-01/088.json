{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [722, 153, 838, 291], "vertical": true, "font_size": 19.0, "lines": ["先日ついに", "メジャー通算", "２００本異打を", "成し遂げた", "由美ちゃんは、"]}, {"box": [218, 138, 417, 412], "vertical": true, "font_size": 20.0, "lines": ["えぇ〜〜っ", "なんか暗そう", "じゃない？", "やっぱ男は", "もっと筋肉があって", "えきっ", "背ぇ高", "てて車", "外人で"]}, {"box": [764, 506, 809, 651], "vertical": true, "font_size": 21.0, "lines": ["ゲイの", "小松っちゃんは"]}, {"box": [345, 497, 392, 597], "vertical": true, "font_size": 20.0, "lines": ["アタシは", "感じるわ！！"]}, {"box": [196, 299, 244, 428], "vertical": true, "font_size": 22.0, "lines": ["．．．とか", "言ってたけど。"]}, {"box": [205, 556, 299, 695], "vertical": true, "font_size": 20.0, "lines": ["彼の目の", "奥に光る", "世界を変える", "ほどの野心を！！"]}, {"box": [764, 782, 858, 979], "vertical": true, "font_size": 18.0, "lines": ["あんたももう", "１８なんだから", "さっさと処女膜", "破ってもらいなさい！！"]}, {"box": [438, 808, 537, 974], "vertical": true, "font_size": 22.0, "lines": ["アタシは", "渇ききった", "受験生活を", "どうにか潤そうと、"]}, {"box": [293, 808, 363, 965], "vertical": true, "font_size": 21.0, "lines": ["夏期集中講座に", "現れた", "見知らぬ美少年を"]}, {"box": [220, 807, 269, 1007], "vertical": true, "font_size": 21.0, "lines": ["デートに誘ったのだ！！", "超強引に！！"]}, {"box": [639, 1109, 661, 1190], "vertical": true, "font_size": 22.0, "lines": ["ラジャ！！"]}, {"box": [375, 1140, 440, 1183], "vertical": false, "font_size": 20.0, "lines": ["．．．"]}, {"box": [190, 1101, 262, 1240], "vertical": true, "font_size": 19.0, "lines": ["あ、あのさ！！", "堀川くんって", "高校ドコなの！？"]}]}