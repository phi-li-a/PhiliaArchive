{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [736, 142, 903, 438], "vertical": true, "font_size": 20.0, "lines": ["ねぇ晴、", "この敵マジで", "強えんだけど！！", "仲間全員", "やられちったら", "もう勝ち目", "ねーじゃん！！"]}, {"box": [432, 179, 454, 259], "vertical": true, "font_size": 20.0, "lines": ["大丈夫！！"]}, {"box": [320, 234, 390, 393], "vertical": true, "font_size": 20.0, "lines": ["タイムマシンで", "過去に戻って", "やっつけっから！！"]}, {"box": [251, 399, 298, 559], "vertical": true, "font_size": 18.0, "lines": ["やっつけれんの！？", "すげぇ", "！！"]}, {"box": [808, 584, 878, 750], "vertical": true, "font_size": 21.0, "lines": ["なんか", "超必殺技で", "すげーやっつけて、"]}, {"box": [713, 663, 781, 783], "vertical": true, "font_size": 21.0, "lines": ["なんかすげー", "未来が平和に", "なんの"]}, {"box": [800, 831, 896, 990], "vertical": true, "font_size": 20.0, "lines": ["やっぱ悪い奴が", "さかえたためしは", "ないって言う", "からな"]}, {"box": [552, 857, 622, 981], "vertical": true, "font_size": 21.0, "lines": ["もう頭の中で", "話はできてん", "だ！！"]}, {"box": [295, 646, 333, 703], "vertical": true, "font_size": 26.0, "lines": ["．．．晴、"]}, {"box": [224, 682, 272, 772], "vertical": true, "font_size": 26.0, "lines": ["それマジ", "すげーよ。"]}, {"box": [232, 868, 301, 1007], "vertical": true, "font_size": 21.0, "lines": ["月曜までに", "ぜってー描いて", "くるよ！！"]}, {"box": [651, 1125, 721, 1244], "vertical": true, "font_size": 19.0, "lines": ["ねぇ続きは", "いつ見れんの", "カなぁ？"]}, {"box": [212, 1060, 259, 1182], "vertical": true, "font_size": 24.0, "lines": ["すげー", "ブロみて"]}]}