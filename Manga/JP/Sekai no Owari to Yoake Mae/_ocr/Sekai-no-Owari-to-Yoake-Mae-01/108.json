{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [804, 125, 851, 229], "vertical": true, "font_size": 19.0, "lines": ["恋人に", "裏切られて、"]}, {"box": [684, 153, 750, 310], "vertical": true, "font_size": 19.0, "lines": ["親との折り合いも", "悪くて家を", "飛び出して、"]}, {"box": [508, 115, 599, 254], "vertical": true, "font_size": 19.0, "lines": ["日銭を稼ぐため", "ＡＶに出ようと", "したけど直前で", "おじけづいて、"]}, {"box": [346, 146, 465, 267], "vertical": true, "font_size": 19.0, "lines": ["悪い奴らに", "暴行された", "あげく山道に", "捨てられたと", "したら、"]}, {"box": [186, 189, 282, 367], "vertical": true, "font_size": 19.0, "lines": ["１７年しか", "生きてない女子に", "とって十分死ねる", "理由だと思わない？"]}, {"box": [572, 879, 617, 979], "vertical": true, "font_size": 18.0, "lines": ["．．．", "どしたの？"]}, {"box": [224, 681, 273, 800], "vertical": true, "font_size": 26.0, "lines": ["ん．．．", "んんー．．．"]}, {"box": [796, 1070, 820, 1152], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．ん？"]}, {"box": [172, 1085, 245, 1225], "vertical": true, "font_size": 23.0, "lines": ["こ、これだよ、", "私の探していた", "場所は。"]}]}