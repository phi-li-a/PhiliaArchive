{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [645, 155, 692, 284], "vertical": true, "font_size": 20.0, "lines": ["うるせータコ、", "話しかけんな。"]}, {"box": [337, 153, 456, 293], "vertical": true, "font_size": 22.0, "lines": ["今俺は", "人類の平和と", "共存についてで", "頭がいっぱい", "なんだよ。"]}, {"box": [799, 491, 845, 595], "vertical": true, "font_size": 21.0, "lines": ["俺、ラップ", "やるからさ、"]}, {"box": [236, 508, 329, 684], "vertical": true, "font_size": 19.0, "lines": ["ホラお前", "いつだかサンプラー", "興味あるとか", "言ってたじゃん？"]}, {"box": [807, 850, 830, 937], "vertical": true, "font_size": 20.0, "lines": ["観てみろ。"]}, {"box": [809, 850, 853, 1005], "vertical": true, "font_size": 18.0, "lines": ["テレビとネットを"]}, {"box": [667, 847, 761, 1043], "vertical": true, "font_size": 20.0, "lines": ["いくらアホな俺だって", "どんだけ未来に", "期待できないが", "くらいわかるって。"]}, {"box": [219, 797, 239, 829], "vertical": true, "font_size": 20.0, "lines": ["む。"]}, {"box": [208, 790, 246, 838], "vertical": true, "font_size": 32.0, "lines": ["む。"]}, {"box": [597, 1057, 643, 1146], "vertical": true, "font_size": 21.0, "lines": ["んな金", "ねーーし。"]}, {"box": [205, 1136, 272, 1255], "vertical": true, "font_size": 21.0, "lines": ["中坊みたいに", "ＣＤ盗んで", "売ればぁ？"]}]}