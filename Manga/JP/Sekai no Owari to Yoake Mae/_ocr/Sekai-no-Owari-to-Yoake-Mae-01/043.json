{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [510, 211, 579, 320], "vertical": true, "font_size": 20.0, "lines": ["僕の村には", "高速道路が", "走っている。"]}, {"box": [649, 587, 794, 711], "vertical": true, "font_size": 23.0, "lines": ["道路を建設", "する時、", "土地を売った", "お金で、", "無駄にでかい", "家を建てた"]}, {"box": [829, 795, 874, 903], "vertical": true, "font_size": 21.0, "lines": ["いって", "らっしゃい。"]}, {"box": [493, 587, 566, 754], "vertical": true, "font_size": 20.0, "lines": ["といってもそれは", "死んだしいさんの", "若い頃の話で、"]}, {"box": [534, 817, 603, 926], "vertical": true, "font_size": 19.0, "lines": ["今日、帰りは", "何時頃に", "なりそう？"]}, {"box": [324, 589, 393, 756], "vertical": true, "font_size": 21.0, "lines": ["今はただ", "部屋を持て余す", "平凡な母子家庭だ。"]}, {"box": [192, 884, 273, 1164], "vertical": true, "font_size": 18.0, "lines": ["んー", "進路の直談が", "わからない", "あるから遅く", "なるかも"]}]}