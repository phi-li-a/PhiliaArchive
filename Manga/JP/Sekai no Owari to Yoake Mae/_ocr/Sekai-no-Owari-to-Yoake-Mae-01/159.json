{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [573, 130, 642, 271], "vertical": true, "font_size": 18.0, "lines": ["人に何かされて", "うれしい気分に", "なったのなんて、"]}, {"box": [394, 129, 465, 251], "vertical": true, "font_size": 22.0, "lines": ["今月に入って", "初めてかも", "しれない。"]}, {"box": [734, 350, 830, 494], "vertical": true, "font_size": 20.0, "lines": ["彼氏だった", "あの人にこれを", "差し入れで", "持っていったら、"]}, {"box": [232, 490, 277, 635], "vertical": true, "font_size": 18.0, "lines": ["彼は喜んで", "くれるだろうか"]}, {"box": [754, 696, 822, 856], "vertical": true, "font_size": 20.0, "lines": ["渋谷に", "着く頃には", "冷めちゃうよ．．．"]}, {"box": [434, 677, 568, 744], "vertical": false, "font_size": 32.0, "lines": ["吉祥寺駅"]}, {"box": [229, 1096, 299, 1225], "vertical": true, "font_size": 21.0, "lines": ["また", "温め直せば", "いいじゃない。"]}]}