{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [842, 154, 887, 294], "vertical": true, "font_size": 20.0, "lines": ["．．．もしもし", "なんだよコレ？"]}, {"box": [217, 144, 412, 439], "vertical": true, "font_size": 21.0, "lines": ["女子中学生の", "自殺ライブ", "ですよ！", "ネット上で", "自殺の瞬間を", "リアルタイムに", "配信するつもり", "っぽいスね！！"]}, {"box": [784, 485, 876, 643], "vertical": true, "font_size": 20.0, "lines": ["．．．お前さっ", "編集のくせに", "こんなん見つけて", "ヒマな奴だなー．．．"]}, {"box": [349, 470, 408, 514], "vertical": false, "font_size": 32.0, "lines": ["はあああ"]}, {"box": [829, 853, 903, 1002], "vertical": true, "font_size": 22.0, "lines": ["．．．理解", "てきねーな。", "最近のガキって。"]}, {"box": [478, 824, 607, 1035], "vertical": true, "font_size": 20.0, "lines": ["は？", "無理無理", "今さらこんな", "腐ったオヤジに", "何が言える？"]}, {"box": [224, 585, 342, 761], "vertical": true, "font_size": 20.0, "lines": ["やだなぁ", "たまたまですよ。", "先生こそ", "どーせ一行も進んで", "ないんでしょ？"]}, {"box": [603, 957, 710, 1279], "vertical": true, "font_size": 19.0, "lines": ["．．．あぁ一応", "こんなん", "書き込むトコも", "誹謗中傷の的に", "あるのね", "なるに決まってん", "じゃんなぁ。"]}, {"box": [446, 1166, 499, 1197], "vertical": false, "font_size": 31.0, "lines": ["．．．"]}, {"box": [219, 1069, 337, 1247], "vertical": true, "font_size": 20.0, "lines": ["またまたぁ。", "その腐ったオヤジの", "デタラメで大勢の", "読者を救ってきたん", "じゃないですかぁ。"]}]}