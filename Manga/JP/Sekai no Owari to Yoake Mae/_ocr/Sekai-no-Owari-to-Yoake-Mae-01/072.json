{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [755, 158, 806, 262], "vertical": true, "font_size": 22.0, "lines": ["お前達を", "信じてる。"]}, {"box": [245, 225, 316, 364], "vertical": true, "font_size": 21.0, "lines": ["親父は", "俺の何を", "信じてたんだ？"]}, {"box": [613, 480, 681, 616], "vertical": true, "font_size": 19.0, "lines": ["もんやりしつつ", "寝ていると、", "中島から電話"]}, {"box": [360, 473, 456, 641], "vertical": true, "font_size": 21.0, "lines": ["３日後の夕方", "あらためて", "香田と３人で", "会うことになった。"]}, {"box": [813, 739, 855, 857], "vertical": true, "font_size": 18.0, "lines": ["オース中島", "ひざしぶり！！"]}, {"box": [751, 851, 795, 969], "vertical": true, "font_size": 18.0, "lines": ["あいかわらず", "デブだな。"]}, {"box": [511, 746, 555, 828], "vertical": true, "font_size": 20.0, "lines": ["．．．あれ？", "香田は？"]}, {"box": [194, 808, 237, 945], "vertical": true, "font_size": 18.0, "lines": ["もうちょっとて", "来るってよ。"]}, {"box": [632, 1030, 676, 1127], "vertical": true, "font_size": 20.0, "lines": ["よう江園、", "髪切った？"]}, {"box": [170, 1081, 236, 1223], "vertical": true, "font_size": 17.0, "lines": ["．．．そういや中島", "全国ツアーって", "なんだよ？"]}]}