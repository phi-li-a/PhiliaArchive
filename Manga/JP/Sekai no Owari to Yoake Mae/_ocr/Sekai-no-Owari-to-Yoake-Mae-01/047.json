{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [761, 194, 835, 323], "vertical": true, "font_size": 23.0, "lines": ["僕は子供の頃", "喘息持ち", "だった。"]}, {"box": [792, 490, 838, 600], "vertical": true, "font_size": 20.0, "lines": ["杉崎くんも", "見学なんだ。"]}, {"box": [221, 262, 316, 423], "vertical": true, "font_size": 21.0, "lines": ["その大義名分が", "あるから、僕は", "マラソンの授業を", "見学できる。"]}, {"box": [630, 716, 723, 856], "vertical": true, "font_size": 20.0, "lines": ["．．．そういえば", "大沢さんて毎回", "体育、見学", "してるよね。"]}, {"box": [482, 726, 554, 856], "vertical": true, "font_size": 20.0, "lines": ["あたし実は", "不治の病に", "冒されてるの"]}, {"box": [499, 1118, 523, 1190], "vertical": true, "font_size": 24.0, "lines": ["嘘だよ。"]}]}