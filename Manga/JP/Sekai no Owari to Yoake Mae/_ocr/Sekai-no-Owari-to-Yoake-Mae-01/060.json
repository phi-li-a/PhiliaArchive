{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [778, 162, 842, 317], "vertical": true, "font_size": 28.0, "lines": ["．．．あい、", "江園ですけど。"]}, {"box": [232, 112, 359, 378], "vertical": true, "font_size": 21.0, "lines": ["．．．部長", "突然", "すみません、", "携帯つながら", "なくて．．．"]}, {"box": [761, 458, 847, 655], "vertical": true, "font_size": 27.0, "lines": ["え？", "あのー", "．．．"]}, {"box": [537, 447, 589, 576], "vertical": true, "font_size": 23.0, "lines": ["お兄ちゃん", "電話誰ー？"]}, {"box": [253, 529, 346, 706], "vertical": true, "font_size": 18.0, "lines": ["部長はずっと", "会社に尽くして", "真面目に働いて", "らしたと思います！"]}, {"box": [782, 776, 854, 955], "vertical": true, "font_size": 21.0, "lines": ["どうして部長が", "解雇されなきゃ", "ならないんですか！？"]}, {"box": [524, 777, 620, 916], "vertical": true, "font_size": 20.0, "lines": ["．．．えーと、", "親父って今", "出張中なんじゃ", "ないんすか？"]}, {"box": [236, 920, 260, 981], "vertical": true, "font_size": 24.0, "lines": ["あれ？"]}, {"box": [630, 1094, 700, 1197], "vertical": true, "font_size": 22.0, "lines": ["．．．僕は納得", "できません", "よ．．．"]}, {"box": [368, 1098, 432, 1222], "vertical": true, "font_size": 30.0, "lines": ["親父が", "失踪した。"]}]}