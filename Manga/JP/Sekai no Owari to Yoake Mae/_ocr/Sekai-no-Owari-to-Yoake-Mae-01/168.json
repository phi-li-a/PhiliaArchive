{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [638, 165, 847, 490], "vertical": true, "font_size": 19.0, "lines": ["．．．それよか", "さっきの話！！", "愛と平和の歌で", "レゲエ界の頂点", "目指してビッグに", "なろうぜ！？", "そしたらリアル女と", "やりまくりよ？"]}, {"box": [244, 356, 314, 516], "vertical": true, "font_size": 22.0, "lines": ["．．．お前さっきより", "話、でかくなって", "るよ。"]}, {"box": [700, 610, 778, 740], "vertical": true, "font_size": 20.0, "lines": ["もういいよ", "そういうのは。"]}, {"box": [678, 613, 697, 716], "vertical": true, "font_size": 19.0, "lines": ["メンドクセ。"]}, {"box": [781, 926, 824, 1047], "vertical": true, "font_size": 18.0, "lines": ["ありゃろぁ", "らっしゃ～～～"]}, {"box": [555, 608, 626, 787], "vertical": true, "font_size": 20.0, "lines": ["きっと俺の人生には", "サンプラーとか", "関係ねーんだよ。"]}, {"box": [324, 603, 445, 784], "vertical": true, "font_size": 22.0, "lines": ["今の俺はいかに", "安全なサイトから", "裏動画を落とすかが", "人生の最重要課題", "だからな。"]}, {"box": [521, 859, 571, 1007], "vertical": true, "font_size": 23.0, "lines": ["今さらどう", "あがいたトコで、"]}, {"box": [201, 855, 274, 982], "vertical": true, "font_size": 24.0, "lines": ["未来なんて", "そうだいして", "変わんねーよ。"]}, {"box": [490, 1180, 512, 1213], "vertical": true, "font_size": 22.0, "lines": ["あ。"]}, {"box": [478, 1170, 525, 1226], "vertical": true, "font_size": 32.0, "lines": ["あ。"]}]}