{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [807, 131, 903, 328], "vertical": true, "font_size": 20.0, "lines": ["結局、一歩でも", "外に出たら、", "バカで声の大きな奴が", "勝つ世の中なのさ。"]}, {"box": [490, 160, 585, 328], "vertical": true, "font_size": 19.0, "lines": ["何も生産せず、", "誰にも迷惑かけず、", "そして猫のように", "人知れず死ぬんだ。"]}, {"box": [620, 414, 715, 591], "vertical": true, "font_size": 20.0, "lines": ["だからそろそろ", "本格引きこもりでも", "始めようかって", "考えてるんだよ。"]}, {"box": [453, 415, 473, 496], "vertical": true, "font_size": 18.0, "lines": ["．．．なんか"]}, {"box": [303, 408, 353, 558], "vertical": true, "font_size": 22.0, "lines": ["．．．なんか", "言ってやりたい。"]}, {"box": [809, 628, 877, 746], "vertical": true, "font_size": 20.0, "lines": ["てもそれじゃ", "生きてる意味", "ないじゃん？"]}, {"box": [697, 687, 767, 825], "vertical": true, "font_size": 20.0, "lines": ["．．．それに", "家族だって", "いるんだし．．．"]}, {"box": [824, 902, 870, 1060], "vertical": true, "font_size": 20.0, "lines": ["．．．江園さんは？", "進路どうすんの？"]}, {"box": [329, 635, 373, 759], "vertical": true, "font_size": 19.0, "lines": ["ウチの親は", "バカだからね"]}, {"box": [528, 932, 595, 1031], "vertical": true, "font_size": 32.0, "lines": ["いやあ．．．アタシはフツーに．．．"]}, {"box": [221, 683, 292, 870], "vertical": true, "font_size": 19.0, "lines": ["あの人達、俺よりも", "資産の運用で", "頭がいっぱいなんだ。"]}, {"box": [425, 922, 597, 1244], "vertical": true, "font_size": 20.0, "lines": ["いやあ．．．", "アタシは", "フツーに．．．", "それより", "お父さんが会社", "クビになって", "いなくなっちゃって", "それが心配．．．"]}, {"box": [321, 975, 340, 1079], "vertical": true, "font_size": 20.0, "lines": ["わかるなぁ、"]}, {"box": [198, 1077, 292, 1256], "vertical": true, "font_size": 20.0, "lines": ["君のお父さんは", "何もかも信じられ", "なくなっちゃったん", "だね。"]}]}