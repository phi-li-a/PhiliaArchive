{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [769, 120, 864, 280], "vertical": true, "font_size": 21.0, "lines": ["時期を同じくして", "大沢さんも", "学校に来なく", "なった。"]}, {"box": [528, 124, 549, 252], "vertical": true, "font_size": 18.0, "lines": ["．．．なんとなく、"]}, {"box": [443, 123, 465, 249], "vertical": true, "font_size": 22.0, "lines": ["そしてきっと、"]}, {"box": [282, 119, 382, 306], "vertical": true, "font_size": 22.0, "lines": ["大沢さんは", "自由を求めて", "高速道路を", "行ってしまったんだ。"]}, {"box": [206, 121, 255, 269], "vertical": true, "font_size": 22.0, "lines": ["と、思うことに", "している。"]}, {"box": [616, 426, 709, 587], "vertical": true, "font_size": 20.0, "lines": ["馬場先生と", "駆け落ちしたとか", "病気で死んだとか", "噂がたったけど。"]}, {"box": [516, 404, 547, 462], "vertical": true, "font_size": 29.0, "lines": ["なあ。"]}, {"box": [215, 451, 288, 591], "vertical": true, "font_size": 23.0, "lines": ["来週、", "俺ら二人で", "渋谷行かねぇ？"]}, {"box": [817, 634, 867, 726], "vertical": true, "font_size": 25.0, "lines": ["．．．別に", "いいけど、"]}, {"box": [759, 703, 781, 783], "vertical": true, "font_size": 25.0, "lines": ["なんて？"]}, {"box": [776, 939, 798, 1047], "vertical": true, "font_size": 21.0, "lines": ["いいけどさ。"]}, {"box": [294, 629, 368, 809], "vertical": true, "font_size": 21.0, "lines": ["バッカ、お前", "ギャルをナンパしに", "いくんだよ！！"]}, {"box": [201, 728, 271, 829], "vertical": true, "font_size": 21.0, "lines": ["男をあげる", "旅に出よう", "ぜ！！"]}, {"box": [693, 1026, 735, 1151], "vertical": true, "font_size": 21.0, "lines": ["お前．．．その頭", "不利だよ？"]}, {"box": [297, 1032, 340, 1152], "vertical": true, "font_size": 18.0, "lines": ["そーゆうこと", "言うなよ。"]}, {"box": [202, 1226, 432, 1255], "vertical": false, "font_size": 26.0, "lines": ["「ルファルフィー完一"]}]}