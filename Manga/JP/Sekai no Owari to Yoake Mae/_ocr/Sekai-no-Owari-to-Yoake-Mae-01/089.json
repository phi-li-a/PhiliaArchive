{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [802, 180, 850, 311], "vertical": true, "font_size": 23.0, "lines": ["学校は", "行ってないよ。"]}, {"box": [673, 271, 745, 429], "vertical": true, "font_size": 23.0, "lines": ["いじめられそうに", "なったから", "辞めた。"]}, {"box": [796, 543, 816, 661], "vertical": true, "font_size": 17.0, "lines": ["．．．ありゃん？"]}, {"box": [312, 550, 341, 613], "vertical": true, "font_size": 23.0, "lines": ["あ．．．"]}, {"box": [215, 609, 284, 690], "vertical": true, "font_size": 23.0, "lines": ["あぁー", "そうなん", "だぁー"]}, {"box": [781, 757, 874, 905], "vertical": true, "font_size": 21.0, "lines": ["そういう", "動物っぽい", "力争いって", "バカらしくてさ。"]}, {"box": [512, 772, 584, 894], "vertical": true, "font_size": 21.0, "lines": ["．．．あっ、", "じゃあ大検", "受けるんだ！！"]}, {"box": [211, 856, 306, 940], "vertical": true, "font_size": 23.0, "lines": ["だから", "夏期講習", "来てるん", "でしょ？"]}, {"box": [612, 1053, 709, 1175], "vertical": true, "font_size": 21.0, "lines": ["学校っていう", "システム自体", "そもそも疑問", "だったし。"]}, {"box": [333, 1052, 356, 1120], "vertical": true, "font_size": 22.0, "lines": ["．．．いや、"]}, {"box": [184, 1100, 301, 1221], "vertical": true, "font_size": 22.0, "lines": ["自分の学力を", "どこまで", "高められるか", "試したかった", "だけで。"]}]}