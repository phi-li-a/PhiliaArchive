{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [754, 162, 846, 320], "vertical": true, "font_size": 20.0, "lines": ["事実、世の中は", "たくさんの悪意に", "満ちていると", "僕は思う。"]}, {"box": [507, 428, 528, 494], "vertical": true, "font_size": 21.0, "lines": ["けれど、"]}, {"box": [159, 446, 279, 612], "vertical": true, "font_size": 20.0, "lines": ["幸運や", "人の優しさも", "君のすぐそばに", "きっと隠れてるん", "じゃないだろうか。"]}, {"box": [730, 739, 821, 859], "vertical": true, "font_size": 19.0, "lines": ["少なくとも、", "朝は誰にでも", "平等にやって", "くるから。"]}, {"box": [406, 702, 606, 739], "vertical": false, "font_size": 32.0, "lines": ["０１／２５／０６：０５"]}, {"box": [202, 830, 269, 946], "vertical": true, "font_size": 18.0, "lines": ["そこで", "何を撮むかは", "モゾダナ"]}, {"box": [158, 1092, 672, 1173], "vertical": false, "font_size": 32.0, "lines": ["ｏｓｏｎ＞＞ありがとう。"]}, {"box": [399, 1278, 471, 1300], "vertical": false, "font_size": 20.0, "lines": ["あ"]}]}