{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [804, 151, 893, 331], "vertical": true, "font_size": 19.0, "lines": ["．．．なんかさー", "いまさらだけど", "１５万も家賃払えるか、", "不安だなー．．．"]}, {"box": [263, 128, 328, 242], "vertical": true, "font_size": 17.0, "lines": ["私は安定して", "るけどキミが", "なーー．．．"]}, {"box": [738, 359, 827, 512], "vertical": true, "font_size": 19.0, "lines": ["．．．二人で出せば", "なんとかなるって", "言ったの、", "お前だろ？"]}, {"box": [207, 407, 320, 562], "vertical": true, "font_size": 19.0, "lines": ["バッカ、お前．．．", "今に見てろって！", "瞬く間に売れっ子", "カメラマンだよ！？", "．．．きっと。"]}, {"box": [718, 811, 863, 1034], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．て？", "どうだったの。", "仕事は？", "グラビアの", "お姉ちゃん達と", "仲良くなれた？"]}, {"box": [573, 616, 664, 770], "vertical": true, "font_size": 21.0, "lines": ["あの頃の私が", "思い描いていた", "素晴らしい世界が", "なんだったのか、"]}, {"box": [437, 615, 506, 751], "vertical": true, "font_size": 21.0, "lines": ["今の私にはもう", "最気桜のように", "おぼろげだ。"]}, {"box": [342, 826, 455, 998], "vertical": true, "font_size": 19.0, "lines": ["ふざけんなって。", "ホノルル空港で", "カメラやら機材やら", "盗まれて、みんな", "大慌てだよ。"]}, {"box": [221, 912, 311, 1073], "vertical": true, "font_size": 19.0, "lines": ["俺らアシが", "英語できねーのに、", "街中探しまわって", "ごぁ．．．．．．"]}, {"box": [704, 1112, 726, 1196], "vertical": true, "font_size": 22.0, "lines": ["それとも、"]}, {"box": [606, 1112, 652, 1245], "vertical": true, "font_size": 21.0, "lines": ["何も知らないが", "ゆえに、"]}, {"box": [430, 1109, 545, 1284], "vertical": true, "font_size": 20.0, "lines": ["あの頃の私は", "素晴らしい世界の", "中にいることに", "気が付かなかったの", "かもしれない。"]}, {"box": [354, 1113, 399, 1216], "vertical": true, "font_size": 20.0, "lines": ["．．．なんて", "考えてみる。"]}]}