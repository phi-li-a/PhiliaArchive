{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [778, 162, 859, 303], "vertical": true, "font_size": 23.0, "lines": ["．．．テキトーに", "流しちゃう", "自分に。"]}, {"box": [237, 216, 368, 525], "vertical": true, "font_size": 21.0, "lines": ["．．．あ、香田？", "中島は崖から", "落ちて死んだよ。", "．．．今日は", "２人で", "会おうぜ。"]}, {"box": [796, 615, 864, 791], "vertical": true, "font_size": 19.0, "lines": ["．．．江園くん、", "髪型そっちのほうが", "似合ってるよ"]}, {"box": [759, 891, 871, 1095], "vertical": true, "font_size": 23.0, "lines": ["．．．ごめん", "やっぱり", "あたし", "帰るね。"]}, {"box": [468, 733, 539, 817], "vertical": true, "font_size": 25.0, "lines": ["あれ？", "近くに", "いんの？"]}, {"box": [337, 658, 407, 781], "vertical": true, "font_size": 22.0, "lines": ["お、俺さ、", "また書こうと", "思って、"]}, {"box": [519, 947, 612, 1086], "vertical": true, "font_size": 20.0, "lines": ["．．．なんか君とは", "もう会わない", "ほうがいいと", "思うんだ"]}, {"box": [447, 1090, 493, 1229], "vertical": true, "font_size": 20.0, "lines": ["．．．オイ", "なんだよソレ！？"]}, {"box": [202, 1096, 268, 1215], "vertical": true, "font_size": 17.0, "lines": ["ちょっとだけ", "脚本書き出し", "だんだよ！！"]}]}