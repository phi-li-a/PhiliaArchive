{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [604, 155, 715, 548], "vertical": true, "font_size": 20.0, "lines": ["思い描いていた", "くい止める術が", "理想の家庭は", "わからず、", "少しずつ崩れ、", "ただ私は仕事に", "打ち込んだが．．．"]}, {"box": [196, 507, 266, 615], "vertical": true, "font_size": 20.0, "lines": ["結局会社に", "首を切られ", "このザマだ。"]}, {"box": [809, 699, 855, 787], "vertical": true, "font_size": 21.0, "lines": ["．．．家族に", "裏切られ"]}, {"box": [735, 1105, 781, 1193], "vertical": true, "font_size": 21.0, "lines": ["社会に", "裏切られ"]}, {"box": [453, 1123, 497, 1211], "vertical": true, "font_size": 21.0, "lines": ["会社に", "変切られ"]}]}