{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [581, 159, 654, 317], "vertical": true, "font_size": 21.0, "lines": ["ねぇねぇ、", "さっきのもう１回", "言ってみて？"]}, {"box": [198, 211, 271, 332], "vertical": true, "font_size": 22.0, "lines": ["じ．．．実はボク", "前からキミの", "コト．．．．．．"]}, {"box": [669, 606, 870, 963], "vertical": true, "font_size": 27.0, "lines": ["あたしが", "好きだって！？", "それが", "汚い顔", "なんだよ！！", "ぶら下げて、", "今日はどこまで", "エロゲーの", "お買い物ですか！？"]}, {"box": [611, 905, 652, 995], "vertical": true, "font_size": 20.0, "lines": ["そんなコト", "一言も．．．"]}, {"box": [177, 606, 364, 960], "vertical": true, "font_size": 23.0, "lines": ["どーせお前、", "普段は親元で", "引きこもってる", "ネットの中", "オナニー童貞", "では神様", "野郎のクチだろ！？", "気分っつー", "アレだろ！？"]}, {"box": [602, 1029, 851, 1260], "vertical": true, "font_size": 24.0, "lines": ["オメーみたいな", "なんの努力もしない", "奴に限って、", "ありのままの", "自分を", "受け入れてくれ", "とかって言うん", "！！", "だよなぁー"]}, {"box": [247, 1048, 349, 1245], "vertical": true, "font_size": 28.0, "lines": ["てめぇ何様だ！？", "子宮の中から", "人生やり直せ！！"]}, {"box": [171, 1160, 198, 1264], "vertical": true, "font_size": 27.0, "lines": ["ひ～～～"]}]}