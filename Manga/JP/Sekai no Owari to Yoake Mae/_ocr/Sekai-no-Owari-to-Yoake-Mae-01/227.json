{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [691, 159, 855, 429], "vertical": true, "font_size": 21.0, "lines": ["俺は", "わかってたぜ。", "「自分はお前ら", "とは違う」って", "態度で一線", "引いてたもんな。"]}, {"box": [228, 295, 346, 465], "vertical": true, "font_size": 21.0, "lines": ["今だって本当は", "「小さな田舎町で", "満足できる奴らは", "幸せだ」って言いた", "かったんだろ？"]}, {"box": [314, 597, 406, 744], "vertical": true, "font_size": 18.0, "lines": ["．．．それを今更", "孤独だなんて", "言われても、", "同情できねぇよ。"]}, {"box": [508, 844, 601, 1024], "vertical": true, "font_size": 20.0, "lines": ["お前だって", "逃げるために", "東京に行った訳じゃ", "ないんだろ？"]}, {"box": [224, 652, 267, 774], "vertical": true, "font_size": 18.0, "lines": ["自分で選んだ", "道じゃねぇか"]}, {"box": [661, 1057, 758, 1216], "vertical": true, "font_size": 22.0, "lines": ["．．．．．別に", "ごっちはこっちで", "みんな必死に", "やってんだ。"]}, {"box": [355, 1103, 449, 1243], "vertical": true, "font_size": 22.0, "lines": ["だったら", "ぐだぐだ言って", "ねーで", "がんばんだよ。"]}]}