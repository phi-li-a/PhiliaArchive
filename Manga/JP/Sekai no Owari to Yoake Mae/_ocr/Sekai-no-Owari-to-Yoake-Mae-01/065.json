{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [760, 149, 876, 335], "vertical": true, "font_size": 19.0, "lines": ["一年半振りに", "会った香田は", "ちょっと大人っぽく、", "そしてやっぱり", "眩しかった。"]}, {"box": [250, 194, 345, 353], "vertical": true, "font_size": 20.0, "lines": ["東京帰って", "くるたびホント", "人多くてびっくり", "するよ。"]}, {"box": [776, 519, 846, 674], "vertical": true, "font_size": 22.0, "lines": ["つーか子供", "置いてきちゃって", "いいのかよ？"]}, {"box": [240, 594, 308, 693], "vertical": true, "font_size": 19.0, "lines": ["たまには", "息抜きも", "必要なの！！"]}, {"box": [824, 770, 892, 909], "vertical": true, "font_size": 18.0, "lines": ["．．．そういえば", "中島くんは", "来られないの？"]}, {"box": [203, 802, 350, 1165], "vertical": true, "font_size": 21.0, "lines": ["こうして普通に", "お酒飲んでると、", "大人になっちゃったん", "高校卒業してから", "だなーって気が", "みんな", "しない？", "バラバラ", "だもんねー"]}, {"box": [796, 960, 864, 1085], "vertical": true, "font_size": 18.0, "lines": ["全国ツアーが", "急に延長に", "なったんだと。"]}, {"box": [673, 998, 692, 1075], "vertical": true, "font_size": 18.0, "lines": ["何それ？"]}, {"box": [602, 1096, 646, 1196], "vertical": true, "font_size": 20.0, "lines": ["意味わかん", "ねーだろ？"]}, {"box": [199, 1184, 228, 1240], "vertical": true, "font_size": 26.0, "lines": ["なあ。"]}]}