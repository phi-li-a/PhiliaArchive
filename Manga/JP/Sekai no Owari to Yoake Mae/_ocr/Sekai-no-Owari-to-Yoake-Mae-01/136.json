{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [595, 109, 837, 247], "vertical": true, "font_size": 18.0, "lines": ["清潔感溢れる", "サラサラ髪に", "シャープな顎！！", "スーツか似合う", "細身の長身に、", "朝日を見て", "ちょっと眉を", "しかめる", "ギャップが", "超カワイイ！！"]}, {"box": [334, 163, 379, 304], "vertical": true, "font_size": 21.0, "lines": ["．．．でも少し", "疲れてるみたい"]}, {"box": [334, 168, 381, 306], "vertical": true, "font_size": 32.0, "lines": ["．．．でも少し疲れてるみたい。"]}, {"box": [163, 162, 302, 362], "vertical": true, "font_size": 21.0, "lines": ["きっと若いのに他事が", "できるばっかりに、", "無能なハゲの上司に", "いきなり大きな", "商談を任されて", "しまったのね！！"]}, {"box": [403, 497, 438, 511], "vertical": false, "font_size": 14.0, "lines": ["すじっ！"]}, {"box": [189, 526, 217, 630], "vertical": true, "font_size": 23.0, "lines": ["１０５円です"]}, {"box": [643, 700, 671, 796], "vertical": true, "font_size": 28.0, "lines": ["あ．．．"]}, {"box": [389, 686, 438, 856], "vertical": true, "font_size": 24.0, "lines": ["．．．でも．．．．．", "でも、ごめんね．．．"]}, {"box": [482, 922, 528, 992], "vertical": true, "font_size": 27.0, "lines": ["という訳かー"]}, {"box": [185, 752, 259, 914], "vertical": true, "font_size": 21.0, "lines": ["私はあなただけの", "ものになることは", "できないの．．．"]}, {"box": [780, 1070, 849, 1187], "vertical": true, "font_size": 18.0, "lines": ["．．．実はボク", "前からキミの", "こと．．．．．．"]}, {"box": [477, 1075, 499, 1217], "vertical": true, "font_size": 18.0, "lines": ["．．．みたいな！？"]}, {"box": [181, 1064, 276, 1223], "vertical": true, "font_size": 19.0, "lines": ["だって爽子は．．．", "炎子はみんなに", "愛される英子", "なんだもん！！"]}]}