{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [796, 155, 866, 314], "vertical": true, "font_size": 20.0, "lines": ["：お兄ちゃん", "こういう時って", "やっぱ捜索願い！？"]}, {"box": [345, 150, 389, 329], "vertical": true, "font_size": 20.0, "lines": ["．．．死んじゃってたら", "どうする？"]}, {"box": [668, 315, 760, 416], "vertical": true, "font_size": 19.0, "lines": ["そのうち", "テキトーに", "帰ってくん", "だろー？"]}, {"box": [430, 457, 635, 625], "vertical": true, "font_size": 21.0, "lines": ["思い返せば", "いなくなる当日", "突然叩き起こされ", "珍しく朝食を", "作り出したりして、", "確かに親父は", "変だった。"]}, {"box": [233, 297, 302, 433], "vertical": true, "font_size": 19.0, "lines": ["．．．その場合", "生命保険て", "おりんのかな？"]}, {"box": [700, 885, 750, 972], "vertical": true, "font_size": 25.0, "lines": ["俺は、", "お前達を"]}, {"box": [328, 681, 350, 765], "vertical": true, "font_size": 23.0, "lines": ["．．．親父、"]}, {"box": [228, 742, 275, 822], "vertical": true, "font_size": 23.0, "lines": ["なんすか", "コレ．．．"]}, {"box": [358, 935, 380, 1063], "vertical": true, "font_size": 22.0, "lines": ["信じてるよ。"]}]}