{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [643, 132, 736, 272], "vertical": true, "font_size": 19.0, "lines": ["．．．ふとした時に", "恐ろしく孤独に", "なる瞬間が", "あるんだ。"]}, {"box": [420, 134, 599, 345], "vertical": true, "font_size": 19.0, "lines": ["外に出たって", "街には他人しか", "いなくて、", "なんでもある", "けれど結局", "その全てが自分の", "ものではなくて、"]}, {"box": [183, 177, 276, 376], "vertical": true, "font_size": 20.0, "lines": ["自分が一体何者で、", "どこで何をしてるのか", "すらわからなく", "なって．．．"]}, {"box": [211, 467, 303, 608], "vertical": true, "font_size": 18.0, "lines": ["今日こっちに", "帰ってきたのは", "寂しかったから", "．．．", "力もなー"]}, {"box": [700, 677, 838, 898], "vertical": true, "font_size": 21.0, "lines": ["でも", "なんか．．．", "やっぱりここに", "自分の居場所は", "ないんだな．．．"]}, {"box": [231, 707, 360, 910], "vertical": true, "font_size": 21.0, "lines": ["．．．けど来て", "良かった。", "みんな", "元気そうで", "なによりだよ。"]}, {"box": [774, 988, 818, 1135], "vertical": true, "font_size": 18.0, "lines": ["お前はホント", "むかつく奴だな。"]}, {"box": [231, 1066, 279, 1197], "vertical": true, "font_size": 23.0, "lines": ["昔から", "そうだったよ。"]}]}