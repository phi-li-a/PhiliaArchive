{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [760, 181, 804, 307], "vertical": true, "font_size": 20.0, "lines": ["ホント．．．", "ホントごめん。"]}, {"box": [239, 182, 282, 348], "vertical": true, "font_size": 32.0, "lines": ["この前の話．．．あれ、ウソなんだ。"]}, {"box": [690, 304, 793, 596], "vertical": true, "font_size": 27.0, "lines": ["ちょっと", "待っ．．．．．", "ちょ．．．"]}, {"box": [179, 179, 286, 598], "vertical": true, "font_size": 20.0, "lines": ["この前の話．．．", "．．．旦那も子供も", "あれ、ウソなんだ。", "ちゃんといるし、", "あたしは普通の", "幸せな主婦だよ。"]}, {"box": [764, 759, 834, 898], "vertical": true, "font_size": 20.0, "lines": ["ただ少し、", "今の生活に", "飽きちゃって．．．"]}, {"box": [694, 876, 806, 1194], "vertical": true, "font_size": 28.0, "lines": ["だって", "あの涙．．．", "ウソだろ！？"]}, {"box": [599, 1072, 668, 1175], "vertical": true, "font_size": 19.0, "lines": ["そういえば", "この大きな", "父が点は、"]}, {"box": [445, 1070, 543, 1230], "vertical": true, "font_size": 24.0, "lines": ["いつも", "他人顔をした", "人で溢れかえって", "いてー"]}, {"box": [158, 1035, 250, 1210], "vertical": true, "font_size": 18.0, "lines": ["．．．あたし達", "このままヤな感じに", "大人になっちゃう", "のかな？"]}]}