{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [372, 608, 393, 715], "vertical": true, "font_size": 18.0, "lines": ["そう思った。"]}, {"box": [593, 608, 707, 761], "vertical": true, "font_size": 20.0, "lines": ["こんな気持ちに", "なる日が、", "人生であと何回", "あるかわからない", "けれど、"]}, {"box": [459, 609, 526, 744], "vertical": true, "font_size": 32.0, "lines": ["家に帰ったら大急ぎで手紙を書こう．．．"]}, {"box": [456, 608, 526, 744], "vertical": true, "font_size": 20.0, "lines": ["家に帰ったら", "大急ぎで手紙を", "昔こう．．．"]}, {"box": [476, 938, 560, 1119], "vertical": true, "font_size": 23.0, "lines": ["「お元気ですか？", "いつかの私へ", "いつかの私より」"]}, {"box": [195, 1219, 453, 1250], "vertical": false, "font_size": 27.0, "lines": ["素晴らしいい世界一完一"]}]}