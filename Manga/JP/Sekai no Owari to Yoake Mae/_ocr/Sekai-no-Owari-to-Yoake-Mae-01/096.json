{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [748, 163, 822, 262], "vertical": true, "font_size": 20.0, "lines": ["顔が好みな", "だけにより", "むかつく！！"]}, {"box": [411, 172, 529, 338], "vertical": true, "font_size": 22.0, "lines": ["そりゃアタシは", "頭悪いし", "政治も", "世の中のことも", "よく知らないけど、"]}, {"box": [255, 175, 350, 293], "vertical": true, "font_size": 22.0, "lines": ["アタシは", "アタシなりに", "悩んで", "一生懸命"]}, {"box": [232, 174, 352, 295], "vertical": true, "font_size": 22.0, "lines": ["やってんだ！！"]}, {"box": [190, 380, 283, 517], "vertical": true, "font_size": 18.0, "lines": ["．．．お姉ちゃんは", "なんでこう", "自由に生きられ", "るんだろう．．．"]}, {"box": [703, 606, 840, 817], "vertical": true, "font_size": 24.0, "lines": ["お父さ～～～ん", "．．．", "さっさと", "帰って", "きて〜"]}, {"box": [321, 716, 395, 818], "vertical": true, "font_size": 23.0, "lines": ["．．．なに？", "お兄ちゃん", "失恋？"]}, {"box": [713, 960, 833, 1143], "vertical": true, "font_size": 22.0, "lines": ["ウチは", "お母さんいないから、", "世界のことより", "家事で頭が", "いっぱいなの！！"]}, {"box": [449, 1077, 519, 1162], "vertical": true, "font_size": 22.0, "lines": ["なぁ若菜、", "髪切って", "くんね？"]}, {"box": [180, 912, 274, 1201], "vertical": true, "font_size": 20.0, "lines": ["むしろ明日は", "ちげーよ", "勝負の日だから", "イケてる風に", "頼むぜ。"]}]}