{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [773, 101, 842, 251], "vertical": true, "font_size": 20.0, "lines": ["あなたは昔から", "少しひねくれてて", "少し悲観的で、"]}, {"box": [368, 124, 435, 267], "vertical": true, "font_size": 19.0, "lines": ["難しいことを", "悩んでるようで", "実はからっぽで、"]}, {"box": [175, 388, 292, 559], "vertical": true, "font_size": 23.0, "lines": ["あなたがいつか、", "つまらない人間に", "なってしまうんじゃ", "ないかと実はべ配", "だったりします。"]}, {"box": [700, 874, 841, 1044], "vertical": true, "font_size": 23.0, "lines": ["ところで", "今朝のニュースは", "あなたが大ファンの", "ハリウッドスターの", "来日で話題は", "持ちきりでした。"]}, {"box": [284, 650, 329, 793], "vertical": true, "font_size": 18.0, "lines": ["．．．余計な", "お世話だっつの。"]}, {"box": [211, 1003, 332, 1169], "vertical": true, "font_size": 23.0, "lines": ["〈昨日までは", "両親と妹を殺した", "高校生の事件で", "大騒ぎだったのに、", "おかしな話です。〉"]}]}