{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [732, 125, 756, 324], "vertical": true, "font_size": 20.0, "lines": ["この人ゴミの中じゃ．．．"]}, {"box": [684, 127, 706, 231], "vertical": true, "font_size": 20.0, "lines": ["彼女の姿も、"]}, {"box": [611, 124, 656, 263], "vertical": true, "font_size": 20.0, "lines": ["いつの間にか", "失ってた何かも"]}, {"box": [336, 116, 413, 256], "vertical": true, "font_size": 21.0, "lines": ["俺にはもう", "見つけることは", "できないのか？"]}, {"box": [761, 421, 817, 550], "vertical": true, "font_size": 28.0, "lines": ["．．．脚本", "今度こそは、"]}, {"box": [319, 818, 343, 971], "vertical": true, "font_size": 22.0, "lines": ["がんばってね"]}, {"box": [772, 1072, 798, 1190], "vertical": true, "font_size": 24.0, "lines": ["香田さん！！"]}, {"box": [184, 1109, 298, 1275], "vertical": true, "font_size": 23.0, "lines": ["聞いたんだ。", "君が役者", "目指してるって", "こと！！"]}]}