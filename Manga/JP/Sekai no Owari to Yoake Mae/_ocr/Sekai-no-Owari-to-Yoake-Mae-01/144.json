{"version": "0.1.6", "img_width": 980, "img_height": 1329, "blocks": [{"box": [476, 173, 568, 332], "vertical": true, "font_size": 18.0, "lines": ["そして夕方には", "核攻撃にも耐える", "秘密基地に", "帰還します。"]}, {"box": [188, 525, 285, 689], "vertical": true, "font_size": 23.0, "lines": ["．．．市の", "アパートで、", "段ボールに入った", "幼児の遺体が．．．"]}, {"box": [530, 782, 651, 981], "vertical": true, "font_size": 21.0, "lines": ["．．．被告に対し", "懲役２年", "執行猶予３年の", "判決が下され、", "それに対し遺族は．．．"]}, {"box": [686, 751, 826, 904], "vertical": false, "font_size": 22.5, "lines": ["おおおーっ", "ちゃんとか世代通りの"]}, {"box": [763, 729, 865, 879], "vertical": false, "font_size": 23.0, "lines": ["キャンセット", "そんなことで"]}, {"box": [674, 825, 867, 1125], "vertical": false, "font_size": 28.0, "lines": ["それと数多く同じとなのばかり部"]}, {"box": [189, 1101, 258, 1249], "vertical": true, "font_size": 20.0, "lines": ["それから英子は", "ちょっとだけ", "考えごとをして、"]}, {"box": [796, 921, 895, 1090], "vertical": false, "font_size": 22.5, "lines": ["マッサージャー", "やるか"]}, {"box": [734, 988, 848, 1166], "vertical": false, "font_size": 27.0, "lines": ["せどせなのっ！"]}]}