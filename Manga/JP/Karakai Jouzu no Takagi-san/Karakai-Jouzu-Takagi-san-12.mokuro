7, 222], "vertical": true, "font_size": 18.0, "lines": ["えぐみも", "あるよねー。"]}, {"box": [187, 111, 208, 177], "vertical": true, "font_size": 20.0, "lines": ["なんだ。"]}, {"box": [731, 533, 747, 652], "vertical": true, "font_size": 20.0, "lines": ["そうなんだよ。"]}, {"box": [611, 520, 686, 672], "vertical": true, "font_size": 20.0, "lines": ["ホント", "なんで朝から", "ピーマンなんて．．．"]}, {"box": [154, 532, 238, 621], "vertical": true, "font_size": 24.0, "lines": ["私は別に", "嫌いじゃ", "ないけど。"]}, {"box": [370, 920, 398, 1001], "vertical": true, "font_size": 26.0, "lines": ["ええ！？"]}], "img_path": "058.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [694, 60, 732, 118], "vertical": true, "font_size": 32.0, "lines": ["西片、"]}, {"box": [274, 79, 322, 183], "vertical": true, "font_size": 22.0, "lines": ["ピーマン", "嫌いなんだ。"]}, {"box": [168, 48, 191, 164], "vertical": true, "font_size": 20.0, "lines": ["やられた．．．！！"]}, {"box": [407, 473, 465, 554], "vertical": true, "font_size": 23.0, "lines": ["お子様舌", "だねぇ。"]}, {"box": [135, 449, 165, 557], "vertical": true, "font_size": 30.0, "lines": ["ぐうぅぅ"]}, {"box": [631, 550, 687, 673], "vertical": true, "font_size": 32.0, "lines": ["あはは"]}, {"box": [641, 941, 690, 1043], "vertical": true, "font_size": 24.0, "lines": ["そういう", "高木さんは、"]}, {"box": [117, 950, 169, 1045], "vertical": true, "font_size": 21.0, "lines": ["嫌いなもの", "ないの？"]}], "img_path": "059.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [698, 89, 727, 159], "vertical": true, "font_size": 29.0, "lines": ["嫌いな、"]}, {"box": [414, 89, 440, 144], "vertical": true, "font_size": 26.0, "lines": ["もの。"]}, {"box": [313, 62, 344, 119], "vertical": true, "font_size": 26.0, "lines": ["んー。"]}, {"box": [554, 397, 607, 486], "vertical": true, "font_size": 24.0, "lines": ["微妙な", "とこかな。"]}, {"box": [276, 366, 299, 433], "vertical": true, "font_size": 21.0, "lines": ["あるな、"]}, {"box": [108, 364, 132, 433], "vertical": true, "font_size": 22.0, "lines": ["これは。"]}, {"box": [371, 815, 503, 939], "vertical": true, "font_size": 22.0, "lines": ["じゃあ", "高木さんの", "嫌いなもの", "当てられたら", "オレの勝ちで。"]}, {"box": [117, 796, 144, 863], "vertical": true, "font_size": 25.0, "lines": ["いいよ。"]}], "img_path": "060.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [685, 148, 749, 183], "vertical": false, "font_size": 21.0, "lines": ["あはは"]}, {"box": [591, 59, 640, 174], "vertical": true, "font_size": 18.0, "lines": ["当たらないと", "思うけど。"]}, {"box": [365, 76, 420, 172], "vertical": true, "font_size": 23.0, "lines": ["絶対当てて", "やる．．．"]}, {"box": [269, 55, 289, 126], "vertical": true, "font_size": 20.0, "lines": ["「そして、"]}, {"box": [151, 73, 210, 146], "vertical": true, "font_size": 32.0, "lines": ["子供舌", "だねぇ。"]}, {"box": [69, 42, 94, 174], "vertical": true, "font_size": 16.0, "lines": ["と言ってやる。"]}, {"box": [494, 509, 525, 575], "vertical": true, "font_size": 29.0, "lines": ["野菜？"]}, {"box": [213, 515, 267, 602], "vertical": true, "font_size": 23.0, "lines": ["野菜じゃ", "ないねー。"]}, {"box": [692, 780, 741, 884], "vertical": true, "font_size": 21.0, "lines": ["ヒント", "ありなんだ。"]}, {"box": [161, 1016, 192, 1074], "vertical": true, "font_size": 31.0, "lines": ["ふむ。"]}], "img_path": "061.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [788, 56, 816, 108], "vertical": true, "font_size": 26.0, "lines": ["あと、"]}, {"box": [586, 84, 643, 202], "vertical": true, "font_size": 24.0, "lines": ["元気が出る．．", "かな。"]}, {"box": [674, 411, 738, 514], "vertical": true, "font_size": 32.0, "lines": ["全然しば", "絞れない．．．"]}, {"box": [223, 445, 252, 507], "vertical": true, "font_size": 25.0, "lines": ["味は？"]}, {"box": [697, 705, 746, 783], "vertical": true, "font_size": 22.0, "lines": ["スーっと", "したり、"]}, {"box": [442, 726, 497, 812], "vertical": true, "font_size": 24.0, "lines": ["酸味が", "あるけど、"]}, {"box": [352, 757, 372, 870], "vertical": true, "font_size": 24.0, "lines": ["甘かったり？"]}, {"box": [135, 754, 302, 813], "vertical": false, "font_size": 32.0, "lines": ["むむむ．．．？"]}], "img_path": "062.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [591, 65, 611, 144], "vertical": true, "font_size": 20.0, "lines": ["じゃあ．．．"]}, {"box": [402, 76, 460, 151], "vertical": true, "font_size": 28.0, "lines": ["あ、", "待って。"]}, {"box": [317, 70, 366, 148], "vertical": true, "font_size": 28.0, "lines": ["あと１つ", "だけね。"]}, {"box": [69, 131, 94, 200], "vertical": true, "font_size": 25.0, "lines": ["ヒント。"]}, {"box": [663, 458, 690, 509], "vertical": true, "font_size": 27.0, "lines": ["な！！"]}, {"box": [107, 424, 188, 576], "vertical": true, "font_size": 20.0, "lines": ["だって無制限だと", "そのうち", "当たっちゃうし。"]}, {"box": [677, 801, 752, 901], "vertical": true, "font_size": 27.0, "lines": ["く．．．いきが", "勢いを", "削がれた．．．"]}, {"box": [399, 799, 451, 904], "vertical": true, "font_size": 23.0, "lines": ["さすが", "高木さんだ。"]}, {"box": [292, 787, 342, 940], "vertical": true, "font_size": 18.0, "lines": ["あと１つで核心を", "つけるもの．．．"]}, {"box": [99, 793, 120, 890], "vertical": true, "font_size": 20.0, "lines": ["といえば．．．"]}], "img_path": "063.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [659, 89, 688, 166], "vertical": true, "font_size": 21.0, "lines": ["色は．．．？"]}, {"box": [419, 72, 438, 137], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．"]}, {"box": [120, 93, 156, 152], "vertical": true, "font_size": 31.0, "lines": ["へえ。"]}, {"box": [275, 369, 309, 427], "vertical": true, "font_size": 32.0, "lines": ["黄色。"]}, {"box": [660, 682, 739, 762], "vertical": true, "font_size": 25.0, "lines": ["よし！", "かなり", "絞れた！！"]}, {"box": [142, 679, 235, 781], "vertical": true, "font_size": 32.0, "lines": ["完璧な質問とったぞ", "だったぞ。"]}], "img_path": "064.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [420, 84, 460, 285], "vertical": true, "font_size": 32.0, "lines": ["ハイナップル。"]}, {"box": [340, 125, 381, 192], "vertical": true, "font_size": 32.0, "lines": ["外れ。"]}, {"box": [665, 625, 686, 703], "vertical": true, "font_size": 21.0, "lines": ["はやっ！！"]}, {"box": [162, 648, 182, 714], "vertical": true, "font_size": 20.0, "lines": ["あはは。"]}, {"box": [724, 889, 742, 952], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．？"]}, {"box": [417, 973, 444, 1051], "vertical": true, "font_size": 19.0, "lines": ["答えは．．．"]}], "img_path": "065.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [715, 90, 764, 281], "vertical": true, "font_size": 22.0, "lines": ["エナジードリンク系の", "飲みもの、"]}, {"box": [630, 201, 651, 270], "vertical": true, "font_size": 22.0, "lines": ["でした。"]}, {"box": [287, 139, 340, 254], "vertical": true, "font_size": 20.0, "lines": ["食べものじゃ", "ないじゃん！！"]}, {"box": [670, 533, 748, 652], "vertical": true, "font_size": 23.0, "lines": ["だって", "「嫌いなもの」", "聞かれたし。"]}, {"box": [332, 553, 387, 706], "vertical": true, "font_size": 20.0, "lines": ["それに微妙だけど", "って言ったよね。"]}, {"box": [684, 886, 708, 981], "vertical": true, "font_size": 16.0, "lines": ["言ってた．．．"]}, {"box": [179, 873, 201, 961], "vertical": true, "font_size": 21.0, "lines": ["でしょー。"]}], "img_path": "066.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [678, 82, 739, 139], "vertical": true, "font_size": 32.0, "lines": ["私の", "勝ち。"]}, {"box": [581, 381, 743, 529], "vertical": true, "font_size": 19.0, "lines": ["もし私が西片に", "料理作ることが", "あったらさ．．．"]}, {"box": [151, 387, 185, 434], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}, {"box": [723, 789, 743, 923], "vertical": true, "font_size": 17.0, "lines": ["あったらって．．．"]}, {"box": [417, 847, 461, 960], "vertical": true, "font_size": 18.0, "lines": ["あるの．．．？", "そんなコト．．．"]}], "img_path": "067.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [706, 72, 759, 176], "vertical": true, "font_size": 24.0, "lines": ["いつか", "あるかもよ。"]}, {"box": [385, 128, 407, 206], "vertical": true, "font_size": 21.0, "lines": ["ふーん．．．"]}, {"box": [691, 548, 745, 670], "vertical": true, "font_size": 27.0, "lines": ["高木さんの．．．て？？", "手料理．．．"]}, {"box": [194, 588, 220, 672], "vertical": true, "font_size": 21.0, "lines": ["その時は、"]}, {"box": [598, 874, 674, 1018], "vertical": true, "font_size": 21.0, "lines": ["おいしい", "ピーマン料理", "作ってあげるよ。"]}, {"box": [212, 886, 325, 1025], "vertical": true, "font_size": 22.0, "lines": ["ピーマン抜きで", "お願いします．．"]}], "img_path": "068.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [84, 986, 306, 1115], "vertical": false, "font_size": 32.0, "lines": ["ーフォ・", "ＵＦＣ"]}], "img_path": "069.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [690, 113, 753, 300], "vertical": true, "font_size": 29.0, "lines": ["見ろ！！", "ＵＦＯの写真だ！！"]}, {"box": [150, 148, 217, 291], "vertical": true, "font_size": 32.0, "lines": ["昨日", "撮ったのさ！！"]}, {"box": [731, 632, 753, 738], "vertical": true, "font_size": 22.0, "lines": ["ウソくせー。"]}, {"box": [639, 635, 687, 731], "vertical": true, "font_size": 22.0, "lines": ["虫とかじゃ", "ねーの。"]}, {"box": [465, 650, 511, 745], "vertical": true, "font_size": 20.0, "lines": ["ホントなん", "だって！！"]}, {"box": [369, 631, 421, 768], "vertical": true, "font_size": 20.0, "lines": ["昨日の夜、ふと", "空を見たら、"]}, {"box": [100, 630, 204, 783], "vertical": true, "font_size": 20.0, "lines": ["キラッと光った", "気がして", "とっさにカメラを", "かまえたわけよ。"]}, {"box": [133, 964, 152, 1047], "vertical": true, "font_size": 16.0, "lines": ["そしたら、"]}], "img_path": "070.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [697, 69, 746, 174], "vertical": true, "font_size": 21.0, "lines": ["ブワーって", "光ってなぁ。"]}, {"box": [376, 64, 405, 134], "vertical": true, "font_size": 25.0, "lines": ["高尾君。"]}, {"box": [698, 332, 752, 428], "vertical": true, "font_size": 20.0, "lines": ["まだＵＦＯ", "なんて、"]}, {"box": [445, 323, 470, 456], "vertical": true, "font_size": 20.0, "lines": ["信じてるの．．．？"]}, {"box": [332, 356, 378, 488], "vertical": true, "font_size": 20.0, "lines": ["あわれむような", "目をするな。"]}, {"box": [63, 355, 120, 437], "vertical": true, "font_size": 24.0, "lines": ["日々野の", "クセに。"]}, {"box": [667, 876, 746, 993], "vertical": true, "font_size": 25.0, "lines": ["高尾のクセに", "何その", "口の利き方。"]}, {"box": [125, 898, 172, 1033], "vertical": true, "font_size": 20.0, "lines": ["ゴメンなさい！！", "ゴメンなさい！！"]}], "img_path": "071.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [725, 83, 745, 202], "vertical": true, "font_size": 23.0, "lines": ["ていうかそれ、"]}, {"box": [595, 90, 674, 263], "vertical": true, "font_size": 23.0, "lines": ["昨日の夜、畑で上に", "光る何か投げて", "撮ってたでしょ。"]}, {"box": [514, 103, 538, 172], "vertical": true, "font_size": 23.0, "lines": ["何度も。"]}, {"box": [171, 110, 196, 179], "vertical": true, "font_size": 25.0, "lines": ["ああ！？"]}, {"box": [696, 462, 745, 614], "vertical": true, "font_size": 20.0, "lines": ["ななな", "なんのことだあ！？"]}, {"box": [515, 452, 535, 554], "vertical": true, "font_size": 20.0, "lines": ["見てたのよ。"]}, {"box": [402, 478, 451, 581], "vertical": true, "font_size": 20.0, "lines": ["ランニング", "してたから"]}, {"box": [626, 976, 704, 1073], "vertical": true, "font_size": 25.0, "lines": ["じゃあ", "声とか", "かけろよ！！"]}, {"box": [356, 980, 380, 1047], "vertical": true, "font_size": 24.0, "lines": ["イヤよ、"]}, {"box": [250, 999, 301, 1106], "vertical": true, "font_size": 24.0, "lines": ["気持ち", "悪かったし。"]}], "img_path": "072.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [507, 837, 569, 889], "vertical": false, "font_size": 32.0, "lines": ["カネッ"]}, {"box": [492, 817, 590, 907], "vertical": false, "font_size": 32.0, "lines": ["カチャ"]}], "img_path": "073.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [468, 78, 492, 120], "vertical": true, "font_size": 24.0, "lines": ["ん？"]}, {"box": [324, 63, 404, 153], "vertical": true, "font_size": 28.0, "lines": ["あーいつう", "普通に", "石だなー。"]}, {"box": [115, 92, 142, 210], "vertical": true, "font_size": 25.0, "lines": ["何してるの？"]}, {"box": [633, 541, 716, 658], "vertical": true, "font_size": 22.0, "lines": ["ＵＦＯの画像", "撮れない", "かなーって。"]}, {"box": [154, 537, 261, 659], "vertical": true, "font_size": 25.0, "lines": ["あぁ、昼休み", "高尾君が", "騒いでた", "からかー。"]}, {"box": [691, 825, 741, 910], "vertical": true, "font_size": 24.0, "lines": ["ロマン", "だよねぇ、"]}, {"box": [353, 822, 387, 894], "vertical": true, "font_size": 32.0, "lines": ["ＵＦＯ。"]}, {"box": [276, 810, 302, 880], "vertical": true, "font_size": 26.0, "lines": ["へぇー。"]}], "img_path": "074.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [711, 67, 741, 123], "vertical": true, "font_size": 30.0, "lines": ["じゃ、"]}, {"box": [399, 86, 455, 171], "vertical": true, "font_size": 22.0, "lines": ["手伝って", "あげるよ。"]}, {"box": [105, 86, 132, 131], "vertical": true, "font_size": 27.0, "lines": ["へ？"]}, {"box": [414, 765, 435, 850], "vertical": true, "font_size": 21.0, "lines": ["いくよー。"]}, {"box": [315, 767, 342, 827], "vertical": true, "font_size": 21.0, "lines": ["ＯＫ！！"]}], "img_path": "075.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [530, 59, 583, 168], "vertical": true, "font_size": 23.0, "lines": ["あー、", "ダメだなー。"]}, {"box": [429, 64, 476, 167], "vertical": true, "font_size": 23.0, "lines": ["石にしか", "見えないや。"]}, {"box": [121, 195, 169, 327], "vertical": true, "font_size": 20.0, "lines": ["スピードが", "足りないとか？"]}, {"box": [694, 472, 740, 568], "vertical": true, "font_size": 20.0, "lines": ["とりあえず", "もう一回！！"]}, {"box": [405, 464, 425, 569], "vertical": true, "font_size": 20.0, "lines": ["はいはーい。"]}, {"box": [338, 467, 354, 530], "vertical": true, "font_size": 16.0, "lines": ["．．．．．．？"]}, {"box": [106, 485, 132, 568], "vertical": true, "font_size": 17.0, "lines": ["西片はさ、"]}, {"box": [725, 825, 748, 868], "vertical": true, "font_size": 23.0, "lines": ["ん？"]}, {"box": [465, 816, 503, 866], "vertical": true, "font_size": 32.0, "lines": ["何？"]}, {"box": [137, 814, 190, 929], "vertical": true, "font_size": 19.0, "lines": ["ＵＦＯって", "いると思う？"]}], "img_path": "076.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [365, 112, 413, 216], "vertical": true, "font_size": 21.0, "lines": ["そりゃあ", "いるでしょ。"]}, {"box": [664, 547, 682, 631], "vertical": true, "font_size": 16.0, "lines": ["あははは。"]}, {"box": [222, 532, 249, 577], "vertical": true, "font_size": 26.0, "lines": ["え！？"]}, {"box": [714, 779, 735, 901], "vertical": true, "font_size": 20.0, "lines": ["コメンゴメン。"]}, {"box": [397, 793, 473, 879], "vertical": true, "font_size": 25.0, "lines": ["あまりに", "普通に", "言うから。"]}, {"box": [332, 776, 349, 839], "vertical": true, "font_size": 17.0, "lines": ["．．．．．．？"]}, {"box": [130, 567, 181, 648], "vertical": true, "font_size": 26.0, "lines": ["なんで", "笑うの！？"]}, {"box": [104, 785, 149, 890], "vertical": true, "font_size": 20.0, "lines": ["それより", "次投げてよ。"]}], "img_path": "077.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [346, 73, 367, 142], "vertical": true, "font_size": 21.0, "lines": ["うーん。"]}, {"box": [722, 423, 752, 488], "vertical": true, "font_size": 21.0, "lines": ["ダメ？"]}, {"box": [604, 416, 675, 549], "vertical": true, "font_size": 21.0, "lines": ["もうちょっと", "小さいのに", "してみよっか？"]}, {"box": [168, 436, 187, 499], "vertical": true, "font_size": 19.0, "lines": ["．．．"]}, {"box": [693, 710, 745, 846], "vertical": true, "font_size": 21.0, "lines": ["高木さんは", "信じてないの？"]}, {"box": [463, 707, 497, 779], "vertical": true, "font_size": 30.0, "lines": ["ＵＦＯ"]}, {"box": [397, 714, 417, 782], "vertical": true, "font_size": 20.0, "lines": ["まぁー"]}, {"box": [96, 713, 148, 803], "vertical": true, "font_size": 24.0, "lines": ["信じて", "ないかな。"]}], "img_path": "078.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [651, 63, 732, 161], "vertical": true, "font_size": 24.0, "lines": ["なんか", "ウソっぽい", "しさ。"]}, {"box": [386, 79, 460, 166], "vertical": true, "font_size": 22.0, "lines": ["わかって", "ないなぁ", "ロマンを。"]}, {"box": [292, 70, 315, 174], "vertical": true, "font_size": 21.0, "lines": ["ロマンねぇ。"]}, {"box": [725, 546, 750, 610], "vertical": true, "font_size": 22.0, "lines": ["んーん、"]}, {"box": [640, 544, 688, 648], "vertical": true, "font_size": 22.0, "lines": ["いいね", "そういうの。"]}, {"box": [70, 340, 98, 436], "vertical": true, "font_size": 21.0, "lines": ["．．．悪い．．．？"]}, {"box": [151, 541, 181, 608], "vertical": true, "font_size": 25.0, "lines": ["っ．．．次、"]}, {"box": [104, 543, 124, 665], "vertical": true, "font_size": 25.0, "lines": ["お願いします。"]}, {"box": [269, 906, 338, 1053], "vertical": true, "font_size": 32.0, "lines": ["インス"]}], "img_path": "079.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [725, 111, 745, 189], "vertical": true, "font_size": 20.0, "lines": ["うーん．．．"]}, {"box": [472, 114, 524, 230], "vertical": true, "font_size": 20.0, "lines": ["なんか違うん", "だよなぁ。"]}, {"box": [128, 148, 180, 229], "vertical": true, "font_size": 23.0, "lines": ["こだわる", "ねー。"]}, {"box": [385, 511, 403, 593], "vertical": true, "font_size": 16.0, "lines": ["そりゃあ"]}, {"box": [112, 527, 164, 644], "vertical": true, "font_size": 19.0, "lines": ["出てくるなら", "本物撮るよ。"]}, {"box": [646, 517, 745, 690], "vertical": true, "font_size": 20.0, "lines": ["というか、", "ロマンっていうなら", "本物を狙った方が", "いいんじゃないの。"]}, {"box": [667, 892, 720, 1018], "vertical": true, "font_size": 24.0, "lines": ["でも", "いないしさぁ。"]}, {"box": [169, 905, 196, 959], "vertical": true, "font_size": 27.0, "lines": ["んー。"]}], "img_path": "080.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [697, 67, 746, 209], "vertical": true, "font_size": 21.0, "lines": ["まぁ", "私が宇宙人なら、"]}, {"box": [542, 76, 617, 193], "vertical": true, "font_size": 21.0, "lines": ["西片の前には", "現れない", "かなー。"]}, {"box": [361, 101, 387, 164], "vertical": true, "font_size": 26.0, "lines": ["えぇ？！"]}, {"box": [171, 80, 222, 176], "vertical": true, "font_size": 18.0, "lines": ["