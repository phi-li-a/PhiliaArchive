: true, "font_size": 25.0, "lines": ["作戦１はしっかりは", "失敗．．．"]}, {"box": [42, 792, 117, 871], "vertical": true, "font_size": 23.0, "lines": ["だがまだ", "作戦は", "ある．．．"]}], "img_path": "125.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [664, 85, 755, 249], "vertical": true, "font_size": 27.0, "lines": ["ホワイトデーの", "お返しを渡す", "作戦は。"]}, {"box": [476, 976, 639, 1013], "vertical": false, "font_size": 32.0, "lines": ["キーンコーン"]}], "img_path": "126.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [716, 64, 744, 166], "vertical": true, "font_size": 20.0, "lines": ["作戦その２"]}, {"box": [230, 50, 338, 166], "vertical": true, "font_size": 23.0, "lines": ["高木さんが", "いない間に", "机にこっそり", "入れる．．．"]}, {"box": [629, 855, 732, 972], "vertical": true, "font_size": 22.0, "lines": ["なぜ", "今日に限って", "机から離れ", "ないんだ"]}], "img_path": "127.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [507, 64, 531, 150], "vertical": true, "font_size": 24.0, "lines": ["チャンス。"]}, {"box": [419, 60, 444, 146], "vertical": true, "font_size": 24.0, "lines": ["すばやく、"]}, {"box": [131, 237, 196, 312], "vertical": true, "font_size": 32.0, "lines": ["最短", "距離で。"]}, {"box": [716, 933, 747, 1005], "vertical": true, "font_size": 31.0, "lines": ["なっ！？"]}, {"box": [383, 918, 463, 1034], "vertical": true, "font_size": 22.0, "lines": ["教科書が", "いっぱいで．．．", "入らない。"]}], "img_path": "128.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [691, 377, 746, 450], "vertical": true, "font_size": 30.0, "lines": ["おーい", "真野ー。"]}, {"box": [565, 372, 649, 455], "vertical": true, "font_size": 30.0, "lines": ["これ", "チョコの", "お返し。"]}, {"box": [222, 401, 243, 462], "vertical": true, "font_size": 20.0, "lines": ["もー！！"]}, {"box": [125, 426, 171, 568], "vertical": true, "font_size": 20.0, "lines": ["ロマンチックな", "雰囲気出してよ。"]}, {"box": [595, 764, 614, 828], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．．"]}, {"box": [268, 772, 340, 890], "vertical": true, "font_size": 22.0, "lines": ["あんなふうに", "気軽にわた", "渡せたら．．．"]}, {"box": [93, 902, 148, 985], "vertical": true, "font_size": 25.0, "lines": ["どんなに", "楽か．．．"]}], "img_path": "129.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [685, 57, 742, 141], "vertical": true, "font_size": 31.0, "lines": ["次はそんな", "作戦３．"]}, {"box": [181, 72, 260, 188], "vertical": true, "font_size": 19.0, "lines": ["作戦４だけは", "なんとしても", "逃げたい"]}, {"box": [694, 329, 768, 444], "vertical": true, "font_size": 22.0, "lines": ["だから", "この作戦３で", "決める！！"]}, {"box": [369, 309, 417, 414], "vertical": true, "font_size": 20.0, "lines": ["じゃあ、気を", "つけてな。"]}, {"box": [99, 328, 130, 415], "vertical": true, "font_size": 22.0, "lines": ["また明日。"]}, {"box": [612, 888, 740, 1024], "vertical": true, "font_size": 23.0, "lines": ["ホームルームが", "終わったと", "同時にすぐ", "ゲタ箱へ", "行き、"]}, {"box": [186, 898, 240, 1032], "vertical": true, "font_size": 20.0, "lines": ["チョコを入れて", "すぐ帰る。"]}], "img_path": "130.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [316, 48, 343, 92], "vertical": true, "font_size": 27.0, "lines": ["な．．．"]}, {"box": [71, 191, 105, 275], "vertical": true, "font_size": 32.0, "lines": ["速っ．．．！！"]}, {"box": [287, 305, 341, 405], "vertical": true, "font_size": 25.0, "lines": ["一緒に", "帰らない？"]}, {"box": [638, 754, 699, 836], "vertical": true, "font_size": 28.0, "lines": ["作戦３も", "失敗"]}], "img_path": "131.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [736, 106, 789, 186], "vertical": true, "font_size": 23.0, "lines": ["残るは", "作戦４："]}, {"box": [381, 85, 421, 233], "vertical": true, "font_size": 32.0, "lines": ["直接手渡し。"]}, {"box": [682, 943, 732, 1060], "vertical": true, "font_size": 24.0, "lines": ["く．．．", "恥ずかしい"]}, {"box": [115, 928, 217, 1100], "vertical": true, "font_size": 22.0, "lines": ["だからそれ", "作戦３までに", "なんとしても決めた", "かったのに．．．"]}], "img_path": "132.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [639, 104, 743, 240], "vertical": true, "font_size": 22.0, "lines": ["しかし", "恥ずかしがって", "渡すのは", "ダメだ。"]}, {"box": [80, 51, 372, 73], "vertical": false, "font_size": 20.0, "lines": ["からかいよ", "１上手の高ホさんの"]}, {"box": [132, 117, 213, 232], "vertical": true, "font_size": 20.0, "lines": ["高木さんに", "バカにされて", "しまう。"]}, {"box": [639, 418, 745, 534], "vertical": true, "font_size": 21.0, "lines": ["教科書でも", "渡すみたいに", "普通に淡せば", "いいのさ。"]}, {"box": [123, 425, 150, 494], "vertical": true, "font_size": 21.0, "lines": ["普通に。"]}, {"box": [619, 803, 672, 893], "vertical": true, "font_size": 26.0, "lines": ["た．．．たかぎ", "高木さん"]}, {"box": [154, 808, 181, 855], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}], "img_path": "133.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [738, 69, 780, 124], "vertical": true, "font_size": 32.0, "lines": ["何？"]}, {"box": [660, 555, 715, 625], "vertical": true, "font_size": 27.0, "lines": ["いや．．．", "えーと。"]}, {"box": [182, 563, 202, 642], "vertical": true, "font_size": 20.0, "lines": ["えーと？"]}], "img_path": "134.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [366, 273, 452, 418], "vertical": true, "font_size": 29.0, "lines": ["これ、", "バレンタインの", "お返し。"]}, {"box": [726, 781, 747, 859], "vertical": true, "font_size": 21.0, "lines": ["．．．です．．．"]}, {"box": [468, 779, 493, 841], "vertical": true, "font_size": 25.0, "lines": ["よし．．"]}, {"box": [339, 774, 420, 856], "vertical": true, "font_size": 27.0, "lines": ["割りといっ", "普通に", "言えた．．"]}, {"box": [376, 1031, 408, 1086], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [64, 935, 92, 984], "vertical": true, "font_size": 28.0, "lines": ["ハズ。"]}], "img_path": "135.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [665, 77, 747, 160], "vertical": true, "font_size": 28.0, "lines": ["それ、", "ふでばこ", "だよ。"]}, {"box": [401, 91, 422, 129], "vertical": true, "font_size": 21.0, "lines": ["へ？"]}, {"box": [284, 76, 319, 246], "vertical": true, "font_size": 32.0, "lines": ["あああぁあ。"]}, {"box": [670, 530, 716, 653], "vertical": true, "font_size": 22.0, "lines": ["こ．．．", "こっちでした。"]}, {"box": [145, 557, 223, 638], "vertical": true, "font_size": 23.0, "lines": ["あはは", "焦りすぎ", "だよー。"]}, {"box": [675, 856, 746, 953], "vertical": true, "font_size": 20.0, "lines": ["そんなに", "恥ずかし", "かったの？"]}, {"box": [110, 846, 154, 961], "vertical": true, "font_size": 18.0, "lines": ["くううう", "オレのアホ！！"]}], "img_path": "136.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [649, 118, 750, 235], "vertical": true, "font_size": 22.0, "lines": ["今日ずっと", "チャンス", "うかがってた", "でしょ。"]}, {"box": [570, 117, 619, 213], "vertical": true, "font_size": 22.0, "lines": ["ゲタ箱とか", "机とか。"]}, {"box": [82, 52, 373, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [205, 166, 281, 302], "vertical": true, "font_size": 22.0, "lines": ["だからチャンス", "作らなかったん", "だよ。"]}, {"box": [61, 122, 85, 156], "vertical": true, "font_size": 24.0, "lines": ["な。"]}, {"box": [622, 672, 679, 774], "vertical": true, "font_size": 28.0, "lines": ["全部", "知ってて．．．"]}, {"box": [159, 653, 239, 808], "vertical": true, "font_size": 22.0, "lines": ["オレが苦しむのを", "楽しんで", "いたというのか．．"]}, {"box": [693, 952, 722, 1062], "vertical": true, "font_size": 25.0, "lines": ["高木さんめ。"]}], "img_path": "137.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [453, 113, 536, 212], "vertical": true, "font_size": 22.0, "lines": ["直接渡して", "ほしかった", "からさー。"]}, {"box": [589, 585, 611, 691], "vertical": true, "font_size": 20.0, "lines": ["ありがとね。"]}, {"box": [665, 895, 738, 1029], "vertical": true, "font_size": 20.0, "lines": ["じゃあオレ．．．！", "急ぐから", "先行くね．．．！！"]}, {"box": [399, 915, 451, 1040], "vertical": true, "font_size": 21.0, "lines": ["じゃあ私も", "急ごうかなー。"]}, {"box": [178, 964, 208, 1019], "vertical": true, "font_size": 30.0, "lines": ["ええ。"]}], "img_path": "138.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [360, 87, 472, 237], "vertical": true, "font_size": 32.0, "lines": ["夜"]}], "img_path": "139.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "140.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [269, 57, 288, 114], "vertical": true, "font_size": 18.0, "lines": ["あれ？"]}, {"box": [48, 246, 68, 348], "vertical": true, "font_size": 16.0, "lines": ["おかしいな。"]}, {"box": [670, 547, 698, 632], "vertical": true, "font_size": 20.0, "lines": ["数時間前。"]}, {"box": [131, 564, 211, 678], "vertical": true, "font_size": 29.0, "lines": ["へぇー今日", "銭湯", "行くんだ。"]}, {"box": [649, 915, 754, 1033], "vertical": true, "font_size": 24.0, "lines": ["うん。", "家の風呂が", "壊れちゃった", "から。"]}, {"box": [421, 918, 441, 1005], "vertical": true, "font_size": 20.0, "lines": ["そっかー。"]}, {"box": [370, 910, 385, 972], "vertical": true, "font_size": 15.0, "lines": ["．．．．．．"]}, {"box": [93, 916, 147, 1032], "vertical": true, "font_size": 23.0, "lines": ["何時くらいに", "行くの？"]}], "img_path": "141.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [558, 73, 612, 181], "vertical": true, "font_size": 20.0, "lines": ["フ時すぎ", "くらいかな。"]}, {"box": [229, 57, 276, 138], "vertical": true, "font_size": 24.0, "lines": ["そっか", "そっかー。"]}, {"box": [665, 480, 721, 604], "vertical": true, "font_size": 26.0, "lines": ["って", "言ってたから、"]}, {"box": [158, 479, 235, 614], "vertical": true, "font_size": 20.0, "lines": ["待ちかまえてる", "もんだと", "思ってたのに．．"]}, {"box": [668, 909, 743, 1006], "vertical": true, "font_size": 22.0, "lines": ["なんだか", "拍子抜けと", "いうか"]}], "img_path": "142.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [642, 80, 699, 240], "vertical": true, "font_size": 26.0, "lines": ["少し", "さみしいというか"]}, {"box": [674, 568, 722, 669], "vertical": true, "font_size": 22.0, "lines": ["いやいや、", "なんだそれ"]}, {"box": [559, 566, 608, 682], "vertical": true, "font_size": 22.0, "lines": ["そんなコトは", "ない。"]}, {"box": [151, 566, 198, 718], "vertical": true, "font_size": 20.0, "lines": ["からかわれなくて", "安心だろ。"]}, {"box": [646, 941, 663, 1010], "vertical": true, "font_size": 17.0, "lines": ["そうさ．．．"]}, {"box": [145, 944, 238, 1041], "vertical": true, "font_size": 24.0, "lines": ["フルーツ", "牛乳でも", "飲んでっ", "落ち着こう。"]}], "img_path": "143.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [692, 107, 771, 203], "vertical": true, "font_size": 23.0, "lines": ["へー西片", "フルーツ派", "なんだ。"]}, {"box": [720, 594, 743, 633], "vertical": true, "font_size": 23.0, "lines": ["な！！"]}, {"box": [393, 588, 444, 713], "vertical": true, "font_size": 18.0, "lines": ["私はコーヒー", "牛乳にしよー。"]}, {"box": [111, 603, 134, 646], "vertical": true, "font_size": 23.0, "lines": ["き．．．"]}, {"box": [702, 925, 727, 1028], "vertical": true, "font_size": 20.0, "lines": ["来てたんだ。"]}, {"box": [162, 929, 216, 1010], "vertical": true, "font_size": 26.0, "lines": ["ん？", "なんで？"]}], "img_path": "144.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [694, 104, 743, 249], "vertical": true, "font_size": 20.0, "lines": ["いや、来てないな", "って思ってたから。"]}, {"box": [433, 110, 455, 133], "vertical": true, "font_size": 20.0, "lines": ["あ、"]}, {"box": [336, 138, 401, 278], "vertical": true, "font_size": 20.0, "lines": ["その言い方だと", "さがして", "くれたってこと？"]}, {"box": [658, 465, 714, 532], "vertical": true, "font_size": 30.0, "lines": ["いや．．．", "別に。"]}, {"box": [236, 435, 313, 543], "vertical": true, "font_size": 22.0, "lines": ["私の方が", "お風呂時間", "かかるから、"]}, {"box": [106, 442, 176, 623], "vertical": true, "font_size": 22.0, "lines": ["西片が出てきそうな", "時間を逆算して", "先に入ってたんだよ。"]}, {"box": [384, 782, 437, 885], "vertical": true, "font_size": 18.0, "lines": ["計算どおり", "だったよー"]}, {"box": [318, 762, 335, 805], "vertical": true, "font_size": 17.0, "lines": ["く．．．"]}, {"box": [33, 776, 80, 881], "vertical": true, "font_size": 22.0, "lines": ["なんか", "負けた気分。"]}], "img_path": "145.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [89, 553, 155, 640], "vertical": true, "font_size": 19.0, "lines": ["せっけんの", "においが", "してきて．．．"]}, {"box": [371, 550, 414, 661], "vertical": true, "font_size": 18.0, "lines": ["なんか．．．", "高木さんから、"]}, {"box": [332, 716, 364, 809], "vertical": true, "font_size": 28.0, "lines": ["ふわっ．．．"]}, {"box": [418, 875, 490, 978], "vertical": true, "font_size": 28.0, "lines": ["なんか", "新鮮", "じゃない？"]}, {"box": [153, 909, 185, 953], "vertical": true, "font_size": 24.0, "lines": ["え。"]}], "img_path": "146.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [376, 123, 431, 273], "vertical": true, "font_size": 28.0, "lines": ["夜一緒に歩くの", "初めてだから。"]}, {"box": [258, 72, 303, 168], "vertical": true, "font_size": 18.0, "lines": ["あ、ああ．．．", "そうだね．．．"]}, {"box": [654, 615, 731, 733], "vertical": true, "font_size": 23.0, "lines": ["お互い", "あんまり顔も", "見えないね。"]}, {"box": [629, 950, 709, 1059], "vertical": true, "font_size": 25.0, "lines": ["高木さん", "勝負", "しないかい。"]}, {"box": [197, 939, 227, 1008], "vertical": true, "font_size": 23.0, "lines": ["いいよ。"]}, {"box": [132, 953, 152, 1032], "vertical": true, "font_size": 23.0, "lines": ["なんの？"]}], "img_path": "147.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [640, 140, 745, 239], "vertical": true, "font_size": 25.0, "lines": ["テレて", "顔が赤く", "なった方の", "負け。"]}, {"box": [119, 133, 148, 193], "vertical": true, "font_size": 25.0, "lines": ["へえ。"]}, {"box": [698, 535, 746, 618], "vertical": true, "font_size": 25.0, "lines": ["どうだ", "高木さん"]}, {"box": [558, 532, 641, 690], "vertical": true, "font_size": 25.0, "lines": ["暗くて相手の", "顔を確認できない", "以上、"]}, {"box": [323, 837, 398, 935], "vertical": true, "font_size": 23.0, "lines": ["いいけど、こんな", "自己申告は", "なしね。"]}, {"box": [101, 542, 184, 680], "vertical": true, "font_size": 24.0, "lines": ["自己申告でしか", "勝負は", "つかない。"]}, {"box": [261, 835, 289, 878], "vertical": true, "font_size": 28.0, "lines": ["へ？"]}, {"box": [695, 860, 748, 961], "vertical": true, "font_size": 19.0, "lines": ["引き分けに", "もちこめる"]}, {"box": [624, 989, 656, 1100], "vertical": true, "font_size": 30.0, "lines": ["ふーっふふふっ！！"]}], "img_path": "148.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [665, 45, 746, 200], "vertical": true, "font_size": 19.0, "lines": ["だって自分の顔が", "赤いかなんて", "わかんないし。"]}, {"box": [465, 72, 548, 162], "vertical": true, "font_size": 21.0, "lines": ["たしかに。"]}, {"box": [376, 110, 424, 226], "vertical": true, "font_size": 22.0, "lines": ["じゃあ", "どうやって．．．"]}, {"box": [82, 52, 372, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [691, 468, 716, 553], "vertical": true, "font_size": 21.0, "lines": ["暗いけど、"]}, {"box": [105, 445, 178, 568], "vertical": true, "font_size": 20.0, "lines": ["これくらい", "近かったら", "確認できるよ。"]}, {"box": [406, 980, 453, 1116], "vertical": true, "font_size": 21.0, "lines": ["あれ？", "もう赤いけど？"]}, {"box": [96, 960, 124, 1006], "vertical": true, "font_size": 28.0, "lines": ["な．．．"]}], "img_path": "149.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [695, 58, 749, 139], "vertical": true, "font_size": 23.0, "lines": ["私の勝ち", "かなー。"]}, {"box": [446, 67, 521, 183], "vertical": true, "font_size": 22.0, "lines": ["い．．．いや", "まだ始まって", "ないし．．．"]}, {"box": [343, 94, 393, 230], "vertical": true, "font_size": 23.0, "lines": ["く．．．", "高木さんめ．．．！！"]}, {"box": [96, 106, 174, 258], "vertical": true, "font_size": 18.0, "lines": ["顔近づけられて", "赤くならないワケ", "ないだろ！！"]}, {"box": [652, 513, 681, 567], "vertical": true, "font_size": 24.0, "lines": ["じゃ、"]}, {"box": [605, 557, 625, 642], "vertical": true, "font_size": 24.0, "lines": ["やろっか。"]}, {"box": [515, 525, 564, 623], "vertical": true, "font_size": 20.0, "lines": ["やっぱ", "なしで．．．！！"]}, {"box": [431, 526, 477, 660], "vertical": true, "font_size": 20.0, "lines": ["のぼせたのかも", "しれないし．．．"]}, {"box": [117, 353, 137, 435], "vertical": true, "font_size": 20.0, "lines": ["ズルいぞ"]}, {"box": [103, 532, 175, 664], "vertical": true, "font_size": 18.0, "lines": ["けっこう", "時間たってると", "思うけどなー。"]}, {"box": [594, 738, 614, 777], "vertical": true, "font_size": 20.0, "lines": ["や．．．"]}, {"box": [604, 918, 678, 1020], "vertical": true, "font_size": 26.0, "lines": ["もっかい", "確認", "していい？"]}, {"box": [521, 935, 565, 1023], "vertical": true, "font_size": 32.0, "lines": ["あはは"]}, {"box": [217, 952, 239, 1030], "vertical": true, "font_size": 21.0, "lines": ["やめて！！"]}], "img_path": "150.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [237, 221, 309, 335], "vertical": true, "font_size": 19.0, "lines": ["さんざん", "からかわれて", "しまった．．"]}, {"box": [94, 235, 148, 363], "vertical": true, "font_size": 24.0, "lines": ["じゃ、私", "こっちだから。"]}, {"box": [691, 251, 741, 359], "vertical": true, "font_size": 24.0, "lines": ["あー", "楽しかった。"]}, {"box": [500, 814, 524, 844], "vertical": true, "font_size": 22.0, "lines": ["あ、"]}, {"box": [447, 836, 467, 921], "vertical": true, "font_size": 22.0, "lines": ["高木さん。"]}, {"box": [361, 830, 385, 873], "vertical": true, "font_size": 24.0, "lines": ["ん？"]}], "img_path": "151.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [665, 110, 718, 235], "vertical": true, "font_size": 27.0, "lines": ["暗いし", "送っていくよ。"]}, {"box": [380, 956, 406, 1005], "vertical": true, "font_size": 26.0, "lines": ["あれ、"]}, {"box": [100, 978, 146, 1080], "vertical": true, "font_size": 32.0, "lines": ["何この間。"]}], "img_path": "152.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [693, 90, 747, 223], "vertical": true, "font_size": 20.0, "lines": ["なんか変なコト", "言ったか．．．？"]}, {"box": [299, 91, 405, 227], "vertical": true, "font_size": 21.0, "lines": ["どんな", "してるのかも", "暗くて", "わからないし．．"]}, {"box": [98, 89, 125, 117], "vertical": false, "font_size": 27.0, "lines": ["！？"]}, {"box": [702, 414, 731, 465], "vertical": true, "font_size": 29.0, "lines": ["それ、"]}, {"box": [380, 451, 434, 612], "vertical": true, "font_size": 18.0, "lines": ["恋人に言う", "セリフみたいだね。"]}, {"box": [72, 413, 113, 464], "vertical": true, "font_size": 32.0, "lines": ["な。"]}, {"box": [674, 910, 722, 1017], "vertical": true, "font_size": 26.0, "lines": ["そ．．．", "そうなの．．．！？"]}, {"box": [569, 914, 622, 987], "vertical": true, "font_size": 26.0, "lines": ["いや、", "オレは．．．"]}, {"box": [316, 915, 366, 1013], "vertical": true, "font_size": 20.0, "lines": ["近いから", "大丈夫だよ。"]}, {"box": [247, 945, 263, 1038], "vertical": true, "font_size": 20.0, "lines": ["ありがとね。"]}], "img_path": "153.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [697, 56, 777, 192], "vertical": true, "font_size": 21.0, "lines": ["私もちょっと", "のぼせちゃった", "かもなー。"]}, {"box": [376, 72, 404, 117], "vertical": true, "font_size": 28.0, "lines": ["へ？"]}, {"box": [352, 311, 399, 390], "vertical": true, "font_size": 22.0, "lines": ["なんても", "ないよ。"]}, {"box": [242, 311, 317, 428], "vertical": true, "font_size": 22.0, "lines": ["じゃあ", "湯冷めしない", "ようにねー。"]}, {"box": [250, 519, 289, 602], "vertical": true, "font_size": 32.0, "lines": ["たたたー"]}, {"box": [633, 762, 688, 856], "vertical": true, "font_size": 24.0, "lines": ["あと西片", "顔赤いよ。"]}, {"box": [361, 795, 436, 894], "vertical": true, "font_size": 23.0, "lines": ["い．．．いや", "だから", "のぼせて．．．"]}, {"box": [262, 878, 337, 975], "vertical": true, "font_size": 23.0, "lines": ["って．．．", "見えてない", "だろ！！"]}, {"box": [246, 1127, 605, 1150], "vertical": false, "font_size": 23.0, "lines": ["「からかい上手の高木さん昭・完一"]}], "img_path": "154.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "155.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [130, 91, 612, 145], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [133, 180, 568, 203], "vertical": false, "font_size": 23.0, "lines": ["ゲッサン少年サンデーコミックススペシャル"]}, {"box": [194, 544, 499, 567], "vertical": false, "font_size": 20.0, "lines": ["２０１９年１２月１７日初版第１刷発行"]}, {"box": [439, 513, 760, 528], "vertical": false, "font_size": 13.5, "lines": ["０９－１２９５２６－２", "ＩＳＢＮ９７８－４－０"]}, {"box": [196, 657, 262, 682], "vertical": false, "font_size": 22.0, "lines": ["者", "著"]}, {"box": [197, 726, 262, 787], "vertical": false, "font_size": 22.0, "lines": ["発行者", "ＥＤＦＵアプリ"]}, {"box": [137, 825, 552, 931], "vertical": false, "font_size": 17.75, "lines": ["「ゲッサン」２０１８年１１月号２０１９年２月号〜９月号掲載作品", "連載担当／板谷真人", "単行本編集責任ノ石川昌彦", "単行本編集ノ板谷真人。〈三輪狼子（アイブロダクション）"]}, {"box": [402, 650, 664, 751], "vertical": false, "font_size": 26.333333333333332, "lines": ["山本禁一曲", "ＣＳＳｉｃｈｉｒｏＴａｎａｍａｎｏｎｏ．２０１９", "樹正田絶"]}, {"box": [407, 767, 617, 783], "vertical": false, "font_size": 16.0, "lines": ["中央精版の印刷株式会社"]}, {"box": [142, 942, 240, 979], "vertical": false, "font_size": 32.0, "lines": ["発行所"]}, {"box": [256, 943, 599, 962], "vertical": false, "font_size": 16.0, "lines": ["〈〒１０－＊８０１）東京都千代田区一ツ橋二の三の"]}, {"box": [138, 1027, 762, 1142], "vertical": false, "font_size": 14.0, "lines": ["●法本には十分注意しでおりますが、印刷、製本なと製造上の不備がございましたら「制作局コール", "センター「パフリーダイヤルＩＤＥ」３８６－６８２にご連絡ください。", "〈電話受付は、土・日・提供日を除く９，３０〜１７：８０", "●本書の一部または全部を無断で複製、転載、複写（コピー）、スキャン、デジタル化、上演、放送", "等をすることは、著作権法上での例外を除き禁じられています。代行業者等の第三者による本書の", "電子的複製も認められておりません。"]}, {"box": [425, 965, 741, 1018], "vertical": false, "font_size": 32.0, "lines": ["２０１８年１１月１５日－編集ＯＲ（３２３）１９７２５", "平成２８年１０月１８日、現在は５８０１５年６月１５日に３０１３年３月２５日、東京・東京"]}], "img_path": "156.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [101, 761, 716, 945], "vertical": false, "font_size": 30.0, "lines": ["からかい上手の高木さん１２", "山本崇一朗", "○山本崇一朗ノ小学館", "書名著者名", "株式会社小学年", "行", "発", "〒１０１－８００１．東京都千代田区一ツ橋２・３－"]}, {"box": [121, 991, 574, 1023], "vertical": false, "font_size": 30.0, "lines": ["電子書籍制作会社株式会社昭和ブライト"]}, {"box": [123, 1065, 661, 1106], "vertical": false, "font_size": 30.0, "lines": ["氷収録されている作品は、執筆された当時の状況や年代を考慮の上、", "初回掲載時の表現のまま掲載されております。ご了承ください。"]}], "img_path": "157.jpg"}]}