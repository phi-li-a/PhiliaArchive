{"version": "0.2.0-beta.6", "title": "Karakai Jouzu no Takagi-san", "title_uuid": "8b310d10-25a6-4fdb-aaef-cacc33c51c4b", "volume": "Karakai-Jouzu-Takagi-san-12", "volume_uuid": "1c85fb42-c3b3-4c2e-b604-0acd4883a221", "pages": [{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [24, 39, 84, 800], "vertical": true, "font_size": 32.0, "lines": ["からかい上手の高木さんＢ－山栄空朗"]}, {"box": [637, 1151, 814, 1171], "vertical": false, "font_size": 12.0, "lines": ["ＯＮＩＣＳＳＰＥＣＩＡＩ"]}], "img_path": "001.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "002.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [66, 1100, 678, 1132], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さん『○山本宗一朗』"]}], "img_path": "003.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [670, 528, 776, 543], "vertical": false, "font_size": 15.0, "lines": ["ｏｎｔｅｎｔｓ"]}, {"box": [721, 711, 742, 823], "vertical": true, "font_size": 21.0, "lines": ["２年生一つの"]}, {"box": [567, 699, 620, 826], "vertical": true, "font_size": 32.0, "lines": ["クレーンゲーム"]}, {"box": [440, 692, 464, 823], "vertical": true, "font_size": 20.0, "lines": ["握力のやつの"]}, {"box": [302, 693, 323, 822], "vertical": true, "font_size": 20.0, "lines": ["苦手なモノール"]}, {"box": [165, 712, 181, 766], "vertical": true, "font_size": 16.0, "lines": ["ＵＦＯ"]}, {"box": [161, 710, 184, 825], "vertical": true, "font_size": 22.0, "lines": ["ＵＦＯ"]}, {"box": [722, 966, 743, 1075], "vertical": true, "font_size": 20.0, "lines": ["血液型の"]}, {"box": [581, 954, 605, 1083], "vertical": true, "font_size": 16.0, "lines": ["おみくじゃ、"]}, {"box": [441, 965, 463, 1019], "vertical": true, "font_size": 22.0, "lines": ["お返し"]}], "img_path": "004.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [684, 87, 741, 161], "vertical": true, "font_size": 31.0, "lines": ["おはよ、", "西片。"]}, {"box": [59, 86, 83, 177], "vertical": true, "font_size": 21.0, "lines": ["おはよう。"]}, {"box": [364, 698, 427, 825], "vertical": true, "font_size": 26.0, "lines": ["今日から", "２年生だね。"]}, {"box": [94, 1140, 164, 1168], "vertical": false, "font_size": 26.0, "lines": ["２年生"]}], "img_path": "005.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [374, 1035, 681, 1173], "vertical": false, "font_size": 32.0, "lines": ["ねん", "せい", "２年生"]}], "img_path": "006.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "007.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [721, 79, 750, 184], "vertical": true, "font_size": 19.0, "lines": ["２年生かー。"]}, {"box": [421, 89, 450, 175], "vertical": true, "font_size": 21.0, "lines": ["早いねぇ。"]}, {"box": [336, 58, 358, 162], "vertical": true, "font_size": 20.0, "lines": ["そうだねー、"]}, {"box": [104, 75, 152, 198], "vertical": true, "font_size": 23.0, "lines": ["オレも", "センパイかー。"]}, {"box": [660, 551, 750, 728], "vertical": true, "font_size": 18.0, "lines": ["まぁ部活とか", "入ってないから", "そう呼ばれることなんて", "ないんだろうけど。"]}], "img_path": "008.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [644, 111, 677, 262], "vertical": true, "font_size": 28.0, "lines": ["西片センパイ。"]}, {"box": [456, 571, 485, 621], "vertical": true, "font_size": 29.0, "lines": ["な！！"]}, {"box": [340, 560, 418, 687], "vertical": true, "font_size": 20.0, "lines": ["そう呼んで", "ほしいのかなと", "思って。"]}, {"box": [105, 573, 123, 668], "vertical": true, "font_size": 16.0, "lines": ["うれしい？"]}, {"box": [656, 880, 708, 962], "vertical": true, "font_size": 28.0, "lines": ["いや．．．", "別に．．．！"]}, {"box": [246, 866, 328, 1012], "vertical": true, "font_size": 21.0, "lines": ["あ、西片センパイ", "うれしそう", "ですねー。"]}, {"box": [117, 896, 148, 985], "vertical": true, "font_size": 25.0, "lines": ["違うって。"]}], "img_path": "009.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [677, 110, 752, 225], "vertical": true, "font_size": 20.0, "lines": ["センパイに", "なるってのも", "あるけど、"]}, {"box": [343, 59, 420, 203], "vertical": true, "font_size": 22.0, "lines": ["私には", "クラス替えが", "一番重要かなー。"]}, {"box": [94, 107, 189, 266], "vertical": true, "font_size": 20.0, "lines": ["あー、確かにねー．．．", "一年間の生活が", "決まっちゃうと", "言ってもいいし．．．"]}, {"box": [670, 494, 720, 591], "vertical": true, "font_size": 22.0, "lines": ["クラス", "替えかー．．．"]}, {"box": [422, 697, 503, 860], "vertical": true, "font_size": 21.0, "lines": ["高木さんと", "同じクラスなら", "いいんだけどなぁ。"]}], "img_path": "010.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [345, 69, 379, 112], "vertical": true, "font_size": 28.0, "lines": ["あ。"]}, {"box": [659, 446, 733, 581], "vertical": true, "font_size": 21.0, "lines": ["い．．．いや．．．！！", "同じクラスだと", "勝負できるし、"]}, {"box": [303, 435, 380, 565], "vertical": true, "font_size": 27.0, "lines": ["オレが", "勝つ", "チャンスがさ。"]}, {"box": [202, 425, 251, 528], "vertical": true, "font_size": 21.0, "lines": ["へぇー、", "そうなんだ。"]}, {"box": [698, 858, 751, 991], "vertical": true, "font_size": 18.0, "lines": ["同じクラスだと", "いいのかー"]}, {"box": [352, 883, 406, 963], "vertical": true, "font_size": 27.0, "lines": ["いや、", "だから．．．"]}], "img_path": "011.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [734, 78, 793, 159], "vertical": true, "font_size": 26.0, "lines": ["一緒だと", "いいね。"]}, {"box": [670, 523, 743, 659], "vertical": true, "font_size": 21.0, "lines": ["あれ？", "顔が赤いですよ", "西片センバイ"]}, {"box": [576, 552, 600, 625], "vertical": true, "font_size": 24.0, "lines": ["あはは"]}, {"box": [406, 310, 428, 396], "vertical": true, "font_size": 20.0, "lines": ["う．．．うん"]}, {"box": [238, 530, 290, 632], "vertical": true, "font_size": 27.0, "lines": ["それ", "やめて．．．！"]}], "img_path": "012.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [698, 57, 742, 227], "vertical": true, "font_size": 18.0, "lines": ["いえーい！！", "３人同じクラスー！！！"]}, {"box": [513, 54, 603, 225], "vertical": true, "font_size": 25.0, "lines": ["．．．"]}, {"box": [432, 56, 452, 139], "vertical": true, "font_size": 20.0, "lines": ["いえーい。"]}, {"box": [317, 56, 393, 154], "vertical": true, "font_size": 24.0, "lines": ["また", "この子らと", "一緒か．．．"]}, {"box": [242, 45, 286, 150], "vertical": true, "font_size": 20.0, "lines": ["センパイって", "呼んで！！"]}, {"box": [50, 73, 98, 169], "vertical": true, "font_size": 21.0, "lines": ["テンション", "高いなぁ。"]}, {"box": [728, 464, 750, 533], "vertical": true, "font_size": 20.0, "lines": ["わはっ。"]}, {"box": [469, 474, 518, 612], "vertical": true, "font_size": 23.0, "lines": ["同じクラスだよ", "中井君！"]}, {"box": [415, 494, 441, 547], "vertical": true, "font_size": 23.0, "lines": ["ほら。"]}, {"box": [309, 553, 393, 630], "vertical": false, "font_size": 32.0, "lines": ["以前、自己を認めるのは", "大丈夫？"]}, {"box": [101, 466, 182, 564], "vertical": true, "font_size": 22.0, "lines": ["あ、村田と", "谷口も同じ", "クラスだ。"]}, {"box": [660, 976, 739, 1073], "vertical": true, "font_size": 22.0, "lines": ["私と！！", "同じクラス", "だよっ！！"]}, {"box": [174, 957, 197, 1059], "vertical": true, "font_size": 20.0, "lines": ["そーだなー、"]}, {"box": [105, 964, 125, 1067], "vertical": true, "font_size": 20.0, "lines": ["うれしいな。"]}], "img_path": "013.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [702, 435, 754, 515], "vertical": true, "font_size": 24.0, "lines": ["緊張", "してる？"]}, {"box": [372, 425, 422, 486], "vertical": true, "font_size": 23.0, "lines": ["ま、", "まぁ．．．"]}, {"box": [194, 431, 215, 528], "vertical": true, "font_size": 20.0, "lines": ["あ、そうだ。"]}, {"box": [669, 792, 747, 941], "vertical": true, "font_size": 20.0, "lines": ["じゃあ、私がまず", "クラス分け", "見てくるから、"]}, {"box": [153, 809, 287, 942], "vertical": true, "font_size": 19.0, "lines": ["私の反応で", "私と西片が", "同じクラスか", "そうじゃないか", "当ててみてよ。"]}], "img_path": "014.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [333, 133, 402, 274], "vertical": true, "font_size": 30.0, "lines": ["２年生最初の", "勝負。"]}, {"box": [706, 526, 731, 589], "vertical": true, "font_size": 25.0, "lines": ["いいよ。"]}, {"box": [481, 517, 508, 570], "vertical": true, "font_size": 25.0, "lines": ["じゃ、"]}, {"box": [426, 529, 449, 656], "vertical": true, "font_size": 25.0, "lines": ["行ってくるね。"]}], "img_path": "015.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [660, 650, 684, 752], "vertical": true, "font_size": 21.0, "lines": ["めっちゃ、"]}, {"box": [183, 659, 208, 785], "vertical": true, "font_size": 24.0, "lines": ["うれしそう。"]}, {"box": [755, 975, 808, 1080], "vertical": true, "font_size": 20.0, "lines": ["違うクラス", "でしょーか。"]}, {"box": [451, 959, 504, 1065], "vertical": true, "font_size": 20.0, "lines": ["同じクラス", "でしょーか。"]}, {"box": [356, 964, 408, 1096], "vertical": true, "font_size": 18.0, "lines": ["いや．．．その顔．．．", "どう見ても．．"]}, {"box": [105, 960, 156, 1059], "vertical": true, "font_size": 25.0, "lines": ["いや．．．", "ブラフか？"]}], "img_path": "016.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [663, 118, 745, 291], "vertical": true, "font_size": 23.0, "lines": ["そうだ、高木さんは", "ポーカーフェイス", "だし、"]}, {"box": [339, 125, 391, 259], "vertical": true, "font_size": 19.0, "lines": ["違うクラス", "だったのでは"]}, {"box": [256, 86, 283, 165], "vertical": true, "font_size": 20.0, "lines": ["違う！！"]}, {"box": [666, 494, 742, 704], "vertical": true, "font_size": 20.0, "lines": ["いつもこういう時に", "高木さんはウラのウラを", "ついてくる．．．！！"]}, {"box": [60, 287, 89, 372], "vertical": true, "font_size": 25.0, "lines": ["待て待て。"]}, {"box": [374, 550, 391, 665], "vertical": true, "font_size": 18.0, "lines": ["ということは"]}, {"box": [287, 580, 306, 691], "vertical": true, "font_size": 18.0, "lines": ["同じクラス。"]}, {"box": [606, 878, 740, 998], "vertical": true, "font_size": 26.0, "lines": ["２年生に", "なったオレは", "ひと味", "違うぞ", "高木さん。"]}, {"box": [120, 883, 146, 979], "vertical": true, "font_size": 17.0, "lines": ["同じクラ．．．"]}], "img_path": "017.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [727, 102, 753, 198], "vertical": true, "font_size": 20.0, "lines": ["待て待て！！"]}, {"box": [447, 103, 490, 208], "vertical": true, "font_size": 19.0, "lines": ["もうちょっと", "待って．．．"]}, {"box": [125, 116, 151, 212], "vertical": true, "font_size": 18.0, "lines": ["考えるねぇ。"]}, {"box": [694, 528, 744, 664], "vertical": true, "font_size": 21.0, "lines": ["忘れる", "ところだった．．．"]}, {"box": [535, 305, 585, 367], "vertical": true, "font_size": 24.0, "lines": ["ん？", "まだ？"]}, {"box": [424, 527, 445, 586], "vertical": true, "font_size": 21.0, "lines": ["そう．．．"]}, {"box": [324, 548, 380, 648], "vertical": true, "font_size": 22.0, "lines": ["高木さんも", "２年生！！"]}, {"box": [688, 908, 738, 986], "vertical": true, "font_size": 23.0, "lines": ["ウラの", "ウラの．．"]}, {"box": [125, 915, 179, 1008], "vertical": true, "font_size": 22.0, "lines": ["そのまた", "ウラだ！！"]}], "img_path": "018.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [651, 135, 688, 230], "vertical": true, "font_size": 28.0, "lines": ["答えは、"]}, {"box": [140, 162, 174, 325], "vertical": true, "font_size": 28.0, "lines": ["違うクラス！！"]}, {"box": [700, 541, 752, 622], "vertical": true, "font_size": 26.0, "lines": ["それで", "いいの？"]}, {"box": [229, 533, 256, 587], "vertical": true, "font_size": 27.0, "lines": ["あぁ。"]}, {"box": [661, 859, 689, 926], "vertical": true, "font_size": 21.0, "lines": ["答えは、"]}, {"box": [359, 544, 418, 661], "vertical": true, "font_size": 24.0, "lines": ["２年生最初の", "勝負．．．"]}, {"box": [107, 559, 125, 644], "vertical": true, "font_size": 17.0, "lines": ["もらった。"]}], "img_path": "019.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [721, 94, 755, 222], "vertical": true, "font_size": 28.0, "lines": ["また一年間、"]}, {"box": [185, 132, 209, 260], "vertical": true, "font_size": 21.0, "lines": ["よろしくね。"]}, {"box": [397, 632, 418, 692], "vertical": true, "font_size": 21.0, "lines": ["あれ？"]}, {"box": [699, 936, 745, 1060], "vertical": true, "font_size": 21.0, "lines": ["同じクラスで", "うれしいけど、"]}, {"box": [567, 917, 641, 1042], "vertical": true, "font_size": 21.0, "lines": ["勝負に負けて", "複雑ですか？", "西片センパイ。"]}, {"box": [199, 921, 248, 1037], "vertical": true, "font_size": 23.0, "lines": ["だから", "それやめて！"]}], "img_path": "020.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "021.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [760, 498, 787, 600], "vertical": true, "font_size": 20.0, "lines": ["オレは明片。"]}, {"box": [356, 494, 461, 649], "vertical": true, "font_size": 20.0, "lines": ["今日はワケあって", "変装して", "ゲームセンターに", "来ている。"]}, {"box": [114, 469, 171, 549], "vertical": true, "font_size": 26.0, "lines": ["目当ては", "これ。"]}, {"box": [510, 817, 540, 949], "vertical": true, "font_size": 30.0, "lines": ["本日稼働円"]}, {"box": [667, 868, 732, 1041], "vertical": true, "font_size": 28.0, "lines": ["「１００％片想い」の", "クレーンゲーム。"]}], "img_path": "022.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [658, 72, 737, 206], "vertical": true, "font_size": 20.0, "lines": ["知り合いに", "バレるワケには", "いかない．．．"]}, {"box": [233, 93, 331, 208], "vertical": true, "font_size": 20.0, "lines": ["こんな", "ところを", "知り合いに", "見られたら．．．"]}, {"box": [55, 203, 84, 241], "vertical": true, "font_size": 29.0, "lines": ["あ。"]}, {"box": [428, 488, 467, 554], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}], "img_path": "023.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [615, 62, 647, 116], "vertical": true, "font_size": 32.0, "lines": ["た．．"]}, {"box": [333, 77, 364, 191], "vertical": true, "font_size": 21.0, "lines": ["高木さん！？"]}, {"box": [190, 73, 219, 119], "vertical": true, "font_size": 29.0, "lines": ["ダ．．．"]}, {"box": [684, 492, 735, 627], "vertical": true, "font_size": 24.0, "lines": ["ダレの", "ことですか．．．？"]}, {"box": [240, 500, 268, 547], "vertical": true, "font_size": 28.0, "lines": ["ん？"]}, {"box": [672, 813, 749, 923], "vertical": true, "font_size": 27.0, "lines": ["あれーひとちが", "人違い", "ですかねー。"]}, {"box": [213, 956, 291, 1112], "vertical": true, "font_size": 22.0, "lines": ["でも", "西片ってのに反応", "してたしなー。"]}], "img_path": "024.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [328, 55, 381, 155], "vertical": true, "font_size": 26.0, "lines": ["何．．．", "高木さん．．．"]}, {"box": [53, 64, 104, 142], "vertical": true, "font_size": 23.0, "lines": ["やっぱり", "西片だ。"]}, {"box": [64, 199, 92, 267], "vertical": true, "font_size": 28.0, "lines": ["あはは"]}, {"box": [679, 431, 732, 554], "vertical": true, "font_size": 20.0, "lines": ["好きだねー", "「１００％片想い」。"]}, {"box": [161, 442, 217, 570], "vertical": true, "font_size": 24.0, "lines": ["これ、今日から", "でしょ。"]}, {"box": [678, 758, 752, 862], "vertical": true, "font_size": 21.0, "lines": ["．．．．．", "高木さんは", "なぜここに。"]}, {"box": [412, 782, 438, 885], "vertical": true, "font_size": 20.0, "lines": ["好きだから、"]}, {"box": [108, 782, 131, 835], "vertical": true, "font_size": 23.0, "lines": ["だよ。"]}], "img_path": "025.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [408, 90, 492, 240], "vertical": true, "font_size": 23.0, "lines": ["あ！！", "『１００％片想い』が", "ってことか。"]}, {"box": [111, 123, 134, 260], "vertical": true, "font_size": 20.0, "lines": ["ビックリした。"]}, {"box": [704, 445, 752, 580], "vertical": true, "font_size": 21.0, "lines": ["しかし", "知らなかった．．"]}, {"box": [557, 445, 658, 580], "vertical": true, "font_size": 21.0, "lines": ["高木さん", "そんなに", "１００％片想い", "好きだったのか"]}, {"box": [175, 494, 227, 614], "vertical": true, "font_size": 25.0, "lines": ["それで、", "どれ狙うの？"]}, {"box": [702, 809, 749, 894], "vertical": true, "font_size": 20.0, "lines": ["そりゃあ", "もちろん、"]}, {"box": [445, 813, 475, 961], "vertical": true, "font_size": 24.0, "lines": ["２人セットの、"]}, {"box": [582, 939, 617, 1010], "vertical": true, "font_size": 32.0, "lines": ["チラッ"]}, {"box": [106, 827, 134, 987], "vertical": true, "font_size": 25.0, "lines": ["ぬいぐるみ！！"]}], "img_path": "026.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [695, 72, 741, 205], "vertical": true, "font_size": 18.0, "lines": ["っていうのは．．．", "恥ずかしすぎる"]}, {"box": [401, 73, 452, 164], "vertical": true, "font_size": 24.0, "lines": ["パ．．．パズル", "かな．．．"]}, {"box": [51, 87, 100, 169], "vertical": true, "font_size": 23.0, "lines": ["ふーん", "そっかー。"]}, {"box": [726, 474, 746, 548], "vertical": true, "font_size": 20.0, "lines": ["じゃあ．．．"]}, {"box": [378, 519, 436, 583], "vertical": true, "font_size": 30.0, "lines": ["取ろう", "かな、"]}, {"box": [119, 523, 141, 612], "vertical": true, "font_size": 20.0, "lines": ["パズルを。"]}, {"box": [640, 885, 723, 1057], "vertical": true, "font_size": 24.0, "lines": ["そう．．．", "パズルを", "狙ったフリをして、"]}, {"box": [123, 900, 177, 1042], "vertical": true, "font_size": 20.0, "lines": ["２人セットの", "ぬいぐるみを！！"]}], "img_path": "027.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [733, 70, 805, 205], "vertical": true, "font_size": 20.0, "lines": ["おっと！！", "手元がくるって", "しまった！！"]}, {"box": [463, 64, 515, 170], "vertical": true, "font_size": 25.0, "lines": ["よし！！", "いい感じだ。"]}, {"box": [400, 67, 425, 128], "vertical": true, "font_size": 25.0, "lines": ["よし！！"]}, {"box": [100, 91, 131, 147], "vertical": true, "font_size": 31.0, "lines": ["いけ。"]}, {"box": [388, 271, 418, 352], "vertical": true, "font_size": 30.0, "lines": ["いけ！！"]}, {"box": [180, 967, 235, 1023], "vertical": true, "font_size": 30.0, "lines": ["あら、", "残念。"]}], "img_path": "028.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [693, 53, 746, 132], "vertical": true, "font_size": 20.0, "lines": ["じゃあ次", "私いい？"]}, {"box": [436, 66, 491, 181], "vertical": true, "font_size": 23.0, "lines": ["２人セットの", "狙おー。"]}, {"box": [101, 112, 131, 149], "vertical": true, "font_size": 25.0, "lines": ["な。"]}, {"box": [697, 868, 718, 953], "vertical": true, "font_size": 20.0, "lines": ["やったー"]}, {"box": [123, 890, 149, 983], "vertical": true, "font_size": 24.0, "lines": ["スゲー！！"]}], "img_path": "029.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [761, 44, 811, 223], "vertical": true, "font_size": 20.0, "lines": ["しかもバズルの", "横の２人セットを"]}, {"box": [495, 45, 513, 179], "vertical": true, "font_size": 16.0, "lines": ["こうなったら．．．"]}, {"box": [374, 80, 397, 229], "vertical": true, "font_size": 20.0, "lines": ["やるしかない！"]}, {"box": [722, 479, 749, 575], "vertical": true, "font_size": 23.0, "lines": ["おー、５００円。"]}, {"box": [640, 491, 663, 614], "vertical": true, "font_size": 23.0, "lines": ["やる気だねぇ。"]}, {"box": [169, 495, 215, 599], "vertical": true, "font_size": 20.0, "lines": ["これなら", "６回できる。"]}, {"box": [285, 796, 416, 954], "vertical": true, "font_size": 19.0, "lines": ["回数が余ったから", "しょうがなく", "２人セットを狙う", "という流れに", "もっていけるのさ"]}, {"box": [639, 846, 690, 982], "vertical": true, "font_size": 22.0, "lines": ["パズルを", "取ったあとに．．"]}], "img_path": "030.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [429, 140, 475, 300], "vertical": true, "font_size": 32.0, "lines": ["カンペキ。"]}, {"box": [337, 71, 373, 137], "vertical": true, "font_size": 31.0, "lines": ["１回目"]}, {"box": [722, 580, 752, 641], "vertical": true, "font_size": 25.0, "lines": ["２回目"]}, {"box": [526, 580, 556, 644], "vertical": true, "font_size": 29.0, "lines": ["３回目"]}, {"box": [366, 579, 395, 638], "vertical": true, "font_size": 26.0, "lines": ["４回目"]}, {"box": [189, 581, 219, 643], "vertical": true, "font_size": 25.0, "lines": ["５回目"]}, {"box": [674, 948, 721, 1068], "vertical": true, "font_size": 20.0, "lines": ["なんてこった、", "あとがない"]}, {"box": [113, 950, 169, 1028], "vertical": true, "font_size": 21.0, "lines": ["集中しろ", "オレ！！"]}], "img_path": "031.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [94, 853, 155, 929], "vertical": true, "font_size": 32.0, "lines": ["ありゃ、", "残念。"]}], "img_path": "032.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [701, 66, 754, 193], "vertical": true, "font_size": 25.0, "lines": ["最後", "惜しかったね。"]}, {"box": [381, 65, 434, 256], "vertical": true, "font_size": 20.0, "lines": ["６００円も使って．．．", "１つも取れないとは．．．"]}, {"box": [124, 22, 346, 99], "vertical": false, "font_size": 32.0, "lines": ["ガクゥ．．．"]}, {"box": [144, 562, 182, 614], "vertical": true, "font_size": 32.0, "lines": ["何？"]}, {"box": [620, 538, 711, 663], "vertical": true, "font_size": 21.0, "lines": ["ねぇ西片。"]}, {"box": [620, 829, 649, 867], "vertical": true, "font_size": 29.0, "lines": ["ん。"]}], "img_path": "033.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [764, 78, 795, 124], "vertical": true, "font_size": 31.0, "lines": ["へ？"]}, {"box": [370, 58, 418, 142], "vertical": true, "font_size": 22.0, "lines": ["これで", "よければ、"]}, {"box": [108, 121, 130, 207], "vertical": true, "font_size": 20.0, "lines": ["あげるよ。"]}, {"box": [365, 303, 415, 389], "vertical": true, "font_size": 24.0, "lines": ["い．．．", "いやいや、"]}, {"box": [101, 314, 148, 383], "vertical": true, "font_size": 22.0, "lines": ["もらえ", "ないよ。"]}, {"box": [660, 608, 711, 693], "vertical": true, "font_size": 24.0, "lines": ["いいから", "いいから、"]}, {"box": [578, 616, 599, 699], "vertical": true, "font_size": 24.0, "lines": ["１００円だし。"]}, {"box": [679, 928, 755, 1085], "vertical": true, "font_size": 24.0, "lines": ["す．．．", "好きって", "言ってたのに．．？"]}, {"box": [302, 940, 355, 1055], "vertical": true, "font_size": 20.0, "lines": ["あぁ、最初に", "言ったやつ？"]}], "img_path": "034.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [714, 106, 745, 164], "vertical": true, "font_size": 31.0, "lines": ["それ、"]}, {"box": [310, 132, 367, 291], "vertical": true, "font_size": 22.0, "lines": ["『１００％片想い』の", "ことじゃないよ。"]}, {"box": [613, 682, 671, 813], "vertical": true, "font_size": 22.0, "lines": ["私が好きって", "言ったのは、"]}], "img_path": "035.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [749, 90, 770, 234], "vertical": true, "font_size": 17.0, "lines": ["クレーンゲーム。"]}, {"box": [658, 672, 731, 788], "vertical": true, "font_size": 21.0, "lines": ["よかったねー", "一番ほしいの", "手に入って。"]}, {"box": [180, 707, 201, 802], "vertical": true, "font_size": 20.0, "lines": ["バレてる！！"]}], "img_path": "036.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [213, 958, 545, 1081], "vertical": false, "font_size": 32.0, "lines": ["握汁", "握力のやつ"]}], "img_path": "037.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [514, 87, 563, 166], "vertical": true, "font_size": 24.0, "lines": ["おはよー", "西片。"]}, {"box": [678, 508, 753, 596], "vertical": true, "font_size": 23.0, "lines": ["ああ", "おはよう", "高木さん。"]}, {"box": [298, 498, 322, 540], "vertical": true, "font_size": 24.0, "lines": ["ん？"]}, {"box": [707, 833, 743, 889], "vertical": true, "font_size": 32.0, "lines": ["西片、"]}, {"box": [629, 849, 656, 901], "vertical": true, "font_size": 32.0, "lines": ["それ。"]}, {"box": [190, 850, 221, 907], "vertical": true, "font_size": 31.0, "lines": ["ふっ。"]}], "img_path": "038.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [698, 86, 751, 193], "vertical": true, "font_size": 25.0, "lines": ["昨日．．", "買ったのさ。"]}, {"box": [356, 57, 405, 142], "vertical": true, "font_size": 24.0, "lines": ["どうだ", "高木さん。"]}, {"box": [250, 60, 306, 181], "vertical": true, "font_size": 20.0, "lines": ["運動部が", "よくやってる、"]}, {"box": [57, 71, 111, 215], "vertical": true, "font_size": 26.0, "lines": ["握力の", "かっこいいやつ。"]}, {"box": [680, 591, 727, 670], "vertical": true, "font_size": 21.0, "lines": ["うらやま", "しいか。"]}, {"box": [449, 691, 489, 742], "vertical": false, "font_size": 32.0, "lines": ["ギム"]}, {"box": [290, 595, 320, 649], "vertical": true, "font_size": 30.0, "lines": ["へー。"]}, {"box": [97, 570, 121, 638], "vertical": true, "font_size": 24.0, "lines": ["いいね。"]}, {"box": [664, 958, 743, 1047], 