171], "vertical": true, "font_size": 26.0, "lines": ["あ、おはよ、", "西片。"]}, {"box": [277, 79, 360, 258], "vertical": true, "font_size": 24.0, "lines": ["今日、占いで星座と", "血液型西片一位", "だったね。"]}, {"box": [189, 59, 214, 120], "vertical": true, "font_size": 25.0, "lines": ["そう！！"]}, {"box": [55, 326, 75, 405], "vertical": true, "font_size": 19.0, "lines": ["だけど．．．"]}, {"box": [699, 652, 746, 842], "vertical": true, "font_size": 20.0, "lines": ["ま．．．毎日", "チェックしてるの．．．？"]}, {"box": [624, 676, 644, 799], "vertical": true, "font_size": 20.0, "lines": ["オレの分まで。"]}, {"box": [146, 675, 196, 782], "vertical": true, "font_size": 24.0, "lines": ["まー", "ついでにね。"]}, {"box": [725, 966, 752, 1034], "vertical": true, "font_size": 25.0, "lines": ["それで、"]}, {"box": [459, 972, 512, 1068], "vertical": true, "font_size": 18.0, "lines": ["今回は何を", "するの？"]}, {"box": [384, 964, 414, 1020], "vertical": true, "font_size": 30.0, "lines": ["ふっ。"]}], "img_path": "103.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [711, 67, 786, 203], "vertical": true, "font_size": 22.0, "lines": ["前の占いは", "当たらなかった", "けど．．．"]}, {"box": [610, 79, 656, 192], "vertical": true, "font_size": 22.0, "lines": ["今回は勝って", "みせるよ。"]}, {"box": [436, 110, 518, 208], "vertical": true, "font_size": 23.0, "lines": ["前のも", "当たってた", "けどなー。"]}, {"box": [369, 60, 391, 183], "vertical": true, "font_size": 18.0, "lines": ["クリティカル。"]}, {"box": [666, 644, 747, 741], "vertical": true, "font_size": 22.0, "lines": ["ま．．．前のは", "もういい", "から．．．"]}, {"box": [373, 639, 394, 707], "vertical": true, "font_size": 21.0, "lines": ["あはは。"]}, {"box": [277, 646, 326, 746], "vertical": true, "font_size": 22.0, "lines": ["て、", "何するの？"]}, {"box": [749, 944, 776, 1050], "vertical": true, "font_size": 24.0, "lines": ["おみくじ。"]}], "img_path": "104.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [652, 103, 732, 257], "vertical": true, "font_size": 23.0, "lines": ["大凶から大吉まで", "一枚ずつ計７枚", "袋に入ってる。"]}, {"box": [167, 75, 277, 194], "vertical": true, "font_size": 25.0, "lines": ["交互に引いて", "先に大吉を", "引いた方の", "勝ち。"]}, {"box": [64, 103, 91, 173], "vertical": true, "font_size": 25.0, "lines": ["ふーん。"]}, {"box": [697, 495, 751, 621], "vertical": true, "font_size": 20.0, "lines": ["じゃ、高木さん", "先攻どうぞ。"]}, {"box": [410, 502, 461, 590], "vertical": true, "font_size": 24.0, "lines": ["へえ", "余裕だね。"]}, {"box": [299, 492, 354, 619], "vertical": true, "font_size": 22.0, "lines": ["まぁ、運勢一位", "だからね。"]}, {"box": [658, 833, 753, 923], "vertical": true, "font_size": 22.0, "lines": ["あ", "その前に．．", "ちょっと", "待って。"]}, {"box": [206, 832, 230, 882], "vertical": true, "font_size": 22.0, "lines": ["よし。"]}], "img_path": "105.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [658, 57, 685, 101], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [455, 67, 504, 154], "vertical": true, "font_size": 22.0, "lines": ["これも", "入れてよ。"]}, {"box": [387, 69, 407, 164], "vertical": true, "font_size": 20.0, "lines": ["いいけど．．．"]}, {"box": [103, 99, 142, 151], "vertical": true, "font_size": 32.0, "lines": ["何？"]}, {"box": [673, 461, 711, 557], "vertical": true, "font_size": 32.0, "lines": ["超大吉。"]}, {"box": [723, 849, 750, 891], "vertical": true, "font_size": 27.0, "lines": ["へ？"]}, {"box": [445, 844, 472, 900], "vertical": true, "font_size": 27.0, "lines": ["ふふ。"]}, {"box": [360, 839, 387, 962], "vertical": true, "font_size": 24.0, "lines": ["引いてみての、"]}, {"box": [106, 865, 133, 950], "vertical": true, "font_size": 21.0, "lines": ["お楽しみ。"]}], "img_path": "106.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [700, 118, 747, 193], "vertical": true, "font_size": 21.0, "lines": ["．．．．．．まぁ", "いいか。"]}, {"box": [499, 114, 518, 179], "vertical": true, "font_size": 19.0, "lines": ["なにせ"]}, {"box": [400, 179, 459, 250], "vertical": true, "font_size": 30.0, "lines": ["今日の", "オレは、"]}, {"box": [80, 51, 371, 73], "vertical": false, "font_size": 20.