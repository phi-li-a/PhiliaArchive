e, "font_size": 24.0, "lines": ["ここも", "だねー。"]}, {"box": [325, 83, 346, 144], "vertical": true, "font_size": 22.0, "lines": ["くそ．．．"]}, {"box": [242, 92, 291, 208], "vertical": true, "font_size": 22.0, "lines": ["なんで", "オレばかり．．．"]}, {"box": [640, 502, 704, 669], "vertical": true, "font_size": 28.0, "lines": ["西片って血液型", "Ｏ型でしょ。"]}, {"box": [130, 514, 227, 656], "vertical": true, "font_size": 25.0, "lines": ["Ｏ型って", "蚊に好かれる", "らしいから。"]}, {"box": [632, 907, 714, 1023], "vertical": true, "font_size": 20.0, "lines": ["く．．．Ｏ型で", "後悔する日が", "来るとは．．．"]}, {"box": [263, 905, 318, 975], "vertical": true, "font_size": 25.0, "lines": ["大げさ", "だなー。"]}], "img_path": "093.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [698, 119, 778, 236], "vertical": true, "font_size": 23.0, "lines": ["高木さんは", "全然刺されて", "ないよね。"]}, {"box": [306, 63, 361, 118], "vertical": true, "font_size": 27.0, "lines": ["ああ", "うん。"]}, {"box": [124, 203, 154, 268], "vertical": true, "font_size": 25.0, "lines": ["私は．．"]}, {"box": [689, 545, 723, 655], "vertical": true, "font_size": 28.0, "lines": ["待った！！"]}, {"box": [711, 840, 775, 944], "vertical": true, "font_size": 28.0, "lines": ["当てて", "みせよう。"]}, {"box": [174, 851, 248, 985], "vertical": true, "font_size": 28.0, "lines": ["高木さんの", "血液型．．．"]}], "img_path": "094.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [725, 67, 744, 132], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．．"]}, {"box": [406, 96, 458, 212], "vertical": true, "font_size": 21.0, "lines": ["当たらないと", "思うよ。"]}, {"box": [303, 71, 350, 174], "vertical": true, "font_size": 21.0, "lines": ["じゃあ", "当たったら、"]}, {"box": [67, 125, 96, 248], "vertical": true, "font_size": 22.0, "lines": ["オレの勝ちで。"]}, {"box": [704, 469, 727, 535], "vertical": true, "font_size": 22.0, "lines": ["いいよ。"]}, {"box": [377, 476, 401, 540], "vertical": true, "font_size": 24.0, "lines": ["よし．．"]}, {"box": [251, 440, 299, 520], "vertical": true, "font_size": 22.0, "lines": ["さて", "推理だ．．．"]}, {"box": [105, 445, 158, 578], "vertical": true, "font_size": 18.0, "lines": ["まず高木さんは", "０型ではない。"]}, {"box": [695, 848, 715, 929], "vertical": true, "font_size": 20.0, "lines": ["なぜなら、"]}, {"box": [458, 834, 489, 911], "vertical": true, "font_size": 25.0, "lines": ["残るは、"]}, {"box": [62, 858, 128, 939], "vertical": true, "font_size": 28.0, "lines": ["Ａ、Ｂ", "ＡＢ型"]}, {"box": [571, 956, 618, 1068], "vertical": true, "font_size": 20.0, "lines": ["蚊に刺されて", "いないから。"]}], "img_path": "095.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [575, 98, 622, 213], "vertical": true, "font_size": 20.0, "lines": ["ここまでなら", "三択だった．．．"]}, {"box": [451, 84, 524, 238], "vertical": true, "font_size": 21.0, "lines": ["しかし", "今の高木さんの", "不用心なセリフ．．．"]}, {"box": [381, 125, 398, 188], "vertical": true, "font_size": 17.0, "lines": ["．．．．．．"]}, {"box": [92, 144, 144, 260], "vertical": true, "font_size": 21.0, "lines": ["当たらないと", "思うよ。"]}, {"box": [619, 488, 725, 632], "vertical": true, "font_size": 23.0, "lines": ["当たらないと", "思う．．．", "つまり、確率が", "低いということ。"]}, {"box": [117, 499, 140, 571], "vertical": true, "font_size": 20.0, "lines": ["ならば、"]}, {"box": [497, 826, 545, 938], "vertical": true, "font_size": 32.0, "lines": ["ＡＢ型。"]}, {"box": [183, 775, 212, 823], "vertical": true, "font_size": 29.0, "lines": ["フッ"]}], "img_path": "096.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [680, 94, 733, 237], "vertical": true, "font_size": 22.0, "lines": ["と、普通なら", "そう思うだろう。"]}, {"box": [402, 75, 451, 155], "vertical": true, "font_size": 22.0, "lines": ["見くびり", "すぎだよ"]}, {"box": [319, 76, 342, 192], "vertical": true, "font_size": 22.0, "lines": ["高木さん．．．！"]}, {"box": [64, 70, 135, 205], "vertical": true, "font_size": 17.0, "lines": ["そんなセリフに", "だまされたりは", "しないのさ。"]}, {"box": [610, 389, 725, 568], "vertical": true, "font_size": 21.0, "lines": ["こういう時", "高木さんは", "常に裏をとって", "こようとするんだ。"]}, {"box": [124, 386, 238, 558], "vertical": true, "font_size": 24.0, "lines": ["つまり", "本当の答えは", "日本人に一番多い", "血液型．．．"]}, {"box": [332, 705, 403, 868], "vertical": true, "font_size": 32.0, "lines": ["Ａ型だ。"]}], "img_path": "097.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [604, 86, 629, 155], "vertical": true, "font_size": 25.0, "lines": ["はずれ。"]}, {"box": [435, 93, 472, 153], "vertical": true, "font_size": 32.0, "lines": ["な！！"]}, {"box": [315, 121, 343, 187], "vertical": true, "font_size": 21.0, "lines": ["答えは、"]}, {"box": [103, 130, 132, 234], "vertical": true, "font_size": 21.0, "lines": ["Ｏ型でした。"]}, {"box": [694, 636, 745, 771], "vertical": true, "font_size": 20.0, "lines": ["当たらないって", "言ったでしょ。"]}, {"box": [101, 639, 122, 754], "vertical": true, "font_size": 20.0, "lines": ["い．．．いや．．．！！"]}, {"box": [692, 958, 746, 1110], "vertical": true, "font_size": 27.0, "lines": ["じゃあ", "おかしくない！？"]}, {"box": [579, 970, 640, 1046], "vertical": true, "font_size": 27.0, "lines": ["だって", "Ｏ型は、"]}, {"box": [162, 960, 226, 1116], "vertical": true, "font_size": 31.0, "lines": ["蚊に", "刺されやすい．．．"]}], "img_path": "098.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [681, 106, 707, 155], "vertical": true, "font_size": 26.0, "lines": ["ん？"]}, {"box": [231, 67, 255, 111], "vertical": true, "font_size": 24.0, "lines": ["な．．．"]}, {"box": [60, 275, 115, 373], "vertical": true, "font_size": 24.0, "lines": ["虫よけ", "スプレー．．．"]}, {"box": [621, 629, 723, 753], "vertical": true, "font_size": 20.0, "lines": ["言おうと", "したら", "勝負しかけて", "くるんだもん。"]}, {"box": [148, 618, 229, 754], "vertical": true, "font_size": 20.0, "lines": ["絶対Ｏ型って", "答えないなーと", "思ったよ。"]}, {"box": [702, 921, 734, 1113], "vertical": true, "font_size": 30.0, "lines": ["あぁあー"]}, {"box": [117, 932, 188, 1156], "vertical": true, "font_size": 25.0, "lines": ["最初から負けて", "いたのか！"]}], "img_path": "099.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [5