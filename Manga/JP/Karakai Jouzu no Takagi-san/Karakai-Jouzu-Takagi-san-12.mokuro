: 20.0, "lines": ["別にいいよ．．"]}, {"box": [107, 113, 156, 247], "vertical": true, "font_size": 18.0, "lines": ["負けてるオレが", "悪いんだし．．"]}], "img_path": "088.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [690, 75, 733, 139], "vertical": true, "font_size": 32.0, "lines": ["西片、"]}, {"box": [357, 111, 392, 251], "vertical": true, "font_size": 29.0, "lines": ["目つぶって。"]}, {"box": [237, 89, 282, 151], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}, {"box": [702, 577, 745, 655], "vertical": true, "font_size": 21.0, "lines": ["いいからはや", "ほら早く。"]}, {"box": [490, 577, 546, 643], "vertical": true, "font_size": 28.0, "lines": ["見えて", "ない？"]}, {"box": [282, 574, 301, 643], "vertical": true, "font_size": 17.0, "lines": ["うん。"]}, {"box": [117, 605, 153, 667], "vertical": true, "font_size": 32.0, "lines": ["な．．．"]}, {"box": [721, 885, 742, 998], "vertical": true, "font_size": 25.0, "lines": ["なんだ．．．？"]}, {"box": [617, 884, 678, 1069], "vertical": true, "font_size": 25.0, "lines": ["さっき", "お返しとかって．．．"]}, {"box": [62, 904, 133, 1019], "vertical": true, "font_size": 32.0, "lines": ["ま．．．", "まさか．．"]}], "img_path": "089.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [752, 86, 791, 153], "vertical": true, "font_size": 32.0, "lines": ["キ．．．"]}, {"box": [263, 85, 291, 180], "vertical": true, "font_size": 28.0, "lines": ["えっ！？"]}, {"box": [650, 610, 727, 718], "vertical": true, "font_size": 28.0, "lines": ["あー、", "逃がし", "ちゃったや。"]}, {"box": [180, 594, 247, 716], "vertical": true, "font_size": 31.0, "lines": ["何！？", "なんなの！？"]}, {"box": [593, 875, 649, 996], "vertical": true, "font_size": 26.0, "lines": ["蚊が", "いたんだよ．．．"]}, {"box": [511, 884, 547, 937], "vertical": true, "font_size": 32.0, "lines": ["蚊．．．"]}, {"box": [352, 896, 375, 993], "vertical": true, "font_size": 20.0, "lines": ["ホントに？"]}, {"box": [251, 933, 279, 965], "vertical": false, "font_size": 26.0, "lines": ["ス"]}, {"box": [104, 889, 153, 957], "vertical":