: 32.0, "lines": ["うん。"]}, {"box": [1031, 1539, 1063, 1678], "vertical": true, "font_size": 32.0, "lines": ["．．．そっか。"]}], "img_path": "148.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1153, 95, 1187, 219], "vertical": true, "font_size": 32.0, "lines": ["そっか．．．"]}, {"box": [708, 103, 832, 289], "vertical": true, "font_size": 32.0, "lines": ["呼ぶなら", "オレから．．．", "ってことか．．．"]}, {"box": [545, 116, 635, 284], "vertical": true, "font_size": 32.0, "lines": ["思い出して", "くれたんだ。"]}, {"box": [798, 847, 866, 1059], "vertical": true, "font_size": 30.0, "lines": ["なんか．．．あらた", "まっちゃうと．．．"]}, {"box": [669, 866, 744, 991], "vertical": true, "font_size": 30.0, "lines": ["今さらな", "だけに、"]}, {"box": [937, 1111, 964, 1212], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．？"]}, {"box": [196, 885, 271, 1038], "vertical": true, "font_size": 32.0, "lines": ["ムダに", "テレるな．．．"]}, {"box": [183, 1166, 215, 1273], "vertical": true, "font_size": 32.0, "lines": ["あはは。"]}, {"box": [817, 1458, 988, 1674], "vertical": true, "font_size": 32.0, "lines": ["両親との", "あいさつとかも", "なんかニゴして", "たしねー。"]}, {"box": [256, 1440, 502, 1656], "vertical": true, "font_size": 32.0, "lines": ["いやー．．．", "ホントにずっと", "高木さんて", "呼んでたのが", "しっくり", "きすぎてて．．．"]}], "img_path": "149.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1235, 136, 1278, 221], "vertical": true, "font_size": 32.0, "lines": ["でも、"]}, {"box": [628, 189, 758, 406], "vertical": true, "font_size": 32.0, "lines": ["今すごく", "下の名前で", "呼びたいから．．"]}, {"box": [181, 703, 238, 795], "vertical": true, "font_size": 32.0, "lines": ["呼ぶ。"]}, {"box": [1072, 1125, 1117, 1213], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}], "img_path": "150.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1017, 1411, 1132, 1609], "vertical": true, "font_size": 31.0, "lines": ["あはは、", "なんか声", "ふるえてたよ。"]}, {"box": [855, 1408, 898, 1492], "vertical": true, "font_size": 32.0, "lines": ["な！"]}, {"box": [513, 1392, 598, 1590], "vertical": true, "font_size": 32.0, "lines": ["それに名前", "呼ぶだけって。"]}, {"box": [335, 1432, 402, 1667], "vertical": true, "font_size": 26.0, "lines": ["しょうがないだろ、", "緊張したんだから。"]}], "img_path": "151.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1025, 1438, 1142, 1599], "vertical": true, "font_size": 32.0, "lines": ["あらためて", "これから", "よろしくね、"]}, {"box": [900, 1471, 958, 1563], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [650, 1426, 738, 1558], "vertical": true, "font_size": 32.0, "lines": ["うん、", "よろし．．"]}, {"box": [532, 1479, 573, 1578], "vertical": true, "font_size": 32.0, "lines": ["あれ！？"]}, {"box": [376, 1805, 960, 1845], "vertical": false, "font_size": 32.0, "lines": ["一からかい上手の高木さん図・完一"]}, {"box": [174, 1440, 390, 1691], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "冗談だよ。", "これから", "いっぱい", "呼ぶね。"]}], "img_path": "152.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "153.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [705, 73, 1218, 1522], "vertical": true, "font_size": 32.0, "lines": ["あれませんよ", "１１００Ｊ＃", "汁弟瑞瀬湖ユニ東浜迷", "Ｂｏｏｋ"]}, {"box": [1207, 510, 1263, 1798], "vertical": true, "font_size": 32.0, "lines": ["ＫａｒｄｋａｉｊｏｚｕｎｏＴａｋａｇｉｓａｎＷｏｒｌｄ"]}, {"box": [720, 1201, 767, 1239], "vertical": false, "font_size": 32.0, "lines": ["５"]}, {"box": [847, 1535, 969, 1815], "vertical": true, "font_size": 29.0, "lines": ["ひさ", "あ々ひい"]}, {"box": [201, 1550, 487, 1813], "vertical": false, "font_size": 32.0, "lines": ["！？．．．４ｖａ", "ＭｒｒｕｂＨｉｔ", "京盛期党ＳＭＣ", "一定出ささすげにさん", "・テーメメリハ", "．．．みんな平成く"]}], "img_path": "154.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [230, 101, 545, 712], "vertical": true, "font_size": 32.0, "lines": ["きゅきこんやるくりがみんな", "一と８熊"]}, {"box": [116, 104, 193, 647], "vertical": true, "font_size": 32.0, "lines": ["●日平に〈引〉卵汁水〉＞２＞９概帯はＩさ", "審査員