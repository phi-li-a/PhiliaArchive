, "lines": ["あ。"]}, {"box": [1117, 978, 1163, 1116], "vertical": true, "font_size": 32.0, "lines": ["罰ゲーム、"]}, {"box": [707, 988, 749, 1218], "vertical": true, "font_size": 32.0, "lines": ["何にしようかな。"]}, {"box": [241, 969, 286, 1048], "vertical": true, "font_size": 32.0, "lines": ["んー、"]}, {"box": [153, 990, 185, 1128], "vertical": true, "font_size": 32.0, "lines": ["そーだな。"]}, {"box": [157, 1518, 189, 1707], "vertical": true, "font_size": 32.0, "lines": ["あ、じゃあさ、"]}], "img_path": "141.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1053, 138, 1220, 307], "vertical": true, "font_size": 32.0, "lines": ["私のこと", "苗字の", "「高木さん」", "じゃなくて"]}, {"box": [296, 170, 386, 313], "vertical": true, "font_size": 32.0, "lines": ["名前で", "呼んでよ。"]}, {"box": [1143, 926, 1188, 982], "vertical": true, "font_size": 32.0, "lines": ["へ。"]}], "img_path": "142.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1093, 88, 1168, 227], "vertical": true, "font_size": 32.0, "lines": ["これから", "ずっとね。"]}, {"box": [609, 82, 643, 208], "vertical": true, "font_size": 32.0, "lines": ["ずっと！？"]}, {"box": [585, 371, 628, 459], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}, {"box": [397, 95, 474, 225], "vertical": true, "font_size": 32.0, "lines": ["さすがに", "それは．．．"]}, {"box": [67, 118, 156, 245], "vertical": true, "font_size": 32.0, "lines": ["恥ずかし", "すぎる。"]}, {"box": [975, 583, 1183, 860], "vertical": true, "font_size": 32.0, "lines": ["いや、でも", "ここでサラッと", "名前を呼んだら", "高木さんビックリ", "するんじゃないか！？"]}, {"box": [168, 592, 241, 817], "vertical": true, "font_size": 32.0, "lines": ["カウンターを", "決めるチャンス。"]}, {"box": [1149, 1225, 1176, 1349], "vertical": true, "font_size": 26.0, "lines": ["じゃあ．．．"]}, {"box": [763, 1335, 812, 1438], "vertical": true, "font_size": 32.0, "lines": ["コホン"]}], "img_path": "143.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1115, 135, 1194, 260], "vertical": true, "font_size": 32.0, "lines": ["やっぱり", "ムリー"]}, {"box": [585, 159, 616, 283], "vertical": true, "font_size": 31.0, "lines": ["あれー？"]}, {"box": [393, 123, 478, 275], "vertical": true, "font_size": 32.0, "lines": ["恥ずかしい", "のかな？"]}, {"box": [163, 204, 273, 431], "vertical": true, "font_size": 32.0, "lines": ["そ．．．", "そういうわけじゃ", "ないけど．．．！！"]}, {"box": [1076, 661, 1125, 748], "vertical": true, "font_size": 32.0, "lines": ["んー、"]}, {"box": [258, 663, 386, 789], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "しょうが", "ない。"]}, {"box": [630, 963, 809, 1396], "vertical": true, "font_size": 32.0, "lines": ["西片が呼んで", "くれたら、", "私も西片を", "名前で呼ぶよ。"]}, {"box": [166, 1016, 214, 1213], "vertical": true, "font_size": 32.0, "lines": ["！！！", "えー"]}], "img_path": "144.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1035, 110, 1161, 292], "vertical": true, "font_size": 28.0, "lines": ["それ余計", "恥ずかしいん", "だけど！！"]}, {"box": [573, 151, 692, 320], "vertical": true, "font_size": 32.0, "lines": ["やっぱり", "恥ずかし", "かったんだ。"]}, {"box": [465, 105, 493, 206], "vertical": true, "font_size": 28.0, "lines": ["．．．．．．"]}, {"box": [86, 288, 118, 414], "vertical": true, "font_size": 32.0, "lines": ["えっと．．．"]}, {"box": [1033, 804, 1155, 1050], "vertical": true, "font_size": 32.0, "lines": ["そう．．．！！", "なんか高木さんて", "呼び慣れてるし！！"]}, {"box": [669, 630, 722, 684], "vertical": false, "font_size": 32.0, "lines": ["！？"]}, {"box": [305, 789, 425, 1048], "vertical": true, "font_size": 31.0, "lines": ["オレも西片って", "呼ばれ慣れ", "ちゃってるからさ！！"]}, {"box": [153, 815, 223, 1027], "vertical": true, "font_size": 31.0, "lines": ["このままの方が", "いいかなー！！"]}, {"box": [1065, 1291, 1183, 1494], "vertical": true, "font_size": 32.0, "lines": ["んーたしかに", "それは", "あるかも。"]}, {"box": [558, 1335, 591, 1462], "vertical": true, "font_size": 32.0, "lines": ["でしょ！！"]}, {"box": [258, 1284, 421, 1464], "vertical": true, "font_size": 32.0, "lines": ["よし．．", "これで他の", "罰ゲームになが", "する流れで．．．"]}], "img_path": "145.jpg"}, {"version": "0.1.6", 