{"version": "0.2.0-beta.6", "title": "Karakai Jouzu no Takagi-san", "title_uuid": "8b310d10-25a6-4fdb-aaef-cacc33c51c4b", "volume": "Karakai-Jouzu-Takagi-san-19", "volume_uuid": "06012528-cab8-42ce-b7ca-4634b473331e", "pages": [{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1207, 12, 1331, 1286], "vertical": true, "font_size": 32.0, "lines": ["からか、上手の国家さんの山本盤町"]}, {"box": [1016, 1842, 1302, 1873], "vertical": false, "font_size": 13.0, "lines": ["ＳＨＯＮＦＡＳＵＮＤＡＣｏｎｄＣＳＳＰＦＣＩＡＬ"]}], "img_path": "001.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "002.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [105, 1753, 988, 1818], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さんいい山本崇"]}], "img_path": "003.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1063, 845, 1243, 870], "vertical": false, "font_size": 25.0, "lines": ["ｏれｔｃれｔＳ"]}, {"box": [1153, 1149, 1189, 1320], "vertical": true, "font_size": 32.0, "lines": ["髪型"]}, {"box": [926, 1126, 965, 1239], "vertical": true, "font_size": 32.0, "lines": ["ケンケン"]}, {"box": [707, 1151, 742, 1213], "vertical": true, "font_size": 32.0, "lines": ["んっ．．．"]}, {"box": [482, 1126, 517, 1320], "vertical": true, "font_size": 26.0, "lines": ["お見舞い"]}, {"box": [241, 1123, 309, 1271], "vertical": true, "font_size": 32.0, "lines": ["ユカリの", "ハレンタイン"]}, {"box": [1154, 1509, 1188, 1659], "vertical": true, "font_size": 26.0, "lines": ["委員会決め"]}, {"box": [930, 1543, 965, 1633], "vertical": true, "font_size": 32.0, "lines": ["誕生日"]}, {"box": [708, 1548, 740, 1629], "vertical": true, "font_size": 29.0, "lines": ["タッチ"]}, {"box": [484, 1557, 516, 1623], "vertical": true, "font_size": 30.0, "lines": ["名前"]}], "img_path": "004.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1023, 116, 1145, 333], "vertical": true, "font_size": 32.0, "lines": ["く．．．", "また居残り掃除", "とは．．．"]}, {"box": [515, 151, 551, 349], "vertical": true, "font_size": 32.0, "lines": ["こりないねえ。"]}, {"box": [1104, 476, 1222, 558], "vertical": true, "font_size": 32.0, "lines": ["型"]}, {"box": [1067, 641, 1198, 808], "vertical": true, "font_size": 32.0, "lines": ["もう少しで", "勝てたん", "だけどなぁ。"]}, {"box": [395, 635, 556, 815], "vertical": true, "font_size": 32.0, "lines": ["ていうか、", "さっきから", "高木さんは", "何してるの？"]}, {"box": [283, 729, 326, 815], "vertical": true, "font_size": 32.0, "lines": ["んー、"]}, {"box": [1067, 1265, 1123, 1381], "vertical": true, "font_size": 32.0, "lines": ["さて、"]}, {"box": [120, 1256, 166, 1563], "vertical": true, "font_size": 32.0, "lines": ["なんでしょう？"]}], "img_path": "005.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "006.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [78, 28, 508, 251], "vertical": false, "font_size": 32.0, "lines": ["がた", "型", "髪"]}], "img_path": "007.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [361, 144, 450, 318], "vertical": true, "font_size": 32.0, "lines": ["あ！", "高木さん！？"]}, {"box": [174, 191, 255, 331], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "そうだよ。"]}, {"box": [997, 800, 1128, 1021], "vertical": true, "font_size": 32.0, "lines": ["文化祭の道具", "いっぱい置いて", "あったから、"]}, {"box": [200, 804, 417, 1035], "vertical": true, "font_size": 32.0, "lines": ["面白いの", "ないかなって", "探してたら", "ウィッグ", "見つけたんだー。"]}, {"box": [1093, 1278, 1177, 1498], "vertical": true, "font_size": 32.0, "lines": ["ちょうど週末に", "美容室で、"]}, {"box": [832, 1303, 999, 1548], "vertical": true, "font_size": 32.0, "lines": ["次は思い切って", "髪型変えてみても", "いいかなって", "考えてたから、"]}, {"box": [168, 1308, 244, 1567], "vertical": true, "font_size": 30.0, "lines": ["これでいろいろ", "試してみようかな。"]}], "img_path": "008.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1158, 135, 1202, 228], "vertical": true, "font_size": 32.0, "lines": ["へえ．．．"]}, {"box": [586, 101, 793, 637], "vertical": true, "font_size": 32.0, "lines": ["あ、そうだ。", "せっかくだし", "その方が", "西片の好きな", "からかいやすくなる", "髪型にして", "かもしれないし。", "みようかな。"]}, {"box": [1136, 528, 1184, 641], "vertical": true, "font_size": 32.0, "lines": ["髪型を。"]}, {"box": [170, 513, 213, 585], "vertical": true, "font_size": 32.0, "lines": ["え！？"]}, {"box": [590, 873, 721, 1057], "vertical": true, "font_size": 32.0, "lines": ["西片は", "どんな髪型が", "好き？"]}, {"box": [1076, 1434, 1201, 1651], "vertical": true, "font_size": 32.0, "lines": ["いや．．．別に", "好みの髪型とか", "ないけど．．．！"]}, {"box": [577, 1452, 612, 1558], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [69, 1447, 154, 1636], "vertical": true, "font_size": 32.0, "lines": ["じゃあ調べて", "みようかな。"]}], "img_path": "009.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1065, 209, 1106, 393], "vertical": true, "font_size": 32.0, "lines": ["調べるって．．．"]}, {"box": [735, 146, 783, 245], "vertical": true, "font_size": 32.0, "lines": ["これ、"]}, {"box": [208, 184, 257, 410], "vertical": true, "font_size": 32.0, "lines": ["似合ってる？"]}, {"box": [1128, 1456, 1211, 1702], "vertical": true, "font_size": 32.0, "lines": ["に、似合ってるん", "じゃないかな．．．？"]}, {"box": [675, 1468, 710, 1693], "vertical": true, "font_size": 30.0, "lines": ["今のテレ方だと、"]}, {"box": [560, 1483, 631, 1665], "vertical": true, "font_size": 30.0, "lines": ["まあまあって", "とこかな。"]}, {"box": [165, 1475, 249, 1616], "vertical": true, "font_size": 32.0, "lines": ["そういう", "調べ方？！！"]}], "img_path": "010.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1083, 159, 1166, 311], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "次はこれ。"]}, {"box": [357, 88, 442, 359], "vertical": true, "font_size": 32.0, "lines": ["あ！ちょっと", "キュン子っぽい！"]}, {"box": [601, 956, 792, 1205], "vertical": true, "font_size": 30.0, "lines": ["いや、しかし", "ちょっとときめいて", "しまっているのを", "バレるわけには", "いかない！"]}, {"box": [156, 951, 242, 1224], "vertical": true, "font_size": 30.0, "lines": ["絶対に！", "からかわれるから！！"]}, {"box": [960, 1466, 1125, 1620], "vertical": true, "font_size": 32.0, "lines": ["いやー、", "どこかで", "見たことの", "ある．．．"]}, {"box": [358, 1471, 416, 1560], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [171, 1661, 196, 1707], "vertical": true, "font_size": 25.0, "lines": ["！"]}], "img_path": "011.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [641, 167, 723, 348], "vertical": true, "font_size": 32.0, "lines": ["好き？"]}, {"box": [157, 268, 234, 414], "vertical": true, "font_size": 32.0, "lines": ["な！！"]}, {"box": [1072, 1048, 1170, 1192], "vertical": true, "font_size": 32.0, "lines": ["髪型の", "ことだよ。"]}, {"box": [1127, 1447, 1209, 1661], "vertical": true, "font_size": 32.0, "lines": ["かなり好きそう", "だねー。"]}, {"box": [654, 1449, 737, 1664], "vertical": true, "font_size": 32.0, "lines": ["いや！今の", "台詞のせいで！"]}, {"box": [435, 1473, 566, 1686], "vertical": true, "font_size": 32.0, "lines": ["大丈夫．．．天丈夫、", "ちゃんと", "わかってるよ。"]}, {"box": [211, 1530, 250, 1697], "vertical": true, "font_size": 32.0, "lines": ["ホントに！？"]}], "img_path": "012.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1110, 125, 1203, 385], "vertical": true, "font_size": 32.0, "lines": ["西片わかりやすい", "から、"]}, {"box": [595, 141, 679, 397], "vertical": true, "font_size": 29.0, "lines": ["目見たらだいたい", "わかっちゃうよ。"]}, {"box": [131, 144, 213, 279], "vertical": true, "font_size": 32.0, "lines": ["そこまで", "言うなら、"]}, {"box": [1027, 811, 1112, 1010], "vertical": true, "font_size": 32.0, "lines": ["じゃあ、次", "これどうかな。"]}, {"box": [150, 804, 268, 1110], "vertical": true, "font_size": 30.0, "lines": ["ホントにわかってるか", "確かめさせて", "もらおう！！"]}, {"box": [1147, 1344, 1176, 1421], "vertical": true, "font_size": 29.0, "lines": ["．．．．．"]}, {"box": [735, 1398, 762, 1535], "vertical": true, "font_size": 26.0, "lines": ["まあまあ。"]}, {"box": [521, 1389, 645, 1666], "vertical": true, "font_size": 32.0, "lines": ["オレの", "ポーカーフェースを", "見せてやる！！"]}, {"box": [90, 1374, 124, 1602], "vertical": true, "font_size": 31.0, "lines": ["ふーん、そっか。"]}], "img_path": "013.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1166, 135, 1201, 393], "vertical": true, "font_size": 32.0, "lines": ["これどうですかー、"]}, {"box": [226, 165, 273, 363], "vertical": true, "font_size": 32.0, "lines": ["西片センパイ。"]}, {"box": [403, 840, 446, 1097], "vertical": true, "font_size": 32.0, "lines": ["似合ってるかなー。"]}, {"box": [665, 1375, 708, 1590], "vertical": true, "font_size": 32.0, "lines": ["元気出してこ！"]}, {"box": [798, 1698, 832, 1800], "vertical": true, "font_size": 32.0, "lines": ["どう？"]}], "img_path": "014.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1158, 204, 1190, 523], "vertical": true, "font_size": 27.0, "lines": ["ごきげんうるわしゅう。"]}, {"box": [511, 180, 555, 501], "vertical": true, "font_size": 32.0, "lines": ["落ち着いた感じだねー。"]}, {"box": [1096, 856, 1179, 1029], "vertical": true, "font_size": 32.0, "lines": ["はーたの", "楽しかった。"]}, {"box": [195, 800, 356, 1018], "vertical": true, "font_size": 32.0, "lines": ["なんか", "高木さんじゃ", "ないみたいで", "心臓に悪いな．．．"]}, {"box": [1068, 1436, 1184, 1650], "vertical": true, "font_size": 32.0, "lines": ["しかしどうだ", "オレのポーカー", "フェース。"]}, {"box": [170, 1466, 211, 1565], "vertical": true, "font_size": 32.0, "lines": ["んー．．．"]}], "img_path": "015.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1063, 118, 1184, 348], "vertical": true, "font_size": 32.0, "lines": ["キュン子っぽい", "のが一番で、", "ボブがそこそこ。"]}, {"box": [485, 103, 697, 440], "vertical": true, "font_size": 32.0, "lines": ["今のやつと", "ゆるふわロングも", "結構好きで、そのあとが", "ツインテールとか", "その他って感じかー。"]}, {"box": [183, 164, 234, 461], "vertical": true, "font_size": 32.0, "lines": ["全部当たってる！"]}, {"box": [959, 791, 1185, 1042], "vertical": true, "font_size": 32.0, "lines": ["じゃあどうしっ", "美容室に", "行った時", "してもらうのは", "キュン子っぽいので", "決まりかなー。"]}, {"box": [191, 845, 307, 1093], "vertical": true, "font_size": 27.0, "lines": ["製型変えるのなんて", "初めてだから", "なんか楽しみだよ。"]}, {"box": [1042, 1353, 1203, 1567], "vertical": true, "font_size": 32.0, "lines": ["しかし", "髪の毛だけで", "こんなに変わる", "ものだとは。"]}, {"box": [740, 1426, 842, 1561], "vertical": true, "font_size": 32.0, "lines": ["髪型の", "くせに．．．"]}], "img_path": "016.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [453, 95, 543, 230], "vertical": true, "font_size": 32.0, "lines": ["高木さん", "来週から、"]}, {"box": [65, 105, 153, 264], "vertical": true, "font_size": 32.0, "lines": ["違う髪型に", "なるのか"]}, {"box": [543, 879, 660, 1016], "vertical": true, "font_size": 32.0, "lines": ["これから", "ずっと", "なのかな。"]}, {"box": [997, 1417, 1112, 1569], "vertical": true, "font_size": 32.0, "lines": ["いつもの", "あの髪型は", "もう．．．"]}], "img_path": "017.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [934, 118, 1050, 363], "vertical": true, "font_size": 32.0, "lines": ["いつものが", "一番似合ってると", "思うけどなあ。"]}, {"box": [172, 1149, 228, 1228], "vertical": true, "font_size": 32.0, "lines": ["あ。"]}, {"box": [144, 1321, 231, 1449], "vertical": true, "font_size": 32.0, "lines": ["オレは今", "何を．．．"]}, {"box": [660, 1531, 704, 1775], "vertical": true, "font_size": 32.0, "lines": ["えっと、今のは．．．"]}, {"box": [166, 1575, 200, 1684], "vertical": true, "font_size": 32.0, "lines": ["そっか。"]}], "img_path": "018.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1033, 86, 1108, 343], "vertical": true, "font_size": 32.0, "lines": ["いつものは", "聞いてなかったね。"]}], "img_path": "019.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [692, 270, 744, 504], "vertical": true, "font_size": 32.0, "lines": ["一番テレてる。"]}, {"box": [151, 862, 272, 1016], "vertical": true, "font_size": 32.0, "lines": ["しばらくは", "このままで", "いよー。"]}, {"box": [1033, 845, 1198, 1121], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "変えるわけには", "いかなくなっちゃっ", "たなー。"]}, {"box": [1112, 1273, 1151, 1342], "vertical": true, "font_size": 32.0, "lines": ["そ．．．"]}, {"box": [236, 1344, 270, 1441], "vertical": true, "font_size": 32.0, "lines": ["そう．．．"]}, {"box": [982, 1591, 1121, 1845], "vertical": true, "font_size": 32.0, "lines": ["西片、", "この髪型が大好き", "みたいだし。"]}, {"box": [341, 1606, 414, 1822], "vertical": true, "font_size": 29.0, "lines": ["そ、そこまで", "じゃないから！！"]}], "img_path": "020.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [401, 166, 934, 300], "vertical": false, "font_size": 32.0, "lines": ["ケンケン"]}], "img_path": "021.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1185, 120, 1219, 347], "vertical": true, "font_size": 32.0, "lines": ["めずらしいねー、"]}, {"box": [251, 146, 338, 377], "vertical": true, "font_size": 32.0, "lines": ["学校終わったら", "海行こうなんて。"]}, {"box": [1248, 1001, 1290, 1100], "vertical": true, "font_size": 32.0, "lines": ["ふ．．．．．"]}, {"box": [909, 995, 986, 1156], "vertical": true, "font_size": 32.0, "lines": ["今日ここに", "来たのには、"]}, {"box": [843, 1020, 877, 1245], "vertical": true, "font_size": 32.0, "lines": ["理由があってね。"]}, {"box": [723, 1006, 778, 1093], "vertical": true, "font_size": 32.0, "lines": ["うん、"]}, {"box": [168, 1001, 202, 1198], "vertical": true, "font_size": 32.0, "lines": ["わかってるよ。"]}, {"box": [690, 1477, 767, 1618], "vertical": true, "font_size": 32.0, "lines": ["さすが", "高木さん。"]}, {"box": [198, 1473, 243, 1612], "vertical": true, "font_size": 32.0, "lines": ["話が早い。"]}], "img_path": "022.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [613, 101, 710, 307], "vertical": true, "font_size": 32.0, "lines": ["告白", "するんだよね。"]}, {"box": [200, 181, 260, 268], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}, {"box": [1130, 826, 1191, 958], "vertical": true, "font_size": 32.0, "lines": ["誰が！？"]}, {"box": [678, 800, 778, 909], "vertical": true, "font_size": 32.0, "lines": ["西片が", "私に。"]}, {"box": [543, 793, 616, 976], "vertical": true, "font_size": 32.0, "lines": ["す．．．するわけ", "ないでしょ！！"]}, {"box": [448, 810, 489, 924], "vertical": true, "font_size": 32.0, "lines": ["違うよ。"]}, {"box": [168, 796, 247, 949], "vertical": true, "font_size": 32.0, "lines": ["あはは", "顔真っ赤。"]}, {"box": [496, 1357, 594, 1511], "vertical": true, "font_size": 32.0, "lines": ["勝負だよ", "勝負！！"]}, {"box": [980, 1378, 1061, 1535], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "何するの？"]}, {"box": [290, 1363, 360, 1576], "vertical": true, "font_size": 32.0, "lines": ["わかってて", "言ってるだろ！！"]}, {"box": [174, 1601, 210, 1710], "vertical": true, "font_size": 32.0, "lines": ["あはは。"]}], "img_path": "023.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1194, 114, 1233, 313], "vertical": true, "font_size": 32.0, "lines": ["ルールは簡単。"]}, {"box": [984, 120, 1102, 337], "vertical": true, "font_size": 32.0, "lines": ["砂浜に描いた", "円をケンケンで", "進んでいって、"]}, {"box": [395, 123, 606, 339], "vertical": true, "font_size": 32.0, "lines": ["先にバランスを", "くずして", "円から出たり", "両足がついた", "方の負け。"]}, {"box": [797, 939, 832, 1001], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [646, 928, 722, 1066], "vertical": true, "font_size": 32.0, "lines": ["んーん、", "なんでも。"]}, {"box": [195, 945, 351, 1134], "vertical": true, "font_size": 32.0, "lines": ["ところで", "今日はどんな", "手を考えて", "きてるの？"]}, {"box": [1172, 1503, 1205, 1627], "vertical": true, "font_size": 32.0, "lines": ["ふふふ．．．"]}, {"box": [665, 1481, 746, 1651], "vertical": true, "font_size": 32.0, "lines": ["それは", "お楽しみさ。"]}, {"box": [504, 1485, 586, 1597], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "行くよ。"]}, {"box": [163, 1556, 196, 1680], "vertical": true, "font_size": 32.0, "lines": ["せーの！"]}], "img_path": "024.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [435, 618, 472, 714], "vertical": true, "font_size": 32.0, "lines": ["な．．．！？"]}, {"box": [84, 553, 131, 598], "vertical": false, "font_size": 32.0, "lines": ["！？"]}, {"box": [51, 748, 182, 1061], "vertical": true, "font_size": 31.0, "lines": ["思ったより", "沈む．．．！？", "バランスが．．．"]}], "img_path": "025.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1215, 86, 1254, 240], "vertical": true, "font_size": 32.0, "lines": ["ぶはぁ！！"]}, {"box": [780, 146, 823, 230], "vertical": true, "font_size": 32.0, "lines": ["おー。"]}, {"box": [555, 60, 688, 260], "vertical": true, "font_size": 32.0, "lines": ["一回で勝負", "ついちゃうとこ", "だったね。"]}, {"box": [1153, 813, 1188, 975], "vertical": true, "font_size": 32.0, "lines": ["よかったよ、"]}, {"box": [155, 412, 206, 598], "vertical": true, "font_size": 32.0, "lines": ["危なーー！！"]}, {"box": [570, 896, 691, 1097], "vertical": true, "font_size": 32.0, "lines": ["せっかくの", "勝負がすぐ", "終わらなくて。"]}, {"box": [453, 1068, 521, 1226], "vertical": true, "font_size": 32.0, "lines": ["むむ．．．"]}, {"box": [971, 1381, 1050, 1519], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "次いくよ。"]}, {"box": [586, 1396, 620, 1520], "vertical": true, "font_size": 32.0, "lines": ["せーの！"]}], "img_path": "026.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [170, 133, 298, 279], "vertical": true, "font_size": 32.0, "lines": ["えーと、いま", "今８回目", "だっけ。"]}, {"box": [1119, 793, 1205, 990], "vertical": true, "font_size": 30.0, "lines": ["お互い慣れて", "きちゃったね。"]}, {"box": [714, 795, 802, 967], "vertical": true, "font_size": 32.0, "lines": ["勝負、", "つくのかな。"]}, {"box": [578, 780, 659, 990], "vertical": true, "font_size": 30.0, "lines": ["つくに決まって", "いるだろう。"]}, {"box": [151, 787, 270, 1014], "vertical": true, "font_size": 32.0, "lines": ["すっかり", "油断しているな", "高木さん。"]}, {"box": [918, 1346, 1018, 1479], "vertical": true, "font_size": 32.0, "lines": ["今回の", "秘策．．．！！"]}, {"box": [1052, 1381, 1181, 1513], "vertical": true, "font_size": 32.0, "lines": ["よし．．", "そろそろ", "出すか．．．"]}, {"box": [271, 1387, 323, 1530], "vertical": true, "font_size": 32.0, "lines": ["高木さん。"]}], "img_path": "027.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1149, 112, 1278, 360], "vertical": true, "font_size": 32.0, "lines": ["この砂浜で", "１０回連続で", "ケンケンすると．．．"]}, {"box": [489, 148, 617, 406], "vertical": true, "font_size": 32.0, "lines": ["次の小遣いが", "半分になるって", "ウワサがあるんだ。"]}, {"box": [1083, 1001, 1205, 1138], "vertical": true, "font_size": 32.0, "lines": ["高尾から", "聞いたん", "だけどね。"]}, {"box": [909, 963, 1031, 1192], "vertical": true, "font_size": 32.0, "lines": ["かなり", "信用できる", "ウワサらしいよ。"]}, {"box": [165, 978, 324, 1226], "vertical": true, "font_size": 32.0, "lines": ["どうだ", "高木さん．．．！！", "オレが今日聞いた", "このウワサ．．．！！"]}, {"box": [1168, 1505, 1194, 1726], "vertical": true, "font_size": 32.0, "lines": ["オレはいいのさ。"]}, {"box": [875, 1470, 1083, 1779], "vertical": true, "font_size": 32.0, "lines": ["たとえ小遣いが", "半分になったとしても", "それで高木さんに", "勝てるなら", "安いもの：・"]}, {"box": [180, 1503, 293, 1723], "vertical": true, "font_size": 32.0, "lines": ["覚悟は", "できてる！！"]}], "img_path": "028.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1123, 180, 1194, 423], "vertical": true, "font_size": 32.0, "lines": ["しかし高木さんは", "どうだ！？"]}, {"box": [902, 165, 1083, 416], "vertical": true, "font_size": 32.0, "lines": ["小遣い半分が", "こわくてケンケン", "できないんじゃ", "ないのかな！？"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [273, 187, 482, 461], "vertical": true, "font_size": 32.0, "lines": ["できたとしても", "心が乱れた", "その状態でちゃんと", "成功させられるの", "かな！？"]}, {"box": [1061, 768, 1113, 849], "vertical": true, "font_size": 32.0, "lines": ["え！？"]}, {"box": [918, 742, 1001, 900], "vertical": true, "font_size": 32.0, "lines": ["あ！！", "ちょっと！？"]}, {"box": [172, 433, 253, 603], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "次やるよー。"]}, {"box": [328, 785, 367, 898], "vertical": true, "font_size": 32.0, "lines": ["せーの。"]}], "img_path": "029.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1160, 183, 1201, 381], "vertical": true, "font_size": 32.0, "lines": ["危なかったね。"]}, {"box": [613, 251, 669, 360], "vertical": true, "font_size": 32.0, "lines": ["全く．．．"]}, {"box": [151, 168, 239, 358], "vertical": true, "font_size": 32.0, "lines": ["動揺して", "いないだと！？"]}, {"box": [1117, 781, 1190, 977], "vertical": true, "font_size": 29.0, "lines": ["なぜだ！？", "ありえないぞ。"]}, {"box": [203, 785, 361, 999], "vertical": true, "font_size": 28.0, "lines": ["ウワサが", "本当だったら", "どうしようとか", "思わないのか！？"]}, {"box": [1134, 1290, 1215, 1402], "vertical": true, "font_size": 32.0, "lines": ["あ、", "そうだ。"]}, {"box": [496, 1312, 628, 1518], "vertical": true, "font_size": 32.0, "lines": ["私も", "こんなウワサ", "聞いたような。"]}, {"box": [150, 1299, 228, 1404], "vertical": true, "font_size": 32.0, "lines": ["えーと", "たしか、"]}], "img_path": "030.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [935, 163, 1106, 352], "vertical": true, "font_size": 32.0, "lines": ["この砂浜で", "２人で並んで", "１０回ケンケン", "したら、"]}, {"box": [103, 106, 266, 414], "vertical": true, "font_size": 32.0, "lines": ["そのあとッ", "２人で抱き合わないと", "不幸になる、", "だっけ。"]}, {"box": [1128, 1269, 1187, 1366], "vertical": true, "font_size": 32.0, "lines": ["は！？"]}, {"box": [515, 1231, 599, 1447], "vertical": true, "font_size": 32.0, "lines": ["２人とも", "１０回成功したら、"]}, {"box": [157, 1243, 191, 1438], "vertical": true, "font_size": 32.0, "lines": ["やらなきゃね。"]}], "img_path": "031.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [669, 110, 715, 238], "vertical": true, "font_size": 32.0, "lines": ["２人で．．．"]}, {"box": [168, 129, 254, 316], "vertical": true, "font_size": 32.0, "lines": ["じゃあ１０回目", "行くよー。"]}, {"box": [1128, 759, 1168, 925], "vertical": true, "font_size": 32.0, "lines": ["せーのー。"]}, {"box": [341, 972, 401, 1106], "vertical": true, "font_size": 32.0, "lines": ["抱き．．．"]}], "img_path": "032.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [583, 900, 630, 960], "vertical": true, "font_size": 32.0, "lines": ["あ。"]}, {"box": [1087, 926, 1181, 1054], "vertical": true, "font_size": 32.0, "lines": ["できる", "かぁあ。"]}, {"box": [692, 915, 770, 1117], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "私の勝ちだね。"]}, {"box": [153, 894, 309, 1161], "vertical": true, "font_size": 31.0, "lines": ["ちなみに", "さっきのウワサ", "聞いたのは、", "気のせいだったかも。"]}], "img_path": "033.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1040, 241, 1079, 479], "vertical": true, "font_size": 32.0, "lines": ["くそぉおおお。"]}, {"box": [418, 219, 495, 389], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "帰ろっかー。"]}, {"box": [959, 979, 996, 1162], "vertical": true, "font_size": 26.0, "lines": ["また負けた．．．"]}, {"box": [502, 933, 581, 1119], "vertical": true, "font_size": 32.0, "lines": ["．．．でも", "大丈夫なの？"]}, {"box": [202, 1003, 238, 1072], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}], "img_path": "034.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [958, 202, 1129, 421], "vertical": true, "font_size": 32.0, "lines": ["高木さん", "１０回跳んだから", "来月の小遣い", "半分だよ．．．？"]}, {"box": [129, 82, 596, 120], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [1112, 652, 1143, 761], "vertical": true, "font_size": 31.0, "lines": ["あはは。"]}, {"box": [523, 729, 573, 817], "vertical": true, "font_size": 32.0, "lines": ["え！？"]}, {"box": [311, 592, 406, 768], "vertical": true, "font_size": 32.0, "lines": ["全然", "大丈夫だよ。"]}, {"box": [1087, 1290, 1207, 1509], "vertical": true, "font_size": 30.0, "lines": ["えー．．．", "そんなにウワサ", "信じてないの！？"]}, {"box": [954, 1303, 1025, 1486], "vertical": true, "font_size": 30.0, "lines": ["もしかしたら", "本当かもよ。"]}, {"box": [526, 1370, 656, 1498], "vertical": true, "font_size": 32.0, "lines": ["んーん、ぜったい", "絶対ウソ", "だよ。"]}, {"box": [262, 1359, 303, 1460], "vertical": true, "font_size": 32.0, "lines": ["でも．．．"]}], "img_path": "035.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1153, 135, 1187, 240], "vertical": true, "font_size": 32.0, "lines": ["だって、"]}, {"box": [977, 198, 1035, 217], "vertical": false, "font_size": 19.0, "lines": ["．．．"]}, {"box": [609, 131, 728, 286], "vertical": true, "font_size": 32.0, "lines": ["あのウワサ", "流したの", "私だもん"]}, {"box": [1040, 888, 1195, 1141], "vertical": true, "font_size": 31.0, "lines": ["西片の耳に入ったら", "それ使って", "勝負挑んで", "くるかなーって。"]}, {"box": [601, 946, 656, 1081], "vertical": true, "font_size": 32.0, "lines": ["な．．．！？"]}, {"box": [153, 918, 196, 1091], "vertical": true, "font_size": 32.0, "lines": ["えぇえ！！"]}, {"box": [1037, 1475, 1072, 1668], "vertical": true, "font_size": 32.0, "lines": ["面白かったし、"]}, {"box": [855, 1477, 937, 1676], "vertical": true, "font_size": 32.0, "lines": ["また流して", "みよっかなー。"]}, {"box": [322, 1505, 441, 1661], "vertical": true, "font_size": 32.0, "lines": ["やめて！！", "信じちゃう", "から！"]}], "img_path": "036.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [178, 1270, 403, 1681], "vertical": false, "font_size": 32.0, "lines": ["験"]}], "img_path": "037.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [804, 106, 903, 225], "vertical": true, "font_size": 32.0, "lines": ["真野", "さーん。"]}, {"box": [1158, 954, 1203, 1091], "vertical": true, "font_size": 32.0, "lines": ["木下さん。"]}, {"box": [586, 958, 656, 1155], "vertical": true, "font_size": 31.0, "lines": ["真野さんて", "彼氏いたわよね。"]}, {"box": [472, 1048, 543, 1164], "vertical": true, "font_size": 31.0, "lines": ["中井君：・", "だっけ。"]}, {"box": [352, 958, 423, 1076], "vertical": true, "font_size": 32.0, "lines": ["そ、そう", "だけど。"]}, {"box": [1098, 1443, 1142, 1593], "vertical": true, "font_size": 32.0, "lines": ["キスって、"]}, {"box": [241, 1475, 324, 1610], "vertical": true, "font_size": 32.0, "lines": ["したこと", "ある？"]}], "img_path": "038.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [813, 118, 898, 367], "vertical": true, "font_size": 32.0, "lines": ["まー、付き合って", "けっこう経つし、"]}, {"box": [155, 153, 230, 367], "vertical": true, "font_size": 32.0, "lines": ["そりゃあキスの", "一回や二回は。"]}, {"box": [1113, 978, 1196, 1140], "vertical": true, "font_size": 32.0, "lines": ["おー、", "やっぱり！！"]}, {"box": [634, 950, 719, 1135], "vertical": true, "font_size": 28.0, "lines": ["じゃあ放課後", "取材させて！！"]}, {"box": [178, 945, 374, 1211], "vertical": true, "font_size": 32.0, "lines": ["学校の新聞で", "「キスの感想と好きな", "シチュエーション」", "って記事書こうと", "思ってんのよ。"]}, {"box": [240, 1303, 281, 1378], "vertical": true, "font_size": 32.0, "lines": ["な！"]}, {"box": [1087, 1477, 1207, 1698], "vertical": true, "font_size": 32.0, "lines": ["いやー、", "経験値高そうで", "助かるわー！！"]}, {"box": [733, 1471, 813, 1612], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "よろしく。"]}, {"box": [566, 1505, 603, 1663], "vertical": true, "font_size": 32.0, "lines": ["え、あの．．．"]}, {"box": [163, 1507, 246, 1657], "vertical": true, "font_size": 30.0, "lines": ["いい記事に", "なりそー。"]}], "img_path": "039.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1115, 765, 1147, 871], "vertical": true, "font_size": 32.0, "lines": ["あはは。"]}, {"box": [616, 693, 703, 836], "vertical": true, "font_size": 32.0, "lines": ["西片顔", "真っ赤ー。"]}, {"box": [444, 690, 570, 851], "vertical": true, "font_size": 32.0, "lines": ["すぐ", "テレるから", "面白いや。"]}, {"box": [1042, 1348, 1123, 1531], "vertical": true, "font_size": 32.0, "lines": ["高木さんを", "テレさせて．．"]}, {"box": [699, 1344, 742, 1511], "vertical": true, "font_size": 32.0, "lines": ["真野ちゃん。"]}, {"box": [1198, 1370, 1280, 1528], "vertical": true, "font_size": 32.0, "lines": ["く．．．いつか", "見てろ．．．！！"]}, {"box": [859, 1412, 929, 1549], "vertical": true, "font_size": 32.0, "lines": ["ガラッ"]}], "img_path": "040.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1119, 88, 1164, 285], "vertical": true, "font_size": 32.0, "lines": ["高木ちゃんて、"]}, {"box": [556, 129, 638, 328], "vertical": true, "font_size": 32.0, "lines": ["キスしたこと", "ある？"]}, {"box": [316, 91, 365, 165], "vertical": true, "font_size": 32.0, "lines": ["へ！？"]}, {"box": [397, 588, 431, 684], "vertical": true, "font_size": 32.0, "lines": ["んー．．．"]}, {"box": [613, 1023, 743, 1211], "vertical": true, "font_size": 32.0, "lines": ["私たち", "キスしたこと", "あるっけ。"]}, {"box": [188, 1095, 286, 1285], "vertical": true, "font_size": 32.0, "lines": ["いや", "ないって！！"]}, {"box": [1065, 1561, 1143, 1672], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "ないよ。"]}, {"box": [181, 1558, 288, 1779], "vertical": true, "font_size": 32.0, "lines": ["そっかぁあ", "ああ～～"]}], "img_path": "041.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1130, 135, 1177, 219], "vertical": true, "font_size": 32.0, "lines": ["へー。"]}, {"box": [795, 108, 889, 326], "vertical": true, "font_size": 24.0, "lines": ["それでキス", "したことないのに", "嘘言っちゃったんだ。"]}, {"box": [245, 151, 292, 255], "vertical": true, "font_size": 32.0, "lines": ["つい．．．"]}, {"box": [1027, 796, 1187, 981], "vertical": true, "font_size": 31.0, "lines": ["だから．．．", "高木ちゃんが", "したこと", "あるなら、"]}, {"box": [758, 783, 879, 1031], "vertical": true, "font_size": 32.0, "lines": ["それ", "パクろうかなって", "思ってたのに。"]}, {"box": [360, 798, 487, 956], "vertical": true, "font_size": 32.0, "lines": ["なんで", "してないの", "西片君！"]}, {"box": [165, 826, 204, 941], "vertical": true, "font_size": 32.0, "lines": ["オレ！？"]}, {"box": [1025, 1449, 1143, 1698], "vertical": true, "font_size": 32.0, "lines": ["ホ、ホントは", "したことないって", "正直に言えば．．．？"]}, {"box": [223, 1496, 339, 1650], "vertical": true, "font_size": 32.0, "lines": ["そんなの", "恥ずかしい", "でしょ！"]}], "img_path": "042.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1074, 148, 1192, 393], "vertical": true, "font_size": 32.0, "lines": ["キスしたことある", "って人に言う方が", "恥ずかしくない！？"]}, {"box": [639, 240, 716, 408], "vertical": true, "font_size": 32.0, "lines": ["あぁー", "どうしよー。"]}, {"box": [290, 88, 590, 114], "vertical": false, "font_size": 26.0, "lines": ["上手の高ホさんの"]}, {"box": [129, 82, 270, 120], "vertical": false, "font_size": 32.0, "lines": ["からかい"]}, {"box": [110, 315, 188, 500], "vertical": true, "font_size": 32.0, "lines": ["どうにか", "しなきゃー！！"]}, {"box": [386, 870, 413, 971], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．？"]}, {"box": [628, 1363, 673, 1516], "vertical": true, "font_size": 32.0, "lines": ["ねぇ西片。"]}], "img_path": "043.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [722, 131, 778, 232], "vertical": true, "font_size": 32.0, "lines": ["キス、"]}, {"box": [583, 123, 622, 361], "vertical": true, "font_size": 32.0, "lines": ["してみよっか。"]}, {"box": [1207, 999, 1292, 1229], "vertical": true, "font_size": 32.0, "lines": ["えええ！？", "何言ってんの！？"]}, {"box": [674, 1001, 800, 1200], "vertical": true, "font_size": 32.0, "lines": ["真野ちゃんの", "手助けに", "なるかなって。"]}, {"box": [337, 986, 380, 1170], "vertical": true, "font_size": 32.0, "lines": ["手助けって！！"]}], "img_path": "044.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1040, 238, 1151, 410], "vertical": true, "font_size": 32.0, "lines": ["いやいや．．．", "そ、そういう", "のは．．．"]}, {"box": [603, 198, 672, 407], "vertical": true, "font_size": 29.0, "lines": ["もっとちゃんと", "すべきというか。"]}, {"box": [165, 238, 241, 361], "vertical": true, "font_size": 32.0, "lines": ["ちゃんと", "って？"]}, {"box": [1065, 654, 1185, 877], "vertical": true, "font_size": 32.0, "lines": ["だから本人同士の", "気持ちとか．．", "さぁ。"]}, {"box": [887, 680, 927, 849], "vertical": true, "font_size": 31.0, "lines": ["気持ちかぁ。"]}, {"box": [759, 710, 806, 891], "vertical": true, "font_size": 32.0, "lines": ["西片はイヤ？"]}, {"box": [99, 757, 143, 956], "vertical": true, "font_size": 32.0, "lines": ["私はいいけど。"]}, {"box": [484, 1408, 560, 1606], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "テレすぎだよ。"]}, {"box": [113, 1446, 143, 1551], "vertical": true, "font_size": 30.0, "lines": ["．．．．．．"]}], "img_path": "045.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1125, 101, 1295, 380], "vertical": true, "font_size": 32.0, "lines": ["いくら", "冗談てわかってても", "テレるって、", "普通は！！"]}, {"box": [545, 125, 758, 369], "vertical": true, "font_size": 32.0, "lines": ["高木さん", "そういうの", "余裕すぎて", "わかんないかも", "しれないけどさ！"]}, {"box": [155, 174, 282, 333], "vertical": true, "font_size": 32.0, "lines": ["私だって", "テレる時は", "テレるよ。"]}, {"box": [707, 971, 796, 1160], "vertical": true, "font_size": 32.0, "lines": ["今までだと", "どんな時に！？"]}, {"box": [185, 999, 226, 1083], "vertical": true, "font_size": 32.0, "lines": ["んー。"]}, {"box": [1108, 1496, 1198, 1601], "vertical": true, "font_size": 32.0, "lines": ["それは", "秘密。"]}, {"box": [920, 1494, 965, 1582], "vertical": true, "font_size": 32.0, "lines": ["なっ。"]}, {"box": [570, 1455, 714, 1705], "vertical": true, "font_size": 28.0, "lines": ["く．．．ヒントがあれば", "高木さんを", "テレさせられるかも", "しれないのに．．．"]}, {"box": [155, 1471, 230, 1655], "vertical": true, "font_size": 32.0, "lines": ["やっぱり", "嘘なんじゃ．．．"]}], "img_path": "046.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [923, 94, 1098, 267], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "そうだなー。"]}, {"box": [496, 88, 627, 288], "vertical": true, "font_size": 32.0, "lines": ["次テレた時は", "西片に", "教えてあげる。"]}, {"box": [277, 157, 360, 283], "vertical": true, "font_size": 32.0, "lines": ["ホント", "かなー．．．"]}, {"box": [161, 236, 232, 401], "vertical": true, "font_size": 32.0, "lines": ["期待せずに", "待っとくよ。"]}, {"box": [902, 1500, 978, 1698], "vertical": true, "font_size": 32.0, "lines": ["で、キスは", "するんだっけ。"]}, {"box": [541, 1511, 579, 1696], "vertical": true, "font_size": 32.0, "lines": ["だからぁ！！"]}, {"box": [307, 1608, 339, 1715], "vertical": true, "font_size": 32.0, "lines": ["あはは。"]}], "img_path": "047.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [367, 114, 449, 347], "vertical": true, "font_size": 29.0, "lines": ["あ、真野ちゃん、", "またどうしたの？"]}, {"box": [305, 931, 348, 1008], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}], "img_path": "048.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1005, 232, 1038, 356], "vertical": true, "font_size": 32.0, "lines": ["えっと．．．"]}, {"box": [752, 264, 909, 481], "vertical": true, "font_size": 32.0, "lines": ["あのあと", "キスしたこと", "ある人探し", "まわってたら．．．"]}, {"box": [131, 84, 594, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [285, 305, 410, 495], "vertical": true, "font_size": 32.0, "lines": ["通りかかった", "中井君に", "聞かれて．．．"]}, {"box": [245, 746, 286, 845], "vertical": true, "font_size": 32.0, "lines": ["その．．．"]}, {"box": [1065, 1090, 1108, 1200], "vertical": true, "font_size": 32.0, "lines": ["嘘じゃ、"]}, {"box": [217, 1100, 293, 1224], "vertical": true, "font_size": 32.0, "lines": ["なくなり", "ました。"]}], "img_path": "049.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1138, 183, 1177, 294], "vertical": true, "font_size": 32.0, "lines": ["じゃ！！"]}, {"box": [1015, 744, 1173, 957], "vertical": true, "font_size": 31.0, "lines": ["え．．じゃあ．．．", "ついさっき．．．", "キ．．．キスして", "きたってコト！？"]}, {"box": [253, 823, 306, 975], "vertical": true, "font_size": 32.0, "lines": ["学校で！？"]}, {"box": [1125, 1316, 1196, 1467], "vertical": true, "font_size": 30.0, "lines": ["なんか．．．", "こっちが．．"]}, {"box": [748, 1314, 789, 1481], "vertical": true, "font_size": 32.0, "lines": ["恥ずかしー。"]}], "img_path": "050.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [986, 217, 1074, 303], "vertical": true, "font_size": 32.0, "lines": ["ねえにしかた", "西片。"]}, {"box": [682, 155, 755, 369], "vertical": true, "font_size": 29.0, "lines": ["う．．．また", "からかわれる．．．"]}, {"box": [129, 82, 596, 118], "vertical": false, "font_size": 32.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [155, 219, 208, 331], "vertical": true, "font_size": 32.0, "lines": ["な．．．何。"]}], "img_path": "051.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1151, 166, 1190, 296], "vertical": true, "font_size": 32.0, "lines": ["ほらね。"]}, {"box": [180, 1020, 253, 1246], "vertical": true, "font_size": 29.0, "lines": ["あれはさすがに", "テレちゃうなー。"]}, {"box": [1083, 1483, 1158, 1650], "vertical": true, "font_size": 31.0, "lines": ["どこでキス", "したんだろ。"]}, {"box": [887, 1486, 1003, 1700], "vertical": true, "font_size": 31.0, "lines": ["西片は学校で", "するなら", "どこでしたい？"]}, {"box": [468, 1470, 586, 1655], "vertical": true, "font_size": 30.0, "lines": ["ちょっと！？", "それホントに", "テレてる！？"]}, {"box": [228, 1563, 268, 1674], "vertical": true, "font_size": 32.0, "lines": ["あはは。"]}], "img_path": "052.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [33, 1717, 524, 1891], "vertical": false, "font_size": 32.0, "lines": ["ま", "み", "お見舞し"]}], "img_path": "053.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1020, 885, 1059, 984], "vertical": true, "font_size": 32.0, "lines": ["ふー．．．"]}], "img_path": "054.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1140, 108, 1179, 225], "vertical": true, "font_size": 32.0, "lines": ["はーい。"]}, {"box": [846, 108, 1033, 317], "vertical": true, "font_size": 32.0, "lines": ["あの．．．おな", "同じクラスの", "西片といいます。", "プリントを", "届けに来ました。"]}, {"box": [631, 138, 742, 588], "vertical": true, "font_size": 32.0, "lines": ["あぁー", "どうぞ", "ありがとうね、", "あがってー。", "話は聞いてるわー。"]}, {"box": [491, 170, 565, 270], "vertical": true, "font_size": 32.0, "lines": ["あの．．．"]}, {"box": [663, 701, 694, 849], "vertical": true, "font_size": 27.0, "lines": ["あがるの！？"]}, {"box": [1131, 971, 1176, 1095], "vertical": true, "font_size": 32.0, "lines": ["や、西片。"]}, {"box": [560, 1006, 633, 1172], "vertical": true, "font_size": 28.0, "lines": ["わざわざ", "ありがとね。"]}], "img_path": "055.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [851, 131, 892, 206], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [727, 137, 755, 320], "vertical": true, "font_size": 26.0, "lines": ["あ．．．えっと！"]}, {"box": [185, 138, 285, 275], "vertical": true, "font_size": 32.0, "lines": ["熱はいじょう", "大丈夫！？"]}, {"box": [682, 586, 780, 742], "vertical": true, "font_size": 32.0, "lines": ["うん、だいぶ", "楽には", "なったよ。"]}, {"box": [234, 590, 506, 763], "vertical": true, "font_size": 32.0, "lines": ["熱も", "下がっては", "きたし．．．", "明日には", "学校行けそう", "だよ。"]}, {"box": [294, 890, 361, 976], "vertical": true, "font_size": 32.0, "lines": ["そ．．．", "そっか。"]}, {"box": [1053, 1115, 1202, 1284], "vertical": true, "font_size": 32.0, "lines": ["プ．．．プリント", "どこに", "置いとけば", "いいかな。"]}, {"box": [815, 1149, 928, 1333], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "机の上に", "置いといてー。"]}, {"box": [339, 1138, 459, 1267], "vertical": true, "font_size": 32.0, "lines": ["じゃあ．．．", "オレは", "これで。"]}, {"box": [200, 1190, 256, 1278], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}], "img_path": "056.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1068, 136, 1183, 268], "vertical": true, "font_size": 32.0, "lines": ["せっかく", "来てくれ", "たんだし、"]}, {"box": [650, 131, 739, 285], "vertical": true, "font_size": 32.0, "lines": ["少し座って", "いってよ。"]}, {"box": [459, 135, 514, 273], "vertical": true, "font_size": 32.0, "lines": ["お願い。"]}, {"box": [680, 701, 857, 841], "vertical": true, "font_size": 32.0, "lines": ["え、", "いや．．．でも。"]}, {"box": [618, 1224, 746, 1425], "vertical": true, "font_size": 32.0, "lines": ["今日", "抜き打ちテスト", "あったんでしょ。"]}, {"box": [483, 1248, 549, 1432], "vertical": true, "font_size": 32.0, "lines": ["すみれちゃんに", "聞いたよ。"]}, {"box": [146, 1239, 230, 1351], "vertical": true, "font_size": 32.0, "lines": ["え、あ、", "ああ。"]}], "img_path": "057.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1208, 113, 1294, 301], "vertical": true, "font_size": 32.0, "lines": ["女子の部屋．．．", "初めてで．．"]}, {"box": [631, 121, 709, 276], "vertical": true, "font_size": 30.0, "lines": ["めっちゃ", "緊張する．．．"]}, {"box": [412, 82, 571, 258], "vertical": true, "font_size": 32.0, "lines": ["高木さんもねっ", "熱のせいか", "いつもと違う", "気がして．．．"]}, {"box": [144, 99, 268, 273], "vertical": true, "font_size": 28.0, "lines": ["なんか変に", "ドキドキ", "するな．．．"]}, {"box": [317, 329, 341, 401], "vertical": true, "font_size": 24.0, "lines": ["．．．．．"]}, {"box": [1115, 798, 1211, 1055], "vertical": true, "font_size": 32.0, "lines": ["西片、そこの", "水とってくれる？"]}, {"box": [723, 420, 804, 551], "vertical": true, "font_size": 32.0, "lines": ["うん．．．", "あった．．．"]}, {"box": [286, 806, 318, 931], "vertical": true, "font_size": 32.0, "lines": ["ありがと"]}, {"box": [155, 798, 234, 990], "vertical": true, "font_size": 32.0, "lines": ["ついでに", "そこ座ってよ。"]}, {"box": [898, 1035, 930, 1174], "vertical": true, "font_size": 32.0, "lines": ["あ．．．うん。"]}, {"box": [1173, 1395, 1290, 1608], "vertical": true, "font_size": 32.0, "lines": ["さっきみたいに", "遠いときみしい", "からさ。"]}, {"box": [692, 1406, 733, 1481], "vertical": true, "font_size": 32.0, "lines": ["な．．．"]}, {"box": [478, 1393, 517, 1490], "vertical": true, "font_size": 32.0, "lines": ["はい．．"]}, {"box": [385, 1412, 418, 1540], "vertical": true, "font_size": 32.0, "lines": ["９どん．．．"]}, {"box": [142, 1383, 262, 1599], "vertical": true, "font_size": 32.0, "lines": ["なんだそれ．．．", "なんか．．．", "素直というか．．"]}], "img_path": "058.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1037, 164, 1166, 393], "vertical": true, "font_size": 32.0, "lines": ["なんか今日", "言うことよく", "聞いてくれるね。"]}, {"box": [93, 264, 211, 420], "vertical": true, "font_size": 32.0, "lines": ["プリントも", "持ってきて", "くれたし。"]}, {"box": [1162, 639, 1202, 736], "vertical": true, "font_size": 32.0, "lines": ["まぁ．．．"]}, {"box": [731, 641, 815, 797], "vertical": true, "font_size": 32.0, "lines": ["高木さん", "熱あるし．．．"]}, {"box": [585, 637, 624, 750], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [1113, 1179, 1155, 1373], "vertical": true, "font_size": 32.0, "lines": ["じゃあ今日は"]}, {"box": [556, 1211, 672, 1470], "vertical": true, "font_size": 31.0, "lines": ["なんでも", "言うこと", "聞いてくれるんだ。"]}, {"box": [442, 1182, 469, 1280], "vertical": true, "font_size": 24.0, "lines": ["！！"]}, {"box": [78, 1239, 153, 1402], "vertical": true, "font_size": 32.0, "lines": ["なるほど．．．", "わかったぞ。"]}], "img_path": "059.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [930, 151, 1183, 371], "vertical": true, "font_size": 32.0, "lines": ["熱が出て", "弱っている", "ふりをして．．．", "オレが言うこと", "聞くのを", "いいことに．．．"]}, {"box": [688, 150, 853, 365], "vertical": true, "font_size": 32.0, "lines": ["さらには", "女子の部屋", "というこの場を", "使い．．．"]}, {"box": [555, 151, 626, 391], "vertical": true, "font_size": 32.0, "lines": ["オレをテレさせて", "からかうつもりか。"]}, {"box": [309, 181, 481, 311], "vertical": true, "font_size": 32.0, "lines": ["今日一日", "からかえ", "なかった", "分を．．．"]}, {"box": [178, 195, 247, 328], "vertical": true, "font_size": 32.0, "lines": ["まとめて", "今ここで。"]}, {"box": [1155, 843, 1202, 950], "vertical": true, "font_size": 32.0, "lines": ["西片ー、"]}, {"box": [656, 926, 742, 1078], "vertical": true, "font_size": 32.0, "lines": ["水飲ませて", "ほしいな。"]}, {"box": [1082, 1398, 1198, 1588], "vertical": true, "font_size": 32.0, "lines": ["よし．．．！！", "受けてたつよ", "高木さん．．．！！"]}, {"box": [451, 1445, 534, 1586], "vertical": true, "font_size": 32.0, "lines": ["わ．．．", "わかった。"]}, {"box": [198, 1398, 335, 1607], "vertical": true, "font_size": 32.0, "lines": ["全て", "耐えきったら", "オレの勝ちだ。"]}], "img_path": "060.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [526, 461, 559, 598], "vertical": true, "font_size": 32.0, "lines": ["ありがと。"]}, {"box": [616, 888, 663, 965], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [1160, 931, 1194, 1027], "vertical": true, "font_size": 32.0, "lines": ["はぁ〜"]}, {"box": [429, 1318, 493, 1391], "vertical": true, "font_size": 32.0, "lines": ["手。"]}], "img_path": "061.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [614, 63, 876, 159], "vertical": false, "font_size": 32.0, "lines": ["ぎぎ！？"]}, {"box": [618, 1297, 671, 1350], "vertical": false, "font_size": 32.0, "lines": ["！？"]}, {"box": [431, 1237, 512, 1417], "vertical": true, "font_size": 29.0, "lines": ["はー、冷たくて", "気持ちいい。"]}], "img_path": "062.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [881, 198, 1038, 341], "vertical": true, "font_size": 32.0, "lines": ["これは", "高木さんの", "オデコじゃ", "ない！！"]}, {"box": [688, 213, 825, 346], "vertical": true, "font_size": 32.0, "lines": ["そう！！", "リンゴか", "何か！！"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [324, 206, 356, 358], "vertical": true, "font_size": 32.0, "lines": ["大丈夫だ！！"]}, {"box": [178, 275, 217, 442], "vertical": true, "font_size": 32.0, "lines": ["耐えろオレ。"]}, {"box": [579, 697, 695, 892], "vertical": true, "font_size": 30.0, "lines": ["今日ホントに", "言うこと聞いて", "くれるね。"]}, {"box": [1012, 1222, 1136, 1390], "vertical": true, "font_size": 32.0, "lines": ["なんかねこ", "寝込むのも", "悪くないや。"]}, {"box": [902, 1207, 944, 1333], "vertical": true, "font_size": 32.0, "lines": ["あはは"]}, {"box": [649, 1199, 678, 1263], "vertical": true, "font_size": 29.0, "lines": ["ぐ．．．"]}, {"box": [493, 1175, 570, 1357], "vertical": true, "font_size": 32.0, "lines": ["ふ．．．しかし", "耐えきったぞ。"]}, {"box": [294, 1172, 331, 1417], "vertical": true, "font_size": 26.0, "lines": ["これはオレの勝．．．"]}, {"box": [193, 1209, 245, 1411], "vertical": true, "font_size": 32.0, "lines": ["じゃあ、西片。"]}], "img_path": "063.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [633, 196, 694, 393], "vertical": true, "font_size": 32.0, "lines": ["頭なでて。"]}], "img_path": "064.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1137, 117, 1164, 220], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．．"]}, {"box": [615, 82, 697, 422], "vertical": true, "font_size": 32.0, "lines": ["そ．．．", "それは．．．", "さすがに．．．"]}, {"box": [435, 191, 517, 435], "vertical": true, "font_size": 32.0, "lines": ["恥ずかしすぎて．．．", "ムリ．．．"]}, {"box": [95, 96, 129, 191], "vertical": true, "font_size": 32.0, "lines": ["．．．ま．．．"]}, {"box": [1138, 633, 1183, 871], "vertical": true, "font_size": 32.0, "lines": ["負けたぁぁあ。"]}, {"box": [335, 656, 370, 781], "vertical": true, "font_size": 32.0, "lines": ["そっか．．．"]}, {"box": [840, 1215, 900, 1303], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [519, 1181, 596, 1305], "vertical": true, "font_size": 32.0, "lines": ["．．．くっ．．．", "来るぞ．．．"]}, {"box": [165, 1175, 239, 1387], "vertical": true, "font_size": 29.0, "lines": ["いつもみたいに", "からかいが．．．"]}, {"box": [206, 1590, 253, 1698], "vertical": true, "font_size": 32.0, "lines": ["な．．．何。"]}], "img_path": "065.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1173, 80, 1260, 236], "vertical": true, "font_size": 32.0, "lines": ["今日", "来てくれて、"]}, {"box": [723, 78, 753, 285], "vertical": true, "font_size": 27.0, "lines": ["うれしかったよ。"]}, {"box": [1023, 832, 1061, 901], "vertical": true, "font_size": 32.0, "lines": ["え？"]}, {"box": [313, 798, 356, 858], "vertical": true, "font_size": 32.0, "lines": ["す"]}, {"box": [382, 1616, 461, 1741], "vertical": true, "font_size": 32.0, "lines": ["．．．ね．．．", "寝てる．．．"]}], "img_path": "066.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1048, 412, 1083, 494], "vertical": true, "font_size": 32.0, "lines": ["んー。"]}, {"box": [1146, 1065, 1172, 1166], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．"]}, {"box": [686, 1083, 813, 1425], "vertical": true, "font_size": 32.0, "lines": ["寝ちゃって", "たかー。", "西片も", "帰ってるや。"]}, {"box": [572, 1065, 603, 1171], "vertical": true, "font_size": 31.0, "lines": ["．．．．．．．"]}, {"box": [165, 1123, 208, 1205], "vertical": true, "font_size": 32.0, "lines": ["ふー。"]}, {"box": [1156, 1535, 1197, 1710], "vertical": true, "font_size": 31.0, "lines": ["冷えるやつ．．．"]}, {"box": [682, 1546, 725, 1740], "vertical": true, "font_size": 32.0, "lines": ["お母さんかな。"]}], "img_path": "067.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1209, 101, 1295, 255], "vertical": true, "font_size": 32.0, "lines": ["熱があった", "とはいえ、"]}, {"box": [661, 127, 792, 375], "vertical": true, "font_size": 32.0, "lines": ["ちょっと素直に", "甘えすぎちゃった", "かな．．．"]}, {"box": [536, 84, 615, 327], "vertical": true, "font_size": 29.0, "lines": ["変に思われて", "なかったらいいけど。"]}, {"box": [740, 937, 802, 1132], "vertical": true, "font_size": 32.0, "lines": ["お大事に"]}, {"box": [716, 1149, 750, 1316], "vertical": true, "font_size": 32.0, "lines": ["顔赤かたの"]}, {"box": [639, 1143, 707, 1316], "vertical": true, "font_size": 32.0, "lines": ["ヒエピタはって", "おきました"]}, {"box": [699, 1533, 776, 1730], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "西片らしいや。"]}], "img_path": "068.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "069.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [588, 1725, 1220, 1781], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さん"]}], "img_path": "070.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [431, 273, 607, 378], "vertical": false, "font_size": 32.0, "lines": ["ケーキ材料日本茶・"]}], "img_path": "071.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1097, 845, 1218, 958], "vertical": true, "font_size": 32.0, "lines": ["うん、", "いいね。"]}, {"box": [797, 840, 843, 926], "vertical": true, "font_size": 32.0, "lines": ["ねー。"]}, {"box": [671, 822, 697, 973], "vertical": true, "font_size": 26.0, "lines": ["もーいっこ。"]}, {"box": [157, 821, 271, 1035], "vertical": true, "font_size": 32.0, "lines": ["なくなりそうな", "勢いで味見", "してるな．．．"]}, {"box": [590, 1040, 652, 1164], "vertical": true, "font_size": 32.0, "lines": ["私もー。"]}, {"box": [723, 1327, 803, 1543], "vertical": true, "font_size": 32.0, "lines": ["見つかったら", "没収らしいよ？"]}, {"box": [253, 1323, 350, 1443], "vertical": true, "font_size": 32.0, "lines": ["大丈夫", "大丈夫。"]}, {"box": [1068, 1346, 1190, 1657], "vertical": true, "font_size": 32.0, "lines": ["でも、そんなに", "いっぱい持っていって", "大丈夫？"]}], "img_path": "072.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1097, 147, 1188, 368], "vertical": true, "font_size": 32.0, "lines": ["バレンタイン", "なんだよ！"]}, {"box": [450, 121, 602, 421], "vertical": true, "font_size": 32.0, "lines": ["先生も", "目つぶって許して", "くれるよ！"]}, {"box": [363, 195, 391, 346], "vertical": true, "font_size": 27.0, "lines": ["そうかな．．．"]}, {"box": [136, 643, 215, 796], "vertical": true, "font_size": 32.0, "lines": ["ユカリのも", "味見ー。"]}, {"box": [1115, 965, 1192, 1089], "vertical": true, "font_size": 32.0, "lines": ["ちょっと", "やめろ！！"]}, {"box": [714, 930, 755, 1036], "vertical": true, "font_size": 32.0, "lines": ["ケチー。"]}, {"box": [433, 945, 470, 1111], "vertical": true, "font_size": 32.0, "lines": ["食べたいー。"]}, {"box": [161, 965, 202, 1080], "vertical": true, "font_size": 32.0, "lines": ["ダメ！"]}, {"box": [1027, 1432, 1110, 1533], "vertical": true, "font_size": 32.0, "lines": ["これは", "その．．．"]}, {"box": [170, 1380, 245, 1610], "vertical": true, "font_size": 30.0, "lines": ["ちゃんと", "渡すやつだから。"]}], "img_path": "073.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [172, 178, 220, 411], "vertical": true, "font_size": 32.0, "lines": ["気になる人に！"]}, {"box": [508, 873, 549, 980], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [1149, 856, 1193, 1115], "vertical": true, "font_size": 32.0, "lines": ["前に言ったでしょ。"]}, {"box": [629, 885, 751, 1070], "vertical": true, "font_size": 31.0, "lines": ["隣のクラスに", "好きな人", "いるって．．．"]}, {"box": [1042, 1456, 1131, 1656], "vertical": true, "font_size": 32.0, "lines": ["じゃあ余計", "味見しなきゃ。"]}, {"box": [716, 1455, 752, 1567], "vertical": true, "font_size": 32.0, "lines": ["そうね。"]}, {"box": [260, 1432, 429, 1687], "vertical": true, "font_size": 32.0, "lines": ["この", "“おまじないレシピ", "材料の配分が大切", "だから、ダメ！！"]}], "img_path": "074.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [722, 131, 809, 286], "vertical": true, "font_size": 32.0, "lines": ["ほしい人は", "どーぞー"]}], "img_path": "075.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1125, 172, 1200, 327], "vertical": true, "font_size": 32.0, "lines": ["チョコ", "ありがとう。"]}, {"box": [838, 157, 915, 312], "vertical": true, "font_size": 29.0, "lines": ["君の気持ち", "うれしいよ。"]}, {"box": [640, 170, 677, 339], "vertical": true, "font_size": 26.0, "lines": ["実はオレも．．．"]}, {"box": [510, 196, 543, 354], "vertical": true, "font_size": 32.0, "lines": ["なんて～"]}, {"box": [258, 189, 326, 300], "vertical": true, "font_size": 32.0, "lines": ["没収！"]}, {"box": [170, 245, 200, 429], "vertical": true, "font_size": 26.0, "lines": ["せんせえー"]}, {"box": [1005, 907, 1087, 1093], "vertical": true, "font_size": 30.0, "lines": ["お目こぼし、", "なかった～～"]}, {"box": [1164, 1378, 1203, 1486], "vertical": true, "font_size": 32.0, "lines": ["それで、"]}, {"box": [551, 1361, 628, 1449], "vertical": true, "font_size": 32.0, "lines": ["いや、"]}, {"box": [249, 905, 330, 1155], "vertical": true, "font_size": 32.0, "lines": ["だから", "言ったじゃない．．．"]}, {"box": [720, 1413, 795, 1627], "vertical": true, "font_size": 32.0, "lines": ["ユカリちゃんは", "いつ渡すのー？"]}, {"box": [157, 1380, 275, 1627], "vertical": true, "font_size": 32.0, "lines": ["どうやって", "渡したら効果的か", "考えてて．．．"]}], "img_path": "076.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1104, 183, 1185, 431], "vertical": true, "font_size": 32.0, "lines": ["じゃあ聞いてきて", "あげるよ～！"]}, {"box": [690, 174, 727, 241], "vertical": true, "font_size": 32.0, "lines": ["え？"]}, {"box": [489, 195, 577, 298], "vertical": true, "font_size": 32.0, "lines": ["ゴー", "ゴー！"]}, {"box": [129, 82, 592, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [142, 183, 253, 446], "vertical": true, "font_size": 31.0, "lines": ["こいつら", "チョコ没収されて", "ヒマになったんだな。"]}, {"box": [1093, 973, 1136, 1142], "vertical": true, "font_size": 32.0, "lines": ["高尾くーん。"]}, {"box": [1153, 1323, 1185, 1474], "vertical": true, "font_size": 32.0, "lines": ["な、なんだ。"]}, {"box": [860, 1304, 892, 1426], "vertical": true, "font_size": 32.0, "lines": ["えーと．．．"]}, {"box": [150, 961, 195, 1083], "vertical": true, "font_size": 32.0, "lines": ["月本．．．！"]}, {"box": [564, 1376, 682, 1560], "vertical": true, "font_size": 32.0, "lines": ["チョコって", "どうやって", "渡されたい？"]}], "img_path": "077.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [875, 93, 932, 161], "vertical": true, "font_size": 32.0, "lines": ["ふ。"]}, {"box": [626, 90, 713, 260], "vertical": true, "font_size": 32.0, "lines": ["渡し方は", "関係ないぜ。"]}, {"box": [211, 116, 297, 287], "vertical": true, "font_size": 32.0, "lines": ["大切なのは", "心だからな。"]}, {"box": [1149, 783, 1192, 982], "vertical": true, "font_size": 32.0, "lines": ["参考にならん。"]}, {"box": [765, 860, 811, 999], "vertical": true, "font_size": 32.0, "lines": ["次行こー。"]}, {"box": [583, 787, 661, 968], "vertical": true, "font_size": 30.0, "lines": ["くれるんじゃ", "ないの！？"]}, {"box": [163, 793, 279, 1006], "vertical": true, "font_size": 32.0, "lines": ["バレンタインに", "そんな残酷な", "ことするな！"]}, {"box": [1138, 1228, 1218, 1355], "vertical": true, "font_size": 32.0, "lines": ["チョコの", "渡し方？"]}, {"box": [498, 1224, 585, 1363], "vertical": true, "font_size": 32.0, "lines": ["下駄箱に", "入れたよ。"]}, {"box": [159, 1237, 188, 1369], "vertical": true, "font_size": 26.0, "lines": ["ふむふむ"]}, {"box": [541, 1625, 568, 1839], "vertical": true, "font_size": 27.0, "lines": ["すみれちゃんは？"]}, {"box": [151, 1710, 197, 1807], "vertical": true, "font_size": 32.0, "lines": ["私も！？"]}], "img_path": "078.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1092, 90, 1208, 240], "vertical": true, "font_size": 30.0, "lines": ["放課後に", "呼び出して", "校舎裏とか、"]}, {"box": [688, 203, 722, 328], "vertical": true, "font_size": 32.0, "lines": ["かな～～"]}, {"box": [420, 186, 452, 372], "vertical": true, "font_size": 27.0, "lines": ["ありがとー"]}, {"box": [129, 82, 275, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい"]}, {"box": [140, 165, 217, 350], "vertical": true, "font_size": 32.0, "lines": ["なんだったん", "だろ．．"]}, {"box": [1121, 841, 1207, 997], "vertical": true, "font_size": 32.0, "lines": ["ふ、普通に", "渡すわよ。"]}, {"box": [752, 800, 831, 982], "vertical": true, "font_size": 29.0, "lines": ["追わせるって", "いうのかな。"]}, {"box": [426, 819, 498, 1078], "vertical": true, "font_size": 28.0, "lines": ["まあなんか", "ドラマチックよね。"]}, {"box": [266, 798, 346, 967], "vertical": true, "font_size": 32.0, "lines": ["とにかく", "うれしい！"]}, {"box": [660, 1535, 732, 1748], "vertical": true, "font_size": 29.0, "lines": ["ただいまー", "ユカリちゃん！"]}], "img_path": "079.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1186, 95, 1300, 312], "vertical": true, "font_size": 31.0, "lines": ["いろいろ", "調査して案を", "出したところ！"]}, {"box": [571, 136, 790, 465], "vertical": true, "font_size": 32.0, "lines": ["手紙で呼び出して", "追われながら", "下駄箱にドラマチックに", "入れるってのは", "どうかな！！"]}, {"box": [307, 84, 352, 279], "vertical": true, "font_size": 32.0, "lines": ["いい案でしょ！"]}, {"box": [165, 133, 213, 219], "vertical": true, "font_size": 32.0, "lines": ["へー。"]}, {"box": [1027, 913, 1104, 1096], "vertical": true, "font_size": 32.0, "lines": ["いいわけ", "ないでしょ．．．"]}, {"box": [386, 878, 496, 1129], "vertical": true, "font_size": 28.0, "lines": ["使ってよー", "私たちの調査", "無駄になるじゃん！！"]}, {"box": [166, 950, 281, 1183], "vertical": true, "font_size": 31.0, "lines": ["いや、普通に", "帰りに昇降口で", "渡すことにしたし。"]}, {"box": [1117, 1563, 1164, 1663], "vertical": true, "font_size": 32.0, "lines": ["放課後"]}], "img_path": "080.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "081.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1074, 103, 1106, 381], "vertical": true, "font_size": 32.0, "lines": ["はああぁあああ。"]}, {"box": [1093, 894, 1175, 1093], "vertical": true, "font_size": 32.0, "lines": ["まさか", "渡せないとは。"]}, {"box": [1160, 1342, 1286, 1473], "vertical": true, "font_size": 32.0, "lines": ["そうよ", "臆病者よ", "私は。"]}, {"box": [588, 1333, 626, 1546], "vertical": true, "font_size": 32.0, "lines": ["渡せなかった．．．"]}, {"box": [262, 916, 303, 1145], "vertical": true, "font_size": 32.0, "lines": ["渡すだけなのに。"]}, {"box": [148, 1344, 225, 1511], "vertical": true, "font_size": 32.0, "lines": ["せっかく", "作ったのに。"]}, {"box": [692, 1366, 821, 1554], "vertical": true, "font_size": 32.0, "lines": ["渡す勇気すら", "ない自分に", "幻滅するわ。"]}], "img_path": "082.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [487, 136, 575, 341], "vertical": true, "font_size": 32.0, "lines": ["じゃあこれ", "ちょうだい。"]}, {"box": [1108, 954, 1140, 1069], "vertical": true, "font_size": 32.0, "lines": ["どうぞ．．．"]}, {"box": [774, 920, 851, 1091], "vertical": true, "font_size": 32.0, "lines": ["やったー", "もらったー。"]}, {"box": [540, 922, 693, 1123], "vertical": true, "font_size": 32.0, "lines": ["こ．．．", "こいつら～～～", "私のことより", "チョコなのか．．"]}, {"box": [150, 950, 271, 1247], "vertical": true, "font_size": 32.0, "lines": ["昼休みも渡し方を", "真剣に考えてんのを", "だしにして遊んでたし。"]}, {"box": [1125, 1486, 1196, 1741], "vertical": true, "font_size": 29.0, "lines": ["ユカリちゃんにも", "いっこあげるねー。"]}, {"box": [765, 1483, 858, 1680], "vertical": true, "font_size": 32.0, "lines": ["私の", "なんだけど！！"]}, {"box": [397, 1490, 525, 1763], "vertical": true, "font_size": 32.0, "lines": ["こっちが渡せなくて", "落ち込んでるって", "いうのに．．．"]}, {"box": [60, 1509, 129, 1694], "vertical": true, "font_size": 32.0, "lines": ["ねー", "ユカリちゃん。"]}], "img_path": "083.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [618, 150, 759, 354], "vertical": true, "font_size": 32.0, "lines": ["ちゃんと", "渡せて", "よかったね。"]}, {"box": [1140, 868, 1188, 956], "vertical": true, "font_size": 32.0, "lines": ["は？"]}, {"box": [849, 885, 935, 1117], "vertical": true, "font_size": 32.0, "lines": ["渡せなかったの", "イヤなんでしょ。"]}, {"box": [183, 875, 383, 1183], "vertical": true, "font_size": 32.0, "lines": ["だったら", "最初から私たちに", "渡すために作ったって", "ことにしとけば", "よくない？"]}], "img_path": "084.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [973, 795, 1103, 1037], "vertical": true, "font_size": 32.0, "lines": ["渡し方の", "案よりは", "だいぶマシかもね。"]}, {"box": [641, 802, 726, 1020], "vertical": true, "font_size": 32.0, "lines": ["あれも最高の", "案だったけど！？"]}, {"box": [298, 833, 416, 971], "vertical": true, "font_size": 32.0, "lines": ["あーもー", "わかった", "わかった。"]}, {"box": [607, 1353, 646, 1479], "vertical": true, "font_size": 32.0, "lines": ["じゃあ、"]}], "img_path": "085.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1038, 131, 1136, 403], "vertical": true, "font_size": 32.0, "lines": ["ハッピー", "バレンタイーン。"]}, {"box": [954, 1381, 1037, 1571], "vertical": true, "font_size": 32.0, "lines": ["まっず！！", "なにこれえ！！"]}, {"box": [682, 1374, 718, 1541], "vertical": true, "font_size": 32.0, "lines": ["デンジャー。"]}, {"box": [245, 1398, 405, 1581], "vertical": true, "font_size": 32.0, "lines": ["なんで！？", "レシピ通りに", "やったハズ", "なのに！"]}], "img_path": "086.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "087.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [588, 1725, 1220, 1781], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さん"]}], "img_path": "088.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [139, 154, 741, 308], "vertical": false, "font_size": 32.0, "lines": ["いん"]}], "img_path": "089.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [898, 217, 1016, 361], "vertical": true, "font_size": 32.0, "lines": ["次の時間", "委員会決め", "だよねー。"]}, {"box": [579, 185, 630, 405], "vertical": true, "font_size": 32.0, "lines": ["私何にしよー。"]}, {"box": [187, 253, 321, 461], "vertical": true, "font_size": 32.0, "lines": ["私放送委員で", "好きな音楽", "流したいー。"]}, {"box": [1082, 811, 1198, 1025], "vertical": true, "font_size": 32.0, "lines": ["オレはやっぱり", "保健委員", "だなー。"]}, {"box": [905, 819, 992, 973], "vertical": true, "font_size": 32.0, "lines": ["寝まくれる", "しー。"]}, {"box": [710, 871, 798, 1022], "vertical": true, "font_size": 32.0, "lines": ["少しは運動", "しなよ。"]}, {"box": [532, 813, 613, 982], "vertical": true, "font_size": 32.0, "lines": ["オレは", "新聞委員だ。"]}, {"box": [348, 834, 466, 991], "vertical": true, "font_size": 32.0, "lines": ["記事書くの", "おもしれー", "から。"]}, {"box": [153, 828, 247, 1056], "vertical": true, "font_size": 32.0, "lines": ["高尾うわさ話", "好きだもんなー。"]}, {"box": [1250, 1402, 1296, 1598], "vertical": true, "font_size": 32.0, "lines": ["私は風紀かな。"]}, {"box": [907, 1389, 948, 1651], "vertical": true, "font_size": 32.0, "lines": ["前もそうだったし。"]}, {"box": [722, 1402, 852, 1646], "vertical": true, "font_size": 32.0, "lines": ["クラス委員長", "以外ならなんでも", "いいや。"]}, {"box": [288, 1400, 410, 1541], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "大変そう", "だもんね。"]}], "img_path": "090.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [531, 161, 744, 558], "vertical": true, "font_size": 32.0, "lines": ["西片", "は？", "高木ちゃん"]}, {"box": [303, 981, 339, 1128], "vertical": true, "font_size": 32.0, "lines": ["オレは．．．"]}, {"box": [1027, 1569, 1083, 1691], "vertical": true, "font_size": 32.0, "lines": ["私は．．．"]}], "img_path": "091.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [898, 198, 985, 369], "vertical": true, "font_size": 32.0, "lines": ["あ、昼休み", "終わりだな。"]}, {"box": [618, 228, 738, 444], "vertical": true, "font_size": 32.0, "lines": ["よっしゃ！", "保健委員", "勝ち取るぞぉ！"]}, {"box": [1074, 823, 1170, 1065], "vertical": true, "font_size": 32.0, "lines": ["次、", "委員会決めだね。"]}, {"box": [537, 510, 561, 580], "vertical": true, "font_size": 24.0, "lines": ["．．．．．"]}, {"box": [590, 1338, 707, 1523], "vertical": true, "font_size": 29.0, "lines": ["ああ！", "もちろん！", "決めてるよ！"]}, {"box": [373, 1345, 414, 1530], "vertical": true, "font_size": 32.0, "lines": ["高木さんは？！！"]}, {"box": [1085, 1357, 1213, 1539], "vertical": true, "font_size": 27.0, "lines": ["西片はもう", "何にするか", "決めてるの？"]}, {"box": [153, 1552, 247, 1758], "vertical": true, "font_size": 32.0, "lines": ["私も", "決まってるよ。"]}], "img_path": "092.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1166, 168, 1207, 251], "vertical": true, "font_size": 32.0, "lines": ["へえ。"]}, {"box": [924, 173, 966, 358], "vertical": true, "font_size": 26.0, "lines": ["何にするの？"]}, {"box": [540, 176, 577, 243], "vertical": true, "font_size": 32.0, "lines": ["え．．．"]}, {"box": [129, 82, 596, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [433, 155, 466, 322], "vertical": true, "font_size": 32.0, "lines": ["あ、ああー、"]}, {"box": [148, 249, 180, 353], "vertical": true, "font_size": 32.0, "lines": ["えーと、"]}, {"box": [1136, 716, 1179, 789], "vertical": true, "font_size": 32.0, "lines": ["な．．．"]}, {"box": [600, 823, 661, 958], "vertical": true, "font_size": 32.0, "lines": ["内緒で。"]}, {"box": [487, 1376, 521, 1482], "vertical": true, "font_size": 32.0, "lines": ["じゃあ、"]}, {"box": [1018, 1391, 1062, 1614], "vertical": true, "font_size": 32.0, "lines": ["た、高木さんは？"]}, {"box": [157, 1391, 203, 1530], "vertical": true, "font_size": 32.0, "lines": ["私も内緒。"]}], "img_path": "093.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1158, 275, 1241, 376], "vertical": true, "font_size": 32.0, "lines": ["そ．．．", "そう．．．"]}, {"box": [896, 133, 1010, 403], "vertical": true, "font_size": 32.0, "lines": ["はい、じゃあ", "注目ー"]}, {"box": [695, 676, 855, 725], "vertical": false, "font_size": 32.0, "lines": ["希望委員"]}, {"box": [157, 125, 312, 835], "vertical": true, "font_size": 32.0, "lines": ["今から配るプリントに", "人数多かったら", "なりたい委員書いて", "ジャンケンで", "１５分後に提出な。", "決めるぞー。"]}, {"box": [1091, 954, 1207, 1123], "vertical": true, "font_size": 32.0, "lines": ["やだなー", "ジャンケン", "弱いのよね。"]}, {"box": [564, 946, 695, 1194], "vertical": true, "font_size": 32.0, "lines": ["大丈夫、", "もう書いておいて", "あげた。"]}, {"box": [271, 951, 345, 1117], "vertical": true, "font_size": 30.0, "lines": ["これなら", "被らないね。"]}, {"box": [157, 1111, 201, 1325], "vertical": true, "font_size": 32.0, "lines": ["勝手に書くな！"]}, {"box": [1230, 1456, 1315, 1699], "vertical": true, "font_size": 30.0, "lines": ["お前ら保健委員に", "入れるなよ！"]}, {"box": [913, 1452, 1042, 1636], "vertical": true, "font_size": 32.0, "lines": ["今日のオレは", "ジャンケン", "強いぞ！"]}, {"box": [823, 1443, 864, 1528], "vertical": true, "font_size": 32.0, "lines": ["ひひ。"]}, {"box": [580, 1458, 662, 1642], "vertical": true, "font_size": 29.0, "lines": ["どんな記事を", "書こうかな。"]}, {"box": [451, 1462, 530, 1612], "vertical": true, "font_size": 30.0, "lines": ["応援委員に", "しようかな。"]}, {"box": [299, 1442, 431, 1475], "vertical": false, "font_size": 32.0, "lines": ["となりのクラス"]}, {"box": [156, 1436, 268, 1743], "vertical": true, "font_size": 32.0, "lines": ["あいつ、", "サッカー部がんばってる", "みたいだし．．．"]}], "img_path": "094.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [1117, 768, 1196, 952], "vertical": true, "font_size": 28.0, "lines": ["書かないの？", "高木さん。"]}, {"box": [545, 783, 633, 969], "vertical": true, "font_size": 32.0, "lines": ["んーまだ時間", "あるしなあ。"]}, {"box": [151, 798, 199, 937], "vertical": true, "font_size": 32.0, "lines": ["西片こそ。"]}, {"box": [1072, 1367, 1168, 1477], "vertical": true, "font_size": 32.0, "lines": ["まあ．．．"]}, {"box": [624, 1348, 740, 1575], "vertical": true, "font_size": 32.0, "lines": ["もうちょっと", "じっくり考えて", "みようかなって。"]}, {"box": [491, 1471, 526, 1579], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}], "img_path": "095.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [755, 123, 795, 281], "vertical": true, "font_size": 32.0, "lines": ["高木さん、"]}, {"box": [641, 178, 680, 440], "vertical": true, "font_size": 32.0, "lines": ["勝負しない？"]}, {"box": [300, 170, 471, 386], "vertical": true, "font_size": 32.0, "lines": ["書こうとしてる", "委員を先に", "言い当てた方が", "勝ちで、"]}, {"box": [148, 210, 185, 309], "vertical": true, "font_size": 32.0, "lines": ["どう？"]}, {"box": [1157, 1070, 1196, 1173], "vertical": true, "font_size": 32.0, "lines": ["いいね。"]}, {"box": [740, 1104, 772, 1239], "vertical": true, "font_size": 32.0, "lines": ["やろっか。"]}, {"box": [575, 1076, 656, 1216], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "オレから。"]}, {"box": [169, 1092, 216, 1355], "vertical": true, "font_size": 32.0, "lines": ["風紀委員。"]}, {"box": [1113, 1576, 1149, 1717], "vertical": true, "font_size": 32.0, "lines": ["はずれー。"]}, {"box": [228, 1644, 270, 1732], "vertical": true, "font_size": 32.0, "lines": ["ぐっ。"]}], "img_path": "096.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [926, 210, 971, 348], "vertical": true, "font_size": 32.0, "lines": ["保健委員。"]}, {"box": [702, 320, 737, 429], "vertical": true, "font_size": 32.0, "lines": ["はずれ。"]}, {"box": [129, 82, 596, 120], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [382, 198, 432, 341], "vertical": true, "font_size": 32.0, "lines": ["体育委員。"]}, {"box": [230, 380, 265, 504], "vertical": true, "font_size": 32.0, "lines": ["はずれ．．"]}, {"box": [1104, 738, 1153, 876], "vertical": true, "font_size": 32.0, "lines": ["飼育委員。"]}, {"box": [952, 898, 986, 1001], "vertical": true, "font_size": 32.0, "lines": ["はずれ。"]}, {"box": [322, 738, 375, 876], "vertical": true, "font_size": 32.0, "lines": ["応援委員。"]}, {"box": [960, 1155, 1008, 1263], "vertical": true, "font_size": 32.0, "lines": ["委員長。"]}, {"box": [247, 945, 281, 1050], "vertical": true, "font_size": 32.0, "lines": ["はずれ。"]}, {"box": [363, 1156, 397, 1261], "vertical": true, "font_size": 32.0, "lines": ["はずれ。"]}, {"box": [277, 1505, 318, 1588], "vertical": true, "font_size": 32.0, "lines": ["んー。"]}], "img_path": "097.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1082, 178, 1194, 330], "vertical": true, "font_size": 31.0, "lines": ["なかなか", "当たらない", "もんだね。"]}, {"box": [618, 206, 748, 361], "vertical": true, "font_size": 32.0, "lines": ["あと西片が", "選びそうな", "ものはー。"]}, {"box": [519, 200, 564, 336], "vertical": true, "font_size": 32.0, "lines": ["高木さん。"]}, {"box": [648, 654, 687, 819], "vertical": true, "font_size": 32.0, "lines": ["オレの負け。"]}, {"box": [1157, 1290, 1192, 1357], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [560, 1295, 646, 1426], "vertical": true, "font_size": 32.0, "lines": ["オレの．．．", "負け．．．"]}], "img_path": "098.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1061, 180, 1188, 369], "vertical": true, "font_size": 32.0, "lines": ["当たったのに", "違うって", "言ったとか？"]}, {"box": [780, 208, 858, 423], "vertical": true, "font_size": 32.0, "lines": ["いや．．．そういう", "わけでは．．"]}, {"box": [673, 163, 705, 298], "vertical": true, "font_size": 32.0, "lines": ["とにかく、"]}, {"box": [435, 178, 474, 344], "vertical": true, "font_size": 31.0, "lines": ["負けました。"]}, {"box": [129, 82, 594, 120], "vertical": false, "font_size": 32.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [301, 176, 340, 286], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [391, 841, 474, 1053], "vertical": true, "font_size": 32.0, "lines": ["ホントに負けで", "いいの？"]}, {"box": [999, 860, 1113, 1074], "vertical": true, "font_size": 30.0, "lines": ["なんかあんまり", "勝った気が", "しないなあ。"]}, {"box": [1147, 1451, 1187, 1550], "vertical": true, "font_size": 32.0, "lines": ["うん．．．"]}, {"box": [167, 1440, 197, 1543], "vertical": true, "font_size": 30.0, "lines": ["．．．．．．．"]}], "img_path": "099.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1147, 105, 1269, 271], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "とりあえず", "罰ゲームで、"]}, {"box": [692, 176, 826, 393], "vertical": true, "font_size": 32.0, "lines": ["西片の正解", "教えてもらおう", "かなー。"]}, {"box": [564, 465, 598, 585], "vertical": true, "font_size": 32.0, "lines": ["いやー．．．"]}, {"box": [352, 451, 386, 556], "vertical": true, "font_size": 32.0, "lines": ["えーと、"]}, {"box": [256, 450, 290, 547], "vertical": true, "font_size": 32.0, "lines": ["その．．．"]}, {"box": [646, 973, 851, 1162], "vertical": true, "font_size": 32.0, "lines": ["高木さんと", "同じのに", "しようと", "思ってた。"]}], "img_path": "100.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [534, 129, 655, 341], "vertical": true, "font_size": 32.0, "lines": ["あ！でも", "そういうんじゃ", "ないから！！"]}, {"box": [62, 112, 229, 388], "vertical": true, "font_size": 32.0, "lines": ["委員同じになったら", "勝負のチャンス", "増えるからいいなと", "思っただけで！"]}, {"box": [1153, 855, 1183, 1022], "vertical": true, "font_size": 26.0, "lines": ["「あははは。"]}, {"box": [405, 832, 444, 945], "vertical": true, "font_size": 32.0, "lines": ["そっか。"]}, {"box": [144, 830, 346, 1147], "vertical": true, "font_size": 32.0, "lines": ["それで２人あわせて", "全部の委員言ったから、", "もう何書いても嘘に", "なっちゃうから", "負けってことかー。"]}, {"box": [1110, 1466, 1188, 1621], "vertical": true, "font_size": 32.0, "lines": ["律儀だなあ", "西片は。"]}, {"box": [782, 1447, 1038, 1726], "vertical": true, "font_size": 32.0, "lines": ["私なら", "どれも自分が", "書こうとしてる", "やつじゃないから", "負けないって考えに", "しちゃうけど。"]}, {"box": [163, 1552, 241, 1741], "vertical": true, "font_size": 32.0, "lines": ["それ", "ズルくない！？"]}], "img_path": "101.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1076, 240, 1128, 480], "vertical": true, "font_size": 32.0, "lines": ["あははほは。"]}, {"box": [170, 262, 264, 414], "vertical": true, "font_size": 32.0, "lines": ["そんなに", "笑う！？"]}, {"box": [1112, 909, 1192, 1109], "vertical": true, "font_size": 32.0, "lines": ["いやー、", "こめんごめん。"]}, {"box": [615, 1325, 703, 1436], "vertical": true, "font_size": 32.0, "lines": ["んーん", "いいや。"]}, {"box": [466, 1333, 549, 1460], "vertical": true, "font_size": 32.0, "lines": ["なんでも", "ない。"]}, {"box": [300, 916, 330, 1102], "vertical": true, "font_size": 26.0, "lines": ["だってさあ．．．"]}, {"box": [195, 1338, 228, 1436], "vertical": true, "font_size": 32.0, "lines": ["ええ．．．"]}], "img_path": "102.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [615, 138, 660, 253], "vertical": true, "font_size": 32.0, "lines": ["ふふっ。"]}, {"box": [656, 885, 774, 1134], "vertical": true, "font_size": 32.0, "lines": ["それで", "高木さんの正解は", "なんだったの？"]}, {"box": [735, 1295, 817, 1464], "vertical": true, "font_size": 32.0, "lines": ["じゃあ、", "図書委員で。"]}, {"box": [543, 1290, 628, 1503], "vertical": true, "font_size": 28.0, "lines": ["西片も同じのに", "するんだよね。"]}, {"box": [232, 928, 277, 1016], "vertical": true, "font_size": 32.0, "lines": ["んー。"]}, {"box": [363, 1314, 450, 1402], "vertical": true, "font_size": 32.0, "lines": ["う、", "うん。"]}, {"box": [178, 1282, 266, 1456], "vertical": true, "font_size": 32.0, "lines": ["図書．．．", "委員．．．っと。"]}], "img_path": "103.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [583, 131, 703, 275], "vertical": true, "font_size": 32.0, "lines": ["お互い", "当たらない", "わけだよ。"]}, {"box": [463, 176, 492, 248], "vertical": true, "font_size": 29.0, "lines": ["．．．．．"]}, {"box": [181, 195, 225, 266], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [1037, 1003, 1073, 1162], "vertical": true, "font_size": 32.0, "lines": ["どしたの？"]}, {"box": [358, 1040, 397, 1166], "vertical": true, "font_size": 32.0, "lines": ["いやー．．．"]}, {"box": [1068, 1485, 1149, 1616], "vertical": true, "font_size": 32.0, "lines": ["じゃあ、", "って何？"]}, {"box": [650, 1492, 690, 1606], "vertical": true, "font_size": 32.0, "lines": ["さあー。"]}, {"box": [352, 1490, 442, 1674], "vertical": true, "font_size": 32.0, "lines": ["１５分経ったし", "集めるぞー。"]}], "img_path": "104.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [455, 150, 853, 343], "vertical": false, "font_size": 32.0, "lines": ["じょう", "たん", "誕生"]}], "img_path": "105.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1207, 234, 1243, 498], "vertical": true, "font_size": 32.0, "lines": ["いきなりだけど、"]}, {"box": [967, 335, 1115, 541], "vertical": true, "font_size": 32.0, "lines": ["高木さんて", "今日誕生日", "だよね。"]}], "img_path": "106.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1097, 178, 1173, 305], "vertical": true, "font_size": 32.0, "lines": ["あれ？", "違った？！！"]}, {"box": [783, 183, 860, 352], "vertical": true, "font_size": 32.0, "lines": ["ううん、", "合ってるよ。"]}, {"box": [677, 168, 726, 352], "vertical": true, "font_size": 32.0, "lines": ["今日誕生日。"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [159, 170, 238, 309], "vertical": true, "font_size": 32.0, "lines": ["よかった、", "合ってて。"]}, {"box": [630, 727, 755, 931], "vertical": true, "font_size": 32.0, "lines": ["でさ、", "プレゼントが", "あるんだけど。"]}, {"box": [204, 1123, 242, 1307], "vertical": true, "font_size": 32.0, "lines": ["プレゼント。"]}, {"box": [1119, 1588, 1158, 1695], "vertical": true, "font_size": 32.0, "lines": ["そう！"]}, {"box": [892, 1550, 1053, 1846], "vertical": true, "font_size": 32.0, "lines": ["高木さんが", "気になるって言ってた", "キツネヌキと", "タヌキツネってやつ。"]}, {"box": [178, 1597, 265, 1777], "vertical": true, "font_size": 32.0, "lines": ["それの小さい", "ぬいぐるみ。"]}], "img_path": "107.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1091, 200, 1187, 427], "vertical": true, "font_size": 32.0, "lines": ["そこで", "勝負しない！？"]}, {"box": [159, 187, 560, 742], "vertical": true, "font_size": 31.0, "lines": ["オレが高木さんに", "渡すのは", "キツネヌキか", "タヌキツネか。", "当たってたら", "どっちなのか", "高木さんの勝ち。", "予想してもらって、", "外れてたら", "オレの勝ち。", "どうかな？"]}, {"box": [1172, 845, 1195, 916], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．"]}, {"box": [847, 864, 933, 978], "vertical": true, "font_size": 32.0, "lines": ["うん", "いいよ。"]}, {"box": [690, 858, 731, 988], "vertical": true, "font_size": 32.0, "lines": ["よし！"]}, {"box": [892, 1291, 1020, 1549], "vertical": true, "font_size": 32.0, "lines": ["実は高木さんが", "どっちを答えても", "オレの勝ちなのさ。"]}, {"box": [511, 1286, 634, 1488], "vertical": true, "font_size": 32.0, "lines": ["なぜなら、", "どっちも", "持ってるから！"]}, {"box": [172, 907, 218, 1185], "vertical": true, "font_size": 32.0, "lines": ["かかったああ。"]}], "img_path": "108.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1016, 168, 1190, 360], "vertical": true, "font_size": 32.0, "lines": ["高木さんが", "答えたのと", "逆のを渡せば", "オレの勝ち！"]}, {"box": [555, 181, 603, 384], "vertical": true, "font_size": 32.0, "lines": ["完璧な作戦！"]}, {"box": [161, 185, 234, 400], "vertical": true, "font_size": 30.0, "lines": ["じゃあ、", "どっちにする？"]}, {"box": [1059, 937, 1106, 1021], "vertical": true, "font_size": 32.0, "lines": ["じゃ、"]}, {"box": [211, 982, 244, 1179], "vertical": true, "font_size": 32.0, "lines": ["キツネヌキで。"]}, {"box": [1003, 1468, 1077, 1648], "vertical": true, "font_size": 29.0, "lines": ["キツネヌキで", "いいんだね。"]}, {"box": [821, 1481, 857, 1558], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}, {"box": [635, 1473, 753, 1751], "vertical": true, "font_size": 32.0, "lines": ["ふふふ、", "あとはタヌキツネを", "渡せばオレの勝．．．"]}], "img_path": "109.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1194, 101, 1277, 283], "vertical": true, "font_size": 29.0, "lines": ["なんか即答", "すぎないか！？"]}, {"box": [873, 121, 900, 393], "vertical": true, "font_size": 32.0, "lines": ["テキトーというか．．．"]}, {"box": [661, 176, 752, 481], "vertical": true, "font_size": 32.0, "lines": ["何か狙っているのか", "高木さん！？"]}, {"box": [1175, 888, 1207, 988], "vertical": true, "font_size": 32.0, "lines": ["まさか"]}, {"box": [517, 862, 592, 986], "vertical": true, "font_size": 32.0, "lines": ["ちゃんと", "ある！！"]}, {"box": [977, 868, 1130, 1117], "vertical": true, "font_size": 32.0, "lines": ["オレが知らずに", "タヌキツネを家に", "忘れていて、", "それに気づいて．．"]}, {"box": [916, 1406, 1109, 1646], "vertical": true, "font_size": 30.0, "lines": ["落ち着けオレ", "ぞもそもそんなの", "高木さんが", "気づけるわけ", "ないだろ。"]}, {"box": [189, 1443, 313, 1603], "vertical": true, "font_size": 32.0, "lines": ["しかし、いった", "なら一体", "どういう"]}], "img_path": "110.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [723, 203, 755, 388], "vertical": true, "font_size": 27.0, "lines": ["どうかした？"]}, {"box": [586, 208, 622, 279], "vertical": true, "font_size": 32.0, "lines": ["あ．．．"]}, {"box": [129, 82, 596, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [155, 206, 195, 388], "vertical": true, "font_size": 32.0, "lines": ["いや、その．．．"]}, {"box": [993, 738, 1179, 988], "vertical": true, "font_size": 30.0, "lines": ["ちなみにだけど", "なんでキツネヌキ", "選んだの？"]}, {"box": [622, 726, 656, 821], "vertical": true, "font_size": 32.0, "lines": ["んー？"]}, {"box": [453, 699, 487, 898], "vertical": true, "font_size": 32.0, "lines": ["テキトーだよ。"]}, {"box": [1125, 1310, 1196, 1461], "vertical": true, "font_size": 29.0, "lines": ["んなわけ", "ないだろ！"]}, {"box": [832, 1308, 864, 1491], "vertical": true, "font_size": 32.0, "lines": ["ホントは．．．？"]}, {"box": [264, 1293, 396, 1481], "vertical": true, "font_size": 32.0, "lines": ["何も考えずに", "思いついたの", "言っただけ。"]}, {"box": [688, 1336, 767, 1584], "vertical": true, "font_size": 32.0, "lines": ["ホントにテキトー", "だよ。"]}, {"box": [110, 1425, 139, 1517], "vertical": true, "font_size": 28.0, "lines": ["ええ？！！"]}], "img_path": "111.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1115, 174, 1194, 356], "vertical": true, "font_size": 32.0, "lines": ["いや、それで", "いいの！？"]}, {"box": [995, 178, 1027, 361], "vertical": true, "font_size": 32.0, "lines": ["テキトーで！"]}, {"box": [823, 202, 907, 376], "vertical": true, "font_size": 32.0, "lines": ["これ", "勝負だけど。"]}, {"box": [474, 202, 559, 504], "vertical": true, "font_size": 32.0, "lines": ["負けてもいいやって", "思ってさ。"]}, {"box": [315, 253, 360, 328], "vertical": true, "font_size": 32.0, "lines": ["え？！"]}, {"box": [161, 241, 200, 348], "vertical": true, "font_size": 32.0, "lines": ["だって、"]}, {"box": [1040, 997, 1251, 1308], "vertical": true, "font_size": 32.0, "lines": ["西片が誕生日", "覚えててくれて", "プレゼントまで", "くれるって言うし、"]}, {"box": [191, 1012, 337, 1340], "vertical": true, "font_size": 32.0, "lines": ["勝負なんて", "どうでもいいくらい", "うれしくて。"]}], "img_path": "112.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [129, 82, 575, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい", "１上手の高ホさんの"]}, {"box": [163, 202, 243, 420], "vertical": true, "font_size": 32.0, "lines": ["それでこた", "答えはどっち？"]}, {"box": [601, 1205, 649, 1335], "vertical": true, "font_size": 32.0, "lines": ["答えは．．．"]}], "img_path": "113.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [992, 956, 1070, 1057], "vertical": true, "font_size": 32.0, "lines": ["ん？ッ．．．ッぅほう", "両方？"]}, {"box": [1127, 1320, 1200, 1505], "vertical": true, "font_size": 32.0, "lines": ["あーそういう", "ことか。"]}, {"box": [669, 1314, 752, 1509], "vertical": true, "font_size": 32.0, "lines": ["西片は", "やさしいなあ。"]}, {"box": [543, 1385, 620, 1610], "vertical": true, "font_size": 32.0, "lines": ["せっかく勝てる", "勝負だったのに。"]}], "img_path": "114.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1145, 187, 1179, 302], "vertical": true, "font_size": 32.0, "lines": ["い、いや、"]}, {"box": [581, 191, 752, 466], "vertical": true, "font_size": 32.0, "lines": ["勝負にやる気ない", "高木さんに勝っても", "しょうがないから", "だから！"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [176, 191, 216, 301], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [1065, 802, 1131, 1037], "vertical": true, "font_size": 26.0, "lines": ["そういうことに", "しといてあげるよ。"]}, {"box": [549, 810, 618, 990], "vertical": true, "font_size": 26.0, "lines": ["そういうこと", "だからね！"]}, {"box": [1097, 1333, 1172, 1458], "vertical": true, "font_size": 32.0, "lines": ["えっと．．．", "じゃあ、"]}, {"box": [566, 1368, 605, 1470], "vertical": true, "font_size": 32.0, "lines": ["その．．．"]}], "img_path": "115.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1149, 860, 1192, 1004], "vertical": true, "font_size": 32.0, "lines": ["なんか"]}, {"box": [496, 783, 705, 1007], "vertical": true, "font_size": 31.0, "lines": ["今更だけどオレ、", "女子の誕生日に", "プレゼント", "あげようと", "してるんだ。"]}, {"box": [767, 823, 864, 1336], "vertical": true, "font_size": 32.0, "lines": ["はっず．．．．．．！！"]}, {"box": [579, 1265, 704, 1570], "vertical": true, "font_size": 30.0, "lines": ["勝負メインのつもり", "だったから気になって", "なかったけど、"]}, {"box": [157, 1305, 325, 1488], "vertical": true, "font_size": 30.0, "lines": ["高木さんが", "あまりに", "うれしそうに", "するから．．．"]}], "img_path": "116.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1044, 225, 1078, 365], "vertical": true, "font_size": 32.0, "lines": ["こ、これ．．．"]}, {"box": [924, 247, 963, 348], "vertical": true, "font_size": 32.0, "lines": ["どうぞ。"]}, {"box": [742, 208, 780, 277], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [528, 176, 649, 422], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "なんか恥ずかしく", "なってきた？"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [157, 205, 189, 443], "vertical": true, "font_size": 26.0, "lines": ["そ．．．そんなんじゃ。"]}, {"box": [1038, 995, 1119, 1246], "vertical": true, "font_size": 32.0, "lines": ["ちゃんと", "言ってほしいな。"]}], "img_path": "117.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1097, 178, 1231, 450], "vertical": true, "font_size": 32.0, "lines": ["誕生日", "おめでとう。"]}, {"box": [1106, 1209, 1155, 1320], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}, {"box": [251, 1233, 303, 1428], "vertical": true, "font_size": 32.0, "lines": ["ありがと。"]}], "img_path": "118.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1057, 228, 1129, 416], "vertical": true, "font_size": 28.0, "lines": ["じゃあこっち", "もらうね。"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [178, 217, 256, 384], "vertical": true, "font_size": 32.0, "lines": ["．．．", "両方いいよ。"]}, {"box": [1037, 731, 1190, 879], "vertical": true, "font_size": 32.0, "lines": ["んーん、", "そっちは", "西片が", "持っててよ。"]}, {"box": [618, 755, 808, 980], "vertical": true, "font_size": 30.0, "lines": ["いや、でも", "せっかくだし", "これよく考えたら", "セットみたいな", "もんだし。"]}, {"box": [337, 716, 371, 883], "vertical": true, "font_size": 32.0, "lines": ["だからだよ。"]}, {"box": [153, 738, 196, 810], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [594, 1231, 675, 1359], "vertical": true, "font_size": 32.0, "lines": ["やるねー", "西片。"]}, {"box": [225, 1314, 262, 1383], "vertical": true, "font_size": 32.0, "lines": ["え？"]}], "img_path": "119.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [474, 138, 629, 401], "vertical": true, "font_size": 32.0, "lines": ["誕生日に自分と", "ペアのもの", "贈るなんてさ。"]}, {"box": [958, 976, 1076, 1248], "vertical": true, "font_size": 32.0, "lines": ["いや！", "そういうつもりじゃ", "ないから！！"]}, {"box": [718, 978, 797, 1136], "vertical": true, "font_size": 32.0, "lines": ["もらってよ", "これ！"]}, {"box": [230, 1042, 348, 1240], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "キツネヌキ", "大事にするね。"]}, {"box": [1031, 1441, 1157, 1638], "vertical": true, "font_size": 32.0, "lines": ["西片も", "タヌキツネ", "大事にしてよ。"]}, {"box": [903, 1468, 945, 1726], "vertical": true, "font_size": 32.0, "lines": ["ペアなんだからさ。"]}, {"box": [663, 1455, 725, 1481], "vertical": false, "font_size": 26.0, "lines": ["あは"]}, {"box": [352, 1525, 384, 1693], "vertical": true, "font_size": 32.0, "lines": ["ちょっと！"]}], "img_path": "120.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "121.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1089, 427, 1145, 500], "vertical": true, "font_size": 32.0, "lines": ["あ。"]}, {"box": [1209, 928, 1247, 993], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [752, 915, 840, 1168], "vertical": true, "font_size": 32.0, "lines": ["いや、高木さんの", "背中にトンボが。"]}, {"box": [601, 922, 682, 1136], "vertical": true, "font_size": 30.0, "lines": ["見えないし", "とってくれる？"]}, {"box": [193, 939, 234, 1021], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}, {"box": [1241, 1518, 1277, 1629], "vertical": true, "font_size": 32.0, "lines": ["ありゃ。"]}], "img_path": "122.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [695, 110, 735, 210], "vertical": true, "font_size": 32.0, "lines": ["これ．．"]}, {"box": [43, 140, 138, 305], "vertical": true, "font_size": 32.0, "lines": ["高木さんに", "触れ．．"]}, {"box": [866, 1297, 905, 1395], "vertical": true, "font_size": 32.0, "lines": ["あ．．．！"]}, {"box": [697, 1295, 774, 1525], "vertical": true, "font_size": 32.0, "lines": ["と、", "飛んでいったよ。"]}, {"box": [213, 1325, 247, 1436], "vertical": true, "font_size": 32.0, "lines": ["そっか。"]}], "img_path": "123.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [674, 89, 703, 194], "vertical": true, "font_size": 29.0, "lines": ["．．．．．．？"]}, {"box": [887, 856, 938, 1014], "vertical": true, "font_size": 32.0, "lines": ["ねぇ西片。"]}, {"box": [618, 946, 661, 1018], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [769, 1263, 842, 1428], "vertical": true, "font_size": 30.0, "lines": ["ルールは", "わかるよね。"]}, {"box": [236, 1280, 314, 1462], "vertical": true, "font_size": 29.0, "lines": ["だるまさんが", "ころんだ。"]}], "img_path": "124.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [988, 90, 1065, 259], "vertical": true, "font_size": 32.0, "lines": ["く．．．たか", "高木さんめ"]}, {"box": [507, 168, 675, 480], "vertical": true, "font_size": 32.0, "lines": ["さっき俺がテレて", "触れなかったのを見て", "タッチが必要な勝負を", "挑んでくるとは．．．"]}, {"box": [339, 185, 414, 341], "vertical": true, "font_size": 32.0, "lines": ["だが甘いぞ", "高木さん。"]}, {"box": [28, 228, 228, 416], "vertical": true, "font_size": 32.0, "lines": ["逆に言えば", "タッチさえ", "してしまえば", "オレの勝ちと", "いうことだ。"]}, {"box": [1065, 843, 1196, 1005], "vertical": true, "font_size": 32.0, "lines": ["絶対に", "タッチして", "みせる！"]}, {"box": [271, 883, 305, 1020], "vertical": true, "font_size": 32.0, "lines": ["やるよー。"]}, {"box": [1127, 1329, 1164, 1459], "vertical": true, "font_size": 32.0, "lines": ["だー"]}, {"box": [800, 1351, 830, 1481], "vertical": true, "font_size": 30.0, "lines": ["るー"]}, {"box": [643, 1346, 692, 1449], "vertical": true, "font_size": 32.0, "lines": ["遅い！"]}, {"box": [444, 1331, 590, 1554], "vertical": true, "font_size": 32.0, "lines": ["どうせ", "タッチできないと", "思って油断して", "いるな！"]}, {"box": [121, 1582, 160, 1805], "vertical": true, "font_size": 32.0, "lines": ["チャンスだ！！"]}], "img_path": "125.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1119, 151, 1237, 349], "vertical": true, "font_size": 32.0, "lines": ["と、", "普通なら", "思うだろうな。"]}, {"box": [513, 112, 551, 242], "vertical": true, "font_size": 32.0, "lines": ["まー"]}, {"box": [211, 140, 366, 374], "vertical": true, "font_size": 28.0, "lines": ["しかし高木さんは", "そんなに", "甘くないことを", "オレは知っている。"]}, {"box": [1068, 742, 1185, 988], "vertical": true, "font_size": 32.0, "lines": ["タッチできるか", "どうかの勝負だと", "思わせておいて．．．"]}, {"box": [954, 731, 1023, 834], "vertical": true, "font_size": 32.0, "lines": ["急に、"]}, {"box": [787, 733, 864, 886], "vertical": true, "font_size": 32.0, "lines": ["さんが", "ころんだ！"]}, {"box": [363, 780, 534, 935], "vertical": true, "font_size": 32.0, "lines": ["って", "振り向くに", "決まってる", "のさ。"]}, {"box": [185, 742, 275, 965], "vertical": true, "font_size": 32.0, "lines": ["今は", "ここで止まる！"]}, {"box": [982, 1313, 1014, 1444], "vertical": true, "font_size": 32.0, "lines": ["さー"]}, {"box": [683, 1262, 718, 1394], "vertical": false, "font_size": 28.0, "lines": ["ん"]}, {"box": [495, 1372, 540, 1504], "vertical": true, "font_size": 32.0, "lines": ["がー"]}, {"box": [161, 1263, 207, 1496], "vertical": true, "font_size": 32.0, "lines": ["まだ遅いだと！？"]}], "img_path": "126.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1065, 153, 1139, 305], "vertical": true, "font_size": 32.0, "lines": ["いくか．．．？", "しかし．．"]}, {"box": [633, 135, 663, 264], "vertical": true, "font_size": 30.0, "lines": ["こ"]}, {"box": [238, 200, 280, 397], "vertical": true, "font_size": 24.0, "lines": ["急にくるかも。"]}, {"box": [1083, 723, 1203, 939], "vertical": true, "font_size": 32.0, "lines": ["いや、でもいっぽ", "あと一歩くらい", "いけそうな。"]}, {"box": [633, 742, 675, 872], "vertical": true, "font_size": 32.0, "lines": ["ろー"]}, {"box": [157, 733, 251, 883], "vertical": true, "font_size": 32.0, "lines": ["よし！", "いくぞ！"]}, {"box": [588, 1239, 637, 1333], "vertical": true, "font_size": 32.0, "lines": ["んだ。"]}], "img_path": "127.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [553, 1455, 677, 1614], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "弱すぎるよ", "西片。"]}, {"box": [298, 1573, 322, 1675], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．"]}], "img_path": "128.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [256, 172, 397, 337], "vertical": true, "font_size": 32.0, "lines": ["それで、", "罰ゲームは", "何？"]}, {"box": [88, 223, 125, 292], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [984, 1068, 1157, 1224], "vertical": true, "font_size": 32.0, "lines": ["別に勝負の", "つもりじゃ", "なかったん", "だけど。"]}, {"box": [590, 1016, 679, 1246], "vertical": true, "font_size": 32.0, "lines": ["勝負って", "言ってないよね。"]}, {"box": [172, 1093, 211, 1211], "vertical": true, "font_size": 32.0, "lines": ["ええ？！"]}, {"box": [1031, 1537, 1192, 1759], "vertical": true, "font_size": 32.0, "lines": ["つまりそんなん", "単純に", "オレをからかう", "ためだけに．．．"]}, {"box": [538, 1539, 571, 1684], "vertical": true, "font_size": 32.0, "lines": ["あれはね、"]}], "img_path": "129.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [977, 232, 1216, 448], "vertical": true, "font_size": 32.0, "lines": ["西片に", "触って", "ほしかった", "だけだよ。"]}, {"box": [1110, 1038, 1170, 1136], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}, {"box": [612, 1470, 643, 1662], "vertical": true, "font_size": 26.0, "lines": ["しかんいかん"]}, {"box": [150, 1468, 267, 1653], "vertical": true, "font_size": 32.0, "lines": ["どうせまた", "からかってる", "だけだ．．．"]}], "img_path": "130.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1037, 180, 1181, 391], "vertical": true, "font_size": 30.0, "lines": ["まあでも", "西片弱すぎて", "そこまで", "いかなかったね。"]}, {"box": [615, 240, 646, 407], "vertical": true, "font_size": 31.0, "lines": ["ざーんねん。"]}, {"box": [525, 375, 549, 444], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．"]}, {"box": [131, 84, 594, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [1125, 736, 1171, 973], "vertical": true, "font_size": 32.0, "lines": ["言っとくけど、"]}, {"box": [217, 762, 317, 948], "vertical": true, "font_size": 32.0, "lines": ["触るくらい", "平気だよ。"]}, {"box": [1078, 1235, 1186, 1499], "vertical": true, "font_size": 31.0, "lines": ["オレがテレて", "触れないと", "思ってただろうけど、"]}, {"box": [751, 1205, 875, 1355], "vertical": true, "font_size": 32.0, "lines": ["全然", "そんなこと", "ないから。"]}, {"box": [450, 1246, 492, 1443], "vertical": true, "font_size": 31.0, "lines": ["もう顔赤いよ。"]}, {"box": [219, 1294, 261, 1511], "vertical": true, "font_size": 32.0, "lines": ["赤くないから！"]}, {"box": [605, 1546, 680, 1744], "vertical": true, "font_size": 32.0, "lines": ["あはは", "ほんとかなー。"]}], "img_path": "131.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [695, 232, 741, 349], "vertical": true, "font_size": 32.0, "lines": ["あはは"]}], "img_path": "132.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [380, 945, 420, 1046], "vertical": true, "font_size": 32.0, "lines": ["ほっ．．．"]}, {"box": [305, 1380, 380, 1567], "vertical": true, "font_size": 32.0, "lines": ["ほら．．．！", "触れただろ！"]}], "img_path": "133.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1128, 1064, 1175, 1299], "vertical": true, "font_size": 32.0, "lines": ["ホントだね。"]}], "img_path": "134.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [496, 187, 579, 352], "vertical": true, "font_size": 32.0, "lines": ["あの．．．たかぎ", "高木さん？"]}, {"box": [129, 82, 592, 120], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [159, 241, 211, 318], "vertical": true, "font_size": 32.0, "lines": ["何？"]}, {"box": [1093, 973, 1132, 1074], "vertical": true, "font_size": 32.0, "lines": ["その．．．"]}, {"box": [208, 997, 240, 1119], "vertical": true, "font_size": 32.0, "lines": ["これは．．．"]}, {"box": [230, 1336, 273, 1423], "vertical": true, "font_size": 32.0, "lines": ["な！"]}, {"box": [1040, 1357, 1212, 1551], "vertical": true, "font_size": 32.0, "lines": ["一瞬じゃ", "ホントに", "テレてないか", "わかんないし、"]}, {"box": [628, 1351, 756, 1611], "vertical": true, "font_size": 32.0, "lines": ["分かれ道まで", "こうやって", "おこうかなーって。"]}], "img_path": "135.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1209, 131, 1259, 271], "vertical": true, "font_size": 32.0, "lines": ["ダメ？"]}, {"box": [602, 66, 634, 173], "vertical": true, "font_size": 32.0, "lines": ["．．．．．．"]}, {"box": [155, 547, 188, 699], "vertical": true, "font_size": 32.0, "lines": ["いいけど．．．"]}, {"box": [917, 1380, 1078, 1537], "vertical": true, "font_size": 32.0, "lines": ["ちょっと", "回り道", "したい気分", "だなー。"]}, {"box": [275, 1395, 401, 1583], "vertical": true, "font_size": 32.0, "lines": ["ま．．．", "まっすぐ", "帰ろうよ．．．！"]}], "