{"version": "0.2.0-beta.6", "title": "Karakai Jouzu no Takagi-san", "title_uuid": "8b310d10-25a6-4fdb-aaef-cacc33c51c4b", "volume": "Karakai-Jouzu-Takagi-san-16", "volume_uuid": "4e955abd-1926-4d8a-908f-4c3fb34078d2", "pages": [{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [30, 26, 144, 963], "vertical": true, "font_size": 32.0, "lines": ["からかい上手の高木さん"]}, {"box": [52, 971, 118, 1273], "vertical": true, "font_size": 32.0, "lines": ["山本景一朗"]}, {"box": [49, 1842, 332, 1871], "vertical": false, "font_size": 18.0, "lines": ["ＳＨＯＮＥＮＳＵＮＤ", "ＣＯＮＩＣＳＳＰＥＣＩＡＩ"]}], "img_path": "001.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "002.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [108, 1762, 1083, 1813], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さんの山本景一朗"]}], "img_path": "003.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1063, 845, 1243, 871], "vertical": false, "font_size": 26.0, "lines": ["ｏれｔｃれｔＳ"]}, {"box": [1153, 1121, 1187, 1321], "vertical": true, "font_size": 30.0, "lines": ["調理実習「２、"]}, {"box": [929, 1107, 965, 1313], "vertical": true, "font_size": 32.0, "lines": ["ウソとホントで"]}, {"box": [703, 1121, 739, 1308], "vertical": true, "font_size": 32.0, "lines": ["移動教室、お"]}, {"box": [481, 1123, 517, 1303], "vertical": true, "font_size": 32.0, "lines": ["視力勝負って"]}, {"box": [255, 1136, 296, 1235], "vertical": true, "font_size": 32.0, "lines": ["校舎裏"]}, {"box": [1156, 1528, 1187, 1648], "vertical": true, "font_size": 26.0, "lines": ["交換日記"]}, {"box": [930, 1545, 965, 1631], "vertical": true, "font_size": 32.0, "lines": ["チョコ"]}, {"box": [705, 1558, 740, 1622], "vertical": true, "font_size": 32.0, "lines": ["微熱"]}, {"box": [481, 1545, 518, 1635], "vertical": true, "font_size": 32.0, "lines": ["卒業式"]}], "img_path": "004.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [93, 30, 283, 553], "vertical": true, "font_size": 32.0, "lines": ["調理実習"]}], "img_path": "005.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [907, 95, 973, 260], "vertical": true, "font_size": 31.0, "lines": ["じゃあ", "やりますかー。"]}, {"box": [1071, 1095, 1184, 1294], "vertical": true, "font_size": 32.0, "lines": ["料理か．．．死ん", "全然したコト", "ないんだよな．．．"]}, {"box": [577, 1102, 663, 1265], "vertical": true, "font_size": 32.0, "lines": ["どう？私の", "エプロン姿。"]}, {"box": [185, 1342, 226, 1517], "vertical": true, "font_size": 32.0, "lines": ["新妻っぽい？"]}, {"box": [1155, 1608, 1196, 1719], "vertical": true, "font_size": 32.0, "lines": ["不安だ．．．"]}, {"box": [725, 1620, 795, 1726], "vertical": true, "font_size": 32.0, "lines": ["ねぇねぇ", "中井君。"]}], "img_path": "006.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1140, 153, 1185, 238], "vertical": true, "font_size": 32.0, "lines": ["あぁ、"]}, {"box": [609, 232, 699, 360], "vertical": true, "font_size": 32.0, "lines": ["お母さん", "ぽいな。"]}, {"box": [93, 134, 132, 286], "vertical": true, "font_size": 32.0, "lines": ["おかあ．．．"]}, {"box": [1055, 682, 1183, 903], "vertical": true, "font_size": 32.0, "lines": ["私、メインの", "ブリの照り焼き", "します！！"]}, {"box": [525, 705, 603, 885], "vertical": true, "font_size": 29.0, "lines": ["じゃあ、私は", "味噌汁かなー。"]}, {"box": [245, 686, 354, 841], "vertical": true, "font_size": 32.0, "lines": ["じゃあ、", "オレらは", "サラダだな。"]}, {"box": [1030, 1269, 1183, 1520], "vertical": true, "font_size": 28.0, "lines": ["不安だけど．．．", "高木さんに呆れられ", "ないようにちゃんと", "作らなければ．．．"]}, {"box": [433, 1310, 468, 1434], "vertical": true, "font_size": 32.0, "lines": ["ハァー"]}], "img_path": "007.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1185, 105, 1265, 301], "vertical": true, "font_size": 32.0, "lines": ["またあんた達と", "同じ班か。"]}, {"box": [601, 90, 669, 243], "vertical": true, "font_size": 30.0, "lines": ["イエーイ", "がんばろー。"]}, {"box": [309, 84, 466, 294], "vertical": true, "font_size": 32.0, "lines": ["せっかく男子に", "いいとこ見せる", "チャンスだと", "思ったのになぁ。"]}, {"box": [1119, 838, 1187, 1048], "vertical": true, "font_size": 29.0, "lines": ["じゃあ、男子役", "やってやるやんけ。"]}, {"box": [534, 598, 566, 721], "vertical": true, "font_size": 32.0, "lines": ["いえーい。"]}, {"box": [532, 832, 641, 1055], "vertical": true, "font_size": 30.0, "lines": ["ユカリ！", "オレは野菜を洗う", "女が好きやねん。"]}, {"box": [211, 897, 245, 1005], "vertical": true, "font_size": 32.0, "lines": ["やめろ。"]}], "img_path": "008.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1115, 161, 1190, 296], "vertical": true, "font_size": 32.0, "lines": ["このブリ", "オレのな。"]}, {"box": [752, 148, 835, 393], "vertical": true, "font_size": 32.0, "lines": ["数グラムって", "そんなに大事か？"]}, {"box": [429, 174, 506, 369], "vertical": true, "font_size": 32.0, "lines": ["いいところを", "見せなければ"]}, {"box": [131, 82, 275, 120], "vertical": false, "font_size": 32.0, "lines": ["からかい"]}, {"box": [150, 163, 278, 350], "vertical": true, "font_size": 32.0, "lines": ["レシピ通り", "やれば大丈夫", "．．．なハズ。"]}, {"box": [436, 1231, 553, 1477], "vertical": true, "font_size": 32.0, "lines": ["すごいなー．．．", "めっちゃテキパキ", "動いてて．．．"]}, {"box": [54, 1245, 184, 1400], "vertical": true, "font_size": 31.0, "lines": ["料理も上手", "なんだな、", "高木さん"]}], "img_path": "009.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1215, 86, 1300, 338], "vertical": true, "font_size": 30.0, "lines": ["エプロン姿も", "サマになってるし。"]}, {"box": [365, 219, 403, 288], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [515, 892, 577, 982], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [1059, 892, 1202, 1117], "vertical": true, "font_size": 29.0, "lines": ["まずい．．", "じっと見てたの．．", "またからかわ", "れる．．．？"]}, {"box": [153, 892, 270, 1104], "vertical": true, "font_size": 31.0, "lines": ["い．．．いや、", "そんなつもりで", "見てたんじゃ．．．"]}, {"box": [1012, 1496, 1130, 1741], "vertical": true, "font_size": 32.0, "lines": ["もうちょっと", "水気とばした方が", "いいと思うよ。"]}, {"box": [316, 1531, 350, 1639], "vertical": true, "font_size": 32.0, "lines": ["レタス。"]}], "img_path": "010.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1158, 95, 1202, 161], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}, {"box": [660, 82, 697, 151], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [328, 116, 399, 271], "vertical": true, "font_size": 32.0, "lines": ["あ、うん．．．！！", "わかった。"]}, {"box": [146, 86, 185, 183], "vertical": true, "font_size": 32.0, "lines": ["あれ？"]}, {"box": [1031, 743, 1110, 866], "vertical": true, "font_size": 32.0, "lines": ["．．．．．", "なんだ？"]}, {"box": [575, 701, 725, 830], "vertical": true, "font_size": 32.0, "lines": ["ちょっと", "中井君、", "切り方", "ヤバイよ。"]}, {"box": [223, 743, 252, 867], "vertical": true, "font_size": 26.0, "lines": ["そーか？"]}, {"box": [163, 1312, 215, 1402], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [58, 1346, 95, 1413], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}], "img_path": "011.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1194, 103, 1280, 271], "vertical": true, "font_size": 32.0, "lines": ["これ、味見", "してみてよ。"]}, {"box": [517, 144, 645, 367], "vertical": true, "font_size": 32.0, "lines": ["それ今、", "高木さんが味見", "した皿．．．！！"]}, {"box": [183, 346, 268, 603], "vertical": true, "font_size": 29.0, "lines": ["間接キスとかで", "からかうつもりか。"]}, {"box": [568, 849, 675, 870], "vertical": false, "font_size": 21.0, "lines": ["いや、やっぱりはいいけどねー"]}, {"box": [1121, 1340, 1267, 1591], "vertical": true, "font_size": 30.0, "lines": ["く．．．ここで", "とまどってたら：", "よけいにからかわれ", "そうだ。"]}, {"box": [842, 1391, 879, 1498], "vertical": true, "font_size": 32.0, "lines": ["えぇい。"]}], "img_path": "012.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1172, 87, 1202, 183], "vertical": true, "font_size": 30.0, "lines": ["どう？"]}, {"box": [701, 84, 815, 226], "vertical": true, "font_size": 32.0, "lines": ["い．．．", "いいんじゃ", "ないかな．．．"]}, {"box": [294, 120, 369, 247], "vertical": true, "font_size": 32.0, "lines": ["そっか、", "ありがと。"]}, {"box": [1068, 658, 1108, 759], "vertical": true, "font_size": 32.0, "lines": ["あれ！？"]}, {"box": [851, 654, 965, 866], "vertical": true, "font_size": 32.0, "lines": ["今度こそ", "からかわれると", "思ったのに．．．"]}, {"box": [1050, 1222, 1104, 1316], "vertical": true, "font_size": 32.0, "lines": ["では、"]}, {"box": [183, 1410, 263, 1535], "vertical": true, "font_size": 32.0, "lines": ["いただき", "まーす。"]}], "img_path": "013.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1244, 108, 1278, 216], "vertical": true, "font_size": 32.0, "lines": ["からっ。"]}, {"box": [633, 78, 744, 268], "vertical": true, "font_size": 31.0, "lines": ["めっちゃ", "塩からいやんけ", "この味噌汁！！"]}, {"box": [151, 131, 238, 318], "vertical": true, "font_size": 32.0, "lines": ["舌がビリビリ", "するやんけ！！"]}, {"box": [1044, 731, 1198, 982], "vertical": true, "font_size": 31.0, "lines": ["自信満々に", "味噌汁作らせろって", "言った結果が", "これなんかユカリ。"]}, {"box": [815, 736, 847, 877], "vertical": true, "font_size": 32.0, "lines": ["アカンで！"]}, {"box": [586, 729, 626, 856], "vertical": true, "font_size": 32.0, "lines": ["ゴメン．．．"]}, {"box": [163, 755, 245, 943], "vertical": true, "font_size": 32.0, "lines": ["男子いなくて", "よかった．．．"]}, {"box": [1104, 1336, 1150, 1477], "vertical": true, "font_size": 32.0, "lines": ["誰だっけ。"]}], "img_path": "014.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1060, 127, 1177, 313], "vertical": true, "font_size": 30.0, "lines": ["フライパンは", "まかせろとか", "言ったのは。"]}, {"box": [688, 103, 811, 241], "vertical": true, "font_size": 32.0, "lines": ["面目ねぇ．．．"]}, {"box": [210, 84, 241, 221], "vertical": true, "font_size": 31.0, "lines": ["まったく。"]}, {"box": [1115, 628, 1194, 843], "vertical": true, "font_size": 32.0, "lines": ["ま、いいけどね", "味はいいし。"]}, {"box": [823, 684, 867, 791], "vertical": true, "font_size": 32.0, "lines": ["許すわ。"]}, {"box": [559, 672, 722, 755], "vertical": false, "font_size": 32.0, "lines": ["まー北条さんがいいならいいけど．．．"]}, {"box": [457, 641, 517, 731], "vertical": true, "font_size": 32.0, "lines": ["北条。"]}, {"box": [151, 641, 240, 836], "vertical": true, "font_size": 32.0, "lines": ["私も味噌汁ー", "自信ないし．．．"]}, {"box": [969, 1177, 1181, 1516], "vertical": true, "font_size": 32.0, "lines": ["こちら、素材を", "楽しんでいただける", "ようにオリーブオイルと", "塩のみで味つけを", "しております。"]}, {"box": [358, 1200, 390, 1413], "vertical": true, "font_size": 32.0, "lines": ["サラダ油だろ！！"]}, {"box": [153, 1226, 279, 1445], "vertical": true, "font_size": 32.0, "lines": ["でけー魚", "選んでんだから", "真面目にやれ！！"]}], "img_path": "015.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [929, 11, 1196, 530], "vertical": false, "font_size": 32.0, "lines": ["ギャー", "わ！"]}, {"box": [283, 181, 411, 339], "vertical": true, "font_size": 32.0, "lines": ["他のところ", "失敗多そう", "だなぁ．．．"]}, {"box": [690, 894, 807, 1139], "vertical": true, "font_size": 31.0, "lines": ["オレのサラダ", "うまくいってたら", "いいけど．．．"]}, {"box": [611, 1468, 692, 1636], "vertical": true, "font_size": 32.0, "lines": ["サラダ", "おいしいね。"]}], "img_path": "016.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1168, 88, 1199, 273], "vertical": true, "font_size": 28.0, "lines": ["よかったぁ．．．"]}, {"box": [688, 90, 718, 267], "vertical": true, "font_size": 26.0, "lines": ["よかったなぁ。"]}, {"box": [615, 65, 657, 331], "vertical": true, "font_size": 32.0, "lines": ["オレ野菜切だ"]}, {"box": [485, 82, 558, 298], "vertical": true, "font_size": 32.0, "lines": ["しかし、どれも", "うまいけど、"]}, {"box": [78, 106, 162, 324], "vertical": true, "font_size": 32.0, "lines": ["この照り焼きは", "めちゃうめーな。"]}, {"box": [1097, 731, 1131, 852], "vertical": true, "font_size": 32.0, "lines": ["ホント！？"]}, {"box": [472, 712, 515, 800], "vertical": true, "font_size": 32.0, "lines": ["あぁ。"]}, {"box": [343, 684, 393, 785], "vertical": true, "font_size": 32.0, "lines": ["へへ．．．"]}, {"box": [153, 697, 183, 819], "vertical": true, "font_size": 27.0, "lines": ["じゃあ．．．"]}, {"box": [1038, 1196, 1168, 1411], "vertical": true, "font_size": 32.0, "lines": ["毎日でも", "作ってあげても", "いいんだよ？"]}, {"box": [322, 1185, 451, 1299], "vertical": true, "font_size": 32.0, "lines": ["いやー、", "それは", "いいわ。"]}, {"box": [176, 1209, 215, 1306], "vertical": true, "font_size": 32.0, "lines": ["えぇ？！"]}], "img_path": "017.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1168, 101, 1296, 301], "vertical": true, "font_size": 32.0, "lines": ["真野なら", "他の料理も", "うまそうだし、"]}, {"box": [671, 136, 755, 368], "vertical": true, "font_size": 32.0, "lines": ["色んなの", "食べてみたいよ。"]}, {"box": [1104, 778, 1184, 1001], "vertical": true, "font_size": 30.0, "lines": ["照り焼きちょっと", "あげるよぉ。"]}, {"box": [693, 778, 768, 934], "vertical": true, "font_size": 32.0, "lines": ["お、", "サンキュー。"]}, {"box": [295, 816, 332, 984], "vertical": true, "font_size": 26.0, "lines": ["仲いいなぁ．．．"]}, {"box": [1072, 1321, 1119, 1430], "vertical": true, "font_size": 32.0, "lines": ["ズズ．．．"]}, {"box": [489, 1299, 620, 1472], "vertical": true, "font_size": 32.0, "lines": ["高木さんの", "味噌汁", "おいしいね。"]}, {"box": [1143, 1668, 1179, 1747], "vertical": true, "font_size": 32.0, "lines": ["おお。"]}], "img_path": "018.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [378, 189, 459, 328], "vertical": true, "font_size": 32.0, "lines": ["ん、", "ありがと。"]}, {"box": [1125, 894, 1200, 1108], "vertical": true, "font_size": 32.0, "lines": ["思いすごしかも", "しれないけど、"]}, {"box": [958, 894, 1078, 1057], "vertical": true, "font_size": 32.0, "lines": ["高木さん", "体調でも", "悪いのかな。"]}, {"box": [573, 920, 714, 1151], "vertical": true, "font_size": 32.0, "lines": ["全然", "からかってこない", "ような．．．"]}, {"box": [686, 1391, 729, 1466], "vertical": true, "font_size": 32.0, "lines": ["な！！"]}, {"box": [504, 1350, 540, 1518], "vertical": true, "font_size": 32.0, "lines": ["してないし。"]}, {"box": [155, 901, 185, 1056], "vertical": true, "font_size": 26.0, "lines": ["よかった．．．"]}, {"box": [153, 1353, 189, 1520], "vertical": true, "font_size": 32.0, "lines": ["してたよー。"]}, {"box": [1003, 1331, 1177, 1552], "vertical": true, "font_size": 32.0, "lines": ["西片が", "間接キスで", "味見してくれた", "おかげだよ。"]}], "img_path": "019.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1121, 170, 1228, 351], "vertical": true, "font_size": 32.0, "lines": ["くそ．．．", "やっぱり", "思いすごしか"]}, {"box": [1123, 1503, 1158, 1657], "vertical": true, "font_size": 32.0, "lines": ["おいしい？"]}, {"box": [926, 1511, 1052, 1668], "vertical": true, "font_size": 32.0, "lines": ["間接キスで", "味見した", "味噌汁。"]}, {"box": [436, 1548, 558, 1672], "vertical": true, "font_size": 32.0, "lines": ["だから", "してない", "って！"]}], "img_path": "020.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [371, 180, 981, 282], "vertical": false, "font_size": 32.0, "lines": ["ノとホント"]}], "img_path": "021.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1106, 883, 1183, 1070], "vertical": true, "font_size": 32.0, "lines": ["くそ．．．", "また負けた．．．"]}, {"box": [1072, 1321, 1189, 1479], "vertical": true, "font_size": 32.0, "lines": ["はー、西片", "からかうの", "楽しいなー。"]}, {"box": [673, 1375, 704, 1444], "vertical": true, "font_size": 31.0, "lines": ["ぐ．．．"]}], "img_path": "022.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1142, 230, 1175, 352], "vertical": true, "font_size": 32.0, "lines": ["べつに．．．"]}, {"box": [950, 238, 1072, 493], "vertical": true, "font_size": 32.0, "lines": ["高木さんを", "からかうのも", "ヨユーなんだけど、"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [210, 309, 327, 555], "vertical": true, "font_size": 32.0, "lines": ["かわいそうだから", "いつも手を抜いて", "あげてるのさ。"]}, {"box": [1130, 990, 1172, 1102], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [551, 995, 631, 1100], "vertical": true, "font_size": 32.0, "lines": ["ウソ", "だねー。"]}, {"box": [151, 971, 196, 1029], "vertical": true, "font_size": 32.0, "lines": ["な。"]}, {"box": [583, 1455, 615, 1605], "vertical": true, "font_size": 32.0, "lines": ["ホントだよ。"]}, {"box": [345, 1468, 420, 1622], "vertical": true, "font_size": 32.0, "lines": ["それも", "ウソだねー。"]}, {"box": [185, 1623, 225, 1676], "vertical": true, "font_size": 32.0, "lines": ["な。"]}], "img_path": "023.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1150, 102, 1193, 298], "vertical": true, "font_size": 26.0, "lines": ["西片だったら、"]}, {"box": [502, 136, 624, 354], "vertical": true, "font_size": 32.0, "lines": ["ホントかウソか", "全部見抜く", "自信あるなー。"]}, {"box": [402, 211, 431, 276], "vertical": true, "font_size": 29.0, "lines": ["ぐ．．．"]}, {"box": [1104, 924, 1188, 1124], "vertical": true, "font_size": 32.0, "lines": ["いや、", "ということは、"]}, {"box": [1158, 1363, 1202, 1434], "vertical": true, "font_size": 32.0, "lines": ["ふ．．．"]}, {"box": [827, 1363, 903, 1516], "vertical": true, "font_size": 32.0, "lines": ["いやー", "じつはさー。"]}, {"box": [200, 915, 327, 1160], "vertical": true, "font_size": 30.0, "lines": ["見抜かれなければ", "オレの勝ちと", "いうこと．．．！？"]}, {"box": [170, 1366, 313, 1605], "vertical": true, "font_size": 32.0, "lines": ["大口をたたいた", "ことを後悔しろ", "高木さん！！"]}], "img_path": "024.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [988, 125, 1160, 314], "vertical": true, "font_size": 32.0, "lines": ["昨日", "ふろ場で", "転びそうに", "なった時に．．"]}, {"box": [631, 153, 673, 240], "vertical": true, "font_size": 32.0, "lines": ["ウソ。"]}, {"box": [1140, 828, 1181, 928], "vertical": true, "font_size": 32.0, "lines": ["なぁ。"]}, {"box": [541, 817, 626, 931], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "正解だ。"]}, {"box": [181, 862, 206, 932], "vertical": true, "font_size": 25.0, "lines": ["．．．．．"]}, {"box": [971, 1365, 1204, 1616], "vertical": true, "font_size": 32.0, "lines": ["最近", "ピーマンを", "食べられるように", "なってさ。"]}, {"box": [421, 1411, 502, 1513], "vertical": true, "font_size": 32.0, "lines": ["それも", "ウソ。"]}], "img_path": "025.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1117, 176, 1149, 289], "vertical": true, "font_size": 32.0, "lines": ["じゃあ"]}, {"box": [1005, 118, 1038, 241], "vertical": true, "font_size": 32.0, "lines": ["昨日さ．．．"]}, {"box": [828, 129, 950, 266], "vertical": true, "font_size": 32.0, "lines": ["部屋を", "片づけて", "たんだよ。"]}, {"box": [193, 172, 268, 298], "vertical": true, "font_size": 32.0, "lines": ["これは", "どうだ．．．"]}, {"box": [1059, 804, 1185, 1027], "vertical": true, "font_size": 32.0, "lines": ["ホントのことも", "おりまぜていく", "作戦。"]}, {"box": [868, 830, 986, 984], "vertical": true, "font_size": 32.0, "lines": ["これでも", "見抜けるか", "高木さん"]}, {"box": [178, 885, 221, 993], "vertical": true, "font_size": 32.0, "lines": ["ホント。"]}, {"box": [1158, 1353, 1196, 1468], "vertical": true, "font_size": 32.0, "lines": ["でしょ。"]}], "img_path": "026.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1102, 121, 1190, 249], "vertical": true, "font_size": 32.0, "lines": ["庭の花が", "咲いた！！"]}, {"box": [881, 142, 922, 226], "vertical": true, "font_size": 32.0, "lines": ["ウソ。"]}, {"box": [684, 91, 774, 208], "vertical": true, "font_size": 32.0, "lines": ["お腹", "すいた。"]}, {"box": [448, 309, 481, 414], "vertical": true, "font_size": 32.0, "lines": ["ホント。"]}, {"box": [303, 106, 393, 232], "vertical": true, "font_size": 32.0, "lines": ["昨日勉強", "した！"]}, {"box": [56, 99, 91, 180], "vertical": true, "font_size": 32.0, "lines": ["ウソ。"]}, {"box": [700, 624, 730, 722], "vertical": true, "font_size": 30.0, "lines": ["～～～〜〜"]}, {"box": [609, 699, 637, 763], "vertical": true, "font_size": 28.0, "lines": ["ウソ。"]}, {"box": [474, 657, 535, 750], "vertical": true, "font_size": 32.0, "lines": ["．．．～～～"]}, {"box": [410, 813, 444, 898], "vertical": true, "font_size": 32.0, "lines": ["ホント。"]}, {"box": [214, 626, 277, 748], "vertical": true, "font_size": 32.0, "lines": ["～～～．．．～～"]}, {"box": [110, 759, 151, 836], "vertical": true, "font_size": 32.0, "lines": ["ウソ。"]}, {"box": [1062, 1245, 1108, 1417], "vertical": true, "font_size": 32.0, "lines": ["なんで！？"]}, {"box": [288, 1291, 486, 1872], "vertical": true, "font_size": 32.0, "lines": ["ほとんど"]}, {"box": [183, 1350, 277, 1534], "vertical": true, "font_size": 32.0, "lines": ["なんで", "わかるの！？"]}], "img_path": "027.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1008, 84, 1086, 295], "vertical": true, "font_size": 32.0, "lines": ["西片、ホントに", "わかりやすいね。"]}, {"box": [1085, 311, 1128, 450], "vertical": true, "font_size": 32.0, "lines": ["あはは"]}, {"box": [819, 122, 843, 246], "vertical": true, "font_size": 21.0, "lines": ["ぐぅぅ．．．"]}, {"box": [661, 60, 730, 310], "vertical": true, "font_size": 26.0, "lines": ["いや、オレばっかり", "じゃなくてさ！！"]}, {"box": [309, 78, 386, 246], "vertical": true, "font_size": 28.0, "lines": ["高木さんも", "やってみてよ。"]}, {"box": [195, 326, 246, 431], "vertical": true, "font_size": 32.0, "lines": ["私も？"]}, {"box": [1054, 889, 1101, 969], "vertical": true, "font_size": 32.0, "lines": ["私ね、"]}, {"box": [1027, 871, 1115, 984], "vertical": false, "font_size": 32.0, "lines": ["私ね、"]}, {"box": [663, 562, 744, 690], "vertical": true, "font_size": 32.0, "lines": ["んー", "じゃあ．．．"]}, {"box": [390, 856, 493, 1038], "vertical": true, "font_size": 32.0, "lines": ["西片と", "会えるから、"]}, {"box": [243, 913, 328, 1113], "vertical": true, "font_size": 32.0, "lines": ["学校ある日が", "好きだよ。"]}], "img_path": "028.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1023, 202, 1097, 373], "vertical": true, "font_size": 32.0, "lines": ["わ．．．", "わかんない．．"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [262, 230, 343, 369], "vertical": true, "font_size": 32.0, "lines": ["ふーん", "そっかー。"]}, {"box": [1154, 669, 1183, 775], "vertical": true, "font_size": 29.0, "lines": ["．．．くそ"]}, {"box": [631, 762, 716, 977], "vertical": true, "font_size": 29.0, "lines": ["答えにくすぎる", "質問を．．．"]}, {"box": [144, 663, 217, 847], "vertical": true, "font_size": 30.0, "lines": ["ずるいぞ", "高木さん．．．！！"]}, {"box": [136, 1352, 179, 1485], "vertical": true, "font_size": 27.0, "lines": ["西片はね。"]}], "img_path": "029.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1207, 116, 1298, 283], "vertical": true, "font_size": 32.0, "lines": ["西片は", "ウソつく時、"]}, {"box": [712, 140, 799, 478], "vertical": true, "font_size": 32.0, "lines": ["目がどこか向いてるから", "わかりやすいんだよ。"]}, {"box": [576, 193, 604, 239], "vertical": true, "font_size": 28.0, "lines": ["え。"]}, {"box": [151, 163, 268, 423], "vertical": true, "font_size": 32.0, "lines": ["あと、うつむいたり", "見上げてたり", "するね。"]}, {"box": [1115, 832, 1205, 998], "vertical": true, "font_size": 32.0, "lines": ["声に自信", "なかったり、"]}, {"box": [639, 858, 727, 997], "vertical": true, "font_size": 32.0, "lines": ["棒読み", "だったり。"]}, {"box": [157, 853, 239, 1117], "vertical": true, "font_size": 32.0, "lines": ["そ．．．そんなに", "わかりやすいの！？"]}, {"box": [1104, 1348, 1138, 1576], "vertical": true, "font_size": 32.0, "lines": ["そうだったのか。"]}, {"box": [363, 1363, 487, 1580], "vertical": true, "font_size": 32.0, "lines": ["自分じゃ", "わかんなかった", "けど．．．"]}, {"box": [217, 1453, 294, 1606], "vertical": true, "font_size": 32.0, "lines": ["オレって", "そんなに．．．"]}], "img_path": "030.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1102, 225, 1190, 410], "vertical": true, "font_size": 32.0, "lines": ["いや．．．でも", "これは．．"]}, {"box": [129, 82, 596, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい", "１上手の高ホさんの"]}, {"box": [1025, 603, 1195, 819], "vertical": true, "font_size": 32.0, "lines": ["勝ちほこって", "調子にのって", "しまったのかな", "高木さん"]}, {"box": [378, 626, 538, 882], "vertical": true, "font_size": 32.0, "lines": ["うかつに", "情報を出して", "しまったことを", "後悔するがいいよ。"]}, {"box": [271, 620, 316, 776], "vertical": true, "font_size": 32.0, "lines": ["高木さん．．．"]}, {"box": [86, 669, 123, 738], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [1025, 1226, 1188, 1383], "vertical": true, "font_size": 32.0, "lines": ["つまり．．．", "オレがその", "クセを利用", "すれば、"]}, {"box": [547, 1278, 705, 1492], "vertical": true, "font_size": 31.0, "lines": ["ホントか", "ウソかは", "わからないって", "ことだろう。"]}, {"box": [686, 1651, 725, 1762], "vertical": true, "font_size": 32.0, "lines": ["あのさ、"]}, {"box": [594, 1717, 648, 1811], "vertical": true, "font_size": 32.0, "lines": ["オレ、"]}], "img_path": "031.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [697, 148, 828, 333], "vertical": true, "font_size": 32.0, "lines": ["高木さんと歩けこう", "登下校するの", "楽しいよ。"]}, {"box": [1154, 1305, 1183, 1460], "vertical": true, "font_size": 26.0, "lines": ["どうだ．．．！！"]}, {"box": [763, 1335, 830, 1503], "vertical": true, "font_size": 29.0, "lines": ["ホントの", "ことだけど．．"]}, {"box": [153, 1288, 271, 1502], "vertical": true, "font_size": 32.0, "lines": ["つまり", "ウソっぽく", "見えるだろう！！"]}, {"box": [541, 1350, 695, 1546], "vertical": true, "font_size": 31.0, "lines": ["言うのが", "恥ずかしいからも", "目を背けて", "しまった．．．"]}], "img_path": "032.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1016, 151, 1202, 378], "vertical": true, "font_size": 31.0, "lines": ["しかもさっき", "高木さんに", "やられたのと同じ", "ことをやり返せる", "という一石二鳥。"]}, {"box": [158, 255, 303, 458], "vertical": true, "font_size": 32.0, "lines": ["さらに", "この作戦は", "一段がまえ。"]}, {"box": [1055, 809, 1186, 1053], "vertical": true, "font_size": 32.0, "lines": ["高木さんが", "「ウソ」と答えれば", "オレの勝ちだし、"]}, {"box": [155, 802, 324, 855], "vertical": false, "font_size": 32.0, "lines": ["ウソでした"]}, {"box": [1007, 1126, 1048, 1233], "vertical": true, "font_size": 32.0, "lines": ["ホント"]}, {"box": [474, 834, 644, 1111], "vertical": true, "font_size": 32.0, "lines": ["「ホント」と答えても", "ウソをつく時の", "クセを消して", "きりぬけてやる。"]}, {"box": [1065, 1368, 1185, 1552], "vertical": true, "font_size": 32.0, "lines": ["どっちに", "してもオレの", "勝ちだ。"]}, {"box": [511, 1509, 588, 1650], "vertical": true, "font_size": 32.0, "lines": ["どうだ", "高木さん。"]}], "img_path": "033.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [780, 114, 827, 254], "vertical": true, "font_size": 32.0, "lines": ["私もだよ。"]}, {"box": [654, 1081, 797, 1282], "vertical": true, "font_size": 32.0, "lines": ["西片と", "登下校するの", "楽しいよ。"]}], "img_path": "034.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1091, 219, 1172, 318], "vertical": true, "font_size": 32.0, "lines": ["そ．．．", "そう．．．"]}, {"box": [560, 219, 601, 301], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}, {"box": [131, 84, 594, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [1115, 1254, 1200, 1353], "vertical": true, "font_size": 32.0, "lines": ["って．．．", "あれ？"]}, {"box": [538, 1256, 616, 1395], "vertical": true, "font_size": 32.0, "lines": ["いやいや、", "高木さん。"]}, {"box": [196, 1353, 234, 1421], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}], "img_path": "035.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [740, 112, 778, 283], "vertical": true, "font_size": 32.0, "lines": ["どしたの？"]}, {"box": [575, 123, 616, 221], "vertical": true, "font_size": 32.0, "lines": ["いや．．．"]}, {"box": [161, 712, 200, 813], "vertical": true, "font_size": 32.0, "lines": ["その．．．"]}, {"box": [1072, 1558, 1145, 1682], "vertical": true, "font_size": 32.0, "lines": ["なんでも", "ないよ．．"]}, {"box": [626, 1567, 710, 1681], "vertical": true, "font_size": 32.0, "lines": ["あ、", "ウソだ。"]}, {"box": [241, 1586, 281, 1685], "vertical": true, "font_size": 32.0, "lines": ["なっ！！"]}], "img_path": "036.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [178, 1606, 635, 1785], "vertical": false, "font_size": 32.0, "lines": ["どうきょう", "移動教室"]}], "img_path": "037.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [575, 204, 665, 390], "vertical": true, "font_size": 32.0, "lines": ["じゃあ残るは", "連絡事項か。"]}, {"box": [168, 253, 204, 362], "vertical": true, "font_size": 32.0, "lines": ["えーと。"]}, {"box": [1012, 806, 1052, 916], "vertical": true, "font_size": 32.0, "lines": ["ふふふ。"]}, {"box": [763, 796, 796, 1069], "vertical": true, "font_size": 32.0, "lines": ["いいタイミングだ！！"]}, {"box": [166, 843, 202, 1061], "vertical": true, "font_size": 32.0, "lines": ["しかけるか！！"]}, {"box": [631, 1327, 762, 1502], "vertical": true, "font_size": 32.0, "lines": ["高木さん、", "勝負", "しないかい。"]}], "img_path": "038.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1166, 186, 1194, 310], "vertical": true, "font_size": 26.0, "lines": ["どんな？"]}, {"box": [798, 165, 888, 444], "vertical": true, "font_size": 32.0, "lines": ["このあとの一限目の", "美術の移動教室、"]}, {"box": [95, 249, 229, 406], "vertical": true, "font_size": 32.0, "lines": ["先に教室に", "着いた方の", "勝ち。"]}, {"box": [932, 875, 1072, 1010], "vertical": true, "font_size": 32.0, "lines": ["廊下を", "走るのは", "ＮＧ。"]}, {"box": [431, 879, 517, 1008], "vertical": true, "font_size": 32.0, "lines": ["ルートは", "自由。"]}, {"box": [1145, 1286, 1193, 1395], "vertical": true, "font_size": 32.0, "lines": ["西片ァ。"]}, {"box": [787, 1256, 862, 1438], "vertical": true, "font_size": 32.0, "lines": ["ちゃんと", "聞いてるか！！"]}, {"box": [603, 1280, 690, 1365], "vertical": true, "font_size": 32.0, "lines": ["は．．．", "はい。"]}, {"box": [301, 948, 333, 1087], "vertical": true, "font_size": 32.0, "lines": ["どうだい。"]}, {"box": [418, 1243, 450, 1357], "vertical": true, "font_size": 32.0, "lines": ["ひぇぇ．．．"]}, {"box": [80, 1231, 142, 1393], "vertical": true, "font_size": 26.0, "lines": ["うん、じゃあ", "それでいいよ。"]}], "img_path": "039.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1098, 153, 1258, 341], "vertical": true, "font_size": 32.0, "lines": ["よし、じゃあ", "ＨＲが", "終わったら", "スタートで。"]}, {"box": [888, 191, 933, 279], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}, {"box": [373, 98, 446, 308], "vertical": true, "font_size": 26.0, "lines": ["よーし、じゃあ", "こんなとこか。"]}, {"box": [995, 875, 1097, 1023], "vertical": true, "font_size": 32.0, "lines": ["ＨＲ", "終わりー。"]}, {"box": [174, 853, 253, 980], "vertical": true, "font_size": 32.0, "lines": ["よし！！", "行くぞ！！"]}, {"box": [701, 1456, 738, 1524], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [571, 1462, 598, 1565], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．？"]}], "img_path": "040.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1053, 112, 1208, 309], "vertical": true, "font_size": 31.0, "lines": ["逆方向に行った", "オレの作戦に", "気づけるかな", "高木さん．．．！！"]}, {"box": [603, 180, 637, 286], "vertical": true, "font_size": 32.0, "lines": ["フフフ。"]}, {"box": [408, 116, 541, 275], "vertical": true, "font_size": 32.0, "lines": ["廊下は", "走っては", "いけない．．"]}, {"box": [1065, 581, 1108, 661], "vertical": true, "font_size": 32.0, "lines": ["そう、"]}, {"box": [1153, 871, 1196, 975], "vertical": true, "font_size": 32.0, "lines": ["外なら、"]}, {"box": [183, 596, 226, 705], "vertical": true, "font_size": 32.0, "lines": ["つまり、"]}, {"box": [330, 849, 451, 1001], "vertical": true, "font_size": 32.0, "lines": ["美術室は", "別棟っ"]}, {"box": [521, 894, 606, 1029], "vertical": true, "font_size": 32.0, "lines": ["走っても", "いいのさ。"]}, {"box": [89, 1501, 260, 1753], "vertical": true, "font_size": 32.0, "lines": ["廊下を", "走れないとなると", "外を走った方が", "確実に速い！！"]}], "img_path": "041.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [991, 170, 1191, 410], "vertical": true, "font_size": 29.0, "lines": ["このことを", "思いつかないで", "あろうギリギリの", "タイミングでの", "勝負のもちかけ。"]}, {"box": [517, 165, 614, 388], "vertical": true, "font_size": 32.0, "lines": ["「廊下は歩く」の", "念押し。"]}, {"box": [1023, 637, 1112, 802], "vertical": true, "font_size": 32.0, "lines": ["何もかも", "カンペキさ。"]}, {"box": [860, 1432, 988, 1533], "vertical": true, "font_size": 32.0, "lines": ["あ、", "西片。"]}, {"box": [504, 1391, 579, 1575], "vertical": true, "font_size": 32.0, "lines": ["もうっ", "着いてたんだ。"]}, {"box": [157, 1425, 193, 1530], "vertical": true, "font_size": 32.0, "lines": ["ふふふ。"]}], "img_path": "042.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1106, 120, 1193, 275], "vertical": true, "font_size": 32.0, "lines": ["遅かったね", "高木さん。"]}, {"box": [641, 153, 696, 283], "vertical": true, "font_size": 32.0, "lines": ["勝った。"]}, {"box": [517, 633, 648, 802], "vertical": true, "font_size": 32.0, "lines": ["ついになぎ", "高木さんに", "勝ったんだ。"]}, {"box": [195, 836, 309, 928], "vertical": false, "font_size": 32.0, "lines": ["美術"]}, {"box": [999, 1031, 1170, 1248], "vertical": true, "font_size": 32.0, "lines": ["別棟の入り口に", "靴あったけど、", "もしかして外", "走ってきたの？"]}, {"box": [905, 1048, 937, 1245], "vertical": true, "font_size": 32.0, "lines": ["よくやるねー。"]}, {"box": [270, 1076, 309, 1185], "vertical": true, "font_size": 32.0, "lines": ["ふふふ、"]}, {"box": [189, 1117, 226, 1346], "vertical": true, "font_size": 32.0, "lines": ["負けおしみかな。"]}, {"box": [1121, 1612, 1205, 1721], "vertical": true, "font_size": 32.0, "lines": ["んーん、", "別に。"]}], "img_path": "043.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1215, 183, 1286, 395], "vertical": true, "font_size": 27.0, "lines": ["オレもはじめは", "そうだったよ．．"]}, {"box": [700, 174, 824, 402], "vertical": true, "font_size": 32.0, "lines": ["強がって", "負けを認めたく", "なかったものさ。"]}, {"box": [555, 161, 641, 375], "vertical": true, "font_size": 32.0, "lines": ["でも高木さんは", "負けたのさ。"]}, {"box": [146, 166, 262, 361], "vertical": true, "font_size": 30.0, "lines": ["早く受けいれて", "悔しがれば", "いいのさ"]}, {"box": [181, 568, 315, 733], "vertical": true, "font_size": 32.0, "lines": ["じゃ", "罰ゲーム", "どうする？"]}, {"box": [1154, 930, 1189, 992], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}, {"box": [727, 931, 770, 1094], "vertical": true, "font_size": 26.0, "lines": ["負けた方の、"]}, {"box": [200, 1068, 248, 1207], "vertical": true, "font_size": 32.0, "lines": ["罰ゲーム。"]}, {"box": [797, 1468, 879, 1625], "vertical": true, "font_size": 32.0, "lines": ["負けを", "受け入れ．．．"]}, {"box": [678, 1458, 750, 1640], "vertical": true, "font_size": 32.0, "lines": ["それでもなお", "このヨユー．．．"]}, {"box": [181, 1522, 215, 1678], "vertical": true, "font_size": 32.0, "lines": ["すごいな．．．"]}], "img_path": "044.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1072, 172, 1204, 418], "vertical": true, "font_size": 32.0, "lines": ["．．．罰ゲーム．．．", "そういえば考えて", "なかったな．．．"]}, {"box": [948, 384, 986, 554], "vertical": true, "font_size": 32.0, "lines": ["どうしよう。"]}, {"box": [348, 590, 440, 738], "vertical": true, "font_size": 32.0, "lines": ["キスでも", "する？"]}, {"box": [1158, 971, 1198, 1068], "vertical": true, "font_size": 32.0, "lines": ["はぁ！？"]}, {"box": [727, 973, 798, 1108], "vertical": true, "font_size": 30.0, "lines": ["あはは", "冗談だよ。"]}, {"box": [568, 954, 660, 1089], "vertical": true, "font_size": 32.0, "lines": ["西片、顔", "赤いね。"]}, {"box": [466, 1083, 519, 1198], "vertical": true, "font_size": 32.0, "lines": ["あはは"]}, {"box": [159, 954, 241, 1119], "vertical": true, "font_size": 30.0, "lines": ["は．．．走って", "きたからね。"]}, {"box": [1089, 1526, 1178, 1713], "vertical": true, "font_size": 32.0, "lines": ["くそ．．．勝者は", "オレなのに．．．"]}, {"box": [285, 1530, 401, 1713], "vertical": true, "font_size": 31.0, "lines": ["なぜオレが", "からかわれて", "いるんだ．．．"]}, {"box": [161, 1543, 191, 1723], "vertical": true, "font_size": 31.0, "lines": ["おそろしい！！"]}], "img_path": "045.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [969, 93, 1178, 339], "vertical": true, "font_size": 30.0, "lines": ["考えろ：どんな", "罰ゲームにすれば", "高木さんを", "負けた気に", "させられるんだ？"]}, {"box": [1115, 577, 1197, 823], "vertical": true, "font_size": 30.0, "lines": ["シンプルに弱点を", "教えてもらうか。"]}, {"box": [571, 573, 609, 789], "vertical": true, "font_size": 32.0, "lines": ["いや、ダメだ．．"]}, {"box": [153, 588, 263, 847], "vertical": true, "font_size": 26.0, "lines": ["はぐらかされた上に", "ヘタしたらまた", "からかわれてしまう。"]}, {"box": [1081, 1162, 1196, 1389], "vertical": true, "font_size": 32.0, "lines": ["今までしてきた", "中で一番", "恥ずかしいコト："]}, {"box": [855, 1188, 881, 1299], "vertical": true, "font_size": 26.0, "lines": ["ううむ．．．"]}, {"box": [705, 1198, 778, 1362], "vertical": true, "font_size": 30.0, "lines": ["せっかくの", "勝利なんだ。"]}, {"box": [183, 1215, 256, 1368], "vertical": true, "font_size": 30.0, "lines": ["もっとこう", "決定的な．．．"]}, {"box": [680, 1616, 724, 1815], "vertical": true, "font_size": 32.0, "lines": ["悩んでるねー。"]}], "img_path": "046.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1042, 165, 1074, 313], "vertical": true, "font_size": 32.0, "lines": ["じゃあさ、"]}, {"box": [221, 249, 314, 555], "vertical": true, "font_size": 32.0, "lines": ["好きな人の", "名前言うってのは？"]}, {"box": [577, 1042, 653, 1192], "vertical": true, "font_size": 32.0, "lines": ["いいんじゃ", "ないか？"]}, {"box": [243, 1078, 408, 1295], "vertical": true, "font_size": 32.0, "lines": ["名前を", "言うなら", "ごまかしようが", "ない上に、"]}, {"box": [153, 1061, 191, 1290], "vertical": true, "font_size": 32.0, "lines": ["弱みもにぎれる。"]}, {"box": [915, 1505, 1027, 1651], "vertical": true, "font_size": 32.0, "lines": ["ほ．．．ほんき", "本気で", "言ってる？"]}, {"box": [720, 1530, 800, 1687], "vertical": true, "font_size": 32.0, "lines": ["本気で", "言ってるよ。"]}], "img_path": "047.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1145, 235, 1175, 333], "vertical": true, "font_size": 30.0, "lines": ["どう？"]}, {"box": [570, 221, 650, 412], "vertical": true, "font_size": 32.0, "lines": ["それでけってい", "決定でいい？"]}, {"box": [453, 189, 483, 339], "vertical": true, "font_size": 27.0, "lines": ["いけど．．．"]}, {"box": [152, 176, 230, 363], "vertical": true, "font_size": 32.0, "lines": ["でも", "それ以上に：："]}, {"box": [1115, 847, 1200, 1025], "vertical": true, "font_size": 30.0, "lines": ["ん、反論ない", "みたいだし、"]}, {"box": [562, 828, 605, 952], "vertical": true, "font_size": 32.0, "lines": ["待って！！"]}, {"box": [155, 819, 198, 983], "vertical": true, "font_size": 32.0, "lines": ["それ以上に、"]}, {"box": [1070, 1370, 1147, 1496], "vertical": true, "font_size": 32.0, "lines": ["なんか．．．", "聞くの、"]}, {"box": [712, 886, 845, 1055], "vertical": true, "font_size": 32.0, "lines": ["好きな人の", "名前を言う、", "で決て．．．"]}, {"box": [232, 1393, 279, 1560], "vertical": true, "font_size": 32.0, "lines": ["恥ずかしい。"]}], "img_path": "048.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [767, 168, 889, 382], "vertical": true, "font_size": 32.0, "lines": ["あ、もしかして", "恥ずかしいの", "かなー。"]}, {"box": [129, 82, 568, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [178, 228, 226, 399], "vertical": true, "font_size": 32.0, "lines": ["ち．．．違うよ。"]}, {"box": [1001, 958, 1129, 1177], "vertical": true, "font_size": 32.0, "lines": ["人！！そう", "みんなそろそろ", "来るし．．．！！"]}, {"box": [196, 965, 279, 1166], "vertical": true, "font_size": 32.0, "lines": ["また", "あとにしよう。"]}, {"box": [995, 1389, 1205, 1578], "vertical": true, "font_size": 32.0, "lines": ["ここは時間を", "引き伸ばして", "ゆっくりと", "罰ゲームを", "考えよう．．．"]}, {"box": [616, 1395, 703, 1670], "vertical": true, "font_size": 32.0, "lines": ["うん、さすが勝者だ", "冴えている"]}, {"box": [163, 1435, 193, 1558], "vertical": true, "font_size": 26.0, "lines": ["みんな？"]}], "img_path": "049.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [742, 138, 783, 274], "vertical": true, "font_size": 32.0, "lines": ["来ないよ。"]}, {"box": [300, 157, 356, 232], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}, {"box": [1027, 971, 1204, 1218], "vertical": true, "font_size": 32.0, "lines": ["西片が私に勝負", "持ちかけてた時に", "先生が言ってたん", "だよ。"]}, {"box": [594, 982, 710, 1168], "vertical": true, "font_size": 32.0, "lines": ["今日の美術は", "視聴覚室に", "変更って。"]}, {"box": [448, 1031, 526, 1188], "vertical": true, "font_size": 32.0, "lines": ["えぇ！？", "そうなの！？"]}, {"box": [596, 1246, 671, 1509], "vertical": true, "font_size": 32.0, "lines": ["だから迎えに", "来てあげたんだよ。"]}, {"box": [887, 1614, 969, 1756], "vertical": true, "font_size": 32.0, "lines": ["え！？", "てことは。"]}, {"box": [234, 1644, 279, 1730], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}], "img_path": "050.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1029, 150, 1196, 364], "vertical": true, "font_size": 32.0, "lines": ["私はここに", "来る前に", "視聴覚室寄って", "きたから"]}, {"box": [798, 172, 846, 352], "vertical": true, "font_size": 32.0, "lines": ["西片の負け。"]}, {"box": [138, 241, 180, 487], "vertical": true, "font_size": 32.0, "lines": ["ええーー！！"]}, {"box": [878, 881, 1034, 1106], "vertical": true, "font_size": 32.0, "lines": ["さっきまで西片が", "考えてたのは", "自分の", "罰ゲームだよ。"]}, {"box": [352, 924, 395, 1078], "vertical": true, "font_size": 32.0, "lines": ["えぇー！！"]}, {"box": [999, 1411, 1082, 1642], "vertical": true, "font_size": 32.0, "lines": ["いやー", "惜しかったなー。"]}], "img_path": "051.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1042, 73, 1166, 339], "vertical": true, "font_size": 32.0, "lines": ["「好きな人の名前を", "言う」で西片が", "ＯＫしてたら、"]}, {"box": [872, 106, 945, 330], "vertical": true, "font_size": 32.0, "lines": ["西片の好きな人", "知れたのになー。"]}, {"box": [710, 255, 752, 339], "vertical": true, "font_size": 32.0, "lines": ["なっ。"]}, {"box": [616, 106, 643, 286], "vertical": true, "font_size": 28.0, "lines": ["危なかった．．．"]}, {"box": [487, 84, 555, 341], "vertical": true, "font_size": 28.0, "lines": ["まぁ好きな人とか", "よくわかんないけど。"]}, {"box": [590, 477, 635, 615], "vertical": true, "font_size": 32.0, "lines": ["ねぇ西片。"]}, {"box": [1074, 956, 1122, 1184], "vertical": true, "font_size": 32.0, "lines": ["私の好きな人は、"]}, {"box": [253, 961, 334, 1175], "vertical": true, "font_size": 32.0, "lines": ["いつでも聞いて", "いいからね。"]}, {"box": [510, 1558, 553, 1725], "vertical": true, "font_size": 32.0, "lines": ["聞けるかぁ。"]}, {"box": [185, 1595, 304, 1781], "vertical": true, "font_size": 32.0, "lines": ["罰ゲーム．．．", "何に", "しよっかなー。"]}], "img_path": "052.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [116, 320, 361, 971], "vertical": true, "font_size": 32.0, "lines": ["たかぎさん"]}, {"box": [406, 868, 466, 1134], "vertical": true, "font_size": 32.0, "lines": ["じょぅぉ"]}, {"box": [413, 838, 465, 1174], "vertical": true, "font_size": 24.0, "lines": ["．．．"]}, {"box": [352, 1627, 590, 1775], "vertical": false, "font_size": 32.0, "lines": ["力勝負"]}], "img_path": "053.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1143, 133, 1171, 257], "vertical": true, "font_size": 27.0, "lines": ["はぁー．．．"]}, {"box": [858, 123, 1031, 313], "vertical": true, "font_size": 32.0, "lines": ["まさか漫画が", "見つかって", "居残り掃除", "とは．．．"]}, {"box": [208, 131, 322, 316], "vertical": true, "font_size": 30.0, "lines": ["しかもこんな", "ゴチャゴチヤ", "したとこを．．．"]}, {"box": [1099, 1037, 1127, 1139], "vertical": true, "font_size": 28.0, "lines": ["．．．．．．．"]}, {"box": [360, 1046, 431, 1213], "vertical": true, "font_size": 32.0, "lines": ["これ．．", "なんだろう．．"]}], "img_path": "054.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1065, 142, 1192, 300], "vertical": true, "font_size": 32.0, "lines": ["あーしります", "視力検査の", "やつか。"]}, {"box": [523, 390, 650, 605], "vertical": true, "font_size": 32.0, "lines": ["古くなったから", "ここに置いてる", "のかな。"]}, {"box": [1157, 1383, 1198, 1481], "vertical": true, "font_size": 32.0, "lines": ["ふふ．．．"]}, {"box": [881, 1370, 966, 1524], "vertical": true, "font_size": 32.0, "lines": ["思いついて", "しまった。"]}, {"box": [181, 1400, 256, 1586], "vertical": true, "font_size": 32.0, "lines": ["これなら", "高木さんに！！"]}], "img_path": "055.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1127, 157, 1195, 324], "vertical": true, "font_size": 26.0, "lines": ["すぐにでも", "話したい．．．！！"]}, {"box": [888, 161, 964, 368], "vertical": true, "font_size": 30.0, "lines": ["高木さん、まだ", "帰ってないかな。"]}, {"box": [755, 108, 789, 217], "vertical": true, "font_size": 32.0, "lines": ["うわぁ。"]}, {"box": [180, 123, 226, 183], "vertical": true, "font_size": 32.0, "lines": ["わ。"]}, {"box": [1164, 894, 1198, 1103], "vertical": true, "font_size": 32.0, "lines": ["ビックリしたよ。"]}, {"box": [685, 901, 800, 1125], "vertical": true, "font_size": 29.0, "lines": ["入ろうと", "思ったらいきなり", "開いたから。"]}, {"box": [547, 909, 622, 1074], "vertical": true, "font_size": 32.0, "lines": ["こっちの", "セリフだよ。"]}, {"box": [418, 901, 500, 1029], "vertical": true, "font_size": 32.0, "lines": ["なんで", "いるの！"]}, {"box": [155, 888, 188, 1052], "vertical": true, "font_size": 32.0, "lines": ["なんでって。"]}, {"box": [1061, 1485, 1136, 1642], "vertical": true, "font_size": 32.0, "lines": ["なんでだと", "思う？"]}], "img_path": "056.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1170, 176, 1198, 251], "vertical": true, "font_size": 28.0, "lines": ["．．．"]}, {"box": [707, 168, 783, 382], "vertical": true, "font_size": 32.0, "lines": ["からかいに", "来たんでしょ．．．"]}, {"box": [605, 180, 637, 287], "vertical": true, "font_size": 32.0, "lines": ["さぁー。"]}, {"box": [129, 82, 592, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい", "１上手の高ホさんの"]}, {"box": [155, 183, 238, 339], "vertical": true, "font_size": 32.0, "lines": ["やっぱ", "そうだな．．．"]}, {"box": [1115, 733, 1183, 911], "vertical": true, "font_size": 32.0, "lines": ["でもちょうど", "よかったよ。"]}, {"box": [911, 691, 1040, 881], "vertical": true, "font_size": 32.0, "lines": ["呼びに行こう", "と思ってた", "から。"]}, {"box": [495, 706, 579, 866], "vertical": true, "font_size": 32.0, "lines": ["ん？", "そうなの？"]}, {"box": [294, 710, 427, 864], "vertical": true, "font_size": 32.0, "lines": ["告白でも", "するつもり", "かな？"]}, {"box": [181, 884, 228, 1087], "vertical": true, "font_size": 32.0, "lines": ["な．．．違うよ！！"]}, {"box": [1048, 1338, 1117, 1561], "vertical": true, "font_size": 32.0, "lines": ["視力勝負。"]}, {"box": [659, 1358, 884, 1847], "vertical": true, "font_size": 32.0, "lines": ["っか"]}], "img_path": "057.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1080, 123, 1271, 393], "vertical": true, "font_size": 32.0, "lines": ["文字を", "６回さして", "正解率の高い方が", "勝ち。"]}, {"box": [577, 101, 708, 285], "vertical": true, "font_size": 32.0, "lines": ["小さい文字が", "見える方じゃ", "なくて？"]}, {"box": [181, 123, 271, 270], "vertical": true, "font_size": 32.0, "lines": ["変な", "勝負だね。"]}, {"box": [1093, 761, 1175, 931], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "私からねー。"]}, {"box": [467, 736, 543, 958], "vertical": true, "font_size": 26.0, "lines": ["そこの線こえたら", "反則だからね。"]}, {"box": [155, 746, 225, 860], "vertical": true, "font_size": 32.0, "lines": ["わかって", "るって。"]}, {"box": [275, 941, 320, 1108], "vertical": true, "font_size": 32.0, "lines": ["ゆかなのよ"]}, {"box": [230, 982, 262, 1106], "vertical": true, "font_size": 32.0, "lines": ["あさた！"]}, {"box": [1037, 1451, 1185, 1715], "vertical": true, "font_size": 31.0, "lines": ["あ、あと", "やりはじめたら", "よけいなコトは", "しゃべらないように。"]}, {"box": [483, 1486, 597, 1741], "vertical": true, "font_size": 30.0, "lines": ["途中で「あー」とか", "「うーん」とか言うと、", "まぎらわしいし。"]}, {"box": [151, 1445, 195, 1710], "vertical": true, "font_size": 32.0, "lines": ["うん、", "いいよ。"]}], "img_path": "058.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1120, 95, 1196, 266], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "最初はこれ。"]}, {"box": [450, 148, 502, 232], "vertical": true, "font_size": 32.0, "lines": ["「あ」"]}, {"box": [956, 776, 1020, 866], "vertical": true, "font_size": 32.0, "lines": ["「な」"]}, {"box": [508, 768, 568, 856], "vertical": true, "font_size": 32.0, "lines": ["「た」"]}, {"box": [170, 785, 240, 881], "vertical": true, "font_size": 32.0, "lines": ["っかし"]}, {"box": [506, 1087, 560, 1168], "vertical": true, "font_size": 32.0, "lines": ["「の」"]}], "img_path": "059.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1078, 101, 1130, 236], "vertical": true, "font_size": 32.0, "lines": ["．．．「さ」？"]}, {"box": [480, 60, 581, 258], "vertical": true, "font_size": 32.0, "lines": ["残念！！", "「ち」でした！"]}, {"box": [163, 133, 240, 347], "vertical": true, "font_size": 32.0, "lines": ["．．．く．．．", "気付いたか．．．？"]}, {"box": [1104, 905, 1192, 1018], "vertical": true, "font_size": 32.0, "lines": ["続けてょ", "読むと、"]}, {"box": [264, 934, 381, 1178], "vertical": true, "font_size": 30.0, "lines": ["あなたの", "勝ち」になる", "このトラップに．．．"]}, {"box": [1098, 1404, 1194, 1639], "vertical": true, "font_size": 32.0, "lines": ["１つ間違いかー、", "残念。"]}, {"box": [646, 1395, 678, 1562], "vertical": true, "font_size": 32.0, "lines": ["ゆかな？"]}, {"box": [489, 1398, 574, 1524], "vertical": true, "font_size": 32.0, "lines": ["じゃあ次", "西片ね。"]}, {"box": [185, 1436, 226, 1520], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}], "img_path": "060.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1098, 198, 1185, 463], "vertical": true, "font_size": 32.0, "lines": ["ふふ．．．", "高木さんのことだ。"]}, {"box": [967, 241, 1007, 352], "vertical": true, "font_size": 32.0, "lines": ["きっと、"]}, {"box": [444, 165, 693, 472], "vertical": true, "font_size": 32.0, "lines": ["オレが口に出しにくい", "チョイスをして", "くるだろう。", "「あなたを好き」とか", "「あいしてます」とか、", "な。"]}, {"box": [129, 82, 568, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [213, 228, 335, 480], "vertical": true, "font_size": 32.0, "lines": ["でも、そんなのは", "文字変えれば", "回避できるのさ。"]}, {"box": [1087, 637, 1200, 851], "vertical": true, "font_size": 32.0, "lines": ["つまりどちらも", "文字間違いで", "引き分け！！"]}, {"box": [678, 656, 762, 868], "vertical": true, "font_size": 32.0, "lines": ["負けはないって", "ワケさ。"]}, {"box": [489, 607, 609, 855], "vertical": true, "font_size": 32.0, "lines": ["どうだい", "気付いてなければ", "オレの勝ち、"]}, {"box": [228, 637, 397, 858], "vertical": true, "font_size": 32.0, "lines": ["気付いていても", "引き分けという", "オレの完璧な", "作戦は。"]}, {"box": [993, 1381, 1042, 1470], "vertical": true, "font_size": 32.0, "lines": ["ほい。"]}, {"box": [718, 1381, 772, 1466], "vertical": true, "font_size": 32.0, "lines": ["「す」"]}, {"box": [144, 1023, 240, 1208], "vertical": true, "font_size": 32.0, "lines": ["ゆかなのよ", "くあさた．．．"]}, {"box": [187, 1447, 283, 1599], "vertical": false, "font_size": 32.0, "lines": ["き"]}], "img_path": "061.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1196, 95, 1278, 283], "vertical": true, "font_size": 32.0, "lines": ["ふん、", "やっぱりな．．．"]}, {"box": [862, 136, 899, 306], "vertical": true, "font_size": 32.0, "lines": ["「た」．．．かな。"]}, {"box": [757, 70, 786, 223], "vertical": true, "font_size": 26.0, "lines": ["ざんねーん。"]}, {"box": [466, 136, 545, 238], "vertical": true, "font_size": 32.0, "lines": ["外れ。"]}, {"box": [382, 76, 419, 262], "vertical": true, "font_size": 32.0, "lines": ["じゃあこれ。"]}, {"box": [1100, 731, 1129, 834], "vertical": true, "font_size": 29.0, "lines": ["．．．．．．．"]}, {"box": [279, 729, 361, 913], "vertical": true, "font_size": 32.0, "lines": ["いや、あの", "高木さん．．．？"]}, {"box": [1074, 1239, 1200, 1393], "vertical": true, "font_size": 32.0, "lines": ["途中で", "しゃべるの", "禁止だよ。"]}, {"box": [810, 1272, 837, 1376], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．？"]}, {"box": [570, 1205, 700, 1420], "vertical": true, "font_size": 32.0, "lines": ["同じのは", "禁止って言って", "ないしねー。"]}, {"box": [183, 943, 260, 1072], "vertical": true, "font_size": 32.0, "lines": ["それは", "さっき．．．"]}, {"box": [661, 1612, 701, 1740], "vertical": true, "font_size": 32.0, "lines": ["．．．「す」．．．"]}, {"box": [238, 1614, 270, 1738], "vertical": true, "font_size": 32.0, "lines": ["まさか．．．"]}], "img_path": "062.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1113, 91, 1190, 228], "vertical": true, "font_size": 32.0, "lines": ["まさか", "高木さん。"]}, {"box": [1052, 785, 1095, 1011], "vertical": true, "font_size": 32.0, "lines": ["ああぁー"]}, {"box": [950, 1320, 1020, 1475], "vertical": true, "font_size": 32.0, "lines": ["ま．．．", "負けました。"]}, {"box": [348, 1302, 380, 1425], "vertical": true, "font_size": 32.0, "lines": ["やったー。"]}, {"box": [181, 1320, 217, 1448], "vertical": true, "font_size": 32.0, "lines": ["ぐぅう．．．"]}], "img_path": "063.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1060, 116, 1187, 333], "vertical": true, "font_size": 32.0, "lines": ["繰り返すとは．．", "そんな手が", "あったなんて．．．"]}, {"box": [328, 112, 442, 280], "vertical": true, "font_size": 31.0, "lines": ["へんなコト", "しなきゃ", "よかったね。"]}, {"box": [140, 86, 183, 153], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}, {"box": [1072, 605, 1205, 826], "vertical": true, "font_size": 32.0, "lines": ["私、一番下の段", "見えてなかった", "からさ。"]}, {"box": [631, 620, 708, 834], "vertical": true, "font_size": 31.0, "lines": ["普通に視力勝負", "してたら、"]}, {"box": [472, 731, 545, 924], "vertical": true, "font_size": 31.0, "lines": ["西片の勝ち", "だったんだよ。"]}, {"box": [271, 660, 316, 733], "vertical": true, "font_size": 32.0, "lines": ["な！！"]}, {"box": [608, 1487, 638, 1589], "vertical": true, "font_size": 30.0, "lines": ["．．．．．．？"]}], "img_path": "064.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [951, 221, 1128, 420], "vertical": true, "font_size": 32.0, "lines": ["いや！でも", "視力なら", "勝ってるって", "コトで！"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [1050, 830, 1173, 1048], "vertical": true, "font_size": 32.0, "lines": ["でもルールだし", "負けは負け", "だよ。"]}, {"box": [508, 873, 541, 975], "vertical": true, "font_size": 32.0, "lines": ["．．．はい。"]}, {"box": [159, 845, 193, 951], "vertical": true, "font_size": 32.0, "lines": ["それに、"]}, {"box": [1008, 1335, 1151, 1565], "vertical": true, "font_size": 32.0, "lines": ["西片、", "視力がいいって", "いっても、"]}, {"box": [217, 1363, 347, 1533], "vertical": true, "font_size": 32.0, "lines": ["見えてない", "コトの方が", "多いしなぁ。"]}], "img_path": "065.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1076, 173, 1192, 352], "vertical": true, "font_size": 32.0, "lines": ["どゆこと．．．？"]}, {"box": [862, 196, 938, 374], "vertical": true, "font_size": 26.0, "lines": ["だから勝負に", "負けるんだよ。"]}, {"box": [533, 209, 562, 253], "vertical": true, "font_size": 29.0, "lines": ["？"]}, {"box": [176, 227, 205, 274], "vertical": true, "font_size": 29.0, "lines": ["？"]}, {"box": [1047, 924, 1168, 1110], "vertical": true, "font_size": 31.0, "lines": ["はぁ．．．", "とりあえず", "掃除するよ．．．"]}, {"box": [365, 924, 414, 1010], "vertical": true, "font_size": 32.0, "lines": ["うん、"]}, {"box": [268, 960, 307, 1126], "vertical": true, "font_size": 32.0, "lines": ["頑張ってね。"]}, {"box": [1029, 1468, 1198, 1661], "vertical": true, "font_size": 32.0, "lines": ["あれ．．．てっだ", "手伝いに来て", "くれたんじゃ", "ないの！？"]}, {"box": [536, 1468, 607, 1695], "vertical": true, "font_size": 29.0, "lines": ["そんなコト", "言ってないよー。"]}, {"box": [348, 1466, 459, 1633], "vertical": true, "font_size": 32.0, "lines": ["やっぱり", "からかいに", "来たんだろ．．．"]}], "img_path": "066.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [131, 84, 594, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [812, 619, 913, 834], "vertical": true, "font_size": 32.0, "lines": ["ゆかなのよ。", "くあさた．．．"]}], "img_path": "067.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [418, 322, 444, 463], "vertical": true, "font_size": 26.0, "lines": ["あさた"]}, {"box": [487, 320, 519, 420], "vertical": true, "font_size": 32.0, "lines": ["かな"]}, {"box": [178, 1466, 266, 1546], "vertical": true, "font_size": 32.0, "lines": ["え？なに", "何？"]}, {"box": [791, 1485, 834, 1558], "vertical": true, "font_size": 32.0, "lines": ["ね？"]}], "img_path": "068.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "069.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [588, 1725, 1220, 1781], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さん"]}], "img_path": "070.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "071.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1119, 195, 1322, 326], "vertical": false, "font_size": 32.0, "lines": ["音楽室"]}, {"box": [301, 119, 390, 303], "vertical": true, "font_size": 32.0, "lines": ["あーきの", "そーらはー"]}, {"box": [277, 751, 369, 941], "vertical": true, "font_size": 32.0, "lines": ["あかーく", "もえてー"]}], "img_path": "072.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [729, 103, 842, 313], "vertical": true, "font_size": 32.0, "lines": ["じゃあきって", "明後日の授業で", "男女２人ペアで、"]}, {"box": [556, 112, 661, 322], "vertical": true, "font_size": 32.0, "lines": ["歌のテスト", "するから", "そのつもりでー。"]}, {"box": [262, 84, 294, 232], "vertical": true, "font_size": 32.0, "lines": ["マジかよー。"]}, {"box": [97, 103, 138, 196], "vertical": true, "font_size": 32.0, "lines": ["げー．．．"]}, {"box": [1007, 794, 1082, 946], "vertical": true, "font_size": 29.0, "lines": ["オレ楽しみ", "だけどなー。"]}, {"box": [785, 789, 813, 952], "vertical": true, "font_size": 27.0, "lines": ["ホントかー？"]}, {"box": [230, 793, 345, 928], "vertical": true, "font_size": 32.0, "lines": ["絶対", "恥ずかしい", "よー。"]}, {"box": [692, 1368, 767, 1499], "vertical": true, "font_size": 32.0, "lines": ["あの、たかぎ", "高木さん。"]}, {"box": [360, 1365, 405, 1438], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}], "img_path": "073.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [995, 125, 1128, 350], "vertical": true, "font_size": 32.0, "lines": ["放課後、おしゃう。", "校舎裏", "来てくれない？"]}, {"box": [530, 1123, 573, 1203], "vertical": true, "font_size": 32.0, "lines": ["うん、"]}, {"box": [436, 1155, 476, 1261], "vertical": true, "font_size": 32.0, "lines": ["いいよ。"]}, {"box": [298, 1123, 331, 1258], "vertical": true, "font_size": 32.0, "lines": ["よかった、"]}, {"box": [195, 1134, 234, 1235], "vertical": true, "font_size": 32.0, "lines": ["じゃ！"]}], "img_path": "074.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1077, 153, 1186, 610], "vertical": true, "font_size": 32.0, "lines": ["ガャーか、"]}, {"box": [588, 88, 617, 228], "vertical": true, "font_size": 27.0, "lines": ["どしたの？"]}, {"box": [385, 98, 413, 171], "vertical": true, "font_size": 28.0, "lines": ["．．．．．"]}, {"box": [174, 208, 253, 348], "vertical": true, "font_size": 32.0, "lines": ["んーん、", "なんでも。"]}, {"box": [39, 465, 172, 596], "vertical": true, "font_size": 32.0, "lines": ["ＨＲだし", "教室", "戻ろー。"]}, {"box": [879, 915, 918, 1014], "vertical": true, "font_size": 32.0, "lines": ["よし．．"]}, {"box": [200, 933, 285, 1044], "vertical": true, "font_size": 32.0, "lines": ["これでほうかご", "放課後、"]}, {"box": [172, 1518, 358, 1705], "vertical": true, "font_size": 32.0, "lines": ["高木さんに", "歌の練習", "付き合って", "もらえるぞ"]}], "img_path": "075.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1097, 67, 1198, 346], "vertical": true, "font_size": 28.0, "lines": ["どうしても", "女子のパートに", "ひっぱられちゃって．．．"]}, {"box": [825, 67, 1005, 373], "vertical": true, "font_size": 28.0, "lines": ["テストまでに", "どうにかしたかったから", "高木さんにＯＫ", "もらえて本当に", "よかった．．．"]}, {"box": [626, 93, 741, 238], "vertical": true, "font_size": 29.0, "lines": ["校舎裏なら", "人も来ない", "だろうし、"]}, {"box": [161, 129, 241, 303], "vertical": true, "font_size": 32.0, "lines": ["頑張って練習", "するぞ．．．！！"]}, {"box": [1132, 813, 1161, 903], "vertical": true, "font_size": 28.0, "lines": ["あれ？"]}, {"box": [172, 552, 200, 625], "vertical": true, "font_size": 28.0, "lines": ["．．．．．"]}, {"box": [172, 766, 331, 1018], "vertical": true, "font_size": 32.0, "lines": ["そういえばオレ．．．", "歌の練習に", "付き合ってって", "言ったっけ．．．"]}, {"box": [1136, 1299, 1256, 1501], "vertical": true, "font_size": 32.0, "lines": ["放課後、", "校舎裏", "来てくれない？"]}, {"box": [468, 1331, 557, 1590], "vertical": true, "font_size": 32.0, "lines": ["あぁあ！！", "言ってない．．．！！"]}, {"box": [225, 1419, 255, 1573], "vertical": true, "font_size": 26.0, "lines": ["てことは．．．"]}], "img_path": "076.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [958, 196, 1115, 429], "vertical": true, "font_size": 32.0, "lines": ["高木さんに", "告白するって", "思われてる？"]}, {"box": [675, 912, 712, 976], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [808, 892, 856, 1125], "vertical": true, "font_size": 32.0, "lines": ["あの．．．高木さん。"]}, {"box": [939, 1466, 1117, 1624], "vertical": true, "font_size": 32.0, "lines": ["いや．．．", "呼び出す", "用件を伝えて", "なかったなと", "思って．．．"]}, {"box": [253, 1477, 298, 1563], "vertical": true, "font_size": 32.0, "lines": ["あぁ、"]}, {"box": [174, 1548, 210, 1687], "vertical": true, "font_size": 32.0, "lines": ["放課後の。"]}], "img_path": "077.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1226, 129, 1271, 296], "vertical": true, "font_size": 32.0, "lines": ["大丈夫だよ。"]}, {"box": [716, 169, 748, 397], "vertical": true, "font_size": 26.0, "lines": ["わかってるから。"]}, {"box": [543, 116, 621, 361], "vertical": true, "font_size": 32.0, "lines": ["なんだ、よかった", "わかってたのか！！"]}, {"box": [1093, 1050, 1183, 1160], "vertical": true, "font_size": 32.0, "lines": ["いや！", "それ！！"]}, {"box": [1097, 1055, 1177, 1155], "vertical": true, "font_size": 32.0, "lines": ["いや！それ！！"]}, {"box": [881, 1021, 1023, 1263], "vertical": true, "font_size": 32.0, "lines": ["オレが告白", "するって意味で", "言ってない！？"]}, {"box": [189, 1061, 326, 1215], "vertical": true, "font_size": 32.0, "lines": ["わかって", "ないよ", "高木さん。"]}, {"box": [1097, 1501, 1130, 1599], "vertical": true, "font_size": 32.0, "lines": ["あの．．．"]}, {"box": [200, 1500, 337, 1687], "vertical": true, "font_size": 32.0, "lines": ["あ、ＨＡＲ", "終わったね。"]}], "img_path": "078.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1087, 105, 1176, 274], "vertical": true, "font_size": 32.0, "lines": ["じゃ、先に", "行っとくね。"]}, {"box": [1044, 1209, 1121, 1336], "vertical": true, "font_size": 32.0, "lines": ["どうする", "これ．．"]}], "img_path": "079.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1175, 142, 1260, 262], "vertical": true, "font_size": 32.0, "lines": ["あ！！", "そうだ。"]}, {"box": [997, 88, 1035, 270], "vertical": true, "font_size": 32.0, "lines": ["やぁ高木さん。"]}, {"box": [812, 101, 926, 230], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "歌の練習", "しようか。"]}, {"box": [560, 161, 648, 316], "vertical": true, "font_size": 32.0, "lines": ["って感じで", "軽ーく！！"]}, {"box": [367, 228, 485, 474], "vertical": true, "font_size": 32.0, "lines": ["告白とかそういう", "雰囲気をまるで", "感じさせずに、"]}, {"box": [249, 258, 285, 337], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}, {"box": [165, 637, 241, 823], "vertical": true, "font_size": 32.0, "lines": ["ナイス", "アイディア！！"]}, {"box": [1055, 988, 1183, 1181], "vertical": true, "font_size": 32.0, "lines": ["ドタン場で", "思いつくとは", "さすがオレだ。"]}, {"box": [1029, 1584, 1113, 1725], "vertical": true, "font_size": 32.0, "lines": ["やあ", "高木さん。"]}, {"box": [241, 1599, 320, 1756], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "さっそく．．．"]}], "img_path": "080.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1042, 228, 1095, 375], "vertical": true, "font_size": 32.0, "lines": ["あ、西片。"]}, {"box": [1127, 1047, 1175, 1256], "vertical": true, "font_size": 32.0, "lines": ["待ってたよ。"]}], "img_path": "081.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1183, 146, 1263, 245], "vertical": true, "font_size": 32.0, "lines": ["なんだ", "コレ．．．"]}, {"box": [615, 144, 743, 393], "vertical": true, "font_size": 32.0, "lines": ["告白じゃないって", "わかってるのに．．．", "意識しちゃって．．．"]}, {"box": [277, 166, 309, 425], "vertical": true, "font_size": 29.0, "lines": ["違うんだ、高木さん。"]}, {"box": [148, 241, 215, 408], "vertical": true, "font_size": 29.0, "lines": ["歌の練習を", "するために："]}, {"box": [1097, 847, 1170, 1044], "vertical": true, "font_size": 32.0, "lines": ["さらっと", "言うんだホラ。"]}, {"box": [885, 858, 1005, 1014], "vertical": true, "font_size": 32.0, "lines": ["変な間を", "あけると", "変になる．．．"]}, {"box": [358, 862, 436, 990], "vertical": true, "font_size": 32.0, "lines": ["じゃあ．．．", "あの．．．"]}, {"box": [1033, 1421, 1085, 1513], "vertical": true, "font_size": 32.0, "lines": ["ねえ。"]}, {"box": [283, 1436, 367, 1623], "vertical": true, "font_size": 32.0, "lines": ["私から", "言っていい？"]}], "img_path": "082.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1083, 206, 1128, 283], "vertical": true, "font_size": 32.0, "lines": ["へ！？"]}, {"box": [129, 82, 596, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [163, 215, 335, 443], "vertical": true, "font_size": 31.0, "lines": ["たぶん西片が", "言おうと", "してることと", "同じだと思うし。"]}, {"box": [1005, 736, 1171, 924], "vertical": true, "font_size": 32.0, "lines": ["高木さんの", "勘違いしてる", "オレと同じ", "ことって．．．"]}, {"box": [178, 781, 268, 888], "vertical": true, "font_size": 32.0, "lines": ["あのね", "西片。"]}, {"box": [1010, 1275, 1080, 1370], "vertical": true, "font_size": 32.0, "lines": ["私さ、"]}, {"box": [198, 1365, 309, 1507], "vertical": true, "font_size": 32.0, "lines": ["つまり", "告．．．"]}, {"box": [414, 1635, 508, 1751], "vertical": true, "font_size": 32.0, "lines": ["いや．．．", "あの："]}], "img_path": "083.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1089, 159, 1241, 327], "vertical": true, "font_size": 32.0, "lines": ["西片と", "歌の練習", "したいな。"]}, {"box": [1134, 1100, 1198, 1188], "vertical": true, "font_size": 32.0, "lines": ["え。"]}, {"box": [594, 1040, 677, 1327], "vertical": true, "font_size": 32.0, "lines": ["今日、女子パートに", "ひっぱられてたから、"]}, {"box": [361, 1051, 519, 1243], "vertical": true, "font_size": 32.0, "lines": ["テストまでに", "練習", "したかったん", "でしょ？"]}], "img_path": "084.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [618, 181, 745, 399], "vertical": true, "font_size": 32.0, "lines": ["何か他のことと", "勘違いしてると", "思ってた？"]}, {"box": [1007, 918, 1168, 1192], "vertical": true, "font_size": 31.0, "lines": ["ドジだねー", "用件言い忘れて", "自分で緊張しちゃう", "なんてさー。"]}, {"box": [408, 954, 495, 1170], "vertical": true, "font_size": 32.0, "lines": ["べ．．．別に", "してないけど．．．"]}, {"box": [168, 958, 254, 1087], "vertical": true, "font_size": 32.0, "lines": ["高木さん", "めぇえ。"]}, {"box": [1117, 1481, 1188, 1694], "vertical": true, "font_size": 28.0, "lines": ["はじめから．．", "全部知ってて．．．"]}, {"box": [669, 1490, 757, 1644], "vertical": true, "font_size": 32.0, "lines": ["じゃあ練習", "しようか．．．"]}, {"box": [196, 1505, 234, 1586], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}], "img_path": "085.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1091, 234, 1218, 450], "vertical": true, "font_size": 32.0, "lines": ["はじめは一瞬", "期待しちゃった", "けどね。"]}, {"box": [489, 384, 526, 453], "vertical": true, "font_size": 32.0, "lines": ["え？"]}, {"box": [1048, 1258, 1125, 1413], "vertical": true, "font_size": 32.0, "lines": ["あーきの", "そーらはー"]}, {"box": [270, 1235, 476, 1466], "vertical": true, "font_size": 32.0, "lines": ["あかーく", "もえてー"]}], "img_path": "086.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [135, 148, 635, 324], "vertical": false, "font_size": 32.0, "lines": ["かん", "交換日記"]}], "img_path": "087.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1029, 888, 1172, 1068], "vertical": true, "font_size": 32.0, "lines": ["高木さんを", "からかい．．．", "勝つ方法。"]}, {"box": [245, 890, 345, 1084], "vertical": true, "font_size": 32.0, "lines": ["何か", "ないものか．．．"]}, {"box": [1026, 1434, 1187, 1621], "vertical": true, "font_size": 32.0, "lines": ["といっても", "最近パッと", "したのが出て", "こないな．．．"]}, {"box": [639, 1441, 725, 1645], "vertical": true, "font_size": 32.0, "lines": ["何か．．．", "新しいものを"]}, {"box": [530, 1436, 577, 1608], "vertical": true, "font_size": 32.0, "lines": ["ねぇ、西片。"]}], "img_path": "088.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [601, 163, 689, 292], "vertical": true, "font_size": 32.0, "lines": ["交換日記", "しない？"]}, {"box": [678, 1010, 718, 1119], "vertical": true, "font_size": 32.0, "lines": ["いいよ。"]}, {"box": [215, 1027, 247, 1166], "vertical": true, "font_size": 32.0, "lines": ["よかった。"]}, {"box": [930, 1610, 1093, 1770], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "明日", "ノート用意", "しとくよ。"]}, {"box": [388, 1601, 435, 1691], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}, {"box": [296, 1629, 328, 1766], "vertical": true, "font_size": 32.0, "lines": ["わかった。"]}], "img_path": "089.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [797, 140, 885, 300], "vertical": true, "font_size": 32.0, "lines": ["誰にも内緒", "だからね。"]}, {"box": [594, 144, 635, 230], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}, {"box": [1202, 1265, 1249, 1436], "vertical": true, "font_size": 32.0, "lines": ["高木さんめ。"]}, {"box": [658, 1286, 784, 1502], "vertical": true, "font_size": 31.0, "lines": ["わざわざ自分で", "用意して", "くれるとはな！！"]}, {"box": [487, 1250, 570, 1436], "vertical": true, "font_size": 32.0, "lines": ["ふふ．．．", "交換日記か．．．"]}, {"box": [300, 958, 328, 1087], "vertical": true, "font_size": 28.0, "lines": ["く．．．"]}, {"box": [135, 1254, 253, 1468], "vertical": true, "font_size": 32.0, "lines": ["これはからかう", "チャンスが", "増えそうだ。"]}], "img_path": "090.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1027, 172, 1121, 395], "vertical": true, "font_size": 32.0, "lines": ["は．．．？", "高木さんと．．．"]}, {"box": [264, 181, 340, 453], "vertical": true, "font_size": 32.0, "lines": ["交換日記！？"]}, {"box": [1016, 984, 1183, 1200], "vertical": true, "font_size": 32.0, "lines": ["なんか", "テキトーに", "ＯＫしちゃった", "けど、"]}, {"box": [157, 963, 320, 1185], "vertical": true, "font_size": 32.0, "lines": ["それってっ", "付き合ってる", "男女が", "やるやつじゃ．．．"]}, {"box": [1063, 1423, 1115, 1691], "vertical": true, "font_size": 32.0, "lines": ["うわぁあぁ。"]}, {"box": [247, 1440, 318, 1711], "vertical": true, "font_size": 32.0, "lines": ["恥ずかしー。"]}], "img_path": "091.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1065, 183, 1192, 403], "vertical": true, "font_size": 32.0, "lines": ["い：今からでも", "やっぱり", "断るか．．．？"]}, {"box": [526, 172, 644, 416], "vertical": true, "font_size": 31.0, "lines": ["なんかどんどん", "恥ずかしくなって", "きた．．．"]}, {"box": [425, 193, 467, 323], "vertical": true, "font_size": 32.0, "lines": ["いや待て。"]}, {"box": [153, 208, 240, 319], "vertical": true, "font_size": 32.0, "lines": ["よくなか", "考えろ。"]}, {"box": [1061, 774, 1134, 984], "vertical": true, "font_size": 32.0, "lines": ["高木さんが", "なぜオレに．．．？"]}, {"box": [845, 843, 963, 1029], "vertical": true, "font_size": 32.0, "lines": ["決まってる！！", "からかいたい", "からだ"]}, {"box": [451, 808, 573, 1113], "vertical": true, "font_size": 32.0, "lines": ["そして高木さんが", "最も期待していたのは", "おそらく、"]}, {"box": [857, 1359, 903, 1453], "vertical": true, "font_size": 32.0, "lines": ["いいよ"]}, {"box": [260, 856, 339, 1104], "vertical": true, "font_size": 32.0, "lines": ["オレの", "あわてふためく姿"]}, {"box": [1063, 1370, 1192, 1600], "vertical": true, "font_size": 32.0, "lines": ["無意識では", "あったがそこは", "回避した．．．"]}, {"box": [407, 1415, 564, 1629], "vertical": true, "font_size": 31.0, "lines": ["つまり．．．", "これは流れが", "来ていると", "いうことでは．．．"]}], "img_path": "092.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1005, 200, 1104, 425], "vertical": true, "font_size": 32.0, "lines": ["やってやるぞ", "交換日記。"]}, {"box": [243, 236, 346, 403], "vertical": true, "font_size": 32.0, "lines": ["見てろよ", "高木さん。"]}, {"box": [1068, 860, 1116, 958], "vertical": true, "font_size": 32.0, "lines": ["次の日"]}, {"box": [170, 1061, 294, 1190], "vertical": true, "font_size": 32.0, "lines": ["とは", "決めた", "ものの．．"]}, {"box": [1070, 1385, 1154, 1599], "vertical": true, "font_size": 32.0, "lines": ["やはり恥ずかし", "すぎる．．．"]}, {"box": [325, 1350, 495, 1537], "vertical": true, "font_size": 32.0, "lines": ["もし他の人に", "バレたらちゃんが", "絶対勘違い", "されるし．．．"]}], "img_path": "093.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1024, 193, 1193, 438], "vertical": true, "font_size": 32.0, "lines": ["交換日記のことは", "絶対に他の人に", "バレないように", "しなければ．．．"]}, {"box": [348, 159, 476, 376], "vertical": true, "font_size": 32.0, "lines": ["まぁ高木さんも", "内緒って", "言ってたし．．"]}, {"box": [153, 476, 243, 753], "vertical": true, "font_size": 32.0, "lines": ["オレが気をつければ", "バレはしないか．．．"]}, {"box": [761, 924, 808, 1066], "vertical": true, "font_size": 32.0, "lines": ["よー西片。"]}, {"box": [661, 965, 695, 1104], "vertical": true, "font_size": 32.0, "lines": ["おはよー。"]}, {"box": [1055, 1484, 1201, 1625], "vertical": true, "font_size": 32.0, "lines": ["平常心", "平常心．．．"]}, {"box": [798, 1484, 825, 1604], "vertical": true, "font_size": 21.0, "lines": ["おはよう。"]}, {"box": [159, 1505, 234, 1640], "vertical": true, "font_size": 32.0, "lines": ["そういや", "聞いたぞ。"]}], "img_path": "094.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [605, 228, 702, 413], "vertical": true, "font_size": 32.0, "lines": ["交換日記", "するんだろ。"]}, {"box": [91, 146, 174, 333], "vertical": true, "font_size": 32.0, "lines": ["なんで", "知ってんの！？"]}, {"box": [1097, 982, 1179, 1228], "vertical": true, "font_size": 32.0, "lines": ["いや．．．", "そうじゃなくて．．．"]}, {"box": [973, 1033, 1014, 1132], "vertical": true, "font_size": 32.0, "lines": ["あの．．．"]}, {"box": [172, 1014, 261, 1198], "vertical": true, "font_size": 32.0, "lines": ["高木ちゃんに", "聞いたよー。"]}, {"box": [720, 1522, 759, 1670], "vertical": true, "font_size": 32.0, "lines": ["ナイス！"]}], "img_path": "095.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [915, 101, 948, 196], "vertical": true, "font_size": 32.0, "lines": ["あれ！？"]}, {"box": [780, 102, 825, 286], "vertical": true, "font_size": 32.0, "lines": ["高木さんめ．．．"]}, {"box": [153, 140, 287, 328], "vertical": true, "font_size": 32.0, "lines": ["自分で内緒", "って言ってた", "クセに。"]}, {"box": [1059, 866, 1138, 990], "vertical": true, "font_size": 32.0, "lines": ["なしだ", "なし．．．！！"]}, {"box": [245, 881, 333, 1035], "vertical": true, "font_size": 32.0, "lines": ["交換日記は", "なしー！！"]}, {"box": [1063, 1400, 1116, 1593], "vertical": true, "font_size": 32.0, "lines": ["高木さん！"]}, {"box": [256, 1485, 298, 1563], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}], "img_path": "096.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1067, 206, 1187, 345], "vertical": true, "font_size": 32.0, "lines": ["どしたの", "そんなに", "あわてて。"]}, {"box": [517, 213, 590, 340], "vertical": true, "font_size": 32.0, "lines": ["いや．．．", "そのさぁ、"]}, {"box": [290, 86, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["１上手の高ホさんの"]}, {"box": [129, 82, 288, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい"]}, {"box": [151, 172, 273, 311], "vertical": true, "font_size": 32.0, "lines": ["あ、", "ちょっと", "待ってて。"]}, {"box": [142, 418, 225, 588], "vertical": true, "font_size": 32.0, "lines": ["すぐ", "終わるから。"]}, {"box": [755, 1211, 806, 1293], "vertical": true, "font_size": 32.0, "lines": ["はい。"]}, {"box": [532, 1215, 622, 1370], "vertical": true, "font_size": 32.0, "lines": ["交換日記の", "ノート。"]}, {"box": [315, 1177, 433, 1362], "vertical": true, "font_size": 32.0, "lines": ["だから", "そのコト", "なんだけど．．"]}, {"box": [151, 1240, 182, 1296], "vertical": true, "font_size": 31.0, "lines": ["！"]}], "img_path": "097.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1072, 1027, 1158, 1188], "vertical": true, "font_size": 32.0, "lines": ["なに、この", "記号．．．"]}, {"box": [810, 991, 925, 1287], "vertical": true, "font_size": 32.0, "lines": ["あぁ、名前書くと", "恥ずかしいから", "名字のアルファベット。"]}, {"box": [375, 995, 725, 1096], "vertical": true, "font_size": 32.0, "lines": ["真野、", "中井、", "西片、", "高木、"]}, {"box": [176, 1072, 219, 1156], "vertical": true, "font_size": 32.0, "lines": ["だね。"]}, {"box": [660, 1515, 718, 1580], "vertical": true, "font_size": 32.0, "lines": ["さ。"]}], "img_path": "098.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1018, 168, 1179, 365], "vertical": true, "font_size": 32.0, "lines": ["真野ちゃんが", "中井君に", "交換日記", "もちかけたら、"]}, {"box": [778, 187, 937, 405], "vertical": true, "font_size": 32.0, "lines": ["２人でやるのは", "恥ずかしいって", "言われたん", "だってさ。"]}, {"box": [480, 204, 513, 328], "vertical": true, "font_size": 32.0, "lines": ["つまり．．．"]}, {"box": [129, 82, 594, 120], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さんの"]}, {"box": [322, 234, 360, 285], "vertical": true, "font_size": 32.0, "lines": ["そ。"]}, {"box": [1110, 796, 1197, 952], "vertical": true, "font_size": 30.0, "lines": ["私と西片は", "数あわせ。"]}, {"box": [616, 780, 695, 961], "vertical": true, "font_size": 32.0, "lines": ["言って", "なかったっけ。"]}, {"box": [208, 819, 292, 976], "vertical": true, "font_size": 32.0, "lines": ["言って", "ないよォ！"]}, {"box": [1085, 1284, 1132, 1414], "vertical": true, "font_size": 32.0, "lines": ["ハァー"]}, {"box": [375, 1256, 406, 1441], "vertical": true, "font_size": 31.0, "lines": ["それでかぁ．．．"]}, {"box": [185, 1263, 303, 1481], "vertical": true, "font_size": 31.0, "lines": ["中井君と", "真野さんが", "知ってたのは．．．"]}, {"box": [195, 1560, 221, 1723], "vertical": true, "font_size": 31.0, "lines": ["あせったよ。"]}], "img_path": "099.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1132, 223, 1164, 435], "vertical": true, "font_size": 32.0, "lines": ["あぁ、なるほど。"]}, {"box": [995, 228, 1074, 421], "vertical": true, "font_size": 32.0, "lines": ["内緒って", "言ってたのに、"]}, {"box": [592, 181, 774, 435], "vertical": true, "font_size": 32.0, "lines": ["私が", "言いふらしてると", "思ってテレてた", "のか。"]}, {"box": [393, 206, 513, 406], "vertical": true, "font_size": 32.0, "lines": ["ゴメンね、", "４人って", "言い忘れてて。"]}, {"box": [150, 198, 281, 382], "vertical": true, "font_size": 32.0, "lines": ["別にテレてた", "わけじゃない", "って！！"]}, {"box": [1005, 596, 1046, 703], "vertical": true, "font_size": 32.0, "lines": ["あはは"]}, {"box": [990, 973, 1198, 1141], "vertical": true, "font_size": 32.0, "lines": ["とりあえず", "西片最初", "よろしくね。"]}, {"box": [316, 1008, 356, 1108], "vertical": true, "font_size": 32.0, "lines": ["えぇ？！"]}, {"box": [1106, 1406, 1195, 1560], "vertical": true, "font_size": 32.0, "lines": ["何書けば", "いいの．．．？"]}, {"box": [678, 1387, 797, 1616], "vertical": true, "font_size": 32.0, "lines": ["なんでもいいよ", "好きなものとか", "嫌いなものとか。"]}, {"box": [581, 1391, 615, 1515], "vertical": true, "font_size": 32.0, "lines": ["そっか．．．"]}, {"box": [202, 1431, 232, 1564], "vertical": true, "font_size": 30.0, "lines": ["．．．．．．"]}], "img_path": "100.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1018, 223, 1110, 386], "vertical": true, "font_size": 32.0, "lines": ["４人での", "交換日記．．．"]}, {"box": [776, 219, 932, 466], "vertical": true, "font_size": 32.0, "lines": ["．．．これなら別に", "バレてもそこまで", "恥ずかしくは", "ないけど．．．"]}, {"box": [672, 233, 724, 428], "vertical": true, "font_size": 32.0, "lines": ["ああれせだ"]}, {"box": [129, 82, 596, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい」", "１上手の高ホさんの"]}, {"box": [144, 180, 312, 458], "vertical": true, "font_size": 31.0, "lines": ["４人だと", "高木さんを", "からかうことは", "できなさそうだな．．．"]}, {"box": [1076, 793, 1158, 950], "vertical": true, "font_size": 32.0, "lines": ["いや、でも", "いいか．．．"]}, {"box": [193, 826, 363, 1042], "vertical": true, "font_size": 32.0, "lines": ["やっぱり", "交換日記なんて", "恥ずかしすぎる", "もんな．．．"]}, {"box": [327, 1308, 357, 1361], "vertical": true, "font_size": 30.0, "lines": ["！"]}], "img_path": "101.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1230, 136, 1262, 271], "vertical": true, "font_size": 32.0, "lines": ["こっちは、"]}, {"box": [646, 140, 738, 343], "vertical": true, "font_size": 32.0, "lines": ["私としかた", "西片のやつね。"]}, {"box": [157, 562, 193, 703], "vertical": true, "font_size": 32.0, "lines": ["よろしく。"]}, {"box": [1154, 1030, 1186, 1135], "vertical": true, "font_size": 32.0, "lines": ["．．．．．．"]}, {"box": [397, 1055, 436, 1155], "vertical": true, "font_size": 32.0, "lines": ["うん．．．"]}, {"box": [932, 1483, 1057, 1695], "vertical": true, "font_size": 32.0, "lines": ["みんなに", "言いふらさない", "でね。"]}, {"box": [802, 1560, 885, 1715], "vertical": true, "font_size": 32.0, "lines": ["恥ずかしい", "から。"]}, {"box": [305, 1551, 389, 1687], "vertical": true, "font_size": 32.0, "lines": ["言うわけ", "ないだろ。"]}], "img_path": "102.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [150, 157, 496, 277], "vertical": false, "font_size": 32.0, "lines": ["チ"]}], "img_path": "103.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1055, 1089, 1134, 1256], "vertical": true, "font_size": 32.0, "lines": ["バレン", "タイン．．．か。"]}, {"box": [1168, 1475, 1206, 1597], "vertical": true, "font_size": 26.0, "lines": ["言うな．．．"]}, {"box": [701, 1470, 746, 1580], "vertical": true, "font_size": 32.0, "lines": ["スマン。"]}, {"box": [416, 1490, 470, 1584], "vertical": true, "font_size": 32.0, "lines": ["浜口。"]}], "img_path": "104.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [481, 106, 515, 228], "vertical": true, "font_size": 32.0, "lines": ["チョコ．．．"]}, {"box": [378, 165, 412, 288], "vertical": true, "font_size": 32.0, "lines": ["ほしい？"]}, {"box": [1008, 954, 1084, 1029], "vertical": true, "font_size": 32.0, "lines": ["く．．．"]}, {"box": [1108, 1340, 1142, 1449], "vertical": true, "font_size": 32.0, "lines": ["あっそ。"]}, {"box": [847, 1393, 890, 1479], "vertical": true, "font_size": 32.0, "lines": ["はい。"]}, {"box": [258, 925, 289, 1109], "vertical": true, "font_size": 27.0, "lines": ["くれるなら．．．"]}], "img_path": "105.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1121, 161, 1209, 363], "vertical": true, "font_size": 32.0, "lines": ["早く", "受けとってよ。"]}, {"box": [926, 161, 1072, 296], "vertical": true, "font_size": 32.0, "lines": ["先生", "来ちゃう", "でしょ。"]}, {"box": [695, 196, 727, 331], "vertical": true, "font_size": 30.0, "lines": ["あ．．．あぁ。"]}, {"box": [206, 219, 249, 303], "vertical": true, "font_size": 32.0, "lines": ["じゃ。"]}, {"box": [631, 405, 658, 586], "vertical": true, "font_size": 30.0, "lines": ["ありがとう．．"]}, {"box": [751, 946, 782, 1110], "vertical": true, "font_size": 27.0, "lines": ["よかったな。"]}, {"box": [303, 960, 333, 1128], "vertical": true, "font_size": 27.0, "lines": ["．．．じゃない．．．"]}, {"box": [1018, 1507, 1140, 1665], "vertical": true, "font_size": 32.0, "lines": ["これ．．．", "手作りじゃ", "ないぞ．．．"]}], "img_path": "106.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1083, 103, 1203, 290], "vertical": true, "font_size": 32.0, "lines": ["お前．．．", "ケンカを", "売ってるのか。"]}, {"box": [720, 101, 870, 221], "vertical": true, "font_size": 32.0, "lines": ["かわりに", "食べて", "やっても", "いいぞ。"]}, {"box": [495, 161, 535, 361], "vertical": true, "font_size": 27.0, "lines": ["違うんだって。"]}, {"box": [292, 159, 407, 409], "vertical": true, "font_size": 27.0, "lines": ["昨日たまたま", "スーパーで", "見ちゃったんだよ．．"]}, {"box": [978, 768, 1097, 922], "vertical": true, "font_size": 32.0, "lines": ["チョコの", "材料を買う", "北条を．．．"]}, {"box": [1020, 1468, 1146, 1713], "vertical": true, "font_size": 32.0, "lines": ["手作りチョコを", "配ってるわけじゃ", "ないなら．．．"]}, {"box": [200, 1537, 315, 1719], "vertical": true, "font_size": 31.0, "lines": ["あれは．．．", "本命用だった", "ってことだ．．．"]}], "img_path": "107.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [924, 103, 1013, 256], "vertical": true, "font_size": 32.0, "lines": ["オレ以外の", "誰かに．．．"]}, {"box": [692, 93, 812, 232], "vertical": true, "font_size": 32.0, "lines": ["もらえた", "だけで", "いいだろ。"]}, {"box": [579, 72, 609, 266], "vertical": true, "font_size": 26.0, "lines": ["なんだコイツ。"]}, {"box": [176, 157, 267, 341], "vertical": true, "font_size": 32.0, "lines": ["なぐさめろ", "よお！！"]}, {"box": [1078, 1239, 1153, 1393], "vertical": true, "font_size": 32.0, "lines": ["まったく", "あいつら．．．"]}, {"box": [166, 1201, 195, 1302], "vertical": true, "font_size": 29.0, "lines": ["．．．．．．"]}], "img_path": "108.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [661, 219, 786, 496], "vertical": true, "font_size": 32.0, "lines": ["北条は．．．", "誰に手作りチョコを", "渡したんだろう："]}, {"box": [118, 122, 143, 195], "vertical": true, "font_size": 25.0, "lines": ["．．．．．"]}, {"box": [423, 457, 498, 595], "vertical": true, "font_size": 32.0, "lines": ["まぁ．．．", "オレには"]}, {"box": [77, 496, 119, 663], "vertical": true, "font_size": 27.0, "lines": ["関係ないか。"]}, {"box": [843, 1013, 886, 1142], "vertical": true, "font_size": 32.0, "lines": ["いァ．．．"]}, {"box": [1003, 1531, 1052, 1614], "vertical": true, "font_size": 32.0, "lines": ["空が、"]}, {"box": [249, 1552, 285, 1692], "vertical": true, "font_size": 32.0, "lines": ["キレイだ。"]}], "img_path": "109.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1177, 118, 1273, 350], "vertical": true, "font_size": 32.0, "lines": ["何", "落ち込んでんの。"]}, {"box": [508, 116, 555, 215], "vertical": true, "font_size": 32.0, "lines": ["北条．．．"]}, {"box": [1098, 1044, 1185, 1179], "vertical": true, "font_size": 32.0, "lines": ["口開けて", "上向いて、"]}, {"box": [198, 1042, 360, 1258], "vertical": true, "font_size": 32.0, "lines": ["ゾンビみたいで", "怖いから", "やめた方が", "いいわよ。"]}, {"box": [714, 1554, 745, 1658], "vertical": true, "font_size": 31.0, "lines": ["．．．．．．．"]}, {"box": [151, 1548, 277, 1723], "vertical": true, "font_size": 32.0, "lines": ["で、", "何落ち込ん", "でたの。"]}], "img_path": "110.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1033, 138, 1168, 330], "vertical": true, "font_size": 32.0, "lines": ["別に", "落ち込んでは", "いない。"]}, {"box": [594, 178, 628, 285], "vertical": true, "font_size": 32.0, "lines": ["ウソよ。"]}, {"box": [309, 93, 473, 285], "vertical": true, "font_size": 32.0, "lines": ["これやってる", "時は", "落ち込んでる", "もの。"]}, {"box": [80, 225, 114, 358], "vertical": true, "font_size": 32.0, "lines": ["ってやつ。"]}, {"box": [156, 833, 187, 938], "vertical": true, "font_size": 31.0, "lines": ["．．．．．．"]}, {"box": [605, 931, 738, 1126], "vertical": true, "font_size": 32.0, "lines": ["何年の", "付き合いだと", "思ってんの。"]}, {"box": [532, 1477, 570, 1657], "vertical": true, "font_size": 32.0, "lines": ["あ、わかった。"]}, {"box": [386, 1485, 472, 1674], "vertical": true, "font_size": 32.0, "lines": ["落ち込んでる", "理由。"]}], "img_path": "111.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [898, 93, 1016, 281], "vertical": true, "font_size": 32.0, "lines": ["もらった", "チョコが", "少なかった．．"]}, {"box": [795, 172, 834, 273], "vertical": true, "font_size": 32.0, "lines": ["とか？"]}, {"box": [519, 105, 588, 221], "vertical": true, "font_size": 32.0, "lines": ["違う．．．"]}, {"box": [153, 111, 183, 204], "vertical": true, "font_size": 28.0, "lines": ["けど．．．"]}, {"box": [506, 506, 573, 729], "vertical": true, "font_size": 29.0, "lines": ["めんどくさいから", "合わせとくか．．．"]}, {"box": [146, 532, 181, 615], "vertical": true, "font_size": 32.0, "lines": ["あぁ。"]}, {"box": [1040, 924, 1157, 1078], "vertical": true, "font_size": 32.0, "lines": ["まったく", "個数なんて", "気にして。"]}, {"box": [842, 924, 965, 1051], "vertical": true, "font_size": 32.0, "lines": ["男子って", "ホントに", "子供ね。"]}, {"box": [298, 977, 329, 1110], "vertical": true, "font_size": 31.0, "lines": ["．．．．．．？"]}, {"box": [1158, 1492, 1198, 1600], "vertical": true, "font_size": 32.0, "lines": ["それで、"]}, {"box": [707, 1464, 756, 1711], "vertical": true, "font_size": 32.0, "lines": ["何個もらったの？"]}, {"box": [600, 1515, 639, 1622], "vertical": true, "font_size": 28.0, "lines": ["個。"]}], "img_path": "112.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1083, 99, 1165, 313], "vertical": true, "font_size": 31.0, "lines": ["私からだけって", "こと？"]}, {"box": [590, 97, 656, 213], "vertical": true, "font_size": 32.0, "lines": ["はは"]}, {"box": [281, 143, 325, 268], "vertical": true, "font_size": 32.0, "lines": ["悪いか．．．"]}, {"box": [144, 260, 185, 369], "vertical": true, "font_size": 32.0, "lines": ["いやー、"]}, {"box": [75, 315, 110, 399], "vertical": true, "font_size": 32.0, "lines": ["まぁ。"]}, {"box": [601, 723, 741, 995], "vertical": true, "font_size": 32.0, "lines": ["私から", "もらえただけでも", "喜びなさいよ。"]}, {"box": [1022, 1500, 1196, 1760], "vertical": true, "font_size": 32.0, "lines": ["北条から", "市販のチョコを", "もらったから", "落ち込んでんだよ。"]}, {"box": [330, 1501, 448, 1668], "vertical": true, "font_size": 32.0, "lines": ["まったく、", "女子なんて", "大変なのよ。"]}, {"box": [166, 1533, 288, 1719], "vertical": true, "font_size": 32.0, "lines": ["前の日に", "準備しなきゃ", "だし。"]}], "img_path": "113.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [988, 106, 1157, 356], "vertical": true, "font_size": 32.0, "lines": ["誰にあげるかも", "人間関係把握して", "厳選しなきゃ", "だし。"]}, {"box": [673, 112, 896, 333], "vertical": true, "font_size": 32.0, "lines": ["渡す時に", "先生に見つから", "ないように", "気をつけなきゃ", "だし。"]}, {"box": [466, 95, 583, 247], "vertical": true, "font_size": 32.0, "lines": ["北条：今日", "やけに", "しゃべるな。"]}, {"box": [978, 791, 1093, 1008], "vertical": true, "font_size": 30.0, "lines": ["もしかして．．", "元気づけようと", "してくれてる．．．"]}, {"box": [1115, 1284, 1211, 1518], "vertical": true, "font_size": 32.0, "lines": ["当たり前だんじゃ", "冷たそうだけど、"]}, {"box": [967, 1299, 1042, 1453], "vertical": true, "font_size": 32.0, "lines": ["やさしいん", "だよな。"]}, {"box": [703, 1486, 821, 1743], "vertical": true, "font_size": 31.0, "lines": ["そうさ．．．", "オレはそこが", "好きになったんだ。"]}], "img_path": "114.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [973, 125, 1151, 283], "vertical": true, "font_size": 32.0, "lines": ["好きな女の", "幸せを", "願ってこそ", "男．．．"]}, {"box": [225, 131, 311, 364], "vertical": true, "font_size": 32.0, "lines": ["北条は", "どうだったんだ。"]}, {"box": [1027, 577, 1072, 648], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [751, 971, 882, 1160], "vertical": true, "font_size": 32.0, "lines": ["本命チョコ", "ちゃんと", "渡せたのか？"]}, {"box": [457, 1010, 503, 1136], "vertical": true, "font_size": 32.0, "lines": ["本．．．命？"]}, {"box": [63, 1470, 146, 1623], "vertical": true, "font_size": 30.0, "lines": ["隠さなくて", "いいって。"]}], "img_path": "115.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1065, 112, 1153, 292], "vertical": true, "font_size": 32.0, "lines": ["手作りチョコ", "作ってたろ。"]}, {"box": [219, 198, 273, 268], "vertical": true, "font_size": 32.0, "lines": ["な。"]}, {"box": [1089, 939, 1164, 1196], "vertical": true, "font_size": 32.0, "lines": ["ななんで．．．", "それ知ってんのよ。"]}, {"box": [303, 952, 393, 1170], "vertical": true, "font_size": 32.0, "lines": ["手作り", "チョコのこと．．．"]}, {"box": [1059, 1470, 1178, 1715], "vertical": true, "font_size": 28.0, "lines": ["いや、スーパーで", "ごい！！", "材料買ってるの", "偶然見かけて．．"]}, {"box": [155, 1745, 189, 1811], "vertical": true, "font_size": 32.0, "lines": ["こ．．．"]}], "img_path": "116.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1005, 202, 1094, 506], "vertical": true, "font_size": 32.0, "lines": ["焦がして", "ダメになったのよ．．．"]}, {"box": [170, 311, 225, 423], "vertical": true, "font_size": 32.0, "lines": ["全部．．．"]}, {"box": [1023, 1033, 1147, 1219], "vertical": true, "font_size": 32.0, "lines": ["ちょっと目を", "離しただけ", "なのに．．．"]}, {"box": [174, 1021, 291, 1249], "vertical": true, "font_size": 32.0, "lines": ["なんであんなに", "一瞬で", "コゲちゃうわけ。"]}, {"box": [1115, 1428, 1198, 1582], "vertical": true, "font_size": 32.0, "lines": ["ていうか何", "本命って．．．"]}, {"box": [648, 1471, 720, 1655], "vertical": true, "font_size": 31.0, "lines": ["チョコなんて", "全部ギリよ。"]}, {"box": [483, 1471, 560, 1719], "vertical": true, "font_size": 31.0, "lines": ["本命チョコなんて", "子供っぽいもの。"]}, {"box": [153, 1415, 196, 1486], "vertical": true, "font_size": 32.0, "lines": ["は．．．"]}], "img_path": "117.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [933, 165, 967, 270], "vertical": true, "font_size": 32.0, "lines": ["ははは。"]}, {"box": [671, 171, 699, 295], "vertical": true, "font_size": 26.0, "lines": ["なによ！"]}, {"box": [408, 178, 583, 375], "vertical": true, "font_size": 32.0, "lines": ["私がいっぱい", "失敗したのが", "そんなに", "面白いの？"]}, {"box": [168, 240, 253, 352], "vertical": true, "font_size": 32.0, "lines": ["いや．．．", "ゴメン。"]}, {"box": [1158, 1042, 1198, 1093], "vertical": true, "font_size": 32.0, "lines": ["ま、"]}, {"box": [717, 1057, 843, 1272], "vertical": true, "font_size": 32.0, "lines": ["元気出た", "みたいで", "よかったけど．．"]}, {"box": [628, 1037, 653, 1107], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．"]}, {"box": [172, 1080, 202, 1261], "vertical": true, "font_size": 26.0, "lines": ["ありがとう．．．"]}, {"box": [958, 1503, 1071, 1697], "vertical": true, "font_size": 32.0, "lines": ["ホワイトデーは", "高級チョコで", "お願い。"]}, {"box": [300, 1548, 350, 1635], "vertical": true, "font_size": 32.0, "lines": ["え！？"]}], "img_path": "118.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [341, 1618, 491, 1786], "vertical": false, "font_size": 32.0, "lines": ["熱"]}], "img_path": "119.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1008, 774, 1128, 930], "vertical": true, "font_size": 32.0, "lines": ["なんか", "熱っぽいと", "思ったら．．"]}, {"box": [615, 1306, 664, 1524], "vertical": true, "font_size": 32.0, "lines": ["まぁ大丈夫だろ。"]}, {"box": [200, 1375, 246, 1513], "vertical": true, "font_size": 32.0, "lines": ["微熱だし。"]}], "img_path": "120.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1036, 114, 1194, 358], "vertical": true, "font_size": 32.0, "lines": ["それより", "休んで次の日", "何か言われる方が", "イヤだし．．．"]}, {"box": [844, 33, 975, 190], "vertical": true, "font_size": 32.0, "lines": ["なんで休んだんだーーっ"]}, {"box": [656, 110, 703, 249], "vertical": true, "font_size": 32.0, "lines": ["あ、西片。"]}, {"box": [108, 163, 144, 271], "vertical": true, "font_size": 32.0, "lines": ["おはよ。"]}, {"box": [1162, 913, 1204, 1083], "vertical": true, "font_size": 32.0, "lines": ["あ、高木さん。"]}, {"box": [1157, 1335, 1188, 1442], "vertical": true, "font_size": 31.0, "lines": ["そうだ。"]}, {"box": [800, 945, 834, 1038], "vertical": true, "font_size": 32.0, "lines": ["おは．．．"]}, {"box": [429, 1333, 455, 1488], "vertical": true, "font_size": 30.0, "lines": ["どうせだし、"]}, {"box": [176, 1338, 331, 1618], "vertical": true, "font_size": 30.0, "lines": ["熱があるのを", "高木さんにバレずに", "すごせたら勝ちって", "ルールにでもするか"]}], "img_path": "121.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1110, 186, 1200, 444], "vertical": true, "font_size": 32.0, "lines": ["バレないように", "元気に！"]}, {"box": [367, 172, 418, 418], "vertical": true, "font_size": 32.0, "lines": ["おはよう！！"]}, {"box": [1121, 1291, 1205, 1449], "vertical": true, "font_size": 32.0, "lines": ["なんか今日", "元気だね。"]}, {"box": [787, 1321, 832, 1381], "vertical": true, "font_size": 32.0, "lines": ["え。"]}, {"box": [611, 1303, 692, 1430], "vertical": true, "font_size": 32.0, "lines": ["どうか", "したの？"]}, {"box": [178, 1640, 292, 1830], "vertical": true, "font_size": 32.0, "lines": ["い．．．いや、", "別に", "フツーだけど。"]}], "img_path": "122.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1175, 88, 1211, 191], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [733, 183, 885, 369], "vertical": true, "font_size": 32.0, "lines": ["じゃあ、", "学校、", "行こっか。"]}, {"box": [129, 84, 592, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [226, 234, 261, 360], "vertical": true, "font_size": 32.0, "lines": ["う、うん。"]}, {"box": [598, 1021, 688, 1134], "vertical": true, "font_size": 32.0, "lines": ["危ない", "危ない。"]}, {"box": [155, 1027, 323, 1245], "vertical": true, "font_size": 32.0, "lines": ["元気っぽく", "しようとして", "逆に怪しまれる", "ところだった．．．"]}], "img_path": "123.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1093, 161, 1209, 337], "vertical": true, "font_size": 32.0, "lines": ["熱って", "バレたら", "負けなんだ．．．"]}, {"box": [879, 165, 955, 342], "vertical": true, "font_size": 26.0, "lines": ["もっと慎重に", "やらなければ"]}, {"box": [771, 123, 800, 256], "vertical": true, "font_size": 26.0, "lines": ["フツーに"]}, {"box": [157, 125, 236, 339], "vertical": true, "font_size": 32.0, "lines": ["そう、フツーに", "していよう。"]}, {"box": [847, 721, 889, 903], "vertical": true, "font_size": 32.0, "lines": ["高木さん．．．？"]}, {"box": [196, 774, 234, 840], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [1022, 1333, 1183, 1545], "vertical": true, "font_size": 31.0, "lines": ["いや．．．なんで", "そんなゆっくり", "歩いてるの", "かなって．．．"]}, {"box": [249, 1368, 325, 1565], "vertical": true, "font_size": 32.0, "lines": ["そんなに", "ゆっくりかな。"]}], "img_path": "124.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1122, 108, 1207, 290], "vertical": true, "font_size": 29.0, "lines": ["西片が速いん", "じゃない？"]}, {"box": [804, 99, 843, 155], "vertical": true, "font_size": 30.0, "lines": ["え。"]}, {"box": [501, 90, 617, 301], "vertical": true, "font_size": 31.0, "lines": ["しまった．．．", "まだフツーじゃ", "なかったか。"]}, {"box": [232, 161, 311, 346], "vertical": true, "font_size": 29.0, "lines": ["そ．．．そうかも", "しれないね．．．"]}, {"box": [1038, 1325, 1208, 1479], "vertical": true, "font_size": 32.0, "lines": ["意識すると", "フツーって", "なかなか", "難しいな．．．"]}, {"box": [735, 1299, 808, 1543], "vertical": true, "font_size": 30.0, "lines": ["いつもって", "どうしてたっけ．．．"]}, {"box": [172, 1681, 204, 1787], "vertical": true, "font_size": 32.0, "lines": ["そうだ。"]}], "img_path": "125.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1155, 178, 1188, 309], "vertical": true, "font_size": 32.0, "lines": ["高木さん、"]}, {"box": [1020, 170, 1104, 345], "vertical": true, "font_size": 32.0, "lines": ["勝負", "しないかい。"]}, {"box": [566, 183, 643, 412], "vertical": true, "font_size": 32.0, "lines": ["そう、これが", "いつものオレさ。"]}, {"box": [196, 256, 230, 361], "vertical": true, "font_size": 32.0, "lines": ["いいよ。"]}, {"box": [201, 695, 229, 795], "vertical": true, "font_size": 28.0, "lines": ["．．．"]}, {"box": [1088, 924, 1203, 1166], "vertical": true, "font_size": 30.0, "lines": ["って．．．あ！！", "なんの勝負か", "決めてなかった！！"]}, {"box": [902, 1149, 995, 1243], "vertical": true, "font_size": 32.0, "lines": ["ねえ、じゃた", "西片。"]}, {"box": [266, 1040, 351, 1261], "vertical": true, "font_size": 32.0, "lines": ["私が勝負の内容", "決めていい？"]}], "img_path": "126.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [855, 196, 933, 322], "vertical": true, "font_size": 32.0, "lines": ["あ、ああ", "いいよ！！"]}, {"box": [678, 191, 757, 328], "vertical": true, "font_size": 32.0, "lines": ["しょうが", "ないなぁ。"]}, {"box": [129, 84, 594, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [191, 223, 224, 360], "vertical": true, "font_size": 32.0, "lines": ["よかった。"]}, {"box": [1112, 1115, 1186, 1328], "vertical": true, "font_size": 28.0, "lines": ["なんでわざわざ", "神社で．．．"]}, {"box": [688, 1113, 718, 1254], "vertical": true, "font_size": 28.0, "lines": ["まぁまぁ。"]}, {"box": [492, 1106, 611, 1263], "vertical": true, "font_size": 32.0, "lines": ["それで、", "なんの勝負", "するの？"]}], "img_path": "127.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [712, 204, 809, 441], "vertical": true, "font_size": 32.0, "lines": ["熱あったら", "負けって勝負。"]}, {"box": [1115, 963, 1175, 1025], "vertical": true, "font_size": 32.0, "lines": ["熱、"]}, {"box": [243, 1004, 277, 1183], "vertical": true, "font_size": 32.0, "lines": ["あるでしょ。"]}, {"box": [1149, 1411, 1183, 1622], "vertical": true, "font_size": 32.0, "lines": ["バ．．バレてた．．．"]}, {"box": [746, 1408, 813, 1613], "vertical": true, "font_size": 28.0, "lines": ["い．．．いやぁ", "なんのことやら。"]}], "img_path": "128.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [868, 176, 992, 333], "vertical": true, "font_size": 32.0, "lines": ["やっぱり、", "そう言うと", "思ったよ。"]}, {"box": [677, 178, 795, 435], "vertical": true, "font_size": 32.0, "lines": ["なんか最初から", "バレたく", "なさそうだったし。"]}, {"box": [538, 175, 612, 371], "vertical": true, "font_size": 29.0, "lines": ["とにかくこれ", "勝負だからさ。"]}, {"box": [129, 82, 592, 118], "vertical": false, "font_size": 30.0, "lines": ["からかい", "上手の高ホさんの"]}, {"box": [144, 185, 260, 341], "vertical": true, "font_size": 32.0, "lines": ["負けた方は", "家に帰って", "寝る。"]}, {"box": [1155, 888, 1183, 963], "vertical": true, "font_size": 28.0, "lines": ["．．．．．"]}, {"box": [170, 491, 202, 622], "vertical": true, "font_size": 32.0, "lines": ["いいよね。"]}, {"box": [727, 866, 851, 1080], "vertical": true, "font_size": 32.0, "lines": ["いや．．．", "でも．．．だいたい", "勝負って．．"]}, {"box": [628, 885, 660, 1072], "vertical": true, "font_size": 32.0, "lines": ["どうやって．．"]}, {"box": [180, 913, 210, 1138], "vertical": true, "font_size": 26.0, "lines": ["そりゃもちろん。"]}], "img_path": "129.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [468, 232, 501, 401], "vertical": true, "font_size": 32.0, "lines": ["こうやって。"]}, {"box": [1140, 1153, 1178, 1226], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}], "img_path": "130.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1151, 103, 1190, 213], "vertical": true, "font_size": 32.0, "lines": ["なあ！？"]}, {"box": [1145, 984, 1177, 1121], "vertical": true, "font_size": 32.0, "lines": ["やっぱり。"]}, {"box": [948, 1005, 1052, 1170], "vertical": true, "font_size": 32.0, "lines": ["西片の", "負けだね。"]}, {"box": [553, 1449, 673, 1631], "vertical": true, "font_size": 32.0, "lines": ["い．．．いや．．．", "たしかに", "微熱だけど．．．"]}, {"box": [161, 1460, 238, 1711], "vertical": true, "font_size": 28.0, "lines": ["家に帰って寝るほど", "じゃないって．．"]}], "img_path": "131.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1130, 168, 1196, 403], "vertical": true, "font_size": 26.0, "lines": ["ムリすると", "熱あがっちゃうよ。"]}, {"box": [778, 166, 855, 431], "vertical": true, "font_size": 32.0, "lines": ["それに今も", "けっこう熱かったし。"]}, {"box": [556, 172, 702, 279], "vertical": true, "font_size": 32.0, "lines": ["そう！！"]}, {"box": [174, 181, 335, 519], "vertical": true, "font_size": 32.0, "lines": ["オレがぁっ", "熱かったんじゃなくて", "高木さんが冷たかったん", "じゃないかな。"]}, {"box": [772, 641, 855, 770], "vertical": true, "font_size": 32.0, "lines": ["いや．．．", "それは．．．"]}, {"box": [1038, 963, 1164, 1208], "vertical": true, "font_size": 29.0, "lines": ["私が普通より", "体温低かったかも", "ってこと？"]}, {"box": [245, 982, 328, 1083], "vertical": true, "font_size": 32.0, "lines": ["そう！", "それ！"]}, {"box": [1102, 1389, 1183, 1590], "vertical": true, "font_size": 32.0, "lines": ["それは", "ないと思うよ。"]}, {"box": [545, 1376, 667, 1528], "vertical": true, "font_size": 32.0, "lines": ["いや．．．", "わかんない", "でしょ．．．"]}, {"box": [335, 1396, 369, 1534], "vertical": true, "font_size": 32.0, "lines": ["わかるよ。"]}], "img_path": "132.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1031, 241, 1112, 377], "vertical": true, "font_size": 32.0, "lines": ["だって", "さっき私、"]}, {"box": [208, 260, 369, 432], "vertical": true, "font_size": 32.0, "lines": ["ちょっと", "照れて", "カオ熱く", "なってたし。"]}, {"box": [590, 1016, 677, 1231], "vertical": true, "font_size": 32.0, "lines": ["てことで西片の", "負けだから、"]}, {"box": [155, 1016, 232, 1212], "vertical": true, "font_size": 32.0, "lines": ["ちゃんと", "帰って寝てね。"]}, {"box": [1025, 1560, 1054, 1662], "vertical": true, "font_size": 29.0, "lines": ["．．．．．．"]}, {"box": [423, 1548, 472, 1621], "vertical": true, "font_size": 32.0, "lines": ["わ．．．"]}, {"box": [331, 1567, 363, 1751], "vertical": true, "font_size": 32.0, "lines": ["わかったよ．．．"]}], "img_path": "133.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1230, 97, 1267, 204], "vertical": true, "font_size": 32.0, "lines": ["じゃあ、"]}, {"box": [781, 163, 824, 327], "vertical": true, "font_size": 31.0, "lines": ["お大事にね。"]}, {"box": [924, 1449, 1162, 1680], "vertical": true, "font_size": 32.0, "lines": ["あの", "高木さんが", "テレてたって．．．", "ないない．．．"]}, {"box": [320, 1447, 395, 1618], "vertical": true, "font_size": 32.0, "lines": ["うん．．．きっと", "ウソだ。"]}], "img_path": "134.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [134, 159, 564, 335], "vertical": false, "font_size": 32.0, "lines": ["そっ"]}], "img_path": "135.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "136.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [661, 150, 963, 208], "vertical": false, "font_size": 32.0, "lines": ["卒業証書授手式"]}, {"box": [131, 82, 596, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [1113, 907, 1192, 1074], "vertical": true, "font_size": 32.0, "lines": ["いやー", "感動したな。"]}, {"box": [570, 905, 690, 1110], "vertical": true, "font_size": 32.0, "lines": ["なんで？", "お前部活とか", "やってねーし、"]}, {"box": [558, 1209, 631, 1393], "vertical": true, "font_size": 32.0, "lines": ["センパイとか", "いないだろ。"]}, {"box": [380, 894, 509, 1111], "vertical": true, "font_size": 32.0, "lines": ["手あいてる人は", "イスを教室に", "運んでおいてー。"]}, {"box": [160, 1393, 186, 1438], "vertical": true, "font_size": 26.0, "lines": ["！"]}], "img_path": "137.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1100, 135, 1146, 273], "vertical": true, "font_size": 32.0, "lines": ["あ、西片。"]}, {"box": [1215, 1200, 1297, 1370], "vertical": true, "font_size": 32.0, "lines": ["卒業式", "どうだった？"]}, {"box": [727, 1216, 798, 1425], "vertical": true, "font_size": 30.0, "lines": ["んーどうって", "いわれてもなー。"]}, {"box": [408, 1198, 627, 1443], "vertical": true, "font_size": 32.0, "lines": ["中学生に", "なってからもう", "一年たったのかー", "ってカンジ", "かなー。"]}, {"box": [202, 1205, 286, 1380], "vertical": true, "font_size": 32.0, "lines": ["あー", "わかるなー。"]}], "img_path": "138.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1098, 114, 1175, 272], "vertical": true, "font_size": 32.0, "lines": ["このカンジ", "だと、"]}, {"box": [577, 127, 707, 343], "vertical": true, "font_size": 32.0, "lines": ["私たちも", "あっという間に", "卒業かもね。"]}, {"box": [463, 97, 495, 259], "vertical": true, "font_size": 28.0, "lines": ["そうだねぇ。"]}, {"box": [95, 120, 178, 316], "vertical": true, "font_size": 32.0, "lines": ["あー", "楽しみだなー。"]}, {"box": [547, 855, 634, 965], "vertical": true, "font_size": 32.0, "lines": ["楽しみ", "なんだ。"]}, {"box": [361, 840, 433, 993], "vertical": true, "font_size": 28.0, "lines": ["そりゃあ", "もちろん！"]}, {"box": [1037, 1381, 1110, 1605], "vertical": true, "font_size": 30.0, "lines": ["なんといっても", "高校生になれば、"]}, {"box": [256, 1430, 335, 1662], "vertical": true, "font_size": 32.0, "lines": ["バイトが", "できるからねー。"]}, {"box": [123, 1489, 226, 1719], "vertical": true, "font_size": 32.0, "lines": ["こうかいに困る", "ことがなくなる"]}], "img_path": "139.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1184, 113, 1260, 290], "vertical": true, "font_size": 26.0, "lines": ["高校入れれば", "いいけどねー。"]}, {"box": [1007, 133, 1040, 235], "vertical": true, "font_size": 30.0, "lines": ["あはは"]}, {"box": [684, 103, 801, 281], "vertical": true, "font_size": 32.0, "lines": ["不吉なコト", "言わないでよ、", "高木さん。"]}, {"box": [581, 198, 607, 300], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．？"]}, {"box": [178, 217, 217, 331], "vertical": true, "font_size": 32.0, "lines": ["そっか。"]}, {"box": [1089, 738, 1160, 838], "vertical": true, "font_size": 32.0, "lines": ["私は、"]}, {"box": [270, 795, 403, 994], "vertical": true, "font_size": 32.0, "lines": ["卒業式来るの", "ちょっと", "さみしいかな。"]}], "img_path": "140.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1070, 84, 1186, 288], "vertical": true, "font_size": 31.0, "lines": ["そっか．．．普通はだいたい", "大体みんな同じ", "高校行くけど、"]}, {"box": [633, 110, 712, 361], "vertical": true, "font_size": 28.0, "lines": ["高木さん頭いいから", "もしかして．．"]}, {"box": [508, 90, 551, 163], "vertical": true, "font_size": 32.0, "lines": ["いや、"]}, {"box": [348, 91, 459, 380], "vertical": true, "font_size": 32.0, "lines": ["ただ、中学生活が", "楽しいからってだけかも", "しれないけど．．．"]}, {"box": [1093, 1338, 1162, 1507], "vertical": true, "font_size": 30.0, "lines": ["あの．．．", "高木さんて．．．"]}, {"box": [631, 1363, 671, 1419], "vertical": true, "font_size": 32.0, "lines": ["あ。"]}, {"box": [382, 1363, 420, 1432], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}], "img_path": "141.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1135, 59, 1177, 212], "vertical": true, "font_size": 26.0, "lines": ["卒業生．．．？"]}, {"box": [1009, 819, 1039, 861], "vertical": true, "font_size": 30.0, "lines": ["？"]}, {"box": [536, 834, 660, 1003], "vertical": true, "font_size": 32.0, "lines": ["第二ボタン", "もらってたの", "かな。"]}, {"box": [328, 792, 375, 976], "vertical": true, "font_size": 32.0, "lines": ["第二ボタン．．．"]}, {"box": [909, 1383, 1069, 1638], "vertical": true, "font_size": 32.0, "lines": ["それって．．．あの", "ハート（心臓）に", "一番近いボタンを", "くださいっていう．．．"]}, {"box": [320, 1389, 450, 1680], "vertical": true, "font_size": 32.0, "lines": ["告白みたいな", "思い出づくりみたいな", "やつ．．．！？"]}], "img_path": "142.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [753, 118, 834, 328], "vertical": true, "font_size": 32.0, "lines": ["あ、その顔は", "意味知ってるね。"]}, {"box": [198, 123, 266, 303], "vertical": true, "font_size": 30.0, "lines": ["い．．．いや！！", "知らないけど。"]}, {"box": [1006, 703, 1080, 932], "vertical": true, "font_size": 30.0, "lines": ["ウッソだー", "顔真っ赤だもん。"]}, {"box": [900, 703, 937, 834], "vertical": true, "font_size": 32.0, "lines": ["あははは"]}, {"box": [252, 715, 289, 851], "vertical": true, "font_size": 32.0, "lines": ["．．．．．．"]}, {"box": [746, 1318, 828, 1456], "vertical": true, "font_size": 32.0, "lines": ["やっと", "ついたー。"]}, {"box": [155, 1305, 232, 1440], "vertical": true, "font_size": 32.0, "lines": ["けっこう", "大変だね。"]}], "img_path": "143.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1072, 93, 1198, 281], "vertical": true, "font_size": 28.0, "lines": ["高校のこと．．．", "聞きそびれ", "ちゃったな．．．"]}, {"box": [645, 105, 703, 193], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [151, 136, 232, 240], "vertical": true, "font_size": 32.0, "lines": ["な．．．", "なに！？"]}, {"box": [1004, 628, 1146, 1036], "vertical": true, "font_size": 32.0, "lines": ["西片は卒業式で", "第二ボタン", "ちょうだいって言われたら、"]}, {"box": [251, 821, 287, 969], "vertical": true, "font_size": 32.0, "lines": ["あげる？"]}], "img_path": "144.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1123, 84, 1192, 275], "vertical": true, "font_size": 32.0, "lines": ["わ．．．わかんない", "かな．．．"]}, {"box": [626, 103, 660, 240], "vertical": true, "font_size": 32.0, "lines": ["そっかー。"]}, {"box": [478, 76, 547, 287], "vertical": true, "font_size": 31.0, "lines": ["．．．なぜ", "そんなコトを．．．？"]}, {"box": [1012, 613, 1179, 862], "vertical": true, "font_size": 32.0, "lines": ["もしかして．．", "高木さん、オレの", "第二ボタンを", "．．．！？"]}, {"box": [420, 639, 447, 761], "vertical": true, "font_size": 26.0, "lines": ["ちょっと、"]}, {"box": [155, 630, 186, 809], "vertical": true, "font_size": 26.0, "lines": ["さみしいかな。"]}, {"box": [1121, 1166, 1188, 1331], "vertical": true, "font_size": 30.0, "lines": ["あれは", "もしかして．．．"]}, {"box": [851, 1175, 966, 1426], "vertical": true, "font_size": 32.0, "lines": ["オレと別の", "高校に行くのがって", "コト．．．！？"]}, {"box": [630, 1190, 755, 1406], "vertical": true, "font_size": 32.0, "lines": ["いやいや、", "何考えてるんだ", "オレは。"]}, {"box": [515, 1183, 541, 1363], "vertical": true, "font_size": 32.0, "lines": ["そんなわけ．．．"]}, {"box": [196, 1201, 241, 1351], "vertical": true, "font_size": 32.0, "lines": ["ねぇ、西片。"]}], "img_path": "145.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1097, 195, 1133, 383], "vertical": true, "font_size": 32.0, "lines": ["ちょうだい。"]}], "img_path": "146.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1053, 946, 1089, 1012], "vertical": true, "font_size": 32.0, "lines": ["い．．．"]}, {"box": [264, 933, 298, 1055], "vertical": true, "font_size": 32.0, "lines": ["いいよ．．．"]}], "img_path": "147.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1014, 82, 1055, 165], "vertical": true, "font_size": 32.0, "lines": ["じゃ、"]}, {"box": [941, 114, 967, 245], "vertical": true, "font_size": 32.0, "lines": ["もらうね"]}, {"box": [155, 172, 378, 345], "vertical": true, "font_size": 32.0, "lines": ["とりあえず", "こっちに", "まとめといて", "あとではあ", "配置した方が", "いいよね"]}, {"box": [1143, 1355, 1179, 1447], "vertical": true, "font_size": 32.0, "lines": ["へ．．．？"]}, {"box": [753, 1340, 797, 1410], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [631, 1346, 663, 1470], "vertical": true, "font_size": 30.0, "lines": ["イ．．．イス"]}, {"box": [592, 1387, 620, 1440], "vertical": true, "font_size": 30.0, "lines": ["．．．？"]}], "img_path": "148.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [558, 243, 592, 444], "vertical": true, "font_size": 32.0, "lines": ["そうだけど？"]}, {"box": [361, 119, 392, 304], "vertical": true, "font_size": 27.0, "lines": ["どうかした？"]}, {"box": [76, 748, 120, 823], "vertical": true, "font_size": 32.0, "lines": ["あ．．．"]}, {"box": [971, 1106, 1087, 1222], "vertical": true, "font_size": 32.0, "lines": ["な．．．", "なんでも", "ない．．．"]}, {"box": [639, 1091, 757, 1299], "vertical": true, "font_size": 32.0, "lines": ["うわぁああ", "勘違い．．．！？", "恥ずかしいいい。"]}, {"box": [388, 1121, 431, 1233], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [1014, 1451, 1089, 1666], "vertical": true, "font_size": 32.0, "lines": ["ふー．．．", "危なかったー．．．"]}], "img_path": "149.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1187, 123, 1239, 198], "vertical": true, "font_size": 32.0, "lines": ["い．．．"]}, {"box": [1053, 125, 1100, 238], "vertical": true, "font_size": 32.0, "lines": ["いいよ。"]}, {"box": [1078, 1070, 1160, 1171], "vertical": true, "font_size": 32.0, "lines": ["自分のうきっしき", "卒業式、"]}, {"box": [943, 1053, 1014, 1265], "vertical": true, "font_size": 32.0, "lines": ["ちょっと楽しみに", "なってきたや。"]}, {"box": [315, 1101, 345, 1203], "vertical": true, "font_size": 30.0, "lines": ["．．．．．．？"]}, {"box": [391, 1801, 963, 1841], "vertical": false, "font_size": 32.0, "lines": ["一からかい上手の高木さん凪・完一"]}], "img_path": "150.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "151.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1085, 1093, 1196, 1334], "vertical": true, "font_size": 32.0, "lines": ["くそー．．．", "こいつが", "皮むきうまいとか、"]}, {"box": [673, 1074, 746, 1230], "vertical": true, "font_size": 32.0, "lines": ["めっちゃ", "意外だった。"]}, {"box": [496, 1081, 606, 1314], "vertical": true, "font_size": 32.0, "lines": ["うまくできなくて", "半ベソになってる", "とこを、"]}, {"box": [157, 1091, 234, 1301], "vertical": true, "font_size": 26.0, "lines": ["私が助けてやる", "作戦だったのに。"]}], "img_path": "152.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [129, 82, 596, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [157, 189, 194, 372], "vertical": true, "font_size": 32.0, "lines": ["でもまだだ！"]}, {"box": [1007, 729, 1151, 916], "vertical": true, "font_size": 32.0, "lines": ["この味噌汁", "うまいって", "言わせたら、"]}, {"box": [260, 742, 371, 906], "vertical": true, "font_size": 32.0, "lines": ["私の", "勝ちだし。"]}], "img_path": "153.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1130, 191, 1170, 240], "vertical": true, "font_size": 32.0, "lines": ["ん。"]}, {"box": [710, 258, 785, 417], "vertical": true, "font_size": 32.0, "lines": ["これ、恋み", "味見してよ。"]}, {"box": [1128, 1280, 1170, 1357], "vertical": true, "font_size": 32.0, "lines": ["おお、"]}, {"box": [620, 1338, 652, 1469], "vertical": true, "font_size": 32.0, "lines": ["うまいな。"]}, {"box": [148, 1276, 226, 1372], "vertical": true, "font_size": 32.0, "lines": ["よし！", "勝っ．．．"]}], "img_path": "154.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1102, 245, 1170, 370], "vertical": true, "font_size": 30.0, "lines": ["こんな", "うまいの、"]}, {"box": [540, 288, 661, 420], "vertical": true, "font_size": 32.0, "lines": ["毎日", "飲みたい", "くらいだ。"]}, {"box": [131, 84, 575, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [1082, 1224, 1162, 1358], "vertical": true, "font_size": 32.0, "lines": ["は．．．はんそく", "反則だぞ。"]}, {"box": [241, 879, 348, 1055], "vertical": true, "font_size": 32.0, "lines": ["毎日って．．．", "それ．．．"]}, {"box": [202, 1224, 281, 1413], "vertical": true, "font_size": 32.0, "lines": ["おい、", "あぶねーって。"]}, {"box": [138, 1597, 196, 1781], "vertical": true, "font_size": 32.0, "lines": ["おわり"]}], "img_path": "155.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1085, 101, 1217, 481], "vertical": true, "font_size": 32.0, "lines": ["１０００年", "あいま叫び"]}, {"box": [705, 75, 1100, 1522], "vertical": true, "font_size": 32.0, "lines": ["メゑゼみみニアホぷ", "Ｂｏｏｋ"]}, {"box": [1207, 510, 1263, 1798], "vertical": true, "font_size": 32.0, "lines": ["ＫａｒｄｋａｉｊｏｚｕｎｏＴａｋａｇｉｓａｎＷｏｒｌｄ"]}, {"box": [720, 1201, 767, 1239], "vertical": false, "font_size": 32.0, "lines": ["５"]}, {"box": [873, 1734, 917, 1809], "vertical": true, "font_size": 29.0, "lines": ["ひさ"]}, {"box": [847, 1704, 887, 1783], "vertical": true, "font_size": 29.0, "lines": ["あ々ひい"]}, {"box": [201, 1550, 487, 1813], "vertical": false, "font_size": 32.0, "lines": ["！？．．．４ｖａ", "ＭｒｒｕｂＨｉｔ", "京盛期党ＳＭＣ", "一定出ささすげにさん", "・テーメメリハ", "．．．みんな平成く"]}], "img_path": "156.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [232, 99, 547, 714], "vertical": true, "font_size": 32.0, "lines": ["はいはこんから〈引〉《かみ》", "ゴ＆１２畔"]}, {"box": [116, 104, 193, 647], "vertical": true, "font_size": 32.0, "lines": ["●日平に〈引〉卵汁水〉＞２＞９概帯はＩさ", "審査員はこのようにこの相話でダンスメの口を！"]}, {"box": [63, 790, 95, 1127], "vertical": true, "font_size": 26.0, "lines": ["◎すｙｔｙｓｓＳＳの、＄ｆｆｉｖｓｔａ"]}, {"box": [230, 1231, 513, 1779], "vertical": true, "font_size": 32.0, "lines": ["＄ｗさ＞Ｈ４９", "弧オ〆¿", "１＆６Ｋ"]}, {"box": [159, 1218, 191, 1786], "vertical": true, "font_size": 32.0, "lines": ["●いさやいしたばかりでいきこのおいメリューに"]}], "img_path": "157.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [421, 560, 709, 686], "vertical": false, "font_size": 31.0, "lines": ["飼っている犬がおとなしく", "なってきました。", "歳なのでしょうか。"]}, {"box": [1228, 1359, 1278, 1774], "vertical": true, "font_size": 32.0, "lines": ["カバー表紙折り返し"]}, {"box": [415, 1764, 561, 1824], "vertical": false, "font_size": 32.0, "lines": ["ｗｅｒｌｌｕｓｔｒｏｎ＿ＣｏｖｅｒＤｅｓｉｇｈ＿"]}], "img_path": "158.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1226, 1320, 1282, 1779], "vertical": true, "font_size": 32.0, "lines": ["カバー裏表紙折り返し"]}], "img_path": "159.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [144, 1803, 601, 1873], "vertical": false, "font_size": 32.0, "lines": ["らかい上手の高"]}, {"box": [607, 1801, 1005, 1876], "vertical": false, "font_size": 32.0, "lines": ["高木さんの"]}, {"box": [1022, 1725, 1212, 1772], "vertical": false, "font_size": 32.0, "lines": ["本体表紙"]}], "img_path": "160.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [986, 1728, 1207, 1766], "vertical": false, "font_size": 32.0, "lines": ["本体裏表紙"]}], "img_path": "161.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [945, 1726, 1210, 1773], "vertical": false, "font_size": 32.0, "lines": ["カバー裏表紙"]}], "img_path": "162.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [654, 564, 697, 1128], "vertical": true, "font_size": 32.0, "lines": ["からかい上手の高木さんの"]}, {"box": [5, 525, 66, 1111], "vertical": true, "font_size": 32.0, "lines": ["ああ、ああ．．．あの大変期"]}, {"box": [658, 1143, 697, 1398], "vertical": true, "font_size": 32.0, "lines": ["山本黒一朗"]}], "img_path": "163.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [67, 1363, 615, 1387], "vertical": false, "font_size": 24.0, "lines": ["らかい上手の高木さん６０山本景一朗"]}, {"box": [663, 817, 690, 1340], "vertical": true, "font_size": 27.0, "lines": ["手の高木さん１０月２４日、東京"]}], "img_path": "164.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [208, 146, 980, 232], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [215, 288, 907, 326], "vertical": false, "font_size": 32.0, "lines": ["ゲッサン少年サンデー・コミックススペシャル"]}, {"box": [311, 873, 802, 905], "vertical": false, "font_size": 32.0, "lines": ["２０２１年９月１５日初版第１刷発行"]}, {"box": [703, 821, 1175, 845], "vertical": false, "font_size": 21.0, "lines": ["０９－８５０６９１：", "ＩＳＢＮ９７８－４－０"]}, {"box": [315, 1050, 418, 1089], "vertical": false, "font_size": 32.0, "lines": ["者", "著"]}, {"box": [316, 1162, 420, 1260], "vertical": false, "font_size": 32.0, "lines": ["発行者", "印刷所"]}, {"box": [643, 1048, 1061, 1201], "vertical": false, "font_size": 32.0, "lines": ["朗本禁一曲", "◎Ｓｏｉｃｈｉｒｏｙａｎａｍａｎｏｎｏ－２０２１", "樹正田縄"]}, {"box": [215, 1320, 1037, 1488], "vertical": false, "font_size": 27.75, "lines": ["「ゲッサン」２０２０年２月号、７月１３月号、１２月号〜２０２１年４月号掲載作品", "連載担当／板谷真人", "単行本編集責任／石川昌彦", "単行本編集／板谷真人ノ「三輪恭子（アイプロダクション）"]}, {"box": [654, 1230, 988, 1256], "vertical": false, "font_size": 26.0, "lines": ["中央精版印刷株式会社"]}, {"box": [228, 1507, 384, 1567], "vertical": false, "font_size": 32.0, "lines": ["発行所"]}, {"box": [230, 1710, 680, 1728], "vertical": false, "font_size": 18.0, "lines": ["〈電話受けは、土・日・祝休日を除く９，３０〜１７：３０）"]}, {"box": [412, 1513, 958, 1539], "vertical": false, "font_size": 26.0, "lines": ["〈〒１０－－８００）東京都千代田区一ツ橋二の三の"]}, {"box": [223, 1640, 1209, 1698], "vertical": false, "font_size": 25.0, "lines": ["●選本には十分注意しており、ますが、印刷、製作など製造上の不備がございましたら「制作局コール", "センターバフリーダイヤルＩＤＡ３３６－０８２）にご連絡ください。"]}, {"box": [223, 1740, 1217, 1828], "vertical": false, "font_size": 22.666666666666668, "lines": ["●本書の一部または全部を無断で複製、転職、複写（コピー）、スキャン、デジタル化、上演、放送", "等をすることは、著作権法上での例外を除き禁じられています。代行業名等の第三者による本書の", "電子的複製も認められておりません。"]}, {"box": [678, 1543, 1188, 1633], "vertical": false, "font_size": 32.0, "lines": ["．．．いい！！今回のクロロン編集ＯＳ（２３８）９７２５", "１０月２１日（水）２０１８年１２月１６日（火）においております。参加・小学館・"]}], "img_path": "165.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [116, 1123, 827, 1402], "vertical": false, "font_size": 32.0, "lines": ["書名、からかいた手の高校さん。１５歳、１８歳、", "あるからかいですからそれで、１０００円以上の時間があります。それ以外の", "山本宗一朗〇山本崇一朗ノ小学館雑士会社小学給"]}, {"box": [326, 1305, 1142, 1398], "vertical": false, "font_size": 32.0, "lines": ["株式会社小学館", "〒１０１－８０１．東京都千代田区一ツ橋２－３－１"]}, {"box": [181, 1477, 896, 1515], "vertical": false, "font_size": 32.0, "lines": ["電子書籍制作会社株式会社昭和ブライト"]}, {"box": [178, 1590, 947, 1648], "vertical": false, "font_size": 24.5, "lines": ["＊家収録されている作品は、執筆された当時の状況や年代を考慮の上、", "初回掲載時の表現のまま掲載されております。ご了承ください。"]}, {"box": [180, 1687, 1175, 1781], "vertical": false, "font_size": 24.333333333333332, "lines": ["☆本書の一部または全部を無断で複製、転載、複写（コピー）、スキャン、デジタル化、", "上演、放送等をすることは、著作権法上での例外を除き禁じられています。", "代行業者等の第三者によりる本書の電子的複製も認められておりません。"]}], "img_path": "166.jpg"}]}