 "img_width": 847, "img_height": 1200, "blocks": [{"box": [376, 108, 455, 172], "vertical": true, "font_size": 27.0, "lines": ["あ、", "おはよ", "西片。"]}, {"box": [308, 108, 328, 193], "vertical": true, "font_size": 20.0, "lines": ["おはよう。"]}, {"box": [611, 619, 659, 726], "vertical": true, "font_size": 22.0, "lines": ["なんか", "眠そーだね。"]}, {"box": [179, 639, 234, 721], "vertical": true, "font_size": 28.0, "lines": ["悪い夢", "見てさ．．．"]}, {"box": [387, 966, 416, 1064], "vertical": true, "font_size": 20.0, "lines": ["どんな夢？"]}], "img_path": "059.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [666, 133, 738, 247], "vertical": true, "font_size": 20.0, "lines": ["そ、それより", "明日から", "冬休みだね。"]}, {"box": [366, 132, 388, 239], "vertical": true, "font_size": 21.0, "lines": ["そうだねー。"]}, {"box": [246, 125, 300, 268], "vertical": true, "font_size": 21.0, "lines": ["今日で今年の", "学校終わりかー。"]}, {"box": [667, 532, 736, 683], "vertical": true, "font_size": 26.0, "lines": ["今日で今年の", "学校終わり．．．"]}, {"box": [141, 533, 165, 694], "vertical": true, "font_size": 24.0, "lines": ["ということは："]}, {"box": [214, 799, 292, 933], "vertical": true, "font_size": 21.0, "lines": ["まずい．．．何か", "勝てる勝負を", "考えなければ．．．"]}, {"box": [733, 833, 812, 1021], "vertical": true, "font_size": 32.0, "lines": ["今日勝てなければ", "今年全敗！？"]}], "img_path": "060.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [645, 146, 725, 309], "vertical": true, "font_size": 23.0, "lines": ["今年", "さんざん", "がらかわれたんだ。"]}, {"box": [80, 52, 370, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんＱ"]}, {"box": [133, 123, 226, 309], "vertical": true, "font_size": 25.0, "lines": ["せめて締めくくり", "くらい、勝利で", "終わらせたい．．！！"]}, {"box": [194, 486, 246, 566], "vertical": true, "font_size": 23.0, "lines": ["ところで", "西片。"]}, {"box": [352, 798, 373, 858], "vertical": true, "font_size": 21.0, "lines": ["ああ．．．"]}, {"box": [99, 607, 173, 723], "vertical": true, "font_size": 23.0, "lines": ["サンタさんに", "何か頼んだ", "の？"]}, {"box": [105, 806, 184, 969], "vertical": true, "font_size": 22.0, "lines": ["「爆裂！！", "最強サッカー！！この", "ゲームを．．．"]}, {"box": [433, 819, 480, 991], "vertical": true, "font_size": 20.0, "lines": ["そろそろ", "クリスマスでしょ？"]}], "img_path": "061.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [743, 59, 793, 203], "vertical": true, "font_size": 22.0, "lines": ["あはは", "西片っぽいねー。"]}, {"box": [436, 85, 472, 141], "vertical": true, "font_size": 32.0, "lines": ["な！？"]}, {"box": [303, 50, 383, 185], "vertical": true, "font_size": 21.0, "lines": ["毎年ちゃんと", "頼んだもの", "もらえてるの？"]}, {"box": [643, 503, 722, 619], "vertical": true, "font_size": 22.0, "lines": ["いや．．．毎年", "結局服とか", "靴とかだよ．．．"]}, {"box": [236, 480, 261, 549], "vertical": true, "font_size": 22.0, "lines": ["ふーん。"]}, {"box": [120, 525, 196, 660], "vertical": true, "font_size": 22.0, "lines": ["今年はちゃんと", "もらえると", "いいね。"]}, {"box": [767, 762, 795, 898], "vertical": true, "font_size": 20.0, "lines": ["高木さんは．．．？"]}, {"box": [439, 767, 552, 905], "vertical": true, "font_size": 24.0, "lines": ["私は今年は", "手ぶくろと", "新しいマフラー", "かな。"]}, {"box": [250, 757, 279, 821], "vertical": true, "font_size": 21.0, "lines": ["へえ．．．"]}, {"box": [117, 753, 188, 888], "vertical": true, "font_size": 21.0, "lines": ["高木さんは", "頼んだもの", "もらえてるの？"]}], "img_path": "062.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [622, 85, 702, 221], "vertical": true, "font_size": 21.0, "lines": ["毎年お母さんと", "一緒に買いに", "行くからね。"]}, {"box": [272, 79, 322, 201], "vertical": true, "font_size": 18.0, "lines": ["欲しいもの", "もらえてるよ。"]}, {"box": [25, 39, 50, 101], "vertical": true, "font_size": 25.0, "lines": ["ほう．．．"]}, {"box": [598, 457, 698, 611], "vertical": true, "font_size": 21.0, "lines": ["そうか．．．", "お母さんと行けば", "欲しいものが", "手に入るのか．．．"]}, {"box": [112, 448, 213, 602], "vertical": true, "font_size": 22.0, "lines": ["まぁ、ゲームは", "一緒に行っても", "買ってもらえない", "と思うけど。"]}, {"box": [663, 748, 694, 803], "vertical": true, "font_size": 31.0, "lines": ["な！！"]}, {"box": [141, 758, 190, 845], "vertical": true, "font_size": 22.0, "lines": ["あはは", "やっぱり。"]}, {"box": [340, 1004, 417, 1122], "vertical": true, "font_size": 22.0, "lines": ["くそ！！", "高木さんめ．．．", "見ていろ！！"]}, {"box": [192, 1010, 240, 1123], "vertical": true, "font_size": 22.0, "lines": ["今日こそ", "勝ってやる！！"]}], "img_path": "063.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [235, 356, 317, 476], "vertical": true, "font_size": 24.0, "lines": ["何も．．．", "思いつかない", "．．．！"]}, {"box": [112, 364, 169, 502], "vertical": true, "font_size": 28.0, "lines": ["高木さんにちょうに", "勝てる勝負が！！"]}, {"box": [695, 918, 738, 1032], "vertical": true, "font_size": 18.0, "lines": ["うーん．．．", "あれもダメ．．．"]}, {"box": [612, 905, 629, 1018], "vertical": true, "font_size": 18.0, "lines": ["これもダメ．．．"]}], "img_path": "064.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [708, 85, 735, 219], "vertical": true, "font_size": 17.0, "lines": ["何考えてるの？"]}, {"box": [354, 87, 410, 185], "vertical": true, "font_size": 21.0, "lines": ["いや．．．別に", "何も．．．！"]}, {"box": [263, 83, 285, 151], "vertical": true, "font_size": 21.0, "lines": ["ふーん。"]}], "img_path": "065.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [358, 679, 408, 802], "vertical": true, "font_size": 18.0, "lines": ["じゃあ私", "こっちだから。"]}, {"box": [111, 967, 158, 1053], "vertical": true, "font_size": 20.0, "lines": ["あ、うん", "じゃあね。"]}], "img_path": "066.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [183, 60, 268, 215], "vertical": true, "font_size": 23.0, "lines": ["結局．．．何も", "思いつかなかった", "な．．．"]}, {"box": [97, 498, 120, 584], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．"]}, {"box": [616, 927, 647, 1030], "vertical": true, "font_size": 24.0, "lines": ["高木さん。"]}], "img_path": "067.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [523, 64, 575, 179], "vertical": true, "font_size": 19.0, "lines": ["今年最後の", "勝負しない？"]}, {"box": [349, 42, 403, 176], "vertical": true, "font_size": 20.0, "lines": ["何も思いついて", "ないんだけど．．．"]}, {"box": [729, 689, 762, 782], "vertical": true, "font_size": 31.0, "lines": ["いいよ。"]}], "img_path": "068.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [88, 90, 353, 207], "vertical": false, "font_size": 32.0, "lines": ["ねん", "年末の"]}], "img_path": "069.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [653, 120, 708, 258], "vertical": true, "font_size": 22.0, "lines": ["私が勝負の内容", "決めていい？"]}, {"box": [777, 619, 810, 675], "vertical": true, "font_size": 32.0, "lines": ["え！？"]}, {"box": [552, 687, 577, 752], "vertical": true, "font_size": 25.0, "lines": ["ダメ？"]}, {"box": [374, 968, 477, 1057], "vertical": true, "font_size": 28.0, "lines": ["いや．．．", "いいけど。"]}, {"box": [114, 971, 167, 1087], "vertical": true, "font_size": 20.0, "lines": ["何も思いつか", "なかったし．．．"]}], "img_path": "070.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [713, 132, 732, 229], "vertical": true, "font_size": 17.0, "lines": ["じゃあー"]}, {"box": [467, 148, 489, 255], "vertical": true, "font_size": 20.0, "lines": ["そうだなー。"]}, {"box": [253, 154, 336, 254], "vertical": true, "font_size": 24.0, "lines": ["何が来る．．．", "今年最後の", "勝負．．"]}, {"box": [82, 52, 371, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんＱ"]}, {"box": [56, 140, 92, 183], "vertical": true, "font_size": 30.0, "lines": ["ん。"]}, {"box": [383, 671, 465, 788], "vertical": true, "font_size": 24.0, "lines": ["相手を", "喜ばせた方の", "勝ちね。"]}], "img_path": "071.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [697, 126, 723, 173], "vertical": true, "font_size": 26.0, "lines": ["え？"]}, {"box": [421, 165, 502, 303], "vertical": true, "font_size": 25.0, "lines": ["今からそれぞれ", "喜ばせ方", "考えて、"]}, {"box": [153, 148, 207, 271], "vertical": true, "font_size": 22.0, "lines": ["３０分後に", "空き地で勝負。"]}, {"box": [702, 597, 720, 662], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．"]}, {"box": [393, 574, 445, 745], "vertical": true, "font_size": 19.0, "lines": ["それって勝ち負けの", "判定どうするの？"]}, {"box": [308, 582, 331, 642], "vertical": true, "font_size": 23.0, "lines": ["んー"]}, {"box": [657, 890, 741, 1037], "vertical": true, "font_size": 23.0, "lines": ["まぁ点数とかで", "いいんじゃない", "かなー。"]}, {"box": [147, 925, 195, 1005], "vertical": true, "font_size": 20.0, "lines": ["テキトー", "だなぁ．．．"]}], "img_path": "072.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [395, 102, 418, 174], "vertical": true, "font_size": 22.0, "lines": ["どう？"]}, {"box": [57, 50, 78, 126], "vertical": true, "font_size": 20.0, "lines": ["あれ．．．？"]}, {"box": [624, 605, 647, 708], "vertical": true, "font_size": 21.0, "lines": ["い、いいよ。"]}, {"box": [162, 624, 214, 710], "vertical": true, "font_size": 24.0, "lines": ["やった、", "決まりね。"]}, {"box": [603, 933, 702, 1050], "vertical": true, "font_size": 25.0, "lines": ["これ．．", "勝てるんじゃ", "ないか？"]}], "img_path": "073.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [665, 96, 769, 290], "vertical": true, "font_size": 22.0, "lines": ["だって", "喜んでないフリして", "低い点数つけるだけで", "オレの勝ちだろ。"]}, {"box": [112, 86, 228, 282], "vertical": true, "font_size": 32.0, "lines": ["ヨユーで", "今年を勝ちで", "締めくくれる！！"]}, {"box": [632, 589, 739, 705], "vertical": true, "font_size": 20.0, "lines": ["今年最後に", "こんなヘマを", "するとはね", "高木さん．．．"]}, {"box": [472, 832, 524, 937], "vertical": true, "font_size": 24.0, "lines": ["あぁ、", "空き地でね。"]}, {"box": [166, 588, 219, 724], "vertical": true, "font_size": 22.0, "lines": ["じゃあ３０分後に", "空き地でね。"]}, {"box": [670, 829, 749, 983], "vertical": true, "font_size": 22.0, "lines": ["花でも摘んで", "空き地でダラダラ", "しておくか。"]}], "img_path": "074.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [336, 113, 390, 200], "vertical": true, "font_size": 21.0, "lines": ["楽しみに", "してるね。"]}], "img_path": "075.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [657, 147, 740, 250], "vertical": true, "font_size": 19.0, "lines": ["高木さんて", "どんなので", "喜ぶんだろ。"]}, {"box": [275, 112, 356, 247], "vertical": true, "font_size": 20.0, "lines": ["高木さんが", "うれしそうな顔", "してる時って．．．"]}, {"box": [267, 761, 413, 847], "vertical": false, "font_size": 32.0, "lines": ["からかってい"]}, {"box": [674, 1010, 729, 1109], "vertical": true, "font_size": 25.0, "lines": ["いや．．．絶対", "違うな。"]}], "img_path": "076.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [356, 107, 381, 191], "vertical": true, "font_size": 24.0, "lines": ["うーん。"]}, {"box": [666, 662, 720, 776], "vertical": true, "font_size": 18.0, "lines": ["西片が喜ぶ", "ことかー", "．．．"]}, {"box": [479, 648, 532, 783], "vertical": true, "font_size": 18.0, "lines": ["いざ考えると", "むずかしいなー。"]}, {"box": [335, 986, 359, 1048], "vertical": true, "font_size": 24.0, "lines": ["んー"]}], "img_path": "077.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [513, 275, 557, 388], "vertical": true, "font_size": 18.0, "lines": ["いろいろ", "考えたけど．．"]}, {"box": [156, 331, 207, 412], "vertical": true, "font_size": 23.0, "lines": ["ここ", "かなぁ．．．"]}, {"box": [438, 779, 497, 840], "vertical": true, "font_size": 32.0, "lines": ["あ、", "西片。"]}], "img_path": "078.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [722, 117, 750, 213], "vertical": true, "font_size": 20.0, "lines": ["高木さん！？"]}, {"box": [82, 51, 371, 73], "vertical": false, "font_size": 21.0, "lines": ["からかいと手の高ホさんＱ"]}, {"box": [490, 344, 536, 430], "vertical": true, "font_size": 20.0, "lines": ["あはは", "奇遇だね。"]}, {"box": [658, 594, 731, 726], "vertical": true, "font_size": 19.0, "lines": ["喜ばせるなら", "プレゼントじゃ", "ないかなー．．．"]}, {"box": [545, 603, 588, 717], "vertical": true, "font_size": 19.0, "lines": ["てもそんなに", "お金はない．．．"]}, {"box": [182, 594, 258, 766], "vertical": true, "font_size": 20.0, "lines": ["ここなら", "ジュースもおかしも", "割りと安いから．．．"]}, {"box": [97, 663, 121, 796], "vertical": true, "font_size": 20.0, "lines": ["って感じかな？"]}, {"box": [399, 902, 446, 1034], "vertical": true, "font_size": 18.0, "lines": ["なんでいつも", "バレてるんだ．．．"]}, {"box": [319, 896, 349, 982], "vertical": true, "font_size": 22.0, "lines": ["図星だー。"]}, {"box": [107, 898, 123, 959], "vertical": true, "font_size": 16.0, "lines": ["．．．"]}], "img_path": "079.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [392, 165, 446, 255], "vertical": true, "font_size": 26.0, "lines": ["私も", "なんだよ。"]}, {"box": [661, 587, 714, 694], "vertical": true, "font_size": 24.0, "lines": ["そ．．．", "そうなんだ。"]}, {"box": [571, 862, 599, 930], "vertical": true, "font_size": 25.0, "lines": ["へぇー。"]}, {"box": [144, 591, 173, 645], "vertical": true, "font_size": 27.0, "lines": ["うん。"]}, {"box": [320, 855, 346, 970], "vertical": true, "font_size": 20.0, "lines": ["見ないでよ！"]}, {"box": [104, 880, 124, 946], "vertical": true, "font_size": 20.0, "lines": ["あはは。"]}], "img_path": "080.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [626, 339, 699, 493], "vertical": true, "font_size": 19.0, "lines": ["わざわざ", "ここまで来る必要", "なかったんじゃ．．．"]}, {"box": [323, 341, 397, 473], "vertical": true, "font_size": 21.0, "lines": ["まぁまぁ、", "そういうルール", "だったし。"]}, {"box": [160, 288, 233, 467], "vertical": true, "font_size": 20.0, "lines": ["オレが買ったのは", "高木さんがよく", "飲んでるジュースと、"]}, {"box": [44, 291, 90, 444], "vertical": true, "font_size": 20.0, "lines": ["誰でも大好き", "ポテチのコンポ．．．"]}, {"box": [673, 789, 699, 867], "vertical": true, "font_size": 26.0, "lines": ["これは、"]}, {"box": [169, 803, 198, 932], "vertical": true, "font_size": 24.0, "lines": ["勝っただろ。"]}, {"box": [634, 1033, 656, 1099], "vertical": true, "font_size": 22.0, "lines": ["じゃあ、"]}, {"box": [402, 1060, 565, 1103], "vertical": false, "font_size": 22.0, "lines": ["つとかあわせじゃない", "いろいろな"]}, {"box": [203, 1046, 258, 1115], "vertical": true, "font_size": 24.0, "lines": ["私から", "渡すね。"]}], "img_path": "081.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [653, 110, 708, 236], "vertical": true, "font_size": 24.0, "lines": ["メリー", "クリスマス。"]}, {"box": [367, 502, 518, 520], "vertical": false, "font_size": 15.0, "lines": ["そうでしょうがないんだから"]}, {"box": [527, 652, 574, 768], "vertical": true, "font_size": 20.0, "lines": ["そ．．．そういう", "やつなの！？"]}, {"box": [127, 656, 181, 773], "vertical": true, "font_size": 22.0, "lines": ["細かいことは", "気にしない。"]}], "img_path": "082.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [684, 84, 707, 201], "vertical": true, "font_size": 20.0, "lines": ["ありがとう．．．"]}, {"box": [190, 46, 268, 216], "vertical": true, "font_size": 20.0, "lines": ["夢のときはこんなに", "恥ずかしくなかった", "のに．．．"]}, {"box": [712, 496, 732, 576], "vertical": true, "font_size": 20.0, "lines": ["じゃあ．．．"]}, {"box": [583, 489, 611, 540], "vertical": true, "font_size": 28.0, "lines": ["これ、"]}, {"box": [533, 350, 576, 372], "vertical": false, "font_size": 22.0, "lines": ["おまえのお母さんのおお"]}, {"box": [458, 504, 478, 589], "vertical": true, "font_size": 19.0, "lines": ["オレから。"]}, {"box": [98, 513, 119, 599], "vertical": true, "font_size": 16.0, "lines": ["ありがと"]}, {"box": [419, 996, 472, 1021], "vertical": false, "font_size": 14.0, "lines": ["これから", "いや．．．"]}], "img_path": "083.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [776, 53, 803, 99], "vertical": true, "font_size": 27.0, "lines": ["ひ．．．"]}, {"box": [410, 90, 469, 195], "vertical": true, "font_size": 23.0, "lines": ["引き分けに", "しない？"]}, {"box": [124, 99, 148, 167], "vertical": true, "font_size": 24.0, "lines": ["いいよ。"]}, {"box": [597, 889, 673, 1014], "vertical": true, "font_size": 21.0, "lines": ["じゃあ今年", "最後の下校を", "再開しよっか。"]}, {"box": [200, 901, 243, 987], "vertical": true, "font_size": 19.0, "lines": ["．．．", "そうだね．．．"]}], "img_path": "084.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "085.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [439, 69, 462, 111], "vertical": true, "font_size": 23.0, "lines": ["ん？"]}, {"box": [699, 508, 745, 605], "vertical": true, "font_size": 18.0, "lines": ["なんだ．．．？", "木村から？"]}, {"box": [445, 512, 486, 566], "vertical": true, "font_size": 32.0, "lines": ["わ。"]}, {"box": [275, 498, 361, 564], "vertical": false, "font_size": 32.0, "lines": ["木村"]}, {"box": [705, 887, 732, 929], "vertical": true, "font_size": 26.0, "lines": ["な．．"]}, {"box": [611, 892, 664, 982], "vertical": true, "font_size": 26.0, "lines": ["何送って", "きてんだ。"]}, {"box": [210, 908, 228, 941], "vertical": true, "font_size": 18.0, "lines": ["！"]}], "img_path": "086.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [442, 225, 551, 290], "vertical": false, "font_size": 24.0, "lines": ["うででした"]}, {"box": [310, 58, 384, 155], "vertical": true, "font_size": 21.0, "lines": ["なんて", "くだらない", "ことを．．．"]}, {"box": [632, 378, 731, 512], "vertical": true, "font_size": 19.0, "lines": ["いや．．．でもこれ", "高木さんを", "からかうのに", "使えるんじゃ．．．"]}, {"box": [330, 383, 347, 414], "vertical": true, "font_size": 17.0, "lines": ["！"]}, {"box": [240, 369, 270, 467], "vertical": true, "font_size": 21.0, "lines": ["高木さん．．．"]}, {"box": [96, 389, 193, 435], "vertical": false, "font_size": 32.0, "lines": ["高木さん"]}, {"box": [107, 467, 209, 512], "vertical": false, "font_size": 25.0, "lines": ["今何してる"]}, {"box": [236, 587, 256, 611], "vertical": false, "font_size": 24.0, "lines": ["さ"]}, {"box": [700, 701, 753, 829], "vertical": true, "font_size": 25.0, "lines": ["ナイス", "タイミングだ。"]}, {"box": [530, 710, 579, 813], "vertical": true, "font_size": 22.0, "lines": ["さっそく", "今の画像を、"]}, {"box": [453, 706, 488, 781], "vertical": true, "font_size": 32.0, "lines": ["送信！！"]}, {"box": [156, 605, 176, 626], "vertical": false, "font_size": 21.0, "lines": ["あ"]}], "img_path": "087.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [746, 69, 797, 178], "vertical": true, "font_size": 24.0, "lines": ["「それ", "知ってるよ」"]}, {"box": [386, 73, 413, 126], "vertical": true, "font_size": 27.0, "lines": ["っと。"]}, {"box": [267, 64, 310, 157], "vertical": true, "font_size": 19.0, "lines": ["く．．．さすが", "高木さんだ"]}, {"box": [677, 486, 745, 594], "vertical": true, "font_size": 20.0, "lines": ["さて．．．", "どうやって", "からかおう．．．"]}, {"box": [339, 501, 442, 638], "vertical": true, "font_size": 25.0, "lines": ["そうだ、", "木村なら何か", "他にも知ってる", "かも．．．"]}, {"box": [678, 774, 712, 850], "vertical": true, "font_size": 30.0, "lines": ["早っ！！"]}, {"box": [135, 773, 191, 878], "vertical": true, "font_size": 20.0, "lines": ["と思ったら", "高木さんか。"]}, {"box": [656, 990, 735, 1073], "vertical": true, "font_size": 28.0, "lines": ["ステーキ", "好き？", "嫌い？"]}, {"box": [148, 989, 171, 1085], "vertical": true, "font_size": 20.0, "lines": ["ステーキ？"]}], "img_path": "088.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [707, 77, 752, 165], "vertical": true, "font_size": 22.0, "lines": ["いや", "そりゃあ．．．"]}, {"box": [461, 58, 517, 159], "vertical": true, "font_size": 28.0, "lines": ["「好きだよ」", "っと。"]}, {"box": [386, 64, 420, 113], "vertical": true, "font_size": 32.0, "lines": ["迷．．．"]}, {"box": [631, 365, 684, 487], "vertical": true, "font_size": 20.0, "lines": ["待て待て！！", "これだけだと、"]}, {"box": [377, 539, 412, 562], "vertical": false, "font_size": 13.0, "lines": ["木さん"]}, {"box": [103, 455, 182, 607], "vertical": true, "font_size": 20.0, "lines": ["なんか告白してる", "みたいになって", "ないか！？"]}, {"box": [693, 896, 747, 1012], "vertical": true, "font_size": 21.0, "lines": ["危ないところ", "だった．．．"]}, {"box": [459, 894, 476, 940], "vertical": true, "font_size": 17.0, "lines": ["．．．．．"]}, {"box": [94, 877, 117, 928], "vertical": true, "font_size": 23.0, "lines": ["よし。"]}], "img_path": "089.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [721, 210, 741, 277], "vertical": true, "font_size": 20.0, "lines": ["あはは。"]}, {"box": [214, 32, 667, 114], "vertical": false, "font_size": 32.0, "lines": ["好きだよ（ステーキ）"]}, {"box": [377, 210, 426, 352], "vertical": true, "font_size": 23.0, "lines": ["やっぱり", "こう返してきた。"]}, {"box": [274, 234, 325, 297], "vertical": true, "font_size": 26.0, "lines": ["じゃあ", "次は、"]}, {"box": [130, 225, 181, 351], "vertical": true, "font_size": 22.0, "lines": ["「ハートマーク", "は好き？」"]}, {"box": [106, 396, 128, 440], "vertical": true, "font_size": 22.0, "lines": ["っと。"]}, {"box": [693, 734, 713, 867], "vertical": true, "font_size": 20.0, "lines": ["ハートマーク？"]}, {"box": [99, 718, 203, 843], "vertical": true, "font_size": 24.0, "lines": ["いや．．．", "好きでも", "嫌いでも", "ないんだけど。"]}, {"box": [248, 1025, 626, 1093], "vertical": false, "font_size": 32.0, "lines": ["ートマーク", "普通かな！"]}], "img_path": "090.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [281, 53, 386, 206], "vertical": true, "font_size": 21.0, "lines": ["なんか最後に", "ハートマーク", "つけてるみたいに", "なってる！！"]}, {"box": [44, 53, 81, 200], "vertical": true, "font_size": 28.0, "lines": ["危ねえええ。"]}, {"box": [199, 353, 578, 445], "vertical": false, "font_size": 32.0, "lines": ["別にハートマークは好きな", "でもキライでもないかな"]}, {"box": [616, 563, 662, 678], "vertical": true, "font_size": 20.0, "lines": ["ひっかからな", "かったかー。"]}, {"box": [173, 571, 223, 697], "vertical": true, "font_size": 22.0, "lines": ["そりゃ", "そうだよねー。"]}, {"box": [721, 888, 745, 954], "vertical": true, "font_size": 22.0, "lines": ["じゃあ、"]}, {"box": [440, 888, 469, 950], "vertical": true, "font_size": 25.0, "lines": ["次は："]}, {"box": [366, 883, 407, 953], "vertical": true, "font_size": 32.0, "lines": ["何か．．"]}, {"box": [92, 896, 158, 968], "vertical": true, "font_size": 32.0, "lines": ["何か", "ないか。"]}], "img_path": "091.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [715, 76, 795, 172], "vertical": true, "font_size": 18.0, "lines": ["高木さんを", "からかえる", "ような．．．"]}, {"box": [406, 84, 461, 208], "vertical": true, "font_size": 20.0, "lines": ["くそ．．．木村は", "何してるんだ。"]}, {"box": [584, 539, 609, 630], "vertical": true, "font_size": 25.0, "lines": ["いける！！"]}, {"box": [482, 776, 522, 828], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [408, 771, 454, 823], "vertical": true, "font_size": 32.0, "lines": ["あ、"]}, {"box": [248, 543, 305, 658], "vertical": true, "font_size": 24.0, "lines": ["これは", "いけるぞ！！"]}, {"box": [118, 733, 339, 869], "vertical": false, "font_size": 32.0, "lines": ["キスって好き？"]}], "img_path": "092.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [681, 90, 733, 196], "vertical": true, "font_size": 20.0, "lines": ["先にやられ", "ちゃったか。"]}, {"box": [304, 82, 333, 135], "vertical": true, "font_size": 27.0, "lines": ["ふふ。"]}, {"box": [683, 514, 705, 582], "vertical": true, "font_size": 21.0, "lines": ["ふふふ。"]}, {"box": [121, 491, 181, 594], "vertical": true, "font_size": 26.0, "lines": ["どうだい", "高木さん。"]}, {"box": [673, 771, 745, 885], "vertical": true, "font_size": 19.0, "lines": ["もちろん", "キスってのは", "魚のことさ、"]}, {"box": [418, 772, 471, 894], "vertical": true, "font_size": 20.0, "lines": ["勘違いして", "慌てるがいい"]}], "img_path": "093.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [779, 56, 798, 104], "vertical": true, "font_size": 19.0, "lines": ["．．．．．"]}, {"box": [670, 114, 698, 182], "vertical": true, "font_size": 24.0, "lines": ["遅いな。"]}, {"box": [569, 83, 619, 200], "vertical": true, "font_size": 22.0, "lines": ["慌てて", "いるのかな．．．"]}, {"box": [319, 64, 340, 131], "vertical": true, "font_size": 21.0, "lines": ["ふふふ。"]}, {"box": [662, 464, 735, 616], "vertical": true, "font_size": 19.0, "lines": ["もしかして．．．", "魚のことって", "わかってなくて．．．"]}, {"box": [108, 461, 183, 601], "vertical": true, "font_size": 32.0, "lines": ["引かれて", "いる．．．？！？"]}, {"box": [678, 793, 743, 931], "vertical": true, "font_size": 16.0, "lines": ["だとしたらオレ", "すごく恥ずかしい", "ことをしたのか．．．"]}, {"box": [373, 780, 439, 912], "vertical": true, "font_size": 32.0, "lines": ["高木さん．．．！！", "早く返事を。"]}, {"box": [274, 794, 304, 863], "vertical": true, "font_size": 25.0, "lines": ["来た！！"]}], "img_path": "094.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [504, 90, 700, 284], "vertical": false, "font_size": 32.0, "lines": ["えくぼうにえるように", "おにー", "喉の"]}, {"box": [255, 64, 279, 143], "vertical": true, "font_size": 24.0, "lines": ["くっ．．．"]}, {"box": [613, 357, 646, 428], "vertical": true, "font_size": 30.0, "lines": ["来た！！"]}, {"box": [149, 367, 213, 495], "vertical": true, "font_size": 27.0, "lines": ["今度こそ", "高木さんだ。"]}, {"box": [701, 896, 737, 1007], "vertical": true, "font_size": 30.0, "lines": ["動画．．．？"]}], "img_path": "095.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [651, 520, 694, 662], "vertical": true, "font_size": 32.0, "lines": ["好きだよ。"]}], "img_path": "096.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [531, 42, 557, 110], "vertical": true, "font_size": 26.0, "lines": ["ピロン"]}, {"box": [156, 93, 463, 167], "vertical": false, "font_size": 32.0, "lines": ["カオ赤いよ？"]}, {"box": [716, 386, 743, 432], "vertical": true, "font_size": 27.0, "lines": ["あ．．．"]}, {"box": [441, 391, 476, 558], "vertical": true, "font_size": 28.0, "lines": ["「赤くないよ！！」"]}, {"box": [302, 396, 377, 526], "vertical": true, "font_size": 22.0, "lines": ["「ホントかなー", "じゃあ今写真", "とってみてよ」"]}, {"box": [278, 900, 547, 943], "vertical": false, "font_size": 31.0, "lines": ["とってみてよ"]}, {"box": [306, 992, 586, 1042], "vertical": false, "font_size": 32.0, "lines": ["やめとくよ・"]}, {"box": [185, 908, 222, 949], "vertical": true, "font_size": 32.0, "lines": ["！！"]}], "img_path": "097.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [782, 62, 809, 107], "vertical": true, "font_size": 27.0, "lines": ["や．．．"]}, {"box": [500, 103, 520, 219], "vertical": true, "font_size": 20.0, "lines": ["やられた．．．"]}, {"box": [395, 106, 425, 204], "vertical": true, "font_size": 22.0, "lines": ["完璧に．．．"]}, {"box": [626, 493, 706, 631], "vertical": true, "font_size": 26.0, "lines": ["とか", "思ってるかなー", "今ごろ。"]}, {"box": [695, 892, 749, 1038], "vertical": true, "font_size": 26.0, "lines": ["顔", "見たかったなー。"]}, {"box": [122, 890, 180, 1023], "vertical": true, "font_size": 28.0, "lines": ["大体", "想像つくけど。"]}], "img_path": "098.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [684, 97, 737, 233], "vertical": true, "font_size": 20.0, "lines": ["ごはん作るから", "手伝ってー。"]}, {"box": [383, 65, 465, 145], "vertical": true, "font_size": 25.0, "lines": ["はーい。"]}, {"box": [250, 421, 649, 626], "vertical": false, "font_size": 32.0, "lines": ["て", "の", "その．．．んねばくた", "時間だから", "ごはんの時間だからいくね！！また明日学校でね。"]}, {"box": [381, 680, 705, 731], "vertical": false, "font_size": 32.0, "lines": ["うん。じゃあまた明日"]}, {"box": [299, 853, 318, 901], "vertical": true, "font_size": 19.0, "lines": ["．．．"]}, {"box": [113, 869, 138, 919], "vertical": true, "font_size": 23.0, "lines": ["まぁ、"]}, {"box": [651, 846, 731, 988], "vertical": true, "font_size": 22.0, "lines": ["西片の顔", "真っ赤に", "なってるかなー。"]}], "img_path": "099.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [678, 140, 753, 316], "vertical": true, "font_size": 29.0, "lines": ["私も人のこと", "言えないけど。"]}, {"box": [650, 962, 704, 1096], "vertical": true, "font_size": 22.0, "lines": ["結局、なんの用", "だったんだ。"]}, {"box": [231, 991, 260, 1096], "vertical": true, "font_size": 20.0, "lines": ["高木さんは。"]}], "img_path": "100.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [77, 1073, 474, 1115], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さん"]}], "img_path": "101.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "102.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "103.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [620, 643, 698, 758], "vertical": true, "font_size": 23.0, "lines": ["おっと、", "高木さんじゃ", "ないか。"]}, {"box": [504, 672, 561, 730], "vertical": true, "font_size": 32.0, "lines": ["あ、", "西片。"]}, {"box": [171, 655, 196, 723], "vertical": true, "font_size": 25.0, "lines": ["ふふふ。"]}, {"box": [540, 1010, 586, 1094], "vertical": true, "font_size": 20.0, "lines": ["こんな", "ところで、"]}, {"box": [104, 991, 160, 1066], "vertical": true, "font_size": 28.0, "lines": ["偶然", "だねぇ。"]}], "img_path": "104.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [661, 115, 738, 256], "vertical": true, "font_size": 21.0, "lines": ["実はここを", "通るのは", "知っていたのさ。"]}, {"box": [271, 87, 385, 230], "vertical": true, "font_size": 25.0, "lines": ["昨日、いわ", "会話をチラっと", "聞いてしまって", "いたからね"]}, {"box": [708, 525, 733, 591], "vertical": true, "font_size": 25.0, "lines": ["そして、"]}, {"box": [115, 533, 170, 636], "vertical": true, "font_size": 20.0, "lines": ["今日こそ", "オレが勝つ。"]}, {"box": [724, 789, 747, 821], "vertical": true, "font_size": 23.0, "lines": ["て、"]}, {"box": [479, 788, 531, 904], "vertical": true, "font_size": 20.0, "lines": ["どこ行くの？", "西片は。"]}, {"box": [344, 778, 430, 1006], "vertical": true, "font_size": 20.0, "lines": ["まぁ適当に", "ブラブラしてる", "だけだよ。"]}, {"box": [103, 796, 127, 864], "vertical": true, "font_size": 24.0, "lines": ["ふーん。"]}], "img_path": "105.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [729, 77, 784, 194], "vertical": true, "font_size": 20.0, "lines": ["こんな所を？", "珍しくない？"]}, {"box": [347, 52, 434, 157], "vertical": true, "font_size": 20.0, "lines": ["とりあえず、"]}, {"box": [112, 78, 165, 213], "vertical": true, "font_size": 17.0, "lines": ["偶然会ったのも", "何かの縁だし．．．"]}, {"box": [680, 462, 733, 542], "vertical": true, "font_size": 20.0, "lines": ["勝負でも", "しない？"]}, {"box": [197, 424, 265, 517], "vertical": true, "font_size": 26.0, "lines": ["いいよ。"]}, {"box": [104, 433, 132, 510], "vertical": true, "font_size": 20.0, "lines": ["何する？"]}, {"box": [510, 858, 563, 938], "vertical": true, "font_size": 20.0, "lines": ["考える", "フリを．．．"]}, {"box": [449, 856, 470, 920], "vertical": true, "font_size": 21.0, "lines": ["そして、"]}, {"box": [720, 861, 743, 967], "vertical": true, "font_size": 20.0, "lines": ["そうだなぁ。"]}, {"box": [101, 861, 156, 976], "vertical": true, "font_size": 20.0, "lines": ["今思いついた", "フリを"]}, {"box": [185, 1032, 206, 1099], "vertical": true, "font_size": 21.0, "lines": ["じゃあ、"]}], "img_path": "106.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [638, 78, 733, 219], "vertical": true, "font_size": 27.0, "lines": ["あの木まで", "何歩かかるか", "予想して、"]}, {"box": [203, 106, 301, 205], "vertical": true, "font_size": 28.0, "lines": ["近い方が", "勝ちって", "どう？"]}, {"box": [67, 103, 92, 172], "vertical": true, "font_size": 25.0, "lines": ["ふーん。"]}, {"box": [692, 671, 739, 815], "vertical": true, "font_size": 20.0, "lines": ["それじゃあ", "ちょっと近いし、"]}, {"box": [590, 671, 636, 803], "vertical": true, "font_size": 20.0, "lines": ["向こうの電柱", "までにしない？"]}, {"box": [112, 694, 153, 742], "vertical": true, "font_size": 32.0, "lines": ["え。"]}, {"box": [709, 998, 734, 1060], "vertical": true, "font_size": 25.0, "lines": ["ダメ？"]}, {"box": [265, 985, 319, 1055], "vertical": true, "font_size": 28.0, "lines": ["いや．．．", "いいよ。"]}, {"box": [111, 998, 162, 1094], "vertical": true, "font_size": 20.0, "lines": ["そう来たか", "高木さん．．．"]}], "img_path": "107.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [720, 108, 760, 258], "vertical": true, "font_size": 28.0, "lines": ["計算通りだ。"]}, {"box": [646, 523, 677, 605], "vertical": true, "font_size": 23.0, "lines": ["思って、"]}, {"box": [451, 519, 568, 658], "vertical": true, "font_size": 23.0, "lines": ["あらかじめ", "電柱までの", "歩数を数えて", "おいたのさ。"]}, {"box": [213, 439, 326, 533], "vertical": true, "font_size": 18.0, "lines": ["これはズル", "ではない！！", "決めたのは", "高木さん", "なのだから"]}, {"box": [97, 500, 123, 549], "vertical": true, "font_size": 26.0, "lines": ["んー。"]}, {"box": [648, 525, 710, 708], "vertical": true, "font_size": 20.0, "lines": ["そう来るだろうと"]}, {"box": [96, 856, 141, 935], "vertical": true, "font_size": 32.0, "lines": ["な！！"]}, {"box": [380, 904, 482, 1000], "vertical": true, "font_size": 22.0, "lines": ["やっぱり", "２本先の", "電柱までに", "しよっか。"]}], "img_path": "108.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [701, 93, 752, 174], "vertical": true, "font_size": 24.0, "lines": ["な．．．", "なんで？"]}, {"box": [575, 73, 600, 135], "vertical": true, "font_size": 25.0, "lines": ["ダメ？"]}, {"box": [333, 83, 410, 169], "vertical": true, "font_size": 24.0, "lines": ["いや．．．", "ダメじゃ", "ないけど。"]}, {"box": [71, 62, 118, 148], "vertical": true, "font_size": 20.0, "lines": ["じゃあ", "決まりね。"]}, {"box": [639, 485, 746, 660], "vertical": true, "font_size": 28.0, "lines": ["いや．．．", "落ち着け．．．", "１本目の電柱までは", "３５歩．．．"]}, {"box": [543, 488, 605, 597], "vertical": true, "font_size": 28.0, "lines": ["単純にはい", "２倍すれば。"]}, {"box": [107, 491, 159, 560], "vertical": true, "font_size": 26.0, "lines": ["じゃあ、", "７０歩で。"]}, {"box": [712, 814, 741, 894], "vertical": true, "font_size": 20.0, "lines": ["西片は？"]}, {"box": [326, 783, 399, 937], "vertical": true, "font_size": 22.0, "lines": ["くそ．．．なんて", "いいところを", "ついてくるんだ．．．"]}, {"box": [108, 665, 152, 711], "vertical": true, "font_size": 32.0, "lines": ["！？"]}, {"box": [105, 798, 133, 901], "vertical": true, "font_size": 20.0, "lines": ["高木さんめ。"]}], "img_path": "109.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [746, 66, 798, 148], "vertical": true, "font_size": 26.0, "lines": ["じゃあ．．．", "７２歩．．．"]}, {"box": [490, 62, 518, 117], "vertical": true, "font_size": 26.0, "lines": ["うん。"]}, {"box": [407, 60, 453, 134], "vertical": true, "font_size": 24.0, "lines": ["じゃあ", "行くよー"]}, {"box": [353, 42, 378, 105], "vertical": true, "font_size": 24.0, "lines": ["いーち。"]}, {"box": [96, 65, 115, 130], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．？"]}, {"box": [693, 535, 733, 604], "vertical": true, "font_size": 32.0, "lines": ["３４ー。"]}, {"box": [339, 542, 369, 596], "vertical": true, "font_size": 27.0, "lines": ["３５ー。"]}, {"box": [674, 798, 755, 950], "vertical": true, "font_size": 21.0, "lines": ["１本目の電柱で．．．", "５５歩を超えてる", "．．．！！"]}, {"box": [458, 798, 478, 877], "vertical": true, "font_size": 19.0, "lines": ["これは．．"]}, {"box": [112, 796, 139, 881], "vertical": true, "font_size": 21.0, "lines": ["勝てるぞ。"]}, {"box": [114, 1089, 144, 1139], "vertical": true, "font_size": 27.0, "lines": ["３８ー。"]}], "img_path": "110.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [654, 64, 705, 164], "vertical": true, "font_size": 26.0, "lines": ["そういえば", "西片。"]}, {"box": [442, 105, 497, 174], "vertical": true, "font_size": 28.0, "lines": ["会った", "のって、"]}, {"box": [59, 124, 126, 201], "vertical": true, "font_size": 32.0, "lines": ["本当に", "偶然？"]}, {"box": [729, 558, 748, 623], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．？"]}, {"box": [730, 760, 748, 863], "vertical": true, "font_size": 15.0, "lines": ["そうだけど．．．"]}, {"box": [303, 560, 411, 660], "vertical": true, "font_size": 26.0, "lines": ["だって", "私の行き先", "聞いてない", "のに、"]}, {"box": [441, 759, 462, 836], "vertical": true, "font_size": 20.0, "lines": ["なんで？"]}, {"box": [96, 551, 175, 685], "vertical": true, "font_size": 19.0, "lines": ["こっちの方向で", "勝負しかけて", "きたから。"]}, {"box": [666, 1008, 698, 1071], "vertical": true, "font_size": 32.0, "lines": ["あ．．．"]}, {"box": [121, 984, 144, 1086], "vertical": true, "font_size": 21.0, "lines": ["しまった。"]}], "img_path": "111.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [488, 154, 561, 251], "vertical": true, "font_size": 23.0, "lines": ["もしかして", "私の行き先", "知ってて．．．"]}, {"box": [97, 113, 141, 209], "vertical": true, "font_size": 16.0, "lines": ["な．．．なんの", "ことやら．．．"]}, {"box": [693, 536, 741, 643], "vertical": true, "font_size": 24.0, "lines": ["それってさぁ", "西片。"]}, {"box": [366, 251, 440, 369], "vertical": true, "font_size": 23.0, "lines": ["わざわざ", "ここで", "待ってたの？"]}, {"box": [373, 536, 392, 623], "vertical": true, "font_size": 17.0, "lines": ["それって．．"]}, {"box": [566, 889, 679, 1072], "vertical": true, "font_size": 31.0, "lines": ["ストーカーと", "いうやつに", "なるのでは；"]}], "img_path": "112.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [693, 78, 738, 192], "vertical": true, "font_size": 20.0, "lines": ["いやいや．．．！！", "偶然だよ！！"]}, {"box": [446, 77, 500, 192], "vertical": true, "font_size": 19.0, "lines": ["行き先も．．", "なんとなく．．．"]}, {"box": [351, 56, 401, 161], "vertical": true, "font_size": 22.0, "lines": ["なんか", "怪しいなぁ。"]}, {"box": [101, 101, 172, 216], "vertical": true, "font_size": 19.0, "lines": ["そ．．．それより", "勝負の続き", "しようよ。"]}, {"box": [667, 488, 742, 569], "vertical": true, "font_size": 22.0, "lines": ["さっさと", "しないと", "約束に．．．"]}, {"box": [343, 487, 421, 602], "vertical": true, "font_size": 21.0, "lines": ["なんで誰かと", "約束あるって", "知ってるの？"]}, {"box": [706, 868, 731, 1018], "vertical": true, "font_size": 23.0, "lines": ["しまったぁあ。"]}], "img_path": "113.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [735, 62, 779, 174], "vertical": true, "font_size": 20.0, "lines": ["やっぱり", "知ってたんだ。"]}, {"box": [400, 85, 454, 150], "vertical": true, "font_size": 28.0, "lines": ["いや．．．", "あの．．．"]}, {"box": [281, 52, 336, 172], "vertical": true, "font_size": 26.0, "lines": ["それってさぁ", "西片。"]}, {"box": [500, 390, 745, 664], "vertical": true, "font_size": 32.0, "lines": ["ストーカー", "カーカー", "〈トーカ"]}, {"box": [95, 400, 366, 658], "vertical": true, "font_size": 32.0, "lines": ["ストー", "ーカー", "ストーカ・"]}, {"box": [697, 746, 728, 842], "vertical": true, "font_size": 24.0, "lines": ["私のこと、"]}, {"box": [193, 768, 222, 887], "vertical": true, "font_size": 22.0, "lines": ["好