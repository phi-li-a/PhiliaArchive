": 32.0, "lines": ["「可愛らしい」", "しか．．．"]}, {"box": [166, 903, 203, 1079], "vertical": true, "font_size": 28.0, "lines": ["出てこない．．．"]}], "img_path": "034.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [440, 103, 467, 153], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [304, 79, 380, 159], "vertical": true, "font_size": 24.0, "lines": ["ゴメン．．．", "やっぱり", "なしで．．．"]}, {"box": [77, 84, 98, 145], "vertical": true, "font_size": 21.0, "lines": ["んー？"]}, {"box": [650, 554, 699, 657], "vertical": true, "font_size": 22.0, "lines": ["聞かせて", "欲しいなー。"]}, {"box": [145, 573, 194, 651], "vertical": true, "font_size": 23.0, "lines": ["いや．．．", "それは．．．"]}], "img_path": "035.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [397, 543, 480, 676], "vertical": true, "font_size": 24.0, "lines": ["誰かが", "私たちの噂話", "してるのかな。"]}, {"box": [602, 897, 702, 1022], "vertical": true, "font_size": 23.0, "lines": ["あはは", "西片今日、", "顔赤く", "なりすぎだよ。"]}, {"box": [164, 874, 244, 1000], "vertical": true, "font_size": 24.0, "lines": ["か．．．かせ", "風邪かも", "しれないなぁ。"]}], "img_path": "036.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [361, 1030, 597, 1110], "vertical": false, "font_size": 32.0, "lines": ["くれんぼ"]}], "img_path": "037.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [719, 485, 747, 622], "vertical": true, "font_size": 23.0, "lines": ["で、何するの？"]}, {"box": [402, 475, 453, 598], "vertical": true, "font_size": 20.0, "lines": ["勝負って", "言ってたけど。"]}, {"box": [328, 468, 352, 536], "vertical": true, "font_size": 24.0, "lines": ["ふふふ．．．"]}, {"box": [441, 824, 463, 929], "vertical": true, "font_size": 20.0, "lines": ["かくれんぼ。"]}], "img_path": "038.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [698, 73, 730, 153], "vertical": true, "font_size": 29.0, "lines": ["二人で？"]}, {"box": [475, 139, 496, 223], "vertical": true, "fo