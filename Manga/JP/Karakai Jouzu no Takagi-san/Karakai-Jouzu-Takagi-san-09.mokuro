true, "font_size": 17.0, "lines": ["．．．"]}, {"box": [169, 592, 197, 671], "vertical": true, "font_size": 26.0, "lines": ["はぁ！？"]}, {"box": [684, 855, 733, 1030], "vertical": true, "font_size": 22.0, "lines": ["でも、もうちょっと", "観察しようかなー。"]}, {"box": [127, 998, 149, 1149], "vertical": true, "font_size": 20.0, "lines": ["わかってないな！？"]}], "img_path": "123.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [624, 72, 729, 248], "vertical": true, "font_size": 23.0, "lines": ["カマをかけて", "オレの口が滑るのを", "狙っているな", "高木さんめ．．．！！"]}, {"box": [371, 227, 419, 324], "vertical": true, "font_size": 22.0, "lines": ["そうは", "いくか．．！！"]}, {"box": [373, 836, 446, 917], "vertical": true, "font_size": 22.0, "lines": ["ホントに", "どこか", "違うの？"]}, {"box": [228, 828, 255, 880], "vertical": true, "font_size": 27.0, "lines": ["．．．あ。"]}, {"box": [94, 836, 113, 896], "vertical": true, "font_size": 19.0, "lines": ["うん．．．"]}], "img_path": "124.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [714, 95, 737, 199], "vertical": true, "font_size": 17.0, "lines": ["後ろかなー。"]}, {"box": [262, 72, 280, 167], "vertical": true, "font_size": 16.0, "lines": ["しまった．．．"]}, {"box": [579, 472, 704, 635], "vertical": true, "font_size": 26.0, "lines": ["ジロジロ", "見られることを", "計算に入れて", "なかった．．．！！"]}, {"box": [379, 755, 407, 903], "vertical": true, "font_size": 28.0, "lines": ["うわぁああ。"]}, {"box": [298, 749, 324, 864], "vertical": true, "font_size": 20.0, "lines": ["何してんの！？"]}, {"box": [50, 753, 104, 870], "vertical": true, "font_size": 20.0, "lines": ["服の下かなと", "思って"]}, {"box": [38, 1026, 121, 1125], "vertical": true, "font_size": 24.0, "lines": ["違うよ", "見えるとこ", "だよ！！"]}], "img_path": "125.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [695, 112, 741, 217], "vertical": true, "font_size": 19.0, "lines": ["ビックリ", "しすぎだよ。"]}, {"box": [426, 105, 533, 222], "vertical": true, "font_size": 22.0, "lines": ["途中で", "こんなふうに", "からかわれる", "のも．．"]},