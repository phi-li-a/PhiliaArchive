cal": true, "font_size": 26.0, "lines": ["ろーく、"]}, {"box": [80, 51, 371, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんＱ"]}, {"box": [146, 134, 171, 206], "vertical": true, "font_size": 25.0, "lines": ["じゅう。"]}, {"box": [694, 912, 716, 964], "vertical": true, "font_size": 22.0, "lines": ["さて。"]}, {"box": [411, 949, 485, 1065], "vertical": true, "font_size": 22.0, "lines": ["ちゃちゃっと", "見つけ", "ようかなー。"]}, {"box": [260, 910, 337, 1027], "vertical": true, "font_size": 22.0, "lines": ["西片の", "ことだから", "川の方かな？"]}, {"box": [94, 905, 117, 972], "vertical": true, "font_size": 21.0, "lines": ["ふふふ。"]}], "img_path": "041.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [675, 112, 756, 258], "vertical": true, "font_size": 24.0, "lines": ["灯台下暗し．．．", "という言葉を", "知っているかい。"]}, {"box": [659, 585, 740, 721], "vertical": true, "font_size": 23.0, "lines": ["広い範囲と", "長い制限時間は", "トラップ！！"]}, {"box": [144, 566, 248, 683], "vertical": true, "font_size": 19.0, "lines": ["あの条件で", "こんな近くに", "いるとは", "思うまい！"]}, {"box": [681, 853, 750, 991], "vertical": true, "font_size": 17.0, "lines": ["終わったあと", "こんな近くにいた", "とわかったら、"]}, {"box": [495, 864, 563, 970], "vertical": true, "font_size": 20.0, "lines": ["それはそれほ", "悔しがるに", "違いない。"]}, {"box": [405, 869, 451, 992], "vertical": true, "font_size": 21.0, "lines": ["くくく．．．", "楽しみだなぁ．．．"]}, {"box": [104, 871, 169, 994], "vertical": true, "font_size": 18.0, "lines": ["まんがでも", "読んでゆっくり", "待つとしよう．．．"]}], "img_path": "042.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [694, 98, 745, 231], "vertical": true, "font_size": 18.0, "lines": ["おっと待て待て", "あわてるな。"]}, {"box": [398, 130, 499, 246], "vertical": true, "font_size": 20.0, "lines": ["しっかりと", "高木さんが", "行ったか確認", "しておくか"]}, {"box": [82, 52, 371, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんＱ"]}, {"box": [103, 114, 130, 239], "vertical": true, "font_size": 16.0, "lines": ["念のためにな。"]}, {"box": [718, 969, 740, 1018], "vertical": true, "font_size": 22.0, "lines": ["よし。"]}, {"box": [303, 953, 329, 1032], "vertical": true, "font_size": 20.0, "lines": ["行った？"]}, {"box": [118, 971, 149, 1027], "vertical": true, "font_size": 26.0, "lines": ["ああ。"]}], "img_path": "043.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [267, 139, 297, 293], "vertical": true, "font_size": 28.0, "lines": ["えぇえええ"]}, {"box": [725, 660, 745, 764], "vertical": true, "font_size": 20.0, "lines": ["あはははば。"]}, {"box": [461, 644, 489, 689], "vertical": true, "font_size": 25.0, "lines": ["な．．．"]}, {"box": [412, 708, 434, 752], "vertical": true, "font_size": 25.0, "lines": ["な．．．"]}, {"box": [339, 672, 366, 775], "vertical": true, "font_size": 25.0, "lines": ["なんで！！"]}, {"box": [670, 990, 742, 1105], "vertical": true, "font_size": 21.0, "lines": ["こんなので", "勝てると", "思ってたの？"]}, {"box": [570, 998, 619, 1086], "vertical": true, "font_size": 21.0, "lines": ["ホント", "甘いねー。"]}, {"box": [187, 985, 205, 1029], "vertical": true, "font_size": 18.0, "lines": ["く．．．"]}], "img_path": "044.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [714, 72, 734, 150], "vertical": true, "font_size": 20.0, "lines": ["くそ．．．！！"]}, {"box": [381, 71, 436, 207], "vertical": true, "font_size": 26.0, "lines": ["やはり", "敵わないのか！？"]}, {"box": [241, 48, 315, 168], "vertical": true, "font_size": 21.0, "lines": ["ここで少し", "休んでいかない", "か．．．？"]}, {"box": [123, 79, 144, 150], "vertical": true, "font_size": 21.0, "lines": ["ここで？"]}, {"box": [726, 519, 747, 566], "vertical": true, "font_size": 20.0, "lines": ["まぁ、"]}, {"box": [385, 505, 417, 585], "vertical": true, "font_size": 25.0, "lines": ["浜口と．．．"]}, {"box": [101, 520, 128, 615], "vertical": true, "font_size": 17.0, "lines": ["北条さん！？"]}, {"box": [685, 574, 707, 651], "vertical": true, "font_size": 20.0, "lines": ["いいけど。"]}], "img_path": "045.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [733, 62, 