lines": ["やったー。"]}, {"box": [651, 975, 747, 1068], "vertical": true, "font_size": 25.0, "lines": ["今のは", "なしじゃ", "ないの！？"]}, {"box": [376, 965, 397, 1026], "vertical": true, "font_size": 21.0, "lines": ["んー？"]}, {"box": [101, 965, 122, 1042], "vertical": true, "font_size": 20.0, "lines": ["なんで？"]}], "img_path": "141.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [750, 46, 801, 145], "vertical": true, "font_size": 26.0, "lines": ["いや．．．", "だって．．．"]}, {"box": [460, 111, 508, 196], "vertical": true, "font_size": 20.0, "lines": ["しょうが", "ないなー"]}, {"box": [292, 98, 394, 251], "vertical": true, "font_size": 22.0, "lines": ["じゃあ、", "制限時間なしなら", "もう一回勝負して", "あげる。"]}, {"box": [658, 473, 735, 554], "vertical": true, "font_size": 29.0, "lines": ["お．．．．．．", "お願い", "します．．．"]}, {"box": [173, 471, 200, 523], "vertical": true, "font_size": 27.0, "lines": ["うん。"]}, {"box": [382, 816, 398, 879], "vertical": true, "font_size": 16.0, "lines": ["．．．．．．"]}, {"box": [99, 822, 153, 918], "vertical": true, "font_size": 20.0, "lines": ["もう油断は", "しない．．．"]}], "img_path": "142.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [724, 51, 754, 157], "vertical": true, "font_size": 21.0, "lines": ["今度こそ．．．"]}, {"box": [483, 50, 511, 196], "vertical": true, "font_size": 24.0, "lines": ["オレが勝つ．．．！！"]}, {"box": [358, 82, 432, 206], "vertical": true, "font_size": 23.0, "lines": ["ところで", "西片は", "避けるのかな。"]}, {"box": [414, 523, 521, 638], "vertical": true, "font_size": 21.0, "lines": ["私は西片には", "避けるより", "受け止めて", "欲しいなー。"]}, {"box": [28, 292, 104, 407], "vertical": true, "font_size": 23.0, "lines": ["それとも", "受け止めるの", "かな。"]}, {"box": [281, 830, 356, 917], "vertical": true, "font_size": 22.0, "lines": ["ド．．．", "ドッジの", "話だよね。"]}, {"box": [65, 828, 117, 907], "vertical": true, "font_size": 25.0, "lines": ["ドッジの", "話だよ。"]}, {"box": [39, 1018, 51, 1069], "vertical": true, "font_size": 12.0, "lines": ["．．．"]}], "img_path": "143.jpg"}, {"versio