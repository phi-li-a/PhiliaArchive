6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [41, 2, 215, 53], "vertical": false, "font_size": 18.0, "lines": ["Ｓｕｐｐｏｒｔｕｓ", "ｗｗｗ．．．ａｚｍａｎｇａ．ｎｅｔ"]}, {"box": [149, 581, 228, 628], "vertical": false, "font_size": 30.0, "lines": ["おいい！"]}, {"box": [270, 1012, 470, 1116], "vertical": false, "font_size": 32.0, "lines": ["かんせっかん", "間接キ"]}], "img_path": "005.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [735, 133, 764, 220], "vertical": true, "font_size": 25.0, "lines": ["暑いねー。"]}, {"box": [175, 138, 231, 253], "vertical": true, "font_size": 20.0, "lines": ["今日３０度ある", "らしいよ。"]}, {"box": [579, 616, 627, 732], "vertical": true, "font_size": 20.0, "lines": ["のどが．．．", "カラカラだ．．"]}, {"box": [466, 597, 520, 723], "vertical": true, "font_size": 22.0, "lines": ["あ、自販機。", "何か買おうよ。"]}, {"box": [127, 618, 155, 714], "vertical": true, "font_size": 20.0, "lines": ["助かった．．．"]}, {"box": [125, 1007, 154, 1045], "vertical": true, "font_size": 29.0, "lines": ["あ。"]}], "img_path": "006.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [678, 69, 733, 263], "vertical": true, "font_size": 24.0, "lines": ["私７０円しか", "持ってないんだった"]}, {"box": [213, 62, 236, 168], "vertical": true, "font_size": 21.0, "lines": ["ぶっふっふ。"]}, {"box": [635, 483, 724, 667], "vertical": true, "font_size": 23.0, "lines": ["ばっはっは", "まったくしょうが", "ないなぁ！！"]}, {"box": [312, 873, 335, 922], "vertical": true, "font_size": 23.0, "lines": ["あぁ。"]}, {"box": [105, 500, 229, 707], "vertical": true, "font_size": 24.0, "lines": ["お金がないのに", "ジュースを買おうと", "してたのかい", "高木さん！！"]}, {"box": [686, 882, 739, 999], "vertical": true, "font_size": 21.0, "lines": ["オレが出して", "あげるよ"]}, {"box": [379, 878, 429, 959], "vertical": true, "font_size": 24.0, "lines": ["え！", "ホント？"]}, {"box": [150, 901, 170, 967], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．？"]}], "img_path": "007.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [738, 80, 816, 196], "vertical": true, "font_size": 25.0, "lines": ["オレも", "７０円しか", "持ってない！！"]}, {"box": [237, 65, 365, 198], "vertical": true, "font_size": 20.0, "lines": ["さっき", "お金が足りない", "高木さんを", "小バカにした", "ばかりなのに。"]}, {"box": [707, 612, 731, 656], "vertical": true, "font_size": 24.0, "lines": ["ん？"]}, {"box": [407, 611, 425, 725], "vertical": true, "font_size": 17.0, "lines": ["どうしたの？"]}, {"box": [298, 572, 318, 726], "vertical": true, "font_size": 20.0, "lines": ["あ．．．い．いや！．"]}, {"box": [610, 931, 666, 1068], "vertical": true, "font_size": 26.0, "lines": ["ふ．．．二人で", "一本買わない！？"]}, {"box": [168, 916, 226, 987], "vertical": true, "font_size": 30.0, "lines": ["うん、", "いいよ。"]}], "img_path": "008.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [686, 56, 739, 164], "vertical": true, "font_size": 29.0, "lines": ["じゃあはい", "７０円。"]}, {"box": [581, 56, 638, 146], "vertical": true, "font_size": 29.0, "lines": ["西片", "選んでよ。"]}, {"box": [360, 80, 435, 215], "vertical": true, "font_size": 22.0, "lines": ["よし．．", "なんとか危機を", "乗り越えた．．．"]}, {"box": [270, 58, 320, 195], "vertical": true, "font_size": 23.0, "lines": ["でも", "めずらしいねー。"]}, {"box": [619, 492, 673, 653], "vertical": true, "font_size": 22.0, "lines": ["西片が二人で", "一本買おうなんて。"]}, {"box": [695, 847, 742, 925], "vertical": true, "font_size": 20.0, "lines": ["いやぁ．．．", "それは．．．"]}, {"box": [436, 843, 458, 904], "vertical": true, "font_size": 22.0, "lines": ["その．．．"]}, {"box": [366, 839, 393, 869], "vertical": true, "font_size": 27.0, "lines": ["あ、"]}, {"box": [157, 872, 179, 960], "vertical": true, "font_size": 20.0, "lines": ["わかった。"]}], "img_path": "009.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [381, 126, 444, 290], "vertical": true, "font_size": 24.0, "lines": ["間接キスでも", "したいのかな？"]}, {"box": [103, 112, 149, 257], "vertical": true, "font_size": 32.0, "lines": ["違うよ！！"]}, {"box": [625, 638, 708, 720], "vertical": true, "font_size": 26.0, "lines": ["一人だと", "多いなと", "思って。"]}, {"box": [164, 614, 212, 718], "vertical": true, "font_size": 20.0, "lines": ["あははは", "顔赤すぎー。"]}, {"box": [673, 916, 723, 1041], "vertical": true, "font_size": 22.0, "lines": ["恥ずかし", "がっちゃって。"]}, {"box": [544, 878, 596, 951], "vertical": false, "font_size": 32.0, "lines": ["あはは"]}, {"box": [294, 883, 378, 1000], "vertical": true, "font_size": 26.0, "lines": ["別に．．．", "そんなんじゃ", "ないし。"]}, {"box": [105, 905, 123, 1000], "vertical": true, "font_size": 16.0, "lines": ["そーなの？"]}], "img_path": "010.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [713, 116, 733, 195], "vertical": true, "font_size": 20.0, "lines": ["じゃあ．．．"]}, {"box": [65, 80, 176, 226], "vertical": true, "font_size": 26.0, "lines": ["私、", "恥ずかしいから", "先に飲ませて", "もらうね。"]}, {"box": [718, 670, 746, 720], "vertical": true, "font_size": 28.0, "lines": ["な！！"]}, {"box": [335, 677, 397, 773], "vertical": true, "font_size": 30.0, "lines": ["ウソ", "っぽい！！！"]}, {"box": [439, 870, 495, 996], "vertical": true, "font_size": 22.0, "lines": ["私恥ずかしい", "からさー。"]}], "img_path": "011.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [667, 57, 738, 191], "vertical": true, "font_size": 19.0, "lines": ["オレにはウソ", "つかないとか", "言っておいて！！"]}, {"box": [388, 72, 492, 223], "vertical": true, "font_size": 20.0, "lines": ["いや、それより", "先に飲まれて", "しまったらオレが", "間接キスに．．．"]}, {"box": [331, 39, 348, 102], "vertical": true, "font_size": 17.0, "lines": ["．．．．．．"]}, {"box": [139, 119, 166, 205], "vertical": true, "font_size": 20.0, "lines": ["高木さん。"]}, {"box": [666, 509, 715, 649], "vertical": true, "font_size": 20.0, "lines": ["そのジュースの", "一口目をかけて、"]}, {"box": [388, 491, 444, 609], "vertical": true, "font_size": 25.0, "lines": ["勝負．．．", "しないかい？"]}, {"box": [117, 282, 140, 325], "vertical": true, "font_size": 23.0, "lines": ["ん？"]}, {"box": [725, 903, 746, 962], "vertical": true, "font_size": 21.0, "lines": ["あれ？"]}, {"box": [439, 899, 486, 1033], "vertical": true, "font_size": 20.0, "lines": ["やっぱり", "恥ずかしいの？"]}, {"box": [370, 902, 400, 994], "vertical": true, "font_size": 21.0, "lines": ["勝負が．．．"]}, {"box": [110, 903, 134, 1041], "vertical": true, "font_size": 23.0, "lines": ["したいだけ．．．"]}], "img_path": "012.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [719, 55, 745, 124], "vertical": true, "font_size": 29.0, "lines": ["ふーん。"]}, {"box": [618, 57, 679, 132], "vertical": true, "font_size": 29.0, "lines": ["ま、", "いいよ。"]}, {"box": [374, 59, 449, 176], "vertical": true, "font_size": 20.0, "lines": ["じゃあ", "ルールは私が", "決めていい？"]}, {"box": [312, 154, 330, 239], "vertical": true, "font_size": 17.0, "lines": ["．．．どうぞ。"]}, {"box": [28, 151, 49, 218], "vertical": true, "font_size": 21.0, "lines": ["じゃあ、"]}, {"box": [394, 369, 477, 503], "vertical": true, "font_size": 20.0, "lines": ["西片が今", "ウソついてたら", "私の勝ちね。"]}, {"box": [678, 855, 712, 896], "vertical": true, "font_size": 27.0, "lines": ["え、"]}, {"box": [134, 850, 161, 896], "vertical": true, "font_size": 27.0, "lines": ["な．．．"]}, {"box": [185, 975, 213, 1052], "vertical": true, "font_size": 21.0, "lines": ["西片さ．．．"]}], "img_path": "013.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [729, 106, 783, 206], "vertical": true, "font_size": 21.0, "lines": ["ホントは", "間接キス、"]}, {"box": [152, 112, 216, 252], "vertical": true, "font_size": 25.0, "lines": ["恥ずかしいん", "でしょ。"]}, {"box": [719, 799, 741, 959], "vertical": true, "font_size": 20.0, "lines": ["いや．．．ぜーんぜん、"]}, {"box": [474, 835, 496, 950], "vertical": true, "font_size": 20.0, "lines": ["ホントにー？"]}, {"box": [376, 816, 424, 958], "vertical": true, "font_size": 20.0, "lines": ["あぁホント、", "ぜーんぜんだよ。"]}, {"box": [103, 830, 149, 933], "vertical": true, "font_size": 20.0, "lines": ["くそ．．．！！", "高木さんめ。"]}], "img_path": "014.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [638, 93, 717, 247], "vertical": true, "font_size": 22.0, "lines": ["だがこの勝負．．．！！", "突き通せば", "オレの勝ちだ！！"]}, {"box": [125, 93, 186, 189], "vertical": true, "font_size": 28.0, "lines": ["オレは", "引かん！！"]}, {"box": [406, 468, 438, 533], "vertical": true, "font_size": 29.0, "lines": ["絶対？"]}, {"box": [303, 451, 355, 547], "vertical": true, "font_size": 20.0, "lines": ["恥ずかしく", "ないよ．．．"]}, {"box": [718, 739, 739, 806], "vertical": true, "font_size": 21.0, "lines": ["ふーん。"]}, {"box": [468, 742, 516, 850], "vertical": true, "font_size": 20.0, "lines": ["じゃあそう", "なんだねー。"]}, {"box": [222, 773, 272, 843], "vertical": true, "font_size": 24.0, "lines": ["あぁ、", "そうさ。"]}, {"box": [123, 745, 159, 837], "vertical": true, "font_size": 32.0, "lines": ["勝った。"]}], "img_path": "015.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [665, 121, 739, 304], "vertical": true, "font_size": 22.0, "lines": ["でも「ジュース", "二人で一本にしよう」", "って言ったのは、"]}, {"box": [345, 148, 404, 333], "vertical": true, "font_size": 23.0, "lines": ["西片もお金が", "なかったからでしょ。"]}, {"box": [680, 687, 741, 802], "vertical": true, "font_size": 25.0, "lines": ["バレて", "いたのかー"]}, {"box": [651, 793, 672, 825], "vertical": true, "font_size": 25.0, "lines": ["．．．"]}, {"box": [249, 982, 282, 1039], "vertical": true, "font_size": 31.0, "lines": ["じゃ、"]}], "img_path": "016.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [335, 625, 361, 678], "vertical": true, "font_size": 26.0, "lines": ["ふぅ。"]}, {"box": [598, 917, 660, 978], "vertical": true, "font_size": 32.0, "lines": ["はいにしかた", "西片。"]}], "img_path": "017.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [428, 847, 453, 962], "vertical": true, "font_size": 18.0, "lines": ["飲まないの？"]}, {"box": [340, 854, 367, 967], "vertical": true, "font_size": 21.0, "lines": ["飲むけど！？"]}], "img_path": "018.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "019.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [