{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [675, 112, 756, 258], "vertical": true, "font_size": 24.0, "lines": ["灯台下暗し．．．", "という言葉を", "知っているかい。"]}, {"box": [659, 585, 740, 721], "vertical": true, "font_size": 23.0, "lines": ["広い範囲と", "長い制限時間は", "トラップ！！"]}, {"box": [144, 566, 248, 683], "vertical": true, "font_size": 19.0, "lines": ["あの条件で", "こんな近くに", "いるとは", "思うまい！"]}, {"box": [681, 853, 750, 991], "vertical": true, "font_size": 17.0, "lines": ["終わったあと", "こんな近くにいた", "とわかったら、"]}, {"box": [495, 864, 563, 970], "vertical": true, "font_size": 20.0, "lines": ["それはそれほ", "悔しがるに", "違いない。"]}, {"box": [405, 869, 451, 992], "vertical": true, "font_size": 21.0, "lines": ["くくく．．．", "楽しみだなぁ．．．"]}, {"box": [104, 871, 169, 994], "vertical": true, "font_size": 18.0, "lines": ["まんがでも", "読んでゆっくり", "待つとしよう．．．"]}]}