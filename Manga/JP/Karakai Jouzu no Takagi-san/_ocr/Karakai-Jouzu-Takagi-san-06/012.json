{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [657, 44, 734, 217], "vertical": true, "font_size": 23.0, "lines": ["く．．．高木さんめ．．．！！", "この前トンネルで", "肝試しした時"]}, {"box": [492, 39, 567, 194], "vertical": true, "font_size": 23.0, "lines": ["オレが", "デートって言葉に", "弱いと知って．．．！！"]}, {"box": [391, 80, 438, 232], "vertical": true, "font_size": 18.0, "lines": ["だがここで", "負けてたまるが！"]}, {"box": [101, 85, 181, 239], "vertical": true, "font_size": 23.0, "lines": ["べ．．．別に", "そんなコトないん", "じゃないの？"]}, {"box": [645, 514, 667, 621], "vertical": true, "font_size": 20.0, "lines": ["そうかなー"]}, {"box": [181, 522, 204, 610], "vertical": true, "font_size": 21.0, "lines": ["そうだよ。"]}, {"box": [105, 802, 123, 841], "vertical": true, "font_size": 18.0, "lines": ["な．．．"]}, {"box": [395, 839, 469, 1039], "vertical": true, "font_size": 22.0, "lines": ["でもクラスメイトが", "私達を見たらきっと", "デートだと思われるよ。"]}]}