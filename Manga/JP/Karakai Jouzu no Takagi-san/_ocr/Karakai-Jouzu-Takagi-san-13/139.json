{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [388, 53, 489, 213], "vertical": true, "font_size": 21.0, "lines": ["そしてそろそろ", "気付いたようだな、", "オレがチョキしか", "出さないと．．．"]}, {"box": [282, 45, 357, 171], "vertical": true, "font_size": 24.0, "lines": ["そう．．．", "グーをっ", "出し続ければ、"]}, {"box": [87, 284, 141, 405], "vertical": true, "font_size": 20.0, "lines": ["高木さんは", "勝てるのだよ。"]}, {"box": [103, 592, 169, 742], "vertical": true, "font_size": 27.0, "lines": ["出し続け", "られれば．．．ね。"]}, {"box": [657, 905, 733, 1109], "vertical": true, "font_size": 23.0, "lines": ["もしオレが気まぐれで", "パーを出したらという", "疑惑．．．"]}, {"box": [552, 912, 600, 1052], "vertical": true, "font_size": 23.0, "lines": ["それは精神を", "すり減らすハズ。"]}, {"box": [92, 912, 167, 1067], "vertical": true, "font_size": 23.0, "lines": ["そう、これは", "オレとの勝負じゃ", "ないのさ。"]}]}