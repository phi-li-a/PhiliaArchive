{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [716, 128, 733, 241], "vertical": true, "font_size": 17.0, "lines": ["まだ．．．ある！！"]}, {"box": [218, 147, 317, 264], "vertical": true, "font_size": 22.0, "lines": ["神はオレに．．．", "助け舟を", "出してくれて"]}, {"box": [116, 137, 313, 374], "vertical": true, "font_size": 20.0, "lines": ["いた．．．！！"]}, {"box": [694, 516, 749, 619], "vertical": true, "font_size": 25.0, "lines": ["高木さんのしてんじゃ", "自転車だ！！"]}, {"box": [123, 296, 144, 361], "vertical": true, "font_size": 19.0, "lines": ["それは、"]}, {"box": [110, 517, 188, 691], "vertical": true, "font_size": 22.0, "lines": ["これを借りれば", "地面に足をつけずに", "余裕で渡れる。"]}, {"box": [169, 853, 197, 939], "vertical": true, "font_size": 20.0, "lines": ["高木さん。"]}, {"box": [670, 847, 748, 980], "vertical": true, "font_size": 20.0, "lines": ["面白がって", "ついてきたのが", "運のつきさ。"]}, {"box": [336, 890, 413, 1008], "vertical": true, "font_size": 23.0, "lines": ["オレはついに", "高木さんに", "勝つ！！"]}]}