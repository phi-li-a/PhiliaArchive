{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [674, 108, 749, 262], "vertical": true, "font_size": 21.0, "lines": ["そうだ．．．", "帰りに教えるって", "言ってたんだ。"]}, {"box": [390, 137, 475, 240], "vertical": true, "font_size": 26.0, "lines": ["大声でった", "伝えるとか", "だろう．．．"]}, {"box": [306, 151, 359, 220], "vertical": true, "font_size": 26.0, "lines": ["きっと", "そうだ。"]}, {"box": [93, 112, 195, 264], "vertical": true, "font_size": 21.0, "lines": ["だとしたら", "そんな恥ずかしい", "言葉なワケが", "ない．．．"]}, {"box": [686, 533, 732, 693], "vertical": true, "font_size": 18.0, "lines": ["そう．．．たぶん", "「スイカよ」とかだ。"]}, {"box": [701, 853, 756, 933], "vertical": true, "font_size": 24.0, "lines": ["危ない", "危ない．．．"]}, {"box": [108, 537, 239, 767], "vertical": true, "font_size": 22.0, "lines": ["高木さんめ．．．", "オレが", "「好きだよ」にたどりついて", "あたふたするのも", "計算の上か．．．"]}, {"box": [571, 850, 621, 984], "vertical": true, "font_size": 18.0, "lines": ["動揺するところ", "だったよ。"]}]}