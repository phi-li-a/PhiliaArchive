{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1158, 275, 1241, 376], "vertical": true, "font_size": 32.0, "lines": ["そ．．．", "そう．．．"]}, {"box": [896, 133, 1010, 403], "vertical": true, "font_size": 32.0, "lines": ["はい、じゃあ", "注目ー"]}, {"box": [695, 676, 855, 725], "vertical": false, "font_size": 32.0, "lines": ["希望委員"]}, {"box": [157, 125, 312, 835], "vertical": true, "font_size": 32.0, "lines": ["今から配るプリントに", "人数多かったら", "なりたい委員書いて", "ジャンケンで", "１５分後に提出な。", "決めるぞー。"]}, {"box": [1091, 954, 1207, 1123], "vertical": true, "font_size": 32.0, "lines": ["やだなー", "ジャンケン", "弱いのよね。"]}, {"box": [564, 946, 695, 1194], "vertical": true, "font_size": 32.0, "lines": ["大丈夫、", "もう書いておいて", "あげた。"]}, {"box": [271, 951, 345, 1117], "vertical": true, "font_size": 30.0, "lines": ["これなら", "被らないね。"]}, {"box": [157, 1111, 201, 1325], "vertical": true, "font_size": 32.0, "lines": ["勝手に書くな！"]}, {"box": [1230, 1456, 1315, 1699], "vertical": true, "font_size": 30.0, "lines": ["お前ら保健委員に", "入れるなよ！"]}, {"box": [913, 1452, 1042, 1636], "vertical": true, "font_size": 32.0, "lines": ["今日のオレは", "ジャンケン", "強いぞ！"]}, {"box": [823, 1443, 864, 1528], "vertical": true, "font_size": 32.0, "lines": ["ひひ。"]}, {"box": [580, 1458, 662, 1642], "vertical": true, "font_size": 29.0, "lines": ["どんな記事を", "書こうかな。"]}, {"box": [451, 1462, 530, 1612], "vertical": true, "font_size": 30.0, "lines": ["応援委員に", "しようかな。"]}, {"box": [299, 1442, 431, 1475], "vertical": false, "font_size": 32.0, "lines": ["となりのクラス"]}, {"box": [156, 1436, 268, 1743], "vertical": true, "font_size": 32.0, "lines": ["あいつ、", "サッカー部がんばってる", "みたいだし．．．"]}]}