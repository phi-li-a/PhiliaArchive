{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1149, 112, 1278, 360], "vertical": true, "font_size": 32.0, "lines": ["この砂浜で", "１０回連続で", "ケンケンすると．．．"]}, {"box": [489, 148, 617, 406], "vertical": true, "font_size": 32.0, "lines": ["次の小遣いが", "半分になるって", "ウワサがあるんだ。"]}, {"box": [1083, 1001, 1205, 1138], "vertical": true, "font_size": 32.0, "lines": ["高尾から", "聞いたん", "だけどね。"]}, {"box": [909, 963, 1031, 1192], "vertical": true, "font_size": 32.0, "lines": ["かなり", "信用できる", "ウワサらしいよ。"]}, {"box": [165, 978, 324, 1226], "vertical": true, "font_size": 32.0, "lines": ["どうだ", "高木さん．．．！！", "オレが今日聞いた", "このウワサ．．．！！"]}, {"box": [1168, 1505, 1194, 1726], "vertical": true, "font_size": 32.0, "lines": ["オレはいいのさ。"]}, {"box": [875, 1470, 1083, 1779], "vertical": true, "font_size": 32.0, "lines": ["たとえ小遣いが", "半分になったとしても", "それで高木さんに", "勝てるなら", "安いもの：・"]}, {"box": [180, 1503, 293, 1723], "vertical": true, "font_size": 32.0, "lines": ["覚悟は", "できてる！！"]}]}