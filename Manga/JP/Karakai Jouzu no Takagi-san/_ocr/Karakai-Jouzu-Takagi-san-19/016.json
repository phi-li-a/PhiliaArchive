{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1063, 118, 1184, 348], "vertical": true, "font_size": 32.0, "lines": ["キュン子っぽい", "のが一番で、", "ボブがそこそこ。"]}, {"box": [485, 103, 697, 440], "vertical": true, "font_size": 32.0, "lines": ["今のやつと", "ゆるふわロングも", "結構好きで、そのあとが", "ツインテールとか", "その他って感じかー。"]}, {"box": [183, 164, 234, 461], "vertical": true, "font_size": 32.0, "lines": ["全部当たってる！"]}, {"box": [959, 791, 1185, 1042], "vertical": true, "font_size": 32.0, "lines": ["じゃあどうしっ", "美容室に", "行った時", "してもらうのは", "キュン子っぽいので", "決まりかなー。"]}, {"box": [191, 845, 307, 1093], "vertical": true, "font_size": 27.0, "lines": ["製型変えるのなんて", "初めてだから", "なんか楽しみだよ。"]}, {"box": [1042, 1353, 1203, 1567], "vertical": true, "font_size": 32.0, "lines": ["しかし", "髪の毛だけで", "こんなに変わる", "ものだとは。"]}, {"box": [740, 1426, 842, 1561], "vertical": true, "font_size": 32.0, "lines": ["髪型の", "くせに．．．"]}]}