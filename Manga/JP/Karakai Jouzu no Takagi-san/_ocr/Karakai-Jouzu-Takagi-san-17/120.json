{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [990, 140, 1149, 309], "vertical": true, "font_size": 32.0, "lines": ["この４枚の", "トランプから", "高木さんが", "２枚引いて、"]}, {"box": [436, 99, 547, 322], "vertical": true, "font_size": 31.0, "lines": ["２枚とも", "同じのを引けたら", "高木さんの勝ち。"]}, {"box": [204, 161, 354, 341], "vertical": true, "font_size": 31.0, "lines": ["４枚からまい", "２枚だからそ、", "つまりーすの", "勝負かな？"]}, {"box": [1157, 738, 1202, 823], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}, {"box": [738, 757, 821, 870], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "それで。"]}, {"box": [620, 761, 657, 943], "vertical": true, "font_size": 32.0, "lines": ["かかったぁ。"]}, {"box": [1127, 1396, 1205, 1531], "vertical": true, "font_size": 32.0, "lines": ["ふっ．．．", "高木さん。"]}, {"box": [599, 1411, 713, 1629], "vertical": true, "font_size": 32.0, "lines": ["これを１丁のかっ", "確率の勝負だと", "思ったかい？"]}, {"box": [367, 1385, 508, 1575], "vertical": true, "font_size": 32.0, "lines": ["実は", "そうじゃない", "のさ。"]}]}