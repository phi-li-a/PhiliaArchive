{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1027, 260, 1190, 465], "vertical": true, "font_size": 32.0, "lines": ["『ウミガメの", "スープ』という", "ゲームを", "ご存じ？"]}, {"box": [288, 288, 318, 440], "vertical": true, "font_size": 27.0, "lines": ["ウミガメ？"]}, {"box": [1037, 808, 1198, 1025], "vertical": true, "font_size": 32.0, "lines": ["こちらが", "用意したナゾを", "解き明かす", "推理ゲームよ。"]}, {"box": [545, 787, 795, 1083], "vertical": true, "font_size": 32.0, "lines": ["あなたは", "「ＹＥＳ「ＮＯ」で", "答えられる質問を", "私に投げかけ、", "それを手がかりに", "答えにたどりつくの。"]}, {"box": [172, 804, 248, 1033], "vertical": true, "font_size": 32.0, "lines": ["や．．．やって", "やろうじゃない。"]}, {"box": [547, 1436, 673, 1561], "vertical": true, "font_size": 32.0, "lines": ["へー、", "面白そう", "だなー。"]}, {"box": [150, 1400, 245, 1592], "vertical": true, "font_size": 32.0, "lines": ["今度", "木村たちと．．．"]}]}