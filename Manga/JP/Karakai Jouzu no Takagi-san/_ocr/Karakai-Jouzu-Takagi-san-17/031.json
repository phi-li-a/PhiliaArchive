{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1012, 183, 1173, 369], "vertical": true, "font_size": 31.0, "lines": ["さっきオレが", "やったコトを", "やり返す気", "なんだな！"]}, {"box": [620, 114, 703, 234], "vertical": true, "font_size": 32.0, "lines": ["つまり", "答えは、"]}, {"box": [121, 217, 173, 356], "vertical": true, "font_size": 32.0, "lines": ["「西片」。"]}, {"box": [1074, 787, 1145, 982], "vertical": true, "font_size": 31.0, "lines": ["だが高木さんの", "ことだ．．．"]}, {"box": [890, 768, 997, 1020], "vertical": true, "font_size": 31.0, "lines": ["そう思わせて", "おいてのスカという", "可能性も．．．"]}, {"box": [528, 781, 637, 937], "vertical": true, "font_size": 31.0, "lines": ["ここは", "あと５問", "じっくりと"]}, {"box": [225, 833, 266, 1001], "vertical": true, "font_size": 31.0, "lines": ["あと１問ね。"]}, {"box": [1136, 1396, 1187, 1483], "vertical": true, "font_size": 32.0, "lines": ["え！？"]}, {"box": [586, 1488, 677, 1652], "vertical": true, "font_size": 32.0, "lines": ["私は６問で", "当てたから、"]}, {"box": [60, 1389, 189, 1575], "vertical": true, "font_size": 32.0, "lines": ["次で当てられ", "なかったら", "西片の負け。"]}]}