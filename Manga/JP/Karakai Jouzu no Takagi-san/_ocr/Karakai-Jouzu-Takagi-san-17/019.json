{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1075, 95, 1194, 324], "vertical": true, "font_size": 32.0, "lines": ["しかし、", "ホントに突然", "作りはじめたね。"]}, {"box": [609, 172, 688, 341], "vertical": true, "font_size": 32.0, "lines": ["あはは", "ホントにね。"]}, {"box": [360, 106, 478, 298], "vertical": true, "font_size": 32.0, "lines": ["作ったコト", "ないって", "言ってたけど、"]}, {"box": [112, 84, 270, 270], "vertical": true, "font_size": 32.0, "lines": ["小学校のとき", "まわりの人は", "作ったりして", "なかったの？"]}, {"box": [1055, 1040, 1174, 1237], "vertical": true, "font_size": 31.0, "lines": ["私の友達は", "あんまり作って", "なかったかな。"]}, {"box": [772, 1033, 838, 1175], "vertical": true, "font_size": 31.0, "lines": ["男子はよく", "作ってて、"]}, {"box": [596, 1016, 635, 1126], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [722, 1230, 834, 1432], "vertical": true, "font_size": 31.0, "lines": ["男子にまじって", "作ってる女子も", "いたけど。"]}, {"box": [150, 1014, 255, 1153], "vertical": true, "font_size": 32.0, "lines": ["それが急に", "作りたく", "なるって、"]}, {"box": [75, 1207, 185, 1395], "vertical": true, "font_size": 32.0, "lines": ["子供心が", "遅れてやって", "きたのかな。"]}, {"box": [114, 1524, 196, 1664], "vertical": true, "font_size": 32.0, "lines": ["んー", "というか、"]}]}