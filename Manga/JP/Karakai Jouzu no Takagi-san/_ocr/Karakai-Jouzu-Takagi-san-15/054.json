{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [556, 69, 635, 222], "vertical": true, "font_size": 18.0, "lines": ["また木村が", "くだらないもの", "送ってきたかな．．．"]}, {"box": [679, 624, 698, 708], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．"]}, {"box": [427, 768, 571, 833], "vertical": false, "font_size": 29.0, "lines": ["腹筋われた。"]}, {"box": [151, 642, 172, 737], "vertical": true, "font_size": 20.0, "lines": ["やっぱり．．．"]}, {"box": [649, 918, 748, 1024], "vertical": true, "font_size": 20.0, "lines": ["なんだよー", "まんが、", "いいシーン", "なのにさー"]}, {"box": [189, 912, 415, 1121], "vertical": false, "font_size": 28.0, "lines": ["今日、田辺先生が", "キゲンよかったのって", "プロポーズ成功した", "かららしいぜ。", "近々けっこんする", "らしい。"]}]}