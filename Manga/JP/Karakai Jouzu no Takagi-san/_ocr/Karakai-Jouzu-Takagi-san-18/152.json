{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1022, 189, 1138, 358], "vertical": true, "font_size": 32.0, "lines": ["あ、そうだ", "私のやつ", "見にきてよ。"]}, {"box": [558, 268, 590, 409], "vertical": true, "font_size": 27.0, "lines": ["あ．．．うん"]}, {"box": [358, 116, 429, 363], "vertical": true, "font_size": 32.0, "lines": ["書かなかったんじゃ", "なくて．．．"]}, {"box": [215, 234, 294, 453], "vertical": true, "font_size": 32.0, "lines": ["書けなかったん", "だ．．．"]}, {"box": [1033, 804, 1162, 1051], "vertical": true, "font_size": 32.0, "lines": ["それで高木さんは", "自由研究", "何したの？"]}, {"box": [307, 787, 385, 1001], "vertical": true, "font_size": 29.0, "lines": ["だってさすがに", "書けないだろ。"]}, {"box": [1048, 1290, 1198, 1479], "vertical": true, "font_size": 32.0, "lines": ["タイトルに", "「高木さん」", "なんて。"]}, {"box": [701, 1256, 789, 1394], "vertical": true, "font_size": 32.0, "lines": ["西片観察", "日記だよ。"]}, {"box": [406, 1245, 446, 1344], "vertical": true, "font_size": 32.0, "lines": ["ええ！？"]}, {"box": [395, 1805, 958, 1837], "vertical": false, "font_size": 32.0, "lines": ["「からかい上手の高木さん図・完"]}, {"box": [196, 1505, 271, 1674], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "冗談だって。"]}]}