{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1083, 157, 1194, 408], "vertical": true, "font_size": 28.0, "lines": ["これを知ったら", "校則違反だとしても", "やりたくなるなー。"]}, {"box": [549, 200, 637, 491], "vertical": true, "font_size": 32.0, "lines": ["いやー、校則違反じゃ", "なくてよかったー。"]}, {"box": [131, 84, 594, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [161, 185, 193, 290], "vertical": true, "font_size": 32.0, "lines": ["．．．．．．"]}, {"box": [1117, 707, 1203, 954], "vertical": true, "font_size": 32.0, "lines": ["あ、そうだ西片", "一口交換しない？"]}, {"box": [618, 723, 738, 890], "vertical": true, "font_size": 32.0, "lines": ["ん？おな", "同じように", "見えるけど、"]}, {"box": [174, 731, 249, 886], "vertical": true, "font_size": 32.0, "lines": ["なんか", "味違うの？"]}, {"box": [918, 1353, 1093, 1541], "vertical": true, "font_size": 32.0, "lines": ["西片が", "間接キス", "恥ずかしがる", "かなって。"]}, {"box": [376, 1366, 453, 1522], "vertical": true, "font_size": 32.0, "lines": ["何その雑な", "からかい！！"]}, {"box": [215, 1423, 313, 1601], "vertical": true, "font_size": 32.0, "lines": ["交換", "しないよ！！"]}]}