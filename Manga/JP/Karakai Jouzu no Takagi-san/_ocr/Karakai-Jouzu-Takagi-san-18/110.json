{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1044, 163, 1160, 405], "vertical": true, "font_size": 30.0, "lines": ["ここへは", "お参りに来る人は", "ほとんどいない。"]}, {"box": [828, 161, 902, 375], "vertical": true, "font_size": 30.0, "lines": ["それを知ってる", "高木さんは"]}, {"box": [375, 174, 461, 333], "vertical": true, "font_size": 32.0, "lines": ["「いない」の", "方で。"]}, {"box": [193, 365, 285, 493], "vertical": true, "font_size": 32.0, "lines": ["と答える", "だろう。"]}, {"box": [1112, 761, 1188, 911], "vertical": true, "font_size": 29.0, "lines": ["いるんだな", "これが"]}, {"box": [387, 765, 555, 1010], "vertical": true, "font_size": 31.0, "lines": ["夕方おつかいする", "時にたまに", "見かけていた", "おじいちゃん。"]}, {"box": [1179, 1466, 1253, 1648], "vertical": true, "font_size": 30.0, "lines": ["めずらしいな", "と思って、"]}, {"box": [688, 1458, 802, 1682], "vertical": true, "font_size": 26.0, "lines": ["なんとなく", "見かけた日を", "メモしていたら、"]}, {"box": [138, 1445, 300, 1717], "vertical": true, "font_size": 30.0, "lines": ["かならず", "１１日の夕方だと", "決まっていることが", "わかったのさ。"]}]}