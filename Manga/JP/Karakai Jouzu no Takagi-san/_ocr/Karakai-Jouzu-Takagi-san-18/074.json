{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1101, 94, 1228, 453], "vertical": true, "font_size": 32.0, "lines": ["タストマトキャベツ『牛が７９４Ｐにおこし』チーズといにください！"]}, {"box": [819, 110, 864, 245], "vertical": true, "font_size": 32.0, "lines": ["高木さん。"]}, {"box": [397, 144, 493, 319], "vertical": true, "font_size": 32.0, "lines": ["勝負", "しないかい。"]}, {"box": [1168, 935, 1205, 1005], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [603, 945, 828, 1171], "vertical": true, "font_size": 32.0, "lines": ["先に", "おつかいの品を", "そろえて会計を", "すませた方の", "勝ち。"]}, {"box": [1110, 1462, 1155, 1624], "vertical": true, "font_size": 32.0, "lines": ["ルート決め、"]}, {"box": [806, 1458, 907, 1571], "vertical": true, "font_size": 32.0, "lines": ["歩きの", "速さ、"]}, {"box": [463, 1486, 601, 1653], "vertical": true, "font_size": 32.0, "lines": ["そして", "商品探しの", "嗅覚、"]}, {"box": [256, 1503, 375, 1629], "vertical": true, "font_size": 32.0, "lines": ["それらを", "駆使した", "勝負さ。"]}]}