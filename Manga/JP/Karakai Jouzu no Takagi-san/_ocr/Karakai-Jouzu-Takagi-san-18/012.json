{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1053, 110, 1206, 360], "vertical": true, "font_size": 32.0, "lines": ["また明日", "２人で話し合って", "勝敗決めるってのは", "どうかな。"]}, {"box": [588, 140, 702, 363], "vertical": true, "font_size": 28.0, "lines": ["落ち着いたら", "見え方変わるかも", "しれないし。"]}, {"box": [472, 121, 519, 204], "vertical": true, "font_size": 32.0, "lines": ["へえ。"]}, {"box": [664, 661, 832, 883], "vertical": true, "font_size": 32.0, "lines": ["ねぇ、", "どうせなら", "２０歳になった時", "とかにしない？"]}, {"box": [382, 688, 450, 795], "vertical": true, "font_size": 32.0, "lines": ["２０歳！？"]}, {"box": [277, 744, 313, 930], "vertical": true, "font_size": 32.0, "lines": ["そんなに後！！？"]}, {"box": [1059, 1250, 1177, 1475], "vertical": true, "font_size": 32.0, "lines": ["大人になったら", "見え方変わってて", "面白いかなって。"]}, {"box": [571, 1290, 656, 1438], "vertical": true, "font_size": 32.0, "lines": ["んー、", "たしかに。"]}]}