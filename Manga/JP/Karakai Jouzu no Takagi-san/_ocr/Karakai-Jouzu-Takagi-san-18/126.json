{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1104, 99, 1220, 315], "vertical": true, "font_size": 32.0, "lines": ["サナエちゃんは", "陸上部のあたり", "描くのー？"]}, {"box": [648, 198, 780, 328], "vertical": true, "font_size": 32.0, "lines": ["別に、", "どこでも", "いい。"]}, {"box": [446, 97, 555, 332], "vertical": true, "font_size": 30.0, "lines": ["あ、じゃあさー", "屋上行こーよ！！", "みんなで空描こー。"]}, {"box": [176, 185, 215, 294], "vertical": true, "font_size": 32.0, "lines": ["いいよ。"]}, {"box": [1111, 778, 1192, 974], "vertical": true, "font_size": 32.0, "lines": ["ほら、行こー", "ユカリちゃん。"]}, {"box": [881, 523, 902, 631], "vertical": true, "font_size": 21.0, "lines": ["まぁまぁ"]}, {"box": [691, 778, 813, 1070], "vertical": true, "font_size": 32.0, "lines": ["ええ．．．", "私別に屋上に", "思い出ないんだけど。"]}, {"box": [583, 776, 613, 950], "vertical": true, "font_size": 26.0, "lines": ["ユカリちゃん。"]}, {"box": [391, 1314, 566, 1531], "vertical": true, "font_size": 32.0, "lines": ["思いつきで", "深そうな言葉", "ドヤ顔で言うの", "やめな。"]}, {"box": [1156, 1321, 1199, 1575], "vertical": true, "font_size": 27.0, "lines": ["思い出がないなら、"]}, {"box": [622, 1336, 740, 1616], "vertical": true, "font_size": 32.0, "lines": ["これから", "思い出にしちゃえば", "いいのさ。"]}, {"box": [202, 1381, 237, 1549], "vertical": true, "font_size": 32.0, "lines": ["えっへへー。"]}]}