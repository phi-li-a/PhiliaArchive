{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1093, 183, 1210, 369], "vertical": true, "font_size": 32.0, "lines": ["いやでも各自", "思い出の場所", "って。"]}, {"box": [588, 165, 696, 373], "vertical": true, "font_size": 31.0, "lines": ["いーだろ、", "そんなん", "テキトーでさー。"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [322, 161, 479, 307], "vertical": true, "font_size": 32.0, "lines": ["あ、オレは", "描くもの", "決まってる", "から。"]}, {"box": [170, 157, 217, 339], "vertical": true, "font_size": 32.0, "lines": ["何描くんだ？"]}, {"box": [401, 813, 474, 995], "vertical": true, "font_size": 32.0, "lines": ["自販機。"]}, {"box": [1012, 1391, 1198, 1614], "vertical": true, "font_size": 32.0, "lines": ["カロリーの", "足りない時に", "彼はいつも", "そこにいてオレを", "支えてくれた。"]}, {"box": [757, 1398, 801, 1539], "vertical": true, "font_size": 32.0, "lines": ["思い出さ。"]}, {"box": [536, 1408, 616, 1577], "vertical": true, "font_size": 32.0, "lines": ["そうか、", "もう行けよ。"]}, {"box": [354, 1374, 466, 1563], "vertical": true, "font_size": 32.0, "lines": ["じゃあオレたち", "だけで行くか", "西片。"]}, {"box": [120, 1374, 245, 1518], "vertical": true, "font_size": 32.0, "lines": ["ねー", "サナエ", "ちゃーん。"]}]}