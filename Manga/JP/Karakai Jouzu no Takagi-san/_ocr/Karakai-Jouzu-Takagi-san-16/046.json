{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [969, 93, 1178, 339], "vertical": true, "font_size": 30.0, "lines": ["考えろ：どんな", "罰ゲームにすれば", "高木さんを", "負けた気に", "させられるんだ？"]}, {"box": [1115, 577, 1197, 823], "vertical": true, "font_size": 30.0, "lines": ["シンプルに弱点を", "教えてもらうか。"]}, {"box": [571, 573, 609, 789], "vertical": true, "font_size": 32.0, "lines": ["いや、ダメだ．．"]}, {"box": [153, 588, 263, 847], "vertical": true, "font_size": 26.0, "lines": ["はぐらかされた上に", "ヘタしたらまた", "からかわれてしまう。"]}, {"box": [1081, 1162, 1196, 1389], "vertical": true, "font_size": 32.0, "lines": ["今までしてきた", "中で一番", "恥ずかしいコト："]}, {"box": [855, 1188, 881, 1299], "vertical": true, "font_size": 26.0, "lines": ["ううむ．．．"]}, {"box": [705, 1198, 778, 1362], "vertical": true, "font_size": 30.0, "lines": ["せっかくの", "勝利なんだ。"]}, {"box": [183, 1215, 256, 1368], "vertical": true, "font_size": 30.0, "lines": ["もっとこう", "決定的な．．．"]}, {"box": [680, 1616, 724, 1815], "vertical": true, "font_size": 32.0, "lines": ["悩んでるねー。"]}]}