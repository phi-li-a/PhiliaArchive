{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [988, 106, 1157, 356], "vertical": true, "font_size": 32.0, "lines": ["誰にあげるかも", "人間関係把握して", "厳選しなきゃ", "だし。"]}, {"box": [673, 112, 896, 333], "vertical": true, "font_size": 32.0, "lines": ["渡す時に", "先生に見つから", "ないように", "気をつけなきゃ", "だし。"]}, {"box": [466, 95, 583, 247], "vertical": true, "font_size": 32.0, "lines": ["北条：今日", "やけに", "しゃべるな。"]}, {"box": [978, 791, 1093, 1008], "vertical": true, "font_size": 30.0, "lines": ["もしかして．．", "元気づけようと", "してくれてる．．．"]}, {"box": [1115, 1284, 1211, 1518], "vertical": true, "font_size": 32.0, "lines": ["当たり前だんじゃ", "冷たそうだけど、"]}, {"box": [967, 1299, 1042, 1453], "vertical": true, "font_size": 32.0, "lines": ["やさしいん", "だよな。"]}, {"box": [703, 1486, 821, 1743], "vertical": true, "font_size": 31.0, "lines": ["そうさ．．．", "オレはそこが", "好きになったんだ。"]}]}