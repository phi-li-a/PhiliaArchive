{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1098, 198, 1185, 463], "vertical": true, "font_size": 32.0, "lines": ["ふふ．．．", "高木さんのことだ。"]}, {"box": [967, 241, 1007, 352], "vertical": true, "font_size": 32.0, "lines": ["きっと、"]}, {"box": [444, 165, 693, 472], "vertical": true, "font_size": 32.0, "lines": ["オレが口に出しにくい", "チョイスをして", "くるだろう。", "「あなたを好き」とか", "「あいしてます」とか、", "な。"]}, {"box": [129, 82, 568, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [213, 228, 335, 480], "vertical": true, "font_size": 32.0, "lines": ["でも、そんなのは", "文字変えれば", "回避できるのさ。"]}, {"box": [1087, 637, 1200, 851], "vertical": true, "font_size": 32.0, "lines": ["つまりどちらも", "文字間違いで", "引き分け！！"]}, {"box": [678, 656, 762, 868], "vertical": true, "font_size": 32.0, "lines": ["負けはないって", "ワケさ。"]}, {"box": [489, 607, 609, 855], "vertical": true, "font_size": 32.0, "lines": ["どうだい", "気付いてなければ", "オレの勝ち、"]}, {"box": [228, 637, 397, 858], "vertical": true, "font_size": 32.0, "lines": ["気付いていても", "引き分けという", "オレの完璧な", "作戦は。"]}, {"box": [993, 1381, 1042, 1470], "vertical": true, "font_size": 32.0, "lines": ["ほい。"]}, {"box": [718, 1381, 772, 1466], "vertical": true, "font_size": 32.0, "lines": ["「す」"]}, {"box": [144, 1023, 240, 1208], "vertical": true, "font_size": 32.0, "lines": ["ゆかなのよ", "くあさた．．．"]}, {"box": [187, 1447, 283, 1599], "vertical": false, "font_size": 32.0, "lines": ["き"]}]}