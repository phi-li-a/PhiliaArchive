{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1016, 151, 1202, 378], "vertical": true, "font_size": 31.0, "lines": ["しかもさっき", "高木さんに", "やられたのと同じ", "ことをやり返せる", "という一石二鳥。"]}, {"box": [158, 255, 303, 458], "vertical": true, "font_size": 32.0, "lines": ["さらに", "この作戦は", "一段がまえ。"]}, {"box": [1055, 809, 1186, 1053], "vertical": true, "font_size": 32.0, "lines": ["高木さんが", "「ウソ」と答えれば", "オレの勝ちだし、"]}, {"box": [155, 802, 324, 855], "vertical": false, "font_size": 32.0, "lines": ["ウソでした"]}, {"box": [1007, 1126, 1048, 1233], "vertical": true, "font_size": 32.0, "lines": ["ホント"]}, {"box": [474, 834, 644, 1111], "vertical": true, "font_size": 32.0, "lines": ["「ホント」と答えても", "ウソをつく時の", "クセを消して", "きりぬけてやる。"]}, {"box": [1065, 1368, 1185, 1552], "vertical": true, "font_size": 32.0, "lines": ["どっちに", "してもオレの", "勝ちだ。"]}, {"box": [511, 1509, 588, 1650], "vertical": true, "font_size": 32.0, "lines": ["どうだ", "高木さん。"]}]}