{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1024, 193, 1193, 438], "vertical": true, "font_size": 32.0, "lines": ["交換日記のことは", "絶対に他の人に", "バレないように", "しなければ．．．"]}, {"box": [348, 159, 476, 376], "vertical": true, "font_size": 32.0, "lines": ["まぁ高木さんも", "内緒って", "言ってたし．．"]}, {"box": [153, 476, 243, 753], "vertical": true, "font_size": 32.0, "lines": ["オレが気をつければ", "バレはしないか．．．"]}, {"box": [761, 924, 808, 1066], "vertical": true, "font_size": 32.0, "lines": ["よー西片。"]}, {"box": [661, 965, 695, 1104], "vertical": true, "font_size": 32.0, "lines": ["おはよー。"]}, {"box": [1055, 1484, 1201, 1625], "vertical": true, "font_size": 32.0, "lines": ["平常心", "平常心．．．"]}, {"box": [798, 1484, 825, 1604], "vertical": true, "font_size": 21.0, "lines": ["おはよう。"]}, {"box": [159, 1505, 234, 1640], "vertical": true, "font_size": 32.0, "lines": ["そういや", "聞いたぞ。"]}]}