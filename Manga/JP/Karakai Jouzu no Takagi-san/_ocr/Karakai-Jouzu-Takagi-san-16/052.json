{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1042, 73, 1166, 339], "vertical": true, "font_size": 32.0, "lines": ["「好きな人の名前を", "言う」で西片が", "ＯＫしてたら、"]}, {"box": [872, 106, 945, 330], "vertical": true, "font_size": 32.0, "lines": ["西片の好きな人", "知れたのになー。"]}, {"box": [710, 255, 752, 339], "vertical": true, "font_size": 32.0, "lines": ["なっ。"]}, {"box": [616, 106, 643, 286], "vertical": true, "font_size": 28.0, "lines": ["危なかった．．．"]}, {"box": [487, 84, 555, 341], "vertical": true, "font_size": 28.0, "lines": ["まぁ好きな人とか", "よくわかんないけど。"]}, {"box": [590, 477, 635, 615], "vertical": true, "font_size": 32.0, "lines": ["ねぇ西片。"]}, {"box": [1074, 956, 1122, 1184], "vertical": true, "font_size": 32.0, "lines": ["私の好きな人は、"]}, {"box": [253, 961, 334, 1175], "vertical": true, "font_size": 32.0, "lines": ["いつでも聞いて", "いいからね。"]}, {"box": [510, 1558, 553, 1725], "vertical": true, "font_size": 32.0, "lines": ["聞けるかぁ。"]}, {"box": [185, 1595, 304, 1781], "vertical": true, "font_size": 32.0, "lines": ["罰ゲーム．．．", "何に", "しよっかなー。"]}]}