{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1060, 116, 1187, 333], "vertical": true, "font_size": 32.0, "lines": ["繰り返すとは．．", "そんな手が", "あったなんて．．．"]}, {"box": [328, 112, 442, 280], "vertical": true, "font_size": 31.0, "lines": ["へんなコト", "しなきゃ", "よかったね。"]}, {"box": [140, 86, 183, 153], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}, {"box": [1072, 605, 1205, 826], "vertical": true, "font_size": 32.0, "lines": ["私、一番下の段", "見えてなかった", "からさ。"]}, {"box": [631, 620, 708, 834], "vertical": true, "font_size": 31.0, "lines": ["普通に視力勝負", "してたら、"]}, {"box": [472, 731, 545, 924], "vertical": true, "font_size": 31.0, "lines": ["西片の勝ち", "だったんだよ。"]}, {"box": [271, 660, 316, 733], "vertical": true, "font_size": 32.0, "lines": ["な！！"]}, {"box": [608, 1487, 638, 1589], "vertical": true, "font_size": 30.0, "lines": ["．．．．．．？"]}]}