{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1080, 123, 1271, 393], "vertical": true, "font_size": 32.0, "lines": ["文字を", "６回さして", "正解率の高い方が", "勝ち。"]}, {"box": [577, 101, 708, 285], "vertical": true, "font_size": 32.0, "lines": ["小さい文字が", "見える方じゃ", "なくて？"]}, {"box": [181, 123, 271, 270], "vertical": true, "font_size": 32.0, "lines": ["変な", "勝負だね。"]}, {"box": [1093, 761, 1175, 931], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "私からねー。"]}, {"box": [467, 736, 543, 958], "vertical": true, "font_size": 26.0, "lines": ["そこの線こえたら", "反則だからね。"]}, {"box": [155, 746, 225, 860], "vertical": true, "font_size": 32.0, "lines": ["わかって", "るって。"]}, {"box": [275, 941, 320, 1108], "vertical": true, "font_size": 32.0, "lines": ["ゆかなのよ"]}, {"box": [230, 982, 262, 1106], "vertical": true, "font_size": 32.0, "lines": ["あさた！"]}, {"box": [1037, 1451, 1185, 1715], "vertical": true, "font_size": 31.0, "lines": ["あ、あと", "やりはじめたら", "よけいなコトは", "しゃべらないように。"]}, {"box": [483, 1486, 597, 1741], "vertical": true, "font_size": 30.0, "lines": ["途中で「あー」とか", "「うーん」とか言うと、", "まぎらわしいし。"]}, {"box": [151, 1445, 195, 1710], "vertical": true, "font_size": 32.0, "lines": ["うん、", "いいよ。"]}]}