{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1060, 127, 1177, 313], "vertical": true, "font_size": 30.0, "lines": ["フライパンは", "まかせろとか", "言ったのは。"]}, {"box": [688, 103, 811, 241], "vertical": true, "font_size": 32.0, "lines": ["面目ねぇ．．．"]}, {"box": [210, 84, 241, 221], "vertical": true, "font_size": 31.0, "lines": ["まったく。"]}, {"box": [1115, 628, 1194, 843], "vertical": true, "font_size": 32.0, "lines": ["ま、いいけどね", "味はいいし。"]}, {"box": [823, 684, 867, 791], "vertical": true, "font_size": 32.0, "lines": ["許すわ。"]}, {"box": [559, 672, 722, 755], "vertical": false, "font_size": 32.0, "lines": ["まー北条さんがいいならいいけど．．．"]}, {"box": [457, 641, 517, 731], "vertical": true, "font_size": 32.0, "lines": ["北条。"]}, {"box": [151, 641, 240, 836], "vertical": true, "font_size": 32.0, "lines": ["私も味噌汁ー", "自信ないし．．．"]}, {"box": [969, 1177, 1181, 1516], "vertical": true, "font_size": 32.0, "lines": ["こちら、素材を", "楽しんでいただける", "ようにオリーブオイルと", "塩のみで味つけを", "しております。"]}, {"box": [358, 1200, 390, 1413], "vertical": true, "font_size": 32.0, "lines": ["サラダ油だろ！！"]}, {"box": [153, 1226, 279, 1445], "vertical": true, "font_size": 32.0, "lines": ["でけー魚", "選んでんだから", "真面目にやれ！！"]}]}