{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [349, 73, 428, 247], "vertical": true, "font_size": 22.0, "lines": ["お前らって", "ホントに付き合って", "ないの？"]}, {"box": [243, 90, 275, 142], "vertical": true, "font_size": 32.0, "lines": ["は！？"]}, {"box": [661, 520, 740, 655], "vertical": true, "font_size": 21.0, "lines": ["何言ってんの！？", "そんなんじゃ", "ないって！"]}, {"box": [89, 505, 162, 631], "vertical": true, "font_size": 23.0, "lines": ["え、マラソンで", "勝負って", "お前．．"]}, {"box": [302, 535, 409, 727], "vertical": true, "font_size": 22.0, "lines": ["マラソンで勝った方が", "負けた方の", "言うこと聞くって", "勝負するだけだよ。"]}, {"box": [94, 707, 155, 796], "vertical": true, "font_size": 30.0, "lines": ["別に", "いいだろ。"]}, {"box": [579, 889, 747, 1068], "vertical": true, "font_size": 20.0, "lines": ["まぁたしかに", "付き合ってるって", "カンジじゃ", "ないかもなー。"]}, {"box": [343, 901, 421, 1018], "vertical": true, "font_size": 24.0, "lines": ["うん、っ", "付き合ってる", "ってのは．．"]}, {"box": [93, 887, 125, 993], "vertical": true, "font_size": 24.0, "lines": ["中井くーん。"]}]}