{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [385, 91, 487, 262], "vertical": true, "font_size": 19.0, "lines": ["当てれたら、", "さっき西片が台風で", "はしゃいでたの", "だまっててあげる。"]}, {"box": [107, 106, 155, 258], "vertical": true, "font_size": 20.0, "lines": ["いやだから", "あれは風向きを．．．"]}, {"box": [691, 685, 742, 857], "vertical": true, "font_size": 22.0, "lines": ["あのゴミ袋が", "こっちくるまでね！"]}, {"box": [390, 603, 441, 720], "vertical": true, "font_size": 24.0, "lines": ["せ．．．", "制限時間．．．？"]}, {"box": [294, 598, 339, 751], "vertical": true, "font_size": 20.0, "lines": ["く：なんとしても", "当てねば．．．"]}, {"box": [637, 992, 735, 1133], "vertical": true, "font_size": 20.0, "lines": ["わざわざ", "問題に", "するってことは", "ヒネってあるな。"]}, {"box": [119, 990, 224, 1152], "vertical": true, "font_size": 20.0, "lines": ["風が強いから", "自転車だと", "危ないなんて", "答えじゃないハズ。"]}]}