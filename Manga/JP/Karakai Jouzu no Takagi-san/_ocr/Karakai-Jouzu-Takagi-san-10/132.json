{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [763, 84, 790, 130], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [420, 76, 468, 229], "vertical": true, "font_size": 22.0, "lines": ["セロハンテープで", "蓋した箱．．．？"]}, {"box": [278, 64, 358, 217], "vertical": true, "font_size": 20.0, "lines": ["いろんな友達に．．．", "材料借りて．．．", "作ってきたんだ。"]}, {"box": [112, 108, 131, 144], "vertical": false, "font_size": 32.0, "lines": ["は．．．"]}, {"box": [271, 308, 297, 359], "vertical": true, "font_size": 22.0, "lines": ["へえ。"]}, {"box": [114, 294, 216, 430], "vertical": true, "font_size": 22.0, "lines": ["休み時間に", "なった途端", "どこか行ったと", "思ったら。"]}, {"box": [591, 601, 686, 718], "vertical": true, "font_size": 25.0, "lines": ["勝負を", "しないかい", "高木さん。"]}, {"box": [673, 951, 726, 1074], "vertical": true, "font_size": 24.0, "lines": ["１分以内に", "この箱の中に、"]}, {"box": [388, 933, 470, 1089], "vertical": true, "font_size": 23.0, "lines": ["何が入っているか", "答えられたら", "高木さんの勝ち。"]}, {"box": [94, 929, 175, 1045], "vertical": true, "font_size": 20.0, "lines": ["道具の使用と", "箱を壊すのは", "禁止で。"]}]}