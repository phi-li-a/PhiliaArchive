{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [643, 66, 741, 228], "vertical": true, "font_size": 20.0, "lines": ["開けると", "また中は箱で．．．", "さらに多い", "セロハンテープで："]}, {"box": [394, 98, 421, 142], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [727, 460, 751, 595], "vertical": true, "font_size": 20.0, "lines": ["何してんの．．．？"]}, {"box": [468, 473, 492, 514], "vertical": true, "font_size": 24.0, "lines": ["ん？"]}, {"box": [373, 473, 419, 633], "vertical": true, "font_size": 18.0, "lines": ["ふってみて", "音聞いてるんだよ。"]}, {"box": [99, 461, 176, 607], "vertical": true, "font_size": 23.0, "lines": ["んー、なぁ", "中にもう１つ", "箱があるのかな。"]}, {"box": [656, 888, 729, 986], "vertical": true, "font_size": 22.0, "lines": ["その中に―", "小さめの", "ものかな．．．"]}, {"box": [497, 916, 571, 1014], "vertical": true, "font_size": 22.0, "lines": ["そこまで", "固くも", "なさそう．．．"]}, {"box": [358, 902, 384, 932], "vertical": true, "font_size": 26.0, "lines": ["て、"]}, {"box": [247, 914, 326, 1035], "vertical": true, "font_size": 26.0, "lines": ["西片が", "持ってそうな", "物といえば．．．"]}]}