{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [632, 123, 756, 222], "vertical": true, "font_size": 22.0, "lines": ["西部劇かと", "思いきや、", "実は未来の", "話でね。"]}, {"box": [461, 116, 540, 278], "vertical": true, "font_size": 26.0, "lines": ["地球はうちうじん", "宇宙人と戦争に", "なりそうなんだよ。"]}, {"box": [332, 107, 405, 262], "vertical": true, "font_size": 21.0, "lines": ["てもムダな血を", "流すのを", "好まない宇宙人が"]}, {"box": [200, 107, 299, 243], "vertical": true, "font_size": 21.0, "lines": ["地球式の代表者", "一名ずつの", "決闘をしようと", "言ってきて、"]}, {"box": [702, 505, 749, 627], "vertical": true, "font_size": 22.0, "lines": ["へえー", "面白そうだね。"]}, {"box": [511, 276, 587, 348], "vertical": false, "font_size": 16.0, "lines": ["それはそうですか．．．"]}, {"box": [422, 543, 444, 622], "vertical": true, "font_size": 22.0, "lines": ["でしょ！"]}, {"box": [274, 494, 350, 619], "vertical": true, "font_size": 22.0, "lines": ["そして", "ラストの", "どんでん返し。"]}, {"box": [96, 276, 169, 400], "vertical": true, "font_size": 22.0, "lines": ["それに", "主人公が", "選ばれるんだ。"]}, {"box": [615, 871, 728, 987], "vertical": true, "font_size": 25.0, "lines": ["なんと", "主人公も", "宇宙人", "だったんだ。"]}]}