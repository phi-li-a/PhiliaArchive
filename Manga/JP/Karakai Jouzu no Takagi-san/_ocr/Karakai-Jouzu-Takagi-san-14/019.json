{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [619, 66, 703, 260], "vertical": true, "font_size": 23.0, "lines": ["好きな人の名前書くと", "ずっと一緒にいられる", "らしいよ。"]}, {"box": [712, 391, 733, 476], "vertical": true, "font_size": 21.0, "lines": ["へ．．．へぇ．．．"]}, {"box": [394, 390, 468, 516], "vertical": true, "font_size": 21.0, "lines": ["そうだ", "西片、罰ゲーム", "あったよねー。"]}, {"box": [247, 380, 297, 480], "vertical": true, "font_size": 24.0, "lines": ["あの", "ノートに．．．"]}, {"box": [713, 675, 734, 796], "vertical": true, "font_size": 20.0, "lines": ["いやしやいや。"]}, {"box": [403, 677, 453, 791], "vertical": true, "font_size": 18.0, "lines": ["オレそんな人", "いないし！！"]}, {"box": [301, 678, 347, 764], "vertical": true, "font_size": 18.0, "lines": ["あはは、", "冗談だよ。"]}, {"box": [323, 958, 345, 1060], "vertical": true, "font_size": 20.0, "lines": ["罰ゲームは、"]}, {"box": [258, 976, 282, 1080], "vertical": true, "font_size": 20.0, "lines": ["そうだなぁ。"]}]}