{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [710, 88, 739, 230], "vertical": true, "font_size": 20.0, "lines": ["頂上に着いたら、"]}, {"box": [388, 41, 468, 275], "vertical": true, "font_size": 25.0, "lines": ["今登ってきた", "階段は何段だったでしょう", "と聞く作戦。"]}, {"box": [277, 55, 324, 151], "vertical": true, "font_size": 20.0, "lines": ["高木さんの", "ことだ．．．"]}, {"box": [87, 50, 214, 205], "vertical": true, "font_size": 20.0, "lines": ["学校の階段の数は", "知ってても", "おかしくないから", "わざわざこんな", "場所にしたのさ。"]}, {"box": [51, 278, 133, 432], "vertical": true, "font_size": 21.0, "lines": ["ここは登ったこと", "ないってさっき", "言ってたし．．．"]}, {"box": [569, 591, 725, 757], "vertical": true, "font_size": 24.0, "lines": ["たくさん", "話しかけることで、", "何段か数えて", "いるという", "万が一の可能性も", "潰した。"]}, {"box": [108, 609, 130, 673], "vertical": true, "font_size": 22.0, "lines": ["ふふふ"]}, {"box": [121, 931, 150, 1033], "vertical": true, "font_size": 21.0, "lines": ["勝ったな。"]}]}