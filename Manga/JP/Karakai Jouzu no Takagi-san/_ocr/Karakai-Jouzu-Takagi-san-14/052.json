{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [674, 77, 742, 235], "vertical": true, "font_size": 20.0, "lines": ["オレも．．．", "一人で食べるよりは", "楽しかったし．．"]}, {"box": [458, 102, 476, 205], "vertical": true, "font_size": 16.0, "lines": ["ありがとう．．．"]}, {"box": [330, 319, 404, 435], "vertical": true, "font_size": 21.0, "lines": ["じゃあまた", "一緒に食べて", "くれる？"]}, {"box": [674, 578, 743, 665], "vertical": true, "font_size": 26.0, "lines": ["うん。"]}, {"box": [561, 916, 691, 1051], "vertical": true, "font_size": 20.0, "lines": ["じゃあ今度は", "西片がして", "ほしそうだった", "あーんを", "してあげよう。"]}, {"box": [196, 932, 271, 1031], "vertical": true, "font_size": 22.0, "lines": ["だから", "してほしく", "ないって。"]}]}