{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [647, 113, 754, 267], "vertical": true, "font_size": 20.0, "lines": ["そうか．．．高木さん", "オレの謎の", "心のざわめきを", "察して．．．"]}, {"box": [402, 116, 453, 269], "vertical": true, "font_size": 20.0, "lines": ["落ちつかせようと", "して犬を．．．？"]}, {"box": [309, 103, 336, 210], "vertical": true, "font_size": 20.0, "lines": ["その子だよ。"]}, {"box": [656, 461, 686, 507], "vertical": true, "font_size": 30.0, "lines": ["へ？"]}, {"box": [158, 480, 214, 553], "vertical": true, "font_size": 30.0, "lines": ["１５歳の．．．", "男の子。"]}, {"box": [461, 773, 541, 926], "vertical": true, "font_size": 23.0, "lines": ["近くの", "おばあちゃん家の", "子なんだけど、"]}, {"box": [254, 774, 330, 953], "vertical": true, "font_size": 22.0, "lines": ["もう", "犬にしては", "おじいちゃんだから、"]}, {"box": [124, 780, 196, 923], "vertical": true, "font_size": 22.0, "lines": ["服着させて", "あげたいって", "相談されてさー。"]}]}