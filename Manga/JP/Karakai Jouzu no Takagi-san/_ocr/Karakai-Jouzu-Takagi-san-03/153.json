{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [682, 133, 737, 288], "vertical": true, "font_size": 22.0, "lines": ["高木さん", "勝負しないかい？"]}, {"box": [80, 51, 372, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさん８"]}, {"box": [123, 141, 155, 207], "vertical": true, "font_size": 26.0, "lines": ["勝負？"]}, {"box": [634, 510, 738, 626], "vertical": true, "font_size": 22.0, "lines": ["ああ、", "この先の角を", "曲がったら", "スタート、"]}, {"box": [504, 498, 579, 595], "vertical": true, "font_size": 22.0, "lines": ["神社に先に", "ついた方が", "勝ちで。"]}, {"box": [203, 526, 228, 591], "vertical": true, "font_size": 22.0, "lines": ["ふーん、"]}, {"box": [638, 826, 742, 969], "vertical": true, "font_size": 22.0, "lines": ["ふふふったからっ", "高木さんの", "自転車は", "バンクしている。"]}, {"box": [514, 817, 590, 952], "vertical": true, "font_size": 22.0, "lines": ["オレの方が", "速いに決まって", "いるのさ。"]}, {"box": [134, 562, 154, 659], "vertical": true, "font_size": 22.0, "lines": ["いいけど？"]}, {"box": [208, 827, 256, 943], "vertical": true, "font_size": 20.0, "lines": ["言ってるワケ", "ないだろ。"]}, {"box": [105, 844, 151, 1035], "vertical": true, "font_size": 20.0, "lines": ["だいたい勝負って何よ", "勝負って。"]}]}