{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [406, 133, 437, 196], "vertical": true, "font_size": 26.0, "lines": ["鉄棒？"]}, {"box": [104, 125, 184, 278], "vertical": true, "font_size": 21.0, "lines": ["高い方で逆上がり", "てきなかった方が", "負けってことで。"]}, {"box": [599, 601, 750, 801], "vertical": true, "font_size": 21.0, "lines": ["フフフ．．．", "最近高い方の", "鉄棒で何気なく", "逆上がりしてみたら", "生まれて初めて", "成功してしまったのさ。"]}, {"box": [114, 638, 220, 812], "vertical": true, "font_size": 22.0, "lines": ["それ以来なさ", "高木さんが勝負を", "持ちかけてくるのを", "待っていたんだ。"]}, {"box": [622, 953, 719, 1109], "vertical": true, "font_size": 21.0, "lines": ["もしかしたら", "高木さんも", "逆上がりできるの", "かもしれない"]}, {"box": [429, 941, 449, 1017], "vertical": true, "font_size": 20.0, "lines": ["だが．．．！"]}, {"box": [105, 922, 132, 1006], "vertical": true, "font_size": 20.0, "lines": ["ねぇ西片"]}]}