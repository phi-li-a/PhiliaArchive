{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [678, 87, 787, 229], "vertical": true, "font_size": 25.0, "lines": ["今、男子の中で", "誰が一番面白い", "写真撮れるか", "勝負しててさ。"]}, {"box": [397, 111, 422, 179], "vertical": true, "font_size": 25.0, "lines": ["ふーん。"]}, {"box": [274, 105, 330, 210], "vertical": true, "font_size": 20.0, "lines": ["今一番って", "誰なの？"]}, {"box": [665, 567, 718, 685], "vertical": true, "font_size": 24.0, "lines": ["木村のこれが", "ダントツ。"]}, {"box": [146, 562, 193, 659], "vertical": true, "font_size": 19.0, "lines": ["あーこれは", "強烈だね．．．"]}, {"box": [690, 941, 743, 1030], "vertical": true, "font_size": 27.0, "lines": ["面白い", "写真かー。"]}]}