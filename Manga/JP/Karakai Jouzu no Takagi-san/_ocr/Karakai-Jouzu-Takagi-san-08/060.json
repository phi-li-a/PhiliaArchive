{"version": "0.1.6", "img_width": 720, "img_height": 1020, "blocks": [{"box": [603, 57, 691, 206], "vertical": true, "font_size": 19.0, "lines": ["ふふふ．．", "昨日帰り道で", "チラッと言っていた", "あのセリフ、"]}, {"box": [406, 45, 495, 131], "vertical": true, "font_size": 23.0, "lines": ["なんか", "ブレーキの", "効きが", "悪いなー。"]}, {"box": [110, 32, 173, 134], "vertical": true, "font_size": 18.0, "lines": ["オレは", "聞き逃して", "いないのだよ。"]}, {"box": [457, 418, 496, 531], "vertical": true, "font_size": 20.0, "lines": ["こうもあっさり", "勝てるとは．．．"]}, {"box": [392, 404, 416, 461], "vertical": true, "font_size": 21.0, "lines": ["答えは、"]}, {"box": [283, 429, 300, 462], "vertical": true, "font_size": 17.0, "lines": ["フレ"]}, {"box": [212, 424, 254, 521], "vertical": true, "font_size": 20.0, "lines": ["あ、ちょっと", "待って。"]}, {"box": [444, 606, 511, 678], "vertical": true, "font_size": 20.0, "lines": ["少し", "拍子抜け", "だよ．．．"]}, {"box": [520, 774, 611, 861], "vertical": true, "font_size": 20.0, "lines": ["間違ったら", "その時点で", "西片の負け", "だからね。"]}]}