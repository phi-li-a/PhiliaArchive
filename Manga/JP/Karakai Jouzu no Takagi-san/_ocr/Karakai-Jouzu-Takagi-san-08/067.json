{"version": "0.1.6", "img_width": 720, "img_height": 1020, "blocks": [{"box": [581, 106, 633, 200], "vertical": true, "font_size": 21.0, "lines": ["階段、", "そしてネコ。"]}, {"box": [439, 119, 526, 269], "vertical": true, "font_size": 21.0, "lines": ["自転車では", "できないコトに", "意識を向けようと", "していたみたいだが、"]}, {"box": [68, 43, 317, 62], "vertical": false, "font_size": 18.0, "lines": ["からかいと手の高ホさんＱ"]}, {"box": [128, 129, 172, 267], "vertical": true, "font_size": 18.0, "lines": ["少しやりすぎて", "しまったようだね。"]}, {"box": [555, 404, 618, 549], "vertical": true, "font_size": 17.0, "lines": ["昨日言ってしまった", "ブレーキの", "違和感から、"]}, {"box": [409, 433, 491, 537], "vertical": true, "font_size": 17.0, "lines": ["オレの思考を", "遠ざけようと", "しているのが", "バレバレだよ。"]}, {"box": [260, 415, 301, 489], "vertical": true, "font_size": 18.0, "lines": ["どうだい", "高木さん。"]}, {"box": [556, 695, 584, 775], "vertical": true, "font_size": 21.0, "lines": ["正解か！"]}, {"box": [133, 709, 163, 830], "vertical": true, "font_size": 24.0, "lines": ["不正解か．．．！！"]}]}