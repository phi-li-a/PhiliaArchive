{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [547, 62, 630, 161], "vertical": true, "font_size": 25.0, "lines": ["何よ！", "じゃあ勝負", "する！？"]}, {"box": [416, 48, 493, 192], "vertical": true, "font_size": 20.0, "lines": ["ハハハ！勝負？", "別にいいよ", "負けないしオレ。"]}, {"box": [281, 21, 359, 196], "vertical": true, "font_size": 25.0, "lines": ["じゃあ１回ずつ", "投げて、先に入れた", "方が勝ちね。"]}, {"box": [117, 55, 165, 196], "vertical": true, "font_size": 23.0, "lines": ["フフ．．．", "取り乱している。"]}, {"box": [670, 500, 745, 636], "vertical": true, "font_size": 21.0, "lines": ["高木さんが", "冷静さを", "失っている．．．！"]}, {"box": [591, 501, 613, 635], "vertical": true, "font_size": 21.0, "lines": ["オレのせいで！！"]}, {"box": [119, 495, 181, 645], "vertical": true, "font_size": 27.0, "lines": ["なんて", "いい気分だ！！"]}, {"box": [635, 907, 739, 1061], "vertical": true, "font_size": 20.0, "lines": ["もし高木さんが", "勝ったらなんでも", "言うコト聞いて", "あげるよ。"]}, {"box": [113, 926, 166, 1041], "vertical": true, "font_size": 23.0, "lines": ["言ってくれる", "わね！"]}]}