{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [615, 209, 735, 234], "vertical": false, "font_size": 25.0, "lines": ["札月キョーコ"]}, {"box": [421, 101, 552, 164], "vertical": false, "font_size": 32.0, "lines": ["－＆ｃスト"]}, {"box": [319, 176, 527, 218], "vertical": false, "font_size": 18.0, "lines": ["ＴｕｄａｔｓｕｋｉｎｏＫｙｏｋｏ．Ｃｈａｎ", "Ｃｈａｒａｃｔｅｒ８：８ｔｏｒｙ"]}, {"box": [113, 205, 221, 236], "vertical": false, "font_size": 29.0, "lines": ["札月ケンジ"]}, {"box": [687, 287, 704, 342], "vertical": true, "font_size": 17.0, "lines": ["お兄ちゃん"]}, {"box": [504, 444, 698, 481], "vertical": false, "font_size": 16.0, "lines": ["◆普段はクールだが、", "リポンが取れると凶暴＆素直化"]}, {"box": [570, 513, 694, 596], "vertical": false, "font_size": 17.0, "lines": ["つ想いを寄せる", "日々野さんにも", "「シスコン」呼ばわり", "されるが、実は．．"]}, {"box": [502, 297, 520, 346], "vertical": true, "font_size": 18.0, "lines": ["ゴメンね。"]}, {"box": [468, 519, 509, 576], "vertical": true, "font_size": 18.0, "lines": ["札月君ですっ！", "シスコンだし"]}, {"box": [279, 331, 309, 388], "vertical": true, "font_size": 12.0, "lines": ["おはこれが"]}, {"box": [317, 537, 342, 581], "vertical": true, "font_size": 25.0, "lines": ["そんなんだからシスコンって言われんのよ。"]}, {"box": [146, 354, 155, 393], "vertical": true, "font_size": 12.0, "lines": ["お姉たな。"]}, {"box": [115, 444, 303, 461], "vertical": false, "font_size": 12.0, "lines": ["皆が恐れるシスコンヤンキー"]}, {"box": [188, 539, 215, 610], "vertical": true, "font_size": 13.0, "lines": ["オレはシスコン", "じゃねぇえ！！"]}, {"box": [119, 539, 136, 584], "vertical": true, "font_size": 17.0, "lines": ["いや．．．シスコンだろ。"]}, {"box": [530, 698, 710, 738], "vertical": false, "font_size": 14.0, "lines": ["９彼の妹キョ一コは人の血を", "吸う怪力のキヨンシーであり。"]}, {"box": [343, 828, 501, 933], "vertical": false, "font_size": 16.0, "lines": ["●札の役割である", "リポンがほどけてしまうと、", "本能のままに人を", "襲ってしまう。おまけに", "素直になってしまうのだ"]}, {"box": [286, 805, 304, 845], "vertical": true, "font_size": 18.0, "lines": ["ありがとうお兄ちゃん。"]}, {"box": [112, 691, 363, 752], "vertical": false, "font_size": 16.0, "lines": ["つ妹に近づ〈男を片っ端から威圧すること", "から、校内最強の「シスコンヤンキー」と", "恐れられるれ月ケンジ"]}, {"box": [127, 802, 164, 863], "vertical": true, "font_size": 32.0, "lines": ["すごく素直になる。"]}, {"box": [197, 1000, 793, 1123], "vertical": false, "font_size": 32.0, "lines": ["かわいいボンスと．．．", "２０１３．．．ここで『一般ビフォーアフター！！"]}, {"box": [73, 1051, 191, 1079], "vertical": false, "font_size": 23.0, "lines": ["ＰＯＩＮＴ"]}]}