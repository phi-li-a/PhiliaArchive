{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [596, 90, 709, 365], "vertical": true, "font_size": 30.0, "lines": ["これは普段からかわれ", "すぎている自分への：", "罰なのだ。"]}, {"box": [454, 53, 505, 204], "vertical": true, "font_size": 18.0, "lines": ["この苦しみを", "噛みしめながら．．．"]}, {"box": [72, 73, 147, 208], "vertical": true, "font_size": 20.0, "lines": ["次こそはという", "意識を高める", "のだ．．．"]}, {"box": [73, 276, 145, 408], "vertical": true, "font_size": 20.0, "lines": ["この罰の目的は", "そこにあるの", "だから．．．！！"]}, {"box": [617, 532, 737, 694], "vertical": true, "font_size": 24.0, "lines": ["がんばれオレ！", "こんな苦しみを", "味わいたく", "なければ．．．"]}, {"box": [637, 818, 674, 971], "vertical": true, "font_size": 32.0, "lines": ["見てろよ！！"]}, {"box": [103, 527, 228, 711], "vertical": true, "font_size": 22.0, "lines": ["明日からはもっと", "からかわれない", "ように気を", "つけるんだ！"]}, {"box": [492, 1027, 513, 1100], "vertical": true, "font_size": 18.0, "lines": ["ひゃく．．．"]}, {"box": [444, 1078, 460, 1170], "vertical": true, "font_size": 18.0, "lines": ["ごじゅう．．．"]}, {"box": [187, 867, 233, 1026], "vertical": true, "font_size": 32.0, "lines": ["高木さん！！"]}]}