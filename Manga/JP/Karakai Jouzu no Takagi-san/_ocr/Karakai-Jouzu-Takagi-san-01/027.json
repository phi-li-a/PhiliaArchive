{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [653, 67, 742, 254], "vertical": true, "font_size": 29.0, "lines": ["高木さんめ．．．オレが", "生理って言えないと", "思っての自信か？"]}, {"box": [454, 73, 526, 171], "vertical": true, "font_size": 20.0, "lines": ["だとしたら", "オレを甘く", "見すぎ．．．"]}, {"box": [349, 98, 402, 270], "vertical": true, "font_size": 24.0, "lines": ["いや待て！", "高木さんのことだ！"]}, {"box": [108, 78, 181, 212], "vertical": true, "font_size": 21.0, "lines": ["これは", "トラップの", "可能性もある！！"]}, {"box": [494, 532, 522, 616], "vertical": true, "font_size": 21.0, "lines": ["失礼な奴。"]}, {"box": [110, 549, 162, 646], "vertical": true, "font_size": 23.0, "lines": ["十分に", "ありえる！！"]}, {"box": [633, 527, 738, 679], "vertical": true, "font_size": 22.0, "lines": ["オレが勇気を", "ふりしぼって", "「生理」と", "答えたところで．．"]}, {"box": [660, 796, 738, 950], "vertical": true, "font_size": 22.0, "lines": ["いや、しかし", "そこまで読んでの", "．．．"]}, {"box": [523, 810, 596, 925], "vertical": true, "font_size": 22.0, "lines": ["クソ、わけが", "わからなく", "なってきた．．"]}, {"box": [178, 808, 254, 906], "vertical": true, "font_size": 23.0, "lines": ["そうだ．．．", "他の可能性", "は．．．！"]}]}