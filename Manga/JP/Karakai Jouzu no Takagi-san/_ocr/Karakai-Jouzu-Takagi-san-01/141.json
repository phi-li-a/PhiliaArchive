{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [639, 124, 713, 248], "vertical": true, "font_size": 20.0, "lines": ["あ．．．いや～～", "あのオレまだ", "読んでないし。"]}, {"box": [391, 113, 490, 295], "vertical": true, "font_size": 20.0, "lines": ["どんなのか", "知りたいだけだから。", "なんなら表紙", "だけでも。"]}, {"box": [282, 119, 329, 215], "vertical": true, "font_size": 21.0, "lines": ["ムリムリ！", "絶対ムリ！！"]}, {"box": [82, 51, 357, 71], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんは"]}, {"box": [156, 107, 230, 242], "vertical": true, "font_size": 21.0, "lines": ["オレだってまだ", "表紙ちゃんと", "見てないもん！！"]}, {"box": [91, 305, 143, 421], "vertical": true, "font_size": 20.0, "lines": ["じゃあ一緒に", "見ようよ。"]}, {"box": [102, 493, 181, 611], "vertical": true, "font_size": 22.0, "lines": ["オレ、一人で", "見るタイプ", "だからさぁ！！"]}, {"box": [693, 691, 718, 773], "vertical": true, "font_size": 23.0, "lines": ["ちぇ"]}, {"box": [176, 682, 249, 814], "vertical": true, "font_size": 20.0, "lines": ["まさかこんなに", "食いついてくる", "なんて．．．"]}, {"box": [111, 720, 131, 877], "vertical": true, "font_size": 20.0, "lines": ["なんて危険な人だ。"]}, {"box": [629, 953, 683, 1114], "vertical": true, "font_size": 20.0, "lines": ["ここは早く", "離れた方がいいな。"]}, {"box": [124, 959, 177, 1102], "vertical": true, "font_size": 20.0, "lines": ["じゃあ高木さん、", "オレ．．．帰るから。"]}]}