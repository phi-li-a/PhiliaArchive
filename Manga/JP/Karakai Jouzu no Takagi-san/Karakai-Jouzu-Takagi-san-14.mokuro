, 726, 1114], "vertical": true, "font_size": 22.0, "lines": ["あ、でも", "浜口が告白", "したらオレも、", "なんだっけ！？"]}, {"box": [204, 995, 222, 1112], "vertical": true, "font_size": 15.0, "lines": ["どうしよう！！"]}], "img_path": "098.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [262, 318, 280, 383], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．？"]}, {"box": [674, 590, 726, 707], "vertical": true, "font_size": 20.0, "lines": ["じゃ、私．．．", "こっちだか．．．"]}, {"box": [415, 604, 450, 677], "vertical": true, "font_size": 30.0, "lines": ["北条！！"]}, {"box": [332, 877, 356, 921], "vertical": true, "font_size": 24.0, "lines": ["な．．．"]}, {"box": [721, 885, 747, 946], "vertical": true, "font_size": 26.0, "lines": ["あの．．．"]}, {"box": [49, 877, 96, 933], "vertical": true, "font_size": 32.0, "lines": ["何？"]}], "img_path": "099.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [470, 151, 498, 248], "vertical": true, "font_size": 20.0, "lines": ["また明日："]}, {"box": [682, 659, 708, 728], "vertical": true, "font_size": 26.0, "lines": ["バーカ。"]}, {"box": [360, 660, 381, 728], "vertical": true, "font_size": 20.0, "lines": ["またね。"]}, {"box": [644, 949, 692, 1045], "vertical": true, "font_size": 22.0, "lines": ["オレは．．．", "ヘタレだ．．．"]}], "img_path": "100.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "101.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [369, 1078, 763, 1113], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さん"]}], "img_path": "102.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "103.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [720, 195, 813, 256], "vertical": false, "font_size": 32.0, "lines": ["カンコーン"]}, {"box": [486, 85, 571, 169], "vertical": true, "font_size": 27.0, "lines": ["じゃ、", "帰ろうよ", "西片。"]}, {"box": [377, 570, 396, 685], "vertical": true, "font_size": 16.0, "lines": ["あ．．．えっと．．．"]}, {"box": [649, 904, 721, 1040], "vertical": true, "font_size": 20.0, "lines": ["ゴメン．．．", "今日はちょっと", "寄るところが．．．"]}, {"box": [169, 935, 196, 982], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}], "img_path": "104.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [413, 71, 567, 212], "vertical": true, "font_size": 26.0, "lines": ["あ、", "そっか。", "今日", "「１００％片想い」の", "発売日か。"]}, {"box": [247, 44, 289, 148], "vertical": true, "font_size": 18.0, "lines": ["もうバレたし", "いいでしょ。"]}, {"box": [39, 54, 86, 184], "vertical": true, "font_size": 20.0, "lines": ["途中まで", "一緒に帰ろうよ。"]}, {"box": [674, 625, 722, 731], "vertical": true, "font_size": 21.0, "lines": ["西片ホント", "好きだよね。"]}, {"box": [596, 615, 618, 735], "vertical": true, "font_size": 21.0, "lines": ["１００％片想い。"]}, {"box": [696, 953, 741, 1076], "vertical": true, "font_size": 18.0, "lines": ["い．．．いや", "そんなコトは。"]}, {"box": [346, 950, 400, 1074], "vertical": true, "font_size": 20.0, "lines": ["私も続き", "気になるなー。"]}, {"box": [92, 950, 172, 1055], "vertical": true, "font_size": 21.0, "lines": ["前の巻の", "あのシーン", "よかったし。"]}], "img_path": "105.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [711, 83, 756, 174], "vertical": true, "font_size": 21.0, "lines": ["ねぇ、", "なんで今日、"]}, {"box": [624, 114, 692, 202], "vertical": true, "font_size": 21.0, "lines": ["いつもより", "かっこつけ", "てんの。"]}, {"box": [354, 86, 376, 133], "vertical": true, "font_size": 22.0, "lines": ["あぁ。"]}, {"box": [645, 455, 722, 610], "vertical": true, "font_size": 22.0, "lines": ["キュン子に", "かっこいいと", "思ってほしくて．．"]}, {"box": [233, 460, 278, 555], "vertical": true, "font_size": 20.0, "lines": ["そんなコト", "しなくても、"]}, {"box": [97, 468, 140, 577], "vertical": true, "font_size": 20.0, "lines": ["ふだんの方が", "かっこいいよ。"]}, {"box": [96, 658, 121, 705], "vertical": true, "font_size": 20.0, "lines": ["あ！！"]}, {"box": [447, 881, 468, 965], "vertical": true, "font_size": 21.0, "lines": ["ってやつ。"]}, {"box": [367, 881, 391, 995], "vertical": true, "font_size": 21.0, "lines": ["あぁ、あれ！"]}, {"box": [99, 908, 123, 1005], "vertical": true, "font_size": 22.0, "lines": ["よかった．．．"]}], "img_path": "106.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [726, 100, 745, 161], "vertical": true, "font_size": 19.0, "lines": ["．．．よね。"]}, {"box": [448, 97, 541, 261], "vertical": true, "font_size": 19.0, "lines": ["そんでイケ夫が", "キュン子に好みの", "タイプ聞いて", "終わったんだよねー。"]}, {"box": [58, 90, 139, 227], "vertical": true, "font_size": 24.0, "lines": ["ねぇ、西片は", "どんな女の子が", "タイプ？"]}, {"box": [709, 491, 736, 536], "vertical": true, "font_size": 27.0, "lines": ["は？"]}, {"box": [349, 480, 481, 616], "vertical": true, "font_size": 24.0, "lines": ["いやー、", "キュン子", "みたいな子が", "タイプなのかと", "思って。"]}, {"box": [110, 505, 164, 567], "vertical": true, "font_size": 28.0, "lines": ["い．．．", "いや．．．"]}, {"box": [637, 973, 719, 1135], "vertical": true, "font_size": 21.0, "lines": ["頑張り屋だけど", "ドジで照れ屋で", "かわいいからさー。"]}, {"box": [112, 986, 138, 1072], "vertical": true, "font_size": 22.0, "lines": ["キュン子。"]}], "img_path": "107.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [666, 101, 747, 235], "vertical": true, "font_size": 24.0, "lines": ["べ．．．別に", "そうは思わない", "かなー。"]}, {"box": [448, 117, 473, 186], "vertical": true, "font_size": 25.0, "lines": ["ふーん。"]}, {"box": [381, 79, 411, 163], "vertical": true, "font_size": 21.0, "lines": ["ねぇ西片、"]}, {"box": [99, 113, 125, 230], "vertical": true, "font_size": 16.0, "lines": ["勝負しない？"]}, {"box": [675, 475, 723, 573], "vertical": true, "font_size": 22.0, "lines": ["え、", "いいけど．．．"]}, {"box": [175, 468, 251, 547], "vertical": true, "font_size": 20.0, "lines": ["あそこの", "電柱まで", "競走ね、"]}, {"box": [349, 861, 400, 929], "vertical": true, "font_size": 26.0, "lines": ["じゃあ", "よーい、"]}, {"box": [112, 587, 156, 708], "vertical": true, "font_size": 20.0, "lines": ["先にタッチ", "した方の勝ち。"]}, {"box": [739, 860, 787, 978], "vertical": true, "font_size": 22.0, "lines": ["どうしたんだ", "急に．．．"]}, {"box": [496, 900, 572, 1005], "vertical": true, "font_size": 20.0, "lines": ["高木さんめ．．．", "一体どんな", "策を．．．"]}, {"box": [97, 866, 174, 989], "vertical": true, "font_size": 22.0, "lines": ["くそ．．．", "考える余裕も", "くれないのか"]}], "img_path": "108.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [584, 78, 606, 130], "vertical": true, "font_size": 22.0, "lines": ["どん。"]}, {"box": [381, 49, 454, 171], "vertical": true, "font_size": 22.0, "lines": ["とにかく．．．！！", "頑張って", "走る．．．！！"]}, {"box": [50, 90, 100, 169], "vertical": true, "font_size": 22.0, "lines": ["それしか", "ない！！"]}, {"box": [329, 898, 351, 942], "vertical": true, "font_size": 22.0, "lines": ["え？"]}], "img_path": "109.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [726, 86, 782, 204], "vertical": true, "font_size": 24.0, "lines": ["負けちゃった", "かー。"]}, {"box": [435, 70, 458, 111], "vertical": true, "font_size": 23.0, "lines": ["え？"]}, {"box": [367, 71, 394, 150], "vertical": true, "font_size": 21.0, "lines": ["勝った．．．"]}, {"box": [432, 517, 480, 653], "vertical": true, "font_size": 18.0, "lines": ["なんだこの", "あっさり勝利！！"]}, {"box": [100, 309, 127, 386], "vertical": true, "font_size": 21.0, "lines": ["勝った！？"]}, {"box": [108, 541, 131, 632], "vertical": true, "font_size": 20.0, "lines": ["おおお！？"]}, {"box": [390, 907, 463, 1040], "vertical": true, "font_size": 22.0, "lines": ["オレを見くびり", "すぎていたな", "高木さん"]}, {"box": [233, 907, 313, 1008], "vertical": true, "font_size": 22.0, "lines": ["ははは、", "くやしそう", "だ。"]}], "img_path": "110.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [663, 48, 744, 199], "vertical": true, "font_size": 18.0, "lines": ["高木さんが", "なんだか歌そうに", "見えるぞ"]}, {"box": [248, 82, 355, 198], "vertical": true, "font_size": 22.0, "lines": ["今なら", "何をやっても", "勝てそうな", "気がする。"]}, {"box": [146, 67, 176, 152], "vertical": true, "font_size": 21.0, "lines": ["高木さん。"]}, {"box": [208, 441, 235, 493], "vertical": true, "font_size": 24.0, "lines": ["さぁ、"]}, {"box": [132, 500, 181, 591], "vertical": true, "font_size": 24.0, "lines": ["どっち", "でしょう。"]}, {"box": [720, 821, 749, 870], "vertical": true, "font_size": 25.0, "lines": ["んー、"]}, {"box": [413, 835, 433, 920], "vertical": true, "font_size": 20.0, "lines": ["えーっと、"]}, {"box": [319, 805, 340, 882], "vertical": true, "font_size": 20.0, "lines": ["こっち？"]}], "img_path": "111.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [741, 72, 770, 142], "vertical": true, "font_size": 29.0, "lines": ["オレの、"]}, {"box": [358, 78, 390, 133], "vertical": true, "font_size": 30.0, "lines": ["勝ち。"]}, {"box": [257, 73, 282, 126], "vertical": true, "font_size": 22.0, "lines": ["ええ。"]}, {"box": [424, 541, 443, 604], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．？"]}, {"box": [335, 548, 384, 628], "vertical": true, "font_size": 22.0, "lines": ["なんか．．．", "少し．．"]}, {"box": [99, 539, 144, 653], "vertical": true, "font_size": 18.0, "lines": ["わざとらしく", "ないか．．．？"]}, {"box": [671, 540, 736, 685], "vertical": true, "font_size": 17.0, "lines": ["おかしいなぁ", "こっちだと", "思ったんだけどー。"]}, {"box": [629, 892, 733, 1075], "vertical": true, "font_size": 23.0, "lines": ["いや、気のせいだ．．．", "負けた高木さんを", "初めて見たから", "そう感じてるだけだ。"]}, {"box": [309, 897, 328, 1002], "vertical": true, "font_size": 18.0, "lines": ["くっくつく。"]}], "img_path": "112.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [650, 65, 722, 220], "vertical": true, "font_size": 20.0, "lines": ["オレはもう", "完全に高木さんを", "上回った．．"]}, {"box": [298, 64, 329, 100], "vertical": true, "font_size": 31.0, "lines": ["わ。"]}, {"box": [363, 438, 385, 543], "vertical": true, "font_size": 21.0, "lines": ["あ．．．ゴメン。"]}, {"box": [104, 446, 124, 569], "vertical": true, "font_size": 20.0, "lines": ["こけちゃった。"]}, {"box": [660, 909, 682, 993], "vertical": true, "font_size": 21.0, "lines": ["ドジだな、"]}, {"box": [178, 929, 206, 998], "vertical": true, "font_size": 21.0, "lines": ["私って。"]}], "img_path": "113.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [322, 105, 370, 228], "vertical": true, "font_size": 18.0, "lines": ["た．．．高木さん．．．", "大丈夫．．．？"]}, {"box": [175, 105, 219, 228], "vertical": true, "font_size": 20.0, "lines": ["なんか", "おかしいよ．．．？"]}, {"box": [93, 257, 144, 341], "vertical": true, "font_size": 25.0, "lines": ["あ、うん", "大丈夫。"]}, {"box": [668, 466, 746, 571], "vertical": true, "font_size": 22.0, "lines": ["キュン子の", "マネしてた", "だけだから"]}, {"box": [701, 901, 732, 1037], "vertical": true, "font_size": 28.0, "lines": ["あぁああ。"]}, {"box": [228, 871, 317, 1004], "vertical": false, "font_size": 32.0, "lines": ["それでも", "おかしいなこっちだと思ったんだけど"]}, {"box": [197, 1007, 248, 1091], "vertical": true, "font_size": 26.0, "lines": ["ドジだな", "私って．．．"]}], "img_path": "114.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [666, 108, 744, 270], "vertical": true, "font_size": 19.0, "lines": ["高木さんめ．．．", "ごっこ遊びを", "してただけなのが、"]}, {"box": [241, 47, 292, 162], "vertical": true, "font_size": 20.0, "lines": ["勝てたと", "思ったのは．．"]}, {"box": [52, 247, 73, 343], "vertical": true, "font_size": 20.0, "lines": ["まぼろし．．．"]}, {"box": [727, 425, 754, 541], "vertical": true, "font_size": 20.0, "lines": ["なんで急に．．．"]}, {"box": [451, 432, 469, 549], "vertical": true, "font_size": 16.0, "lines": ["そんなこと．．"]}, {"box": [386, 727, 440, 901], "vertical": true, "font_size": 22.0, "lines": ["西片にかわいいって", "思ってほしくて。"]}], "img_path": "115.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [548, 211, 570, 280], "vertical": true, "font_size": 22.0, "lines": ["な．．．．．"]}, {"box": [365, 202, 442, 356], "vertical": true, "font_size": 20.0, "lines": ["好みのタイプ", "聞いてたのって．．．", "そういう．．．？"]}, {"box": [351, 933, 400, 1012], "vertical": true, "font_size": 24.0, "lines": ["い．．．いや", "その．．．"]}], "img_path": "116.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [727, 70, 747, 135], "vertical": true, "font_size": 20.0, "lines": ["あはは。"]}, {"box": [378, 70, 454, 234], "vertical": true, "font_size": 22.0, "lines": ["ダメだよ", "ちゃんとセリフ", "言ってくれないと。"]}, {"box": [236, 55, 315, 154], "vertical": true, "font_size": 24.0, "lines": ["わかり", "にくかった", "かな。"]}, {"box": [60, 83, 110, 180], "vertical": true, "font_size": 22.0, "lines": ["セ．．．", "セリフ．．．！？"]}, {"box": [704, 450, 727, 552], "vertical": true, "font_size": 21.0, "lines": ["あああっ。"]}, {"box": [304, 433, 419, 526], "vertical": false, "font_size": 23.0, "lines": ["キュン子に", "わっこいいと", "思ってほしくて"]}, {"box": [651, 1013, 732, 1137], "vertical": true, "font_size": 24.0, "lines": ["じゃ、", "そろそろ", "本屋さんだし、"]}, {"box": [550, 1021, 606, 1132], "vertical": true, "font_size": 24.0, "lines": ["私は", "行こっかな。"]}], "img_path": "117.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [795, 77, 825, 112], "vertical": true, "font_size": 30.0, "lines": ["あ、"]}, {"box": [402, 117, 504, 251], "vertical": true, "font_size": 21.0, "lines": ["かわいいって", "思ってほしくて", "ってのは", "本音だよ。"]}, {"box": [601, 953, 677, 1069], "vertical": true, "font_size": 21.0, "lines": ["そ．．．", "そんなセリフ", "あったっけ。"]}], "img_path": "118.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [85, 840, 253, 1110], "vertical": false, "font_size": 32.0, "lines": ["談"]}], "img_path": "119.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [475, 608, 503, 675], "vertical": true, "font_size": 21.0, "lines": ["西片君。"]}], "img_path": "120.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [586, 120, 616, 207], "vertical": true, "font_size": 22.0, "lines": ["悪いわね。"]}, {"box": [422, 142, 444, 227], "vertical": true, "font_size": 22.0, "lines": ["い．．．いや。"]}, {"box": [299, 100, 356, 185], "vertical": true, "font_size": 29.0, "lines": ["それで．．．", "何？"]}, {"box": [82, 51, 371, 73], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [214, 111, 241, 193], "vertical": true, "font_size": 28.0, "lines": ["えっと．．．"]}, {"box": [99, 106, 187, 209], "vertical": true, "font_size": 28.0, "lines": ["少し", "聞きたいん", "だけど．．．"]}, {"box": [716, 596, 741, 724], "vertical": true, "font_size": 25.0, "lines": ["ほしいもの、"]}, {"box": [364, 625, 385, 696], "vertical": true, "font_size": 21.0, "lines": ["ある？"]}, {"box": [282, 594, 304, 638], "vertical": true, "font_size": 22.0, "lines": ["え？"]}, {"box": [149, 580, 201, 676], "vertical": true, "font_size": 23.0, "lines": ["あ、ゴメン", "なさい。"]}, {"box": [57, 588, 104, 692], "vertical": true, "font_size": 23.0, "lines": ["聞き方が", "悪かったわ。"]}, {"box": [56, 1011, 104, 1089], "vertical": true, "font_size": 24.0, "lines": ["．．．．．", "えっと．．．"]}], "img_path": "121.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [739, 62, 796, 182], "vertical": true, "font_size": 28.0, "lines": ["浜口．．．", "いるでしょ．．．"]}, {"box": [424, 80, 505, 223], "vertical": true, "font_size": 22.0, "lines": ["あいつ．．．何か", "ほしいもの", "あるのかなって。"]}, {"box": [206, 75, 286, 175], "vertical": true, "font_size": 24.0, "lines": ["今度あいつ", "誕生日", "だから．．．"]}, {"box": [728, 663, 749, 703], "vertical": true, "font_size": 21.0, "lines": ["へ．．．"]}, {"box": [503, 664, 531, 726], "vertical": true, "font_size": 26.0, "lines": ["へえ．．．"]}, {"box": [104, 656, 182, 828], "vertical": true, "font_size": 22.0, "lines": ["あ、待って、", "カンチガイしないで", "ほしいわ。"]}, {"box": [654, 937, 732, 1072], "vertical": true, "font_size": 21.0, "lines": ["先にプレゼント", "くれたのは", "あいつなのよ。"]}, {"box": [207, 957, 255, 1054], "vertical": true, "font_size": 20.0, "lines": ["私からでは", "ないのよ。"]}, {"box": [96, 956, 142, 1069], "vertical": true, "font_size": 20.0, "lines": ["ただのお返し", "だから。"]}], "img_path": "122.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [718, 68, 739, 162], "vertical": true, "font_size": 16.0, "lines": ["わかった！？"]}, {"box": [376, 66, 429, 130], "vertical": true, "font_size": 27.0, "lines": ["あ．．．", "うん？"]}, {"box": [93, 69, 145, 176], "vertical": true, "font_size": 23.0, "lines": ["そう、", "よかったわ"]}, {"box": [633, 468, 708, 585], "vertical": true, "font_size": 20.0, "lines": ["それで？", "ほしいもの", "わかんない？"]}, {"box": [530, 469, 576, 584], "vertical": true, "font_size": 20.0, "lines": ["仲いいでしょ", "あなたたち。"]}, {"box": [233, 479, 251, 556], "vertical": true, "font_size": 16.0, "lines": ["えっと．．．"]}, {"box": [695, 878, 747, 1017], "vertical": true, "font_size": 25.0, "lines": ["他の女子から", "聞いたんだけど、"]}, {"box": [543, 853, 656, 1030], "vertical": true, "font_size": 25.0, "lines": ["北条、最近", "クッキー作りに", "ハマってるらしいん", "だよな．．．"]}, {"box": [134, 881, 240, 999], "vertical": true, "font_size": 22.0, "lines": ["あいつ料理", "苦手だから", "絶対マズいん", "だろうけど。"]}], "img_path": "123.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [714, 94, 790, 202], "vertical": true, "font_size": 25.0, "lines": ["でも．．．", "食ってみてぇ", "なぁ。"]}, {"box": [443, 97, 492, 230], "vertical": true, "font_size": 24.0, "lines": ["北条の", "手作りクッキー。"]}, {"box": [289, 114, 394, 258], "vertical": true, "font_size": 23.0, "lines": ["北条さんの", "手作りクッキー", "食べたいって", "言ってた．．．かな。"]}, {"box": [112, 134, 148, 181], "vertical": true, "font_size": 29.0, "lines": ["な。"]}, {"box": [600, 567, 731, 722], "vertical": true, "font_size": 23.0, "lines": ["なんで", "あいつが", "私がクッキー作り", "ハマってるって", "知ってるわけ！？"]}, {"box": [148, 578, 196, 700], "vertical": true, "font_size": 20.0, "lines": ["い．．．いや", "知らないけど。"]}, {"box": [715, 859, 738, 1012], "vertical": true, "font_size": 20.0, "lines": ["．．．でもそっかぁ。"]}, {"box": [315, 860, 395, 996], "vertical": true, "font_size": 22.0, "lines": ["私のクッキー", "食べたいって．．", "あいつ．．．"]}, {"box": [250, 887, 271, 939], "vertical": true, "font_size": 21.0, "lines": ["へへ．．．"]}], "img_path": "124.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [404, 112, 483, 210], "vertical": true, "font_size": 19.0, "lines": ["ま、お金", "かけるのも", "なんだし"]}, {"box": [80, 51, 371, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [179, 110, 253, 215], "vertical": true, "font_size": 23.0, "lines": ["クッキーで", "いいわ、まぐち", "浜口なんて。"]}, {"box": [716, 512, 747, 567], "vertical": true, "font_size": 24.0, "lines": ["じゃ、"]}, {"box": [651, 525, 671, 646], "vertical": true, "font_size": 24.0, "lines": ["ありがとうね。"]}, {"box": [332, 514, 354, 600], "vertical": true, "font_size": 20.0, "lines": ["あ．．．うん。"]}, {"box": [172, 519, 193, 615], "vertical": true, "font_size": 20.0, "lines": ["あ、そうだ。"]}, {"box": [627, 869, 648, 952], "vertical": true, "font_size": 20.0, "lines": ["このこと"]}, {"box": [121, 882, 174, 1007], "vertical": true, "font_size": 24.0, "lines": ["誰にも", "言わないでね。"]}], "img_path": "125.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [626, 119, 716, 169], "vertical": false, "font_size": 32.0, "lines": ["カーン"]}, {"box": [86, 128, 103, 175], "vertical": true, "font_size": 17.0, "lines": ["．．．"]}, {"box": [650, 600, 740, 774], "vertical": true, "font_size": 20.0, "lines": ["そういえば", "西片、今日", "北条さんと", "しゃべってなかった？"]}, {"box": [209, 645, 238, 686], "vertical": true, "font_size": 27.0, "lines": ["え！？"]}, {"box": [124, 662, 178, 781], "vertical": true, "font_size": 27.0, "lines": ["なんで", "知ってんの！？"]}, {"box": [755, 958, 807, 1062], "vertical": true, "font_size": 22.0, "lines": ["ちょっと", "見かけてさ。"]}, {"box": [656, 983, 704, 1099], "vertical": true, "font_size": 22.0, "lines": ["何しゃべって", "たの？"]}, {"box": [359, 946, 390, 998], "vertical": true, "font_size": 29.0, "lines": ["あー、"]}, {"box": [93, 964, 123, 1031], "vertical": true, "font_size": 22.0, "lines": ["実はさ、"]}], "img_path": "126.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [691, 82, 718, 127], "vertical": true, "font_size": 27.0, "lines": ["あ．．．"]}, {"box": [633, 26, 661, 131], "vertical": true, "font_size": 28.0, "lines": ["だれにも"]}, {"box": [476, 18, 522, 168], "vertical": true, "font_size": 32.0, "lines": ["言わないでね"]}, {"box": [311, 55, 386, 154], "vertical": true, "font_size": 24.0, "lines": ["いや．．．", "別に大した", "ことでは．．．"]}, {"box": [158, 84, 182, 153], "vertical": true, "font_size": 22.0, "lines": ["ふーん。"]}, {"box": [56, 77, 104, 173], "vertical": true, "font_size": 22.0, "lines": ["内緒話って", "こと？"]}, {"box": [696, 494, 743, 639], "vertical": true, "font_size": 19.0, "lines": ["まぁ．．．", "そんなとこかな。"]}, {"box": [378, 487, 398, 555], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．"]}, {"box": [98, 519, 121, 570], "vertical": true, "font_size": 22.0, "lines": ["んー。"]}, {"box": [110, 879, 140, 914], "vertical": true, "font_size": 28.0, "lines": ["！！"]}, {"box": [668, 851, 714, 1008], "vertical": true, "font_size": 20.0, "lines": ["浜口くんが", "何ほしがってるか、"]}, {"box": [590, 878, 610, 1001], "vertical": true, "font_size": 20.0, "lines": ["だったりして。"]}], "img_path": "127.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [718, 111, 736, 223], "vertical": true, "font_size": 16.0, "lines": ["な．．．なんで？"]}, {"box": [411, 119, 476, 244], "vertical": true, "font_size": 24.0, "lines": ["んー、", "なんとなく。"]}, {"box": [127, 66, 152, 183], "vertical": true, "font_size": 17.0, "lines": ["当たってる？"]}, {"box": [700, 403, 742, 516], "vertical": true, "font_size": 21.0, "lines": ["あいかわらず", "鋭すぎる．．．"]}, {"box": [563, 400, 641, 479], "vertical": true, "font_size": 21.0, "lines": ["でも．．．", "言うわけ", "には．．．"]}, {"box": [408, 390, 429, 451], "vertical": true, "font_size": 21.0, "lines": ["さぁ．．．"]}, {"box": [629, 767, 648, 832], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．？"]}, {"box": [319, 783, 344, 851], "vertical": true, "font_size": 25.0, "lines": ["ふーん。"]}], "img_path": "128.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [711, 53, 731, 120], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．"]}, {"box": [459, 75, 490, 130], "vertical": true, "font_size": 23.0, "lines": ["ねえ、"]}, {"box": [316, 80, 424, 215], "vertical": true, "font_size": 23.0, "lines": ["西片は", "プレゼント", "何かほしいもの", "ってある？"]}, {"box": [670, 439, 748, 590], "vertical": true, "font_size": 19.0, "lines": ["いや．．．北条さんと", "そういう会話", "してたわけでは．．．"]}, {"box": [383, 423, 456, 566], "vertical": true, "font_size": 20.0, "lines": ["それとは", "関係なしに", "気になってさー。"]}, {"box": [99, 446, 150, 597], "vertical": true, "font_size": 20.0, "lines": ["プレゼント選びの", "参考にしたくて。"]}, {"box": [350, 884, 399, 1038], "vertical": true, "font_size": 20.0, "lines": ["プレゼントって．．．", "誰に．．．？"]}], "img_path": "129.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [444, 93, 495, 400], "vertical": true, "font_size": 29.0, "lines": ["１４歳の男子、", "かな。"]}, {"box": [272, 360, 335, 396], "vertical": false, "font_size": 32.0, "lines": ["は歳"]}, {"box": [704, 555, 808, 689], "vertical": true, "font_size": 23.0, "lines": ["いやいや", "高木さんめ、", "そう何度も", "ひっかかるか．．"]}, {"box": [529, 564, 576, 670], "vertical": true, "font_size": 20.0, "lines": ["どうせ", "また犬だろ。"]}, {"box": [435, 547, 479, 704], "vertical": true, "font_size": 19.0, "lines": ["あのチワワ．．．１５歳", "じゃなかったっけ？"]}, {"box": [91, 566, 205, 656], "vertical": true, "font_size": 32.0, "lines": ["ん？", "違う", "違う。"]}, {"box": [515, 942, 597, 1033], "vertical": true, "font_size": 28.0, "lines": ["中学", "３年生の", "男子だよ。"]}, {"box": [203, 945, 236, 991], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}], "img_path": "130.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [718, 89, 740, 130], "vertical": true, "font_size": 22.0, "lines": ["あ．．．"]}, {"box": [542, 86, 640, 204], "vertical": true, "font_size": 21.0, "lines": ["またオレを", "からかう", "流れかと", "思ったのに．．"]}, {"box": [391, 112, 473, 240], "vertical": true, "font_size": 20.0, "lines": ["えっと．．．？"]}, {"box": [240, 90, 261, 205], "vertical": true, "font_size": 20.0, "lines": ["わかんない．．．"]}, {"box": [455, 628, 471, 672], "vertical": true, "font_size": 16.0, "lines": ["．．．"]}, {"