{"version": "0.2.0-beta.6", "title": "Karakai Jouzu no Takagi-san", "title_uuid": "8b310d10-25a6-4fdb-aaef-cacc33c51c4b", "volume": "Karakai-Jouzu-Takagi-san-14", "volume_uuid": "06a84f0a-5140-4795-994d-b9106e3174ba", "pages": [{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [19, 16, 86, 802], "vertical": true, "font_size": 32.0, "lines": ["ハッハハーティアホームの面白木空朗"]}, {"box": [635, 1150, 816, 1171], "vertical": false, "font_size": 14.0, "lines": ["Ｓｐａｌｌｅｓｔｉｐｈｔ（ｄｒｉｓｓｙｒｉｌｌ）"]}], "img_path": "001.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "002.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [67, 1100, 677, 1132], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さんの山本宗一朗"]}], "img_path": "003.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [671, 529, 774, 541], "vertical": false, "font_size": 12.0, "lines": ["ｏｎｔｃｎｔｓ"]}, {"box": [721, 710, 743, 822], "vertical": true, "font_size": 21.0, "lines": ["寄り道一つ、"]}, {"box": [581, 710, 604, 824], "vertical": true, "font_size": 21.0, "lines": ["お弁当．．．"]}, {"box": [440, 710, 465, 821], "vertical": true, "font_size": 25.0, "lines": ["初詣で"]}, {"box": [303, 729, 322, 749], "vertical": true, "font_size": 19.0, "lines": ["．．．"]}, {"box": [300, 730, 325, 824], "vertical": false, "font_size": 21.0, "lines": ["はっ"]}, {"box": [719, 971, 745, 1076], "vertical": true, "font_size": 26.0, "lines": ["告白"]}, {"box": [581, 966, 604, 1018], "vertical": true, "font_size": 22.0, "lines": ["タイプ"]}, {"box": [438, 971, 466, 1014], "vertical": true, "font_size": 28.0, "lines": ["相談"]}, {"box": [289, 952, 339, 1079], "vertical": true, "font_size": 32.0, "lines": ["レンタルＤＶＤ"]}], "img_path": "004.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [14, 1038, 483, 1187], "vertical": false, "font_size": 32.0, "lines": ["寄り道ｏ"]}], "img_path": "005.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [359, 101, 443, 237], "vertical": true, "font_size": 24.0, "lines": ["高木さん、今日", "帰りにちょっと", "寄り道しない？"]}, {"box": [147, 80, 181, 134], "vertical": true, "font_size": 26.0, "lines": ["ん？"]}, {"box": [103, 127, 124, 201], "vertical": true, "font_size": 26.0, "lines": ["いいよ。"]}], "img_path": "006.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [719, 55, 740, 111], "vertical": true, "font_size": 21.0, "lines": ["ここ？"]}, {"box": [419, 49, 468, 163], "vertical": true, "font_size": 24.0, "lines": ["うん、", "上まで行こう。"]}, {"box": [312, 112, 370, 238], "vertical": true, "font_size": 28.0, "lines": ["何が", "あるのかなー。"]}, {"box": [67, 65, 119, 237], "vertical": true, "font_size": 23.0, "lines": ["まぁ、着いてからの", "お楽しみで．．．"]}, {"box": [723, 305, 748, 376], "vertical": true, "font_size": 25.0, "lines": ["．．．へぇ。"]}, {"box": [658, 608, 708, 735], "vertical": true, "font_size": 24.0, "lines": ["そりゃ", "楽しみだなぁ。"]}, {"box": [275, 615, 320, 750], "vertical": true, "font_size": 20.0, "lines": ["ちなみに．．．", "来たことある？"]}, {"box": [657, 914, 707, 982], "vertical": true, "font_size": 24.0, "lines": ["んーん、", "ないよ。"]}, {"box": [470, 898, 490, 975], "vertical": true, "font_size": 20.0, "lines": ["なんで？"]}, {"box": [222, 905, 248, 976], "vertical": true, "font_size": 28.0, "lines": ["そっか。"]}, {"box": [103, 915, 187, 1017], "vertical": true, "font_size": 28.0, "lines": ["いや、", "聞いてみた", "だけ。"]}], "img_path": "007.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [665, 72, 739, 243], "vertical": true, "font_size": 20.0, "lines": ["そこであいつが", "シュート止めるのも", "よかったよねー。"]}, {"box": [521, 80, 591, 205], "vertical": true, "font_size": 22.0, "lines": ["あー、あそこ", "かっこよかった", "ねー。"]}, {"box": [149, 101, 190, 206], "vertical": true, "font_size": 16.0, "lines": ["そのあとの", "ケガもさー"]}, {"box": [101, 544, 176, 644], "vertical": true, "font_size": 21.0, "lines": ["そう！", "あそこも", "よかった！"]}, {"box": [643, 532, 750, 675], "vertical": true, "font_size": 20.0, "lines": ["私は試合前の", "目を合わせる", "シーンも", "好きだったなー。"]}, {"box": [675, 892, 753, 1057], "vertical": true, "font_size": 19.0, "lines": ["高木さん、", "他にはどんな", "まんが好きなの？"]}, {"box": [336, 919, 357, 966], "vertical": true, "font_size": 20.0, "lines": ["ん"]}, {"box": [98, 901, 117, 969], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．"]}], "img_path": "008.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [620, 71, 648, 187], "vertical": true, "font_size": 20.0, "lines": ["高木さん．．．？"]}, {"box": [165, 67, 190, 121], "vertical": true, "font_size": 25.0, "lines": ["ねえ。"]}, {"box": [682, 332, 734, 474], "vertical": true, "font_size": 20.0, "lines": ["なんか今日は", "よくしゃべるね、"]}, {"box": [349, 540, 383, 596], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [255, 280, 303, 397], "vertical": true, "font_size": 22.0, "lines": ["そ．．．", "そうかなぁ．．．"]}, {"box": [86, 414, 142, 493], "vertical": true, "font_size": 25.0, "lines": ["普通じゃ", "ない？"]}, {"box": [251, 864, 272, 930], "vertical": true, "font_size": 21.0, "lines": ["ふーん。"]}, {"box": [670, 880, 746, 996], "vertical": true, "font_size": 22.0, "lines": ["なんか", "緊張してたり", "する？"]}, {"box": [317, 889, 370, 971], "vertical": true, "font_size": 22.0, "lines": ["緊張．．．？", "なんで？"]}, {"box": [46, 874, 92, 988], "vertical": true, "font_size": 20.0, "lines": ["してないなら", "いいけど。"]}], "img_path": "009.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [620, 44, 668, 155], "vertical": true, "font_size": 18.0, "lines": ["私はちょっと", "してたけどね"]}, {"box": [477, 82, 509, 137], "vertical": true, "font_size": 31.0, "lines": ["緊張。"]}, {"box": [394, 71, 415, 168], "vertical": true, "font_size": 20.0, "lines": ["なんで．．．？"]}, {"box": [732, 637, 755, 704], "vertical": true, "font_size": 24.0, "lines": ["いいよ。"]}, {"box": [646, 638, 697, 764], "vertical": true, "font_size": 24.0, "lines": ["もう", "してないから。"]}, {"box": [192, 673, 213, 741], "vertical": true, "font_size": 21.0, "lines": ["．．．．．？"]}, {"box": [734, 941, 751, 1004], "vertical": true, "font_size": 17.0, "lines": ["．．．．．．？"]}, {"box": [433, 966, 480, 1118], "vertical": true, "font_size": 18.0, "lines": ["バレては", "いないようだな．．．"]}], "img_path": "010.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [710, 88, 739, 230], "vertical": true, "font_size": 20.0, "lines": ["頂上に着いたら、"]}, {"box": [388, 41, 468, 275], "vertical": true, "font_size": 25.0, "lines": ["今登ってきた", "階段は何段だったでしょう", "と聞く作戦。"]}, {"box": [277, 55, 324, 151], "vertical": true, "font_size": 20.0, "lines": ["高木さんの", "ことだ．．．"]}, {"box": [87, 50, 214, 205], "vertical": true, "font_size": 20.0, "lines": ["学校の階段の数は", "知ってても", "おかしくないから", "わざわざこんな", "場所にしたのさ。"]}, {"box": [51, 278, 133, 432], "vertical": true, "font_size": 21.0, "lines": ["ここは登ったこと", "ないってさっき", "言ってたし．．．"]}, {"box": [569, 591, 725, 757], "vertical": true, "font_size": 24.0, "lines": ["たくさん", "話しかけることで、", "何段か数えて", "いるという", "万が一の可能性も", "潰した。"]}, {"box": [108, 609, 130, 673], "vertical": true, "font_size": 22.0, "lines": ["ふふふ"]}, {"box": [121, 931, 150, 1033], "vertical": true, "font_size": 21.0, "lines": ["勝ったな。"]}], "img_path": "011.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [599, 78, 649, 186], "vertical": true, "font_size": 24.0, "lines": ["おー", "着いたねー。"]}, {"box": [692, 568, 744, 665], "vertical": true, "font_size": 22.0, "lines": ["へー、景色", "いいなー。"]}, {"box": [206, 570, 284, 727], "vertical": true, "font_size": 22.0, "lines": ["ふふふ。", "いい気なものだな", "高木さん。"]}, {"box": [100, 637, 171, 732], "vertical": true, "font_size": 22.0, "lines": ["これから", "負けるとも", "知らずに"]}], "img_path": "012.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [674, 108, 751, 174], "vertical": true, "font_size": 25.0, "lines": ["西片も", "こっち", "来なよ。"]}, {"box": [575, 110, 622, 158], "vertical": true, "font_size": 24.0, "lines": ["あ．．．", "うん。"]}, {"box": [201, 526, 289, 605], "vertical": true, "font_size": 32.0, "lines": ["いい眺めだね", "だねー。"]}, {"box": [439, 885, 460, 972], "vertical": true, "font_size": 20.0, "lines": ["う．．．うん。"]}], "img_path": "013.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [432, 66, 540, 182], "vertical": true, "font_size": 19.0, "lines": ["この風景", "見せるために", "つれてきて", "くれたの？"]}, {"box": [426, 596, 458, 657], "vertical": true, "font_size": 32.0, "lines": ["な．．．"]}, {"box": [700, 910, 726, 1024], "vertical": true, "font_size": 21.0, "lines": ["ち．．．違うよ！！"]}, {"box": [161, 917, 208, 1021], "vertical": true, "font_size": 20.0, "lines": ["わかってる", "わかってる。"]}], "img_path": "014.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [640, 118, 734, 329], "vertical": true, "font_size": 27.0, "lines": ["しよ．．．", "勝負のために", "ここに来たんだよ！！"]}, {"box": [82, 52, 371, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [200, 106, 227, 212], "vertical": true, "font_size": 16.0, "lines": ["だと思った。"]}, {"box": [701, 466, 742, 633], "vertical": true, "font_size": 21.0, "lines": ["なんかいつもより", "しゃべりすぎだったし。"]}, {"box": [599, 475, 647, 560], "vertical": true, "font_size": 21.0, "lines": ["で、勝負の", "方法は？"]}, {"box": [370, 464, 420, 600], "vertical": true, "font_size": 24.0, "lines": ["わかってたなら", "なぜ．．．"]}, {"box": [302, 466, 328, 527], "vertical": true, "font_size": 26.0, "lines": ["ふっ．．．"]}, {"box": [632, 789, 723, 915], "vertical": true, "font_size": 26.0, "lines": ["ここに", "来るまでの", "階段ですが、"]}, {"box": [115, 778, 183, 977], "vertical": true, "font_size": 32.0, "lines": ["何段", "あったでしょうか。"]}], "img_path": "015.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [408, 187, 445, 250], "vertical": true, "font_size": 32.0, "lines": ["４１５段。"]}, {"box": [258, 91, 329, 221], "vertical": true, "font_size": 21.0, "lines": ["まぁ", "ピッタリなんて", "ムリだろうから、"]}, {"box": [112, 106, 205, 246], "vertical": true, "font_size": 21.0, "lines": ["ハンデを", "あげるよ。", "誤差２０段までなら", "高木さんの勝．．．"]}, {"box": [734, 616, 752, 693], "vertical": true, "font_size": 16.0, "lines": ["．．．あれ？"]}, {"box": [602, 623, 625, 665], "vertical": true, "font_size": 23.0, "lines": ["え？"]}, {"box": [366, 618, 398, 673], "vertical": true, "font_size": 32.0, "lines": ["４１５段。"]}, {"box": [662, 982, 721, 1074], "vertical": true, "font_size": 25.0, "lines": ["ええ！？", "なんで！？"]}], "img_path": "016.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [675, 58, 743, 164], "vertical": true, "font_size": 23.0, "lines": ["なんで", "そんな", "ピッタリて．．．"]}, {"box": [430, 64, 456, 167], "vertical": true, "font_size": 16.0, "lines": ["有名だもん。"]}, {"box": [323, 44, 378, 123], "vertical": true, "font_size": 24.0, "lines": ["有名って", "．．．？"]}, {"box": [128, 51, 189, 123], "vertical": true, "font_size": 27.0, "lines": ["４１５段", "だから、"]}, {"box": [63, 84, 90, 264], "vertical": true, "font_size": 27.0, "lines": ["よ・い・こい、", "て。"]}, {"box": [421, 521, 526, 656], "vertical": true, "font_size": 22.0, "lines": ["ここに", "男女で来ると", "付き合えるって", "噂だよ。"]}, {"box": [76, 295, 146, 396], "vertical": false, "font_size": 32.0, "lines": ["１５３"]}, {"box": [18, 301, 60, 348], "vertical": false, "font_size": 32.0, "lines": ["良く"]}], "img_path": "017.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [709, 105, 734, 169], "vertical": true, "font_size": 25.0, "lines": ["えぇ？！"]}, {"box": [301, 107, 370, 257], "vertical": true, "font_size": 21.0, "lines": ["あはは、", "やっぱり", "知らなかったんだ。"]}, {"box": [135, 103, 230, 217], "vertical": true, "font_size": 22.0, "lines": ["知らずに", "ここを", "選ぶとこが", "西片らしいね。"]}, {"box": [617, 528, 702, 551], "vertical": false, "font_size": 21.0, "lines": ["あはは"]}, {"box": [333, 543, 406, 679], "vertical": true, "font_size": 20.0, "lines": ["そ．．．そんなに", "恥ずかしい場所", "だったなんて"]}, {"box": [95, 546, 140, 660], "vertical": true, "font_size": 18.0, "lines": ["オレはなんて", "バカなんだ。"]}, {"box": [385, 840, 459, 991], "vertical": true, "font_size": 20.0, "lines": ["ちなみにあそこの", "祠の中にノート", "おいてあってさ。"]}], "img_path": "018.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [619, 66, 703, 260], "vertical": true, "font_size": 23.0, "lines": ["好きな人の名前書くと", "ずっと一緒にいられる", "らしいよ。"]}, {"box": [712, 391, 733, 476], "vertical": true, "font_size": 21.0, "lines": ["へ．．．へぇ．．．"]}, {"box": [394, 390, 468, 516], "vertical": true, "font_size": 21.0, "lines": ["そうだ", "西片、罰ゲーム", "あったよねー。"]}, {"box": [247, 380, 297, 480], "vertical": true, "font_size": 24.0, "lines": ["あの", "ノートに．．．"]}, {"box": [713, 675, 734, 796], "vertical": true, "font_size": 20.0, "lines": ["いやしやいや。"]}, {"box": [403, 677, 453, 791], "vertical": true, "font_size": 18.0, "lines": ["オレそんな人", "いないし！！"]}, {"box": [301, 678, 347, 764], "vertical": true, "font_size": 18.0, "lines": ["あはは、", "冗談だよ。"]}, {"box": [323, 958, 345, 1060], "vertical": true, "font_size": 20.0, "lines": ["罰ゲームは、"]}, {"box": [258, 976, 282, 1080], "vertical": true, "font_size": 20.0, "lines": ["そうだなぁ。"]}], "img_path": "019.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [619, 98, 665, 194], "vertical": true, "font_size": 20.0, "lines": ["またここに", "来ようよ。"]}, {"box": [460, 105, 518, 178], "vertical": true, "font_size": 32.0, "lines": ["景色", "いいし。"]}, {"box": [248, 115, 272, 148], "vertical": true, "font_size": 24.0, "lines": ["へ。"]}, {"box": [477, 626, 524, 723], "vertical": true, "font_size": 20.0, "lines": ["いや．．．でも", "ここって．．．"]}, {"box": [248, 617, 268, 694], "vertical": true, "font_size": 21.0, "lines": ["あれー？"]}, {"box": [105, 616, 206, 778], "vertical": true, "font_size": 21.0, "lines": ["もともと", "つれてきたのは", "西片じゃ", "なかったっけなー。"]}, {"box": [611, 930, 687, 1046], "vertical": true, "font_size": 21.0, "lines": ["それに", "噂だよー？", "信じてるの？"]}, {"box": [200, 915, 281, 1068], "vertical": true, "font_size": 26.0, "lines": ["べ．．．別に", "そういうわけじゃ", "ないけどさぁ。"]}], "img_path": "020.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [317, 880, 398, 1019], "vertical": true, "font_size": 21.0, "lines": ["景色がいいから", "見に行こうって", "言われて、"]}, {"box": [43, 884, 96, 1038], "vertical": true, "font_size": 19.0, "lines": ["軽くＯＫ", "しちゃったけど．．．"]}], "img_path": "021.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [734, 2, 809, 191], "vertical": true, "font_size": 21.0, "lines": ["よく考えたら", "ここって、"]}, {"box": [342, 150, 437, 312], "vertical": true, "font_size": 27.0, "lines": ["噂の", "４１５段のとこじゃ", "ないの！？"]}, {"box": [208, 113, 279, 219], "vertical": true, "font_size": 19.0, "lines": ["こんなとこに", "つれてくる", "なんて、"]}, {"box": [127, 106, 167, 207], "vertical": true, "font_size": 19.0, "lines": ["何考えてんの", "コイツ．．．"]}, {"box": [433, 567, 479, 664], "vertical": true, "font_size": 20.0, "lines": ["もしかして", "私のこと．．"]}, {"box": [727, 913, 746, 1017], "vertical": true, "font_size": 16.0, "lines": ["な．．．なんだ"]}, {"box": [393, 898, 411, 962], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．"]}], "img_path": "022.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [675, 80, 723, 166], "vertical": true, "font_size": 22.0, "lines": ["なんでも", "ないわよ。"]}, {"box": [256, 70, 331, 186], "vertical": true, "font_size": 23.0, "lines": ["もー．．．", "恥ずかしく", "なってきた．．"]}, {"box": [93, 93, 120, 189], "vertical": true, "font_size": 18.0, "lines": ["帰りたい．．．"]}, {"box": [623, 496, 729, 660], "vertical": true, "font_size": 23.0, "lines": ["でも今ここで", "帰ったら、私が", "噂気にするような", "子供ってことに．．"]}, {"box": [234, 493, 255, 559], "vertical": true, "font_size": 21.0, "lines": ["．．．．．．"]}], "img_path": "023.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [570, 116, 596, 166], "vertical": true, "font_size": 26.0, "lines": ["へー。"]}, {"box": [697, 277, 746, 382], "vertical": true, "font_size": 22.0, "lines": ["たしかに", "いい景色ね。"]}, {"box": [646, 946, 743, 1080], "vertical": true, "font_size": 18.0, "lines": ["どうしたのよ．．", "はやく４５段の", "ネタばらし", "しなさいよ．．．"]}], "img_path": "024.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [694, 65, 741, 224], "vertical": true, "font_size": 20.0, "lines": ["こっちはずっと", "準備できてんのよ。"]}, {"box": [513, 16, 576, 135], "vertical": false, "font_size": 22.0, "lines": ["んくんっっわわ"]}, {"box": [481, 19, 559, 161], "vertical": false, "font_size": 30.0, "lines": ["どのうんｍｏｎ．"]}, {"box": [385, 141, 414, 213], "vertical": true, "font_size": 29.0, "lines": ["子供ね"]}, {"box": [173, 70, 206, 124], "vertical": true, "font_size": 32.0, "lines": ["北条。"]}, {"box": [630, 622, 687, 743], "vertical": true, "font_size": 30.0, "lines": ["実は", "ここってさ．．．"]}, {"box": [713, 902, 743, 964], "vertical": true, "font_size": 27.0, "lines": ["来た．．．"]}, {"box": [143, 902, 161, 949], "vertical": true, "font_size": 18.0, "lines": ["．．．．．"]}], "img_path": "025.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [558, 45, 664, 177], "vertical": true, "font_size": 22.0, "lines": ["空気が．．．", "うまいんだ。"]}, {"box": [215, 64, 242, 110], "vertical": true, "font_size": 27.0, "lines": ["は？"]}, {"box": [110, 533, 189, 666], "vertical": true, "font_size": 19.0, "lines": ["最初から", "できるわけが", "なかったんだ．．．"]}, {"box": [678, 520, 726, 689], "vertical": true, "font_size": 20.0, "lines": ["ムリだ．．．", "ヘタレなオレには．．．"]}, {"box": [584, 860, 603, 925], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．"]}, {"box": [700, 840, 745, 965], "vertical": true, "font_size": 22.0, "lines": ["またこんど", "今度にしよう："]}, {"box": [418, 855, 518, 989], "vertical": true, "font_size": 20.0, "lines": ["なに．．．？", "ホントに空気を", "おいしそうに", "吸って．．．"]}, {"box": [119, 874, 192, 1085], "vertical": true, "font_size": 22.0, "lines": ["もしかして．．．", "ホントに景色を", "見に来ただけだったの！？"]}], "img_path": "026.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [641, 80, 725, 204], "vertical": true, "font_size": 29.0, "lines": ["私一人で", "噂を", "気にして．．．！？"]}, {"box": [188, 120, 213, 201], "vertical": true, "font_size": 27.0, "lines": ["あぁ～"]}, {"box": [101, 194, 130, 344], "vertical": true, "font_size": 27.0, "lines": ["子供っぽいぃ。"]}, {"box": [709, 494, 728, 626], "vertical": true, "font_size": 17.0, "lines": ["こうなったら．．"]}, {"box": [586, 719, 637, 816], "vertical": true, "font_size": 24.0, "lines": ["知ってる？", "ここの噂。"]}, {"box": [333, 707, 357, 740], "vertical": true, "font_size": 24.0, "lines": ["え。"]}, {"box": [333, 972, 360, 1050], "vertical": true, "font_size": 20.0, "lines": ["実はね．．．"]}], "img_path": "027.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [684, 632, 754, 764], "vertical": true, "font_size": 21.0, "lines": ["こ．．．ことも", "子供っぽいから", "忘れちゃったわ。"]}, {"box": [660, 928, 713, 1014], "vertical": true, "font_size": 21.0, "lines": ["景色が", "キレイね"]}, {"box": [195, 933, 298, 1033], "vertical": true, "font_size": 23.0, "lines": ["そ．．．", "そうだな。", "景色が", "キレイだ．．"]}], "img_path": "028.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [386, 785, 488, 883], "vertical": true, "font_size": 22.0, "lines": ["じゃあ", "中井君！！", "せーのて", "行こうね！"]}, {"box": [104, 793, 126, 878], "vertical": true, "font_size": 21.0, "lines": ["せーので。"]}], "img_path": "029.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [755, 58, 781, 105], "vertical": true, "font_size": 26.0, "lines": ["え？"]}, {"box": [557, 64, 604, 161], "vertical": true, "font_size": 20.0, "lines": ["ちょっと", "中井君ー！"]}, {"box": [305, 107, 370, 213], "vertical": true, "font_size": 18.0, "lines": ["もーなんて", "先に登り始め", "ちゃうのー"]}, {"box": [98, 96, 144, 203], "vertical": true, "font_size": 20.0, "lines": ["いやーゴメン", "階段好きで。"]}, {"box": [119, 326, 138, 411], "vertical": true, "font_size": 16.0, "lines": ["なにそれ"]}, {"box": [609, 528, 735, 703], "vertical": true, "font_size": 21.0, "lines": ["わかってる！？", "一緒に登ったら、", "付き合えるっていう", "ありがたい", "階段なんだよ！！"]}, {"box": [160, 551, 181, 718], "vertical": true, "font_size": 20.0, "lines": ["ちゃんとしてよ！！"]}, {"box": [582, 856, 651, 986], "vertical": true, "font_size": 20.0, "lines": ["いやー、でも", "オレらもう", "付き合ってるし。"]}, {"box": [473, 843, 493, 980], "vertical": true, "font_size": 16.0, "lines": ["それでもだよー。"]}, {"box": [247, 858, 299, 942], "vertical": true, "font_size": 23.0, "lines": ["ほら、と", "戻って！！"]}, {"box": [139, 864, 210, 960], "vertical": true, "font_size": 23.0, "lines": ["ちゃんと", "合わせて", "行こうよ！！"]}], "img_path": "030.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [394, 71, 444, 158], "vertical": true, "font_size": 22.0, "lines": ["なんか", "あれだね。"]}, {"box": [104, 56, 131, 101], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [670, 471, 749, 587], "vertical": true, "font_size": 19.0, "lines": ["な．．．中井君も", "緊張してたり", "する？"]}, {"box": [490, 453, 510, 557], "vertical": true, "font_size": 18.0, "lines": ["そうだなー"]}, {"box": [249, 460, 271, 563], "vertical": true, "font_size": 20.0, "lines": ["してるなー。"]}, {"box": [563, 820, 642, 943], "vertical": true, "font_size": 20.0, "lines": ["ホントに？"]}, {"box": [166, 831, 244, 966], "vertical": true, "font_size": 20.0, "lines": ["お、見てみろよ", "なんか変な形の", "岩があるぞ"]}], "img_path": "031.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [701, 293, 724, 384], "vertical": true, "font_size": 20.0, "lines": ["着いたなー。"]}, {"box": [263, 284, 285, 328], "vertical": true, "font_size": 22.0, "lines": ["ん？"]}, {"box": [97, 290, 148, 377], "vertical": true, "font_size": 26.0, "lines": ["どうした", "真野。"]}, {"box": [400, 841, 469, 929], "vertical": true, "font_size": 24.0, "lines": ["えっと．．．", "あの．．．"]}, {"box": [189, 853, 211, 931], "vertical": true, "font_size": 20.0, "lines": ["なんだ？"]}, {"box": [158, 1011, 206, 1109], "vertical": true, "font_size": 21.0, "lines": ["ちゃ．．．", "ちゃんと．．．"]}], "img_path": "032.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [623, 103, 649, 201], "vertical": true, "font_size": 21.0, "lines": ["私のこと．．"]}, {"box": [172, 92, 201, 155], "vertical": true, "font_size": 24.0, "lines": ["好き？"]}, {"box": [694, 438, 746, 527], "vertical": true, "font_size": 26.0, "lines": ["あぁ", "好きだぞ。"]}, {"box": [351, 451, 412, 547], "vertical": true, "font_size": 30.0, "lines": ["景色", "見ようぜ。"]}, {"box": [315, 810, 356, 905], "vertical": true, "font_size": 32.0, "lines": ["軽い！！"]}, {"box": [223, 764, 251, 809], "vertical": true, "font_size": 28.0, "lines": ["え！？"]}, {"box": [43, 776, 154, 877], "vertical": true, "font_size": 30.0, "lines": ["軽い！！", "不安に", "なるくらい", "軽い！！"]}], "img_path": "033.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [677, 48, 752, 181], "vertical": true, "font_size": 17.0, "lines": ["そう言われても", "どうすれば", "いいんだ"]}, {"box": [345, 60, 393, 168], "vertical": true, "font_size": 22.0, "lines": ["うー．．．", "もういいよ。"]}, {"box": [646, 321, 748, 418], "vertical": true, "font_size": 22.0, "lines": ["とりあえず", "ノートに", "お互いの", "名前書こ。"]}, {"box": [162, 312, 235, 473], "vertical": true, "font_size": 21.0, "lines": ["そしたら", "ずっと一緒に", "いられるんだって。"]}, {"box": [483, 751, 505, 874], "vertical": true, "font_size": 20.0, "lines": ["いや、オレは．．．"]}, {"box": [111, 720, 144, 873], "vertical": true, "font_size": 32.0, "lines": ["なんでぇ！？"]}], "img_path": "034.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [666, 112, 745, 258], "vertical": true, "font_size": 21.0, "lines": ["やっぱ私のこと", "好きじゃ", "ないの．．．？"]}, {"box": [357, 119, 411, 210], "vertical": true, "font_size": 27.0, "lines": ["いや、", "違うって。"]}, {"box": [265, 112, 322, 221], "vertical": true, "font_size": 29.0, "lines": ["何が", "違うのよー。"]}, {"box": [82, 52, 353, 72], "vertical": false, "font_size": 20.0, "lines": ["からかい上手の高ホさん"]}, {"box": [703, 467, 747, 579], "vertical": true, "font_size": 18.0, "lines": ["えーと．．．", "恥ずかしいな。"]}, {"box": [461, 457, 512, 590], "vertical": true, "font_size": 20.0, "lines": ["恥ずかしくても", "いいじゃん！"]}, {"box": [294, 469, 320, 553], "vertical": true, "font_size": 21.0, "lines": ["何それー。"]}, {"box": [185, 454, 233, 533], "vertical": true, "font_size": 21.0, "lines": ["そうじゃ", "なくて．．．"]}], "img_path": "035.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [694, 59, 795, 215], "vertical": true, "font_size": 23.0, "lines": ["オレ、", "前に一人で来て、", "すでに名前書いて", "るんだよ．．．"]}, {"box": [685, 621, 741, 714], "vertical": false, "font_size": 32.0, "lines": ["はぁ"]}, {"box": [645, 919, 719, 1025], "vertical": true, "font_size": 22.0, "lines": ["えーもー", "はやく", "言ってよー。"]}, {"box": [521, 937, 599, 1042], "vertical": true, "font_size": 22.0, "lines": ["中井君て", "私のこと", "好きだねぇ。"]}, {"box": [248, 940, 266, 1035], "vertical": true, "font_size": 16.0, "lines": ["そーだなー。"]}], "img_path": "036.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [281, 94, 562, 233], "vertical": false, "font_size": 32.0, "lines": ["お弁当"]}], "img_path": "037.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [493, 127, 568, 225], "vertical": true, "font_size": 24.0, "lines": ["よし！", "やっと", "昼ごはん！！"]}, {"box": [125, 137, 173, 239], "vertical": true, "font_size": 22.0, "lines": ["もう腹が", "ペコペコだ。"]}, {"box": [110, 309, 155, 442], "vertical": true, "font_size": 22.0, "lines": ["はやくみんなで", "弁当を。"]}, {"box": [323, 886, 506, 1108], "vertical": false, "font_size": 29.0, "lines": ["え"]}], "img_path": "038.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [723, 96, 741, 199], "vertical": true, "font_size": 17.0, "lines": ["そうだった．．．"]}, {"box": [398, 98, 471, 239], "vertical": true, "font_size": 19.0, "lines": ["仲のいいやつらは", "今日休んでるん", "だった．．．"]}, {"box": [313, 49, 360, 202], "vertical": true, "font_size": 20.0, "lines": ["たまには", "一人で食べるか．．．"]}], "img_path": "039.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [713, 78, 781, 228], "vertical": true, "font_size": 24.0, "lines": ["いやー、たまには", "いいね！", "一人で食べるのも。"]}, {"box": [306, 78, 382, 192], "vertical": true, "font_size": 21.0, "lines": ["なんか窓も", "あって眺めも", "いいし。"]}, {"box": [215, 85, 240, 196], "vertical": true, "font_size": 17.0, "lines": ["それに何より、"]}, {"box": [711, 540, 731, 635], "vertical": true, "font_size": 16.0, "lines": ["からあげ！！"]}, {"box": [287, 838, 304, 897], "vertical": true, "font_size": 17.0, "lines": ["．．．．．．？"]}, {"box": [144, 551, 197, 650], "vertical": true, "font_size": 24.0, "lines": ["最高の", "おかずだ！"]}, {"box": [105, 843, 147, 956], "vertical": true, "font_size": 18.0, "lines": ["やはり", "少しさみしい。"]}], "img_path": "040.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [659, 130, 712, 219], "vertical": true, "font_size": 26.0, "lines": ["あ、", "いたいた"]}, {"box": [248, 63, 303, 161], "vertical": true, "font_size": 26.0, "lines": ["一緒に", "食べない？"]}, {"box": [712, 538, 730, 602], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．？"]}, {"box": [435, 537, 485, 624], "vertical": true, "font_size": 24.0, "lines": ["い．．．", "いいけど。"]}, {"box": [356, 540, 408, 611], "vertical": true, "font_size": 26.0, "lines": ["でも、", "なんで。"]}, {"box": [170, 844, 189, 875], "vertical": true, "font_size": 19.0, "lines": ["え。"]}, {"box": [645, 867, 732, 1006], "vertical": true, "font_size": 30.0, "lines": ["西片", "一人っぽかった", "から、"]}, {"box": [251, 848, 298, 963], "vertical": true, "font_size": 20.0, "lines": ["さみしいかな", "と思って。"]}], "img_path": "041.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [550, 132, 595, 236], "vertical": true, "font_size": 18.0, "lines": ["からかいに", "来たんだよ。"]}, {"box": [351, 112, 370, 214], "vertical": true, "font_size": 16.0, "lines": ["そうだよね"]}, {"box": [216, 96, 286, 250], "vertical": true, "font_size": 19.0, "lines": ["さみしいと思って", "からかいに来るって", "おかしくない？"]}, {"box": [99, 116, 118, 241], "vertical": true, "font_size": 16.0, "lines": ["いただきまーす。"]}, {"box": [237, 747, 254, 792], "vertical": true, "font_size": 17.0, "lines": ["．．．"]}], "img_path": "042.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [555, 60, 625, 173], "vertical": true, "font_size": 19.0, "lines": ["西片のからあげ", "おいしそう", "だね。"]}, {"box": [82, 107, 133, 233], "vertical": true, "font_size": 20.0, "lines": ["それかけて", "勝負しない？"]}, {"box": [671, 605, 743, 703], "vertical": true, "font_size": 22.0, "lines": ["しかけて", "きたな", "高木さん．．．"]}, {"box": [370, 587, 413, 725], "vertical": true, "font_size": 19.0, "lines": ["じゃあ", "オレが勝ったら．．．"]}, {"box": [277, 588, 318, 707], "vertical": true, "font_size": 16.0, "lines": ["そのレンコンの", "何かをもらう。"]}, {"box": [146, 744, 166, 853], "vertical": true, "font_size": 23.0, "lines": ["はさみあげね、"]}, {"box": [86, 793, 112, 854], "vertical": true, "font_size": 23.0, "lines": ["いいよ。"]}, {"box": [631, 962, 738, 1045], "vertical": true, "font_size": 27.0, "lines": ["肉系の", "おかずは", "弁当のせめいせん", "生命線．．．"]}, {"box": [100, 938, 181, 1073], "vertical": true, "font_size": 23.0, "lines": ["絶対にま", "負けるわけには", "いかないぞ．．．"]}], "img_path": "043.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [664, 126, 731, 249], "vertical": true, "font_size": 19.0, "lines": ["このおにぎりの", "具はなんて", "しょうか"]}, {"box": [241, 112, 317, 227], "vertical": true, "font_size": 22.0, "lines": ["シンプルかつ", "なかなか", "難しい．．．"]}, {"box": [107, 112, 156, 198], "vertical": true, "font_size": 22.0, "lines": ["さすが", "高木さん"]}, {"box": [682, 665, 753, 805], "vertical": true, "font_size": 19.0, "lines": ["高木さんの", "おかずから", "推測できるか．．．？"]}, {"box": [431, 682, 473, 787], "vertical": true, "font_size": 18.0, "lines": ["いや、それは", "難しそうだ．．．"]}, {"box": [351, 662, 394, 783], "vertical": true, "font_size": 32.0, "lines": ["山カンで．．．？"]}, {"box": [108, 663, 180, 863], "vertical": true, "font_size": 19.0, "lines": ["だめだ．．．", "負けたらからあげだぞ", "リスクがでかすぎる．．．"]}, {"box": [706, 963, 753, 1060], "vertical": true, "font_size": 22.0, "lines": ["く．．．", "どうする．．．"]}], "img_path": "044.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [381, 177, 462, 303], "vertical": true, "font_size": 32.0, "lines": ["答えは．．．", "シャケ！！"]}, {"box": [237, 130, 339, 237], "vertical": true, "font_size": 24.0, "lines": ["ふーん。", "じゃあ", "答え合わせ", "してみよー。"]}, {"box": [82, 52, 371, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [656, 583, 746, 694], "vertical": true, "font_size": 23.0, "lines": ["くくく．．．", "高木さん．．．", "オレは見逃さ", "なかったよ．．．"]}, {"box": [323, 583, 451, 727], "vertical": true, "font_size": 24.0, "lines": ["隣の", "おにぎりから", "少しシャケが", "のぞいているのを", "ね！"]}, {"box": [672, 945, 724, 1068], "vertical": true, "font_size": 20.0, "lines": ["はさみあげは", "いただいた。"]}], "img_path": "045.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [477, 98, 535, 214], "vertical": true, "font_size": 25.0, "lines": ["正解は", "ウメでした。"]}, {"box": [374, 63, 401, 106], "vertical": true, "font_size": 27.0, "lines": ["な！？"]}, {"box": [353, 318, 402, 424], "vertical": true, "font_size": 20.0, "lines": ["じゃあ", "もらうねー。"]}, {"box": [96, 316, 114, 380], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．？"]}, {"box": [569, 609, 747, 761], "vertical": true, "font_size": 19.0, "lines": ["そうだ．．．", "あれだけ凝ってる", "弁当だ．．．", "２つのおにぎりの", "具が同じである", "確証なんて", "ないのに．．．"]}, {"box": [103, 609, 229, 820], "vertical": true, "font_size": 18.0, "lines": ["からあげを", "とられることを", "恐れすぎて", "安易な答えに", "手をのばしてしまった．．．"]}, {"box": [696, 918, 743, 1052], "vertical": true, "font_size": 20.0, "lines": ["オレの", "からあげが．．．！！"]}, {"box": [265, 909, 289, 943], "vertical": false, "font_size": 32.0, "lines": ["モぐ"]}], "img_path": "046.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [694, 99, 745, 243], "vertical": true, "font_size": 24.0, "lines": ["やっぱ", "かわいそうだし、"]}, {"box": [357, 107, 428, 241], "vertical": true, "font_size": 19.0, "lines": ["はさみあげと", "交換ってことに", "してあげるよ。"]}, {"box": [287, 99, 309, 212], "vertical": true, "font_size": 21.0, "lines": ["い．．．いいの！？"]}, {"box": [82, 52, 353, 72], "vertical": false, "font_size": 20.0, "lines": ["からかい上手の高ホさん"]}, {"box": [89, 96, 110, 141], "vertical": true, "font_size": 21.0, "lines": ["うん。"]}, {"box": [652, 540, 699, 637], "vertical": true, "font_size": 20.0, "lines": ["いや．．．でも", "負けたし．．．"]}, {"box": [267, 527, 288, 591], "vertical": true, "font_size": 22.0, "lines": ["じゃあ、"]}, {"box": [123, 526, 224, 660], "vertical": true, "font_size": 22.0, "lines": ["その分、別の", "罰ゲームでも", "してもらうって", "ことで。"]}, {"box": [378, 884, 436, 1042], "vertical": true, "font_size": 29.0, "lines": ["べ．．．別の", "罰ゲームって．．．？"]}], "img_path": "047.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [363, 683, 394, 737], "vertical": true, "font_size": 31.0, "lines": ["な．．．"]}], "img_path": "048.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [651, 125, 731, 261], "vertical": true, "font_size": 21.0, "lines": ["罰ゲームって．．．", "もしかして", "これ．．．！？"]}, {"box": [210, 134, 310, 232], "vertical": true, "font_size": 22.0, "lines": ["これを", "あーん", "されろって", "こと．．．！？"]}], "img_path": "049.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [414, 106, 473, 233], "vertical": true, "font_size": 27.0, "lines": ["何に", "しようかなー、"]}, {"box": [353, 126, 374, 213], "vertical": true, "font_size": 27.0, "lines": ["罰ゲーム。"]}, {"box": [442, 413, 470, 457], "vertical": true, "font_size": 28.0, "lines": ["へ？"]}, {"box": [93, 406, 141, 504], "vertical": true, "font_size": 22.0, "lines": ["ん？", "どしたの？"]}, {"box": [698, 667, 747, 771], "vertical": true, "font_size": 23.0, "lines": ["あれ？", "もしかして、"]}, {"box": [368, 725, 413, 877], "vertical": true, "font_size": 18.0, "lines": ["あーんって", "してほしかった？"]}], "img_path": "050.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [638, 144, 685, 241], "vertical": true, "font_size": 20.0, "lines": ["してほしく", "ないから！！"]}, {"box": [388, 121, 410, 243], "vertical": true, "font_size": 20.0, "lines": ["ホントかなー。"]}, {"box": [83, 52, 371, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [145, 148, 183, 352], "vertical": true, "font_size": 31.0, "lines": ["高木さんめぇえ。"]}, {"box": [313, 313, 335, 390], "vertical": true, "font_size": 22.0, "lines": ["ホント！！"]}, {"box": [228, 546, 275, 625], "vertical": true, "font_size": 21.0, "lines": ["ごちそう", "さま。"]}, {"box": [687, 812, 738, 928], "vertical": true, "font_size": 25.0, "lines": ["あーたの", "楽しかったー。"]}, {"box": [312, 827, 330, 931], "vertical": true, "font_size": 17.0, "lines": ["よかったね．．．"]}, {"box": [239, 759, 259, 825], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．？"]}], "img_path": "051.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [674, 77, 742, 235], "vertical": true, "font_size": 20.0, "lines": ["オレも．．．", "一人で食べるよりは", "楽しかったし．．"]}, {"box": [458, 102, 476, 205], "vertical": true, "font_size": 16.0, "lines": ["ありがとう．．．"]}, {"box": [330, 319, 404, 435], "vertical": true, "font_size": 21.0, "lines": ["じゃあまた", "一緒に食べて", "くれる？"]}, {"box": [674, 578, 743, 665], "vertical": true, "font_size": 26.0, "lines": ["うん。"]}, {"box": [561, 916, 691, 1051], "vertical": true, "font_size": 20.0, "lines": ["じゃあ今度は", "西片がして", "ほしそうだった", "あーんを", "してあげよう。"]}, {"box": [196, 932, 271, 1031], "vertical": true, "font_size": 22.0, "lines": ["だから", "してほしく", "ないって。"]}], "img_path": "052.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [244, 1036, 518, 1160], "vertical": false, "font_size": 32.0, "lines": ["はっ", "初詣で"]}], "img_path": "053.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "054.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [381, 67, 453, 172], "vertical": true, "font_size": 19.0, "lines": ["あけまして", "おめでとう", "ございます。"]}, {"box": [697, 826, 755, 908], "vertical": true, "font_size": 30.0, "lines": ["一人で", "来たの？"]}, {"box": [436, 836, 487, 900], "vertical": true, "font_size": 28.0, "lines": ["いや、", "家族と。"]}, {"box": [108, 820, 181, 943], "vertical": true, "font_size": 21.0, "lines": ["駐車場で", "知り合いと", "話しこんでて．．．"]}, {"box": [381, 1023, 479, 1087], "vertical": true, "font_size": 25.0, "lines": ["そっか、", "うちも", "そんな", "感じ。"]}], "img_path": "055.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [780, 66, 809, 121], "vertical": true, "font_size": 27.0, "lines": ["ねぇ、"]}, {"box": [472, 69, 527, 176], "vertical": true, "font_size": 28.0, "lines": ["一緒に", "まわろうよ。"]}, {"box": [298, 114, 330, 166], "vertical": true, "font_size": 26.0, "lines": ["うん、"]}, {"box": [244, 142, 264, 227], "vertical": true, "font_size": 26.0, "lines": ["いいけど。"]}, {"box": [126, 256, 151, 324], "vertical": true, "font_size": 25.0, "lines": ["やった。"]}], "img_path": "056.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [274, 41, 345, 170], "vertical": true, "font_size": 19.0, "lines": ["当たり前だけど", "家族とカップル", "ばっかりだねー。"]}, {"box": [380, 447, 458, 622], "vertical": true, "font_size": 21.0, "lines": ["私たち、", "どっちでもないのに", "なんか変な感じ。"]}, {"box": [87, 625, 106, 692], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．"]}, {"box": [602, 908, 681, 1045], "vertical": true, "font_size": 24.0, "lines": ["えっと．．．", "二礼二拍手一礼", "だっけ．．．"]}, {"box": [174, 917, 226, 1024], "vertical": true, "font_size": 23.0, "lines": ["たしか", "そうだねー。"]}], "img_path": "057.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [772, 22, 812, 101], "vertical": false, "font_size": 24.0, "lines": ["んっ"]}, {"box": [719, 444, 754, 527], "vertical": true, "font_size": 32.0, "lines": ["今年は、"]}, {"box": [112, 462, 207, 648], "vertical": true, "font_size": 25.0, "lines": ["高木さんに", "からかわれません", "ように。"]}, {"box": [412, 880, 461, 956], "vertical": true, "font_size": 32.0, "lines": ["ミコッ"]}], "img_path": "058.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [237, 62, 293, 153], "vertical": true, "font_size": 25.0, "lines": ["何お願い", "したの？"]}, {"box": [531, 534, 551, 630], "vertical": true, "font_size": 20.0, "lines": ["ないしょ．．．"]}, {"box": [440, 526, 485, 659], "vertical": true, "font_size": 20.0, "lines": ["私にからかわれ", "ませんように。"]}, {"box": [372, 550, 397, 615], "vertical": true, "font_size": 20.0, "lines": ["とか？"]}, {"box": [637, 571, 663, 631], "vertical": true, "font_size": 26.0, "lines": ["いや．．．"]}, {"box": [596, 932, 646, 1039], "vertical": true, "font_size": 22.0, "lines": ["あはは、", "当たりだー。"]}, {"box": [135, 946, 207, 1044], "vertical": true, "font_size": 19.0, "lines": ["くそ．．．もう", "からかわれ", "てる．．．"]}], "img_path": "059.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [740, 70, 794, 185], "vertical": true, "font_size": 22.0, "lines": ["高木さんは", "何願ったの。"]}, {"box": [454, 46, 478, 134], "vertical": true, "font_size": 21.0, "lines": ["ないしょ。"]}, {"box": [165, 66, 222, 137], "vertical": true, "font_size": 28.0, "lines": ["当てて", "みてよ。"]}, {"box": [631, 495, 751, 652], "vertical": true, "font_size": 20.0, "lines": ["どーせオレを", "からかえますよーに", "とかでしょ。"]}, {"box": [174, 521, 197, 608], "vertical": true, "font_size": 21.0, "lines": ["はずれー。"]}, {"box": [338, 840, 388, 945], "vertical": true, "font_size": 23.0, "lines": ["ぐ．．．", "高木さんめ。"]}, {"box": [664, 839, 742, 992], "vertical": true, "font_size": 19.0, "lines": ["それは別に", "お願いしなくても", "てきるからねー。"]}], "img_path": "060.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [76, 175, 129, 271], "vertical": true, "font_size": 20.0, "lines": ["今年最初の", "勝負だね。"]}, {"box": [658, 540, 735, 714], "vertical": true, "font_size": 23.0, "lines": ["オレは新年そうそう", "負け続けてる", "気がしてたのに．．．"]}, {"box": [583, 575, 603, 671], "vertical": true, "font_size": 23.0, "lines": ["この余裕："]}, {"box": [274, 567, 302, 671], "vertical": true, "font_size": 20.0, "lines": ["お先どーぞ。"]}, {"box": [183, 547, 209, 701], "vertical": true, "font_size": 30.0, "lines": ["いいのを引いて．．．"]}, {"box": [107, 694, 144, 767], "vertical": true, "font_size": 30.0, "lines": ["勝つ。"]}, {"box": [451, 1109, 489, 1199], "vertical": true, "font_size": 14.0, "lines": ["またオレがないんだけど．．．なんでもなんだもん", "はいはいます！！"]}, {"box": [405, 1110, 437, 1200], "vertical": true, "font_size": 12.0, "lines": ["はいはいっちゃったんだけど", "．．．"]}, {"box": [358, 1107, 389, 1200], "vertical": true, "font_size": 12.0, "lines": ["いやいいいけどね", "おかげないのはいいけどね"]}, {"box": [312, 1107, 343, 1200], "vertical": true, "font_size": 14.0, "lines": ["いや．．．わかりませんでしょうかねえねえ", "ははは"]}], "img_path": "061.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [772, 69, 798, 121], "vertical": true, "font_size": 26.0, "lines": ["おー。"]}, {"box": [521, 80, 539, 146], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．？"]}, {"box": [423, 62, 470, 187], "vertical": true, "font_size": 22.0, "lines": ["吉って", "いいんだっけ？"]}, {"box": [123, 63, 168, 177], "vertical": true, "font_size": 21.0, "lines": ["たしか", "大吉の次だよ。"]}, {"box": [448, 349, 474, 400], "vertical": true, "font_size": 26.0, "lines": ["ほう。"]}, {"box": [606, 554, 733, 689], "vertical": true, "font_size": 21.0, "lines": ["よし．．", "なら高木さんが", "大吉以外なら", "少なくとも", "引き分け．．．"]}, {"box": [250, 821, 271, 907], "vertical": true, "font_size": 21.0, "lines": ["だよなぁ。"]}], "img_path": "062.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [651, 464, 701, 543], "vertical": true, "font_size": 24.0, "lines": ["おいしい", "ねー。"]}, {"box": [178, 468, 202, 533], "vertical": true, "font_size": 24.0, "lines": ["うん．．．"]}, {"box": [726, 864, 746, 943], "vertical": true, "font_size": 20.0, "lines": ["うーん．．．"]}, {"box": [439, 860, 519, 957], "vertical": true, "font_size": 22.0, "lines": ["健康で", "いられます", "ように？"]}, {"box": [132, 879, 156, 923], "vertical": true, "font_size": 23.0, "lines": ["ん？"]}], "img_path": "063.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [764, 50, 793, 104], "vertical": true, "font_size": 24.0, "lines": ["ああ。"]}, {"box": [682, 85, 731, 182], "vertical": true, "font_size": 24.0, "lines": ["私がした", "お願い事？"]}, {"box": [384, 65, 405, 151], "vertical": true, "font_size": 21.0, "lines": ["はずれー。"]}, {"box": [166, 124, 189, 167], "vertical": true, "font_size": 23.0, "lines": ["ぐ．．．"]}, {"box": [657, 515, 732, 658], "vertical": true, "font_size": 22.0, "lines": ["くそ．．．", "新年から", "負け続きなんだ。"]}, {"box": [100, 503, 175, 621], "vertical": true, "font_size": 20.0, "lines": ["なんとしても", "ここは当てて", "おきたい．．"]}, {"box": [722, 875, 743, 943], "vertical": true, "font_size": 20.0, "lines": ["うーむ。"]}, {"box": [391, 887, 421, 1025], "vertical": true, "font_size": 24.0, "lines": ["ピロリローン"]}, {"box": [284, 854, 309, 989], "vertical": true, "font_size": 20.0, "lines": ["あ、お母さんだ。"]}, {"box": [127, 951, 208, 1013], "vertical": false, "font_size": 32.0, "lines": ["お母さ"]}], "img_path": "064.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [656, 67, 738, 189], "vertical": true, "font_size": 26.0, "lines": ["うん、今", "甘酒飲んでる", "とこ。"]}, {"box": [459, 64, 486, 113], "vertical": true, "font_size": 24.0, "lines": ["うん、"]}, {"box": [404, 84, 426, 169], "vertical": true, "font_size": 24.0, "lines": ["わかった。"]}, {"box": [276, 53, 301, 123], "vertical": true, "font_size": 25.0, "lines": ["ゴメン。"]}, {"box": [339, 201, 365, 253], "vertical": true, "font_size": 26.0, "lines": ["うん。"]}, {"box": [100, 62, 152, 178], "vertical": true, "font_size": 20.0, "lines": ["呼ばれたから", "行くね。"]}, {"box": [714, 519, 741, 564], "vertical": true, "font_size": 27.0, "lines": ["な．．．"]}, {"box": [495, 513, 518, 555], "vertical": true, "font_size": 23.0, "lines": ["ん？"]}, {"box": [349, 526, 452, 644], "vertical": true, "font_size": 25.0, "lines": ["あれ？", "もうちょっと", "一緒に", "いたかった？"]}, {"box": [640, 919, 715, 1018], "vertical": true, "font_size": 22.0, "lines": ["そ．．．", "そういう", "わけでは．．．"]}, {"box": [181, 937, 229, 1023], "vertical": true, "font_size": 20.0, "lines": ["あはは", "冗談だよ。"]}], "img_path": "065.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [735, 60, 816, 196], "vertical": true, "font_size": 23.0, "lines": ["ふー、", "最初の勝負でも", "勝てたし、"]}, {"box": [496, 70, 548, 178], "vertical": true, "font_size": 25.0, "lines": ["会えて", "よかったよ。"]}, {"box": [364, 79, 418, 182], "vertical": true, "font_size": 19.0, "lines": ["．．．来年の", "おみくじは、"]}, {"box": [105, 110, 133, 253], "vertical": true, "font_size": 20.0, "lines": ["オレが勝つから。"]}, {"box": [233, 482, 332, 598], "vertical": true, "font_size": 20.0, "lines": ["それって", "来年も一緒に", "初詣でしよう", "ってこと？"]}, {"box": [664, 895, 697, 936], "vertical": true, "font_size": 25.0, "lines": ["あ。"]}, {"box": [531, 901, 604, 1055], "vertical": true, "font_size": 21.0, "lines": ["い．．．いや．．．", "ぐ．．．偶然会ったら", "だけど。"]}], "img_path": "066.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [687, 100, 742, 215], "vertical": true, "font_size": 23.0, "lines": ["来年も一緒に", "したいな"]}, {"box": [365, 90, 395, 158], "vertical": true, "font_size": 22.0, "lines": ["初詣で。"]}, {"box": [297, 59, 316, 123], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．"]}, {"box": [691, 495, 716, 561], "vertical": true, "font_size": 22.0, "lines": ["．．．うん。"]}, {"box": [592, 503, 640, 590], "vertical": true, "font_size": 22.0, "lines": ["じゃあ．．．", "また来年。"]}, {"box": [261, 498, 333, 638], "vertical": true, "font_size": 20.0, "lines": ["どうせ毎年", "親は知り合いと", "話しこんでるし．．．"]}, {"box": [673, 871, 727, 1016], "vertical": true, "font_size": 22.0, "lines": ["早くも", "叶っちゃったな。"]}, {"box": [343, 921, 375, 994], "vertical": true, "font_size": 28.0, "lines": ["願い事。"]}, {"box": [246, 880, 268, 924], "vertical": true, "font_size": 22.0, "lines": ["え？"]}], "img_path": "067.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [713, 90, 793, 230], "vertical": true, "font_size": 22.0, "lines": ["西片に", "デートに誘われ", "ますようにって、"]}, {"box": [335, 103, 390, 210], "vertical": true, "font_size": 26.0, "lines": ["お願い", "したんだよ。"]}, {"box": [96, 90, 123, 135], "vertical": true, "font_size": 27.0, "lines": ["な．．．"]}, {"box": [643, 902, 716, 1034], "vertical": true, "font_size": 24.0, "lines": ["いや！！", "そういうのじゃ", "ないから！！"]}, {"box": [477, 914, 554, 1017], "vertical": true, "font_size": 24.0, "lines": ["っていうか", "絶対", "ウソだろ！"]}, {"box": [200, 905, 276, 1034], "vertical": true, "font_size": 25.0, "lines": ["あはは、", "今年も", "よろしくねー。"]}], "img_path": "068.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "069.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [682, 605, 753, 686], "vertical": true, "font_size": 26.0, "lines": ["おー、", "降って", "きたなー。"]}, {"box": [572, 728, 592, 791], "vertical": true, "font_size": 20.0, "lines": ["うげー。"]}, {"box": [483, 625, 503, 717], "vertical": true, "font_size": 20.0, "lines": ["マジかよー。"]}, {"box": [119, 588, 155, 664], "vertical": true, "font_size": 32.0, "lines": ["雨．．．"]}, {"box": [418, 873, 440, 960], "vertical": true, "font_size": 20.0, "lines": ["ありゃー。"]}, {"box": [215, 878, 297, 975], "vertical": true, "font_size": 22.0, "lines": ["天気予報", "微妙だった", "のにね。"]}], "img_path": "070.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [697, 100, 726, 209], "vertical": true, "font_size": 26.0, "lines": ["まずい！！"]}, {"box": [77, 145, 153, 241], "vertical": true, "font_size": 32.0, "lines": ["傘を", "忘れた。"]}, {"box": [395, 460, 444, 582], "vertical": true, "font_size": 20.0, "lines": ["お、じゃあ", "ＨＲ終わりー。"]}, {"box": [297, 494, 344, 590], "vertical": true, "font_size": 20.0, "lines": ["気をつけて", "帰れよ。"]}], "img_path": "071.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [687, 62, 707, 165], "vertical": true, "font_size": 19.0, "lines": ["すいません。"]}, {"box": [599, 78, 645, 201], "vertical": true, "font_size": 19.0, "lines": ["忘れものの", "傘ありますか。"]}, {"box": [340, 63, 367, 106], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [254, 99, 281, 244], "vertical": true, "font_size": 23.0, "lines": ["あぁ、１本だけ。"]}, {"box": [100, 110, 156, 196], "vertical": true, "font_size": 24.0, "lines": ["貸して", "ください。"]}, {"box": [365, 305, 413, 324], "vertical": false, "font_size": 17.0, "lines": ["おとしもの"]}, {"box": [488, 459, 517, 523], "vertical": true, "font_size": 29.0, "lines": ["ふふ．．．"]}, {"box": [97, 271, 169, 386], "vertical": true, "font_size": 20.0, "lines": ["じゃあここに", "学年と名前", "書いて。"]}, {"box": [99, 467, 147, 583], "vertical": true, "font_size": 20.0, "lines": ["よかった．．．", "傘があって．．．"]}, {"box": [656, 758, 743, 925], "vertical": true, "font_size": 23.0, "lines": ["高木さんに", "傘を忘れたことが", "バレたら、"]}, {"box": [429, 719, 487, 834], "vertical": true, "font_size": 22.0, "lines": ["あいあいかさ", "する"]}, {"box": [99, 864, 150, 998], "vertical": true, "font_size": 20.0, "lines": ["こうなる", "ところだった。"]}], "img_path": "072.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [277, 51, 301, 157], "vertical": true, "font_size": 17.0, "lines": ["高木さんは．．．"]}, {"box": [66, 95, 91, 223], "vertical": true, "font_size": 17.0, "lines": ["もう帰ったかな"]}, {"box": [646, 509, 721, 649], "vertical": true, "font_size": 23.0, "lines": ["いや、まぁいい。", "オレは", "急いで帰ろう．．"]}, {"box": [106, 528, 152, 642], "vertical": true, "font_size": 19.0, "lines": ["なんたって", "あと少しで．．．"]}, {"box": [670, 808, 731, 993], "vertical": true, "font_size": 24.0, "lines": ["爆裂！！", "最強サッカー！！」の、"]}, {"box": [294, 949, 390, 1008], "vertical": false, "font_size": 32.0, "lines": ["５ＰＥ１"]}, {"box": [131, 815, 187, 990], "vertical": true, "font_size": 22.0, "lines": ["スペシャル番組が", "始まるんだからな。"]}], "img_path": "073.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [671, 78, 738, 198], "vertical": true, "font_size": 16.0, "lines": ["ファンとして", "見逃すわけには", "いかない．．．"]}, {"box": [310, 63, 385, 153], "vertical": true, "font_size": 30.0, "lines": ["しかし", "油断", "してたな。"]}, {"box": [100, 58, 178, 234], "vertical": true, "font_size": 22.0, "lines": ["次からは", "天気予報が微妙でも", "傘を持ってこよう．．．"]}, {"box": [229, 583, 247, 632], "vertical": true, "font_size": 18.0, "lines": ["．．．．．"]}, {"box": [482, 881, 512, 979], "vertical": true, "font_size": 21.0, "lines": ["高木さん．．．"]}, {"box": [110, 894, 193, 992], "vertical": true, "font_size": 25.0, "lines": ["傘", "持ってるの", "かな．．．"]}], "img_path": "074.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [357, 71, 435, 171], "vertical": true, "font_size": 23.0, "lines": ["いや、まぁ", "高木さんの", "ことだし、"]}, {"box": [129, 49, 155, 174], "vertical": true, "font_size": 19.0, "lines": ["持ってるだろ。"]}, {"box": [664, 412, 720, 483], "vertical": true, "font_size": 30.0, "lines": ["大丈夫", "大丈夫。"]}, {"box": [649, 802, 729, 924], "vertical": true, "font_size": 23.0, "lines": ["でも前．．．傘", "忘れてたよな、", "高木さん．．．"]}, {"box": [113, 791, 161, 1035], "vertical": true, "font_size": 20.0, "lines": ["もしかして．．", "今日も．．"]}], "img_path": "075.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [675, 69, 750, 222], "vertical": true, "font_size": 20.0, "lines": ["いや！", "だからこそ今日は", "忘れてないだろ！！"]}, {"box": [393, 113, 421, 239], "vertical": true, "font_size": 24.0, "lines": ["高木さんだし。"]}, {"box": [248, 89, 340, 230], "vertical": true, "font_size": 23.0, "lines": ["さっさと帰って", "「爆裂！！", "最強サッカー！！」を", "観よう。"]}, {"box": [98, 288, 124, 342], "vertical": true, "font_size": 26.0, "lines": ["うん。"]}], "img_path": "076.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [82, 52, 370, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [672, 884, 709, 924], "vertical": true, "font_size": 32.0, "lines": ["雨、"]}, {"box": [134, 914, 162, 1011], "vertical": true, "font_size": 20.0, "lines": ["止むかな．．．"]}], "img_path": "077.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [422, 116, 447, 150], "vertical": true, "font_size": 25.0, "lines": ["あ。"]}, {"box": [695, 669, 726, 718], "vertical": true, "font_size": 27.0, "lines": ["西片。"]}, {"box": [439, 661, 453, 722], "vertical": true, "font_size": 14.0, "lines": ["．．．"]}, {"box": [347, 648, 406, 768], "vertical": true, "font_size": 30.0, "lines": ["傘．．．", "忘れたの．．．？"]}, {"box": [156, 662, 175, 773], "vertical": true, "font_size": 17.0, "lines": ["もしかして．．"]}, {"box": [698, 994, 746, 1101], "vertical": true, "font_size": 22.0, "lines": ["うん、", "そうなんだ。"]}, {"box": [171, 989, 191, 1067], "vertical": true, "font_size": 19.0, "lines": ["そっか．．．"]}], "img_path": "078.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [692, 38, 755, 157], "vertical": true, "font_size": 24.0, "lines": ["あの．．．"]}, {"box": [480, 71, 503, 151], "vertical": true, "font_size": 21.0, "lines": ["じゃあ．．．"]}, {"box": [407, 62, 434, 106], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [217, 223, 241, 267], "vertical": true, "font_size": 24.0, "lines": ["あ．．．"]}, {"box": [625, 479, 704, 577], "vertical": true, "font_size": 29.0, "lines": ["しゆ．．．ちくだい", "宿題", "してるの！？"]}, {"box": [345, 536, 374, 590], "vertical": true, "font_size": 26.0, "lines": ["うん。"]}, {"box": [90, 503, 112, 626], "vertical": true, "font_size": 16.0, "lines": ["ヒマつぶしに。"]}, {"box": [234, 546, 313, 673], "vertical": true, "font_size": 26.0, "lines": ["待ってたら", "雨止むかなと", "思って。"]}, {"box": [151, 991, 201, 1054], "vertical": true, "font_size": 26.0, "lines": ["．．．そ．．．", "そう．．．"]}], "img_path": "079.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [702, 117, 755, 232], "vertical": true, "font_size": 20.0, "lines": ["さ．．．誘うの", "恥ずかしい．．．"]}, {"box": [489, 111, 537, 246], "vertical": true, "font_size": 22.0, "lines": ["どうすれば", "いいんだコレ．．．"]}, {"box": [347, 113, 447, 210], "vertical": true, "font_size": 21.0, "lines": ["そういえば", "西片は傘", "借りられ", "たの？"]}, {"box": [118, 122, 135, 153], "vertical": true, "font_size": 17.0, "lines": ["え。"]}, {"box": [107, 116, 144, 160], "vertical": false, "font_size": 32.0, "lines": ["え。"]}, {"box": [582, 469, 744, 663], "vertical": true, "font_size": 22.0, "lines": ["ＨＲ", "終わってから", "ダッシュしてたのって", "忘れものの傘", "借りようと", "したからでしょ。"]}, {"box": [201, 497, 221, 563], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．"]}, {"box": [700, 786, 753, 941], "vertical": true, "font_size": 21.0, "lines": ["運よく１本あって", "借りられて．．．"]}, {"box": [462, 785, 506, 863], "vertical": true, "font_size": 21.0, "lines": ["だから．．．"]}, {"box": [226, 792, 246, 870], "vertical": true, "font_size": 20.0, "lines": ["えーと．．．"]}], "img_path": "080.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [358, 117, 388, 235], "vertical": true, "font_size": 29.0, "lines": ["入ってく．．．？"]}, {"box": [602, 967, 631, 1023], "vertical": true, "font_size": 27.0, "lines": ["うん。"]}], "img_path": "081.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [727, 83, 775, 160], "vertical": true, "font_size": 23.0, "lines": ["うれしい", "なー。"]}, {"box": [599, 78, 675, 225], "vertical": true, "font_size": 23.0, "lines": ["西片が", "相合い傘誘って", "くれるなんて。"]}, {"box": [169, 97, 197, 140], "vertical": true, "font_size": 28.0, "lines": ["な！！"]}, {"box": [686, 462, 733, 576], "vertical": true, "font_size": 18.0, "lines": ["そんなんじゃ", "ないから．．．"]}, {"box": [206, 475, 256, 600], "vertical": true, "font_size": 23.0, "lines": ["あはは、", "コメンゴメン。"]}, {"box": [756, 778, 803, 891], "vertical": true, "font_size": 23.0, "lines": ["からかっちゃ", "ダメだよね。"]}, {"box": [610, 787, 720, 887], "vertical": true, "font_size": 23.0, "lines": ["親切で", "戻ってきて", "くれたん", "だもん"]}, {"box": [386, 767, 469, 904], "vertical": true, "font_size": 23.0, "lines": ["肩のとこ", "ちょっと濡れて", "るの、"]}, {"box": [104, 802, 186, 994], "vertical": true, "font_size": 23.0, "lines": ["途中で心配して", "戻ってきてくれたって", "ことでしょ？"]}], "img_path": "082.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [688, 83, 739, 146], "vertic