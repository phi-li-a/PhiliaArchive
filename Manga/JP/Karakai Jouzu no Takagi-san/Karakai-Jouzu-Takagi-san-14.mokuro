 20.0, "lines": ["そうだ。"]}, {"box": [96, 540, 123, 592], "vertical": true, "font_size": 27.0, "lines": ["えっ。"]}, {"box": [741, 821, 808, 916], "vertical": true, "font_size": 32.0, "lines": ["今日の", "下校時．．"]}, {"box": [667, 850, 693, 924], "vertical": true, "font_size": 32.0, "lines": ["オレは、"]}, {"box": [178, 861, 235, 956], "vertical": true, "font_size": 24.0, "lines": ["北条に", "告白する。"]}], "img_path": "086.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [720, 101, 748, 148], "vertical": true, "font_size": 26.0, "lines": ["こ．．．"]}, {"box": [434, 104, 454, 169], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．？"]}, {"box": [285, 118, 340, 232], "vertical": true, "font_size": 25.0, "lines": ["オレが", "告白したら、"]}, {"box": [729, 381, 746, 450], "vertical": true, "font_size": 17.0, "lines": ["そうか．．．"]}, {"box": [434, 389, 460, 438], "vertical": true, "font_size": 26.0, "lines": ["あぁ。"]}, {"box": [101, 268, 162, 375], "vertical": true, "font_size": 25.0, "lines": ["お前たちも", "しろ。"]}, {"box": [673, 687, 706, 735], "vertical": true, "font_size": 32.0, "lines": ["は！？"]}, {"box": [144, 656, 224, 771], "vertical": true, "font_size": 26.0, "lines": ["いや．．．", "何言ってんだ", "お前．．．"]}, {"box": [665, 924, 728, 1051], "vertical": true, "font_size": 30.0, "lines": ["西片は", "高木さんに、"]}, {"box": [114, 922, 182, 1039], "vertical": true, "font_size": 30.0, "lines": ["高尾は", "月本にだ！"]}], "img_path": "087.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [774, 38, 811, 94], "vertical": true, "font_size": 32.0, "lines": ["高．．．"]}, {"box": [679, 39, 709, 113], "vertical": true, "font_size": 32.0, "lines": ["告．．．？"]}, {"box": [526, 56, 631, 162], "vertical": true, "font_size": 21.0, "lines": ["お前らが", "その二人を", "好きなのは", "バレバレだ。"]}, {"box": [175, 71, 203, 132], "vertical": true, "font_size": 26.0, "lines": ["ええ！？"]}, {"box": [701, 458, 752, 556], "vertical": true, "font_size": 21.0, "lines": ["オレが告白", "したら、"]}, {"box": [623, 459, 666, 555], "vertical": true, "font_size": 21.0, "lines": ["お前たちも", "告白しろ！！"]}, {"box": [452, 460, 500, 557], "vertical": true, "font_size": 21.0, "lines": ["なんで", "そうなる！！"]}, {"box": [361, 468, 394, 567], "vertical": true, "font_size": 25.0, "lines": ["一人だと、"]}, {"box": [106, 493, 166, 575], "vertical": true, "font_size": 28.0, "lines": ["こわい", "からだ。"]}, {"box": [269, 881, 317, 959], "vertical": true, "font_size": 22.0, "lines": ["な．．．", "泣いてる。"]}], "img_path": "088.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [633, 63, 712, 169], "vertical": true, "font_size": 25.0, "lines": ["お前．．．", "ホント", "ヘタレだな。"]}, {"box": [222, 80, 272, 160], "vertical": true, "font_size": 24.0, "lines": ["うるせえ", "高尾！！"]}, {"box": [343, 335, 362, 410], "vertical": true, "font_size": 16.0, "lines": ["オレカ．．．"]}, {"box": [77, 571, 132, 667], "vertical": true, "font_size": 20.0, "lines": ["高木さんに", "告白．．．？"]}, {"box": [92, 762, 113, 835], "vertical": true, "font_size": 20.0, "lines": ["でねー．．．"]}, {"box": [673, 948, 722, 1032], "vertical": true, "font_size": 22.0, "lines": ["いやいや、", "ないない。"]}, {"box": [139, 944, 221, 1059], "vertical": true, "font_size": 22.0, "lines": ["だって別に", "好きとかじゃ", "ないし。"]}], "img_path": "089.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [781, 97, 803, 207], "vertical": true, "font_size": 21.0, "lines": ["バレバレだ！！"]}, {"box": [541, 105, 615, 315], "vertical": true, "font_size": 22.0, "lines": ["でももしかして", "周りからは", "そう思われてるのか．．．？"]}, {"box": [433, 105, 495, 316], "vertical": true, "font_size": 29.0, "lines": ["もしかして．．．", "自覚がないだけで、"]}, {"box": [243, 56, 268, 119], "vertical": true, "font_size": 25.0, "lines": ["ねぇ．．．"]}, {"box": [102, 104, 167, 322], "vertical": true, "font_size": 31.0, "lines": ["オレは．．．", "高木さんのことを．．．"]}, {"box": [112, 424, 143, 475], "vertical": true, "font_size": 27.0, "lines": ["．．．片"]}, {"box": [680, 603, 723, 666], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [728, 844, 754, 923], "vertical": true, "font_size": 20.0, "lines": ["な．．．何？"]}, {"box": [432, 857, 464, 921], "vertical": true, "font_size": 26.0, "lines": ["好き？"]}, {"box": [192, 601, 229, 648], "vertical": true, "font_size": 29.0, "lines": ["わ。"]}], "img_path": "090.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [428, 58, 503, 193], "vertical": true, "font_size": 22.0, "lines": ["いや！！", "全然そんなコト", "ないよ！！"]}, {"box": [87, 119, 110, 216], "vertical": true, "font_size": 20.0, "lines": ["そうなの？"]}, {"box": [674, 578, 749, 700], "vertical": true, "font_size": 21.0, "lines": ["ピザまん", "好きって", "言ってたから、"]}, {"box": [358, 577, 429, 718], "vertical": true, "font_size": 19.0, "lines": ["カレーまんも", "好きかと", "思ったんだけど。"]}, {"box": [700, 945, 750, 1071], "vertical": true, "font_size": 22.0, "lines": ["あぁ、", "カレーまんか。"]}, {"box": [598, 953, 645, 1050], "vertical": true, "font_size": 22.0, "lines": ["カレーまん", "好きだよ。"]}, {"box": [128, 959, 152, 1003], "vertical": true, "font_size": 24.0, "lines": ["ん？"]}], "img_path": "091.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [433, 132, 485, 248], "vertical": true, "font_size": 20.0, "lines": ["なんの話だと", "思ってたの？"]}, {"box": [335, 135, 363, 175], "vertical": true, "font_size": 28.0, "lines": ["あ。"]}, {"box": [654, 679, 709, 746], "vertical": true, "font_size": 30.0, "lines": ["いや．．．", "別に．．．"]}, {"box": [217, 663, 265, 791], "vertical": true, "font_size": 22.0, "lines": ["えー", "気になるなぁ。"]}, {"box": [667, 931, 741, 1065], "vertical": true, "font_size": 20.0, "lines": ["なんかボーっと", "してるなって", "思ってたし、"]}, {"box": [453, 948, 528, 1066], "vertical": true, "font_size": 22.0, "lines": ["ずっと", "そのこと", "考えてたの？"]}, {"box": [394, 936, 417, 992], "vertical": true, "font_size": 23.0, "lines": ["いや．．．"]}, {"box": [234, 943, 255, 1003], "vertical": true, "font_size": 21.0, "lines": ["んー？"]}], "img_path": "092.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [371, 59, 453, 214], "vertical": true, "font_size": 22.0, "lines": ["全然そんなんじゃ", "ないって言ってた", "けど、"]}, {"box": [485, 239, 552, 328], "vertical": true, "font_size": 18.0, "lines": ["ここは", "ダンマリを", "きめこむ！"]}, {"box": [680, 232, 752, 382], "vertical": true, "font_size": 19.0, "lines": ["嘘をついても", "見やぶられて", "不利になりそうだ．．．"]}, {"box": [398, 506, 450, 642], "vertical": true, "font_size": 22.0, "lines": ["好きでは", "ないってこと？"]}, {"box": [324, 493, 342, 555], "vertical": true, "font_size": 18.0, "lines": ["．．．"]}, {"box": [98, 503, 172, 657], "vertical": true, "font_size": 20.0, "lines": ["なんのことか", "わかんないのに、", "聞く意味ある．．．？"]}, {"box": [682, 806, 738, 962], "vertical": true, "font_size": 26.0, "lines": ["推測しようかなー", "って。"]}, {"box": [360, 831, 380, 896], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．？"]}, {"box": [270, 853, 291, 968], "vertical": true, "font_size": 20.0, "lines": ["キライなの？"]}], "img_path": "093.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [624, 116, 706, 198], "vertical": true, "font_size": 27.0, "lines": ["そんな", "ことは．．．", "ない．．．"]}, {"box": [555, 135, 581, 198], "vertical": true, "font_size": 27.0, "lines": ["かな．．．"]}, {"box": [378, 131, 429, 199], "vertical": true, "font_size": 23.0, "lines": ["好きか", "キライ、"]}, {"box": [323, 125, 344, 261], "vertical": true, "font_size": 23.0, "lines": ["どっちかなら？"]}, {"box": [140, 390, 159, 457], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．？"]}, {"box": [674, 692, 749, 827], "vertical": true, "font_size": 23.0, "lines": ["どっちかなら．．．", "キライじゃ", "ない方．．．"]}, {"box": [605, 707, 631, 769], "vertical": true, "font_size": 23.0, "lines": ["かな．．．"]}, {"box": [371, 689, 395, 758], "vertical": true, "font_size": 24.0, "lines": ["ふーん。"]}, {"box": [124, 690, 148, 813], "vertical": true, "font_size": 20.0, "lines": ["好きなんだー。"]}], "img_path": "094.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [310, 104, 363, 216], "vertical": true, "font_size": 20.0, "lines"