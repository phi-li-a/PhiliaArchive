0, "lines": ["長かった．．．"]}, {"box": [622, 787, 793, 946], "vertical": true, "font_size": 32.0, "lines": ["高木さんに", "からかわれ", "続けた", "この人生．．"]}, {"box": [226, 823, 312, 978], "vertical": true, "font_size": 32.0, "lines": ["それが今日", "終わる．．"]}, {"box": [1038, 1374, 1209, 1588], "vertical": true, "font_size": 29.0, "lines": ["今までも何度か", "こういうことは", "言ってた気が", "するけど、"]}, {"box": [650, 1389, 739, 1558], "vertical": true, "font_size": 32.0, "lines": ["今日は", "間違いない。"]}, {"box": [530, 1392, 575, 1530], "vertical": true, "font_size": 32.0, "lines": ["高木さん。"]}, {"box": [163, 1396, 251, 1509], "vertical": true, "font_size": 32.0, "lines": ["あ、", "そうだ、"]}, {"box": [157, 1582, 202, 1663], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}], "img_path": "107.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1095, 101, 1265, 316], "vertical": true, "font_size": 32.0, "lines": ["今日ちょっと", "すみれちゃんと", "話すこと", "あるから、"]}, {"box": [592, 195, 684, 398], "vertical": true, "font_size": 32.0, "lines": ["先生", "帰っといてよ。"]}, {"box": [408, 135, 459, 217], "vertical": true, "font_size": 32.0, "lines": ["え！？"]}, {"box": [1138, 1006, 1177, 1108], "vertical": true, "font_size": 32.0, "lines": ["あれ？"]}, {"box": [590, 1059, 710, 1215], "vertical": true, "font_size": 32.0, "lines": ["もしかしていい", "一緒に帰り", "たかった？"]}, {"box": [159, 982, 236, 1194], "vertical": true, "font_size": 32.0, "lines": ["そういうんじゃ", "ないから！！"]}, {"box": [1108, 1426, 1192, 1643], "vertical": true, "font_size": 32.0, "lines": ["神社で", "待っとくから！！"]}, {"box": [536, 1425, 607, 1580], "vertical": true, "font_size": 32.0, "lines": ["うん", "わかったー。"]}], "img_path": "108.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [675, 120, 710, 202], "vertical": true, "font_size": 32.0, "lines": ["はー。"]}, {"box": [673, 384, 761, 425], "vertical": false, "font_size": 32.0, "lines": ["賽銭"]}, {"box": [127, 121, 212, 273], "vertical": true, "font_size": 32.0, "lines": ["こんな日に", "限って．．．"]}, {"box": [1113, 858, 1192, 1046], "vertical": true, "font_size": 32.0, "lines": ["でも、なんと", "しても今日．．．"]}, {"box": [1114, 862, 1187, 1043], "vertical": true, "font_size": 32.0, "lines": ["でも、なんとしても今日．．．"]}, {"box": [982, 860, 1011, 934], "vertical": true, "font_size": 29.0, "lines": ["そう"]}, {"box": [975, 856, 1018, 941], "vertical": true, "font_size": 32.0, "lines": ["そう。"]}, {"box": [230, 849, 361, 1070], "vertical": true, "font_size": 32.0, "lines": ["勝負は．．．", "今日じゃなきゃ", "ダメなんだ。"]}, {"box": [1130, 1437, 1173, 1617], "vertical": true, "font_size": 32.0, "lines": ["「６時までに」"]}, {"box": [159, 1404, 335, 1638], "vertical": true, "font_size": 32.0, "lines": ["「ここにお参りに", "来る人がいるか", "いないか」の", "勝負．．．"]}], "img_path": "109.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1044, 163, 1160, 405], "vertical": true, "font_size": 30.0, "lines": ["ここへは", "お参りに来る人は", "ほとんどいない。"]}, {"box": [828, 161, 902, 375], "vertical": true, "font_size": 30.0, "lines": ["それを知ってる", "高木さんは"]}, {"box": [375, 174, 461, 333], "vertical": true, "font_size": 32.0, "lines": ["「いない」の", "方で。"]}, {"box": [193, 365, 285, 493], "vertical": true, "font_size": 32.0, "lines": ["と答える", "だろう。"]}, {"box": [1112, 761, 1188, 911], "vertical": true, "font_size": 29.0, "lines": ["いるんだな", "これが"]}, {"box": [387, 765, 555, 1010], "vertical": true, "font_size": 31.0, "lines": ["夕方おつかいする", "時にたまに", "見かけていた", "おじいちゃん。"]}, {"box": [1179, 1466, 1253, 1648], "vertical": true, "font_size": 30.0, "lines": ["めずらしいな", "と思って、"]}, {"box": [688, 1458, 802, 1682], "vertical": true, "font_size": 26.0, "lines": ["なんとなく", "見かけた日を", "メモしていたら、"]}, {"box": [138, 1445, 300, 1717], "vertical": true, "font_size": 30.0, "lines": ["かならず", "１１日の夕方だと", "決まっていることが", "わかったのさ。"]}], "img_path": "110.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [948, 135, 1034, 354], "vertical": true, "font_size": 32.0, "lines": ["つまり今日．．．！！", "１１日．．．！！"]}, {"box": [238, 153, 362, 366], "vertical": true, "font_size": 32.0, "lines": ["お参りの", "おじいちゃんは", "来る．．．！！"]}, {"box": [1136, 986, 1168, 1170], "vertical": true, "font_size": 32.0, "lines": ["くつくっく．．．"]}, {"box": [605, 969, 744, 1190], "vertical": true, "font_size": 32.0, "lines": ["偶然とはいえ", "オレが見つけた", "法則．．．"]}, {"box": [436, 969, 568, 1170], "vertical": true, "font_size": 32.0, "lines": ["どんな顔で", "くやしがるのか", "楽し．．．．．．"]}, {"box": [153, 994, 180, 1094], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．？"]}, {"box": [1125, 1450, 1174, 1648], "vertical": true, "font_size": 32.0, "lines": ["高木さんが、"]}, {"box": [215, 1449, 362, 1671], "vertical": true, "font_size": 32.0, "lines": ["「いる」の方に", "したら．．．", "どうしよう．．．"]}], "img_path": "111.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1178, 93, 1288, 262], "vertical": true, "font_size": 30.0, "lines": ["ヤバイ．．．", "それを考えて", "なかった．．．！！"]}, {"box": [980, 84, 1059, 315], "vertical": true, "font_size": 31.0, "lines": ["高木さんのことだ", "十分にありえる．．．"]}, {"box": [731, 90, 879, 350], "vertical": true, "font_size": 32.0, "lines": ["いや、しかし．．．", "選ぶ確率は", "まぁ２０％くらいだろ、", "８０％で勝てるんだ。"]}, {"box": [148, 142, 309, 328], "vertical": true, "font_size": 32.0, "lines": ["それでも", "いつもよりは", "かなり高い", "確率だぞ。"]}, {"box": [170, 442, 204, 517], "vertical": true, "font_size": 32.0, "lines": ["うん"]}, {"box": [922, 813, 1031, 949], "vertical": true, "font_size": 32.0, "lines": ["どうした？", "悩みごと", "かね？"]}, {"box": [1149, 1336, 1185, 1464], "vertical": true, "font_size": 32.0, "lines": ["そーかー。"]}, {"box": [226, 937, 375, 1080], "vertical": true, "font_size": 32.0, "lines": ["あ、いえ、", "考えごとを", "してた", "だけです。"]}, {"box": [603, 1361, 632, 1535], "vertical": true, "font_size": 27.0, "lines": ["がんばってなー。"]}, {"box": [202, 1449, 249, 1533], "vertical": true, "font_size": 32.0, "lines": ["はい。"]}], "img_path": "112.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [761, 133, 791, 321], "vertical": true, "font_size": 26.0, "lines": ["おじいちゃん"]}, {"box": [133, 183, 221, 352], "vertical": true, "font_size": 32.0, "lines": ["今日お参り", "早いなぁあ。"]}, {"box": [1018, 830, 1179, 965], "vertical": true, "font_size": 32.0, "lines": ["すべての", "計画が．．．", "終わって", "しまった。"]}, {"box": [538, 836, 579, 960], "vertical": true, "font_size": 32.0, "lines": ["ハァー．．．"]}, {"box": [333, 836, 466, 961], "vertical": true, "font_size": 32.0, "lines": ["今日も．．．", "勝てない", "のかぁ。"]}, {"box": [144, 1561, 219, 1745], "vertical": true, "font_size": 32.0, "lines": ["まずい。"]}], "img_path": "113.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1048, 213, 1175, 378], "vertical": true, "font_size": 32.0, "lines": ["今この", "作戦がない．．．", "状態で、"]}, {"box": [853, 217, 980, 406], "vertical": true, "font_size": 32.0, "lines": ["高木さんが", "来てしまった", "ら、"]}, {"box": [230, 204, 442, 455], "vertical": true, "font_size": 32.0, "lines": ["高木さんと", "帰りたくて", "神社で待っている", "だけの男になって", "しまう．．．！！"]}, {"box": [1070, 800, 1211, 964], "vertical": true, "font_size": 32.0, "lines": ["何か．．．", "何か作戦は", "ないか．．．"]}, {"box": [699, 794, 772, 1070], "vertical": true, "font_size": 32.0, "lines": ["どうせなら", "勝てそうなものを："]}, {"box": [540, 800, 623, 954], "vertical": true, "font_size": 26.0, "lines": ["遠投なんて", "どうだ！？"]}, {"box": [1027, 1396, 1182, 1629], "vertical": true, "font_size": 32.0, "lines": ["いや．．．ダメだ。", "絶対息ふきかけ", "られたりする"]}, {"box": [410, 1377, 451, 1530], "vertical": true, "font_size": 32.0, "lines": ["鬼ごっこ．．．"]}], "img_path": "114.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [992, 268, 1155, 483], "vertical": true, "font_size": 32.0, "lines": ["いや．．．", "からかってきて", "タッチさせなさ", "そうだな．．．"]}, {"box": [605, 157, 699, 349], "vertical": true, "font_size": 32.0, "lines": ["へんなとこざわらないでね"]}, {"box": [125, 78, 596, 121], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [165, 255, 249, 361], "vertical": true, "font_size": 32.0, "lines": ["これも", "ダメ。"]}, {"box": [1130, 840, 1176, 1027], "vertical": true, "font_size": 32.0, "lines": ["走り幅飛び！！"]}, {"box": [699, 840, 774, 1052], "vertical": true, "font_size": 29.0, "lines": ["なんだかんだで", "負けそう！！"]}, {"box": [547, 840, 636, 997], "vertical": true, "font_size": 32.0, "lines": ["運まかせの", "すごろく！！"]}, {"box": [195, 828, 273, 954], "vertical": true, "font_size": 32.0, "lines": ["どこに", "あるの？"]}, {"box": [88, 1110, 170, 1268], "vertical": true, "font_size": 32.0, "lines": ["持って", "なかった！！"]}, {"box": [1046, 1515, 1082, 1625], "vertical": true, "font_size": 32.0, "lines": ["うーん。"]}, {"box": [363, 1573, 453, 1749], "vertical": true, "font_size": 32.0, "lines": ["何か．．．だ", "何かないか。"]}], "img_path": "115.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [992, 106, 1025, 244], "vertical": true, "font_size": 31.0, "lines": ["にしかた。"]}, {"box": [440, 206, 474, 374], "vertical": true, "font_size": 32.0, "lines": ["にーしかた。"]}, {"box": [211, 442, 251, 541], "vertical": true, "font_size": 32.0, "lines": ["ん．．．？"]}, {"box": [440, 1282, 489, 1338], "vertical": true, "font_size": 32.0, "lines": ["あ、"]}, {"box": [316, 1318, 358, 1426], "vertical": true, "font_size": 32.0, "lines": ["起きた。"]}], "img_path": "116.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1014, 127, 1108, 283], "vertical": true, "font_size": 32.0, "lines": ["遅くなって", "ゴメン。"]}, {"box": [635, 123, 680, 315], "vertical": true, "font_size": 32.0, "lines": ["よく寝てたね。"]}, {"box": [517, 142, 560, 215], "vertical": true, "font_size": 32.0, "lines": ["あ．．．"]}, {"box": [99, 177, 192, 332], "vertical": true, "font_size": 32.0, "lines": ["考え疲れて", "寝てた！？"]}, {"box": [1072, 690, 1140, 845], "vertical": true, "font_size": 32.0, "lines": ["い．．．いや", "寝てないし。"]}, {"box": [624, 703, 664, 856], "vertical": true, "font_size": 32.0, "lines": ["寝てたよー。"]}, {"box": [444, 671, 483, 783], "vertical": true, "font_size": 32.0, "lines": ["それで、"]}, {"box": [150, 693, 202, 766], "vertical": true, "font_size": 32.0, "lines": ["何？"]}, {"box": [1145, 1310, 1183, 1378], "vertical": true, "font_size": 32.0, "lines": ["え．．"]}, {"box": [673, 1278, 756, 1526], "vertical": true, "font_size": 32.0, "lines": ["用事あったんじゃ", "なかったの？"]}, {"box": [547, 1301, 588, 1383], "vertical": true, "font_size": 32.0, "lines": ["．．．あ。"]}], "img_path": "117.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1203, 150, 1235, 343], "vertical": true, "font_size": 30.0, "lines": ["あーやっぱり、"]}, {"box": [1040, 170, 1112, 442], "vertical": true, "font_size": 30.0, "lines": ["一緒に帰りたかった", "だけかなー。"]}, {"box": [241, 221, 360, 348], "vertical": true, "font_size": 32.0, "lines": ["それとも", "愛の告白", "とか？"]}, {"box": [1159, 886, 1191, 951], "vertical": true, "font_size": 32.0, "lines": ["ぐ．．．"]}, {"box": [603, 885, 692, 1050], "vertical": true, "font_size": 32.0, "lines": ["ち．．．ちが", "違うって．．．"]}, {"box": [352, 890, 484, 1078], "vertical": true, "font_size": 32.0, "lines": ["その．．．勝負を", "しようと", "思って。"]}, {"box": [187, 962, 266, 1087], "vertical": true, "font_size": 32.0, "lines": ["ふーん、", "なんの？"]}, {"box": [1097, 1522, 1173, 1650], "vertical": true, "font_size": 32.0, "lines": ["えーと．．．", "そう．．．"]}, {"box": [241, 1488, 372, 1736], "vertical": true, "font_size": 32.0, "lines": ["オレが待ってる間", "何を考えてたかを", "当てる勝負。"]}], "img_path": "118.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1155, 118, 1194, 228], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [828, 91, 919, 288], "vertical": true, "font_size": 32.0, "lines": ["何を考え", "てたか、ねぇ。"]}, {"box": [641, 75, 768, 352], "vertical": true, "font_size": 32.0, "lines": ["お、これ思いつきで", "言ったけどけっこう", "いいんじゃないか。"]}, {"box": [80, 155, 255, 341], "vertical": true, "font_size": 32.0, "lines": ["考えてたのは", "高木さんとの", "勝負のこと", "だけど、"]}, {"box": [538, 463, 776, 781], "vertical": true, "font_size": 32.0, "lines": ["もし自分でそう答えて、", "間違ったらちょっと", "ハズかしいし、", "やりづらい", "だろ．．．"]}, {"box": [277, 472, 320, 552], "vertical": true, "font_size": 32.0, "lines": ["んー。"]}, {"box": [73, 487, 195, 673], "vertical": true, "font_size": 31.0, "lines": ["ここに来て", "オレはなんて", "ナイスなんだ"]}, {"box": [532, 1072, 583, 1224], "vertical": true, "font_size": 32.0, "lines": ["私のこと。"]}, {"box": [356, 1038, 395, 1153], "vertical": true, "font_size": 32.0, "lines": ["なあ！！"]}], "img_path": "119.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [992, 129, 1083, 241], "vertical": true, "font_size": 32.0, "lines": ["せ．．．せかい", "正解．．．"]}, {"box": [510, 75, 655, 356], "vertical": true, "font_size": 31.0, "lines": ["なんかよけいに", "オレが高木さん", "待ってただけみたいに", "なってしまった．．．！！"]}, {"box": [992, 1376, 1108, 1531], "vertical": true, "font_size": 32.0, "lines": ["ねーどっか", "寄り道して", "帰ろっか。"]}, {"box": [459, 1363, 534, 1517], "vertical": true, "font_size": 30.0, "lines": ["え、もう", "夕方だよ．．．"]}, {"box": [256, 1533, 338, 1727], "vertical": true, "font_size": 26.0, "lines": ["負けたんだし", "つきあってよ。"]}], "img_path": "120.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [140, 159, 530, 354], "vertical": false, "font_size": 32.0, "lines": ["生写"]}], "img_path": "121.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1067, 200, 1235, 390], "vertical": true, "font_size": 32.0, "lines": ["はーい、", "じゃあ今日は", "前に言ってた", "通り、"]}, {"box": [288, 210, 375, 412], "vertical": true, "font_size": 32.0, "lines": ["全校生じゃせいた", "写生大会です。"]}, {"box": [1020, 1044, 1177, 1216], "vertical": true, "font_size": 32.0, "lines": ["各自校内で", "好きな場所を", "写生してくる", "ことー。"]}, {"box": [189, 1046, 380, 1231], "vertical": true, "font_size": 32.0, "lines": ["まぁできれば", "思い出のある", "場所とかが", "いいかなって", "思うよ。"]}, {"box": [1104, 1441, 1197, 1631], "vertical": true, "font_size": 32.0, "lines": ["思い出のある", "場所．．．"]}, {"box": [703, 1435, 782, 1653], "vertical": true, "font_size": 32.0, "lines": ["はーい、じゃあ", "がんばってー。"]}, {"box": [443, 1626, 484, 1762], "vertical": true, "font_size": 32.0, "lines": ["どこいくーっ！？"]}], "img_path": "122.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1125, 150, 1207, 354], "vertical": true, "font_size": 32.0, "lines": ["じゃあ行って", "こよっかな。"]}, {"box": [571, 136, 702, 352], "vertical": true, "font_size": 32.0, "lines": ["高木さん", "どこで描くか", "決まってるの？"]}, {"box": [480, 186, 515, 262], "vertical": true, "font_size": 32.0, "lines": ["うん、"]}, {"box": [63, 200, 107, 400], "vertical": true, "font_size": 32.0, "lines": ["決まってるよ。"]}, {"box": [986, 864, 1014, 1015], "vertical": true, "font_size": 26.0, "lines": ["じゃーねー。"]}, {"box": [680, 863, 745, 1015], "vertical": true, "font_size": 27.0, "lines": ["どこだろ．．．"]}, {"box": [573, 886, 620, 1012], "vertical": true, "font_size": 32.0, "lines": ["中井君！！"]}, {"box": [1035, 1455, 1112, 1606], "vertical": true, "font_size": 32.0, "lines": ["あそこ行こ", "あそこ！！"]}, {"box": [922, 1455, 956, 1612], "vertical": true, "font_size": 32.0, "lines": ["思い出の！"]}, {"box": [414, 1455, 448, 1556], "vertical": true, "font_size": 32.0, "lines": ["どこ？"]}, {"box": [234, 1503, 311, 1749], "vertical": true, "font_size": 32.0, "lines": ["あそこだって、", "わかるでしょー！？"]}], "img_path": "123.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1237, 148, 1275, 348], "vertical": true, "font_size": 32.0, "lines": ["マジでどこ？"]}, {"box": [667, 136, 753, 468], "vertical": true, "font_size": 32.0, "lines": ["体育館裏ぁ！！"]}, {"box": [1040, 1025, 1162, 1239], "vertical": true, "font_size": 32.0, "lines": ["入学式で", "初めて会った", "場所でしょー！！"]}, {"box": [894, 1072, 926, 1228], "vertical": true, "font_size": 32.0, "lines": ["思い出の！！"]}, {"box": [564, 1050, 648, 1249], "vertical": true, "font_size": 30.0, "lines": ["真野はよく", "覚えてるなー。"]}, {"box": [285, 1068, 415, 1284], "vertical": true, "font_size": 32.0, "lines": ["中井君が", "覚えてないダケ", "だから！"]}, {"box": [1168, 1386, 1194, 1524], "vertical": true, "font_size": 26.0, "lines": ["そーかー？"]}, {"box": [992, 1402, 1065, 1528], "vertical": true, "font_size": 32.0, "lines": ["ほらほら", "行くよ！！"]}, {"box": [868, 1429, 891, 1499], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．"]}, {"box": [701, 1423, 789, 1524], "vertical": true, "font_size": 32.0, "lines": ["おーい", "西片。"]}, {"box": [540, 1385, 655, 1584], "vertical": true, "font_size": 31.0, "lines": ["居心地いい", "とこでみんなで", "やろーぜー。"]}, {"box": [159, 1393, 235, 1565], "vertical": true, "font_size": 32.0, "lines": ["ダベリながら", "さー。"]}], "img_path": "124.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1093, 183, 1210, 369], "vertical": true, "font_size": 32.0, "lines": ["いやでも各自", "思い出の場所", "って。"]}, {"box": [588, 165, 696, 373], "vertical": true, "font_size": 31.0, "lines": ["いーだろ、", "そんなん", "テキトーでさー。"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [322, 161, 479, 307], "vertical": true, "font_size": 32.0, "lines": ["あ、オレは", "描くもの", "決まってる", "から。"]}, {"box": [170, 157, 217, 339], "vertical": true, "font_size": 32.0, "lines": ["何描くんだ？"]}, {"box": [401, 813, 474, 995], "vertical": true, "font_size": 32.0, "lines": ["自販機。"]}, {"box": [1012, 1391, 1198, 1614], "vertical": true, "font_size": 32.0, "lines": ["カロリーの", "足りない時に", "彼はいつも", "そこにいてオレを", "支えてくれた。"]}, {"box": [757, 1398, 801, 1539], "vertical": true, "font_size": 32.0, "lines": ["思い出さ。"]}, {"box": [536, 1408, 616, 1577], "vertical": true, "font_size": 32.0, "lines": ["そうか、", "もう行けよ。"]}, {"box": [354, 1374, 466, 1563], "vertical": true, "font_size": 32.0, "lines": ["じゃあオレたち", "だけで行くか", "西片。"]}, {"box": [120, 1374, 245, 1518], "vertical": true, "font_size": 32.0, "lines": ["ねー", "サナエ", "ちゃーん。"]}], "img_path": "125.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1104, 99, 1220, 315], "vertical": true, "font_size": 32.0, "lines": ["サナエちゃんは", "陸上部のあたり", "描くのー？"]}, {"box": [648, 198, 780, 328], "vertical": true, "font_size": 32.0, "lines": ["別に、", "どこでも", "いい。"]}, {"box": [446, 97, 555, 332], "vertical": true, "font_size": 30.0, "lines": ["あ、じゃあさー", "屋上行こーよ！！", "みんなで空描こー。"]}, {"box": [176, 185, 215, 294], "vertical": true, "font_size": 32.0, "lines": ["いいよ。"]}, {"box": [1111, 778, 1192, 974], "vertical": true, "font_size": 32.0, "lines": ["ほら、行こー", "ユカリちゃん。"]}, {"box": [881, 523, 902, 631], "vertical": true, "font_size": 21.0, "lines": ["まぁまぁ"]}, {"box": [691, 778, 813, 1070], "vertical": true, "font_size": 32.0, "lines": ["ええ．．．", "私別に屋上に", "思い出ないんだけど。"]}, {"box": [583, 776, 613, 950], "vertical": true, "font_size": 26.0, "lines": ["ユカリちゃん。"]}, {"box": [391, 1314, 566, 1531], "vertical": true, "font_size": 32.0, "lines": ["思いつきで", "深そうな言葉", "ドヤ顔で言うの", "やめな。"]}, {"box": [1156, 1321, 1199, 1575], "vertical": true, "font_size": 27.0, "lines": ["思い出がないなら、"]}, {"box": [622, 1336, 740, 1616], "vertical": true, "font_size": 32.0, "lines": ["これから", "思い出にしちゃえば", "いいのさ。"]}, {"box": [202, 1381, 237, 1549], "vertical": true, "font_size": 32.0, "lines": ["えっへへー。"]}], "img_path": "126.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1091, 127, 1185, 269], "vertical": true, "font_size": 32.0, "lines": ["いい空", "描こーね。"]}, {"box": [918, 95, 997, 294], "vertical": true, "font_size": 32.0, "lines": ["まぁ", "テキトーにね。"]}, {"box": [1016, 682, 1143, 838], "vertical": true, "font_size": 32.0, "lines": ["西片、オレ", "屋上行って", "くるわ。"]}, {"box": [628, 658, 746, 879], "vertical": true, "font_size": 29.0, "lines": ["思い出が", "あったんだったわ", "屋上には。"]}, {"box": [313, 706, 348, 841], "vertical": true, "font_size": 32.0, "lines": ["え．．．あぁ、"]}, {"box": [215, 808, 251, 886], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}], "img_path": "127.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "128.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [120, 146, 156, 290], "vertical": true, "font_size": 32.0, "lines": ["うーん．．．"]}, {"box": [403, 958, 491, 1111], "vertical": true, "font_size": 32.0, "lines": ["決まらない", "なー。"]}, {"box": [1052, 1513, 1176, 1672], "vertical": true, "font_size": 32.0, "lines": ["思い出って", "言われても", "なー。"]}, {"box": [350, 1513, 435, 1713], "vertical": true, "font_size": 32.0, "lines": ["オレ、部活も", "やってないし。"]}], "img_path": "129.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [900, 108, 1063, 326], "vertical": true, "font_size": 32.0, "lines": ["そういえば", "高木さん、", "どこで描いてん", "だろ。"]}, {"box": [247, 119, 329, 335], "vertical": true, "font_size": 32.0, "lines": ["見かけなかった", "けど。"]}, {"box": [1077, 658, 1194, 905], "vertical": true, "font_size": 26.0, "lines": ["鷹川さんとどこかで", "キレイな風景でも", "描いてんのかな。"]}, {"box": [611, 702, 637, 775], "vertical": true, "font_size": 26.0, "lines": ["．．．．．"]}, {"box": [575, 990, 650, 1209], "vertical": true, "font_size": 32.0, "lines": ["いや、別にいいか、", "そんなコト。"]}, {"box": [855, 1355, 899, 1507], "vertical": true, "font_size": 32.0, "lines": ["思い出の！！"]}, {"box": [140, 982, 274, 1224], "vertical": true, "font_size": 32.0, "lines": ["なんで高木さんの", "こと考えてるんだ", "オレは。"]}, {"box": [1112, 1357, 1200, 1545], "vertical": true, "font_size": 32.0, "lines": ["初めて会った", "場所でしょ！！"]}], "img_path": "130.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [131, 84, 596, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [898, 892, 1029, 1080], "vertical": true, "font_size": 32.0, "lines": ["この教室", "入るのも", "１年ぶりか："]}], "img_path": "131.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1229, 134, 1268, 190], "vertical": true, "font_size": 32.0, "lines": ["あ、"]}, {"box": [1211, 121, 1286, 206], "vertical": false, "font_size": 32.0, "lines": ["あ、"]}, {"box": [645, 163, 720, 275], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [174, 122, 334, 360], "vertical": true, "font_size": 32.0, "lines": ["高木さん！？"]}, {"box": [693, 1584, 832, 1773], "vertical": true, "font_size": 32.0, "lines": ["西片も", "ここに描きに", "来たの？"]}, {"box": [595, 1590, 622, 1692], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．．"]}], "img_path": "132.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [759, 99, 806, 178], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [607, 116, 688, 268], "vertical": true, "font_size": 32.0, "lines": ["い．．．いや", "なんでも．．．"]}, {"box": [1082, 682, 1200, 881], "vertical": true, "font_size": 32.0, "lines": ["邪魔そうだし．．．", "別の場所", "行くよ。"]}, {"box": [896, 665, 1003, 843], "vertical": true, "font_size": 28.0, "lines": ["ん？いいよ、", "西片も描きに", "来たんでしょ。"]}, {"box": [511, 690, 600, 829], "vertical": true, "font_size": 32.0, "lines": ["一緒に", "描こうよ。"]}], "img_path": "133.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1262, 80, 1301, 185], "vertical": true, "font_size": 32.0, "lines": ["それで、"]}, {"box": [1132, 88, 1203, 262], "vertical": true, "font_size": 32.0, "lines": ["なんでここに", "したの？"]}, {"box": [797, 63, 877, 230], "vertical": true, "font_size": 32.0, "lines": ["１年生の時の", "教室に。"]}, {"box": [661, 112, 695, 264], "vertical": true, "font_size": 32.0, "lines": ["い．．．いや．．．"]}, {"box": [153, 106, 235, 292], "vertical": true, "font_size": 32.0, "lines": ["なんでって．．．", "その．．．"]}, {"box": [1076, 828, 1158, 963], "vertical": true, "font_size": 32.0, "lines": ["適当だよ、", "適当。"]}, {"box": [213, 893, 250, 1001], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [965, 1018, 1151, 1284], "vertical": true, "font_size": 32.0, "lines": ["校内グルっと", "回ったけど", "いいとこが", "なかったから．．．", "ここでいいかなって。"]}, {"box": [1038, 1398, 1196, 1612], "vertical": true, "font_size": 31.0, "lines": ["てっきりここに", "思い出を", "感じてるのかと", "思ったよ。"]}, {"box": [618, 1400, 649, 1591], "vertical": true, "font_size": 26.0, "lines": ["いやぃやいや。"]}, {"box": [145, 1396, 269, 1610], "vertical": true, "font_size": 28.0, "lines": ["見慣れてるから", "描きやすいと", "思ったんだよ！"]}], "img_path": "134.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1108, 225, 1190, 333], "vertical": true, "font_size": 32.0, "lines": ["ホント", "かなー。"]}, {"box": [737, 221, 825, 339], "vertical": true, "font_size": 32.0, "lines": ["ホント", "だって。"]}, {"box": [547, 159, 675, 376], "vertical": true, "font_size": 32.0, "lines": ["．．．高木さんは．．．", "なんで", "ここなの．．．？"]}, {"box": [127, 80, 600, 121], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [650, 1018, 707, 1115], "vertical": true, "font_size": 32.0, "lines": ["んー。"]}], "img_path": "135.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [628, 191, 717, 388], "vertical": true, "font_size": 32.0, "lines": ["たぶん西片と", "同じ理由かな。"]}, {"box": [1003, 1464, 1119, 1653], "vertical": true, "font_size": 32.0, "lines": ["じゃ．．．じゃあ", "テキトーって", "ことだね．．．"]}, {"box": [371, 1492, 444, 1658], "vertical": true, "font_size": 30.0, "lines": ["あはは、", "そうかもね。"]}], "img_path": "136.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [150, 1633, 845, 1758], "vertical": false, "font_size": 32.0, "lines": ["イなも", "キ"]}], "img_path": "137.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1064, 34, 1201, 393], "vertical": true, "font_size": 32.0, "lines": ["カシャ"]}, {"box": [270, 1108, 440, 1143], "vertical": false, "font_size": 32.0, "lines": ["１位いい雲"]}, {"box": [255, 1155, 343, 1351], "vertical": true, "font_size": 32.0, "lines": ["２０１３年生"]}, {"box": [331, 1171, 496, 1205], "vertical": false, "font_size": 32.0, "lines": ["しかきごおり"]}, {"box": [270, 1222, 560, 1393], "vertical": false, "font_size": 32.0, "lines": ["走ってるネコ", "立－氷の入った麦茶", "５位、てんとう虫"]}, {"box": [506, 980, 638, 1140], "vertical": true, "font_size": 32.0, "lines": ["今のところ", "５位って", "とこかな。"]}, {"box": [1065, 976, 1192, 1119], "vertical": true, "font_size": 32.0, "lines": ["うん、", "いいのが", "撮れたぞ。"]}, {"box": [541, 1550, 595, 1638], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}], "img_path": "138.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [469, 110, 595, 354], "vertical": true, "font_size": 30.0, "lines": ["夏休みの", "自由研究してるん", "だってね。"]}, {"box": [84, 122, 129, 260], "vertical": true, "font_size": 32.0, "lines": ["高木さん。"]}, {"box": [178, 915, 232, 1003], "vertical": true, "font_size": 32.0, "lines": ["へー。"]}, {"box": [637, 881, 799, 1110], "vertical": true, "font_size": 32.0, "lines": ["キレイなもの", "ランキング", "つくろうかなって", "思って。"]}, {"box": [148, 1098, 245, 1239], "vertical": true, "font_size": 32.0, "lines": ["楽しそう", "だね。"]}, {"box": [1091, 1459, 1206, 1655], "vertical": true, "font_size": 32.0, "lines": ["あ、じゃあ私も", "一緒に探して", "いい？"]}, {"box": [618, 1479, 698, 1695], "vertical": true, "font_size": 32.0, "lines": ["いいのあったら", "使ってよ。"]}], "img_path": "139.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1100, 90, 1158, 157], "vertical": true, "font_size": 32.0, "lines": ["ふ。"]}, {"box": [917, 82, 995, 238], "vertical": true, "font_size": 32.0, "lines": ["いや、まぁ", "いいけど。"]}, {"box": [211, 116, 291, 284], "vertical": true, "font_size": 30.0, "lines": ["撮れるかな", "高木さんに。"]}, {"box": [954, 603, 1160, 913], "vertical": true, "font_size": 32.0, "lines": ["オレはこれを", "やるにあたって", "自分の感性に", "絶対ウソはつかないと", "決めたからね。"]}, {"box": [459, 658, 573, 813], "vertical": true, "font_size": 31.0, "lines": ["ちょっとや", "そっとの", "ものじゃ．．．"]}, {"box": [170, 594, 290, 807], "vertical": true, "font_size": 32.0, "lines": ["これ、ここに", "来る間に", "撮ったんだけど、"]}, {"box": [1168, 1263, 1253, 1466], "vertical": true, "font_size": 32.0, "lines": ["エサあげてる", "ツバメ。"]}, {"box": [645, 1253, 684, 1366], "vertical": true, "font_size": 32.0, "lines": ["あぁ！！"]}, {"box": [155, 1275, 217, 1411], "vertical": true, "font_size": 32.0, "lines": ["いい！！"]}], "img_path": "140.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [885, 74, 926, 228], "vertical": true, "font_size": 32.0, "lines": ["．．．２位で．．．"]}, {"box": [646, 78, 679, 214], "vertical": true, "font_size": 32.0, "lines": ["やったー。"]}, {"box": [440, 73, 560, 260], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "もっと探して", "くるねー。"]}, {"box": [238, 780, 330, 1020], "vertical": true, "font_size": 32.0, "lines": ["負けるわけには", "いかない．．．！！"]}, {"box": [577, 1455, 697, 1620], "vertical": true, "font_size": 32.0, "lines": ["オレも", "がんばって", "探さないと。"]}], "img_path": "141.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1008, 123, 1052, 195], "vertical": true, "font_size": 32.0, "lines": ["な．．．"]}, {"box": [181, 369, 213, 493], "vertical": true, "font_size": 32.0, "lines": ["これは；"]}, {"box": [1160, 676, 1194, 776], "vertical": true, "font_size": 32.0, "lines": ["どう？"]}, {"box": [518, 669, 545, 769], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．"]}, {"box": [147, 693, 270, 907], "vertical": true, "font_size": 32.0, "lines": ["悔しいけど．．．", "正直にやるって", "決めたしな．．．"]}, {"box": [1059, 1340, 1145, 1528], "vertical": true, "font_size": 32.0, "lines": ["１位と．．．", "３位と４位．．．"]}, {"box": [701, 1318, 735, 1455], "vertical": true, "font_size": 32.0, "lines": ["やったー。"]}], "img_path": "142.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [997, 133, 1117, 331], "vertical": true, "font_size": 32.0, "lines": ["まさかい", "１位まで", "とられるとは"]}, {"box": [247, 135, 365, 409], "vertical": true, "font_size": 32.0, "lines": ["くそ．．．このままでは", "オレのランキングが", "高木さんに．．．"]}, {"box": [692, 682, 723, 784], "vertical": true, "font_size": 31.0, "lines": ["．．．．．．？"]}, {"box": [1044, 1291, 1091, 1423], "vertical": true, "font_size": 32.0, "lines": ["おお！！"]}, {"box": [166, 1404, 214, 1578], "vertical": true, "font_size": 32.0, "lines": ["これは！！"]}], "img_path": "143.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1112, 106, 1181, 354], "vertical": true, "font_size": 32.0, "lines": ["１位ー", "．．．"]}, {"box": [493, 159, 611, 341], "vertical": true, "font_size": 32.0, "lines": ["へーたしかに", "きれいな", "貝がらだね。"]}, {"box": [161, 196, 196, 331], "vertical": true, "font_size": 32.0, "lines": ["ふふーん。"]}, {"box": [290, 877, 331, 928], "vertical": true, "font_size": 32.0, "lines": ["あ。"]}, {"box": [1068, 854, 1188, 1068], "vertical": true, "font_size": 32.0, "lines": ["よかった．．．", "なんとか１位は", "守れたぞ。"]}, {"box": [416, 854, 532, 1066], "vertical": true, "font_size": 32.0, "lines": ["じゃあそろそろ", "終わりに", "しようか。"]}, {"box": [1134, 1410, 1172, 1479], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [498, 1443, 616, 1605], "vertical": true, "font_size": 32.0, "lines": ["何か光った", "みたいに", "見えたから、"]}, {"box": [350, 1503, 423, 1666], "vertical": true, "font_size": 32.0, "lines": ["きれいな", "石とかかも。"]}], "img_path": "144.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [812, 90, 932, 253], "vertical": true, "font_size": 32.0, "lines": ["いやいや、", "悔しいのは", "わかるけど、"]}, {"box": [532, 95, 661, 281], "vertical": true, "font_size": 32.0, "lines": ["これより上は", "なかなか", "ないって。"]}, {"box": [1052, 804, 1132, 967], "vertical": true, "font_size": 32.0, "lines": ["え！！たかぎ", "高木さん！？"]}, {"box": [208, 853, 339, 980], "vertical": true, "font_size": 32.0, "lines": ["大丈夫、", "すぐそこ", "だから。"]}, {"box": [791, 1395, 824, 1563], "vertical": true, "font_size": 32.0, "lines": ["あ、これか。"]}, {"box": [97, 1436, 148, 1610], "vertical": true, "font_size": 32.0, "lines": ["見て、西片。"]}], "img_path": "145.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1023, 168, 1102, 322], "vertical": true, "font_size": 32.0, "lines": ["きれいじゃ", "ない？"]}], "img_path": "146.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [129, 84, 590, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [518, 628, 557, 810], "vertical": true, "font_size": 26.0, "lines": ["何位だった？"]}, {"box": [84, 1014, 116, 1169], "vertical": true, "font_size": 32.0, "lines": ["あ．．．いや．．．"]}], "img_path": "147.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1014, 245, 1099, 397], "vertical": true, "font_size": 30.0, "lines": ["帰ってから", "決めるよ"]}, {"box": [365, 316, 528, 472], "vertical": true, "font_size": 32.0, "lines": ["そっか、", "発表の時の", "お楽しみに", "しとくよ。"]}, {"box": [1183, 987, 1246, 1253], "vertical": true, "font_size": 32.0, "lines": ["自由研究展示"]}], "img_path": "148.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1115, 84, 1205, 341], "vertical": true, "font_size": 32.0, "lines": ["木村、カップメン", "食いすぎだろー。"]}, {"box": [785, 73, 960, 230], "vertical": false, "font_size": 32.0, "lines": ["．．．", "ウップみん", "おいしいもの"]}, {"box": [620, 82, 661, 235], "vertical": true, "font_size": 32.0, "lines": ["楽しかった。"]}, {"box": [436, 75, 534, 238], "vertical": true, "font_size": 32.0, "lines": ["あさがおの", "観察："]}, {"box": [76, 108, 122, 247], "vertical": true, "font_size": 32.0, "lines": ["小学生か。"]}, {"box": [821, 560, 862, 658], "vertical": true, "font_size": 32.0, "lines": ["１００．．．"]}, {"box": [391, 864, 513, 1053], "vertical": true, "font_size": 32.0, "lines": ["もっと", "有意義なこと", "しろよ。"]}, {"box": [69, 508, 102, 649], "vertical": true, "font_size": 32.0, "lines": ["うっさい。"]}, {"box": [1037, 866, 1152, 1072], "vertical": true, "font_size": 30.0, "lines": ["西片のは", "キレイなもの", "ランキングかー。"]}, {"box": [151, 905, 281, 1183], "vertical": true, "font_size": 32.0, "lines": ["ゲームプレイ時間", "ランキングの高尾に", "言われたくない。"]}, {"box": [1091, 1475, 1160, 1663], "vertical": true, "font_size": 29.0, "lines": ["別のクラスも", "見に行こーぜー。"]}, {"box": [673, 1486, 733, 1578], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}], "img_path": "149.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [665, 183, 797, 380], "vertical": true, "font_size": 32.0, "lines": ["最後のやつ、", "１位にして", "くれたんだね。"]}, {"box": [157, 919, 191, 966], "vertical": true, "font_size": 32.0, "lines": ["え"]}, {"box": [1166, 918, 1200, 1084], "vertical": true, "font_size": 28.0, "lines": ["うれしいや。"]}, {"box": [1160, 1385, 1200, 1485], "vertical": true, "font_size": 32.0, "lines": ["あれ？"]}, {"box": [622, 928, 656, 1095], "vertical": true, "font_size": 32.0, "lines": ["いや．．．まぁ。"]}, {"box": [988, 1381, 1108, 1625], "vertical": true, "font_size": 32.0, "lines": ["でもこれ", "１位だけタイトル", "入ってないよ？"]}, {"box": [230, 1443, 275, 1596], "vertical": true, "font_size": 26.0, "lines": ["書き忘れ？"]}], "img_path": "150.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1033, 108, 1198, 324], "vertical": true, "font_size": 32.0, "lines": ["あ、", "もしかして", "１位とられたの", "悔しかった？"]}, {"box": [768, 93, 954, 131], "vertical": false, "font_size": 32.0, "lines": ["「なものランキング"]}, {"box": [592, 115, 712, 301], "vertical": true, "font_size": 32.0, "lines": ["い．．．いや、", "書き忘れだよ", "書き忘れ！"]}, {"box": [403, 91, 489, 193], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "はい。"]}, {"box": [63, 118, 187, 307], "vertical": true, "font_size": 32.0, "lines": ["マジック", "持ってるから", "貸したげる。"]}, {"box": [1128, 793, 1183, 1048], "vertical": true, "font_size": 32.0, "lines": ["あ．．．", "えっと。"]}, {"box": [622, 916, 677, 999], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [984, 1421, 1150, 1645], "vertical": true, "font_size": 32.0, "lines": ["いや．．．もう提出", "しちゃってるし、", "このままで", "いいかなって。"]}, {"box": [538, 1419, 577, 1520], "vertical": true, "font_size": 32.0, "lines": ["あはは、"]}, {"box": [337, 1451, 466, 1582], "vertical": true, "font_size": 32.0, "lines": ["やっぱり", "悔しいの", "かな。"]}, {"box": [46, 1423, 89, 1576], "vertical": true, "font_size": 32.0, "lines": ["違うって．．"]}], "img_path": "151.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1022, 189, 1138, 358], "vertical": true, "font_size": 32.0, "lines": ["あ、そうだ", "私のやつ", "見にきてよ。"]}, {"box": [558, 268, 590, 409], "vertical": true, "font_size": 27.0, "lines": ["あ．．．うん"]}, {"box": [358, 116, 429, 363], "vertical": true, "font_size": 32.0, "lines": ["書かなかったんじゃ", "なくて．．．"]}, {"box": [215, 234, 294, 453], "vertical": true, "font_size": 32.0, "lines": ["書けなかったん", "だ．．．"]}, {"box": [1033, 804, 1162, 1051], "vertical": true, "font_size": 32.0, "lines": ["それで高木さんは", "自由研究", "何したの？"]}, {"box": [307, 787, 385, 1001], "vertical": true, "font_size": 29.0, "lines": ["だってさすがに", "書けないだろ。"]}, {"box": [1048, 1290, 1198, 1479], "vertical": true, "font_size": 32.0, "lines": ["タイトルに", "「高木さん」", "なんて。"]}, {"box": [701, 1256, 789, 1394], "vertical": true, "font_size": 32.0, "lines": ["西片観察", "日記だよ。"]}, {"box": [406, 1245, 446, 1344], "vertical": true, "font_size": 32.0, "lines": ["ええ！？"]}, {"box": [395, 1805, 958, 1837], "vertical": false, "font_size": 32.0, "lines": ["「からかい上手の高木さん図・完"]}, {"box": [196, 1505, 271, 1674], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "冗談だって。"]}], "img_path": "152.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [48, 1166, 157, 1459], "vertical": true, "font_size": 32.0, "lines": ["消した方が", "いいのかなこれ．．．"]}], "img_path": "153.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [705, 75, 1213, 1522], "vertical": true, "font_size": 32.0, "lines": ["あれませ", "１１００刊半", "汁弟瑞瀬湖ユニ東浜迷", "Ｂｏｏｋ"]}, {"box": [1207, 510, 1263, 1798], "vertical": true, "font_size": 32.0, "lines": ["ＫａｒｄｋａｉｊｏｚｕｎｏＴａｋａｇｉｓａｎＷｏｒｌｄ"]}, {"box": [720, 1201, 767, 1239], "vertical": false, "font_size": 32.0, "lines": ["５"]}, {"box": [873, 1734, 917, 1809], "vertical": true, "font_size": 29.0, "lines": ["ひさ"]}, {"box": [847, 1704, 887, 1783], "vertical": true, "font_size": 29.0, "lines": ["あ々ひい"]}, {"box": [201, 1550, 487, 1813], "vertical": false, "font_size": 32.0, "lines": ["！？．．．４ｖａ", "ＭｒｒｕｂＨｉｔ", "京盛期党ＳＭＣ", "一定出ささすげにさん", "・テーメメリハ", "．．．みんな平成く"]}], "img_path": "154.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [230, 99, 545, 714], "vertical": true, "font_size": 32.0, "lines": ["ぎゅぎゅんがるくるみゅっ", "１＆６："]}, {"box": [116, 103, 193, 647], "vertical": true, "font_size": 32.0, "lines": ["●日平に〈引〉卵汁水〉＞２＞９概帯はＩさ", "審査員はこのようにこの相話でダンスメの口を！"]}, {"box": [63, 790, 95, 1127], "vertical": true, "font_size": 26.0, "lines": ["◎すｙｔｙｓｓＳＳの、＄ｆｆｉｖｓｔａ"]}, {"box": [229, 1230, 513, 1781], "vertical": true, "font_size": 32.0, "lines": ["「サッシングから", "剄オ〆さ", "１＆１８Ｋ"]}, {"box": [159, 1218, 191, 1786], "vertical": true, "font_size": 32.0, "lines": ["●いさやいしたばかりでいきこのおいメリューに"]}], "img_path": "155.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [0, 56, 1262, 566], "vertical": false, "font_size": 32.0, "lines": ["．．．", "その日常日、"]}, {"box": [105, 1314, 251, 1351], "vertical": false, "font_size": 32.0, "lines": ["サザンカ"]}, {"box": [543, 1096, 654, 1134], "vertical": false, "font_size": 32.0, "lines": ["ァサガオ"]}, {"box": [638, 1210, 821, 1252], "vertical": false, "font_size": 32.0, "lines": ["ちょっとした"]}, {"box": [1003, 982, 1134, 1021], "vertical": false, "font_size": 32.0, "lines": ["ヒナギク"]}, {"box": [108, 1434, 433, 1460], "vertical": false, "font_size": 26.0, "lines": ["◎ゲッサンＳＳ３Ｓ・発行・小学館・"]}, {"box": [103, 1610, 444, 1755], "vertical": false, "font_size": 32.0, "lines": ["山本崇一単行本の"]}, {"box": [101, 1475, 1018, 1541], "vertical": false, "font_size": 32.0, "lines": ["『からかい上手の高木さん』の作者が贈る"]}, {"box": [103, 1638, 1250, 1837], "vertical": false, "font_size": 32.0, "lines": ["朗ヮ", "〇巻大人気発売中！！", "単行本の〜"]}, {"box": [1259, 1432, 1285, 1530], "vertical": true, "font_size": 26.0, "lines": ["！！！山本湖！！"]}], "img_path": "156.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [90, 97, 191, 230], "vertical": false, "font_size": 32.0, "lines": ["男の"]}, {"box": [440, 103, 540, 161], "vertical": false, "font_size": 32.0, "lines": ["埜"]}, {"box": [348, 912, 572, 957], "vertical": false, "font_size": 31.0, "lines": ["シズバショウ"]}, {"box": [204, 1115, 369, 1156], "vertical": false, "font_size": 32.0, "lines": ["ベニスモモ"]}, {"box": [793, 1207, 872, 1241], "vertical": false, "font_size": 32.0, "lines": ["モクレ"]}, {"box": [