{"version": "0.2.0-beta.6", "title": "Karakai Jouzu no Takagi-san", "title_uuid": "8b310d10-25a6-4fdb-aaef-cacc33c51c4b", "volume": "Karakai-Jouzu-Takagi-san-18", "volume_uuid": "05feead6-21d3-4aa1-8939-f51a2fb72828", "pages": [{"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1207, 15, 1320, 1288], "vertical": true, "font_size": 32.0, "lines": ["からか、上の高木さんや山木空町"]}, {"box": [1019, 1843, 1310, 1876], "vertical": false, "font_size": 32.0, "lines": ["＄ｎｕｂｅＷｉｎｖｏｍＳｙｒｉｃｈ"]}], "img_path": "001.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "002.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [953, 90, 1022, 377], "vertical": true, "font_size": 32.0, "lines": ["いらっと．．．"]}, {"box": [634, 52, 755, 308], "vertical": true, "font_size": 32.0, "lines": ["そして、"]}, {"box": [1091, 637, 1126, 824], "vertical": true, "font_size": 32.0, "lines": ["ここだー！！"]}, {"box": [590, 721, 624, 922], "vertical": true, "font_size": 32.0, "lines": ["キャアアァ！！"]}, {"box": [916, 1829, 1198, 1873], "vertical": false, "font_size": 32.0, "lines": ["イムカプセル"]}, {"box": [827, 1383, 892, 1546], "vertical": true, "font_size": 31.0, "lines": ["あはは、", "みつかったー。"]}, {"box": [525, 1426, 594, 1607], "vertical": true, "font_size": 30.0, "lines": ["いいとこ", "かくれたねー。"]}, {"box": [279, 1425, 316, 1492], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}], "img_path": "003.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [611, 1713, 1271, 1852], "vertical": false, "font_size": 32.0, "lines": ["・ムカプセル"]}], "img_path": "004.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "005.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1248, 78, 1280, 219], "vertical": true, "font_size": 32.0, "lines": ["それって．．．"]}, {"box": [717, 93, 823, 249], "vertical": true, "font_size": 28.0, "lines": ["かくれてる", "ときよこに", "あったのー。"]}, {"box": [594, 106, 637, 180], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [181, 97, 260, 234], "vertical": true, "font_size": 32.0, "lines": ["あ、これ", "あれだよ。"]}, {"box": [1016, 781, 1098, 952], "vertical": true, "font_size": 32.0, "lines": ["ああー、", "これかー．．．"]}, {"box": [1248, 1141, 1282, 1246], "vertical": true, "font_size": 32.0, "lines": ["じゃあ、"]}, {"box": [710, 1168, 868, 1365], "vertical": true, "font_size": 32.0, "lines": ["今から１０分で", "キレイな石を", "持ってきた方が", "勝ちで。"]}, {"box": [583, 1177, 624, 1261], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}], "img_path": "006.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1072, 196, 1104, 322], "vertical": true, "font_size": 32.0, "lines": ["じゃあ！！"]}, {"box": [783, 202, 812, 326], "vertical": true, "font_size": 27.0, "lines": ["はじめ！！"]}, {"box": [127, 78, 598, 121], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [1078, 920, 1168, 1048], "vertical": true, "font_size": 32.0, "lines": ["自慢では", "ないが、"]}, {"box": [176, 883, 341, 1113], "vertical": true, "font_size": 32.0, "lines": ["オレは", "今までに何個も", "キレイな石を", "拾ってきたのさ。"]}, {"box": [1095, 1477, 1179, 1668], "vertical": true, "font_size": 32.0, "lines": ["オレの石に", "対する嗅覚．．．"]}, {"box": [532, 1516, 616, 1702], "vertical": true, "font_size": 32.0, "lines": ["見せてやるぞ", "高木さん。"]}], "img_path": "007.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [521, 151, 630, 352], "vertical": true, "font_size": 32.0, "lines": ["いいぞこれ．．．！！", "黒っぽくて", "ツヤがあって．．．"]}, {"box": [148, 170, 236, 333], "vertical": true, "font_size": 32.0, "lines": ["完全に", "勝った．．．！！"]}, {"box": [1243, 1141, 1282, 1194], "vertical": true, "font_size": 32.0, "lines": ["お。"]}, {"box": [746, 1185, 872, 1368], "vertical": true, "font_size": 32.0, "lines": ["いい石拾えた", "みたいなカオ", "してるね。"]}, {"box": [626, 1156, 669, 1243], "vertical": true, "font_size": 32.0, "lines": ["ふっ。"]}, {"box": [219, 1160, 251, 1268], "vertical": true, "font_size": 28.0, "lines": ["まぁね。"]}, {"box": [622, 1543, 697, 1749], "vertical": true, "font_size": 30.0, "lines": ["私もかなり", "いいの拾えたよ。"]}, {"box": [174, 1569, 211, 1620], "vertical": true, "font_size": 32.0, "lines": ["な。"]}], "img_path": "008.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1121, 105, 1205, 247], "vertical": true, "font_size": 32.0, "lines": ["いや、", "あせるな。"]}, {"box": [977, 112, 1074, 249], "vertical": true, "font_size": 32.0, "lines": ["大丈夫だいじょっ", "大丈夫．．"]}, {"box": [675, 123, 755, 262], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "せーので。"]}, {"box": [517, 108, 570, 191], "vertical": true, "font_size": 32.0, "lines": ["せぇ"]}, {"box": [163, 305, 221, 408], "vertical": true, "font_size": 32.0, "lines": ["のっ。"]}, {"box": [636, 1504, 679, 1691], "vertical": true, "font_size": 26.0, "lines": ["高木さんめ．．．"]}, {"box": [101, 1470, 178, 1606], "vertical": true, "font_size": 32.0, "lines": ["これは", "なかなか"]}], "img_path": "009.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1205, 89, 1277, 257], "vertical": true, "font_size": 30.0, "lines": ["い．．．いい石を", "拾ってきたね。"]}, {"box": [986, 101, 1058, 296], "vertical": true, "font_size": 29.0, "lines": ["まぁオレの方が", "いいけど．．．"]}, {"box": [783, 127, 858, 258], "vertical": true, "font_size": 32.0, "lines": ["えー", "そうかな。"]}, {"box": [556, 161, 642, 390], "vertical": true, "font_size": 32.0, "lines": ["でも西片のも", "キレイな石だね。"]}, {"box": [1046, 913, 1172, 1126], "vertical": true, "font_size": 32.0, "lines": ["．．．高木さんめ．．．", "見れば見るほど", "いい石を．．．"]}, {"box": [292, 892, 418, 1104], "vertical": true, "font_size": 32.0, "lines": ["このオレの石と", "同じくらい", "いい石だ．．．"]}, {"box": [1031, 1453, 1191, 1668], "vertical": true, "font_size": 32.0, "lines": ["そういえば", "これって", "どうやって勝敗", "決めるの？"]}, {"box": [181, 1483, 217, 1552], "vertical": true, "font_size": 32.0, "lines": ["あ．．．"]}], "img_path": "010.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1010, 206, 1170, 423], "vertical": true, "font_size": 32.0, "lines": ["高木さんも", "納得のあっとうて", "圧倒的勝利だと", "思ってたし．．"]}, {"box": [838, 208, 958, 421], "vertical": true, "font_size": 32.0, "lines": ["そこまで", "ちゃんと考えて", "なかった．．．"]}, {"box": [480, 191, 560, 313], "vertical": true, "font_size": 32.0, "lines": ["ゴ．．．", "ゴメン．．．"]}, {"box": [131, 84, 470, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高市"]}, {"box": [316, 189, 423, 356], "vertical": true, "font_size": 32.0, "lines": ["そこまで", "ルール決めて", "なかったよ．．．"]}, {"box": [1155, 761, 1188, 896], "vertical": true, "font_size": 32.0, "lines": ["そっかー。"]}, {"box": [607, 761, 788, 924], "vertical": true, "font_size": 32.0, "lines": ["引き分けに", "する．．．？"]}, {"box": [388, 763, 423, 835], "vertical": true, "font_size": 32.0, "lines": ["んー"]}, {"box": [138, 729, 255, 950], "vertical": true, "font_size": 32.0, "lines": ["せっかくお互いに", "いいの拾えたし", "もったいないなー。"]}, {"box": [1076, 1449, 1149, 1622], "vertical": true, "font_size": 32.0, "lines": ["んー、", "そうだよねー。"]}, {"box": [842, 1442, 870, 1543], "vertical": true, "font_size": 28.0, "lines": ["．．．．．．"]}, {"box": [521, 1455, 605, 1567], "vertical": true, "font_size": 32.0, "lines": ["あ、", "そうだ。"]}], "img_path": "011.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1053, 110, 1206, 360], "vertical": true, "font_size": 32.0, "lines": ["また明日", "２人で話し合って", "勝敗決めるってのは", "どうかな。"]}, {"box": [588, 140, 702, 363], "vertical": true, "font_size": 28.0, "lines": ["落ち着いたら", "見え方変わるかも", "しれないし。"]}, {"box": [472, 121, 519, 204], "vertical": true, "font_size": 32.0, "lines": ["へえ。"]}, {"box": [664, 661, 832, 883], "vertical": true, "font_size": 32.0, "lines": ["ねぇ、", "どうせなら", "２０歳になった時", "とかにしない？"]}, {"box": [382, 688, 450, 795], "vertical": true, "font_size": 32.0, "lines": ["２０歳！？"]}, {"box": [277, 744, 313, 930], "vertical": true, "font_size": 32.0, "lines": ["そんなに後！！？"]}, {"box": [1059, 1250, 1177, 1475], "vertical": true, "font_size": 32.0, "lines": ["大人になったら", "見え方変わってて", "面白いかなって。"]}, {"box": [571, 1290, 656, 1438], "vertical": true, "font_size": 32.0, "lines": ["んー、", "たしかに。"]}], "img_path": "012.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1081, 112, 1155, 356], "vertical": true, "font_size": 30.0, "lines": ["じゃあ、どこかに", "埋めとかない？"]}, {"box": [564, 163, 697, 350], "vertical": true, "font_size": 32.0, "lines": ["オレ絶対", "なくしちゃう", "しさ．．．"]}, {"box": [365, 78, 483, 286], "vertical": true, "font_size": 32.0, "lines": ["さっき、石", "探してる時に", "いい缶あったし、"]}, {"box": [52, 101, 173, 301], "vertical": true, "font_size": 32.0, "lines": ["それに入れて", "神社に埋めとく", "とか。"]}, {"box": [1007, 924, 1053, 1029], "vertical": true, "font_size": 32.0, "lines": ["うん、"]}, {"box": [300, 982, 337, 1185], "vertical": true, "font_size": 32.0, "lines": ["それいいね。"]}, {"box": [543, 1535, 654, 1678], "vertical": true, "font_size": 32.0, "lines": ["なんか", "うれしそう", "だな．．．"]}, {"box": [75, 1565, 133, 1655], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}], "img_path": "013.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1111, 215, 1205, 532], "vertical": true, "font_size": 32.0, "lines": ["２人で", "タイムカプセルって、"]}, {"box": [241, 253, 372, 553], "vertical": true, "font_size": 32.0, "lines": ["なかなか", "ロマンチックなコト", "考えるねー。"]}, {"box": [1158, 1027, 1198, 1110], "vertical": true, "font_size": 32.0, "lines": ["なぁ。"]}, {"box": [699, 1021, 830, 1205], "vertical": true, "font_size": 32.0, "lines": ["ただの勝負の", "おあずけ", "だから。"]}, {"box": [255, 1070, 291, 1211], "vertical": true, "font_size": 32.0, "lines": ["はいはい。"]}], "img_path": "014.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [748, 135, 876, 322], "vertical": true, "font_size": 32.0, "lines": ["次開けた時は", "勝負決まると", "いいねー。"]}, {"box": [453, 150, 495, 260], "vertical": true, "font_size": 32.0, "lines": ["ふふん。"]}, {"box": [331, 166, 369, 363], "vertical": true, "font_size": 32.0, "lines": ["オレが勝つよ。"]}, {"box": [1125, 1486, 1168, 1569], "vertical": true, "font_size": 32.0, "lines": ["おー。"]}, {"box": [660, 1485, 733, 1620], "vertical": true, "font_size": 32.0, "lines": ["キレイな", "いしだー。"]}, {"box": [545, 1406, 604, 1531], "vertical": true, "font_size": 30.0, "lines": ["なつかしい", "ねー。"]}], "img_path": "015.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [993, 103, 1207, 354], "vertical": true, "font_size": 32.0, "lines": ["結局、２０歳で", "一緒に開けた時も", "勝負つかなくて", "それっきり", "だったね。"]}, {"box": [727, 148, 770, 230], "vertical": true, "font_size": 32.0, "lines": ["あー、"]}, {"box": [605, 187, 682, 345], "vertical": true, "font_size": 32.0, "lines": ["そーだった", "なー。"]}, {"box": [196, 208, 265, 388], "vertical": true, "font_size": 30.0, "lines": ["あ、ごはん", "炊けたみたい。"]}], "img_path": "016.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [738, 142, 827, 234], "vertical": true, "font_size": 32.0, "lines": ["なぁ、", "ちー。"]}, {"box": [93, 121, 221, 249], "vertical": true, "font_size": 32.0, "lines": ["その石", "どっちが", "キレイ？"]}, {"box": [980, 919, 1010, 1073], "vertical": true, "font_size": 27.0, "lines": ["どっちが．．"]}], "img_path": "017.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1205, 136, 1237, 286], "vertical": true, "font_size": 32.0, "lines": ["こっち！！"]}, {"box": [483, 193, 525, 294], "vertical": true, "font_size": 32.0, "lines": ["んが．．．"]}, {"box": [963, 1258, 1052, 1387], "vertical": true, "font_size": 32.0, "lines": ["私の勝ち", "だねー。"]}, {"box": [650, 1209, 703, 1291], "vertical": true, "font_size": 32.0, "lines": ["え！？"]}, {"box": [485, 1207, 611, 1393], "vertical": true, "font_size": 32.0, "lines": ["なんで", "見てないのに", "わかるの！？"]}, {"box": [266, 1318, 341, 1530], "vertical": true, "font_size": 32.0, "lines": ["このいし", "もらっていい？"]}], "img_path": "018.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [108, 1760, 1085, 1811], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さん。『山本宗一朗』"]}], "img_path": "019.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1055, 841, 1243, 870], "vertical": false, "font_size": 27.0, "lines": ["Ｃｏｎｔｅｎｔｓ"]}, {"box": [1155, 1104, 1188, 1318], "vertical": true, "font_size": 24.0, "lines": ["タイムカフセル・"]}, {"box": [933, 1152, 964, 1216], "vertical": true, "font_size": 31.0, "lines": ["影絵"]}, {"box": [709, 1138, 739, 1228], "vertical": true, "font_size": 28.0, "lines": ["福引き"]}, {"box": [480, 1126, 519, 1318], "vertical": true, "font_size": 32.0, "lines": ["かいくい"]}, {"box": [255, 1125, 292, 1239], "vertical": true, "font_size": 32.0, "lines": ["おつかい"]}, {"box": [1154, 1556, 1192, 1623], "vertical": true, "font_size": 32.0, "lines": ["バス"]}, {"box": [926, 1539, 967, 1636], "vertical": true, "font_size": 32.0, "lines": ["待ち人"]}, {"box": [707, 1556, 742, 1621], "vertical": true, "font_size": 32.0, "lines": ["写生"]}, {"box": [484, 1509, 517, 1683], "vertical": true, "font_size": 26.0, "lines": ["キレイなもの"]}], "img_path": "020.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [127, 129, 301, 371], "vertical": false, "font_size": 32.0, "lines": ["影"]}], "img_path": "021.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1091, 123, 1130, 221], "vertical": true, "font_size": 32.0, "lines": ["はぁ．．．"]}, {"box": [1082, 534, 1170, 752], "vertical": true, "font_size": 32.0, "lines": ["大人に", "なりたいなぁ．．．"]}, {"box": [490, 990, 658, 1203], "vertical": true, "font_size": 31.0, "lines": ["今日みたいに", "宿題忘れて", "居残りしたりが", "ないから？"]}, {"box": [624, 1454, 648, 1521], "vertical": true, "font_size": 24.0, "lines": ["う．．．"]}, {"box": [165, 1458, 235, 1640], "vertical": true, "font_size": 29.0, "lines": ["いや．．．まぁ", "そうだけど．．"]}], "img_path": "022.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1031, 189, 1203, 433], "vertical": true, "font_size": 31.0, "lines": ["大人なら", "宿題忘れて", "なかったと思うん", "だよなぁ。"]}, {"box": [562, 189, 680, 406], "vertical": true, "font_size": 32.0, "lines": ["それは", "人それぞれだと", "思うけどなー。"]}, {"box": [429, 195, 511, 414], "vertical": true, "font_size": 32.0, "lines": ["いや！！", "オレは決めた！"]}, {"box": [129, 82, 566, 120], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんに"]}, {"box": [1041, 795, 1170, 1036], "vertical": true, "font_size": 32.0, "lines": ["これからは", "大人を目指して", "生きていこう！！"]}, {"box": [189, 823, 286, 1134], "vertical": true, "font_size": 32.0, "lines": ["そして少しでも早く", "大人になる！！"]}, {"box": [842, 1520, 875, 1627], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [618, 1503, 773, 1755], "vertical": true, "font_size": 32.0, "lines": ["私はあんまり", "頑張って大人に", "なろうとしなくても", "いいと思うけどなー。"]}], "img_path": "023.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1235, 112, 1270, 217], "vertical": true, "font_size": 32.0, "lines": ["ふふん。"]}, {"box": [661, 99, 812, 313], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "高木さんをおいて", "オレだけ大人に", "なってやる。"]}, {"box": [193, 105, 336, 353], "vertical": true, "font_size": 26.0, "lines": ["そうなったら", "高木さんに", "からかわれるコトも", "なくなるし！"]}], "img_path": "024.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [399, 97, 496, 258], "vertical": true, "font_size": 32.0, "lines": ["何してるの", "西片。"]}, {"box": [860, 811, 1063, 1117], "vertical": true, "font_size": 32.0, "lines": ["いや、なんか", "このカベ白くて", "夕日の影が", "めちゃくちゃキレイに", "映るなと思って。"]}, {"box": [603, 1473, 637, 1591], "vertical": true, "font_size": 32.0, "lines": ["うさぎ。"]}], "img_path": "025.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1063, 136, 1101, 338], "vertical": true, "font_size": 32.0, "lines": ["あははは"]}, {"box": [836, 193, 879, 273], "vertical": true, "font_size": 32.0, "lines": ["え？！"]}, {"box": [643, 114, 729, 346], "vertical": true, "font_size": 32.0, "lines": ["いや、大人になる", "とか言って、"]}, {"box": [191, 363, 307, 577], "vertical": true, "font_size": 32.0, "lines": ["すぐにいつもの", "西片だから", "おかしくて。"]}, {"box": [680, 830, 723, 905], "vertical": true, "font_size": 32.0, "lines": ["な．．．"]}, {"box": [183, 798, 268, 1016], "vertical": true, "font_size": 32.0, "lines": ["し．．．", "しまったぁあ。"]}, {"box": [1074, 1126, 1192, 1278], "vertical": true, "font_size": 32.0, "lines": ["つ．．．つい", "子供っぽい", "コトを．．．"]}, {"box": [718, 1149, 763, 1235], "vertical": true, "font_size": 32.0, "lines": ["はー。"]}, {"box": [566, 1143, 648, 1331], "vertical": true, "font_size": 32.0, "lines": ["なんか", "安心したや。"]}], "img_path": "026.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1110, 133, 1179, 266], "vertical": true, "font_size": 32.0, "lines": ["いやいや！！", "オレは．．．"]}, {"box": [954, 133, 1040, 245], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "私はー、"]}, {"box": [701, 157, 750, 247], "vertical": true, "font_size": 32.0, "lines": ["ほい。"]}, {"box": [1158, 935, 1192, 1027], "vertical": true, "font_size": 32.0, "lines": ["おぉ．．．"]}, {"box": [678, 941, 720, 1033], "vertical": true, "font_size": 32.0, "lines": ["ネコ。"]}, {"box": [530, 926, 605, 1050], "vertical": true, "font_size": 32.0, "lines": ["やるな．．．", "高木さ．．．"]}, {"box": [1056, 1464, 1173, 1616], "vertical": true, "font_size": 30.0, "lines": ["ま、まぁ", "いいんじゃ", "ないかな．．．"]}, {"box": [909, 1432, 953, 1594], "vertical": true, "font_size": 32.0, "lines": ["大人っぽく。"]}, {"box": [558, 1451, 722, 1670], "vertical": true, "font_size": 32.0, "lines": ["オレはおとな", "大人なので", "この辺でやめて", "おくけど。"]}, {"box": [183, 1509, 220, 1617], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}], "img_path": "027.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1145, 86, 1263, 303], "vertical": true, "font_size": 32.0, "lines": ["西片のうさぎより", "私のネコの方が", "強いよね。"]}, {"box": [660, 247, 746, 386], "vertical": true, "font_size": 32.0, "lines": ["まぁ関係", "ないけど。"]}, {"box": [765, 931, 817, 1083], "vertical": true, "font_size": 32.0, "lines": ["シカ！！"]}, {"box": [1162, 1458, 1196, 1562], "vertical": true, "font_size": 32.0, "lines": ["じゃあ、"]}, {"box": [712, 1498, 772, 1560], "vertical": true, "font_size": 32.0, "lines": ["狼。"]}, {"box": [594, 1460, 632, 1611], "vertical": true, "font_size": 32.0, "lines": ["ゴリラ！！"]}], "img_path": "028.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [581, 135, 626, 225], "vertical": true, "font_size": 32.0, "lines": ["ゾウ。"]}, {"box": [414, 153, 461, 303], "vertical": true, "font_size": 32.0, "lines": ["ゾウ．．．"]}, {"box": [978, 1091, 1188, 1370], "vertical": true, "font_size": 32.0, "lines": ["オレの", "手持ちはあと", "カニ・ヤギ・鳥・", "カエル・カタツムリ", "だけ．．．"]}, {"box": [170, 1125, 298, 1310], "vertical": true, "font_size": 32.0, "lines": ["ゾウに", "勝てるやつが", "いない．．．"]}, {"box": [1160, 1548, 1192, 1741], "vertical": true, "font_size": 28.0, "lines": ["こうなったら"]}, {"box": [600, 1576, 675, 1700], "vertical": true, "font_size": 32.0, "lines": ["いちか", "ばちか！"]}], "img_path": "029.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1205, 150, 1265, 279], "vertical": true, "font_size": 32.0, "lines": ["勢いで、"]}, {"box": [547, 288, 611, 511], "vertical": true, "font_size": 32.0, "lines": ["押し通す！！"]}, {"box": [378, 84, 464, 247], "vertical": true, "font_size": 32.0, "lines": ["おー、大技", "きたねー。"]}, {"box": [165, 169, 196, 322], "vertical": true, "font_size": 27.0, "lines": ["いけた．．．！！"]}, {"box": [1186, 512, 1250, 615], "vertical": true, "font_size": 32.0, "lines": ["目！！"]}, {"box": [386, 892, 425, 973], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}, {"box": [1117, 890, 1198, 1057], "vertical": true, "font_size": 32.0, "lines": ["うーん", "じゃあ私は、"]}, {"box": [532, 894, 648, 1068], "vertical": true, "font_size": 30.0, "lines": ["ふっ高木さん、", "次はどう", "くるんだい。"]}, {"box": [1074, 1421, 1200, 1636], "vertical": true, "font_size": 32.0, "lines": ["じゃあ西片にも", "手伝って", "もらおうかな。"]}, {"box": [641, 1428, 686, 1496], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}, {"box": [489, 1408, 570, 1605], "vertical": true, "font_size": 32.0, "lines": ["ここに", "こう立ってて。"]}, {"box": [180, 1451, 300, 1560], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}], "img_path": "030.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1119, 243, 1184, 425], "vertical": true, "font_size": 32.0, "lines": ["この辺かな？"]}, {"box": [131, 84, 596, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [354, 675, 425, 746], "vertical": false, "font_size": 32.0, "lines": ["«"]}, {"box": [1067, 922, 1147, 1065], "vertical": true, "font_size": 32.0, "lines": ["うん、", "いい感じ。"]}, {"box": [872, 1301, 958, 1385], "vertical": true, "font_size": 32.0, "lines": ["ほら", "これ。"]}, {"box": [513, 1310, 575, 1391], "vertical": true, "font_size": 32.0, "lines": ["な。"]}, {"box": [249, 918, 331, 1046], "vertical": true, "font_size": 32.0, "lines": ["もう", "いいの？"]}], "img_path": "031.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1170, 150, 1203, 279], "vertical": true, "font_size": 32.0, "lines": ["これは．．"]}, {"box": [236, 183, 279, 266], "vertical": true, "font_size": 32.0, "lines": ["キ．．．"]}, {"box": [1149, 1006, 1237, 1165], "vertical": true, "font_size": 32.0, "lines": ["これ", "なーんだ。"]}, {"box": [498, 999, 590, 1102], "vertical": true, "font_size": 32.0, "lines": ["い．．．", "いや．．．"]}], "img_path": "032.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1053, 166, 1173, 440], "vertical": true, "font_size": 31.0, "lines": ["そ．．．！！", "そういうルールじゃ", "なくない．．．！？"]}, {"box": [592, 249, 631, 346], "vertical": true, "font_size": 32.0, "lines": ["んー？"]}, {"box": [131, 84, 594, 116], "vertical": false, "font_size": 29.0, "lines": ["上手の高ホさんの", "からかい」"]}, {"box": [395, 168, 507, 390], "vertical": true, "font_size": 30.0, "lines": ["さっきの「目」って", "やつスルーして", "あげたし、"]}, {"box": [136, 200, 242, 365], "vertical": true, "font_size": 29.0, "lines": ["ルールなんて", "そもそも", "ないよね。"]}, {"box": [1142, 894, 1185, 997], "vertical": true, "font_size": 32.0, "lines": ["あれ？"]}, {"box": [78, 878, 111, 949], "vertical": true, "font_size": 32.0, "lines": ["ぐ．．．"]}, {"box": [1020, 883, 1052, 1046], "vertical": true, "font_size": 32.0, "lines": ["もしかして、"]}, {"box": [482, 969, 701, 1239], "vertical": true, "font_size": 32.0, "lines": ["大人を", "目指してるのに", "恥ずかしくて", "これが何か", "言えないのかなー。"]}, {"box": [170, 1670, 204, 1777], "vertical": true, "font_size": 32.0, "lines": ["．．．．．．"]}], "img_path": "033.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1048, 125, 1188, 313], "vertical": true, "font_size": 32.0, "lines": ["負けました。"]}, {"box": [721, 156, 775, 288], "vertical": true, "font_size": 32.0, "lines": ["あはは"]}, {"box": [599, 150, 684, 331], "vertical": true, "font_size": 30.0, "lines": ["別に勝負じゃ", "ないけどね。"]}, {"box": [330, 810, 451, 995], "vertical": true, "font_size": 32.0, "lines": ["オレは．．．", "大人になれる", "のかな。"]}, {"box": [1046, 1560, 1140, 1705], "vertical": true, "font_size": 32.0, "lines": ["急によかき", "弱気だね。"]}, {"box": [243, 1576, 322, 1704], "vertical": true, "font_size": 32.0, "lines": ["いやぁ．．．", "だって．．．"]}], "img_path": "034.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1119, 174, 1155, 249], "vertical": true, "font_size": 32.0, "lines": ["まぁ、"]}, {"box": [963, 251, 1072, 420], "vertical": true, "font_size": 32.0, "lines": ["急がなくても", "いいんじゃ", "ない？"]}, {"box": [532, 248, 565, 434], "vertical": true, "font_size": 32.0, "lines": ["そーかなー．．．"]}, {"box": [1123, 600, 1155, 736], "vertical": true, "font_size": 32.0, "lines": ["そうだよ。"]}, {"box": [316, 558, 463, 765], "vertical": true, "font_size": 28.0, "lines": ["そんなコト言って", "高木さんだけ", "先に大人に", "なろうと．．．"]}, {"box": [63, 579, 133, 702], "vertical": true, "font_size": 30.0, "lines": ["してない", "してない"]}, {"box": [650, 922, 679, 1024], "vertical": true, "font_size": 29.0, "lines": ["．．．．．．？"]}], "img_path": "035.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [997, 1380, 1113, 1593], "vertical": true, "font_size": 30.0, "lines": ["ずっとこのまま", "だったら", "いいのになー。"]}, {"box": [635, 1411, 756, 1599], "vertical": true, "font_size": 32.0, "lines": ["いや、オレは", "大人に", "なりたいよ．．．"]}, {"box": [361, 1483, 480, 1606], "vertical": true, "font_size": 32.0, "lines": ["そういう", "ことじゃ", "ないよ。"]}, {"box": [232, 1621, 261, 1665], "vertical": true, "font_size": 29.0, "lines": ["？"]}], "img_path": "036.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [163, 367, 283, 586], "vertical": false, "font_size": 32.0, "lines": ["特等", "筆"]}, {"box": [659, 303, 1195, 415], "vertical": false, "font_size": 32.0, "lines": ["高木商店"]}, {"box": [195, 603, 296, 759], "vertical": false, "font_size": 32.0, "lines": ["二等三寺"]}, {"box": [298, 506, 478, 564], "vertical": false, "font_size": 32.0, "lines": ["からかい"]}, {"box": [163, 624, 285, 946], "vertical": true, "font_size": 32.0, "lines": ["ここで、", "こきつきましょう。"]}, {"box": [300, 628, 461, 676], "vertical": false, "font_size": 32.0, "lines": ["からかい"]}, {"box": [176, 843, 219, 916], "vertical": false, "font_size": 32.0, "lines": ["四"]}], "img_path": "037.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [701, 817, 744, 883], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [571, 924, 624, 1008], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [603, 1134, 630, 1237], "vertical": true, "font_size": 27.0, "lines": ["よくひき"]}, {"box": [176, 986, 223, 1042], "vertical": true, "font_size": 32.0, "lines": ["ふ。"]}, {"box": [176, 1449, 259, 1603], "vertical": true, "font_size": 32.0, "lines": ["待ってたよ", "高木さん。"]}], "img_path": "038.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [937, 116, 1028, 247], "vertical": true, "font_size": 32.0, "lines": ["待ってた", "って。"]}, {"box": [635, 97, 682, 337], "vertical": true, "font_size": 32.0, "lines": ["あ、", "なるほど。"]}, {"box": [1052, 828, 1085, 928], "vertical": true, "font_size": 32.0, "lines": ["そう．．．"]}, {"box": [82, 435, 169, 601], "vertical": true, "font_size": 32.0, "lines": ["昨日そう", "言ったから。"]}, {"box": [1053, 1240, 1105, 1404], "vertical": true, "font_size": 32.0, "lines": ["福引きで、"]}, {"box": [164, 1233, 317, 1402], "vertical": true, "font_size": 32.0, "lines": ["勝負を", "しようと", "思ってね。"]}, {"box": [465, 1507, 558, 1631], "vertical": true, "font_size": 32.0, "lines": ["福引券", "何だ組み"]}], "img_path": "039.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1160, 183, 1205, 258], "vertical": true, "font_size": 32.0, "lines": ["え？"]}, {"box": [992, 174, 1113, 361], "vertical": true, "font_size": 32.0, "lines": ["休日にも", "会いたくて", "来ちゃった？"]}, {"box": [519, 189, 637, 341], "vertical": true, "font_size": 32.0, "lines": ["どういう", "聞き間違い", "なの！？"]}, {"box": [153, 185, 191, 283], "vertical": true, "font_size": 32.0, "lines": ["ぐぅ．．．"]}, {"box": [1067, 1222, 1194, 1350], "vertical": true, "font_size": 32.0, "lines": ["それで、", "どういう", "勝負？"]}, {"box": [729, 1224, 815, 1390], "vertical": true, "font_size": 32.0, "lines": ["お互いに", "福引きして、"]}, {"box": [386, 1243, 510, 1402], "vertical": true, "font_size": 32.0, "lines": ["いいやつを", "引いた方が", "勝ち。"]}, {"box": [924, 1419, 982, 1621], "vertical": true, "font_size": 32.0, "lines": ["あ、", "ああ。"]}, {"box": [180, 1515, 259, 1638], "vertical": true, "font_size": 32.0, "lines": ["シンプル", "だねー。"]}], "img_path": "040.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1123, 178, 1209, 290], "vertical": true, "font_size": 32.0, "lines": ["お願い", "します。"]}, {"box": [872, 187, 915, 266], "vertical": true, "font_size": 32.0, "lines": ["はい、"]}, {"box": [592, 170, 676, 326], "vertical": true, "font_size": 32.0, "lines": ["５０枚だから", "５回ねー。"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [977, 1051, 1074, 1200], "vertical": true, "font_size": 32.0, "lines": ["最高", "５等かー。"]}, {"box": [673, 1102, 761, 1350], "vertical": true, "font_size": 32.0, "lines": ["４等以上を引けば", "オレの勝ち．．．！！"]}, {"box": [161, 1091, 247, 1246], "vertical": true, "font_size": 32.0, "lines": ["じゃあ次は", "オレの番．．．"]}], "img_path": "041.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1061, 88, 1173, 316], "vertical": true, "font_size": 32.0, "lines": ["ふふ．．．たかぎ", "高木さんは", "知らないだろう．．．"]}, {"box": [727, 135, 807, 328], "vertical": true, "font_size": 30.0, "lines": ["オレの福引きの", "才能を！！"]}, {"box": [369, 88, 520, 341], "vertical": true, "font_size": 32.0, "lines": ["５歳のころ", "福引きで", "連続で２等を当てた", "ことがあるのさ"]}, {"box": [211, 28, 294, 143], "vertical": true, "font_size": 27.0, "lines": ["ま．．．"]}, {"box": [1005, 748, 1143, 911], "vertical": true, "font_size": 32.0, "lines": ["必ずとう", "４等以上を", "出して、"]}, {"box": [286, 798, 363, 922], "vertical": true, "font_size": 32.0, "lines": ["勝つ。"]}, {"box": [860, 1188, 950, 1316], "vertical": true, "font_size": 32.0, "lines": ["あと一回", "だねー。"]}, {"box": [813, 1584, 930, 1740], "vertical": true, "font_size": 32.0, "lines": ["なぜだ．．．", "こんな", "ハズじゃ．．．"]}, {"box": [191, 1575, 308, 1740], "vertical": true, "font_size": 32.0, "lines": ["あのころと", "何が", "違うんだ。"]}], "img_path": "042.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1014, 658, 1136, 875], "vertical": true, "font_size": 32.0, "lines": ["そうか．．．", "必要だったのは", "無心．．．"]}, {"box": [198, 693, 371, 849], "vertical": true, "font_size": 30.0, "lines": ["何も考えず", "ガラガラを", "回すことに", "集中：！！"]}], "img_path": "043.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1168, 123, 1247, 260], "vertical": true, "font_size": 32.0, "lines": ["なんか", "疲れたし、"]}, {"box": [593, 133, 721, 360], "vertical": true, "font_size": 30.0, "lines": ["西片が負けたら", "帰りおんぶして", "もらおうかなー。"]}, {"box": [1076, 918, 1149, 1074], "vertical": true, "font_size": 32.0, "lines": ["そ．．．それは", "ちょっと．．．"]}, {"box": [1087, 1239, 1164, 1453], "vertical": true, "font_size": 31.0, "lines": ["せっかく無心に", "なれてたのに．．．"]}, {"box": [948, 1250, 1022, 1415], "vertical": true, "font_size": 31.0, "lines": ["引けるハズ", "だったのに。"]}, {"box": [568, 1261, 692, 1449], "vertical": true, "font_size": 32.0, "lines": ["あはは、", "なんかそんな", "顔してた。"]}, {"box": [479, 1246, 504, 1356], "vertical": true, "font_size": 25.0, "lines": ["くう．．．"]}, {"box": [238, 898, 271, 1054], "vertical": true, "font_size": 32.0, "lines": ["あぁーー！！"]}, {"box": [888, 1493, 916, 1621], "vertical": true, "font_size": 27.0, "lines": ["ふくひきっ"]}, {"box": [618, 1585, 650, 1770], "vertical": true, "font_size": 32.0, "lines": ["わざとなの！？"]}], "img_path": "044.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1091, 118, 1198, 225], "vertical": false, "font_size": 32.0, "lines": ["はい、西片。"]}, {"box": [780, 144, 825, 281], "vertical": true, "font_size": 32.0, "lines": ["私の余り、"]}, {"box": [144, 118, 262, 354], "vertical": true, "font_size": 30.0, "lines": ["西片の余りと", "合わせたら", "一回引けるでしょ。"]}, {"box": [251, 1044, 285, 1164], "vertical": true, "font_size": 32.0, "lines": ["いいの？"]}, {"box": [1164, 1452, 1200, 1530], "vertical": true, "font_size": 32.0, "lines": ["うん、"]}, {"box": [858, 1438, 898, 1546], "vertical": true, "font_size": 32.0, "lines": ["だって、"]}], "img_path": "045.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [937, 170, 1012, 343], "vertical": true, "font_size": 32.0, "lines": ["どーせ", "当たんないし。"]}, {"box": [609, 180, 703, 350], "vertical": true, "font_size": 32.0, "lines": ["絶対", "当ててやる。"]}, {"box": [493, 217, 543, 318], "vertical": true, "font_size": 32.0, "lines": ["無心．．．"]}, {"box": [140, 215, 240, 331], "vertical": true, "font_size": 32.0, "lines": ["も絶対しない", "無心だ。"]}, {"box": [995, 840, 1033, 1059], "vertical": true, "font_size": 32.0, "lines": ["特等当たったら"]}, {"box": [915, 843, 990, 997], "vertical": true, "font_size": 32.0, "lines": ["２人で旅行", "行こうよ。"]}, {"box": [1136, 836, 1196, 1220], "vertical": true, "font_size": 32.0, "lines": ["あ、そうだ。", "２人で出しあった"]}, {"box": [1093, 993, 1125, 1190], "vertical": true, "font_size": 32.0, "lines": ["福引き券だし、"]}, {"box": [637, 1385, 727, 1556], "vertical": true, "font_size": 32.0, "lines": ["へー、すごい", "無心。"]}], "img_path": "046.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [379, 1290, 412, 1354], "vertical": true, "font_size": 32.0, "lines": ["ふ．．．"]}, {"box": [1119, 1378, 1147, 1404], "vertical": false, "font_size": 26.0, "lines": ["特"]}], "img_path": "047.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1111, 193, 1215, 382], "vertical": true, "font_size": 32.0, "lines": ["２人で？", "旅行って．．"]}, {"box": [221, 292, 265, 528], "vertical": true, "font_size": 32.0, "lines": ["おいやいや。"]}, {"box": [311, 809, 352, 959], "vertical": true, "font_size": 32.0, "lines": ["ああー"]}], "img_path": "048.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1140, 176, 1171, 328], "vertical": true, "font_size": 26.0, "lines": ["よかったね。"]}, {"box": [575, 211, 757, 398], "vertical": true, "font_size": 32.0, "lines": ["最後", "５等引けて、", "引き分け。"]}, {"box": [129, 82, 598, 118], "vertical": false, "font_size": 32.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [189, 204, 232, 328], "vertical": true, "font_size": 32.0, "lines": ["いやー．．．"]}, {"box": [1007, 905, 1125, 1106], "vertical": true, "font_size": 30.0, "lines": ["無心のままなら", "きっと勝ってた", "ハズなのに。"]}, {"box": [281, 931, 320, 1044], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [1012, 1366, 1174, 1552], "vertical": true, "font_size": 32.0, "lines": ["てことは", "何かに心を", "乱されたって", "コト？"]}, {"box": [511, 1408, 598, 1511], "vertical": true, "font_size": 32.0, "lines": ["あ．．．", "いや．．．"]}, {"box": [367, 1368, 457, 1601], "vertical": true, "font_size": 32.0, "lines": ["へー、", "なんだろうなー。"]}], "img_path": "049.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1106, 179, 1143, 359], "vertical": true, "font_size": 26.0, "lines": ["気になるなー。"]}, {"box": [570, 226, 645, 456], "vertical": true, "font_size": 32.0, "lines": ["わかってて", "言ってるよねぇ。"]}, {"box": [1025, 875, 1070, 988], "vertical": true, "font_size": 32.0, "lines": ["でもさ、"]}, {"box": [667, 1207, 750, 1375], "vertical": true, "font_size": 32.0, "lines": ["いつか", "行きたいね。"]}], "img_path": "050.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1145, 189, 1185, 243], "vertical": true, "font_size": 32.0, "lines": ["え。"]}, {"box": [479, 183, 556, 343], "vertical": true, "font_size": 32.0, "lines": ["そう", "思わない？"]}, {"box": [129, 82, 592, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [1085, 397, 1204, 581], "vertical": true, "font_size": 32.0, "lines": ["それって．．．", "２人で旅行に", "ってコト．．．！？"]}, {"box": [1147, 1278, 1188, 1376], "vertical": true, "font_size": 32.0, "lines": ["いや．．．"]}, {"box": [671, 1338, 705, 1451], "vertical": true, "font_size": 32.0, "lines": ["え、と．．．"]}, {"box": [288, 1336, 365, 1464], "vertical": true, "font_size": 32.0, "lines": ["なんと", "いうか．．．"]}], "img_path": "051.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [763, 142, 982, 391], "vertical": true, "font_size": 32.0, "lines": ["お母さんに", "今度の家族旅行", "沖縄にしようって", "言ってみよう", "かなー。"]}, {"box": [286, 232, 333, 301], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}, {"box": [1164, 1018, 1198, 1113], "vertical": true, "font_size": 32.0, "lines": ["あれ？"]}, {"box": [564, 1066, 746, 1237], "vertical": true, "font_size": 32.0, "lines": ["もしかして", "２人で", "行きたいって", "話だと", "思ってた？"]}, {"box": [870, 1464, 1007, 1719], "vertical": true, "font_size": 32.0, "lines": ["沖縄", "行きたいかなって", "考えてたんだよ！！"]}, {"box": [483, 1486, 562, 1624], "vertical": true, "font_size": 32.0, "lines": ["ふーん", "そっかー。"]}], "img_path": "052.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [63, 54, 571, 176], "vertical": false, "font_size": 32.0, "lines": ["かいぐい"]}], "img_path": "053.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1115, 86, 1158, 330], "vertical": true, "font_size": 32.0, "lines": ["やーきいもー"]}, {"box": [378, 123, 468, 294], "vertical": true, "font_size": 32.0, "lines": ["いーし", "やきいもー"]}, {"box": [1080, 864, 1202, 1033], "vertical": true, "font_size": 32.0, "lines": ["あ、", "焼きイモ", "トラックだ。"]}, {"box": [851, 851, 975, 1068], "vertical": true, "font_size": 32.0, "lines": ["なんか", "いいニオイする", "と思った。"]}, {"box": [542, 867, 568, 978], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．"]}], "img_path": "054.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [586, 90, 667, 262], "vertical": true, "font_size": 32.0, "lines": ["かいぐい", "しちゃう？"]}, {"box": [463, 97, 506, 240], "vertical": true, "font_size": 32.0, "lines": ["焼きイモ。"]}, {"box": [543, 856, 649, 1033], "vertical": true, "font_size": 28.0, "lines": ["おいしそう", "だなーって", "見てただけで、"]}, {"box": [151, 886, 242, 1016], "vertical": true, "font_size": 32.0, "lines": ["べ．．．別に", "腹は．．．"]}, {"box": [1115, 858, 1200, 1074], "vertical": true, "font_size": 32.0, "lines": ["今日、おにぎり", "落としてたし、"]}, {"box": [714, 855, 797, 1072], "vertical": true, "font_size": 30.0, "lines": ["お腹空いて", "るんじゃない？"]}, {"box": [210, 1220, 386, 1471], "vertical": false, "font_size": 32.0, "lines": ["そんな"]}], "img_path": "055.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1128, 193, 1209, 331], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "買おうよ。"]}, {"box": [963, 172, 1046, 343], "vertical": true, "font_size": 32.0, "lines": ["私もお腹", "空いてるし。"]}, {"box": [693, 203, 721, 306], "vertical": true, "font_size": 28.0, "lines": ["．．．．．．？"]}, {"box": [481, 165, 560, 382], "vertical": true, "font_size": 32.0, "lines": ["いや、でもな．．．", "うーん．．．"]}, {"box": [153, 588, 196, 658], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [965, 982, 1121, 1205], "vertical": true, "font_size": 32.0, "lines": ["下校中に", "かいぐいって", "校則違反とかじゃ", "なかったっけ．．．"]}, {"box": [291, 980, 371, 1204], "vertical": true, "font_size": 29.0, "lines": ["巡回してる先生に", "見つかったら．．．"]}, {"box": [562, 1432, 605, 1516], "vertical": true, "font_size": 32.0, "lines": ["んー。"]}], "img_path": "056.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1050, 243, 1139, 397], "vertical": true, "font_size": 32.0, "lines": ["大丈夫じゃ", "ない？"]}, {"box": [695, 200, 827, 390], "vertical": true, "font_size": 32.0, "lines": ["ご私", "怒られたコト", "ないよ？"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [318, 193, 360, 275], "vertical": true, "font_size": 32.0, "lines": ["え！？"]}, {"box": [181, 195, 264, 504], "vertical": true, "font_size": 32.0, "lines": ["けっこうかいぐい", "してんの高木さん！？"]}, {"box": [1117, 853, 1190, 1033], "vertical": true, "font_size": 32.0, "lines": ["．．．ていうか", "そうなのか．．．"]}, {"box": [161, 603, 248, 744], "vertical": true, "font_size": 32.0, "lines": ["なんか意外．．．！"]}, {"box": [958, 873, 1037, 1065], "vertical": true, "font_size": 32.0, "lines": ["校則違反だと", "思ってたけど、"]}, {"box": [1138, 1323, 1190, 1419], "vertical": true, "font_size": 32.0, "lines": ["よし、"]}, {"box": [292, 851, 406, 1074], "vertical": true, "font_size": 32.0, "lines": ["高木さんが", "怒られたコト", "ないってコトは、"]}, {"box": [178, 875, 223, 1078], "vertical": true, "font_size": 32.0, "lines": ["大丈夫なのか。"]}, {"box": [650, 1425, 693, 1576], "vertical": true, "font_size": 32.0, "lines": ["じゃあ。"]}], "img_path": "057.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1087, 1404, 1183, 1570], "vertical": true, "font_size": 32.0, "lines": ["買って", "しまった。"]}, {"box": [271, 1393, 378, 1654], "vertical": true, "font_size": 32.0, "lines": ["人生初のうちの", "下校中かいぐい。"]}], "img_path": "058.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1040, 161, 1208, 376], "vertical": true, "font_size": 32.0, "lines": ["ふふ．．．何か", "少し悪いコトを", "しているような", "ワクワクが．．．"]}, {"box": [795, 192, 823, 238], "vertical": true, "font_size": 28.0, "lines": ["！"]}, {"box": [348, 82, 594, 120], "vertical": false, "font_size": 32.0, "lines": ["手の高ホさんの"]}, {"box": [131, 84, 296, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい"]}, {"box": [204, 150, 298, 283], "vertical": true, "font_size": 32.0, "lines": ["．．．食べ", "ないの？"]}, {"box": [91, 191, 126, 311], "vertical": true, "font_size": 32.0, "lines": ["あ、うん。"]}, {"box": [714, 840, 787, 1006], "vertical": true, "font_size": 32.0, "lines": ["かいぐい", "だなーって、"]}, {"box": [606, 862, 633, 903], "vertical": true, "font_size": 27.0, "lines": ["？"]}, {"box": [723, 1110, 757, 1245], "vertical": true, "font_size": 32.0, "lines": ["思ってて。"]}], "img_path": "059.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [667, 163, 702, 289], "vertical": true, "font_size": 32.0, "lines": ["うっま。"]}, {"box": [405, 157, 525, 465], "vertical": true, "font_size": 32.0, "lines": ["いや、焼きイモなんて", "何度も食べてるけど．．．", "これは．．．"]}, {"box": [185, 402, 313, 644], "vertical": true, "font_size": 32.0, "lines": ["罪悪感の味がプラスされているというか。"]}, {"box": [183, 401, 305, 645], "vertical": true, "font_size": 32.0, "lines": ["罪悪感の味が", "プラスされている", "というか。"]}, {"box": [1052, 892, 1203, 1083], "vertical": true, "font_size": 32.0, "lines": ["これが", "かいぐいの", "魔力．．！！"]}, {"box": [1158, 1275, 1188, 1370], "vertical": true, "font_size": 30.0, "lines": ["どう？"]}, {"box": [708, 1302, 793, 1470], "vertical": true, "font_size": 32.0, "lines": ["初めての", "かいぐいは。"]}, {"box": [596, 1273, 630, 1484], "vertical": true, "font_size": 32.0, "lines": ["めちゃくちゃ！！"]}, {"box": [159, 1320, 201, 1451], "vertical": true, "font_size": 32.0, "lines": ["うまい。"]}], "img_path": "060.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1083, 157, 1194, 408], "vertical": true, "font_size": 28.0, "lines": ["これを知ったら", "校則違反だとしても", "やりたくなるなー。"]}, {"box": [549, 200, 637, 491], "vertical": true, "font_size": 32.0, "lines": ["いやー、校則違反じゃ", "なくてよかったー。"]}, {"box": [131, 84, 594, 116], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [161, 185, 193, 290], "vertical": true, "font_size": 32.0, "lines": ["．．．．．．"]}, {"box": [1117, 707, 1203, 954], "vertical": true, "font_size": 32.0, "lines": ["あ、そうだ西片", "一口交換しない？"]}, {"box": [618, 723, 738, 890], "vertical": true, "font_size": 32.0, "lines": ["ん？おな", "同じように", "見えるけど、"]}, {"box": [174, 731, 249, 886], "vertical": true, "font_size": 32.0, "lines": ["なんか", "味違うの？"]}, {"box": [918, 1353, 1093, 1541], "vertical": true, "font_size": 32.0, "lines": ["西片が", "間接キス", "恥ずかしがる", "かなって。"]}, {"box": [376, 1366, 453, 1522], "vertical": true, "font_size": 32.0, "lines": ["何その雑な", "からかい！！"]}, {"box": [215, 1423, 313, 1601], "vertical": true, "font_size": 32.0, "lines": ["交換", "しないよ！！"]}], "img_path": "061.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1115, 1003, 1177, 1091], "vertical": true, "font_size": 32.0, "lines": ["西片、"]}, {"box": [930, 1012, 1050, 1228], "vertical": true, "font_size": 32.0, "lines": ["ちょっと", "焼きイモ貸して", "くれない？"]}, {"box": [547, 1008, 675, 1164], "vertical": true, "font_size": 32.0, "lines": ["．．．また何か", "しようと", "してる．．．？"]}, {"box": [873, 1402, 900, 1441], "vertical": true, "font_size": 27.0, "lines": ["？"]}, {"box": [262, 1066, 337, 1201], "vertical": true, "font_size": 32.0, "lines": ["いいから", "いいから。"]}, {"box": [393, 1376, 436, 1449], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}], "img_path": "062.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1153, 105, 1185, 228], "vertical": true, "font_size": 32.0, "lines": ["あれは．．．"]}, {"box": [660, 127, 753, 292], "vertical": true, "font_size": 32.0, "lines": ["生活指導の", "なかむらせ", "中村先生。"]}, {"box": [219, 800, 335, 1005], "vertical": true, "font_size": 30.0, "lines": ["あまり遅く", "ならないうちに", "帰りなさいねー。"]}, {"box": [1076, 1482, 1106, 1589], "vertical": true, "font_size": 30.0, "lines": ["．．．．．．"]}], "img_path": "063.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [813, 145, 859, 366], "vertical": true, "font_size": 32.0, "lines": ["危なかったね。"]}, {"box": [625, 150, 710, 336], "vertical": true, "font_size": 32.0, "lines": ["校則違反", "なんじゃん！"]}, {"box": [1040, 890, 1166, 1132], "vertical": true, "font_size": 32.0, "lines": ["あれ？私", "校則違反じゃない", "って言ったっけ。"]}, {"box": [536, 892, 650, 1059], "vertical": true, "font_size": 27.0, "lines": ["怒られたコト", "ないとは", "言ったけど。"]}, {"box": [338, 1071, 367, 1176], "vertical": true, "font_size": 29.0, "lines": ["．．．．．．"]}, {"box": [1098, 1391, 1205, 1620], "vertical": true, "font_size": 32.0, "lines": ["ていうか", "かいぐいするのも", "初めてだよ。"]}, {"box": [746, 1415, 780, 1511], "vertical": true, "font_size": 32.0, "lines": ["ええ！？"]}, {"box": [660, 1533, 785, 1766], "vertical": false, "font_size": 32.0, "lines": ["この方の", "いや、そんなことだけど、"]}, {"box": [502, 1410, 607, 1589], "vertical": true, "font_size": 29.0, "lines": ["まったく．．", "見つかったら", "どーすんのさ。"]}], "img_path": "064.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [918, 208, 1047, 429], "vertical": true, "font_size": 32.0, "lines": ["ま、西片と", "仲良く怒られる", "かなー。"]}, {"box": [741, 258, 770, 362], "vertical": true, "font_size": 29.0, "lines": ["．．．．．．．"]}, {"box": [384, 153, 600, 403], "vertical": true, "font_size": 32.0, "lines": ["．．．いや、", "オレは高木さんに", "だまされて", "かいぐいしただけ", "だし、"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [172, 170, 298, 328], "vertical": true, "font_size": 32.0, "lines": ["怒られ", "ないんじゃ", "ないか！？"]}, {"box": [1112, 856, 1192, 1081], "vertical": true, "font_size": 32.0, "lines": ["ははは、", "残念だったねー。"]}, {"box": [937, 862, 1053, 1076], "vertical": true, "font_size": 32.0, "lines": ["怒られるのは", "たぶん高木さん", "だけだよ。"]}, {"box": [500, 886, 532, 1052], "vertical": true, "font_size": 32.0, "lines": ["そうかもね。"]}, {"box": [129, 1466, 180, 1528], "vertical": true, "font_size": 32.0, "lines": ["わ。"]}], "img_path": "065.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "066.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [571, 498, 667, 757], "vertical": true, "font_size": 32.0, "lines": ["共犯に", "なっちゃったね。"]}, {"box": [1087, 951, 1164, 1135], "vertical": true, "font_size": 32.0, "lines": ["でも、きっと", "大丈夫だよ。"]}, {"box": [553, 995, 633, 1121], "vertical": true, "font_size": 32.0, "lines": ["かいぐい", "くらい。"]}, {"box": [982, 1340, 1189, 1588], "vertical": true, "font_size": 32.0, "lines": ["まぁ、でも", "オレをまきこんで", "までかいぐい", "したかった", "なんて、"]}, {"box": [407, 1411, 576, 1653], "vertical": true, "font_size": 30.0, "lines": ["高木さんも", "けっこう", "ビビってたんじゃ", "ないの？"]}], "img_path": "067.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1208, 122, 1238, 258], "vertical": true, "font_size": 26.0, "lines": ["そうだね。"]}, {"box": [564, 247, 682, 444], "vertical": true, "font_size": 32.0, "lines": ["だからまた", "かいぐい", "つきあってよ。"]}, {"box": [828, 1306, 864, 1459], "vertical": true, "font_size": 32.0, "lines": ["いいけど．．．"]}, {"box": [645, 1288, 684, 1415], "vertical": true, "font_size": 32.0, "lines": ["やったー。"]}, {"box": [506, 1355, 616, 1526], "vertical": true, "font_size": 32.0, "lines": ["じゃあ明日は", "からあげ", "かなー。"]}, {"box": [343, 1509, 393, 1610], "vertical": true, "font_size": 32.0, "lines": ["明日！？"]}], "img_path": "068.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "069.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [588, 1725, 1220, 1781], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さん"]}], "img_path": "070.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [783, 716, 864, 774], "vertical": false, "font_size": 22.0, "lines": ["「まぁいい"]}], "img_path": "071.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [671, 489, 752, 650], "vertical": true, "font_size": 32.0, "lines": ["アスパラ、", "じゃがいも、"]}, {"box": [519, 513, 635, 733], "vertical": true, "font_size": 32.0, "lines": ["とうふに卵に", "しょうゆと牛乳", "七味っと。"]}, {"box": [386, 508, 429, 579], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [1027, 1380, 1117, 1470], "vertical": true, "font_size": 32.0, "lines": ["や、", "西片。"]}], "img_path": "072.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [928, 101, 979, 231], "vertical": true, "font_size": 32.0, "lines": ["高木さん。"]}, {"box": [618, 80, 749, 240], "vertical": true, "font_size": 32.0, "lines": ["西片も", "晩ごはんの", "おつかい？"]}, {"box": [457, 105, 577, 262], "vertical": true, "font_size": 32.0, "lines": ["そー、よく", "行かされ", "ててさ。"]}, {"box": [266, 112, 318, 191], "vertical": true, "font_size": 32.0, "lines": ["へー、"]}, {"box": [148, 125, 223, 279], "vertical": true, "font_size": 32.0, "lines": ["晩ごはんの", "献立は？"]}, {"box": [1042, 690, 1160, 909], "vertical": true, "font_size": 31.0, "lines": ["うーんなんだろ、", "このメモじゃ", "わかんないな．．．"]}, {"box": [879, 718, 958, 873], "vertical": true, "font_size": 31.0, "lines": ["何作る気", "なんだろ．．．"]}, {"box": [311, 723, 355, 935], "vertical": true, "font_size": 32.0, "lines": ["高木さんちは？"]}, {"box": [1092, 1183, 1175, 1432], "vertical": true, "font_size": 32.0, "lines": ["ウチは", "オムライスだよ。"]}, {"box": [390, 1193, 484, 1406], "vertical": true, "font_size": 32.0, "lines": ["久々だから", "楽しみなんだ。"]}, {"box": [89, 1110, 210, 1305], "vertical": true, "font_size": 32.0, "lines": ["オムライスかー", "いいねー．．．"]}, {"box": [483, 1545, 603, 1831], "vertical": true, "font_size": 32.0, "lines": ["レタトマトキャバッグ作がＧＰにおこしイーズとりには、"]}], "img_path": "073.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1101, 94, 1228, 453], "vertical": true, "font_size": 32.0, "lines": ["タストマトキャベツ『牛が７９４Ｐにおこし』チーズといにください！"]}, {"box": [819, 110, 864, 245], "vertical": true, "font_size": 32.0, "lines": ["高木さん。"]}, {"box": [397, 144, 493, 319], "vertical": true, "font_size": 32.0, "lines": ["勝負", "しないかい。"]}, {"box": [1168, 935, 1205, 1005], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [603, 945, 828, 1171], "vertical": true, "font_size": 32.0, "lines": ["先に", "おつかいの品を", "そろえて会計を", "すませた方の", "勝ち。"]}, {"box": [1110, 1462, 1155, 1624], "vertical": true, "font_size": 32.0, "lines": ["ルート決め、"]}, {"box": [806, 1458, 907, 1571], "vertical": true, "font_size": 32.0, "lines": ["歩きの", "速さ、"]}, {"box": [463, 1486, 601, 1653], "vertical": true, "font_size": 32.0, "lines": ["そして", "商品探しの", "嗅覚、"]}, {"box": [256, 1503, 375, 1629], "vertical": true, "font_size": 32.0, "lines": ["それらを", "駆使した", "勝負さ。"]}], "img_path": "074.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1134, 202, 1181, 286], "vertical": true, "font_size": 32.0, "lines": ["うん、"]}, {"box": [684, 221, 723, 331], "vertical": true, "font_size": 32.0, "lines": ["いいよ。"]}, {"box": [545, 236, 583, 414], "vertical": true, "font_size": 32.0, "lines": ["かかったぁ。"]}, {"box": [129, 82, 594, 118], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高ホさんの"]}, {"box": [971, 740, 1175, 1014], "vertical": true, "font_size": 32.0, "lines": ["メモを見るに、", "どう考えても", "高木さんの方が", "集めなきゃいけない", "品数が多い。"]}, {"box": [692, 753, 853, 997], "vertical": true, "font_size": 32.0, "lines": ["ルート決めとか", "歩きの速さなんて", "まやかしで", "言ったのさ。"]}, {"box": [292, 744, 381, 931], "vertical": true, "font_size": 32.0, "lines": ["これは確実に", "勝ったな．．．"]}, {"box": [549, 1473, 587, 1673], "vertical": true, "font_size": 32.0, "lines": ["それじゃあ、"]}], "img_path": "075.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [755, 120, 834, 268], "vertical": true, "font_size": 32.0, "lines": ["スタート", "しよっか。"]}, {"box": [514, 127, 557, 319], "vertical": true, "font_size": 32.0, "lines": ["なぁああ。"]}, {"box": [832, 1032, 866, 1156], "vertical": true, "font_size": 32.0, "lines": ["それは．．．"]}, {"box": [365, 993, 483, 1209], "vertical": true, "font_size": 32.0, "lines": ["ん？", "おつかい途中の", "カゴだけど？"]}, {"box": [155, 1031, 200, 1108], "vertical": true, "font_size": 32.0, "lines": ["な．．．"]}, {"box": [1085, 1509, 1172, 1678], "vertical": true, "font_size": 32.0, "lines": ["外に西片", "見えたから、"]}, {"box": [240, 1518, 412, 1768], "vertical": true, "font_size": 32.0, "lines": ["長いメモ見せたら", "勝負挑んで", "くるかと思って", "隠しといたんだよ。"]}], "img_path": "076.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [626, 151, 710, 287], "vertical": true, "font_size": 32.0, "lines": ["かかった", "ねえ。"]}, {"box": [493, 795, 536, 873], "vertical": true, "font_size": 32.0, "lines": ["いや、"]}, {"box": [80, 1110, 112, 1215], "vertical": true, "font_size": 32.0, "lines": ["まだだ。"]}, {"box": [1063, 1445, 1149, 1548], "vertical": true, "font_size": 32.0, "lines": ["ルート", "決め！！"]}, {"box": [795, 1464, 885, 1569], "vertical": true, "font_size": 32.0, "lines": ["歩きの", "速さ！！"]}, {"box": [435, 1430, 562, 1588], "vertical": true, "font_size": 32.0, "lines": ["そしてしょうひんさが", "商品探しの", "嗅覚！！"]}, {"box": [234, 1432, 354, 1560], "vertical": true, "font_size": 32.0, "lines": ["それらを", "駆使して", "勝つ．．．！！"]}], "img_path": "077.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1113, 178, 1185, 362], "vertical": true, "font_size": 30.0, "lines": ["まだオレが", "有利なハズ．．．"]}, {"box": [436, 159, 558, 331], "vertical": true, "font_size": 32.0, "lines": ["あ、西片", "がんばってる", "ねー。"]}, {"box": [1173, 821, 1211, 896], "vertical": true, "font_size": 32.0, "lines": ["あぁ。"]}, {"box": [751, 774, 825, 999], "vertical": true, "font_size": 29.0, "lines": ["めちゃくちゃ", "余裕そうなカオ。"]}, {"box": [553, 766, 681, 967], "vertical": true, "font_size": 32.0, "lines": ["．．．高木さん", "あといくつ", "残ってるの．．．？"]}, {"box": [165, 794, 200, 926], "vertical": true, "font_size": 31.0, "lines": ["んーとね、"]}, {"box": [289, 1293, 385, 1463], "vertical": true, "font_size": 32.0, "lines": ["あと、卵", "だけだね。"]}], "img_path": "078.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1119, 185, 1179, 390], "vertical": true, "font_size": 32.0, "lines": ["ヤバイ．．．"]}, {"box": [566, 163, 710, 322], "vertical": true, "font_size": 32.0, "lines": ["．．．", "片こ西の"]}, {"box": [494, 92, 536, 213], "vertical": true, "font_size": 26.0, "lines": ["西片は？"]}, {"box": [491, 350, 526, 476], "vertical": true, "font_size": 32.0, "lines": ["オレは．．．"]}, {"box": [63, 391, 142, 551], "vertical": true, "font_size": 32.0, "lines": ["こう", "なったら．．"]}, {"box": [1052, 821, 1125, 1044], "vertical": true, "font_size": 32.0, "lines": ["あと．．．", "４つくらいかな．．．"]}, {"box": [583, 416, 752, 660], "vertical": true, "font_size": 32.0, "lines": ["油", "・醤油・牛乳"]}, {"box": [155, 826, 325, 1044], "vertical": true, "font_size": 32.0, "lines": ["多めに言って", "高木さんの", "慢心を狙うしか", "ない．．！！"]}, {"box": [1027, 1378, 1057, 1473], "vertical": true, "font_size": 30.0, "lines": ["じゃあ。"]}, {"box": [571, 1363, 718, 1565], "vertical": true, "font_size": 32.0, "lines": ["頼む．．．！！", "油断してくれ", "高木さん。"]}, {"box": [448, 1432, 499, 1539], "vertical": true, "font_size": 32.0, "lines": ["卵．．．！！"]}], "img_path": "079.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [553, 110, 586, 208], "vertical": true, "font_size": 32.0, "lines": ["あら？"]}, {"box": [975, 1003, 1138, 1162], "vertical": true, "font_size": 32.0, "lines": ["あれ？", "もしかして", "売り切れ", "ちゃった？"]}, {"box": [345, 1029, 382, 1096], "vertical": true, "font_size": 32.0, "lines": ["え．．．"]}, {"box": [258, 1091, 303, 1149], "vertical": true, "font_size": 32.0, "lines": ["あ、"]}, {"box": [178, 1128, 217, 1230], "vertical": true, "font_size": 32.0, "lines": ["うん．．．"]}, {"box": [1100, 1477, 1215, 1646], "vertical": true, "font_size": 32.0, "lines": ["卵がこれで", "売り切れって", "ことは、"]}, {"box": [738, 1466, 815, 1659], "vertical": true, "font_size": 26.0, "lines": ["もう高木さんは", "そろわない．．．"]}, {"box": [586, 1458, 658, 1655], "vertical": true, "font_size": 32.0, "lines": ["オレの", "勝ちなのでは．．"]}, {"box": [151, 1492, 185, 1601], "vertical": true, "font_size": 32.0, "lines": ["そっか。"]}], "img_path": "080.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [629, 84, 699, 293], "vertical": true, "font_size": 31.0, "lines": ["ウチは", "オムライズだよ。"]}, {"box": [85, 112, 164, 292], "vertical": true, "font_size": 28.0, "lines": ["久々だから", "楽しみなんだ。"]}, {"box": [110, 427, 210, 631], "vertical": true, "font_size": 32.0, "lines": ["スタマトレドキャイヤーがＧＩＰしかったと！！"]}, {"box": [868, 1190, 1016, 1340], "vertical": false, "font_size": 32.0, "lines": ["新鮮"]}, {"box": [800, 1297, 1145, 1567], "vertical": false, "font_size": 32.0, "lines": ["それでも、", "そこではあなたは"]}], "img_path": "081.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [716, 125, 798, 238], "vertical": true, "font_size": 32.0, "lines": ["これ．．", "どうぞ。"]}, {"box": [1134, 956, 1173, 1059], "vertical": true, "font_size": 32.0, "lines": ["その．．．"]}, {"box": [568, 958, 637, 1121], "vertical": true, "font_size": 30.0, "lines": ["オムライス", "なんだよね。"]}, {"box": [342, 944, 640, 1156], "vertical": false, "font_size": 32.0, "lines": ["オムライスなんだよね。ウチの奥ごはんなんなのか知らないし．．．"]}, {"box": [348, 941, 468, 1158], "vertical": true, "font_size": 30.0, "lines": ["ウチの晩ごはん", "なんなのか", "知らないし．．"]}, {"box": [251, 1175, 322, 1449], "vertical": true, "font_size": 30.0, "lines": ["たぶん卵なくても", "どうにかなるから．．．"]}], "img_path": "082.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1029, 301, 1108, 429], "vertical": true, "font_size": 32.0, "lines": ["バカだな", "オレは．．"]}, {"box": [172, 313, 294, 476], "vertical": true, "font_size": 32.0, "lines": ["せっかく", "勝てる勝負", "だったのに、"]}, {"box": [112, 536, 185, 727], "vertical": true, "font_size": 32.0, "lines": ["自分から", "負けるなんて。"]}, {"box": [487, 1061, 594, 1166], "vertical": false, "font_size": 32.0, "lines": ["ねぇ西片。"]}, {"box": [408, 1569, 576, 1725], "vertical": true, "font_size": 32.0, "lines": ["ヤバイ．．．", "これは", "罰ゲームの", "流れ．．"]}], "img_path": "083.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1160, 144, 1284, 301], "vertical": true, "font_size": 32.0, "lines": ["ひ．．．ひ", "引き分けに", "しない！？"]}, {"box": [435, 88, 521, 303], "vertical": true, "font_size": 31.0, "lines": ["売り切れなんて", "想定外だしさ！"]}, {"box": [157, 106, 243, 288], "vertical": true, "font_size": 32.0, "lines": ["無効試合って", "ことで！！"]}, {"box": [1031, 1462, 1162, 1648], "vertical": true, "font_size": 32.0, "lines": ["えー", "どうしよっか", "なー。"]}, {"box": [315, 1498, 393, 1636], "vertical": true, "font_size": 32.0, "lines": ["そこを", "なんとか。"]}], "img_path": "084.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1102, 181, 1190, 337], "vertical": true, "font_size": 32.0, "lines": ["引き分けに", "したいの？"]}, {"box": [684, 222, 717, 375], "vertical": true, "font_size": 32.0, "lines": ["できれば．．．"]}, {"box": [508, 101, 542, 210], "vertical": true, "font_size": 32.0, "lines": ["ふーん。"]}, {"box": [61, 93, 192, 341], "vertical": true, "font_size": 32.0, "lines": ["引き分けに", "したいなら", "しょーがないなー。"]}, {"box": [1037, 841, 1158, 1010], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "引き分けに", "してあげる。"]}, {"box": [840, 811, 958, 1061], "vertical": true, "font_size": 32.0, "lines": ["そのかわりに荷物", "片っぽ", "持ってくれない？"]}, {"box": [836, 1121, 868, 1263], "vertical": true, "font_size": 32.0, "lines": ["重くてさ。"]}, {"box": [211, 883, 290, 1072], "vertical": true, "font_size": 32.0, "lines": ["おやすい", "ごようです！！"]}, {"box": [1070, 1483, 1187, 1647], "vertical": true, "font_size": 30.0, "lines": ["よかったー、", "言ってみる", "もんだな"]}], "img_path": "085.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1106, 230, 1183, 333], "vertical": true, "font_size": 32.0, "lines": ["これ．．", "どうぞ。"]}, {"box": [750, 155, 907, 352], "vertical": true, "font_size": 29.0, "lines": ["西片の勝ちで", "いいよって", "言おうとしたん", "だけどなぁ。"]}, {"box": [1127, 967, 1177, 1100], "vertical": true, "font_size": 32.0, "lines": ["え、何？"]}, {"box": [1030, 1381, 1145, 1587], "vertical": true, "font_size": 28.0, "lines": ["この持ち方って", "恋人がよく", "やってるよねー。"]}, {"box": [230, 1393, 375, 1617], "vertical": true, "font_size": 29.0, "lines": ["ちょっと！！", "持たせた後で", "そういうこと", "言うのやめてよ！"]}], "img_path": "086.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "087.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [301, 112, 361, 208], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [764, 826, 804, 950], "vertical": true, "font_size": 32.0, "lines": ["待った？"]}, {"box": [601, 776, 646, 856], "vertical": true, "font_size": 32.0, "lines": ["いや。"]}, {"box": [146, 772, 303, 950], "vertical": true, "font_size": 32.0, "lines": ["ふっ。", "来たな", "高木さん。"]}, {"box": [573, 1336, 665, 1446], "vertical": true, "font_size": 32.0, "lines": ["昨日の", "メール"]}, {"box": [270, 1335, 390, 1423], "vertical": false, "font_size": 32.0, "lines": ["高木さん"]}, {"box": [556, 1642, 585, 1670], "vertical": false, "font_size": 21.0, "lines": ["さ"]}, {"box": [521, 1715, 538, 1730], "vertical": false, "font_size": 15.0, "lines": ["え"]}, {"box": [459, 1747, 481, 1771], "vertical": false, "font_size": 23.0, "lines": ["そ"]}, {"box": [300, 1410, 547, 1606], "vertical": false, "font_size": 30.0, "lines": ["西片最近", "休日の朝に", "「「「．．．」ランニングしてる", "っていってたよね", "明日私も", "ついてっていい？"]}, {"box": [146, 1586, 223, 1692], "vertical": true, "font_size": 32.0, "lines": ["あれは", "つまり、"]}], "img_path": "088.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1119, 100, 1204, 253], "vertical": true, "font_size": 31.0, "lines": ["勝負って", "ことだな！！"]}, {"box": [615, 116, 740, 270], "vertical": true, "font_size": 32.0, "lines": ["受けて", "立とうじゃ", "ないか。"]}, {"box": [481, 69, 564, 227], "vertical": true, "font_size": 32.0, "lines": ["それで", "どうする？"]}, {"box": [148, 82, 221, 333], "vertical": true, "font_size": 32.0, "lines": ["んー、", "じゃあ、"]}, {"box": [949, 700, 1109, 892], "vertical": true, "font_size": 32.0, "lines": ["どっちかが", "ギブアップ", "するまで", "走るってのは、"]}, {"box": [260, 733, 301, 834], "vertical": true, "font_size": 32.0, "lines": ["どう？"]}, {"box": [1151, 1201, 1192, 1307], "vertical": true, "font_size": 32.0, "lines": ["いいよ。"]}, {"box": [864, 1215, 900, 1252], "vertical": true, "font_size": 32.0, "lines": ["！？"]}, {"box": [692, 1243, 812, 1496], "vertical": true, "font_size": 32.0, "lines": ["どう考えても", "オレが勝ちそうな", "ルール．．．！？"]}, {"box": [425, 1237, 547, 1410], "vertical": true, "font_size": 32.0, "lines": ["じゃあ", "よーい", "スタートー。"]}, {"box": [172, 1248, 288, 1434], "vertical": true, "font_size": 32.0, "lines": ["いや、しかし", "高木さんの", "ことだ．．．"]}, {"box": [168, 1496, 288, 1655], "vertical": true, "font_size": 32.0, "lines": ["なにか", "策があるに", "違いない！！"]}], "img_path": "089.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1100, 232, 1147, 320], "vertical": true, "font_size": 32.0, "lines": ["はー、"]}, {"box": [305, 348, 341, 514], "vertical": true, "font_size": 32.0, "lines": ["ギブアップ。"]}, {"box": [174, 1110, 228, 1185], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}], "img_path": "090.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1083, 118, 1197, 271], "vertical": true, "font_size": 30.0, "lines": ["なんだ．．．", "こんなに", "すんなり．．．"]}, {"box": [613, 103, 697, 258], "vertical": true, "font_size": 32.0, "lines": ["ギブアップ", "って。"]}, {"box": [456, 86, 528, 244], "vertical": true, "font_size": 32.0, "lines": ["うん", "ギブアップ。"]}, {"box": [525, 380, 607, 534], "vertical": true, "font_size": 30.0, "lines": ["なんの策も", "なかった！？"]}, {"box": [93, 135, 125, 271], "vertical": true, "font_size": 32.0, "lines": ["疲れたや。"]}, {"box": [56, 341, 133, 481], "vertical": true, "font_size": 32.0, "lines": ["西片体力", "あるね。"]}, {"box": [1016, 695, 1128, 817], "vertical": true, "font_size": 32.0, "lines": ["けっこう", "走った", "よねー。"]}, {"box": [860, 703, 965, 871], "vertical": true, "font_size": 32.0, "lines": ["こんなとこ", "走ってくるの", "初めてだよ。"]}, {"box": [300, 701, 367, 851], "vertical": true, "font_size": 29.0, "lines": ["いや、うん", "そうだけど。"]}, {"box": [1035, 1186, 1196, 1316], "vertical": true, "font_size": 32.0, "lines": ["えっと．．．", "オレの．．．", "勝ちって", "こと．．．？"]}, {"box": [770, 1168, 812, 1245], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [423, 1226, 514, 1430], "vertical": true, "font_size": 32.0, "lines": ["勝負なんて", "言ったっけ？"]}], "img_path": "091.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1235, 112, 1269, 161], "vertical": true, "font_size": 32.0, "lines": ["あ"]}, {"box": [812, 122, 850, 288], "vertical": true, "font_size": 32.0, "lines": ["言ってない。"]}, {"box": [363, 157, 480, 295], "vertical": true, "font_size": 31.0, "lines": ["勝負じゃ", "なかったの", "かぁあ。"]}, {"box": [601, 862, 688, 1025], "vertical": true, "font_size": 32.0, "lines": ["今日．．．", "なんで．．．？"]}, {"box": [163, 455, 280, 686], "vertical": true, "font_size": 32.0, "lines": ["あれ．．．でも", "勝負じゃなかった", "ってコトは、"]}, {"box": [684, 1291, 775, 1463], "vertical": true, "font_size": 32.0, "lines": ["今日学校", "ないからね。"]}], "img_path": "092.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1119, 103, 1194, 231], "vertical": true, "font_size": 32.0, "lines": ["どういう", "こと．．．？"]}, {"box": [832, 76, 864, 185], "vertical": true, "font_size": 32.0, "lines": ["さぁー。"]}, {"box": [1102, 815, 1147, 947], "vertical": true, "font_size": 32.0, "lines": ["ああー。"]}, {"box": [532, 481, 558, 554], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．"]}, {"box": [603, 804, 646, 877], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [159, 780, 191, 1003], "vertical": true, "font_size": 32.0, "lines": ["やっちゃったー．．．"]}, {"box": [1049, 1445, 1187, 1638], "vertical": true, "font_size": 32.0, "lines": ["今日", "観たいアニメ", "あったんだ．．"]}, {"box": [431, 1468, 646, 1685], "vertical": true, "font_size": 32.0, "lines": ["何も考えずに", "まっすぐ走って", "きたし、戻るの", "間に合わなそう", "だなぁ．．．"]}, {"box": [148, 1464, 180, 1572], "vertical": true, "font_size": 32.0, "lines": ["あらら。"]}], "img_path": "093.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [757, 123, 896, 290], "vertical": true, "font_size": 32.0, "lines": ["西片、浅に", "小銭とか", "持ってる？"]}, {"box": [421, 170, 472, 247], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [292, 228, 403, 425], "vertical": true, "font_size": 32.0, "lines": ["飲み物代くらい", "なら持って", "きてるけど。"]}, {"box": [1143, 1100, 1272, 1258], "vertical": true, "font_size": 32.0, "lines": ["バス乗るの", "久しぶり", "だなー。"]}, {"box": [718, 1123, 750, 1231], "vertical": true, "font_size": 32.0, "lines": ["オレも。"]}, {"box": [480, 1076, 600, 1305], "vertical": true, "font_size": 32.0, "lines": ["あの．．．ゴメン。", "疲れてるのに", "急がせちゃって。"]}], "img_path": "094.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1014, 61, 1192, 324], "vertical": true, "font_size": 31.0, "lines": ["んーん、私も", "ヘトヘトで帰るの", "しんどいなって", "思ってたからちょうど", "よかったよ。"]}, {"box": [562, 86, 708, 321], "vertical": true, "font_size": 32.0, "lines": ["それより", "バス代の残り", "合わせて飲み物", "買えてよかったね。"]}, {"box": [274, 106, 304, 152], "vertical": true, "font_size": 30.0, "lines": ["ん。"]}, {"box": [262, 95, 313, 163], "vertical": false, "font_size": 32.0, "lines": ["ん。"]}, {"box": [61, 91, 105, 165], "vertical": true, "font_size": 32.0, "lines": ["ん？"]}, {"box": [1113, 663, 1206, 810], "vertical": true, "font_size": 32.0, "lines": ["先飲んで", "いいよ。"]}, {"box": [699, 663, 789, 924], "vertical": true, "font_size": 32.0, "lines": ["間接キス", "恥ずかしいでしょ。"]}, {"box": [1113, 1316, 1194, 1531], "vertical": true, "font_size": 32.0, "lines": ["高木さんの方が", "疲れてるし、"]}, {"box": [993, 1368, 1082, 1483], "vertical": true, "font_size": 32.0, "lines": ["お先に", "どうぞ。"]}, {"box": [532, 958, 652, 1111], "vertical": true, "font_size": 32.0, "lines": ["べ．．．べつに", "恥ずかしく", "ないし．．．"]}, {"box": [517, 1355, 643, 1471], "vertical": true, "font_size": 32.0, "lines": ["そう？", "じゃあ", "お先に。"]}, {"box": [236, 1370, 354, 1524], "vertical": true, "font_size": 32.0, "lines": ["アニメに", "間に合うと", "いいねー。"]}, {"box": [112, 1548, 140, 1701], "vertical": true, "font_size": 26.0, "lines": ["．．．そうだね。"]}], "img_path": "095.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [148, 1036, 349, 1279], "vertical": true, "font_size": 32.0, "lines": ["寝ちゃった", "のか．．．", "ヘトヘトって", "言ってたもんな"]}], "img_path": "096.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1038, 1044, 1160, 1216], "vertical": true, "font_size": 32.0, "lines": ["今日、", "なんだったん", "だろ．．．"]}, {"box": [872, 1111, 982, 1282], "vertical": true, "font_size": 32.0, "lines": ["勝負しかけて", "くるわけでも", "ないし。"]}, {"box": [601, 1245, 708, 1477], "vertical": true, "font_size": 30.0, "lines": ["かといって", "からかいまくって", "くるわけでもなし。"]}, {"box": [232, 1074, 313, 1226], "vertical": true, "font_size": 32.0, "lines": ["今日学校", "ないからね。"]}], "img_path": "097.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1128, 101, 1250, 375], "vertical": true, "font_size": 32.0, "lines": ["もしかして．．．", "オレに会いたかった", "とか．．．？"]}], "img_path": "098.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1029, 221, 1081, 461], "vertical": true, "font_size": 32.0, "lines": ["次は〝自岩〟ー。"]}, {"box": [221, 401, 436, 650], "vertical": true, "font_size": 32.0, "lines": ["次の停留所で", "お降りのお客様は", "ボタンを押して", "お知らせ", "ください。"]}, {"box": [1098, 1035, 1183, 1136], "vertical": true, "font_size": 32.0, "lines": ["つ．．．っき", "次か．．．"]}, {"box": [930, 1014, 1044, 1230], "vertical": true, "font_size": 32.0, "lines": ["なんとか", "アニメ間に合い", "そうだな。"]}], "img_path": "099.jpg"}, {"version": "0.1.6", "img_width": 1354, "img_height