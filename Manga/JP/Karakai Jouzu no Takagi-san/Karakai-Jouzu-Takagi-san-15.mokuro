 15.0, "lines": ["いいんだよ。"]}, {"box": [679, 952, 698, 1050], "vertical": true, "font_size": 18.0, "lines": ["でもさぁ．．．"]}, {"box": [137, 956, 159, 1042], "vertical": true, "font_size": 19.0, "lines": ["だからね、"]}], "img_path": "149.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [342, 100, 401, 249], "vertical": true, "font_size": 24.0, "lines": ["私も一緒に", "散歩していい？"]}, {"box": [333, 375, 354, 479], "vertical": true, "font_size": 20.0, "lines": ["．．．いいけど。"]}, {"box": [665, 682, 712, 779], "vertical": true, "font_size": 22.0, "lines": ["．．．．．", "どこ行く？"]}, {"box": [267, 689, 316, 766], "vertical": true, "font_size": 22.0, "lines": ["どこでも", "いいよ。"]}, {"box": [194, 694, 214, 799], "vertical": true, "font_size": 22.0, "lines": ["私んちでも。"]}, {"box": [237, 1157, 598, 1177], "vertical": false, "font_size": 20.0, "lines": ["一からかい上手の高木さん田・完"]}, {"box": [132, 898, 158, 963], "vertical": true, "font_size": 26.0, "lines": ["ええ！？"]}], "img_path": "150.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "151.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [195, 92, 588, 196], "vertical": false, "font_size": 32.0, "lines": ["ま", "ん"]}, {"box": [652, 304, 688, 359], "vertical": true, "font_size": 32.0, "lines": ["へー、"]}, {"box": [158, 308, 205, 427], "vertical": true, "font_size": 18.0, "lines": ["こんなゲーム", "あったのかー。"]}, {"box": [670, 739, 697, 808], "vertical": true, "font_size": 25.0, "lines": ["よーし、"]}, {"box": [138, 755, 213, 868], "vertical": true, "font_size": 20.0, "lines": ["ランキングが", "全部ぼくに", "なったぞ。"]}], "img_path": "152.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [80, 51, 373, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [633, 531, 654, 594], "vertical": true, "font_size": 18.0, "lines": ["！！"]}, {"box": [639, 863, 714, 949], "vertical": true, "font_size": 25.0, "lines": ["こりゃあ", "故障", "ですねー。"]}], 