{"version": "0.2.0-beta.6", "title": "Karakai Jouzu no Takagi-san", "title_uuid": "8b310d10-25a6-4fdb-aaef-cacc33c51c4b", "volume": "Karakai-Jouzu-Takagi-san-15", "volume_uuid": "24c4b78f-92a9-4ce5-966f-30d03a452c90", "pages": [{"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [759, 55, 827, 805], "vertical": true, "font_size": 32.0, "lines": ["ならない上手の言木さんの山本袋町"]}, {"box": [637, 1153, 814, 1170], "vertical": false, "font_size": 14.0, "lines": ["ＳＮＡＴＡＲＴＡＴＩＳＴＥＲＴＥＣＳＰＩＣＩＩ"]}], "img_path": "001.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "002.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [549, 56, 576, 141], "vertical": true, "font_size": 25.0, "lines": ["はい１００円。"]}, {"box": [383, 70, 478, 161], "vertical": true, "font_size": 21.0, "lines": ["終わったら", "肉か野菜の", "ところに", "来てねー。"]}, {"box": [260, 52, 303, 154], "vertical": true, "font_size": 18.0, "lines": ["たぶんそこに", "いるから。"]}, {"box": [112, 78, 134, 128], "vertical": true, "font_size": 22.0, "lines": ["うん。"]}, {"box": [369, 636, 434, 808], "vertical": true, "font_size": 27.0, "lines": ["今日は", "何しよっかなー。"]}, {"box": [619, 1140, 738, 1163], "vertical": false, "font_size": 23.0, "lines": ["ランキング"]}], "img_path": "003.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [316, 1062, 811, 1179], "vertical": false, "font_size": 32.0, "lines": ["ランキング"]}], "img_path": "004.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "005.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [645, 49, 665, 117], "vertical": true, "font_size": 20.0, "lines": ["うーん。"]}, {"box": [552, 31, 595, 195], "vertical": true, "font_size": 20.0, "lines": ["これも", "あきちゃったしなー。"]}, {"box": [110, 70, 177, 208], "vertical": true, "font_size": 18.0, "lines": ["おかしとるやつも", "あんまり", "気分じゃないし。"]}, {"box": [701, 447, 725, 489], "vertical": true, "font_size": 24.0, "lines": ["ん？"]}], "img_path": "006.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [541, 57, 612, 126], "vertical": false, "font_size": 32.0, "lines": ["はい１００円。"]}, {"box": [422, 49, 470, 181], "vertical": true, "font_size": 21.0, "lines": ["じゃあ", "いってきまーす"]}, {"box": [64, 71, 90, 188], "vertical": true, "font_size": 20.0, "lines": ["走らないの！"]}, {"box": [701, 733, 726, 796], "vertical": true, "font_size": 25.0, "lines": ["ふふふ。"]}, {"box": [401, 733, 426, 796], "vertical": true, "font_size": 25.0, "lines": ["いいぞ。"]}, {"box": [302, 744, 323, 812], "vertical": true, "font_size": 21.0, "lines": ["あぁー。"]}, {"box": [15, 691, 270, 864], "vertical": false, "font_size": 32.0, "lines": ["Ｇｏｏｇｌｅ"]}, {"box": [292, 959, 343, 1078], "vertical": true, "font_size": 24.0, "lines": ["いやー、でも", "新記録だな。"]}, {"box": [45, 1008, 67, 1094], "vertical": true, "font_size": 20.0, "lines": ["やったぞ。"]}], "img_path": "007.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [701, 50, 746, 189], "vertical": true, "font_size": 17.0, "lines": ["特におもしろくも", "ないゲームだし、"]}, {"box": [528, 56, 597, 196], "vertical": true, "font_size": 19.0, "lines": ["だれも", "やってはいないん", "だろうけど、"]}, {"box": [421, 70, 469, 176], "vertical": true, "font_size": 20.0, "lines": ["だがそこが", "いいんだ"]}, {"box": [190, 57, 211, 140], "vertical": true, "font_size": 20.0, "lines": ["なぜなら、"]}, {"box": [639, 493, 719, 679], "vertical": true, "font_size": 20.0, "lines": ["スコアランキングが", "全てぼくで", "うまってるのが、"]}, {"box": [434, 570, 515, 592], "vertical": false, "font_size": 20.0, "lines": ["５ＧＯＲＥ"]}, {"box": [145, 529, 183, 670], "vertical": true, "font_size": 32.0, "lines": ["気持ちい．．．"]}, {"box": [316, 546, 585, 857], "vertical": false, "font_size": 32.0, "lines": ["．．．", "ちょっといっちゃらりのひとりできないで", "５４０００の１５年２２月２３日日から３日目１０時３０１５", "Ｃｏｐｙｒｉｃｈの", "３０１５６２３", "そのようなころではまたやりこともできなかったようだ", "いただけでなくなったので何度もありませんでしたね", "２０１２年に", "１５日目について", "こちらっっ", "．．．"]}, {"box": [208, 563, 342, 860], "vertical": true, "font_size": 32.0, "lines": ["バイルＯＮＨＨＨＭＨＡＭ１２３１５Ｈ５Ｅ７７８９", "ｇＴＨ", "．．．"]}, {"box": [448, 990, 475, 1072], "vertical": true, "font_size": 26.0, "lines": ["あれ！？"]}, {"box": [329, 964, 379, 1079], "vertical": true, "font_size": 21.0, "lines": ["ティー．．．", "ケー．．．ジー！？"]}, {"box": [63, 945, 265, 1112], "vertical": false, "font_size": 32.0, "lines": ["．．．でもいいでね"]}], "img_path": "008.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [706, 84, 733, 195], "vertical": true, "font_size": 25.0, "lines": ["くそ．．．！！"]}, {"box": [311, 87, 389, 222], "vertical": true, "font_size": 19.0, "lines": ["ぼくの名前で", "うまってた", "ランキングが．．"]}, {"box": [253, 55, 273, 120], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．？"]}, {"box": [185, 266, 267, 296], "vertical": false, "font_size": 30.0, "lines": ["月日の"]}, {"box": [538, 534, 619, 636], "vertical": true, "font_size": 26.0, "lines": ["そう、", "１位だから", "いいさ。"]}, {"box": [213, 323, 256, 396], "vertical": true, "font_size": 18.0, "lines": ["ま．．．まぁ", "いいさ．．．"]}, {"box": [77, 323, 124, 448], "vertical": true, "font_size": 27.0, "lines": ["１位は"]}, {"box": [0, 247, 107, 458], "vertical": true, "font_size": 32.0, "lines": ["ぼくなんだし．．．", "「２３」", "１ｓ７"]}, {"box": [663, 761, 694, 832], "vertical": true, "font_size": 24.0, "lines": ["数日後。"]}, {"box": [214, 548, 240, 653], "vertical": true, "font_size": 20.0, "lines": ["１位だから。"]}, {"box": [209, 823, 236, 874], "vertical": true, "font_size": 27.0, "lines": ["な．．．"]}], "img_path": "009.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [727, 84, 781, 202], "vertical": true, "font_size": 27.0, "lines": ["１位", "とられてる！？"]}, {"box": [267, 55, 311, 133], "vertical": true, "font_size": 18.0, "lines": ["そんな．．．", "まさか．．．"]}, {"box": [670, 577, 718, 676], "vertical": true, "font_size": 24.0, "lines": ["お母さん！！", "もう１００円！！"]}, {"box": [555, 591, 608, 677], "vertical": true, "font_size": 24.0, "lines": ["一生の", "おねがい。"]}, {"box": [292, 566, 312, 676], "vertical": true, "font_size": 23.0, "lines": ["何言ってんの。"]}, {"box": [194, 610, 243, 707], "vertical": true, "font_size": 23.0, "lines": ["ほら", "荷物持って。"]}, {"box": [323, 847, 390, 989], "vertical": true, "font_size": 15.0, "lines": ["ケーティービーめ．．．"]}, {"box": [100, 851, 171, 975], "vertical": true, "font_size": 23.0, "lines": ["いや、", "ティービーケー", "だっけ．．．"]}], "img_path": "010.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [694, 104, 739, 237], "vertical": true, "font_size": 17.0, "lines": ["．．．まぁいいさ", "あんなゲーム．．．"]}, {"box": [367, 111, 410, 229], "vertical": true, "font_size": 17.0, "lines": ["そもそも", "ありきたりで、"]}, {"box": [301, 152, 343, 342], "vertical": true, "font_size": 17.0, "lines": ["そんなにおもしろくも", "なかったし。"]}, {"box": [82, 52, 374, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんＢ"]}, {"box": [185, 91, 264, 208], "vertical": true, "font_size": 22.0, "lines": ["次からは", "別のゲームを", "しよう。"]}, {"box": [26, 296, 104, 383], "vertical": true, "font_size": 22.0, "lines": ["そう、", "たのしい", "ゲームを"]}, {"box": [653, 884, 681, 981], "vertical": true, "font_size": 25.0, "lines": ["はい１００円。"]}], "img_path": "011.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [787, 58, 806, 162], "vertical": true, "font_size": 16.0, "lines": ["ありがとう。"]}, {"box": [206, 125, 235, 176], "vertical": true, "font_size": 25.0, "lines": ["あら、"]}, {"box": [120, 148, 172, 271], "vertical": true, "font_size": 25.0, "lines": ["今日は", "走らないのね。"]}, {"box": [673, 522, 694, 588], "vertical": true, "font_size": 21.0, "lines": ["ふふふ。"]}, {"box": [172, 530, 223, 673], "vertical": true, "font_size": 20.0, "lines": ["見ていろよ", "ティーケービー。"]}, {"box": [661, 834, 746, 969], "vertical": true, "font_size": 23.0, "lines": ["大切なブタを", "はかいしてきた", "から、"]}, {"box": [411, 835, 488, 1008], "vertical": true, "font_size": 23.0, "lines": ["なんと", "１０回もチャレンジが", "可能なのさ。"]}, {"box": [297, 855, 379, 973], "vertical": true, "font_size": 23.0, "lines": ["１位の座を", "うばい返して", "やる。"]}], "img_path": "012.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [172, 56, 193, 117], "vertical": true, "font_size": 21.0, "lines": ["あれ？"]}, {"box": [652, 588, 732, 712], "vertical": true, "font_size": 16.0, "lines": ["あぁ、そこのやつ？", "故障したから", "引きとって", "もらったよ。"]}, {"box": [667, 921, 685, 985], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．？"]}, {"box": [165, 933, 186, 1012], "vertical": true, "font_size": 21.0, "lines": ["そっか．．．"]}], "img_path": "013.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [742, 465, 795, 597], "vertical": true, "font_size": 17.0, "lines": ["西片負けたから", "何かおごりね。"]}, {"box": [398, 491, 419, 575], "vertical": true, "font_size": 20.0, "lines": ["はいはい"]}, {"box": [606, 896, 672, 985], "vertical": true, "font_size": 21.0, "lines": ["あ、なんか", "ゲーム", "増えてる。"]}, {"box": [172, 901, 191, 978], "vertical": true, "font_size": 16.0, "lines": ["ホントだ。"]}], "img_path": "014.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [723, 56, 743, 170], "vertical": true, "font_size": 17.0, "lines": ["あ、これかー"]}, {"box": [515, 78, 571, 157], "vertical": true, "font_size": 26.0, "lines": ["懐かしい", "なー。"]}, {"box": [393, 161, 435, 178], "vertical": false, "font_size": 14.0, "lines": ["５００ＲＥ"]}, {"box": [283, 58, 330, 154], "vertical": true, "font_size": 18.0, "lines": ["やったコト", "あるんだ。"]}, {"box": [85, 77, 144, 148], "vertical": true, "font_size": 25.0, "lines": ["何回か", "だけね。"]}, {"box": [43, 227, 115, 315], "vertical": true, "font_size": 25.0, "lines": ["あんまり", "面白く", "ないけど。"]}, {"box": [563, 526, 584, 591], "vertical": true, "font_size": 21.0, "lines": ["ふーん"]}, {"box": [246, 529, 317, 644], "vertical": true, "font_size": 19.0, "lines": ["どっかで", "見たコト", "あるような：："]}, {"box": [167, 530, 183, 658], "vertical": true, "font_size": 19.0, "lines": ["なんだっけ．．．？"]}, {"box": [452, 858, 480, 925], "vertical": true, "font_size": 26.0, "lines": ["いっか。"]}, {"box": [93, 864, 113, 897], "vertical": true, "font_size": 19.0, "lines": ["え。"]}, {"box": [670, 863, 742, 1007], "vertical": true, "font_size": 17.0, "lines": ["まぁどこにでも", "ありそうな", "ゲームだし、"]}, {"box": [267, 885, 311, 998], "vertical": true, "font_size": 21.0, "lines": ["やって", "みよっかなー。"]}], "img_path": "015.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [636, 93, 706, 208], "vertical": true, "font_size": 23.0, "lines": ["なんで．．．？", "面白く", "ないんでしょ。"]}, {"box": [438, 103, 491, 219], "vertical": true, "font_size": 20.0, "lines": ["懐かしいから", "記念にねー。"]}, {"box": [331, 94, 398, 223], "vertical": true, "font_size": 18.0, "lines": ["あ、そうだ", "罰ゲームとして", "これやらせてよ。"]}, {"box": [217, 103, 265, 185], "vertical": true, "font_size": 24.0, "lines": ["えー", "いいけど。"]}, {"box": [438, 619, 513, 710], "vertical": false, "font_size": 32.0, "lines": ["！！"]}, {"box": [230, 799, 320, 921], "vertical": true, "font_size": 20.0, "lines": ["ホントに", "面白く", "なさそうな", "ゲームだなー．．．"]}], "img_path": "016.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [666, 79, 740, 186], "vertical": true, "font_size": 20.0, "lines": ["これスコア", "競うゲーム", "だからさ、"]}, {"box": [351, 94, 432, 220], "vertical": true, "font_size": 25.0, "lines": ["後から西片も", "やって", "勝負しようよ。"]}, {"box": [112, 107, 161, 213], "vertical": true, "font_size": 22.0, "lines": ["えー、いいよ", "オレは。"]}, {"box": [693, 454, 748, 525], "vertical": true, "font_size": 29.0, "lines": ["そっか、", "残念。"]}, {"box": [347, 459, 399, 604], "vertical": true, "font_size": 25.0, "lines": ["あー", "おわっちゃった。"]}, {"box": [675, 841, 753, 938], "vertical": true, "font_size": 24.0, "lines": ["あ、", "ランキング", "入ってる"]}, {"box": [360, 858, 385, 926], "vertical": true, "font_size": 28.0, "lines": ["えっと、"]}, {"box": [267, 892, 325, 1003], "vertical": true, "font_size": 28.0, "lines": ["名前", "入れてっと。"]}], "img_path": "017.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [678, 60, 725, 174], "vertical": true, "font_size": 21.0, "lines": ["お、やったー", "１位だって。"]}, {"box": [381, 66, 411, 120], "vertical": true, "font_size": 27.0, "lines": ["おー。"]}, {"box": [700, 560, 746, 656], "vertical": true, "font_size": 20.0, "lines": ["なんか．．．", "どっかで．．"]}, {"box": [459, 555, 478, 666], "vertical": true, "font_size": 16.0, "lines": ["なんだっけ？"]}, {"box": [383, 544, 404, 659], "vertical": true, "font_size": 19.0, "lines": ["わかんない．．．"]}, {"box": [100, 549, 121, 690], "vertical": true, "font_size": 17.0, "lines": ["わかんないけど、"]}, {"box": [646, 861, 718, 1041], "vertical": true, "font_size": 19.0, "lines": ["なんかこのスコア：", "抜かなきゃいけない", "気がしてきた．．"]}, {"box": [161, 911, 216, 1020], "vertical": true, "font_size": 26.0, "lines": ["あ、結局", "やるんだね。"]}], "img_path": "018.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [67, 1100, 678, 1132], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さん『山本宗一朗"]}], "img_path": "019.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [670, 528, 774, 543], "vertical": false, "font_size": 15.0, "lines": ["ｏｎｔｅｎｔｓ"]}, {"box": [721, 694, 743, 823], "vertical": true, "font_size": 20.0, "lines": ["ランキング「"]}, {"box": [582, 694, 604, 824], "vertical": true, "font_size": 16.0, "lines": ["紙ヒコーキーの"]}, {"box": [438, 712, 465, 822], "vertical": true, "font_size": 24.0, "lines": ["シーン．．．？"]}, {"box": [301, 704, 324, 822], "vertical": true, "font_size": 16.0, "lines": ["けっこん．"]}, {"box": [162, 711, 183, 821], "vertical": true, "font_size": 21.0, "lines": ["豆まき"]}, {"box": [720, 972, 746, 1076], "vertical": true, "font_size": 26.0, "lines": ["サビ"]}, {"box": [581, 955, 604, 1028], "vertical": true, "font_size": 17.0, "lines": ["反射性は"]}, {"box": [442, 947, 464, 1071], "vertical": true, "font_size": 16.0, "lines": ["落としもの"]}, {"box": [304, 956, 320, 1027], "vertical": true, "font_size": 16.0, "lines": ["やさしさ"]}], "img_path": "020.jpg"}, {"version": "0.1.6", "img_width": 847, "