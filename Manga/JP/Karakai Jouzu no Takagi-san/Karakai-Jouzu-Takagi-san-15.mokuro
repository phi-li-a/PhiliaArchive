s": ["ふーん。"]}, {"box": [461, 796, 481, 862], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．．"]}, {"box": [118, 820, 173, 921], "vertical": true, "font_size": 32.0, "lines": ["くふっ"]}], "img_path": "024.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [625, 577, 679, 649], "vertical": true, "font_size": 27.0, "lines": ["あ、", "できた。"]}, {"box": [372, 558, 398, 693], "vertical": true, "font_size": 25.0, "lines": ["えええぇ！？"]}, {"box": [205, 563, 281, 643], "vertical": true, "font_size": 25.0, "lines": ["なんで！？", "何が", "違うの！？"]}, {"box": [119, 577, 140, 655], "vertical": true, "font_size": 25.0, "lines": ["投げ方！？"]}, {"box": [99, 872, 120, 939], "vertical": true, "font_size": 21.0, "lines": ["うーん。"]}], "img_path": "025.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [422, 89, 503, 234], "vertical": true, "font_size": 21.0, "lines": ["西片のヒコーキ、", "私のこと好き", "なんじゃないの。"]}, {"box": [105, 144, 137, 237], "vertical": true, "font_size": 21.0, "lines": ["何それ！！"]}, {"box": [651, 578, 725, 714], "vertical": true, "font_size": 23.0, "lines": ["マジメにさぁ！！", "オレ何か", "間違ってた！？"]}, {"box": [181, 570, 230, 657], "vertical": true, "font_size": 22.0, "lines": ["あはは、", "顔赤いよ。"]}, {"box": [113, 727, 172, 818], "vertical": true, "font_size": 30.0, "lines": ["赤く", "ないって。"]}, {"box": [702, 911, 748, 998], "vertical": true, "font_size": 18.0, "lines": ["しょうが", "ないなー"]}], "img_path": "026.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [708, 63, 734, 116], "vertical": true, "font_size": 26.0, "lines": ["はい。"]}, {"box": [247, 65, 346, 189], "vertical": true, "font_size": 20.0, "lines": ["これなら", "大丈夫だと", "思うから", "やってみてよ。"]}, {"box": [100, 246, 120, 276], "vertical": true, "font_size": 20.0, "lines": ["え。"]}, {"box": [730, 534, 744, 576], "vertical": true, "font_size": 14.0, "lines": ["．．．．．"]}, {"box": [366, 560, 391, 592], "vertical": true, "font_size": 25.0, "lines": ["あ、"]}, {"box": [641, 813, 688, 927], "vertical": true, "font_size": 20.0, "lines": ["これでもし", "成功したら．．"]}, {"box": [275, 796, 373, 938], "vertical": true, "font_size": 20.0, "lines": ["そんなに私の", "ヒコーキに戻って", "きてほしかったん", "だねー。"]}, {"box": [104, 567, 127, 661], "vertical": true, "font_size": 21.0, "lines": ["わかった。"]}, {"box": [106, 829, 156, 935], "vertical": true, "font_size": 26.0, "lines": ["とか", "言う気だな。"]}], "img_path": "027.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [693, 104, 745, 199], "vertical": true, "font_size": 20.0, "lines": ["その手には", "のるか．．．"]}, {"box": [492, 96, 586, 219], "vertical": true, "font_size": 23.0, "lines": ["いや．．．", "オレはさっきの", "自分の", "作ったので．．"]}, {"box": [366, 130, 448, 234], "vertical": true, "font_size": 24.0, "lines": ["私さっき", "西片ので", "成功したし、"]}, {"box": [217, 97, 292, 250], "vertical": true, "font_size": 23.0, "lines": ["私のヒコーキで", "西片が成功したら", "引き分け。"]}, {"box": [90, 130, 153, 372], "vertical": true, "font_size": 23.0, "lines": ["失敗したり、", "薬権", "するなら、"]}, {"box": [385, 607, 453, 683], "vertical": true, "font_size": 32.0, "lines": ["西片の", "負け。"]}, {"box": [670, 875, 742, 1030], "vertical": true, "font_size": 21.0, "lines": ["このタイミングで", "勝負に", "するとは．．．"]}, {"box": [114, 894, 164, 996], "vertical": true, "font_size": 22.0, "lines": ["やるな", "高木さんめ"]}], "img_path": "028.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [673, 112, 753, 227], "vertical": true, "font_size": 21.0, "lines": ["成功しても", "からかわれる", "し．．．"]}, {"box": [442, 132, 495, 229], "vertical": true, "font_size": 18.0, "lines": ["失敗したら", "負け．．．か"]}, {"box": [305, 107, 377, 221], "vertical": true, "font_size": 17.0, "lines": ["どっちも", "負けみたいな", "もんだな．．．"]}, {"box": [647, 460, 701, 597], "vertical": true, "font_size": 26.0, "lines": ["完全に", "してやられた．．．"]}, {"box": [98, 480, 224, 596], "vertical": true, "font_size": 20.0, "lines": ["こうなったら", "オレに", "できるのは", "普通に投げる", "ことだけだ．．．"]}, {"box": [691, 901, 741, 1010], "vertical": true, "font_size": 27.0, "lines": ["ぬぬ．．．"]}, {"box": [367, 942, 442, 1039], "vertical": true, "font_size": 22.0, "lines": ["どうせまた", "失敗だろう", "けど．．．"]}], "img_path": "029.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "030.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [309, 97, 336, 150], "vertical": true, "font_size": 27.0, "lines": ["おー。"]}, {"box": [656, 648, 706, 764], "vertical": true, "font_size": 23.0, "lines": ["よかったねー", "西片ー。"]}, {"box": [585, 673, 606, 758], "vertical": true, "font_size": 23.0, "lines": ["成功だね。"]}, {"box": [685, 923, 706, 1002], "vertical": true, "font_size": 21.0, "lines": ["きっと．．．"]}, {"box": [403, 978, 424, 1015], "vertical": true, "font_size": 21.0, "lines": ["！"]}], "img_path": "031.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [749, 115, 787, 301], "vertical": true, "font_size": 32.0, "lines": ["やったー！！"]}, {"box": [347, 257, 380, 441], "vertical": true, "font_size": 32.0, "lines": ["できたーー！！"]}, {"box": [692, 812, 746, 966], "vertical": true, "font_size": 22.0, "lines": ["今の投げ方が", "よかったのかな．．．"]}, {"box": [380, 802, 455, 946], "vertical": true, "font_size": 21.0, "lines": ["いや、高木さんの", "作り方が", "よかったのかも。"]}, {"box": [283, 801, 331, 900], "vertical": true, "font_size": 21.0, "lines": ["どっちだと", "思う？！"]}, {"box": [160, 881, 181, 950], "vertical": true, "font_size": 21.0, "lines": ["えっと。"]}], "img_path": "032.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [632, 101, 754, 229], "vertical": true, "font_size": 23.0, "lines": ["西片の", "ヒコーキの", "折り方、一か所", "違うとこが", "あったから。"]}, {"box": [523, 110, 552, 164], "vertical": true, "font_size": 25.0, "lines": ["あぁ、"]}, {"box": [433, 111, 483, 229], "vertical": true, "font_size": 25.0, "lines": ["そうだったん", "だ！！"]}, {"box": [333, 101, 380, 234], "vertical": true, "font_size": 20.0, "lines": ["いやー、でも", "うれしいなー！！"]}, {"box": [658, 569, 707, 667], "vertical": true, "font_size": 24.0, "lines": ["しまった．．．", "つい．．．"]}, {"box": [390, 950, 411, 1056], "vertical": true, "font_size": 20.0, "lines": ["よかったね。"]}], "img_path": "033.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [705, 103, 746, 197], "vertical": true, "font_size": 16.0, "lines": ["あ．．．うん．．．", "ありがとう"]}, {"box": [521, 111, 542, 171], "vertical": true, "font_size": 21.0, "lines": ["あれ？"]}, {"box": [389, 108, 461, 231], "vertical": true, "font_size": 20.0, "lines": ["からかいが", "くると", "思ってたのに、"]}, {"box": [125, 120, 148, 162], "vertical": true, "font_size": 23.0, "lines": ["ん？"]}, {"box": [342, 522, 391, 619], "vertical": true, "font_size": 21.0, "lines": ["あ．．．いや", "なんでも．．．"]}, {"box": [708, 542, 731, 659], "vertical": true, "font_size": 20.0, "lines": ["どうかした？"]}, {"box": [98, 535, 151, 668], "vertical": true, "font_size": 18.0, "lines": ["考えすぎ", "だったのか．．．？"]}, {"box": [643, 885, 715, 1003], "vertical": true, "font_size": 22.0, "lines": ["もしかして．．．", "高木さんて", "意外と．．．"]}], "img_path": "034.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [636, 84, 685, 162], "vertical": true, "font_size": 22.0, "lines": ["お、また", "いけた。"]}, {"box": [434, 55, 575, 173], "vertical": true, "font_size": 23.0, "lines": ["あんなに", "無邪気に", "喜ばれたら、"]}, {"box": [80, 93, 103, 237], "vertical": true, "font_size": 20.0, "lines": ["からかえないよ。"]}, {"box": [670, 569, 699, 616], "vertical": true, "font_size": 26.0, "lines": ["え？"]}, {"box": [142, 561, 164, 629], "vertical": true, "font_size": 22.0, "lines": ["さぁー。"]}, {"box": [582, 587, 632, 667], "vertical": true, "font_size": 26.0, "lines": ["なんか", "言った？"]}, {"box": [357, 918, 405, 994], "vertical": true, "font_size": 21.0, "lines": ["お、また", "成功だ。"]}], "img_path": "035.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [528, 80, 601, 178], "vertical": true, "font_size": 20.0, "lines": ["なんかコツ", "掴んだ気が", "するなー。"]}, {"box": [372, 229, 422, 336], "vertical": true, "font_size": 24.0, "lines": ["おおー", "戻ってくる。"]}, {"box": [112, 215, 137, 283], "vertical": true, "font_size": 22.0, "lines": ["ははは。"]}, {"box": [135, 345, 159, 452], "vertical": true, "font_size": 22.0, "lines": ["すごいなー。"]}, {"box": [575, 617, 703, 768], "vertical": true, "font_size": 22.0, "lines": ["西片が", "私のヒコーキに", "戻ってきてほし", "がりすぎるんじゃ", "ない？"]}, {"box": [468, 624, 497, 660], "vertical": true, "font_size": 29.0, "lines": ["え、"]}, {"box": [262, 639, 301, 690], "vertical": true, "font_size": 32.0, "lines": ["今！？"]}, {"box": [126, 648, 176, 770], "vertical": true, "font_size": 24.0, "lines": ["ガマン", "できなかった。"]}], "img_path": "036.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "037.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [681, 69, 714, 123], "vertical": true, "font_size": 26.0, "lines": ["はー。"]}, {"box": [556, 60, 637, 195], "vertical": true, "font_size": 26.0, "lines": ["昨日の", "「１００％片想い」の", "アニメ．．．"]}, {"box": [111, 103, 190, 219], "vertical": true, "font_size": 22.0, "lines": ["名シーン", "ばかりだった", "なあ。"]}, {"box": [656, 548, 734, 708], "vertical": true, "font_size": 23.0, "lines": ["イケ男の", "バトルシーンも", "かっこよかったし、"]}, {"box": [720, 846, 740, 917], "vertical": true, "font_size": 20.0, "lines": ["それに．．．"]}, {"box": [466, 851, 495, 887], "vertical": true, "font_size": 29.0, "lines": ["あ、"]}, {"box": [128, 569, 186, 697], "vertical": true, "font_size": 30.0, "lines": ["犬も", "取り戻せたし。"]}, {"box": [538, 870, 591, 933], "vertical": true, "font_size": 27.0, "lines": ["にーし", "かた。"]}, {"box": [113, 858, 146, 952], "vertical": true, "font_size": 25.0, "lines": ["高木さ．．．"]}], "img_path": "038.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [269, 115, 303, 294], "vertical": true, "font_size": 26.0, "lines": ["わ、", "驚いた。"]}, {"box": [82, 52, 373, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [645, 473, 695, 539], "vertical": true, "font_size": 24.0, "lines": ["まさか", "西片が"]}, {"box": [145, 476, 192, 637], "vertical": true, "font_size": 20.0, "lines": ["こんなのに", "ひっかかるなんて。"]}, {"box": [684, 926, 735, 1034], "vertical": true, "font_size": 23.0, "lines": ["あ！！これは", "昨日の！"]}, {"box": [277, 883, 325, 978], "vertical": true, "font_size": 18.0, "lines": ["高木さんも", "観てたんだ。"]}, {"box": [162, 882, 185, 928], "vertical": true, "font_size": 22.0, "lines": ["うん。"]}, {"box": [99, 877, 119, 986], "vertical": true, "font_size": 22.0, "lines": ["面白かったね。"]}], "img_path": "039.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [707, 93, 788, 221], "vertical": true, "font_size": 24.0, "lines": ["特に", "あのシーン", "よかったなー。"]}, {"box": [534, 90, 583, 181], "vertical": true, "font_size": 20.0, "lines": ["あんなの", "されたら、"]}, {"box": [115, 112, 173, 246], "vertical": true, "font_size": 20.0, "lines": ["私もきっと", "テレちゃうな。"]}, {"box": [725, 894, 752, 1008], "vertical": true, "font_size": 16.0, "lines": ["高木さんが．．．"]}, {"box": [455, 897, 473, 972], "vertical": true, "font_size": 17.0, "lines": ["テレる！？"]}, {"box": [285, 911, 400, 1078], "vertical": true, "font_size": 22.0, "lines": ["オレは今、", "ものすごい情報を", "知ってしまった", "のでは。"]}], "img_path": "040.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [677, 50, 748, 168], "vertical": true, "font_size": 21.0, "lines": ["ち．．．", "ちなみに", "どのシーン．．．？"]}, {"box": [447, 90, 511, 192], "vertical": true, "font_size": 32.0, "lines": ["もしオレにできるようなコトなら．．．"]}, {"box": [444, 89, 510, 192], "vertical": true, "font_size": 19.0, "lines": ["もしオレに", "できるような", "コトなら．．．"]}, {"box": [339, 118, 388, 215], "vertical": true, "font_size": 19.0, "lines": ["高木さんに", "勝てる．．"]}, {"box": [693, 426, 714, 492], "vertical": true, "font_size": 20.0, "lines": ["じゃあ、"]}, {"box": [549, 483, 644, 598], "vertical": true, "font_size": 20.0, "lines": ["これかなって", "思うやつ", "シーン再現", "してみてよ。"]}, {"box": [141, 464, 222, 562], "vertical": true, "font_size": 22.0, "lines": ["合ってたら", "正解って", "言うから。"]}, {"box": [707, 849, 739, 1012], "vertical": true, "font_size": 28.0, "lines": ["シーン再現．．．！？"]}, {"box": [407, 840, 481, 965], "vertical": true, "font_size": 21.0, "lines": ["うん、さっき", "私がやった", "みたいなやつ。"]}], "img_path": "041.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [745, 49, 789, 182], "vertical": true, "font_size": 19.0, "lines": ["テレるシーンと", "いうなら．．．"]}, {"box": [616, 59, 688, 192], "vertical": true, "font_size": 19.0, "lines": ["これかなって", "やつはだいたい", "見当はつく．．．"]}, {"box": [529, 83, 548, 180], "vertical": true, "font_size": 16.0, "lines": ["おそらく．．．"]}, {"box": [125, 80, 199, 215], "vertical": true, "font_size": 23.0, "lines": ["あごをクイって", "やる", "あのシーン。"]}, {"box": [650, 590, 755, 690], "vertical": true, "font_size": 22.0, "lines": ["でも", "そんなもん", "できるわけ", "ないだろ．．"]}, {"box": [262, 616, 338, 759], "vertical": true, "font_size": 21.0, "lines": ["あれ？", "どうしたの", "固まっちゃって。"]}, {"box": [193, 653, 213, 768], "vertical": true, "font_size": 21.0, "lines": ["やらないの？"]}, {"box": [653, 943, 727, 1078], "vertical": true, "font_size": 23.0, "lines": ["も．．", "もう少し", "考えようかな．．．"]}, {"box": [187, 978, 212, 1048], "vertical": true, "font_size": 25.0, "lines": ["ふーん。"]}], "img_path": "042.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [404, 91, 451, 214], "vertical": true, "font_size": 20.0, "lines": ["いつでも", "かかってきな。"]}, {"box": [188, 166, 251, 242], "vertical": false, "font_size": 18.5, "lines": ["終こんじゃ", "．．．"]}, {"box": [72, 86, 127, 182], "vertical": true, "font_size": 23.0, "lines": ["イケ男の", "再現で．．．！！"]}, {"box": [592, 550, 657, 645], "vertical": true, "font_size": 26.0, "lines": ["高木さん", "めぇえ。"]}], "img_path": "043.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [556, 32, 633, 188], "vertical": true, "font_size": 22.0, "lines": ["く．．．やはり", "危険を冒してでも", "やるべきか．．．"]}, {"box": [452, 69, 497, 183], "vertical": true, "font_size": 20.0, "lines": ["でももし", "違ってたら．．．"]}, {"box": [132, 113, 154, 263], "vertical": true, "font_size": 20.0, "lines": ["ハズカしすぎる。"]}, {"box": [661, 575, 681, 651], "vertical": true, "font_size": 20.0, "lines": ["ぐぬぬ．．．"]}, {"box": [723, 803, 749, 857], "vertical": true, "font_size": 26.0, "lines": ["えい。"]}, {"box": [429, 801, 458, 882], "vertical": true, "font_size": 26.0, "lines": ["わはっ。"]}, {"box": [353, 800, 384, 862], "vertical": true, "font_size": 25.0, "lines": ["何を！！"]}, {"box": [99, 805, 154, 942], "vertical": true, "font_size": 26.0, "lines": ["ふふ、", "びっくりした？"]}], "img_path": "044.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [686, 73, 735, 150], "vertical": true, "font_size": 24.0, "lines": ["いつもの", "お返し。"]}, {"box": [228, 62, 284, 160], "vertical": true, "font_size": 26.0, "lines": ["キュン子の", "再現！！"]}, {"box": [641, 574, 713, 764], "vertical": true, "font_size": 19.0, "lines": ["ていうか", "いつもやられてるのは", "オレなんだけど、"]}, {"box": [728, 935, 746, 1012], "vertical": true, "font_size": 17.0, "lines": ["くそー．．．"]}, {"box": [97, 922, 154, 976], "vertical": true, "font_size": 32.0, "lines": ["いや", "待て。"]}], "img_path": "045.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [719, 105, 799, 243], "vertical": true, "font_size": 32.0, "lines": ["失敗したな", "高木さん。"]}, {"box": [318, 96, 374, 239], "vertical": true, "font_size": 24.0, "lines": ["今高木さんが", "やったシーンは"]}, {"box": [94, 116, 167, 214], "vertical": true, "font_size": 24.0, "lines": ["あごクイの", "直前の", "シーン！！"]}, {"box": [600, 532, 721, 717], "vertical": true, "font_size": 25.0, "lines": ["これならオレでも", "流れで", "いけるんじゃ", "ないか．．．！？"]}, {"box": [406, 864, 433, 909], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [128, 591, 173, 711], "vertical": true, "font_size": 32.0, "lines": ["ふふ．．．"]}, {"box": [335, 855, 354, 970], "vertical": true, "font_size": 16.0, "lines": ["どうしたの？"]}], "img_path": "046.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [722, 440, 742, 516], "vertical": true, "font_size": 20.0, "lines": ["オレは．．．"]}, {"box": [365, 539, 454, 638], "vertical": true, "font_size": 29.0, "lines": ["今日", "高木さんに", "勝つ。"]}], "img_path": "047.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [782, 67, 807, 137], "vertical": true, "font_size": 22.0, "lines": ["おっと。"]}, {"box": [677, 77, 752, 175], "vertical": true, "font_size": 22.0, "lines": ["ちゃんと", "しまって", "なかった．．．"]}, {"box": [253, 68, 282, 215], "vertical": true, "font_size": 29.0, "lines": ["ムリー"]}, {"box": [712, 652, 730, 733], "vertical": true, "font_size": 16.0, "lines": ["ムリだ！！"]}, {"box": [107, 646, 226, 754], "vertical": true, "font_size": 25.0, "lines": ["勝手", "流れでとか", "思ったけど", "絶対ムリ"]}], "img_path": "048.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [609, 508, 711, 653], "vertical": true, "font_size": 24.0, "lines": ["やはり", "オレは．．．いっしゃったか", "一生高木さんに", "勝てないのか．．"]}, {"box": [718, 854, 739, 930], "vertical": true, "font_size": 20.0, "lines": ["なんだ？"]}, {"box": [399, 843, 460, 988], "vertical": true, "font_size": 30.0, "lines": ["急に", "いいニオイが．．．"]}], "img_path": "049.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [764, 708, 794, 746], "vertical": true, "font_size": 30.0, "lines": ["あ、"]}, {"box": [473, 704, 531, 832], "vertical": true, "font_size": 30.0, "lines": ["正解", "されちゃった。"]}], "img_path": "050.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [397, 58, 418, 125], "vertical": true, "font_size": 22.0, "lines": ["あーあ。"]}, {"box": [272, 52, 351, 169], "vertical": true, "font_size": 22.0, "lines": ["西片に", "テレさせられ", "ちゃったよ。"]}, {"box": [360, 310, 413, 398], "vertical": true, "font_size": 22.0, "lines": ["じゃ教室", "行こっか。"]}, {"box": [675, 570, 734, 686], "vertical": true, "font_size": 23.0, "lines": ["壁ドンの方", "だったのか．．．"]}, {"box": [318, 847, 336, 911], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．．"]}, {"box": [119, 575, 167, 682], "vertical": true, "font_size": 24.0, "lines": ["でもなんで", "自分で．．．"]}, {"box": [700, 843, 752, 977], "vertical": true, "font_size": 26.0, "lines": ["いや．．．", "なんでもいい！！"]}, {"box": [380, 863, 453, 962], "vertical": true, "font_size": 21.0, "lines": ["とにかくなき", "高木さんを", "テレさせ．．．"]}], "img_path": "051.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [638, 77, 690, 175], "vertical": true, "font_size": 26.0, "lines": ["いや．．．", "見れない．．"]}, {"box": [461, 48, 477, 167], "vertical": true, "font_size": 17.0, "lines": ["恥ずかしくて．．．"]}, {"box": [346, 44, 413, 185], "vertical": true, "font_size": 17.0, "lines": ["これじゃホントに", "テレてるか", "どうかが．．．"]}, {"box": [156, 234, 226, 371], "vertical": true, "font_size": 19.0, "lines": ["そうか．．．", "これがわかってて", "自分から．．．"]}, {"box": [106, 359, 126, 475], "vertical": true, "font_size": 19.0, "lines": ["高木さんめ．．．"]}, {"box": [360, 603, 489, 733], "vertical": true, "font_size": 28.0, "lines": ["また、", "壁ドン", "したく", "なったらさ、"]}, {"box": [679, 887, 721, 998], "vertical": true, "font_size": 18.0, "lines": ["いつでも", "かかってきな。"]}, {"box": [105, 896, 153, 1030], "vertical": true, "font_size": 22.0, "lines": ["できるわけ", "ないでしょー"]}], "img_path": "052.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [423, 1017, 754, 1099], "vertical": false, "font_size": 32.0, "lines": ["けっこん"]}], "img_path": "053.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [556, 69, 635, 222], "vertical": true, "font_size": 18.0, "lines": ["また木村が", "くだらないもの", "送ってきたかな．．．"]}, {"box": [679, 624, 698, 708], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．"]}, {"box": [427, 768, 571, 833], "vertical": false, "font_size": 29.0, "lines": ["腹筋われた。"]}, {"box": [151, 642, 172, 737], "vertical": true, "font_size": 20.0, "lines": ["やっぱり．．．"]}, {"box": [649, 918, 748, 1024], "vertical": true, "font_size": 20.0, "lines": ["なんだよー", "まんが、", "いいシーン", "なのにさー"]}, {"box": [189, 912, 415, 1121], "vertical": false, "font_size": 28.0, "lines": ["今日、田辺先生が", "キゲンよかったのって", "プロポーズ成功した", "かららしいぜ。", "近々けっこんする", "らしい。"]}], "img_path": "054.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [687, 97, 719, 173], "vertical": true, "font_size": 27.0, "lines": ["えぇ？"]}, {"box": [600, 99, 629, 239], "vertical": true, "font_size": 27.0, "lines": ["田辺先生が！？"]}, {"box": [110, 196, 137, 331], "vertical": true, "font_size": 23.0, "lines": ["けっこん！？"]}, {"box": [705, 451, 752, 581], "vertical": true, "font_size": 21.0, "lines": ["へぇー", "あの田辺先生が。"]}, {"box": [619, 458, 663, 585], "vertical": true, "font_size": 21.0, "lines": ["いやー、なんか", "おめでたいなー。"]}, {"box": [287, 451, 360, 659], "vertical": true, "font_size": 19.0, "lines": ["けっこんとか", "ぜんぜんわかんないけど", "なんかよかったー。"]}, {"box": [613, 836, 720, 992], "vertical": true, "font_size": 24.0, "lines": ["そうだ", "高木さん、", "このこと知ってる", "のかな。"]}, {"box": [142, 878, 198, 966], "vertical": true, "font_size": 23.0, "lines": ["教えて", "あげるか。"]}], "img_path": "055.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [541, 80, 561, 146], "vertical": true, "font_size": 20.0, "lines": ["そうだ。"]}, {"box": [301, 98, 420, 161], "vertical": false, "font_size": 32.0, "lines": ["高木さん"]}, {"box": [102, 105, 147, 246], "vertical": true, "font_size": 16.0, "lines": ["どうせなら", "勝負にしてやる。"]}, {"box": [214, 508, 241, 551], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [653, 615, 700, 693], "vertical": true, "font_size": 22.0, "lines": ["どしたの", "西片？"]}, {"box": [427, 989, 443, 1033], "vertical": true, "font_size": 16.0, "lines": ["．．．"]}, {"box": [288, 982, 318, 1041], "vertical": true, "font_size": 25.0, "lines": ["西片？"]}, {"box": [93, 978, 120, 1023], "vertical": true, "font_size": 27.0, "lines": ["あ．．．"]}], "img_path": "056.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [699, 76, 747, 144], "vertical": true, "font_size": 24.0, "lines": ["いや．．．", "えっと。"]}, {"box": [506, 65, 527, 142], "vertical": true, "font_size": 21.0, "lines": ["なんか．．．"]}, {"box": [281, 58, 385, 212], "vertical": true, "font_size": 22.0, "lines": ["奇遇だね、", "私も連絡しようと", "思ってたとこ", "なんだよ。"]}, {"box": [93, 64, 142, 182], "vertical": true, "font_size": 22.0, "lines": ["そ．．．", "そうなんだ．．．"]}, {"box": [630, 462, 708, 600], "vertical": true, "font_size": 24.0, "lines": ["なんか勢いで", "電話しちゃった", "けど、"]}, {"box": [510, 502, 586, 603], "vertical": true, "font_size": 24.0, "lines": ["声聞いたら", "ハズかしく", "なってきた。"]}, {"box": [644, 837, 692, 1001], "vertical": true, "font_size": 22.0, "lines": ["あれ？もしかして", "なんかテレてる？"]}, {"box": [146, 871, 220, 986], "vertical": true, "font_size": 20.0, "lines": ["い．．．いやいや", "そんなコト", "ないから。"]}], "img_path": "057.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [705, 49, 753, 222], "vertical": true, "font_size": 16.0, "lines": ["そ．．．それで高木さんは", "なんの用だったの．．．？"]}, {"box": [374, 85, 429, 180], "vertical": true, "font_size": 20.0, "lines": ["西片からで", "いいよ。"]}, {"box": [92, 97, 125, 145], "vertical": true, "font_size": 32.0, "lines": ["何？"]}, {"box": [672, 540, 698, 604], "vertical": true, "font_size": 26.0, "lines": ["では．．．"]}, {"box": [187, 558, 260, 594], "vertical": false, "font_size": 26.0, "lines": ["コホン"]}, {"box": [656, 775, 735, 931], "vertical": true, "font_size": 20.0, "lines": ["ウチの学校で", "近々けっこんする", "先生がいます。"]}, {"box": [174, 812, 201, 917], "vertical": true, "font_size": 20.0, "lines": ["誰でしょう。"]}], "img_path": "058.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [671, 59, 741, 174], "vertical": true, "font_size": 29.0, "lines": ["へぇー。"]}, {"box": [373, 78, 400, 203], "vertical": true, "font_size": 20.0, "lines": ["誰だろーなー。"]}, {"box": [698, 495, 747, 602], "vertical": true, "font_size": 20.0, "lines": ["これって", "勝負だよね。"]}, {"box": [386, 500, 459, 632], "vertical": true, "font_size": 19.0, "lines": ["ってことは", "意外な先生って", "ことかなー。"]}, {"box": [297, 495, 345, 611], "vertical": true, "font_size": 18.0, "lines": ["く．．．さすがに", "するどいな。"]}, {"box": [96, 510, 142, 588], "vertical": true, "font_size": 21.0, "lines": ["ヒントは", "なしで．．．"]}, {"box": [721, 815, 745, 858], "vertical": true, "font_size": 22.0, "lines": ["んー"]}, {"box": [653, 808, 675, 903], "vertical": true, "font_size": 22.0, "lines": ["そうだなー。"]}, {"box": [524, 815, 551, 900], "vertical": true, "font_size": 21.0, "lines": ["当てるな。"]}, {"box": [424, 796, 479, 900], "vertical": true, "font_size": 26.0, "lines": ["外してくれ", "高木さん！！"]}, {"box": [94, 817, 153, 907], "vertical": true, "font_size": 29.0, "lines": ["頼む！", "当たるな。"]}, {"box": [114, 1044, 136, 1110], "vertical": true, "font_size": 21.0, "lines": ["じゃあ、"]}], "img_path": "059.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [490, 93, 519, 179], "vertical": true, "font_size": 25.0, "lines": ["田辺先生。"]}, {"box": [380, 90, 407, 213], "vertical": true, "font_size": 25.0, "lines": ["がぁああ。"]}, {"box": [672, 605, 749, 670], "vertical": true, "font_size": 27.0, "lines": ["また．．", "オレは", "負け．．．"]}, {"box": [431, 628, 454, 752], "vertical": true, "font_size": 23.0, "lines": ["じゃなくてー。"]}, {"box": [315, 608, 337, 650], "vertical": true, "font_size": 22.0, "lines": ["お？"]}, {"box": [99, 631, 126, 717], "vertical": true, "font_size": 20.0, "lines": ["誰だろー。"]}, {"box": [718, 880, 745, 933], "vertical": true, "font_size": 26.0, "lines": ["おお。"]}, {"box": [582, 897, 686, 997], "vertical": true, "font_size": 26.0, "lines": ["いいぞ．．．たなべせんせい", "田辺先生が次々し", "選択肢から", "外れた．．．"]}, {"box": [107, 890, 158, 970], "vertical": true, "font_size": 24.0, "lines": ["こ．．", "これは．．"]}], "img_path": "060.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [606, 87, 634, 210], "vertical": true, "font_size": 20.0, "lines": ["月本先生かな。"]}, {"box": [365, 101, 446, 200], "vertical": true, "font_size": 21.0, "lines": ["なんか今日", "うれしそう", "だったし。"]}, {"box": [265, 48, 284, 130], "vertical": true, "font_size": 17.0, "lines": ["おおねお。"]}, {"box": [57, 52, 104, 227], "vertical": true, "font_size": 23.0, "lines": ["ファ．．．", "ファイナルアンサー？"]}, {"box": [266, 317, 283, 382], "vertical": true, "font_size": 17.0, "lines": ["．．．．．．？"]}, {"box": [697, 635, 729, 740], "vertical": true, "font_size": 24.0, "lines": ["月本先生で、"]}, {"box": [349, 658, 397, 752], "vertical": true, "font_size": 20.0, "lines": ["ファイナル", "アンサー"]}], "img_path": "061.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [668, 126, 724, 194], "vertical": true, "font_size": 27.0, "lines": ["答えは", "なんと、"]}, {"box": [192, 155, 258, 249], "vertical": true, "font_size": 26.0, "lines": ["田辺先生", "でした。"]}, {"box": [722, 686, 774, 767], "vertical": true, "font_size": 23.0, "lines": ["勝った．．．", "ついに．．．"]}, {"box": [495, 689, 524, 801], "vertical": true, "font_size": 21.0, "lines": ["高木さんに。"]}, {"box": [363, 675, 438, 789], "vertical": true, "font_size": 21.0, "lines": ["ありがとう", "ございます", "田辺先生．．．！！"]}, {"box": [93, 691, 173, 806], "vertical": true, "font_size": 24.0, "lines": ["そして", "おめでとう", "ございます！"]}, {"box": [503, 926, 602, 980], "vertical": false, "font_size": 32.0, "lines": ["高木さん"]}], "img_path": "062.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [661, 112, 739, 228], "vertical": true, "font_size": 24.0, "lines": ["いやー、ごめん", "残念だったね", "高木さん。"]}, {"box": [426, 214, 480, 309], "vertical": false, "font_size": 27.0, "lines": ["これとは"]}, {"box": [290, 116, 339, 178], "vertical": true, "font_size": 24.0, "lines": ["な．．．", "なに．．．"]}, {"box": [80, 51, 374, 75], "vertical": false, "font_size": 24.0, "lines": ["からかい上手の高ホさんは"]}, {"box": [636, 525, 742, 662], "vertical": true, "font_size": 24.0, "lines": ["西片、今", "バンザイ", "してたんだろう", "なって思って。"]}, {"box": [339, 510, 415, 643], "vertical": true, "font_size": 21.0, "lines": ["ははは、", "負けおしみかい", "高木さん。"]}, {"box": [94, 307, 146, 376], "vertical": true, "font_size": 27.0, "lines": ["ん？", "いやー。"]}, {"box": [103, 519, 128, 587], "vertical": true, "font_size": 22.0, "lines": ["んーん"]}, {"box": [98, 644, 146, 775], "vertical": true, "font_size": 22.0, "lines": ["負けおしみじゃ", "ないかな"]}, {"box": [374, 868, 426, 964], "vertical": true, "font_size": 20.0, "lines": ["だって私の", "勝ちだし。"]}, {"box": [110, 920, 136, 973], "vertical": true, "font_size": 26.0, "lines": ["へ？"]}], "img_path": "063.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [661, 114, 768, 238], "vertical": true, "font_size": 20.0, "lines": ["田辺先生が", "プロポーズ", "したのって", "月本先生だし"]}, {"box": [247, 60, 303, 154], "vertical": true, "font_size": 24.0, "lines": ["えええ", "ウソォ！？"]}, {"box": [671, 635, 724, 773], "vertical": true, "font_size": 21.0, "lines": ["あああ！！", "ホントだ．．．！！"]}, {"box": [361, 618, 580, 802], "vertical": false, "font_size": 31.0, "lines": ["しかも相手は", "月本のねーちゃん", "だってよ。", "なんかスゲーな"]}, {"box": [105, 629, 166, 745], "vertical": true, "font_size": 28.0, "lines": ["木村め", "今ごろ．．．！！"]}, {"box": [643, 882, 748, 980], "vertical": true, "font_size": 22.0, "lines": ["ぜ．．．全部", "知ってて．．．", "悩んでる", "フリを．．．"]}, {"box": [513, 888, 538, 942], "vertical": true, "font_size": 25.0, "lines": ["うん。"]}, {"box": [359, 896, 466, 1050], "vertical": true, "font_size": 21.0, "lines": ["だって私が西片に", "連絡しようと", "思ってたのも", "そのことだし。"]}, {"box": [101, 894, 123, 953], "vertical": true, "font_size": 22.0, "lines": ["えぇ！？"]}], "img_path": "064.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [627, 123, 752, 295], "vertical": true, "font_size": 20.0, "lines": ["．．．？", "つまり．．．", "高木さんもオレに", "この勝負をもちかけ", "ようと．．．"]}, {"box": [248, 35, 348, 171], "vertical": true, "font_size": 23.0, "lines": ["オレはただ", "高木さんからの", "連絡を", "待っていれば．．．"]}, {"box": [69, 97, 120, 232], "vertical": true, "font_size": 20.0, "lines": ["勝ってたという", "ことか．．．"]}, {"box": [617, 458, 695, 584], "vertical": true, "font_size": 26.0, "lines": ["いやー", "よかったよね、", "田辺先生。"]}, {"box": [397, 456, 412, 499], "vertical": true, "font_size": 15.0, "lines": ["．．．"]}, {"box": [261, 458, 281, 555], "vertical": true, "font_size": 20.0, "lines": ["そうだね．．．"]}, {"box": [659, 829, 679, 934], "vertical": true, "font_size": 20.0, "lines": ["うれしいね。"]}, {"box": [262, 816, 342, 921], "vertical": true, "font_size": 30.0, "lines": ["うん。"]}, {"box": [138, 795, 168, 894], "vertical": true, "font_size": 24.0, "lines": ["ねぇ西片。"]}], "img_path": "065.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [694, 86, 774, 243], "vertical": true, "font_size": 23.0, "lines": ["うれしい情報を", "真っ先に教えたく", "なる相手って、"]}, {"box": [401, 121, 457, 210], "vertical": true, "font_size": 22.0, "lines": ["好きな人", "らしいよ。"]}, {"box": [226, 48, 336, 167], "vertical": true, "font_size": 24.0, "lines": ["西片、", "真っ先に私に", "電話してきた", "よね。"]}, {"box": [92, 342, 125, 405], "vertical": true, "font_size": 31.0, "lines": ["なっ。"]}, {"box": [625, 607, 726, 732], "vertical": true, "font_size": 23.0, "lines": ["い．．いやいや。", "真っ先に", "電話は", "したけど、"]}, {"box": [197, 619, 275, 735], "vertical": true, "font_size": 22.0, "lines": ["それは", "勝負のためで", "あって！！"]}, {"box": [106, 645, 152, 779], "vertical": true, "font_size": 22.0, "lines": ["そういうんじゃ", "ないから。"]}, {"box": [605, 917, 709, 1004], "vertical": true, "font_size": 22.0, "lines": ["じゃ．．．", "じゃあ", "そろそろ", "切るから。"]}, {"box": [192, 933, 237, 1030], "vertical": true, "font_size": 18.0, "lines": ["うん、また", "あしたね"]}], "img_path": "066.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [304, 50, 352, 171], "vertical": true, "font_size": 32.0, "lines": ["うれしい情報を真っ先に．．．"]}, {"box": [303, 49, 349, 174], "vertical": true, "font_size": 24.0, "lines": ["うれしい情報を", "真っ先に．．．"]}, {"box": [201, 86, 250, 166], "vertical": true, "font_size": 24.0, "lines": ["たしかに", "最初は、"]}, {"box": [46, 322, 95, 418], "vertical": true, "font_size": 22.0, "lines": ["そうだった", "けど．．．"]}, {"box": [612, 598, 713, 722], "vertical": true, "font_size": 20.0, "lines": ["いやいや、", "でもオレは", "勝負のために", "電話したんだ。"]}, {"box": [128, 605, 207, 719], "vertical": true, "font_size": 24.0, "lines": ["そうさ、", "そんなんじゃ", "ない．．"]}, {"box": [715, 885, 735, 951], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．"]}, {"box": [362, 937, 414, 1070], "vertical": true, "font_size": 18.0, "lines": ["また負けた上に", "からかわれた．．．"]}], "img_path": "067.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [728, 43, 780, 178], "vertical": true, "font_size": 25.0, "lines": ["しかし", "惜しかったな．．．"]}, {"box": [578, 240, 754, 322], "vertical": false, "font_size": 17.0, "lines": ["田辺先生が月本先生に", "プロポーズしたんだって"]}, {"box": [392, 137, 502, 290], "vertical": true, "font_size": 20.0, "lines": ["高木さんから", "先に勝負しかけて", "くれてたら", "勝ってたのに．．．"]}, {"box": [152, 127, 187, 160], "vertical": false, "font_size": 32.0, "lines": ["あ"]}, {"box": [729, 310, 746, 326], "vertical": false, "font_size": 17.0, "lines": ["と"]}, {"box": [734, 344, 768, 376], "vertical": false, "font_size": 22.0, "lines": ["は"]}, {"box": [680, 371, 700, 386], "vertical": false, "font_size": 15.0, "lines": ["な"]}, {"box": [608, 345, 630, 369], "vertical": false, "font_size": 24.0, "lines": ["あ"]}, {"box": [636, 433, 651, 451], "vertical": false, "font_size": 18.0, "lines": ["ま"]}, {"box": [619, 591, 650, 707], "vertical": true, "font_size": 21.0, "lines": ["高木さんめ．．．"]}, {"box": [686, 930, 715, 997], "vertical": true, "font_size": 26.0, "lines": ["次の日。"]}, {"box": [585, 905, 630, 1001], "vertical": true, "font_size": 18.0, "lines": ["おはよー", "ございます、"]}, {"box": [445, 922, 466, 999], "vertical": true, "font_size": 21.0, "lines": ["ニーサン。"]}, {"box": [174, 932, 232, 1069], "vertical": true, "font_size": 26.0, "lines": ["学校では先生と", "呼べ、月本．．．"]}], "img_path": "068.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "069.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [369, 1078, 763, 1113], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さん"]}], "img_path": "070.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [522, 997, 567, 1019], "vertical": false, "font_size": 22.0, "lines": ["まめ"]}], "img_path": "071.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [386, 314, 469, 462], "vertical": true, "font_size": 24.0, "lines": ["今日、何月何日か", "知っているかい", "高木さん。"]}, {"box": [659, 858, 715, 938], "vertical": true, "font_size": 24.0, "lines": ["２月３日", "でしょ。"]}, {"box": [231, 885, 256, 948], "vertical": true, "font_size": 23.0, "lines": ["そう！"]}, {"box": [155, 878, 176, 943], "vertical": true, "font_size": 23.0, "lines": ["つまり、"]}], "img_path": "072.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [347, 105, 380, 233], "vertical": true, "font_size": 29.0, "lines": ["豆まきの日。"]}, {"box": [154, 585, 233, 666], "vertical": true, "font_size": 28.0, "lines": ["え！？", "なんで", "笑うの！？"]}, {"box": [140, 870, 161, 928], "vertical": true, "font_size": 21.0, "lines": ["ああ！"]}, {"box": [424, 890, 476, 995], "vertical": true, "font_size": 20.0, "lines": ["節分の日", "じゃないの"]}], "img_path": "073.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [712, 73, 756, 168], "vertical": true, "font_size": 18.0, "lines": ["くぅう．．．", "しまった．．．"]}, {"box": [490, 46, 598, 165], "vertical": true, "font_size": 21.0, "lines": ["考えてた", "勝負の内容が", "口に出て", "しまった．．"]}, {"box": [357, 63, 433, 161], "vertical": true, "font_size": 22.0, "lines": ["その", "間違い方は", "あれかな。"]}, {"box": [269, 62, 323, 203], "vertical": true, "font_size": 16.0, "lines": ["豆まき勝負でも", "考えてたのかな。"]}, {"box": [714, 478, 735, 579], "vertical": true, "font_size": 20.0, "lines": ["バレてるし"]}, {"box": [277, 515, 307, 621], "vertical": true, "font_size": 20.0, "lines": ["図星だねー。"]}, {"box": [207, 479, 225, 549], "vertical": true, "font_size": 18.0, "lines": ["．．．そう。"]}, {"box": [270, 662, 303, 717], "vertical": true, "font_size": 19.0, "lines": ["あはは"]}, {"box": [658, 883, 715, 955], "vertical": true, "font_size": 25.0, "lines": ["豆まき", "勝負さ。"]}, {"box": [144, 885, 228, 1033], "vertical": true, "font_size": 21.0, "lines": ["オレがオニ！！", "高木さんは", "豆を投げる人！"]}], "img_path": "074.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [610, 86, 740, 242], "vertical": true, "font_size": 23.0, "lines": ["オレの作った", "この豆っぽいのを", "１０個投げて全部", "よけられたら", "オレの勝ち！"]}, {"box": [350, 82, 425, 178], "vertical": true, "font_size": 23.0, "lines": ["当たったら", "高木さんの", "勝ち！"]}, {"box": [55, 111, 79, 178], "vertical": true, "font_size": 24.0, "lines": ["いいよ。"]}, {"box": [352, 303, 377, 375], "vertical": true, "font_size": 23.0, "lines": ["どう！？"]}, {"box": [652, 554, 728, 727], "vertical": true, "font_size": 23.0, "lines": ["ふふ．．．", "出バナを", "少しくじかれたが．．．"]}, {"box": [104, 577, 151, 691], "vertical": true, "font_size": 20.0, "lines": ["これでオレの", "勝ちだ。"]}, {"box": [603, 877, 736, 1032], "vertical": true, "font_size": 23.0, "lines": ["実はこの", "豆っぽいの、", "中身がスカスカで", "ちゃんと投げられ", "ないのさ。"]}, {"box": [125, 900, 235, 1016], "vertical": true, "font_size": 22.0, "lines": ["確認せずに", "勝負を受けた", "高木さんの", "負けだ。"]}], "img_path": "075.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [650, 44, 729, 128], "vertical": true, "font_size": 29.0, "lines": ["あ、でも", "始める", "前に、"]}, {"box": [474, 71, 529, 125], "vertical": true, "font_size": 28.0, "lines": ["な．．．", "なに。"]}, {"box": [234, 66, 329, 155], "vertical": true, "font_size": 22.0, "lines": ["まさか．．．", "豆のことが", "バレている", "のか。"]}, {"box": [649, 417, 705, 482], "vertical": true, "font_size": 32.0, "lines": ["オニの", "お面、"]}, {"box": [179, 444, 207, 529], "vertical": true, "font_size": 20.0, "lines": ["作ろうよ。"]}, {"box": [702, 774, 732, 817], "vertical": true, "font_size": 30.0, "lines": ["へ？"]}, {"box": [427, 765, 533, 881], "vertical": true, "font_size": 20.0, "lines": ["だって豆まき", "なんだから", "雰囲気は", "必要だよ。"]}, {"box": [328, 774, 376, 853], "vertical": true, "font_size": 23.0, "lines": ["バレては", "いない！"]}, {"box": [92, 787, 120, 832], "vertical": true, "font_size": 28.0, "lines": ["か．．"]}], "img_path": "076.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [684, 59, 717, 141], "vertical": true, "font_size": 30.0, "lines": ["勝った。"]}, {"box": [373, 87, 394, 211], "vertical": true, "font_size": 20.0, "lines": ["あぁ、いいよ。"]}, {"box": [267, 198, 320, 317], "vertical": true, "font_size": 27.0, "lines": ["はい、じゃあ", "これ。"]}, {"box": [93, 219, 118, 322], "vertical": true, "font_size": 20.0, "lines": ["オニ描いて。"]}, {"box": [666, 500, 686, 585], "vertical": true, "font_size": 20.0, "lines": ["はいはい。"]}, {"box": [295, 532, 367, 623], "vertical": true, "font_size": 21.0, "lines": ["ふふふ．．．", "いいものを", "描いて、"]}, {"box": [194, 542, 261, 649], "vertical": true, "font_size": 21.0, "lines": ["約束された", "勝利に花を", "そえておくか"]}], "img_path": "077.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [667, 57, 739, 188], "vertical": true, "font_size": 22.0, "lines": ["あはは、", "なんかかわいい", "オニだね。"]}, {"box": [421, 69, 496, 168], "vertical": true, "font_size": 25.0, "lines": ["ええ？", "強そう", "じゃない！？"]}, {"box": [322, 50, 378, 148], "vertical": true, "font_size": 22.0, "lines": ["なんか西片", "みたい。"]}, {"box": [94, 59, 144, 194], "vertical": true, "font_size": 22.0, "lines": ["バカにされてる", "気がする。"]}, {"box": [649, 458, 749, 610], "vertical": true, "font_size": 20.0, "lines": ["まさか", "オレを小バカに", "するために", "お面の提案を．．．？"]}, {"box": [493, 471, 521, 585], "vertical": true, "font_size": 20.0, "lines": ["高木さんめ．．．"]}, {"box": [380, 506, 439, 594], "vertical": true, "font_size": 30.0, "lines": ["不安", "なのだな。"]}, {"box": [657, 902, 734, 998], "vertical": true, "font_size": 22.0, "lines": ["負ける", "予感がして", "いるから、"]}, {"box": [135, 889, 266, 1043], "vertical": true, "font_size": 19.0, "lines": ["せめてその前に", "できるだけオレに", "ダメージを", "与えておこうと", "いったカンジか？"]}], "img_path": "078.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [638, 83, 664, 177], "vertical": true, "font_size": 21.0, "lines": ["いや待て！！"]}, {"box": [510, 114, 592, 217], "vertical": true, "font_size": 21.0, "lines": ["高木さんが", "そんなに", "弱いか！？"]}, {"box": [323, 110, 402, 207], "vertical": true, "font_size": 21.0, "lines": ["何かある．．", "何かあるぞ", "これは"]}, {"box": [146, 69, 250, 223], "vertical": true, "font_size": 23.0, "lines": ["じゃ、目のとこ", "穴あけて", "輪ゴムくっつける", "よ。"]}, {"box": [55, 126, 104, 249], "vertical": true, "font_size": 23.0, "lines": ["それで", "お面完成だね。"]}, {"box": [330, 857, 353, 900], "vertical": true, "font_size": 23.0, "lines": ["オ．．．"]}, {"box": [550, 856, 581, 952], "vertical": true, "font_size": 28.0, "lines": ["待って！！"]}, {"box": [92, 874, 141, 941], "vertical": true, "font_size": 24.0, "lines": ["オレが", "やるよ。"]}], "img_path": "079.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [733, 64, 790, 154], "vertical": true, "font_size": 25.0, "lines": ["ええ、", "いいよー。"]}, {"box": [679, 72, 699, 215], "vertical": true, "font_size": 25.0, "lines": ["やったげるって。"]}, {"box": [533, 73, 581, 215], "vertical": true, "font_size": 22.0, "lines": ["いやいや、", "オレのお面だし。"]}, {"box": [448, 60, 468, 146], "vertical": true, "font_size": 20.0, "lines": ["そっかー。"]}, {"box": [114, 64, 164, 151], "vertical": true, "font_size": 23.0, "lines": ["じゃあ", "よろしく。"]}, {"box": [462, 255, 482, 358], "vertical": true, "font_size": 20.0, "lines": ["わかったぞ。"]}, {"box": [103, 257, 156, 377], "vertical": true, "font_size": 21.0, "lines": ["だか", "高木さんの思う", "本当の狙い．．．"]}, {"box": [694, 584, 749, 705], "vertical": true, "font_size": 20.0, "lines": ["目の部分を", "小さくあけて、"]}, {"box": [104, 576, 208, 768], "vertical": true, "font_size": 19.0, "lines": ["オレの視界を", "さえぎって、よけられ", "ないようにするつもり", "だったんだな。"]}, {"box": [679, 917, 752, 1031], "vertical": true, "font_size": 21.0, "lines": ["しかしそれも", "今オレが", "つぶした。"]}, {"box": [360, 976, 417, 1092], "vertical": true, "font_size": 24.0, "lines": ["カンペキな", "勝利．．．！！"]}], "img_path": "080.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [691, 121, 753, 258], "vertical": true, "font_size": 24.0, "lines": ["この初勝利で", "オレは、"]}, {"box": [383, 70, 445, 269], "vertical": true, "font_size": 26.0, "lines": ["高木さんを", "完全に超えるのだ。"]}, {"box": [652, 644, 701, 714], "vertical": true, "font_size": 22.0, "lines": ["よし！", "できた。"]}, {"box": [152, 658, 180, 711], "vertical": true, "font_size": 26.0, "lines": ["おー。"]}, {"box": [652, 953, 726, 1039], "vertical": true, "font_size": 23.0, "lines": ["いいねー", "ちょっと", "見せてよ。"]}, {"box": [159, 946, 212, 1018], "vertical": true, "font_size": 26.0, "lines": ["あぁ", "いいよ。"]}], "img_path": "081.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [780, 57, 800, 135], "vertical": true, "font_size": 20.0, "lines": ["ふむふむ。"]}, {"box": [702, 439, 722, 526], "vertical": true, "font_size": 20.0, "lines": ["よいしょ。"]}, {"box": [248, 423, 279, 468], "vertical": true, "font_size": 29.0, "lines": ["へ？"]}, {"box": [632, 909, 705, 1032], "vertical": true, "font_size": 18.0, "lines": ["うん、ちゃんと", "できてる", "みたいだね。"]}, {"box": [330, 931, 408, 996], "vertical": true, "font_size": 27.0, "lines": ["あの．．．", "オニは", "オレ．．．"]}, {"box": [164, 916, 183, 1007], "vertical": true, "font_size": 19.0, "lines": ["あぁうん、"]}, {"box": [91, 943, 135, 1039], "vertical": true, "font_size": 19.0, "lines": ["確かめてた", "だけだよ"]}], "img_path": "082.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [296, 120, 349, 209], "vertical": true, "font_size": 26.0, "lines": ["はい、", "オニさん。"]}, {"box": [699, 553, 750, 643], "vertical": true, "font_size": 24.0, "lines": ["じゃ、", "やろっか。"]}, {"box": [618, 950, 720, 1067], "vertical": true, "font_size": 22.0, "lines": ["これ、さっき", "高木さんの", "口ついて", "なかった．．．！？"]}, {"box": [113, 976, 145, 1044], "vertical": true, "font_size": 29.0, "lines": ["完全に。"]}], "img_path": "083.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [762, 62, 817, 170], "vertical": true, "font_size": 26.0, "lines": ["これ．．", "かぶるの．．．"]}, {"box": [483, 65, 507, 251], "vertical": true, "font_size": 16.0, "lines": ["恥ずかしすぎだろ．．．"]}, {"box": [392, 49, 440, 184], "vertical": true, "font_size": 22.0, "lines": ["あれ？", "かぶらないの？"]}, {"box": [94, 79, 144, 166], "vertical": true, "font_size": 23.0, "lines": ["はやく", "やろーよ。"]}, {"box": [415, 341, 436, 400], "vertical": true, "font_size": 21.0, "lines": ["ぐっ．．．"]}, {"box": [719, 884, 741, 970], "vertical": true, "font_size": 20.0, "lines": ["ムリだぁ。"]}, {"box": [342, 907, 416, 1047], "vertical": true, "font_size": 20.0, "lines": ["かぷらないなら", "私がオニ", "やろっか？"]}], "img_path": "084.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [695, 48, 747, 183], "vertical": true, "font_size": 22.0, "lines": ["まぁ、その時は", "西片が"]}, {"box": [398, 77, 473, 230], "vertical": true, "font_size": 18.0, "lines": ["投げにくい", "豆を投げることに", "なるけど。"]}, {"box": [672, 556, 747, 691], "vertical": true, "font_size": 20.0, "lines": ["そこまで．．", "そこまで", "わかっていて！"]}, {"box": [333, 614, 362, 730], "vertical": true, "font_size": 20.0, "lines": ["高木さんめ．．．"]}, {"box": [682, 924, 728, 1038], "vertical": true, "font_size": 18.0, "lines": ["これさえ．．．", "かぶれれば．．．"]}, {"box": [92, 913, 114, 982], "vertical": true, "font_size": 21.0, "lines": ["ふふっ。"]}], "img_path": "085.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [704, 71, 787, 189], "vertical": true, "font_size": 26.0, "lines": ["西片、お面", "かぶってない", "のに、"]}, {"box": [358, 70, 410, 203], "vertical": true, "font_size": 20.0, "lines": ["赤オニみたいに", "なってるね。"]}, {"box": [567, 603, 724, 683], "vertical": true, "font_size": 23.0, "lines": ["このまま", "終われる", "か．．．"]}, {"box": [733, 786, 749, 898], "vertical": true, "font_size": 20.0, "lines": ["わかったよ！！"]}, {"box": [637, 798, 688, 923], "vertical": true, "font_size": 20.0, "lines": ["高木さんが", "オニで勝負だ。"]}, {"box": [421, 774, 441, 858], "vertical": true, "font_size": 20.0, "lines": ["いいよー"]}, {"box": [127, 623, 207, 686], "vertical": true, "font_size": 28.0, "lines": ["いちか", "ばちか", "でも．．．"]}, {"box": [133, 822, 181, 901], "vertical": true, "font_size": 23.0, "lines": ["もちろん", "負けた。"]}], "img_path": "086.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "087.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [640, 116, 663, 196], "vertical": true, "font_size": 21.0, "lines": ["おおお。"]}, {"box": [657, 488, 753, 628], "vertical": true, "font_size": 28.0, "lines": ["ＯＰが", "新しく", "なってる．．．！！"]}, {"box": [282, 528, 306, 608], "vertical": true, "font_size": 21.0, "lines": ["おおお。"]}, {"box": [682, 970, 713, 1039], "vertical": true, "font_size": 30.0, "lines": ["次の日。"]}], "img_path": "088.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [688, 76, 738, 160], "vertical": true, "font_size": 23.0, "lines": ["フーン", "フンフン。"]}, {"box": [318, 53, 393, 225], "vertical": true, "font_size": 23.0, "lines": ["いやぁ．．．", "かっこよかったなぁ", "新ＯＰ。"]}, {"box": [372, 372, 395, 487], "vertical": true, "font_size": 16.0, "lines": ["特にサビが．．．"]}, {"box": [154, 372, 175, 465], "vertical": true, "font_size": 20.0, "lines": ["フンフーン。"]}, {"box": [98, 399, 118, 491], "vertical": true, "font_size": 20.0, "lines": ["フンフーン"]}, {"box": [667, 617, 721, 683], "vertical": true, "font_size": 29.0, "lines": ["おはよ", "西片。"]}, {"box": [153, 660, 182, 746], "vertical": true, "font_size": 29.0, "lines": ["わぁ！"]}, {"box": [638, 986, 709, 1091], "vertical": true, "font_size": 20.0, "lines": ["あはは、", "ビックリ", "しすぎだよ。"]}, {"box": [169, 990, 221, 1069], "vertical": true, "font_size": 26.0, "lines": ["えっと．．．", "いや．．．"]}], "img_path": "089.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [652, 70, 748, 220], "vertical": true, "font_size": 21.0, "lines": ["さっき昨日の", "爆裂！！", "最強サッカー！！この", "新ＯＰ歌ってた？"]}, {"box": [324, 96, 348, 212], "vertical": true, "font_size": 20.0, "lines": ["聞かれてた．．．"]}, {"box": [173, 62, 246, 165], "vertical": true, "font_size": 22.0, "lines": ["っていうか", "高木さんも", "観てたのか"]}, {"box": [693, 469, 742, 614], "vertical": true, "font_size": 24.0, "lines": ["あれ", "かっこいいよね。"]}, {"box": [666, 820, 713, 962], "vertical": true, "font_size": 20.0, "lines": ["だよねえ！", "かっこいいよね。"]}, {"box": [167, 850, 189, 900], "vertical": true, "font_size": 22.0, "lines": ["うん。"]}], "img_path": "090.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [698, 104, 740, 243], "vertical": true, "font_size": 17.0, "lines": ["わかってるなぁ．．．", "さすが高木さん"]}, {"box": [452, 112, 507, 167], "vertical": true, "font_size": 30.0, "lines": ["あ、", "でも、"]}, {"box": [288, 114, 413, 229], "vertical": true, "font_size": 20.0, "lines": ["サビって", "さっき西片が", "歌ってた", "フンフーン", "じゃなくて"]}, {"box": [82, 52, 372, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [48, 138, 96, 262], "vertical": true, "font_size": 20.0, "lines": ["フフーンじゃ", "なかったっけ。"]}, {"box": [647, 581, 699, 718], "vertical": true, "font_size": 26.0, "lines": ["え！？", "そうだっけ．．．！？"]}, {"box": [447, 858, 746, 910], "vertical": false, "font_size": 32.0, "lines": ["脳内再生中"]}, {"box": [142, 608, 199, 697], "vertical": true, "font_size": 27.0, "lines": ["確か", "そうだよ。"]}, {"box": [331, 884, 408, 983], "vertical": true, "font_size": 23.0, "lines": ["いや！", "フンフーン", "だったよ。"]}, {"box": [93, 885, 147, 979], "vertical": true, "font_size": 26.0, "lines": ["えーちが", "違うよー。"]}], "img_path": "091.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [738, 67, 789, 195], "vertical": true, "font_size": 23.0, "lines": ["じゃあ", "確認しよっか。"]}, {"box": [364, 93, 414, 181], "vertical": true, "font_size": 22.0, "lines": ["どっちが", "正しいか。"]}, {"box": [277, 117, 297, 230], "vertical": true, "font_size": 20.0, "lines": ["どうやって？"]}, {"box": [693, 795, 747, 921], "vertical": true, "font_size": 23.0, "lines": ["私、昨日曲", "買ったんだよ。"]}, {"box": [328, 817, 352, 885], "vertical": true, "font_size": 24.0, "lines": ["へぇー。"]}, {"box": [194, 793, 269, 873], "vertical": true, "font_size": 24.0, "lines": ["オレも", "あとで", "買おう．．．"]}, {"box": [106, 825, 134, 877], "vertical": true, "font_size": 26.0, "lines": ["じゃ、"]}], "img_path": "092.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [429, 80, 461, 133], "vertical": true, "font_size": 29.0, "lines": ["はい、"]}, {"box": [349, 120, 404, 189], "vertical": true, "font_size": 29.0, "lines": ["片っぽ", "使って。"]}, {"box": [52, 91, 80, 138], "vertical": true, "font_size": 28.0, "lines": ["へ？"]}, {"box": [722, 534, 746, 577], "vertical": true, "font_size": 24.0, "lines": ["え．．"]}, {"box": [380, 519, 452, 690], "vertical": true, "font_size": 21.0, "lines": ["い．．．いや．．．", "スピーカーモードで", "よくないかな．．．"]}, {"box": [287, 846, 364, 943], "vertical": true, "font_size": 24.0, "lines": ["いや．．．", "そういう", "ワケでは．．．"]}, {"box": [93, 549, 170, 665], "vertical": true, "font_size": 18.0, "lines": ["確かめるなら", "こっちの方が", "確実だよー。"]}, {"box": [69, 856, 123, 922], "vertical": true, "font_size": 28.0, "lines": ["じゃあ", "はい。"]}, {"box": [522, 866, 571, 1001], "vertical": true, "font_size": 22.0, "lines": ["あ、もしかして", "恥ずかしいの？"]}], "img_path": "093.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [261, 64, 295, 137], "vertical": true, "font_size": 29.0, "lines": ["近．．．"]}, {"box": [682, 582, 750, 672], "vertical": true, "font_size": 20.0, "lines": ["イントロも", "かっこいい", "よねー。"]}, {"box": [672, 854, 745, 936], "vertical": true, "font_size": 32.0, "lines": ["いや．．．！！！", "全然、"]}, {"box": [329, 562, 359, 707], "vertical": true, "font_size": 24.0, "lines": ["ね、", "西片"]}, {"box": [104, 856, 173, 978], "vertical": true, "font_size": 32.0, "lines": ["耳に入って", "こない．．．"]}], "img_path": "094.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [699, 53, 745, 139], "vertical": true, "font_size": 20.0, "lines": ["そろそろ", "サビだよ。"]}, {"box": [460, 55, 511, 185], "vertical": true, "font_size": 24.0, "lines": ["フンフーンなら", "西片、"]}, {"box": [358, 87, 404, 202], "vertical": true, "font_size": 24.0, "lines": ["フフーンなら", "私の勝ちね。"]}, {"box": [93, 87, 121, 147], "vertical": true, "font_size": 21.0, "lines": ["西片？"]}, {"box": [366, 400, 462, 519], "vertical": true, "font_size": 26.0, "lines": ["集中", "しすぎてる", "のかな？"]}, {"box": [677, 973, 705, 1054], "vertical": true, "font_size": 26.0, "lines": ["どわぁ。"]}, {"box": [103, 976, 155, 1047], "vertical": true, "font_size": 27.0, "lines": ["あ、", "サビだ。"]}], "img_path": "095.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [774, 52, 808, 98], "vertical": true, "font_size": 32.0, "lines": ["あ。"]}, {"box": [444, 63, 487, 182], "vertical": true, "font_size": 18.0, "lines": ["ほら、やっぱり", "フフーンだよ。"]}, {"box": [267, 84, 290, 127], "vertical": true, "font_size": 23.0, "lines": ["な．．．"]}, {"box": [649, 473, 750, 608], "vertical": true, "font_size": 20.0, "lines": ["ウソ．．．？", "じゃあちょっと", "巻き戻して", "聴かせてよ。"]}, {"box": [447, 467, 477, 521], "vertical": true, "font_size": 23.0, "lines": ["えー、"]}, {"box": [343, 476, 415, 600], "vertical": true, "font_size": 23.0, "lines": ["聴くならまた", "最初から", "聴きたいなー。"]}, {"box": [275, 479, 293, 521], "vertical": true, "font_size": 18.0, "lines": ["ぐ．．．"]}, {"box": [667, 869, 741, 967], "vertical": true, "font_size": 22.0, "lines": ["どうする？", "もう一回", "確かめる？"]}, {"box": [309, 866, 414, 1000], "vertical": true, "font_size": 19.0, "lines": ["高木さんめ．．．", "またサビの前で", "邪魔して楽しむ", "もりか．．．"]}], "img_path": "096.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [420, 110, 441, 242], "vertical": true, "font_size": 20.0, "lines": ["いや．．．そうか！！"]}, {"box": [80, 52, 372, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [99, 108, 177, 262], "vertical": true, "font_size": 17.0, "lines": ["邪魔をするのは．．", "オレに聴かせない", "ため．．．！？"]}, {"box": [658, 587, 733, 727], "vertical": true, "font_size": 22.0, "lines": ["オレの", "フンフーンで", "合ってるんだな。"]}, {"box": [117, 599, 154, 748], "vertical": true, "font_size": 31.0, "lines": ["高木さんめ。"]}, {"box": [640, 883, 746, 1018], "vertical": true, "font_size": 20.0, "lines": ["また最初から", "なんて言ってる", "のはオレに諦め", "させるため："]}, {"box": [429, 882, 480, 969], "vertical": true, "font_size": 24.0, "lines": ["ふふ．．．", "読めたぞ。"]}, {"box": [316, 887, 393, 985], "vertical": true, "font_size": 22.0, "lines": ["じゃあ．．．", "もう一回．．．", "よろしく。"]}, {"box": [101, 902, 124, 952], "vertical": true, "font_size": 23.0, "lines": ["うん。"]}], "img_path": "097.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [700, 62, 775, 184], "vertical": true, "font_size": 21.0, "lines": ["くくく．．．", "照れるのを", "ガマンすれば"]}, {"box": [365, 123, 425, 249], "vertical": true, "font_size": 24.0, "lines": ["オレの勝ちだ", "高木さん"]}, {"box": [698, 540, 747, 607], "vertical": true, "font_size": 22.0, "lines": ["さぁ、", "サビだ"]}, {"box": [449, 529, 495, 615], "vertical": true, "font_size": 18.0, "lines": ["どうくる", "高木さん。"]}, {"box": [208, 786, 237, 876], "vertical": true, "font_size": 29.0, "lines": ["あれ？"]}], "img_path": "098.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [702, 84, 731, 193], "vertical": true, "font_size": 29.0, "lines": ["フフーン"]}, {"box": [132, 58, 173, 206], "vertical": true, "font_size": 32.0, "lines": ["あれぇ！？"]}, {"box": [711, 434, 746, 479], "vertical": true, "font_size": 29.0, "lines": ["ね、"]}, {"box": [373, 502, 422, 583], "vertical": true, "font_size": 22.0, "lines": ["フフーン", "でしょ？"]}, {"box": [688, 880, 742, 1054], "vertical": true, "font_size": 21.0, "lines": ["二段構えとは．．．", "さすが高木さんだ．．．"]}, {"box": [363, 895, 441, 983], "vertical": true, "font_size": 24.0, "lines": ["ねえ、", "もう一回", "聴こうよ。"]}], "img_path": "099.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [668, 93, 745, 265], "vertical": true, "font_size": 19.0, "lines": ["次こそオレを", "恥ずかしがらせて", "からかうつもりか．．．"]}, {"box": [419, 106, 468, 205], "vertical": true, "font_size": 23.0, "lines": ["それが", "罰ゲーム？"]}, {"box": [323, 123, 341, 237], "vertical": true, "font_size": 16.0, "lines": ["なんのこと？"]}, {"box": [146, 151, 180, 196], "vertical": true, "font_size": 31.0, "lines": ["え！？"]}, {"box": [434, 296, 461, 339], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [385, 458, 494, 578], "vertical": true, "font_size": 26.0, "lines": ["私がじゃた", "西片と一緒に", "聴きたいだけ", "だよ。"]}], "img_path": "100.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [83, 51, 374, 75], "vertical": false, "font_size": 24.0, "lines": ["からかい上手の高ホさんは"]}, {"box": [700, 442, 752, 540], "vertical": true, "font_size": 26.0, "lines": ["い．．．", "いいけど．．．"]}, {"box": [397, 481, 422, 535], "vertical": true, "font_size": 25.0, "lines": ["うん。"]}, {"box": [205, 429, 325, 641], "vertical": true, "font_size": 18.0, "lines": ["そういえば．．．勝負なんて", "言も言ってなかったし．．．", "もしかして高木さんは", "からかってるつもりも", "なかったのか．．．"]}, {"box": [643, 884, 745, 1000], "vertical": true, "font_size": 22.0, "lines": ["じゃあ．．．", "オレと", "聴きたいって", "いうのは．．"]}, {"box": [397, 874, 447, 961], "vertical": true, "font_size": 23.0, "lines": ["じゃあ", "いくよー。"]}, {"box": [171, 919, 270, 1053], "vertical": true, "font_size": 19.0, "lines": ["ホントにただ", "オレとイヤホン", "片っぽずつで", "聴きたいと．．．"]}], "img_path": "101.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [331, 72, 353, 116], "vertical": true, "font_size": 22.0, "lines": ["え？"]}, {"box": [697, 509, 749, 615], "vertical": true, "font_size": 24.0, "lines": ["あ、", "もしかして、"]}, {"box": [332, 285, 359, 330], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [90, 515, 139, 567], "vertical": true, "font_size": 27.0, "lines": ["え．．", "いや。"]}, {"box": [376, 561, 454, 698], "vertical": true, "font_size": 22.0, "lines": ["また", "イヤホン二人で", "使いたかった？"]}, {"box": [623, 926, 727, 1033], "vertical": true, "font_size": 22.0, "lines": ["じゃあ", "そう言って", "くれれば", "いいのにー。"]}, {"box": [506, 932, 579, 1087], "vertical": true, "font_size": 22.0, "lines": ["そっかー", "二人でイヤホンで", "聴きたいかー。"]}, {"box": [246, 941, 318, 1039], "vertical": true, "font_size": 23.0, "lines": ["いや．．．！", "それで", "いいから！"]}, {"box": [105, 920, 136, 1090], "vertical": true, "font_size": 23.0, "lines": ["高木さんめぇえ。"]}], "img_path": "102.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [78, 93, 196, 414], "vertical": true, "font_size": 32.0, "lines": ["反射神経"]}], "img_path": "103.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [485, 82, 567, 187], "vertical": true, "font_size": 20.0, "lines": ["図書委員て", "思ったより", "退屈だねー。"]}, {"box": [105, 111, 164, 222], "vertical": true, "font_size": 30.0, "lines": ["全然", "人来ないし。"]}, {"box": [651, 556, 668, 651], "vertical": true, "font_size": 16.0, "lines": ["そうだねぇ。"]}, {"box": [723, 858, 750, 907], "vertical": true, "font_size": 27.0, "lines": ["ふー"]}, {"box": [369, 856, 405, 922], "vertical": true, "font_size": 32.0, "lines": ["次次"]}, {"box": [454, 862, 507, 1004], "vertical": true, "font_size": 22.0, "lines": ["この図鑑も", "面白かったなぁ。"]}], "img_path": "104.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [674, 66, 752, 223], "vertical": true, "font_size": 24.0, "lines": ["あ、", "読み終わったなら", "何かしない？"]}, {"box": [298, 108, 350, 193], "vertical": true, "font_size": 26.0, "lines": ["いやー、", "悪いけど、"]}, {"box": [94, 113, 148, 221], "vertical": true, "font_size": 28.0, "lines": ["図鑑が", "面白くてさ。"]}, {"box": [602, 496, 688, 618], "vertical": true, "font_size": 20.0, "lines": ["．．．そっか。"]}, {"box": [704, 892, 750, 993], "vertical": true, "font_size": 20.0, "lines": ["そんなに", "面白いなら、"]}, {"box": [624, 941, 671, 1044], "vertical": true, "font_size": 20.0, "lines": ["私も図鑑", "読もうかな。"]}, {"box": [391, 882, 410, 1033], "vertical": true, "font_size": 16.0, "lines": ["いいんじゃない？"]}, {"box": [292, 875, 339, 998], "vertical": true, "font_size": 20.0, "lines": ["どれに", "しよっかなー。"]}], "img_path": "105.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [700, 38, 781, 182], "vertical": true, "font_size": 29.0, "lines": ["きゃうりゃうんじゃぜ、どうかっ", "動物、鳥は", "読み終わったし、"]}, {"box": [620, 85, 656, 153], "vertical": true, "font_size": 29.0, "lines": ["次は．．"]}, {"box": [365, 62, 439, 166], "vertical": true, "font_size": 21.0, "lines": ["あ、じゃあ", "これに", "しようかな。"]}, {"box": [301, 55, 326, 105], "vertical": true, "font_size": 25.0, "lines": ["よし。"]}, {"box": [101, 83, 122, 149], "vertical": true, "font_size": 20.0, "lines": ["これだ。"]}, {"box": [123, 551, 166, 612], "vertical": false, "font_size": 32.0, "lines": ["昆虫"]}, {"box": [251, 989, 287, 1035], "vertical": true, "font_size": 17.0, "lines": ["まあままはまだまだな", "．．．"]}], "img_path": "106.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [504, 482, 581, 590], "vertical": true, "font_size": 23.0, "lines": ["あ．．．！！", "いやあの．．．", "ゴメン。"]}], "img_path": "107.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [697, 97, 747, 195], "vertical": true, "font_size": 23.0, "lines": ["なんか", "テレてる？"]}, {"box": [417, 145, 469, 214], "vertical": true, "font_size": 26.0, "lines": ["テレて", "ないよ。"]}, {"box": [351, 67, 376, 137], "vertical": true, "font_size": 25.0, "lines": ["ふーん。"]}, {"box": [530, 471, 583, 558], "vertical": true, "font_size": 23.0, "lines": ["それで", "この図鑑、"]}, {"box": [479, 489, 495, 611], "vertical": true, "font_size": 23.0, "lines": ["どうしよっか。"]}, {"box": [353, 474, 436, 609], "vertical": true, "font_size": 21.0, "lines": ["高木さんの方が", "先だったし．．", "読めば？"]}, {"box": [670, 820, 745, 944], "vertical": true, "font_size": 21.0, "lines": ["あれ？", "西片が先じゃ", "なかったっけ。"]}, {"box": [377, 815, 422, 967], "vertical": true, "font_size": 22.0, "lines": ["いや．．．高木さんが", "先だったよ。"]}, {"box": [255, 815, 276, 878], "vertical": true, "font_size": 21.0, "lines": ["うーん。"]}, {"box": [316, 916, 344, 986], "vertical": true, "font_size": 22.0, "lines": ["絶対に。"]}], "img_path": "108.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [722, 99, 741, 227], "vertical": true, "font_size": 16.0, "lines": ["わかんないから、"]}, {"box": [372, 121, 444, 246], "vertical": true, "font_size": 21.0, "lines": ["さっきの", "再現でも", "してみようか。"]}, {"box": [82, 52, 372, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [90, 128, 117, 173], "vertical": true, "font_size": 27.0, "lines": ["な．．．"]}, {"box": [668, 542, 740, 666], "vertical": true, "font_size": 20.0, "lines": ["いやいや、", "そこまで", "しなくても．．．！"]}, {"box": [577, 556, 619, 694], "vertical": true, "font_size": 20.0, "lines": ["高木さんが読めば", "いいじゃん！"]}, {"box": [306, 860, 334, 916], "vertical": true, "font_size": 22.0, "lines": ["勝負．．．"]}, {"box": [101, 549, 192, 705], "vertical": true, "font_size": 17.0, "lines": ["てもそれじゃあ", "西片から", "横取りしたみたいに", "なっちゃうしさー。"]}, {"box": [94, 844, 200, 945], "vertical": true, "font_size": 26.0, "lines": ["いや．．．", "こんな．．．", "顔が熱いときたい", "状態じゃ．．．"]}, {"box": [647, 847, 737, 976], "vertical": true, "font_size": 19.0, "lines": ["そうだ、じゃあ", "何か勝負して", "勝った方が", "好きにしようよ。"]}], "img_path": "109.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [643, 110, 746, 198], "vertical": true, "font_size": 26.0, "lines": ["あ、じゃ", "西片今", "テレてて", "ムリかー。"]}, {"box": [329, 131, 378, 219], "vertical": true, "font_size": 24.0, "lines": ["テレて", "ないって。"]}, {"box": [305, 532, 331, 584], "vertical": true, "font_size": 24.0, "lines": ["うん。"]}, {"box": [635, 532, 682, 675], "vertical": true, "font_size": 20.0, "lines": ["いいよ！", "じゃあやろうよ。"]}, {"box": [226, 555, 274, 662], "vertical": true, "font_size": 24.0, "lines": ["じゃあ", "用意するね。"]}], "img_path": "110.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [686, 113, 738, 212], "vertical": true, "font_size": 24.0, "lines": ["じゃんけん", "して、"]}, {"box": [577, 110, 653, 207], "vertical": true, "font_size": 24.0, "lines": ["負けた方は", "ファイルで", "ガード。"]}, {"box": [649, 243, 763, 344], "vertical": false, "font_size": 32.0, "lines": ["ＤＥＦＥルＳＥ"]}, {"box": [246, 121, 328, 223], "vertical": true, "font_size": 24.0, "lines": ["勝った方は", "ハリセンで", "攻撃。"]}, {"box": [80, 51, 374, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんＢ"]}, {"box": [131, 112, 203, 266], "vertical": true, "font_size": 24.0, "lines": ["ハリセンを", "くらわせられたら", "１ポイント、"]}, {"box": [654, 535, 701, 639], "vertical": true, "font_size": 20.0, "lines": ["２ポイント", "先取で勝利。"]}, {"box": [107, 303, 180, 426], "vertical": true, "font_size": 24.0, "lines": ["お手つきは", "相手に", "１ポイントね。"]}, {"box": [164, 536, 185, 597], "vertical": true, "font_size": 21.0, "lines": ["どう？"]}, {"box": [723, 795, 745, 860], "vertical": true, "font_size": 22.0, "lines": ["いいよ。"]}, {"box": [442, 798, 495, 898], "vertical": true, "font_size": 24.0, "lines": ["集中．．．しゅうちゅう", "集中しろ："]}, {"box": [326, 791, 401, 916], "vertical": true, "font_size": 23.0, "lines": ["まだ", "顔が熱いけど", "それがなんだ"]}, {"box": [162, 833, 215, 949], "vertical": true, "font_size": 20.0, "lines": ["頭をフル回転", "させるんだ。"]}, {"box": [60, 800, 82, 952], "vertical": true, "font_size": 20.0, "lines": ["じゃーんけーん．．．"]}, {"box": [353, 1021, 404, 1109], "vertical": true, "font_size": 24.0, "lines": ["じゃあ", "いくよー。"]}], "img_path": "111.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [701, 73, 731, 128], "vertical": true, "font_size": 27.0, "lines": ["ぼん。"]}, {"box": [536, 56, 588, 135], "vertical": true, "font_size": 20.0, "lines": ["勝った！！", "よし！！"]}, {"box": [359, 71, 386, 209], "vertical": true, "font_size": 25.0, "lines": ["ハリセンだ！！"]}], "img_path": "112.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [672, 94, 747, 201], "vertical": true, "font_size": 21.0, "lines": ["おっと、", "お手つき", "しちゃった。"]}, {"box": [176, 48, 228, 173], "vertical": true, "font_size": 22.0, "lines": ["西片の", "１ポイントね。"]}, {"box": [668, 468, 688, 552], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．"]}, {"box": [144, 493, 171, 540], "vertical": true, "font_size": 27.0, "lines": ["ぜ．．．"]}, {"box": [687, 773, 747, 897], "vertical": true, "font_size": 30.0, "lines": ["絶対", "わざとだろ！！"]}, {"box": [285, 778, 332, 864], "vertical": true, "font_size": 23.0, "lines": ["じゃあ次", "いくよー。"]}, {"box": [200, 780, 251, 861], "vertical": true, "font_size": 23.0, "lines": ["じゃーん", "けーん、"]}, {"box": [112, 802, 135, 834], "vertical": true, "font_size": 23.0, "lines": ["え。"]}], "img_path": "113.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [692, 72, 742, 168], "vertical": true, "font_size": 23.0, "lines": ["ちょっと．．．", "頭が．．．"]}, {"box": [547, 86, 574, 138], "vertical": true, "font_size": 27.0, "lines": ["ぽん。"]}, {"box": [289, 114, 318, 183], "vertical": true, "font_size": 29.0, "lines": ["ヤバイ。"]}, {"box": [691, 479, 716, 558], "vertical": true, "font_size": 24.0, "lines": ["待って．．．"]}, {"box": [533, 816, 579, 914], "vertical": true, "font_size": 21.0, "lines": ["じゃんけん", "ぽん。"]}, {"box": [160, 956, 223, 1010], "vertical": true, "font_size": 32.0, "lines": ["頭がぜんぜん", "全然、"]}], "img_path": "114.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [649, 98, 676, 182], "vertical": true, "font_size": 19.0, "lines": ["回らな．．．"]}, {"box": [688, 420, 719, 526], "vertical": true, "font_size": 24.0, "lines": ["私の勝ちー。"]}, {"box": [296, 405, 321, 550], "vertical": true, "font_size": 23.0, "lines": ["ぁぁあぁあ"]}, {"box": [483, 819, 529, 897], "vertical": true, "font_size": 20.0, "lines": ["じゃあ．．．", "どうぞ．．．"]}, {"box": [325, 809, 349, 853], "vertical": true, "font_size": 24.0, "lines": ["ん？"]}, {"box": [243, 815, 269, 855], "vertical": true, "font_size": 24.0, "lines": ["へ？"]}], "img_path": "115.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [733, 94, 787, 201], "vertical": true, "font_size": 24.0, "lines": ["一緒に", "見るんだよ。"]}, {"box": [385, 97, 406, 174], "vertical": true, "font_size": 20.0, "lines": ["なんで！？"]}, {"box": [89, 98, 196, 223], "vertical": true, "font_size": 23.0, "lines": ["勝った方が", "好きにして", "いいって", "ルールでしょ。"]}, {"box": [719, 875, 755, 943], "vertical": true, "font_size": 32.0, "lines": ["近い．．．"]}, {"box": [101, 896, 134, 967], "vertical": true, "font_size": 30.0, "lines": ["な．．．何"]}], "img_path": "116.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [693, 116, 739, 250], "vertical": true, "font_size": 20.0, "lines": ["まだテレてる？", "顔赤いよ。"]}, {"box": [358, 111, 407, 199], "vertical": true, "font_size": 24.0, "lines": ["テレて", "ないって。"]}, {"box": [82, 51, 373, 73], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんＢ"]}, {"box": [646, 469, 726, 587], "vertical": true, "font_size": 25.0, "lines": ["くそ．．．た", "急に楽しそう", "だな．．．"]}, {"box": [282, 445, 353, 602], "vertical": true, "font_size": 22.0, "lines": ["さっきまで", "退屈ーとか", "言ってたクセに．．．"]}, {"box": [707, 764, 746, 851], "vertical": true, "font_size": 20.0, "lines": ["高木さん．．．"]}, {"box": [608, 781, 631, 823], "vertical": true, "font_size": 23.0, "lines": ["ん？"]}, {"box": [508, 766, 554, 919], "vertical": true, "font_size": 19.0, "lines": ["も．．．もしかして．．．", "退屈だからって、"]}, {"box": [268, 759, 313, 892], "vertical": true, "font_size": 18.0, "lines": ["オレからかって", "楽しんでる．．．？"]}], "img_path": "117.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [766, 77, 787, 145], "vertical": true, "font_size": 21.0, "lines": ["さぁー。"]}, {"box": [96, 112, 158, 228], "vertical": true, "font_size": 29.0, "lines": ["絶対", "そうじゃん"]}, {"box": [673, 528, 728, 630], "vertical": true, "font_size": 26.0, "lines": ["あ、西片に", "問題ー。"]}, {"box": [564, 533, 645, 659], "vertical": true, "font_size": 26.0, "lines": ["今名前隠した", "この魚は", "なんでしょー。"]}, {"box": [162, 570, 203, 648], "vertical": true, "font_size": 20.0, "lines": ["キ．．．キス。"]}, {"box": [612, 894, 687, 1030], "vertical": true, "font_size": 24.0, "lines": ["ん？", "もっかい", "言ってくれる？"]}, {"box": [390, 911, 443, 1011], "vertical": true, "font_size": 24.0, "lines": ["聞こえてる", "だろ！！"]}, {"box": [165, 895, 227, 1003], "vertical": true, "font_size": 30.0, "lines": ["絶対", "そうじゃん。"]}], "img_path": "118.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [419, 91, 753, 195], "vertical": false, "font_size": 32.0, "lines": ["落としもの"]}], "img_path": "119.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [709, 69, 732, 141], "vertical": true, "font_size": 22.0, "lines": ["あはは。"]}, {"box": [161, 110, 214, 226], "vertical": true, "font_size": 24.0, "lines": ["カオ", "まっかだよ。"]}, {"box": [646, 551, 746, 689], "vertical": true, "font_size": 21.0, "lines": ["くそ．．．", "今日もさんざん", "からかわれて", "しまった．．"]}, {"box": [215, 560, 287, 716], "vertical": true, "font_size": 19.0, "lines": ["どうにかして", "高木さんを", "見返したいけど．．．"]}, {"box": [126, 575, 173, 711], "vertical": true, "font_size": 19.0, "lines": ["もうそろそろ", "分かれ道だし．．．"]}, {"box": [694, 898, 750, 1021], "vertical": true, "font_size": 26.0, "lines": ["何か．．．だ", "何かないか．．．"]}, {"box": [367, 918, 387, 945], "vertical": true, "font_size": 20.0, "lines": ["！！"]}, {"box": [106, 919, 127, 989], "vertical": true, "font_size": 21.0, "lines": ["ある！！"]}], "img_path": "120.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [302, 106, 344, 248], "vertical": true, "font_size": 32.0, "lines": ["家のカギ。"]}, {"box": [171, 67, 215, 174], "vertical": true, "font_size": 20.0, "lines": ["すっかり", "忘れてた．．．！！"]}, {"box": [37, 98, 132, 239], "vertical": true, "font_size": 20.0, "lines": ["今日、母さんが", "出かけるからって", "持たされていた", "カギ！！"]}, {"box": [651, 491, 743, 663], "vertical": true, "font_size": 16.0, "lines": ["カギ持ってるなんて", "ちょっと大人っぽくて", "ビビるんじゃ", "ないか．．．！！"]}, {"box": [536, 519, 563, 604], "vertical": true, "font_size": 20.0, "lines": ["高木さん。"]}, {"box": [428, 515, 455, 561], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [111, 526, 137, 588], "vertical": true, "font_size": 26.0, "lines": ["ふふ．．．"]}, {"box": [695, 889, 746, 1024], "vertical": true, "font_size": 18.0, "lines": ["オレは今日．．．", "こんなものを．．"]}], "img_path": "121.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [715, 88, 783, 309], "vertical": true, "font_size": 28.0, "lines": ["どっかに", "落とした〜〜．．．！？"]}, {"box": [324, 62, 342, 155], "vertical": true, "font_size": 16.0, "lines": ["どしたの？"]}, {"box": [290, 325, 345, 390], "vertical": true, "font_size": 29.0, "lines": ["あ．．．", "いや．．．"]}, {"box": [84, 322, 132, 396], "vertical": true, "font_size": 24.0, "lines": ["マズイぞ", "これ。"]}, {"box": [702, 605, 719, 737], "vertical": true, "font_size": 18.0, "lines": ["なんでもない！！"]}, {"box": [630, 621, 650, 718], "vertical": true, "font_size": 18.0, "lines": ["じゃあね！！"]}, {"box": [185, 612, 215, 646], "vertical": true, "font_size": 25.0, "lines": ["ん、"]}, {"box": [132, 633, 152, 739], "vertical": true, "font_size": 25.0, "lines": ["じゃあねー。"]}], "img_path": "122.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [691, 47, 724, 237], "vertical": true, "font_size": 28.0, "lines": ["捜さないと．．．！！"]}, {"box": [687, 485, 712, 553], "vertical": true, "font_size": 25.0, "lines": ["どこだ。"]}, {"box": [120, 488, 171, 626], "vertical": true, "font_size": 24.0, "lines": ["どこで", "落としたんだ！？"]}, {"box": [620, 731, 645, 799], "vertical": true, "font_size": 25.0, "lines": ["くそー。"]}, {"box": [209, 701, 311, 837], "vertical": true, "font_size": 22.0, "lines": ["ふだん", "持ってないから", "全然意識して", "なかった．．．！！"]}, {"box": [39, 916, 143, 1067], "vertical": true, "font_size": 19.0, "lines": ["落とすとしたら", "ネコ追っかけて", "コケたこのへんの", "ハズなんだけど．．．"]}], "img_path": "123.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [731, 91, 765, 240], "vertical": true, "font_size": 28.0, "lines": ["何落としたの？"]}, {"box": [201, 160, 228, 245], "vertical": true, "font_size": 20.0, "lines": ["家のカギ。"]}, {"box": [687, 690, 713, 742], "vertical": true, "font_size": 26.0, "lines": ["わあ。"]}, {"box": [188, 675, 209, 741], "vertical": true, "font_size": 21.0, "lines": ["あはは。"]}, {"box": [91, 706, 165, 880], "vertical": true, "font_size": 21.0, "lines": ["何か落としもの", "したのかと思ったら", "やっぱりだ。"]}, {"box": [721, 960, 745, 1084], "vertical": true, "font_size": 18.0, "lines": ["家のカギかー。"]}, {"box": [434, 971, 485, 1089], "vertical": true, "font_size": 25.0, "lines": ["それはいちだいじ", "一大事だね．．．"]}, {"box": [331, 989, 388, 1081], "vertical": true, "font_size": 32.0, "lines": ["私も", "手伝うよ。"]}, {"box": [114, 996, 141, 1044], "vertical": true, "font_size": 27.0, "lines": ["え！？"]}], "img_path": "124.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [681, 82, 733, 161], "vertical": true, "font_size": 25.0, "lines": ["いいよ", "悪いし．．．"]}, {"box": [324, 91, 373, 175], "vertical": true, "font_size": 22.0, "lines": ["いいから", "いいから。"]}, {"box": [251, 41, 268, 87], "vertical": true, "font_size": 17.0, "lines": ["．．．．．"]}, {"box": [654, 550, 674, 664], "vertical": true, "font_size": 17.0, "lines": ["ありがとう．．．"]}, {"box": [139, 553, 189, 680], "vertical": true, "font_size": 24.0, "lines": ["どう", "いたしまして。"]}, {"box": [722, 870, 745, 956], "vertical": true, "font_size": 22.0, "lines": ["ところで、"]}, {"box": [374, 946, 449, 1088], "vertical": true, "font_size": 21.0, "lines": ["さっき私に", "カギ見せようと", "してたんだよね。"]}, {"box": [289, 978, 336, 1080], "vertical": true, "font_size": 21.0, "lines": ["それって", "もしかして、"]}], "img_path": "125.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [376, 83, 435, 277], "vertical": true, "font_size": 28.0, "lines": ["今日、両親遅いから", "ウチ来ない？"]}, {"box": [267, 99, 312, 213], "vertical": true, "font_size": 21.0, "lines": ["とか言おうと", "してた？"]}, {"box": [178, 116, 230, 249], "vertical": true, "font_size": 21.0, "lines": ["１００％片想い』の", "やつみたいに。"]}, {"box": [99, 146, 120, 192], "vertical": true, "font_size": 21.0, "lines": ["な．．．"]}, {"box": [679, 643, 728, 740], "vertical": true, "font_size": 24.0, "lines": ["それって．．．", "あの．．"]}, {"box": [126, 642, 177, 813], "vertical": true, "font_size": 20.0, "lines": ["キスシルエット回の", "セリフ．．．！？"]}, {"box": [734, 896, 810, 1048], "vertical": true, "font_size": 19.0, "lines": ["言うわけないだろ", "そんなえっちな", "セリフ。"]}, {"box": [646, 919, 678, 1010], "vertical": true, "font_size": 24.0, "lines": ["違うって。"]}, {"box": [234, 887, 335, 1076], "vertical": true, "font_size": 21.0, "lines": ["カギ持ってたら", "大人っぽいかなとか", "思ったから見せようと", "しただけで！！"]}, {"box": [124, 902, 169, 1016], "vertical": true, "font_size": 21.0, "lines": ["そんなんじゃ", "ないから。"]}], "img_path": "126.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [380, 82, 425, 203], "vertical": true, "font_size": 17.0, "lines": ["そうだったら", "よかったのに。"]}, {"box": [349, 638, 387, 712], "vertical": true, "font_size": 32.0, "lines": ["へ？"]}, {"box": [374, 968, 402, 1017], "vertical": true, "font_size": 28.0, "lines": ["．．．今"]}, {"box": [52, 977, 110, 1074], "vertical": true, "font_size": 25.0, "lines": ["聞き間違い", "か．．．？"]}], "img_path": "127.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [705, 67, 754, 157], "vertical": true, "font_size": 24.0, "lines": ["あの", "セリフを．．"]}, {"box": [563, 49, 606, 187], "vertical": true, "font_size": 16.0, "lines": ["そうだったら", "よかったのに．．．！？"]}, {"box": [493, 47, 513, 143], "vertical": true, "font_size": 16.0, "lines": ["それって．．．"]}, {"box": [99, 104, 129, 201], "vertical": true, "font_size": 19.0, "lines": ["高木さん．．．"]}, {"box": [395, 424, 470, 550], "vertical": true, "font_size": 24.0, "lines": ["どしたの？", "手とまってる", "けど。"]}], "img_path": "128.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [701, 37, 743, 193], "vertical": true, "font_size": 18.0, "lines": ["どこらへんかなって", "思い出してた：！！！"]}, {"box": [399, 63, 419, 94], "vertical": true, "font_size": 20.0, "lines": ["そ。"]}, {"box": [636, 363, 735, 536], "vertical": true, "font_size": 19.0, "lines": ["そうだ．．．！！", "さっきみたいに", "またからかって", "るんだな。"]}, {"box": [107, 367, 153, 488], "vertical": true, "font_size": 20.0, "lines": ["もしくは", "聞き間違いだ。"]}, {"box": [595, 690, 649, 755], "vertical": true, "font_size": 28.0, "lines": ["くそ．．．", "でも．．．"]}, {"box": [506, 860, 551, 933], "vertical": true, "font_size": 22.0, "lines": ["ドキドキ", "と．．"]}, {"box": [130, 677, 178, 775], "vertical": true, "font_size": 22.0, "lines": ["そうは", "思っても．．"]}, {"box": [713, 867, 741, 944], "vertical": true, "font_size": 21.0, "lines": ["心臓が．．．"]}, {"box": [433, 982, 474, 1100], "vertical": true, "font_size": 32.0, "lines": ["ゴリッ"]}, {"box": [161, 869, 187, 932], "vertical": true, "font_size": 26.0, "lines": ["ゴリ？"]}], "img_path": "129.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [424, 92, 456, 135], "vertical": true, "font_size": 32.0, "lines": ["あ。"]}, {"box": [181, 561, 202, 623], "vertical": true, "font_size": 21.0, "lines": ["んーん。"]}, {"box": [692, 561, 736, 639], "vertical": true, "font_size": 20.0, "lines": ["あの．．．", "ホントに、"]}, {"box": [609, 573, 652, 701], "vertical": true, "font_size": 20.0, "lines": ["ありがとう．．．", "手伝ってくれて。"]}, {"box": [616, 930, 747, 1045], "vertical": true, "font_size": 19.0, "lines": ["今さらだけど", "朝、母さんが", "そんなコトを", "言っていた", "ような．．．"]}, {"box": [276, 916, 385, 1026], "vertical": false, "font_size": 22.0, "lines": ["ズボンのポケット", "んハハイ．．．いやで人の", "おとに３０だからハウナルト", "よしししたかっムネポケットに", "いやホクッ！！いれどくよー"]}, {"box": [103, 933, 155, 1091], "vertical": true, "font_size": 22.0, "lines": ["まぁ、見つかって", "よかったよ。"]}], "img_path": "130.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [603, 127, 656, 189], "vertical": true, "font_size": 26.0, "lines": ["な．．", "なに？"]}, {"box": [339, 107, 446, 273], "vertical": true, "font_size": 24.0, "lines": ["いやー西片の", "“カギ持ってたら", "大人っていうのが", "面白くてさ。"]}, {"box": [80, 51, 373, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [667, 578, 742, 716], "vertical": true, "font_size": 24.0, "lines": ["同級生でも", "けっこういると", "思うよ、"]}, {"box": [581, 578, 631, 684], "vertical": true, "font_size": 24.0, "lines": ["カギ", "持ってる人。"]}, {"box": [310, 576, 333, 693], "vertical": true, "font_size": 21.0, "lines": ["そうなの．．．！？"]}, {"box": [690, 916, 743, 1021], "vertical": true, "font_size": 18.0, "lines": ["．．．．．今日ね", "私もなんだ。"]}, {"box": [448, 924, 477, 965], "vertical": true, "font_size": 29.0, "lines": ["へ？"]}], "img_path": "131.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [659, 144, 723, 253], "vertical": true, "font_size": 26.0, "lines": ["今日両親", "遅いから、"]}, {"box": [168, 162, 230, 237], "vertical": true, "font_size": 30.0, "lines": ["ウチ、", "来る？"]}, {"box": [92, 731, 128, 780], "vertical": true, "font_size": 29.0, "lines": ["え。"]}], "img_path": "132.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [725, 106, 748, 148], "vertical": true, "font_size": 23.0, "lines": ["た．．．"]}, {"box": [542, 104, 624, 239], "vertical": true, "font_size": 22.0, "lines": ["高木さんも", "持ってたんだ．．．", "カギ．．．"]}, {"box": [80, 51, 373, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [246, 110, 269, 161], "vertical": true, "font_size": 22.0, "lines": ["うん。"]}, {"box": [468, 543, 514, 630], "vertical": true, "font_size": 20.0, "lines": ["じゃあ！", "また明日。"]}, {"box": [146, 546, 173, 597], "vertical": true, "font_size": 24.0, "lines": ["うん、"]}, {"box": [98, 547, 118, 632], "vertical": true, "font_size": 24.0, "lines": ["じゃあね。"]}], "img_path": "133.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [752, 101, 786, 225], "vertical": true, "font_size": 30.0, "lines": ["あぶなっ。"]}, {"box": [333, 44, 414, 216], "vertical": true, "font_size": 21.0, "lines": ["一瞬本気で言ってん", "のかと思って", "とまっちゃった。"]}, {"box": [153, 45, 197, 195], "vertical": true, "font_size": 17.0, "lines": ["またからかわれる", "とこだった．．．"]}, {"box": [99, 73, 119, 195], "vertical": true, "font_size": 17.0, "lines": ["あぶなー", "．．．"]}, {"box": [100, 75, 119, 199], "vertical": true, "font_size": 19.0, "lines": ["あぶなー！！"]}, {"box": [353, 310, 407, 483], "vertical": true, "font_size": 21.0, "lines": ["ふふ．．．今日さんざん", "からかわれたけど、"]}, {"box": [98, 331, 179, 472], "vertical": true, "font_size": 23.0, "lines": ["最後は", "もちこたえたぞ、", "高木さん"]}, {"box": [587, 867, 638, 982], "vertical": true, "font_size": 18.0, "lines": ["本気だったん", "だけどなー"]}], "img_path": "134.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [100, 86, 400, 180], "vertical": false, "font_size": 32.0, "lines": ["やさしさ"]}], "img_path": "135.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [295, 84, 350, 172], "vertical": true, "font_size": 28.0, "lines": ["ついに．．．", "今日だ。"]}, {"box": [677, 611, 735, 685], "vertical": true, "font_size": 27.0, "lines": ["待ちに", "待った、"]}, {"box": [164, 591, 224, 788], "vertical": true, "font_size": 24.0, "lines": ["１００％片想い』の", "オフィシャル資料集"]}, {"box": [639, 923, 743, 1060], "vertical": true, "font_size": 21.0, "lines": ["この日のために", "家の手伝いして", "こづかいを", "貯めたんだ．．．"]}, {"box": [126, 919, 224, 1080], "vertical": true, "font_size": 20.0, "lines": ["ふふふ．．．", "高いものだけど", "ギリギリ", "貯まってよかった。"]}], "img_path": "136.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [649, 111, 730, 216], "vertical": true, "font_size": 31.0, "lines": ["楽しみ", "すぎる。"]}, {"box": [243, 86, 276, 139], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [684, 703, 713, 797], "vertical": true, "font_size": 21.0, "lines": ["偶然だね。"]}, {"box": [203, 962, 227, 1004], "vertical": true, "font_size": 24.0, "lines": ["な．．．"]}], "img_path": "137.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [741, 65, 790, 182], "vertical": true, "font_size": 22.0, "lines": ["まぁ偶然でも", "ないか。"]}, {"box": [646, 195, 723, 349], "vertical": true, "font_size": 22.0, "lines": ["１００％片想い』の", "資料集買いに行く", "とこでしょ。"]}, {"box": [362, 94, 386, 219], "vertical": true, "font_size": 16.0, "lines": ["私もなんだよ。"]}, {"box": [640, 527, 716, 625], "vertical": true, "font_size": 22.0, "lines": ["い．．．いや．．．", "オレはただ", "散歩で．．．"]}, {"box": [169, 534, 223, 653], "vertical": true, "font_size": 28.0, "lines": ["バレバレだよ", "西片。"]}, {"box": [435, 902, 464, 1005], "vertical": true, "font_size": 21.0, "lines": ["一緒に行こ。"]}, {"box": [104, 888, 123, 953], "vertical": true, "font_size": 19.0, "lines": ["．．．．．．"]}], "img_path": "138.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [461, 78, 518, 151], "vertical": true, "font_size": 31.0, "lines": ["楽しみ", "だねー。"]}, {"box": [691, 549, 744, 684], "vertical": true, "font_size": 19.0, "lines": ["く．．．高木さんが", "一緒だなんて．．．"]}, {"box": [360, 557, 408, 655], "vertical": true, "font_size": 20.0, "lines": ["どうやって", "買おうか．．．"]}, {"box": [653, 958, 704, 1045], "vertical": true, "font_size": 24.0, "lines": ["そう", "いえばさ、"]}, {"box": [101, 937, 204, 1073], "vertical": true, "font_size": 20.0, "lines": ["スペシャル", "ポストカードも", "ついてくる", "らしいよ。"]}], "img_path": "139.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [769, 69, 795, 140], "vertical": true, "font_size": 26.0, "lines": ["ええ！？"]}, {"box": [473, 89, 530, 250], "vertical": true, "font_size": 24.0, "lines": ["スペシャル", "ポストカード！？"]}, {"box": [670, 530, 741, 645], "vertical": true, "font_size": 20.0, "lines": ["まぁオレは", "散歩してる", "だけだけど．．．"]}, {"box": [108, 536, 183, 643], "vertical": true, "font_size": 25.0, "lines": ["あはは、", "素直に", "なりなって。"]}, {"box": [585, 656, 659, 774], "vertical": true, "font_size": 20.0, "lines": ["気が向いたら", "買ってみても", "いいかな．．．"]}, {"box": [664, 883, 744, 1058], "vertical": true, "font_size": 22.0, "lines": ["ホントは買うための", "お金も持ってるん", "でしょ。"]}, {"box": [338, 881, 387, 978], "vertical": true, "font_size": 23.0, "lines": ["．．．いや．．．", "その．．．"]}, {"box": [106, 1095, 123, 1123], "vertical": true, "font_size": 17.0, "lines": ["！"]}], "img_path": "140.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [711, 100, 742, 226], "vertical": true, "font_size": 29.0, "lines": ["ビエエエ。"]}, {"box": [329, 70, 379, 132], "vertical": true, "font_size": 24.0, "lines": ["どうか", "した？"]}, {"box": [37, 139, 65, 203], "vertical": true, "font_size": 26.0, "lines": ["いやー。"]}, {"box": [665, 519, 743, 633], "vertical": true, "font_size": 20.0, "lines": ["遊んでたら", "おもいっきり", "こけて．．．"]}, {"box": [398, 487, 431, 522], "vertical": false, "font_size": 32.0, "lines": ["え"]}, {"box": [725, 854, 746, 916], "vertical": true, "font_size": 21.0, "lines": ["ありゃ。"]}, {"box": [384, 848, 431, 998], "vertical": true, "font_size": 20.0, "lines": ["たいしたケガじゃ", "ないだろ、"]}, {"box": [324, 851, 344, 955], "vertical": true, "font_size": 20.0, "lines": ["ホラ帰るぞ。"]}, {"box": [100, 869, 129, 963], "vertical": true, "font_size": 27.0, "lines": ["死ぬー"]}], "img_path": "141.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [750, 60, 796, 185], "vertical": true, "font_size": 19.0, "lines": ["とりあえず", "水で洗おうか。"]}, {"box": [640, 59, 685, 173], "vertical": true, "font_size": 19.0, "lines": ["ちょっとだけ", "歩ける？"]}, {"box": [105, 81, 136, 259], "vertical": true, "font_size": 30.0, "lines": ["ムリー"]}, {"box": [725, 432, 746, 509], "vertical": true, "font_size": 22.0, "lines": ["そっか．．．"]}, {"box": [623, 405, 671, 578], "vertical": true, "font_size": 22.0, "lines": ["じゃあ何かで", "水くんで、ここで．．．"]}, {"box": [202, 432, 236, 495], "vertical": true, "font_size": 26.0, "lines": ["西片？"]}, {"box": [692, 782, 740, 868], "vertical": true, "font_size": 21.0, "lines": ["ちょっと", "待ってて。"]}, {"box": [408, 792, 434, 916], "vertical": true, "font_size": 20.0, "lines": ["すぐ戻るから。"]}], "img_path": "142.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [431, 73, 465, 130], "vertical": true, "font_size": 29.0, "lines": ["はい、"]}, {"box": [374, 72, 404, 179], "vertical": true, "font_size": 29.0, "lines": ["これでＯＫ。"]}, {"box": [686, 518, 715, 596], "vertical": true, "font_size": 21.0, "lines": ["大丈夫？"]}, {"box": [332, 528, 385, 608], "vertical": true, "font_size": 25.0, "lines": ["めっちゃ", "しみた。"]}, {"box": [97, 499, 149, 634], "vertical": true, "font_size": 23.0, "lines": ["ありがとうだろ", "バカ。"]}, {"box": [695, 871, 742, 1012], "vertical": true, "font_size": 22.0, "lines": ["お礼はこの", "お兄ちゃんにね。"]}, {"box": [563, 876, 641, 996], "vertical": true, "font_size": 22.0, "lines": ["近くの薬局に", "走ってきて", "くれたから。"]}, {"box": [369, 871, 391, 977], "vertical": true, "font_size": 20.0, "lines": ["．．．ありがと。"]}, {"box": [144, 882, 193, 946], "vertical": true, "font_size": 26.0, "lines": ["いや、", "いいよ。"]}], "img_path": "143.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [492, 843, 541, 935], "vertical": true, "font_size": 24.0, "lines": ["やさしいね", "西片。"]}, {"box": [123, 847, 200, 938], "vertical": true, "font_size": 25.0, "lines": ["別に．．．", "なんとなく", "だよ．．．"]}], "img_path": "144.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [699, 63, 723, 134], "vertical": true, "font_size": 24.0, "lines": ["ふーん、"]}, {"box": [452, 101, 473, 237], "vertical": true, "font_size": 17.0, "lines": ["なんとなくか"]}, {"box": [359, 55, 386, 104], "vertical": true, "font_size": 24.0, "lines": ["うん、"]}, {"box": [290, 66, 310, 146], "vertical": true, "font_size": 24.0, "lines": ["じゃあね。"]}, {"box": [83, 85, 105, 125], "vertical": true, "font_size": 22.0, "lines": ["ん？"]}, {"box": [653, 583, 705, 687], "vertical": true, "font_size": 19.0, "lines": ["本屋さん．．．", "行かないの？"]}, {"box": [670, 867, 687, 926], "vertical": true, "font_size": 17.0, "lines": ["．．．．．．？"]}, {"box": [180, 607, 209, 671], "vertical": true, "font_size": 25.0, "lines": ["資料集。"]}, {"box": [171, 888, 241, 1005], "vertical": true, "font_size": 22.0, "lines": ["だからこんば", "散歩してた", "だけだってば。"]}], "img_path": "145.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [660, 99