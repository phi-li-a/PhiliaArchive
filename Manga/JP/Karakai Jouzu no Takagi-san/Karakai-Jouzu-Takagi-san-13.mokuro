img_width": 847, "img_height": 1200, "blocks": [], "img_path": "006.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "007.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "008.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "009.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [385, 823, 473, 855], "vertical": false, "font_size": 32.0, "lines": ["そうだな．．．"]}], "img_path": "010.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "011.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "012.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "013.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [647, 549, 736, 645], "vertical": false, "font_size": 32.0, "lines": ["Ｑ"]}], "img_path": "014.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "015.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "016.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "017.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "018.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "019.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [381, 627, 433, 717], "vertical": true, "font_size": 32.0, "lines": ["！？"]}, {"box": [190, 690, 236, 756], "vertical": true, "font_size": 32.0, "lines": ["．．．"]}], "img_path": "020.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [94, 96, 385, 227], "vertical": false, "font_size": 32.0, "lines": ["がん", "願掛け"]}], "img_path": "021.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [745, 376, 801, 531], "vertical": true, "font_size": 23.0, "lines": ["小学生のころ", "よくやっていた．．"]}, {"box": [476, 373, 591, 474], "vertical": true, "font_size": 26.0, "lines": ["道路に足を", "つかずに", "家に帰る", "遊び。"]}, {"box": [381, 403, 432, 505], "vertical": true, "font_size": 19.0, "lines": ["それを今", "やっている。"]}, {"box": [392, 802, 414, 892], "vertical": true, "font_size": 20.0, "lines": ["ゴールは"]}, {"box": [113, 821, 142, 884], "vertical": true, "font_size": 21.0, "lines": ["神士！！"]}], "img_path": "022.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [659, 80, 730, 204], "vertical": true, "font_size": 20.0, "lines": ["クリアしたら", "高木さんに", "勝てるという、"]}, {"box": [112, 83, 165, 205], "vertical": true, "font_size": 18.0, "lines": ["願掛けを", "しているのさ。"]}, {"box": [622, 926, 705, 1014], "vertical": true, "font_size": 25.0, "lines": ["ふっ", "ちょろい", "ちょろい"]}], "img_path": "023.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [541, 91, 603, 152], "vertical": true, "font_size": 32.0, "lines": ["あ、", "西片。"]}, {"box": [716, 985, 742, 1069], "vertical": true, "font_size": 20.0, "lines": ["危ねぇえ"]}, {"box": [418, 970, 466, 1050], "vertical": true, "font_size": 23.0, "lines": ["や、やあ", "高木さん。"]}, {"box": [114, 967, 185, 1057], "vertical": true, "font_size": 21.0, "lines": ["こんなとこ", "歩いてる", "なんて。"]}], "img_path": "024.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [725, 62, 747, 165], "vertical": true, "font_size": 20.0, "lines": ["もしかして、"]}, {"box": [407, 91, 488, 203], "vertical": true, "font_size": 21.0, "lines": ["道路歩いちゃ", "いけない", "ルール？"]}, {"box": [289, 92, 344, 177], "vertical": true, "font_size": 24.0, "lines": ["一瞬で", "バレてる。"]}, {"box": [53, 79, 104, 196], "vertical": true, "font_size": 21.0, "lines": ["そ、", "そうだけど．．．"]}, {"box": [684, 454, 754, 619], "vertical": true, "font_size": 21.0, "lines": ["へー、", "面白そうだし、ついて", "行ってみよー。"]}, {"box": [376, 477, 396, 542], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．．"]}, {"box": [189, 854, 215, 917], "vertical": true, "font_size": 28.0, "lines": ["あれ？"]}, {"box": [99, 848, 159, 971], "vertical": true, "font_size": 28.0, "lines": ["道路", "歩いてるよ？"]}], "img_path": "025.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [704, 62, 802, 177], "vertical": true, "font_size": 22.0, "lines": ["何かに", "さわってたら", "セーフって", "ルールだから。"]}, {"box": [552, 73, 577, 138], "vertical": true, "font_size": 25.0, "lines": ["ふーん。"]}, {"box": [400, 130, 454, 210], "vertical": true, "font_size": 25.0, "lines": ["家まで", "やるの？"]}, {"box": [171, 133, 221, 261], "vertical": true, "font_size": 22.0, "lines": ["いや、ゴールは", "神社だけど。"]}, {"box": [104, 344, 166, 418], "vertical": true, "font_size": 31.0, "lines": ["へえー、", "神社。"]}, {"box": [234, 610, 289, 726], "vertical": true, "font_size": 19.0, "lines": ["何か願掛け", "してるとか？"]}, {"box": [692, 987, 746, 1051], "vertical": true, "font_size": 29.0, "lines": ["また", "バレ．．．"]}, {"box": [126, 991, 173, 1106], "vertical": true, "font_size": 20.0, "lines": ["そ．．．そっかー", "願掛けかー。"]}], "img_path": "026.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [672, 84, 719, 199], "vertical": true, "font_size": 18.0, "lines": ["そういうのも", "ありだねー。"]}, {"box": [197, 64, 298, 196], "vertical": true, "font_size": 20.0, "lines": ["高木さんに", "勝ちたいって", "願掛けをしてる", "ってバレたら、"]}, {"box": [96, 107, 145, 212], "vertical": true, "font_size": 20.0, "lines": ["全力で邪魔", "されそうだ。"]}, {"box": [700, 426, 747, 541], "vertical": true, "font_size": 18.0, "lines": ["なんとしても", "ゴマかす"]}, {"box": [447, 423, 524, 560], "vertical": true, "font_size": 23.0, "lines": ["テストでいい点", "とれるように．．．", "とかかなー。"]}, {"box": [330, 432, 408, 530], "vertical": true, "font_size": 24.0, "lines": ["へー、", "なんか意外", "だなー。"]}, {"box": [453, 675, 503, 742], "vertical": true, "font_size": 23.0, "lines": ["やると", "したら。"]}, {"box": [456, 833, 506, 932], "vertical": true, "font_size": 24.0, "lines": ["私に勝てる", "ように。"]}, {"box": [357, 836, 433, 944], "vertical": true, "font_size": 24.0, "lines": ["とか", "言うかと", "思ったけど。"]}, {"box": [103, 656, 152, 737], "vertical": true, "font_size": 24.0, "lines": ["な．．．", "何が．．．？"]}], "img_path": "027.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [680, 69, 710, 138], "vertical": true, "font_size": 25.0, "lines": ["危なっ。"]}, {"box": [120, 67, 171, 155], "vertical": true, "font_size": 24.0, "lines": ["おー", "ギリギリ。"]}, {"box": [632, 475, 715, 557], "vertical": true, "font_size": 26.0, "lines": ["図星で", "動揺した", "とか？"]}, {"box": [187, 500, 236, 597], "vertical": true, "font_size": 23.0, "lines": ["ぐ．．．それも", "図星だ。"]}, {"box": [764, 837, 814, 953], "vertical": true, "font_size": 23.0, "lines": ["だが見ていろ", "高木さん。"]}, {"box": [665, 827, 715, 925], "vertical": true, "font_size": 23.0, "lines": ["もう少しでぇじゃ", "神社だ。"]}, {"box": [197, 830, 297, 955], "vertical": true, "font_size": 20.0, "lines": ["そういえば", "神社の前って", "道路じゃ", "なかったっけ。"]}, {"box": [350, 833, 457, 967], "vertical": true, "font_size": 19.0, "lines": ["オレの願掛けが", "成功すれば", "もうそんなコト", "言えないぞ"]}], "img_path": "028.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [700, 64, 746, 161], "vertical": true, "font_size": 20.0, "lines": ["どうやって", "渡るの？"]}, {"box": [454, 71, 485, 126], "vertical": true, "font_size": 29.0, "lines": ["ふっ。"]}, {"box": [367, 64, 395, 166], "vertical": true, "font_size": 20.0, "lines": ["神社の前は、"]}, {"box": [120, 66, 175, 154], "vertical": true, "font_size": 27.0, "lines": ["今工事", "しててね。"]}, {"box": [564, 513, 673, 648], "vertical": true, "font_size": 22.0, "lines": ["通行禁止の", "看板をつたって", "向こうへ", "行けるのさ。"]}, {"box": [728, 840, 753, 909], "vertical": true, "font_size": 25.0, "lines": ["へぇー。"]}, {"box": [453, 691, 486, 782], "vertical": true, "font_size": 30.0, "lines": ["通行型"]}, {"box": [380, 675, 429, 794], "vertical": true, "font_size": 32.0, "lines": ["作業中"]}, {"box": [440, 841, 465, 909], "vertical": true, "font_size": 22.0, "lines": ["ふふふ。"]}, {"box": [145, 615, 269, 690], "vertical": false, "font_size": 32.0, "lines": ["ただいまー"]}, {"box": [349, 882, 395, 964], "vertical": true, "font_size": 22.0, "lines": ["どうだ", "高木さん"]}, {"box": [263, 870, 289, 991], "vertical": true, "font_size": 18.0, "lines": ["オレの勝ちだ。"]}], "img_path": "029.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [697, 596, 718, 673], "vertical": true, "font_size": 21.0, "lines": ["あれ．．．？"]}, {"box": [691, 820, 745, 938], "vertical": true, "font_size": 26.0, "lines": ["工事が", "終わってる！？"]}, {"box": [433, 837, 459, 904], "vertical": true, "font_size": 21.0, "lines": ["嘘だろ。"]}, {"box": [324, 822, 370, 973], "vertical": true, "font_size": 18.0, "lines": ["こんな", "タイミングで．．．！？"]}, {"box": [185, 611, 212, 658], "vertical": true, "font_size": 27.0, "lines": ["こ．．．"]}, {"box": [117, 836, 161, 931], "vertical": true, "font_size": 16.0, "lines": ["そんなコト", "ありえる！？"]}], "img_path": "030.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [345, 74, 473, 283], "vertical": true, "font_size": 25.0, "lines": ["運命が．．．", "オレは高木さんに", "勝てないと", "言っているのか．．．！？"]}, {"box": [361, 526, 392, 645], "vertical": true, "font_size": 25.0, "lines": ["詰み．．．．．か．．．"]}, {"box": [463, 585, 515, 667], "vertical": true, "font_size": 25.0, "lines": ["どう", "するの？"]}, {"box": [165, 888, 194, 982], "vertical": true, "font_size": 29.0, "lines": ["いや．．．"]}], "img_path": "031.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [716, 128, 733, 241], "vertical": true, "font_size": 17.0, "lines": ["まだ．．．ある！！"]}, {"box": [218, 147, 317, 264], "vertical": true, "font_size": 22.0, "lines": ["神はオレに．．．", "助け舟を", "出してくれて"]}, {"box": [116, 137, 313, 374], "vertical": true, "font_size": 20.0, "lines": ["いた．．．！！"]}, {"box": [694, 516, 749, 619], "vertical": true, "font_size": 25.0, "lines": ["高木さんのしてんじゃ", "自転車だ！！"]}, {"box": [123, 296, 144, 361], "vertical": true, "font_size": 19.0, "lines": ["それは、"]}, {"box": [110, 517, 188, 691], "vertical": true, "font_size": 22.0, "lines": ["これを借りれば", "地面に足をつけずに", "余裕で渡れる。"]}, {"box": [169, 853, 197, 939], "vertical": true, "font_size": 20.0, "lines": ["高木さん。"]}, {"box": [670, 847, 748, 980], "vertical": true, "font_size": 20.0, "lines": ["面白がって", "ついてきたのが", "運のつきさ。"]}, {"box": [336, 890, 413, 1008], "vertical": true, "font_size": 23.0, "lines": ["オレはついに", "高木さんに", "勝つ！！"]}], "img_path": "032.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [460, 128, 494, 280], "vertical": true, "font_size": 25.0, "lines": ["自転車貸して。"]}, {"box": [319, 123, 392, 248], "vertical": true, "font_size": 32.0, "lines": ["んーん、", "貸さない。"]}, {"box": [716, 471, 738, 530], "vertical": true, "font_size": 22.0, "lines": ["えぇ？！"]}], "img_path": "033.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [664, 104, 727, 277], "vertical": true, "font_size": 27.0, "lines": ["手なら", "貸してあげるよ。"]}, {"box": [723, 679, 743, 708], "vertical": true, "font_size": 20.0, "lines": ["え。"]}, {"box": [520, 656, 598, 789], "vertical": true, "font_size": 25.0, "lines": ["何かに", "さわってたら", "ＯＫなんでしょ。"]}, {"box": [146, 702, 165, 799], "vertical": true, "font_size": 16.0, "lines": ["どうする？"]}], "img_path": "034.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [729, 112, 750, 173], "vertical": true, "font_size": 21.0, "lines": ["じゃ．．．"]}, {"box": [547, 108, 567, 186], "vertical": true, "font_size": 20.0, "lines": ["じゃあ．．．"]}, {"box": [605, 414, 707, 597], "vertical": true, "font_size": 21.0, "lines": ["恥ずかしがる", "オレを見て", "楽しんでるんだろう。", "高木さん．．．"]}, {"box": [727, 892, 753, 970], "vertical": true, "font_size": 20.0, "lines": ["耐えろ．．"]}, {"box": [456, 911, 508, 990], "vertical": true, "font_size": 22.0, "lines": ["願掛けの", "ためだ．．．"]}, {"box": [254, 905, 286, 960], "vertical": true, "font_size": 31.0, "lines": ["西片。"]}], "img_path": "035.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [384, 124, 465, 194], "vertical": true, "font_size": 26.0, "lines": ["願掛け、", "叶うと", "いいね。"]}, {"box": [665, 652, 687, 741], "vertical": true, "font_size": 20.0, "lines": ["う．．．うん。"]}, {"box": [338, 641, 391, 748], "vertical": true, "font_size": 26.0, "lines": ["ほら、", "ついたよー。"]}, {"box": [133, 649, 240, 803], "vertical": true, "font_size": 23.0, "lines": ["願掛けしても", "高木さんには", "勝てそうにないと", "思った。"]}], "img_path": "036.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [82, 70, 217, 241], "vertical": false, "font_size": 32.0, "lines": ["散"]}, {"box": [380, 501, 418, 516], "vertical": false, "font_size": 12.0, "lines": ["．．．"]}], "img_path": "037.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [147, 69, 174, 114], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}, {"box": [706, 439, 754, 578], "vertical": true, "font_size": 16.0, "lines": ["高木さんから．．．？", "なんだ？"]}, {"box": [574, 516, 638, 539], "vertical": false, "font_size": 18.0, "lines": ["高木さん"]}, {"box": [727, 761, 755, 844], "vertical": true, "font_size": 25.0, "lines": ["ホチ．．．"]}, {"box": [269, 834, 300, 861], "vertical": false, "font_size": 27.0, "lines": ["か"]}, {"box": [197, 830, 226, 860], "vertical": false, "font_size": 25.0, "lines": ["あ"]}, {"box": [629, 971, 731, 1105], "vertical": true, "font_size": 23.0, "lines": ["おお！", "これは", "あのお姉さんの", "飼ってる犬。"]}], "img_path": "038.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [695, 110, 748, 196], "vertical": true, "font_size": 25.0, "lines": ["しかし", "なぜ急に。"]}, {"box": [695, 505, 741, 621], "vertical": true, "font_size": 18.0, "lines": ["．．．さっきと", "場所が違う！"]}, {"box": [483, 519, 508, 652], "vertical": true, "font_size": 20.0, "lines": ["歩いている．．．？"]}, {"box": [265, 539, 317, 627], "vertical": true, "font_size": 23.0, "lines": ["まさか．．．", "高木さん。"]}, {"box": [243, 922, 565, 1156], "vertical": false, "font_size": 32.0, "lines": ["頼まれて犬の散歩", "私は、こんなとしてるんだけど良", "かったら一緒にして、の", "ない？"]}], "img_path": "039.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [692, 420, 747, 539], "vertical": true, "font_size": 25.0, "lines": ["早かったねー", "西片。"]}, {"box": [353, 430, 373, 502], "vertical": true, "font_size": 20.0, "lines": ["まぁね．．．"]}, {"box": [231, 424, 304, 558], "vertical": true, "font_size": 20.0, "lines": ["たまたま．．", "近くを歩いてた", "からさ．．．"]}, {"box": [656, 931, 753, 1110], "vertical": true, "font_size": 20.0, "lines": ["家でダラけてたけど", "犬の散歩したくて", "ダッシュで来たのかと", "思ったよ。"]}, {"box": [331, 946, 352, 1030], "vertical": true, "font_size": 20.0, "lines": ["バレてる。"]}, {"box": [235, 941, 287, 1026], "vertical": true, "font_size": 26.0, "lines": ["いや、", "それより、"]}], "img_path": "040.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [685, 65, 756, 168], "vertical": true, "font_size": 32.0, "lines": ["犬と．．．", "散歩．．．！！"]}, {"box": [156, 82, 208, 162], "vertical": true, "font_size": 27.0, "lines": ["昔からの", "夢が．．．"]}, {"box": [77, 100, 111, 216], "vertical": true, "font_size": 27.0, "lines": ["今日現実に。"]}, {"box": [723, 487, 745, 563], "vertical": true, "font_size": 22.0, "lines": ["フフフ．．．"]}, {"box": [401, 483, 421, 548], "vertical": true, "font_size": 20.0, "lines": ["フフフ。"]}, {"box": [303, 480, 361, 587], "vertical": true, "font_size": 24.0, "lines": ["西片、犬", "好きだねぇ。"]}, {"box": [91, 543, 124, 625], "vertical": true, "font_size": 23.0, "lines": ["クスクス"]}, {"box": [654, 881, 726, 1014], "vertical": true, "font_size": 19.0, "lines": ["い．．．いやー", "そこまでじゃ", "ないけどねー．．．"]}, {"box": [212, 909, 237, 977], "vertical": true, "font_size": 25.0, "lines": ["ふーん。"]}, {"box": [80, 896, 156, 994], "vertical": true, "font_size": 21.0, "lines": ["ま、", "とりあえず", "行こっか。"]}], "img_path": "041.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [93, 147, 125, 227], "vertical": true, "font_size": 27.0, "lines": ["楽しい．．"]}, {"box": [743, 467, 790, 581], "vertical": true, "font_size": 20.0, "lines": ["リードを", "持ちたい．．．！！"]}, {"box": [340, 318, 361, 377], "vertical": true, "font_size": 21.0, "lines": ["けど．．．"]}, {"box": [228, 462, 274, 596], "vertical": true, "font_size": 22.0, "lines": ["散歩といえば", "やはりリード！"]}, {"box": [98, 529, 174, 645], "vertical": true, "font_size": 22.0, "lines": ["リードを", "持ってこその", "犬の散歩。"]}, {"box": [697, 904, 752, 987], "vertical": true, "font_size": 24.0, "lines": ["普通に", "刺むか．．．"]}, {"box": [589, 867, 629, 950], "vertical": true, "font_size": 22.0, "lines": ["だ", "そたせて"]}, {"box": [381, 865, 440, 965], "vertical": true, "font_size": 22.0, "lines": ["大のさんは"]}, {"box": [377, 864, 441, 966], "vertical": true, "font_size": 22.0, "lines": ["へー、そんなに", "したいんだー"]}, {"box": [263, 892, 312, 975], "vertical": true, "font_size": 24.0, "lines": ["どう", "すれば．．．"]}, {"box": [346, 1030, 395, 1110], "vertical": true, "font_size": 22.0, "lines": ["イヤ！", "ダメだ！！"]}, {"box": [348, 1033, 390, 1107], "vertical": true, "font_size": 32.0, "lines": ["イヤ！ダメだ！！"]}, {"box": [94, 883, 162, 949], "vertical": true, "font_size": 32.0, "lines": ["ねえ", "西片。"]}], "img_path": "042.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [360, 107, 433, 205], "vertical": true, "font_size": 22.0, "lines": ["よかったら", "リード", "持たない？"]}, {"box": [65, 63, 89, 106], "vertical": true, "font_size": 24.0, "lines": ["え？"]}, {"box": [466, 591, 490, 653], "vertical": true, "font_size": 24.0, "lines": ["イヤ？"]}, {"box": [301, 596, 351, 676], "vertical": true, "font_size": 25.0, "lines": ["い．．．いや", "持つよ。"]}, {"box": [107, 616, 144, 676], "vertical": true, "font_size": 32.0, "lines": ["持つ。"]}, {"box": [652, 906, 684, 1029], "vertical": true, "font_size": 29.0, "lines": ["おおお．．．"]}], "img_path": "043.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [752, 64, 811, 166], "vertical": true, "font_size": 31.0, "lines": ["散歩", "している．．"]}, {"box": [408, 84, 460, 189], "vertical": true, "font_size": 20.0, "lines": ["オレは今．．．", "犬の散歩を。"]}, {"box": [217, 119, 270, 171], "vertical": true, "font_size": 25.0, "lines": ["ねぇ", "西片。"]}, {"box": [104, 101, 181, 201], "vertical": true, "font_size": 25.0, "lines": ["この子", "走るの好き", "らしいよ。"]}, {"box": [112, 257, 137, 325], "vertical": true, "font_size": 25.0, "lines": ["へぇー。"]}, {"box": [668, 472, 742, 608], "vertical": true, "font_size": 21.0, "lines": ["じゃ．．．じゃあ", "ちょっと走って", "あげようかな。"]}, {"box": [578, 470, 627, 570], "vertical": true, "font_size": 32.0, "lines": ["はうがないなー"]}, {"box": [250, 471, 352, 637], "vertical": true, "font_size": 23.0, "lines": ["うん、だ", "私は歩いていくから", "神社あたりで", "待っててよ。"]}, {"box": [140, 487, 188, 557], "vertical": true, "font_size": 22.0, "lines": ["よし．．．", "じゃあ。"]}, {"box": [651, 915, 727, 1055], "vertical": false, "font_size": 32.0, "lines": ["だっ"]}], "img_path": "044.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [534, 78, 596, 195], "vertical": true, "font_size": 26.0, "lines": ["うおおお", "楽しいー！！"]}, {"box": [143, 78, 206, 229], "vertical": true, "font_size": 29.0, "lines": ["犬と．．．！", "犬と走ってる。"]}, {"box": [540, 765, 597, 839], "vertical": true, "font_size": 29.0, "lines": ["ふーっかー", "疲れた。"]}, {"box": [390, 732, 471, 871], "vertical": true, "font_size": 26.0, "lines": ["高木さんは", "歩いてくるって", "言ってたな．．．"]}, {"box": [97, 753, 150, 887], "vertical": true, "font_size": 18.0, "lines": ["しばらく時間が", "ある．．．か"]}, {"box": [105, 1039, 126, 1099], "vertical": true, "font_size": 21.0, "lines": ["よし！！"]}], "img_path": "045.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [746, 75, 794, 197], "vertical": true, "font_size": 20.0, "lines": ["うぉー", "かわいいなー。"]}, {"box": [446, 65, 466, 204], "vertical": true, "font_size": 20.0, "lines": ["よーしょしよし。"]}, {"box": [344, 82, 393, 168], "vertical": true, "font_size": 24.0, "lines": ["よーし", "よしよし。"]}, {"box": [99, 307, 153, 387], "vertical": true, "font_size": 28.0, "lines": ["よしよし", "よし。"]}, {"box": [119, 457, 171, 544], "vertical": true, "font_size": 26.0, "lines": ["あ、", "いたいた。"]}, {"box": [352, 848, 372, 923], "vertical": true, "font_size": 20.0, "lines": ["ま、まぁ、"]}, {"box": [419, 862, 477, 946], "vertical": true, "font_size": 30.0, "lines": ["楽し", "かった？"]}, {"box": [100, 857, 152, 972], "vertical": true, "font_size": 19.0, "lines": ["いい運動には", "なったよ。"]}], "img_path": "046.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [353, 44, 371, 109], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．"]}, {"box": [122, 55, 229, 152], "vertical": true, "font_size": 22.0, "lines": ["高木さん、", "そろそろ", "リード", "返そうか？"]}, {"box": [36, 189, 59, 233], "vertical": true, "font_size": 23.0, "lines": ["ん？"]}, {"box": [631, 478, 731, 611], "vertical": true, "font_size": 20.0, "lines": ["なんか．．．", "オレばっかり", "持ってて悪いな", "って思って．．．"]}, {"box": [391, 480, 414, 549], "vertical": true, "font_size": 22.0, "lines": ["んーん。"]}, {"box": [100, 496, 179, 658], "vertical": true, "font_size": 22.0, "lines": ["いいよ、西片が", "持ってる方が", "西片楽しそうだし。"]}, {"box": [694, 792, 743, 908], "vertical": true, "font_size": 24.0, "lines": ["いや．．．オレは", "別に．．．"]}, {"box": [333, 846, 440, 944], "vertical": true, "font_size": 21.0, "lines": ["それに私も", "十分すぎる", "くらいに", "楽しいし。"]}], "img_path": "047.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [398, 71, 419, 150], "vertical": true, "font_size": 21.0, "lines": ["だって．．．"]}, {"box": [366, 549, 384, 643], "vertical": true, "font_size": 17.0, "lines": ["だって．．．？"]}, {"box": [389, 854, 496, 901], "vertical": false, "font_size": 27.0, "lines": ["それ"]}, {"box": [659, 875, 705, 972], "vertical": true, "font_size": 20.0, "lines": ["なんでだと", "思う？"]}, {"box": [164, 898, 185, 966], "vertical": true, "font_size": 21.0, "lines": ["さぁー。"]}], "img_path": "048.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [337, 863, 394, 964], "vertical": true, "font_size": 28.0, "lines": ["楽しかった", "ねー。"]}, {"box": [94, 908, 148, 980], "vertical": true, "font_size": 26.0, "lines": ["そう", "だねぇ。"]}], "img_path": "049.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [586, 59, 661, 175], "vertical": true, "font_size": 22.0, "lines": ["あ．．．いや．．．", "いい運動に", "なったかな．．．"]}, {"box": [515, 133, 554, 206], "vertical": true, "font_size": 31.0, "lines": ["あはは"]}, {"box": [103, 243, 124, 321], "vertical": true, "font_size": 21.0, "lines": ["だって．．．"]}, {"box": [383, 232, 463, 405], "vertical": true, "font_size": 20.0, "lines": ["それに私も", "十分すぎるくらいに", "楽しいし。"]}, {"box": [384, 941, 463, 1062], "vertical": true, "font_size": 22.0, "lines": ["だっての続き、", "教えて", "あげよっか。"]}], "img_path": "050.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [672, 124, 732, 192], "vertical": true, "font_size": 32.0, "lines": ["いや．．．", "別に．．．"]}, {"box": [452, 113, 500, 247], "vertical": true, "font_size": 23.0, "lines": ["じゃあメールで", "送るよ。"]}, {"box": [338, 145, 388, 269], "vertical": true, "font_size": 23.0, "lines": ["直接は", "伝えにくいし。"]}, {"box": [413, 568, 463, 657], "vertical": true, "font_size": 26.0, "lines": ["はい、", "送ったよ。"]}, {"box": [257, 715, 281, 778], "vertical": true, "font_size": 24.0, "lines": ["ピロリッ"]}], "img_path": "051.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [388, 53, 413, 88], "vertical": true, "font_size": 25.0, "lines": ["！！"]}, {"box": [623, 585, 650, 646], "vertical": true, "font_size": 27.0, "lines": ["ええ！？"]}, {"box": [333, 592, 386, 678], "vertical": true, "font_size": 26.0, "lines": ["いいの", "撮れたよ。"]}, {"box": [597, 962, 683, 1041], "vertical": true, "font_size": 31.0, "lines": ["西片", "犬好き", "だねぇ。"]}, {"box": [328, 967, 409, 1053], "vertical": true, "font_size": 27.0, "lines": ["べ．．．別に", "普通", "だけど！？"]}], "img_path": "052.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [405, 244, 445, 260], "vertical": false, "font_size": 13.0, "lines": ["なんだな．．．"]}, {"box": [699, 261, 739, 275], "vertical": false, "font_size": 15.0, "lines": ["はいはい．．．"]}, {"box": [106, 635, 151, 647], "vertical": false, "font_size": 14.0, "lines": ["．．．"]}, {"box": [732, 643, 753, 652], "vertical": false, "font_size": 12.0, "lines": ["．．．"]}, {"box": [251, 1011, 301, 1039], "vertical": false, "font_size": 28.0, "lines": ["だん"]}], "img_path": "053.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [658, 80, 712, 164], "vertical": true, "font_size": 25.0, "lines": ["では次は", "これ！"]}, {"box": [376, 61, 393, 124], "vertical": true, "font_size": 17.0, "lines": ["．．．．．．"]}, {"box": [104, 63, 138, 128], "vertical": true, "font_size": 32.0, "lines": ["御門．．．"]}, {"box": [371, 305, 389, 366], "vertical": true, "font_size": 18.0, "lines": ["こ．．．！！"]}, {"box": [100, 318, 125, 387], "vertical": true, "font_size": 25.0, "lines": ["おお！！"]}, {"box": [670, 600, 742, 722], "vertical": true, "font_size": 19.0, "lines": ["オレに．．．", "こんな才能が", "あったなんて"]}, {"box": [160, 645, 189, 773], "vertical": true, "font_size": 26.0, "lines": ["くっくつく。"]}, {"box": [612, 982, 663, 1085], "vertical": true, "font_size": 23.0, "lines": ["見ていろ", "高木さんめ。"]}, {"box": [291, 989, 337, 1092], "vertical": true, "font_size": 19.0, "lines": ["はーーっ", "ほっはっは。"]}], "img_path": "054.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [540, 423, 565, 469], "vertical": true, "font_size": 25.0, "lines": ["ん？"]}, {"box": [264, 406, 290, 457], "vertical": true, "font_size": 26.0, "lines": ["やあ、"]}, {"box": [98, 400, 126, 485], "vertical": true, "font_size": 20.0, "lines": ["高木さん。"]}, {"box": [695, 875, 752, 943], "vertical": true, "font_size": 30.0, "lines": ["早いね", "西片。"]}, {"box": [433, 878, 488, 974], "vertical": true, "font_size": 20.0, "lines": ["今日の日直", "私だよ？"]}, {"box": [324, 892, 346, 980], "vertical": true, "font_size": 21.0, "lines": ["だからさ。"]}], "img_path": "055.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [588, 78, 671, 178], "vertical": true, "font_size": 26.0, "lines": ["勝負", "しないかい", "高木さん。"]}, {"box": [135, 82, 226, 220], "vertical": true, "font_size": 19.0, "lines": ["えーと", "昨日やってた", "番組で西片が", "好きそうなのは．．．"]}, {"box": [640, 618, 697, 735], "vertical": true, "font_size": 22.0, "lines": ["値段当て", "ゲームかな？"]}, {"box": [713, 942, 740, 1034], "vertical": true, "font_size": 25.0, "lines": ["なぁっ！？"]}, {"box": [305, 930, 357, 994], "vertical": true, "font_size": 26.0, "lines": ["な．．．", "なぜ．．．"]}, {"box": [176, 926, 197, 993], "vertical": true, "font_size": 23.0, "lines": ["あはは。"]}, {"box": [85, 924, 135, 1041], "vertical": true, "font_size": 23.0, "lines": ["わかりやすい", "ねえ。"]}], "img_path": "056.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [699, 92, 750, 227], "vertical": true, "font_size": 20.0, "lines": ["当てたから", "私の勝ちかな？"]}, {"box": [392, 100, 473, 246], "vertical": true, "font_size": 26.0, "lines": ["いや．．．", "それは", "ノーカンでしょ。"]}, {"box": [315, 107, 353, 232], "vertical": true, "font_size": 16.0, "lines": ["くそ．．．おそろしい", "高木さん．．．"]}, {"box": [80, 51, 372, 73], "vertical": false, "font_size": 19.0, "lines": ["１上手の高ホさんの", "からかいよ"]}, {"box": [98, 118, 164, 216], "vertical": true, "font_size": 19.0, "lines": ["始める前からさぁ", "少し負けた", "気分だ．．．"]}, {"box": [703, 397, 750, 532], "vertical": true, "font_size": 20.0, "lines": ["それで", "どんなルール？"]}, {"box": [496, 381, 514, 444], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．？"]}, {"box": [103, 394, 203, 556], "vertical": true, "font_size": 22.0, "lines": ["高木さんの", "持ちものの値段を", "オレが", "当てられたら勝ち。"]}, {"box": [720, 793, 746, 843], "vertical": true, "font_size": 26.0, "lines": ["んー。"]}, {"box": [476, 788, 556, 944], "vertical": true, "font_size": 22.0, "lines": ["私は持ちもの", "出すだけ？", "不公平じゃない？"]}, {"box": [398, 799, 418, 914], "vertical": true, "font_size": 20.0, "lines": ["こうしない？"]}, {"box": [105, 642, 126, 703], "vertical": true, "font_size": 22.0, "lines": ["どう？"]}, {"box": [133, 806, 185, 979], "vertical": true, "font_size": 23.0, "lines": ["お互いの持ちものの", "値段言って、"]}, {"box": [50, 842, 73, 966], "vertical": true, "font_size": 23.0, "lines": ["近い方が勝ち。"]}], "img_path": "057.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [748, 67, 793, 145], "vertical": true, "font_size": 22.0, "lines": ["．．．", "いいよ．．．"]}, {"box": [679, 83, 701, 133], "vertical": true, "font_size": 22.0, "lines": ["うん。"]}, {"box": [527, 69, 603, 166], "vertical": true, "font_size": 22.0, "lines": ["じゃあ", "何を出そう", "かなー。"]}, {"box": [101, 92, 174, 178], "vertical": true, "font_size": 22.0, "lines": ["くくく．．．", "むしろ", "好都合だ"]}, {"box": [109, 493, 207, 691], "vertical": true, "font_size": 19.0, "lines": ["オレはこれで", "ピッタリ当てなくても", "高木さんより近ければ", "よくなったんだからな"]}, {"box": [670, 515, 749, 686], "vertical": true, "font_size": 18.0, "lines": ["逆にオレを有利に", "してしまっているぞ", "高木さん"]}, {"box": [186, 848, 212, 945], "vertical": true, "font_size": 20.0, "lines": ["決まった？"]}, {"box": [638, 860, 745, 1017], "vertical": true, "font_size": 24.0, "lines": ["昨日の番組で．．．たくさん", "値段を全て当てた", "オレの能力を", "見せてやる。"]}], "img_path": "058.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [486, 84, 507, 168], "vertical": true, "font_size": 21.0, "lines": ["私はこれ、"]}, {"box": [424, 147, 446, 232], "vertical": true, "font_size": 21.0, "lines": ["ふでばこ。"]}, {"box": [343, 62, 361, 184], "vertical": true, "font_size": 16.0, "lines": ["じゃあオレは"]}, {"box": [72, 87, 94, 192], "vertical": true, "font_size": 21.0, "lines": ["このペンで。"]}, {"box": [733, 560, 754, 626], "vertical": true, "font_size": 20.0, "lines": ["ふーん"]}, {"box": [316, 580, 349, 635], "vertical": true, "font_size": 32.0, "lines": ["１５６円。"]}, {"box": [695, 908, 732, 973], "vertical": true, "font_size": 32.0, "lines": ["な！！"]}, {"box": [373, 890, 397, 1004], "vertical": true, "font_size": 17.0, "lines": ["当たってる？"]}, {"box": [267, 883, 312, 999], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．ヒッタリ", "当たってる．．．"]}], "img_path": "059.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [719, 119, 739, 203], "vertical": true, "font_size": 20.0, "lines": ["よかった。"]}, {"box": [507, 66, 583, 229], "vertical": true, "font_size": 22.0, "lines": ["じゃあこれで", "西片ピッタリじゃ", "ないと、"]}, {"box": [352, 56, 378, 143], "vertical": true, "font_size": 20.0, "lines": ["負けだね。"]}, {"box": [100, 82, 120, 145], "vertical": true, "font_size": 20.0, "lines": ["ぐ．．．"]}, {"box": [118, 512, 192, 686], "vertical": true, "font_size": 22.0, "lines": ["つまりオレに", "プレッシャーだけを", "上のせする作戦．．．"]}, {"box": [609, 522, 742, 696], "vertical": true, "font_size": 21.0, "lines": ["高木さんめ．．．", "オレの持ちものが", "少ないことから", "当てる自信があった", "ってことか"]}, {"box": [682, 876, 728, 978], "vertical": true, "font_size": 17.0, "lines": ["さすがだ．．．", "だがオレも、"]}, {"box": [358, 875, 407, 1030], "vertical": true, "font_size": 20.0, "lines": ["ピッタリ当てれば", "問題はない．．．"]}], "img_path": "060.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [653, 80, 733, 181], "vertical": true, "font_size": 24.0, "lines": ["見たところ", "普通の", "ふでばこ．．．"]}, {"box": [377, 52, 485, 177], "vertical": true, "font_size": 25.0, "lines": ["割りとたか", "高かった", "気がするなー、", "これ。"]}, {"box": [224, 67, 271, 200], "vertical": true, "font_size": 18.0, "lines": ["まどわせようと", "してきた。"]}, {"box": [66, 80, 91, 141], "vertical": true, "font_size": 25.0, "lines": ["だが．．．"]}, {"box": [653, 449, 699, 590], "vertical": true, "font_size": 18.0, "lines": ["そんなのに", "負けてたまるか。"]}, {"box": [149, 501, 194, 598], "vertical": true, "font_size": 32.0, "lines": ["１２００円！！"]}], "img_path": "061.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [576, 59, 598, 164], "vertical": true, "font_size": 21.0, "lines": ["せいかーい"]}, {"box": [267, 105, 322, 222], "vertical": true, "font_size": 20.0, "lines": ["引き分けだね", "じゃあ次の．．．"]}, {"box": [99, 106, 125, 240], "vertical": true, "font_size": 20.0, "lines": ["待って行って！！"]}, {"box": [687, 520, 737, 673], "vertical": true, "font_size": 22.0, "lines": ["このままじゃ勝負", "つかないから、"]}, {"box": [728, 819, 749, 884], "vertical": true, "font_size": 21.0, "lines": ["ふーん"]}, {"box": [584, 820, 602, 924], "vertical": true, "font_size": 16.0, "lines": ["まぁいいよ。"]}, {"box": [488, 817, 541, 942], "vertical": true, "font_size": 20.0, "lines": ["じゃあ何に", "しようかなー。"]}, {"box": [176, 528, 223, 698], "vertical": true, "font_size": 18.0, "lines": ["やっぱりオレだけで", "やらせてよ．．．"]}, {"box": [195, 966, 220, 1050], "vertical": true, "font_size": 25.0, "lines": ["ふふ．．．"]}], "img_path": "062.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [681, 119, 726, 233], "vertical": true, "font_size": 18.0, "lines": ["やはりオレは", "才能がある．．．"]}, {"box": [343, 110, 417, 246], "vertical": true, "font_size": 22.0, "lines": ["このルールなら", "次で確実に", "オレの勝ちだ。"]}, {"box": [234, 53, 283, 158], "vertical": true, "font_size": 22.0, "lines": ["じゃ、これに", "しよう。"]}, {"box": [687, 955, 708, 1048], "vertical": true, "font_size": 20.0, "lines": ["ハンカチ．．．"]}, {"box": [113, 936, 192, 1073], "vertical": true, "font_size": 23.0, "lines": ["これって確か．．", "オレが入学式で", "拾った．．．"]}], "img_path": "063.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [761, 72, 788, 125], "vertical": true, "font_size": 27.0, "lines": ["ふむ。"]}, {"box": [536, 48, 598, 201], "vertical": true, "font_size": 29.0, "lines": ["いい布を", "使っているっぽ"]}, {"box": [392, 160, 455, 195], "vertical": false, "font_size": 17.0, "lines": ["フ．．．"]}, {"box": [139, 46, 197, 154], "vertical": true, "font_size": 27.0, "lines": ["色も", "きれいだし"]}, {"box": [548, 304, 600, 384], "vertical": true, "font_size": 24.0, "lines": ["ズバリ、", "値段は．．．"]}, {"box": [132, 325, 159, 378], "vertical": true, "font_size": 27.0, "lines": ["ねえ。"]}, {"box": [678, 632, 704, 727], "vertical": true, "font_size": 16.0, "lines": ["覚えてる？"]}, {"box": [340, 836, 358, 884], "vertical": true, "font_size": 18.0, "lines": ["おまえはっ"]}, {"box": [152, 622, 259, 760], "vertical": true, "font_size": 22.0, "lines": ["これ、西片が", "入学式で拾って", "くれたハンカチ", "なんだよ。"]}, {"box": [672, 989, 719, 1112], "vertical": true, "font_size": 20.0, "lines": ["あ．．．うん、", "覚えてるけど。"]}, {"box": [166, 990, 247, 1097], "vertical": true, "font_size": 24.0, "lines": ["へー、", "覚えてて", "くれたんだ。"]}], "img_path": "064.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [318, 127, 343, 243], "vertical": true, "font_size": 20.0, "lines": ["うれしいよ。"]}, {"box": [648, 602, 698, 706], "vertical": true, "font_size": 18.0, "lines": ["あの時は", "ありがとね。"]}, {"box": [187, 596, 209, 680], "vertical": true, "font_size": 20.0, "lines": ["い．．．いや。"]}, {"box": [695, 878, 748, 1034], "vertical": true, "font_size": 20.0, "lines": ["西片との思い出が", "あるから、"]}, {"box": [328, 924, 405, 1088], "vertical": true, "font_size": 21.0, "lines": ["私にとって", "とても大切な", "ハンカチなんだー。"]}], "img_path": "065.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [767, 75, 791, 141], "vertical": true, "font_size": 24.0, "lines": ["それで、"]}, {"box": [480, 67, 526, 166], "vertical": true, "font_size": 20.0, "lines": ["いくらだと", "思う？"]}, {"box": [369, 83, 389, 197], "vertical": true, "font_size": 19.0, "lines": ["いくらって．．"]}, {"box": [693, 544, 746, 682], "vertical": true, "font_size": 20.0, "lines": ["そんなコト", "言われたら．．．"]}, {"box": [446, 765, 495, 881], "vertical": true, "font_size": 24.0, "lines": ["わ．．．", "わかんない．．．"]}], "img_path": "066.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [725, 99, 749, 168], "vertical": true, "font_size": 24.0, "lines": ["ふーん。"]}, {"box": [385, 72, 436, 208], "vertical": true, "font_size": 22.0, "lines": ["じゃあ私の", "勝ちってこと？"]}, {"box": [303, 114, 323, 210], "vertical": true, "font_size": 20.0, "lines": ["ぐぬぬ．．．"]}, {"box": [649, 541, 700, 639], "vertical": true, "font_size": 23.0, "lines": ["ズルいぞ", "高木さん．．．"]}, {"box": [178, 564, 215, 631], "vertical": true, "font_size": 30.0, "lines": ["何が？"]}, {"box": [664, 959, 738, 1074], "vertical": true, "font_size": 20.0, "lines": ["そんなふうに", "大げさに", "言われたら、"]}, {"box": [217, 950, 301, 1052], "vertical": true, "font_size": 26.0, "lines": ["値段", "言えるわけ", "ないだろ。"]}, {"box": [152, 936, 179, 982], "vertical": true, "font_size": 27.0, "lines": ["ん？"]}], "img_path": "067.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [500, 98, 555, 222], "vertical": true, "font_size": 22.0, "lines": ["別に大げさに", "言ってないよ。"]}, {"box": [647, 588, 750, 705], "vertical": true, "font_size": 21.0, "lines": ["ねぇ、", "どのへんが", "大げさに", "聞こえたの？"]}, {"box": [296, 633, 356, 744], "vertical": true, "font_size": 28.0, "lines": ["教えて", "ほしいなー。"]}, {"box": [584, 945, 685, 1100], "vertical": true, "font_size": 21.0, "lines": ["そ．．．それより", "高木さん", "日直の仕事", "しなくていいの！？"]}, {"box": [338, 962, 416, 1077], "vertical": true, "font_size": 24.0, "lines": ["あそうだね、", "手伝ってよ", "西片。"]}, {"box": [166, 987, 193, 1037], "vertical": true, "font_size": 27.0, "lines": ["え！？"]}], "img_path": "068.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [343, 111, 529, 192], "vertical": false, "font_size": 32.0, "lines": ["忘れもの"]}], "img_path": "069.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [505, 84, 529, 120], "vertical": true, "font_size": 24.0, "lines": ["あ。"]}, {"box": [495, 78, 537, 130], "vertical": false, "font_size": 32.0, "lines": ["あ。"]}, {"box": [664, 515, 685, 601], "vertical": true, "font_size": 20.0, "lines": ["どしたの。"]}, {"box": [164, 535, 247, 638], "vertical": true, "font_size": 28.0, "lines": ["宿題", "学校に忘れ", "ちゃって．．．"]}, {"box": [734, 890, 807, 1005], "vertical": true, "font_size": 19.0, "lines": ["めんどくさい", "けど．．．取りに", "戻らないと．．"]}, {"box": [476, 888, 523, 986], "vertical": true, "font_size": 21.0, "lines": ["じゃあね", "高木さん．．．"]}, {"box": [426, 896, 447, 980], "vertical": true, "font_size": 21.0, "lines": ["また明日。"]}], "img_path": "070.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [290, 104, 318, 260], "vertical": true, "font_size": 20.0, "lines": ["私もついてくよ。"]}, {"box": [641, 822, 745, 964], "vertical": true, "font_size": 23.0, "lines": ["なんか", "この時間に登校", "してるみたいで", "変な気分だなぁ。"]}, {"box": [397, 816, 415, 918], "vertical": true, "font_size": 16.0, "lines": ["そうだねー"]}, {"box": [263, 808, 345, 946], "vertical": true, "font_size": 22.0, "lines": ["下校してない人", "けっこう", "いるなぁ。"]}], "img_path": "071.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [725, 80, 774, 176], "vertical": true, "font_size": 23.0, "lines": ["カップルが", "残って、"]}, {"box": [418, 111, 470, 236], "vertical": true, "font_size": 20.0, "lines": ["お話してたり", "するらしいよ。"]}, {"box": [350, 69, 367, 131], "vertical": true, "font_size": 17.0, "lines": ["．．．"]}, {"box": [103, 105, 124, 202], "vertical": true, "font_size": 20.0, "lines": ["なんで．．．？"]}, {"box": [99, 332, 180, 466], "vertical": true, "font_size": 25.0, "lines": ["一緒に", "いたいからじゃ", "ないの？"]}, {"box": [695, 646, 742, 742], "vertical": true, "font_size": 20.0, "lines": ["そ、そんな", "理由で．．．？"]}, {"box": [197, 673, 280, 781], "vertical": true, "font_size": 24.0, "lines": ["十分な", "理由じゃ", "ないかなー。"]}, {"box": [724, 938, 741, 983], "vertical": true, "font_size": 17.0, "lines": ["．．．．．"]}], "img_path": "072.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [675, 96, 750, 195], "vertical": true, "font_size": 22.0, "lines": ["なら", "もしかして", "この状況．．"]}, {"box": [308, 99, 380, 253], "vertical": true, "font_size": 18.0, "lines": ["オレたちも", "付き合ってるとか", "思われるのでは"]}, {"box": [660, 384, 740, 544], "vertical": true, "font_size": 23.0, "lines": ["いや．．．違う。", "オレは忘れものを", "取りに来ただけだ。"]}, {"box": [155, 427, 177, 498], "vertical": true, "font_size": 21.0, "lines": ["そう！！"]}, {"box": [720, 751, 739, 865], "vertical": true, "font_size": 16.0, "lines": ["そうだけど．．"]}, {"box": [493, 758, 522, 845], "vertical": true, "font_size": 21.0, "lines": ["高木さん。"]}, {"box": [387, 761, 434, 896], "vertical": true, "font_size": 20.0, "lines": ["ちょ．．．ちょっと", "トイレ！！"]}, {"box": [64, 765, 90, 834], "vertical": true, "font_size": 26.0, "lines": ["ふーん。"]}], "img_path": "073.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [557, 77, 577, 154], "vertical": true, "font_size": 20.0, "lines": ["よしっ！！"]}, {"box": [460, 89, 508, 192], "vertical": true, "font_size": 21.0, "lines": ["トイレの", "窓から出て、"]}, {"box": [103, 105, 182, 280], "vertical": true, "font_size": 22.0, "lines": ["違う道から", "忘れものを回収して", "すぐ帰る"]}, {"box": [712, 567, 735, 682], "vertical": true, "font_size": 21.0, "lines": ["カンペキ！！"]}, {"box": [174, 675, 238, 694], "vertical": false, "font_size": 19.0, "lines": ["消火器"]}], "img_path": "074.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [667, 71, 752, 193], "vertical": true, "font_size": 26.0, "lines": ["確かにだとよ", "男女ペアが．．．", "多いような．．．"]}, {"box": [335, 73, 390, 128], "vertical": true, "font_size": 32.0, "lines": ["おーにしかた", "西片。"]}, {"box": [391, 563, 419, 617], "vertical": true, "font_size": 26.0, "lines": ["よー。"]}, {"box": [722, 566, 749, 643], "vertical": true, "font_size": 21.0, "lines": ["中井君．．．"]}, {"box": [656, 568, 668, 653], "vertical": true, "font_size": 12.0, "lines": ["直、おさん、"]}, {"box": [277, 555, 330, 652], "vertical": true, "font_size": 22.0, "lines": ["何してんの", "放課後に。"]}, {"box": [685, 917, 739, 1034], "vertical": true, "font_size": 26.0, "lines": ["いや．．．", "忘れものを．．"]}, {"box": [104, 952, 192, 1109], "vertical": true, "font_size": 22.0, "lines": ["もー中井君！！", "聞かなくても", "わかるでしょー。"]}], "img_path": "075.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [713, 118, 785, 281], "vertical": true, "font_size": 28.0, "lines": ["私らと", "同じだよっ！！"]}, {"box": [237, 91, 294, 158], "vertical": true, "font_size": 32.0, "lines": ["な。"]}, {"box": [706, 631, 758, 747], "vertical": true, "font_size": 20.0, "lines": ["いや．．．違．．．", "忘れものを．．"]}, {"box": [361, 610, 469, 711], "vertical": true, "font_size": 27.0, "lines": ["そっかー", "じゃあ", "高木さんと", "かー。"]}, {"box": [264, 655, 312, 733], "vertical": true, "font_size": 24.0, "lines": ["ほらほら", "行くよ。"]}, {"box": [209, 611, 231, 718], "vertical": true, "font_size": 20.0, "lines": ["じゃーなー。"]}, {"box": [721, 987, 745, 1028], "vertical": true, "font_size": 24.0, "lines": ["ち．．．"]}, {"box": [604, 994, 658, 1074], "vertical": true, "font_size": 24.0, "lines": ["違うん", "だけど．．．"]}], "img_path": "076.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [671, 132, 746, 267], "vertical": true, "font_size": 20.0, "lines": ["なー、ところで", "そろそろ", "帰ろうぜ。"]}, {"box": [577, 155, 622, 278], "vertical": true, "font_size": 20.0, "lines": ["学校にいる", "理由がねーよ。"]}, {"box": [82, 51, 373, 73], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんＢ"]}, {"box": [155, 172, 236, 306], "vertical": true, "font_size": 24.0, "lines": ["一緒に", "いたいってのが", "理由だよー！！"]}, {"box": [666, 566, 735, 700], "vertical": true, "font_size": 17.0, "lines": ["く．．．さっさと", "宿題を回収して", "帰ろう．．．"]}], "img_path": "077.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [287, 111, 313, 215], "vertical": true, "font_size": 19.0, "lines": ["遅かったね。"]}, {"box": [728, 665, 747, 760], "vertical": true, "font_size": 17.0, "lines": ["なにぃ．．．！！"]}, {"box": [456, 673, 529, 808], "vertical": true, "font_size": 22.0, "lines": ["トイレの", "近くで待ってる", "と思ったのに。"]}, {"box": [319, 663, 391, 778], "vertical": true, "font_size": 18.0, "lines": ["そういえば", "なんでそっち", "からなの？"]}, {"box": [135, 862, 164, 949], "vertical": true, "font_size": 21.0, "lines": ["変だなー。"]}], "img_path": "078.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [697, 83, 743, 204], "vertical": true, "font_size": 20.0, "lines": ["もしかして", "一緒に歩くと、"]}, {"box": [378, 90, 461, 227], "vertical": true, "font_size": 22.0, "lines": ["放課後残ってる", "カップルだと", "思われそうで、"]}, {"box": [60, 84, 135, 188], "vertical": true, "font_size": 22.0, "lines": ["トイレの", "窓から出て", "回ってきた。"]}, {"box": [64, 253, 96, 307], "vertical": true, "font_size": 22.0, "lines": ["とか。"]}, {"box": [702, 526, 719, 640], "vertical": true, "font_size": 17.0, "lines": ["さ．．．さぁ～～．．"]}, {"box": [247, 527, 291, 612], "vertical": true, "font_size": 18.0, "lines": ["けっこう", "多いよね。"]}, {"box": [702, 855, 732, 898], "vertical": true, "font_size": 30.0, "lines": ["へ？"]}, {"box": [551, 1123, 586, 1139], "vertical": false, "font_size": 13.0, "lines": ["．．．"]}, {"box": [270, 869, 350, 959], "vertical": true, "font_size": 25.0, "lines": ["学校に", "残ってる", "カップル。"]}], "img_path": "079.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [726, 57, 743, 162], "vertical": true, "font_size": 16.0, "lines": ["そうかなー"]}, {"box": [399, 59, 472, 204], "vertical": true, "font_size": 23.0, "lines": ["そういうのは", "全く", "見なかったけど。"]}, {"box": [332, 62, 358, 125], "vertical": true, "font_size": 23.0, "lines": ["全く？"]}, {"box": [258, 59, 278, 172], "vertical": true, "font_size": 23.0, "lines": ["ホントにー？"]}, {"box": [104, 89, 132, 133], "vertical": true, "font_size": 28.0, "lines": ["そ．．．"]}, {"box": [693, 517, 742, 660], "vertical": true, "font_size": 21.0, "lines": ["それより、", "回収できたから、"]}, {"box": [315, 539, 363, 617], "vertical": true, "font_size": 20.0, "lines": ["さっさと", "帰ろう！！"]}, {"box": [187, 509, 243, 566], "vertical": true, "font_size": 32.0, "lines": ["お、", "西片。"]}, {"box": [440, 889, 542, 989], "vertical": true, "font_size": 22.0, "lines": ["やっぱ", "高木さんと", "残ってたん", "だなー。"]}, {"box": [248, 989, 385, 1031], "vertical": false, "font_size": 28.0, "lines": ["これからも、こんなのはお"]}, {"box": [119, 910, 146, 956], "vertical": true, "font_size": 27.0, "lines": ["あ．．．"]}], "img_path": "080.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [684, 62, 750, 167], "vertical": true, "font_size": 20.0, "lines": ["い、いや", "だから", "忘れものを．．．"]}, {"box": [501, 70, 519, 192], "vertical": true, "font_size": 16.0, "lines": ["ほいじゃなー"]}, {"box": [82, 51, 372, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [680, 550, 734, 721], "vertical": true, "font_size": 20.0, "lines": ["全く見なかったって", "言ってなかった？"]}, {"box": [105, 570, 125, 646], "vertical": true, "font_size": 20.0, "lines": ["えっと．．．"]}, {"box": [731, 907, 750, 996], "vertical": true, "font_size": 20.0, "lines": ["ま、まぁ．．．"]}, {"box": [641, 912, 687, 1010], "vertical": true, "font_size": 20.0, "lines": ["とりあえず", "帰ろうよ。"]}, {"box": [113, 941, 169, 997], "vertical": true, "font_size": 32.0, "lines": ["ねぇ", "西片。"]}], "img_path": "081.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [356, 124, 442, 230], "vertical": true, "font_size": 25.0, "lines": ["私たちも", "残って", "いかない？"]}, {"box": [715, 595, 736, 687], "vertical": true, "font_size": 20.0, "lines": ["い．．．いや．．．"]}, {"box": [639, 617, 659, 701], "vertical": true, "font_size": 20.0, "lines": ["帰ろうよ。"]}, {"box": [205, 617, 284, 735], "vertical": true, "font_size": 26.0, "lines": ["あ、", "恥ずかしいん", "だ。"]}, {"box": [697, 908, 742, 1059], "vertical": true, "font_size": 20.0, "lines": ["そ、そんなんじゃ", "なくて！！"]}, {"box": [328, 901, 408, 1001], "vertical": true, "font_size": 25.0, "lines": ["残る理由が", "別に", "ないし．．．"]}], "img_path": "082.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [55, 517, 91, 562], "vertical": true, "font_size": 32.0, "lines": ["え。"]}, {"box": [393, 551, 446, 662], "vertical": true, "font_size": 32.0, "lines": ["私には", "あるけどな、"]}, {"box": [287, 624, 340, 713], "vertical": true, "font_size": 32.0, "lines": ["理由。"]}], "img_path": "083.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [567, 49, 639, 210], "vertical": true, "font_size": 20.0, "lines": ["せっかくだから", "宿題して帰ろう", "かなーって、理由"]}, {"box": [697, 616, 742, 694], "vertical": true, "font_size": 20.0, "lines": ["なんだと", "思った？"]}, {"box": [600, 921, 682, 1037], "vertical": true, "font_size": 25.0, "lines": ["宿題は", "家てやるもん", "だし！！"]}, {"box": [247, 936, 293, 1032], "vertical": true, "font_size": 18.0, "lines": ["そうだねー", "帰ろっか。"]}, {"box": [167, 976, 207, 1052], "vertical": true, "font_size": 27.0, "lines": ["あはは"]}], "img_path": "084.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [69, 77, 210, 360], "vertical": true, "font_size": 32.0, "lines": ["海水浴"]}], "img_path": "085.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [735, 105, 767, 223], "vertical": true, "font_size": 28.0, "lines": ["泳ぐぞー！！"]}, {"box": [153, 112, 177, 194], "vertical": true, "font_size": 21.0, "lines": ["おおお。"]}, {"box": [663, 656, 745, 739], "vertical": true, "font_size": 26.0, "lines": ["予定通り", "ささっと", "泳いで、"]}, {"box": [538, 642, 590, 728], "vertical": true, "font_size": 26.0, "lines": ["ウチで", "ゲームな。"]}, {"box": [386, 949, 411, 984], "vertical": true, "font_size": 25.0, "lines": ["あ。"]}], "img_path": "086.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [713, 87, 748, 132], "vertical": false, "font_size": 32.0, "lines": ["あ、"]}, {"box": [721, 96, 741, 126], "vertical": true, "font_size": 20.0, "lines": ["あ、"]}, {"box": [394, 91, 426, 146], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [295, 65, 321, 160], "vertical": true, "font_size": 16.0, "lines": ["高木さん．．．"]}, {"box": [303, 323, 327, 428], "vertical": true, "font_size": 20.0, "lines": ["来てたんだ。"]}, {"box": [30, 316, 174, 387], "vertical": true, "font_size": 32.0, "lines": ["あ．．．", "うん。", "今来た", "とこ．．．"]}, {"box": [690, 660, 745, 750], "vertical": true, "font_size": 24.0, "lines": ["私も今", "来たとこ。"]}, {"box": [466, 666, 514, 782], "vertical": true, "font_size": 20.0, "lines": ["すみれちゃん", "たちと。"]}, {"box": [394, 670, 414, 748], "vertical": true, "font_size": 20.0, "lines": ["そっか．．．"]}, {"box": [101, 690, 178, 794], "vertical": true, "font_size": 21.0, "lines": ["じゃあ", "ケガしない", "ようにねー。"]}], "img_path": "087.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [342, 117, 400, 198], "vertical": true, "font_size": 24.0, "lines": ["見すぎだ", "西片。"]}, {"box": [98, 113, 178, 178], "vertical": true, "font_size": 28.0, "lines": ["な！！", "いや．．．", "別に。"]}, {"box": [727, 547, 749, 666], "vertical": true, "font_size": 21.0, "lines": ["そ．．．それより、"]}, {"box": [626, 571, 673, 670], "vertical": true, "font_size": 21.0, "lines": ["競争するん", "だろ！！"]}, {"box": [321, 867, 339, 909], "vertical": true, "font_size": 18.0, "lines": ["ぐ．．．"]}, {"box": [159, 569, 259, 683], "vertical": true, "font_size": 20.0, "lines": ["あぁそうだ、", "負けたやつが", "ジュースを", "パシリな。"]}], "img_path": "088.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [705, 49, 751, 186], "vertical": true, "font_size": 16.0, "lines": ["ゴーグルを忘れて", "しまうとは．．．"]}, {"box": [541, 80, 582, 168], "vertical": true, "font_size": 18.0, "lines": ["こんなの", "絶対負け．．．"]}, {"box": [410, 61, 427, 89], "vertical": true, "font_size": 17.0, "lines": ["！"]}, {"box": [169, 941, 191, 1037], "vertical": true, "font_size": 20.0, "lines": ["いやいや．．．"]}], "img_path": "089.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [736, 64, 788, 190], "vertical": true, "font_size": 25.0, "lines": ["おい西片、", "最下位だぞー。"]}, {"box": [407, 70, 426, 114], "vertical": true, "font_size": 19.0, "lines": ["ぐ．．．"]}, {"box": [285, 99, 335, 209], "vertical": true, "font_size": 23.0, "lines": ["じゃ", "よろしくー"]}, {"box": [95, 116, 167, 216], "vertical": true, "font_size": 23.0, "lines": ["ゴーグルを", "忘れて", "なければ．．．"]}, {"box": [536, 633, 590, 760], "vertical": true, "font_size": 22.0, "lines": ["えーと、高尾は", "これで．．．"]}, {"box": [269, 636, 310, 696], "vertical": true, "font_size": 32.0, "lines": ["西片。"]}, {"box": [444, 959, 470, 990], "vertical": true, "font_size": 26.0, "lines": ["や。"]}], "img_path": "090.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [339, 94, 422, 234], "vertical": true, "font_size": 26.0, "lines": ["た．．．たかさ", "高木さんも", "ジュースを．．．？"]}, {"box": [80, 51, 373, 72], "vertical": false, "font_size": 20.0, "lines": ["からかいと手の高ホさんの"]}, {"box": [101, 108, 124, 176], "vertical": true, "font_size": 22.0, "lines": ["んーん。"]}, {"box": [52, 568, 107, 624], "vertical": true, "font_size": 30.0, "lines": ["そ．．．", "そう。"]}, {"box": [429, 582, 509, 698], "vertical": true, "font_size": 23.0, "lines": ["西片が", "買いに行くの", "見えたから。"]}, {"box": [633, 921, 734, 1053], "vertical": true, "font_size": 20.0, "lines": ["と．．．ところで", "高木さん、オレ", "ゴーグルは", "忘れたけど、"]}, {"box": [112, 938, 210, 1080], "vertical": true, "font_size": 18.0, "lines": ["うきわは", "はじめから", "持ってくる気", "なかったんだよ。"]}], "img_path": "091.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [588, 65, 611, 108], "vertical": true, "font_size": 23.0, "lines": ["ん？"]}, {"box": [467, 93, 545, 228], "vertical": true, "font_size": 25.0, "lines": ["いや、", "言ってたでしょ", "ロパクで。"]}, {"box": [256, 105, 302, 182], "vertical": true, "font_size": 21.0, "lines": ["うきわも", "って．．．"]}, {"box": [108, 113, 164, 167], "vertical": false, "font_size": 32.0, "lines": ["き"]}, {"box": [698, 550, 747, 635], "vertical": true, "font_size": 21.0, "lines": ["あはは", "ホントだ。"]}, {"box": [606, 556, 652, 639], "vertical": true, "font_size": 21.0, "lines": ["そうにも", "見えるわ"]}, {"box": [171, 574, 222, 656], "vertical": true, "font_size": 27.0, "lines": ["え？ちが！", "違うの！？"]}, {"box": [700, 877, 750, 956], "vertical": true, "font_size": 22.0, "lines": ["じゃあ", "なんて．．．"]}, {"box": [371, 864, 474, 988], "vertical": true, "font_size": 22.0, "lines": ["んー、", "じゃあ西片が", "帰る時に", "こっち見てよ。"]}, {"box": [109, 887, 160, 1012], "vertical": true, "font_size": 22.0, "lines": ["その時", "教えてあげる。"]}], "img_path": "092.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [675, 70, 695, 175], "vertical": true, "font_size": 20.0, "lines": ["じゃーねー。"]}, {"box": [140, 86, 187, 174], "vertical": true, "font_size": 20.0, "lines": ["ちょっと、", "高木さん。"]}, {"box": [649, 408, 749, 510], "vertical": true, "font_size": 21.0, "lines": ["よーし", "涼んだし", "オレんち", "行こーぜー。"]}, {"box": [388, 412, 443, 520], "vertical": true, "font_size": 27.0, "lines": ["海水で", "ベタベタだ。"]}, {"box": [269, 405, 350, 542], "vertical": true, "font_size": 23.0, "lines": ["お前んちで", "シャワー貸して", "くれよ。"]}, {"box": [193, 437, 222, 506], "vertical": true, "font_size": 26.0, "lines": ["１００円な。"]}, {"box": [685, 890, 736, 1012], "vertical": true, "font_size": 22.0, "lines": ["帰りにって．．", "言ってたけど、"]}, {"box": [142, 888, 165, 967], "vertical": true, "font_size": 22.0, "lines": ["どこで．．"]}], "img_path": "093.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [495, 70, 575, 169], "vertical": true, "font_size": 26.0, "lines": ["だから", "見すぎだぞ", "西片。"]}, {"box": [126, 218, 148, 305], "vertical": true, "font_size": 20.0, "lines": ["いやいや。"]}, {"box": [536, 520, 619, 607], "vertical": true, "font_size": 32.0, "lines": ["な．．．何を言っ", "言って．．．"]}, {"box": [386, 543, 410, 587], "vertical": true, "font_size": 24.0, "lines": ["ん？"]}, {"box": [304, 542, 334, 638], "vertical": true, "font_size": 20.0, "lines": ["あ、月本だ。"]}, {"box": [701, 555, 752, 671], "vertical": true, "font_size": 20.0, "lines": ["やっぱりお前", "高木さんを．．．"]}, {"box": [351, 827, 400, 971], "vertical": true, "font_size": 17.0, "lines": ["しないから", "見えてなかった"]}, {"box": [272, 844, 325, 933], "vertical": true, "font_size": 25.0, "lines": ["お前も", "見すぎだ。"]}, {"box": [461, 833, 516, 970], "vertical": true, "font_size": 28.0, "lines": ["月本．．．", "来てたのかぁ．．．"]}], "img_path": "094.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [670, 86, 742, 191], "vertical": true, "font_size": 21.0, "lines": ["やっぱり", "月本、好き", "なんだろう。"]}, {"box": [308, 84, 353, 199], "vertical": true, "font_size": 18.0, "lines": ["んなワケ", "ないだろう！！"]}, {"box": [264, 453, 719, 568], "vertical": true, "font_size": 32.0, "lines": ["き", "だ"]}, {"box": [687, 925, 739, 1011], "vertical": true, "font_size": 26.0, "lines": ["いやいや", "いやいや。"]}, {"box": [249, 911, 301, 1010], "vertical": true, "font_size": 26.0, "lines": ["どしたんだ", "西片。"]}], "img_path": "095.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [674, 108, 749, 262], "vertical": true, "font_size": 21.0, "lines": ["そうだ．．．", "帰りに教えるって", "言ってたんだ。"]}, {"box": [390, 137, 475, 240], "vertical": true, "font_size": 26.0, "lines": ["大声でった", "伝えるとか", "だろう．．．"]}, {"box": [306, 151, 359, 220], "vertical": true, "font_size": 26.0, "lines": ["きっと", "そうだ。"]}, {"box": [93, 112, 195, 264], "vertical": true, "font_size": 21.0, "lines": ["だとしたら", "そんな恥ずかしい", "言葉なワケが", "ない．．．"]}, {"box": [686, 533, 732, 693], "vertical": true, "font_size": 18.0, "lines": ["そう．．．たぶん", "「スイカよ」とかだ。"]}, {"box": [701, 853, 756, 933], "vertical": true, "font_size": 24.0, "lines": ["危ない", "危ない．．．"]}, {"box": [108, 537, 239, 767], "vertical": true, "font_size": 22.0, "lines": ["高木さんめ．．．", "オレが", "「好きだよ」にたどりついて", "あたふたするのも", "計算の上か．．．"]}, {"box": [571, 850, 621, 984], "vertical": true, "font_size": 18.0, "lines": ["動揺するところ", "だったよ。"]}], "img_path": "096.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [685, 72, 742, 191], "vertical": true, "font_size": 24.0, "lines": ["さぁどうぞ", "高木さん"]}, {"box": [269, 602, 292, 644], "vertical": true, "font_size": 23.0, "lines": ["ん？"]}], "img_path": "097.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [400, 82, 428, 178], "vertical": true, "font_size": 21.0, "lines": ["砂に宇．．．！！"]}, {"box": [98, 142, 145, 227], "vertical": true, "font_size": 20.0, "lines": ["なるほど", "その手が"]}, {"box": [234, 359, 281, 493], "vertical": true, "font_size": 19.0, "lines": ["しかし．．", "ということは．．"]}, {"box": [686, 575, 733, 691], "vertical": true, "font_size": 20.0, "lines": ["もしかして．．", "本当に．．．"]}, {"box": [180, 691, 207, 826], "vertical": true, "font_size": 21.0, "lines": ["好．．．なのでは．．．"]}, {"box": [337, 953, 364, 1004], "vertical": true, "font_size": 27.0, "lines": ["ス．．．"]}], "img_path": "098.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [627, 116, 728, 250], "vertical": true, "font_size": 20.0, "lines": ["いや、まだだ", "スイカよ」の", "続もまだ", "消えていない．．"]}, {"box": [269, 82, 325, 180], "vertical": true, "font_size": 24.0, "lines": ["次の．．．次の", "文字は．．．"]}, {"box": [41, 201, 94, 336], "vertical": true, "font_size": 20.0, "lines": ["くそ．．．隠れてて", "見えない"]}, {"box": [650, 439, 711, 590], "vertical": true, "font_size": 27.0, "lines": ["だから", "見すぎだって。"]}, {"box": [302, 437, 352, 502], "vertical": true, "font_size": 26.0, "lines": ["月本を", "さぁー。"]}, {"box": [96, 413, 144, 528], "vertical": true, "font_size": 24.0, "lines": ["いや、", "見てないって！"]}, {"box": [109, 772, 137, 850], "vertical": true, "font_size": 28.0, "lines": ["ホー．．．"]}], "img_path": "099.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [287, 62, 343, 146], "vertical": true, "font_size": 26.0, "lines": ["な．．．波で", "消えて．．．"]}, {"box": [421, 577, 439, 641], "vertical": true, "font_size": 18.0, "lines": ["．．．．．．"]}, {"box": [656, 945, 706, 1044], "vertical": true, "font_size": 24.0, "lines": ["スイカよ", "だ．．"]}, {"box": [162, 976, 213, 1043], "vertical": true, "font_size": 23.0, "lines": ["きっと", "そうだ。"]}], "img_path": "100.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [], "img_path": "101.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [369, 1078, 762, 1113], "vertical": false, "font_size": 32.0, "lines": ["からかい上手の高木さん"]}], "img_path": "102.jpg"}, {"version": "0.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [94, 90, 232, 223], "vertical": true, "font_size": 32.0, "lines": ["魔"]}, {"box": [202, 266, 236, 339], "vertical": true, "font_size": 32.0, "lines": [