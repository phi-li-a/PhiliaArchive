]]], "lines": ["ここは", "じっくりと", "いく。"]}], "img_path": "042.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1080, 166, 1175, 370], "vertical": true, "font_size": 48, "lines_coords": [[[1112.0, 166.0], [1175.0, 166.0], [1175.0, 249.0], [1112.0, 249.0]], [[1080.0, 174.0], [1112.0, 174.0], [1112.0, 369.0], [1080.0, 369.0]]], "lines": ["何か", "しゃべろうよ。"]}, {"box": [590, 246, 629, 394], "vertical": true, "font_size": 34, "lines_coords": [[[590.0, 249.0], [624.0, 249.0], [624.0, 388.0], [590.0, 388.0]]], "lines": ["ニッシー。"]}, {"box": [91, 183, 135, 369], "vertical": true, "font_size": 40, "lines_coords": [[[95.0, 183.0], [135.0, 183.0], [131.0, 369.0], [91.0, 369.0]]], "lines": ["ニッシー！？"]}, {"box": [1038, 905, 1128, 1008], "vertical": true, "font_size": 46, "lines_coords": [[[1076.0, 905.0], [1125.0, 905.0], [1125.0, 1008.0], [1076.0, 1008.0]], [[1038.0, 907.0], [1080.0, 907.0], [1080.0, 1006.0], [1038.0, 1006.0]]], "lines": ["な．．．何", "それ．．．"]}, {"box": [963, 828, 1014, 905], "vertical": false, "font_size": 71, "lines_coords": [[[977.0, 828.0], [1014.0, 836.0], [1001.0, 905.0], [963.0, 898.0]]], "lines": ["オレのこと！？"]}, {"box": [348, 870, 423, 1121], "vertical": true, "font_size": 32, "lines_coords": [[[391.0, 870.0], [423.0, 870.0], [423.0, 1113.0], [391.0, 1113.0]], [[348.0, 870.0], [380.0, 870.0], [380.0, 1121.0], [348.0, 1121.0]]], "lines": ["名前がＮＧワード", "かもしれないから、"]}, {"box": [189, 903, 266, 1100], "vertical": true, "font_size": 32, "lines_coords": [[[223.0, 905.0], [260.0, 903.0], [266.0, 1063.0], [228.0, 1065.0]], [[189.0, 911.0], [215.0, 911.0], [215.0, 1100.0], [189.0, 1100.0]]], "lines": ["違う呼び方", "してるんだよ。"]}, {"box": [722, 1524, 757, 1659], "vertical": true, "font_size": 32, "lines_coords": [[[722.0, 1524.0], [753.0, 1524.0], [757.0, 1659.0], [725.0, 1659.0]]], "lines": ["ニッシー。"]}], "img_path": "043.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1067, 125, 1183, 311], "vertical