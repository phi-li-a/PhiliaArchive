, 1082, 1561], "vertical": true, "font_size": 39, "lines_coords": [[[1038.0, 1417.0], [1082.0, 1417.0], [1082.0, 1496.0], [1038.0, 1496.0]], [[1001.0, 1419.0], [1035.0, 1419.0], [1037.0, 1561.0], [1003.0, 1561.0]], [[969.0, 1423.0], [995.0, 1423.0], [995.0, 1541.0], [969.0, 1541.0]]], "lines": ["ほら、どう", "学校おくれ", "ちゃうよ。"]}, {"box": [860, 1451, 911, 1535], "vertical": true, "font_size": 39, "lines_coords": [[[860.0, 1451.0], [911.0, 1451.0], [911.0, 1535.0], [860.0, 1535.0]]], "lines": ["行こ。"]}, {"box": [393, 1803, 960, 1841], "vertical": false, "font_size": 38, "lines_coords": [[[393.0, 1803.0], [960.0, 1803.0], [960.0, 1841.0], [393.0, 1841.0]]], "lines": ["一からかい上手の高木さん凪・完"]}, {"box": [324, 1430, 435, 1582], "vertical": true, "font_size": 34, "lines_coords": [[[391.0, 1430.0], [435.0, 1430.0], [435.0, 1477.0], [391.0, 1477.0]], [[360.0, 1432.0], [391.0, 1432.0], [391.0, 1573.0], [360.0, 1573.0]], [[324.0, 1436.0], [350.0, 1436.0], [350.0, 1580.0], [324.0, 1580.0]]], "lines": ["あ、", "そうだった", "急がないと。"]}], "img_path": "152.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [123, 1721, 759, 1783], "vertical": false, "font_size": 58, "lines_coords": [[[123.0, 1721.0], [759.0, 1725.0], [759.0, 1783.0], [123.0, 1779.0]]], "lines": ["からかい上手の高木さん"]}], "img_path": "153.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1038, 217, 1091, 421], "vertical": true, "font_size": 40, "lines_coords": [[[1038.0, 217.0], [1078.0, 217.0], [1083.0, 421.0], [1044.0, 421.0]]], "lines": ["今日の帰り道、"]}, {"box": [251, 249, 329, 405], "vertical": true, "font_size": 32, "lines_coords": [[[296.0, 249.0], [328.0, 249.0], [328.0, 405.0], [296.0, 405.0]], [[251.0, 249.0], [283.0, 249.0], [283.0, 386.0], [251.0, 386.0]]], "lines": ["ひみつきち", "つくろう。"]}, {"box": [1117, 939, 1188, 1121], "vertical": true, "font_size": 32, "lines_coords": [[[1155.0, 939.0], [1188.0, 939.0], [1188.0, 1027.0], [1155.0, 1027.0]], [[1117.0, 943.0], [1149.0, 943.0], [1149.0, 1121.0], [1117.0, 1121.0]]], "lines": ["まーた", "へんなことを。"]}, {"box": [801, 931, 911, 1172], "vertical": true, "font_size": 31, "lines_coords": [[[875.0, 931.0], [911.0, 931.0], [911.0, 997.0], [875.0, 997.0]], [[836.0, 937.0], [868.0, 937.0], [868.0, 1134.0], [836.0, 1134.0]], [[802.0, 937.0], [828.0, 937.0], [828.0, 1170.0], [802.0, 1170.0]]], "lines": ["もー", "ユカリちゃんは", "ロマンがないなあ。"]}, {"box": [667, 952, 693, 1117], "vertical": true, "font_size": 25, "lines_coords": [[[667.0, 952.0], [692.0, 952.0], [692.0, 1115.0], [667.0, 1115.0]]], "lines": ["ロマンねえ；"]}, {"box": [620, 1344, 692, 1523], "vertical": true, "font_size": 30, "lines_coords": [[[658.0, 1344.0], [692.0, 1344.0], [692.0, 1470.0], [658.0, 1470.0]], [[620.0, 1344.0], [646.0, 1344.0], [646.0, 1520.0], [620.0, 1520.0]]], "lines": ["いいねー、", "ロマンだねえ。"]}, {"box": [163, 920, 240, 1061], "vertical": true, "font_size": 33, "lines_coords": [[[200.0, 920.0], [234.0, 920.0], [234.0, 1061.0], [200.0, 1061.0]], [[163.0, 920.0], [195.0, 920.0], [195.0, 1021.0], [163.0, 1021.0]]], "lines": ["高いとこが", "いいな。"]}, {"box": [163, 1353, 232, 1554], "vertical": true, "font_size": 29, "lines_coords": [[[200.0, 1353.0], [232.0, 1353.0], [232.0, 1554.0], [200.0, 1554.0]], [[163.0, 1357.0], [189.0, 1357.0], [189.0, 1507.0], [163.0, 1507.0]]], "lines": ["あと、ソファー", "ほしいかな。"]}], "img_path": "154.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1053, 193, 1162, 366], "vertical": true, "font_size": 31, "lines_coords": [[[1134.0, 196.0], [1160.0, 196.0], [1160.0, 363.0], [1134.0, 363.0]], [[1091.0, 193.0], [1127.0, 193.0], [1127.0, 285.0], [1091.0, 285.0]], [[1053.0, 195.0], [1085.0, 195.0], [1085.0, 322.0], [1053.0, 322.0]]], "lines": ["わっかるー！", "あとさ", "机もほしー"]}, {"box": [131, 84, 594, 116], "vertical": false, "font_size": 32, "lines_coords": [[[131.0, 84.0], [594.0, 84.0], [594.0, 116.0], [131.0, 116.0]]], "lines": ["からかい上手の高ホさんの"]}, {"box": [369, 204, 440, 442], "ve