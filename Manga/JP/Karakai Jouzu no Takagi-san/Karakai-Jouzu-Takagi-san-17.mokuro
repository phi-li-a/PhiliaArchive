l": true, "font_size": 32, "lines_coords": [[[444.0, 108.0], [478.0, 108.0], [478.0, 260.0], [444.0, 260.0]], [[403.0, 106.0], [436.0, 106.0], [436.0, 230.0], [403.0, 230.0]], [[360.0, 106.0], [391.0, 106.0], [391.0, 298.0], [360.0, 298.0]]], "lines": ["作ったコト", "ないって", "言ってたけど、"]}, {"box": [112, 84, 270, 270], "vertical": true, "font_size": 32, "lines_coords": [[[234.0, 84.0], [268.0, 84.0], [270.0, 270.0], [236.0, 270.0]], [[195.0, 84.0], [230.0, 84.0], [230.0, 270.0], [195.0, 270.0]], [[151.0, 86.0], [185.0, 86.0], [185.0, 268.0], [151.0, 268.0]], [[112.0, 86.0], [138.0, 86.0], [138.0, 268.0], [112.0, 268.0]]], "lines": ["小学校のとき", "まわりの人は", "作ったりして", "なかったの？"]}, {"box": [1055, 1040, 1174, 1237], "vertical": true, "font_size": 31, "lines_coords": [[[1130.0, 1042.0], [1162.0, 1042.0], [1162.0, 1183.0], [1130.0, 1183.0]], [[1091.0, 1040.0], [1125.0, 1040.0], [1127.0, 1237.0], [1093.0, 1237.0]], [[1055.0, 1042.0], [1082.0, 1042.0], [1082.0, 1218.0], [1055.0, 1218.0]]], "lines": ["私の友達は", "あんまり作って", "なかったかな。"]}, {"box": [772, 1033, 838, 1175], "vertical": true, "font_size": 31, "lines_coords": [[[812.0, 1035.0], [838.0, 1035.0], [838.0, 1175.0], [812.0, 1175.0]], [[772.0, 1033.0], [804.0, 1033.0], [804.0, 1156.0], [772.0, 1156.0]]], "lines": ["男子はよく", "作ってて、"]}, {"box": [596, 1016, 635, 1126], "vertical": true, "font_size": 39, "lines_coords": [[[596.0, 1016.0], [635.0, 1016.0], [635.0, 1126.0], [596.0, 1126.0]]], "lines": ["ふーん。"]}, {"box": [722, 1230, 834, 1432], "vertical": true, "font_size": 31, "lines_coords": [[[797.0, 1230.0], [834.0, 1230.0], [834.0, 1432.0], [797.0, 1432.0]], [[763.0, 1233.0], [795.0, 1233.0], [791.0, 1430.0], [759.0, 1430.0]], [[722.0, 1235.0], [750.0, 1235.0], [753.0, 1359.0], [725.0, 1359.0]]], "lines": ["男子にまじって", "作ってる女子も", "いたけど。"]}, {"box": [150, 1014, 255, 1153], "vertical": true, "font_size": 32, "lines_coords": [[[223.0, 1014.0], [255.0, 1014.0], [255.0, 1153.0], [223.0, 1153.0]], [[187.0, 1016.0], [219.0, 1016.0], [219.0, 1130.0], [187.0, 1130.0]], [[150.0, 1014.0], [181.0, 1014.0], [181.0, 1140.0], [150.0, 1140.0]]], "lines": ["それが急に", "作りたく", "なるって、"]}, {"box": [75, 1207, 185, 1395], "vertical": true, "font_size": 32, "lines_coords": [[[142.0, 1209.0], [181.0, 1207.0], [185.0, 1327.0], [146.0, 1329.0]], [[110.0, 1213.0], [142.0, 1213.0], [142.0, 1395.0], [110.0, 1395.0]], [[75.0, 1213.0], [101.0, 1213.0], [101.0, 1365.0], [75.0, 1365.0]]], "lines": ["子供心が", "遅れてやって", "きたのかな。"]}, {"box": [114, 1524, 196, 1664], "vertical": true, "font_size": 40, "lines_coords": [[[151.0, 1524.0], [196.0, 1524.0], [196.0, 1597.0], [151.0, 1597.0]], [[114.0, 1528.0], [148.0, 1528.0], [148.0, 1663.0], [114.0, 1663.0]]], "lines": ["んー", "というか、"]}], "img_path": "019.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1108, 343, 1259, 609], "vertical": true, "font_size": 39, "lines_coords": [[[1207.0, 343.0], [1254.0, 345.0], [1247.0, 609.0], [1200.0, 607.0]], [[1157.0, 346.0], [1194.0, 346.0], [1194.0, 603.0], [1157.0, 603.0]], [[1110.0, 350.0], [1142.0, 350.0], [1142.0, 510.0], [1110.0, 510.0]]], "lines": ["小学校のころは", "西片いなかった", "からかな。"]}, {"box": [476, 106, 534, 178], "vertical": true, "font_size": 44, "lines_coords": [[[476.0, 116.0], [519.0, 106.0], [534.0, 168.0], [491.0, 178.0]]], "lines": ["へ。"]}, {"box": [1042, 1020, 1192, 1215], "vertical": true, "font_size": 30, "lines_coords": [[[1160.0, 1020.0], [1192.0, 1020.0], [1192.0, 1134.0], [1160.0, 1134.0]], [[1121.0, 1021.0], [1153.0, 1021.0], [1153.0, 1190.0], [1121.0, 1190.0]], [[1087.0, 1023.0], [1113.0, 1023.0], [1113.0, 1215.0], [1087.0, 1215.0]], [[1048.0, 1020.0], [1080.0, 1020.0], [1074.0, 1186.0], [1042.0, 1186.0]]], "lines": ["それは．．．", "オレとだから", "作りたくなった", "ってコト．．．？"]}, {"box": [611, 1044, 648, 1111], "vertical": true, "font_size": 37, "lines_coords": [[[611.0, 1044.0], [648.0, 1044.0], [648.0, 1111.0], [611.0, 1111.0]]], "lines": ["ん？"]}, {"box": [168, 1029, 240, 1154], "vertical": true, "font_size": 36, "lines_coords": [[[196.0, 1029.0], [240.0, 1029.0], [240.0, 1121.0], [196.0, 1121.0]], [[168.0, 1033.0], [195.0, 1033.0], [195.0, 1153.0], [168.0, 1153.0]]], "lines": ["いや．．．", "なんでも。"]}, {"box": [1097, 1546, 1175, 1653], "vertical": true, "font_size": 36, "lines_coords": [[[1136.0, 1546.0], [1175.0, 1546.0], [1175.0, 1593.0], [1136.0, 1593.0]], [[1097.0, 1546.0], [1138.0, 1546.0], [1138.0, 1653.0], [1097.0, 1653.0]]], "lines": ["あ、", "そうだ。"]}, {"box": [913, 1539, 1061, 1710], "vertical": true, "font_size": 36, "lines_coords": [[[1018.0, 1539.0], [1061.0, 1539.0], [1061.0, 1608.0], [1018.0, 1608.0]], [[984.0, 1541.0], [1018.0, 1541.0], [1018.0, 1687.0], [984.0, 1687.0]], [[947.0, 1541.0], [980.0, 1541.0], [980.0, 1710.0], [947.0, 1710.0]], [[913.0, 1545.0], [939.0, 1545.0], [939.0, 1691.0], [913.0, 1691.0]]], "lines": ["ここ", "ひみつきち", "だし、他の人", "には内緒ね。"]}, {"box": [283, 1505, 399, 1701], "vertical": true, "font_size": 30, "lines_coords": [[[356.0, 1505.0], [388.0, 1505.0], [388.0, 1700.0], [356.0, 1700.0]], [[316.0, 1507.0], [348.0, 1507.0], [348.0, 1672.0], [316.0, 1672.0]], [[283.0, 1507.0], [309.0, 1507.0], [309.0, 1683.0], [283.0, 1683.0]]], "lines": ["心配しなくても", "ハズかしくて", "言えないって。"]}], "img_path": "020.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [337, 1593, 652, 1775], "vertical": false, "font_size": 171, "lines_coords": [[[337.0, 1605.0], [646.0, 1593.0], [652.0, 1764.0], [343.0, 1775.0]]], "lines": ["進理ク"]}], "img_path": "021.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1027, 260, 1190, 465], "vertical": true, "font_size": 34, "lines_coords": [[[1157.0, 260.0], [1190.0, 260.0], [1187.0, 431.0], [1153.0, 431.0]], [[1110.0, 264.0], [1147.0, 264.0], [1147.0, 465.0], [1110.0, 465.0]], [[1067.0, 262.0], [1100.0, 262.0], [1100.0, 388.0], [1067.0, 388.0]], [[1027.0, 262.0], [1061.0, 262.0], [1061.0, 388.0], [1027.0, 388.0]]], "lines": ["『ウミガメの", "スープ』という", "ゲームを", "ご存じ？"]}, {"box": [288, 288, 318, 440], "vertical": true, "font_size": 27, "lines_coords": [[[288.0, 288.0], [315.0, 288.0], [315.0, 440.0], [288.0, 440.0]]], "lines": ["ウミガメ？"]}, {"box": [1037, 808, 1198, 1025], "vertical": true, "font_size": 35, "lines_coords": [[[1158.0, 808.0], [1198.0, 808.0], [1198.0, 937.0], [1158.0, 937.0]], [[1117.0, 808.0], [1155.0, 808.0], [1155.0, 1025.0], [1117.0, 1025.0]], [[1078.0, 810.0], [1110.0, 810.0], [1110.0, 963.0], [1078.0, 963.0]], [[1037.0, 810.0], [1068.0, 810.0], [1068.0, 1008.0], [1037.0, 1008.0]]], "lines": ["こちらが", "用意したナゾを", "解き明かす", "推理ゲームよ。"]}, {"box": [545, 787, 795, 1083], "vertical": true, "font_size": 33, "lines_coords": [[[755.0, 791.0], [795.0, 791.0], [795.0, 920.0], [755.0, 920.0]], [[712.0, 787.0], [750.0, 787.0], [753.0, 1038.0], [716.0, 1038.0]], [[673.0, 793.0], [705.0, 793.0], [705.0, 1036.0], [673.0, 1036.0]], [[631.0, 793.0], [663.0, 793.0], [663.0, 991.0], [631.0, 991.0]], [[592.0, 795.0], [618.0, 795.0], [618.0, 1036.0], [592.0, 1036.0]], [[545.0, 791.0], [577.0, 791.0], [579.0, 1080.0], [547.0, 1080.0]]], "lines": ["あなたは", "「ＹＥＳ「ＮＯ」で", "答えられる質問を", "私に投げかけ、", "それを手がかりに", "答えにたどりつくの。"]}, {"box": [172, 804, 248, 1033], "vertical": true, "font_size": 32, "lines_coords": [[[215.0, 806.0], [247.0, 806.0], [247.0, 961.0], [215.0, 961.0]], [[172.0, 804.0], [204.0, 804.0], [204.0, 1031.0], [172.0, 1031.0]]], "lines": ["や．．．やって", "やろうじゃない。"]}, {"box": [547, 1436, 673, 1561], "vertical": true, "font_size": 37, "lines_coords": [[[630.0, 1436.0], [673.0, 1436.0], [673.0, 1516.0], [630.0, 1516.0]], [[592.0, 1438.0], [626.0, 1438.0], [626.0, 1561.0], [592.0, 1561.0]], [[547.0, 1436.0], [581.0, 1436.0], [581.0, 1545.0], [547.0, 1545.0]]], "lines": ["へー、", "面白そう", "だなー。"]}, {"box": [150, 1400, 245, 1592], "vertical": true, "font_size": 48, "lines_coords": [[[180.0, 1400.0], [245.0, 1400.0], [245.0, 1483.0], [180.0, 1483.0]], [[150.0, 1408.0], [181.0, 1408.0], [181.0, 1590.0], [150.0, 1590.0]]], "lines": ["今度", "木村たちと．．．"]}], "