66.0], [453.0, 1393.0], [221.0, 1393.0]], [[215.0, 1411.0], [532.0, 1410.0], [532.0, 1441.0], [215.0, 1443.0]], [[221.0, 1462.0], [868.0, 1462.0], [868.0, 1488.0], [221.0, 1488.0]]], "lines": ["「ゲッサン」２０１４年１月号５月号、７月号〜１１月号掲載作品", "連載担当／板谷真人", "単行本編集責任／石川昌彦", "単行本編集／板谷真人ノ「三輪恭子（アイプロダクション）"]}, {"box": [654, 1108, 1061, 1140], "vertical": false, "font_size": 32, "lines_coords": [[[654.0, 1108.0], [1061.0, 1108.0], [1061.0, 1140.0], [654.0, 1140.0]]], "lines": ["ＣＳｏｉｃｈｉｒｏＹａｎａｍａｔｏｔｏ２０２"]}, {"box": [645, 1149, 995, 1201], "vertical": false, "font_size": 45, "lines_coords": [[[645.0, 1156.0], [995.0, 1149.0], [995.0, 1194.0], [645.0, 1201.0]]], "lines": ["樹正田縄"]}, {"box": [654, 1230, 988, 1256], "vertical": false, "font_size": 26, "lines_coords": [[[654.0, 1230.0], [988.0, 1230.0], [988.0, 1256.0], [654.0, 1256.0]]], "lines": ["中央精版印刷株式会社"]}, {"box": [228, 1507, 384, 1567], "vertical": false, "font_size": 60, "lines_coords": [[[228.0, 1507.0], [384.0, 1507.0], [384.0, 1567.0], [228.0, 1567.0]]], "lines": ["発行所"]}, {"box": [230, 1710, 680, 1728], "vertical": false, "font_size": 18, "lines_coords": [[[230.0, 1710.0], [680.0, 1710.0], [680.0, 1728.0], [230.0, 1728.0]]], "lines": ["〈電話受付は、上・日・祝休日を除く９：３０〜１７．３０）"]}, {"box": [412, 1513, 958, 1539], "vertical": false, "font_size": 26, "lines_coords": [[[412.0, 1513.0], [958.0, 1513.0], [958.0, 1539.0], [412.0, 1539.0]]], "lines": ["〈〒１０－－８００）東京都千代田区一ツ橋二の三の"]}, {"box": [223, 1640, 1207, 1698], "vertical": false, "font_size": 25.0, "lines_coords": [[[223.0, 1640.0], [1207.0, 1642.0], [1207.0, 1668.0], [223.0, 1666.0]], [[223.0, 1674.0], [789.0, 1674.0], [789.0, 1698.0], [223.0, 1698.0]]], "lines": ["●選本には十分注意しており、ますが、印刷、変わると製造しの不備がございましたら「制作局コール", "センターバフリーダイヤルＩＤＡ３３６－０８２）にご連絡ください。"]}, {"box": [223, 1740, 1218, 1828], "vertical": false, "font_size": 22.666666666666668, "lines_coords": [[[223.0, 1740.0], [1218.0, 1740.0], [1218.0, 1764.0], [223.0, 1764.0]], [[225.0, 1773.0], [1215.0, 1773.0], [1215.0, 1792.0], [225.0, 1792.0]], [[223.0, 1803.0], [585.0, 1803.0], [585.0, 1828.0], [223.0, 1828.0]]], "lines": ["●本書の一部または全部を無断で複製、転職、複写（コピー）、スキャン、デジタル化、上演、放送", "等をすることは、著作権法上での例外を除き禁じられています。代行業名等の第三者による本書の", "電子的複製も認められておりません。"]}, {"box": [678, 1543, 1188, 1633], "vertical": false, "font_size": 57.5, "lines_coords": [[[678.0, 1550.0], [960.0, 1550.0], [960.0, 1575.0], [678.0, 1575.0]], [[725.0, 1543.0], [1188.0, 1543.0], [1188.0, 1633.0], [725.0, 1633.0]]], "lines": ["．．．いい！！今回のクロロン編集ＯＳ（２３８）９７２５", "１０月２１日（水）２０１８年１２月１６日（火）においております。参加・小学館・"]}], "img_path": "167.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [116, 1123, 823, 1402], "vertical": false, "font_size": 117.33333333333333, "lines_coords": [[[176.0, 1130.0], [823.0, 1128.0], [823.0, 1166.0], [176.0, 1168.0]], [[118.0, 1123.0], [579.0, 1126.0], [577.0, 1402.0], [116.0, 1398.0]], [[333.0, 1246.0], [710.0, 1246.0], [710.0, 1284.0], [333.0, 1284.0]]], "lines": ["書名、からかいと手の高はさん、ＩＴ教材、ＪＴＭカード", "あるからかいですからそれで、１０００円以上の時間があります。それ以外の", "山本宗一朗〇山本崇一朗ノ小学館雑士会社小学給"]}, {"box": [326, 1305, 1142, 1398], "vertical": false, "font_size": 34.0, "lines_coords": [[[326.0, 1305.0], [596.0, 1306.0], [596.0, 1340.0], [326.0, 1338.0]], [[333.0, 1361.0], [1142.0, 1365.0], [1142.0, 1398.0], [333.0, 1395.0]]], "lines": ["株式会社小学館", "〒１０１－８０１．東京都千代田区一ツ橋２－３－１"]}, {"box": [181, 1477, 896, 1515], "vertical": false, "font_size": 38, "lines_coords": [[[181.0, 1477.0], [896.0, 1477.0], [896.0, 1515.0], [181.0, 1515.0]]], "lines": ["電子書籍制作会社株式会社昭和ブライト"]}, {"box": [178, 1590, 947, 1648], "vertical": false, "font_size": 24.5, "lines_coords": [[[178.0, 1590.0], [947.0, 1590.0], [947.0, 1614.0], [178.0, 1614.0]], [[178.0, 1623.0], [900.0, 1623.0], [900.0, 1648.0], [178.0, 1648.0]]], "lines": ["＊家収録されている作品は、執筆された当時の状況や年代を考慮の上、", "初回掲載時の表現のまま掲載されております。ご了承ください。"]}, {"box": [180, 1687, 1175, 1781], "vertical": false, "font_size": 24.333333333333332, "lines_coords": [[[180.0, 1689.0], [1175.0, 1687.0], [1175.0, 1711.0], [180.0, 1713.0]], [[183.0, 1723.0], [1025.0, 1723.0], [1025.0, 1747.0], [183.0, 1747.0]], [[180.0, 1756.0], [973.0, 1756.0], [973.0, 1781.0], [180.0, 1781.0]]], "lines": ["☆本書の一部または全部を無断で複製、転載、複写（コピー）、スキャン、デジタル化、", "上演、放送等をすることは、著作権法上での例外を除き禁じられています。", "代行業者等の第三者によりる本書の電子的複製も認められておりません。"]}], "img_path": "168.jpg"}]}