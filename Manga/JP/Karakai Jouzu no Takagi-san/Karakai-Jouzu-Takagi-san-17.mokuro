], [472.0, 1050.0]], [[431.0, 870.0], [463.0, 870.0], [463.0, 1006.0], [431.0, 1006.0]]], "lines": ["じゃあ入って", "みようよ。"]}, {"box": [151, 1141, 281, 1299], "vertical": true, "font_size": 40, "lines_coords": [[[230.0, 1141.0], [281.0, 1141.0], [281.0, 1245.0], [230.0, 1245.0]], [[193.0, 1145.0], [226.0, 1145.0], [226.0, 1299.0], [193.0, 1299.0]], [[151.0, 1141.0], [187.0, 1141.0], [187.0, 1226.0], [151.0, 1226.0]]], "lines": ["２人の", "ひみつきち", "だよ。"]}, {"box": [958, 1372, 1153, 1640], "vertical": true, "font_size": 41, "lines_coords": [[[1108.0, 1374.0], [1147.0, 1372.0], [1153.0, 1526.0], [1113.0, 1528.0]], [[1072.0, 1374.0], [1110.0, 1374.0], [1110.0, 1603.0], [1072.0, 1603.0]], [[1040.0, 1376.0], [1072.0, 1376.0], [1072.0, 1640.0], [1040.0, 1640.0]], [[997.0, 1376.0], [1037.0, 1376.0], [1037.0, 1492.0], [997.0, 1492.0]], [[958.0, 1372.0], [997.0, 1372.0], [997.0, 1479.0], [958.0, 1479.0]]], "lines": ["それに西片、", "私がつけてくると", "思って走りまわって", "疲れてる", "でしょ。"]}, {"box": [804, 1395, 890, 1528], "vertical": true, "font_size": 41, "lines_coords": [[[825.0, 1395.0], [890.0, 1395.0], [890.0, 1473.0], [825.0, 1473.0]], [[804.0, 1402.0], [838.0, 1402.0], [838.0, 1528.0], [804.0, 1528.0]]], "lines": ["中で", "休みなよ。"]}, {"box": [511, 1422, 547, 1556], "vertical": true, "font_size": 34, "lines_coords": [[[511.0, 1423.0], [545.0, 1423.0], [545.0, 1554.0], [511.0, 1554.0]]], "lines": ["バレてた。"]}, {"box": [376, 1428, 406, 1566], "vertical": true, "font_size": 27, "lines_coords": [[[376.0, 1428.0], [403.0, 1428.0], [403.0, 1561.0], [376.0, 1561.0]]], "lines": ["ほらほら。"]}], "img_path": "017.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [300, 161, 422, 348], "vertical": true, "font_size": 32, "lines_coords": [[[390.0, 166.0], [421.0, 166.0], [421.0, 288.0], [390.0, 288.0]], [[348.0, 168.0], [375.0, 168.0], [375.0, 348.0], [348.0, 348.0]], [[300.0, 161.0], [339.0, 161.0], [339.0, 264.0], [300.0, 264.0]]], "lines": ["やっぱ．．．", "せまくない？", "これ．．"]}, {"box": 