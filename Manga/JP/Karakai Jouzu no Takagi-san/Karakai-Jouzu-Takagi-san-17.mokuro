, "font_size": 51, "lines_coords": [[[1149.0, 939.0], [1200.0, 939.0], [1200.0, 1023.0], [1149.0, 1023.0]]], "lines": ["な．．．"]}, {"box": [1117, 1541, 1172, 1674], "vertical": true, "font_size": 37, "lines_coords": [[[1117.0, 1541.0], [1172.0, 1541.0], [1172.0, 1674.0], [1117.0, 1674.0]]], "lines": ["不覚．．．！！"]}, {"box": [787, 1503, 995, 1749], "vertical": true, "font_size": 37, "lines_coords": [[[960.0, 1507.0], [995.0, 1507.0], [995.0, 1693.0], [960.0, 1693.0]], [[915.0, 1507.0], [948.0, 1507.0], [950.0, 1661.0], [917.0, 1661.0]], [[879.0, 1509.0], [905.0, 1509.0], [905.0, 1749.0], [879.0, 1749.0]], [[834.0, 1507.0], [866.0, 1507.0], [866.0, 1721.0], [834.0, 1721.0]], [[787.0, 1503.0], [828.0, 1503.0], [828.0, 1586.0], [787.0, 1586.0]]], "lines": ["少し考えれば", "高木さんが", "そう言うのなんて", "わかりきってた", "だろ。"]}, {"box": [313, 1511, 531, 1726], "vertical": true, "font_size": 36, "lines_coords": [[[487.0, 1513.0], [521.0, 1513.0], [517.0, 1666.0], [483.0, 1666.0]], [[440.0, 1513.0], [480.0, 1513.0], [480.0, 1642.0], [440.0, 1642.0]], [[401.0, 1515.0], [433.0, 1515.0], [433.0, 1696.0], [401.0, 1696.0]], [[360.0, 1515.0], [391.0, 1515.0], [391.0, 1726.0], [360.0, 1726.0]], [[313.0, 1511.0], [354.0, 1511.0], [354.0, 1593.0], [313.0, 1593.0]]], "lines": ["力を得たと", "油断して", "そんなコトを", "見逃してしまう", "とは。"]}], "img_path": "128.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1121, 165, 1208, 292], "vertical": true, "font_size": 32, "lines_coords": [[[1168.0, 170.0], [1194.0, 170.0], [1194.0, 292.0], [1168.0, 292.0]], [[1121.0, 165.0], [1160.0, 165.0], [1160.0, 266.0], [1121.0, 266.0]]], "lines": ["考えろ．．．", "何か．．．"]}, {"box": [767, 163, 894, 436], "vertical": true, "font_size": 30, "lines_coords": [[[851.0, 163.0], [883.0, 163.0], [883.0, 316.0], [851.0, 316.0]], [[812.0, 166.0], [838.0, 166.0], [838.0, 315.0], [812.0, 315.0]], [[767.0, 163.0], [798.0, 163.0], [798.0, 436.0], [767.0, 436.0]]], "lines": ["高木さんに", "さわらずに", "持ちあげる方法を．．"]}, {"box": [660, 1