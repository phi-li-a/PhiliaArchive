, 1127, 913], "vertical": true, "font_size": 35, "lines_coords": [[[1093.0, 626.0], [1127.0, 626.0], [1127.0, 780.0], [1093.0, 780.0]], [[1050.0, 624.0], [1087.0, 624.0], [1087.0, 901.0], [1050.0, 901.0]], [[1010.0, 628.0], [1042.0, 628.0], [1042.0, 913.0], [1010.0, 913.0]], [[965.0, 624.0], [1003.0, 624.0], [999.0, 856.0], [962.0, 856.0]]], "lines": ["もしかして", "昨日『１００％片想い』で", "やってた『ウミガメの", "スープ』で勝負？"]}, {"box": [296, 675, 330, 770], "vertical": true, "font_size": 34, "lines_coords": [[[296.0, 675.0], [330.0, 675.0], [330.0, 770.0], [296.0, 770.0]]], "lines": ["えぇ！"]}, {"box": [1113, 1188, 1196, 1301], "vertical": true, "font_size": 40, "lines_coords": [[[1151.0, 1188.0], [1196.0, 1188.0], [1196.0, 1263.0], [1151.0, 1263.0]], [[1113.0, 1190.0], [1149.0, 1190.0], [1151.0, 1301.0], [1115.0, 1301.0]]], "lines": ["なぜ", "それを。"]}, {"box": [765, 1192, 872, 1320], "vertical": true, "font_size": 31, "lines_coords": [[[836.0, 1194.0], [872.0, 1194.0], [872.0, 1282.0], [836.0, 1282.0]], [[800.0, 1192.0], [832.0, 1192.0], [832.0, 1308.0], [800.0, 1308.0]], [[765.0, 1196.0], [791.0, 1196.0], [791.0, 1320.0], [765.0, 1320.0]]], "lines": ["なんか", "そんな顔", "してたよ。"]}, {"box": [637, 1196, 709, 1307], "vertical": true, "font_size": 33, "lines_coords": [[[675.0, 1196.0], [707.0, 1196.0], [707.0, 1306.0], [675.0, 1306.0]], [[637.0, 1196.0], [671.0, 1196.0], [671.0, 1284.0], [637.0, 1284.0]]], "lines": ["エスパー", "か．．．？"]}, {"box": [179, 1190, 293, 1391], "vertical": true, "font_size": 32, "lines_coords": [[[249.0, 1190.0], [283.0, 1190.0], [286.0, 1335.0], [253.0, 1335.0]], [[210.0, 1192.0], [247.0, 1192.0], [247.0, 1391.0], [210.0, 1391.0]], [[180.0, 1196.0], [204.0, 1196.0], [204.0, 1387.0], [180.0, 1387.0]]], "lines": ["こんな人と", "推理ゲームして", "勝てるのか．．．？"]}], "img_path": "024.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1113, 136, 1188, 262], "vertical": true, "font_size": 32, "lines_coords": [[[1155.0, 138.0], [1188.0, 138.0], [1188.0, 260.0], 