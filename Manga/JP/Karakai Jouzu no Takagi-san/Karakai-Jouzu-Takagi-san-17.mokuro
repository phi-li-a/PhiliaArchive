, 290, 1190], "vertical": true, "font_size": 32, "lines_coords": [[[258.0, 1014.0], [290.0, 1014.0], [290.0, 1155.0], [258.0, 1155.0]], [[225.0, 1012.0], [249.0, 1012.0], [249.0, 1190.0], [225.0, 1190.0]]], "lines": ["ありがとな", "ごちそーさま。"]}], "img_path": "084.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [1158, 226, 1185, 418], "vertical": true, "font_size": 32, "lines_coords": [[[1158.0, 226.0], [1185.0, 226.0], [1185.0, 418.0], [1158.0, 418.0]]], "lines": ["あーやだやだ。"]}, {"box": [952, 232, 1074, 480], "vertical": true, "font_size": 32, "lines_coords": [[[1037.0, 232.0], [1074.0, 232.0], [1074.0, 450.0], [1037.0, 450.0]], [[995.0, 232.0], [1029.0, 232.0], [1031.0, 480.0], [997.0, 480.0]], [[956.0, 232.0], [988.0, 232.0], [984.0, 429.0], [952.0, 429.0]]], "lines": ["あいつといると", "私まで子供っぽく", "なっちゃうわ。"]}, {"box": [131, 84, 594, 116], "vertical": false, "font_size": 32, "lines_coords": [[[131.0, 84.0], [594.0, 84.0], [594.0, 116.0], [131.0, 116.0]]], "lines": ["からかい上手の高ホさんの"]}, {"box": [950, 918, 1069, 1102], "vertical": true, "font_size": 33, "lines_coords": [[[1035.0, 920.0], [1068.0, 920.0], [1068.0, 1076.0], [1035.0, 1076.0]], [[993.0, 922.0], [1027.0, 922.0], [1027.0, 1102.0], [993.0, 1102.0]], [[950.0, 920.0], [982.0, 920.0], [982.0, 1083.0], [950.0, 1083.0]]], "lines": ["ここんとこ", "毎日このへん", "走ってんだ。"]}, {"box": [1058, 1387, 1089, 1490], "vertical": true, "font_size": 31, "lines_coords": [[[1058.0, 1387.0], [1089.0, 1387.0], [1089.0, 1490.0], [1058.0, 1490.0]]], "lines": ["．．．．．．？"]}], "img_path": "085.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [{"box": [950, 241, 1077, 440], "vertical": true, "font_size": 34, "lines_coords": [[[1029.0, 241.0], [1074.0, 241.0], [1074.0, 406.0], [1029.0, 406.0]], [[992.0, 247.0], [1023.0, 247.0], [1023.0, 429.0], [992.0, 429.0]], [[952.0, 249.0], [978.0, 249.0], [978.0, 433.0], [952.0, 433.0]]], "lines": ["明日からは、", "お箸もつけて", "おいてやるか。"]}, {"box": [446, 294, 551, 501], "vertical": true, "font_size": 33, "lines_coords": [[[519.0, 296.0], [551.0, 296.0], [551.0, 489.0], [519.0, 489.0]], [[476.0, 294.0], [517.0, 294.0], [517.0, 386.0], [476.0, 386.0]], [[446.0, 294.0], [472.0, 294.0], [472.0, 496.0], [446.0, 496.0]]], "lines": ["おじいちゃーん", "天ぷら", "持ってきたよー。"]}, {"box": [1082, 1044, 1181, 1201], "vertical": true, "font_size": 41, "lines_coords": [[[1113.0, 1050.0], [1168.0, 1044.0], [1181.0, 1196.0], [1127.0, 1201.0]], [[1082.0, 1050.0], [1136.0, 1050.0], [1136.0, 1164.0], [1082.0, 1164.0]]], "lines": ["おい昨日", "浜口が、"]}, {"box": [920, 1040, 1038, 1226], "vertical": true, "font_size": 41, "lines_coords": [[[1005.0, 1042.0], [1038.0, 1042.0], [1038.0, 1222.0], [1005.0, 1222.0]], [[965.0, 1040.0], [999.0, 1040.0], [995.0, 1226.0], [962.0, 1226.0]], [[920.0, 1040.0], [952.0, 1040.0], [956.0, 1196.0], [924.0, 1196.0]]], "lines": ["メガネ女子と", "夜に会ってた", "らしいぞ！"]}, {"box": [731, 1027, 849, 1224], "vertical": true, "font_size": 35, "lines_coords": [[[802.0, 1027.0], [843.0, 1027.0], [843.0, 1121.0], [802.0, 1121.0]], [[768.0, 1031.0], [800.0, 1031.0], [800.0, 1224.0], [768.0, 1224.0]], [[731.0, 1031.0], [763.0, 1031.0], [763.0, 1209.0], [731.0, 1209.0]]], "lines": ["見た目", "子供っぽかった", "って聞いたぞ。"]}, {"box": [485, 1065, 622, 1179], "vertical": true, "font_size": 48, "lines_coords": [[[570.0, 1065.0], [616.0, 1065.0], [616.0, 1168.0], [570.0, 1168.0]], [[528.0, 1066.0], [575.0, 1066.0], [575.0, 1179.0], [528.0, 1179.0]], [[485.0, 1065.0], [536.0, 1065.0], [536.0, 1153.0], [485.0, 1153.0]]], "lines": ["後輩か", "何かか、誰でも", "浜口。"]}, {"box": [172, 1078, 255, 1205], "vertical": true, "font_size": 42, "lines_coords": [[[210.0, 1078.0], [255.0, 1078.0], [255.0, 1149.0], [210.0, 1149.0]], [[172.0, 1080.0], [211.0, 1080.0], [211.0, 1205.0], [172.0, 1205.0]]], "lines": ["い．．．", "いやー．．．"]}], "img_path": "086.jpg"}, {"version": "0.2.0-beta.6", "img_width": 1354, "img_height": 1920, "blocks": [], "img_path": "087.jpg"}, {"version": "0.2.0-beta.6", "img_widt