3.0], [62.0, 653.0]]], "lines": ["１０／２４にしてはい、おしさと緊張でどきどき"]}, {"box": [287, 484, 381, 615], "vertical": true, "font_size": 32.5, "lines_coords": [[[346.0, 490.0], [381.0, 490.0], [381.0, 615.0], [346.0, 615.0]], [[287.0, 484.0], [317.0, 484.0], [317.0, 575.0], [287.0, 575.0]]], "lines": ["いい一方", "に．．．度"]}, {"box": [62, 732, 388, 1287], "vertical": true, "font_size": 80.0, "lines_coords": [[[346.0, 790.0], [388.0, 790.0], [383.0, 1231.0], [342.0, 1231.0]], [[248.0, 799.0], [373.0, 797.0], [379.0, 1250.0], [254.0, 1252.0]], [[110.0, 732.0], [296.0, 732.0], [296.0, 1273.0], [110.0, 1273.0]], [[116.0, 780.0], [158.0, 780.0], [164.0, 1229.0], [123.0, 1229.0]], [[81.0, 745.0], [137.0, 745.0], [131.0, 1287.0], [75.0, 1287.0]], [[62.0, 843.0], [91.0, 843.0], [91.0, 1268.0], [62.0, 1268.0]]], "lines": ["はうァく監様スてしまう", "はうァ～監操スてしまへと敵し簀＿スけにり杜ー素華森一掛品なベ手作に", "ここ料金業業務のため入ってくれた大人ですが、お客様にお客さんに対応して作品を楽しめることがあった様子のプラン撮ってみるのは、", "「自で作って育イフのは", "あの夏品メさゃレッ本頂た", "「作品」だ替ブターでした"]}, {"box": [66, 1364, 89, 1450], "vertical": true, "font_size": 23, "lines_coords": [[[66.0, 1364.0], [89.0, 1364.0], [89.0, 1450.0], [66.0, 1450.0]]], "lines": ["しあ"]}, {"box": [60, 1448, 93, 1490], "vertical": false, "font_size": 36, "lines_coords": [[[60.0, 1454.0], [87.0, 1448.0], [93.0, 1483.0], [66.0, 1490.0]]], "lines": ["い"]}, {"box": [0, 446, 598, 1999], "vertical": false, "font_size": 182.57142857142858, "lines_coords": [[[317.0, 475.0], [352.0, 475.0], [352.0, 523.0], [317.0, 523.0]], [[33.0, 446.0], [319.0, 446.0], [319.0, 594.0], [33.0, 594.0]], [[62.0, 571.0], [354.0, 571.0], [354.0, 607.0], [62.0, 607.0]], [[0.0, 692.0], [394.0, 565.0], [598.0, 1231.0], [191.0, 1356.0]], [[83.0, 1275.0], [298.0, 1264.0], [302.0, 1335.0], [87.0, 1346.0]], [[93.0, 1318.0], [292.0, 1323.0], [292.0, 1366.0], [93.0, 1362.0]], [[95.0, 1222.0], [365.0, 1214.0], [373.0, 1492.0], [104.0, 1500.0]], [[164.0, 1452.0], [191.0, 1460.0], [179.0, 1500.0], [152.0, 1492.0]], [[25.0, 1295.0], [433.0, 1308.0], [423.0, 1661.0], [14.0, 1648.0]], [[58.0, 1579.0], [358.0, 1586.0], [358.0, 1629.0], [58.0, 1623.0]], [[39.0, 1700.0], [189.0, 1700.0], [189.0, 1867.0], [39.0, 1867.0]], [[2.0, 1661.0], [392.0, 1661.0], [392.0, 1953.0], [2.0, 1953.0]], [[0.0, 1690.0], [452.0, 1690.0], [452.0, 1999.0], [0.0, 1999.0]], [[66.0, 1942.0], [388.0, 1942.0], [388.0, 1972.0], [66.0, 1972.0]]], "lines": ["事に描い一度、一度", "います。教学前に大事に話した記事でもう一度初め事にして頂きましてご参加できた", "お湯酒を入学した漫画をもう一度、一冊の本にして頂き、過しさと緊張でどきどき", "．．．", "気持ちもことだなりアニメ化へと訊いくださった方や、参加してくだそった", "アニメ化へと導いくださった方や、参してくだきった皆", "そうだな．．．そういうことになってるんだよなんだろうなんですかもしれないんだからね。", "当にありがました。とても嬉し", "そんなことはないでしょうがないのですが．．．でもそういうことになっているかもしれないと思いますから．．", "とても嬉しいことが作業しているとふと嬉しくて涙が出てきたりしております。", "うしておりまえとこの学校を受験したうったので、やってください", "ああ．．．お兄ちゃん、おはようございます。そういうことはないですけど、どうしてもいいのだろうかもしれないと思いました。", "そういうことですから．．．お兄ちゃんのお母さんにおいしくなってください", "待ってくださった皆様、ありがとうございました。"]}, {"box": [146, 1492, 202, 1548], "vertical": false, "font_size": 38, "lines_coords": [[[146.0, 1521.0], [175.0, 1492.0], [202.0, 1519.0], [173.0, 1548.0]]], "lines": ["そー"]}, {"box": [302, 1275, 388, 1627], "vertical": true, "font_size": 47.0, "lines_coords": [[[346.0, 1277.0], [388.0, 1277.0], [388.0, 1627.0], [346.0, 1627.0]], [[306.0, 1275.0], [358.0, 1275.0], [354.0, 1452.0], [302.0, 1452.0]]], "lines": ["て・加藤ざ．．．何とた", "いい参皆ご"]}, {"box": [279, 1496, 325, 1548], "vertical": false, "font_size": 45, "lines_coords": [[[289.0, 1496.0], [325.0, 1504.0], [315.0, 1548.0], [279.0, 1540.0]]], "lines": ["くて、"]}, {"box": [494, 1137, 534, 1229], "vertical": true, "font_size": 40, "lines_coords": [[[494.0, 1137.0], [534.0, 1137.0], [534.0, 1229.0], [494.0, 1229.0]]], "lines": ["ははっ"]}, {"box": [627, 1072, 678, 1199], "vertical": true, "font_size": 46, "lines_coords": [[[627.0, 1072.0], [673.0, 1072.0], [673.0, 1199.0], [627.0, 1199.0]]], "lines": ["．．．変なの"]}, {"box": [469, 1433, 594, 1727], "vertical": true, "font_size": 33, "lines_coords": [[[557.0, 1435.0], [594.0, 1435.0], [592.0, 1727.0], [554.0, 1727.0]], [[511.0, 1433.0], [546.0, 1433.0], [