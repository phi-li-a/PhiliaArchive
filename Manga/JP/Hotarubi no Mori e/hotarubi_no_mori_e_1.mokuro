827.0, 934.0]]], "lines": ["一人で山に入って", "迷子になったら", "どうする！！"]}, {"box": [585, 780, 769, 1034], "vertical": true, "font_size": 39, "lines_coords": [[[727.0, 782.0], [762.0, 782.0], [769.0, 972.0], [733.0, 972.0]], [[683.0, 782.0], [719.0, 782.0], [721.0, 1034.0], [685.0, 1034.0]], [[637.0, 784.0], [673.0, 784.0], [677.0, 1005.0], [642.0, 1005.0]], [[585.0, 782.0], [633.0, 780.0], [637.0, 888.0], [589.0, 890.0]]], "lines": ["おじいちゃん", "あの森には妖怪が", "住んでいるって", "本当？"]}, {"box": [233, 504, 316, 698], "vertical": true, "font_size": 42, "lines_coords": [[[266.0, 504.0], [316.0, 504.0], [316.0, 579.0], [266.0, 579.0]], [[233.0, 511.0], [266.0, 511.0], [271.0, 698.0], [237.0, 698.0]]], "lines": ["あっ", "おじいちゃん"]}, {"box": [95, 584, 179, 701], "vertical": true, "font_size": 50, "lines_coords": [[[118.0, 584.0], [179.0, 584.0], [179.0, 636.0], [118.0, 636.0]], [[95.0, 632.0], [135.0, 632.0], [135.0, 698.0], [95.0, 698.0]]], "lines": ["蛍", "この"]}, {"box": [99, 805, 226, 1040], "vertical": true, "font_size": 34, "lines_coords": [[[181.0, 809.0], [216.0, 809.0], [216.0, 997.0], [181.0, 997.0]], [[141.0, 805.0], [179.0, 805.0], [175.0, 1040.0], [137.0, 1040.0]], [[100.0, 809.0], [129.0, 809.0], [129.0, 963.0], [100.0, 963.0]]], "lines": ["山神の森か？", "さぁなそういう", "言い伝えだ"]}, {"box": [1148, 1282, 1321, 1533], "vertical": true, "font_size": 35, "lines_coords": [[[1282.0, 1282.0], [1317.0, 1282.0], [1321.0, 1443.0], [1286.0, 1443.0]], [[1236.0, 1284.0], [1273.0, 1284.0], [1275.0, 1533.0], [1238.0, 1533.0]], [[1192.0, 1289.0], [1229.0, 1289.0], [1229.0, 1460.0], [1192.0, 1460.0]], [[1148.0, 1289.0], [1186.0, 1289.0], [1186.0, 1447.0], [1148.0, 1447.0]]], "lines": ["子供の頃は", "妖怪に逢いたくて", "よく友達と", "森へ入った"]}, {"box": [608, 1330, 781, 1585], "vertical": true, "font_size": 36, "lines_coords": [[[735.0, 1330.0], [773.0, 1330.0], [775.0, 1491.0], [737.0, 1491.0]], [[692.0, 1332.0], [727.0, 1332.0], [727.0, 1535.0], [692.0, 1535.0]], [[654.0, 1335.0], [690.0, 1335.0], [690.0, 1491.0], [654.0, 1491.0]], [[608.0, 1335.0], [644.0, 1335.0], [644.0, 1585.0], [608.0, 1585.0]]], "lines": ["夏になると", "夜森の中から", "おはやしが", "聞こえてきた！？"]}, {"box": [1171, 1637, 1300, 1964], "vertical": true, "font_size": 35, "lines_coords": [[[1261.0, 1637.0], [1296.0, 1637.0], [1300.0, 1964.0], [1265.0, 1964.0]], [[1213.0, 1637.0], [1248.0, 1637.0], [1252.0, 1921.0], [1217.0, 1921.0]], [[1171.0, 1641.0], [1200.0, 1641.0], [1204.0, 1919.0], [1175.0, 1919.0]]], "lines": ["結局逢えなかったけど", "目の端でチラチラと", "何かを見た気がした"]}, {"box": [377, 1739, 462, 1927], "vertical": true, "font_size": 35, "lines_coords": [[[421.0, 1739.0], [458.0, 1739.0], [462.0, 1898.0], [425.0, 1898.0]], [[377.0, 1739.0], [412.0, 1739.0], [416.0, 1927.0], [381.0, 1927.0]]], "lines": ["そういえば", "岩ちゃん達が"]}, {"box": [179, 1725, 296, 2033], "vertical": true, "font_size": 35, "lines_coords": [[[260.0, 1727.0], [296.0, 1727.0], [296.0, 1973.0], [260.0, 1973.0]], [[212.0, 1725.0], [250.0, 1725.0], [252.0, 2033.0], [214.0, 2033.0]], [[179.0, 1729.0], [208.0, 1729.0], [208.0, 1881.0], [179.0, 1881.0]]], "lines": ["森の中で夏祭りに", "迷いこんで遊んだって", "．．．．．けれど"]}], "img_path": "016.png"}, {"version": "0.2.0-beta.7", "img_width": 1475, "img_height": 2141, "blocks": [{"box": [1228, 148, 1347, 457], "vertical": true, "font_size": 34, "lines_coords": [[[1311.0, 148.0], [1347.0, 148.0], [1347.0, 303.0], [1311.0, 303.0]], [[1269.0, 150.0], [1299.0, 150.0], [1299.0, 457.0], [1269.0, 457.0]], [[1230.0, 148.0], [1261.0, 148.0], [1259.0, 397.0], [1228.0, 397.0]]], "lines": ["村の人間が", "あの森で夏祭りなんか", "するハズもなくて"]}, {"box": [933, 244, 1211, 545], "vertical": true, "font_size": 34, "lines_coords": [[[1175.0, 244.0], [1211.0, 244.0], [1209.0, 514.0], [1173.0, 514.0]], [[1129.0, 248.0], [1165.0, 248.0], [1165.0, 468.0], [1129.0, 468.0]], [[1060.0, 265.0], [1096.0, 265.0], [1100.0, 485.0], [1064.0, 485.0]], [[1012.0, 263.0], [1050.0, 263.0], [1056.0, 514.0], [1018.0, 514.0]], [[968.0, 265.0], [1004.0, 265.0], [1008.0, 545.0], [972.0, 545.0]], [[933.0, 269.0], [968.0, 269.0], [968.0, 3