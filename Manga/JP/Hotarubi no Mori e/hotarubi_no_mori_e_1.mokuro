 true, "font_size": 38, "lines_coords": [[[735.0, 200.0], [773.0, 200.0], [773.0, 317.0], [735.0, 317.0]]], "lines": ["迷うて．．．"]}, {"box": [234, 171, 351, 403], "vertical": true, "font_size": 35, "lines_coords": [[[307.0, 171.0], [342.0, 171.0], [346.0, 344.0], [311.0, 344.0]]], "lines": ["腹が減って．．"]}, {"box": [1257, 624, 1352, 873], "vertical": true, "font_size": 34, "lines_coords": [[[1305.0, 624.0], [1341.0, 624.0], [1341.0, 781.0], [1305.0, 781.0]], [[1262.0, 624.0], [1293.0, 624.0], [1289.0, 869.0], [1257.0, 869.0]]], "lines": ["大事な柿を", "食べてしもうた．．．"]}, {"box": [522, 610, 645, 829], "vertical": true, "font_size": 34, "lines_coords": [[[595.0, 610.0], [639.0, 610.0], [639.0, 743.0], [595.0, 743.0]], [[553.0, 614.0], [589.0, 614.0], [589.0, 829.0], [553.0, 829.0]], [[522.0, 618.0], [545.0, 618.0], [545.0, 706.0], [522.0, 706.0]]], "lines": ["蛍の柿を", "食べてしもうた", "．．．．．．"]}, {"box": [877, 1178, 938, 1311], "vertical": true, "font_size": 30, "lines_coords": [[[908.0, 1178.0], [938.0, 1178.0], [934.0, 1310.0], [904.0, 1310.0]], [[877.0, 1180.0], [908.0, 1180.0], [908.0, 1264.0], [877.0, 1264.0]]], "lines": ["．．．すまん．．．", "ギン．．．"]}, {"box": [616, 1833, 731, 1974], "vertical": true, "font_size": 54, "lines_coords": [[[616.0, 1893.0], [670.0, 1893.0], [670.0, 1974.0], [616.0, 1974.0]]], "lines": ["いや"]}, {"box": [215, 1854, 250, 2024], "vertical": true, "font_size": 29, "lines_coords": [[[215.0, 1855.0], [244.0, 1855.0], [244.0, 2022.0], [215.0, 2022.0]]], "lines": ["ありがとう"]}], "img_path": "169.png"}, {"version": "0.2.0-beta.7", "img_width": 1475, "img_height": 2137, "blocks": [{"box": [584, 165, 627, 373], "vertical": true, "font_size": 35, "lines_coords": [[[584.0, 166.0], [619.0, 166.0], [619.0, 369.0], [584.0, 369.0]]], "lines": ["ありがとう"]}, {"box": [121, 496, 204, 575], "vertical": true, "font_size": 50, "lines_coords": [[[154.0, 498.0], [204.0, 498.0], [204.0, 575.0], [154.0, 575.0]], [[121.0, 496.0], [171.0, 496.0], [171.0, 571.0], [121.0, 571.0]]], "lines": ["ねえ", "ギン"]}, {"box": [229, 939, 327, 1085], "vertical": true, "font_size": 41, "lines_coords": [[[292.0, 947.0], [327.0, 947.0], [327.0, 1085.0], [292.0, 1085.0]], [[235.0, 939.0], [292.0, 947.0], [285.0, 993.0], [229.0, 985.0]]], "lines": ["そうだな", "蛍"]}, {"box": [878, 953, 1024, 1254], "vertical": true, "font_size": 41, "lines_coords": [[[965.0, 953.0], [1007.0, 953.0], [1001.0, 1254.0], [959.0, 1254.0]], [[917.0, 955.0], [959.0, 955.0], [959.0, 1208.0], [917.0, 1208.0]], [[882.0, 955.0], [920.0, 957.0], [915.0, 1072.0], [878.0, 1070.0]]], "lines": ["「食べてみたいものや", "見てみたいものは", "ある？」"]}, {"box": [175, 1064, 258, 1306], "vertical": true, "font_size": 41, "lines_coords": [[[219.0, 1064.0], [256.0, 1064.0], [258.0, 1256.0], [221.0, 1256.0]], [[175.0, 1066.0], [210.0, 1066.0], [214.0, 1306.0], [179.0, 1306.0]]], "lines": ["それはよく", "わからないけど"]}, {"box": [902, 1519, 1087, 1807], "vertical": true, "font_size": 48, "lines_coords": [[[1022.0, 1519.0], [1074.0, 1519.0], [1074.0, 1727.0], [1022.0, 1727.0]], [[961.0, 1521.0], [1011.0, 1521.0], [1011.0, 1807.0], [961.0, 1807.0]], [[905.0, 1521.0], [947.0, 1521.0], [947.0, 1763.0], [905.0, 1763.0]]], "lines": ["蛍と一緒に", "食べたいものや", "見たいもので"]}, {"box": [287, 1554, 342, 1784], "vertical": true, "font_size": 50, "lines_coords": [[[292.0, 1554.0], [342.0, 1554.0], [337.0, 1784.0], [287.0, 1784.0]]], "lines": ["もうずっと"]}], "img_path": "170.png"}, {"version": "0.2.0-beta.7", "img_width": 1474, "img_height": 2141, "blocks": [{"box": [1070, 112, 1182, 368], "vertical": true, "font_size": 50, "lines_coords": [[[1122.0, 114.0], [1172.0, 114.0], [1177.0, 367.0], [1126.0, 367.0]], [[1070.0, 112.0], [1120.0, 112.0], [1124.0, 367.0], [1074.0, 367.0]]], "lines": ["おれの世界は", "あふれている"]}, {"box": [364, 215, 539, 520], "vertical": true, "font_size": 46, "lines_coords": [[[499.0, 215.0], [539.0, 255.0], [503.0, 288.0], [466.0, 250.0]], [[420.0, 227.0], [472.0, 227.0], [472.0, 363.0], [420.0, 363.0]], [[365.0, 229.0], [407.0, 229.0], [407.0, 520.0], [365.0, 520.0]]], "lines": ["あ", "いつか", "こんな気持ちが"]}, {"box": [1171, 679, 1291, 1095], "vertical": true, "font_size": 44, "lines_coords": [[[1229.0, 679.0], [1275.0, 679.0], [1279.0, 972.0], [1233.0, 972.0]], [[1172.0, 681.0], [1214.0, 681.0], [1214.0, 972.0], [1172.0, 972.0]]], "lines": ["君に伝わる時が", "来るだろうかー"]}, {"box": [514, 963, 544, 1075], "vertical": true, "font_size": 27, "lines_coords": [[[514.0, 968.0], [541.0, 968.0], [541.0, 997.0], [514.0, 997.0]]], "lines": ["ギ"]}, {"box": [248, 748, 294, 865], "vertical": true, "font_size": 30, "lines_coords": [[[261.0, 815.0], [286.0, 815.0], [286.0, 863.0], [261.0, 863.0]], [[261.0, 748.0], [294.0, 756.0], [282.0, 807.0], [248.0, 798.0]]], "lines": ["ーン", "ギー"]}, {"box": [142, 2018, 575, 2053], "vertical": false, "font_size": 30, "lines_coords": [[[146.0, 2019.0], [562.0, 2019.0], [562.0, 2049.0], [146.0, 2049.0]]], "lines": ["蛍火の杜へ特別編／おわり"]}], "img_path": "171.png"}, {"version": "0.2.0-beta.7", "img_width": 1444, "img_height": 2138, "blocks": [{"box": [911, 207, 1381, 515], "vertical": false, "font_size": 82, "lines_coords": [[[972.0, 231.0], [1335.0, 225.0], [1335.0, 269.0], [972.0, 275.0]], [[951.0, 225.0], [1381.0, 250.0], [1368.0, 425.0], [941.0, 400.0]], [[945.0, 233.0], [1001.0, 233.0], [1001.0, 329.0], [945.0, 329.0]], [[911.0, 223.0], [957.0, 223.0], [957.0, 319.0], [911.0, 319.0]], [[997.0, 363.0], [1260.0, 369.0], [1260.0, 419.0], [997.0, 413.0]], [[984.0, 413.0], [1279.0, 413.0], [1279.0, 469.0], [984.0, 469.0]], [[941.0, 457.0], [1316.0, 453.0], [1316.0, 511.0], [941.0, 515.0]]], "lines": ["で描いてきた漫画の中で", "まて聞いてきた漫画の中で、番迷いなく描ききることの出来た作品でした。そして色々な方と", "まば番", "今ぃー", "そして色々な方と", "ご縁を繋いでくれた", "大事な作品となりました。"]}, {"box": [594, 75, 903, 160], "vertical": false, "font_size": 79, "lines_coords": [[[596.0, 75.0], [903.0, 81.0], [901.0, 160.0], [594.0, 154.0]]], "lines": ["あとがき"]}, {"box": [888, 620, 1437, 1198], "vertical": false, "font_size": 56, "lines_coords": [[[1035.0, 661.0], [1279.0, 661.0], [1279.0, 705.0], [1035.0, 705.0]], [[911.0, 734.0], [1437.0, 749.0], [1433.0, 914.0], [907.0, 899.0]], [[888.0, 716.0], [1421.0, 716.0], [1421.0, 780.0], [888.0, 780.0]], [[918.0, 778.0], [945.0, 778.0], [945.0, 818.0], [918.0, 818.0]], [[928.0, 874.0], [1385.0, 872.0], [1385.0, 914.0], [928.0, 916.0]], [[897.0, 916.0], [1404.0, 924.0], [1404.0, 968.0], [897.0, 960.0]], [[911.0, 968.0], [1402.0, 968.0], [1402.0, 1012.0], [911.0, 1012.0]], [[966.0, 1010.0], [1341.0, 1010.0], [1341.0, 1066.0], [966.0, 1066.0]], [[993.0, 1064.0], [1322.0, 1064.0], [1322.0, 1106.0], [993.0, 1106.0]], [[901.0, 1112.0], [1410.0, 1114.0], [1410.0, 1150.0], [901.0, 1148.0]], [[972.0, 1162.0], [1337.0, 1162.0], [1337.0, 1198.0], [972.0, 1198.0]]], "lines": ["星も見えない", "人間っこくで世間知りずな男の子が自分の無力でにしゅんとする話が描きたくて出来たお話です。強いている人の親御となんて", "人懐っこくて世間知らずな男の子が", "白", "俯いている人の顔を回り込んで", "覗きこむような、ちょっと無神経で", "でもそういう強さのあるキャラに", "出来ていれば嬉しいです。", "石田タイプの女の子は", "なかなか描いたことがなかったので", "難しくも楽しかったです。"]}, {"box": [191, 223, 776, 865], "vertical": false, "font_size": 41, "lines_coords": [[[354.0, 223.0], [607.0, 223.0], [607.0, 281.0], [354.0, 281.0]], [[321.0, 292.0], [648.0, 296.0], [648.0, 346.0], [321.0, 342.0]], [[269.0, 352.0], [690.0, 346.0], [690.0, 388.0], [269.0, 394.0]], [[235.0, 400.0], [736.0, 400.0], [736.0, 436.0], [235.0, 436.0]], [[361.0, 444.0], [607.0, 444.0], [607.0, 486.0], [361.0, 486.0]], [[200.0, 480.0], [759.0, 492.0], [759.0, 542.0], [200.0, 530.0]], [[252.0, 536.0], [719.0, 540.0], [719.0, 582.0], [252.0, 578.0]], [[262.0, 586.0], [709.0, 588.0], [709.0, 624.0], [262.0, 622.0]], [[294.0, 630.0], [680.0, 630.0], [680.0, 674.0], [294.0, 674.0]], [[246.0, 682.0], [726.0, 684.0], [726.0, 720.0], [246.0, 718.0]], [[329.0, 728.0], [644.0, 728.0], [644.0, 770.0], [329.0, 770.0]], [[221.0, 768.0], [260.0, 768.0], [260.0, 785.0], [221.0, 785.0]], [[214.0, 774.0], [749.0, 774.0], [749.0, 816.0], [214.0, 816.0]], [[239.0, 822.0], [734.0, 822.0], [734.0, 858.0], [239.0, 858.0]]], "lines": ["体温のかけら", "想い合っているけれど、", "ハッピーエンドとは言い難い", "ちょっと意地悪なものが描きたくて", "描いた作品です。", "海の近くに住んだことがなかったので、", "色々描き詰まりそうになる所を、", "海近くに住んでいらっしゃった", "ことのある当時の編集長が", "アドバイスや励ましをくださった", "思い出深い作品です。", "そんこ", "原稿でも、色々な方に手伝って頂いて", "見直すと胸がいっぱいになります。"]}, {"box": [116, 954, 662, 1561], "vertical": false, "font_size": 41, "lines_coords": [[[206.0, 954.0], [571.0, 958.0], [571.0, 1016.0], [206.0, 1012.0]], [[204.0, 1025.0], [567.0, 1029.0], [567.0, 1079.0], [204.0, 1075.0]], [[127.0, 1083.0], [642.0, 1087.0], [642.0, 1121.0], [127.0, 1117.0]], [[137.0, 1137.0], [640.0, 1137.0], [640.0, 1167.0], [137.0, 1167.0]], [[269.0, 1179.0], [507.0, 1179.0], [507.0, 1221.0], [269.0, 1221.0]], [[137.0, 1219.0], [632.0, 1223.0], [632.0, 1267.0], [137.0, 1263.0]], [[179.0, 1252.0], [613.0, 1258.0], [613.0, 1321.0], [179.0, 1315.0]], [[223.0, 1321.0], [550.0, 1321.0], [550.0, 1357.0], [223.0, 1357.0]], [[125.0, 1365.0], [644.0, 1365.0], [644.0, 1407.0], [125.0, 1407.0]], [[189.0, 1415.0], [588.0, 1415.0], [588.0, 1451.0], [189.0, 1451.0]], [[292.0, 1465.0], [479.0, 1465.0], [479.0, 1494.0], [292.0, 1494.0]], [[227.0, 1513.0], [548.0, 1515.0], [548.0, 1545.0], [227.0, 1542.0]]], "lines": ["蛍火の社へ特別編", "きちんと完結したお話に、", "付け足しをするのは難しかったので、", "ページがあったら描いてみたかった", "エピソードから、", "ギン視点のものを選んでみました。", "本編を読んでくださった方の", "イメージを壊さないか、", "すごく緊張しながら描いたのですが", "やはり、もう一度ギンや蛍を", "描けたことが", "とても嬉しかったです。"]}, {"box": [146, 1634, 613, 1735], "vertical": false, "font_size": 54.0, "lines_coords": [[[300.0, 1634.0], [463.0, 1638.0], [463.0, 1682.0], [300.0, 1678.0]], [[146.0, 1666.0], [613.0, 1670.0], [613.0, 1735.0], [146.0, 1730.0]]], "lines": ["読んで頂き、", "本当にありがとうございました。"]}, {"box": [185, 1765, 592, 2008], "vertical": false, "font_size": 32, "lines_coords": [[[342.0, 1770.0], [431.0, 1770.0], [431.0, 1801.0], [342.0, 1801.0]], [[340.0, 1810.0], [431.0, 1810.0], [431.0, 1841.0], [340.0, 1841.0]], [[340.0, 1847.0], [434.0, 1847.0], [434.0, 1885.0], [340.0, 1885.0]], [[308.0, 1893.0], [463.0, 1893.0], [463.0, 1922.0], [308.0, 1922.0]], [[185.0, 1931.0], [588.0, 1933.0], [588.0, 1962.0], [185.0, 1960.0]], [[204.0, 1968.0], [565.0, 1973.0], [565.0, 2008.0], [204.0, 2004.0]]], "lines": ["佐藤様", "種岡様", "柳沢様", "現代書院様", "お手伝いくださいました皆様", "ありがとうございました。"]}], "img_path": "172.png"}, {"version": "0.2.0-beta.7", "img_width": 1447, "img_height": 2136, "blocks": [{"box": [120, 173, 587, 244], "vertical": false, "font_size": 24.333333333333332, "lines_coords": [[[120.0, 173.0], [189.0, 173.0], [189.0, 202.0], [120.0, 202.0]], [[125.0, 212.0], [306.0, 214.0], [306.0, 244.0], [125.0, 241.0]], [[300.0, 223.0], [587.0, 223.0], [587.0, 237.0], [300.0, 237.0]]], "lines": ["《初出》", "●蛍火の杜へ２０", "２００２年、ＬａｌａＤＸ７月号掲載"]}, {"box": [123, 273, 558, 300], "vertical": false, "font_size": 27, "lines_coords": [[[123.0, 273.0], [558.0, 273.0], [558.0, 300.0], [123.0, 300.0]]], "lines": ["●体温のかけら，２００３年ＬａＬａ８月号掲載"]}, {"box": [125, 329, 585, 350], "vertical": false, "font_size": 21, "lines_coords": [[[125.0, 329.0], [585.0, 329.0], [585.0, 350.0], [125.0, 350.0]]], "lines": ["●星も見えない。２００５年ＬａＬａＤＸ３５号掲載"]}, {"box": [127, 385, 458, 406], "vertical": false, "font_size": 21, "lines_coords": [[[127.0, 385.0], [458.0, 385.0], [458.0, 406.0], [127.0, 406.0]]], "lines": ["●蛍火の杜へ特別編一描き下ろし"]}, {"box": [1231, 805, 1322, 865], "vertical": false, "font_size": 36, "lines_coords": [[[1259.0, 802.0], [1296.0, 802.0], [1296.0, 843.0], [1259.0, 843.0]], [[1234.0, 831.0], [1319.0, 831.0], [1319.0, 868.0], [1234.0, 868.0]]], "lines": ["ＨＣＦＣ", "ＳＰＥＣＩＡＬ"]}, {"box": [1241, 924, 1312, 1362], "vertical": true, "font_size": 46, "lines_coords": [[[1248.0, 959.0], [1307.0, 959.0], [1301.0, 1355.0], [1242.0, 1355.0]], [[1261.0, 924.0], [1294.0, 924.0], [1294.0, 953.0], [1261.0, 953.0]]], "lines": ["蛍火の杜へ", "蔵"]}, {"box": [973, 1073, 1004, 1130], "vertical": true, "font_size": 25, "lines_coords": [[[977.0, 1076.0], [1002.0, 1078.0], [998.0, 1126.0], [973.0, 1124.0]]], "lines": ["著者"]}, {"box": [1118, 1080, 1183, 1579], "vertical": true, "font_size": 20, "lines_coords": [[[1153.0, 1080.0], [1173.0, 1080.0], [1173.0, 1574.0], [1153.0, 1574.0]], [[1121.0, 1084.0], [1142.0, 1084.0], [1142.0, 1579.0], [1121.0, 1579.0]]], "lines": ["この一一年、九月、「十日、第一刷発行", "この二年、五月、十五日、第十制発行"]}, {"box": [971, 1261, 1012, 1725], "vertical": true, "font_size": 29, "lines_coords": [[[975.0, 1261.0], [1004.0, 1261.0], [1004.0, 1725.0], [975.0, 1725.0]]], "lines": ["緑川はさっき「ｏｉｎｈｏｎｉｎｉｔｉｏｎ"]}, {"box": [884, 1073, 921, 1157], "vertical": true, "font_size": 33, "lines_coords": [[[888.0, 1074.0], [921.0, 1076.0], [917.0, 1155.0], [884.0, 1153.0]]], "lines": ["発行人"]}, {"box": [802, 1074, 832, 1157], "vertical": true, "font_size": 29, "lines_coords": [[[802.0, 1076.0], [831.0, 1076.0], [831.0, 1155.0], [802.0, 1155.0]]], "lines": ["発行所"]}, {"box": [888, 1259, 923, 1405], "vertical": true, "font_size": 29, "lines_coords": [[[890.0, 1264.0], [919.0, 1264.0], [919.0, 1401.0], [890.0, 1401.0]]], "lines": ["酒井俊朗"]}, {"box": [534, 1074, 560, 1212], "vertical": true, "font_size": 26, "lines_coords": [[[534.0, 1074.0], [560.0, 1074.0], [560.0, 1212.0], [534.0, 1212.0]]], "lines": ["印刷・製本"]}, {"box": [683, 1259, 831, 1662], "vertical": true, "font_size": 28, "lines_coords": [[[802.0, 1264.0], [831.0, 1264.0], [831.0, 1514.0], [802.0, 1514.0]], [[765.0, 1259.0], [792.0, 1259.0], [792.0, 1468.0], [765.0, 1468.0]], [[729.0, 1261.0], [758.0, 1261.0], [758.0, 1660.0], [729.0, 1660.0]], [[685.0, 1259.0], [715.0, 1259.0], [713.0, 1662.0], [683.0, 1662.0]]], "lines": ["株式会社白泉社", "〒１０１－００ｋｍ", "東京都千代田区神田波路町ニーニュース", "電話『親狼』○ミー三五ニ六「ハワニカ"]}, {"box": [529, 1074, 566, 1546], "vertical": true, "font_size": 29, "lines_coords": [[[531.0, 1074.0], [560.0, 1074.0], [558.0, 1541.0], [529.0, 1541.0]]], "lines": ["印刷・製本「図書印刷株式会社"]}, {"box": [617, 1316, 679, 1664], "vertical": true, "font_size": 28, "lines_coords": [[[648.0, 1316.0], [677.0, 1316.0], [679.0, 1662.0], [650.0, 1662.0]], [[617.0, 1318.0], [644.0, 1318.0], [644.0, 1664.0], [617.0, 1664.0]]], "lines": ["『販売』〇三Ｔ三五三六－八〇二〇", "【制作】○ミーミ五三六－八〇二〇"]}, {"box": [442, 1075, 473, 1132], "vertical": true, "font_size": 31, "lines_coords": [[[442.0, 1076.0], [473.0, 1076.0], [473.0, 1132.0], [442.0, 1132.0]]], "lines": ["装丁"]}, {"box": [437, 1174, 476, 1466], "vertical": true, "font_size": 30, "lines_coords": [[[442.0, 1174.0], [471.0, 1174.0], [467.0, 1466.0], [437.0, 1466.0]]], "lines": ["．．．ｆａｂｒｃｅｎｇｎｅ"]}, {"box": [360, 1078, 387, 1775], "vertical": true, "font_size": 27, "lines_coords": [[[360.0, 1078.0], [387.0, 1078.0], [387.0, 1775.0], [360.0, 1775.0]]], "lines": ["２０１８年０３月２６日アニア「Ｔｈｉｎｔｅｒｉｎ」ｌａｐａｎｉｓＢａｚｏｎメーティーエットコーナー"]}, {"box": [104, 1073, 295, 1960], "vertical": true, "font_size": 25, "lines_coords": [[[266.0, 1078.0], [287.0, 1078.0], [287.0, 1956.0], [266.0, 1956.0]], [[237.0, 1078.0], [258.0, 1078.0], [258.0, 1960.0], [237.0, 1960.0]], [[202.0, 1076.0], [229.0, 1076.0], [229.0, 1912.0], [202.0, 1912.0]], [[168.0, 1078.0], [195.0, 1078.0], [195.0, 1952.0], [168.0, 1952.0]], [[137.0, 1076.0], [164.0, 1076.0], [164.0, 1929.0], [137.0, 1929.0]], [[104.0, 1078.0], [131.0, 1078.0], [131.0, 1418.0], [104.0, 1418.0]]], "lines": ["●週末には十分み越しております。が、落丁３乱コス本のページの抜け落ちゃ順序の間違い、一の場合は", "お取り替え致します。購入されたた書店名を明記して「制作課」あてにお送り下さい。送料小社負担に", "てお取り替え致します。ただし、新品番店で購入したものについてはお取り替え出来ません。", "●本書の一部または全部を無断で複製等の利用をすることは、著作権法が認める場合を除き禁じ", "られています。また、購入者以外の第三者が世界視線を行うことは「切認められておりません。", "●定価はカバーに表示してあります。"]}], "img_path": "173.png"}, {"version": "0.2.0-beta.7", "img_width": 1445, "img_height": 2194, "blocks": [{"box": [630, 2111, 774, 2155], "vertical": false, "font_size": 37, "lines_coords": [[[641.0, 2114.0], [765.0, 2114.0], [765.0, 2151.0], [641.0, 2151.0]]], "lines": ["白泉社"]}], "img_path": "174.png"}]}