], [1224.0, 1244.0]], [[1176.0, 1058.0], [1211.0, 1058.0], [1211.0, 1336.0], [1176.0, 1336.0]], [[1132.0, 1060.0], [1161.0, 1060.0], [1165.0, 1309.0], [1136.0, 1309.0]], [[1096.0, 1060.0], [1128.0, 1060.0], [1128.0, 1158.0], [1096.0, 1158.0]]], "lines": ["―ねぇギン", "他に食べたいものや", "見てみたいものは", "ある？"]}, {"box": [172, 1018, 386, 1329], "vertical": true, "font_size": 34, "lines_coords": [[[340.0, 1018.0], [386.0, 1018.0], [386.0, 1117.0], [340.0, 1117.0]], [[302.0, 1020.0], [332.0, 1020.0], [332.0, 1327.0], [302.0, 1327.0]], [[263.0, 1020.0], [292.0, 1020.0], [292.0, 1329.0], [263.0, 1329.0]], [[211.0, 1018.0], [246.0, 1018.0], [250.0, 1210.0], [215.0, 1210.0]], [[173.0, 1023.0], [202.0, 1023.0], [202.0, 1238.0], [173.0, 1238.0]]], "lines": ["ふふっ", "また用意出来るものが", "あるかもしれないから", "次の夏までに", "考えておいてね"]}, {"box": [1316, 1524, 1355, 1730], "vertical": true, "font_size": 40, "lines_coords": [[[1320.0, 1524.0], [1355.0, 1524.0], [1351.0, 1730.0], [1316.0, 1730.0]]], "lines": ["じゃあまた．．．"]}, {"box": [1205, 1595, 1282, 1787], "vertical": true, "font_size": 40, "lines_coords": [[[1245.0, 1599.0], [1282.0, 1599.0], [1282.0, 1787.0], [1245.0, 1787.0]], [[1205.0, 1595.0], [1253.0, 1595.0], [1253.0, 1668.0], [1205.0, 1668.0]]], "lines": ["来年の夏にね", "ギン"]}], "img_path": "161.png"}, {"version": "0.2.0-beta.7", "img_width": 1481, "img_height": 2136, "blocks": [{"box": [815, 177, 896, 312], "vertical": true, "font_size": 43, "lines_coords": [[[846.0, 177.0], [896.0, 177.0], [896.0, 254.0], [846.0, 254.0]], [[815.0, 183.0], [851.0, 183.0], [851.0, 312.0], [815.0, 312.0]]], "lines": ["ギン", "どうした"]}, {"box": [594, 127, 719, 377], "vertical": true, "font_size": 42, "lines_coords": [[[682.0, 127.0], [717.0, 127.0], [719.0, 377.0], [684.0, 377.0]], [[629.0, 129.0], [673.0, 129.0], [677.0, 306.0], [634.0, 306.0]], [[594.0, 129.0], [640.0, 129.0], [640.0, 233.0], [594.0, 233.0]]], "lines": ["またここにいたか", "最近元気が", "ないな"]}, {"box": [663, 546, 736, 704], "vertical": true, "font_size": 36, "lines_coords": [[[69