, [135.0, 1242.0]]], "lines": ["氷！？", "氷など何に", "使うのだ"]}, {"box": [897, 1877, 1029, 2031], "vertical": true, "font_size": 38, "lines_coords": [[[978.0, 1877.0], [1022.0, 1877.0], [1022.0, 2010.0], [978.0, 2010.0]], [[938.0, 1883.0], [968.0, 1883.0], [968.0, 2031.0], [938.0, 2031.0]], [[897.0, 1879.0], [936.0, 1879.0], [936.0, 1979.0], [897.0, 1979.0]]], "lines": ["蛍に柿を", "食わせたい", "のか？"]}], "img_path": "166.png"}, {"version": "0.2.0-beta.7", "img_width": 1474, "img_height": 2141, "blocks": [{"box": [947, 135, 986, 234], "vertical": true, "font_size": 35, "lines_coords": [[[947.0, 135.0], [986.0, 135.0], [986.0, 234.0], [947.0, 234.0]]], "lines": ["よし！"]}, {"box": [865, 307, 991, 696], "vertical": true, "font_size": 35, "lines_coords": [[[955.0, 307.0], [991.0, 307.0], [991.0, 664.0], [955.0, 664.0]], [[907.0, 309.0], [942.0, 309.0], [942.0, 696.0], [907.0, 696.0]], [[865.0, 311.0], [894.0, 311.0], [894.0, 620.0], [865.0, 620.0]]], "lines": ["ではこの山から出られぬ", "ギンのかわりにこの松菱が", "蛍に柿を届けてこよう"]}, {"box": [577, 129, 627, 213], "vertical": true, "font_size": 50, "lines_coords": [[[577.0, 129.0], [627.0, 129.0], [627.0, 213.0], [577.0, 213.0]]], "lines": ["えっ"]}, {"box": [324, 399, 403, 740], "vertical": true, "font_size": 33, "lines_coords": [[[367.0, 401.0], [403.0, 401.0], [403.0, 740.0], [367.0, 740.0]], [[326.0, 399.0], [357.0, 399.0], [355.0, 616.0], [324.0, 616.0]]], "lines": ["人の世には詳しくないが", "行って来てやる"]}, {"box": [181, 439, 255, 719], "vertical": true, "font_size": 33, "lines_coords": [[[215.0, 439.0], [250.0, 439.0], [255.0, 719.0], [219.0, 719.0]], [[181.0, 443.0], [211.0, 443.0], [211.0, 637.0], [181.0, 637.0]]], "lines": ["住んでいる街の名は", "わかるかギン"]}], "img_path": "167.png"}, {"version": "0.2.0-beta.7", "img_width": 1475, "img_height": 2135, "blocks": [{"box": [1266, 1144, 1310, 1230], "vertical": true, "font_size": 33, "lines_coords": [[[1270.0, 1144.0], [1310.0, 1146.0], [1306.0, 1230.0], [1266.0, 1228.0]]], "lines": ["ギン"]}, {"box": [1180, 1244, 1260, 1505], "vertical": tr