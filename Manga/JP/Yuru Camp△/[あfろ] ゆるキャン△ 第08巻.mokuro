620.0, 1110.0], [620.0, 1481.0], [594.0, 1481.0]]], "lines": ["あきちゃん薪の配布って", "もう来年までやんないの？"]}, {"box": [1117, 1413, 1188, 1726], "vertical": true, "font_size": 30, "lines_coords": [[[1156.0, 1413.0], [1185.0, 1413.0], [1186.0, 1633.0], [1158.0, 1633.0]], [[1117.0, 1415.0], [1149.0, 1415.0], [1149.0, 1726.0], [1117.0, 1726.0]]], "lines": ["薪貰い損ねたし", "薪代も稼がねーとだし、"]}, {"box": [135, 1354, 211, 1696], "vertical": true, "font_size": 30, "lines_coords": [[[178.0, 1359.0], [210.0, 1359.0], [210.0, 1648.0], [178.0, 1648.0]], [[138.0, 1359.0], [165.0, 1359.0], [165.0, 1696.0], [138.0, 1696.0]]], "lines": ["いや、次は３月末に", "身延と笛吹であるんだ"]}], "img_path": "00014.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1080, 131, 1168, 433], "vertical": true, "font_size": 25, "lines_coords": [[[1141.0, 133.0], [1168.0, 133.0], [1168.0, 258.0], [1141.0, 258.0]], [[1110.0, 131.0], [1134.0, 131.0], [1134.0, 356.0], [1110.0, 356.0]], [[1080.0, 133.0], [1104.0, 133.0], [1104.0, 433.0], [1080.0, 433.0]]], "lines": ["その頃なら", "春休み入ってるから", "みんなで貰いに行こうよ！！"]}, {"box": [789, 125, 866, 226], "vertical": true, "font_size": 37, "lines_coords": [[[826.0, 129.0], [866.0, 129.0], [866.0, 226.0], [826.0, 226.0]], [[796.0, 125.0], [830.0, 131.0], [823.0, 168.0], [789.0, 163.0]]], "lines": ["おうよ", "！！"]}, {"box": [202, 163, 274, 416], "vertical": true, "font_size": 32, "lines_coords": [[[240.0, 165.0], [271.0, 165.0], [271.0, 384.0], [240.0, 384.0]], [[202.0, 163.0], [234.0, 163.0], [234.0, 416.0], [202.0, 416.0]]], "lines": ["私もお父さんに", "頼んで行こうかな"]}, {"box": [1186, 528, 1218, 769], "vertical": true, "font_size": 27, "lines_coords": [[[1186.0, 528.0], [1213.0, 528.0], [1213.0, 765.0], [1186.0, 765.0]]], "lines": ["前回の失敗を活かし"]}, {"box": [1072, 555, 1133, 999], "vertical": true, "font_size": 24, "lines_coords": [[[1106.0, 575.0], [1130.0, 575.0], [1130.0, 999.0], [1106.0, 999.0]], [[1072.0, 579.0], [1096.0, 579.0], [1096.0, 948.0], [1072.0, 948.0]]], "lines": ["次はゲート前で夜通しキャンプして",