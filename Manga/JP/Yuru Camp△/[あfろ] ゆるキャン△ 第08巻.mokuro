568.0]], [[1104.0, 159.0], [1130.0, 159.0], [1130.0, 596.0], [1104.0, 596.0]]], "lines": ["ほうとうは家によって", "作り方が違うって聞いたけど、", "あおいちゃんの家はどうなの？"]}, {"box": [744, 172, 817, 515], "vertical": true, "font_size": 29, "lines_coords": [[[787.0, 176.0], [813.0, 176.0], [813.0, 515.0], [787.0, 515.0]], [[744.0, 174.0], [776.0, 174.0], [778.0, 453.0], [746.0, 453.0]]], "lines": ["うちはかぼちゃ少な目の", "汁なしほうとうやで"]}, {"box": [598, 159, 670, 469], "vertical": true, "font_size": 26, "lines_coords": [[[639.0, 161.0], [665.0, 161.0], [665.0, 468.0], [639.0, 468.0]], [[598.0, 159.0], [624.0, 159.0], [624.0, 405.0], [598.0, 405.0]]], "lines": ["野菜と麺が茹たったら", "味噌を入れる前に"]}, {"box": [183, 63, 622, 97], "vertical": false, "font_size": 32, "lines_coords": [[[183.0, 63.0], [622.0, 65.0], [622.0, 97.0], [183.0, 95.0]]], "lines": ["栗後６４ほうとうはご自由に"]}, {"box": [140, 125, 251, 532], "vertical": true, "font_size": 28, "lines_coords": [[[215.0, 125.0], [247.0, 125.0], [247.0, 530.0], [215.0, 530.0]], [[180.0, 131.0], [206.0, 131.0], [206.0, 530.0], [180.0, 530.0]], [[140.0, 127.0], [166.0, 127.0], [166.0, 313.0], [140.0, 313.0]]], "lines": ["半分位お湯を抜いてスープが", "カルボナーラみとうなるまで", "煮詰めるんや"]}, {"box": [150, 714, 196, 823], "vertical": true, "font_size": 46, "lines_coords": [[[150.0, 714.0], [196.0, 714.0], [196.0, 823.0], [150.0, 823.0]]], "lines": ["へぇー"]}, {"box": [1096, 969, 1207, 1408], "vertical": true, "font_size": 33, "lines_coords": [[[1171.0, 969.0], [1205.0, 969.0], [1207.0, 1376.0], [1173.0, 1376.0]], [[1136.0, 971.0], [1168.0, 971.0], [1168.0, 1408.0], [1136.0, 1408.0]], [[1096.0, 971.0], [1128.0, 971.0], [1128.0, 1252.0], [1096.0, 1252.0]]], "lines": ["それから少し冷まして七味と", "オリーブオイルかけて食べると", "むっちゃうまいんよ"]}, {"box": [706, 975, 776, 1226], "vertical": true, "font_size": 30, "lines_coords": [[[744.0, 976.0], [776.0, 976.0], [774.0, 1226.0], [742.0, 1226.0]], [[706.0, 976.0], [733.0, 976.0], [735.0, 1134.0], [708.0, 1134.0]]], "lines": ["オリーブオイルも", "合うんだ！！"]}, {"box": [598, 1036, 628, 1348], "vertical": true, "font_size": 26, "lines_coords": [[[598.0, 1036.0], [624.0, 1036.0], [624.0, 1348.0], [598.0, 1348.0]]], "lines": ["まだまだ甘いなイヌ子"]}, {"box": [149, 961, 258, 1396], "vertical": true, "font_size": 28, "lines_coords": [[[226.0, 961.0], [253.0, 961.0], [253.0, 1393.0], [226.0, 1393.0]], [[185.0, 961.0], [217.0, 961.0], [217.0, 1305.0], [185.0, 1305.0]], [[150.0, 963.0], [176.0, 963.0], [176.0, 1273.0], [150.0, 1273.0]]], "lines": ["ほうとうのレギュレーションは", "ああの麺さえ入れれば他は", "限りなく自由なんだよ"]}, {"box": [183, 1563, 262, 1706], "vertical": true, "font_size": 38, "lines_coords": [[[219.0, 1563.0], [262.0, 1563.0], [262.0, 1642.0], [219.0, 1642.0]], [[183.0, 1567.0], [215.0, 1567.0], [215.0, 1706.0], [183.0, 1706.0]]], "lines": ["あき", "ちゃん！？"]}], "img_path": "00167.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1093, 133, 1168, 573], "vertical": true, "font_size": 35, "lines_coords": [[[1130.0, 136.0], [1168.0, 136.0], [1168.0, 498.0], [1130.0, 498.0]], [[1093.0, 133.0], [1125.0, 133.0], [1126.0, 573.0], [1095.0, 573.0]]], "lines": ["いいか世の中ってもんは", "色んなマナーやルールがあって"]}, {"box": [504, 153, 577, 403], "vertical": true, "font_size": 29, "lines_coords": [[[543.0, 153.0], [575.0, 153.0], [575.0, 373.0], [543.0, 373.0]], [[504.0, 153.0], [530.0, 153.0], [530.0, 401.0], [504.0, 401.0]]], "lines": ["完全な自由って", "訳じゃないだろ？"]}, {"box": [271, 213, 307, 355], "vertical": true, "font_size": 32, "lines_coords": [[[271.0, 215.0], [303.0, 215.0], [303.0, 354.0], [271.0, 354.0]]], "lines": ["ううん"]}, {"box": [151, 699, 270, 1055], "vertical": true, "font_size": 53, "lines_coords": [[[210.0, 703.0], [264.0, 701.0], [270.0, 855.0], [215.0, 856.0]], [[151.0, 699.0], [202.0, 699.0], [202.0, 1055.0], [151.0, 1055.0]]], "lines": ["本当の", "自由って奴が！！！"]}, {"box": [1086, 837, 1179, 1261], "vertical": true, "font_size": 39, "lines_coords": [[[1140.0, 841.0], [1179.0, 841.0], [1179.0, 1196.0], [1140.0, 1196.0]], [[1087.0, 840.0], [1126.0, 840.0], [1126.0, 1261.0], [1087.0, 1261.0]]], "lines": ["けどなほうとうの", "鍋ん中にはあるんだよ"]}, {"box": [1081, 1388, 1202, 1732], "vertical": true, "font_size": 32, "lines_coords": [[[1168.0, 1389.0], [1200.0, 1389.0], [1200.0, 1696.0], [1168.0, 1696.0]], [[1126.0, 1389.0], [1158.0, 1389.0], [1158.0, 1732.0], [1126.0, 1732.0]], [[1081.0, 1389.0], [1113.0, 1389.0], [1113.0, 1563.0], [1081.0, 1563.0]]], "lines": ["とか言って何にでも", "ほうとう麺つっ込むぞ", "うちの母親"]}, {"box": [517, 1623, 733, 1689], "vertical": false, "font_size": 26.5, "lines_coords": [[[517.0, 1623.0], [733.0, 1623.0], [733.0, 1650.0], [517.0, 1650.0]], [[538.0, 1663.0], [699.0, 1663.0], [699.0, 1689.0], [538.0, 1689.0]]], "lines": ["ＤＥＡＴＨＨｏｖＴｏｕ", "ＡＴＴＡＣＫ"]}, {"box": [303, 1359, 377, 1599], "vertical": true, "font_size": 32, "lines_coords": [[[345.0, 1359.0], [376.0, 1359.0], [376.0, 1496.0], [345.0, 1496.0]], [[303.0, 1363.0], [335.0, 1363.0], [335.0, 1599.0], [303.0, 1599.0]]], "lines": ["ほうとう", "ハラスメントや"]}], "img_path": "00168.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1114, 189, 1190, 601], "vertical": true, "font_size": 30, "lines_coords": [[[1156.0, 189.0], [1190.0, 189.0], [1188.0, 601.0], [1155.0, 601.0]], [[1117.0, 193.0], [1143.0, 193.0], [1143.0, 598.0], [1117.0, 598.0]]], "lines": ["原付乗るようになってから", "行動範囲広まったよねリン"]}, {"box": [185, 163, 281, 470], "vertical": true, "font_size": 42, "lines_coords": [[[236.0, 163.0], [281.0, 163.0], [281.0, 470.0], [236.0, 470.0]], [[185.0, 165.0], [225.0, 165.0], [225.0, 425.0], [185.0, 425.0]]], "lines": ["あんまり遠いと", "疲れるけどね"]}, {"box": [1138, 991, 1209, 1366], "vertical": true, "font_size": 29, "lines_coords": [[[1179.0, 993.0], [1205.0, 993.0], [1205.0, 1207.0], [1179.0, 1207.0]], [[1138.0, 991.0], [1170.0, 991.0], [1170.0, 1366.0], [1138.0, 1366.0]]], "lines": ["これから車とか", "大型バイクの免許取ったら、"]}, {"box": [708, 990, 779, 1303], "vertical": true, "font_size": 29, "lines_coords": [[[750.0, 991.0], [776.0, 991.0], [776.0, 1175.0], [750.0, 1175.0]], [[708.0, 990.0], [740.0, 990.0], [740.0, 1303.0], [708.0, 1303.0]]], "lines": ["もっと世界が", "広くなるんじゃない？"]}, {"box": [183, 978, 308, 1288], "vertical": true, "font_size": 36, "lines_coords": [[[270.0, 982.0], [307.0, 982.0], [307.0, 1260.0], [270.0, 1260.0]], [[230.0, 982.0], [262.0, 982.0], [262.0, 1288.0], [230.0, 1288.0]], [[185.0, 978.0], [223.0, 978.0], [221.0, 1256.0], [183.0, 1256.0]]], "lines": ["大型バイクの免許", "取ったから北海道で", "キャンプしてくる"]}, {"box": [734, 1498, 765, 1665], "vertical": true, "font_size": 26, "lines_coords": [[[735.0, 1498.0], [761.0, 1498.0], [761.0, 1663.0], [735.0, 1663.0]]], "lines": ["そうかもね"]}, {"box": [170, 1410, 250, 1584], "vertical": true, "font_size": 38, "lines_coords": [[[217.0, 1413.0], [249.0, 1413.0], [249.0, 1584.0], [217.0, 1584.0]], [[170.0, 1410.0], [213.0, 1410.0], [213.0, 1486.0], [170.0, 1486.0]]], "lines": ["気をつけて", "ねー"]}], "img_path": "00169.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [817, 132, 877, 476], "vertical": true, "font_size": 28, "lines_coords": [[[845.0, 133.0], [877.0, 133.0], [877.0, 399.0], [845.0, 399.0]], [[817.0, 133.0], [841.0, 133.0], [841.0, 476.0], [817.0, 476.0]]], "lines": ["パスポート取ったから", "アメリカでキャンプしてくる"]}, {"box": [228, 134, 293, 472], "vertical": true, "font_size": 26, "lines_coords": [[[262.0, 136.0], [288.0, 136.0], [288.0, 388.0], [262.0, 388.0]], [[228.0, 135.0], [255.0, 135.0], [255.0, 472.0], [228.0, 472.0]]], "lines": ["国際免許取ったから", "世界一周キャンプしてくる"]}, {"box": [733, 551, 808, 710], "vertical": true, "font_size": 38, "lines_coords": [[[776.0, 553.0], [808.0, 553.0], [808.0, 710.0], [776.0, 710.0]], [[733.0, 551.0], [776.0, 551.0], [776.0, 624.0], [733.0, 624.0]]], "lines": ["気をつけて", "ねー"]}, {"box": [148, 553, 225, 712], "vertical": true, "font_size": 38, "lines_coords": [[[193.0, 556.0], [225.0, 556.0], [225.0, 712.0], [193.0, 712.0]], [[148.0, 553.0], [193.0, 553.0], [193.0, 628.0], [148.0, 628.0]]], "lines": ["気をつけて", "ねー"]}, {"box": [871, 1006, 935, 1371], "vertical": true, "font_size": 26, "lines_coords": [[[905.0, 1008.0], [931.0, 1008.0], [931.0, 1370.0], [905.0, 1370.0]], [[871.0, 1006.0], [896.0, 1006.0], [896.0, 1316.0], [871.0, 1316.0]]], "lines": ["火星移住計画に当選したから", "火星でキャンプしてくる"]}, {"box": [555, 965, 682, 1228], "vertical": true, "font_size": 60, "lines_coords": [[[622.0, 971.0], [682.0, 971.0], [682.0, 1177.0], [622.0, 1177.0]], [[558.0, 965.0], [618.0, 965.0], [615.0, 1228.0], [555.0, 1228.0]]], "lines": ["おみやげ", "よろしくね"]}, {"box": [750, 1417, 826, 1576], "vertical": true, "font_size": 38, "lines_coords": [[[793.0, 1421.0], [825.0, 1421.0], [825.0, 1576.0], [793.0, 1576.0]], [[750.0, 1417.0], [795.0, 1417.0], [795.0, 1490.0], [750.0, 1490.0]]], "lines": ["気をつけて", "ねー"]}, {"box": [155, 1479, 226, 1762], "vertical": true, "font_size": 29, "lines_coords": [[[193.0, 1479.0], [225.0, 1479.0], [225.0, 1762.0], [193.0, 1762.0]], [[155.0, 1483.0], [181.0, 1483.0], [181.0, 1606.0], [155.0, 1606.0]]], "lines": ["帰ってこれないとこ", "行かすな"]}], "img_path": "00170.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1160, 136, 1231, 446], "vertical": true, "font_size": 30, "lines_coords": [[[1198.0, 136.0], [1230.0, 136.0], [1231.0, 446.0], [1200.0, 446.0]], [[1160.0, 140.0], [1192.0, 140.0], [1192.0, 296.0], [1160.0, 296.0]]], "lines": ["前にウッドキャンドル", "やったけど"]}, {"box": [1044, 286, 1149, 508], "vertical": true, "font_size": 30, "lines_coords": [[[1117.0, 286.0], [1149.0, 286.0], [1149.0, 414.0], [1117.0, 414.0]], [[1080.0, 290.0], [1108.0, 290.0], [1110.0, 446.0], [1081.0, 446.0]], [[1044.0, 292.0], [1070.0, 292.0], [1070.0, 508.0], [1044.0, 508.0]]], "lines": ["焚き火の", "組み方って", "色々あるんだね"]}, {"box": [120, 71, 690, 103], "vertical": false, "font_size": 32, "lines_coords": [[[120.0, 71.0], [690.0, 71.0], [690.0, 103.0], [120.0, 103.0]]], "lines": ["放課後６６ファイアースネーク組み"]}, {"box": [279, 148, 348, 553], "vertical": true, "font_size": 29, "lines_coords": [[[316.0, 148.0], [348.0, 148.0], [348.0, 553.0], [316.0, 553.0]], [[279.0, 148.0], [305.0, 148.0], [305.0, 427.0], [279.0, 427.0]]], "lines": ["束にすると火は大きくなるが、", "燃焼時間は短くなる"]}, {"box": [695, 577, 738, 652], "vertical": true, "font_size": 43, "lines_coords": [[[695.0, 577.0], [738.0, 577.0], [738.0, 652.0], [695.0, 652.0]]], "lines": ["うむ"]}, {"box": [155, 328, 223, 701], "vertical": true, "font_size": 29, "lines_coords": [[[196.0, 328.0], [223.0, 328.0], [223.0, 701.0], [196.0, 701.0]], [[155.0, 330.0], [187.0, 330.0], [187.0, 613.0], [155.0, 613.0]]], "lines": ["空気の通り道も作らないと", "火が安定しないんだ"]}, {"box": [1085, 840, 1215, 1138], "vertical": true, "font_size": 37, "lines_coords": [[[1177.0, 840.0], [1215.0, 840.0], [1215.0, 1029.0], [1177.0, 1029.0]], [[1128.0, 841.0], [1168.0, 841.0], [1168.0, 1104.0], [1128.0, 1104.0]], [[1085.0, 843.0], [1117.0, 843.0], [1117.0, 1138.0], [1085.0, 1138.0]]], "lines": ["そこで私は", "長時間安定して", "たき火を楽しめる"]}, {"box": [167, 844, 250, 1143], "vertical": true, "font_size": 35, "lines_coords": [[[211.0, 845.0], [249.0, 845.0], [249.0, 1108.0], [211.0, 1108.0]], [[168.0, 847.0], [200.0, 847.0], [200.0, 1141.0], [168.0, 1141.0]]], "lines": ["究極の組み方を", "編み出したのだよ"]}, {"box": [215, 1226, 256, 1333], "vertical": true, "font_size": 36, "lines_coords": [[[215.0, 1226.0], [256.0, 1226.0], [256.0, 1333.0], [215.0, 1333.0]]], "lines": ["おぉー"]}, {"box": [170, 1271, 202, 1383], "vertical": true, "font_size": 36, "lines_coords": [[[170.0, 1271.0], [202.0, 1271.0], [202.0, 1383.0], [170.0, 1383.0]]], "lines": ["ーっ！！"]}, {"box": [1121, 1351, 1196, 1691], "vertical": true, "font_size": 32, "lines_coords": [[[1164.0, 1351.0], [1196.0, 1351.0], [1196.0, 1571.0], [1164.0, 1571.0]], [[1121.0, 1353.0], [1155.0, 1353.0], [1156.0, 1691.0], [1123.0, 1691.0]]], "lines": ["適度な薪の束を", "一列に並べる事によって"]}, {"box": [980, 1434, 1089, 1751], "vertical": true, "font_size": 32, "lines_coords": [[[1057.0, 1436.0], [1089.0, 1436.0], [1089.0, 1657.0], [1057.0, 1657.0]], [[1018.0, 1436.0], [1050.0, 1436.0], [1050.0, 1687.0], [1018.0, 1687.0]], [[980.0, 1434.0], [1012.0, 1434.0], [1012.0, 1751.0], 