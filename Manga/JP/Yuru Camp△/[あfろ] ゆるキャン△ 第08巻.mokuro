[1231.0, 630.0], [1205.0, 630.0]]], "lines": ["そうですね"]}, {"box": [1230, 780, 1271, 890], "vertical": true, "font_size": 41, "lines_coords": [[[1230.0, 780.0], [1271.0, 780.0], [1271.0, 890.0], [1230.0, 890.0]]], "lines": ["うわっ"]}, {"box": [644, 783, 765, 1024], "vertical": true, "font_size": 33, "lines_coords": [[[718.0, 785.0], [759.0, 783.0], [765.0, 922.0], [723.0, 924.0]], [[684.0, 787.0], [716.0, 787.0], [716.0, 1023.0], [684.0, 1023.0]], [[645.0, 787.0], [671.0, 787.0], [671.0, 956.0], [645.0, 956.0]]], "lines": ["伊豆って", "こんなに温泉地", "あるんだ．．．"]}, {"box": [511, 753, 606, 1020], "vertical": true, "font_size": 26, "lines_coords": [[[577.0, 755.0], [603.0, 755.0], [603.0, 888.0], [577.0, 888.0]], [[543.0, 755.0], [570.0, 755.0], [570.0, 995.0], [543.0, 995.0]], [[511.0, 753.0], [536.0, 753.0], [536.0, 1020.0], [511.0, 1020.0]]], "lines": ["伊豆は大昔", "海底火山だったので", "温泉が多いそうですよ。"]}, {"box": [140, 474, 172, 646], "vertical": true, "font_size": 32, "lines_coords": [[[140.0, 474.0], [172.0, 474.0], [172.0, 646.0], [140.0, 646.0]]], "lines": ["分かりました"]}, {"box": [360, 770, 393, 889], "vertical": true, "font_size": 33, "lines_coords": [[[360.0, 770.0], [393.0, 770.0], [393.0, 847.0], [360.0, 847.0]]], "lines": ["あぁー"]}, {"box": [127, 746, 195, 1085], "vertical": true, "font_size": 28, "lines_coords": [[[168.0, 750.0], [193.0, 750.0], [193.0, 1027.0], [168.0, 1027.0]], [[127.0, 746.0], [159.0, 746.0], [161.0, 1085.0], [129.0, 1085.0]]], "lines": ["ジオスポも火山活動で", "出来た場所多いですしねぇ"]}, {"box": [669, 1117, 735, 1282], "vertical": true, "font_size": 30, "lines_coords": [[[701.0, 1117.0], [735.0, 1117.0], [735.0, 1230.0], [701.0, 1230.0]], [[669.0, 1117.0], [695.0, 1117.0], [695.0, 1282.0], [669.0, 1282.0]]], "lines": ["ホントだ", "すごいねコレ"]}, {"box": [378, 1171, 487, 1249], "vertical": false, "font_size": 34, "lines_coords": [[[378.0, 1175.0], [483.0, 1175.0], [483.0, 1207.0], [378.0, 1207.0]], [[388.0, 1213.0], [476.0, 1213.0], [476.0, 1248.0], [388.0, 1248.0]]], "lines": ["海底火山", "伊豆"]}, {"