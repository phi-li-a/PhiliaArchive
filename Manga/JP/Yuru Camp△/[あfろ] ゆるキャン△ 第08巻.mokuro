0]]], "lines": ["原付だと", "大変だろう"]}, {"box": [832, 971, 858, 1222], "vertical": true, "font_size": 28, "lines_coords": [[[832.0, 971.0], [858.0, 971.0], [858.0, 1222.0], [832.0, 1222.0]]], "lines": ["長距離を走るのなら"]}, {"box": [723, 1006, 787, 1350], "vertical": true, "font_size": 28, "lines_coords": [[[755.0, 1006.0], [787.0, 1006.0], [785.0, 1350.0], [753.0, 1350.0]], [[723.0, 1010.0], [748.0, 1010.0], [748.0, 1265.0], [723.0, 1265.0]]], "lines": ["スクリーンを付けておいた", "方がいいかもしれん"]}, {"box": [583, 924, 647, 1237], "vertical": true, "font_size": 29, "lines_coords": [[[613.0, 924.0], [645.0, 924.0], [645.0, 1237.0], [613.0, 1237.0]], [[583.0, 926.0], [609.0, 926.0], [609.0, 1179.0], [583.0, 1179.0]]], "lines": ["うちに使っていない奴が", "転がっていたはずだ"]}, {"box": [136, 1126, 202, 1354], "vertical": true, "font_size": 26, "lines_coords": [[[172.0, 1130.0], [198.0, 1130.0], [198.0, 1299.0], [172.0, 1299.0]], [[136.0, 1126.0], [161.0, 1126.0], [161.0, 1351.0], [136.0, 1351.0]]], "lines": ["欲しいのなら", "今度持っていこう"]}, {"box": [1078, 1519, 1108, 1717], "vertical": true, "font_size": 26, "lines_coords": [[[1078.0, 1520.0], [1104.0, 1520.0], [1104.0, 1717.0], [1078.0, 1717.0]]], "lines": ["お言葉に甘えて"]}, {"box": [268, 1507, 372, 1740], "vertical": true, "font_size": 30, "lines_coords": [[[345.0, 1513.0], [371.0, 1513.0], [371.0, 1651.0], [345.0, 1651.0]], [[307.0, 1507.0], [339.0, 1507.0], [337.0, 1740.0], [305.0, 1740.0]], [[271.0, 1509.0], [305.0, 1509.0], [301.0, 1627.0], [268.0, 1627.0]]], "lines": ["スクリーン", "もらっといた方が", "いいかも"]}], "img_path": "00019.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1125, 363, 1205, 466], "vertical": true, "font_size": 44, "lines_coords": [[[1158.0, 363.0], [1205.0, 363.0], [1205.0, 466.0], [1158.0, 466.0]], [[1125.0, 365.0], [1166.0, 365.0], [1166.0, 466.0], [1125.0, 466.0]]], "lines": ["ブーッ", "ブーッ"]}, {"box": [613, 337, 657, 448], "vertical": true, "font_size": 40, "lines_coords": [[[616.0, 337.0], [656.0, 339.0], [652.0, 448.0], [613.0, 446.0]]], "lines": ["斉藤か"]}, {"box": [307, 160, 583, 237], "vertical": false, "font_size": 32, "lines_coords": [[[316.0, 163.0], [573.0, 163.0], [573.0, 195.0], [316.0, 195.0]], [[311.0, 204.0], [515.0, 204.0], [515.0, 236.0], [311.0, 236.0]]], "lines": ["リン、あきちゃん", "起きてるー？"]}, {"box": [283, 808, 382, 840], "vertical": false, "font_size": 28, "lines_coords": [[[283.0, 808.0], [382.0, 811.0], [382.0, 840.0], [283.0, 836.0]]], "lines": ["ねてる。"]}, {"box": [268, 885, 512, 917], "vertical": false, "font_size": 25, "lines_coords": [[[283.0, 888.0], [506.0, 888.0], [506.0, 913.0], [283.0, 913.0]]], "lines": ["（¬「ｅ＇）＿スヤァ．．．"]}, {"box": [872, 1188, 1181, 1237], "vertical": false, "font_size": 24, "lines_coords": [[[875.0, 1188.0], [1177.0, 1188.0], [1177.0, 1213.0], [875.0, 1213.0]], [[877.0, 1213.0], [1155.0, 1213.0], [1155.0, 1237.0], [877.0, 1237.0]]], "lines": ["なでしこちゃんとあおいちゃんの", "プレゼントでろそろ決めない？"]}, {"box": [880, 1293, 1030, 1321], "vertical": false, "font_size": 26, "lines_coords": [[[885.0, 1295.0], [1025.0, 1295.0], [1025.0, 1321.0], [885.0, 1321.0]]], "lines": ["お、そうだな"]}, {"box": [268, 966, 501, 993], "vertical": false, "font_size": 24, "lines_coords": [[[275.0, 969.0], [496.0, 969.0], [496.0, 993.0], [275.0, 993.0]]], "lines": ["はいはい、起きてるね"]}, {"box": [229, 1200, 477, 1228], "vertical": false, "font_size": 25, "lines_coords": [[[262.0, 1203.0], [470.0, 1203.0], [470.0, 1228.0], [262.0, 1228.0]]], "lines": ["ンは何か考えてる？"]}, {"box": [317, 1283, 452, 1312], "vertical": false, "font_size": 26, "lines_coords": [[[322.0, 1286.0], [440.0, 1286.0], [440.0, 1312.0], [322.0, 1312.0]]], "lines": ["そうだなー"]}, {"box": [905, 1730, 1112, 1757], "vertical": false, "font_size": 21, "lines_coords": [[[909.0, 1732.0], [1102.0, 1734.0], [1102.0, 1755.0], [909.0, 1753.0]]], "lines": ["おい言し出しっへ"]}, {"box": [836, 1645, 1016, 1674], "vertical": false, "font_size": 26, "lines_coords": [[[836.0, 1646.0], [1006.0, 1648.0], [1006.0, 1674.0], [836.0, 1672.0]]], "lines": ["やべー忘れてた"]}], "img_path": "00020.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [838, 157, 1072, 225], "vertical": false, "font_size": 36, "lines_coords": [[[841.0, 157.0], [1066.0, 157.0], [1066.0, 195.0], [841.0, 195.0]], [[838.0, 191.0], [916.0, 191.0], [916.0, 225.0], [838.0, 225.0]]], "lines": ["イスとかテーブルは", "高いし"]}, {"box": [839, 273, 1071, 334], "vertical": false, "font_size": 29, "lines_coords": [[[843.0, 273.0], [1044.0, 273.0], [1044.0, 305.0], [843.0, 305.0]], [[845.0, 307.0], [1066.0, 307.0], [1066.0, 333.0], [845.0, 333.0]]], "lines": ["２人とも一通りの", "道具は持ってるよな"]}, {"box": [348, 163, 534, 187], "vertical": false, "font_size": 24, "lines_coords": [[[348.0, 163.0], [534.0, 163.0], [534.0, 187.0], [348.0, 187.0]]], "lines": ["食器類とかどう？"]}, {"box": [200, 243, 572, 306], "vertical": false, "font_size": 24, "lines_coords": [[[202.0, 249.0], [568.0, 249.0], [568.0, 273.0], [202.0, 273.0]], [[202.0, 279.0], [425.0, 279.0], [425.0, 303.0], [202.0, 303.0]]], "lines": ["いいかも、家で使うってるお椀とか", "紙皿使ってるもんね"]}, {"box": [905, 1054, 1211, 1118], "vertical": false, "font_size": 25, "lines_coords": [[[909.0, 1057.0], [1205.0, 1057.0], [1205.0, 1083.0], [909.0, 1083.0]], [[913.0, 1091.0], [1104.0, 1091.0], [1104.0, 1115.0], [913.0, 1115.0]]], "lines": ["あ！プラスチック製だけど", "木皿っぽいあれ！！"]}, {"box": [786, 947, 1091, 1003], "vertical": false, "font_size": 26, "lines_coords": [[[789.0, 948.0], [1025.0, 948.0], [1025.0, 975.0], [789.0, 975.0]], [[791.0, 976.0], [1085.0, 976.0], [1085.0, 1001.0], [791.0, 1001.0]]], "lines": ["あれいいんじゃやないか？", "富士吉田カリブーで見たやつ！"]}, {"box": [159, 1346, 697, 1430], "vertical": false, "font_size": 37, "lines_coords": [[[161.0, 1348.0], [575.0, 1348.0], [575.0, 1385.0], [161.0, 1385.0]], [[159.0, 1391.0], [697.0, 1391.0], [697.0, 1428.0], [159.0, 1428.0]]], "lines": ["木繊維と樹脂を合わせた素材で", "耐熱・耐久性に優れお手入れも簡単です。"]}, {"box": [261, 1457, 600, 1519], "vertical": false, "font_size": 39, "lines_coords": [[[262.0, 1468.0], [588.0, 1468.0], [588.0, 1507.0], [262.0, 1507.0]]], "lines": ["＼３０ＤＯ（利用以）"]}, {"box": [255, 1575, 524, 1642], "vertical": false, "font_size": 32, "lines_coords": [[[256.0, 1576.0], [444.0, 1576.0], [444.0, 1608.0], [256.0, 1608.0]], [[255.0, 1610.0], [511.0, 1610.0], [511.0, 1642.0], [255.0, 1642.0]]], "lines": ["お、これいいな", "値段も高すぎないし"]}, {"box": [354, 1696, 499, 1737], "vertical": false, "font_size": 40, "lines_coords": [[[354.0, 1696.0], [491.0, 1696.0], [491.0, 1736.0], [354.0, 1736.0]]], "lines": ["だろー？"]}], "img_path": "00021.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [809, 289, 1109, 322], "vertical": false, "font_size": 26, "lines_coords": [[[819.0, 294.0], [1100.0, 294.0], [1100.0, 320.0], [819.0, 320.0]]], "lines": ["じゃあこれにこしない？"]}, {"box": [820, 373, 1025, 411], "vertical": false, "font_size": 34, "lines_coords": [[[823.0, 376.0], [1020.0, 373.0], [1020.0, 406.0], [823.0, 410.0]]], "lines": ["よーし決定！！"]}, {"box": [730, 160, 1070, 242], "vertical": false, "font_size": 33, "lines_coords": [[[733.0, 163.0], [1059.0, 165.0], [1059.0, 196.0], [733.0, 195.0]], [[733.0, 204.0], [1061.0, 206.0], [1061.0, 240.0], [733.0, 238.0]]], "lines": ["２個で６０００円だから", "１人２０００円ずつだな"]}, {"box": [832, 764, 1176, 840], "vertical": false, "font_size": 32, "lines_coords": [[[836.0, 766.0], [1175.0, 766.0], [1175.0, 798.0], [836.0, 798.0]], [[836.0, 808.0], [1050.0, 808.0], [1050.0, 840.0], [836.0, 840.0]]], "lines": ["確か身延の力リブーにも", "あったはずだぞ"]}, {"box": [763, 682, 1066, 721], "vertical": false, "font_size": 32, "lines_coords": [[[763.0, 688.0], [1059.0, 688.0], [1059.0, 720.0], [763.0, 720.0]]], "lines": ["どこで買う？ネットの"]}, {"box": [157, 678, 498, 785], "vertical": false, "font_size": 34, "lines_coords": [[[157.0, 680.0], [495.0, 680.0], [495.0, 712.0], [157.0, 712.0]], [[157.0, 712.0], [493.0, 712.0], [493.0, 744.0], [157.0, 744.0]], [[159.0, 746.0], [331.0, 746.0], [331.0, 785.0], [159.0, 785.0]]], "lines": ["あたし明日バイト休みだし", "早速学校帰りにカリブーで", "買ってくるわ"]}, {"box": [243, 824, 576, 862], "ve