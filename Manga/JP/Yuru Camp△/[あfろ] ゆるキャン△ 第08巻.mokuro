 32, "lines_coords": [[[180.0, 879.0], [211.0, 879.0], [211.0, 1155.0], [180.0, 1155.0]], [[136.0, 881.0], [168.0, 881.0], [168.0, 1155.0], [136.0, 1155.0]]], "lines": ["７人乗りですから", "全員乗れますよ？"]}, {"box": [581, 1350, 665, 1730], "vertical": true, "font_size": 38, "lines_coords": [[[622.0, 1350.0], [661.0, 1350.0], [665.0, 1522.0], [626.0, 1522.0]], [[581.0, 1351.0], [618.0, 1351.0], [618.0, 1730.0], [581.0, 1730.0]]], "lines": ["私原付で", "行ってもいいですか？"]}, {"box": [166, 1526, 232, 1751], "vertical": true, "font_size": 32, "lines_coords": [[[196.0, 1526.0], [232.0, 1526.0], [232.0, 1616.0], [196.0, 1616.0]], [[166.0, 1528.0], [193.0, 1528.0], [193.0, 1751.0], [166.0, 1751.0]]], "lines": ["それは", "分かってるんです"]}], "img_path": "00011.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1215, 163, 1276, 545], "vertical": true, "font_size": 28, "lines_coords": [[[1245.0, 163.0], [1276.0, 163.0], [1276.0, 545.0], [1245.0, 545.0]], [[1215.0, 166.0], [1241.0, 166.0], [1241.0, 504.0], [1215.0, 504.0]]], "lines": ["私お正月に原付で伊豆へ行く", "計画を立ててたんですけど、"]}, {"box": [178, 206, 242, 601], "vertical": true, "font_size": 26, "lines_coords": [[[213.0, 208.0], [240.0, 208.0], [240.0, 543.0], [213.0, 543.0]], [[180.0, 206.0], [204.0, 206.0], [204.0, 598.0], [180.0, 598.0]]], "lines": ["それからずっと伊豆の道を", "自分で走ってみたかったんです"]}, {"box": [1149, 435, 1175, 630], "vertical": true, "font_size": 28, "lines_coords": [[[1149.0, 435.0], [1175.0, 435.0], [1175.0, 630.0], [1149.0, 630.0]]], "lines": ["結局行けなくて"]}, {"box": [995, 808, 1070, 937], "vertical": true, "font_size": 38, "lines_coords": [[[1029.0, 808.0], [1070.0, 808.0], [1070.0, 909.0], [1029.0, 909.0]], [[995.0, 810.0], [1029.0, 810.0], [1029.0, 937.0], [995.0, 937.0]]], "lines": ["原付で", "ですか．．．"]}, {"box": [283, 753, 405, 995], "vertical": true, "font_size": 30, "lines_coords": [[[369.0, 755.0], [401.0, 755.0], [401.0, 960.0], [369.0, 960.0]], [[330.0, 759.0], [356.0, 759.0], [356.0, 991.0], [330.0, 991.0]], [[283.0, 753.0], [315.0, 753.0], [315.0, 995.0], [283.0, 995.0]]], "lines": ["身延からだと", "かなり大変かと", "思いますけど．．"]}, {"box": [1175, 1143, 1243, 1519], "vertical": true, "font_size": 29, "lines_coords": [[[1211.0, 1143.0], [1243.0, 1143.0], [1243.0, 1516.0], [1211.0, 1516.0]], [[1175.0, 1147.0], [1201.0, 1147.0], [1201.0, 1426.0], [1175.0, 1426.0]]], "lines": ["リンちゃんは「原付の旅」が", "やりたいんだよね！！"]}, {"box": [503, 1121, 581, 1466], "vertical": true, "font_size": 36, "lines_coords": [[[541.0, 1121.0], [581.0, 1121.0], [581.0, 1348.0], [541.0, 1348.0]], [[504.0, 1123.0], [536.0, 1123.0], [536.0, 1466.0], [504.0, 1466.0]]], "lines": ["先生リンなら", "大丈夫だと思いますよ"]}, {"box": [131, 1147, 208, 1456], "vertical": true, "font_size": 33, "lines_coords": [[[170.0, 1147.0], [204.0, 1147.0], [206.0, 1455.0], [172.0, 1455.0]], [[131.0, 1149.0], [163.0, 1149.0], [163.0, 1456.0], [131.0, 1456.0]]], "lines": ["浜松も伊那も原付で", "行った事ありますし"]}, {"box": [1016, 1567, 1059, 1710], "vertical": true, "font_size": 41, "lines_coords": [[[1018.0, 1571.0], [1059.0, 1571.0], [1059.0, 1710.0], [1018.0, 1710.0]]], "lines": ["ねっ！！"]}, {"box": [626, 1456, 748, 1627], "vertical": true, "font_size": 33, "lines_coords": [[[714.0, 1456.0], [748.0, 1456.0], [748.0, 1575.0], [714.0, 1575.0]], [[671.0, 1456.0], [703.0, 1456.0], [703.0, 1627.0], [671.0, 1627.0]], [[626.0, 1456.0], [660.0, 1456.0], [660.0, 1561.0], [626.0, 1561.0]]], "lines": ["ままぁ", "そうなんだ", "けど．．．"]}, {"box": [144, 1609, 226, 1743], "vertical": true, "font_size": 41, "lines_coords": [[[185.0, 1610.0], [226.0, 1610.0], [226.0, 1743.0], [185.0, 1743.0]]], "lines": ["うーん"]}], "img_path": "00012.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1151, 150, 1218, 487], "vertical": true, "font_size": 29, "lines_coords": [[[1190.0, 151.0], [1216.0, 151.0], [1216.0, 487.0], [1190.0, 487.0]], [[1153.0, 150.0], [1185.0, 150.0], [1183.0, 461.0], [1151.0, 461.0]]], "lines": ["観光する時はキャンプ場に", "バイク預けて車で回れば"]}, {"box": [748, 163, 810, 416], "vertical": true, "f