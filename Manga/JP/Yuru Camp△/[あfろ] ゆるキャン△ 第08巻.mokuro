.0], [238.0, 916.0], [204.0, 916.0]], [[174.0, 744.0], [206.0, 744.0], [204.0, 1083.0], [172.0, 1083.0]]], "lines": ["こうして出来た岩体を", "シルｓｉｌといい", "俵磯の岩体もその一種です。"]}, {"box": [1138, 1261, 1171, 1350], "vertical": true, "font_size": 33, "lines_coords": [[[1138.0, 1261.0], [1171.0, 1261.0], [1171.0, 1350.0], [1138.0, 1350.0]]], "lines": ["みそー！！"]}, {"box": [763, 1231, 806, 1299], "vertical": true, "font_size": 43, "lines_coords": [[[763.0, 1231.0], [806.0, 1231.0], [806.0, 1299.0], [763.0, 1299.0]]], "lines": ["豚ｉｌ！"]}, {"box": [828, 1618, 860, 1758], "vertical": true, "font_size": 28, "lines_coords": [[[828.0, 1618.0], [856.0, 1618.0], [860.0, 1756.0], [832.0, 1756.0]]], "lines": ["かきたま．．．"]}, {"box": [316, 1696, 467, 1740], "vertical": false, "font_size": 34, "lines_coords": [[[320.0, 1700.0], [448.0, 1700.0], [448.0, 1734.0], [320.0, 1734.0]]], "lines": ["おｓｉｌに"]}], "img_path": "00112.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1156, 594, 1220, 873], "vertical": true, "font_size": 26, "lines_coords": [[[1192.0, 594.0], [1218.0, 594.0], [1218.0, 819.0], [1192.0, 819.0]], [[1156.0, 594.0], [1183.0, 594.0], [1185.0, 873.0], [1158.0, 873.0]]], "lines": ["ごめんなさいね．．．", "こんな事になるなんて"]}, {"box": [720, 585, 786, 909], "vertical": true, "font_size": 28, "lines_coords": [[[757.0, 588.0], [783.0, 588.0], [783.0, 909.0], [757.0, 909.0]], [[720.0, 585.0], [751.0, 585.0], [751.0, 787.0], [720.0, 787.0]]], "lines": ["今、泊まれるキャンプ場を", "探してますから"]}, {"box": [562, 581, 663, 922], "vertical": true, "font_size": 27, "lines_coords": [[[631.0, 583.0], [660.0, 583.0], [658.0, 922.0], [630.0, 922.0]], [[596.0, 583.0], [622.0, 583.0], [622.0, 808.0], [596.0, 808.0]], [[562.0, 581.0], [588.0, 581.0], [588.0, 778.0], [562.0, 778.0]]], "lines": ["今日は久しぶりにお昼から", "外でお洒飲めると", "思ってたのに．．．"]}, {"box": [151, 1003, 220, 1284], "vertical": true, "font_size": 30, "lines_coords": [[[187.0, 1003.0], [219.0, 1003.0], [219.0, 1207.0], [187.0, 1207.0]], [[151.0, 1003.0], [178.0, 1003.0], [178.0, 1284.0], [151.0, 1284.0]]], "lines": ["先生そんなに", "落ちこまなくても："]}, {"box": [266, 1383, 305, 1485], "vertical": true, "font_size": 30, "lines_coords": [[[266.0, 1383.0], [305.0, 1383.0], [305.0, 1485.0], [266.0, 1485.0]]], "lines": ["せや！！"]}, {"box": [1096, 1335, 1197, 1589], "vertical": true, "font_size": 26, "lines_coords": [[[1168.0, 1336.0], [1194.0, 1336.0], [1194.0, 1586.0], [1168.0, 1586.0]], [[1134.0, 1338.0], [1160.0, 1338.0], [1160.0, 1531.0], [1134.0, 1531.0]], [[1096.0, 1335.0], [1123.0, 1335.0], [1123.0, 1586.0], [1096.0, 1586.0]]], "lines": ["でもキャンプ場って", "当日予約なしで", "泊まれるものなの？"]}, {"box": [771, 1471, 881, 1721], "vertical": true, "font_size": 29, "lines_coords": [[[847.0, 1471.0], [875.0, 1471.0], [877.0, 1721.0], [849.0, 1721.0]], [[808.0, 1475.0], [840.0, 1475.0], [840.0, 1693.0], [808.0, 1693.0]], [[772.0, 1477.0], [798.0, 1477.0], [798.0, 1691.0], [772.0, 1691.0]]], "lines": ["予約不要の所とか", "無料の所とかは", "大丈夫だと思う"]}, {"box": [408, 1306, 503, 1625], "vertical": true, "font_size": 26, "lines_coords": [[[472.0, 1306.0], [500.0, 1306.0], [502.0, 1625.0], [474.0, 1625.0]], [[442.0, 1310.0], [466.0, 1310.0], [466.0, 1575.0], [442.0, 1575.0]], [[408.0, 1308.0], [435.0, 1308.0], [435.0, 1428.0], [408.0, 1428.0]]], "lines": ["要予約な所でも空き具合で", "イケるんじゃないか？", "今冬だし"]}, {"box": [159, 1415, 251, 1758], "vertical": true, "font_size": 30, "lines_coords": [[[225.0, 1415.0], [251.0, 1415.0], [251.0, 1698.0], [225.0, 1698.0]], [[189.0, 1415.0], [221.0, 1415.0], [221.0, 1758.0], [189.0, 1758.0]], [[159.0, 1421.0], [180.0, 1421.0], [180.0, 1531.0], [159.0, 1531.0]]], "lines": ["早く見つけんと夕方に", "管理人さん帰ってまう事も", "あるで！！"]}], "img_path": "00113.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [735, 22, 806, 429], "vertical": true, "font_size": 64, "lines_coords": [[[735.0, 22.0], [798.0, 22.0], [806.0, 429.0], [742.0, 429.0]]], "lines": ["あの時みたいに。"]}, {"box": [603, 82, 669, 257], "vertical": true, "font_size": 29, "lines_coords": [[