l": false, "font_size": 64, "lines_coords": [[[193.0, 337.0], [360.0, 346.0], [356.0, 410.0], [189.0, 401.0]]], "lines": ["まりんだんご行ける"]}, {"box": [642, 748, 733, 991], "vertical": true, "font_size": 38, "lines_coords": [[[693.0, 748.0], [733.0, 748.0], [733.0, 991.0], [693.0, 991.0]], [[643.0, 748.0], [680.0, 748.0], [680.0, 991.0], [643.0, 991.0]]], "lines": ["これはマジで", "温泉地獄だぞ"]}, {"box": [523, 739, 590, 922], "vertical": true, "font_size": 29, "lines_coords": [[[558.0, 740.0], [590.0, 740.0], [590.0, 922.0], [558.0, 922.0]], [[523.0, 740.0], [549.0, 740.0], [549.0, 892.0], [523.0, 892.0]]], "lines": ["何言うとんの", "あきちゃん"]}, {"box": [66, 736, 136, 988], "vertical": true, "font_size": 29, "lines_coords": [[[101.0, 736.0], [133.0, 736.0], [133.0, 988.0], [101.0, 988.0]], [[67.0, 740.0], [93.0, 740.0], [93.0, 988.0], [67.0, 988.0]]], "lines": ["温泉地獄やのうて", "温泉天国やんかー"]}, {"box": [1140, 909, 1209, 1190], "vertical": true, "font_size": 30, "lines_coords": [[[1175.0, 909.0], [1207.0, 909.0], [1207.0, 1190.0], [1175.0, 1190.0]], [[1141.0, 911.0], [1168.0, 911.0], [1168.0, 1186.0], [1141.0, 1186.0]]], "lines": ["この道沿いだけでも", "すげー数の温泉だな"]}, {"box": [93, 1096, 172, 1200], "vertical": true, "font_size": 42, "lines_coords": [[[121.0, 1096.0], [172.0, 1096.0], [172.0, 1173.0], [121.0, 1173.0]], [[93.0, 1102.0], [127.0, 1102.0], [127.0, 1200.0], [93.0, 1200.0]]], "lines": ["そう", "だよー"]}, {"box": [948, 1284, 1116, 1856], "vertical": true, "font_size": 36, "lines_coords": [[[1076.0, 1288.0], [1113.0, 1288.0], [1113.0, 1856.0], [1076.0, 1856.0]], [[1031.0, 1286.0], [1070.0, 1286.0], [1068.0, 1773.0], [1029.0, 1773.0]], [[988.0, 1284.0], [1025.0, 1284.0], [1025.0, 1666.0], [988.0, 1666.0]], [[950.0, 1286.0], [982.0, 1286.0], [982.0, 1816.0], [950.0, 1816.0]]], "lines": ["「温泉が多すぎてどこの温泉に入るか", "いつまでも決められずにいたら", "営業時間が終了して結局", "どこの温泉にも入れなくなる地獄"]}, {"box": [225, 1428, 324, 1561], "vertical": true, "font_size": 93, "lines_coords": [[[225.0, 1434.0], [318.0, 1428.0], [324.0, 1556.0], [232.0, 1561