6.0, 1410.0]]], "lines": ["予約が必要？", "やっぱりそうですか"]}, {"box": [733, 1511, 837, 1707], "vertical": true, "font_size": 45, "lines_coords": [[[791.0, 1513.0], [836.0, 1513.0], [836.0, 1689.0], [791.0, 1689.0]], [[733.0, 1511.0], [778.0, 1511.0], [781.0, 1706.0], [736.0, 1706.0]]], "lines": ["あたしは", "そこかい。"]}], "img_path": "00114.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1151, 116, 1216, 345], "vertical": true, "font_size": 28, "lines_coords": [[[1188.0, 118.0], [1216.0, 118.0], [1213.0, 258.0], [1185.0, 258.0]], [[1151.0, 116.0], [1183.0, 116.0], [1183.0, 345.0], [1151.0, 345.0]]], "lines": ["飯田さんに", "聞いてみるのは？"]}, {"box": [1048, 65, 1106, 339], "vertical": true, "font_size": 28, "lines_coords": [[[1080.0, 65.0], [1106.0, 65.0], [1106.0, 339.0], [1080.0, 339.0]], [[1048.0, 65.0], [1074.0, 65.0], [1074.0, 215.0], [1048.0, 215.0]]], "lines": ["ベテランキャンパーだし", "地元の人だし"]}, {"box": [736, 123, 843, 358], "vertical": true, "font_size": 46, "lines_coords": [[[793.0, 123.0], [840.0, 123.0], [840.0, 311.0], [793.0, 311.0]], [[736.0, 125.0], [781.0, 125.0], [781.0, 358.0], [736.0, 358.0]]], "lines": ["その手が", "あったか！！"]}, {"box": [172, 185, 256, 430], "vertical": true, "font_size": 42, "lines_coords": [[[204.0, 185.0], [256.0, 185.0], [256.0, 264.0], [204.0, 264.0]], [[172.0, 191.0], [204.0, 191.0], [204.0, 427.0], [172.0, 427.0]]], "lines": ["はい", "飯田酒店ですー"]}, {"box": [1048, 795, 1143, 1098], "vertical": true, "font_size": 39, "lines_coords": [[[1104.0, 795.0], [1143.0, 795.0], [1143.0, 926.0], [1104.0, 926.0]], [[1050.0, 796.0], [1089.0, 796.0], [1089.0, 1098.0], [1050.0, 1098.0]]], "lines": ["あー！", "山中湖ん時のー"]}, {"box": [247, 823, 290, 1089], "vertical": true, "font_size": 39, "lines_coords": [[[247.0, 823.0], [286.0, 823.0], [290.0, 1089.0], [251.0, 1089.0]]], "lines": ["どうしたのー"]}, {"box": [1151, 1305, 1225, 1477], "vertical": true, "font_size": 29, "lines_coords": [[[1196.0, 1308.0], [1222.0, 1308.0], [1222.0, 1458.0], [1196.0, 1458.0]], [