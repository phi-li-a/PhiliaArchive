{"box": [198, 210, 272, 346], "vertical": true, "font_size": 32, "lines_coords": [[[238.0, 211.0], [271.0, 211.0], [271.0, 345.0], [238.0, 345.0]], [[198.0, 210.0], [230.0, 210.0], [230.0, 346.0], [198.0, 346.0]]], "lines": ["いろいろ", "するよー"]}, {"box": [1141, 911, 1218, 1291], "vertical": true, "font_size": 34, "lines_coords": [[[1181.0, 911.0], [1218.0, 911.0], [1218.0, 1291.0], [1181.0, 1291.0]], [[1141.0, 915.0], [1173.0, 915.0], [1173.0, 1190.0], [1141.0, 1190.0]]], "lines": ["ブランケットに包まって", "ボーっとしたりー"]}, {"box": [443, 930, 650, 1005], "vertical": false, "font_size": 29, "lines_coords": [[[485.0, 933.0], [603.0, 933.0], [603.0, 965.0], [485.0, 965.0]], [[448.0, 973.0], [639.0, 973.0], [639.0, 999.0], [448.0, 999.0]]], "lines": ["秘密結社", "テーブルクロス"]}, {"box": [160, 930, 351, 1005], "vertical": false, "font_size": 30, "lines_coords": [[[193.0, 931.0], [316.0, 931.0], [316.0, 965.0], [193.0, 965.0]], [[166.0, 975.0], [339.0, 975.0], [339.0, 1001.0], [166.0, 1001.0]]], "lines": ["秘密結社", "タオルケット"]}, {"box": [297, 1380, 495, 1438], "vertical": false, "font_size": 26, "lines_coords": [[[346.0, 1383.0], [444.0, 1383.0], [444.0, 1410.0], [346.0, 1410.0]], [[300.0, 1413.0], [495.0, 1413.0], [495.0, 1438.0], [300.0, 1438.0]]], "lines": ["秘密結社", "牛乳拭いたそうきん"]}, {"box": [714, 1558, 793, 1693], "vertical": true, "font_size": 36, "lines_coords": [[[753.0, 1558.0], [793.0, 1558.0], [793.0, 1693.0], [753.0, 1693.0]], [[714.0, 1560.0], [746.0, 1560.0], [746.0, 1693.0], [714.0, 1693.0]]], "lines": ["ゴロゴロ", "したりー"]}, {"box": [567, 1398, 652, 1768], "vertical": true, "font_size": 36, "lines_coords": [[[613.0, 1398.0], [652.0, 1398.0], [652.0, 1588.0], [613.0, 1588.0]], [[568.0, 1400.0], [600.0, 1400.0], [600.0, 1768.0], [568.0, 1768.0]]], "lines": ["敵対組織と", "シマの奪い合いしたり、"]}, {"box": [140, 1432, 225, 1730], "vertical": true, "font_size": 35, "lines_coords": [[[183.0, 1432.0], [221.0, 1432.0], [225.0, 1730.0], [187.0, 1730.0]], [[140.0, 1436.0], [172.0, 1436.0], [172.0, 1657.0], [140.0, 1657.0]]], "lines": ["急に血なまぐさい", "話になったな"]}], "img_path": "00177.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1111, 159, 1187, 434], "vertical": true, "font_size": 32, "lines_coords": [[[1151.0, 159.0], [1183.0, 159.0], [1183.0, 365.0], [1151.0, 365.0]], [[1111.0, 161.0], [1143.0, 161.0], [1143.0, 433.0], [1111.0, 433.0]]], "lines": ["あと布教活動", "とかもやってるぞ"]}, {"box": [841, 266, 878, 454], "vertical": true, "font_size": 32, "lines_coords": [[[843.0, 266.0], [875.0, 266.0], [875.0, 451.0], [843.0, 451.0]]], "lines": ["布教活動？"]}, {"box": [669, 140, 738, 513], "vertical": true, "font_size": 28, "lines_coords": [[[705.0, 140.0], [736.0, 140.0], [736.0, 513.0], [705.0, 513.0]], [[669.0, 142.0], [695.0, 142.0], [695.0, 451.0], [669.0, 451.0]]], "lines": ["寒さに凍える徹夜組とかに", "ブランケット売ったり、"]}, {"box": [446, 160, 528, 401], "vertical": true, "font_size": 32, "lines_coords": [[[446.0, 176.0], [478.0, 176.0], [481.0, 337.0], [450.0, 337.0]]], "lines": ["いらんかねー"]}, {"box": [148, 135, 224, 374], "vertical": true, "font_size": 32, "lines_coords": [[[187.0, 135.0], [219.0, 135.0], [223.0, 311.0], [191.0, 311.0]], [[148.0, 138.0], [180.0, 138.0], [185.0, 373.0], [153.0, 373.0]]], "lines": ["ブランケット", "いやまんえんー"]}, {"box": [438, 652, 532, 691], "vertical": false, "font_size": 34, "lines_coords": [[[440.0, 652.0], [532.0, 658.0], [530.0, 691.0], [438.0, 686.0]]], "lines": ["かぅ"]}, {"box": [352, 506, 496, 568], "vertical": false, "font_size": 30.5, "lines_coords": [[[371.0, 506.0], [474.0, 511.0], [472.0, 538.0], [369.0, 532.0]], [[354.0, 525.0], [496.0, 534.0], [495.0, 568.0], [352.0, 558.0]]], "lines": ["殺害結婚は", "ヴランケット"]}, {"box": [139, 660, 215, 832], "vertical": true, "font_size": 28, "lines_coords": [[[180.0, 663.0], [211.0, 663.0], [211.0, 832.0], [180.0, 832.0]], [[140.0, 661.0], [166.0, 661.0], [166.0, 796.0], [140.0, 796.0]]], "lines": ["だいぶ足元", "見とるな"]}, {"box": [1132, 946, 1205, 1323], "vertical": true, "font_size": 32, "lines_coords": [[[1170.0, 946.0], [1201.0, 946.0], [1201.0, 1323.0], [1170.0, 1323.0]], [[1132.0, 948.0], [1164.0, 948.0], [1164.0, 1323.0], [1132.0, 1323.0]]], "lines": ["あと指定の商品についてる", "ブランケットシール２０枚を"]}, {"box": [976, 980, 1050, 1126], "vertical": true, "font_size": 56, "lines_coords": [[[995.0, 980.0], [1050.0, 988.0], [1031.0, 1126.0], [976.0, 1119.0]]], "lines": ["まじっちゃ"]}, {"box": [913, 1181, 945, 1331], "vertical": true, "font_size": 32, "lines_coords": [[[913.0, 1181.0], [945.0, 1181.0], [945.0, 1331.0], [913.0, 1331.0]]], "lines": ["まじっまよくし"]}, {"box": [566, 1000, 643, 1308], "vertical": true, "font_size": 32, "lines_coords": [[[607.0, 1001.0], [639.0, 1001.0], [639.0, 1308.0], [607.0, 1308.0]], [[566.0, 1001.0], [598.0, 1001.0], [598.0, 1243.0], [566.0, 1243.0]]], "lines": ["特製ブランケットが", "必ずもらえる！！"]}, {"box": [144, 1164, 195, 1246], "vertical": true, "font_size": 51, "lines_coords": [[[144.0, 1164.0], [195.0, 1164.0], [195.0, 1246.0], [144.0, 1246.0]]], "lines": ["とか"]}, {"box": [719, 1440, 755, 1751], "vertical": true, "font_size": 31, "lines_coords": [[[720.0, 1440.0], [751.0, 1440.0], [751.0, 1751.0], [720.0, 1751.0]]], "lines": ["台紙に貼って送ると"]}, {"box": [148, 1477, 233, 1702], "vertical": true, "font_size": 35, "lines_coords": [[[193.0, 1477.0], [230.0, 1477.0], [230.0, 1702.0], [193.0, 1702.0]], [[148.0, 1481.0], [181.0, 1481.0], [181.0, 1661.0], [148.0, 1661.0]]], "lines": ["春のなんとか", "まつりかい"]}], "img_path": "00178.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [433, 487, 937, 598], "vertical": false, "font_size": 29, "lines_coords": [[[435.0, 487.0], [894.0, 489.0], [894.0, 517.0], [435.0, 515.0]], [[433.0, 525.0], [937.0, 525.0], [937.0, 562.0], [433.0, 562.0]], [[435.0, 571.0], [615.0, 571.0], [615.0, 598.0], [435.0, 598.0]]], "lines": ["ゆるキャン△＠いかがでしたでしょうか。", "今回は伊豆キャンプ７出発編とへやキャン△を", "収録致しました。"]}, {"box": [420, 652, 980, 804], "vertical": false, "font_size": 29, "lines_coords": [[[420.0, 652.0], [980.0, 652.0], [980.0, 678.0], [420.0, 678.0]], [[420.0, 691.0], [615.0, 691.0], [615.0, 718.0], [420.0, 718.0]], [[515.0, 733.0], [967.0, 735.0], [967.0, 761.0], [515.0, 759.0]], [[511.0, 772.0], [948.0, 770.0], [948.0, 802.0], [511.0, 804.0]]], "lines": ["伊豆は１巻（６話）まるまる使うくらいかなぁ．．と", "思っていましたが", "伊豆広すぎジオスポ＆温泉多すぎ地獄で", "次巻もまだまだ伊豆編は続きそうです。"]}, {"box": [594, 856, 750, 883], "vertical": false, "font_size": 29, "lines_coords": [[[594.0, 856.0], [750.0, 856.0], [750.0, 883.0], [594.0, 883.0]]], "lines": ["あｆろでした。"]}, {"box": [394, 1709, 1061, 1864], "vertical": false, "font_size": 25, "lines_coords": [[[406.0, 1713.0], [1061.0, 1713.0], [1061.0, 1743.0], [406.0, 1743.0]], [[410.0, 1745.0], [753.0, 1745.0], [753.0, 1773.0], [410.0, 1773.0]], [[898.0, 1747.0], [993.0, 1747.0], [993.0, 1772.0], [898.0, 1772.0]], [[403.0, 1775.0], [1040.0, 1775.0], [1040.0, 1803.0], [403.0, 1803.0]], [[403.0, 1809.0], [515.0, 1809.0], [515.0, 1833.0], [403.0, 1833.0]], [[401.0, 1835.0], [729.0, 1835.0], [729.0, 1863.0], [401.0, 1863.0]]], "lines": ["いいよ。まんがタイムきららフォワーお平成３０年１２月号・平成２４年４月、", "・ＣＯＭＯ．ＦＵＺ平成３１年３３月掲載分", "これ．．．", "さらに、このペース平成２９年１２月１８日こ平成３０年７月１２日更新分〜", "・描き下ろし", "本書は以上の内容を収穫しました。"]}, {"box": [406, 1689, 528, 1710], "vertical": false, "font_size": 21, "lines_coords": [[[406.0, 1689.0], [528.0, 1689.0], [528.0, 1710.0], [406.0, 1710.0]]], "lines": ["〈初出＝覧〉て、"]}], "img_path": "00179.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [], "img_path": "00180.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [774, 401, 1173, 569], "vertical": false, "font_size": 168, "lines_coords": [[[774.0, 401.0], [1173.0, 401.0], [1173.0, 569.0], [774.0, 569.0]]], "lines": ["リストレム"]}, {"box": [386, 526, 462, 549], "vertical": false, "font_size": 19, "lines_coords": [[[395.0, 530.0], [453.0, 530.0], [453.0, 549.0], [395.0, 549.0]]], "lines": ["お風呂に"]}, {"box": [593, 999, 639, 1100], "vertical": true, "font_size": 21, "lines_coords": [[[618.0, 999.0], [639.0, 999.0], [639.0, 1087.0], [618.0, 1087.0]]], "lines": ["随分かけ足な"]}, {"box": [577, 1348, 637, 1522], "vertical": true, "font_size": 19, "lines_coords": [[[616.0, 1348.0], [637.0, 1348.0], [635.0, 1522.0], [615.0, 1522.0]], [[598.0, 1350.0], [616.0, 1350.0], [616.0, 1507.0], [598.0, 1507.0]], [[577.0, 1348.0], [596.0, 1348.0], [596.0, 1492.0], [577.0, 1492.0]]], "lines": ["まったり全部回ってたら", "伊豆編が５巻くらいに", "なっちまうんだよ！！"]}, {"box": [221, 1089, 256, 1248], "vertical": true, "font_size": 16, "lines_coords": [[[238.0, 1089.0], [256.0, 1089.0], [256.0, 1248.0], [238.0, 1248.0]], [[221.0, 1091.0], [234.0, 1091.0], [234.0, 1192.0], [221.0, 1192.0]]], "lines": ["伊豆は広いから急がないと", "間に合わねーぞ！"]}, {"box": [903, 1584, 1013, 1618], "vertical": false, "font_size": 34, "lines_coords": [[[903.0, 1584.0], [1010.0, 1584.0], [1010.0, 1618.0], [903.0, 1618.0]]], "lines": ["鮎壺の滝"]}, {"box": [225, 1464, 262, 1605], "vertical": true, "font_size": 18, "lines_coords": [[[241.0, 1464.0], [260.0, 1464.0], [260.0, 1560.0], [241.0, 1560.0]], [[225.0, 1464.0], [243.0, 1464.0], [243.0, 1605.0], [225.0, 1605.0]]], "lines": ["それは流石に", "まったりしすぎや！！"]}], "img_path": "00181.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [395, 796, 611, 900], "vertical": false, "font_size": 39.0, "lines_coords": [[[397.0, 796.0], [611.0, 796.0], [611.0, 834.0], [397.0, 834.0]], [[395.0, 860.0], [495.0, 860.0], [495.0, 900.0], [395.0, 900.0]]], "lines": ["著者：あｆろ", "©ａｆｒｏ"]}, {"box": [414, 618, 935, 675], "vertical": false, "font_size": 57, "lines_coords": [[[414.0, 618.0], [935.0, 618.0], [935.0, 675.0], [414.0, 675.0]]], "lines": ["ゆるキャン△，第８巻"]}, {"box": [393, 980, 963, 1230], "vertical": false, "font_size": 36, "lines_coords": [[[393.0, 993.0], [946.0, 990.0], [946.0, 1027.0], [393.0, 1031.0]], [[397.0, 1059.0], [691.0, 1059.0], [691.0, 1096.0], [397.0, 1096.0]], [[399.0, 1123.0], [800.0, 1126.0], [800.0, 1158.0], [399.0, 1155.0]], [[543.0, 1188.0], [950.0, 1188.0], [950.0, 1226.0], [543.0, 1226.0]]], "lines": ["電子版発行日：２０１９