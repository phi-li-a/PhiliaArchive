0, 166.0], [1175.0, 485.0], [1136.0, 485.0]]], "lines": ["ハンモックの練習"]}, {"box": [1140, 680, 1177, 992], "vertical": true, "font_size": 32, "lines_coords": [[[1141.0, 680.0], [1173.0, 680.0], [1173.0, 990.0], [1141.0, 990.0]]], "lines": ["焚き火を囲んで談笑"]}, {"box": [541, 682, 619, 992], "vertical": true, "font_size": 32, "lines_coords": [[[583.0, 684.0], [616.0, 684.0], [616.0, 855.0], [583.0, 855.0]], [[541.0, 686.0], [573.0, 686.0], [573.0, 991.0], [541.0, 991.0]]], "lines": ["そして時折", "富士山を眺める練習"]}, {"box": [921, 1437, 998, 1677], "vertical": true, "font_size": 33, "lines_coords": [[[963.0, 1440.0], [997.0, 1440.0], [997.0, 1608.0], [963.0, 1608.0]], [[922.0, 1438.0], [954.0, 1438.0], [954.0, 1676.0], [922.0, 1676.0]]], "lines": ["何で私だけ", "道具の役なの？"]}, {"box": [234, 1501, 315, 1711], "vertical": true, "font_size": 38, "lines_coords": [[[281.0, 1505.0], [313.0, 1505.0], [313.0, 1711.0], [281.0, 1711.0]], [[234.0, 1501.0], [279.0, 1501.0], [279.0, 1578.0], [234.0, 1578.0]]], "lines": ["おもろいから", "やで"]}], "img_path": "0168.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [868, 73, 1166, 105], "vertical": false, "font_size": 32, "lines_coords": [[[868.0, 73.0], [1166.0, 73.0], [1166.0, 105.0], [868.0, 105.0]]], "lines": ["放課後８キャンク"]}, {"box": [1091, 167, 1171, 618], "vertical": true, "font_size": 35, "lines_coords": [[[1130.0, 170.0], [1168.0, 170.0], [1168.0, 616.0], [1130.0, 616.0]], [[1091.0, 170.0], [1123.0, 170.0], [1123.0, 481.0], [1091.0, 481.0]]], "lines": ["キャンプが題材のゲームって", "ありそうで無いよな"]}, {"box": [423, 528, 503, 735], "vertical": true, "font_size": 33, "lines_coords": [[[466.0, 528.0], [498.0, 528.0], [498.0, 735.0], [466.0, 735.0]], [[423.0, 528.0], [457.0, 528.0], [457.0, 630.0], [423.0, 630.0]]], "lines": ["需要無いから", "やない"]}, {"box": [178, 378, 260, 641], "vertical": true, "font_size": 34, "lines_coords": [[[221.0, 378.0], [258.0, 378.0], [258.0, 641.0], [221.0, 641.0]], [[178.0, 382.0], [210.0, 382.0], [210.0, 605.0], [178.0, 605.0]]], "lines": ["それを言っちゃ", "おしめーよ！！！"]}, {"box": [1076, 892, 1210, 1231], "vertical": true, "font_size": 40, "lines_coords": [[[1171.0, 894.0], [1209.0, 894.0], [1209.0, 1231.0], [1171.0, 1231.0]], [[1121.0, 894.0], [1158.0, 894.0], [1158.0, 1228.0], [1121.0, 1228.0]], [[1076.0, 892.0], [1121.0, 892.0], [1121.0, 973.0], [1076.0, 973.0]]], "lines": ["キャンプ場経営する", "ゲームはあるみたい", "だよ"]}, {"box": [487, 1177, 574, 1543], "vertical": true, "font_size": 36, "lines_coords": [[[534.0, 1177.0], [573.0, 1177.0], [571.0, 1543.0], [532.0, 1543.0]], [[487.0, 1181.0], [519.0, 1181.0], [519.0, 1380.0], [487.0, 1380.0]]], "lines": ["じゃどんなゲームが", "ええんよ？"]}, {"box": [157, 1080, 195, 1327], "vertical": true, "font_size": 34, "lines_coords": [[[157.0, 1080.0], [191.0, 1080.0], [193.0, 1263.0], [159.0, 1263.0]]], "lines": ["そうだなー"]}, {"box": [686, 1368, 784, 1715], "vertical": true, "font_size": 45, "lines_coords": [[[738.0, 1370.0], [783.0, 1370.0], [783.0, 1715.0], [738.0, 1715.0]], [[686.0, 1368.0], [731.0, 1368.0], [731.0, 1674.0], [686.0, 1674.0]]], "lines": ["やる側のゲームは", "ないのかねチミ"]}], "img_path": "0169.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [183, 160, 628, 437], "vertical": false, "font_size": 304, "lines_coords": [[[183.0, 133.0], [628.0, 133.0], [628.0, 464.0], [183.0, 464.0]]], "lines": ["逃避"]}, {"box": [692, 669, 796, 718], "vertical": false, "font_size": 24, "lines_coords": [[[697.0, 673.0], [791.0, 673.0], [791.0, 693.0], [697.0, 693.0]], [[699.0, 691.0], [770.0, 691.0], [770.0, 718.0], [699.0, 718.0]]], "lines": ["ＹＡＣＨＭＥ", "ＳＥＬＥＣ"]}, {"box": [692, 910, 784, 933], "vertical": false, "font_size": 18, "lines_coords": [[[697.0, 915.0], [781.0, 915.0], [781.0, 933.0], [697.0, 933.0]]], "lines": ["ちなのｋｍ"]}, {"box": [138, 800, 628, 875], "vertical": false, "font_size": 32, "lines_coords": [[[140.0, 800.0], [555.0, 800.0], [555.0, 832.0], [140.0, 832.0]], [[138.0, 843.0], [626.0, 840.0], [626.0, 871.0], [138.0, 875.0]]], "lines": ["車、バイク、自転車、公共交通機関", "様々な手段を使ってキャンプ場へ急げ"]}, {"box": [163, 939, 315, 967], "vertical": false, "font_size": 26, "lines_coords": [[[163.0, 941.0], [315.0, 939.0], [315.0, 965.0], [163.0, 967.0]]], "lines": ["ＡＣＣＩＤＥＮＴ"]}, {"box": [1118, 1352, 1206, 1369], "vertical": false, "font_size": 17, "lines_coords": [[[1118.0, 1352.0], [1206.0, 1352.0], [1206.0, 1369.0], [1118.0, 1369.0]]], "lines": ["．．．"]}, {"box": [142, 1008, 650, 1110], "vertical": false, "font_size": 28.666666666666668, "lines_coords": [[[144.0, 1008.0], [650.0, 1008.0], [650.0, 1035.0], [144.0, 1035.0]], [[142.0, 1042.0], [605.0, 1042.0], [605.0, 1074.0], [142.0, 1074.0]], [[146.0, 1083.0], [433.0, 1083.0], [433.0, 1110.0], [146.0, 1110.0]]], "lines": ["悪天候、渋滞、事故、上司から突然の呼び出し", "あらゆるトラブルがプレレイヤーを阻む。", "食材の調達も忘れるな！！"]}, {"box": [142, 1211, 602, 1322], "vertical": false, "font_size": 28, "lines_coords": [[[142.0, 1216.0], [526.0, 1216.0], [526.0, 1243.0], [142.0, 1243.0]], [[144.0, 1252.0], [365.0, 1252.0], [365.0, 1278.0], [144.0, 1278.0]], [[144.0, 1290.0], [590.0, 1290.0], [590.0, 1321.0], [144.0, 1321.0]]], "lines": ["時間内にチェックインできたら", "ＢＢＯタイムだ！！", "キャンプ場の絶景も待っているぞ！！"]}, {"box": [155, 1158, 328, 1190], "vertical": false, "font_size": 32, "lines_coords": [[[155.0, 1158.0], [328.0, 1158.0], [328.0, 1190.0], [155.0, 1190.0]]], "lines": ["ＣＨＥＣＫＩＮ"]}, {"box": [1100, 1460, 1186, 1721], "vertical": true, "font_size": 37, "lines_coords": [[[1141.0, 1460.0], [1183.0, 1460.0], [1186.0, 1612.0], [1145.0, 1612.0]], [[1100.0, 1466.0], [1132.0, 1466.0], [1132.0, 1719.0], [1100.0, 1719.0]]], "lines": ["ほぼほぼ", "レースゲーやな"]}, {"box": [140, 1449, 262, 1721], "vertical": true, "font_size": 32, "lines_coords": [[[223.0, 1449.0], [262.0, 1449.0], [262.0, 1556.0], [223.0, 1556.0]], [[181.0, 1453.0], [213.0, 1453.0], [213.0, 1721.0], [181.0, 1721.0]], [[140.0, 1455.0], [166.0, 1455.0], [166.0, 1687.0], [140.0, 1687.0]]], "lines": ["だって", "レースゲーの方が", "おもろいじゃん"]}], "img_path": "0170.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [868, 75, 1200, 101], "vertical": false, "font_size": 26, "lines_coords": [[[868.0, 75.0], [1200.0, 75.0], [1200.0, 101.0], [868.0, 101.0]]], "lines": ["放課後９ソバウドを"]}, {"box": [590, 174, 697, 487], "vertical": true, "font_size": 31, "lines_coords": [[[661.0, 174.0], [695.0, 174.0], [697.0, 384.0], [663.0, 384.0]], [[628.0, 174.0], [660.0, 174.0], [660.0, 487.0], [628.0, 487.0]], [[590.0, 174.0], [622.0, 174.0], [622.0, 414.0], [590.0, 414.0]]], "lines": ["山の方に行くと", "「そばうどん」のお店が", "たくさんあるけど"]}, {"box": [528, 346, 555, 570], "vertical": true, "font_size": 31, "lines_coords": [[[528.0, 346.0], [555.0, 346.0], [555.0, 570.0], [528.0, 570.0]]], "lines": ["あれ何でだろ？"]}, {"box": [168, 485, 243, 725], "vertical": true, "font_size": 30, "lines_coords": [[[208.0, 487.0], [240.0, 487.0], [240.0, 725.0], [208.0, 725.0]], [[168.0, 489.0], [195.0, 489.0], [195.0, 656.0], [168.0, 656.0]]], "lines": ["言われてみると", "そうだなー"]}, {"box": [1115, 890, 1199, 1192], "vertical": true, "font_size": 38, "lines_coords": [[[1160.0, 890.0], [1198.0, 890.0], [1198.0, 1190.0], [1160.0, 1190.0]], [[1115.0, 890.0], [1153.0, 890.0], [1153.0, 1192.0], [1115.0, 1192.0]]], "lines": ["材料が少なくても", "作れるからとか．．．"]}, {"box": [751, 892, 886, 1121], "vertical": true, "font_size": 37, "lines_coords": [[[849.0, 896.0], [883.0, 896.0], [883.0, 1078.0], [849.0, 1078.0]], [[800.0, 894.0], [840.0, 894.0], [836.0, 1081.0], [796.0, 1081.0]], [[755.0, 892.0], [793.0, 892.0], [789.0, 1121.0], [751.0, 1121.0]]], "lines": ["水がきれい", "だからとか", "じゃないか？"]}, {"box": [523, 913, 644, 1351], "vertical": true, "font_size": 46, "lines_coords": [[[579.0, 916.0], [624.0, 916.0], [624.0, 1350.0], [579.0, 1350.0]], [[523.0, 913.0], [570.0, 913.0], [573.0, 1230.0], [526.0, 1230.0]]], "lines": ["あれ本当は「豪麦鵜井」", "だったんやぁ．．．"]}, {"box": [708, 1406, 810, 1763], "vertical": true, "font_size": 47, "lines_coords": [[[750.0, 1408.0], [804.0, 1406.0], [810.0, 1546.0], [755.0, 1548.0]], [[708.0, 1408.0], [748.0, 1408.0], [751.0, 1663.0], [712.0, 1663.0]]], "lines": ["それは", "ちゃうでぇー"]}, {"box": [153, 1500, 228, 1751], "vertical": true, "font_size": 47, "lines_coords": [[[153.0, 1500.0], [200.0, 1500.0], [204.0, 1751.0], [157.0, 1751.0]]], "lines": ["蕎麦鵜丼？"]}], "img_path": "0171.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1113, 133, 1218, 570], "vertical": true, "font_size": 45, "lines_coords": [[[1173.0, 135.0], [1218.0, 135.0], [1215.0, 543.0], [1170.0, 543.0]], [[1117.0, 133.0], [1162.0, 133.0], [1158.0, 536.0], [1113.0, 536.0]]], "lines": ["せやぁ飼料に蕎麦を", "混ぜて育てた鵜の肉"]}, {"box": [616, 133, 719, 662], "vertical": true, "font_size": 45, "lines_coords": [[[673.0, 133.0], [718.0, 133.0], [714.0, 536.0], [669.0, 536.0]], [[616.0, 136.0], [661.0, 136.0], [665.0, 661.0], [620.0, 661.0]]], "lines": ["甘辛ぁいタレで煮て", "山菜混ぜご飯の上に乗せた"]}, {"box": [114, 481, 220, 882], "vertical": true, "font_size": 44, "lines_coords": [[[168.0, 481.0], [211.0, 481.0], [215.0, 785.0], [172.0, 785.0]], [[118.0, 481.0], [163.0, 481.0], [159.0, 875.0], [114.0, 875.0]]], "lines": ["とある山間部の", "郷お料理やったんや"]}, {"box": [1117, 1008, 1213, 1346], "vertical": true, "font_size": 41.5, "lines_coords": [[[1168.0, 1036.0], [1213.0, 1036.0], [1213.0, 1346.0], [1168.0, 1346.0]], [[1117.0, 1008.0], [1155.0, 1008.0], [1160.0, 1273.0], [1123.0, 1273.0]]], "lines": ["が段々ＦＦでばりうど", "寝て間違えられた"]}, {"box": [856, 1261, 991, 1413], "vertical": false, "font_size": 143, "lines_coords": [[[868.0, 1261.0], [991.0, 1271.0], [980.0, 1413.0], [856.0, 1404.0]]], "lines": ["著者さん"]}, {"box": [620, 920, 718, 1412], "vertical": true, "font_size": 41, "lines_coords": [[[673.0, 920.0], [718.0, 920.0], [714.0, 1143.0], [669.0, 1143.0]], [[624.0, 937.0], [661.0, 937.0], [661.0, 1269.0], [624.0, 1269.0]]], "lines": ["「蕎麦鵜丼は", "歴史から姿を消し"]}, {"box": [504, 963, 550, 1310], "vertical": true, "font_size": 39, "lines_coords": [[[504.0, 963.0], [543.0, 963.0], [543.0, 1310.0], [504.0, 1310.0]]], "lines": ["んなワケあるかい"]}, {"box": [1002, 1492, 1193, 1778], "vertical": true, "font_size": 191, "lines_coords": [[[1002.0, 1492.0], [1193.0, 1492.0], [1193.0, 1778.0], [1002.0, 1778.0]]], "lines": ["あとは、"]}, {"box": [663, 1488, 744, 1713], "vertical": true, "font_size": 40, "lines_coords": [[[706.0, 1488.0], [744.0, 1488.0], [744.0, 1713.0], [706.0, 1713.0]], [[663.0, 1488.0], [705.0, 1488.0], [705.0, 1597.0], [663.0, 1597.0]]], "lines": ["そそうだった", "んだ．．．"]}], "img_path": "0172.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [988, 76, 1235, 106], "vertical": false, "font_size": 26, "lines_coords": [[[988.0, 76.0], [1235.0, 80.0], [1235.0, 106.0], [988.0, 103.0]]], "lines": ["１０取り扱い注意"]}, {"box": [290, 159, 377, 647], "vertical": true, "font_size": 35, "lines_coords": [[[335.0, 161.0], [373.0, 161.0], [373.0, 575.0], [335.0, 575.0]], [[290.0, 159.0], [322.0, 159.0], [322.0, 645.0], [290.0, 645.0]]], "lines": ["刃物類は特に注意せんと", "捕まってまう事もあるんやで"]}, {"box": [1083, 346, 1172, 874], "vertical": true, "font_size": 39, "lines_coords": [[[1130.0, 352.0], [1170.0, 352.0], [1170.0, 688.0], [1130.0, 688.0]], [[1083.0, 350.0], [1121.0, 350.0], [1121.0, 871.0], [1083.0, 871.0]]], "lines": ["アウトドアの道具は", "取り扱い注意なもんが多いけど、"]}, {"box": [195, 729, 241, 853], "vertical": true, "font_size": 46, "lines_coords": [[[195.0, 729.0], [241.0, 729.0], [241.0, 853.0], [195.0, 853.0]]], "lines": ["へぇー"]}, {"box": [1132, 982, 1199, 1429], "vertical": true, "font_size": 26, "lines_coords": [[[1171.0, 984.0], [1196.0, 984.0], [1196.0, 1338.0], [1171.0, 1338.0]], [[1134.0, 986.0], [1160.0, 986.0], [1160.0, 1426.0], [1134.0, 1426.0]]], "lines": ["まずそのまま持ち運ぶこと", "必要以上に大きな刃物はアウトや"]}, {"box": [159, 1007, 237, 1452], "vertical": true, "font_size": 32, "lines_coords": [[[202.0, 1008.0], [234.0, 1008.0], [234.0, 1451.0], [202.0, 1451.0]], [[159.0, 1010.0], [191.0, 1010.0], [191.0, 1351.0], [159.0, 1351.0]]], "lines": ["持ち歩く時はケースに入れて", "キャンプ道具と運ぶ事"]}, {"box": [748, 1558, 782, 1701], "vertical": true, "font_size": 32, "lines_coords": [[[748.0, 1558.0], [780.0, 1558.0], [780.0, 1700.0], [748.0, 1700.0]]], "lines": ["ふむふむ"]}], "img_path": "0173.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1111, 157, 1193, 380], "vertical": true, "font_size": 33, "lines_coords": [[[1160.0, 161.0], [1192.0, 161.0], [1192.0, 378.0], [1160.0, 378.0]], [[1111.0, 157.0], [1145.0, 157.0], [1147.0, 378.0], [1113.0, 378.0]]], "lines": ["もちろん斧も", "例外やないで"]}, {"box": [695, 148, 783, 300], "vertical": true, "font_size": 37, "lines_coords": [[[748.0, 153.0], [781.0, 153.0], [781.0, 300.0], [748.0, 300.0]], [[695.0, 150.0], [736.0, 148.0], [740.0, 262.0], [699.0, 264.0]]], "lines": ["ほうほう", "斧かぁ"]}, {"box": [163, 290, 292, 533], "vertical": true, "font_size": 42, "lines_coords": [[[245.0, 290.0], [292.0, 290.0], [292.0, 401.0], [245.0, 401.0]], [[208.0, 294.0], [245.0, 294.0], [245.0, 532.0], [208.0, 532.0]], [[163.0, 292.0], [204.0, 292.0], [204.0, 401.0], [163.0, 401.0]]], "lines": ["それは", "ファンタジーの", "やつや"]}, {"box": [1125, 645, 1203, 1093], "vertical": true, "font_size": 33, "lines_coords": [[[1168.0, 645.0], [1201.0, 645.0], [1200.0, 1055.0], [1166.0, 1055.0]], [[1126.0, 652.0], [1158.0, 652.0], [1158.0, 1093.0], [1126.0, 1093.0]]], "lines": ["でも林業の人みたいに山で", "一目で用途が分かる格好なら、"]}, {"box": [656, 637, 736, 844], "vertical": true, "font_size": 32, "lines_coords": [[[699.0, 643.0], [731.0, 643.0], [731.0, 841.0], [699.0, 841.0]], [[656.0, 637.0], [688.0, 637.0], [691.0, 813.0], [660.0, 813.0]]], "lines": ["一目で分かる", "格好かぁ．．．"]}, {"box": [135, 641, 215, 810], "vertical": true, "font_size": 32, "lines_coords": [[[180.0, 643.0], [213.0, 643.0], [213.0, 810.0], [180.0, 810.0]], [[135.0, 641.0], [166.0, 641.0], [166.0, 778.0], [135.0, 778.0]]], "lines": ["それは色々", "アウトや"]}, {"box": [810, 1308, 880, 1724], "vertical": true, "font_size": 26, "lines_coords": [[[847.0, 1308.0], [873.0, 1308.0], [873.0, 1543.0], [847.0, 1543.0]], [[811.0, 1310.0], [838.0, 1310.0], [838.0, 1721.0], [811.0, 1721.0]]], "lines": ["腰に大きなナタを", "つけててもＯＫな場合もあるわ"]}, {"box": [149, 1455, 221, 1740], "vertical": true, "font_size": 32, "lines_coords": [[[183.0, 1455.0], [221.0, 1455.0], [221.0, 1740.0], [183.0, 1740.0]], [[150.0, 1458.0], [176.0, 1458.0], [176.0, 1642.0], [150.0, 1642.0]]], "lines": ["何でサンプルが全部", "あたしなんだ"]}], "img_path": "0174.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [995, 78, 1177, 110], "vertical": false, "font_size": 32, "lines_coords": [[[995.0, 78.0], [1177.0, 78.0], [1177.0, 110.0], [995.0, 110.0]]], "lines": ["１．おもてな"]}, {"box": [1157, 174, 1199, 663], "vertical": true, "font_size": 38, "lines_coords": [[[1158.0, 174.0], [1196.0, 174.0], [1196.0, 660.0], [1158.0, 660.0]]], "lines": ["世の中には接待ゴルフならぬ"]}, {"box": [148, 159, 235, 611], "vertical": true, "font_size": 37, "lines_coords": [[[193.0, 159.0], [230.0, 159.0], [232.0, 611.0], [195.0, 611.0]], [[148.0, 161.0], [185.0, 161.0], [185.0, 421.0], [148.0, 421.0]]], "lines": ["接待キャンプというものが", "存在するらしい"]}, {"box": [969, 911, 1132, 1185], "vertical": true, "font_size": 35, "lines_coords": [[[1095.0, 911.0], [1132.0, 911.0], [1132.0, 1155.0], [1095.0, 1155.0]], [[1055.0, 913.0], [1087.0, 913.0], [1087.0, 1185.0], [1055.0, 1185.0]], [[1008.0, 911.0], [1046.0, 911.0], [1046.0, 1153.0], [1008.0, 1153.0]], [[969.0, 913.0], [1001.0, 913.0], [1001.0, 1147.0], [969.0, 1147.0]]], "lines": ["焚き火を囲んで", "うまい料理と酒で", "取り引き相手を", "もてなすらしい"]}, {"box": [673, 928, 749, 1098], "vertical": true, "font_size": 32, "lines_coords": [[[716.0, 928.0], [748.0, 928.0], [748.0, 1098.0], [716.0, 1098.0]], [[673.0, 928.0], [705.0, 928.0], [705.0, 1098.0], [673.0, 1098.0]]], "lines": ["そんなのも", "あるんやぁ"]}, {"box": [276, 915, 403, 1348], "vertical": true, "font_size": 61, "lines_coords": [[[337.0, 915.0], [403.0, 915.0], [403.0, 1194.0], [337.0, 1194.0]], [[277.0, 916.0], [333.0, 916.0], [333.0, 1348.0], [277.0, 1348.0]]], "lines": ["キャンプで", "おもてなしかぁ．．．"]}, {"box": [791, 1614, 840, 1738], "vertical": true, 