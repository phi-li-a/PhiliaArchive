]], "lines": ["出来るならダウンジャケット", "とか着せてあげたい"]}, {"box": [736, 1500, 853, 1770], "vertical": true, "font_size": 54, "lines_coords": [[[795.0, 1500.0], [853.0, 1500.0], [853.0, 1751.0], [795.0, 1751.0]], [[736.0, 1503.0], [787.0, 1503.0], [787.0, 1770.0], [736.0, 1770.0]]], "lines": ["すげー話が", "飛んだなォィ"]}], "img_path": "0177.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1115, 179, 1196, 438], "vertical": true, "font_size": 32, "lines_coords": [[[1160.0, 180.0], [1192.0, 180.0], [1192.0, 436.0], [1160.0, 436.0]], [[1115.0, 180.0], [1147.0, 180.0], [1147.0, 399.0], [1115.0, 399.0]]], "lines": ["んじゃあたしは", "ウシャンカと"]}, {"box": [753, 528, 832, 838], "vertical": true, "font_size": 34, "lines_coords": [[[798.0, 532.0], [832.0, 532.0], [830.0, 838.0], [796.0, 838.0]], [[757.0, 528.0], [791.0, 528.0], [787.0, 701.0], [753.0, 701.0]]], "lines": ["モコモコのブーツを", "進呈しよう"]}, {"box": [1151, 1027, 1201, 1320], "vertical": true, "font_size": 50, "lines_coords": [[[1151.0, 1027.0], [1201.0, 1027.0], [1201.0, 1320.0], [1151.0, 1320.0]]], "lines": ["ご太刀浴びれば"]}, {"box": [609, 1008, 759, 1756], "vertical": true, "font_size": 81.0, "lines_coords": [[[675.0, 1008.0], [753.0, 1008.0], [759.0, 1471.0], [680.0, 1471.0]], [[609.0, 1423.0], [693.0, 1423.0], [693.0, 1756.0], [609.0, 1756.0]]], "lines": ["ラン切らせて．．．", "骨を断つ！！"]}, {"box": [129, 951, 216, 1424], "vertical": true, "font_size": 84, "lines_coords": [[[129.0, 1010.0], [213.0, 1010.0], [213.0, 1423.0], [129.0, 1423.0]]], "lines": ["アンジャケ侍"]}, {"box": [806, 1276, 862, 1770], "vertical": true, "font_size": 56, "lines_coords": [[[806.0, 1316.0], [862.0, 1316.0], [862.0, 1770.0], [806.0, 1770.0]]], "lines": ["毛噴き出し目眩まし"]}, {"box": [146, 1513, 226, 1751], "vertical": true, "font_size": 32, "lines_coords": [[[191.0, 1515.0], [223.0, 1515.0], [223.0, 1719.0], [191.0, 1719.0]], [[146.0, 1513.0], [178.0, 1513.0], [178.0, 1751.0], [146.0, 1751.0]]], "lines": ["エッジ効いた", "設定の時代劇が"]}], "img_path": "0178.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [110, 129, 566, 168], "vertical": false, "font_size": 28, "lines_coords": [[[110.0, 133.0], [566.0, 134.0], [566.0, 165.0], [110.0, 163.0]]], "lines": ["ゆるキャン△＠ｖわかがでしたでしょうか。"]}, {"box": [85, 214, 967, 449], "vertical": false, "font_size": 35, "lines_coords": [[[110.0, 212.0], [740.0, 212.0], [740.0, 250.0], [110.0, 250.0]], [[106.0, 252.0], [496.0, 252.0], [496.0, 295.0], [106.0, 295.0]], [[103.0, 287.0], [909.0, 291.0], [909.0, 334.0], [103.0, 331.0]], [[106.0, 330.0], [877.0, 328.0], [877.0, 372.0], [106.0, 374.0]], [[106.0, 370.0], [757.0, 372.0], [757.0, 415.0], [106.0, 413.0]], [[326.0, 403.0], [391.0, 403.0], [391.0, 423.0], [326.0, 423.0]], [[108.0, 413.0], [624.0, 409.0], [624.0, 447.0], [108.0, 451.0]]], "lines": ["今回は野クルカ用品店、リンの胸ヶ根ツーリングキャンプ", "ベッドキャンペを取扱いさせました。", "リンが泊まったのは願いがですが、他にも画野高原は、鹿島高原などの", "俺はキャンプ場も近くにあります。あのでまとめて回ってみるのもオススメ", "そして願う根を訪れた際はなてしろがお勧めした喫茶店の", "こんなことは", "メガ盛りソースカツ丼に挑戦してみて下さい。"]}, {"box": [110, 496, 256, 525], "vertical": false, "font_size": 27, "lines_coords": [[[110.0, 498.0], [256.0, 496.0], [256.0, 523.0], [110.0, 525.0]]], "lines": ["あれろでした。"]}, {"box": [108, 1635, 708, 1782], "vertical": false, "font_size": 29, "lines_coords": [[[116.0, 1633.0], [221.0, 1633.0], [221.0, 1663.0], [116.0, 1663.0]], [[116.0, 1661.0], [705.0, 1657.0], [705.0, 1693.0], [116.0, 1697.0]], [[121.0, 1691.0], [635.0, 1691.0], [635.0, 1721.0], [121.0, 1721.0]], [[121.0, 1723.0], [238.0, 1723.0], [238.0, 1753.0], [121.0, 1753.0]], [[108.0, 1751.0], [474.0, 1749.0], [474.0, 1779.0], [108.0, 1781.0]]], "lines": ["（初セール）", "まんがタイムきちらフォワード平成２８年８月号〜１２月に", "いきららペース平成２８年４月の日〜６月２０日月２１日更新分", "．．．描き下ろし", "・地上３－２８大阪は以上の内容を収入しました。"]}], "img_path": "0179.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [384, 795, 603, 898], "vertical": false, "font_size": 37.0, "lines_coords": [[[384.0, 798.0], [603.0, 795.0], [603.0, 834.0], [384.0, 838.0]], [[388.0, 864.0], [483.0, 864.0], [483.0, 898.0], [388.0, 898.0]]], "lines": ["著者：あｆろ", "©ａｆｒｏ"]}, {"box": [403, 615, 930, 678], "vertical": false, "font_size": 63, "lines_coords": [[[403.0, 615.0], [930.0, 615.0], [930.0, 678.0], [403.0, 678.0]]], "lines": ["ゆるキャン△，第３巻"]}, {"box": [386, 980, 958, 1227], "vertical": false, "font_size": 34, "lines_coords": [[[386.0, 993.0], [939.0, 988.0], [939.0, 1027.0], [386.0, 1033.0]], [[388.0, 1061.0], [680.0, 1061.0], [680.0, 1093.0], [388.0, 1093.0]], [[390.0, 1123.0], [793.0, 1126.0], [793.0, 1158.0], [390.0, 1155.0]], [[538.0, 1190.0], [939.0, 1190.0], [939.0, 1222.0], [538.0, 1222.0]]], "lines": ["電子版発行日：２０１７年３月１５日", "発行人：東敬彰：東", "発行所：株式会社芳文社", "東京都文京区後楽１－２－１２"]}], "img_path": "0180.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [31, 675, 161, 845], "vertical": true, "font_size": 27, "lines_coords": [[[136.0, 675.0], [161.0, 675.0], [161.0, 845.0], [136.0, 845.0]], [[78.0, 688.0], [105.0, 688.0], [108.0, 823.0], [82.0, 823.0]], [[31.0, 686.0], [76.0, 682.0], [90.0, 826.0], [45.0, 830.0]]], "lines": ["お客様からのお見上げかりがとうございます。", "生活費も経し、色々週間らゆえキャンプ生活にも慣れてきまし", "そろそろ本格的なことので、資料をたくさん集めてこれからのとおります。"]}, {"box": [138, 836, 157, 860], "vertical": true, "font_size": 27, "lines_coords": [[[144.0, 836.0], [157.0, 840.0], [151.0, 860.0], [138.0, 856.0]]], "lines": ["．．．"]}, {"box": [266, 671, 632, 768], "vertical": false, "font_size": 96, "lines_coords": [[[275.0, 668.0], [615.0, 672.0], [615.0, 776.0], [275.0, 773.0]]], "lines": ["ゆお市は、"]}, {"box": [658, 830, 690, 1241], "vertical": true, "font_size": 32, "lines_coords": [[[658.0, 830.0], [690.0, 830.0], [690.0, 1241.0], [658.0, 1241.0]]], "lines": ["そういえば、このように"]}], "img_path": "0181.jpg"}]}