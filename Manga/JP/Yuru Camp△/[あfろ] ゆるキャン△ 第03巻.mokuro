], "vertical": true, "font_size": 32, "lines_coords": [[[778.0, 706.0], [815.0, 706.0], [815.0, 990.0], [778.0, 990.0]], [[742.0, 712.0], [774.0, 712.0], [774.0, 991.0], [742.0, 991.0]], [[706.0, 716.0], [733.0, 716.0], [733.0, 1063.0], [706.0, 1063.0]]], "lines": ["インフレータブルは", "コンパクトに畳めて", "「番寝心地イイ！！らしい"]}, {"box": [166, 564, 750, 596], "vertical": false, "font_size": 32, "lines_coords": [[[166.0, 564.0], [750.0, 564.0], [750.0, 596.0], [166.0, 596.0]]], "lines": ["中にスポンジも入っている空気で膨らませる"]}, {"box": [526, 807, 635, 1087], "vertical": true, "font_size": 30, "lines_coords": [[[601.0, 808.0], [633.0, 808.0], [633.0, 1027.0], [601.0, 1027.0]], [[562.0, 808.0], [594.0, 808.0], [594.0, 1087.0], [562.0, 1087.0]], [[526.0, 808.0], [553.0, 808.0], [553.0, 961.0], [526.0, 961.0]]], "lines": ["でも空気入れる", "タイプはパンクする", "事もあるで"]}, {"box": [200, 474, 461, 555], "vertical": false, "font_size": 36.0, "lines_coords": [[[200.0, 474.0], [461.0, 474.0], [461.0, 506.0], [200.0, 506.0]], [[281.0, 511.0], [382.0, 515.0], [380.0, 555.0], [279.0, 551.0]]], "lines": ["インフレータブル", "タイプ"]}, {"box": [260, 598, 397, 630], "vertical": false, "font_size": 32, "lines_coords": [[[260.0, 598.0], [397.0, 598.0], [397.0, 630.0], [260.0, 630.0]]], "lines": ["エアマット"]}, {"box": [132, 751, 163, 967], "vertical": true, "font_size": 26, "lines_coords": [[[133.0, 751.0], [159.0, 751.0], [159.0, 967.0], [133.0, 967.0]]], "lines": ["それは困るねぇ"]}, {"box": [1241, 1233, 1314, 1605], "vertical": true, "font_size": 32, "lines_coords": [[[1280.0, 1233.0], [1312.0, 1233.0], [1312.0, 1605.0], [1280.0, 1605.0]], [[1241.0, 1235.0], [1273.0, 1235.0], [1273.0, 1545.0], [1241.0, 1545.0]]], "lines": ["だが空気タイプはめっちゃ", "コンパクトになるぞ！！"]}, {"box": [656, 1196, 735, 1573], "vertical": true, "font_size": 32, "lines_coords": [[[699.0, 1196.0], [731.0, 1196.0], [731.0, 1554.0], [699.0, 1554.0]], [[656.0, 1196.0], [688.0, 1196.0], [688.0, 1573.0], [656.0, 1573.0]]], "lines": ["ま結局６００円の銀マット", "しか買えへんのやけどな"]}, {"box": [508, 1252, 624, 1366], "ve