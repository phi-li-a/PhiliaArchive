0]], [[885.0, 995.0], [909.0, 995.0], [909.0, 1164.0], [885.0, 1164.0]]], "lines": ["おかげで昼のバラエティが", "見放題だー！！"]}, {"box": [734, 805, 798, 1216], "vertical": true, "font_size": 26, "lines_coords": [[[768.0, 817.0], [795.0, 817.0], [796.0, 1183.0], [770.0, 1183.0]], [[735.0, 819.0], [761.0, 819.0], [761.0, 1211.0], [735.0, 1211.0]]], "lines": ["会社の人に聞いたんだけどな", "地元の人が家で作るほうとうは"]}, {"box": [165, 1218, 314, 1255], "vertical": false, "font_size": 26, "lines_coords": [[[202.0, 1222.0], [290.0, 1222.0], [290.0, 1248.0], [202.0, 1248.0]]], "lines": ["え"]}, {"box": [187, 1398, 311, 1713], "vertical": true, "font_size": 37, "lines_coords": [[[273.0, 1402.0], [307.0, 1402.0], [307.0, 1575.0], [273.0, 1575.0]], [[228.0, 1404.0], [268.0, 1404.0], [262.0, 1713.0], [223.0, 1713.0]], [[187.0, 1398.0], [225.0, 1398.0], [225.0, 1642.0], [187.0, 1642.0]]], "lines": ["気づいたら", "一家全員分作る事に", "なっとるがな！！"]}, {"box": [117, 1505, 153, 1783], "vertical": true, "font_size": 26, "lines_coords": [[[121.0, 1520.0], [148.0, 1520.0], [146.0, 1783.0], [120.0, 1783.0]]], "lines": ["ハードル上がってるし！！"]}], "img_path": "0079.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1216, 133, 1248, 292], "vertical": true, "font_size": 31, "lines_coords": [[[1216.0, 133.0], [1248.0, 133.0], [1248.0, 292.0], [1216.0, 292.0]]], "lines": ["どうする．．．"]}, {"box": [1108, 140, 1179, 551], "vertical": true, "font_size": 31, "lines_coords": [[[1145.0, 140.0], [1179.0, 140.0], [1177.0, 551.0], [1143.0, 551.0]], [[1108.0, 142.0], [1134.0, 142.0], [1134.0, 390.0], [1108.0, 390.0]]], "lines": ["ほうとうなんて家で出るもん", "食ってただけだし"]}, {"box": [534, 136, 661, 485], "vertical": true, "font_size": 36, "lines_coords": [[[622.0, 136.0], [661.0, 136.0], [658.0, 418.0], [618.0, 418.0]], [[577.0, 138.0], [615.0, 138.0], [615.0, 485.0], [577.0, 485.0]], [[536.0, 138.0], [568.0, 138.0], [568.0, 414.0], [536.0, 414.0]]], "lines": ["ハードル上がった", "この状況で適当なもん", "出していいのか？"]}, {"box": [58, 169, 138, 324], "vertical": true, "fon