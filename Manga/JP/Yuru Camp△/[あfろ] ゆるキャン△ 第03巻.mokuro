, 161.0], [174.0, 273.0], [133.0, 273.0]]], "lines": ["いや．．．"]}, {"box": [1100, 791, 1201, 1125], "vertical": true, "font_size": 26, "lines_coords": [[[1171.0, 791.0], [1198.0, 791.0], [1198.0, 960.0], [1171.0, 960.0]], [[1136.0, 793.0], [1162.0, 793.0], [1162.0, 1125.0], [1136.0, 1125.0]], [[1100.0, 796.0], [1126.0, 796.0], [1126.0, 1042.0], [1100.0, 1042.0]]], "lines": ["私も山登りは", "雪が積もる前のこの時期が", "一番好きなんですよ"]}, {"box": [140, 403, 212, 744], "vertical": true, "font_size": 29, "lines_coords": [[[178.0, 410.0], [210.0, 410.0], [210.0, 744.0], [178.0, 744.0]], [[140.0, 405.0], [166.0, 405.0], [166.0, 558.0], [140.0, 558.0]]], "lines": ["一部の人がやってるだけ", "というか．．．"]}, {"box": [725, 1212, 810, 1417], "vertical": true, "font_size": 40, "lines_coords": [[[772.0, 1213.0], [810.0, 1213.0], [810.0, 1417.0], [772.0, 1417.0]], [[725.0, 1213.0], [766.0, 1213.0], [766.0, 1325.0], [725.0, 1325.0]]], "lines": ["そそうです", "よね！"]}, {"box": [579, 1203, 656, 1550], "vertical": true, "font_size": 32, "lines_coords": [[[622.0, 1205.0], [654.0, 1205.0], [654.0, 1550.0], [622.0, 1550.0]], [[579.0, 1203.0], [611.0, 1203.0], [611.0, 1333.0], [579.0, 1333.0]]], "lines": ["あの今から登られるん", "ですか？"]}, {"box": [221, 810, 341, 1119], "vertical": true, "font_size": 33, "lines_coords": [[[307.0, 810.0], [339.0, 810.0], [339.0, 1119.0], [307.0, 1119.0]], [[262.0, 811.0], [296.0, 811.0], [294.0, 1117.0], [260.0, 1117.0]], [[221.0, 811.0], [253.0, 811.0], [253.0, 982.0], [221.0, 982.0]]], "lines": ["程よく雪化粧をした", "山の景色を見る事が", "楽しみで．．．"]}, {"box": [136, 1213, 217, 1541], "vertical": true, "font_size": 38, "lines_coords": [[[180.0, 1213.0], [217.0, 1213.0], [217.0, 1541.0], [180.0, 1541.0]], [[136.0, 1216.0], [174.0, 1216.0], [174.0, 1528.0], [136.0, 1528.0]]], "lines": ["ええでも一緒に登る", "知人がなかなか来．．．"]}, {"box": [1230, 1385, 1308, 1766], "vertical": true, "font_size": 34, "lines_coords": [[[1275.0, 1389.0], [1306.0, 1389.0], [1306.0, 1661.0], [1275.0, 1661.0]], [[1230.0, 1385.0], [1267.0, 1385.0], [1267.0, 1766.0], [123