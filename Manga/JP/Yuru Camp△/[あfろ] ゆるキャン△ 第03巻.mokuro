]]], "lines": ["そうだ！"]}, {"box": [582, 280, 645, 681], "vertical": true, "font_size": 26, "lines_coords": [[[616.0, 281.0], [641.0, 281.0], [641.0, 523.0], [616.0, 523.0]], [[583.0, 281.0], [609.0, 281.0], [609.0, 680.0], [583.0, 680.0]]], "lines": ["リンちゃん間違えて", "通行止めの道に行っちゃったのか"]}, {"box": [453, 517, 488, 654], "vertical": true, "font_size": 34, "lines_coords": [[[453.0, 517.0], [487.0, 517.0], [487.0, 652.0], [453.0, 652.0]]], "lines": ["ふむぅ．．．"]}, {"box": [540, 793, 583, 1105], "vertical": true, "font_size": 40, "lines_coords": [[[543.0, 793.0], [583.0, 793.0], [579.0, 1104.0], [540.0, 1104.0]]], "lines": ["いい事思いついた！！"]}, {"box": [481, 1351, 579, 1430], "vertical": false, "font_size": 37, "lines_coords": [[[500.0, 1351.0], [579.0, 1398.0], [560.0, 1430.0], [481.0, 1383.0]]], "lines": ["かシャ"]}, {"box": [180, 943, 210, 1093], "vertical": true, "font_size": 26, "lines_coords": [[[181.0, 943.0], [208.0, 943.0], [206.0, 1093.0], [180.0, 1093.0]]], "lines": ["プーンブーン"]}, {"box": [914, 1832, 1191, 1866], "vertical": false, "font_size": 26, "lines_coords": [[[926.0, 1835.0], [1190.0, 1835.0], [1190.0, 1861.0], [926.0, 1861.0]]], "lines": ["「ンちゃん今どこー？"]}], "img_path": "0064.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [579, 97, 1270, 147], "vertical": false, "font_size": 37, "lines_coords": [[[581.0, 103.0], [1258.0, 103.0], [1258.0, 140.0], [581.0, 140.0]]], "lines": ["お１５話おすすめ！なでしこナビ"]}, {"box": [752, 947, 912, 999], "vertical": false, "font_size": 34, "lines_coords": [[[770.0, 956.0], [886.0, 956.0], [886.0, 990.0], [770.0, 990.0]]], "lines": ["うっ"]}], "img_path": "0065.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [], "img_path": "0066.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [816, 161, 1177, 198], "vertical": false, "font_size": 26, "lines_coords": [[[821.0, 170.0], [1173.0, 166.0], [1173.0, 193.0], [821.0, 196.0]]], "lines": ["ふおおぉぉぉお！！（＊○○＊）"]}, {"box": [833, 269, 1165, 306], "vertical": false, "font_size": 26, "lines_coords": [[[834.0, 275.0], [1160.0, 275.0], [1160.0, 301.0], [834.0, 301.0]]], "lines": ["どこ！？どこなのそこ！？"]}, {"box": [714, 376, 1058, 411], "vertical": false, "font_size": 32, "lines_coords": [[[714.0, 378.0], [1053.0, 378.0], [1053.0, 410.0], [714.0, 410.0]]], "lines": ["諏訪湖の南の杖突峠ってとこ"]}, {"box": [264, 58, 602, 133], "vertical": false, "font_size": 30, "lines_coords": [[[270.0, 63.0], [594.0, 63.0], [594.0, 90.0], [270.0, 90.0]], [[266.0, 97.0], [476.0, 101.0], [476.0, 133.0], [266.0, 129.0]]], "lines": ["あ、そうそう私いいこと", "思いついたよ！"]}, {"box": [850, 473, 1148, 547], "vertical": false, "font_size": 26, "lines_coords": [[[855.0, 478.0], [1080.0, 478.0], [1080.0, 504.0], [855.0, 504.0]], [[855.0, 515.0], [1140.0, 515.0], [1140.0, 541.0], [855.0, 541.0]]], "lines": ["へえ～～（＊．．．", "いい眺めのとこだねぇ"]}, {"box": [740, 910, 1177, 974], "vertical": false, "font_size": 26, "lines_coords": [[[744.0, 913.0], [1162.0, 913.0], [1162.0, 939.0], [744.0, 939.0]], [[740.0, 945.0], [1173.0, 943.0], [1173.0, 969.0], [740.0, 971.0]]], "lines": ["リンちゃんがもう道に迷わつないように", "私がここからナ「ビしますっ！！（°ｕ°＇）ゞ"]}, {"box": [347, 723, 491, 767], "vertical": false, "font_size": 34, "lines_coords": [[[348.0, 731.0], [483.0, 727.0], [483.0, 761.0], [348.0, 765.0]]], "lines": ["ん、何？"]}, {"box": [149, 920, 440, 992], "vertical": false, "font_size": 30, "lines_coords": [[[150.0, 922.0], [435.0, 924.0], [435.0, 952.0], [150.0, 950.0]], [[153.0, 958.0], [416.0, 958.0], [416.0, 990.0], [153.0, 990.0]]], "lines": ["いや、間違えそうなど", "もう無しいから大丈夫"]}, {"box": [157, 1073, 427, 1151], "vertical": false, "font_size": 38, "lines_coords": [[[161.0, 1076.0], [423.0, 1076.0], [423.0, 1108.0], [161.0, 1108.0]], [[157.0, 1108.0], [249.0, 1108.0], [249.0, 1151.0], [157.0, 1151.0]]], "lines": ["ていうかナ・ビアプリ", "あるし"]}, {"box": [172, 1214, 216, 1387], "vertical": true, "font_size": 38, "lines_coords": [[[172.0, 1216.0], [210.0, 1216.0], [213.0, 1385.0], [176.0, 1385.0]]], "lines": ["どられたっ！？"]}], "img_path": "0067.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [806, 189, 1058, 228], "vertical": false, "font_size": 27, "lines_coords": [[[808.0, 198.0], [1055.0, 198.0], [1055.0, 225.0], [808.0, 225.0]]], "lines": ["そっか．．．（・；ｕ；｀｀"]}, {"box": [812, 295, 1184, 356], "vertical": false, "font_size": 25, "lines_coords": [[[817.0, 298.0], [1160.0, 298.0], [1160.0, 324.0], [817.0, 324.0]], [[815.0, 330.0], [1183.0, 330.0], [1183.0, 354.0], [815.0, 354.0]]], "lines": ["一緒にキャンプ行ってる気分に", "なれていいと思ううたんだけどなぁ"]}, {"box": [54, 827, 442, 894], "vertical": false, "font_size": 26, "lines_coords": [[[56.0, 832.0], [442.0, 832.0], [442.0, 858.0], [56.0, 858.0]], [[54.0, 862.0], [423.0, 866.0], [423.0, 892.0], [54.0, 888.0]]], "lines": ["分かった。じゃあ伊那と駒ヶ根の", "観光スポット調べてナビしてよ"]}, {"box": [1091, 1310, 1143, 1391], "vertical": true, "font_size": 52, "lines_coords": [[[1091.0, 1310.0], [1143.0, 1310.0], [1143.0, 1391.0], [1091.0, 1391.0]]], "lines": ["さて"]}, {"box": [117, 946, 397, 1005], "vertical": false, "font_size": 27, "lines_coords": [[[125.0, 946.0], [371.0, 948.0], [371.0, 975.0], [125.0, 973.0]], [[127.0, 978.0], [322.0, 978.0], [322.0, 1005.0], [127.0, 1005.0]]], "lines": ["昨日眠くて調べる前に", "寝ちゃったからさ"]}, {"box": [183, 1125, 559, 1193], "vertical": false, "font_size": 29, "lines_coords": [[[183.0, 1128.0], [558.0, 1125.0], [558.0, 1156.0], [183.0, 1160.0]], [[187.0, 1164.0], [532.0, 1164.0], [532.0, 1190.0], [187.0, 1190.0]]], "lines": ["分かりましたっ！！（｀＞ｖ＜｀）»", "いっぱい調べてナビするね！！"]}, {"box": [107, 1460, 170, 1728], "vertical": true, "font_size": 26, "lines_coords": [[[138.0, 1460.0], [165.0, 1460.0], [165.0, 1595.0], [138.0, 1595.0]], [[108.0, 1460.0], [133.0, 1460.0], [133.0, 1728.0], [108.0, 1728.0]]], "lines": ["どんな所を", "紹介してくれるのやら"]}], "img_path": "0068.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [461, 195, 513, 266], "vertical": true, "font_size": 52, "lines_coords": [[[461.0, 195.0], [513.0, 195.0], [513.0, 266.0], [461.0, 266.0]]], "lines": ["あー"]}, {"box": [350, 755, 408, 776], "vertical": false, "font_size": 21, "lines_coords": [[[350.0, 755.0], [408.0, 755.0], [408.0, 776.0], [350.0, 776.0]]], "lines": ["Ｊ鎖中"]}, {"box": [684, 847, 773, 1076], "vertical": true, "font_size": 37, "lines_coords": [[[733.0, 849.0], [770.0, 849.0], [770.0, 1038.0], [733.0, 1038.0]], [[684.0, 847.0], [721.0, 847.0], [721.0, 1076.0], [684.0, 1076.0]]], "lines": ["ココも冬は", "休みなのか："]}, {"box": [305, 806, 519, 1248], "vertical": false, "font_size": 129, "lines_coords": [[[345.0, 811.0], [401.0, 1156.0], [361.0, 1162.0], [305.0, 817.0]], [[343.0, 813.0], [393.0, 806.0], [440.0, 1149.0], [390.0, 1156.0]], [[423.0, 813.0], [457.0, 810.0], [481.0, 982.0], [448.0, 986.0]], [[423.0, 806.0], [496.0, 1241.0], [451.0, 1248.0], [378.0, 813.0]], [[466.0, 1042.0], [498.0, 1036.0], [519.0, 1155.0], [487.0, 1160.0]]], "lines": ["大旅行し救急地４８．頼むこれから", "．．．なんか言ってここからですね", "公衆トイレ！！", "株協任毎日ムヤ「世」いいもの案のように", "します。"]}, {"box": [146, 991, 236, 1260], "vertical": true, "font_size": 42, "lines_coords": [[[191.0, 993.0], [236.0, 993.0], [236.0, 1260.0], [191.0, 1260.0]], [[146.0, 991.0], [185.0, 991.0], [185.0, 1183.0], [146.0, 1183.0]]], "lines": ["ってトイレまで", "冬休みかよ"]}, {"box": [1141, 1486, 1209, 1742], "vertical": true, "font_size": 28, "lines_coords": [[[1175.0, 1486.0], [1207.0, 1486.0], [1207.0, 1715.0], [1175.0, 1715.0]], [[1141.0, 1486.0], [1166.0, 1486.0], [1166.0, 1741.0], [1141.0, 1741.0]]], "lines": ["最寄りのトイレが", "ここからＧＰＳとか．．．"]}, {"box": [258, 1478, 323, 1758], "vertical": true, "font_size": 26, "lines_coords": [[[294.0, 1479.0], [320.0, 1479.0], [320.0, 1758.0], [294.0, 1758.0]], [[258.0, 1481.0], [285.0, 1481.0], [285.0, 1593.0], [258.0, 1593.0]]], "lines": ["トイレ目的で来た人は", "大変だな"]}], "img_path": "0069.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1181, 740, 1215, 997], "vertical": true, "font_size": 32, "lines_coords": [[[1181.0, 740.0], [1213.0, 740.0], [