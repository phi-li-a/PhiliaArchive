tical": false, "font_size": 26, "lines_coords": [[[894.0, 168.0], [1151.0, 168.0], [1151.0, 195.0], [894.0, 195.0]], [[890.0, 204.0], [1201.0, 204.0], [1201.0, 230.0], [890.0, 230.0]]], "lines": ["しまりん！昼めしに", "ローメンなんてどうだ！？"]}, {"box": [261, 160, 688, 229], "vertical": false, "font_size": 29, "lines_coords": [[[266.0, 163.0], [678.0, 163.0], [678.0, 189.0], [266.0, 189.0]], [[266.0, 196.0], [630.0, 196.0], [630.0, 228.0], [266.0, 228.0]]], "lines": ["焼きそば風とラーメン風が置べる", "伊那名物の麺料理らしいぜ！！"]}, {"box": [1141, 830, 1213, 1005], "vertical": true, "font_size": 33, "lines_coords": [[[1181.0, 830.0], [1213.0, 830.0], [1213.0, 1005.0], [1181.0, 1005.0]], [[1141.0, 832.0], [1175.0, 832.0], [1175.0, 958.0], [1141.0, 958.0]]], "lines": ["そ、そろそろ", "出よう．．．"]}, {"box": [258, 832, 575, 891], "vertical": false, "font_size": 25, "lines_coords": [[[258.0, 834.0], [570.0, 836.0], [570.0, 862.0], [258.0, 860.0]], [[258.0, 866.0], [485.0, 866.0], [485.0, 890.0], [258.0, 890.0]]], "lines": ["あきちゃん！リンちゃんは今", "駒ヶ根にしいるんだよ？"]}, {"box": [284, 1235, 682, 1299], "vertical": false, "font_size": 29, "lines_coords": [[[285.0, 1237.0], [429.0, 1237.0], [429.0, 1263.0], [285.0, 1263.0]], [[285.0, 1267.0], [682.0, 1267.0], [682.0, 1299.0], [285.0, 1299.0]]], "lines": ["熱々のご飯と", "ジャキシャキ千切りキャベツの上に"]}, {"box": [285, 948, 544, 1012], "vertical": false, "font_size": 26, "lines_coords": [[[288.0, 952.0], [536.0, 952.0], [536.0, 978.0], [288.0, 978.0]], [[288.0, 986.0], [538.0, 986.0], [538.0, 1012.0], [288.0, 1012.0]]], "lines": ["だったら胸ヶ根名物", "ソースカツ丼だよ！！"]}, {"box": [273, 1778, 688, 1865], "vertical": false, "font_size": 22, "lines_coords": [[[275.0, 1781.0], [573.0, 1781.0], [573.0, 1800.0], [275.0, 1800.0]], [[277.0, 1807.0], [688.0, 1807.0], [688.0, 1831.0], [277.0, 1831.0]], [[277.0, 1837.0], [530.0, 1837.0], [530.0, 1861.0], [277.0, 1861.0]]], "lines": ["特製ソースをたつふりやめた", "ロースカツがど一んと乗ってるんだよ？", "美味しくなしＮ訳ないよ！！"]}], "img_path": "0100.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{