, 952, 606, 1179], "vertical": true, "font_size": 39, "lines_coords": [[[566.0, 954.0], [603.0, 954.0], [603.0, 1179.0], [566.0, 1179.0]], [[517.0, 952.0], [558.0, 952.0], [558.0, 1068.0], [517.0, 1068.0]]], "lines": ["肉まん買って", "帰ろー"]}, {"box": [1134, 1625, 1222, 1751], "vertical": true, "font_size": 42, "lines_coords": [[[1186.0, 1629.0], [1222.0, 1629.0], [1222.0, 1683.0], [1186.0, 1683.0]], [[1134.0, 1625.0], [1181.0, 1625.0], [1181.0, 1751.0], [1134.0, 1751.0]]], "lines": ["うー", "寒ぅー"]}], "img_path": "0118.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1078, 155, 1192, 440], "vertical": true, "font_size": 29, "lines_coords": [[[1160.0, 159.0], [1192.0, 159.0], [1192.0, 440.0], [1160.0, 440.0]], [[1123.0, 159.0], [1149.0, 159.0], [1149.0, 406.0], [1123.0, 406.0]], [[1081.0, 155.0], [1115.0, 155.0], [1111.0, 348.0], [1078.0, 348.0]]], "lines": ["キャンプに持ってく", "道具じゃないけど", "すごいもの．．．"]}, {"box": [1003, 318, 1029, 600], "vertical": true, "font_size": 29, "lines_coords": [[[1003.0, 318.0], [1029.0, 318.0], [1029.0, 600.0], [1003.0, 600.0]]], "lines": ["何だろねあきちゃん"]}, {"box": [613, 131, 686, 506], "vertical": true, "font_size": 32, "lines_coords": [[[654.0, 133.0], [686.0, 133.0], [686.0, 446.0], [654.0, 446.0]], [[613.0, 131.0], [645.0, 131.0], [645.0, 506.0], [613.0, 506.0]]], "lines": ["でかい丸太持ってって", "キャンプファイヤーとか？"]}, {"box": [135, 153, 219, 455], "vertical": true, "font_size": 37, "lines_coords": [[[178.0, 157.0], [215.0, 157.0], [219.0, 305.0], [181.0, 305.0]], [[135.0, 157.0], [172.0, 157.0], [172.0, 455.0], [135.0, 455.0]]], "lines": ["そんなの", "持ってけないよー"]}, {"box": [1081, 808, 1200, 1081], "vertical": true, "font_size": 32, "lines_coords": [[[1168.0, 810.0], [1200.0, 810.0], [1200.0, 982.0], [1168.0, 982.0]], [[1126.0, 808.0], [1158.0, 808.0], [1158.0, 1081.0], [1126.0, 1081.0]], [[1081.0, 810.0], [1113.0, 810.0], [1113.0, 1016.0], [1081.0, 1016.0]]], "lines": ["とりあえず", "どのキャンプ場か", "決めんとなー"]}, {"box": [761, 601, 804, 678], "vert