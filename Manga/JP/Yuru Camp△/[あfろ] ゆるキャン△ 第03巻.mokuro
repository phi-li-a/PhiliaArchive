, "font_size": 73, "lines_coords": [[[270.0, 146.0], [562.0, 146.0], [562.0, 185.0], [270.0, 185.0]], [[313.0, 180.0], [495.0, 180.0], [495.0, 337.0], [313.0, 337.0]], [[168.0, 204.0], [234.0, 204.0], [234.0, 281.0], [168.0, 281.0]], [[151.0, 243.0], [331.0, 253.0], [324.0, 406.0], [144.0, 397.0]], [[328.0, 290.0], [455.0, 298.0], [450.0, 391.0], [322.0, 384.0]], [[519.0, 221.0], [601.0, 221.0], [601.0, 264.0], [519.0, 264.0]], [[510.0, 271.0], [630.0, 275.0], [630.0, 307.0], [510.0, 303.0]], [[508.0, 309.0], [607.0, 309.0], [607.0, 341.0], [508.0, 341.0]], [[508.0, 346.0], [628.0, 346.0], [628.0, 373.0], [508.0, 373.0]]], "lines": ["のレシピ・ほうとう", "こんにゃくニンジンカボチャはくさい", "まいが里芋", "里芋ジャガイモ長ネギブタ肉", "んふっはくさい油あげ", "えいえ", "ほうとう麺", "甲州みそ", "だし（顆粒〉"]}, {"box": [720, 446, 1225, 559], "vertical": false, "font_size": 33, "lines_coords": [[[930.0, 446.0], [997.0, 446.0], [997.0, 481.0], [930.0, 481.0]], [[746.0, 525.0], [1162.0, 525.0], [1162.0, 556.0], [746.0, 556.0]], [[729.0, 483.0], [1115.0, 485.0], [1115.0, 519.0], [729.0, 517.0]]], "lines": ["まず", "鍋に入れぐらぐら煮ていきます", "ニンジンジャガイモ里芋"]}, {"box": [137, 442, 656, 534], "vertical": false, "font_size": 42, "lines_coords": [[[142.0, 446.0], [656.0, 442.0], [656.0, 487.0], [142.0, 491.0]], [[174.0, 493.0], [622.0, 493.0], [622.0, 532.0], [174.0, 532.0]]], "lines": ["野菜が程々に柔らかくなったら", "粉が付いたままの麺を投入"]}, {"box": [791, 1096, 1252, 1186], "vertical": false, "font_size": 48, "lines_coords": [[[793.0, 1096.0], [1246.0, 1096.0], [1246.0, 1147.0], [793.0, 1147.0]], [[858.0, 1141.0], [1177.0, 1141.0], [1177.0, 1186.0], [858.0, 1186.0]]], "lines": ["暫く煮込んだら残りの具材を", "投入しさらに煮込み"]}, {"box": [633, 1095, 699, 1291], "vertical": true, "font_size": 29, "lines_coords": [[[667.0, 1096.0], [699.0, 1096.0], [699.0, 1211.0], [667.0, 1211.0]], [[635.0, 1095.0], [661.0, 1095.0], [660.0, 1291.0], [633.0, 1291.0]]], "lines": ["ただいま", "何作ってんの？"]}, {"box": [431, 1103, 494, 1451], "vertical": true, "font_size": 26, "lines_coords": [[[465.0, 1110.0], [491.0, 1110.0], [