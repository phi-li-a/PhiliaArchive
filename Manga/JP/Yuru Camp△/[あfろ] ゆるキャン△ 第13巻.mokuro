 1678.0], [91.0, 1854.0], [65.0, 1854.0]]], "lines": ["あ．．", "４月１日やん"]}], "img_path": "00159.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [768, 1638, 1215, 1807], "vertical": false, "font_size": 73.5, "lines_coords": [[[785.0, 1659.0], [1089.0, 1693.0], [1076.0, 1807.0], [772.0, 1773.0]], [[768.0, 1638.0], [1215.0, 1640.0], [1215.0, 1672.0], [768.0, 1670.0]]], "lines": ["〈人服〉", "〈次ベージからは番外編《"]}], "img_path": "00160.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1134, 148, 1206, 554], "vertical": true, "font_size": 28, "lines_coords": [[[1173.0, 151.0], [1201.0, 151.0], [1203.0, 553.0], [1175.0, 553.0]], [[1136.0, 148.0], [1164.0, 148.0], [1162.0, 519.0], [1134.0, 519.0]]], "lines": ["最近知ったんだけど山梨では", "「カッ井」の事を二煮カツ丼」"]}, {"box": [921, 135, 1012, 163], "vertical": false, "font_size": 28, "lines_coords": [[[922.0, 135.0], [1012.0, 135.0], [1012.0, 163.0], [922.0, 163.0]]], "lines": ["煮ヵッ丼"]}, {"box": [935, 367, 995, 393], "vertical": false, "font_size": 26, "lines_coords": [[[935.0, 367.0], [995.0, 367.0], [995.0, 393.0], [935.0, 393.0]]], "lines": ["カツ丼"]}, {"box": [736, 133, 800, 521], "vertical": true, "font_size": 26, "lines_coords": [[[772.0, 135.0], [798.0, 135.0], [798.0, 519.0], [772.0, 519.0]], [[736.0, 133.0], [763.0, 133.0], [763.0, 354.0], [736.0, 354.0]]], "lines": ["「ソースカッ井」の事を「カッポ」", "って呼ぶんだよね"]}, {"box": [513, 131, 556, 241], "vertical": true, "font_size": 38, "lines_coords": [[[513.0, 133.0], [551.0, 131.0], [556.0, 238.0], [519.0, 240.0]]], "lines": ["店長！！"]}, {"box": [603, 144, 674, 613], "vertical": true, "font_size": 30, "lines_coords": [[[639.0, 148.0], [671.0, 148.0], [671.0, 613.0], [639.0, 613.0]], [[603.0, 146.0], [630.0, 146.0], [630.0, 611.0], [603.0, 611.0]]], "lines": ["バイト先で初めてメニュー見た時", "間違えてるのかと思っちゃったよ"]}, {"box": [121, 75, 418, 103], "vertical": false, "font_size": 26, "lines_coords": [[[121.0, 75.0], [418.0, 76.0], [418.0, 103.0], [121.0, 101.0]]], "lines": ["放課後１０８カツ丼"]}, {"box": [223, 143, 292, 350], "vertical": true, "font_size": 35, "lines_coords": [[[256.0, 144.0], [292.0, 144.0], [292.0, 223.0], [256.0, 223.0]], [[223.0, 144.0], [256.0, 144.0], [260.0, 350.0], [226.0, 350.0]]], "lines": ["これ", "間違ってます！！"]}, {"box": [267, 367, 309, 501], "vertical": true, "font_size": 42, "lines_coords": [[[267.0, 367.0], [309.0, 367.0], [309.0, 501.0], [267.0, 501.0]]], "lines": ["よしながき"]}, {"box": [718, 671, 817, 806], "vertical": true, "font_size": 48, "lines_coords": [[[776.0, 680.0], [817.0, 680.0], [817.0, 806.0], [776.0, 806.0]], [[718.0, 671.0], [774.0, 671.0], [774.0, 772.0], [718.0, 772.0]]], "lines": ["そうだ", "ぞー"]}, {"box": [137, 398, 207, 806], "vertical": true, "font_size": 28, "lines_coords": [[[174.0, 401.0], [202.0, 401.0], [204.0, 695.0], [176.0, 695.0]], [[138.0, 403.0], [165.0, 403.0], [165.0, 804.0], [138.0, 804.0]]], "lines": ["あぁなでしこちゃん", "ソバ屋さんで働いとるもんね"]}, {"box": [194, 918, 318, 952], "vertical": false, "font_size": 34, "lines_coords": [[[194.0, 918.0], [318.0, 918.0], [318.0, 952.0], [194.0, 952.0]]], "lines": ["へぇ〜"]}, {"box": [1134, 918, 1209, 1291], "vertical": true, "font_size": 32, "lines_coords": [[[1173.0, 920.0], [1205.0, 920.0], [1205.0, 1260.0], [1173.0, 1260.0]], [[1136.0, 918.0], [1168.0, 918.0], [1166.0, 1291.0], [1134.0, 1291.0]]], "lines": ["確かに「カッ井」注文して", "「ソースカツ丼」出て来たら、"]}, {"box": [759, 907, 845, 1204], "vertical": true, "font_size": 34, "lines_coords": [[[806.0, 907.0], [840.0, 907.0], [841.0, 1203.0], [808.0, 1203.0]], [[759.0, 907.0], [793.0, 907.0], [796.0, 1093.0], [763.0, 1093.0]]], "lines": ["県外から来た人は", "驚くわなぁ"]}, {"box": [373, 902, 482, 1213], "vertical": true, "font_size": 28, "lines_coords": [[[451.0, 905.0], [478.0, 905.0], [478.0, 1213.0], [451.0, 1213.0]], [[410.0, 903.0], [442.0, 903.0], [442.0, 1185.0], [410.0, 1185.0]], [[373.0, 905.0], [399.0, 905.0], [399.0, 1119.0], [373.0, 1119.0]]], "lines": ["でも県内のコンビニで", "売っとる「カッ井」は", "卵とじの方やで"]}, {"box": [1111, 1362, 1195, 1657], "vertical": true, "font_size": 35, "lines_coords": [[[1160.0, 1363.0], [1192.0, 1363.0], [1192.0, 1657.0], [1160.0, 1657.0]], [[1111.0, 1363.0], [1149.0, 1363.0], [1149.0, 1625.0], [1111.0, 1625.0]]], "lines": ["そういえば店長に", "聞いたんだけど"]}, {"box": [401, 1374, 566, 1719], "vertical": true, "font_size": 34, "lines_coords": [[[525.0, 1374.0], [562.0, 1374.0], [562.0, 1719.0], [525.0, 1719.0]], [[485.0, 1374.0], [519.0, 1374.0], [517.0, 1717.0], [483.0, 1717.0]], [[444.0, 1376.0], [476.0, 1376.0], [476.0, 1683.0], [444.0, 1683.0]], [[401.0, 1374.0], [433.0, 1374.0], [433.0, 1580.0], [401.0, 1580.0]]], "lines": ["「カツ丼」って呼ばれる", "ちょっと違うカツ丼て", "他の県にもいくつか", "あるらしいよ"]}, {"box": [172, 1554, 234, 1680], "vertical": true, "font_size": 62, "lines_coords": [[[172.0, 1554.0], [234.0, 1554.0], [234.0, 1680.0], [172.0, 1680.0]]], "lines": ["ほー"]}], "img_path": "00161.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1132, 170, 1202, 451], "vertical": true, "font_size": 29, "lines_coords": [[[1168.0, 170.0], [1200.0, 170.0], [1200.0, 451.0], [1168.0, 451.0]], [[1134.0, 174.0], [1160.0, 174.0], [1160.0, 450.0], [1134.0, 450.0]]], "lines": ["福井だと「カツ井」が", "ソースカツ丼の事で"]}, {"box": [623, 207, 732, 453], "vertical": true, "font_size": 28, "lines_coords": [[[699.0, 208.0], [731.0, 208.0], [731.0, 453.0], [699.0, 453.0]], [[663.0, 210.0], [690.0, 210.0], [690.0, 423.0], [663.0, 423.0]], [[624.0, 208.0], [650.0, 208.0], [650.0, 391.0], [624.0, 391.0]]], "lines": ["卵とじのカツ丼は", "上カッ井」って", "呼ぶんだって"]}, {"box": [148, 150, 219, 431], "vertical": true, "font_size": 32, "lines_coords": [[[185.0, 151.0], [217.0, 151.0], [217.0, 341.0], [185.0, 341.0]], [[148.0, 150.0], [180.0, 150.0], [180.0, 431.0], [148.0, 431.0]]], "lines": ["県外の人絶対", "引っかかるだろそれ"]}, {"box": [1113, 641, 1184, 922], "vertical": true, "font_size": 29, "lines_coords": [[[1151.0, 641.0], [1183.0, 641.0], [1183.0, 768.0], [1151.0, 768.0]], [[1115.0, 646.0], [1141.0, 646.0], [1141.0, 922.0], [1115.0, 922.0]]], "lines": ["沖縄だと", "野菜卵とじ井の上に"]}, {"box": [748, 611, 894, 652], "vertical": false, "font_size": 39, "lines_coords": [[[748.0, 611.0], [894.0, 611.0], [894.0, 650.0], [748.0, 650.0]]], "lines": ["カツ丼"]}, {"box": [418, 643, 527, 988], "vertical": true, "font_size": 32, "lines_coords": [[[493.0, 643.0], [525.0, 643.0], [525.0, 984.0], [493.0, 984.0]], [[455.0, 645.0], [487.0, 645.0], [487.0, 988.0], [455.0, 988.0]], [[418.0, 645.0], [450.0, 645.0], [450.0, 770.0], [418.0, 770.0]]], "lines": ["トンカツを乗っけた物が", "「カツ丼」って呼ばれてる", "らしいよ"]}, {"box": [335, 523, 489, 555], "vertical": false, "font_size": 32, "lines_coords": [[[335.0, 523.0], [489.0, 523.0], [489.0, 555.0], [335.0, 555.0]]], "lines": ["上カツ丼"]}, {"box": [180, 622, 264, 963], "vertical": true, "font_size": 35, "lines_coords": [[[225.0, 626.0], [262.0, 626.0], [262.0, 963.0], [225.0, 963.0]], [[180.0, 622.0], [213.0, 622.0], [215.0, 920.0], [181.0, 920.0]]], "lines": ["これは今まで見た事", "ないタイプやなぁ"]}, {"box": [1170, 1072, 1198, 1567], "vertical": true, "font_size": 30, "lines_coords": [[[1170.0, 1072.0], [1196.0, 1072.0], [1198.0, 1567.0], [1171.0, 1567.0]]], "lines": ["あとこれも教えてもらったんだけど"]}, {"box": [1048, 1138, 1121, 1672], "vertical": true, "font_size": 30, "lines_coords": [[[1083.0, 1138.0], [1121.0, 1138.0], [1119.0, 1672.0], [1081.0, 1672.0]], [[1048.0, 1143.0], [1074.0, 1143.0], [1074.0, 1546.0], [1048.0, 1546.0]]], "lines": ["ちょっと変わった「カッ丼」のある県で", "刑事ドラマが放送される時は、"]}, {"box": [338, 1086, 405, 1680], "vertical": true, "font_size": 29, "lines_coords": [[[373.0, 1091.0], [405.0, 1091.0], [405.0, 1597.0], [373.0, 1597.0]], [[339.0, 1093.0], [365.0, 1093.0], [365.0, 1680.0], [339.0, 1680.0]]], "lines": ["取り調べのシーンで出て来る「カッ丼」は", "一地元のカッ井」に差し替ええられてるんだってさ"]}, {"box": [174, 1134, 217, 1588], "vertical": true, "font_size": 39, "lines_coords": [[[176.0, 1134.0], [215.0, 1134.0], [213.0, 1584.0], [174.0, 1584.0]]], "lines": ["店長イス子の親戚だろ絶対"]}, {"box": [734, 1442, 761, 1618], "vertical": true, "font_size": 20, "lines_coords": [[[735.0, 1445.0], [755.0, 1445.0], [755.0, 1578.0], [735.0, 1578.0]]], "lines": ["こっしいよ、"]}, {"box": [541, 1456, 568, 1587], "vertical": true, "font_size": 27, "lines_coords": [[[541.0, 1456.0], [568.0, 1456.0], [568.0, 1587.0], [541.0, 1587.0]]], "lines": ["へぇー"]}], "img_path": "00162.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1128, 148, 1196, 335], "vertical": true, "font_size": 27, "lines_coords": [[[1170.0, 150.0], [1196.0, 150.0], [1196.0, 273.0], [1170.0, 273.0]], [[1128.0, 148.0], [1156.0, 148.0], [1158.0, 333.0], [1130.0, 333.0]]], "lines": ["そろそろ", "暖かくなって"]}, {"box": [123, 78, 493, 105], "vertical": false, "font_size": 27, "lines_coords": [[[123.0, 78.0], [493.0, 78.0], [493.0, 105.0], [123.0, 105.0]]], "lines": ["放課後１０９農鳥の伝説"]}, {"box": [157, 193, 256, 320], "vertical": true, "font_size": 46, "lines_coords": [[[202.0, 193.0], [256.0, 193.0], [256.0, 320.0], [202.0, 320.0]], [[157.0, 193.0], [196.0, 193.0], [196.0, 320.0], [157.0, 320.0]]], "lines": ["ホンマ", "やなぁ"]}, {"box": [761, 427, 830, 705], "vertical": true, "font_size": 29, "lines_coords": [[[796.0, 427.0], [828.0, 427.0], [826.0, 682.0], [795.0, 682.0]], [[761.0, 431.0], [787.0, 431.0], [787.0, 705.0], [761.0, 705.0]]], "lines": ["富士山もだんだん", "雪解けしてきたねぃ"]}, {"box": [656, 813, 695, 1029], "vertical": true, "font_size": 39, "lines_coords": [[[656.0, 817.0], [695.0, 817.0], [695.0, 1029.0], [656.0, 1029.0]]], "lines": ["のうとり？"]}, {"box": [165, 828, 241, 1080], "vertical": true, "font_size": 29, "lines_coords": [[[210.0, 832.0], [236.0, 832.0], [236.0, 1080.0], [210.0, 1080.0]], [[168.0, 828.0], [200.0, 828.0], [196.0, 958.0], [165.0, 958.0]]], "lines": ["富士山に住んでる", "鳥なの？"]}, {"box": [1081, 811, 1203, 1156], "vertical": true, "font_size": 34, "lines_coords": [[[1166.0, 811.0], [1203.0, 811.0], [1200.0, 1072.0], [1162.0, 1072.0]], [[1126.0, 815.0], [1158.0, 815.0], [1158.0, 1055.0], [1126.0, 1055.0]], [[1081.0, 821.0], [1113.0, 821.0], [1113.0, 1156.0], [1081.0, 1156.0]]], "lines": ["せや春になると", "富士山に現れる", "一農鳥」って知っとる？"]}, {"box": [1108, 1269, 1209, 1591], "vertical": true, "font_size": 26, "lines_coords": [[[1183.0, 1271.0], [1209.0, 1271.0], [1209.0, 1531.0], [1183.0, 1531.0]], [[1145.0, 1269.0], [1170.0, 1269.0], [1170.0, 1590.0], [1145.0, 1590.0]], [[1108.0, 1271.0], [1134.0, 1271.0], [1134.0, 1591.0], [1108.0, 1591.0]]], "lines": ["ほんまの鳥やなくて", "富士山の溶け残った雪が", "鳥の形に見える現象でな"]}, {"box": [307, 1205, 388, 1715], "vertical": true, "font_size": 36, "lines_coords": [[[348.0, 1205.0], [388.0, 1205.0], [388.0, 1636.0], [348.0, 1636.0]], [[307.0, 1209.0], [339.0, 1209.0], [339.0, 1715.0], [307.0, 1715.0]]], "lines": ["昔はこれが現れる時期と形で", "農作物の具作を占っとったらしいわ"]}, {"box": [153, 1297, 195, 1709], "vertical": true, "font_size": 38, "lines_coords": [[[157.0, 1297.0], [195.0, 1297.0], [191.0, 1706.0], [153.0, 1706.0]]], "lines": ["ホントに鳥の形してる！"]}], "img_path": "00163.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1088, 223, 1207, 532], "vertical": true, "font_size": 33, "lines_coords": [[[1170.0, 223.0], [1203.0, 223.0], [1205.0, 429.0], [1171.0, 429.0]], [[1130.0, 223.0], [1164.0, 223.0], [1164.0, 361.0], [1130.0, 361.0]], [[1089.0, 223.0], [1121.0, 223.0], [1121.0, 532.0], [1089.0, 532.0]]], "lines": ["あおいちゃん", "これって", "どこで見られるの？"]}, {"box": [695, 172, 779, 393], "vertical": true, "font_size": 35, "lines_coords": [[[738.0, 172.0], [776.0, 172.0], [776.0, 393.0], [738.0, 393.0]], [[695.0, 174.0], [727.0, 174.0], [727.0, 360.0], [695.0, 360.0]]], "lines": ["北側の斜面に", "出るから．．．"]}, {"box": [253, 172, 326, 487], "vertical": true, "font_size": 32, "lines_coords": [[[292.0, 174.0], [324.0, 174.0], [324.0, 393.0], [292.0, 393.0]], [[255.0, 172.0], [286.0, 172.0], [285.0, 487.0], [253.0, 487.0]]], "lines": ["富士五湖周辺が", "見えやすいんやない？"]}, {"box": [150, 355, 190, 513], "vertical": true, "font_size": 33, "lines_coords": [[[150.0, 356.0], [183.0, 356.0], [183.0, 513.0], [150.0, 513.0]]], "lines": ["農鳥かぁ"]}, {"box": [1166, 622, 1203, 961], "vertical": true, "font_size": 37, "lines_coords": [[[1166.0, 622.0], [1203.0, 622.0], [1203.0, 961.0], [1166.0, 961.0]]], "lines": ["豊作を占う以外にも"]}, {"box": [157, 633, 289, 1005], "vertical": true, "font_size": 38, "lines_coords": [[[249.0, 639.0], [286.0, 639.0], [286.0, 858.0], [249.0, 858.0]], [[202.0, 635.0], [241.0, 635.0], [241.0, 935.0], [202.0, 935.0]], [[157.0, 633.0], [195.0, 633.0], [195.0, 1005.0], [157.0, 1005.0]]], "lines": ["一年間健康に", "暮らせるっていう", "伝説があるんだよなァ"]}, {"box": [1021, 933, 1153, 1235], "vertical": true, "font_size": 37, "lines_coords": [[[1111.0, 933.0], [1149.0, 933.0], [1153.0, 1198.0], [1115.0, 1198.0]], [[1068.0, 933.0], [1106.0, 933.0], [1106.0, 1235.0], [1068.0, 1235.0]], [[1021.0, 933.0], [1055.0, 933.0], [1057.0, 1233.0], [1023.0, 1233.0]]], "lines": ["毎年富士五湖で", "農鳥を眺めながら", "鶏料理を食べると"]}, {"box": [159, 1068, 206, 1238], "vertical": true, "font_size": 43, "lines_coords": [[[159.0, 1070.0], [202.0, 1068.0], [206.0, 1153.0], [163.0, 1155.0]]], "lines": ["へえ"]}, {"box": [1067, 1426, 1177, 1740], "vertical": true, "font_size": 28, "lines_coords": [[[1145.0, 1426.0], [1177.0, 1426.0], [1177.0, 1740.0], [1145.0, 1740.0]], [[1108.0, 1426.0], [1134.0, 1426.0], [1134.0, 1738.0], [1108.0, 1738.0]], [[1068.0, 1428.0], [1095.0, 1428.0], [1095.0, 1704.0], [1068.0, 1704.0]]], "lines": ["．．．って噂を流しとけば", "富士チキン五湖計画も", "イケると思うんだが、"]}, {"box": [903, 1370, 978, 1580], "vertical": true, "font_size": 30, "lines_coords": [[[950.0, 1385.0], [976.0, 1385.0], [976.0, 1503.0], [950.0, 1503.0]], [[903.0, 1372.0], [937.0, 1370.0], [950.0, 1578.0], [916.0, 1580.0]]], "lines": ["恵ち巻き", "みたいな売り方で"]}, {"box": [435, 1398, 513, 1745], "vertical": true, "font_size": 38, "lines_coords": [[[478.0, 1402.0], [510.0, 1402.0], [510.0, 1745.0], [478.0, 1745.0]], [[435.0, 1398.0], [478.0, 1398.0], [478.0, 1473.0], [435.0, 1473.0]]], "lines": ["まだ引きずっとったんか", "それ"]}], "img_path": "00164.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [860, 78, 1190, 103], "vertical": false, "font_size": 25, "lines_coords": [[[860.0, 78.0], [1190.0, 78.0], [1190.0, 103.0], [860.0, 103.0]]], "lines": ["放課後１１０透ける眉"]}, {"box": [1129, 164, 1198, 506], "vertical": true, "font_size": 29, "lines_coords": [[[1166.0, 165.0], [1198.0, 165.0], [1198.0, 444.0], [1166.0, 444.0]], [[1130.0, 166.0], [1156.0, 166.0], [1156.0, 506.0], [1130.0, 506.0]]], "lines": ["クリキャンの写真に", "えらい物が写っていた：："]}, {"box": [676, 168, 735, 502], "vertical": true, "font_size": 59, "lines_coords": [[[676.0, 168.0], [735.0, 168.0], [735.0, 502.0], [676.0, 502.0]]], "lines": ["しっ心霊写真！？"]}, {"box": [150, 185, 224, 481], "vertical": true, "font_size": 32, "lines_coords": [[[191.0, 189.0], [223.0, 189.0], [223.0, 481.0], [191.0, 481.0]], [[150.0, 185.0], [181.0, 185.0], [181.0, 376.0], [150.0, 376.0]]], "lines": ["いいやオバケ系では", "ないんだが．．．"]}, {"box": [1077, 630, 1199, 1132], "vertical": true, "font_size": 32, "lines_coords": [[[1164.0, 631.0], [1196.0, 631.0], [1196.0, 890.0], [1164.0, 890.0]], [[1113.0, 630.0], [1151.0, 630.0], [1151.0, 1132.0], [1113.0, 1132.0]], [[1080.0, 631.0], [1106.0, 631.0], [1106.0, 1066.0], [1080.0, 1066.0]]], "lines": ["これなんだが．．．", "いつもは透けてるイヌ子の眉毛が", "アルミマットで隠れてんだよ"]}, {"box": [157, 637, 243, 1087], "vertical": true, "font_size": 38, "lines_coords": [[[204.0, 641.0], [241.0, 641.0], [241.0, 1087.0], [204.0, 1087.0]], [[157.0, 637.0], [195.0, 637.0], [195.0, 976.0], [157.0, 976.0]]], "lines": ["ああ、ホントだ。でもそんなに", "気になる事かなぁ？"]}, {"box": [912, 1283, 954, 1498], "vertical": true, "font_size": 37, "lines_coords": [[[915.0, 1286.0], [952.0, 1286.0], [952.0, 1498.0], [915.0, 1498.0]]], "lines": ["．．．．．電波だ"]}, {"box": [151, 1245, 231, 1516], "vertical": true, "font_size": 32, "lines_coords": [[[196.0, 1248.0], [228.0, 1248.0], [228.0, 1516.0], [196.0, 1516.0]], [[155.0, 1245.0], [187.0, 1245.0], [183.0, 1485.0], [151.0, 1485.0]]], "lines": ["一眉電波」なんじゃ", "ないだろうか！？"]}, {"box": [1132, 1240, 1202, 1727], "vertical": true, "font_size": 28, "lines_coords": [[[1170.0, 1241.0], [1201.0, 1241.0], [1201.0, 1608.0], [1170.0, 1608.0]], [[1132.0, 1241.0], [1158.0, 1241.0], [1158.0, 1726.0], [1132.0, 1726.0]]], "lines": ["木やガラスは通り抜けるが", "アルミ（金属）を通さない物と言えば"]}, {"box": [742, 1252, 826, 1659], "vertical": true, "font_size": 38, "lines_coords": [[[789.0, 1252.0], [826.0, 1252.0], [826.0, 1659.0], [789.0, 1659.0]], [[742.0, 1254.0], [780.0, 1254.0], [780.0, 1511.0], [742.0, 1511.0]]], "lines": ["つまり犬子の額の△△は", "「眉毛」ではなく"]}, {"box": [169, 1605, 235, 1669], "vertical": false, "font_size": 64, "lines_coords": [[[169.0, 1605.0], [235.0, 1605.0], [235.0, 1669.0], [169.0, 1669.0]]], "lines": ["！！？"]}], "img_path": "00165.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1123, 178, 1200, 420], "vertical": true, "font_size": 33, "lines_coords": [[[1166.0, 180.0], [1200.0, 180.0], [1200.0, 316.0], [1166.0, 316.0]], [[1123.0, 180.0], [1155.0, 180.0], [1155.0, 420.0], [1123.0, 420.0]]], "lines": ["電波って", "目に見えるの？"]}, {"box": [579, 166, 650, 414], "vertical": true, "font_size": 27, "lines_coords": [[[620.0, 166.0], [646.0, 166.0], [646.0, 380.0], [620.0, 380.0]], [[579.0, 166.0], [607.0, 166.0], [609.0, 414.0], [581.0, 414.0]]], "lines": ["普通は見えない", "はずなんだよなぁ"]}, {"box": [1141, 607, 1211, 826], "vertical": true, "font_size": 32, "lines_coords": [[[1179.0, 607.0], [1211.0, 607.0], [1211.0, 735.0], [1179.0, 735.0]], [[1141.0, 607.0], [1173.0, 607.0], [1173.0, 826.0], [1141.0, 826.0]]], "lines": ["うむむ．．．", "何だろうね一体"]}, {"box": [598, 615, 663, 868], "vertical": true, "font_size": 26, "lines_coords": [[[633.0, 616.0], [660.0, 616.0], [660.0, 813.0], [633.0, 813.0]], [[600.0, 615.0], [626.0, 615.0], [624.0, 868.0], [598.0, 868.0]]], "lines": ["引き続き調査を", "続けるしかないな．．．"]}, {"box": [740, 875, 775, 1132], "vertical": true, "font_size": 32, "lines_coords": [[[742.0, 875.0], [774.0, 875.0], [772.0, 1132.0], [740.0, 1132.0]]], "lines": ["謎は深まるばかりだ"]}, {"box": [174, 984, 211, 1141], "vertical": true, "font_size": 32, "lines_coords": [[[174.0, 984.0], [206.0, 984.0], [210.0, 1141.0], [178.0, 1141.0]]], "lines": ["そうだねぇ"]}, {"box": [1063, 1278, 1170, 1752], "vertical": true, "font_size": 49, "lines_coords": [[[1119.0, 1280.0], [1170.0, 1280.0], [1170.0, 1629.0], [1119.0, 1629.0]], [[1066.0, 1278.0], [1113.0, 1278.0], [1110.0, 1751.0], [1063.0, 1751.0]]], "lines": ["自分は大丈夫だと", "思ってはいませんか．．．？"]}, {"box": [412, 1275, 462, 1667], "vertical": true, "font_size": 45, "lines_coords": [[[412.0, 1278.0], [457.0, 1278.0], [461.0, 1665.0], [416.0, 1665.0]]], "lines": ["よく鏡を見て下さい"]}, {"box": [165, 1278, 263, 1683], "vertical": true, "font_size": 42, "lines_coords": [[[219.0, 1282.0], [258.0, 1282.0], [258.0, 1683.0], [219.0, 1683.0]], [[165.0, 1278.0], [210.0, 1278.0], [210.0, 1533.0], [165.0, 1533.0]]], "lines": ["ほらあなたの眉毛も", "きっと．．．．．．"]}], "img_path": "00166.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [320, 75, 628, 101], "vertical": false, "font_size": 26, "lines_coords": [[[320.0, 75.0], [628.0, 75.0], [628.0, 101.0], [320.0, 101.0]]], "lines": ["リメイクしすぎ問題"]}, {"box": [120, 78, 296, 103], "vertical": false, "font_size": 25, "lines_coords": [[[120.0, 78.0], [296.0, 78.0], [296.0, 103.0], [120.0, 103.0]]], "lines": ["放課後１１１"]}, {"box": [1078, 406, 1194, 804], "vertical": true, "font_size": 31, "lines_coords": [[[1164.0, 410.0], [1190.0, 410.0], [1190.0, 804.0], [1164.0, 804.0]], [[1117.0, 406.0], [1151.0, 406.0], [1153.0, 609.0], [1119.0, 609.0]], [[1078.0, 408.0], [1110.0, 408.0], [1110.0, 770.0], [1078.0, 770.0]]], "lines": ["肉じゃがをカレーにしたり、", "アヒージョを", "アクアバッツァにしたり、"]}, {"box": [166, 405, 239, 776], "vertical": true, "font_size": 30, "lines_coords": [[[206.0, 405.0], [238.0, 405.0], [238.0, 776.0], [206.0, 776.0]], [[168.0, 406.0], [195.0, 406.0], [195.0, 772.0], [168.0, 772.0]]], "lines": ["リメイクレシピで色々な", "味が楽しめてええよねぇ"]}, {"box": [1064, 870, 1171, 1209], "vertical": true, "font_size": 28, "lines_coords": [[[1138.0, 870.0], [1170.0, 870.0], [1171.0,