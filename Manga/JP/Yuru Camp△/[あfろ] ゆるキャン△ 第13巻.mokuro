255.0, 607.0]]], "lines": ["「にしがわから", "みたふじさん"]}, {"box": [243, 783, 371, 1063], "vertical": true, "font_size": 36, "lines_coords": [[[331.0, 785.0], [371.0, 785.0], [371.0, 993.0], [331.0, 993.0]], [[281.0, 783.0], [318.0, 783.0], [320.0, 1063.0], [283.0, 1063.0]], [[243.0, 785.0], [275.0, 785.0], [275.0, 1061.0], [243.0, 1061.0]]], "lines": ["字面からして", "富士山争いする気", "満々じゃねぇか．．．"]}, {"box": [556, 1209, 890, 1580], "vertical": true, "font_size": 334, "lines_coords": [[[556.0, 1209.0], [890.0, 1209.0], [890.0, 1580.0], [556.0, 1580.0]]], "lines": ["梨"]}, {"box": [150, 892, 185, 1112], "vertical": true, "font_size": 32, "lines_coords": [[[150.0, 892.0], [181.0, 892.0], [183.0, 1111.0], [151.0, 1111.0]]], "lines": ["曲解しすぎや。"]}, {"box": [305, 1283, 353, 1500], "vertical": true, "font_size": 48, "lines_coords": [[[305.0, 1283.0], [353.0, 1283.0], [353.0, 1500.0], [305.0, 1500.0]]], "lines": ["山梨だろ。"]}, {"box": [198, 1276, 355, 1504], "vertical": true, "font_size": 50, "lines_coords": [[[300.0, 1280.0], [346.0, 1280.0], [350.0, 1498.0], [303.0, 1498.0]], [[198.0, 1276.0], [251.0, 1276.0], [255.0, 1503.0], [202.0, 1503.0]]], "lines": ["山梨だろ。", "山梨やな。"]}, {"box": [506, 1561, 984, 1768], "vertical": false, "font_size": 207, "lines_coords": [[[506.0, 1561.0], [984.0, 1561.0], [984.0, 1768.0], [506.0, 1768.0]]], "lines": ["【きたがわから】みたふじさん」"]}], "img_path": "00176.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1098, 138, 1200, 515], "vertical": true, "font_size": 52, "lines_coords": [[[1141.0, 138.0], [1200.0, 138.0], [1200.0, 515.0], [1141.0, 515.0]], [[1098.0, 144.0], [1143.0, 144.0], [1143.0, 350.0], [1098.0, 350.0]]], "lines": ["キャンプが出来ない」", "雨の休日は"]}, {"box": [120, 76, 444, 103], "vertical": false, "font_size": 27, "lines_coords": [[[120.0, 76.0], [444.0, 76.0], [444.0, 103.0], [120.0, 103.0]]], "lines": ["放課後１１６雨の休日"]}, {"box": [157, 570, 263, 1098], "vertical": true, "font_size": 51, "lines_coords": [[[211.0, 571.0], [262.0, 571.0], [262.0, 1098.0], [211.0, 1098.0]], [[157.0, 581.0], [208.0, 581.0], [208.0, 901.0], [157.0, 901.0]]], "lines": ["キャンプの動画を見るのも", "一つの楽しみだ。"]}, {"box": [1162, 1256, 1196, 1398], "vertical": true, "font_size": 34, "lines_coords": [[[1162.0, 1256.0], [1196.0, 1256.0], [1196.0, 1398.0], [1162.0, 1398.0]]], "lines": ["ずず．．．"]}, {"box": [748, 1167, 815, 1490], "vertical": true, "font_size": 26, "lines_coords": [[[783.0, 1168.0], [810.0, 1168.0], [810.0, 1490.0], [783.0, 1490.0]], [[748.0, 1168.0], [774.0, 1168.0], [774.0, 1312.0], [748.0, 1312.0]]], "lines": ["このキャンプ場いいなぁ", "どこだろ？"]}, {"box": [637, 1170, 678, 1507], "vertical": true, "font_size": 39, "lines_coords": [[[637.0, 1170.0], [676.0, 1170.0], [676.0, 1507.0], [637.0, 1507.0]]], "lines": ["焚き火動画なんかも"]}, {"box": [150, 1170, 240, 1661], "vertical": true, "font_size": 40, "lines_coords": [[[198.0, 1170.0], [236.0, 1170.0], [236.0, 1436.0], [198.0, 1436.0]], [[150.0, 1170.0], [193.0, 1170.0], [193.0, 1661.0], [150.0, 1661.0]]], "lines": ["実際に焚き火を", "しているみたいで癒やされる"]}], "img_path": "00177.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1119, 127, 1200, 663], "vertical": true, "font_size": 38, "lines_coords": [[[1155.0, 127.0], [1198.0, 127.0], [1198.0, 633.0], [1155.0, 633.0]], [[1119.0, 131.0], [1151.0, 131.0], [1151.0, 663.0], [1119.0, 663.0]]], "lines": ["バイクに乗るようになってからは", "ツーリング動画も見るようになった"]}, {"box": [1082, 706, 1183, 1044], "vertical": true, "font_size": 30, "lines_coords": [[[1149.0, 706.0], [1181.0, 706.0], [1181.0, 1044.0], [1149.0, 1044.0]], [[1113.0, 708.0], [1145.0, 708.0], [1145.0, 991.0], [1113.0, 991.0]], [[1083.0, 710.0], [1108.0, 710.0], [1108.0, 961.0], [1083.0, 961.0]]], "lines": ["ＢＧＭがエンジン音だけの", "疑似ツーリング動画が", "特にいいんだよな．．．"]}, {"box": [256, 755, 321, 950], "vertical": true, "font_size": 26, "lines_coords": [[[290.0, 755.0], [316.0, 755.0], [316.0, 924.0], [290.0, 924.0]], [[256.0, 757.0], [283.0, 757.0], [283.0, 950.0], [256.0, 950.0]]], "lines": ["この音が妙に", "まったりする．．．"]}, {"box": [1123, 1117, 1200, 1466], "vertical": true, "font_size": 75, "lines_coords": [[[1123.0, 1121.0], [1198.0, 1121.0], [1198.0, 1284.0], [1123.0, 1284.0]]], "lines": ["パア！"]}, {"box": [954, 1117, 1042, 1295], "vertical": true, "font_size": 77, "lines_coords": [[[954.0, 1123.0], [1031.0, 1117.0], [1042.0, 1290.0], [965.0, 1295.0]]], "lines": ["パァ！"]}, {"box": [798, 1124, 868, 1503], "vertical": true, "font_size": 70, "lines_coords": [[[798.0, 1126.0], [868.0, 1126.0], [868.0, 1284.0], [798.0, 1284.0]]], "lines": ["パァー"]}, {"box": [644, 1122, 707, 1375], "vertical": true, "font_size": 27, "lines_coords": [[[678.0, 1123.0], [706.0, 1123.0], [703.0, 1235.0], [675.0, 1235.0]], [[645.0, 1123.0], [671.0, 1123.0], [671.0, 1374.0], [645.0, 1374.0]]], "lines": ["次の動画", "マン島バイクレース"]}, {"box": [300, 1134, 547, 1194], "vertical": false, "font_size": 60, "lines_coords": [[[300.0, 1134.0], [547.0, 1134.0], [547.0, 1194.0], [300.0, 1194.0]]], "lines": ["パァーン"]}, {"box": [121, 1207, 208, 1475], "vertical": true, "font_size": 79, "lines_coords": [[[129.0, 1207.0], [208.0, 1209.0], [200.0, 1475.0], [121.0, 1473.0]]], "lines": ["パアーン"]}, {"box": [135, 1522, 225, 1768], "vertical": true, "font_size": 40, "lines_coords": [[[185.0, 1524.0], [225.0, 1524.0], [221.0, 1768.0], [181.0, 1768.0]], [[138.0, 1522.0], [178.0, 1522.0], [174.0, 1753.0], [135.0, 1753.0]]], "lines": ["し心臓に悪い", "関連動画だ．．．"]}], "img_path": "00178.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [114, 96, 567, 167], "vertical": false, "font_size": 25, "lines_coords": [[[116.0, 101.0], [564.0, 101.0], [564.0, 125.0], [116.0, 125.0]], [[118.0, 138.0], [517.0, 140.0], [517.0, 166.0], [118.0, 165.0]]], "lines": ["ゆるキャン△＠いかがでしたでしょうか", "今回は桜巡り前編を収録致しました。"]}, {"box": [106, 386, 266, 405], "vertical": false, "font_size": 19, "lines_coords": [[[106.0, 386.0], [266.0, 386.0], [266.0, 405.0], [106.0, 405.0]]], "lines": ["あｆろでした。"]}, {"box": [116, 223, 879, 328], "vertical": false, "font_size": 24.333333333333332, "lines_coords": [[[116.0, 223.0], [879.0, 223.0], [879.0, 247.0], [116.0, 247.0]], [[118.0, 262.0], [718.0, 262.0], [718.0, 286.0], [118.0, 286.0]], [[118.0, 303.0], [667.0, 303.0], [667.0, 328.0], [118.0, 328.0]]], "lines": ["作中では触れていませんが山梨では有名な桃の花、梅の花スポットも", "ありますので桜巡りと合わせてぜひ回ってみて下さい。", "私は未だにどっちがどっちか見分けが付きません。"]}, {"box": [116, 1687, 211, 1713], "vertical": false, "font_size": 26, "lines_coords": [[[116.0, 1687.0], [211.0, 1687.0], [211.0, 1713.0], [116.0, 1713.0]]], "lines": ["初出一覧"]}, {"box": [95, 1703, 887, 1816], "vertical": false, "font_size": 27, "lines_coords": [[[120.0, 1713.0], [883.0, 1713.0], [883.0, 1743.0], [120.0, 1743.0]], [[118.0, 1747.0], [228.0, 1747.0], [228.0, 1772.0], [118.0, 1772.0]], [[110.0, 1769.0], [438.0, 1771.0], [438.0, 1802.0], [110.0, 1800.0]]], "lines": ["・Ｃｏｒｄ．．．ＣＯＭＯＦＵＺ、それ２０１５－今回２年９月、金利８年４月令和８年１０月掲載分", "・描き下ろし", "一部さらし本屋は以上の内容を吸収致しました。"]}], "img_path": "00179.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [391, 795, 609, 901], "vertical": false, "font_size": 39.5, "lines_coords": [[[391.0, 798.0], [609.0, 795.0], [609.0, 834.0], [391.0, 838.0]], [[393.0, 862.0], [519.0, 862.0], [519.0, 901.0], [393.0, 901.0]]], "lines": ["著者：あｆろ", "©ａｆｒｏ"]}, {"box": [393, 620, 950, 673], "vertical": false, "font_size": 50.0, "lines_coords": [[[761.0, 622.0], [950.0, 622.0], [950.0, 669.0], [761.0, 669.0]], [[393.0, 620.0], [780.0, 620.0], [780.0, 673.0], [393.0, 673.0]]], "lines": ["第１３巻", "ゆるキャン△第"]}, {"box": [393, 978, 963, 1228], "vertical": false, "font_size": 37, "lines_coords": [[[393.0, 991.0], [952.0, 990.0], [952.0, 1029.0], [393.0, 1031.0]], [[395.0, 1059.0], [691.0, 1059.0], [691.0, 1096.0], [395.0, 1096.0]], [[395.0, 1123.0], [798.0, 1126.0], [798.0, 1158.0], [395.0, 1155.0]], [[541.0, 1188.0], [948.0, 1188.0], [948.0, 1226.0], [541.0, 1226.0]]], "lines": ["電子版発行日：２０２２年４月１５日", "発行人・東・敬彰", "発行所：株式会社芳文社", "東京都文京区後楽１－２－１２"]}], "img_path": "00180.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [90, 937, 128, 958], "vertical": false, "font_size": 23, "lines_coords": [[[91.0, 935.0], [125.0, 935.0], [125.0, 960.0], [91.0, 960.0]]], "lines": ["あｆ３"]}, {"box": [266, 671, 582, 776], "vertical": false, "font_size": 111, "lines_coords": [[[268.0, 661.0], [560.0, 665.0], [558.0, 786.0], [266.0, 782.0]]], "lines": ["ゆらホン"]}, {"box": [658, 821, 690, 1215], "vertical": true, "font_size": 32, "lines_coords": [[[658.0, 821.0], [690.0, 821.0], [690.0, 1215.0], [658.0, 1215.0]]], "lines": ["ゆぅキァメミローァぅ"]}], "img_path": "00181.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1243, 581, 1272, 747], "vertical": true, "font_size": 20, "lines_coords": [[[1243.0, 583.0], [1263.0, 583.0], [1263.0, 669.0], [1243.0, 669.0]]], "lines": ["四人兄弟の長男な"]}, {"box": [1103, 591, 1115, 622], "vertical": true, "font_size": 12, "lines_coords": [[[1103.0, 591.0], [1115.0, 591.0], [1115.0, 622.0], [1103.0, 622.0]]], "lines": ["せやで"]}, {"box": [1241, 776, 1269, 945], "vertical": true, "font_size": 24, "lines_coords": [[[1245.0, 776.0], [1269.0, 776.0], [1265.0, 945.0], [1241.0, 945.0]]], "lines": ["元々は高山の家系で山梨は来たのはひいおじいちゃんの代からなんだね"]}, {"box": [1046, 621, 1081, 732], "vertical": true, "font_size": 35, "lines_coords": [[[1046.0, 621.0], [1081.0, 621.0], [1081.0, 732.0], [1046.0, 732.0]]], "lines": ["顔写真付き家系図ってタ方のニュースとかで見るやつじゃねぇか"]}, {"box": [969, 588, 1006, 743], "vertical": true, "font_size": 20, "lines_coords": [[[986.0, 590.0], [1006.0, 590.0], [1006.0, 641.0], [986.0, 641.0]]], "lines": ["高山の春子行ってもう"]}, {"box": [1047, 782, 1072, 859], "vertical": true, "font_size": 25, "lines_coords": [[[1047.0, 782.0], [1072.0, 782.0], [1072.0, 859.0], [1047.0, 859.0]]], "lines": ["ん？何か変だぞここ"]}, {"box": [975, 783, 998, 915], "vertical": true, "font_size": 23, "lines_coords": [[[975.0, 783.0], [998.0, 783.0], [998.0, 915.0], [975.0, 915.0]]], "lines": ["見てあきちゃんベットも家系図に入ってるよ"]}, {"box": [781, 586, 808, 664], "vertical": true, "font_size": 27, "lines_coords": [[[781.0, 586.0], [808.0, 586.0], [808.0, 664.0], [781.0, 664.0]]], "lines": ["作品ジャンルの話じゃねぇよ"]}, {"box": [648, 511, 700, 555], "vertical": false, "font_size": 44, "lines_coords": [[[648.0, 511.0], [700.0, 511.0], [700.0, 555.0], [648.0, 555.0]]], "lines": ["ん？"]}, {"box": [853, 908, 927, 924], "vertical": false, "font_size": 16, "lines_coords": [[[853.0, 908.0], [927.0, 908.0], [927.0, 924.0], [853.0, 924.0]]], "lines": ["けんたろう"]}, {"box": [784, 827, 798, 906], "vertical": true, "font_size": 14, "lines_coords": [[[784.0, 827.0], [798.0, 827.0], [798.0, 906.0], [784.0, 906.0]]], "lines": ["むほんとうだ"]}, {"box": [641, 608, 702, 990], "vertical": true, "font_size": 56, "lines_coords": [[[645.0, 609.0], [701.0, 609.0], [697.0, 990.0], [641.0, 990.0]]], "lines": ["ゆるチャン△："]}, {"box": [313, 670, 562, 770], "vertical": false, "font_size": 100, "lines_coords": [[[313.0, 670.0], [562.0, 670.0], [562.0, 770.0], [313.0, 770.0]]], "lines": ["．．．ふふふ"]}, {"box": [260, 579, 287, 713], "vertical": true, "font_size": 27, "lines_coords": [[[260.0, 579.0], [287.0, 579.0], [287.0, 713.0], [260.0, 713.0]]], "lines": ["ほおぉこれがあおいちゃんの自転車かぁ"]}, {"box": [264, 780, 285, 932], "vertical": true, "font_size": 21, "lines_coords": [[[264.0, 780.0], [285.0, 780.0], [285.0, 932.0], [264.0, 932.0]]], "lines": ["私よく人から被責ったり懸賞当たったけどかするんよねぇ"]}, {"box": [66, 632, 89, 746], "vertical": true, "font_size": 23, "lines_coords": [[[66.0, 632.0], [89.0, 632.0], [89.0, 746.0], [66.0, 746.0]]], "lines": ["こんなすごいの貰ったなんていいなぁ"]}, {"box": [103, 841, 123, 920], "vertical": true, "font_size": 22, "lines_coords": [[[105.0, 841.0], [123.0, 841.0], [121.0, 920.0], [103.0, 920.0]]], "lines": ["言われてみれば"]}, {"box": [52, 795, 82, 930], "vertical": true, "font_size": 22, "lines_coords": [[[52.0, 795.0], [78.0, 795.0], [82.0, 930.0], [56.0, 930.0]]], "lines": ["お肉とかそうだったよね。"]}, {"box": [1245, 970, 1270, 1134], "vertical": true, "font_size": 25, "lines_coords": [[[1245.0, 970.0], [1270.0, 970.0], [1270.0, 1134.0], [1245.0, 1134.0]]], "lines": ["あぁーこれは常団時代にタイムスリップした京田郎おじさん。"]}, {"box": [1243, 1171, 1269, 1265], "vertical": true, "font_size": 26, "lines_coords": [[[1243.0, 1171.0], [1269.0, 1171.0], [1269.0, 1265.0], [1243.0, 1265.0]]], "lines": ["岐阜で犬山一族を興したところやな"]}, {"box": [1083, 1168, 1195, 1194], "vertical": false, "font_size": 26, "lines_coords": [[[1083.0, 1168.0], [1194.0, 1168.0], [1194.0, 1194.0], [1083.0, 1194.0]]], "lines": ["犬山家系団"]}, {"box": [982, 981, 994, 1071], "vertical": true, "font_size": 12, "lines_coords": [[[982.0, 981.0], [994.0, 981.0], [994.0, 1071.0], [982.0, 1071.0]]], "lines": ["けんたろうが．．．"]}, {"box": [1053, 1207, 1070, 1312], "vertical": true, "font_size": 17, "lines_coords": [[[1053.0, 1207.0], [1070.0, 1207.0], [1070.0, 1312.0], [1053.0, 1312.0]]], "lines": ["何だこのＳＦ家系図"]}, {"box": [780, 1018, 810, 1133], "vertical": true, "font_size": 26, "lines_coords": [[[780.0, 1018.0], [806.0, 1018.0], [810.0, 1115.0], [783.0, 1115.0]]], "lines": ["高山ラーメンとくっついて．．．？"]}, {"box": [659, 939, 687, 1042], "vertical": true, "font_size": 28, "lines_coords": [[[659.0, 939.0], [687.0, 939.0], [687.0, 1042.0], [659.0, 1042.0]]], "lines": ["ｉｎｇｈｓｏｈｏｏｌｄｉｎｓｐｏＶｕｒｃｏｏｍｐｉｎｎｏｔｕｒｅ"]}, {"box": [859, 1303, 933, 1319], "vertical": false, "font_size": 16, "lines_coords": [[[859.0, 1303.0], [933.0, 1303.0], [933.0, 1319.0], [859.0, 1319.0]]], "lines": ["めんたろう"]}, {"box": [788, 1187, 802, 1304], "vertical": true, "font_size": 14, "lines_coords": [[[788.0, 1187.0], [802.0, 1187.0], [802.0, 1304.0], [788.0, 1304.0]]], "lines": ["ゆるキャラじゃねぇか。"]}, {"box": [658, 1155, 692, 1186], "vertical": false, "font_size": 31, "lines_coords": [[[658.0, 1155.0], [692.0, 1155.0], [692.0, 1186.0], [658.0, 1186.0]]], "lines": ["１３"]}, {"box": [646, 1149, 695, 1396], "vertical": true, "font_size": 45, "lines_coords": [[[650.0, 1149.0], [695.0, 1149.0], [691.0, 1396.0], [646.0, 1396.0]]], "lines": ["１８．３あｆ３＊"]}, {"box": [260, 972, 286, 1085], "vertical": true, "font_size": 26, "lines_coords": [[[260.0, 972.0], [286.0, 972.0], [286.0, 1085.0], [260.0, 1085.0]]], "lines": ["自転車くれたおばさんって高山の？"]}, {"box": [261, 1169, 284, 1308], "vertical": true, "font_size": 23, "lines_coords": [[[261.0, 1169.0], [284.0, 1169.0], [284.0, 1308.0], [261.0, 1308.0]]], "lines": ["せや犬山一族の家系図たまたま持っとったから見る？"]}, {"box": [65, 1018, 90, 1134], "vertical": true, "font_size": 25, "lines_coords": [[[65.0, 1018.0], [90.0, 1018.0], [90.0, 1134.0], [65.0, 1134.0]]], "lines": ["うんうちのお父さんの年の離れたいとこやね"]}, {"box": [66, 1170, 130, 1314], "vertical": true, "font_size": 64, "lines_coords": [[[66.0, 1170.0], [130.0, 1170.0], [130.0, 1314.0], [66.0, 1314.0]]], "lines": ["おっ見る見るたまたま持ってるもんじゃねえぞそれ"]}], "img_path": "00182.jpg"}, {"version": "0.1.6", "img_width": 1351, "img_height": 1920, "blocks": [{"box": [69, 0, 1238, 380], "vertical": false, "font_size": 364, "lines_coords": [[[69.0, 15.0], [1232.0, 0.0], [1238.0, 363.0], [74.0, 380.0]]], "lines": ["ゆるみにＪ＾"]}, {"box": [1029, 314, 1295, 367], "vertical": false, "font_size": 37, "lines_coords": [[[1038.0, 313.0], [1277.0, 317.0], [1277.0, 357.0], [1038.0, 353.0]]], "lines": ["平穏な話によります。"]}, {"box": [1054, 407, 1289, 516], "vertical": false, "font_size": 119, "lines_coords": [[[1054.0, 397.0], [1289.0, 397.0], [1289.0, 526.0], [1054.0, 526.0]]], "lines": ["あ４３／"]}, {"box": [114, 769, 355, 892], "vertical": false, "font_size": 26, "lines_coords": [[[161.0, 774.0], [189.0, 774.0], [189.0, 798.0], [161.0, 798.0]], [[217.0, 774.0], [264.0, 774.0], [264.0, 795.0], [217.0, 795.0]], [[121.0, 815.0], [341.0, 802.0], [342.0, 832.0], [123.0, 845.0]], [[125.0, 856.0], [341.0, 843.0], [342.0, 873.0], [127.0, 886.0]]], "lines": ["東", "そういえば、", "遺農域", "フルーツライン"]}, {"box": [144, 907, 312, 943], "vertical": false, "font_size": 27, "lines_coords": [[[144.0, 916.0], [311.0, 907.0], [312.0, 933.0], [146.0, 943.0]]], "lines": ["市梨梨山"]}, {"box": [1058, 502, 1270, 540], "vertical": false, "font_size": 29, "lines_coords": [[[1066.0, 511.0], [1260.0, 500.0], [1261.0