"lines": ["だって思いっ切り", "書いてあるし"]}, {"box": [320, 315, 376, 690], "vertical": true, "font_size": 25, "lines_coords": [[[348.0, 315.0], [375.0, 315.0], [376.0, 577.0], [350.0, 577.0]], [[320.0, 316.0], [345.0, 316.0], [345.0, 690.0], [320.0, 690.0]]], "lines": ["神奈川東京にほど近い", "上野原に作られたベッドタウンで"]}, {"box": [166, 579, 237, 736], "vertical": true, "font_size": 32, "lines_coords": [[[166.0, 579.0], [198.0, 579.0], [198.0, 736.0], [166.0, 736.0]]], "lines": ["忍びの里？"]}, {"box": [1134, 873, 1206, 1310], "vertical": true, "font_size": 32, "lines_coords": [[[1171.0, 873.0], [1203.0, 873.0], [1203.0, 1216.0], [1171.0, 1216.0]], [[1134.0, 875.0], [1166.0, 875.0], [1166.0, 1310.0], [1134.0, 1310.0]]], "lines": ["けど戦乱の時代が終わり", "この土地を離れる事になった時"]}, {"box": [302, 856, 413, 1342], "vertical": true, "font_size": 30, "lines_coords": [[[378.0, 858.0], [410.0, 858.0], [410.0, 1263.0], [378.0, 1263.0]], [[339.0, 856.0], [371.0, 856.0], [371.0, 1342.0], [339.0, 1342.0]], [[303.0, 858.0], [330.0, 858.0], [330.0, 1201.0], [303.0, 1201.0]]], "lines": ["ここが一族の故郷だったのを", "忘れんよう山を犬の形に切り招き", "残すことにしたそうや．．．"]}, {"box": [151, 986, 228, 1295], "vertical": true, "font_size": 34, "lines_coords": [[[191.0, 986.0], [228.0, 986.0], [228.0, 1278.0], [191.0, 1278.0]], [[153.0, 988.0], [185.0, 988.0], [185.0, 1295.0], [153.0, 1295.0]]], "lines": ["い言われてみると", "犬っぽい形してる．．．"]}, {"box": [1136, 1432, 1195, 1760], "vertical": true, "font_size": 24, "lines_coords": [[[1170.0, 1434.0], [1194.0, 1434.0], [1194.0, 1760.0], [1170.0, 1760.0]], [[1140.0, 1432.0], [1164.0, 1432.0], [1160.0, 1610.0], [1136.0, 1610.0]]], "lines": ["その拓かれた土地にそのまま", "住宅が建てられ"]}, {"box": [628, 1436, 690, 1741], "vertical": true, "font_size": 26, "lines_coords": [[[661.0, 1438.0], [688.0, 1438.0], [688.0, 1713.0], [661.0, 1713.0]], [[628.0, 1436.0], [654.0, 1436.0], [654.0, 1741.0], [628.0, 1741.0]]], "lines": ["四方津ニュータウンが", "出来たって訳なんやなぁ"]}, {"box": [399, 1813, 540, 1833], "vertical": false, "font_size": 20, "lines_coords": [[[399.0, 1813.0], [540.0, 1813.0], [540.0, 1833.0], [399.0, 1833.0]]], "lines": ["バー下参照"]}, {"box": [332, 1474, 355, 1547], "vertical": true, "font_size": 23, "lines_coords": [[[332.0, 1474.0], [355.0, 1474.0], [355.0, 1547.0], [332.0, 1547.0]]], "lines": ["．．．．．"]}, {"box": [123, 1811, 350, 1835], "vertical": false, "font_size": 24, "lines_coords": [[[123.0, 1811.0], [350.0, 1811.0], [350.0, 1835.0], [123.0, 1835.0]]], "lines": ["Ｘゆるキャン△０"]}], "img_path": "00171.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1124, 148, 1188, 484], "vertical": true, "font_size": 26, "lines_coords": [[[1158.0, 148.0], [1185.0, 148.0], [1185.0, 481.0], [1158.0, 481.0]], [[1125.0, 150.0], [1151.0, 150.0], [1151.0, 483.0], [1125.0, 483.0]]], "lines": ["あおいちゃんってこういう", "嘘をいつ考えてるのかな？"]}, {"box": [858, 285, 892, 399], "vertical": true, "font_size": 34, "lines_coords": [[[858.0, 286.0], [892.0, 286.0], [892.0, 399.0], [858.0, 399.0]]], "lines": ["うーん"]}, {"box": [571, 174, 646, 504], "vertical": true, "font_size": 30, "lines_coords": [[[616.0, 178.0], [643.0, 178.0], [643.0, 502.0], [616.0, 502.0]], [[577.0, 174.0], [609.0, 174.0], [603.0, 356.0], [571.0, 356.0]]], "lines": ["ホラ話は意外性があって", "真実味のある"]}, {"box": [138, 421, 206, 718], "vertical": true, "font_size": 26, "lines_coords": [[[174.0, 423.0], [200.0, 423.0], [200.0, 718.0], [174.0, 718.0]], [[138.0, 421.0], [165.0, 421.0], [165.0, 690.0], [138.0, 690.0]]], "lines": ["みんなが楽しめるもの", "を心がける．．．そんで"]}, {"box": [1033, 855, 1117, 1237], "vertical": true, "font_size": 38, "lines_coords": [[[1078.0, 855.0], [1117.0, 855.0], [1115.0, 1237.0], [1076.0, 1237.0]], [[1036.0, 855.0], [1074.0, 855.0], [1070.0, 1100.0], [1033.0, 1100.0]]], "lines": ["騙されても誰も傷つかん", "話にせんとな．．"]}, {"box": [1085, 1380, 1183, 1779], "vertical": true, "font_size": 27, "lines_coords": [[[1151.0, 1380.0], [1183.0, 1380.0], [1183.0, 1755.0], [1151.0, 1755.0]], [[1121.0, 1381.0], [1145.0, 1381.0], [1145.0, 1779.0], [1121.0, 1779.0]], [[1087.0, 1380.0], [1113.0, 1380.0], [1111.0, 1623.0], [1085.0, 1623.0]]], "lines": ["大子が夜な夜なネタ帳に真剣に", "考えたホラ話を書き溜めてるかと", "思うと泣けてくる．．．"]}, {"box": [328, 1430, 435, 1711], "vertical": true, "font_size": 31, "lines_coords": [[[403.0, 1430.0], [435.0, 1430.0], [435.0, 1711.0], [403.0, 1711.0]], [[361.0, 1430.0], [395.0, 1430.0], [395.0, 1556.0], [361.0, 1556.0]], [[328.0, 1430.0], [354.0, 1430.0], [354.0, 1710.0], [328.0, 1710.0]]], "lines": ["ちゃんと騙されよ！！", "今度から", "ちゃんと騙されよ！！"]}, {"box": [181, 1449, 207, 1490], "vertical": true, "font_size": 26, "lines_coords": [[[181.0, 1449.0], [207.0, 1449.0], [207.0, 1490.0], [181.0, 1490.0]]], "lines": ["？"]}], "img_path": "00172.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1119, 207, 1189, 518], "vertical": true, "font_size": 32, "lines_coords": [[[1156.0, 208.0], [1188.0, 208.0], [1188.0, 517.0], [1156.0, 517.0]], [[1119.0, 208.0], [1151.0, 208.0], [1151.0, 397.0], [1119.0, 397.0]]], "lines": ["前から思ってたんだが", "「傘」って漢字"]}, {"box": [523, 233, 985, 413], "vertical": false, "font_size": 180, "lines_coords": [[[523.0, 233.0], [985.0, 233.0], [985.0, 413.0], [523.0, 413.0]]], "lines": ["２０１４年"]}, {"box": [313, 75, 635, 105], "vertical": false, "font_size": 26, "lines_coords": [[[313.0, 75.0], [635.0, 78.0], [635.0, 105.0], [313.0, 101.0]]], "lines": ["アウトドア創作漢字"]}, {"box": [121, 80, 260, 101], "vertical": false, "font_size": 21, "lines_coords": [[[121.0, 80.0], [260.0, 80.0], [260.0, 101.0], [121.0, 101.0]]], "lines": ["放課後１１"]}, {"box": [146, 146, 257, 457], "vertical": true, "font_size": 32, "lines_coords": [[[223.0, 148.0], [255.0, 148.0], [255.0, 412.0], [223.0, 412.0]], [[183.0, 148.0], [215.0, 148.0], [215.0, 427.0], [183.0, 427.0]], [[146.0, 146.0], [178.0, 146.0], [178.0, 457.0], [146.0, 457.0]]], "lines": ["ホントだ！四人で", "ワンポールテントに", "入ってるみたいだよね"]}, {"box": [1169, 840, 1199, 965], "vertical": true, "font_size": 26, "lines_coords": [[[1170.0, 841.0], [1196.0, 841.0], [1196.0, 963.0], [1170.0, 963.0]]], "lines": ["創作漢字"]}, {"box": [882, 818, 952, 891], "vertical": true, "font_size": 70, "lines_coords": [[[882.0, 818.0], [952.0, 818.0], [952.0, 891.0], [882.0, 891.0]]], "lines": ["まあ"]}, {"box": [350, 315, 421, 660], "vertical": true, "font_size": 29, "lines_coords": [[[388.0, 315.0], [418.0, 315.0], [421.0, 660.0], [391.0, 660.0]], [[352.0, 315.0], [380.0, 315.0], [378.0, 502.0], [350.0, 502.0]]], "lines": ["こう弄るとテントっぽく", "見えないか？"]}, {"box": [151, 564, 228, 691], "vertical": true, "font_size": 34, "lines_coords": [[[195.0, 566.0], [226.0, 566.0], [226.0, 691.0], [195.0, 691.0]], [[151.0, 564.0], [189.0, 564.0], [189.0, 633.0], [151.0, 633.0]]], "lines": ["創作漢字", "やな"]}, {"box": [1050, 845, 1130, 1153], "vertical": true, "font_size": 32, "lines_coords": [[[1095.0, 845.0], [1126.0, 845.0], [1126.0, 1119.0], [1095.0, 1119.0]], [[1051.0, 845.0], [1083.0, 845.0], [1083.0, 1153.0], [1051.0, 1153.0]]], "lines": ["既存の漢字にない", "新しく作られた漢字"]}, {"box": [922, 959, 985, 1181], "vertical": true, "font_size": 27, "lines_coords": [[[956.0, 961.0], [984.0, 961.0], [982.0, 1181.0], [954.0, 1181.0]], [[922.0, 960.0], [948.0, 960.0], [948.0, 1126.0], [922.0, 1126.0]]], "lines": ["へぇーこんなのが", "あるんだねぇ"]}, {"box": [1089, 1260, 1209, 1500], "vertical": true, "font_size": 36, "lines_coords": [[[1171.0, 1260.0], [1209.0, 1260.0], [1209.0, 1498.0], [1171.0, 1498.0]], [[1128.0, 1260.0], [1166.0, 1260.0], [1166.0, 1500.0], [1128.0, 1500.0]], [[1089.0, 1260.0], [1121.0, 1260.0], [1121.0, 1393.0], [1089.0, 1393.0]]], "lines": ["タープつきとか", "ソロテントなら", "こうか？"]}, {"box": [491, 1404, 742, 1455], "vertical": false, "font_size": 51, "lines_coords": [[[491.0, 1404.0], [742.0, 1404.0], [742.0, 1455.0], [491.0, 1455.0]]], "lines": ["【ソロテント】"]}, {"box": [166, 827, 228, 1134], "vertical": true, "font_size": 27, "lines_coords": [[[198.0, 830.0], [225.0, 830.0], [225.0, 1134.0], [198.0, 1134.0]], [[166.0, 830.0], [193.0, 830.0], [193.0, 1051.0], [166.0, 1051.0]]], "lines": ["毎年コンテストなんかも", "やっとるらしいで"]}, {"box": [176, 1248, 247, 1