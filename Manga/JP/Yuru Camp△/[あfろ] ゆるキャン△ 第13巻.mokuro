.0]], [[1108.0, 191.0], [1134.0, 191.0], [1134.0, 465.0], [1108.0, 465.0]]], "lines": ["まず薄味スープで", "素材の味を楽しんで"]}, {"box": [965, 131, 1046, 236], "vertical": true, "font_size": 75, "lines_coords": [[[971.0, 131.0], [1046.0, 131.0], [1046.0, 236.0], [971.0, 236.0]]], "lines": ["まず"]}, {"box": [185, 161, 249, 495], "vertical": true, "font_size": 27, "lines_coords": [[[217.0, 161.0], [245.0, 161.0], [247.0, 444.0], [219.0, 444.0]], [[185.0, 163.0], [211.0, 163.0], [211.0, 495.0], [185.0, 495.0]]], "lines": ["具材のうま味が出たら", "スープを濃い味にチェンジ"]}, {"box": [1100, 611, 1168, 973], "vertical": true, "font_size": 29, "lines_coords": [[[1140.0, 613.0], [1166.0, 613.0], [1166.0, 973.0], [1140.0, 973.0]], [[1100.0, 611.0], [1132.0, 611.0], [1132.0, 920.0], [1100.0, 920.0]]], "lines": ["次は玉子とかチーズみたいに", "クリーミーな味付けとか"]}, {"box": [183, 624, 247, 904], "vertical": true, "font_size": 26, "lines_coords": [[[217.0, 624.0], [243.0, 624.0], [243.0, 873.0], [217.0, 873.0]], [[183.0, 626.0], [208.0, 626.0], [208.0, 903.0], [183.0, 903.0]]], "lines": ["辛味調味料を入れて", "幸口にしてもいいかも"]}, {"box": [1127, 1072, 1197, 1455], "vertical": true, "font_size": 26, "lines_coords": [[[1164.0, 1072.0], [1190.0, 1072.0], [1190.0, 1455.0], [1164.0, 1455.0]], [[1128.0, 1074.0], [1155.0, 1074.0], [1155.0, 1443.0], [1128.0, 1443.0]]], "lines": ["その後はこはん麺類でしめ", "お鍋だとこんな感じかなぁ"]}, {"box": [899, 1076, 969, 1293], "vertical": true, "font_size": 29, "lines_coords": [[[935.0, 1076.0], [967.0, 1076.0], [967.0, 1293.0], [935.0, 1293.0]], [[900.0, 1078.0], [926.0, 1078.0], [926.0, 1261.0], [900.0, 1261.0]]], "lines": ["今のレシピやと", "４段変身やな"]}, {"box": [731, 1042, 820, 1417], "vertical": true, "font_size": 42, "lines_coords": [[[778.0, 1044.0], [817.0, 1044.0], [819.0, 1415.0], [780.0, 1415.0]], [[731.0, 1042.0], [776.0, 1042.0], [776.0, 1350.0], [731.0, 1350.0]]], "lines": ["何度も回度も変身して", "なかなか倒せない"]}, {"box": [245, 1045, 664, 1087], "vertical": false, "font_size": 32, "lines_coords": [[[255.0, 1051.0], [663.0, 1051.0], [663.0, 1083.0],