 1179.0], [1040.0, 1179.0]], [[1008.0, 1051.0], [1033.0, 1051.0], [1033.0, 1241.0], [1008.0, 1241.0]]], "lines": ["それ僕らが", "持って帰ろうか？"]}, {"box": [1096, 1333, 1181, 1539], "vertical": true, "font_size": 40, "lines_coords": [[[1138.0, 1335.0], [1177.0, 1335.0], [1181.0, 1539.0], [1141.0, 1539.0]], [[1096.0, 1333.0], [1136.0, 1333.0], [1136.0, 1440.0], [1096.0, 1440.0]]], "lines": ["いいのぃいの", "車だし"]}, {"box": [255, 975, 316, 1151], "vertical": true, "font_size": 30, "lines_coords": [[[283.0, 975.0], [316.0, 975.0], [316.0, 1008.0], [283.0, 1008.0]], [[255.0, 978.0], [281.0, 978.0], [281.0, 1151.0], [255.0, 1151.0]]], "lines": ["え", "いいんですか？"]}, {"box": [249, 1408, 319, 1748], "vertical": true, "font_size": 29, "lines_coords": [[[290.0, 1408.0], [316.0, 1408.0], [316.0, 1747.0], [290.0, 1747.0]], [[249.0, 1408.0], [281.0, 1408.0], [281.0, 1627.0], [249.0, 1627.0]]], "lines": ["どうせ私らもキャンプで", "ゴミ出るんだし"]}], "img_path": "00017.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1096, 176, 1204, 425], "vertical": true, "font_size": 30, "lines_coords": [[[1171.0, 178.0], [1203.0, 178.0], [1203.0, 393.0], [1171.0, 393.0]], [[1132.0, 176.0], [1164.0, 176.0], [1164.0, 425.0], [1132.0, 425.0]], [[1096.0, 178.0], [1123.0, 178.0], [1123.0, 331.0], [1096.0, 331.0]]], "lines": ["管理人もいない", "無料のキャンプ場", "なんだから"]}, {"box": [138, 198, 272, 508], "vertical": true, "font_size": 26, "lines_coords": [[[243.0, 202.0], [270.0, 202.0], [270.0, 508.0], [243.0, 508.0]], [[210.0, 200.0], [236.0, 200.0], [236.0, 508.0], [210.0, 508.0]], [[174.0, 200.0], [200.0, 200.0], [200.0, 395.0], [174.0, 395.0]], [[138.0, 198.0], [163.0, 198.0], [163.0, 423.0], [138.0, 423.0]]], "lines": ["ゴミなんか放置してたら", "そのうち閉鎖されるのは", "目に見えてると", "思うんだけどなぁ"]}, {"box": [1108, 626, 1202, 943], "vertical": true, "font_size": 28, "lines_coords": [[[1175.0, 630.0], [1200.0, 630.0], [1200.0, 943.0], [1175.0, 943.0]], [[1141.0, 630.0], [1168.0, 630.0], [1168.0, 916.0], [1141.0, 916.0]], [[1108.0, 626.0], [1140.0, 626.0], [1140.0, 736.0], [1108.0, 736.0]]], "lines": ["初心者がキャンプ始める時", "周りにキャンプ経験者が", "居ないと"]}, {"box": [564, 596, 624, 806], "vertical": true, "font_size": 24, "lines_coords": [[[598.0, 598.0], [624.0, 598.0], [624.0, 806.0], [598.0, 806.0]], [[564.0, 596.0], [590.0, 596.0], [590.0, 729.0], [564.0, 729.0]]], "lines": ["意外と分かんない", "ものかもね"]}, {"box": [540, 682, 562, 804], "vertical": true, "font_size": 24, "lines_coords": [[[540.0, 682.0], [560.0, 682.0], [562.0, 804.0], [541.0, 804.0]]], "lines": ["消し欲の処分とか"]}, {"box": [1089, 1243, 1176, 1545], "vertical": true, "font_size": 25, "lines_coords": [[[1151.0, 1243.0], [1175.0, 1243.0], [1175.0, 1520.0], [1151.0, 1520.0]], [[1119.0, 1245.0], [1145.0, 1245.0], [1145.0, 1545.0], [1119.0, 1545.0]], [[1089.0, 1245.0], [1113.0, 1245.0], [1113.0, 1518.0], [1089.0, 1518.0]]], "lines": ["偉そうな事言ってるけど", "僕らも始めて一年の初心者", "キャンバーなんだけどね"]}, {"box": [521, 1260, 586, 1374], "vertical": true, "font_size": 32, "lines_coords": [[[555.0, 1260.0], [586.0, 1260.0], [586.0, 1374.0], [555.0, 1374.0]], [[521.0, 1260.0], [555.0, 1260.0], [555.0, 1374.0], [521.0, 1374.0]]], "lines": ["そうなん", "ですか？"]}, {"box": [168, 971, 232, 1113], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 971.0], [232.0, 971.0], [232.0, 1089.0], [200.0, 1089.0]], [[170.0, 973.0], [191.0, 973.0], [191.0, 1111.0], [170.0, 1111.0]]], "lines": ["いやでも", "あれは酷い"]}, {"box": [258, 1374, 318, 1623], "vertical": true, "font_size": 28, "lines_coords": [[[292.0, 1374.0], [318.0, 1374.0], [316.0, 1623.0], [290.0, 1623.0]], [[260.0, 1374.0], [286.0, 1374.0], [285.0, 1601.0], [258.0, 1601.0]]], "lines": ["まぁ私らは知り合いに", "キャンプ好きが居て"]}, {"box": [151, 1483, 243, 1691], "vertical": true, "font_size": 28, "lines_coords": [[[208.0, 1483.0], [243.0, 1483.0], [243.0, 1548.0], [208.0, 1548.0]], [[180.0, 1492.0], [206.0, 1492.0], [206.0, 1670.0], [180.0, 1670.0]], [[151.0, 1494.0], [176.0, 1494.0], [176.0, 1691.0], [151.0, 1691.0]]], "lines": ["色々", "教えてもらえた", "から良かったけど"]}], "img_path": "00018.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1087, 174, 1146, 373], "vertical": true, "font_size": 25, "lines_coords": [[[1121.0, 176.0], [1145.0, 176.0], [1145.0, 373.0], [1121.0, 373.0]], [[1089.0, 174.0], [1115.0, 174.0], [1113.0, 350.0], [1087.0, 350.0]]], "lines": ["僕らはキャンプの", "片付けについて"]}, {"box": [318, 181, 418, 350], "vertical": true, "font_size": 28, "lines_coords": [[[386.0, 181.0], [418.0, 181.0], [418.0, 298.0], [386.0, 298.0]], [[352.0, 183.0], [378.0, 183.0], [378.0, 324.0], [352.0, 324.0]], [[318.0, 183.0], [345.0, 183.0], [345.0, 350.0], [318.0, 350.0]]], "lines": ["その人に", "ある格言を", "教えられてね"]}, {"box": [1103, 501, 1177, 1005], "vertical": true, "font_size": 34, "lines_coords": [[[1138.0, 502.0], [1175.0, 502.0], [1175.0, 894.0], [1138.0, 894.0]], [[1104.0, 504.0], [1136.0, 504.0], [1136.0, 1005.0], [1104.0, 1005.0]]], "lines": ["「撤収する時は痕跡を残すな", "殺し屋に追われていると思えて。"]}, {"box": [193, 618, 264, 963], "vertical": true, "font_size": 32, "lines_coords": [[[228.0, 618.0], [260.0, 618.0], [264.0, 873.0], [232.0, 873.0]], [[193.0, 622.0], [225.0, 622.0], [225.0, 963.0], [193.0, 963.0]]], "lines": ["殺し屋って．．．けど", "何だか分かりやすいです"]}, {"box": [672, 1160, 807, 1184], "vertical": false, "font_size": 24, "lines_coords": [[[672.0, 1160.0], [807.0, 1160.0], [807.0, 1184.0], [672.0, 1184.0]]], "lines": ["にがい．．．"]}, {"box": [595, 1364, 636, 1458], "vertical": true, "font_size": 41, "lines_coords": [[[595.0, 1364.0], [636.0, 1364.0], [636.0, 1458.0], [595.0, 1458.0]]], "lines": ["コーヒーづラック）"]}, {"box": [480, 1166, 537, 1453], "vertical": true, "font_size": 24, "lines_coords": [[[511.0, 1168.0], [536.0, 1168.0], [536.0, 1453.0], [511.0, 1453.0]], [[480.0, 1166.0], [504.0, 1166.0], [504.0, 1316.0], [480.0, 1316.0]]], "lines": ["あぁごめん苦かったかな", "砂糖もあるよ"]}, {"box": [161, 1535, 189, 1727], "vertical": true, "font_size": 26, "lines_coords": [[[161.0, 1535.0], [187.0, 1535.0], [187.0, 1726.0], [161.0, 1726.0]]], "lines": ["すすみません"]}], "img_path": "00019.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1125, 136, 1213, 487], "vertical": true, "font_size": 26, "lines_coords": [[[1186.0, 136.0], [1213.0, 136.0], [1213.0, 485.0], [1186.0, 485.0]], [[1155.0, 138.0], [1181.0, 138.0], [1181.0, 461.0], [1155.0, 461.0]], [[1125.0, 138.0], [1149.0, 138.0], [1149.0, 487.0], [1125.0, 487.0]]], "lines": ["苦いものを美味しく感じるのは", "年を取って舌が苦味に鈍感に", "なるからって聞いた事があるし、"]}, {"box": [304, 215, 341, 344], "vertical": true, "font_size": 37, "lines_coords": [[[304.0, 215.0], [341.0, 215.0], [341.0, 344.0], [304.0, 344.0]]], "lines": ["ぎばーっ"]}, {"box": [153, 285, 251, 590], "vertical": true, "font_size": 29, "lines_coords": [[[217.0, 285.0], [251.0, 285.0], [251.0, 401.0], [217.0, 401.0]], [[183.0, 285.0], [211.0, 285.0], [213.0, 590.0], [185.0, 590.0]], [[153.0, 286.0], [178.0, 286.0], [178.0, 483.0], [153.0, 483.0]]], "lines": ["あれっ！？", "小川さんブラック派じゃ", "なかったっけ！？"]}, {"box": [750, 442, 780, 692], "vertical": true, "font_size": 24, "lines_coords": [[[753.0, 442.0], [778.0, 442.0], [774.0, 691.0], [750.0, 691.0]]], "lines": ["若い証拠じゃないかな"]}, {"box": [586, 813, 646, 1100], "vertical": true, "font_size": 26, "lines_coords": [[[618.0, 813.0], [645.0, 813.0], [645.0, 1100.0], [618.0, 1100.0]], [[586.0, 815.0], [611.0, 815.0], [611.0, 1038.0], [586.0, 1038.0]]], "lines": ["そういえば私もキャンプ", "始めたばかりの頃に"]}, {"box": [131, 813, 197, 1237], "vertical": true, "font_size": 32, "lines_coords": [[[163.0, 813.0], [195.0, 813.0], [195.0, 1237.0], [163.0, 1237.0]], [[131.0, 815.0], [163.0, 815.0], [163.0, 1192.0], [131.0, 1192.0]]], "lines": ["「家から持って来た物は主部持ち帰れ", "ってお爺ちゃんに教えられたっけ"]}, {"box": [335, 1359, 393, 1635], "vertical": true, "font_size": 24, "lines_coords": [[[367.0, 1361.0], [391.0, 1361.0], [391.0, 1633.0], [367.0, 1633.0]], [[335.0, 1359.0], [360.0, 1359.0], [360.0, 1635.0], [335.0, 1635.0]]], "lines": ["そう考えるキャンバーが", "増えてくれたらいいよな"]}], "img_path": "00020.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1044, 176, 1114, 487], "vertical": true, "font_size": 32, "lines_coords": [[[1081.0, 178.0], [1113.0, 178.0], [1113.0, 395.0], [1081.0, 395.0]], [[1044.0, 176.0], [1076.0, 176.0], [1076.0, 487.0], [1044.0, 487.0]]], "lines": ["気を取り直して", "キャンプごはん作るか"]}, {"box": [1100, 669, 1213, 943], "vertical": true, "font_size": 27, "lines_coords": [[[1186.0, 671.0], [1213.0, 671.0], [1213.0, 821.0], [1186.0, 821.0]], [[1156.0, 669.0], [1185.0, 669.0], [1183.0, 920.0], [1155.0, 920.0]], [[1128.0, 669.0], [1155.0, 669.0], [1155.0, 825.0], [1128.0, 825.0]], [[1100.0, 669.0], [1126.0, 669.0], [1126.0, 943.0], [1100.0, 943.0]]], "lines": ["今日の朝食は", "コッヘル一つて出来る", "ほうれん草と", "たっぷりトマトのパスタ"]}, {"box": [286, 630, 421, 650], "vertical": false, "font_size": 20, "lines_coords": [[[286.0, 630.0], [421.0, 630.0], [421.0, 650.0], [286.0, 650.0]]], "lines": ["コンニ４ワ／"]}, {"box": [150, 1227, 178, 1353], "vertical": true, "font_size": 26, "lines_coords": [[[150.0, 1228.0], [176.0, 1228.0], [176.0, 1351.0], [150.0, 1351.0]]], "lines": ["おおう．．．"]}, {"box": [1130, 1434, 1197, 1730], "vertical": true, "font_size": 26, "lines_coords": [[[1168.0, 1436.0], [1194.0, 1436.0], [1194.0, 1730.0], [1168.0, 1730.0]], [[1130.0, 1436.0], [1156.0, 1436.0], [1156.0, 1590.0], [1130.0, 1590.0]]], "lines": ["リンー瑞牆キャンプの", "お土産だよ"]}, {"box": [556, 1470, 647, 1745], "vertical": true, "font_size": 26, "lines_coords": [[[618.0, 1470.0], [645.0, 1470.0], [645.0, 1621.0], [618.0, 1621.0]], [[590.0, 1471.0], [615.0, 1471.0], [615.0, 1698.0], [590.0, 1698.0]], [[558.0, 1470.0], [585.0, 1470.0], [583.0, 1745.0], [556.0, 1745.0]]], "lines": ["このトマトで", "ピザとか作ったけど", "すごく美味しかったよー"]}], "img_path": "00021.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1130, 150, 1212, 530], "vertical": true, "font_size": 40, "lines_coords": [[[1175.0, 151.0], [1209.0, 151.0], [1207.0, 528.0], [1173.0, 528.0]], [[1130.0, 150.0], [1177.0, 150.0], [1177.0, 255.0], [1130.0, 255.0]]], "lines": ["まずコッヘルにベーコンを", "投入し"]}, {"box": [603, 151, 682, 496], "vertical": true, "font_size": 34, "lines_coords": [[[645.0, 151.0], [678.0, 151.0], [680.0, 496.0], [646.0, 496.0]], [[607.0, 151.0], [641.0, 151.0], [637.0, 343.0], [603.0, 343.0]]], "lines": ["次にオリープオイル太１", "刻みにんにく"]}, {"box": [131, 281, 205, 665], "vertical": true, "font_size": 33, "lines_coords": [[[166.0, 281.0], [198.0, 281.0], [198.0, 665.0], [166.0, 665.0]], [[131.0, 283.0], [165.0, 283.0], [165.0, 403.0], [131.0, 403.0]]], "lines": ["輪切りのタカクツメを入れて", "次にかけ"]}, {"box": [1136, 731, 1210, 1075], "vertical": true, "font_size": 29, "lines_coords": [[[1175.0, 733.0], [1207.0, 733.0], [1207.0, 984.0], [1175.0, 984.0]], [[1140.0, 736.0], [1166.0, 736.0], [1166.0, 1072.0], [1140.0, 1072.0]]], "lines": ["中玉トマト１個を", "回つ切りにして入れたら"]}, {"box": [738, 391, 811, 671], "vertical": true, "font_size": 32, "lines_coords": [[[778.0, 391.0], [810.0, 391.0], [810.0, 671.0], [778.0, 671.0]], [[738.0, 391.0], [770.0, 391.0], [770.0, 515.0], [738.0, 515.0]]], "lines": ["カリカリになるまで", "炒めます"]}, {"box": [1087, 1389, 1121, 1473], "vertical": true, "font_size": 34, "lines_coords": [[[1087.0, 1389.0], [1121.0, 1389.0], [1121.0, 1473.0], [1087.0, 1473.0]]], "lines": ["ガール"]}, {"box": [679, 909, 717, 1256], "vertical": true, "font_size": 32, "lines_coords": [[[680.0, 911.0], [712.0, 911.0], [712.0, 1256.0], [680.0, 1256.0]]], "lines": ["崩しながら煮ていきます"]}, {"box": [363, 849, 418, 1081], "vertical": true, "font_size": 47, "lines_coords": [[[363.0, 851.0], [410.0, 849.0], [418.0, 1078.0], [371.0, 1080.0]]], "lines": ["刻みに！？"]}, {"box": [423, 1567, 456, 1680], "vertical": true, "font_size": 32, "lines_coords": [[[423.0, 1567.0], [455.0, 1567.0], [455.0, 1680.0], [423.0, 1680.0]]], "lines": ["ガールズ"]}, {"box": [213, 1480, 275, 1620], "vertical": true, "font_size": 30, "lines_coords": [[[241.0, 1481.0], [273.0, 1481.0], [273.0, 1620.0], [241.0, 1620.0]], [[213.0, 1481.0], [241.0, 1481.0], [241.0, 1565.0], [213.0, 1565.0]]], "lines": ["ガーリック", "．．．っと"]}], "img_path": "00022.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [993, 144, 1136, 408], "vertical": true, "font_size": 30, "lines_coords": [[[1106.0, 144.0], [1132.0, 144.0], [1132.0, 378.0], [1106.0, 378.0]], [[1066.0, 144.0], [1098.0, 144.0], [1098.0, 408.0], [1066.0, 408.0]], [[1031.0, 144.0], [1063.0, 144.0], [1063.0, 380.0], [1031.0, 380.0]], [[993.0, 144.0], [1025.0, 144.0], [1025.0, 264.0], [993.0, 264.0]]], "lines": ["トマトが崩れたら", "ほうわん草と水２００ｃ", "ハーブ塩を入れて", "沸騰させ"]}, {"box": [639, 136, 775, 307], "vertical": true, "font_size": 30, "lines_coords": [[[742.0, 136.0], [774.0, 136.0], [774.0, 307.0], [742.0, 307.0]], [[706.0, 136.0], [738.0, 136.0], [738.0, 277.0], [706.0, 277.0]], [[671.0, 136.0], [703.0, 136.0], [703.0, 277.0], [671.0, 277.0]], [[639.0, 136.0], [665.0, 136.0], [665.0, 303.0], [639.0, 303.0]]], "lines": ["パスタ１００ｇを", "二つ折りに", "して投入し", "煮ていきます"]}, {"box": [830, 389, 864, 477], "vertical": true, "font_size": 34, "lines_coords": [[[830.0, 389.0], [864.0, 389.0], [864.0, 477.0], [830.0, 477.0]]], "lines": ["イベリア人は見てないよね？"]}, {"box": [208, 136, 425, 374], "vertical": true, "font_size": 27, "lines_coords": [[[393.0, 140.0], [420.0, 140.0], [420.0, 373.0], [393.0, 373.0]], [[356.0, 140.0], [382.0, 140.0], [382.0, 345.0], [356.0, 345.0]], [[318.0, 136.0], [343.0, 136.0], [343.0, 371.0], [318.0, 371.0]], [[277.0, 136.0], [309.0, 136.0], [309.0, 373.0], [277.0, 373.0]], [[243.0, 138.0], [270.0, 138.0], [270.0, 341.0], [243.0, 341.0]], [[208.0, 138.0], [234.0, 138.0], [234.0, 285.0], [208.0, 285.0]]], "lines": ["バスタが煮え切る", "少し前に刻んだ", "中玉トマト２値を", "上に乗せて強火で", "水分をある程度", "私はしたら"]}, {"box": [183, 819, 232, 924], "vertical": true, "font_size": 49, "lines_coords": [[[183.0, 819.0], [232.0, 819.0], [232.0, 924.0], [183.0, 924.0]]], "lines": ["よし。"]}, {"box": [1091, 774, 1187, 1338], "vertical": true, "font_size": 44, "lines_coords": [[[1141.0, 774.0], [1185.0, 774.0], [1185.0, 1323.0], [1141.0, 1323.0]