2, 1156, 1593], "vertical": true, "font_size": 25, "lines_coords": [[[1130.0, 1372.0], [1155.0, 1372.0], [1155.0, 1593.0], [1130.0, 1593.0]], [[1100.0, 1372.0], [1125.0, 1372.0], [1125.0, 1565.0], [1100.0, 1565.0]]], "lines": ["橋を渡ったあっちは", "ただの公園ばいな"]}, {"box": [136, 1500, 195, 1745], "vertical": true, "font_size": 26, "lines_coords": [[[168.0, 1503.0], [193.0, 1503.0], [193.0, 1745.0], [168.0, 1745.0]], [[138.0, 1500.0], [165.0, 1500.0], [163.0, 1691.0], [136.0, 1691.0]]], "lines": ["そことはこっち側だけ", "キャンプ場なのか"]}], "img_path": "00111.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1083, 181, 1183, 531], "vertical": true, "font_size": 28, "lines_coords": [[[1147.0, 181.0], [1179.0, 181.0], [1183.0, 504.0], [1151.0, 504.0]], [[1115.0, 187.0], [1141.0, 187.0], [1141.0, 528.0], [1115.0, 528.0]], [[1083.0, 187.0], [1110.0, 187.0], [1110.0, 301.0], [1083.0, 301.0]]], "lines": ["しかしこんなガラガラで", "無料ってのはかなりの穴場", "だよな．．．"]}, {"box": [202, 176, 309, 556], "vertical": true, "font_size": 36, "lines_coords": [[[273.0, 180.0], [309.0, 180.0], [309.0, 271.0], [273.0, 271.0]], [[238.0, 176.0], [277.0, 176.0], [277.0, 556.0], [238.0, 556.0]], [[206.0, 180.0], [238.0, 180.0], [234.0, 328.0], [202.0, 328.0]]], "lines": ["さすが", "キャンプ場ハンターしまりん", "侮りがたし"]}, {"box": [1134, 651, 1162, 821], "vertical": true, "font_size": 26, "lines_coords": [[[1134.0, 652.0], [1160.0, 652.0], [1160.0, 819.0], [1134.0, 819.0]]], "lines": ["サクッと設営"]}, {"box": [605, 1318, 660, 1560], "vertical": true, "font_size": 23, "lines_coords": [[[633.0, 1318.0], [658.0, 1318.0], [658.0, 1560.0], [633.0, 1560.0]], [[605.0, 1320.0], [626.0, 1320.0], [626.0, 1460.0], [605.0, 1460.0]]], "lines": ["リンが読書なでしこが", "実験料理なら"]}, {"box": [238, 838, 270, 1088], "vertical": true, "font_size": 32, "lines_coords": [[[238.0, 838.0], [270.0, 838.0], [270.0, 1087.0], [238.0, 1087.0]]], "lines": ["今日の寝床ヨシ！"]}, {"box": [1151, 1303, 1208, 1655], "vertical": true, "font_size": 24, "lines_coords": [[[1181.0, 1303.0], [1205.0, 1303.0], [1205.0, 1593.0], [1181.0, 1593.0]], [[1151.0, 1305.0], [1175.0, 1305.0], [1175.0, 1655.0], [1151.0, 1655.0]]], "lines": ["さてなでしこが言っていた", "ソロキャン酸を持て余す問題だが、"]}, {"box": [733, 1308, 805, 1597], "vertical": true, "font_size": 24, "lines_coords": [[[780.0, 1308.0], [804.0, 1308.0], [804.0, 1537.0], [780.0, 1537.0]], [[753.0, 1310.0], [780.0, 1310.0], [780.0, 1597.0], [753.0, 1597.0]], [[733.0, 1314.0], [753.0, 1314.0], [753.0, 1413.0], [733.0, 1413.0]]], "lines": ["ソロキャンは暇つぶしを", "考えていくことが肝心なんだよ", "あきちゃん"]}, {"box": [159, 1528, 189, 1719], "vertical": true, "font_size": 26, "lines_coords": [[[159.0, 1528.0], [185.0, 1528.0], [187.0, 1717.0], [161.0, 1717.0]]], "lines": ["私の暇つぶしは．．．"]}], "img_path": "00112.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1134, 318, 1161, 418], "vertical": true, "font_size": 26, "lines_coords": [[[1134.0, 318.0], [1160.0, 318.0], [1160.0, 418.0], [1134.0, 418.0]]], "lines": ["コレだな"]}, {"box": [172, 166, 210, 479], "vertical": true, "font_size": 32, "lines_coords": [[[176.0, 166.0], [208.0, 166.0], [204.0, 478.0], [172.0, 478.0]]], "lines": ["自作ノンアルカクテル"]}, {"box": [1117, 621, 1186, 961], "vertical": true, "font_size": 32, "lines_coords": [[[1155.0, 624.0], [1186.0, 624.0], [1186.0, 961.0], [1155.0, 961.0]], [[1117.0, 624.0], [1149.0, 624.0], [1149.0, 909.0], [1117.0, 909.0]]], "lines": ["今日のノンアルカクテルは", "キロサラトガクーラー"]}, {"box": [387, 668, 459, 703], "vertical": false, "font_size": 35, "lines_coords": [[[387.0, 668.0], [459.0, 668.0], [459.0, 703.0], [387.0, 703.0]]], "lines": ["ミナモンスティック"]}, {"box": [176, 623, 250, 938], "vertical": true, "font_size": 36, "lines_coords": [[[210.0, 624.0], [247.0, 624.0], [247.0, 937.0], [210.0, 937.0]], [[176.0, 624.0], [210.0, 624.0], [210.0, 798.0], [176.0, 798.0]]], "lines": ["ジンジャエールを使った", "カクテルです"]}, {"box": [1143, 1033, 1209, 1379], "vertical": true, "font_size": 30, "lines_coords": [[[1177.0, 1033.0], [1209.0, 1033.0], [1209.0, 1295.0], [1177.0, 1295.0]], [[1143.0, 1035.0], [1170.0, 1035.0], [1170.0, 1378.0], [1143.0, 1378.0]]], "lines": ["まず小鍋に水７０ｃと", "ざらめ６０ｇを入れ次にかけ"]}, {"box": [420, 1065, 481, 1318], "vertical": true, "font_size": 26, "lines_coords": [[[453.0, 1065.0], [478.0, 1065.0], [478.0, 1291.0], [453.0, 1291.0]], [[421.0, 1066.0], [448.0, 1066.0], [446.0, 1318.0], [420.0, 1318.0]]], "lines": ["なんかコレ歯医者で", "嗅いだ事ある匂いだな"]}, {"box": [134, 1027, 200, 1573], "vertical": true, "font_size": 26, "lines_coords": [[[170.0, 1027.0], [196.0, 1027.0], [196.0, 1483.0], [170.0, 1483.0]], [[135.0, 1051.0], [161.0, 1051.0], [161.0, 1571.0], [135.0, 1571.0]]], "lines": ["淡クローブは歯科治療薬の原料にも", "使われていて歯医者さんの匂いがします。"]}, {"box": [559, 1363, 697, 1777], "vertical": true, "font_size": 30, "lines_coords": [[[661.0, 1365.0], [693.0, 1365.0], [697.0, 1740.0], [665.0, 1740.0]], [[626.0, 1365.0], [658.0, 1365.0], [660.0, 1685.0], [628.0, 1685.0]], [[590.0, 1363.0], [622.0, 1363.0], [624.0, 1777.0], [592.0, 1777.0]], [[560.0, 1366.0], [586.0, 1366.0], [586.0, 1511.0], [560.0, 1511.0]]], "lines": ["沸騰したらライムの皮１個分", "シナモンスティック半分", "生姜スライス２０ｇクロープ遺量", "を入れます"]}], "img_path": "00113.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1098, 129, 1202, 588], "vertical": true, "font_size": 30, "lines_coords": [[[1168.0, 129.0], [1200.0, 129.0], [1201.0, 498.0], [1170.0, 498.0]], [[1132.0, 129.0], [1164.0, 129.0], [1162.0, 588.0], [1130.0, 588.0]], [[1098.0, 133.0], [1125.0, 133.0], [1125.0, 577.0], [1098.0, 577.0]]], "lines": ["今回作るサラトガクーラーは", "幸口なので普通の唐幸子の代わりに", "ハバネロバウダーで幸味を出します"]}, {"box": [830, 176, 870, 356], "vertical": true, "font_size": 34, "lines_coords": [[[830.0, 176.0], [864.0, 176.0], [870.0, 337.0], [836.0, 337.0]]], "lines": ["そーっと．．"]}, {"box": [271, 159, 305, 465], "vertical": true, "font_size": 30, "lines_coords": [[[273.0, 159.0], [305.0, 159.0], [303.0, 465.0], [271.0, 465.0]]], "lines": ["淡ハバネロパウダーは"]}, {"box": [159, 189, 264, 555], "vertical": true, "font_size": 30, "lines_coords": [[[238.0, 191.0], [264.0, 191.0], [264.0, 403.0], [238.0, 403.0]], [[196.0, 189.0], [228.0, 189.0], [226.0, 555.0], [195.0, 555.0]], [[159.0, 189.0], [191.0, 189.0], [191.0, 493.0], [159.0, 493.0]]], "lines": ["量を間違えると", "死ぬほど辛くなりますので", "十分気をつけましょう"]}, {"box": [1104, 639, 1205, 1112], "vertical": true, "font_size": 27, "lines_coords": [[[1173.0, 639.0], [1200.0, 639.0], [1200.0, 1104.0], [1173.0, 1104.0]], [[1136.0, 639.0], [1164.0, 639.0], [1166.0, 1100.0], [1138.0, 1100.0]], [[1104.0, 645.0], [1130.0, 645.0], [1130.0, 841.0], [1104.0, 841.0]]], "lines": ["３分ほど煮たら、次を止め少し冷まし", "さらに生姜スライス２０ｇを追加して", "一晩寝かします。"]}, {"box": [285, 648, 347, 1046], "vertical": true, "font_size": 24, "lines_coords": [[[318.0, 648.0], [345.0, 648.0], [345.0, 1046.0], [318.0, 1046.0]], [[285.0, 650.0], [305.0, 650.0], [305.0, 774.0], [285.0, 774.0]]], "lines": ["とりあえずジンジャーシロップは", "コレでよー"]}, {"box": [1158, 1175, 1226, 1548], "vertical": true, "font_size": 32, "lines_coords": [[[1190.0, 1175.0], [1226.0, 1175.0], [1226.0, 1265.0], [1190.0, 1265.0]], [[1158.0, 1179.0], [1185.0, 1179.0], [1185.0, 1548.0], [1158.0, 1548.0]]], "lines": ["本当は", "一晩寝かしたいとこなんだが"]}, {"box": [620, 1211, 678, 1519], "vertical": true, "font_size": 26, "lines_coords": [[[652.0, 1211.0], [678.0, 1211.0], [678.0, 1518.0], [652.0, 1518.0]], [[620.0, 1211.0], [645.0, 1211.0], [645.0, 1387.0], [620.0, 1387.0]]], "lines": ["さてとシロップを冷ます間", "の暇つぶしは．．．"]}, {"box": [750, 1503, 849, 1702], "vertical": true, "font_size": 26, "lines_coords": [[[819.0, 1503.0], [845.0, 1503.0], [845.0, 1702.0], [819.0, 1702.0]], [[783.0, 1507.0], [810.0, 1507.0], [810.0, 1702.0], [783.0, 1702.0]], [[750.0, 1505.0], [776.0, 1505.0], [776.0, 1616.0], [750.0, 1616.0]]], "lines": ["すぐ飲みたいし", "一時間ぐらいに", "しとくか"]}], "img_path": "00114.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1110, 176, 1181, 453], "vertical": true, "font_size": 30, "lines_coords": [[[1145.0, 178.0], [1177.0, 178.0], [1177.0, 453.0], [1145.0, 453.0]], [[1111.0, 176.0], [1138.0, 176.0], [1138.0, 423.0], [1111.0, 423.0]]], "lines": ["パラコードを使って", "自作ブレスレット"]}, {"box": [189, 255, 286, 528], "vertical": true, "font_size": 34, "lines_coords": [[[251.0, 255.0], [283.0, 255.0], [286.0, 438.0], [255.0, 438.0]], [[223.0, 256.0], [255.0, 256.0], [255.0, 528.0], [223.0, 528.0]], [[189.0, 255.0], [226.0, 255.0], [226.0, 322.0], [189.0, 322.0]]], "lines": ["前からやって", "みたかったんだよな", "これ"]}, {"box": [1173, 641, 1205, 786], "vertical": true, "font_size": 32, "lines_coords": [[[1173.0, 641.0], [1205.0, 641.0], [1205.0, 785.0], [1173.0, 785.0]]], "lines": ["パラコード"]}, {"box": [681, 650, 744, 991], "vertical": true, "font_size": 25, "lines_coords": [[[714.0, 650.0], [740.0, 650.0], [740.0, 991.0], [714.0, 991.0]], [[682.0, 650.0], [706.0, 650.0], [706.0, 980.0], [682.0, 980.0]]], "lines": ["中の紐は取り出して縫い糸や", "フロス、釣り糸に代用したり、"]}, {"box": [143, 618, 237, 1149], "vertical": true, "font_size": 25, "lines_coords": [[[208.0, 620.0], [234.0, 620.0], [234.0, 1027.0], [208.0, 1027.0]], [[176.0, 620.0], [202.0, 620.0], [202.0, 1149.0], [176.0, 1149.0]], [[144.0, 618.0], [168.0, 618.0], [168.0, 1134.0], [144.0, 1134.0]]], "lines": ["着火成分の含まれる劣が入っていて、", "次起こしに使用出来るパパラコードもあったりと", "見た目以上に便利なアウトトドアアイテムです。"]}, {"box": [1087, 821, 1214, 1141], "vertical": true, "font_size": 26, "lines_coords": [[[1185.0, 823.0], [1211.0, 823.0], [1211.0, 1087.0], [1185.0, 1087.0]], [[1151.0, 823.0], [1177.0, 823.0], [1177.0, 1141.0], [1151.0, 1141.0]], [[1119.0, 823.0], [1145.0, 823.0], [1145.0, 1035.0], [1119.0, 1035.0]], [[1087.0, 823.0], [1113.0, 823.0], [1113.0, 1059.0], [1087.0, 1059.0]]], "lines": ["ナイロンパイプの中に", "細い糸が何本も入っている", "非常に強度のある", "バラシュート用の紐"]}, {"box": [1149, 1181, 1212, 1456], "vertical": true, "font_size": 29, "lines_coords": [[[1183.0, 1183.0], [1209.0, 1183.0], [1209.0, 1456.0], [1183.0, 1456.0]], [[1149.0, 1181.0], [1181.0, 1181.0], [1181.0, 1286.0], [1149.0, 1286.0]]], "lines": ["作るのはニ色コフラ編み", "だから．．"]}, {"box": [705, 1185, 765, 1453], "vertical": true, "font_size": 26, "lines_coords": [[[736.0, 1185.0], [763.0, 1185.0], [763.0, 1453.0], [736.0, 1453.0]], [[705.0, 1186.0], [729.0, 1186.0], [729.0, 1453.0], [705.0, 1453.0]]], "lines": ["それぞれＬｉｍの紐から", "親んでけばいいんだな"]}, {"box": [140, 1185, 197, 1608], "vertical": true, "font_size": 25, "lines_coords": [[[170.0, 1185.0], [195.0, 1185.0], [195.0, 1608.0], [170.0, 1608.0]], [[140.0, 1185.0], [165.0, 1185.0], [165.0, 1584.0], [140.0, 1584.0]]], "lines": ["３メートルもあったら非常時にほどいて", "ロープにしても十分使える長さじゃん"]}], "img_path": "00115.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1138, 136, 1214, 601], "vertical": true, "font_size": 32, "lines_coords": [[[1181.0, 136.0], [1213.0, 136.0], [1209.0, 594.0], [1177.0, 594.0]], [[1138.0, 163.0], [1170.0, 163.0], [1170.0, 414.0], [1138.0, 414.0]]], "lines": ["１まず二本の紐の端をライターで", "多くって少し溶かし"]}, {"box": [461, 73, 1001, 97], "vertical": false, "font_size": 24, "lines_coords": [[[461.0, 73.0], [1001.0, 73.0], [1001.0, 97.0], [461.0, 97.0]]], "lines": ["バラコードプレスレットニ色コブラ編みの作り方"]}, {"box": [703, 132, 769, 641], "vertical": true, "font_size": 26, "lines_coords": [[[738.0, 135.0], [765.0, 135.0], [766.0, 641.0], [740.0, 641.0]], [[703.0, 135.0], [729.0, 135.0], [729.0, 330.0], [703.0, 330.0]]], "lines": ["溶けているうちに押し付けてつなげます", "淡やけどに注意"]}, {"box": [133, 140, 281, 605], "vertical": true, "font_size": 31, "lines_coords": [[[247.0, 140.0], [281.0, 140.0], [281.0, 296.0], [247.0, 296.0]], [[210.0, 166.0], [241.0, 166.0], [241.0, 603.0], [210.0, 603.0]], [[170.0, 170.0], [202.0, 170.0], [202.0, 573.0], [170.0, 573.0]], [[133.0, 170.0], [161.0, 170.0], [163.0, 356.0], [135.0, 356.0]]], "lines": ["４それから", "先生になる二本の紐を縛るように", "ひと結びを交互に繰り返して", "いきましょう"]}, {"box": [705, 733, 731, 1008], "vertical": true, "font_size": 26, "lines_coords": [[[705.0, 733.0], [731.0, 733.0], [731.0, 1008.0], [705.0, 1008.0]]], "lines": ["二つに折りにしたら、"]}, {"box": [744, 701, 770, 1162], "vertical": true, "font_size": 26, "lines_coords": [[[744.0, 701.0], [770.0, 701.0], [770.0, 1162.0], [744.0, 1162.0]]], "lines": ["２次に紐の中心から少しずらして"]}, {"box": [585, 695, 657, 1104], "vertical": true, "font_size": 32, "lines_coords": [[[624.0, 695.0], [656.0, 695.0], [654.0, 1100.0], [622.0, 1100.0]], [[585.0, 699.0], [616.0, 699.0], [616.0, 945.0], [585.0, 945.0]]], "lines": ["５下を向いている方の紐先は", "二重紐の上にのせ"]}, {"box": [140, 695, 252, 1224], "vertical": true, "font_size": 30, "lines_coords": [[[217.0, 695.0], [249.0, 695.0], [249.0, 1224.0], [217.0, 1224.0]], [[181.0, 699.0], [208.0, 699.0], [208.0, 1100.0], [181.0, 1100.0]], [[140.0, 695.0], [172.0, 695.0], [172.0, 1196.0], [140.0, 1196.0]]], "lines": ["上を向いている紐先はもう片方の紐に", "なぶせるようにして下に回し、", "輪の中に通すのが結び方のコツです。"]}, {"box": [1138, 1263, 1214, 1736], "vertical": true, "font_size": 29, "lines_coords": [[[1181.0, 1263.0], [1207.0, 1263.0], [1207.0, 1723.0], [1181.0, 1723.0]], [[1141.0, 1290.0], [1173.0, 1290.0], [1170.0, 1728.0], [1138.0, 1728.0]]], "lines": ["３手首の外周より少し短い位置で", "図のように輪を作って結びます"]}, {"box": [1008, 1426, 1104, 1545], "vertical": false, "font_size": 25.0, "lines_coords": [[[1029.0, 1451.0], [1070.0, 1520.0], [1050.0, 1533.0], [1008.0, 1464.0]], [[1048.0, 1426.0], [1104.0, 1533.0], [1083.0, 1545.0], [1025.0, 1440.0]]], "lines": ["もし欲し", "林物太郎もっ"]}, {"box": [571, 1270, 647, 1760], "vertical": true, "font_size": 29, "lines_coords": [[[615.0, 1271.0], [641.0, 1271.0], [641.0, 1678.0], [615.0, 1678.0]], [[571.0, 1293.0], [603.0, 1293.0], [605.0, 1760.0], [573.0, 1760.0]]], "lines": ["６最後まで結び目を作ったら", "図のように紐先を輪に通じて結び"]}], "img_path": "00116.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1141, 138, 1213, 508], "vertical": true, "font_size": 30, "lines_coords": [[[1179.0, 138.0], [1211.0, 138.0], [1211.0, 508.0], [1179.0, 508.0]], [[1141.0, 163.0], [1168.0, 163.0], [1168.0, 506.0], [1141.0, 506.0]]], "lines": ["７更に反対側の二つの輪に", "それぞれ紐先を通します"]}, {"box": [500, 133, 650, 707], "vertical": true, "font_size": 32, "lines_coords": [[[616.0, 133.0], [650.0, 133.0], [650.0, 255.0], [616.0, 255.0]], [[581.0, 163.0], [613.0, 163.0], [613.0, 706.0], [581.0, 706.0]], [[541.0, 163.0], [573.0, 163.0], [573.0, 592.0], [541.0, 592.0]], [[504.0, 161.0], [536.0, 161.0], [532.0, 315.0], [500.0, 315.0]]], "lines": ["８最後に", "コードストッパーを通して紐の先を結び", "先端を切りそろえてライターで", "炙ったら．．．"]}, {"box": [701, 303, 777, 710], "vertical": true, "font_size": 32, "lines_coords": [[[742.0, 303.0], [774.0, 303.0], [774.0, 708.0], [742.0, 708.0]], [[701.0, 330.0], [733.0, 330.0], [735.0, 710.0], [703.0, 710.0]]], "lines": ["淡紐先は炙って斜めにカット", "しておくと通しやすいです"]}, {"box": [266, 785, 304, 955], "vertical": true, "font_size": 33, "lines_coords": [[[268.0, 787.0], [301.0, 787.0], [301.0, 954.0], [268.0, 954.0]]], "lines": ["できたー"]}, {"box": [1106, 963, 1164, 1182], "vertical": true, "font_size": 58, "lines_coords": [[[1106.0, 963.0], [1164.0, 963.0], [1164.0, 1171.0], [1106.0, 1171.0]]], "lines": ["完成です"]}, {"box": [360, 1303, 406, 1517], "vertical": true, "font_size": 29, "lines_coords": [[[361.0, 1305.0], [390.0, 1303.0], [405.0, 1485.0], [376.0, 1486.0]]], "lines": ["おしゃれキャンパー"]}, {"box": [1109, 1265, 1146, 1638], "vertical": true, "font_size": 31, "lines_coords": [[[1110.0, 1265.0], [1141.0, 1265.0], [1141.0, 1638.0], [1110.0, 1638.0]]], "lines": ["思ったより簡単だったなぁ"]}, {"box": [183, 1299, 256, 1676], "vertical": true, "font_size": 32, "lines_coords": [[[223.0, 1299.0], [255.0, 1299.0], [251.0, 1676.0], [219.0, 1676.0]], [[183.0, 1301.0], [215.0, 1301.0], [215.0, 1612.0], [183.0, 1612.0]]], "lines": ["２０ミリのコード使ったから、", "スリムな奴が出来たぜ"]}], "img_path": "00117.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1140, 129, 1231, 465], "vertical": true, "font_size": 30, "lines_coords": [[[1194.0, 129.0], [1231.0, 129.0], [1231.0, 193.0], [1194.0, 193.0]], [[1171.0, 191.0], [1198.0, 191.0], [1198.0, 465.0], [1171.0, 465.0]], [[1140.0, 187.0], [1166.0, 187.0], [1168.0, 465.0], [1141.0, 465.0]]], "lines": ["へえ", "パラコードで犬のリード", "編んでる人もいんのかぁ"]}, {"box": [547, 307, 573, 423], "vertical": true, "font_size": 26, "lines_coords": [[[547.0, 307.0], [573.0, 307.0], [573.0, 423.0], [547.0, 423.0]]], "lines": ["さてさて"]}, {"box": [665, 461, 720, 836], "vertical": true, "font_size": 25, "lines_coords": [[[691.0, 463.0], [716.0, 463.0], [716.0, 836.0], [691.0, 836.0]], [[665.0, 463.0], [690.0, 463.0], [690.0, 744.0], [665.0, 744.0]]], "lines": ["色々編み力の種類があるみたいだし、", "後でもう一本編んでみっか"]}, {"box": [133, 556, 199, 851], "vertical": true, "font_size": 26, "lines_coords": [[[170.0, 556.0], [196.0, 556.0], [196.0, 851.0], [170.0, 851.0]], [[133.0, 556.0], [159.0, 556.0], [159.0, 825.0], [133.0, 825.0]]], "lines": ["ジンジャーシロップも", "そろそろいいかな〜"]}, {"box": [1151, 893, 1211, 1183], "vertical": true, "font_size": 25, "lines_coords": [[[1185.0, 894.0], [1209.0, 894.0], [1209.0, 1104.0], [1185.0, 1104.0]], [[1151.0, 894.0], [1177.0, 894.0], [1177.0, 1183.0], [1151.0, 1183.0]]], "lines": ["皮を剥いておいた", "ライムをコップに入れて"]}, {"box": [678, 946, 768, 1323], "vertical": true, "font_size": 42, "lines_coords": [[[729.0, 948.0], [766.0, 948.0], [763.0, 1323.0], [725.0, 1323.0]], [[678.0, 946.0], [725.0, 946.0], [725.0, 1070.0], [678.0, 1070.0]]], "lines": ["辛口サラトガクーラー", "完成～"]}, {"box": [849, 1406, 907, 1783], "vertical": true, "font_size": 24, "lines_coords": [[[881.0, 1410.0], [905.0, 1410.0], [905.0, 1783.0], [881.0, 1783.0]], [[849.0, 1410.0], [873.0, 1410.0], [873.0, 1612.0], [849.0, 1612.0]]], "lines": ["その上からジンジャーシロップと", "炭酸水を注いだら"]}], "img_path": "00118.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1164, 133, 1222, 410], "vertical": true, "font_size": 24, "lines_coords": [[[1194.0, 133.0], [1218.0, 133.0], [1218.0, 410.0], [1194.0, 410.0]], [[1164.0, 135.0], [1188.0, 135.0], [1188.0, 408.0], [1164.0, 408.0]]], "lines": ["このスパイシーな香りが", "食欲をそそるじゃねぇか"]}, {"box": [174, 440, 307, 855], "vertical": true, "font_size": 63, "lines_coords": [[[241.0, 442.0], [303.0, 440.0], [307.0, 626.0], [245.0, 628.0]], [