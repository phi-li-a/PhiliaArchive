}], "img_path": "00087.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1129, 145, 1197, 483], "vertical": true, "font_size": 27, "lines_coords": [[[1166.0, 146.0], [1194.0, 146.0], [1196.0, 483.0], [1168.0, 483.0]], [[1130.0, 146.0], [1156.0, 146.0], [1156.0, 425.0], [1130.0, 425.0]]], "lines": ["それともダウンなしじゃ", "まだ寒かったかな？"]}, {"box": [538, 208, 573, 392], "vertical": true, "font_size": 32, "lines_coords": [[[541.0, 208.0], [573.0, 208.0], [570.0, 391.0], [538.0, 391.0]]], "lines": ["うりうり～"]}, {"box": [1126, 1278, 1200, 1423], "vertical": true, "font_size": 32, "lines_coords": [[[1168.0, 1278.0], [1200.0, 1278.0], [1200.0, 1421.0], [1168.0, 1421.0]], [[1126.0, 1278.0], [1158.0, 1278.0], [1158.0, 1423.0], [1126.0, 1423.0]]], "lines": ["うりうり", "うりうり"]}, {"box": [558, 945, 598, 984], "vertical": false, "font_size": 39, "lines_coords": [[[558.0, 945.0], [598.0, 945.0], [598.0, 984.0], [558.0, 984.0]]], "lines": ["あ"]}, {"box": [159, 993, 189, 1175], "vertical": true, "font_size": 26, "lines_coords": [[[159.0, 993.0], [185.0, 993.0], [185.0, 1175.0], [159.0, 1175.0]]], "lines": ["やりすぎたか"]}, {"box": [309, 1623, 386, 1726], "vertical": true, "font_size": 46, "lines_coords": [[[337.0, 1623.0], [386.0, 1623.0], [386.0, 1726.0], [337.0, 1726.0]], [[309.0, 1625.0], [352.0, 1625.0], [352.0, 1723.0], [309.0, 1723.0]]], "lines": ["ブーン", "ブーン"]}], "img_path": "00088.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [815, 151, 1137, 213], "vertical": false, "font_size": 26, "lines_coords": [[[819.0, 155.0], [1010.0, 155.0], [1010.0, 180.0], [819.0, 180.0]], [[819.0, 183.0], [1132.0, 183.0], [1132.0, 210.0], [819.0, 210.0]]], "lines": ["桜満開じゃんかー", "恵那は今日どこ行ってんだ？"]}, {"box": [708, 140, 753, 161], "vertical": false, "font_size": 21, "lines_coords": [[[708.0, 140.0], [753.0, 140.0], [753.0, 161.0], [708.0, 161.0]]], "lines": ["！２：０３"]}, {"box": [138, 157, 483, 236], "vertical": false, "font_size": 27, "lines_coords": [[[140.0, 157.0], [480.0, 155.0], [480.0, 183.0], [140.0, 185.0]], [[142.0, 183.0], [421.0, 183.0], [421.0, 212.0], [142.0, 212.0]], [[142.0, 209.0], [294.0, 209.0], [294.0, 238.0], [142.0, 238.0]]], "lines": ["そう思って今日は満着させて来たんだんだけど．．．", "だけどまだ寒かったみたいで", "こんななってる。"]}, {"box": [787, 798, 1181, 856], "vertical": false, "font_size": 26, "lines_coords": [[[787.0, 800.0], [993.0, 800.0], [993.0, 825.0], [787.0, 825.0]], [[787.0, 826.0], [1177.0, 830.0], [1177.0, 856.0], [787.0, 853.0]]], "lines": ["暖かくなってきたし", "寒がりのちくわにはい＞い季節だもんな"]}, {"box": [682, 691, 1080, 747], "vertical": false, "font_size": 25, "lines_coords": [[[682.0, 691.0], [1072.0, 691.0], [1072.0, 716.0], [682.0, 716.0]], [[686.0, 721.0], [1006.0, 721.0], [1006.0, 746.0], [686.0, 746.0]]], "lines": ["天気が良かったから少し足を伸ばして", "富士川公園までちくわの散歩に"]}, {"box": [686, 795, 727, 810], "vertical": false, "font_size": 15, "lines_coords": [[[686.0, 795.0], [727.0, 795.0], [727.0, 810.0], [686.0, 810.0]]], "lines": ["！２：０４"]}, {"box": [734, 923, 789, 945], "vertical": false, "font_size": 24, "lines_coords": [[[734.0, 921.0], [789.0, 921.0], [789.0, 947.0], [734.0, 947.0]]], "lines": ["１２：０５"]}, {"box": [265, 793, 570, 825], "vertical": false, "font_size": 25, "lines_coords": [[[270.0, 796.0], [566.0, 796.0], [566.0, 821.0], [270.0, 821.0]]], "lines": ["うはは亀になってやがる"]}, {"box": [837, 950, 1177, 983], "vertical": false, "font_size": 24, "lines_coords": [[[883.0, 950.0], [1177.0, 954.0], [1177.0, 978.0], [883.0, 975.0]]], "lines": ["トの連勤今日まででなんだっけ？"]}, {"box": [798, 1285, 1187, 1342], "vertical": false, "font_size": 28, "lines_coords": [[[798.0, 1314.0], [991.0, 1314.0], [991.0, 1344.0], [798.0, 1344.0]]], "lines": ["お互い様よ（３）"]}, {"box": [796, 1285, 1187, 1341], "vertical": false, "font_size": 26, "lines_coords": [[[796.0, 1288.0], [1183.0, 1288.0], [1183.0, 1314.0], [796.0, 1314.0]]], "lines": ["気にすんなってみんなバイトしてるし"]}, {"box": [702, 1162, 1089, 1244], "vertical": false, "font_size": 25, "lines_coords": [[[705.0, 1162.0], [1072.0, 1162.0], [1072.0, 1190.0], [705.0, 1190.0]], [[705.0, 1188.0], [1080.0, 1188.0], [1080.0, 1217.0], [705.0, 1217.0]], [[706.0, 1218.0], [828.0, 1218.0], [828.0, 1243.0], [706.0, 1243.0]]], "lines": ["うん、今日の午後行った。ら２日休みだよ", "ごめんね、私のせいで中々お花見の予定", "合わなくって"]}, {"box": [705, 1288, 740, 1303], "vertical": false, "font_size": 15, "lines_coords": [[[705.0, 1288.0], [740.0, 1288.0], [740.0, 1303.0], [705.0, 1303.0]]], "lines": ["２：０５"]}, {"box": [374, 1719, 576, 1749], "vertical": false, "font_size": 26, "lines_coords": [[[380.0, 1723.0], [575.0, 1723.0], [575.0, 1749.0], [380.0, 1749.0]]], "lines": ["私か？私はなー"]}, {"box": [177, 1624, 513, 1658], "vertical": false, "font_size": 26, "lines_coords": [[[185.0, 1629.0], [506.0, 1629.0], [506.0, 1655.0], [185.0, 1655.0]]], "lines": ["そっちはう日何してるの？"]}], "img_path": "00089.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [790, 127, 1208, 198], "vertical": false, "font_size": 28, "lines_coords": [[[795.0, 133.0], [1196.0, 133.0], [1196.0, 159.0], [795.0, 159.0]], [[793.0, 165.0], [1205.0, 165.0], [1205.0, 196.0], [793.0, 196.0]]], "lines": ["一足先に前乗りして場所取り８", "ソロキャンに出かけてんだよ〜"]}, {"box": [922, 416, 963, 429], "vertical": false, "font_size": 13, "lines_coords": [[[922.0, 416.0], [963.0, 416.0], [963.0, 429.0], [922.0, 429.0]]], "lines": ["よりはた"]}, {"box": [161, 157, 489, 230], "vertical": false, "font_size": 38, "lines_coords": [[[161.0, 157.0], [429.0, 157.0], [429.0, 195.0], [161.0, 195.0]], [[161.0, 191.0], [489.0, 191.0], [489.0, 230.0], [161.0, 230.0]]], "lines": ["あきちゃんもついに", "ソロキャンデビューかぁ"]}, {"box": [161, 276, 485, 307], "vertical": false, "font_size": 26, "lines_coords": [[[161.0, 279.0], [483.0, 279.0], [483.0, 305.0], [161.0, 305.0]]], "lines": ["キャンプ場まで気を付けてね"]}, {"box": [993, 689, 1090, 725], "vertical": false, "font_size": 35, "lines_coords": [[[995.0, 690.0], [1083.0, 690.0], [1083.0, 725.0], [995.0, 725.0]]], "lines": ["おっ！"]}, {"box": [775, 774, 1215, 832], "vertical": false, "font_size":