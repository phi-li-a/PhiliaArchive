], [761.0, 720.0]], [[735.0, 418.0], [759.0, 418.0], [759.0, 667.0], [735.0, 667.0]]], "lines": ["一人２０２として６人分間で", "だからラム４０に豚６０："]}, {"box": [588, 412, 650, 714], "vertical": true, "font_size": 30, "lines_coords": [[[618.0, 412.0], [650.0, 412.0], [650.0, 714.0], [618.0, 714.0]], [[588.0, 412.0], [615.0, 412.0], [615.0, 680.0], [588.0, 680.0]]], "lines": ["いや各務原さんは一人で", "４００ぐらい食べそうよね"]}, {"box": [1134, 1318, 1196, 1426], "vertical": true, "font_size": 58, "lines_coords": [[[1138.0, 1318.0], [1196.0, 1320.0], [1192.0, 1426.0], [1134.0, 1425.0]]], "lines": ["こ．．．"]}, {"box": [258, 806, 320, 1134], "vertical": true, "font_size": 24, "lines_coords": [[[292.0, 808.0], [316.0, 808.0], [316.0, 1134.0], [292.0, 1134.0]], [[258.0, 808.0], [283.0, 808.0], [283.0, 1031.0], [258.0, 1031.0]]], "lines": ["野菜類は皆さんに頼むとして", "あとはタレと．．．ん？"]}, {"box": [178, 1226, 212, 1470], "vertical": true, "font_size": 32, "lines_coords": [[[178.0, 1226.0], [210.0, 1226.0], [210.0, 1470.0], [178.0, 1470.0]]], "lines": ["このお肉は．．．："]}], "img_path": "00153.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1081, 183, 1140, 343], "vertical": true, "font_size": 24, "lines_coords": [[[1113.0, 183.0], [1140.0, 183.0], [1140.0, 343.0], [1113.0, 343.0]], [[1081.0, 187.0], [1102.0, 187.0], [1102.0, 315.0], [1081.0, 315.0]]], "lines": ["うん分かった", "６時過ぎね"]}, {"box": [202, 241, 266, 431], "vertical": true, "font_size": 32, "lines_coords": [[[228.0, 241.0], [266.0, 241.0], [266.0, 307.0], [228.0, 307.0]], [[202.0, 245.0], [228.0, 245.0], [228.0, 431.0], [202.0, 431.0]]], "lines": ["うん", "悪いけど頼むわ"]}, {"box": [1117, 565, 1180, 883], "vertical": true, "font_size": 29, "lines_coords": [[[1151.0, 566.0], [1177.0, 566.0], [1177.0, 879.0], [1151.0, 879.0]], [[1117.0, 566.0], [1149.0, 566.0], [1149.0, 883.0], [1117.0, 883.0]]], "lines": ["お父さんが仕事終わったら", "バンで迎えに来てくれるで"]}, {"box": [787, 593, 808, 687], "vertical": true, "font_size": 21, "lines_coords": [[[787.0, 593.0], [808.0, 593.0], [80