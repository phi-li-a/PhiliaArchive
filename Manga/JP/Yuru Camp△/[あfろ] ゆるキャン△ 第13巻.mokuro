転車に乗ってちょっとそこまで"]}], "img_path": "00137.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1132, 129, 1220, 406], "vertical": true, "font_size": 25, "lines_coords": [[[1192.0, 131.0], [1218.0, 131.0], [1220.0, 356.0], [1194.0, 356.0]], [[1164.0, 133.0], [1188.0, 133.0], [1188.0, 406.0], [1164.0, 406.0]], [[1132.0, 129.0], [1156.0, 129.0], [1156.0, 331.0], [1132.0, 331.0]]], "lines": ["なんやあかりちゃん", "前に会った時から全然背", "伸びとらんなぁー"]}, {"box": [615, 127, 674, 406], "vertical": true, "font_size": 26, "lines_coords": [[[646.0, 129.0], [671.0, 129.0], [671.0, 354.0], [646.0, 354.0]], [[615.0, 127.0], [641.0, 127.0], [643.0, 406.0], [616.0, 406.0]]], "lines": ["あおいちゃんは身長", "私とおんなじくらいやな"]}, {"box": [1128, 528, 1217, 780], "vertical": true, "font_size": 25, "lines_coords": [[[1188.0, 532.0], [1213.0, 532.0], [1213.0, 778.0], [1188.0, 778.0]], [[1158.0, 530.0], [1183.0, 530.0], [1183.0, 706.0], [1158.0, 706.0]], [[1128.0, 528.0], [1153.0, 528.0], [1153.0, 755.0], [1128.0, 755.0]]], "lines": ["前に会ったの正月やん", "そんな短い間に", "伸びるわけないし！"]}, {"box": [1143, 819, 1203, 1027], "vertical": true, "font_size": 26, "lines_coords": [[[1177.0, 819.0], [1201.0, 819.0], [1201.0, 1027.0], [1177.0, 1027.0]], [[1143.0, 819.0], [1171.0, 819.0], [1171.0, 901.0], [1143.0, 901.0]]], "lines": ["これがもろもろの", "付属品"]}, {"box": [765, 517, 830, 708], "vertical": true, "font_size": 34, "lines_coords": [[[787.0, 517.0], [830.0, 517.0], [830.0, 585.0], [787.0, 585.0]], [[765.0, 525.0], [789.0, 525.0], [789.0, 708.0], [765.0, 708.0]]], "lines": ["私は", "これからやし！"]}, {"box": [270, 474, 296, 579], "vertical": true, "font_size": 25, "lines_coords": [[[270.0, 474.0], [296.0, 474.0], [296.0, 579.0], [270.0, 579.0]]], "lines": ["よしよし"]}, {"box": [174, 525, 232, 765], "vertical": true, "font_size": 25, "lines_coords": [[[206.0, 525.0], [232.0, 525.0], [232.0, 710.0], [206.0, 710.0]], [[174.0, 526.0], [198.0, 526.0], [198.0, 765.0], [174.0, 765.0]]], "lines": ["身長違うと体に", "合わん事があるでな"]}, {"box": [975, 855, 1035, 1168], "vertical": true, "font_size": 24, "lines_coords": [[[1008.0, 855.0], [1033.0, 855.0], [1033.0, 1168.0], [1008.0, 1168.0]], [[975.0, 855.0], [999.0, 855.0], [999.0, 1145.0], [975.0, 1145.0]]], "lines": ["乗る時ヘルメットと前後の", "ライトは必ずつけること"]}, {"box": [1106, 1228, 1194, 1530], "vertical": true, "font_size": 24, "lines_coords": [[[1168.0, 1235.0], [1192.0, 1235.0], [1192.0, 1530.0], [1168.0, 1530.0]], [[1134.0, 1228.0], [1158.0, 1228.0], [1158.0, 1455.0], [1134.0, 1455.0]], [[1106.0, 1230.0], [1130.0, 1230.0], [1130.0, 1479.0], [1106.0, 1479.0]]], "lines": ["一通り整備はしてあるけど", "分からん事あったら", "達雄兄さんに聞いてな"]}, {"box": [772, 1271, 804, 1423], "vertical": true, "font_size": 32, "lines_coords": [[[772.0, 1271.0], [804.0, 1271.0], [804.0, 1423.0], [772.0, 1423.0]]], "lines": ["お父さん？"]}, {"box": [609, 1220, 663, 1640], "vertical": true, "font_size": 22, "lines_coords": [[[637.0, 1220.0], [661.0, 1220.0], [661.0, 1621.0], [637.0, 1621.0]], [[609.0, 1220.0], [628.0, 1220.0], [628.0, 1640.0], [609.0, 1640.0]]], "lines": ["昔はゴリゴリのロードバイク乗りでな", "足なんて驚いますみだいやったんやでー"]}, {"box": [189, 826, 248, 1151], "vertical": true, "font_size": 25, "lines_coords": [[[217.0, 826.0], [243.0, 826.0], [245.0, 1151.0], [219.0, 1151.0]], [[189.0, 828.0], [213.0, 828.0], [213.0, 1102.0], [189.0, 1102.0]]], "lines": ["細かい注意はメモに書いたで", "乗る前にちゃんと読んで"]}, {"box": [148, 1258, 219, 1461], "vertical": true, "font_size": 30, "lines_coords": [[[185.0, 1261.0], [219.0, 1261.0], [219.0, 1350.0], [185.0, 1350.0]], [[148.0, 1258.0], [174.0, 1258.0], [174.0, 1460.0], [148.0, 1460.0]]], "lines": ["へぇー", "知らんかったわ"]}, {"box": [795, 1595, 821, 1708], "vertical": true, "font_size": 26, "lines_coords": [[[795.0, 1595.0], [821.0, 1595.0], [821.0, 1708.0], [795.0, 1708.0]]], "lines": ["そうそう"]}], "img_path": "00138.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1123, 185, 1215, 421], "vertical": true, "font_size": 26, "lines_coords": [[[1186.0, 185.0], [1213.0, 185.0], [1215.0, 420.0], [1188.0, 420.0]], [[1155.0, 187.0], [1181.0, 187.0], [1183.0, 420.0], [1156.0, 420.0]], [[1123.0, 189.0], [1149.0, 189.0], [1149.0, 292.0], [1123.0, 292.0]]], "lines": ["そんじゃおばちゃん", "これから用事あるで", "またなー"]}, {"box": [626, 180, 658, 371], "vertical": true, "font_size": 27, "lines_coords": [[[626.0, 180.0], [658.0, 180.0], [658.0, 371.0], [626.0, 371.0]]], "lines": ["行ってもうた．．"]}, {"box": [555, 298, 611, 551], "vertical": true, "font_size": 27, "lines_coords": [[[583.0, 298.0], [609.0, 298.0], [611.0, 551.0], [585.0, 551.0]], [[555.0, 301.0], [579.0, 301.0], [579.0, 498.0], [555.0, 498.0]]], "lines": ["相変わらずせっかちな", "おばちゃんやなぁ"]}, {"box": [1091, 785, 1155, 1012], "vertical": true, "font_size": 27, "lines_coords": [[[1123.0, 785.0], [1151.0, 785.0], [1155.0, 954.0], [1126.0, 954.0]], [[1093.0, 785.0], [1119.0, 785.0], [1117.0, 1012.0], [1091.0, 1012.0]]], "lines": ["あおいちゃん", "どうするんこれ？"]}, {"box": [326, 811, 360, 909], "vertical": true, "font_size": 34, "lines_coords": [[[326.0, 811.0], [360.0, 811.0], [360.0, 909.0], [326.0, 909.0]]], "lines": ["うーん"]}, {"box": [1081, 1374, 1173, 1730], "vertical": true, "font_size": 26, "lines_coords": [[[1145.0, 1374.0], [1171.0, 1374.0], [1171.0, 1689.0], [1145.0, 1689.0]], [[1111.0, 1374.0], [1138.0, 1374.0], [1140.0, 1638.0], [1113.0, 1638.0]], [[1081.0, 1376.0], [1106.0, 1376.0], [1106.0, 1730.0], [1081.0, 1730.0]]], "lines": ["今日はもう用事あらへんし", "とりあえずこれ乗って", "コンビニでも行ってこよかな。"]}, {"box": [217, 1458, 313, 1714], "vertical": true, "font_size": 28, "lines_coords": [[[281.0, 1458.0], [313.0, 1458.0], [313.0, 1573.0], [281.0, 1573.0]], [[247.0, 1460.0], [275.0, 1460.0], [277.0, 1683.0], [249.0, 1683.0]], [[217.0, 1460.0], [241.0, 1460.0], [241.0, 1683.0], [217.0, 1683.0]]], "lines": ["ほんじゃ", "ボテチ買うてきて", "わきび味のやつー"]}], "img_path": "00139.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [525, 210, 596, 396], "vertical": true, "font_size": 31, "lines_coords": [[[560.0, 210.0], [594.0, 210.0], [596.0, 335.0],