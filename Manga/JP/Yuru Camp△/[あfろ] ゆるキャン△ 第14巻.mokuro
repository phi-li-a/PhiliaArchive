023.0], [738.0, 1248.0], [714.0, 1248.0]], [[680.0, 1023.0], [706.0, 1023.0], [706.0, 1273.0], [680.0, 1273.0]]], "lines": ["あぁー食べた食べだ", "ヤバかったよなあれ！！"]}, {"box": [755, 1346, 813, 1520], "vertical": true, "font_size": 25, "lines_coords": [[[787.0, 1346.0], [811.0, 1346.0], [811.0, 1520.0], [787.0, 1520.0]], [[755.0, 1346.0], [781.0, 1346.0], [781.0, 1520.0], [755.0, 1520.0]]], "lines": ["勧誘ポスターに", "書いてあったぜ"]}, {"box": [275, 1153, 301, 1231], "vertical": true, "font_size": 26, "lines_coords": [[[275.0, 1153.0], [301.0, 1153.0], [301.0, 1231.0], [275.0, 1231.0]]], "lines": ["うーん"]}, {"box": [133, 1053, 188, 1267], "vertical": true, "font_size": 25, "lines_coords": [[[159.0, 1053.0], [185.0, 1053.0], [187.0, 1243.0], [161.0, 1243.0]], [[133.0, 1057.0], [157.0, 1057.0], [157.0, 1267.0], [133.0, 1267.0]]], "lines": ["野外なんとかって", "書いてあった気する"]}, {"box": [166, 1321, 251, 1556], "vertical": true, "font_size": 24, "lines_coords": [[[225.0, 1321.0], [249.0, 1321.0], [249.0, 1531.0], [225.0, 1531.0]], [[198.0, 1323.0], [219.0, 1323.0], [219.0, 1462.0], [198.0, 1462.0]], [[166.0, 1321.0], [193.0, 1321.0], [193.0, 1556.0], [166.0, 1556.0]]], "lines": ["あんな美味しい料理", "作れるなら私", "料理研究部入ろっかな"]}, {"box": [1141, 1515, 1195, 1771], "vertical": true, "font_size": 24, "lines_coords": [[[1170.0, 1515.0], [1194.0, 1515.0], [1194.0, 1771.0], [1170.0, 1771.0]], [[1141.0, 1515.0], [1166.0, 1515.0], [1166.0, 1749.0], [1141.0, 1749.0]]], "lines": ["そういえば料理研究部が", "野外料理やってるって"]}, {"box": [622, 1318, 678, 1646], "vertical": true, "font_size": 25, "lines_coords": [[[654.0, 1320.0], [678.0, 1320.0], [678.0, 1633.0], [654.0, 1633.0]], [[622.0, 1318.0], [648.0, 1318.0], [650.0, 1646.0], [624.0, 1646.0]]], "lines": ["ねぇ聞いた？この間のヒザ会", "料理研究部がやってたんだって"]}, {"box": [761, 1596, 787, 1755], "vertical": true, "font_size": 24, "lines_coords": [[[761.0, 1597.0], [785.0, 1597.0], [785.0, 1755.0], [761.0, 1755.0]]], "lines": ["あそうなんだ"]}, {"box": [150, 1610, 210, 1773], "vertical": true, "font_size": 29, "lines_coords":