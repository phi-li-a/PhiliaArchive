: 27, "lines_coords": [[[1158.0, 886.0], [1185.0, 886.0], [1185.0, 1046.0], [1158.0, 1046.0]], [[1126.0, 885.0], [1153.0, 885.0], [1153.0, 1177.0], [1126.0, 1177.0]]], "lines": ["それでさ絵真", "今日の放課後ってヒマ？"]}, {"box": [165, 855, 227, 1173], "vertical": true, "font_size": 27, "lines_coords": [[[198.0, 858.0], [225.0, 858.0], [225.0, 1123.0], [198.0, 1123.0]], [[165.0, 855.0], [191.0, 855.0], [193.0, 1173.0], [166.0, 1173.0]]], "lines": ["ヒマと言えばヒマだよ", "部活もバイトもしてないし"]}, {"box": [1085, 1305, 1158, 1680], "vertical": true, "font_size": 32, "lines_coords": [[[1126.0, 1305.0], [1158.0, 1305.0], [1158.0, 1680.0], [1126.0, 1680.0]], [[1085.0, 1306.0], [1117.0, 1306.0], [1119.0, 1535.0], [1087.0, 1535.0]]], "lines": ["ちょっとスポーツ自転車に", "興味が湧いてさ。"]}, {"box": [236, 1438, 268, 1563], "vertical": true, "font_size": 32, "lines_coords": [[[236.0, 1438.0], [268.0, 1438.0], [268.0, 1563.0], [236.0, 1563.0]]], "lines": ["自転車？"]}], "img_path": "00080.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [], "img_path": "00081.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [885, 1445, 961, 1532], "vertical": true, "font_size": 76, "lines_coords": [[[885.0, 1445.0], [961.0, 1445.0], [961.0, 1532.0], [885.0, 1532.0]]], "lines": ["はい"]}, {"box": [796, 1661, 1055, 1704], "vertical": false, "font_size": 38, "lines_coords": [[[796.0, 1666.0], [1055.0, 1661.0], [1055.0, 1698.0], [796.0, 1704.0]]], "lines": ["地引網はじめました。"]}], "img_path": "00082.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1158, 172, 1190, 327], "vertical": true, "font_size": 26, "lines_coords": [[[1160.0, 172.0], [1186.0, 172.0], [1186.0, 326.0], [1160.0, 326.0]]], "lines": ["道の駅増穂"]}, {"box": [1036, 242, 1069, 436], "vertical": true, "font_size": 32, "lines_coords": [[[1036.0, 245.0], [1068.0, 245.0], [1068.0, 436.0], [1036.0, 436.0]]], "lines": ["道の駅到着〰"]}, {"box": [206, 231, 240, 448], "vertical": true, "font_size": 26, "lines_coords": [[[208.0, 232.0], [234.0, 232.0], [234.0, 448.0], [208.0, 448.0]]], "lines": ["地味に歩いたね"]}, {"box": [1089, 631, 1199, 943], "vertical": true, "font_size": 31, "lines_coords": [[[1170.0, 633.0], [1198.0, 633.0], [1196.0, 943.0], [1168.0, 943.0]], [[1130.0, 635.0], [1162.0, 635.0], [1162.0, 883.0], [1130.0, 883.0]], [[1091.0, 631.0], [1123.0, 631.0], [1121.0, 885.0], [1089.0, 885.0]]], "lines": ["でもスポーツ自転車に", "興味出たからって", "何で道の駅なの？"]}, {"box": [285, 613, 392, 926], "vertical": true, "font_size": 31, "lines_coords": [[[360.0, 616.0], [391.0, 616.0], [391.0, 926.0], [360.0, 926.0]], [[320.0, 615.0], [352.0, 615.0], [352.0, 834.0], [320.0, 834.0]], [[285.0, 613.0], [316.0, 613.0], [316.0, 926.0], [285.0, 926.0]]], "lines": ["ここレンタサイクルで", "ロードバイクを", "貸し出してるんだって"]}, {"box": [168, 790, 196, 944], "vertical": true, "font_size": 27, "lines_coords": [[[168.0, 791.0], [195.0, 791.0], [195.0, 943.0], [168.0, 943.0]]], "lines": ["そうなんだ"]}, {"box": [1143, 1043, 1215, 1483], "vertical": true, "font_size": 32, "lines_coords": [[[1183.0, 1046.0], [1215.0, 1046.0], [1215.0, 1389.0], [1183.0, 1389.0]], [[1143.0, 1046.0], [1175.0, 1046.0], [1175.0, 1483.0], [1143.0, 1483.0]]], "lines": ["ちょっと興味出ただけで", "今すぐ買うって訳でもないから"]}, {"box": [590, 1048, 663, 1421], "vertical": true, "font_size": 30, "lines_coords": [[[633.0, 1050.0], [660.0, 1050.0], [660.0, 1421.0], [633.0, 1421.0]], [[590.0, 1048.0], [622.0, 1048.0], [622.0, 1297.0], [590.0, 1297.0]]], "lines": ["それに休み時間にめっちゃ", "検索したんだけど"]}, {"box": [708, 1366, 780, 1770], "vertical": true, "font_size": 27, "lines_coords": [[[750.0, 1370.0], [776.0, 1370.0], [776.0, 1770.0], [750.0, 1770.0]], [[708.0, 1366.0], [736.0, 1366.0], [738.0, 1770.0], [710.0, 1770.0]]], "lines": ["お店で試乗するのは冷やかし", "みたいになっちゃいそうだし、"]}, {"box": [139, 1385, 208, 1758], "vertical": true, "font_size": 29, "lines_coords": [[[176.0, 1387.0], [208.0, 1387.0], [208.0, 1758.0], [176.0, 1758.0]], [[140.0, 1389.0], [166.0, 1389.0], [166.0, 1726.0], [140.0, 1726.0]]], "lines": ["ロードバイクって専門店で", "売ってるものみたいでさ"]}], "img_path": "00083.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1141, 148, 1211, 427], "vertical": true, "font_size": 30, "lines_coords": [[[1179.0, 148.0], [1211.0, 148.0], [1211.0, 427.0], [1179.0, 427.0]], [[1141.0, 148.0], [1168.0, 148.0], [1168.0, 393.0], [1141.0, 393.0]]], "lines": ["何かそういう所って", "入りづらいじゃん"]}, {"box": [571, 251, 643, 643], "vertical": true, "font_size": 30, "lines_coords": [[[609.0, 251.0], [641.0, 251.0], [641.0, 643.0], [609.0, 643.0]], [[571.0, 251.0], [598.0, 251.0], [598.0, 590.0], [571.0, 590.0]]], "lines": ["今後何かの専門店行くこと。", "あったら頼むからね絵真"]}, {"box": [151, 150, 183, 360], "vertical": true, "font_size": 27, "lines_coords": [[[151.0, 150.0], [178.0, 150.0], [178.0, 358.0], [151.0, 358.0]]], "lines": ["いたしかたない"]}, {"box": [1153, 551, 1186, 646], "vertical": true, "font_size": 33, "lines_coords": [[[1153.0, 551.0], [1186.0, 551.0], [1186.0, 646.0], [1153.0, 646.0]]], "lines": ["分かる"]}, {"box": [993, 795, 1066, 918], "vertical": true, "font_size": 32, "lines_coords": [[[1035.0, 795.0], [1066.0, 795.0], [1066.0, 918.0], [1035.0, 918.0]], [[993.0, 796.0], [1027.0, 796.0], [1027.0, 918.0], [993.0, 918.0]]], "lines": ["なにこれ", "かわいい"]}, {"box": [701, 367, 773, 680], "vertical": true, "font_size": 32, "lines_coords": [[[740.0, 367.0], [772.0, 367.0], [770.0, 680.0], [738.0, 680.0]], [[701.0, 369.0], [733.0, 369.0], [733.0, 618.0], [701.0, 618.0]]], "lines": ["個人経営の専門店とか、", "絶対一人じゃ無理"]}, {"box": [172, 786, 253, 1076], "vertical": true, "font_size": 26, "lines_coords": [[[219.0, 787.0], [251.0, 787.0], [253.0, 1035.0], [221.0, 1035.0]], [[185.0, 787.0], [211.0, 787.0], [211.0, 945.0], [185.0, 945.0]], [[187.0, 935.0], [213.0, 935.0], [219.0, 1076.0], [193.0, 1076.0]], [[172.0, 969.0], [191.0, 969.0], [191.0, 1036.0], [172.0, 1036.0]]], "lines": ["ここのゆるキャラ", "じゃない？", "・ロードバイク", "抱いてる"]}, {"box": [1166, 1325, 1197, 1543], "vertical": true, "font_size": 26, "lines_coords": [[[1168.0, 1