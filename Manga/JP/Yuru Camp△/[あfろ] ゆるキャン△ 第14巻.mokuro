08.0, 913.0], [208.0, 1145.0], [176.0, 1145.0]]], "lines": ["あああん時の"]}, {"box": [1087, 1470, 1146, 1693], "vertical": true, "font_size": 26, "lines_coords": [[[1119.0, 1471.0], [1145.0, 1471.0], [1145.0, 1693.0], [1119.0, 1693.0]], [[1089.0, 1470.0], [1115.0, 1470.0], [1113.0, 1644.0], [1087.0, 1644.0]]], "lines": ["この間はありがとう", "ございました！"]}, {"box": [721, 1569, 778, 1770], "vertical": true, "font_size": 26, "lines_coords": [[[750.0, 1569.0], [776.0, 1569.0], [778.0, 1719.0], [751.0, 1719.0]], [[721.0, 1571.0], [746.0, 1571.0], [746.0, 1770.0], [721.0, 1770.0]]], "lines": ["もうええって", "授業間に合った？"]}, {"box": [198, 1484, 255, 1708], "vertical": true, "font_size": 25, "lines_coords": [[[228.0, 1485.0], [253.0, 1485.0], [253.0, 1666.0], [228.0, 1666.0]], [[198.0, 1485.0], [223.0, 1485.0], [223.0, 1708.0], [198.0, 1708.0]]], "lines": ["はい教頭先生に", "迎えに来てもらって"]}], "img_path": "00119.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1153, 146, 1211, 421], "vertical": true, "font_size": 22, "lines_coords": [[[1185.0, 148.0], [1205.0, 148.0], [1205.0, 273.0], [1185.0, 273.0]], [[1153.0, 146.0], [1177.0, 146.0], [1177.0, 418.0], [1153.0, 418.0]]], "lines": ["ん自転車が", "ロードハイクになっとる"]}, {"box": [669, 161, 733, 414], "vertical": true, "font_size": 31, "lines_coords": [[[695.0, 161.0], [733.0, 161.0], [733.0, 221.0], [695.0, 221.0]], [[669.0, 163.0], [693.0, 163.0], [693.0, 410.0], [669.0, 410.0]]], "lines": ["最近", "始めたばっかりなんス"]}, {"box": [564, 133, 621, 459], "vertical": true, "font_size": 25, "lines_coords": [[[592.0, 133.0], [618.0, 133.0], [620.0, 384.0], [594.0, 384.0]], [[564.0, 135.0], [588.0, 135.0], [588.0, 459.0], [564.0, 459.0]]], "lines": ["それで今日自転車部の", "体験入部に行ったんスけど．．．"]}, {"box": [1119, 654, 1181, 879], "vertical": true, "font_size": 26, "lines_coords": [[[1151.0, 654.0], [1177.0, 654.0], [1177.0, 875.0], [1151.0, 875.0]], [[1119.0, 656.0], [1145.0, 656.0], [1145.0, 879.0], [1119.0, 879.0]]], "lines": ["練習が厳しすぎて", "心が折れました．．．"]}, {"box": [251, 631, 285, 718], "vertical": true, "font_size": 28, "lines_coords": [[[251.0, 631.0], [285.0, 631.0], [285.0, 718.0], [251.0, 718.0]]], "lines": ["あぁー"]}, {"box": [151, 701, 241, 1050], "vertical": true, "font_size": 28, "lines_coords": [[[215.0, 703.0], [241.0, 703.0], [241.0, 1050.0], [215.0, 1050.0]], [[183.0, 701.0], [210.0, 701.0], [210.0, 1027.0], [183.0, 1027.0]], [[151.0, 703.0], [178.0, 703.0], [178.0, 995.0], [151.0, 995.0]]], "lines": ["うちの自転車部そこそこ強豪", "やからなぁ本栖みちばっか", "登るて聞いたことあるわ"]}, {"box": [1136, 1475, 1192, 1773], "vertical": true, "font_size": 24, "lines_coords": [[[1166.0, 1475.0], [1190.0, 1475.0], [1190.0, 1633.0], [1166.0, 1633.0]], [[1136.0, 1475.0], [1160.0, 1475.0], [1160.0, 1773.0], [1136.0, 1773.0]]], "lines": ["あれ？先輩は", "自転車部じゃないんスか？"]}, {"box": [735, 1560, 763, 1719], "vertical": true, "font_size": 26, "lines_coords": [[[736.0, 1560.0], [763.0, 1560.0], [761.0, 1719.0], [735.0, 1719.0]]], "lines": ["うん？違うで"]}], "img_path": "00120.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1091, 170, 1148, 472], "vertical": true, "font_size": 25, "lines_coords": [[[1121.0, 170.0], [1145.0, 170.0], [1145.0, 453.0], [1121.0, 453.0]], [[1091.0, 172.0], [1117.0, 172.0], [1117.0, 472.0], [1091.0, 472.0]]], "lines": ["なあ自転車部入らんなら", "うちのサークルこーへん？"]}, {"box": [688, 236, 744, 483], "vertical": true, "font_size": 23, "lines_coords": [[[718.0, 236.0], [744.0, 236.0], [742.0, 483.0], [716.0, 483.0]], [[688.0, 236.0], [708.0, 236.0], [708.0, 358.0], [688.0, 358.0]]], "lines": ["アウトドアのサークル", "なんやけど"]}, {"box": [298, 189, 327, 412], "vertical": true, "font_size": 26, "lines_coords": [[[298.0, 189.0], [324.0, 189.0], [324.0, 412.0], [298.0, 412.0]]], "lines": ["アウトドアっスか？"]}, {"box": [1066, 684, 1128, 825], "vertical": true, "font_size": 26, "lines_coords": [[[1102.0, 684.0], [1128.0, 684.0], [1128.0, 823.0], [1102.0, 823.0]], [[1066.0, 686.0], [1093.0, 686.0], [1093.0, 825.0], [1066.0, 825.0]]], "lines": ["リンちゃん", "おまたせー"]},