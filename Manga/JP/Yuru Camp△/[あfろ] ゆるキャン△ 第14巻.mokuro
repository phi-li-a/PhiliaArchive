0], [834.0, 294.0], [834.0, 324.0], [630.0, 324.0]]], "lines": ["のんびりしてきた"]}, {"box": [660, 376, 945, 466], "vertical": false, "font_size": 25, "lines_coords": [[[667.0, 380.0], [935.0, 380.0], [935.0, 405.0], [667.0, 405.0]], [[667.0, 410.0], [935.0, 410.0], [935.0, 435.0], [667.0, 435.0]], [[667.0, 440.0], [864.0, 440.0], [864.0, 466.0], [667.0, 466.0]]], "lines": ["少しだけど桜が嘆いてて", "いい感じの場所だったよ", "温泉も良かったし"]}, {"box": [810, 879, 1182, 960], "vertical": false, "font_size": 22, "lines_coords": [[[813.0, 883.0], [1175.0, 883.0], [1175.0, 901.0], [813.0, 901.0]], [[815.0, 907.0], [1091.0, 907.0], [1091.0, 931.0], [815.0, 931.0]], [[810.0, 935.0], [1003.0, 935.0], [1003.0, 960.0], [810.0, 960.0]]], "lines": ["あとお十差にもらった『日曜のトマトで", "トマトバスタ作つたんだけど", "めっちゃうまかった"]}, {"box": [736, 518, 1064, 552], "vertical": false, "font_size": 26, "lines_coords": [[[738.0, 523.0], [1061.0, 523.0], [1061.0, 549.0], [738.0, 549.0]]], "lines": ["富士川町の山の方だっけ？"]}, {"box": [647, 611, 760, 646], "vertical": false, "font_size": 33, "lines_coords": [[[650.0, 613.0], [757.0, 613.0], [757.0, 646.0], [650.0, 646.0]]], "lines": ["うんそう"]}, {"box": [260, 884, 631, 916], "vertical": false, "font_size": 25, "lines_coords": [[[264.0, 890.0], [628.0, 890.0], [628.0, 915.0], [264.0, 915.0]]], "lines": ["そっちのキャンブ場はどんな感じ？"]}, {"box": [171, 980, 523, 1035], "vertical": false, "font_size": 60, "lines_coords": [[[171.0, 975.0], [523.0, 975.0], [523.0, 1040.0], [171.0, 1040.0]]], "lines": ["聞いてた通り投げたくさん使いててあんまり人も居ない人に気になることも"]}, {"box": [172, 980, 521, 1035], "vertical": false, "font_size": 24, "lines_coords": [[[174.0, 982.0], [519.0, 982.0], [519.0, 1006.0], [174.0, 1006.0]], [[174.0, 1008.0], [519.0, 1008.0], [519.0, 1033.0], [174.0, 1033.0]]], "lines": ["聞いてた通り桜がたくさん咲いてて", "あんまり人も居ないいし穴場だなここ"]}, {"box": [172, 1104, 518, 1134], "vertical": false, "font_size": 24, "lines_coords": [[[178.0, 1108.0], [517.0, 1108.0], [517.0, 1132.0], [178.0, 1132.0]]], "lines": ["ていうか穴場過ぎて今私しかいねぇ"]}, {"box": [291, 1194, 382, 1228], "vertical": false, "font_size": 30, "lines_coords": [[[296.0, 1194.0], [376.0, 1194.0], [376.0, 1226.0], [296.0, 1226.0]]], "lines": ["（上）"]}, {"box": [161, 1181, 200, 1196], "vertical": false, "font_size": 15, "lines_coords": [[[161.0, 1181.0], [200.0, 1181.0], [200.0, 1196.0], [161.0, 1196.0]]], "lines": ["２０：１０"]}, {"box": [743, 1476, 1077, 1539], "vertical": false, "font_size": 27, "lines_coords": [[[744.0, 1477.0], [1072.0, 1479.0], [1072.0, 1505.0], [744.0, 1503.0]], [[744.0, 1507.0], [868.0, 1511.0], [868.0, 1539.0], [744.0, 1535.0]]], "lines": ["おリンはパス夕に使ったのか", "いいじゃん"]}, {"box": [730, 1571, 1077, 1660], "vertical": false, "font_size": 25, "lines_coords": [[[735.0, 1573.0], [1074.0, 1573.0], [1074.0, 1597.0], [735.0, 1597.0]], [[733.0, 1603.0], [1074.0, 1603.0], [1074.0, 1629.0], [733.0, 1629.0]], [[731.0, 1635.0], [950.0, 1635.0], [950.0, 1659.0], [731.0, 1659.0]]], "lines": ["トマトは生で食うのもいいけど", "じっくり煮込むと旨味が増して", "たまんなしそんだよな"]}, {"box": [856, 1705, 952, 1738], "vertical": false, "font_size": 28, "lines_coords": [[[858.0, 1710.0], [943.0, 1710.0], [943.0, 1738.0], [858.0, 1738.0]]], "lines": ["わかる"]}, {"box": [854, 1705, 950, 1738], "vertical": false, "font_size": 36, "lines_coords": [[[854.0, 1702.0], [950.0, 1702.0], [950.0, 1741.0], [854.0, 1741.0]]], "lines": ["わかる。"]}, {"box": [725, 1689, 768, 1710], "vertical": false, "font_size": 21, "lines_coords": [[[725.0, 1689.0], [768.0, 1689.0], [768.0, 1710.0], [725.0, 1710.0]]], "lines": ["２０：０９"]}], "img_path": "00039.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [314, 178, 658, 232], "vertical": false, "font_size": 24, "lines_coords": [[[315.0, 181.0], [658.0, 181.0], [658.0, 206.0], [315.0, 206.0]], [[316.0, 208.0], [532.0, 208.0], [532.0, 232.0], [316.0, 232.0]]], "lines": ["んで花見しながらサラトガクーラー", "飲んでまったりしてた"]}, {"box": [248, 364, 650, 398], "vertical": false, "font_size": 26, "lines_coords": [[[251.0, 367.0], [639.0, 365.0], [639.0, 391.0], [251.0, 393.0]]], "lines": ["ジン