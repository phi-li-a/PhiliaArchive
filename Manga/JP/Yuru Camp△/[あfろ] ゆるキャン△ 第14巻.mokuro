 813.0], [631.0, 813.0]], [[598.0, 448.0], [622.0, 448.0], [622.0, 896.0], [598.0, 896.0]]], "lines": ["しかし２人分を２種類かぁ．．．", "昼休み内に下ごしらえ間に合うか？"]}, {"box": [159, 580, 227, 763], "vertical": true, "font_size": 26, "lines_coords": [[[198.0, 581.0], [225.0, 581.0], [225.0, 763.0], [198.0, 763.0]], [[159.0, 583.0], [185.0, 583.0], [185.0, 735.0], [159.0, 735.0]]], "lines": ["そこは３人で", "がんばろ！！"]}, {"box": [999, 943, 1170, 1318], "vertical": true, "font_size": 31, "lines_coords": [[[1136.0, 945.0], [1170.0, 945.0], [1170.0, 1068.0], [1136.0, 1068.0]], [[1074.0, 946.0], [1108.0, 946.0], [1110.0, 1291.0], [1076.0, 1291.0]], [[1038.0, 948.0], [1066.0, 948.0], [1068.0, 1318.0], [1040.0, 1318.0]], [[1001.0, 950.0], [1029.0, 950.0], [1027.0, 1166.0], [999.0, 1166.0]]], "lines": ["なでしこ", "材料費計算したって事は", "もう使う材料リストアップ", "してあるのか？"]}, {"box": [650, 1057, 691, 1132], "vertical": true, "font_size": 41, "lines_coords": [[[650.0, 1057.0], [691.0, 1057.0], [691.0, 1132.0], [650.0, 1132.0]]], "lines": ["うん"]}, {"box": [748, 1363, 823, 1490], "vertical": true, "font_size": 36, "lines_coords": [[[783.0, 1363.0], [823.0, 1363.0], [823.0, 1464.0], [783.0, 1464.0]], [[748.0, 1365.0], [780.0, 1365.0], [780.0, 1490.0], [748.0, 1490.0]]], "lines": ["うん！", "やろう！"]}, {"box": [185, 943, 295, 1287], "vertical": true, "font_size": 32, "lines_coords": [[[262.0, 943.0], [294.0, 943.0], [292.0, 1224.0], [260.0, 1224.0]], [[225.0, 945.0], [256.0, 945.0], [256.0, 1286.0], [225.0, 1286.0]], [[187.0, 945.0], [219.0, 945.0], [217.0, 1164.0], [185.0, 1164.0]]], "lines": ["トマトもお父さんが", "今日買ってくるはずだし", "バッチリだよ！！"]}, {"box": [1096, 1378, 1194, 1740], "vertical": true, "font_size": 26, "lines_coords": [[[1166.0, 1381.0], [1192.0, 1381.0], [1192.0, 1685.0], [1166.0, 1685.0]], [[1130.0, 1378.0], [1156.0, 1378.0], [1156.0, 1603.0], [1130.0, 1603.0]], [[1096.0, 1380.0], [1123.0, 1380.0], [1123.0, 1740.0], [1096.0, 1740.0]]], "lines": ["んじゃ今から他の材料も", "買い出しに行って", "明日早速ビザ会やっちまうか"]}, {"box": [388, 1387, 450, 1751], "vertical": t