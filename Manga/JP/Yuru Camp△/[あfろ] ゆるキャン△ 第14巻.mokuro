0], [1149.0, 1365.0], [1123.0, 1365.0]]], "lines": ["そんでもって帰りは", "うちのお父さんに", "迎えの車を頼んだから"]}, {"box": [524, 1134, 553, 1291], "vertical": true, "font_size": 27, "lines_coords": [[[526.0, 1134.0], [553.0, 1134.0], [553.0, 1173.0], [526.0, 1173.0]]], "lines": ["う"]}, {"box": [178, 1143, 213, 1395], "vertical": true, "font_size": 32, "lines_coords": [[[178.0, 1143.0], [210.0, 1143.0], [211.0, 1393.0], [180.0, 1393.0]]], "lines": ["７０キロっスかぁ．．．"]}, {"box": [641, 1470, 742, 1751], "vertical": true, "font_size": 28, "lines_coords": [[[710.0, 1471.0], [742.0, 1471.0], [742.0, 1698.0], [710.0, 1698.0]], [[675.0, 1470.0], [703.0, 1470.0], [705.0, 1751.0], [676.0, 1751.0]], [[641.0, 1470.0], [665.0, 1470.0], [665.0, 1751.0], [641.0, 1751.0]]], "lines": ["ロードで走るのは", "行きの７０キロだけって", "考えてくれたらええわ"]}], "img_path": "00141.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1179, 144, 1208, 378], "vertical": true, "font_size": 26, "lines_coords": [[[1179.0, 144.0], [1205.0, 144.0], [1205.0, 378.0], [1179.0, 378.0]]], "lines": ["そういやなでしこ"]}, {"box": [712, 136, 775, 555], "vertical": true, "font_size": 26, "lines_coords": [[[748.0, 136.0], [774.0, 136.0], [774.0, 555.0], [748.0, 555.0]], [[712.0, 136.0], [738.0, 136.0], [738.0, 472.0], [712.0, 472.0]]], "lines": ["ダイエットしたって言ってたけど", "そん時はどうだったんだ？"]}, {"box": [585, 144, 648, 478], "vertical": true, "font_size": 26, "lines_coords": [[[618.0, 146.0], [645.0, 146.0], [645.0, 478.0], [618.0, 478.0]], [[585.0, 144.0], [611.0, 144.0], [611.0, 397.0], [585.0, 397.0]]], "lines": ["浜名湖って結構でかいから", "距離あるはずだろ？"]}, {"box": [1149, 470, 1214, 720], "vertical": true, "font_size": 26, "lines_coords": [[[1185.0, 470.0], [1211.0, 470.0], [1211.0, 720.0], [1185.0, 720.0]], [[1149.0, 470.0], [1175.0, 470.0], [1175.0, 720.0], [1149.0, 720.0]]], "lines": ["昔夏休みにチャリで", "毎日浜名湖一周して"]}, {"box": [1138, 806, 1170, 1025], "vertical": true, "font_size": 32, "lines_coords": [[[1138.0, 808.0], [1170.0, 808.0], [1170.0, 1025.0], [1138.0, 