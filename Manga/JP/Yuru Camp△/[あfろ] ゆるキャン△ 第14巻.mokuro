.0, 271.0]]], "lines": ["それじゃ"]}, {"box": [165, 221, 192, 419], "vertical": true, "font_size": 26, "lines_coords": [[[165.0, 223.0], [191.0, 223.0], [191.0, 418.0], [165.0, 418.0]]], "lines": ["ビックリした．．．"]}, {"box": [1115, 365, 1207, 639], "vertical": true, "font_size": 25, "lines_coords": [[[1181.0, 365.0], [1205.0, 365.0], [1205.0, 564.0], [1181.0, 564.0]], [[1151.0, 365.0], [1175.0, 365.0], [1175.0, 639.0], [1151.0, 639.0]], [[1115.0, 365.0], [1141.0, 365.0], [1145.0, 491.0], [1119.0, 491.0]]], "lines": ["今から自転車部の", "体験入部行ってくるから", "またね絵真"]}, {"box": [729, 496, 789, 624], "vertical": true, "font_size": 30, "lines_coords": [[[755.0, 496.0], [789.0, 496.0], [789.0, 588.0], [755.0, 588.0]], [[729.0, 500.0], [755.0, 500.0], [755.0, 622.0], [729.0, 622.0]]], "lines": ["ううん", "がんばって"]}, {"box": [841, 791, 875, 885], "vertical": true, "font_size": 34, "lines_coords": [[[841.0, 791.0], [875.0, 791.0], [875.0, 885.0], [841.0, 885.0]]], "lines": ["よっと"]}, {"box": [684, 778, 714, 1030], "vertical": true, "font_size": 26, "lines_coords": [[[684.0, 778.0], [710.0, 778.0], [712.0, 1029.0], [686.0, 1029.0]]], "lines": ["薪もだいぶ割れたなぁ"]}, {"box": [382, 909, 466, 960], "vertical": false, "font_size": 51, "lines_coords": [[[382.0, 909.0], [466.0, 909.0], [466.0, 960.0], [382.0, 960.0]]], "lines": ["ふぅっ"]}, {"box": [151, 915, 208, 1216], "vertical": true, "font_size": 26, "lines_coords": [[[181.0, 916.0], [208.0, 916.0], [208.0, 1215.0], [181.0, 1215.0]], [[151.0, 915.0], [176.0, 915.0], [176.0, 1215.0], [151.0, 1215.0]]], "lines": ["この調子なら４月中に全部", "片付いてまうかもしれんね"]}], "img_path": "00115.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1149, 140, 1212, 521], "vertical": true, "font_size": 29, "lines_coords": [[[1183.0, 144.0], [1209.0, 144.0], [1209.0, 444.0], [1183.0, 444.0]], [[1149.0, 146.0], [1181.0, 146.0], [1181.0, 521.0], [1149.0, 521.0]]], "lines": ["あれから一週間も経つのに", "一人も八郎君真の１年が来ねぇ．．．"]}, {"box": [710, 363, 762, 526], "vertical": true, "font_size": 23, "lines_coords": [[[740.0, 365.0], [761.0, 365.0], [761.0, 487.0], [740.0, 487.0]], [[710.0, 363.0], [735.0, 363.0], [735.0, 526.0], [710.0, 526.0]]], "lines": ["ままぁまぁ", "まだ一週間やし"]}, {"box": [593, 311, 657, 583], "vertical": true, "font_size": 29, "lines_coords": [[[624.0, 311.0], [656.0, 311.0], [654.0, 583.0], [622.0, 583.0]], [[594.0, 316.0], [620.0, 316.0], [620.0, 528.0], [594.0, 528.0]]], "lines": ["ピザあんまり美味しく", "なかったのかな．．．"]}, {"box": [204, 178, 230, 309], "vertical": true, "font_size": 25, "lines_coords": [[[204.0, 178.0], [230.0, 178.0], [230.0, 309.0], [204.0, 309.0]]], "lines": ["いいやいや"]}, {"box": [135, 318, 191, 521], "vertical": true, "font_size": 25, "lines_coords": [[[163.0, 318.0], [189.0, 318.0], [191.0, 521.0], [165.0, 521.0]], [[135.0, 320.0], [159.0, 320.0], [159.0, 496.0], [135.0, 496.0]]], "lines": ["みんなうまいって", "喜んどったやん"]}, {"box": [1070, 650, 1097, 875], "vertical": true, "font_size": 26, "lines_coords": [[[1070.0, 650.0], [1096.0, 650.0], [1096.0, 875.0], [1070.0, 875.0]]], "lines": ["あのー．．．すみません"]}, {"box": [275, 628, 333, 903], "vertical": true, "font_size": 26, "lines_coords": [[[305.0, 628.0], [330.0, 628.0], [330.0, 875.0], [305.0, 875.0]], [[275.0, 630.0], [301.0, 630.0], [301.0, 903.0], [275.0, 903.0]]], "lines": ["もしかしてこの前ビザ", "焼いてた先輩方ですか？"]}, {"box": [1173, 946, 1200, 1085], "vertical": true, "font_size": 27, "lines_coords": [[[1173.0, 946.0], [1200.0, 946.0], [1200.0, 1085.0], [1173.0, 1085.0]]], "lines": ["やっぱり！！"]}, {"box": [1074, 1078, 1138, 1359], "vertical": true, "font_size": 27, "lines_coords": [[[1111.0, 1080.0], [1138.0, 1080.0], [1138.0, 1359.0], [1111.0, 1359.0]], [[1074.0, 1078.0], [1100.0, 1078.0], [1100.0, 1331.0], [1074.0, 1331.0]]], "lines": ["この間のエビカドビザ", "美味しかったです！！"]}, {"box": [343, 948, 403, 1125], "vertical": true, "font_size": 27, "lines_coords": [[[371.0, 948.0], [399.0, 948.0], [403.0, 1125.0], [375.0, 1125.0]], [[345.0, 948.0], [371.0, 948.0], [369.0, 1102.0], [343.0, 1102.0]]], "lines": ["私はトマトピザ",