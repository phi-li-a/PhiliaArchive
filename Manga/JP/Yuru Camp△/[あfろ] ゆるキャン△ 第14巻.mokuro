029, 1447, 1081, 1556], "vertical": true, "font_size": 24, "lines_coords": [[[1053.0, 1447.0], [1081.0, 1447.0], [1081.0, 1516.0], [1053.0, 1516.0]], [[1029.0, 1449.0], [1050.0, 1449.0], [1050.0, 1556.0], [1029.0, 1556.0]]], "lines": ["これは", "鶏の唐揚げ"]}, {"box": [1063, 1633, 1115, 1741], "vertical": true, "font_size": 24, "lines_coords": [[[1087.0, 1633.0], [1115.0, 1633.0], [1115.0, 1704.0], [1087.0, 1704.0]], [[1063.0, 1635.0], [1083.0, 1635.0], [1083.0, 1741.0], [1063.0, 1741.0]]], "lines": ["これは", "鶏の唐揚げ"]}, {"box": [592, 1475, 645, 1584], "vertical": true, "font_size": 24, "lines_coords": [[[618.0, 1475.0], [645.0, 1475.0], [645.0, 1546.0], [618.0, 1546.0]], [[592.0, 1477.0], [613.0, 1477.0], [613.0, 1584.0], [592.0, 1584.0]]], "lines": ["これは", "頭の唐揚げ"]}, {"box": [530, 1640, 585, 1753], "vertical": true, "font_size": 28, "lines_coords": [[[551.0, 1640.0], [585.0, 1640.0], [585.0, 1715.0], [551.0, 1715.0]], [[530.0, 1644.0], [551.0, 1644.0], [551.0, 1753.0], [530.0, 1753.0]]], "lines": ["これは", "鶏の唐揚げ"]}, {"box": [223, 1465, 256, 1683], "vertical": true, "font_size": 26, "lines_coords": [[[225.0, 1466.0], [251.0, 1466.0], [251.0, 1681.0], [225.0, 1681.0]]], "lines": ["暗示かけとる．．．"]}], "img_path": "00050.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1098, 151, 1222, 416], "vertical": true, "font_size": 25, "lines_coords": [[[1194.0, 151.0], [1220.0, 151.0], [1220.0, 390.0], [1194.0, 390.0]], [[1162.0, 151.0], [1188.0, 151.0], [1188.0, 416.0], [1162.0, 416.0]], [[1128.0, 151.0], [1155.0, 151.0], [1155.0, 390.0], [1128.0, 390.0]], [[1100.0, 153.0], [1121.0, 153.0], [1121.0, 286.0], [1100.0, 286.0]]], "lines": ["癖のあるラムの方が", "ジンギスカンらしいし", "私はラム肉メインで", "行くかな～"]}, {"box": [857, 142, 930, 394], "vertical": true, "font_size": 36, "lines_coords": [[[885.0, 142.0], [930.0, 142.0], [930.0, 206.0], [885.0, 206.0]], [[858.0, 146.0], [885.0, 146.0], [885.0, 393.0], [858.0, 393.0]]], "lines": ["おっ", "あきちゃん通だねぃ"]}, {"box": [694, 142, 787, 412], "vertical": true, "font_size": 28, "lines_coords": [[[759.0, 146.0], [785.0, 146.0], [785.0, 331.0], [759.0, 331.0]], [[725.0, 142.0], [757.0, 142.0], [753.0, 412.0], [721.0, 412.0]], [[695.0, 148.0], [720.0, 148.0], [720.0, 360.0], [695.0, 360.0]]], "lines": ["私はラムも豚も", "どっちも大好きだから", "両方いただきます"]}, {"box": [556, 146, 650, 384], "vertical": true, "font_size": 28, "lines_coords": [[[618.0, 146.0], [650.0, 146.0], [650.0, 309.0], [618.0, 309.0]], [[586.0, 148.0], [613.0, 148.0], [613.0, 382.0], [586.0, 382.0]], [[556.0, 148.0], [581.0, 148.0], [581.0, 361.0], [556.0, 361.0]]], "lines": ["私はラムより", "豚の方が好きだから", "豚メインにするよ"]}, {"box": [136, 138, 268, 406], "vertical": true, "font_size": 28, "lines_coords": [[[232.0, 138.0], [268.0, 138.0], [268.0, 198.0], [232.0, 198.0]], [[202.0, 140.0], [228.0, 140.0], [228.0, 380.0], [202.0, 380.0]], [[170.0, 142.0], [195.0, 142.0], [195.0, 352.0], [170.0, 352.0]], [[136.0, 140.0], [163.0, 140.0], [163.0, 406.0], [136.0, 406.0]]], "lines": ["じゃ", "私もそうしようかな", "実はちょっとだけ", "苦手なんだよねラム肉"]}, {"box": [1155, 742, 1215, 1033], "vertical": true, "font_size": 26, "lines_coords": [[[1188.0, 742.0], [1215.0, 742.0], [1215.0, 988.0], [1188.0, 988.0]], [[1155.0, 742.0], [1181.0, 742.0], [1181.0, 1033.0], [1155.0, 1033.0]]], "lines": ["恵那ちゃんラム肉の", "何がそんなに苦手なん？"]}, {"box": [626, 741, 686, 1096], "vertical": true, "font_size": 26, "lines_coords": [[[658.0, 742.0], [684.0, 742.0], [684.0, 1095.0], [658.0, 1095.0]], [[626.0, 744.0], [652.0, 744.0], [652.0, 1061.0], [626.0, 1061.0]]], "lines": ["あおいちゃんジンギスカンに", "臭みなんてあったかなぁ？"]}, {"box": [303, 763, 330, 873], "vertical": true, "font_size": 27, "lines_coords": [[[303.0, 763.0], [330.0, 763.0], [330.0, 873.0], [303.0, 873.0]]], "lines": ["さぁねぇ"]}, {"box": [1095, 1265, 1177, 1586], "vertical": true, "font_size": 35, "lines_coords": [[[1141.0, 1269.0], [1175.0, 1269.0], [1173.0, 1586.0], [1140.0, 1586.0]], [[1095.0, 1265.0], [1132.0, 1265.0], [1132.0, 1518.0], [1095.0, 1518.0]]], "lines": ["それではみなさん、", "始めましょうか"]}, {"box": [736, 948, 795, 1186], "vertical": true, "font_size": 27, "lines_coords": [[[768.0, 948.0], [795.0, 948.0], [795.0, 1059.0], [768.0, 1059.0]], [[736.0, 948.0], [763.0, 948.0], [763.0, 1186.0], [736.0, 1186.0]]], "lines": ["うーん．．．", "あの独特の臭みかな"]}, {"box": [213, 930, 273, 1168], "vertical": true, "font_size": 28, "lines_coords": [[[247.0, 930.0], [273.0, 930.0], [273.0, 1168.0], [247.0, 1168.0]], [[213.0, 930.0], [240.0, 930.0], [240.0, 1166.0], [213.0, 1166.0]]], "lines": ["うちら小さい頃から", "よう食べとったから"]}, {"box": [131, 870, 195, 1164], "vertical": true, "font_size": 28, "lines_coords": [[[155.0, 871.0], [191.0, 870.0], [195.0, 956.0], [159.0, 958.0]], [[131.0, 873.0], [155.0, 873.0], [155.0, 1164.0], [131.0, 1164.0]]], "lines": ["たぶん", "慣れてしまったんやろな"]}, {"box": [225, 1267, 266, 1528], "vertical": true, "font_size": 37, "lines_coords": [[[225.0, 1267.0], [262.0, 1267.0], [262.0, 1524.0], [225.0, 1524.0]]], "lines": ["いただきまーす"]}], "img_path": "00051.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1171, 165, 1203, 290], "vertical": true, "font_size": 30, "lines_coords": [[[1171.0, 165.0], [1203.0, 165.0], [1203.0, 290.0], [1171.0, 290.0]]], "lines": ["そうそう"]}, {"box": [1091, 245, 1158, 526], "vertical": true, "font_size": 30, "lines_coords": [[[1132.0, 245.0], [1158.0, 245.0], [1158.0, 526.0], [1132.0, 526.0]], [[1091.0, 249.0], [1123.0, 249.0], [1123.0, 438.0], [1091.0, 438.0]]], "lines": ["こうやって下の方に", "野菜を置いて"]}, {"box": [279, 185, 408, 451], "vertical": true, "font_size": 26, "lines_coords": [[[380.0, 187.0], [406.0, 187.0], [406.0, 450.0], [380.0, 450.0]], [[346.0, 187.0], [373.0, 187.0], [373.0, 345.0], [346.0, 345.0]], [[311.0, 185.0], [337.0, 185.0], [341.0, 450.0], [315.0, 450.0]], [[279.0, 185.0], [305.0, 185.0], [307.0, 371.0], [281.0, 371.0]]], "lines": ["上の方でお肉を焼くと、", "垂れたお汁が", "野菜の方に染み込んで", "うまいんよねぇ"]}, {"box": [159, 330, 225, 588], "vertical": true, "font_size": 29, "lines_coords": [[[193.0, 330.0], [225.0, 330.0], [225.0, 588.0], [193.0, 588.0]], [[159.0, 330.0], [185.0, 330.0], [185.0, 498.0], [159.0, 498.0]]], "lines": ["やっぱり詳しいねぇ", "あかりちゃん"]}, {"box": [1162, 747, 1190, 939], "vertical": true, "font_size": 26, "lines_coords": [[[1162.0, 748.0], [1188.0, 748.0], [1188.0, 939.0], [1162.0, 939.0]]], "lines": ["んーっおいひい"]}, {"box": [1014, 740, 1042, 909], "vertical": true, "font_size": 26, "lines_coords": [[[1014.0, 740.0], [1040.0, 740.0], [1040.0, 907.0], [1014.0, 907.0]]], "lines": ["ラム肉うめ〰"]}, {"box": [832, 715, 885, 948], "vertical": true, "font_size": 24, "lines_coords": [[[860.0, 718.0], [885.0, 718.0], [885.0, 905.0], [860.0, 905.0]], [[832.0, 716.0], [856.0, 716.0], [856.0, 948.0], [832.0, 948.0]]], "lines": ["豚の方もちゃんと", "タレに合っててうまし"]}, {"box": [708, 750, 736, 915], "vertical": true, "font_size": 27, "lines_coords": [[[708.0, 750.0], [735.0, 750.0], [735.0, 915.0], [708.0, 915.0]]], "lines": ["おいひいねぇ"]}, {"box": [577, 774, 635, 1121], "vertical": true, "font_size": 24, "lines_coords": [[[607.0, 776.0], [631.0, 776.0], [631.0, 1121.0], [607.0, 1121.0]], [[577.0, 774.0], [601.0, 774.0], [601.0, 1072.0], [577.0, 1072.0]]], "lines": ["お花見しながらのジンギスカン", "なかなかいいものですねえ"]}, {"box": [136, 930, 200, 1125], "vertical": true, "font_size": 26, "lines_coords": [[[170.0, 931.0], [196.0, 931.0], [196.0, 1072.0], [170.0, 1072.0]], [[136.0, 931.0], [163.0, 931.0], [163.0, 1125.0], [136.0, 1125.0]]], "lines": ["来年も是非", "やりましょう！"]}, {"box": [1093, 1284, 1175, 1635], "vertical": true, "font_size": 38, "lines_coords": [[[1132.0, 1284.0], [1171.0, 1284.0], [1175.0, 1428.0], [1136.0, 1428.0]], [[1093.0, 1286.0], [1130.0, 1286.0], [1130.0, 1633.0], [1093.0, 1633.0]]], "lines": ["あれっ？", "二人ともどうしたの？"]}], "img_path": "00052.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1145, 140, 1216, 453], "vertical": true, "font_size": 32, "lines_coords": [[[1183.0, 140.0], [1215.0, 140.0], [1216.0, 450.0], [1185.0, 450.0]], [[1145.0, 142.0], [1177.0, 142.0], [1177.0, 453.0], [1145.0, 453.0]]], "lines": ["もしもしおばあちゃん", "今キャンプしとってな"]}, {"box": [157, 159, 219, 551], "vertical": true, "font_size": 26, "lines_coords": [[[191.0, 159.0], [217.0, 159.0], [217.0, 551.0], [191.0, 551.0]], [[157.0, 159.0], [183.0, 159.0], [183.0, 438.0], [157.0, 438.0]]], "lines": ["なんかうちのジンギスカンとは", "ぜんぜん味が違うんよ"]}, {"box": [1066, 781, 1130, 1072], "vertical": true, "font_size": 24, "lines_coords": [[[1102.0, 781.0], [1126.0, 781.0], [1126.0, 1072.0], [1102.0, 1072.0]], [[1066.0, 783.0], [1091.0, 783.0], [1091.0, 1035.0], [1066.0, 1035.0]]], "lines": ["それでな先生が豚肉を", "ジンギスカンだれに"]}, {"box": [705, 444, 775, 751], "vertical": true, "font_size": 28, "lines_coords": [[[744.0, 448.0], [770.0, 448.0], [770.0, 751.0], [744.0, 751.0]], [[705.0, 446.0], [736.0, 446.0], [736.0, 695.0], [705.0, 695.0]]], "lines": ["みんなでジンギスカン", "食べとるんやけど"]}, {"box": [1128, 1179, 1184, 1678], "vertical": true, "font_size": 51, "lines_coords": [[[1128.0, 1179.0], [1179.0, 1179.0], [1179.0, 1678.0], [1128.0, 1678.0]]], "lines": ["そっち焼いて食べたら"]}, {"box": [219, 830, 277, 1109], "vertical": true, "font_size": 25, "lines_coords": [[[247.0, 830.0], [273.0, 830.0], [277.0, 1108.0], [251.0, 1108.0]], [[219.0, 832.0], [243.0, 832.0], [243.0, 1008.0], [219.0, 1008.0]]], "lines": ["漬けたものも持ってきて", "くれたんやけど"]}, {"box": [142, 1200, 277, 1747], "vertical": true, "font_size": 59, "lines_coords": [[[215.0, 1200.0], [273.0, 1200.0], [277.0, 1747.0], [219.0, 1747.0]], [[150.0, 1200.0], [210.0, 1200.0], [202.0, 1590.0], [142.0, 1590.0]]], "lines": ["そうちのジンギスカンの", "味がするんよ！！"]}], "img_path": "00053.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1061, 91, 1121, 367], "vertical": true, "font_size": 28, "lines_coords": [[[1089.0, 91.0], [1121.0, 91.0], [1121.0, 198.0], [1089.0, 198.0]], [[1061.0, 95.0], [1085.0, 95.0], [1085.0, 367.0], [1061.0, 367.0]]], "lines": ["あおい．．．", "ついに気づいてもうたか"]}, {"box": [256, 91, 311, 372], "vertical": true, "font_size": 24, "lines_coords": [[[2