 [1100.0, 742.0], [830.0, 742.0]]], "lines": ["キャンプ場ついたー"]}, {"box": [829, 780, 1113, 852], "vertical": false, "font_size": 28, "lines_coords": [[[830.0, 780.0], [1106.0, 780.0], [1106.0, 811.0], [830.0, 811.0]], [[834.0, 821.0], [1042.0, 821.0], [1042.0, 847.0], [834.0, 847.0]]], "lines": ["今から初めノロキャン", "開始するぜー！！"]}, {"box": [656, 1389, 695, 1486], "vertical": true, "font_size": 39, "lines_coords": [[[656.0, 1389.0], [695.0, 1389.0], [695.0, 1486.0], [656.0, 1486.0]]], "lines": ["そうだ"]}], "img_path": "00024.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [172, 208, 236, 431], "vertical": true, "font_size": 26, "lines_coords": [[[208.0, 211.0], [234.0, 211.0], [234.0, 406.0], [208.0, 406.0]], [[172.0, 208.0], [198.0, 208.0], [200.0, 431.0], [174.0, 431.0]]], "lines": ["車から見るのは", "また違うんだよぅ"]}, {"box": [1151, 436, 1186, 526], "vertical": true, "font_size": 28, "lines_coords": [[[1151.0, 436.0], [1186.0, 436.0], [1186.0, 526.0], [1151.0, 526.0]]], "lines": ["おおー"]}, {"box": [1072, 476, 1132, 671], "vertical": true, "font_size": 28, "lines_coords": [[[1106.0, 476.0], [1132.0, 476.0], [1132.0, 671.0], [1106.0, 671.0]], [[1072.0, 476.0], [1096.0, 476.0], [1096.0, 671.0], [1072.0, 671.0]]], "lines": ["やっぱり盆地の", "夜景はいいねぇ"]}, {"box": [442, 446, 505, 667], "vertical": true, "font_size": 26, "lines_coords": [[[478.0, 448.0], [504.0, 448.0], [504.0, 613.0], [478.0, 613.0]], [[442.0, 446.0], [468.0, 446.0], [468.0, 667.0], [442.0, 667.0]]], "lines": ["鳥居焼の所で", "十分見たじゃない"]}, {"box": [639, 781, 667, 965], "vertical": true, "font_size": 26, "lines_coords": [[[639.0, 781.0], [665.0, 781.0], [665.0, 965.0], [639.0, 965.0]]], "lines": ["わかってるよー"]}, {"box": [1158, 806, 1215, 1156], "vertical": true, "font_size": 27, "lines_coords": [[[1186.0, 806.0], [1213.0, 806.0], [1215.0, 1156.0], [1188.0, 1156.0]], [[1158.0, 810.0], [1185.0, 810.0], [1185.0, 1130.0], [1158.0, 1130.0]]], "lines": ["そろそろリンちゃんの言ってた", "天文字焼きが見える頃でしょ"]}, {"box": [1087, 993, 1113, 1