1.0], [545.0, 191.0], [545.0, 279.0], [510.0, 279.0]]], "lines": ["ハヤシ"]}, {"box": [294, 189, 331, 283], "vertical": true, "font_size": 34, "lines_coords": [[[294.0, 191.0], [328.0, 189.0], [331.0, 281.0], [298.0, 283.0]]], "lines": ["うまし"]}, {"box": [148, 159, 215, 525], "vertical": true, "font_size": 32, "lines_coords": [[[181.0, 161.0], [213.0, 161.0], [213.0, 523.0], [181.0, 523.0]], [[148.0, 161.0], [180.0, 161.0], [180.0, 388.0], [148.0, 388.0]]], "lines": ["夕飯はカップライス（ハヤシン）", "で簡単にすませる"]}, {"box": [1170, 680, 1202, 796], "vertical": true, "font_size": 31, "lines_coords": [[[1170.0, 680.0], [1201.0, 680.0], [1201.0, 796.0], [1170.0, 796.0]]], "lines": ["それから"]}, {"box": [753, 716, 838, 950], "vertical": true, "font_size": 26, "lines_coords": [[[811.0, 716.0], [838.0, 716.0], [838.0, 950.0], [811.0, 950.0]], [[781.0, 716.0], [806.0, 716.0], [806.0, 950.0], [781.0, 950.0]], [[753.0, 716.0], [778.0, 716.0], [778.0, 883.0], [753.0, 883.0]]], "lines": ["ソロキャンは夜明けを", "眺めながらのココアが", "最高なんだよ～"]}, {"box": [607, 671, 680, 1179], "vertical": true, "font_size": 32, "lines_coords": [[[645.0, 671.0], [676.0, 671.0], [676.0, 1177.0], [645.0, 1177.0]], [[611.0, 671.0], [643.0, 671.0], [639.0, 1014.0], [607.0, 1014.0]]], "lines": ["というなでしこのアドバイスを真に受け", "早めに寝袋に入ったのだが"]}, {"box": [140, 673, 182, 1128], "vertical": true, "font_size": 38, "lines_coords": [[[140.0, 673.0], [178.0, 673.0], [178.0, 1125.0], [140.0, 1125.0]]], "lines": ["テンドの中で寝付けぬまま約１時間"]}, {"box": [721, 1241, 763, 1601], "vertical": true, "font_size": 40, "lines_coords": [[[721.0, 1241.0], [761.0, 1241.0], [761.0, 1601.0], [721.0, 1601.0]]], "lines": ["キャンプ場には私一人だけ"]}, {"box": [534, 1239, 648, 1631], "vertical": true, "font_size": 38, "lines_coords": [[[613.0, 1241.0], [648.0, 1241.0], [645.0, 1605.0], [609.0, 1605.0]], [[573.0, 1241.0], [611.0, 1241.0], [611.0, 1631.0], [573.0, 1631.0]], [[536.0, 1239.0], [575.0, 1239.0], [573.0, 1603.0], [534.0, 1603.0]]], "lines": ["周辺には街灯が三本もなく", "さらに今日は新月だったため", "キャンプ場は本当に真っ暗"]}, {"box": [341, 1329, 406, 1365], "vertical": false, "font_size": 36, "lines_coords": [[[341.0, 1329.0], [406.0, 1329.0], [406.0, 1365.0], [341.0, 1365.0]]], "lines": ["ホー"]}, {"box": [1081, 1237, 1191, 1745], "vertical": true, "font_size": 35, "lines_coords": [[[1156.0, 1239.0], [1188.0, 1239.0], [1188.0, 1743.0], [1156.0, 1743.0]], [[1115.0, 1237.0], [1155.0, 1237.0], [1153.0, 1591.0], [1113.0, 1591.0]], [[1081.0, 1241.0], [1113.0, 1241.0], [1113.0, 1629.0], [1081.0, 1629.0]]], "lines": ["どうやら周りにいた他のキャンパーは", "デイキャンだったらしく", "７時頃には全員帰ってしまい"]}], "img_path": "00031.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1160, 148, 1203, 496], "vertical": true, "font_size": 38, "lines_coords": [[[1160.0, 148.0], [1198.0, 148.0], [1201.0, 496.0], [1164.0, 496.0]]], "lines": ["そのうち軽く尿意を催し"]}, {"box": [813, 210, 876, 476], "vertical": true, "font_size": 26, "lines_coords": [[[847.0, 213.0], [873.0, 213.0], [873.0, 397.0], [847.0, 397.0]], [[815.0, 210.0], [841.0, 210.0], [840.0, 476.0], [813.0, 476.0]]], "lines": ["こんな暗闇の中", "トイレ行くの嫌だなぁ"]}, {"box": [562, 148, 637, 496], "vertical": true, "font_size": 34, "lines_coords": [[[598.0, 148.0], [635.0, 148.0], [633.0, 496.0], [596.0, 496.0]], [[562.0, 151.0], [594.0, 151.0], [594.0, 341.0], [562.0, 341.0]]], "lines": ["どこからか怪しい物音が", "聞こえ始める"]}, {"box": [697, 363, 740, 858], "vertical": true, "font_size": 43, "lines_coords": [[[697.0, 363.0], [740.0, 363.0], [740.0, 843.0], [697.0, 843.0]]], "lines": ["と寝袋の中でもそもそしていると"]}, {"box": [1132, 1066, 1215, 1265], "vertical": true, "font_size": 68, "lines_coords": [[[1147.0, 1066.0], [1215.0, 1072.0], [1200.0, 1265.0], [1132.0, 1260.0]]], "lines": ["ガサガサ"]}, {"box": [984, 932, 1064, 1423], "vertical": true, "font_size": 37, "lines_coords": [[[1020.0, 933.0], [1057.0, 933.0], [1061.0, 1421.0], [1023.0, 1421.0]], [[984.0, 937.0], [1021.0, 937.0], [1021.0, 1269.0], [984.0, 1269.0]]], "lines": ["物音が静まったらドイレに行こうと", "耳をすませるごと約３０分"]}, {"box": [144, 1252, 204, 1363],