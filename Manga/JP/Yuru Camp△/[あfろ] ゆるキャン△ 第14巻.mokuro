 [480.0, 1438.0], [339.0, 1438.0]]], "lines": ["今は帰宅途は"]}, {"box": [183, 1381, 230, 1402], "vertical": false, "font_size": 21, "lines_coords": [[[183.0, 1381.0], [230.0, 1381.0], [230.0, 1402.0], [183.0, 1402.0]]], "lines": ["２０：１９"]}], "img_path": "00040.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [223, 746, 613, 808], "vertical": false, "font_size": 26, "lines_coords": [[[228.0, 750.0], [530.0, 746.0], [530.0, 772.0], [228.0, 776.0]], [[223.0, 781.0], [442.0, 778.0], [442.0, 804.0], [223.0, 808.0]]], "lines": ["ここの桜がライトアップして", "ちょっとぎっただけ"]}, {"box": [152, 873, 461, 905], "vertical": false, "font_size": 24, "lines_coords": [[[157.0, 877.0], [457.0, 877.0], [457.0, 901.0], [157.0, 901.0]]], "lines": ["すげーこんな場所あるのか"]}, {"box": [840, 1053, 1190, 1084], "vertical": false, "font_size": 26, "lines_coords": [[[849.0, 1053.0], [1186.0, 1057.0], [1186.0, 1083.0], [849.0, 1080.0]]], "lines": ["ソロ楽しめてるなら良かったよ"]}, {"box": [748, 1146, 1080, 1208], "vertical": false, "font_size": 26, "lines_coords": [[[753.0, 1149.0], [1006.0, 1149.0], [1006.0, 1175.0], [753.0, 1175.0]], [[755.0, 1179.0], [1074.0, 1179.0], [1074.0, 1205.0], [755.0, 1205.0]]], "lines": ["おうリンがいマるのも", "ちょっと分かった気がするよ"]}, {"box": [581, 1140, 620, 1155], "vertical": false, "font_size": 15, "lines_coords": [[[581.0, 1140.0], [620.0, 1140.0], [620.0, 1155.0], [581.0, 1155.0]]], "lines": ["２０：２１"]}, {"box": [287, 1026, 637, 1089], "vertical": false, "font_size": 25, "lines_coords": [[[290.0, 1031.0], [630.0, 1031.0], [630.0, 1055.0], [290.0, 1055.0]], [[288.0, 1061.0], [435.0, 1061.0], [435.0, 1087.0], [288.0, 1087.0]]], "lines": ["それじゃ私はそろそろ帰るから", "風邪引くなよ"]}, {"box": [200, 1153, 501, 1185], "vertical": false, "font_size": 26, "lines_coords": [[[200.0, 1155.0], [495.0, 1156.0], [495.0, 1183.0], [200.0, 1181.0]]], "lines": ["リンも気をつけけて帰れよ〜"]}, {"box": [296, 1245, 483, 1276], "vertical": false, "font_size": 31, "lines_coords": [[[300.0, 1245.0], [480.0, 1245.0], [480.0, 1276.0], [300.0, 1276.0]]], "lines": ["うむまた明日な"]}], "img_path": "00041.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [844, 205, 1055, 238], "vertical": false, "font_size": 32, "lines_coords": [[[845.0, 206.0], [1048.0, 206.0], [1048.0, 238.0], [845.0, 238.0]]], "lines": ["うむ、また明日な"]}, {"box": [822, 302, 1175, 353], "vertical": false, "font_size": 51, "lines_coords": [[[822.0, 302.0], [1175.0, 302.0], [1175.0, 353.0], [822.0, 353.0]]], "lines": ["１１月１１日（金）については、２０１６年１０月１０日（日）までにありがとうございました。おかげです。"]}, {"box": [168, 219, 208, 318], "vertical": true, "font_size": 40, "lines_coords": [[[168.0, 219.0], [208.0, 219.0], [208.0, 318.0], [168.0, 318.0]]], "lines": ["おぉ．．．"]}, {"box": [1141, 480, 1183, 573], "vertical": true, "font_size": 42, "lines_coords": [[[1141.0, 480.0], [1183.0, 480.0], [1183.0, 573.0], [1141.0, 573.0]]], "lines": ["ペコン"]}, {"box": [828, 420, 894, 605], "vertical": true, "font_size": 31, "lines_coords": [[[858.0, 420.0], [894.0, 420.0], [894.0, 453.0], [858.0, 453.0]], [[830.0, 421.0], [856.0, 421.0], [856.0, 605.0], [830.0, 605.0]]], "lines": ["ん", "今度は何だ？"]}, {"box": [429, 1417, 518, 1689], "vertical": true, "font_size": 25, "lines_coords": [[[491.0, 1417.0], [515.0, 1417.0], [515.0, 1689.0], [491.0, 1689.0]], [[459.0, 1417.0], [485.0, 1417.0], [485.0, 1563.0], [459.0, 1563.0]], [[429.0, 1417.0], [455.0, 1417.0], [455.0, 1616.0], [429.0, 1616.0]]], "lines": ["確かこれ毎年春になると", "ライトアップ", "してるやつだっけ"]}, {"box": [228, 1518, 291, 1743], "vertical": true, "font_size": 26, "lines_coords": [[[262.0, 1522.0], [288.0, 1522.0], [288.0, 1743.0], [262.0, 1743.0]], [[228.0, 1518.0], [253.0, 1518.0], [253.0, 1689.0], [228.0, 1689.0]]], "lines": ["ライブカメラでも", "見れたのか．．"]}], "img_path": "00042.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [408, 240, 442, 444], "vertical": true, "font_size": 32, "lines_coords": [[[408.0, 240.0], [440.0, 240.0], [440.0, 442.0], [408.0, 442.0]]], "lines": ["きれいじゃん"]}], "img_p