x": [742, 1048, 776, 1134], "vertical": true, "font_size": 34, "lines_coords": [[[742.0, 1048.0], [776.0, 1048.0], [776.0, 1134.0], [742.0, 1134.0]]], "lines": ["あはい"]}, {"box": [678, 1269, 733, 1479], "vertical": true, "font_size": 25, "lines_coords": [[[708.0, 1271.0], [733.0, 1271.0], [733.0, 1479.0], [708.0, 1479.0]], [[678.0, 1269.0], [703.0, 1269.0], [703.0, 1456.0], [678.0, 1456.0]]], "lines": ["みんなバイト探しに", "苦労するんだよね"]}, {"box": [624, 1308, 648, 1543], "vertical": true, "font_size": 25, "lines_coords": [[[624.0, 1308.0], [648.0, 1308.0], [648.0, 1543.0], [624.0, 1543.0]]], "lines": ["この辺求人少ないから"]}, {"box": [129, 939, 189, 1190], "vertical": true, "font_size": 26, "lines_coords": [[[161.0, 939.0], [187.0, 939.0], [189.0, 1140.0], [163.0, 1140.0]], [[129.0, 939.0], [155.0, 939.0], [157.0, 1190.0], [131.0, 1190.0]]], "lines": ["あとはバイトして", "返す予定なんですけど"]}, {"box": [223, 1321, 249, 1435], "vertical": true, "font_size": 26, "lines_coords": [[[223.0, 1321.0], [249.0, 1321.0], [249.0, 1434.0], [223.0, 1434.0]]], "lines": ["そうそう"]}, {"box": [1121, 1348, 1185, 1533], "vertical": true, "font_size": 30, "lines_coords": [[[1149.0, 1348.0], [1185.0, 1348.0], [1185.0, 1411.0], [1149.0, 1411.0]], [[1121.0, 1351.0], [1147.0, 1351.0], [1151.0, 1533.0], [1125.0, 1533.0]]], "lines": ["もう", "決まってるの？"]}, {"box": [775, 1440, 830, 1736], "vertical": true, "font_size": 25, "lines_coords": [[[802.0, 1440.0], [828.0, 1440.0], [830.0, 1599.0], [804.0, 1599.0]], [[776.0, 1440.0], [800.0, 1440.0], [800.0, 1736.0], [776.0, 1736.0]]], "lines": ["いえまだです", "なかなか見つからなくて．．．"]}, {"box": [168, 1603, 196, 1687], "vertical": true, "font_size": 28, "lines_coords": [[[168.0, 1603.0], [196.0, 1603.0], [196.0, 1687.0], [168.0, 1687.0]]], "lines": ["ははは"]}], "img_path": "00109.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1095, 193, 1124, 371], "vertical": true, "font_size": 26, "lines_coords": [[[1096.0, 193.0], [1123.0, 193.0], [1121.0, 371.0], [1095.0, 371.0]]]