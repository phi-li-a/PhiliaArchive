場所取りご苦労さまー"]}, {"box": [318, 1518, 382, 1756], "vertical": true, "font_size": 26, "lines_coords": [[[354.0, 1518.0], [380.0, 1518.0], [380.0, 1756.0], [354.0, 1756.0]], [[320.0, 1518.0], [346.0, 1518.0], [345.0, 1706.0], [318.0, 1706.0]]], "lines": ["場所取りしなくても", "選び放題だわー"]}], "img_path": "00045.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1173, 163, 1202, 385], "vertical": true, "font_size": 25, "lines_coords": [[[1173.0, 163.0], [1198.0, 163.0], [1198.0, 384.0], [1173.0, 384.0]]], "lines": ["あきちゃんおーす"]}, {"box": [793, 294, 853, 538], "vertical": true, "font_size": 26, "lines_coords": [[[826.0, 294.0], [851.0, 294.0], [851.0, 538.0], [826.0, 538.0]], [[793.0, 294.0], [819.0, 294.0], [819.0, 476.0], [793.0, 476.0]]], "lines": ["なんだちびイヌ子も", "ついて来たのか"]}, {"box": [663, 144, 724, 480], "vertical": true, "font_size": 26, "lines_coords": [[[695.0, 144.0], [721.0, 144.0], [721.0, 480.0], [695.0, 480.0]], [[663.0, 144.0], [688.0, 144.0], [688.0, 480.0], [663.0, 480.0]]], "lines": ["ほんまはお昼から友達んち", "行こうかと思っとったけど"]}, {"box": [166, 135, 227, 536], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 138.0], [225.0, 138.0], [225.0, 388.0], [200.0, 388.0]], [[166.0, 135.0], [193.0, 135.0], [195.0, 536.0], [168.0, 536.0]]], "lines": ["焼き肉やるって聞いて", "あおいちゃんについてきましたっ！！"]}, {"box": [1049, 776, 1192, 1098], "vertical": true, "font_size": 30, "lines_coords": [[[1149.0, 776.0], [1192.0, 776.0], [1192.0, 845.0], [1149.0, 845.0]], [[1111.0, 798.0], [1138.0, 798.0], [1138.0, 1098.0], [1111.0, 1098.0]], [[1080.0, 800.0], [1106.0, 800.0], [1106.0, 999.0], [1080.0, 999.0]], [[1050.0, 800.0], [1074.0, 800.0], [1074.0, 999.0], [1050.0, 999.0]]], "lines": ["先生", "花見の料理任せてくれって", "言ってましたけど", "焼き肉やるんすね"]}, {"box": [150, 573, 223, 669], "vertical": true, "font_size": 34, "lines_coords": [[[189.0, 573.0], [223.0, 573.0], [223.0, 669.0], [189.0, 669.0]], [[150.0, 573.0], [183.0, 573.0], [183.0, 667.0], [150.0, 667.0]]], "lines": ["肉目的", "かよー"]}, {"box": [200, 825, 271, 1097], "vertical": true, "font_size": 34, "lines_coords": [[[228.0, 825.0], [271.0, 825.0], [271.0, 900.0], [228.0, 900.0]], [[200.0, 832.0], [226.0, 832.0], [226.0, 1096.0], [200.0, 1096.0]]], "lines": ["ええ", "焼き内は焼き肉でも"]}, {"box": [363, 1175, 429, 1429], "vertical": true, "font_size": 30, "lines_coords": [[[395.0, 1175.0], [429.0, 1175.0], [429.0, 1291.0], [395.0, 1291.0]], [[365.0, 1177.0], [391.0, 1177.0], [390.0, 1428.0], [363.0, 1428.0]]], "lines": ["やったー", "ジンギスカンやー！！"]}, {"box": [1067, 1220, 1110, 1688], "vertical": true, "font_size": 38, "lines_coords": [[[1068.0, 1220.0], [1106.0, 1220.0], [1106.0, 1685.0], [1068.0, 1685.0]]], "lines": ["ジンギスカン焼き肉です！"]}], "img_path": "00046.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1130, 144, 1192, 435], "vertical": true, "font_size": 26, "lines_coords": [[[1162.0, 144.0], [1188.0, 144.0], [1192.0, 305.0], [1166.0, 305.0]], [[1130.0, 144.0], [1156.0, 144.0], [1156.0, 433.0], [1130.0, 433.0]]], "lines": ["あかりちゃん", "ジンギスカン好きなの？"]}, {"box": [785, 180, 825, 281], "vertical": true, "font_size": 40, "lines_coords": [[[785.0, 180.0], [825.0, 180.0], [825.0, 281.0], [785.0, 281.0]]], "lines": ["うん！"]}, {"box": [506, 181, 565, 481], "vertical": true, "font_size": 25, "lines_coords": [[[538.0, 181.0], [564.0, 181.0], [564.0, 481.0], [538.0, 481.0]], [[506.0, 181.0], [530.0, 181.0], [530.0, 459.0], [506.0, 459.0]]], "lines": ["私んち月３回くらい夕飯に", "ジンギスカン出てくるし、"]}, {"box": [161, 163, 214, 375], "vertical": true, "font_size": 22, "lines_coords": [[[191.0, 166.0], [211.0, 166.0], [211.0, 279.0], [191.0, 279.0]], [[161.0, 163.0], [185.0, 163.0], [185.0, 375.0], [161.0, 375.0]]], "lines": ["月に３回は", "ちょっとすごいねぇ"]}, {"box": [1155, 575, 1213, 924], "vertical": true, "font_size": 27, "lines_coords": [[[1186.0, 577.0], [1213.0, 577.0], [1213.0, 924.0], [1186.0, 924.0]], [[1156.0, 575.0], [1183.0, 575.0], [1181.0, 851.0], [1155.0, 851.0]]], "lines": ["だからうちらジンギスカンには", "ちょっとうるさいんよね"]}, {"box": [832, 566, 901, 739], "vertical": true, "font_size": 36, "lines_coords": [[[856.0, 566.0], [901.0, 566.0], [901.0, 635.0], [856.0, 635.0]], [[832.0, 571.0], [858.0, 571.0], [858.0, 738.0], [832.0, 738.0]]], "lines": ["ねー", "あおいちゃん"]}, {"box": [646, 588, 708, 952], "vertical": true, "font_size": 26, "lines_coords": [[[682.0, 588.0], [708.0, 588.0], [708.0, 896.0], [682.0, 896.0]], [[646.0, 588.0], [673.0, 588.0], [673.0, 952.0], [646.0, 952.0]]], "lines": ["この前ＴＶで北海道では", "ジンギスカンをつつきながら、"]}, {"box": [753, 847, 819, 1040], "vertical": true, "font_size": 32, "lines_coords": [[[783.0, 847.0], [819.0, 847.0], [819.0, 933.0], [783.0, 933.0]], [[753.0, 847.0], [780.0, 847.0], [780.0, 1040.0], [753.0, 1040.0]]], "lines": ["んふふ", "かもしれんなぁ"]}, {"box": [564, 729, 624, 1076], "vertical": true, "font_size": 26, "lines_coords": [[[598.0, 731.0], [624.0, 731.0], [624.0, 1076.0], [598.0, 1076.0]], [[566.0, 729.0], [592.0, 729.0], [590.0, 1076.0], [564.0, 1076.0]]], "lines": ["花見をすると紹介されていて、", "ちょっといいなと思いまして"]}, {"box": [136, 575, 200, 825], "vertical": true, "font_size": 26, "lines_coords": [[[172.0, 575.0], [198.0, 575.0], [198.0, 725.0], [172.0, 725.0]], [[136.0, 575.0], [161.0, 575.0], [161.0, 825.0], [136.0, 825.0]]], "lines": ["あそれ私も", "聞いたことあります"]}, {"box": [1108, 1179, 1184, 1663], "vertical": true, "font_size": 35, "lines_coords": [[[1145.0, 1179.0], [1183.0, 1179.0], [1183.0, 1663.0], [1145.0, 1663.0]], [[1108.0, 1185.0], [1140.0, 1185.0], [1140.0, 1627.0], [1108.0, 1627.0]]], "lines": ["それにジンギスカンなら調理は", "肉をタレに付けるだけなので"]}, {"box": [545, 1275, 573, 1333], "vertical": true, "font_size": 28, "lines_coords": [[[545.0, 1275.0], [573.0, 1275.0], [573.0, 1333.0], [545.0, 1333.0]]], "lines": ["ブシュ"]}, {"box": [322, 1177, 407, 1644], "vertical": true, "font_size": 32, "lines_coords": [[[371.0, 1179.0], [403.0, 1179.0], [403.0, 1644.0], [371.0, 1644.0]], [[326.0, 1177.0], [358.0, 1177.0], [354.0, 1503.0], [322.0, 1503.0]]], "lines": ["酔っ払って覚束なくなっても、", "問題ないですから！！"]}, {"box": [183, 1357, 221, 1698], "vertical": true, "font_size": 34, "lines_coords": [[[183.0, 1357.0], [217.0, 1357.0], [219.0, 1698.0], [185.0, 1698.0]]], "lines": ["今日も平常運転すねぇ"]}], "img_path": "00047.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1156, 294, 1213, 618], "vertical": true, "font_size": 26, "lines_coords": [[[1186.0, 296.0], [1213.0, 296.0], [1213.0, 618.0], [1186.0, 618.0]], [[1156.0, 294.0], [1181.0, 294.0], [1181.0, 592.0], [1156.0, 592.0]]], "lines": ["一応ラム肉と豚肉の２種類を", "タレに漬けてきましたので"]}, {"box": [762, 150, 824, 375], "vertical": true, "font_size": 26, "lines_coords": [[[796.0, 151.0], [823.0, 151.0], [823.0, 373.0], [796.0, 373.0]], [[763.0, 150.0], [787.0, 150.0], [787.0, 373.0], [763.0, 373.0]]], "lines": ["ラムが苦手な方は", "豚肉の方をどうぞ"]}, {"box": [656, 292, 714, 517], "vertical": true, "font_size": 24, "lines_coords": [[[690.0, 294.0], [714.0, 294.0], [714.0, 444.0], [690.0, 444.0]], [[656.0, 292.0], [682.0, 292.0], [682.0, 517.0], [656.0, 517.0]]], "lines": ["それと今日は", "ジンギスカンの他に"]}, {"box": [377, 184, 409, 232], "vertical": true, "font_size": 32, "lines_coords": [[[377.0, 184.0], [409.0, 184.0], [409.0, 232.0], [377.0, 232.0]]], "lines": ["？"]}, {"box": [1128, 757, 1179, 1008], "vertical": true, "font_size": 51, "lines_coords": [[[1128.0, 757.0], [1179.0, 757.0], [1179.0, 1008.0], [1128.0, 1008.0]]], "lines": ["これです！"]}, {"box": [596, 393, 650, 671], "vertical": true, "font_size": 24, "lines_coords": [[[626.0, 393.0], [650.0, 393.0], [650.0, 671.0], [626.0, 671.0]], [[596.0, 395.0], [620.0, 395.0], [620.0, 646.0], [596.0, 646.0]]], "lines": ["あまり見かけないお肉を", "買ってきたんですよね"]}, {"box": [153, 466, 219, 663], "vertical": true, "font_size": 26, "lines_coords": [[[189.0, 468.0], [215.0, 468.0], [215.0, 635.0], [189.0, 635.0]], [[153.0, 466.0], [180.0, 466.0], [180.0, 663.0], [153.0, 663.0]]], "lines": ["少し驚くかも", "しれませんが．．．"]}, {"box": [221, 764, 292, 1085], "vertical": true, "font_size": 66, "lines_coords": [[[221.0, 768.0], [286.0, 768.0], [292.0, 1085.0], [226.0, 1085.0]]], "lines": ["かカエル！？"]}, {"box": [1139, 1333, 1204, 1543], "vertical": true, "font_size": 26, "lines_coords": [[[1175.0, 1333.0], [1203.0, 1333.0], [1200.0, 1494.0], [1171.0, 1494.0]], [[1140.0, 1338.0], [1164.0, 1338.0], [1164.0, 1543.0], [1140.0, 1543.0]]], "lines": ["どどうした", "んですかコレ？"]}, {"box": [622, 1163, 810, 1241], "vertical": false, "font_size": 33, "lines_coords": [[[624.0, 1164.0], [806.0, 1164.0], [806.0, 1209.0], [624.0, 1209.0]], [[688.0, 1218.0], [768.0, 1218.0], [768.0, 1239.0], [688.0, 1239.0]]], "lines": ["カエル肉", "主規制"]}, {"box": [759, 1314, 868, 1354], "vertical": false, "font_size": 40, "lines_coords": [[[759.0, 1314.0], [868.0, 1314.0], [868.0, 1354.0], [759.0, 1354.0]]], "lines": ["めちやめちゃカエルじゃん"]}, {"box": [682, 1329, 708, 1488], "vertical": true, "font_size": 26, "lines_coords": [[[682.0, 1329.0], [708.0, 1329.0], [708.0, 1488.0], [682.0, 1488.0]]], "lines": ["それがですね"]}, {"box": [596, 1340, 656, 1738], "vertical": true, "font_size": 26, "lines_coords": [[[630.0, 1340.0], [656.0, 1340.0], [656.0, 1738.0], [630.0, 1738.0]], [[596.0, 1342.0], [622.0, 1342.0], [622.0, 1681.0], [596.0, 1681.0]]], "lines": ["せっかくジンギスカンをやるなら、", "お肉の専門店で買おうと思い"]}, {"box": [157, 1346, 219, 1655], "vertical": true, "font_size": 26, "lines_coords": [[[191.0, 1346.0], [217.0, 1346.0], [217.0, 1569.0], [191.0, 1569.0]], [[157.0, 1350.0], [183.0, 1350.0], [183.0, 1655.0], [157.0, 1655.0]]], "lines": ["富士川町のとある", "お店に伺ったんですが．．．"]}], "img_path": "00048.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1158, 168, 1192, 309], "vertical": true, "font_size": 33, "lines_coords": [[[1158.0, 168.0], [1192.0, 168.0], [1192.0, 309.0], [1158.0, 309.0]]], "lines": ["実はそこ"]}, {"box": [1065, 234, 1141, 562], "vertical": true, "font_size": 33, "lines_coords": [[[1108.0, 234.0], [1141.0, 234.0], [1140.0, 525.0], [1106.0, 525.0]], [[1065.0, 236.0], [1096.0, 236.0], [1096.0, 562.0], [1065.0, 562.0]]], "lines": ["普通の精肉店では、", "まず置いてはいない"]}, {"box": [864, 315, 941, 371], "vertical": false, "font_size": 28, "lines_coords": [[[864.0, 316.0], [937.0, 316.0], [937.0, 343.0], [864.0, 343.0]], [[871.0, 341.0], [928.0, 341.0], [928.0, 371.0], [871.0, 371.0]]], "lines": ["うさま", "２８０円"]}, {"box": [684, 310, 761, 360], "vertical": false, "font_size": 28, "lines_coords": [[[684.0, 313.0], [759.0, 313.0], [759.0, 341.0], [684.0, 341.0]]], "lines": ["かえる"]}, {"box": [300, 161, 379, 485], "vertical": true, "font_size": 32, "lines_coords": [[[343.0, 161.0], [375.0, 161.0], [375.0, 481.0], [343.0, 481.0]], [[300.0, 166.0], [331.0, 166.0], [331.0, 485.0], [300.0, 485.0]]], "lines": ["特殊肉も扱っている", "お店だったんです！"]}, {"box": [1155, 768, 1211, 1025], "vertical": true, "font_size": 24, "lines_coords": [[[1186.0, 768.0], [1211.0, 768.0], [1211.0, 1025.0], [1186.0, 1025.0]], [[1155.0, 768.0], [1179.0, 768.0], [1179.0, 1003.0], [1155.0, 1003.0]]], "lines": ["それで特殊肉コーナーを", "恐る恐る眺めていた所"]}, {"box": [984, 772, 1055, 1016], "vertical": true, "font_size": 21, "lines_coords": [[[1031.0, 774.0], [1051.0, 774.0], [1051.0, 913.0], [1031.0, 913.0]], [[1006.0, 772.0], [1031.0, 772.0], [1031.0, 1016.0], [1006.0, 1016.0]], [[984.0, 774.0], [1003.0, 774.0], [1003.0, 954.0], [984.0, 954.0]]], "lines": ["初めてでしたら", "カエルなんか鶏肉っぽくて", "意外とイケますよ～"]}, {"box": [843, 518, 956, 577], "vertical": false, "font_size": 28, "lines_coords": [[[847.0, 519.0], [950.0, 519.0], [950.0, 545.0], [847.0, 545.0]], [[858.0, 543.0], [933.0, 547.0], [931.0, 577.0], [856.0, 573.0]]], "lines": ["ガラガラへと", "．．．"]}, {"box": [688, 511, 750, 566], "vertical": false, "font_size": 28, "lines_coords": [[[690.0, 511.0], [744.0, 511.0], [744.0, 540.0], [690.0, 540.0]], [[690.0, 538.0], [748.0, 538.0], [748.0, 566.0], [690.0, 566.0]]], "lines": ["わに", "８４６円"]}, {"box": [664, 701, 760, 727], "vertical": false, "font_size": 26, "lines_coords": [[[664.0, 701.0], [760.0, 701.0], [760.0, 727.0], [664.0, 727.0]]], "lines": ["イノシジ"]}, {"box": [492, 501, 596, 553], "vertical": false, "font_size": 24, "lines_coords": [[[495.0, 502.0], [590.0, 502.0], [590.0, 528.0], [495.0, 528.0]], [[511.0, 532.0], [573.0, 532.0], [573.0, 553.0], [511.0, 553.0]]], "lines": ["ニシキヘビ", "１８００円"]}, {"box": [493, 692, 595, 724], "vertical": false, "font_size": 32, "lines_coords": [[[493.0, 692.0], [595.0, 692.0], [595.0, 724.0], [493.0, 724.0]]], "lines": ["粗椀馬肉"]}, {"box": [583, 787, 645, 954], "vertical": true, "font_size": 26, "lines_coords": [[[616.0, 787.0], [643.0, 787.0], [643.0, 926.0], [616.0, 926.0]], [[583.0, 787.0], [609.0, 787.0], [609.0, 954.0], [583.0, 954.0]]], "lines": ["買ってきた", "という訳です"]}, {"box": [470, 879, 510, 1008], "vertical": true, "font_size": 40, "lines_coords": [[[470.0, 879.0], [510.0, 879.0], [510.0, 1008.0], [470.0, 1008.0]]], "lines": ["値段もそれほど高くなかったので"]}, {"box": [166, 386, 229, 617], "vertical": true, "font_size": 30, "lines_coords": [[[196.0, 386.0], [228.0, 386.0], [228.0, 616.0], [196.0, 616.0]], [[166.0, 388.0], [193.0, 388.0], [193.0, 526.0], [166.0, 526.0]]], "lines": ["がガラガラヘビに", "ワニって．．．"]}, {"box": [153, 796, 247, 1061], "vertical": true, "font_size": 25, "lines_coords": [[[217.0, 796.0], [243.0, 796.0], [243.0, 982.0], [217.0, 982.0]], [[185.0, 796.0], [210.0, 796.0], [210.0, 956.0], [185.0, 956.0]], [[153.0, 796.0], [178.0, 796.0], [178.0, 1061.0], [153.0, 1061.0]]], "lines": ["鶏肉っぽいなら", "鶏肉食べれば", "ええんやないですかね"]}, {"box": [701, 1008, 783, 1267], "vertical": true, "font_size": 23, "lines_coords": [[[761.0, 1010.0], [781.0, 1010.0], [781.0, 1149.0], [761.0, 1149.0]], [[729.0, 1008.0], [755.0, 1008.0], [753.0, 1267.0], [727.0, 1267.0]], [[701.0, 1008.0], [725.0, 1008.0], [725.0, 1218.0], [701.0, 1218.0]]], "lines": ["とお勧めされ", "お花見に持っていったら", "面白いかなぁと思い"]}, {"box": [1119, 1335, 1194, 1590], "vertical": true, "font_size": 33, "lines_coords": [[[1156.0, 1335.0], [1194.0, 1335.0], [1194.0, 1590.0], [1156.0, 1590.0]], [[1121.0, 1335.0], [1149.0, 1335.0], [1147.0, 1582.0], [1119.0, 1582.0]]], "lines": ["ビジュアルがもろ", "カエルだったため"]},