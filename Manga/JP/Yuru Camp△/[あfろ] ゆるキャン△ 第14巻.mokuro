], "vertical": false, "font_size": 70, "lines_coords": [[[328.0, 605.0], [688.0, 650.0], [680.0, 720.0], [320.0, 675.0]]], "lines": ["おぉおおぉぉ"]}, {"box": [125, 371, 226, 678], "vertical": true, "font_size": 26, "lines_coords": [[[196.0, 373.0], [223.0, 373.0], [223.0, 678.0], [196.0, 678.0]], [[159.0, 371.0], [185.0, 371.0], [185.0, 596.0], [159.0, 596.0]], [[125.0, 373.0], [151.0, 373.0], [151.0, 650.0], [125.0, 650.0]]], "lines": ["ずっと湖沿いを走るから", "風が強い所とかは", "走りづらかったかなぁ"]}, {"box": [1115, 860, 1183, 1126], "vertical": true, "font_size": 29, "lines_coords": [[[1151.0, 860.0], [1183.0, 860.0], [1183.0, 1126.0], [1151.0, 1126.0]], [[1115.0, 862.0], [1141.0, 862.0], [1141.0, 1126.0], [1115.0, 1126.0]]], "lines": ["坂は何度も登ったり", "降りたりたったけど"]}, {"box": [161, 943, 228, 1235], "vertical": true, "font_size": 26, "lines_coords": [[[198.0, 943.0], [225.0, 943.0], [225.0, 1235.0], [198.0, 1235.0]], [[161.0, 943.0], [187.0, 943.0], [187.0, 1177.0], [161.0, 1177.0]]], "lines": ["きつい坂とか長い坂は", "無かったと思うよ"]}, {"box": [1132, 1383, 1194, 1610], "vertical": true, "font_size": 22, "lines_coords": [[[1170.0, 1389.0], [1190.0, 1389.0], [1190.0, 1526.0], [1170.0, 1526.0]], [[1132.0, 1383.0], [1156.0, 1383.0], [1156.0, 1610.0], [1132.0, 1610.0]]], "lines": ["あと距離は", "どうだったかなぁ"]}, {"box": [931, 1563, 1000, 1770], "vertical": true, "font_size": 27, "lines_coords": [[[971.0, 1565.0], [997.0, 1565.0], [997.0, 1740.0], [971.0, 1740.0]], [[931.0, 1563.0], [960.0, 1563.0], [961.0, 1768.0], [933.0, 1768.0]]], "lines": ["浜名湖一周は", "６７キロだってさ"]}, {"box": [390, 1509, 450, 1683], "vertical": true, "font_size": 26, "lines_coords": [[[423.0, 1511.0], [450.0, 1511.0], [450.0, 1621.0], [423.0, 1621.0]], [[390.0, 1509.0], [414.0, 1509.0], [414.0, 1683.0], [390.0, 1683.0]]], "lines": ["そんなに", "あるんスか？"]}, {"box": [186, 1385, 249, 1745], "vertical": true, "font_size": 27, "lines_coords": [[[219.0, 1385.0], [247.0, 1385.0], [245.0, 1691.0], [217.0, 1691.0]], [[187.0, 1389.0], [213.0, 1389.0], [213.0, 1745.0], [187.0, 1745.0]]], "lines": ["自転車好きは一ハマイチ」", "って呼ぶ有名なコースらしい"]}], "img_path": "00143.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [901, 217, 935, 288], "vertical": true, "font_size": 34, "lines_coords": [[[901.0, 217.0], [935.0, 217.0], [935.0, 288.0], [901.0, 288.0]]], "lines": ["猪鼻湖"]}, {"box": [879, 425, 971, 463], "vertical": false, "font_size": 34, "lines_coords": [[[881.0, 425.0], [971.0, 429.0], [969.0, 463.0], [879.0, 459.0]]], "lines": ["浜名湖"]}, {"box": [193, 176, 260, 290], "vertical": true, "font_size": 54, "lines_coords": [[[193.0, 181.0], [247.0, 176.0], [260.0, 285.0], [206.0, 290.0]]], "lines": ["でへへ"]}, {"box": [1145, 435, 1210, 723], "vertical": true, "font_size": 27, "lines_coords": [[[1179.0, 435.0], [1207.0, 435.0], [1209.0, 723.0], [1181.0, 723.0]], [[1145.0, 438.0], [1171.0, 438.0], [1171.0, 688.0], [1145.0, 688.0]]], "lines": ["あ私こっちの方までは", "回らなかったと思う"]}, {"box": [739, 435, 803, 738], "vertical": true, "font_size": 26, "lines_coords": [[[774.0, 436.0], [800.0, 436.0], [800.0, 738.0], [774.0, 738.0]], [[740.0, 436.0], [766.0, 436.0], [766.0, 658.0], [740.0, 658.0]]], "lines": ["んじゃ猪鼻湖を回らない", "５０キロのコースが"]}, {"box": [616, 410, 682, 699], "vertical": true, "font_size": 24, "lines_coords": [[[654.0, 414.0], [678.0, 414.0], [678.0, 691.0], [654.0, 691.0]], [[620.0, 410.0], [645.0, 410.0], [641.0, 699.0], [616.0, 699.0]]], "lines": ["それでも毎日５０キロも", "走ってたんだなおまえ"]}, {"box": [159, 455, 229, 705], "vertical": true, "font_size": 26, "lines_coords": [[[198.0, 457.0], [225.0, 457.0], [225.0, 703.0], [198.0, 703.0]], [[159.0, 457.0], [185.0, 457.0], [185.0, 705.0], [159.0, 705.0]]], "lines": ["雨の日はさすがに", "休みだったけどね"]}, {"box": [1098, 808, 1196, 1143], "vertical": true, "font_size": 28, "lines_coords": [[[1170.0, 811.0], [1196.0, 811.0], [1196.0, 1143.0], [1170.0, 1143.0]], [[1136.0, 813.0], [1162.0, 813.0], [1162.0, 1089.0], [1136.0, 1089.0]], [[1098.0, 808.0], [1130.0, 808.0], [1130.0, 1063.0], [1098.0, 1063.0]]], "lines": ["けど運動不足のなでしこが", "ママチャリで５０キロも", "走れたって考えると"]}, {"box": [971, 864, 1066, 1228], "vertical": true, "font_size": 28, "lines_coords": [[[1040.0, 866.0], [1066.0, 866.0], [1066.0, 1200.0], [1040.0, 1200.0]], [[1003.0, 864.0], [1035.0, 864.0], [1035.0, 1228.0], [1003.0, 1228.0]], [[971.0, 866.0], [997.0, 866.0], [997.0, 1145.0], [971.0, 1145.0]]], "lines": ["初心者でも時間をかければ", "この７０キロも無茶な距離って", "訳じゃないかもしれん"]}, {"box": [373, 1091, 405, 1222], "vertical": true, "font_size": 32, "lines_coords": [[[373.0, 1091.0], [405.0, 1091.0], [405.0, 1222.0], [373.0, 1222.0]]], "lines": ["それそれ"]}, {"box": [1125, 1325, 1220, 1661], "vertical": true, "font_size": 26, "lines_coords": [[[1194.0, 1327.0], [1220.0, 1327.0], [1220.0, 1603.0], [1194.0, 1603.0]], [[1156.0, 1325.0], [1183.0, 1325.0], [1183.0, 1548.0], [1156.0, 1548.0]], [[1125.0, 1327.0], [1151.0, 1327.0], [1151.0, 1661.0], [1125.0, 1661.0]]], "lines": ["前にキャンプ場までの", "３０キロを走った時", "まだまだ行けそうやったし、"]}, {"box": [1044, 1395, 1104, 1758], "vertical": true, "font_size": 26, "lines_coords": [[[1080.0, 1395.0], [1104.0, 1395.0], [1104.0, 1728.0], [1080.0, 1728.0]], [[1044.0, 1395.0], [1070.0, 1395.0], [1070.0, 1758.0], [1044.0, 1758.0]]], "lines": ["朝早めに出発すれば７０キロ", "走れなくもないと思ったんよ"]}, {"box": [409, 1557, 433, 1635], "vertical": true, "font_size": 24, "lines_coords": [[[409.0, 1557.0], [433.0, 1557.0], [433.0, 1635.0], [409.0, 1635.0]]], "lines": ["．．．．．．"]}, {"box": [183, 1378, 290, 1734], "vertical": true, "font_size": 30, "lines_coords": [[[260.0, 1381.0], [286.0, 1381.0], [286.0, 1704.0], [260.0, 1704.0]], [[221.0, 1380.0], [253.0, 1380.0], [253.0, 1734.0], [221.0, 1734.0]], [[185.0, 1378.0], [217.0, 1378.0], [215.0, 1734.0], [183.0, 1734.0]]], "lines": ["それにうちらが乗るのは", "ママチャリより全然速くて", "坂道にも強いロードやし．．．"]}], "img_path": "00144.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1164, 179, 1202, 376], "vertical": true, "font_size": 37, "lines_coords": [[[1164.0, 180.0], [1201.0, 180.0], [1201.0, 376.0], [1164.0, 376.0]]], "lines": ["いいやいや"]}, {"box": [762, 151, 843, 405], "vertical": true, "font_size": 35, "lines_coords": [[[804.0, 151.0], [841.0, 151.0], [838.0, 405.0], [800.0, 405.0]], [[763.0, 151.0], [795.0, 151.0], [795.0, 367.0], [763.0, 367.0]]], "lines": ["やっぱり無茶な", "計画やったな"]}, {"box": [154, 146, 230, 489], "vertical": true, "font_size": 29, "lines_coords": [[[193.0, 146.0], [225.0, 146.0], [228.0, 489.0], [196.0, 489.0]], [[155.0, 150.0], [181.0, 150.0], [181.0, 418.0], [155.0, 418.0]]], "lines": ["話を聞いてたら行ける", "気がしてきたっス"]}, {"box": [761, 598, 866, 924], "vertical": true, "font_size": 27, "lines_coords": [[[836.0, 603.0], [862.0, 603.0], [862.0, 924.0], [836.0, 924.0]], [[798.0, 598.0], [826.0, 598.0], [825.0, 924.0], [796.0, 924.0]], [[763.0, 598.0], [789.0, 598.0], [787.0, 864.0], [761.0, 864.0]]], "lines": ["メイちゃんが入ったから", "早くキャンプせなあかん", "思うて焦りすぎたわ"]}, {"box": [589, 532, 693, 856], "vertical": true, "font_size": 26, "lines_coords": [[[663.0, 532.0], [690.0, 532.0], [690.0, 798.0], [663.0, 798.0]], [[628.0, 534.0], [654.0, 534.0], [654.0, 856.0], [628.0, 856.0]], [[590.0, 532.0], [616.0, 532.0], [616.0, 828.0], [590.0, 828.0]]], "lines": ["ちょい先になるけど", "初キャンプはＧＷ過ぎて", "落ち着いたら近場で："]}, {"box": [180, 705, 219, 834], "vertical": true, "font_size": 39, "lines_coords": [[[180.0, 705.0], [219.0, 705.0], [219.0, 834.0], [180.0, 834.0]]], "lines": ["えっ？"]}, {"box": [1113, 988, 1179, 1410], "vertical": true, "font_size": 29, "lines_coords": [[[1149.0, 988.0], [1175.0, 988.0], [1175.0, 1239.0], [1149.0, 1239.0]], [[1113.0, 990.0], [1145.0, 990.0], [1145.0, 1410.0], [1113.0, 1410.0]]], "lines": ["やりましょう先輩！！", "山梨縦断サイクリングキャンプ！！"]}, {"box": [238, 1132, 273, 1349], "vertical": true, "font_size": 32, "lines_coords": [[[238.0, 1132.0], [270.0, 1132.0], [270.0, 1348.0], [238.0, 1348.0]]], "lines": ["ほほんまに！？"]}, {"box": [1106, 1500, 1187, 1690], "vertical": true, "font_size": 23, "lines_coords": [[[1166.0, 1503.0], [1186.0, 1503.0], [1186.0, 1642.0], [1166.0, 1642.0]], [[1134.0, 1501.0], [1158.0, 1501.0], [1158.0, 1668.0], [1134.0, 1668.0]], [[1106.0, 1500.0], [1130.0, 1500.0], [1130.0, 1689.0], [1106.0, 1689.0]]], "lines": ["走り切れるか", "分からないけど", "頑張ってみます！"]}, {"box": [753, 1516, 813, 1706], "vertical": true, "font_size": 29, "lines_coords": [[[781.0, 1516.0], [813.0, 1516.0], [813.0, 1618.0], [781.0, 1618.0]], [[755.0, 1522.0], [781.0, 1522.0], [780.0, 1706.0], [753.0, 1706.0]]], "lines": ["せやな！", "一緒に頑張ろか！"]}, {"box": [510, 1524, 566, 1642], "vertical": true, "font_size": 24, "lines_coords": [[[541.0, 1528.0], [562.0, 1528.0], [562.0, 1642.0], [541.0, 1642.0]], [[510.0, 1524.0], [536.0, 1524.0], [536.0, 1621.0], [510.0, 1621.0]]], "lines": ["がんはれよ", "お前らー"]}, {"box": [249, 1492, 336, 1766], "vertical": true, "font_size": 25, "lines_coords": [[[309.0, 1494.0], [335.0, 1494.0], [335.0, 1743.0], [309.0, 1743.0]], [[279.0, 1494.0], [305.0, 1494.0], [305.0, 1766.0], [279.0, 1766.0]], [[249.0, 1492.0], [273.0, 1492.0], [273.0, 1644.0], [249.0, 1644.0]]], "lines": ["私は当日行けないけど", "キャンプごはんのレシピ", "考えとくね！"]}], "img_path": "00145.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1104, 161, 1197, 487], "vertical": true, "font_size": 26, "lines_coords": [[[1170.0, 161.0], [1196.0, 161.0], [1194.0, 478.0], [1168.0, 478.0]], [[1136.0, 161.0], [1162.0, 161.0], [1162.0, 487.0], [1136.0, 487.0]], [[1104.0, 163.0], [1130.0, 163.0], [1130.0, 401.0], [1104.0, 401.0]]], "lines": ["この痛恨の判断ミスにより", "その後とんでもない地獄を", "味わう事になるとは"]}, {"box": [401, 208, 463, 470], "vertical": true, "font_size": 24, "lines_coords": [[[438.0, 210.0], [459.0, 210.0], [459.0, 341.0], [438.0, 341.0]], [[401.0, 208.0], [427.0, 208.0], [429.0, 470.0], [403.0, 470.0]]], "lines": ["二人はまだ", "知る由も無かった．．．"]}, {"box": [195, 185, 228, 465], "vertical": true, "font_size": 27, "lines_coords": [[[196.0, 189.0], [223.0, 189.0], [223.0, 465.0], [196.0, 465.0]]], "lines": ["死亡フラグやめーや"]}, {"box": [1046, 703, 1120, 976], "vertical": true, "font_size": 33, "lines_coords": [[[1085.0, 703.0], [1119.0, 703.0], [1119.0, 885.0], [1085.0, 885.0]], [[1046.0, 703.0], [1078.0, 703.0], [1078.0, 976.0], [1046.0, 976.0]]], "lines": ["な７０キロ！？", "大丈夫なのそれ？"]}, {"box": [1121, 1156, 1224, 1451], "vertical": true, "font_size": 28, "lines_coords": [[[1192.0, 1156.0], [1224.0, 1156.0], [1224.0, 1425.0], [1192.0, 1425.0]], [[1158.0, 1158.0], [1185.0, 1158.0], [1185.0, 1451.0], [1158.0, 1451.0]], [[1121.0, 1158.0], [1147.0, 1158.0], [1147.0, 1421.0], [1121.0, 1421.0]]], "lines": ["無理そうになったら", "先生が車で自転車ごと", "運んでくれるみたい"]}, {"box": [566, 1166, 664, 1396], "vertical": true, "font_size": 28, "lines_coords": [[[635.0, 1171.0], [661.0, 1171.0], [661.0, 1365.0], [635.0, 1365.0]], [[598.0, 1166.0], [630.0, 1166.0], [626.0, 1396.0], [594.0, 1396.0]], [[566.0, 1170.0], [592.0, 1170.0], [592.0, 1310.0], [566.0, 1310.0]]], "lines": ["１０キロぐらいで", "ギブアップしたら", "面白いかも"]}, {"box": [163, 1179, 228, 1426], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 1179.0], [225.0, 1179.0], [225.0, 1426.0], [200.0, 1426.0]], [[163.0, 1179.0], [189.0, 1179.0], [191.0, 1348.0], [165.0, 1348.0]]], "lines": ["さすがに１０キロじゃ", "しないからー"]}, {"box": [749, 1485, 819, 1754], "vertical": true, "font_size": 32, "lines_coords": [[[780.0, 1485.0], [819.0, 1485.0], [819.0, 1582.0], [780.0, 1582.0]], [[750.0, 1488.0], [776.0, 1488.0], [776.0, 1753.0], [750.0, 1753.0]]], "lines": ["なんだ", "それなら安心じゃん"]}], "img_path": "00146.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1102, 174, 1201, 570], "vertical": true, "font_size": 30, "lines_coords": [[[1170.0, 176.0], [1201.0, 176.0], [1201.0, 429.0], [1170.0, 429.0]], [[1134.0, 174.0], [1166.0, 174.0], [1168.0, 570.0], [1136.0, 570.0]], [[1102.0, 176.0], [1128.0, 176.0], [1128.0, 511.0], [1102.0, 511.0]]], "lines": ["それに先輩が夏休み", "ママチャリで毎日５０キロ走って", "ダイエットした話を聞いて"]}, {"box": [300, 232, 399, 540], "vertical": true, "font_size": 28, "lines_coords": [[[365.0, 232.0], [397.0, 232.0], [397.0, 515.0], [365.0, 515.0]], [[331.0, 236.0], [358.0, 236.0], [358.0, 540.0], [331.0, 540.0]], [[300.0, 236.0], [326.0, 236.0], [326.0, 375.0], [300.0, 375.0]]], "lines": ["私はロードバイクだし", "案外行けるんじゃないか", "って思って"]}, {"box": [174, 416, 210, 510], "vertical": true, "font_size": 36, "lines_coords": [[[174.0, 418.0], [210.0, 418.0], [210.0, 510.0], [174.0, 510.0]]], "lines": ["ふーん"]}, {"box": [1100, 690, 1163, 930], "vertical": true, "font_size": 29, "lines_coords": [[[1136.0, 691.0], [1162.0, 691.0], [1162.0, 875.0], [1136.0, 875.0]], [[1100.0, 690.0], [1132.0, 690.0], [1132.0, 930.0], [1100.0, 930.0]]], "lines": ["そういえば絵真", "バイトの方はどう？"]}, {"box": [661, 701, 703, 802], "vertical": true, "font_size": 42, "lines_coords": [[[661.0, 701.0], [703.0, 701.0], [703.0, 802.0], [661.0, 802.0]]], "lines": ["うーん"]}, {"box": [183, 676, 278, 943], "vertical": true, "font_size": 28, "lines_coords": [[[249.0, 680.0], [275.0, 680.0], [275.0, 943.0], [249.0, 943.0]], [[213.0, 678.0], [245.0, 678.0], [245.0, 918.0], [213.0, 918.0]], [[185.0, 676.0], [211.0, 676.0], [210.0, 840.0], [183.0, 840.0]]], "lines": ["始めたばっかりだから", "覚えることが多くて", "ちょっと大変"]}, {"box": [1098, 1049, 1195, 1387], "vertical": true, "font_size": 26, "lines_coords": [[[1166.0, 1050.0], [1192.0, 1050.0], [1192.0, 1299.0], [1166.0, 1299.0]], [[1130.0, 1050.0], [1156.0, 1050.0], [1156.0, 1273.0], [1130.0, 1273.0]], [[1098.0, 1051.0], [1125.0, 1051.0], [1125.0, 1387.0], [1098.0, 1387.0]]], "lines": ["今までアウトドアに", "興味無かったから", "商品知識とかまるで無いし"]}, {"box": [585, 1003, 684, 1421], "vertical": true, "font_size": 26, "lines_coords": [[[656.0, 1005.0], [682.0, 1005.0], [682.0, 1421.0], [656.0, 1421.0]], [[620.0, 1005.0], [646.0, 1005.0], [646.0, 1310.0], [620.0, 1310.0]], [[586.0, 1003.0], [613.0, 1003.0], [611.0, 1254.0], [585.0, 1254.0]]], "lines": ["でも逆にアウトドア好きだったら", "あれもこれも欲しいって", "なっちゃいそうだね"]}, {"box": [178, 1042, 212, 1252], "vertical": true, "font_size": 26, "lines_coords": [[[180.0, 1044.0], [206.0, 1044.0], [206.0, 1252.0], [180.0, 1252.0]]], "lines": ["あーそれそれ"]}, {"box": [783, 1560, 817, 1659], "vertical": true, "font_size": 34, "lines_coords": [[[783.0, 1560.0], [817.0, 1560.0], [817.0, 1659.0], [783.0, 1659.0]]], "lines": ["あぁー"]}], "img_path": "00147.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [556, 157, 665, 436], "vertical": true, "font_size": 30, "lines_coords": [[[630.0, 159.0], [661.0, 159.0], [661.0, 375.0], [630.0, 375.0]], [[594.0, 157.0], [626.0, 157.0], [624.0, 376.0], [592.0, 376.0]], [[558.0, 159.0], [585.0, 159.0], [585.0, 436.0], [558.0, 436.0]]], "lines": ["バイト代出たら", "キャンプ道具に", "課金するて言ってた"]}, {"box": [1115, 403, 1221, 682], "vertical": true, "font_size": 28, "lines_coords": [[[1192.0, 412.0], [1218.0, 412.0], [1218.0, 652.0], [1192.0, 652.0]], [[1151.0, 403.0], [1183.0, 403.0], [1183.0, 682.0], [1151.0, 682.0]], [[1115.0, 405.0], [1141.0, 405.0], [1141.0, 590.0], [1115.0, 590.0]]], "lines": ["一緒に働き始めた", "大学生バイトの人が", "居るんだけど"]}, {"box": [1123, 761, 1185, 1068], "vertical": true, "font_size": 26, "lines_coords": [[[1156.0, 763.0], [1183.0, 763.0], [1183.0, 1050.0], [1156.0, 1050.0]], [[1123.0, 763.0], [1149.0, 763.0], [1149.0, 1068.0], [1123.0, 1068.0]]], "lines": ["ううん虫が嫌いだから", "キャンプしないらしいよ"]}, {"box": [708, 415, 769, 693], "vertical": true, "font_size": 26, "lines_coords": [[[740.0, 416.0], [766.0, 416.0], [766.0, 693.0], [740.0, 693.0]], [[708.0, 418.0], [733.0, 418.0], [733.0, 693.0], [708.0, 693.0]]], "lines": ["その人キャンプ道具が", "めっちゃ好きらしくて"]}, {"box": [138, 418, 202, 699], "vertical": true, "font_size": 30, "lines_coords": [[[170.0, 418.0], [202.0, 418.0], [202.0, 646.0], [170.0, 646.0]], [[138.0, 421.0], [165.0, 421.0], [165.0, 699.0], [138.0, 699.0]]], "lines": ["キャンプ好きだと", "やっぱりそうなるんだ"]}, {"box": [166, 765, 239, 1074], "vertical": true, "font_size": 29, "lines_coords": [[[210.0, 766.0], [236.0, 766.0], [236.0, 980.0], [210.0, 980.0]], [[168.0, 765.0], [200.0, 765.0], [198.0, 1074.0], [166.0, 1074.0]]], "lines": ["えーじゃあ何で", "キャンプ道具買うの？"]}, {"box": [1147, 1134, 1214, 1530], "vertical": true, "font_size": 30, "lines_coords": [[[1186.0, 1140.0], [1213.0, 1140.0], [1213.0, 1445.0], [1186.0, 1445.0]], [[1147.0, 1134.0], [1179.0, 1134.0], [1181.0, 1530.0], [1149.0, 1530.0]]], "lines": ["部屋のインテリアを全部", "キャンプ道具にしたいんだって"]}, {"box": [382, 1126, 445, 1546], "vertical": true, "font_size": 25, "lines_coords": [[[418.0, 1128.0], [444.0, 1128.0], [444.0, 1490.0], [418.0, 1490.0]], [[382.0, 1126.0], [406.0, 1126.0], [406.0, 1545.0], [382.0, 1545.0]]], "lines": ["キャンプ道具ってオシャレで", "物欲を刺激するもの多いらしいね"]}, {"box": [487, 1396, 556, 1781], "vertical": true, "font_size": 32, "lines_coords": [[[523.0, 1396.0], [555.0, 1396.0], [556.0, 1781.0], [525.0, 1781.0]], [[487.0, 1398.0], [519.0, 1398.0], [519.0, 1753.0], [487.0, 1753.0]]], "lines": ["キャンプ好きなんじゃなくて", "キャンプ道具が好きなのか"]}, {"box": [148, 1496, 179, 1789], "vertical": true, "font_size": 24, "lines_coords": [[[150.0, 1496.0], [174.0, 1496.0], [174.0, 1786.0], [150.0, 1786.0]]], "lines": ["まだよく知らないけど"]}], "img_path": "00148.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [625, 154, 689, 329], "vertical": true, "font_size": 34, "lines_coords": [[[652.0, 157.0], [686.0, 157.0], [682.0, 328.0], [648.0, 328.0]]], "lines": ["これこんなに"]}, {"box": [136, 146, 206, 397], "vertical": true, "font_size": 32, "lines_coords": [[[172.0, 146.0], [204.0, 146.0], [206.0, 397.0], [174.0, 397.0]], [[136.0, 148.0], [168.0, 148.0], [168.0, 335.0], [136.0, 335.0]]], "lines": ["あれはハマったら", "やばい沼だよ"]}, {"box": [742, 457, 810, 811], "vertical": true, "font_size": 29, "lines_coords": [[[778.0, 457.0], [810.0, 457.0], [810.0, 811.0], [778.0, 811.0]], [[742.0, 459.0], [768.0, 459.0], [768.0, 751.0], [742.0, 751.0]]], "lines": ["それよりキャンプ道具って", "ものすごく高いんだよ"]}, {"box": [586, 410, 674, 725], "vertical": true, "font_size": 24, "lines_coords": [[[650.0, 410.0], [671.0, 410.0], [671.0, 534.0], [650.0, 534.0]], [[616.0, 410.0], [643.0, 410.0], [641.0, 725.0], [615.0, 725.0]], [[586.0, 412.0], [611.0, 412.0], [611.0, 560.0], [586.0, 560.0]]], "lines": ["どの商品も", "「え？値段間違えてない？」", "って感じだし"]}, {"box": [136, 510, 241, 718], "vertical": true, "font_size": 31, "lines_coords": [[[204.0, 510.0], [238.0, 510.0], [241.0, 633.0], [208.0, 633.0]], [[166.0, 510.0], [198.0, 510.0], [202.0, 718.0], [170.0, 718.0]], [[136.0, 513.0], [163.0, 513.0], [163.0, 631.0], [136.0, 631.0]]], "lines": ["あははは", "確かにヤバそう", "だよねー"]}, {"box": [1068, 894, 1186, 1336], "vertical": true, "font_size": 33, "lines_coords": [[[1149.0, 894.0], [1186.0, 894.0], [1186.0, 1271.0], [1149.0, 1271.0]], [[1110.0, 896.0], [1141.0, 896.0], [1141.0, 1336.0], [1110.0, 1336.0]], [[1068.0, 894.0], [1100.0, 894.0], [1100.0, 1305.0], [1068.0, 1305.0]]], "lines": ["いやいや高校生のくせに", "お金かかる趣味のダブル治に", "片足ずつ突っこんでるから"]}, {"box": [866, 999, 909, 1080], "vertical": true, "font_size": 43, "lines_coords": [[[866.0, 999.0], [909.0, 999.0], [909.0, 1080.0], [866.0, 1080.0]]], "lines": ["え？"]}, {"box": [870, 1248, 905, 1438], "vertical": true, "font_size": 32, "lines_coords": [[[873.0, 1248.0], [905.0, 1248.0], [901.0, 1438.0], [870.0, 1438.0]]], "lines": ["ロードバイク"]}, {"box": [264, 875, 326, 1132], "vertical": true, "font_size": 26, "lines_coords": [[[298.0, 877.0], [324.0, 877.0], [324.0, 1132.0], [298.0, 1132.0]], [[268.0, 875.0], [294.0, 875.0], [290.0, 1027.0], [264.0, 1027.0]]], "lines": ["早くバイト決めないと", "ヤバいかな？"]}, {"box": [427, 1335, 470, 1466], "vertical": true, "font_size": 39, "lines_coords": [[[431.0, 1335.0], [470.0, 1335.0], [466.0, 1466.0], [427.0, 1466.0]]], "lines": ["キャンプ"]}, {"box": [157, 1520, 219, 1715], "vertical": true, "font_size": 26, "lines_coords": [[[191.0, 1520.0], [217.0, 1520.0], [217.0, 1631.0], [191.0, 1631.0]], [[157.0, 1520.0], [183.0, 1520.0], [183.0, 1715.0], [157.0, 1715.0]]], "lines": ["何も活動", "できないと思う"]}], "img_path": "00149.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1123, 176, 1158, 245], "vertical": true, "font_size": 33, "lines_coords": [[[1123.0, 176.0], [1158.0