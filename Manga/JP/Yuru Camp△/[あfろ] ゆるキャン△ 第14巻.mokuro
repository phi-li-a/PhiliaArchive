[1149.0, 1089.0], [1125.0, 1089.0]]], "lines": ["あなでしこちゃんと", "あかりの寝花見や"]}, {"box": [170, 905, 231, 1250], "vertical": true, "font_size": 24, "lines_coords": [[[204.0, 907.0], [228.0, 907.0], [228.0, 1250.0], [204.0, 1250.0]], [[170.0, 907.0], [195.0, 907.0], [195.0, 1145.0], [170.0, 1145.0]]], "lines": ["寝袋で横になってする花見も", "気持ちよかったです"]}, {"box": [1098, 1437, 1192, 1781], "vertical": true, "font_size": 26, "lines_coords": [[[1166.0, 1440.0], [1192.0, 1440.0], [1192.0, 1650.0], [1166.0, 1650.0]], [[1132.0, 1440.0], [1158.0, 1440.0], [1158.0, 1781.0], [1132.0, 1781.0]], [[1098.0, 1438.0], [1123.0, 1438.0], [1123.0, 1755.0], [1098.0, 1755.0]]], "lines": ["けどそろそろ私も", "みんなみたいにキャンプ椅子", "買おうと思ってるんだよね"]}, {"box": [273, 1458, 333, 1677], "vertical": true, "font_size": 24, "lines_coords": [[[305.0, 1458.0], [331.0, 1458.0], [331.0, 1676.0], [305.0, 1676.0]], [[273.0, 1460.0], [294.0, 1460.0], [294.0, 1591.0], [273.0, 1591.0]]], "lines": ["んどの椅子買うか", "決めたん？"]}, {"box": [168, 1609, 192, 1742], "vertical": true, "font_size": 21, "lines_coords": [[[168.0, 1610.0], [189.0, 1610.0], [189.0, 1740.0], [168.0, 1740.0]]], "lines": ["ううんまだ"]}], "img_path": "00060.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1125, 161, 1217, 504], "vertical": true, "font_size": 26, "lines_coords": [[[1190.0, 161.0], [1216.0, 161.0], [1216.0, 294.0], [1190.0, 294.0]], [[1156.0, 161.0], [1183.0, 161.0], [1185.0, 478.0], [1158.0, 478.0]], [[1125.0, 161.0], [1151.0, 161.0], [1151.0, 504.0], [1125.0, 504.0]]], "lines": ["だから今度", "バイト前にカリブー寄って", "見てこようと思うんだけど．．．"]}, {"box": [365, 133, 631, 225], "vertical": false, "font_size": 74, "lines_coords": [[[365.0, 151.0], [626.0, 133.0], [631.0, 206.0], [371.0, 225.0]]], "lines": ["どうかうかラッ"]}, {"box": [153, 196, 296, 500], "vertical": true, "font_size": 72, "lines_coords": [[[215.0, 196.0], [296.0, 196.0], [296.0, 448.0], [215.0, 448.0]], [[153.0, 196.0], [217.0, 196.0], [217.0, 500.0], [153.0, 500.0]]], "lines": ["大変だぞ", "お前らっ！！"]}, {"box": [1132, 656, 1194, 817], "vertical": true, "font_size": 26, "lines_coords": [[[1168.0, 656.0], [1194.0, 656.0], [1190.0, 787.0], [1164.0, 787.0]], [[1132.0, 658.0], [1158.0, 658.0], [1158.0, 817.0], [1132.0, 817.0]]], "lines": ["どうしたの", "あきちゃん？"]}, {"box": [571, 639, 665, 849], "vertical": true, "font_size": 25, "lines_coords": [[[637.0, 641.0], [661.0, 641.0], [661.0, 800.0], [637.0, 800.0]], [[603.0, 641.0], [630.0, 641.0], [630.0, 849.0], [603.0, 849.0]], [[571.0, 639.0], [596.0, 639.0], [596.0, 800.0], [571.0, 800.0]]], "lines": ["勧誘ボスター", "貼りに行ったんや", "なかったん？"]}, {"box": [163, 654, 224, 840], "vertical": true, "font_size": 26, "lines_coords": [[[195.0, 656.0], [221.0, 656.0], [221.0, 840.0], [195.0, 840.0]], [[163.0, 654.0], [189.0, 654.0], [189.0, 761.0], [163.0, 761.0]]], "lines": ["貼りに行ったよ", "そしたら"]}, {"box": [1113, 897, 1194, 1412], "vertical": true, "font_size": 35, "lines_coords": [[[1158.0, 901.0], [1190.0, 901.0], [1190.0, 1411.0], [1158.0, 1411.0]], [[1113.0, 900.0], [1151.0, 900.0], [1151.0, 1276.0], [1113.0, 1276.0]]], "lines": ["ほとんどの部活がキャンプ推しに", "なってやがるんだよー！！"]}, {"box": [699, 1252, 873, 1299], "vertical": false, "font_size": 23.5, "lines_coords": [[[699.0, 1252.0], [873.0, 1256.0], [873.0, 1282.0], [699.0, 1278.0]], [[706.0, 1278.0], [817.0, 1278.0], [817.0, 1299.0], [706.0, 1299.0]]], "lines": ["野外料理、Ｂ級グルメとんあります", "とか作ります"]}, {"box": [512, 1191, 661, 1259], "vertical": false, "font_size": 68, "lines_coords": [[[512.0, 1191.0], [661.0, 1191.0], [661.0, 1259.0], [512.0, 1259.0]]], "lines": ["囲碁将棋部甌♯ッゃリます"]}, {"box": [343, 1156, 513, 1344], "vertical": true, "font_size": 159, "lines_coords": [[[354.0, 1156.0], [513.0, 1166.0], [502.0, 1344.0], [343.0, 1335.0]]], "lines": ["書道部アウトドアをはじめました"]}, {"box": [1080, 1492, 1141, 1756], "vertical": true, "font_size": 24, "lines_coords": [[[1113.0, 1494.0], [1138.0, 1494.0], [1138.0, 1755.0], [1113.0, 1755.0]], [[1080.0, 1492.0], [1104.0, 1492.0], [1104.0, 1756.0], [1080.0, 1756.0]]], "lines": ["キャンプブームの波が", "こんなところにまで："]}, {"box": [225, 1499, 316, 1764], "vertical": true, "font_size": 26, "lines_coords": [[[290.0, 1500.0], [316.0, 1500.0], [316.0, 1606.0], [290.0, 1606.0]], [[256.0, 1500.0], [283.0, 1500.0], [283.0, 1764.0], [256.0, 1764.0]], [[225.0, 1500.0], [249.0, 1500.0], [249.0, 1687.0], [225.0, 1687.0]]], "lines": ["ええー．．．", "囲碁将棋とキャンプで", "関係ないやん．．．"]}], "img_path": "00061.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [811, 180, 868, 311], "vertical": true, "font_size": 24, "lines_coords": [[[841.0, 180.0], [868.0, 180.0], [868.0, 311.0], [841.0, 311.0]], [[811.0, 181.0], [832.0, 181.0], [832.0, 311.0], [811.0, 311.0]]], "lines": ["どうしよう", "あきちゃん"]}, {"box": [1126, 367, 1221, 765], "vertical": true, "font_size": 26, "lines_coords": [[[1192.0, 367.0], [1220.0, 367.0], [1218.0, 765.0], [1190.0, 765.0]], [[1160.0, 369.0], [1186.0, 369.0], [1186.0, 660.0], [1160.0, 660.0]], [[1126.0, 369.0], [1151.0, 369.0], [1151.0, 686.0], [1126.0, 686.0]]], "lines": ["人気の部活にこんな事やられたら", "弱小サークルのうちらは", "新入部員取られてまうで．．．"]}, {"box": [1059, 802, 1189, 1066], "vertical": true, "font_size": 39, "lines_coords": [[[1145.0, 804.0], [1185.0, 804.0], [1188.0, 991.0], [1149.0, 991.0]], [[1102.0, 806.0], [1141.0, 806.0], [1141.0, 1025.0], [1102.0, 1025.0]], [[1059.0, 802.0], [1098.0, 802.0], [1098.0, 1066.0], [1059.0, 1066.0]]], "lines": ["という訳で", "各部へ直談判", "しに行くことに"]}, {"box": [893, 825, 958, 926], "vertical": true, "font_size": 65, "lines_coords": [[[893.0, 825.0], [958.0, 825.0], [958.0, 926.0], [893.0, 926.0]]], "lines": ["行くぞ野郎ども！！"]}, {"box": [834, 528, 861, 740], "vertical": true, "font_size": 26, "lines_coords": [[[834.0, 528.0], [860.0, 528.0], [860.0, 738.0], [834.0, 738.0]]], "lines": ["こうなったらもう"]}, {"box": [138, 390, 230, 758], "vertical": true, "font_size": 40, "lines_coords": [[[189.0, 395.0], [228.0, 395.0], [228.0, 716.0], [189.0, 716.0]], [[138.0, 395.0], [178.0, 395.0], [178.0, 757.0], [138.0, 757.0]]], "lines": ["各部へ殴り込みに", "行くし