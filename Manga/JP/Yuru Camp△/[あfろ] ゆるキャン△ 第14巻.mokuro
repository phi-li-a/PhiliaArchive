1519], "vertical": true, "font_size": 114, "lines_coords": [[[987.0, 1257.0], [1101.0, 1257.0], [1101.0, 1519.0], [987.0, 1519.0]]], "lines": ["．．．"]}, {"box": [303, 1349, 507, 1389], "vertical": false, "font_size": 32, "lines_coords": [[[309.0, 1355.0], [498.0, 1355.0], [498.0, 1387.0], [309.0, 1387.0]]], "lines": ["いいんですよ。"]}, {"box": [1170, 1263, 1205, 1629], "vertical": true, "font_size": 31, "lines_coords": [[[1170.0, 1263.0], [1201.0, 1263.0], [1201.0, 1629.0], [1170.0, 1629.0]]], "lines": ["この辺りに居る動物と言えば"]}, {"box": [712, 1292, 784, 1656], "vertical": true, "font_size": 34, "lines_coords": [[[750.0, 1295.0], [781.0, 1295.0], [781.0, 1653.0], [750.0, 1653.0]], [[712.0, 1293.0], [750.0, 1293.0], [750.0, 1569.0], [712.0, 1569.0]]], "lines": ["タヌキハクビシンカモシカ", "さるイノシシ．．．クマ"]}, {"box": [573, 1270, 639, 1747], "vertical": true, "font_size": 30, "lines_coords": [[[603.0, 1271.0], [635.0, 1271.0], [635.0, 1554.0], [603.0, 1554.0]], [[573.0, 1275.0], [600.0, 1275.0], [600.0, 1747.0], [573.0, 1747.0]]], "lines": ["タヌキとかなら良いが", "イノシシとかクマだったらどうする？"]}, {"box": [163, 1318, 230, 1655], "vertical": true, "font_size": 32, "lines_coords": [[[198.0, 1318.0], [230.0, 1318.0], [228.0, 1601.0], [196.0, 1601.0]], [[163.0, 1320.0], [195.0, 1320.0], [195.0, 1655.0], [163.0, 1655.0]]], "lines": ["キャンプ場にお約束の", "クマ注意看板無かったか？"]}], "img_path": "00034.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1096, 148, 1184, 521], "vertical": true, "font_size": 42, "lines_coords": [[[1141.0, 150.0], [1181.0, 150.0], [1181.0, 519.0], [1141.0, 519.0]], [[1096.0, 148.0], [1141.0, 148.0], [1141.0, 423.0], [1096.0, 423.0]]], "lines": ["確かここからドイレまで", "２０メートルぐらい"]}, {"box": [1098, 600, 1183, 944], "vertical": true, "font_size": 40, "lines_coords": [[[1140.0, 600.0], [1179.0, 600.0], [1181.0, 941.0], [1141.0, 941.0]], [[1098.0, 603.0], [1138.0, 603.0], [1138.0, 937.0], [1098.0, 937.0]]], "lines": ["ゆっくり歩いていると", "万が一クマに会ったら"]}, {"box": [281, 628, 361, 1134], "vertical": true, "font_size": 46, "lines_coords": [[[320.0, 628.0], [358.0, 628.0], [361.0, 1132.0], [324.0, 1132.0]], [[281.0, 628.0], [318.0, 628.0], [318.0, 1134.0], [281.0, 1134.0]]], "lines": ["目を合わせず背中を見せないよう", "後ろにゆっくり下がって距離を．．．"]}, {"box": [161, 601, 226, 1134], "vertical": true, "font_size": 46, "lines_coords": [[[161.0, 601.0], [225.0, 601.0], [226.0, 1134.0], [163.0, 1134.0]]], "lines": ["取ってたら絶対漏らす"]}, {"box": [1138, 1224, 1209, 1566], "vertical": true, "font_size": 35, "lines_coords": [[[1171.0, 1224.0], [1209.0, 1224.0], [1209.0, 1518.0], [1171.0, 1518.0]], [[1138.0, 1224.0], [1170.0, 1224.0], [1170.0, 1563.0], [1138.0, 1563.0]]], "lines": ["いっそのことトイレに", "ダッシュして立て籠もるか"]}, {"box": [583, 1224, 662, 1654], "vertical": true, "font_size": 38, "lines_coords": [[[624.0, 1226.0], [661.0, 1226.0], [661.0, 1651.0], [624.0, 1651.0]], [[583.0, 1224.0], [622.0, 1224.0], [626.0, 1428.0], [586.0, 1428.0]]], "lines": ["ていうかそんな頑丈なドイレには", "見えなかったし"]}, {"box": [729, 1457, 798, 1770], "vertical": true, "font_size": 32, "lines_coords": [[[765.0, 1458.0], [796.0, 1458.0], [796.0, 1770.0], [765.0, 1770.0]], [[729.0, 1458.0], [761.0, 1458.0], [761.0, 1768.0], [729.0, 1768.0]]], "lines": ["いやいや立て籠もったら", "きっと朝までそのままだ"]}, {"box": [138, 1459, 210, 1773], "vertical": true, "font_size": 35, "lines_coords": [[[172.0, 1460.0], [210.0, 1460.0], [210.0, 1773.0], [172.0, 1773.0]], [[138.0, 1460.0], [170.0, 1460.0], [170.0, 1635.0], [138.0, 1635.0]]], "lines": ["クマなんかに襲われたら", "ひどたまりも"]}], "img_path": "00035.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1125, 208, 1198, 489], "vertical": true, "font_size": 73, "lines_coords": [[[1125.0, 208.0], [1198.0, 208.0], [1198.0, 489.0], [1125.0, 489.0]]], "lines": ["ぼすっ！"]}, {"box": [131, 166, 251, 519], "vertical": true, "font_size": 59, "lines_coords": [[[185.0, 166.0], [251.0, 166.0], [251.0, 519.0], [185.0, 519.0]], [[131.0, 170.0], [183.0, 170.0], [187.0, 470.0], [135.0, 470.0]]], "lines": ["ひぃぃぃいいい", "いい！！！"]}, {