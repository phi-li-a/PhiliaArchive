, {"box": [258, 721, 292, 819], "vertical": true, "font_size": 34, "lines_coords": [[[258.0, 721.0], [292.0, 721.0], [292.0, 819.0], [258.0, 819.0]]], "lines": ["あぁー"]}, {"box": [213, 924, 315, 1248], "vertical": true, "font_size": 29, "lines_coords": [[[283.0, 924.0], [315.0, 924.0], [315.0, 1248.0], [283.0, 1248.0]], [[245.0, 924.0], [277.0, 924.0], [279.0, 1190.0], [247.0, 1190.0]], [[213.0, 926.0], [240.0, 926.0], [240.0, 1160.0], [213.0, 1160.0]]], "lines": ["山に鳥居みたいな模様が", "ついてたから撮って", "みたんだけど．．．"]}, {"box": [150, 1126, 176, 1363], "vertical": true, "font_size": 29, "lines_coords": [[[150.0, 1126.0], [176.0, 1126.0], [176.0, 1363.0], [150.0, 1363.0]]], "lines": ["何だろうねコレ？"]}, {"box": [1138, 1460, 1186, 1693], "vertical": true, "font_size": 32, "lines_coords": [[[1138.0, 1460.0], [1170.0, 1460.0], [1170.0, 1693.0], [1138.0, 1693.0]]], "lines": ["これは一茨形焼」。"]}, {"box": [184, 1473, 217, 1698], "vertical": true, "font_size": 26, "lines_coords": [[[185.0, 1473.0], [211.0, 1473.0], [211.0, 1696.0], [185.0, 1696.0]]], "lines": ["おいがたやき？"]}], "img_path": "00012.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1112, 165, 1179, 476], "vertical": true, "font_size": 30, "lines_coords": [[[1147.0, 165.0], [1179.0, 165.0], [1179.0, 446.0], [1147.0, 446.0]], [[1113.0, 166.0], [1140.0, 166.0], [1140.0, 476.0], [1113.0, 476.0]]], "lines": ["今からこれ見に行く", "予定だったんだけど．．．"]}, {"box": [526, 596, 564, 806], "vertical": true, "font_size": 38, "lines_coords": [[[526.0, 596.0], [564.0, 596.0], [564.0, 806.0], [526.0, 806.0]]], "lines": ["一緒に来る？"]}], "img_path": "00013.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1156, 196, 1186, 380], "vertical": true, "font_size": 27, "lines_coords": [[[1158.0, 196.0], [1185.0, 196.0], [1183.0, 380.0], [1156.0, 380.0]]], "lines": ["いい景色の所ね"]}, {"box": [978, 283, 1037, 543], "vertical": true, "font_size": 26, "lines_coords": [[[1012.0, 285.0], [1036.0, 285.0], [1036.0, 543.0], [1012.0, 543.0]], [[978.0, 283.0], [1005.0, 283.0], [1005.0, 534.0], [978.0, 534.0]]], "lines": ["リンちゃん茨形焼って", "どのへんに見えるの？"]}, {"box": [183, 270, 241, 560], "vertical": true, "font_size": 26, "lines_coords": [[[215.0, 270.0], [241.0, 270.0], [241.0, 376.0], [215.0, 376.0]], [[183.0, 270.0], [208.0, 270.0], [208.0, 560.0], [183.0, 560.0]]], "lines": ["えーと．．．", "たぶんあの山の辺りかな"]}, {"box": [1158, 701, 1185, 1018], "vertical": true, "font_size": 26, "lines_coords": [[[1158.0, 701.0], [1185.0, 701.0], [1185.0, 1018.0], [1158.0, 1018.0]]], "lines": ["毎年４月１日から何日間か"]}, {"box": [1066, 796, 1125, 1089], "vertical": true, "font_size": 26, "lines_coords": [[[1098.0, 796.0], [1125.0, 796.0], [1125.0, 1063.0], [1098.0, 1063.0]], [[1066.0, 798.0], [1091.0, 798.0], [1091.0, 1089.0], [1066.0, 1089.0]]], "lines": ["夜になると鳥居の形に", "ライトアップするんだよ"]}, {"box": [183, 791, 232, 896], "vertical": true, "font_size": 49, "lines_coords": [[[183.0, 791.0], [232.0, 791.0], [232.0, 896.0], [183.0, 896.0]]], "lines": ["へぇー"]}, {"box": [1151, 1192, 1216, 1515], "vertical": true, "font_size": 26, "lines_coords": [[[1190.0, 1192.0], [1215.0, 1192.0], [1215.0, 1515.0], [1190.0, 1515.0]], [[1151.0, 1192.0], [1177.0, 1192.0], [1177.0, 1316.0], [1151.0, 1316.0]]], "lines": ["まぁ正しくは鳥居じゃなくて", "「茨」らしい"]}, {"box": [997, 1233, 1036, 1331], "vertical": true, "font_size": 39, "lines_coords": [[[997.0, 1233.0], [1036.0, 1233.0], [1036.0, 1331.0], [997.0, 1331.0]]], "lines": ["おい？"]}, {"box": [564, 1230, 598, 1329], "vertical": true, "font_size": 32, "lines_coords": [[[564.0, 1230.0], [596.0, 1230.0], [596.0, 1329.0], [564.0, 1329.0]]], "lines": ["笈形焼"]}, {"box": [675, 1543, 740, 1779], "vertical": true, "font_size": 26, "lines_coords": [[[710.0, 1545.0], [736.0, 1545.0], [736.0, 1721.0], [710.0, 1721.0]], [[675.0, 1545.0], [701.0, 1545.0], [701.0, 1779.0], [675.0, 1779.0]]], "lines": ["私も詳しくは", "知らないんだけど"]}, {"box": [150, 1523, 223, 1747], "vertical": true, "font_size": 26, "lines_coords": [[[193.0, 1524.0], [219.0, 1524.0], [219.0, 1691.0], [193.0, 1691.0]], [[151.0, 1526.0], [178.0, 1526.0], [178.0, 1747.0], [151.0, 1747.0]]], "lines": ["山伏が背負う", "「愛」を模した篝火"]}], "img_path": "00014.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1157, 138, 1221, 455], "vertical": true, "font_size": 26, "lines_coords": [[[1190.0, 138.0], [1218.0, 138.0], [1220.0, 455.0], [1192.0, 455.0]], [[1158.0, 140.0], [1183.0, 140.0], [1183.0, 391.0], [1158.0, 391.0]]], "lines": ["平安時代甲州の大善寺と", "笛吹の長谷寺の間で"]}, {"box": [684, 144, 748, 369], "vertical": true, "font_size": 26, "lines_coords": [[[720.0, 146.0], [746.0, 146.0], [746.0, 313.0], [720.0, 313.0]], [[684.0, 144.0], [710.0, 144.0], [710.0, 367.0], [684.0, 367.0]]], "lines": ["大きな争いが", "起こっていました"]}, {"box": [583, 138, 646, 446], "vertical": true, "font_size": 26, "lines_coords": [[[618.0, 140.0], [643.0, 140.0], [643.0, 446.0], [618.0, 446.0]], [[583.0, 140.0], [609.0, 140.0], [609.0, 390.0], [583.0, 390.0]]], "lines": ["争いは死人が出るような", "とても大きなもので"]}, {"box": [66, 204, 241, 239], "vertical": false, "font_size": 25, "lines_coords": [[[73.0, 211.0], [236.0, 211.0], [236.0, 236.0], [73.0, 236.0]]], "lines": ["ＤＨＯＫＯＫＵＪ"]}, {"box": [1045, 632, 1223, 674], "vertical": false, "font_size": 42, "lines_coords": [[[1045.0, 632.0], [1223.0, 632.0], [1223.0, 674.0], [1045.0, 674.0]]], "lines": ["ＤＡＩＺＥＮＪＩ"]}, {"box": [1153, 729, 1216, 1046], "vertical": true, "font_size": 28, "lines_coords": [[[1185.0, 729.0], [1216.0, 729.0], [1216.0, 1046.0], [1185.0, 1046.0]], [[1153.0, 729.0], [1179.0, 729.0], [1179.0, 894.0], [1153.0, 894.0]]], "lines": ["そのせいで大善寺の僧が", "怒ってしまい"]}, {"box": [692, 633, 871, 673], "vertical": false, "font_size": 40, "lines_coords": [[[692.0, 633.0], [871.0, 633.0], [871.0, 673.0], [692.0, 673.0]]], "lines": ["ＣＨＯＫＯＫＵＪＩ"]}, {"box": [52, 375, 150, 682], "vertical": true, "font_size": 26, "lines_coords": [[[121.0, 375.0], [148.0, 375.0], [148.0, 652.0], [121.0, 652.0]], [[86.0, 375.0], [112.0, 375.0], [112.0, 682.0], [86.0, 682.0]], [[52.0, 376.0], [78.0, 376.0], [78.0, 680.0], [52.0, 680.0]]], "lines": ["見かねた山梨岡神社が", "長谷寺に加勢して争いを", "収めようとしたのですが、"]}, {"box": [65, 733, 129, 1039], "vertical": true, "font_size": 26, "lines_coords": [[[101.0, 733.0], [127.0, 733.0], [127.0, 1012.0], [101.0, 1012.0]], [[65.0, 733.0], [91.0, 733.0], [91.0, 1038.0], [65.0, 1038.0]]], "lines": ["仕返しに大善寺の笈を", "燃やしてしまったのです"]}, {"box": [676, 952, 742, 1260], "vertical": true, "font_size": 26, "lines_coords": [[[712.0, 956.0], [738.0, 956.0], [738.0, 1260.0], [712.0, 1260.0]], [[676.0, 952.0], [703.0, 952.0], [703.0, 1235.0], [676.0, 1235.0]]], "lines": ["山梨岡神社の鳥居を奪い", "燃やしてしまいました"]}, {"box": [590, 892, 621, 1260], "vertical": true, "font_size": 26, "lines_coords": [[[590.0, 892.0], [616.0, 892.0], [616.0, 1254.0], [590.0, 1254.0]]], "lines": ["それを見た長谷寺の信も怒り"]}, {"box": [1096, 1333, 1195, 1696], "vertical": true, "font_size": 27, "lines_coords": [[[1166.0, 1335.0], [1192.0, 1335.0], [1192.0, 1696.0], [1166.0, 1696.0]], [[1128.0, 1333.0], [1155.0, 1333.0], [1155.0, 1526.0], [1128.0, 1526.0]], [[1096.0, 1335.0], [1123.0, 1335.0], [1123.0, 1640.0], [1096.0, 1640.0]]], "lines": ["この出来事が笛吹の笈形焼と", "甲州の鳥居焼の", "始まりと言われています"]}, {"box": [153, 1477, 225, 1775], "vertical": true, "font_size": 32, "lines_coords": [[[193.0, 1477.0], [225.0, 1477.0], [225.0, 1745.0], [193.0, 1745.0]], [[155.0, 1477.0], [187.0, 1477.0], [185.0, 1775.0], [153.0, 1775.0]]], "lines": ["えぇ．．．そんな物騒な", "由来だったんですか？"]}], "img_path": "00015.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1115, 163, 1175, 427], "vertical": true, "font_size": 28, "lines_coords": [[[1143.0, 163.0], [1175.0, 163.0], [1175.0, 427.0], [1143.0, 427.0]], [[1115.0, 166.0], [1140.0, 166.0], [1140.0, 403.0], [1115.0, 403.0]]], "lines": ["もっとお祭り的なもの", "かと思ってました．．．"]}, {"box": [320, 168, 385, 394], "vertical": true, "font_size": 26, "lines_coords": [[[358.0, 170.0], [384.0, 170.0], [384.0, 339.0], [358.0, 339.0]], [[320.0, 168.0], [346.0, 168.0], [346.0, 391.0], [320.0, 391.0]]], "lines": ["まぁ歴史って", "そういうものよね"]}, {"box": [161, 236, 256, 429], "vertical": true, "font_size": 24, "lines_coords": [[[228.0, 238.0], [255.0, 238.0], [255.0, 429.0], [228.0, 429.0]], [[193.0, 236.0], [219.0, 236.0], [219.0, 429.0], [193.0, 429.0]], [[161.0, 238.0], [181.0, 238.0], [181.0, 373.0], [161.0, 373.0]]], "lines": ["戦国武将だって", "今では英雄扱い", "されてるし"]}, {"box": [1141, 510, 1205, 929], "vertical": true, "font_size": 27, "lines_coords": [[[1173.0, 510.0], [1200.0, 510.0], [1200.0, 926.0], [1173.0, 926.0]], [[1141.0, 511.0], [1168.0, 511.0], [1168.0, 901.0], [1141.0, 901.0]]], "lines": ["江戸時代頃からは精霊送りの蒼火", "みたいな意味でやってたようね"]}, {"box": [601, 506, 671, 975], "vertical": true, "font_size": 30, "lines_coords": [[[635.0, 506.0], [667.0, 506.0], [669.0, 975.0], [637.0, 975.0]], [[601.0, 510.0], [628.0, 510.0], [628.0, 883.0], [601.0, 883.0]]], "lines": ["念形嫁が今も続いてるってことは", "鳥居焼もまだやってるの？"]}, {"box": [146, 772, 182, 1108], "vertical": true, "font_size": 26, "lines_coords": [[[148.0, 772.0], [174.0, 772.0], [174.0, 1108.0], [148.0, 1108.0]]], "lines": ["うん鳥居焼は毎年１０月"]}, {"box": [1121, 1222, 1186, 1458], "vertical": true, "font_size": 26, "lines_coords": [[[1158.0, 1224.0], [1185.0, 1224.0], [1185.0, 1458.0], [1158.0, 1458.0]], [[1121.0, 1222.0], [1145.0, 1222.0], [1145.0, 1428.0], [1121.0, 1428.0]]], "lines": ["ていうか鳥居焼は", "真後ろにあるし"]}, {"box": [740, 896, 766, 1090], "vertical": true, "font_size": 25, "lines_coords": [[[740.0, 896.0], [765.0, 896.0], [765.0, 1089.0], [740.0, 1089.0]]], "lines": ["そうなんですね"]}, {"box": [806, 1575, 883, 1706], "vertical": true, "font_size": 38, "lines_coords": [[[840.0, 1575.0], [883.0, 1575.0], [883.0, 1650.0], [840.0, 1650.0]], [[806.0, 1582.0], [840.0, 1582.0], [840.0, 1706.0], [806.0, 1706.0]]], "lines": ["うわ", "ホントだ"]}, {"box": [189, 1395, 259, 1614], "vertical": true, "font_size": 32, "lines_coords": [[[223.0, 1395.0], [255.0, 1395.0], [258.0, 1584.0], [226.0, 1584.0]], [[189.0, 1396.0], [221.0, 1396.0], [221.0, 1614.0], [189.0, 1614.0]]], "lines": ["ここ鳥居焼の", "真下だったんだ"]}], "img_path": "00016.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1153, 170, 1215, 480], "vertical": true, "font_size": 26, "lines_coords": [[[1185.0, 170.0], [1211.0, 170.0], [1211.0, 423.0], [1185.0, 423.0]], [[1153.0, 172.0], [1179.0, 172.0], [1179.0, 480.0], [1153.0, 480.0]]], "lines": ["茨形焼は今は照明を", "使ってるらしいんだけど"]}, {"box": [671, 131, 741, 521], "vertical": true, "font_size": 26, "lines_coords": [[[708.0, 135.0], [735.0, 135.0], [735.0, 521.0], [708.0, 521.0]], [[671.0, 131.0], [697.0, 131.0], [699.0, 412.0], [673.0, 412.0]]], "lines": ["鳥居焼は昔ながらに薪を焚いて", "篝火をしてるんだって"]}, {"box": [596, 159, 630, 504], "vertical": true, "font_size": 26, "lines_coords": [[[598.0, 163.0], [624.0, 163.0], [624.0, 500.0], [598.0, 500.0]]], "lines": ["甲州の鳥居焼は１０月上旬"]}, {"box": [138, 288, 201, 652], "vertical": true, "font_size": 26, "lines_coords": [[[172.0, 290.0], [198.0, 290.0], [198.0, 652.0], [172.0, 652.0]], [[138.0, 288.0], [163.0, 288.0], [163.0, 652.0], [138.0, 652.0]]], "lines": ["地元の中学生ボランティアが", "柏尾山の山肌に薪を積み上げ、"]}, {"box": [1149, 722, 1213, 1174], "vertical": true, "font_size": 26, "lines_coords": [[[1183.0, 723.0], [1211.0, 723.0], [1213.0, 1061.0], [1185.0, 1061.0]], [[1149.0, 727.0], [1173.0, 727.0], [1173.0, 1171.0], [1149.0, 1171.0]]], "lines": ["鳥居焼き当日には大善寺で", "採火された松明を持って町内を走り"]}, {"box": [721, 564, 768, 660], "vertical": true, "font_size": 44, "lines_coords": [[[721.0, 566.0], [765.0, 564.0], [768.0, 658.0], [725.0, 660.0]]], "lines": ["へぇー"]}, {"box": [667, 785, 738, 1111], "vertical": true, "font_size": 30, "lines_coords": [[[708.0, 789.0], [735.0, 789.0], [735.0, 1111.0], [708.0, 1111.0]], [[669.0, 785.0], [701.0, 785.0], [699.0, 1087.0], [667.0, 1087.0]]], "lines": ["最終的に山へ駆け上がり", "鳥居焼に火を灯します"]}, {"box": [215, 817, 241, 1083], "vertical": true, "font_size": 29, "lines_coords": [[[215.0, 817.0], [241.0, 817.0], [241.0, 1083.0], [215.0, 1083.0]]], "lines": ["中学生大活躍ですね"]}, {"box": [138, 787, 172, 1171], "vertical": true, "font_size": 29, "lines_coords": [[[140.0, 787.0], [172.0, 787.0], [170.0, 1171.0], [138.0, 1171.0]]], "lines": ["でも何か楽しそうじゃない？"]}, {"box": [1130, 1305, 1192, 1638], "vertical": true, "font_size": 26, "lines_coords": [[[1164.0, 1305.0], [1190.0, 1305.0], [1190.0, 1638.0], [1164.0, 1638.0]], [[1130.0, 1305.0], [1155.0, 1305.0], [1155.0, 1528.0], [1130.0, 1528.0]]], "lines": ["キャンプで似たようなことを", "出来ないかなぁ？"]}, {"box": [161, 1297, 229, 1655], "vertical": true, "font_size": 29, "lines_coords": [[[195.0, 1301.0], [226.0, 1301.0], [228.0, 1655.0], [196.0, 1655.0]], [[161.0, 1303.0], [187.0, 1303.0], [187.0, 1449.0], [161.0, 1449.0]]], "lines": ["松明持って走り回る時点で", "アウトだろ"]}], "img_path": "00017.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [926, 165, 989, 429], "vertical": true, "font_size": 26, "lines_coords": [[[961.0, 166.0], [988.0, 166.0], [988.0, 429.0], [961.0, 429.0]], [[928.0, 165.0], [954.0, 165.0], [952.0, 416.0], [926.0, 416.0]]], "lines": ["それでリンちゃんは", "ここによく来てたの"]}, {"box": [166, 324, 232, 609], "vertical": true, "font_size": 32, "lines_coords": [[[195.0, 324.0], [232.0, 324.0], [232.0, 390.0], [195.0, 390.0]], [[166.0, 328.0], [193.0, 328.0], [193.0, 609.0], [166.0, 609.0]]], "lines": ["うん", "小さい頃なんだけど．．．"]}, {"box": [1130, 718, 1217, 991], "vertical": true, "font_size": 26, "lines_coords": [[[1190.0, 720.0], [1216.0, 720.0], [1216.0, 965.0], [1190.0, 965.0]], [[1160.0, 718.0], [1186.0, 718.0], [1185.0, 894.0], [1158.0, 894.0]], [[1130.0, 718.0], [1155.0, 718.0], [1155.0, 991.0], [1130.0, 991.0]]], "lines": ["毎年春になると家族で", "花見に出かけて", "甲府で夕飯を食べた後は"]}, {"box": [826, 725, 883, 973], "vertical": true, "font_size": 25, "lines_coords": [[[856.0, 725.0], [881.0, 725.0], [881.0, 973.0], [856.0, 973.0]], [[826.0, 725.0], [851.0, 725.0], [851.0, 875.0], [826.0, 875.0]]], "lines": ["ここで笈形焼を眺めに", "来てたんだよ"]}, {"box": [622, 729, 680, 1102], "vertical": true, "font_size": 25, "lines_coords": [[[654.0, 729.0], [680.0, 729.0], [680.0, 1003.0], [654.0, 1003.0]], [[622.0, 729.0], [646.0, 729.0], [646.0, 1102.0], [622.0, 1102.0]]], "lines": ["もう随分来てなかったし、", "自分で運転してた訳じゃないけど、"]}, {"box": [748, 988, 783, 1078], "vertical": true, "font_size": 35, "lines_coords": [[[748.0, 988.0], [783.0, 988.0], [783.0, 1078.0], [748.0, 1078.0]]], "lines": ["ふーん"]}, {"box": [133, 1040, 193, 1305], "vertical": true, "font_size": 25, "lines_coords": [[[163.0, 1040.0], [189.0, 1040.0], [189.0, 1305.0], [163.0, 1305.0]], [[133.0, 1042.0], [157.0, 1042.0], [157.0, 1201.0], [133.0, 1201.0]]], "lines": ["道って意外と覚えてる", "ものなんだな"]}, {"box": [361, 1449, 422, 1700], "vertical": true, "font_size": 26, "lines_coords": [[[395.0, 1449.0], [421.0, 1449.0], [421.0, 1644.0], [395.0, 1644.0]], [[361.0, 1449.0], [386.0, 1449.0], [386.0, 1700.0], [361.0, 1700.0]]], "lines": ["．．．リンちゃんの", "思い出の風景なんだ"]}], "img_path": "00018.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1132, 157, 1194, 448], "vertical": true, "font_size": 23, "lines_coords": [[[1168.0, 161.0], [1188.0, 161.0], [1188.0, 290.0], [1168.0, 290.0]], [[1132.0, 157.0], [1158.0, 157.0], [1162.0, 448.0], [1136.0, 448.0]]], "lines": ["１６時５分．．．", "そろそろ点灯する時間ね"]}, {"box": [425, 168, 457, 348], "vertical": true, "font_size": 32, "lines_coords": [[[425.0, 168.0], [457.0, 168.0], [457.0, 348.0], [425.0, 348.0]]], "lines": ["あっあそこ！"]}], "img_path": "00019.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1269, 671, 1344, 690], "vertical": false, "font_size": 19, "lines_coords": [[[1269.0, 671.0], [1344.0, 671.0], [1344.0, 690.0], [1269.0, 690.0]]], "lines": ["．．．"]}], "img_path": "00020.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [], "img_path": "00021.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1098, 335, 1165, 604], "vertical": true, "font_size": 26, "lines_coords": [[[1138.0, 339.0]