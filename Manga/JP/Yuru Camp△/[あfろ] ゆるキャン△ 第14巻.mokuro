.0], [187.0, 326.0], [187.0, 616.0], [161.0, 616.0]], [[127.0, 328.0], [153.0, 328.0], [153.0, 566.0], [127.0, 566.0]]], "lines": ["なんか遠足の前みたいで", "ワクワクしてきた〰"]}, {"box": [1121, 1195, 1196, 1475], "vertical": true, "font_size": 30, "lines_coords": [[[1168.0, 1198.0], [1194.0, 1198.0], [1194.0, 1423.0], [1168.0, 1423.0]], [[1126.0, 1196.0], [1160.0, 1196.0], [1155.0, 1475.0], [1121.0, 1475.0]]], "lines": ["そうだボトルも", "絶対持ってかないと"]}, {"box": [719, 979, 742, 1028], "vertical": true, "font_size": 23, "lines_coords": [[[719.0, 979.0], [742.0, 979.0], [742.0, 1028.0], [719.0, 1028.0]]], "lines": ["わしゃ"]}, {"box": [561, 1515, 630, 1764], "vertical": true, "font_size": 29, "lines_coords": [[[598.0, 1515.0], [630.0, 1515.0], [630.0, 1764.0], [598.0, 1764.0]], [[562.0, 1518.0], [588.0, 1518.0], [588.0, 1764.0], [562.0, 1764.0]]], "lines": ["自転車漕いでると", "めっちゃ喉乾くし"]}, {"box": [405, 1550, 459, 1672], "vertical": true, "font_size": 54, "lines_coords": [[[405.0, 1550.0], [459.0, 1550.0], [459.0, 1672.0], [405.0, 1672.0]]], "lines": ["パチン"]}], "img_path": "00151.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1117, 320, 1153, 606], "vertical": true, "font_size": 32, "lines_coords": [[[1119.0, 320.0], [1151.0, 320.0], [1151.0, 603.0], [1119.0, 603.0]]], "lines": ["初めてのキャンプに"]}, {"box": [215, 217, 288, 513], "vertical": true, "font_size": 30, "lines_coords": [[[256.0, 221.0], [285.0, 221.0], [283.0, 511.0], [255.0, 511.0]], [[217.0, 217.0], [249.0, 217.0], [247.0, 455.0], [215.0, 455.0]]], "lines": ["ロード買って初めての", "ロングライドかぁ"]}, {"box": [568, 723, 638, 1003], "vertical": true, "font_size": 29, "lines_coords": [[[605.0, 723.0], [637.0, 723.0], [637.0, 943.0], [605.0, 943.0]], [[568.0, 723.0], [594.0, 723.0], [594.0, 1003.0], [568.0, 1003.0]]], "lines": ["今度はちょっと", "不安になってきた："]}, {"box": [762, 1071, 783, 1149], "vertical": true, "font_size": 21, "lines_coords": [[[762.0, 1071.0], [783.0, 1071.0], [783.0, 1149.0], [762.0, 1149.0]]], "lines": ["．．．"]}, {"b