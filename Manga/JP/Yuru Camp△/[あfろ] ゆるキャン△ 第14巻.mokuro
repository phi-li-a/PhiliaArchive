 318.0], [506.0, 318.0]]], "lines": ["よしよし", "いい感じ"]}, {"box": [818, 506, 1070, 643], "vertical": false, "font_size": 36, "lines_coords": [[[843.0, 515.0], [978.0, 508.0], [980.0, 540.0], [845.0, 547.0]], [[830.0, 556.0], [1065.0, 526.0], [1070.0, 566.0], [836.0, 596.0]]], "lines": ["活動場所", "平日は特定グラウンド"]}, {"box": [635, 448, 781, 530], "vertical": false, "font_size": 49, "lines_coords": [[[648.0, 448.0], [781.0, 483.0], [770.0, 530.0], [635.0, 495.0]]], "lines": ["活動内容なん"]}, {"box": [204, 841, 274, 1043], "vertical": true, "font_size": 34, "lines_coords": [[[245.0, 845.0], [271.0, 845.0], [271.0, 1042.0], [245.0, 1042.0]], [[204.0, 841.0], [245.0, 841.0], [245.0, 935.0], [204.0, 935.0]]], "lines": ["結構集まってる", "じゃん"]}, {"box": [566, 1195, 627, 1462], "vertical": true, "font_size": 26, "lines_coords": [[[598.0, 1198.0], [624.0, 1198.0], [624.0, 1462.0], [598.0, 1462.0]], [[566.0, 1196.0], [592.0, 1196.0], [592.0, 1410.0], [566.0, 1410.0]]], "lines": ["何事も早く始める事が", "勝つための基本だ"]}, {"box": [1138, 1471, 1200, 1765], "vertical": true, "font_size": 26, "lines_coords": [[[1173.0, 1471.0], [1198.0, 1471.0], [1198.0, 1711.0], [1173.0, 1711.0]], [[1140.0, 1471.0], [1166.0, 1471.0], [1164.0, 1764.0], [1138.0, 1764.0]]], "lines": ["新入生の部活選びは", "４月いっぱいまでだけど"]}, {"box": [690, 1411, 752, 1764], "vertical": true, "font_size": 26, "lines_coords": [[[721.0, 1413.0], [748.0, 1413.0], [748.0, 1764.0], [721.0, 1764.0]], [[690.0, 1411.0], [716.0, 1411.0], [716.0, 1636.0], [690.0, 1636.0]]], "lines": ["みんなだいたい１〜２週間位で", "決めちまうんだっけ"]}, {"box": [136, 1421, 200, 1766], "vertical": true, "font_size": 26, "lines_coords": [[[170.0, 1421.0], [195.0, 1421.0], [195.0, 1766.0], [170.0, 1766.0]], [[136.0, 1421.0], [163.0, 1421.0], [163.0, 1736.0], [136.0, 1736.0]]], "lines": ["これ貼ったらイヌ子達と早速", "部員獲得作戦会議を：ん？"]}], "img_path": "00058.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1076, 200, 1147, 461], "vertical": true, "font_size": 66, "lines_coords": [[[1076.0, 202.