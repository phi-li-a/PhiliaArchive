[534.0, 976.0], [510.0, 976.0]]], "lines": ["素直にニキャンプサークル」に", "しときゃよかったと今更思うわ"]}, {"box": [341, 631, 403, 922], "vertical": true, "font_size": 26, "lines_coords": [[[376.0, 633.0], [401.0, 633.0], [401.0, 870.0], [376.0, 870.0]], [[343.0, 631.0], [369.0, 631.0], [367.0, 922.0], [341.0, 922.0]]], "lines": ["初心者にもやさしい", "まったりキャンプかな？"]}, {"box": [153, 660, 246, 900], "vertical": true, "font_size": 28, "lines_coords": [[[217.0, 661.0], [243.0, 661.0], [241.0, 900.0], [215.0, 900.0]], [[180.0, 660.0], [211.0, 660.0], [215.0, 847.0], [183.0, 847.0]], [[153.0, 663.0], [178.0, 663.0], [178.0, 849.0], [153.0, 849.0]]], "lines": ["部員数少ないゆえの", "フットワークの", "軽さとかもやな"]}, {"box": [1065, 834, 1121, 1098], "vertical": true, "font_size": 26, "lines_coords": [[[1096.0, 834.0], [1121.0, 834.0], [1121.0, 1098.0], [1096.0, 1098.0]], [[1065.0, 834.0], [1089.0, 834.0], [1089.0, 1046.0], [1065.0, 1046.0]]], "lines": ["分かりやすく伝える事", "だと思うんだよな"]}, {"box": [170, 1098, 228, 1258], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 1098.0], [226.0, 1098.0], [226.0, 1258.0], [200.0, 1258.0]], [[170.0, 1100.0], [196.0, 1100.0], [196.0, 1130.0], [170.0, 1130.0]]], "lines": ["それもあるが", "．．．"]}, {"box": [1125, 1404, 1185, 1719], "vertical": true, "font_size": 26, "lines_coords": [[[1156.0, 1406.0], [1183.0, 1406.0], [1183.0, 1719.0], [1156.0, 1719.0]], [[1125.0, 1404.0], [1151.0, 1404.0], [1151.0, 1695.0], [1125.0, 1695.0]]], "lines": ["この野クルの一番の売りは", "なでしこだと思うんだよ"]}, {"box": [204, 1509, 237, 1635], "vertical": true, "font_size": 32, "lines_coords": [[[204.0, 1509.0], [236.0, 1509.0], [236.0, 1635.0], [204.0, 1635.0]]], "lines": ["わたし？"]}], "img_path": "00064.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1132, 172, 1193, 412], "vertical": true, "font_size": 26, "lines_coords": [[[1166.0, 174.0], [1192.0, 174.0], [1192.0, 410.0], [1166.0, 410.0]], [[1132.0, 174.0], [1158.0, 174.0], [1158.0, 412.0], [1132.0, 412.0]]], "lines": ["正しくはなでしこが", "作るキャンプめしだ"]}, {"box": [264, 163, 358, 510], "vertical": true, "font_size": 26, "lines_coords": [[[330.0, 166.0], [356.0, 166.0], [356.0, 457.0], [330.0, 457.0]], [[298.0, 166.0], [324.0, 166.0], [324.0, 376.0], [298.0, 376.0]], [[264.0, 166.0], [290.0, 166.0], [290.0, 510.0], [264.0, 510.0]]], "lines": ["確かになでしこちゃんの", "キャンプごはんは", "野クルの売りかもしれんなぁ"]}, {"box": [172, 283, 196, 424], "vertical": true, "font_size": 21, "lines_coords": [[[172.0, 285.0], [193.0, 285.0], [193.0, 421.0], [172.0, 421.0]]], "lines": ["そそうかな"]}, {"box": [1080, 562, 1156, 735], "vertical": true, "font_size": 61, "lines_coords": [[[1095.0, 562.0], [1156.0, 568.0], [1141.0, 735.0], [1080.0, 729.0]]], "lines": ["おみまい"]}, {"box": [1123, 745, 1218, 1118], "vertical": true, "font_size": 26, "lines_coords": [[[1190.0, 748.0], [1216.0, 748.0], [1216.0, 915.0], [1190.0, 915.0]], [[1156.0, 748.0], [1183.0, 748.0], [1183.0, 1115.0], [1156.0, 1115.0]], [[1123.0, 748.0], [1147.0, 748.0], [1147.0, 1089.0], [1123.0, 1089.0]]], "lines": ["だから放課後", "部室棟前でビストロなでしこの", "キャンフめし炊き出しを行い、"]}, {"box": [699, 569, 746, 720], "vertical": true, "font_size": 41, "lines_coords": [[[699.0, 573.0], [740.0, 571.0], [746.0, 718.0], [705.0, 720.0]]], "lines": ["するぞ！！"]}, {"box": [605, 594, 668, 911], "vertical": true, "font_size": 25, "lines_coords": [[[639.0, 594.0], [663.0, 594.0], [663.0, 911.0], [639.0, 911.0]], [[607.0, 594.0], [633.0, 594.0], [631.0, 886.0], [605.0, 886.0]]], "lines": ["新入部員を一般打尽にする", "ってのはどうだろうか？"]}, {"box": [496, 590, 558, 906], "vertical": true, "font_size": 26, "lines_coords": [[[530.0, 592.0], [555.0, 592.0], [555.0, 905.0], [530.0, 905.0]], [[496.0, 590.0], [523.0, 590.0], [523.0, 855.0], [496.0, 855.0]]], "lines": ["キャンプの楽しみといえば", "アウトドアごはんだし、"]}, {"box": [131, 596, 191, 886], "vertical": true, "font_size": 26, "lines_coords": [[[161.0, 598.0], [189.0, 598.0], [191.0, 808.0], [163.0, 808.0]], [[131.0, 596.0], [155.0, 596.0], [155.0, 886.0], [131.0, 886.0]]], "lines": ["一番興味を持って", "くれやすいアピールかも"]}, {"box": [615, 1033, 697, 1108], "vertical": true, "font_size": 44, "lines_coords": [[[654.0, 1035.0], [697.0, 1035.0], [697.0, 1108.0], [654.0, 1108.0]], [[615.0, 1033.0], [660.0, 1033.0], [660.0, 1108.0], [615.0, 1108.0]]], "lines": ["ほう", "ほう"]}, {"box": [660, 1241, 720, 1559], "vertical": true, "font_size": 24, "lines_coords": [[[691.0, 1241.0], [716.0, 1241.0], [716.0, 1558.0], [691.0, 1558.0]], [[660.0, 1243.0], [684.0, 1243.0], [684.0, 1509.0], [660.0, 1509.0]]], "lines": ["炊き出しと言えばやっぱり", "汁物とか鍋料理かな？"]}, {"box": [185, 1032, 215, 1125], "vertical": true, "font_size": 28, "lines_coords": [[[185.0, 1033.0], [213.0, 1033.0], [213.0, 1125.0], [185.0, 1125.0]]], "lines": ["だろ？"]}, {"box": [1158, 1552, 1217, 1763], "vertical": true, "font_size": 26, "lines_coords": [[[1190.0, 1552.0], [1216.0, 1552.0], [1216.0, 1721.0], [1190.0, 1721.0]], [[1158.0, 1554.0], [1183.0, 1554.0], [1183.0, 1762.0], [1158.0, 1762.0]]], "lines": ["でも結構お金", "かかりそうやなぁ"]}, {"box": [787, 1479, 848, 1717], "vertical": true, "font_size": 26, "lines_coords": [[[821.0, 1479.0], [847.0, 1479.0], [847.0, 1717.0], [821.0, 1717.0]], [[787.0, 1479.0], [813.0, 1479.0], [813.0, 1584.0], [787.0, 1584.0]]], "lines": ["まぁそこはなるべく", "節約して"]}, {"box": [142, 1404, 271, 1773], "vertical": true, "font_size": 31, "lines_coords": [[[230.0, 1404.0], [271.0, 1404.0], [271.0, 1492.0], [230.0, 1492.0]], [[176.0, 1423.0], [202.0, 1423.0], [202.0, 1747.0], [176.0, 1747.0]], [[142.0, 1421.0], [168.0, 1421.0], [170.0, 1773.0], [144.0, 1773.0]]], "lines": ["いやー", "外で大鍋を温められる設備が", "無いからちょっと無理やない？"]}], "img_path": "00065.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1145, 157, 1206, 526], "vertical": true, "font_size": 26, "lines_coords": [[[1177.0, 157.0], [1205.0, 157.0], [1203.0, 525.0], [1175.0, 525.0]], [[1145.0, 157.0], [1170.0, 157.0], [1170.0, 448.0], [1145.0, 448.0]]], "lines": ["紙皿も箸もゴミになってまうし", "地味にコストかかるから"]}, {"box": [905, 129, 1006, 159], "vertical": false, "font_size": 26, "lines_coords": [[[905.0, 129.0], [1006.0, 133.0], [1006.0, 159.0], [905.0, 155.0]]], "lines": ["うまし"]}, {"box": [714, 148, 774, 547], "vertical": true, "font_size": 26, "lines_coords": [[[748.0, 148.0], [774.0, 148.0], [774.0, 386.0], [748.0, 386.0]], [[714.0, 150.0], [740.0, 150.0], [740.0, 547.0], [714.0, 547.0]]], "lines": ["手でそのまま持って", "食べられる物がいいかもしれんね"]}, {"box": [598, 153, 658, 362], "vertical": true, "font_size": 24, "lines_coords": [[[631.0, 153.0], [656.0, 153.0], [656.0, 361.0], [631.0, 361.0]], [[598.0, 153.0], [622.0, 153.0], [622.0, 361.0], [598.0, 361.0]]], "lines": ["だったらバンとか", "おにぎり系かな？"]}, {"box": [200, 146, 260, 438], "vertical": true, "font_size": 26, "lines_coords": [[[230.0, 146.0], [258.0, 146.0], [260.0, 410.0], [232.0, 410.0]], [[200.0, 146.0], [225.0, 146.0], [225.0, 438.0], [200.0, 438.0]]], "lines": ["おにぎりだとちょっと", "遠足っぽいからバンか？"]}, {"box": [1143, 800, 1198, 888], "vertical": true, "font_size": 51, "lines_coords": [[[1143.0, 802.0], [1194.0, 800.0], [1198.0, 886.0], [1147.0, 888.0]]], "lines": ["せや"]}, {"box": [862, 542, 886, 643], "vertical": true, "font_size": 21, "lines_coords": [[[862.0, 543.0], [883.0, 543.0], [883.0, 643.0], [862.0, 643.0]]], "lines": ["ふんふん"]}, {"box": [136, 448, 196, 712], "vertical": true, "font_size": 26, "lines_coords": [[[170.0, 448.0], [196.0, 448.0], [196.0, 712.0], [170.0, 712.0]], [[136.0, 450.0], [163.0, 450.0], [163.0, 661.0], [136.0, 661.0]]], "lines": ["それを外でどうやって", "たくさん作るか．．．"]}, {"box": [975, 796, 1036, 1168], "vertical": true, "font_size": 26, "lines_coords": [[[1008.0, 796.0], [1035.0, 796.0], [1035.0, 1140.0], [1008.0, 1140.0]], [[975.0, 798.0], [999.0, 798.0], [999.0, 1168.0], [975.0, 1168.0]]], "lines": ["瑞牆キャンプの後でビザ震が", "気になって調べとったんやけど、"]}, {"box": [1160, 1239, 1219, 1531], "vertical": true, "font_size": 26, "lines_coords": [[[1192.0, 1241.0], [1218.0, 1241.0], [1218.0, 1453.0], [1192.0, 1453.0]], [[1160.0, 1239.0], [1185.0, 1239.0], [1185.0, 1531.0], [1160.0, 1531.0]]], "lines": ["ダンボールって．．．", "燃えちゃわないのそれ？"]}, {"box": [262, 783, 322, 1153], "vertical": true, "font_size": 26, "lines_coords": [[[296.0, 785.0], [322.0, 785.0], [322.0, 1126.0], [296.0, 1126.0]], [[262.0, 783.0], [288.0, 783.0], [288.0, 1153.0], [262.0, 1153.0]]], "lines": ["ダンボールとアルミホイルで", "簡易オープンが作れるらしいで"]}, {"box": [136, 1228, 197, 1571], "vertical": true, "font_size": 26, "lines_coords": [[[170.0, 1230.0], [196.0, 1230.0], [196.0, 1571.0], [170.0, 1571.0]], [[136.0, 1228.0], [163.0, 1228.0], [163.0, 1545.0], [136.0, 1545.0]]], "lines": ["しっかり作ればダンボールが", "燃えることは無いんやって"]}, {"box": [635, 1263, 728, 1635], "vertical": true, "font_size": 28, "lines_coords": [[[699.0, 1265.0], [725.0, 1265.0], [725.0, 1610.0], [699.0, 1610.0]], [[663.0, 1263.0], [695.0, 1263.0], [695.0, 1635.0], [663.0, 1635.0]], [[635.0, 1263.0], [660.0, 1263.0], [660.0, 1477.0], [635.0, 1477.0]]], "lines": ["中に炭を入れて使うんやけど、", "内側に貼られたアルミホイルで", "熱が反射するから"]}, {"box": [772, 1415, 832, 1786], "vertical": true, "font_size": 26, "lines_coords": [[[804.0, 1417.0], [830.0, 1417.0], [830.0, 1655.0], [804.0, 1655.0]], [[772.0, 1415.0], [798.0, 1415.0], [798.0, 1786.0], [772.0, 1786.0]]], "lines": ["私も初めは冗談かと", "思ったんやけど大丈夫らしいわ"]}, {"box": [155, 1612, 183, 1767], "vertical": true, "font_size": 26, "lines_coords": [[[155.0, 1612.0], [181.0, 1612.0], [181.0, 1691.0], [155.0, 1691.0]]], "lines": ["ほぉー"]}], "img_path": "00066.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1104, 138, 1164, 453], "vertical": true, "font_size": 26, "lines_coords": [[[1136.0, 138.0], [1162.0, 138.0], [1162.0, 324.0], [1136.0, 324.0]], [[1104.0, 140.0], [1130.0, 140.0], [1130.0, 453.0], [1104.0, 453.0]]], "lines": ["黒が作れるなら", "せっかくだしピザ作ろうよ"]}, {"box": [495, 161, 588, 451], "vertical": true, "font_size": 26, "lines_coords": [[[558.0, 161.0], [585.0, 161.0], [586.0, 451.0], [560.0, 451.0]], [[526.0, 163.0], [553.0, 163.0], [553.0, 425.0], [526.0, 425.0]], [[495.0, 163.0], [519.0, 163.0], [519.0, 348.0], [495.0, 348.0]]], "lines": ["きっとピザを焼く香りで", "人がたくさん集まって", "くると思うよ！！"]}, {"box": [157, 211, 256, 303], "vertical": true, "font_size": 48, "lines_coords": [[[208.0, 211.0], [256.0, 211.0], [256.0, 301.0], [208.0, 301.0]], [[157.0, 211.0], [206.0, 211.0], [206.0, 303.0], [157.0, 303.0]]], "lines": ["なる", "ほど"]}, {"box": [1149, 672, 1210, 1018], "vertical": true, "font_size": 26, "lines_coords": [[[1181.0, 673.0], [1207.0, 673.0], [1209.0, 1018.0], [1183.0, 1018.0]], [[1149.0, 676.0], [1175.0, 676.0], [1175.0, 886.0], [1149.0, 886.0]]], "lines": ["生地は小麦粉でミニサイズに", "たくさんこねて．．．"]}, {"box": [716, 691, 809, 956], "vertical": true, "font_size": 26, "lines_coords": [[[781.0, 693.0], [808.0, 693.0], [808.0, 886.0], [781.0, 886.0]], [[748.0, 691.0], [774.0, 691.0], [774.0, 952.0], [748.0, 952.0]], [[716.0, 691.0], [740.0, 691.0], [740.0, 956.0], [716.0, 956.0]]], "lines": ["いや餃子の皮を", "生地にすれば丁度いい", "ミニヒザが出来るかな"]}, {"box": [564, 703, 657, 1044], "vertical": true, "font_size": 26, "lines_coords": [[[628.0, 703.0], [654.0, 703.0], [654.0, 1018.0], [628.0, 1018.0]], [[596.0, 703.0], [622.0, 703.0], [622.0, 1044.0], [596.0, 1044.0]], [[564.0, 705.0], [590.0, 705.0], [590.0, 941.0], [564.0, 941.0]]], "lines": ["あとは市販のピザソースに", "小さく切ったオリーブの実と", "ベーコンを乗せて．．．"]}, {"box": [710, 997, 738, 1209], "vertical": true, "font_size": 26, "lines_coords": [[[710.0, 997.0], [736.0, 997.0], [736.0, 1209.0], [710.0, 1209.0]]], "lines": ["餃子の皮ビザやな"]}, {"box": [159, 922, 191, 1141], "vertical": true, "font_size": 32, "lines_coords": [[[159.0, 922.0], [191.0, 922.0], [191.0, 1141.0], [159.0, 1141.0]]], "lines": ["待ったなでしこ"]}, {"box": [1100, 1336, 1164, 1698], "vertical": true, "font_size": 26, "lines_coords": [[[1136.0, 1338.0], [1162.0, 1338.0], [1162.0, 1618.0], [1136.0, 1618.0]], [[1100.0, 1336.0], [1126.0, 1336.0], [1126.0, 1698.0], [1100.0, 1698.0]]], "lines": ["ソースは瑞牆で作った", "自家製トマトソースを使おう"]}], "img_path": "00067.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1120, 100, 1239, 541], "vertical": true, "font_size": 27, "lines_coords": [[[1207.0, 101.0], [1239.0, 101.0], [1239.0, 211.0], [1207.0, 211.0]], [[1185.0, 217.0], [1211.0, 217.0], [1211.0, 324.0], [1185.0, 324.0]], [[1151.0, 215.0], [1177.0, 215.0], [1179.0, 534.0], [1153.0, 534.0]], [[1121.0, 217.0], [1145.0, 217.0], [1145.0, 510.0], [1121.0, 510.0]]], "lines": ["いやいや", "あん時は", "５００円詰め放題のトマト", "使うたから良かったけど、"]}, {"box": [566, 155, 624, 421], "vertical": true, "font_size": 26, "lines_coords": [[[596.0, 155.0], [622.0, 155.0], [624.0, 371.0], [598.0, 371.0]], [[566.0, 159.0], [592.0, 159.0], [592.0, 421.0], [566.0, 421.0]]], "lines": ["それに他の具材も", "地味にかかっとったし、"]}, {"box": [236, 241, 273, 354], "vertical": true, "font_size": 29, "lines_coords": [[[240.0, 241.0], [273.0, 241.0], [270.0, 354.0], [236.0, 354.0]]], "lines": ["でもなぁ"]}, {"box": [901, 630, 1033, 678], "vertical": false, "font_size": 41, "lines_coords": [[[903.0, 630.0], [1033.0, 637.0], [1031.0, 678.0], [901.0, 671.0]]], "lines": ["－ツトマ"]}, {"box": [825, 695, 1020, 740], "vertical": false, "font_size": 45, "lines_coords": [[[825.0, 695.0], [1020.0, 695.0], [1020.0, 740.0], [825.0, 740.0]]], "lines": ["ｗｗ，３５０"]}, {"box": [678, 406, 740, 725], "vertical": true, "font_size": 30, "lines_coords": [[[708.0, 406.0], [740.0, 406.0], [740.0, 725.0], [708.0, 725.0]], [[678.0, 406.0], [705.0, 406.0], [705.0, 723.0], [678.0, 723.0]]], "lines": ["スーパーで普通に買うたら、", "トマト代がバカにならんて"]}, {"box": [698, 808, 768, 1031], "vertical": true, "font_size": 30, "lines_coords": [[[733.0, 808.0], [766.0, 808.0], [768.0, 937.0], [735.0, 937.0]], [[699.0, 811.0], [725.0, 811.0], [725.0, 1029.0], [699.0, 1029.0]]], "lines": ["トマトは", "何とかなるかも"]}, {"box": [131, 311, 228, 661], "vertical": true, "font_size": 29, "lines_coords": [[[196.0, 311.0], [228.0, 311.0], [226.0, 661.0], [195.0, 661.0]], [[166.0, 313.0], [193.0, 313.0], [189.0, 660.0], [163.0, 660.0]], [[133.0, 313.0], [159.0, 313.0], [157.0, 633.0], [131.0, 633.0]]], "lines": ["せっかく読まで作るんだし．．．", "市販のソースよりあれの方が", "ぜったい感動すると思うぞ"]}, {"box": [170, 795, 232, 1006], "vertical": true, "font_size": 26, "lines_coords": [[[206.0, 795.0], [232.0, 795.0], [228.0, 1006.0], [202.0, 1006.0]], [[170.0, 796.0], [196.0, 796.0], [196.0, 1006.0], [170.0, 1006.0]]], "lines": ["いっしょに頼めば", "安く済むと思うよ"]}, {"box": [1125, 785, 1228, 1233], "vertical": true, "font_size": 30, "lines_coords": [[[1196.0, 785.0], [1228.0, 785.0], [1226.0, 1040.0], [1194.0, 1040.0]], [[1166.0, 789.0], [1192.0, 789.0], [1192.0, 1230.0], [1166.0, 1230.0]], [[1125.0, 785.0], [1156.0, 785.0], [1160.0, 1166.0], [1128.0, 1166.0]]], "lines": ["まぁあのソースが", "むっちゃうまいんは分かるけど", "たくさん作るとなると変ぁ"]}, {"box": [590, 781, 649, 1231], "vertical": true, "font_size": 26, "lines_coords": [[[622.0, 781.0], [648.0, 781.0], [648.0, 1153.0], [622.0, 1153.0]], [[590.0, 781.0], [615.0, 781.0], [615.0, 1231.0], [590.0, 1231.0]]], "lines": ["うちトマトはお父さんがいつも", "訳ありの物を箱買いしてくるんだけど"]}, {"box": [140, 1095, 204, 1256], "vertical": true, "font_size": 31, "lines_coords": [[[168.0, 1095.0], [204.0, 1095.0], [204.0, 1181.0], [168.0, 1181.0]], [[140.0, 1096.0], [166.0, 1096.0], [166.0, 1256.0], [140.0, 1256.0]]], "lines": ["おお！", "そんな手が！！"]}, {"box": [1128, 1396, 1192, 1740], "vertical": true, "font_size": 26, "lines_coords": [[[1162.0, 1396.0], [1188.0, 1396.0], [1190.0, 1661.0], [1164.0, 1661.0]], [[1128.0, 1396.0], [1155.0, 1396.0], [1156.0, 1740.0], [1130.0, 1740.0]]], "lines": ["他の具材も何とか安く", "抑えられるよう考えっからさ"]}, {"box": [727, 1449, 765, 1551], "vertical": true, "font_size": 32, "lines_coords": [[[733.0, 1449.0], [765.0, 1451.0], [759.0, 1550.0], [727.0, 1548.0]]], "lines": ["おねがい"]}, {"box": [202, 1411, 296, 1726], "vertical": true, "font_size": 25, "lines_coords": [[[270.0, 1413.0], [294.0, 1413.0], [294.0, 1597.0], [270.0, 1597.0]], [[236.0, 1411.0], [262.0, 1411.0], [262.0, 1623.0], [236.0, 1623.0]], [[202.0, 1411.0], [228.0, 1411.0], [228.0, 1726.0], [202.0, 1726.0]]], "lines": ["しゃあないなぁ", "そこまで言うなら", "あの自家製ソースでいこか"]}], "img_path": "00068.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [654, 133, 743, 383], "vertical": true, "font_size": 25, "lines_coords": [[[716.0, 133.0], [742.0, 133.0], [742.0, 382.0], [716.0, 382.0]], [[684.0, 133.0], [708.0, 133.0], [708.0, 305.0], [684.0, 305.0]], [[654.0, 135.0], [680.0, 135.0], [680.0, 333.0], [654.0, 333.0]]], "lines": ["ダンボール窯を使って", "自家製ソースの", "餃子ピザで決まり"]}, {"box": [1134, 408, 1198, 646], "vertical": true, "font_size": 26, "lines_coords": [[[1168.0, 408.0], [1194.0, 408.0], [1198.0, 543.0], [1171.0, 543.0]], [[1134.0, 410.0], [1160.0, 410.0], [1160.0, 646.0], [1134.0, 646.0]]], "lines": ["そんじゃあ", "新入部員獲得作戦は"]}, {"box": [260, 504, 301, 588], "vertical": true, "font_size": 41, "lines_coords": [[[260.0, 504.0], [301.0, 504.0], [301.0, 588.0], [260.0, 588.0]]], "lines": ["だな。"]}, {"box": [1174, 1091, 1204, 1441], "vertical": true, "font_size": 25, "lines_coords": [[[1175.0, 1091.0], [1200.0, 1091.0], [1200.0, 1441.0], [1175.0, 1441.0]]], "lines": ["よーしポスター直し完了っと"]}, {"box": [583, 1100, 641, 1348], "vertical": true, "font_size": 25, "lines_coords": [[[613.0, 1100.0], [639.0, 1100.0], [639.0, 1299.0], [613.0, 1299.0]], [[583.0, 1100.0], [607.0, 1100.0], [607.0, 1348.0], [583.0, 1348.0]]], "lines": ["今日はもう遅いし", "これ張り替えて帰ろか"]}, {"box": [331, 1091, 387, 1391], "vertical": true, "font_size": 25, "lines_coords": [[[361.0, 1093.0], [386.0, 1093.0], [386.0, 1368.0], [361.0, 1368.0]], [[331.0, 1091.0], [356.0, 1091.0], [356.0, 1391.0], [331.0, 1391.0]]], "lines": ["明日は早速ダンボール窯", "を作って実験してみようね"]}, {"box": [155, 1132, 214, 1357], "vertical": true, "font_size": 24, "lines_coords": [[[187.0, 1132.0], [211.0, 1132.0], [211.0, 1357.0], [187.0, 1357.0]], [[155.0, 1132.0], [180.0, 1132.0], [180.0, 1355.0], [155.0, 1355.0]]], "lines": ["あと安い食材探しも", "何とかしないとなぁ"]}, {"box": [777, 1479, 805, 1689], "vertical": true, "font_size": 24, "lines_coords": [[[778.0, 1479.0], [802.0, 1479.0], [802.0, 1689.0], [778.0, 1689.0]]], "lines": ["やっと終わったー"]}], "img_path": "00069.jpg"}, {"version": "0.1.6",