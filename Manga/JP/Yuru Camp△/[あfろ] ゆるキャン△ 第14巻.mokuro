65.0]], [[200.0, 900.0], [232.0, 900.0], [232.0, 1035.0], [200.0, 1035.0]]], "lines": ["何でここで", "出んねん"]}, {"box": [1063, 1304, 1134, 1717], "vertical": true, "font_size": 29, "lines_coords": [[[1104.0, 1316.0], [1130.0, 1316.0], [1130.0, 1717.0], [1104.0, 1717.0]], [[1063.0, 1316.0], [1095.0, 1316.0], [1095.0, 1565.0], [1063.0, 1565.0]]], "lines": ["鼻血が出るかはあきちゃんの", "コスパ感覚による"]}, {"box": [348, 1329, 429, 1636], "vertical": true, "font_size": 36, "lines_coords": [[[386.0, 1329.0], [425.0, 1329.0], [429.0, 1636.0], [390.0, 1636.0]], [[348.0, 1333.0], [380.0, 1333.0], [380.0, 1477.0], [348.0, 1477.0]]], "lines": ["はい、ここテストに", "出まーす"]}, {"box": [165, 1494, 249, 1674], "vertical": true, "font_size": 41, "lines_coords": [[[198.0, 1494.0], [249.0, 1494.0], [249.0, 1576.0], [198.0, 1576.0]], [[165.0, 1498.0], [196.0, 1498.0], [196.0, 1674.0], [165.0, 1674.0]]], "lines": ["何の", "テストだよ"]}], "img_path": "00174.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1081, 155, 1181, 496], "vertical": true, "font_size": 28, "lines_coords": [[[1149.0, 155.0], [1181.0, 155.0], [1179.0, 496.0], [1147.0, 496.0]], [[1117.0, 159.0], [1143.0, 159.0], [1143.0, 324.0], [1117.0, 324.0]], [[1081.0, 157.0], [1108.0, 157.0], [1108.0, 408.0], [1081.0, 408.0]]], "lines": ["キャンプでのヒマつぶしは", "キャンパーの", "永遠のテーマやけど、"]}, {"box": [120, 75, 556, 101], "vertical": false, "font_size": 26, "lines_coords": [[[120.0, 75.0], [556.0, 75.0], [556.0, 101.0], [120.0, 101.0]]], "lines": ["放課後１２４アウトドア占い"]}, {"box": [342, 200, 405, 425], "vertical": true, "font_size": 29, "lines_coords": [[[373.0, 200.0], [405.0, 200.0], [405.0, 425.0], [373.0, 425.0]], [[343.0, 202.0], [369.0, 202.0], [369.0, 425.0], [343.0, 425.0]]], "lines": ["アウトドアでやる", "占いってどうやろ"]}, {"box": [193, 376, 240, 493], "vertical": true, "font_size": 47, "lines_coords": [[[193.0, 376.0], [240.0, 376.0], [240.0, 493.0], [193.0, 493.0]]], "lines": ["占い？"]}, {"box": [1132, 654, 1205, 967], "vertical": true, "font_size": 32, "lines_coords": [[[1171.0, 658.0], [1203.0, 658.0], [1203.0, 967.0], [1171.0, 967.0]], [[1132.0, 654.0], [1164.0, 654.0], [1164.0, 965.0], [1132.0, 965.0]]], "lines": ["キャンプ場で占いかぁ", "何かピンとこないなぁ"]}, {"box": [1136, 1226, 1204, 1565], "vertical": true, "font_size": 26, "lines_coords": [[[1171.0, 1226.0], [1198.0, 1226.0], [1201.0, 1565.0], [1175.0, 1565.0]], [[1136.0, 1226.0], [1162.0, 1226.0], [1162.0, 1411.0], [1136.0, 1411.0]]], "lines": ["これならキャンプほいよ。", "あきちゃん！！"]}, {"box": [168, 1215, 235, 1509], "vertical": true, "font_size": 26, "lines_coords": [[[204.0, 1218.0], [230.0, 1218.0], [230.0, 1509.0], [204.0, 1509.0]], [[168.0, 1216.0], [195.0, 1216.0], [195.0, 1462.0], [168.0, 1462.0]]], "lines": ["別に占い師のコスプレ", "する訳やないから。"]}], "img_path": "00175.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1119, 146, 1225, 571], "vertical": true, "font_size": 32, "lines_coords": [[[1196.0, 151.0], [1222.0, 151.0], [1222.0, 485.0], [1196.0, 485.0]], [[1158.0, 150.0], [1186.0, 150.0], [1188.0, 571.0], [1160.0, 571.0]], [[1119.0, 146.0], [1162.0, 146.0], [1162.0, 213.0], [1119.0, 213.0]]], "lines": ["占いなんて今日の運勢とか", "おみくじ位しかやった事なかった", "けど"]}, {"box": [766, 146, 1136, 748], "vertical": false, "font_size": 191, "lines_coords": [[[843.0, 146.0], [1104.0, 146.0], [1104.0, 211.0], [843.0, 211.0]], [[847.0, 196.0], [956.0, 196.0], [956.0, 255.0], [847.0, 255.0]], [[766.0, 172.0], [1136.0, 172.0], [1136.0, 748.0], [766.0, 748.0]], [[879.0, 555.0], [1006.0, 570.0], [999.0, 633.0], [871.0, 618.0]]], "lines": ["タロット占い", "個水", "いいんじゃないんだかわからなかったんだよ", "占い"]}, {"box": [586, 142, 649, 278], "vertical": true, "font_size": 26, "lines_coords": [[[620.0, 144.0], [646.0, 144.0], [646.0, 243.0], [620.0, 243.0]], [[586.0, 142.0], [613.0, 142.0], [618.0, 277.0], [592.0, 277.0]]], "lines": ["仕事運が", "いいですわー"]}, {"box": [721, 346, 788, 601], "vertical": true, "font_size": 26, "lines_coords": [[[755.0, 348.0], [781.0, 348.0], [785.0, 598.0], [759.0, 598.0]], [[721.0, 346.0], [748.0, 346.0], [751.0, 515.0], [725.0, 515.0]]], "lines": ["結構いろんな種類が", "あるんだねぇ"]}, {"box": [131, 144, 232, 341], "vertical": true, "font_size": 28, "lines_coords": [[[200.0, 144.0], [232.0, 144.0], [232.0, 341.0], [200.0, 341.0]], [[168.0, 146.0], [195.0, 146.0], [195.0, 256.0], [168.0, 256.0]], [[131.0, 144.0], [157.0, 144.0], [157.0, 283.0], [131.0, 283.0]]], "lines": ["仲ようなったり", "あるかも", "しれんで？"]}, {"box": [1061, 748, 1143, 935], "vertical": true, "font_size": 25, "lines_coords": [[[1117.0, 748.0], [1143.0, 748.0], [1143.0, 900.0], [1117.0, 900.0]], [[1089.0, 748.0], [1113.0, 748.0], [1113.0, 935.0], [1089.0, 935.0]], [[1061.0, 748.0], [1085.0, 748.0], [1085.0, 933.0], [1061.0, 933.0]]], "lines": ["よし私はまず", "トランプ占いから", "やってみようかな"]}, {"box": [586, 346, 684, 680], "vertical": true, "font_size": 26, "lines_coords": [[[656.0, 348.0], [680.0, 348.0], [680.0, 680.0], [656.0, 680.0]], [[620.0, 346.0], [646.0, 346.0], [646.0, 624.0], [620.0, 624.0]], [[586.0, 346.0], [613.0, 346.0], [613.0, 485.0], [586.0, 485.0]]], "lines": ["おとなりキャンパーさんも", "占ってあげたらそれが", "きっかけで"]}, {"box": [489, 725, 573, 913], "vertical": true, "font_size": 26, "lines_coords": [[[547.0, 727.0], [573.0, 727.0], [573.0, 892.0], [547.0, 892.0]], [[517.0, 725.0], [543.0, 725.0], [541.0, 913.0], [515.0, 913.0]], [[489.0, 727.0], [515.0, 727.0], [515.0, 825.0], [489.0, 825.0]]], "lines": ["手相って自分で", "書き足してもいい", "らしいぞ"]}, {"box": [136, 478, 199, 613], "vertical": true, "font_size": 26, "lines_coords": [[[172.0, 478.0], [198.0, 478.0], [198.0, 613.0], [172.0, 613.0]], [[136.0, 480.0], [163.0, 480.0], [163.0, 590.0], [136.0, 590.0]]], "lines": ["それはいい", "かもなー"]}, {"box": [223, 778, 280, 903], "vertical": true, "font_size": 26, "lines_coords": [[[253.0, 778.0], [279.0, 778.0], [279.0, 879.0], [253.0, 879.0]], [[223.0, 778.0], [249.0, 778.0], [249.0, 903.0], [223.0, 903.0]]], "lines": ["何やそれ", "チートやん"]}, {"box": [1053, 1147, 1147, 1388], "vertical": true, "font_size": 40, "lines_coords": [[[1108.0, 1149.0], [1147.0, 1149.0], [1147.0, 1387.0], [1108.0, 1387.0]], [[1053.0, 1147.0], [1095.0, 1147.0], [1098.0, 1286.0], [1057.0, 1286.0]]], "lines": ["何やってんだ", "お前ら。"]}, {"box": [286, 1507, 372, 1786], "vertical": true, "font_size": 44, "lines_coords": [[[333.0, 1511.0], [371.0, 1511.0], [371.0, 1786.0], [333.0, 1786.0]], [[286.0, 1507.0], [337.0, 1507.0], [337.0, 1586.0], [286.0, 1586.0]]], "lines": ["裏フライドチキン", "占い"]}], "img_path": "00176.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1106, 136, 1207, 500], "vertical": true, "font_size": 32, "lines_coords": [[[1175.0, 136.0], [1207.0, 136.0], [1207.0, 361.0], [1175.0, 361.0]], [[1140.0, 138.0], [1171.0, 138.0], [1171.0, 361.0], [1140.0, 361.0]], [[1106.0, 136.0], [1138.0, 136.0], [1138.0, 500.0], [1106.0, 500.0]]], "lines": ["テントもいいけど", "いつかはみんなで", "コテージ泊してみたいよねぇ"]}, {"box": [120, 75, 751, 101], "vertical": false, "font_size": 26, "lines_coords": [[[120.0, 75.0], [751.0, 75.0], [751.0, 101.0], [120.0, 101.0]]], "lines": ["放課後１２５ロッシ・コテージ・バンガロ"]}, {"box": [1068, 720, 1177, 1061], "vertical": true, "font_size": 30, "lines_coords": [[[1145.0, 720.0], [1177.0, 720.0], [1177.0, 875.0], [1145.0, 875.0]], [[1104.0, 721.0], [1136.0, 721.0], [1136.0, 1061.0], [1104.0, 1061.0]], [[1070.0, 721.0], [1096.0, 721.0], [1095.0, 1061.0], [1068.0, 1061.0]]], "lines": ["そういえば", "コテージとバンガローと", "ロッジってどう違うの？"]}, {"box": [189, 723, 260, 1036], "vertical": true, "font_size": 28, "lines_coords": [[[234.0, 879.0], [255.0, 879.0], [255.0, 913.0], [234.0, 913.0]], [[228.0, 723.0], [260.0, 723.0], [260.0, 862.0], [228.0, 862.0]], [[189.0, 725.0], [221.0, 725.0], [221.0, 1036.0], [189.0, 1036.0]]], "lines": ["ん", "そうだな！", "似たような感じだが．．"]}, {"box": [1137, 1126, 1205, 1560], "vertical": true, "font_size": 26, "lines_coords": [[[1173.0, 1126.0], [1200.0, 1126.0], [1200.0, 1494.0], [1173.0, 1494.0]], [[1138.0, 1126.0], [1164.0, 1126.0], [1164.0, 1560.0], [1138.0, 1560.0]]], "lines": ["ますコテージは少人数用の", "丸ごと借りる一軒家のことだな"]}, {"box": [575, 1108, 645, 1584], "vertical": true, "font_size": 32, "lines_coords": [[[607.0, 1108.0], [645.0, 1108.0], [643.0, 1584.0], [605.0, 1584.0]], [[575.0, 1111.0], [601.0, 1111.0], [601.0, 1462.0], [575.0, 1462.0]]], "lines": ["バンガローは風呂とかトイレなしの", "コテージより簡素な建物だ。"]}, {"box": [721, 1558, 757, 1693], "vertical": true, "font_size": 34, "lines_coords": [[[721.0, 1558.0], [755.0, 1558.0], [757.0, 1693.0], [723.0, 1693.0]]], "lines": ["ほぅほぅ"]}, {"box": [151, 1560, 193, 1699], "vertical": true, "font_size": 42, "lines_coords": [[[151.0, 1560.0], [193.0, 1560.0], [193.0, 1644.0], [151.0, 1644.0]]], "lines": ["へえー"]}], "img_path": "00177.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1140, 191, 1174, 498], "vertical": true, "font_size": 31, "lines_coords": [[[1140.0, 191.0], [1171.0, 191.0], [1171.0, 498.0], [1140.0, 498.0]]], "lines": ["そんでロッジは山荘"]}, {"box": [461, 136, 1010, 279], "vertical": false, "font_size": 126, "lines_coords": [[[461.0, 153.0], [1006.0, 136.0], [1010.0, 262.0], [465.0, 279.0]]], "lines": ["○Ｘｕ荘殺人事件"]}, {"box": [303, 189, 423, 601], "vertical": true, "font_size": 33, "lines_coords": [[[390.0, 195.0], [421.0, 195.0], [421.0, 601.0], [390.0, 601.0]], [[341.0, 189.0], [378.0, 189.0], [382.0, 536.0], [345.0, 536.0]], [[303.0, 193.0], [335.0, 193.0], [335.0, 331.0], [303.0, 331.0]]], "lines": ["つまりサスベンスドラマで", "殺人事件がよう起きる", "建物やな"]}, {"box": [180, 481, 215, 684], "vertical": true, "font_size": 32, "lines_coords": [[[180.0, 481.0], [211.0, 481.0], [213.0, 684.0], [181.0, 684.0]]], "lines": ["偏見がひでぇ"]}, {"box": [1089, 829, 1179, 1179], "vertical": true, "font_size": 25, "lines_coords": [[[1151.0, 832.0], [1177.0, 832.0], [1177.0, 1175.0], [1151.0, 1175.0]], [[1121.0, 830.0], [1145.0, 830.0], [1145.0, 1126.0], [1121.0, 1126.0]], [[1089.0, 832.0], [1115.0, 832.0], [1115.0, 1080.0], [1089.0, 1080.0]]], "lines": ["パンガローって一泊１万５千円", "とかだけど５人で泊まれば", "一人３千円くらいだし、"]}, {"box": [738, 899, 798, 1190], "vertical": true, "font_size": 26, "lines_coords": [[[770.0, 900.0], [796.0, 900.0], [796.0, 1164.0], [770.0, 1164.0]], [[738.0, 900.0], [763.0, 900.0], [763.0, 1190.0], [738.0, 1190.0]]], "lines": ["意外と気軽に泊まれる", "値段なのかもしれないね"]}, {"box": [468, 1282, 568, 1488], "vertical": true, "font_size": 49, "lines_coords": [[[523.0, 1284.0], [568.0, 1284.0], [568.0, 1488.0], [523.0, 1488.0]], [[468.0, 1282.0], [521.0, 1282.0], [521.0, 1335.0], [468.0, 1335.0]]], "lines": ["そうなのっ", "！？"]}, {"box": [288, 845, 385, 1125], "vertical": true, "font_size": 26, "lines_coords": [[[358.0, 847.0], [384.0, 847.0], [384.0, 986.0], [358.0, 986.0]], [[320.0, 845.0], [348.0, 845.0], [346.0, 1125.0], [318.0, 1125.0]], [[288.0, 847.0], [313.0, 847.0], [313.0, 1040.0], [288.0, 1040.0]]], "lines": ["そうだなぁ", "そろそろこういう所も", "泊まってみるか"]}, {"box": [165, 1301, 241, 1471], "vertical": true, "font_size": 32, "lines_coords": [[[206.0, 1301.0], [238.0, 1301.0], [238.0, 1471.0], [206.0, 1471.0]], [[165.0, 1303.0], [198.0, 1303.0], [198.0, 1419.0], [165.0, 1419.0]]], "lines": ["巻き込まれ", "ねぇよ。"]}, {"box": [1038, 1254, 1189, 1723], "vertical": true, "font_size": 31, "lines_coords": [[[1156.0, 1256.0], [1188.0, 1256.0], [1188.0, 1443.0], [1156.0, 1443.0]], [[1119.0, 1256.0], [1151.0, 1256.0], [1151.0, 1663.0], [1119.0, 1663.0]], [[1081.0, 1258.0], [1108.0, 1258.0], [1108.0, 1723.0], [1081.0, 1723.0]], [[1038.0, 1254.0], [1070.0, 1254.0], [1070.0, 1503.0], [1038.0, 1503.0]]], "lines": ["この３ヵ月後", "彼女らは初めてのロッジ泊で", "凄惨な事件に巻き込まれるのだが、", "それはまた別の話"]}], "img_path": "00178.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [118, 123, 641, 187], "vertical": false, "font_size": 27, "lines_coords": [[[118.0, 123.0], [568.0, 123.0], [568.0, 150.0], [118.0, 150.0]], [[120.0, 163.0], [641.0, 163.0], [641.0, 187.0], [120.0, 187.0]]], "lines": ["ゆるキャン△＠いかがでしたでしょうか。", "今回は桜巡り後編と新学期編を収録致しました。"]}, {"box": [112, 245, 755, 352], "vertical": false, "font_size": 27, "lines_coords": [[[118.0, 245.0], [755.0, 245.0], [755.0, 270.0], [118.0, 270.0]], [[118.0, 283.0], [583.0, 283.0], [583.0, 309.0], [118.0, 309.0]], [[112.0, 320.0], [543.0, 318.0], [543.0, 350.0], [112.0, 352.0]]], "lines": ["作中で出てきたダンボール窯はお手軽ですが一歩間違うと", "ダンボール焚き火になってしまいますので", "作り方をよく調べてからお試し下さい。"]}, {"box": [116, 403, 270, 431], "vertical": false, "font_size": 27, "lines_coords": [[[116.0, 403.0], [270.0, 405.0], [270.0, 431.0], [116.0, 429.0]]], "lines": ["あｆろでした。"]}, {"box": [108, 1687, 1023, 1800], "vertical": false, "font_size": 25.0, "lines_coords": [[[114.0, 1687.0], [210.0, 1687.0], [210.0, 1708.0], [114.0, 1708.0]], [[116.0, 1715.0], [1023.0, 1715.0], [1023.0, 1740.0], [116.0, 1740.0]], [[118.0, 1743.0], [226.0, 1743.0], [226.0, 1770.0], [118.0, 1770.0]], [[108.0, 1771.0], [438.0, 1773.0], [438.0, 1800.0], [108.0, 1798.0]]], "lines": ["〈初出一覧〉", "・ＯＯＭＣＦＵＺ令利２４９月令利３年１月、令机３年ＩＩ月、余別な年２月〜４日、６月、７月１日水", "・描き下ろし", "本当は以上の内容を収録しました。"]}], "img_path": "00179.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [391, 795, 609, 901], "vertical": false, "font_size": 39.5, "lines_coords": [[[391.0, 798.0], [609.0, 795.0], [609.0, 834.0], [391.0, 838.0]], [[393.0, 862.0], [519.0, 862.0], [519.0, 901.0], [393.0, 901.0]]], "lines": ["著者：あｆろ", "©ａｆｒｏ"]}, {"box": [393, 620, 950, 673], "vertical": false, "font_size": 50.0, "lines_coords": [[[765.0, 622.0], [950.0, 622.0], [950.0, 669.0], [765.0, 669.0]], [[393.0, 620.0], [778.0, 620.0], [778.0, 673.0], [393.0, 673.0]]], "lines": ["第１４巻", "ゆるキャン△第"]}, {"box": [393, 979, 974, 1229], "vertical": false, "font_size": 37, "lines_coords": [[[393.0, 991.0], [969.0, 990.0], [969.0, 1029.0], [393.0, 1031.0]], [[395.0, 1059.0], [691.0, 1059.0], [691.0, 1096.0], [395.0, 1096.0]], [[397.0, 1123.0], [798.0, 1126.0], [798.0, 1158.0], [397.0, 1155.0]], [[541.0, 1188.0], [948.0, 1188.0], [948.0, 1226.0], [541.0, 1226.0]]], "lines": ["電子版発行日：２０２２年１２月１５日", "発行人・東・敬彰・", "発行所：株式会社芳文社", "東京都文京区後楽１－２－１２"]}], "img_path": "00180.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [279, 688, 453, 763], "vertical": false, "font_size": 75, "lines_coords": [[[279.0, 688.0], [453.0, 688.0], [453.0, 763.0], [279.0, 763.0]]], "lines": ["ゆる赤"]}, {"box": [559, 759, 639, 779], "vertical": false, "font_size": 22, "lines_coords": [[[559.0, 757.0], [639.0, 757.0], [639.0, 781.0], [559.0, 781.0]]], "lines": ["それではＣａｍｐ"]}, {"box": [1183, 829, 1291, 888], "vertical": false, "font_size": 23, "lines_coords": [[[1190.0, 828.0], [1271.0, 828.0], [1271.0, 853.0], [1190.0, 853.0]]], "lines": ["、、いやいＣａｒｐ。"]}, {"box": [663, 933, 684, 1001], "vertical": true, "font_size": 21, "lines_coords": [[[663.0, 933.0], [684.0, 933.0], [684.0, 1001.0], [663.0, 1001.0]]], "lines": ["．．．"]}, {"box": [663, 1104, 684, 1188], "vertical": true, "font_size": 21, "lines_coords": [[[663.0, 1104.0], [684.0, 1104.0], [684.0, 1188.0], [663.0, 1188.0]]], "lines": ["あｆ"]}, {"box": [864, 1181, 913, 1201], "vertical": false, "font_size": 20, "lines_coords": [[[864.0, 1181.0], [913.0, 1181.0], [913.0, 1201.0], [864.0, 1201.0]]], "lines": ["．．"]}], "img_path": "00181.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1252, 581, 1266, 706], "vertical": true, "font_size": 14, "lines_coords": [[[1252.0, 581.0], [1266.0, 581.0], [1266.0, 706.0], [1252.0, 706.0]]], "lines": ["水道とトイレだけあって"]}, {"box": [1242, 805, 1269, 939], "vertical": true, "font_size": 27, "lines_coords": [[[1242.0, 805.0], [1269.0, 805.0], [1269.0, 939.0], [1242.0, 939.0]]], "lines": ["んこのソロキャンショップ山の方にもあるんだね"]}, {"box": [1046, 584, 1071, 734], "vertical": true, "font_size": 25, "lines_coords": [[[1046.0, 584.0], [1071.0, 584.0], [1071.0, 734.0], [1046.0, 734.0]]], "lines": ["予約チェックイン・アウトは全部スマホでやるんだへぇー"]}, {"box": [952, 584, 1002, 747], "vertical": true, "font_size": 21, "lines_coords": [[[980.0, 586.0], [1001.0, 586.0], [1001.0, 678.0], [980.0, 678.0]]], "lines": ["そういや最近別々の各々キャンプしてり"]}, {"box": [1047, 775, 1072, 907], "vertical": true, "font_size": 25, "lines_coords": [[[1047.0, 775.0], [1072.0, 775.0], [1072.0, 907.0], [1047.0, 907.0]]], "lines": ["こっちならキャンプ気分に味わえそう"]}, {"box": [974, 775, 1001, 890], "vertical": true, "font_size": 27, "lines_coords": [[[974.0, 775.0], [1001.0, 775.0], [1001.0, 890.0], [974.0, 890.0]]], "lines": ["せやせっかくやから次の野クルキャンプは"]}, {"box": [648, 510, 702, 554], "vertical": false, "font_size": 44, "lines_coords": [[[648.0, 510.0], [702.0, 510.0], [702.0, 554.0], [648.0, 554.0]]], "lines": ["え？"]}, {"box": [647, 511, 701, 554], "vertical": false, "font_size": 47, "lines_coords": [[[647.0, 507.0], [701.0, 507.0], [701.0, 558.0], [647.0, 558.0]]], "lines": ["火沢"]}, {"box": [779, 659, 805, 747], "vertical": true, "font_size": 26, "lines_coords": [[[779.0, 659.0], [805.0, 659.0], [805.0, 747.0], [779.0, 747.0]]], "lines": ["へぇーこれはちょっと楽しそう"]}, {"box": [780, 829, 805, 939], "vertical": true, "font_size": 25, "lines_coords": [[[780.0, 829.0], [805.0, 829.0], [805.0, 939.0], [780.0, 939.0]]], "lines": ["リモートグルキャンにせーへん？"]}, {"box": [641, 606, 702, 958], "vertical": true, "font_size": 58, "lines_coords": [[[641.0, 609.0], [699.0, 609.0], [699.0, 958.0], [641.0, 958.0]]], "lines": ["ゆるキ；Ｊ△"]}, {"box": [258, 585, 289, 640], "vertical": true, "font_size": 31, "lines_coords": [[[258.0, 585.0], [289.0, 585.0], [289.0, 640.0], [258.0, 640.0]]], "lines": ["あれっ何これ？"]}, {"box": [262, 785, 284, 931], "vertical": true, "font_size": 22, "lines_coords": [[[262.0, 785.0], [284.0, 785.0], [284.0, 931.0], [262.0, 931.0]]], "lines": ["おこれは山梨で最近増えてきたソロキャンプ場やな"]}, {"box": [59, 615, 98, 747], "vertical": true, "font_size": 39, "lines_coords": [[[59.0, 615.0], [98.0, 615.0], [98.0, 747.0], [59.0, 747.0]]], "lines": ["昨日までここラッキードリンクショップだったのにソロキャン？"]}, {"box": [64, 855, 90, 943], "vertical": true, "font_size": 26, "lines_coords": [[[64.0, 855.0], [90.0, 855.0], [90.0, 943.0], [64.0, 943.0]]], "lines": ["えこれキャンプ場なの！？"]}, {"box": [1244, 967, 1275, 1088], "vertical": true, "font_size": 21, "lines_coords": [[[1254.0, 967.0], [1275.0, 969.0], [1269.0, 1061.0], [1248.0, 1059.0]]], "lines": ["ちなみに山にあるく"]}, {"box": [1241, 1178, 1268, 1278], "vertical": true, "font_size": 27, "lines_coords": [[[1241.0, 1178.0], [1268.0, 1178.0], [1268.0, 1278.0], [1241.0, 1278.0]]], "lines": ["使い捨てトイレを持ってくか我慢する"]}, {"box": [1042, 1015, 1085, 1136], "vertical": true, "font_size": 43, "lines_coords": [[[1042.0, 1015.0], [1085.0, 1015.0], [1085.0, 1136.0], [1042.0, 1136.0]]], "lines": ["え！？トイレ行きたくなったらどうするの？"]}, {"box": [963, 975, 1000, 1131], "vertical": true, "font_size": 13, "lines_coords": [[[986.0, 978.0], [999.0, 978.0], [999.0, 1006.0], [986.0, 1006.0]]], "lines": ["という"]}, {"box": [1056, 1282, 1068, 1323], "vertical": true, "font_size": 12, "lines_coords": [[[1056.0, 1282.0], [1068.0, 1282.0], [1068.0, 1323.0], [1056.0, 1323.0]]], "lines": ["えぇー"]}, {"box": [954, 1304, 1006, 1330], "vertical": false, "font_size": 26, "lines_coords": [[[954.0, 1304.0], [1006.0, 1304.0], [1006.0, 1330.0], [954.0, 1330.0]]], "lines": ["カモノ甲府駅前"]}, {"box": [865, 1253, 1002, 1278], "vertical": false, "font_size": 25, "lines_coords": [[[865.0, 1253.0], [1002.0, 1253.0], [1002.0, 1278.0], [865.0, 1278.0]]], "lines": ["ラッキーソロキャンショップ甲府駅前店"]}, {"box": [785, 987, 806, 1098], "vertical": true, "font_size": 21, "lines_coords": [[[785.0, 987.0], [806.0, 987.0], [806.0, 1098.0], [785.0, 1098.0]]], "lines": ["果たしてどんなキャンプになるのやら．．．"]}, {"box": [865, 1200, 917, 1217], "vertical": false, "font_size": 17, "lines_coords": [[[865.0, 1200.0], [917.0, 1200.0], [917.0, 1217.0], [865.0, 1217.0]]], "lines": ["・甲府駅"]}, {"box": [659, 938, 687, 1042], "vertical": true, "font_size": 28, "lines_coords": [[[659.0, 938.0], [687.0, 938.0], [687.0, 1042.0], [659.0, 1042.0]]], "lines": ["ｈｉｇｈｓｏｈｏｏｌｄｉｎｓｐｏｖｕｒｃｏｏｍｐｉｎｎｏｔｉｃｅ"]}, {"box": [780, 1219, 808, 1320], "vertical": true, "font_size": 13, "lines_coords": [[[780.0, 1222.0], [793.0, 1222.0], [793.0, 1291.0], [780.0, 1291.0]]], "lines": ["くつろげない"]}, {"box": [657, 1155, 694, 1188], "vertical": false, "font_size": 33, "lines_coords": [[[657.0, 1155.0], [694.0, 1155.0], [694.0, 1188.0], [657.0, 1188.0]]], "lines": ["１４"]}, {"box": [652, 1155, 691, 1393], "vertical": true, "font_size": 39, "lines_coords": [[[652.0, 1155.0], [691.0, 1155.0], [691.0, 1393.0], [652.0, 1393.0]]], "lines": ["１４．５あｆ３："]}, {"box": [252, 975, 288, 1126], "vertical": true, "font_size": 13, "lines_coords": [[[275.0, 1016.0], [288.0, 1016.0], [288.0, 1117.0], [275.0, 1117.0]]], "lines": ["ムでキャンプ場が混ん"]}, {"box": [262, 1170, 284, 1308], "vertical": true, "font_size": 22, "lines_coords": [[[262.0, 1170.0], [284.0, 1170.0], [284.0, 1308.0], [262.0, 1308.0]]], "lines": ["でもこれ本当にくつろげるの？住宅地だよここ？"]}, {"box": [62, 978, 97, 1098], "vertical": true, "font_size": 35, "lines_coords": [[[62.0, 978.0], [97.0, 978.0], [97.0, 1098.0], [62.0, 1098.0]]], "lines": ["ソロ向けにラッキードリンクショップの会社が始めたらしいわ"]}], "img_path": "00182.jpg"}]}