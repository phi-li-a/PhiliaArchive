690.0], [864.0, 690.0]]], "lines": ["うんもう", "グッスリだよ"]}, {"box": [695, 540, 766, 697], "vertical": true, "font_size": 32, "lines_coords": [[[735.0, 540.0], [766.0, 540.0], [766.0, 697.0], [735.0, 697.0]], [[695.0, 541.0], [729.0, 541.0], [729.0, 637.0], [695.0, 637.0]]], "lines": ["それじゃあ", "やるぞ"]}, {"box": [1096, 834, 1182, 1209], "vertical": true, "font_size": 36, "lines_coords": [[[1141.0, 834.0], [1179.0, 834.0], [1179.0, 1209.0], [1141.0, 1209.0]], [[1096.0, 836.0], [1130.0, 836.0], [1132.0, 1096.0], [1098.0, 1096.0]]], "lines": ["禁断の揚げ身延饅頭を", "お姉ちゃんと．．．"]}, {"box": [588, 879, 798, 1145], "vertical": false, "font_size": 235, "lines_coords": [[[686.0, 879.0], [798.0, 931.0], [701.0, 1145.0], [588.0, 1093.0]]], "lines": ["おばさや！！"]}, {"box": [176, 858, 261, 1233], "vertical": true, "font_size": 37, "lines_coords": [[[223.0, 860.0], [260.0, 860.0], [260.0, 1121.0], [223.0, 1121.0]], [[176.0, 858.0], [213.0, 858.0], [213.0, 1233.0], [176.0, 1233.0]]], "lines": ["母さんに秘密で", "夜中に食べるという．．．"]}, {"box": [1074, 1374, 1222, 1687], "vertical": true, "font_size": 137, "lines_coords": [[[1074.0, 1380.0], [1211.0, 1374.0], [1222.0, 1681.0], [1085.0, 1687.0]]], "lines": ["悪魔の"]}, {"box": [135, 1374, 290, 1801], "vertical": true, "font_size": 150, "lines_coords": [[[140.0, 1374.0], [290.0, 1376.0], [285.0, 1801.0], [135.0, 1800.0]]], "lines": ["所業を！！！"]}], "img_path": "00163.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [646, 73, 802, 121], "vertical": false, "font_size": 39, "lines_coords": [[[648.0, 73.0], [802.0, 82.0], [800.0, 121.0], [646.0, 112.0]]], "lines": ["コンミイ"]}, {"box": [883, 1344, 1035, 1788], "vertical": true, "font_size": 75, "lines_coords": [[[956.0, 1344.0], [1035.0, 1346.0], [1027.0, 1668.0], [948.0, 1666.0]], [[883.0, 1351.0], [954.0, 1351.0], [954.0, 1788.0], [883.0, 1788.0]]], "lines": ["ヒャアアア", "アァアアアッ！！"]}, {"box": [268, 1467, 305, 1653], "vertical": true, "font_size": 32, "lines_coords": [[[268.0, 1468.0], [300.0, 1468.0], [300.0, 1648.0], [268.0, 1648.0]]], "lines": ["まだまだね。"]}], "img_path": "00164.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1049, 170, 1168, 583], "vertical": true, "font_size": 32, "lines_coords": [[[1134.0, 172.0], [1166.0, 172.0], [1166.0, 545.0], [1134.0, 545.0]], [[1089.0, 170.0], [1123.0, 170.0], [1125.0, 412.0], [1091.0, 412.0]], [[1050.0, 172.0], [1081.0, 172.0], [1081.0, 583.0], [1050.0, 583.0]]], "lines": ["そろそろ春が来る訳だが", "熊が冬眠を終え", "活動を始める時期でもある"]}, {"box": [453, 244, 516, 293], "vertical": false, "font_size": 49, "lines_coords": [[[453.0, 244.0], [516.0, 244.0], [516.0, 293.0], [453.0, 293.0]]], "lines": ["しき"]}, {"box": [123, 75, 481, 101], "vertical": false, "font_size": 26, "lines_coords": [[[123.0, 75.0], [481.0, 75.0], [481.0, 101.0], [123.0, 101.0]]], "lines": ["放課後１１９日本のクマ"]}, {"box": [315, 152, 392, 531], "vertical": true, "font_size": 32, "lines_coords": [[[358.0, 153.0], [390.0, 153.0], [390.0, 530.0], [358.0, 530.0]], [[315.0, 155.0], [346.0, 155.0], [346.0, 427.0], [315.0, 427.0]]], "lines": ["今日はそれについて話を", "しようじゃないか"]}, {"box": [157, 272, 232, 585], "vertical": true, "font_size": 36, "lines_coords": [[[198.0, 275.0], [230.0, 275.0], [230.0, 585.0], [198.0, 585.0]], [[157.0, 273.0], [196.0, 273.0], [196.0, 375.0], [157.0, 375.0]]], "lines": ["久々にアウトドアほい", "話やな"]}, {"box": [626, 712, 735, 1023], "vertical": true, "font_size": 34, "lines_coords": [[[703.0, 714.0], [735.0, 714.0], [735.0, 961.0], [703.0, 961.0]], [[661.0, 712.0], [699.0, 712.0], [699.0, 1023.0], [661.0, 1023.0]], [[626.0, 712.0], [658.0, 712.0], [658.0, 963.0], [626.0, 963.0]]], "lines": ["この辺にいるのは", "体長１０代重さ９０ｍ位の", "ツキノワグマだな"]}, {"box": [147, 689, 212, 982], "vertical": true, "font_size": 26, "lines_coords": [[[183.0, 691.0], [210.0, 691.0], [210.0, 868.0], [183.0, 868.0]], [[148.0, 691.0], [174.0, 691.0], [174.0, 982.0], [148.0, 982.0]]], "lines": ["そう考えると", "あんまり怖くないねぇ"]}, {"box": [1137, 983, 1207, 1354], "vertical": true, "font_size": 26, "lines_coords": [[[1175.0, 986.0], [1201.0, 986.0], [1201.0, 1353.0], [1175.0, 1353.0]], [[1138.0, 984.0], [1164.0, 984.0], [1164.0, 1201.0], [1138.0, 1201.0]]], "lines": ["日本の熊はツキノワグマと", "ヒグマの２種類"]}, {"box": [663, 1076, 734, 1391], "vertical": true, "font_size": 32, "lines_coords": [[[701.0, 1076.0], [733.0, 1076.0], [733.0, 1391.0], [701.0, 1391.0]], [[663.0, 1078.0], [695.0, 1078.0], [695.0, 1357.0], [663.0, 1357.0]]], "lines": ["数字だけ見るとそんな", "大きくないんだねぇ"]}, {"box": [495, 1078, 560, 1332], "vertical": true, "font_size": 26, "lines_coords": [[[530.0, 1081.0], [556.0, 1081.0], [556.0, 1331.0], [530.0, 1331.0]], [[495.0, 1078.0], [521.0, 1078.0], [521.0, 1329.0], [495.0, 1329.0]]], "lines": ["メタボの中学生男子", "くらいじゃないか？"]}, {"box": [146, 1080, 212, 1359], "vertical": true, "font_size": 28, "lines_coords": [[[180.0, 1083.0], [211.0, 1083.0], [211.0, 1359.0], [180.0, 1359.0]], [[150.0, 1080.0], [176.0, 1080.0], [172.0, 1359.0], [146.0, 1359.0]]], "lines": ["いやいやツキノワグマ", "むっちゃ危険やから！！"]}, {"box": [1108, 1484, 1173, 1747], "vertical": true, "font_size": 26, "lines_coords": [[[1145.0, 1485.0], [1171.0, 1485.0], [1171.0, 1719.0], [1145.0, 1719.0]], [[1108.0, 1485.0], [1134.0, 1485.0], [1134.0, 1747.0], [1108.0, 1747.0]]], "lines": ["それじゃヒグマは", "どこに住んでるの？"]}, {"box": [180, 1520, 258, 1689], "vertical": true, "font_size": 36, "lines_coords": [[[219.0, 1520.0], [258.0, 1520.0], [258.0, 1657.0], [219.0, 1657.0]], [[181.0, 1520.0], [213.0, 1520.0], [213.0, 1689.0], [181.0, 1689.0]]], "lines": ["ヒグマは", "北海道だな"]}], "img_path": "00165.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1061, 136, 1166, 552], "vertical": true, "font_size": 30, "lines_coords": [[[1134.0, 140.0], [1160.0, 140.0], [1160.0, 551.0], [1134.0, 551.0]], [[1093.0, 136.0], [1130.0, 136.0], [1130.0, 466.0], [1093.0, 466.0]], [[1061.0, 142.0], [1087.0, 142.0], [1087.0, 403.0], [1061.0, 403.0]]], "lines": ["ヒゲマは日本では北海道に生息", "体長１０〜２００３体重６０ｃｍに", "なる事もあるらしい"]}, {"box": [181, 215, 305, 455], "vertical": true, "font_size": 37, "lines_coords": [[[266.0, 215.0], [305.0, 215.0], [305.0, 356.0], [266.0, 356.0]], [[221.0, 215.0], [258.0, 215.0], [262.0, 455.0], [225.0, 455.0]], [[181.0, 215.0], [215.0, 215.0], [217.0, 455.0], [183.0, 455.0]]], "lines": ["ひぇえー", "ツキノワグマと", "全然違うねぇ．．．"]}, {"box": [1080, 615, 1149, 954], "vertical": true, "font_size": 29, "lines_coords": [[[1117.0, 615.0], [1149.0, 615.0], [1149.0, 892.0], [1117.0, 892.0]], [[1080.0, 615.0], [1106.0, 615.0], [1108.0, 954.0], [1081.0, 954.0]]], "lines": ["同じクマなのに何で", "こんなに違うのかなぁ？"]}, {"box": [211, 607, 315, 961], "vertical": true, "font_size": 29, "lines_coords": [[[283.0, 607.0], [315.0, 607.0], [315.0, 817.0], [283.0, 817.0]], [[245.0, 607.0], [273.0, 607.0], [275.0, 901.0], [247.0, 901.0]], [[211.0, 611.0], [238.0, 611.0], [238.0, 961.0], [211.0, 961.0]]], "lines": ["なでしこちゃん", "北海道にはゴキブリが", "おらんって話は知っとる？"]}, {"box": [1065, 1049, 1205, 1558], "vertical": true, "font_size": 32, "lines_coords": [[[1179.0, 1051.0], [1205.0, 1051.0], [1205.0, 1170.0], [1179.0, 1170.0]], [[1138.0, 1051.0], [1170.0, 1051.0], [1170.0, 1524.0], [1138.0, 1524.0]], [[1098.0, 1050.0], [1136.0, 1050.0], [1136.0, 1558.0], [1098.0, 1558.0]], [[1065.0, 1051.0], [1098.0, 1051.0], [1098.0, 1143.0], [1065.0, 1143.0]]], "lines": ["どうやら", "北海道に住んどったツキノワダマが", "食べつくしたせいやった言われとるん", "やけど"]}, {"box": [180, 999, 322, 1381], "vertical": true, "font_size": 28, "lines_coords": [[[290.0, 1001.0], [318.0, 1001.0], [316.0, 1381.0], [288.0, 1381.0]], [[249.0, 999.0], [281.0, 999.0], [285.0, 1269.0], [253.0, 1269.0]], [[217.0, 1003.0], [243.0, 1003.0], [243.0, 1353.0], [217.0, 1353.0]], [[181.0, 1001.0], [206.0, 1001.0], [206.0, 1192.0], [181.0, 1192.0]]], "lines": ["ゴキブリを食べたツキノワが", "突然変異を起こして", "ヒグマに進化したって説が", "濃厚なんやてー"]}, {"box": [166, 1455, 318, 1706], "vertical": true, "font_size": 34, "lines_coords": [[[285.0, 1456.0], [318.0, 1456.0], [318.0, 1584.0], [285.0, 1584.0]], [[245.0, 1458.0], [277.0, 1458.0], [277.0, 1706.0], [245.0, 1706.0]], [[206.0, 1458.0], [238.0, 1458.0], [238.0, 1706.0], [206.0, 1706.0]], [[166.0, 1455.0], [204.0, 1455.0], [204.0, 1522.0], [166.0, 1522.0]]], "lines": ["だったら", "本州のツキノワも", "ヒグマになってる", "だろ"]}], "img_path": "00166.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1076, 153, 1140, 376], "vertical": true, "font_size": 26, "lines_coords": [[[1113.0, 155.0], [1140.0, 155.0], [1140.0, 350.0], [1113.0, 350.0]], [[1076.0, 153.0], [1102.0, 153.0], [1102.0, 376.0], [1076.0, 376.0]]], "lines": ["熊は人に対して", "警戒心が強いから"]}, {"box": [969, 176, 1031, 483], "vertical": true, "font_size": 26, "lines_coords": [[[1001.0, 176.0], [1027.0, 176.0], [1031.0, 483.0], [1005.0, 483.0]], [[969.0, 178.0], [995.0, 178.0], [995.0, 315.0], [969.0, 315.0]]], "lines": ["積極的に襲って来る事は", "あまり無い"]}, {"box": [105, 35, 616, 120], "vertical": false, "font_size": 36.333333333333336, "lines_coords": [[[303.0, 35.0], [549.0, 35.0], [549.0, 73.0], [303.0, 73.0]], [[105.0, 60.0], [305.0, 63.0], [305.0, 90.0], [105.0, 86.0]], [[292.0, 69.0], [616.0, 75.0], [616.0, 120.0], [292.0, 114.0]]], "lines": ["くまに食べ物を", "放課後１２０１", "与えてはいけません"]}, {"box": [202, 273, 237, 413], "vertical": true, "font_size": 34, "lines_coords": [[[202.0, 277.0], [236.0, 277.0], [236.0, 412.0], [202.0, 412.0]]], "lines": ["クマァ．．．"]}, {"box": [1162, 553, 1199, 900], "vertical": true, "font_size": 32, "lines_coords": [[[1164.0, 553.0], [1196.0, 553.0], [1194.0, 900.0], [1162.0, 900.0]]], "lines": ["熊が襲って来るのは主に"]}, {"box": [903, 643, 1051, 695], "vertical": false, "font_size": 52, "lines_coords": [[[903.0, 643.0], [1051.0, 643.0], [1051.0, 695.0], [903.0, 695.0]]], "lines": ["そんなー！！"]}, {"box": [157, 558, 194, 686], "vertical": true, "font_size": 34, "lines_coords": [[[157.0, 558.0], [191.0, 558.0], [191.0, 684.0], [157.0, 684.0]]], "lines": ["などだ。"]}, {"box": [901, 1034, 1074, 1065], "vertical": false, "font_size": 27, "lines_coords": [[[905.0, 1036.0], [1068.0, 1036.0], [1068.0, 1063.0], [905.0, 1063.0]]], "lines": ["熊が驚いた時"]}, {"box": [1144, 1229, 1214, 1634], "vertical": true, "font_size": 29, "lines_coords": [[[1181.0, 1231.0], [1213.0, 1231.0], [1213.0, 1633.0], [1181.0, 1633.0]], [[1145.0, 1233.0], [1171.0, 1233.0], [1171.0, 1447.0], [1145.0, 1447.0]]], "lines": ["だが例外として人の食べ物の", "味を覚えた熊は"]}, {"box": [601, 1032, 768, 1098], "vertical": false, "font_size": 29, "lines_coords": [[[615.0, 1035.0], [750.0, 1035.0], [750.0, 1061.0], [615.0, 1061.0]], [[601.0, 1066.0], [766.0, 1066.0], [766.0, 1098.0], [601.0, 1098.0]]], "lines": ["熊が小熊と", "一緒にいる時"]}, {"box": [865, 1276, 886, 1357], "vertical": true, "font_size": 21, "lines_coords": [[[865.0, 1276.0], [886.0, 1276.0], [886.0, 1357.0], [865.0, 1357.0]]], "lines": ["キラ明太っ"]}, {"box": [543, 1224, 653, 1571], "vertical": true, "font_size": 32, "lines_coords": [[[620.0, 1226.0], [652.0, 1226.0], [652.0, 1509.0], [620.0, 1509.0]], [[583.0, 1224.0], [615.0, 1224.0], [615.0, 1571.0], [583.0, 1571.0]], [[543.0, 1226.0], [575.0, 1226.0], [575.0, 1539.0], [543.0, 1539.0]]], "lines": ["人がいる所に行けば", "うまい食べ物があるって", "覚えちまうらしいんだ"]}, {"box": [285, 1031, 478, 1098], "vertical": false, "font_size": 29, "lines_coords": [[[286.0, 1035.0], [472.0, 1035.0], [472.0, 1061.0], [286.0, 1061.0]], [[322.0, 1066.0], [438.0, 1066.0], [438.0, 1098.0], [322.0, 1098.0]]], "lines": ["熊に背を向けて", "逃げた時"]}, {"box": [699, 1471, 768, 1753], "vertical": true, "font_size": 29, "lines_coords": [[[733.0, 1471.0], [765.0, 1471.0], [766.0, 1753.0], [735.0, 1753.0]], [[699.0, 1477.0], [725.0, 1477.0], [725.0, 1599.0], [699.0, 1599.0]]], "lines": ["積極的に襲って来る", "事がある"]}], "img_path": "00167.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1020, 148, 1208, 521], "vertical": true, "font_size": 31, "lines_coords": [[[1175.0, 150.0], [1207.0, 150.0], [1207.0, 459.0], [1175.0, 459.0]], [[1136.0, 148.0], [1168.0, 148.0], [1168.0, 521.0], [1136.0, 521.0]], [[1096.0, 150.0], [1128.0, 150.0], [1128.0, 431.0], [1096.0, 431.0]], [[1061.0, 150.0], [1087.0, 150.0], [1087.0, 425.0], [1061.0, 425.0]], [[1020.0, 148.0], [1053.0, 148.0], [1053.0, 243.0], [1020.0, 243.0]]], "lines": ["だからキャンプの時は、", "食材や食べのこしなんかを", "外に放置しないよう", "気をつけなきゃダメ", "なんだ"]}, {"box": [510, 181, 540, 369], "vertical": true, "font_size": 28, "lines_coords": [[[510.0, 181.0], [538.0, 181.0], [540.0, 369.0], [511.0, 369.0]]], "lines": ["なるほどねぇ"]}, {"box": [155, 187, 198, 316], "vertical": true, "font_size": 40, "lines_coords": [[[159.0, 187.0], [198.0, 189.0], [195.0, 316.0], [155.0, 315.0]]], "lines": ["せやでー"]}, {"box": [1018, 596, 1168, 907], "vertical": true, "font_size": 31, "lines_coords": [[[1136.0, 598.0], [1168.0, 598.0], [1168.0, 813.0], [1136.0, 813.0]], [[1093.0, 596.0], [1126.0, 596.0], [1128.0, 907.0], [1095.0, 907.0]], [[1059.0, 598.0], [1085.0, 598.0], [1085.0, 813.0], [1059.0, 813.0]], [[1018.0, 596.0], [1050.0, 596.0], [1050.0, 720.0], [1018.0, 720.0]]], "lines": ["特に最近の熊は", "かなり賢いらしいから", "十分気をつけな", "あかんで"]}, {"box": [266, 658, 299, 828], "vertical": true, "font_size": 32, "lines_coords": [[[266.0, 658.0], [298.0, 658.0], [298.0, 828.0], [266.0, 828.0]]], "lines": ["そうなの？"]}, {"box": [1090, 986, 1197, 1549], "vertical": true, "font_size": 30, "lines_coords": [[[1164.0, 988.0], [1190.0, 988.0], [1190.0, 1398.0], [1164.0, 1398.0]], [[1126.0, 986.0], [1158.0, 986.0], [1158.0, 1462.0], [1126.0, 1462.0]], [[1091.0, 988.0], [1123.0, 988.0], [1123.0, 1548.0], [1091.0, 1548.0]]], "lines": ["人の食べ物の味を覚えてまうと、", "あっという間にＳＮＳで拡散されて", "山からみんな人里に降りて来てまうでなぁ"]}, {"box": [930, 1374, 984, 1421], "vertical": false, "font_size": 47, "lines_coords": [[[930.0, 1374.0], [984.0, 1374.0], [984.0, 1421.0], [930.0, 1421.0]]], "lines": ["い"]}, {"box": [707, 1205, 905, 1294], "vertical": false, "font_size": 26, "lines_coords": [[[712.0, 1205.0], [877.0, 1205.0], [877.0, 1231.0], [712.0, 1231.0]], [[712.0, 1235.0], [855.0, 1235.0], [855.0, 1261.0], [712.0, 1261.0]], [[712.0, 1267.0], [905.0, 1267.0], [905.0, 1293.0], [712.0, 1293.0]]], "lines": ["アクアパッツァ", "たべたくま！！", "まじうまいくま！！"]}, {"box": [680, 1321, 746, 1387], "vertical": false, "font_size": 45, "lines_coords": [[[680.0, 1355.0], [714.0, 1321.0], [746.0, 1353.0], [712.0, 1387.0]]], "lines": ["くっ"]}, {"box": [693, 1335, 734, 1375], "vertical": false, "font_size": 40, "lines_coords": [[[693.0, 1335.0], [734.0, 1335.0], [734.0, 1375.0], [693.0, 1375.0]]], "lines": ["い"]}, {"box": [303, 1368, 478, 1438], "vertical": false, "font_size": 32.0, "lines_coords": [[[335.0, 1368.0], [472.0, 1374.0], [470.0, 1406.0], [333.0, 1400.0]], [[305.0, 1395.0], [478.0, 1406.0], [476.0, 1438.0], [303.0, 1426.0]]], "lines": ["アクアパッツァ", "食べに行くのは"]}, {"box": [148, 967, 252, 1410], "vertical": true, "font_size": 28, "lines_coords": [[[223.0, 969.0], [249.0, 969.0], [249.0, 1410.0], [223.0, 1410.0]], [[181.0, 967.0], [213.0, 967.0], [213.0, 1267.0], [181.0, 1267.0]], [[148.0, 967.0], [174.0, 967.0], [174.0, 1203.0], [148.0, 1203.0]]], "lines": ["ＳＮＳできる位の知能があったら", "逆に人間とうまく共存", "できそうだけどな"]}, {"box": [941, 1657, 993, 1706], "vertical": false, "font_size": 49, "lines_coords": [[[941.0, 1657.0], [993.0, 1657.0], [993.0, 1706.0], [941.0, 1706.0]]], "lines": ["い"]}], "img_path": "00168.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [712, 73, 1222, 99], "vertical": false, "font_size": 26, "lines_coords": [[[712.0, 73.0], [1222.0, 73.0], [1222.0, 99.0], [712.0, 99.0]]], "lines": ["放課後１２１人工芸を敷いてみた"]}, {"box": [1061, 234, 1144, 538], "vertical": true, "font_size": 35, "lines_coords": [[[1108.0, 238.0], [1141.0, 238.0], [1143.0, 425.0], [1110.0, 425.0]], [[1063.0, 234.0], [1100.0, 234.0], [1098.0, 538.0], [1061.0, 538.0]]], "lines": ["あきちゃん", "どうしたのこれ！？"]}, {"box": [316, 200, 389, 609], "vertical": true, "font_size": 32, "lines_coords": [[[356.0, 204.0], [388.0, 204.0], [388.0, 609.0], [356.0, 609.0]], [[316.0, 200.0], [348.0, 200.0], [348.0, 575.0], [316.0, 575.0]]], "lines": ["ホムセンで安売りしてたから、", "ちょっと買ってみたんだよ"]}, {"box": [176, 393, 210, 521], "vertical": true, "font_size": 34, "lines_coords": [[[176.0, 393.0], [210.0, 393.0], [210.0, 478.0], [176.0, 478.0]]], "lines": ["ほぉー"]}, {"box": [1139, 1156, 1209, 1410], "vertical": true, "font_size": 32, "lines_coords": [[[1171.0, 1156.0], [1209.0, 1156.0], [1209.0, 1410.0], [1171.0, 1410.0]], [[1140.0, 1160.0], [1166.0, 1160.0], [1166.0, 1391.0], [1140.0, 1391.0]]], "lines": ["手触りもホンマに", "リアルやなこれ"]}, {"box": [544, 964, 805, 1011], "vertical": false, "font_size": 32, "lines_coords": [[[551.0, 971.0], [796.0, 969.0], [796.0, 1001.0], [551.0, 1003.0]]], "lines": ["リアル人でも"]}, {"box": [706, 1175, 748, 1286], "vertical": true, "font_size": 42, "lines_coords": [[[706.0, 1175.0], [748.0, 1175.0], [748.0, 1286.0], [706.0, 1286.0]]], "lines": ["だろー"]}, {"box": [496, 1522, 630, 1773], "vertical": true, "font_size": 26, "lines_coords": [[[600.0, 1524.0], [626.0, 1524.0], [626.0, 1773.0], [600.0, 1773.0]], [[564.0, 1524.0], [590.0, 1524.0], [590.0, 1743.0], [564.0, 1743.0]], [[532.0, 1524.0], [558.0, 1524.0], [558.0, 1689.0], [532.0, 1689.0]], [[496.0, 1522.0], [523.0, 1522.0], [523.0, 1663.0], [496.0, 1663.0]]], "lines": ["人工芝ってこういう", "ゴワゴワしたやつ", "ばっかりだと", "思ってたよ"]}, {"box": [140, 1507, 210, 1695], "vertical": true, "font_size": 32, "lines_coords": [[[178.0, 1507.0], [210.0, 1507.0], [210.0, 1695.0], [178.0, 1695.0]], [[140.0, 1507.0], [172.0, 1507.0], [172.0, 1695.0], [140.0, 1695.0]]], "lines": ["あーよくある", "芝マットだな"]}], "img_path": "00169.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [225, 270, 305, 421], "vertical": true, "font_size": 33, "lines_coords": [[[270.0, 273.0], [303.0, 273.0], [303.0, 416.0], [270.0, 416.0]], [[225.0, 270.0], [258.0, 270.0], [260.0, 421.0], [226.0, 421.0]]], "lines": ["フカフカ", "やなぁ～"]}, {"box": [1066, 360, 1147, 637], "vertical": true, "font_size": 38, "lines_coords": [[[1110.0, 360.0], [1147.0, 360.0], [1147.0, 637.0], [1110.0, 637.0]], [[1066.0, 360.0], [1106.0, 360.0], [1106.0, 536.0], [1066.0, 536.0]]], "lines": ["はぁ〰〰フカフカ", "だねぃ～～"]}, {"box": [360, 798, 399, 903], "vertical": true, "font_size": 39, "lines_coords": [[[360.0, 798.0], [399.0, 798.0], [399.0, 903.0], [360.0, 903.0]]], "lines": ["だねぇ"]}, {"box": [185, 823, 253, 1038], "vertical": true, "font_size": 29, "lines_coords": [[[221.0, 823.0], [253.0, 823.0], [253.0, 1008.0], [221.0, 1008.0]], [[185.0, 825.0], [211.0, 825.0], [211.0, 1038.0], [185.0, 1038.0]]], "lines": ["この部屋じゃ", "狭すぎやけどね"]}, {"box": [1033, 753, 1142, 1188], "vertical": true, "font_size": 30, "lines_coords": [[[1110.0, 755.0], [1141.0, 755.0], [1141.0, 1096.0], [1110.0, 1096.0]], [[1072.0, 757.0], [1098.0, 757.0], [1098.0, 1188.0], [1072.0, 1188.0]], [[1033.0, 753.0], [1065.0, 753.0], [1065.0, 973.0], [1033.0, 973.0]]], "lines": ["人工芝敷いてこうやって", "室内キャンフ気分を味わうのも", "悪くないだろ？"]}, {"box": [425, 1273, 496, 1523], "vertical": true, "font_size": 32, "lines_coords": [[[465.0, 1275.0], [496.0, 1275.0], [496.0, 1428.0], [465.0, 1428.0]], [[425.0, 1273.0], [457.0, 1273.0], [457.0, 1520.0], [425.0, 1520.0]]], "lines": ["これはいい", "買い物だったなー"]}, {"box": [1068, 1299, 1167, 1635], "vertical": true, "font_size": 29, "lines_coords": [[[1138.0, 1299.0], [1164.0, 1299.0], [1164.0, 1580.0], [1138.0, 1580.0]], [[1098.0, 1299.0], [1130.0, 1299.0], [1132.0, 1635.0], [1100.0, 1635.0]], [[1068.0, 1301.0], [1096.0, 1301.0], [1096.0, 1385.0], [1068.0, 1385.0]]], "lines": ["部屋で食べるお菓子も", "いつもとちょっと違う気が", "するよ"]}, {"box": [705, 1404, 742, 1582], "vertical": true, "font_size": 34, "lines_coords": [[[705.0, 1404.0], [738.0, 1404.0], [742.0, 1582.0], [708.0, 1582.0]]], "lines": ["ホンマやなぁ"]}, {"box": [131, 1248, 287, 1786], "vertical": true, "font_size": 36, "lines_coords": [[[255.0, 1252.0], [286.0, 1252.0], [286.0, 1473.0], [255.0, 1473.0]], [[213.0, 1250.0], [251.0, 1250.0], [251.0, 1631.0], [213.0, 1631.0]], [[174.0, 1250.0], [211.0, 1250.0], [211.0, 1786.0], [174.0, 1786.0]], [[131.0, 1248.0], [168.0, 1248.0], [172.0, 1520.0], [135.0, 1520.0]]], "lines": ["この後お菓子の", "食べこぼしのせいでえ生に", "めちゃくちゃ虫がわく事になるのだが", "それはまた別の話"]}, {"box": [116, 1807, 650, 1835], "vertical": false, "font_size": 24, "lines_coords": [[[116.0, 1807.0], [650.0, 1811.0], [650.0, 1835.0], [116.0, 1831.0]]], "lines": ["☆人工芝を敷く時はちゃんと手入れをしましょう"]}], "img_path": "00170.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [120, 69, 675, 103], "vertical": false, "font_size": 32, "lines_coords": [[[120.0, 71.0], [675.0, 69.0], [675.0, 101.0], [120.0, 103.0]]], "lines": ["放課後１２２ゴーストライター千吸"]}, {"box": [380, 217, 444, 472], "vertical": true, "font_size": 29, "lines_coords": [[[412.0, 219.0], [444.0, 219.0], [444.0, 472.0], [412.0, 472.0]], [[380.0, 217.0], [406.0, 217.0], [406.0, 470.0], [380.0, 470.0]]], "lines": ["なでしこまたスマホ", "忘れてんじゃねーか"]}, {"box": [283, 151, 316, 361], "vertical": true, "font_size": 28, "lines_coords": [[[283.0, 151.0], [311.0, 151.0], [313.0, 360.0], [285.0, 360.0]]], "lines": ["しょうがねぇなぁ"]}, {"box": [564, 808, 652, 828], "vertical": false, "font_size": 20, "lines_coords": [[[564.0, 808.0], [652.0, 808.0], [652.0, 828.0], [564.0, 828.0]]], "lines": ["．．．"]}, {"box": [183, 980, 531, 1072], "vertical": false, "font_size": 26, "lines_coords": [[[185.0, 984.0], [478.0, 984.0], [478.0, 1010.0], [185.0, 1010.0]], [[187.0, 1016.0], [526.0, 1016.0], [526.0, 1042.0], [187.0, 1042.0]], [[427.0, 1046.0], [513.0, 1046.0], [513.0, 1072.0], [427.0, 1072.0]]], "lines": ["リンちゃん！！部活してたら", "校庭にわんこが入ってきたよ！！", "（ワ）"]}, {"box": [1143, 1503, 1177, 1612], "vertical": true, "font_size": 34, "lines_coords": [[[1143.0, 1503.0], [1177.0, 1503.0], [1177.0, 1612.0], [1143.0, 1612.0]]], "lines": ["そうだ"]}, {"box": [755, 1380, 826, 1738], "vertical": true, "font_size": 29, "lines_coords": [[[793.0, 1380.0], [825.0, 1380.0], [825.0, 1738.0], [793.0, 1738.0]], [[755.0, 1381.0], [781.0, 1381.0], [781.0, 1736.0], [755.0, 1736.0]]], "lines": ["またなでしこのフリして", "リンをからかってやるか"]}, {"box": [196, 1430, 234, 1627], "vertical": true, "font_size": 38, "lines_coords": [[[196.0, 1430.0], [234.