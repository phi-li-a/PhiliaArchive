, 1162.0]], [[146.0, 930.0], [178.0, 930.0], [178.0, 1121.0], [146.0, 1121.0]]], "lines": ["ああパンクかぁ", "大変やったね"]}, {"box": [718, 1535, 789, 1727], "vertical": true, "font_size": 29, "lines_coords": [[[753.0, 1535.0], [785.0, 1535.0], [789.0, 1708.0], [757.0, 1708.0]], [[720.0, 1541.0], [746.0, 1541.0], [746.0, 1726.0], [720.0, 1726.0]]], "lines": ["あおはよう", "ございます！"]}], "img_path": "00076.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1153, 142, 1222, 412], "vertical": true, "font_size": 34, "lines_coords": [[[1186.0, 142.0], [1222.0, 142.0], [1222.0, 204.0], [1186.0, 204.0]], [[1156.0, 144.0], [1188.0, 144.0], [1185.0, 412.0], [1153.0, 412.0]]], "lines": ["まぁ", "パンク修理くらいなら"]}, {"box": [630, 134, 693, 628], "vertical": true, "font_size": 26, "lines_coords": [[[663.0, 135.0], [690.0, 135.0], [690.0, 622.0], [663.0, 622.0]], [[630.0, 135.0], [656.0, 135.0], [656.0, 504.0], [630.0, 504.0]]], "lines": ["あれ？ロードバイクのタイヤチューブて", "ママチャリに使えるんやろか？"]}, {"box": [140, 170, 202, 489], "vertical": true, "font_size": 26, "lines_coords": [[[174.0, 170.0], [200.0, 170.0], [196.0, 489.0], [170.0, 489.0]], [[140.0, 174.0], [166.0, 174.0], [166.0, 410.0], [140.0, 410.0]]], "lines": ["よう見たら空気入れる所の", "大さも違うような．．．"]}, {"box": [750, 345, 811, 720], "vertical": true, "font_size": 26, "lines_coords": [[[781.0, 346.0], [808.0, 346.0], [808.0, 720.0], [781.0, 720.0]], [[750.0, 346.0], [774.0, 346.0], [774.0, 690.0], [750.0, 690.0]]], "lines": ["こないだお父さんに教わったし、", "予備チューフも持っとるし．．．"]}, {"box": [1132, 763, 1192, 1164], "vertical": true, "font_size": 25, "lines_coords": [[[1166.0, 765.0], [1190.0, 765.0], [1190.0, 1164.0], [1166.0, 1164.0]], [[1134.0, 763.0], [1160.0, 763.0], [1158.0, 965.0], [1132.0, 965.0]]], "lines": ["てもタイヤの太さは同じくらいやし", "行けそうな気も："]}, {"box": [1177, 1252, 1205, 1522], "vertical": true, "font_size": 26, "lines_coords": [[[1177.0, 1252.0], [1203.0, 1252.0], [1203.0, 1522.0], [1177.0, 1522.0]]], "lines": ["せやちょい待っててな"]}, {"box": [701, 1006, 733, 1