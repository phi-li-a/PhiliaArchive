{"box": [1179, 652, 1207, 901], "vertical": true, "font_size": 26, "lines_coords": [[[1179.0, 652.0], [1205.0, 652.0], [1207.0, 901.0], [1181.0, 901.0]]], "lines": ["なでしこは椅子だっけ"]}, {"box": [744, 690, 778, 787], "vertical": true, "font_size": 34, "lines_coords": [[[744.0, 690.0], [778.0, 690.0], [778.0, 787.0], [744.0, 787.0]]], "lines": ["候補１"]}, {"box": [838, 871, 930, 1148], "vertical": true, "font_size": 27, "lines_coords": [[[892.0, 871.0], [930.0, 871.0], [930.0, 930.0], [892.0, 930.0]], [[868.0, 875.0], [892.0, 875.0], [892.0, 1147.0], [868.0, 1147.0]], [[840.0, 877.0], [858.0, 877.0], [858.0, 1145.0], [840.0, 1145.0]]], "lines": ["うん", "二つ候補があるんだけど", "座り比べて決めるつもり"]}, {"box": [270, 922, 329, 1121], "vertical": true, "font_size": 26, "lines_coords": [[[301.0, 922.0], [328.0, 922.0], [328.0, 1121.0], [301.0, 1121.0]], [[270.0, 922.0], [296.0, 922.0], [296.0, 1096.0], [270.0, 1096.0]]], "lines": ["これは私と千明が", "使ってるやつか"]}, {"box": [157, 1014, 195, 1083], "vertical": true, "font_size": 38, "lines_coords": [[[157.0, 1014.0], [195.0, 1014.0], [195.0, 1083.0], [157.0, 1083.0]]], "lines": ["うん"]}, {"box": [286, 1263, 349, 1543], "vertical": true, "font_size": 26, "lines_coords": [[[320.0, 1263.0], [346.0, 1263.0], [346.0, 1430.0], [320.0, 1430.0]], [[286.0, 1263.0], [313.0, 1263.0], [313.0, 1543.0], [286.0, 1543.0]]], "lines": ["それに軽いし", "すっごく小さくなるし"]}, {"box": [1068, 1473, 1132, 1723], "vertical": true, "font_size": 28, "lines_coords": [[[1100.0, 1473.0], [1132.0, 1473.0], [1130.0, 1698.0], [1098.0, 1698.0]], [[1068.0, 1475.0], [1093.0, 1475.0], [1093.0, 1723.0], [1068.0, 1723.0]]], "lines": ["やっぱりこの椅子", "座り心地いいよねぃ"]}], "img_path": "00122.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1162, 178, 1196, 275], "vertical": true, "font_size": 34, "lines_coords": [[[1162.0, 178.0], [1196.0, 178.0], [1196.0, 275.0], [1162.0, 275.0]]], "lines": ["候補２"]}, {"box": [204, 138, 311, 159], "vertical": false, "font_size": 21, "lines_coords": [[[204.0, 138.0], [311.0, 138.0], [311.0, 159.0], [204.0, 159.0]]], "lines": ["こんにちは"]}, {"box": [1160, 509, 1187, 648], "vertical": true, "font_size": 26, "lines_coords": [[[1160.0, 510.0], [1186.0, 510.0], [1186.0, 648.0], [1160.0, 648.0]]], "lines": ["次はこっち"]}, {"box": [1121, 733, 1206, 1155], "vertical": true, "font_size": 26, "lines_coords": [[[1177.0, 733.0], [1203.0, 733.0], [1205.0, 1153.0], [1179.0, 1153.0]], [[1149.0, 733.0], [1175.0, 733.0], [1177.0, 1155.0], [1151.0, 1155.0]], [[1121.0, 733.0], [1147.0, 733.0], [1147.0, 898.0], [1121.0, 898.0]]], "lines": ["このチェアは接地面を四本のフレームで", "ガッチリ固めているので安定感が強くて", "浅めの座り心地"]}, {"box": [757, 464, 813, 618], "vertical": true, "font_size": 24, "lines_coords": [[[787.0, 465.0], [811.0, 465.0], [811.0, 618.0], [787.0, 618.0]], [[757.0, 465.0], [781.0, 465.0], [781.0, 613.0], [757.0, 613.0]]], "lines": ["んこの椅子も", "人気あるよな"]}, {"box": [611, 406, 701, 680], "vertical": true, "font_size": 27, "lines_coords": [[[673.0, 408.0], [699.0, 408.0], [697.0, 656.0], [671.0, 656.0]], [[643.0, 408.0], [669.0, 408.0], [669.0, 680.0], [643.0, 680.0]], [[611.0, 406.0], [641.0, 406.0], [641.0, 463.0], [611.0, 463.0]]], "lines": ["リンちゃんの椅子より", "ちょっと座り心地が固い", "けど"]}, {"box": [684, 736, 736, 991], "vertical": true, "font_size": 24, "lines_coords": [[[710.0, 740.0], [736.0, 740.0], [736.0, 991.0], [710.0, 991.0]], [[684.0, 736.0], [708.0, 736.0], [708.0, 924.0], [684.0, 924.0]]], "lines": ["一方こちらはフレームが", "しなる形状なので"]}, {"box": [144, 448, 201, 618], "vertical": true, "font_size": 25, "lines_coords": [[[176.0, 448.0], [200.0, 448.0], [200.0, 596.0], [176.0, 596.0]], [[144.0, 450.0], [170.0, 450.0], [170.0, 618.0], [144.0, 618.0]]], "lines": ["こっちもまた", "いいんだよねい"]}, {"box": [600, 883, 654, 1145], "vertical": true, "font_size": 24, "lines_coords": [[[626.0, 883.0], [650.0, 883.0], [654.0, 1145.0], [630.0, 1145.0]], [[600.0, 886.0], [624.0, 886.0], [624.0, 1098.0], [600.0, 1098.0]]], "lines": ["柔らかく包まれるような", "深めの座り心地です"]}, {"box": [168, 960, 196, 1081], "vertical": true, "font_size": 27, "lines_coords": [[[168.0, 960.0], [195.0, 960.0], [195.0, 1081.0], [168.0, 1081.0]]], "lines": ["なるほど"]}, {"box": [165, 1220, 224, 1520], "vertical": true, "font_size": 26, "lines_coords": [[[196.0, 1222.0], [223.0, 1222.0], [223.0, 1520.0], [196.0, 1520.0]], [[165.0, 1220.0], [191.0, 1220.0], [191.0, 1445.0], [165.0, 1445.0]]], "lines": ["あとは国内の店舗在庫しか", "残っていないんです"]}, {"box": [1141, 1539, 1198, 1785], "vertical": true, "font_size": 22, "lines_coords": [[[1170.0, 1539.0], [1194.0, 1539.0], [1194.0, 1764.0], [1170.0, 1764.0]], [[1141.0, 1543.0], [1160.0, 1543.0], [1160.0, 1785.0], [1141.0, 1785.0]]], "lines": ["似たような椅子でも", "こんなに違うんですね"]}, {"box": [821, 1633, 862, 1708], "vertical": true, "font_size": 41, "lines_coords": [[[821.0, 1633.0], [862.0, 1633.0], [862.0, 1708.0], [821.0, 1708.0]]], "lines": ["ええ"]}, {"box": [654, 1411, 741, 1712], "vertical": true, "font_size": 25, "lines_coords": [[[716.0, 1411.0], [740.0, 1411.0], [740.0, 1710.0], [716.0, 1710.0]], [[684.0, 1411.0], [710.0, 1411.0], [710.0, 1687.0], [684.0, 1687.0]], [[654.0, 1411.0], [678.0, 1411.0], [678.0, 1711.0], [654.0, 1711.0]]], "lines": ["ですが実はこちらのチェア", "ちょっと前にアメリカの", "製造元が廃業してしまって"]}, {"box": [151, 1573, 217, 1736], "vertical": true, "font_size": 31, "lines_coords": [[[180.0, 1573.0], [217.0, 1573.0], [217.0, 1631.0], [180.0, 1631.0]], [[151.0, 1576.0], [176.0, 1576.0], [176.0, 1736.0], [151.0, 1736.0]]], "lines": ["えっ", "廃業ですか！？"]}], "img_path": "00123.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1128, 165, 1213, 376], "vertical": true, "font_size": 27, "lines_coords": [[[1185.0, 165.0], [1213.0, 165.0], [1213.0, 240.0], [1185.0, 240.0]], [[1151.0, 165.0], [1179.0, 165.0], [1183.0, 331.0], [1155.0, 331.0]], [[1128.0, 166.0], [1153.0, 166.0], [1153.0, 376.0], [1128.0, 376.0]]], "lines": ["じゃあ", "修理もできなく", "なるって事ですか？"]}, {"box": [626, 140, 687, 406], "vertical": true, "font_size": 25, "lines_coords": [[[660.0, 140.0], [684.0, 140.0], [684.0, 405.0], [660.0, 405.0]], [[626.0, 142.0], [652.0, 142.0], [652.0, 406.0], [626.0, 406.0]]], "lines": ["それじゃ壊さないよう", "大切に扱わないとな．．．"]}, {"box": [714, 286, 804, 588], "vertical": true, "font_size": 26, "lines_coords": [[[776.0, 286.0], [802.0, 286.0], [804.0, 540.0], [778.0, 540.0]], [[746.0, 290.0], [772.0, 290.0], [772.0, 588.0], [746.0, 588.0]], [[714.0, 288.0], [740.0, 288.0], [742.0, 513.0], [716.0, 513.0]]], "lines": ["そうなるかと思います", "しばらくは国内の代理店が", "対応するようですが"]}, {"box": [121, 142, 184, 406], "vertical": true, "font_size": 26, "lines_coords": [[[157.0, 148.0], [181.0, 148.0], [181.0, 406.0], [157.0, 406.0]], [[123.0, 142.0], [150.0, 142.0], [148.0, 380.0], [121.0, 380.0]]], "lines": ["こっちは在庫のみかぁ", "．．．どっちにしよう"]}, {"box": [1151, 671, 1209, 1020], "vertical": true, "font_size": 25, "lines_coords": [[[1181.0, 671.0], [1205.0, 671.0], [1205.0, 918.0], [1181.0, 918.0]], [[1151.0, 671.0], [1177.0, 671.0], [1177.0, 1020.0], [1151.0, 1020.0]]], "lines": ["最近取り扱いを始めた", "こちらのチェアはどうですか？"]}, {"box": [744, 673, 803, 1046], "vertical": true, "font_size": 26, "lines_coords": [[[776.0, 675.0], [802.0, 675.0], [802.0, 1046.0], [776.0, 1046.0]], [[744.0, 673.0], [770.0, 673.0], [770.0, 920.0], [744.0, 920.0]]], "lines": ["そちらの二つよりも収納サイズが", "少し大きめなんですが、"]}, {"box": [1098, 1248, 1197, 1595], "vertical": true, "font_size": 29, "lines_coords": [[[1170.0, 1252.0], [1194.0, 1252.0], [1194.0, 1543.0], [1170.0, 1543.0]], [[1136.0, 1252.0], [1162.0, 1252.0], [1162.0, 1595.0], [1136.0, 1595.0]], [[1098.0, 1248.0], [1134.0, 1248.0], [1134.0, 1333.0], [1098.0, 1333.0]]], "lines": ["収納サイズ５０～かぁ．．．", "この２つが３０％だから確かに", "デカい"]}, {"box": [135, 832, 197, 1149], "vertical": true, "font_size": 26, "lines_coords": [[[166.0, 832.0], [193.0, 832.0], [193.0, 1149.0], [166.0, 1149.0]], [[135.0, 834.0], [159.0, 834.0], [159.0, 1018.0], [135.0, 1018.0]]], "lines": ["座り心地は抜群にいいので", "おすすめですよ"]}, {"box": [183, 1237, 248, 1554], "vertical": true, "font_size": 26, "lines_coords": [[[219.0, 1237.0], [245.0, 1237.0], [241.0, 1554.0], [215.0, 1554.0]], [[185.0, 1237.0], [211.0, 1237.0], [210.0, 1530.0], [183.0, 1530.0]]], "lines": ["なでしこ徒歩メインだから", "運ぶの大変じゃないか？"]}, {"box": [234, 1630, 263, 1725], "vertical": true, "font_size": 28, "lines_coords": [[[234.0, 1633.0], [262.0, 1633.0], [262.0, 1725.0], [234.0, 1725.0]]], "lines": ["うーん"]}], "img_path": "00124.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [217, 176, 309, 466], "vertical": true, "font_size": 25, "lines_coords": [[[281.0, 176.0], [307.0, 176.0], [307.0, 281.0], [281.0, 281.0]], [[249.0, 178.0], [275.0, 178.0], [275.0, 466.0], [249.0, 466.0]], [[217.0, 176.0], [241.0, 176.0], [241.0, 440.0], [217.0, 440.0]]], "lines": ["関さんが", "おすすめって言ってるし", "とにかく座ってみるよ"]}, {"box": [355, 563, 732, 667], "vertical": false, "font_size": 104, "lines_coords": [[[355.0, 563.0], [732.0, 563.0], [732.0, 667.0], [355.0, 667.0]]], "lines": ["ほげ．．．"]}, {"box": [215, 665, 273, 838], "vertical": true, "font_size": 55, "lines_coords": [[[215.0, 665.0], [270.0, 665.0], [270.0, 838.0], [215.0, 838.0]]], "lines": ["即決！？"]}, {"box": [1066, 817, 1152, 1115], "vertical": true, "font_size": 38, "lines_coords": [[[1113.0, 819.0], [1151.0, 819.0], [1151.0, 1115.0], [1113.0, 1115.0]], [[1066.0, 817.0], [1104.0, 817.0], [1108.0, 1080.0], [1070.0, 1080.0]]], "lines": ["リンちゃんわたし", "これにするぅー"]}, {"box": [1156, 1209, 1213, 1434], "vertical": true, "font_size": 27, "lines_coords": [[[1186.0, 1211.0], [1213.0, 1211.0], [1213.0, 1434.0], [1186.0, 1434.0]], [[1156.0, 1209.0], [1181.0, 1209.0], [1181.0, 1381.0], [1156.0, 1381.0]]], "lines": ["ハンモックメーカー", "が作った椅子で"]}, {"box": [433, 1213, 491, 1415], "vertical": true, "font_size": 25, "lines_coords": [[[465.0, 1216.0], [489.0, 1216.0], [489.0, 1415.0], [465.0, 1415.0]], [[433.0, 1213.0], [459.0, 1213.0], [459.0, 1389.0], [433.0, 1389.0]]], "lines": ["それじゃ週明けに", "買いに来ます！！"]}, {"box": [161, 1201, 189, 1400], "vertical": true, "font_size": 24, "lines_coords": [[[161.0, 1201.0], [185.0, 1201.0], [185.0, 1400.0], [161.0, 1400.0]]], "lines": ["お待ちしています"]}, {"box": [1108, 1441, 1196, 1672], "vertical": true, "font_size": 27, "lines_coords": [[[1171.0, 1447.0], [1196.0, 1447.0], [1196.0, 1646.0], [1171.0, 1646.0]], [[1143.0, 1447.0], [1168.0, 1447.0], [1168.0, 1672.0], [1143.0, 1672.0]], [[1108.0, 1441.0], [1143.0, 1441.0], [1143.0, 1503.0], [1108.0, 1503.0]]], "lines": ["一座るハンモック」", "なんて呼ばれている", "とか"]}, {"box": [645, 1453, 703, 1788], "vertical": true, "font_size": 24, "lines_coords": [[[676.0, 1453.0], [703.0, 1453.0], [703.0, 1788.0], [676.0, 1788.0]], [[645.0, 1455.0], [671.0, 1455.0], [671.0, 1762.0], [645.0, 1762.0]]], "lines": ["座面が広くて確かにこれは", "座るハンモックですね．．．"]}, {"box": [616, 1605, 635, 1786], "vertical": true, "font_size": 24, "lines_coords": [[[616.0, 1605.0], [635.0, 1605.0], [635.0, 1786.0], [616.0, 1786.0]]], "lines": ["包まれ感はんはない"]}], "img_path": "00125.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1155, 148, 1216, 350], "vertical": true, "font_size": 28, "lines_coords": [[[1183.0, 148.0], [1216.0, 148.0], [1216.0, 230.0], [1183.0, 230.0]], [[1155.0, 153.0], [1179.0, 153.0], [1179.0, 346.0], [1155.0, 346.0]]], "lines": ["あれ？", "バイト募集してる"]}, {"box": [806, 288, 1010, 451], "vertical": false, "font_size": 79.0, "lines_coords": [[[811.0, 348.0], [990.0, 360.0], [984.0, 451.0], [806.0, 440.0]], [[834.0, 294.0], [1008.0, 288.0], [1010.0, 354.0], [836.0, 360.0]]], "lines": ["ちゃん！！", "アルバイ"]}, {"box": [811, 438, 1091, 521], "vertical": false, "font_size": 29.0, "lines_coords": [[[815.0, 438.0], [1091.0, 470.0], [1087.0, 502.0], [811.0, 470.0]], [[830.0, 470.0], [1078.0, 495.0], [1076.0, 521.0], [828.0, 496.0]]], "lines": ["アウトドアで調味のある方一緒に過ぎませんか？サーノドラムに「コーローコー」の問い合わせんですが、", "ブログにはその３ヶ月に渡しましたが、新しくはスタッフにお願い合わせください。"]}, {"box": [571, 142, 625, 504], "vertical": true, "font_size": 24, "lines_coords": [[[600.0, 144.0], [624.0, 144.0], [624.0, 504.0], [600.0, 504.0]], [[571.0, 146.0], [596.0, 146.0], [596.0, 496.0], [571.0, 496.0]]], "lines": ["あぁ今までアルバイトをしていた", "大学生の子が就職で辞めちゃって"]}, {"box": [1039, 796, 1069, 1088], "vertical": true, "font_size": 26, "lines_coords": [[[1040.0, 796.0], [1066.0, 796.0], [1066.0, 1087.0], [1040.0, 1087.0]]], "lines": ["実は私も転勤するんです"]}, {"box": [706, 412, 738, 564], "vertical": true, "font_size": 32, "lines_coords": [[[706.0, 412.0], [738.0, 412.0], [738.0, 564.0], [706.0, 564.0]]], "lines": ["むホントだ"]}, {"box": [168, 466, 196, 592], "vertical": true, "font_size": 27, "lines_coords": [[[168.0, 466.0], [195.0, 466.0], [195.0, 592.0], [168.0, 592.0]]], "lines": ["それに．．．"]}, {"box": [270, 802, 335, 1018], "vertical": true, "font_size": 30, "lines_coords": [[[298.0, 802.0], [335.0, 802.0], [335.0, 860.0], [298.0, 860.0]], [[270.0, 806.0], [294.0, 806.0], [294.0, 1016.0], [270.0, 1016.0]]], "lines": ["えっ", "そうなんですか！？"]}, {"box": [1134, 1468, 1226, 1717], "vertical": true, "font_size": 28, "lines_coords": [[[1200.0, 1470.0], [1224.0, 1470.0], [1224.0, 1691.0], [1200.0, 1691.0]], [[1168.0, 1470.0], [1192.0, 1470.0], [1192.0, 1717.0], [1168.0, 1717.0]], [[1134.0, 1468.0], [1170.0, 1468.0], [1170.0, 1550.0], [1134.0, 1550.0]]], "lines": ["結婚して新潟の方へ", "引っ越すのでそちらの", "店舗に"]}, {"box": [585, 1329, 616, 1560], "vertical": true, "font_size": 31, "lines_coords": [[[585.0, 1329.0], [616.0, 1329.0], [616.0, 1560.0], [585.0, 1560.0]]], "lines": ["せ関さぁん．．．"]}, {"box": [703, 1539, 768, 1715], "vertical": true, "font_size": 26, "lines_coords": [[[740.0, 1541.0], [766.0, 1541.0], [766.0, 1715.0], [740.0, 1715.0]], [[706.0, 1539.0], [733.0, 1539.0], [729.0, 1680.0], [703.0, 1680.0]]], "lines": ["おおめでとう", "ございます"]}], "img_path": "00126.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1140, 208, 1175, 343], "vertical": true, "font_size": 32, "lines_coords": [[[1140.0, 208.0], [1171.0, 208.0], [1175.0, 343.0], [1143.0, 343.0]]], "lines": ["ああのっ"]}, {"box": [360, 146, 418, 495], "vertical": true, "font_size": 24, "lines_coords": [[[391.0, 148.0], [416.0, 148.0], [416.0, 495.0], [391.0, 495.0]], [[360.0, 146.0], [384.0, 146.0], [384.0, 470.0], [360.0, 470.0]]], "lines": ["もし新潟に来ることがあったら", "お店に遊びに来て下さいね！！"]}, {"box": [187, 206, 249, 408], "vertical": true, "font_size": 30, "lines_coords": [[[215.0, 206.0], [249.0, 206.0], [249.0, 290.0], [215.0, 290.0]], [[187.0, 208.0], [213.0, 208.0], [215.0, 408.0], [189.0, 408.0]]], "lines": ["関さん", "新潟は遠過ぎです"]}, {"box": [581, 615, 615, 824], "vertical": true, "font_size": 32, "lines_coords": [[[581.0, 615.0], [613.0, 615.0], [613.0, 823.0], [581.0, 823.0]]], "lines": ["バイト募集か．．．"]}, {"box": [264, 776, 541, 909], "vertical": false, "font_size": 49.0, "lines_coords": [[[268.0, 843.0], [541.0, 875.0], [538.0, 909.0], [264.0, 877.0]], [[264.0, 787.0], [423.0, 776.0], [427.0, 840.0], [268.0, 851.0]]], "lines": ["プリトマス事業のある方一覧に集まさせておいてもスタッフに参加し合せください。", "お茉中"]}, {"box": [281, 877, 525, 928], "vertical": false, "font_size": 27, "lines_coords": [[[283.0, 877.0], [525.0, 901.0], [523.0, 928.0], [281.0, 903.0]]], "lines": ["ジャイクとホテルのメンバーに渡しましたが、新しくはスタッフにお願い合わせください。"]}], "img_path": "00127.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1150, 164, 1188, 463], "vertical": true, "font_size": 37, "lines_coords": [[[1151.0, 165.0], [1188.0, 165.0], [1188.0, 463.0], [1151.0, 463.0]]], "lines": ["中津川メイっス！"]}, {"box": [541, 348, 604, 571], "vertical": true, "font_size": 26, "lines_coords": [[[575.0, 350.0], [601.0, 350.0], [601.0, 571.0], [575.0, 571.0]], [[541.0, 348.0], [568.0, 348.0], [568.0, 541.0], [541.0, 541.0]]], "lines": ["改めましてやけど", "私は犬山あおい"]}, {"box": [153, 180, 182, 391], "vertical": true, "font_size": 27, "lines_coords": [[[153.0, 180.0], [180.0, 180.0], [180.0, 390.0], [153.0, 390.0]]], "lines": ["そんでこっちが．．"]}, {"box": [686, 791, 770, 1093], "vertical": true, "font_size": 38, "lines_coords": [[[731.0, 791.0], [770.0, 791.0], [770.0, 945.0], [731.0, 945.0]], [[686.0, 793.0], [723.0, 793.0], [723.0, 1093.0], [686.0, 1093.0]]], "lines": ["よろしく", "おねがいします！"]}, {"box": [481, 728, 562, 873], "vertical": true, "font_size": 81, "lines_coords": [[[481.0, 731.0], [562.0, 731.0], [562.0, 873.0], [481.0, 873.0]]], "lines": ["ガッ"]}, {"box": [997, 1274, 1068, 1485], "vertical": true, "font_size": 36, "lines_coords": [[[1025.0, 1275.0], [1065.0, 1275.0], [1068.0, 1425.0], [1029.0, 1425.0]], [[997.0, 1335.0], [1029.0, 1335.0], [1035.0, 1485.0], [1003.0, 1485.0]]], "lines": ["アリガトウ", "アリガトウ"]}, {"box": [1093, 1305, 1205, 1713], "vertical": true, "font_size": 34, "lines_coords": [[[1162.0, 1306.0], [1201.0, 1305.0], [1205.0, 1402.0], [1166.0, 1404.0]], [[1130.0, 1306.0], [1162.0, 1306.0], [1164.0, 1713.0], [1132.0, 1713.0]], [[1093.0, 1308.0], [1125.0, 1308.0], [1125.0, 1560.0], [1093.0, 1560.0]]], "lines": ["あたし", "部長をやらしてもらってます", "大垣と申します！！"]}, {"box": [341, 1303, 409, 1676], "vertical": true, "font_size": 26, "lines_coords": [[[378.0, 1305.0], [405.0, 1305.0], [405.0, 1676.0], [378.0, 1676.0]], [[341.0, 1305.0], [367.0, 1305.0], [367.0, 1582.0], [341.0, 1582.0]]], "lines": ["この度はウチのサークルを", "選んで頂いて誠に．．．"]}, {"box": [181, 1453, 227, 1629], "vertical": true, "font_size": 45, "lines_coords": [[[181.0, 1453.0], [226.0, 1453.0], [226.0, 1629.0], [181.0, 1629.0]]], "lines": ["腰低っ！"]}], "img_path": "00128.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [806, 375, 832, 487], "vertical": true, "font_size": 26, "lines_coords": [[[806.0, 376.0], [832.0, 376.0], [832.0, 487.0], [806.0, 487.0]]], "lines": ["うんうん"]}, {"box": [660, 305, 686, 455], "vertical": true, "font_size": 28, "lines_coords": [[[660.0, 305.0], [686.0, 305.0], [686.0, 455.0], [660.0, 455.0]]], "lines": ["野外活動部？"]}, {"box": [538, 129, 633, 429], "vertical": true, "font_size": 28, "lines_coords": [[[596.0, 129.0], [633.0, 129.0], [633.0, 187.0], [596.0, 187.0]], [[568.0, 131.0], [594.0, 131.0], [594.0, 429.0], [568.0, 429.0]], [[538.0, 131.0], [562.0, 131.0], [562.0, 380.0], [538.0, 380.0]]], "lines": ["いや", "部になるならちょっと名前", "変えたほうがいいか？"]}, {"box": [1141, 358, 1222, 663], "vertical": true, "font_size": 23, "lines_coords": [[[1198.0, 360.0], [1222.0, 360.0], [1222.0, 594.0], [1198.0, 594.0]], [[1168.0, 358.0], [1192.0, 358.0], [1192.0, 663.0], [1168.0, 663.0]], [[1141.0, 360.0], [1162.0, 360.0], [1162.0, 474.0], [1141.0, 474.0]]], "lines": ["これでついに野クルも", "晴れて部に昇格できる人数に", "なった訳だ"]}, {"box": [172, 368, 243, 690], "vertical": true, "font_size": 32, "lines_coords": [[[210.0, 371.0], [241.0, 371.0], [241.0, 690.0], [210.0, 690.0]], [[174.0, 369.0], [206.0, 369.0], [204.0, 652.0], [172.0, 652.0]]], "lines": ["あき残念やけど野クルは", "昨日まででおしまいや"]}, {"box": [1040, 858, 1190, 1207], "vertical": true, "font_size": 44, "lines_coords": [[[1149.0, 858.0], [1186.0, 858.0], [1186.0, 1190.0], [1149.0, 1190.0]], [[1085.0, 858.0], [1143.0, 858.0], [1143.0, 1207.0], [1085.0, 1207.0]], [[1040.0, 862.0], [1078.0, 862.0], [1078.0, 1155.0], [1040.0, 1155.0]]], "lines": ["部活化を機にここは", "「ゆる自転車部」", "になるんやからな"]}, {"box": [133, 780, 249, 1220], "vertical": true, "font_size": 96, "lines_coords": [[[133.0, 785.0], [228.0, 780.0], [249.0, 1215.0], [153.0, 1220.0]]], "lines": ["なん．．．だと．．．"]}, {"box": [1046, 1330, 1115, 1698], "vertical": true, "font_size": 29, "lines_coords": [[[1081.0, 1333.0], [1113.0, 1333.0], [1113.0, 1698.0], [1081.0, 1698.0]], [[1048.0, 1335.0], [1074.0, 1335.0], [1074.0, 1612.0], [1048.0, 1612.0]]], "lines": ["おばちゃんにロードバイクを", "もろてから思ったんや"]}], "img_path": "00129.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1057, 195, 1177, 481], "vertical": true, "font_size": 36, "lines_coords": [[[1134.0, 195.0], [1173.0, 195.0], [1177.0, 481.0], [1138.0, 481.0]], [[1102.0, 196.0], [1136.0, 196.0], [1132.0, 418.0], [1098.0, 418.0]], [[1061.0, 195.0], [1095.0, 195.0], [1091.0, 356.0], [1057.0, 356.0]]], "lines": ["たまにしか行けへん", "キャンプよりも", "これからは"]}, {"box": [189, 129, 266, 534], "vertical": true, "font_size": 32, "lines_coords": [[[226.0, 129.0], [258.0, 129.0], [262.0, 444.0], [230.0, 444.0]], [[189.0, 129.0], [221.0, 129.0], [225.0, 534.0], [193.0, 534.0]]], "lines": ["通勤通学でも楽しめる", "ゆるサイクリングの時代やて"]}, {"box": [1115, 603, 1220, 845], "vertical": true, "font_size": 33, "lines_coords": [[[1185.0, 603.0], [1220.0, 603.0], [1220.0, 690.0], [1185.0, 690.0]], [[1153.0, 605.0], [1185.0, 605.0], [1185.0, 845.0], [1153.0, 845.0]], [[1119.0, 603.0], [1151.0, 603.0], [1147.0, 793.0], [1115.0, 793.0]]], "lines": ["すでに", "なでしこちゃんにも", "根回しが済んで"]}, {"box": [808, 723, 902, 789], "vertical": false, "font_size": 40, "lines_coords": [[[808.0, 723.0], [888.0, 723.0], [888.0, 759.0], [808.0, 759.0]], [[825.0, 746.0], [901.0, 746.0], [901.0, 789.0], [825.0, 789.0]]], "lines": ["げきウマ", "おかし"]}, {"box": [166, 592, 231, 832], "vertical": true, "font_size": 28, "lines_coords": [[[198.0, 592.0], [226.0, 592.0], [228.0, 832.0], [200.0, 832.0]], [[168.0, 592.0], [195.0, 592.0], [193.0, 804.0], [166.0, 804.0]]], "lines": ["さらにリンちゃんも", "引き入れる予定や"]}, {"box": [1132, 1014, 1200, 1276], "vertical": true, "font_size": 32, "lines_coords": [[[1168.0, 1014.0], [1200.0, 1014.0], [1200.0, 1276.0], [1168.0, 1276.0]], [[1132.0, 1014.0], [1164.0, 1014.0], [1164.0, 1269.0], [1132.0, 1269.0]]], "lines": ["あき「野クルの残党は", "もうあんただけや．．．"]}, {"box": [690, 1119, 758, 1428], "vertical": true, "font_size": 30, "lines_coords": [[[723.0, 1119.0], [757.0, 1119.0], [757.0, 1235.0], [723.0, 1235.0]], [[691.0, 1121.0], [718.0, 1121.0], [718.0, 1426.0], [691.0, 1426.0]]], "lines": ["観念して", "ゆる自転車部に入り！や"]}, {"box": [144, 981, 244, 1338], "vertical": true, "font_size": 52, "lines_coords": [[[191.0, 988.0], [243.0, 988.0], [243.0, 1308.0], [191.0, 1308.0]]], "lines": ["謀ったなイヌ子－"]}], "img_path": "00130.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1108, 131, 1215, 656], "vertical": true, "font_size": 24, "lines_coords": [[[1188.0, 131.0], [1215.0, 131.0], [1213.0, 346.0], [1186.0, 346.0]], [[1164.0, 330.0], [1188.0, 330.0], [1188.0, 519.0], [1164.0, 519.0]], [[1136.0, 330.0], [1160.0, 330.0], [1160.0, 656.0], [1136.0, 656.0]], [[1108.0, 330.0], [1128.0, 330.0], [1128.0, 470.0], [1108.0, 470.0]]], "lines": ["まあ寸劇はさておき", "私もメイちゃんも", "自転車でキャンプに行くことも", "考えてるんよ"]}, {"box": [478, 148, 570, 525], "vertical": true, "font_size": 27, "lines_coords": [[[543.0, 150.0], [570.0, 150.0], [570.0, 450.0], [543.0, 450.0]], [[510.0, 148.0], [538.0, 148.0], [540.0, 523.0], [511.0, 523.0]], [[481.0, 148.0], [508.0, 148.0], [504.0, 275.0], [478.0, 275.0]]], "lines": ["自転車でキャンプといえば", "リンが去年まで自転車キャンパー", "だったから"]}, {"box": [133, 144, 190, 341], "vertical": true, "font_size": 24, "lines_coords": [[[163.0, 144.0], [187.0, 144.0], [187.0, 341.0], [163.0, 341.0]], [[133.0, 144.0], [157.0, 144.0], [157.0, 318.0], [133.0, 318.0]]], "lines": ["積み方のコツとか", "詳しいかもなぁ"]}, {"box": [1145, 765, 1223, 976], "vertical": true, "font_size": 24, "lines_coords": [[[1201.0, 766.0], [1222.0, 766.0], [1222.0, 905.0], [1201.0, 905.0]], [[1171.0, 766.0], [1198.0, 766.0], [1198.0, 976.0], [1171.0, 976.0]], [[1145.0, 765.0], [1170.0, 765.0], [1170.0, 975.0], [1145.0, 975.0]]], "lines": ["その前にまず", "メイのキャンプ道具", "どうにかしなきゃな"]}, {"box": [624, 410, 678, 622], "vertical": true, "font_size": 24, "lines_coords": [[[654.0, 412.0], [678.0, 412.0], [678.0, 596.0], [654.0, 596.0]], [[624.0, 410.0], [648.0, 410.0], [648.0, 622.0], [624.0, 622.0]]], "lines": ["ロードでキャンプ", "行ってみたいっス！"]}, {"box": [673, 720, 738, 982], "vertical": true, "font_size": 29, "lines_coords": [[[706.0, 720.0], [738.0, 720.0], [738.0, 982.0], [706.0, 982.0]], [[673.0, 721.0], [699.0, 721.0], [699.0, 973.0], [673.0, 973.0]]], "lines": ["あのもう一人部員の", "先輩がいるんスよね"]}, {"box": [1106, 1241, 1196, 1466], "vertical": true, "font_size": 25, "lines_coords": [[[1170.0, 1241.0], [1196.0, 1241.0], [1196.0, 1464.0], [1170.0, 1464.0]], [[1138.0, 1241.0], [1162.0, 1241.0], [1162.0, 1415.0], [1138.0, 1415.0]], [[1108.0, 1241.0], [1134.0, 1241.0], [1132.0, 1466.0], [1106.0, 1466.0]]], "lines": ["そういやバイト前に", "今日もカリフー