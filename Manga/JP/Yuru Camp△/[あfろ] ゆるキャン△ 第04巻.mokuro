0.0], [170.0, 1121.0], [138.0, 1121.0]]], "lines": ["クク：理由は", "それだけ", "じゃないぞ"]}, {"box": [1111, 1289, 1188, 1669], "vertical": true, "font_size": 33, "lines_coords": [[[1151.0, 1290.0], [1188.0, 1290.0], [1188.0, 1635.0], [1151.0, 1635.0]], [[1113.0, 1291.0], [1141.0, 1291.0], [1140.0, 1666.0], [1111.0, 1666.0]]], "lines": ["ひっくり返った斉藤と", "なでしこで挟む事により"]}, {"box": [307, 1263, 374, 1648], "vertical": true, "font_size": 26, "lines_coords": [[[345.0, 1265.0], [371.0, 1265.0], [371.0, 1648.0], [345.0, 1648.0]], [[307.0, 1265.0], [333.0, 1265.0], [333.0, 1471.0], [307.0, 1471.0]]], "lines": ["しまりんまでもひっくり返す", "計画なのだよ："]}, {"box": [161, 1516, 204, 1695], "vertical": true, "font_size": 39, "lines_coords": [[[161.0, 1516.0], [200.0, 1516.0], [204.0, 1695.0], [165.0, 1695.0]]], "lines": ["オセロか。"]}], "img_path": "0164.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [800, 123, 832, 262], "vertical": true, "font_size": 35, "lines_coords": [[[800.0, 123.0], [832.0, 123.0], [832.0, 262.0], [800.0, 262.0]]], "lines": ["うわっ！？"]}, {"box": [718, 148, 759, 513], "vertical": true, "font_size": 35, "lines_coords": [[[718.0, 148.0], [755.0, 148.0], [759.0, 513.0], [721.0, 513.0]]], "lines": ["イヌ子何だその頭！！"]}, {"box": [551, 165, 644, 485], "vertical": true, "font_size": 38, "lines_coords": [[[603.0, 166.0], [641.0, 166.0], [641.0, 410.0], [603.0, 410.0]], [[551.0, 165.0], [590.0, 165.0], [594.0, 485.0], [555.0, 485.0]]], "lines": ["あおいちゃん", "変な頭してるーっ"]}, {"box": [241, 127, 380, 172], "vertical": false, "font_size": 32, "lines_coords": [[[241.0, 140.0], [376.0, 127.0], [380.0, 159.0], [245.0, 172.0]]], "lines": ["ははは"]}, {"box": [1126, 473, 1202, 750], "vertical": true, "font_size": 32, "lines_coords": [[[1170.0, 474.0], [1201.0, 474.0], [1201.0, 748.0], [1170.0, 748.0]], [[1128.0, 474.0], [1160.0, 474.0], [1160.0, 750.0], [1128.0, 750.0]]], "lines": ["そうと分かったら", "斉藤を野クルに．．．"]}, {"box": [748, 727, 789, 856], "vertical": true, "font_size": 41, "lines_coords"