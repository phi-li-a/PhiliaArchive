0], [1239.0, 988.0], [1213.0, 988.0]]], "lines": ["泊まりの方が", "楽しそうだから"]}, {"box": [754, 491, 823, 709], "vertical": true, "font_size": 29, "lines_coords": [[[791.0, 491.0], [823.0, 491.0], [823.0, 680.0], [791.0, 680.0]], [[755.0, 493.0], [781.0, 493.0], [781.0, 708.0], [755.0, 708.0]]], "lines": ["それでも結構", "奮発したやーん"]}, {"box": [1153, 1001, 1222, 1246], "vertical": true, "font_size": 29, "lines_coords": [[[1188.0, 1001.0], [1220.0, 1001.0], [1222.0, 1246.0], [1190.0, 1246.0]], [[1156.0, 1003.0], [1188.0, 1003.0], [1185.0, 1207.0], [1153.0, 1207.0]]], "lines": ["寝袋休みに調べて", "注文しちゃった"]}, {"box": [836, 1325, 1155, 1358], "vertical": false, "font_size": 26, "lines_coords": [[[862.0, 1329.0], [1153.0, 1329.0], [1153.0, 1355.0], [862.0, 1355.0]]], "lines": ["アルビニスト８００"]}, {"box": [954, 1396, 1035, 1423], "vertical": false, "font_size": 27, "lines_coords": [[[954.0, 1396.0], [1035.0, 1396.0], [1035.0, 1423.0], [954.0, 1423.0]]], "lines": ["－１００"]}, {"box": [570, 1016, 630, 1254], "vertical": true, "font_size": 26, "lines_coords": [[[603.0, 1018.0], [630.0, 1018.0], [630.0, 1254.0], [603.0, 1254.0]], [[570.0, 1016.0], [596.0, 1016.0], [596.0, 1241.0], [570.0, 1241.0]]], "lines": ["私寒いの苦手だから", "これにしたんだけど"]}, {"box": [131, 1010, 215, 1200], "vertical": true, "font_size": 40, "lines_coords": [[[166.0, 1010.0], [215.0, 1010.0], [215.0, 1098.0], [166.0, 1098.0]], [[131.0, 1014.0], [163.0, 1014.0], [163.0, 1200.0], [131.0, 1200.0]]], "lines": ["おー", "どれどれー"]}, {"box": [140, 1310, 211, 1497], "vertical": true, "font_size": 32, "lines_coords": [[[172.0, 1310.0], [211.0, 1310.0], [211.0, 1410.0], [172.0, 1410.0]], [[140.0, 1312.0], [166.0, 1312.0], [166.0, 1496.0], [140.0, 1496.0]]], "lines": ["あき！！", "鼻血出とる！！"]}, {"box": [1149, 1470, 1333, 1788], "vertical": true, "font_size": 91, "lines_coords": [[[1239.0, 1473.0], [1333.0, 1477.0], [1321.0, 1786.0], [1226.0, 1783.0]], [[1149.0, 1470.0], [1237.0, 1470.0], [1241.0, 1788.0], [1153.0, 1788.0]]], "lines": ["よんまん", "ごせん！！"]}, {"box": [801, 1668, 1118, 1817], "vertical": false, "font_size": 32, "lines_coords": [[[811.0, 1670.0], [1027.0, 1670.0], [1027.0, 1708.0], [811.0, 1708.0]], [[804.0, 1719.0], [1053.0, 1721.0], [1053.0, 1755.0], [804.0, 1753.0]], [[806.0, 1756.0], [1096.0, 1756.0], [1096.0, 1783.0], [806.0, 1783.0]], [[808.0, 1786.0], [1025.0, 1786.0], [1025.0, 1813.0], [808.0, 1813.0]]], "lines": ["それら、ＤＯＯ（税込）", "冬山登山で使用できる", "コンパクト＆ライトウェイ", "ダウンシュラフです"]}, {"box": [495, 1351, 600, 1696], "vertical": true, "font_size": 27, "lines_coords": [[[568.0, 1351.0], [600.0, 1351.0], [600.0, 1696.0], [568.0, 1696.0]], [[532.0, 1355.0], [558.0, 1355.0], [558.0, 1693.0], [532.0, 1693.0]], [[495.0, 1355.0], [519.0, 1355.0], [519.0, 1590.0], [495.0, 1590.0]]], "lines": ["「アウトドアはいい経験に", "なるから」ってお父さんが", "お金出してくれて"]}, {"box": [680, 1637, 740, 1840], "vertical": true, "font_size": 55, "lines_coords": [[[680.0, 1642.0], [735.0, 1640.0], [740.0, 1818.0], [686.0, 1820.0]]], "lines": ["高っ！！"]}, {"box": [363, 1627, 401, 1773], "vertical": true, "font_size": 34, "lines_coords": [[[363.0, 1627.0], [397.0, 1627.0], [401.0, 1771.0], [367.0, 1771.0]]], "lines": ["いいなー"]}, {"box": [172, 1633, 205, 1747], "vertical": true, "font_size": 32, "lines_coords": [[[172.0, 1633.0], [204.0, 1633.0], [204.0, 1747.0], [172.0, 1747.0]]], "lines": ["ほわっ！？"]}], "img_path": "0009.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [367, 931, 543, 990], "vertical": false, "font_size": 33, "lines_coords": [[[367.0, 931.0], [543.0, 931.0], [543.0, 963.0], [367.0, 963.0]], [[367.0, 956.0], [485.0, 956.0], [485.0, 990.0], [367.0, 990.0]]], "lines": ["焚き火台買ったぜ", "しまりん！！"]}, {"box": [416, 1029, 450, 1065], "vertical": true, "font_size": 34, "lines_coords": [[[416.0, 1029.0], [450.0, 1029.0], [450.0, 1065.0], [416.0, 1065.0]]], "lines": ["お"]}, {"box": [748, 1592, 1096, 1622], "vertical": false, "font_size": 25, "lines_coords": [[[751.0, 1595.0], [1095.0, 1595.0], [1095.0, 1620.0], [751.0, 1620.0]]], "lines": ["すごい軽くて人気のやつじゃん"]}, {"box": [795, 1685, 1204, 1745], "vertical": false, "font_size": 25, "lines_coords": [[[796.0, 1687.0], [1200.0, 1685.0], [1200.0, 1711.0], [796.0, 1713.0]], [[800.0, 1717.0], [1196.0, 1717.0], [1196.0, 1741.0], [800.0, 1741.0]]], "lines": ["めっちゃコンパクトでいい！！（（＊｀）", "クリキャンはこいつで焚き火やるぜ！！"]}], "img_path": "0010.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1106, 142, 1166, 322], "vertical": true, "font_size": 25, "lines_coords": [[[1140.0, 148.0], [1164.0, 148.0], [1164.0, 298.0], [1140.0, 298.0]], [[1108.0, 142.0], [1134.0, 142.0], [1132.0, 322.0], [1106.0, 322.0]]], "lines": ["あの焚き火台", "確かにいいよな"]}, {"box": [973, 176, 1032, 391], "vertical": true, "font_size": 26, "lines_coords": [[[1003.0, 176.0], [1029.0, 176.0], [1031.0, 391.0], [1005.0, 391.0]], [[973.0, 178.0], [999.0, 178.0], [999.0, 330.0], [973.0, 330.0]]], "lines": ["市販の薪・割らずに", "載せられるし"]}, {"box": [1250, 496, 1288, 704], "vertical": true, "font_size": 32, "lines_coords": [[[1250.0, 496.0], [1282.0, 496.0], [1282.0, 703.0], [1250.0, 703.0]]], "lines": ["焚き火台には"]}, {"box": [579, 496, 619, 671], "vertical": true, "font_size": 34, "lines_coords": [[[583.0, 496.0], [616.0, 496.0], [613.0, 669.0], [579.0, 669.0]]], "lines": ["などがあり"]}, {"box": [450, 489, 528, 1063], "vertical": true, "font_size": 32, "lines_coords": [[[493.0, 493.0], [525.0, 493.0], [525.0, 1053.0], [493.0, 1053.0]], [[453.0, 489.0], [485.0, 489.0], [485.0, 1031.0], [453.0, 1031.0]]], "lines": ["不安定で鍋が載せられない焚き火台では", "「ゴトク」や「トライポッド」を使います。"]}, {"box": [153, 847, 185, 956], "vertical": true, "font_size": 32, "lines_coords": [[[153.0, 847.0], [185.0, 847.0], [185.0, 956.0], [153.0, 956.0]]], "lines": ["トライヤッ！！"]}, {"box": [806, 924, 1273, 1026], "vertical": false, "font_size": 28, "lines_coords": [[[832.0, 926.0], [1070.0, 926.0], [1070.0, 952.0], [832.0, 952.0]], [[819.0, 958.0], [1246.0, 958.0], [1246.0, 990.0], [819.0, 990.0]], [[806.0, 995.0], [1273.0, 995.0], [1273.0, 1021.0], [806.0, 1021.0]], [[1063.0, 926.0], [1256.0, 926.0], [1256.0, 952.0], [1063.0, 952.0]]], "lines": ["高い通気性で、", "燃焼効率がよく使える料理の", "焚き火に長けた物煮炊きに長けた物", "頑丈で重い鍋も"]}, {"box": [1136, 1177, 1200, 1490], "vertical": true, "font_size": 26, "lines_coords": [[[1171.0, 1179.0], [1198.0, 1179.0], [1198.0, 1376.0], [1171.0, 1376.0]], [[1136.0, 1177.0], [1162.0, 1177.0], [1162.0, 1490.0], [1136.0, 1490.0]]], "lines": ["私の焚き火台は", "煮炊きと焼き肉向きかな"]}, {"box": [649, 976, 768, 1078], "vertical": false, "font_size": 32, "lines_coords": [[[665.0, 976.0], [751.0, 976.0], [751.0, 1005.0], [665.0, 1005.0]], [[652.0, 1010.0], [766.0, 1010.0], [766.0, 1042.0], [652.0, 1042.0]], [[652.0, 1044.0], [766.0, 1044.0], [766.0, 1078.0], [652.0, 1078.0]]], "lines": ["軽量で", "収納性に", "長けた物"]}, {"box": [796, 1500, 858, 1661], "vertical": true, "font_size": 27, "lines_coords": [[[826.0, 1500.0], [853.0, 1500.0], [858.0, 1661.0], [832.0, 1661.0]], [[796.0, 1507.0], [823.0, 1507.0], [823.0, 1625.0], [796.0, 1625.0]]], "lines": ["前は割らないと", "入らないし"]}], "img_path": "0011.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [163, 144, 245, 320], "vertical": true, "font_size": 37, "lines_coords": [[[200.0, 146.0], [241.0, 144.0], [245.0, 253.0], [204.0, 255.0]], [[166.0, 146.0], [198.0, 146.0], [195.0, 320.0], [163.0, 320.0]]], "lines": ["教頭と", "鳥羽先生だ"]}, {"box": [1081, 1426, 1183, 1625], "vertical": true, "font_size": 28, "lines_coords": [[[1155.0, 1430.0], [1181.0, 1430.0], [1181.0, 1599.0], [1155.0, 1599.0]], [[1119.0, 1428.0], [1145.0, 1428.0], [1145.0, 1625.0], [1119.0, 1625.0]], [[1081.0, 1426.0], [1113.0, 1426.0], [1113.0, 1543.0], [1081.0, 1543.0]]], "lines": ["鳥羽先生って", "誰かに似てるん", "だよな．．．"]}, {"box": [399, 1475, 472, 1635], "vertical": true, "font_size": 34, "lines_coords": [[[436.0, 1475.0], [472.0, 1475.0], [472.0, 1545.0], [436.0, 1545.0]], [[399.0, 1477.0], [431.0, 1477.0], [431.0, 1635.0], [399.0, 1635.0]]], "lines": ["．．．．．", "誰だっけ？"]}], "img_path": "0012.jpg"}, {"version": "0.1.6", "