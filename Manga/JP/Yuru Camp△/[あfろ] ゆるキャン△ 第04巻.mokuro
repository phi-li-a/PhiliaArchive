のだが、"]}, {"box": [727, 956, 850, 1616], "vertical": true, "font_size": 48, "lines_coords": [[[796.0, 956.0], [847.0, 956.0], [847.0, 1616.0], [796.0, 1616.0]], [[727.0, 960.0], [772.0, 960.0], [772.0, 1290.0], [727.0, 1290.0]]], "lines": ["非常食ならカンパンなどの方が", "適している筈だ"]}, {"box": [618, 960, 684, 1603], "vertical": true, "font_size": 51, "lines_coords": [[[624.0, 960.0], [675.0, 960.0], [675.0, 1595.0], [624.0, 1595.0]]], "lines": ["ではこれは何用のツチなのか"]}, {"box": [129, 1288, 245, 1764], "vertical": true, "font_size": 60, "lines_coords": [[[189.0, 1288.0], [245.0, 1288.0], [245.0, 1732.0], [189.0, 1732.0]], [[129.0, 1303.0], [193.0, 1303.0], [193.0, 1764.0], [129.0, 1764.0]]], "lines": ["さらに考えてみると", "つの仮説が浮かんだ"]}], "img_path": "0150.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1098, 125, 1217, 472], "vertical": true, "font_size": 56, "lines_coords": [[[1158.0, 125.0], [1216.0, 125.0], [1216.0, 472.0], [1158.0, 472.0]], [[1104.0, 131.0], [1158.0, 133.0], [1153.0, 373.0], [1098.0, 371.0]]], "lines": ["これは「非常用」", "ではあるが"]}, {"box": [120, 131, 241, 517], "vertical": true, "font_size": 59, "lines_coords": [[[181.0, 131.0], [241.0, 131.0], [236.0, 517.0], [176.0, 517.0]], [[123.0, 133.0], [181.0, 133.0], [178.0, 493.0], [120.0, 493.0]]], "lines": ["「非常食ではない」", "のではないかと"]}, {"box": [1110, 567, 1213, 993], "vertical": true, "font_size": 45, "lines_coords": [[[1166.0, 601.0], [1211.0, 601.0], [1211.0, 881.0], [1166.0, 881.0]], [[1110.0, 588.0], [1155.0, 588.0], [1158.0, 993.0], [1113.0, 993.0]]], "lines": ["ご存知のとおり", "野クルの部室は狭く、"]}, {"box": [719, 567, 828, 1053], "vertical": true, "font_size": 44, "lines_coords": [[[776.0, 579.0], [821.0, 579.0], [821.0, 1008.0], [776.0, 1008.0]], [[723.0, 571.0], [766.0, 571.0], [766.0, 1053.0], [723.0, 1053.0]]], "lines": ["こんな所で野生動物に", "襲われたら逃げ場が無い"]}, {"box": [558, 574, 663, 972], "vertical": true, "font_size": 40, "lines_coords": [[[615.0, 583.0], [654.0, 583.0], [654.0, 945.0], [615.0, 945.0]], [[560.0, 579.0], [600.0, 579.0], [600.0, 834.0], [560.0, 834.0]]], "lines": ["そうこれは動物の", "注意を逸らし"]}, {"box": [133, 826, 239, 1374], "vertical": true, "font_size": 49, "lines_coords": [[[185.0, 826.0], [238.0, 826.0], [238.0, 1198.0], [185.0, 1198.0]], [[135.0, 826.0], [180.0, 826.0], [180.0, 1374.0], [135.0, 1374.0]]], "lines": ["生き延びるための", "非常用ツナ缶だったのだ！！"]}, {"box": [1084, 1436, 1196, 1719], "vertical": true, "font_size": 34, "lines_coords": [[[1153.0, 1436.0], [1196.0, 1436.0], [1196.0, 1507.0], [1153.0, 1507.0]], [[1121.0, 1438.0], [1153.0, 1438.0], [1153.0, 1719.0], [1121.0, 1719.0]], [[1085.0, 1440.0], [1111.0, 1440.0], [1111.0, 1625.0], [1085.0, 1625.0]]], "lines": ["いや", "ツナ缶オイルランプ", "作ろうとして"]}, {"box": [648, 1438, 729, 1680], "vertical": true, "font_size": 35, "lines_coords": [[[691.0, 1440.0], [729.0, 1440.0], [729.0, 1680.0], [691.0, 1680.0]], [[650.0, 1438.0], [682.0, 1438.0], [680.0, 1680.0], [648.0, 1680.0]]], "lines": ["ほったらかしに", "なってただけだ"]}, {"box": [127, 1410, 168, 1546], "vertical": true, "font_size": 41, "lines_coords": [[[127.0, 1410.0], [168.0, 1410.0], [168.0, 1486.0], [127.0, 1486.0]]], "lines": ["あー"]}], "img_path": "0151.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1126, 170, 1211, 502], "vertical": true, "font_size": 36, "lines_coords": [[[1179.0, 170.0], [1211.0, 170.0], [1211.0, 502.0], [1179.0, 502.0]], [[1126.0, 170.0], [1164.0, 170.0], [1164.0, 429.0], [1126.0, 429.0]]], "lines": ["そういえば甲州市に", "心霊スポットの"]}, {"box": [1040, 268, 1078, 680], "vertical": true, "font_size": 36, "lines_coords": [[[1040.0, 268.0], [1078.0, 268.0], [1078.0, 680.0], [1040.0, 680.0]]], "lines": ["キャンプ場があってなー"]}, {"box": [560, 76, 1016, 103], "vertical": false, "font_size": 27, "lines_coords": [[[560.0, 76.0], [1016.0, 76.0], [1016.0, 103.0], [560.0, 103.0]]], "lines": ["放課後１４本当にあった怖い話"]}, {"box": [398, 238, 523, 669], "vertical": true, "font_size": 50, "lines_coords": [[[459.0, 238.0], [523.0, 238.0], [523.0, 538.0], [459.0, 538.0]], [[399.0, 253.0], [436.0, 253.0], [436.0, 669.0], [399.0, 669.0]]], "lines": ["やめてー！！", "あおいちゃんやめてー！！"]}, {"box": [146, 469, 230, 753], "vertical": true, "font_size": 36, "lines_coords": [[[191.0, 470.0], [230.0, 470.0], [230.0, 753.0], [191.0, 753.0]], [[148.0, 472.0], [180.0, 472.0], [180.0, 658.0], [148.0, 658.0]]], "lines": ["何やこういう話", "苦手なん？"]}, {"box": [1175, 904, 1212, 1246], "vertical": true, "font_size": 32, "lines_coords": [[[1177.0, 905.0], [1209.0, 905.0], [1209.0, 1246.0], [1177.0, 1246.0]]], "lines": ["キャンプの怖い話か？"]}, {"box": [723, 1076, 804, 1316], "vertical": true, "font_size": 38, "lines_coords": [[[766.0, 1076.0], [804.0, 1076.0], [804.0, 1284.0], [766.0, 1284.0]], [[723.0, 1081.0], [761.0, 1081.0], [761.0, 1316.0], [723.0, 1316.0]]], "lines": ["そんなら私も", "一つ知ってるぞ"]}, {"box": [585, 978, 664, 1220], "vertical": true, "font_size": 34, "lines_coords": [[[626.0, 980.0], [663.0, 980.0], [663.0, 1220.0], [626.0, 1220.0]], [[585.0, 978.0], [616.0, 978.0], [616.0, 1185.0], [585.0, 1185.0]]], "lines": ["夜通し焚き火を", "楽しんでいた"]}, {"box": [150, 911, 188, 1326], "vertical": true, "font_size": 27, "lines_coords": [[[153.0, 916.0], [180.0, 916.0], [180.0, 1325.0], [153.0, 1325.0]]], "lines": ["とあるキャンパー達の話だ"]}, {"box": [718, 1546, 815, 1710], "vertical": true, "font_size": 48, "lines_coords": [[[768.0, 1548.0], [813.0, 1548.0], [813.0, 1710.0], [768.0, 1710.0]], [[718.0, 1546.0], [770.0, 1546.0], [770.0, 1635.0], [718.0, 1635.0]]], "lines": ["やーめー", "てー"]}], "img_path": "0152.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1104, 133, 1209, 538], "vertical": true, "font_size": 51, "lines_coords": [[[1155.0, 133.0], [1205.0, 133.0], [1209.0, 538.0], [1158.0, 538.0]], [[1104.0, 135.0], [1155.0, 135.0], [1155.0, 534.0], [1104.0, 534.0]]], "lines": ["彼らが焚き火を終え", "テントで寝ていると、"]}, {"box": [133, 131, 289, 488], "vertical": true, "font_size": 48, "lines_coords": [[[241.0, 136.0], [288.0, 136.0], [288.0, 315.0], [241.0, 315.0]], [[187.0, 131.0], [240.0, 131.0], [236.0, 487.0], [183.0, 487.0]], [[135.0, 135.0], [180.0, 135.0], [180.0, 444.0], [135.0, 444.0]]], "lines": ["明け方頃", "隣のキャンパーに", "突然起こされた"]}, {"box": [1165, 612, 1212, 1198], "vertical": true, "font_size": 37, "lines_coords": [[[1168.0, 613.0], [1205.0, 613.0], [1205.0, 1198.0], [1168.0, 1198.0]]], "lines": ["彼の剣幕に何事かと聞いてみると"]}, {"box": [712, 607, 810, 1042], "vertical": true, "font_size": 48, "lines_coords": [[[761.0, 611.0], [806.0, 611.0], [806.0, 1042.0], [761.0, 1042.0]], [[712.0, 607.0], [763.0, 607.0], [763.0, 980.0], [712.0, 980.0]]], "lines": ["穴だらけの布を見せられ", "こう言われたんだと"]}, {"box": [618, 611, 661, 1263], "vertical": true, "font_size": 43, "lines_coords": [[[618.0, 611.0], [661.0, 611.0], [661.0, 1263.0], [618.0, 1263.0]]], "lines": ["「お前らの焚き火で火の粉が飛んで」"]}, {"box": [127, 611, 223, 1203], "vertical": true, "font_size": 42, "lines_coords": [[[176.0, 611.0], [221.0, 611.0], [221.0, 1203.0], [176.0, 1203.0]], [[127.0, 613.0], [166.0, 613.0], [166.0, 817.0], [127.0, 817.0]]], "lines": ["「テントが穴だらけになっただろう", "弁償しろ。」"]}, {"box": [981, 1344, 1177, 1678], "vertical": true, "font_size": 36, "lines_coords": [[[1140.0, 1346.0], [1175.0, 1346.0], [1177.0, 1518.0], [1141.0, 1518.0]], [[1095.0, 1344.0], [1132.0, 1344.0], [1136.0, 1588.0], [1098.0, 1588.0]]], "lines": ["結局彼らは", "テントの弁償で"]}, {"box": [980, 1445, 1057, 1685], "vertical": true, "font_size": 32, "lines_coords": [[[1020.0, 1447.0], [1051.0, 1447.0], [1051.0, 1685.0], [1020.0, 1685.0]], [[980.0, 1447.0], [1012.0, 1447.0], [1012.0, 1653.0], [980.0, 1653.0]]], "lines": ["数万円払う事に", "なったそうな"]}, {"box": [713, 1336, 791, 1633], "vertical": true, "font_size": 35, "lines_coords": [[[753.0, 1336.0], [791.0, 1336.0], [791.0, 1546.0], [753.0, 1546.0]], [[714.0, 1338.0], [746.0, 1338.0], [746.0, 1620.0], [714.0, 1620.0]]], "lines": ["それリアルに", "怖い事例やないか。"]}, {"box": [229, 1356, 301, 1670], "vertical": true, "font_size": 30, "lines_coords": [[[264.0, 1357.0], [298.0, 1357.0], [300.0, 1576.0], [266.0, 1576.0]], [[230.0, 1361.0], [256.0, 1361.0], [256.0, 1670.0], [230.0, 1670.0]]], "lines": ["聞こえないっ！！", "何も聞こえないもん！！"]}], "img_path": "0153.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [628, 73, 1222, 105], "vertical": false, "font_size": 32, "lines_coords": [[[628.0, 73.0], [1222.0, 73.0], [1222.0, 105.0], [628.0, 105.0]]], "lines": ["放課後１５．本当に怖いシネマフェス"]}, {"box": [1073, 148, 1193, 633], "vertical": true, "font_size": 34, "lines_coords": [[[1158.0, 151.0], [1190.0, 151.0], [1190.0, 630.0], [1158.0, 630.0]], [[1110.0, 148.0], [1149.0, 148.0], [1153.0, 633.0], [1113.0, 633.0]], [[1074.0, 151.0], [1106.0, 151.0], [1106.0, 360.0], [1074.0, 360.0]]], "lines": ["最近は野外ロックフェスならぬ", "野外フィルムフェスなんてのが", "あるらしいな"]}, {"box": [176, 525, 258, 750], "vertical": true, "font_size": 32, "lines_coords": [[[219.0, 525.0], [256.0, 525.0], [256.0, 714.0], [219.0, 714.0]], [[178.0, 530.0], [204.0, 530.0], [204.0, 748.0], [178.0, 748.0]]], "lines": ["そんなのも", "あるんやなー"]}, {"box": [352, 918, 562, 1166], "vertical": true, "font_size": 45, "lines_coords": [[[521.0, 920.0], [560.0, 920.0], [556.0, 1123.0], [517.0, 1123.0]], [[468.0, 918.0], [513.0, 918.0], [508.0, 1166.0], [463.0, 1166.0]], [[403.0, 920.0], [461.0, 920.0], [461.0, 1128.0], [403.0, 1128.0]], [[352.0, 920.0], [390.0, 920.0], [390.0, 1121.0], [352.0, 1121.0]]], "lines": ["でも野外で", "上映すんなら", "ホラーに", "限るよなぁ"]}, {"box": [669, 1248, 745, 1449], "vertical": true, "font_size": 32, "lines_coords": [[[712.0, 1250.0], [744.0, 1250.0], [744.0, 1449.0], [712.0, 1449.0]], [[669.0, 1248.0], [701.0, 1248.0], [701.0, 1417.0], [669.0, 1417.0]]], "lines": ["ロックフェス", "みたいやー"]}, {"box": [1070, 1203, 1188, 1755], "vertical": true, "font_size": 32, "lines_coords": [[[1155.0, 1207.0], [1186.0, 1207.0], [1186.0, 1755.0], [1155.0, 1755.0]], [[1111.0, 1209.0], [1143.0, 1209.0], [1143.0, 1653.0], [1111.0, 1653.0]], [[1070.0, 1209.0], [1102.0, 1209.0], [1102.0, 1445.0], [1070.0, 1445.0]]], "lines": ["会場に何カ所もスクリーンがあって", "オールナイトで色