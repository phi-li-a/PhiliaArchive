ertical": true, "font_size": 34, "lines_coords": [[[1149.0, 984.0], [1183.0, 984.0], [1185.0, 1143.0], [1151.0, 1143.0]], [[1110.0, 982.0], [1143.0, 982.0], [1145.0, 1203.0], [1111.0, 1203.0]], [[1074.0, 984.0], [1108.0, 984.0], [1108.0, 1113.0], [1074.0, 1113.0]]], "lines": ["相変わらず", "ウマそうに食い", "やがるぜ"]}, {"box": [201, 969, 543, 1032], "vertical": false, "font_size": 24, "lines_coords": [[[206.0, 971.0], [532.0, 971.0], [532.0, 995.0], [206.0, 995.0]], [[206.0, 1003.0], [525.0, 1003.0], [525.0, 1027.0], [206.0, 1027.0]]], "lines": ["たすけて！！なでしこの食欲に", "おやつの残量はもうゼロよ！！"]}, {"box": [984, 1691, 1031, 1771], "vertical": true, "font_size": 36, "lines_coords": [[[995.0, 1691.0], [1031.0, 1696.0], [1020.0, 1771.0], [984.0, 1766.0]]], "lines": ["カシャ"]}, {"box": [247, 1600, 665, 1660], "vertical": false, "font_size": 26, "lines_coords": [[[247.0, 1601.0], [585.0, 1601.0], [585.0, 1627.0], [247.0, 1627.0]], [[249.0, 1631.0], [665.0, 1631.0], [665.0, 1657.0], [249.0, 1657.0]]], "lines": ["なんてことなの！！このままでは", "ちくわ（犬）がおやつにされてしまうわ！！"]}, {"box": [265, 1721, 583, 1754], "vertical": false, "font_size": 26, "lines_coords": [[[268.0, 1725.0], [575.0, 1725.0], [575.0, 1751.0], [268.0, 1751.0]]], "lines": ["あ、私ももうすぐ着くよー"]}], "img_path": "0055.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1169, 157, 1198, 267], "vertical": true, "font_size": 26, "lines_coords": [[[1170.0, 159.0], [1196.0, 159.0], [1196.0, 266.0], [1170.0, 266.0]]], "lines": ["めちゃせた"]}, {"box": [609, 123, 675, 318], "vertical": true, "font_size": 31, "lines_coords": [[[645.0, 123.0], [673.0, 123.0], [675.0, 318.0], [646.0, 318.0]], [[609.0, 123.0], [641.0, 123.0], [641.0, 296.0], [609.0, 296.0]]], "lines": ["私はおせんべい", "持って来たよ"]}, {"box": [562, 251, 594, 369], "vertical": true, "font_size": 31, "lines_coords": [[[562.0, 251.0], [594.0, 251.0], [594.0, 369.0], [562.0, 369.0]]], "lines": ["食べる？"]}, {"box": [185, 131, 217, 279], "vertical": true, "font_size": 28, "lines_coords": [[[185.0, 131.0], [213.0, 131.0], [217.0, 279.0], [189.0, 279.0]]], "lines": ["うん食べる"]}, {"box": [1104, 993, 1166, 1179], "vertical": true, "font_size": 29, "lines_coords": [[[1134.0, 993.0], [1166.0, 993.0], [1166.0, 1128.0], [1134.0, 1128.0]], [[1104.0, 997.0], [1130.0, 997.0], [1130.0, 1179.0], [1104.0, 1179.0]]], "lines": ["はぁ～～～", "いい所だよねぇ"]}, {"box": [1152, 1288, 1216, 1552], "vertical": true, "font_size": 26, "lines_coords": [[[1188.0, 1288.0], [1215.0, 1288.0], [1215.0, 1548.0], [1188.0, 1548.0]], [[1153.0, 1288.0], [1179.0, 1288.0], [1179.0, 1464.0], [1153.0, 1464.0]]], "lines": ["リンちゃんに聞いて", "よかったよ！！"]}, {"box": [817, 1312, 853, 1417], "vertical": true, "font_size": 32, "lines_coords": [[[817.0, 1312.0], [849.0, 1312.0], [853.0, 1417.0], [821.0, 1417.0]]], "lines": ["さすが！！"]}, {"box": [286, 927, 348, 1167], "vertical": true, "font_size": 26, "lines_coords": [[[320.0, 930.0], [346.0, 930.0], [346.0, 1115.0], [320.0, 1115.0]], [[286.0, 928.0], [313.0, 928.0], [313.0, 1166.0], [286.0, 1166.0]]], "lines": ["富士山も見えて", "芝生で気持ちいいし"]}, {"box": [159, 1289, 228, 1527], "vertical": true, "font_size": 28, "lines_coords": [[[195.0, 1290.0], [226.0, 1290.0], [226.0, 1470.0], [195.0, 1470.0]], [[159.0, 1290.0], [185.0, 1290.0], [185.0, 1526.0], [159.0, 1526.0]]], "lines": ["知ってたのは", "うちのお爺ちゃん"]}, {"box": [530, 1583, 561, 1762], "vertical": true, "font_size": 26, "lines_coords": [[[530.0, 1584.0], [556.0, 1584.0], [556.0, 1760.0], [530.0, 1760.0]]], "lines": ["私じゃないよ"]}], "img_path": "0056.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1121, 136, 1190, 412], "vertical": true, "font_size": 26, "lines_coords": [[[1160.0, 136.0], [1186.0, 136.0], [1186.0, 412.0], [1160.0, 412.0]], [[1121.0, 136.0], [1147.0, 136.0], [1147.0, 320.0], [1121.0, 320.0]]], "lines": ["キャンプ道具くれた", "お爺ちゃん？"]}, {"box": [225, 172, 273, 260], "vertical": true, "font_size": 48, "lines_coords": [[[225.0, 172.0], [273.0, 172.0], [273.0, 260.0], [225.0, 260.0]]], "lines": ["うん"]