, 1503.0], [236.0, 1591.0], [187.0, 1593.0]], [[144.0, 1509.0], [181.0, 1509.0], [181.0, 1770.0], [144.0, 1770.0]]], "lines": ["あら", "なつかしいわぁ"]}], "img_path": "0174.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1125, 120, 1181, 320], "vertical": true, "font_size": 26, "lines_coords": [[[1156.0, 120.0], [1181.0, 120.0], [1181.0, 320.0], [1156.0, 320.0]], [[1125.0, 120.0], [1151.0, 120.0], [1151.0, 247.0], [1125.0, 247.0]]], "lines": ["煮込みカレーめん", "温まるわぁ"]}, {"box": [697, 131, 780, 296], "vertical": true, "font_size": 23, "lines_coords": [[[755.0, 133.0], [780.0, 133.0], [780.0, 296.0], [755.0, 296.0]], [[729.0, 135.0], [750.0, 135.0], [750.0, 249.0], [729.0, 249.0]], [[697.0, 131.0], [723.0, 131.0], [723.0, 251.0], [697.0, 251.0]]], "lines": ["この年になると", "キャンプは", "春先が一番"]}, {"box": [669, 208, 690, 346], "vertical": true, "font_size": 23, "lines_coords": [[[669.0, 208.0], [690.0, 208.0], [690.0, 346.0], [669.0, 346.0]]], "lines": ["いいわねぇ"]}, {"box": [474, 198, 500, 303], "vertical": true, "font_size": 26, "lines_coords": [[[474.0, 198.0], [500.0, 198.0], [500.0, 303.0], [474.0, 303.0]]], "lines": ["そうねぇ"]}, {"box": [219, 123, 283, 316], "vertical": true, "font_size": 26, "lines_coords": [[[253.0, 123.0], [279.0, 123.0], [281.0, 316.0], [255.0, 316.0]], [[219.0, 125.0], [245.0, 125.0], [245.0, 290.0], [219.0, 290.0]]], "lines": ["ボカボカ陽気で", "いいわよねぇ"]}, {"box": [148, 1305, 234, 1565], "vertical": true, "font_size": 36, "lines_coords": [[[193.0, 1305.0], [230.0, 1305.0], [234.0, 1565.0], [196.0, 1565.0]], [[151.0, 1305.0], [185.0, 1305.0], [181.0, 1455.0], [148.0, 1455.0]]], "lines": ["それはめっちゃ", "ありそう"]}], "img_path": "0175.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1149, 152, 1217, 493], "vertical": true, "font_size": 26, "lines_coords": [[[1188.0, 153.0], [1215.0, 153.0], [1215.0, 307.0], [1188.0, 307.0]], [[1149.0, 153.0], [1175.0, 153.0], [1175.0, 493.0], [1149.0, 493.0]]], "lines": ["国