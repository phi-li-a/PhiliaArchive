{"box": [853, 187, 879, 412], "vertical": true, "font_size": 26, "lines_coords": [[[853.0, 187.0], [879.0, 187.0], [879.0, 412.0], [853.0, 412.0]]], "lines": ["危険だと思います。"]}, {"box": [1147, 528, 1214, 684], "vertical": true, "font_size": 29, "lines_coords": [[[1181.0, 528.0], [1213.0, 528.0], [1213.0, 682.0], [1181.0, 682.0]], [[1147.0, 528.0], [1173.0, 528.0], [1173.0, 684.0], [1147.0, 684.0]]], "lines": ["火事にでも", "なったら．．．"]}, {"box": [770, 836, 803, 941], "vertical": true, "font_size": 32, "lines_coords": [[[770.0, 840.0], [802.0, 840.0], [802.0, 941.0], [770.0, 941.0]]], "lines": ["．．．んん"]}, {"box": [574, 585, 695, 894], "vertical": true, "font_size": 32, "lines_coords": [[[658.0, 585.0], [695.0, 585.0], [695.0, 795.0], [658.0, 795.0]], [[615.0, 585.0], [648.0, 585.0], [650.0, 894.0], [616.0, 894.0]], [[577.0, 586.0], [603.0, 586.0], [603.0, 856.0], [577.0, 856.0]]], "lines": ["最初のうちは", "あたしが立ち会って", "片付けの仕方とか"]}, {"box": [75, 575, 155, 990], "vertical": true, "font_size": 34, "lines_coords": [[[114.0, 575.0], [151.0, 575.0], [155.0, 926.0], [118.0, 926.0]], [[75.0, 577.0], [106.0, 577.0], [108.0, 990.0], [76.0, 990.0]]], "lines": ["消火器の使い方を指導", "しましたから大丈夫ですよ"]}, {"box": [1147, 1113, 1218, 1359], "vertical": true, "font_size": 34, "lines_coords": [[[1186.0, 1113.0], [1218.0, 1113.0], [1218.0, 1359.0], [1186.0, 1359.0]], [[1147.0, 1115.0], [1179.0, 1115.0], [1179.0, 1331.0], [1147.0, 1331.0]]], "lines": ["火を使う時は一声", "かけてくれるし"]}, {"box": [1072, 1254, 1115, 1389], "vertical": true, "font_size": 34, "lines_coords": [[[1072.0, 1254.0], [1111.0, 1254.0], [1115.0, 1389.0], [1076.0, 1389.0]]], "lines": ["な大垣"]}, {"box": [914, 1113, 957, 1335], "vertical": true, "font_size": 39, "lines_coords": [[[915.0, 1115.0], [954.0, 1115.0], [954.0, 1333.0], [915.0, 1333.0]]], "lines": ["ういっす！！"]}, {"box": [752, 1090, 822, 1404], "vertical": true, "font_size": 30, "lines_coords": [[[787.0, 1091.0], [819.0, 1091.0], [821.0, 1402.0], [789.0, 1402.0]], [[753.0, 1093.0], [780.0, 1093.0], [780.0, 1338.0], [753.0, 1338.0]]], "lines": ["まぁ全く心配じゃない", "訳ではないですが"]}, {"box": [615, 1098, 686, 1408], "vertical": true, "font_size": 29, "lines_coords": [[[654.0, 1100.0], [686.0, 1100.0], [686.0, 1348.0], [654.0, 1348.0]], [[615.0, 1098.0], [641.0, 1098.0], [645.0, 1408.0], [618.0, 1408.0]]], "lines": ["あたしも他の部の", "顧問がありますしねぇ"]}, {"box": [478, 1095, 543, 1415], "vertical": true, "font_size": 26, "lines_coords": [[[511.0, 1095.0], [538.0, 1095.0], [538.0, 1413.0], [511.0, 1413.0]], [[478.0, 1095.0], [502.0, 1095.0], [502.0, 1400.0], [478.0, 1400.0]]], "lines": ["そうだ、いっそ鳥羽先生が", "監督されたらどうです？"]}, {"box": [67, 1196, 123, 1327], "vertical": true, "font_size": 56, "lines_coords": [[[67.0, 1196.0], [123.0, 1196.0], [123.0, 1327.0], [67.0, 1327.0]]], "lines": ["へっ！？"]}, {"box": [886, 1603, 918, 1725], "vertical": true, "font_size": 32, "lines_coords": [[[886.0, 1603.0], [918.0, 1603.0], [918.0, 1725.0], [886.0, 1725.0]]], "lines": ["ですが．．"]}], "img_path": "0026.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1207, 148, 1278, 461], "vertical": true, "font_size": 30, "lines_coords": [[[1245.0, 148.0], [1276.0, 148.0], [1276.0, 461.0], [1245.0, 461.0]], [[1209.0, 151.0], [1237.0, 151.0], [1235.0, 431.0], [1207.0, 431.0]]], "lines": ["そうそう確か先生まだ", "フリーでしたよね！？"]}, {"box": [618, 134, 691, 478], "vertical": true, "font_size": 34, "lines_coords": [[[654.0, 135.0], [691.0, 135.0], [691.0, 373.0], [654.0, 373.0]], [[618.0, 135.0], [650.0, 135.0], [650.0, 478.0], [618.0, 478.0]]], "lines": ["え！？先生が顧問", "やってくれるんですか！？"]}, {"box": [1128, 720, 1155, 995], "vertical": true, "font_size": 30, "lines_coords": [[[1128.0, 720.0], [1155.0, 720.0], [1155.0, 995.0], [1128.0, 995.0]]], "lines": ["いやー安心しました！？"]}, {"box": [1020, 774, 1091, 1033], "vertical": true, "font_size": 30, "lines_coords": [[[1059.0, 776.0], [1091.0, 776.0], [1089.0, 1033.0], [1057.0, 1033.0]], [[1025.0, 774.0], [1057.0, 774.0], [1051.0, 1006.0], [1020.0, 1006.0]]], "lines": ["教頭へはあたしか