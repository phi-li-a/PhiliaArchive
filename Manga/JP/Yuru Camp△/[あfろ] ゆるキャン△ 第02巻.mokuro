.0, 1389.0], [1132.0, 1389.0]], [[1098.0, 1192.0], [1125.0, 1192.0], [1125.0, 1359.0], [1098.0, 1359.0]], [[1066.0, 1190.0], [1091.0, 1190.0], [1091.0, 1222.0], [1066.0, 1222.0]]], "lines": ["薪は自由に", "使ってもらって", "構わないけど", "．．．"]}, {"box": [468, 1192, 594, 1505], "vertical": true, "font_size": 37, "lines_coords": [[[556.0, 1194.0], [594.0, 1194.0], [594.0, 1505.0], [556.0, 1505.0]], [[513.0, 1194.0], [551.0, 1194.0], [551.0, 1503.0], [513.0, 1503.0]], [[472.0, 1192.0], [506.0, 1192.0], [502.0, 1398.0], [468.0, 1398.0]]], "lines": ["キャンプファイヤー", "じゃないから丁寧に", "焚き火してね"]}], "img_path": "0034.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1096, 58, 1206, 311], "vertical": true, "font_size": 30, "lines_coords": [[[1175.0, 61.0], [1201.0, 61.0], [1201.0, 309.0], [1175.0, 309.0]], [[1138.0, 61.0], [1170.0, 61.0], [1170.0, 296.0], [1138.0, 296.0]], [[1096.0, 58.0], [1128.0, 58.0], [1132.0, 211.0], [1100.0, 211.0]]], "lines": ["そうだ、折角だから", "ウッドキャンドル", "やろうぜ！！"]}, {"box": [177, 149, 624, 309], "vertical": false, "font_size": 31, "lines_coords": [[[238.0, 153.0], [598.0, 153.0], [598.0, 193.0], [238.0, 193.0]], [[181.0, 204.0], [624.0, 204.0], [624.0, 236.0], [181.0, 236.0]], [[202.0, 243.0], [605.0, 243.0], [605.0, 270.0], [202.0, 270.0]], [[230.0, 277.0], [564.0, 277.0], [564.0, 301.0], [230.0, 301.0]]], "lines": ["ラッドキヤンドル", "輪切りにした丸太に切れ込みを入れ", "苦火刺を詰めて、ろうそくの様に", "決やすおき！！のやり方です"]}, {"box": [1111, 613, 1177, 798], "vertical": true, "font_size": 32, "lines_coords": [[[1141.0, 613.0], [1177.0, 613.0], [1177.0, 701.0], [1141.0, 701.0]], [[1111.0, 615.0], [1138.0, 615.0], [1138.0, 798.0], [1111.0, 798.0]]], "lines": ["ウッド", "キャンドル？"]}, {"box": [240, 677, 560, 780], "vertical": false, "font_size": 28, "lines_coords": [[[251.0, 680.0], [551.0, 680.0], [551.0, 706.0], [251.0, 706.0]], [[247.0, 716.0], [547.0, 716.0], [547.0, 742.0], [247.0, 742.0]], [[290.0, 748.0], [502.0, 748.0], [502.0, 780.0], [290.0, 780.0]]], "lines": ["「スウェーデントーチじゃ", "「木こり