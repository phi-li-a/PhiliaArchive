51.0, 1410.0], [418.0, 1410.0]], [[380.0, 1284.0], [412.0, 1284.0], [412.0, 1410.0], [380.0, 1410.0]]], "lines": ["その手が", "あったか"]}, {"box": [742, 1486, 816, 1770], "vertical": true, "font_size": 29, "lines_coords": [[[776.0, 1486.0], [808.0, 1486.0], [808.0, 1770.0], [776.0, 1770.0]], [[744.0, 1486.0], [770.0, 1486.0], [768.0, 1770.0], [742.0, 1770.0]]], "lines": ["心配なら丑三つ時より", "前に寝ればいいんだよ"]}], "img_path": "0107.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [770, 138, 835, 420], "vertical": true, "font_size": 27, "lines_coords": [[[808.0, 140.0], [834.0, 140.0], [834.0, 281.0], [808.0, 281.0]], [[770.0, 138.0], [798.0, 138.0], [800.0, 420.0], [772.0, 420.0]]], "lines": ["リンちゃん", "場所どこにしよっか？"]}, {"box": [939, 461, 965, 616], "vertical": true, "font_size": 24, "lines_coords": [[[939.0, 461.0], [963.0, 461.0], [963.0, 616.0], [939.0, 616.0]]], "lines": ["バカな女だぜ"]}, {"box": [1008, 786, 1116, 1066], "vertical": true, "font_size": 30, "lines_coords": [[[1083.0, 787.0], [1115.0, 787.0], [1115.0, 943.0], [1083.0, 943.0]], [[1044.0, 787.0], [1076.0, 787.0], [1076.0, 1066.0], [1044.0, 1066.0]], [[1008.0, 789.0], [1035.0, 789.0], [1035.0, 975.0], [1008.0, 975.0]]], "lines": ["直火ＯＫの", "グリーンサイトって", "所にしない？"]}, {"box": [65, 350, 174, 696], "vertical": true, "font_size": 27, "lines_coords": [[[144.0, 356.0], [170.0, 356.0], [170.0, 600.0], [144.0, 600.0]], [[103.0, 350.0], [135.0, 350.0], [135.0, 570.0], [103.0, 570.0]], [[67.0, 354.0], [91.0, 354.0], [91.0, 693.0], [67.0, 693.0]]], "lines": ["んー芝生サイトは", "焚火できる所が", "限られるみたいだから："]}, {"box": [438, 1222, 476, 1374], "vertical": true, "font_size": 34, "lines_coords": [[[438.0, 1222.0], [472.0, 1222.0], [476.0, 1372.0], [442.0, 1372.0]]], "lines": ["さてと．．．"]}, {"box": [285, 903, 316, 1029], "vertical": true, "font_size": 31, "lines_coords": [[[285.0, 903.0], [316.0, 903.0], [316.0, 1029.0], [285.0, 1029.0]]], "lines": ["そだねー"]}], "img_path": "0108.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1049, 1147, 1183, 1317], "vertical": true, "font_size": 26, "lines_coords": [[[1155.0, 1147.0], [1181.0, 1147.0], [1181.0, 1316.0], [1155.0, 1316.0]], [[1117.0, 1147.0], [1145.0, 1147.0], [1147.0, 1288.0], [1119.0, 1288.0]], [[1085.0, 1149.0], [1111.0, 1149.0], [1111.0, 1290.0], [1085.0, 1290.0]], [[1050.0, 1149.0], [1076.0, 1149.0], [1076.0, 1316.0], [1050.0, 1316.0]]], "lines": ["リンちゃんの", "テントって", "よく見ると", "変わってるね"]}, {"box": [583, 1136, 647, 1417], "vertical": true, "font_size": 26, "lines_coords": [[[616.0, 1136.0], [643.0, 1136.0], [643.0, 1385.0], [616.0, 1385.0]], [[583.0, 1138.0], [609.0, 1138.0], [609.0, 1417.0], [583.0, 1417.0]]], "lines": ["テントの：袖（？）に", "ボールを通してないし"]}, {"box": [144, 1369, 221, 1509], "vertical": true, "font_size": 33, "lines_coords": [[[187.0, 1370.0], [219.0, 1370.0], [219.0, 1507.0], [187.0, 1507.0]], [[144.0, 1370.0], [178.0, 1370.0], [178.0, 1509.0], [144.0, 1509.0]]], "lines": ["吊り下げ", "式の事？"]}], "img_path": "0109.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [691, 150, 1141, 279], "vertical": false, "font_size": 36, "lines_coords": [[[735.0, 151.0], [1093.0, 150.0], [1093.0, 189.0], [735.0, 191.0]], [[695.0, 198.0], [1128.0, 198.0], [1128.0, 230.0], [695.0, 230.0]], [[783.0, 238.0], [1042.0, 238.0], [1042.0, 275.0], [783.0, 275.0]]], "lines": ["テントには主に本体を", "フレームに吊るして設営する", "「吊り下げ式と"]}, {"box": [138, 131, 549, 258], "vertical": false, "font_size": 40, "lines_coords": [[[151.0, 131.0], [536.0, 131.0], [536.0, 168.0], [151.0, 168.0]], [[138.0, 172.0], [547.0, 176.0], [547.0, 215.0], [138.0, 211.0]], [[170.0, 213.0], [519.0, 213.0], [519.0, 258.0], [170.0, 258.0]]], "lines": ["細かい違いはありますが", "普通のキャンプで使うなら", "あまり差はありません"]}, {"box": [662, 702, 1167, 828], "vertical": false, "font_size": 38, "lines_coords": [[[776.0, 703.0], [1053.0, 703.0], [1053.0, 742.0], [776.0, 742.0]], [[723.0, 746.0], [1100.0, 746.0], [1100.0, 783.0], [723.0, 783.0]], [[667.0, 789.0], [1158.0, 789.0], [1158.0, 826.0], [667.0, 826.0]]], "lines": ["本体のスリープに", "ポールを通して設営する", "「スリーブ式」の２つがあります"]}, {"box": [815, 907, 1163, 989], "vertical": false, "font_size": 38, "lines_coords": [[[815.0, 907.0], [1162.0, 907.0], [1162.0, 946.0], [815.0, 946.0]], [[817.0, 950.0], [1162.0, 950.0], [1162.0, 988.0], [817.0, 988.0]]], "lines": ["物によっては片側から", "ポールを入れるだけで"]}, {"box": [175, 756, 518, 836], "vertical": false, "font_size": 35, "lines_coords": [[[176.0, 757.0], [513.0, 757.0], [513.0, 795.0], [176.0, 795.0]], [[211.0, 802.0], [480.0, 802.0], [480.0, 834.0], [211.0, 834.0]]], "lines": ["慣れわば設営の手間も", "だいたい同じです"]}, {"box": [213, 908, 545, 988], "vertical": false, "font_size": 35, "lines_coords": [[[217.0, 911.0], [540.0, 911.0], [540.0, 943.0], [217.0, 943.0]], [[258.0, 950.0], [493.0, 950.0], [493.0, 988.0], [258.0, 988.0]]], "lines": ["フック箇所を減らして", "早く設営できる"]}, {"box": [1035, 1220, 1091, 1260], "vertical": false, "font_size": 40, "lines_coords": [[[1035.0, 1220.0], [1091.0, 1220.0], [1091.0, 1260.0], [1035.0, 1260.0]]], "lines": ["ｏｋ"]}, {"box": [833, 1343, 1142, 1422], "vertical": false, "font_size": 32, "lines_coords": [[[838.0, 1346.0], [1134.0, 1346.0], [1134.0, 1378.0], [838.0, 1378.0]], [[845.0, 1387.0], [1132.0, 1387.0], [1132.0, 1419.0], [845.0, 1419.0]]], "lines": ["反対側が固定される", "スリープ式テントや"]}, {"box": [709, 1132, 763, 1171], "vertical": false, "font_size": 39, "lines_coords": [[[710.0, 1132.0], [763.0, 1132.0], [763.0, 1171.0], [710.0, 1171.0]]], "lines": ["ｏｋ"]}, {"box": [240, 1342, 502, 1423], "vertical": false, "font_size": 29, "lines_coords": [[[243.0, 1342.0], [496.0, 1346.0], [496.0, 1378.0], [243.0, 1374.0]], [[260.0, 1391.0], [485.0, 1391.0], [485.0, 1417.0], [260.0, 1417.0]]], "lines": ["吊り下げ式テント", "などもありまで"]}, {"box": [1143, 1503, 1224, 1693], "vertical": true, "font_size": 72, "lines_coords": [[[1153.0, 1503.0], [1224.0, 1507.0], [1215.0, 1693.0], [1143.0, 1689.0]]], "lines": ["お高い"]}, {"box": [1081, 1496, 1145, 1638], "vertical": true, "font_size": 49, "lines_coords": [[[1096.0, 1496.0], [1145.0, 1501.0], [1130.0, 1638.0], [1081.0, 1633.0]]], "lines": ["ですが"]}, {"box": [1044, 1565, 1076, 1730], "vertical": true, "font_size": 28, "lines_coords": [[[1048.0, 1565.0], [1076.0, 1565.0], [1072.0, 1730.0], [1044.0, 1730.0]]], "lines": ["【２万位から"]}, {"box": [350, 1548, 390, 1648], "vertical": true, "font_size": 40, "lines_coords": [[[350.0, 1548.0], [390.0, 1548.0], [390.0, 1648.0], [350.0, 1648.0]]], "lines": ["ＯＨ："]}], "img_path": "0110.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1138, 142, 1209, 358], "vertical": true, "font_size": 32, "lines_coords": [[[1177.0, 142.0], [1209.0, 142.0], [1209.0, 358.0], [1177.0, 358.0]], [[1138.0, 142.0], [1170.0, 142.0], [1170.0, 331.0], [1138.0, 331.0]]], "lines": ["この下に敷いて", "あるのは何？"]}, {"box": [705, 148, 778, 369], "vertical": true, "font_size": 36, "lines_coords": [[[738.0, 148.0], [778.0, 148.0], [778.0, 249.0], [738.0, 249.0]], [[705.0, 150.0], [736.0, 150.0], [738.0, 367.0], [706.0, 367.0]]], "lines": ["それは", "グランドシート"]}, {"box": [575, 133, 650, 480], "vertical": true, "font_size": 32, "lines_coords": [[[616.0, 136.0], [648.0, 136.0], [648.0, 480.0], [616.0, 480.0]], [[575.0, 133.0], [607.0, 133.0], [607.0, 386.0], [575.0, 386.0]]], "lines": ["敷いておくと汚れないし", "片付けるの楽だよ"]}, {"box": [136, 282, 206, 470], "vertical": true, "font_size": 30, "lines_coords": [[[174.0, 283.0], [206.0, 283.0], [206.0, 470.0], [174.0, 470.0]], [[136.0, 283.0], [163.0, 283.0], [163.0, 406.0], [136.0, 406.0]]], "lines": ["あとテントの", "破れ防止"]}, {"box": [1142, 738, 1211, 1052], "vertical": true, "font_size": 30, "lines_coords": [[[1175.0, 738.0], [1209.0, 738.0], [1211.0, 958.0], [1177.0, 958.0]], [[1143.0, 742.0], [1170.0, 742.0], [1170.0, 1051.0], [1143.0, 1051.0]]], "lines": ["確かにこの間の", "キャンプで片付ける時"]}, {"box": [710, 720, 776, 945], "vertical": true, "font_size": 29, "lines_coords": [[[744.0, 721.0], [776.0, 721.0], [776.0, 945.0], [744.0, 945.0]], [[710.0, 721.