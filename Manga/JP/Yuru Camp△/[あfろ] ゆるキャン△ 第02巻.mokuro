, [840.0, 858.0]]], "lines": ["次の野クルキャンプは"]}, {"box": [791, 598, 870, 703], "vertical": true, "font_size": 40, "lines_coords": [[[828.0, 598.0], [870.0, 600.0], [866.0, 701.0], [825.0, 699.0]], [[791.0, 600.0], [830.0, 600.0], [830.0, 703.0], [791.0, 703.0]]], "lines": ["ヴ～～～", "ヴ～～～"]}, {"box": [451, 1215, 481, 1300], "vertical": true, "font_size": 25, "lines_coords": [[[453.0, 1215.0], [481.0, 1215.0], [481.0, 1278.0], [453.0, 1278.0]], [[451.0, 1271.0], [472.0, 1265.0], [480.0, 1293.0], [459.0, 1299.0]]], "lines": ["よー", "ん"]}, {"box": [222, 1170, 251, 1449], "vertical": true, "font_size": 26, "lines_coords": [[[223.0, 1171.0], [249.0, 1171.0], [249.0, 1445.0], [223.0, 1445.0]]], "lines": ["テストがんばるぞーっ"]}, {"box": [806, 1677, 1171, 1736], "vertical": false, "font_size": 22, "lines_coords": [[[806.0, 1680.0], [1063.0, 1680.0], [1063.0, 1704.0], [806.0, 1704.0]], [[810.0, 1711.0], [1166.0, 1711.0], [1166.0, 1730.0], [810.0, 1730.0]]], "lines": ["テスト終わりのごほうび", "クリスマスキセンフで決まりやー"]}, {"box": [324, 1726, 433, 1766], "vertical": false, "font_size": 40, "lines_coords": [[[324.0, 1726.0], [433.0, 1726.0], [433.0, 1766.0], [324.0, 1766.0]]], "lines": ["一般社会議会社会は、"]}], "img_path": "0175.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1010, 204, 1045, 315], "vertical": true, "font_size": 34, "lines_coords": [[[1010.0, 204.0], [1044.0, 204.0], [1044.0, 313.0], [1010.0, 313.0]]], "lines": ["さてー"]}, {"box": [781, 189, 823, 463], "vertical": true, "font_size": 38, "lines_coords": [[[785.0, 189.0], [823.0, 189.0], [819.0, 463.0], [781.0, 463.0]]], "lines": ["早速磨いた木皿で"]}, {"box": [180, 155, 261, 373], "vertical": true, "font_size": 35, "lines_coords": [[[221.0, 157.0], [260.0, 157.0], [260.0, 343.0], [221.0, 343.0]], [[180.0, 155.0], [211.0, 155.0], [211.0, 373.0], [180.0, 373.0]]], "lines": ["スープ飲ん", "じゃうぜーっ"]}, {"box": [1141, 864, 1211, 1082], "vertical": true, "font_size": 32, "lines_coords": [[[1179.0, 864.0], [1211.0, 864.0], [1211.0, 1020.0], [1179.0, 1020.0]], [[1141.0, 866.0], [1173.0, 866.0], [1173.0, 1081.0], [1141.0, 1081.0]]], "lines": ["んーただの", "コーンスープも"]}, {"box": [676, 990, 746, 1241], "vertical": true, "font_size": 28, "lines_coords": [[[712.0, 990.0], [744.0, 990.0], [744.0, 1239.0], [712.0, 1239.0]], [[676.0, 993.0], [701.0, 993.0], [701.0, 1149.0], [676.0, 1149.0]]], "lines": ["木皿に注ぐだけで", "こんなに．．．"]}, {"box": [534, 900, 596, 1179], "vertical": true, "font_size": 58, "lines_coords": [[[534.0, 937.0], [592.0, 937.0], [592.0, 1179.0], [534.0, 1179.0]]], "lines": ["くっさ！！"]}, {"box": [1171, 1332, 1204, 1554], "vertical": true, "font_size": 32, "lines_coords": [[[1171.0, 1333.0], [1203.0, 1333.0], [1203.0, 1552.0], [1171.0, 1552.0]]], "lines": ["こんなに．．．"]}, {"box": [682, 1348, 769, 1693], "vertical": true, "font_size": 36, "lines_coords": [[[727.0, 1350.0], [766.0, 1350.0], [766.0, 1693.0], [727.0, 1693.0]], [[682.0, 1348.0], [716.0, 1348.0], [718.0, 1661.0], [684.0, 1661.0]]], "lines": ["注意：塗装を剥がした", "アカシア製木皿には"]}, {"box": [45, 1258, 124, 1743], "vertical": true, "font_size": 30, "lines_coords": [[[86.0, 1258.0], [120.0, 1258.0], [121.0, 1726.0], [88.0, 1726.0]], [[46.0, 1260.0], [73.0, 1260.0], [73.0, 1740.0], [46.0, 1740.0]]], "lines": ["独特の匂いがありその風味が", "食品に移ることとかありますので、"]}], "img_path": "0176.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1119, 176, 1190, 552], "vertical": true, "font_size": 26, "lines_coords": [[[1156.0, 178.0], [1183.0, 178.0], [1183.0, 547.0], [1156.0, 547.0]], [[1119.0, 176.0], [1145.0, 176.0], [1145.0, 549.0], [1119.0, 549.0]]], "lines": ["お酢を混ぜた水に浸けおき", "よく脱臭して使いましょう"]}, {"box": [759, 191, 795, 258], "vertical": true, "font_size": 36, "lines_coords": [[[759.0, 191.0], [795.0, 191.0], [795.0, 258.0], [759.0, 258.0]]], "lines": ["おお"]}, {"box": [946, 510, 979, 680], "vertical": true, "font_size": 32, "lines_coords": [[[946.0, 511.0], [978.0, 511.0], [978.0, 680.0], [946.0, 680.0]]], "lines": ["くっせぇ！！"]}, {"box": [703, 495, 836, 721], "vertical": true, "font_size": 29, "lines_coords": [[[804.0, 496.0], [836.0, 496.0], [836.0, 613.0], [804.0, 613.0]], [[770.0, 495.0], [802.0, 495.0], [802.0, 721.0], [770.0, 721.0]], [[738.0, 498.0], [763.0, 498.0], [763.0, 691.0], [738.0, 691.0]], [[703.0, 498.0], [729.0, 498.0], [729.0, 637.0], [703.0, 637.0]]], "lines": ["この辺も", "地図の３Ｄビュー", "見られるように", "なってるよ"]}, {"box": [862, 896, 911, 948], "vertical": true, "font_size": 49, "lines_coords": [[[862.0, 896.0], [911.0, 896.0], [911.0, 948.0], [862.0, 948.0]]], "lines": ["あ"]}, {"box": [120, 489, 183, 684], "vertical": true, "font_size": 26, "lines_coords": [[[155.0, 493.0], [181.0, 493.0], [181.0, 684.0], [155.0, 684.0]], [[120.0, 489.0], [146.0, 489.0], [146.0, 684.0], [120.0, 684.0]]], "lines": ["へーいつ撮りに", "来たのかしらね"]}], "img_path": "0177.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [82, 1260, 534, 1286], "vertical": false, "font_size": 26, "lines_coords": [[[82.0, 1260.0], [534.0, 1260.0], [534.0, 1286.0], [82.0, 1286.0]]], "lines": ["ゆるキャン△◎いいかがでしたでしょうか。"]}, {"box": [84, 1665, 234, 1691], "vertical": false, "font_size": 26, "lines_coords": [[[84.0, 1665.0], [234.0, 1665.0], [234.0, 1691.0], [84.0, 1691.0]]], "lines": ["あｆ＿ろでした。"]}, {"box": [72, 1333, 1100, 1617], "vertical": false, "font_size": 27, "lines_coords": [[[86.0, 1340.0], [746.0, 1340.0], [746.0, 1366.0], [86.0, 1366.0]], [[82.0, 1380.0], [311.0, 1381.0], [311.0, 1408.0], [82.0, 1406.0]], [[84.0, 1423.0], [750.0, 1423.0], [750.0, 1447.0], [84.0, 1447.0]], [[84.0, 1462.0], [676.0, 1462.0], [676.0, 1488.0], [84.0, 1488.0]], [[82.0, 1500.0], [1100.0, 1498.0], [1100.0, 1530.0], [82.0, 1531.0]], [[84.0, 1543.0], [993.0, 1543.0], [993.0, 1569.0], [84.0, 1569.0]], [[84.0, 1582.0], [815.0, 1582.0], [815.0, 1608.0], [84.0, 1608.0]]], "lines": ["今回は高ボッチ高原、笛吹公園そして四尾連湖でのキャンプ", "描かせて頂きました。", "作中では季節が冬のおかげでどこへ行っても寒そうでしたか", "高ボッチは夏に避暑で放牧された牛をぼーっと眺めに", "笛吹公園は季節によって変わる句、の果物スイーツを食べ、年中美しい夜景をポーっと眺めに", "四尾連湖は桜が植えてあるので４月にボーっと花見キャンプするのもいいですね。", "お時間のある方は日常を忘れてボー・っとしに行ってみてください。"]}, {"box": [656, 1764, 763, 1785], "vertical": false, "font_size": 19, "lines_coords": [[[656.0, 1764.0], [763.0, 1766.0], [763.0, 1785.0], [656.0, 1783.0]]], "lines": ["まんかタイ"]}, {"box": [639, 1794, 796, 1841], "vertical": false, "font_size": 19.0, "lines_coords": [[[639.0, 1794.0], [753.0, 1794.0], [753.0, 1813.0], [639.0, 1813.0]], [[661.0, 1822.0], [796.0, 1822.0], [796.0, 1841.0], [661.0, 1841.0]]], "lines": ["行描き下ろ", "本書は以上の内"]}], "img_path": "0178.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [386, 795, 603, 898], "vertical": false, "font_size": 37.0, "lines_coords": [[[386.0, 798.0], [603.0, 795.0], [603.0, 834.0], [386.0, 838.0]], [[390.0, 864.0], [483.0, 864.0], [483.0, 898.0], [390.0, 898.0]]], "lines": ["著者：あｆろ", "©ａｆｒｏ"]}, {"box": [405, 615, 930, 678], "vertical": false, "font_size": 63, "lines_coords": [[[405.0, 615.0], [930.0, 615.0], [930.0, 678.0], [405.0, 678.0]]], "lines": ["ゆるキャン△，第２巻"]}, {"box": [386, 981, 958, 1228], "vertical": false, "font_size": 37, "lines_coords": [[[386.0, 993.0], [939.0, 988.0], [939.0, 1027.0], [386.0, 1033.0]], [[386.0, 1059.0], [682.0, 1059.0], [682.0, 1096.0], [386.0, 1096.0]], [[390.0, 1123.0], [793.0, 1126.0], [793.0, 1158.0], [390.0, 1155.0]], [[536.0, 1188.0], [941.0, 1188.0], [941.0, 1226.0], [536.0, 1226.0]]], "lines": ["電子版発行日：２０１６年８月１５日", "発行人・東・敬彰・", "発行所：株式会社芳文社", "東京都文京区後楽１－２－１２"]}], "img_path": "0179.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [3, 656, 230, 892], "vertical": false, "font_size": 173, "lines_coords": [[[9.0, 656.0], [230.0, 663.0], [225.0, 836.0], [3.0, 828.0]]], "lines": ["．．．"]}, {"box": [268, 650, 553, 778], "vertical": false, "font_size": 107, "lines_coords": [[[275.0, 650.0], [553.0, 671.0], [545.0, 778.0], [268.0, 757.0]]], "lines": ["ゆゝまン"]}, {"box": [563, 760, 641, 779], "vertical": false, "font_size": 21, "lines_coords": [[[563.0, 758.0], [641.0, 758.0], [641.0, 781.0], [563.0, 781.0]]], "lines": ["Ｙｕｒｕｃａｍｐ"]}, {"box": [1183, 828, 1289, 888], "vertical": false, "font_size": 23, "lines_coords": [[[1190.0, 828.0], [1275.0, 828.0], [1275.0, 853.0], [1190.0, 853.0]], [[1224.0, 856.0], [1263.0, 856.0], [1263.0, 881.0], [1224.0, 881.0]]], "lines": ["ｖｉｎｌＣｉｎｐｓ", "そのためには、これから"]}, {"box": [416, 1162, 530, 1188], "vertical": false, "font_size": 26, "lines_coords": [[[416.0, 1162.0], [530.0, 1162.0], [530.0, 1188.0], [416.0, 1188.0]]], "lines": ["いつだけではないので"]}, {"box": [885, 1153, 913, 1177], "vertical": false, "font_size": 24, "lines_coords": [[[885.0, 1153.0], [913.0, 1153.0], [913.0, 1177.0], [885.0, 1177.0]]], "lines": ["え"]}], "img_path": "0180.jpg"}]}