lines": ["これ上に鍋直乗せして", "料理も出来るんだぜ"]}, {"box": [585, 660, 650, 1001], "vertical": true, "font_size": 29, "lines_coords": [[[618.0, 660.0], [650.0, 660.0], [650.0, 1001.0], [618.0, 1001.0]], [[585.0, 661.0], [611.0, 661.0], [611.0, 997.0], [585.0, 997.0]]], "lines": ["でも野クルのポットみたく", "まっ黒になっちゃうけどな"]}, {"box": [238, 667, 517, 759], "vertical": false, "font_size": 49, "lines_coords": [[[238.0, 667.0], [418.0, 667.0], [418.0, 720.0], [238.0, 720.0]], [[240.0, 708.0], [504.0, 714.0], [504.0, 759.0], [240.0, 753.0]]], "lines": ["野クル備品", "コーヒー用ポット"]}, {"box": [939, 1274, 999, 1488], "vertical": true, "font_size": 26, "lines_coords": [[[971.0, 1275.0], [997.0, 1275.0], [997.0, 1460.0], [971.0, 1460.0]], [[939.0, 1275.0], [965.0, 1275.0], [965.0, 1488.0], [939.0, 1488.0]]], "lines": ["焚き火見てると", "どうしてこんなに"]}, {"box": [726, 886, 758, 1123], "vertical": true, "font_size": 26, "lines_coords": [[[727.0, 886.0], [753.0, 886.0], [753.0, 1123.0], [727.0, 1123.0]]], "lines": ["それすごいなー"]}, {"box": [465, 1329, 491, 1470], "vertical": true, "font_size": 26, "lines_coords": [[[465.0, 1329.0], [491.0, 1329.0], [491.0, 1470.0], [465.0, 1470.0]]], "lines": ["せやなぁ．．．"]}, {"box": [256, 1087, 493, 1126], "vertical": false, "font_size": 28, "lines_coords": [[[270.0, 1089.0], [489.0, 1091.0], [489.0, 1119.0], [270.0, 1117.0]]], "lines": ["ススでまっくろ"]}, {"box": [150, 876, 182, 1105], "vertical": true, "font_size": 26, "lines_coords": [[[150.0, 879.0], [176.0, 879.0], [176.0, 1102.0], [150.0, 1102.0]]], "lines": ["それもそうだねー"]}, {"box": [847, 1357, 872, 1558], "vertical": true, "font_size": 24, "lines_coords": [[[847.0, 1357.0], [871.0, 1357.0], [871.0, 1558.0], [847.0, 1558.0]]], "lines": ["落ちつくのかなぁ"]}], "img_path": "0036.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1145, 1200, 1209, 1479], "vertical": true, "font_size": 25, "lines_coords": [[[1181.0, 1201.0], [1207.0, 1201.0], [1207.0, 1396.0], [1181.0, 1396.0]], [[1147.0, 1201.0], [1171.0, 1201.0], [1171.0, 1