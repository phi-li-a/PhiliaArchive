6.0, 1085.0]], [[133.0, 778.0], [165.0, 778.0], [165.0, 982.0], [133.0, 982.0]]], "lines": ["そういえばここって", "紅葉以外にも"]}, {"box": [1099, 862, 1218, 1070], "vertical": true, "font_size": 32, "lines_coords": [[[1181.0, 862.0], [1215.0, 862.0], [1216.0, 1070.0], [1183.0, 1070.0]], [[1141.0, 864.0], [1173.0, 864.0], [1173.0, 1068.0], [1141.0, 1068.0]], [[1100.0, 864.0], [1132.0, 864.0], [1132.0, 1036.0], [1100.0, 1036.0]]], "lines": ["教えてくれた", "あきちゃんに", "感謝だよ！！"]}, {"box": [1190, 1153, 1280, 1563], "vertical": true, "font_size": 38, "lines_coords": [[[1239.0, 1153.0], [1276.0, 1153.0], [1276.0, 1393.0], [1239.0, 1393.0]], [[1190.0, 1153.0], [1228.0, 1153.0], [1228.0, 1563.0], [1190.0, 1563.0]]], "lines": ["牛のお化けの", "言い伝えで有名らしいね"]}, {"box": [637, 1177, 705, 1325], "vertical": true, "font_size": 68, "lines_coords": [[[637.0, 1177.0], [705.0, 1177.0], [705.0, 1325.0], [637.0, 1325.0]]], "lines": ["ピクッ"]}], "img_path": "0103.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1145, 69, 1218, 335], "vertical": true, "font_size": 48, "lines_coords": [[[1153.0, 69.0], [1218.0, 71.0], [1211.0, 335.0], [1145.0, 333.0]]], "lines": ["四尾連湖」"]}, {"box": [1057, 230, 1140, 615], "vertical": true, "font_size": 48, "lines_coords": [[[1096.0, 230.0], [1136.0, 230.0], [1140.0, 615.0], [1100.0, 615.0]], [[1057.0, 232.0], [1096.0, 232.0], [1096.0, 538.0], [1057.0, 538.0]]], "lines": ["本栖湖の北西に位置する", "小さなカルデラ湖。"]}, {"box": [576, 63, 664, 504], "vertical": true, "font_size": 40, "lines_coords": [[[618.0, 63.0], [658.0, 63.0], [660.0, 504.0], [620.0, 504.0]], [[577.0, 63.0], [616.0, 63.0], [616.0, 416.0], [577.0, 416.0]]], "lines": ["江戸時代には「富士八海」の", "数えられた紅葉の名所"]}, {"box": [479, 63, 528, 517], "vertical": true, "font_size": 40, "lines_coords": [[[483.0, 63.0], [523.0, 63.0], [523.0, 517.0], [483.0, 517.0]]], "lines": ["ここでは丑三つ時になると"]}, {"box": [76, 62, 170, 611], "vertical": true, "font_size": 45, "lines_coords": [[[123.0, 63.0], [168.0, 63.0], [168.0, 611.0], [123.0, 611.0]], [[76.0, 63.0], [121.0, 63.0], [121.0, 592.0], [76.0, 592.0]]], "lines": ["昔武士に倒された生鬼の亡霊が", "湖面に現れるという言い伝えが"]}, {"box": [1182, 735, 1225, 1040], "vertical": true, "font_size": 32, "lines_coords": [[[1186.0, 736.0], [1218.0, 736.0], [1218.0, 1029.0], [1186.0, 1029.0]]], "lines": ["あるとかないとか"]}, {"box": [693, 736, 757, 1128], "vertical": true, "font_size": 30, "lines_coords": [[[721.0, 736.0], [753.0, 736.0], [757.0, 993.0], [725.0, 993.0]], [[693.0, 738.0], [720.0, 738.0], [720.0, 1128.0], [693.0, 1128.0]]], "lines": ["お願いします今夜は", "ってないで下さいでないぞ下され"]}, {"box": [858, 1025, 892, 1154], "vertical": true, "font_size": 34, "lines_coords": [[[858.0, 1025.0], [892.0, 1025.0], [892.0, 1151.0], [858.0, 1151.0]]], "lines": ["チャリン"]}, {"box": [129, 1018, 210, 1222], "vertical": true, "font_size": 33, "lines_coords": [[[174.0, 1018.0], [208.0, 1018.0], [204.0, 1190.0], [170.0, 1190.0]], [[129.0, 1018.0], [161.0, 1018.0], [161.0, 1222.0], [129.0, 1222.0]]], "lines": ["何の石碑に", "拝んでるの？"]}, {"box": [230, 1811, 705, 1850], "vertical": false, "font_size": 36.0, "lines_coords": [[[294.0, 1811.0], [705.0, 1811.0], [705.0, 1848.0], [294.0, 1848.0]], [[230.0, 1815.0], [307.0, 1815.0], [307.0, 1850.0], [230.0, 1850.0]]], "lines": ["冬キャンと回尾連湖", "話"]}, {"box": [285, 1426, 361, 1586], "vertical": true, "font_size": 38, "lines_coords": [[[315.0, 1426.0], [361.0, 1426.0], [361.0, 1496.0], [315.0, 1496.0]], [[285.0, 1426.0], [316.0, 1426.0], [316.0, 1586.0], [285.0, 1586.0]]], "lines": ["おい", "どこへ行く"]}], "img_path": "0104.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [599, 57, 1249, 111], "vertical": false, "font_size": 54, "lines_coords": [[[599.0, 57.0], [1249.0, 57.0], [1249.0, 111.0], [599.0, 111.0]]], "lines": ["第１１１話、冬キャンと回尾連湖"]}], "img_path": "0105.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1141, 71, 1211, 240], "vertical": true, "font_size": 26, "lines_coords": [[[1183.0, 73.0], [1209.0, 73.0], 