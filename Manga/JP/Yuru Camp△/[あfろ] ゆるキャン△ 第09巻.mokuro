165.0], [131.0, 498.0], [99.0, 498.0]], [[61.0, 166.0], [88.0, 166.0], [88.0, 513.0], [61.0, 513.0]]], "lines": ["千潮時には海岸から島へ", "歩いて渡る事が出来ます。"]}, {"box": [1134, 802, 1209, 1205], "vertical": true, "font_size": 35, "lines_coords": [[[1168.0, 802.0], [1205.0, 802.0], [1209.0, 1205.0], [1171.0, 1205.0]], [[1134.0, 806.0], [1166.0, 806.0], [1166.0, 1136.0], [1134.0, 1136.0]]], "lines": ["朝早くに地元の料理人が船で", "島に食材を持って渡り"]}, {"box": [725, 802, 798, 1205], "vertical": true, "font_size": 34, "lines_coords": [[[761.0, 802.0], [798.0, 802.0], [798.0, 1205.0], [761.0, 1205.0]], [[725.0, 806.0], [757.0, 806.0], [757.0, 1035.0], [725.0, 1035.0]]], "lines": ["千潮で道が出来ている間だけ", "屋台を開きます。"]}, {"box": [579, 796, 659, 1265], "vertical": true, "font_size": 38, "lines_coords": [[[618.0, 800.0], [656.0, 800.0], [656.0, 1201.0], [618.0, 1201.0]], [[579.0, 802.0], [616.0, 802.0], [616.0, 1263.0], [579.0, 1263.0]]], "lines": ["その屋台で出される料理こそ", "三匹郎島のとんぼろこと呼ばれる"]}, {"box": [48, 798, 122, 1295], "vertical": true, "font_size": 29, "lines_coords": [[[88.0, 800.0], [120.0, 800.0], [120.0, 1293.0], [88.0, 1293.0]], [[50.0, 804.0], [76.0, 804.0], [76.0, 1237.0], [50.0, 1237.0]]], "lines": ["１日２時間しか食べる事の出来ない", "幻の西伊豆Ｂ級グルメなのです"]}, {"box": [1126, 1387, 1213, 1695], "vertical": true, "font_size": 39, "lines_coords": [[[1170.0, 1387.0], [1209.0, 1387.0], [1213.0, 1657.0], [1173.0, 1657.0]], [[1126.0, 1387.0], [1164.0, 1387.0], [1164.0, 1695.0], [1126.0, 1695.0]]], "lines": ["今食べに行くで", "待っとってなー！！"]}, {"box": [654, 1657, 746, 1845], "vertical": true, "font_size": 43, "lines_coords": [[[699.0, 1657.0], [746.0, 1657.0], [746.0, 1775.0], [699.0, 1775.0]], [[654.0, 1657.0], [693.0, 1657.0], [697.0, 1845.0], [658.0, 1845.0]]], "lines": ["とんぼ", "ろーーっ！！"]}, {"box": [433, 1425, 506, 1580], "vertical": true, "font_size": 30, "lines_coords": [[[476.0, 1432.0], [502.0, 1432.0], [502.0, 1580.0], [476.0, 1580.0]], [[433.0, 1426.0], [466.0, 1425.0], [470.0, 1516.0], [436.0, 1518.0]]], "lines": ["たのしみや", "なーっ"]}, {"box": [241, 1365, 367, 1569], "vertical": true, "font_size": 29, "lines_coords": [[[335.0, 1366.0], [367.0, 1366.0], [367.0, 1524.0], [335.0, 1524.0]], [[303.0, 1368.0], [335.0, 1368.0], [335.0, 1498.0], [303.0, 1498.0]], [[275.0, 1368.0], [301.0, 1368.0], [301.0, 1520.0], [275.0, 1520.0]], [[241.0, 1365.0], [268.0, 1365.0], [270.0, 1569.0], [243.0, 1569.0]]], "lines": ["あかりちゃん", "思いっきり", "信じてるけど", "どうすんのこれ？"]}], "img_path": "00057.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [116, 138, 626, 186], "vertical": false, "font_size": 45, "lines_coords": [[[116.0, 138.0], [622.0, 138.0], [622.0, 183.0], [116.0, 183.0]]], "lines": ["第４９話海の道と空の道"]}], "img_path": "00058.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1151, 135, 1208, 405], "vertical": true, "font_size": 26, "lines_coords": [[[1181.0, 135.0], [1207.0, 135.0], [1207.0, 281.0], [1181.0, 281.0]], [[1151.0, 135.0], [1177.0, 135.0], [1177.0, 405.0], [1151.0, 405.0]]], "lines": ["だんだん潮が", "引いてきたんじゃない？"]}, {"box": [605, 136, 675, 401], "vertical": true, "font_size": 32, "lines_coords": [[[637.0, 136.0], [675.0, 136.0], [675.0, 401.0], [637.0, 401.0]], [[605.0, 142.0], [631.0, 142.0], [631.0, 384.0], [605.0, 384.0]]], "lines": ["ほらさっき撮った", "写真と比べると．．．"]}, {"box": [1091, 757, 1153, 1059], "vertical": true, "font_size": 26, "lines_coords": [[[1126.0, 759.0], [1151.0, 759.0], [1151.0, 1057.0], [1126.0, 1057.0]], [[1091.0, 759.0], [1117.0, 759.0], [1117.0, 924.0], [1091.0, 924.0]]], "lines": ["そろそろ渡れるんやない", "あきちゃん！？"]}, {"box": [712, 466, 785, 671], "vertical": true, "font_size": 32, "lines_coords": [[[753.0, 470.0], [785.0, 470.0], [785.0, 641.0], [753.0, 641.0]], [[712.0, 466.0], [744.0, 466.0], [746.0, 671.0], [714.0, 671.0]]], "lines": ["うーん．．．", "そうかなぁ？"]}, {"box": [58, 466, 135, 640], "vertical": true, "font_size": 41, "lines_coords": [[[101.0, 472.0], [133.0, 472.0], [133.0, 639.0], [101.0, 639.0]], [[58.0, 466.0], [108.0, 466.0], [108.0, 543.0], [58.0, 543.0]]], "lines": ["あホントだ", "ねぇ"]}, {"box": [253, 826, 341, 980], "vertical": true, "font_size": 37, "lines_coords": [[[305.0, 830.0], [339.0, 830.0], [339.0, 976.0], [305.0, 976.0]], [[258.0, 826.0], [298.0, 828.0], [292.0, 980.0], [253.0, 978.0]]], "lines": ["そうだな", "行くか！！"]}, {"box": [1143, 1183, 1211, 1434], "vertical": true, "font_size": 26, "lines_coords": [[[1183.0, 1186.0], [1209.0, 1186.0], [1209.0, 1398.0], [1183.0, 1398.0]], [[1143.0, 1183.0], [1170.0, 1183.0], [1170.0, 1434.0], [1143.0, 1434.0]]], "lines": ["真ん中とかまだ", "道できてないぞ？"]}, {"box": [691, 1177, 763, 1423], "vertical": true, "font_size": 27, "lines_coords": [[[733.0, 1181.0], [759.0, 1181.0], [759.0, 1423.0], [733.0, 1423.0]], [[691.0, 1177.0], [720.0, 1177.0], [721.0, 1359.0], [693.0, 1359.0]]], "lines": ["けどほちほち渡り", "始めとるなぁ"]}, {"box": [545, 1183, 650, 1530], "vertical": true, "font_size": 29, "lines_coords": [[[616.0, 1183.0], [650.0, 1183.0], [650.0, 1273.0], [616.0, 1273.0]], [[583.0, 1185.0], [609.0, 1185.0], [609.0, 1530.0], [583.0, 1530.0]], [[545.0, 1183.0], [571.0, 1183.0], [571.0, 1355.0], [545.0, 1355.0]]], "lines": ["みんな", "どんほろ」を目指して渡り", "始めたんや！！"]}], "img_path": "00059.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1153, 151, 1230, 335], "vertical": true, "font_size": 23, "lines_coords": [[[1205.0, 151.0], [1230.0, 151.0], [1230.0, 335.0], [1205.0, 335.0]], [[1179.0, 151.0], [1203.0, 151.0], [1203.0, 313.0], [1179.0, 313.0]], [[1153.0, 153.0], [1173.0, 153.0], [1173.0, 290.0], [1153.0, 290.0]]], "lines": ["うちらも急がんと", "食べそこなって", "まうでーっ！！"]}, {"box": [742, 155, 806, 326], "vertical": true, "font_size": 31, "lines_coords": [[[766.0, 157.0], [802.0, 155.0], [806.0, 245.0], [770.0, 247.0]], [[742.0, 163.0], [768.0, 163.0], [768.0, 326.0], [742.0, 326.0]]], "lines": ["行くぞ", "お前らーっ！！"]}, {"box": [673, 365, 727, 551], "vertical": true, "font_size": 27, "lines_coords": [[[697.0, 365.0], [727.0, 365.0], [727.0, 416.0], [697.0, 416.0]], [[673.0, 367.0], [697.0, 367.0], [697.0, 551.0], [673.0, 551.0]]], "lines": ["もー", "しょうがないなぁ"]}, {"box": [268, 142, 326, 339], "vertical": true, "font_size": 26, "lines_coords": [[[300.0, 146.0], [326.0, 146.0], [326.0, 290.0], [300.0, 290.0]], [[268.0, 142.0], [294.0, 142.0], [296.0, 339.0], [270.0, 339.0]]], "lines": ["ごめんなさい", "遅くなっちゃって"]}, {"box": [135, 363, 200, 557], "vertical": true, "font_size": 29, "lines_coords": [[[168.0, 363.0], [200.0, 363.0], [200.0, 465.0], [168.0, 465.0]], [[135.0, 363.0], [161.0, 363.0], [163.0, 556.0], [136.0, 556.0]]], "lines": ["あ先生", "おつかれ様です"]}, {"box": [1096, 682, 1207, 960], "vertical": true, "font_size": 32, "lines_coords": [[[1170.0, 684.0], [1207.0, 684.0], [1207.0, 900.0], [1170.0, 900.0]], [[1134.0, 684.0], [1166.0, 684.0], [1166.0, 960.0], [1134.0, 960.0]], [[1098.0, 682.0], [1126.0, 682.0], [1125.0, 898.0], [1096.0, 898.0]]], "lines": ["今からトンボロ", "渡りますけど先生は", "どうしますか？"]}, {"box": [309, 660, 373, 1019], "vertical": true, "font_size": 29, "lines_coords": [[[341.0, 661.0], [373.0, 661.0], [373.0, 969.0], [341.0, 969.0]], [[309.0, 663.0], [335.0, 663.0], [335.0, 1018.0], [309.0, 1018.0]]], "lines": ["私はここで見てますから", "気をつけて行ってきて下さい"]}, {"box": [693, 1372, 763, 1415], "vertical": false, "font_size": 43, "lines_coords": [[[693.0, 1372.0], [763.0, 1372.0], [763.0, 1415.0], [693.0, 1415.0]]], "lines": ["いってきま"]}, {"box": [159, 894, 196, 1100], "vertical": true, "font_size": 37, "lines_coords": [[[159.0, 894.0], [196.0, 894.0], [196.0, 1100.0], [159.0, 1100.0]]], "lines": ["分かりました"]}], "img_path": "00060.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1153, 206, 1209, 360], "vertical": true, "font_size": 26, "lines_coords": [[[1181.0, 206.0], [1207.0, 206.0], [1209.0, 360.0], [1183.0, 360.0]], [[1153.0, 208.0], [1179.0, 208.0], [1179.0, 313.0], [1153.0, 313.0]]], "lines": ["岩がゴロゴロ", "してて．．．"]}, {"box": [1095, 361, 1151, 519], "vertical": true, "font_size": 26, "lines_coords": [[[1125.0, 361.0], [115