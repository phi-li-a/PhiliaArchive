"lines_coords": [[[135.0, 78.0], [510.0, 78.0], [510.0, 105.0], [135.0, 105.0]]], "lines": ["放課後７６燃やして発電"]}, {"box": [160, 308, 229, 830], "vertical": true, "font_size": 27, "lines_coords": [[[196.0, 309.0], [225.0, 309.0], [226.0, 830.0], [198.0, 830.0]], [[161.0, 311.0], [187.0, 311.0], [187.0, 710.0], [161.0, 710.0]]], "lines": ["アウトドアで使えるＵＳＢ発電機って", "結構商品化されとるんやねえ"]}, {"box": [1134, 930, 1207, 1266], "vertical": true, "font_size": 29, "lines_coords": [[[1175.0, 930.0], [1207.0, 930.0], [1207.0, 1233.0], [1175.0, 1233.0]], [[1134.0, 931.0], [1160.0, 931.0], [1160.0, 1265.0], [1134.0, 1265.0]]], "lines": ["うちらもスマホとか", "タフレットよく使うし"]}, {"box": [699, 913, 777, 1252], "vertical": true, "font_size": 32, "lines_coords": [[[744.0, 916.0], [776.0, 916.0], [776.0, 1252.0], [744.0, 1252.0]], [[699.0, 913.0], [731.0, 913.0], [731.0, 1115.0], [699.0, 1115.0]]], "lines": ["キャンプの電源確保は", "重要だよなぁ"]}, {"box": [604, 931, 637, 1199], "vertical": true, "font_size": 26, "lines_coords": [[[605.0, 931.0], [631.0, 931.0], [631.0, 1198.0], [605.0, 1198.0]]], "lines": ["そういえばあたし"]}, {"box": [165, 918, 238, 1400], "vertical": true, "font_size": 29, "lines_coords": [[[204.0, 918.0], [236.0, 918.0], [236.0, 1400.0], [204.0, 1400.0]], [[165.0, 920.0], [191.0, 920.0], [191.0, 1171.0], [165.0, 1171.0]]], "lines": ["この新燃やして発電する奴見ると、", "いつも思うんだよ"]}, {"box": [712, 1530, 744, 1661], "vertical": true, "font_size": 32, "lines_coords": [[[712.0, 1530.0], [744.0, 1530.0], [744.0, 1661.0], [712.0, 1661.0]]], "lines": ["せやなぁ"]}], "img_path": "00173.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1163, 146, 1199, 548], "vertical": true, "font_size": 26, "lines_coords": [[[1166.0, 146.0], [1192.0, 146.0], [1192.0, 547.0], [1166.0, 547.0]]], "lines": ["物燃やして発電できるなら、"]}, {"box": [573, 140, 641, 508], "vertical": true, "font_size": 28, "lines_coords": [[[615.0, 142.0], [641.0, 142.0], [641.0, 508.0], [615.0, 508.0]], [[573.0, 140.0], [605.0, 140.0], [605.0, 418.0], [573.0, 418.0]]], "lines": ["脂肪を燃やして電気を作る", "発電機とかもいつか"]}, {"box": [519, 204, 545, 538], "vertical": true, "font_size": 28, "lines_coords": [[[519.0, 204.0], [545.0, 204.0], [545.0, 538.0], [519.0, 538.0]]], "lines": ["できんじゃねぇかってさ"]}, {"box": [1114, 1425, 1149, 1661], "vertical": true, "font_size": 32, "lines_coords": [[[1115.0, 1426.0], [1147.0, 1426.0], [1147.0, 1661.0], [1115.0, 1661.0]]], "lines": ["人類のユメやな"]}, {"box": [618, 1462, 661, 1539], "vertical": true, "font_size": 43, "lines_coords": [[[618.0, 1462.0], [661.0, 1462.0], [661.0, 1539.0], [618.0, 1539.0]]], "lines": ["うむ"]}], "img_path": "00174.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1132, 155, 1198, 447], "vertical": true, "font_size": 26, "lines_coords": [[[1168.0, 157.0], [1194.0, 157.0], [1194.0, 330.0], [1168.0, 330.0]], [[1132.0, 155.0], [1158.0, 155.0], [1158.0, 446.0], [1132.0, 446.0]]], "lines": ["最近本格的に", "寒くなって来たよねー"]}, {"box": [1033, 258, 1061, 373], "vertical": true, "font_size": 26, "lines_coords": [[[1033.0, 260.0], [1059.0, 260.0], [1059.0, 373.0], [1033.0, 373.0]]], "lines": ["だよねー"]}, {"box": [866, 195, 969, 489], "vertical": true, "font_size": 28, "lines_coords": [[[933.0, 195.0], [965.0, 195.0], [969.0, 489.0], [937.0, 489.0]], [[901.0, 196.0], [928.0, 196.0], [928.0, 485.0], [901.0, 485.0]], [[866.0, 195.0], [892.0, 195.0], [892.0, 429.0], [866.0, 429.0]]], "lines": ["いっつも思うんだけど", "お店に並ぶの９月って", "気が早すぎだよね"]}, {"box": [780, 360, 807, 550], "vertical": true, "font_size": 26, "lines_coords": [[[780.0, 360.0], [806.0, 360.0], [806.0, 547.0], [780.0, 547.0]]], "lines": ["それわかるー"]}, {"box": [613, 180, 684, 586], "vertical": true, "font_size": 32, "lines_coords": [[[650.0, 181.0], [682.0, 181.0], [684.0, 553.0], [652.0, 553.0]], [[613.0, 183.0], [645.0, 183.0], [645.0, 586.0], [613.0, 586.0]]], "lines": ["そういえばこの前ちょっと", "怖い喧耳にしたんだけどさ．．．"]}, {"box": [202, 82, 575, 108], "vertical": false, "font_size": 26, "lines_coords": [[[202.0, 82.0], [575.0, 82.0], [575.0, 108.0], [202.0, 108.0]]], "lines": ["後７７つぶし下焼くやつ"]}, {"box": [193, 183, 221, 384], "vertical": true, "font_size": 24, "lines_coords": [[[193.0, 185.0], [217.0, 185.0], [217.0, 380.0], [193.0, 380.0]]], "lines": ["えなになに？"]}, {"box": [1138, 958, 1210, 1513], "vertical": true, "font_size": 29, "lines_coords": [[[1179.0, 961.0], [1205.0, 961.0], [1205.0, 1513.0], [1179.0, 1513.0]], [[1138.0, 958.0], [1170.0, 958.0], [1170.0, 1421.0], [1138.0, 1421.0]]], "lines": ["私たちを熱した鉄板で押しつぶしてから", "「食べる人間が増えてるらしいのよ」"]}, {"box": [463, 935, 538, 1376], "vertical": true, "font_size": 32, "lines_coords": [[[504.0, 935.0], [536.0, 935.0], [536.0, 1306.0], [504.0, 1306.0]], [[463.0, 935.0], [495.0, 935.0], [495.0, 1376.0], [463.0, 1376.0]]], "lines": ["そのまま食べられるのに", "そんなヒドいことされるの！？"]}, {"box": [183, 1002, 213, 1185], "vertical": true, "font_size": 27, "lines_coords": [[[183.0, 1003.0], [210.0, 1003.0], [210.0, 1185.0], [183.0, 1185.0]]], "lines": ["うわーん！！"]}, {"box": [592, 1449, 680, 1730], "vertical": true, "font_size": 36, "lines_coords": [[[635.0, 1451.0], [675.0, 1449.0], [680.0, 1612.0], [641.0, 1614.0]], [[594.0, 1455.0], [626.0, 1455.0], [626.0, 1730.0], [594.0, 1730.0]]], "lines": ["うそっ！", "なにそれ怖い！！"]}, {"box": [151, 1468, 228, 1741], "vertical": true, "font_size": 34, "lines_coords": [[[191.0, 1468.0], [228.0, 1468.0], [228.0, 1741.0], [191.0, 1741.0]], [[151.0, 1470.0], [183.0, 1470.0], [183.0, 1676.0], [151.0, 1676.0]]], "lines": ["ちょっとピザまん", "泣いてるの？"]}], "img_path": "00175.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1136, 147, 1213, 486], "vertical": true, "font_size": 36, "lines_coords": [[[1173.0, 148.0], [1213.0, 148.0], [1213.0, 279.0], [1173.0, 279.0]], [[1136.0, 148.0], [1168.0, 148.0], [1168.0, 485.0], [1136.0, 485.0]]], "lines": ["アハハハ", "ピザまんビビりすぎー"]}, {"box": [611, 183, 648, 573], "vertical": true, "font_size": 26, "lines_coords": [[[615.0, 191.0], [641.0, 191.0], [641.0, 573.0], [615.0, 573.0]]], "lines": ["ほらあの人みたいにさー"]}, {"box": [1051, 564, 1128, 832], "vertical": true, "font_size": 34, "lines_coords": [[[1091.0, 564.0], [1128.0, 564.0], [1128.0, 832.0], [1091.0, 832.0]], [[1051.0, 564.0], [1083.0, 564.0], [1083.0, 765.0], [1051.0, 765.0]]], "lines": ["ていうかそんなの", "作り話だって"]}, {"box": [710, 438, 941, 554], "vertical": false, "font_size": 34, "lines_coords": [[[720.0, 438.0], [939.0, 442.0], [939.0, 476.0], [720.0, 472.0]]], "lines": ["ジューシー肝好まん"]}, {"box": [735, 566, 879, 845], "vertical": true, "font_size": 30, "lines_coords": [[[841.0, 568.0], [877.0, 568.0], [879.0, 693.0], [843.0, 693.0]], [[804.0, 566.0], [838.0, 566.0], [841.0, 785.0], [808.0, 785.0]], [[772.0, 570.0], [798.0, 570.0], [798.0, 843.0], [772.0, 843.0]], [[735.0, 571.0], [761.0, 571.0], [761.0, 845.0], [735.0, 845.0]]], "lines": ["寒い日に", "私たちを買って", "家まで我慢できる人", "いるわけないじゃん"]}, {"box": [489, 904, 693, 941], "vertical": false, "font_size": 32, "lines_coords": [[[495.0, 909.0], [690.0, 905.0], [690.0, 937.0], [495.0, 941.0]]], "lines": ["ハハローハンや"]}, {"box": [1040, 911, 1159, 1245], "vertical": true, "font_size": 32, "lines_coords": [[[1125.0, 913.0], [1156.0, 913.0], [1156.0, 1215.0], [1125.0, 1215.0]], [[1081.0, 915.0], [1113.0, 915.0], [1113.0, 1245.0], [1081.0, 1245.0]], [[1040.0, 913.0], [1072.0, 913.0], [1072.0, 1215.0], [1040.0, 1215.0]]], "lines": ["言うの忘れてたけど、", "一番被害にあってるの", "豚まんらしいわよ？"]}, {"box": [292, 991, 329, 1175], "vertical": true, "font_size": 34, "lines_coords": [[[292.0, 995.0], [326.0, 995.0], [326.0, 1173.0], [292.0, 1173.0]]], "lines": ["．．．えっ？"]}, {"box": [1051, 1353, 1183, 1723], "vertical": true, "font_size": 39, "lines_coords": [[[1143.0, 1353.0], [1183.0, 1353.0], [1183.0, 1653.0], [1143.0, 1653.0]], [[1098.0, 1357.0], [1136.0, 1357.0], [1136.0, 1723.0], [1098.0, 1723.0]], [[1051.0, 1355.0], [1089.0, 1355.0], [1089.0, 1578.0], [1051.0, 1578.0]]], "lines": ["ヤメテェエエエ！！", "つぶして焼かれるのは", "イヤァアア！！"]}, {"box": [174, 1398, 225, 1638], "vertical": true, "font_size": 45, "lines_coords": [[[174.0, 1398.0], [219.0, 1398.0], [225.0, 1638.0], [180.0, 1638.0]]], "lines": ["買い辛いわ。"]}], "img_path": "00176.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1128, 175, 1204, 581], "vertical": true, "font_size": 32, "lines_coords": [[[1171.0, 176.0], [1203.0, 176.0], [1203.0, 581.0], [1171.0, 581.0]], [[1128.0, 176.0], [1160.0, 176.0], [1160.0, 510.0], [1128.0, 510.0]]], "lines": ["具だくさんサンドイッチを", "ひろーいキャンプ場で"]}, {"box": [183, 75, 622, 108], "vertical": false, "font_size": 32, "lines_coords": [[[183.0, 76.0], [622.0, 75.0], [622.0, 106.0], [183.0, 108.0]]], "lines": ["課後７８サンドイッチむずい"]}, {"box": [275, 165, 350, 540], "vertical": true, "font_size": 33.0, "lines_coords": [[[315.0, 165.0], [348.0, 165.0], [350.0, 337.0], [316.0, 337.0]], [[275.0, 168.0], [307.0, 168.0], [307.0, 540.0], [275.0, 540.0]]], "lines": ["思いっきり", "かぶりついてみたいです"]}, {"box": [163, 375, 196, 714], "vertical": true, "font_size": 32, "lines_coords": [[[165.0, 375.0], [196.0, 375.0], [195.0, 714.0], [163.0, 714.0]]], "lines": ["キャンプのロマンやなぁ"]}, {"box": [1103, 885, 1171, 1158], "vertical": true, "font_size": 29, "lines_coords": [[[1138.0, 885.0], [1170.0, 885.0], [1170.0, 1130.0], [1138.0, 1130.0]], [[1104.0, 886.0], [1130.0, 886.0], [1130.0, 1158.0], [1104.0, 1158.0]]], "lines": ["でもあれ食べるの", "スキルいるんよねぇ"]}, {"box": [864, 866, 1046, 1239], "vertical": true, "font_size": 42, "lines_coords": [[[995.0, 866.0], [1046.0, 866.0], [1046.0, 943.0], [995.0, 943.0]], [[963.0, 868.0], [1008.0, 868.0], [1008.0, 943.0], [963.0, 943.0]], [[900.0, 898.0], [937.0, 898.0], [937.0, 1239.0], [900.0, 1239.0]], [[864.0, 900.0], [898.0, 900.0], [898.0, 1023.0], [864.0, 1023.0]]], "lines": ["そう", "そう", "私サンドイッチ食べると", "いっつも"]}, {"box": [262, 885, 292, 1159], "vertical": true, "font_size": 26, "lines_coords": [[[262.0, 888.0], [288.0, 888.0], [288.0, 1156.0], [262.0, 1156.0]]], "lines": ["ってなっちゃうもん"]}, {"box": [1080, 1350, 1155, 1689], "vertical": true, "font_size": 34, "lines_coords": [[[1117.0, 1350.0], [1155.0, 1350.0], [1155.0, 1659.0], [1117.0, 1659.0]], [[1080.0, 1351.0], [1111.0, 1351.0], [1111.0, 1689.0], [1080.0, 1689.0]]], "lines": ["具だくさんサンドは", "ホットサンドにすれば"]}, {"box": [200, 1389, 283, 1629], "vertical": true, "font_size": 35, "lines_coords": [[[247.0, 1393.0], [279.0, 1393.0], [279.0, 1627.0], [247.0, 1627.0]], [[204.0, 1389.0], [241.0, 1389.0], [238.0, 1595.0], [200.0, 1595.0]]], "lines": ["具が圧縮されて", "食べやすいぜ"]}], "img_path": "00177.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1124, 165, 1200, 416], "vertical": true, "font_size": 38, "lines_coords": [[[1156.0, 165.0], [1200.0, 165.0], [1200.0, 208.0], [1156.0, 208.0]], [[1125.0, 168.0], [1156.0, 168.0], [1156.0, 416.0], [1125.0, 416.0]]], "lines": ["具", "入れすぎやない？"]}, {"box": [780, 140, 817, 339], "vertical": true, "font_size": 36, "lines_coords": [[[780.0, 140.0], [817.0, 140.0], [817.0, 339.0], [780.0, 339.0]]], "lines": ["へーキヘーキ"]}, {"box": [682, 228, 759, 571], "vertical": true, "font_size": 36, "lines_coords": [[[720.0, 228.0], [759.0, 228.0], [757.0, 571.0], [718.0, 571.0]], [[682.0, 234.0], [714.0, 234.0], [714.0, 538.0], [682.0, 538.0]]], "lines": ["こうやって思いっ切り", "押しつぶせ：ばつ！！"]}, {"box": [545, 645, 592, 796], "vertical": true, "font_size": 47, "lines_coords": [[[545.0, 646.0], [592.0, 646.0], [592.0, 796.0], [545.0, 796.0]]], "lines": ["あっ！！"]}, {"box": [316, 571, 431, 821], "vertical": true, "font_size": 56, "lines_coords": [[[369.0, 571.0], [427.0, 571.0], [431.0, 821.0], [373.0, 821.0]], [[316.0, 573.0], [369.0, 573.0], [369.0, 725.0], [316.0, 725.0]]], "lines": ["ハンバーグ", "がっ！！"]}, {"box": [815, 1168, 856, 1265], "vertical": true, "font_size": 41, "lines_coords": [[[815.0, 1168.0], [856.0, 1168.0], [856.0, 1265.0], [815.0, 1265.0]]], "lines": ["スポッ"]}, {"box": [158, 928, 257, 1273], "vertical": true, "font_size": 42, "lines_coords": [[[211.0, 928.0], [256.0, 928.0], [256.0, 1190.0], [211.0, 1190.0]], [[161.0, 930.0], [200.0, 930.0], [200.0, 1273.0], [161.0, 1273.0]]], "lines": ["あきちゃんの", "カバンの中にっ！！"]}, {"box": [1100, 1361, 1173, 1561], "vertical": true, "font_size": 36, "lines_coords": [[[1134.0, 1361.0], [1173.0, 1361.0], [1173.0, 1396.0], [1134.0, 1396.0]], [[1100.0, 1363.0], [1132.0, 1363.0], [1132.0, 1560.0], [1100.0, 1560.0]]], "lines": ["か", "かばんサンド。"]}, {"box": [309, 1402, 416, 1556], "vertical": true, "font_size": 51, "lines_coords": [[[361.0, 1402.0], [416.0, 1402.0], [416.0, 1539.0], [361.0, 1539.0]], [[309.0, 1408.0], [356.0, 1406.0], [361.0, 1554.0], [315.0, 1556.0]]], "lines": ["食うて", "みいや。"]}], "img_path": "00178.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [551, 108, 1231, 185], "vertical": false, "font_size": 30, "lines_coords": [[[768.0, 106.0], [1231.0, 106.0], [1231.0, 142.0], [768.0, 142.0]], [[577.0, 149.0], [1228.0, 149.0], [1228.0, 178.0], [577.0, 178.0]]], "lines": ["ゆるキャン△＠ｖかがでしたでしょうか。", "今回は伊豆キャンプ完結編とヘヤキャンを収録致しました。"]}, {"box": [405, 232, 1231, 260], "vertical": false, "font_size": 26, "lines_coords": [[[405.0, 234.0], [1231.0, 232.0], [1231.0, 258.0], [405.0, 260.0]]], "lines": ["これで伊豆傷はおしまいいですが、他にも見どころはたくさんありますので"]}, {"box": [412, 358, 1233, 382], "vertical": false, "font_size": 24, "lines_coords": [[[412.0, 358.0], [1233.0, 358.0], [1233.0, 382.0], [412.0, 382.0]]], "lines": ["冷暖房がかかっていて２度と出たくなくなる門脇埼灯台がおすすめです。"]}, {"box": [622, 273, 1230, 300], "vertical": false, "font_size": 27, "lines_coords": [[[622.0, 273.0], [1230.0, 273.0], [1230.0, 300.0], [622.0, 300.0]]], "lines": ["伊豆に興味の湧いた方はぜひ実際に訪れてみて下さい。"]}, {"box": [1074, 438, 1226, 461], "vertical": false, "font_size": 21, "lines_coords": [[[1074.0, 438.0], [1226.0, 440.0], [1226.0, 461.0], [1074.0, 459.0]]], "lines": ["あｆろでした。"]}, {"box": [105, 1619, 698, 1773], "vertical": false, "font_size": 33, "lines_coords": [[[105.0, 1626.0], [204.0, 1626.0], [204.0, 1658.0], [105.0, 1658.0]], [[105.0, 1647.0], [667.0, 1652.0], [667.0, 1690.0], [105.0, 1684.0]], [[108.0, 1708.0], [232.0, 1705.0], [232.0, 1744.0], [108.0, 1748.0]], [[105.0, 1740.0], [431.0, 1740.0], [431.0, 1773.0], [105.0, 1773.0]]], "lines": ["〈初出一覧〉《．．．", "２０１７年００月２７日の平成３１年４月に分〜令和元年８月掲載分▼中９１年１日０日まで", "きららベース描き下ろし", "＊御さんつい、本当は以上の内容を収録しました。"]}, {"box": [113, 1618, 695, 1771], "vertical": false, "font_size": 33, "lines_coords": [[[116.0, 1678.0], [691.0, 1680.0], [691.0, 1713.0], [116.0, 1711.0]]], "lines": ["きららベース、平成茨３０年８月７日〜平成３１年１月８日更新分"]}], "img_path": "00179.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [635, 243, 658, 416], "vertical": true, "font_size": 19, "lines_coords": [[[635.0, 243.0], [654.0, 243.0], [654.0, 412.0], [635.0, 412.0]]], "lines": ["ジオスボ３５カ所目"]}, {"box": [568, 286, 613, 465], "vertical": true, "font_size": 20, "lines_coords": [[[594.0, 288.0], [613.0, 288.0], [613.0, 451.0], [594.0, 451.0]], [[570.0, 286.0], [590.0, 286.0], [588.0, 465.0], [568.0, 465.0]]], "lines": ["い伊豆ジオスポは", "全部で９０カ所以上．．．"]}, {"box": [367, 369, 414, 570], "vertical": true, "font_size": 22, "lines_coords": [[[390.0, 369.0], [414.0, 369.0], [414.0, 570.0], [390.0, 570.0]], [[369.0, 369.0], [390.0, 369.0], [388.0, 525.0], [367.0, 525.0]]], "lines": ["２巻で全部回るなんて", "無茶やったんや！！"]}, {"box": [208, 264, 257, 525], "vertical": true, "font_size": 23, "lines_coords": [[[234.0, 268.0], [255.0, 268.0], [255.0, 406.0], [234.0, 406.0]], [[208.0, 264.0], [232.0, 264.0], [236.0, 525.0], [211.0, 525.0]]], "lines": ["諦めるなイヌ子", "こうなったら奥の手を使う！！"]}, {"box": [729, 412, 1083, 598], "vertical": false, "font_size": 101.0, "lines_coords": [[[742.0, 425.0], [1027.0, 450.0], [1014.0, 598.0], [729.0, 573.0]], [[810.0, 412.0], [1083.0, 412.0], [1083.0, 465.0], [810.0, 465.0]]], "lines": ["Ａｍａｚｏｎ本はするい上げやありがとうございます", "Ａｍａｚｏｎ機能は、"]}, {"box": [583, 622, 631, 817], "vertical": true, "font_size": 24, "lines_coords": [[[607.0, 622.0], [631.0, 622.0], [631.0, 817.0], [607.0, 817.0]], [[583.0, 624.0], [607.0, 624.0], [607.0, 798.0], [583.0, 798.0]]], "lines": ["こいつに乗って残りは", "一気に回るんだっ！！"]}, {"box": [320, 829, 434, 861], "vertical": false, "font_size": 19, "lines_coords": [[[346.0, 830.0], [406.0, 830.0], [406.0, 849.0], [346.0, 849.0]]], "lines": ["１０棟合体"]}, {"box": [238, 669, 264, 787], "vertical": true, "font_size": 26, "lines_coords": [[[238.0, 669.0], [264.0, 669.0], [264.0, 787.0], [238.0, 787.0]]], "lines": ["なんやこれ"]}, {"box": [210, 727, 236, 785], "vertical": true, "font_size": 26, "lines_coords": [[[210.0, 727.0], [236.0, 727.0], [236.0, 785.0], [210.0, 785.0]]], "lines": ["っ！？"]}, {"box": [585, 982, 630, 1200], "vertical": true, "font_size": 22, "lines_coords": [[[605.0, 982.0], [630.0, 982.0], [630.0, 1200.0], [605.0, 1200.0]], [[585.0, 984.0], [605.0, 984.0], [605.0, 1121.0], [585.0, 1121.0]]], "lines": ["これは本編とは関係ない", "おまけマンガだ"]}, {"box": [271, 993, 318, 1155], "vertical": true, "font_size": 22, "lines_coords": [[[294.0, 993.0], [318.0, 993.0], [318.0, 1155.0], [294.0, 1155.0]], [[271.0, 993.0], [290.0, 993.0], [290.0, 1113.0], [271.0, 1113.0]]], "lines": ["多少の設定崩壊は", "問題ないっ！！"]}, {"box": [215, 1141, 264, 1273], "vertical": true, "font_size": 21, "lines_coords": [[[241.0, 1141.0], [262.0, 1141.0], [262.0, 1273.0], [241.0, 1273.0]], [[215.0, 1141.0], [236.0, 1141.0], [236.0, 1254.0], [215.0, 1254.0]]], "lines": ["多少どころや", "ないわっ！！"]}, {"box": [575, 1346, 628, 1621], "vertical": true, "font_size": 23, "lines_coords": [[[603.0, 1346.0], [628.0, 1346.0], [628.0, 1621.0], [603.0, 1621.0]], [[575.0, 1348.0], [596.0, 1348.0], [598.0, 1537.0], [577.0, 1537.0]]], "lines": ["こうして二人は残りのジオスポを", "一日で回りきったそうな"]}, {"box": [225, 1362, 282, 1575], "vertical": true, "font_size": 25, "lines_coords": [[[255.0, 1363.0], [281.0, 1363.0], [281.0, 1500.0], [255.0, 1500.0]], [[225.0, 1363.0], [249.0, 1363.0], [249.0, 1575.0], [225.0, 1575.0]]], "lines": ["ゆるキャン△", "伊豆ジオスポ激闘編"]}], "img_path": "00180.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [395, 796, 611, 900], "vertical": false, "font_size": 39.0, "lines_coords": [[[397.0, 796.0], [611.0, 796.0], [611.0, 834.0], [397.0, 834.0]], [[395.0, 860.0], [495.0, 860.0], [495.0, 900.0], [395.0, 900.0]]], "lines": ["著者：あｆろ", "©ａｆｒｏ"]}, {"box": [416, 618, 933, 673], "vertical": false, "font_size": 52.0, "lines_coords": [[[416.0, 618.0], [796.0, 622.0], [796.0, 673.0], [416.0, 669.0]], [[778.0, 620.0], [933.0, 620.0], [933.0, 673.0], [778.0, 673.0]]], "lines": ["ゆるキャン△第", "第９巻"]}, {"box": [393, 979, 963, 1229], "vertical": false, "font_size": 36, "lines_coords": [[[393.0, 993.0], [946.0, 990.0], [946.0, 1027.0], [393.0, 1031.0]], [[397.0, 1059.0], [691.0, 1059.0], [691.0, 1096.0], [397.0, 1096.0]], [[399.0, 1123.0], [800.0, 1126.0], [800.0, 1158.0], [399.0, 1155.0]], [[543.0, 1188.0], [950.0, 1188.0], [950.0, 1226.0], [543.0, 1226.0]]], "lines": ["電子版発行日：２０２０年２月１５日", "発行人・東・敬彰・", "発行所：株式会社芳文社", "東京都文京区後楽１－２－１２"]}], "img_path": "00181.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [258, 660, 551, 781], "vertical": false, "font_size": 103, "lines_coords": [[[266.0, 660.0], [551.0, 678.0], [543.0, 781.0], [258.0, 763.0]]], "lines": ["ゆるホこル。"]}, {"box": [663, 1091, 682, 1203], "vertical": true, "font_size": 19, "lines_coords": [[[663.0, 1091.0], [682.0, 1091.0], [682.0, 1203.0], [663.0, 1203.0]]], "lines": ["し、いいわ。よくし"]}], "img_path": "00182.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1240, 597, 1274, 678], "vertical": true, "font_size": 34, "lines_coords": [[[1240.0, 597.0], [1274.0, 597.0], [1274.0, 678.0], [1240.0, 678.0]]], "lines": ["なーあおいちゃん何で心に太いて書いて"]}, {"box": [1104, 591, 1118, 675], "vertical": true, "font_size": 14, "lines_coords": [[[1104.0, 591.0], [1118.0, 591.0], [1118.0, 675.0], [1104.0, 675.0]]], "lines": ["心太」って読むん？"]}, {"box": [1231, 783, 1275, 907], "vertical": true, "font_size": 44, "lines_coords": [[[1231.0, 783.0], [1275.0, 783.0], [1275.0, 907.0], [1231.0, 907.0]]], "lines": ["心太の元になる海藻ん中には毒を持つもんがあるんやけど"]}, {"box": [973, 595, 995, 684], "vertical": true, "font_size": 22, "lines_coords": [[[973.0, 595.0], [995.0, 595.0], [995.0, 684.0], [973.0, 684.0]]], "lines": ["ていうかこの「ところでん突き」て"]}, {"box": [1047, 786, 1075, 912], "vertical": true, "font_size": 28, "lines_coords": [[[1047.0, 786.0], [1075.0, 786.0], [1075.0, 912.0], [1047.0, 912.0]]], "lines": ["昔は薬のありなしを見分ける方法が無くて"]}, {"box": [969, 776, 1005, 905], "vertical": true, "font_size": 32, "lines_coords": [[[969.0, 776.0], [1001.0, 776.0], [1005.0, 905.0], [973.0, 905.0]]], "lines": ["かわいいイラストの形に切れるやつとかあったら"]}, {"box": [648, 510, 701, 555], "vertical": false, "font_size": 45, "lines_coords": [[[648.0, 510.0], [701.0, 510.0], [701.0, 555.0], [648.0, 555.0]]], "lines": ["ん？"]}, {"box": [785, 624, 810, 737], "vertical": true, "font_size": 25, "lines_coords": [[[785.0, 624.0], [810.0, 624.0], [810.0, 737.0], [785.0, 737.0]]], "lines": ["四角く切れるやつしかないんかなー"]}, {"box": [780, 784, 806, 853], "vertical": true, "font_size": 20, "lines_coords": [[[780.0, 789.0], [800.0, 789.0], [800.0, 851.0], [780.0, 851.0]]], "lines": ["どうんやけど"]}, {"box": [780, 873, 819, 918], "vertical": true, "font_size": 39, "lines_coords": [[[780.0, 873.0], [819.0, 873.0], [819.0, 918.0], [780.0, 918.0]]], "lines": ["かわいいイラストかあ．．．"]}, {"box": [643, 608, 702, 975], "vertical": true, "font_size": 58, "lines_coords": [[[643.0, 611.0], [701.0, 611.0], [701.0, 975.0], [643.0, 975.0]]], "lines": ["ゆるキャゾ△"]}, {"box": [449, 673, 584, 741], "vertical": false, "font_size": 68, "lines_coords": [[[449.0, 673.0], [584.0, 673.0], [584.0, 741.0], [449.0, 741.0]]], "lines": ["山姉妹"]}, {"box": [243, 583, 284, 723], "vertical": true, "font_size": 21, "lines_coords": [[[260.0, 583.0], [281.0, 583.0], [283.0, 723.0], [262.0, 723.0]], [[243.0, 586.0], [264.0, 586.0], [264.0, 695.0], [243.0, 695.0]]], "lines": ["伊豆みやげに天草を", "買って来たので"]}, {"box": [61, 584, 101, 668], "vertical": true, "font_size": 20, "lines_coords": [[[80.0, 586.0], [101.0, 586.0], [101.0, 663.0], [80.0, 663.0]], [[61.0, 585.0], [80.0, 585.0], [80.0, 667.0], [61.0, 667.0]]], "lines": ["ところてん", "作ってみた。"]}, {"box": [265, 865, 282, 926], "vertical": true, "font_size": 17, "lines_coords": [[[265.0, 865.0], [282.0, 865.0], [282.0, 926.0], [265.0, 926.0]]], "lines": ["おぉーっ"]}, {"box": [63, 776, 105, 841], "vertical": true, "font_size": 27, "lines_coords": [[[78.0, 776.0], [105.0, 776.0], [105.0, 841.0], [78.0, 841.0]]], "lines": ["おもろ"]}, {"box": [1235, 973, 1271, 1113], "vertical": true, "font_size": 20, "lines_coords": [[[1246.0, 973.0], [1267.0, 973.0], [1271.0, 1063.0], [1250.0, 1063.0]], [[1237.0, 1010.0], [1256.0, 1010.0], [1254.0, 1113.0], [1235.0, 1113.0]]], "lines": ["沢山の人たちが食中毒ニャッ", "母になっとったんよ"]}, {"box": [1242, 1173, 1265, 1306], "vertical": true, "font_size": 23, "lines_coords": [[[1242.0, 1173.0], [1265.0, 1173.0], [1265.0, 1306.0], [1242.0, 1306.0]]], "lines": ["「心が鍛えられる図太くなる」ゆうて「心太」って"]}, {"box": [1046, 971, 1077, 1125], "vertical": true, "font_size": 26, "lines_coords": [[[1046.0, 971.0], [1072.0, 971.0], [1076.0, 1125.0], [1050.0, 1125.0]]], "lines": ["せやから心太を食べるんは、度胸試しの意味もあってな"]}, {"box": [974, 977, 1000, 1100], "vertical": true, "font_size": 26, "lines_coords": [[[974.0, 977.0], [1000.0, 977.0], [1000.0, 1100.0], [974.0, 1100.0]]], "lines": ["逆にむっちゃ怖い心太ができそうやな．．．"]}, {"box": [1053, 1164, 1074, 1239], "vertical": true, "font_size": 21, "lines_coords": [[[1053.0, 1164.0], [1074.0, 1164.0], [1074.0, 1239.0], [1053.0, 1239.0]]], "lines": ["呼ばれるようになったんやでー"]}, {"box": [1047, 1257, 1078, 1300], "vertical": true, "font_size": 31, "lines_coords": [[[1047.0, 1257.0], [1078.0, 1257.0], [1078.0, 1300.0], [1047.0, 1300.0]]], "lines": ["えーっ！！"]}, {"box": [660, 938, 688, 1043], "vertical": true, "font_size": 28, "lines_coords": [[[660.0, 938.0], [688.0, 938.0], [688.0, 1043.0], [660.0, 1043.0]]], "lines": ["ｈｉｇｈｓｏｈｏｏｌｄｉｎｓＱｏｙｕｒｕｃｏｏｍｐｉｎｄｉｃｒｅ"]}, {"box": [807, 1185, 838, 1252], "vertical": true, "font_size": 31, "lines_coords": [[[807.0, 1185.0], [838.0, 1185.0], [838.0, 1252.0], [807.0, 1252.0]]], "lines": ["って作りすぎや"]}, {"box": [652, 1203, 691, 1381], "vertical": true, "font_size": 39, "lines_coords": [[[652.0, 1203.0], [691.0, 1203.0], [691.0, 1381.0], [652.0, 1381.0]]], "lines": ["あｆこ"]}, {"box": [262, 1007, 274, 1050], "vertical": true, "font_size": 12, "lines_coords": [[[262.0, 1007.0], [274.0, 1007.0], [274.0, 1050.0], [262.0, 1050.0]]], "lines": ["．．．．．"]}, {"box": [262, 1164, 284, 1271], "vertical": true, "font_size": 21, "lines_coords": [[[262.0, 1164.0], [283.0, 1164.0], [283.0, 1269.0], [262.0, 1269.0]]], "lines": ["おもろーい！！"]}], "img_path": "00183.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [5, 0, 1384, 393], "vertical": false, "font_size": 238, "lines_coords": [[[54.0, 0.0], [1263.0, 0.0], [1263.0, 414.0], [54.0, 414.0]], [[1023.0, 294.0], [1263.0, 303.0], [1261.0, 386.0], [1021.0, 377.0]]], "lines": ["１９８５歳この年。", "早期期間は時間まで、"]}, {"box": [1029, 389, 1270, 525], "vertical": false, "font_size": 91, "lines_coords": [[[1038.0, 398.0], [1252.0, 402.0], [1250.0, 501.0], [1036.0, 497.0]]], "lines": ["あｆ３"]}, {"box": [1060, 1870, 1310, 1896], "vertical": false, "font_size": 28, "lines_coords": [[[1060.0, 1868.0], [1310.0, 1868.0], [1310.0, 1898.0], [1060.0, 1898.0]]], "lines": ["ｍａｎ．ｅｆｔｍｉｘｐ．ｃｏｍｉｃｓ"]}], "img_path": "cover.jpg"}]}