6.0, 1749.0], [1096.0, 1777.0], [896.0, 1777.0]], [[888.0, 1783.0], [1098.0, 1783.0], [1098.0, 1805.0], [888.0, 1805.0]]], "lines": ["ｎｉｇｎｓｓｈｏｏｌｇｉｒｉｓｇの", "ｙｕｒｕｅａｍｐｉｎｎｄｕｒｅ"]}], "img_path": "00003.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [151, 155, 371, 223], "vertical": false, "font_size": 33, "lines_coords": [[[151.0, 191.0], [365.0, 155.0], [371.0, 187.0], [157.0, 223.0]]], "lines": ["ｙｕｐｕｌｄｇｍｐ"]}, {"box": [266, 228, 1023, 401], "vertical": false, "font_size": 58.333333333333336, "lines_coords": [[[386.0, 236.0], [995.0, 228.0], [995.0, 292.0], [386.0, 300.0]], [[457.0, 303.0], [1023.0, 318.0], [1021.0, 384.0], [455.0, 369.0]], [[266.0, 356.0], [468.0, 326.0], [476.0, 371.0], [271.0, 401.0]]], "lines": ["第一話「本日の晩ごはん！！」のね", "早起きしまりんの抜け駆け温泉", "第一と話して、"]}, {"box": [371, 388, 975, 705], "vertical": false, "font_size": 68.5, "lines_coords": [[[373.0, 391.0], [975.0, 388.0], [975.0, 466.0], [373.0, 470.0]], [[427.0, 474.0], [958.0, 470.0], [958.0, 536.0], [427.0, 540.0]], [[371.0, 566.0], [913.0, 547.0], [915.0, 611.0], [373.0, 630.0]], [[421.0, 639.0], [961.0, 635.0], [961.0, 701.0], [421.0, 705.0]]], "lines": ["第１９話、海の道と空の道の道", "第回目話・バースデート・Ｏｎ－", "第三話、大室山はどんな色の", "第二話旅の終わりに「８８"]}, {"box": [455, 716, 826, 776], "vertical": false, "font_size": 45, "lines_coords": [[[455.0, 731.0], [825.0, 716.0], [826.0, 761.0], [457.0, 776.0]]], "lines": ["番外編・ヘやキャン△"]}], "img_path": "00004.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1147, 616, 1210, 781], "vertical": true, "font_size": 25, "lines_coords": [[[1183.0, 616.0], [1207.0, 616.0], [1207.0, 781.0], [1183.0, 781.0]], [[1147.0, 616.0], [1173.0, 616.0], [1173.0, 755.0], [1147.0, 755.0]]], "lines": ["まず細い枝に", "火をつける"]}, {"box": [586, 788, 650, 1096], "vertical": true, "font_size": 26, "lines_coords": [[[622.0, 789.0], [648.0, 789.0], [648.0, 1081.0], [622.0, 1081.0]], [[586.0, 789.0], [613.0, 789.0], [613.0, 1096.0], [586.0, 1096.0]]], "lines": ["で細い木からだんだん", "太い木をのせていけば．．．"]}, {"box": [1171, 1185, 1211, 1282], "vertical": true, "font_size": 40, "lines_coords": [[[1171.0, 1185.0], [1211.0, 1185.0], [1211.0, 1282.0], [1171.0, 1282.0]]], "lines": ["おおお"]}, {"box": [669, 1222, 740, 1398], "vertical": true, "font_size": 32, "lines_coords": [[[708.0, 1222.0], [740.0, 1222.0], [740.0, 1357.0], [708.0, 1357.0]], [[669.0, 1222.0], [701.0, 1222.0], [705.0, 1398.0], [673.0, 1398.0]]], "lines": ["ね簡単に", "ついたでしょ"]}, {"box": [352, 1181, 413, 1458], "vertical": true, "font_size": 25, "lines_coords": [[[386.0, 1185.0], [410.0, 1185.0], [410.0, 1458.0], [386.0, 1458.0]], [[354.0, 1181.0], [380.0, 1181.0], [378.0, 1357.0], [352.0, 1357.0]]], "lines": ["たき火てもっと大変かと", "思っとったよー"]}], "img_path": "00005.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [783, 155, 872, 331], "vertical": true, "font_size": 26, "lines_coords": [[[843.0, 155.0], [868.0, 155.0], [871.0, 331.0], [847.0, 331.0]], [[813.0, 155.0], [840.0, 155.0], [838.0, 305.0], [811.0, 305.0]], [[783.0, 157.0], [810.0, 157.0], [810.0, 258.0], [783.0, 258.0]]], "lines": ["あかりちゃんは", "たき火するの", "初めて？"]}, {"box": [600, 161, 682, 397], "vertical": true, "font_size": 23, "lines_coords": [[[654.0, 161.0], [680.0, 161.0], [682.0, 350.0], [656.0, 350.0]], [[628.0, 161.0], [652.0, 161.0], [652.0, 397.0], [628.0, 397.0]], [[600.0, 161.0], [620.0, 161.0], [620.0, 253.0], [600.0, 253.0]]], "lines": ["クラスのみんなで", "落ちぱたきやったこと", "あるけど"]}, {"box": [148, 163, 213, 388], "vertical": true, "font_size": 26, "lines_coords": [[[183.0, 163.0], [208.0, 163.0], [208.0, 386.0], [183.0, 386.0]], [[148.0, 166.0], [174.0, 166.0], [174.0, 331.0], [148.0, 331.0]]], "lines": ["自分でつけるのは", "初めてやなぁ"]}, {"box": [1106, 755, 1224, 993], "vertical": true, "font_size": 29, "lines_coords": [[[1190.0, 755.0], [1224.0, 755.0], [1224.0, 832.0], [1190.0, 832.0]], [[1138.0, 770.0], [1164.0, 770.0], [1164.0, 993.0], [1138.0, 993.0]], [[1106.0, 772.0], [1132.0, 772.0], [1132.0, 911.0], [1106.0, 911.0]]], "lines": ["はぁ", "ボカボカすんねぇ", "リンちゃん"]}, {"box": [171, 799, 196, 870], "vertical": true, "font_size": 25, "lines_coords": [[[171.0, 799.0], [196.0, 799.0], [196.0, 870.0], [171.0, 870.0]]], "lines": ["．．．．．．"]}, {"box": [690, 1046, 765, 1145], "vertical": true, "font_size": 41, "lines_coords": [[[725.0, 1051.0], [761.0, 1050.0], [765.0, 1143.0], [729.0, 1145.0]], [[690.0, 1046.0], [735.0, 1046.0], [735.0, 1119.0], [690.0, 1119.0]]], "lines": ["そうだ", "ね．．．"]}, {"box": [716, 1351, 783, 1473], "vertical": true, "font_size": 32, "lines_coords": [[[750.0, 1351.0], [783.0, 1351.0], [783.0, 1443.0], [750.0, 1443.0]], [[716.0, 1351.0], [748.0, 1351.0], [748.0, 1473.0], [716.0, 1473.0]]], "lines": ["あおい", "ちゃーん"]}, {"box": [134, 1470, 210, 1743], "vertical": true, "font_size": 32, "lines_coords": [[[176.0, 1470.0], [208.0, 1470.0], [208.0, 1674.0], [176.0, 1674.0]], [[135.0, 1470.0], [166.0, 1470.0], [166.0, 1743.0], [135.0, 1743.0]]], "lines": ["リンちゃんが", "旅立ってもーたー"]}], "img_path": "00006.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [17, 1777, 124, 1861], "vertical": false, "font_size": 34, "lines_coords": [[[37.0, 1815.0], [93.0, 1777.0], [112.0, 1805.0], [56.0, 1843.0]]], "lines": ["．ｎ９"]}, {"box": [360, 1548, 885, 1591], "vertical": false, "font_size": 43, "lines_coords": [[[360.0, 1548.0], [885.0, 1548.0], [885.0, 1591.0], [360.0, 1591.0]]], "lines": ["第４７話本日の晩ごはん！！"]}, {"box": [978, 1688, 1093, 1803], "vertical": false, "font_size": 59, "lines_coords": [[[978.0, 1686.0], [1085.0, 1686.0], [1085.0, 1754.0], [978.0, 1754.0]], [[982.0, 1742.0], [1087.0, 1742.0], [1087.0, 1801.0], [982.0, 1801.0]]], "lines": ["ＨＥＢ－", "ＳＡＬＴ"]}, {"box": [1246, 1815, 1340, 1921], "vertical": true, "font_size": 94, "lines_coords": [[[1246.0, 1815.0], [1340.0, 1815.0], [1340.0, 1921.0], [1246.0, 1921.0]]], "lines": ["スパレ"]}], "img_path": "00007.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1141, 144, 1201, 446], "vertical": true, "font_size": 29, "lines_coords": [[[1170.0, 144.0], [1201.0, 144.0], [1201.0, 262.0], [1170.0, 262.0]], [[1141.0, 146.0], [1168.0, 146.0], [1168.0, 444.0], [1141.0, 444.0]]], "lines": ["まず鍋に", "オリーブオイルをｉカップ"]}, {"box": [720, 150, 779, 556], "vertical": true, "font_size": 25, "lines_coords": [[[751.0, 150.0], [776.0, 150.0], [776.0, 523.0], [751.0, 523.0]], [[721.0, 155.0], [746.0, 155.0], [746.0, 556.0], [721.0, 556.0]]], "lines": ["にんにくのいい香りがしてきたら", "一口大に切ったなす。マッシュルーム"]}, {"box": [858, 521, 917, 870], "vertical": true, "font_size": 25, "lines_coords": [[[890.0, 521.0], [915.0, 521.0], [915.0, 795.0], [890.0, 795.0]], [[858.0, 521.0], [883.0, 521.0], [883.0, 870.0], [858.0, 870.0]]], "lines": ["刻んだにんにくと鷹の爪", "ハーブ壇を入れ弱火にかけます"]}, {"box": [164, 576, 223, 858], "vertical": true, "font_size": 25, "lines_coords": [[[195.0, 577.0], [221.0, 577.0], [221.0, 858.0], [195.0, 858.0]], [[165.0, 577.0], [189.0, 577.0], [189.0, 802.0], [165.0, 802.0]]], "lines": ["しめじにんにく〈粒ごと〉", "を入れ中火にします。"]}, {"box": [1118, 995, 1211, 1249], "vertical": true, "font_size": 28, "lines_coords": [[[1175.0, 995.0], [1211.0, 997.0], [1207.0, 1081.0], [1171.0, 1080.0]], [[1145.0, 997.0], [1171.0, 997.0], [1171.0, 1248.0], [1145.0, 1248.0]], [[1119.0, 1003.0], [1140.0, 1003.0], [1140.0, 1111.0], [1119.0, 1111.0]]], "lines": ["なすが", "やわらかくなった所で", "タコエヒ"]}, {"box": [161, 1021, 223, 1263], "vertical": true, "font_size": 29, "lines_coords": [[[187.0, 1021.0], [219.0, 1021.0], [223.0, 1263.0], [191.0, 1263.0]], [[161.0, 1023.0], [187.0, 1023.0], [187.0, 1200.0], [161.0, 1200.0]]], "lines": ["ウインナーバブリカ", "ヤングコーンと"]}, {"box": [1129, 1389, 1194, 1727], "vertical": true, "font_size": 26, "lines_coords": [[[1166.0, 1389.0], [1192.0, 1389.0], [1192.0, 1726.0], [1166.0, 1726.0]], [[1130.0, 1389.0], [1156.0, 1389.0], [1156.0, 1726.0], [1130.0, 1726.0]]], "lines": ["下茹でをして水気を切った", "長芋とブロッコリーを入れ"]}, {"box": [179, 1430, 209, 1683], "vertical": true, "font_size": 24, "lines_coords":