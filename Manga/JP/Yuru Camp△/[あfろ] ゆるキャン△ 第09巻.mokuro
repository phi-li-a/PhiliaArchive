0, 746.0], [1186.0, 870.0], [1155.0, 870.0]]], "lines": ["こっちね"]}, {"box": [853, 521, 920, 637], "vertical": true, "font_size": 34, "lines_coords": [[[879.0, 521.0], [920.0, 521.0], [920.0, 616.0], [879.0, 616.0]], [[853.0, 525.0], [879.0, 525.0], [879.0, 637.0], [853.0, 637.0]]], "lines": ["分かり", "ましたー"]}, {"box": [615, 733, 674, 1031], "vertical": true, "font_size": 26, "lines_coords": [[[645.0, 733.0], [671.0, 733.0], [673.0, 1031.0], [646.0, 1031.0]], [[616.0, 735.0], [643.0, 735.0], [641.0, 909.0], [615.0, 909.0]]], "lines": ["そういえばトンボロ現象は", "初めて見るわね"]}, {"box": [1138, 1305, 1172, 1426], "vertical": true, "font_size": 33, "lines_coords": [[[1138.0, 1305.0], [1171.0, 1305.0], [1171.0, 1426.0], [1138.0, 1426.0]]], "lines": ["あれっ？"]}, {"box": [464, 1318, 489, 1427], "vertical": true, "font_size": 25, "lines_coords": [[[464.0, 1318.0], [489.0, 1318.0], [489.0, 1427.0], [464.0, 1427.0]]], "lines": ["もーっ"]}, {"box": [676, 1539, 745, 1730], "vertical": true, "font_size": 30, "lines_coords": [[[712.0, 1539.0], [744.0, 1539.0], [738.0, 1730.0], [706.0, 1730.0]], [[676.0, 1545.0], [703.0, 1545.0], [703.0, 1726.0], [676.0, 1726.0]]], "lines": ["下にも駐車場", "あるじゃない"]}], "img_path": "00053.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [671, 174, 720, 264], "vertical": true, "font_size": 49, "lines_coords": [[[671.0, 174.0], [720.0, 174.0], [720.0, 264.0], [671.0, 264.0]]], "lines": ["満車"]}, {"box": [1111, 633, 1198, 815], "vertical": true, "font_size": 36, "lines_coords": [[[1158.0, 633.0], [1198.0, 633.0], [1198.0, 781.0], [1158.0, 781.0]], [[1113.0, 633.0], [1145.0, 633.0], [1145.0, 813.0], [1113.0, 813.0]]], "lines": ["ちょっと", "狭いわね．．．"]}, {"box": [633, 534, 708, 641], "vertical": true, "font_size": 68, "lines_coords": [[[633.0, 538.0], [701.0, 534.0], [708.0, 637.0], [641.0, 641.0]]], "lines": ["あっ"]}, {"box": [148, 562, 232, 795], "vertical": true, "font_size": 34, "lines_coords": [[[193.0, 564.0], [230.0, 564.0], [230.0, 795.0], [19