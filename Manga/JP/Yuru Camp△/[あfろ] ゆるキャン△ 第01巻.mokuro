0], [632.0, 426.0], [632.0, 453.0], [468.0, 453.0]], [[470.0, 453.0], [650.0, 453.0], [650.0, 475.0], [470.0, 475.0]]], "lines": ["体全体を覆うので", "冬用はだしいたいこれ"]}, {"box": [585, 520, 658, 656], "vertical": true, "font_size": 24, "lines_coords": [[[635.0, 521.0], [656.0, 521.0], [656.0, 656.0], [635.0, 656.0]], [[610.0, 523.0], [635.0, 523.0], [635.0, 603.0], [610.0, 603.0]], [[585.0, 520.0], [612.0, 520.0], [612.0, 603.0], [585.0, 603.0]]], "lines": ["リンちゃんのは", "マミー型", "だったよ"]}, {"box": [600, 712, 645, 856], "vertical": true, "font_size": 20, "lines_coords": [[[625.0, 712.0], [645.0, 712.0], [645.0, 856.0], [625.0, 856.0]], [[600.0, 712.0], [621.0, 712.0], [621.0, 795.0], [600.0, 795.0]]], "lines": ["よく考えてみろ", "なでしこ"]}, {"box": [143, 465, 376, 517], "vertical": false, "font_size": 30, "lines_coords": [[[145.0, 465.0], [376.0, 465.0], [376.0, 492.0], [145.0, 492.0]], [[143.0, 484.0], [373.0, 484.0], [373.0, 517.0], [143.0, 517.0]]], "lines": ["手足が分かれているので", "自由に歩くことができる"]}, {"box": [182, 550, 233, 662], "vertical": true, "font_size": 24, "lines_coords": [[[210.0, 553.0], [232.0, 553.0], [232.0, 639.0], [210.0, 639.0]], [[182.0, 550.0], [209.0, 550.0], [209.0, 662.0], [182.0, 662.0]]], "lines": ["なにこれ", "面白ーい！！"]}, {"box": [964, 1099, 1015, 1282], "vertical": true, "font_size": 22, "lines_coords": [[[990.0, 1100.0], [1012.0, 1100.0], [1012.0, 1281.0], [990.0, 1281.0]], [[964.0, 1100.0], [985.0, 1100.0], [985.0, 1214.0], [964.0, 1214.0]]], "lines": ["奴らの走る速度は", "自動車並み"]}, {"box": [733, 787, 751, 912], "vertical": true, "font_size": 16, "lines_coords": [[[734.0, 787.0], [750.0, 787.0], [750.0, 912.0], [734.0, 912.0]]], "lines": ["これいいなー！！"]}, {"box": [476, 717, 542, 1001], "vertical": true, "font_size": 30, "lines_coords": [[[507.0, 717.0], [540.0, 717.0], [542.0, 1001.0], [509.0, 1001.0]], [[476.0, 720.0], [503.0, 720.0], [503.0, 945.0], [476.0, 945.0]]], "lines": ["走れようが走れまいが", "クマの一人勝ちだ"]}, {"box": [292, 925, 346, 948], "vertical": false, "font_size": 23, "lines_coords": [[[292.0, 925.0], [346.0, 925.0], [346.0, 948.0], [292.0, 948.0]]], "lines": ["くす"]}, {"box": [717, 1398, 801, 1445], "vertical": false, "font_size": 20, "lines_coords": [[[720.0, 1401.0], [796.0, 1401.0], [796.0, 1418.0], [720.0, 1418.0]], [[720.0, 1423.0], [798.0, 1423.0], [798.0, 1445.0], [720.0, 1445.0]]], "lines": ["去定速に", "６０ｋｍ／ｈ"]}], "img_path": "0129.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [932, 118, 1011, 315], "vertical": true, "font_size": 22, "lines_coords": [[[989.0, 118.0], [1010.0, 118.0], [1010.0, 314.0], [989.0, 314.0]], [[960.0, 120.0], [982.0, 120.0], [982.0, 273.0], [960.0, 273.0]], [[934.0, 118.0], [956.0, 118.0], [954.0, 293.0], [932.0, 293.0]]], "lines": ["化学繊維とダウンの", "２種類あるけど", "どっちがいいの？"]}, {"box": [615, 84, 692, 259], "vertical": true, "font_size": 23, "lines_coords": [[[665.0, 84.0], [692.0, 84.0], [692.0, 176.0], [665.0, 176.0]], [[640.0, 87.0], [662.0, 87.0], [662.0, 259.0], [640.0, 259.0]], [[615.0, 87.0], [635.0, 87.0], [635.0, 215.0], [615.0, 215.0]]], "lines": ["それなー", "まあ細かい違いは", "色々あるけど"]}, {"box": [492, 178, 541, 353], "vertical": true, "font_size": 21, "lines_coords": [[[518.0, 179.0], [540.0, 179.0], [540.0, 287.0], [518.0, 287.0]], [[492.0, 178.0], [512.0, 178.0], [512.0, 353.0], [492.0, 353.0]]], "lines": ["大まかには", "こんな感じやねー"]}, {"box": [317, 289, 485, 415], "vertical": false, "font_size": 23.0, "lines_coords": [[[328.0, 292.0], [442.0, 289.0], [442.0, 310.0], [328.0, 314.0]], [[326.0, 315.0], [431.0, 315.0], [431.0, 342.0], [326.0, 342.0]], [[318.0, 342.0], [445.0, 342.0], [445.0, 364.0], [318.0, 364.0]], [[328.0, 368.0], [485.0, 368.0], [485.0, 390.0], [328.0, 390.0]], [[317.0, 393.0], [428.0, 393.0], [428.0, 415.0], [317.0, 415.0]]], "lines": ["コンパクトに", "圧縮できる．．．", "・洗濯に手間が", "かかる〈乾き難い〉", "・価格が高い"]}, {"box": [164, 248, 242, 270], "vertical": false, "font_size": 22, "lines_coords": [[[164.0, 248.0], [242.0, 248.0], [242.0, 270.0], [164.0, 270.0]]], "lines": ["化学繊維"]}, {"box": [129, 270, 300, 418], "vertical": false, "font_size": 59, "lines_coords": [[[129.0, 270.0], [300.0, 270.0], [300.0, 390.0], [129.0, 390.0]], [[154.0, 364.0], [279.0, 364.0], [279.0, 392.0], [154.0, 392.0]], [[143.0, 390.0], [256.0, 390.0], [256.0, 418.0], [143.0, 418.0]]], "lines": ["・ダウンに比べ重くかさばる．．．洗濯しやすい（乾きヤすい）", "〈乾きやすい〉", "・価格が安い"]}, {"box": [714, 625, 762, 792], "vertical": true, "font_size": 22, "lines_coords": [[[742.0, 626.0], [762.0, 626.0], [762.0, 771.0], [742.0, 771.0]], [[715.0, 625.0], [737.0, 625.0], [735.0, 792.0], [714.0, 792.0]]], "lines": ["夏用は入ってる", "中綿が少ないけど"]}, {"box": [532, 600, 575, 623], "vertical": false, "font_size": 23, "lines_coords": [[[532.0, 600.0], [575.0, 600.0], [575.0, 623.0], [532.0, 623.0]]], "lines": ["夏用"]}, {"box": [626, 659, 695, 873], "vertical": true, "font_size": 22, "lines_coords": [[[675.0, 660.0], [695.0, 660.0], [695.0, 854.0], [675.0, 854.0]], [[653.0, 660.0], [673.0, 660.0], [673.0, 873.0], [653.0, 873.0]], [[626.0, 659.0], [654.0, 659.0], [654.0, 725.0], [626.0, 725.0]]], "lines": ["冬用は暖かくするため", "中綿がもっさり入っとる", "やん？"]}, {"box": [246, 593, 281, 660], "vertical": true, "font_size": 35, "lines_coords": [[[246.0, 593.0], [281.0, 593.0], [281.0, 660.0], [246.0, 660.0]]], "lines": ["うん"]}, {"box": [862, 953, 957, 981], "vertical": false, "font_size": 28, "lines_coords": [[[862.0, 953.0], [957.0, 953.0], [957.0, 981.0], [862.0, 981.0]]], "lines": ["化学繊維"]}, {"box": [700, 954, 777, 978], "vertical": false, "font_size": 24, "lines_coords": [[[700.0, 954.0], [777.0, 954.0], [777.0, 978.0], [700.0, 978.0]]], "lines": ["ダウン"]}, {"box": [431, 931, 557, 1089], "vertical": true, "font_size": 22, "lines_coords": [[[537.0, 935.0], [557.0, 935.0], [557.0, 1070.0], [537.0, 1070.0]], [[514.0, 937.0], [531.0, 937.0], [531.0, 1050.0], [514.0, 1050.0]], [[485.0, 935.0], [507.0, 935.0], [507.0, 1089.0], [485.0, 1089.0]], [[459.0, 934.0], [481.0, 934.0], [481.0, 1068.0], [459.0, 1068.0]], [[431.0, 931.0], [462.0, 931.0], [462.0, 978.0], [431.0, 978.0]]], "lines": ["同じ耐寒温度で", "化繊の物より", "２〜３諭吉はど", "お高くなっとり", "ます"]}, {"box": [821, 1167, 895, 1415], "vertical": true, "font_size": 21, "lines_coords": [[[873.0, 1168.0], [893.0, 1168.0], [893.0, 1415.0], [873.0, 1415.0]], [[846.0, 1168.0], [868.0, 1168.0], [868.0, 1414.0], [846.0, 1414.0]], [[821.0, 1168.0], [843.0, 1168.0], [843.0, 1414.0], [821.0, 1414.0]]], "lines": ["だから冬用は圧縮に優れた", "ダウンの方がコンパクトに", "収納できていいんやけど．．．"]}, {"box": [712, 1249, 735, 1326], "vertical": true, "font_size": 23, "lines_coords": [[[712.0, 1250.0], [735.0, 1250.0], [735.0, 1326.0], [712.0, 1326.0]]], "lines": ["けど？"]}], "img_path": "0130.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [948, 115, 1017, 315], "vertical": true, "font_size": 21, "lines_coords": [[[992.0, 117.0], [1015.0, 117.0], [1017.0, 278.0], [993.0, 278.0]], [[962.0, 115.0], [984.0, 115.0], [987.0, 257.0], [965.0, 257.0]], [[948.0, 214.0], [965.0, 214.0], [965.0, 315.0], [948.0, 315.0]]], "lines": ["化繊でも安くて", "５千円かぁ．．．", "まだ高いなー"]}, {"box": [193, 131, 215, 266], "vertical": true, "font_size": 21, "lines_coords": [[[193.0, 131.0], [214.0, 131.0], [214.0, 265.0], [193.0, 265.0]]], "lines": ["あそういえば"]}, {"box": [618, 467, 668, 693], "vertical": true, "font_size": 21, "lines_coords": [[[648.0, 467.0], [668.0, 467.0], [668.0, 609.0], [648.0, 609.0]], [[618.0, 467.0], [640.0, 467.0], [643.0, 693.0], [621.0, 693.0]]], "lines": ["西部開拓時代の", "カウボーイは野宿する時"]}, {"box": [576, 648, 600, 814], "vertical": true, "font_size": 21, "lines_coords": [[[578.0, 648.0], [600.0, 648.0], [598.0, 814.0], [576.0, 814.0]]], "lines": ["朝まで焚き火して"]}, {"box": [415, 506, 487, 643], "vertical": true, "font_size": 22, "lines_coords": [[[465.0, 506.0], [487.0, 506.0], [487.0, 604.0], [465.0, 604.0]], [[440.0, 507.0], [460.0, 507.0], [460.0, 643.0], [440.0, 643.0]], [[415.0, 507.0], [440.0, 507.0], [440.0, 587.0], [415.0, 587.0]]], "lines": ["暖をとって", "やり過ごすのも", "ありだな"]}, {"box": [528, 648, 597, 834], "vertical": true, "font