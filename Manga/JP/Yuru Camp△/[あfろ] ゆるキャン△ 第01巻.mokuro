{"version": "0.2.0-beta.6", "title": "Yuru Camp△", "title_uuid": "a455d610-e3f3-44d0-9214-956621941f71", "volume": "[あfろ] ゆるキャン△ 第01巻", "volume_uuid": "34ca122f-d000-4019-a6b5-2e7ae2728ddd", "pages": [{"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [125, 276, 293, 345], "vertical": false, "font_size": 75, "lines_coords": [[[125.0, 270.0], [293.0, 270.0], [293.0, 351.0], [125.0, 351.0]]], "lines": ["．．．"]}, {"box": [123, 353, 278, 373], "vertical": false, "font_size": 20, "lines_coords": [[[123.0, 353.0], [278.0, 353.0], [278.0, 373.0], [123.0, 373.0]]], "lines": ["＇ｐｒｅｗｅｎｔｅｄｂｙ：Ｈｆｒｅ"]}, {"box": [209, 1, 1045, 306], "vertical": false, "font_size": 288, "lines_coords": [[[215.0, 1.0], [1045.0, 18.0], [1039.0, 306.0], [209.0, 289.0]]], "lines": ["ゆるホこル、"]}, {"box": [577, 276, 791, 323], "vertical": false, "font_size": 29, "lines_coords": [[[585.0, 280.0], [787.0, 283.0], [787.0, 314.0], [585.0, 311.0]]], "lines": ["ＹｕｔｕＣａｒｉｐ"]}], "img_path": "0001.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [141, 48, 326, 97], "vertical": false, "font_size": 22, "lines_coords": [[[145.0, 48.0], [310.0, 48.0], [310.0, 72.0], [145.0, 72.0]], [[146.0, 73.0], [323.0, 73.0], [323.0, 97.0], [146.0, 97.0]]], "lines": ["ｈｉｇｈｅｃｈｏｌｏｒｌｉｓｇｏ", "ＹｕＴｕｃｅｍｐｉｎａｔｕｅ"]}, {"box": [14, 16, 153, 589], "vertical": true, "font_size": 139, "lines_coords": [[[14.0, 104.0], [153.0, 104.0], [153.0, 525.0], [14.0, 525.0]]], "lines": ["．．．。"]}, {"box": [30, 566, 148, 613], "vertical": false, "font_size": 20, "lines_coords": [[[65.0, 587.0], [106.0, 587.0], [106.0, 609.0], [65.0, 609.0]]], "lines": ["．．．"]}, {"box": [36, 777, 140, 838], "vertical": false, "font_size": 22, "lines_coords": [[[90.0, 815.0], [124.0, 793.0], [133.0, 813.0], [101.0, 835.0]]], "lines": ["．．．"]}], "img_path": "0002.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [190, 184, 882, 642], "vertical": false, "font_size": 70.16666666666667, "lines_coords": [[[273.0, 201.0], [809.0, 184.0], [810.0, 248.0], [275.0, 265.0]], [[320.0, 273.0], [832.0, 268.0], [832.0, 328.0], [320.0, 332.0]], [[267.0, 353.0], [803.0, 335.0], [804.0, 404.0], [268.0, 421.0]], [[312.0, 425.0], [839.0, 418.0], [839.0, 484.0], [312.0, 490.0]], [[190.0, 504.0], [878.0, 478.0], [882.0, 573.0], [195.0, 600.0]], [[318.0, 576.0], [834.0, 571.0], [834.0, 637.0], [318.0, 642.0]]], "lines": ["お嬢様、心じさんとカップラーメン。", "私は、野切りへようこそ！！！", "現実、ふあとのソロキャンガール", "まあ、富士山と銀キャンプーの", "また、道具を揃える所からずキャンプです。でも、冬キュレットは", "．．．一瞬、冬キャッと叫かつまった。"]}, {"box": [262, 653, 815, 721], "vertical": false, "font_size": 41.5, "lines_coords": [[[382.0, 653.0], [815.0, 657.0], [815.0, 707.0], [382.0, 703.0]], [[262.0, 689.0], [387.0, 673.0], [392.0, 706.0], [267.0, 721.0]]], "lines": ["『日曜日とロッキングチェア", "［番外編］"]}, {"box": [367, 1345, 451, 1384], "vertical": false, "font_size": 25, "lines_coords": [[[370.0, 1357.0], [445.0, 1357.0], [445.0, 1384.0], [370.0, 1384.0]]], "lines": ["・５１・７５８"]}], "img_path": "0003.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [538, 757, 557, 790], "vertical": true, "font_size": 19, "lines_coords": [[[538.0, 757.0], [557.0, 757.0], [557.0, 790.0], [538.0, 790.0]]], "lines": ["はぁ"]}, {"box": [179, 757, 194, 791], "vertical": true, "font_size": 15, "lines_coords": [[[179.0, 757.0], [194.0, 757.0], [194.0, 791.0], [179.0, 791.0]]], "lines": ["さぁ"]}, {"box": [107, 1004, 166, 1216], "vertical": true, "font_size": 26, "lines_coords": [[[139.0, 1004.0], [165.0, 1004.0], [165.0, 1215.0], [139.0, 1215.0]], [[110.0, 1006.0], [137.0, 1006.0], [134.0, 1125.0], [107.0, 1125.0]]], "lines": ["今日は雲がかかって", "見えないか"]}, {"box": [706, 1364, 740, 1445], "vertical": true, "font_size": 34, "lines_coords": [[[706.0, 1364.0], [740.0, 1364.0], [740.0, 1445.0], [706.0, 1445.0]]], "lines": ["キィッ"]}], "img_path": "0004.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [975, 125, 999, 262], "vertical": true, "font_size": 22, "lines_coords": [[[976.0, 125.0], [998.0, 125.0], [998.0, 262.0], [976.0, 262.0]]], "lines": ["もう２時だ．．．"]}, {"box": [764, 970, 813, 1101], "vertical": true, "font_size": 20, "lines_coords": [[[790.0, 970.0], [812.0, 970.0], [812.0, 1101.0], [790.0, 1101.0]], [[765.0, 971.0], [782.0, 971.0], [782.0, 1078.0], [765.0, 1078.0]]], "lines": ["あれは確実に", "大セミくな"]}, {"box": [590, 956, 651, 1110], "vertical": true, "font_size": 24, "lines_coords": [[[626.0, 957.0], [648.0, 957.0], [648.0, 1110.0], [626.0, 1110.0]], [[590.0, 956.0], [617.0, 956.0], [620.0, 1110.0], [593.0, 1110.0]]], "lines": ["明日まで一泊", "お願いします"]}, {"box": [162, 1209, 214, 1417], "vertical": true, "font_size": 21, "lines_coords": [[[190.0, 1210.0], [210.0, 1210.0], [210.0, 1417.0], [190.0, 1417.0]], [[162.0, 1209.0], [184.0, 1209.0], [185.0, 1406.0], [164.0, 1406.0]]], "lines": ["ではここに連絡先と", "名前を書いて下さい"]}], "img_path": "0005.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [573, 71, 632, 276], "vertical": true, "font_size": 24, "lines_coords": [[[607.0, 75.0], [629.0, 75.0], [629.0, 276.0], [607.0, 276.0]], [[573.0, 71.0], [600.0, 71.0], [600.0, 203.0], [573.0, 203.0]]], "lines": ["チェックアウトは", "明日朝１０時"]}, {"box": [942, 586, 999, 815], "vertical": true, "font_size": 22, "lines_coords": [[[975.0, 589.0], [996.0, 589.0], [996.0, 792.0], [975.0, 792.0]], [[943.0, 589.0], [965.0, 589.0], [965.0, 814.0], [943.0, 814.0]]], "lines": ["薪は林の中の物を", "自由に使って下さい"]}, {"box": [945, 1010, 998, 1242], "vertical": true, "font_size": 24, "lines_coords": [[[971.0, 1010.0], [998.0, 1010.0], [998.0, 1231.0], [971.0, 1231.0]], [[945.0, 1012.0], [967.0, 1012.0], [967.0, 1242.0], [945.0, 1242.0]]], "lines": ["今の子こんな時期に", "キャンプやるんかね？"]}, {"box": [604, 1059, 665, 1165], "vertical": true, "font_size": 29, "lines_coords": [[[634.0, 1059.0], [665.0, 1059.0], [665.0, 1117.0], [634.0, 1117.0]], [[604.0, 1062.0], [631.0, 1062.0], [631.0, 1165.0], [604.0, 1165.0]]], "lines": ["ああ", "伊藤さん"]}, {"box": [478, 1007, 536, 1262], "vertical": true, "font_size": 24, "lines_coords": [[[512.0, 1009.0], [534.0, 1009.0], [534.0, 1262.0], [512.0, 1262.0]], [[478.0, 1007.0], [504.0, 1007.0], [504.0, 1251.0], [478.0, 1251.0]]], "lines": ["この時期になるとよく", "来るんですよあの子"]}, {"box": [137, 1236, 189, 1432], "vertical": true, "font_size": 23, "lines_coords": [[[165.0, 1237.0], [189.0, 1237.0], [187.0, 1431.0], [164.0, 1431.0]], [[137.0, 1237.0], [159.0, 1237.0], [159.0, 1395.0], [137.0, 1395.0]]], "lines": ["へぇー小さいのに", "逞しい子だねェ"]}], "img_path": "0006.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [503, 320, 537, 398], "vertical": true, "font_size": 34, "lines_coords": [[[503.0, 320.0], [537.0, 320.0], [537.0, 398.0], [503.0, 398.0]]], "lines": ["キィッ"]}, {"box": [582, 1029, 665, 1176], "vertical": true, "font_size": 38, "lines_coords": [[[628.0, 1029.0], [665.0, 1029.0], [665.0, 1176.0], [628.0, 1176.0]], [[582.0, 1031.0], [621.0, 1031.0], [621.0, 1176.0], [582.0, 1176.0]]], "lines": ["貸し切り", "状態．．．．．"]}, {"box": [115, 1004, 193, 1195], "vertical": true, "font_size": 37, "lines_coords": [[[157.0, 1010.0], [190.0, 1010.0], [190.0, 1195.0], [157.0, 1195.0]], [[115.0, 1004.0], [156.0, 1004.0], [156.0, 1078.0], [115.0, 1078.0]]], "lines": ["シーズンオフ", "最高"]}], "img_path": "0007.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [923, 62, 953, 248], "vertical": true, "font_size": 27, "lines_coords": [[[923.0, 62.0], [950.0, 62.0], [953.0, 248.0], [926.0, 248.0]]], "lines": ["この辺にしよう"]}, {"box": [962, 657, 993, 747], "vertical": true, "font_size": 31, "lines_coords": [[[962.0, 657.0], [993.0, 657.0], [993.0, 707.0], [962.0, 707.0]]], "lines": ["ブフ"]}, {"box": [696, 626, 732, 717], "vertical": true, "font_size": 36, "lines_coords": [[[696.0, 626.0], [732.0, 626.0], [732.0, 682.0], [696.0, 682.0]]], "lines": ["ブフ"]}], "img_path": "0008.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [353, 860, 387, 934], "vertical": true, "font_size": 34, "lines_coords": [[[353.0, 860.0], [387.0, 860.0], [387.0, 934.0], [353.0, 934.0]]], "lines": ["よし。"]}], "img_path": "0009.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [79, 1485, 473, 1535], "vertical": false, "font_size": 42, "lines_coords": [[[79.0, 1493.0], [473.0, 1485.0], [473.0, 1528.0], [79.0, 1535.0]]], "lines": ["第１話「ふじさんとカップ"]}], "img_path": "0010.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [498, 39, 554, 225], "vertical": true, "font_size": 24, "lines_coords": [[[528.0, 39.0], [553.0, 39.0], [550.0, 225.0], [525.0, 225.0]], [[501.0, 39.0], [523.0, 39.0], [520.0, 157.0], [498.0, 157.0]]], "lines": ["焚き火やらなくて", "よさそうだ"]}, {"box": [151, 59, 180, 239], "vertical": true, "font_size": 27, "lines_coords": [[[151.0, 59.0], [178.0, 59.0], [178.0, 239.0], [151.0, 239.0]]], "lines": ["めんどくさいし"]}, {"box": [943, 321, 1007, 581], "vertical": true, "font_size": 27, "lines_coords": [[[979.0, 323.0], [1006.0, 323.0], [1003.0, 581.0], [976.0, 581.0]], [[948.0, 321.0], [975.0, 321.0], [970.0, 506.0], [943.0, 506.0]]], "lines": ["今日は使い捨てカイロ", "持って来たから"]}, {"box": [395, 1104, 450, 1242], "vertical": true, "font_size": 25, "lines_coords": [[[428.0, 1104.0], [450.0, 1104.0], [450.0, 1242.0], [428.0, 1242.0]], [[395.0, 1104.0], [425.0, 1104.0], [425.0, 1176.0], [395.0, 1176.0]]], "lines": ["でも焚き火は", "なぁ．．．"]}, {"box": [946, 1075, 982, 1354], "vertical": true, "font_size": 33, "lines_coords": [[[948.0, 1075.0], [981.0, 1075.0], [979.0, 1354.0], [946.0, 1354.0]]], "lines": ["思ったより効かん："]}, {"box": [371, 1520, 493, 1559], "vertical": false, "font_size": 39, "lines_coords": [[[371.0, 1520.0], [493.0, 1520.0], [493.0, 1559.0], [371.0, 1559.0]]], "lines": ["☆気温！"]}, {"box": [323, 1242, 376, 1407], "vertical": true, "font_size": 25, "lines_coords": [[[350.0, 1242.0], [376.0, 1242.0], [376.0, 1340.0], [350.0, 1340.0]], [[323.0, 1245.0], [345.0, 1245.0], [345.0, 1407.0], [323.0, 1407.0]]], "lines": ["火起こし", "めんどくさいし"]}, {"box": [199, 1163, 254, 1304], "vertical": true, "font_size": 22, "lines_coords": [[[229.0, 1164.0], [251.0, 1164.0], [251.0, 1304.0], [229.0, 1304.0]], [[200.0, 1164.0], [221.0, 1164.0], [221.0, 1281.0], [200.0, 1281.0]]], "lines": ["煙臭くなるし、", "乾燥するし"]}, {"box": [141, 1355, 196, 1518], "vertical": true, "font_size": 24, "lines_coords": [[[168.0, 1356.0], [195.0, 1356.0], [192.0, 1498.0], [165.0, 1498.0]], [[142.0, 1357.0], [164.0, 1357.0], [164.0, 1518.0], [142.0, 1518.0]]], "lines": ["火の粉飛んで", "服に穴空くし．．．"]}], "img_path": "0011.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [256, 140, 311, 306], "vertical": true, "font_size": 25, "lines_coords": [[[287.0, 143.0], [309.0, 143.0], [309.0, 306.0], [287.0, 306.0]], [[256.0, 140.0], [284.0, 140.0], [284.0, 217.0], [256.0, 217.0]]], "lines": ["まず薪を集める", "前に．．．"]}, {"box": [963, 580, 992, 723], "vertical": true, "font_size": 26, "lines_coords": [[[964.0, 581.0], [990.0, 581.0], [990.0, 723.0], [964.0, 723.0]]], "lines": ["松ぼっくり"]}, {"box": [138, 575, 199, 915], "vertical": true, "font_size": 24, "lines_coords": [[[170.0, 578.0], [196.0, 578.0], [196.0, 915.0], [170.0, 915.0]], [[140.0, 579.0], [162.0, 579.0], [162.0, 834.0], [140.0, 834.0]]], "lines": ["これはマッチー本で火がつく。", "自然の優秀な着火剤だ。"]}, {"box": [937, 1018, 997, 1301], "vertical": true, "font_size": 24, "lines_coords": [[[968.0, 1018.0], [995.0, 1018.0], [995.0, 1301.0], [968.0, 1301.0]], [[939.0, 1018.0], [960.0, 1018.0], [960.0, 1301.0], [939.0, 1301.0]]], "lines": ["「かさ」が開いている物は", "乾燥していてよく燃える"]}, {"box": [676, 817, 709, 912], "vertical": true, "font_size": 33, "lines_coords": [[[676.0, 817.0], [709.0, 817.0], [709.0, 912.0], [676.0, 912.0]]], "lines": ["あった"]}, {"box": [479, 1025, 521, 1101], "vertical": true, "font_size": 42, "lines_coords": [[[479.0, 1025.0], [521.0, 1025.0], [521.0, 1101.0], [479.0, 1101.0]]], "lines": ["よし"]}, {"box": [121, 1312, 174, 1475], "vertical": true, "font_size": 21, "lines_coords": [[[151.0, 1314.0], [171.0, 1314.0], [171.0, 1475.0], [151.0, 1475.0]], [[121.0, 1314.0], [143.0, 1314.0], [143.0, 1417.0], [121.0, 1417.0]]], "lines": ["とりすぎたけど", "まあよし"]}], "img_path": "0012.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [945, 68, 1004, 339], "vertical": true, "font_size": 26, "lines_coords": [[[976.0, 70.0], [1003.0, 70.0], [1003.0, 339.0], [976.0, 339.0]], [[945.0, 68.0], [971.0, 68.0], [971.0, 276.0], [945.0, 276.0]]], "lines": ["次に薪これもなるべく", "乾燥した物を選ぶ"]}, {"box": [482, 73, 542, 305], "vertical": true, "font_size": 27, "lines_coords": [[[515.0, 73.0], [542.0, 73.0], [542.0, 281.0], [515.0, 281.0]], [[482.0, 73.0], [509.0, 73.0], [509.0, 304.0], [482.0, 304.0]]], "lines": ["あまり湿った物は", "火がつかなかったり"]}, {"box": [234, 100, 262, 156], "vertical": false, "font_size": 56, "lines_coords": [[[234.0, 100.0], [262.0, 100.0], [262.0, 156.0], [234.0, 156.0]]], "lines": ["．．．"]}, {"box": [140, 259, 170, 432], "vertical": true, "font_size": 27, "lines_coords": [[[140.0, 259.0], [167.0, 259.0], [167.0, 429.0], [140.0, 429.0]]], "lines": ["爆ぜたりする"]}, {"box": [975, 550, 1003, 829], "vertical": true, "font_size": 22, "lines_coords": [[[976.0, 550.0], [998.0, 550.0], [998.0, 828.0], [976.0, 828.0]]], "lines": ["薪は買うと一束約３００円"]}, {"box": [661, 544, 933, 593], "vertical": false, "font_size": 24, "lines_coords": [[[664.0, 546.0], [931.0, 546.0], [931.0, 568.0], [664.0, 568.0]], [[700.0, 567.0], [893.0, 567.0], [893.0, 593.0], [700.0, 593.0]]], "lines": ["薪ストーブ用の薪を売っている", "「薪屋さん」がおすすめ"]}, {"box": [522, 554, 588, 839], "vertical": true, "font_size": 26, "lines_coords": [[[556.0, 554.0], [582.0, 554.0], [582.0, 837.0], [556.0, 837.0]], [[523.0, 557.0], [550.0, 557.0], [550.0, 809.0], [523.0, 809.0]]], "lines": ["しかし利用料を払えば", "薪はタダで使い放題"]}, {"box": [252, 600, 272, 710], "vertical": true, "font_size": 17, "lines_coords": [[[253.0, 601.0], [270.0, 601.0], [270.0, 707.0], [253.0, 707.0]]], "lines": ["また拾いすぎた。"]}, {"box": [131, 545, 185, 846], "vertical": true, "font_size": 22, "lines_coords": [[[160.0, 546.0], [182.0, 546.0], [182.0, 846.0], [160.0, 846.0]], [[131.0, 546.0], [153.0, 546.0], [153.0, 778.0], [131.0, 778.0]]], "lines": ["という気前のいいキャンプ場", "も稀にあったりします"]}, {"box": [721, 883, 875, 929], "vertical": false, "font_size": 22, "lines_coords": [[[723.0, 884.0], [873.0, 884.0], [873.0, 906.0], [723.0, 906.0]], [[721.0, 907.0], [873.0, 906.0], [873.0, 928.0], [721.0, 929.0]]], "lines": ["木の種類によって", "火持ちが違います"]}, {"box": [790, 1001, 851, 1162], "vertical": true, "font_size": 28, "lines_coords": [[[820.0, 1001.0], [848.0, 1001.0], [851.0, 1106.0], [823.0, 1106.0]], [[790.0, 1003.0], [817.0, 1001.0], [828.0, 1160.0], [801.0, 1162.0]]], "lines": ["ヒャッハー", "燃やし放題だぜ"]}, {"box": [220, 1117, 265, 1207], "vertical": true, "font_size": 22, "lines_coords": [[[240.0, 1117.0], [262.0, 1117.0], [265.0, 1193.0], [243.0, 1193.0]], [[220.0, 1123.0], [242.0, 1123.0], [245.0, 1207.0], [223.0, 1207.0]]], "lines": ["常識的な", "筋肉でだけど"]}], "img_path": "0013.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [932, 79, 988, 234], "vertical": true, "font_size": 22, "lines_coords": [[[964.0, 79.0], [985.0, 79.0], [985.0, 231.0], [964.0, 231.0]], [[932.0, 81.0], [954.0, 81.0], [954.0, 181.0], [932.0, 181.0]]], "lines": ["きさまら全員", "まとめて"]}, {"box": [473, 157, 523, 271], "vertical": true, "font_size": 45, "lines_coords": [[[473.0, 159.0], [518.0, 157.0], [523.0, 270.0], [478.0, 271.0]]], "lines": ["ふんっ"]}, {"box": [942, 635, 976, 723], "vertical": true, "font_size": 34, "lines_coords": [[[942.0, 635.0], [976.0, 635.0], [976.0, 723.0], [942.0, 723.0]]], "lines": ["ふんっ"]}, {"box": [646, 409, 705, 567], "vertical": true, "font_size": 26, "lines_coords": [[[678.0, 409.0], [704.0, 409.0], [704.0, 514.0], [678.0, 514.0]], [[646.0, 410.0], [673.0, 410.0], [673.0, 567.0], [646.0, 567.0]]], "lines": ["刀の錆に", "してやるぜ．．．"]}, {"box": [650, 640, 676, 775