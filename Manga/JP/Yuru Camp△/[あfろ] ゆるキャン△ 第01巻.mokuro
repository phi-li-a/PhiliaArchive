.0, 1171.0], [514.0, 1296.0], [493.0, 1296.0]]], "lines": ["これはいい．．"]}], "img_path": "0174.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [493, 842, 516, 937], "vertical": true, "font_size": 22, "lines_coords": [[[493.0, 842.0], [515.0, 842.0], [515.0, 896.0], [493.0, 896.0]]], "lines": ["んむー"]}, {"box": [376, 1256, 406, 1303], "vertical": true, "font_size": 30, "lines_coords": [[[376.0, 1256.0], [406.0, 1256.0], [406.0, 1303.0], [376.0, 1303.0]]], "lines": ["はっ"]}], "img_path": "0175.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [444, 155, 521, 292], "vertical": true, "font_size": 20, "lines_coords": [[[500.0, 156.0], [521.0, 156.0], [521.0, 267.0], [500.0, 267.0]], [[470.0, 156.0], [492.0, 156.0], [492.0, 292.0], [470.0, 292.0]], [[445.0, 157.0], [462.0, 157.0], [462.0, 268.0], [445.0, 268.0]]], "lines": ["このライト", "工事現場の人", "みたいだー"]}, {"box": [228, 340, 392, 374], "vertical": false, "font_size": 17, "lines_coords": [[[239.0, 343.0], [315.0, 343.0], [315.0, 360.0], [239.0, 360.0]]], "lines": ["Ｌ－ＬＥＤへ"]}, {"box": [121, 126, 173, 264], "vertical": true, "font_size": 22, "lines_coords": [[[150.0, 128.0], [171.0, 128.0], [171.0, 242.0], [150.0, 242.0]], [[121.0, 126.0], [143.0, 126.0], [143.0, 264.0], [121.0, 264.0]]], "lines": ["こんなのも", "あるんだねぇ"]}, {"box": [459, 476, 507, 725], "vertical": true, "font_size": 21, "lines_coords": [[[481.0, 476.0], [503.0, 476.0], [503.0, 662.0], [481.0, 662.0]], [[459.0, 478.0], [479.0, 478.0], [479.0, 725.0], [459.0, 725.0]]], "lines": ["テント内に吊るすと", "ランタンとしても使えます"]}, {"box": [117, 482, 178, 643], "vertical": true, "font_size": 29, "lines_coords": [[[143.0, 482.0], [178.0, 482.0], [178.0, 557.0], [143.0, 557.0]], [[117.0, 484.0], [140.0, 484.0], [142.0, 643.0], [118.0, 643.0]]], "lines": ["へぇー", "これ便利だなぁ"]}, {"box": [440, 825, 501, 925], "vertical": true, "font_size": 32, "lines_coords": [[[471.0, 829.0], [501.0, 829.0], [501.0, 901.0], [471.0, 901.0]], [[440.0, 825.0], [473.0, 825.0], [473.0, 925.0], [440.0, 925.0]]], "lines": ["ヘッド", "ライト．．"]}, {"box": [464, 1192, 487, 1295], "vertical": true, "font_size": 21, "lines_coords": [[[464.0, 1192.0], [485.0, 1192.0], [485.0, 1295.0], [464.0, 1295.0]]], "lines": ["かわいい．．．"]}], "img_path": "0176.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [], "img_path": "0177.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [282, 951, 667, 973], "vertical": false, "font_size": 22, "lines_coords": [[[282.0, 951.0], [667.0, 951.0], [667.0, 973.0], [282.0, 973.0]]], "lines": ["ゆるキャン△○いかがでしたでしょうか。"]}, {"box": [276, 995, 1031, 1183], "vertical": false, "font_size": 25, "lines_coords": [[[282.0, 1018.0], [607.0, 1018.0], [607.0, 1039.0], [282.0, 1039.0]], [[284.0, 1053.0], [975.0, 1053.0], [975.0, 1075.0], [284.0, 1075.0]], [[284.0, 1085.0], [646.0, 1085.0], [646.0, 1107.0], [284.0, 1107.0]], [[281.0, 1115.0], [775.0, 1115.0], [775.0, 1142.0], [281.0, 1142.0]], [[276.0, 1145.0], [1006.0, 1150.0], [1006.0, 1181.0], [276.0, 1176.0]]], "lines": ["山梨から始まったゆるキャンですか", "真冬は伊豆キャンプ、夏になったら島キャンプや上高地での避暑キャンプと", "徐々に広げていいろんな土地でのキャンプ", "それとテント泊だけでなくロッジ泊やツリーハウス泊", "色々なキャンプ道具が絡んだエピソードなども描けたらなーと思っております。"]}, {"box": [284, 1218, 410, 1240], "vertical": false, "font_size": 22, "lines_coords": [[[284.0, 1218.0], [410.0, 1218.0], [410.0, 1240.0], [284.0, 1240.0]]], "lines": ["あｆろでした。"]}, {"box": [282, 1285, 517, 1306], "vertical": false, "font_size": 21, "lines_coords": [[[282.0, 1285.0], [517.0, 1285.0], [517.0, 1306.0], [282.0, 1306.0]]], "lines": ["キャンプしたいなぁ．．．"]}, {"box": [498, 1383, 991, 1504], "vertical": false, "font_size": 19, "lines_coords": [[[506.0, 1385.0], [582.0, 1385.0], [582.0, 1403.0], [506.0, 1403.0]], [[509.0, 1407.0], [989.0, 1407.0], [989.0, 1429.0], [509.0, 1429.0]], [[509.0, 1435.0], [882.0, 1435.0], [882.0, 1451.0], [509.0, 1451.0]], [[507.0, 1459.0], [596.0, 1459.0], [596.0, 1476.0], [507.0, 1476.0]], [[498.0, 1481.0], [790.0, 1482.0], [790.0, 1503.0], [498.0, 1501.0]]], "lines": ["初出一覧", "まんがタイムきららフォワード平成２７２月号〜１２月", "まんがタイムきららミラク平成２７年１２月", "描き下ろし", "本書は以上の内容を収録致しました。"]}], "img_path": "0178.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [315, 665, 495, 750], "vertical": false, "font_size": 32.0, "lines_coords": [[[317.0, 665.0], [495.0, 665.0], [495.0, 696.0], [317.0, 696.0]], [[315.0, 717.0], [396.0, 717.0], [396.0, 750.0], [315.0, 750.0]]], "lines": ["著者：あｆろ", "©ａｆｒｏ"]}, {"box": [335, 510, 778, 568], "vertical": false, "font_size": 58, "lines_coords": [[[335.0, 510.0], [778.0, 510.0], [778.0, 568.0], [335.0, 568.0]]], "lines": ["ゆるキャン△，第１巻"]}, {"box": [315, 817, 801, 1024], "vertical": false, "font_size": 30, "lines_coords": [[[315.0, 828.0], [793.0, 825.0], [793.0, 857.0], [315.0, 860.0]], [[315.0, 882.0], [562.0, 882.0], [562.0, 914.0], [315.0, 914.0]], [[315.0, 935.0], [653.0, 939.0], [653.0, 965.0], [315.0, 962.0]], [[439.0, 989.0], [779.0, 990.0], [779.0, 1021.0], [439.0, 1020.0]]], "lines": ["電子版発行日：２０１５年１２月１５日", "発行人・東・敬彰", "発行所：株式会社芳文社", "東京都文京区後楽１－２－１２"]}], "img_path": "0179.jpg"}, {"version": "0.1.6", "img_width": 1125, "img_height": 1600, "blocks": [{"box": [22, 573, 43, 686], "vertical": true, "font_size": 21, "lines_coords": [[[22.0, 573.0], [43.0, 573.0], [43.0, 686.0], [22.0, 686.0]]], "lines": ["というでいで最後からお退いしております。"]}, {"box": [58, 572, 168, 708], "vertical": false, "font_size": 149, "lines_coords": [[[58.0, 559.0], [168.0, 559.0], [168.0, 721.0], [58.0, 721.0]]], "lines": ["．．．"]}, {"box": [232, 635, 304, 669], "vertical": false, "font_size": 37, "lines_coords": [[[232.0, 632.0], [304.0, 632.0], [304.0, 672.0], [232.0, 672.0]]], "lines": ["この１５００ｍｍの"]}, {"box": [227, 554, 521, 646], "vertical": false, "font_size": 101, "lines_coords": [[[231.0, 545.0], [506.0, 545.0], [506.0, 655.0], [231.0, 655.0]]], "lines": ["ゆるたり、"]}, {"box": [373, 638, 448, 655], "vertical": false, "font_size": 19, "lines_coords": [[[373.0, 636.0], [448.0, 