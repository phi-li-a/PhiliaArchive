ical": true, "font_size": 29, "lines_coords": [[[414.0, 1224.0], [446.0, 1224.0], [446.0, 1537.0], [414.0, 1537.0]], [[380.0, 1222.0], [406.0, 1222.0], [405.0, 1507.0], [378.0, 1507.0]]], "lines": ["バイクで走って冷えた分", "温泉がきもちええ．．．"]}, {"box": [181, 1419, 214, 1731], "vertical": true, "font_size": 28, "lines_coords": [[[183.0, 1419.0], [211.0, 1419.0], [210.0, 1728.0], [181.0, 1728.0]]], "lines": ["やっぱり冬の温泉はいい"]}], "img_path": "00138.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [684, 253, 718, 412], "vertical": true, "font_size": 32, "lines_coords": [[[684.0, 253.0], [716.0, 253.0], [716.0, 412.0], [684.0, 412.0]]], "lines": ["サウナか．．"]}, {"box": [827, 805, 858, 998], "vertical": true, "font_size": 27, "lines_coords": [[[828.0, 808.0], [855.0, 808.0], [855.0, 997.0], [828.0, 997.0]]], "lines": ["そういえば．．．"]}, {"box": [206, 766, 269, 1046], "vertical": true, "font_size": 26, "lines_coords": [[[240.0, 766.0], [266.0, 766.0], [266.0, 1020.0], [240.0, 1020.0]], [[206.0, 766.0], [232.0, 766.0], [232.0, 1046.0], [206.0, 1046.0]]], "lines": ["冬は温泉もいいけど", "サウナもいいんだよね"]}, {"box": [1226, 1183, 1297, 1470], "vertical": true, "font_size": 29, "lines_coords": [[[1265.0, 1185.0], [1291.0, 1185.0], [1291.0, 1468.0], [1265.0, 1468.0]], [[1228.0, 1183.0], [1260.0, 1183.0], [1258.0, 1451.0], [1226.0, 1451.0]]], "lines": ["サウナ水風呂外気治", "って繰り返してると"]}, {"box": [793, 1312, 861, 1790], "vertical": true, "font_size": 29, "lines_coords": [[[826.0, 1314.0], [858.0, 1314.0], [858.0, 1790.0], [826.0, 1790.0]], [[793.0, 1318.0], [819.0, 1318.0], [819.0, 1464.0], [793.0, 1464.0]]], "lines": ["そのうちディープリラックス状態を", "むかえて．．．"]}, {"box": [643, 1147, 723, 1773], "vertical": true, "font_size": 73, "lines_coords": [[[650.0, 1147.0], [723.0, 1149.0], [718.0, 1477.0], [645.0, 1475.0]]], "lines": ["ととのった"]}, {"box": [219, 1466, 247, 1660], "vertical": true, "font_size": 26, "lines_coords": [[[219.0, 1466.0], [245.0, 1466.0], [245.0, 1659.0], [219.0, 1659.0]]], "lines": ["ってなる