 [1085.0, 1755.0], [941.0, 1755.0]]], "lines": ["ネイルペク"]}, {"box": [673, 1423, 751, 1665], "vertical": true, "font_size": 34, "lines_coords": [[[714.0, 1423.0], [751.0, 1423.0], [751.0, 1633.0], [714.0, 1633.0]], [[675.0, 1425.0], [706.0, 1425.0], [705.0, 1665.0], [673.0, 1665.0]]], "lines": ["ネイルペグて", "ほぼほぼ釘やな"]}, {"box": [356, 1551, 441, 1592], "vertical": false, "font_size": 34, "lines_coords": [[[365.0, 1554.0], [431.0, 1554.0], [431.0, 1588.0], [365.0, 1588.0]]], "lines": ["パク"]}, {"box": [150, 1533, 236, 1708], "vertical": true, "font_size": 36, "lines_coords": [[[193.0, 1533.0], [232.0, 1533.0], [236.0, 1708.0], [196.0, 1708.0]], [[150.0, 1535.0], [183.0, 1535.0], [183.0, 1687.0], [150.0, 1687.0]]], "lines": ["あこれは", "ちゃうか"]}], "img_path": "00175.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1130, 134, 1202, 510], "vertical": true, "font_size": 32, "lines_coords": [[[1168.0, 135.0], [1200.0, 135.0], [1200.0, 508.0], [1168.0, 508.0]], [[1130.0, 136.0], [1162.0, 136.0], [1162.0, 450.0], [1130.0, 450.0]]], "lines": ["そして数あるペグの中でも", "多くのキャンパーから"]}, {"box": [566, 153, 677, 436], "vertical": true, "font_size": 32, "lines_coords": [[[645.0, 153.0], [676.0, 153.0], [676.0, 435.0], [645.0, 435.0]], [[605.0, 155.0], [637.0, 155.0], [637.0, 436.0], [605.0, 436.0]], [[566.0, 155.0], [598.0, 155.0], [598.0, 279.0], [566.0, 279.0]]], "lines": ["どんな硬い地面でも", "ぶっ刺さりびくとも", "しねぇ！！"]}, {"box": [693, 427, 803, 757], "vertical": true, "font_size": 35, "lines_coords": [[[770.0, 433.0], [802.0, 433.0], [802.0, 727.0], [770.0, 727.0]], [[733.0, 433.0], [765.0, 433.0], [765.0, 757.0], [733.0, 757.0]], [[693.0, 427.0], [733.0, 427.0], [733.0, 525.0], [693.0, 525.0]]], "lines": ["「最強」と謳われるのが", "この「５０センチ鍛造ベグ」", "だっ！！"]}, {"box": [137, 523, 209, 775], "vertical": true, "font_size": 30, "lines_coords": [[[174.0, 523.0], [206.0, 523.0], [206.0, 774.0], [174.0, 774.0]], [[138.0, 530.0], [165.0, 530.0], [165.0, 742.0], [138.0, 742.0]]], "lines": ["曲がっても叩いて", "戻せる頑丈さ！！"]}, {"box": [1102, 1085, 1199, 1342], "vertical": true, "font_size": 40, "lines_coords": [[[1156.0, 1087.0], [1196.0, 1087.0], [1196.0, 1342.0], [1156.0, 1342.0]], [[1102.0, 1085.0], [1141.0, 1085.0], [1141.0, 1299.0], [1102.0, 1299.0]]], "lines": ["この最強ペグ", "さえあれば"]}, {"box": [351, 875, 457, 1209], "vertical": true, "font_size": 46, "lines_coords": [[[401.0, 875.0], [453.0, 875.0], [457.0, 1209.0], [405.0, 1209.0]], [[354.0, 881.0], [393.0, 881.0], [393.0, 1205.0], [354.0, 1205.0]]], "lines": ["台風が来たって", "怖くねえぜっ！！"]}, {"box": [189, 1149, 249, 1245], "vertical": true, "font_size": 48, "lines_coords": [[[189.0, 1149.0], [249.0, 1149.0], [249.0, 1245.0], [189.0, 1245.0]]], "lines": ["おお"]}, {"box": [150, 1220, 187, 1275], "vertical": true, "font_size": 48, "lines_coords": [[[150.0, 1220.0], [187.0, 1220.0], [187.0, 1275.0], [150.0, 1275.0]]], "lines": ["ーっ"]}, {"box": [217, 1428, 330, 1645], "vertical": true, "font_size": 33, "lines_coords": [[[290.0, 1428.0], [330.0, 1428.0], [330.0, 1556.0], [290.0, 1556.0]], [[258.0, 1430.0], [285.0, 1430.0], [285.0, 1644.0], [258.0, 1644.0]], [[217.0, 1428.0], [249.0, 1428.0], [249.0, 1533.0], [217.0, 1533.0]]], "lines": ["ペグ以外", "全部飛ばされて", "もうた。"]}], "img_path": "00176.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1117, 166, 1188, 502], "vertical": true, "font_size": 32, "lines_coords": [[[1153.0, 166.0], [1186.0, 166.0], [1188.0, 420.0], [1155.0, 420.0]], [[1117.0, 170.0], [1149.0, 170.0], [1149.0, 502.0], [1117.0, 502.0]]], "lines": ["こないだ野クルで", "ペグの話したんだけど"]}, {"box": [892, 260, 951, 571], "vertical": true, "font_size": 26, "lines_coords": [[[924.0, 262.0], [950.0, 262.0], [950.0, 571.0], [924.0, 571.0]], [[892.0, 260.0], [918.0, 260.0], [918.0, 571.0], [892.0, 571.0]]], "lines": ["ペグハンマーってやっぱり", "持ってた方がいいのかな？"]}, {"box": [127, 80, 575, 106], "vertical": false, "font_size": 26, "lines_coords": [[[127.0, 80.0], [575.0, 80.0], [575.0, 106.0], [127.0, 106.0]]], "lines": ["放課後８９ペグハンマーの鑑"]}, {"box": [374, 196, 443, 448], "vertical": true, "font_size": 29, "lines_coords": [[[410.0, 196.0], [442.0, 196.0], [442.0, 448.0], [410.0, 448.0]], [[375.0, 198.0], [401.0, 198.0], [401.0, 384.0], [375.0, 384.0]]], "lines": ["荷物減らしたいし", "私は石派かな"]}, {"box": [223, 320, 294, 555], "vertical": true, "font_size": 32, "lines_coords": [[[262.0, 322.0], [294.0, 322.0], [294.0, 480.0], [262.0, 480.0]], [[223.0, 320.0], [255.0, 320.0], [256.0, 555.0], [225.0, 555.0]]], "lines": ["それか足で", "踏んで押し込む。"]}, {"box": [1078, 738, 1155, 1048], "vertical": true, "font_size": 35, "lines_coords": [[[1117.0, 738.0], [1155.0, 738.0], [1155.0, 1046.0], [1117.0, 1046.0]], [[1078.0, 740.0], [1110.0, 740.0], [1110.0, 1048.0], [1078.0, 1048.0]]], "lines": ["足で押しこむとペグ", "曲がっちゃわない？"]}, {"box": [241, 766, 320, 1179], "vertical": true, "font_size": 35, "lines_coords": [[[286.0, 766.0], [318.0, 766.0], [318.0, 1177.0], [286.0, 1177.0]], [[241.0, 766.0], [279.0, 766.0], [279.0, 1179.0], [241.0, 1179.0]]], "lines": ["こうやって両手で押さえて", "ゆっくり踏みこめば大丈夫"]}, {"box": [1066, 1359, 1171, 1744], "vertical": true, "font_size": 30, "lines_coords": [[[1140.0, 1361.0], [1171.0, 1361.0], [1171.0, 1717.0], [1140.0, 1717.0]], [[1100.0, 1359.0], [1132.0, 1359.0], [1132.0, 1743.0], [1100.0, 1743.0]], [[1066.0, 1363.0], [1093.0, 1363.0], [1093.0, 1608.0], [1066.0, 1608.0]]], "lines": ["でもちゃんとペグハンマー", "持ってくのもベテランぼくて", "がっこいいけどね。"]}, {"box": [585, 1396, 628, 1554], "vertical": true, "font_size": 40, "lines_coords": [[[585.0, 1396.0], [624.0, 1396.0], [628.0, 1554.0], [588.0, 1554.0]]], "lines": ["だよねぇ"]}], "img_path": "00177.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1136, 158, 1212, 500], "vertical": true, "font_size": 30, "lines_coords": [[[1177.0, 161.0], [1209.0, 161.0], [1209.0, 500.0], [1177.0, 500.0]], [[1138.0, 159.0], [1166.0, 159.0], [1164.0, 395.0], [1136.0, 395.0]]], "lines": ["これとかすごくいいと", "思うんだよねー"]}, {"box": [633, 150, 705, 587], "vertical": true, "font_size": 32, "lines_coords": [[[671.0, 150.0], [703.0, 150.0], [703.0, 585.0], [671.0, 585.0]], [[633.0, 150.0], [665.0, 150.0], [665.0, 523.0], [633.0, 523.0]]], "lines": ["ペグを叩くと銅の部分が潰れて", "食い込むからズレにくいし"]}, {"box": [129, 140, 203, 485], "vertical": true, "font_size": 32, "lines_coords": [[[168.0, 144.0], [200.0, 144.0], [200.0, 455.0], [168.0, 455.0]], [[129.0, 140.0], [161.0, 140.0], [163.0, 485.0], [131.0, 485.0]]], "lines": ["会計な力が逃げるから", "腕も疲れにくいんだって"]}, {"box": [906, 590, 1072, 658], "vertical": false, "font_size": 30, "lines_coords": [[[937.0, 592.0], [1048.0, 592.0], [1048.0, 618.0], [937.0, 618.0]], [[907.0, 624.0], [1063.0, 620.0], [1063.0, 654.0], [907.0, 658.0]]], "lines": ["銅ヘッド", "ペグハンマー"]}, {"box": [759, 545, 834, 686], "vertical": true, "font_size": 36, "lines_coords": [[[791.0, 545.0], [830.0, 545.0], [834.0, 686.0], [795.0, 686.0]], [[759.0, 547.0], [793.0, 547.0], [793.0, 643.0], [759.0, 643.0]]], "lines": ["おシブい", "じゃん"]}, {"box": [151, 548, 198, 660], "vertical": true, "font_size": 47, "lines_coords": [[[151.0, 549.0], [198.0, 549.0], [198.0, 660.0], [151.0, 660.0]]], "lines": ["へぇー"]}, {"box": [1096, 821, 1169, 1194], "vertical": true, "font_size": 30, "lines_coords": [[[1134.0, 823.0], [1166.0, 823.0], [1166.0, 1149.0], [1134.0, 1149.0]], [[1098.0, 823.0], [1126.0, 823.0], [1125.0, 1194.0], [1096.0, 1194.0]]], "lines": ["けどね使ってくうちに", "銅の部分がどんどん潰れて"]}, {"box": [244, 840, 319, 1113], "vertical": true, "font_size": 32, "lines_coords": [[[281.0, 841.0], [318.0, 841.0], [318.0, 1046.0], [281.0, 1046.0]], [[245.0, 841.0], [271.0, 841.0], [271.0, 1111.0], [245.0, 1111.0]]], "lines": ["ぺしゃんこに", "なっちゃうんだ．．．"]}, {"box": [1091, 1266, 1176, 1719], "vertical": true, "font_size": 38, "lines_coords": [[[1136.0, 1267.0], [1175.0, 1267.0], [1175.0, 1717.0], [1136.0, 1717.0]], [[1091.0, 1267.0], [1128.0, 1267.0], [1128.0, 1719.0], [1091.0, 1719.0]]], "lines": ["自分の身を犠牲にしてまで", "まっすぐペグを打ちこむ．．．"]}, {"box": [539, 1258, 625, 1632], "vertical": true, "font_size": 34, "lines_coords": [[[585.0, 1258.0], [622.0, 1258.0], [622.0, 1631.0], [585.0, 1631.0]], [[540.0, 1258.0], [571.0, 1258.0], [571.0, 1593.0], [540.0, 1593.0]]], "lines": ["まさにペグハンマーの", "鑑定と思うんだよ！！"]}, {"box": [232, 1466, 278, 1702], "vertical": true, "font_size": 39, "lines_coords": [[[236.0, 1466.0], [275.0, 1466.0], [271.0, 1702.0], [232.0, 1702.0]]], "lines": ["よくわからん"]}], "img_path": "00178.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [110, 112, 641, 181], "vertical": false, "font_size": 26.0, "lines_coords": [[[110.0, 112.0], [568.0, 116.0], [568.0, 142.0], [110.0, 138.0]], [[112.0, 155.0], [641.0, 155.0], [641.0, 181.0], [112.0, 181.0]]], "lines": ["ゆるキャン△＠じわかがでしたでしょうか。", "今回は庭キャンと大井川前編を収録致しました。"]}, {"box": [112, 440, 262, 465], "vertical": false, "font_size": 25, "lines_coords": [[[112.0, 440.0], [262.0, 440.0], [262.0, 465.0], [112.0, 465.0]]], "lines": ["あｆろでした。"]}, {"box": [112, 238, 856, 384], "vertical": false, "font_size": 25.75, "lines_coords": [[[112.0, 238.0], [856.0, 238.0], [856.0, 262.0], [112.0, 262.0]], [[114.0, 277.0], [435.0, 277.0], [435.0, 303.0], [114.0, 303.0]], [[112.0, 316.0], [356.0, 316.0], [356.0, 343.0], [112.0, 343.0]], [[114.0, 358.0], [622.0, 358.0], [622.0, 384.0], [114.0, 384.0]]], "lines": ["作中で出てきたアルコールストーブは燃えてる時にひっくり返すと", "本当に未参事になりますので、", "気をつけてくださいね", "ひっくり返すなよ！絶対にひっくり返すなよ！"]}, {"box": [114, 1666, 204, 1687], "vertical": false, "font_size": 21, "lines_coords": [[[114.0, 1666.0], [204.0, 1666.0], [204.0, 1687.0], [114.0, 1687.0]]], "lines": ["〈初出一覧〉"]}, {"box": [95, 1689, 954, 1817], "vertical": false, "font_size": 26, "lines_coords": [[[110.0, 1687.0], [954.0, 1691.0], [954.0, 1721.0], [110.0, 1717.0]], [[112.0, 1721.0], [575.0, 1721.0], [575.0, 1749.0], [112.0, 1749.0]], [[114.0, 1753.0], [221.0, 1753.0], [221.0, 1777.0], [114.0, 1777.0]], [[108.0, 1779.0], [433.0, 1781.0], [433.0, 1809.0], [108.0, 1807.0]]], "lines": ["・ＣＯＭＯＦＵＺ平成３１年３月開催分〜令机元年６月、令和元年１０月〜令和２年１月撮戦分", "・どとのったＭＡＧＡＺＡＮＥ（ヤマハ発動機株式会社）", "・描き下ろし", "本書は以上の内容を収録しました。"]}], "img_path": "00179.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [741, 221, 1181, 417], "vertical": false, "font_size": 196, "lines_coords": [[[741.0, 221.0], [1181.0, 221.0], [1181.0, 417.0], [741.0, 417.0]]], "lines": ["ちょうど"]}, {"box": [585, 260, 629, 556], "vertical": true, "font_size": 22, "lines_coords": [[[605.0, 260.0], [626.0, 260.0], [628.0, 519.0], [607.0, 519.0]], [[585.0, 262.0], [609.0, 262.0], [609.0, 556.0], [585.0, 556.0]]], "lines": ["ハイクは車よりも危険な乗り物", "プロテクターを付ける事も大切だが、"]}, {"box": [219, 286, 262, 490], "vertical": true, "font_size": 20, "lines_coords": [[[241.0, 286.0], [262.0, 286.0], [260.0, 455.0], [240.0, 455.0]], [[221.0, 286.0], [241.0, 286.0], [240.0, 489.0], [219.0, 489.0]]], "lines": ["事故に遭わないよう", "危険予測する事が重要だ"]}, {"box": [744, 491, 999, 611], "vertical": false, "font_size": 101, "lines_coords": [[[751.0, 491.0], [999.0, 510.0], [991.0, 611.0], [744.0, 592.0]]], "lines": ["Ｈｍｏｚｏｎはよろいヒドキ！！"]}, {"box": [579, 618, 628, 870], "vertical": true, "font_size": 24, "lines_coords": [[[603.0, 620.0], [628.0, 620.0], [628.0, 851.0], [603.0, 851.0]], [[579.0, 618.0], [603.0, 618.0], [603.0, 870.0], [579.0, 870.0]]], "lines": ["「路地とか駐車してる車の", "カゲから飛び出すかも」って"]}, {"box": [300, 654, 347, 755], "vertical": true, "font_size": 23, "lines_coords": [[[326.0, 654.0], [346.0, 654.0], [346.0, 755.0], [326.0, 755.0]], [[300.0, 654.0], [326.0, 654.0], [326.0, 718.0], [300.0, 718.0]]], "lines": ["注意する事", "だよね"]}, {"box": [217, 652, 262, 851], "vertical": true, "font_size": 21, "lines_coords": [[[241.0, 654.0], [262.0, 654.0], [262.0, 755.0], [241.0, 755.0]], [[217.0, 652.0], [238.0, 652.0], [240.0, 849.0], [219.0, 849.0]]], "lines": ["その通りだ", "実際にやってみせよう"]}, {"box": [601, 1006, 626, 1162], "vertical": true, "font_size": 25, "lines_coords": [[[601.0, 1006.0], [626.0, 1006.0], [626.0, 1162.0], [601.0, 1162.0]]], "lines": ["ふむ：見えたぞ"]}, {"box": [273, 980, 316, 1188], "vertical": true, "font_size": 22, "lines_coords": [[[298.0, 982.0], [316.0, 982.0], [316.0, 1128.0], [298.0, 1128.0]], [[273.0, 980.0], [298.0, 980.0], [298.0, 1188.0], [273.0, 1188.0]]], "lines": ["右から脇見運転の", "白いセダンが飛び出した"]}, {"box": [215, 1125, 260, 1284], "vertical": true, "font_size": 22, "lines_coords": [[[240.0, 1126.0], [260.0, 1126.0], [260.0, 1224.0], [240.0, 1224.0]], [[215.0, 1125.0], [240.0, 1125.0], [240.0, 1284.0], [215.0, 1284.0]]], "lines": ["トラックと", "ニアミスする．．．！！"]}, {"box": [240, 1359, 283, 1515], "vertical": true, "font_size": 20, "lines_coords": [[[262.0, 1359.0], [283.0, 1359.0], [283.0, 1477.0], [262.0, 1477.0]], [[240.0, 1359.0], [258.0, 1359.0], [258.0, 1515.0], [240.0, 1515.0]]], "lines": ["おじいちゃん", "何その予知能力！？"]}, {"box": [526, 1470, 603, 1633], "vertical": true, "font_size": 24, "lines_coords": [[[577.0, 1471.0], [601.0, 1471.0], [601.0, 1633.0], [577.0, 1633.0]], [[558.0, 1475.0], [579.0, 1475.0], [579.0, 1591.0], [558.0, 1591.0]], [[532.0, 1470.0], [558.0, 1470.0], [553.0, 1631.0], [526.0, 1631.0]]], "lines": ["長年乗っていれば", "この位予測が", "出来るようになる"]}], "img_path": "00180.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [376, 798, 594, 901], "vertical": false, "font_size": 39.5, "lines_coords": [[[378.0, 798.0], [594.0, 798.0], [594.0, 836.0], [378.0, 836.0]], [[376.0, 860.0], [476.0, 860.0], [476.0, 901.0], [376.0, 901.0]]], "lines": ["著者：あｆろ", "©ａｆｒｏ"]}, {"box": [369, 615, 948, 678], "vertical": false, "font_size": 63, "lines_coords": [[[369.0, 615.0], [948.0, 615.0], [948.0, 678.0], [369.0, 678.0]]], "lines": ["ゆるキャン△，第１０巻"]}, {"box": [378, 983, 951, 1229], "vertical": false, "font_size": 37, "lines_coords": [[[378.0, 993.0], [930.0, 988.0], [930.0, 1027.0], [378.0, 1033.0]], [[378.0, 1059.0], [675.0, 1059.0], [675.0, 1096.0], [378.0, 1096.0]], [[378.0, 1123.0], [783.0, 1126.0], [783.0, 1158.0], [378.0, 1155.0]], [[526.0, 1186.0], [933.0, 1188.0], [933.0, 1226.0], [526.0, 1224.0]]], "lines": ["電子版発行日：２０２０年４月１５日", "発行人：東敬彰", "発行所：株式会社芳文社", "東京都文京区後楽１－２－１２"]}], "img_path": "00181.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [554, 787, 637, 819], "vertical": false, "font_size": 35, "lines_coords": [[[554.0, 784.0], [637.0, 784.0], [637.0, 822.0], [554.0, 822.0]]], "lines": ["あ：３"]}, {"box": [1217, 1057, 1254, 1083], "vertical": false, "font_size": 28, "lines_coords": [[[1217.0, 1055.0], [1254.0, 1055.0], [1254.0, 1085.0], [1217.0, 1085.0]]], "lines": ["１０"]}], "img_path": "00182.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1250, 583, 1269, 688], "vertical": true, "font_size": 19, "lines_coords": [[[1250.0, 583.0], [1269.0, 583.0], [1269.0, 648.0], [1250.0, 648.0]]], "lines": ["犬山家は戦"]}, {"box": [1238, 787, 1274, 901], "vertical": true, "font_size": 36, "lines_coords": [[[1238.0, 787.0], [1274.0, 787.0], [1274.0, 901.0], [1238.0, 901.0]]], "lines": ["けどある時一人の忍びが敵に正体を見抜かれてもうて"]}, {"box": [1208, 776, 1228, 822], "vertical": true, "font_size": 20, "lines_coords": [[[1208.0, 776.0], [1228.0, 776.0], [1228.0, 822.0], [1208.0, 822.0]]], "lines": ["ホッ吹きおるぞ！！"]}, {"box": [1050, 585, 1078, 748], "vertical": true, "font_size": 26, "lines_coords": [[[1050.0, 585.0], [1076.0, 585.0], [1078.0, 748.0], [1051.0, 748.0]]], "lines": ["敵陣に潜り込み情報操作をする少人数の忍び、家やった"]}, {"box": [1151, 778, 1175, 841], "vertical": true, "font_size": 24, "lines_coords": [[[1151.0, 778.0], [1175.0, 778.0], [1175.0, 841.0], [1151.0, 841.0]]], "lines": ["そっとも出ぁえ出すえ"]}, {"box": [960, 581, 1003, 744], "vertical": true, "font_size": 20, "lines_coords": [[[978.0, 581.0], [999.0, 581.0], [1003.0, 697.0], [982.0, 697.0]], [[960.0, 581.0], [980.0, 581.0], [980.0, 682.0], [960.0, 682.0]]], "lines": ["おはあちゃんもおじい犬山一族のお母や", "フト「あの日よその息子のお父さん"]}, {"box": [1048, 781, 1074, 907], "vertical": true, "font_size": 26, "lines_coords": [[[1048.0, 781.0], [1074.0, 781.0], [1074.0, 907.0], [1048.0, 907.0]]], "lines": ["味方全員が命の危険に晒される事件が起きてな"]}, {"box": [948, 782, 1004, 916], "vertical": true, "font_size": 13, "lines_coords": [[[948.0, 821.0], [961.0, 821.0], [961.0, 915.0], [948.0, 915.0]]], "lines": ["空身につけなあかんよ"]}, {"box": [774, 582, 810, 745], "vertical": true, "font_size": 24, "lines_coords": [[[778.0, 585.0], [802.0, 585.0], [798.0, 742.0], [774.0, 742.0]]], "lines": ["みんな太眉で細目やないか！！"]}, {"box": [648, 511, 700, 555], "vertical": false, "font_size": 44, "lines_coords": [[[648.0, 511.0], [700.0, 511.0], [700.0, 555.0], [648.0, 555.0]]], "lines": ["ん？"]}, {"box": [788, 777, 815, 904], "vertical": true, "font_size": 27, "lines_coords": [[[788.0, 777.0], [815.0, 777.0], [815.0, 904.0], [788.0, 904.0]]], "lines": ["あれっ？太眉細目って他にも居たような．．．"]}, {"box": [639, 606, 705, 990], "vertical": true, "font_size": 58, "lines_coords": [[[646.0, 609.0], [705.0, 609.0], [697.0, 990.0], [639.0, 990.0]]], "lines": ["ゆるキャゾ△："]}, {"box": [257, 584, 285, 708], "vertical": true, "font_size": 28, "lines_coords": [[[257.0, 584.0], [285.0, 584.0], [285.0, 708.0], [257.0, 708.0]]], "lines": ["最近なでしこちゃんにホラ吹いても"]}, {"box": [253, 775, 290, 916], "vertical": true, "font_size": 37, "lines_coords": [[[253.0, 775.0], [290.0, 775.0], [290.0, 916.0], [253.0, 916.0]]], "lines": ["あおいそれはホラ吹く時のあんたの目に問題があるんやで"]}, {"box": [66, 584, 93, 736], "vertical": true, "font_size": 27, "lines_coords": [[[66.0, 584.0], [93.0, 584.0], [93.0, 736.0], [66.0, 736.0]]], "lines": ["すぐ見抜かれてまうようになったしつまらんなー"]}, {"box": [79, 827, 93, 911], "vertical": true, "font_size": 14, "lines_coords": [[[79.0, 827.0], [93.0, 827.0], [93.0, 911.0], [79.0, 911.0]]], "lines": ["あおばあちゃん"]}, {"box": [1233, 971, 1273, 1098], "vertical": true, "font_size": 22, "lines_coords": [[[1250.0, 973.0], [1269.0, 973.0], [1273.0, 1091.0], [1254.0, 1091.0]], [[1237.0, 971.0], [1261.0, 971.0], [1258.0, 1098.0], [1233.0, 1098.0]]], "lines": ["その後一族の人間は", "二度と嘘がばれんよう"]}, {"box": [1241, 1174, 1267, 1322], "vertical": true, "font_size": 26, "lines_coords": [[[1241.0, 1174.0], [1267.0, 1174.0], [1267.0, 1322.0], [1241.0, 1322.0]]], "lines": ["そうして戦国時代の末期には「狐目太眉の犬山一族」として"]}, {"box": [1046, 973, 1078, 1111], "vertical": true, "font_size": 26, "lines_coords": [[[1046.0, 973.0], [1072.0, 973.0], [1078.0, 1108.0], [1051.0, 1108.0]]], "lines": ["表情で悟られんよう目を細めるようになったそうや"]}, {"box": [956, 978, 984, 1027], "vertical": true, "font_size": 28, "lines_coords": [[[956.0, 978.0], [984.0, 978.0], [984.0, 1027.0], [956.0, 1027.0]]], "lines": ["はっ"]}, {"box": [1051, 1170, 1074, 1323], "vertical": true, "font_size": 21, "lines_coords": [[[1051.0, 1170.0], [1072.0, 1170.0], [1074.0, 1323.0], [1053.0, 1323.0]]], "lines": ["敵はかりか味方から私恐れられる忍びの一族に成長したという話だ"]}, {"box": [973, 1165, 1000, 1310], "vertical": true, "font_size": 27, "lines_coords": [[[973.0, 1165.0], [1000.0, 1165.0], [1000.0, 1310.0], [973.0, 1310.0]]], "lines": ["もしかして先生も犬山一族の末裔だったりすんのやろか．．．"]}, {"box": [776, 1018, 813, 1110], "vertical": true, "font_size": 20, "lines_coords": [[[793.0, 1021.0], [813.0, 1021.0], [813.0, 1083.0], [793.0, 1083.0]], [[776.0, 1018.0], [795.0, 1018.0], [795.0, 1110.0], [776.0, 1110.0]]], "lines": ["鳥羽先生", "やないかっ！！"]}, {"box": [659, 938, 688, 1042], "vertical": true, "font_size": 29, "lines_coords": [[[659.0, 938.0], [688.0, 938.0], [688.0, 1042.0], [659.0, 1042.0]]], "lines": ["ｈｉｇｈａｓｈｏｏｌｄｉｒｓｐｏｙｕｒｕｃｏｍｐｉｎｏｔｉｃｅ"]}, {"box": [780, 1206, 809, 1328], "vertical": true, "font_size": 29, "lines_coords": [[[780.0, 1206.0], [809.0, 1206.0], [809.0, 1328.0], [780.0, 1328.0]]], "lines": ["あおいもまだまだやな今の話全部うそやで。"]}, {"box": [656, 1220, 690, 1372], "vertical": true, "font_size": 34, "lines_coords": [[[656.0, 1220.0], [690.0, 1220.0], [690.0, 1372.0], [656.0, 1372.0]]], "lines": ["あｆこ"]}, {"box": [259, 970, 284, 1106], "vertical": true, "font_size": 25, "lines_coords": [[[259.0, 970.0], [284.0, 970.0], [284.0, 1106.0], [259.0, 1106.0]]], "lines": ["分かっとるけどどうしてもあの目になってまうんよー"]}, {"box": [126, 997, 140, 1074], "vertical": true, "font_size": 14, "lines_coords": [[[126.0, 997.0], [140.0, 997.0], [140.0, 1074.0], [126.0, 1074.0]]], "lines": ["仕方あらへん"]}, {"box": [261, 1165, 285, 1292], "vertical": true, "font_size": 24, "lines_coords": [[[261.0, 1165.0], [285.0, 1165.0], [285.0, 1292.0], [261.0, 1292.0]]], "lines": ["「法婦の目」は３０年続く犬山一族の証やからなぁ"]}, {"box": [65, 1168, 90, 1309], "vertical": true, "font_size": 21, "lines_coords": [[[67.0, 1168.0], [88.0, 1168.0], [86.0, 1305.0], [65.0, 1305.0]]], "lines": ["ていうか３０年前のご先祖様もあんな目でホラ吹いとったん？"]}], "img_path": "00183.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1028, 330, 1284, 377], "vertical": false, "font_size": 32, "lines_coords": [[[1031.0, 333.0], [1275.0, 333.0], [1275.0, 365.0], [1031.0, 365.0]]], "lines": ["「フォーマークロークス"]}, {"box": [180, 41, 774, 320], "vertical": false, "font_size": 279, "lines_coords": [[[180.0, 41.0], [774.0, 41.0], [774.0, 320.0], [180.0, 320.0]]], "lines": ["ひぅぅぅっ"]}, {"box": [1031, 501, 1261, 522], "vertical": false, "font_size": 21, "lines_coords": [[[1031.0, 501.0], [1261.0, 501.0], [1261.0, 522.0], [1031.0, 522.0]]], "lines": ["ｐｒｅｇｅｎｔｅｄｂｙ：ＪＡｆｒｏ"]}], "img_path": "cover.jpg"}]}