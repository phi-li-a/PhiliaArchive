, 768.0]]], "lines": ["なかなか出てこーへんくて", "家族で大騒ぎやったんよ"]}, {"box": [174, 550, 236, 761], "vertical": true, "font_size": 25, "lines_coords": [[[210.0, 553.0], [234.0, 553.0], [234.0, 761.0], [210.0, 761.0]], [[174.0, 551.0], [200.0, 551.0], [200.0, 691.0], [174.0, 691.0]]], "lines": ["えっ！？そんな事", "起きるの！？"]}, {"box": [1074, 900, 1192, 1243], "vertical": true, "font_size": 33, "lines_coords": [[[1156.0, 900.0], [1190.0, 900.0], [1192.0, 1177.0], [1158.0, 1177.0]], [[1115.0, 903.0], [1147.0, 903.0], [1147.0, 1209.0], [1115.0, 1209.0]], [[1074.0, 903.0], [1106.0, 903.0], [1106.0, 1243.0], [1074.0, 1243.0]]], "lines": ["温かさにつられて", "車の下からスルっと", "入り込んじまうらしい"]}, {"box": [1153, 1348, 1194, 1423], "vertical": true, "font_size": 35, "lines_coords": [[[1153.0, 1348.0], [1194.0, 1348.0], [1194.0, 1423.0], [1153.0, 1423.0]]], "lines": ["ああ"]}, {"box": [183, 898, 255, 1211], "vertical": true, "font_size": 32, "lines_coords": [[[223.0, 898.0], [255.0, 898.0], [255.0, 1181.0], [223.0, 1181.0]], [[183.0, 900.0], [215.0, 900.0], [215.0, 1211.0], [183.0, 1211.0]]], "lines": ["そのまま運転したら、", "大変な事にならない？"]}, {"box": [1035, 1408, 1149, 1685], "vertical": true, "font_size": 35, "lines_coords": [[[1117.0, 1408.0], [1149.0, 1408.0], [1149.0, 1650.0], [1117.0, 1650.0]], [[1074.0, 1411.0], [1111.0, 1411.0], [1111.0, 1621.0], [1074.0, 1621.0]], [[1035.0, 1413.0], [1066.0, 1413.0], [1066.0, 1685.0], [1035.0, 1685.0]]], "lines": ["だから乗る前に", "ボンネットを", "こうやって叩いて"]}, {"box": [209, 1388, 285, 1661], "vertical": true, "font_size": 29, "lines_coords": [[[249.0, 1389.0], [281.0, 1389.0], [281.0, 1661.0], [249.0, 1661.0]], [[210.0, 1391.0], [236.0, 1391.0], [236.0, 1661.0], [210.0, 1661.0]]], "lines": ["中に猫が居ないか", "確認すんだってさ"]}], "img_path": "00157.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1162, 804, 1196, 969], "vertical": true, "font_size": 37, "lines_coords": [[[1162.0, 804.0], [1196.0, 804.0], [1196.0, 969.0], [1162.0, 969.0]]], "lines": ["ああれ？"]}, {"box": [127, 695, 270, 1018], "vertical": true, "font_size": 69, "lines_coords": [[[198.0, 695.0], [270.0, 695.0], [266.0, 1018.0], [195.0, 1018.0]], [[127.0, 701.0], [193.0, 701.0], [193.0, 1016.0], [127.0, 1016.0]]], "lines": ["ぎゃあぁあ", "あぁあぁ！！"]}, {"box": [1018, 890, 1106, 1083], "vertical": true, "font_size": 37, "lines_coords": [[[1063.0, 890.0], [1102.0, 890.0], [1106.0, 1044.0], [1066.0, 1044.0]], [[1018.0, 890.0], [1055.0, 890.0], [1055.0, 1083.0], [1018.0, 1083.0]]], "lines": ["なでしこ", "どうした？"]}, {"box": [624, 1209, 699, 1335], "vertical": true, "font_size": 38, "lines_coords": [[[658.0, 1209.0], [699.0, 1209.0], [699.0, 1308.0], [658.0, 1308.0]], [[624.0, 1211.0], [658.0, 1211.0], [658.0, 1335.0], [624.0, 1335.0]]], "lines": ["なんだ", "ユメかー"]}, {"box": [873, 1599, 941, 1781], "vertical": true, "font_size": 68, "lines_coords": [[[873.0, 1599.0], [941.0, 1599.0], [941.0, 1781.0], [873.0, 1781.0]]], "lines": ["はっ！？"]}], "img_path": "00158.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1098, 145, 1194, 563], "vertical": true, "font_size": 28, "lines_coords": [[[1168.0, 150.0], [1194.0, 150.0], [1194.0, 256.0], [1168.0, 256.0]], [[1130.0, 148.0], [1162.0, 148.0], [1162.0, 558.0], [1130.0, 558.0]], [[1098.0, 148.0], [1125.0, 148.0], [1125.0, 502.0], [1098.0, 502.0]]], "lines": ["こないだ", "「ディストピア飯作ってみた」って", "ネット記事見てたんだけどさ"]}, {"box": [120, 90, 526, 116], "vertical": false, "font_size": 26, "lines_coords": [[[120.0, 90.0], [526.0, 90.0], [526.0, 116.0], [120.0, 116.0]]], "lines": ["放課後８０でぃすキャンロ"]}, {"box": [316, 208, 391, 611], "vertical": true, "font_size": 30, "lines_coords": [[[354.0, 208.0], [391.0, 208.0], [391.0, 611.0], [354.0, 611.0]], [[318.0, 210.0], [346.0, 210.0], [345.0, 579.0], [316.0, 579.0]]], "lines": ["ディストピアなキャンプとか", "考えたらおもろくないか？"]}, {"box": [1076, 858, 1185, 1042], "vertical": true, "font_size": 30, "lines_coords": [[[1153.0, 858.0], [1185.0, 858.0], [1185.0, 1042.0], [1153.0, 1042.0]], [[1113.0, 860.0], [1145.0, 860.0], [1