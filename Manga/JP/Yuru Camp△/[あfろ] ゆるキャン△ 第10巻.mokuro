es": ["それは", "分かる"]}, {"box": [1147, 1237, 1209, 1656], "vertical": true, "font_size": 28, "lines_coords": [[[1177.0, 1237.0], [1209.0, 1237.0], [1209.0, 1655.0], [1177.0, 1655.0]], [[1147.0, 1239.0], [1171.0, 1239.0], [1171.0, 1601.0], [1147.0, 1601.0]]], "lines": ["１００８でもこんな疲れるのに５０％で", "伊豆行っちゃうリンちゃんは"]}, {"box": [136, 1450, 238, 1776], "vertical": true, "font_size": 44, "lines_coords": [[[189.0, 1453.0], [238.0, 1453.0], [238.0, 1584.0], [189.0, 1584.0]], [[138.0, 1455.0], [178.0, 1455.0], [178.0, 1775.0], [138.0, 1775.0]]], "lines": ["ヒドい", "言われようだよ。"]}], "img_path": "00102.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1099, 163, 1163, 528], "vertical": true, "font_size": 26, "lines_coords": [[[1134.0, 165.0], [1160.0, 165.0], [1160.0, 470.0], [1134.0, 470.0]], [[1100.0, 163.0], [1125.0, 163.0], [1125.0, 528.0], [1100.0, 528.0]]], "lines": ["やっぱり時間が早すぎて", "駅前の店はまだやってないね"]}, {"box": [264, 159, 328, 521], "vertical": true, "font_size": 26, "lines_coords": [[[300.0, 161.0], [326.0, 161.0], [326.0, 521.0], [300.0, 521.0]], [[264.0, 159.0], [290.0, 159.0], [290.0, 466.0], [264.0, 466.0]]], "lines": ["そこのお店の川根茶ソフトが", "美味しいらしいんだけど"]}, {"box": [1145, 684, 1215, 1027], "vertical": true, "font_size": 32, "lines_coords": [[[1183.0, 684.0], [1215.0, 684.0], [1215.0, 1025.0], [1183.0, 1025.0]], [[1145.0, 684.0], [1177.0, 684.0], [1177.0, 1027.0], [1145.0, 1027.0]]], "lines": ["そういえば川根茶買って", "来てって親に頼まれたよ"]}, {"box": [585, 678, 665, 939], "vertical": true, "font_size": 32, "lines_coords": [[[631.0, 680.0], [663.0, 680.0], [663.0, 939.0], [631.0, 939.0]], [[585.0, 678.0], [616.0, 678.0], [616.0, 901.0], [585.0, 901.0]]], "lines": ["まー明日帰りに", "寄ってこうよ"]}, {"box": [193, 734, 227, 881], "vertical": true, "font_size": 32, "lines_coords": [[[193.0, 735.0], [225.0, 735.0], [225.0, 881.0], [193.0, 881.0]]], "lines": ["そうだね"]}, {"box": [759, 1025, 811, 1188], "vertical": true, "font_size": 52, "lines_coords": [[[759.0, 1025.0], [811.0, 1025.0], [811.0, 1188.0], [759.0, 1188.0]]], "lines": ["あ私も"]}, {"box": [1098, 1354, 1134, 1668], "vertical": true, "font_size": 32, "lines_coords": [[[1100.0, 1357.0], [1132.0, 1357.0], [1132.0, 1668.0], [1100.0, 1668.0]]], "lines": ["道具は持って来た？"]}, {"box": [292, 1390, 356, 1685], "vertical": true, "font_size": 29, "lines_coords": [[[324.0, 1393.0], [356.0, 1393.0], [356.0, 1685.0], [324.0, 1685.0]], [[292.0, 1391.0], [318.0, 1391.0], [318.0, 1614.0], [292.0, 1614.0]]], "lines": ["一通りやっぱテントと", "寝袋嵩張るよねー"]}], "img_path": "00103.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1145, 129, 1216, 598], "vertical": true, "font_size": 30, "lines_coords": [[[1188.0, 133.0], [1215.0, 133.0], [1215.0, 316.0], [1188.0, 316.0]], [[1145.0, 129.0], [1177.0, 129.0], [1177.0, 598.0], [1145.0, 598.0]]], "lines": ["浜松で有名な", "例のハンバーグも持って来たから"]}, {"box": [708, 138, 745, 508], "vertical": true, "font_size": 32, "lines_coords": [[[708.0, 138.0], [740.0, 138.0], [740.0, 508.0], [708.0, 508.0]]], "lines": ["楽しみにしといてよー"]}, {"box": [577, 157, 652, 500], "vertical": true, "font_size": 32, "lines_coords": [[[620.0, 159.0], [652.0, 159.0], [652.0, 500.0], [620.0, 500.0]], [[577.0, 157.0], [609.0, 157.0], [609.0, 283.0], [577.0, 283.0]]], "lines": ["こっちもビーフシチュー", "の下準備"]}, {"box": [133, 185, 205, 371], "vertical": true, "font_size": 32, "lines_coords": [[[172.0, 185.0], [204.0, 185.0], [204.0, 371.0], [172.0, 371.0]], [[133.0, 187.0], [165.0, 187.0], [165.0, 313.0], [133.0, 313.0]]], "lines": ["しっかりして", "来たから"]}, {"box": [1085, 778, 1151, 1074], "vertical": true, "font_size": 30, "lines_coords": [[[1115.0, 778.0], [1149.0, 778.0], [1151.0, 1074.0], [1117.0, 1074.0]], [[1085.0, 781.0], [1111.0, 781.0], [1111.0, 946.0], [1085.0, 946.0]]], "lines": ["あでもハンバーグって", "生モノだよね"]}, {"box": [731, 566, 772, 661], "vertical": true, "font_size": 41, "lines_coords": [[[731.0, 566.0], [772.0, 566.0], [772.0, 660.0], [731.0, 660.0]]], "lines": ["うん"]}, {"box": [135, 506, 247, 688], "ve