.0]]], "lines": ["「目常」と「非日常」", "の感覚が逆転してもーて．．．"]}, {"box": [1113, 1155, 1184, 1529], "vertical": true, "font_size": 32, "lines_coords": [[[1151.0, 1155.0], [1183.0, 1155.0], [1183.0, 1526.0], [1151.0, 1526.0]], [[1113.0, 1155.0], [1145.0, 1155.0], [1145.0, 1449.0], [1113.0, 1449.0]]], "lines": ["外じゃこんなキャンパーに", "なってまうらしいわ。"]}, {"box": [854, 1316, 936, 1384], "vertical": false, "font_size": 68, "lines_coords": [[[854.0, 1316.0], [936.0, 1316.0], [936.0, 1384.0], [854.0, 1384.0]]], "lines": ["スーッ"]}, {"box": [526, 1246, 680, 1365], "vertical": false, "font_size": 81, "lines_coords": [[[528.0, 1246.0], [678.0, 1250.0], [676.0, 1331.0], [526.0, 1327.0]]], "lines": ["オフィスチャアメテーブル"]}, {"box": [182, 1399, 274, 1567], "vertical": true, "font_size": 34, "lines_coords": [[[236.0, 1402.0], [270.0, 1402.0], [270.0, 1567.0], [236.0, 1567.0]], [[183.0, 1402.0], [217.0, 1402.0], [217.0, 1567.0], [183.0, 1567.0]]], "lines": ["ならない", "ならない"]}], "img_path": "00170.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [957, 201, 1000, 401], "vertical": true, "font_size": 39, "lines_coords": [[[960.0, 204.0], [999.0, 204.0], [999.0, 401.0], [960.0, 401.0]]], "lines": ["お姉ちゃん！！"]}, {"box": [560, 136, 654, 345], "vertical": true, "font_size": 37, "lines_coords": [[[613.0, 136.0], [652.0, 138.0], [645.0, 345.0], [605.0, 343.0]], [[564.0, 146.0], [598.0, 146.0], [594.0, 318.0], [560.0, 318.0]]], "lines": ["全くじー億円", "あた、たし！！"]}, {"box": [118, 75, 425, 103], "vertical": false, "font_size": 26, "lines_coords": [[[118.0, 75.0], [425.0, 76.0], [425.0, 103.0], [118.0, 101.0]]], "lines": ["放課後６５うそやで"]}, {"box": [1145, 318, 1213, 671], "vertical": true, "font_size": 34, "lines_coords": [[[1181.0, 318.0], [1213.0, 318.0], [1213.0, 671.0], [1181.0, 671.0]], [[1145.0, 318.0], [1177.0, 318.0], [1177.0, 517.0], [1145.0, 517.0]]], "lines": ["私毎年エイプリルフールに", "嘘つくんだけど"]}, {"box": [1021, 478, 1100, 819], "vertical": true, "font_size": 34, "lines_coords": [[[1063.0, 478.0], [10