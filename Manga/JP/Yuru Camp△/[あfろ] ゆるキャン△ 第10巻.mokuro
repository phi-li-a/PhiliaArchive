 "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [], "img_path": "00081.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [], "img_path": "00082.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [759, 160, 1093, 229], "vertical": false, "font_size": 32, "lines_coords": [[[759.0, 161.0], [1093.0, 161.0], [1093.0, 193.0], [759.0, 193.0]], [[761.0, 193.0], [894.0, 193.0], [894.0, 226.0], [761.0, 226.0]]], "lines": ["大井川キャンプ３解です！！", "くくじり"]}, {"box": [881, 277, 920, 313], "vertical": false, "font_size": 36, "lines_coords": [[[881.0, 277.0], [920.0, 277.0], [920.0, 313.0], [881.0, 313.0]]], "lines": ["お"]}, {"box": [855, 356, 979, 391], "vertical": false, "font_size": 34, "lines_coords": [[[858.0, 358.0], [976.0, 356.0], [976.0, 390.0], [858.0, 391.0]]], "lines": ["やった！！"]}, {"box": [240, 166, 560, 191], "vertical": false, "font_size": 25, "lines_coords": [[[240.0, 166.0], [560.0, 166.0], [560.0, 191.0], [240.0, 191.0]]], "lines": ["でもどうして大井川なの？"]}, {"box": [240, 227, 601, 298], "vertical": false, "font_size": 24, "lines_coords": [[[243.0, 232.0], [573.0, 232.0], [573.0, 256.0], [243.0, 256.0]], [[249.0, 270.0], [601.0, 270.0], [601.0, 294.0], [249.0, 294.0]]], "lines": ["両方の家から真ん中くらい", "じゃないと片方が大変じゃん"]}, {"box": [271, 334, 564, 399], "vertical": false, "font_size": 26, "lines_coords": [[[277.0, 337.0], [540.0, 337.0], [540.0, 363.0], [277.0, 363.0]], [[277.0, 371.0], [553.0, 371.0], [553.0, 397.0], [277.0, 397.0]]], "lines": ["で、調べたらちょうど", "大井川の辺りだった訳"]}, {"box": [775, 778, 1201, 842], "vertical": false, "font_size": 26, "lines_coords": [[[781.0, 783.0], [1198.0, 783.0], [1198.0, 808.0], [781.0, 808.0]], [[783.0, 813.0], [1175.0, 813.0], [1175.0, 840.0], [783.0, 840.0]]], "lines": ["初日は私達／バイクで井川を回ってから", "キャンプ場向かうつもりなんだけど"]}, {"box": [772, 887, 1066, 919], "vertical": false, "font_size": 25, "lines_coords": [[[772.0, 890.0], [1059.0, 890.0], [1059.0, 915.0], [772.0, 915.0]]], "lines": ["それまでー人でも大丈夫？