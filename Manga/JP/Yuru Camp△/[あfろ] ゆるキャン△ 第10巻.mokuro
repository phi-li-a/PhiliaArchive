.0, 918.0], [1117.0, 918.0], [1117.0, 1260.0], [1085.0, 1260.0]]], "lines": ["けどしっかりした", "木の道具って", "値段高いんだよねぇ．．．"]}, {"box": [128, 956, 355, 1218], "vertical": true, "font_size": 35, "lines_coords": [[[311.0, 956.0], [348.0, 956.0], [352.0, 1183.0], [315.0, 1183.0]], [[268.0, 960.0], [307.0, 960.0], [303.0, 1185.0], [264.0, 1185.0]], [[223.0, 958.0], [255.0, 958.0], [255.0, 1218.0], [223.0, 1218.0]], [[176.0, 958.0], [210.0, 958.0], [208.0, 1218.0], [174.0, 1218.0]], [[129.0, 958.0], [161.0, 958.0], [161.0, 1179.0], [129.0, 1179.0]]], "lines": ["それに重くて", "かさばるから", "うちらみたいな", "徒歩キャンやと", "大変やしなぁ"]}, {"box": [1051, 1357, 1173, 1738], "vertical": true, "font_size": 34, "lines_coords": [[[1140.0, 1363.0], [1171.0, 1363.0], [1171.0, 1599.0], [1140.0, 1599.0]], [[1098.0, 1361.0], [1130.0, 1361.0], [1130.0, 1635.0], [1098.0, 1635.0]], [[1051.0, 1357.0], [1089.0, 1357.0], [1089.0, 1738.0], [1051.0, 1738.0]]], "lines": ["ホンモノの木に", "こだわんなくても", "木目調でもよくないか？"]}, {"box": [217, 1395, 294, 1672], "vertical": true, "font_size": 32, "lines_coords": [[[258.0, 1395.0], [290.0, 1395.0], [290.0, 1633.0], [258.0, 1633.0]], [[217.0, 1395.0], [249.0, 1395.0], [249.0, 1672.0], [217.0, 1672.0]]], "lines": ["結構いい感じの", "道具売ってるぞ？"]}], "img_path": "00173.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1070, 169, 1200, 579], "vertical": true, "font_size": 34, "lines_coords": [[[1164.0, 170.0], [1198.0, 170.0], [1200.0, 579.0], [1166.0, 579.0]], [[1117.0, 170.0], [1151.0, 170.0], [1153.0, 577.0], [1119.0, 577.0]], [[1070.0, 172.0], [1104.0, 172.0], [1106.0, 468.0], [1072.0, 468.0]]], "lines": ["それにこういうの使えば", "手持ちの道具を木目調に", "アレンジできるぞ"]}, {"box": [774, 177, 967, 211], "vertical": false, "font_size": 27, "lines_coords": [[[778.0, 181.0], [958.0, 181.0], [958.0, 208.0], [778.0, 208.0]]], "lines": ["木目調シート"]}, {"box": [197, 178, 279, 260], "vertical": true, "font_size": 45, "lines_coords": [[[234.0, 178.0], [279.0, 178.0], [279.0, 258.0], [234.0, 258.0]]], "lines":