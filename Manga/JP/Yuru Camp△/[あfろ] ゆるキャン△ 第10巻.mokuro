ロヘイヤなどを加え"]}, {"box": [328, 793, 410, 1053], "vertical": true, "font_size": 32, "lines_coords": [[[375.0, 795.0], [406.0, 795.0], [406.0, 1053.0], [375.0, 1053.0]], [[328.0, 793.0], [361.0, 793.0], [363.0, 1016.0], [330.0, 1016.0]]], "lines": ["さらに粘り気を", "出しましょう"]}, {"box": [595, 1189, 681, 1395], "vertical": true, "font_size": 39, "lines_coords": [[[637.0, 1200.0], [676.0, 1200.0], [676.0, 1395.0], [637.0, 1395.0]]], "lines": ["へびのぬｋ"]}, {"box": [159, 885, 247, 1046], "vertical": true, "font_size": 34, "lines_coords": [[[210.0, 888.0], [243.0, 888.0], [243.0, 1044.0], [210.0, 1044.0]], [[161.0, 886.0], [195.0, 886.0], [195.0, 1046.0], [161.0, 1046.0]]], "lines": ["変なもん", "混ぜんな"]}, {"box": [1179, 1183, 1220, 1732], "vertical": true, "font_size": 37, "lines_coords": [[[1179.0, 1188.0], [1216.0, 1188.0], [1216.0, 1732.0], [1179.0, 1732.0]]], "lines": ["次にケーシング（度）を使う分だけカット"]}, {"box": [719, 1180, 793, 1792], "vertical": true, "font_size": 30, "lines_coords": [[[757.0, 1190.0], [789.0, 1190.0], [789.0, 1786.0], [757.0, 1786.0]], [[721.0, 1190.0], [748.0, 1190.0], [748.0, 1396.0], [721.0, 1396.0]]], "lines": ["スタッファーの口金にに縞めた状態でセットし", "先端を縛ります。"]}, {"box": [144, 1526, 224, 1751], "vertical": true, "font_size": 35, "lines_coords": [[[185.0, 1526.0], [223.0, 1526.0], [223.0, 1751.0], [185.0, 1751.0]], [[144.0, 1526.0], [176.0, 1526.0], [176.0, 1666.0], [144.0, 1666.0]]], "lines": ["おいそれ以上", "言うなよ"]}], "img_path": "00059.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1101, 131, 1213, 562], "vertical": true, "font_size": 32, "lines_coords": [[[1175.0, 131.0], [1213.0, 131.0], [1213.0, 320.0], [1175.0, 320.0]], [[1138.0, 131.0], [1171.0, 131.0], [1170.0, 504.0], [1136.0, 504.0]], [[1104.0, 135.0], [1130.0, 135.0], [1130.0, 560.0], [1104.0, 560.0]]], "lines": ["ケーシングは", "コラーゲン製の人工の物と", "動物の腸を使う天然の物があり、"]}, {"box": [127, 133, 245, 561], "vertical": true, "font_size": 34, "lines_coords": [[[206.0, 135.0], [243.0, 135.0], [243.0, 558.0], [206.0, 558.0]], [[168.0, 138.0], [200.0, 138.0], [200.0, 435.0], [168.0, 435.0]], [[127.0, 133.0], [159.0, 133.0], [161.0, 560.0], [129.0, 560.0]]], "lines": ["天然ケーシングを使う場合は", "はじめに水に漬けて", "塩抜きをする必要があります。"]}, {"box": [1132, 608, 1204, 894], "vertical": true, "font_size": 34, "lines_coords": [[[1166.0, 611.0], [1203.0, 611.0], [1203.0, 894.0], [1166.0, 894.0]], [[1132.0, 613.0], [1164.0, 613.0], [1164.0, 892.0], [1132.0, 892.0]]], "lines": ["そしてこねた挽肉を", "スタッファーに詰め"]}, {"box": [616, 611, 696, 1080], "vertical": true, "font_size": 40, "lines_coords": [[[656.0, 611.0], [693.0, 611.0], [691.0, 976.0], [654.0, 976.0]], [[616.0, 611.0], [660.0, 611.0], [660.0, 1080.0], [616.0, 1080.0]]], "lines": ["空気が入らないよう、また", "皮がバンバンになりすぎないよう"]}, {"box": [133, 604, 172, 991], "vertical": true, "font_size": 27, "lines_coords": [[[136.0, 611.0], [163.0, 611.0], [163.0, 986.0], [136.0, 986.0]]], "lines": ["程よく押し出していきます"]}, {"box": [1116, 1190, 1207, 1760], "vertical": true, "font_size": 38, "lines_coords": [[[1162.0, 1200.0], [1200.0, 1200.0], [1200.0, 1723.0], [1162.0, 1723.0]], [[1117.0, 1198.0], [1155.0, 1198.0], [1155.0, 1760.0], [1117.0, 1760.0]]], "lines": ["肉を詰め終わったら後ろを縛り", "好きな長さの所で捻れば完成です"]}, {"box": [492, 1696, 881, 1735], "vertical": false, "font_size": 26, "lines_coords": [[[495.0, 1700.0], [870.0, 1700.0], [870.0, 1726.0], [495.0, 1726.0]]], "lines": ["スタ１００％生ソーヤー、"]}, {"box": [155, 1485, 271, 1698], "vertical": true, "font_size": 52, "lines_coords": [[[210.0, 1485.0], [268.0, 1485.0], [271.0, 1698.0], [213.0, 1698.0]], [[155.0, 1488.0], [200.0, 1488.0], [200.0, 1546.0], [155.0, 1546.0]]], "lines": ["ほれーっ", "！！"]}], "img_path": "00060.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1146, 127, 1215, 436], "vertical": true, "font_size": 29, "lines_coords": [[[1183.0, 127.0], [1215.0, 127.0], [1215.0, 436.0], [1183.0, 436.0]], [[1147.0, 129.0], [1173.0, 129.0], [1173.0, 315.0], [1147.0, 315.0]]], "lines": ["ちゃんとソーセージに", "なっとるなー"]}, {"box": [6