e": 32, "lines_coords": [[[626.0, 609.0], [658.0, 609.0], [658.0, 736.0], [626.0, 736.0]], [[588.0, 611.0], [620.0, 611.0], [620.0, 736.0], [588.0, 736.0]]], "lines": ["富士山．．．", "だよね？"]}, {"box": [176, 575, 285, 920], "vertical": true, "font_size": 28, "lines_coords": [[[251.0, 575.0], [283.0, 575.0], [283.0, 810.0], [251.0, 810.0]], [[215.0, 579.0], [241.0, 579.0], [241.0, 916.0], [215.0, 916.0]], [[176.0, 577.0], [202.0, 577.0], [202.0, 823.0], [176.0, 823.0]]], "lines": ["そうだ日本全国", "デフォルメされた富士山", "と言えばこうだな"]}, {"box": [1145, 1020, 1228, 1230], "vertical": true, "font_size": 40, "lines_coords": [[[1186.0, 1020.0], [1228.0, 1020.0], [1228.0, 1126.0], [1186.0, 1126.0]], [[1145.0, 1023.0], [1183.0, 1023.0], [1183.0, 1230.0], [1145.0, 1230.0]]], "lines": ["それで", "この富士山．．．"]}, {"box": [963, 1404, 1065, 1436], "vertical": false, "font_size": 32, "lines_coords": [[[963.0, 1404.0], [1065.0, 1404.0], [1065.0, 1436.0], [963.0, 1436.0]]], "lines": ["大沢崩れ"]}, {"box": [615, 991, 712, 1297], "vertical": true, "font_size": 45, "lines_coords": [[[660.0, 991.0], [712.0, 993.0], [706.0, 1228.0], [654.0, 1226.0]], [[615.0, 995.0], [652.0, 995.0], [652.0, 1297.0], [615.0, 1297.0]]], "lines": ["どこから見た", "富士山だと思う？"]}, {"box": [165, 1006, 243, 1183], "vertical": true, "font_size": 32, "lines_coords": [[[210.0, 1010.0], [243.0, 1010.0], [243.0, 1117.0], [210.0, 1117.0]], [[168.0, 1006.0], [200.0, 1006.0], [196.0, 1183.0], [165.0, 1183.0]]], "lines": ["えっ？", "どこから？"]}, {"box": [1145, 1396, 1217, 1772], "vertical": true, "font_size": 32, "lines_coords": [[[1183.0, 1396.0], [1215.0, 1396.0], [1216.0, 1771.0], [1185.0, 1771.0]], [[1145.0, 1400.0], [1177.0, 1400.0], [1177.0, 1539.0], [1145.0, 1539.0]]], "lines": ["『富士山は見る方角によって", "形が違う。"]}, {"box": [694, 1404, 764, 1748], "vertical": true, "font_size": 29, "lines_coords": [[[731.0, 1406.0], [763.0, 1406.0], [763.0, 1747.0], [731.0, 1747.0]], [[695.0, 1408.0], [721.0, 1408.0], [721.0, 1685.0], [695.0, 1685.0]]], "lines": ["西から見れば大沢崩れが", "南から見れば宝永山"]}, {"box": [549, 1576, 656, 1610], "vertical": false, "font_size": 34, "lines_coords": [[[549.0, 1576.0], [656.0, 1576.0], [656.0, 1610.0], [549.0, 1610.0]]], "lines": ["吉田大沢"]}, {"box": [144, 1413, 253, 1694], "vertical": true, "font_size": 30, "lines_coords": [[[219.0, 1413.0], [251.0, 1413.0], [251.0, 1601.0], [219.0, 1601.0]], [[180.0, 1413.0], [211.0, 1413.0], [211.0, 1693.0], [180.0, 1693.0]], [[144.0, 1413.0], [170.0, 1413.0], [170.0, 1693.0], [144.0, 1693.0]]], "lines": ["東から見れば", "宝永山と吉田大沢が", "見えるはずなんだよ"]}], "img_path": "00165.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [952, 127, 1164, 510], "vertical": true, "font_size": 37, "lines_coords": [[[1126.0, 129.0], [1164.0, 129.0], [1164.0, 510.0], [1126.0, 510.0]], [[1085.0, 129.0], [1123.0, 129.0], [1123.0, 406.0], [1085.0, 406.0]], [[1040.0, 129.0], [1078.0, 129.0], [1078.0, 472.0], [1040.0, 472.0]], [[990.0, 127.0], [1035.0, 127.0], [1035.0, 440.0], [990.0, 440.0]], [[952.0, 133.0], [978.0, 133.0], [978.0, 298.0], [952.0, 298.0]]], "lines": ["それが無いと言うことは。", "デフォルメされた", "富士山イラストは全て", "北側から見た富士山", "．．．．．つまり"]}, {"box": [772, 134, 855, 750], "vertical": true, "font_size": 79, "lines_coords": [[[772.0, 138.0], [851.0, 138.0], [855.0, 750.0], [776.0, 750.0]]], "lines": ["山梨（甲府）側から見た"]}, {"box": [165, 128, 246, 866], "vertical": true, "font_size": 75, "lines_coords": [[[168.0, 138.0], [243.0, 138.0], [240.0, 866.0], [165.0, 866.0]]], "lines": ["富士山だったんズラーっ！！"]}, {"box": [774, 983, 879, 1730], "vertical": true, "font_size": 101, "lines_coords": [[[774.0, 991.0], [875.0, 991.0], [879.0, 1730.0], [778.0, 1730.0]]], "lines": ["ななんやってーっ！！！"]}, {"box": [202, 999, 288, 1241], "vertical": true, "font_size": 42, "lines_coords": [[[236.0, 999.0], [288.0, 999.0], [288.0, 1081.0], [236.0, 1081.0]], [[206.0, 1001.0], [238.0, 1001.0], [234.0, 1241.0], [202.0, 1241.0]]], "lines": ["いや", "どうでもええわ"]}], "img_path": "00166.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1115, 176, 1190, 586], "vertical": true, "font_size": 38, "lines_coords": [[[1145.0, 176.0], [1190.0, 176.0], [1190.0, 513.0], [1145.0, 513.0]], [[1115.0, 183.0], [1147.0, 183.0], [1147.0, 586.0], [1115.0, 586.0]]], "lines": ["私雨の日のキャンプも", "いつかやってみたいんだよね"]}, {"box": [127, 78, 536, 106], "vertical": false, "font_size": 26, "lines_coords": [[[127.0, 78.0], [536.0, 80.0], [536.0, 106.0], [127.0, 105.0]]], "lines": ["放課後８４雨の日キャンプ"]}, {"box": [159, 210, 230, 714], "vertical": true, "font_size": 29, "lines_coords": [[[196.0, 215.0], [228.0, 215.0], [228.0, 714.0], [196.0, 714.0]], [[159.0, 217.0], [185.0, 217.0], [185.0, 648.0], [159.0, 648.0]]], "lines": ["雨に濡れない準備をしっかりすれば", "思ったより悪くないと思うんだ"]}, {"box": [1122, 868, 1191, 1147], "vertical": true, "font_size": 29, "lines_coords": [[[1158.0, 868.0], [1190.0, 868.0], [1190.0, 1085.0], [1158.0, 1085.0]], [[1125.0, 870.0], [1151.0, 870.0], [1151.0, 1147.0], [1125.0, 1147.0]]], "lines": ["タープに当たる", "雨の音を聞きながら、"]}, {"box": [337, 825, 375, 1140], "vertical": true, "font_size": 34, "lines_coords": [[[337.0, 825.0], [371.0, 825.0], [373.0, 1138.0], [339.0, 1138.0]]], "lines": ["焚き火してご飯食べて"]}, {"box": [151, 869, 223, 1179], "vertical": true, "font_size": 30, "lines_coords": [[[189.0, 870.0], [221.0, 870.0], [221.0, 1179.0], [189.0, 1179.0]], [[151.0, 870.0], [178.0, 870.0], [178.0, 1115.0], [151.0, 1115.0]]], "lines": ["いつもと違う雰囲気で", "楽しいと思うんだ"]}, {"box": [828, 1344, 930, 1623], "vertical": true, "font_size": 30, "lines_coords": [[[894.0, 1346.0], [930.0, 1346.0], [930.0, 1391.0], [894.0, 1391.0]], [[864.0, 1346.0], [890.0, 1346.0], [890.0, 1541.0], [864.0, 1541.0]], [[828.0, 1344.0], [855.0, 1344.0], [856.0, 1623.0], [830.0, 1623.0]]], "lines": ["んー", "そう言われると", "雨の日もアリかもなぁ"]}, {"box": [433, 1360, 503, 1606], "vertical": true, "font_size": 26, "lines_coords": [[[472.0, 1363.0], [498.0, 1363.0], [498.0, 1605.0], [472.0, 1605.0]], [[433.0, 1361.0], [459.0, 1361.0], [459.0, 1546.0], [433.0, 1546.0]]], "lines": ["雨だと設営撤収が", "大変そうだな"]}], "img_path": "00167.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1106, 133, 1209, 549], "vertical": true, "font_size": 30, "lines_coords": [[[1175.0, 133.0], [1207.0, 133.0], [1207.0, 517.0], [1175.0, 517.0]], [[1140.0, 135.0], [1171.0, 135.0], [1171.0, 549.0], [1140.0, 549.0]], [[1106.0, 136.0], [1132.0, 136.0], [1132.0, 341.0], [1106.0, 341.0]]], "lines": ["水はけの悪いキャンプ場だと", "サイト一面水たまりになる事も", "あるらしいから"]}, {"box": [719, 151, 753, 491], "vertical": true, "font_size": 25, "lines_coords": [[[723.0, 151.0], [748.0, 151.0], [748.0, 491.0], [723.0, 491.0]]], "lines": ["それも気をつけないとな"]}, {"box": [553, 148, 662, 461], "vertical": true, "font_size": 30, "lines_coords": [[[633.0, 151.0], [660.0, 151.0], [660.0, 457.0], [633.0, 457.0]], [[592.0, 148.0], [624.0, 148.0], [624.0, 397.0], [592.0, 397.0]], [[553.0, 148.0], [585.0, 148.0], [585.0, 461.0], [553.0, 461.0]]], "lines": ["あんまり雨がヒドいと", "まずキャンプ場が", "水没して帰れなくなる"]}, {"box": [220, 178, 279, 294], "vertical": true, "font_size": 34, "lines_coords": [[[245.0, 178.0], [279.0, 178.0], [279.0, 294.0], [245.0, 294.0]]], "lines": ["帰れない"]}, {"box": [729, 618, 766, 815], "vertical": true, "font_size": 37, "lines_coords": [[[729.0, 618.0], [766.0, 618.0], [766.0, 815.0], [729.0, 815.0]]], "lines": ["そうなんだ"]}, {"box": [1117, 1240, 1146, 1297], "vertical": true, "font_size": 29, "lines_coords": [[[1117.0, 1240.0], [1146.0, 1240.0], [1146.0, 1297.0], [1117.0, 1297.0]]], "lines": ["山中は"]}, {"box": [888, 1340, 969, 1371], "vertical": false, "font_size": 26, "lines_coords": [[[890.0, 1342.0], [950.0, 1342.0], [950.0, 1368.0], [890.0, 1368.0]]], "lines": ["．．．"]}, {"box": [755, 1147, 783, 1192], "vertical": false, "font_size": 45, "lines_coords": [[[755.0, 1147.0], [783.0, 1147.0], [783.0, 1192.0], [755.0, 1192.0]]], "lines": ["本格が"]}, {"box": [576, 1183, 674, 1402], "vertical": true, "font_size": 42, "lines_coords": [[[628.0, 1185.0], [673.0, 1185.0], [673.0, 1402.0], [628.0, 1402.0]], [[577.0, 1186.0], [615.0, 1186.0], [615.0, 1380.0], [577.0, 1380.0]]], "lines": ["最終的には", "こうなる。"]}, {"box": [333, 1123, 451, 1156], "vertical": false, "font_size": 33, "lines_coords": [[[333.0, 1123.0], [451.0, 1123.0], [451.0, 1156.0], [333.0, 1156.0]]], "lines": ["甲府湾"]}, {"box": [757, 1439, 828, 1783], "vertical": true, "font_size": 32, "lines_coords": [[[795.0, 1440.0], [826.0, 1440.0], [826.0, 1659.0], [795.0, 1659.0]], [[757.0, 1440.0], [789.0, 1440.0], [789.0, 1783.0], [757.0, 1783.0]]], "lines": ["しばらくすると", "富士五湖が全部繋がって"]}, {"box": [136, 1500, 236, 1695], "vertical": true, "font_size": 45, "lines_coords": [[[189.0, 1500.0], [234.0, 1500.0], [234.0, 1674.0], [189.0, 1674.0]], [[136.0, 1500.0], [181.0, 1500.0], [181.0, 1695.0], [136.0, 1695.0]]], "lines": ["未曾有の", "大災害や。"]}], "img_path": "00168.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1171, 151, 1203, 635], "vertical": true, "font_size": 30, "lines_coords": [[[1171.0, 151.0], [1203.0, 151.0], [1203.0, 635.0], [1171.0, 635.0]]], "lines": ["私一人暮らしするようになったら"]}, {"box": [176, 78, 506, 105], "vertical": false, "font_size": 27, "lines_coords": [[[176.0, 78.0], [506.0, 78.0], [506.0, 105.0], [176.0, 105.0]]], "lines": ["課後８５日常と非日常"]}, {"box": [148, 165, 227, 511], "vertical": true, "font_size": 32, "lines_coords": [[[191.0, 170.0], [223.0, 170.0], [223.0, 510.0], [191.0, 510.0]], [[148.0, 166.0], [180.0, 166.0], [180.0, 476.0], [148.0, 476.0]]], "lines": ["あれオシャレだよなー", "私もやってみたいぞ"]}, {"box": [1057, 406, 1125, 748], "vertical": true, "font_size": 30, "lines_coords": [[[1093.0, 406.0], [1125.0, 406.0], [1125.0, 748.0], [1093.0, 748.0]], [[1057.0, 408.0], [1083.0, 408.0], [1083.0, 718.0], [1057.0, 718.0]]], "lines": ["家具をアウトドア用品で", "揃えてみたいんだよね"]}, {"box": [721, 879, 806, 1179], "vertical": true, "font_size": 36, "lines_coords": [[[768.0, 881.0], [806.0, 881.0], [806.0, 1179.0], [768.0, 1179.0]], [[721.0, 879.0], [755.0, 879.0], [757.0, 1177.0], [723.0, 1177.0]]], "li