"lines": ["ダムカレー"]}, {"box": [943, 758, 1131, 1147], "vertical": true, "font_size": 33, "lines_coords": [[[1096.0, 763.0], [1128.0, 763.0], [1128.0, 952.0], [1096.0, 952.0]], [[1055.0, 761.0], [1093.0, 761.0], [1093.0, 1147.0], [1055.0, 1147.0]], [[1020.0, 763.0], [1051.0, 763.0], [1051.0, 1140.0], [1020.0, 1140.0]], [[978.0, 763.0], [1010.0, 763.0], [1010.0, 1018.0], [978.0, 1018.0]], [[943.0, 761.0], [975.0, 761.0], [975.0, 952.0], [943.0, 952.0]]], "lines": ["ごはんをダム", "カレーをダム湖に見たてた", "ダムがある地域の飲食店で", "食べる事の出来る", "ご当地カレー"]}, {"box": [153, 333, 194, 633], "vertical": true, "font_size": 38, "lines_coords": [[[153.0, 333.0], [191.0, 333.0], [193.0, 633.0], [155.0, 633.0]]], "lines": ["ダムカレーだっ！！"]}, {"box": [127, 759, 282, 1107], "vertical": true, "font_size": 32, "lines_coords": [[[245.0, 761.0], [277.0, 761.0], [277.0, 1104.0], [245.0, 1104.0]], [[206.0, 763.0], [238.0, 763.0], [238.0, 952.0], [206.0, 952.0]], [[165.0, 759.0], [196.0, 759.0], [200.0, 1044.0], [168.0, 1044.0]], [[127.0, 761.0], [159.0, 761.0], [159.0, 911.0], [127.0, 911.0]]], "lines": ["その土地のダムを模して", "作られるため", "様々なダムカレーが", "存在する。"]}, {"box": [908, 1186, 1153, 1539], "vertical": true, "font_size": 52, "lines_coords": [[[1089.0, 1186.0], [1153.0, 1186.0], [1153.0, 1539.0], [1089.0, 1539.0]], [[1053.0, 1188.0], [1106.0, 1188.0], [1102.0, 1501.0], [1050.0, 1501.0]], [[1001.0, 1188.0], [1059.0, 1188.0], [1059.0, 1428.0], [1001.0, 1428.0]], [[958.0, 1188.0], [1003.0, 1188.0], [1003.0, 1494.0], [958.0, 1494.0]], [[916.0, 1192.0], [956.0, 1192.0], [952.0, 1458.0], [913.0, 1458.0]]], "lines": ["ダムカレーはいつか", "食べに行きたいと", "思ってたけど", "まさかこんな所で", "遭遇するなんて"]}, {"box": [879, 1188, 900, 1270], "vertical": true, "font_size": 21, "lines_coords": [[[879.0, 1188.0], [900.0, 1188.0], [900.0, 1270.0], [879.0, 1270.0]]], "lines": ["．．．．．"]}, {"box": [650, 1190, 755, 1635], "vertical": true, "font_size": 53, "lines_coords": [[[705.0, 1192.0], [755.0, 1192.0], [755.0, 1526.0], [705.0, 1526.0]], [[650.0, 1190.0], [706.0, 1190.0], [706.0, 1635.0], [650.0, 1635.0]]], "lines": ["そっか大井川は", "静岡の中でも大きな川"]}, {"box": [123, 1190, 230, 1588], "vertical": true, "font_size": 48, "lines_coords": [[[176.0, 1190.0], [228.0, 1190.0], [228.0, 1586.0], [176.0, 1586.0]], [[123.0, 1190.0], [168.0, 1190.0], [174.0, 1588.0], [129.0, 1588.0]]], "lines": ["そんな川ならダムが", "あるのは当たり前！！"]}, {"box": [208, 1816, 855, 1846], "vertical": false, "font_size": 26, "lines_coords": [[[208.0, 1816.0], [855.0, 1820.0], [855.0, 1846.0], [208.0, 1843.0]]], "lines": ["狩野川と安倍川は大きいいけどダムないですよー。"]}], "img_path": "00130.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1070, 136, 1220, 517], "vertical": true, "font_size": 88, "lines_coords": [[[1119.0, 136.0], [1216.0, 136.0], [1220.0, 517.0], [1123.0, 517.0]], [[1070.0, 142.0], [1149.0, 142.0], [1149.0, 395.0], [1070.0, 395.0]]], "lines": ["ダムカレーが", "あるのも"]}, {"box": [140, 335, 288, 819], "vertical": true, "font_size": 77, "lines_coords": [[[206.0, 335.0], [288.0, 335.0], [285.0, 819.0], [202.0, 819.0]], [[140.0, 343.0], [211.0, 343.0], [215.0, 708.0], [144.0, 708.0]]], "lines": ["当たり前だったん", "だぁーっ！！"]}, {"box": [1110, 971, 1141, 1095], "vertical": true, "font_size": 31, "lines_coords": [[[1110.0, 971.0], [1141.0, 971.0], [1141.0, 1095.0], [1110.0, 1095.0]]], "lines": ["よぉーし"]}, {"box": [1140, 1254, 1213, 1475], "vertical": true, "font_size": 32, "lines_coords": [[[1179.0, 1256.0], [1211.0, 1256.0], [1211.0, 1473.0], [1179.0, 1473.0]], [[1140.0, 1254.0], [1171.0, 1254.0], [1171.0, 1443.0], [1140.0, 1443.0]]], "lines": ["そんで食後には", "リンちゃんが"]}, {"box": [951, 1295, 1020, 1356], "vertical": false, "font_size": 61, "lines_coords": [[[951.0, 1295.0], [1020.0, 1295.0], [1020.0, 1356.0], [951.0, 1356.0]]], "lines": ["絶対いうまい"]}, {"box": [234, 960, 307, 1147], "vertical": true, "font_size": 30, "lines_coords": [[[271.0, 960.0], [303.0, 960.0], [303.0, 1147.0], [271.0, 1147.0]], [[234.0, 960.0], [262.0, 960.0], [264.0, 1115.0], [236.0, 1115.0]]], "lines": ["ダムカレーに