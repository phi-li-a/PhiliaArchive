0], [654.0, 438.0], [654.0, 633.0], [628.0, 633.0]]], "lines": ["明日キャンプ行こうと", "思ってたのに．．"]}, {"box": [826, 772, 933, 1074], "vertical": true, "font_size": 31, "lines_coords": [[[886.0, 776.0], [928.0, 772.0], [933.0, 841.0], [892.0, 845.0]], [[858.0, 781.0], [885.0, 781.0], [885.0, 1074.0], [858.0, 1074.0]], [[826.0, 783.0], [851.0, 783.0], [851.0, 1074.0], [826.0, 1074.0]]], "lines": ["えっ", "タイヤミつついてるよ？", "二輪の免許で乗れるの？"]}, {"box": [133, 367, 199, 678], "vertical": true, "font_size": 29, "lines_coords": [[[170.0, 369.0], [196.0, 369.0], [196.0, 648.0], [170.0, 648.0]], [[133.0, 367.0], [165.0, 367.0], [165.0, 678.0], [133.0, 678.0]]], "lines": ["せっかくだからあれで", "行ってみたらどうだい？"]}, {"box": [380, 903, 410, 952], "vertical": true, "font_size": 30, "lines_coords": [[[380.0, 903.0], [410.0, 903.0], [410.0, 952.0], [380.0, 952.0]]], "lines": ["ふむ"]}, {"box": [562, 896, 686, 1288], "vertical": true, "font_size": 28, "lines_coords": [[[652.0, 898.0], [678.0, 898.0], [678.0, 1149.0], [652.0, 1149.0]], [[616.0, 896.0], [650.0, 896.0], [650.0, 988.0], [616.0, 988.0]], [[594.0, 960.0], [618.0, 960.0], [618.0, 1162.0], [594.0, 1162.0]], [[562.0, 961.0], [588.0, 961.0], [590.0, 1288.0], [564.0, 1288.0]]], "lines": ["その辺説明は難しい", "けど．．．", "大丈夫１００だから", "リンの免許でも運転できるよ"]}, {"box": [125, 1050, 192, 1247], "vertical": true, "font_size": 29, "lines_coords": [[[159.0, 1050.0], [191.0, 1050.0], [191.0, 1220.0], [159.0, 1220.0]], [[125.0, 1050.0], [151.0, 1050.0], [151.0, 1245.0], [125.0, 1245.0]]], "lines": ["三輪バイクで", "キャンフかぁ．．．"]}], "img_path": "00136.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1119, 146, 1203, 548], "vertical": true, "font_size": 80, "lines_coords": [[[1123.0, 146.0], [1203.0, 146.0], [1200.0, 545.0], [1119.0, 545.0]]], "lines": ["１０５ｃスクーター"]}, {"box": [166, 149, 232, 553], "vertical": true, "font_size": 64, "lines_coords": [[[166.0, 151.0], [230.0, 151.0], [230.0, 553.0], [166.0, 553.0]]], "lines": ["めっちゃ速っ！！"]}, {"box": [1156, 911, 12