635.0, 1344.0]], [[588.0, 1089.0], [622.0, 1089.0], [622.0, 1269.0], [588.0, 1269.0]]], "lines": ["こねてるうちに", "手の温度で"]}, {"box": [133, 1397, 211, 1775], "vertical": true, "font_size": 32, "lines_coords": [[[176.0, 1402.0], [208.0, 1402.0], [208.0, 1775.0], [176.0, 1775.0]], [[135.0, 1398.0], [166.0, 1398.0], [165.0, 1605.0], [133.0, 1605.0]]], "lines": ["お肉が温まっちゃったん", "だと思うよ？"]}], "img_path": "00068.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1215, 125, 1260, 206], "vertical": true, "font_size": 45, "lines_coords": [[[1215.0, 125.0], [1260.0, 125.0], [1260.0, 206.0], [1215.0, 206.0]]], "lines": ["注意"]}, {"box": [1119, 138, 1193, 579], "vertical": true, "font_size": 34, "lines_coords": [[[1155.0, 142.0], [1192.0, 142.0], [1192.0, 399.0], [1155.0, 399.0]], [[1119.0, 144.0], [1151.0, 144.0], [1151.0, 579.0], [1119.0, 579.0]]], "lines": ["挽き肉は直前まで", "冷やしておくのはもちろんの事"]}, {"box": [814, 144, 853, 252], "vertical": true, "font_size": 39, "lines_coords": [[[814.0, 144.0], [853.0, 144.0], [853.0, 252.0], [814.0, 252.0]]], "lines": ["．．．"]}, {"box": [669, 129, 745, 508], "vertical": true, "font_size": 33, "lines_coords": [[[708.0, 129.0], [742.0, 129.0], [740.0, 478.0], [706.0, 478.0]], [[669.0, 129.0], [701.0, 129.0], [701.0, 508.0], [669.0, 508.0]]], "lines": ["スタッファーやボワルも", "あらかじめ冷凍庫で冷やし"]}, {"box": [542, 131, 615, 637], "vertical": true, "font_size": 29, "lines_coords": [[[579.0, 131.0], [611.0, 131.0], [613.0, 491.0], [581.0, 491.0]], [[545.0, 135.0], [571.0, 135.0], [571.0, 637.0], [545.0, 637.0]]], "lines": ["肉をこねる時もミキサーで", "かき氷状態に砕いた氷も一緒に混ぜて"]}, {"box": [136, 144, 171, 425], "vertical": true, "font_size": 32, "lines_coords": [[[136.0, 144.0], [168.0, 144.0], [168.0, 425.0], [136.0, 425.0]]], "lines": ["低温を保ちましょう"]}, {"box": [69, 118, 111, 629], "vertical": true, "font_size": 32, "lines_coords": [[[69.0, 118.0], [101.0, 118.0], [101.0, 616.0], [69.0, 616.0]]], "lines": ["淡新鮮な挽き肉を使う事も重要です。"]}, {"box": [1078, 682, 1226, 1020], "ver