145.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [810, 165, 1188, 243], "vertical": false, "font_size": 24, "lines_coords": [[[813.0, 168.0], [1040.0, 168.0], [1040.0, 193.0], [813.0, 193.0]], [[817.0, 193.0], [1158.0, 191.0], [1158.0, 215.0], [817.0, 217.0]], [[815.0, 219.0], [1115.0, 219.0], [1115.0, 243.0], [815.0, 243.0]]], "lines": ["野クルキャンブｍ伊豆！！", "３月はじめに開催予定だよ！！（＊＊＊）", "恵那ちゃんとりンちゃんもどう？"]}, {"box": [818, 299, 1186, 326], "vertical": false, "font_size": 20, "lines_coords": [[[826.0, 303.0], [1181.0, 300.0], [1181.0, 320.0], [826.0, 324.0]]], "lines": ["バイトで稼しいて伊豆キャンや！（＾＾"]}, {"box": [821, 378, 1121, 409], "vertical": false, "font_size": 24, "lines_coords": [[[821.0, 382.0], [1117.0, 382.0], [1117.0, 406.0], [821.0, 406.0]]], "lines": ["まさに気遊。〈く〉〉《、くの》"]}, {"box": [472, 181, 548, 386], "vertical": true, "font_size": 33, "lines_coords": [[[511.0, 181.0], [545.0, 181.0], [547.0, 352.0], [513.0, 352.0]], [[472.0, 181.0], [504.0, 181.0], [504.0, 386.0], [472.0, 386.0]]], "lines": ["いいじゃん", "伊豆キャン！"]}, {"box": [881, 450, 1100, 511], "vertical": false, "font_size": 58, "lines_coords": [[[881.0, 450.0], [1100.0, 453.0], [1100.0, 511.0], [881.0, 508.0]]], "lines": ["そうこそ"]}, {"box": [210, 635, 249, 766], "vertical": true, "font_size": 39, "lines_coords": [[[210.0, 635.0], [249.0, 635.0], [249.0, 766.0], [210.0, 766.0]]], "lines": ["豪遊て。"]}, {"box": [1123, 915, 1194, 1230], "vertical": true, "font_size": 29, "lines_coords": [[[1162.0, 916.0], [1188.0, 916.0], [1188.0, 1166.0], [1162.0, 1166.0]], [[1123.0, 915.0], [1155.0, 915.0], [1155.0, 1230.0], [1123.0, 1230.0]]], "lines": ["伊豆に行くなら私", "下田であれ食べたいな"]}, {"box": [999, 950, 1032, 1181], "vertical": true, "font_size": 32, "lines_coords": [[[999.0, 950.0], [1031.0, 950.0], [1031.0, 1181.0], [999.0, 1181.0]]], "lines": ["金目鯛バーガー。"]}, {"box": [515, 1104, 652, 1136], "vertical": false, "font_size": 32, "lines_coords": [[[515.0, 1104.0], [652.0, 1104.0], [652.0, 1136.0], [515.0, 1136.0]]