1071, 471], "vertical": true, "font_size": 26, "lines_coords": [[[1040.0, 131.0], [1066.0, 131.0], [1070.0, 468.0], [1044.0, 468.0]], [[1006.0, 131.0], [1033.0, 131.0], [1033.0, 382.0], [1006.0, 382.0]]], "lines": ["私もホットサンドメーカー", "買っちゃおっかなぁ"]}, {"box": [123, 73, 660, 105], "vertical": false, "font_size": 26.0, "lines_coords": [[[373.0, 73.0], [660.0, 76.0], [660.0, 105.0], [373.0, 101.0]], [[123.0, 75.0], [386.0, 78.0], [386.0, 103.0], [123.0, 99.0]]], "lines": ["フルメーカーの罠", "放課後５６ワップ"]}, {"box": [290, 135, 350, 470], "vertical": true, "font_size": 26, "lines_coords": [[[326.0, 136.0], [350.0, 136.0], [350.0, 470.0], [326.0, 470.0]], [[290.0, 135.0], [316.0, 135.0], [316.0, 331.0], [290.0, 331.0]]], "lines": ["ホットサンドメーカーなら、", "うちにもあるで"]}, {"box": [172, 240, 236, 603], "vertical": true, "font_size": 26, "lines_coords": [[[210.0, 241.0], [236.0, 241.0], [236.0, 603.0], [210.0, 603.0]], [[174.0, 240.0], [200.0, 240.0], [198.0, 408.0], [172.0, 408.0]]], "lines": ["たまにベーコンエッグサンド", "とか作るわー"]}, {"box": [1145, 898, 1205, 1295], "vertical": true, "font_size": 26, "lines_coords": [[[1177.0, 900.0], [1203.0, 900.0], [1203.0, 1136.0], [1177.0, 1136.0]], [[1145.0, 900.0], [1171.0, 900.0], [1171.0, 1295.0], [1145.0, 1295.0]]], "lines": ["改めて考えてみると、", "ホットサンドでキャンプ向きやな"]}, {"box": [650, 961, 682, 1398], "vertical": true, "font_size": 26, "lines_coords": [[[652.0, 961.0], [678.0, 961.0], [678.0, 1398.0], [652.0, 1398.0]]], "lines": ["ワッフルメーカーもいいよね"]}, {"box": [159, 1183, 230, 1678], "vertical": true, "font_size": 29, "lines_coords": [[[198.0, 1185.0], [230.0, 1185.0], [230.0, 1590.0], [198.0, 1590.0]], [[159.0, 1183.0], [185.0, 1183.0], [185.0, 1678.0], [159.0, 1678.0]]], "lines": ["ホットケーキミックス入れて", "カリカリに焼いてメーフルかけて．．．"]}, {"box": [755, 1421, 825, 1751], "vertical": true, "font_size": 29, "lines_coords": [[[791.0, 1423.0], [823.0, 1423.0], [823.0, 1751.0], [791.0, 1751.0]], [[755.0, 1425.0], [781.0, 1425.0], [781.0, 1702.0], [755.0, 1702.0]]], "lines": ["簡単やし食べやすいし", "色んなレシピあるし"]}], "img_path": "00169.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1136, 155, 1205, 532], "vertical": true, "font_size": 26, "lines_coords": [[[1177.0, 159.0], [1203.0, 159.0], [1203.0, 466.0], [1177.0, 466.0]], [[1136.0, 155.0], [1162.0, 155.0], [1162.0, 528.0], [1136.0, 528.0]]], "lines": ["ワッフルメーカーには", "苦い思い出があんだよなー"]}, {"box": [615, 159, 686, 656], "vertical": true, "font_size": 30, "lines_coords": [[[652.0, 159.0], [684.0, 159.0], [684.0, 536.0], [652.0, 536.0]], [[616.0, 161.0], [643.0, 161.0], [643.0, 656.0], [616.0, 656.0]]], "lines": ["これでお好み焼き作ったら、", "カリッカリになって激ウマじゃね？"]}, {"box": [270, 348, 301, 451], "vertical": true, "font_size": 31, "lines_coords": [[[270.0, 348.0], [301.0, 348.0], [301.0, 451.0], [270.0, 451.0]]], "lines": ["うんひっ"]}, {"box": [761, 663, 789, 831], "vertical": true, "font_size": 26, "lines_coords": [[[761.0, 663.0], [787.0, 663.0], [787.0, 830.0], [761.0, 830.0]]], "lines": ["あきちゃん"]}, {"box": [142, 408, 180, 911], "vertical": true, "font_size": 32, "lines_coords": [[[144.0, 408.0], [176.0, 408.0], [174.0, 905.0], [142.0, 905.0]]], "lines": ["って思ってやってみた事があんだよ"]}, {"box": [1134, 995, 1207, 1335], "vertical": true, "font_size": 32, "lines_coords": [[[1173.0, 995.0], [1205.0, 995.0], [1207.0, 1335.0], [1175.0, 1335.0]], [[1134.0, 1001.0], [1160.0, 1001.0], [1160.0, 1299.0], [1134.0, 1299.0]]], "lines": ["うちのお好み焼きって", "フワフワにするため"]}, {"box": [1025, 1166, 1102, 1584], "vertical": true, "font_size": 32, "lines_coords": [[[1063.0, 1166.0], [1100.0, 1166.0], [1102.0, 1584.0], [1065.0, 1584.0]], [[1025.0, 1170.0], [1057.0, 1170.0], [1057.0, 1515.0], [1025.0, 1515.0]]], "lines": ["午乳とベーキングパウダー", "多めに入れんだけどさ"]}, {"box": [705, 1003, 776, 1410], "vertical": true, "font_size": 32, "lines_coords": [[[744.0, 1003.0], [776.0, 1003.0], [776.0, 1378.0], [744.0, 1378.0]], [[705.0, 1003.0], [736.0, 1003.0], [736.0, 1410.0], [705.0, 1410.0]]], "lines": ["フワッフワに膨らみ過ぎて", "横から全部出ちまったんだわ"]}, {"box": [839, 1449, 922, 1687], "v