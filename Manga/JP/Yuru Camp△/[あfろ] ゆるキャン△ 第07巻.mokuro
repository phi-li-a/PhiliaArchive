.0, 1336.0], [228.0, 1331.0]]], "lines": ["お湯をかけると出来る", "シュラフ"]}, {"box": [1098, 1434, 1183, 1747], "vertical": true, "font_size": 38, "lines_coords": [[[1145.0, 1434.0], [1183.0, 1434.0], [1181.0, 1747.0], [1143.0, 1747.0]], [[1098.0, 1434.0], [1136.0, 1434.0], [1141.0, 1710.0], [1104.0, 1710.0]]], "lines": ["使う前に干さないと", "きもちわるいよぅ"]}, {"box": [183, 1443, 269, 1723], "vertical": true, "font_size": 38, "lines_coords": [[[230.0, 1443.0], [268.0, 1443.0], [268.0, 1723.0], [230.0, 1723.0]], [[183.0, 1443.0], [221.0, 1443.0], [221.0, 1633.0], [183.0, 1633.0]]], "lines": ["だめだ干したら", "元に戻るぞ"]}], "img_path": "00164.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1126, 195, 1205, 575], "vertical": true, "font_size": 34, "lines_coords": [[[1170.0, 196.0], [1203.0, 196.0], [1205.0, 573.0], [1171.0, 573.0]], [[1126.0, 195.0], [1164.0, 195.0], [1164.0, 575.0], [1126.0, 575.0]]], "lines": ["わたしテントで寝てる時", "外から聞こえる物音って"]}, {"box": [127, 67, 695, 105], "vertical": false, "font_size": 38, "lines_coords": [[[127.0, 67.0], [695.0, 67.0], [695.0, 105.0], [127.0, 105.0]]], "lines": ["放課後５４アウトドア便利グッズ２"]}, {"box": [260, 273, 292, 444], "vertical": true, "font_size": 32, "lines_coords": [[[260.0, 273.0], [292.0, 273.0], [292.0, 444.0], [260.0, 444.0]]], "lines": ["分かるわー"]}, {"box": [1038, 307, 1070, 682], "vertical": true, "font_size": 34, "lines_coords": [[[1038.0, 307.0], [1070.0, 307.0], [1070.0, 682.0], [1038.0, 682.0]]], "lines": ["すごく苦手なんだよねぇ"]}, {"box": [144, 352, 241, 719], "vertical": true, "font_size": 29, "lines_coords": [[[189.0, 408.0], [221.0, 408.0], [221.0, 686.0], [189.0, 686.0]], [[150.0, 412.0], [176.0, 412.0], [176.0, 718.0], [150.0, 718.0]]], "lines": ["静かな場所だから", "余計気になんだよな"]}, {"box": [434, 880, 465, 991], "vertical": true, "font_size": 26, "lines_coords": [[[435.0, 883.0], [461.0, 883.0], [461.0, 991.0], [435.0, 991.0]]], "lines": ["ひいいい"]}, {"box": [1029, 892, 1192, 1170], "vertical": true, "font_size": 36, "lines_coords": [[[1