.0], [751.0, 1531.0]], [[716.0, 1192.0], [742.0, 1192.0], [742.0, 1408.0], [716.0, 1408.0]]], "lines": ["いつ頃から通れるように", "なるんですか？"]}, {"box": [183, 1164, 253, 1479], "vertical": true, "font_size": 30, "lines_coords": [[[217.0, 1164.0], [249.0, 1164.0], [249.0, 1415.0], [217.0, 1415.0]], [[183.0, 1168.0], [210.0, 1168.0], [210.0, 1479.0], [183.0, 1479.0]]], "lines": ["まだしばらく開通", "しないんじゃないかな"]}, {"box": [393, 1541, 510, 1591], "vertical": false, "font_size": 24.0, "lines_coords": [[[423.0, 1541.0], [470.0, 1541.0], [470.0, 1563.0], [423.0, 1563.0]], [[393.0, 1565.0], [510.0, 1565.0], [510.0, 1591.0], [393.0, 1591.0]]], "lines": ["．．．", "ですかエンタイプ"]}], "img_path": "00099.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1151, 144, 1213, 451], "vertical": true, "font_size": 26, "lines_coords": [[[1186.0, 144.0], [1213.0, 144.0], [1213.0, 451.0], [1186.0, 451.0]], [[1151.0, 144.0], [1177.0, 144.0], [1177.0, 367.0], [1151.0, 367.0]]], "lines": ["あの林道は台風のたびに", "土砂崩れが起きて"]}, {"box": [1050, 172, 1110, 510], "vertical": true, "font_size": 26, "lines_coords": [[[1083.0, 172.0], [1110.0, 172.0], [1110.0, 510.0], [1083.0, 510.0]], [[1050.0, 172.0], [1074.0, 172.0], [1074.0, 339.0], [1050.0, 339.0]]], "lines": ["何度直してもすぐ通れなく", "なるんですよ"]}, {"box": [298, 150, 400, 431], "vertical": true, "font_size": 27, "lines_coords": [[[369.0, 150.0], [395.0, 150.0], [395.0, 418.0], [369.0, 418.0]], [[333.0, 150.0], [361.0, 150.0], [360.0, 431.0], [331.0, 431.0]], [[298.0, 150.0], [324.0, 150.0], [324.0, 318.0], [298.0, 318.0]]], "lines": ["それで今町で直すか", "そのままにするのかを", "協議してます"]}, {"box": [131, 281, 197, 502], "vertical": true, "font_size": 26, "lines_coords": [[[168.0, 285.0], [195.0, 285.0], [195.0, 502.0], [168.0, 502.0]], [[133.0, 281.0], [159.0, 281.0], [157.0, 450.0], [131.0, 450.0]]], "lines": ["いつから通行止め", "なんですか？"]}, {"box": [1137, 596, 1207, 881], "vertical": true, "font_size": 32, "lines_coords": [[[1168.0, 596.0], [1205.0, 596.0], [1207.0, 881.0], [1170.