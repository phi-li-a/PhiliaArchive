.0, 266.0]]], "lines": ["伊豆キャン", "すかー"]}, {"box": [798, 163, 873, 294], "vertical": true, "font_size": 36, "lines_coords": [[[838.0, 166.0], [871.0, 166.0], [873.0, 294.0], [840.0, 294.0]], [[798.0, 163.0], [838.0, 163.0], [838.0, 266.0], [798.0, 266.0]]], "lines": ["いいよね", "伊豆！！"]}, {"box": [150, 176, 224, 379], "vertical": true, "font_size": 32, "lines_coords": [[[195.0, 180.0], [221.0, 180.0], [221.0, 378.0], [195.0, 378.0]], [[150.0, 176.0], [189.0, 176.0], [189.0, 279.0], [150.0, 279.0]]], "lines": ["うん。ええよね", "伊豆！！"]}, {"box": [1087, 738, 1158, 1020], "vertical": true, "font_size": 32, "lines_coords": [[[1126.0, 738.0], [1158.0, 738.0], [1158.0, 958.0], [1126.0, 958.0]], [[1087.0, 738.0], [1119.0, 738.0], [1119.0, 1020.0], [1087.0, 1020.0]]], "lines": ["伊豆なら冬でも", "比較的暖かいですし"]}, {"box": [195, 733, 306, 1080], "vertical": true, "font_size": 31, "lines_coords": [[[273.0, 736.0], [305.0, 736.0], [305.0, 1080.0], [273.0, 1080.0]], [[234.0, 735.0], [266.0, 735.0], [266.0, 1016.0], [234.0, 1016.0]], [[196.0, 733.0], [225.0, 733.0], [223.0, 984.0], [195.0, 984.0]]], "lines": ["山中湖でお世話になった", "飯田さんにもお礼に", "行きたいですしね"]}, {"box": [590, 1179, 653, 1543], "vertical": true, "font_size": 26, "lines_coords": [[[626.0, 1181.0], [652.0, 1181.0], [652.0, 1543.0], [626.0, 1543.0]], [[590.0, 1179.0], [615.0, 1179.0], [615.0, 1458.0], [590.0, 1458.0]]], "lines": ["チョコちゃんかわいいよねぇ", "私も会ってみたいなぁ"]}, {"box": [1113, 1430, 1226, 1710], "vertical": true, "font_size": 32, "lines_coords": [[[1194.0, 1430.0], [1226.0, 1430.0], [1226.0, 1618.0], [1194.0, 1618.0]], [[1158.0, 1434.0], [1185.0, 1434.0], [1185.0, 1710.0], [1158.0, 1710.0]], [[1113.0, 1430.0], [1151.0, 1430.0], [1151.0, 1650.0], [1113.0, 1650.0]]], "lines": ["飯田さんって", "コーギーと飛行機と", "薪ストーブの？"]}, {"box": [706, 1612, 789, 1691], "vertical": true, "font_size": 48, "lines_coords": [[[744.0, 1616.0], [789.0, 1616.0], [789.0, 1689.0], [744.0, 1689.0]], [[706.0, 1612.0], [757.0, 1612.0], [757.0, 1691.0], [706.0, 1691.0]]], "lines": ["せや", "でー"]}], "img_path": "00142.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1146, 151, 1213, 450], "vertical": true, "font_size": 28, "lines_coords": [[[1181.0, 151.0], [1213.0, 151.0], [1213.0, 450.0], [1181.0, 450.0]], [[1147.0, 155.0], [1171.0, 155.0], [1171.0, 421.0], [1147.0, 421.0]]], "lines": ["助けてもらったお礼に", "お土産持ってかなな"]}, {"box": [920, 196, 993, 352], "vertical": true, "font_size": 33, "lines_coords": [[[958.0, 198.0], [990.0, 198.0], [993.0, 352.0], [961.0, 352.0]], [[920.0, 196.0], [954.0, 196.0], [954.0, 294.0], [920.0, 294.0]]], "lines": ["たまてばこ", "とか？"]}, {"box": [712, 213, 786, 399], "vertical": true, "font_size": 36, "lines_coords": [[[753.0, 215.0], [785.0, 215.0], [785.0, 399.0], [753.0, 399.0]], [[712.0, 213.0], [751.0, 213.0], [751.0, 313.0], [712.0, 313.0]]], "lines": ["何でウラシマ", "やねん"]}, {"box": [575, 189, 654, 431], "vertical": true, "font_size": 35, "lines_coords": [[[616.0, 189.0], [654.0, 189.0], [654.0, 414.0], [616.0, 414.0]], [[575.0, 191.0], [607.0, 191.0], [607.0, 431.0], [575.0, 431.0]]], "lines": ["でも先生何で", "３月なんすか？"]}, {"box": [148, 223, 219, 444], "vertical": true, "font_size": 32, "lines_coords": [[[187.0, 223.0], [219.0, 223.0], [219.0, 442.0], [187.0, 442.0]], [[148.0, 223.0], [180.0, 223.0], [180.0, 380.0], [148.0, 380.0]]], "lines": ["まだ一カ月以上", "先ですよ？"]}, {"box": [1113, 787, 1224, 1066], "vertical": true, "font_size": 30, "lines_coords": [[[1194.0, 789.0], [1220.0, 789.0], [1220.0, 1051.0], [1194.0, 1051.0]], [[1153.0, 787.0], [1185.0, 787.0], [1185.0, 1066.0], [1153.0, 1066.0]], [[1113.0, 787.0], [1145.0, 787.0], [1145.0, 943.0], [1113.0, 943.0]]], "lines": ["大垣さん達この前", "キャンプしたばかり", "でしょう？"]}, {"box": [873, 766, 905, 883], "vertical": true, "font_size": 32, "lines_coords": [[[873.0, 766.0], [905.0, 766.0], [905.0, 883.0], [873.0, 883.0]]], "lines": ["はいっ！"]}, {"box": [746, 759, 811, 1044], "vertical": true, "font_size": 32, "lines_coords": [[[780.0, 759.0], [811.0, 759.0], [811.0, 873.0], [780.0, 873.0]], [[746.0, 759.0], [778.0, 759.0], [778.0, 1044.0], [746.0, 1044.0]]], "lines": ["私も昨日", "行ったばかりですっ！！"]}, {"box": [142, 802, 206, 1053], "vertical": true, "font_size": 26, "lines_coords": [[[178.0, 802.0], [204.0, 802.0], [204.0, 1053.0], [178.0, 1053.0]], [[142.0, 804.0], [168.0, 804.0], [168.0, 997.0], [142.0, 997.0]]], "lines": ["少し間をあけた方が", "いいかと思って"]}, {"box": [562, 920, 627, 1259], "vertical": true, "font_size": 29, "lines_coords": [[[600.0, 922.0], [626.0, 922.0], [626.0, 1258.0], [600.0, 1258.0]], [[562.0, 920.0], [594.0, 920.0], [594.0, 1177.0], [562.0, 1177.0]]], "lines": ["伊豆でのキャンプとなると、", "旅費もかかりますし"]}, {"box": [1119, 1430, 1217, 1711], "vertical": true, "font_size": 26, "lines_coords": [[[1188.0, 1432.0], [1215.0, 1432.0], [1215.0, 1601.0], [1188.0, 1601.0]], [[1155.0, 1432.0], [1181.0, 1432.0], [1181.0, 1711.0], [1155.0, 1711.0]], [[1119.0, 1432.0], [1145.0, 1432.0], [1145.0, 1711.0], [1119.0, 1711.0]]], "lines": ["確かにこの前", "イス買っちまったから", "資金不足は否めない．．．"]}, {"box": [382, 1443, 414, 1558], "vertical": true, "font_size": 32, "lines_coords": [[[382.0, 1443.0], [414.0, 1443.0], [414.0, 1558.0], [382.0, 1558.0]]], "lines": ["せやなぁ"]}, {"box": [187, 1430, 245, 1680], "vertical": true, "font_size": 25, "lines_coords": [[[217.0, 1434.0], [243.0, 1434.0], [243.0, 1606.0], [217.0, 1606.0]], [[187.0, 1430.0], [211.0, 1430.0], [211.0, 1680.0], [187.0, 1680.0]]], "lines": ["伊豆でおいしい", "物とか食べたいもんね"]}], "img_path": "00143.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1149, 479, 1170, 559], "vertical": true, "font_size": 21, "lines_coords": [[[1149.0, 479.0], [1170.0, 479.0], [1170.0, 559.0], [1149.0, 559.0]]], "lines": ["．．．．．"]}, {"box": [547, 425, 646, 669], "vertical": true, "font_size": 45, "lines_coords": [[[607.0, 431.0], [639.0, 431.0], [639.0, 669.0], [607.0, 669.0]], [[547.0, 427.0], [605.0, 425.0], [615.0, 660.0], [556.0, 661.0]]], "lines": ["先生もお金ない", "んすね．．．お酒屋みすぎて"]}, {"box": [131, 495, 194, 691], "vertical"