{"version": "0.2.0-beta.6", "title": "Yuru Camp△", "title_uuid": "a455d610-e3f3-44d0-9214-956621941f71", "volume": "[あfろ] ゆるキャン△ 第07巻", "volume_uuid": "b6f693c2-f126-44e8-b7fc-79cc00ff9c99", "pages": [{"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [41, 0, 1241, 388], "vertical": false, "font_size": 378, "lines_coords": [[[41.0, 5.0], [1235.0, 0.0], [1241.0, 373.0], [46.0, 388.0]]], "lines": ["ゆ５ホン△"]}, {"box": [1029, 319, 1277, 371], "vertical": false, "font_size": 57, "lines_coords": [[[1029.0, 314.0], [1277.0, 314.0], [1277.0, 376.0], [1029.0, 376.0]]], "lines": ["よしよしこまでお"]}, {"box": [97, 576, 332, 704], "vertical": false, "font_size": 82, "lines_coords": [[[105.0, 593.0], [315.0, 593.0], [315.0, 682.0], [105.0, 682.0]]], "lines": ["あｆ３"]}], "img_path": "00001.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [], "img_path": "00002.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [60, 1179, 197, 1261], "vertical": false, "font_size": 37, "lines_coords": [[[60.0, 1189.0], [167.0, 1176.0], [173.0, 1220.0], [65.0, 1233.0]], [[99.0, 1212.0], [154.0, 1208.0], [156.0, 1241.0], [101.0, 1245.0]]], "lines": ["ｎｅｓｅｎｔｅｄｅｒｄｏｆｉｒｏ", "ｅｅｎｔｅｏｄｆｒｏ"]}, {"box": [105, 1293, 144, 1434], "vertical": true, "font_size": 39, "lines_coords": [[[105.0, 1293.0], [144.0, 1293.0], [144.0, 1434.0], [105.0, 1434.0]]], "lines": ["ｆ"]}, {"box": [60, 1449, 183, 1512], "vertical": false, "font_size": 33, "lines_coords": [[[73.0, 1450.0], [163.0, 1446.0], [165.0, 1486.0], [75.0, 1489.0]], [[75.0, 1474.0], [166.0, 1480.0], [165.0, 1512.0], [73.0, 1506.0]]], "lines": ["そんなことないよ", "うん。いや、やっぱり"]}, {"box": [91, 1531, 151, 1749], "vertical": true, "font_size": 26, "lines_coords": [[[125.0, 1548.0], [150.0, 1548.0], [150.0, 1747.0], [125.0, 1747.0]], [[91.0, 1531.0], [118.0, 1531.0], [120.0, 1747.0], [93.0, 1747.0]]], "lines": ["ｈｉｃｈｓｏｉｏｌｄｉｓｇｏ", "ｙｕｒｕｅｏｍｐｉｎｎａｔｌｌｅ"]}, {"box": [998, 1528, 1181, 1622], "vertical": false, "font_size": 82, "lines_coords": [[[1001.0, 1534.0], [1174.0, 1523.0], [1180.0, 1611.0], [1006.0, 1622.0]]], "lines": ["．．．"]}, {"box": [669, 1674, 1247, 1856], "vertical": false, "font_size": 200, "lines_coords": [[[669.0, 1656.0], [1233.0, 1656.0], [1233.0, 1874.0], [669.0, 1874.0]]], "lines": ["やるさんっ、"]}, {"box": [1024, 1635, 1142, 1674], "vertical": false, "font_size": 42, "lines_coords": [[[1027.0, 1632.0], [1134.0, 1632.0], [1134.0, 1677.0], [1027.0, 1677.0]]], "lines": ["ＣＲＡＣＭＣＲＳ．．．"]}, {"box": [1126, 1836, 1249, 1865], "vertical": false, "font_size": 31, "lines_coords": [[[1126.0, 1834.0], [1249.0, 1834.0], [1249.0, 1867.0], [1126.0, 1867.0]]], "lines": ["Ｖｕｒｕｃａｍｐ"]}], "img_path": "00003.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [151, 155, 369, 223], "vertical": false, "font_size": 33, "lines_coords": [[[151.0, 191.0], [363.0, 155.0], [369.0, 187.0], [157.0, 223.0]]], "lines": ["Ｙｕｐｕｉｃｇｍｐ"]}, {"box": [238, 217, 1059, 483], "vertical": false, "font_size": 78.25, "lines_coords": [[[975.0, 264.0], [1057.0, 271.0], [1055.0, 296.0], [973.0, 288.0]], [[303.0, 234.0], [984.0, 217.0], [986.0, 301.0], [305.0, 318.0]], [[238.0, 313.0], [1042.0, 283.0], [1046.0, 391.0], [241.0, 421.0]], [[322.0, 388.0], [1059.0, 380.0], [1059.0, 476.0], [322.0, 483.0]]], "lines": ["．．．", "いつも言ったでしょうのリロキャ『最適』として、マナルギュー。", "第一話で、この時期に関してはほとまりませんが、おしゃべりでしょう。", "また、一部のカロビーズには、新しいコピーイと一人旅の旅の中には"]}, {"box": [463, 481, 915, 528], "vertical": false, "font_size": 45, "lines_coords": [[[463.0, 483.0], [915.0, 481.0], [915.0, 526.0], [463.0, 528.0]]], "lines": ["第一話、静かの湖．．．"]}, {"box": [461, 740, 553, 770], "vertical": false, "font_size": 26, "lines_coords": [[[461.0, 744.0], [553.0, 740.0], [553.0, 766.0], [461.0, 770.0]]], "lines": ["番外編"]}, {"box": [412, 553, 883, 620], "vertical": false, "font_size": 50, "lines_coords": [[[412.0, 570.0], [881.0, 553.0], [883.0, 603.0], [414.0, 620.0]]], "lines": ["第一話一人のキャンプ"]}, {"box": [318, 622, 967, 725], "vertical": false, "font_size": 84, "lines_coords": [[[318.0, 641.0], [965.0, 622.0], [967.0, 706.0], [320.0, 725.0]]], "lines": ["あぁ、あぁぁぁっ、ありがとうございますねー。"]}, {"box": [637, 723, 916, 766], "vertical": false, "font_size": 30.0, "lines_coords": [[[817.0, 731.0], [916.0, 738.0], [915.0, 766.0], [815.0, 759.0]], [[637.0, 723.0], [821.0, 727.0], [821.0, 759.0], [637.0, 755.0]]], "lines": ["１８８", "、やキャン△"]}, {"box": [856, 1590, 935, 1621], "vertical": false, "font_size": 22, "lines_coords": [[[856.0, 1599.0], [930.0, 1599.0], [930.0, 1623.0], [856.0, 1623.0]]], "lines": ["・５－７５０"]}], "img_path": "00004.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1181, 142, 1212, 388], "vertical": true, "font_size": 26, "lines_coords": [[[1183.0, 142.0], [1209.0, 142.0], [1209.0, 386.0], [1183.0, 386.0]]], "lines": ["ここが大間々岬で"]}, {"box": [603, 140, 675, 455], "vertical": true, "font_size": 30, "lines_coords": [[[643.0, 140.0], [675.0, 140.0], [675.0, 455.0], [643.0, 455.0]], [[605.0, 140.0], [633.0, 140.0], [631.0, 330.0], [603.0, 330.0]]], "lines": ["これがみんなで食べた", "きりたんほ鍋"]}, {"box": [765, 648, 827, 841], "vertical": true, "font_size": 26, "lines_coords": [[[800.0, 648.0], [826.0, 648.0], [826.0, 841.0], [800.0, 841.0]], [[765.0, 648.0], [791.0, 648.0], [791.0, 813.0], [765.0, 813.0]]], "lines": ["おぉーふじさん", "よく見えるー"]}, {"box": [151, 654, 220, 841], "vertical": true, "font_size": 30, "lines_coords": [[[187.0, 654.0], [219.0, 654.0], [219.0, 841.0], [187.0, 841.0]], [[151.0, 656.0], [178.0, 656.0], [178.0, 806.0], [151.0, 806.0]]], "lines": ["美味しそうに", "出来たねぃ"]}, {"box": [1164, 970, 1226, 1345], "vertical": true, "font_size": 25, "lines_coords": [[[1198.0, 971.0], [1222.0, 971.0], [1222.0, 1340.0], [1198.0, 1340.0]], [[1164.0, 973.0], [1190.0, 973.0], [1190.0, 1316.0], [1164.0, 1316.0]]], "lines": ["きりたんぽって焼きおにぎりと", "焼き餅の中間くらいなんだね"]}, {"box": [592, 980, 656, 1177], "vertical": true, "font_size": 26, "lines_coords": [[[628.0, 980.0], [654.0, 980.0], [654.0, 1121.0], [628.0, 1121.0]], [[592.0, 980.0], [618.0, 980.0], [618.0, 1177.0], [592.0, 1177.0]]], "lines": ["豆乳が濃厚", "クリーミーで．．"]}, {"box": [710, 1426, 774, 1719], "vertical": true, "font_size": 26, "lines_coords": [[[746.0, 1426.0], [772.0, 1426.0], [772.0, 1719.0], [746.0, 1719.0]], [[710.0, 1426.0], [736.0, 1426.0], [736.0, 1676.0], [710.0, 1676.0]]], "lines": ["うん、手抜きしたい時は、", "お餅でもおいしいよ"]}, {"box": [155, 1529, 218, 1668], "vertical": true, "font_size": 26, "lines_coords": [[[191.0, 1530.0], [217.0, 1530.0], [217.0, 1655.0], [191.0, 1655.0]], [[155.0, 1530.0], [181.0, 1530.0], [181.0, 1668.0], [155.0, 1668.0]]], "lines": ["あこれは", "違う写真が"]}], "img_path": "00005.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1149, 125, 1252, 528], "vertical": true, "font_size": 29, "lines_coords": [[[1224.0, 133.0], [1252.0, 133.0], [1252.0, 161.0], [1224.0, 161.0]], [[1183.0, 127.0], [1215.0, 127.0], [1215.0, 421.0], [1183.0, 421.0]], [[1149.0, 125.0], [1177.0, 125.0], [1179.0, 528.0], [1151.0, 528.0]]], "lines": ["で", "この人達が寒さに凍える", "私達を助けてくれた飯田さん親子"]}, {"box": [605, 129, 667, 448], "vertical": true, "font_size": 24, "lines_coords": [[[639.0, 129.0], [663.0, 129.0], [663.0, 393.0], [639.0, 393.0]], [[605.0, 129.0], [630.0, 129.0], [630.0, 448.0], [605.0, 448.0]]], "lines": ["リンが心配して先生に", "知らせてくれたおかげだよ"]}, {"box": [157, 140, 216, 326], "vertical": true, "font_size": 25, "lines_coords": [[[189.0, 142.0], [215.0, 142.0], [215.0, 301.0], [189.0, 301.0]], [[157.0, 140.0], [181.0, 140.0], [181.0, 326.0], [157.0, 326.0]]], "lines": ["じゃなければ", "どうなってたか"]}, {"box": [1130, 778, 1192, 999], "vertical": true, "font_size": 26, "lines_coords": [[[1162.0, 780.0], [1188.0, 780.0], [1188.0, 999.0], [1162.0, 999.0]], [[1130.0, 778.0], [1155.0, 778.0], [1155.0, 945.0], [1130.0, 945.0]]], "lines": ["これからは感謝と", "尊敬を込めて"]}, {"box": [714, 480, 780, 665], "vertical": true, "font_size": 33, "lines_coords": [[[748.0, 480.0], [780.0, 480.0], [780.0, 665.0], [748.0, 665.0]], [[714.0, 481.0], [748.0, 481.0], [748.0, 568.0], [714.0, 568.0]]], "lines": ["あ鳥羽先生も", "いるー"]}, {"box": [637, 784, 713, 1078], "vertical": true, "font_size": 29, "lines_coords": [[[676.0, 789.0], [708.0, 789.0], [708.0, 1065.0], [676.0, 1065.0]], [[637.0, 787.0], [663.0, 787.0], [663.0, 1078.0], [637.0, 1078.0]]], "lines": ["「しまりん様」って", "呼ばなくちゃいけないね"]}, {"box": [125, 405, 221, 660], "vertical": true, "font_size": 30, "lines_coords": [[[183.0, 405.0], [221.0, 405.0], [221.0, 465.0], [183.0, 465.0]], [[155.0, 410.0], [181.0, 410.0], [181.0, 660.0], [155.0, 660.0]], [[125.0, 410.0], [150.0, 410.0], [150.0, 635.0], [125.0, 635.0]]], "lines": ["私も", "本栖湖でリンちゃんに", "助けられた事あるよ"]}, {"box": [184, 772, 253, 960], "vertical": true, "font_size": 29, "lines_coords": [[[221.0, 774.0], [253.0, 774.0], [253.0, 900.0], [221.0, 900.0]], [[185.0, 776.0], [211.0, 776.0], [211.0, 960.0], [185.0, 960.0]]], "lines": ["そうだよ", "恵那ちゃん！！"]}, {"box": [907, 1350, 1104, 1462], "vertical": false, "font_size": 18.666666666666668, "lines_coords": [[[933.0, 1350.0], [1055.0, 1389.0], [1050.0, 1408.0], [928.0, 1368.0]], [[913.0, 1383.0], [1091.0, 1445.0], [1085.0, 1462.0], [907.0, 1400.0]], [[918.0, 1365.0], [1104.0, 1426.0], [1098.0, 1445.0], [913.0, 1383.0]]], "lines": ["い、いいっ．．．", "これまでは、この時期は自分ではありませんでしたが", "い、あの時は自分の自由なのですが、まだまだお"]}, {"box": [802, 1158, 865, 1383], "vertical": true, "font_size": 26, "lines_coords": [[[836.0, 1158.0], [862.0, 1158.0], [864.0, 1383.0], [838.0, 1383.0]], [[802.0, 1160.0], [828.0, 1160.0], [828.0, 1355.0], [802.0, 1355.0]]], "lines": ["しまりん様どうぞ", "お納め下さい．．．"]}, {"box": [540, 1209, 603, 1353], "vertical": true, "font_size": 30, "lines_coords": [[[575.0, 1213.0], [601.0, 1213.0], [601.0, 1351.0], [575.0, 1351.0]], [[540.0, 1209.0], [573.0, 1209.0], [573.0, 1243.0], [540.0, 1243.0]]], "lines": ["しまりん様", "．．．"]}, {"box": [279, 1170, 344, 1314], "vertical": true, "font_size": 29, "lines_coords": [[[309.0, 1170.0], [341.0, 1170.0], [341.0, 1314.0], [309.0, 1314.0]], [[279.0, 1173.0], [305.0, 1173.0], [305.0, 1314.0], [279.0, 1314.0]]], "lines": ["ありがたや", "ありがたや"]}, {"box": [952, 1631, 1063, 1730], "vertical": false, "font_size": 99, "lines_coords": [[[952.0, 1631.0], [1063.0, 1631.0], [1063.0, 1730.0], [952.0, 1730.0]]], "lines": ["チャリン"]}, {"box": [170, 1519, 219, 1693], "vertical": true, "font_size": 47, "lines_coords": [[[170.0, 1522.0], [217.0, 1522.0], [217.0, 1693.0], [170.0, 1693.0]]], "lines": ["拝むな。"]}], "img_path": "00006.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [503, 1780, 1256, 1833], "vertical": false, "font_size": 44, "lines_coords": [[[515.0, 1786.0], [1256.0, 1786.0], [1256.0, 1830.0], [515.0, 1830.0]]], "lines": ["第３５回話したで、しこのソロキャン計画"]}], "img_path": "00007.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1138, 136, 1209, 390], "vertical": true, "font_size": 32, "lines_coords": [[[1177.0, 136.0], [1209.0, 136.0], [1207.0, 358.0], [1175.0, 358.0]], [[1138.0, 136.0], [1170.0, 136.0], [1170.0, 390.0], [1138.0, 390.0]]], "lines": ["そういえば今日", "野クルはいいの？"]}, {"box": [652, 142, 718, 481], "vertical": true, "font_size": 26, "lines_coords": [[[690.0, 146.0], [716.0, 146.0], [716.0, 481.0], [690.0, 481.0]], [[654.0, 142.0], [680.0, 142.0], [678.0, 395.0], [652.0, 395.0]]], "lines": ["今日は二人共バイトだから", "部活はお休みなんだ"]}, {"box": [455, 390, 536, 495], "vertical": false, "font_size": 31, "lines_coords": [[[455.0, 478.0], [510.0, 390.0], [536.0, 406.0], [481.0, 495.0]]], "lines": ["．．．それで"]}, {"box": [448, 397, 478, 420], "vertical": false, "font_size": 23, "lines_coords": [[[448.0, 397.0], [478.0, 397.0], [478.0, 420.0], [448.0, 420.0]]], "lines": ["国"]}, {"box": [1125, 771, 1186, 1012], "vertical": true, "font_size": 27, "lines_coords": [[[1155.0, 772.0], [1183.0, 772.0], [1186.0, 905.0], [1158.0, 905.0]], [[1125.0, 774.0], [1151.0, 774.0], [1151.0, 1012.0], [1125.0, 1012.0]]], "lines": ["私もバイト", "するようになったし、"]}, {"box": [960, 740, 1024, 995], "vertical": true, "font_size": 26, "lines_coords": [[[995.0, 744.0], [1020.0, 744.0], [1020.0, 967.0], [995.0, 967.0]], [[961.0, 740.0], [988.0, 740.0], [986.0, 995.0], [960.0, 995.0]]], "lines": ["最近あんまり部活", "出来てないんだよね"]}, {"box": [412, 793, 438, 1005], "vertical": true, "font_size": 24, "lines_coords": [[[412.0, 793.0], [436.0, 793.0], [436.0, 1005.0], [412.0, 1005.0]]], "lines": ["ちょっと寂しいよ"]}, {"box": [181, 775, 213, 902], "vertical": true, "font_size": 32, "lines_coords": [[[181.0, 776.0], [213.0, 776.0], [213.0, 901.0], [181.0, 901.0]]], "lines": ["そっか．．．"]}, {"box": [772, 1194, 838, 1424], "vertical": true, "font_size": 32, "lines_coords": [[[800.0, 1194.0], [838.0, 1194.0], [838.0, 1383.0], [800.0, 1383.0]], [[772.0, 1196.0], [798.0, 1196.0], [798.0, 1421.0], [772.0, 1421.0]]], "lines": ["おっいいね！", "なでしこちゃん！！"]}, {"box": [562, 1141, 630, 1423], "vertical": true, "font_size": 29, "lines_coords": [[[598.0, 1141.0], [630.0, 1141.0], [630.0, 1395.0], [598.0, 1395.0]], [[562.0, 1145.0], [588.0, 1145.0], [588.0, 1423.0], [562.0, 1423.0]]], "lines": ["と思ったけど私も", "今日は用事あるんだ"]}, {"box": [234, 1143, 274, 1297], "vertical": true, "font_size": 36, "lines_coords": [[[234.0, 1143.0], [270.0, 1143.0], [271.0, 1280.0], [236.0, 1280.0]]], "lines": ["またねー"]}, {"box": [1139, 1359, 1204, 1738], "vertical": true, "font_size": 26, "lines_coords": [[[1175.0, 1361.0], [1201.0, 1361.0], [1200.0, 1738.0], [1173.0, 1738.0]], [[1140.0, 1363.0], [1166.0, 1363.0], [1166.0, 1698.0], [1140.0, 1698.0]]], "lines": ["ねぇ恵那ちゃん私たち３人で", "一臨時野クル」をやらない！？"]}, {"box": [681, 1546, 748, 1714], "vertical": true, "font_size": 29, "lines_coords": [[[714.0, 1548.0], [748.0, 1548.0], [748.0, 1661.0], [714.0, 1661.0]], [[682.0, 1546.0], [706.0, 1546.0], [706.0, 1713.0], [682.0, 1713.0]]], "lines": ["しれっと", "私を入れるな"]}, {"box": [176, 1544, 211, 1708], "vertical": true, "font_size": 29, "lines_coords": [[[180.0, 1642.0], [208.0, 1642.0], [208.0, 1704.0], [180.0, 1704.0]], [[176.0, 1545.0], [206.0, 1545.0], [206.0, 1601.0], [176.0, 1601.0]]], "lines": ["ーっ", "えー"]}], "img_path": "00008.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1132, 204, 1224, 483], "vertical": true, "font_size": 28, "lines_coords": [[[1200.0, 208.0], [1224.0, 208.0], [1224.0, 393.0], [1200.0, 393.0]], [[1168.0, 206.0], [1194.0, 206.0], [1194.0, 483.0], [1168.0, 483.0]], [[1132.0, 204.0], [1166.0, 204.0], [1166.0, 285.0], [1132.0, 285.0]]], "lines": ["それでなでしこ", "ソロキャン行くって本気", "なの？"]}, {"box": [813, 103, 847, 204], "vertical": true, "font_size": 30, "lines_coords": [[[813.0, 103.0], [847.0, 103.0], [847.0, 204.0], [813.0, 204.0]]], "lines": ["うん！！"]}, {"box": [733, 189, 796, 476], "vertical": true, "font_size": 30, "lines_coords": [[[765.0, 189.0], [796.0, 189.0], [796.0, 476.0], [765.0, 476.0]], [[733.0, 195.0], [759.0, 195.0], [759.0, 418.0], [733.0, 418.0]]], "lines": ["今週行こうと思うんだ", "バイト休みだから"]}, {"box": [1134, 759, 1201, 1016], "vertical": true, "font_size": 32, "lines_coords": [[[1164.0, 759.0], [1201.0, 759.0], [1201.0, 823.0], [1164.0, 823.0]], [[1134.0, 765.0], [1160.0, 765.0], [1160.0, 1016.0], [1134.0, 1016.0]]], "lines": ["ほら", "お正月にリンちゃん"]}, {"box": [174, 414, 210, 572], "vertical": true, "font_size": 32, "lines_coords": [[[178.0, 414.0], [210.0, 414.0], [206.0, 571.0], [174.0, 571.0]]], "lines": ["何でまた．．．"]}, {"box": [322, 787, 415, 997], "vertical": true, "font_size": 25, "lines_coords": [[[388.0, 787.0], [414.0, 787.0], [414.0, 945.0], [388.0, 945.0]], [[354.0, 787.0], [380.0, 787.0], [380.0, 997.0], [354.0, 997.0]], [[322.0, 787.0], [346.0, 787.0], [346.0, 948.0], [322.0, 948.0]]], "lines": ["それを聞いて", "私もやってみたく", "なったんだー"]}, {"box": [922, 843, 1012, 1121], "vertical": true, "font_size": 27, "lines_coords": [[[984.0, 843.0], [1010.0, 843.0], [1012.0, 1035.0], [986.0, 1035.0]], [[954.0, 847.0], [978.0, 847.0], [978.0, 1121.0], [954.0, 1121.0]], [[922.0, 847.0], [948.0, 847.0], [948.0, 1110.0], [922.0, 1110.0]]], "lines": ["「ソロキャンプは", "みんなでやるキャンプと", "全く別のアウトドアだ」"]}, {"box": [877, 905, 911, 1188], "vertical": true, "font_size": 27, "lines_coords": [[[877.0, 905.0], [909.0, 905.0], [911.0, 1188.0], [879.0, 1188.0]]], "lines": ["って言ってたでしょ？"]}, {"box": [157, 939, 219, 1108], "vertical": true, "font_size": 26, "lines_coords": [[[191.0, 941.0], [217.0, 941.0], [217.0, 1080.0], [191.0, 1080.0]], [[157.0, 939.0], [183.0, 939.0], [183.0, 1108.0], [157.0, 1108.0]]], "lines": ["私そんな事", "言ったっけ？"]}, {"box": [163, 1282, 228, 1536], "vertical": true, "font_size": 26, "lines_coords": [[[198.0, 1284.0], [225.0, 1284.0], [225.0, 1479.0], [198.0, 1479.0]], [[163.0, 1282.0], [189.0, 1282.0], [189.0, 1533.0], [163.0, 1533.0]]], "lines": ["知らないうちに", "焚きつけてたのか？"]}, {"box": [1126, 1316, 1188, 1597], "vertical": true, "font_size": 29, "lines_coords": [[[1158.0, 1316.0], [1186.0, 1316.0], [1188.0, 1569.0], [1160.0, 1569.0]], [[1126.0, 1318.0], [1153.0, 1318.0], [1153.0, 1597.0], [1126.0, 1597.0]]], "lines": ["今日はリンちゃんに", "ソロキャンの始め方を"]}, {"box": [1061, 1378, 1093, 1717], "vertical": true, "font_size": 29, "lines_coords": [[[1061.0, 1378.0], [1093.0, 1378.0], [1093.0, 1717.0], [1061.0, 1717.0]]], "lines": ["じっくり聞こうと思って！！"]}], "img_path": "00009.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1137, 134, 1201, 586], "vertical": true, "font_size": 26, "lines_coords": [[[1173.0, 138.0], [1200.0, 138.0], [1200.0, 489.0], [1173.0, 489.0]], [[1138.0, 136.0], [1164.0, 136.0], [1164.0, 585.0], [1138.0, 585.0]]], "lines": ["ねぇリンちゃんっていつも", "どうやってキャンプ場決めてるの？"]}, {"box": [581, 185, 658, 600], "vertical": true, "font_size": 32, "lines_coords": [[[624.0, 185.0], [656.0, 185.0], [656.0, 598.0], [624.0, 598.0]], [[581.0, 187.0], [613.0, 187.0], [613.0, 600.0], [581.0, 600.0]]], "lines": ["どうやって探したらいいか", "よく分かんないんだけど．．．"]}, {"box": [153, 558, 196, 641], "vertical": true, "font_size": 43, "lines_coords": [[[153.0, 558.0], [196.0, 558.0], [196.0, 641.0], [153.0, 641.0]]], "lines": ["あぁ"]}, {"box": [1122, 971, 1184, 1291], "vertical": true, "font_size": 26, "lines_coords": [[[1156.0, 973.0], [1183.0, 973.0], [1183.0, 1237.0], [1156.0, 1237.0]], [[1123.0, 971.0], [1149.0, 971.0], [1149.0, 1288.0], [1123.0, 1288.0]]], "lines": ["私はグルグルマップで", "「キャンプ場」って検索して"]}, {"box": [429, 958, 492, 1295], "vertical": true, "font_size": 26, "lines_coords": [[[465.0, 958.0], [491.0, 958.0], [491.0, 1181.0], [465.0, 1181.0]], [[429.0, 960.0], [455.0, 960.0], [455.0, 1295.0], [429.0, 1295.0]]], "lines": ["どんな感じの所か", "細かく調べて決めてるかな"]}, {"box": [200, 1005, 236, 1142], "vertical": true, "font_size": 36, "lines_coords": [[[200.0, 1005.0], [236.0, 1005.0], [236.0, 1087.0], [200.0, 1087.0]]], "lines": ["へえー"]}, {"box": [800, 1464, 864, 1745], "vertical": true, "font_size": 26, "lines_coords": [[[836.0, 1466.0], [862.0, 1466.0], [862.0, 1745.0], [836.0, 1745.0]], [[800.0, 1464.0], [825.0, 1464.0], [825.0, 1635.0], [800.0, 1635.0]]], "lines": ["気になるキャンプ場の", "目星つけたら"]}], "img_path": "00010.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [615, 138, 671, 489], "vertical": true, "font_size": 25, "lines_coords": [[[643.0, 138.0], [669.0, 138.0], [671.0, 489.0], [645.0, 489.0]], [[615.0, 140.0], [639.0, 140.0], [639.0, 416.0], [615.0, 416.0]]], "lines": ["クリキャンで泊まった所とかは", "研修施設だから検索には"]}, {"box": [560, 232, 585, 590], "vertical": true, "font_size": 25, "lines_coords": [[[560.0, 232.0], [585.0, 232.0], [585.0, 590.0], [560.0, 590.0]]], "lines": ["引っかからなかったりするけど、"]}, {"box": [157, 385, 185, 508], "vertical": true, "font_size": 26, "lines_coords": [[[157.0, 386.0], [183.0, 386.0], [183.0, 508.0], [157.0, 508.0]]], "lines": ["ほうほう"]}, {"box": [1158, 388, 1215, 712], "vertical": true, "font_size": 27, "lines_coords": [[[1185.0, 388.0], [1211.0, 388.0], [1215.0, 564.0], [1188.0, 564.0]], [[1158.0, 391.0], [1185.0, 391.0], [1185.0, 712.0], [1158.0, 712.0]]], "lines": ["おーーーたしかに", "マップで見ると見やすいかも"]}, {"box": [806, 815, 869, 999], "vertical": true, "font_size": 28, "lines_coords": [[[841.0, 815.0], [868.0, 815.0], [868.0, 950.0], [841.0, 950.0]], [[808.0, 815.0], [836.0, 815.0], [834.0, 999.0], [806.0, 999.0]]], "lines": ["だから穴場", "だったんだねぃ"]}, {"box": [410, 828, 501, 1076], "vertical": true, "font_size": 28, "lines_coords": [[[474.0, 830.0], [498.0, 830.0], [498.0, 1076.0], [474.0, 1076.0]], [[442.0, 830.0], [468.0, 830.0], [468.0, 1055.0], [442.0, 1055.0]], [[410.0, 828.0], [444.0, 828.0], [444.0, 907.0], [410.0, 907.0]]], "lines": ["あとキャンパーさんの", "ブログとか見るのも", "いいよ"]}, {"box": [1163, 1216, 1192, 1450], "vertical": true, "font_size": 26, "lines_coords": [[[1164.0, 1216.0], [1190.0, 1216.0], [1190.0, 1447.0], [1164.0, 1447.0]]], "lines": ["あここよさそう"]}, {"box": [543, 1215, 622, 1456], "vertical": true, "font_size": 33, "lines_coords": [[[590.0, 1216.0], [622.0, 1216.0], [622.0, 1353.0], [590.0, 1353.0]], [[547.0, 1215.0], [581.0, 1215.0], [577.0, 1456.0], [543.0, 1456.0]]], "lines": ["ほらここ", "すごい絶景だよ"]}, {"box": [236, 843, 292, 1104], "vertical": true, "font_size": 24, "lines_coords": [[[266.0, 845.0], [292.0, 845.0], [292.0, 1104.0], [266.0, 1104.0]], [[236.0, 843.0], [262.0, 843.0], [262.0, 1033.0], [236.0, 1033.0]]], "lines": ["実際に泊まってみないと", "分からない事まで"]}, {"box": [195, 952, 215, 1091], "vertical": true, "font_size": 24, "lines_coords": [[[195.0, 952.0], [215.0, 952.0], [215.0, 1091.0], [195.0, 1091.0]]], "lines": ["書いてあるし"]}, {"box": [712, 1630, 742, 1686], "vertical": true, "font_size": 30, "lines_coords": [[[712.0, 1633.0], [742.0, 1633.0], [742.0, 1685.0], [712.0, 1685.0]]], "lines": ["ん？"]}, {"box": [159, 1561, 240, 1665], "vertical": true, "font_size": 41, "lines_coords": [[[193.0, 1563.0], [236.0, 1561.0], [240.0, 1635.0], [196.0, 1636.0]], [[159.0, 1565.0], [198.0, 1565.0], [198.0, 1665.0], [159.0, 1665.0]]], "lines": ["あぁ", "ここか"]}], "img_path": "00011.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1141, 103, 1200, 420], "vertical": true, "font_size": 27, "lines_coords": [[[1173.0, 103.0], [1200.0, 103.0], [1196.0, 420.0], [1170.0, 420.0]], [[1141.0, 105.0], [1168.0, 105.0], [1168.0, 382.0], [1141.0, 382.0]]], "lines": ["でも結構山の方にあるから", "行けそうにないかなぁ．．．"]}, {"box": [667, 120, 727, 442], "vertical": true, "font_size": 25, "lines_coords": [[[697.0, 120.0], [723.0, 120.0], [723.0, 318.0], [697.0, 318.0]], [[667.0, 121.0], [691.0, 121.0], [691.0, 442.0], [667.0, 442.0]]], "lines": ["あれ？桜さんに", "送って貰うんじゃないの？"]}, {"box": [1092, 763, 1203, 1136], "vertical": true, "font_size": 30, "lines_coords": [[[1170.0, 763.0], [1201.0, 763.0], [1201.0, 1044.0], [1170.0, 1044.0]], [[1132.0, 765.0], [1158.0, 765.0], [1158.0, 1136.0], [1132.0, 1136.0]], [[1093.0, 763.0], [1125.0, 763.0], [1125.0, 1108.0], [1093.0, 1108.0]]], "lines": ["お姉ちゃんに一人で", "キャンプするって言ったら、", "絶対反対されると思うし、"]}, {"box": [774, 420, 866, 671], "vertical": true, "font_size": 27, "lines_coords": [[[840.0, 421.0], [864.0, 421.0], [864.0, 671.0], [840.0, 671.0]], [[808.0, 421.0], [834.0, 421.0], [834.0, 622.0], [808.0, 622.0]], [[774.0, 420.0], [806.0, 420.0], [806.0, 525.0], [774.0, 525.0]]], "lines": ["キャンプ場はだいたい", "街から離れた所に", "あるから"]}, {"box": [172, 532, 206, 645], "vertical": true, "font_size": 34, "lines_coords": [[[172.0, 532.0], [206.0, 532.0], [206.0, 645.0], [172.0, 645.0]]], "lines": ["ううん"]}, {"box": [945, 1216, 1053, 1456], "vertical": true, "font_size": 30, "lines_coords": [[[1014.0, 1216.0], [1053.0, 1216.0], [1053.0, 1316.0], [1014.0, 1316.0]], [[980.0, 1222.0], [1006.0, 1222.0], [1006.0, 1455.0], [980.0, 1455.0]], [[946.0, 1222.0], [971.0, 1222.0], [971.0, 1428.0], [946.0, 1428.0]]], "lines": ["じゃあ", "出かける時家族に", "何て言うんだ？"]}, {"box": [712, 1211, 773, 1479], "vertical": true, "font_size": 25, "lines_coords": [[[746.0, 1211.0], [770.0, 1211.0], [770.0, 1436.0], [746.0, 1436.0]], [[712.0, 1213.0], [738.0, 1213.0], [738.0, 1479.0], [712.0, 1479.0]]], "lines": ["みみんなと一緒に", "行くって言おっかな．．．"]}, {"box": [159, 958, 195, 1088], "vertical": true, "font_size": 36, "lines_coords": [[[159.0, 958.0], [195.0, 958.0], [195.0, 1021.0], [159.0, 1021.0]]], "lines": ["あー"]}, {"box": [206, 1261, 268, 1541], "vertical": true, "font_size": 26, "lines_coords": [[[240.0, 1261.0], [266.0, 1261.0], [266.0, 1541.0], [240.0, 1541.0]], [[206.0, 1261.0], [232.0, 1261.0], [232.0, 1541.0], [206.0, 1541.0]]], "lines": ["リンちゃんはいいなぁ", "原付でどこでも行けて"]}], "img_path": "00012.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1160, 141, 1217, 440], "vertical": true, "font_size": 25, "lines_coords": [[[1192.0, 142.0], [1216.0, 142.0], [1216.0, 440.0], [1192.0, 440.0]], [[1160.0, 142.0], [1186.0, 142.0], [1186.0, 343.0], [1160.0, 343.0]]], "lines": ["アヤちゃんもいつの間にか", "免許取ってたし："]}, {"box": [654, 140, 717, 410], "vertical": true, "font_size": 29, "lines_coords": [[[686.0, 142.0], [712.0, 142.0], [716.0, 251.0], [690.0, 251.0]], [[654.0, 140.0], [686.0, 140.0], [686.0, 410.0], [654.0, 410.0]]], "lines": ["私も免許", "取っちゃおうかナァ．．．"]}, {"box": [1155, 888, 1228, 1010], "vertical": true, "font_size": 37, "lines_coords": [[[1185.0, 888.0], [1228.0, 888.0], [1228.0, 958.0], [1185.0, 958.0]], [[1155.0, 890.0], [1186.0, 890.0], [1186.0, 1010.0], [1155.0, 1010.0]]], "lines": ["すぐ", "転けそう"]}, {"box": [975, 856, 1085, 984], "vertical": true, "font_size": 33, "lines_coords": [[[1050.0, 856.0], [1083.0, 856.0], [1083.0, 984.0], [1050.0, 984.0]], [[1012.0, 858.0], [1046.0, 858.0], [1046.0, 984.0], [1012.0, 984.0]], [[975.0, 856.0], [1008.0, 856.0], [1008.0, 956.0], [975.0, 956.0]]], "lines": ["ガス欠で", "立ち往生", "しそう"]}, {"box": [646, 828, 746, 1083], "vertical": true, "font_size": 29, "lines_coords": [[[712.0, 828.0], [746.0, 828.0], [746.0, 918.0], [712.0, 918.0]], [[678.0, 832.0], [705.0, 832.0], [705.0, 1083.0], [678.0, 1083.0]], [[646.0, 832.0], [671.0, 832.0], [671.0, 1081.0], [646.0, 1081.0]]], "lines": ["確かに", "家族のみんなからも", "反対されそうだけど"]}, {"box": [828, 906, 892, 1050], "vertical": true, "font_size": 26, "lines_coords": [[[862.0, 907.0], [888.0, 907.0], [888.0, 1050.0], [862.0, 1050.0]], [[828.0, 907.0], [855.0, 907.0], [855.0, 1048.0], [828.0, 1048.0]]], "lines": ["道間違えて", "遭難しそう"]}, {"box": [682, 1231, 746, 1499], "vertical": true, "font_size": 26, "lines_coords": [[[720.0, 1231.0], [746.0, 1231.0], [746.0, 1498.0], [720.0, 1498.0]], [[682.0, 1231.0], [708.0, 1231.0], [708.0, 1485.0], [682.0, 1485.0]]], "lines": ["よし！こうなったら", "リンちゃんの原付に"]}, {"box": [65, 1243, 137, 1494], "vertical": true, "font_size": 30, "lines_coords": [[[108.0, 1248.0], [135.0, 1248.0], [135.0, 1462.0], [108.0, 1462.0]], [[65.0, 1243.0], [97.0, 1243.0], [97.0, 1494.0], [65.0, 1494.0]]], "lines": ["リヤカー付けて", "運んでもらおう！！"]}, {"box": [828, 1528, 900, 1781], "vertical": true, "font_size": 30, "lines_coords": [[[866.0, 1530.0], [898.0, 1530.0], [898.0, 1781.0], [866.0, 1781.0]], [[828.0, 1528.0], [856.0, 1528.0], [858.0, 1749.0], [830.0, 1749.0]]], "lines": ["顔が絶対ダメって", "言ってるよぅ．．．"]}, {"box": [80, 1582, 143, 1777], "vertical": true, "font_size": 26, "lines_coords": [[[114.0, 1582.0], [140.0, 1582.0], [140.0, 1777.0], [114.0, 1777.0]], [[80.0, 1582.0], [106.0, 1582.0], [106.0, 1695.0], [80.0, 1695.0]]], "lines": ["重くて進まなく", "なるだろ"]}], "img_path": "00013.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1174, 140, 1236, 392], "vertical": true, "font_size": 26, "lines_coords": [[[1207.0, 140.0], [1233.0, 140.0], [1233.0, 390.0], [1207.0, 390.0]], [[1175.0, 142.0], [1200.0, 142.0], [1200.0, 337.0], [1175.0, 337.0]]], "lines": ["じゃあリンちゃんが", "車の免許取って"]}, {"box": [620, 161, 690, 305], "vertical": true, "font_size": 34, "lines_coords": [[[654.0, 161.0], [686.0, 161.0], [690.0, 305.0], [658.0, 305.0]], [[620.0, 161.0], [656.0, 161.0], [656.0, 251.0], [620.0, 251.0]]], "lines": ["リヤカーを", "車で．．"]}, {"box": [463, 185, 489, 450], "vertical": true, "font_size": 26, "lines_coords": [[[463.0, 185.0], [489.0, 185.0], [489.0, 450.0], [463.0, 450.0]]], "lines": ["車がダメなら自転車か"]}, {"box": [358, 298, 450, 566], "vertical": true, "font_size": 26, "lines_coords": [[[423.0, 298.0], [450.0, 298.0], [450.0, 406.0], [423.0, 406.0]], [[391.0, 301.0], [418.0, 301.0], [418.0, 566.0], [391.0, 566.0]], [[358.0, 300.0], [384.0, 300.0], [384.0, 566.0], [358.0, 566.0]]], "lines": ["電車とか", "バスで途中まで行って", "あとは歩きじゃない？"]}, {"box": [1156, 795, 1286, 984], "vertical": true, "font_size": 32, "lines_coords": [[[1250.0, 804.0], [1286.0, 804.0], [1286.0, 840.0], [1250.0, 840.0]], [[1196.0, 796.0], [1228.0, 796.0], [1228.0, 984.0], [1196.0, 984.0]], [[1158.0, 796.0], [1185.0, 796.0], [1185.0, 950.0], [1158.0, 950.0]]], "lines": ["あ", "輪行するって", "手もあるか"]}, {"box": [564, 477, 626, 675], "vertical": true, "font_size": 26, "lines_coords": [[[600.0, 480.0], [626.0, 480.0], [626.0, 618.0], [600.0, 618.0]], [[564.0, 478.0], [590.0, 478.0], [590.0, 675.0], [564.0, 675.0]]], "lines": ["おとなしく", "車の方に乗れよ"]}, {"box": [697, 793, 762, 1044], "vertical": true, "font_size": 26, "lines_coords": [[[735.0, 795.0], [761.0, 795.0], [761.0, 988.0], [735.0, 988.0]], [[697.0, 793.0], [723.0, 793.0], [723.0, 1044.0], [697.0, 1044.0]]], "lines": ["バスとか電車に", "自転車を持ち込む事"]}, {"box": [849, 1177, 941, 1299], "vertical": true, "font_size": 45, "lines_coords": [[[886.0, 1179.0], [937.0, 1177.0], [941.0, 1265.0], [890.0, 1267.0]], [[849.0, 1185.0], [888.0, 1185.0], [888.0, 1299.0], [849.0, 1299.0]]], "lines": ["りん", "こう？"]}, {"box": [185, 995, 248, 1276], "vertical": true, "font_size": 26, "lines_coords": [[[221.0, 997.0], [247.0, 997.0], [247.0, 1276.0], [221.0, 1276.0]], [[185.0, 995.0], [211.0, 995.0], [211.0, 1276.0], [185.0, 1276.0]]], "lines": ["これなら下りた駅から", "自転車移動が出来るよ"]}, {"box": [1098, 1468, 1171, 1640], "vertical": true, "font_size": 33, "lines_coords": [[[1130.0, 1470.0], [1171.0, 1470.0], [1171.0, 1561.0], [1130.0, 1561.0]], [[1098.0, 1468.0], [1130.0, 1468.0], [1130.0, 1640.0], [1098.0, 1640.0]]], "lines": ["へぇー", "それいいかも"]}, {"box": [1038, 1580, 1065, 1695], "vertical": true, "font_size": 33, "lines_coords": [[[1038.0, 1580.0], [1065.0, 1580.0], [1065.0, 1695.0], [1038.0, 1695.0]]], "lines": ["輪行かぁ"]}], "img_path": "00014.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1153, 144, 1224, 396], "vertical": true, "font_size": 30, "lines_coords": [[[1192.0, 148.0], [1220.0, 148.0], [1222.0, 393.0], [1194.0, 393.0]], [[1153.0, 144.0], [1186.0, 144.0], [1186.0, 303.0], [1153.0, 303.0]]], "lines": ["一輪車で輪行する", "リンちゃん"]}, {"box": [764, 142, 838, 303], "vertical": true, "font_size": 36, "lines_coords": [[[798.0, 144.0], [838.0, 144.0], [838.0, 275.0], [798.0, 275.0]], [[765.0, 142.0], [796.0, 142.0], [796.0, 301.0], [765.0, 301.0]]], "lines": ["リンリン", "リンちゃん"]}, {"box": [624, 173, 701, 414], "vertical": true, "font_size": 32, "lines_coords": [[[665.0, 176.0], [697.0, 176.0], [697.0, 414.0], [665.0, 414.0]], [[624.0, 174.0], [656.0, 174.0], [656.0, 345.0], [624.0, 345.0]]], "lines": ["今くだらない事", "考えてたろ"]}, {"box": [1145, 785, 1205, 1106], "vertical": true, "font_size": 26, "lines_coords": [[[1179.0, 785.0], [1205.0, 785.0], [1205.0, 1076.0], [1179.0, 1076.0]], [[1145.0, 785.0], [1171.0, 785.0], [1171.0, 1106.0], [1145.0, 1106.0]]], "lines": ["．．．けど自転車折り畳んで", "専用のバッグに入れないと、"]}, {"box": [1091, 1016, 1117, 1147], "vertical": true, "font_size": 26, "lines_coords": [[[1091.0, 1016.0], [1117.0, 1016.0], [1117.0, 1147.0], [1091.0, 1147.0]]], "lines": ["ダメだとか"]}, {"box": [1145, 1246, 1210, 1500], "vertical": true, "font_size": 26, "lines_coords": [[[1183.0, 1250.0], [1209.0, 1250.0], [1209.0, 1500.0], [1183.0, 1500.0]], [[1147.0, 1246.0], [1173.0, 1246.0], [1171.0, 1471.0], [1145.0, 1471.0]]], "lines": ["やっぱりバスと電車", "使って歩きかなぁ"]}, {"box": [686, 807, 749, 1149], "vertical": true, "font_size": 26, "lines_coords": [[[721.0, 810.0], [748.0, 810.0], [748.0, 1145.0], [721.0, 1145.0]], [[686.0, 808.0], [710.0, 808.0], [710.0, 1145.0], [686.0, 1145.0]]], "lines": ["混んでる時は乗れない事も", "あるとかちょっと面倒がも"]}, {"box": [170, 933, 206, 1063], "vertical": true, "font_size": 34, "lines_coords": [[[170.0, 933.0], [204.0, 933.0], [206.0, 1063.0], [172.0, 1063.0]]], "lines": ["むむぅ．．．"]}, {"box": [690, 1249, 752, 1672], "vertical": true, "font_size": 27, "lines_coords": [[[721.0, 1250.0], [750.0, 1250.0], [751.0, 1672.0], [723.0, 1672.0]], [[690.0, 1250.0], [716.0, 1250.0], [716.0, 1616.0], [690.0, 1616.0]]], "lines": ["あとリンちゃんがキャンプする時", "注意してる事って何かある？"]}, {"box": [144, 1539, 216, 1680], "vertical": true, "font_size": 32, "lines_coords": [[[181.0, 1543.0], [213.0, 1543.0], [213.0, 1680.0], [181.0, 1680.0]]], "lines": ["そうだな"]}], "img_path": "00015.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1177, 153, 1215, 401], "vertical": true, "font_size": 38, "lines_coords": [[[1177.0, 153.0], [1215.0, 153.0], [1215.0, 401.0], [1177.0, 401.0]]], "lines": ["「電波が通じる"]}, {"box": [1126, 243, 1164, 474], "vertical": true, "font_size": 38, "lines_coords": [[[1126.0, 243.0], [1164.0, 243.0], [1164.0, 474.0], [1126.0, 474.0]]], "lines": ["ンブ場を選ぶ"]}, {"box": [822, 315, 877, 410], "vertical": true, "font_size": 30, "lines_coords": [[[847.0, 315.0], [877.0, 315.0], [877.0, 410.0], [847.0, 410.0]]], "lines": ["天ぷらっンバ"]}, {"box": [626, 135, 692, 448], "vertical": true, "font_size": 26, "lines_coords": [[[663.0, 138.0], [690.0, 138.0], [690.0, 446.0], [663.0, 446.0]], [[626.0, 136.0], [652.0, 136.0], [652.0, 360.0], [626.0, 360.0]]], "lines": ["何か困った事が起きた時", "助けも呼べないし"]}, {"box": [125, 127, 191, 467], "vertical": true, "font_size": 29, "lines_coords": [[[159.0, 129.0], [191.0, 129.0], [191.0, 412.0], [159.0, 412.0]], [[127.0, 129.0], [153.0, 129.0], [151.0, 466.0], [125.0, 466.0]]], "lines": ["知りたい事があっても", "ネットで調べられないから"]}, {"box": [1134, 750, 1160, 926], "vertical": true, "font_size": 32, "lines_coords": [[[1134.0, 750.0], [1160.0, 750.0], [1160.0, 926.0], [1134.0, 926.0]]], "lines": ["言っておく"]}, {"box": [1173, 708, 1215, 1113], "vertical": true, "font_size": 32, "lines_coords": [[[1177.0, 708.0], [1215.0, 708.0], [1211.0, 1113.0], [1173.0, 1113.0]]], "lines": ["２家族や知人に行き先を"]}, {"box": [630, 725, 661, 973], "vertical": true, "font_size": 31, "lines_coords": [[[630.0, 725.0], [661.0, 725.0], [661.0, 973.0], [630.0, 973.0]]], "lines": ["一人だとなおさらね"]}, {"box": [135, 521, 211, 596], "vertical": true, "font_size": 39, "lines_coords": [[[168.0, 521.0], [211.0, 521.0], [211.0, 596.0], [168.0, 596.0]], [[135.0, 523.0], [170.0, 523.0], [170.0, 594.0], [135.0, 594.0]]], "lines": ["うん", "うん"]}, {"box": [230, 787, 298, 1040], "vertical": true, "font_size": 29, "lines_coords": [[[266.0, 787.0], [298.0, 787.0], [298.0, 1040.0], [266.0, 1040.0]], [[230.0, 787.0], [256.0, 787.0], [260.0, 928.0], [234.0, 928.0]]], "lines": ["やっぱり言わなきゃ", "タメかなぁ"]}, {"box": [140, 730, 178, 879], "vertical": true, "font_size": 34, "lines_coords": [[[140.0, 731.0], [174.0, 731.0], [174.0, 879.0], [140.0, 879.0]]], "lines": ["ダメだろ"]}, {"box": [502, 1267, 572, 1610], "vertical": true, "font_size": 30, "lines_coords": [[[543.0, 1269.0], [570.0, 1269.0], [570.0, 1610.0], [543.0, 1610.0]], [[502.0, 1269.0], [534.0, 1269.0], [534.0, 1426.0], [502.0, 1426.0]]], "lines": ["調べるってキャンプ場の", "場所とか？"]}, {"box": [1177, 1237, 1219, 1652], "vertical": true, "font_size": 39, "lines_coords": [[[1177.0, 1237.0], [1216.0, 1237.0], [1216.0, 1648.0], [1177.0, 1648.0]]], "lines": ["３じっくり下調べをする"]}, {"box": [138, 1511, 204, 1717], "vertical": true, "font_size": 26, "lines_coords": [[[176.0, 1513.0], [202.0, 1513.0], [202.0, 1717.0], [176.0, 1717.0]], [[138.0, 1513.0], [165.0, 1513.0], [165.0, 1657.0], [138.0, 1657.0]]], "lines": ["それもあるけど", "他にも色々"]}], "img_path": "00016.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [727, 268, 798, 646], "vertical": true, "font_size": 32, "lines_coords": [[[766.0, 268.0], [798.0, 268.0], [796.0, 645.0], [765.0, 645.0]], [[727.0, 270.0], [759.0, 270.0], [759.0, 646.0], [727.0, 646.0]]], "lines": ["よく調べずに行ってみたら、", "冬に水道が止まってるとか"]}, {"box": [603, 163, 667, 476], "vertical": true, "font_size": 30, "lines_coords": [[[635.0, 163.0], [667.0, 163.0], [665.0, 476.0], [633.0, 476.0]], [[603.0, 166.0], [630.0, 166.0], [630.0, 279.0], [603.0, 279.0]]], "lines": ["トイレが酷かったりとか", "あるから"]}, {"box": [153, 165, 217, 313], "vertical": true, "font_size": 26, "lines_coords": [[[189.0, 166.0], [215.0, 166.0], [215.0, 313.0], [189.0, 313.0]], [[153.0, 165.0], [180.0, 165.0], [180.0, 281.0], [153.0, 281.0]]], "lines": ["あーそれは", "嫌だねぇ"]}, {"box": [708, 772, 801, 1074], "vertical": true, "font_size": 38, "lines_coords": [[[759.0, 772.0], [796.0, 772.0], [796.0, 1074.0], [759.0, 1074.0]], [[708.0, 806.0], [748.0, 806.0], [751.0, 960.0], [712.0, 960.0]]], "lines": ["４天気予報を確認", "しておく"]}, {"box": [1145, 810, 1209, 1117], "vertical": true, "font_size": 26, "lines_coords": [[[1179.0, 810.0], [1205.0, 810.0], [1207.0, 1089.0], [1181.0, 1089.0]], [[1145.0, 813.0], [1171.0, 813.0], [1171.0, 1117.0], [1145.0, 1117.0]]], "lines": ["あとキャンプ場までの", "ルートとかかる時間もね"]}, {"box": [879, 1240, 991, 1303], "vertical": false, "font_size": 27, "lines_coords": [[[883.0, 1243.0], [990.0, 1243.0], [990.0, 1269.0], [883.0, 1269.0]], [[881.0, 1271.0], [984.0, 1275.0], [984.0, 1303.0], [881.0, 1299.0]]], "lines": ["日１時間５分", "５３．７ｋｍ"]}, {"box": [155, 916, 221, 1183], "vertical": true, "font_size": 26, "lines_coords": [[[193.0, 916.0], [219.0, 916.0], [219.0, 1095.0], [193.0, 1095.0]], [[155.0, 916.0], [181.0, 916.0], [181.0, 1183.0], [155.0, 1183.0]]], "lines": ["天気予報なら", "私だって見てるよー"]}, {"box": [870, 1513, 915, 1627], "vertical": true, "font_size": 42, "lines_coords": [[[870.0, 1515.0], [911.0, 1513.0], [915.0, 1625.0], [873.0, 1627.0]]], "lines": ["へぇー"]}, {"box": [710, 1348, 783, 1663], "vertical": true, "font_size": 30, "lines_coords": [[[753.0, 1355.0], [780.0, 1355.0], [780.0, 1663.0], [753.0, 1663.0]], [[712.0, 1348.0], [744.0, 1348.0], [742.0, 1603.0], [710.0, 1603.0]]], "lines": ["雨予報だけじゃなくて", "気温グラフも見て"]}, {"box": [185, 1325, 250, 1563], "vertical": true, "font_size": 29, "lines_coords": [[[217.0, 1329.0], [249.0, 1329.0], [249.0, 1563.0], [217.0, 1563.0]], [[185.0, 1325.0]