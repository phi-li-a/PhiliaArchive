1678], "vertical": true, "font_size": 56, "lines_coords": [[[211.0, 1524.0], [264.0, 1524.0], [264.0, 1608.0], [211.0, 1608.0]], [[150.0, 1522.0], [210.0, 1522.0], [210.0, 1678.0], [150.0, 1678.0]]], "lines": ["あー", "確かに"]}], "img_path": "00177.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1127, 153, 1197, 588], "vertical": true, "font_size": 26, "lines_coords": [[[1168.0, 155.0], [1194.0, 155.0], [1194.0, 495.0], [1168.0, 495.0]], [[1130.0, 153.0], [1155.0, 153.0], [1155.0, 588.0], [1130.0, 588.0]]], "lines": ["食器とかお鍋は寝る前に", "片付けた方がスッキリするよね"]}, {"box": [573, 141, 648, 616], "vertical": true, "font_size": 32, "lines_coords": [[[615.0, 146.0], [646.0, 146.0], [646.0, 459.0], [615.0, 459.0]], [[573.0, 144.0], [605.0, 144.0], [605.0, 615.0], [573.0, 615.0]]], "lines": ["起きたら帰るだけやし", "テーブルとイスもＲ付けてええな"]}, {"box": [1123, 1008, 1201, 1457], "vertical": true, "font_size": 32, "lines_coords": [[[1168.0, 1012.0], [1200.0, 1012.0], [1200.0, 1456.0], [1168.0, 1456.0]], [[1125.0, 1008.0], [1156.0, 1008.0], [1155.0, 1425.0], [1123.0, 1425.0]]], "lines": ["寝起きで片付けんの大変だし、", "テントもまとめちまうか！！"]}], "img_path": "00178.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [101, 211, 1051, 277], "vertical": false, "font_size": 26, "lines_coords": [[[101.0, 211.0], [553.0, 211.0], [553.0, 236.0], [101.0, 236.0]], [[101.0, 249.0], [1051.0, 251.0], [1051.0, 277.0], [101.0, 275.0]]], "lines": ["ゆるキャン△ういかがでしたでしょうか。", "今回はなでしこのソロキャンにまつわる話と薪集め、ヘヤキャン△を収録致しました"]}, {"box": [99, 331, 849, 438], "vertical": false, "font_size": 26, "lines_coords": [[[103.0, 331.0], [601.0, 333.0], [601.0, 360.0], [103.0, 358.0]], [[99.0, 373.0], [849.0, 373.0], [849.0, 399.0], [99.0, 399.0]], [[99.0, 412.0], [560.0, 412.0], [560.0, 438.0], [99.0, 438.0]]], "lines": ["７巻まで来てまだ作中では１月末なんですね", "次巻では少しだけけ時間を飛ばして伊豆の話を書こうかなと思います", "伊豆のわさびソフトまた食べたいナァ．．．"]}, {"box": [99, 496, 249, 523], "vertical": false, "font_size": 27, "lines_coords": [[[99.0, 496.0], [249.0, 496.0], [249.0, 523.0], [99.0, 523.0]]], "lines": ["あｆろでした。"]}, {"box": [408, 1689, 500, 1715], "vertical": false, "font_size": 26, "lines_coords": [[[408.0, 1689.0], [500.0, 1689.0], [500.0, 1715.0], [408.0, 1715.0]]], "lines": ["初出一覧"]}, {"box": [401, 1713, 1241, 1838], "vertical": false, "font_size": 33, "lines_coords": [[[416.0, 1710.0], [1241.0, 1712.0], [1241.0, 1750.0], [416.0, 1748.0]], [[406.0, 1733.0], [898.0, 1738.0], [898.0, 1782.0], [406.0, 1776.0]], [[405.0, 1778.0], [538.0, 1774.0], [538.0, 1801.0], [405.0, 1804.0]], [[401.0, 1798.0], [731.0, 1804.0], [731.0, 1840.0], [401.0, 1834.0]]], "lines": ["お兄ちゃんもんなんかダイムもうフックード平成２８年５月２５日に平成３０年９月１３日、平成２０年１１月５日", "そんなダイエッジングードアルバイトです。こちらへ「大平成２４年５月１日－２０日〜２０１３年１２月１７日－１９月１２日土日土曜日までの", "こっちへへ．．．描き下ろし", "・抱きやらし本人は以上の内容を収録しました。"]}], "img_path": "00179.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [744, 226, 1027, 416], "vertical": false, "font_size": 179, "lines_coords": [[[751.0, 226.0], [1027.0, 238.0], [1020.0, 416.0], [744.0, 405.0]]], "lines": ["リストラン"]}, {"box": [578, 266, 637, 555], "vertical": true, "font_size": 29, "lines_coords": [[[601.0, 266.0], [633.0, 266.0], [637.0, 555.0], [605.0, 555.0]], [[579.0, 268.0], [605.0, 268.0], [605.0, 431.0], [579.0, 431.0]]], "lines": ["うだっに人る者の足を掴み", "こたつの奥底へ"]}, {"box": [213, 265, 269, 458], "vertical": true, "font_size": 30, "lines_coords": [[[241.0, 270.0], [268.0, 270.0], [268.0, 457.0], [241.0, 457.0]], [[213.0, 268.0], [245.0, 268.0], [245.0, 414.0], [213.0, 414.0]]], "lines": ["引きずり込む妖怪", "「こたつ河童」"]}, {"box": [725, 416, 1117, 628], "vertical": false, "font_size": 75.33333333333333, "lines_coords": [[[751.0, 416.0], [1117.0, 435.0], [1113.0, 506.0], [748.0, 489.0]], [[725.0, 498.0], [982.0, 478.0], [988.0, 558.0], [731.0, 579.0]], [[727.0, 555.0], [1089.0, 547.0], [1091.0, 620.0], [729.0, 628.0]]], "lines": ["Ａｍａｚｏｎ機能は、", "おそらくそんなことじゃなくなっていいよ", "本当だけど"]}, {"box": [568, 643, 626, 880], "vertical": true, "font_size": 25, "lines_coords": [[[598.0, 643.0], [622.0, 643.0], [622.0, 877.0], [598.0, 877.0]], [[568.0, 643.0], [594.0, 643.0], [596.0, 834.0], [570.0, 834.0]]], "lines": ["山梨では古くからこの", "こたつに取り憑く"]}, {"box": [226, 642, 253, 881], "vertical": true, "font_size": 25, "lines_coords": [[[226.0, 645.0], [251.0, 645.0], [251.0, 881.0], [226.0, 881.0]]], "lines": ["こたつ河童を祓うため"]}, {"box": [571, 986, 626, 1293], "vertical": true, "font_size": 26, "lines_coords": [[[598.0, 986.0], [624.0, 986.0], [622.0, 1284.0], [596.0, 1284.0]], [[571.0, 988.0], [596.0, 988.0], [596.0, 1293.0], [571.0, 1293.0]]], "lines": ["毎年こたつを出す前の１０月末", "こたつを担いで身延山を登る。"]}, {"box": [465, 1356, 507, 1494], "vertical": true, "font_size": 20, "lines_coords": [[[485.0, 1357.0], [506.0, 1357.0], [506.0, 1494.0], [485.0, 1494.0]], [[465.0, 1357.0], [485.0, 1357.0], [485.0, 1473.0], [465.0, 1473.0]]], "lines": ["県民に親しまれ", "とるんやでー"]}, {"box": [217, 984, 273, 1239], "vertical": true, "font_size": 26, "lines_coords": [[[243.0, 995.0], [270.0, 995.0], [271.0, 1235.0], [245.0, 1235.0]], [[217.0, 984.0], [243.0, 984.0], [245.0, 1237.0], [219.0, 1237.0]]], "lines": ["こたつ参り」という", "奇祭が行われていました"]}, {"box": [255, 1387, 281, 1470], "vertical": true, "font_size": 26, "lines_coords": [[[255.0, 1387.0], [281.0, 1387.0], [281.0, 1470.0], [255.0, 1470.0]]], "lines": ["はいはい"]}, {"box": [570, 1366, 641, 1586], "vertical": true, "font_size": 25, "lines_coords": [[[616.0, 1366.0], [641.0, 1366.0], [641.0, 1545.0], [616.0, 1545.0]], [[596.0, 1370.0], [620.0, 1370.0], [620.0, 1586.0], [596.0, 1586.0]], [[573.0, 1368.0], [600.0, 1368.0], [596.0, 1509.0], [570.0, 1509.0]]], "lines": ["こたつ参りは今じゃ", "山梨の最もポピュラーな", "スポーツとして"]}], "img_path": "00180.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [395, 796, 611, 900], "vertical": false, "font_size": 39.0, "lines_coords": [[[397.0, 796.0], [611.0, 796.0], [611.0, 834.0], [397.0, 834.0]], [[395.0, 860.0], [495.0, 860.0], [495.0, 900.0], [395.0, 900.0]]], "lines": ["著者：あ