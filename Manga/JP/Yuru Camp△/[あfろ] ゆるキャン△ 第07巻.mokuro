86.0], [1081.0, 727.0], [1055.0, 727.0]]], "lines": ["何らかの妖精ではないかと聞されている"]}, {"box": [969, 581, 999, 699], "vertical": true, "font_size": 21, "lines_coords": [[[978.0, 581.0], [999.0, 581.0], [999.0, 699.0], [978.0, 699.0]]], "lines": ["さすがに作り話"]}, {"box": [921, 586, 949, 612], "vertical": false, "font_size": 26, "lines_coords": [[[921.0, 586.0], [949.0, 586.0], [949.0, 612.0], [921.0, 612.0]]], "lines": ["いやいや"]}, {"box": [976, 775, 1002, 879], "vertical": true, "font_size": 26, "lines_coords": [[[976.0, 775.0], [1002.0, 775.0], [1002.0, 879.0], [976.0, 879.0]]], "lines": ["大垣市は飛び地でな小さい大垣が一つと"]}, {"box": [775, 581, 805, 683], "vertical": true, "font_size": 30, "lines_coords": [[[775.0, 581.0], [805.0, 581.0], [805.0, 683.0], [775.0, 683.0]]], "lines": ["今の話を裏付ける証拠があるんや"]}, {"box": [648, 510, 701, 555], "vertical": false, "font_size": 45, "lines_coords": [[[648.0, 510.0], [701.0, 510.0], [701.0, 555.0], [648.0, 555.0]]], "lines": ["んの"]}, {"box": [776, 774, 801, 864], "vertical": true, "font_size": 25, "lines_coords": [[[776.0, 774.0], [801.0, 774.0], [801.0, 864.0], [776.0, 864.0]]], "lines": ["大きい大垣が二つ存在するんや。"]}, {"box": [779, 894, 806, 941], "vertical": true, "font_size": 27, "lines_coords": [[[779.0, 894.0], [806.0, 894.0], [806.0, 941.0], [779.0, 941.0]]], "lines": ["つまり"]}, {"box": [641, 609, 702, 990], "vertical": true, "font_size": 56, "lines_coords": [[[645.0, 609.0], [701.0, 609.0], [697.0, 990.0], [641.0, 990.0]]], "lines": ["ゆるチャン△："]}, {"box": [427, 667, 481, 714], "vertical": false, "font_size": 47, "lines_coords": [[[427.0, 667.0], [481.0, 667.0], [481.0, 714.0], [427.0, 714.0]]], "lines": ["な"]}, {"box": [262, 609, 293, 687], "vertical": true, "font_size": 31, "lines_coords": [[[262.0, 609.0], [293.0, 609.0], [293.0, 687.0], [262.0, 687.0]]], "lines": ["信じるか信じないかは"]}, {"box": [270, 775, 297, 878], "vertical": true, "font_size": 27, "lines_coords": [[[270.0, 775.0], [297.0, 775.0], [297.0, 878.0], [270.0, 878.0]]], "lines": ["都市伝説ってドキドキするよねぇ"]}, {"box": [56, 605, 123, 695], "vertical": true, "font_size": 34, "lines_coords": [[[90.0, 607.0], [123.0, 607.0], [123.0, 695.0], [90.0, 695.0]], [[56.0, 605.0], [90.0, 605.0], [90.0, 693.0], [56.0, 693.0]]], "lines": ["金次第", "です！！"]}, {"box": [70, 879, 101, 936], "vertical": true, "font_size": 31, "lines_coords": [[[70.0, 879.0], [101.0, 879.0], [101.0, 936.0], [70.0, 936.0]]], "lines": ["おもろいよなぁー"]}, {"box": [1240, 969, 1268, 1108], "vertical": true, "font_size": 28, "lines_coords": [[[1240.0, 969.0], [1268.0, 969.0], [1268.0, 1108.0], [1240.0, 1108.0]]], "lines": ["あきの肩に乗っかっとったんよ！！"]}, {"box": [1219, 1161, 1286, 1257], "vertical": true, "font_size": 21, "lines_coords": [[[1220.0, 1196.0], [1241.0, 1196.0], [1241.0, 1256.0], [1220.0, 1256.0]]], "lines": ["――人あきが！！"]}, {"box": [1041, 1044, 1081, 1118], "vertical": true, "font_size": 40, "lines_coords": [[[1041.0, 1044.0], [1081.0, 1044.0], [1081.0, 1118.0], [1041.0, 1118.0]]], "lines": ["ていうかちっちゃいあきちゃん！？"]}, {"box": [969, 981, 1005, 1119], "vertical": true, "font_size": 19, "lines_coords": [[[986.0, 982.0], [1005.0, 982.0], [1005.0, 1119.0], [986.0, 1119.0]], [[969.0, 982.0], [988.0, 982.0], [988.0, 1061.0], [969.0, 1061.0]]], "lines": ["やっぱりあきは３人", "おったんや"]}, {"box": [1049, 1242, 1077, 1324], "vertical": true, "font_size": 28, "lines_coords": [[[1049.0, 1242.0], [1077.0, 1242.0], [1077.0, 1324.0], [1049.0, 1324.0]]], "lines": ["とどどどういうこと！！"]}, {"box": [659, 938, 688, 1042], "vertical": true, "font_size": 29, "lines_coords": [[[659.0, 938.0], [688.0, 938.0], [688.0, 1042.0], [659.0, 1042.0]]], "lines": ["ｈｉ＠ｈａｓｈｏｏｌｄｉｒｓｐｏｙｕｒｕｃｏｍｐｉｎｎｏｔｉｌｅ"]}, {"box": [260, 982, 300, 1096], "vertical": true, "font_size": 40, "lines_coords": [[[260.0, 982.0], [300.0, 982.0], [300.0, 1096.0], [260.0, 1096.0]]], "lines": ["あおいちゃんは何かふしぎ体験したことない？"]}, {"box": [91, 978, 122, 1027], "vertical": true, "font_size": 31, "lines_coords": [[[91.0, 978.0], [122.0, 978.0], [122.0, 1027.0], [91.0, 1027.0]]], "lines": ["あるで――"]}, {"box": [261, 1171, 300, 128