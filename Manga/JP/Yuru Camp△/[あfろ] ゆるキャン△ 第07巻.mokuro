": "00153.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1126, 159, 1188, 523], "vertical": true, "font_size": 26, "lines_coords": [[[1162.0, 159.0], [1186.0, 159.0], [1186.0, 356.0], [1162.0, 356.0]], [[1126.0, 159.0], [1153.0, 159.0], [1153.0, 523.0], [1126.0, 523.0]]], "lines": ["おっかしいなー", "ＨＰが間違ってんのかなぁ？"]}, {"box": [660, 153, 727, 502], "vertical": true, "font_size": 30, "lines_coords": [[[691.0, 153.0], [725.0, 153.0], [727.0, 502.0], [693.0, 502.0]], [[660.0, 157.0], [686.0, 157.0], [686.0, 466.0], [660.0, 466.0]]], "lines": ["もしかしてもう配布終了", "してしまったんじゃ："]}, {"box": [127, 171, 208, 352], "vertical": true, "font_size": 34, "lines_coords": [[[172.0, 172.0], [206.0, 172.0], [206.0, 352.0], [172.0, 352.0]], [[127.0, 174.0], [161.0, 174.0], [161.0, 318.0], [127.0, 318.0]]], "lines": ["それはない", "ですよー"]}, {"box": [1107, 773, 1185, 1185], "vertical": true, "font_size": 33, "lines_coords": [[[1147.0, 774.0], [1181.0, 774.0], [1183.0, 1183.0], [1149.0, 1183.0]], [[1108.0, 776.0], [1140.0, 776.0], [1140.0, 1119.0], [1108.0, 1119.0]]], "lines": ["去年新配布に参加した人の", "ブログ見たんですけど、"]}, {"box": [253, 815, 324, 1190], "vertical": true, "font_size": 28, "lines_coords": [[[292.0, 815.0], [324.0, 815.0], [324.0, 1190.0], [292.0, 1190.0]], [[253.0, 815.0], [285.0, 815.0], [285.0, 1100.0], [253.0, 1100.0]]], "lines": ["河川敷一面に薪がどっさり", "積まれてたんですよ"]}, {"box": [170, 1001, 241, 1293], "vertical": true, "font_size": 28, "lines_coords": [[[210.0, 1001.0], [241.0, 1001.0], [241.0, 1220.0], [210.0, 1220.0]], [[170.0, 1003.0], [202.0, 1003.0], [202.0, 1273.0], [170.0, 1273.0]], [[180.0, 1271.0], [193.0, 1271.0], [193.0, 1293.0], [180.0, 1293.0]]], "lines": ["さすがに一日で", "無くなるって事はー", "．．．"]}, {"box": [1080, 1494, 1161, 1700], "vertical": true, "font_size": 36, "lines_coords": [[[1126.0, 1498.0], [1158.0, 1498.0], [1158.0, 1700.0], [1126.0, 1700.0]], [[1080.0, 1494.0], [1119.0, 1494.0], [1119.0, 1603.0], [1080.0, 1603.0]]], "lines": ["無くなるって", "事は．．"]}], "img_path