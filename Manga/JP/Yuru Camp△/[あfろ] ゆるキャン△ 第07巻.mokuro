.0], [157.0, 1706.0]]], "lines": ["そうですね"]}], "img_path": "00024.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [768, 165, 804, 524], "vertical": true, "font_size": 32, "lines_coords": [[[768.0, 166.0], [800.0, 166.0], [800.0, 521.0], [768.0, 521.0]]], "lines": ["お池池じゃないですか"]}, {"box": [178, 198, 360, 313], "vertical": false, "font_size": 30, "lines_coords": [[[178.0, 286.0], [346.0, 198.0], [360.0, 225.0], [191.0, 313.0]]], "lines": ["いやむ、ｌｅｏｌｙ"]}, {"box": [1155, 776, 1220, 1029], "vertical": true, "font_size": 29, "lines_coords": [[[1192.0, 776.0], [1220.0, 776.0], [1218.0, 1014.0], [1190.0, 1014.0]], [[1156.0, 776.0], [1185.0, 776.0], [1183.0, 1029.0], [1155.0, 1029.0]]], "lines": ["ええ去年登山部で", "伊豆登山に行った時"]}, {"box": [487, 466, 705, 645], "vertical": false, "font_size": 33.5, "lines_coords": [[[487.0, 598.0], [686.0, 466.0], [705.0, 496.0], [508.0, 628.0]], [[547.0, 618.0], [637.0, 562.0], [654.0, 588.0], [564.0, 645.0]]], "lines": ["ｗｅｂ．２．３７６円は", "それが正直な"]}, {"box": [140, 453, 213, 640], "vertical": true, "font_size": 34, "lines_coords": [[[172.0, 453.0], [213.0, 453.0], [213.0, 553.0], [172.0, 553.0]], [[140.0, 455.0], [166.0, 455.0], [166.0, 639.0], [140.0, 639.0]]], "lines": ["ご存知", "なんですか？"]}, {"box": [1061, 879, 1128, 1136], "vertical": true, "font_size": 29, "lines_coords": [[[1093.0, 879.0], [1125.0, 879.0], [1128.0, 1110.0], [1096.0, 1110.0]], [[1061.0, 883.0], [1087.0, 883.0], [1087.0, 1136.0], [1061.0, 1136.0]]], "lines": ["地元の酒屋さんで", "勧められたんですよ"]}, {"box": [1140, 1230, 1213, 1543], "vertical": true, "font_size": 32, "lines_coords": [[[1181.0, 1231.0], [1213.0, 1231.0], [1213.0, 1543.0], [1181.0, 1543.0]], [[1141.0, 1230.0], [1173.0, 1230.0], [1171.0, 1451.0], [1140.0, 1451.0]]], "lines": ["伊豆はいいですよねぇ", "海も山もあるし"]}, {"box": [473, 1195, 538, 1497], "vertical": true, "font_size": 26, "lines_coords": [[[510.0, 1198.0], [536.0, 1198.0], [536.0, 1378.0], [510.0, 1378.0]]], "lines": ["そうだ。部活で"]}, {"box": [470, 1196, 502,