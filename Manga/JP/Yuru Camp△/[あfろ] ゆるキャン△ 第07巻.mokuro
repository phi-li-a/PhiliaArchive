es": ["浜松とか伊那とか行ってたから", "めちゃ近所に感じる"]}, {"box": [318, 1599, 639, 1670], "vertical": false, "font_size": 36, "lines_coords": [[[320.0, 1599.0], [639.0, 1601.0], [639.0, 1635.0], [320.0, 1633.0]], [[318.0, 1633.0], [590.0, 1629.0], [590.0, 1666.0], [318.0, 1670.0]]], "lines": ["そういえば前に「カド街」で", "早川町特集されてたよ"]}, {"box": [400, 1721, 536, 1750], "vertical": false, "font_size": 26, "lines_coords": [[[405.0, 1723.0], [528.0, 1723.0], [528.0, 1749.0], [405.0, 1749.0]]], "lines": ["そうなの？"]}], "img_path": "00046.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [817, 458, 1189, 523], "vertical": false, "font_size": 25, "lines_coords": [[[823.0, 461.0], [1186.0, 461.0], [1186.0, 485.0], [823.0, 485.0]], [[821.0, 495.0], [1162.0, 495.0], [1162.0, 521.0], [821.0, 521.0]]], "lines": ["「世界一古い宿」って認定された", "温泉旅館とかあるんだってさ"]}, {"box": [765, 703, 1106, 769], "vertical": false, "font_size": 26, "lines_coords": [[[770.0, 708.0], [1081.0, 708.0], [1081.0, 735.0], [770.0, 735.0]], [[772.0, 742.0], [1106.0, 742.0], [1106.0, 766.0], [772.0, 766.0]]], "lines": ["とりあえず今日は奥山梨の", "一番奥まで行ってみるつもり"]}, {"box": [1036, 901, 1089, 931], "vertical": false, "font_size": 30, "lines_coords": [[[1036.0, 901.0], [1089.0, 901.0], [1089.0, 931.0], [1036.0, 931.0]]], "lines": ["うい"]}, {"box": [845, 821, 1145, 852], "vertical": false, "font_size": 25, "lines_coords": [[[845.0, 826.0], [1136.0, 826.0], [1136.0, 851.0], [845.0, 851.0]]], "lines": ["頑張るなぁ、気をつけなよ"]}, {"box": [805, 1163, 1173, 1191], "vertical": false, "font_size": 24, "lines_coords": [[[806.0, 1164.0], [1173.0, 1164.0], [1173.0, 1188.0], [806.0, 1188.0]]], "lines": ["あ、私そろそろバイト行く時間だから"]}, {"box": [800, 1236, 1114, 1267], "vertical": false, "font_size": 24, "lines_coords": [[[800.0, 1237.0], [1104.0, 1241.0], [1104.0, 1265.0], [800.0, 1261.0]]], "lines": ["ん？音藤バイト始めたの？"]}, {"box": [825, 1313, 1074, 1346], "vertical": false, "font_size": 32, "lines_coords": [[[826.0, 1314.0], [1050.0, 1314.0], [1050.0, 1346.0], [826.0, 