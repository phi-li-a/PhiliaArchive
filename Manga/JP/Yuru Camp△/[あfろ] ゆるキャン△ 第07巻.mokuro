4.0, 508.0]]], "lines": ["私もお酒を少し", "ごちそうになった訳だし、"]}, {"box": [1132, 616, 1168, 757], "vertical": true, "font_size": 34, "lines_coords": [[[1132.0, 616.0], [1166.0, 616.0], [1166.0, 755.0], [1132.0, 755.0]]], "lines": ["とにかく"]}, {"box": [764, 568, 842, 811], "vertical": true, "font_size": 34, "lines_coords": [[[804.0, 568.0], [841.0, 568.0], [838.0, 778.0], [800.0, 778.0]], [[765.0, 570.0], [796.0, 570.0], [796.0, 810.0], [765.0, 810.0]]], "lines": ["大垣さん達も", "お世話になって"]}, {"box": [476, 720, 659, 795], "vertical": false, "font_size": 32, "lines_coords": [[[481.0, 721.0], [581.0, 721.0], [581.0, 753.0], [481.0, 753.0]], [[478.0, 757.0], [652.0, 761.0], [652.0, 793.0], [478.0, 789.0]]], "lines": ["メ少し", "つがぶがぶ"]}, {"box": [1144, 1119, 1212, 1447], "vertical": true, "font_size": 27, "lines_coords": [[[1183.0, 1119.0], [1211.0, 1119.0], [1209.0, 1417.0], [1181.0, 1417.0]], [[1145.0, 1121.0], [1171.0, 1121.0], [1171.0, 1447.0], [1145.0, 1447.0]]], "lines": ["近いうちに何かお礼を", "しなければいけないわね"]}, {"box": [676, 870, 740, 1209], "vertical": true, "font_size": 26, "lines_coords": [[[712.0, 871.0], [738.0, 871.0], [738.0, 1181.0], [712.0, 1181.0]], [[676.0, 871.0], [703.0, 871.0], [703.0, 1209.0], [676.0, 1209.0]]], "lines": ["伊東へお越しの際はぜひ", "うちの店に寄って下さいね"]}, {"box": [133, 935, 200, 1335], "vertical": true, "font_size": 29, "lines_coords": [[[166.0, 935.0], [198.0, 935.0], [196.0, 1335.0], [165.0, 1335.0]], [[135.0, 937.0], [161.0, 937.0], [159.0, 1192.0], [133.0, 1192.0]]], "lines": ["先生が気に入った伊豆の地酒も", "取り扱ってるでよ！！"]}, {"box": [851, 1509, 917, 1755], "vertical": true, "font_size": 30, "lines_coords": [[[888.0, 1513.0], [915.0, 1513.0], [915.0, 1702.0], [888.0, 1702.0]], [[853.0, 1509.0], [885.0, 1509.0], [883.0, 1755.0], [851.0, 1755.0]]], "lines": ["遠くはないけど", "近くもないのよねぇ"]}], "img_path": "00023.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1151, 138, 1219, 326], "vertical": true, "font_size": 26, "lines_coords": [[[1188.0, 138.0], [1215.0, 138.0]