_height": 1920, "blocks": [{"box": [1122, 159, 1199, 783], "vertical": true, "font_size": 64, "lines_coords": [[[1126.0, 159.0], [1190.0, 159.0], [1190.0, 783.0], [1126.0, 783.0]]], "lines": ["外で食事をするとうまい"]}, {"box": [123, 65, 506, 99], "vertical": false, "font_size": 32, "lines_coords": [[[123.0, 67.0], [506.0, 65.0], [506.0, 97.0], [123.0, 99.0]]], "lines": ["株課後５２州メシうまい"]}, {"box": [189, 146, 333, 873], "vertical": true, "font_size": 74, "lines_coords": [[[251.0, 146.0], [328.0, 146.0], [333.0, 873.0], [256.0, 873.0]], [[195.0, 150.0], [266.0, 150.0], [260.0, 768.0], [189.0, 768.0]]], "lines": ["誰しも一度はそう思った事が", "あるのではないだろうか"]}, {"box": [1117, 1000, 1221, 1576], "vertical": true, "font_size": 47, "lines_coords": [[[1175.0, 1006.0], [1218.0, 1006.0], [1218.0, 1573.0], [1175.0, 1573.0]], [[1117.0, 1006.0], [1168.0, 1006.0], [1168.0, 1447.0], [1117.0, 1447.0]]], "lines": ["そもそもなぜ外でとる食事は", "「美味しく」感じるのか"]}, {"box": [730, 993, 838, 1710], "vertical": true, "font_size": 44, "lines_coords": [[[789.0, 1005.0], [834.0, 1005.0], [830.0, 1533.0], [785.0, 1533.0]], [[735.0, 1005.0], [778.0, 1005.0], [776.0, 1706.0], [733.0, 1706.0]]], "lines": ["それは昔から人類が「外」を", "危険な場所と感じてさ来たからである"]}, {"box": [586, 1006, 686, 1355], "vertical": true, "font_size": 42, "lines_coords": [[[641.0, 1006.0], [686.0, 1006.0], [686.0, 1355.0], [641.0, 1355.0]], [[586.0, 1006.0], [626.0, 1006.0], [626.0, 1265.0], [586.0, 1265.0]]], "lines": ["危険な状況でとる", "食事の快感は"]}, {"box": [133, 1242, 239, 1768], "vertical": true, "font_size": 44, "lines_coords": [[[189.0, 1243.0], [232.0, 1243.0], [232.0, 1768.0], [189.0, 1768.0]], [[133.0, 1243.0], [178.0, 1243.0], [178.0, 1683.0], [133.0, 1683.0]]], "lines": ["安全な状況でとる食事より", "大きくなるというのだ"]}], "img_path": "00161.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1158, 170, 1190, 412], "vertical": true, "font_size": 28, "lines_coords": [[[1160.0, 170.0], [1188.0, 170.0], [1186.0, 410.0], [1158.0, 410.0]]], "lines": ["食事中、熊が現れた"]}, {"bo