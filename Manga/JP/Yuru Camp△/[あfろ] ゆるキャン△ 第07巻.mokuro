 570, 667, 661], "vertical": true, "font_size": 41, "lines_coords": [[[626.0, 570.0], [667.0, 570.0], [667.0, 661.0], [626.0, 661.0]]], "lines": ["ま．．．"]}, {"box": [388, 1010, 658, 1044], "vertical": false, "font_size": 24, "lines_coords": [[[388.0, 1010.0], [658.0, 1020.0], [658.0, 1044.0], [388.0, 1035.0]]], "lines": ["この先、高さ制限３４ｋＭ幅員３６Ｍ"]}, {"box": [1046, 920, 1113, 1216], "vertical": true, "font_size": 58, "lines_coords": [[[1046.0, 922.0], [1104.0, 920.0], [1113.0, 1215.0], [1055.0, 1216.0]]], "lines": ["またこれか。"]}, {"box": [508, 1438, 603, 1462], "vertical": false, "font_size": 23, "lines_coords": [[[510.0, 1439.0], [601.0, 1439.0], [601.0, 1464.0], [510.0, 1464.0]]], "lines": ["冬季閉鎖中"]}], "img_path": "00080.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [], "img_path": "00081.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [], "img_path": "00082.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1134, 200, 1169, 421], "vertical": true, "font_size": 32, "lines_coords": [[[1134.0, 200.0], [1166.0, 200.0], [1168.0, 421.0], [1136.0, 421.0]]], "lines": ["また通行止め："]}, {"box": [1132, 811, 1167, 971], "vertical": true, "font_size": 34, "lines_coords": [[[1132.0, 811.0], [1166.0, 811.0], [1166.0, 971.0], [1132.0, 971.0]]], "lines": ["．．．なんてね"]}, {"box": [202, 791, 279, 956], "vertical": true, "font_size": 36, "lines_coords": [[[236.0, 791.0], [275.0, 791.0], [279.0, 956.0], [240.0, 956.0]], [[206.0, 795.0], [240.0, 795.0], [236.0, 954.0], [202.0, 954.0]]], "lines": ["昨日調べて", "知ってたし"]}, {"box": [1117, 1245, 1186, 1447], "vertical": true, "font_size": 32, "lines_coords": [[[1153.0, 1245.0], [1185.0, 1245.0], [1185.0, 1363.0], [1153.0, 1363.0]], [[1119.0, 1245.0], [1151.0, 1245.0], [1149.0, 1447.0], [1117.0, 1447.0]]], "lines": ["確かこの", "トンネルの先が"]}, {"box": [525, 1490, 589, 1734], "vertical": true, "font_size": 26, "lines_coords": [[[560.0, 1494.0], [586.0, 1494.0], [586.0, 1627.0