 286.0]], [[740.0, 127.0], [765.0, 127.0], [765.0, 391.0], [740.0, 391.0]]], "lines": ["よかったよー", "富士宮観光もできたし、"]}, {"box": [620, 148, 689, 429], "vertical": true, "font_size": 29, "lines_coords": [[[654.0, 148.0], [686.0, 148.0], [686.0, 427.0], [654.0, 427.0]], [[620.0, 151.0], [646.0, 151.0], [646.0, 397.0], [620.0, 397.0]]], "lines": ["キャンプ場も夜景が", "キレイなとこでね"]}, {"box": [125, 142, 196, 425], "vertical": true, "font_size": 29, "lines_coords": [[[165.0, 142.0], [196.0, 142.0], [193.0, 425.0], [161.0, 425.0]], [[125.0, 144.0], [151.0, 144.0], [151.0, 391.0], [125.0, 391.0]]], "lines": ["晩ごはんもなかなか", "うまくできたんだ"]}, {"box": [127, 508, 195, 711], "vertical": true, "font_size": 29, "lines_coords": [[[163.0, 510.0], [195.0, 510.0], [195.0, 660.0], [163.0, 660.0]], [[127.0, 508.0], [153.0, 508.0], [153.0, 710.0], [127.0, 710.0]]], "lines": ["ホイル焼き", "うまそうやなぁ"]}, {"box": [1126, 791, 1189, 1156], "vertical": true, "font_size": 26, "lines_coords": [[[1160.0, 793.0], [1186.0, 793.0], [1186.0, 1156.0], [1160.0, 1156.0]], [[1126.0, 791.0], [1153.0, 791.0], [1153.0, 1070.0], [1126.0, 1070.0]]], "lines": ["でもごはん食べ終わってから", "ちょっと暇だったかな"]}, {"box": [937, 943, 1008, 1143], "vertical": true, "font_size": 32, "lines_coords": [[[976.0, 943.0], [1008.0, 943.0], [1005.0, 1115.0], [973.0, 1115.0]], [[941.0, 943.0], [973.0, 943.0], [969.0, 1143.0], [937.0, 1143.0]]], "lines": ["キャンプ場が", "園外だったから"]}, {"box": [972, 1311, 1003, 1427], "vertical": true, "font_size": 31, "lines_coords": [[[972.0, 1311.0], [1003.0, 1311.0], [1003.0, 1427.0], [972.0, 1427.0]]], "lines": ["うへへ"]}, {"box": [127, 817, 226, 1127], "vertical": true, "font_size": 28, "lines_coords": [[[193.0, 817.0], [226.0, 817.0], [226.0, 905.0], [193.0, 905.0]], [[159.0, 817.0], [185.0, 817.0], [189.0, 1098.0], [163.0, 1098.0]], [[127.0, 819.0], [153.0, 819.0], [153.0, 1126.0], [127.0, 1126.0]]], "lines": ["だから", "景色見ながらボーッと", "考え事してたんだけど．．．"]}, {"box": [1116, 1333, 1179, 1731], "vertical": true, "font_size": 26, "lines_coords": [[[1149.0, 1335.0], [1175.0, 1335.0], [1175.0, 1616.0], [1149.0, 1616.0]], [[1117.0, 1336.0], [1143.0, 1336.0], [1143.0, 1730.0], [1117.0, 1730.0]]], "lines": ["そしたらまたみんなと", "キャンプ行きたくなっちゃった"]}, {"box": [198, 1574, 234, 1720], "vertical": true, "font_size": 32, "lines_coords": [[[198.0, 1575.0], [230.0, 1575.0], [230.0, 1719.0], [198.0, 1719.0]]], "lines": ["そっかぁ"]}], "img_path": "00136.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1153, 135, 1215, 408], "vertical": true, "font_size": 28, "lines_coords": [[[1188.0, 135.0], [1215.0, 135.0], [1215.0, 408.0], [1188.0, 408.0]], [[1153.0, 135.0], [1179.0, 135.0], [1179.0, 298.0], [1153.0, 298.0]]], "lines": ["これからはソロキャン", "とグルキャン"]}, {"box": [1053, 189, 1117, 474], "vertical": true, "font_size": 28, "lines_coords": [[[1085.0, 191.0], [1117.0, 191.0], [1117.0, 474.0], [1085.0, 474.0]], [[1053.0, 189.0], [1080.0, 189.0], [1080.0, 303.0], [1053.0, 303.0]]], "lines": ["交互にやってきたいと", "思います"]}, {"box": [168, 168, 233, 418], "vertical": true, "font_size": 26, "lines_coords": [[[204.0, 168.0], [230.0, 168.0], [230.0, 416.0], [204.0, 416.0]], [[168.0, 168.0], [195.0, 168.0], [195.0, 281.0], [168.0, 281.0]]], "lines": ["なら次はグルキャン", "せなな～"]}, {"box": [1076, 555, 1209, 838], "vertical": true, "font_size": 28, "lines_coords": [[[1177.0, 555.0], [1209.0, 555.0], [1209.0, 838.0], [1177.0, 838.0]], [[1143.0, 555.0], [1170.0, 555.0], [1170.0, 806.0], [1143.0, 806.0]], [[1111.0, 556.0], [1138.0, 556.0], [1138.0, 723.0], [1111.0, 723.0]], [[1076.0, 556.0], [1102.0, 556.0], [1102.0, 695.0], [1076.0, 695.0]]], "lines": ["そういえばあきちゃん", "すごい発見したって", "言ってたけど", "何だろね？"]}, {"box": [755, 533, 852, 755], "vertical": true, "font_size": 26, "lines_coords": [[[825.0, 534.0], [851.0, 534.0], [851.0, 701.0], [825.0, 701.0]], [[789.0, 534.0], [815.0, 534.0], [815.0, 755.0], [789.0, 755.0]], [[755.0, 534.0], [781.0, 534.0], [781.0, 645.0], [755.0, 645.0]]], "lines": ["あきの事やし", "大げさに言っとる", "だけやろ"]}, {"box": [586, 643, 661, 781], "vertical": true, "font_size": 34, "lines_coords": [[[628.0, 643.0], [661.0, 643.0], [661.0, 748.0], [628.0, 748.0]], [[586.0, 643.0], [620.0, 643.0], [620.0, 781.0], [586.0, 781.0]]], "lines": ["あきー", "来たでー"]}], "img_path": "00137.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [662, 233, 704, 521], "vertical": true, "font_size": 40, "lines_coords": [[[663.0, 234.0], [703.0, 234.0], [703.0, 521.0], [663.0, 521.0]]], "lines": ["薪の無料配布？"]}, {"box": [1218, 654, 1302, 1031], "vertical": true, "font_size": 38, "lines_coords": [[[1263.0, 654.0], [1301.0, 654.0], [1301.0, 1031.0], [1263.0, 1031.0]], [[1218.0, 654.0], [1256.0, 654.0], [1256.0, 995.0], [1218.0, 995.0]]], "lines": ["なんと軽トラ一台分も", "妄莉がもらえるそうだ"]}, {"box": [646, 648, 717, 1068], "vertical": true, "font_size": 28, "lines_coords": [[[682.0, 648.0], [714.0, 648.0], [716.0, 1021.0], [684.0, 1021.0]], [[648.0, 648.0], [673.0, 648.0], [673.0, 1068.0], [648.0, 1068.0]]], "lines": ["ただより高い物はないって", "よく言うよ？騙されてない？"]}, {"box": [145, 650, 214, 992], "vertical": true, "font_size": 29, "lines_coords": [[[181.0, 652.0], [213.0, 652.0], [213.0, 840.0], [181.0, 840.0]], [[146.0, 650.0], [172.0, 650.0], [172.0, 991.0], [146.0, 991.0]]], "lines": ["おばあちゃん", "詐欺にあったんと違う？"]}, {"box": [776, 1098, 860, 1363], "vertical": true, "font_size": 37, "lines_coords": [[[821.0, 1098.0], [858.0, 1098.0], [858.0, 1325.0], [821.0, 1325.0]], [[776.0, 1098.0], [813.0, 1098.0], [813.0, 1363.0], [776.0, 1363.0]]], "lines": ["それに行って", "来ようと思う！！"]}, {"box": [153, 1117, 251, 1387], "vertical": true, "font_size": 49, "lines_coords": [[[193.0, 1117.0], [251.0, 1117.0], [251.0, 1213.0], [193.0, 1213.0]], [[153.0, 1125.0], [193.0, 1125.0], [193.0, 1387.0], [153.0, 1387.0]]], "lines": ["誰が", "ばあちゃんだ。"]}, {"box": [1087, 1453, 1253, 1696], "vertical": true, "font_size": 35, "lines_coords": [[[1215.0, 1453.0], [1252.0, 1453.0], [1252.0, 1695.0], [1215.0, 1695.0]], [[1173.0, 1453.0], [1211.0, 1453.0], [1207.0, 1696.0], [1170.0, 1696.0]], [[1130.0, 1456.0], [1162.0, 1456.0], [1162.0, 1693.0], [1130.0, 1693.0]], [[1087.0, 1455.0], [1119.0, 1455.0], [1119.0, 1661.0], [1087.0, 1661.0]]], "lines": ["県が川の整備で", "切った木を毎年", "無料配布してる", "らしいんだよ"]}, {"box": [330, 1462, 1027, 1545], "vertical": false, "font_size": 68, "lines_coords": [[[337.0, 1477.0], [528.0, 1462.0], [534.0, 1530.0], [343.0, 1545.0]]], "lines": ["いろいろ"]}, {"box": [161, 1614, 1014, 1651], "vertical": false, "font_size": 37, "lines_coords": [[[161.0, 1614.0], [1014.0, 1614.0], [1014.0, 1651.0], [161.0, 1651.0]]], "lines": ["】河川内において依採した木を無料で差し上げます。"]}, {"box": [189, 1687, 898, 1760], "vertical": false, "font_size": 25.0, "lines_coords": [[[189.0, 1687.0], [429.0, 1687.0], [429.0, 1713.0], [189.0, 1713.0]], [[193.0, 1736.0], [898.0, 1736.0], [898.0, 1760.0], [193.0, 1760.0]]], "lines": ["膿配布場所・期間", "１．富士川上流出張所【山梨県韮崎市・栄二丁目"]}], "img_path": "00138.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1155, 127, 1223, 572], "vertical": true, "font_size": 26, "lines_coords": [[[1192.0, 127.0], [1218.0, 127.0], [1218.0, 511.0], [1192.0, 511.0]], [[1155.0, 127.0], [1181.0, 127.0], [1181.0, 570.0], [1155.0, 570.0]]], "lines": ["河川の岸や中小に伸びた木を", "放置すると台風なとて増水した時"]}, {"box": [701, 129, 773, 631], "vertical": true, "font_size": 29, "lines_coords": [[[742.0, 131.0], [768.0, 131.0], [768.0, 630.0], [742.0, 630.0]], [[701.0, 129.0], [733.0, 129.0], [733.0, 631.0], [701.0, 631.0]]], "lines": ["川の流れが変わり氾濫してしまうので", "毎年定期的に依探する必要があります。"]}, {"box": [594, 148, 662, 449], "vertical": true, "font_size": 26, "lines_coords": [[[633.0, 150.0], [660.0, 150.0], [660.0, 446.0], [633.0, 446.0]], [[594.0, 148.0], [620.0, 148.0], [620.0, 384.0], [594.0, 384.0]]], "lines": ["伐採木は処分するにも", "費用がかかるため"]}, {"box": [459, 142, 553, 202], "vertical": false, "font_size": 34, "lines_coords": [[[459.0, 142.0], [534.0, 142.0], [534.0, 176.0], [459.0, 176.0]], [[463.0, 168.0], [553.0, 168.0], [553.0, 202.0], [463.0, 202.0]]], "lines": ["処分料", "５千万な"]}, {"box": [136, 146, 242, 476], "vertical": true, "font_size": 30, "lines_coords": [[[210.0, 148.0], [241.0, 148.0], [241.0, 418.0], [210.0, 418.0]], [[172.0, 146.0], [204.0, 146.0], [202.0, 476.0], [170.0, 476.0]], [[136.0, 151.0], [163.0, 151.0], [163.0, 418.0], [136.0, 418.0]]], "lines": ["県の河川事務所では", "家庭で消費する薪として", "配布しているのです。"]}, {"box": [1052, 778, 1159, 1031], "vertical": true, "font_size": 28, "lines_coords": [[[1130.0, 781.0], [1156.0, 781.0], [1156.0, 999.0], [1130.0, 999.0]], [[1089.0, 778.0], [1121.0, 778.0], [1121.0, 1031.0], [1089.0, 1031.0]], [[1053.0, 780.0], [1080.0, 780.0], [1080.0, 937.0], [1053.0, 937.0]]], "lines": ["じゃあ配る方も", "貰う方もどっちも", "得って訳や"]}, {"box": [335, 560, 395, 613], "vertical": false, "font_size": 28.5, "lines_coords": [[[339.0, 560.0], [390.0, 560.0], [390.0, 579.0], [339.0, 579.0]], [[335.0, 575.0], [395.0, 575.0], [395.0, 613.0], [335.0, 613.0]]], "lines": ["産地道は", "まさに朝"]}, {"box": [159, 535, 226, 598], "vertical": true, "font_size": 41, "lines_coords": [[[185.0, 536.0], [226.0, 536.0], [226.0, 598.0], [185.0, 598.0]]], "lines": ["へえ"]}, {"box": [1149, 1256, 1215, 1537], "vertical": true, "font_size": 26, "lines_coords": [[[1186.0, 1260.0], [1213.0, 1260.0], [1213.0, 1481.0], [1186.0, 1481.0]], [[1149.0, 1256.0], [1175.0, 1256.0], [1175.0, 1535.0], [1149.0, 1535.0]]], "lines": ["んで今年の配布が", "今日かららしいんだよ"]}, {"box": [800, 1284, 858, 1498], "vertical": true, "font_size": 26, "lines_coords": [[[834.0, 1284.0], [858.0, 1284.0], [858.0, 1470.0], [834.0, 1470.0]], [[800.0, 1284.0], [826.0, 1284.0], [826.0, 1498.0], [800.0, 1498.0]]], "lines": ["そういう事なら", "貰いに行かななー"]}, {"box": [196, 935, 270, 1072], "vertical": true, "font_size": 33, "lines_coords": [[[236.0, 935.0], [270.0, 935.0], [270.0, 1070.0], [236.0, 1070.0]], [[196.0, 935.0], [228.0, 935.0], [228.0, 1072.0], [196.0, 1072.0]]], "lines": ["そういう", "ことだな"]}, {"box": [174, 1235, 240, 1490], "vertical": true, "font_size": 29, "lines_coords": [[[208.0, 1235.0], [240.0, 1235.0], [240.0, 1490.0], [208.0, 1490.0]], [[174.0, 1239.0], [200.0, 1239.0], [200.0, 1488.0], [174.0, 1488.0]]], "lines": ["軽トラ一杯の薪って", "いくらするのかな？"]}, {"box": [740, 1500, 800, 1713], "vertical": true, "font_size": 26, "lines_coords": [[[774.0, 1500.0], [800.0, 1500.0], [800.0, 1713.0], [774.0, 1713.0]], [[740.0, 1501.0], [766.0, 1501.0], [766.0, 1685.0], [740.0, 1685.0]]], "lines": ["キャンプの薪代も", "バカにならんし"]}, {"box": [639, 1406, 668, 1631], "vertical": true, "font_size": 24, "lines_coords": [[[639.0, 1406.0], [663.0, 1406.0], [663.0, 1629.0], [639.0, 1629.0]]], "lines": ["ねぇあおいちゃん"]}, {"box": [178, 1614, 210, 1728], "vertical": true, "font_size": 32, "lines_coords": [[[178.0, 1614.0], [210.0, 1614.0], [210.0, 1728.0], [178.0, 1728.0]]], "lines": ["せやなぁ"]}], "img_path": "00139.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1140, 129, 1206, 496], "vertical": true, "font_size": 27, "lines_coords": [[[1173.0, 129.0], [1201.0, 129.0], [1203.0, 495.0], [1175.0, 495.0]], [[1140.0, 129.0], [1166.0, 129.0], [1168.0, 425.0], [1141.0, 425.0]]], "lines": ["軽トラの荷台サイズからして", "積めるのはこんくらい。"]}, {"box": [922, 108, 1098, 251], "vertical": false, "font_size": 135, "lines_coords": [[[928.0, 108.0], [1098.0, 116.0], [1093.0, 251.0], [922.0, 243.0]]], "lines": ["長さ１９ｍ大さ２５ｃｍのおじさんらい"]}, {"box": [601, 138, 668, 480], "vertical": true, "font_size": 32, "lines_coords": [[[633.0, 138.0], [665.0, 138.0], [665.0, 397.0], [633.0, 397.0]], [[601.0, 140.0], [633.0, 140.0], [633.0, 480.0], [601.0, 480.0]]], "lines": ["薪一束４０ｍ位やから", "木一本から新５束は作れる"]}, {"box": [140, 174, 210, 431], "vertical": true, "font_size": 32, "lines_coords": [[[178.0, 176.0], [210.0, 176.0], [210.0, 375.0], [178.0, 375.0]], [[142.0, 174.0], [174.0, 174.0], [172.0, 431.0], [140.0, 431.0]]], "lines": ["一束５００円として", "１５Ｘ５ｘ５００で―．．．"]}, {"box": [733, 493, 768, 558], "vertical": true, "font_size": 35, "lines_coords": [[[733.0, 493.0], [768.0, 493.0], [768.0, 558.0], [733.0, 558.0]]], "lines": ["うん"]}, {"bo