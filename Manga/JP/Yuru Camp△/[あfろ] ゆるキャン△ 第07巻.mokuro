], [594.0, 1576.0], [568.0, 1576.0]], [[534.0, 1237.0], [560.0, 1237.0], [560.0, 1466.0], [534.0, 1466.0]]], "lines": ["でも今は台風で道が崩れて", "工事中らしいから"]}, {"box": [1136, 1220, 1226, 1732], "vertical": true, "font_size": 37, "lines_coords": [[[1181.0, 1222.0], [1218.0, 1222.0], [1218.0, 1732.0], [1181.0, 1732.0]], [[1136.0, 1220.0], [1173.0, 1220.0], [1173.0, 1567.0], [1136.0, 1567.0]]], "lines": ["県境にある標高ＷＥＢの山伏峠は", "登山スポットでもあり"]}, {"box": [641, 1219, 733, 1736], "vertical": true, "font_size": 40, "lines_coords": [[[686.0, 1220.0], [729.0, 1220.0], [729.0, 1736.0], [686.0, 1736.0]], [[646.0, 1222.0], [684.0, 1222.0], [684.0, 1543.0], [646.0, 1543.0]]], "lines": ["頂上からは富士山や南アルフスを", "望むことができます"]}, {"box": [129, 1590, 196, 1790], "vertical": true, "font_size": 26, "lines_coords": [[[166.0, 1590.0], [193.0, 1590.0], [193.0, 1734.0], [166.0, 1734.0]], [[129.0, 1590.0], [155.0, 1590.0], [155.0, 1790.0], [129.0, 1790.0]]], "lines": ["開通したら", "通ってみたいな"]}], "img_path": "00091.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1147, 179, 1188, 222], "vertical": true, "font_size": 41, "lines_coords": [[[1147.0, 179.0], [1188.0, 179.0], [1188.0, 222.0], [1147.0, 222.0]]], "lines": ["む"]}, {"box": [571, 800, 647, 1021], "vertical": true, "font_size": 32, "lines_coords": [[[615.0, 800.0], [646.0, 800.0], [646.0, 961.0], [615.0, 961.0]], [[575.0, 800.0], [609.0, 800.0], [605.0, 1021.0], [571.0, 1021.0]]], "lines": ["思ったより", "しっかりしてる"]}, {"box": [169, 453, 207, 605], "vertical": true, "font_size": 34, "lines_coords": [[[170.0, 455.0], [204.0, 455.0], [204.0, 605.0], [170.0, 605.0]]], "lines": ["吊り橋だ"]}, {"box": [1231, 851, 1303, 1202], "vertical": true, "font_size": 32, "lines_coords": [[[1267.0, 851.0], [1299.0, 851.0], [1303.0, 1201.0], [1271.0, 1201.0]], [[1231.0, 855.0], [1263.0, 855.0], [1263.0, 1076.0], [1231.0, 1076.0]]], "lines": ["そういえば奈良田湖にも", "架かってたよな"]}], "img_path": "00092.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1044, 215, 1081, 390], "vertical": true, "font_size": 32, "lines_coords": [[[1048.0, 215.0], [1080.0, 215.0], [1076.0, 390.0], [1044.0, 390.0]]], "lines": ["おおおぉお"]}, {"box": [240, 358, 319, 532], "vertical": true, "font_size": 30, "lines_coords": [[[281.0, 358.0], [315.0, 358.0], [315.0, 498.0], [281.0, 498.0]], [[243.0, 361.0], [270.0, 361.0], [270.0, 530.0], [243.0, 530.0]]], "lines": ["真ん中は", "ゆれるるる"]}, {"box": [1158, 751, 1192, 879], "vertical": true, "font_size": 34, "lines_coords": [[[1158.0, 753.0], [1192.0, 753.0], [1192.0, 877.0], [1158.0, 877.0]]], "lines": ["けもの道"]}, {"box": [737, 748, 811, 1096], "vertical": true, "font_size": 35, "lines_coords": [[[774.0, 748.0], [811.0, 748.0], [808.0, 1096.0], [770.0, 1096.0]], [[738.0, 750.0], [770.0, 750.0], [770.0, 1065.0], [738.0, 1065.0]]], "lines": ["って渡った先の道の方が", "もっとヤバそうじゃん"]}, {"box": [589, 720, 618, 917], "vertical": true, "font_size": 26, "lines_coords": [[[590.0, 721.0], [616.0, 721.0], [616.0, 916.0], [590.0, 916.0]]], "lines": ["戻って温泉行こ"]}, {"box": [348, 1246, 378, 1329], "vertical": true, "font_size": 27, "lines_coords": [[[348.0, 1248.0], [375.0, 1246.0], [378.0, 1327.0], [352.0, 1329.0]]], "lines": ["おむおお"]}], "img_path": "00093.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [799, 802, 875, 964], "vertical": true, "font_size": 38, "lines_coords": [[[832.0, 802.0], [875.0, 802.0], [875.0, 892.0], [832.0, 892.0]], [[800.0, 806.0], [832.0, 806.0], [832.0, 963.0], [800.0, 963.0]]], "lines": ["鹿熊", "イノシシ．．．"]}, {"box": [147, 719, 208, 1038], "vertical": true, "font_size": 25, "lines_coords": [[[180.0, 720.0], [206.0, 720.0], [206.0, 933.0], [180.0, 933.0]], [[148.0, 720.0], [172.0, 720.0], [172.0, 1038.0], [148.0, 1038.0]]], "lines": ["鹿はクセが無くて", "食べやすいって聞くわよね"]}], "img_path": "00094.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1115, 194, 1201, 573], "vertical": true, "font_size": 38, "lines_coords": [[[1162.0, 196.0], [1200.0, 196.0], [1200.0, 386.0], [1162.0, 386.0]], [[1115.0, 196.0], [1153.0, 196.0], [1153.0, 573.0], [1115.0, 573.0]]], "lines": ["高級中華の", "「熊の手の煮込み」って"]}, {"box": [159, 198, 249, 501], "vertical": true, "font_size": 41, "lines_coords": [[[204.0, 198.0], [249.0, 198.0], [249.0, 431.0], [204.0, 431.0]], [[159.0, 200.0], [196.0, 200.0], [196.0, 500.0], [159.0, 500.0]]], "lines": ["考えて見れば", "あれもジビエよね"]}, {"box": [1080, 826, 1193, 1111], "vertical": true, "font_size": 32, "lines_coords": [[[1158.0, 826.0], [1192.0, 826.0], [1190.0, 1111.0], [1156.0, 1111.0]], [[1121.0, 830.0], [1153.0, 830.0], [1153.0, 1018.0], [1121.0, 1018.0]], [[1080.0, 830.0], [1111.0, 830.0], [1113.0, 1108.0], [1081.0, 1108.0]]], "lines": ["オーナーが狩猟した", "ジビエを直売", "しているようだけど"]}, {"box": [1140, 1200, 1205, 1426], "vertical": true, "font_size": 26, "lines_coords": [[[1175.0, 1201.0], [1201.0, 1201.0], [1201.0, 1372.0], [1175.0, 1372.0]], [[1140.0, 1200.0], [1166.0, 1200.0], [1166.0, 1426.0], [1140.0, 1426.0]]], "lines": ["そもそも家で", "作れるレシピか："]}, {"box": [632, 1186, 661, 1389], "vertical": true, "font_size": 25, "lines_coords": [[[633.0, 1186.0], [658.0, 1186.0], [658.0, 1385.0], [633.0, 1385.0]]], "lines": ["熊の手の意込み"]}, {"box": [539, 1164, 604, 1622], "vertical": true, "font_size": 26, "lines_coords": [[[575.0, 1168.0], [601.0, 1168.0], [601.0, 1545.0], [575.0, 1545.0]], [[540.0, 1164.0], [566.0, 1164.0], [566.0, 1612.0], [540.0, 1612.0]]], "lines": ["まず館の手を生姜、葱と一緒に", "４〜５時間煮込んで具みを抜きます"]}, {"box": [199, 829, 271, 1110], "vertical": true, "font_size": 29, "lines_coords": [[[238.0, 830.0], [270.0, 830.0], [270.0, 1020.0], [238.0, 1020.0]], [[200.0, 832.0], [226.0, 832.0], [226.0, 1110.0], [200.0, 1110.0]]], "lines": ["熊の手は販売", "してないのかしら？"]}, {"box": [885, 1706, 1132, 1738], "vertical": false, "font_size": 32, "lines_coords": [[[885.0, 1706.0], [1126.0, 1706.0], [1126.0, 1738.0], [885.0, 1738.0]]], "lines": ["熊の手「煮込み」レシピ"]}, {"box": [757, 1707, 828, 1736], "vertical": false, "font_size": 28, "lines_coords": [[[757.0, 1708.0], [828.0, 1708.0], [828.0, 1736.0], [757.0, 1736.0]]], "lines": ["Ｑ検索"]}, {"box": [140, 1162, 210, 1790], "vertical": true, "font_size": 32, "lines_coords": [[[174.0, 1162.0], [206.0, 1162.0], [210.0, 1788.0], [178.0, 1788.0]], [[140.0, 1166.0], [172.0, 1166.0], [172.0, 1584.0], [140.0, 1584.0]]], "lines": ["具みが抜けたら毛抜ですべての毛を抜きましょう。", "（この作業は６時間程かかります）"]}], "img_path": "00095.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1128, 131, 1211, 444], "vertical": true, "font_size": 39, "lines_coords": [[[1168.0, 131.0], [1207.0, 131.0], [1211.0, 410.0], [1171.0, 410.0]], [[1128.0, 133.0], [1166.0, 133.0], [1166.0, 444.0], [1128.0, 444.0]]], "lines": ["毛が全て抜けたら", "また４時間程煮込み"]}, {"box": [1076, 285, 1106, 339], "vertical": false, "font_size": 54, "lines_coords": [[[1076.0, 285.0], [1106.0, 285.0], [1106.0, 339.0], [1076.0, 339.0]]], "lines": ["ぐっ"]}, {"box": [633, 120, 722, 763], "vertical": true, "font_size": 32, "lines_coords": [[[678.0, 133.0], [710.0, 133.0], [714.0, 579.0], [682.0, 579.0]], [[635.0, 129.0], [667.0, 129.0], [671.0, 742.0], [639.0, 742.0]]], "lines": ["調理中は室内がかなり獣臭く", "なりますので十分換気を行いましょう"]}, {"box": [135, 127, 215, 513], "vertical": true, "font_size": 32, "lines_coords": [[[181.0, 135.0], [213.0, 135.0], [210.0, 388.0], [178.0, 388.0]], [[135.0, 127.0], [166.0, 127.0], [166.0, 510.0], [135.0, 510.0]]], "lines": ["下ごしらえはここ", "次項から訴理に入ります。"]}, {"box": [761, 328, 845, 750], "vertical": true, "font_size": 38, "lines_coords": [[[800.0, 328.0], [840.0, 328.0], [841.0, 750.0], [802.0, 750.0]], [[761.0, 331.0], [798.0, 331.0], [798.0, 682.0], [761.0, 682.0]]], "lines": ["柔らかくなった所で表皮と", "骨と爪を取り除きます。"]}, {"box": [858, 821, 918, 1014], "vertical": true, "font_size": 26, "lines_coords": [[[892.0, 823.0], [918.0, 823.0], [918.0, 961.0], [892.0, 961.0]], [[858.0, 823.0], [883.0, 823.0], [883.0, 1014.0], [858.0, 1014.0]]], "lines": ["すみません", "この鹿肉下さい"]}, {"box": [173, 591, 191, 653], "vertical": tru