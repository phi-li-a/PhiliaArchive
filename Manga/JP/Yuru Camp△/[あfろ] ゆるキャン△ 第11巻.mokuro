, 1488.0], [275.0, 1488.0], [275.0, 1556.0], [238.0, 1556.0]], [[210.0, 1494.0], [234.0, 1494.0], [234.0, 1717.0], [210.0, 1717.0]]], "lines": ["うん", "見晴らしいいよな"]}], "img_path": "00138.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [804, 774, 825, 867], "vertical": true, "font_size": 21, "lines_coords": [[[804.0, 776.0], [825.0, 776.0], [825.0, 830.0], [804.0, 830.0]]], "lines": ["どうも"]}, {"box": [664, 758, 679, 830], "vertical": true, "font_size": 15, "lines_coords": [[[664.0, 758.0], [679.0, 758.0], [679.0, 830.0], [664.0, 830.0]]], "lines": ["どうもー"]}, {"box": [1144, 1224, 1207, 1597], "vertical": true, "font_size": 26, "lines_coords": [[[1179.0, 1228.0], [1205.0, 1228.0], [1205.0, 1569.0], [1179.0, 1569.0]], [[1145.0, 1228.0], [1171.0, 1228.0], [1171.0, 1595.0], [1145.0, 1595.0]]], "lines": ["なるほどすれ違いのために", "所々足場が広くなってるんだ。"]}, {"box": [350, 1216, 430, 1567], "vertical": true, "font_size": 79, "lines_coords": [[[350.0, 1218.0], [429.0, 1218.0], [429.0, 1567.0], [350.0, 1567.0]]], "lines": ["すれ違い．．．"]}], "img_path": "00139.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1131, 161, 1200, 568], "vertical": true, "font_size": 29, "lines_coords": [[[1166.0, 161.0], [1198.0, 161.0], [1200.0, 568.0], [1168.0, 568.0]], [[1132.0, 166.0], [1158.0, 166.0], [1158.0, 538.0], [1132.0, 538.0]]], "lines": ["もしも畑薙大吊橋渡ってる時", "向かいから人が来てたら．．．"]}, {"box": [691, 301, 838, 380], "vertical": false, "font_size": 49, "lines_coords": [[[703.0, 301.0], [838.0, 333.0], [826.0, 380.0], [691.0, 348.0]]], "lines": ["さて、"]}, {"box": [330, 316, 1023, 553], "vertical": false, "font_size": 192, "lines_coords": [[[330.0, 361.0], [1010.0, 316.0], [1023.0, 508.0], [343.0, 553.0]]], "lines": ["９ＡＭＥ．ＯＶＦＰ"]}, {"box": [148, 130, 219, 470], "vertical": true, "font_size": 32, "lines_coords": [[[181.0, 131.0], [219.0, 131.0], [219.0, 442.0], [181.0, 442.0]], [[148.0, 131.0], [174.0, 131.0], [174.0, 470.0], [148.0, 470.0]]], "lines": ["二人とも畑薙大吊橋が", "トラウマになってない？"]}, {"box": [988, 890, 1145, 1145], "vertical": true, "font_size": 62.5, "lines_coords": [[[1040.0, 903.0], [1100.0, 890.0], [1145.0, 1098.0], [1085.0, 1111.0]], [[988.0, 939.0], [1050.0, 922.0], [1108.0, 1128.0], [1046.0, 1145.0]]], "lines": ["ただただだだ", "だからねだ"]}], "img_path": "00140.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1138, 811, 1203, 1061], "vertical": true, "font_size": 27, "lines_coords": [[[1175.0, 811.0], [1203.0, 811.0], [1200.0, 982.0], [1171.0, 982.0]], [[1138.0, 813.0], [1164.0, 813.0], [1166.0, 1061.0], [1140.0, 1061.0]]], "lines": ["ちょっとー！！", "走ると危ないぞーっ"]}, {"box": [643, 665, 675, 791], "vertical": true, "font_size": 32, "lines_coords": [[[643.0, 665.0], [675.0, 665.0], [675.0, 791.0], [643.0, 791.0]]], "lines": ["折り返し"]}, {"box": [907, 1204, 960, 1511], "vertical": true, "font_size": 24, "lines_coords": [[[935.0, 1207.0], [960.0, 1207.0], [960.0, 1370.0], [935.0, 1370.0]], [[907.0, 1205.0], [931.0, 1205.0], [931.0, 1511.0], [907.0, 1511.0]]], "lines": ["あの先を進むと", "キャンプ場があるみたいだよ"]}, {"box": [755, 909, 822, 1120], "vertical": true, "font_size": 29, "lines_coords": [[[793.0, 913.0], [819.0, 913.0], [819.0, 1119.0], [793.0, 1119.0]], [[755.0, 909.0], [787.0, 909.0], [787.0, 1053.0], [755.0, 1053.0]]], "lines": ["こ子供は怖い物", "知らずだ．．．"]}, {"box": [798, 1500, 828, 1596], "vertical": true, "font_size": 30, "lines_coords": [[[798.0, 1500.0], [828.0, 1500.0], [828.0, 1596.0], [798.0, 1596.0]]], "lines": ["へー"]}], "img_path": "00141.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1110, 1001, 1162, 1231], "vertical": true, "font_size": 49, "lines_coords": [[[1113.0, 1001.0], [1162.0, 1003.0], [1158.0, 1108.0], [1110.0, 1106.0]]], "lines": ["ボォー"]}, {"box": [1113, 1376, 1186, 1625], "vertical": true, "font_size": 34, "lines_coords": [[[1145.0, 1376.0], [1186.0, 1376.0], [1186.0, 1490.0], [1145.0, 1490.0]], [[1113.0, 1376.0], [1140.0, 1376.0], [1140.0, 1623.0], [1113.0, 1623.0]]], "lines": ["い今の", "ＳＬだったよね？"]}, {"box": [202, 1405, 236, 1537], "vertical": true, "font_size": 34, "lines_coords": [[[202.0, 1406.0], [236.0, 1406.0], [236.0, 1537.0], [202.0, 1537.0]]], "lines": ["ううん"]}], "img_path": "00142.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1078, 202, 1134, 290], "vertical": true, "font_size": 53, "lines_coords": [[[1078.0, 204.0], [1130.0, 202.0], [1134.0, 288.0], [1081.0, 290.0]]], "lines": ["しゃ"]}, {"box": [183, 240, 266, 495], "vertical": true, "font_size": 34, "lines_coords": [[[230.0, 243.0], [264.0, 243.0], [264.0, 421.0], [230.0, 421.0]], [[183.0, 241.0], [217.0, 241.0], [219.0, 495.0], [185.0, 495.0]]], "lines": ["写真撮るの", "忘れたぁーっ！！"]}, {"box": [926, 699, 1053, 1015], "vertical": true, "font_size": 52, "lines_coords": [[[971.0, 705.0], [1021.0, 699.0], [1053.0, 982.0], [1003.0, 988.0]], [[926.0, 705.0], [978.0, 699.0], [1005.0, 1008.0], [952.0, 1014.0]]], "lines": ["あとでお父さんに", "ＳＬを合成してもこう。"]}, {"box": [150, 690, 234, 952], "vertical": true, "font_size": 35, "lines_coords": [[[195.0, 690.0], [232.0, 690.0], [232.0, 952.0], [195.0, 952.0]], [[150.0, 695.0], [183.0, 695.0], [183.0, 856.0], [150.0, 856.0]]], "lines": ["それでいいのか", "なでしこ。"]}, {"box": [1132, 1010, 1190, 1138], "vertical": true, "font_size": 47, "lines_coords": [[[1132.0, 1014.0], [1179.0, 1010.0], [1190.0, 1134.0], [1143.0, 1138.0]]], "lines": ["よし。"]}, {"box": [256, 1338, 318, 1580], "vertical": true, "font_size": 28, "lines_coords": [[[286.0, 1338.0], [318.0, 1338.0], [318.0, 1580.0], [286.0, 1580.0]], [[256.0, 1338.0], [283.0, 1338.0], [283.0, 1580.0], [256.0, 1580.0]]], "lines": ["大井川ってほぼ毎日", "ＳＬが走ってたのか"]}, {"box": [200, 1494, 226, 1678], "vertical": true, "font_size": 28, "lines_coords": [[[200.0, 1494.0], [226.0, 1494.0], [226.0, 1678.0], [200.0, 1678.0]]], "lines": ["知らなかった．．"]}], "img_path": "00143.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1141, 172, 1210, 330], "vertical": true, "font_size": 30, "lines_coords": [[[1177.0, 172.0], [1209.0, 172.0], [1209.0, 330.0], [1177.0, 330.0]], [[1141.0, 178.0], [1168.0, 178.0], [1168.0, 326.0], [1141.0, 326.0]]], "lines": ["普通列車は", "レトロだし"]}, {"box": [725, 136, 811, 547], "vertical": true, "font_size": 38, "lines_coords": [[[768.0, 136.0], [806.0, 136.0], [811.0, 363.0], [774.0, 363.0]], [[725.0, 136.0], [763.0, 136.0], [763.0, 547.0], [725.0, 547.0]]], "lines": ["鉄道好きには", "たまらない場所なんだよ"]}, {"box": [148, 159, 236, 502], "vertical": true, "font_size": 84, "lines_coords": [[[148.0, 159.0], [232.0, 159.0], [236.0, 502.0], [151.0, 502.0]]], "lines": ["大井川は！！"]}, {"box": [853, 594, 965, 813], "vertical": true, "font_size": 34, "lines_coords": [[[926.0, 594.0], [965.0, 594.0], [965.0, 691.0], [926.0, 691.0]], [[892.0, 594.0], [924.0, 594.0], [924.0, 813.0], [892.0, 813.0]], [[853.0, 596.0], [885.0, 596.0], [885.0, 750.0], [853.0, 750.0]]], "lines": ["ＳＬも", "トロッコ列車も", "走ってるし"]}, {"box": [148, 627, 290, 826], "vertical": true, "font_size": 40, "lines_coords": [[[249.0, 628.0], [290.0, 628.0], [286.0, 789.0], [245.0, 789.0]], [[196.0, 628.0], [236.0, 628.0], [236.0, 826.0], [196.0, 826.0]], [[148.0, 628.0], [187.0, 628.0], [187.0, 789.0], [148.0, 789.0]]], "lines": ["いつから", "鉄道好きに", "なった？"]}, {"box": [1081, 911, 1171, 1121], "vertical": true, "font_size": 29, "lines_coords": [[[1138.0, 911.0], [1171.0, 911.0], [1171.0, 986.0], [1138.0, 986.0]], [[1113.0, 913.0], [1138.0, 913.0], [1138.0, 1121.0], [1113.0, 1121.0]], [[1081.0, 911.0], [1111.0, 911.0], [1111.0, 963.0], [1081.0, 963.0]]], "lines": ["いやー", "アプト列車に乗って", "から"]}, {"box": [1143, 1218, 1212, 1601], "vertical": true, "font_size": 27, "lines_coords": [[[1183.0, 1222.0], [1209.0, 1222.0], [1209.0, 1601.0], [1183.0, 1601.0]], [[1145.0, 1220.0], [1173.0, 1220.0], [1171.0, 1483.0], [1143.0, 1483.0]]], "lines": ["それに今回電車を乗り継いで", "キャンプに行くのが"]}, {"box": [705, 1226, 771, 1546], "vertical": true, "font_size": 26, "lines_coords": [[[744.0, 1226.0], [770.0, 1226.0], [770.0, 1398.0], [744.0, 1398.0]], [[706.0, 1226.0], [733.0, 1226.0], [733.0, 1545.0], [706.0, 1545.0]]], "lines": ["リンちゃんは", "バイクキャンバーだけど"]}, {"box": [221, 896, 311, 1170], "vertical": true, "font_size": 26, "lines_coords": [[[283.0, 898.0], [309.0, 898.0], [309.0, 1145.0], [283.0, 1145.0]], [[253.0, 898.0], [279.0, 898.0], [279.0, 1170.0], [253.0, 1170.0]], [[221.0, 896.0], [247.0, 896.0], [247.0, 1020.0], [221.0, 1020.0]]], "lines": ["レトロな電車とか何か", "かわいくていいなーって", "興味わいて"]}, {"box": [150, 1222, 217, 1548], "vertical": true, "font_size": 29, "lines_coords": [[[183.0, 1222.0], [215.0, 1222.0], [215.0, 1520.0], [183.0, 1520.0]], [[150.0, 1224.0], [176.0, 1224.0], [176.0, 1546.0], [150.0, 1546.0]]], "lines": ["私は電車キャンパーを", "目指そうかと思います！！"]}, {"box": [847, 1544, 878, 1779], "vertical": true, "font_size": 26, "lines_coords": [[[849.0, 1545.0], [875.0, 1545.0], [875.0, 1779.0], [849.0, 1779.0]]], "lines": ["結構面白かったし"]}, {"box": [181, 1599, 305, 1773], "vertical": true, "font_size": 39, "lines_coords": [[[262.0, 1599.0], [305.0, 1599.0], [305.0, 1676.0], [262.0, 1676.0]], [[217.0, 1603.0], [256.0, 1603.0], [260.0, 1773.0], [221.0, 1773.0]], [[181.0, 1605.0], [215.0, 1605.0], [215.0, 1741.0], [181.0, 1741.0]]], "lines": ["まぁ", "いいんじゃ", "ないか？"]}], "img_path": "00144.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1115, 279, 1139, 355], "vertical": true, "font_size": 24, "lines_coords": [[[1115.0, 279.0], [1139.0, 279.0], [1139.0, 355.0], [1115.0, 355.0]]], "lines": ["―．．．"]}, {"box": [889, 157, 915, 236], "vertical": true, "font_size": 26, "lines_coords": [[[889.0, 157.0], [915.0, 157.0], [915.0, 236.0], [889.0, 236.0]]], "lines": ["．．．"]}, {"box": [1156, 830, 1214, 982], "vertical": true, "font_size": 23, "lines_coords": [[[1188.0, 832.0], [1209.0, 832.0], [1209.0, 952.0], [1188.0, 952.0]], [[1156.0, 830.0], [1181.0, 830.0], [1181.0, 982.0], [1156.0, 982.0]]], "lines": ["山梨行くの", "楽しみだけど"]}, {"box": [571, 52