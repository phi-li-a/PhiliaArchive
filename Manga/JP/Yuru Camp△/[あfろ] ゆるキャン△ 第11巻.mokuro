.0], [249.0, 375.0]]], "lines": ["第５９話"]}, {"box": [367, 193, 1134, 663], "vertical": false, "font_size": 67.83333333333333, "lines_coords": [[[399.0, 202.0], [963.0, 193.0], [963.0, 258.0], [399.0, 268.0]], [[425.0, 281.0], [1001.0, 277.0], [1001.0, 341.0], [425.0, 345.0]], [[367.0, 367.0], [945.0, 350.0], [946.0, 421.0], [369.0, 438.0]], [[380.0, 451.0], [930.0, 433.0], [931.0, 496.0], [382.0, 515.0]], [[369.0, 506.0], [1134.0, 525.0], [1132.0, 622.0], [367.0, 603.0]], [[532.0, 605.0], [973.0, 618.0], [971.0, 663.0], [530.0, 650.0]]], "lines": ["第３話、中で卵を目指して。", "・肥満ブタック！！地獄のデスロー", "第６０１話、変き火と谷の夕暮れ", "第６１話、今夜はプチ牛まつり", "家はいい。それは温泉が浸かるかもしれませんのですねえのか", "それじゃあまた、いつか"]}, {"box": [195, 564, 343, 635], "vertical": false, "font_size": 42, "lines_coords": [[[195.0, 594.0], [335.0, 564.0], [343.0, 605.0], [202.0, 635.0]]], "lines": ["第０２話"]}, {"box": [337, 622, 489, 684], "vertical": false, "font_size": 39, "lines_coords": [[[337.0, 645.0], [483.0, 622.0], [489.0, 661.0], [343.0, 684.0]]], "lines": ["第６３話"]}, {"box": [474, 705, 566, 738], "vertical": false, "font_size": 28, "lines_coords": [[[474.0, 710.0], [564.0, 705.0], [566.0, 733.0], [476.0, 738.0]]], "lines": ["番外編"]}, {"box": [618, 697, 834, 723], "vertical": false, "font_size": 26, "lines_coords": [[[618.0, 697.0], [834.0, 697.0], [834.0, 723.0], [618.0, 723.0]]], "lines": ["ヘやキャン△"]}, {"box": [1029, 650, 1065, 675], "vertical": false, "font_size": 25, "lines_coords": [[[1029.0, 650.0], [1065.0, 650.0], [1065.0, 675.0], [1029.0, 675.0]]], "lines": ["．．．"]}, {"box": [429, 1108, 768, 1278], "vertical": false, "font_size": 52.0, "lines_coords": [[[453.0, 1108.0], [729.0, 1215.0], [705.0, 1278.0], [429.0, 1171.0]], [[688.0, 1188.0], [753.0, 1160.0], [768.0, 1194.0], [703.0, 1222.0]]], "lines": ["そういえば、", "．．．"]}, {"box": [727, 1201, 806, 1256], "vertical": false, "font_size": 29, "lines_coords": [[[727.0, 1230.0], [795.0, 1201.0], [806.0, 1228.0], [738.0, 1256.0]]], "lines": ["．．．"]}], "img_path": "00004.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [960, 145, 1161, 667], "vertical": true, "font_size": 47, "lines_coords": [[[1106.0, 481.0], [1153.0, 481.0], [1153.0, 586.0], [1106.0, 586.0]], [[1059.0, 483.0], [1098.0, 485.0], [1091.0, 667.0], [1051.0, 665.0]], [[1076.0, 204.0], [1113.0, 204.0], [1108.0, 496.0], [1070.0, 496.0]], [[1014.0, 174.0], [1080.0, 176.0], [1068.0, 609.0], [1003.0, 607.0]], [[1111.0, 159.0], [1158.0, 159.0], [1158.0, 275.0], [1111.0, 275.0]]], "lines": ["＂ん", "「．．．」ここに", "．．．．．．ーーー", "それはそうですが、ここまでの", "うー"]}, {"box": [165, 138, 243, 305], "vertical": true, "font_size": 62, "lines_coords": [[[165.0, 144.0], [226.0, 138.0], [243.0, 300.0], [181.0, 305.0]]], "lines": ["まぁ"]}, {"box": [1143, 710, 1210, 963], "vertical": true, "font_size": 30, "lines_coords": [[[1177.0, 712.0], [1209.0, 712.0], [1209.0, 963.0], [1177.0, 963.0]], [[1145.0, 710.0], [1173.0, 710.0], [1171.0, 905.0], [1143.0, 905.0]]], "lines": ["つい匂いにつられて", "買っちゃった．．．"]}, {"box": [1132, 1326, 1192, 1704], "vertical": true, "font_size": 25, "lines_coords": [[[1160.0, 1327.0], [1186.0, 1327.0], [1188.0, 1704.0], [1162.0, 1704.0]], [[1132.0, 1331.0], [1156.0, 1331.0], [1156.0, 1481.0], [1132.0, 1481.0]]], "lines": ["千頭駅で降りた人を狙い撃ちする", "豚串スメル．．．"]}, {"box": [795, 1638, 982, 1792], "vertical": false, "font_size": 36.666666666666664, "lines_coords": [[[898.0, 1725.0], [969.0, 1755.0], [954.0, 1792.0], [883.0, 1762.0]], [[808.0, 1661.0], [982.0, 1715.0], [969.0, 1755.0], [795.0, 1700.0]], [[813.0, 1638.0], [928.0, 1666.0], [922.0, 1693.0], [808.0, 1665.0]]], "lines": ["４００円", "ジャンボ隊串", "めっちゃまびろま"]}, {"box": [140, 1488, 212, 1770], "vertical": true, "font_size": 32, "lines_coords": [[[178.0, 1490.0], [210.0, 1490.0], [210.0, 1648.0], [178.0, 1648.0]], [[140.0, 1490.0], [172.0, 1490.0], [172.0, 1770.0], [140.0, 1770.0]]], "lines": ["これは絶対", "避けられないよねぇ"]}], "img_path": "00005.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [121, 1798, 665, 1848], "vertical": false, "font_size": 38, "lines_coords": [[[121.0, 1805.0], [665.0, 1805.0], [665.0, 1843.0], [121.0, 1843.0]]], "lines": ["第５８話やで卵を目指して"]}], "img_path": "00006.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1168, 150, 1209, 375], "vertical": true, "font_size": 39, "lines_coords": [[[1168.0, 150.0], [1207.0, 150.0], [1207.0, 373.0], [1168.0, 373.0]]], "lines": ["ジャンボ豚串"]}, {"box": [549, 150, 585, 401], "vertical": true, "font_size": 32, "lines_coords": [[[549.0, 150.0], [581.0, 150.0], [581.0, 401.0], [549.0, 401.0]]], "lines": ["だがまだ足りぬっ"]}, {"box": [650, 286, 684, 638], "vertical": true, "font_size": 32, "lines_coords": [[[650.0, 286.0], [682.0, 286.0], [682.0, 637.0], [650.0, 637.0]]], "lines": ["おいしゅうございました。"]}, {"box": [140, 153, 170, 546], "vertical": true, "font_size": 26, "lines_coords": [[[140.0, 153.0], [166.0, 153.0], [166.0, 543.0], [140.0, 543.0]]], "lines": ["余はまだ食い足りぬのじゃーっ"]}, {"box": [1124, 1306, 1166, 1680], "vertical": true, "font_size": 37, "lines_coords": [[[1125.0, 1306.0], [1162.0, 1306.0], [1162.0, 1680.0], [1125.0, 1680.0]]], "lines": ["次は本命のダムカレー"]}, {"box": [189, 1404, 245, 1706], "vertical": true, "font_size": 50, "lines_coords": [[[189.0, 1404.0], [240.0, 1404.0], [245.0, 1706.0], [195.0, 1706.0]]], "lines": ["いただきます。"]}], "img_path": "00007.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1111, 138, 1209, 661], "vertical": true, "font_size": 42, "lines_coords": [[[1166.0, 142.0], [1209.0, 142.0], [1209.0, 658.0], [1166.0, 658.0]], [[1111.0, 138.0], [1162.0, 138.0], [1168.0, 661.0], [1117.0, 661.0]]], "lines": ["千頭のダムカレーは上流にある", "長島ダムを接して作られており、"]}, {"box": [999, 236, 1085, 678], "vertical": true, "font_size": 42, "lines_coords": [[[1046.0, 241.0], [1085.0, 241.0], [1085.0, 678.0], [1046.0, 678.0]], [[999.0, 236.0], [1036.0, 236.0], [1036.0, 528.0], [999.0, 528.0]]], "lines": ["エビフライはダムにかかる", "しぶき橋（吊橋）を"]}, {"box": [135, 141, 268, 584], "vertical": true, "font_size": 39, "lines_coords": [[[225.0, 144.0], [264.0, 144.0], [264.0, 583.0], [225.0, 583.0]], [[178.0, 144.0], [217.0, 144.0], [217.0, 549.0], [178.0, 549.0]], [[135.0, 144.0], [174.0, 144.0], [174.0, 440.0], [135.0, 440.0]]], "lines": ["カレーに浮かぶゆで玉子は", "奥大井湖上駅をイメージ", "しているそうです"]}, {"box": [1143, 732, 1216, 1174], "vertical": true, "font_size": 32, "lines_coords": [[[1181.0, 735.0], [1213.0, 735.0], [1213.0, 1173.0], [1181.0, 1173.0]], [[1143.0, 735.0], [1175.0, 735.0], [1175.0, 986.0], [1143.0, 986.0]]], "lines": ["リンちゃん達は大井川の奥まで", "行くみたいだけど"]}, {"box": [633, 1038, 742, 1265], "vertical": true, "font_size": 51, "lines_coords": [[[691.0, 1040.0], [738.0, 1040.0], [742.0, 1265.0], [695.0, 1265.0]], [[633.0, 1040.0], [688.0, 1038.0], [693.0, 1179.0], [639.0, 1181.0]]], "lines": ["私は湖上駅", "までっ"]}, {"box": [1164, 1327, 1224, 1852], "vertical": true, "font_size": 51, "lines_coords": [[[1173.0, 1329.0], [1224.0, 1329.0], [1215.0, 1852.0], [1164.0, 1852.0]]], "lines": ["ダムカレーの醍醐味はここから"]}, {"box": [892, 1329, 939, 1897], "vertical": true, "font_size": 39, "lines_coords": [[[894.0, 1329.0], [933.0, 1329.0], [931.0, 1884.0], [892.0, 1884.0]]], "lines": ["程よく見た目と味を楽しんだ所で"]}, {"box": [759, 1382, 806, 1518], "vertical": true, "font_size": 47, "lines_coords": [[[759.0, 1383.0], [806.0, 1383.0], [806.0, 1518.0], [759.0, 1518.0]]], "lines": ["放水！！"]}, {"box": [123, 1334, 221, 1813], "vertical": true, "font_size": 42, "lines_coords": [[[172.0, 1335.0], [217.0, 1335.0], [217.0, 1811.0], [172.0, 1811.0]], [[123.0, 1335.0], [163.0, 1335.0], [163.0, 1580.0], [123.0, 1580.0]]], "lines": ["ダムの様に放水をする事が", "出来るのです。"]}], "img_path": "00008.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1140, 140, 1213, 453], "vertical": true, "font_size": 26, "lines_coords": [[[1177.0, 140.0], [1211.0, 140.0], [1213.0, 453.0], [1179.0, 453.0]], [[1140.0, 142.0], [1171.0, 142.0], [1171.0, 298.0], [1140.0, 298.0]]], "lines": ["遊び心がある料理って", "いいよねぃ"]