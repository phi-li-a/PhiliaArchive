乗せて", "スモアトースト作ったけど、"]}, {"box": [215, 960, 250, 1207], "vertical": true, "font_size": 32, "lines_coords": [[[215.0, 960.0], [247.0, 960.0], [247.0, 1207.0], [215.0, 1207.0]]], "lines": ["おいしかったなぁ"]}, {"box": [1070, 1331, 1189, 1742], "vertical": true, "font_size": 34, "lines_coords": [[[1151.0, 1331.0], [1188.0, 1331.0], [1188.0, 1573.0], [1151.0, 1573.0]], [[1113.0, 1336.0], [1145.0, 1336.0], [1145.0, 1642.0], [1113.0, 1642.0]], [[1070.0, 1335.0], [1102.0, 1335.0], [1102.0, 1741.0], [1070.0, 1741.0]]], "lines": ["そういえば最近", "コンビニでもスモア", "見かけるようになったよね"]}, {"box": [210, 1419, 251, 1691], "vertical": true, "font_size": 38, "lines_coords": [[[213.0, 1419.0], [251.0, 1419.0], [247.0, 1691.0], [210.0, 1691.0]]], "lines": ["スモアタルトとか"]}], "img_path": "00177.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1066, 165, 1189, 577], "vertical": true, "font_size": 35, "lines_coords": [[[1153.0, 165.0], [1186.0, 165.0], [1188.0, 337.0], [1155.0, 337.0]], [[1110.0, 166.0], [1147.0, 166.0], [1147.0, 510.0], [1110.0, 510.0]], [[1066.0, 168.0], [1100.0, 168.0], [1102.0, 577.0], [1068.0, 577.0]]], "lines": ["私の中では", "チョコとマシュマロが", "ミルクアイスの中に入った"]}, {"box": [174, 206, 253, 519], "vertical": true, "font_size": 35, "lines_coords": [[[215.0, 206.0], [253.0, 206.0], [253.0, 519.0], [215.0, 519.0]], [[174.0, 206.0], [206.0, 206.0], [208.0, 515.0], [176.0, 515.0]]], "lines": ["スモアアイスが一番", "オススメかなーっ！！"]}, {"box": [1171, 705, 1209, 948], "vertical": true, "font_size": 38, "lines_coords": [[[1171.0, 705.0], [1209.0, 705.0], [1209.0, 948.0], [1171.0, 948.0]]], "lines": ["ほいできたぞ"]}, {"box": [720, 705, 765, 943], "vertical": true, "font_size": 40, "lines_coords": [[[720.0, 705.0], [759.0, 705.0], [763.0, 943.0], [723.0, 943.0]]], "lines": ["ありがとーっ"]}, {"box": [142, 1014, 186, 1162], "vertical": true, "font_size": 28, "lines_coords": [[[142.0, 1021.0], [174.0, 1014.0], [185.0, 1061.0], [153.0, 1068.0]], [[155.0, 1119.0], [178.0, 1119.0], [178.0, 1155.0], [155.0, 1155.0]]], "lines": ["ん", "－"]}], "img_path": "00178.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [110, 123, 574, 191], "vertical": false, "font_size": 28, "lines_coords": [[[114.0, 121.0], [568.0, 121.0], [568.0, 152.0], [114.0, 152.0]], [[114.0, 161.0], [525.0, 161.0], [525.0, 191.0], [114.0, 191.0]]], "lines": ["ゆるキャン△Ｏしわかがでしたでしょうか。", "今回は大井川後編を収録致しました"]}, {"box": [100, 240, 929, 485], "vertical": false, "font_size": 31, "lines_coords": [[[116.0, 241.0], [909.0, 241.0], [909.0, 272.0], [116.0, 272.0]], [[116.0, 279.0], [686.0, 279.0], [686.0, 315.0], [116.0, 315.0]], [[114.0, 320.0], [744.0, 318.0], [744.0, 354.0], [114.0, 356.0]], [[118.0, 359.0], [684.0, 358.0], [684.0, 395.0], [118.0, 397.0]], [[118.0, 403.0], [590.0, 403.0], [590.0, 433.0], [118.0, 433.0]], [[120.0, 442.0], [562.0, 442.0], [562.0, 472.0], [120.0, 472.0]]], "lines": ["話作りの段階にキャンプ地をどここでするがでも沢山駅の三十所で迷い", "なでしこの行動範囲の都合で市代に決めたんですが", "畑蒸のキャンプ場もＯＮ形なのでぜひ訪れてみて下さい。", "リンと綾乃が行った畑薙大吊橋よりもっと先にある", "芝生のきれいな登山１苦用のキャンプ場です。", "〈畑薙デスロードエクストラステージ）"]}, {"box": [112, 521, 277, 560], "vertical": false, "font_size": 27, "lines_coords": [[[118.0, 524.0], [270.0, 524.0], [270.0, 553.0], [118.0, 553.0]]], "lines": ["あｆろでした。"]}, {"box": [114, 1760, 436, 1779], "vertical": false, "font_size": 19, "lines_coords": [[[114.0, 1760.0], [436.0, 1760.0], [436.0, 1779.0], [114.0, 1779.0]]], "lines": ["本書は以上の内容を収録致しました。"]}, {"box": [65, 1672, 620, 1755], "vertical": false, "font_size": 24.0, "lines_coords": [[[99.0, 1672.0], [208.0, 1672.0], [208.0, 1693.0], [99.0, 1693.0]], [[118.0, 1696.0], [620.0, 1698.0], [620.0, 1723.0], [118.0, 1721.0]], [[65.0, 1721.0], [226.0, 1728.0], [226.0, 1755.0], [65.0, 1747.0]]], "lines": ["寒く初出一覧）", "．．．８０１７年０７月１２日オールデーター３１０月・売れ２年１月ご", "．．．描き下ろし"]}], "img_path": "00179.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [376, 798, 594, 901], "vertical": false, "font_size": 39.5, "lines_coords": [[[378.0, 798.0], [594.0, 798.0], [594.0, 836.0], [378.0, 836.0]], [[376.0, 860.0], [476.0, 860.0], [476.0, 901.0], [376.0, 901.0]]], "lines": ["著者：あｆろ", "©ａｆｒｏ"]}, {"box": [367, 613, 952, 682], "vertical": false, "font_size": 69, "lines_coords": [[[367.0, 613.0], [952.0, 613.0], [952.0, 682.0], [367.0, 682.0]]], "lines": ["ゆるキャン△，第１１巻"]}, {"box": [378, 982, 952, 1228], "vertical": false, "font_size": 38, "lines_coords": [[[378.0, 991.0], [930.0, 986.0], [930.0, 1029.0], [378.0, 1035.0]], [[378.0, 1059.0], [675.0, 1059.0], [675.0, 1096.0], [378.0, 1096.0]], [[378.0, 1123.0], [783.0, 1126.0], [783.0, 1158.0], [378.0, 1155.0]], [[526.0, 1186.0], [933.0, 1188.0], [933.0, 1226.0], [526.0, 1224.0]]], "lines": ["電子版発行日：２０２１年２月１５日", "発行人：東敬彰", "発行所：株式会社芳文社", "東京都文京区後楽１－２－１２"]}], "img_path": "00180.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [125, 777, 196, 1023], "vertical": true, "font_size": 19, "lines_coords": [[[127.0, 892.0], [146.0, 892.0], [148.0, 1016.0], [129.0, 1016.0]]], "lines": ["こちらにお肌質のアークが描かれていますので、あたりにことにします。"]}, {"box": [1182, 830, 1290, 886], "vertical": false, "font_size": 15, "lines_coords": [[[1200.0, 832.0], [1267.0, 832.0], [1267.0, 849.0], [1200.0, 849.0]]], "lines": ["＊ｕｍｌＣａｍｐ："]}, {"box": [52, 1006, 91, 1023], "vertical": false, "font_size": 17, "lines_coords": [[[54.0, 1006.0], [88.0, 1006.0], [88.0, 1025.0], [54.0, 1025.0]]], "lines": ["あ．．．"]}], "img_path": "00181.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1243, 580, 1269, 719], "vertical": true, "font_size": 26, "lines_coords": [[[1243.0, 580.0], [1269.0, 580.0], [1269.0, 719.0], [1243.0, 719.0]]], "lines": ["すげーキャンピングカーとオフロード車しかいねぇぞ"]}, {"box": [1236, 778, 1274, 917], "vertical": true, "font_size": 38, "lines_coords": [[[1236.0, 778.0], [1274.0, 778.0], [1274.0, 917.0], [1236.0, 917.0]]], "lines": ["９０年代て確か大きなキャンプブームがあった頃やない？"]}, {"box": [1046, 671, 1073, 725], "vertical": true, "font_size": 27, "lines_coords": [[[1046.0, 671.0], [1073.0, 671.0], [1073.0, 725.0], [1046.0, 725.0]]], "lines": ["ほんとだねぇ"]}, {"box": [967, 577, 1003, 739], "vertical": true, "font_size": 34, "lines_coords": [[[967.0, 577.0], [1001.0, 577.0], [1003.0, 710.0], [969.0, 710.0]]], "lines": ["でも知り合いに事故で死んじゃった人とかいな"]}, {"box": [1049, 853, 1074, 908], "vertical": true, "font_size": 25, "lines_coords": [[[1049.0, 853.0], [1074.0, 853.0], [1074.0, 908.0], [1049.0, 908.0]]], "lines": ["へーそうだったんだ"]}, {"box": [960, 786, 1004, 916], "vertical": true, "font_size": 44, "lines_coords": [[[960.0, 786.0], [1004.0, 786.0], [1004.0, 916.0], [960.0, 916.0]]], "lines": ["うちらの使命はきっと現代ではなくなってもうたキャンプ場を救うとかやないやろか"]}, {"box": [783, 585, 809, 735], "vertical": true, "font_size": 26, "lines_coords": [[[783.0, 585.0], [809.0, 585.0], [809.0, 735.0], [783.0, 735.0]]], "lines": ["いやそれはほのぼの野クルのうちらとは興違いの話や"]}, {"box": [648, 511, 700, 555], "vertical": false, "font_size": 44, "lines_coords": [[[648.0, 511.0], [700.0, 511.0], [700.0, 555.0], [648.0, 555.0]]], "lines": ["んの"]}, {"box": [831, 899, 929, 917], "vertical": false, "font_size": 18, "lines_coords": [[[831.0, 899.0], [929.0, 899.0], [929.0, 917.0], [831.0, 917.0]]], "lines": ["オンライン"]}, {"box": [780, 782, 813, 841], "vertical": true, "font_size": 33, "lines_coords": [[[780.0, 782.0], [813.0, 782.0], [813.0, 841.0], [780.0, 841.0]]], "lines": ["それだイヌ子！！"]}, {"box": [641, 609, 702, 958], "vertical": true, "font_size": 58, "lines_coords": [[[641.0, 609.0], [699.0, 609.0], [699.0, 958.0], [641.0, 958.0]]], "lines": ["ゆるキュゾへ"]}, {"box": [325, 603, 582, 713], "vertical": false, "font_size": 110, "lines_coords": [[[325.0, 603.0], [582.0, 603.0], [582.0, 713.0], [325.0, 713.0]]], "lines": ["あははな、"]}, {"box": [256, 582, 288, 729], "vertical": true, "font_size": 32, "lines_coords": [[[256.0, 582.0], [288.0, 582.0], [288.0, 729.0], [256.0, 729.0]]], "lines": ["ある日私達が富士の麓でキャンプをしていると"]}, {"box": [208, 724, 231, 742], "vertical": false, "font_size": 18, "lines_coords": [[[208.0, 724.0], [231.0, 724.0], [231.0, 742.0], [208.0, 742.0]]], "lines": ["この"]}, {"box": [256, 777, 289, 934], "vertical": true, "font_size": 33, "lines_coords": [[[256.0, 777.0], [289.0, 777.0], [289.0, 934.0], [256.0, 934.0]]], "lines": ["気がつくと２５年前の過去に、タイムスリップをしてしまって"]}, {"box": [58, 577, 80, 751], "vertical": true, "font_size": 20, "lines_coords": [[[58.0, 577.0], [78.0, 577.0], [80.0, 746.0], [60.0, 746.0]]], "lines": ["辺りが急に謎の霧に包まれ"]}, {"box": [1218, 981, 1270, 1136], "vertical": true, "font_size": 52, "lines_coords": [[[1218.0, 981.0], [1270.0, 981.0], [1270.0, 1136.0], [1218.0, 1136.0]]], "lines": ["けど何でこんな事になったんだ？うちらキャンプしてただけじゃん"]}, {"box": [1057, 984, 1083, 1046], "vertical": true, "font_size": 26, "lines_coords": [[[1057.0, 984.0], [1083.0, 984.0], [1083.0, 1046.0], [1057.0, 1046.0]]], "lines": ["はっ！！"]}, {"box": [1228, 1162, 1269, 1333], "vertical": true, "font_size": 20, "lines_coords": [[[1231.0, 1162.0], [1252.0, 1162.0], [1248.0, 1275.0], [1228.0, 1275.0]]], "lines": ["過去の事あ？日本人を救う話がお決まりや"]}, {"box": [969, 985, 1000, 1048], "vertical": true, "font_size": 31, "lines_coords": [[[969.0, 985.0], [1000.0, 985.0], [1000.0, 1048.0], [969.0, 1048.0]]], "lines": ["やろうよあきちゃんあおいちゃえ！！"]}, {"box": [922, 985, 935, 1023], "vertical": true, "font_size": 13, "lines_coords": [[[922.0, 985.0], [935.0, 985.0], [935.0, 1023.0], [922.0, 1023.0]]], "lines": ["せやな！！"]}, {"box": [1046, 1168, 1076, 1327], "vertical": true, "font_size": 24, "lines_coords": [[[1048.0, 1170.0], [1072.0, 1170.0], [1070.0, 1325.0], [1046.0, 1325.0]]], "lines": ["うちはもういっ来たこの時代に呼ばれたんちゃう！？"]}, {"box": [971, 1171, 1002, 1288], "vertical": true, "font_size": 19, "lines_coords": [[[971.0, 1171.0], [990.0, 1171.0], [990.0, 1261.0], [971.0, 1261.0]]], "lines": ["自販機だよっ！！"]}, {"box": [854, 1058, 873, 1129], "vertical": true, "font_size": 19, "lines_coords": [[[854.0, 1058.0], [873.0, 1058.0], [873.0, 1129.0], [854.0, 1129.0]]], "lines": ["よしやってやるぜ！！"]}, {"box": [774, 969, 828, 1136], "vertical": true, "font_size": 19, "lines_coords": [[[810.0, 976.0], [828.0, 976.0], [828.0, 1121.0], [810.0, 1121.0]], [[789.0, 971.0], [810.0, 971.0], [811.0, 1128.0], [791.0, 1128.0]], [[774.0, 971.0], [793.0, 971.0], [793.0, 1108.0], [774.0, 1108.0]]], "lines": ["こうしてなんやかんやで", "時を超えた野クルの冒険。", "今始まるのであった"]}, {"box": [660, 939, 687, 1043], "vertical": true, "font_size": 27, "lines_coords": [[[660.0, 939.0], [687.0, 939.0], [687.0, 1043.0], [660.0, 1043.0]]], "lines": ["ｈｉｇｈｓｏｆｏｏｌｄｉｒｓｐｏｖｕｒｃｏｏｍｐｉｎｄｉｃｒｅ"]}, {"box": [780, 1166, 811, 1194], "vertical": false, "font_size": 28, "lines_coords": [[[780.0, 1166.0], [811.0, 1166.0], [811.0, 1194.0], [780.0, 1194.0]]], "lines": ["え"]}, {"box": [835, 1248, 861, 1310], "vertical": true, "font_size": 26, "lines_coords": [[[835.0, 1248.0], [861.0, 1248.0], [861.0, 1310.0], [835.0, 1310.0]]], "lines": ["カップめんもある！！"]}, {"box": [784, 1208, 810, 1281], "vertical": true, "font_size": 26, "lines_coords": [[[784.0, 1208.0], [810.0, 1208.0], [810.0, 1281.0], [784.0, 1281.0]]], "lines": ["いきなり脱線しとるなぁ"]}, {"box": [660, 1153, 692, 1187], "vertical": true, "font_size": 32, "lines_coords": [[[660.0, 1153.0], [692.0, 1153.0], [692.0, 1187.0], [660.0, 1187.0]]], "lines": ["１１"]}, {"box": [652, 1175, 691, 1374], "vertical": true, "font_size": 39, "lines_coords": [[[652.0, 1175.0], [691.0, 1175.0], [691.0, 1374.0], [652.0, 1374.0]]], "lines": ["「あｆこ"]}, {"box": [251, 972, 284, 1125], "vertical": true, "font_size": 17, "lines_coords": [[[264.0, 973.0], [283.0, 973.0], [283.0, 1121.0], [264.0, 1121.0]], [[251.0, 976.0], [266.0, 976.0], [266.0, 1014.0], [251.0, 1014.0]]], "lines": ["こっこれはどういうコト", "なんや"]}, {"box": [60, 973, 116, 1056], "vertical": true, "font_size": 20, "lines_coords": [[[95.0, 973.0], [116.0, 973.0], [116.0, 1033.0], [95.0, 1033.0]], [[76.0, 973.0], [97.0, 973.0], [97.0, 1036.0], [76.0, 1036.0]], [[60.0, 975.0], [78.0, 975.0], [78.0, 1036.0], [60.0, 1036.0]]], "lines": ["都合よく", "新聞落ち", "てたなぁ"]}, {"box": [248, 1229, 292, 1332], "vertical": true, "font_size": 44, "lines_coords": [[[248.0, 1229.0], [292.0, 1229.0], [292.0, 1332.0], [248.0, 1332.0]]], "lines": ["って二人とも顔が９０年代になっとるやん！！"]}, {"box": [61, 1166, 94, 1284], "vertical": true, "font_size": 21, "lines_coords": [[[61.0, 1168.0], [82.0, 1168.0], [82.0, 1284.0], [61.0, 1284.0]]], "lines": ["イス子もだぞーや！！"]}, {"box": [67, 1248, 102, 1298], "vertical": true, "font_size": 35, "lines_coords": [[[67.0, 1248.0], [102.0, 1248.0], [102.0, 1298.0], [67.0, 1298.0]]], "lines": ["ほんまや！！"]}], "img_path": "00182.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [88, 125, 532, 476], "vertical": false, "font_size": 153.0, "lines_coords": [[[296.0, 125.0], [532.0, 146.0], [519.0, 305.0], [283.0, 285.0]], [[88.0, 330.0], [320.0, 330.0], [320.0, 476.0], [88.0, 476.0]]], "lines": ["Ｄｏ", "ひぁ"]}, {"box": [1026, 329, 1286, 377], "vertical": false, "font_size": 44, "lines_coords": [[[1035.0, 326.0], [1278.0, 331.0], [1278.0, 379.0], [1035.0, 373.0]]], "lines": ["いいじゃないので"]}], "img_path": "cover.jpg"}]}