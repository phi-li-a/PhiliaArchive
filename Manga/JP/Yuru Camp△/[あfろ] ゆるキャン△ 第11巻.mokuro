75, 127, 315, 265], "vertical": true, "font_size": 34, "lines_coords": [[[281.0, 127.0], [315.0, 129.0], [309.0, 247.0], [275.0, 245.0]]], "lines": ["むむむ．．．"]}, {"box": [131, 133, 215, 545], "vertical": true, "font_size": 35, "lines_coords": [[[170.0, 140.0], [208.0, 140.0], [210.0, 545.0], [172.0, 545.0]], [[135.0, 133.0], [166.0, 133.0], [163.0, 313.0], [131.0, 313.0]]], "lines": ["８３度に保ったお湯で約３０分", "湯煎します"]}, {"box": [1151, 768, 1184, 1013], "vertical": true, "font_size": 28, "lines_coords": [[[1153.0, 768.0], [1181.0, 768.0], [1179.0, 1012.0], [1151.0, 1012.0]]], "lines": ["何で６３度なんだ？"]}, {"box": [742, 765, 806, 1012], "vertical": true, "font_size": 26, "lines_coords": [[[776.0, 765.0], [802.0, 765.0], [804.0, 1012.0], [778.0, 1012.0]], [[742.0, 766.0], [768.0, 766.0], [768.0, 958.0], [742.0, 958.0]]], "lines": ["それ以下だと中まで", "殺菌できないし"]}, {"box": [73, 120, 99, 862], "vertical": true, "font_size": 26, "lines_coords": [[[73.0, 120.0], [99.0, 120.0], [99.0, 862.0], [73.0, 862.0]]], "lines": ["淡袋が溶けないよう、鍋底に油切り用の丸網などを敷きます"]}, {"box": [294, 721, 356, 999], "vertical": true, "font_size": 25, "lines_coords": [[[326.0, 721.0], [350.0, 721.0], [350.0, 969.0], [326.0, 969.0]], [[294.0, 721.0], [320.0, 721.0], [320.0, 999.0], [294.0, 999.0]]], "lines": ["それ以上だとお肉が", "固くなっちゃうんだよ"]}, {"box": [142, 787, 205, 1117], "vertical": true, "font_size": 25, "lines_coords": [[[178.0, 789.0], [202.0, 789.0], [202.0, 1117.0], [178.0, 1117.0]], [[142.0, 787.0], [168.0, 787.0], [168.0, 1035.0], [142.0, 1035.0]]], "lines": ["ゆでる時間と温度は色んな", "説があるんだけどね"]}, {"box": [1155, 1297, 1189, 1565], "vertical": true, "font_size": 31, "lines_coords": [[[1155.0, 1297.0], [1186.0, 1297.0], [1186.0, 1563.0], [1155.0, 1563.0]]], "lines": ["あシュラフむしだ"]}, {"box": [361, 1207, 446, 1372], "vertical": true, "font_size": 26, "lines_coords": [[[420.0, 1207.0], [446.0, 1207.0], [446.0, 1372.0], [420.0, 1372.0]], [[391.0, 1207.0], [416.0, 1207.0], [416.0, 1372.0], [391.0, 1372.0]], [[361.0, 1207.0], [388.0, 1207.0], [388.0, 1305.0], [361.0, 1305.0]]], "lines": ["んじゃこっちも", "ビーフシチュー", "作るかな"]}, {"box": [538, 1353, 579, 1597], "vertical": true, "font_size": 38, "lines_coords": [[[538.0, 1353.0], [575.0, 1353.0], [579.0, 1597.0], [541.0, 1597.0]]], "lines": ["シュラフむしだ"]}, {"box": [140, 1528, 208, 1723], "vertical": true, "font_size": 34, "lines_coords": [[[172.0, 1528.0], [208.0, 1528.0], [208.0, 1616.0], [172.0, 1616.0]], [[140.0, 1528.0], [172.0, 1528.0], [172.0, 1723.0], [140.0, 1723.0]]], "lines": ["わーい", "ビーフシチュー"]}], "img_path": "00083.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [625, 1734, 1224, 1785], "vertical": false, "font_size": 45, "lines_coords": [[[628.0, 1738.0], [1224.0, 1738.0], [1224.0, 1783.0], [628.0, 1783.0]]], "lines": ["第５１話今夜はプチ牛まつり"]}], "img_path": "00084.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1125, 136, 1211, 581], "vertical": true, "font_size": 45, "lines_coords": [[[1160.0, 140.0], [1211.0, 140.0], [1211.0, 581.0], [1160.0, 581.0]], [[1128.0, 136.0], [1168.0, 136.0], [1164.0, 311.0], [1125.0, 311.0]]], "lines": ["まずし圧力鍋でニロ大に切った", "牛すね肉を"]}, {"box": [708, 140, 792, 406], "vertical": true, "font_size": 40, "lines_coords": [[[750.0, 142.0], [789.0, 142.0], [789.0, 406.0], [750.0, 406.0]], [[708.0, 140.0], [750.0, 140.0], [753.0, 283.0], [712.0, 283.0]]], "lines": ["オリーブオイルで", "炒めます"]}, {"box": [129, 143, 210, 500], "vertical": true, "font_size": 38, "lines_coords": [[[168.0, 144.0], [206.0, 144.0], [206.0, 500.0], [168.0, 500.0]], [[129.0, 144.0], [166.0, 144.0], [166.0, 468.0], [129.0, 468.0]]], "lines": ["次に水と赤ワインを加え", "アクを取りつつ惹込み"]}, {"box": [1119, 637, 1198, 1095], "vertical": true, "font_size": 33, "lines_coords": [[[1160.0, 639.0], [1192.0, 639.0], [1192.0, 961.0], [1160.0, 961.0]], [[1119.0, 637.0], [1153.0, 637.0], [1155.0, 1095.0], [1121.0, 1095.0]]], "lines": ["蓋をして圧力をかけて", "さらに約３０分、弱火で煮込みます。"]}, {"box": [176, 793, 241, 997], "vertical": true, "font_size": 33, "lines_coords": [[[196.0, 795.0], [238.0, 793.0], [241.0, 877.0], [200.0, 879.0]], [[176.0, 796.0], [200.0, 796.0], [200.0, 995.0], [176.0, 995.0]]], "lines": ["へぇー", "それ圧力鍋なんだ"]}, {"box": [980, 1128, 1198, 1372], "vertical": true, "font_size": 30, "lines_coords": [[[1162.0, 1128.0], [1194.0, 1128.0], [1198.0, 1282.0], [1166.0, 1282.0]], [[1128.0, 1130.0], [1160.0, 1130.0], [1160.0, 1372.0], [1128.0, 1372.0]], [[1089.0, 1132.0], [1121.0, 1132.0], [1121.0, 1312.0], [1089.0, 1312.0]], [[1050.0, 1130.0], [1081.0, 1130.0], [1081.0, 1280.0], [1050.0, 1280.0]], [[1018.0, 1134.0], [1044.0, 1134.0], [1044.0, 1340.0], [1018.0, 1340.0]], [[980.0, 1132.0], [1006.0, 1132.0], [1006.0, 1252.0], [980.0, 1252.0]]], "lines": ["すね肉って", "じっくり煮込むと", "コラーゲンが", "トロトロに", "とろけるんだよ", "ねぃ．．．"]}, {"box": [779, 1135, 844, 1348], "vertical": true, "font_size": 26, "lines_coords": [[[817.0, 1140.0], [843.0, 1140.0], [843.0, 1286.0], [817.0, 1286.0]], [[780.0, 1138.0], [806.0, 1138.0], [806.0, 1348.0], [780.0, 1348.0]]], "lines": ["トロトロで", "うまいんだよな"]}, {"box": [579, 1147, 663, 1590], "vertical": true, "font_size": 37, "lines_coords": [[[624.0, 1149.0], [661.0, 1149.0], [661.0, 1481.0], [624.0, 1481.0]], [[579.0, 1149.0], [616.0, 1149.0], [616.0, 1590.0], [579.0, 1590.0]]], "lines": ["すね肉が煮えた所で", "茹で汁を手分ほど水に替え"]}, {"box": [994, 1420, 1015, 1486], "vertical": true, "font_size": 21, "lines_coords": [[[994.0, 1420.0], [1015.0, 1420.0], [1015.0, 1486.0], [994.0, 1486.0]]], "lines": ["じゃるり"]}, {"box": [61, 1149, 150, 1779], "vertical": true, "font_size": 40, "lines_coords": [[[105.0, 1149.0], [148.0, 1149.0], [148.0, 1779.0], [105.0, 1779.0]], [[61.0, 1151.0], [99.0, 1151.0], [99.0, 1629.0], [61.0, 1629.0]]], "lines": ["主ねぞシャガイモーニンジンを加えて", "今度は約５分圧力をかけます。"]}], "img_path": "00085.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1153, 140, 1246, 624], "vertical": true, "font_size": 42, "lines_coords": [[[1201.0, 142.0], [1241.0, 142.0], [1241.0, 403.0], [1201.0, 403.0]], [[1156.0, 140.0], [1201.0, 140.0], [1198.0, 624.0], [1153.0, 624.0]]], "lines": ["仕上げにルウと", "マッシュルームの水煮を入れ"]}, {"box": [613, 142, 700, 440], "vertical": true, "font_size": 37, "lines_coords": [[[658.0, 146.0], [695.0, 146.0], [699.0, 440.0], [661.0, 440.0]], [[613.0, 142.0], [650.0, 142.0], [650.0, 403.0], [613.0, 403.0]]], "lines": ["とろみがつくまで", "煮たら完成です"]}, {"box": [146, 157, 208, 506], "vertical": true, "font_size": 26, "lines_coords": [[[181.0, 157.0], [206.0, 157.0], [206.0, 506.0], [181.0, 506.0]], [[146.0, 159.0], [172.0, 159.0], [172.0, 466.0], [146.0, 466.0]]], "lines": ["まぁすね肉の下ごしらえは", "家でしてきたんだけどね"]}, {"box": [1147, 740, 1179, 935], "vertical": true, "font_size": 29, "lines_coords": [[[1147.0, 740.0], [1179.0, 740.0], [1179.0, 935.0], [1147.0, 935.0]]], "lines": ["現地で煮るのは"]}, {"box": [1152, 740, 1213, 1048], "vertical": true, "font_size": 26, "lines_coords": [[[1185.0, 740.0], [1211.0, 740.0], [1211.0, 1042.0], [1185.0, 1042.0]]], "lines": ["ものすごく脂が出るから"]}, {"box": [1013, 797, 1082, 1094], "vertical": true, "font_size": 69, "lines_coords": [[[1013.0, 797.0], [1082.0, 797.0], [1082.0, 1094.0], [1013.0, 1094.0]]], "lines": ["やめた方がいいってお母さんに言われてさ"]}, {"box": [1014, 796, 1080, 1096], "vertical": true, "font_size": 29, "lines_coords": [[[1050.0, 796.0], [1078.0, 796.0], [1080.0, 1066.0], [1051.0, 1066.0]], [[1014.0, 800.0], [1040.0, 800.0], [1040.0, 1096.0], [1014.0, 1096.0]]], "lines": ["やめた方がいいって", "お母さんに言われてさ"]}, {"box": [616, 500, 693, 600], "vertical": true, "font_size": 40, "lines_coords": [[[648.0, 500.0], [693.0, 500.0], [693.0, 575.0], [648.0, 575.0]], [[616.0, 504.0], [650.0, 504.0], [650.0, 600.0], [616.0, 600.0]]], "lines": ["よし", "できた"]}, {"box": [290, 765, 397, 1036], "vertical": true, "font_size": 32, "lines_coords": [[[360.0, 765.0], [397.0, 765.0], [397.0, 832.0], [360.0, 832.0]], [[326.0, 766.0], [358.0, 766.0], [358.0, 1010.0], [326.0, 1010.0]], [[290.0, 768.0], [316.0, 768.0], [316.0, 1036.0], [290.0, 1036.0]]], "lines": ["あー", "茹で汁全部使うと"