s": [[[1132.0, 639.0], [1171.0, 639.0], [1171.0, 751.0], [1132.0, 751.0]]], "lines": ["猿並橋"]}, {"box": [1132, 1198, 1206, 1606], "vertical": true, "font_size": 29, "lines_coords": [[[1175.0, 1205.0], [1201.0, 1205.0], [1201.0, 1603.0], [1175.0, 1603.0]], [[1134.0, 1198.0], [1166.0, 1198.0], [1164.0, 1606.0], [1132.0, 1606.0]]], "lines": ["山に住む猿達が寸又峡温泉を", "行来するために渡ることから"]}, {"box": [710, 1205, 744, 1486], "vertical": true, "font_size": 32, "lines_coords": [[[712.0, 1205.0], [744.0, 1205.0], [742.0, 1486.0], [710.0, 1486.0]]], "lines": ["この名がつけられた"]}, {"box": [564, 1190, 626, 1468], "vertical": true, "font_size": 25, "lines_coords": [[[600.0, 1192.0], [624.0, 1192.0], [624.0, 1468.0], [600.0, 1468.0]], [[564.0, 1190.0], [590.0, 1190.0], [590.0, 1413.0], [564.0, 1413.0]]], "lines": ["ここのお猿もやっぱり", "温泉入るのかな？"]}, {"box": [378, 1276, 408, 1434], "vertical": true, "font_size": 27, "lines_coords": [[[378.0, 1276.0], [405.0, 1276.0], [405.0, 1434.0], [378.0, 1434.0]]], "lines": ["どうだろ？"]}, {"box": [151, 1230, 225, 1357], "vertical": true, "font_size": 38, "lines_coords": [[[193.0, 1231.0], [225.0, 1231.0], [225.0, 1357.0], [193.0, 1357.0]], [[151.0, 1230.0], [195.0, 1230.0], [195.0, 1303.0], [151.0, 1303.0]]], "lines": ["なごむよ", "ねー"]}], "img_path": "00120.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1102, 403, 1132, 485], "vertical": true, "font_size": 26, "lines_coords": [[[1106.0, 403.0], [1132.0, 405.0], [1128.0, 485.0], [1102.0, 483.0]]], "lines": ["おさる"]}, {"box": [767, 433, 819, 502], "vertical": true, "font_size": 30, "lines_coords": [[[789.0, 433.0], [819.0, 433.0], [819.0, 476.0], [789.0, 476.0]]], "lines": ["ホン"]}, {"box": [1093, 1494, 1176, 1719], "vertical": true, "font_size": 32, "lines_coords": [[[1141.0, 1494.0], [1175.0, 1494.0], [1171.0, 1648.0], [1138.0, 1648.0]], [[1095.0, 1496.0], [1126.0, 1496.0], [1126.0, 1717.0], [1095.0, 1717.0]]], "lines": ["夢の吊橋", "見えて来たよ"]}, {"box": [159, 1560, 266, 1734], "vertical": true, "font_size": 47, "lines_coords": [[[217.0, 1560.0], [266.0, 1560.0], [266.0, 1691.0], [217.0, 1691.0]], [[165.0, 1561.0], [210.0, 1563.0], [204.0, 1734.0], [159.0, 1732.0]]], "lines": ["おぉー", "ついに！！"]}], "img_path": "00121.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1186, 202, 1223, 352], "vertical": true, "font_size": 32, "lines_coords": [[[1188.0, 202.0], [1220.0, 202.0], [1220.0, 352.0], [1188.0, 352.0]]], "lines": ["夢の吊橋"]}, {"box": [1149, 862, 1249, 1143], "vertical": true, "font_size": 27, "lines_coords": [[[1218.0, 864.0], [1245.0, 864.0], [1245.0, 1057.0], [1218.0, 1057.0]], [[1183.0, 862.0], [1211.0, 862.0], [1213.0, 1141.0], [1185.0, 1141.0]], [[1149.0, 864.0], [1175.0, 864.0], [1175.0, 1057.0], [1149.0, 1057.0]]], "lines": ["橋は一方通行で", "向こう岸を大回りして", "戻って来るんだ"]}, {"box": [360, 853, 424, 1104], "vertical": true, "font_size": 26, "lines_coords": [[[395.0, 855.0], [421.0, 855.0], [421.0, 1076.0], [395.0, 1076.0]], [[360.0, 853.0], [386.0, 853.0], [388.0, 1104.0], [361.0, 1104.0]]], "lines": ["やっぱり時期外れ", "だから空いてるねぇ"]}, {"box": [140, 918, 204, 1117], "vertical": true, "font_size": 29, "lines_coords": [[[172.0, 918.0], [204.0, 918.0], [204.0, 1117.0], [172.0, 1117.0]], [[140.0, 920.0], [166.0, 920.0], [166.0, 1061.0], [140.0, 1061.0]]], "lines": ["まったり渡れて", "最高じゃん"]}, {"box": [198, 1342, 262, 1537], "vertical": true, "font_size": 30, "lines_coords": [[[230.0, 1342.0], [262.0, 1342.0], [262.0, 1460.0], [230.0, 1460.0]], [[198.0, 1348.0], [225.0, 1348.0], [225.0, 1537.0], [198.0, 1537.0]]], "lines": ["ほぉおー", "川の色きれーっ"]}], "img_path": "00122.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1036, 191, 1106, 472], "vertical": true, "font_size": 32, "lines_coords": [[[1072.0, 191.0], [1104.0, 191.0], [1104.0, 442.0], [1072.0, 442.0]], [[1036.0, 191.0], [1068.0, 191.0], [1068.0, 472.0], [1036.0, 472.0]]], "lines": ["でも真下を見ると", "ちょっと怖いかも．．"]}, {"box": [448, 393, 521, 442], "vertical": false, "font_size": 14.0, "lines_coords": [[[481.0, 393.0], [521.0, 412.0], [515.0, 425.0], [476.0, 406.0]], [[466.0, 399.0], [515.0, 423.0], [508.0, 436.0], [459.0, 412.0]], [[453.0, 410.0], [504.0, 429.0], [498.0, 442.0], [448.0, 421.0]]], "lines": ["いいじゃないのよねえあんたはあんまります", "．．．そういうこともありませんでしょうかよかった", "．．．やっぱりキャッチンしてるんじゃないかもしれ"]}, {"box": [210, 221, 242, 345], "vertical": true, "font_size": 26, "lines_coords": [[[213.0, 221.0], [240.0, 221.0], [236.0, 345.0], [210.0, 345.0]]], "lines": ["高さ８ｍ"]}, {"box": [1055, 840, 1132, 1078], "vertical": true, "font_size": 32, "lines_coords": [[[1096.0, 840.0], [1128.0, 840.0], [1128.0, 1078.0], [1096.0, 1078.0]], [[1055.0, 841.0], [1087.0, 841.0], [1087.0, 1005.0], [1055.0, 1005.0]]], "lines": ["それに真ん中は", "ゆれるーっ"]}, {"box": [639, 463, 776, 534], "vertical": false, "font_size": 17.0, "lines_coords": [[[663.0, 496.0], [740.0, 519.0], [736.0, 534.0], [660.0, 511.0]], [[646.0, 463.0], [774.0, 495.0], [770.0, 511.0], [643.0, 481.0]], [[645.0, 474.0], [776.0, 508.0], [770.0, 526.0], [639.0, 493.0]]], "lines": ["そういうことでしょうか．．．", "これからは、これまではないかもしれませんでしょうがないんですよね。それはそれでもいいですね。", "これからはスーパートフォルマーケティングサービスに入っていましたが、これまではないでしょうか。"]}, {"box": [665, 513, 738, 547], "vertical": false, "font_size": 15, "lines_coords": [[[669.0, 513.0], [738.0, 532.0], [735.0, 547.0], [665.0, 528.0]]], "lines": ["それはそれじゃないんじゃねえよねえ．．．いいんだよねぇよぉーん"]}, {"box": [296, 459, 401, 536], "vertical": false, "font_size": 16.0, "lines_coords": [[[352.0, 459.0], [401.0, 483.0], [395.0, 496.0], [346.0, 472.0]], [[328.0, 468.0], [401.0, 506.0], [393.0, 521.0], [320.0, 483.0]], [[303.0, 481.0], [378.0, 521.0], [371.0, 536.0], [296.0, 496.0]]], "lines": ["いいかいい", "いや．．．いやいや、", "．．．"]}, {"box": [270, 495, 348, 549], "vertical": false, "font_size": 14, "lines_coords": [[[279.0, 495.0], [348.0, 536.0], [341.0, 549.0], [270.0, 506.0]]], "lines": ["いいよいいじゃないけど"]}, {"box": [298, 766, 325, 879], "vertical": true, "font_size": 26, "lines_coords": [[[298.0, 766.0], [324.0, 766.0], [324.0, 879.0], [298.0, 879.0]]], "lines": ["あははは"]}, {"box": [1140, 1273, 1213, 1429], "vertical": true, "font_size": 32, "lines_coords": [[[1181.0, 1275.0], [1213.0, 1275.0], [1213.0, 1428.0], [1181.0, 1428.0]], [[1140.0, 1273.0], [1171.0, 1273.0], [1171.0, 1398.0], [1140.0, 1398.0]]], "lines": ["二人は怖く", "ないの？"]}, {"box": [690, 1262, 795, 1649], "vertical": true, "font_size": 40, "lines_coords": [[[740.0, 1263.0], [780.0, 1263.0], [780.0, 1648.0], [740.0, 1648.0]], [[690.0, 1263.0], [729.0, 1263.0], [729.0, 1588.0], [690.0, 1588.0]]], "lines": ["昨日デス・ブリッジを", "渡って来たからさ"]}, {"box": [847, 1608, 923, 1745], "vertical": true, "font_size": 32, "lines_coords": [[[890.0, 1608.0], [922.0, 1608.0], [922.0, 1745.0], [890.0, 1745.0]], [[847.0, 1608.0], [879.0, 1608.0], [879.0, 1745.0], [847.0, 1745.0]]], "lines": ["あははは", "私らはー"]}, {"box": [97, 1584, 200, 1730], "vertical": true, "font_size": 52, "lines_coords": [[[142.0, 1584.0], [200.0, 1584.0], [200.0, 1680.0], [142.0, 1680.0]], [[97.0, 1584.0], [144.0, 1584.0], [144.0, 1730.0], [97.0, 1730.0]]], "lines": ["全然", "効かん。"]}], "img_path": "00123.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1117, 153, 1179, 358], "vertical": true, "font_size": 28, "lines_coords": [[[1153.0, 153.0], [1179.0, 153.0], [1179.0, 316.0], [1153.0, 316.0]], [[1117.0, 153.0], [1143.0, 153.0], [1143.0, 358.0], [1117.0, 358.0]]], "lines": ["そうだ昨日", "調べたんだけど"]}, {"box": [954, 202, 1057, 436], "vertical": true, "font_size": 28, "lines_coords": [[[1025.0, 202.0], [1057.0, 202.0], [1057.0, 436.0], [1025.0, 436.0]], [[990.0, 202.0], [1018.0, 202.0], [1016.0, 406.0], [988.0, 406.0]], [[954.0, 202.0], [980.0, 202.0], [980.0, 406.0], [954.0, 406.0]]], "lines": ["この奥に畑薙より", "ヤバい吊り橋が", "あるみたいだよ"]}, {"box": [140, 159, 260, 435], "vertical": true, "font_size": 36, "lines_coords": [[[223.0, 159.0], [260.0, 159.0], [260.0, 386.0], [223.0, 386.0]], [[180.0, 159.0], [217.0, 159.0], [219.0, 435.0], [181.0, 435.0]], [[140.0, 161.0], [172.0, 161.0], [172.0, 300.0], [140.0, 300.0]]], "lines": ["えっ！？あれが", "この辺で最強じゃ", "ないの！？"]}, {"box": [1151, 543, 1187, 694], "vertical": true, "font_size": 32, "lines_coords": [[[1153.0, 543.0], [1185.0, 543.0], [1185.0, 693.0], [1153.0, 693.0]]], "lines": ["夢想吊橋"]}, {"box": [941, 504, 1098, 1121], "vertical": true, "font_size": 53, "lines_coords": [[[1048.0, 513.0], [1098.0, 513.0], [1095.0, 841.0], [1044.0, 841.0]], [[999.0, 511.0], [1050.0, 511.0], [1050.0, 980.0], [999.0, 980.0]], [[946.0, 504.0], [1005.0, 504.0], [999.0, 1121.0], [941.0, 1121.0]]], "lines": ["全長Ｍａ高さ８８ｍ", "林作業用に作られた橋で", "日本一怖い吊り橋として知られる"]}, {"box": [1115, 1209, 1185, 1487], "vertical": true, "font_size": 29, "lines_coords": [[[1153.0, 1209.0], [1185.0, 1209.0], [1183.0, 1486.0], [1151.0, 1486.0]], [[1117.0, 1211.0], [1143.0, 1211.0], [1143.0, 1486.0], [1117.0, 1486.0]]], "lines": ["高さ８３ｍって畑薙の", "３倍近くあるじゃん"]}, {"box": [860, 1250, 892, 1372], "vertical": true, "font_size": 32, "lines_coords": [[[860.0, 1250.0], [892.0, 1250.0], [892.0, 1372.0], [860.0, 1372.0]]], "lines": ["ひぃいい"]}, {"box": [549, 1194, 635, 1470], "vertical": true, "font_size": 27, "lines_coords": [[[609.0, 1194.0], [635.0, 1194.0], [635.0, 1466.0], [609.0, 1466.0]], [[575.0, 1194.0], [601.0, 1194.0], [601.0, 1391.0], [575.0, 1391.0]], [[549.0, 1194.0], [573.0, 1194.0], [573.0, 1470.0], [549.0, 1470.0]]], "lines": ["しかも老朽化が進んでて", "いつ積が落ちても", "おかしくないんだってさ"]}, {"box": [523, 1543, 588, 1768], "vertical": true, "font_size": 27, "lines_coords": [[[553.0, 1543.0], [588.0, 1543.0], [588.0, 1631.0], [553.0, 1631.0]], [[523.0, 1546.0], [549.0, 1546.0], [549.0, 1768.0], [523.0, 1768.0]]], "lines": ["何その", "ロシアン吊り橋！！"]}, {"box": [183, 1824, 900, 1852], "vertical": false, "font_size": 26, "lines_coords": [[[183.0, 1824.0], [900.0, 1826.0], [900.0, 1852.0], [183.0, 1850.0]]], "lines": ["現在、夢想吊橋はほぼ崩壊してしまっていいるので渡れませんよ。"]}], "img_path": "00124.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1125, 390, 1189, 555], "v