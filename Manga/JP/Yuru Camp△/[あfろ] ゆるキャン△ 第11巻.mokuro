0], [206.0, 1683.0], [180.0, 1683.0]]], "lines": ["確かにカタい", "感じするなー"]}], "img_path": "00163.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1149, 135, 1215, 440], "vertical": true, "font_size": 29, "lines_coords": [[[1183.0, 135.0], [1215.0, 135.0], [1215.0, 440.0], [1183.0, 440.0]], [[1149.0, 135.0], [1175.0, 135.0], [1175.0, 328.0], [1149.0, 328.0]]], "lines": ["リンちゃんはカタカナで", "かっこいいよね"]}, {"box": [555, 138, 665, 356], "vertical": true, "font_size": 30, "lines_coords": [[[635.0, 142.0], [661.0, 142.0], [661.0, 356.0], [635.0, 356.0]], [[594.0, 140.0], [626.0, 140.0], [626.0, 328.0], [594.0, 328.0]], [[555.0, 138.0], [588.0, 138.0], [588.0, 236.0], [555.0, 236.0]]], "lines": ["あおいちゃんは", "何でひらがな", "なの？"]}, {"box": [728, 299, 796, 654], "vertical": true, "font_size": 26, "lines_coords": [[[766.0, 303.0], [793.0, 303.0], [793.0, 654.0], [766.0, 654.0]], [[729.0, 303.0], [755.0, 303.0], [755.0, 626.0], [729.0, 626.0]]], "lines": ["何でかは聞いた事無いけど、", "名前書く時楽でいいかな"]}, {"box": [187, 313, 299, 534], "vertical": true, "font_size": 30, "lines_coords": [[[268.0, 316.0], [294.0, 316.0], [294.0, 526.0], [268.0, 526.0]], [[226.0, 315.0], [258.0, 315.0], [258.0, 534.0], [226.0, 534.0]], [[187.0, 313.0], [219.0, 313.0], [219.0, 470.0], [187.0, 470.0]]], "lines": ["ホンマは漢字で", "「葵」になるはず", "やったんよ"]}, {"box": [1027, 697, 1211, 1113], "vertical": true, "font_size": 39, "lines_coords": [[[1162.0, 697.0], [1211.0, 697.0], [1211.0, 783.0], [1162.0, 783.0]], [[1119.0, 701.0], [1156.0, 701.0], [1156.0, 1035.0], [1119.0, 1035.0]], [[1074.0, 703.0], [1111.0, 703.0], [1111.0, 1113.0], [1074.0, 1113.0]], [[1031.0, 705.0], [1063.0, 705.0], [1063.0, 1111.0], [1031.0, 1111.0]]], "lines": ["けど", "出生届を出す直前に", "おばあちゃんが気づいて", "ひらがなに変えたんやて"]}, {"box": [328, 705, 366, 901], "vertical": true, "font_size": 37, "lines_coords": [[[328.0, 705.0], [365.0, 705.0], [365.0, 901.0], [328.0, 901.0]]], "lines": ["えっ？何で"]}, {"box": [151, 798, 228, 1035], "vertical": true, "font_size": 30, "lines_coords": [[[193.0, 798.0], [225.0, 798.0], [225.0, 1020.0], [193.0, 1020.0]], [[151.0, 798.0], [178.0, 798.0], [178.0, 1035.0], [151.0, 1035.0]]], "lines": ["そうか、名字と", "名前つなけると"]}, {"box": [155, 1156, 235, 1611], "vertical": true, "font_size": 32, "lines_coords": [[[200.0, 1158.0], [232.0, 1158.0], [232.0, 1603.0], [200.0, 1603.0]], [[155.0, 1156.0], [187.0, 1156.0], [187.0, 1599.0], [155.0, 1599.0]]], "lines": ["漢字が読めるようになった頃", "アダ名が変わるパターンだな"]}, {"box": [1080, 1222, 1171, 1672], "vertical": true, "font_size": 38, "lines_coords": [[[1130.0, 1222.0], [1170.0, 1222.0], [1170.0, 1672.0], [1130.0, 1672.0]], [[1080.0, 1222.0], [1117.0, 1222.0], [1117.0, 1668.0], [1080.0, 1668.0]]], "lines": ["せゃ危ぅく「いぬわさび」", "にされるとこやったんや．．．"]}, {"box": [581, 1175, 857, 1762], "vertical": true, "font_size": 161, "lines_coords": [[[581.0, 1261.0], [742.0, 1256.0], [757.0, 1756.0], [596.0, 1762.0]]], "lines": ["ノ山葵"]}], "img_path": "00164.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1151, 187, 1200, 562], "vertical": true, "font_size": 45, "lines_coords": [[[1153.0, 187.0], [1198.0, 187.0], [1198.0, 562.0], [1153.0, 562.0]]], "lines": ["静梨富士山論争に"]}, {"box": [121, 75, 470, 106], "vertical": false, "font_size": 31, "lines_coords": [[[121.0, 75.0], [470.0, 75.0], [470.0, 106.0], [121.0, 106.0]]], "lines": ["放課後９２争いの終結"]}, {"box": [151, 195, 252, 618], "vertical": true, "font_size": 42, "lines_coords": [[[206.0, 195.0], [251.0, 195.0], [251.0, 571.0], [206.0, 571.0]], [[153.0, 198.0], [193.0, 198.0], [193.0, 618.0], [153.0, 618.0]]], "lines": ["とうとう終わりが", "見えたかもしれん！！"]}, {"box": [1117, 721, 1204, 1134], "vertical": true, "font_size": 38, "lines_coords": [[[1164.0, 723.0], [1201.0, 723.0], [1201.0, 1134.0], [1164.0, 1134.0]], [[1117.0, 721.0], [1155.0, 721.0], [1155.0, 1042.0], [1117.0, 1042.0]]], "lines": ["この不毛の争いがやっと", "終わるんか、あき！？"]}, {"box": [613, 926, 711, 1188], "vertical": true, "font_size": 40, "lines_coords": [[[665.0, 928.0], [706.0, 928.0], [710.0, 1147.0], [669.0, 1147.0]], [[613.0, 926.0], [652.0, 926.0], [656.0, 1188.0], [616.0, 1188.0]]], "lines": ["あきちゃん", "くわしくっ！！"]}, {"box": [174, 1021, 215, 1110], "vertical": true, "font_size": 41, "lines_coords": [[[174.0, 1021.0], [215.0, 1021.0], [215.0, 1110.0], [174.0, 1110.0]]], "lines": ["うむ"]}, {"box": [349, 1307, 429, 1529], "vertical": true, "font_size": 32, "lines_coords": [[[395.0, 1310.0], [427.0, 1310.0], [427.0, 1492.0], [395.0, 1492.0]], [[350.0, 1308.0], [382.0, 1308.0], [382.0, 1528.0], [350.0, 1528.0]]], "lines": ["あの大きく", "崩れた谷やろ"]}, {"box": [1117, 1294, 1199, 1704], "vertical": true, "font_size": 33, "lines_coords": [[[1164.0, 1295.0], [1198.0, 1295.0], [1196.0, 1591.0], [1162.0, 1591.0]], [[1119.0, 1297.0], [1151.0, 1297.0], [1151.0, 1704.0], [1119.0, 1704.0]]], "lines": ["富士山西側にある", "大沢崩れは知っているな"]}, {"box": [150, 1384, 255, 1720], "vertical": true, "font_size": 29, "lines_coords": [[[219.0, 1385.0], [255.0, 1385.0], [255.0, 1477.0], [219.0, 1477.0]], [[185.0, 1387.0], [211.0, 1387.0], [211.0, 1719.0], [185.0, 1719.0]], [[150.0, 1385.0], [176.0, 1385.0], [176.0, 1623.0], [150.0, 1623.0]]], "lines": ["そうだ", "実はあの谷今も少しずつ", "崩れているらしく"]}], "img_path": "00165.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1055, 145, 1188, 596], "vertical": true, "font_size": 37, "lines_coords": [[[1149.0, 146.0], [1186.0, 146.0], [1186.0, 594.0], [1149.0, 594.0]], [[1104.0, 146.0], [1141.0, 146.0], [1141.0, 596.0], [1104.0, 596.0]], [[1057.0, 146.0], [1095.0, 146.0], [1095.0, 556.0], [1057.0, 556.0]]], "lines": ["そのうち山梨側と静岡側で", "まっ二つに割れちまう事が", "判明したんズラーーっ！！！"]}, {"box": [763, 384, 810, 495], "vertical": true, "font_size": 47, "lines_coords": [[[763.0, 384.0], [810.0, 384.0], [810.0, 495.0], [763.0, 495.0]]], "lines": ["背宙を"]}, {"box": [468, 384, 510, 494], "vertical": true, "font_size": 42, "lines_coords": [[[468.0, 384.0], [510.0, 384.0], [510.0, 493.0], [468.0, 493.0]]], "lines": ["梨富士"]}, {"box": [198, 157,