], [[333.0, 150.0], [375.0, 150.0], [375.0, 245.0], [333.0, 245.0]]], "lines": ["ホント", "ホント"]}, {"box": [193, 365, 260, 544], "vertical": true, "font_size": 32, "lines_coords": [[[223.0, 365.0], [260.0, 365.0], [260.0, 431.0], [223.0, 431.0]], [[193.0, 369.0], [219.0, 369.0], [219.0, 543.0], [193.0, 543.0]]], "lines": ["えー", "そうかなぁ？"]}, {"box": [1128, 725, 1196, 949], "vertical": true, "font_size": 30, "lines_coords": [[[1168.0, 727.0], [1194.0, 727.0], [1194.0, 948.0], [1168.0, 948.0]], [[1128.0, 725.0], [1162.0, 725.0], [1162.0, 825.0], [1128.0, 825.0]]], "lines": ["まーなでしこって", "犬だし。"]}, {"box": [675, 784, 704, 870], "vertical": true, "font_size": 28, "lines_coords": [[[675.0, 785.0], [703.0, 785.0], [703.0, 870.0], [675.0, 870.0]]], "lines": ["わかる"]}, {"box": [536, 698, 600, 1008], "vertical": true, "font_size": 26, "lines_coords": [[[571.0, 701.0], [598.0, 701.0], [598.0, 1006.0], [571.0, 1006.0]], [[536.0, 699.0], [560.0, 699.0], [560.0, 948.0], [536.0, 948.0]]], "lines": ["そういえば小学１〜２年", "くらいの頃だったが、"]}, {"box": [136, 680, 199, 1042], "vertical": true, "font_size": 24, "lines_coords": [[[172.0, 680.0], [196.0, 680.0], [196.0, 988.0], [172.0, 988.0]], [[136.0, 682.0], [161.0, 682.0], [161.0, 1042.0], [136.0, 1042.0]]], "lines": ["なでしこんちの買い物に", "ついて行った時なんだけどさ"]}, {"box": [842, 1069, 1047, 1128], "vertical": false, "font_size": 25, "lines_coords": [[[853.0, 1070.0], [1033.0, 1070.0], [1033.0, 1096.0], [853.0, 1096.0]], [[843.0, 1102.0], [1044.0, 1102.0], [1044.0, 1126.0], [843.0, 1126.0]]], "lines": ["みんなＤＡＩＳＵＫ、", "おさんほＣＤＡＩＳＵＫ"]}, {"box": [1135, 1226, 1203, 1567], "vertical": true, "font_size": 26, "lines_coords": [[[1173.0, 1230.0], [1200.0, 1230.0], [1200.0, 1473.0], [1173.0, 1473.0]], [[1136.0, 1230.0], [1162.0, 1230.0], [1162.0, 1567.0], [1136.0, 1567.0]]], "lines": ["なでしこが途中で", "いなくなったと思ったら"]}, {"box": [712, 990, 742, 1085], "vertical": true, "font_size": 30, "lines_coords": [[[712.0, 990.0], [742.0, 990.0], [742.0, 1035.0], [712.0, 1035.0]]], "lines": ["えー"]},