53.0], [275.0, 1353.0], [277.0, 1743.0], [249.0, 1743.0]], [[215.0, 1353.0], [241.0, 1353.0], [241.0, 1603.0], [215.0, 1603.0]]], "lines": ["山梨もお隣なのに遠いのよねぇ", "山があるおかげでー"]}], "img_path": "00036.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1138, 138, 1210, 530], "vertical": true, "font_size": 27, "lines_coords": [[[1175.0, 140.0], [1201.0, 140.0], [1201.0, 504.0], [1175.0, 504.0]], [[1138.0, 138.0], [1166.0, 138.0], [1168.0, 530.0], [1140.0, 530.0]]], "lines": ["昔は山伏峠を通って早川から", "甲府へ行ってたんだけどねぇー"]}, {"box": [562, 141, 633, 453], "vertical": true, "font_size": 32, "lines_coords": [[[601.0, 142.0], [633.0, 142.0], [633.0, 298.0], [601.0, 298.0]], [[562.0, 142.0], [594.0, 142.0], [594.0, 453.0], [562.0, 453.0]]], "lines": ["もしかして", "雨畑を通る道ですか？"]}, {"box": [155, 258, 187, 384], "vertical": true, "font_size": 32, "lines_coords": [[[155.0, 258.0], [187.0, 258.0], [187.0, 384.0], [155.0, 384.0]]], "lines": ["そうだよ"]}, {"box": [754, 556, 778, 610], "vertical": true, "font_size": 24, "lines_coords": [[[754.0, 556.0], [778.0, 556.0], [778.0, 610.0], [754.0, 610.0]]], "lines": ["！"]}, {"box": [144, 499, 173, 652], "vertical": true, "font_size": 26, "lines_coords": [[[144.0, 500.0], [170.0, 500.0], [170.0, 652.0], [144.0, 652.0]]], "lines": ["あめはた？"]}, {"box": [274, 808, 337, 1003], "vertical": true, "font_size": 24, "lines_coords": [[[309.0, 811.0], [335.0, 811.0], [335.0, 1003.0], [309.0, 1003.0]], [[277.0, 811.0], [298.0, 811.0], [298.0, 946.0], [277.0, 946.0]]], "lines": ["一月末に行って", "来たんだよ"]}, {"box": [1110, 771, 1174, 1164], "vertical": true, "font_size": 26, "lines_coords": [[[1143.0, 776.0], [1170.0, 776.0], [1170.0, 1083.0], [1143.0, 1083.0]], [[1110.0, 774.0], [1136.0, 774.0], [1136.0, 1164.0], [1110.0, 1164.0]]], "lines": ["山梨に雨畑林道って言う", "井川に通じる道があるんだけど"]}, {"box": [1149, 1205, 1209, 1603], "vertical": true, "font_size": 26, "lines_coords": [[[1181.0, 1209.0], [1207.0, 1209.0], [1207.0, 1603.0], [1181.0, 1603.0]], [[1149.0, 1209.0], [1175.0, 1209.0], [1175.0, 1578.0], [1149.0, 1578.0]]], "lines": ["今は通行止めて通れないですけど、", "それっていつの話なんですか？"]}, {"box": [127, 943, 166, 1044], "vertical": true, "font_size": 39, "lines_coords": [[[127.0, 943.0], [166.0, 943.0], [166.0, 1044.0], [127.0, 1044.0]]], "lines": ["ふーん"]}, {"box": [339, 1250, 399, 1430], "vertical": true, "font_size": 60, "lines_coords": [[[339.0, 1250.0], [399.0, 1250.0], [399.0, 1430.0], [339.0, 1430.0]]], "lines": ["３０年！？"]}, {"box": [909, 1439, 971, 1730], "vertical": true, "font_size": 25, "lines_coords": [[[943.0, 1440.0], [969.0, 1440.0], [969.0, 1730.0], [943.0, 1730.0]], [[909.0, 1440.0], [933.0, 1440.0], [933.0, 1663.0], [909.0, 1663.0]]], "lines": ["そうだねぇ、私が子育て", "してた頃だからー"]}, {"box": [804, 1365, 843, 1773], "vertical": true, "font_size": 37, "lines_coords": [[[804.0, 1365.0], [841.0, 1365.0], [841.0, 1773.0], [804.0, 1773.0]]], "lines": ["３０年くらい前の話だねぇ"]}, {"box": [113, 1393, 144, 1755], "vertical": true, "font_size": 26, "lines_coords": [[[114.0, 1393.0], [140.0, 1393.0], [140.0, 1755.0], [114.0, 1755.0]]], "lines": ["直すお金がないんだねきっと"]}], "img_path": "00037.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1190, 195, 1259, 622], "vertical": true, "font_size": 29, "lines_coords": [[[1230.0, 195.0], [1256.0, 195.0], [1256.0, 622.0], [1230.0, 622.0]], [[1190.0, 198.0], [1222.0, 198.0], [1222.0, 609.0], [1190.0, 609.0]]], "lines": ["そうだ山伏へ行く途中に井川を", "一望出来る高原があるんだけど"]}, {"box": [264, 168, 367, 461], "vertical": true, "font_size": 28, "lines_coords": [[[333.0, 168.0], [365.0, 168.0], [365.0, 376.0], [333.0, 376.0]], [[301.0, 170.0], [328.0, 170.0], [328.0, 461.0], [301.0, 461.0]], [[264.0, 172.0], [290.0, 172.0], [290.0, 346.0], [264.0, 346.0]]], "lines": ["時間があるなら", "行ってみたらどうだい", "いい所だよ？"]}, {"box": [603, 806, 671, 1031], "vertical": true, "font_size": 32, "lines_coords": [[[639.0, 808.0], [671.0, 808.0], [671.0, 922.0], [639.0, 922.0]], [[603.0, 806.0], [635.0, 806.0], [637.0, 1031.0], [605.0, 1031.0]]], "lines": ["まだ営業", "してないんだって"]}, {"box": [196, 423, 228, 609], "vertical": true, "font_size": 33, "lines_coords": [[[196.0, 423.0], [228.0, 423.0], [228.0, 609.0], [196.0, 609.0]]], "lines": ["高原ですかー"]}, {"box": [138, 508, 172, 609], "vertical": true, "font_size": 33, "lines_coords": [[[138.0, 508.0], [172.0, 508.0], [172.0, 609.0], [138.0, 609.0]]], "lines": ["へぇー"]}, {"box": [260, 804, 322, 971], "vertical": true, "font_size": 29, "lines_coords": [[[290.0, 804.0], [322.0, 804.0], [322.0, 922.0], [290.0, 922.0]], [[260.0, 804.0], [286.0, 804.0], [286.0, 971.0], [260.0, 971.0]]], "lines": ["また今度", "行ってみてね"]}, {"box": [1151, 898, 1216, 1208], "vertical": true, "font_size": 30, "lines_coords": [[[1188.0, 901.0], [1215.0, 901.0], [1215.0, 1207.0], [1188.0, 1207.0]], [[1151.0, 898.0], [1183.0, 898.0], [1183.0, 1126.0], [1151.0, 1126.0]]], "lines": ["今はまだやってないわよ", "春営業は４月から"]}, {"box": [1149, 1276, 1213, 1419], "vertical": true, "font_size": 29, "lines_coords": [[[1181.0, 1276.0], [1213.0, 1276.0], [1213.0, 1393.0], [1181.0, 1393.0]], [[1149.0, 1280.0], [1175.0, 1280.0], [1175.0, 1419.0], [1149.0, 1419.0]]], "lines": ["ごちそう", "さまでした"]}, {"box": [886, 1031, 952, 1203], "vertical": true, "font_size": 32, "lines_coords": [[[916.0, 1031.0], [952.0, 1031.0], [952.0, 1121.0], [916.0, 1121.0]], [[886.0, 1035.0], [913.0, 1035.0], [913.0, 1203.0], [886.0, 1203.0]]], "lines": ["あれっ", "そうだっけ？"]}, {"box": [826, 1521, 894, 1707], "vertical": true, "font_size": 26, "lines_coords": [[[864.0, 1524.0], [890.0, 1524.0], [890.0, 1706.0], [864.0, 1706.0]], [[826.0, 1522.0], [853.0, 1522.0], [853.0, 1706.0], [826.0, 1706.0]]], "lines": ["お姉さんたち", "ありがとねー"]}, {"box": [690, 1270, 766, 1737], "vertical": true, "font_size": 32, "lines_coords": [[[731.0, 1271.0], [763.0, 1271.0], [763.0, 1586.0], [731.0, 1586.0]], [[690.0, 1271.0], [721.0, 1271.0], [723.0, 1736.0], [691.0, 1736.0]]], "lines": ["おでん美味しかったし、", "興味深い音話も聞けてよかったな"]}], "img_path": "00038.jpg"}, {"version": "0.1.6", "img_width": 1350,