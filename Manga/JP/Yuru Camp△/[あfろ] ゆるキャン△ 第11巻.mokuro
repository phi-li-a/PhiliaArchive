721.0, 1666.0], [695.0, 1666.0]]], "lines": ["でも一方通行で北斗市からは", "戻って来れないらしいよ"]}, {"box": [148, 1575, 177, 1698], "vertical": true, "font_size": 26, "lines_coords": [[[148.0, 1575.0], [174.0, 1575.0], [174.0, 1698.0], [148.0, 1698.0]]], "lines": ["こわっ！！"]}], "img_path": "00175.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1130, 138, 1202, 705], "vertical": true, "font_size": 30, "lines_coords": [[[1171.0, 148.0], [1198.0, 148.0], [1198.0, 643.0], [1171.0, 643.0]], [[1130.0, 144.0], [1162.0, 144.0], [1162.0, 705.0], [1130.0, 705.0]]], "lines": ["その森の近くを歩いているとたまに", "見えない位まで引き伸ばされた人たちの"]}, {"box": [883, 256, 1021, 328], "vertical": false, "font_size": 27, "lines_coords": [[[883.0, 303.0], [1012.0, 256.0], [1021.0, 281.0], [892.0, 328.0]]], "lines": ["＼コンニ４ワ／"]}, {"box": [420, 253, 575, 333], "vertical": false, "font_size": 32, "lines_coords": [[[431.0, 253.0], [575.0, 303.0], [566.0, 333.0], [420.0, 283.0]]], "lines": ["いつシミィワノ"]}, {"box": [191, 165, 265, 510], "vertical": true, "font_size": 33, "lines_coords": [[[226.0, 165.0], [260.0, 165.0], [262.0, 354.0], [228.0, 354.0]], [[191.0, 165.0], [223.0, 165.0], [223.0, 510.0], [191.0, 510.0]]], "lines": ["悲痛な叫びが", "聞こえてくるっていう．．．"]}, {"box": [155, 626, 268, 774], "vertical": true, "font_size": 60, "lines_coords": [[[213.0, 626.0], [268.0, 626.0], [268.0, 768.0], [213.0, 768.0]], [[155.0, 628.0], [219.0, 628.0], [219.0, 774.0], [155.0, 774.0]]], "lines": ["ひいい", "いいー"]}, {"box": [1174, 960, 1206, 1237], "vertical": true, "font_size": 26, "lines_coords": [[[1177.0, 960.0], [1203.0, 960.0], [1203.0, 1237.0], [1177.0, 1237.0]]], "lines": ["この話ホントなの？"]}, {"box": [1016, 931, 1042, 1081], "vertical": true, "font_size": 30, "lines_coords": [[[1016.0, 931.0], [1042.0, 931.0], [1042.0, 1081.0], [1016.0, 1081.0]]], "lines": ["わかんない"]}, {"box": [853, 967, 961, 1218], "vertical": true, "font_size": 30, "lines_coords": [[[930.0, 967.0], [961.0, 967.0], [961.0, 1188.0], [930.0, 1188.0]], [[888.0, 96