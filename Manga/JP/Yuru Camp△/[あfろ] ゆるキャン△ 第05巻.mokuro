0], [611.0, 326.0]], [[570.0, 151.0], [603.0, 151.0], [600.0, 360.0], [566.0, 360.0]]], "lines": ["洞窟に潜る", "「ケイビング」"]}, {"box": [1095, 786, 1169, 1050], "vertical": true, "font_size": 34, "lines_coords": [[[1130.0, 787.0], [1168.0, 787.0], [1168.0, 1050.0], [1130.0, 1050.0]], [[1095.0, 787.0], [1126.0, 787.0], [1126.0, 1050.0], [1095.0, 1050.0]]], "lines": ["私「ボルダリング」", "やってみたいなー"]}, {"box": [163, 318, 232, 693], "vertical": true, "font_size": 29, "lines_coords": [[[200.0, 318.0], [232.0, 318.0], [232.0, 693.0], [200.0, 693.0]], [[163.0, 322.0], [189.0, 322.0], [189.0, 536.0], [163.0, 536.0]]], "lines": ["アウトドアのスポーツって", "色々あるよなー"]}, {"box": [258, 808, 331, 1091], "vertical": true, "font_size": 32, "lines_coords": [[[296.0, 810.0], [328.0, 810.0], [328.0, 1061.0], [296.0, 1061.0]], [[258.0, 808.0], [290.0, 808.0], [290.0, 1091.0], [258.0, 1091.0]]], "lines": ["「ボルダリング」は", "浸透して来とるよね"]}, {"box": [1126, 1215, 1201, 1479], "vertical": true, "font_size": 34, "lines_coords": [[[1164.0, 1215.0], [1201.0, 1215.0], [1201.0, 1479.0], [1164.0, 1479.0]], [[1126.0, 1222.0], [1158.0, 1222.0], [1158.0, 1447.0], [1126.0, 1447.0]]], "lines": ["「カヌーイング」に", "「ボタリング」．．．"]}, {"box": [137, 1027, 219, 1155], "vertical": true, "font_size": 35, "lines_coords": [[[180.0, 1065.0], [215.0, 1065.0], [215.0, 1155.0], [180.0, 1155.0]]], "lines": ["中府に"]}, {"box": [151, 1404, 261, 1732], "vertical": true, "font_size": 31, "lines_coords": [[[228.0, 1406.0], [260.0, 1406.0], [260.0, 1556.0], [228.0, 1556.0]], [[191.0, 1404.0], [223.0, 1404.0], [221.0, 1732.0], [189.0, 1732.0]], [[155.0, 1406.0], [183.0, 1406.0], [180.0, 1554.0], [151.0, 1554.0]]], "lines": ["渓谷を下る", "「キャニオニング」てのも", "あるんやー"]}], "img_path": "00175.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1101, 165, 1183, 442], "vertical": true, "font_size": 37, "lines_coords": [[[1143.0, 165.0], [1183.0, 165.0], [1179.0, 442.0], [1140.0, 442.0]], [[1102.0, 172.0], [1136.0, 172.0], [1136.0, 305.0], [1102.0, 305.0]]], "lines": ["「トレッキング」は", "山歩きで"]}, {"box": [170, 189, 253, 500], "vertical": true, "font_size": 39, "lines_coords": [[[213.0, 189.0], [253.0, 189.0], [253.0, 466.0], [213.0, 466.0]], [[170.0, 191.0], [208.0, 191.0], [208.0, 500.0], [170.0, 500.0]]], "lines": ["「ツリーイング」は", "木登りの事なんだね"]}, {"box": [1130, 659, 1210, 808], "vertical": true, "font_size": 33, "lines_coords": [[[1175.0, 660.0], [1209.0, 660.0], [1209.0, 806.0], [1175.0, 806.0]], [[1130.0, 660.0], [1162.0, 660.0], [1162.0, 808.0], [1130.0, 808.0]]], "lines": ["まだまだ", "あるぞ！！"]}, {"box": [607, 663, 682, 916], "vertical": true, "font_size": 35, "lines_coords": [[[648.0, 665.0], [680.0, 665.0], [680.0, 881.0], [648.0, 881.0]], [[607.0, 665.0], [645.0, 665.0], [645.0, 916.0], [607.0, 916.0]]], "lines": ["外で犬と戯れる", "「イヌーイング」！！"]}, {"box": [140, 645, 213, 988], "vertical": true, "font_size": 32, "lines_coords": [[[180.0, 645.0], [211.0, 645.0], [211.0, 988.0], [180.0, 988.0]], [[140.0, 648.0], [172.0, 648.0], [172.0, 961.0], [140.0, 961.0]]], "lines": ["森で松ぼっくりを集める", "「マツボックリング」！？"]}, {"box": [1042, 1211, 1150, 1539], "vertical": true, "font_size": 32, "lines_coords": [[[1115.0, 1211.0], [1147.0, 1211.0], [1147.0, 1419.0], [1115.0, 1419.0]], [[1080.0, 1215.0], [1111.0, 1215.0], [1111.0, 1539.0], [1080.0, 1539.0]], [[1042.0, 1213.0], [1074.0, 1213.0], [1074.0, 1425.0], [1042.0, 1425.0]]], "lines": ["真冬の本栖湖で", "一人読書キャンプをする", "「シマリング」！！"]}, {"box": [275, 1306, 350, 1636], "vertical": true, "font_size": 30, "lines_coords": [[[315.0, 1308.0], [348.0, 1308.0], [350.0, 1636.0], [316.0, 1636.0]], [[275.0, 1306.0], [307.0, 1306.0], [307.0, 1537.0], [275.0, 1537.0]]], "lines": ["わたしも「シマリング」", "したいですっ！！"]}, {"box": [162, 1506, 228, 1715], "vertical": true, "font_size": 66, "lines_coords": [[[162.0, 1506.0], [228.0, 1506.0], [228.0, 1715.0], [162.0, 1715.0]]], "lines": ["おちつきやーなでしこちゃん"]}, {"box": [161, 1505, 225, 1719], "vertical": true, "font_size": 30, "lines_coords": [[[198.0, 1505.0], [225.0, 1505.0], [225.0, 1687.0], [198.0, 1687.0]], [[161.0, 1505.0], [187.0, 1505.0], [187.0, 1719.0], [161.0, 1719.0]]], "lines": ["おちつきやー", "なでしこちゃん"]}], "img_path": "00176.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1113, 172, 1192, 620], "vertical": true, "font_size": 38, "lines_coords": [[[1155.0, 172.0], [1192.0, 172.0], [1192.0, 618.0], [1155.0, 618.0]], [[1113.0, 172.0], [1151.0, 172.0], [1151.0, 620.0], [1113.0, 620.0]]], "lines": ["十德ナイフって一本あったら", "キャンプに便利そうだよねぇ"]}, {"box": [123, 67, 476, 103], "vertical": false, "font_size": 32, "lines_coords": [[[123.0, 67.0], [476.0, 71.0], [476.0, 103.0], [123.0, 99.0]]], "lines": ["放課後４２宝の持ち腐れ"]}, {"box": [163, 157, 241, 430], "vertical": true, "font_size": 29, "lines_coords": [[[208.0, 159.0], [234.0, 159.0], [234.0, 425.0], [208.0, 425.0]], [[163.0, 157.0], [195.0, 157.0], [195.0, 292.0], [163.0, 292.0]]], "lines": ["たまに持ってる人", "おるよね"]}, {"box": [266, 534, 344, 856], "vertical": true, "font_size": 33, "lines_coords": [[[307.0, 534.0], [341.0, 534.0], [339.0, 856.0], [305.0, 856.0]], [[266.0, 534.0], [298.0, 534.0], [298.0, 740.0], [266.0, 740.0]]], "lines": ["ザ・アウトドアツール", "て感じだしな"]}, {"box": [1130, 960, 1214, 1296], "vertical": true, "font_size": 32, "lines_coords": [[[1177.0, 961.0], [1209.0, 961.0], [1209.0, 1295.0], [1177.0, 1295.0]], [[1130.0, 960.0], [1162.0, 960.0], [1162.0, 1295.0], [1130.0, 1295.0]]], "lines": ["けどコルク抜きとか", "私らには不要だよな"]}, {"box": [1036, 1068, 1074, 1207], "vertical": true, "font_size": 32, "lines_coords": [[[1036.0, 1070.0], [1068.0, 1068.0], [1074.0, 1205.0], [1042.0, 1207.0]]], "lines": ["酒飲まんし"]}, {"box": [579, 971, 660, 1318], "vertical": true, "font_size": 34, "lines_coords": [[[624.0, 971.0], [656.0, 971.0], [656.0, 1297.0], [624.0, 1297.0]], [[579.0, 971.0], [616.0, 971.0], [616.0, 1318.0], [579.0, 1318.0]]], "lines": ["せや最近の缶詰って", "殆どプルトップやから"]}, {"box": [148, 991, 183, 1267], "vertical": true, "font_size": 32, "lines_coords": [[[148.0, 993.0], [180.0, 993.0], [180.0, 1267.0], [148.0, 1267.0]]], "lines": ["缶切りも使わんわ"]}, {"box": [746, 1548, 780, 1695], "vertical": true, "font_size": 32, "lines_coords": [[[746.0, 1550.0], [778.0, 1550.0], [778.0, 1693.0], [746.0, 1693.0]]], "lines": ["だよねー"]}, {"box": [170, 1528, 207, 1683], "vertical": true, "font_size": 34, "lines_coords": [[[170.0, 1528.0], [204.0, 1528.0], [206.0, 1683.0], [172.0, 1683.0]]], "lines": ["あそっか"]}], "img_path": "00177.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1102, 144, 1224, 526], "vertical": true, "font_size": 34, "lines_coords": [[[1186.0, 144.0], [1224.0, 144.0], [1222.0, 526.0], [1185.0, 526.0]], [[1145.0, 148.0], [1177.0, 148.0], [1177.0, 526.0], [1145.0, 526.0]], [[1102.0, 144.0], [1136.0, 144.0], [1136.0, 249.0], [1102.0, 249.0]]], "lines": ["ノコギリも使わなくね？", "薪は売ってる奴そのまま", "使うし"]}, {"box": [568, 176, 656, 515], "vertical": true, "font_size": 38, "lines_coords": [[[611.0, 176.0], [656.0, 176.0], [652.0, 483.0], [607.0, 483.0]], [[568.0, 183.0], [600.0, 183.0], [600.0, 515.0], [568.0, 515.0]]], "lines": ["あとドライバーも", "ヤスリも使わんで？"]}, {"box": [174, 330, 211, 521], "vertical": true, "font_size": 37, "lines_coords": [[[174.0, 330.0], [211.0, 330.0], [211.0, 521.0], [174.0, 521.0]]], "lines": ["たたしかに"]}, {"box": [714, 740, 759, 890], "vertical": true, "font_size": 45, "lines_coords": [[[714.0, 740.0], [759.0, 740.0], [759.0, 810.0], [714.0, 810.0]]], "lines": ["あー"]}, {"box": [996, 959, 1153, 1271], "vertical": true, "font_size": 35, "lines_coords": [[[1119.0, 960.0], [1151.0, 960.0], [1151.0, 1233.0], [1119.0, 1233.0]], [[1074.0, 960.0], [1111.0, 960.0], [1111.0, 1203.0], [1074.0, 1203.0]], [[1029.0, 960.0], [1066.0, 960.0], [1066.0, 1271.0], [1029.0, 1271.0]]], "lines": ["よく考えてみたら", "外で料理する時", "ナイフ使わないよ私"]}, {"box": [331, 1292, 638, 1330], "vertical": false, "font_size": 26, "lines_coords": [[[335.0, 1299.0], [633.0, 1299.0], [633.0, 1325.0], [335.0, 1325.0]]], "lines": ["野クル専用一徳ナイフ"]}], "img_path": "00178.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [116, 222, 905, 291], "vertical": false, "font_size": 27, "lines_coords": [[[191.0, 224.0], [474.0, 224.0], [474.0, 247.0], [191.0, 247.0]], [[123.0, 234.0], [570.0, 238.0], [570.0, 273.0], [123.0, 270.0]], [[116.0, 262.0], [547.0, 260.0], [547.0, 288.0], [116.0, 290.0]]], "lines": ["ヤン△Ｇいかがでしたでし", "ゆるキャン△６いかがで合同け年末～午昭けのしたでしょうか。トリンのハロキ", "今回は年末〜年明けの話とリンのソロキ"]}, {"box": [110, 344, 963, 453], "vertical": false, "font_size": 27, "lines_coords": [[[159.0, 346.0], [836.0, 346.0], [836.0, 369.0], [159.0, 369.0]], [[118.0, 365.0], [845.0, 365.0], [845.0, 395.0], [118.0, 395.0]], [[187.0, 384.0], [860.0, 384.0], [860.0, 412.0], [187.0, 412.0]], [[112.0, 395.0], [881.0, 397.0], [881.0, 446.0], [112.0, 444.0]], [[615.0, 427.0], [918.0, 427.0], [918.0, 450.0], [615.0, 450.0]], [[123.0, 427.0], [543.0, 427.0], [543.0, 450.0], [123.0, 450.0]]], "lines": ["中で道路凍結のため家まで帰れないといいう描写がありましたが", "やってきたんだろうになってしまうのは、キャンプ当日はポケポケットです。あという相当がありましたが、中学期冷え込んですが、", "フ当日はボカボカ陽気だったけど翌朝冷え込んで道路が凍結", "キャンプ当日はボカボカ腸気だったという事はよくありますので皆さんがけど翌朝冷え込んで道路が漢続も冬キャンプの際はお気をつけて", "シワの際はお気をつけ下さい", "という事はよくありますので皆さんも冬"]}, {"box": [116, 510, 260, 532], "vertical": false, "font_size": 22, "lines_coords": [[[116.0, 510.0], [260.0, 510.0], [260.0, 532.0], [116.0, 532.0]]], "lines": ["あｆろでした。"]}, {"box": [105, 995, 881, 1065], "vertical": false, "font_size": 34, "lines_coords": [[[418.0, 1002.0], [588.0, 992.0], [590.0, 1026.0], [420.0, 1036.0]], [[637.0, 1000.0], [695.0, 1000.0], [695.0, 1032.0], [637.0, 1032.0]], [[217.0, 992.0], [429.0, 1009.0], [427.0, 1041.0], [215.0, 1024.0]], [[105.0, 1013.0], [744.0, 1011.0], [744.0, 1062.0], [105.0, 1064.0]]], "lines": ["ド平成２９年６月号０日", "１０月号", "イムきららフォワードチェーチェックスロードの", "まんかタイムさららフォワードアップスキャンペース平成２８年７月１８日、２０１６月号〜１０月１０日１４日〜平成２９年３月"]}], "img_path": "00179.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [386, 795, 601, 898], "vertical": false, "font_size": 37.0, "lines_coords": [[[386.0, 798.0], [601.0, 795.0], [601.0, 834.0], [386.0, 838.0]], [[390.0, 864.0], [483.0, 864.0], [483.0, 898.0], [390.0, 898.0]]], "lines": ["著者：あｆろ", "©ａｆｒｏ"]}, {"box": [403, 609, 930, 678], "vertical": false, "font_size": 64, "lines_coords": [[[403.0, 609.0], [930.0, 615.0], [930.0, 678.0], [403.0, 673.0]]], "lines": ["ゆるキャン△，第５巻"]}, {"box": [386, 981, 958, 1228], "vertical": false, "font_size": 37, "lines_coords": [[[386.0, 993.0], [939.0, 988.0], [939.0, 1027.0], [386.0, 1033.0]], [[386.0, 1059.0], [682.0, 1059.0], [682.0, 1096.0], [386.0, 1096.0]], [[390.0, 1123.0], [793.0, 1126.0], [793.0, 1158.0], [390.0, 1155.0]], [[534.0, 1186.0], [941.0, 1188.0], [941.0, 1226.0], [534.0, 1224.0]]], "lines": ["電子版発行日：２０１８年１月１５日", "発行人・東・敬章の", "発行所：株式会社芳文社", "東京都文京区後楽１－２－１２"]}], "img_path": "00180.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [55, 684, 181, 904], "vertical": true, "font_size": 19, "lines_coords": [[[129.0, 688.0], [148.0, 688.0], [148.0, 800.0], [129.0, 800.0]]], "lines": ["富士森の部屋で通販してるの"]}, {"box": [262, 667, 635, 778], "vertical": false, "font_size": 93, "lines_coords": [[[274.0, 659.0], [560.0, 685.0], [553.0, 785.0], [267.0, 758.0]]], "lines": ["ゆおホン"]}, {"box": [564, 759, 643, 780], "vertical": false, "font_size": 21, "lines_coords": [[[564.0, 757.0], [635.0, 759.0], [635.0, 782.0], [564.0, 780.0]]], "lines": ["Ｙｕｒｕｃｅｎｐ"]}, {"box": [660, 1057, 686, 1196], "vertical": true, "font_size": 26, "lines_coords": [[[660.0, 1057.0], [686.0, 1057.0], [686.0, 1196.0], [660.0, 1196.0]]], "lines": ["５．あｆｘ"]}, {"box": [885, 1151, 915, 1175], "vertical": false, "font_size": 24, "lines_coords": [[[885.0, 1151.0], [915.0, 1151.0], [915.0, 1175.0], [885.0, 1175.0]]], "lines": ["☆"]}], "img_path": "00181.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1235, 579, 1276, 666], "vertical": true, "font_size": 20, "lines_coords": [[[1252.0, 579.0], [1273.0, 579.0], [1276.0, 656.0], [1256.0, 656.0]], [[1235.0, 581.0], [1254.0, 581.0], [1254.0, 665.0], [1235.0, 665.0]]], "lines": ["何で富士Ｐが", "入ってんだよー"]}, {"box": [1108, 609, 1145, 724], "vertical": true, "font_size": 20, "lines_coords": [[[1121.0, 609.0], [1141.0, 609.0], [1145.0, 699.0], [1125.0, 699.0]]], "lines": ["富士Ｐは山梨の"]}, {"box": [1235, 776, 1275, 905], "vertical": true, "font_size": 21, "lines_coords": [[[1252.0, 776.0], [1273.0, 776.0], [1275.0, 903.0], [1254.0, 903.0]], [[1235.0, 778.0], [1256.0, 778.0], [1256.0, 866.0], [1235.0, 866.0]]], "lines": ["何で富士山があんなに", "近くにあるの！？"]}, {"box": [1086, 611, 1125, 725], "vertical": true, "font_size": 19, "lines_coords": [[[1106.0, 615.0], [1125.0, 615.0], [1125.0, 725.0], [1106.0, 725.0]]], "lines": ["テーマパークだろ？"]}, {"box": [1042, 615, 1082, 716], "vertical": true, "font_size": 20, "lines_coords": [[[1063.0, 615.0], [1081.0, 615.0], [1081.0, 708.0], [1063.0, 708.0]], [[1042.0, 616.0], [1063.0, 616.0], [1063.0, 699.0], [1042.0, 699.0]]], "lines": ["ああきちゃん", "あれ見てっ！！"]}, {"box": [967, 586, 997, 710], "vertical": true, "font_size": 26, "lines_coords": [[[971.0, 586.0], [997.0, 586.0], [993.0, 710.0], [967.0, 710.0]]], "lines": ["パッパラレル"]}, {"box": [1049, 812, 1083, 939], "vertical": true, "font_size": 34, "lines_coords": [[[1049.0, 812.0], [1083.0, 812.0], [1083.0, 939.0], [1049.0, 939.0]]], "lines": ["私たち犬山市にいるのに何で！？"]}, {"box": [968, 775, 1005, 919], "vertical": true, "font_size": 19, "lines_coords": [[[986.0, 778.0], [1005.0, 778.0], [1005.0, 918.0], [986.0, 918.0]]], "lines": ["あおいちゃん元の山梨に"]}, {"box": [647, 511, 701, 554], "vertical": false, "font_size": 43, "lines_coords": [[[647.0, 511.0], [701.0, 511.0], [701.0, 554.0], [647.0, 554.0]]], "lines": ["んの"]}, {"box": [778, 632, 799, 727], "vertical": true, "font_size": 20, "lines_coords": [[[778.0, 633.0], [798.0, 633.0], [798.0, 725.0], [778.0, 725.0]]], "lines": ["ワールド！？"]}, {"box": [778, 777, 834, 927], "vertical": true, "font_size": 20, "lines_coords": [[[813.0, 778.0], [834.0, 778.0], [834.0, 873.0], [813.0, 873.0]], [[789.0, 781.0], [808.0, 781.0], [808.0, 926.0], [789.0, 926.0]]], "lines": ["あかん！！", "山梨の事はもう忘れるんや！！"]}, {"box": [641, 609, 703, 997], "vertical": true, "font_size": 58, "lines_coords": [[[645.0, 609.0], [703.0, 609.0], [699.0, 997.0], [641.0, 997.0]]], "lines": ["ゆるキュゾ△"]}, {"box": [359, 577, 600, 671], "vertical": false, "font_size": 94, "lines_coords": [[[359.0, 577.0], [600.0, 577.0], [600.0, 671.0], [359.0, 671.0]]], "lines": ["ははは．．．"]}, {"box": [251, 583, 292, 729], "vertical": true, "font_size": 24, "lines_coords": [[[264.0, 583.0], [288.0, 583.0], [292.0, 695.0], [268.0, 695.0]]], "lines": ["前回犬山にまっ"]}, {"box": [263, 779, 297, 902], "vertical": true, "font_size": 34, "lines_coords": [[[263.0, 779.0], [297.0, 779.0], [297.0, 902.0], [263.0, 902.0]]], "lines": ["今日はあおいちゃ犬山市の"]}, {"box": [226, 773, 254, 836], "vertical": true, "font_size": 28, "lines_coords": [[[226.0, 773.0], [254.0, 773.0], [254.0, 836.0], [226.0, 836.0]]], "lines": ["あれが犬山城やでー"]}, {"box": [80, 609, 119, 730], "vertical": true, "font_size": 21, "lines_coords": [[[95.0, 611.0], [116.0, 611.0], [116.0, 705.0], [95.0, 705.0]]], "lines": ["色々迷惑をかけ"]}, {"box": [73, 778, 110, 922], "vertical": true, "font_size": 18, "lines_coords": [[[91.0, 780.0], [110.0, 780.0], [110.0, 905.0], [91.0, 905.0]], [[73.0, 781.0], [91.0, 781.0], [91.0, 903.0], [73.0, 903.0]]], "lines": ["観光案内をしてくれ", "という事になります"]}, {"box": [1151, 970, 1195, 1043], "vertical": true, "font_size": 44, "lines_coords": [[[1151.0, 970.0], [1195.0, 970.0], [1195.0, 1043.0], [1151.0, 1043.0]]], "lines": ["気づいてしまったようやな．．．"]}, {"box": [1216, 1177, 1275, 1333], "vertical": true, "font_size": 21, "lines_coords": [[[1220.0, 1216.0], [1241.0, 1218.0], [1237.0, 1271.0], [1216.0, 1269.0]]], "lines": ["「犬山帝国"]}, {"box": [966, 975, 999, 1068], "vertical": true, "font_size": 13, "lines_coords": [[[984.0, 978.0], [997.0, 978.0], [997.0, 1021.0], [984.0, 1021.0]]], "lines": ["そんな"]}, {"box": [1040, 1170, 1087, 1283], "vertical": true, "font_siz