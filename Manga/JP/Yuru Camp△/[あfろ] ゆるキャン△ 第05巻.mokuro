rue, "font_size": 34, "lines_coords": [[[273.0, 168.0], [307.0, 168.0], [307.0, 301.0], [273.0, 301.0]]], "lines": ["いいなー"]}, {"box": [1083, 740, 1204, 1102], "vertical": true, "font_size": 32, "lines_coords": [[[1171.0, 744.0], [1203.0, 744.0], [1203.0, 1102.0], [1171.0, 1102.0]], [[1128.0, 744.0], [1160.0, 744.0], [1160.0, 1051.0], [1128.0, 1051.0]], [[1085.0, 740.0], [1117.0, 740.0], [1115.0, 986.0], [1083.0, 986.0]]], "lines": ["なぁツリーハウスって", "土台の木が伸びたら", "どうなるんだ？"]}, {"box": [583, 731, 635, 997], "vertical": true, "font_size": 50, "lines_coords": [[[583.0, 731.0], [633.0, 731.0], [633.0, 997.0], [583.0, 997.0]]], "lines": ["放っといたら"]}, {"box": [251, 918, 294, 1001], "vertical": false, "font_size": 83, "lines_coords": [[[251.0, 918.0], [294.0, 918.0], [294.0, 1001.0], [251.0, 1001.0]]], "lines": ["ぐん"]}, {"box": [129, 731, 181, 1085], "vertical": true, "font_size": 51, "lines_coords": [[[129.0, 731.0], [180.0, 731.0], [180.0, 1085.0], [129.0, 1085.0]]], "lines": ["ぐんぐん伸びて．．．"]}, {"box": [1162, 1233, 1207, 1498], "vertical": true, "font_size": 45, "lines_coords": [[[1162.0, 1233.0], [1207.0, 1233.0], [1207.0, 1498.0], [1162.0, 1498.0]]], "lines": ["しめ縄されて"]}, {"box": [687, 928, 755, 1113], "vertical": true, "font_size": 30, "lines_coords": [[[720.0, 928.0], [755.0, 928.0], [755.0, 963.0], [720.0, 963.0]], [[688.0, 930.0], [714.0, 930.0], [714.0, 1113.0], [688.0, 1113.0]]], "lines": ["あ", "そうだよねぇ"]}, {"box": [123, 1233, 235, 1749], "vertical": true, "font_size": 51, "lines_coords": [[[183.0, 1237.0], [234.0, 1237.0], [234.0, 1738.0], [183.0, 1738.0]], [[123.0, 1233.0], [174.0, 1233.0], [181.0, 1633.0], [131.0, 1633.0]]], "lines": ["周りに神社とか建てられて", "祀られたら嫌だなぁ"]}], "img_path": "00148.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1031, 140, 1065, 230], "vertical": true, "font_size": 34, "lines_coords": [[[1031.0, 140.0], [1065.0, 140.0], [1065.0, 230.0], [1031.0, 230.0]]], "lines": ["ふでだ？"]}, {"box": [1136, 136, 1208, 635], "vertical": true, "font_size": 30, "lines_coords": [[[1171.0, 136.0], [1205.0, 136.0], [1207.0, 635.0], [1173.0, 635.0]], [[1136.0, 136.0], [1162.0, 136.0], [1162.0, 568.0], [1136.0, 568.0]]], "lines": ["野クルのテントって三人用なんだが、", "実際三人じゃ寝られんよなアレ"]}, {"box": [642, 122, 693, 410], "vertical": true, "font_size": 50, "lines_coords": [[[643.0, 123.0], [693.0, 123.0], [693.0, 410.0], [643.0, 410.0]]], "lines": ["テント狭っ！！"]}, {"box": [150, 75, 590, 101], "vertical": false, "font_size": 26, "lines_coords": [[[150.0, 75.0], [590.0, 75.0], [590.0, 101.0], [150.0, 101.0]]], "lines": ["家課後２０あなたのテントは何人"]}, {"box": [168, 508, 234, 764], "vertical": true, "font_size": 26, "lines_coords": [[[204.0, 510.0], [230.0, 510.0], [230.0, 731.0], [204.0, 731.0]], [[168.0, 508.0], [193.0, 508.0], [193.0, 761.0], [168.0, 761.0]]], "lines": ["だよねぇあれじゃ", "寝返りもうてないよ"]}, {"box": [1143, 888, 1208, 1318], "vertical": true, "font_size": 26, "lines_coords": [[[1179.0, 892.0], [1205.0, 892.0], [1205.0, 1318.0], [1179.0, 1318.0]], [[1143.0, 890.0], [1170.0, 890.0], [1170.0, 1155.0], [1143.0, 1155.0]]], "lines": ["それなテントメーカーのＨＰに", "こんな図があったわ"]}, {"box": [682, 896, 757, 1149], "vertical": true, "font_size": 32, "lines_coords": [[[723.0, 898.0], [755.0, 898.0], [755.0, 1053.0], [723.0, 1053.0]], [[682.0, 896.0], [714.0, 896.0], [714.0, 1149.0], [682.0, 1149.0]]], "lines": ["頭の位置が", "交互になってる．．．"]}, {"box": [166, 1145, 248, 1695], "vertical": true, "font_size": 36, "lines_coords": [[[210.0, 1145.0], [247.0, 1145.0], [247.0, 1663.0], [210.0, 1663.0]], [[168.0, 1147.0], [202.0, 1147.0], [200.0, 1695.0], [166.0, 1695.0]]], "lines": ["「三人快適に使えます」じゃなくて", "「三人収まります」って感じだなこれ"]}, {"box": [856, 1546, 905, 1635], "vertical": true, "font_size": 49, "lines_coords": [[[856.0, 1546.0], [905.0, 1546.0], [905.0, 1635.0], [856.0, 1635.0]]], "lines": ["ん？"]}], "img_path": "00149.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1087, 127, 1203, 489], "vertical": true, "font_size": 32, "lines_coords": [[[1170.0, 129.0], [1201.0, 129.0], [1201.0, 489.0], [1170.0, 489.0]], [[1128.0, 129.0], [1160.0, 129.0], [1160.0, 455.0], [1128.0, 455.0]], [[1087.0, 127.0], [1119.0, 127.0], [1119.0, 423.0], [1087.0, 423.0]]], "lines": ["テントを快適に使うには", "許容人数：１人ってのが", "常識だったみたいや"]}, {"box": [624, 178, 705, 541], "vertical": true, "font_size": 38, "lines_coords": [[[667.0, 178.0], [705.0, 178.0], [705.0, 541.0], [667.0, 541.0]], [[624.0, 178.0], [661.0, 178.0], [661.0, 421.0], [624.0, 421.0]]], "lines": ["そっか三人用は二人で", "二人用は一人で"]}, {"box": [791, 590, 860, 870], "vertical": true, "font_size": 26, "lines_coords": [[[830.0, 592.0], [856.0, 592.0], [856.0, 855.0], [830.0, 855.0]], [[791.0, 592.0], [817.0, 592.0], [817.0, 870.0], [791.0, 870.0]]], "lines": ["ま買ってみるまで", "分からん事もあるさ"]}, {"box": [123, 821, 206, 930], "vertical": true, "font_size": 42, "lines_coords": [[[165.0, 830.0], [206.0, 830.0], [206.0, 930.0], [165.0, 930.0]], [[123.0, 821.0], [166.0, 821.0], [166.0, 898.0], [123.0, 898.0]]], "lines": ["一人用", "は．．．"]}, {"box": [468, 1003, 624, 1267], "vertical": true, "font_size": 48, "lines_coords": [[[573.0, 1012.0], [624.0, 1012.0], [624.0, 1267.0], [573.0, 1267.0]], [[523.0, 1003.0], [570.0, 1003.0], [570.0, 1224.0], [523.0, 1224.0]], [[468.0, 1003.0], [513.0, 1003.0], [513.0, 1224.0], [468.0, 1224.0]]], "lines": ["一人用テント", "使う人って", "すごいね！！"]}, {"box": [151, 1001, 226, 1293], "vertical": true, "font_size": 32, "lines_coords": [[[191.0, 1001.0], [223.0, 1001.0], [223.0, 1293.0], [191.0, 1293.0]], [[151.0, 1003.0], [183.0, 1003.0], [183.0, 1132.0], [151.0, 1132.0]]], "lines": ["それは大用テントの", "サイズだ"]}], "img_path": "00150.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1126, 165, 1192, 382], "vertical": true, "font_size": 30, "lines_coords": [[[1162.0, 165.0], [1190.0, 165.0], [1192.0, 320.0], [1164.0, 320.0]], [[1126.0, 165.0], [1153.0, 165.0], [1153.0, 382.0], [1126.0, 382.0]]], "lines": ["あきちゃん", "あおいちゃん！！"]}, {"box": [1001, 198, 1074, 451], "ver