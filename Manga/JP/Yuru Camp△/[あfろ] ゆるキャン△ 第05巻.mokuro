 "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1121, 129, 1185, 493], "vertical": true, "font_size": 26, "lines_coords": [[[1153.0, 131.0], [1179.0, 131.0], [1183.0, 493.0], [1156.0, 493.0]], [[1121.0, 129.0], [1147.0, 129.0], [1147.0, 410.0], [1121.0, 410.0]]], "lines": ["一空気穴」がついてるテントが", "使えるらしいんだけど"]}, {"box": [436, 155, 504, 425], "vertical": true, "font_size": 30, "lines_coords": [[[468.0, 155.0], [500.0, 155.0], [504.0, 425.0], [472.0, 425.0]], [[436.0, 159.0], [463.0, 159.0], [463.0, 395.0], [436.0, 395.0]]], "lines": ["理由知ってちょっと", "怖くなっちゃった"]}, {"box": [215, 226, 286, 446], "vertical": true, "font_size": 32, "lines_coords": [[[253.0, 226.0], [286.0, 226.0], [286.0, 339.0], [253.0, 339.0]], [[215.0, 226.0], [247.0, 226.0], [247.0, 446.0], [215.0, 446.0]]], "lines": ["え？何", "こわい話なの？"]}, {"box": [748, 543, 1191, 664], "vertical": false, "font_size": 39, "lines_coords": [[[793.0, 543.0], [1143.0, 543.0], [1143.0, 583.0], [793.0, 583.0]], [[751.0, 585.0], [1186.0, 585.0], [1186.0, 624.0], [751.0, 624.0]], [[806.0, 624.0], [1126.0, 624.0], [1126.0, 661.0], [806.0, 661.0]]], "lines": ["通常のテントでは降雪時", "フライシートと地面のすぎ間が", "雪で埋まってしまうと"]}, {"box": [183, 542, 621, 622], "vertical": false, "font_size": 38, "lines_coords": [[[183.0, 543.0], [620.0, 543.0], [620.0, 581.0], [183.0, 581.0]], [[193.0, 583.0], [605.0, 583.0], [605.0, 622.0], [193.0, 622.0]]], "lines": ["それを防止するため山岳用など", "降雪時でも使えるテントには"]}, {"box": [1196, 1213, 1230, 1299], "vertical": true, "font_size": 28, "lines_coords": [[[1196.0, 1213.0], [1230.0, 1213.0], [1230.0, 1299.0], [1196.0, 1299.0]]], "lines": ["うわ．．．"]}, {"box": [781, 1016, 1161, 1131], "vertical": false, "font_size": 32, "lines_coords": [[[836.0, 1016.0], [1096.0, 1016.0], [1096.0, 1053.0], [836.0, 1053.0]], [[787.0, 1061.0], [1155.0, 1061.0], [1155.0, 1087.0], [787.0, 1087.0]], [[890.0, 1096.0], [1044.0, 1096.0], [1044.0, 1128.0], [890.0, 1128.0]]], "lines": ["換気できなくなり", "酸欠を起こし、てしまう事が", "あるのです"]}, {"box": [1110, 1190, 1168, 1426], "vertical": true, "font_size": 28, "lines_coords": [[[1143.0, 1192.0], [1168.0, 1192.0], [1168.0, 1404.0], [1143.0, 1404.0]], [[1110.0, 1190.0], [1134.0, 1190.0], [1134.0, 1426.0], [1110.0, 1426.0]]], "lines": ["そんな事あるんだ", "雪って怖いんだねぇ"]}, {"box": [684, 1194, 763, 1645], "vertical": true, "font_size": 32, "lines_coords": [[[727.0, 1200.0], [759.0, 1200.0], [759.0, 1507.0], [727.0, 1507.0]], [[684.0, 1194.0], [716.0, 1194.0], [716.0, 1642.0], [684.0, 1642.0]]], "lines": ["でも調べてるうちに", "どんどんテント欲しくなって"]}, {"box": [309, 1089, 442, 1121], "vertical": false, "font_size": 32, "lines_coords": [[[309.0, 1089.0], [442.0, 1089.0], [442.0, 1121.0], [309.0, 1121.0]]], "lines": ["ついでいま"]}, {"box": [215, 1046, 453, 1074], "vertical": false, "font_size": 24, "lines_coords": [[[215.0, 1050.0], [453.0, 1046.0], [453.0, 1070.0], [215.0, 1074.0]]], "lines": ["取り入れ口（ベンチ"]}, {"box": [856, 1587, 889, 1683], "vertical": true, "font_size": 32, "lines_coords": [[[856.0, 1588.0], [888.0, 1588.0], [888.0, 1633.0], [856.0, 1633.0]]], "lines": ["ねー"]}, {"box": [148, 1371, 229, 1751], "vertical": true, "font_size": 37, "lines_coords": [[[191.0, 1376.0], [228.0, 1376.0], [228.0, 1721.0], [191.0, 1721.0]], [[148.0, 1374.0], [185.0, 1374.0], [185.0, 1751.0], [148.0, 1751.0]]], "lines": ["バイト代入ったら私も", "買っちゃうかもしれない"]}], "img_path": "00015.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1119, 80, 1190, 423], "vertical": true, "font_size": 29, "lines_coords": [[[1156.0, 82.0], [1188.0, 82.0], [1188.0, 423.0], [1156.0, 423.0]], [[1119.0, 82.0], [1145.0, 82.0], [1145.0, 275.0], [1119.0, 275.0]]], "lines": ["おっ野クルはいつでも", "カモンだよー"]}, {"box": [472, 58, 540, 399], "vertical": true, "font_size": 30, "lines_coords": [[[511.0, 61.0], [538.0, 61.0], [538.0, 243.0], [511.0, 243.0]], [[474.0, 58.0], [506.0, 58.0], [504.0, 399.0], [472.0, 399.0]]], "lines": ["そうだ帰りに", "カリブー寄っていかない？"]}, {"box": [1111, 757, 1180, 1005], "vertical": true, "font_size": 26, "lines_coords": [[[115