": [[[1256.0, 1260.0], [1282.0, 1260.0], [1282.0, 1612.0], [1256.0, 1612.0]], [[1222.0, 1258.0], [1248.0, 1258.0], [1250.0, 1584.0], [1224.0, 1584.0]]], "lines": ["今回はバッチリ予定組んだから", "前回のような失態はないっ！！"]}, {"box": [918, 1276, 953, 1391], "vertical": true, "font_size": 34, "lines_coords": [[[918.0, 1276.0], [952.0, 1276.0], [952.0, 1391.0], [918.0, 1391.0]]], "lines": ["．．．たぶん"]}, {"box": [780, 1261, 846, 1485], "vertical": true, "font_size": 27, "lines_coords": [[[817.0, 1263.0], [843.0, 1263.0], [843.0, 1430.0], [817.0, 1430.0]], [[780.0, 1261.0], [808.0, 1261.0], [810.0, 1485.0], [781.0, 1485.0]]], "lines": ["海沿い走るの", "気持ちいぃぃぃ！！"]}, {"box": [592, 1323, 667, 1366], "vertical": false, "font_size": 27, "lines_coords": [[[598.0, 1323.0], [667.0, 1340.0], [661.0, 1366.0], [592.0, 1350.0]]], "lines": ["オオ"]}, {"box": [466, 1303, 592, 1351], "vertical": false, "font_size": 33, "lines_coords": [[[470.0, 1303.0], [592.0, 1318.0], [588.0, 1351.0], [466.0, 1336.0]]], "lines": ["オォォ"]}, {"box": [144, 1265, 214, 1475], "vertical": true, "font_size": 29, "lines_coords": [[[181.0, 1265.0], [213.0, 1265.0], [213.0, 1475.0], [181.0, 1475.0]], [[144.0, 1265.0], [170.0, 1265.0], [170.0, 1443.0], [144.0, 1443.0]]], "lines": ["けど風超強くて", "美しいしッ！！"]}], "img_path": "00038.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1100, 155, 1140, 258], "vertical": true, "font_size": 40, "lines_coords": [[[1100.0, 155.0], [1140.0, 155.0], [1140.0, 258.0], [1100.0, 258.0]]], "lines": ["お茶．．．"]}, {"box": [691, 185, 761, 344], "vertical": true, "font_size": 30, "lines_coords": [[[727.0, 185.0], [759.0, 185.0], [759.0, 313.0], [727.0, 313.0]], [[691.0, 185.0], [718.0, 185.0], [718.0, 343.0], [691.0, 343.0]]], "lines": ["たくさん", "ありすぎて"]}, {"box": [1115, 703, 1217, 973], "vertical": true, "font_size": 28, "lines_coords": [[[1190.0, 708.0], [1215.0, 708.0], [1215.0, 973.0], [1190.0, 973.0]], [[1155.0, 710.0], [1181.0, 710.0], [1181.0, 873.0], [1155.0, 873.0]], [[1117.0, 703.0], [1149.0, 703.0], [1147.0, 961.0], [1115.0, 961.0]]], "lines": ["もしもしお母さん？", "お茶どんなの", "買ってけばいいの？"]}, {"box": [566, 716, 702, 956], "vertical": true, "font_size": 29, "lines_coords": [[[671.0, 720.0], [697.0, 720.0], [697.0, 956.0], [671.0, 956.0]], [[633.0, 718.0], [665.0, 718.0], [665.0, 916.0], [633.0, 916.0]], [[598.0, 716.0], [630.0, 716.0], [633.0, 916.0], [601.0, 916.0]], [[566.0, 720.0], [592.0, 720.0], [592.0, 858.0], [566.0, 858.0]]], "lines": ["リンク・２千円分で", "おいしそうなの", "あったらそれで", "いいわよー"]}, {"box": [80, 386, 156, 611], "vertical": true, "font_size": 32, "lines_coords": [[[120.0, 390.0], [151.0, 390.0], [151.0, 611.0], [120.0, 611.0]], [[82.0, 386.0], [114.0, 386.0], [112.0, 609.0], [80.0, 609.0]]], "lines": ["どれがいいのか", "全然わからん．．．"]}, {"box": [181, 725, 253, 978], "vertical": true, "font_size": 30, "lines_coords": [[[217.0, 725.0], [249.0, 725.0], [249.0, 978.0], [217.0, 978.0]], [[181.0, 727.0], [208.0, 727.0], [208.0, 915.0], [181.0, 915.0]]], "lines": ["そんなの見た目で", "分からんし．．．"]}, {"box": [605, 1091, 634, 1166], "vertical": true, "font_size": 28, "lines_coords": [[[605.0, 1091.0], [633.0, 1091.0], [633.0, 1166.0], [605.0, 1166.0]]], "lines": ["フツッ"]}, {"box": [607, 1289, 633, 1428], "vertical": true, "font_size": 21, "lines_coords": [[[609.0, 1291.0], [630.0, 1291.0], [630.0, 1426.0], [609.0, 1426.0]]], "lines": ["そうですね"]}, {"box": [1146, 1265, 1210, 1659], "vertical": true, "font_size": 26, "lines_coords": [[[1179.0, 1265.0], [1207.0, 1265.0], [1209.0, 1560.0], [1181.0, 1560.0]], [[1147.0, 1267.0], [1171.0, 1267.0], [1171.0, 1659.0], [1147.0, 1659.0]]], "lines": ["すみません。２千円位で", "おすすめのお茶ありませんか？"]}, {"box": [144, 1320, 217, 1689], "vertical": true, "font_size": 26, "lines_coords": [[[180.0, 1320.0], [206.0, 1320.0], [206.0, 1687.0], [180.0, 1687.0]], [[144.0, 1320.0], [170.0, 1320.0], [170.0, 1541.0], [144.0, 1541.0]]], "lines": ["でしたらこちらの「秘蔵」など", "いかがでしょう？"]}], "img_path": "00039.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1243, 148, 1305, 485], "vertical": true, "font_size": 26, "lines_coords": [[[1278.0, 150.0], [1305.0, 150.0], [1305.0, 485.0], [1278.0, 485.0]], [[1243.0, 148.0], [1269.0, 148.0], [1269.0, 316.0], [1243.0, 316.0]]], "lines": ["山奥の蔵でひと夏寝かせた", "熟成茶でして"]}, {"box": [1156, 255, 1218, 594], "vertical": true, "font_size": 26, "lines_coords": [[[1192.0, 255.0], [1218.0, 255.0], [1218.0, 594.0], [1192.0, 594.0]], [[1156.0, 255.0], [1181.0, 255.0], [1181.0, 538.0], [1156.0, 538.0]]], "lines": ["角がとれたまろやかな味が", "特徴となっております"]}, {"box": [783, 140, 852, 397], "vertical": true, "font_size": 29, "lines_coords": [[[823.0, 144.0], [849.0, 144.0], [849.0, 397.0], [823.0, 397.0]], [[787.0, 140.0], [819.0, 140.0], [815.0, 286.0], [783.0, 286.0]]], "lines": ["よくわからないけど", "おいしい．．"]}, {"box": [496, 189, 523, 358], "vertical": true, "font_size": 26, "lines_coords": [[[496.0, 189.0], [523.0, 189.0], [523.0, 358.0], [496.0, 358.0]]], "lines": ["もしかして．．"]}, {"box": [421, 230, 481, 511], "vertical": true, "font_size": 26, "lines_coords": [[[455.0, 230.0], [481.0, 230.0], [481.0, 511.0], [455.0, 511.0]], [[421.0, 232.0], [446.0, 232.0], [446.0, 455.0], [421.0, 455.0]]], "lines": ["夜叉神峠でお会いした", "お嬢さんかしら？"]}, {"box": [150, 161, 183, 228], "vertical": true, "font_size": 33, "lines_coords": [[[150.0, 161.0], [183.0, 161.0], [183.0, 228.0], [150.0, 228.0]]], "lines": ["え？"]}, {"box": [1156, 766, 1192, 1010], "vertical": true, "font_size": 32, "lines_coords": [[[1156.0, 766.0], [1188.0, 766.0], [1188.0, 1010.0], [1156.0, 1010.0]]], "lines": ["ああの時の！！"]}, {"box": [705, 546, 731, 630], "vertical": true, "font_size": 26, "lines_coords": [[[705.0, 547.0], [731.0, 547.0], [731.0, 630.0], [705.0, 630.0]]], "lines": ["あら？"]}, {"box": [680, 886, 714, 999], "vertical": true, "font_size": 34, "lines_coords": [[[680.0, 886.0], [714.0, 886.0], [714.0, 999.0], [680.0, 999.0]]], "lines": ["どうも"]}, {"box": [500, 693, 562, 1005], "vertical": true, "font_size": 23, "lines_coords": [[[536.0, 695.0], [562.0, 695.0], [558.0, 920.0], [532.0, 920.0]], [[500.0, 693.0], [525.0, 693.0], [525.0, 1005.0], [500.0, 1005.0]]], "lines": ["この間はほうじ茶", "ありがとうございました"]}, {"box": [463, 832, 481, 1014], "vertical": true, "font_size": 23, "lines_coords": [[[463.0, 832.0], [481.0, 832.0], [481.0, 1014.0], [463.0, 1014.0]]], "lines": ["おいしかったです！！"]}, {"box": [862, 1282, 920, 1522], "vertical": true, "font_size": 25, "lines_coords": [[[892.0, 1284.0], [918.0, 1284.0], [916.0, 1522.0], [890.0, 1522.0]], [[862.0, 1282.0], [886.0, 1282.0], [886.0, 1458.0], [862.0, 1458.0]]], "lines": ["はい。磐田の海の方に", "初日の出を見に"]}, {"box": [121, 873, 228, 1215], "vertical": true, "font_size": 30, "lines_coords": [[[196.0, 873.0], [228.0, 873.0], [228.0, 988.0], [196.0, 988.0]], [[155.0, 903.0], [187.0, 903.0], [187.0, 1050.0], [155.0, 1050.0]], [[121.0, 905.0], [148.0, 905.0], [150.0, 1215.0], [123.0, 1215.0]]], "lines": ["いえいえ", "驚きました", "こんな偶然あるんですね"]}, {"box": [1183, 1290, 1213, 1625], "vertical": true, "font_size": 26, "lines_coords": [[[1183.0, 1290.0], [1209.0, 1290.0], [1209.0, 1625.0], [1183.0, 1625.0]]], "lines": ["今日はお一人で掛川まで？"]}, {"box": [601, 1359, 662, 1609], "vertical": true, "font_size": 26, "lines_coords": [[[635.0, 1359.0], [660.0, 1359.0], [660.0, 1608.0], [635.0, 1608.0]], [[601.0, 1361.0], [628.0, 1361.0], [628.0, 1466.0], [601.0, 1466.0]]], "lines": ["まぁそれではるばる", "山梨から"]}, {"box": [476, 1297, 538, 1616], "vertical": true, "font_size": 26, "lines_coords": [[[510.0, 1297.0], [536.0, 1297.0], [536.0, 1616.0], [510.0, 1616.0]], [[476.0, 1299.0], [502.0, 1299.0], [502.0, 1561.0], [476.0, 1561.0]]], "lines": ["警田でしたら「福田海岸」が", "いいかもしれませんね"]}, {"box": [125, 1606, 189, 1775], "vertical": true, "font_size": 26, "lines_coords": [[[161.0, 1610.0], [187.0, 1610.0], [187.0, 1775.0], [161.0, 1775.0]], [[125.0, 1606.0], [151.0, 1606.0], [151.0, 1719.0], [125.0, 1719.0]]], "lines": ["ふくで海岸．．．", "ですか？"]}], "img_path": "00040.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1