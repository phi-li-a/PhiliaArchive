]]], "lines": ["ホントはあきと川で", "キャンプする予定やった", "けど"]}, {"box": [630, 705, 705, 1062], "vertical": true, "font_size": 30, "lines_coords": [[[671.0, 705.0], [703.0, 705.0], [703.0, 1035.0], [671.0, 1035.0]], [[633.0, 705.0], [660.0, 705.0], [660.0, 1061.0], [633.0, 1061.0]]], "lines": ["ネットで注文しとった", "テントが全然届かんくて"]}, {"box": [139, 410, 243, 619], "vertical": true, "font_size": 104, "lines_coords": [[[139.0, 410.0], [243.0, 410.0], [243.0, 619.0], [139.0, 619.0]]], "lines": ["宿題やってゲームしとっただけやなー"]}, {"box": [136, 410, 243, 622], "vertical": true, "font_size": 32, "lines_coords": [[[211.0, 410.0], [243.0, 410.0], [243.0, 562.0], [211.0, 562.0]], [[172.0, 410.0], [204.0, 410.0], [206.0, 622.0], [174.0, 622.0]], [[140.0, 412.0], [168.0, 412.0], [165.0, 560.0], [136.0, 560.0]]], "lines": ["宿題やって", "ゲームしとった", "だけやなー"]}, {"box": [163, 768, 195, 907], "vertical": true, "font_size": 32, "lines_coords": [[[163.0, 768.0], [195.0, 768.0], [195.0, 907.0], [163.0, 907.0]]], "lines": ["そうそう"]}, {"box": [1113, 1289, 1192, 1668], "vertical": true, "font_size": 32, "lines_coords": [[[1156.0, 1291.0], [1188.0, 1291.0], [1188.0, 1601.0], [1156.0, 1601.0]], [[1113.0, 1293.0], [1145.0, 1293.0], [1145.0, 1668.0], [1113.0, 1668.0]]], "lines": ["夏っぽい事言うたら、", "スイカ食べたくらいやー"]}, {"box": [883, 1515, 917, 1661], "vertical": true, "font_size": 33, "lines_coords": [[[883.0, 1515.0], [916.0, 1515.0], [916.0, 1661.0], [883.0, 1661.0]]], "lines": ["だよなー"]}, {"box": [161, 1357, 245, 1732], "vertical": true, "font_size": 35, "lines_coords": [[[208.0, 1359.0], [245.0, 1359.0], [245.0, 1621.0], [208.0, 1621.0]], [[163.0, 1357.0], [196.0, 1357.0], [195.0, 1728.0], [161.0, 1728.0]]], "lines": ["来年はみんなで", "川キャンプ行きたいね"]}], "img_path": "00153.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [727, 654, 765, 862], "vertical": true, "font_size": 38, "lines_coords": [[[727.0, 654.0], [765.0, 654.0], [765.0, 862.0], [727.0, 862.0]]], "lines": ["ＢＢＱしてー"]}, {"box": [543, 693, 583, 843], "v