cal": false, "font_size": 32, "lines_coords": [[[420.0, 930.0], [697.0, 930.0], [697.0, 961.0], [420.0, 961.0]], [[423.0, 969.0], [603.0, 969.0], [603.0, 1001.0], [423.0, 1001.0]]], "lines": ["それどこかで聞いた", "気がするわー"]}, {"box": [680, 1477, 740, 1680], "vertical": true, "font_size": 30, "lines_coords": [[[706.0, 1477.0], [740.0, 1477.0], [740.0, 1560.0], [706.0, 1560.0]], [[680.0, 1481.0], [705.0, 1481.0], [705.0, 1680.0], [680.0, 1680.0]]], "lines": ["乾麺は", "ゆで汁が出るから"]}, {"box": [206, 1540, 266, 1804], "vertical": true, "font_size": 24, "lines_coords": [[[240.0, 1541.0], [264.0, 1541.0], [264.0, 1803.0], [240.0, 1803.0]], [[206.0, 1541.0], [230.0, 1541.0], [230.0, 1753.0], [206.0, 1753.0]]], "lines": ["外で作るならゆで麺が", "インスタントかな"]}], "img_path": "00026.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [872, 144, 1189, 212], "vertical": false, "font_size": 32, "lines_coords": [[[873.0, 146.0], [1183.0, 146.0], [1183.0, 178.0], [873.0, 178.0]], [[875.0, 180.0], [1151.0, 180.0], [1151.0, 211.0], [875.0, 211.0]]], "lines": ["だったらそうめんの方が", "条件に合ってないか？"]}, {"box": [889, 261, 1178, 294], "vertical": false, "font_size": 26, "lines_coords": [[[894.0, 266.0], [1170.0, 266.0], [1170.0, 292.0], [894.0, 292.0]]], "lines": ["ほっそい奴あるじゃん"]}, {"box": [298, 153, 595, 191], "vertical": false, "font_size": 26, "lines_coords": [[[307.0, 159.0], [590.0, 159.0], [590.0, 185.0], [307.0, 185.0]]], "lines": ["私にゅううめん好きー"]}, {"box": [780, 645, 1069, 682], "vertical": false, "font_size": 32, "lines_coords": [[[783.0, 645.0], [1061.0, 646.0], [1061.0, 678.0], [783.0, 676.0]]], "lines": ["それは言えてるかも"]}, {"box": [900, 759, 1160, 850], "vertical": false, "font_size": 28, "lines_coords": [[[905.0, 761.0], [1125.0, 761.0], [1125.0, 787.0], [905.0, 787.0]], [[900.0, 785.0], [1053.0, 789.0], [1053.0, 821.0], [900.0, 817.0]], [[907.0, 823.0], [1151.0, 823.0], [1151.0, 849.0], [907.0, 849.0]]], "lines": ["ここは国境のカベを", "取っぱらって", "年越しカッペリーニ！"]}, {"box": [872, 886, 1179, 920], "vertical": false, "font_size": 32, "lines_coords": [[[873.0, 886.0], [1175.0, 886.0], [1175.0, 918.0], [873.0, 918.0]]], "lines": ["とかもアリしなんじゃね？"]}, {"box": [288, 560, 612, 590], "vertical": false, "font_size": 24, "lines_coords": [[[288.0, 564.0], [611.0, 564.0], [611.0, 588.0], [288.0, 588.0]]], "lines": ["私も風邪らしいた時いいよね－"]}, {"box": [284, 772, 609, 834], "vertical": false, "font_size": 26, "lines_coords": [[[286.0, 774.0], [605.0, 776.0], [605.0, 802.0], [286.0, 800.0]], [[285.0, 806.0], [530.0, 806.0], [530.0, 832.0], [285.0, 832.0]]], "lines": ["それやったらビ一フンやって", "細長くて切れやすいで"]}, {"box": [641, 1410, 1092, 1444], "vertical": false, "font_size": 32, "lines_coords": [[[641.0, 1410.0], [1091.0, 1411.0], [1091.0, 1443.0], [641.0, 1441.0]]], "lines": ["私ビーフンよりフォ一の方が好きかな"]}, {"box": [323, 1272, 571, 1309], "vertical": false, "font_size": 27, "lines_coords": [[[324.0, 1276.0], [568.0, 1276.0], [568.0, 1303.0], [324.0, 1303.0]]], "lines": ["年越しとーフン！！"]}, {"box": [918, 1495, 1182, 1537], "vertical": false, "font_size": 31, "lines_coords": [[[920.0, 1500.0], [1177.0, 1500.0], [1177.0, 1531.0], [920.0, 1531.0]]], "lines": ["年越しノフォー！！"]}, {"box": [930, 1694, 1148, 1765], "vertical": false, "font_size": 30, "lines_coords": [[[933.0, 1696.0], [1143.0, 1696.0], [1143.0, 1723.0], [933.0, 1723.0]], [[933.0, 1732.0], [1145.0, 1732.0], [1145.0, 1764.0], [933.0, 1764.0]]], "lines": ["パクチーぬきで", "おねがいします"]}, {"box": [772, 1702, 815, 1723], "vertical": false, "font_size": 21, "lines_coords": [[[772.0, 1702.0], [815.0, 1702.0], [815.0, 1723.0], [772.0, 1723.0]]], "lines": ["Ｐ：２３"]}], "img_path": "00027.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [851, 123, 1203, 238], "vertical": false, "font_size": 115, "lines_coords": [[[851.0, 123.0], [1203.0, 123.0], [1203.0, 238.0], [851.0, 238.0]]], "lines": ["もう睡類やったら何でもええ気がするわー"]}, {"box": [307, 141, 592, 215], "vertical": false, "font_size": 26, "lines_coords": [[[307.0, 146.0], [585.0, 146.0], [585.0, 172.0], [307.0, 172.0]], [[313.0, 185.0], [553.0, 185.0], [553.0, 211.0], [313.0, 211.0]]], "lines": ["年越しうと一んとか", "こんでやっとろし"]}, {"box": [947, 768, 1171, 807], "vertical": false, "font_size": 38, "lines_coords": [[[954.0, 768.0], [1160.0, 768.0], [1160.0, 806.0], [954.0, 806.0]]], "lines": ["年越し春雨！！"]}, {"box": [931, 857, 1183, 893], "vertical": false, "font_size": 26, "lines_coords": [[[931.0, 860.0], [1179.0, 862.0], [1179.0, 888.0], [931.0, 886.0]]], "lines": ["年越しところてん！！"]}, {"box": [286, 650, 589, 688], "vertical": false, "font_size": 38, "lines_coords": [[[286.0, 650.0], [588.0, 650.0], [588.0, 688.0], [286.0, 688.0]]], "lines": ["あ、やってるやっこるー"]}, {"box": [678, 954, 1198, 978], "vertical": false, "font_size": 24, "lines_coords": [[[678.0, 954.0], [1198.0, 954.0], [1198.0, 978.0], [678.0, 978.0]]], "lines": ["年越し小倉抹茶いちご生クリーム山盛パスタ！！"]}, {"box": [869, 1160, 1182, 1200], "vertical": false, "font_size": 32, "lines_coords": [[[873.0, 1164.0], [1177.0, 1166.0], [1177.0, 1198.0], [873.0, 1196.0]]], "lines": ["うどんで思いい出したか"]}, {"box": [866, 1036, 975, 1076], "vertical": false, "font_size": 34, "lines_coords": [[[871.0, 1036.0], [969.0, 1040.0], [967.0, 1074.0], [870.0, 1070.0]]], "lines": ["オエエ"]}, {"box": [871, 1243, 1181, 1336], "vertical": false, "font_size": 26, "lines_coords": [[[875.0, 1246.0], [1171.0, 1246.0], [1171.0, 1271.0], [875.0, 1271.0]], [[877.0, 1276.0], [1149.0, 1276.0], [1149.0, 1303.0], [877.0, 1303.0]], [[877.0, 1308.0], [1181.0, 1308.0], [1181.0, 1335.0], [877.0, 1335.0]]], "lines": ["群馬には「ひもかわうどん」", "とかいううどんの妖怪が", "おってな．．．〈く〉〉《、くの》"]}, {"box": [249, 1194, 316, 1402], "vertical": true, "font_size": 26, "lines_coords": [[[286.0, 1196.0], [313.0, 1196.0], [313.0, 1385.0], [286.0, 1385.0]], [[249.0, 1196.0], [275.0, 1196.0], [275.0, 1402.0], [249.0, 1402.0]]], "lines": ["そうか今度は", "伊豆に行くんだ"]}, {"box": [883, 1633, 1151, 1666], "vertical": false, "font_size": 31, "lines_coords": [[[883.0, 1635.0], [1151.0, 1635.0], [1151.0, 1666.0], [883.0, 1666.0]]], "lines": ["キャー！！こわーい！！"]}, {"box": [888, 1723, 1145, 1760], "vertical": false, "font_size": 37, "lines_coords": [[[888.0, 1723.0], [1140.0, 1723.0], [1140.0, 1760.0], [888.0, 1760.0]]], "lines": ["キャーッ！！（＞□く）"]}], "img_path": "00028.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1153, 153, 1224, 371], "vertical": true, "font_size": 32, "lines_coords": [[[1192.0, 155.0], [1224.0, 155.0], [1224.0, 371.0], [1192.0, 371.0]], [[1153.0, 153.0], [1185.0, 153.0], [1186.0, 371.0], [1155.0, 371.0]]], "lines": ["だったら沼津の", "海沿いを通って"]}, {"box": [620, 138, 690, 422], "vertical": true, "font_size": 32, "lines_coords": [[[656.0, 138.0], [688.0, 138.0], [688.0, 390.0], [656.0, 390.0]], [[620.0, 140.0], [652.0, 140.0], [652.0, 421.0], [620.0, 421.0]]], "lines": ["高台から見下ろす", "御浜岬もキレイだし"]}, {"box": [133, 84, 196, 478], "vertical": true, "font_size": 26, "lines_coords": [[[168.0, 86.0], [195.0, 86.0], [195.0, 365.0], [168.0, 365.0]], [[133.0, 84.0], [159.0, 84.0], [159.0, 478.0], [133.0, 478.0]]], "lines": ["西伊豆スカイラインも", "景色よくて走りやすいと思うよ"]}, {"box": [1143, 738, 1218, 1057], "vertical": true, "font_size": 32, "lines_coords": [[[1186.0, 742.0], [1218.0, 742.0], [1218.0, 1023.0], [1186.0, 1023.0]], [[1145.0, 738.0], [1179.0, 738.0], [1177.0, 1057.0], [1143.0, 1057.0]]], "lines": ["でも伊豆は正月だと", "混むんじゃないかな？"]}, {"box": [733, 390, 802, 673], "vertical": true, "font_size": 29, "lines_coords": [[[774.0, 393.0], [800.0, 393.0], [800.0, 562.0], [774.0, 562.0]], [[733.0, 390.0], [765.0, 390.0], [765.0, 673.0], [733.0, 673.0]]], "lines": ["こう肥田を", "抜けるのはどうかな"]}, {"box": [587, 736, 648, 961], "vertical": true, "font_size": 23, "lines_coords": [[[618.0, 736.0], [643.0, 736.0], [643.0, 961.0], [618.0, 961.0]], [[588.0, 738.0], [609.0, 738.0], [609.0, 875.0], [588.0, 875.0]]], "lines": ["海を見に行くなら", "御前崎は？"]}, {"box": [384, 737, 444, 963], "vertical": true, "font_size": 25, "lines_coords": [[[418.0, 738.0], [442.0, 738.0], [442.0, 941.0], [418.0, 941.0]], [[386.0, 738.0], [412.0, 738.0], [410.0, 963.0], [384.0, 963.0]]], "lines": ["灯台の丘から見る", "大平洋がキレイだよ"]}, {"box": [153, 530, 195, 626], "vertical": true, "font_size": 42, "lines_coords": [[[153.0, 530.0], [195.0, 530.0], [195.0, 626.0], [153.0, 626.0]]], "lines": ["へぇー"]}, {"box": [144, 748, 177, 903], "vertical": true, "font_size": 32, "lines_coords": [[[144.0, 748.0], [176.0, 748.0], [176.0, 903.0], [144.0, 903.0]]], "lines": ["御前崎かぁ"]}, {"box": [1055, 900, 1125, 1153], "vertical": true, "font_size": 32, "lines_coords": [[[1093.0, 900.0], [1125.0, 900.0], [1125.0, 1153.0], [1093.0, 1153.0]], [[1055.0, 901.0], [1087.0, 901.0], [1087.0, 1121.0], [1055.0, 1121.0]]], "lines": ["東京から来る人も", "多いみたいだし"]}, {"box": [701, 1091, 772, 1264], "vertical": true, "font_size": 34, "lines_coords": [[[729.0, 1091.0], [772.0, 1091.0], [772.0, 1156.0], [729.0, 1156.0]], [[701.0, 1096.0], [727.0, 1096.0], [727.0, 1263.0], [701.0, 1263.0]]], "lines": ["うっ", "それは嫌だな"]}, {"box": [1140, 1329, 1211, 1644], "vertical": true, "font_size": 32, "lines_coords": [[[1177.0, 1329.0], [1209.0, 1329.0], [1211.0, 1640.0], [1179.0, 1640.0]], [[1140.0, 1329.0], [1171.0, 1329.0], [1171.0, 1644.0], [1140.0, 1644.0]]], "lines": ["事故には気をつけてね", "私はそれだけが心配よ。"]}, {"box": [609, 1337, 672, 1642], "vertical": true, "font_size": 26, "lines_coords": [[[643.0, 1338.0], [669.0, 1338.0], [669.0, 1642.0], [643.0, 1642.0]], [[611.0, 1338.0], [637.0, 1338.0], [635.0, 1576.0], [609.0, 1576.0]]], "lines": ["分かってる車が多い道は", "なるべく通らないよ"]}], "img_path": "00029.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1136, 135, 1168, 262], "vertical": true, "font_size": 28, "lines_coords": [[[1136.0, 135.0], [1168.0, 135.0], [1168.0, 262.0], [1136.0, 262.0]]], "lines": ["あ三日に"]}, {"box": [1038, 148, 1102, 485], "vertical": true, "font_size": 28, "lines_coords": [[[1076.0, 151.0], [1102.0, 151.0], [1102.0, 431.0], [1076.0, 431.0]], [[1038.0, 148.0], [1065.0, 148.0], [1065.0, 485.0], [1038.0, 485.0]]], "lines": ["お爺ちゃんが来るから", "それまでに帰って来てね？"]}, {"box": [538, 181, 569, 335], "vertical": true, "font_size": 26, "lines_coords": [[[540.0, 181.0], [566.0, 181.0], [566.0, 335.0], [540.0, 335.0]]], "lines": ["うん大丈夫"]}, {"box": [1076, 633, 1177, 884], "vertical": true, "font_size": 28, "lines_coords": [[[1145.0, 633.0], [1177.0, 633.0], [1177.0, 776.0], [1145.0, 776.0]], [[1113.0, 633.0], [1138.0, 633.0], [1138.0, 800.0], [1113.0, 800.0]], [[1076.0, 633.0], [1102.0, 633.0], [1102.0, 883.0], [1076.0, 883.0]]], "lines": ["お爺ちゃん", "リンに会うの", "楽しみにしてるって"]}, {"box": [296, 714, 337, 795], "vertical": true, "font_size": 41, "lines_coords": [[[296.0, 714.0], [337.0, 714.0], [337.0, 795.0], [296.0, 795.0]]], "lines": ["うん"]}, {"box": [1141, 1104, 1206, 1526], "vertical": true, "font_size": 26, "lines_coords": [[[1179.0, 1108.0], [1205.0, 1108.0], [1205.0, 1430.0], [1179.0, 1430.0]], [[1141.0, 1104.0], [1168.0, 1104.0], [1168.0, 1526.0], [1141.0, 1526.0]]], "lines": ["さてとりあえず伊豆から", "御前崎方面へ行き先変更したけど、"]}, {"box": [616, 1048, 660, 1128], "vertical": true, "font_size": 44, "lines_coords": [[[616.0, 1048.0], [660.0, 1048.0], [660.0, 1128.0], [616.0, 1128.0]]], "lines": ["お！！"]}, {"box": [412, 1266, 583, 1296], "vertical": false, "font_size": 24, "lines_coords": [[[416.0, 1267.0], [577.0, 1267.0], [577.0, 1291.0], [416.0, 1291.0]]], "lines": ["銀前崎キャンプ場"]}, {"box": [138, 1047, 208, 1327], "vertical": true, "font_size": 30, "lines_coords": [[[176.0, 1048.0], [208.0, 1048.0], [208.0, 1327.0], [176.0, 1327.0]], [[138.0, 1048.0], [165.0, 1048.0], [165.0, 1235.0], [138.0, 1235.0]]], "lines": ["ちょうど灯台のすぐ", "近くにある！！"]}, {"box": [723, 1396, 789, 1759], "vertical": true, "font_size": 26, "lines_coords": [[[759.0, 1398.0], [785.0, 1398.0], [785.0, 1758.0], [759.0, 1758.0]], [[723.0, 1396.0], [750.0, 1396.0], [750.0, 1509.0], [723.0, 1509.0]]], "lines": ["こっちの方でキャンプできる", "場所は．．．"]}, {"box": [178, 1545, 675, 1651], "vertical": false, "font_size": 45.0, "lines_coords": [[[178.0, 1545.0], [654.0, 1545.0], [654.0, 1590.0], 