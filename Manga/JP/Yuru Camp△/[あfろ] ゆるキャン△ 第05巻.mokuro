th": 1350, "img_height": 1920, "blocks": [{"box": [1216, 154, 1282, 408], "vertical": true, "font_size": 26, "lines_coords": [[[1252.0, 155.0], [1278.0, 155.0], [1278.0, 408.0], [1252.0, 408.0]], [[1216.0, 155.0], [1243.0, 155.0], [1243.0, 354.0], [1216.0, 354.0]]], "lines": ["確か：事務所の横で", "飼われてるって"]}, {"box": [879, 153, 910, 409], "vertical": true, "font_size": 26, "lines_coords": [[[881.0, 153.0], [907.0, 153.0], [907.0, 406.0], [881.0, 406.0]]], "lines": ["犬と参拝に来た人が"]}, {"box": [1248, 744, 1280, 885], "vertical": true, "font_size": 32, "lines_coords": [[[1248.0, 744.0], [1280.0, 744.0], [1280.0, 885.0], [1248.0, 885.0]]], "lines": ["どこだ？"]}, {"box": [744, 738, 837, 990], "vertical": true, "font_size": 25, "lines_coords": [[[810.0, 738.0], [836.0, 738.0], [836.0, 990.0], [810.0, 990.0]], [[776.0, 738.0], [802.0, 738.0], [802.0, 952.0], [776.0, 952.0]], [[744.0, 738.0], [768.0, 738.0], [768.0, 950.0], [744.0, 950.0]]], "lines": ["あの悉平太郎三世が", "飼われているって", "聞いたんですけど"]}, {"box": [453, 350, 484, 660], "vertical": true, "font_size": 27, "lines_coords": [[[453.0, 350.0], [480.0, 350.0], [480.0, 660.0], [453.0, 660.0]]], "lines": ["プログに書いてたけど．．．"]}, {"box": [281, 725, 309, 839], "vertical": true, "font_size": 26, "lines_coords": [[[281.0, 725.0], [307.0, 725.0], [307.0, 836.0], [281.0, 836.0]]], "lines": ["あぁー．．．"]}, {"box": [360, 1001, 420, 1186], "vertical": true, "font_size": 28, "lines_coords": [[[391.0, 1001.0], [420.0, 1001.0], [420.0, 1083.0], [391.0, 1083.0]], [[360.0, 1003.0], [386.0, 1003.0], [386.0, 1186.0], [360.0, 1186.0]]], "lines": ["どこに", "いるんですか？"]}, {"box": [1055, 1276, 1192, 1760], "vertical": true, "font_size": 62, "lines_coords": [[[1128.0, 1280.0], [1188.0, 1280.0], [1192.0, 1576.0], [1132.0, 1576.0]], [[1061.0, 1276.0], [1125.0, 1276.0], [1119.0, 1760.0], [1055.0, 1760.0]]], "lines": ["何年か前に", "亡くなりまして．．．"]}], "img_path": "00046.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [528, 129, 590, 369], "vertical": true, "font_size": 26, "lines_coords": [[[562.0, 129.0], [588.0, 129.0], [588.0, 290.0], [562.0, 290.0]], [[528.0, 129.0], [555.0, 129.0], [555.0, 369.0], [528.0, 369.0]]], "lines": ["考えてみれば", "犬の寿命は１５年位："]}, {"box": [1118, 676, 1183, 875], "vertical": true, "font_size": 27, "lines_coords": [[[1155.0, 676.0], [1183.0, 676.0], [1179.0, 847.0], [1151.0, 847.0]], [[1119.0, 678.0], [1145.0, 678.0], [1145.0, 875.0], [1119.0, 875.0]]], "lines": ["人間より全然", "短いんだよな．．．"]}, {"box": [834, 1061, 1141, 1093], "vertical": false, "font_size": 26, "lines_coords": [[[843.0, 1065.0], [1141.0, 1065.0], [1141.0, 1091.0], [843.0, 1091.0]]], "lines": ["そっか、残念だったね．．．"]}, {"box": [768, 1139, 1113, 1173], "vertical": false, "font_size": 32, "lines_coords": [[[768.0, 1141.0], [1113.0, 1140.0], [1113.0, 1171.0], [768.0, 1173.0]]], "lines": ["それで少し思うったんだけどさ"]}, {"box": [673, 952, 1101, 1020], "vertical": false, "font_size": 29, "lines_coords": [[[678.0, 956.0], [1095.0, 956.0], [1095.0, 982.0], [678.0, 982.0]], [[673.0, 984.0], [937.0, 988.0], [937.0, 1020.0], [673.0, 1016.0]]], "lines": ["現付天神の悉平三世に会いＮに来たら", "すでに亡くなってた．．．"]}, {"box": [157, 1192, 545, 1254], "vertical": false, "font_size": 28, "lines_coords": [[[166.0, 1194.0], [511.0, 1194.0], [511.0, 1218.0], [166.0, 1218.0]], [[163.0, 1222.0], [538.0, 1222.0], [538.0, 1254.0], [163.0, 1254.0]]], "lines": ["犬の寿命って人間よりも短いし", "何十年も一緒にはいいられないよね"]}, {"box": [165, 1297, 540, 1358], "vertical": false, "font_size": 25, "lines_coords": [[[168.0, 1299.0], [538.0, 1299.0], [538.0, 1325.0], [168.0, 1325.0]], [[170.0, 1331.0], [335.0, 1331.0], [335.0, 1355.0], [170.0, 1355.0]]], "lines": ["斉藤はいつか来るちくわとの別れ", "怖くならない？"]}, {"box": [822, 1441, 1207, 1509], "vertical": false, "font_size": 29, "lines_coords": [[[826.0, 1441.0], [1201.0, 1441.0], [1201.0, 1473.0], [826.0, 1473.0]], [[826.0, 1479.0], [1188.0, 1479.0], [1188.0, 1505.0], [826.0, 1505.0]]], "lines": ["すっごく怖いしそうなったら", "悲しいけど．．．仕方ないと思う"]}, {"box": [820, 1495, 1198, 1577], "vertical": false, "font_size": 82, "lines_coords": [[[820.0, 1495.0], [1198.0, 1495.0], [1198.0, 1577.0], [820.0, 1577.0]]], "lines": ["ぷしぃりと、はんないとかったから今いっぱいぶんであげて"]}, {"box": [814, 1552, 1211, 1614], "vertical": false, "font_size": 25, "lines_coords": [[[817.0, 1556.0], [1162.0, 1556.0], [1162.0, 1580.0], [817.0, 1580.0]], [[817.0, 1586.0], [1211.0, 1586.0], [1211.0, 1612.0], [817.0, 1612.0]]], "lines": ["だから今いっぱいい遊んであげて", "楽しかったって思ってもらいたいよ"]}, {"box": [360, 1729, 559, 1762], "vertical": false, "font_size": 32, "lines_coords": [[[363.0, 1730.0], [551.0, 1730.0], [551.0, 1762.0], [363.0, 1762.0]]], "lines": ["お、そうなんだ"]}, {"box": [230, 1555, 663, 1680], "vertical": false, "font_size": 28, "lines_coords": [[[236.0, 1556.0], [315.0, 1556.0], [315.0, 1590.0], [236.0, 1590.0]], [[240.0, 1591.0], [583.0, 1591.0], [583.0, 1616.0], [240.0, 1616.0]], [[240.0, 1621.0], [483.0, 1621.0], [483.0, 1648.0], [240.0, 1648.0]], [[240.0, 1653.0], [660.0, 1653.0], [660.0, 1678.0], [240.0, 1678.0]]], "lines": ["そうだ", "こないだのキャンプ行ってから", "みんなの写真見せると", "すごいテンシヨン上がんだよちくわｗ"]}], "img_path": "00047.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [875, 84, 1102, 155], "vertical": false, "font_size": 40, "lines_coords": [[[877.0, 84.0], [1098.0, 84.0], [1098.0, 116.0], [877.0, 116.0]], [[875.0, 108.0], [1051.0, 108.0], [1051.0, 155.0], [875.0, 155.0]]], "lines": ["またあそんでね！！", "リンちゃん！！"]}, {"box": [570, 693, 640, 907], "vertical": true, "font_size": 32, "lines_coords": [[[607.0, 695.0], [639.0, 695.0], [639.0, 847.0], [607.0, 847.0]], [[573.0, 693.0], [605.0, 693.0], [601.0, 907.0], [570.0, 907.0]]], "lines": ["悉平太郎の", "犬みくじゲット"]}, {"box": [174, 547, 506, 616], "vertical": false, "font_size": 32, "lines_coords": [[[174.0, 547.0], [506.0, 547.0], [506.0, 585.0], [174.0, 585.0]], [[178.0, 586.0], [343.0, 586.0], [343.0, 613.0], [178.0, 613.0]]], "lines": ["よし、これでもかと言う程", "遊んでやろう"]}, {"box": [133, 697, 195, 802], "vertical": true, "font_size": 29, "lines_coords": [[[163.0, 697.0], [195.0, 697