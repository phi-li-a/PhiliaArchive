45, 1178, 639], "vertical": false, "font_size": 25, "lines_coords": [[[845.0, 549.0], [1100.0, 549.0], [1100.0, 575.0], [845.0, 575.0]], [[843.0, 579.0], [1044.0, 579.0], [1044.0, 605.0], [843.0, 605.0]], [[843.0, 613.0], [1170.0, 609.0], [1170.0, 633.0], [843.0, 637.0]]], "lines": ["おつかれさまー（＇ｖ｀）", "だいぶ慣れたよー", "あきちゃんはどう？忙しいの"]}, {"box": [757, 708, 1069, 747], "vertical": false, "font_size": 26, "lines_coords": [[[763.0, 714.0], [1055.0, 714.0], [1055.0, 740.0], [763.0, 740.0]]], "lines": ["めちゃいそがしいぞー"]}, {"box": [158, 550, 523, 616], "vertical": false, "font_size": 27, "lines_coords": [[[161.0, 553.0], [523.0, 553.0], [523.0, 579.0], [161.0, 579.0]], [[159.0, 585.0], [463.0, 586.0], [463.0, 615.0], [159.0, 613.0]]], "lines": ["年末年始は酒が売れるからな", "４日までフルで出勤だー"]}, {"box": [793, 1241, 1138, 1306], "vertical": false, "font_size": 26, "lines_coords": [[[795.0, 1245.0], [1025.0, 1245.0], [1025.0, 1271.0], [795.0, 1271.0]], [[795.0, 1278.0], [1132.0, 1278.0], [1132.0, 1303.0], [795.0, 1303.0]]], "lines": ["お互い稼ぎ時だから", "休み無いけどがんばろーぜ！"]}, {"box": [871, 1351, 1213, 1415], "vertical": false, "font_size": 36, "lines_coords": [[[875.0, 1353.0], [948.0, 1353.0], [948.0, 1387.0], [875.0, 1387.0]], [[871.0, 1376.0], [1213.0, 1372.0], [1213.0, 1411.0], [871.0, 1415.0]]], "lines": ["えっ？", "私２日と３日休みもらえたよ？"]}, {"box": [189, 1085, 500, 1157], "vertical": false, "font_size": 28, "lines_coords": [[[193.0, 1089.0], [495.0, 1089.0], [495.0, 1115.0], [193.0, 1115.0]], [[189.0, 1125.0], [496.0, 1125.0], [496.0, 1156.0], [189.0, 1156.0]]], "lines": ["宿題片付（けたらそれで", "冬休みはおしまいだな"]}, {"box": [266, 1252, 589, 1295], "vertical": false, "font_size": 39, "lines_coords": [[[266.0, 1256.0], [586.0, 1256.0], [586.0, 1295.0], [266.0, 1295.0]]], "lines": ["あ私は３、４休みだよ"]}, {"box": [811, 1712, 1078, 1761], "vertical": false, "font_size": 34, "lines_coords": [[[813.0, 1717.0], [1066.0, 1719.0], [1066.0, 1753.0], [813.0, 1751.0]]], "lines": ["．．．なんだと．．"]}], "img_path": "00018.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [859, 156, 1183, 188], "vertical": false, "font_size": 24, "lines_coords": [[[864.0, 161.0], [1183.0, 161.0], [1183.0, 185.0], [864.0, 185.0]]], "lines": ["私は元旦から３日まで休みやー"]}, {"box": [753, 138, 796, 153], "vertical": false, "font_size": 15, "lines_coords": [[[753.0, 138.0], [796.0, 138.0], [796.0, 153.0], [753.0, 153.0]]], "lines": ["！５：０７"]}, {"box": [304, 155, 611, 188], "vertical": false, "font_size": 24, "lines_coords": [[[307.0, 161.0], [605.0, 161.0], [605.0, 185.0], [307.0, 185.0]]], "lines": ["みんなお休みなみは何するの？"]}, {"box": [863, 709, 1187, 746], "vertical": false, "font_size": 32, "lines_coords": [[[864.0, 712.0], [1185.0, 712.0], [1185.0, 744.0], [864.0, 744.0]]], "lines": ["私３１から４日まで休み"]}, {"box": [857, 824, 1170, 891], "vertical": false, "font_size": 26, "lines_coords": [[[860.0, 828.0], [1164.0, 828.0], [1164.0, 855.0], [860.0, 855.0]], [[858.0, 862.0], [1057.0, 862.0], [1057.0, 888.0], [858.0, 888.0]]], "lines": ["私は家族で高山の親戚の", "家に遊び行くわ"]}, {"box": [296, 596, 617, 660], "vertical": false, "font_size": 32, "lines_coords": [[[296.0, 596.0], [611.0, 596.0], [611.0, 628.0], [296.0, 628.0]], [[298.0, 628.0], [590.0, 628.0], [590.0, 660.0], [298.0, 660.0]]], "lines": ["私はお昼までゆっくり寝て", "ちくわと近所にこ初詣して"]}, {"box": [283, 711, 633, 741], "vertical": false, "font_size": 24, "lines_coords": [[[283.0, 714.0], [633.0, 714.0], [633.0, 738.0], [283.0, 738.0]]], "lines": ["あとはショッピングセンターかな"]}, {"box": [286, 825, 627, 892], "vertical": false, "font_size": 26, "lines_coords": [[[290.0, 830.0], [622.0, 830.0], [622.0, 855.0], [290.0, 855.0]], [[288.0, 862.0], [495.0, 862.0], [495.0, 888.0], [288.0, 888.0]]], "lines": ["あ、高山って牛刺しの握りか", "名物なんだっけ？"]}, {"box": [871, 1349, 1143, 1382], "vertical": false, "font_size": 25, "lines_coords": [[[877.0, 1353.0], [1132.0, 1353.0], [1132.0, 1378.0], [877.0, 1378.0]]], "lines": ["いいよね飛騨高山"]}, {"box": [275, 1260, 627, 1291], "vertical": false, "font_size": 26, "lines_coords": [[[277.0, 1261.0], [622.0, 1260.0], [622.0, 1286.0], [277.0, 1288.0]]], "lines": ["毎年食べに行くでー（＊・ワ｀＊"]}, {"box": [268, 1350, 624, 1382], "vertical": false, "font_size": 25, "lines_coords": [[[271.0, 1355.0], [624.0, 1353.0], [624.0, 1378.0], [271.0, 1380.0]]], "lines": ["いいなー！牛刺しし屋り（＊＞）く＊"]}, {"box": [864, 1479, 1198, 1513], "vertical": false, "font_size": 26, "lines_coords": [[[870.0, 1485.0], [1194.0, 1485.0], [1194.0, 1511.0], [870.0, 1511.0]]], "lines": ["なでしこはどこか行くの？"]}, {"box": [874, 1564, 1193, 1622], "vertical": false, "font_size": 25, "lines_coords": [[[879.0, 1567.0], [1190.0, 1567.0], [1190.0, 1591.0], [879.0, 1591.0]], [[877.0, 1595.0], [1014.0, 1595.0], [1014.0, 1621.0], [877.0, 1621.0]]], "lines": ["うん。浜名湖ののおばあちゃんち", "行く予定だよ"]}], "img_path": "00019.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [850, 140, 1153, 210], "vertical": false, "font_size": 32, "lines_coords": [[[855.0, 142.0], [1151.0, 142.0], [1151.0, 174.0], [855.0, 174.0]], [[855.0, 178.0], [1057.0, 178.0], [1057.0, 210.0], [855.0, 210.0]]], "lines": ["浜名湖でことはウナギ", "食べに行くん？"]}, {"box": [291, 150, 600, 179], "vertical": false, "font_size": 25, "lines_coords": [[[298.0, 153.0], [592.0, 153.0], [592.0, 178.0], [298.0, 178.0]]], "lines": ["私はまたソロキャン行くよ"]}, {"box": [283, 234, 608, 298], "vertical": false, "font_size": 28, "lines_coords": [[[288.0, 240.0], [607.0, 240.0], [607.0, 264.0], [288.0, 264.0]], [[286.0, 266.0], [388.0, 266.0], [388.0, 298.0], [286.0, 298.0]]], "lines": ["場所は決めてないけど海の方", "伊豆とか"]}, {"box": [856, 700, 1158, 786], "vertical": false, "font_size": 22, "lines_coords": [[[864.0, 703.0], [1151.0, 703.0], [1151.0, 721.0], [864.0, 721.0]], [[860.0, 729.0], [1117.0, 729.0], [1117.0, 753.0], [860.0, 753.0]], [[860.0, 759.0], [1126.0, 759.0], [1126.0, 783.0], [860.0, 783.0]]], "lines": ["うへへへぇーい、）すぐ近くに", "おいしいウナギ屋さんが", "あるんですよぅ奧さん！！"]}, {"box": [843, 828, 1166, 859], "vertical": false, "font_size": 25, "lines_coords": [[[845.0, 830.0], [1164.0, 830.0], [1164.0, 855.0], [845.0, 855.0]]], "lines": ["なでしこちゃんはウナギかぁ"]}, {"box": [256, 730, 629, 765], "vertical": false, "font_size": 24, "lines_coords": [[[256.0, 735.0], [622.0, 735.0], [622.0, 759.0], [256.0, 759.0]]], "lines": ["いずキャン！！しいいねい（＊｀ｖ｀＊"]}, {"box": [255, 826, 626, 858], "vertical": false, "font_size": 25, "lines_coords": [[[255.0, 830.0], [626.0, 826.0], [626.0, 851.0], [255.0, 855.0]]], "lines": ["伊豆あったかいしええよねー（・ワ）"]}, {"box": [891, 941, 1172, 1008], "vertical": false, "font_size": 26, "lines_coords": [[[892.0, 945.0], [1141.0, 945.0], [1141.0, 971.0], [892.0, 971.0]], [[894.0, 980.0], [1170.0, 980.0], [1170.0, 1006.0], [894.0, 1006.0]]], "lines": ["海から早る初日の出", "見に行こうと思ってさ"]}, {"box": [894, 1042, 1176, 1108], "vertical": false, "font_size": 32, "lines_coords": [[[894.0, 1046.0], [1168.0, 1042.0], [1168.0, 1074.0], [894.0, 1078.0]], [[896.0, 1076.0], [1110.0, 1076.0], [1110.0, 1108.0], [896.0, 1108.0]]], "lines": ["海からの日の出もキレイ", "だよー（＊｀ｖ｀＊）"]}, {"box": [868, 1389, 1188, 1477], "vertical": false, "font_size": 24, "lines_coords": [[[873.0, 1393.0], [1033.0, 1393.0], [1033.0, 1417.0], [873.0, 1417.0]], [[875.0, 1419.0], [1126.0, 1419.0], [1126.0, 1443.0], [875.0, 1443.0]], [[871.0, 1451.0], [1186.0, 1451.0], [1186.0, 1475.0], [871.0, 1475.0]]], "lines": ["伊豆っていえば", "下田の余目編／「一ガーナ", "おいしいってＴＶでやってたよ"]}, {"box": [870, 1539, 1177, 1567], "vertical": false, "font_size": 26, "lines_coords": [[[870.0, 1539.0], [1177.0, 1541.0], [1177.0, 1567.0], [870.0, 1565.0]]], "lines": ["へぇー行ってみようかな"]}, {"box": [903, 1627, 1027, 1660], "vertical": false, "font_size": 26, "lines_coords": [[[909.0, 1631.0], [1021.0, 1631.0], [1021.0, 1657.0], [909.0, 1657.0]]], "lines": ["あとさー"]}], "img_path": "00020.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1115, 144, 1218, 515], "vertical": true, "font_size": 100, "lines_coords": [[[1119.0, 144.0], [1218.0, 144.0], [1215.0, 515.0], [1115.0, 515.0]]], "lines": ["圧倒的３"]}, {"box": [365, 123, 500, 787], "vertical": true, "fo