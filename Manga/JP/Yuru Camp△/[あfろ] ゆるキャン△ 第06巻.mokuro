0], [826.0, 1021.0], [789.0, 1021.0]], [[753.0, 815.0], [785.0, 815.0], [785.0, 926.0], [753.0, 926.0]]], "lines": ["あポール家に", "忘れた。"]}, {"box": [579, 1241, 668, 1363], "vertical": true, "font_size": 89, "lines_coords": [[[579.0, 1241.0], [668.0, 1241.0], [668.0, 1363.0], [579.0, 1363.0]]], "lines": ["次にこの"]}, {"box": [1183, 1430, 1220, 1526], "vertical": true, "font_size": 34, "lines_coords": [[[1183.0, 1432.0], [1216.0, 1430.0], [1220.0, 1524.0], [1186.0, 1526.0]]], "lines": ["えぇー"]}, {"box": [648, 1424, 713, 1620], "vertical": true, "font_size": 26, "lines_coords": [[[684.0, 1426.0], [710.0, 1426.0], [710.0, 1620.0], [684.0, 1620.0]], [[648.0, 1425.0], [675.0, 1425.0], [675.0, 1565.0], [648.0, 1565.0]]], "lines": ["ボール忘れたら", "終わりやん"]}, {"box": [136, 1430, 215, 1640], "vertical": true, "font_size": 36, "lines_coords": [[[172.0, 1432.0], [211.0, 1430.0], [215.0, 1541.0], [176.0, 1543.0]], [[136.0, 1434.0], [168.0, 1434.0], [168.0, 1640.0], [136.0, 1640.0]]], "lines": ["まて．．．", "．．．まてまて"]}], "img_path": "00009.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1207, 131, 1275, 339], "vertical": true, "font_size": 30, "lines_coords": [[[1246.0, 133.0], [1273.0, 133.0], [1273.0, 311.0], [1246.0, 311.0]], [[1207.0, 131.0], [1239.0, 131.0], [1239.0, 339.0], [1207.0, 339.0]]], "lines": ["片方はこう．．．", "ポール代わりに"]}, {"box": [703, 155, 768, 403], "vertical": true, "font_size": 65, "lines_coords": [[[703.0, 155.0], [768.0, 155.0], [768.0, 403.0], [703.0, 403.0]]], "lines": ["ジャーン"]}, {"box": [138, 159, 208, 406], "vertical": true, "font_size": 66, "lines_coords": [[[138.0, 159.0], [204.0, 159.0], [208.0, 406.0], [142.0, 406.0]]], "lines": ["ケーン！！"]}, {"box": [1173, 718, 1293, 1080], "vertical": true, "font_size": 113, "lines_coords": [[[1181.0, 718.0], [1293.0, 720.0], [1286.0, 1080.0], [1173.0, 1078.0]]], "lines": ["ホイッ！！"]}, {"box": [846, 489, 877, 635], "vertical": true, "font_size": 26, "lines_coords": [[[847.0, 491.0], [873.0, 491.0], [873.0, 635.0], [847.0, 635.0]]], "lines": ["木に結んで"]}, {"box": [1186, 1156, 1297, 1445], "vertical": true, "font_size": 52, "lines_coords": [[[1241.0, 1156.0], [1293.0, 1156.0], [1297.0, 1351.0], [1245.0, 1351.0]], [[1186.0, 1158.0], [1237.0, 1158.0], [1237.0, 1445.0], [1186.0, 1445.0]]], "lines": ["なでしこ", "ポール役な！！"]}, {"box": [679, 1201, 838, 1356], "vertical": false, "font_size": 155, "lines_coords": [[[679.0, 1201.0], [838.0, 1201.0], [838.0, 1356.0], [679.0, 1356.0]]], "lines": ["！！？"]}, {"box": [515, 1136, 615, 1666], "vertical": true, "font_size": 45, "lines_coords": [[[568.0, 1136.0], [613.0, 1136.0], [615.0, 1666.0], [570.0, 1666.0]], [[519.0, 1179.0], [564.0, 1179.0], [560.0, 1421.0], [515.0, 1421.0]]], "lines": ["３張り組をタボプに取りつけ", "ペグで固定し"]}, {"box": [425, 965, 465, 1008], "vertical": false, "font_size": 39, "lines_coords": [[[425.0, 969.0], [465.0, 969.0], [465.0, 1008.0], [425.0, 1008.0]]], "lines": ["あ"]}, {"box": [573, 1429, 616, 1667], "vertical": true, "font_size": 43, "lines_coords": [[[573.0, 1429.0], [616.0, 1429.0], [616.0, 1667.0], [573.0, 1667.0]]], "lines": ["プに取りつけ"]}], "img_path": "00010.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1169, 140, 1212, 600], "vertical": true, "font_size": 32, "lines_coords": [[[1173.0, 275.0], [1205.0, 275.0], [1205.0, 581.0], [1173.0, 581.0]]], "lines": ["元を自立させます。"]}, {"box": [144, 136, 232, 661], "vertical": true, "font_size": 34, "lines_coords": [[[191.0, 136.0], [228.0, 136.0], [228.0, 661.0], [191.0, 661.0]], [[144.0, 168.0], [176.0, 168.0], [176.0, 590.0], [144.0, 590.0]]], "lines": ["５最後に張り網の長さを調節し", "テンションをかけたら．．．"]}, {"box": [1147, 729, 1211, 975], "vertical": true, "font_size": 60, "lines_coords": [[[1147.0, 729.0], [1207.0, 729.0], [1211.0, 973.0], [1151.0, 973.0]]], "lines": ["完成です。"]}, {"box": [148, 735, 287, 1230], "vertical": true, "font_size": 42, "lines_coords": [[[241.0, 736.0], [279.0, 736.0], [285.0, 1181.0], [247.0, 1181.0]], [[193.0, 735.0], [243.0, 735.0], [243.0, 1230.0], [193.0, 1230.0]], [[148.0, 736.0], [185.0, 736.0], [191.0, 1029.0], [153.0, 1029.0]]], "lines": ["タープを安定させるには、", "張り網ペクポールの角度が", "重要になります。"]}, {"box": [1136, 1316, 1209, 1629], "vertical": true, "font_size": 32, "lines_coords": [[[1175.0, 1318.0], [1207.0, 1318.0], [1207.0, 1629.0], [1175.0, 1629.0]], [[1136.0, 1316.0], [1168.0, 1316.0], [1170.0, 1629.0], [1138.0, 1629.0]]], "lines": ["タープ一枚あるだけで", "だいぶ雰囲気出るなー"]}, {"box": [150, 1315, 221, 1640], "vertical": true, "font_size": 30, "lines_coords": [[[187.0, 1316.0], [219.0, 1316.0], [219.0, 1640.0], [187.0, 1640.0]], [[151.0, 1318.0], [178.0, 1318.0], [178.0, 1595.0], [151.0, 1595.0]]], "lines": ["なキャンプしてる感が", "グッと上がるだろー"]}], "img_path": "00011.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1112, 174, 1197, 474], "vertical": true, "font_size": 37, "lines_coords": [[[1151.0, 174.0], [1190.0, 174.0], [1196.0, 474.0], [1156.0, 474.0]], [[1113.0, 178.0], [1147.0, 178.0], [1147.0, 326.0], [1113.0, 326.0]]], "lines": ["ちなみにタープの", "素材には"]}, {"box": [151, 176, 191, 438], "vertical": true, "font_size": 32, "lines_coords": [[[151.0, 180.0], [183.0, 180.0], [183.0, 436.0], [151.0, 436.0]]], "lines": ["などがあります"]}, {"box": [805, 445, 1022, 523], "vertical": false, "font_size": 33, "lines_coords": [[[806.0, 448.0], [1018.0, 448.0], [1018.0, 480.0], [806.0, 480.0]], [[851.0, 485.0], [976.0, 489.0], [976.0, 523.0], [851.0, 519.0]]], "lines": ["携帯性に優れた", "ナイロン"]}, {"box": [309, 448, 659, 520], "vertical": false, "font_size": 32, "lines_coords": [[[346.0, 448.0], [622.0, 448.0], [622.0, 480.0], [346.0, 480.0]], [[316.0, 487.0], [652.0, 487.0], [652.0, 519.0], [316.0, 519.0]]], "lines": ["中で焚き火ができる", "難燃性に優れたコットン"]}, {"box": [1176, 1197, 1203, 1350], "vertical": true, "font_size": 24, "lines_coords": [[[1177.0, 1198.0], [1201.0, 1198.0], [1201.0, 1350.0], [1177.0, 1350.0]]], "lines": ["そういえば"]}, {"box": [826, 1186, 889, 1560], "vertical": true, "font_size": 26, "lines_coords"