 "lines": ["和物でテントの", "かわりになる物", "無さそうやし"]}, {"box": [746, 783, 789, 856], "vertical": true, "font_size": 43, "lines_coords": [[[746.0, 783.0], [789.0, 783.0], [789.0, 856.0], [746.0, 856.0]]], "lines": ["あっ"]}, {"box": [616, 622, 687, 905], "vertical": true, "font_size": 30, "lines_coords": [[[654.0, 622.0], [686.0, 622.0], [686.0, 903.0], [654.0, 903.0]], [[616.0, 622.0], [643.0, 622.0], [643.0, 870.0], [616.0, 870.0]]], "lines": ["殿様を運ぶあれは？", "テントっほいよ？"]}, {"box": [168, 793, 199, 1033], "vertical": true, "font_size": 27, "lines_coords": [[[168.0, 795.0], [195.0, 795.0], [195.0, 1031.0], [168.0, 1031.0]]], "lines": ["あーええかも！！"]}, {"box": [183, 1265, 269, 1525], "vertical": true, "font_size": 39, "lines_coords": [[[228.0, 1271.0], [268.0, 1271.0], [268.0, 1522.0], [228.0, 1522.0]], [[183.0, 1265.0], [221.0, 1265.0], [221.0, 1492.0], [183.0, 1492.0]]], "lines": ["一気に胡散臭く", "なったぞオイ"]}], "img_path": "00162.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1149, 129, 1213, 493], "vertical": true, "font_size": 27, "lines_coords": [[[1183.0, 129.0], [1211.0, 129.0], [1209.0, 493.0], [1181.0, 493.0]], [[1149.0, 135.0], [1175.0, 135.0], [1175.0, 328.0], [1149.0, 328.0]]], "lines": ["動画サイトで「キャンフ動画」", "ってあんじゃん"]}, {"box": [993, 262, 1057, 283], "vertical": false, "font_size": 21, "lines_coords": [[[993.0, 262.0], [1057.0, 262.0], [1057.0, 283.0], [993.0, 283.0]]], "lines": ["次の動画"]}, {"box": [123, 69, 470, 99], "vertical": false, "font_size": 26, "lines_coords": [[[123.0, 69.0], [470.0, 73.0], [470.0, 99.0], [123.0, 95.0]]], "lines": ["放課後４４キャンプ動画"]}, {"box": [311, 174, 435, 211], "vertical": false, "font_size": 34, "lines_coords": [[[311.0, 174.0], [435.0, 178.0], [435.0, 211.0], [311.0, 208.0]]], "lines": ["ＷｅＴｕｂｅ"]}, {"box": [1023, 444, 1055, 712], "vertical": true, "font_size": 27, "lines_coords": [[[1023.0, 444.0], [1055.0, 444.0], [1055.0, 712.0], [1023.0, 712.0]]], "lines": ["あ、私たまに見とるで"]}, {"box": [862, 566, 991, 789], "vertical": true, "font_size": 27, "lines_coords": [[[965.0, 566.0], [991.0, 566.0], [991.0, 789.0], [965.0, 789.0]], [[931.0, 566.0], [958.0, 566.0], [958.0, 763.0], [931.0, 763.0]], [[896.0, 568.0], [922.0, 568.0], [922.0, 763.0], [896.0, 763.0]], [[862.0, 570.0], [888.0, 570.0], [888.0, 736.0], [862.0, 736.0]]], "lines": ["定点カメラ置いて", "テント立てたり", "焚き火するとこ", "撮ったりなー"]}, {"box": [677, 864, 882, 893], "vertical": false, "font_size": 29, "lines_coords": [[[677.0, 864.0], [882.0, 864.0], [882.0, 893.0], [677.0, 893.0]]], "lines": ["視聴回数１０．０２"]}, {"box": [388, 828, 571, 853], "vertical": false, "font_size": 25, "lines_coords": [[[388.0, 828.0], [571.0, 828.0], [571.0, 853.0], [388.0, 853.0]]], "lines": ["野クルチャンネル"]}, {"box": [290, 747, 592, 824], "vertical": false, "font_size": 31, "lines_coords": [[[292.0, 750.0], [579.0, 750.0], [579.0, 781.0], [292.0, 781.0]]], "lines": ["野クル冬キャンプ"]}, {"box": [163, 459, 234, 835], "vertical": true, "font_size": 31, "lines_coords": [[[196.0, 459.0], [234.0, 459.0], [234.0, 526.0], [196.0, 526.0]], [[163.0, 463.0], [187.0, 463.0], [187.0, 834.0], [163.0, 834.0]]], "lines": ["あれ", "うちらもやってみないか？"]}, {"box": [1123, 991, 1231, 1303], "vertical": true, "font_size": 30, "lines_coords": [[[1200.0, 991.0], [1231.0, 991.0], [1231.0, 1207.0], [1200.0, 1207.0]], [[1164.0, 993.0], [1190.0, 993.0], [1190.0, 1301.0], [1164.0, 1301.0]], [[1123.0, 991.0], [1155.0, 991.0], [1155.0, 1303.0], [1123.0, 1303.0]]], "lines": ["食材調達しつつ", "キャンプ場行くとこも", "スマホで自撮りしてさ"]}, {"box": [532, 980, 681, 1387], "vertical": true, "font_size": 30, "lines_coords": [[[648.0, 980.0], [680.0, 980.0], [678.0, 1261.0], [646.0, 1261.0]], [[609.0, 980.0], [643.0, 980.0], [637.0, 1140.0], [603.0, 1140.0]], [[570.0, 982.0], [598.0, 982.0], [600.0, 1325.0], [571.0, 1325.0]], [[534.0, 982.0], [560.0, 982.0], [560.0, 1383.0], [534.0, 1383.0]]], "lines": ["キャンプ場着いたら", "散策したり", "ＢＢＱしてるとこ撮って", "まったり夜が更けてくんだよ"]}, {"box": [740, 1561, 776, 1689], "vertical": true, "font_size": 32, "lines_coords": [[[744.0, 1561.0], [776.0, 1561.0], [772.0, 1689.0], [740.0, 1689.0]]], "lines": ["うんうん"]}, {"box": [176, 1565, 264, 1717], "vertical": true, "font_size": 41, "lines_coords": [[[219.0, 1569.0], [260.0, 1569.0], [264.0, 1717.0], [223.0, 1717.0]], [[176.0, 1565.0], [217.0, 1565.0], [217.0, 1610.0], [176.0, 1610.0]]], "lines": ["いいねー", "！！"]}], "img_path": "00163.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1089, 140, 1187, 504], "vertical": true, "font_size": 26, "lines_coords": [[[1158.0, 140.0], [1185.0, 140.0], [1185.0, 504.0], [1158.0, 504.0]], [[1123.0, 140.0], [1149.0, 140.0], [1149.0, 500.0], [1123.0, 500.0]], [[1089.0, 140.0], [1115.0, 140.0], [1115.0, 420.0], [1089.0, 420.0]]], "lines": ["しかし肝だめしで森に入った", "野クル部員達はとんでもない", "光景を目にしてしまう。"]}, {"box": [160, 161, 269, 472], "vertical": true, "font_size": 28, "lines_coords": [[[238.0, 163.0], [266.0, 163.0], [264.0, 472.0], [236.0, 472.0]], [[195.0, 161.0], [226.0, 161.0], [228.0, 416.0], [196.0, 416.0]], [[161.0, 165.0], [187.0, 165.0], [187.0, 444.0], [161.0, 444.0]]], "lines": ["そこは謎の秘密結社が", "悪魔の儀式を行う", "集会場だったのだ！！"]}, {"box": [1074, 555, 1185, 1023], "vertical": true, "font_size": 30, "lines_coords": [[[1153.0, 555.0], [1185.0, 555.0], [1185.0, 840.0], [1153.0, 840.0]], [[1110.0, 555.0], [1141.0, 555.0], [1141.0, 1023.0], [1110.0, 1023.0]], [[1074.0, 556.0], [1100.0, 556.0], [1100.0, 678.0], [1074.0, 678.0]]], "lines": ["逃げ惑うなでしこ！！", "死んだフリでやりすごそうとする", "イヌ子！！"]}, {"box": [163, 647, 274, 1216], "vertical": true, "font_size": 31, "lines_coords": [[[241.0, 650.0], [273.0, 650.0], [273.0, 995.0], [241.0, 995.0]], [[202.0, 650.0], [234.0, 650.0], [234.0, 1213.0], [202.0, 1213.0]], [[165.0, 650.0], [193.0, 650.0], [191.0, 1119.0], [163.0, 1119.0]]], "lines": ["原付で逃げようとするが、", "なぜかエンジンがかからないしまりん！！", "気づかず寝袋でグッスリの斉藤！！"]}, {"box": [1147, 1291, 1210, 1514], "vertical": true, "font_size": 26, "lines_coords": [[[1181.0, 1291.0], [1207.0, 1291.0], [1207.0, 1513.0], [1181.0, 1513.0]], [[1147.0,