7.0], [180.0, 1781.0], [146.0, 1781.0]]], "lines": ["賢明な", "判断やで。"]}], "img_path": "00006.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [118, 63, 849, 114], "vertical": false, "font_size": 38, "lines_coords": [[[118.0, 69.0], [849.0, 65.0], [849.0, 103.0], [118.0, 106.0]]], "lines": ["第２９話『バイトのお金で何を買う？"]}], "img_path": "00007.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1134, 99, 1190, 348], "vertical": true, "font_size": 52, "lines_coords": [[[1134.0, 99.0], [1186.0, 99.0], [1190.0, 348.0], [1138.0, 348.0]]], "lines": ["ヘキサゴン"]}, {"box": [155, 84, 233, 583], "vertical": true, "font_size": 67, "lines_coords": [[[155.0, 86.0], [223.0, 84.0], [226.0, 262.0], [159.0, 264.0]], [[159.0, 350.0], [225.0, 350.0], [225.0, 583.0], [159.0, 583.0]]], "lines": ["タァー", "ップ！！"]}, {"box": [1162, 695, 1192, 879], "vertical": true, "font_size": 26, "lines_coords": [[[1164.0, 697.0], [1190.0, 697.0], [1190.0, 879.0], [1164.0, 879.0]]], "lines": ["買っちったぜ"]}, {"box": [868, 688, 941, 938], "vertical": true, "font_size": 34, "lines_coords": [[[901.0, 688.0], [941.0, 688.0], [941.0, 864.0], [901.0, 864.0]], [[870.0, 690.0], [898.0, 690.0], [896.0, 937.0], [868.0, 937.0]]], "lines": ["おー今度は", "タープ買ったんや"]}, {"box": [412, 552, 571, 594], "vertical": false, "font_size": 42, "lines_coords": [[[412.0, 552.0], [571.0, 552.0], [571.0, 594.0], [412.0, 594.0]]], "lines": ["¥６，０００"]}, {"box": [592, 701, 669, 907], "vertical": true, "font_size": 33, "lines_coords": [[[635.0, 705.0], [669.0, 705.0], [669.0, 868.0], [635.0, 868.0]], [[592.0, 701.0], [624.0, 701.0], [624.0, 905.0], [592.0, 905.0]]], "lines": ["ふおおーっ", "ターフだー！！"]}, {"box": [463, 678, 529, 945], "vertical": true, "font_size": 29, "lines_coords": [[[502.0, 682.0], [526.0, 682.0], [526.0, 945.0], [502.0, 945.0]], [[466.0, 678.0], [500.0, 678.0], [496.0, 791.0], [463.0, 791.0]]], "lines": ["クリキャンやってみて", "やっぱり"]}, {"box": [632, 1269, 1214, 1356], "vertical": fals