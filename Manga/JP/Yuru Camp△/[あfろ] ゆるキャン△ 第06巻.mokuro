70.0, 438.0], [202.0, 438.0], [202.0, 641.0], [170.0, 641.0]], [[125.0, 438.0], [159.0, 438.0], [155.0, 645.0], [121.0, 645.0]]], "lines": ["キャンプ場の", "アルバイト！？"]}, {"box": [221, 775, 278, 1001], "vertical": true, "font_size": 24, "lines_coords": [[[249.0, 776.0], [273.0, 776.0], [273.0, 1001.0], [249.0, 1001.0]], [[221.0, 776.0], [245.0, 776.0], [245.0, 950.0], [221.0, 950.0]]], "lines": ["それは分からんけど", "惹かれるよねぇ"]}, {"box": [1086, 1153, 1203, 1476], "vertical": true, "font_size": 28, "lines_coords": [[[1175.0, 1156.0], [1203.0, 1156.0], [1203.0, 1185.0], [1175.0, 1185.0]], [[1166.0, 1252.0], [1192.0, 1252.0], [1192.0, 1468.0], [1166.0, 1468.0]], [[1125.0, 1250.0], [1156.0, 1250.0], [1156.0, 1441.0], [1125.0, 1441.0]], [[1089.0, 1254.0], [1115.0, 1254.0], [1115.0, 1470.0], [1089.0, 1470.0]]], "lines": ["ま", "うちらの店でも", "募集あったら", "すぐ連絡するわ"]}, {"box": [455, 1156, 519, 1468], "vertical": true, "font_size": 27, "lines_coords": [[[491.0, 1156.0], [519.0, 1156.0], [515.0, 1327.0], [487.0, 1327.0]], [[455.0, 1160.0], [481.0, 1160.0], [481.0, 1468.0], [455.0, 1468.0]]], "lines": ["ビバーク新刊", "借りてきたけど読むか？"]}, {"box": [622, 1483, 707, 1627], "vertical": true, "font_size": 39, "lines_coords": [[[667.0, 1485.0], [706.0, 1485.0], [706.0, 1627.0], [667.0, 1627.0]], [[622.0, 1483.0], [661.0, 1483.0], [661.0, 1612.0], [622.0, 1612.0]]], "lines": ["おねがい", "します。"]}, {"box": [174, 1464, 206, 1700], "vertical": true, "font_size": 26, "lines_coords": [[[176.0, 1464.0], [202.0, 1464.0], [202.0, 1696.0], [176.0, 1696.0]]], "lines": ["うん読む読むー"]}], "img_path": "00038.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [799, 108, 1176, 204], "vertical": false, "font_size": 95, "lines_coords": [[[806.0, 100.0], [1166.0, 106.0], [1164.0, 208.0], [804.0, 203.0]]], "lines": ["ＢＮＯＵＡＣ"]}, {"box": [958, 234, 1012, 382], "vertical": true, "font_size": 29, "lines_coords": [[[986.0, 238.0], [1012.0, 238.0], [1012.0, 373.0], [986.0, 373.0]], [[958.0, 234.0], [990.0, 234.0], [