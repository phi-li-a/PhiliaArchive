75.0]], [[1145.0, 691.0], [1177.0, 691.0], [1177.0, 913.0], [1145.0, 913.0]]], "lines": ["平湯温泉で雪見露天", "入ってきたわー"]}, {"box": [140, 680, 671, 786], "vertical": false, "font_size": 46, "lines_coords": [[[183.0, 680.0], [626.0, 680.0], [626.0, 736.0], [183.0, 736.0]], [[140.0, 744.0], [671.0, 744.0], [671.0, 781.0], [140.0, 781.0]]], "lines": ["和洋折衷スイーツ！！", "栗きんとんクッキーサンドうめえ！！"]}, {"box": [1145, 1325, 1211, 1523], "vertical": true, "font_size": 30, "lines_coords": [[[1177.0, 1327.0], [1211.0, 1327.0], [1211.0, 1415.0], [1177.0, 1415.0]], [[1145.0, 1325.0], [1170.0, 1325.0], [1170.0, 1522.0], [1145.0, 1522.0]]], "lines": ["浜松は", "どうだったん？"]}, {"box": [342, 1188, 510, 1230], "vertical": false, "font_size": 34, "lines_coords": [[[350.0, 1188.0], [500.0, 1196.0], [498.0, 1230.0], [348.0, 1222.0]]], "lines": ["飛騨士産"]}, {"box": [845, 1471, 911, 1807], "vertical": true, "font_size": 25, "lines_coords": [[[885.0, 1475.0], [909.0, 1475.0], [909.0, 1807.0], [885.0, 1807.0]], [[849.0, 1471.0], [875.0, 1471.0], [871.0, 1696.0], [845.0, 1696.0]]], "lines": ["こっちはおばあちゃん家で", "まったりしてたよ"]}, {"box": [723, 1348, 789, 1655], "vertical": true, "font_size": 29, "lines_coords": [[[761.0, 1350.0], [787.0, 1350.0], [787.0, 1655.0], [761.0, 1655.0]], [[723.0, 1348.0], [755.0, 1348.0], [755.0, 1603.0], [723.0, 1603.0]]], "lines": ["１日目は地元の友だちと", "リンちゃんが来てー"]}], "img_path": "00005.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1137, 48, 1200, 441], "vertical": true, "font_size": 24, "lines_coords": [[[1173.0, 48.0], [1198.0, 48.0], [1198.0, 440.0], [1173.0, 440.0]], [[1138.0, 48.0], [1162.0, 48.0], [1162.0, 358.0], [1138.0, 358.0]]], "lines": ["２日目はお姉ちゃんたちが来て", "家族で初詣行って来たよ"]}, {"box": [133, 71, 656, 177], "vertical": false, "font_size": 54, "lines_coords": [[[133.0, 71.0], [656.0, 71.0], [656.0, 127.0], [133.0, 127.0]], [[136.0, 125.0], [652.0, 125.0], [652.0, 176.0], [136.0, 176.0]]], "lines": ["浜松はうなぎだけじゃねぇ！！", "すっぽんビスケットうまし！！"]}, {"box": [1151, 695, 1207, 1