1.0]], [[309.0, 860.0], [341.0, 860.0], [341.0, 986.0], [309.0, 986.0]]], "lines": ["火持ちが良くて", "専用の器具に入れて使うと、", "丸一日持たせる事も出来る", "らしいわ"]}, {"box": [189, 1023, 223, 1172], "vertical": true, "font_size": 34, "lines_coords": [[[189.0, 1023.0], [223.0, 1023.0], [223.0, 1106.0], [189.0, 1106.0]]], "lines": ["へぇー"]}, {"box": [1115, 1333, 1204, 1708], "vertical": true, "font_size": 39, "lines_coords": [[[1162.0, 1335.0], [1200.0, 1335.0], [1200.0, 1597.0], [1162.0, 1597.0]], [[1115.0, 1333.0], [1155.0, 1333.0], [1156.0, 1708.0], [1117.0, 1708.0]]], "lines": ["面白そうなので", "とりあえず作ってみた"]}, {"box": [513, 1710, 831, 1772], "vertical": false, "font_size": 26, "lines_coords": [[[513.0, 1710.0], [828.0, 1710.0], [828.0, 1734.0], [513.0, 1734.0]], [[562.0, 1743.0], [774.0, 1743.0], [774.0, 1770.0], [562.0, 1770.0]]], "lines": ["ミニテーブル＋毛布＋豆炭あんかて", "かんたんこたつ"]}, {"box": [185, 1395, 292, 1678], "vertical": true, "font_size": 30, "lines_coords": [[[258.0, 1396.0], [290.0, 1396.0], [290.0, 1586.0], [258.0, 1586.0]], [[219.0, 1395.0], [251.0, 1395.0], [253.0, 1678.0], [221.0, 1678.0]], [[185.0, 1400.0], [211.0, 1400.0], [211.0, 1608.0], [185.0, 1608.0]]], "lines": ["これがあれば", "真冬のキャンプでも", "ぬくぬくだーっ"]}, {"box": [118, 1809, 748, 1839], "vertical": false, "font_size": 26, "lines_coords": [[[118.0, 1809.0], [748.0, 1813.0], [748.0, 1839.0], [118.0, 1835.0]]], "lines": ["米豆炭を使う時は火事やー敵化炭素中高に気をつけましょう。"]}]}