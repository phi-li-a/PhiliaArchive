{"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1098, 129, 1202, 588], "vertical": true, "font_size": 30, "lines_coords": [[[1168.0, 129.0], [1200.0, 129.0], [1201.0, 498.0], [1170.0, 498.0]], [[1132.0, 129.0], [1164.0, 129.0], [1162.0, 588.0], [1130.0, 588.0]], [[1098.0, 133.0], [1125.0, 133.0], [1125.0, 577.0], [1098.0, 577.0]]], "lines": ["今回作るサラトガクーラーは", "幸口なので普通の唐幸子の代わりに", "ハバネロバウダーで幸味を出します"]}, {"box": [830, 176, 870, 356], "vertical": true, "font_size": 34, "lines_coords": [[[830.0, 176.0], [864.0, 176.0], [870.0, 337.0], [836.0, 337.0]]], "lines": ["そーっと．．"]}, {"box": [271, 159, 305, 465], "vertical": true, "font_size": 30, "lines_coords": [[[273.0, 159.0], [305.0, 159.0], [303.0, 465.0], [271.0, 465.0]]], "lines": ["淡ハバネロパウダーは"]}, {"box": [159, 189, 264, 555], "vertical": true, "font_size": 30, "lines_coords": [[[238.0, 191.0], [264.0, 191.0], [264.0, 403.0], [238.0, 403.0]], [[196.0, 189.0], [228.0, 189.0], [226.0, 555.0], [195.0, 555.0]], [[159.0, 189.0], [191.0, 189.0], [191.0, 493.0], [159.0, 493.0]]], "lines": ["量を間違えると", "死ぬほど辛くなりますので", "十分気をつけましょう"]}, {"box": [1104, 639, 1205, 1112], "vertical": true, "font_size": 27, "lines_coords": [[[1173.0, 639.0], [1200.0, 639.0], [1200.0, 1104.0], [1173.0, 1104.0]], [[1136.0, 639.0], [1164.0, 639.0], [1166.0, 1100.0], [1138.0, 1100.0]], [[1104.0, 645.0], [1130.0, 645.0], [1130.0, 841.0], [1104.0, 841.0]]], "lines": ["３分ほど煮たら、次を止め少し冷まし", "さらに生姜スライス２０ｇを追加して", "一晩寝かします。"]}, {"box": [285, 648, 347, 1046], "vertical": true, "font_size": 24, "lines_coords": [[[318.0, 648.0], [345.0, 648.0], [345.0, 1046.0], [318.0, 1046.0]], [[285.0, 650.0], [305.0, 650.0], [305.0, 774.0], [285.0, 774.0]]], "lines": ["とりあえずジンジャーシロップは", "コレでよー"]}, {"box": [1158, 1175, 1226, 1548], "vertical": true, "font_size": 32, "lines_coords": [[[1190.0, 1175.0], [1226.0, 1175.0], [1226.0, 1265.0], [1190.0, 1265.0]], [[1158.0, 1179.0], [1185.0, 1179.0], [1185.0, 1548.0], [1158.0, 1548.0]]], "lines": ["本当は", "一晩寝かしたいと