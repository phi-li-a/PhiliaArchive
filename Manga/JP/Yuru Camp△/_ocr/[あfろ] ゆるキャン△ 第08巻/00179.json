{"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [433, 487, 937, 598], "vertical": false, "font_size": 29, "lines_coords": [[[435.0, 487.0], [894.0, 489.0], [894.0, 517.0], [435.0, 515.0]], [[433.0, 525.0], [937.0, 525.0], [937.0, 562.0], [433.0, 562.0]], [[435.0, 571.0], [615.0, 571.0], [615.0, 598.0], [435.0, 598.0]]], "lines": ["ゆるキャン△＠いかがでしたでしょうか。", "今回は伊豆キャンプ７出発編とへやキャン△を", "収録致しました。"]}, {"box": [420, 652, 980, 804], "vertical": false, "font_size": 29, "lines_coords": [[[420.0, 652.0], [980.0, 652.0], [980.0, 678.0], [420.0, 678.0]], [[420.0, 691.0], [615.0, 691.0], [615.0, 718.0], [420.0, 718.0]], [[515.0, 733.0], [967.0, 735.0], [967.0, 761.0], [515.0, 759.0]], [[511.0, 772.0], [948.0, 770.0], [948.0, 802.0], [511.0, 804.0]]], "lines": ["伊豆は１巻（６話）まるまる使うくらいかなぁ．．と", "思っていましたが", "伊豆広すぎジオスポ＆温泉多すぎ地獄で", "次巻もまだまだ伊豆編は続きそうです。"]}, {"box": [594, 856, 750, 883], "vertical": false, "font_size": 29, "lines_coords": [[[594.0, 856.0], [750.0, 856.0], [750.0, 883.0], [594.0, 883.0]]], "lines": ["あｆろでした。"]}, {"box": [394, 1709, 1061, 1864], "vertical": false, "font_size": 25, "lines_coords": [[[406.0, 1713.0], [1061.0, 1713.0], [1061.0, 1743.0], [406.0, 1743.0]], [[410.0, 1745.0], [753.0, 1745.0], [753.0, 1773.0], [410.0, 1773.0]], [[898.0, 1747.0], [993.0, 1747.0], [993.0, 1772.0], [898.0, 1772.0]], [[403.0, 1775.0], [1040.0, 1775.0], [1040.0, 1803.0], [403.0, 1803.0]], [[403.0, 1809.0], [515.0, 1809.0], [515.0, 1833.0], [403.0, 1833.0]], [[401.0, 1835.0], [729.0, 1835.0], [729.0, 1863.0], [401.0, 1863.0]]], "lines": ["いいよ。まんがタイムきららフォワーお平成３０年１２月号・平成２４年４月、", "・ＣＯＭＯ．ＦＵＺ平成３１年３３月掲載分", "これ．．．", "さらに、このペース平成２９年１２月１８日こ平成３０年７月１２日更新分〜", "・描き下ろし", "本書は以上の内容を収穫しました。"]}, {"box": [406, 1689, 528, 1710], "vertical": false, "font_size": 21, "lines_coords": [[[406.0, 1689.0], [528.0, 1689.0], [528.0, 1710.0], [406.0, 1710.0]]], "lines": ["〈初出＝覧〉て、"]}]}