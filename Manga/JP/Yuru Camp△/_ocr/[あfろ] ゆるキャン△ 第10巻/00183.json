77, 815, 904], "vertical": true, "font_size": 27, "lines_coords": [[[788.0, 777.0], [815.0, 777.0], [815.0, 904.0], [788.0, 904.0]]], "lines": ["あれっ？太眉細目って他にも居たような．．．"]}, {"box": [639, 606, 705, 990], "vertical": true, "font_size": 58, "lines_coords": [[[646.0, 609.0], [705.0, 609.0], [697.0, 990.0], [639.0, 990.0]]], "lines": ["ゆるキャゾ△："]}, {"box": [257, 584, 285, 708], "vertical": true, "font_size": 28, "lines_coords": [[[257.0, 584.0], [285.0, 584.0], [285.0, 708.0], [257.0, 708.0]]], "lines": ["最近なでしこちゃんにホラ吹いても"]}, {"box": [253, 775, 290, 916], "vertical": true, "font_size": 37, "lines_coords": [[[253.0, 775.0], [290.0, 775.0], [290.0, 916.0], [253.0, 916.0]]], "lines": ["あおいそれはホラ吹く時のあんたの目に問題があるんやで"]}, {"box": [66, 584, 93, 736], "vertical": true, "font_size": 27, "lines_coords": [[[66.0, 584.0], [93.0, 584.0], [93.0, 736.0], [66.0, 736.0]]], "lines": ["すぐ見抜かれてまうようになったしつまらんなー"]}, {"box": [79, 827, 93, 911], "vertical": true, "font_size": 14, "lines_coords": [[[79.0, 827.0], [93.0, 827.0], [93.0, 911.0], [79.0, 911.0]]], "lines": ["あおばあちゃん"]}, {"box": [1233, 971, 1273, 1098], "vertical": true, "font_size": 22, "lines_coords": [[[1250.0, 973.0], [1269.0, 973.0], [1273.0, 1091.0], [1254.0, 1091.0]], [[1237.0, 971.0], [1261.0, 971.0], [1258.0, 1098.0], [1233.0, 1098.0]]], "lines": ["その後一族の人間は", "二度と嘘がばれんよう"]}, {"box": [1241, 1174, 1267, 1322], "vertical": true, "font_size": 26, "lines_coords": [[[1241.0, 1174.0], [1267.0, 1174.0], [1267.0, 1322.0], [1241.0, 1322.0]]], "lines": ["そうして戦国時代の末期には「狐目太眉の犬山一族」として"]}, {"box": [1046, 973, 1078, 1111], "vertical": true, "font_size": 26, "lines_coords": [[[1046.0, 973.0], [1072.0, 973.0], [1078.0, 1108.0], [1051.0, 1108.0]]], "lines": ["表情で悟られんよう目を細めるようになったそうや"]}, {"box": [956, 978, 984, 1027], "vertical": true, "font_size": 28, "lines_coords": [[[956.0, 978.0], [984.0, 978.0], [984.0, 1027.0], [956.0, 1027.0]]], "lines": ["はっ"]}, {"box": [1051, 1170, 1074, 1323], "vertical": true, "font_size": 21, "lines_coords": [[[1051.0, 1170.0], [1072.0, 1170.0], [1074.0, 1323.0], [1053.0, 1323.0]]], "lines": ["敵はかりか味方から私恐れられる忍びの一族に成長したという話だ"]}, {"box": [973, 1165, 1000, 1310], "vertical": true, "font_size": 27, "lines_coords": [[[973.0, 1165.0], [1000.0, 1165.0], [1000.0, 1310.0], [973.0, 1310.0]]], "lines": ["もしかして先生も犬山一族の末裔だったりすんのやろか．．．"]}, {"box": [776, 1018, 813, 1110], "vertical": true, "font_size": 20, "lines_coords": [[[793.0, 1021.0], [813.0, 1021.0], [813.0, 1083.0], [793.0, 1083.0]], [[776.0, 1018.0], [795.0, 1018.0], [795.0, 1110.0], [776.0, 1110.0]]], "lines": ["鳥羽先生", "やないかっ！！"]}, {"box": [659, 938, 688, 1042], "vertical": true, "font_size": 29, "lines_coords": [[[659.0, 938.0], [688.0, 938.0], [688.0, 1042.0], [659.0, 1042.0]]], "lines": ["ｈｉｇｈａｓｈｏｏｌｄｉｒｓｐｏｙｕｒｕｃｏｍｐｉｎｏｔｉｃｅ"]}, {"box": [780, 1206, 809, 1328], "vertical": true, "font_size": 29, "lines_coords": [[[780.0, 1206.0], [809.0, 1206.0], [809.0, 1328.0], [780.0, 1328.0]]], "lines": ["あおいもまだまだやな今の話全部うそやで。"]}, {"box": [656, 1220, 690, 1372], "vertical": true, "font_size": 34, "lines_coords": [[[656.0, 1220.0], [690.0, 1220.0], [690.0, 1372.0], [656.0, 1372.0]]], "lines": ["あｆこ"]}, {"box": [259, 970, 284, 1106], "vertical": true, "font_size": 25, "lines_coords": [[[259.0, 970.0], [284.0, 970.0], [284.0, 1106.0], [259.0, 1106.0]]], "lines": ["分かっとるけどどうしてもあの目になってまうんよー"]}, {"box": [126, 997, 140, 1074], "vertical": true, "font_size": 14, "lines_coords": [[[126.0, 997.0], [140.0, 997.0], [140.0, 1074.0], [126.0, 1074.0]]], "lines": ["仕方あらへん"]}, {"box": [261, 1165, 285, 1292], "vertical": true, "font_size": 24, "lines_coords": [[[261.0, 1165.0], [285.0, 1165.0], [285.0, 1292.0], [261.0, 1292.0]]], "lines": ["「法婦の目」は３０年続く犬山一族の証やからなぁ"]}, {"box": [65, 1168, 90, 1309], "vertical": true, "font_size": 21, "lines_coords": [[[67.0, 1168.0], [88.0, 1168.0], [86.0, 1305.0], [65.0, 1305.0]]], "lines": ["ていうか３０年前のご先祖様もあんな目でホラ吹いとったん？"]}]}