]]], "lines": ["すっごく怖いしそうなったら", "悲しいけど．．．仕方ないと思う"]}, {"box": [820, 1495, 1198, 1577], "vertical": false, "font_size": 82, "lines_coords": [[[820.0, 1495.0], [1198.0, 1495.0], [1198.0, 1577.0], [820.0, 1577.0]]], "lines": ["ぷしぃりと、はんないとかったから今いっぱいぶんであげて"]}, {"box": [814, 1552, 1211, 1614], "vertical": false, "font_size": 25, "lines_coords": [[[817.0, 1556.0], [1162.0, 1556.0], [1162.0, 1580.0], [817.0, 1580.0]], [[817.0, 1586.0], [1211.0, 1586.0], [1211.0, 1612.0], [817.0, 1612.0]]], "lines": ["だから今いっぱいい遊んであげて", "楽しかったって思ってもらいたいよ"]}, {"box": [360, 1729, 559, 1762], "vertical": false, "font_size": 32, "lines_coords": [[[363.0, 1730.0], [551.0, 1730.0], [551.0, 1762.0], [363.0, 1762.0]]], "lines": ["お、そうなんだ"]}, {"box": [230, 1555, 663, 1680], "vertical": false, "font_size": 28, "lines_coords": [[[236.0, 1556.0], [315.0, 1556.0], [315.0, 1590.0], [236.0, 1590.0]], [[240.0, 1591.0], [583.0, 1591.0], [583.0, 1616.0], [240.0, 1616.0]], [[240.0, 1621.0], [483.0, 1621.0], [483.0, 1648.0], [240.0, 1648.0]], [[240.0, 1653.0], [660.0, 1653.0], [660.0, 1678.0], [240.0, 1678.0]]], "lines": ["そうだ", "こないだのキャンプ行ってから", "みんなの写真見せると", "すごいテンシヨン上がんだよちくわｗ"]}]}