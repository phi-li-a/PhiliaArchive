ines_coords": [[[165.0, 1599.0], [191.0, 1599.0], [191.0, 1710.0], [165.0, 1710.0]]], "lines": ["そうそう"]}], "img_path": "00033.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1134, 133, 1217, 438], "vertical": true, "font_size": 24, "lines_coords": [[[1192.0, 133.0], [1216.0, 133.0], [1216.0, 436.0], [1192.0, 436.0]], [[1162.0, 133.0], [1186.0, 133.0], [1186.0, 438.0], [1162.0, 438.0]], [[1134.0, 135.0], [1158.0, 135.0], [1158.0, 300.0], [1134.0, 300.0]]], "lines": ["こっからバスで行くとしたら", "昇仙峡：いやそれなら甲府駅", "から行くよな？"]}, {"box": [543, 234, 613, 422], "vertical": true, "font_size": 30, "lines_coords": [[[577.0, 234.0], [609.0, 234.0], [613.0, 393.0], [581.0, 393.0]], [[543.0, 238.0], [570.0, 238.0], [570.0, 421.0], [543.0, 421.0]]], "lines": ["あきちゃん", "あれなにー？"]}, {"box": [1155, 600, 1215, 823], "vertical": true, "font_size": 27, "lines_coords": [[[1188.0, 600.0], [1215.0, 600.0], [1215.0, 821.0], [1188.0, 821.0]], [[1158.0, 600.0], [1185.0, 600.0], [1181.0, 774.0], [1155.0, 774.0]]], "lines": ["しっかし韮崎なんて", "久々に来たなぁ"]}, {"box": [710, 425, 800, 545], "vertical": true, "font_size": 31, "lines_coords": [[[765.0, 425.0], [800.0, 425.0], [800.0, 481.0], [765.0, 481.0]], [[735.0, 425.0], [768.0, 425.0], [768.0, 525.0], [735.0, 525.0]], [[710.0, 427.0], [736.0, 427.0], [736.0, 545.0], [710.0, 545.0]]], "lines": ["まぁ", "楽しみに", "しときやー"]}, {"box": [714, 830, 776, 1053], "vertical": true, "font_size": 26, "lines_coords": [[[750.0, 830.0], [776.0, 830.0], [776.0, 1053.0], [750.0, 1053.0]], [[714.0, 830.0], [740.0, 830.0], [742.0, 1053.0], [716.0, 1053.0]]], "lines": ["あんまりこっちは", "用事ないからなぁ"]}, {"box": [168, 781, 265, 952], "vertical": true, "font_size": 26, "lines_coords": [[[238.0, 783.0], [264.0, 783.0], [264.0, 931.0], [238.0, 931.0]], [[202.0, 781.0], [228.0, 781.0], [228.0, 952.0], [202.0, 952.0]], [[168.0, 783.0], [195.0, 783.0], [195.0, 950.0], [168.0, 950.0]]], "lines": ["あぁあれは", "韮崎平和観音", "っていうー．．．"]}, {"box": [168, 1185, 243, 1372], "vertical": true, "font_size": 32, "lines_coords": [[[210.0, 1185.0], [241.0, 1185.0], [241.0, 1342.0], [210.0, 1342.0]], [[172.0, 1185.0], [204.0, 1185.0], [200.0, 1372.0], [168.0, 1372.0]]], "lines": ["えーべつに", "いいじゃーん"]}, {"box": [1079, 1183, 1178, 1706], "vertical": true, "font_size": 45, "lines_coords": [[[1132.0, 1188.0], [1177.0, 1188.0], [1177.0, 1492.0], [1132.0, 1492.0]], [[1080.0, 1183.0], [1125.0, 1183.0], [1125.0, 1706.0], [1080.0, 1706.0]]], "lines": ["って回想の中に", "入ってきてんじゃねえよ！！"]}], "img_path": "00034.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1162, 271, 1194, 429], "vertical": true, "font_size": 27, "lines_coords": [[[1162.0, 271.0], [1194.0, 271.0], [1194.0, 429.0], [1162.0, 429.0]]], "lines": ["だめだっ！！"]}, {"box": [1031, 328, 1115, 635], "vertical": true, "font_size": 27, "lines_coords": [[[1089.0, 330.0], [1115.0, 330.0], [1115.0, 635.0], [1089.0, 635.0]], [[1059.0, 328.0], [1083.0, 328.0], [1083.0, 562.0], [1059.0, 562.0]], [[1031.0, 330.0], [1057.0, 330.0], [1057.0, 588.0], [1031.0, 588.0]]], "lines": ["実際に存在しなかった人物が", "出てくると回想世界の", "バランスがくるって．．．！！"]}, {"box": [583, 817, 691, 988], "vertical": true, "font_size": 33, "lines_coords": [[[650.0, 817.0], [691.0, 817.0], [691.0, 909.0], [650.0, 909.0]], [[622.0, 823.0], [646.0, 823.0], [646.0, 988.0], [622.0, 988.0]], [[583.0, 819.0], [616.0, 819.0], [616.0, 907.0], [583.0, 907.0]]], "lines": ["ぶぅー", "あきちゃんの", "ケチー"]}, {"box": [174, 421, 305, 658], "vertical": true, "font_size": 36, "lines_coords": [[[268.0, 425.0], [300.0, 425.0], [300.0, 658.0], [268.0, 658.0]], [[215.0, 423.0], [253.0, 423.0], [253.0, 650.0], [215.0, 650.0]], [[174.0, 421.0], [211.0, 421.0], [211.0, 646.0], [174.0, 646.0]]], "lines": ["見ろ！！世界が", "崩壊し始めた", "じゃねぇか！！"]}, {"box": [1102, 881, 1168, 1108], "vertical": true, "font_size": 30, "lines_coords": [[[1141.0, 885.0], [1168.0, 885.0], [1168.0, 1078.0], [1141.0, 1078.0]], [[1104.0, 881.0], [1136.0, 881.0], [1134.0, 1108.0], [1102.0, 1108.0]]], "lines"