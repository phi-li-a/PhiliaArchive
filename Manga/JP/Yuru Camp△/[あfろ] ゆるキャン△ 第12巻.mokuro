[[[645.0, 684.0], [678.0, 682.0], [682.0, 766.0], [648.0, 768.0]]], "lines": ["クルミ"]}, {"box": [279, 650, 306, 802], "vertical": true, "font_size": 26, "lines_coords": [[[279.0, 654.0], [305.0, 654.0], [305.0, 802.0], [279.0, 802.0]]], "lines": ["ハリエンジュ"]}, {"box": [1080, 1073, 1152, 1415], "vertical": true, "font_size": 32, "lines_coords": [[[1119.0, 1074.0], [1151.0, 1074.0], [1151.0, 1415.0], [1119.0, 1415.0]], [[1080.0, 1074.0], [1111.0, 1074.0], [1111.0, 1231.0], [1080.0, 1231.0]]], "lines": ["臭うのはハリエンジュの", "方でしょう"]}, {"box": [213, 1093, 335, 1441], "vertical": true, "font_size": 30, "lines_coords": [[[303.0, 1098.0], [330.0, 1098.0], [330.0, 1378.0], [303.0, 1378.0]], [[262.0, 1096.0], [294.0, 1096.0], [294.0, 1411.0], [262.0, 1411.0]], [[213.0, 1093.0], [245.0, 1093.0], [247.0, 1441.0], [215.0, 1441.0]]], "lines": ["こちらは生木のまま", "燃やすと臭いもきつく", "煤ばかり出てしまいます"]}, {"box": [1042, 1526, 1153, 1809], "vertical": true, "font_size": 32, "lines_coords": [[[1117.0, 1526.0], [1149.0, 1526.0], [1153.0, 1719.0], [1121.0, 1719.0]], [[1080.0, 1528.0], [1113.0, 1528.0], [1111.0, 1779.0], [1078.0, 1779.0]], [[1042.0, 1528.0], [1074.0, 1528.0], [1074.0, 1809.0], [1042.0, 1809.0]]], "lines": ["校内に余った", "スチールラックが", "あると思いますので"]}, {"box": [215, 1505, 318, 1801], "vertical": true, "font_size": 28, "lines_coords": [[[283.0, 1505.0], [315.0, 1505.0], [318.0, 1687.0], [286.0, 1687.0]], [[251.0, 1509.0], [277.0, 1509.0], [277.0, 1801.0], [251.0, 1801.0]], [[215.0, 1507.0], [241.0, 1507.0], [241.0, 1685.0], [215.0, 1685.0]]], "lines": ["薪棚を作って", "そこで乾燥させてから", "使いましょう"]}], "img_path": "00023.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1143, 146, 1211, 453], "vertical": true, "font_size": 26, "lines_coords": [[[1181.0, 146.0], [1207.0, 146.0], [1207.0, 421.0], [1181.0, 421.0]], [[1143.0, 146.0], [1170.0, 146.0], [1170.0, 453.0], [1143.0, 453.0]]], "lines": ["十分乾燥していれば", "臭いも気になりません"]}, {"box": [717, 157, 786, 436], "vertical": true, "font_size": 26