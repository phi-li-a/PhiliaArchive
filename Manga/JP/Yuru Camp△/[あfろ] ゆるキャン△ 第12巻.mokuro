[1175.0, 410.0], [1149.0, 410.0]], [[1108.0, 133.0], [1134.0, 133.0], [1134.0, 470.0], [1108.0, 470.0]]], "lines": ["最近嫌な夢ばっか", "見んだけどストレス", "たまってんのかなあたし"]}, {"box": [669, 187, 738, 341], "vertical": true, "font_size": 28, "lines_coords": [[[705.0, 187.0], [736.0, 187.0], [736.0, 341.0], [705.0, 341.0]], [[669.0, 187.0], [695.0, 187.0], [695.0, 341.0], [669.0, 341.0]]], "lines": ["お疲れだね", "あきちゃん"]}, {"box": [125, 78, 391, 105], "vertical": false, "font_size": 27, "lines_coords": [[[125.0, 78.0], [391.0, 78.0], [391.0, 105.0], [125.0, 105.0]]], "lines": ["放課後９９嫌な夢"]}, {"box": [166, 161, 236, 442], "vertical": true, "font_size": 30, "lines_coords": [[[202.0, 161.0], [234.0, 161.0], [234.0, 442.0], [202.0, 442.0]], [[166.0, 163.0], [193.0, 163.0], [193.0, 410.0], [166.0, 410.0]]], "lines": ["辛い物とか食べると", "見るって言うよな"]}, {"box": [1164, 887, 1199, 1201], "vertical": true, "font_size": 32, "lines_coords": [[[1164.0, 888.0], [1196.0, 888.0], [1196.0, 1200.0], [1164.0, 1200.0]]], "lines": ["私が最近見た嫌な夢は"]}, {"box": [307, 882, 418, 1256], "vertical": true, "font_size": 30, "lines_coords": [[[386.0, 885.0], [412.0, 885.0], [412.0, 1130.0], [386.0, 1130.0]], [[346.0, 885.0], [378.0, 885.0], [378.0, 1256.0], [346.0, 1256.0]], [[307.0, 883.0], [339.0, 883.0], [339.0, 1040.0], [307.0, 1040.0]]], "lines": ["年賀状の仕分けが", "いつまでも終わらないって", "夢だったよ"]}, {"box": [140, 917, 226, 1066], "vertical": true, "font_size": 34, "lines_coords": [[[187.0, 920.0], [221.0, 920.0], [221.0, 1065.0], [187.0, 1065.0]], [[140.0, 920.0], [174.0, 920.0], [174.0, 1066.0], [140.0, 1066.0]]], "lines": ["バイトの", "影響だな"]}, {"box": [1095, 1331, 1173, 1747], "vertical": true, "font_size": 34, "lines_coords": [[[1132.0, 1331.0], [1170.0, 1331.0], [1173.0, 1747.0], [1136.0, 1747.0]], [[1095.0, 1335.0], [1126.0, 1335.0], [1126.0, 1678.0], [1095.0, 1678.0]]], "lines": ["私は何度ココアを淹れても", "ダマになるって夢かな"]}, {"box": [258, 1383, 339, 1554], "vertical": true, "font_size": 36, "lines_coords": [[[303.0, 1385.0], [335.0, 1385.0], [335.0, 1