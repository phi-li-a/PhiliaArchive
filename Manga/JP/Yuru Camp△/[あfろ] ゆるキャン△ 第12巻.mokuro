 363], "vertical": true, "font_size": 32, "lines_coords": [[[849.0, 174.0], [881.0, 174.0], [881.0, 298.0], [849.0, 298.0]], [[811.0, 174.0], [843.0, 174.0], [843.0, 363.0], [811.0, 363.0]]], "lines": ["えーと．．．", "いつだっけ？"]}, {"box": [118, 78, 596, 105], "vertical": false, "font_size": 27, "lines_coords": [[[118.0, 78.0], [596.0, 78.0], [596.0, 105.0], [118.0, 105.0]]], "lines": ["放課後１０１えなリンの出会い"]}, {"box": [187, 191, 266, 322], "vertical": true, "font_size": 38, "lines_coords": [[[223.0, 191.0], [266.0, 191.0], [266.0, 266.0], [223.0, 266.0]], [[187.0, 196.0], [219.0, 196.0], [223.0, 322.0], [191.0, 322.0]]], "lines": ["中学", "からだよ"]}, {"box": [1111, 703, 1182, 1014], "vertical": true, "font_size": 32, "lines_coords": [[[1149.0, 703.0], [1181.0, 703.0], [1181.0, 890.0], [1149.0, 890.0]], [[1111.0, 703.0], [1143.0, 703.0], [1143.0, 1014.0], [1111.0, 1014.0]]], "lines": ["確か席替えで", "たまたま前後になって"]}, {"box": [1068, 1177, 1189, 1597], "vertical": true, "font_size": 35, "lines_coords": [[[1151.0, 1181.0], [1188.0, 1181.0], [1188.0, 1590.0], [1151.0, 1590.0]], [[1106.0, 1177.0], [1143.0, 1177.0], [1147.0, 1597.0], [1110.0, 1597.0]], [[1068.0, 1183.0], [1100.0, 1183.0], [1100.0, 1423.0], [1068.0, 1423.0]]], "lines": ["二人ともメガネの父を持つ", "という共通点から意気投合", "したんだよねー"]}, {"box": [883, 1221, 943, 1406], "vertical": true, "font_size": 26, "lines_coords": [[[916.0, 1222.0], [943.0, 1222.0], [943.0, 1406.0], [916.0, 1406.0]], [[883.0, 1224.0], [907.0, 1224.0], [907.0, 1398.0], [883.0, 1398.0]]], "lines": ["うそ、志摩さんも", "メガネ父なの？"]}, {"box": [755, 1222, 781, 1386], "vertical": true, "font_size": 26, "lines_coords": [[[755.0, 1222.0], [781.0, 1222.0], [781.0, 1383.0], [755.0, 1383.0]]], "lines": ["斉藤さんも？"]}, {"box": [157, 1126, 228, 1342], "vertical": true, "font_size": 32, "lines_coords": [[[195.0, 1126.0], [228.0, 1126.0], [228.0, 1265.0], [195.0, 1265.0]], [[157.0, 1126.0], [189.0, 1126.0], [189.0, 1342.0], [157.0, 1342.0]]], "lines": ["め珍しい", "きっかけだねぇ"]}, {"box": [157, 1461, 224, 1710], "vertical": true, "font_size": 29, "lines_coords": [[[191.0, 1462.0], [223.0, 1462.0], [223.0, 1710.0], [191.0, 1710.0]], [[157.0, 1464.0], [183.0, 1464.0], [183.0, 1631.0], [157.0, 1631.0]]], "lines": ["ウソに決まってん", "じゃねぇか。"]}], "img_path": "00165.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1087, 135, 1195, 448], "vertical": true, "font_size": 30, "lines_coords": [[[1162.0, 138.0], [1194.0, 138.0], [1194.0, 446.0], [1162.0, 446.0]], [[1125.0, 135.0], [1156.0, 135.0], [1156.0, 448.0], [1125.0, 448.0]], [[1087.0, 136.0], [1113.0, 136.0], [1113.0, 320.0], [1087.0, 320.0]]], "lines": ["いつだったか小学校に", "柴犬が入り込んで来た", "事があってさ"]}, {"box": [976, 196, 1005, 414], "vertical": true, "font_size": 27, "lines_coords": [[[976.0, 198.0], [1003.0, 198.0], [1003.0, 414.0], [976.0, 414.0]]], "lines": ["あーあるよねー"]}, {"box": [815, 153, 843, 245], "vertical": true, "font_size": 28, "lines_coords": [[[815.0, 153.0], [843.0, 153.0], [843.0, 245.0], [815.0, 245.0]]], "lines": ["たべる？"]}, {"box": [202, 136, 311, 478], "vertical": true, "font_size": 30, "lines_coords": [[[277.0, 140.0], [309.0, 140.0], [309.0, 356.0], [277.0, 356.0]], [[238.0, 136.0], [270.0, 136.0], [270.0, 453.0], [238.0, 453.0]], [[202.0, 138.0], [228.0, 138.0], [228.0, 478.0], [202.0, 478.0]]], "lines": ["たまたま昼時で", "給食のパンをあげたら、", "懐かれちゃったんだけど"]}, {"box": [1086, 556, 1184, 864], "vertical": true, "font_size": 26, "lines_coords": [[[1156.0, 556.0], [1183.0, 556.0], [1183.0, 864.0], [1156.0, 864.0]], [[1121.0, 556.0], [1147.0, 556.0], [1147.0, 864.0], [1121.0, 864.0]], [[1087.0, 556.0], [1111.0, 556.0], [1111.0, 862.0], [1087.0, 862.0]]], "lines": ["実はその柴犬斉藤が毎朝", "登校する時餌付けしてる", "近所の犬だったみたいで"]}, {"box": [405, 620, 466, 754], "vertical": true, "font_size": 32, "lines_coords": [[[435.0, 620.0], [466.0, 620.0], [466.0, 753.0], [435.0, 753.0]], [[405.0, 630.0], [438.0, 630.0], [438.0, 729.0], [405.0, 729.0]]], "lines": ["ソーセージ", "だよー"]}, {"box": [188, 554, 298, 927], "vertical": true, "font_size": 30, "lines_coords": [[[262.0, 555.0], [294.0, 555.0], [294.0, 776.0], [262.0, 776.0]], [[225.0, 555.0], [256.0, 555.0], [256.0, 898.0], [225.0, 898.0]], [[189.0, 555.0], [215.0, 555.0], [215.0, 926.0], [189.0, 926.0]]], "lines": ["斉藤に食べ物を", "貰いに行こうと散歩中に", "脱走した事が分かったんだ"]}, {"box": [1102, 971, 1204, 1365], "vertical": true, "font_size": 28, "lines_coords": [[[1170.0, 971.0], [1201.0, 971.0], [1203.0, 1365.0], [1171.0, 1365.0]], [[1136.0, 973.0], [1164.0, 973.0], [1166.0, 1198.0], [1138.0, 1198.0]], [[1102.0, 973.0], [1128.0, 973.0], [1128.0, 1220.0], [1102.0, 1220.0]]], "lines": ["その頃斉藤はマンション住みで", "犬が飼いたくても", "飼えなかったらしい"]}, {"box": [975, 1171, 1010, 1268], "vertical": true, "font_size": 35, "lines_coords": [[[975.0, 1171.0], [1010.0, 1171.0], [1010.0, 1228.0], [975.0, 1228.0]]], "lines": ["あー"]}, {"box": [136, 981, 296, 1359], "vertical": true, "font_size": 31, "lines_coords": [[[262.0, 984.0], [294.0, 984.0], [294.0, 1254.0], [262.0, 1254.0]], [[219.0, 984.0], [251.0, 984.0], [251.0, 1258.0], [219.0, 1258.0]], [[174.0, 982.0], [208.0, 982.0], [210.0, 1359.0], [176.0, 1359.0]], [[136.0, 986.0], [163.0, 986.0], [163.0, 1220.0], [136.0, 1220.0]]], "lines": ["首輪に電話番号が", "書かれていたから", "先生が飼い主に連絡して", "事なきを得てさ"]}, {"box": [1108, 1410, 1171, 1721], "vertical": true, "font_size": 26, "lines_coords": [[[1141.0, 1410.0], [1168.0, 1410.0], [1168.0, 1606.0], [1141.0, 1606.0]], [[1108.0, 1411.0], [1134.0, 1411.0], [1134.0, 1721.0], [1108.0, 1721.0]]], "lines": ["それから何かと", "話すようになったんだよ"]}, {"box": [530, 1434, 587, 1704], "vertical": true, "font_size": 25, "lines_coords": [[[560.0, 1434.0], [585.0, 1434.0], [585.0, 1704.0], [560.0, 1704.0]], [[530.0, 1434.0], [555.0, 1434.0], [555.0, 1582.0], [530.0, 1582.0]]], "lines": ["ワンコがつないだ縁かぁ", "いい話だねぇ"]}, {"box": [313, 1430, 418, 1703], "vertical": true, "font_size": 28, "lines_coords": [[[386.0, 1430.0], [418.0, 1430.0], [418.0, 1702.0], [386.0, 1702.0]], [[350.0, 1432.0], [376.0, 1432.0], [376.0, 1612.0], [350.0, 1612.0]], [[313.0, 1432.0], [339.0, 1432.0], [339.0, 1700.0], [313.0, 1700.0]]], "lines": ["ディテール凝ってて", "実話ほいけど", "その話もウソだから"]}, {"box": [166, 1582, 200, 1693], "vertical": true, "font_size": 34, "lines_coords": [[[166.0, 1582.0], [200.0, 1582.0], [200.0, 1693.0], [166.0, 1693.0]]], "lines": ["えっ！？"]}], "img_path": "00166.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1128, 200, 1192, 543], "vertical": true, "font_size": 29, "lines_coords": [[[1166.0, 202.0], [1192.0, 202.0], [1192.0, 543.0], [1166.0, 543.0]], [[1128.0, 200.0], [1155.0, 200.0], [1155.0, 388.0], [1128.0, 388.0]]], "lines": ["前にこたつ型テントの話", "しとったけど"]}, {"box": [123, 65, 600, 101], "vertical": false, "font_size": 32, "lines_coords": [[[123.0, 65.0], [600.0, 69.0], [600.0, 101.0], [123.0, 97.0]]], "lines": ["放課後１０２アウトドアこたつ"]}, {"box": [200, 193, 236, 301], "vertical": true, "font_size": 36, "lines_coords": [[[200.0, 193.0], [236.0, 193.0], [236.0, 251.0], [200.0, 251.0]]], "lines": ["ほー"]}, {"box": [1003, 296, 1074, 763], "vertical": true, "font_size": 29, "lines_coords": [[[1042.0, 298.0], [1074.0, 298.0], [1074.0, 703.0], [1042.0, 703.0]], [[1003.0, 296.0], [1035.0, 296.0], [1035.0, 763.0], [1003.0, 763.0]]], "lines": ["豆炭あんか使うてキャンプで", "こたつしとる人結構おるらしいで"]}, {"box": [774, 851, 984, 1029], "vertical": false, "font_size": 160, "lines_coords": [[[789.0, 851.0], [984.0, 870.0], [969.0, 1029.0], [774.0, 1010.0]]], "lines": ["．．．"]}, {"box": [150, 532, 221, 660], "vertical": true, "font_size": 33, "lines_coords": [[[189.0, 532.0], [221.0, 532.0], [221.0, 660.0], [189.0, 660.0]], [[153.0, 534.0], [187.0, 534.0], [183.0, 660.0], [150.0, 660.0]]], "lines": ["まめたん", "って何？"]}, {"box": [1078, 851, 1187, 1194], "vertical": true, "font_size": 29, "lines_coords": [[[1155.0, 853.0], [1186.0, 853.0], [1186.0, 1132.0], [1155.0, 1132.0]], [[1115.0, 851.0], [1147.0, 851.0], [1147.0, 1194.0], [1115.0, 1194.0]], [[1081.0, 853.0], [1106.0, 853.0], [1106.0, 1130.0], [1081.0, 1130.0]]], "lines": ["石灰とか木炭の粉を", "接着剤で豆みたいに丸く", "固めた固形燃料でな"]}, {"box": [309, 858, 468, 1233], "vertical": true, "font_size": 33, "lines_coords": [[[431.0, 858.0], [468.0, 858.0], [468.0, 1080.0], [431.0, 1080.0]], [[388.0, 858.0], [420.0, 858.0], [420.0, 1233.0], [388.0, 1233.0]], [[348.0, 860.0], [380.0, 860.0], [380.0, 1231.0], [348.0, 1231.0]], [[309.0, 860.0], [341.0, 860.0], [341.0, 986.0], [309.0, 986.0]]], "lines": ["火持ちが良くて", "専用の器具に入れて使うと、", "丸一日持たせる事も出来る", "らしいわ"]}, {"box": [189, 1023, 223, 1172], "vertical": true, "font_size": 34, "lines_coords": [[[189.0, 1023.0], [223.0, 1023.0], [223.0, 1106.0], [189.0, 1106.0]]], "lines": ["へぇー"]}, {"box": [1115, 1333, 1204, 1708], "vertical": true, "font_size": 39, "lines_coords": [[[1162.0, 1335.0], [1200.0, 1335.0], [1200.0, 1597.0], [1162.0, 1597.0]], [[1115.0, 1333.0], [1155.0, 1333.0], [1156.0, 1708.0], [1117.0, 1708.0]]], "lines": ["面白そうなので", "とりあえず作ってみた"]}, {"box": [513, 1710, 831, 1772], "vertical": false, "font_size": 26, "lines_coords": [[[513.0, 1710.0], [828.0, 1710.0], [828.0, 1734.0], [513.0, 1734.0]], [[562.0, 1743.0], [774.0, 1743.0], [774.0, 1770.0], [562.0, 1770.0]]], "lines": ["ミニテーブル＋毛布＋豆炭あんかて", "かんたんこたつ"]}, {"box": [185, 1395, 292, 1678], "vertical": true, "font_size": 30, "lines_coords": [[[258.0, 1396.0], [290.0, 1396.0], [290.0, 1586.0], [258.0, 1586.0]], [[219.0, 1395.0], [251.0, 1395.0], [253.0, 1678.0], [221.0, 1678.0]], [[185.0, 1400.0], [211.0, 1400.0], [211.0, 1608.0], [185.0, 1608.0]]], "lines": ["これがあれば", "真冬のキャンプでも", "ぬくぬくだーっ"]}, {"box": [118, 1809, 748, 1839], "vertical": false, "font_size": 26, "lines_coords": [[[118.0, 1809.0], [748.0, 1813.0], [748.0, 1839.0], [118.0, 1835.0]]], "lines": ["米豆炭を使う時は火事やー敵化炭素中高に気をつけましょう。"]}], "img_path": "00167.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1065, 136, 1170, 433], "vertical": true, "font_size": 29, "lines_coords": [[[1134.0, 136.0], [1168.0, 136.0], [1170.0, 260.0], [1136.0, 260.0]], [[1102.0, 142.0], [1128.0, 142.0], [1128.0, 433.0], [1102.0, 433.0]], [[1065.0, 140.0], [1091.0, 140.0], [1091.0, 315.0], [1065.0, 315.0]]], "lines": ["そうだ！", "こたつで温まりながら", "お鍋やろうよ"]}, {"box": [275, 135, 345, 493], "vertical": true, "font_size": 31, "lines_coords": [[[309.0, 135.0], [343.0, 135.0], [345.0, 493.0], [311.0, 493.0]], [[277.0, 136.0], [305.0, 136.0], [303.0, 491.0], [275.0, 491.0]]], "lines": ["たしかうちに伊豆で買った", "ひものがまだ残ってたから"]}, {"box": [1005, 600, 1074, 851], "vertical": true, "font_size": 32, "lines_coords": [[[1042.0, 600.0], [1074.0, 600.0], [1074.0, 817.0], [1042.0, 817.0]], [[1005.0, 601.0], [1036.0, 601.0], [1036.0, 851.0], [1005.0, 851.0]]], "lines": ["それをつかって", "ひもゥのなべェ．．．"]}, {"box": [1085, 1042, 1183, 1153], "vertical": true, "font_size": 35, "lines_coords": [[[1151.0, 1046.0], [1183.0, 1046.0], [1183.0, 1153.0], [1151.0, 1153.0]], [[1113.0, 1042.0], [1155.0, 1042.0], [1155.0, 1132.0], [1113.0, 1132.0]], [[1085.0, 1046.0], [1117.0, 1046.0], [1117.0, 1153.0], [1085.0, 1153.0]]], "lines": ["おなべは", "やっぱ", "いいやー"]}, {"box": [684, 1040, 743, 1226], "vertical": true, "font_size": 24, "lines_coords": [[[716.0, 1040.0], [740.0, 1040.0], [740.0, 1224.0], [716.0, 1224.0]], [[684.0, 1042.0], [708.0, 1042.0], [708.0, 1226.0], [684.0, 1226.0]]], "lines": ["アイスとおかし", "かってきてぇー"]}, {"box": [358, 1173, 485, 1358], "vertical": true, "font_size": 26, "lines_coords": [[[457.0, 1175.0], [483.0, 1175.0], [483.0, 1357.0], [457.0, 1357.0]], [[423.0, 1173.0], [450.0, 1173.0], [450.0, 1280.0], [423.0, 1280.0]], [[391.0, 1177.0], [418.0, 1177.0], [418.0, 1333.0], [391.0, 1333.0]], [[358.0, 1177.0], [384.0, 1177.0], [384.0, 1282.0], [358.0, 1282.0]]], "lines": ["あっと言う間に", "やる気を", "吸い取られて", "やがる．．．"]}, {"box": [1023, 1430, 1132, 1678], "vertical": true, "font_size": 30, "lines_coords": [[[1100.0, 1430.0], [1132.0, 1430.0], [1132.0, 1618.0], [1100.0, 1618.0]], [[1063.0, 1430.0], [1089.0, 1430.0], [1089.0, 1676.0], [1063.0, 1676.0]], [[1023.0, 1430.0], [1055.0, 1430.0], [1055.0, 1650.0], [1023.0, 1650.0]]], "lines": ["あきちゃーん", "がわりにトイレも", "行ってきてぇー"]}, {"box": [221, 1430, 327, 1678], "vertical": true, "font_size": 26, "lines_coords": [[[298.0, 1430.0], [324.0, 1430.0], [324.0, 1676.0], [298.0, 1676.0]], [[258.0, 1432.0], [285.0, 1432.0], [285.0, 1646.0], [258.0, 1646.0]], [[221.0, 1432.0], [247.0, 1432.0], [247.0, 1646.0], [221.0, 1646.0]]], "lines": ["あたしが行っても", "おまえの尿意は", "おさまらねえよ"]}], "img_path": "00168.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [123, 67, 570, 103], "vertical": false, "font_size": 32, "lines_coords": [[[123.0, 67.0], [570.0, 71.0], [570.0, 103.0], [123.0, 99.0]]], "lines": ["放課後１０３ちくわと斉藤父"]}, {"box": [511, 262, 571, 290], "vertical": false, "font_size": 28, "lines_coords": [[[511.0, 262.0], [571.0, 262.0], [571.0, 290.0], [511.0, 290.0]]], "lines": ["ささみ"]}, {"box": [561, 834, 593, 873], "vertical": true, "font_size": 32, "lines_coords": [[[561.0, 834.0], [593.0, 834.0], [593.0, 873.0], [561.0, 873.0]]], "lines": ["！？"]}, {"box": [757, 695, 790, 733], "vertical": true, "font_size": 33, "lines_coords": [[[757.0, 695.0], [790.0, 695.0], [790.0, 733.0], [757.0, 733.0]]], "lines": ["！？"]}, {"box": [1044, 1342, 1086, 1397], "vertical": true, "font_size": 42, "lines_coords": [[[1044.0, 1342.0], [1086.0, 1342.0], [1086.0, 1397.0], [1044.0, 1397.0]]], "lines": ["！！"]}, {"box": [133, 1434, 187, 1608], "vertical": true, "font_size": 47, "lines_coords": [[[133.0, 1436.0], [180.0, 1434.0], [187.0, 1606.0], [140.0, 1608.0]]], "lines": ["はぐっ十"]}, {"box": [502, 1411, 545, 1571], "vertical": true, "font_size": 39, "lines_coords": [[[506.0, 1411.0], [545.0, 1411.0], [541.0, 1571.0], [502.0, 1571.0]]], "lines": ["「はいっ"]}], "img_path": "00169.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [928, 235, 1061, 281], "vertical": false, "font_size": 41, "lines_coords": [[[928.0, 240.0], [1053.0, 240.0], [1053.0, 281.0], [928.0, 281.0]]], "lines": ["けぷっ"]}, {"box": [571, 217, 607, 288], "vertical": true, "font_s