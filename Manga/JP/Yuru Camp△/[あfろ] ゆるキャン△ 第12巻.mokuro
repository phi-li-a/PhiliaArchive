5.0]], [[718.0, 144.0], [744.0, 144.0], [744.0, 283.0], [718.0, 283.0]]], "lines": ["朝ごはんを食べに", "行くからね"]}, {"box": [599, 133, 660, 466], "vertical": true, "font_size": 26, "lines_coords": [[[631.0, 135.0], [658.0, 135.0], [658.0, 440.0], [631.0, 440.0]], [[600.0, 133.0], [624.0, 133.0], [624.0, 466.0], [600.0, 466.0]]], "lines": ["そういえば３人で山中湖", "行った時もバスやったなぁ"]}, {"box": [142, 190, 534, 314], "vertical": false, "font_size": 97, "lines_coords": [[[161.0, 195.0], [418.0, 206.0], [414.0, 303.0], [157.0, 292.0]]], "lines": ["クベスチャ〜"]}, {"box": [1147, 360, 1212, 669], "vertical": true, "font_size": 27, "lines_coords": [[[1185.0, 361.0], [1211.0, 361.0], [1211.0, 669.0], [1185.0, 669.0]], [[1149.0, 360.0], [1177.0, 360.0], [1175.0, 669.0], [1147.0, 669.0]]], "lines": ["ここからしばらく行った", "明野って所で買い出しと"]}, {"box": [1050, 729, 1114, 924], "vertical": true, "font_size": 29, "lines_coords": [[[1081.0, 729.0], [1113.0, 729.0], [1113.0, 870.0], [1081.0, 870.0]], [[1050.0, 729.0], [1076.0, 729.0], [1078.0, 924.0], [1051.0, 924.0]]], "lines": ["何かこの辺", "ガケ多くない？"]}, {"box": [746, 530, 789, 598], "vertical": true, "font_size": 43, "lines_coords": [[[746.0, 530.0], [789.0, 530.0], [789.0, 598.0], [746.0, 598.0]]], "lines": ["ふむ"]}, {"box": [129, 466, 206, 655], "vertical": true, "font_size": 38, "lines_coords": [[[172.0, 470.0], [206.0, 470.0], [202.0, 652.0], [168.0, 652.0]], [[129.0, 466.0], [172.0, 466.0], [172.0, 540.0], [129.0, 540.0]]], "lines": ["バスキャン", "だね"]}, {"box": [300, 753, 365, 948], "vertical": true, "font_size": 27, "lines_coords": [[[339.0, 753.0], [365.0, 753.0], [361.0, 948.0], [335.0, 948.0]], [[303.0, 753.0], [330.0, 753.0], [326.0, 948.0], [300.0, 948.0]]], "lines": ["八ヶ岳の噴火で", "できたらしいわ"]}, {"box": [206, 834, 270, 1031], "vertical": true, "font_size": 27, "lines_coords": [[[234.0, 834.0], [266.0, 834.0], [270.0, 1008.0], [238.0, 1008.0]], [[206.0, 838.0], [230.0, 838.0], [230.0, 1031.0], [206.0, 1031.0]]], "lines": ["韮崎の七里岩", "とかが有名やで"]}, {"box": [1170, 1222, 1200, 1