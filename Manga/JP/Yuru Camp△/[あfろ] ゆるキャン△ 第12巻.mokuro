92.0], [369.0, 1411.0], [343.0, 1411.0]], [[313.0, 1188.0], [337.0, 1188.0], [337.0, 1340.0], [313.0, 1340.0]], [[285.0, 1190.0], [305.0, 1190.0], [305.0, 1312.0], [285.0, 1312.0]]], "lines": ["いっぱい貰ってきて", "薪割り中だよ", "見に来る？"]}, {"box": [737, 1563, 834, 1760], "vertical": true, "font_size": 26, "lines_coords": [[[808.0, 1565.0], [834.0, 1565.0], [834.0, 1745.0], [808.0, 1745.0]], [[772.0, 1565.0], [798.0, 1565.0], [798.0, 1704.0], [772.0, 1704.0]], [[738.0, 1563.0], [763.0, 1563.0], [763.0, 1760.0], [738.0, 1760.0]]], "lines": ["あリンちゃん", "薪を乾かす", "棚を作るんだよ"]}, {"box": [172, 1618, 236, 1771], "vertical": true, "font_size": 32, "lines_coords": [[[200.0, 1618.0], [236.0, 1618.0], [236.0, 1680.0], [200.0, 1680.0]], [[176.0, 1621.0], [204.0, 1621.0], [200.0, 1771.0], [172.0, 1771.0]]], "lines": ["じゃ", "ちょっとだけ"]}], "img_path": "00057.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [339, 73, 1241, 110], "vertical": false, "font_size": 37, "lines_coords": [[[339.0, 73.0], [1241.0, 73.0], [1241.0, 110.0], [339.0, 110.0]]], "lines": ["第１５話・薪割り道具とみずがき湖の謎グルメ"]}], "img_path": "00058.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1087, 196, 1171, 500], "vertical": true, "font_size": 38, "lines_coords": [[[1132.0, 196.0], [1171.0, 196.0], [1171.0, 408.0], [1132.0, 408.0]], [[1087.0, 198.0], [1125.0, 198.0], [1125.0, 500.0], [1087.0, 500.0]]], "lines": ["うわすげー", "貰って来たんだな"]}, {"box": [808, 187, 839, 301], "vertical": true, "font_size": 31, "lines_coords": [[[808.0, 187.0], [839.0, 187.0], [839.0, 301.0], [808.0, 301.0]]], "lines": ["はー"]}, {"box": [142, 195, 226, 384], "vertical": true, "font_size": 38, "lines_coords": [[[185.0, 195.0], [226.0, 195.0], [226.0, 315.0], [185.0, 315.0]], [[142.0, 198.0], [178.0, 198.0], [178.0, 384.0], [142.0, 384.0]]], "lines": ["ざっと", "車２台分だ"]}, {"box": [1119, 723, 1185, 960], "vertical": true, "font_size": 26, "lines_coords": [[[1156.0, 725.0], [1183.0, 725.0], [1183.0, 930.0], [1156.0, 930.0]], [[1119.0, 725.0], [1145.0, 725.0], [1145.0, 960.0], [1119.0, 960.0]]], "lines": ["それで昨日から", "割り始めたんだよ"]}, {"box": [984, 765, 1049, 999], "vertical": true, "font_size": 27, "lines_coords": [[[1020.0, 765.0], [1048.0, 765.0], [1046.0, 999.0], [1018.0, 999.0]], [[984.0, 766.0], [1010.0, 766.0], [1010.0, 969.0], [984.0, 969.0]]], "lines": ["しばらく野クルは", "薪割り活動やぁ"]}, {"box": [328, 708, 397, 864], "vertical": true, "font_size": 29, "lines_coords": [[[369.0, 712.0], [395.0, 712.0], [395.0, 864.0], [369.0, 864.0]], [[328.0, 708.0], [360.0, 708.0], [360.0, 862.0], [328.0, 862.0]]], "lines": ["もうすでに", "肩がいてぇ"]}, {"box": [181, 883, 221, 982], "vertical": true, "font_size": 40, "lines_coords": [[[181.0, 883.0], [221.0, 883.0], [221.0, 982.0], [181.0, 982.0]]], "lines": ["ふーん"]}, {"box": [1145, 1151, 1210, 1486], "vertical": true, "font_size": 26, "lines_coords": [[[1181.0, 1151.0], [1207.0, 1151.0], [1207.0, 1430.0], [1181.0, 1430.0]], [[1145.0, 1151.0], [1171.0, 1151.0], [1171.0, 1486.0], [1145.0, 1486.0]]], "lines": ["結構太い薪があるけど、", "大きい斧ないと大変だろ？"]}, {"box": [622, 1152, 652, 1435], "vertical": true, "font_size": 26, "lines_coords": [[[622.0, 1155.0], [648.0, 1155.0], [648.0, 1432.0], [622.0, 1432.0]]], "lines": ["これじゃダメなの？"]}, {"box": [144, 1149, 248, 1562], "vertical": true, "font_size": 30, "lines_coords": [[[215.0, 1149.0], [247.0, 1149.0], [247.0, 1417.0], [215.0, 1417.0]], [[178.0, 1149.0], [210.0, 1149.0], [210.0, 1505.0], [178.0, 1505.0]], [[144.0, 1151.0], [170.0, 1151.0], [170.0, 1561.0], [144.0, 1561.0]]], "lines": ["割れなくはないけど", "重さのある大きい斧の方が", "割りやすいし安全だって言うよ"]}, {"box": [723, 1509, 791, 1711], "vertical": true, "font_size": 30, "lines_coords": [[[759.0, 1509.0], [791.0, 1509.0], [791.0, 1711.0], [759.0, 1711.0]], [[723.0, 1513.0], [750.0, 1513.0], [750.0, 1693.0], [723.0, 1693.0]]], "lines": ["うーんやっぱ", "そうだよなァ"]}], "img_path": "00059.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1096, 151, 1198, 463], "ve