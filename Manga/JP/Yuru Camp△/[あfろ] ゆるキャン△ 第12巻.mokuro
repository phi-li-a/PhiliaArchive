]]], "lines": ["私もまだ", "大丈夫だけど"]}, {"box": [281, 1329, 354, 1494], "vertical": true, "font_size": 32, "lines_coords": [[[322.0, 1329.0], [354.0, 1329.0], [350.0, 1494.0], [318.0, 1494.0]], [[281.0, 1329.0], [313.0, 1329.0], [313.0, 1485.0], [281.0, 1485.0]]], "lines": ["えっこんな", "山の中に？"]}, {"box": [1081, 1351, 1190, 1633], "vertical": true, "font_size": 30, "lines_coords": [[[1156.0, 1351.0], [1186.0, 1351.0], [1190.0, 1629.0], [1160.0, 1629.0]], [[1119.0, 1353.0], [1151.0, 1353.0], [1151.0, 1633.0], [1119.0, 1633.0]], [[1083.0, 1355.0], [1110.0, 1355.0], [1110.0, 1569.0], [1083.0, 1569.0]]], "lines": ["この先にちょーっと", "ウマいもん売っとる", "お店があんねん"]}, {"box": [165, 1571, 206, 1685], "vertical": true, "font_size": 41, "lines_coords": [[[165.0, 1571.0], [206.0, 1571.0], [206.0, 1685.0], [165.0, 1685.0]]], "lines": ["せやで"]}], "img_path": "00048.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1134, 153, 1188, 365], "vertical": true, "font_size": 26, "lines_coords": [[[1164.0, 153.0], [1188.0, 153.0], [1188.0, 365.0], [1164.0, 365.0]], [[1134.0, 153.0], [1160.0, 153.0], [1160.0, 296.0], [1134.0, 296.0]]], "lines": ["湖をグルっと回った", "先にあるから"]}, {"box": [1048, 286, 1108, 487], "vertical": true, "font_size": 26, "lines_coords": [[[1081.0, 286.0], [1108.0, 286.0], [1108.0, 481.0], [1081.0, 481.0]], [[1048.0, 288.0], [1074.0, 288.0], [1074.0, 487.0], [1048.0, 487.0]]], "lines": ["湖散歩も兼ねて", "食べに行かん？"]}, {"box": [476, 198, 536, 352], "vertical": true, "font_size": 29, "lines_coords": [[[502.0, 198.0], [536.0, 198.0], [536.0, 279.0], [502.0, 279.0]], [[476.0, 200.0], [500.0, 200.0], [500.0, 352.0], [476.0, 352.0]]], "lines": ["んじゃ", "行ってみっか"]}, {"box": [225, 200, 286, 369], "vertical": true, "font_size": 28, "lines_coords": [[[255.0, 200.0], [286.0, 200.0], [286.0, 313.0], [255.0, 313.0]], [[225.0, 200.0], [249.0, 200.0], [249.0, 369.0], [225.0, 369.0]]], "lines": ["えー何が", "あるんだろ？"]}, {"box": [442, 455, 476, 521], "vertical": true, "font_size": 34, "lines_