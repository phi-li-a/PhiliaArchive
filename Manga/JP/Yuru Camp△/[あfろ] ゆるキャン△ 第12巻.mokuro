77.0, 1256.0], [243.0, 1256.0]], [[195.0, 1110.0], [232.0, 1110.0], [232.0, 1335.0], [195.0, 1335.0]]], "lines": ["おそまつ", "さまでしたー"]}, {"box": [774, 1520, 843, 1775], "vertical": true, "font_size": 34, "lines_coords": [[[800.0, 1520.0], [843.0, 1520.0], [843.0, 1590.0], [800.0, 1590.0]], [[774.0, 1528.0], [800.0, 1528.0], [800.0, 1775.0], [774.0, 1775.0]]], "lines": ["ほー", "細かいこだわりやな"]}], "img_path": "00149.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1102, 148, 1212, 584], "vertical": true, "font_size": 30, "lines_coords": [[[1177.0, 148.0], [1209.0, 148.0], [1209.0, 581.0], [1177.0, 581.0]], [[1143.0, 150.0], [1170.0, 150.0], [1170.0, 583.0], [1143.0, 583.0]], [[1102.0, 148.0], [1134.0, 148.0], [1134.0, 307.0], [1102.0, 307.0]]], "lines": ["けどあれだけトマト使ったのに", "まだ二袋分まるまる残ってるん", "だよねぇ．．．"]}, {"box": [560, 148, 663, 445], "vertical": true, "font_size": 28, "lines_coords": [[[631.0, 148.0], [663.0, 148.0], [663.0, 386.0], [631.0, 386.0]], [[598.0, 151.0], [624.0, 151.0], [624.0, 412.0], [598.0, 412.0]], [[560.0, 150.0], [586.0, 150.0], [586.0, 444.0], [560.0, 444.0]]], "lines": ["もーあきちゃんが", "みんなでやった方が", "楽しいって言うから！"]}, {"box": [382, 314, 412, 412], "vertical": true, "font_size": 30, "lines_coords": [[[382.0, 315.0], [412.0, 315.0], [412.0, 356.0], [382.0, 356.0]]], "lines": ["もー"]}, {"box": [180, 183, 270, 339], "vertical": true, "font_size": 45, "lines_coords": [[[226.0, 185.0], [266.0, 185.0], [270.0, 339.0], [230.0, 339.0]], [[180.0, 183.0], [230.0, 183.0], [230.0, 270.0], [180.0, 270.0]]], "lines": ["おめえら", "だよ"]}, {"box": [1072, 802, 1206, 1059], "vertical": true, "font_size": 27, "lines_coords": [[[1179.0, 806.0], [1205.0, 806.0], [1205.0, 973.0], [1179.0, 973.0]], [[1141.0, 802.0], [1173.0, 802.0], [1171.0, 1059.0], [1140.0, 1059.0]], [[1108.0, 804.0], [1134.0, 804.0], [1134.0, 1027.0], [1108.0, 1027.0]], [[1074.0, 802.0], [1100.0, 802.0], [1098.0, 973.0], [1072.0, 973.0]]], "lines": ["そういえば．．．", "さっきからちくわを", "見かけないんだが", "どこ行った？"]}, {"box": [736, 395, 798, 701], "vertical": true, "font_size": 26, "lines_coords": [[[770.0, 397.0], [796.0, 397.0], [796.0, 590.0], [770.0, 590.0]], [[736.0, 397.0], [761.0, 397.0], [761.0, 701.0], [736.0, 701.0]]], "lines": ["詰め放題３人で", "やらんでもよかったなぁ"]}, {"box": [356, 791, 425, 1006], "vertical": true, "font_size": 26, "lines_coords": [[[395.0, 793.0], [421.0, 793.0], [421.0, 1006.0], [395.0, 1006.0]], [[358.0, 791.0], [384.0, 791.0], [382.0, 945.0], [356.0, 945.0]]], "lines": ["あれっホントだ", "ちくわー？"]}, {"box": [1068, 1243, 1160, 1567], "vertical": true, "font_size": 42, "lines_coords": [[[1115.0, 1243.0], [1160.0, 1243.0], [1156.0, 1567.0], [1111.0, 1567.0]], [[1068.0, 1245.0], [1106.0, 1245.0], [1106.0, 1528.0], [1068.0, 1528.0]]], "lines": ["ってワイプの中に", "おるやないか！！"]}], "img_path": "00150.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1147, 135, 1215, 461], "vertical": true, "font_size": 32, "lines_coords": [[[1177.0, 135.0], [1215.0, 135.0], [1215.0, 361.0], [1177.0, 361.0]], [[1147.0, 140.0], [1173.0, 140.0], [1173.0, 461.0], [1147.0, 461.0]]], "lines": ["うわワイプの中", "めっちゃ暖けーじゃん！！"]}, {"box": [545, 116, 656, 371], "vertical": true, "font_size": 33, "lines_coords": [[[624.0, 120.0], [656.0, 120.0], [656.0, 371.0], [624.0, 371.0]], [[586.0, 118.0], [620.0, 118.0], [615.0, 330.0], [581.0, 330.0]], [[549.0, 116.0], [581.0, 116.0], [577.0, 300.0], [545.0, 300.0]]], "lines": ["ちょっ！！一人だけ", "ズルいであき！！", "私も入るし！！"]}, {"box": [328, 110, 365, 320], "vertical": true, "font_size": 32, "lines_coords": [[[328.0, 110.0], [360.0, 110.0], [365.0, 320.0], [333.0, 320.0]]], "lines": ["だったら私も～"]}, {"box": [118, 223, 200, 382], "vertical": true, "font_size": 38, "lines_coords": [[[153.0, 225.0], [193.0, 223.0], [200.0, 345.0], [161.0, 346.0]], [[118.0, 226.0], [155.0, 223.0], [168.0, 378.0], [131.0, 382.0]]], "lines": ["あらひも", "はいるぅ～"]}, {"box": [1115, 738, 1209, 997], "vertical": true, "font_size": 94, "lines_coords": [[[1115.0, 738.0], [1209.0, 738.0], [1209.0, 997.0], [1115.0, 997.0]]], "lines": ["そして："]}, {"box": [735, 360, 827, 676], "vertical": true, "font_size": 26, "lines_coords": [[[800.0, 361.0], [826.0, 361.0], [826.0, 650.0], [800.0, 650.0]], [[766.0, 361.0], [793.0, 361.0], [793.0, 676.0], [766.0, 676.0]], [[735.0, 361.0], [761.0, 361.0], [761.0, 495.0], [735.0, 495.0]]], "lines": ["回想なのにあたしらだけ", "実空の下でバカみたいじゃ", "ねえかっ！！"]}, {"box": [217, 465, 296, 611], "vertical": true, "font_size": 39, "lines_coords": [[[253.0, 466.0], [286.0, 465.0], [296.0, 609.0], [262.0, 611.0]], [[217.0, 466.0], [262.0, 466.0], [262.0, 534.0], [217.0, 534.0]]], "lines": ["おい押すな", "って"]}, {"box": [1145, 1310, 1174, 1426], "vertical": true, "font_size": 26, "lines_coords": [[[1145.0, 1310.0], [1171.0, 1310.0], [1171.0, 1426.0], [1145.0, 1426.0]]], "lines": ["やれやれ"]}, {"box": [142, 735, 271, 1203], "vertical": true, "font_size": 66, "lines_coords": [[[206.0, 735.0], [271.0, 735.0], [268.0, 1053.0], [202.0, 1053.0]], [[146.0, 736.0], [211.0, 736.0], [208.0, 1203.0], [142.0, 1203.0]]], "lines": ["はんぺん以外", "誰も居なくなった："]}, {"box": [731, 1468, 795, 1775], "vertical": true, "font_size": 29, "lines_coords": [[[763.0, 1468.0], [795.0, 1468.0], [795.0, 1719.0], [763.0, 1719.0]], [[731.0, 1468.0], [757.0, 1468.0], [757.0, 1775.0], [731.0, 1775.0]]], "lines": ["キャンプの夜くらい", "静かに過ごせないものか"]}, {"box": [133, 1530, 204, 1747], "vertical": true, "font_size": 32, "lines_coords": [[[172.0, 1530.0], [204.0, 1530.0], [204.0, 1732.0], [172.0, 1732.0]], [[133.0, 1530.0], [165.0, 1530.0], [165.0, 1747.0], [133.0, 1747.0]]], "lines": ["うむたき火が", "何とも心地よい"]}], "img_path": "00151.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1132, 238, 1196, 506], "vertical": true, "font_size": 25, "lines_coords": [[[1168.0, 243.0], [1194.0, 243.0], [1194.0, 504.0], [1168.0, 504.0]], [[1132.0, 238.0], [1156.0, 238.0], [1156.0, 463.0], [1132.0, 463.0]]], "lines": ["しかしここは本当に", "良いキャンフ場だ"]}, {"box": [330, 139, 396, 480], "vertical": true, "font_size": 26, "lines_coords": [[[365.0, 142.0], [391.0, 142.0], [391.0, 478.0], [365.0, 478.0]], [[330.0, 142.0], [356.0, 142.0], [356.0, 281.0], [330.0, 281.0]]], "lines": ["交通の便は決して良いとは", "言えないが"]}, {"box": [135, 206, 234, 541], "vertical": true, "font_size": 26, "lines_coords": [[[206.0, 208.0], [232.0, 208.0], [232.0, 541.0], [206.0, 541.0]], [[170.0, 206.0], [196.0, 206.0], [196.0, 485.0], [170.0, 485.0]], [[135.0, 206.0], [161.0, 206.0], [161.0, 538.0], [135.0, 538.0]]], "lines": ["こういった場所だからこそ、", "落ちついたキャンプが", "出来るのではないだろうか"]}, {"box": [1140, 627, 1203, 974], "vertical": true, "font_size": 26, "lines_coords": [[[1175.0, 630.0], [1201.0, 630.0], [1201.0, 973.0], [1175.0, 973.0]], [[1141.0, 630.0], [1166.0, 630.0], [1166.0, 907.0], [1141.0, 907.0]]], "lines": ["さてこれで瑞穂キャンプの", "回想は終わりとなるが"]}, {"box": [918, 624, 1015, 1014], "vertical": true, "font_size": 26, "lines_coords": [[[988.0, 628.0], [1012.0, 628.0], [1012.0, 1014.0], [988.0, 1014.0]], [[952.0, 624.0], [978.0, 624.0], [978.0, 877.0], [952.0, 877.0]], [[918.0, 626.0], [945.0, 626.0], [945.0, 988.0], [918.0, 988.0]]], "lines": ["誰もいなくなってしまったため", "私から最後の言葉を", "送らせてもらうこととしよう"]}, {"box": [785, 661, 827, 885], "vertical": true, "font_size": 38, "lines_coords": [[[789.0, 661.0], [826.0, 661.0], [823.0, 885.0], [785.0, 885.0]]], "lines": ["グッドボタン"]}, {"box": [616, 1254, 827, 1290], "vertical": false, "font_size": 32, "lines_coords": [[[616.0, 1258.0], [823.0, 1258.0], [823.0, 1290.0], [616.0, 1290.0]]], "lines": ["チャンネル登録"]}, {"box": [163, 958, 255, 1243], "vertical": true, "font_size": 42, "lines_coords": [[[210.0, 958.0], [255.0, 958.0], [255.0, 1243.0], [210.0, 1243.0]], [[163.0, 961.0], [202.0, 961.0], [202.0, 1216.0], [163.0, 1216.0]]], "lines": ["チャンネル登録", "お願いします。"]}, {"box": [975, 1410, 1042, 1591], "vertical": true, "font_size": 28, "lines_coords": [[[1016.0, 1411.0], [1042.0, 1411.0], [1042.0, 1591.0], [1016.0, 1591.0]], [[978.0, 1410.0], [1006.0, 1410.0], [1003.0, 1552.0], [975.0, 1552.0]]], "lines": ["という感じで", "あたしらは"]}, {"box": [872, 1445, 936, 1725], "vertical": true, "font_size": 64, "lines_coords": [[[872.0, 1445.0], [936.0, 1445.0], [936.0, 1725.0], [872.0, 1725.0]]], "lines": ["瑞牆で春の冬キャンを楽しんで来た訳だー"]}, {"box": [871, 1447, 935, 1730], "vertical": true, "font_size": 28, "lines_coords": [[[903.0, 1447.0], [935.0, 1447.0], [935.0, 1730.0], [903.0, 1730.0]], [[871.0, 1449.0], [898.0, 1449.0], [898.0, 1700.0], [871.0, 1700.0]]], "lines": ["瑞牆で春の冬キャンを", "楽しんで来た訳だ！"]}, {"box": [793, 1453, 834, 1555], "vertical": true, "font_size": 41, "lines_coords": [[[793.0, 1453.0], [834.0, 1453.0], [834.0, 1555.0], [793.0, 1555.0]]], "lines": ["いやー安かだよー"]}, {"box": [476, 1376, 533, 1715], "vertical": true, "font_size": 25, "lines_coords": [[[508.0, 1378.0], [532.0, 1378.0], [532.0, 1651.0], [508.0, 1651.0]], [[476.0, 1376.0], [502.0, 1376.0], [504.0, 1715.0], [478.0, 1715.0]]], "lines": ["私達が大井川に行ってる時", "こんなキャンプをしてたんだねぇ"]}, {"box": [221, 1452, 283, 1674], "vertical": true, "font_size": 26, "lines_coords": [[[255.0, 1453.0], [281.0, 1453.0], [281.0, 1674.0], [255.0, 1674.0]], [[221.0, 1453.0], [247.0, 1453.0], [247.0, 1648.0], [221.0, 1648.0]]], "lines": ["デタラメ大盛りの", "話やったけどな"]}], "img_path": "00152.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1050, 200, 1152, 509], "vertical": true, "font_size": 26, "lines_coords": [[[1123.0, 200.0], [1149.0, 200.0], [1149.0, 508.0], [1123.0, 508.0]], [[1085.0, 200.0], [1111.0, 200.0], [1111.0, 406.0], [1085.0, 406.0]], [[1050.0, 200.0], [1076.0, 200.0], [1076.0, 433.0], [1050.0, 433.0]]], "lines": ["さてと話も終わったし、", "今日の薪割りは", "ここまでにすっか"]}, {"box": [268, 204, 309, 318], "vertical": true, "font_size": 41, "lines_coords": [[[268.0, 204.0], [309.0, 204.0], [309.0, 318.0], [268.0, 318.0]]], "lines": ["せやな"]}, {"box": [1128, 684, 1194, 922], "vertical": true, "font_size": 30, "lines_coords": [[[1162.0, 686.0], [1194.0, 686.0], [1194.0, 851.0], [1162.0, 851.0]], [[1128.0, 684.0], [1155.0, 684.0], [1155.0, 920.0], [1128.0, 920.0]]], "lines": ["薪まだまだ", "どっさりあるなぁ"]}, {"box": [714, 710, 789, 841], "vertical": true, "font_size": 37, "lines_coords": [[[757.0, 718.0], [789.0, 718.0], [789.0, 841.0], [757.0, 841.0]], [[714.0, 712.0], [755.0, 710.0], [759.0, 783.0], [718.0, 785.0]]], "lines": ["ホントに", "なあ"]}, {"box": [423, 680, 515, 896], "vertical": true, "font_size": 28, "lines_coords": [[[487.0, 682.0], [513.0, 682.0], [513.0, 815.0], [487.0, 815.0]], [[455.0, 680.0], [487.0, 680.0], [483.0, 791.0], [451.0, 791.0]], [[423.0, 682.0], [448.0, 682.0], [448.0, 896.0], [423.0, 896.0]]], "lines": ["割りながら", "ちょっと", "思ったんだけどさ"]}, {"box": [1072, 1312, 1143, 1685], "vertical": true, "font_size": 29, "lines_coords": [[[1110.0, 1312.0], [1141.0, 1312.0], [1140.0, 1595.0], [1108.0, 1595.0]], [[1072.0, 1312.0], [1098.0, 1312.0], [1098.0, 1681.0], [1072.0, 1681.0]]], "lines": ["毎年こうやって薪を", "もらって割って乾燥させて"]}, {"box": [202, 1392, 275, 1798], "vertical": true, "font_size": 30, "lines_coords": [[[241.0, 1393.0], [268.0, 1393.0], [268.0, 1638.0], [241.0, 1638.0]], [[202.0, 1393.0], [234.0, 1393.0], [234.0, 1798.0], [202.0, 1798.0]]], "lines": ["それを後輩たちが", "キャンプで焚き火に使って．．．"]}], "img_path": "00153.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [753, 172, 853, 485], "vertical": true, "font_size": 30, "lines_coords": [[[821.0, 176.0], [853.0, 176.0], [853.0, 318.0], [821.0, 318.0]], [[785.0, 172.0], [817.0, 172.0], [815.0, 485.0], [783.0, 485.0]], [[753.0, 178.0], [780.0, 178.0], [780.0, 481.0], [753.0, 481.0]]], "lines": ["そうやって", "代々受け継いで行けたら", "何か「部活」らしいなって"]}, {"box": [187, 406, 253, 532], "vertical": true, "font_size": 30, "lines_coords": [[[217.0, 406.0], [251.0, 406.0], [253.0, 532.0], [219.0, 532.0]], [[187.0, 406.0], [213.0, 406.0], [213.0, 472.0], [187.0, 472.0]]], "lines": ["せやなぁ", "．．．．．．"]}, {"box": [766, 741, 907, 1097], "vertical": true, "font_size": 29, "lines_coords": [[[879.0, 742.0], [905.0, 742.0], [905.0, 860.0], [879.0, 860.0]], [[838.0, 742.0], [870.0, 742.0], [870.0, 1096.0], [838.0, 1096.0]], [[802.0, 742.0], [834.0, 742.0], [830.0, 1096.0], [798.0, 1096.0]], [[766.0, 744.0], [793.0, 744.0], [793.0, 890.0], [766.0, 890.0]]], "lines": ["なるほど", "新入生に「部のしきたりだ」", "って薪を全部割らせるのも", "アリだな．．．"]}, {"box": [411, 720, 582, 772], "vertical": false, "font_size": 26, "lines_coords": [[[418.0, 720.0], [568.0, 720.0], [568.0, 746.0], [418.0, 746.0]], [[416.0, 746.0], [575.0, 742.0], [575.0, 768.0], [416.0, 772.0]]], "lines": ["お前ら！薪割り", "１０００本だっ！！"]}, {"box": [184, 747, 247, 1031], "vertical": true, "font_size": 24, "lines_coords": [[[217.0, 751.0], [243.0, 751.0], [243.0, 1031.0], [217.0, 1031.0]], [[185.0, 751.0], [206.0, 751.0], [206.0, 888.0], [185.0, 888.0]]], "lines": ["パワハラはだめだよぅ", "あきちゃん"]}, {"box": [1068, 1198, 1189, 1440], "vertical": true, "font_size": 33, "lines_coords": [[[1155.0, 1198.0], [1186.0, 1198.0], [1186.0, 1432.0], [1155.0, 1432.0]], [[1113.0, 1200.0], [1147.0, 1200.0], [1143.0, 1440.0], [1110.0, 1440.0]], [[1068.0, 1198.0], [1102.0, 1198.0], [1104.0, 1438.0], [1070.0, 1438.0]]], "lines": ["その前に後輩が", "入って来るかも", "分からんしなぁ"]}, {"box": [703, 1188, 802, 1481], "vertical": true, "font_size": 26, "lines_coords": [[[770.0, 1190.0], [796.0, 1190.0], [800.0, 1481.0], [774.0, 1481.0]], [[738.0, 1188.0], [765.0, 1188.0], [765.0, 1428.0], [738.0, 1428.0]], [[703.0, 1188.0], [729.0, 1188.0], [729.0, 1468.0], [703.0, 1468.0]]], "lines": ["いや、必ずとっ捕まえて", "見せるぞ、今年こそ", "部に昇格するために＂＂"]}, {"box": [570, 1243, 615, 1284], "vertical": false, "font_size": 41, "lines_coords": [[[570.0, 1243.0], [615.0, 1243.0], [615.0, 1284.0], [570.0, 1284.0]]], "lines": ["お"]}, {"box": [727, 1633, 804, 1732], "vertical": true, "font_size": 46, "lines_coords": [[[755.0, 1633.0], [804.0, 1633.0], [804.0, 1732.0], [755.0, 1732.0]], [[727.0, 1635.0], [770.0, 1635.0], [770.0, 1728.0], [727.0, 1728.0]]], "lines": ["ブーン", "ブーン"]}], "img_path": "00154.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1048, 178, 1157, 583], "vertical": true, "font_size": 30, "lines_coords": [[[1123.0, 178.0], [1155.0, 178.0], [1156.0, 399.0], [1125.0, 399.0]], [[1085.0, 181.0], [1117.0, 181.0], [1117.0, 583.0], [1085.0, 583.0]], [[1048.0, 178.0], [1076.0, 178.0], [1078.0, 459.0], [1050.0, 459.0]]], "lines": ["リンちゃんから", "お花見が出来るキャンプ場の", "情報が届いたよっ！！"]}, {"box": [215, 397, 298, 530], "vertical": true, "font_size": 75, "lines_coords": [[[215.0, 401.0], [290.0, 397.0], [298.0, 526.0], [223.0, 530.0]]], "lines": ["おっ"]}, {"box": [1156, 682, 1213, 965], "vertical": true, "font_size": 26, "lines_coords": [[[1188.0, 684.0], [1213.0, 684.0], [1213.0, 894.0], [1188.0, 894.0]], [[1158.0, 682.0], [1185.0, 682.0], [1183.0, 965.0], [1156.0, 965.0]]], "lines": ["ほほーこんな所にも", "キャンプ場があったとは．．．"]}, {"box": [448, 541, 871, 602], "vertical": false, "font_size": 24, "lines_coords": [[[457.0, 545.0], [870.0, 545.0], [870.0, 570.0], [457.0, 570.0]], [[453.0, 577.0], [804.0, 577.0], [804.0, 601.0], [453.0, 601.0]]], "lines": ["ここのキャンプ場花見てきるっぽいよ", "ＷｉｎｄｏｙｇｉｎｅｎｄｒｉＰｕｃａｍｐ．ｃｏｍ"]}, {"box": [678, 691, 739, 956], "vertical": true, "font_size": 26, "lines_coords": [[[712.0, 691.0], [736.0, 691.0], [736.0, 901.0], [712.0, 901.0]], [[678.0, 691.0], [705.0, 691.0], [705.0, 956.0], [678.0, 956.0]]], "lines": ["なでしこちゃんの", "家から近いんやない？"]}, {"box": [549, 693, 611, 941], "vertical": true, "font_size": 24, "lines_coords": [[[583.0, 693.0], [607.0, 693.0], [607.0, 941.0], [583.0, 941.0]], [[549.0, 693.0], [573.0, 693.0], [573.0, 930.0], [549.0, 930.0]]], "lines": ["よし花見キャンプは", "ここに決定だなっ！！"]}, {"box": [318, 703, 375, 975], "vertical": true, "font_size": 26, "lines_coords": [[[348.0, 703.0], [375.0, 703.0], [375.0, 901.0], [348.0, 901.0]], [[318.0, 703.0], [343.0, 703.0], [343.0, 975.0], [318.0, 975.0]]], "lines": ["伊豆キャンぶりに", "みんなでキャンプだねぃ"]}, {"box": [740, 1061, 787, 1104], "vertical": false, "font_size": 43, "lines_coords": [[[740.0, 1061.0], [787.0, 1061.0], [787.0, 1104.0], [740.0, 1104.0]]], "lines": ["ね"]}, {"box"