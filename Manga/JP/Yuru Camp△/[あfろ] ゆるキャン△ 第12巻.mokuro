cks": [{"box": [811, 166, 838, 309], "vertical": true, "font_size": 27, "lines_coords": [[[811.0, 166.0], [838.0, 166.0], [838.0, 309.0], [811.0, 309.0]]], "lines": ["ヨシャーの湯"]}, {"box": [438, 202, 487, 260], "vertical": true, "font_size": 30, "lines_coords": [[[457.0, 202.0], [487.0, 202.0], [487.0, 260.0], [457.0, 260.0]], [[438.0, 202.0], [468.0, 202.0], [468.0, 260.0], [438.0, 260.0]]], "lines": ["ちょろ", "ちょろ"]}, {"box": [1110, 778, 1173, 1086], "vertical": true, "font_size": 26, "lines_coords": [[[1143.0, 780.0], [1170.0, 780.0], [1170.0, 1085.0], [1143.0, 1085.0]], [[1110.0, 778.0], [1136.0, 778.0], [1136.0, 976.0], [1110.0, 976.0]]], "lines": ["ナトリウム等が含まれた", "しょっぱい冷泉"]}, {"box": [187, 774, 246, 1100], "vertical": true, "font_size": 26, "lines_coords": [[[219.0, 774.0], [245.0, 774.0], [245.0, 1076.0], [219.0, 1076.0]], [[187.0, 774.0], [213.0, 774.0], [213.0, 1100.0], [187.0, 1100.0]]], "lines": ["昔は沸かして風呂場として", "利用していた事があるらしい"]}, {"box": [656, 1258, 881, 1297], "vertical": false, "font_size": 39, "lines_coords": [[[656.0, 1258.0], [879.0, 1258.0], [879.0, 1297.0], [656.0, 1297.0]]], "lines": ["お先にどうぞ"]}, {"box": [915, 1707, 1196, 1781], "vertical": false, "font_size": 26, "lines_coords": [[[920.0, 1710.0], [1153.0, 1711.0], [1153.0, 1738.0], [920.0, 1736.0]], [[922.0, 1745.0], [1190.0, 1745.0], [1190.0, 1771.0], [922.0, 1771.0]]], "lines": ["メ野湯なのでー応", "入浴できます（水風呂"]}, {"box": [187, 1415, 260, 1766], "vertical": true, "font_size": 64, "lines_coords": [[[187.0, 1417.0], [251.0, 1415.0], [260.0, 1764.0], [196.0, 1766.0]]], "lines": ["入らねぇよ。"]}], "img_path": "00051.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [408, 166, 463, 366], "vertical": true, "font_size": 26, "lines_coords": [[[436.0, 168.0], [463.0, 168.0], [463.0, 264.0], [436.0, 264.0]], [[408.0, 166.0], [433.0, 166.0], [433.0, 365.0], [408.0, 365.0]]], "lines": ["回想だと", "やりたい放題だな。"]}, {"box": [185, 200, 221, 354], "vertical": true, "font_size": 32, "lines_coords": [[[185.0, 200.0], [217.0, 200.0], [221.0, 354.0], [189.0, 354.0]]], "lines": ["ホンマやな。"]}, {"box": [170, 1820, 759, 1848], "vertical": false, "font_size": 26, "lines_coords": [[[170.0, 1820.0], [759.0, 1822.0], [759.0, 1848.0], [170.0, 1846.0]]], "lines": ["現実ではヨシャーの湯にペットを入れてはダメですよ。"]}, {"box": [393, 1301, 504, 1582], "vertical": true, "font_size": 32, "lines_coords": [[[472.0, 1303.0], [504.0, 1303.0], [504.0, 1490.0], [472.0, 1490.0]], [[433.0, 1301.0], [465.0, 1301.0], [465.0, 1492.0], [433.0, 1492.0]], [[393.0, 1303.0], [425.0, 1303.0], [425.0, 1582.0], [393.0, 1582.0]]], "lines": ["バスを降りて", "結構な距離を", "歩いたとは思ったが、"]}, {"box": [196, 1490, 224, 1614], "vertical": true, "font_size": 27, "lines_coords": [[[196.0, 1490.0], [223.0, 1490.0], [223.0, 1614.0], [196.0, 1614.0]]], "lines": ["まさか．．．"]}], "img_path": "00052.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1051, 210, 1185, 418], "vertical": true, "font_size": 35, "lines_coords": [[[1128.0, 210.0], [1170.0, 210.0], [1173.0, 354.0], [1132.0, 354.0]], [[1091.0, 213.0], [1128.0, 213.0], [1128.0, 418.0], [1091.0, 418.0]], [[1053.0, 217.0], [1080.0, 217.0], [1080.0, 365.0], [1053.0, 365.0]]], "lines": ["神戸まで", "来てしまって", "いたとは。"]}, {"box": [236, 220, 498, 484], "vertical": true, "font_size": 153, "lines_coords": [[[301.0, 279.0], [446.0, 230.0], [498.0, 382.0], [354.0, 431.0]]], "lines": ["．．"]}, {"box": [1126, 626, 1210, 969], "vertical": true, "font_size": 29, "lines_coords": [[[1168.0, 631.0], [1194.0, 631.0], [1194.0, 967.0], [1168.0, 967.0]], [[1126.0, 626.0], [1158.0, 626.0], [1158.0, 969.0], [1126.0, 969.0]]], "lines": ["いやいや神戸ちゃうやん", "下に読みが書いてあるで"]}, {"box": [316, 834, 525, 907], "vertical": false, "font_size": 69, "lines_coords": [[[318.0, 834.0], [525.0, 838.0], [523.0, 907.0], [316.0, 903.0]]], "lines": ["Ｇｏｄｏ"]}, {"box": [997, 1248, 1033, 1421], "vertical": true, "font_size": 34, "lines_coords": [[[997.0, 1248.0], [1031.0, 1248.0], [1033.0, 1421.0], [999.0, 1421.0]]],