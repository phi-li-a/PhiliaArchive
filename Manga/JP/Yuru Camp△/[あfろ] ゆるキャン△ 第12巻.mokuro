228.0, 1398.0], [228.0, 1623.0], [196.0, 1623.0]]], "lines": ["どうでしょう"]}], "img_path": "00024.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1126, 195, 1164, 264], "vertical": true, "font_size": 38, "lines_coords": [[[1126.0, 195.0], [1164.0, 195.0], [1164.0, 264.0], [1126.0, 264.0]]], "lines": ["けど"]}, {"box": [909, 206, 1042, 461], "vertical": true, "font_size": 29, "lines_coords": [[[1010.0, 206.0], [1042.0, 206.0], [1042.0, 346.0], [1010.0, 346.0]], [[976.0, 206.0], [1008.0, 206.0], [1008.0, 461.0], [976.0, 461.0]], [[941.0, 208.0], [967.0, 208.0], [967.0, 431.0], [941.0, 431.0]], [[909.0, 208.0], [935.0, 208.0], [935.0, 375.0], [909.0, 375.0]]], "lines": ["薪について", "困った事があったら", "教えて下さるかも", "しれませんね"]}, {"box": [270, 203, 304, 341], "vertical": true, "font_size": 31, "lines_coords": [[[270.0, 204.0], [301.0, 204.0], [301.0, 341.0], [270.0, 341.0]]], "lines": ["そっすね"]}, {"box": [1141, 635, 1183, 714], "vertical": true, "font_size": 42, "lines_coords": [[[1141.0, 635.0], [1183.0, 635.0], [1183.0, 714.0], [1141.0, 714.0]]], "lines": ["翌日"]}, {"box": [1091, 1132, 1209, 1374], "vertical": true, "font_size": 33, "lines_coords": [[[1173.0, 1136.0], [1207.0, 1136.0], [1207.0, 1303.0], [1173.0, 1303.0]], [[1130.0, 1132.0], [1168.0, 1132.0], [1168.0, 1374.0], [1130.0, 1374.0]], [[1091.0, 1136.0], [1117.0, 1136.0], [1117.0, 1336.0], [1091.0, 1336.0]]], "lines": ["薪いっぱい", "貰って来たねぇ", "あきちゃん！！"]}, {"box": [176, 1119, 284, 1460], "vertical": true, "font_size": 28, "lines_coords": [[[255.0, 1123.0], [281.0, 1123.0], [281.0, 1460.0], [255.0, 1460.0]], [[213.0, 1119.0], [245.0, 1119.0], [245.0, 1370.0], [213.0, 1370.0]], [[176.0, 1121.0], [202.0, 1121.0], [202.0, 1400.0], [176.0, 1400.0]]], "lines": ["ぶっちゃけ昨日こんなに", "貰って来れるとは", "思ってなかったわー"]}, {"box": [1098, 1527, 1205, 1777], "vertical": true, "font_size": 28, "lines_coords": [[[1171.0, 1528.0], [1203.0, 1528.0], [1203.0, 1777.0], [1171.0, 1777.0]], [[1138.0, 1530.0], [1164.0, 1530.0], [1164.0, 1683.0], [1138.0, 1683.0]], [[1098.0, 1528.0], [1125.0, 1528.0], [1125.0, 1651.0], [1098.0, 1651.0]]], "lines": ["春休みになったら", "笛吹でまた", "貰えるし"]}, {"box": [626, 1539, 693, 1725], "vertical": true, "font_size": 29, "lines_coords": [[[661.0, 1539.0], [693.0, 1539.0], [693.0, 1695.0], [661.0, 1695.0]], [[626.0, 1541.0], [652.0, 1541.0], [652.0, 1725.0], [626.0, 1725.0]]], "lines": ["もう薪には", "困らないね！！"]}, {"box": [142, 1535, 263, 1775], "vertical": true, "font_size": 35, "lines_coords": [[[228.0, 1539.0], [262.0, 1539.0], [262.0, 1674.0], [228.0, 1674.0]], [[183.0, 1535.0], [221.0, 1535.0], [221.0, 1775.0], [183.0, 1775.0]], [[142.0, 1539.0], [174.0, 1539.0], [174.0, 1753.0], [142.0, 1753.0]]], "lines": ["いやいや", "もうこれ以上は", "いらねえから。"]}], "img_path": "00025.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1072, 189, 1171, 470], "vertical": true, "font_size": 28, "lines_coords": [[[1143.0, 189.0], [1170.0, 189.0], [1168.0, 470.0], [1141.0, 470.0]], [[1110.0, 193.0], [1136.0, 193.0], [1136.0, 442.0], [1110.0, 442.0]], [[1072.0, 191.0], [1104.0, 191.0], [1104.0, 303.0], [1072.0, 303.0]]], "lines": ["まぁこれ以上もろても", "割るのでしんどそう", "やしなぁ"]}, {"box": [330, 151, 394, 459], "vertical": true, "font_size": 26, "lines_coords": [[[365.0, 151.0], [390.0, 151.0], [390.0, 459.0], [365.0, 459.0]], [[330.0, 151.0], [356.0, 151.0], [356.0, 459.0], [330.0, 459.0]]], "lines": ["しばらく野クルの活動は", "新割りがメインになるな"]}, {"box": [181, 283, 228, 388], "vertical": true, "font_size": 47, "lines_coords": [[[181.0, 283.0], [228.0, 283.0], [228.0, 388.0], [181.0, 388.0]]], "lines": ["うへー"]}, {"box": [1136, 654, 1204, 1057], "vertical": true, "font_size": 29, "lines_coords": [[[1171.0, 654.0], [1203.0, 654.0], [1203.0, 1057.0], [1171.0, 1057.0]], [[1136.0, 654.0], [1162.0, 654.0], [1162.0, 960.0], [1136.0, 960.0]]], "lines": ["だが割ったからと言って薪は", "すぐ使える訳じゃない"]}, {"box": [661, 599, 731, 965], "vertical": true, "font_size": 26, "lines_coords": [[[701.0, 600.0], [727.0, 600.0], [727.0, 937.0], [701.0, 937.0]], [[661.0, 600.0], [688.0, 600.0], [688.0, 965.0], [661.0, 965.0]]], "lines": ["最低でも半年から一年は", "乾燥させないとダメらしい"]}, {"box": [658, 1014, 744, 1162], "vertical": true, "font_size": 42, "lines_coords": [[[705.0, 1014.0], [744.0, 1014.0], [744.0, 1162.0], [705.0, 1162.0]], [[658.0, 1014.0], [703.0, 1014.0], [703.0, 1057.0], [658.0, 1057.0]]], "lines": ["そんなに", "！？"]}, {"box": [517, 935, 587, 1245], "vertical": true, "font_size": 29, "lines_coords": [[[553.0, 935.0], [585.0, 935.0], [585.0, 1215.0], [553.0, 1215.0]], [[517.0, 937.0], [543.0, 937.0], [543.0, 1245.0], [517.0, 1245.0]]], "lines": ["薪が乾燥する頃には", "来年になってまうなぁ"]}, {"box": [143, 967, 212, 1243], "vertical": true, "font_size": 26, "lines_coords": [[[183.0, 967.0], [210.0, 967.0], [210.0, 1243.0], [183.0, 1243.0]], [[144.0, 969.0], [170.0, 969.0], [170.0, 1213.0], [144.0, 1213.0]]], "lines": ["まだ薪は買わなきゃ", "いけないのかぁ．．．"]}, {"box": [1134, 1335, 1206, 1614], "vertical": true, "font_size": 27, "lines_coords": [[[1173.0, 1335.0], [1201.0, 1335.0], [1203.0, 1612.0], [1175.0, 1612.0]], [[1138.0, 1336.0], [1164.0, 1336.0], [1160.0, 1522.0], [1134.0, 1522.0]]], "lines": ["うちら徒歩キャンが", "メインだから"]}, {"box": [633, 1320, 704, 1693], "vertical": true, "font_size": 30, "lines_coords": [[[671.0, 1321.0], [703.0, 1321.0], [703.0, 1633.0], [671.0, 1633.0]], [[633.0, 1320.0], [660.0, 1320.0], [660.0, 1691.0], [633.0, 1691.0]]], "lines": ["ぶっちゃけ薪は現地で", "買った方が楽なんだけどな"]}, {"box": [142, 1320, 234, 1605], "vertical": true, "font_size": 39, "lines_coords": [[[189.0, 1320.0], [228.0, 1320.0], [232.0, 1605.0], [193.0, 1605.0]], [[142.0, 1321.0], [181.0, 1321.0], [181.0, 1605.0], [142.0, 1605.0]]], "lines": ["私ががんばって", "持ってきます！！"]}], "img_path": "00026.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1076, 193, 1182, 474], "vertical": true, "font_size": 28, "lines_coords": [[[1149.0, 193.0], [1181.0, 193.0], [1181.0, 474.0], [1149.0, 474.0]], [[1113.0, 195.0], [1140.0, 195.0], [1140.0, 440.0], [1113.0, 440.0]], [[1076.0, 195.0], [1102.0, 195.0], [1102.0, 406.0], [1076.0, 406.0]]], "lines": ["考えても仕方ないし", "とりあえず薪割り", "始めるぞーーっ"]}, {"box": [635, 1209, 705, 1428], "vertical": true, "font_size": 29, "lines_coords": [[[673.0, 1209.0], [705.0, 1209.0], [705.0, 1428.0], [673.0, 1428.0]], [[635.0, 1209.0], [661.0, 1209.0], [661.0, 1365.0], [635.0, 1365.0]]], "lines": ["なでしこちゃん", "うまいなー"]}, {"box": [140, 1436, 213, 1749], "vertical": true, "font_size": 32, "lines_coords": [[[181.0, 1438.0], [213.0, 1438.0], [213.0, 1749.0], [181.0, 1749.0]], [[142.0, 1436.0], [174.0, 1436.0], [172.0, 1687.0], [140.0, 1687.0]]], "lines": ["こないだのキャンプで", "薪割りしたんだよ"]}], "img_path": "00027.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1035, 184, 1183, 420], "vertical": true, "font_size": 30, "lines_coords": [[[1151.0, 185.0], [1183.0, 185.0], [1183.0, 420.0], [1151.0, 420.0]], [[1110.0, 185.0], [1141.0, 185.0], [1141.0, 373.0], [1110.0, 373.0]], [[1072.0, 185.0], [1104.0, 185.0], [1104.0, 373.0], [1072.0, 373.0]], [[1036.0, 185.0], [1063.0, 185.0], [1063.0, 403.0], [1036.0, 403.0]]], "lines": ["そうだなでしこ", "あたしが週末", "どこ行ったか", "聞いてたよな？"]}, {"box": [150, 251, 258, 470], "vertical": true, "font_size": 32, "lines_coords": [[[221.0, 251.0], [258.0, 251.0], [258.0, 461.0], [221.0, 461.0]], [[185.0, 253.0], [217.0, 253.0], [217.0, 470.0], [185.0, 470.0]], [[150.0, 255.0], [176.0, 255.0], [176.0, 440.0], [150.0, 440.0]]], "lines": ["あそうそう！！", "どこ行ってたの", "あきちゃん？"]}, {"box": [1132, 628, 1200, 937], "vertical": true, "font_size": 30, "lines_coords": [[[1173.0, 631.0], [1200.0, 631.0], [1200.0, 937.0], [1173.0, 937.0]], [[1132.0, 628.0], [1164.0, 628.0], [1164.0, 787.0], [1132.0, 787.0]]], "lines": ["実はお前らが大井川に", "行ってた時"]}, {"box": [221, 600, 262, 710], "vertical": true, "font_size": 41, "lines_coords": [[[221.0, 600.0], [262.0, 600.0], [262.0, 710.0], [221.0, 710.0]]], "lines": ["せやな"]}, {"box": [161, 855, 208, 1053], "vertical": true, "font_size": 47, "lines_coords": [[[161.0, 855.0], [208.0, 855.0], [208.0, 1053.0], [161.0, 1053.0]]], "lines": ["えー！！"]}, {"box": [1044, 838, 1115, 1151], "vertical": true, "font_size": 30, "lines_coords": [[[1083.0, 841.0], [1115.0, 841.0], [1115.0, 1151.0], [1083.0, 1151.0]], [[1046.0, 838.0], [1074.0, 838.0], [1072.0, 1057.0], [1044.0, 1057.0]]], "lines": ["「あたしら」もキャンプ", "行ってたんだよ"]}, {"box": [1141, 1237, 1211, 1547], "vertical": true, "font_size": 32, "lines_coords": [[[1173.0, 1237.0], [1211.0, 1237.0], [1211.0, 1456.0], [1173.0, 1456.0]], [[1141.0, 1239.0], [1168.0, 1239.0], [1168.0, 1546.0], [1141.0, 1546.0]]], "lines": ["二人ともどこに", "キャンプ行ってたの！？"]}, {"box": [768, 1332, 799, 1501], "vertical": true, "font_size": 27, "lines_coords": [[[768.0, 1333.0], [795.0, 1333.0], [795.0, 1501.0], [768.0, 1501.0]]], "lines": ["それはなー"]}, {"box": [596, 1231, 667, 1451], "vertical": true, "font_size": 29, "lines_coords": [[[637.0, 1231.0], [663.0, 1231.0], [663.0, 1428.0], [637.0, 1428.0]], [[596.0, 1231.0], [628.0, 1231.0], [628.0, 1451.0], [596.0, 1451.0]]], "lines": ["よしそんじゃ", "薪割りしながら"]}, {"box": [136, 1426, 211, 1723], "vertical": true, "font_size": 30, "lines_coords": [[[181.0, 1430.0], [208.0, 1430.0], [208.0, 1723.0], [181.0, 1723.0]], [[142.0, 1426.0], [174.0, 1426.0], [168.0, 1642.0], [136.0, 1642.0]]], "lines": ["キャンプの土産話でも", "してきますかー"]}], "img_path": "00028.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [], "img_path": "00029.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [], "img_path": "00030.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1124, 161, 1186, 451], "vertical": true, "font_size": 26, "lines_coords": [[[1160.0, 165.0], [1185.0, 165.0], [1185.0, 384.0], [1160.0, 384.0]], [[1125.0, 161.0], [1151.0, 161.0], [1151.0, 451.0], [1125.0, 451.0]]], "lines": ["えー毎度おなじみ", "大垣千明でございます。"]}, {"box": [521, 165, 612, 517], "vertical": true, "font_size": 25, "lines_coords": [[[585.0, 170.0], [611.0, 170.0], [611.0, 515.0], [585.0, 515.0]], [[555.0, 168.0], [579.0, 168.0], [579.0, 517.0], [555.0, 517.0]], [[521.0, 165.0], [547.0, 165.0], [551.0, 292.0], [525.0, 292.0]]], "lines": ["なでしことリンが浜松の友人と", "大井川キャンプへ行ってしまう", "という事で"]}, {"box": [142, 326, 199, 624], "vertical": true, "font_size": 24, "lines_coords": [[[172.0, 326.0], [196.0, 326.0], [196.0, 573.0], [172.0, 573.0]], [[142.0, 328.0], [166.0, 328.0], [166.0, 624.0], [142.0, 624.0]]], "lines": ["休みを持て余した我々", "野クルの残り物メンバーは"]}, {"box": [1126, 714, 1185, 1036], "vertical": true, "font_size": 26, "lines_coords": [[[1158.0, 714.0], [1185.0, 714.0], [1185.0, 1036.0], [1158.0, 1036.0]], [[1126.0, 714.0], [1151.0, 714.0], [1151.0, 937.0], [1126.0, 937.0]]], "lines": ["夜遅くまでＳＮＳで無駄話に", "興じていたのですが、"]}, {"box": [590, 671, 684, 1044], "vertical": true, "font_size": 26, "lines_coords": [[[656.0, 671.0], [682.0, 671.0], [682.0, 896.0], [656.0, 896.0]], [[624.0, 673.0], [650.0, 673.0], [650.0, 1044.0], [624.0, 1044.0]], [[590.0, 675.0], [616.0, 675.0], [616.0, 896.0], [590.0, 896.0]]], "lines": ["「ワシらもキャンプ", "行ったろやないか！！おおん！！", "という流れになり"]}, {"box": [740, 952, 768, 1229], "vertical": true, "font_size": 26, "lines_coords": [[[740.0, 952.0], [766.0, 952.0], [766.0, 1226.0], [740.0, 1226.0]]], "lines": ["深夜のテンションからか"]}, {"box": [142, 939, 206, 1220], "vertical": true, "font_size": 26, "lines_coords": [[[178.0, 941.0], [204.0, 941.0], [204.0, 1173.0], [178.0, 1173.0]], [[142.0, 941.0], [168.0, 941.0], [168.0, 1220.0], [142.0, 1220.0]]], "lines": ["急遽山梨の北へと", "向かう事となりました"]}, {"box": [1074, 1320, 1172, 1657], "vertical": true, "font_size": 28, "lines_coords": [[[1141.0, 1320.0], [1168.0, 1320.0], [1168.0, 1567.0], [1141.0, 1567.0]], [[1106.0, 1320.0], [1138.0, 1320.0], [1138.0, 1657.0], [1106.0, 1657.0]], [[1074.0, 1321.0], [1100.0, 1321.0], [1100.0, 1550.0], [1074.0, 1550.0]]], "lines": ["今回はそんな３人の", "やけくそキャンプの回想を", "お送りいたします。"]}], "img_path": "00031.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "bloc