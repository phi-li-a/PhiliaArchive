, 937.0], [358.0, 937.0]], [[324.0, 763.0], [348.0, 763.0], [348.0, 1076.0], [324.0, 1076.0]], [[292.0, 765.0], [316.0, 765.0], [316.0, 1089.0], [292.0, 1089.0]]], "lines": ["うちらはあきに", "デス・ソーセージアタックを", "お見舞いされてしまうのか？"]}, {"box": [716, 903, 774, 1203], "vertical": true, "font_size": 25, "lines_coords": [[[746.0, 907.0], [772.0, 907.0], [772.0, 1203.0], [746.0, 1203.0]], [[716.0, 903.0], [740.0, 903.0], [740.0, 1080.0], [716.0, 1080.0]]], "lines": ["お好み焼きをお見舞いする", "私と恵那ちゃん"]}, {"box": [155, 907, 220, 1140], "vertical": true, "font_size": 26, "lines_coords": [[[191.0, 907.0], [217.0, 907.0], [217.0, 1140.0], [191.0, 1140.0]], [[155.0, 907.0], [181.0, 907.0], [181.0, 1115.0], [155.0, 1115.0]]], "lines": ["はんべんは本当に", "実在するのか？"]}, {"box": [1070, 1323, 1167, 1629], "vertical": true, "font_size": 28, "lines_coords": [[[1138.0, 1325.0], [1164.0, 1325.0], [1164.0, 1629.0], [1138.0, 1629.0]], [[1102.0, 1323.0], [1134.0, 1323.0], [1132.0, 1606.0], [1100.0, 1606.0]], [[1070.0, 1325.0], [1096.0, 1325.0], [1096.0, 1475.0], [1070.0, 1475.0]]], "lines": ["ホラと現実の入り混じる", "「瑞牆キャンプ回想編」", "最終回です。"]}], "img_path": "00135.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [108, 65, 712, 117], "vertical": false, "font_size": 44, "lines_coords": [[[283.0, 65.0], [708.0, 65.0], [708.0, 116.0], [283.0, 116.0]], [[108.0, 75.0], [298.0, 75.0], [298.0, 112.0], [108.0, 112.0]]], "lines": ["春の瑞牆冬キャンプ", "第６９話"]}, {"box": [266, 247, 341, 333], "vertical": true, "font_size": 62, "lines_coords": [[[266.0, 247.0], [328.0, 247.0], [328.0, 333.0], [266.0, 333.0]]], "lines": ["じゃ"]}], "img_path": "00136.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [594, 154, 675, 412], "vertical": true, "font_size": 32, "lines_coords": [[[639.0, 155.0], [671.0, 155.0], [671.0, 412.0], [639.0, 412.0]], [[594.0, 155.0], [626.0, 155.0], [626.0, 337.0], [594.0, 337.0]]], "lines": ["冷えているのに", "固まらない"]}, {"box": [1137, 384, 1206, 631], "vertical": true, 