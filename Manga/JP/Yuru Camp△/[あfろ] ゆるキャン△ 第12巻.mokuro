.0], [780.0, 1726.0], [748.0, 1726.0]], [[706.0, 1395.0], [738.0, 1395.0], [742.0, 1584.0], [710.0, 1584.0]]], "lines": ["今夜はデス・ソーセージ", "アタックや．．．"]}, {"box": [144, 1437, 191, 1743], "vertical": true, "font_size": 41, "lines_coords": [[[144.0, 1438.0], [185.0, 1438.0], [189.0, 1743.0], [148.0, 1743.0]]], "lines": ["気を取り直して"]}], "img_path": "00124.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1106, 174, 1181, 521], "vertical": true, "font_size": 38, "lines_coords": [[[1143.0, 176.0], [1181.0, 176.0], [1181.0, 521.0], [1143.0, 521.0]], [[1106.0, 174.0], [1143.0, 174.0], [1143.0, 397.0], [1106.0, 397.0]]], "lines": ["トマトをたくさん使った", "キャンプごはん"]}, {"box": [668, 352, 708, 705], "vertical": true, "font_size": 37, "lines_coords": [[[669.0, 352.0], [706.0, 352.0], [706.0, 705.0], [669.0, 705.0]]], "lines": ["作ろか恵那ちゃん！！"]}, {"box": [680, 780, 780, 1119], "vertical": true, "font_size": 28, "lines_coords": [[[750.0, 783.0], [776.0, 783.0], [776.0, 1119.0], [750.0, 1119.0]], [[712.0, 780.0], [744.0, 780.0], [744.0, 1091.0], [712.0, 1091.0]], [[680.0, 781.0], [706.0, 781.0], [706.0, 950.0], [680.0, 950.0]]], "lines": ["トマトシュースＰＣでを加えて", "「崩れるまでフライパンで", "煮ていきます"]}, {"box": [236, 451, 286, 592], "vertical": true, "font_size": 50, "lines_coords": [[[236.0, 451.0], [286.0, 451.0], [286.0, 592.0], [236.0, 592.0]]], "lines": ["だね！！"]}, {"box": [140, 770, 205, 1106], "vertical": true, "font_size": 26, "lines_coords": [[[174.0, 770.0], [200.0, 770.0], [200.0, 1051.0], [174.0, 1051.0]], [[140.0, 770.0], [165.0, 770.0], [165.0, 1104.0], [140.0, 1104.0]]], "lines": ["刻みニンニク３かけと", "オリープオイル太３を加え"]}, {"box": [1136, 778, 1204, 1184], "vertical": true, "font_size": 32, "lines_coords": [[[1171.0, 780.0], [1203.0, 780.0], [1203.0, 1183.0], [1171.0, 1183.0]], [[1136.0, 780.0], [1168.0, 780.0], [1168.0, 978.0], [1136.0, 978.0]]], "lines": ["まずヘタを取りざく切りにした", "トマト中６コに"]}, {"box": [1080, 1276, 1113, 1495], "vertical": true, "font_size": 31, "lines_coords": [[[1080.0, 1276.0], [1111.0, 1276.0], [1111.0, 1400.0], [1080.0, 1400.0]]], "lines": ["メイラー"]}, {"box": [570, 768, 637, 1188], "vertical": true, "font_size": 32, "lines_coords": [[[605.0, 770.0], [637.0, 770.0], [637.0, 1051.0], [605.0, 1051.0]], [[570.0, 768.0], [601.0, 768.0], [603.0, 1188.0], [571.0, 1188.0]]], "lines": ["トマトを着る傍ら鍋で", "みじん切りにした玉ねぎ中２個に"]}, {"box": [661, 1287, 694, 1504], "vertical": true, "font_size": 32, "lines_coords": [[[661.0, 1291.0], [693.0, 1291.0], [693.0, 1408.0], [661.0, 1408.0]]], "lines": ["メイラー"]}, {"box": [247, 1239, 481, 1520], "vertical": true, "font_size": 37, "lines_coords": [[[440.0, 1239.0], [481.0, 1239.0], [481.0, 1368.0], [440.0, 1368.0]], [[406.0, 1241.0], [438.0, 1241.0], [438.0, 1430.0], [406.0, 1430.0]], [[363.0, 1239.0], [401.0, 1239.0], [401.0, 1458.0], [363.0, 1458.0]], [[326.0, 1239.0], [363.0, 1239.0], [363.0, 1520.0], [326.0, 1520.0]], [[285.0, 1239.0], [326.0, 1239.0], [326.0, 1338.0], [285.0, 1338.0]], [[251.0, 1239.0], [285.0, 1239.0], [281.0, 1408.0], [247.0, 1408.0]]], "lines": ["ちなみに", "ここから先は", "フライパン！ＦＰ", "オリーブオイルＩＯＯ", "鍋！ＢＮＢ", "と略します。"]}, {"box": [1164, 1248, 1206, 1724], "vertical": true, "font_size": 37, "lines_coords": [[[1164.0, 1248.0], [1201.0, 1248.0], [1201.0, 1723.0], [1164.0, 1723.0]]], "lines": ["きつね色になるまで炒めましょう"]}, {"box": [185, 1535, 259, 1748], "vertical": true, "font_size": 28, "lines_coords": [[[225.0, 1535.0], [256.0, 1535.0], [256.0, 1734.0], [225.0, 1734.0]], [[187.0, 1537.0], [213.0, 1537.0], [213.0, 1747.0], [187.0, 1747.0]]], "lines": ["鍋は略しても", "意味ねぇだろ。"]}], "img_path": "00125.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1130, 146, 1200, 517], "vertical": true, "font_size": 32, "lines_coords": [[[1166.0, 146.0], [1198.0, 146.0], [1196.0, 515.0], [1164.0, 515.0]], [[1130.0, 148.0], [1162.0, 148.0], [1162.0, 431.0], [1130.0, 431.0]]], "lines": ["小さめに刻んだ豚バラ１５０ｇを", "ＮＢに加えてさらになめ"]}, {"box": [1020, 168, 1059, 370], "vertical": true, "font_size": 39, "lines_coords": [[[1020.0, 168.0], [1059.0, 168.0], [1059.0, 283.0], [1020.0, 283.0]]], "lines": ["メイラー"]}, {"box": [892, 129, 995, 234], "vertical": true, "font_size": 45, "lines_coords": [[[948.0, 129.0], [995.0, 129.0], [995.0, 232.0], [948.0, 232.0]], [[896.0, 131.0], [939.0, 133.0], [935.0, 234.0], [892.0, 232.0]]], "lines": ["メイラ", "メイラ"]}, {"box": [538, 137, 634, 322], "vertical": true, "font_size": 33, "lines_coords": [[[600.0, 138.0], [633.0, 138.0], [633.0, 255.0], [600.0, 255.0]], [[538.0, 138.0], [571.0, 138.0], [571.0, 318.0], [538.0, 318.0]]], "lines": ["メイラー", "メイラード"]}, {"box": [459, 146, 500, 344], "vertical": true, "font_size": 37, "lines_coords": [[[463.0, 146.0], [500.0, 146.0], [496.0, 288.0], [459.0, 288.0]]], "lines": ["メイラー"]}, {"box": [397, 200, 436, 366], "vertical": true, "font_size": 39, "lines_coords": [[[397.0, 200.0], [436.0, 200.0], [436.0, 324.0], [397.0, 324.0]]], "lines": ["メイラー"]}, {"box": [200, 181, 285, 408], "vertical": true, "font_size": 38, "lines_coords": [[[247.0, 181.0], [285.0, 181.0], [285.0, 371.0], [247.0, 371.0]], [[200.0, 183.0], [238.0, 183.0], [238.0, 408.0], [200.0, 408.0]]], "lines": ["さっきから", "何だその呪文"]}, {"box": [1098, 579, 1198, 928], "vertical": true, "font_size": 26, "lines_coords": [[[1168.0, 581.0], [1194.0, 581.0], [1194.0, 856.0], [1168.0, 856.0]], [[1132.0, 583.0], [1158.0, 583.0], [1158.0, 924.0], [1132.0, 924.0]], [[1098.0, 581.0], [1125.0, 581.0], [1125.0, 774.0], [1098.0, 774.0]]], "lines": ["豚肉に火が通った所で", "ローリエ１枚赤ワインＢＣＧ", "水１００ｃを加えて"]}, {"box": [380, 581, 446, 832], "vertical": true, "font_size": 29, "lines_coords": [[[418.0, 583.0], [444.0, 583.0], [444.0, 828.0], [418.0, 828.0]], [[380.0, 581.0], [412.0, 581.0], [412.0, 695.0], [380.0, 695.0]]], "lines": ["アクを取りつつ煮て", "いきます"]}, {"box": [202, 599, 281, 855], "vertical": true, "font_size": 36, "lines_coords": [[[243.0, 600.0], [281.0, 600.0], [281.0, 855.0], [243.0, 855.0]], [[202.0, 603.0], [236.0, 603.0], [236.0, 738.0], [202.0, 738.0]]], "lines": ["あ〜ん、わらひの", "ワイン～"]}, {"box": [1084, 1031, 1200, 1342], "vertical": true, "font_size": 30, "lines_coords": [[[1166.0, 1035.0], [1198.0, 1035.0], [1198.0, 1342.0], [1166.0, 1342.0]], [[1121.0, 1031.0], [1153.0, 1031.0], [1153.0, 1301.0], [1121.0, 1301.0]], [[1085.0, 1036.0], [1111.0, 1036.0], [1111.0, 1220.0], [1085.0, 1220.0]]], "lines": ["ＦＰで煮崩したトマトと", "顆粒コンソメ塩を", "ＮＥに入れたら"]}, {"box": [991, 1002, 1040, 1093], "vertical": true, "font_size": 29, "lines_coords": [[[991.0, 1005.0], [1020.0, 1005.0], [1020.0, 1093.0], [991.0, 1093.0]]], "lines": ["高えたよ"]}, {"box": [296, 980, 393, 1316], "vertical": true, "font_size": 27, "lines_coords": [[[365.0, 980.0], [391.0, 980.0], [391.0, 1203.0], [365.0, 1203.0]], [[328.0, 982.0], [356.0, 982.0], [358.0, 1316.0], [330.0, 1316.0]], [[296.0, 982.0], [322.0, 982.0], [322.0, 1177.0], [296.0, 1177.0]]], "lines": ["焦がさないように", "量が半分くらいになるまで", "煮詰めましょう"]}, {"box": [1083, 1401, 1140, 1777], "vertical": true, "font_size": 26, "lines_coords": [[[1113.0, 1406.0], [1140.0, 1406.0], [1140.0, 1777.0], [1113.0, 1777.0]], [[1083.0, 1406.0], [1108.0, 1406.0], [1108.0, 1627.0], [1083.0, 1627.0]]], "lines": ["ＮＢのトマトソースが煮詰まったら、", "ローリエを取り出し"]}, {"box": [262, 1828, 710, 1852], "vertical": false, "font_size": 24, "lines_coords": [[[262.0, 1828.0], [710.0, 1828.0], [710.0, 1852.0], [262.0, 1852.0]]], "lines": ["コンソメと塩は味見をしながら加えます。"]}, {"box": [380, 1435, 451, 1743], "vertical": true, "font_size": 29, "lines_coords": [[[418.0, 1436.0], [450.0, 1436.0], [450.0, 1713.0], [418.0, 1713.0]], [[380.0, 1436.0], [406.0, 1436.0], [406.0, 1743.0], [380.0, 1743.0]]], "lines": ["バター２５ｇを入れて", "もう少し火にかけます"]}], "img_path": "00126.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1145, 249, 1206, 671], "vertical": true, "font_size": 26, "lines_coords": [[[1177.0, 251.0], [1203.0, 251.0], [1203.0, 671.0], [1177.0, 671.0]], [[1145.0, 249.0], [1170.0, 249.0], [1170.0, 646.0], [1145.0, 646.0]]], "lines": ["ＦＰの汚れを拭き取ってＯＯを軽く引き", "ざく切りにしたキャベツ葉３枚と"]}, {"box": [675, 129, 775, 523], "vertical": true, "font_size": 26, "lines_coords": [[[744.0, 133.0], [770.0, 133.0], [774.0, 523.0], [748.0, 523.0]], [[712.0, 133.0], [738.0, 133.0], [738.0, 440.0], [712.0, 440.0]], [[675.0, 129.0], [701.0, 129.0], [705.0, 480.0], [678.0, 480.0]]], "lines": ["イチョウ切りにした人参１本を", "しなっとするまで炒めて", "半分は取り出しておきます。"]}, {"box": [138, 133, 242, 525], "vertical": true, "font_size": 28, "lines_coords": [[[211.0, 135.0], [238.0, 135.0], [238.0, 525.0], [211.0, 525.0]], [[176.0, 133.0], [202.0, 133.0], [202.0, 356.0], [176.0, 356.0]], [[138.0, 133.0], [170.0, 133.0], [170.0, 472.0], [138.0, 472.0]]], "lines": ["ＦＰに焼きそば１玉と水を加えて", "蒸し焼きにしたら", "粉末ソースを絡めましょう。"]}, {"box": [1082, 746, 1181, 1141], "vertical": true, "font_size": 28, "lines_coords": [[[1153.0, 750.0], [1179.0, 750.0], [1179.0, 1140.0], [1153.0, 1140.0]], [[1113.0, 746.0], [1145.0, 746.0], [1147.0, 1126.0], [1115.0, 1126.0]], [[1083.0, 750.0], [1110.0, 750.0], [1110.0, 984.0], [1083.0, 984.0]]], "lines": ["その上からＮＢのトマトソースを", "ひとかけパセリと粉チーズを", "振ったら完成です。"]}, {"box": [421, 1221, 946, 1326], "vertical": false, "font_size": 33, "lines_coords": [[[431.0, 1224.0], [931.0, 1224.0], [931.0, 1248.0], [431.0, 1248.0]], [[425.0, 1250.0], [943.0, 1250.0], [943.0, 1276.0], [425.0, 1276.0]], [[459.0, 1275.0], [901.0, 1275.0], [901.0, 1325.0], [459.0, 1325.0]]], "lines": ["山梨県中央市が地元のトマトを広めるため考案した", "トマト焼きそばをあえて地所のトマトを使用して作る", "背徳のトマ卜焼きそば"]}, {"box": [159, 862, 272, 1216], "vertical": true, "font_size": 51, "lines_coords": [[[217.0, 862.0], [268.0, 862.0], [271.0, 1216.0], [221.0, 1216.0]], [[159.0, 864.0], [210.0, 864.0], [210.0, 1168.0], [159.0, 1168.0]]], "lines": ["うまそうだけど", "ネーミング！！"]}, {"box": [1132, 1590, 1205, 1747], "vertical": true, "font_size": 36, "lines_coords": [[[1166.0, 1590.0], [1205.0, 1590.0], [1205.0, 1689.0], [1166.0, 1689.0]], [[1132.0, 1590.0], [1164.0, 1590.0], [1164.0, 1745.0], [1132.0, 1745.0]]], "lines": ["１品目", "完成やでー"]}, {"box": [736, 1408, 821, 1620], "vertical": true, "font_size": 27, "lines_coords": [[[793.0, 1408.0], [819.0, 1408.0], [821.0, 1575.0], [795.0, 1575.0]], [[766.0, 1413.0], [793.0, 1413.0], [793.0, 1620.0], [766.0, 1620.0]], [[736.0, 1410.0], [763.0, 1410.0], [763.0, 1528.0], [736.0, 1528.0]]], "lines": ["トマトソースの", "かかった焼きそばて", "珍しいなー"]}, {"box": [838, 1606, 904, 1721], "vertical": true, "font_size": 30, "lines_coords": [[[877.0, 1612.0], [903.0, 1612.0], [903.0, 1721.0], [877.0, 1721.0]], [[838.0, 1606.0], [873.0, 1606.0], [873.0, 1672.0], [838.0, 1672.0]]], "lines": ["めしあが", "れー"]}, {"box": [403, 1445, 472, 1561], "vertical": true, "font_size": 34, "lines_coords": [[[435.0, 1445.0], [468.0, 1445.0], [472.0, 1561.0], [438.0, 1561.0]], [[403.0, 1445.0], [438.0, 1445.0], [438.0, 1509.0], [403.0, 1509.0]]], "lines": ["いただき", "ます"]}, {"box": [150, 1633, 215, 1751], "vertical": true, "font_size": 34, "lines_coords": [[[183.0, 1638.0], [215.0, 1638.0], [215.0, 1751.0], [183.0, 1751.0]], [[150.0, 1633.0], [185.0, 1633.0], [185.0, 1698.0], [150.0, 1698.0]]], "lines": ["いららき", "まー"]}], "img_path": "00127.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1115, 180, 1173, 459], "vertical": true, "font_size": 58, "lines_coords": [[[1115.0, 180.0], [1173.0, 180.0], [1173.0, 459.0], [1115.0, 459.0]]], "lines": ["うっま！！"]}, {"box": [498, 131, 583, 442], "vertical": true, "font_size": 36, "lines_coords": [[[543.0, 131.0], [583.0, 131.0], [583.0, 403.0], [543.0, 403.0]], [[498.0, 131.0], [530.0, 131.0], [530.0, 442.0], [498.0, 442.0]]], "lines": ["何だこのソース", "うますぎるだろ！！"]}, {"box": [172, 206, 260, 255], "vertical": false, "font_size": 49, "lines_coords": [[[172.0, 206.0], [260.0, 206.0], [260.0, 255.0], [172.0, 255.0]]], "lines": ["うまー"]}, {"box": [1104, 785, 1179, 1096], "vertical": true, "font_size": 35, "lines_coords": [[[1138.0, 785.0], [1175.0, 785.0], [1179.0, 1003.0], [1141.0, 1003.0]], [[1104.0, 787.0], [1136.0, 787.0], [1136.0, 1096.0], [1104.0, 1096.0]]], "lines": ["トマトの旨味が", "すげー凝縮されてて．．．"]}, {"box": [191, 757, 285, 1140], "vertical": true, "font_size": 28, "lines_coords": [[[256.0, 757.0], [283.0, 757.0], [283.0, 1140.0], [256.0, 1140.0]], [[221.0, 757.0], [253.0, 757.0], [253.0, 997.0], [221.0, 997.0]], [[191.0, 759.0], [215.0, 759.0], [215.0, 969.0], [191.0, 969.0]]], "lines": ["やばい今まで食ったキャンプ飯", "の中で１〜２を争う", "ウマさかもしれん"]}, {"box": [1153, 1528, 1185, 1657], "vertical": true, "font_size": 32, "lines_coords": [[[1153.0, 1528.0], [1185.0, 1528.0], [1185.0, 1657.0], [1153.0, 1657.0]]], "lines": ["うま！！"]}, {"box": [845, 1486, 901, 1788], "vertical": true, "font_size": 26, "lines_coords": [[[871.0, 1486.0], [898.0, 1486.0], [900.0, 1788.0], [873.0, 1788.0]], [[845.0, 1486.0], [870.0, 1486.0], [870.0, 1766.0], [845.0, 1766.0]]], "lines": ["レシピ通り作っただけやけど", "ホンマにむっちゃうまいわ"]}, {"box": [648, 1586, 721, 1711], "vertical": true, "font_size": 35, "lines_coords": [[[688.0, 1590.0], [720.0, 1590.0], [720.0, 1711.0], [688.0, 1711.0]], [[648.0, 1586.0], [686.0, 1586.0], [686.0, 1655.0], [648.0, 1655.0]]], "lines": ["おいひい", "よね"]}, {"box": [515, 1393, 581, 1777], "vertical": true, "font_size": 26, "lines_coords": [[[553.0, 1395.0], [579.0, 1395.0], [579.0, 1719.0], [553.0, 1719.0]], [[515.0, 1395.0], [541.0, 1395.0], [541.0, 1777.0], [515.0, 1777.0]]], "lines": ["そう言えば何で途中から", "なでしこが解説してたんだ？"]}], "img_path": "00128.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1087, 150, 1190, 507], "vertical": true, "font_size": 30, "lines_coords": [[[1162.0, 153.0], [1188.0, 153.0], [1188.0, 300.0], [1162.0, 300.0]], [[1119.0, 150.0], [1156.0, 150.0], [1156.0, 481.0], [1119.0, 481.0]], [[1089.0, 153.0], [1115.0, 153.0], [1115.0, 506.0], [1089.0, 506.0]]], "lines": ["だってこれ", "うちの「クックレシピ」に", "投稿してあるレシピだもん"]}, {"box": [311, 178, 870, 241], "vertical": false, "font_size": 58, "lines_coords": [[[311.0, 178.0], [870.0, 183.0], [870.0, 241.0], [311.0, 236.0]]], "lines": ["噂ｃｏｏｋｒｅｃｉｐｅ"]}, {"box": [275, 260, 823, 388], "vertical": false, "font_size": 74, "lines_coords": [[[275.0, 260.0], [823.0, 260.0], [823.0, 356.0], [275.0, 356.0]], [[341.0, 337.0], [744.0, 337.0], [744.0, 388.0], [341.0, 388.0]]], "lines": ["山県中央市北地区のマッチなどが参加したマスト教えて、友人であって使用しているサイトは", "背徳のトマト焼きそば"]}, {"box": [1080, 775, 1179, 1080], "vertical": true, "font_size": 25, "lines_coords": [[[1149.0, 778.0], [1175.0, 778.0], [1175.0, 1025.0], [1149.0, 1025.0]], [[1115.0, 780.0], [1141.0, 780.0], [1141.0, 1078.0], [1115.0, 1078.0]], [[1080.0, 776.0], [1104.0, 776.0], [1104.0, 999.0], [1080.0, 999.0]]], "lines": ["なでしこちゃん家は", "一家全員でクックレシピ", "やっとるんよねー"]}, {"box": [772, 495, 965, 785], "vertical": false, "font_size": 164.0, "lines_coords": [[[813.0, 495.0], [965.0, 495.0], [965.0, 547.0], [813.0, 547.0]], [[785.0, 500.0], [963.0, 510.0], [950.0, 785.0], [772.0, 776.0]]], "lines": ["．．．", "ああ．．．"]}, {"box": [603, 793, 667, 903], "vertical": true, "font_size": 32, "lines_coords": [[[635.0, 793.0], [667.0, 793.0], [667.0, 903.0], [635.0, 903.0]], [[603.0, 793.0], [635.0, 793.0], [635.0, 901.0], [603.0, 901.0]]], "lines": ["そうなん", "だよねぇ"]}, {"box": [168, 327, 260, 663], "vertical": true, "font_size": 40, "lines_coords": [[[219.0, 328.0], [258.0, 328.0], [258.0, 579.0], [219.0, 579.0]], [[168.0, 328.0], [208.0, 328.0], [208.0, 663.0], [168.0, 663.0]]], "lines": ["ネーミングは", "なでしこ父かい！！"]}, {"box": [176, 853, 253, 1029], "vertical": true, "font_size": 36, "lines_coords": [[[213.0, 853.0], [253.0, 853.0], [253.0, 961.0], [213.0, 961.0]], [[176.0, 855.0], [208.0, 855.0], [208.0, 1029.0], [176.0, 1029.0]]], "lines": ["さすが", "各務原家：："]}, {"box": [1146, 1145, 1209, 1396], "vertical": true, "font_size": 26, "lines_coords": [[[1179.0, 1145.0], [1207.0, 1145.0], [1209.0, 1396.0], [1181.0, 1396.0]], [[1147.0, 1145.0], [1171.0, 1145.0], [1171.0, 1312.0], [1147.0, 1312.0]]], "lines": ["お父さんはちょっと", "変わった料理"]}, {"box": [744, 1143, 806, 1367], "vertical": true, "font_size": 26, "lines_coords": [[[780.0, 1143.0], [806.0, 1143.0], [806.0, 1365.0], [780.0, 1365.0]], [[744.0, 1143.0], [770.0, 1143.0], [770.0, 1366.0], [744.0, 1366.0]]], "lines": ["お母さんは毎日の", "献立に使える料理"]}, {"box": [609, 1130, 675, 1466], "vertical": true, "font_size": 26, "lines_coords": [[[645.0, 1134.0], [671.0, 1134.0], [671.0, 1464.0], [645.0, 1464.0]], [[609.0, 1130.0], [635.0, 1130.0], [635.0, 1355.0], [609.0, 1355.0]]], "lines": ["お姉ちゃんは５分でできる", "手抜きおやつだよ"]}, {"box": [303, 1167, 539, 1196], "vertical": false, "font_size": 24, "lines_coords": [[[303.0, 1171.0], [534.0, 1168.0], [534.0, 1192.0], [303.0, 1196.0]]], "lines": ["みたらし・団子アイフ"]}, {"box": [142, 1138, 207, 1388], "vertical": true, "font_size": 26, "lines_coords": [[[180.0, 1141.0], [206.0, 1141.0], [206.0, 1361.0], [180.0, 1361.0]], [[142.0, 1138.0], [168.0, 1138.0], [168.0, 1387.0], [142.0, 1387.0]]], "lines": ["お姉さん文章まで", "むっちゃ手抜きやな"]}, {"box": [736, 1500, 809, 1786], "vertical": true, "font_size": 36, "lines_coords": [[[780.0, 1505.0], [806.0, 1505.0], [806.0, 1786.0], [780.0, 1786.0]], [[736.0, 1500.0], [781.0, 1500.0], [781.0, 1569.0], [736.0, 1569.0]]], "lines": ["私はキャンプで作った", "料理"]}, {"box": [303, 1476, 540, 1501], "vertical": false, "font_size": 24, "lines_coords": [[[303.0, 1477.0], [532.0, 1477.0], [532.0, 1501.0], [303.0, 1501.0]]], "lines": ["みたらし団子をアイスに乗せる"]}, {"box": [305, 1432, 370, 1455], "vertical": false, "font_size": 21, "lines_coords": [[[307.0, 1434.0], [363.0, 1434.0], [363.0, 1455.0], [307.0, 1455.0]]], "lines": ["作り方"]}, {"box": [140, 1545, 212, 1765], "vertical": true, "font_size": 32, "lines_coords": [[[180.0, 1545.0], [211.0, 1545.0], [211.0, 1700.0], [180.0, 1700.0]], [[140.0, 1545.0], [172.0, 1545.0], [172.0, 1728.0], [140.0, 1728.0]]], "lines": ["でも簡単で", "おいしいよー"]}], "img_path": "00129.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1138, 196, 1169, 411], "vertical": true, "font_size": 26, "lines_coords": [[[1140.0, 196.0], [1166.0, 196.0], [1166.0, 410.0], [1140.0, 410.0]]], "lines": ["おいしかったー"]}, {"box": [365, 213, 425, 465], "vertical": true, "f