08.0], [705.0, 1608.0]], [[667.0, 1365.0], [693.0, 1365.0], [693.0, 1670.0], [667.0, 1670.0]]], "lines": ["薪割りってナタと", "斧でやるものだよねぇ"]}, {"box": [151, 1511, 219, 1760], "vertical": true, "font_size": 30, "lines_coords": [[[187.0, 1511.0], [219.0, 1511.0], [219.0, 1702.0], [187.0, 1702.0]], [[151.0, 1515.0], [178.0, 1515.0], [178.0, 1760.0], [151.0, 1760.0]]], "lines": ["どないしたん", "なでしこちゃん？"]}], "img_path": "00060.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1087, 309, 1222, 588], "vertical": true, "font_size": 28, "lines_coords": [[[1188.0, 309.0], [1222.0, 309.0], [1222.0, 412.0], [1188.0, 412.0]], [[1156.0, 313.0], [1183.0, 313.0], [1183.0, 588.0], [1156.0, 588.0]], [[1119.0, 311.0], [1145.0, 311.0], [1145.0, 534.0], [1119.0, 534.0]], [[1087.0, 311.0], [1111.0, 311.0], [1111.0, 532.0], [1087.0, 532.0]]], "lines": ["私前に", "ハンマーで薪割りする", "おじさんの動画を", "見かけたんだけど"]}, {"box": [315, 305, 382, 558], "vertical": true, "font_size": 31, "lines_coords": [[[346.0, 305.0], [382.0, 305.0], [382.0, 395.0], [346.0, 395.0]], [[315.0, 307.0], [341.0, 307.0], [341.0, 556.0], [315.0, 556.0]]], "lines": ["あれは", "何だったのかなぁ？"]}, {"box": [165, 172, 229, 450], "vertical": true, "font_size": 29, "lines_coords": [[[196.0, 172.0], [228.0, 172.0], [228.0, 450.0], [196.0, 450.0]], [[165.0, 172.0], [191.0, 172.0], [191.0, 283.0], [165.0, 283.0]]], "lines": ["ハンマーってめっちゃ", "力技だな"]}, {"box": [1036, 690, 1136, 971], "vertical": true, "font_size": 29, "lines_coords": [[[1106.0, 690.0], [1134.0, 690.0], [1136.0, 901.0], [1108.0, 901.0]], [[1068.0, 690.0], [1100.0, 690.0], [1102.0, 971.0], [1070.0, 971.0]], [[1036.0, 690.0], [1063.0, 690.0], [1063.0, 941.0], [1036.0, 941.0]]], "lines": ["それもしかして", "クサビを使って薪割り", "してたんじゃない？"]}, {"box": [206, 703, 240, 828], "vertical": true, "font_size": 34, "lines_coords": [[[206.0, 703.0], [240.0, 703.0], [240.0, 828.0], [206.0, 828.0]]], "lines": ["くさび？"]}, {"box": [1110, 1059, 1207, 1450], "vertical": true, "font_size": 27, "lines_coords": [[[1177.0, 1059.0], [1203.0, 1059.0], [1203.0, 1391.0], [1177.0, 1391.0]], [[1141.0, 1059.0], [1170.0, 1059.0], [1171.0, 1449.0], [1143.0, 1449.0]], [[1110.0, 1059.0], [1136.0, 1059.0], [1136.0, 1282.0], [1110.0, 1282.0]]], "lines": ["こういう金属製のクサビを", "ハンマーで打ち込んで薪を割る", "方法もあるんだよ"]}, {"box": [616, 1074, 685, 1383], "vertical": true, "font_size": 26, "lines_coords": [[[656.0, 1080.0], [682.0, 1080.0], [682.0, 1353.0], [656.0, 1353.0]], [[616.0, 1074.0], [643.0, 1074.0], [643.0, 1383.0], [616.0, 1383.0]]], "lines": ["ハンマーを使うなら、", "他にもこんな道具とか"]}, {"box": [144, 1081, 215, 1313], "vertical": true, "font_size": 29, "lines_coords": [[[185.0, 1085.0], [211.0, 1085.0], [211.0, 1312.0], [185.0, 1312.0]], [[144.0, 1081.0], [176.0, 1081.0], [176.0, 1301.0], [144.0, 1301.0]]], "lines": ["ほほう、据置型の", "斧って感じだな"]}, {"box": [761, 1478, 829, 1696], "vertical": true, "font_size": 26, "lines_coords": [[[800.0, 1479.0], [826.0, 1479.0], [826.0, 1695.0], [800.0, 1695.0]], [[761.0, 1479.0], [787.0, 1479.0], [789.0, 1663.0], [763.0, 1663.0]]], "lines": ["そんな割り方も", "あるんだねぇ"]}, {"box": [148, 1477, 217, 1695], "vertical": true, "font_size": 29, "lines_coords": [[[183.0, 1477.0], [215.0, 1477.0], [215.0, 1695.0], [183.0, 1695.0]], [[150.0, 1479.0], [176.0, 1479.0], [176.0, 1631.0], [150.0, 1631.0]]], "lines": ["これはアイデア", "商品やなぁ"]}], "img_path": "00061.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1119, 148, 1218, 457], "vertical": true, "font_size": 27, "lines_coords": [[[1192.0, 150.0], [1218.0, 150.0], [1218.0, 345.0], [1192.0, 345.0]], [[1155.0, 148.0], [1181.0, 148.0], [1181.0, 399.0], [1155.0, 399.0]], [[1123.0, 148.0], [1149.0, 148.0], [1145.0, 457.0], [1119.0, 457.0]]], "lines": ["思ったんだけど", "これだけ大量の薪を", "毎年割るならいっその事"]}, {"box": [1008, 255, 1074, 536], "vertical": true, "font_size": 27, "lines_coords": [[[1042.0, 255.0], [1074.0, 255.0], [1074.0, 536.0], [1042.0, 536.0]], [[1008.0, 256.0], [1035.0, 256.0], [1035.0, 506.0], [1008.0, 506.0]]], "lines": ["新割り機を買った方が", "いいんじゃないか？"]}, {"box": [189, 236, 222, 393], "vertical": true, "font_size": 32, "lines_coords": [[[189.0, 238.0], [221.0, 238.0], [221.0, 393.0], [189.0, 393.0]]], "lines": ["薪割り機？"]}, {"box": [1077, 648, 1177, 901], "vertical": true, "font_size": 28, "lines_coords": [[[1145.0, 650.0], [1177.0, 650.0], [1177.0, 819.0], [1145.0, 819.0]], [[1110.0, 648.0], [1138.0, 648.0], [1140.0, 900.0], [1111.0, 900.0]], [[1078.0, 650.0], [1102.0, 650.0], [1102.0, 819.0], [1078.0, 819.0]]], "lines": ["こんな感じで", "両側からプレスして", "薪を割る機械"]}, {"box": [189, 663, 259, 975], "vertical": true, "font_size": 32, "lines_coords": [[[226.0, 663.0], [258.0, 663.0], [258.0, 851.0], [226.0, 851.0]], [[189.0, 665.0], [221.0, 665.0], [221.0, 975.0], [189.0, 975.0]]], "lines": ["ほほーなんか", "フロっぽい道具だねぇ"]}, {"box": [189, 1074, 303, 1376], "vertical": true, "font_size": 48, "lines_coords": [[[253.0, 1080.0], [303.0, 1080.0], [303.0, 1353.0], [253.0, 1353.0]], [[189.0, 1074.0], [236.0, 1074.0], [240.0, 1376.0], [193.0, 1376.0]]], "lines": ["ってたかっ！！", "くそたかっ！！"]}, {"box": [504, 1608, 1125, 1775], "vertical": false, "font_size": 84.5, "lines_coords": [[[680.0, 1616.0], [1123.0, 1608.0], [1125.0, 1685.0], [682.0, 1693.0]], [[504.0, 1680.0], [1063.0, 1683.0], [1063.0, 1775.0], [504.0, 1771.0]]], "lines": ["ジン武１５♭薪割り殺『へへへ", "¥１３０，０００ｘ２"]}, {"box": [212, 1486, 311, 1701], "vertical": true, "font_size": 42, "lines_coords": [[[264.0, 1486.0], [311.0, 1486.0], [311.0, 1621.0], [264.0, 1621.0]], [[213.0, 1488.0], [251.0, 1488.0], [251.0, 1698.0], [213.0, 1698.0]]], "lines": ["じゅう", "さんまん！！"]}], "img_path": "00062.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1083, 168, 1190, 423], "vertical": true, "font_size": 32, "lines_coords": [[[1153.0, 168.0], [1190.0, 168.0], [1190.0, 423.0], [1153.0, 423.0]], [[1119.0, 172.0], [1151.0, 172.0], [1151.0, 350.0], [1119.0, 350.0]], [[1083.0, 168.0], [1110.0, 168.0], [1110.0, 346.0], [1083.0, 346.0]]], "lines": ["いいくらなんで