rds": [[[626.0, 712.0], [652.0, 712.0], [652.0, 1081.0], [626.0, 1081.0]], [[586.0, 708.0], [611.0, 708.0], [611.0, 1130.0], [586.0, 1130.0]]], "lines": ["まぁこないだも瞬殺されてたし、", "今頃行っても残ってるとは思えんが"]}, {"box": [136, 710, 198, 1003], "vertical": true, "font_size": 30, "lines_coords": [[[166.0, 714.0], [198.0, 714.0], [198.0, 1003.0], [166.0, 1003.0]], [[136.0, 710.0], [163.0, 710.0], [163.0, 819.0], [136.0, 819.0]]], "lines": ["一応先生と見てこようと", "思ってさ"]}, {"box": [1110, 1245, 1226, 1464], "vertical": true, "font_size": 34, "lines_coords": [[[1194.0, 1248.0], [1226.0, 1248.0], [1222.0, 1402.0], [1190.0, 1402.0]], [[1156.0, 1250.0], [1183.0, 1250.0], [1183.0, 1464.0], [1156.0, 1464.0]], [[1110.0, 1245.0], [1153.0, 1245.0], [1153.0, 1316.0], [1110.0, 1316.0]]], "lines": ["大垣さーん", "もう車出せます", "よー"]}, {"box": [718, 850, 786, 1157], "vertical": true, "font_size": 26, "lines_coords": [[[755.0, 851.0], [781.0, 851.0], [781.0, 1156.0], [755.0, 1156.0]], [[718.0, 851.0], [744.0, 851.0], [744.0, 1128.0], [718.0, 1128.0]]], "lines": ["身延の配布も今日から", "やってるらしくてな"]}, {"box": [622, 1248, 695, 1498], "vertical": true, "font_size": 35, "lines_coords": [[[661.0, 1250.0], [693.0, 1250.0], [693.0, 1498.0], [661.0, 1498.0]], [[622.0, 1248.0], [660.0, 1248.0], [660.0, 1316.0], [622.0, 1316.0]]], "lines": ["って事でまた明日", "なー"]}, {"box": [136, 1051, 210, 1123], "vertical": true, "font_size": 36, "lines_coords": [[[174.0, 1051.0], [210.0, 1051.0], [210.0, 1123.0], [174.0, 1123.0]], [[136.0, 1051.0], [172.0, 1051.0], [172.0, 1123.0], [136.0, 1123.0]]], "lines": ["なる", "ほど"]}, {"box": [183, 1306, 253, 1462], "vertical": true, "font_size": 31, "lines_coords": [[[215.0, 1306.0], [247.0, 1306.0], [253.0, 1462.0], [221.0, 1462.0]], [[183.0, 1306.0], [213.0, 1306.0], [213.0, 1361.0], [183.0, 1361.0]]], "lines": ["がんばって", "ねー"]}, {"box": [774, 1471, 842, 1612], "vertical": true, "font_size": 30, "lines_coords": [[[808.0, 1471.0], [841.0, 1471.0], [841.0, 1612.0], [808.0, 1612.0]], [[774.0, 1473.0], [800.0, 1473.0], [800.0, 1597.0], [774.0, 1597.0]]], "lines": ["あ分かり", "ましたー"]}], "img_path": "00009.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1106, 303, 1166, 583], "vertical": true, "font_size": 29, "lines_coords": [[[1140.0, 305.0], [1166.0, 305.0], [1166.0, 583.0], [1140.0, 583.0]], [[1106.0, 303.0], [1138.0, 303.0], [1138.0, 506.0], [1106.0, 506.0]]], "lines": ["この辺りの桜ももうじき", "咲きそうですねぇ"]}, {"box": [151, 166, 218, 418], "vertical": true, "font_size": 26, "lines_coords": [[[187.0, 166.0], [213.0, 166.0], [213.0, 391.0], [187.0, 391.0]], [[151.0, 166.0], [178.0, 166.0], [180.0, 418.0], [153.0, 418.0]]], "lines": ["もうだいぶ暖かく", "なりましたもんねぇ"]}, {"box": [1141, 731, 1207, 971], "vertical": true, "font_size": 66, "lines_coords": [[[1141.0, 731.0], [1207.0, 731.0], [1207.0, 971.0], [1141.0, 971.0]]], "lines": ["花見酒：："]}, {"box": [1142, 1183, 1213, 1451], "vertical": true, "font_size": 32, "lines_coords": [[[1175.0, 1183.0], [1213.0, 1183.0], [1213.0, 1451.0], [1175.0, 1451.0]], [[1143.0, 1186.0], [1170.0, 1186.0], [1170.0, 1340.0], [1143.0, 1340.0]]], "lines": ["今脳内で酒飲んで", "ましたよね"]}, {"box": [526, 1175, 596, 1593], "vertical": true, "font_size": 26, "lines_coords": [[[566.0, 1175.0], [592.0, 1175.0], [592.0, 1590.0], [566.0, 1590.0]], [[526.0, 1177.0], [553.0, 1177.0], [553.0, 1485.0], [526.0, 1485.0]]], "lines": ["そうだ春休みに花見キャンプ", "やろうと思うんすけど"]}, {"box": [654, 1531, 721, 1751], "vertical": true, "font_size": 27, "lines_coords": [[[690.0, 1531.0], [718.0, 1531.0], [720.0, 1661.0], [691.0, 1661.0]], [[654.0, 1535.0], [680.0, 1535.0], [680.0, 1749.0], [654.0, 1749.0]]], "lines": ["そんな事", "ありませんよー"]}, {"box": [138, 1537, 206, 1753], "vertical": true, "font_size": 30, "lines_coords": [[[174.0, 1537.0], [206.0, 1537.0], [206.0, 1740.0], [174.0, 1740.0]], [[138.0, 1539.0], [165.0, 1539.0], [165.0, 1753.0], [138.0, 1753.0]]], "lines": ["先生いいとこ", "知りませんか？"]}], "img_path": "00010.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1147, 153, 1213, 464], "vertical": true, "font_size": 26, "lines_coords": [[[1181.0, 157.0], [1207.0, 157.0], [1207.0, 463.0], [1181.0, 463.0]]], "lines": ["お花見キャンプですが、"]}, {"box": [920, 211, 991, 495], "vertical": true, "font_size": 30, "lines_coords": [[[961.0, 213.0], [988.0, 213.0], [988.0, 399.0], [961.0, 399.0]], [[920.0, 211.0], [952.0, 211.0], [952.0, 495.0], [920.0, 495.0]]], "lines": ["桜の木がある", "キャンプ場と言えば、"]}, {"box": [210, 245, 280, 495], "vertical": true, "font_size": 29, "lines_coords": [[[243.0, 245.0], [275.0, 245.0], [275.0, 495.0], [243.0, 495.0]], [[210.0, 249.0], [236.0, 249.0], [236.0, 401.0], [210.0, 401.0]]], "lines": ["四尾連湖に田貫湖", "辺りですね"]}, {"box": [1145, 645, 1215, 891], "vertical": true, "font_size": 29, "lines_coords": [[[1183.0, 645.0], [1215.0, 645.0], [1215.0, 866.0], [1183.0, 866.0]], [[1147.0, 648.0], [1173.0, 648.0], [1173.0, 890.0], [1147.0, 890.0]]], "lines": ["どちらも花見で", "混雑しそうですが、"]}, {"box": [997, 735, 1068, 1016], "vertical": true, "font_size": 32, "lines_coords": [[[1036.0, 735.0], [1068.0, 735.0], [1068.0, 1014.0], [1036.0, 1014.0]], [[997.0, 735.0], [1029.0, 735.0], [1029.0, 1016.0], [997.0, 1016.0]]], "lines": ["やっぱりあの辺しか", "無さそうですよねー"]}, {"box": [279, 615, 378, 954], "vertical": true, "font_size": 28, "lines_coords": [[[348.0, 618.0], [375.0, 618.0], [375.0, 954.0], [348.0, 954.0]], [[309.0, 615.0], [341.0, 615.0], [345.0, 843.0], [313.0, 843.0]], [[279.0, 622.0], [305.0, 622.0], [305.0, 759.0], [279.0, 759.0]]], "lines": ["探せばあると思いますけど", "私の方でも調べて", "おきますね"]}, {"box": [148, 834, 182, 1004], "vertical": true, "font_size": 32, "lines_coords": [[[148.0, 834.0], [180.0, 834.0], [180.0, 1003.0], [148.0, 1003.0]]], "lines": ["頼みますー"]}, {"box": [1141, 1132, 1210, 1473], "vertical": true, "font_size": 30, "lines_coords": [[[1177.0, 1132.0], [1209.0, 1132.0], [1209.0, 1441.0], [1177.0, 1441.0]], [[1141.0, 1132.0], [1168.0, 1132.0], [1168.0, 1473.0], [1141.0, 1473.0]]], "lines": ["大垣さん配布場所まで", "あとどのくらいですか？"]}, {"box": [495, 1117, 560, 1368], "vertical": true, "font_size": 26, "lines_coords": [[[530.0, 1117.0], [555.0, 1117.0], [555.0, 1368.0], [530.0, 1368.0]], [[495.0, 1119.0], [521.0, 1119.0], [521.0, 1256.0], [495.0, 1256.0]]], "lines": ["今回は残っていると", "いいですね"]}, {"box": [648, 1471, 720, 1753], "vertical": true, "font_size": 33, "lines_coords": [[[686.0, 1473.0], [720.0, 1473.0], [720.0, 1601.0], [686.0, 1601.0]], [[648.0, 1471.0], [680.0, 1471.0], [680.0, 1753.0], [648.0, 1753.0]]], "lines": ["えーっと", "あと１０時くらいっス"]}, {"box": [136, 1486, 234, 1757], "vertical": true, "font_size": 26, "lines_coords": [[[206.0, 1488.0], [232.0, 1488.0], [232.0, 1708.0], [206.0, 1708.0]], [[170.0, 1486.0], [196.0, 1486.0], [196.0, 1736.0], [170.0, 1736.0]], [[136.0, 1486.0], [163.0, 1486.0], [163.0, 1653.0], [136.0, 1653.0]]], "lines": ["だといいですけど", "あんま期待しないで", "行きましょう"]}], "img_path": "00011.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1132, 165, 1254, 808], "vertical": true, "font_size": 118, "lines_coords": [[[1136.0, 172.0], [1254.0, 172.0], [1250.0, 616.0], [1132.0, 616.0]]], "lines": ["全っ然残っ"]}, {"box": [1211, 1100, 1253, 1365], "vertical": true, "font_size": 37, "lines_coords": [[[1211.0, 1100.0], [1248.0, 1100.0], [1252.0, 1365.0], [1215.0, 1365.0]]], "lines": ["何だこの差は？"]}, {"box": [163, 1288, 271, 1509], "vertical": true, "font_size": 30, "lines_coords": [[[238.0, 1288.0], [271.0, 1288.0], [268.0, 1462.0], [234.0, 1462.0]], [[198.0, 1291.0], [230.0, 1291.0], [230.0, 1509.0], [198.0, 1509.0]], [[163.0, 1291.0], [189.0, 1291.0], [189.0, 1509.0], [163.0, 1509.0]]], "lines": ["そそっすね", "ガッツリ貰って", "行きましょう！！"]}, {"box": [774, 1438, 872, 1770], "vertical": true, "font_size": 26, "lines_coords": [[[843.0, 1440.0], [870.0, 1440.0], [870.0, 1689.0], [843.0, 1689.0]], [[808.0, 1438.0], [834.0, 1438.0], [834.0, 1770.0], [808.0, 1770.0]], [[774.0, 1438.0], [800.0, 1438.0], [800.0, 1635.0], [774.0, 1635.0]]], "lines": ["こないだの配布場は", "薪が主食のモンスターでも", "出没したんか！？"]}, {"box": [618, 1444, 687, 1785], "vertical": true, "font_size": 30, "lines_coords": [[[654.0, 1447.0], [686.0, 1447.0], [686.0, 1665.0], [654.0, 1665.0]], [[618.0, 1447.0], [645.0, 1447.0], [645.0, 1785.0], [618.0, 1785.0]]], "lines": ["でも残っていて", "良かったじゃないですか"]}], "img_path": "00012.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1126, 161, 1199, 414], "vertical": true, "font_size": 30, "lines_coords": [[[1166.0, 161.0], [1198.0, 161.0], [1196.0, 414.0], [1164.0, 414.0]], [[1130.0, 168.0], [1158.0, 168.0], [1155.0, 311.0], [1126.0, 311.0]]], "lines": ["薪の配布について", "〈おさらい〉"]}, {"box": [955, 142, 1090, 482], "vertical": true, "font_size": 40, "lines_coords": [[[1046.0, 144.0], [1085.0, 144.0], [1089.0, 425.0], [1050.0, 425.0]], [[1006.0, 142.0], [1046.0, 142.0], [1042.0, 318.0], [1003.0, 318.0]], [[961.0, 144.0], [1001.0, 144.0], [1001.0, 481.0], [961.0, 481.0]]], "lines": ["河川の岸や中州に", "伸びた木を", "そのままにしておくと"]}, {"box": [595, 132, 689, 153], "vertical": false, "font_size": 21, "lines_coords": [[[595.0, 132.0], [689.0, 132.0], [689.0, 153.0], [595.0, 153.0]]], "lines": ["キャー！"]}, {"box": [146, 142, 313, 489], "vertical": true, "font_size": 36, "lines_coords": [[[271.0, 142.0], [309.0, 142.0], [309.0, 489.0], [271.0, 489.0]], [[232.0, 146.0], [264.0, 146.0], [264.0, 418.0], [232.0, 418.0]], [[187.0, 144.0], [225.0, 144.0], [225.0, 455.0], [187.0, 455.0]], [[146.0, 142.0], [180.0, 142.0], [180.0, 281.0], [146.0, 281.0]]], "lines": ["台風などで増水した時", "川の流れが変わり、", "氾濫してしまう事が", "あるので"]}, {"box": [1126, 546, 1212, 1037], "vertical": true, "font_size": 36, "lines_coords": [[[1170.0, 547.0], [1207.0, 547.0], [1209.0, 1035.0], [1171.0, 1035.0]], [[1126.0, 547.0], [1160.0, 547.0], [1162.0, 706.0], [1128.0, 706.0]]], "lines": ["毎年定期的に伐採する必要が", "あります。"]}, {"box": [560, 541, 651, 1111], "vertical": true, "font_size": 40, "lines_coords": [[[605.0, 541.0], [648.0, 541.0], [648.0, 1111.0], [605.0, 1111.0]], [[562.0, 545.0], [600.0, 545.0], [600.0, 851.0], [562.0, 851.0]]], "lines": ["しかしその伐採本を処分するにも", "お金がかかるので"]}, {"box": [281, 600, 523, 860], "vertical": true, "font_size": 225, "lines_coords": [[[281.0, 615.0], [506.0, 600.0], [523.0, 845.0], [298.0, 860.0]]], "lines": ["ご自由にお持ち帰り下さい。"]}, {"box": [129, 542, 264, 1008], "vertical": true, "font_size": 39, "lines_coords": [[[221.0, 545.0], [260.0, 545.0], [260.0, 808.0], [221.0, 808.0]], [[176.0, 545.0], [215.0, 545.0], [215.0, 960.0], [176.0, 960.0]], [[129.0, 545.0], [168.0, 545.0], [168.0, 1005.0], [129.0, 1005.0]]], "lines": ["経費削減のため", "家庭で消費する薪として", "無料配布をしているのです。"]}, {"box": [185, 1211, 262, 1451], "vertical": true, "font_size": 32, "lines_coords": [[[228.0, 1211.0], [260.0, 1211.0], [260.0, 1415.0], [228.0, 1415.0]], [[185.0, 1215.0], [217.0, 1215.0], [217.0, 1451.0], [185.0, 1451.0]]], "lines": ["これは完全に", "プロ向けっすね"]}, {"box": [1081, 1181, 1205, 1771], "vertical": true, "font_size": 40, "lines_coords": [[[1166.0, 1183.0], [1203.0, 1183.0], [1201.0, 1676.0], [1164.0, 1676.0]], [[1117.0, 1181.0], [1162.0, 1181.0], [1166.0, 1771.0], [1121.0, 1771.0]], [[1081.0, 1181.0], [1119.0, 1181.0], [1119.0, 1511.0], [1081.0, 1511.0]]], "lines": ["更なる経費削減のため現在では", "伐採従業から持ち帰りまでできる方の", "公募も行っています。"]}], "img_path": "00013.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1121, 133, 1218, 502], "vertical": true, "font_size": 29, "lines_coords": [[[1190.0, 135.0], [1216.0, 135.0], [1216.0, 502.0], [1190.0, 502.0]], [[1155.0, 133.0], [1181.0, 133.0], [1181.0, 451.0], [1155.0, 451.0]], [[1121.0, 133.0], [1155.0, 133.0], [1155.0, 217.0], [1121.0, 217.0]]], "lines": ["以前は伐採木をウッドチップに", "加工したりもやっていたん", "ですが"]}, {"box": [582, 146, 685, 595], "vertical": true, "font_size": 30, "lines_coords": [[[652.0, 146.0], [684.0, 146.0], [684.0, 534.0], [652.0, 534.0]], [[615.0, 146.0], [646.0, 146.0], [648.0, 476.0], [616.0, 476.0]], [[583.0, 148.0], [609.0, 148.0], [609.0, 590.0], [583.0, 590.0]]], "lines": ["今の無料配布に切り替えた所", "皆さん喜んで持ち帰って", "下さるので助かっているんですよ"]}, {"box": [753, 465, 782, 757], "vertical": true, "font_size": 25, "lines_coords": [[[753.0, 465.0], [778.0, 465.0], [778.0, 757.0], [753.0, 757.0]]], "lines": ["まぁコストがかかって．．．"]}, {"box": [140, 405, 204, 768], "vertical": true, "font_size": 26, "lines_coords": [[[174.0, 405.0], [200.0, 405.0], [202.0, 656.0], [176.0, 656.0]], [[140.0, 406.0], [166.0, 406.0], [166.0, 768.0], [140.0, 768.0]]], "lines": ["こちらも部活で使う", "薪が頂けて非常に助かります。"]}, {"box": [183, 870, 258, 1042], "vertical": true, "font_size": 32, "lines_coords": [[[223.0, 870.0], [255.0, 870.0], [255.0, 1040.0], [223.0, 1040.0]], [[183.0, 870.0], [215.0, 870.0], [215.0, 1042.0], [183.0, 1042.0]]], "lines": ["ありがとう", "ございます"]}, {"box": [999, 821, 1134, 1126], "vertical": true, "font_size": 28, "lines_coords": [[[1102.0, 821.0], [1134.0, 821.0], [1134.0, 1074.0], [1102.0, 1074.0]], [[1068.0, 823.0], [1095.0, 823.0], [1095.0, 1074.0], [1068.0, 1074.0]], [[1035.0, 823.0], [1061.0, 823.0], [1061.0, 1102.0], [1035.0, 1102.0]], [[999.0, 823.0], [1025.0, 823.0], [1025.0, 1126.0], [999.0, 1126.0]]], "lines": ["薪はだいたい２ｍに", "切り揃えてあるんで", "お一人軽トラー台分を", "目安に持ち帰って下さい"]}, {"box": [1079, 1237, 1186, 1546], "vertical": true, "font_size": 30, "lines_coords": [[[1153.0, 1237.0], [1186.0, 1237.0], [1186.0, 1361.0], [1153.0, 1361.0]], [[1113.0, 1237.0], [1145.0, 1237.0], [1145.0, 1546.0], [1113.0, 1546.0]], [[1080.0, 1239.0], [1106.0, 1239.0], [1106.0, 1515.0], [1080.0, 1515.0]]], "lines": ["２ｍって", "軽トラの荷台の長さに", "合わせてあるんすね"]}, {"box": [457, 1470, 525, 1691], "vertical": true, "font_size": 29, "lines_coords": [[[493.0, 1470.0], [525.0, 1470.0], [525.0, 1691.0], [493.0, 1691.0]], [[457.0, 1475.0], [483.0, 1475.0], [483.0, 1657.0], [457.0, 1657.0]]], "lines": ["どうりで軽トラ", "だらけな訳だ"]}], "img_path": "00014.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1115, 73, 1187, 450], "vertical": true, "font_size": 32, "lines_coords": [[[1153.0, 75.0], [1185.0, 75.0], [1185.0, 448.0], [1153.0, 448.0]], [[1115.0, 73.0], [1147.0, 73.0], [1147.0, 450.0], [1115.0, 450.0]]], "lines": ["私の車は後部座席を倒して", "長さ１ｍちょっとですから"]}, {"box": [251, 138, 324, 450], "vertical": true, "font_size": 32, "lines_coords": [[[292.0, 140.0], [324.0, 140.0], [324.0, 450.0], [292.0, 450.0]], [[251.0, 138.0], [288.0, 138.0], [288.0, 361.0], [251.0, 361.0]]], "lines": ["そんじゃ二つに切って", "短くしましょう"]}, {"box": [166, 281, 236, 564], "vertical": true, "font_size": 32, "lines_coords": [[[204.0, 281.0], [236.0, 281.0], [236.0, 564.0], [204.0, 564.0]], [[166.0, 283.0], [193.0, 283.0], [193.0, 528.0], [166.0, 528.0]]], "lines": ["ノコギリもちゃんと", "持って来てますし"]}, {"box": [961, 387, 1033, 609], "vertical": true, "font_size": 32, "lines_coords": [[[1001.0, 388.0], [1033.0, 388.0], [1033.0, 577.0], [1001.0, 577.0]], [[961.0, 388.0], [993.0, 388.0], [993.0, 609.0], [961.0, 609.0]]], "lines": ["そのままでは", "入りませんね．．．"]}, {"box": [1085, 731, 1209, 1108], "vertical": true, "font_size": 36, "lines_coords": [[[1171.0, 731.0], [1209.0, 731.0], [1209.0, 1108.0], [1171.0, 1108.0]], [[1130.0, 731.0], [1162.0, 731.0], [1162.0, 903.0], [1130.0, 903.0]], [[1085.0, 731.0], [1123.0, 731.0], [1123.0, 1006.0], [1085.0, 1006.0]]], "lines": ["ノコギリで木を切る時は", "手で木材を", "しっかり押さえて"]}, {"box": [506, 727, 628, 1036], "vertical": true, "font_size": 34, "lines_coords": [[[590.0, 731.0], [622.0, 731.0], [622.0, 971.0], [590.0, 971.0]], [[547.0, 727.0], [586.0, 727.0], [583.0, 900.0], [543.0, 900.0]], [[506.0, 731.0], [538.0, 731.0], [538.0, 1036.0], [506.0, 1036.0]]], "lines": ["刃を斜めに構え", "上から下へ", "引っ張るようにして"]}], "img_path": "00015.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1063, 948, 1132, 1201], "vertical": true, "font_size": 32, "lines_coords": [[[1098.0, 950.0], [1130.0, 950.0], [1130.0, 1123.0], [1098.0, 1123.0]], [[1063.0, 948.0], [1095.0, 948.0], [1095.0, 1201.0], [1063.0, 1201.0]]], "lines": ["お大垣さん", "他にノコギリは．．．"]}, {"box": [194, 954, 260, 1142], "vertical": true, "font_size": 32, "lines_coords": [[[223.0, 954.0], [255.0, 954.0], [258.0, 1141.0], [226.0, 1141.0]]], "lines": ["これだけっす"]}], "img_path": "00016.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1068, 166, 1143, 324], "vertical": true, "font_size": 32, "lines_coords": [[[1110.0, 170.0], [1143.0, 170.0], [1143.0, 294.0], [1110.0, 294.0]], [[1072.0, 166.0], [1104.0, 166.0], [1100.0, 324.0], [1068.0, 324.0]]], "lines": ["モシモシ", "鳥羽先生？"]}, {"box": [811, 159, 921, 487], "vertical": true, "font_size": 30, "lines_coords": [[[892.0, 163.0], [918.0, 163.0], [918.0, 487.0], [892.0, 487.0]], [[851.0, 159.0], [883.0, 159.0], [883.0, 440.0], [851.0, 440.0]], [[811.0, 159.0], [843.0, 159.0], [843.0, 412.0], [811.0, 412.0]]], "lines": ["あははそういう事なら", "学校の軽トラ乗って", "行きましょうか？"]}, {"box": [1111, 727, 1183, 1010], "vertical": true, "font_size": 32, "lines_coords": [[[1151.0, 731.0], [1183.0, 731.0], [1183.0, 856.0], [1151.0, 856.0]], [[1113.0, 727.0], [1145.0, 727.0], [1143.0, 1010.0], [1111.0, 1010.0]]], "lines": ["大町先生", "どうされましたか？"]}, {"box": [661, 725, 764, 1005], "vertical": true, "font_size": 29, "lines_coords": [[[735.0, 725.0], [761.0, 725.0], [761.0, 948.0], [735.0, 948.0]], [[701.0, 725.0], [727.0, 725.0], [727.0, 1005.0], [701.0, 1005.0]], [[661.0, 725.0], [695.0, 725.0], [695.0, 811.0], [661.0, 811.0]]], "lines": ["今学校の軽トラが", "どうのって聞こえたん", "ですが"]}, {"box": [177, 393, 246, 607], "vertical": true, "font_size": 29, "lines_coords": [[[213.0, 395.0], [245.0, 395.0], [245.0, 519.0], [213.0, 519.0]], [[178.0, 393.0], [204.0, 393.0], [204.0, 607.0], [178.0, 607.0]]], "lines": ["いえいえ", "全然いいですよ"]}, {"box": [234, 733, 267, 940], "vertical": true, "font_size": 32, "lines_coords": [[[234.0, 733.0], [266.0, 733.0], [266.0, 939.0], [234.0, 939.0]]], "lines": ["あぁ教頭先生"]}, {"box": [1065, 1226, 1173, 1601], "vertical": true, "font_size": 30, "lines_coords": [[[1140.0, 1228.0], [1171.0, 1228.0], [1171.0, 1601.0], [1140.0, 1601.0]], [[1100.0, 1226.0], [1132.0, 1226.0], [1132.0, 1571.0], [1100.0, 1571.0]], [[1065.0, 1228.0], [1091.0, 1228.0], [1091.0, 1475.0], [1065.0, 1475.0]]], "lines": ["鳥羽先生が今生徒と一緒に", "薪の無料配布に行ってる", "らしいんですけど"]}, {"box": [179, 1299, 289, 1738], "vertical": true, "font_size": 31, "lines_coords": [[[255.0, 1301.0], [286.0, 1301.0], [286.0, 1676.0], [255.0, 1676.0]], [[215.0, 1299.0], [249.0, 1299.0], [251.0, 1738.0], [217.0, 1738.0]], [[181.0, 1305.0], [208.0, 1305.0], [208.0, 1674.0], [181.0, 1674.0]]], "lines": ["ノコギリが折れて薪を車に", "積めなくなっちゃったみたいで", "何かいい方法は無いかって"]}], "img_path": "00017.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1051, 140, 1196, 583], "vertical": true, "font_size": 28, "lines_coords": [[[1166.0, 140.0], [1192.0, 140.0], [1194.0, 376.0], [1168.0, 376.0]], [[1130.0, 142.0], [1156.0, 142.0], [1156.0, 465.0], [1130.0, 465.0]], [[1093.0, 140.0], [1119.0, 140.0], [1119.0, 583.0], [1093.0, 583.0]], [[1055.0, 142.0], [1087.0, 142.0], [1083.0, 466.0], [1051.0, 466.0]]], "lines": ["あたしもちょうど", "手が空いた所だったんで", "一軽トラで助けに行きましょうか」", "って話していたんですよ"]}, {"box": [374, 265, 413, 568], "vertical": true, "font_size": 37, "lines_coords": [[[375.0, 266.0], [412.0, 266.0], [412.0, 568.0], [375.0, 568.0]]], "lines": ["薪の配布ですか．．．"]}, {"box": [549, 1188, 620, 1501], "vertical": true, "font_size": 30, "lines_coords": [[[586.0, 1188.0], [618.0, 1188.0], [618.0, 1470.0], [586.0, 1470.0]], [[551.0, 1192.0], [579.0, 1192.0], [577.0, 1498.0], [549.0, 1498.0]]], "lines": ["すみません大町先生", "お手数をおかけして："]}, {"box": [680, 1546, 813, 1770], "vertical": true, "font_size": 40, "lines_coords": [[[774.0, 1546.0], [813.0, 1546.0], [810.0, 1753.0], [770.0, 1753.0]], [[723.0, 1546.0], [768.0, 1546.0], [768.0, 1738.0], [723.0, 1738.0]], [[684.0, 1548.0], [718.0, 1548.0], [714.0, 1770.0], [680.0, 1770.0]]], "lines": ["あ大町先生", "来てくれた", "みたいっすよ"]}], "img_path": "00018.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1066, 352, 1158, 543], "vertical": true, "font_size": 42, "lines_coords": [[[1113.0, 352.0], [1158.0, 352.0], [1158.0, 433.0], [1113.0, 433.0]], [[1066.0, 354.0], [1104.0, 354.0], [1104.0, 543.0], [1066.0, 543.0]]], "lines": ["きょ", "教頭先生？"]}, {"box": [448, 346, 480, 448], "vertical": true, "font_size": 32, "lines_coords": [[[448.0, 346.0], [480.0, 346.0], [480.0, 448.0], [448.0, 448.0]]], "lines": ["どうも"]}, {"box": [1138, 684, 1208, 961], "vertical": true, "font_size": 29, "lines_coords": [[[1175.0, 684.0], [1207.0, 684.0], [1205.0, 961.0], [1173.0, 961.0]], [[1138.0, 684.0], [1164.0, 684.0], [1164.0, 931.0], [1138.0, 931.0]]], "lines": ["てっきり大町先生が", "来られるのがと．．．"]}, {"box": [590, 685, 668, 1029], "vertical": true, "font_size": 32, "lines_coords": [[[630.0, 688.0], [661.0, 688.0], [661.0, 907.0], [630.0, 907.0]], [[590.0, 686.0], [622.0, 686.0], [622.0, 1029.0], [590.0, 1029.0]]], "lines": ["薪を玉切りして", "学校まで運ぶんですよね"]}, {"box": [1021, 1233, 1139, 1576], "vertical": true, "font_size": 34, "lines_coords": [[[1106.0, 1235.0], [1138.0, 1235.0], [1138.0, 1458.0], [1106.0, 1458.0]], [[1059.0, 1233.0], [1096.0, 1233.0], [1096.0, 1576.0], [1059.0, 1576.0]], [[1021.0, 1235.0], [1053.0, 1235.0], [1053.0, 1509.0], [1021.0, 1509.0]]], "lines": ["私こう見えて", "チェーンソーの扱いに", "慣れていますので"]}, {"box": [125, 1848, 545, 1875], "vertical": false, "font_size": 27, "lines_coords": [[[125.0, 1848.0], [545.0, 1848.0], [545.0, 1875.0], [125.0, 1875.0]]], "lines": ["淡一定の大きさに切り分ける事"]}], "img_path": "00019.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [198, 603, 247, 729], "vertical": true, "font_size": 46, "lines_coords": [[[198.0, 603.0], [247.0, 603.0], [247.0, 729.0], [198.0, 729.0]]], "lines": ["おおー"]}, {"box": [148, 663, 191, 735], "vertical": true, "font_size": 46, "lines_coords": [[[148.0, 663.0], [191.0, 663.0], [191.0, 735.0], [148.0, 735.0]]], "lines": ["ーっ"]}, {"box": [1111, 950, 1182, 1326], "vertical": true, "font_size": 30, "lines_coords": [[[1149.0, 950.0], [1181.0, 950.0], [1181.0, 1267.0], [1149.0, 1267.0]], [[1113.0, 954.0], [1140.0, 954.0], [1140.0, 1323.0], [1113.0, 1323.0]]], "lines": ["どんどん切りますので", "荷台に積んでいって下さい"]}, {"box": [523, 1147, 601, 1425], "vertical": true, "font_size": 36, "lines_coords": [[[558.0, 1147.0], [598.0, 1147.0], [601.0, 1425.0], [562.0, 1425.0]], [[523.0, 1149.0], [555.0, 1149.0], [556.0, 1387.0], [525.0, 1387.0]]], "lines": ["教頭先生めっちゃ", "慣れてますねぇ"]}, {"box": [737, 1541, 778, 1734], "vertical": true, "font_size": 40, "lines_coords": [[[738.0, 1541.0], [778.0, 1541.0], [778.0, 1734.0], [738.0, 1734.0]]], "lines": ["あはい！！"]}], "img_path": "00020.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1138, 155, 1202, 519], "vertical": true, "font_size": 26, "lines_coords": [[[1173.0, 155.0], [1198.0, 155.0], [1198.0, 519.0], [1173.0, 519.0]], [[1138.0, 155.0], [1164.0, 155.0], [1164.0, 491.0], [1138.0, 491.0]]], "lines": ["自宅に薪ストーブがあるので", "薪作りによく使うんですよ"]}, {"box": [735, 367, 768, 588], "vertical": true, "font_size": 31, "lines_coords": [[[735.0, 367.0], [766.0, 367.0], [766.0, 588.0], [735.0, 588.0]]], "lines": ["あぁーそれで"]}, {"box": [123, 337, 232, 586], "vertical": true, "font_size": 28, "lines_coords": [[[198.0, 337.0], [230.0, 337.0], [230.0, 586.0], [198.0, 586.0]], [[163.0, 339.0], [189.0, 339.0], [189.0, 583.0], [163.0, 583.0]], [[123.0, 339.0], [150.0, 339.0], [150.0, 461.0], [123.0, 461.0]]], "lines": ["私もこの薪配布は", "毎年楽しみにして", "いまして"]}, {"box": [1122, 742, 1200, 1086], "vertical": true, "font_size": 35, "lines_coords": [[[1162.0, 742.0], [1200.0, 742.0], [1200.0, 1051.0], [1162.0, 1051.0]], [[1123.0, 742.0], [1155.0, 742.0], [1155.0, 1085.0], [1123.0, 1085.0]]], "lines": ["今年も伐採作業から", "参加させて頂きました"]}, {"box": [1126, 1290, 1211, 1552], "vertical": true, "font_size": 36, "lines_coords": [[[1173.0, 1290.0], [1211.0, 1290.0], [1211.0, 1552.0], [1173.0, 1552.0]], [[1128.0, 1291.0], [1162.0, 1291.0], [1160.0, 1552.0], [1126.0, 1552.0]]], "lines": ["どっさりゲット", "できましたねー"]}, {"box": [165, 736, 254, 1203], "vertical": true, "font_size": 39, "lines_coords": [[