ッツリ食って来たんじゃ", "ないのかよ"]}, {"box": [526, 657, 622, 1055], "vertical": true, "font_size": 25, "lines_coords": [[[594.0, 663.0], [620.0, 663.0], [620.0, 937.0], [594.0, 937.0]], [[558.0, 660.0], [583.0, 660.0], [583.0, 885.0], [558.0, 885.0]], [[526.0, 663.0], [551.0, 663.0], [551.0, 1055.0], [526.0, 1055.0]]], "lines": ["こんな時間にカレーの", "話なんてされたら", "お腹鳴るに決まってるじゃんー"]}, {"box": [253, 703, 315, 982], "vertical": true, "font_size": 26, "lines_coords": [[[288.0, 703.0], [315.0, 703.0], [315.0, 841.0], [288.0, 841.0]], [[253.0, 703.0], [279.0, 703.0], [279.0, 982.0], [253.0, 982.0]]], "lines": ["めしテロは", "犯罪なんだからねっ！！"]}, {"box": [792, 1042, 855, 1237], "vertical": true, "font_size": 26, "lines_coords": [[[826.0, 1042.0], [853.0, 1042.0], [853.0, 1235.0], [826.0, 1235.0]], [[793.0, 1042.0], [817.0, 1042.0], [817.0, 1237.0], [793.0, 1237.0]]], "lines": ["だって食べたの", "先週の事だしー"]}, {"box": [178, 1306, 405, 1333], "vertical": false, "font_size": 27, "lines_coords": [[[178.0, 1306.0], [405.0, 1306.0], [405.0, 1333.0], [178.0, 1333.0]]], "lines": ["淡現在午後４時"]}, {"box": [965, 1458, 1155, 1745], "vertical": true, "font_size": 34, "lines_coords": [[[1123.0, 1460.0], [1155.0, 1460.0], [1155.0, 1650.0], [1123.0, 1650.0]], [[1083.0, 1462.0], [1117.0, 1462.0], [1113.0, 1681.0], [1080.0, 1681.0]], [[1046.0, 1462.0], [1078.0, 1462.0], [1078.0, 1711.0], [1046.0, 1711.0]], [[1006.0, 1462.0], [1038.0, 1462.0], [1038.0, 1648.0], [1006.0, 1648.0]], [[965.0, 1458.0], [1003.0, 1458.0], [1003.0, 1745.0], [965.0, 1745.0]]], "lines": ["今日は帰りに", "コンビニで絶対", "フライドチキンと", "サンドイッチ", "買ってくもんねっ！！"]}, {"box": [185, 1578, 217, 1702], "vertical": true, "font_size": 32, "lines_coords": [[[185.0, 1578.0], [217.0, 1578.0], [217.0, 1702.0], [185.0, 1702.0]]], "lines": ["はいはい"]}], "img_path": "00044.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1106, 123, 1183, 267], "vertical": true, "font_size": 24, "lines_coords": [[[1151.0, 123.0], [1183.0, 123.0], [1183.0, 170.0], [1151.0, 170.0]], [[1132.0, 127.0], [1153.0, 127.0], [1153.0, 266.0], [1132.0, 266.0]], [[1106.0, 125.0], [1126.0, 125.0], [1126.0, 225.0], [1106.0, 225.0]]], "lines": ["いや", "ホットドッグも", "捨てがたい"]}, {"box": [862, 176, 926, 346], "vertical": true, "font_size": 29, "lines_coords": [[[894.0, 176.0], [926.0, 176.0], [926.0, 292.0], [894.0, 292.0]], [[862.0, 176.0], [888.0, 176.0], [888.0, 346.0], [862.0, 346.0]]], "lines": ["この先は", "どうすんだ？"]}, {"box": [545, 140, 654, 305], "vertical": true, "font_size": 24, "lines_coords": [[[628.0, 142.0], [654.0, 142.0], [654.0, 290.0], [628.0, 290.0]], [[600.0, 140.0], [626.0, 140.0], [626.0, 283.0], [600.0, 283.0]], [[571.0, 140.0], [596.0, 140.0], [596.0, 305.0], [571.0, 305.0]], [[545.0, 142.0], [566.0, 142.0], [566.0, 279.0], [545.0, 279.0]]], "lines": ["あそういえば", "おにぎり１００円", "キャンペーンが", "やってたっけ"]}, {"box": [1033, 736, 1185, 1023], "vertical": true, "font_size": 33, "lines_coords": [[[1153.0, 740.0], [1185.0, 740.0], [1185.0, 960.0], [1153.0, 960.0]], [[1113.0, 742.0], [1145.0, 742.0], [1145.0, 960.0], [1113.0, 960.0]], [[1070.0, 740.0], [1108.0, 740.0], [1108.0, 1023.0], [1070.0, 1023.0]], [[1033.0, 736.0], [1065.0, 736.0], [1066.0, 1021.0], [1035.0, 1021.0]]], "lines": ["なでしこちゃん", "何食っとったか", "分からんようなるで", "少しだまっとってな"]}, {"box": [746, 382, 805, 609], "vertical": true, "font_size": 26, "lines_coords": [[[778.0, 382.0], [804.0, 382.0], [804.0, 585.0], [778.0, 585.0]], [[746.0, 382.0], [772.0, 382.0], [772.0, 609.0], [746.0, 609.0]]], "lines": ["次のバスに乗って", "更に北上して行くで"]}, {"box": [142, 412, 237, 635], "vertical": true, "font_size": 24, "lines_coords": [[[210.0, 412.0], [234.0, 412.0], [234.0, 635.0], [210.0, 635.0]], [[174.0, 412.0], [200.0, 412.0], [200.0, 635.0], [174.0, 635.0]], [[142.0, 414.0], [163.0, 414.0], [163.0, 551.0], [142.0, 551.0]]], "lines": ["そんで暫く行くと", "湖があるんやけど", "そこにー．．．"]}, {"box": [1070, 1402, 1200, 1743], "vertical": true, "font_size": 41, "lines_coords": [[[1160.0, 1406.0], [1200.0, 1406.0], [1200.0, 1644.0], [1160.0, 1644.0]], [[1119.0, 1404.0], [1156.0, 1404.0], [1158.0, 1743.0], [1121.0, 1743.0]], [[1070.0, 1402.0], [1115.0, 1402.0], [1121.0, 1728.0], [1076.0, 1728.0]]], "lines": ["そしてうちらは", "再びバスに乗り明野を", "後にしたのであった。"]}, {"box": [270, 1509, 301, 1548], "vertical": false, "font_size": 39, "lines_coords": [[[270.0, 1509.0], [301.0, 1509.0], [301.0, 1548.0], [270.0, 1548.0]]], "lines": ["．．．"]}], "img_path": "00045.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1110, 138, 1212, 592], "vertical": true, "font_size": 30, "lines_coords": [[[1179.0, 138.0], [1211.0, 138.0], [1211.0, 592.0], [1179.0, 592.0]], [[1143.0, 140.0], [1175.0, 140.0], [1175.0, 455.0], [1143.0, 455.0]], [[1110.0, 138.0], [1136.0, 138.0], [1136.0, 579.0], [1110.0, 579.0]]], "lines": ["ちなみに明野はひまわりでも有名で", "夏に来れば一面に広がる", "ひまわり畑を楽しむ事が出来ます。"]}, {"box": [230, 193, 287, 343], "vertical": true, "font_size": 26, "lines_coords": [[[260.0, 193.0], [286.0, 193.0], [286.0, 294.0], [260.0, 294.0]], [[230.0, 195.0], [255.0, 195.0], [255.0, 343.0], [230.0, 343.0]]], "lines": ["ひまわり", "キレイだねぃ"]}, {"box": [596, 1222, 678, 1469], "vertical": true, "font_size": 39, "lines_coords": [[[637.0, 1224.0], [676.0, 1224.0], [676.0, 1366.0], [637.0, 1366.0]], [[596.0, 1222.0], [635.0, 1222.0], [635.0, 1466.0], [596.0, 1466.0]]], "lines": ["明野から", "走ること約３０分"]}], "img_path": "00046.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1117, 150, 1233, 534], "vertical": true, "font_size": 56, "lines_coords": [[[1185.0, 155.0], [1231.0, 155.0], [1231.0, 386.0], [1185.0, 386.0]], [[1117.0, 150.0], [1183.0, 150.0], [1183.0, 534.0], [1117.0, 534.0]]], "lines": ["次の目的地", "みずがき湖に到着"]}, {"box": [176, 412, 275, 630], "vertical": true, "font_size": 45, "lines_coords": [[[225.0, 412.0], [270.0, 412.0], [273.0, 630.0], [228.0, 630.0]], [[176.0, 414.0], [221.0, 414.0], [221.0, 626.0], [176.0, 626.0]]], "lines": ["みずがき湖", "ついたーっ"]}, {"box": [1031, 892, 1114, 1125], "vertical": true, "font_size"