0]]], "lines": ["なんか先生の", "様子がおかしいよ？"]}, {"box": [1131, 1272, 1193, 1438], "vertical": true, "font_size": 25, "lines_coords": [[[1166.0, 1273.0], [1192.0, 1273.0], [1192.0, 1438.0], [1166.0, 1438.0]], [[1132.0, 1273.0], [1156.0, 1273.0], [1156.0, 1438.0], [1132.0, 1438.0]]], "lines": ["ていうか逆に", "気味が悪いで"]}, {"box": [817, 1282, 883, 1430], "vertical": true, "font_size": 30, "lines_coords": [[[856.0, 1286.0], [883.0, 1286.0], [883.0, 1402.0], [856.0, 1402.0]], [[817.0, 1282.0], [849.0, 1282.0], [849.0, 1430.0], [817.0, 1430.0]]], "lines": ["んじゃあ", "元に戻すか"]}, {"box": [705, 1343, 734, 1509], "vertical": true, "font_size": 26, "lines_coords": [[[705.0, 1344.0], [731.0, 1344.0], [731.0, 1509.0], [705.0, 1509.0]]], "lines": ["いつもの先生"]}, {"box": [189, 868, 327, 1192], "vertical": true, "font_size": 28, "lines_coords": [[[298.0, 871.0], [324.0, 871.0], [324.0, 1104.0], [298.0, 1104.0]], [[258.0, 868.0], [290.0, 868.0], [288.0, 1192.0], [256.0, 1192.0]], [[225.0, 868.0], [251.0, 868.0], [251.0, 1072.0], [225.0, 1072.0]], [[189.0, 868.0], [215.0, 868.0], [215.0, 1130.0], [189.0, 1130.0]]], "lines": ["いつもアレだから", "回想の時くらいは上品に", "酒を飲む先生は", "どうかと思ってなぁ"]}, {"box": [358, 1222, 506, 1320], "vertical": false, "font_size": 45, "lines_coords": [[[358.0, 1278.0], [489.0, 1222.0], [506.0, 1263.0], [375.0, 1320.0]]], "lines": ["お酒おい"]}, {"box": [178, 1376, 245, 1520], "vertical": true, "font_size": 64, "lines_coords": [[[178.0, 1378.0], [241.0, 1376.0], [245.0, 1518.0], [181.0, 1520.0]]], "lines": ["よし。"]}], "img_path": "00138.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [633, 172, 666, 476], "vertical": true, "font_size": 26, "lines_coords": [[[635.0, 172.0], [661.0, 172.0], [661.0, 476.0], [635.0, 476.0]]], "lines": ["これはこれでウマい。"]}, {"box": [836, 598, 1114, 663], "vertical": false, "font_size": 26, "lines_coords": [[[840.0, 598.0], [1113.0, 601.0], [1113.0, 628.0], [840.0, 624.0]], [[838.0, 633.0], [975.0, 637.0], [975.0, 663.0], [838.0, 660.0]]], "lines": ["ピザクラストを使った", "お好み焼き"]}, {"box": [1029, 748, 1163, 1085], "vertical": true, "font_size": 38, "lines_coords": [[[1123.0, 748.0], [1162.0, 748.0], [1162.0, 939.0], [1123.0, 939.0]], [[1074.0, 750.0], [1111.0, 750.0], [1111.0, 1085.0], [1074.0, 1085.0]], [[1029.0, 748.0], [1066.0, 748.0], [1066.0, 1012.0], [1029.0, 1012.0]]], "lines": ["けどピザが", "食いたかったんだよ", "あたしはーっ！！"]}, {"box": [744, 1134, 843, 1271], "vertical": true, "font_size": 99, "lines_coords": [[[744.0, 1134.0], [843.0, 1134.0], [843.0, 1271.0], [744.0, 1271.0]]], "lines": ["ほらまだ２枚"]}, {"box": [549, 1132, 638, 1434], "vertical": true, "font_size": 26, "lines_coords": [[[609.0, 1132.0], [635.0, 1132.0], [635.0, 1357.0], [609.0, 1357.0]], [[579.0, 1136.0], [605.0, 1136.0], [605.0, 1434.0], [579.0, 1434.0]], [[549.0, 1136.0], [575.0, 1136.0], [575.0, 1310.0], [549.0, 1310.0]]], "lines": ["次はキーマカレーと", "ソーセージでナンドッグに", "してみよっかー"]}, {"box": [183, 1196, 225, 1455], "vertical": true, "font_size": 40, "lines_coords": [[[183.0, 1196.0], [223.0, 1196.0], [223.0, 1455.0], [183.0, 1455.0]]], "lines": ["おいやめろ！！"]}, {"box": [1108, 1528, 1218, 1779], "vertical": true, "font_size": 32, "lines_coords": [[[1186.0, 1530.0], [1218.0, 1530.0], [1218.0, 1687.0], [1186.0, 1687.0]], [[1147.0, 1531.0], [1179.0, 1531.0], [1179.0, 1779.0], [1147.0, 1779.0]], [[1110.0, 1528.0], [1141.0, 1528.0], [1140.0, 1749.0], [1108.0, 1749.0]]], "lines": ["安心してよ", "このピザクラスト", "３枚入りだから"]}, {"box": [720, 1524, 808, 1718], "vertical": true, "font_size": 40, "lines_coords": [[[768.0, 1524.0], [808.0, 1524.0], [808.0, 1713.0], [768.0, 1713.0]]], "lines": ["まじで！！"]}, {"box": [718, 1564, 744, 1716], "vertical": true, "font_size": 26, "lines_coords": [[[718.0, 1567.0], [744.0, 1567.0], [744.0, 1676.0], [718.0, 1676.0]]], "lines": ["よかった！"]}, {"box": [382, 1501, 412, 1644], "vertical": true, "font_size": 26, "lines_coords": [[[384.0, 1501.0], [410.0, 1501.0], [410.0, 1616.0], [384.0, 1616.0]]], "lines": ["せやなー"]}], "img_path": "00139.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1178, 115, 1241, 369], "vertical": true, "font_size": 26, "lines_coords": [[[1213.0, 118.0], [1239.0, 118.0], [1239.0, 369.0], [1213.0, 369.0]], [[1179.0, 116.0], [1205.0, 116.0], [1205.0, 285.0], [1179.0, 285.0]]], "lines": ["フライパンを使った", "ビザの焼き方"]}, {"box": [877, 145, 1030, 378], "vertical": true, "font_size": 33, "lines_coords": [[[995.0, 148.0], [1027.0, 148.0], [1027.0, 337.0], [995.0, 337.0]], [[954.0, 148.0], [991.0, 148.0], [991.0, 337.0], [954.0, 337.0]], [[916.0, 146.0], [948.0, 146.0], [948.0, 369.0], [916.0, 369.0]], [[879.0, 148.0], [911.0, 148.0], [911.0, 376.0], [879.0, 376.0]]], "lines": ["まず大きめの", "フライパンに", "蓋をして強火で", "温めておきます。"]}, {"box": [590, 146, 675, 637], "vertical": true, "font_size": 42, "lines_coords": [[[630.0, 146.0], [675.0, 146.0], [673.0, 637.0], [628.0, 637.0]], [[590.0, 151.0], [628.0, 151.0], [628.0, 633.0], [590.0, 633.0]]], "lines": ["ピザクラストにはざっき作った", "トマトソースをたっぷりと塗り"]}, {"box": [1089, 751, 1211, 1131], "vertical": true, "font_size": 37, "lines_coords": [[[1173.0, 757.0], [1211.0, 757.0], [1211.0, 1123.0], [1173.0, 1123.0]], [[1130.0, 753.0], [1168.0, 753.0], [1168.0, 1078.0], [1130.0, 1078.0]], [[1089.0, 751.0], [1123.0, 751.0], [1123.0, 888.0], [1089.0, 888.0]]], "lines": ["一口大に切ったベーコン", "アスパラパプリカを", "散りばめ"]}, {"box": [138, 742, 259, 1155], "vertical": true, "font_size": 31, "lines_coords": [[[226.0, 746.0], [253.0, 746.0], [253.0, 1149.0], [226.0, 1149.0]], [[178.0, 742.0], [211.0, 742.0], [213.0, 1123.0], [180.0, 1123.0]], [[138.0, 746.0], [172.0, 746.0], [172.0, 888.0], [138.0, 888.0]]], "lines": ["深火が通りやすくするため", "具材は薄切りにするのが", "コツです。"]}, {"box": [138, 1216, 222, 1529], "vertical": true, "font_size": 36, "lines_coords": [[[181.0, 1220.0], [215.0, 1220.0], [217.0, 1526.0], [183.0, 1526.0]], [[138.0, 1218.0], [176.0, 1218.0], [176.0, 1496.0], [138.0, 1496.0]]], "lines": ["最後にビザチーズを", "振りかけましょう"]}, {"box": [1049, 1496, 1198, 1780], "vertical": true, "font_size": 31, "lines_coords": [[[1166.0, 1498.0], [1198.0, 1498.0], [1198.0, 1717.0], [1166.0, 1717.0]], [[1123.0, 1496.0], [1156.0, 1496.0], [1158.0, 1627.0], [1125.0, 1627.0]], [[1087.0, 1500.0], [1119.0, 1500.0], [1119.0, 1747.0], [1087.0, 1747.0]], [[1051.0, 1500.0], [1078.0, 1500.0], [1078.0, 1775.0], [1051.0, 1775.0]]], "lines": ["ざく切りにした", "トマトと", "バジルを乗せたら", "マヨネーズを一回し"]}], "img_path": "00140.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [866, 140, 1074, 421], "vertical": true, "font_size": 39, "lines_coords": [[[1035.0, 142.0], [1074.0, 142.0], [1074.0, 288.0], [1035.0, 288.0]], [[993.0, 144.0], [1031.0, 144.0], [1031.0, 421.0], [993.0, 421.0]], [[950.0, 146.0], [990.0, 146.0], [990.0, 421.0], [950.0, 421.0]], [[909.0, 140.0], [948.0, 140.0], [945.0, 352.0], [905.0, 352.0]], [[866.0, 142.0], [905.0, 142.0], [905.0, 384.0], [866.0, 384.0]]], "lines": ["蓋をして", "強火で温められた", "フライパンの中が", "「窯」の状態に", "なっているので"]}, {"box": [241, 138, 556, 365], "vertical": true, "font_size": 40, "lines_coords": [[[521.0, 144.0], [555.0, 144.0], [555.0, 303.0], [521.0, 303.0]], [[478.0, 142.0], [517.0, 142.0], [517.0, 337.0], [478.0, 337.0]], [[440.0, 142.0], [478.0, 142.0], [474.0, 333.0], [436.0, 333.0]], [[401.0, 140.0], [440.0, 140.0], [440.0, 365.0], [401.0, 365.0]], [[360.0, 140.0], [405.0, 140.0], [405.0, 307.0], [360.0, 307.0]], [[324.0, 140.0], [363.0, 140.0], [363.0, 335.0], [324.0, 335.0]], [[286.0, 144.0], [320.0, 144.0], [320.0, 301.0], [286.0, 301.0]], [[241.0, 138.0], [292.0, 138.0], [292.0, 230.0], [241.0, 230.0]]], "lines": ["中の熱気が", "逃げないよう", "蓋の隙間から", "オリーブオイル", "を軽く引き", "素早くピザを", "滑り込ませ", "ます。"]}, {"box": [772, 469, 1197, 628], "vertical": false, "font_size": 69, "lines_coords": [[[795.0, 536.0], [1171.0, 532.0], [1171.0, 601.0], [795.0, 605.0]]], "lines": ["いいのか、"]}, {"box": [436, 802, 678, 851], "vertical": false, "font_size": 38, "lines_coords": [[[436.0, 813.0], [676.0, 802.0], [678.0, 840.0], [438.0, 851.0]]], "lines": ["まずは、"]}, {"box": [371, 474, 420, 560], "vertical": false, "font_size": 86, "lines_coords": [[[371.0, 474.0], [420.0, 474.0], [420.0, 560.0], [371.0, 560.0]]], "lines": ["ササッ"]}, {"box": [1089, 826, 1203, 1179], "vertical": true, "font_size": 36, "lines_coords": [[[1168.0, 826.0], [1200.0, 826.0], [1203.0, 1021.0], [1171.0, 1021.0]], [[1126.0, 828.0], [1164.0, 828.0], [1164.0, 1179.0], [1126.0, 1179.0]], [[1089.0, 826.0], [1126.0, 826.0], [1128.0, 1179.0], [1091.0, 1179.0]]], "lines": ["あとは弱火で", "ピザチーズが溶けるまで", "じっくりと焼きましょう。"]}, {"box": [1076, 1274, 1183, 1612], "vertical": true, "font_size": 26, "lines_coords": [[[1155.0, 1275.0], [1181.0, 1275.0], [1181.0, 1584.0], [1155.0, 1584.0]], [[1115.0, 1276.0], [1141.0, 1276.0], [1141.0, 1612.0], [1115.0, 1612.0]], [[1078.0, 1275.0], [1104.0, 1275.0], [1104.0, 1582.0], [1078.0, 1582.0]]], "lines": ["ほほーフライバンでも", "こうすれば擬似ヒサ窯の", "状態になるって訳かぁ"]}, {"box": [164, 1417, 274, 1792], "vertical": true, "font_size": 31, "lines_coords": [[[238.0, 1417.0], [271.0, 1417.0], [273.0, 1758.0], [240.0, 1758.0]], [[202.0, 1419.0], [234.0, 1419.0], [234.0, 1792.0], [202.0, 1792.0]], [[166.0, 1419.0], [193.0, 1419.0], [193.0, 1696.0], [166.0, 1696.0]]], "lines": ["これならダッチオープン", "とかピザ黒がなくても一応、", "ヒザが焼けるんやで"]}], "img_path": "00141.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1036, 140, 1187, 453], "vertical": true, "font_size": 33, "lines_coords": [[[1153.0, 140.0], [1185.0, 140.0], [1185.0, 453.0], [1153.0, 453.0]], [[1111.0, 142.0], [1145.0, 142.0], [1145.0, 268.0], [1111.0, 268.0]], [[1072.0, 142.0], [1106.0, 142.0], [1108.0, 300.0], [1074.0, 300.0]], [[1036.0, 142.0], [1068.0, 142.0], [1068.0, 360.0], [1036.0, 360.0]]], "lines": ["ピザが焼き上がったら、", "仕上げに", "バーナーで", "焼き目をつけて"]}, {"box": [144, 275, 216, 465], "vertical": true, "font_size": 30, "lines_coords": [[[185.0, 281.0], [211.0, 281.0], [211.0, 463.0], [185.0, 463.0]], [[144.0, 275.0], [178.0, 275.0], [178.0, 375.0], [144.0, 375.0]]], "lines": ["おぉそんな物", "まで！！