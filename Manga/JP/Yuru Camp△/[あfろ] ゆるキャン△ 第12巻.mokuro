, 1280, 1203, 1657], "vertical": true, "font_size": 37, "lines_coords": [[[1166.0, 1282.0], [1203.0, 1282.0], [1203.0, 1655.0], [1166.0, 1655.0]], [[1115.0, 1280.0], [1153.0, 1280.0], [1158.0, 1657.0], [1121.0, 1657.0]]], "lines": ["アウトドアの食器って", "金属性が多いでしょ？"]}, {"box": [376, 1246, 463, 1755], "vertical": true, "font_size": 40, "lines_coords": [[[418.0, 1248.0], [461.0, 1248.0], [461.0, 1753.0], [418.0, 1753.0]], [[376.0, 1248.0], [414.0, 1248.0], [414.0, 1661.0], [376.0, 1661.0]]], "lines": ["私、金属の食器がこすれる音が", "ちょっと苦手なんだよね"]}], "img_path": "00173.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1115, 140, 1237, 540], "vertical": true, "font_size": 36, "lines_coords": [[[1198.0, 140.0], [1237.0, 140.0], [1237.0, 245.0], [1198.0, 245.0]], [[1158.0, 142.0], [1192.0, 142.0], [1190.0, 540.0], [1156.0, 540.0]], [[1117.0, 140.0], [1151.0, 140.0], [1149.0, 506.0], [1115.0, 506.0]]], "lines": ["リンは", "コッヘルに金属のフォーク", "使ってるけど平気なの？"]}, {"box": [140, 146, 212, 459], "vertical": true, "font_size": 32, "lines_coords": [[[180.0, 148.0], [211.0, 148.0], [211.0, 459.0], [180.0, 459.0]], [[140.0, 148.0], [172.0, 148.0], [172.0, 399.0], [140.0, 399.0]]], "lines": ["強くこすれないように", "気を使ってるかも"]}, {"box": [1066, 802, 1179, 1083], "vertical": true, "font_size": 34, "lines_coords": [[[1141.0, 802.0], [1179.0, 802.0], [1179.0, 993.0], [1141.0, 993.0]], [[1106.0, 802.0], [1138.0, 802.0], [1138.0, 1023.0], [1106.0, 1023.0]], [[1066.0, 802.0], [1098.0, 802.0], [1100.0, 1083.0], [1068.0, 1083.0]]], "lines": ["気になったり", "ならなかったり", "人それぞれだよねぇ"]}, {"box": [737, 441, 811, 678], "vertical": true, "font_size": 30, "lines_coords": [[[778.0, 442.0], [810.0, 442.0], [810.0, 678.0], [778.0, 678.0]], [[738.0, 442.0], [765.0, 442.0], [765.0, 645.0], [738.0, 645.0]]], "lines": ["私はあまり気に", "ならないかな"]}, {"box": [611, 339, 682, 676], "vertical": true, "font_size": 32, "lines_coords": [[[650.0, 339.0], [682.0, 339.0], [680.0, 676.0], [648.0, 676.0]], [[611.0, 339.0], [643.0, 339.0], [643.0, 590.0], [611.0, 590.0]]], "lines": ["でもコッヘルがテフロン", "加工されてるから"]}, {"box": [616, 796, 685, 1044], "vertical": true, "font_size": 30, "lines_coords": [[[652.0, 796.0], [684.0, 796.0], [684.0, 1044.0], [652.0, 1044.0]], [[616.0, 800.0], [643.0, 800.0], [643.0, 950.0], [616.0, 950.0]]], "lines": ["世の中には金属の", "スプーンと"]}, {"box": [155, 528, 197, 656], "vertical": true, "font_size": 41, "lines_coords": [[[155.0, 528.0], [196.0, 528.0], [196.0, 656.0], [155.0, 656.0]]], "lines": ["ふーん"]}, {"box": [148, 785, 212, 1117], "vertical": true, "font_size": 26, "lines_coords": [[[183.0, 787.0], [210.0, 787.0], [210.0, 1117.0], [183.0, 1117.0]], [[148.0, 785.0], [174.0, 785.0], [174.0, 1117.0], [148.0, 1117.0]]], "lines": ["陶器のお皿がこすれる音も", "苦手な人もいるらしいから"]}, {"box": [1112, 1209, 1220, 1552], "vertical": true, "font_size": 28, "lines_coords": [[[1188.0, 1209.0], [1220.0, 1209.0], [1220.0, 1398.0], [1188.0, 1398.0]], [[1153.0, 1213.0], [1179.0, 1213.0], [1179.0, 1520.0], [1153.0, 1520.0]], [[1113.0, 1211.0], [1140.0, 1211.0], [1140.0, 1552.0], [1113.0, 1552.0]]], "lines": ["そういう人は", "レストランとか行くの", "大変だろうなって思うよ。"]}, {"box": [145, 1453, 215, 1762], "vertical": true, "font_size": 29, "lines_coords": [[[180.0, 1453.0], [211.0, 1453.0], [215.0, 1625.0], [183.0, 1625.0]], [[146.0, 1455.0], [172.0, 1455.0], [172.0, 1762.0], [146.0, 1762.0]]], "lines": ["いやマジで", "大変な事になってるし、"]}], "img_path": "00174.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1134, 155, 1210, 463], "vertical": true, "font_size": 33, "lines_coords": [[[1173.0, 155.0], [1207.0, 155.0], [1209.0, 461.0], [1175.0, 461.0]], [[1134.0, 159.0], [1166.0, 159.0], [1166.0, 463.0], [1134.0, 463.0]]], "lines": ["この前リンちゃんに", "いたずらされたので"]}, {"box": [757, 73, 1200, 99], "vertical": false, "font_size": 26, "lines_coords": [[[757.0, 73.0], [1200.0, 73.0], [1200.0, 99.0], [757.0, 99.0]]], "lines": ["放課後１０６なでしこの仕返"]}, {"box": [553, 727, 637, 828], "vertical": true, "font_size": 45, "lines_coords": [[[588.0, 727.0], [637.0, 727.0], [637.0, 826.0], [588.0, 826.0]], [[553.0, 733.0], [594.0, 729.0], [601.0, 825.0], [560.0, 828.0]]], "lines": ["なんだ", "コレ！？"]}, {"box": [145, 368, 220, 639], "vertical": true, "font_size": 29, "lines_coords": [[[185.0, 369.0], [217.0, 369.0], [217.0, 639.0], [185.0, 639.0]], [[146.0, 369.0], [172.0, 369.0], [172.0, 540.0], [146.0, 540.0]]], "lines": ["仕返しをしようと", "思います！！"]}, {"box": [1164, 742, 1200, 1179], "vertical": true, "font_size": 32, "lines_coords": [[[1164.0, 742.0], [1196.0, 742.0], [1196.0, 1179.0], [1164.0, 1179.0]]], "lines": ["焚き火台の中のまつぼっくりが"]}, {"box": [420, 738, 495, 1183], "vertical": true, "font_size": 36, "lines_coords": [[[453.0, 738.0], [491.0, 738.0], [495.0, 1183.0], [457.0, 1183.0]], [[420.0, 742.0], [453.0, 742.0], [453.0, 896.0], [420.0, 896.0]]], "lines": ["アーティチョークになってたら、", "驚くぞーっ"]}, {"box": [547, 1271, 579, 1419], "vertical": true, "font_size": 32, "lines_coords": [[[547.0, 1271.0], [579.0, 1271.0], [579.0, 1419.0], [547.0, 1419.0]]], "lines": ["ここも！？"]}, {"box": [271, 1344, 405, 1393], "vertical": false, "font_size": 49, "lines_coords": [[[271.0, 1344.0], [405.0, 1344.0], [405.0, 1393.0], [271.0, 1393.0]]], "lines": ["ＨＡＧＩＭＯ"]}, {"box": [1169, 1276, 1203, 1612], "vertical": true, "font_size": 26, "lines_coords": [[[1170.0, 1276.0], [1196.0, 1276.0], [1196.0, 1612.0], [1170.0, 1612.0]]], "lines": ["うちには置いとらんで"]}, {"box": [675, 1498, 718, 1629], "vertical": true, "font_size": 40, "lines_coords": [[[675.0, 1498.0], [714.0, 1498.0], [718.0, 1629.0], [678.0, 1629.0]]], "lines": ["えっ！？"]}, {"box": [140, 1569, 206, 1724], "vertical": true, "font_size": 29, "lines_coords": [[[174.0, 1571.0], [206.0, 1571.0], [206.0, 1695.0], [174.0, 1695.0]], [[140.0, 1569.0], [166.0, 1569.0], [166.0, 1723.0], [140.0, 1723.0]]], "lines": ["ここにも", "ないーっ！！"]}], "img_path": "00175.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1134, 157, 1208, 465], "vertical": true, "font_size": 32, "lines_coords": [[[1173.0, 157.0], [1205.0, 157.0], [1205.0, 395.0], [1173.0, 395.0]], [[1134.0, 157.0], [1166.0, 157.0], [1166.0, 465.0], [1134.0, 465.0]]], "lines": ["ネット通販なら", "買えるんじゃない？"]}, {"box": [653, 163, 696, 375], "vertical": true, "font_size": 39, "lines_coords": [[[654.0, 166.0], [693.0, 166.0], [693.0, 375.0], [654.0, 375.0]]], "lines": ["届いたーっ"]}, {"box": [217, 174, 446, 255], "vertical": false, "font_size": 60, "lines_coords": [[[217.0, 195.0], [440.0, 174.0], [446.0, 234.0], [223.0, 255.0]]], "lines": ["＼ｃｉａｏ！／"]}, {"box": [778, 613, 826, 830], "vertical": true, "font_size": 45, "lines_coords": [[[778.0, 613.0], [823.0, 613.0], [826.0, 830.0], [781.0, 830.0]]], "lines": ["つうはん！！"]}, {"box": [135, 618, 221, 883], "vertical": true, "font_size": 38, "lines_coords": [[[178.0, 618.0], [217.0, 618.0], [221.0, 772.0], [181.0, 772.0]], [[135.0, 620.0], [172.0, 620.0], [172.0, 883.0], [135.0, 883.0]]], "lines": ["ちょっと", "高かったけど！！"]}, {"box": [701, 993, 773, 1335], "vertical": true, "font_size": 32, "lines_coords": [[[736.0, 995.0], [768.0, 995.0], [772.0, 1215.0], [740.0, 1215.0]], [[701.0, 993.0], [733.0, 993.0], [735.0, 1335.0], [703.0, 1335.0]]], "lines": ["珍しい食材だし", "どう調理しようかなーっ"]}, {"box": [530, 976, 600, 1224], "vertical": true, "font_size": 32, "lines_coords": [[[568.0, 976.0], [600.0, 976.0], [600.0, 1224.0], [568.0, 1224.0]], [[530.0, 978.0], [562.0, 978.0], [562.0, 1134.0], [530.0, 1134.0]]], "lines": ["生ハムと炒めるの", "おいしそー"]}, {"box": [421, 1040, 493, 1323], "vertical": true, "font_size": 32, "lines_coords": [[[457.0, 1040.0], [489.0, 1040.0], [493.0, 1261.0], [461.0, 1261.0]], [[421.0, 1042.0], [453.0, 1042.0], [453.0, 1323.0], [421.0, 1323.0]]], "lines": ["今度キャンプで", "作ってみよっかなー"]}, {"box": [129, 1381, 206, 1704], "vertical": true, "font_size": 36, "lines_coords": [[[166.0, 1381.0], [206.0, 1381.0], [206.0, 1704.0], [166.0, 1704.0]], [[129.0, 1383.0], [161.0, 1383.0], [161.0, 1657.0], [129.0, 1657.0]]], "lines": ["あれ？でも何でコレ", "買ったんだっけ？"]}], "img_path": "00176.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1139, 140, 1208, 639], "vertical": true, "font_size": 29, "lines_coords": [[[1175.0, 142.0], [1207.0, 142.0], [1207.0, 639.0], [1175.0, 639.0]], [[1140.0, 142.0], [1166.0, 142.0], [1166.0, 513.0], [1140.0, 513.0]]], "lines": ["山中湖がローストチキンに似ている", "というのは周知の事実だが、"]}, {"box": [691, 148, 760, 398], "vertical": true, "font_size": 26, "lines_coords": [[[731.0, 150.0], [757.0, 150.0], [757.0, 333.0], [731.0, 333.0]], [[691.0, 148.0], [718.0, 148.0], [718.0, 395.0], [691.0, 395.0]]], "lines": ["あきが勝手に", "言っとるだけやん"]}, {"box": [579, 148, 630, 523], "vertical": true, "font_size": 51, "lines_coords": [[[579.0, 148.0], [630.0, 148.0], [630.0, 523.0], [579.0, 523.0]]], "lines": ["とんでもない事が"]}, {"box": [127, 73, 564, 99], "vertical": false, "font_size": 26, "lines_coords": [[[127.0, 73.0], [564.0, 73.0], [564.0, 99.0], [127.0, 99.0]]], "lines": ["放課後１０７新ご当地グルメ"]}, {"box": [694, 600, 763, 816], "vertical": true, "font_size": 26, "lines_coords": [[[733.0, 600.0], [759.0, 600.0], [759.0, 815.0], [733.0, 815.0]], [[695.0, 600.0], [721.0, 600.0], [721.0, 755.0], [695.0, 755.0]]], "lines": ["実は他の四湖も", "調べた結果"]}, {"box": [148, 551, 194, 787], "vertical": true, "font_size": 45, "lines_coords": [[[148.0, 553.0], [193.0, 553.0], [193.0, 787.0], [148.0, 787.0]]], "lines": ["判明した！！"]}, {"box": [562, 911, 660, 1089], "vertical": true, "font_size": 43, "lines_coords": [[[615.0, 911.0], [660.0, 911.0], [660.0, 1089.0], [615.0, 1089.0]], [[562.0, 915.0], [603.0, 915.0], [603.0, 1046.0], [562.0, 1046.0]]], "lines": ["精進湖は", "手羽先"]}, {"box": [736, 1428, 822, 1685], "vertical": true, "font_size": 36, "lines_coords": [[[785.0, 1428.0], [819.0, 1428.0], [819.0, 1576.0], [785.0, 1576.0]], [[736.0, 1428.0], [774.0, 1428.0], [774.0, 1685.0], [736.0, 1685.0]]], "lines": ["本栖湖は", "フライドチキン"]}], "img_path": "00177.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [917, 131, 1069, 307], "vertical": true, "font_size": 47, "lines_coords": [[[1025.0, 138.0], [1066.0, 138.0], [1066.0, 264.0], [1025.0, 264.0]], [[958.0, 131.0], [1023.0, 131.0], [1023.0, 234.0], [958.0, 234.0]], [[920.0, 138.0], [954.0, 138.0], [954.0, 305.0], [920.0, 305.0]]], "lines": ["西湖は", "若鶏", "半身揚げ"]}, {"box": [164, 153, 274, 352], "vertical": true, "font_size": 48, "lines_coords": [[[221.0, 153.0], [273.0, 153.0], [273.0, 352.0], [221.0, 352.0]], [[165.0, 155.0], [210.0, 155.0], [210.0, 350.0], [165.0, 350.0]]], "lines": ["河口湖は", "よだれ鶏"]}, {"box": [1078, 960, 1189, 1301], "vertical": true, "font_size": 32, "lines_coords": [[[1156.0, 960.0], [1188.0, 960.0], [1188.0, 1228.0], [1156.0, 1228.0]], [[1117.0, 961.0], [1149.0, 961.0], [1149.0, 1301.0], [1117.0, 1301.0]], [[1078.0, 961.0], [1110.0, 961.0], [1110.0, 1087.0], [1078.0, 1087.0]]], "lines": ["そう並べてみると", "分かる通り五湖すべての", "湖の形が"]}, {"box": [438, 985, 508, 1293], "vertical": true, "font_size": 32, "lines_coords": [[[476.0, 986.0], [508.0, 986.0], [508.0, 1293.0], [476.0, 1293.0]], [[438.0, 986.0], [470.0, 986.0], [470.0, 1205.0], [438.0, 1205.0]]], "lines": ["チキン料理にソックリ", "だったのだっ！！"]}, {"box": [322, 990, 356, 1154], "vertical": true, "font_size": 30, "lines_coords": [[[326.0, 1089.0], [354.0, 1089.0], [354.0, 1153.0], [326.0, 1153.0]], [[322.0, 990.0], [354.0, 990.0], [354.0, 1093.0], [322.0, 1093.0]]], "lines": ["ーっ", "おおー"]}, {"box": [166, 980, 229, 1228], "vertical": true, "font_size": 26, "lines_coords": [[[200.0, 980.0], [226.0, 980.0], [226.0, 1185.0], [200.0, 1185.0]], [[166.0, 980.0], [193.0, 980.0], [193.0, 1228.0], [166.0, 1228.0]]], "lines": ["いや河口湖とか", "かなり無理あるやん"]}, {"box": [1053, 1370, 1162, 1783], "vertical": true, "font_size": 33, "lines_coords": [[[1126.0, 1372.0], [1160.0, 1372.0], [1162.0, 1520.0], [1128.0, 1520.0]], [[1091.0, 1372.0], [1123.0, 1372.0], [1125.0, 1695.0], [1093.0, 1695.0]], [[1055.0, 1370.0], [1087.0, 1370.0], [1085.0, 1783.0], [1053.0, 1783.0]]], "lines": ["これからは", "「富士チキン五湖」として", "各湖のご当地チキン料理を作り"]}, {"box": [834, 1402, 900, 1730], "vertical": true, "font_size": 28, "lines_coords": [[[866.0, 1402.0], [898.0, 1402.0], [900.0, 1730.0], [868.0, 1730.0]], [[834.0, 1406.0], [858.0, 1406.0], [858.0, 1642.0], [834.0, 1642.0]]], "lines": ["盛り上げていくべきでは", "ないだろうかっ！！"]}, {"box": [526, 1372, 588, 1650], "vertical": true, "font_size": 28, "lines_coords": [[[560.0, 1372.0], [588.0, 1372.0], [586.0, 1650.0], [558.0, 1650.0]], [[526.0, 1374.0], [553.0, 1374.0], [553.0, 1595.0], [526.0, 1595.0]]], "lines": ["本栖湖フライドチキン", "たべたいですっ！！"]}, {"box": [198, 1430, 256, 1732], "vertical": true, "font_size": 26, "lines_coords": [[[228.0, 1430.0], [255.0, 1430.0], [255.0, 1683.0], [228.0, 1683.0]], [[198.0, 1432.0], [223.0, 1432.0], [223.0, 1732.0], [198.0, 1732.0]]], "lines": ["ナキンチキン言うから", "おなか減ってきてもうたわ"]}], "img_path": "00178.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [110, 1234, 637, 1306], "vertical": false, "font_size": 33, "lines_coords": [[[112.0, 1232.0], [570.0, 1232.0], [570.0, 1270.0], [112.0, 1270.0]], [[116.0, 1273.0], [637.0, 1273.0], [637.0, 1306.0], [116.0, 1306.0]]], "lines": ["ゆるキャン△ぐいかがでしたでしょうか。", "今回は薪作り瑞牆キャンプ編を収録致しました。"]}, {"box": [113, 1359, 1168, 1512], "vertical": false, "font_size": 28, "lines_coords": [[[114.0, 1357.0], [834.0, 1357.0], [834.0, 1387.0], [114.0, 1387.0]], [[116.0, 1396.0], [841.0, 1396.0], [841.0, 1427.0], [116.0, 1427.0]], [[116.0, 1438.0], [1168.0, 1438.0], [1168.0, 1468.0], [116.0, 1468.0]], [[114.0, 1477.0], [888.0, 1477.0], [888.0, 1505.0], [114.0, 1505.0]]], "lines": ["作中で千暇たちは３月末に瑞穂山のキャンプ場へ行っていますが", "実際には４月までゲートが現まっておりハスも通行していません。", "それと神戸（こうど）の話をしていた青春板すぐ横の神戸トンネルも１２月上旬〜４月中旬まで", "出口が新神戸トンネルに繋がっていますのでくれぐれもご注意下さい。"]}, {"box": [109, 1554, 275, 1591], "vertical": false, "font_size": 27, "lines_coords": [[[116.0, 1559.0], [266.0, 1559.0], [266.0, 1588.0], [116.0, 1588.0]]], "lines": ["あｆろでした。"]}, {"box": [105, 1685, 809, 1803], "vertical": false, "font_size": 26, "lines_coords": [[[112.0, 1683.0], [208.0, 1683.0], [208.0, 1713.0], [112.0, 1713.0]], [[118.0, 1713.0], [798.0, 1713.0], [798.0, 1742.0], [118.0, 1742.0]], [[114.0, 1745.0], [221.0, 1745.0], [221.0, 1770.0], [114.0, 1770.0]], [[108.0, 1773.0], [435.0, 1773.0], [435.0, 1802.0], [108.0, 1802.0]]], "lines": ["〈初出一覧〉", "・２０１００ＭＣＦＵＺ令和テ年１１月－今回の年３月、９月、金沢３１３月曜日", "・描き下ろし", "本書は以上の内容を収録しました。"]}], "img_path": "00179.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [391, 795, 609, 901], "vertical": false, "font_size": 39.5, "lines_coords": [[[391.0, 798.0], [609.0, 795.0], [609.0, 834.0], [391.0, 838.0]], [[393.0, 862.0], [504.0, 862.0], [504.0, 901.0], [393.0, 901.0]]], "lines": ["著者：あｆろ", "©ａｆｒｏ"]}, {"box": [393, 618, 954, 673], "vertical": false, "font_size": 50.0, "lines_coords": [[[393.0, 620.0], [778.0, 620.0], [778.0, 673.0], [393.0, 673.0]], [[761.0, 622.0], [954.0, 618.0], [954.0, 665.0], [761.0, 669.0]]], "lines": ["ゆるキャン△第", "第１２巻"]}, {"box": [392, 980, 966, 1226], "vertical": false, "font_size": 37, "lines_coords": [[[393.0, 991.0], [952.0, 990.0], [952.0, 1029.0], [393.0, 1031.0]], [[395.0, 1059.0], [690.0, 1059.0], [690.0, 1096.0], [395.0, 1096.0]], [[397.0, 1123.0], [798.0, 1126.0], [798.0, 1158.0], [397.0, 1155.0]], [[541.0, 1188.0], [948.0, 1188.0], [948.0, 1226.0], [541.0, 1226.0]]], "lines": ["電子版発行日：２０２１年５月１５日", "発行人・東・敬彰", "発行所：株式会社芳文社", "東京都文京区後楽１－２－１２"]}], "img_path": "00180.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [100, 766, 136, 781], "vertical": false, "font_size": 17, "lines_coords": [[[101.0, 764.0], [133.0, 764.0], [133.0, 783.0], [101.0, 783.0]]], "lines": ["あ．．．"]}, {"box": [271, 674, 617, 773], "vertical": false, "font_size": 101, "lines_coords": [[[277.0, 669.0], [570.0, 669.0], [570.0, 779.0], [277.0, 779.0]]], "lines": ["ゆみホ．．．"]}, {"box": [663, 1119, 682, 1203], "vertical": true, "font_size": 19, "lines_coords": [[[663.0, 1119.0], [682.0, 1119.0], [682.0, 1203.0], [663.0, 1203.0]]], "lines": ["あｆご"]}], "img_path": "00181.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1241, 581, 1265, 676], "vertical": true, "font_size": 20, "lines_coords": [[[1245.0, 581.0], [1265.0, 581.0], [1261.0, 676.0], [1241.0, 676.0]]], "lines": ["たまたま持っとったキャンプ雑誌によると"]}, {"box": [1211, 635, 1230, 744], "vertical": true, "font_size": 20, "lines_coords": [[[1211.0, 635.0], [1230.0, 635.0], [1230.0, 744.0], [1211.0, 744.0]]], "lines": ["この涼口波長キャンプ場は２０１０年代に閉鎖されて"]}, {"box": [1244, 775, 1266, 872], "vertical": true, "font_size": 22, "lines_coords": [[[1244.0, 775.0], [1266.0, 775.0], [1266.0, 872.0], [1244.0, 872.0]]], "lines": ["このキャンプ場なくなっちゃうんだ．．．"]}, {"box": [1048, 583, 1071, 691], "vertical": true, "font_size": 23, "lines_coords": [[[1048.0, 583.0], [1071.0, 583.0], [1071.0, 691.0], [1048.0, 691.0]]], "lines": ["現在ではリゾート施設が出来とるらしいわ"]}, {"box": [959, 583, 1001, 697], "vertical": true, "font_size": 19, "lines_coords": [[[982.0, 583.0], [1001.0, 583.0], [1001.0, 678.0], [982.0, 678.0]]], "lines": ["この後オーナーは、"]}, {"box": [1046, 815, 1070, 938], "vertical": true, "font_size": 18, "lines_coords": [[[1046.0, 815.0], [1065.0, 815.0], [1068.0, 905.0], [1050.0, 905.0]]], "lines": ["小さいじとさまで見晴らしがいい場に"]}, {"box": [965, 777, 1001, 892], "vertical": true, "font_size": 21, "lines_coords": [[[980.0, 780.0], [1001.0, 780.0], [1001.0, 892.0], [980.0, 892.0]]], "lines": ["五湖周辺の土地を"]}, {"box": [876, 869, 942, 891], "vertical": false, "font_size": 22, "lines_coords": [[[876.0, 869.0], [942.0, 869.0], [942.0, 891.0], [876.0, 891.0]]], "lines": ["ＣＡＭＰＦＵＪ－ＣＯＫＯ"]}, {"box": [778, 580, 807, 748], "vertical": true, "font_size": 29, "lines_coords": [[[778.0, 580.0], [807.0, 580.0], [807.0, 748.0], [778.0, 748.0]]], "lines": ["「ーー株すげぇ」という言葉を元になんやかんで美大な財を成し"]}, {"box": [648, 511, 701, 555], "vertical": false, "font_size": 44, "lines_coords": [[[648.0, 511.0], [701.0, 511.0], [701.0, 555.0], [648.0, 555.0]]], "lines": ["んの"]}, {"box": [811, 810, 830, 918], "vertical": true, "font_size": 19, "lines_coords": [[[811.0, 810.0], [830.0, 810.0], [830.0, 918.0], [811.0, 918.0]]], "lines": ["最大のキャンプ場"]}, {"box": [776, 781, 795, 907], "vertical": true, "font_size": 19, "lines_coords": [[[776.0, 781.0], [795.0, 781.0], [795.0, 907.0], [776.0, 907.0]]], "lines": ["作り上げたのだった"]}, {"box": [641, 608, 701, 997], "vertical": true, "font_size": 56, "lines_coords": [[[645.0, 609.0], [701.0, 609.0], [697.0, 997.0], [641.0, 997.0]]], "lines": ["ゆるキ；Ｊ△"]}, {"box": [242, 775, 288, 925], "vertical": true, "font_size": 46, "lines_coords": [[[242.0, 775.0], [288.0, 775.0], [288.0, 925.0], [242.0, 925.0]]], "lines": ["キャンプ中突然２５年前にタイムスリップしてしまっ野クル３人は"]}, {"box": [1239, 971, 1264, 1131], "vertical": true, "font_size": 25, "lines_coords": [[[1239.0, 971.0], [1264.0, 971.0], [1264.0, 1131.0], [1239.0, 1131.0]]], "lines": ["あおいちゃん！！このキャンプ場何とかして残そうよ！！"]}, {"box": [1106, 991, 1126, 1061], "vertical": true, "font_size": 20, "lines_coords": [[[1106.0, 991.0], [1126.0, 991.0], [1126.0, 1061.0], [1106.0, 1061.0]]], "lines": ["せやな！！"]}, {"box": [1226, 1164, 1269, 1314], "vertical": true, "font_size": 21, "lines_coords": [[[1252.0, 1168.0], [1267.0, 1168.0], [1269.0, 1288.0], [1254.0, 1288.0]], [[1226.0, 1164.0], [1252.0, 1164.0], [1258.0, 1314.0], [1231.0, 1314.0]]], "lines": ["たまたま持っとったこの", "富くじ年蓋をオーナーさんに渡せばバッチリやで！！"]}, {"box": [1048, 974, 1077, 1107], "vertical": true, "font_size": 20, "lines_coords": [[[1048.0, 975.0], [1068.0, 975.0], [1068.0, 1074.0], [1048.0, 1074.0]]], "lines": ["何の策も財力もない"]}, {"box": [968, 982, 1003, 1082], "vertical": true, "font_size": 17, "lines_coords": [[[969.0, 984.0], [986.0, 984.0], [986.0, 1031.0], [969.0, 1031.0]]], "lines": ["キャンプ！！"]}, {"box": [1048, 1207, 1075, 1314], "vertical": true, "font_size": 27, "lines_coords": [[[1048.0, 1207.0], [1075.0, 1207.0], [1075.0, 1314.0], [1048.0, 1314.0]]], "lines": ["たまたま持ってるもんじゃねーよ！！"]}, {"box": [832, 1171, 954, 1190], "vertical": false, "font_size": 19, "lines_coords": [[[834.0, 1171.0], [948.0, 1171.0], [948.0, 1190.0], [834.0, 1190.0]]], "lines": ["ＣＡＭＰ「ＦＵＪ－ＣＯＫＣ"]}, {"box": [780, 1003, 793, 1133], "vertical": true, "font_size": 13, "lines_coords": [[[780.0, 1003.0], [793.0, 1003.0], [793.0, 1133.0], [780.0, 1133.0]]], "lines": ["これで解消できる訳やけど．．．"]}, {"box": [659, 938, 687, 1042], "vertical": true, "font_size": 28, "lines_coords": [[[659.0, 938.0], [687.0, 938.0], [687.0, 1042.0], [659.0, 1042.0]]], "lines": ["ｈｉＱｈｓｏｈｏｏｌｄｉｎｓｐｏｙｕｒｃｏｏｍｐｉｎａｔｉｕｒｅ"]}, {"box": [780, 1165, 804, 1269], "vertical": true, "font_size": 24, "lines_coords": [[[780.0, 1165.0], [804.0, 1165.0], [804.0, 1269.0], [780.0, 1269.0]]], "lines": ["これでホンマによかったんやろうか"]}, {"box": [657, 1154, 693, 1188], "vertical": false, "font_size": 34, "lines_coords": [[[657.0, 1154.0], [693.0, 1154.0], [693.0, 1188.0], [657.0, 1188.0]]], "lines": ["１２"]}, {"box": [646, 1151, 695, 1393], "vertical": true, "font_size": 45, "lines_coords": [[[650.0, 1151.0], [695.0, 1151.0], [691.0, 1393.0], [646.0, 1393.0]]], "lines": ["１２．１．あｆ３．"]}, {"box": [241, 973, 289, 1128], "vertical": true, "font_size": 48, "lines_coords": [[[241.0, 973.0], [289.0, 973.0], [289.0, 1128.0], [241.0, 1128.0]]], "lines": ["なんやかんやで現在では廃業してしまったキャンプ場を救うため"]}, {"box": [261, 1180, 276, 1257], "vertical": true, "font_size": 15, "lines_coords": [[[261.0, 1180.0], [276.0, 1180.0], [276.0, 1257.0], [261.0, 1257.0]]], "lines": ["．．．どんどこ？"]}, {"box": [61, 973, 77, 1106], "vertical": true, "font_size": 16, "lines_coords": [[[61.0, 973.0], [77.0, 973.0], [77.0, 1106.0], [61.0, 1106.0]]], "lines": ["立ち上がるのであった。"]}, {"box": [90, 1169, 128, 1249], "vertical": true, "font_size": 38, "lines_coords": [[[90.0, 1169.0], [128.0, 1169.0], [128.0, 1249.0], [90.0, 1249.0]]], "lines": ["このＣＭ９０年代からやってたんだー"]}], "img_path": "00182.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [75, 342, 320, 466], "vertical": false, "font_size": 55, "lines_coords": [[[116.0, 349.0], [311.0, 355.0], [309.0, 434.0], [114.0, 428.0]], [[75.0, 428.0], [320.0, 