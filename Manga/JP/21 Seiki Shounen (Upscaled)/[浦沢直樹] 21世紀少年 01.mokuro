, 982.0], [731.0, 1155.0], [691.0, 1155.0]], [[642.0, 984.0], [681.0, 984.0], [681.0, 1214.0], [642.0, 1214.0]], [[595.0, 986.0], [635.0, 986.0], [635.0, 1190.0], [595.0, 1190.0]]], "lines": ["だけどさ、", "オバケなんて", "いないよね。"]}, {"box": [1396, 1481, 1476, 1640], "vertical": true, "font_size": 40, "lines_coords": [[[1436.0, 1481.0], [1476.0, 1481.0], [1476.0, 1640.0], [1436.0, 1640.0]]], "lines": ["どうかな"]}, {"box": [824, 1146, 911, 1303], "vertical": true, "font_size": 42, "lines_coords": [[[871.0, 1148.0], [911.0, 1148.0], [911.0, 1303.0], [871.0, 1303.0]], [[824.0, 1146.0], [867.0, 1146.0], [867.0, 1303.0], [824.0, 1303.0]]], "lines": ["なるほど", "ね．．．．．．"]}, {"box": [944, 1455, 1127, 1839], "vertical": true, "font_size": 39, "lines_coords": [[[1078.0, 1455.0], [1127.0, 1455.0], [1127.0, 1579.0], [1078.0, 1579.0]], [[1035.0, 1460.0], [1075.0, 1460.0], [1075.0, 1739.0], [1035.0, 1739.0]], [[991.0, 1457.0], [1024.0, 1457.0], [1024.0, 1839.0], [991.0, 1839.0]], [[944.0, 1460.0], [977.0, 1460.0], [977.0, 1739.0], [944.0, 1739.0]]], "lines": ["それに", "おまえはこの先、", "もっと恐ろしいものを", "見ることになる。"]}, {"box": [796, 1476, 848, 1565], "vertical": true, "font_size": 47, "lines_coords": [[[796.0, 1478.0], [843.0, 1476.0], [848.0, 1563.0], [801.0, 1565.0]]], "lines": ["え？"]}, {"box": [749, 1886, 841, 2097], "vertical": true, "font_size": 40, "lines_coords": [[[801.0, 1889.0], [841.0, 1889.0], [841.0, 2055.0], [801.0, 2055.0]], [[754.0, 1886.0], [794.0, 1886.0], [789.0, 2097.0], [749.0, 2097.0]]], "lines": ["もういい、", "話は今度だ。"]}, {"box": [178, 1886, 314, 2135], "vertical": true, "font_size": 38, "lines_coords": [[[271.0, 1891.0], [311.0, 1891.0], [311.0, 2078.0], [271.0, 2078.0]], [[224.0, 1889.0], [264.0, 1889.0], [264.0, 2135.0], [224.0, 2135.0]], [[182.0, 1886.0], [215.0, 1886.0], [210.0, 2128.0], [178.0, 2128.0]]], "lines": ["マルオ達が", "来ると面倒だ。", "とっとと帰れ。"]}], "img_path": "00129.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1342, 203, 1527, 475], "vertical": true, "font_size": 37, "lines_coords": [[[1485.0, 206.0], [1527.0, 206.0], [1527.0, 337.0], [1485.0, 337.0]], [[1436.0, 203.0], [1478.0, 203.0], [1474.0, 475.0], [1431.0, 475.0]], [[1392.0, 208.0], [1424.0, 208.0], [1424.0, 400.0], [1392.0, 400.0]], [[1342.0, 203.0], [1375.0, 203.0], [1375.0, 468.0], [1342.0, 468.0]]], "lines": ["ちぇっ、", "ギター触らせて", "もらおうと", "思ったのに．．．"]}, {"box": [721, 178, 817, 414], "vertical": true, "font_size": 50, "lines_coords": [[[756.0, 178.0], [817.0, 178.0], [817.0, 243.0], [756.0, 243.0]], [[721.0, 182.0], [761.0, 182.0], [761.0, 403.0], [721.0, 403.0]]], "lines": ["あ、", "おまえさ．．．"]}, {"box": [785, 789, 827, 946], "vertical": true, "font_size": 42, "lines_coords": [[[785.0, 789.0], [827.0, 789.0], [827.0, 946.0], [785.0, 946.0]]], "lines": ["あの．．．"]}, {"box": [234, 799, 316, 1027], "vertical": true, "font_size": 40, "lines_coords": [[[274.0, 799.0], [314.0, 799.0], [309.0, 1026.0], [269.0, 1026.0]]], "lines": ["宇宙特捜隊の"]}, {"box": [1464, 1235, 1518, 1324], "vertical": true, "font_size": 54, "lines_coords": [[[1464.0, 1235.0], [1518.0, 1235.0], [1518.0, 1324.0], [1464.0, 1324.0]]], "lines": ["何？"]}, {"box": [1480, 1617, 1514, 1772], "vertical": true, "font_size": 34, "lines_coords": [[[1480.0, 1617.0], [1514.0, 1617.0], [1514.0, 1772.0], [1480.0, 1772.0]]], "lines": ["え．．．．．？"]}], "img_path": "00130.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1333, 159, 1485, 304], "vertical": true, "font_size": 58, "lines_coords": [[[1429.0, 161.0], [1485.0, 161.0], [1485.0, 253.0], [1429.0, 253.0]], [[1380.0, 164.0], [1438.0, 164.0], [1438.0, 304.0], [1380.0, 304.0]], [[1333.0, 159.0], [1394.0, 159.0], [1394.0, 269.0], [1333.0, 269.0]]], "lines": ["まあ", "いいや、", "行け。"]}, {"box": [892, 178, 988, 304], "vertical": true, "font_size": 50, "lines_coords": [[[937.0, 180.0], [988.0, 180.0], [988.0, 304.0], [937.0, 304.0]], [[892.0, 178.0], [942.0, 178.0], [942.0, 304.0], [892.0, 304.0]]], "lines": ["なんだ", "よ．．．．．．"]}, {