]], "lines": ["いえ．．．"]}, {"box": [970, 963, 1057, 1305], "vertical": true, "font_size": 40, "lines_coords": [[[1017.0, 965.0], [1056.0, 965.0], [1056.0, 1305.0], [1017.0, 1305.0]], [[970.0, 963.0], [1010.0, 963.0], [1010.0, 1284.0], [970.0, 1284.0]]], "lines": ["いや、それにしても", "たいしたもんだよ。"]}, {"box": [1103, 1694, 1286, 1889], "vertical": true, "font_size": 39, "lines_coords": [[[1242.0, 1694.0], [1284.0, 1694.0], [1286.0, 1889.0], [1244.0, 1889.0]], [[1195.0, 1694.0], [1235.0, 1694.0], [1235.0, 1849.0], [1195.0, 1849.0]], [[1152.0, 1696.0], [1185.0, 1696.0], [1185.0, 1886.0], [1152.0, 1886.0]], [[1103.0, 1696.0], [1143.0, 1696.0], [1143.0, 1867.0], [1103.0, 1867.0]]], "lines": ["その若さで", "なかなか", "なれるもん", "じゃない。"]}, {"box": [206, 1263, 487, 1533], "vertical": true, "font_size": 41, "lines_coords": [[[438.0, 1267.0], [487.0, 1267.0], [487.0, 1389.0], [438.0, 1389.0]], [[398.0, 1270.0], [431.0, 1270.0], [431.0, 1460.0], [398.0, 1460.0]], [[351.0, 1270.0], [384.0, 1270.0], [379.0, 1532.0], [346.0, 1532.0]], [[302.0, 1267.0], [337.0, 1267.0], [335.0, 1528.0], [299.0, 1528.0]], [[246.0, 1263.0], [299.0, 1263.0], [299.0, 1364.0], [246.0, 1364.0]], [[206.0, 1267.0], [246.0, 1267.0], [246.0, 1495.0], [206.0, 1495.0]]], "lines": ["連合軍", "警察予備隊", "どもだち〟教団", "調査特別チーム", "隊長、", "蝶野将平．．．"]}, {"box": [763, 1699, 991, 1966], "vertical": true, "font_size": 39, "lines_coords": [[[951.0, 1699.0], [991.0, 1699.0], [991.0, 1926.0], [951.0, 1926.0]], [[902.0, 1699.0], [942.0, 1699.0], [942.0, 1931.0], [902.0, 1931.0]], [[853.0, 1699.0], [895.0, 1699.0], [897.0, 1940.0], [855.0, 1940.0]], [[808.0, 1699.0], [848.0, 1699.0], [848.0, 1966.0], [808.0, 1966.0]], [[763.0, 1699.0], [796.0, 1699.0], [796.0, 1898.0], [763.0, 1898.0]]], "lines": ["私を逮捕した", "おかげか．．．", "いや、ホント、", "君に逮捕されて", "よかったよ。"]}, {"box": [175, 1696, 357, 1926], "vertical": true, "font_size": 35, "lines_coords": [[[318.0, 1699.0], [351.0, 1699.0], [351.0, 1924.0], [318.0, 1924.0]], [[269.0, 1696.0], [309.0, 1696.0], [309.0, 1926.0], [269.0, 1926.0]], [[224.0, 1701.0], [257.0, 1701.0], [257.0, 1926.0], [224.0, 1926.0]], [[175.0, 1701.0], [208.0, 1701.0], [208.0, 1886.0], [175.0, 1886.0]]], "lines": ["これで少しは", "チョーさんに", "償いができた", "かな．．．？？"]}], "img_path": "00167.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1467, 203, 1518, 309], "vertical": true, "font_size": 51, "lines_coords": [[[1467.0, 203.0], [1518.0, 203.0], [1518.0, 309.0], [1467.0, 309.0]]], "lines": ["ふん。"]}, {"box": [932, 206, 1071, 473], "vertical": true, "font_size": 35, "lines_coords": [[[1035.0, 210.0], [1068.0, 210.0], [1068.0, 400.0], [1035.0, 400.0]], [[988.0, 213.0], [1021.0, 213.0], [1021.0, 473.0], [988.0, 473.0]], [[937.0, 206.0], [977.0, 206.0], [972.0, 440.0], [932.0, 440.0]]], "lines": ["そう簡単に", "償えるもんじゃ", "ないか．．．．．．"]}, {"box": [747, 173, 834, 438], "vertical": true, "font_size": 36, "lines_coords": [[[796.0, 175.0], [829.0, 175.0], [829.0, 403.0], [796.0, 403.0]], [[747.0, 173.0], [787.0, 173.0], [787.0, 438.0], [747.0, 438.0]]], "lines": ["太陽の塔の中", "入ってみたか？"]}, {"box": [226, 189, 311, 573], "vertical": true, "font_size": 38, "lines_coords": [[[267.0, 189.0], [309.0, 189.0], [311.0, 349.0], [269.0, 349.0]], [[227.0, 192.0], [260.0, 192.0], [260.0, 569.0], [227.0, 569.0]]], "lines": ["いえ．．．", "山ちゃんおじさん．．．"]}, {"box": [232, 1009, 566, 1316], "vertical": true, "font_size": 38, "lines_coords": [[[522.0, 1012.0], [555.0, 1012.0], [555.0, 1235.0], [522.0, 1235.0]], [[471.0, 1010.0], [510.0, 1010.0], [510.0, 1202.0], [471.0, 1202.0]], [[428.0, 1012.0], [461.0, 1012.0], [461.0, 1275.0], [428.0, 1275.0]], [[377.0, 1010.0], [417.0, 1010.0], [417.0, 1314.0], [377.0, 1314.0]], [[328.0, 1010.0], [372.0, 1010.0], [372.0, 1242.0], [328.0, 1242.0]], [[281.0, 1010.0], [321.0, 1010.0], [321.0, 1242.0], [281.0, 1242.0]], [[232.0, 1012.0], [271.0, 1012.0], [271.0, 1314.0], [232.0, 1314.0]]], "lines": ["どもだちの", "関連施設は", "すべて国連軍の", "管理下に置かれて", "しまい．．．．．．", "申請は出して", "いるんですが．．．"]}, {"box": [1272, 1009, 1503, 1427], "vertical": true, "font_size": 37, "lines_coords": [[[1459.0, 1010.0], [1502.0, 1010.0], [1502.0, 1178.0], [1459.0, 1178.0]], [[1413.0, 1012.0], [1452.0, 1012.0], [1452.0, 1350.0], [1413.0, 1350.0]], [[1370.0, 1012.0], [1403.0, 1012.0], [1403.0, 1253.0], [1370.0, 1253.0]], [[1317.0, 1010.0], [1356.0, 1010.0], [1356.0, 1279.0], [1317.0, 1279.0]], [[1274.0, 1012.0], [1307.0, 1012.0], [1307.0, 1427.0], [1274.0, 1427.0]]], "lines": ["あ、いや、", "山崎元警察庁長官の", "証言を受けて、", "ただちに捜索に", "入ろうとしたのですが．．．"]}, {"box": [1467, 1652, 1511, 1848], "vertical": true, "font_size": 40, "lines_coords": [[[1471.0, 1652.0], [1511.0, 1652.0], [1506.0, 1844.0], [1467.0, 1844.0]]], "lines": ["そうか．．．．．"]}, {"box": [217, 1654, 258, 1808], "vertical": true, "font_size": 40, "lines_coords": [[[217.0, 1654.0], [257.0, 1654.0], [257.0, 1807.0], [217.0, 1807.0]]], "lines": ["はあ．．．"]}, {"box": [820, 1652, 1099, 2015], "vertical": true, "font_size": 39, "lines_coords": [[[1056.0, 1654.0], [1099.0, 1654.0], [1099.0, 1771.0], [1056.0, 1771.0]], [[1010.0, 1654.0], [1049.0, 1654.0], [1049.0, 1896.0], [1010.0, 1896.0]], [[963.0, 1654.0], [1003.0, 1654.0], [1003.0, 1921.0], [963.0, 1921.0]], [[913.0, 1654.0], [953.0, 1654.0], [953.0, 1961.0], [913.0, 1961.0]], [[867.0, 1654.0], [906.0, 1654.0], [906.0, 2001.0], [867.0, 2001.0]], [[820.0, 1654.0], [855.0, 1654.0], [857.0, 2010.0], [822.0, 2010.0]]], "lines": ["連中に", "言ってやれよ。", "太陽の塔の中の", "チョーさんメモは", "あんた方が見たって", "意味わからないって。"]}, {"box": [590, 1650, 733, 2015], "vertical": true, "font_size": 47, "lines_coords": [[[681.0, 1652.0], [733.0, 1652.0], [733.0, 1776.0], [681.0, 1776.0]], [[637.0, 1652.0], [679.0, 1652.0], [681.0, 1975.0], [639.0, 1975.0]], [[590.0, 1650.0], [637.0, 1650.0], [637.0, 2015.0], [590.0, 2015.0]]], "lines": ["強気で", "出たほうがいいぞ、", "君、隊長なんだから。"]}], "img_path": "00168.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1347, 199, 1492, 434], "vertical": true, "font_size": 47, "lines_coords": [[[1443.0, 206.0], [1492.0, 206.0], [1492.0, 339.0], [1443.0, 339.0]], [[1399.0, 203.0], [1438.0, 203.0], [1438.0, 433.0], [1399.0, 433.0]], [[1347.0, 199.0], [1399.0, 199.0], [1399.0, 300.0], [1347.0, 300.0]]], "lines": ["．．．．．．で、", "これなんです", "けど、"]}, {"box": [738, 184, 823, 413], "vertical": true, "font_size": 36, "lines_coords": [[[785.0, 187.0], [817.0, 187.0], [817.0, 407.0], [785.0, 407.0]], [[738.0, 185.0], [778.0, 185.0], [778.0, 353.0], [738.0, 353.0]]], "lines": ["どもだち〟の", "遺体です。"]}, {"box": [583, 1052, 768, 1249], "vertical": true, "font_size": 44, "lines_coords": [[[726.0, 1052.0], [768.0, 1052.0], [763.0, 1249.0], [721.0, 1249.0]], [[672.0, 1052.0], [724.0, 1052.0], [724.0, 1176.0], [672.0, 1176.0]], [[630.0, 1059.0], [670.0, 1059.0], [670.0, 1244.0], [630.0, 1244.0]], [[583.0, 1057.0], [625.0, 1057.0], [625.0, 1211.0], [583.0, 1211.0]]], "lines": ["間違いなく", "それが", "どもだち", "ですか？"]}, {"box": [1040, 1500, 1134, 1741], "vertical": true, "font_size": 44, "lines_coords": [[[1094.0, 1502.0], [1134.0, 1502.0], [1134.0, 1736.0], [1094.0, 1736.0]], [[1040.0, 1500.0], [1089.0, 1500.0], [1089.0, 1640.0], [1040.0, 1640.0]]], "lines": ["そっくりだが", "違うな。"]}, {"box": [520, 1500, 562, 1623], "vertical": true, "font_size": 42, "lines_coords": [[[520.0, 1500.0], [562.0, 1500.0], [562.0, 1582.0], [520.0, 1582.0]]], "lines": ["え．．"]}, {"box": [342, 1501, 426, 1659], "vertical": true, "font_size": 37, "lines_coords": [[[384.0, 1502.0], [426.0, 1502.0], [426.0, 1659.0], [384.0, 1659.0]], [[342.0, 1502.0], [374.0, 1502.0], [374.0, 1577.0], [342.0, 1577.0]]], "lines": ["違うって", "．．．"]}], "img_path": "00169.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1342, 161, 1530, 583], "vertical": true, "font_size": 44, "lines_coords": [[[1476.0, 161.0], [1530.0, 161.0], [1530.0, 257.0], [1476.0, 257.0]], [[1436.0, 164.0], [1476.0, 164.0], [1476.0, 468.0], [1436.0, 468.0]], [[1389.0, 164.0], [1429.0, 164.0], [1429.0, 583.0], [1389.0, 583.0]], [[1342.0, 164.0], [1382.0, 164.0], [1382.0, 295.0], [1342.0, 295.0]]], "lines": ["いや、", "俺が入信した時の", "っともだち心じゃないって", "ことさ。"]}, {"box": [848, 189, 1036, 536], "vertical": true, "font_size": 40, "lines_coords": [[[995.0, 192.0], [1035.0, 192.0], [1035.0, 349.0], [995.0, 349.0]], [[944.0, 189.0], [991.0, 189.0], [991.0, 536.0], [944.0, 536.0]], [[904.0, 194.0], [937.0, 194.0], [937.0, 382.0], [904.0, 382.0]], [[848.0, 189.0], [888.0, 189.0], [895.0, 440.0], [855.0, 440.0]]], "lines": ["こいつは", "本当のともだちが", "死んだ時に", "すりかわった。"]}, {"box": [214, 194, 298, 425], "vertical": true, "font_size": 32, "lines_coords": [[[260.0, 199.0], [292.0, 199.0], [292.0, 424.0], [260.0, 424.0]]], "lines": ["すりかわった"]}, {"box": [1406, 1019, 1493, 1305], "vertical": true, "font_size": 38, "lines_coords": [[[1452.0, 1019.0], [1492.0, 1019.0], [1490.0, 1296.0], [1450.0, 1296.0]], [[1406.0, 1021.0], [1441.0, 1021.0], [1443.0, 1303.0], [1408.0, 1303.0]]], "lines": ["俺が信じたのは、", "こいつじゃない。"]}, {"box": [678, 553, 763, 780], "vertical": true, "font_size": 36, "lines_coords": [[[724.0, 553.0], [763.0, 553.0], [759.0, 780.0], [719.0, 780.0]], [[679.0, 557.0], [712.0, 557.0], [712.0, 757.0], [679.0, 757.0]]], "lines": ["＂ともだち〟の", "コピーだよ。"]}, {"box": [782, 1544, 878, 1780], "vertical": true, "font_size": 44, "lines_coords": [[[841.0, 1553.0], [874.0, 1553.0], [874.0, 1778.0], [841.0, 1778.0]], [[782.0, 1544.0], [836.0, 1544.0], [836.0, 1650.0], [782.0, 1650.0]]], "lines": ["山崎元警察庁", "長官。"]}, {"box": [232, 1945, 321, 2135], "vertical": true, "font_size": 41, "lines_coords": [[[281.0, 1945.0], [321.0, 1945.0], [321.0, 2135.0], [281.0, 2135.0]], [[232.0, 1945.0], [274.0, 1945.0], [274.0, 2074.0], [232.0, 2074.0]]], "lines": ["おじさんで", "いいよ。"]}], "img_path": "00170.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1328, 208, 1462, 475], "vertical": true, "font_size": 38, "lines_coords": [[[1417.0, 208.0], [1457.0, 208.0], [1462.0, 372.0], [1422.0, 372.0]], [[1373.0, 210.0], [1415.0, 210.0], [1415.0, 370.0], [1373.0, 370.0]], [[1328.0, 213.0], [1361.0, 213.0], [1361.0, 475.0], [1328.0, 475.0]]], "lines": ["あなたは、", "なぜ入信", "したんですか？"]}, {"box": [1375, 693, 1462, 963], "vertical": true, "font_size": 38, "lines_coords": [[[1417.0, 693.0], [1459.0, 693.0], [1462.0, 850.0], [1420.0, 850.0]], [[1375.0, 700.0], [1408.0, 700.0], [1408.0, 963.0], [1375.0, 963.0]]], "lines": ["君はなぜ", "刑事になった？"]}, {"box": [857, 696, 1039, 1040], "vertical": true, "font_size": 36, "lines_coords": [[[1000.0, 698.0], [1033.0, 698.0], [1033.0, 895.0], [1000.0, 895.0]], [[949.0, 696.0], [988.0, 696.0], [988.0, 904.0], [949.0, 904.0]], [[902.0, 698.0], [942.0, 698.0], [942.0, 1040.0], [902.0, 1040.0]], [[857.0, 700.0], [890.0, 700.0], [890.0, 848.0], [857.0, 848.0]]], "lines": ["社会のため、", "正義のため、", "犯人を逮捕するため", "．．．．．．か？"]}, {"box": [670, 691, 768, 850], "vertical": true, "font_size": 48, "lines_coords": [[[728.0, 696.0], [768.0, 696.0], [768.0, 850.0], [728.0, 850.0]], [[674.0, 691.0], [731.0, 693.0], [726.0, 796.0], [670.0, 794.0]]], "lines": ["もちろん", "です。"]}, {"box": [201, 1047, 297, 1261], "vertical": true, "font_size": 48, "lines_coords": [[[241.0, 1047.0], [297.0, 1047.0], [297.0, 1139.0], [241.0, 1139.0]], [[201.0, 1050.0], [241.0, 1050.0], [241.0, 1258.0], [201.0, 1258.0]]], "lines": ["俺も", "そうだった。"]}, {"box": [1453, 1419, 1485, 1548], "vertical": true, "font_size": 32, "lines_coords": [[[1453.0, 1419.0], [1485.0, 1419.0], [1485.0, 1548.0], [1453.0, 1548.0]]], "lines": ["．．．．．．"]}, {"box": [1025, 1422, 1256, 1745], "vertical": true, "font_size": 38, "lines_coords": [[[1211.0, 1422.0], [1251.0, 1422.0], [1256.0, 1619.0], [1216.0, 1619.0]], [[1167.0, 1427.0], [1206.0, 1427.0], [1206.0, 1741.0], [1167.0, 1741.0]], [[1117.0, 1425.0], [1157.0, 1425.0], [1157.0, 1659.0], [1117.0, 1659.0]], [[1070.0, 1425.0], [1110.0, 1425.0], [1110.0, 1657.0], [1070.0, 1657.0]], [[1026.0, 1429.0], [1059.0, 1429.0], [1059.0, 1743.0], [1026.0, 1743.0]]], "lines": ["そりゃもう", "毎日必死になって、", "足を棒にして", "捜査、捜査に", "明け暮れたもんさ。"]}, {"box": [785, 1420, 924, 1694], "vertical": true, "font_size": 41, "lines_coords": [[[885.0, 1429.0], [918.0, 1429.0], [918.0, 1652.0], [885.0, 1652.0]], [[834.0, 1425.0], [874.0, 1425.0], [874.0, 1694.0], [834.0, 1694.0]], [[785.0, 1420.0], [834.0, 1420.0], [834.0, 1490.0], [785.0, 1490.0]]], "lines": ["最高の刑事に", "なろうと思って", "な。"]}, {"box": [168, 1422, 260, 1579], "vertical": true, "font_size": 44, "lines_coords": [[[220.0, 1425.0], [260.0, 1425.0], [260.0, 1579.0], [220.0, 1579.0]], [[168.0, 1422.0], [217.0, 1422.0], [217.0, 1546.0], [168.0, 1546.0]]], "lines": ["ところが", "だ．．．．．"]}], "img_path": "00171.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1331, 171, 1515, 478], "vertical": true, "font_size": 40, "lines_coords": [[[1469.0, 173.0], [1509.0, 173.0], [1513.0, 328.0], [1474.0, 328.0]], [[1424.0, 171.0], [1464.0, 171.0], [1467.0, 452.0], [1427.0, 452.0]], [[1377.0, 171.0], [1417.0, 171.0], [1417.0, 478.0], [1377.0, 478.0]], [[1331.0, 173.0], [1373.0, 173.0], [1373.0, 302.0], [1331.0, 302.0]]], "lines": ["どんなに", "足を棒にしても、", "どんなに張り込み", "しても、"]}, {"box": [724, 189, 768, 413], "vertical": true, "font_size": 40, "lines_coords": [[[724.0, 189.0], [763.0, 189.0], [768.0, 412.0], [728.0, 412.0]]], "lines": ["かなわない？"]}, {"box": [909, 550, 993, 820], "vertical": true, "font_size": 36, "lines_coords": [[[953.0, 550.0], [993.0, 550.0], [993.0, 710.0], [953.0, 710.0]], [[909.0, 557.0], [942.0, 557.0], [942.0, 817.0], [909.0, 817.0]]], "lines": ["どうにも", "がなわない．．．"]}, {"box": [228, 517, 410, 768], "vertical": true, "font_size": 41, "lines_coords": [[[365.0, 517.0], [405.0, 517.0], [410.0, 675.0], [370.0, 675.0]], [[321.0, 522.0], [360.0, 522.0], [360.0, 714.0], [321.0, 714.0]], [[267.0, 522.0], [318.0, 522.0], [318.0, 644.0], [267.0, 644.0]], [[229.0, 525.0], [262.0, 525.0], [262.0, 764.0], [229.0, 764.0]]], "lines": ["そう．．．．．", "俺の上には", "いつも", "あの人がいた。"]}, {"box": [278, 1059, 414, 1214], "vertical": true, "font_size": 42, "lines_coords": [[[374.0, 1059.0], [414.0, 1059.0], [414.0, 1214.0], [374.0, 1214.0]], [[325.0, 1061.0], [367.0, 1061.0], [367.0, 1211.0], [325.0, 1211.0]], [[278.0, 1059.0], [321.0, 1059.0], [321.0, 1192.0], [278.0, 1192.0]]], "lines": ["こいつを", "徹底的に", "洗おう。"]}, {"box": [1443, 1636, 1525, 1829], "vertical": true, "font_size": 38, "lines_coords": [[[1483.0, 1640.0], [1523.0, 1640.0], [1523.0, 1828.0], [1483.0, 1828.0]], [[1443.0, 1642.0], [1478.0, 1642.0], [1478.0, 1753.0], [1443.0, 1753.0]]], "lines": ["じいちゃん", "．．．．．．"]}, {"box": [454, 1637, 687, 1907], "vertical": true, "font_size": 37, "lines_coords": [[[649.0, 1640.0], [681.0, 1640.0], [681.0, 1828.0], [649.0, 1828.0]], [[599.0, 1638.0], [639.0, 1638.0], [639.0, 1795.0], [599.0, 1795.0]], [[550.0, 1640.0], [590.0, 1640.0], [590.0, 1804.0], [550.0, 1804.0]], [[506.0, 1640.0], [539.0, 1640.0], [539.0, 1903.0], [506.0, 1903.0]], [[454.0, 1638.0], [496.0, 1638.0], [496.0, 1771.0], [454.0, 1771.0]]], "lines": ["五十嵐長介", "．．．．．．", "あの人は、", "まさに捜査の神", "だった。"]}, {"box": [937, 1635, 1031, 2003], "vertical": true, "font_size": 44, "lines_coords": [[[979.0, 1635.0], [1026.0, 1635.0], [1031.0, 1950.0], [984.0, 1950.0]], [[937.0, 1640.0], [977.0, 1640.0], [977.0, 2003.0], [937.0, 2003.0]]], "lines": ["才能っていうのは", "いかんともしがたい。"]}], "img_path": "00172.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1384, 210, 1474, 416], "vertical": true, "font_size": 38, "lines_coords": [[[1431.0, 210.0], [1474.0, 210.0], [1474.0, 330.0], [1431.0, 330.0]], [[1387.0, 210.0], [1420.0, 210.0], [1420.0, 412.0], [1387.0, 412.0]]], "lines": ["いくら", "努力しても、"]}, {"box": [883, 208, 1017, 434], "vertical": true, "font_size": 35, "lines_coords": [[[977.0, 208.0], [1017.0, 208.0], [1017.0, 363.0], [977.0, 363.0]], [[932.0, 210.0], [965.0, 210.0], [965.0, 433.0], [932.0, 433.0]], [[883.0, 208.0], [916.0, 208.0], [916.0, 419.0], [883.0, 419.0]]], "lines": ["努力じゃ", "越えられない", "ものがある。"]}, {"box": [607, 164, 788, 450], "vertical": true, "font_size": 36, "lines_coords": [[[747.0, 166.0], [787.0, 166.0], [787.0, 358.0], [747.0, 358.0]], [[700.0, 166.0], [740.0, 166.0], [740.0, 403.0], [700.0, 403.0]], [[656.0, 166.0], [688.0, 166.0], [688.0, 316.0], [656.0, 316.0]], [[609.0, 166.0], [642.0, 166.0], [642.0, 447.0], [609.0, 447.0]]], "lines": ["自暴自棄に", "なっていた時、", "ある男に", "声をかけられた。"]}, {"box": [1403, 969, 1483, 1092], "vertical": true, "font_size": 42, "lines_coords": [[[1441.0, 972.0], [1483.0, 972.0], [1483.0, 1092.0], [1441.0, 1092.0]]], "lines": ["ある男"]}, {"box": [864, 965, 963, 1181], "vertical": true, "font_size": 48, "lines_coords": [[[909.0, 965.0], [963.0, 965.0], [963.0, 1059.0], [909.0, 1059.0]], [[864.0, 970.0], [906.0, 970.0], [911.0, 1181.0], [869.0, 1181.0]]], "lines": ["彼は", "俺に言った。"]}, {"box": [199, 967, 341, 1333], "vertical": true, "font_size": 38, "lines_coords": [[[304.0, 975.0], [337.0, 975.0], [337.0, 1143.0], [304.0, 1143.0]], [[255.0, 975.0], [288.0, 975.0], [288.0, 1200.0], [255.0, 1200.0]], [[199.0, 967.0], [246.0, 967.0], [250.0, 1333.0], [203.0, 1333.0]]], "lines": ["「あなたは", "あるがままで", "十分素晴らしい．．．"]}], "img_path": "00173.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1366, 187, 1502, 476], "vertical": true, "font_size": 42, "lines_coords": [[[1457.0, 192.0], [1499.0, 192.0], [1502.0, 363.0], [1459.0, 363.0]], [[1408.0, 187.0], [1457.0, 187.0], [1457.0, 311.0], [1408.0, 311.0]], [[1366.0, 189.0], [1399.0, 189.0], [1399.0, 468.0], [1366.0, 468.0]]], "lines": ["私と共に", "宇宙に", "なりましょう．．．"]}, {"box": [845, 201, 920, 359], "vertical": true, "font_size": 29, "lines_coords": [[[845.0, 208.0], [874.0, 208.0], [874.0, 269.0], [845.0, 269.0]]], "lines": ["くく"]}, {"box": [1469, 1003, 1509, 1198], "vertical": true, "font_size": 40, "lines_coords": [[[1469.0, 1003.0], [1509.0, 1003.0], [1509.0, 1195.0], [1469.0, 1195.0]]], "lines": ["それで．．．．．．"]}, {"box": [747, 590, 932, 860], "vertical": true, "font_size": 41, "lines_coords": [[[890.0, 592.0], [930.0, 592.0], [930.0, 836.0], [890.0, 836.0]], [[843.0, 595.0], [883.0, 595.0], [883.0, 860.0], [843.0, 860.0]], [[794.0, 590.0], [836.0, 590.0], [836.0, 750.0], [794.0, 750.0]], [[747.0, 592.0], [789.0, 592.0], [789.0, 728.0], [747.0, 728.0]]], "lines": ["今となっちゃ、", "何を言ってるの", "やら．．．", "だがね。"]}, {"box": [781, 1000, 960, 1232], "vertical": true, "font_size": 41, "lines_coords": [[[909.0, 1000.0], [960.0, 1000.0], [960.0, 1127.0], [909.0, 1127.0]], [[867.0, 1003.0], [906.0, 1003.0], [906.0, 1162.0], [867.0, 1162.0]], [[824.0, 1005.0], [857.0, 1005.0], [857.0, 1232.0], [824.0, 1232.0]]], "lines": ["それで", "あなたは", "じいちゃんを"]}, {"box": [1422, 1598, 1525, 1706], "vertical": true, "font_size": 54, "lines_coords": [[[1462.0, 1598.0], [1525.0, 1598.0], [1525.0, 1706.0], [1462.0, 1706.0]], [[1422.0, 1607.0], [1467.0, 1607.0], [1467.0, 1701.0], [1422.0, 1701.0]]], "lines": ["ああ", "．．．"]}, {"box": [262, 1607, 374, 1790], "vertical": true, "font_size": 54, "lines_coords": [[[314.0, 1612.0], [374.0, 1612.0], [374.0, 1746.0], [314.0, 1746.0]], [[262.0, 1607.0], [311.0, 1607.0], [311.0, 1790.0], [262.0, 1790.0]]], "lines": ["“絶交”", "した．．．"]}], "img_path": "00174.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [691, 201, 878, 448], "vertical": true, "font_size": 41, "lines_coords": [[[836.0, 206.0], [876.0, 206.0], [871.0, 445.0], [831.0, 445.0]], [[789.0, 201.0], [829.0, 201.0], [824.0, 431.0], [785.0, 431.0]], [[738.0, 201.0], [778.0, 201.0], [778.0, 431.0], [738.0, 431.0]], [[691.0, 201.0], [735.0, 201.0], [735.0, 300.0], [691.0, 300.0]]], "lines": ["〝絶交〟した後、", "チョーさんの", "残したメモを", "見た。"]}, {"box": [189, 201, 325, 411], "vertical": true, "font_size": 43, "lines_coords": [[[271.0, 201.0], [325.0, 201.0], [325.0, 302.0], [271.0, 302.0]], [[232.0, 206.0], [274.0, 206.0], [274.0, 375.0], [232.0, 375.0]], [[189.0, 206.0], [222.0, 206.0], [222.0, 410.0], [189.0, 410.0]]], "lines": ["いやー", "驚いたね。", "さすが神だ。"]}, {"box": [1387, 998, 1471, 1190], "vertical": true, "font_size": 36, "lines_coords": [[[1436.0, 1000.0], [1469.0, 1000.0], [1469.0, 1188.0], [1436.0, 1188.0]], [[1387.0, 998.0], [1427.0, 998.0], [1427.0, 1190.0], [1387.0, 1190.0]]], "lines": ["ヤマネとは", "何者か．．．"]}, {"box": [1007, 998, 1047, 1225], "vertical": true, "font_size": 38, "lines_coords": [[[1007.0, 998.0], [1047.0, 998.0], [1047.0, 1225.0], [1007.0, 1225.0]]], "lines": ["サダキヨ．．．"]}, {"box": [1009, 1001, 1048, 1229], "vertical": true, "font_size": 39, "lines_coords": [[[1009.0, 1001.0], [1048.0, 1001.0], [1048.0, 1229.0], [1009.0, 1229.0]]], "lines": ["サダキヨ．．．"]}, {"box": [850, 996, 935, 1185], "vertical": true, "font_size": 38, "lines_coords": [[[902.0, 1000.0], [935.0, 1000.0], [935.0, 1185.0], [902.0, 1185.0]], [[850.0, 996.0], [892.0, 996.0], [892.0, 1150.0], [850.0, 1150.0]]], "lines": ["サダキヨの", "友達．．．．．"]}, {"box": [684, 998, 773, 1223], "vertical": true, "font_size": 41, "lines_coords": [[[733.0, 1003.0], [773.0, 1003.0], [768.0, 1223.0], [728.0, 1223.0]], [[684.0, 998.0], [726.0, 998.0], [726.0, 1153.0], [684.0, 1153.0]]], "lines": ["『ともだち〟の", "正体．．．"]}, {"box": [166, 602, 349, 849], "vertical": true, "font_size": 41, "lines_coords": [[[306.0, 604.0], [349.0, 604.0], [349.0, 759.0], [306.0, 759.0]], [[260.0, 602.0], [302.0, 602.0], [302.0, 757.0], [260.0, 757.0]], [[213.0, 604.0], [253.0, 604.0], [253.0, 796.0], [213.0, 796.0]], [[166.0, 604.0], [206.0, 604.0], [206.0, 848.0], [166.0, 848.0]]], "lines": ["そこには", "すべての", "謎の答えが", "書いてあった。"]}, {"box": [178, 993, 319, 1228], "vertical": true, "font_size": 44, "lines_coords": [[[276.0, 1000.0], [318.0, 1000.0], [318.0, 1192.0], [276.0, 1192.0]], [[229.0, 1000.0], [269.0, 1000.0], [269.0, 1228.0], [229.0, 1228.0]], [[178.0, 993.0], [227.0, 993.0], [227.0, 1190.0], [178.0, 1190.0]]], "lines": ["フクベエと", "呼ばれていた", "服部．．．．．．"]}, {"box": [1347, 1495, 1485, 1730], "vertical": true, "font_size": 40, "lines_coords": [[[1427.0, 1497.0], [1481.0, 1495.0], [1485.0, 1621.0], [1431.0, 1624.0]], [[1394.0, 1502.0], [1427.0, 1502.0], [1427.0, 1727.0], [1394.0, 1727.0]], [[1347.0, 1502.0], [1380.0, 1502.0], [1380.0, 1687.0], [1347.0, 1687.0]]], "lines": ["そして", "もっと驚いた", "ことに．．．"]}, {"box": [810, 1537, 946, 1844], "vertical": true, "font_size": 40, "lines_coords": [[[906.0, 1537.0], [946.0, 1537.0], [946.0, 1734.0], [906.0, 1734.0]], [[857.0, 1539.0], [897.0, 1539.0], [897.0, 1844.0], [857.0, 1844.0]], [[810.0, 1542.0], [850.0, 1542.0], [850.0, 1746.0], [810.0, 1746.0]]], "lines": ["そのメモは", "そこで終わっては", "いなかった。"]}, {"box": [149, 1537, 288, 1732], "vertical": true, "font_size": 43, "lines_coords": [[[239.0, 1537.0], [288.0, 1537.0], [288.0, 1671.0], [239.0, 1671.0]], [[196.0, 1539.0], [236.0, 1539.0], [236.0, 1729.0], [196.0, 1729.0]], [[149.0, 1537.0], [189.0, 1537.0], [189.0, 1732.0], [149.0, 1732.0]]], "lines": ["なんと、", "あの時点で", "すでに．．．"]}], "img_path": "00175.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [264, 201, 609, 407], "vertical": false, "font_size": 75, "lines_coords": [[[264.0, 339.0], [578.0, 201.0], [609.0, 269.0], [295.0, 407.0]]], "lines": ["イルルドリンクターに"]}, {"box": [1124, 208, 1251, 290], "vertical": false, "font_size": 38, "lines_coords": [[[1124.0, 255.0], [1237.0, 208.0], [1251.0, 243.0], [1138.0, 290.0]]], "lines": ["あの友達"]}, {"box": [1049, 243, 1300, 435], "vertical": false, "font_size": 38.5, "lines_coords": [[[1049.0, 346.0], [1281.0, 243.0], [1298.0, 283.0], [1066.0, 386.0]], [[1054.0, 405.0], [1286.0, 311.0], [1300.0, 342.0], [1068.0, 435.0]]], "lines": ["ある一括向景元の", "いわならば後放って"]}, {"box": [1138, 513, 1321, 618], "vertical": false, "font_size": 37.5, "lines_coords": [[[1232.0, 581.0], [1312.0, 560.0], [1321.0, 597.0], [1242.0, 618.0]], [[1138.0, 585.0], [1288.0, 513.0], [1305.0, 546.0], [1155.0, 618.0]]], "lines": ["もう", "イレットリレメタトに"]}, {"box": [797, 960, 995, 1310], "vertical": true, "font_size": 45, "lines_coords": [[[928.0, 960.0], [995.0, 960.0], [995.0, 1057.0], [928.0, 1057.0]], [[890.0, 970.0], 