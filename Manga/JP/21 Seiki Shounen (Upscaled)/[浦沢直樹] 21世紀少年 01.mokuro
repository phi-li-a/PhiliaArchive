rtical": true, "font_size": 36, "lines_coords": [[[1422.0, 883.0], [1462.0, 883.0], [1462.0, 1117.0], [1422.0, 1117.0]], [[1377.0, 885.0], [1410.0, 885.0], [1410.0, 1183.0], [1377.0, 1183.0]]], "lines": ["肝心なことを", "見ないように．．．"]}, {"box": [751, 885, 835, 1113], "vertical": true, "font_size": 34, "lines_coords": [[[792.0, 885.0], [831.0, 885.0], [831.0, 1113.0], [792.0, 1113.0]], [[752.0, 885.0], [782.0, 885.0], [782.0, 1092.0], [752.0, 1092.0]]], "lines": ["いつも逃げて", "きたからだ。"]}, {"box": [625, 877, 660, 1005], "vertical": true, "font_size": 35, "lines_coords": [[[625.0, 877.0], [660.0, 877.0], [660.0, 1005.0], [625.0, 1005.0]]], "lines": ["．．．．．．"]}, {"box": [1284, 1389, 1467, 1621], "vertical": true, "font_size": 39, "lines_coords": [[[1427.0, 1389.0], [1467.0, 1389.0], [1467.0, 1518.0], [1427.0, 1518.0]], [[1377.0, 1389.0], [1417.0, 1389.0], [1417.0, 1621.0], [1377.0, 1621.0]], [[1331.0, 1389.0], [1366.0, 1389.0], [1368.0, 1619.0], [1333.0, 1619.0]], [[1284.0, 1389.0], [1324.0, 1389.0], [1324.0, 1593.0], [1284.0, 1593.0]]], "lines": ["将平君、", "伝説の刑事に", "なりたいって", "言ってたな。"]}, {"box": [107, 1509, 158, 1762], "vertical": true, "font_size": 47, "lines_coords": [[[107.0, 1511.0], [154.0, 1511.0], [154.0, 1762.0], [107.0, 1762.0]]], "lines": ["違いますね。"]}, {"box": [1420, 1810, 1464, 1966], "vertical": true, "font_size": 40, "lines_coords": [[[1422.0, 1811.0], [1462.0, 1811.0], [1462.0, 1966.0], [1422.0, 1966.0]]], "lines": ["簡単だ。"]}, {"box": [799, 1809, 908, 2062], "vertical": true, "font_size": 48, "lines_coords": [[[857.0, 1811.0], [906.0, 1811.0], [906.0, 1999.0], [857.0, 1999.0]], [[799.0, 1809.0], [845.0, 1809.0], [850.0, 2062.0], [803.0, 2062.0]]], "lines": ["俺の逆を", "やればいい。"]}], "img_path": "00177.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1366, 588, 1502, 782], "vertical": true, "font_size": 41, "lines_coords": [[[1462.0, 592.0], [1502.0, 592.0], [1502.0, 745.0], [1462.0, 745.0]], [[1415.0, 590.0], [1455.0, 590.0], [1455.0, 782.0], [1415.0, 782.0]], [[1366.0, 588.0], [1408.0, 588.0], [1408.0, 721.0], [1366.0, 721.0]]], "lines": ["あなたは", "優秀な刑事", "だった。"]}, {"box": [616, 492, 800, 836], "vertical": true, "font_size": 38, "lines_coords": [[[759.0, 492.0], [799.0, 492.0], [799.0, 810.0], [759.0, 810.0]], [[714.0, 494.0], [747.0, 494.0], [747.0, 719.0], [714.0, 719.0]], [[663.0, 494.0], [703.0, 494.0], [703.0, 836.0], [663.0, 836.0]], [[616.0, 492.0], [656.0, 492.0], [656.0, 738.0], [616.0, 738.0]]], "lines": ["母は言ってました。", "じいちゃんは", "いつもあなたのこと", "ほめてたって。"]}, {"box": [715, 923, 902, 1314], "vertical": true, "font_size": 43, "lines_coords": [[[848.0, 923.0], [902.0, 923.0], [902.0, 1026.0], [848.0, 1026.0]], [[806.0, 928.0], [845.0, 928.0], [845.0, 1085.0], [806.0, 1085.0]], [[754.0, 928.0], [801.0, 928.0], [801.0, 1314.0], [754.0, 1314.0]], [[717.0, 932.0], [749.0, 932.0], [749.0, 1132.0], [717.0, 1132.0]]], "lines": ["あと、", "あなたは", "いつも逃げてきたって", "言ったけど、"]}, {"box": [232, 574, 412, 785], "vertical": true, "font_size": 44, "lines_coords": [[[370.0, 576.0], [412.0, 576.0], [412.0, 731.0], [370.0, 731.0]], [[323.0, 576.0], [365.0, 576.0], [365.0, 731.0], [323.0, 731.0]], [[271.0, 574.0], [323.0, 574.0], [323.0, 698.0], [271.0, 698.0]], [[232.0, 578.0], [271.0, 578.0], [271.0, 785.0], [232.0, 785.0]]], "lines": ["あんなに", "努力する", "人間は", "いないって。"]}, {"box": [227, 925, 316, 1272], "vertical": true, "font_size": 40, "lines_coords": [[[269.0, 925.0], [316.0, 925.0], [316.0, 1272.0], [269.0, 1272.0]], [[229.0, 930.0], [262.0, 930.0], [262.0, 1155.0], [229.0, 1155.0]]], "lines": ["あの。ともだち«府が", "倒れた夜．．．．．"]}, {"box": [1474, 1464, 1568, 1699], "vertical": true, "font_size": 40, "lines_coords": [[[1525.0, 1469.0], [1565.0, 1469.0], [1565.0, 1696.0], [1525.0, 1696.0]], [[1474.0, 1464.0], [1513.0, 1464.0], [1518.0, 1671.0], [1478.0, 1671.0]]], "lines": ["僕にすべてを", "告白した後、"]}, {"box": [850, 1467, 985, 1865], "vertical": true, "font_size": 35, "lines_coords": [[[944.0, 1467.0], [984.0, 1467.0], [984.0, 1783.0], [