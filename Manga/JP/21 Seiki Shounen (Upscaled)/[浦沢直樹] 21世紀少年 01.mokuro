？"]}, {"box": [199, 796, 331, 1141], "vertical": true, "font_size": 38, "lines_coords": [[[290.0, 796.0], [330.0, 796.0], [330.0, 991.0], [290.0, 991.0]], [[243.0, 799.0], [283.0, 799.0], [283.0, 1141.0], [243.0, 1141.0]], [[199.0, 796.0], [232.0, 796.0], [232.0, 1040.0], [199.0, 1040.0]]], "lines": ["だから俺は", "スーパージェッター", "じゃねえって。"]}, {"box": [1363, 1296, 1506, 1530], "vertical": true, "font_size": 48, "lines_coords": [[[1452.0, 1296.0], [1506.0, 1296.0], [1506.0, 1387.0], [1452.0, 1387.0]], [[1406.0, 1298.0], [1455.0, 1296.0], [1459.0, 1420.0], [1410.0, 1422.0]], [[1363.0, 1298.0], [1403.0, 1298.0], [1408.0, 1530.0], [1368.0, 1530.0]]], "lines": ["私を", "殺しに", "来たんだろ？"]}, {"box": [241, 1679, 279, 1850], "vertical": true, "font_size": 33, "lines_coords": [[[241.0, 1680.0], [274.0, 1680.0], [274.0, 1844.0], [241.0, 1844.0]]], "lines": ["だろうな。"]}, {"box": [1312, 1675, 1495, 1926], "vertical": true, "font_size": 46, "lines_coords": [[[1455.0, 1675.0], [1495.0, 1675.0], [1490.0, 1870.0], [1450.0, 1870.0]], [[1403.0, 1678.0], [1455.0, 1678.0], [1455.0, 1811.0], [1403.0, 1811.0]], [[1354.0, 1678.0], [1408.0, 1678.0], [1408.0, 1800.0], [1354.0, 1800.0]], [[1312.0, 1678.0], [1352.0, 1678.0], [1352.0, 1926.0], [1312.0, 1926.0]]], "lines": ["この世界に", "入って、", "出口が", "見つからない。"]}], "img_path": "00132.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1380, 234, 1470, 443], "vertical": true, "font_size": 38, "lines_coords": [[[1429.0, 234.0], [1469.0, 234.0], [1469.0, 426.0], [1429.0, 426.0]], [[1380.0, 234.0], [1415.0, 234.0], [1420.0, 440.0], [1385.0, 440.0]]], "lines": ["ガキどもに", "見られたろ。"]}, {"box": [824, 386, 1012, 616], "vertical": true, "font_size": 44, "lines_coords": [[[963.0, 386.0], [1012.0, 386.0], [1012.0, 546.0], [963.0, 546.0]], [[920.0, 389.0], [963.0, 389.0], [963.0, 543.0], [920.0, 543.0]], [[871.0, 386.0], [911.0, 386.0], [911.0, 616.0], [871.0, 616.0]], [[824.0, 389.0], [867.0, 389.0], [867.0, 522.0], [824.0, 522.0]]], "lines": ["オバケが", "出るって", "噂になってる", "らしい。"]}, {"box": [639, 372, 739, 569], "vertical": true, "font_size": 50, "lines_coords": [[[698.0, 379.0], [738.0, 379.0], [738.0, 569.0], [698.0, 569.0]], [[639.0, 372.0], [700.0, 372.0], [700.0, 482.0], [639.0, 482.0]]], "lines": ["行く場所が", "ない。"]}, {"box": [171, 356, 311, 625], "vertical": true, "font_size": 43, "lines_coords": [[[262.0, 356.0], [311.0, 356.0], [311.0, 489.0], [262.0, 489.0]], [[220.0, 360.0], [260.0, 360.0], [260.0, 625.0], [220.0, 625.0]], [[171.0, 360.0], [210.0, 360.0], [210.0, 525.0], [171.0, 525.0]]], "lines": ["だから、", "ここに寝泊まり", "していた。"]}, {"box": [1325, 726, 1460, 977], "vertical": true, "font_size": 38, "lines_coords": [[[1420.0, 726.0], [1459.0, 726.0], [1455.0, 935.0], [1415.0, 935.0]], [[1370.0, 731.0], [1410.0, 731.0], [1410.0, 923.0], [1370.0, 923.0]], [[1326.0, 731.0], [1359.0, 731.0], [1359.0, 970.0], [1326.0, 970.0]]], "lines": ["情けねえな、", "あそこまで", "行った人間が"]}, {"box": [1096, 730, 1138, 938], "vertical": true, "font_size": 40, "lines_coords": [[[1096.0, 731.0], [1136.0, 731.0], [1136.0, 935.0], [1096.0, 935.0]]], "lines": ["助けてくれ。"]}, {"box": [304, 719, 541, 999], "vertical": true, "font_size": 45, "lines_coords": [[[501.0, 724.0], [541.0, 724.0], [541.0, 876.0], [501.0, 876.0]], [[454.0, 721.0], [494.0, 721.0], [494.0, 993.0], [454.0, 993.0]], [[400.0, 719.0], [449.0, 719.0], [449.0, 843.0], [400.0, 843.0]], [[358.0, 724.0], [398.0, 724.0], [398.0, 911.0], [358.0, 911.0]], [[304.0, 719.0], [358.0, 719.0], [358.0, 817.0], [304.0, 817.0]]], "lines": ["いきなり", "殴りつけといて、", "今度は", "助けてくれ", "かい。"]}, {"box": [1420, 1515, 1459, 1681], "vertical": true, "font_size": 33, "lines_coords": [[[1422.0, 1518.0], [1455.0, 1518.0], [1455.0, 1678.0], [1422.0, 1678.0]]], "lines": ["無理だよ。"]}, {"box": [656, 1167, 801, 1340], "vertical": true, "font_size": 47, "lines_coords": [[[749.0, 1167.0], [801.0, 1167.0], [801.0, 1289.0], [749.0, 1289.0]], [[703.0, 1167.0], [752.0, 1167.0], [752.0, 1291.0], [703.0, 1291.0]], [[656.0, 1169.0], [696.0, 1169.0], [700.0, 1340.0], [660.0, 1340.0]]], "lines": ["現実の", "世界に", "戻りたい。"]}, {"box": [830, 1511, 915, 1743], "vertical": true, "font_size": 36, "lines_coords": [[[874.0, 1511.0], [913.0, 1511.0], [913.0, 1743.0], [874.0, 1743.0]], [[831.0, 1516.0], [864.0, 1516.0], [864.0, 1682.0], [831.0, 1682.0]]], "lines": ["あんた、もう", "戻れない。"]}, {"box": [98, 1537, 269, 1882], "vertical": true, "font_size": 47, "lines_coords": [[[213.0, 1537.0], [262.0, 1537.0], [269.0, 1882.0], [220.0, 1882.0]], [[166.0, 1542.0], [206.0, 1542.0], [206.0, 1860.0], [166.0, 1860.0]], [[98.0, 1539.0], [149.0, 1537.0], [154.0, 1696.0], [103.0, 1699.0]]], "lines": ["現実の世界じゃ、", "死んじまったん", "だから。"]}, {"box": [822, 1926, 867, 2049], "vertical": true, "font_size": 42, "lines_coords": [[[822.0, 1926.0], [864.0, 1926.0], [867.0, 2046.0], [824.0, 2046.0]]], "lines": ["え．．．"]}], "img_path": "00133.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [417, 208, 473, 478], "vertical": true, "font_size": 47, "lines_coords": [[[417.0, 208.0], [468.0, 208.0], [473.0, 478.0], [421.0, 478.0]]], "lines": ["なんだって"]}, {"box": [358, 288, 400, 370], "vertical": true, "font_size": 47, "lines_coords": [[[358.0, 288.0], [400.0, 288.0], [400.0, 370.0], [358.0, 370.0]]], "lines": ["．．．？"]}], "img_path": "00134.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [168, 1717, 1206, 2071], "vertical": false, "font_size": 84, "lines_coords": [[[168.0, 1989.0], [1185.0, 1717.0], [1206.0, 1797.0], [189.0, 2071.0]]], "lines": ["いいのかわかるわけじゃないけど．．．"]}], "img_path": "00135.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [], "img_path": "00136.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1304, 157, 1435, 387], "vertical": true, "font_size": 36, "lines_coords": [[[1401.0, 159.0], [1434.0, 159.0], [1434.0, 335.0], [1401.0, 335.0]], [[1347.0, 157.0], [1389.0, 157.0], [1389.0, 276.0], [1347.0, 276.0]], [[1305.0, 157.0], [1338.0, 157.0], [1338.0, 382.0], [1305.0, 382.0]]], "lines": ["さーーさー", "みんな", "よっといで！！"]}, {"box": [175, 154, 367, 423], "vertical": true, "font_size": 39, "lines_coords": [[[318.0, 154.0], [367.0, 154.0], [367.0, 276.0], [318.0, 276.0]], [[278.0, 159.0], [311.0, 159.0], [311.0, 421.0], [278.0, 421.0]], [[229.0, 157.0], [262.0, 157.0], [262.0, 386.0], [229.0, 386.0]], [[180.0, 154.0], [220.0, 154.0], [215.0, 384.0], [175.0, 384.0]]], "lines": ["ここに", "取り出したるは", "みんなもよく", "ご存じの．．．："]}, {"box": [84, 166, 124, 494], "vertical": true, "font_size": 40, "lines_coords": [[[84.0, 166.0], [124.0, 166.0], [124.0, 492.0], [84.0, 492.0]]], "lines": ["第６話マネのマネ"]}, {"box": [209, 1025, 261, 1288], "vertical": true, "font_size": 40, "lines_coords": [[[213.0, 1031.0], [253.0, 1031.0], [253.0, 1286.0], [213.0, 1286.0]]], "lines": ["宇宙食だ！！"]}, {"box": [1315, 1024, 1448, 1378], "vertical": true, "font_size": 36, "lines_coords": [[[1406.0, 1024.0], [1445.0, 1024.0], [1448.0, 1373.0], [1408.0, 1373.0]], [[1359.0, 1024.0], [1399.0, 1024.0], [1399.0, 1291.0], [1359.0, 1291.0]], [[1317.0, 1026.0], [1347.0, 1026.0], [1347.0, 1289.0], [1317.0, 1289.0]]], "lines": ["アメリカ航空宇宙局", "あのＮＡＳＡが", "開発した．．．：！！"]}, {"box": [1403, 1528, 1443, 1680], "vertical": true, "font_size": 40, "lines_coords": [[[1403.0, 1528.0], [1443.0, 1528.0], [1443.0, 1680.0], [1403.0, 1680.0]]], "lines": ["宇宙食？"]}, {"box": [1017, 1500, 1113, 1745], "vertical": true, "font_size": 48, "lines_coords": [[[1066.0, 1500.0], [1113.0, 1500.0], [1113.0, 1741.0], [1066.0, 1741.0]], [[1017.0, 1500.0], [1066.0, 1500.0], [1066.0, 1624.0], [1017.0, 1624.0]]], "lines": ["食べられるの、", "それ？"]}, {"box": [822, 1502, 911, 1828], "vertical": true, "font_size": 41, "lines_coords": [[[869.0, 1502.0], [911.0, 1502.0], [911.0, 1696.0], [869.0, 1696.0]], [[822.0, 1502.0], [862.0, 1502.0], [862.0, 1828.0], [822.0, 1828.0]]], "lines": ["バカなこと", "聞いちゃいけない。"]}, {"box": [192, 1502, 432, 1811], "vertical": true, "font_size": 37, "lines_coords": [[[391.0, 1502.0], [431.0, 1502.0], [431.0, 1736.0], [391.0, 1736.0]], [[346.0, 1504.0], [379.0, 1504.0], [379.0, 1729.0], [346.0, 1729.0]], [[299.0, 1504.0], [332.0, 1504.0], [332.0, 1692.0], [299.0, 1692.0]], [[248.0, 1502.0], [288.0, 1502.0], [288.0, 1811.0], [248.0, 1811.0]], [[192.0, 1504.0], [232.0, 1504.0], [232.0, 1809.0], [192.0, 1809.0]]], "lines": ["アメリカでは", "なんとすでに", "２０万世帯の", "食卓で食べられて", "いるって代物だ！！"]}, {"box": [817, 1914, 910, 2120], "vertical": true, "font_size": 46, "lines_coords": [[[867.0, 1919.0], [909.0, 1919.0], [909.0, 2116.0], [867.0, 2116.0]], [[817.0, 1914.0], [867.0, 1914.0], [867.0, 2039.0], [817.0, 2039.0]]], "lines": ["おいしいの、", "それ？"]}], "img_path": "00137.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1427, 152, 1509, 344], "vertical": true, "font_size": 36, "lines_coords": [[[1469.0, 152.0], [1509.0, 152.0], [1509.0, 344.0], [1469.0, 344.0]], [[1427.0, 152.0], [1459.0, 152.0], [1459.0, 304.0], [1427.0, 304.0]]], "lines": ["よく聞いて", "くれた！！"]}, {"box": [981, 152, 1071, 345], "vertical": true, "font_size": 36, "lines_coords": [[[1033.0, 154.0], [1066.0, 154.0], [1066.0, 342.0], [1033.0, 342.0]], [[981.0, 152.0], [1021.0, 152.0], [1021.0, 307.0], [981.0, 307.0]]], "lines": ["これが実に", "うまい！！"]}, {"box": [698, 210, 881, 424], "vertical": true, "font_size": 41, "lines_coords": [[[838.0, 210.0], [881.0, 210.0], [881.0, 405.0], [838.0, 405.0]], [[792.0, 213.0], [831.0, 213.0], [831.0, 407.0], [792.0, 407.0]], [[745.0, 215.0], [787.0, 215.0], [787.0, 367.0], [745.0, 367.0]], [[698.0, 213.0], [738.0, 213.0], [738.0, 424.0], [698.0, 424.0]]], "lines": ["宇宙食って", "まずいって", "テレビで", "言ってたぜ。"]}, {"box": [1223, 963, 1502, 1307], "vertical": true, "font_size": 37, "lines_coords": [[[1459.0, 965.0], [1499.0, 965.0], [1502.0, 1232.0], [1462.0, 1232.0]], [[1413.0, 965.0], [1452.0, 965.0], [1452.0, 1272.0], [1413.0, 1272.0]], [[1361.0, 963.0], [1401.0, 963.0], [1406.0, 1207.0], [1366.0, 1207.0]], [[1321.0, 970.0], [1354.0, 970.0], [1354.0, 1305.0], [1321.0, 1305.0]], [[1272.0, 967.0], [1305.0, 967.0], [1305.0, 1153.0], [1272.0, 1153.0]], [[1223.0, 970.0], [1258.0, 970.0], [1260.0, 1284.0], [1225.0, 1284.0]]], "lines": ["無重力の中でも", "食べやすいものを", "ということで、", "最初に発明したのが", "アメリカの", "マクドナルド博士。"]}, {"box": [211, 588, 398, 802], "vertical": true, "font_size": 42, "lines_coords": [[[339.0, 590.0], [393.0, 588.0], [398.0, 693.0], [344.0, 696.0]], [[306.0, 597.0], [339.0, 597.0], [339.0, 785.0], [306.0, 785.0]], [[250.0, 592.0], [299.0, 592.0], [299.0, 717.0], [250.0, 717.0]], [[213.0, 597.0], [246.0, 597.0], [246.0, 801.0], [213.0, 801.0]]], "lines": ["そう、", "これまでは", "それが", "常識だった。"]}, {"box": [210, 960, 448, 1195], "vertical": true, "font_size": 41, "lines_coords": [[[407.0, 963.0], [447.0, 963.0], [447.0, 1134.0], [407.0, 1134.0]], [[358.0, 965.0], [398.0, 965.0], [398.0, 1192.0], [358.0, 1192.0]], [[316.0, 967.0], [349.0, 967.0], [349.0, 1132.0], [316.0, 1132.0]], [[264.0, 965.0], [304.0, 965.0], [304.0, 1195.0], [264.0, 1195.0]], [[210.0, 960.0], [264.0, 960.0], [264.0, 1061.0], [210.0, 1061.0]]], "lines": ["ところが、", "これがただの", "流動食で、", "味もそっ気も", "ない。"]}, {"box": [1281, 1420, 1516, 1696], "vertical": true, "font_size": 41, "lines_coords": [[[1467.0, 1420.0], [1516.0, 1420.0], [1516.0, 1546.0], [1467.0, 1546.0]], [[1424.0, 1425.0], [1464.0, 1425.0], [1464.0, 1657.0], [1424.0, 1657.0]], [[1380.0, 1429.0], [1413.0, 1429.0], [1413.0, 1696.0], [1380.0, 1696.0]], [[1333.0, 1429.0], [1366.0, 1429.0], [1366.0, 1614.0], [1333.0, 1614.0]], [[1281.0, 1432.0], [1321.0, 1432.0], [1321.0, 1668.0], [1281.0, 1668.0]]], "lines": ["それを", "改良しようと", "のりだしたのが", "フランスの", "マキシム博士。"]}, {"box": [1096, 1422, 1190, 1553], "vertical": true, "font_size": 41, "lines_coords": [[[1138.0, 1422.0], [1190.0, 1422.0], [1190.0, 1549.0], [1138.0, 1549.0]], [[1096.0, 1425.0], [1138.0, 1425.0], [1138.0, 1553.0], [1096.0, 1553.0]]], "lines": ["博士は", "考えた。"]}, {"box": [761, 1420, 999, 1694], "vertical": true, "font_