481.0], [787.0, 1481.0], [782.0, 1889.0], [719.0, 1889.0]]], "lines": ["！！", "あー", "あの『スーパー", "ジェッター』か！！"]}, {"box": [180, 1153, 218, 1345], "vertical": true, "font_size": 33, "lines_coords": [[[180.0, 1153.0], [213.0, 1153.0], [213.0, 1338.0], [180.0, 1338.0]]], "lines": ["ジェ．．．．．．？"]}, {"box": [171, 1525, 293, 1898], "vertical": true, "font_size": 48, "lines_coords": [[[239.0, 1525.0], [288.0, 1525.0], [288.0, 1898.0], [239.0, 1898.0]], [[171.0, 1528.0], [217.0, 1528.0], [217.0, 1792.0], [171.0, 1792.0]]], "lines": ["渝星号、流星号", "応答せよ！！"]}], "img_path": "00121.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1373, 178, 1523, 506], "vertical": true, "font_size": 44, "lines_coords": [[[1471.0, 178.0], [1523.0, 178.0], [1523.0, 283.0], [1471.0, 283.0]], [[1434.0, 187.0], [1467.0, 187.0], [1467.0, 450.0], [1434.0, 450.0]], [[1380.0, 180.0], [1427.0, 180.0], [1420.0, 506.0], [1373.0, 506.0]]], "lines": ["そう。", "あれに出てくる", "バクダンの名前だ。"]}, {"box": [871, 201, 959, 523], "vertical": true, "font_size": 40, "lines_coords": [[[918.0, 201.0], [958.0, 201.0], [958.0, 433.0], [918.0, 433.0]], [[871.0, 201.0], [911.0, 201.0], [911.0, 522.0], [871.0, 522.0]]], "lines": ["未来の国から", "やってきた．．．．．か。"]}, {"box": [248, 210, 337, 485], "vertical": true, "font_size": 41, "lines_coords": [[[295.0, 210.0], [337.0, 210.0], [332.0, 447.0], [290.0, 447.0]], [[248.0, 215.0], [288.0, 215.0], [288.0, 485.0], [248.0, 485.0]]], "lines": ["まあ、確かに", "俺はそうか．．．"]}, {"box": [1350, 780, 1534, 1008], "vertical": true, "font_size": 38, "lines_coords": [[[1490.0, 813.0], [1534.0, 813.0], [1534.0, 907.0], [1490.0, 907.0]], [[1445.0, 782.0], [1478.0, 782.0], [1478.0, 972.0], [1445.0, 972.0]], [[1394.0, 782.0], [1434.0, 782.0], [1434.0, 975.0], [1394.0, 975.0]], [[1352.0, 780.0], [1385.0, 780.0], [1385.0, 1007.0], [1352.0, 1007.0]]], "lines": ["．．．で、", "その反陽子", "ばくだんが", "どうしたの？"]}, {"box": [648, 750, 830, 1075], "vertical": true, "font_size": 42, "lines_coords": [[[789.0, 750.0], [829.0, 750.0], [829.0, 951.0], [789.0, 951.0]], [[735.0, 754.0], [789.0, 754.0], [789.0, 855.0], [735.0, 855.0]], [[693.0, 754.0], [733.0, 754.0], [733.0, 1075.0], [693.0, 1075.0]], [[651.0, 754.0], [684.0, 754.0], [684.0, 1026.0], [651.0, 1026.0]]], "lines": ["あ．．．．．あと、", "『Ｗ３", "ワンダースリー", "にも出てくるよ。"]}, {"box": [215, 787, 299, 958], "vertical": true, "font_size": 38, "lines_coords": [[[257.0, 789.0], [299.0, 789.0], [299.0, 909.0], [257.0, 909.0]], [[215.0, 787.0], [248.0, 787.0], [248.0, 951.0], [215.0, 951.0]]], "lines": ["反陽子", "ばくだん"]}, {"box": [1280, 1539, 1506, 1818], "vertical": true, "font_size": 39, "lines_coords": [[[1457.0, 1539.0], [1506.0, 1539.0], [1506.0, 1661.0], [1457.0, 1661.0]], [[1417.0, 1546.0], [1450.0, 1546.0], [1450.0, 1809.0], [1417.0, 1809.0]], [[1370.0, 1544.0], [1403.0, 1544.0], [1403.0, 1816.0], [1370.0, 1816.0]], [[1319.0, 1542.0], [1359.0, 1542.0], [1359.0, 1811.0], [1319.0, 1811.0]]], "lines": ["地球が", "いい星だったら", "爆発しないけど、", "悪い星だったら"]}, {"box": [911, 1195, 994, 1423], "vertical": true, "font_size": 33, "lines_coords": [[[958.0, 1197.0], [991.0, 1197.0], [991.0, 1422.0], [958.0, 1422.0]], [[911.0, 1195.0], [944.0, 1195.0], [944.0, 1359.0], [911.0, 1359.0]]], "lines": ["聞きたいのは", "こっちだ。"]}, {"box": [632, 1556, 745, 1703], "vertical": true, "font_size": 56, "lines_coords": [[[684.0, 1560.0], [745.0, 1560.0], [745.0, 1703.0], [684.0, 1703.0]], [[632.0, 1556.0], [684.0, 1556.0], [684.0, 1699.0], [632.0, 1699.0]]], "lines": ["一瞬で", "ボン！！"]}, {"box": [215, 1150, 351, 1381], "vertical": true, "font_size": 37, "lines_coords": [[[314.0, 1155.0], [346.0, 1155.0], [346.0, 1380.0], [314.0, 1380.0]], [[262.0, 1150.0], [302.0, 1150.0], [302.0, 1307.0], [262.0, 1307.0]], [[215.0, 1153.0], [255.0, 1153.0], [255.0, 1342.0], [215.0, 1342.0]]], "lines": ["なんにしても", "ネタ元は", "漫画か．．．"]}], "img_path": "00122.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1286, 1631, 1474, 1903], "vertical": true, "font_size": 41, "