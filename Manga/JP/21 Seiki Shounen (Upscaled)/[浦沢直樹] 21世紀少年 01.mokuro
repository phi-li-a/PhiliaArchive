], [1427.0, 1446.0], [1387.0, 1446.0]]], "lines": ["い．．．いや、", "そんなこと", "ないって。"]}, {"box": [1038, 1275, 1174, 1503], "vertical": true, "font_size": 41, "lines_coords": [[[1131.0, 1277.0], [1174.0, 1277.0], [1174.0, 1429.0], [1131.0, 1429.0]], [[1087.0, 1275.0], [1127.0, 1275.0], [1127.0, 1502.0], [1087.0, 1502.0]], [[1038.0, 1277.0], [1078.0, 1277.0], [1078.0, 1502.0], [1038.0, 1502.0]]], "lines": ["ゆっくり", "話したほうが", "いいって．．．"]}, {"box": [753, 1275, 912, 1519], "vertical": true, "font_size": 41, "lines_coords": [[[867.0, 1277.0], [909.0, 1277.0], [909.0, 1502.0], [867.0, 1502.0]], [[810.0, 1275.0], [857.0, 1275.0], [857.0, 1518.0], [810.0, 1518.0]], [[756.0, 1279.0], [789.0, 1279.0], [789.0, 1497.0], [756.0, 1497.0]]], "lines": ["困ります！！", "そんなこと、", "無理です！！"]}, {"box": [1017, 1853, 1051, 1911], "vertical": true, "font_size": 34, "lines_coords": [[[1017.0, 1853.0], [1051.0, 1853.0], [1051.0, 1911.0], [1017.0, 1911.0]]], "lines": ["？"]}], "img_path": "00202.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1377, 168, 1479, 445], "vertical": true, "font_size": 44, "lines_coords": [[[1436.0, 173.0], [1478.0, 173.0], [1478.0, 353.0], [1436.0, 353.0]], [[1377.0, 168.0], [1424.0, 168.0], [1424.0, 445.0], [1377.0, 445.0]]], "lines": ["ＩＣＵは", "あそこです！！"]}, {"box": [1198, 39, 1267, 219], "vertical": true, "font_size": 69, "lines_coords": [[[1198.0, 39.0], [1267.0, 39.0], [1267.0, 219.0], [1198.0, 219.0]]], "lines": ["かッ"]}, {"box": [541, 47, 607, 218], "vertical": true, "font_size": 66, "lines_coords": [[[541.0, 47.0], [607.0, 47.0], [607.0, 218.0], [541.0, 218.0]]], "lines": ["Ｈッ"]}, {"box": [178, 222, 342, 428], "vertical": true, "font_size": 48, "lines_coords": [[[285.0, 225.0], [335.0, 222.0], [342.0, 426.0], [292.0, 428.0]], [[239.0, 229.0], [281.0, 229.0], [281.0, 410.0], [239.0, 410.0]], [[178.0, 229.0], [229.0, 229.0], [229.0, 367.0], [178.0, 367.0]]], "lines": ["患者は今、", "危篤状態", "です！！"]}, {"box": [1392, 822, 1481, 946], "vertical": true, "font_size": 44, "lines_coords": [[[1429.0, 822.0], [1481.0, 822.0], [1481.0, 946.0], [1429.0, 946.0]], [[1392.0, 825.0], [1427.0, 825.0], [1427.0, 939.0], [1392.0, 939.0]]], "lines": ["なんだ", "．．．．．．？"]}, {"box": [185, 796, 346, 1207], "vertical": true, "font_size": 45, "lines_coords": [[[302.0, 799.0], [342.0, 799.0], [342.0, 1026.0], [302.0, 1026.0]], [[241.0, 796.0], [288.0, 796.0], [288.0, 1075.0], [241.0, 1075.0]], [[185.0, 796.0], [234.0, 796.0], [234.0, 1207.0], [185.0, 1207.0]]], "lines": ["自白剤投与", "なんかしたら", "死んでしまいます！！"]}, {"box": [1293, 1333, 1476, 1676], "vertical": true, "font_size": 38, "lines_coords": [[[1436.0, 1333.0], [1476.0, 1333.0], [1476.0, 1596.0], [1436.0, 1596.0]], [[1387.0, 1333.0], [1427.0, 1333.0], [1427.0, 1497.0], [1387.0, 1497.0]], [[1338.0, 1335.0], [1377.0, 1335.0], [1377.0, 1638.0], [1338.0, 1638.0]], [[1295.0, 1335.0], [1328.0, 1335.0], [1328.0, 1675.0], [1295.0, 1675.0]]], "lines": ["今は患者一人の", "命よりも、", "地球全体の生命が", "かかっているんだ！！"]}, {"box": [867, 1331, 951, 1523], "vertical": true, "font_size": 37, "lines_coords": [[[909.0, 1331.0], [951.0, 1331.0], [951.0, 1453.0], [909.0, 1453.0]], [[867.0, 1333.0], [899.0, 1333.0], [899.0, 1518.0], [867.0, 1518.0]]], "lines": ["そ．．．．．．", "そんな．．．．．"]}, {"box": [635, 1326, 778, 1561], "vertical": true, "font_size": 43, "lines_coords": [[[721.0, 1326.0], [778.0, 1326.0], [778.0, 1417.0], [721.0, 1417.0]], [[686.0, 1333.0], [719.0, 1333.0], [719.0, 1560.0], [686.0, 1560.0]], [[635.0, 1331.0], [674.0, 1331.0], [674.0, 1525.0], [635.0, 1525.0]]], "lines": ["彼に", "問いただせば", "答えが．．．"]}, {"box": [1293, 1795, 1475, 2068], "vertical": true, "font_size": 39, "lines_coords": [[[1438.0, 1800.0], [1471.0, 1800.0], [1471.0, 1987.0], [1438.0, 1987.0]], [[1387.0, 1795.0], [1427.0, 1795.0], [1422.0, 2027.0], [1382.0, 2027.0]], [[1338.0, 1797.0], [1380.0, 1797.0], [1380.0, 1950.0], [1338.0, 1950.0]], [[1293.0, 1800.0], [1333.0, 1800.0], [1333.0, 2048.0], [1293.0, 2048.0]]], "lines": ["佐田清志は", "”ともだち”に", "最も近い", "パー