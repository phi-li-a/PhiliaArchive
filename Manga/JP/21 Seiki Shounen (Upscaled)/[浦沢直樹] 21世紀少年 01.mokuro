], "vertical": false, "font_size": 57, "lines_coords": [[[458.0, 442.0], [840.0, 238.0], [864.0, 289.0], [480.0, 493.0]], [[463.0, 491.0], [885.0, 287.0], [908.0, 346.0], [487.0, 550.0]]], "lines": ["ファンファイナンフフフェイン", "いつでもファンディングファイルの"]}, {"box": [241, 196, 393, 283], "vertical": false, "font_size": 38, "lines_coords": [[[246.0, 199.0], [353.0, 199.0], [353.0, 234.0], [246.0, 234.0]], [[241.0, 243.0], [391.0, 243.0], [391.0, 283.0], [241.0, 283.0]]], "lines": ["国連軍", "総司令部"]}, {"box": [850, 1148, 1082, 1455], "vertical": true, "font_size": 38, "lines_coords": [[[1045.0, 1153.0], [1078.0, 1153.0], [1078.0, 1300.0], [1045.0, 1300.0]], [[988.0, 1148.0], [1031.0, 1148.0], [1035.0, 1352.0], [993.0, 1352.0]], [[946.0, 1150.0], [986.0, 1150.0], [986.0, 1455.0], [946.0, 1455.0]], [[902.0, 1150.0], [935.0, 1150.0], [935.0, 1338.0], [902.0, 1338.0]], [[850.0, 1150.0], [892.0, 1150.0], [892.0, 1284.0], [850.0, 1284.0]]], "lines": ["あなたが", "いなければ、", "今のような平和は", "訪れません", "でした。"]}, {"box": [1251, 1877, 1443, 2165], "vertical": true, "font_size": 39, "lines_coords": [[[1392.0, 1877.0], [1443.0, 1877.0], [1443.0, 1982.0], [1392.0, 1982.0]], [[1352.0, 1884.0], [1385.0, 1884.0], [1385.0, 2144.0], [1352.0, 2144.0]], [[1300.0, 1884.0], [1333.0, 1884.0], [1333.0, 2107.0], [1300.0, 2107.0]], [[1251.0, 1877.0], [1291.0, 1877.0], [1293.0, 2165.0], [1253.0, 2165.0]]], "lines": ["まず、", "我々はあなたに", "心から感謝の", "言葉を贈ります。"]}, {"box": [981, 1814, 1067, 2022], "vertical": true, "font_size": 40, "lines_coords": [[[1026.0, 1814.0], [1066.0, 1814.0], [1066.0, 2008.0], [1026.0, 2008.0]], [[981.0, 1814.0], [1021.0, 1814.0], [1021.0, 2022.0], [981.0, 2022.0]]], "lines": ["ありがとう", "ございます。"]}, {"box": [232, 1814, 363, 2060], "vertical": true, "font_size": 37, "lines_coords": [[[323.0, 1814.0], [363.0, 1814.0], [363.0, 1971.0], [323.0, 1971.0]], [[276.0, 1814.0], [316.0, 1814.0], [316.0, 2060.0], [276.0, 2060.0]], [[232.0, 1818.0], [264.0, 1818.0], [264.0, 2017.0], [232.0, 2017.0]]], "lines": ["あなたは", "真の英雄です、", "ケンヂさん。"]}], "img_path": "00076.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1338, 150, 1475, 379], "vertical": true, "font_size": 41, "lines_coords": [[[1434.0, 152.0], [1474.0, 152.0], [1474.0, 309.0], [1434.0, 309.0]], [[1382.0, 150.0], [1422.0, 150.0], [1427.0, 379.0], [1387.0, 379.0]], [[1338.0, 152.0], [1380.0, 152.0], [1380.0, 281.0], [1338.0, 281.0]]], "lines": ["別に俺は", "そんなんじゃ", "ねえよ。"]}, {"box": [510, 150, 793, 421], "vertical": true, "font_size": 41, "lines_coords": [[[749.0, 154.0], [792.0, 154.0], [792.0, 271.0], [749.0, 271.0]], [[700.0, 150.0], [742.0, 150.0], [745.0, 398.0], [703.0, 398.0]], [[656.0, 152.0], [696.0, 152.0], [696.0, 384.0], [656.0, 384.0]], [[609.0, 152.0], [649.0, 152.0], [649.0, 421.0], [609.0, 421.0]], [[562.0, 152.0], [602.0, 152.0], [602.0, 309.0], [562.0, 309.0]], [[510.0, 150.0], [550.0, 150.0], [555.0, 321.0], [515.0, 321.0]]], "lines": ["調査は", "進んでいます。", "ゲンジ一派の", "リーダーからも", "事情聴取", "しました。"]}, {"box": [1429, 1600, 1478, 1760], "vertical": true, "font_size": 49, "lines_coords": [[[1429.0, 1600.0], [1478.0, 1600.0], [1478.0, 1760.0], [1429.0, 1760.0]]], "lines": ["ふふ．．．．．"]}, {"box": [869, 1117, 1005, 1385], "vertical": true, "font_size": 40, "lines_coords": [[[963.0, 1122.0], [1005.0, 1122.0], [1005.0, 1284.0], [963.0, 1284.0]], [[916.0, 1117.0], [958.0, 1117.0], [958.0, 1275.0], [916.0, 1275.0]], [[871.0, 1120.0], [906.0, 1120.0], [904.0, 1385.0], [869.0, 1385.0]]], "lines": ["ヨシツネ、", "ちゃんと", "しゃべれたか？"]}, {"box": [591, 1113, 778, 1401], "vertical": true, "font_size": 38, "lines_coords": [[[721.0, 1115.0], [773.0, 1113.0], [778.0, 1237.0], [726.0, 1239.0]], [[686.0, 1122.0], [719.0, 1122.0], [719.0, 1401.0], [686.0, 1401.0]], [[639.0, 1120.0], [672.0, 1120.0], [672.0, 1385.0], [639.0, 1385.0]], [[592.0, 1120.0], [625.0, 1120.0], [625.0, 1364.0], [592.0, 1364.0]]], "lines": ["とても", "シャイな方です。", "とてもリーダー", "とは思えない。"]}, {"box": [822, 1600, 1108, 1875], "vertical": true, "font_size": 43, "lines_coords": [[[1061.0, 1605.0], [1108.0, 1605.0], [1108.0, 1875.0], [1061.0, 1875.0]], [[1017.0, 1605.0], [1056.0, 1605.0], [1056.0, 1872.0], [1017.0, 1872.0]], [[967.0, 1605.0], [1010.0, 1605.0], [1010.0, 1771.0], [967.0, 1771.0]], [[920.0, 1603.0], [960.0, 1603.0], [960.0, 1797.0], [920.0, 1797.0]], [[869.0, 1600.0], [911.0, 1600.0], [913.0, 1757.0], [871.0, 1757.0]], [[822.0, 1600.0], [871.0, 1600.0], [871.0, 1741.0], [822.0, 1741.0]]], "lines": ["ヨシツネさんが", "リーダーだった", "からこそ、", "多くの血が", "流れずに", "すんだ。"]}, {"box": [171, 1598, 306, 1924], "vertical": true, "font_size": 42, "lines_coords": [[[264.0, 1603.0], [304.0, 1603.0], [304.0, 1811.0], [264.0, 1811.0]], [[210.0, 1598.0], [264.0, 1598.0], [264.0, 1694.0], [210.0, 1694.0]], [[171.0, 1603.0], [203.0, 1603.0], [208.0, 1924.0], [175.0, 1924.0]]], "lines": ["そのとおり。", "よく", "わかってんじゃん。"]}], "img_path": "00077.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1370, 330, 1520, 609], "vertical": true, "font_size": 55, "lines_coords": [[[1464.0, 332.0], [1520.0, 332.0], [1520.0, 424.0], [1464.0, 424.0]], [[1422.0, 332.0], [1471.0, 332.0], [1464.0, 609.0], [1415.0, 609.0]], [[1370.0, 330.0], [1431.0, 330.0], [1431.0, 445.0], [1370.0, 445.0]]], "lines": ["私は", "プロファイラー", "です。"]}, {"box": [735, 215, 778, 375], "vertical": true, "font_size": 43, "lines_coords": [[[735.0, 215.0], [778.0, 215.0], [778.0, 367.0], [735.0, 367.0]]], "lines": ["プロ．．．．．．"]}, {"box": [213, 213, 306, 372], "vertical": true, "font_size": 49, "lines_coords": [[[250.0, 213.0], [306.0, 213.0], [306.0, 307.0], [250.0, 307.0]], [[213.0, 217.0], [255.0, 217.0], [255.0, 372.0], [213.0, 372.0]]], "lines": ["なん", "だって？"]}, {"box": [1457, 703, 1502, 994], "vertical": true, "font_size": 40, "lines_coords": [[[1462.0, 703.0], [1502.0, 703.0], [1497.0, 986.0], [1457.0, 986.0]]], "lines": ["プロファイラー。"]}, {"box": [232, 705, 464, 1012], "vertical": true, "font_size": 40, "lines_coords": [[[421.0, 707.0], [461.0, 707.0], [461.0, 972.0], [421.0, 972.0]], [[374.0, 707.0], [414.0, 707.0], [414.0, 1012.0], [374.0, 1012.0]], [[328.0, 705.0], [367.0, 705.0], [363.0, 935.0], [323.0, 935.0]], [[278.0, 707.0], [318.0, 707.0], [318.0, 975.0], [278.0, 975.0]], [[232.0, 710.0], [274.0, 710.0], [274.0, 836.0], [232.0, 836.0]]], "lines": ["人類を未曾有の", "危機に追い込んだ", "〝ともだち〟の", "内面を調査して", "います。"]}, {"box": [1328, 1225, 1509, 1456], "vertical": true, "font_size": 38, "lines_coords": [[[1469.0, 1228.0], [1509.0, 1228.0], [1509.0, 1382.0], [1469.0, 1382.0]], [[1420.0, 1225.0], [1459.0, 1225.0], [1459.0, 1453.0], [1420.0, 1453.0]], [[1373.0, 1228.0], [1413.0, 1228.0], [1413.0, 1455.0], [1373.0, 1455.0]], [[1328.0, 1230.0], [1361.0, 1230.0], [1361.0, 1413.0], [1328.0, 1413.0]]], "lines": ["あなたは", "どもだちが", "誰だか知って", "いますか？"]}, {"box": [1415, 1703, 1502, 1858], "vertical": true, "font_size": 40, "lines_coords": [[[1467.0, 1710.0], [1499.0, 1710.0], [1499.0, 1858.0], [1467.0, 1858.0]], [[1415.0, 1703.0], [1462.0, 1703.0], [1462.0, 1790.0], [1415.0, 1790.0]]], "lines": ["心当たり", "は？"]}, {"box": [241, 1239, 282, 1410], "vertical": true, "font_size": 40, "lines_coords": [[[241.0, 1239.0], [281.0, 1239.0], [281.0, 1406.0], [241.0, 1406.0]]], "lines": ["知らねえ。"]}, {"box": [688, 1701, 727, 1932], "vertical": true, "font_size": 33, "lines_coords": [[[688.0, 1701.0], [721.0, 1701.0], [721.0, 1924.0], [688.0, 1924.0]]], "lines": ["知らねえ．．．"]}], "img_path": "00078.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1338, 208, 1481, 405], "vertical": true, "font_size": 50, "lines_coords": [[[1422.0, 208.0], [1481.0, 208.0], [1481.0, 337.0], [1422.0, 337.0]], [[1382.0, 213.0], [1434.0, 213.0], [1434.0, 337.0], [1382.0, 337.0]], [[1338.0, 215.0], [1377.0, 215.0], [1377.0, 405.0], [1338.0, 405.0]]], "lines": ["これは", "知って", "いますね？"]}, {"box": [328, 166, 475, 257], "vertical": false, "font_size": 30.0, "lines_coords": [[[358.0, 166.0], [475.0, 199.0], [466.0, 232.0], [349.0, 199.0]], [[335.0, 189.0], [475.0, 232.0], [468.0, 257.0], [328.0, 215.0]]], "lines": ["ドラカンチャーメンの", "１９９９年１１月１９日土に"]}, {"box": [1434, 1047, 1474, 1201], "vertical": true, "font_size": 40, "lines_coords": [[[1434.0, 1047.0], [1474.0, 1047.0], [1474.0, 1200.0], [1434.0, 1200.0]]], "lines": ["ああ．．．．．"]}, {"box": [662, 625, 841, 890], "vertical": true, "font_size": 41, "lines_coords": [[[801.0, 625.0], [841.0, 625.0], [841.0, 817.0], [801.0, 817.0]], [[749.0, 625.0], [799.0, 625.0], [799.0, 747.0], [749.0, 747.0]], [[707.0, 630.0], [747.0, 630.0], [747.0, 890.0], [707.0, 890.0]], [[663.0, 630.0], [696.0, 630.0], [696.0, 832.0], [663.0, 832.0]]], "lines": ["あなた方が", "書いた", "〝よげんの書〟の", "コピーです。"]}, {"box": [853, 1042, 1005, 1240], "vertical": true, "font_size": 48, "lines_coords": [[[944.0, 1042.0], [1005.0, 1042.0], [1005.0, 1134.0], [944.0, 1134.0]], [[904.0, 1047.0], [946.0, 1047.0], [946.0, 1204.0], [904.0, 1204.0]], [[857.0, 1045.0], [899.0, 1045.0], [895.0, 1237.0], [853.0, 1237.0]]], "lines": ["俺が", "ガキの頃", "書いた．．．"]}, {"box": [688, 1045, 775, 1240], "vertical": true, "font_size": 41, "lines_coords": [[[726.0, 1045.0], [775.0, 1045.0], [775.0, 1169.0], [726.0, 1169.0]], [[688.0, 1050.0], [721.0, 1050.0], [721.0, 1225.0], [688.0, 1225.0]]], "lines": ["そして", "こちら．．．"]}, {"box": [1282, 1570, 1416, 1892], "vertical": true, "font_size": 38, "lines_coords": [[[1375.0, 1575.0], [1415.0, 1575.0], [1410.0, 1797.0], [1370.0, 1797.0]], [[1328.0, 1570.0], [1368.0, 1570.0], [1368.0, 1877.0], [1328.0, 1877.0]], [[1284.0, 1577.0], [1317.0, 1577.0], [1317.0, 1891.0], [1284.0, 1891.0]]], "lines": ["”ともだち〟が", "書いたと言われる", "しんよげんの書類。"]}, {"box": [1345, 2116, 1459, 2196], "vertical": false, "font_size": 45, "lines_coords": [[[1345.0, 2153.0], [1443.0, 2116.0], [1459.0, 2158.0], [1361.0, 2196.0]]], "lines": ["「りょうは"]}, {"box": [1160, 2156, 1506, 2364], "vertical": false, "font_size": 55.0, "lines_coords": [[[1160.0, 2271.0], [1485.0, 2156.0], [1506.0, 2210.0], [1181.0, 2325.0]], [[1195.0, 2315.0], [1438.0, 2228.0], [1455.0, 2278.0], [1211.0, 2364.0]]], "lines": ["おせしいいじゃうけども、", "いつのようになっているのですが、"]}, {"box": [185, 2144, 428, 2287], "vertical": false, "font_size": 44.0, "lines_coords": [[[185.0, 2212.0], [417.0, 2144.0], [428.0, 2182.0], [196.0, 2250.0]], [[187.0, 2240.0], [407.0, 2191.0], [417.0, 2238.0], [196.0, 2287.0]]], "lines": ["そして、せかしだいところから", "せかしだいじょっとやったんだようするだろう。"]}], "img_path": "00079.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1382, 208, 1520, 382], "vertical": true, "font_size": 43, "lines_coords": [[[1471.0, 208.0], [1520.0, 208.0], [1520.0, 335.0], [1471.0, 335.0]], [[1429.0, 213.0], [1469.0, 213.0], [1469.0, 370.0], [1429.0, 370.0]], [[1382.0, 213.0], [1422.0, 213.0], [1422.0, 382.0], [1382.0, 382.0]]], "lines": ["それは", "俺達には", "関係ねえ。"]}, {"box": [653, 98, 839, 440], "vertical": true, "font_size": 41, "lines_coords": [[[796.0, 105.0], [836.0, 105.0], [836.0, 440.0], [796.0, 440.0]], [[749.0, 100.0], [785.0, 100.0], [787.0, 365.0], [752.0, 365.0]], [[698.0, 98.0], [747.0, 98.0], [747.0, 222.0], [698.0, 222.0]], [[653.0, 98.0], [693.0, 98.0], [696.0, 421.0], [656.0, 421.0]]], "lines": ["あともだち。ランドの", "アトラクション", "として", "作られたものです。"]}, {"box": [1394, 541, 1529, 810], "vertical": true, "font_size": 40, "lines_coords": [[[1488.0, 546.0], [1527.0, 546.0], [1527.0, 742.0], [1488.0, 742.0]], [[1436.0, 541.0], [1485.0, 541.0], [1485.0, 667.0], [1436.0, 667.0]], [[1394.0, 546.0], [1427.0, 546.0], [1427.0, 808.0], [1394.0, 808.0]]], "lines": ["ケンヂさん、", "あなた", "ご存じですか？"]}, {"box": [1382, 993, 1527, 1230], "vertical": true, "font_size": 47, "lines_coords": [[[1467.0, 993.0], [1527.0, 993.0], [1527.0, 1101.0], [1467.0, 1101.0]], [[1429.0, 1003.0], [1469.0, 1003.0], [1469.0, 1230.0], [1429.0, 1230.0]], [[1382.0, 1000.0], [1422.0, 1000.0], [1422.0, 1169.0], [1382.0, 1169.0]]], "lines": ["ああ、", "ヨシツネ達に", "聞いたよ。"]}, {"box": [943, 543, 1028, 902], "vertical": true, "font_size": 36, "lines_coords": [[[988.0, 543.0], [1028.0, 543.0], 