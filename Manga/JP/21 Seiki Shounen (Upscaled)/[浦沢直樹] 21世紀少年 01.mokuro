 1413.0], [925.0, 1446.0], [778.0, 1446.0]], [[773.0, 1450.0], [909.0, 1450.0], [909.0, 1483.0], [773.0, 1483.0]]], "lines": ["単行本編集責任ムーーム・", "自石幹人"]}, {"box": [796, 1528, 902, 1553], "vertical": false, "font_size": 25, "lines_coords": [[[796.0, 1528.0], [902.0, 1528.0], [902.0, 1553.0], [796.0, 1553.0]]], "lines": ["単行本編集"]}, {"box": [696, 1556, 998, 1591], "vertical": false, "font_size": 33, "lines_coords": [[[696.0, 1556.0], [998.0, 1558.0], [998.0, 1591.0], [696.0, 1589.0]]], "lines": ["生川遥・満留綾子"]}, {"box": [763, 1635, 937, 1696], "vertical": false, "font_size": 25.5, "lines_coords": [[[763.0, 1635.0], [937.0, 1635.0], [937.0, 1661.0], [763.0, 1661.0]], [[780.0, 1671.0], [920.0, 1671.0], [920.0, 1696.0], [780.0, 1696.0]]], "lines": ["アートディレクション", "海野一雄"]}, {"box": [813, 1743, 883, 1769], "vertical": false, "font_size": 26, "lines_coords": [[[813.0, 1743.0], [883.0, 1743.0], [883.0, 1769.0], [813.0, 1769.0]]], "lines": ["デザイン"]}, {"box": [613, 1771, 1082, 1807], "vertical": false, "font_size": 33, "lines_coords": [[[613.0, 1774.0], [1082.0, 1771.0], [1082.0, 1804.0], [613.0, 1807.0]]], "lines": ["吉村勲＋ベイブリッジ・スタジオ"]}, {"box": [539, 1883, 1162, 2027], "vertical": false, "font_size": 28, "lines_coords": [[[834.0, 1886.0], [867.0, 1886.0], [867.0, 1905.0], [834.0, 1905.0]], [[703.0, 1994.0], [995.0, 1989.0], [995.0, 2022.0], [703.0, 2027.0]], [[663.0, 1910.0], [1040.0, 1910.0], [1040.0, 1940.0], [663.0, 1940.0]], [[539.0, 1952.0], [1157.0, 1952.0], [1157.0, 1982.0], [539.0, 1982.0]]], "lines": ["カッ", "完全版編集２０１７年", "「週刊ビッグコミックスピリッツ", "２００７年第４・５合併号〜第１０号、第１２号〜第１４号"]}, {"box": [586, 2064, 1113, 2186], "vertical": false, "font_size": 30, "lines_coords": [[[609.0, 2062.0], [1089.0, 2065.0], [1089.0, 2102.0], [609.0, 2099.0]], [[663.0, 2100.0], [1035.0, 2100.0], [1035.0, 2127.0], [663.0, 2127.0]], [[677.0, 2126.0], [1019.0, 2126.0], [1019.0, 2160.0], [677.0, 2160.0]], [[592.0, 2158.0], [1103.0, 2158.0], [1103.0, 2186.0], [592.0, 2186.0]]], "lines": ["●本曲の一部または全部を無断で、こんなんじゃ「複製、転職、被写（コピー）、なぜ乾きますこしょ", "スキャン、デジタル化、さん上流、放送等をすることは、", "いろいろインスルは一人の人気をすると、著作権上での例外を除き禁止されています。なんでしょうか。", "代行来者などの第三者によお兄ちゃん、お子様はも認められておりません。"]}, {"box": [576, 2066, 1122, 2189], "vertical": false, "font_size": 123, "lines_coords": [[[576.0, 2066.0], [1122.0, 2066.0], [1122.0, 2189.0], [576.0, 2189.0]]], "lines": ["本日の一部には金融機関が大阪ではなく、スポンシーデンタル化していますが、数年間程度での時から発生されます。代表的なのかも知れませんの事故との男性になっている時には、新規模なのです。"]}, {"box": [690, 2226, 1000, 2311], "vertical": false, "font_size": 29, "lines_coords": [[[719.0, 2224.0], [979.0, 2224.0], [979.0, 2252.0], [719.0, 2252.0]], [[712.0, 2276.0], [986.0, 2276.0], [986.0, 2310.0], [712.0, 2310.0]]], "lines": ["ＪＡＳＲＡＣ曲Ｖ７６５ＳＩＰＩ", "○ＳＨＯＧＡＫＵＫＡＮ－２０１"]}], "img_path": "00213.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [417, 1497, 592, 1523], "vertical": false, "font_size": 26, "lines_coords": [[[417.0, 1497.0], [592.0, 1497.0], [592.0, 1523.0], [417.0, 1523.0]]], "lines": ["浦沢直樹"]}, {"box": [138, 1408, 1244, 1760], "vertical": false, "font_size": 116.25, "lines_coords": [[[222.0, 1417.0], [421.0, 1417.0], [421.0, 1457.0], [222.0, 1457.0]], [[405.0, 1422.0], [1244.0, 1422.0], [1244.0, 1455.0], [405.0, 1455.0]], [[138.0, 1408.0], [827.0, 1408.0], [827.0, 1760.0], [138.0, 1760.0]], [[414.0, 1567.0], [836.0, 1567.0], [836.0, 1607.0], [414.0, 1607.0]]], "lines": ["２０１４年書", "２１世紀少年「完全版．．．」デジタルＶｅｒ．＿上", "まあ、そういえば、大丈夫だから、僕は自分たち、女性的には、大学になって安定されています。", "Ｇ．．．１．０浦沢直樹ノ小学館ｗｅｒｋｕｒ．»"]}, {"box": [417, 1703, 1429, 1753], "vertical": false, "font_size": 47, "lines_coords": [[[417.0, 1703.0], [1429.0, 1706.0], [1429.0, 1753.0], [417.0, 1750.0]]], "lines": ["〒１０１－８０１．東京都千代田区一ツ橋２・３－１"]}, {"box": [224, 1858, 1026, 1891], "vertical": false, "font_size": 33, "lines_coords": [[[224.0, 1858.0], [1026.0, 1858.0], [1026.0, 1891.0], [224.0, 1891.0]]], "lines": ["電子書籍制作会社凸版印刷株式会社"]}, {"box": [220, 1994, 1183, 2067], "vertical": false, "font_size": 31.0, "lines_coords": [[[220.0, 1994.0], [1183.0, 1994.0], [1183.0, 2025.0], [220.0, 2025.0]], [[220.0, 2036.0], [1127.0, 2036.0], [1127.0, 2067.0], [220.0, 2067.0]]], "lines": ["Ｘ取録されている作品は、執筆された当時の状況や年代を考慮の上、", "初回掲載時の表現のまま掲載されております。ご了承ください。"]}, {"box": [215, 2111, 1476, 2235], "vertical": false, "font_size": 35.0, "lines_coords": [[[215.0, 2111.0], [1476.0, 2114.0], [1476.0, 2153.0], [215.0, 2151.0]], [[220.0, 2160.0], [1286.0, 2160.0], [1286.0, 2193.0], [220.0, 2193.0]], [[217.0, 2200.0], [1225.0, 2203.0], [1225.0, 2235.0], [217.0, 2233.0]]], "lines": ["☆本書の一部または全部を無断で複製、転職、複写（コピー）、スキャン、デジタル化、", "上演、放送等をすることは、著作権法上での例外を除き禁じられています。", "代行業者等の第三者による本書の電子的複製も認められておりません。"]}], "img_path": "00214.webp"}]}