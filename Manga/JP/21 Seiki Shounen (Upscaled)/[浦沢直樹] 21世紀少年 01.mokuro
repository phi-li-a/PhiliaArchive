256.0, 1512.0], [1256.0, 1560.0], [431.0, 1560.0]], [[290.0, 1575.0], [1399.0, 1575.0], [1399.0, 1623.0], [290.0, 1623.0]], [[398.0, 1634.0], [1288.0, 1636.0], [1288.0, 1684.0], [398.0, 1682.0]]], "lines": ["この作品は", "２０１６年〜２０Ｉ７年に、加筆修正のうえ刊行された", "『２０世紀少年、完全版』全１１巻や『２．世紀少年、完全版』全１巻を、", "全２２巻＋上下巻に再編集したデジタル特別版です。"]}], "img_path": "00004.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1295, 986, 1513, 1072], "vertical": false, "font_size": 33, "lines_coords": [[[1354.0, 986.0], [1457.0, 991.0], [1455.0, 1024.0], [1352.0, 1019.0]], [[1298.0, 1033.0], [1513.0, 1035.0], [1513.0, 1068.0], [1298.0, 1066.0]]], "lines": ["おまえは", "テラシタルＶｅｒ．"]}, {"box": [236, 1570, 555, 1610], "vertical": false, "font_size": 40, "lines_coords": [[[236.0, 1570.0], [555.0, 1570.0], [555.0, 1610.0], [236.0, 1610.0]]], "lines": ["＂ともだち＂の死"]}, {"box": [268, 1134, 1401, 1617], "vertical": false, "font_size": 397, "lines_coords": [[[305.0, 1098.0], [1404.0, 1222.0], [1364.0, 1652.0], [265.0, 1527.0]]], "lines": ["いや、いや．．．"]}, {"box": [567, 1633, 1122, 1816], "vertical": false, "font_size": 183, "lines_coords": [[[569.0, 1634.0], [1117.0, 1617.0], [1122.0, 1816.0], [574.0, 1832.0]]], "lines": ["浦沢直樹"]}, {"box": [349, 1804, 1328, 2170], "vertical": false, "font_size": 26, "lines_coords": [[[749.0, 1802.0], [930.0, 1802.0], [930.0, 1839.0], [749.0, 1839.0]], [[679.0, 1842.0], [995.0, 1842.0], [995.0, 1869.0], [679.0, 1869.0]], [[452.0, 1880.0], [1220.0, 1880.0], [1220.0, 1907.0], [452.0, 1907.0]], [[503.0, 1915.0], [1171.0, 1915.0], [1171.0, 1942.0], [503.0, 1942.0]], [[616.0, 1952.0], [1063.0, 1952.0], [1063.0, 1980.0], [616.0, 1980.0]], [[351.0, 1987.0], [1324.0, 1987.0], [1324.0, 2015.0], [351.0, 2015.0]], [[454.0, 2025.0], [1223.0, 2025.0], [1223.0, 2052.0], [454.0, 2052.0]], [[576.0, 2060.0], [1101.0, 2060.0], [1101.0, 2087.0], [576.0, 2087.0]], [[506.0, 2093.0], [1174.0, 2095.0], [1174.0, 2125.0], [506.0, 2123.0]], [[456.0, 2133.0], [1223.0, 2133.0], [1223.0, 2160.0], [456.0, 2160.0]]], "lines": ["Ｗａｒｔｓｏｒｅｒ．", "ＴｈｅｒＷｉｎｄｏｒｄＶｉｓｔｅｒは、", "Ｐａｏｐｌｅａｎｅｒｅｌｅｓｓｄｆｒｏｍｉｔｅ．ｄａｎｇｓでのｆｅｘｔｉｎｃｉｎｏｎ．", "「ＨａｌｙＰａｃｅｓｈｅｓｔｅｒｃｉｎｅｔｏＴｏｋｉｃ．ｉｃｓｅａｎｓ．", "Ｂｕｔｔｈｅｒｎｕｓｔｅｒｙｓｔｉｌ．ｃｅｎａｔｉｎｓ．", "Ｗｏｒｄｏｗｓｒａｍｓｗｉｔｔｅｒ＂Ｆｉｓｎｄ＂ｗａｓａｎｄＷｉｎｄｏｗｓ．ｃａｍｅｒｉｏｎ．", "Ｔｈｅ．ｏｎＤｒｏｌｌｅ店舗ではＧｒｏｇｌｅＰｏｒｔｓでのＷｉｎｄｏｗｓＴｏｒｄｓ：", "．．．街は、ｍｓｍｏｒｉｅｓｏｆｔｈｅ．ｈａｒｏ．Ｋｅｎｔ．", "ＴｈｓｔｓｔａｔｉｍｅｔｏｎｅｒｔｒｅＰａｎｔｉｏｎａｓｈｏｘ．", "Ｙｏｕ．ｃｏｍ、ｓｅｅｖｉｎａｔｓｉｅｆｔｏｎｔｈｅｂｏｔｔｏｍｏｆｔｉｅなので、"]}], "img_path": "00005.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [714, 93, 1577, 474], "vertical": false, "font_size": 83, "lines_coords": [[[714.0, 86.0], [1577.0, 91.0], [1577.0, 311.0], [714.0, 307.0]], [[775.0, 269.0], [1506.0, 267.0], [1506.0, 330.0], [775.0, 332.0]], [[768.0, 335.0], [1518.0, 332.0], [1518.0, 386.0], [768.0, 389.0]], [[909.0, 379.0], [1246.0, 382.0], [1246.0, 438.0], [909.0, 435.0]], [[836.0, 426.0], [1216.0, 426.0], [1216.0, 480.0], [836.0, 480.0]]], "lines": ["登場少年親介", "そして、それはそれでもいいのですが、", "人報道士の危機を聞いた世界を悪夢が喋り、リンキュネルギーを", "世の危機を脱した世界＂ともだち＂の残したう一つの異ナは．．．？", "「どもだちの残したもう一つの罠とは．．．！？"]}, {"box": [459, 213, 567, 264], "vertical": false, "font_size": 51, "lines_coords": [[[459.0, 213.0], [567.0, 213.0], [567.0, 264.0], [459.0, 264.0]]], "lines": ["蝶野"]}, {"box": [357, 274, 667, 454], "vertical": false, "font_size": 34, "lines_coords": [[[374.0, 285.0], [658.0, 285.0], [658.0, 316.0], [374.0, 316.0]], [[367.0, 330.0], [658.0, 330.0], [658.0, 360.0], [367.0, 360.0]], [[367.0, 372.0], [632.0, 372.0], [632.0, 405.0], [367.0, 405.0]], [[365.0, 412.0], [520.0, 412.0], [520.0, 452.0], [365.0, 452.0]]], "lines": ["うともだち・組織を", "捜査中に殺された", "伝説の刑事・チョ", "さんの孫。"]}, {"box": [222, 555, 379, 597], "vertical": false, "font_size": 42, "lines_coords": [[[222.0, 555.0], [379.0, 555.0], [379.0, 597.0], [222.0, 597.0]]], "lines": ["カンナ"]}, {"box": [885, 667, 1153, 907], "vertical": false, "font_size": 37, "lines_coords": [[[925.0, 670.0], [1143.0, 667.0], [1143.0, 710.0], [925.0, 712.0]], [[892.0, 733.0], [1148.0, 733.0], [1148.0, 766.0], [892.0, 766.0]], [[892.0, 780.0], [1129.0, 780.0], [1129.0, 813.0], [892.0, 813.0]], [[895.0, 825.0], [1099.0, 825.0], [1099.0, 857.0], [895.0, 857.0]], [[888.0, 857.0], [1012.0, 864.0], [1010.0, 907.0], [885.0, 900.0]]], "lines": ["ともだち", "●謎のカリスマ。", "世界をウイルス", "で減亡させた", "独裁者。"]}, {"box": [133, 590, 477, 747], "vertical": false, "font_size": 37, "lines_coords": [[[140.0, 618.0], [468.0, 614.0], [468.0, 653.0], [140.0, 658.0]], [[138.0, 663.0], [454.0, 663.0], [454.0, 703.0], [138.0, 703.0]], [[140.0, 710.0], [435.0, 710.0], [435.0, 742.0], [140.0, 742.0]]], "lines": ["●ケンヂの姉・キリコ", "と＂ともだち＂の娘。", "不思議な力を持つ。"]}, {"box": [410, 1216, 749, 1835], "vertical": false, "font_size": 41.23076923076923, "lines_coords": [[[531.0, 1216.0], [749.0, 1216.0], [749.0, 1258.0], [531.0, 1258.0]], [[494.0, 1270.0], [665.0, 1270.0], [665.0, 1310.0], [494.0, 1310.0]], [[487.0, 1310.0], [606.0, 1310.0], [606.0, 1352.0], [487.0, 1352.0]], [[485.0, 1357.0], [670.0, 1357.0], [670.0, 1406.0], [485.0, 1406.0]], [[489.0, 1401.0], [637.0, 1401.0], [637.0, 1441.0], [489.0, 1441.0]], [[487.0, 1439.0], [670.0, 1439.0], [670.0, 1488.0], [487.0, 1488.0]], [[492.0, 1488.0], [606.0, 1488.0], [606.0, 1532.0], [492.0, 1532.0]], [[410.0, 1558.0], [632.0, 1558.0], [632.0, 1600.0], [410.0, 1600.0]], [[492.0, 1617.0], [665.0, 1617.0], [665.0, 1657.0], [492.0, 1657.0]], [[531.0, 1666.0], [660.0, 1666.0], [660.0, 1706.0], [531.0, 1706.0]], [[456.0, 1715.0], [667.0, 1715.0], [667.0, 1748.0], [456.0, 1748.0]], [[454.0, 1748.0], [672.0, 1753.0], [672.0, 1792.0], [454.0, 1788.0]], [[410.0, 1797.0], [658.0, 1800.0], [658.0, 1835.0], [410.0, 1832.0]]], "lines": ["万丈目胤舟", "●＂ともだち＂", "を長年", "支えた腹心。", "愛人だった", "高須に暗殺", "された。", "サダキヨ", "●ケンヂの", "同級生。", "いつもお面を", "いつもの回りかぶっていた", "イジメられっ子。"]}, {"box": [248, 1200, 396, 1251], "vertical": false, "font_size": 42, "lines_coords": [[[250.0, 1200.0], [396.0, 1209.0], [393.0, 1251.0], [248.0, 1242.0]]], "lines": ["クベエ"]}, {"box": [123, 1265, 433, 1444], "vertical": false, "font_size": 38, "lines_coords": [[[138.0, 1265.0], [428.0, 1265.0], [428.0, 1305.0], [138.0, 1305.0]], [[131.0, 1312.0], [431.0, 1312.0], [431.0, 1352.0], [131.0, 1352.0]], [[131.0, 1357.0], [431.0, 1357.0], [431.0, 1396.0], [131.0, 1396.0]], [[131.0, 1406.0], [412.0, 1406.0], [412.0, 1439.0], [131.0, 1439.0]]], "lines": ["夢ともだち＂として", "世界的英雄まで昇", "わつめたが、２０１５", "年、凶弾に倒れた。"]}, {"box": [1371, 1938, 1509, 2294], "vertical": true, "font_size": 58, "lines_coords": [[[1457.0, 1992.0], [1506.0, 1992.0], [1506.0, 2228.0], [1457.0, 2228.0]], [[1375.0, 1938.0], [1441.0, 1938.0], [1441.0, 2285.0], [1375.0, 2285.0]]], "lines": ["いままでの", "あらすじ"]}, {"box": [719, 1914, 1298, 2310], "vertical": true, "font_size": 118, "lines_coords": [[[1265.0, 1959.0], [1298.0, 1959.0], [1298.0, 2303.0], [1265.0, 2303.0]], [[1211.0, 1917.0], [1251.0, 1917.0], [1251.0, 2310.0], [1211.0, 2310.0]], [[1164.0, 1921.0], [1197.0, 1921.0], [1197.0, 2310.0], [1164.0, 2310.0]], [[1113.0, 1914.0], [1152.0, 1914.0], [1150.0, 2308.0], [1110.0, 2308.0]], [[1066.0, 1919.0], [1099.0, 1919.0], [1099.0, 2306.0], [1066.0, 2306.0]], [[1017.0, 1919.0], [1049.0, 1919.0], [1049.0, 2292.0], [1017.0, 2292.0]], [[970.0, 1921.0], [1000.0, 1921.0], [1000.0, 2308.0], [970.0, 2308.0]], [[918.0, 1919.0], [951.0, 1919.0], [951.0, 2308.0], [918.0, 2308.0]], [[864.0, 1919.0], [906.0, 1919.0], [906.0, 2090.0], [864.0, 2090.0]], [[768.0, 1921.0], [801.0, 1921.0], [801.0, 2238.0], [768.0, 2238.0]], [[719.0, 1921.0], [752.0, 1921.0], [752.0, 2231.0], [719.0, 2231.0]], [[749.0, 2203.0], [780.0, 2203.0], [780.0, 2221.0], [749.0, 2221.0]]], "lines": ["昭和四〇年代、空き地", "に秘密基地を作り、引世", "紀を空想していたケンチ", "と仲間達ーー悪の組織の", "世界征服計画を阻止す", "る正義の味方を夢見て", "他愛のないシナリオを描き", "それをよげんの書とも", "づけていた。", "姉キリコの娘カンナ", "てながらコンビニを", "．．"]}, {"box": [105, 1755, 1021, 2400], "vertical": true, "font_size": 118, "lines_coords": [[[674.0, 1921.0], [705.0, 1921.0], [705.0, 2219.0], [674.0, 2219.0]], [[616.0, 1914.0], [653.0, 1914.0], [658.0, 2210.0], [621.0, 2210.0]], [[466.0, 1914.0], [515.0, 1914.0], [515.0, 2231.0], [466.0, 2231.0]], [[447.0, 1842.0], [756.0, 1858.0], [731.0, 2308.0], [421.0, 2292.0]], [[374.0, 1917.0], [414.0, 1917.0], [414.0, 2250.0], [374.0, 2250.0]], [[372.0, 1889.0], [515.0, 1889.0], [515.0, 2257.0], [372.0, 2257.0]], [[323.0, 1919.0], [363.0, 1919.0], [363.0, 2268.0], [323.0, 2268.0]], [[253.0, 1835.0], [977.0, 1835.0], [977.0, 2397.0], [253.0, 2397.0]], [[220.0, 1914.0], [269.0, 1914.0], [269.0, 2310.0], [220.0, 2310.0]], [[175.0, 1917.0], [215.0, 1917.0], [215.0, 2308.0], [175.0, 2308.0]], [[121.0, 1914.0], [175.0, 1914.0], [175.0, 2008.0], [121.0, 2008.0]], [[124.0, 1755.0], [1021.0, 1778.0], [1003.0, 2400.0], [105.0, 2400.0]]], "lines": ["ケンヂは、ミュージン", "なる夢も破れ、ど", "で起こる奇妙な事", "でなかどうしてタンチは、スージンとなる夢も優れ、どこにもいろつまらない人たちになっていた。たが彼の心配にも効かなければこんの時、そうくりを", "ことに気づき、彼の人が", "で起こる奇妙な事件．．よげんの書・そっくりことに気づき、彼の人生", "一変する。どもだち」", "それはそういうことですが、これまではありませんでしょうかもしれないと思っていましたが、そんなことはないのですから、それだけではなんだけど．．．", "本気で世界の征服を夢", "見ていることに気づいた", "のだ。", "．．．"]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1399, 222, 1485, 248], "vertical": false, "font_size": 26, "lines_coords": [[[1399.0, 222.0], [1485.0, 222.0], [1485.0, 248.0], [1399.0, 248.0]]], "lines": ["ルオ"]}, {"box": [1261, 257, 1582, 450], "vertical": false, "font_size": 32, "lines_coords": [[[1265.0, 281.0], [1567.0, 283.0], [1567.0, 316.0], [1265.0, 314.0]], [[1368.0, 328.0], [1553.0, 328.0], [1553.0, 360.0], [1368.0, 360.0]], [[1340.0, 417.0], [1572.0, 417.0], [1572.0, 447.0], [1340.0, 447.0]], [[1408.0, 372.0], [1546.0, 372.0], [1546.0, 405.0], [1408.0, 405.0]]], "lines": ["カケンダの幼なじみ。", "国民的歌手・", "マネージャー。", "春波天の"]}, {"box": [684, 215, 1194, 362], "vertical": false, "font_size": 35, "lines_coords": [[[719.0, 215.0], [965.0, 215.0], [965.0, 255.0], [719.0, 255.0]], [[686.0, 281.0], [1174.0, 281.0], [1174.0, 314.0], [686.0, 314.0]], [[684.0, 323.0], [1188.0, 325.0], [1188.0, 358.0], [684.0, 356.0]]], "lines": ["ケロヨン", "●ケンヂの幼なじみ。ワクチン", "を被災者に配って人々を守った。"]}, {"box": [178, 210, 479, 452], "vertical": false, "font_size": 44, "lines_coords": [[[227.0, 210.0], [435.0, 215.0], [435.0, 262.0], [227.0, 257.0]], [[182.0, 281.0], [471.0, 281.0], [471.0, 321.0], [182.0, 321.0]], [[178.0, 323.0], [421.0, 314.0], [424.0, 363.0], [180.0, 372.0]], [[180.0, 367.0], [374.0, 367.0], [374.0, 407.0], [180.0, 407.0]], [[180.0, 410.0], [302.0, 410.0], [302.0, 452.0], [180.0, 452.0]]], "lines": ["オッチョ", "●ケンヂの親友。", "巨大ロボットを", "操り、東京を", "救った。"]}, {"box": [232, 543, 389, 585], "vertical": false, "font_size": 35, "lines_coords": [[[232.0, 550.0], [386.0, 543.0], [389.0, 578.0], [234.0, 585.0]]], "lines": ["ユキジ"]}, {"box": [1251, 543, 1583, 742], "vertical": false, "font_size": 38, "lines_coords": [[[1321.0, 546.0], [1537.0, 543.0], [1537.0, 585.0], [1321.0, 588.0]], [[1260.0, 614.0], [1560.0, 614.0], [1560.0, 646.0], [1260.0, 646.0]], [[1295.0, 658.0], [1563.0, 658.0], [1563.0, 691.0], [1295.0, 691.0]], [[1312.0, 693.0], [1581.0, 693.0], [1581.0, 740.0], [1312.0, 740.0]]], "lines": ["ヨシツネ", "●ケンチの幼なじみ", "で、反政府組織を", "率いたリーダー。"]}, {"box": [168, 580, 396, 916], "vertical": false, "font_size": 62, "lines_coords": [[[187.0, 611.0], [356.0, 611.0], [356.0, 644.0], [187.0, 644.0]], [[178.0, 651.0], [339.0, 651.0], [339.0, 703.0], [178.0, 703.0]], [[178.0, 689.0], [330.0, 689.0], [330.0, 747.0], [178.0, 747.0]], [[178.0, 733.0], [323.0, 733.0], [323.0, 782.0], [178.0, 782.0]], [[168.0, 771.0], [306.0, 771.0], [306.0, 883.0], [168.0, 883.0]], [[178.0, 846.0], [271.0, 846.0], [271.0, 916.0], [178.0, 916.0]]], "lines": ["●ケンヂの", "幼なじみ。", "カンナの", "親代わり", "となり、面倒を", "固門見る。"]}, {"box": [1145, 1645, 1612, 1858], "vertical": false, "font_size": 116.0, "lines_coords": [[[1155.0, 1708.0], [1581.0, 1750.0], [1572.0, 1858.0], [1145.0, 1816.0]], [[1183.0, 1645.0], [1612.0, 1652.0], [1609.0, 1776.0], [1181.0, 1769.0]]], "lines": ["Ｂｏｘ", "Ｓｏｎｔｕｄｒｂｉｏｘ"]}, {"box": [450, 1642, 762, 1839], "vertical": false, "font_size": 38, "lines_coords": [[[527.0, 1645.0], [688.0, 1642.0], [688.0, 1685.0], [527.0, 1687.0]], [[454.0, 1699.0], [747.0, 1703.0], [747.0, 1746.0], [454.0, 1741.0]], [[464.0, 1755.0], [754.0, 1755.0], [754.0, 1788.0], [464.0, 1788.0]], [[456.0, 1797.0], [719.0, 1797.0], [719.0, 1830.0], [456.0, 1830.0]]], "lines": ["ケンチ", "●ガンナの叔父。", "ともだち「から世界", "を救ったダメ男。"]}, {"box": [860, 1870, 1553, 2332], "vertical": true, "font_size": 50, "lines_coords": [[[1520.0, 1952.0], [1553.0, 1952.0], [1553.0, 2306.0], [1520.0, 2306.0]], [[1464.0, 1917.0], [1504.0, 1917.0], [1504.0, 2308.0], [1464.0, 2308.0]], [[1413.0, 1914.0], [1459.0, 1914.0], [1459.0, 2313.0], [1413.0, 2313.0]], [[1363.0, 1912.0], [1413.0, 1912.0], [1413.0, 2310.0], [1363.0, 2310.0]], [[1319.0, 1917.0], [1354.0, 1917.0], [1356.0, 2303.0], [1321.0, 2303.0]], [[1272.0, 1919.0], [1302.0, 1919.0], [1302.0, 2317.0], [1272.0, 2317.0]], [[1223.0, 1919.0], [1256.0, 1919.0], [1256.0, 2306.0], [1223.0, 2306.0]], [[1174.0, 1919.0], [1206.0, 1919.0], [1209.0, 2139.0], [1176.0, 2139.0]], [[1106.0, 1931.0], [1188.0, 1938.0], [1164.0, 2292.0], [1082.0, 2285.0]], [[1073.0, 1919.0], [1113.0, 1919.0], [1113.0, 2259.0], [1073.0, 2259.0]], [[1024.0, 1917.0], [1059.0, 1917.0], [1061.0, 2275.0], [1026.0, 2275.0]], [[949.0, 1870.0], [1122.0, 1905.0], [1033.0, 2332.0], [860.0, 2296.0]], [[930.0, 1921.0], [960.0, 1921.0], [960.0, 2257.0], [930.0, 2257.0]], [[881.0, 1921.0], [913.0, 1921.0], [913.0, 2306.0], [881.0, 2306.0]], [[902.0, 2266.0], [1157.0, 2254.0], [1160.0, 2303.0], [904.0, 2315.0]]], "lines": ["どもだちとは誰！？仲", "間を集めて立ち上がった", "ケンヂは、どもだちの巧", "みな計略に嵌り、２０世紀", "最後の日、テロリストの活", "名を着せられ行方不明に", "「どもだち」は惨劇を救う", "た英雄となる。", "あーこの二五年、どもだち．．．おまえも、", "暗殺されてしまうが", "ーマ法王の前で復活。", "暗殺され．．．俺達１マ法王の前で復活１マホの子に昇りつめばから神の子は、ウイルスた彼はその一方、ウィルス地帯を滅亡", "た彼はその方、ウイン", "をばら撒き、世界を滅亡", "「スタッフは"]}, {"box": [487, 1917, 864, 2306], "vertical": true, "font_size": 50, "lines_coords": [[[827.0, 1919.0], [860.0, 1919.0], [864.0, 2128.0], [831.0, 2128.0]], [[782.0, 1959.0], [813.0, 1959.0], [813.0, 2303.0], [782.0, 2303.0]], [[733.0, 1919.0], [763.0, 1919.0], [763.0, 2306.0], [733.0, 2306.0]], [[679.0, 1917.0], [712.0, 1917.0], [714.0, 2303.0], [681.0, 2303.0]], [[635.0, 1919.0], [665.0, 1919.0], [665.0, 2303.0], [635.0, 2303.0]], [[585.0, 1919.0], [616.0, 1919.0], [616.0, 2303.0], [585.0, 2303.0]], [[539.0, 1924.0], [564.0, 1924.0], [564.0, 2097.0], [539.0, 2097.0]], [[487.0, 1959.0], [517.0, 1959.0], [517.0, 2303.0], [487.0, 2303.0]]], "lines": ["へと追い込む。", "二年後、わずかに残った", "人類に世界大統領として", "君臨するどもだちは世", "界に向けた放送で真相を", "雪白、人類の完全な波亡", "を盲言する", "カンナは唯一の安全な"]}, {"box": [187, 1903, 485, 2317], "vertical": true, "font_size": 50, "lines_coords": [[[396.0, 1903.0], [485.0, 1903.0], [485.0, 2317.0], [396.0, 2317.0]], [[384.0, 1917.0], [424.0, 1917.0], [424.0, 2306.0], [384.0, 2306.0]], [[337.0, 1919.0], [370.0, 1919.0], [370.0, 2306.0], [337.0, 2306.0]], [[285.0, 1919.0], [318.0, 1919.0], [318.0, 2306.0], [285.0, 2306.0]], [[239.0, 1919.0], [269.0, 1919.0], [269.0, 2306.0], [239.0, 2306.0]], [[187.0, 1919.0], [220.0, 1919.0], [220.0, 2167.0], [187.0, 2167.0]]], "lines": ["場所、万博会場でのコンサートを開催し、人々を敗", "ートを開催し、人々を救う", "おうと画策する。そして", "姿を現したケンチはども", "だあと直接対決。ついに", "人類を救うが！？"]}], "img_path": "00007.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [12, 64, 438, 344], "vertical": false, "font_size": 308, "lines_coords": [[[12.0, 36.0], [438.0, 36.0], [438.0, 372.0], [12.0, 372.0]]], "lines": ["いや、"]}, {"box": [104, 469, 1002, 642], "vertical": false, "font_size": 115, "lines_coords": [[[215.0, 489.0], [766.0, 517.0], [759.0, 645.0], [208.0, 617.0]], [[712.0, 531.0], [949.0, 503.0], [960.0, 624.0], [724.0, 652.0]]], "lines": ["もしあげましょう。", "．．．"]}, {"box": [491, 229, 1018, 269], "vertical": false, "font_size": 33, "lines_coords": [[[494.0, 229.0], [1010.0, 229.0], [1010.0, 265.0], [494.0, 265.0]]], "lines": ["ＮＡＯＫＬＵＲＡＳＮＡＰＲＥＳＥＮＴＳ"]}, {"box": [182, 710, 979, 1094], "vertical": false, "font_size": 147.0, "lines_coords": [[[466.0, 710.0