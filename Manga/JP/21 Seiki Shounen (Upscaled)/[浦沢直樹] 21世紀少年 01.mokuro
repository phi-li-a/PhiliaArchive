], [1206.0, 525.0], [1209.0, 616.0], [747.0, 628.0]]], "lines": ["仮に帰子はしたん"]}, {"box": [1281, 1052, 1462, 1260], "vertical": true, "font_size": 39, "lines_coords": [[[1420.0, 1057.0], [1462.0, 1057.0], [1462.0, 1171.0], [1420.0, 1171.0]], [[1373.0, 1057.0], [1413.0, 1057.0], [1413.0, 1209.0], [1373.0, 1209.0]], [[1326.0, 1052.0], [1366.0, 1052.0], [1366.0, 1211.0], [1326.0, 1211.0]], [[1281.0, 1057.0], [1314.0, 1057.0], [1314.0, 1260.0], [1281.0, 1260.0]]], "lines": ["これが", "何を意味", "するのか", "調査します。"]}, {"box": [853, 817, 1005, 860], "vertical": false, "font_size": 43, "lines_coords": [[[853.0, 817.0], [1005.0, 817.0], [1005.0, 860.0], [853.0, 860.0]]], "lines": ["いいって"]}, {"box": [550, 670, 567, 902], "vertical": true, "font_size": 17, "lines_coords": [[[550.0, 670.0], [567.0, 670.0], [567.0, 902.0], [550.0, 902.0]]], "lines": ["そういえばここで、"]}, {"box": [1284, 1544, 1469, 1772], "vertical": true, "font_size": 39, "lines_coords": [[[1429.0, 1546.0], [1462.0, 1546.0], [1462.0, 1769.0], [1429.0, 1769.0]], [[1380.0, 1546.0], [1420.0, 1546.0], [1420.0, 1701.0], [1380.0, 1701.0]], [[1328.0, 1544.0], [1370.0, 1544.0], [1373.0, 1701.0], [1331.0, 1701.0]], [[1284.0, 1544.0], [1324.0, 1544.0], [1324.0, 1675.0], [1284.0, 1675.0]]], "lines": ["特殊部隊だか", "なんだか", "知らねえ", "けどさ、"]}, {"box": [717, 1265, 1003, 1431], "vertical": false, "font_size": 38, "lines_coords": [[[768.0, 1270.0], [984.0, 1265.0], [984.0, 1305.0], [768.0, 1310.0]], [[773.0, 1347.0], [998.0, 1342.0], [998.0, 1385.0], [773.0, 1389.0]], [[871.0, 1305.0], [923.0, 1305.0], [923.0, 1342.0], [871.0, 1342.0]], [[796.0, 1396.0], [909.0, 1396.0], [909.0, 1429.0], [796.0, 1429.0]]], "lines": ["【帰子ばたし、", "思いに、「天子化への", "で", "いろいろ"]}, {"box": [937, 1544, 1025, 1774], "vertical": true, "font_size": 40, "lines_coords": [[[984.0, 1544.0], [1024.0, 1544.0], [1024.0, 1774.0], [984.0, 1774.0]], [[937.0, 1546.0], [977.0, 1546.0], [977.0, 1701.0], [937.0, 1701.0]]], "lines": ["まずいんじゃ", "ないの？"]}, {"box": [811, 1542, 845, 1595], "vertical"