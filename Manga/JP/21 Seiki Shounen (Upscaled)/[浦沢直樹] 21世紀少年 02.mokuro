 [1424.0, 1052.0], [1424.0, 1164.0], [1389.0, 1164.0]]], "lines": ["なんだって", "．．．．．．？"]}, {"box": [934, 663, 1062, 929], "vertical": true, "font_size": 35, "lines_coords": [[[1028.0, 663.0], [1061.0, 663.0], [1061.0, 864.0], [1028.0, 864.0]], [[977.0, 663.0], [1017.0, 663.0], [1017.0, 815.0], [977.0, 815.0]], [[935.0, 665.0], [967.0, 665.0], [967.0, 925.0], [935.0, 925.0]]], "lines": ["よくあるよ、", "思春期の", "青少年には．．．："]}, {"box": [536, 1031, 769, 1298], "vertical": true, "font_size": 38, "lines_coords": [[[733.0, 1033.0], [766.0, 1033.0], [766.0, 1223.0], [733.0, 1223.0]], [[681.0, 1031.0], [721.0, 1031.0], [721.0, 1298.0], [681.0, 1298.0]], [[635.0, 1033.0], [674.0, 1033.0], [674.0, 1237.0], [635.0, 1237.0]], [[590.0, 1035.0], [623.0, 1035.0], [623.0, 1221.0], [590.0, 1221.0]], [[536.0, 1031.0], [583.0, 1031.0], [583.0, 1115.0], [536.0, 1115.0]]], "lines": ["そんなこと", "どうでもいい！！", "カンナって、", "あのカンナ", "か！？"]}, {"box": [173, 1031, 307, 1258], "vertical": true, "font_size": 40, "lines_coords": [[[267.0, 1031.0], [306.0, 1031.0], [306.0, 1225.0], [267.0, 1225.0]], [[220.0, 1031.0], [260.0, 1031.0], [260.0, 1258.0], [220.0, 1258.0]], [[173.0, 1031.0], [213.0, 1031.0], [213.0, 1185.0], [173.0, 1185.0]]], "lines": ["どのカンナ", "だか知らない", "よ～～！！"]}, {"box": [1336, 1666, 1469, 1899], "vertical": true, "font_size": 36, "lines_coords": [[[1424.0, 1666.0], [1467.0, 1666.0], [1469.0, 1828.0], [1427.0, 1828.0]], [[1385.0, 1671.0], [1417.0, 1671.0], [1417.0, 1898.0], [1385.0, 1898.0]], [[1338.0, 1673.0], [1370.0, 1673.0], [1370.0, 1875.0], [1338.0, 1875.0]]], "lines": ["とにかく", "夢に出てきて", "言ったんだ。"]}, {"box": [831, 1042, 1052, 1393], "vertical": true, "font_size": 40, "lines_coords": [[[1010.0, 1042.0], [1052.0, 1042.0], [1052.0, 1197.0], [1010.0, 1197.0]], [[967.0, 1042.0], [1007.0, 1042.0], [1007.0, 1324.0], [967.0, 1324.0]], [[923.0, 1045.0], [963.0, 1045.0], [963.0, 1387.0], [923.0, 1387.0]], [[878.0, 1042.0], [918.0, 1042.0], [918.0, 1340.0], [878.0, 1340.0]], [[831.0, 1042.0], [871.0, 1042.0], [871.0, 1305.0], [831.0, 1305.0]]], "lines": ["けっこう", "かわいかったよ。", "マユズミジュンとか", "ヨシザワキョーコ", "みたいに．．．"]}, {"box": [845, 1668, 986, 1954], "vertical": true, "font_size": 42, "lines_coords": [[[928.0, 1671.0], [981.0, 1668.0], [986.0, 1790.0], [932.0, 1792.0]], [[890.0, 1671.0], [930.0, 1671.0], [930.0, 1900.0], [890.0, 1900.0]], [[845.0, 1671.0], [878.0, 1671.0], [878.0, 1950.0], [845.0, 1950.0]]], "lines": ["ケンヂ", "おじちゃんに", "伝えてくれって。"]}], "img_path": "00045.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1431, 225, 1523, 349], "vertical": true, "font_size": 44, "lines_coords": [[[1481.0, 229.0], [1523.0, 229.0], [1523.0, 349.0], [1481.0, 349.0]], [[1436.0, 225.0], [1481.0, 227.0], [1476.0, 314.0], [1431.0, 311.0]]], "lines": ["なんて", "．．．．．．"]}, {"box": [1291, 972, 1523, 1241], "vertical": true, "font_size": 40, "lines_coords": [[[1478.0, 972.0], [1518.0, 972.0], [1523.0, 1162.0], [1483.0, 1162.0]], [[1434.0, 977.0], [1476.0, 977.0], [1476.0, 1115.0], [1434.0, 1115.0]], [[1387.0, 975.0], [1427.0, 975.0], [1427.0, 1183.0], [1387.0, 1183.0]], [[1340.0, 975.0], [1380.0, 975.0], [1380.0, 1164.0], [1340.0, 1164.0]], [[1291.0, 975.0], [1331.0, 975.0], [1333.0, 1239.0], [1293.0, 1239.0]]], "lines": ["ええと．．．．．．", "〝反陽子", "ばくだん”の", "リモコンの", "かくし場所．．．"]}, {"box": [928, 625, 1155, 853], "vertical": true, "font_size": 38, "lines_coords": [[[1113.0, 625.0], [1152.0, 625.0], [1152.0, 817.0], [1113.0, 817.0]], [[1066.0, 625.0], [1106.0, 625.0], [1106.0, 853.0], [1066.0, 853.0]], [[1019.0, 625.0], [1059.0, 625.0], [1059.0, 825.0], [1019.0, 825.0]], [[972.0, 625.0], [1012.0, 625.0], [1012.0, 810.0], [972.0, 810.0]], [[928.0, 628.0], [960.0, 628.0], [960.0, 815.0], [928.0, 815.0]]], "lines": ["サングラス", "かけたヒゲの", "ケンヂって、", "おじさんの", "ことだろ？"]}, {"box": [639, 588, 836, 862], "vertical": true, "font_size": 49, "lines_coords": [[[787.0, 590.0], [836.0, 590.0], [836.0, 728.0], [787.0, 728.0]], [[738.0, 590.0], [787.0, 590.0], [787.0, 775.0], [738.0, 775.0]], [[688.0, 590.0], [740.0, 590.0], [740.0, 733.0], [688.0, 733.0]], [[639.0, 588.0], [686.0, 588.0], [686.0, 862.0], [639.0, 862.0]]], "lines": ["だから", "カンナは", "なんて", "言ったんだ！！"]}, {"box": [223, 745, 258, 802], "vertical": true, "font_size": 35, "lines_coords": [[[223.0, 745.0], [258.0, 745.0], [258.0, 802.0], [223.0, 802.0]]], "lines": ["！！"]}, {"box": [447, 1626, 553, 1903], "vertical": true, "font_size": 44, "lines_coords": [[[506.0, 1626.0], [548.0, 1626.0], [548.0, 1849.0], [506.0, 1849.0]], [[447.0, 1626.0], [494.0, 1626.0], [494.0, 1903.0], [447.0, 1903.0]]], "lines": ["秘密基地の", "中だって．．．．．"]}], "img_path": "00046.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [710, 217, 763, 349], "vertical": true, "font_size": 49, "lines_coords": [[[710.0, 220.0], [759.0, 217.0], [763.0, 346.0], [714.0, 349.0]]], "lines": ["犯人は、"]}, {"box": [175, 215, 273, 450], "vertical": true, "font_size": 47, "lines_coords": [[[232.0, 222.0], [269.0, 222.0], [264.0, 450.0], [227.0, 450.0]], [[175.0, 215.0], [232.0, 215.0], [232.0, 414.0], [175.0, 414.0]]], "lines": ["”ともだち〟の", "残党．．．．．？"]}, {"box": [553, 1045, 690, 1290], "vertical": true, "font_size": 40, "lines_coords": [[[646.0, 1047.0], [688.0, 1047.0], [688.0, 1183.0], [646.0, 1183.0]], [[597.0, 1047.0], [637.0, 1047.0], [637.0, 1258.0], [597.0, 1258.0]], [[553.0, 1045.0], [592.0, 1045.0], [592.0, 1286.0], [553.0, 1286.0]]], "lines": ["〝反陽子", "ばくだん”の", "リモコンをね。"]}, {"box": [1256, 1040, 1478, 1389], "vertical": true, "font_size": 45, "lines_coords": [[[1424.0, 1040.0], [1478.0, 1040.0], [1478.0, 1132.0], [1424.0, 1132.0]], [[1389.0, 1045.0], [1431.0, 1045.0], [1424.0, 1389.0], [1382.0, 1389.0]], [[1340.0, 1045.0], [1392.0, 1045.0], [1392.0, 1181.0], [1340.0, 1181.0]], [[1300.0, 1047.0], [1340.0, 1047.0], [1340.0, 1350.0], [1300.0, 1350.0]], [[1256.0, 1047.0], [1295.0, 1047.0], [1295.0, 1214.0], [1256.0, 1214.0]]], "lines": ["まだ", "どもだちの教えを", "信じて、", "守っている連中が", "いるのよ。"]}, {"box": [1448, 1574, 1478, 1731], "vertical": true, "font_size": 30, "lines_coords": [[[1448.0, 1574.0], [1478.0, 1574.0], [1478.0, 1731.0], [1448.0, 1731.0]]], "lines": ["．．．．．．．！！"]}, {"box": [778, 1282, 876, 1475], "vertical": true, "font_size": 50, "lines_coords": [[[824.0, 1282.0], [876.0, 1282.0], [876.0, 1408.0], [824.0, 1408.0]], [[778.0, 1286.0], [827.0, 1286.0], [827.0, 1471.0], [778.0, 1471.0]]], "lines": ["守って", "いる．．．！？"]}, {"box": [785, 1575, 1017, 1807], "vertical": true, "font_size": 42, "lines_coords": [[[967.0, 1575.0], [1017.0, 1575.0], [1017.0, 1699.0], [967.0, 1699.0]], [[923.0, 1575.0], [965.0, 1575.0], [967.0, 1743.0], [925.0, 1743.0]], [[878.0, 1575.0], [918.0, 1575.0], [918.0, 1732.0], [878.0, 1732.0]], [[831.0, 1577.0], [871.0, 1577.0], [871.0, 1807.0], [831.0, 1807.0]], [[785.0, 1577.0], [824.0, 1577.0], [824.0, 1748.0], [785.0, 1748.0]]], "lines": ["それを", "押したら、", "今度こそ", "本当に人類は", "滅亡する。"]}, {"box": [187, 1572, 323, 1884], "vertical": true, "font_size": 40, "lines_coords": [[[283.0, 1575.0], [323.0, 1575.0], [323.0, 1851.0], [283.0, 1851.0]], [[234.0, 1577.0], [274.0, 1577.0], [274.0, 1884.0], [234.0, 1884.0]], [[187.0, 1572.0], [227.0, 1572.0], [227.0, 1696.0], [187.0, 1696.0]]], "lines": ["その時が来たら、", "連中はどうすると", "思う？"]}], "img_path": "00047.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1373, 396, 1506, 624], "vertical": true, "font_size": 35, "lines_coords": [[[1462.0, 396.0], [1502.0, 396.0], [1506.0, 588.0], [1467.0, 588.0]], [[1420.0, 400.0], [1452.0, 400.0], [1452.0, 623.0], [1420.0, 623.0]], [[1373.0, 400.0], [1406.0, 400.0], [1406.0, 562.0], [1373.0, 562.0]]], "lines": ["ロケットで", "火星へ逃げる", "つもりよ。"]}, {"box": [979, 195, 1013, 322], "vertical": true, "font_size": 34, "lines_coords": [[[979.0, 195.0], [1013.0, 195.0], [1013.0, 322.0], [979.0, 322.0]]], "lines": ["．．．．．．"]}, {"box": [227, 194, 363, 581], "vertical": true, "font_size": 38, "lines_coords": [[[323.0, 194.0], [363.0, 194.0], [360.0, 487.0], [321.0, 487.0]], [[278.0, 201.0], [311.0, 201.0], [311.0, 466.0], [278.0, 466.0]], [[227.0, 199.0], [267.0, 199.0], [267.0, 581.0], [227.0, 581.0]]], "lines": ["どうかしてるわ。", "あんなロケット", "飛びもしないのに．．．"]}, {"box": [1335, 782, 1516, 991], "vertical": true, "font_size": 39, "lines_coords": [[[1474.0, 782.0], [1516.0, 782.0], [1516.0, 921.0], [1474.0, 921.0]], [[1427.0, 785.0], [1467.0, 785.0], [1467.0, 991.0], [1427.0, 991.0]], [[1380.0, 782.0], [1420.0, 782.0], [1420.0, 975.0], [1380.0, 975.0]], [[1335.0, 782.0], [1368.0, 782.0], [1368.0, 972.0], [1335.0, 972.0]]], "lines": ["〝反陽子", "ばくだんの", "リモコンて", "どこなの？"]}, {"box": [1420, 1446, 1516, 1605], "vertical": true, "font_size": 52, "lines_coords": [[[1474.0, 1450.0], [1516.0, 1450.0], [1511.0, 1605.0], [1469.0, 1605.0]], [[1420.0, 1446.0], [1481.0, 1446.0], [1481.0, 1521.0], [1420.0, 1521.0]]], "lines": ["この子を", "ね。"]}, {"box": [884, 1132, 979, 1309], "vertical": true, "font_size": 48, "lines_coords": [[[916.0, 1132.0], [979.0, 1132.0], [979.0, 1228.0], [916.0, 1228.0]], [[885.0, 1143.0], [918.0, 1143.0], [918.0, 1307.0], [885.0, 1307.0]]], "lines": ["私は", "知らない。"]}, {"box": [578, 1134, 773, 1331], "vertical": true, "font_size": 50, "lines_coords": [[[719.0, 1134.0], [773.0, 1134.0], [773.0, 1223.0], [719.0, 1223.0]], [[674.0, 1136.0], [724.0, 1136.0], [724.0, 1267.0], [674.0, 1267.0]], [[632.0, 1139.0], [674.0, 1139.0], [674.0, 1331.0], [632.0, 1331.0]], [[578.0, 1139.0], [632.0, 1139.0], [632.0, 1239.0], [578.0, 1239.0]]], "lines": ["ただ", "連中は、", "私を狙って", "いる。"]}, {"box": [763, 1474, 851, 1666], "vertical": true, "font_size": 40, "lines_coords": [[[810.0, 1476.0], [850.0, 1476.0], [850.0, 1666.0], [810.0, 1666.0]], [[763.0, 1474.0], [803.0, 1474.0], [803.0, 1642.0], [763.0, 1642.0]]], "lines": ["この窓から", "見たのよ。"]}], "img_path": "00048.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [748, 292, 854, 574], "vertical": true, "font_size": 45, "lines_coords": [[[799.0, 292.0], [848.0, 292.0], [853.0