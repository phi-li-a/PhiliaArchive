 2053.0], [631.0, 2053.0]]], "lines": ["うーん、"]}, {"box": [208, 1846, 287, 2001], "vertical": true, "font_size": 40, "lines_coords": [[[243.0, 1846.0], [283.0, 1846.0], [283.0, 2001.0], [243.0, 2001.0]]], "lines": ["しかしさ"]}], "img_path": "00094.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1284, 196, 1464, 462], "vertical": true, "font_size": 36, "lines_coords": [[[1424.0, 196.0], [1464.0, 196.0], [1464.0, 365.0], [1424.0, 365.0]], [[1380.0, 201.0], [1413.0, 201.0], [1413.0, 459.0], [1380.0, 459.0]], [[1328.0, 196.0], [1368.0, 196.0], [1368.0, 389.0], [1328.0, 389.0]], [[1284.0, 196.0], [1317.0, 196.0], [1317.0, 386.0], [1284.0, 386.0]]], "lines": ["国連軍は、", "いつになったら", "あれを撤去", "するんだ？"]}, {"box": [1204, 1188, 1442, 1492], "vertical": true, "font_size": 40, "lines_coords": [[[1401.0, 1192.0], [1441.0, 1192.0], [1441.0, 1457.0], [1401.0, 1457.0]], [[1352.0, 1188.0], [1401.0, 1188.0], [1401.0, 1312.0], [1352.0, 1312.0]], [[1312.0, 1192.0], [1345.0, 1192.0], [1345.0, 1432.0], [1312.0, 1432.0]], [[1263.0, 1192.0], [1295.0, 1192.0], [1295.0, 1490.0], [1263.0, 1490.0]], [[1209.0, 1188.0], [1256.0, 1188.0], [1251.0, 1471.0], [1204.0, 1471.0]]], "lines": ["メチャクチャに", "なった", "都民の生活を、", "なんとかするのに", "手一杯なんだろ。"]}, {"box": [140, 1221, 281, 1468], "vertical": true, "font_size": 41, "lines_coords": [[[229.0, 1221.0], [281.0, 1221.0], [281.0, 1342.0], [229.0, 1342.0]], [[192.0, 1225.0], [224.0, 1225.0], [224.0, 1375.0], [192.0, 1375.0]], [[140.0, 1223.0], [180.0, 1223.0], [180.0, 1460.0], [140.0, 1460.0]]], "lines": ["ゴミの", "後始末は", "二の次ってね。"]}], "img_path": "00095.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1255, 133, 1530, 365], "vertical": true, "font_size": 40, "lines_coords": [[[1485.0, 138.0], [1527.0, 138.0], [1530.0, 292.0], [1488.0, 292.0]], [[1441.0, 140.0], [1483.0, 140.0], [1483.0, 307.0], [1441.0, 307.0]], [[1392.0, 138.0], [1431.0, 138.0], [1431.0, 365.0], [1392.0, 365.0]], [[1342.0, 133.0], [1392.0, 133.0], [1392.0, 260.0], [1342.0, 260.0]], [[1302.0, 140.0], [1335.0, 140.0], [1335.0, 328.0], [1302.0, 328.0]], [[1256.0, 140.0], [1288.0, 140.0], [1288.0, 325.0], [1256.0, 325.0]]], "lines": ["ゴミって", "いっても、", "なんかこっち", "見てて", "不気味なん", "だよね．．．"]}, {"box": [553, 203, 740, 513], "vertical": true, "font_size": 41, "lines_coords": [[[688.0, 203.0], [740.0, 203.0], [740.0, 304.0], [688.0, 304.0]], [[646.0, 210.0], [686.0, 210.0], [686.0, 513.0], [646.0, 513.0]], [[602.0, 210.0], [635.0, 210.0], [635.0, 475.0], [602.0, 475.0]], [[553.0, 213.0], [592.0, 213.0], [592.0, 513.0], [553.0, 513.0]]], "lines": ["さあ、", "金子氏、氏木氏！！", "そんなことより", "エンディングだ！！"]}, {"box": [1279, 839, 1509, 1109], "vertical": true, "font_size": 43, "lines_coords": [[[1467.0, 846.0], [1509.0, 846.0], [1509.0, 998.0], [1467.0, 998.0]], [[1413.0, 841.0], [1464.0, 841.0], [1464.0, 963.0], [1413.0, 963.0]], [[1375.0, 846.0], [1408.0, 846.0], [1408.0, 1108.0], [1375.0, 1108.0]], [[1319.0, 839.0], [1370.0, 839.0], [1370.0, 965.0], [1319.0, 965.0]], [[1279.0, 841.0], [1319.0, 841.0], [1319.0, 1035.0], [1279.0, 1035.0]]], "lines": ["主人公は", "地球の", "危機を救った！！", "その後", "どうする？"]}, {"box": [217, 839, 377, 997], "vertical": true, "font_size": 45, "lines_coords": [[[314.0, 841.0], [356.0, 841.0], [360.0, 996.0], [318.0, 996.0]], [[269.0, 839.0], [309.0, 839.0], [309.0, 996.0], [269.0, 996.0]], [[217.0, 839.0], [269.0, 839.0], [269.0, 946.0], [217.0, 946.0]]], "lines": ["角田氏は", "どう思う", "のよ。"]}, {"box": [1486, 1351, 1521, 1562], "vertical": true, "font_size": 32, "lines_coords": [[[1488.0, 1354.0], [1520.0, 1354.0], [1520.0, 1394.0], [1488.0, 1394.0]]], "lines": ["う"]}, {"box": [909, 1352, 1133, 1622], "vertical": true, "font_size": 37, "lines_coords": [[[1099.0, 1357.0], [1131.0, 1357.0], [1131.0, 1509.0], [1099.0, 1509.0]], [[1047.0, 1354.0], [1087.0, 1354.0], [1087.0, 1546.0], [1047.0, 1546.0]], [[1000.0, 1357.0], [1040.0, 1357.0], [1040.0, 1619.0], [1000.0, 1619.0]], [[953.0, 1352.0], [993.0, 1352.0], [993.0, 1544.0], [953.0, 1544.0]], [[909.0, 1354.0], [942.0, 1354.0], [942.0, 1617.0], [909.0, 1617.0]]], "lines": ["このまま", "終わったら", "つまらない．．．", "それだけは", "わかってる．．．"]}, {"box": [599, 1347, 829, 1544], "vertical": true, "font_size": 43, "lines_coords": [[[780.0, 1350.0], [829.0, 1350.0], [829.0, 1474.0], [780.0, 1474.0]], [[731.0, 1347.0], [787.0, 1347.0], [787.0, 1448.0], [731.0, 1448.0]], [[691.0, 1354.0], [731.0, 1354.0], [731.0, 1544.0], [691.0, 1544.0]], [[646.0, 1354.0], [679.0, 1354.0], [679.0, 1504.0], [646.0, 1504.0]], [[599.0, 1357.0], [635.0, 1357.0], [635.0, 1467.0], [599.0, 1467.0]]], "lines": ["それで", "最後、", "ヒーローは", "どうなる", "．．．．．．？"]}, {"box": [1335, 1750, 1520, 1982], "vertical": true, "font_size": 41, "lines_coords": [[[1478.0, 1755.0], [1520.0, 1755.0], [1520.0, 1907.0], [1478.0, 1907.0]], [[1431.0, 1753.0], [1471.0, 1753.0], [1471.0, 1982.0], [1431.0, 1982.0]], [[1385.0, 1755.0], [1427.0, 1755.0], [1422.0, 1910.0], [1380.0, 1910.0]], [[1335.0, 1750.0], [1375.0, 1750.0], [1380.0, 1924.0], [1340.0, 1924.0]]], "lines": ["もう一回", "敵が出てくる", "ってのは", "どうかな。"]}, {"box": [915, 1753, 1046, 2094], "vertical": true, "font_size": 36, "lines_coords": [[[1010.0, 1757.0], [1042.0, 1757.0], [1042.0, 2092.0], [1010.0, 2092.0]], [[960.0, 1753.0], [1003.0, 1753.0], [995.0, 2020.0], [953.0, 2020.0]], [[916.0, 1757.0], [949.0, 1757.0], [949.0, 1961.0], [916.0, 1961.0]]], "lines": ["ターミネーターとか", "ジェイソンとか", "みたいにね。"]}, {"box": [423, 1819, 454, 1943], "vertical": true, "font_size": 31, "lines_coords": [[[423.0, 1819.0], [454.0, 1819.0], [454.0, 1943.0], [423.0, 1943.0]]], "lines": ["．．．．．．"]}], "img_path": "00096.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1422, 220, 1462, 410], "vertical": true, "font_size": 35, "lines_coords": [[[1427.0, 220.0], [1462.0, 220.0], [1457.0, 410.0], [1422.0, 410.0]]], "lines": ["死ぬのか？"]}, {"box": [1279, 965, 1464, 1243], "vertical": true, "font_size": 40, "lines_coords": [[[1422.0, 967.0], [1462.0, 967.0]