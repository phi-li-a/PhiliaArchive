]]], "lines": ["な．．．．．", "何？"]}, {"box": [1263, 523, 1445, 843], "vertical": true, "font_size": 36, "lines_coords": [[[1406.0, 527.0], [1438.0, 527.0], [1438.0, 843.0], [1406.0, 843.0]], [[1356.0, 525.0], [1396.0, 525.0], [1396.0, 686.0], [1356.0, 686.0]], [[1310.0, 525.0], [1349.0, 525.0], [1349.0, 787.0], [1310.0, 787.0]], [[1263.0, 525.0], [1295.0, 525.0], [1295.0, 750.0], [1263.0, 750.0]]], "lines": ["瀬戸口ユキジさん。", "たった今、", "本部から連絡が", "入りました！！"]}, {"box": [1256, 932, 1472, 1266], "vertical": true, "font_size": 42, "lines_coords": [[[1424.0, 935.0], [1467.0, 935.0], [1469.0, 1258.0], [1427.0, 1258.0]], [[1368.0, 937.0], [1410.0, 937.0], [1410.0, 1164.0], [1368.0, 1164.0]], [[1310.0, 935.0], [1356.0, 935.0], [1356.0, 1211.0], [1310.0, 1211.0]], [[1256.0, 932.0], [1295.0, 932.0], [1295.0, 1253.0], [1256.0, 1253.0]]], "lines": ["あなたの仲間が", "大学病院と", "路上で人質を", "とっています！！"]}, {"box": [189, 934, 293, 1210], "vertical": true, "font_size": 41, "lines_coords": [[[243.0, 935.0], [285.0, 935.0], [288.0, 1209.0], [246.0, 1209.0]], [[189.0, 937.0], [229.0, 937.0], [229.0, 1162.0], [189.0, 1162.0]]], "lines": ["説得にご協力", "願いたい！！"]}, {"box": [1331, 1467, 1467, 1600], "vertical": true, "font_size": 62, "lines_coords": [[[1406.0, 1469.0], [1467.0, 1469.0], [1467.0, 1600.0], [1406.0, 1600.0]], [[1356.0, 1469.0], [1420.0, 1467.0], [1424.0, 1598.0], [1361.0, 1600.0]]], "lines": ["なんで", "すって"]}], "img_path": "00051.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1412, 142, 1471, 261], "vertical": true, "font_size": 59, "lines_coords": [[[1412.0, 142.0], [1471.0, 142.0], [1471.0, 261.0], [1412.0, 261.0]]], "lines": ["や、"]}, {"box": [742, 94, 819, 233], "vertical": true, "font_size": 77, "lines_coords": [[[742.0, 94.0], [819.0, 94.0], [819.0, 233.0], [742.0, 233.0]]], "lines": ["や．．．"]}, {"box": [1387, 1754, 1519, 1959], "vertical": true, "font_size": 38, "lines_coords": [[[1478.0, 1755.0], [1518.0, 1755.0], [1518.0, 1952.0], [1478.0, 1952.0]], [[1431.