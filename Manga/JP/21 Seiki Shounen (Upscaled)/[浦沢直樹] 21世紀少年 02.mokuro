33], "vertical": false, "font_size": 86, "lines_coords": [[[817.0, 93.0], [1558.0, 93.0], [1558.0, 297.0], [817.0, 297.0]], [[771.0, 264.0], [1504.0, 264.0], [1504.0, 332.0], [771.0, 332.0]], [[806.0, 330.0], [1471.0, 328.0], [1471.0, 382.0], [806.0, 384.0]], [[810.0, 382.0], [1469.0, 382.0], [1469.0, 428.0], [810.0, 428.0]]], "lines": ["敎場少年解介", "それはそういえばいいでしょうか。", "・反時子はくだんで世界は放りるだろう。少年やちに改る最大の危機。最後の", "スマホテムに入りに立ち取ってるだろう少年たちに迫る最大の危機、最後の強い"]}, {"box": [1235, 513, 1438, 557], "vertical": false, "font_size": 42, "lines_coords": [[[1235.0, 515.0], [1438.0, 513.0], [1438.0, 555.0], [1235.0, 557.0]]], "lines": ["オッチョ"]}, {"box": [213, 515, 426, 555], "vertical": false, "font_size": 40, "lines_coords": [[[213.0, 515.0], [426.0, 515.0], [426.0, 555.0], [213.0, 555.0]]], "lines": ["ヨシツネ"]}, {"box": [1224, 586, 1495, 717], "vertical": false, "font_size": 35, "lines_coords": [[[1225.0, 592.0], [1478.0, 592.0], [1478.0, 625.0], [1225.0, 625.0]], [[1291.0, 637.0], [1476.0, 637.0], [1476.0, 670.0], [1291.0, 670.0]], [[1288.0, 677.0], [1488.0, 677.0], [1488.0, 717.0], [1288.0, 717.0]]], "lines": ["●ケンヂの親友", "冷静沈着な", "武術の達人。"]}, {"box": [630, 637, 789, 675], "vertical": false, "font_size": 34, "lines_coords": [[[630.0, 639.0], [789.0, 637.0], [789.0, 672.0], [630.0, 675.0]]], "lines": ["コ、キミ"]}, {"box": [557, 717, 864, 794], "vertical": false, "font_size": 34, "lines_coords": [[[562.0, 717.0], [864.0, 717.0], [864.0, 750.0], [562.0, 750.0]], [[557.0, 759.0], [754.0, 761.0], [754.0, 794.0], [557.0, 792.0]]], "lines": ["●ケンチこの幼なじみ", "柔道の達人。"]}, {"box": [158, 594, 491, 765], "vertical": false, "font_size": 33, "lines_coords": [[[166.0, 595.0], [473.0, 595.0], [473.0, 628.0], [166.0, 628.0]], [[171.0, 642.0], [466.0, 642.0], [466.0, 675.0], [171.0, 675.0]], [[168.0, 686.0], [461.0, 686.0], [461.0, 719.0], [168.0, 719.0]], [[164.0, 726.0], [480.0, 726.0], [480.0, 759.0], [164.0, 759.0]]], "lines": ["カケンタこの幼ないみ", "気弱なサラリーマン", "だったが、なぜか", "組織のリーダーに"]}, {"box": [309, 1132, 391, 1164], "vertical": false, "font_size": 32, "lines_coords": [[[309.0, 1132.0], [391.0, 1132.0], [391.0, 1164.0], [309.0, 1164.0]]], "lines": ["ルオ"]}, {"box": [1066, 1757, 1492, 1842], "vertical": false, "font_size": 33, "lines_coords": [[[1066.0, 1757.0], [1488.0, 1757.0], [1488.0, 1790.0], [1066.0, 1790.0]], [[1152.0, 1802.0], [1485.0, 1807.0], [1485.0, 1839.0], [1152.0, 1835.0]]], "lines": ["●キリコと＂ともだち＂の娘？", "不思議な能力をもつ。"]}, {"box": [155, 1202, 483, 1333], "vertical": false, "font_size": 34, "lines_coords": [[[180.0, 1204.0], [478.0, 1202.0], [478.0, 1242.0], [180.0, 1244.0]], [[164.0, 1253.0], [466.0, 1253.0], [466.0, 1284.0], [164.0, 1284.0]], [[164.0, 1296.0], [391.0, 1296.0], [391.0, 1326.0], [164.0, 1326.0]]], "lines": ["●ケンヂの幼なじみ。", "実家は商店街でマ", "房具屋を経営。"]}, {"box": [206, 1685, 421, 1729], "vertical": false, "font_size": 40, "lines_coords": [[[206.0, 1685.0], [421.0, 1689.0], [421.0, 1729.0], [206.0, 1725.0]]], "lines": ["ケロヨン"]}, {"box": [1310, 1934, 1452, 2294], "vertical": true, "font_size": 54, "lines_coords": [[[1389.0, 1989.0], [1438.0, 1989.0], [1438.0, 2224.0], [1389.0, 2224.0]], [[1317.0, 1935.0], [1375.0, 1935.0], [1375.0, 2191.0], [1317.0, 2191.0]]], "lines": ["いままでの", "あらす"]}, {"box": [871, 1837, 1305, 2383], "vertical": true, "font_size": 90, "lines_coords": [[[1211.0, 1952.0], [1251.0, 1952.0], [1251.0, 2301.0], [1211.0, 2301.0]], [[1164.0, 1912.0], [1199.0, 1912.0], [1202.0, 2275.0], [1167.0, 2275.0]], [[1115.0, 1914.0], [1150.0, 1914.0], [1152.0, 2268.0], [1117.0, 2268.0]], [[1017.0, 1914.0], [1056.0, 1914.0], [1056.0, 2301.0], [1017.0, 2301.0]], [[1005.0, 1837.0], [1305.0, 1863.0], [1260.0, 2383.0], [963.0, 2357.0]], [[970.0, 1917.0], [1003.0, 1917.0], [1003.0, 2261.0], [970.0, 2261.0]], [[918.0, 1914.0], [958.0, 1914.0], [958.0, 2301.0], [918.0, 2301.0]], [[871.0, 1917.0], [904.0, 1917.0], [904.0, 2296.0], [871.0, 2296.0]]], "lines": ["昭和四〇年代、空き地", "に秘密基地を作り、引", "紀を語り合っていたケン", "世界征服計画を阻止す", "「昭和国、平代、空き道に親族投資を作り、韓国社を売り立ていたので、２０時間差１１歳の組織の症状行限兵庫を理止す」と言う気分を感じて、", "る正義の味方を夢見", "他愛のないシナリオを指", "き、それを。よげんの書を"]}, {"box": [128, 1788, 1010, 2400], "vertical": true, "font_size": 90, "lines_coords": [[[986.0, 2261.0], [1010.0, 2285.0], [988.0, 2308.0], [965.0, 2285.0]], [[822.0, 1912.0], [857.0, 1912.0], [853.0, 2118.0], [817.0, 2118.0]], [[773.0, 1950.0], [806.0, 1950.0], [806.0, 2299.0], [773.0, 2299.0]], [[623.0, 1912.0], [663.0, 1912.0], [663.0, 2242.0], [623.0, 2242.0]], [[527.0, 1914.0], [560.0, 1914.0], [560.0, 2247.0], [527.0, 2247.0]], [[513.0, 1853.0], [785.0, 1853.0], [785.0, 2332.0], [513.0, 2332.0]], [[389.0, 1879.0], [550.0, 1877.0], [555.0, 2303.0], [393.0, 2306.0]], [[370.0, 1910.0], [419.0, 1910.0], [419.0, 2310.0], [370.0, 2310.0]], [[325.0, 1912.0], [365.0, 1912.0], [365.0, 2303.0], [325.0, 2303.0]], [[295.0, 1800.0], [871.0, 1788.0], [883.0, 2400.0], [306.0, 2400.0]], [[278.0, 1912.0], [318.0, 1912.0], [318.0, 2306.0], [278.0, 2306.0]], [[232.0, 1914.0], [264.0, 1914.0], [264.0, 2301.0], [232.0, 2301.0]], [[175.0, 1910.0], [222.0, 1910.0], [222.0, 2306.0], [175.0, 2306.0]], [[128.0, 1910.0], [168.0, 1910.0], [171.0, 2303.0], [131.0, 2303.0]]], "lines": ["ん", "名づけていた。", "「九九七年、失踪した姉", "ヂは、ミュージシャン！", "るつまらない大人にな", "キリコの朝カンナを育てながらコンビニを含むテン犬は、ミュージシャンとか名参を成れ、レミにでもいるつまらない大人になって", "えっまらない大人になっていた。だが彼の周辺で起こる奇妙な事件が、子供の頭に書いたようなのね", "頃に書いた。よげんの書：", "通りであることに気づい", "それはそんなことはないのですが、それではなくなってしまったんですよね。今日はそれぞれの時は．．．というわけでもないけど、あなたがそれだと思うなんだろうかと思います。ことを知らないままですかった。そればこれですね。", "た時から、彼は巨大な事", "件に巻き込まれることに", "なる。ともだちょと言わ", "れる謎のカリスマが本気"]}, {"box": [154, 1750, 486, 1850], "vertical": false, "font_size": 32, "lines_coords": [[[166.0, 1764.0], [473.0, 1764.0], [473.0, 1797.0], [166.0, 1797.0]], [[161.0, 1811.0], [471.0, 1811.0], [471.0, 1842.0], [161.0, 1842.0]]], "lines": ["．．．の幼なじみ。", "カエル顔のそば屋"]}], "img_path": "00006.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [306, 555, 414, 600], "vertical": false, "font_size": 35, "lines_coords": [[[306.0, 555.0], [414.0, 555.0], [414.0, 600.0], [306.0, 600.0]]], "lines": ["蝶野"]}, {"box": [1216, 820, 1571, 956], "vertical": false, "font_size": 36, "lines_coords": [[[1216.0, 827.0], [1563.0, 820.0], [1563.0, 862.0], [1216.0, 869.0]], [[1223.0, 871.0], [1553.0, 871.0], [1553.0, 904.0], [1223.0, 904.0]], [[1220.0, 918.0], [1516.0, 918.0], [1516.0, 951.0], [1220.0, 951.0]]], "lines": ["●本編の主人公でカン", "ナの叔父＞。世界を救う", "元・ミュ・ジシャン。"]}, {"box": [203, 637, 522, 757], "vertical": false, "font_size": 35, "lines_coords": [[[203.0, 637.0], [508.0, 637.0], [508.0, 667.0], [203.0, 667.0]], [[203.0, 682.0], [513.0, 679.0], [513.0, 712.0], [203.0, 714.0]], [[208.0, 724.0], [522.0, 724.0], [522.0, 757.0], [208.0, 757.0]]], "lines": ["どもだちの犠牲者", "刑事。チョーさんの孫", "察予備隊の警官"]}, {"box": [1297, 1101, 1581, 1417], "vertical": false, "font_size": 36, "lines_coords": [[[1307.0, 1101.0], [1520.0, 1108.0], [1520.0, 1139.0], [1307.0, 1132.0]], [[1300.0, 1129.0], [1525.0, 1129.0], [1525.0, 1171.0], [1300.0, 1171.0]], [[1314.0, 1195.0], [1563.0, 1197.0], [1563.0, 1232.0], [1314.0, 1230.0]], [[1347.0, 1239.0], [1567.0, 1239.0], [1567.0, 1279.0], [1347.0, 1279.0]], [[1413.0, 1284.0], [1567.0, 1284.0], [1567.0, 1324.0], [1413.0, 1324.0]], [[1328.0, 1333.0], [1563.0, 1333.0], [1563.0, 1366.0], [1328.0, 1366.0]], [[1354.0, 1375.0], [1565.0, 1375.0], [1565.0, 1408.0], [1354.0, 1408.0]]], "lines": ["まぁ、しょう。わーいんじゃねえ", "プラマラミルがご", "●＂ともだち＂の", "腹心だったが", "暗殺され、", "ヴァーチャルを", "彷徨う幽霊に"]}, {"box": [1120, 1518, 1326, 1551], "vertical": false, "font_size": 33, "lines_coords": [[[1120.0, 1518.0], [1326.0, 1518.0], [1326.0, 1551.0], [1120.0, 1551.0]]], "lines": ["サダキヨ"]}, {"box": [1073, 1557, 1326, 1852], "vertical": false, "font_size": 35, "lines_coords": [[[1078.0, 1591.0], [1246.0, 1591.0], [1246.0, 1624.0], [1078.0, 1624.0]], [[1080.0, 1638.0], [1192.0, 1638.0], [1192.0, 1671.0], [1080.0, 1671.0]], [[1075.0, 1671.0], [1213.0, 1678.0], [1211.0, 1720.0], [1073.0, 1713.0]], [[1078.0, 1722.0], [1211.0, 1722.0], [1211.0, 1762.0], [1078.0, 1762.0]], [[1080.0, 1767.0], [1183.0, 1771.0], [1181.0, 1804.0], [1078.0, 1800.0]], [[1082.0, 1816.0], [1213.0, 1816.0], [1213.0, 1842.0], [1082.0, 1842.0]]], "lines": ["●ケーションの", "司級生", "５年生で", "転校した", "イジメ", "うれっ子"]}, {"box": [267, 1635, 480, 1675], "vertical": false, "font_size": 34, "lines_coords": [[[267.0, 1635.0], [480.0, 1635.0], [480.0, 1675.0], [267.0, 1675.0]]], "lines": ["ともだち"]}, {"box": [203, 1710, 550, 1832], "vertical": false, "font_size": 34, "lines_coords": [[[208.0, 1710.0], [550.0, 1713.0], [550.0, 1746.0], [208.0, 1743.0]], [[203.0, 1757.0], [536.0, 1753.0], [536.0, 1785.0], [203.0, 1790.0]], [[206.0, 1800.0], [503.0, 1800.0], [503.0, 1832.0], [206.0, 1832.0]]], "lines": ["●正体不「明の独裁者。", "ケンヂの同級生。人類", "滅亡計画の首謀者"]}, {"box": [724, 1790, 1556, 2400], "vertical": true, "font_size": 71, "lines_coords": [[[1516.0, 1912.0], [1556.0, 1912.0], [1556.0, 2306.0], [1516.0, 2306.0]], [[1467.0, 1912.0], [1506.0, 1912.0], [1504.0, 2303.0], [1464.0, 2303.0]], [[1417.0, 1912.0], [1459.0, 1912.0], [1455.0, 2306.0], [1413.0, 2306.0]], [[1366.0, 1912.0], [1413.0, 1912.0], [1413.0, 2308.0], [1366.0, 2308.0]], [[1321.0, 1917.0], [1354.0, 1917.0], [1354.0, 2306.0], [1321.0, 2306.0]], [[1272.0, 1919.0], [1305.0, 1919.0], [1305.0, 2303.0], [1272.0, 2303.0]], [[1216.0, 1912.0], [1263.0, 1912.0], [1263.0, 2308.0], [1216.0, 2308.0]], [[1124.0, 1914.0], [1157.0, 1914.0], [1160.0, 2268.0], [1127.0, 2268.0]], [[1073.0, 1952.0], [1106.0, 1952.0], [1108.0, 2273.0], [1075.0, 2273.0]], [[995.0, 1905.0], [1075.0, 1905.0], [1075.0, 2273.0], [995.0, 2273.0]], [[977.0, 1917.0], [1017.0, 1917.0], [1017.0, 2261.0], [977.0, 2261.0]], [[928.0, 1919.0], [960.0, 1919.0], [960.0, 2268.0], [928.0, 2268.0]], [[874.0, 1914.0], [913.0, 1914.0], [916.0, 2280.0], [876.0, 2280.0]], [[829.0, 1914.0], [869.0, 1914.0], [869.0, 2303.0], [829.0, 2303.0]], [[778.0, 1919.0], [817.0, 1919.0], [817.0, 2128.0], [778.0, 2128.0]], [[724.0, 1800.0], [1324.0, 1790.0], [1333.0, 2400.0], [733.0, 2400.0]]], "lines": ["で世界の征服を計画して", "いることに気づいたケンヂ", "は、幼なじみを集めて立", "ち上がる。しかし、ともだ", "ち。の巧妙な計略に嵌り", "２０世紀最後の日、テロリス", "トの汚名を着せられ行方", "惨劇を救った英雄とな", "二〇二五年、どもだお", "は暗殺されてしまう。ローマ芸ＥＤ前で夏香。", "ローマ法王の前で復活。", "雄から神の子に昇りつ", "た。彼はその一方、ウイル", "をばら撒き、世界を滅亡", "へと追い込む。", "ああ、そうだね．．．"]}, {"box": [576, 1863, 820, 2360], "vertical": true, "font_size": 71, "lines_coords": [[[581.0, 1917.0], [616.0, 1917.0], [618.0, 2280.0], [583.0, 2280.0]], [[576.0, 1863.0], [820.0, 1863.0], [820.0, 2360.0], [576.0, 2360.0]]], "lines": ["全滅亡計画を遂行する", "へと追い込む。二年後、巨界大統領として丑聖することだちはわずかに残った人様に完全感に印刷を遂行する。"]}, {"box": [288, 1912, 567, 2306], "vertical": true, "font_size": 71, "lines_coords": [[[534.0, 1954.0], [567.0, 1954.0], [567.0, 2306.0], [534.0, 2306.0]], [[487.0, 1919.0], [517.0, 1919.0], [517.0, 2306.0], [487.0, 2306.0]], [[435.0, 1921.0], [468.0, 1921.0], [468.0, 2303.0], [435.0, 2303.0]], [[379.0, 1912.0], [428.0, 1912.0], [428.0, 2036.0], [379.0, 2036.0]], [[337.0, 1947.0], [370.0, 1947.0], [370.0, 2289.0], [337.0, 2289.0]], [[288.0, 1919.0], [321.0, 1919.0], [321.0, 2306.0], [288.0, 2306.0]]], "lines": ["その時、奇跡的に２０世", "紀最後の目を生きのびた", "ケンヂが彼の前に立ちる", "さがる。", "「ともだち。は遂に倒れ", "平和は甦ったかに見えた"]}, {"box": [236, 1917, 271, 2315], "vertical": true, "font_size": 32, "lines_coords": [[[239.0, 1917.0], [271.0, 1917.0], [269.0, 2315.0], [236.0, 2315.0]]], "lines": ["が、悪夢はまだ続いていた。"]}], "img_path": "00007.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [45, 76, 454, 355], "vertical": false, "font_size": 188, "lines_coords": [[[121.0, 116.0], [431.0, 116.0], [431.0, 321.0], [121.0, 321.0]]], "lines": ["つまり"]}, {"box": [496, 226, 1017, 266], "vertical": false, "font_size": 25, "lines_coords": [[[496.0, 230.0], [1010.0, 230.0], [1010.0, 257.0], [496.0, 257.0]]], "lines": ["ＭａｃｃｒｉｕｋｉｓＡＷＡ『ＲＥＳＥＮＴＳ"]}, {"box": [1014, 121, 1584, 497], "vertical": false, "font_size": 77, "lines_coords": [[[1138.0, 314.0], [1495.0, 318.0], [1495.0, 407.0], [1138.0, 403.0]], [[1218.0, 407.0], [1455.0, 417.0], [1452.0, 496.0], [1216.0, 487.0]]], "