4, "lines_coords": [[[911.0, 1605.0], [960.0, 1605.0], [960.0, 1729.0], [911.0, 1729.0]], [[869.0, 1610.0], [909.0, 1610.0], [909.0, 1807.0], [869.0, 1807.0]]], "lines": ["本当に", "死んだのは、"]}, {"box": [581, 1610, 621, 1816], "vertical": true, "font_size": 40, "lines_coords": [[[581.0, 1610.0], [621.0, 1610.0], [621.0, 1814.0], [581.0, 1814.0]]], "lines": ["フクベエだ。"]}, {"box": [1060, 1606, 1243, 2042], "vertical": true, "font_size": 36, "lines_coords": [[[1202.0, 1607.0], [1242.0, 1607.0], [1242.0, 1839.0], [1202.0, 1839.0]], [[1152.0, 1610.0], [1192.0, 1610.0], [1192.0, 2039.0], [1152.0, 2039.0]], [[1108.0, 1610.0], [1141.0, 1610.0], [1141.0, 1952.0], [1108.0, 1952.0]], [[1061.0, 1610.0], [1094.0, 1610.0], [1094.0, 1800.0], [1061.0, 1800.0]]], "lines": ["俺ら子供達は", "冗談みたいに言ってたが、", "おまえは生きながら", "葬られた．．．"]}], "img_path": "00212.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1242, 199, 1472, 520], "vertical": true, "font_size": 35, "lines_coords": [[[1431.0, 201.0], [1471.0, 201.0], [1471.0, 468.0], [1431.0, 468.0]], [[1385.0, 199.0], [1424.0, 199.0], [1424.0, 440.0], [1385.0, 440.0]], [[1338.0, 199.0], [1370.0, 199.0], [1370.0, 517.0], [1338.0, 517.0]], [[1291.0, 201.0], [1324.0, 201.0], [1324.0, 468.0], [1291.0, 468.0]], [[1242.0, 199.0], [1274.0, 199.0], [1274.0, 464.0], [1242.0, 464.0]]], "lines": ["小学校卒業して", "すぐの春休み、", "フクベエは死んだ。", "ほとんど誰にも", "知られずに．．．"]}, {"box": [602, 435, 843, 705], "vertical": true, "font_size": 42, "lines_coords": [[[794.0, 435.0], [843.0, 435.0], [843.0, 560.0], [794.0, 560.0]], [[752.0, 440.0], [792.0, 440.0], [792.0, 604.0], [752.0, 604.0]], [[703.0, 440.0], [742.0, 440.0], [742.0, 635.0], [703.0, 635.0]], [[658.0, 440.0], [691.0, 440.0], [691.0, 705.0], [658.0, 705.0]], [[602.0, 435.0], [653.0, 435.0], [653.0, 536.0], [602.0, 536.0]]], "lines": ["それで", "おまえは、", "フクベエに", "なりかわろうと", "した。"]}, {"box": [1279, 1347, 1464, 1659], "vertical": true, "font_size": 40, "lines_coords": [[[1427.0, 1354.0], [1459.0, 13