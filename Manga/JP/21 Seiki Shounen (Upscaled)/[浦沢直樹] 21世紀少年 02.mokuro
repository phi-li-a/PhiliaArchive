48], "vertical": true, "font_size": 52, "lines_coords": [[[953.0, 1896.0], [995.0, 1896.0], [995.0, 2048.0], [953.0, 2048.0]], [[897.0, 1889.0], [958.0, 1889.0], [958.0, 1961.0], [897.0, 1961.0]]], "lines": ["知ってる", "わ。"]}], "img_path": "00043.webp"}, {"version": "0.2.1", "img_width": 1692, "img_height": 2400, "blocks": [{"box": [1413, 82, 1471, 147], "vertical": false, "font_size": 52, "lines_coords": [[[1431.0, 82.0], [1471.0, 98.0], [1452.0, 147.0], [1413.0, 131.0]]], "lines": ["チッ"]}, {"box": [766, 377, 806, 544], "vertical": true, "font_size": 40, "lines_coords": [[[766.0, 377.0], [806.0, 377.0], [806.0, 539.0], [766.0, 539.0]]], "lines": ["おじさん。"]}, {"box": [970, 673, 1068, 828], "vertical": true, "font_size": 98, "lines_coords": [[[970.0, 673.0], [1068.0, 673.0], [1068.0, 828.0], [970.0, 828.0]]], "lines": ["チョーチュレ"]}, {"box": [717, 663, 812, 823], "vertical": true, "font_size": 46, "lines_coords": [[[778.0, 675.0], [810.0, 675.0], [810.0, 822.0], [778.0, 822.0]], [[717.0, 663.0], [778.0, 663.0], [778.0, 775.0], [717.0, 775.0]]], "lines": ["おじさん", "てば。"]}, {"box": [213, 895, 262, 1019], "vertical": true, "font_size": 49, "lines_coords": [[[213.0, 895.0], [262.0, 895.0], [262.0, 1019.0], [213.0, 1019.0]]], "lines": ["む．．．．．．"]}, {"box": [1429, 1132, 1516, 1361], "vertical": true, "font_size": 38, "lines_coords": [[[1474.0, 1132.0], [1516.0, 1132.0], [1516.0, 1319.0], [1474.0, 1319.0]], [[1431.0, 1132.0], [1464.0, 1132.0], [1464.0, 1359.0], [1431.0, 1359.0]]], "lines": ["む〜〜～～～", "なんだあ．．．．．"]}, {"box": [1420, 1619, 1503, 1844], "vertical": true, "font_size": 32, "lines_coords": [[[1467.0, 1619.0], [1499.0, 1619.0], [1499.0, 1844.0], [1467.0, 1844.0]], [[1420.0, 1619.0], [1452.0, 1619.0], [1452.0, 1818.0], [1420.0, 1818.0]]], "lines": ["なんだよ．．．", "おまえかよ。"]}, {"box": [688, 1110, 795, 1337], "vertical": true, "font_size": 43, "lines_coords": [[[749.0, 1113.0], [792.0, 1113.0], [792.0, 1305.0], [749.0, 1305.0]], [[693.0, 1110.0], [735.0, 1110.0], [731.0, 1335.0], [