{"version": "0.1.7", "img_width": 1032, "img_height": 1592, "blocks": [{"box": [242, 10, 414, 31], "vertical": false, "font_size": 21, "lines_coords": [[[242.0, 10.0], [414.0, 10.0], [414.0, 31.0], [242.0, 31.0]]], "lines": ["月間ランキング第８位"]}, {"box": [116, 54, 980, 202], "vertical": false, "font_size": 70.5, "lines_coords": [[[116.0, 54.0], [980.0, 60.0], [980.0, 138.0], [116.0, 132.0]], [[135.0, 125.0], [944.0, 139.0], [944.0, 202.0], [135.0, 188.0]]], "lines": ["「俺より度胸ある奴いんの？」", "一公共の場での迷惑行為を自慢一"]}, {"box": [430, 237, 719, 253], "vertical": false, "font_size": 16, "lines_coords": [[[430.0, 237.0], [719.0, 237.0], [719.0, 253.0], [430.0, 253.0]]], "lines": ["．．．あああっはああ"]}, {"box": [422, 253, 943, 276], "vertical": false, "font_size": 22, "lines_coords": [[[422.0, 253.0], [943.0, 254.0], [943.0, 276.0], [422.0, 275.0]]], "lines": ["プログに書く０つぶやく！２．おすすめする。９このページを印刷"]}, {"box": [424, 301, 833, 362], "vertical": false, "font_size": 29.0, "lines_coords": [[[425.0, 301.0], [833.0, 301.0], [833.0, 328.0], [425.0, 328.0]], [[424.0, 328.0], [789.0, 331.0], [789.0, 362.0], [424.0, 359.0]]], "lines": ["勝コミュニティサイトが流行る今日、", "使われ方も多様である．．．。"]}, {"box": [533, 214, 899, 236], "vertical": false, "font_size": 20, "lines_coords": [[[533.0, 214.0], [899.0, 216.0], [899.0, 236.0], [533.0, 234.0]]], "lines": ["携帯出来る育毛剤に興味はありませんか？［ＰＲ］"]}, {"box": [89, 679, 395, 719], "vertical": false, "font_size": 18, "lines_coords": [[[91.0, 682.0], [391.0, 679.0], [391.0, 699.0], [91.0, 702.0]], [[91.0, 702.0], [315.0, 699.0], [315.0, 716.0], [91.0, 719.0]]], "lines": ["この男子生徒が通う高校に問い合わせた所", "現在事実関係を調査中とのこと。"]}, {"box": [425, 520, 794, 541], "vertical": false, "font_size": 21, "lines_coords": [[[425.0, 520.0], [794.0, 520.0], [794.0, 541.0], [425.0, 541.0]]], "lines": ["橋の下には市で詞言されている時間がいる。"]}, {"box": [435, 564, 916, 610], "vertical": false, "font_size": 21.0, "lines_coords": [[[442.0, 565.0], [916.0, 564.0], [916.0, 586.0], [442.0, 587.0]], [[435.0, 590.0], [763.0, 587.0], [763.0, 607.0], [435.0, 610.0]]], "lines": ["週３日、この場所で壁に飯をあげている高須さんは言う。", "「最近ここの鯉の元気が無い．．．」"]}, {"box": [390, 371, 1050, 519], "vertical": false, "font_size": 52.6, "lines_coords": [[[441.0, 380.0], [736.0, 380.0], [736.0, 402.0], [441.0, 402.0]], [[390.0, 371.0], [1050.0, 371.0], [1050.0, 506.0], [390.0, 506.0]], [[450.0, 421.0], [994.0, 408.0], [994.0, 450.0], [450.0, 463.0]], [[419.0, 460.0], [691.0, 467.0], [690.0, 509.0], [418.0, 502.0]], [[424.0, 497.0], [996.0, 494.0], [996.0, 516.0], [424.0, 519.0]]], "lines": ["とある投稿に弁護が発習している。橋から川へ飛び込む少空。一見くの", "そうか．．．そうだな。そうなんだけど、そういうことはありませんでしょうかもしれないのですが、それではないですから、そんなことなんですね。それはあなたが、これでもうないうですよ。", "それ以外の報告も楽しましたが、あまりにもかかったのですが、初めてご利用されておりませんが、このようなことがあるのではないでしょうか。", "ひそめるのではないだろうか。「俺より腹痛みる良いんの？」彼がこれを振った公共の広場には", "俺より英解ある気にいんの？彼がこれを振った公共の広場には、橋の下には市で写真さんでしょう。市民が利用する小さな横がある。がいろ。"]}, {"box": [428, 631, 1024, 680], "vertical": false, "font_size": 21.333333333333332, "lines_coords": [[[444.0, 637.0], [901.0, 631.0], [901.0, 652.0], [444.0, 659.0]], [[428.0, 660.0], [680.0, 660.0], [680.0, 680.0], [428.0, 680.0]], [[669.0, 656.0], [1024.0, 652.0], [1024.0, 674.0], [669.0, 677.0]]], "lines": ["彼の投稿展展をさかのぼってみると、今回のみならず、", "過去にもこういった飛び込み", "みーい友樹試しが行われていたのである"]}, {"box": [427, 677, 997, 727], "vertical": false, "font_size": 21.0, "lines_coords": [[[427.0, 684.0], [912.0, 677.0], [912.0, 698.0], [427.0, 704.0]], [[430.0, 705.0], [997.0, 699.0], [997.0, 721.0], [430.0, 727.0]]], "lines": ["なぜそんな事を？自慢？武馬伝？ノリ？勝負？ネタ提供？", "何が動機にせよ彼の行高は世界中に発信されてしまったのである．．．"]}, {"box": [90, 783, 174, 981], "vertical": true, "font_size": 79, "lines_coords": [[[90.0, 783.0], [169.0, 783.0], [169.0, 956.0], [90.0, 956.0]]], "lines": ["え？"]}, {"box": [371, 1173, 444, 1472], "vertical": true, "font_size": 65, "lines_coords": [[[371.0, 1176.0], [436.0, 1175.0], [442.0, 1470.0], [377.0, 1472.0]]], "lines": ["あの時の．．．！？"]}, {"box": [797, 1046, 909, 1358], "vertical": true, "font_size": 89, "lines_coords": [[[797.0, 1052.0], [885.0, 1046.0], [909.0, 1352.0], [820.0, 1358.0]]], "lines": ["これ俺！？"]}]}