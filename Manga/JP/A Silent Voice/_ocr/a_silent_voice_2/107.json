{"version": "0.1.7", "img_width": 1032, "img_height": 1592, "blocks": [{"box": [119, 163, 277, 447], "vertical": true, "font_size": 45, "lines_coords": [[[233.0, 169.0], [270.0, 169.0], [270.0, 328.0], [233.0, 328.0]], [[172.0, 166.0], [220.0, 166.0], [220.0, 447.0], [172.0, 447.0]], [[122.0, 163.0], [172.0, 163.0], [169.0, 362.0], [119.0, 362.0]]], "lines": ["何これ．．．", "全然頭に入って", "こない．．．"]}, {"box": [556, 161, 679, 203], "vertical": false, "font_size": 19.0, "lines_coords": [[[571.0, 161.0], [674.0, 167.0], [674.0, 185.0], [571.0, 178.0]], [[556.0, 178.0], [679.0, 183.0], [679.0, 203.0], [556.0, 199.0]]], "lines": ["とある投稿に滅び", "このうえ。一度、傷から川へ飛込む。しかし"]}, {"box": [547, 186, 690, 293], "vertical": false, "font_size": 35.0, "lines_coords": [[[554.0, 186.0], [680.0, 195.0], [679.0, 223.0], [553.0, 214.0]], [[557.0, 211.0], [677.0, 214.0], [677.0, 236.0], [557.0, 233.0]], [[559.0, 225.0], [683.0, 225.0], [683.0, 258.0], [559.0, 258.0]], [[548.0, 233.0], [690.0, 236.0], [688.0, 293.0], [547.0, 290.0]]], "lines": ["嫌から川へ飛込むしかし、彼の事を２ひそめるのではな", "しかし、彼の書きてひそめるのではない「熱より変換あるが", "ひそもそのではなく「俺より英語おる！彼がこれを嫌った」", "「俺より皮膚あるが彼がこれを乗った公機の下には市で相資さ"]}, {"box": [671, 160, 814, 457], "vertical": true, "font_size": 68.5, "lines_coords": [[[742.0, 163.0], [808.0, 161.0], [814.0, 455.0], [749.0, 457.0]], [[671.0, 160.0], [742.0, 160.0], [742.0, 379.0], [671.0, 379.0]]], "lines": ["ネットに俺が", "投稿．．．？"]}, {"box": [814, 143, 1000, 163], "vertical": false, "font_size": 17, "lines_coords": [[[814.0, 143.0], [1000.0, 146.0], [1000.0, 163.0], [814.0, 160.0]]], "lines": ["日、使われ方も多様である"]}, {"box": [800, 188, 963, 226], "vertical": false, "font_size": 18.0, "lines_coords": [[[800.0, 188.0], [963.0, 194.0], [963.0, 214.0], [800.0, 208.0]], [[814.0, 206.0], [960.0, 211.0], [960.0, 226.0], [814.0, 222.0]]], "lines": ["貴と思われるかもしれない食べはってーった。", "えーといった大人なら誰を持った犬人なんだら星を"]}, {"box": [829, 310, 896, 365], "vertical": false, "font_size": 42, "lines_coords": [[[829.0, 324.0], [885.0, 310.0], [896.0, 351.0], [840.0, 365.0]]], "lines": ["一時の比判があるから"]}, {"box": [514, 539, 798, 583], "vertical": false, "font_size": 18.0, "lines_coords": [[[543.0, 539.0], [784.0, 547.0], [784.0, 562.0], [543.0, 555.0]], [[514.0, 556.0], [798.0, 562.0], [798.0, 583.0], [514.0, 576.0]]], "lines": ["その環境は何によってやって作られたのかー", "筆者は何やだ！！で今からね"]}, {"box": [512, 477, 1016, 556], "vertical": false, "font_size": 28.8, "lines_coords": [[[728.0, 477.0], [1010.0, 483.0], [1010.0, 505.0], [728.0, 499.0]], [[575.0, 491.0], [783.0, 491.0], [783.0, 522.0], [575.0, 522.0]], [[512.0, 494.0], [592.0, 494.0], [592.0, 522.0], [512.0, 522.0]], [[533.0, 520.0], [983.0, 536.0], [983.0, 556.0], [533.0, 541.0]], [[784.0, 499.0], [1016.0, 499.0], [1016.0, 542.0], [784.0, 542.0]]], "lines": ["当社の社長が大丈夫で、うした危険", "おまえはまあまあ食べてるのは", "あだめて", "日本の投資が、この時間が、ごめいった結婚相談は何でよ。では東京都市東京東京駅からのお世話番号へと盛り立てるのではないか。", "実行記事でも実際の新しいというのは"]}, {"box": [839, 382, 943, 418], "vertical": false, "font_size": 16.5, "lines_coords": [[[839.0, 382.0], [910.0, 385.0], [910.0, 402.0], [839.0, 399.0]], [[840.0, 402.0], [943.0, 402.0], [943.0, 418.0], [840.0, 418.0]]], "lines": ["ネタ望快？", "しまったのである"]}, {"box": [812, 415, 1005, 453], "vertical": false, "font_size": 18.5, "lines_coords": [[[812.0, 415.0], [1005.0, 422.0], [1005.0, 444.0], [812.0, 436.0]], [[815.0, 438.0], [923.0, 438.0], [923.0, 453.0], [815.0, 453.0]]], "lines": ["その手段を知って", "．．．うはまたしたら"]}, {"box": [839, 569, 960, 589], "vertical": false, "font_size": 17, "lines_coords": [[[839.0, 569.0], [960.0, 572.0], [960.0, 589.0], [839.0, 586.0]]], "lines": ["ずるその事"]}, {"box": [747, 691, 850, 862], "vertical": true, "font_size": 26, "lines_coords": [[[823.0, 694.0], [850.0, 694.0], [850.0, 803.0], [823.0, 803.0]], [[778.0, 691.0], [806.0, 691.0], [808.0, 862.0], [780.0, 862.0]], [[747.0, 694.0], [774.0, 694.0], [774.0, 806.0], [747.0, 806.0]]], "lines": ["こんなの", "投稿した覚え", "ないしさ"]}, {"box": [932, 621, 988, 778], "vertical": true, "font_size": 26, "lines_coords": [[[958.0, 621.0], [986.0, 621.0], [988.0, 735.0], 