{"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [86, 27, 218, 38], "vertical": false, "font_size": 11, "lines_coords": [[[86.0, 27.0], [218.0, 27.0], [218.0, 38.0], [86.0, 38.0]]], "lines": ["ング総評、オトコ製"]}, {"box": [302, 90, 677, 417], "vertical": true, "font_size": 82, "lines_coords": [[[607.0, 173.0], [662.0, 173.0], [665.0, 417.0], [610.0, 417.0]], [[520.0, 94.0], [605.0, 92.0], [611.0, 361.0], [527.0, 363.0]], [[447.0, 92.0], [541.0, 92.0], [541.0, 302.0], [447.0, 302.0]], [[382.0, 92.0], [470.0, 94.0], [465.0, 299.0], [377.0, 298.0]], [[317.0, 90.0], [403.0, 97.0], [388.0, 307.0], [302.0, 301.0]]], "lines": ["ならざる", "者たちが、", "異なる", "者の間", "揺れる、"]}, {"box": [683, 102, 752, 365], "vertical": true, "font_size": 27, "lines_coords": [[[723.0, 102.0], [750.0, 102.0], [750.0, 361.0], [723.0, 361.0]], [[683.0, 102.0], [710.0, 102.0], [710.0, 333.0], [683.0, 333.0]]], "lines": ["そして吸血鬼や食人鬼マ", "ツガは、人の姿をして"]}, {"box": [46, 210, 348, 1088], "vertical": true, "font_size": 86, "lines_coords": [[[216.0, 253.0], [296.0, 247.0], [348.0, 980.0], [269.0, 986.0]], [[121.0, 232.0], [211.0, 223.0], [253.0, 653.0], [162.0, 661.0]], [[46.0, 239.0], [138.0, 232.0], [205.0, 1082.0], [113.0, 1088.0]], [[164.0, 627.0], [245.0, 621.0], [280.0, 1071.0], [199.0, 1077.0]]], "lines": ["人はしょせんわかりあえない", "他人同士。でも", "手を伸ばせば届く距離でもある。", "も、人の隔たりは"]}, {"box": [728, 506, 750, 806], "vertical": true, "font_size": 22, "lines_coords": [[[728.0, 506.0], [750.0, 506.0], [750.0, 806.0], [728.0, 806.0]]], "lines": ["にする作者の十八番でもあ"]}, {"box": [407, 470, 712, 1176], "vertical": true, "font_size": 27.875, "lines_coords": [[[683.0, 471.0], [712.0, 471.0], [710.0, 1173.0], [681.0, 1173.0]], [[646.0, 471.0], [673.0, 471.0], [673.0, 801.0], [646.0, 801.0]], [[603.0, 470.0], [635.0, 470.0], [634.0, 991.0], [602.0, 991.0]], [[567.0, 473.0], [594.0, 473.0], [594.0, 804.0], [567.0, 804.0]], [[527.0, 473.0], [554.0, 473.0], [554.0, 694.0], [527.0, 694.0]], [[490.0, 492.0], [517.0, 492.0], [511.0, 1173.0], [484.0, 1173.0]], [[450.0, 471.0], [477.0, 471.0], [471.0, 1176.0], [444.0, 1176.0]], [[411.0, 471.0], [438.0, 471.0], [434.0, 1169.0], [407.0, 1169.0]]], "lines": ["る。かたや『東京喰種』（２位）のおもしろさは、偏見に固", "はスタイリッシュに傾きつつ", "も、序盤のアニメ化により主人、爽やかさだ。", "公のアイデンティティを問うた", "原点が思い出された。", "同じ社会のなかでも「無理解」変則的すぎる家族ぐるみのおつ", "が人を隔てることもある。原子、きあいから恋が芽生えた。子供", "力発電所での作業も都市伝説のはわかってあげない」ですが、"]}, {"box": [522, 819, 594, 1174], "vertical": true, "font_size": 30.0, "lines_coords": [[[565.0, 819.0], [594.0, 819.0], [592.0, 1174.0], [564.0, 1174.0]], [[524.0, 838.0], [556.0, 838.0], [554.0, 1173.0], [522.0, 1173.0]]], "lines": ["「異質ｘ異質の王道は", "ボーイ・ミーツ・ガール。"]}, {"box": [642, 836, 672, 1174], "vertical": true, "font_size": 27, "lines_coords": [[[645.0, 836.0], [672.0, 836.0], [669.0, 1174.0], [642.0, 1174.0]]], "lines": ["まった頭に風穴を開ける"]}, {"box": [724, 511, 986, 1177], "vertical": true, "font_size": 25.375, "lines_coords": [[[963.0, 546.0], [986.0, 546.0], [986.0, 801.0], [963.0, 801.0]], [[924.0, 541.0], [946.0, 541.0], [946.0, 803.0], [924.0, 803.0]], [[882.0, 532.0], [909.0, 532.0], [909.0, 808.0], [882.0, 808.0]], [[844.0, 525.0], [871.0, 525.0], [868.0, 801.0], [841.0, 801.0]], [[806.0, 519.0], [828.0, 519.0], [828.0, 819.0], [806.0, 819.0]], [[764.0, 511.0], [791.0, 511.0], [790.0, 808.0], [763.0, 808.0]], [[759.0, 792.0], [791.0, 792.0], [790.0, 1177.0], [758.0, 1177.0]], [[724.0, 803.0], [747.0, 803.0], [747.0, 1171.0], [724.0, 1171.0]]], "lines": ["時の流れに人間関係を", "押し流された主人公を独", "居老人のように描いた", "『日暮のクロニクル』（１４位）", "は斬新だったし、日常と非、", "日常を「お役所」で地続き", "さ、『いちえふ』でもやっ健康で文章", "「化的な最低限度の生活」へ１０位"]}, {"box": [801, 806, 989, 1547], "vertical": true, "font_size": 27.6, "lines_coords": [[[955.0, 836.0], [986.0, 836.0], [989.0, 1547.0], [959.0, 1547.0]], [[920.0, 839.0], [947.0, 839.0], [947.0, 1179.0], [920.0, 1179.0]], [[881.0, 806.0], [908.0, 806.0], [906.0, 1177.0], [879.0, 1177.0]], [[839.0, 833.0], [866.0, 833.0], [866.0, 1171.0], [839.0, 1171.0]], [[801.0, 836.0], [828.0, 836.0], [828.0, 1176.0], [801.0, 1176.0]]], "lines": ["士がメシを食い、汗を流出会うがトウの立ったボーイ同", "す日常がある。生活保護の現", "一場でも、統計数字の向こうには", "一人ひとりが生を習んでいる。", "綿密な取材や体験に基づいた"]}, {"box": [995, 549, 1029, 1547], "vertical": true, "font_size": 32, "lines_coords": [[[997.0, 549.0], [1029.0, 549.0], [1027.0, 1547.0], [995.0, 1547.0]]], "lines": ["そあぶり出す定番だ。いっ地獄ではなく、仲間同一戦後の焼け跡でガール．．．とも"]}, {"box": [423, 1201, 845, 1547], "vertical": true, "font_size": 78, "lines_coords": [[[763.0, 1227.0], [825.0, 1225.0], [831.0, 1416.0], [769.0, 1418.0]], [[680.0, 1203.0], [780.0, 1201.0], [783.0, 1416.0], [683.0, 1418.0]], [[629.0, 1244.0], [691.0, 1244.0], [691.0, 1486.0], [629.0, 1486.0]], [[536.0, 1206.0], [643.0, 1206.0], [643.0, 1542.0], [536.0, 1542.0]], [[482.0, 1214.0], [560.0, 1212.0], [565.0, 1510.0], [487.0, 1512.0]], [[423.0, 1217.0], [482.0, 1217.0], [482.0, 1353.0], [423.0, 1353.0]]], "lines": ["いつまで", "相手が", "ミステリア", "こんな素敵", "な関係って", "ない"]}, {"box": [842, 1206, 868, 1364], "vertical": true, "font_size": 24, "lines_coords": [[[842.0, 1206.0], [866.0, 1206.0], [868.0, 1364.0], [844.0, 1364.0]]], "lines": ["ら惹かれあう。"]}, {"box": [884, 1179, 946, 1544], "vertical": true, "font_size": 22.0, "lines_coords": [[[924.0, 1179.0], [946.0, 1179.0], [946.0, 1544.0], [924.0, 1544.0]], [[884.0, 1180.0], [906.0, 1180.0], [906.0, 1542.0], [884.0, 1542.0]]], "lines": ["上が出会い直す『あれよ星屑』", "〈５位〉も、互いにわからないか"]}]}