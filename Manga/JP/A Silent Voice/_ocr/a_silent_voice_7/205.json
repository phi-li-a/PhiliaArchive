], [[900.0, 1211.0], [927.0, 1211.0], [928.0, 1537.0], [901.0, 1537.0]], [[871.0, 1211.0], [893.0, 1211.0], [893.0, 1536.0], [871.0, 1536.0]], [[834.0, 1212.0], [863.0, 1212.0], [863.0, 1306.0], [834.0, 1306.0]]], "lines": ["しますか？", "大今、そうですね、読者の声を聞き", "くことも目的でこの作品を探して", "いたようなものですから。感想を", "書いてくれる人には、本当に感謝", "してます。"]}, {"box": [803, 1255, 825, 1469], "vertical": true, "font_size": 25, "lines_coords": [[[803.0, 1255.0], [825.0, 1255.0], [825.0, 1469.0], [803.0, 1469.0]]], "lines": ["一何で感想を見ます？"]}, {"box": [632, 1208, 798, 1541], "vertical": true, "font_size": 25, "lines_coords": [[[764.0, 1208.0], [796.0, 1208.0], [798.0, 1541.0], [766.0, 1541.0]], [[734.0, 1211.0], [761.0, 1211.0], [761.0, 1539.0], [734.0, 1539.0]], [[704.0, 1211.0], [726.0, 1211.0], [726.0, 1536.0], [704.0, 1536.0]], [[670.0, 1212.0], [693.0, 1212.0], [693.0, 1533.0], [670.0, 1533.0]], [[632.0, 1211.0], [659.0, 1211.0], [661.0, 1541.0], [634.0, 1541.0]]], "lines": ["大今ネットですね。独りごとみ", "たいな、むきだしの、なんとなく", "しゃべったような感想が聞きたい", "ので、ツイッター、２ちゃんねる。", "４ｃｈａｎ、ふたば☆ちゃんねる"]}, {"box": [570, 1262, 592, 1537], "vertical": true, "font_size": 23, "lines_coords": [[[570.0, 1262.0], [592.0, 1262.0], [592.0, 1537.0], [570.0, 1537.0]]], "lines": ["「かなり見てますね（笑）。最"]}, {"box": [436, 1211, 559, 1539], "vertical": true, "font_size": 23, "lines_coords": [[[536.0, 1233.0], [559.0, 1233.0], [559.0, 1534.0], [536.0, 1534.0]], [[501.0, 1211.0], [528.0, 1211.0], [528.0, 1536.0], [501.0, 1536.0]], [[470.0, 1212.0], [492.0, 1212.0], [492.0, 1539.0], [470.0, 1539.0]], [[436.0, 1214.0], [458.0, 1214.0], [458.0, 1407.0], [436.0, 1407.0]]], "lines": ["後に読者にひと言お願いします。", "大今、読者のみなさまにこのマン", "ガを育てていただきました。あり", "がとうございました。"]}, {"box": [404, 1273, 426, 1530], "vertical": true, "font_size": 23, "lines_coords": [[[404.0, 1273.0], [426.0, 1273.0], [426.0, 1530.0], [404.0, 1530.0]]], "lines": ["連載終了、お疲れ様でした。"]}, {"box": [21, 1201, 255, 1294], "vertical": false, "font_size": 30, "lines_coords": [[[30.0, 1235.0], [238.0, 1201.0], [243.0, 1228.0], [35.