ords": [[[139.0, 603.0], [499.0, 603.0], [499.0, 629.0], [139.0, 629.0]], [[141.0, 634.0], [500.0, 634.0], [500.0, 665.0], [141.0, 665.0]], [[143.0, 671.0], [292.0, 671.0], [292.0, 698.0], [143.0, 698.0]], [[141.0, 702.0], [500.0, 704.0], [500.0, 732.0], [141.0, 730.0]], [[141.0, 735.0], [503.0, 735.0], [503.0, 768.0], [141.0, 768.0]], [[136.0, 764.0], [508.0, 768.0], [508.0, 805.0], [136.0, 802.0]]], "lines": ["妹の事もあるし、私も家族や", "石田君達と離れそのは正直さ", "みしいです。", "資格ならどこに居ても取れる", "ので、東京じやなくて地元で", "チャレンジしてみますｐ（＾＾）ｑ"]}, {"box": [558, 1216, 586, 1338], "vertical": true, "font_size": 26, "lines_coords": [[[558.0, 1217.0], [584.0, 1217.0], [584.0, 1337.0], [558.0, 1337.0]]], "lines": ["あーらら"]}, {"box": [335, 1263, 374, 1413], "vertical": true, "font_size": 38, "lines_coords": [[[335.0, 1263.0], [373.0, 1263.0], [373.0, 1413.0], [335.0, 1413.0]]], "lines": ["おおう．．．"]}, {"box": [59, 1316, 119, 1531], "vertical": true, "font_size": 32, "lines_coords": [[[97.0, 1319.0], [119.0, 1319.0], [119.0, 1425.0], [97.0, 1425.0]], [[59.0, 1316.0], [102.0, 1316.0], [102.0, 1528.0], [59.0, 1528.0]]], "lines": ["ざいあくかん", "罪悪感が．．．"]}]}