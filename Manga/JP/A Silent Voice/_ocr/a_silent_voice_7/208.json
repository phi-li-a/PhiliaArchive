0]], [[889.0, 468.0], [927.0, 468.0], [927.0, 532.0], [889.0, 532.0]]], "lines": ["人はしょせんわかりあえない", "他人同士。それでも一緒に前に", "歩いていけるー。今年の顔ぶ", "れは、"]}, {"box": [262, 835, 293, 1171], "vertical": true, "font_size": 27, "lines_coords": [[[266.0, 835.0], [293.0, 835.0], [289.0, 1171.0], [262.0, 1171.0]]], "lines": ["物語で、現実で解体しつつあっ"]}, {"box": [109, 465, 528, 1453], "vertical": true, "font_size": 27.53846153846154, "lines_coords": [[[500.0, 495.0], [528.0, 495.0], [525.0, 803.0], [497.0, 803.0]], [[457.0, 470.0], [489.0, 470.0], [489.0, 1174.0], [457.0, 1174.0]], [[420.0, 468.0], [452.0, 468.0], [452.0, 811.0], [420.0, 811.0]], [[423.0, 809.0], [446.0, 809.0], [446.0, 1171.0], [423.0, 1171.0]], [[382.0, 795.0], [409.0, 795.0], [409.0, 1173.0], [382.0, 1173.0]], [[382.0, 471.0], [409.0, 471.0], [409.0, 806.0], [382.0, 806.0]], [[342.0, 471.0], [369.0, 471.0], [369.0, 803.0], [342.0, 803.0]], [[304.0, 470.0], [331.0, 470.0], [331.0, 1173.0], [304.0, 1173.0]], [[264.0, 468.0], [291.0, 468.0], [288.0, 847.0], [261.0, 847.0]], [[224.0, 470.0], [251.0, 470.0], [251.0, 1174.0], [224.0, 1174.0]], [[180.0, 465.0], [216.0, 465.0], [219.0, 927.0], [183.0, 927.0]], [[148.0, 471.0], [170.0, 471.0], [170.0, 804.0], [148.0, 804.0]], [[109.0, 473.0], [132.0, 473.0], [132.0, 1453.0], [109.0, 1453.0]]], "lines": ["トップの『賢の形』〈１位〉は、", "聴覚が「自由が不自由か」から、法使いの嫁」（２位）も人外ｘ少", "始まり、いじめっ子といじぬら", "「女カップルが違いに戸惑いつつ", "こ、も「夫婦」になろうとし、『ジャー", "れっ子、日常を壊したもの壊さ", "れたものの溝に向きあう。過去", "は変えられず、心の壁はいつまでが共同生活のなかで心が近づく", "でも残る。しかし人の隔たり．．．", "は手を伸ばせば届く距離、た「家族」への揺れ返しかもし", "でもあることは、「僕だけが」れない。", "いない街」です位でも孤立してい", "た主人公がたどりついた場所だ。ちあわせ１０位は「他人同士」そ、てハートフルな２作だ。"]}, {"box": [144, 793, 173, 1542], "vertical": true, "font_size": 26, "lines_coords": [[[148.0, 793.0], [173.0, 793.0], [170.0, 1542.0], [144.0, 1542.0]]], "lines": ["い、『ヤガントマキア』（７位や＂ま、「を信じる点で、ハードコアでい"]}, {"box": [340, 806, 371, 1174], "vertical": true, "font_size": 29, "lines_coords": [[[342.0, 806.0], [371.0, 806.0], [369.0, 1174.0], [340.0, 1174.0]]], "lines": ["「リー』（８位）もメイドと女王人"]}, {"box": [500, 839, 605, 1174], "vertical": true, "font_size": 27.0, "lines_coords": [[[578.0, 841.0], [605.0, 841.0], [603.0, 1173.0], [576.0, 1173.0]], [[540.0, 839.0], [567.0, 839.0], [567.0, 1168.0], [540.0, 1168.0]], [[500.0, 839.0], [527.0, 839.0], [527.0, 1174.0], [500.0, 1174.0]]], "lines": ["似家族を描いた「五色の舟」へ。", "位〕のマンガ化と高い支持は、", "いい意味で予想外だった。『魔"]}, {"box": [653, 839, 724, 1169], "vertical": true, "font_size": 29.5, "lines_coords": [[[697.0, 871.0], [724.0, 871.0], [724.0, 1056.0], [697.0, 1056.0]], [[654.0, 839.0], [686.0, 839.0], [685.0, 1169.0], [653.0, 1169.0]]], "lines": ["人と人が時を", "ともにする原点は家族。"]}, {"box": [618, 839, 645, 1534], "vertical": true, "font_size": 27, "lines_coords": [[[618.0, 839.0], [645.0, 839.0], [645.0, 1534.0], [618.0, 1534.0]]], "lines": ["異形の者たちが身を寄せあう擬地球規模のマクロに捉えたもの。"]}, {"box": [186, 1212, 208, 1539], "vertical": true, "font_size": 22, "lines_coords": [[[186.0, 1212.0], [208.0, 1212.0], [208.0, 1539.0], [186.0, 1539.0]]], "lines": ["あるいは姿形に捕らわれない愛"]}, {"box": [250, 1249, 460, 1453], "vertical": true, "font_size": 112, "lines_coords": [[[391.0, 1407.0], [460.0, 1415.0], [455.0, 1453.0], [387.0, 1445.0]], [[250.0, 1249.0], [294.0, 1249.0], [294.0, 1431.0], [250.0, 1431.0]]], "lines": ["は", "ロレス"]}, {"box": [301, 1168, 599, 1526], "vertical": true, "font_size": 112, "lines_coords": [[[509.0, 1204.0], [599.0, 1204.0], [599.0, 1520.0], [509.0, 1520.0]], [[356.0, 1190.0], [492.0, 1192.0], [489.0, 1416.0], [353.0, 1415.0]], [[320.0, 1185.0], [554.0, 1168.0], [579.0, 1509.0], [345.0, 1526.0]], [[304.0, 1225.0], [387.0, 1227.0], [383.0, 1408.0], [301.0, 1407.0]]], "lines": ["生存を賭け", "激突、", "４名を賭けた異種族の激突、失弾言語は", "言語は"]}, {"box": [382, 1474, 514, 1528], "vertical": true, "font_size": 112, "lines_coords": [[[382.0, 1477.0], [513.0, 1474.0], [514.0, 1525.0], [383.0, 1528.0]]], "lines": ["通の"]}]}