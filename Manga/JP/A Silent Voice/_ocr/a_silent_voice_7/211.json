{"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [935, 106, 1024, 441], "vertical": true, "font_size": 23, "lines_coords": [[[1003.0, 108.0], [1024.0, 108.0], [1024.0, 439.0], [1003.0, 439.0]], [[967.0, 108.0], [994.0, 108.0], [994.0, 433.0], [967.0, 433.0]], [[935.0, 106.0], [957.0, 106.0], [957.0, 441.0], [935.0, 441.0]]], "lines": ["がかりに読んだらいいかわからな。", "いんじゃないかと思うんですよ。", "私は、テーマがないと描けない。"]}, {"box": [836, 108, 925, 433], "vertical": true, "font_size": 23, "lines_coords": [[[903.0, 108.0], [925.0, 108.0], [925.0, 433.0], [903.0, 433.0]], [[869.0, 109.0], [892.0, 109.0], [892.0, 433.0], [869.0, 433.0]], [[836.0, 108.0], [858.0, 108.0], [858.0, 433.0], [836.0, 433.0]]], "lines": ["「テーマなしで自由に描いてくださ", "い」とか言われると、全然マンガ描", "けないと思う。何を考えたいのか、"]}, {"box": [736, 159, 756, 433], "vertical": true, "font_size": 23, "lines_coords": [[[736.0, 159.0], [756.0, 159.0], [756.0, 433.0], [736.0, 433.0]]], "lines": ["「『襞の形』が終わったあと"]}, {"box": [567, 108, 658, 436], "vertical": true, "font_size": 23, "lines_coords": [[[635.0, 108.0], [658.0, 108.0], [658.0, 436.0], [635.0, 436.0]], [[567.0, 159.0], [587.0, 159.0], [587.0, 436.0], [567.0, 436.0]]], "lines": ["考えてないんです。まだ自分のな", "「『霧の形』は７巻でまとま"]}, {"box": [434, 109, 624, 604], "vertical": true, "font_size": 23, "lines_coords": [[[602.0, 109.0], [624.0, 109.0], [624.0, 427.0], [602.0, 427.0]], [[434.0, 443.0], [457.0, 443.0], [457.0, 604.0], [434.0, 604.0]]], "lines": ["かで、次やることが育っていない。", "そうですよね？"]}, {"box": [399, 108, 557, 596], "vertical": true, "font_size": 23, "lines_coords": [[[536.0, 130.0], [557.0, 130.0], [557.0, 435.0], [536.0, 435.0]], [[501.0, 129.0], [525.0, 129.0], [524.0, 283.0], [500.0, 283.0]], [[466.0, 108.0], [489.0, 108.0], [489.0, 433.0], [466.0, 433.0]], [[431.0, 108.0], [458.0, 108.0], [458.0, 435.0], [431.0, 435.0]], [[399.0, 109.0], [426.0, 109.0], [426.0, 596.0], [399.0, 596.0]]], "lines": ["りましたが、次回作はもっと長", "いのでしょうか。", "大今、本当は長い連載もやりた", "い。描きたいことはたくさんある", "んです。そして、長く続けたいけど、担当・〈苦笑〉"]}, {"box": [31, 22, 322, 51], "vertical": false, "font_size": 20, "lines_coords": [[[44.0, 21.0], [317.0, 20.0], [317.0, 41.0], [44.0, 43.0]]], "lines": ["オトコ編第１位ＳＰＥＯＩＡＬＩＮＴＥＲＷＥＷ"]}, {"box": [968, 502, 1027, 749], "vertical": true, "font_size": 23, "lines_coords": [[[1005.0, 502.0], [1027.0, 502.0], [1024.0, 749.0], [1002.0, 749.0]], [[971.0, 510.0], [994.0, 510.0], [991.0, 621.0], [968.0, 621.0]]], "lines": ["．．．。うぅ、休みたい．．．。", "ーー（一同笑）"]}, {"box": [702, 441, 959, 804], "vertical": true, "font_size": 23, "lines_coords": [[[936.0, 441.0], [959.0, 441.0], [959.0, 801.0], [936.0, 801.0]], [[900.0, 468.0], [927.0, 468.0], [928.0, 803.0], [901.0, 803.0]], [[868.0, 473.0], [892.0, 473.0], [893.0, 801.0], [869.0, 801.0]], [[834.0, 473.0], [861.0, 473.0], [861.0, 804.0], [834.0, 804.0]], [[799.0, 466.0], [826.0, 466.0], [828.0, 801.0], [801.0, 801.0]], [[769.0, 471.0], [791.0, 471.0], [791.0, 736.0], [769.0, 736.0]], [[736.0, 494.0], [758.0, 494.0], [759.0, 801.0], [737.0, 801.0]], [[702.0, 490.0], [729.0, 490.0], [729.0, 594.0], [702.0, 594.0]]], "lines": ["「大今、ネームに時間がかかりすぎる」", "うるんですよ。いや、作画も時間が", "ふかってるんですけど．．．。でも", "本当は、もっと丁寧にネームも考え", "えたいし、もっと描きこみたい。", "うーん．．．ダメですね．．．．。", "ー＿週刊連載でこの密度はすご", "いですよ。"]}, {"box": [567, 109, 823, 800], "vertical": true, "font_size": 23, "lines_coords": [[[803.0, 109.0], [823.0, 109.0], [823.0, 438.0], [803.0, 438.0]], [[567.0, 439.0], [589.0, 439.0], [589.0, 800.0], [567.0, 800.0]]], "lines": ["何を伝えたいのか、を決めなきゃ", "．．．年マガジン」の読者は学生が多い"]}, {"box": [533, 108, 791, 798], "vertical": true, "font_size": 23, "lines_coords": [[[769.0, 108.0], [791.0, 108.0], [791.0, 221.0], [769.0, 221.0]], [[533.0, 452.0], [556.0, 452.0], [556.0, 798.0], [533.0, 798.0]]], "lines": ["いけません。", "こので、だから映画１本見るくらい"]}, {"box": [500, 130, 724, 801], "vertical": true, "font_size": 23, "lines_coords": [[[702.0, 130.0], [724.0, 130.0], [724.0, 318.0], [702.0, 318.0]], [[500.0, 476.0], [522.0, 476.0], [522.0, 801.0], [500.0, 801.0]]], "lines": ["はファンタジーを？", "の密度はやりたいんです。目標と"]}, {"box": [466, 106, 694, 801], "vertical": true, "font_size": 23, "lines_coords": [[[667.0, 106.0], [694.0, 106.0], [694.0, 438.0], [667.0, 438.0]], [[466.0, 470.0], [489.0, 470.0], [489.0, 801.0], [466.0, 801.0]]], "lines": ["大今はい。いや、やっぱり全然", "して。私、ネームの時間かかるは"]}, {"box": [635, 441, 691, 800], "vertical": true, "font_size": 23, "lines_coords": [[[669.0, 441.0], [691.0, 441.0], [691.0, 800.0], [669.0, 800.0]], [[635.0, 441.0], [658.0, 441.0], [658.0, 798.0], [635.0, 798.0]]], "lines": ["大今、いまコミックスって４５０", "「円くらいしますよね？。値段も、"]}, {"box": [600, 468, 622, 798], "vertical": true, "font_size": 23, "lines_coords": [[[600.0, 468.0], [622.0, 468.0], [622.0, 798.0], [600.0, 798.0]]], "lines": ["すごく気にするんです。一週刊少"]}, {"box": [54, 497, 348, 720], "vertical": false, "font_size": 21.5, "lines_coords": [[[54.0, 497.0], [348.0, 497.0], [348.0, 519.0], [54.0, 519.0]], [[66.0, 538.0], [332.0, 537.0], [332.0, 559.0], [66.0, 561.0]], [[65.0, 565.0], [332.0, 564.0], [332.0, 586.0], [65.0, 588.0]], [[68.0, 591.0], [334.0, 591.0], [334.0, 613.0], [68.0, 613.0]], [[68.0, 619.0], [336.0, 619.0], [336.0, 640.0], [68.0, 640.0]], [[70.0, 645.0], [332.0, 645.0], [332.0, 666.0], [70.0, 666.0]], [[68.0, 672.0], [332.0, 672.0], [332.0, 693.0], [68.0, 693.0]], [[68.0, 699.0], [332.0, 699.0], [332.0, 720.0], [68.0, 720.0]]], "lines": ["『コンプレックス・エイジ", "大今先生が今注目しているマン", "ガは佐久間結衣「コンプレック", "ス・エイジム．．．ス・工イジュールページ参照し「お", "もしろかったです。佐久間さんは", "うちの元アシスタントさんで、４巻", "の観覧車とかを描いてくれまし", "た。カケアミがとっても上手なん"]}, {"box": [70, 728, 282, 744], "vertical": false, "font_size": 16, "lines_coords": [[[70.0, 728.0], [282.0, 728.0], [282.0, 744.0], [70.0, 744.0]]], "lines": ["です。ほんと美しい」（大今）。"]}, {"box": [890, 967, 983, 1150], "vertical": true, "font_size": 31, "lines_coords": [[[954.0, 969.0], [983.0, 969.0], [983.0, 1074.0], [954.0, 1074.0]], [[917.0, 967.0], [951.0, 967.0], [954.0, 1150.0], [920.0, 1150.0]], [[890.0, 969.0], [919.0, 969.0], [919.0, 1051.0], [890.0, 1051.0]]], "lines": ["．．．つまり", "ごめんねーって", "こと．．．"]}, {"box": [133, 839, 426, 1176], "vertical": true, "font_size": 26, "lines_coords": [[[399.0, 844.0], [426.0, 844.0], [426.0, 1078.0], [399.0, 1078.0]], [[336.0, 844.0], [358.0, 844.0], [358.0, 1067.0], [336.0, 1067.0]], [[364.0, 839.0], [396.0, 839.0], [393.0, 1173.0], [361.0, 1173.0]], [[299.0, 844.0], [326.0, 844.0], [326.0, 1173.0], [299.0, 1173.0]], [[266.0, 844.0], [293.0, 844.0], [291.0, 1174.0], [264.0, 1174.0]], [[232.0, 843.0], [259.0, 843.0], [256.0, 1158.0], [229.0, 1158.0]], [[197.0, 841.0], [229.0, 841.0], [229.0, 1176.0], [197.0, 1176.0]], [[167.0, 844.0], [189.0, 844.0], [189.0, 1171.0], [167.0, 1171.0]], [[133.0, 846.0], [156.0, 846.0], [156.0, 1173.0], [133.0, 1173.0]]], "lines": ["大今ほら、かかってる。", "す。そして不思議です。", "担当あと、めちゃくちゃ怖いで", "大今、嘘！嘘！！嘘ですよ。怖", "くないですし、変でもないのですね。", "担当で、次の連載どうします？", "大今、いや、だから何も決まって", "ないっす。私は１年間ゲームをや", "るって決めている。１年間！！ゲーム"]}, {"box": [100, 847, 122, 1152], "vertical": true, "font_size": 26, "lines_coords": [[[100.0, 847.0], [122.0, 847.0], [122.0, 1152.0], [100.0, 1152.0]]], "lines": ["ムを！します！．．．．．たぶん。"]}, {"box": [66, 892, 89, 1163], "vertical": true, "font_size": 26, "lines_coords": [[[66.0, 892.0], [89.0, 892.0], [89.0, 1163.0], [66.0, 1163.0]]], "lines": ["「なんのゲームをやります？"]}, {"box": [454, 1456, 1027, 1531], "vertical": false, "font_size": 23, "lines_coords": [[[458.0, 1456.0], [1024.0, 1456.0], [1024.0, 1479.0], [458.0, 1479.0]], [[458.0, 1482.0], [1024.0, 1482.0], [1024.0, 1504.0], [458.0, 1504.0]], [[460.0, 1507.0], [536.0, 1507.0], [536.0, 1531.0], [460.0, 1531.0]]], "lines": ["顔のｘはすべて手描き。ＣＧで元絵の上に貼りつけているわけではな", "い。ちなみに、このコマの背景のカケアミは、佐久間結衣先生によるも", "のだそう。"]}, {"box": [332, 1211, 426, 1539], "vertical": true, "font_size": 26, "lines_coords": [[[399.0, 1214.0], [426.0, 1214.0], [426.0, 1539.0], [399.0, 1539.0]], [[368.0, 1214.0], [390.0, 1214.0], [390.0, 1539.0], [368.0, 1539.0]], [[332.0, 1211.0], [360.0, 1211.0], [360.0, 1310.0], [332.0, 1310.0]]], "lines": ["大今『ときめきメモリアル２』。", "あと『ＦＦ』のライトニングが出て", "くるやつ。"]}, {"box": [301, 1246, 323, 1514], "vertical": true, "font_size": 26, "lines_coords": [[[301.0, 1246.0], [323.0, 1246.0], [323.0, 1514.0], [301.0, 1514.0]]], "lines": ["ーーゲームお好きなんですね、"]}, {"box": [100, 1179, 293, 1541], "vertical": true, "font_size": 26, "lines_coords": [[[266.0, 1179.0], [293.0, 1179.0], [293.0, 1541.0], [266.0, 1541.0]], [[200.0, 1241.0], [226.0, 1241.0], [223.0, 1541.0], [197.0, 1541.0]], [[167.0, 1219.0], [194.0, 1219.0], [194.0, 1539.0], [167.0, 1539.0]], [[133.0, 1228.0], [162.0, 1228.0], [162.0, 1294.0], [133.0, 1294.0]], [[100.0, 1209.0], [127.0, 1209.0], [127.0, 1404.0], [100.0, 1404.0]]], "lines": ["「大今、うん。ゲーム．．．！楽しい", "一次回作も楽しみにしています。", "す〈笑〉。なるべく早く読みたい", "です。", "大今は、はい．．．。"]}]}