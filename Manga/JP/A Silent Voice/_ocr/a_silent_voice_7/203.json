{"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [57, 19, 219, 36], "vertical": false, "font_size": 16, "lines_coords": [[[57.0, 19.0], [219.0, 20.0], [219.0, 36.0], [57.0, 35.0]]], "lines": ["オトコ編第１位ＳＰＥＣＡ"]}, {"box": [78, 57, 743, 204], "vertical": false, "font_size": 61, "lines_coords": [[[78.0, 90.0], [485.0, 57.0], [490.0, 122.0], [82.0, 156.0]], [[86.0, 148.0], [728.0, 92.0], [732.0, 148.0], [90.0, 204.0]]], "lines": ["石田母の右耳から", "推測できるなんらかの修羅場！？"]}, {"box": [474, 259, 557, 363], "vertical": true, "font_size": 26, "lines_coords": [[[524.0, 261.0], [551.0, 261.0], [551.0, 363.0], [524.0, 363.0]], [[495.0, 259.0], [524.0, 259.0], [524.0, 347.0], [495.0, 347.0]], [[474.0, 261.0], [497.0, 261.0], [497.0, 361.0], [474.0, 361.0]]], "lines": ["明日からは", "良い子に", "するのよ？"]}, {"box": [826, 138, 1040, 202], "vertical": false, "font_size": 58, "lines_coords": [[[838.0, 141.0], [1040.0, 141.0], [1040.0, 199.0], [838.0, 199.0]]], "lines": ["合田お"]}, {"box": [648, 225, 1048, 387], "vertical": false, "font_size": 22, "lines_coords": [[[653.0, 232.0], [1040.0, 232.0], [1040.0, 253.0], [653.0, 253.0]], [[653.0, 256.0], [1040.0, 256.0], [1040.0, 278.0], [653.0, 278.0]], [[653.0, 282.0], [1040.0, 283.0], [1040.0, 306.0], [653.0, 304.0]], [[654.0, 310.0], [1040.0, 310.0], [1040.0, 331.0], [654.0, 331.0]], [[653.0, 337.0], [1038.0, 337.0], [1038.0, 358.0], [653.0, 358.0]], [[651.0, 361.0], [989.0, 363.0], [989.0, 385.0], [651.0, 384.0]]], "lines": ["西宮母に詫びに行く際、石田母の左右の耳にピ", "アスがある。しかし、謝罪後の場面では右耳のピ", "アスがなく、耳たぶには血のあとが．．．．．．。母親同", "土の話しあいの場で、なんらかの修羅場があっ", "たと推測できる。将也が気づいていないため、何", "が起きたのか、作中で語られることはない。"]}, {"box": [104, 656, 151, 731], "vertical": true, "font_size": 47, "lines_coords": [[[104.0, 656.0], [151.0, 656.0], [151.0, 731.0], [104.0, 731.0]]], "lines": ["昨日はよくもやってくれたなー"]}, {"box": [43, 482, 508, 634], "vertical": false, "font_size": 57, "lines_coords": [[[43.0, 522.0], [503.0, 482.0], [508.0, 541.0], [47.0, 581.0]], [[47.0, 580.0], [489.0, 541.0], [493.0, 596.0], [52.0, 634.0]]], "lines": ["靴を盗ったデラックスは", "ガキ大将か、パシリか？"]}, {"box": [521, 607, 583, 678], "vertical": true, "font_size": 34, "lines_coords": [[[552.0, 608.0], [583.0, 610.0], [579.0, 677.0], [549.0, 675.0]], [[527.0, 607.0], [564.0, 607.0], [564.0, 678.0], [527.0, 678.0]]], "lines": ["「返す」と", "言ったら"]}, {"box": [723, 579, 756, 632], "vertical": true, "font_size": 33, "lines_coords": [[[723.0, 579.0], [756.0, 579.0], [756.0, 632.0], [723.0, 632.0]]], "lines": ["ではもし俺が．．．"]}, {"box": [657, 447, 963, 521], "vertical": false, "font_size": 66, "lines_coords": [[[658.0, 451.0], [946.0, 447.0], [946.0, 514.0], [658.0, 517.0]]], "lines": ["デラックス"]}, {"box": [785, 556, 1046, 788], "vertical": false, "font_size": 21, "lines_coords": [[[791.0, 556.0], [1040.0, 556.0], [1040.0, 576.0], [791.0, 576.0]], [[788.0, 580.0], [1040.0, 581.0], [1040.0, 604.0], [788.0, 602.0]], [[791.0, 608.0], [1041.0, 608.0], [1041.0, 631.0], [791.0, 631.0]], [[791.0, 635.0], [1040.0, 635.0], [1040.0, 656.0], [791.0, 656.0]], [[790.0, 661.0], [1040.0, 661.0], [1040.0, 682.0], [790.0, 682.0]], [[790.0, 688.0], [1038.0, 688.0], [1038.0, 709.0], [790.0, 709.0]], [[791.0, 715.0], [1040.0, 715.0], [1040.0, 736.0], [791.0, 736.0]], [[791.0, 742.0], [1040.0, 742.0], [1040.0, 763.0], [791.0, 763.0]], [[791.0, 768.0], [971.0, 768.0], [971.0, 788.0], [791.0, 788.0]]], "lines": ["将也の靴を盗んだ犯人（とされ", "た）隣校の少年・デラックス。将", "也の視点からは大柄なガキ大", "将に映るが、２巻の結舷の回想", "シーンでは、硝子をいじめるグ", "ループのひとりとして登場。そこ", "ではランドセル持ちをやらされ", "ている。キャラの様々な側面が", "見えてくる代表的な例。"]}, {"box": [78, 882, 185, 1171], "vertical": true, "font_size": 27, "lines_coords": [[[148.0, 884.0], [175.0, 884.0], [172.0, 1171.0], [144.0, 1171.0]], [[116.0, 882.0], [143.0, 882.0], [138.0, 1171.0], [111.0, 1171.0]], [[81.0, 882.0], [108.0, 882.0], [105.0, 1163.0], [78.0, 1163.0]]], "lines": ["大今、大雑把なところは最後", "まで決めておいて、そこから", "逆算して「ここにアレ入れて、"]}, {"box": [216, 946, 237, 1166], "vertical": true, "font_size": 21, "lines_coords": [[[216.0, 946.0], [237.0, 946.0], [237.0, 1166.0], [216.0, 1166.0]]], "lines": ["それは最初から計画的"]}, {"box": [246, 882, 438, 1171], "vertical": true, "font_size": 24.833333333333332, "lines_coords": [[[415.0, 887.0], [438.0, 887.0], [438.0, 1168.0], [415.0, 1168.0]], [[380.0, 886.0], [407.0, 886.0], [406.0, 1171.0], [379.0, 1171.0]], [[350.0, 884.0], [372.0, 884.0], [372.0, 1166.0], [350.0, 1166.0]], [[313.0, 882.0], [340.0, 882.0], [340.0, 1169.0], [313.0, 1169.0]], [[283.0, 886.0], [305.0, 886.0], [305.0, 1169.0], [283.0, 1169.0]], [[246.0, 886.0], [274.0, 886.0], [274.0, 1086.0], [246.0, 1086.0]]], "lines": ["大今、同じことはやりたくな", "いので変えました。読み切り", "ではやれないことを、連載で", "はやろう、と。最初はずっと", "将也の視点で、６巻でみんな", "の目線に変わります。"]}, {"box": [446, 905, 543, 1168], "vertical": true, "font_size": 27.666666666666668, "lines_coords": [[[516.0, 905.0], [543.0, 905.0], [541.0, 1165.0], [514.0, 1165.0]], [[450.0, 905.0], [479.0, 906.0], [474.0, 1023.0], [446.0, 1021.0]], [[482.0, 906.0], [509.0, 906.0], [508.0, 1168.0], [481.0, 1168.0]]], "lines": ["将也の視点に絞ったのは、", "更点ですね。", "読み切り版からの大きな変"]}, {"box": [556, 841, 632, 1137], "vertical": true, "font_size": 32.0, "lines_coords": [[[600.0, 843.0], [632.0, 843.0], [632.0, 1137.0], [600.0, 1137.0]], [[559.0, 841.0], [591.0, 841.0], [587.0, 1120.0], [556.0, 1120.0]]], "lines": ["各巻の構成は連載前", "から決まっていた！？"]}, {"box": [648, 841, 772, 1168], "vertical": true, "font_size": 23.5, "lines_coords": [[[750.0, 843.0], [772.0, 843.0], [772.0, 1168.0], [750.0, 1168.0]], [[716.0, 843.0], [739.0, 843.0], [739.0, 1168.0], [716.0, 1168.0]], [[683.0, 841.0], [705.0, 841.0], [705.0, 1166.0], [683.0, 1166.0]], [[648.0, 841.0], [675.0, 841.0], [675.0, 1141.0], [648.0, 1141.0]]], "lines": ["てました。「こんなこと、効果あん", "のかなぁ？」と思ったりもします", "が、やっぱりテーマに導かれてい", "るので、やらないといけません。"]}, {"box": [782, 838, 879, 1173], "vertical": true, "font_size": 31.0, "lines_coords": [[[841.0, 838.0], [879.0, 838.0], [879.0, 1173.0], [841.0, 1173.0]], [[812.0, 839.0], [841.0, 839.0], [842.0, 1171.0], [814.0, 1171.0]], [[782.0, 841.0], [809.0, 841.0], [809.0, 1169.0], [782.0, 1169.0]]], "lines": ["そ、多面的なキャラクター描写、わ", "からない部分も作るような描き方", "は、やらないと意味がないよ思っ"]}, {"box": [882, 838, 1041, 1173], "vertical": true, "font_size": 28.2, "lines_coords": [[[1013.0, 839.0], [1040.0, 839.0], [1041.0, 1169.0], [1014.0, 1169.0]], [[979.0, 838.0], [1011.0, 838.0], [1011.0, 1173.0], [979.0, 1173.0]], [[949.0, 838.0], [976.0, 838.0], [971.0, 1171.0], [944.0, 1171.0]], [[916.0, 838.0], [943.0, 838.0], [940.0, 1171.0], [912.0, 1171.0]], [[882.0, 839.0], [909.0, 839.0], [909.0, 1169.0], [882.0, 1169.0]]], "lines": ["うとすることの尊さ」がデーマでし", "た。その行為はたとえ成功しなく", "ても、尊い。ばらばらに、それぞれ", "の事情を抱えて、勝手に生きてい", "る人たち。それがテーマだからこ"]}, {"box": [79, 1230, 203, 1537], "vertical": true, "font_size": 26.25, "lines_coords": [[[181.0, 1268.0], [203.0, 1268.0], [203.0, 1536.0], [181.0, 1536.0]], [[149.0, 1230.0], [176.0, 1230.0], [172.0, 1537.0], [144.0, 1537.0]], [[113.0, 1230.0], [141.0, 1230.0], [140.0, 1537.0], [111.0, 1537.0]], [[79.0, 1231.0], [106.0, 1231.0], [108.0, 1528.0], [81.0, 1528.0]]], "lines": ["「硝子に聴覚障がいがあって", "他者とのコミュニケーションが成", "立しにくいことが、作品をおもし", "ろくしていると思うんですよね。"]}, {"box": [223, 1206, 842, 1542], "vertical": true, "font_size": 25.944444444444443, "lines_coords": [[[814.0, 1209.0], [841.0, 1209.0], [842.0, 1539.0], [815.0, 1539.0]], [[777.0, 1206.0], [809.0, 1206.0], [810.0, 1542.0], [779.0, 1542.0]], [[748.0, 1211.0], [775.0, 1211.0], [775.0, 1539.0], [748.0, 1539.0]], [[716.0, 1211.0], [739.0, 1211.0], [739.0, 1531.0], [716.0, 1531.0]], [[683.0, 1211.0], [705.0, 1211.0], [704.0, 1539.0], [681.0, 1539.0]], [[646.0, 1208.0], [673.0, 1208.0], [675.0, 1539.0], [648.0, 1539.0]], [[616.0, 1211.0], [638.0, 1211.0], [638.0, 1536.0], [616.0, 1536.0]], [[581.0, 1211.0], [603.0, 1211.0], [603.0, 1537.0], [581.0, 1537.0]], [[549.0, 1212.0], [571.0, 1212.0], [571.0, 1537.0], [549.0, 1537.0]], [[513.0, 1211.0], [540.0, 1211.0], [541.0, 1456.0], [514.0, 1456.0]], [[484.0, 1265.0], [506.0, 1265.0], [506.0, 1537.0], [484.0, 1537.0]], [[447.0, 1231.0], [474.0, 1231.0], [474.0, 1537.0], [447.0, 1537.0]], [[417.0, 1233.0], [439.0, 1233.0], [439.0, 1534.0], [417.0, 1534.0]], [[382.0, 1228.0], [409.0, 1228.0], [406.0, 1472.0], [379.0, 1472.0]], [[345.0, 1208.0], [377.0, 1208.0], [377.0, 1537.0], [345.0, 1537.0]], [[313.0, 1209.0], [340.0, 1209.0], [340.0, 1364.0], [313.0, 1364.0]], [[264.0, 1212.0], [296.0, 1212.0], [296.0, 1534.0], [264.0, 1534.0]], [[226.0, 1211.0], [253.0, 1211.0], [250.0, 1439.0], [223.0, 1439.0]]], "lines": ["が、２巻では「将也と結舷」、３巻", "最後で「硝子の重大シーン」「４巻", "で「硝子と結絃の出生の話」、５巻", "での「あの展開」．．．．というのは、", "じつは、連載開始前から、先生から", "提示されていました。そして、ほ", "ぼそのとおりに実現したのは驚異", "的です。キャラクターを、出生前", "から含めて丁寧に構築しているか", "らこそできるのでしょう。", "「毎週のテーマ、毎巻のテ！", "マ、話全体のテーマ．．．と、テー", "マの入れ予構造がすごいです。", "週刊連載だとは思えない。", "大今「いえ。もっとも」ときめ細」", "かくやらないと。", "読者の声を聞くことを", "目的とした作品"]}, {"box": [847, 1208, 1037, 1539], "vertical": true, "font_size": 22.0, "lines_coords": [[[1016.0, 1209.0], [1037.0, 1209.0], [1037.0, 1530.0], [1016.0, 1530.0]], [[983.0, 1208.0], [1003.0, 1208.0], [1003.0, 1534.0], [983.0, 1534.0]], [[951.0, 1209.0], [971.0, 1209.0], [971.0, 1536.0], [951.0, 1536.0]], [[916.0, 1209.0], [938.0, 1209.0], [938.0, 1534.0], [916.0, 1534.0]], [[884.0, 1211.0], [906.0, 1211.0], [906.0, 1346.0], [884.0, 1346.0]], [[849.0, 1208.0], [876.0, 1208.0], [874.0, 1539.0], [847.0, 1539.0]]], "lines": ["ここでゴレやって」と。あとは研究", "毎週の「引き」です。読者に読んで", "もらうためにもー引き」は大事にし", "ています。でも、まだまだ全然で", "きていません。", "祖当、先生はそうおっしゃいます"]}]}