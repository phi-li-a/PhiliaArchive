{"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [586, 0, 1104, 191], "vertical": false, "font_size": 47, "lines_coords": [[[600.0, 9.0], [1080.0, 138.0], [1065.0, 191.0], [586.0, 62.0]], [[858.0, 17.0], [1083.0, 82.0], [1072.0, 121.0], [847.0, 55.0]]], "lines": ["読み返すと印象が変わる", "こがすごい！！"]}, {"box": [694, 180, 991, 288], "vertical": false, "font_size": 53, "lines_coords": [[[694.0, 180.0], [991.0, 180.0], [991.0, 264.0], [694.0, 264.0]], [[709.0, 264.0], [930.0, 264.0], [930.0, 286.0], [709.0, 286.0]]], "lines": ["西宮硝子", "にしみや・しょうこ"]}, {"box": [697, 319, 1059, 475], "vertical": false, "font_size": 21, "lines_coords": [[[699.0, 321.0], [1051.0, 321.0], [1051.0, 342.0], [699.0, 342.0]], [[697.0, 345.0], [1053.0, 347.0], [1053.0, 369.0], [697.0, 368.0]], [[701.0, 374.0], [1053.0, 374.0], [1053.0, 395.0], [701.0, 395.0]], [[702.0, 401.0], [1051.0, 401.0], [1051.0, 422.0], [702.0, 422.0]], [[701.0, 427.0], [1053.0, 427.0], [1053.0, 447.0], [701.0, 447.0]], [[701.0, 454.0], [955.0, 454.0], [955.0, 474.0], [701.0, 474.0]]], "lines": ["笑顔が印象的なヒロイン・西宮硝子。しか", "し、彼女がほほえむ理由は「主人公の視点", "では知りえないこと」（大今）なので、彼女が", "何を考えていいるかわからないい。６巻で硝子の", "内面が描かれると、それまでの笑顔の場面", "も、また違って見えてくるだろう。"]}, {"box": [79, 129, 284, 556], "vertical": false, "font_size": 144, "lines_coords": [[[141.0, 137.0], [210.0, 545.0], [148.0, 556.0], [79.0, 148.0]], [[141.0, 138.0], [199.0, 130.0], [229.0, 366.0], [172.0, 374.0]], [[202.0, 135.0], [253.0, 129.0], [277.0, 313.0], [226.0, 320.0]]], "lines": ["賀叶Ｇ挑螂Ｇ鬨丑", "明かされる", "６巻にて"]}, {"box": [707, 597, 839, 782], "vertical": true, "font_size": 22, "lines_coords": [[[810.0, 600.0], [833.0, 600.0], [833.0, 765.0], [810.0, 765.0]], [[785.0, 599.0], [806.0, 599.0], [806.0, 782.0], [785.0, 782.0]], [[761.0, 599.0], [783.0, 599.0], [783.0, 693.0], [761.0, 693.0]], [[736.0, 597.0], [759.0, 597.0], [756.0, 712.0], [732.0, 712.0]], [[710.0, 599.0], [731.0, 599.0], [728.0, 726.0], [707.0, 726.0]]], "lines": ["自分がやるより先に", "生徒に覚えさせようと", "するなんて", "恥ずかしいと", "思いませんか？"]}, {"box": [90, 659, 386, 733], "vertical": false, "font_size": 74, "lines_coords": [[[90.0, 659.0], [380.0, 659.0], [380.0, 733.0], [90.0, 733.0]]], "lines": ["竹内先生"]}, {"box": [568, 991, 1057, 1152], "vertical": false, "font_size": 19, "lines_coords": [[[575.0, 994.0], [1049.0, 994.0], [1049.0, 1015.0], [575.0, 1015.0]], [[576.0, 1018.0], [1048.0, 1020.0], [1048.0, 1040.0], [576.0, 1039.0]], [[581.0, 1048.0], [1049.0, 1048.0], [1049.0, 1064.0], [581.0, 1064.0]], [[573.0, 1072.0], [1051.0, 1072.0], [1051.0, 1093.0], [573.0, 1093.0]], [[575.0, 1101.0], [1048.0, 1101.0], [1048.0, 1117.0], [575.0, 1117.0]], [[573.0, 1123.0], [1010.0, 1125.0], [1010.0, 1145.0], [573.0, 1144.0]]], "lines": ["主人公・将也の小６時代の担任。障がいい児童の受け入れに", "否定的なようだが、再登場時には手話を理解している（左）。", "「描いているときは自分が１００％竹内になるので、竹内につ", "いて質問されると『俺はこういう風に考えてるんだ』って言っ", "い訳したくなリます。まあ、竹内も精神的には成長してない", "ですよ。少なくとも本人は絶対そう思うっています」（大今）"]}, {"box": [94, 766, 525, 914], "vertical": false, "font_size": 67, "lines_coords": [[[98.0, 803.0], [519.0, 766.0], [524.0, 816.0], [103.0, 852.0]], [[94.0, 830.0], [387.0, 817.0], [390.0, 902.0], [97.0, 914.0]]], "lines": ["１コマから推測できる", "キャラの背景"]}, {"box": [121, 1081, 155, 1133], "vertical": true, "font_size": 34, "lines_coords": [[[121.0, 1081.0], [155.0, 1081.0], [155.0, 1133.0], [121.0, 1133.0]]], "lines": ["来たかった？"]}, {"box": [1027, 1231, 1053, 1533], "vertical": true, "font_size": 25, "lines_coords": [[[1030.0, 1231.0], [1053.0, 1231.0], [1049.0, 1533.0], [1027.0, 1533.0]]], "lines": ["けど、その意図をお聞かせくだ"]}, {"box": [793, 1209, 987, 1537], "vertical": true, "font_size": 25, "lines_coords": [[[960.0, 1209.0], [987.0, 1209.0], [984.0, 1536.0], [957.0, 1536.0]], [[925.0, 1209.0], [952.0, 1209.0], [952.0, 1537.0], [925.0, 1537.0]], [[895.0, 1212.0], [917.0, 1212.0], [917.0, 1534.0], [895.0, 1534.0]], [[860.0, 1212.0], [884.0, 1212.0], [882.0, 1536.0], [858.0, 1536.0]], [[828.0, 1214.0], [850.0, 1214.0], [850.0, 1536.0], [828.0, 1536.0]], [[793.0, 1212.0], [815.0, 1212.0], [815.0, 1450.0], [793.0, 1450.0]]], "lines": ["大今、将也が知りえないことは読", "者には知らせない、将也が気づい", "ていないことは取りあげない、つ", "もりでした。将也が注目していな", "い事柄には、読者の注意を向けさ", "せないようにしてました。"]}, {"box": [761, 1246, 783, 1445], "vertical": true, "font_size": 25, "lines_coords": [[[761.0, 1246.0], [783.0, 1246.0], [783.0, 1445.0], [761.0, 1445.0]]], "lines": ["それはどうして？"]}, {"box": [258, 1208, 753, 1537], "vertical": true, "font_size": 25, "lines_coords": [[[726.0, 1208.0], [753.0, 1208.0], [750.0, 1537.0], [723.0, 1537.0]], [[691.0, 1211.0], [718.0, 1211.0], [716.0, 1536.0], [689.0, 1536.0]], [[659.0, 1211.0], [685.0, 1211.0], [681.0, 1534.0], [656.0, 1534.0]], [[626.0, 1230.0], [653.0, 1230.0], [651.0, 1537.0], [624.0, 1537.0]], [[592.0, 1230.0], [619.0, 1230.0], [618.0, 1537.0], [591.0, 1537.0]], [[562.0, 1233.0], [584.0, 1233.0], [584.0, 1534.0], [562.0, 1534.0]], [[525.0, 1228.0], [552.0, 1228.0], [551.0, 1537.0], [524.0, 1537.0]], [[492.0, 1227.0], [519.0, 1227.0], [516.0, 1523.0], [489.0, 1523.0]], [[458.0, 1209.0], [485.0, 1209.0], [482.0, 1536.0], [455.0, 1536.0]], [[425.0, 1211.0], [452.0, 1211.0], [449.0, 1536.0], [422.0, 1536.0]], [[391.0, 1211.0], [419.0, 1211.0], [419.0, 1530.0], [391.0, 1530.0]], [[360.0, 1211.0], [382.0, 1211.0], [382.0, 1534.0], [360.0, 1534.0]], [[326.0, 1212.0], [348.0, 1212.0], [348.0, 1534.0], [326.0, 1534.0]], [[294.0, 1209.0], [317.0, 1209.0], [313.0, 1534.0], [291.0, 1534.0]], [[261.0, 1211.0], [283.0, 1211.0], [280.0, 1512.0], [258.0, 1512.0]]], "lines": ["大今、主人公に感情移入して読ん", "でもらうためです。感情移入しに", "くい、イヤな主人公ですからね（笑）", "ーーただ、そういった点に気づく", "かどうかで、登場人物に対する印", "象が変わりますよね。物語の漆", "中で「こういう人だ」と断定され", "るのは怖くありませんでした？", "大今、怖いです。読者の方や、私", "の周囲の人が「こいつはこういう", "ヤツだ」と言ってくれるんですが、", "そして、それはありがたいことな", "のですが、そのキャラクターの印", "象もまた、その読者のフィルター", "を通した人物像でしかないんで。"]}, {"box": [223, 1259, 251, 1536], "vertical": true, "font_size": 25, "lines_coords": [[[224.0, 1259.0], [251.0, 1259.0], [250.0, 1536.0], [223.0, 1536.0]]], "lines": ["「読者が深読みしたくなる作"]}, {"box": [125, 1209, 218, 1537], "vertical": true, "font_size": 25, "lines_coords": [[[192.0, 1227.0], [218.0, 1227.0], [215.0, 1537.0], [189.0, 1537.0]], [[157.0, 1209.0], [184.0, 1209.0], [184.0, 1534.0], [157.0, 1534.0]], [[125.0, 1211.0], [148.0, 1211.0], [148.0, 1534.0], [125.0, 1534.0]]], "lines": ["りです。正直、たいへんですよね？", "大今、まあ、苦しい時はあるんで", "すけどねぇ。ただ、この作品は人"]}, {"box": [94, 1211, 114, 1534], "vertical": true, "font_size": 20, "lines_coords": [[[94.0, 1211.0], [114.0, 1211.0], [114.0, 1534.0], [94.0, 1534.0]]], "lines": ["が人を知ろうとすること、関わろ"]}]}