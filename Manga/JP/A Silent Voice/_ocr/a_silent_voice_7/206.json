4.0, 714.0], [261.0, 714.0], [258.0, 1107.0], [231.0, 1107.0]], [[202.0, 718.0], [224.0, 718.0], [224.0, 1104.0], [202.0, 1104.0]], [[165.0, 714.0], [197.0, 714.0], [192.0, 1106.0], [160.0, 1106.0]], [[133.0, 715.0], [160.0, 715.0], [157.0, 1107.0], [130.0, 1107.0]], [[98.0, 714.0], [127.0, 714.0], [129.0, 980.0], [100.0, 980.0]]], "lines": ["傑作読み切りから人気連載", "物語は熱い青春群像劇に", "「いじめとは何か？」「障がいと向き合う", "とはどういうことか？」連載に先行して", "掲載された読み切り版は、そんな難しい", "テーマに正面からぶつかり、爽やかな物", "語へと巧みに昇華した、衝撃的な完成度", "の作品だった。ゆえに連載開始にあたっ", "て、この作品をどう長編化するのか？」", "というような不安の声がささやかれたの", "も、仕方のないことだろう。"]}, {"box": [892, 1459, 1073, 1534], "vertical": false, "font_size": 14, "lines_coords": [[[893.0, 1459.0], [952.0, 1459.0], [952.0, 1475.0], [893.0, 1475.0]], [[892.0, 1479.0], [1073.0, 1477.0], [1073.0, 1494.0], [892.0, 1496.0]], [[893.0, 1501.0], [1073.0, 1501.0], [1073.0, 1517.0], [893.0, 1517.0]], [[895.0, 1523.0], [981.0, 1523.0], [981.0, 1534.0], [895.0, 1534.0]]], "lines": ["講談を", "「週刊少年マガジン、掲載", "講談社コミックス／既刊", "巻以下続中"]}, {"box": [893, 1553, 1014, 1565], "vertical": false, "font_size": 14, "lines_coords": [[[893.0, 1553.0], [1014.0, 1553.0], [1014.0, 1565.0], [893.0, 1565.0]]], "lines": ["０大今度は〈説談〉"]}, {"box": [591, 1344, 822, 1535], "vertical": false, "font_size": 18, "lines_coords": [[[597.0, 1349.0], [812.0, 1348.0], [812.0, 1365.0], [597.0, 1367.0]], [[595.0, 1372.0], [815.0, 1372.0], [815.0, 1392.0], [595.0, 1392.0]], [[595.0, 1394.0], [815.0, 1394.0], [815.0, 1415.0], [595.0, 1415.0]], [[592.0, 1420.0], [815.0, 1416.0], [815.0, 1437.0], [592.0, 1440.0]], [[595.0, 1443.0], [812.0, 1442.0], [812.0, 1459.0], [595.0, 1461.0]], [[597.0, 1467.0], [807.0, 1467.0], [807.0, 1483.0], [597.0, 1483.0]], [[597.0, 1491.0], [812.0, 1491.0], [812.0, 1507.0], [597.0, 1507.0]], [[599.0, 1515.0], [734.0, 1515.0], [734.0, 1531.0], [599.0, 1531.0]]], "lines": ["やんちゃなガキ大将・石田将", "也は、耳の聞こえない転校", "生・西宮硝子をいじめてい", "た。やがて、ふとしたきっかけ", "から、今度は将せがいじめの", "ターゲットに。そして数年後", "孤独な将也は、可憐に成長し", "た硝子と再会する"]}, {"box": [100, 1145, 524, 1541], "vertical": true, "font_size": 24, "lines_coords": [[[503.0, 1168.0], [524.0, 1168.0], [524.0, 1534.0], [503.0, 1534.0]], [[466.0, 1150.0], [493.0, 1150.0], [493.0, 1537.0], [466.0, 1537.0]], [[436.0, 1150.0], [458.0, 1150.0], [458.0, 1537.0], [436.0, 1537.0]], [[403.0, 1149.0], [425.0, 1149.0], [423.0, 1537.0], [401.0, 1537.0]], [[369.0, 1149.0], [391.0, 1149.0], [391.0, 1537.0], [369.0, 1537.0]], [[332.0, 1145.0], [360.0, 1145.0], [358.0, 1541.0], [331.0, 1541.0]], [[302.0, 1150.0], [325.0, 1150.0], [325.0, 1539.0], [302.0, 1539.0]], [[269.0, 1150.0], [291.0, 1150.0], [291.0, 1537.0], [269.0, 1537.0]], [[235.0, 1150.0], [258.0, 1150.0], [258.0, 1539.0], [235.0, 1539.0]], [[200.0, 1147.0], [227.0, 1147.0], [226.0, 1539.0], [199.0, 1539.0]], [[167.0, 1147.0], [194.0, 1147.0], [192.0, 1541.0], [165.0, 1541.0]], [[132.0, 1149.0], [159.0, 1149.0], [160.0, 1534.0], [133.0, 1534.0]], [[100.0, 1147.0], [127.0, 1147.0], [129.0, 1351.0], [101.0, 1351.0]]], "lines": ["だが、それは杞憂だった。作者は高い", "ハードルを見事に乗り越えてみせたのだ。", "いじめの加害者と被害者が、長い時を経", "て再会する。読み切りとほぼ同じ展開を", "経て、物語は二者関係から、より大きな", "人間関係へ接続される。地に足のついた", "語り口はそのままに、作品は熱い青春群", "像劇へと展開され、エンターテインメン", "トとしての魅力を増やした。本書の刊行時", "には、物語はクライマックスを迎えてい", "え。今からでも遅くない、傷つきつつ懸け", "命に前に進む登場人物たちの行く末を、", "ぜひ見届けてほしい。"]}, {"box": [105, 1490, 124, 1531], "vertical": true, "font_size": 24, "lines_coords": [[[105.0, 1490.0], [124.0, 1490.0], [124.0, 1531.0], [105.0, 1531.0]]], "lines": ["後ー"]}]}