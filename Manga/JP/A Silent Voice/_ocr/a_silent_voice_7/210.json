{"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [101, 89, 228, 138], "vertical": false, "font_size": 20, "lines_coords": [[[106.0, 90.0], [223.0, 90.0], [223.0, 113.0], [106.0, 113.0]], [[108.0, 116.0], [223.0, 116.0], [223.0, 133.0], [108.0, 133.0]]], "lines": ["このマンガが", "すごい！？ｎ５"]}, {"box": [97, 186, 146, 210], "vertical": false, "font_size": 24, "lines_coords": [[[97.0, 186.0], [146.0, 186.0], [146.0, 210.0], [97.0, 210.0]]], "lines": ["第"]}, {"box": [290, 70, 856, 397], "vertical": false, "font_size": 29, "lines_coords": [[[724.0, 70.0], [801.0, 73.0], [799.0, 102.0], [723.0, 98.0]]], "lines": ["かたら"]}, {"box": [183, 0, 1105, 541], "vertical": false, "font_size": 238.0, "lines_coords": [[[235.0, 0.0], [1105.0, 84.0], [1053.0, 541.0], [183.0, 444.0]], [[581.0, 388.0], [812.0, 388.0], [812.0, 411.0], [581.0, 411.0]]], "lines": ["聲の形！！", "何も先生インタビ．．．ウォハンからのおまえも"]}, {"box": [913, 54, 1105, 147], "vertical": false, "font_size": 38, "lines_coords": [[[967.0, 54.0], [1097.0, 54.0], [1097.0, 98.0], [967.0, 98.0]], [[927.0, 105.0], [1092.0, 105.0], [1092.0, 143.0], [927.0, 143.0]]], "lines": ["ＳＰＥＣＩＡＬ", "ＪＮＴＥＲＶＩＥＭ"]}, {"box": [135, 473, 658, 803], "vertical": true, "font_size": 23.875, "lines_coords": [[[635.0, 514.0], [658.0, 514.0], [658.0, 798.0], [635.0, 798.0]], [[602.0, 497.0], [624.0, 497.0], [622.0, 669.0], [600.0, 669.0]], [[567.0, 476.0], [594.0, 476.0], [594.0, 801.0], [567.0, 801.0]], [[533.0, 476.0], [556.0, 476.0], [556.0, 800.0], [533.0, 800.0]], [[498.0, 473.0], [525.0, 473.0], [525.0, 803.0], [498.0, 803.0]], [[466.0, 474.0], [489.0, 474.0], [489.0, 801.0], [466.0, 801.0]], [[434.0, 476.0], [457.0, 476.0], [457.0, 800.0], [434.0, 800.0]], [[403.0, 474.0], [425.0, 474.0], [422.0, 761.0], [399.0, 761.0]], [[366.0, 474.0], [393.0, 474.0], [390.0, 714.0], [363.0, 714.0]], [[334.0, 478.0], [356.0, 478.0], [356.0, 680.0], [334.0, 680.0]], [[301.0, 478.0], [323.0, 478.0], [323.0, 655.0], [301.0, 655.0]], [[266.0, 474.0], [293.0, 474.0], [293.0, 637.0], [266.0, 637.0]], [[232.0, 476.0], [254.0, 476.0], [254.0, 621.0], [232.0, 621.0]], [[199.0, 474.0], [226.0, 474.0], [223.0, 615.0], [195.0, 615.0]], [[167.0, 474.0], [189.0, 474.0], [189.0, 610.0], [167.0, 610.0]], [[135.0, 478.0], [157.0, 478.0], [157.0, 608.0], [135.0, 608.0]]], "lines": ["「いちばん影響を受けたマン", "ガはなんですか？", "大今、はじめて自分のお金で買って", "たマンガが「３ｘ３．ＢＹＥＳ」でした", "た。何十回も読んでましたね。も", "う思い入れが強すぎて、好きなの", "かどうかわからないくらいです。", "買ったのは小学生のときなん", "で、全然内容はわからな", "かったですよ。でも", "キャラクターの名", "前とか、いまで", "も完全に言え", "る。高田裕三", "さんの描く", "キャラの「手」"]}, {"box": [678, 476, 750, 795], "vertical": true, "font_size": 30.5, "lines_coords": [[[718.0, 478.0], [750.0, 478.0], [750.0, 795.0], [718.0, 795.0]], [[680.0, 476.0], [709.0, 476.0], [707.0, 777.0], [678.0, 777.0]]], "lines": ["影響を受けたマンガは", "『３Ｘ３ＥＹＥＳ』！"]}, {"box": [118, 1086, 403, 1162], "vertical": false, "font_size": 22, "lines_coords": [[[122.0, 1086.0], [401.0, 1086.0], [401.0, 1109.0], [122.0, 1109.0]], [[121.0, 1114.0], [399.0, 1114.0], [399.0, 1134.0], [121.0, 1134.0]], [[121.0, 1137.0], [337.0, 1139.0], [337.0, 1161.0], [121.0, 1160.0]]], "lines": ["大今先生が自ら示してくれた高田", "裕三先生のキャラの手の形。一同", "「あるある」」ってなりました。"]}, {"box": [431, 839, 624, 1177], "vertical": true, "font_size": 22.333333333333332, "lines_coords": [[[602.0, 844.0], [624.0, 844.0], [621.0, 1177.0], [599.0, 1177.0]], [[568.0, 844.0], [591.0, 844.0], [587.0, 1173.0], [565.0, 1173.0]], [[533.0, 843.0], [556.0, 843.0], [556.0, 1171.0], [533.0, 1171.0]], [[500.0, 843.0], [522.0, 843.0], [522.0, 1173.0], [500.0, 1173.0]], [[465.0, 839.0], [487.0, 839.0], [487.0, 1168.0], [465.0, 1168.0]], [[434.0, 839.0], [457.0, 839.0], [454.0, 1173.0], [431.0, 1173.0]]], "lines": ["と、小指がこういう風に曲がるん", "ですよ〈突〉《バラス・ヴィダーヒ》』", "ここか手で印を結ぶのも、めっちゃ", "やりました。あとバイが手につけ", "ていた黒いヤツ、あれ作りました。", "軍手を切って、黒に浸して黒くし"]}, {"box": [669, 867, 691, 1145], "vertical": true, "font_size": 22, "lines_coords": [[[669.0, 867.0], [691.0, 867.0], [691.0, 1145.0], [669.0, 1145.0]]], "lines": ["似した人の手つきですよ（笑）。"]}, {"box": [630, 839, 729, 1539], "vertical": true, "font_size": 30.0, "lines_coords": [[[694.0, 881.0], [726.0, 881.0], [729.0, 1265.0], [697.0, 1265.0]], [[632.0, 839.0], [659.0, 839.0], [658.0, 1539.0], [630.0, 1539.0]]], "lines": ["ーあ、すごい。それ、相当真っ〈変〉", "大今、机をバーンと叩いたりする。「大今、かなり模写しました。小学"]}, {"box": [736, 847, 758, 1539], "vertical": true, "font_size": 22, "lines_coords": [[[736.0, 847.0], [758.0, 847.0], [758.0, 1539.0], [736.0, 1539.0]]], "lines": ["を、よく真似しました。ほら、これ。って。うまくできなかったですけど"]}, {"box": [814, 459, 1050, 1507], "vertical": true, "font_size": 38, "lines_coords": [[[1005.0, 497.0], [1048.0, 497.0], [1048.0, 1182.0], [1005.0, 1182.0]], [[960.0, 500.0], [998.0, 500.0], [998.0, 1348.0], [960.0, 1348.0]], [[912.0, 500.0], [951.0, 500.0], [949.0, 1158.0], [911.0, 1158.0]], [[865.0, 498.0], [901.0, 498.0], [897.0, 1381.0], [860.0, 1381.0]], [[815.0, 500.0], [849.0, 500.0], [847.0, 1507.0], [814.0, 1507.0]]], "lines": ["最行全７巻ごついに完結を迎える『最初形』。", "インタビューは最終回「第６２話）用の打ち合わせ直後に", "「週刊少年マガジン」編集部にて行われた。", "物語の行方はもちろんのこと、次回作も気になるところ。", "大今先生の人となりに迫るとともに、次回作の構想をうかがった。"]}, {"box": [98, 1212, 288, 1539], "vertical": true, "font_size": 23.833333333333332, "lines_coords": [[[264.0, 1247.0], [286.0, 1247.0], [288.0, 1504.0], [266.0, 1504.0]], [[231.0, 1214.0], [258.0, 1214.0], [258.0, 1415.0], [231.0, 1415.0]], [[199.0, 1254.0], [221.0, 1254.0], [219.0, 1435.0], [197.0, 1435.0]], [[164.0, 1212.0], [191.0, 1212.0], [191.0, 1537.0], [164.0, 1537.0]], [[132.0, 1214.0], [154.0, 1214.0], [154.0, 1537.0], [132.0, 1537.0]], [[98.0, 1216.0], [121.0, 1216.0], [121.0, 1539.0], [98.0, 1539.0]]], "lines": ["ーファンタジーがお好き？", "大今、やりたいです。", "ーやりたいですか。", "大今やりたい．．．．．．けど．．．、雛", "しいです。ルールが広すぎて。な", "にか縛りがないと、読者も何を手"]}, {"box": [309, 1212, 380, 1506], "vertical": true, "font_size": 31.5, "lines_coords": [[[348.0, 1212.0], [380.0, 1212.0], [380.0, 1506.0], [348.0, 1506.0]], [[309.0, 1214.0], [340.0, 1214.0], [340.0, 1474.0], [309.0, 1474.0]]], "lines": ["次回作の構想は．．．", "とりあえず白紙？"]}, {"box": [398, 1209, 587, 1539], "vertical": true, "font_size": 23.0, "lines_coords": [[[565.0, 1209.0], [587.0, 1209.0], [587.0, 1537.0], [565.0, 1537.0]], [[532.0, 1209.0], [554.0, 1209.0], [554.0, 1537.0], [532.0, 1537.0]], [[497.0, 1209.0], [524.0, 1209.0], [522.0, 1537.0], [495.0, 1537.0]], [[466.0, 1214.0], [489.0, 1214.0], [489.0, 1537.0], [466.0, 1537.0]], [[433.0, 1214.0], [455.0, 1214.0], [455.0, 1539.0], [433.0, 1539.0]], [[398.0, 1216.0], [420.0, 1216.0], [420.0, 1451.0], [398.0, 1451.0]]], "lines": ["作ってたくらいですから。最初は", "トレースからはじまって、あの世", "界観っぽい絵を描いたり。バトル", "シーンとか、キャラクターの体の", "描き方は、ぜんぶ高田先生が教え", "てくれたようなものです。"]}, {"box": [597, 1208, 622, 1539], "vertical": true, "font_size": 22, "lines_coords": [[[600.0, 1208.0], [622.0, 1208.0], [619.0, 1539.0], [597.0, 1539.0]]], "lines": ["生のときに一高田裕三ノート」を"]}, {"box": [667, 1262, 688, 1531], "vertical": true, "font_size": 21, "lines_coords": [[[667.0, 1262.0], [688.0, 1262.0], [688.0, 1531.0], [667.0, 1531.0]]], "lines": ["「絵的にも影響受けました？"]}]}