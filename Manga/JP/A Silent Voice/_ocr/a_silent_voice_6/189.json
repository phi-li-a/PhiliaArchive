{"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [52, 19, 285, 101], "vertical": false, "font_size": 27, "lines_coords": [[[52.0, 43.0], [270.0, 19.0], [274.0, 44.0], [56.0, 67.0]], [[56.0, 72.0], [280.0, 46.0], [283.0, 76.0], [59.0, 101.0]]], "lines": ["大今良時ｘ右村架純", "『群の形』対談"]}, {"box": [64, 134, 342, 431], "vertical": true, "font_size": 20.5, "lines_coords": [[[318.0, 134.0], [342.0, 134.0], [342.0, 431.0], [318.0, 431.0]], [[284.0, 135.0], [304.0, 135.0], [304.0, 427.0], [284.0, 427.0]], [[248.0, 135.0], [268.0, 135.0], [268.0, 430.0], [248.0, 430.0]], [[211.0, 135.0], [230.0, 135.0], [230.0, 430.0], [211.0, 430.0]], [[174.0, 135.0], [194.0, 135.0], [194.0, 428.0], [174.0, 428.0]], [[135.0, 135.0], [155.0, 135.0], [155.0, 426.0], [135.0, 426.0]], [[100.0, 135.0], [121.0, 135.0], [121.0, 221.0], [100.0, 221.0]], [[64.0, 135.0], [84.0, 135.0], [84.0, 428.0], [64.0, 428.0]]], "lines": ["大今、はい。見聞きした事実が", "根っこにあります。その当時の雰囲", "気を思い出しながら、物語を膨らま", "せています。作品では時に極端な", "方向に物語の枝を伸ばしますか", "ら、そのままというわけではあり", "ませんが。", "有村・見て見ぬふりをしたり、自分の"]}, {"box": [358, 135, 375, 496], "vertical": true, "font_size": 17, "lines_coords": [[[358.0, 135.0], [375.0, 135.0], [375.0, 496.0], [358.0, 496.0]]], "lines": ["物語は、実体験をもとにしているんですか？"]}, {"box": [393, 132, 710, 594], "vertical": true, "font_size": 22.555555555555557, "lines_coords": [[[686.0, 134.0], [710.0, 134.0], [710.0, 592.0], [686.0, 592.0]], [[651.0, 132.0], [675.0, 132.0], [674.0, 589.0], [650.0, 589.0]], [[614.0, 133.0], [637.0, 133.0], [637.0, 592.0], [614.0, 592.0]], [[577.0, 133.0], [601.0, 133.0], [601.0, 592.0], [577.0, 592.0]], [[542.0, 135.0], [562.0, 135.0], [562.0, 367.0], [542.0, 367.0]], [[502.0, 132.0], [527.0, 132.0], [527.0, 378.0], [502.0, 378.0]], [[467.0, 134.0], [487.0, 134.0], [487.0, 588.0], [467.0, 588.0]], [[430.0, 134.0], [453.0, 134.0], [453.0, 594.0], [430.0, 594.0]], [[393.0, 134.0], [413.0, 134.0], [414.0, 588.0], [395.0, 588.0]]], "lines": ["有村小学校から中学校くらいにかけて、無視された", "そり、悪口を言われましたね。「調子乗ってんなよ」とか、", "男の人と話していると陰口を叩かれたりして。でも", "ずっとではなくて、リーダ「彼みたいな人の意向に", "沿ってローテーションで．．．。", "大今、順番が回ってくる、と。", "有村「そうなんです。一家の形態を読んで気づいたのは、", "本当にありそうな場面がたくさん出てくること。自分", "ならどう振る舞うか、迷うようなシーンが多いんです。"]}, {"box": [430, 647, 717, 1117], "vertical": true, "font_size": 23, "lines_coords": [[[685.0, 655.0], [705.0, 655.0], [706.0, 1113.0], [686.0, 1113.0]], [[650.0, 653.0], [670.0, 653.0], [668.0, 1057.0], [648.0, 1057.0]], [[610.0, 655.0], [634.0, 655.0], [634.0, 1113.0], [610.0, 1113.0]], [[572.0, 655.0], [600.0, 655.0], [600.0, 778.0], [572.0, 778.0]], [[538.0, 655.0], [561.0, 655.0], [561.0, 1113.0], [538.0, 1113.0]], [[502.0, 656.0], [522.0, 656.0], [521.0, 826.0], [501.0, 826.0]], [[463.0, 652.0], [490.0, 652.0], [490.0, 1115.0], [463.0, 1115.0]], [[430.0, 653.0], [450.0, 653.0], [450.0, 1113.0], [430.0, 1113.0]]], "lines": ["の立場次第でいじめの標的を変えるクラスメート：", "．．．。すごく真に迫っていたので、気になりました。", "「いじめのまわりにあった気持ちの変化を描け", "ねビ《え》", "大今、作中に登場した入物で好きなキャラ、嫌いな", "キャラはいますか？", "有村２巻で登場した、新しいお友達の永束君が好き", "ですね。「友達の定義って何かわかる？」って聞かれて"]}]}