{"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [461, 72, 594, 155], "vertical": false, "font_size": 83, "lines_coords": [[[461.0, 72.0], [594.0, 72.0], [594.0, 155.0], [461.0, 155.0]]], "lines": ["良時"]}, {"box": [439, 285, 549, 339], "vertical": false, "font_size": 29.0, "lines_coords": [[[443.0, 292.0], [549.0, 300.0], [546.0, 339.0], [439.0, 332.0]], [[482.0, 285.0], [526.0, 285.0], [526.0, 303.0], [482.0, 303.0]]], "lines": ["対診", "．．．"]}, {"box": [246, 356, 556, 371], "vertical": false, "font_size": 15, "lines_coords": [[[246.0, 356.0], [556.0, 356.0], [556.0, 371.0], [246.0, 371.0]]], "lines": ["本この対象は、選手少年マガジン２０１４年７月に掲載されたものです。"]}, {"box": [229, 393, 559, 414], "vertical": false, "font_size": 15, "lines_coords": [[[229.0, 393.0], [559.0, 394.0], [559.0, 414.0], [229.0, 413.0]]], "lines": ["昨年、朝の連続テレレビ小説「あまちゃん、などで注"]}, {"box": [230, 424, 559, 476], "vertical": false, "font_size": 15, "lines_coords": [[[230.0, 424.0], [559.0, 424.0], [559.0, 447.0], [230.0, 447.0]], [[233.0, 448.0], [295.0, 448.0], [295.0, 460.0], [233.0, 460.0]], [[232.0, 457.0], [555.0, 457.0], [555.0, 476.0], [232.0, 476.0]]], "lines": ["目を集め、ドラマ、映画、ＣＭに引っ張りだこの", "ありむらかすね", "有村架純さん。じつは大の「少年マンガ好き」"]}, {"box": [229, 491, 560, 570], "vertical": false, "font_size": 15, "lines_coords": [[[234.0, 491.0], [556.0, 491.0], [556.0, 507.0], [234.0, 507.0]], [[229.0, 521.0], [560.0, 520.0], [560.0, 540.0], [229.0, 541.0]], [[234.0, 543.0], [260.0, 543.0], [260.0, 553.0], [234.0, 553.0]], [[230.0, 554.0], [505.0, 553.0], [505.0, 569.0], [230.0, 570.0]], [[368.0, 513.0], [384.0, 513.0], [384.0, 521.0], [368.0, 521.0]], [[364.0, 542.0], [399.0, 542.0], [399.0, 554.0], [364.0, 554.0]], [[498.0, 512.0], [556.0, 512.0], [556.0, 523.0], [498.0, 523.0]]], "lines": ["賢の形の感想をお聞きしたところ、ご自身の", "体験もからめて深く語ってくれました。大今良時", "えせい", "先生とのスイペシャル対談をお届けします。", "．．．", "たいだん", "おおいまよしと"]}, {"box": [708, 679, 731, 1115], "vertical": true, "font_size": 20, "lines_coords": [[[708.0, 679.0], [731.0, 679.0], [731.0, 1115.0], [708.0, 1115.0]]], "lines": ["「今回の対談に先駆けて、有村さんには、『聲の形』の"]}, {"box": [416, 655, 693, 1115], "vertical": true, "font_size": 20, "lines_coords": [[[674.0, 656.0], [693.0, 656.0], [693.0, 1115.0], [674.0, 1115.0]], [[634.0, 655.0], [654.0, 655.0], [656.0, 909.0], [636.0, 909.0]], [[617.0, 659.0], [630.0, 659.0], [630.0, 696.0], [617.0, 696.0]], [[597.0, 656.0], [621.0, 656.0], [621.0, 1114.0], [597.0, 1114.0]], [[562.0, 656.0], [586.0, 656.0], [586.0, 973.0], [562.0, 973.0]], [[524.0, 656.0], [547.0, 656.0], [547.0, 1115.0], [524.0, 1115.0]], [[490.0, 657.0], [509.0, 657.0], [509.0, 1114.0], [490.0, 1114.0]], [[451.0, 656.0], [471.0, 656.0], [472.0, 1113.0], [452.0, 1113.0]], [[416.0, 657.0], [436.0, 657.0], [436.0, 1114.0], [416.0, 1114.0]]], "lines": ["２巻も読んでいただきますした。まずは「賢の形・全体の感", "想から聞かせてもらえますか。", "ありひら", "有村さん（以下、有村〉＿正直にに言ってもいいんですか？", "大多先生以下、大多〉もちろんです。", "有村、心が痛かったです。いしめた側がいじめられるよ", "うになり、机に落書きされ、ノートを放り投げられる。同", "級生も家族もそれぞれの立場があって、誰がいい、誰か", "悪いとも言えない苦しさのようなものが伝わってきます"]}, {"box": [373, 653, 404, 707], "vertical": false, "font_size": 54, "lines_coords": [[[373.0, 653.0], [404.0, 653.0], [404.0, 707.0], [373.0, 707.0]]], "lines": ["した。おい！"]}, {"box": [338, 653, 366, 1115], "vertical": true, "font_size": 28, "lines_coords": [[[338.0, 653.0], [366.0, 653.0], [366.0, 1115.0], [338.0, 1115.0]]], "lines": ["大今、ありがとうございます。すごく丁寧に読んでいた"]}, {"box": [83, 653, 328, 1116], "vertical": true, "font_size": 26, "lines_coords": [[[303.0, 656.0], [328.0, 656.0], [328.0, 825.0], [303.0, 825.0]], [[266.0, 653.0], [293.0, 653.0], [293.0, 1115.0], [266.0, 1115.0]], [[232.0, 656.0], [252.0, 656.0], [252.0, 1114.0], [232.0, 1114.0]], [[194.0, 656.0], [218.0, 656.0], [216.0, 955.0], [193.0, 955.0]], [[153.0, 657.0], [181.0, 657.0], [182.0, 1116.0], [154.0, 1116.0]], [[118.0, 655.0], [146.0, 655.0], [143.0, 840.0], [114.0, 840.0]], [[83.0, 655.0], [111.0, 655.0], [111.0, 882.0], [83.0, 882.0]]], "lines": ["だき、驚いています。", "有村「私なら、どう振る舞うまだろうって、考えてしまい", "ました。いじめというほどじゃやないかもしれませんけ", "ど、私の身の回りにもあったんです。", "「現実でも、ローテーションで、いじめの順番が", "回ってくる」〈有村〉", "大今、有村さん自身にも？"]}]}