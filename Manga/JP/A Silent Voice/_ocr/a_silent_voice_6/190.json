{"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [325, 290, 335, 309], "vertical": false, "font_size": 19, "lines_coords": [[[325.0, 290.0], [335.0, 290.0], [335.0, 309.0], [325.0, 309.0]]], "lines": ["ひね"]}, {"box": [630, 130, 662, 401], "vertical": true, "font_size": 32, "lines_coords": [[[630.0, 130.0], [662.0, 130.0], [662.0, 401.0], [630.0, 401.0]]], "lines": ["大今苦手なキャラクターは？"]}, {"box": [85, 131, 329, 590], "vertical": true, "font_size": 23.142857142857142, "lines_coords": [[[302.0, 133.0], [327.0, 133.0], [329.0, 432.0], [304.0, 432.0]], [[264.0, 131.0], [293.0, 131.0], [293.0, 475.0], [264.0, 475.0]], [[230.0, 133.0], [254.0, 133.0], [254.0, 585.0], [230.0, 585.0]], [[194.0, 133.0], [214.0, 133.0], [215.0, 590.0], [195.0, 590.0]], [[158.0, 133.0], [181.0, 133.0], [179.0, 590.0], [155.0, 590.0]], [[121.0, 134.0], [141.0, 134.0], [141.0, 590.0], [121.0, 590.0]], [[85.0, 134.0], [105.0, 134.0], [106.0, 384.0], [86.0, 384.0]]], "lines": ["している。その姿に胸が痛くて．．．。", "大きく少し、謎めいていますよね。あの子、", "有村『うふふ。そうですよね。ミステリアスですね。", "堂々としていて、ムキにならないのがかっこいいです", "が、本当はどう思っているんだろう、と想像してしまい", "ます。勝手な希望としては、硝子ちゃんには軽々しく", "怒ってほしくないかなあ．．．。"]}, {"box": [141, 513, 153, 548], "vertical": true, "font_size": 12, "lines_coords": [[[141.0, 513.0], [153.0, 513.0], [153.0, 548.0], [141.0, 548.0]]], "lines": ["ふふふっ"]}, {"box": [344, 137, 361, 588], "vertical": true, "font_size": 17, "lines_coords": [[[344.0, 137.0], [361.0, 137.0], [361.0, 588.0], [344.0, 588.0]]], "lines": ["んよね。ひどいことをされても、自分から歩み寄ろうと"]}, {"box": [376, 132, 403, 591], "vertical": true, "font_size": 27, "lines_coords": [[[376.0, 132.0], [403.0, 132.0], [403.0, 591.0], [376.0, 591.0]]], "lines": ["有村一作中での硝子ちゃんは、何をされても怒りませ"]}, {"box": [362, 424, 373, 441], "vertical": false, "font_size": 17, "lines_coords": [[[362.0, 424.0], [373.0, 424.0], [373.0, 441.0], [362.0, 441.0]]], "lines": ["ぶん"]}, {"box": [363, 471, 371, 493], "vertical": true, "font_size": 8, "lines_coords": [[[363.0, 471.0], [371.0, 471.0], [371.0, 493.0], [363.0, 493.0]]], "lines": ["あ"]}, {"box": [414, 133, 620, 591], "vertical": true, "font_size": 20.333333333333332, "lines_coords": [[[597.0, 133.0], [618.0, 133.0], [620.0, 590.0], [599.0, 590.0]], [[561.0, 134.0], [581.0, 134.0], [582.0, 590.0], [562.0, 590.0]], [[526.0, 135.0], [546.0, 135.0], [546.0, 506.0], [526.0, 506.0]], [[487.0, 133.0], [511.0, 133.0], [511.0, 591.0], [487.0, 591.0]], [[454.0, 137.0], [471.0, 137.0], [471.0, 589.0], [454.0, 589.0]], [[414.0, 134.0], [434.0, 134.0], [436.0, 550.0], [416.0, 550.0]]], "lines": ["有村「気になるのは、手のひらを返して石田君をいじ", "めてた昔の仲間たち。彼らがあのまま大きくなってい", "たらと思うと、ちょっとイヤかもしれません。", "大今、そのうち、「いま」この彼らも描こうと思っています。", "す。ひとつのいじめのまわりにあった、いろいろな「気", "持ち」がどう変わっていくのかも描かなければ、と。"]}, {"box": [670, 132, 695, 546], "vertical": true, "font_size": 24, "lines_coords": [[[671.0, 132.0], [695.0, 132.0], [693.0, 546.0], [670.0, 546.0]]], "lines": ["りに一人いるだけで、すごとく救われる気がします。"]}, {"box": [711, 137, 727, 589], "vertical": true, "font_size": 16, "lines_coords": [[[711.0, 137.0], [727.0, 137.0], [727.0, 589.0], [711.0, 589.0]]], "lines": ["素敵な言葉を残すんです。ああいう楽観的な人がまわ"]}, {"box": [104, 660, 116, 714], "vertical": true, "font_size": 12, "lines_coords": [[[104.0, 660.0], [116.0, 660.0], [116.0, 714.0], [104.0, 714.0]]], "lines": ["しゃかた"]}, {"box": [198, 659, 214, 746], "vertical": true, "font_size": 16, "lines_coords": [[[198.0, 659.0], [214.0, 659.0], [214.0, 746.0], [198.0, 746.0]]], "lines": ["ています。"]}, {"box": [249, 658, 262, 697], "vertical": true, "font_size": 13, "lines_coords": [[[249.0, 658.0], [262.0, 658.0], [262.0, 697.0], [249.0, 697.0]]], "lines": ["けんさく"]}, {"box": [87, 659, 103, 1110], "vertical": true, "font_size": 16, "lines_coords": [[[87.0, 659.0], [103.0, 659.0], [103.0, 1110.0], [87.0, 1110.0]]], "lines": ["著者の方はもちろん、その作品にもファンの方々がいる"]}, {"box": [105, 878, 113, 901], "vertical": true, "font_size": 8, "lines_coords": [[[105.0, 878.0], [113.0, 878.0], [113.0, 901.0], [105.0, 901.0]]], "lines": ["ひァ"]}, {"box": [121, 658, 141, 1114], "vertical": true, "font_size": 20, "lines_coords": [[[121.0, 658.0], [141.0, 658.0], [141.0, 1114.0], [121.0, 1114.0]]], "lines": ["から外れないように演じようと心がけています。原作"]}, {"box": [179, 802, 187, 846], "vertical": true, "font_size": 8, "lines_coords": [[[179.0, 802.0], [187.0, 802.0], [187.0, 846.0], [179.0, 846.0]]], "lines": ["ぎくひ"]}, {"box": [160, 658, 189, 1110], "vertical": true, "font_size": 14.5, "lines_coords": [[[177.0, 659.0], [189.0, 659.0], [189.0, 747.0], [177.0, 747.0]], [[160.0, 658.0], [177.0, 658.0], [177.0, 1110.0], [160.0, 1110.0]]], "lines": ["ありがらすんで！", "有村、原作のある作品ということで、原作のテイスト"]}, {"box": [234, 657, 262, 1109], "vertical": true, "font_size": 14.5, "lines_coords": [[[249.0, 793.0], [262.0, 793.0], [262.0, 833.0], [249.0, 833.0]], [[234.0, 657.0], [250.0, 657.0], [250.0, 1109.0], [234.0, 1109.0]]], "lines": ["しつれ", "原作のドラマ『失恋ショコラティエーにも出演され"]}, {"box": [362, 659, 373, 693], "vertical": true, "font_size": 11, "lines_coords": [[[362.0, 659.0], [373.0, 659.0], [373.0, 693.0], [362.0, 693.0]]], "lines": ["ふふっふふん"]}, {"box": [287, 812, 298, 850], "vertical": true, "font_size": 11, "lines_coords": [[[287.0, 812.0], [298.0, 812.0], [298.0, 850.0], [287.0, 850.0]]], "lines": ["ありむら"]}, {"box": [269, 657, 363, 1113], "vertical": true, "font_size": 18.666666666666668, "lines_coords": [[[341.0, 657.0], [361.0, 657.0], [363.0, 1110.0], [343.0, 1110.0]], [[307.0, 660.0], [323.0, 660.0], [323.0, 1081.0], [307.0, 1081.0]], [[269.0, 677.0], [289.0, 677.0], [289.0, 1113.0], [269.0, 1113.0]]], "lines": ["大今、本当にありがとうごごさいます。そこまで読み込み", "んでいただけると、かえって恥ずかしいですね（笑）", "「そういえば、有村さんは今月スタートのマンガ"]}, {"box": [380, 658, 397, 978], "vertical": true, "font_size": 17, "lines_coords": [[[380.0, 658.0], [397.0, 658.0], [397.0, 978.0], [380.0, 978.0]]], "lines": ["硝子」を演してみたいな、と思いました"]}, {"box": [416, 658, 471, 1113], "vertical": true, "font_size": 18.5, "lines_coords": [[[454.0, 658.0], [471.0, 658.0], [471.0, 1113.0], [454.0, 1113.0]], [[416.0, 658.0], [436.0, 658.0], [436.0, 1113.0], [416.0, 1113.0]]], "lines": ["しんでいて、すごく共感できるんです。一ああいう表情", "になるような気持ちってあるよね」って。いつか「西宮"]}, {"box": [491, 658, 507, 1112], "vertical": true, "font_size": 16, "lines_coords": [[[491.0, 658.0], [507.0, 658.0], [507.0, 1112.0], [491.0, 1112.0]]], "lines": ["験者としては、やさしさが、まなさしや口角の角度にに"]}, {"box": [538, 656, 560, 697], "vertical": false, "font_size": 41, "lines_coords": [[[538.0, 656.0], [560.0, 656.0], [560.0, 697.0], [538.0, 697.0]]], "lines": ["有村"]}, {"box": [521, 651, 588, 1114], "vertical": true, "font_size": 30.0, "lines_coords": [[[556.0, 651.0], [588.0, 651.0], [588.0, 864.0], [556.0, 864.0]], [[521.0, 652.0], [549.0, 652.0], [549.0, 1114.0], [521.0, 1114.0]]], "lines": ["大今、コクリ（うなずく）", "有村「あそこまでひどい目には遭っていないけど、経"]}, {"box": [600, 657, 620, 1046], "vertical": true, "font_size": 20, "lines_coords": [[[600.0, 657.0], [620.0, 657.0], [620.0, 1046.0], [600.0, 1046.0]]], "lines": ["に、その真剣さが伝わる面はあるんでしょうね。"]}, {"box": [633, 653, 733, 1115], "vertical": true, "font_size": 27.333333333333332, "lines_coords": [[[703.0, 658.0], [731.0, 658.0], [733.0, 1114.0], [705.0, 1114.0]], [[668.0, 656.0], [696.0, 656.0], [696.0, 776.0], [668.0, 776.0]], [[633.0, 653.0], [659.0, 653.0], [659.0, 1115.0], [633.0, 1115.0]]], "lines": ["「硯子ちゃんのやさしさが表情から感じられるん", "です」〈有心〉", "有村っただ、ふたん怒らないからこそ、いざ怒ったとき、"]}, {"box": [105, 1038, 113, 1052], "vertical": false, "font_size": 14, "lines_coords": [[[105.0, 1038.0], [113.0, 1038.0], [113.0, 1052.0], [105.0, 1052.0]]], "lines": ["がた"]}]}