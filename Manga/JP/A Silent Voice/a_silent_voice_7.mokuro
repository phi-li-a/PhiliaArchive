.0], [119.0, 1255.0], [119.0, 1354.0], [39.0, 1354.0]]], "lines": ["２０１８年１２月"]}, {"box": [130, 1190, 398, 1294], "vertical": false, "font_size": 16, "lines_coords": [[[133.0, 1190.0], [398.0, 1190.0], [398.0, 1206.0], [133.0, 1206.0]], [[130.0, 1209.0], [240.0, 1209.0], [240.0, 1225.0], [130.0, 1225.0]], [[132.0, 1239.0], [317.0, 1241.0], [317.0, 1259.0], [132.0, 1257.0]], [[135.0, 1263.0], [274.0, 1263.0], [274.0, 1275.0], [135.0, 1275.0]], [[135.0, 1271.0], [377.0, 1273.0], [377.0, 1294.0], [135.0, 1292.0]]], "lines": ["田中だー．．．まちあわせ", "田中雄ー・講談社", "ＡｌｌＹｏｕＮｅｅｄｌｓＫｉｌ", "桜坂洋「原作竹内良覧「橋成", "安倍吉俊キャラクター原案小梅健＂漫画，集天を"]}, {"box": [52, 1420, 223, 1463], "vertical": false, "font_size": 21.5, "lines_coords": [[[52.0, 1429.0], [202.0, 1420.0], [203.0, 1447.0], [54.0, 1456.0]], [[121.0, 1447.0], [223.0, 1447.0], [223.0, 1463.0], [121.0, 1463.0]]], "lines": ["い、いや、Ｏｒａｎｇｅ．", "立高野苺「双葉社"]}, {"box": [109, 1388, 254, 1404], "vertical": false, "font_size": 16, "lines_coords": [[[109.0, 1388.0], [254.0, 1388.0], [254.0, 1404.0], [109.0, 1404.0]]], "lines": ["仕ゆうきまさみ小学館"]}, {"box": [116, 1308, 376, 1345], "vertical": false, "font_size": 16, "lines_coords": [[[133.0, 1308.0], [376.0, 1308.0], [376.0, 1324.0], [133.0, 1324.0]], [[116.0, 1329.0], [238.0, 1329.0], [238.0, 1345.0], [116.0, 1345.0]]], "lines": ["東京除積トーキョークー", "立石田スイ・集英社"]}, {"box": [132, 1365, 293, 1386], "vertical": false, "font_size": 21, "lines_coords": [[[132.0, 1365.0], [293.0, 1365.0], [293.0, 1386.0], [132.0, 1386.0]]], "lines": ["白喜のクロニクル"]}, {"box": [66, 1503, 264, 1596], "vertical": false, "font_size": 22, "lines_coords": [[[76.0, 1504.0], [256.0, 1533.0], [253.0, 1555.0], [73.0, 1526.0]], [[73.0, 1530.0], [183.0, 1547.0], [180.0, 1569.0], [70.0, 1552.0]]], "lines": ["２１位以降のランキングは", "Ｐ６４を手"]}, {"box": [485, 1244, 503, 1310], "vertical": true, "font_size": 18, "lines_coords": [[[485.0, 1244.0], [503.0, 1244.0], [503.0, 1310.0], [485.0, 1310.0]]], "lines": ["．．"]}, {"box": [576, 1255, 599, 1412], "vertical": true, "font_size": 23, "lines_coords": [[[576.0, 1255.0], [599.0, 1255.0], [599.0, 1412.0], [576.0, 1412.0]]], "lines": ["Ｊｒ＇３９｀３８："]}, {"box": [600, 1246, 632, 1402], "vertical": true, "font_size": 29, "lines_coords": [[[603.0, 1246.0], [632.0, 1246.0], [629.0, 1402.0], [600.0, 1402.0]]], "lines": ["クレード"]}, {"box": [653, 1361, 767, 1408], "vertical": false, "font_size": 27.5, "lines_coords": [[[653.0, 1361.0], [767.0, 1361.0], [767.0, 1394.0], [653.0, 1394.0]], [[658.0, 1386.0], [755.0, 1386.0], [755.0, 1408.0], [658.0, 1408.0]]], "lines": ["あそびあい新聞", "新田章講談社"]}, {"box": [297, 1485, 1040, 1630], "vertical": false, "font_size": 21.142857142857142, "lines_coords": [[[302.0, 1485.0], [629.0, 1485.0], [629.0, 1506.0], [302.0, 1506.0]], [[299.0, 1509.0], [1034.0, 1510.0], [1034.0, 1533.0], [299.0, 1531.0]], [[297.0, 1528.0], [1037.0, 1531.0], [1037.0, 1553.0], [297.0, 1550.0]], [[297.0, 1547.0], [1040.0, 1552.0], [1040.0, 1573.0], [297.0, 1568.0]], [[297.0, 1566.0], [919.0, 1569.0], [919.0, 1590.0], [297.0, 1587.0]], [[299.0, 1584.0], [873.0, 1590.0], [873.0, 1611.0], [299.0, 1604.0]], [[310.0, 1601.0], [890.0, 1609.0], [890.0, 1630.0], [310.0, 1622.0]]], "lines": ["「ランキング集計方法（オトコ幅）について、", "日本の人が楽しい４名、「貴店員が選ぶ」というキャッシャーケース１．２１店舗、「雑誌編集部が選ぶ」（４誌）、「大学漫研が選ぶ」（４校）「各地」を", "あの人はまいいわけで、普通見のマンガ好きが選ぶ」「６名」の名アイノーニング「とに店舗へ雑誌編集部の方へのケートについては、「付き１０点、その時、入手漫研のように、２位一つ点、３位一３点、４位目７点、５", "大人くんがんでしたらしいものも、仕事も点とし、ランキング集計に加算する。「あの人が選ぶ」「雑誌編集部が選んで今月、１９日でもホームページ、「名界のマンガ好きが選ぶ」にもして生まれ", "２０１６点というと、ついては、オンナ編回答者もすぐに加早する。日福作品から１作品のみ選択徳誌編集部の速い」各木の可能とし、同枠は５点として集計。", "ついでは、一冊四百合さんの二度面家のタマゴが選ぶ」になっていた。「一緒に叫びついては、１票０５点としお選択可能とし、旧市はい点として集計（少数点以下は切り上げ。", "漫画家２０１３年１０月１日〜２２１４年ついでは、宗の期間に、単行本が発売され点以上はツーツ。た作品を選考対象とした"]}, {"box": [653, 1244, 866, 1353], "vertical": false, "font_size": 22.5, "lines_coords": [[[653.0, 1244.0], [825.0, 1246.0], [825.0, 1268.0], [653.0, 1267.0]], [[656.0, 1270.0], [866.0, 1268.0], [866.0, 1286.0], [656.0, 1287.0]], [[656.0, 1306.0], [798.0, 1306.0], [798.0, 1329.0], [656.0, 1329.0]], [[658.0, 1326.0], [772.0, 1326.0], [772.0, 1353.0], [658.0, 1353.0]]], "lines": ["アルスラーン戦記", "荒川私画田中芳樹（作）議談社", "ハウアーユー？", "山本美希・祥伝社"]}, {"box": [573, 1413, 997, 1466], "vertical": false, "font_size": 26.5, "lines_coords": [[[573.0, 1424.0], [997.0, 1413.0], [997.0, 1450.0], [573.0, 1461.0]], [[638.0, 1450.0], [863.0, 1450.0], [863.0, 1466.0], [638.0, 1466.0]]], "lines": ["．．．いつかつて魔法少女女性専属にあスクエスと悪は敵対していた。", "仙藤原之あ「スクウェア」エニックス"]}], "img_path": "199.png"}, {"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [116, 73, 264, 133], "vertical": false, "font_size": 28.0, "lines_coords": [[[116.0, 73.0], [264.0, 76.0], [264.0, 105.0], [116.0, 102.0]], [[117.0, 106.0], [262.0, 106.0], [262.0, 133.0], [117.0, 133.0]]], "lines": ["このマンガが", "すごい！２０１５"]}, {"box": [100, 197, 138, 232], "vertical": false, "font_size": 35, "lines_coords": [[[100.0, 197.0], [138.0, 197.0], [138.0, 232.0], [100.0, 232.0]]], "lines": ["第"]}, {"box": [148, 291, 238, 309], "vertical": false, "font_size": 18, "lines_coords": [[[148.0, 291.0], [238.0, 291.0], [238.0, 309.0], [148.0, 309.0]]], "lines": ["オトコ編"]}, {"box": [232, 197, 297, 234], "vertical": false, "font_size": 37, "lines_coords": [[[232.0, 197.0], [297.0, 197.0], [297.0, 234.0], [232.0, 234.0]]], "lines": ["位"]}, {"box": [312, 43, 1043, 352], "vertical": false, "font_size": 305, "lines_coords": [[[312.0, 47.0], [1035.0, 43.0], [1037.0, 347.0], [313.0, 352.0]]], "lines": ["聲の形"]}, {"box": [900, 49, 1003, 92], "vertical": false, "font_size": 40, "lines_coords": [[[901.0, 49.0], [1003.0, 52.0], [1002.0, 92.0], [900.0, 89.0]]], "lines": ["かたち"]}, {"box": [93, 353, 699, 533], "vertical": false, "font_size": 21, "lines_coords": [[[95.0, 357.0], [672.0, 353.0], [672.0, 374.0], [95.0, 377.0]], [[98.0, 385.0], [538.0, 385.0], [538.0, 408.0], [98.0, 408.0]], [[97.0, 415.0], [699.0, 415.0], [699.0, 438.0], [97.0, 438.0]], [[97.0, 446.0], [462.0, 446.0], [462.0, 466.0], [97.0, 466.0]], [[97.0, 478.0], [587.0, 478.0], [587.0, 498.0], [97.0, 498.0]], [[97.0, 508.0], [395.0, 508.0], [395.0, 529.0], [97.0, 529.0]]], "lines": ["主人公・石田将也は、小学生時代、耳が聞こえないかな、", "西宮硝子をいいじめていた。後悔をいだきつつ", "やがて高校生になった将也は、硝子に再び会いいにいく．．．！？", "職賞障がいやいじめ問題を頭かとし", "コミュニケーシコンの成り立ちの難しさを描く本作", "そのマンガ表現について聞く！"]}, {"box": [264, 1265, 900, 1364], "vertical": false, "font_size": 35, "lines_coords": [[[264.0, 1265.0], [900.0, 1265.0], [900.0, 1364.0], [264.0, 1364.0]]], "lines": ["大今良時ですが、"]}, {"box": [262, 1389, 882, 1486], "vertical": false, "font_size": 35, "lines_coords": [[[262.0, 1389.0], [882.0, 1389.0], [882.0, 1410.0], [262.0, 1410.0]], [[266.0, 1418.0], [882.0, 1418.0], [882.0, 1434.0], [266.0, 1434.0]], [[264.0, 1440.0], [882.0, 1440.0], [882.0, 1461.0], [264.0, 1461.0]], [[266.0, 1466.0], [782.0, 1466.0], [782.0, 1486.0], [266.0, 1486.0]]], "lines": ["岐阜県大垣市出身。２００８年「週刊少年マガジン新人漫画賞山に「聲の形」（読", "み切りで入選。２００９年「マルドゥック・スクランブル」（原作．．．沖方丁）で運", "載デビュー。２０１３年に「週刊少年マガジン」に読み切り版「聲の形」（入選作", "のリメイク作品）が掲載され、同年に『聲の形』の連載がスタート。"]}], "img_path": "200.png"}, {"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [58, 20, 329, 36], "vertical": false, "font_size": 16, "lines_coords": [[[58.0, 20.0], [329.0, 20.0], [329.0, 36.0], [58.0, 36.0]]], "lines": ["オトコ編第１位ＳＰＥＯＩＡＬＩＮＩＥＲＶＩＥＷ"]}, {"box": [114, 103, 141, 388], "vertical": true, "font_size": 25, "lines_coords": [[[114.0, 103.0], [141.0, 103.0], [141.0, 388.0], [114.0, 388.0]]], "lines": ["大今、ああ。そうですね（笑）。"]}, {"box": [84, 160, 106, 425], "vertical": true, "font_size": 25, "lines_coords": [[[84.0, 160.0], [106.0, 160.0], [106.0, 425.0], [84.0, 425.0]]], "lines": ["「こういった箇所が多いです"]}, {"box": [184, 122, 305, 430], "vertical": true, "font_size": 25, "lines_coords": [[[283.0, 125.0], [305.0, 125.0], [305.0, 428.0], [283.0, 428.0]], [[248.0, 124.0], [275.0, 124.0], [275.0, 430.0], [248.0, 430.0]], [[213.0, 122.0], [240.0, 122.0], [242.0, 428.0], [215.0, 428.0]], [[184.0, 127.0], [207.0, 127.0], [207.0, 428.0], [184.0, 428.0]]], "lines": ["ビアスの件（Ｊ７ページ参照）で", "す。なにか修羅場があっただろ", "うと推測できるのですが、その", "ことについて作中では語られま"]}, {"box": [312, 160, 340, 427], "vertical": true, "font_size": 25, "lines_coords": [[[312.0, 160.0], [339.0, 160.0], [340.0, 427.0], [313.0, 427.0]]], "lines": ["たとえば石田のお母さんの"]}, {"box": [350, 106, 508, 430], "vertical": true, "font_size": 26.4, "lines_coords": [[[481.0, 164.0], [508.0, 164.0], [508.0, 430.0], [481.0, 430.0]], [[446.0, 124.0], [471.0, 124.0], [474.0, 430.0], [449.0, 430.0]], [[414.0, 125.0], [441.0, 125.0], [441.0, 428.0], [414.0, 428.0]], [[380.0, 125.0], [411.0, 125.0], [411.0, 204.0], [380.0, 204.0]], [[350.0, 106.0], [372.0, 106.0], [372.0, 376.0], [350.0, 376.0]]], "lines": ["単刀直入にお聞きします", "が、作中では「描かれているけど", "語られていない」ことが多いで", "すよね。", "大今、どういうことですか？"]}, {"box": [514, 102, 1034, 431], "vertical": true, "font_size": 26.666666666666668, "lines_coords": [[[1003.0, 105.0], [1032.0, 105.0], [1034.0, 392.0], [1005.0, 392.0]], [[962.0, 103.0], [994.0, 103.0], [994.0, 333.0], [962.0, 333.0]], [[922.0, 106.0], [949.0, 106.0], [949.0, 266.0], [922.0, 266.0]], [[881.0, 143.0], [908.0, 143.0], [909.0, 431.0], [882.0, 431.0]], [[847.0, 119.0], [876.0, 119.0], [873.0, 239.0], [844.0, 239.0]], [[812.0, 102.0], [844.0, 102.0], [844.0, 422.0], [812.0, 422.0]], [[780.0, 143.0], [807.0, 143.0], [809.0, 428.0], [782.0, 428.0]], [[745.0, 122.0], [772.0, 122.0], [775.0, 428.0], [748.0, 428.0]], [[716.0, 124.0], [739.0, 124.0], [739.0, 420.0], [716.0, 420.0]], [[683.0, 124.0], [705.0, 124.0], [705.0, 428.0], [683.0, 428.0]], [[651.0, 124.0], [673.0, 124.0], [673.0, 428.0], [651.0, 428.0]], [[618.0, 127.0], [640.0, 127.0], [640.0, 427.0], [618.0, 427.0]], [[583.0, 124.0], [610.0, 124.0], [608.0, 428.0], [581.0, 428.0]], [[548.0, 125.0], [575.0, 125.0], [575.0, 264.0], [548.0, 264.0]], [[514.0, 105.0], [541.0, 105.0], [541.0, 325.0], [514.0, 325.0]]], "lines": ["多彩な解釈が可能な", "重層的な描写が", "あちこちに", "｜本年度のオトコ編第１位に", "輝きました。", "大今．．．うれしいです、とても。", "｜連載開始直後から話題に", "なっていたので、すでに数多く", "の取材を受けられていますが、", "マンガと関係ないことを聞かれ", "ることも多かったように思いま", "す。そこで今回はマンガの内容", "についても深くお聞きしたいと", "考えています。", "大今ありがたいです。"]}, {"box": [90, 516, 232, 640], "vertical": false, "font_size": 52.0, "lines_coords": [[[108.0, 576.0], [154.0, 588.0], [143.0, 640.0], [97.0, 629.0]], [[90.0, 529.0], [223.0, 516.0], [229.0, 581.0], [97.0, 594.0]], [[165.0, 584.0], [229.0, 578.0], [232.0, 615.0], [170.0, 621.0]]], "lines": ["第", "オトコ編", "１位"]}, {"box": [360, 691, 391, 747], "vertical": false, "font_size": 56, "lines_coords": [[[360.0, 691.0], [391.0, 691.0], [391.0, 747.0], [360.0, 747.0]]], "lines": ["恥かい"]}, {"box": [347, 486, 1016, 610], "vertical": false, "font_size": 56.5, "lines_coords": [[[457.0, 489.0], [766.0, 486.0], [766.0, 529.0], [457.0, 532.0]], [[348.0, 522.0], [1016.0, 540.0], [1014.0, 610.0], [347.0, 592.0]]], "lines": ["特別描き下ろし、", "今先生、おめでとうございます！！"]}, {"box": [506, 651, 619, 809], "vertical": true, "font_size": 33, "lines_coords": [[[586.0, 658.0], [615.0, 658.0], [615.0, 766.0], [586.0, 766.0]], [[533.0, 656.0], [571.0, 651.0], [589.0, 792.0], [551.0, 796.0]], [[506.0, 664.0], [538.0, 663.0], [544.0, 808.0], [513.0, 809.0]]], "lines": ["やったよ", "おかーさん", "やったよ！！"]}], "img_path": "201.png"}, {"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [586, 0, 1104, 191], "vertical": false, "font_size": 47, "lines_coords": [[[600.0, 9.0], [1080.0, 138.0], [1065.0, 191.0], [586.0, 62.0]], [[858.0, 17.0], [1083.0, 82.0], [1072.0, 121.0], [847.0, 55.0]]], "lines": ["読み返すと印象が変わる", "こがすごい！！"]}, {"box": [694, 180, 991, 288], "vertical": false, "font_size": 53, "lines_coords": [[[694.0, 180.0], [991.0, 180.0], [991.0, 264.0], [694.0, 264.0]], [[709.0, 264.0], [930.0, 264.0], [930.0, 286.0], [709.0, 286.0]]], "lines": ["西宮硝子", "にしみや・しょうこ"]}, {"box": [697, 319, 1059, 475], "vertical": false, "font_size": 21, "lines_coords": [[[699.0, 321.0], [1051.0, 321.0], [1051.0, 342.0], [699.0, 342.0]], [[697.0, 345.0], [1053.0, 347.0], [1053.0, 369.0], [697.0, 368.0]], [[701.0, 374.0], [1053.0, 374.0], [1053.0, 395.0], [701.0, 395.0]], [[702.0, 401.0], [1051.0, 401.0], [1051.0, 422.0], [702.0, 422.0]], [[701.0, 427.0], [1053.0, 427.0], [1053.0, 447.0], [701.0, 447.0]], [[701.0, 454.0], [955.0, 454.0], [955.0, 474.0], [701.0, 474.0]]], "lines": ["笑顔が印象的なヒロイン・西宮硝子。しか", "し、彼女がほほえむ理由は「主人公の視点", "では知りえないこと」（大今）なので、彼女が", "何を考えていいるかわからないい。６巻で硝子の", "内面が描かれると、それまでの笑顔の場面", "も、また違って見えてくるだろう。"]}, {"box": [79, 129, 284, 556], "vertical": false, "font_size": 144, "lines_coords": [[[141.0, 137.0], [210.0, 545.0], [148.0, 556.0], [79.0, 148.0]], [[141.0, 138.0], [199.0, 130.0], [229.0, 366.0], [172.0, 374.0]], [[202.0, 135.0], [253.0, 129.0], [277.0, 313.0], [226.0, 320.0]]], "lines": ["賀叶Ｇ挑螂Ｇ鬨丑", "明かされる", "６巻にて"]}, {"box": [707, 597, 839, 782], "vertical": true, "font_size": 22, "lines_coords": [[[810.0, 600.0], [833.0, 600.0], [833.0, 765.0], [810.0, 765.0]], [[785.0, 599.0], [806.0, 599.0], [806.0, 782.0], [785.0, 782.0]], [[761.0, 599.0], [783.0, 599.0], [783.0, 693.0], [761.0, 693.0]], [[736.0, 597.0], [759.0, 597.0], [756.0, 712.0], [732.0, 712.0]], [[710.0, 599.0], [731.0, 599.0], [728.0, 726.0], [707.0, 726.0]]], "lines": ["自分がやるより先に", "生徒に覚えさせようと", "するなんて", "恥ずかしいと", "思いませんか？"]}, {"box": [90, 659, 386, 733], "vertical": false, "font_size": 74, "lines_coords": [[[90.0, 659.0], [380.0, 659.0], [380.0, 733.0], [90.0, 733.0]]], "lines": ["竹内先生"]}, {"box": [568, 991, 1057, 1152], "vertical": false, "font_size": 19, "lines_coords": [[[575.0, 994.0], [1049.0, 994.0], [1049.0, 1015.0], [575.0, 1015.0]], [[576.0, 1018.0], [1048.0, 1020.0], [1048.0, 1040.0], [576.0, 1039.0]], [[581.0, 1048.0], [1049.0, 1048.0], [1049.0, 1064.0], [581.0, 1064.0]], [[573.0, 1072.0], [1051.0, 1072.0], [1051.0, 1093.0], [573.0, 1093.0]], [[575.0, 1101.0], [1048.0, 1101.0], [1048.0, 1117.0], [575.0, 1117.0]], [[573.0, 1123.0], [1010.0, 1125.0], [1010.0, 1145.0], [573.0, 1144.0]]], "lines": ["主人公・将也の小６時代の担任。障がいい児童の受け入れに", "否定的なようだが、再登場時には手話を理解している（左）。", "「描いているときは自分が１００％竹内になるので、竹内につ", "いて質問されると『俺はこういう風に考えてるんだ』って言っ", "い訳したくなリます。まあ、竹内も精神的には成長してない", "ですよ。少なくとも本人は絶対そう思うっています」（大今）"]}, {"box": [94, 766, 525, 914], "vertical": false, "font_size": 67, "lines_coords": [[[98.0, 803.0], [519.0, 766.0], [524.0, 816.0], [103.0, 852.0]], [[94.0, 830.0], [387.0, 817.0], [390.0, 902.0], [97.0, 914.0]]], "lines": ["１コマから推測できる", "キャラの背景"]}, {"box": [121, 1081, 155, 1133], "vertical": true, "font_size": 34, "lines_coords": [[[121.0, 1081.0], [155.0, 1081.0], [155.0, 1133.0], [121.0, 1133.0]]], "lines": ["来たかった？"]}, {"box": [1027, 1231, 1053, 1533], "vertical": true, "font_size": 25, "lines_coords": [[[1030.0, 1231.0], [1053.0, 1231.0], [1049.0, 1533.0], [1027.0, 1533.0]]], "lines": ["けど、その意図をお聞かせくだ"]}, {"box": [793, 1209, 987, 1537], "vertical": true, "font_size": 25, "lines_coords": [[[960.0, 1209.0], [987.0, 1209.0], [984.0, 1536.0], [957.0, 1536.0]], [[925.0, 1209.0], [952.0, 1209.0], [952.0, 1537.0], [925.0, 1537.0]], [[895.0, 1212.0], [917.0, 1212.0], [917.0, 1534.0], [895.0, 1534.0]], [[860.0, 1212.0], [884.0, 1212.0], [882.0, 1536.0], [858.0, 1536.0]], [[828.0, 1214.0], [850.0, 1214.0], [850.0, 1536.0], [828.0, 1536.0]], [[793.0, 1212.0], [815.0, 1212.0], [815.0, 1450.0], [793.0, 1450.0]]], "lines": ["大今、将也が知りえないことは読", "者には知らせない、将也が気づい", "ていないことは取りあげない、つ", "もりでした。将也が注目していな", "い事柄には、読者の注意を向けさ", "せないようにしてました。"]}, {"box": [761, 1246, 783, 1445], "vertical": true, "font_size": 25, "lines_coords": [[[761.0, 1246.0], [783.0, 1246.0], [783.0, 1445.0], [761.0, 1445.0]]], "lines": ["それはどうして？"]}, {"box": [258, 1208, 753, 1537], "vertical": true, "font_size": 25, "lines_coords": [[[726.0, 1208.0], [753.0, 1208.0], [750.0, 1537.0], [723.0, 1537.0]], [[691.0, 1211.0], [718.0, 1211.0], [716.0, 1536.0], [689.0, 1536.0]], [[659.0, 1211.0], [685.0, 1211.0], [681.0, 1534.0], [656.0, 1534.0]], [[626.0, 1230.0], [653.0, 1230.0], [651.0, 1537.0], [624.0, 1537.0]], [[592.0, 1230.0], [619.0, 1230.0], [618.0, 1537.0], [591.0, 1537.0]], [[562.0, 1233.0], [584.0, 1233.0], [584.0, 1534.0], [562.0, 1534.0]], [[525.0, 1228.0], [552.0, 1228.0], [551.0, 1537.0], [524.0, 1537.0]], [[492.0, 1227.0], [519.0, 1227.0], [516.0, 1523.0], [489.0, 1523.0]], [[458.0, 1209.0], [485.0, 1209.0], [482.0, 1536.0], [455.0, 1536.0]], [[425.0, 1211.0], [452.0, 1211.0], [449.0, 1536.0], [422.0, 1536.0]], [[391.0, 1211.0], [419.0, 1211.0], [419.0, 1530.0], [391.0, 1530.0]], [[360.0, 1211.0], [382.0, 1211.0], [382.0, 1534.0], [360.0, 1534.0]], [[326.0, 1212.0], [348.0, 1212.0], [348.0, 1534.0], [326.0, 1534.0]], [[294.0, 1209.0], [317.0, 1209.0], [313.0, 1534.0], [291.0, 1534.0]], [[261.0, 1211.0], [283.0, 1211.0], [280.0, 1512.0], [258.0, 1512.0]]], "lines": ["大今、主人公に感情移入して読ん", "でもらうためです。感情移入しに", "くい、イヤな主人公ですからね（笑）", "ーーただ、そういった点に気づく", "かどうかで、登場人物に対する印", "象が変わりますよね。物語の漆", "中で「こういう人だ」と断定され", "るのは怖くありませんでした？", "大今、怖いです。読者の方や、私", "の周囲の人が「こいつはこういう", "ヤツだ」と言ってくれるんですが、", "そして、それはありがたいことな", "のですが、そのキャラクターの印", "象もまた、その読者のフィルター", "を通した人物像でしかないんで。"]}, {"box": [223, 1259, 251, 1536], "vertical": true, "font_size": 25, "lines_coords": [[[224.0, 1259.0], [251.0, 1259.0], [250.0, 1536.0], [223.0, 1536.0]]], "lines": ["「読者が深読みしたくなる作"]}, {"box": [125, 1209, 218, 1537], "vertical": true, "font_size": 25, "lines_coords": [[[192.0, 1227.0], [218.0, 1227.0], [215.0, 1537.0], [189.0, 1537.0]], [[157.0, 1209.0], [184.0, 1209.0], [184.0, 1534.0], [157.0, 1534.0]], [[125.0, 1211.0], [148.0, 1211.0], [148.0, 1534.0], [125.0, 1534.0]]], "lines": ["りです。正直、たいへんですよね？", "大今、まあ、苦しい時はあるんで", "すけどねぇ。ただ、この作品は人"]}, {"box": [94, 1211, 114, 1534], "vertical": true, "font_size": 20, "lines_coords": [[[94.0, 1211.0], [114.0, 1211.0], [114.0, 1534.0], [94.0, 1534.0]]], "lines": ["が人を知ろうとすること、関わろ"]}], "img_path": "202.png"}, {"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [57, 19, 219, 36], "vertical": false, "font_size": 16, "lines_coords": [[[57.0, 19.0], [219.0, 20.0], [219.0, 36.0], [57.0, 35.0]]], "lines": ["オトコ編第１位ＳＰＥＣＡ"]}, {"box": [78, 57, 743, 204], "vertical": false, "font_size": 61, "lines_coords": [[[78.0, 90.0], [485.0, 57.0], [490.0, 122.0], [82.0, 156.0]], [[86.0, 148.0], [728.0, 92.0], [732.0, 148.0], [90.0, 204.0]]], "lines": ["石田母の右耳から", "推測できるなんらかの修羅場！？"]}, {"box": [474, 259, 557, 363], "vertical": true, "font_size": 26, "lines_coords": [[[524.0, 261.0], [551.0, 261.0], [551.0, 363.0], [524.0, 363.0]], [[495.0, 259.0], [524.0, 259.0], [524.0, 347.0], [495.0, 347.0]], [[474.0, 261.0], [497.0, 261.0], [497.0, 361.0], [474.0, 361.0]]], "lines": ["明日からは", "良い子に", "するのよ？"]}, {"box": [826, 138, 1040, 202], "vertical": false, "font_size": 58, "lines_coords": [[[838.0, 141.0], [1040.0, 141.0], [1040.0, 199.0], [838.0, 199.0]]], "lines": ["合田お"]}, {"box": [648, 225, 1048, 387], "vertical": false, "font_size": 22, "lines_coords": [[[653.0, 232.0], [1040.0, 232.0], [1040.0, 253.0], [653.0, 253.0]], [[653.0, 256.0], [1040.0, 256.0], [1040.0, 278.0], [653.0, 278.0]], [[653.0, 282.0], [1040.0, 283.0], [1040.0, 306.0], [653.0, 304.0]], [[654.0, 310.0], [1040.0, 310.0], [1040.0, 331.0], [654.0, 331.0]], [[653.0, 337.0], [1038.0, 337.0], [1038.0, 358.0], [653.0, 358.0]], [[651.0, 361.0], [989.0, 363.0], [989.0, 385.0], [651.0, 384.0]]], "lines": ["西宮母に詫びに行く際、石田母の左右の耳にピ", "アスがある。しかし、謝罪後の場面では右耳のピ", "アスがなく、耳たぶには血のあとが．．．．．．。母親同", "土の話しあいの場で、なんらかの修羅場があっ", "たと推測できる。将也が気づいていないため、何", "が起きたのか、作中で語られることはない。"]}, {"box": [104, 656, 151, 731], "vertical": true, "font_size": 47, "lines_coords": [[[104.0, 656.0], [151.0, 656.0], [151.0, 731.0], [104.0, 731.0]]], "lines": ["昨日はよくもやってくれたなー"]}, {"box": [43, 482, 508, 634], "vertical": false, "font_size": 57, "lines_coords": [[[43.0, 522.0], [503.0, 482.0], [508.0, 541.0], [47.0, 581.0]], [[47.0, 580.0], [489.0, 541.0], [493.0, 596.0], [52.0, 634.0]]], "lines": ["靴を盗ったデラックスは", "ガキ大将か、パシリか？"]}, {"box": [521, 607, 583, 678], "vertical": true, "font_size": 34, "lines_coords": [[[552.0, 608.0], [583.0, 610.0], [579.0, 677.0], [549.0, 675.0]], [[527.0, 607.0], [564.0, 607.0], [564.0, 678.0], [527.0, 678.0]]], "lines": ["「返す」と", "言ったら"]}, {"box": [723, 579, 756, 632], "vertical": true, "font_size": 33, "lines_coords": [[[723.0, 579.0], [756.0, 579.0], [756.0, 632.0], [723.0, 632.0]]], "lines": ["ではもし俺が．．．"]}, {"box": [657, 447, 963, 521], "vertical": false, "font_size": 66, "lines_coords": [[[658.0, 451.0], [946.0, 447.0], [946.0, 514.0], [658.0, 517.0]]], "lines": ["デラックス"]}, {"box": [785, 556, 1046, 788], "vertical": false, "font_size": 21, "lines_coords": [[[791.0, 556.0], [1040.0, 556.0], [1040.0, 576.0], [791.0, 576.0]], [[788.0, 580.0], [1040.0, 581.0], [1040.0, 604.0], [788.0, 602.0]], [[791.0, 608.0], [1041.0, 608.0], [1041.0, 631.0], [791.0, 631.0]], [[791.0, 635.0], [1040.0, 635.0], [1040.0, 656.0], [791.0, 656.0]], [[790.0, 661.0], [1040.0, 661.0], [1040.0, 682.0], [790.0, 682.0]], [[790.0, 688.0], [1038.0, 688.0], [1038.0, 709.0], [790.0, 709.0]], [[791.0, 715.0], [1040.0, 715.0], [1040.0, 736.0], [791.0, 736.0]], [[791.0, 742.0], [1040.0, 742.0], [1040.0, 763.0], [791.0, 763.0]], [[791.0, 768.0], [971.0, 768.0], [971.0, 788.0], [791.0, 788.0]]], "lines": ["将也の靴を盗んだ犯人（とされ", "た）隣校の少年・デラックス。将", "也の視点からは大柄なガキ大", "将に映るが、２巻の結舷の回想", "シーンでは、硝子をいじめるグ", "ループのひとりとして登場。そこ", "ではランドセル持ちをやらされ", "ている。キャラの様々な側面が", "見えてくる代表的な例。"]}, {"box": [78, 882, 185, 1171], "vertical": true, "font_size": 27, "lines_coords": [[[148.0, 884.0], [175.0, 884.0], [172.0, 1171.0], [144.0, 1171.0]], [[116.0, 882.0], [143.0, 882.0], [138.0, 1171.0], [111.0, 1171.0]], [[81.0, 882.0], [108.0, 882.0], [105.0, 1163.0], [78.0, 1163.0]]], "lines": ["大今、大雑把なところは最後", "まで決めておいて、そこから", "逆算して「ここにアレ入れて、"]}, {"box": [216, 946, 237, 1166], "vertical": true, "font_size": 21, "lines_coords": [[[216.0, 946.0], [237.0, 946.0], [237.0, 1166.0], [216.0, 1166.0]]], "lines": ["それは最初から計画的"]}, {"box": [246, 882, 438, 1171], "vertical": true, "font_size": 24.833333333333332, "lines_coords": [[[415.0, 887.0], [438.0, 887.0], [438.0, 1168.0], [415.0, 1168.0]], [[380.0, 886.0], [407.0, 886.0], [406.0, 1171.0], [379.0, 1171.0]], [[350.0, 884.0], [372.0, 884.0], [372.0, 1166.0], [350.0, 1166.0]], [[313.0, 882.0], [340.0, 882.0], [340.0, 1169.0], [313.0, 1169.0]], [[283.0, 886.0], [305.0, 886.0], [305.0, 1169.0], [283.0, 1169.0]], [[246.0, 886.0], [274.0, 886.0], [274.0, 1086.0], [246.0, 1086.0]]], "lines": ["大今、同じことはやりたくな", "いので変えました。読み切り", "ではやれないことを、連載で", "はやろう、と。最初はずっと", "将也の視点で、６巻でみんな", "の目線に変わります。"]}, {"box": [446, 905, 543, 1168], "vertical": true, "font_size": 27.666666666666668, "lines_coords": [[[516.0, 905.0], [543.0, 905.0], [541.0, 1165.0], [514.0, 1165.0]], [[450.0, 905.0], [479.0, 906.0], [474.0, 1023.0], [446.0, 1021.0]], [[482.0, 906.0], [509.0, 906.0], [508.0, 1168.0], [481.0, 1168.0]]], "lines": ["将也の視点に絞ったのは、", "更点ですね。", "読み切り版からの大きな変"]}, {"box": [556, 841, 632, 1137], "vertical": true, "font_size": 32.0, "lines_coords": [[[600.0, 843.0], [632.0, 843.0], [632.0, 1137.0], [600.0, 1137.0]], [[559.0, 841.0], [591.0, 841.0], [587.0, 1120.0], [556.0, 1120.0]]], "lines": ["各巻の構成は連載前", "から決まっていた！？"]}, {"box": [648, 841, 772, 1168], "vertical": true, "font_size": 23.5, "lines_coords": [[[750.0, 843.0], [772.0, 843.0], [772.0, 1168.0], [750.0, 1168.0]], [[716.0, 843.0], [739.0, 843.0], [739.0, 1168.0], [716.0, 1168.0]], [[683.0, 841.0], [705.0, 841.0], [705.0, 1166.0], [683.0, 1166.0]], [[648.0, 841.0], [675.0, 841.0], [675.0, 1141.0], [648.0, 1141.0]]], "lines": ["てました。「こんなこと、効果あん", "のかなぁ？」と思ったりもします", "が、やっぱりテーマに導かれてい", "るので、やらないといけません。"]}, {"box": [782, 838, 879, 1173], "vertical": true, "font_size": 31.0, "lines_coords": [[[841.0, 838.0], [879.0, 838.0], [879.0, 1173.0], [841.0, 1173.0]], [[812.0, 839.0], [841.0, 839.0], [842.0, 1171.0], [814.0, 1171.0]], [[782.0, 841.0], [809.0, 841.0], [809.0, 1169.0], [782.0, 1169.0]]], "lines": ["そ、多面的なキャラクター描写、わ", "からない部分も作るような描き方", "は、やらないと意味がないよ思っ"]}, {"box": [882, 838, 1041, 1173], "vertical": true, "font_size": 28.2, "lines_coords": [[[1013.0, 839.0], [1040.0, 839.0], [1041.0, 1169.0], [1014.0, 1169.0]], [[979.0, 838.0], [1011.0, 838.0], [1011.0, 1173.0], [979.0, 1173.0]], [[949.0, 838.0], [976.0, 838.0], [971.0, 1171.0], [944.0, 1171.0]], [[916.0, 838.0], [943.0, 838.0], [940.0, 1171.0], [912.0, 1171.0]], [[882.0, 839.0], [909.0, 839.0], [909.0, 1169.0], [882.0, 1169.0]]], "lines": ["うとすることの尊さ」がデーマでし", "た。その行為はたとえ成功しなく", "ても、尊い。ばらばらに、それぞれ", "の事情を抱えて、勝手に生きてい", "る人たち。それがテーマだからこ"]}, {"box": [79, 1230, 203, 1537], "vertical": true, "font_size": 26.25, "lines_coords": [[[181.0, 1268.0], [203.0, 1268.0], [203.0, 1536.0], [181.0, 1536.0]], [[149.0, 1230.0], [176.0, 1230.0], [172.0, 1537.0], [144.0, 1537.0]], [[113.0, 1230.0], [141.0, 1230.0], [140.0, 1537.0], [111.0, 1537.0]], [[79.0, 1231.0], [106.0, 1231.0], [108.0, 1528.0], [81.0, 1528.0]]], "lines": ["「硝子に聴覚障がいがあって", "他者とのコミュニケーションが成", "立しにくいことが、作品をおもし", "ろくしていると思うんですよね。"]}, {"box": [223, 1206, 842, 1542], "vertical": true, "font_size": 25.944444444444443, "lines_coords": [[[814.0, 1209.0], [841.0, 1209.0], [842.0, 1539.0], [815.0, 1539.0]], [[777.0, 1206.0], [809.0, 1206.0], [810.0, 1542.0], [779.0, 1542.0]], [[748.0, 1211.0], [775.0, 1211.0], [775.0, 1539.0], [748.0, 1539.0]], [[716.0, 1211.0], [739.0, 1211.0], [739.0, 1531.0], [716.0, 1531.0]], [[683.0, 1211.0], [705.0, 1211.0], [704.0, 1539.0], [681.0, 1539.0]], [[646.0, 1208.0], [673.0, 1208.0], [675.0, 1539.0], [648.0, 1539.0]], [[616.0, 1211.0], [638.0, 1211.0], [638.0, 1536.0], [616.0, 1536.0]], [[581.0, 1211.0], [603.0, 1211.0], [603.0, 1537.0], [581.0, 1537.0]], [[549.0, 1212.0], [571.0, 1212.0], [571.0, 1537.0], [549.0, 1537.0]], [[513.0, 1211.0], [540.0, 1211.0], [541.0, 1456.0], [514.0, 1456.0]], [[484.0, 1265.0], [506.0, 1265.0], [506.0, 1537.0], [484.0, 1537.0]], [[447.0, 1231.0], [474.0, 1231.0], [474.0, 1537.0], [447.0, 1537.0]], [[417.0, 1233.0], [439.0, 1233.0], [439.0, 1534.0], [417.0, 1534.0]], [[382.0, 1228.0], [409.0, 1228.0], [406.0, 1472.0], [379.0, 1472.0]], [[345.0, 1208.0], [377.0, 1208.0], [377.0, 1537.0], [345.0, 1537.0]], [[313.0, 1209.0], [340.0, 1209.0], [340.0, 1364.0], [313.0, 1364.0]], [[264.0, 1212.0], [296.0, 1212.0], [296.0, 1534.0], [264.0, 1534.0]], [[226.0, 1211.0], [253.0, 1211.0], [250.0, 1439.0], [223.0, 1439.0]]], "lines": ["が、２巻では「将也と結舷」、３巻", "最後で「硝子の重大シーン」「４巻", "で「硝子と結絃の出生の話」、５巻", "での「あの展開」．．．．というのは、", "じつは、連載開始前から、先生から", "提示されていました。そして、ほ", "ぼそのとおりに実現したのは驚異", "的です。キャラクターを、出生前", "から含めて丁寧に構築しているか", "らこそできるのでしょう。", "「毎週のテーマ、毎巻のテ！", "マ、話全体のテーマ．．．と、テー", "マの入れ予構造がすごいです。", "週刊連載だとは思えない。", "大今「いえ。もっとも」ときめ細」", "かくやらないと。", "読者の声を聞くことを", "目的とした作品"]}, {"box": [847, 1208, 1037, 1539], "vertical": true, "font_size": 22.0, "lines_coords": [[[1016.0, 1209.0], [1037.0, 1209.0], [1037.0, 1530.0], [1016.0, 1530.0]], [[983.0, 1208.0], [1003.0, 1208.0], [1003.0, 1534.0], [983.0, 1534.0]], [[951.0, 1209.0], [971.0, 1209.0], [971.0, 1536.0], [951.0, 1536.0]], [[916.0, 1209.0], [938.0, 1209.0], [938.0, 1534.0], [916.0, 1534.0]], [[884.0, 1211.0], [906.0, 1211.0], [906.0, 1346.0], [884.0, 1346.0]], [[849.0, 1208.0], [876.0, 1208.0], [874.0, 1539.0], [847.0, 1539.0]]], "lines": ["ここでゴレやって」と。あとは研究", "毎週の「引き」です。読者に読んで", "もらうためにもー引き」は大事にし", "ています。でも、まだまだ全然で", "きていません。", "祖当、先生はそうおっしゃいます"]}], "img_path": "203.png"}, {"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [721, 1, 1057, 156], "vertical": false, "font_size": 46, "lines_coords": [[[732.0, 28.0], [1027.0, 100.0], [1016.0, 145.0], [721.0, 73.0]]], "lines": ["構成力がすごい！"]}, {"box": [773, 204, 1060, 467], "vertical": false, "font_size": 20, "lines_coords": [[[775.0, 207.0], [1049.0, 207.0], [1049.0, 227.0], [775.0, 227.0]], [[777.0, 232.0], [1053.0, 232.0], [1053.0, 255.0], [777.0, 255.0]], [[775.0, 259.0], [1053.0, 259.0], [1053.0, 280.0], [775.0, 280.0]], [[775.0, 283.0], [1053.0, 285.0], [1053.0, 307.0], [775.0, 306.0]], [[777.0, 312.0], [1051.0, 312.0], [1051.0, 333.0], [777.0, 333.0]], [[779.0, 337.0], [1053.0, 337.0], [1053.0, 358.0], [779.0, 358.0]], [[779.0, 368.0], [1049.0, 368.0], [1049.0, 384.0], [779.0, 384.0]], [[779.0, 392.0], [1053.0, 392.0], [1053.0, 412.0], [779.0, 412.0]], [[777.0, 415.0], [1049.0, 415.0], [1049.0, 436.0], [777.0, 436.0]], [[777.0, 446.0], [884.0, 446.0], [884.0, 463.0], [777.0, 463.0]]], "lines": ["２巻の最初のモノローグ（左）は、", "当初は石田の内省のように読める", "が、２巻を最後まで読むと結絃の", "独自だと気づく。同じセリフで２巻", "の冒頭と締めくくりを挟んでいる。", "「こちらが意図していない点まで", "読者に深読みされることもあります", "す（笑）。大筋以外は、そんなに事前", "にミッチリ決めてしいるワケじゃない", "ですよ。（大今"]}, {"box": [138, 57, 642, 189], "vertical": false, "font_size": 60, "lines_coords": [[[141.0, 78.0], [415.0, 57.0], [420.0, 111.0], [146.0, 132.0]], [[138.0, 124.0], [637.0, 90.0], [642.0, 156.0], [143.0, 189.0]]], "lines": ["単行本ごとに", "ストーリーがまとまる構成"]}, {"box": [334, 233, 357, 301], "vertical": true, "font_size": 22, "lines_coords": [[[334.0, 234.0], [356.0, 234.0], [356.0, 301.0], [334.0, 301.0]]], "lines": ["石田将也"]}, {"box": [250, 353, 306, 417], "vertical": true, "font_size": 26, "lines_coords": [[[267.0, 353.0], [296.0, 353.0], [296.0, 417.0], [267.0, 417.0]], [[250.0, 357.0], [274.0, 357.0], [274.0, 401.0], [250.0, 401.0]]], "lines": ["こいつが", "嫌いだ"]}, {"box": [509, 596, 551, 684], "vertical": true, "font_size": 21, "lines_coords": [[[527.0, 596.0], [551.0, 596.0], [551.0, 667.0], [527.0, 667.0]], [[509.0, 597.0], [527.0, 597.0], [527.0, 678.0], [509.0, 678.0]]], "lines": ["おじゃま", "しました"]}, {"box": [418, 618, 446, 655], "vertical": true, "font_size": 28, "lines_coords": [[[418.0, 618.0], [446.0, 618.0], [446.0, 655.0], [418.0, 655.0]]], "lines": ["誰？"]}, {"box": [47, 513, 549, 604], "vertical": false, "font_size": 48, "lines_coords": [[[47.0, 556.0], [544.0, 513.0], [549.0, 561.0], [52.0, 604.0]]], "lines": ["主人公将地の視点から"]}, {"box": [172, 735, 225, 791], "vertical": false, "font_size": 20, "lines_coords": [[[173.0, 737.0], [219.0, 737.0], [219.0, 755.0], [173.0, 755.0]], [[172.0, 753.0], [223.0, 753.0], [223.0, 776.0], [172.0, 776.0]]], "lines": ["子ども", "供げ所"]}, {"box": [528, 1001, 548, 1096], "vertical": true, "font_size": 16, "lines_coords": [[[530.0, 1002.0], [546.0, 1002.0], [546.0, 1091.0], [530.0, 1091.0]]], "lines": ["．．．ふ～ん．．．"]}, {"box": [95, 814, 573, 994], "vertical": false, "font_size": 19, "lines_coords": [[[98.0, 819.0], [571.0, 819.0], [571.0, 835.0], [98.0, 835.0]], [[97.0, 843.0], [573.0, 843.0], [573.0, 863.0], [97.0, 863.0]], [[97.0, 870.0], [571.0, 870.0], [571.0, 890.0], [97.0, 890.0]], [[98.0, 897.0], [571.0, 897.0], [571.0, 918.0], [98.0, 918.0]], [[98.0, 922.0], [565.0, 922.0], [565.0, 943.0], [98.0, 943.0]], [[103.0, 951.0], [568.0, 951.0], [568.0, 967.0], [103.0, 967.0]], [[103.0, 976.0], [213.0, 976.0], [213.0, 994.0], [103.0, 994.0]]], "lines": ["将也視点の回では、顔にメマークがつく手法で彼の心理か", "表現される。将也の気持ちに合わせて、メマークが遠くから", "飛んできて顔に貼りついたり、ぺらっとはがれたりする。そし", "て６巻になると、将也視点を通さない各キャラの物語へ。ち", "なみに大今先生の好きなキャラは永束で、好きなシーンは", "永束が震えているシーン。丸いものは描いていて楽しい", "大今）とのこと、"]}, {"box": [52, 1026, 309, 1153], "vertical": false, "font_size": 50, "lines_coords": [[[70.0, 1048.0], [301.0, 1026.0], [305.0, 1082.0], [74.0, 1104.0]], [[52.0, 1055.0], [92.0, 1050.0], [98.0, 1096.0], [58.0, 1101.0]], [[57.0, 1102.0], [210.0, 1102.0], [210.0, 1149.0], [57.0, 1149.0]]], "lines": ["各キャラクタ", "ｘ", "の物語"]}, {"box": [791, 1209, 1054, 1539], "vertical": true, "font_size": 24.5, "lines_coords": [[[1027.0, 1209.0], [1054.0, 1209.0], [1054.0, 1533.0], [1027.0, 1533.0]], [[992.0, 1209.0], [1019.0, 1209.0], [1019.0, 1534.0], [992.0, 1534.0]], [[959.0, 1209.0], [986.0, 1209.0], [984.0, 1536.0], [957.0, 1536.0]], [[927.0, 1209.0], [954.0, 1209.0], [951.0, 1539.0], [924.0, 1539.0]], [[895.0, 1212.0], [917.0, 1212.0], [917.0, 1534.0], [895.0, 1534.0]], [[860.0, 1211.0], [882.0, 1211.0], [882.0, 1530.0], [860.0, 1530.0]], [[828.0, 1212.0], [850.0, 1212.0], [850.0, 1536.0], [828.0, 1536.0]], [[795.0, 1211.0], [817.0, 1211.0], [814.0, 1485.0], [791.0, 1485.0]]], "lines": ["大今「耳が聞こえないこと」とは、", "しっかり向きあうよう意識してい", "まず。西宮は「こういうことを思っ", "ているんだ」「こういうことを伝え", "たいんだ」と慎重に考えながら描い", "ています。かなり労力を使いまず、", "彼女が思っていること、伝えたいと", "この大半は描かないのですが、"]}, {"box": [94, 1208, 783, 1537], "vertical": true, "font_size": 24.285714285714285, "lines_coords": [[[761.0, 1243.0], [783.0, 1243.0], [783.0, 1534.0], [761.0, 1534.0]], [[729.0, 1230.0], [752.0, 1230.0], [752.0, 1359.0], [729.0, 1359.0]], [[693.0, 1211.0], [720.0, 1211.0], [720.0, 1536.0], [693.0, 1536.0]], [[661.0, 1214.0], [683.0, 1214.0], [683.0, 1537.0], [661.0, 1537.0]], [[627.0, 1212.0], [650.0, 1212.0], [650.0, 1537.0], [627.0, 1537.0]], [[595.0, 1209.0], [618.0, 1209.0], [615.0, 1534.0], [592.0, 1534.0]], [[559.0, 1211.0], [586.0, 1211.0], [586.0, 1537.0], [559.0, 1537.0]], [[525.0, 1209.0], [548.0, 1209.0], [548.0, 1533.0], [525.0, 1533.0]], [[492.0, 1209.0], [519.0, 1209.0], [519.0, 1537.0], [492.0, 1537.0]], [[460.0, 1211.0], [482.0, 1211.0], [482.0, 1534.0], [460.0, 1534.0]], [[425.0, 1208.0], [452.0, 1208.0], [450.0, 1537.0], [423.0, 1537.0]], [[393.0, 1209.0], [417.0, 1209.0], [415.0, 1537.0], [391.0, 1537.0]], [[360.0, 1211.0], [383.0, 1211.0], [382.0, 1528.0], [358.0, 1528.0]], [[326.0, 1209.0], [352.0, 1209.0], [348.0, 1537.0], [323.0, 1537.0]], [[294.0, 1211.0], [317.0, 1211.0], [317.0, 1533.0], [294.0, 1533.0]], [[261.0, 1211.0], [286.0, 1211.0], [283.0, 1418.0], [258.0, 1418.0]], [[226.0, 1208.0], [253.0, 1208.0], [250.0, 1537.0], [223.0, 1537.0]], [[192.0, 1208.0], [219.0, 1208.0], [216.0, 1537.0], [189.0, 1537.0]], [[160.0, 1211.0], [183.0, 1211.0], [183.0, 1534.0], [160.0, 1534.0]], [[125.0, 1211.0], [148.0, 1211.0], [148.0, 1399.0], [125.0, 1399.0]], [[94.0, 1243.0], [116.0, 1243.0], [116.0, 1533.0], [94.0, 1533.0]]], "lines": ["「ご自分にいちばん性格が近", "いキャラは？", "え今、わぁ、わからないですねぇ", "．．．うーん。佐原は自分がこうな", "りたい感じだし、積野はストレス", "を発散させているときの自分だっ", "たり、将也はうじうじ悩んでいる", "ときの自分だったり。西宮は言い", "たいことが言えないけれどなにか", "自分の良心、大切にしておきたい", "部分とか。結絃は家族のなかでの", "自分の立ち位置と同じものををす", "ごく感じます、私も姉がいるので、", "担当いちばんいいお母さんにな", "るのは川井じゃないか、っておっ", "しゃってましたよね？", "大今川井も好きです。読者の反", "応はボロクソですけど（笑）「いじ", "め絶対ダメ！川井は死んだほう", "がいい！」とか〈笑〉。", "｜読者の反応は、かなり気に"]}], "img_path": "204.png"}, {"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [672, 0, 1050, 148], "vertical": false, "font_size": 33, "lines_coords": [[[795.0, 62.0], [994.0, 108.0], [987.0, 140.0], [788.0, 95.0]]], "lines": ["ティがすごい"]}, {"box": [998, 178, 1027, 363], "vertical": true, "font_size": 28, "lines_coords": [[[1000.0, 178.0], [1027.0, 178.0], [1026.0, 363.0], [998.0, 363.0]]], "lines": ["を同住ラ角て生"]}, {"box": [855, 157, 1027, 259], "vertical": false, "font_size": 44.75, "lines_coords": [[[858.0, 157.0], [1027.0, 165.0], [1024.0, 248.0], [855.0, 240.0]], [[868.0, 197.0], [952.0, 200.0], [951.0, 242.0], [866.0, 239.0]], [[930.0, 226.0], [1011.0, 229.0], [1010.0, 258.0], [928.0, 255.0]], [[908.0, 237.0], [932.0, 224.0], [944.0, 245.0], [920.0, 259.0]]], "lines": ["西宮家に生活感を出すため、実際に同じ関取り（２００）に住", "西宮家に生活出すため、実じ間取り（２０", "め、美味に向け（２ＤＫ）に住次員にナメラ", "取りに"]}, {"box": [839, 224, 1013, 385], "vertical": false, "font_size": 38.8, "lines_coords": [[[873.0, 258.0], [1008.0, 258.0], [1008.0, 286.0], [873.0, 286.0]], [[869.0, 227.0], [920.0, 224.0], [922.0, 256.0], [871.0, 259.0]], [[871.0, 283.0], [1013.0, 280.0], [1013.0, 309.0], [871.0, 312.0]], [[841.0, 290.0], [1011.0, 293.0], [1010.0, 377.0], [839.0, 374.0]], [[857.0, 364.0], [995.0, 364.0], [995.0, 385.0], [857.0, 385.0]]], "lines": ["この問収集部員にカメラを渡し、あらゆる", "出すためじ間取り", "も艦果部員にルメラを渡し、あらゆる角度から写真を撮って", "を装し、あらゆる角度から写真を撮ってもらったという。「生活感、命です」大今」", "もちろんこいつ。活感、命です」（大今"]}, {"box": [852, 178, 885, 318], "vertical": true, "font_size": 33, "lines_coords": [[[852.0, 178.0], [885.0, 178.0], [885.0, 318.0], [852.0, 318.0]]], "lines": ["西出じゃむ線を"]}, {"box": [446, 332, 794, 387], "vertical": false, "font_size": 43, "lines_coords": [[[447.0, 337.0], [785.0, 333.0], [785.0, 376.0], [447.0, 380.0]]], "lines": ["西宮家の生活感"]}, {"box": [44, 25, 270, 36], "vertical": false, "font_size": 11, "lines_coords": [[[44.0, 25.0], [270.0, 25.0], [270.0, 36.0], [44.0, 36.0]]], "lines": ["オトコ編第１位ＳＰＥＯ！ＡＬＩＮＴＥＲ"]}, {"box": [65, 79, 361, 119], "vertical": false, "font_size": 27, "lines_coords": [[[71.0, 86.0], [350.0, 86.0], [350.0, 113.0], [71.0, 113.0]]], "lines": ["ネームと完成原稿"]}, {"box": [165, 165, 200, 205], "vertical": true, "font_size": 35, "lines_coords": [[[165.0, 165.0], [200.0, 165.0], [200.0, 205.0], [165.0, 205.0]]], "lines": ["あいはまず部屋で買ってる"]}, {"box": [971, 406, 1027, 650], "vertical": true, "font_size": 56, "lines_coords": [[[971.0, 406.0], [1027.0, 406.0], [1027.0, 647.0], [971.0, 647.0]]], "lines": ["取材の徹底"]}, {"box": [885, 430, 933, 495], "vertical": true, "font_size": 27, "lines_coords": [[[906.0, 430.0], [933.0, 435.0], [925.0, 474.0], [898.0, 470.0]]], "lines": ["広ェ"]}, {"box": [447, 457, 718, 639], "vertical": false, "font_size": 20, "lines_coords": [[[454.0, 460.0], [713.0, 460.0], [713.0, 476.0], [454.0, 476.0]], [[452.0, 484.0], [715.0, 484.0], [715.0, 505.0], [452.0, 505.0]], [[450.0, 511.0], [715.0, 511.0], [715.0, 532.0], [450.0, 532.0]], [[449.0, 537.0], [715.0, 535.0], [715.0, 557.0], [449.0, 559.0]], [[452.0, 564.0], [715.0, 564.0], [715.0, 584.0], [452.0, 584.0]], [[452.0, 591.0], [710.0, 591.0], [710.0, 612.0], [452.0, 612.0]], [[454.0, 618.0], [678.0, 618.0], [678.0, 639.0], [454.0, 639.0]]], "lines": ["担当氏によるとした〈〉先生は取材", "マニアで、写真の数が膨大」とのこ", "と。右は５巻のデート場所で、モデ", "ルとなったのは岐阜県養老町にあ", "る「養老天命反転地」。天命が反", "転するというテーマを持ったアー", "ト作品でもある珍しい公園だ"]}, {"box": [685, 678, 719, 723], "vertical": true, "font_size": 34, "lines_coords": [[[685.0, 678.0], [719.0, 678.0], [719.0, 723.0], [685.0, 723.0]]], "lines": ["しゃはらあぁんかいいあんほらおっあいいがねぇ．．．"]}, {"box": [532, 711, 574, 760], "vertical": true, "font_size": 42, "lines_coords": [[[532.0, 711.0], [574.0, 711.0], [574.0, 760.0], [532.0, 760.0]]], "lines": ["にちぃみああぁんいっちょいいかえおぉ！"]}, {"box": [41, 575, 119, 658], "vertical": true, "font_size": 64, "lines_coords": [[[41.0, 589.0], [103.0, 575.0], [119.0, 643.0], [57.0, 658.0]]], "lines": ["完成原稿"]}, {"box": [778, 716, 1029, 957], "vertical": false, "font_size": 20, "lines_coords": [[[785.0, 723.0], [1022.0, 723.0], [1022.0, 739.0], [785.0, 739.0]], [[783.0, 747.0], [1026.0, 747.0], [1026.0, 768.0], [783.0, 768.0]], [[783.0, 774.0], [1024.0, 774.0], [1024.0, 796.0], [783.0, 796.0]], [[783.0, 801.0], [1024.0, 801.0], [1024.0, 822.0], [783.0, 822.0]], [[783.0, 830.0], [1024.0, 830.0], [1024.0, 846.0], [783.0, 846.0]], [[783.0, 854.0], [1026.0, 854.0], [1026.0, 874.0], [783.0, 874.0]], [[783.0, 881.0], [1024.0, 881.0], [1024.0, 902.0], [783.0, 902.0]], [[783.0, 908.0], [1026.0, 908.0], [1026.0, 929.0], [783.0, 929.0]], [[783.0, 935.0], [1019.0, 935.0], [1019.0, 956.0], [783.0, 956.0]]], "lines": ["「硝子は高度難聴。聾ではね", "いが、右耳がほとんど聞こえな", "い」（大今）。その聴力を表現す", "るために、硝子視点で補聴器", "をつけていない、場面では、セリ", "フの右側を削ったり、文字の", "大きさや書体を変えて工夫し", "ている。作中、途中から硝子は", "右だけ補聴器をかけなくなる。"]}, {"box": [761, 996, 790, 1054], "vertical": true, "font_size": 29, "lines_coords": [[[761.0, 996.0], [790.0, 996.0], [790.0, 1054.0], [761.0, 1054.0]]], "lines": ["えええとまこまで．．．"]}, {"box": [452, 969, 560, 1171], "vertical": true, "font_size": 53, "lines_coords": [[[503.0, 969.0], [560.0, 970.0], [557.0, 1118.0], [500.0, 1117.0]], [[455.0, 975.0], [503.0, 975.0], [500.0, 1171.0], [452.0, 1171.0]]], "lines": ["硝子の", "聴力表現"]}, {"box": [68, 1018, 362, 1147], "vertical": false, "font_size": 21, "lines_coords": [[[71.0, 1018.0], [360.0, 1018.0], [360.0, 1039.0], [71.0, 1039.0]], [[71.0, 1045.0], [360.0, 1045.0], [360.0, 1066.0], [71.0, 1066.0]], [[71.0, 1072.0], [360.0, 1072.0], [360.0, 1093.0], [71.0, 1093.0]], [[68.0, 1098.0], [360.0, 1096.0], [360.0, 1118.0], [68.0, 1120.0]], [[70.0, 1125.0], [288.0, 1125.0], [288.0, 1145.0], [70.0, 1145.0]]], "lines": ["あらかじめ決めていいた物語を、各話", "でどこまで進めるか。担当編集と綿", "密な打ち合わせをし、ネームが描か", "れる。ネーム段階でも、かなりキャラ", "クターの表情がよくわかる。"]}, {"box": [834, 1209, 1027, 1537], "vertical": true, "font_size": 25, "lines_coords": [[[1005.0, 1228.0], [1027.0, 1228.0], [1024.0, 1341.0], [1002.0, 1341.0]], [[968.0, 1209.0], [995.0, 1209.0], [995.0, 1537.0], [968.0, 1537.0]], [[935.0, 1209.0], [957.0, 1209.0], [957.0, 1536.0], [935.0, 1536.0]], [[900.0, 1211.0], [927.0, 1211.0], [928.0, 1537.0], [901.0, 1537.0]], [[871.0, 1211.0], [893.0, 1211.0], [893.0, 1536.0], [871.0, 1536.0]], [[834.0, 1212.0], [863.0, 1212.0], [863.0, 1306.0], [834.0, 1306.0]]], "lines": ["しますか？", "大今、そうですね、読者の声を聞き", "くことも目的でこの作品を探して", "いたようなものですから。感想を", "書いてくれる人には、本当に感謝", "してます。"]}, {"box": [803, 1255, 825, 1469], "vertical": true, "font_size": 25, "lines_coords": [[[803.0, 1255.0], [825.0, 1255.0], [825.0, 1469.0], [803.0, 1469.0]]], "lines": ["一何で感想を見ます？"]}, {"box": [632, 1208, 798, 1541], "vertical": true, "font_size": 25, "lines_coords": [[[764.0, 1208.0], [796.0, 1208.0], [798.0, 1541.0], [766.0, 1541.0]], [[734.0, 1211.0], [761.0, 1211.0], [761.0, 1539.0], [734.0, 1539.0]], [[704.0, 1211.0], [726.0, 1211.0], [726.0, 1536.0], [704.0, 1536.0]], [[670.0, 1212.0], [693.0, 1212.0], [693.0, 1533.0], [670.0, 1533.0]], [[632.0, 1211.0], [659.0, 1211.0], [661.0, 1541.0], [634.0, 1541.0]]], "lines": ["大今ネットですね。独りごとみ", "たいな、むきだしの、なんとなく", "しゃべったような感想が聞きたい", "ので、ツイッター、２ちゃんねる。", "４ｃｈａｎ、ふたば☆ちゃんねる"]}, {"box": [570, 1262, 592, 1537], "vertical": true, "font_size": 23, "lines_coords": [[[570.0, 1262.0], [592.0, 1262.0], [592.0, 1537.0], [570.0, 1537.0]]], "lines": ["「かなり見てますね（笑）。最"]}, {"box": [436, 1211, 559, 1539], "vertical": true, "font_size": 23, "lines_coords": [[[536.0, 1233.0], [559.0, 1233.0], [559.0, 1534.0], [536.0, 1534.0]], [[501.0, 1211.0], [528.0, 1211.0], [528.0, 1536.0], [501.0, 1536.0]], [[470.0, 1212.0], [492.0, 1212.0], [492.0, 1539.0], [470.0, 1539.0]], [[436.0, 1214.0], [458.0, 1214.0], [458.0, 1407.0], [436.0, 1407.0]]], "lines": ["後に読者にひと言お願いします。", "大今、読者のみなさまにこのマン", "ガを育てていただきました。あり", "がとうございました。"]}, {"box": [404, 1273, 426, 1530], "vertical": true, "font_size": 23, "lines_coords": [[[404.0, 1273.0], [426.0, 1273.0], [426.0, 1530.0], [404.0, 1530.0]]], "lines": ["連載終了、お疲れ様でした。"]}, {"box": [21, 1201, 255, 1294], "vertical": false, "font_size": 30, "lines_coords": [[[30.0, 1235.0], [238.0, 1201.0], [243.0, 1228.0], [35.0, 1262.0]], [[66.0, 1260.0], [207.0, 1243.0], [211.0, 1275.0], [71.0, 1292.0]]], "lines": ["サイン入りコミックス", "をプレゼント"]}, {"box": [270, 1468, 376, 1541], "vertical": false, "font_size": 22, "lines_coords": [[[283.0, 1471.0], [361.0, 1471.0], [361.0, 1493.0], [283.0, 1493.0]], [[289.0, 1493.0], [360.0, 1493.0], [360.0, 1515.0], [289.0, 1515.0]], [[272.0, 1517.0], [374.0, 1514.0], [374.0, 1536.0], [272.0, 1539.0]]], "lines": ["インタビュー", "の続きは", "４０ページでは"]}, {"box": [194, 1587, 401, 1603], "vertical": false, "font_size": 16, "lines_coords": [[[194.0, 1587.0], [401.0, 1587.0], [401.0, 1603.0], [194.0, 1603.0]]], "lines": ["「このマンガがすごい！ＷＥＢ"]}, {"box": [50, 1441, 241, 1547], "vertical": false, "font_size": 19, "lines_coords": [[[55.0, 1442.0], [232.0, 1442.0], [232.0, 1458.0], [55.0, 1458.0]], [[54.0, 1461.0], [234.0, 1463.0], [234.0, 1480.0], [54.0, 1479.0]], [[55.0, 1483.0], [235.0, 1483.0], [235.0, 1504.0], [55.0, 1504.0]], [[52.0, 1504.0], [234.0, 1504.0], [234.0, 1525.0], [52.0, 1525.0]], [[52.0, 1523.0], [200.0, 1526.0], [200.0, 1547.0], [52.0, 1544.0]]], "lines": ["大今先生の直筆サイン本を", "３名様に！サイン本には当選", "者のお名前を入れさせてい", "ただきます。応募方法は", "１６０ページをチェック！"]}], "img_path": "205.png"}, {"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [1021, 35, 1104, 105], "vertical": false, "font_size": 70, "lines_coords": [[[1021.0, 35.0], [1104.0, 35.0], [1104.0, 105.0], [1021.0, 105.0]]], "lines": ["オトコ"]}, {"box": [1056, 170, 1090, 205], "vertical": true, "font_size": 20, "lines_coords": [[[1061.0, 175.0], [1081.0, 175.0], [1081.0, 196.0], [1061.0, 196.0]]], "lines": ["．．"]}, {"box": [880, 170, 914, 206], "vertical": false, "font_size": 24, "lines_coords": [[[884.0, 175.0], [908.0, 175.0], [908.0, 199.0], [884.0, 199.0]]], "lines": ["んっ．．．はっ"]}, {"box": [1043, 296, 1062, 532], "vertical": true, "font_size": 16, "lines_coords": [[[1043.0, 296.0], [1059.0, 296.0], [1059.0, 522.0], [1043.0, 522.0]]], "lines": ["ここをのかたち、おおいまよしとき"]}, {"box": [882, 296, 1026, 584], "vertical": true, "font_size": 49, "lines_coords": [[[986.0, 302.0], [1022.0, 302.0], [1022.0, 364.0], [986.0, 364.0]], [[951.0, 326.0], [1026.0, 336.0], [994.0, 584.0], [919.0, 575.0]], [[936.0, 296.0], [992.0, 298.0], [989.0, 390.0], [933.0, 388.0]], [[882.0, 310.0], [909.0, 310.0], [912.0, 441.0], [885.0, 441.0]]], "lines": ["．．．", "言いか", "また", "大今良時"]}, {"box": [506, 636, 879, 1314], "vertical": true, "font_size": 145, "lines_coords": [[[651.0, 683.0], [812.0, 661.0], [879.0, 1153.0], [718.0, 1176.0]], [[570.0, 710.0], [724.0, 690.0], [806.0, 1294.0], [651.0, 1314.0]], [[506.0, 714.0], [624.0, 707.0], [654.0, 1214.0], [536.0, 1220.0]]], "lines": ["いじめ、障がい．．．", "して、より大きな", "水と人との物語へ"]}, {"box": [98, 714, 479, 1107], "vertical": true, "font_size": 27, "lines_coords": [[[452.0, 717.0], [479.0, 717.0], [479.0, 1059.0], [452.0, 1059.0]], [[414.0, 717.0], [441.0, 717.0], [441.0, 1016.0], [414.0, 1016.0]], [[366.0, 718.0], [393.0, 718.0], [393.0, 1107.0], [366.0, 1107.0]], [[331.0, 714.0], [358.0, 714.0], [360.0, 1106.0], [332.0, 1106.0]], [[302.0, 717.0], [325.0, 717.0], [325.0, 1106.0], [302.0, 1106.0]], [[267.0, 714.0], [294.0, 714.0], [291.0, 1107.0], [264.0, 1107.0]], [[234.0, 714.0], [261.0, 714.0], [258.0, 1107.0], [231.0, 1107.0]], [[202.0, 718.0], [224.0, 718.0], [224.0, 1104.0], [202.0, 1104.0]], [[165.0, 714.0], [197.0, 714.0], [192.0, 1106.0], [160.0, 1106.0]], [[133.0, 715.0], [160.0, 715.0], [157.0, 1107.0], [130.0, 1107.0]], [[98.0, 714.0], [127.0, 714.0], [129.0, 980.0], [100.0, 980.0]]], "lines": ["傑作読み切りから人気連載", "物語は熱い青春群像劇に", "「いじめとは何か？」「障がいと向き合う", "とはどういうことか？」連載に先行して", "掲載された読み切り版は、そんな難しい", "テーマに正面からぶつかり、爽やかな物", "語へと巧みに昇華した、衝撃的な完成度", "の作品だった。ゆえに連載開始にあたっ", "て、この作品をどう長編化するのか？」", "というような不安の声がささやかれたの", "も、仕方のないことだろう。"]}, {"box": [892, 1459, 1073, 1534], "vertical": false, "font_size": 14, "lines_coords": [[[893.0, 1459.0], [952.0, 1459.0], [952.0, 1475.0], [893.0, 1475.0]], [[892.0, 1479.0], [1073.0, 1477.0], [1073.0, 1494.0], [892.0, 1496.0]], [[893.0, 1501.0], [1073.0, 1501.0], [1073.0, 1517.0], [893.0, 1517.0]], [[895.0, 1523.0], [981.0, 1523.0], [981.0, 1534.0], [895.0, 1534.0]]], "lines": ["講談を", "「週刊少年マガジン、掲載", "講談社コミックス／既刊", "巻以下続中"]}, {"box": [893, 1553, 1014, 1565], "vertical": false, "font_size": 14, "lines_coords": [[[893.0, 1553.0], [1014.0, 1553.0], [1014.0, 1565.0], [893.0, 1565.0]]], "lines": ["０大今度は〈説談〉"]}, {"box": [591, 1344, 822, 1535], "vertical": false, "font_size": 18, "lines_coords": [[[597.0, 1349.0], [812.0, 1348.0], [812.0, 1365.0], [597.0, 1367.0]], [[595.0, 1372.0], [815.0, 1372.0], [815.0, 1392.0], [595.0, 1392.0]], [[595.0, 1394.0], [815.0, 1394.0], [815.0, 1415.0], [595.0, 1415.0]], [[592.0, 1420.0], [815.0, 1416.0], [815.0, 1437.0], [592.0, 1440.0]], [[595.0, 1443.0], [812.0, 1442.0], [812.0, 1459.0], [595.0, 1461.0]], [[597.0, 1467.0], [807.0, 1467.0], [807.0, 1483.0], [597.0, 1483.0]], [[597.0, 1491.0], [812.0, 1491.0], [812.0, 1507.0], [597.0, 1507.0]], [[599.0, 1515.0], [734.0, 1515.0], [734.0, 1531.0], [599.0, 1531.0]]], "lines": ["やんちゃなガキ大将・石田将", "也は、耳の聞こえない転校", "生・西宮硝子をいじめてい", "た。やがて、ふとしたきっかけ", "から、今度は将せがいじめの", "ターゲットに。そして数年後", "孤独な将也は、可憐に成長し", "た硝子と再会する"]}, {"box": [100, 1145, 524, 1541], "vertical": true, "font_size": 24, "lines_coords": [[[503.0, 1168.0], [524.0, 1168.0], [524.0, 1534.0], [503.0, 1534.0]], [[466.0, 1150.0], [493.0, 1150.0], [493.0, 1537.0], [466.0, 1537.0]], [[436.0, 1150.0], [458.0, 1150.0], [458.0, 1537.0], [436.0, 1537.0]], [[403.0, 1149.0], [425.0, 1149.0], [423.0, 1537.0], [401.0, 1537.0]], [[369.0, 1149.0], [391.0, 1149.0], [391.0, 1537.0], [369.0, 1537.0]], [[332.0, 1145.0], [360.0, 1145.0], [358.0, 1541.0], [331.0, 1541.0]], [[302.0, 1150.0], [325.0, 1150.0], [325.0, 1539.0], [302.0, 1539.0]], [[269.0, 1150.0], [291.0, 1150.0], [291.0, 1537.0], [269.0, 1537.0]], [[235.0, 1150.0], [258.0, 1150.0], [258.0, 1539.0], [235.0, 1539.0]], [[200.0, 1147.0], [227.0, 1147.0], [226.0, 1539.0], [199.0, 1539.0]], [[167.0, 1147.0], [194.0, 1147.0], [192.0, 1541.0], [165.0, 1541.0]], [[132.0, 1149.0], [159.0, 1149.0], [160.0, 1534.0], [133.0, 1534.0]], [[100.0, 1147.0], [127.0, 1147.0], [129.0, 1351.0], [101.0, 1351.0]]], "lines": ["だが、それは杞憂だった。作者は高い", "ハードルを見事に乗り越えてみせたのだ。", "いじめの加害者と被害者が、長い時を経", "て再会する。読み切りとほぼ同じ展開を", "経て、物語は二者関係から、より大きな", "人間関係へ接続される。地に足のついた", "語り口はそのままに、作品は熱い青春群", "像劇へと展開され、エンターテインメン", "トとしての魅力を増やした。本書の刊行時", "には、物語はクライマックスを迎えてい", "え。今からでも遅くない、傷つきつつ懸け", "命に前に進む登場人物たちの行く末を、", "ぜひ見届けてほしい。"]}, {"box": [105, 1490, 124, 1531], "vertical": true, "font_size": 24, "lines_coords": [[[105.0, 1490.0], [124.0, 1490.0], [124.0, 1531.0], [105.0, 1531.0]]], "lines": ["後ー"]}], "img_path": "206.png"}, {"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [587, 100, 941, 199], "vertical": false, "font_size": 62, "lines_coords": [[[587.0, 137.0], [935.0, 100.0], [941.0, 162.0], [594.0, 199.0]]], "lines": ["ここがすごい！"]}, {"box": [598, 226, 953, 257], "vertical": false, "font_size": 28, "lines_coords": [[[602.0, 227.0], [949.0, 227.0], [949.0, 255.0], [602.0, 255.0]]], "lines": ["記号的表現も大胆に用いる"]}, {"box": [45, 18, 311, 39], "vertical": false, "font_size": 16, "lines_coords": [[[58.0, 22.0], [309.0, 22.0], [309.0, 38.0], [58.0, 38.0]]], "lines": ["シキングレビュー１位〜２０位『オトコ編"]}, {"box": [70, 102, 438, 194], "vertical": false, "font_size": 61, "lines_coords": [[[70.0, 133.0], [433.0, 102.0], [438.0, 162.0], [74.0, 194.0]]], "lines": ["ここがすごい！"]}, {"box": [81, 212, 486, 402], "vertical": false, "font_size": 21, "lines_coords": [[[183.0, 216.0], [481.0, 216.0], [481.0, 239.0], [183.0, 239.0]], [[82.0, 285.0], [484.0, 285.0], [484.0, 306.0], [82.0, 306.0]], [[84.0, 310.0], [482.0, 310.0], [482.0, 326.0], [84.0, 326.0]], [[332.0, 248.0], [484.0, 245.0], [484.0, 272.0], [332.0, 275.0]], [[81.0, 331.0], [482.0, 331.0], [482.0, 352.0], [81.0, 352.0]], [[82.0, 355.0], [482.0, 355.0], [482.0, 376.0], [82.0, 376.0]], [[84.0, 380.0], [455.0, 380.0], [455.0, 396.0], [84.0, 396.0]]], "lines": ["微妙な感情をすぐい取る", "日常にひたすら退屈していた、悪がキ時代の将也。た", "だ小僧らしいだけではなく、虚無感のようなものが顔", "表現力の妙", "から漂っている。こうした割りきれないい表情を描くこと", "が、作者は抜群にうまい。ヒロインの硝子を魅力的に", "描けるのも、このような表現力があってこそだろう"]}, {"box": [998, 345, 1085, 490], "vertical": true, "font_size": 28, "lines_coords": [[[1048.0, 347.0], [1078.0, 345.0], [1081.0, 430.0], [1051.0, 431.0]], [[1019.0, 349.0], [1046.0, 347.0], [1054.0, 489.0], [1027.0, 490.0]], [[998.0, 352.0], [1026.0, 352.0], [1026.0, 436.0], [998.0, 436.0]]], "lines": ["石田君に", "近づかない方が", "いいわよ"]}, {"box": [594, 664, 1021, 779], "vertical": false, "font_size": 21, "lines_coords": [[[597.0, 666.0], [1021.0, 666.0], [1021.0, 686.0], [597.0, 686.0]], [[600.0, 686.0], [1019.0, 686.0], [1019.0, 709.0], [600.0, 709.0]], [[599.0, 712.0], [1018.0, 712.0], [1018.0, 733.0], [599.0, 733.0]], [[597.0, 734.0], [1019.0, 734.0], [1019.0, 755.0], [597.0, 755.0]], [[599.0, 758.0], [935.0, 758.0], [935.0, 779.0], [599.0, 779.0]]], "lines": ["将也が苦手意識を抱いている相手の顔には、巨大なバ", "ツマークが重なって見える。リアルな表現で微妙な空気", "感を切り取る一方で、マンガの得意とする記号的な表現", "を、要所で大胆に取りリ入れ、強烈なインパクトを生み出", "す。その手腕は、極めで技巧的だといえよう。"]}, {"box": [548, 490, 613, 608], "vertical": true, "font_size": 30, "lines_coords": [[[578.0, 494.0], [607.0, 492.0], [613.0, 607.0], [584.0, 608.0]], [[548.0, 492.0], [578.0, 490.0], [583.0, 565.0], [552.0, 567.0]]], "lines": ["いじめっこ", "だから"]}, {"box": [348, 436, 513, 798], "vertical": true, "font_size": 41, "lines_coords": [[[439.0, 441.0], [482.0, 436.0], [513.0, 793.0], [470.0, 798.0]], [[387.0, 446.0], [431.0, 443.0], [446.0, 663.0], [401.0, 666.0]], [[348.0, 452.0], [383.0, 449.0], [401.0, 701.0], [366.0, 704.0]]], "lines": ["退屈に圧勝した日とは", "今日のことを", "いうのだろう！"]}, {"box": [978, 1069, 1054, 1174], "vertical": true, "font_size": 76, "lines_coords": [[[978.0, 1069.0], [1054.0, 1069.0], [1054.0, 1174.0], [978.0, 1174.0]]], "lines": ["う、"]}, {"box": [471, 814, 1000, 1043], "vertical": false, "font_size": 95, "lines_coords": [[[511.0, 814.0], [997.0, 871.0], [987.0, 954.0], [501.0, 897.0]], [[485.0, 868.0], [991.0, 938.0], [976.0, 1043.0], [471.0, 973.0]]], "lines": ["伝えたい人がいる", "伝えたいこえがあ"]}, {"box": [484, 1101, 608, 1314], "vertical": true, "font_size": 124, "lines_coords": [[[484.0, 1101.0], [608.0, 1101.0], [608.0, 1314.0], [484.0, 1314.0]]], "lines": ["きぃ"]}, {"box": [78, 1060, 384, 1135], "vertical": false, "font_size": 22, "lines_coords": [[[89.0, 1067.0], [372.0, 1067.0], [372.0, 1090.0], [89.0, 1090.0]], [[89.0, 1106.0], [377.0, 1106.0], [377.0, 1128.0], [89.0, 1128.0]]], "lines": ["この作品を選んだ人は", "この作品も選んでいます"]}, {"box": [76, 1161, 133, 1275], "vertical": true, "font_size": 57, "lines_coords": [[[76.0, 1161.0], [133.0, 1161.0], [133.0, 1275.0], [76.0, 1275.0]]], "lines": ["僕だけがいない街"]}, {"box": [255, 1343, 395, 1404], "vertical": false, "font_size": 19, "lines_coords": [[[269.0, 1346.0], [382.0, 1346.0], [382.0, 1364.0], [269.0, 1364.0]], [[278.0, 1365.0], [360.0, 1365.0], [360.0, 1388.0], [278.0, 1388.0]], [[261.0, 1388.0], [391.0, 1388.0], [391.0, 1404.0], [261.0, 1404.0]]], "lines": ["『ばらかもん", "ヨシノサツキ", "スクウェア・エニックス"]}, {"box": [53, 1366, 208, 1410], "vertical": false, "font_size": 21, "lines_coords": [[[54.0, 1367.0], [208.0, 1367.0], [208.0, 1388.0], [54.0, 1388.0]], [[57.0, 1389.0], [207.0, 1389.0], [207.0, 1410.0], [57.0, 1410.0]]], "lines": ["『僕だけがいない街』", "三部けいノＫＡＤＯＫＡＷＡ"]}, {"box": [62, 1423, 105, 1440], "vertical": false, "font_size": 17, "lines_coords": [[[62.0, 1423.0], [105.0, 1423.0], [105.0, 1440.0], [62.0, 1440.0]]], "lines": ["紹介は"]}], "img_path": "207.png"}, {"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [275, 376, 429, 402], "vertical": false, "font_size": 21, "lines_coords": [[[278.0, 379.0], [423.0, 379.0], [423.0, 400.0], [278.0, 400.0]]], "lines": ["文・多根清よ"]}, {"box": [94, 100, 1014, 369], "vertical": false, "font_size": 147.5, "lines_coords": [[[94.0, 157.0], [745.0, 100.0], [752.0, 165.0], [100.0, 223.0]], [[626.0, 140.0], [1010.0, 132.0], [1014.0, 361.0], [630.0, 369.0]]], "lines": ["このマンガがすごい！２０１５", "グ総評"]}, {"box": [869, 373, 1004, 411], "vertical": false, "font_size": 38, "lines_coords": [[[869.0, 373.0], [1004.0, 373.0], [1004.0, 411.0], [869.0, 411.0]]], "lines": ["オトコ編"]}, {"box": [605, 482, 689, 532], "vertical": false, "font_size": 50, "lines_coords": [[[605.0, 482.0], [689.0, 482.0], [689.0, 532.0], [605.0, 532.0]]], "lines": ["る"]}, {"box": [533, 457, 900, 798], "vertical": true, "font_size": 93.6, "lines_coords": [[[809.0, 460.0], [900.0, 465.0], [885.0, 790.0], [795.0, 785.0]], [[739.0, 460.0], [825.0, 465.0], [812.0, 688.0], [726.0, 683.0]], [[665.0, 457.0], [782.0, 465.0], [763.0, 752.0], [646.0, 744.0]], [[579.0, 516.0], [689.0, 517.0], [685.0, 798.0], [575.0, 796.0]], [[533.0, 476.0], [597.0, 471.0], [608.0, 627.0], [544.0, 632.0]]], "lines": ["「絆」という", "安易な１", "を乗り越", "力強さが", "ある。"]}, {"box": [737, 653, 814, 750], "vertical": false, "font_size": 90, "lines_coords": [[[737.0, 661.0], [804.0, 653.0], [814.0, 742.0], [747.0, 750.0]]], "lines": ["よ言って"]}, {"box": [748, 734, 815, 793], "vertical": false, "font_size": 29.5, "lines_coords": [[[748.0, 734.0], [810.0, 734.0], [810.0, 771.0], [748.0, 771.0]], [[755.0, 771.0], [815.0, 771.0], [815.0, 793.0], [755.0, 793.0]]], "lines": ["世", "未"]}, {"box": [889, 468, 1041, 805], "vertical": true, "font_size": 29, "lines_coords": [[[1013.0, 495.0], [1037.0, 495.0], [1035.0, 801.0], [1011.0, 801.0]], [[973.0, 471.0], [1000.0, 471.0], [1000.0, 803.0], [973.0, 803.0]], [[933.0, 471.0], [960.0, 471.0], [960.0, 803.0], [933.0, 803.0]], [[889.0, 468.0], [927.0, 468.0], [927.0, 532.0], [889.0, 532.0]]], "lines": ["人はしょせんわかりあえない", "他人同士。それでも一緒に前に", "歩いていけるー。今年の顔ぶ", "れは、"]}, {"box": [262, 835, 293, 1171], "vertical": true, "font_size": 27, "lines_coords": [[[266.0, 835.0], [293.0, 835.0], [289.0, 1171.0], [262.0, 1171.0]]], "lines": ["物語で、現実で解体しつつあっ"]}, {"box": [109, 465, 528, 1453], "vertical": true, "font_size": 27.53846153846154, "lines_coords": [[[500.0, 495.0], [528.0, 495.0], [525.0, 803.0], [497.0, 803.0]], [[457.0, 470.0], [489.0, 470.0], [489.0, 1174.0], [457.0, 1174.0]], [[420.0, 468.0], [452.0, 468.0], [452.0, 811.0], [420.0, 811.0]], [[423.0, 809.0], [446.0, 809.0], [446.0, 1171.0], [423.0, 1171.0]], [[382.0, 795.0], [409.0, 795.0], [409.0, 1173.0], [382.0, 1173.0]], [[382.0, 471.0], [409.0, 471.0], [409.0, 806.0], [382.0, 806.0]], [[342.0, 471.0], [369.0, 471.0], [369.0, 803.0], [342.0, 803.0]], [[304.0, 470.0], [331.0, 470.0], [331.0, 1173.0], [304.0, 1173.0]], [[264.0, 468.0], [291.0, 468.0], [288.0, 847.0], [261.0, 847.0]], [[224.0, 470.0], [251.0, 470.0], [251.0, 1174.0], [224.0, 1174.0]], [[180.0, 465.0], [216.0, 465.0], [219.0, 927.0], [183.0, 927.0]], [[148.0, 471.0], [170.0, 471.0], [170.0, 804.0], [148.0, 804.0]], [[109.0, 473.0], [132.0, 473.0], [132.0, 1453.0], [109.0, 1453.0]]], "lines": ["トップの『賢の形』〈１位〉は、", "聴覚が「自由が不自由か」から、法使いの嫁」（２位）も人外ｘ少", "始まり、いじめっ子といじぬら", "「女カップルが違いに戸惑いつつ", "こ、も「夫婦」になろうとし、『ジャー", "れっ子、日常を壊したもの壊さ", "れたものの溝に向きあう。過去", "は変えられず、心の壁はいつまでが共同生活のなかで心が近づく", "でも残る。しかし人の隔たり．．．", "は手を伸ばせば届く距離、た「家族」への揺れ返しかもし", "でもあることは、「僕だけが」れない。", "いない街」です位でも孤立してい", "た主人公がたどりついた場所だ。ちあわせ１０位は「他人同士」そ、てハートフルな２作だ。"]}, {"box": [144, 793, 173, 1542], "vertical": true, "font_size": 26, "lines_coords": [[[148.0, 793.0], [173.0, 793.0], [170.0, 1542.0], [144.0, 1542.0]]], "lines": ["い、『ヤガントマキア』（７位や＂ま、「を信じる点で、ハードコアでい"]}, {"box": [340, 806, 371, 1174], "vertical": true, "font_size": 29, "lines_coords": [[[342.0, 806.0], [371.0, 806.0], [369.0, 1174.0], [340.0, 1174.0]]], "lines": ["「リー』（８位）もメイドと女王人"]}, {"box": [500, 839, 605, 1174], "vertical": true, "font_size": 27.0, "lines_coords": [[[578.0, 841.0], [605.0, 841.0], [603.0, 1173.0], [576.0, 1173.0]], [[540.0, 839.0], [567.0, 839.0], [567.0, 1168.0], [540.0, 1168.0]], [[500.0, 839.0], [527.0, 839.0], [527.0, 1174.0], [500.0, 1174.0]]], "lines": ["似家族を描いた「五色の舟」へ。", "位〕のマンガ化と高い支持は、", "いい意味で予想外だった。『魔"]}, {"box": [653, 839, 724, 1169], "vertical": true, "font_size": 29.5, "lines_coords": [[[697.0, 871.0], [724.0, 871.0], [724.0, 1056.0], [697.0, 1056.0]], [[654.0, 839.0], [686.0, 839.0], [685.0, 1169.0], [653.0, 1169.0]]], "lines": ["人と人が時を", "ともにする原点は家族。"]}, {"box": [618, 839, 645, 1534], "vertical": true, "font_size": 27, "lines_coords": [[[618.0, 839.0], [645.0, 839.0], [645.0, 1534.0], [618.0, 1534.0]]], "lines": ["異形の者たちが身を寄せあう擬地球規模のマクロに捉えたもの。"]}, {"box": [186, 1212, 208, 1539], "vertical": true, "font_size": 22, "lines_coords": [[[186.0, 1212.0], [208.0, 1212.0], [208.0, 1539.0], [186.0, 1539.0]]], "lines": ["あるいは姿形に捕らわれない愛"]}, {"box": [250, 1249, 460, 1453], "vertical": true, "font_size": 112, "lines_coords": [[[391.0, 1407.0], [460.0, 1415.0], [455.0, 1453.0], [387.0, 1445.0]], [[250.0, 1249.0], [294.0, 1249.0], [294.0, 1431.0], [250.0, 1431.0]]], "lines": ["は", "ロレス"]}, {"box": [301, 1168, 599, 1526], "vertical": true, "font_size": 112, "lines_coords": [[[509.0, 1204.0], [599.0, 1204.0], [599.0, 1520.0], [509.0, 1520.0]], [[356.0, 1190.0], [492.0, 1192.0], [489.0, 1416.0], [353.0, 1415.0]], [[320.0, 1185.0], [554.0, 1168.0], [579.0, 1509.0], [345.0, 1526.0]], [[304.0, 1225.0], [387.0, 1227.0], [383.0, 1408.0], [301.0, 1407.0]]], "lines": ["生存を賭け", "激突、", "４名を賭けた異種族の激突、失弾言語は", "言語は"]}, {"box": [382, 1474, 514, 1528], "vertical": true, "font_size": 112, "lines_coords": [[[382.0, 1477.0], [513.0, 1474.0], [514.0, 1525.0], [383.0, 1528.0]]], "lines": ["通の"]}], "img_path": "208.png"}, {"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [86, 27, 218, 38], "vertical": false, "font_size": 11, "lines_coords": [[[86.0, 27.0], [218.0, 27.0], [218.0, 38.0], [86.0, 38.0]]], "lines": ["ング総評、オトコ製"]}, {"box": [302, 90, 677, 417], "vertical": true, "font_size": 82, "lines_coords": [[[607.0, 173.0], [662.0, 173.0], [665.0, 417.0], [610.0, 417.0]], [[520.0, 94.0], [605.0, 92.0], [611.0, 361.0], [527.0, 363.0]], [[447.0, 92.0], [541.0, 92.0], [541.0, 302.0], [447.0, 302.0]], [[382.0, 92.0], [470.0, 94.0], [465.0, 299.0], [377.0, 298.0]], [[317.0, 90.0], [403.0, 97.0], [388.0, 307.0], [302.0, 301.0]]], "lines": ["ならざる", "者たちが、", "異なる", "者の間", "揺れる、"]}, {"box": [683, 102, 752, 365], "vertical": true, "font_size": 27, "lines_coords": [[[723.0, 102.0], [750.0, 102.0], [750.0, 361.0], [723.0, 361.0]], [[683.0, 102.0], [710.0, 102.0], [710.0, 333.0], [683.0, 333.0]]], "lines": ["そして吸血鬼や食人鬼マ", "ツガは、人の姿をして"]}, {"box": [46, 210, 348, 1088], "vertical": true, "font_size": 86, "lines_coords": [[[216.0, 253.0], [296.0, 247.0], [348.0, 980.0], [269.0, 986.0]], [[121.0, 232.0], [211.0, 223.0], [253.0, 653.0], [162.0, 661.0]], [[46.0, 239.0], [138.0, 232.0], [205.0, 1082.0], [113.0, 1088.0]], [[164.0, 627.0], [245.0, 621.0], [280.0, 1071.0], [199.0, 1077.0]]], "lines": ["人はしょせんわかりあえない", "他人同士。でも", "手を伸ばせば届く距離でもある。", "も、人の隔たりは"]}, {"box": [728, 506, 750, 806], "vertical": true, "font_size": 22, "lines_coords": [[[728.0, 506.0], [750.0, 506.0], [750.0, 806.0], [728.0, 806.0]]], "lines": ["にする作者の十八番でもあ"]}, {"box": [407, 470, 712, 1176], "vertical": true, "font_size": 27.875, "lines_coords": [[[683.0, 471.0], [712.0, 471.0], [710.0, 1173.0], [681.0, 1173.0]], [[646.0, 471.0], [673.0, 471.0], [673.0, 801.0], [646.0, 801.0]], [[603.0, 470.0], [635.0, 470.0], [634.0, 991.0], [602.0, 991.0]], [[567.0, 473.0], [594.0, 473.0], [594.0, 804.0], [567.0, 804.0]], [[527.0, 473.0], [554.0, 473.0], [554.0, 694.0], [527.0, 694.0]], [[490.0, 492.0], [517.0, 492.0], [511.0, 1173.0], [484.0, 1173.0]], [[450.0, 471.0], [477.0, 471.0], [471.0, 1176.0], [444.0, 1176.0]], [[411.0, 471.0], [438.0, 471.0], [434.0, 1169.0], [407.0, 1169.0]]], "lines": ["る。かたや『東京喰種』（２位）のおもしろさは、偏見に固", "はスタイリッシュに傾きつつ", "も、序盤のアニメ化により主人、爽やかさだ。", "公のアイデンティティを問うた", "原点が思い出された。", "同じ社会のなかでも「無理解」変則的すぎる家族ぐるみのおつ", "が人を隔てることもある。原子、きあいから恋が芽生えた。子供", "力発電所での作業も都市伝説のはわかってあげない」ですが、"]}, {"box": [522, 819, 594, 1174], "vertical": true, "font_size": 30.0, "lines_coords": [[[565.0, 819.0], [594.0, 819.0], [592.0, 1174.0], [564.0, 1174.0]], [[524.0, 838.0], [556.0, 838.0], [554.0, 1173.0], [522.0, 1173.0]]], "lines": ["「異質ｘ異質の王道は", "ボーイ・ミーツ・ガール。"]}, {"box": [642, 836, 672, 1174], "vertical": true, "font_size": 27, "lines_coords": [[[645.0, 836.0], [672.0, 836.0], [669.0, 1174.0], [642.0, 1174.0]]], "lines": ["まった頭に風穴を開ける"]}, {"box": [724, 511, 986, 1177], "vertical": true, "font_size": 25.375, "lines_coords": [[[963.0, 546.0], [986.0, 546.0], [986.0, 801.0], [963.0, 801.0]], [[924.0, 541.0], [946.0, 541.0], [946.0, 803.0], [924.0, 803.0]], [[882.0, 532.0], [909.0, 532.0], [909.0, 808.0], [882.0, 808.0]], [[844.0, 525.0], [871.0, 525.0], [868.0, 801.0], [841.0, 801.0]], [[806.0, 519.0], [828.0, 519.0], [828.0, 819.0], [806.0, 819.0]], [[764.0, 511.0], [791.0, 511.0], [790.0, 808.0], [763.0, 808.0]], [[759.0, 792.0], [791.0, 792.0], [790.0, 1177.0], [758.0, 1177.0]], [[724.0, 803.0], [747.0, 803.0], [747.0, 1171.0], [724.0, 1171.0]]], "lines": ["時の流れに人間関係を", "押し流された主人公を独", "居老人のように描いた", "『日暮のクロニクル』（１４位）", "は斬新だったし、日常と非、", "日常を「お役所」で地続き", "さ、『いちえふ』でもやっ健康で文章", "「化的な最低限度の生活」へ１０位"]}, {"box": [801, 806, 989, 1547], "vertical": true, "font_size": 27.6, "lines_coords": [[[955.0, 836.0], [986.0, 836.0], [989.0, 1547.0], [959.0, 1547.0]], [[920.0, 839.0], [947.0, 839.0], [947.0, 1179.0], [920.0, 1179.0]], [[881.0, 806.0], [908.0, 806.0], [906.0, 1177.0], [879.0, 1177.0]], [[839.0, 833.0], [866.0, 833.0], [866.0, 1171.0], [839.0, 1171.0]], [[801.0, 836.0], [828.0, 836.0], [828.0, 1176.0], [801.0, 1176.0]]], "lines": ["士がメシを食い、汗を流出会うがトウの立ったボーイ同", "す日常がある。生活保護の現", "一場でも、統計数字の向こうには", "一人ひとりが生を習んでいる。", "綿密な取材や体験に基づいた"]}, {"box": [995, 549, 1029, 1547], "vertical": true, "font_size": 32, "lines_coords": [[[997.0, 549.0], [1029.0, 549.0], [1027.0, 1547.0], [995.0, 1547.0]]], "lines": ["そあぶり出す定番だ。いっ地獄ではなく、仲間同一戦後の焼け跡でガール．．．とも"]}, {"box": [423, 1201, 845, 1547], "vertical": true, "font_size": 78, "lines_coords": [[[763.0, 1227.0], [825.0, 1225.0], [831.0, 1416.0], [769.0, 1418.0]], [[680.0, 1203.0], [780.0, 1201.0], [783.0, 1416.0], [683.0, 1418.0]], [[629.0, 1244.0], [691.0, 1244.0], [691.0, 1486.0], [629.0, 1486.0]], [[536.0, 1206.0], [643.0, 1206.0], [643.0, 1542.0], [536.0, 1542.0]], [[482.0, 1214.0], [560.0, 1212.0], [565.0, 1510.0], [487.0, 1512.0]], [[423.0, 1217.0], [482.0, 1217.0], [482.0, 1353.0], [423.0, 1353.0]]], "lines": ["いつまで", "相手が", "ミステリア", "こんな素敵", "な関係って", "ない"]}, {"box": [842, 1206, 868, 1364], "vertical": true, "font_size": 24, "lines_coords": [[[842.0, 1206.0], [866.0, 1206.0], [868.0, 1364.0], [844.0, 1364.0]]], "lines": ["ら惹かれあう。"]}, {"box": [884, 1179, 946, 1544], "vertical": true, "font_size": 22.0, "lines_coords": [[[924.0, 1179.0], [946.0, 1179.0], [946.0, 1544.0], [924.0, 1544.0]], [[884.0, 1180.0], [906.0, 1180.0], [906.0, 1542.0], [884.0, 1542.0]]], "lines": ["上が出会い直す『あれよ星屑』", "〈５位〉も、互いにわからないか"]}], "img_path": "209.png"}, {"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [101, 89, 228, 138], "vertical": false, "font_size": 20, "lines_coords": [[[106.0, 90.0], [223.0, 90.0], [223.0, 113.0], [106.0, 113.0]], [[108.0, 116.0], [223.0, 116.0], [223.0, 133.0], [108.0, 133.0]]], "lines": ["このマンガが", "すごい！？ｎ５"]}, {"box": [97, 186, 146, 210], "vertical": false, "font_size": 24, "lines_coords": [[[97.0, 186.0], [146.0, 186.0], [146.0, 210.0], [97.0, 210.0]]], "lines": ["第"]}, {"box": [290, 70, 856, 397], "vertical": false, "font_size": 29, "lines_coords": [[[724.0, 70.0], [801.0, 73.0], [799.0, 102.0], [723.0, 98.0]]], "lines": ["かたら"]}, {"box": [183, 0, 1105, 541], "vertical": false, "font_size": 238.0, "lines_coords": [[[235.0, 0.0], [1105.0, 84.0], [1053.0, 541.0], [183.0, 444.0]], [[581.0, 388.0], [812.0, 388.0], [812.0, 411.0], [581.0, 411.0]]], "lines": ["聲の形！！", "何も先生インタビ．．．ウォハンからのおまえも"]}, {"box": [913, 54, 1105, 147], "vertical": false, "font_size": 38, "lines_coords": [[[967.0, 54.0], [1097.0, 54.0], [1097.0, 98.0], [967.0, 98.0]], [[927.0, 105.0], [1092.0, 105.0], [1092.0, 143.0], [927.0, 143.0]]], "lines": ["ＳＰＥＣＩＡＬ", "ＪＮＴＥＲＶＩＥＭ"]}, {"box": [135, 473, 658, 803], "vertical": true, "font_size": 23.875, "lines_coords": [[[635.0, 514.0], [658.0, 514.0], [658.0, 798.0], [635.0, 798.0]], [[602.0, 497.0], [624.0, 497.0], [622.0, 669.0], [600.0, 669.0]], [[567.0, 476.0], [594.0, 476.0], [594.0, 801.0], [567.0, 801.0]], [[533.0, 476.0], [556.0, 476.0], [556.0, 800.0], [533.0, 800.0]], [[498.0, 473.0], [525.0, 473.0], [525.0, 803.0], [498.0, 803.0]], [[466.0, 474.0], [489.0, 474.0], [489.0, 801.0], [466.0, 801.0]], [[434.0, 476.0], [457.0, 476.0], [457.0, 800.0], [434.0, 800.0]], [[403.0, 474.0], [425.0, 474.0], [422.0, 761.0], [399.0, 761.0]], [[366.0, 474.0], [393.0, 474.0], [390.0, 714.0], [363.0, 714.0]], [[334.0, 478.0], [356.0, 478.0], [356.0, 680.0], [334.0, 680.0]], [[301.0, 478.0], [323.0, 478.0], [323.0, 655.0], [301.0, 655.0]], [[266.0, 474.0], [293.0, 474.0], [293.0, 637.0], [266.0, 637.0]], [[232.0, 476.0], [254.0, 476.0], [254.0, 621.0], [232.0, 621.0]], [[199.0, 474.0], [226.0, 474.0], [223.0, 615.0], [195.0, 615.0]], [[167.0, 474.0], [189.0, 474.0], [189.0, 610.0], [167.0, 610.0]], [[135.0, 478.0], [157.0, 478.0], [157.0, 608.0], [135.0, 608.0]]], "lines": ["「いちばん影響を受けたマン", "ガはなんですか？", "大今、はじめて自分のお金で買って", "たマンガが「３ｘ３．ＢＹＥＳ」でした", "た。何十回も読んでましたね。も", "う思い入れが強すぎて、好きなの", "かどうかわからないくらいです。", "買ったのは小学生のときなん", "で、全然内容はわからな", "かったですよ。でも", "キャラクターの名", "前とか、いまで", "も完全に言え", "る。高田裕三", "さんの描く", "キャラの「手」"]}, {"box": [678, 476, 750, 795], "vertical": true, "font_size": 30.5, "lines_coords": [[[718.0, 478.0], [750.0, 478.0], [750.0, 795.0], [718.0, 795.0]], [[680.0, 476.0], [709.0, 476.0], [707.0, 777.0], [678.0, 777.0]]], "lines": ["影響を受けたマンガは", "『３Ｘ３ＥＹＥＳ』！"]}, {"box": [118, 1086, 403, 1162], "vertical": false, "font_size": 22, "lines_coords": [[[122.0, 1086.0], [401.0, 1086.0], [401.0, 1109.0], [122.0, 1109.0]], [[121.0, 1114.0], [399.0, 1114.0], [399.0, 1134.0], [121.0, 1134.0]], [[121.0, 1137.0], [337.0, 1139.0], [337.0, 1161.0], [121.0, 1160.0]]], "lines": ["大今先生が自ら示してくれた高田", "裕三先生のキャラの手の形。一同", "「あるある」」ってなりました。"]}, {"box": [431, 839, 624, 1177], "vertical": true, "font_size": 22.333333333333332, "lines_coords": [[[602.0, 844.0], [624.0, 844.0], [621.0, 1177.0], [599.0, 1177.0]], [[568.0, 844.0], [591.0, 844.0], [587.0, 1173.0], [565.0, 1173.0]], [[533.0, 843.0], [556.0, 843.0], [556.0, 1171.0], [533.0, 1171.0]], [[500.0, 843.0], [522.0, 843.0], [522.0, 1173.0], [500.0, 1173.0]], [[465.0, 839.0], [487.0, 839.0], [487.0, 1168.0], [465.0, 1168.0]], [[434.0, 839.0], [457.0, 839.0], [454.0, 1173.0], [431.0, 1173.0]]], "lines": ["と、小指がこういう風に曲がるん", "ですよ〈突〉《バラス・ヴィダーヒ》』", "ここか手で印を結ぶのも、めっちゃ", "やりました。あとバイが手につけ", "ていた黒いヤツ、あれ作りました。", "軍手を切って、黒に浸して黒くし"]}, {"box": [669, 867, 691, 1145], "vertical": true, "font_size": 22, "lines_coords": [[[669.0, 867.0], [691.0, 867.0], [691.0, 1145.0], [669.0, 1145.0]]], "lines": ["似した人の手つきですよ（笑）。"]}, {"box": [630, 839, 729, 1539], "vertical": true, "font_size": 30.0, "lines_coords": [[[694.0, 881.0], [726.0, 881.0], [729.0, 1265.0], [697.0, 1265.0]], [[632.0, 839.0], [659.0, 839.0], [658.0, 1539.0], [630.0, 1539.0]]], "lines": ["ーあ、すごい。それ、相当真っ〈変〉", "大今、机をバーンと叩いたりする。「大今、かなり模写しました。小学"]}, {"box": [736, 847, 758, 1539], "vertical": true, "font_size": 22, "lines_coords": [[[736.0, 847.0], [758.0, 847.0], [758.0, 1539.0], [736.0, 1539.0]]], "lines": ["を、よく真似しました。ほら、これ。って。うまくできなかったですけど"]}, {"box": [814, 459, 1050, 1507], "vertical": true, "font_size": 38, "lines_coords": [[[1005.0, 497.0], [1048.0, 497.0], [1048.0, 1182.0], [1005.0, 1182.0]], [[960.0, 500.0], [998.0, 500.0], [998.0, 1348.0], [960.0, 1348.0]], [[912.0, 500.0], [951.0, 500.0], [949.0, 1158.0], [911.0, 1158.0]], [[865.0, 498.0], [901.0, 498.0], [897.0, 1381.0], [860.0, 1381.0]], [[815.0, 500.0], [849.0, 500.0], [847.0, 1507.0], [814.0, 1507.0]]], "lines": ["最行全７巻ごついに完結を迎える『最初形』。", "インタビューは最終回「第６２話）用の打ち合わせ直後に", "「週刊少年マガジン」編集部にて行われた。", "物語の行方はもちろんのこと、次回作も気になるところ。", "大今先生の人となりに迫るとともに、次回作の構想をうかがった。"]}, {"box": [98, 1212, 288, 1539], "vertical": true, "font_size": 23.833333333333332, "lines_coords": [[[264.0, 1247.0], [286.0, 1247.0], [288.0, 1504.0], [266.0, 1504.0]], [[231.0, 1214.0], [258.0, 1214.0], [258.0, 1415.0], [231.0, 1415.0]], [[199.0, 1254.0], [221.0, 1254.0], [219.0, 1435.0], [197.0, 1435.0]], [[164.0, 1212.0], [191.0, 1212.0], [191.0, 1537.0], [164.0, 1537.0]], [[132.0, 1214.0], [154.0, 1214.0], [154.0, 1537.0], [132.0, 1537.0]], [[98.0, 1216.0], [121.0, 1216.0], [121.0, 1539.0], [98.0, 1539.0]]], "lines": ["ーファンタジーがお好き？", "大今、やりたいです。", "ーやりたいですか。", "大今やりたい．．．．．．けど．．．、雛", "しいです。ルールが広すぎて。な", "にか縛りがないと、読者も何を手"]}, {"box": [309, 1212, 380, 1506], "vertical": true, "font_size": 31.5, "lines_coords": [[[348.0, 1212.0], [380.0, 1212.0], [380.0, 1506.0], [348.0, 1506.0]], [[309.0, 1214.0], [340.0, 1214.0], [340.0, 1474.0], [309.0, 1474.0]]], "lines": ["次回作の構想は．．．", "とりあえず白紙？"]}, {"box": [398, 1209, 587, 1539], "vertical": true, "font_size": 23.0, "lines_coords": [[[565.0, 1209.0], [587.0, 1209.0], [587.0, 1537.0], [565.0, 1537.0]], [[532.0, 1209.0], [554.0, 1209.0], [554.0, 1537.0], [532.0, 1537.0]], [[497.0, 1209.0], [524.0, 1209.0], [522.0, 1537.0], [495.0, 1537.0]], [[466.0, 1214.0], [489.0, 1214.0], [489.0, 1537.0], [466.0, 1537.0]], [[433.0, 1214.0], [455.0, 1214.0], [455.0, 1539.0], [433.0, 1539.0]], [[398.0, 1216.0], [420.0, 1216.0], [420.0, 1451.0], [398.0, 1451.0]]], "lines": ["作ってたくらいですから。最初は", "トレースからはじまって、あの世", "界観っぽい絵を描いたり。バトル", "シーンとか、キャラクターの体の", "描き方は、ぜんぶ高田先生が教え", "てくれたようなものです。"]}, {"box": [597, 1208, 622, 1539], "vertical": true, "font_size": 22, "lines_coords": [[[600.0, 1208.0], [622.0, 1208.0], [619.0, 1539.0], [597.0, 1539.0]]], "lines": ["生のときに一高田裕三ノート」を"]}, {"box": [667, 1262, 688, 1531], "vertical": true, "font_size": 21, "lines_coords": [[[667.0, 1262.0], [688.0, 1262.0], [688.0, 1531.0], [667.0, 1531.0]]], "lines": ["「絵的にも影響受けました？"]}], "img_path": "210.png"}, {"version": "0.1.7", "img_width": 1136, "img_height": 1632, "blocks": [{"box": [935, 106, 1024, 441], "vertical": true, "font_size": 23, "lines_coords": [[[1003.0, 108.0], [1024.0, 108.0], [1024.0, 439.0], [1003.0, 439.0]], [[967.0, 108.0], [994.0, 108.0], [994.0, 433.0], [967.0, 433.0]], [[935.0, 106.0], [957.0, 106.0], [957.0, 441.0], [935.0, 441.0]]], "lines": ["がかりに読んだらいいかわからな。", "いんじゃないかと思うんですよ。", "私は、テーマがないと描けない。"]}, {"box": [836, 108, 925, 433], "vertical": true, "font_size": 23, "lines_coords": [[[903.0, 108.0], [925.0, 108.0], [925.0, 433.0], [903.0, 433.0]], [[869.0, 109.0], [892.0, 109.0], [892.0, 433.0], [869.0, 433.0]], [[836.0, 108.0], [858.0, 108.0], [858.0, 433.0], [836.0, 433.0]]], "lines": ["「テーマなしで自由に描いてくださ", "い」とか言われると、全然マンガ描", "けないと思う。何を考えたいのか、"]}, {"box": [736, 159, 756, 433], "vertical": true, "font_size": 23, "lines_coords": [[[736.0, 159.0], [756.0, 159.0], [756.0, 433.0], [736.0, 433.0]]], "lines": ["「『襞の形』が終わったあと"]}, {"box": [567, 108, 658, 436], "vertical": true, "font_size": 23, "lines_coords": [[[635.0, 108.0], [658.0, 108.0], [658.0, 436.0], [635.0, 436.0]], [[567.0, 159.0], [587.0, 159.0], [587.0, 436.0], [567.0, 436.0]]], "lines": ["考えてないんです。まだ自分のな", "「『霧の形』は７巻でまとま"]}, {"box": [434, 109, 624, 604], "vertical": true, "font_size": 23, "lines_coords": [[[602.0, 109.0], [624.0, 109.0], [624.0, 427.0], [602.0, 427.0]], [[434.0, 443.0], [457.0, 443.0], [457.0, 604.0], [434.0, 604.0]]], "lines": ["かで、次やることが育っていない。", "そうですよね？"]}, {"box": [399, 108, 557, 596], "vertical": true, "font_size": 23, "lines_coords": [[[536.0, 130.0], [557.0, 130.0], [557.0, 435.0], [536.0, 435.0]], [[501.0, 129.0], [525.0, 129.0], [524.0, 283.0], [500.0, 283.0]], [[466.0, 108.0], [489.0, 108.0], [489.0, 433.0], [466.0, 433.0]], [[431.0, 108.0], [458.0, 108.0], [458.0, 435.0], [431.0, 435.0]], [[399.0, 109.0], [426.0, 109.0], [426.0, 596.0], [399.0, 596.0]]], "lines": ["りましたが、次回作はもっと長", "いのでしょうか。", "大今、本当は長い連載もやりた", "い。描きたいことはたくさんある", "んです。そして、長く続けたいけど、担当・〈苦笑〉"]}, {"box": [31, 22, 322, 51], "vertical": false, "font_size": 20, "lines_coords": [[[44.0, 21.0], [317.0, 20.0], [317.0, 41.0], [44.0, 43.0]]], "lines": ["オトコ編第１位ＳＰＥＯＩＡＬＩＮＴＥＲＷＥＷ"]}, {"box": [968, 502, 1027, 749], "vertical": true, "font_size": 23, "lines_coords": [[[1005.0, 502.0], [1027.0, 502.0], [1024.0, 749.0], [1002.0, 749.0]], [[971.0, 510.0], [994.0, 510.0], [991.0, 621.0], [968.0, 621.0]]], "lines": ["．．．。うぅ、休みたい．．．。", "ーー（一同笑）"]}, {"box": [702, 441, 959, 804], "vertical": true, "font_size": 23, "lines_coords": [[[936.0, 441.0], [959.0, 441.0], [959.0, 801.0], [936.0, 801.0]], [[900.0, 468.0], [927.0, 468.0], [928.0, 803.0], [901.0, 803.0]], [[868.0, 473.0], [892.0, 473.0], [893.0, 801.0], [869.0, 801.0]], [[834.0, 473.0], [861.0, 473.0], [861.0, 804.0], [834.0, 804.0]], [[799.0, 466.0], [826.0, 466.0], [828.0, 801.0], [801.0, 801.0]], [[769.0, 471.0], [791.0, 471.0], [791.0, 736.0], [769.0, 736.0]], [[736.0, 494.0], [758.0, 494.0], [759.0, 801.0], [737.0, 801.0]], [[702.0, 490.0], [729.0, 490.0], [729.0, 594.0], [702.0, 594.0]]], "lines": ["「大今、ネームに時間がかかりすぎる」", "うるんですよ。いや、作画も時間が", "ふかってるんですけど．．．。でも", "本当は、もっと丁寧にネームも考え", "えたいし、もっと描きこみたい。", "うーん．．．ダメですね．．．．。", "ー＿週刊連載でこの密度はすご", "いですよ。"]}, {"box": [567, 109, 823, 800], "vertical": true, "font_size": 23, "lines_coords": [[[803.0, 109.0], [823.0, 109.0], [823.0, 438.0], [803.0, 438.0]], [[567.0, 439.0], [589.0, 439.0], [589.0, 800.0], [567.0, 800.0]]], "lines": ["何を伝えたいのか、を決めなきゃ", "．．．年マガジン」の読者は学生が多い"]}, {"box": [533, 108, 791, 798], "vertical": true, "font_size": 23, "lines_coords": [[[769.0, 108.0], [791.0, 108.0], [791.0, 221.0], [769.0, 221.0]], [[533.0, 452.0], [556.0, 452.0], [556.0, 798.0], [533.0, 798.0]]], "lines": ["いけません。", "こので、だから映画１本見るくらい"]}, {"box": [500, 130, 724, 801], "vertical": true, "font_size": 23, "lines_coords": [[[702.0, 130.0], [724.0, 130.0], [724.0, 318.0], [702.0, 318.0]], [[500.0, 476.0], [522.0, 476.0], [522.0, 801.0], [500.0, 801.0]]], "lines": ["はファンタジーを？", "の密度はやりたいんです。目標と"]}, {"box": [466, 106, 694, 801], "vertical": true, "font_size": 23, "lines_coords": [[[667.0, 106.0], [694.0, 106.0], [694.0, 438.0], [667.0, 438.0]], [[466.0, 470.0], [489.0, 470.0], [489.0, 801.0], [466.0, 801.0]]], "lines": ["大今はい。いや、やっぱり全然", "して。私、ネームの時間かかるは"]}, {"box": [635, 441, 691, 800], "vertical": true, "font_size": 23, "lines_coords": [[[669.0, 441.0], [691.0, 441.0], [691.0, 800.0], [669.0, 800.0]], [[635.0, 441.0], [658.0, 441.0], [658.0, 798.0], [635.0, 798.0]]], "lines": ["大今、いまコミックスって４５０", "「円くらいしますよね？。値段も、"]}, {"box": [600, 468, 622, 798], "vertical": true, "font_size": 23, "lines_coords": [[[600.0, 468.0], [622.0, 468.0], [622.0, 798.0], [600.0, 798.0]]], "lines": ["すごく気にするんです。一週刊少"]}, {"box": [54, 497, 348, 720], "vertical": false, "font_size": 21.5, "lines_coords": [[[54.0, 497.0], [348.0, 497.0], [348.0, 519.0], [54.0, 519.0]], [[66.0, 538.0], [332.0, 537.0], [332.0, 559.0], [66.0, 561.0]], [[65.0, 565.0], [332.0, 564.0], [332.0, 586.0], [65.0, 588.0]], [[68.0, 591.0], [334.0, 591.0], [334.0, 613.0], [68.0, 613.0]], [[68.0, 619.0], [336.0, 619.0], [336.0, 640.0], [68.0, 640.0]], [[70.0, 645.0], [332.0, 645.0], [332.0, 666.0], [70.0, 666.0]], [[68.0, 672.0], [332.0, 672.0], [332.0, 693.0], [68.0, 693.0]], [[68.0, 699.0], [332.0, 699.0], [332.0, 720.0], [68.0, 720.0]]], "lines": ["『コンプレックス・エイジ", "大今先生が今注目しているマン", "ガは佐久間結衣「コンプレック", "ス・エイジム．．．ス・工イジュールページ参照し「お", "もしろかったです。佐久間さんは", "うちの元アシスタントさんで、４巻", "の観覧車とかを描いてくれまし", "た。カケアミがとっても上手なん"]}, {"box": [70, 728, 282, 744], "vertical": false, "font_size": 16, "lines_coords": [[[70.0, 728.0], [282.0, 728.0], [282.0, 744.0], [70.0, 744.0]]], "lines": ["です。ほんと美しい」（大今）。"]}, {"box": [890, 967, 983, 1150], "vertical": true, "font_size": 31, "lines_coords": [[[954.0, 969.0], [983.0, 969.0], [983.0, 1074.0], [954.0, 1074.0]], [[917.0, 967.0], [951.0, 967.0], [954.0, 1150.0], [920.0, 1150.0]], [[890.0, 969.0], [919.0, 969.0], [919.0, 1051.0], [890.0, 1051.0]]], "lines": ["．．．つまり", "ごめんねーって", "こと．．．"]}, {"box": [133, 839, 426, 1176], "vertical": true, "font_size": 26, "lines_coords": [[[399.0, 844.0], [426.0, 844.0], [426.0, 1078.0], [399.0, 1078.0]], [[336.0, 844.0], [358.0, 844.0], [358.0, 1067.0], [336.0, 1067.0]], [[364.0, 839.0], [396.0, 839.0], [393.0, 1173.0], [361.0, 1173.0]], [[299.0, 844.0], [326.0, 844.0], [326.0, 1173.0], [299.0, 1173.0]], [[266.0, 844.0], [293.0, 844.0], [291.0, 1174.0], [264.0, 1174.0]], [[232.0, 843.0], [259.0, 843.0], [256.0, 1158.0], [229.0, 1158.0]], [[197.0, 841.0], [229.0, 841.0], [229.0, 1176.0], [197.0, 1176.0]], [[167.0, 844.0], [189.0, 844.0], [189.0, 1171.0], [167.0, 1171.0]], [[133.0, 846.0], [156.0, 846.0], [156.0, 1173.0], [133.0, 1173.0]]], "lines": ["大今ほら、かかってる。", "す。そして不思議です。", "担当あと、めちゃくちゃ怖いで", "大今、嘘！嘘！！嘘ですよ。怖", "くないですし、変でもないのですね。", "担当で、次の連載どうします？", "大今、いや、だから何も決まって", "ないっす。私は１年間ゲームをや", "るって決めている。１年間！！ゲーム"]}, {"box": [100, 847, 122, 1152], "vertical": true, "font_size": 26, "lines_coords": [[[100.0, 847.0], [122.0, 847.0], [122.0, 1152.0], [100.0, 1152.0]]], "lines": ["ムを！します！．．．．．たぶん。"]}, {"box": [66, 892, 89, 1163], "vertical": true, "font_size": 26, "lines_coords": [[[66.0, 892.0], [89.0, 892.0], [89.0, 1163.0], [66.0, 1163.0]]], "lines": ["「なんのゲームをやります？"]}, {"box": [454, 1456, 1027, 1531], "vertical": false, "font_size": 23, "lines_coords": [[[458.0, 1456.0], [1024.0, 1456.0], [1024.0, 1479.0], [458.0, 1479.0]], [[458.0, 1482.0], [1024.0, 1482.0], [1024.0, 1504.0], [458.0, 1504.0]], [[460.0, 1507.0], [536.0, 1507.0], [536.0, 1531.0], [460.0, 1531.0]]], "lines": ["顔のｘはすべて手描き。ＣＧで元絵の上に貼りつけているわけではな", "い。ちなみに、このコマの背景のカケアミは、佐久間結衣先生によるも", "のだそう。"]}, {"box": [332, 1211, 426, 1539], "vertical": true, "font_size": 26, "lines_coords": [[[399.0, 1214.0], [426.0, 1214.0], [426.0, 1539.0], [399.0, 1539.0]], [[368.0, 1214.0], [390.0, 1214.0], [390.0, 1539.0], [368.0, 1539.0]], [[332.0, 1211.0], [360.0, 1211.0], [360.0, 1310.0], [332.0, 1310.0]]], "lines": ["大今『ときめきメモリアル２』。", "あと『ＦＦ』のライトニングが出て", "くるやつ。"]}, {"box": [301, 1246, 323, 1514], "vertical": true, "font_size": 26, "lines_coords": [[[301.0, 1246.0], [323.0, 1246.0], [323.0, 1514.0], [301.0, 1514.0]]], "lines": ["ーーゲームお好きなんですね、"]}, {"box": [100, 1179, 293, 1541], "vertical": true, "font_size": 26, "lines_coords": [[[266.0, 1179.0], [293.0, 1179.0], [293.0, 1541.0], [266.0, 1541.0]], [[200.0, 1241.0], [226.0, 1241.0], [223.0, 1541.0], [197.0, 1541.0]], [[167.0, 1219.0], [194.0, 1219.0], [194.0, 1539.0], [167.0, 1539.0]], [[133.0, 1228.0], [162.0, 1228.0], [162.0, 1294.0], [133.0, 1294.0]], [[100.0, 1209.0], [127.0, 1209.0], [127.0, 1404.0], [100.0, 1404.0]]], "lines": ["「大今、うん。ゲーム．．．！楽しい", "一次回作も楽しみにしています。", "す〈笑〉。なるべく早く読みたい", "です。", "大今は、はい．．．。"]}], "img_path": "211.png"}]}