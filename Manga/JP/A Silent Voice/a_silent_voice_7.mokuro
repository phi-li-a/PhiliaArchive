{"version": "0.2.0-beta.6", "title": "A Silent Voice", "title_uuid": "0ef04b72-4228-48b1-ba08-9674badb458b", "volume": "a_silent_voice_7", "volume_uuid": "52de4717-9f46-4796-911e-dc28fb75d062", "pages": [{"version": "0.1.7", "img_width": 2273, "img_height": 1600, "blocks": [{"box": [1914, 26, 2229, 55], "vertical": false, "font_size": 27, "lines_coords": [[[1917.0, 24.0], [2221.0, 26.0], [2221.0, 55.0], [1917.0, 53.0]]], "lines": ["ＳＢＮ９７６－４．０６－３５２８－１"]}, {"box": [1456, 554, 1782, 656], "vertical": false, "font_size": 51, "lines_coords": [[[1473.0, 554.0], [1664.0, 570.0], [1660.0, 619.0], [1469.0, 603.0]], [[1458.0, 601.0], [1780.0, 590.0], [1782.0, 643.0], [1460.0, 654.0]]], "lines": ["こういった", "「じゃーな、西宮"]}, {"box": [1047, 217, 1231, 1000], "vertical": true, "font_size": 109, "lines_coords": [[[1047.0, 224.0], [1218.0, 217.0], [1231.0, 521.0], [1061.0, 528.0]], [[1103.0, 570.0], [1149.0, 570.0], [1147.0, 989.0], [1100.0, 989.0]]], "lines": ["聲ｐ", "「こえのかたち"]}, {"box": [1451, 761, 2102, 1162], "vertical": false, "font_size": 32, "lines_coords": [[[1451.0, 761.0], [1855.0, 763.0], [1855.0, 807.0], [1451.0, 805.0]], [[1524.0, 867.0], [1960.0, 869.0], [1960.0, 909.0], [1524.0, 907.0]], [[1607.0, 812.0], [1820.0, 816.0], [1820.0, 847.0], [1607.0, 843.0]], [[1538.0, 918.0], [2035.0, 918.0], [2035.0, 949.0], [1538.0, 949.0]], [[1587.0, 974.0], [2039.0, 976.0], [2039.0, 1005.0], [1587.0, 1003.0]], [[1529.0, 1076.0], [1991.0, 1076.0], [1991.0, 1107.0], [1529.0, 1107.0]], [[1531.0, 1129.0], [2102.0, 1131.0], [2102.0, 1162.0], [1531.0, 1160.0]], [[1591.0, 1114.0], [1627.0, 1114.0], [1627.0, 1129.0], [1591.0, 1129.0]], [[1782.0, 954.0], [1857.0, 949.0], [1860.0, 974.0], [1784.0, 978.0]], [[1797.0, 1011.0], [2075.0, 1011.0], [2075.0, 1058.0], [1797.0, 1058.0]], [[1769.0, 1051.0], [1964.0, 1049.0], [1964.0, 1080.0], [1769.0, 1082.0]]], "lines": ["硝子を庇って大けがを負いつつ、", "前を向くと決めた硝子は、絶望の中", "眠り続ける将也", "壊してしまったものを取り戻そうと動き出す", "バラバラになった仲間たちの「こえ」に", "繋がる想い、そして、再開した映画作り", "時を刻み始めた彼らの世界に待ち受ける未来は", "・", "なか、まだ", "そっと耳を澄ませるー", "さいから、えいかつ、"]}, {"box": [1087, 1276, 1166, 1578], "vertical": true, "font_size": 68, "lines_coords": [[[1092.0, 1276.0], [1160.0, 1276.0], [1160.0, 1560.0], [1092.0, 1560.0]]], "lines": ["今良時"]}, {"box": [295, 1422, 765, 1547], "vertical": false, "font_size": 78, "lines_coords": [[[530.0, 1442.0], [730.0, 1442.0], [730.0, 1527.0], [530.0, 1527.0]]], "lines": ["良時"]}], "img_path": "001.png"}, {"version": "0.1.7", "img_width": 2273, "img_height": 1600, "blocks": [{"box": [488, 562, 520, 778], "vertical": true, "font_size": 31, "lines_coords": [[[488.0, 563.0], [519.0, 563.0], [519.0, 774.0], [488.0, 774.0]]], "lines": ["大今良時、作品"]}, {"box": [347, 537, 466, 1049], "vertical": true, "font_size": 34, "lines_coords": [[[423.0, 537.0], [466.0, 537.0], [466.0, 623.0], [423.0, 623.0]], [[390.0, 541.0], [419.0, 541.0], [419.0, 1049.0], [390.0, 1049.0]], [[355.0, 539.0], [384.0, 539.0], [384.0, 878.0], [355.0, 878.0]]], "lines": ["ＫＣＭ", "マルドッック・スクランブルー全７巻", "最作・沖方丁、漫画・大今良時"]}, {"box": [281, 539, 321, 772], "vertical": true, "font_size": 38, "lines_coords": [[[281.0, 539.0], [319.0, 539.0], [319.0, 772.0], [281.0, 772.0]]], "lines": ["夢の形、全７巻、"]}, {"box": [235, 1550, 555, 1581], "vertical": false, "font_size": 34, "lines_coords": [[[235.0, 1547.0], [555.0, 1547.0], [555.0, 1584.0], [235.0, 1584.0]]], "lines": ["〇〇年１２月６日（日）、高大学期１６：００"]}], "img_path": "002.png"}, {"version": "0.1.7", "img_width": 2241, "img_height": 1600, "blocks": [{"box": [1041, 232, 1177, 1010], "vertical": true, "font_size": 90, "lines_coords": [[[1118.0, 247.0], [1177.0, 253.0], [1166.0, 369.0], [1107.0, 363.0]], [[1041.0, 236.0], [1162.0, 236.0], [1168.0, 1000.0], [1048.0, 1000.0]]], "lines": ["．．．", "まあ、ここえらかたち"]}, {"box": [1081, 1213, 1157, 1568], "vertical": true, "font_size": 70, "lines_coords": [[[1085.0, 1216.0], [1155.0, 1216.0], [1157.0, 1558.0], [1087.0, 1558.0]]], "lines": ["大今良時"]}, {"box": [1490, 107, 1696, 212], "vertical": false, "font_size": 48, "lines_coords"