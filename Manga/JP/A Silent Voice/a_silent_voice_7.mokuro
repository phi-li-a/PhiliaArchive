5.0, 715.0], [604.0, 712.0]], [[604.0, 719.0], [951.0, 719.0], [951.0, 750.0], [604.0, 750.0]], [[607.0, 754.0], [962.0, 755.0], [962.0, 783.0], [607.0, 782.0]], [[604.0, 786.0], [780.0, 789.0], [780.0, 817.0], [604.0, 814.0]]], "lines": ["昨日あれからよく考えてみま", "した。", "実はちょっとだけ東京にあこ", "がれてた部分はあるんです。", "でもあこがれだけで行っちゃ", "駄目ですよね。"]}, {"box": [246, 456, 565, 486], "vertical": false, "font_size": 22, "lines_coords": [[[253.0, 460.0], [561.0, 458.0], [561.0, 480.0], [253.0, 481.0]]], "lines": ["いい、昨日はごめんなさい"]}, {"box": [248, 402, 427, 433], "vertical": false, "font_size": 26, "lines_coords": [[[248.0, 407.0], [427.0, 402.0], [427.0, 429.0], [248.0, 433.0]]], "lines": ["ｔｒｏｎ：西宮硝子"]}, {"box": [143, 541, 310, 561], "vertical": false, "font_size": 20, "lines_coords": [[[143.0, 541.0], [310.0, 541.0], [310.0, 561.0], [143.0, 561.0]]], "lines": ["原因で９人では、"]}, {"box": [136, 555, 508, 805], "vertical": false, "font_size": 30, "lines_coords": [[[139.0, 603.0], [499.0, 603.0], [499.0, 629.0], [139.0, 629.0]], [[141.0, 634.0], [500.0, 634.0], [500.0, 665.0], [141.0, 665.0]], [[143.0, 671.0], [292.0, 671.0], [292.0, 698.0], [143.0, 698.0]], [[141.0, 702.0], [500.0, 704.0], [500.0, 732.0], [141.0, 730.0]], [[141.0, 735.0], [503.0, 735.0], [503.0, 768.0], [141.0, 768.0]], [[136.0, 764.0], [508.0, 768.0], [508.0, 805.0], [136.0, 802.0]]], "lines": ["妹の事もあるし、私も家族や", "石田君達と離れそのは正直さ", "みしいです。", "資格ならどこに居ても取れる", "ので、東京じやなくて地元で", "チャレンジしてみますｐ（＾＾）ｑ"]}, {"box": [558, 1216, 586, 1338], "vertical": true, "font_size": 26, "lines_coords": [[[558.0, 1217.0], [584.0, 1217.0], [584.0, 1337.0], [558.0, 1337.0]]], "lines": ["あーらら"]}, {"box": [335, 1263, 374, 1413], "vertical": true, "font_size": 38, "lines_coords": [[[335.0, 1263.0], [373.0, 1263.0], [373.0, 1413.0], [335.0, 1413.0]]], "lines": ["おおう．．．"]}, {"box": [59, 1316, 119, 1531], "vertical": true, "font_size": 32, "lines_coords": [[[97.0, 1319.0], [119.0, 1319.0], [119.0, 1425.0], [97.0, 1425.0]], [[59.0, 1316.0], [102.0, 1316.0], [102.0, 1528.0], [59.0, 1528.0]]], "lines": ["ざいあくかん", "罪悪感が．．．"]}], "img_path": "138.png"}, {"version": "0.1.7", "img_width": 1040, "img_height": 1592, "blocks": [{"box": [794, 77, 942, 259], "vertical": true, "font_size": 37, "lines_coords": [[[900.0, 82.0], [942.0, 82.0], [942.0, 158.0], [900.0, 158.0]], [[850.0, 83.0], [882.0, 83.0], [882.0, 256.0], [850.0, 256.0]], [[794.0, 77.0], [831.0, 77.0], [834.0, 259.0], [797.0, 259.0]]], "lines": ["へー", "西宮さんが", "東京にねぇ"]}, {"box": [822, 399, 953, 578], "vertical": true, "font_size": 25, "lines_coords": [[[917.0, 399.0], [951.0, 399.0], [951.0, 480.0], [917.0, 480.0]], [[890.0, 402.0], [912.0, 402.0], [912.0, 551.0], [890.0, 551.0]], [[859.0, 401.0], [881.0, 401.0], [881.0, 578.0], [859.0, 578.0]], [[822.0, 399.0], [844.0, 399.0], [844.0, 551.0], [822.0, 551.0]]], "lines": ["行くの", "やめるなんて", "もったいないと", "思うけどねー"]}, {"box": [642, 489, 746, 598], "vertical": true, "font_size": 35, "lines_coords": [[[707.0, 491.0], [746.0, 491.0], [746.0, 548.0], [707.0, 548.0]], [[674.0, 489.0], [707.0, 489.0], [707.0, 598.0], [674.0, 598.0]], [[642.0, 492.0], [674.0, 492.0], [674.0, 575.0], [642.0, 575.0]]], "lines": ["もーんじ", "返事した", "のか？"]}, {"box": [520, 399, 548, 520], "vertical": true, "font_size": 29, "lines_coords": [[[520.0, 399.0], [548.0, 399.0], [548.0, 520.0], [520.0, 520.0]]], "lines": ["いやまだ"]}, {"box": [362, 447, 485, 578], "vertical": true, "font_size": 29, "lines_coords": [[[457.0, 447.0], [485.0, 447.0], [485.0, 555.0], [457.0, 555.0]], [[424.0, 450.0], [452.0, 450.0], [452.0, 578.0], [424.0, 578.0]], [[390.0, 450.0], [424.0, 450.0], [424.0, 531.0], [390.0, 531.0]], [[362.0, 452.0], [391.0, 452.0], [391.0, 528.0], [362.0, 528.0]]], "lines": ["どう返事", "していいか", "わから", "なくて"]}, {"box": [438, 624, 572, 777], "vertical": true, "font_size": 26, "lines_coords": [[[548.0, 628.0], [570.0, 628.0], [570.0, 777.0], [548.0, 777.0]], [[508.0, 624.0], [534.0, 624.0], [534.0, 777.0], [508.0, 777.0]], [[471.0, 624.0], [497.0, 624.0], [497.0, 750.0], [471.0, 75