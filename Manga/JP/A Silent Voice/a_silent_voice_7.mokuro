 1117.0], [443.0, 1117.0], [443.0, 1217.0], [404.0, 1217.0]]], "lines": ["緊張？"]}, {"box": [326, 1333, 416, 1490], "vertical": true, "font_size": 34, "lines_coords": [[[366.0, 1333.0], [405.0, 1333.0], [405.0, 1462.0], [366.0, 1462.0]], [[326.0, 1337.0], [355.0, 1337.0], [355.0, 1490.0], [326.0, 1490.0]]], "lines": ["実は俺も", "緊張してる"]}], "img_path": "189.png"}, {"version": "0.1.7", "img_width": 1040, "img_height": 1592, "blocks": [], "img_path": "190.png"}, {"version": "0.1.7", "img_width": 1056, "img_height": 1592, "blocks": [], "img_path": "191.png"}, {"version": "0.1.7", "img_width": 1056, "img_height": 1592, "blocks": [], "img_path": "192.png"}, {"version": "0.1.7", "img_width": 1040, "img_height": 1592, "blocks": [{"box": [59, 1538, 176, 1584], "vertical": false, "font_size": 46, "lines_coords": [[[59.0, 1538.0], [176.0, 1538.0], [176.0, 1584.0], [59.0, 1584.0]]], "lines": ["【おわり】"]}], "img_path": "193.png"}, {"version": "0.1.7", "img_width": 1040, "img_height": 1592, "blocks": [], "img_path": "194.png"}, {"version": "0.1.7", "img_width": 1040, "img_height": 1592, "blocks": [{"box": [125, 119, 848, 344], "vertical": false, "font_size": 23, "lines_coords": [[[125.0, 123.0], [710.0, 117.0], [710.0, 141.0], [125.0, 148.0]], [[129.0, 151.0], [848.0, 145.0], [848.0, 171.0], [129.0, 177.0]], [[133.0, 183.0], [206.0, 183.0], [206.0, 208.0], [133.0, 208.0]], [[132.0, 218.0], [610.0, 214.0], [610.0, 239.0], [132.0, 244.0]], [[130.0, 252.0], [579.0, 249.0], [579.0, 275.0], [130.0, 278.0]], [[127.0, 285.0], [674.0, 282.0], [674.0, 306.0], [127.0, 309.0]], [[129.0, 310.0], [679.0, 307.0], [679.0, 331.0], [129.0, 334.0]]], "lines": ["編集部では、この作品に対する皆様のご飯見ご感想をお待ちしております。", "また「講談社コミックス」にまとめてほしい作品がありましたら、編集部までお知らせください。", "〈あて先〉", "〒１２－８００１東京都文京区音羽２－１２－２１講談社", "週刊少年マガジン編集部少年マガジンＫＣＪ係", "なお、お送りいただいたお子様やおガキは、ご注文いただいた個人情報を含めて", "なお、お金が入ったことで一般的な教育にお越しすることがありますので、あらかじめじゃないで、これからもあらわしめご了解のうえ、お送りください。"]}, {"box": [129, 370, 732, 436], "vertical": false, "font_size": 21.0, "lines_coords": [[[129.0, 376.0], [732.0, 370.0], [732.0, 390.0], [129.0, 396.0]], [[129.0, 415.0], [536.0, 413.0], [536.0, 435.0], [129.0, 436.0]]], "lines": ["★この物語はフィクションであり、実在の人物や団体や出来事などとは一切関係ありません。", "作品初出／週刊少年マガジン２０１４年第２２号〜５１号"]}, {"box": [346, 587, 390, 612], "vertical": false, "font_size": 25, "lines_coords": [[[346.0, 587.0], [390.0, 587.0], [390.0, 612.0], [346.0, 612.0]]], "lines": ["かたち"]}, {"box": [240, 544, 659, 671], "vertical": false, "font_size": 39.333333333333336, "lines_coords": [[[272.0, 548.0], [659.0, 544.0], [659.0, 565.0], [272.0, 570.0]], [[256.0, 589.0], [309.0, 589.0], [309.0, 612.0], [256.0, 612.0]], [[240.0, 598.0], [432.0, 598.0], [432.0, 671.0], [240.0, 671.0]]], "lines": ["講談社コミック・スマガジンＫＣＭＥ２８", "こえ", "聲の形の"]}, {"box": [253, 726, 839, 750], "vertical": false, "font_size": 21, "lines_coords": [[[253.0, 729.0], [839.0, 726.0], [839.0, 747.0], [253.0, 750.0]]], "lines": ["２０１４年１２月１７日第１期発行（定価は外取り》一ルに表示してあります）"]}, {"box": [250, 819, 326, 853], "vertical": false, "font_size": 34, "lines_coords": [[[250.0, 819.0], [326.0, 819.0], [326.0, 853.0], [250.0, 853.0]]], "lines": ["著者"]}, {"box": [250, 979, 328, 1044], "vertical": false, "font_size": 32, "lines_coords": [[[253.0, 979.0], [323.0, 979.0], [323.0, 1007.0], [253.0, 1007.0]], [[250.0, 1008.0], [328.0, 1008.0], [328.0, 1044.0], [250.0, 1044.0]]], "lines": ["発行者", "発行所"]}, {"box": [394, 799, 579, 879], "vertical": false, "font_size": 24.333333333333332, "lines_coords": [[[394.0, 799.0], [522.0, 799.0], [522.0, 819.0], [394.0, 819.0]], [[396.0, 819.0], [522.0, 816.0], [522.0, 847.0], [396.0, 850.0]], [[396.0, 858.0], [579.0, 856.0], [579.0, 878.0], [396.0, 879.0]]], "lines": ["おおいまよしとき", "大今良時", "＠ｙｏｓｈｉｔｏｋｉｃｙｉｎａ．２０１４"]}, {"box": [393, 977, 789, 1111], "vertical": false, "font_size": 27.25, "lines_coords": [[[394.0, 977.0], [488.0, 977.0], [488.0, 1005.0], [394.0, 1005.0]], [[394.0, 1012.0], [570.0, 1008.0], [570.0, 1036.0], [394.0, 1040.0]], [[399.0, 1047.0], [789.0, 1047.0], [789.0, 1074.0], [399.0, 1074.0]], [[393.0, 1085.0], [780.0, 1082.0], [780.0, 1108.0], [393.0, 1111.0]]], "lines": ["清水保雅", "株式会社講談社", "〒１２－８００１東京都文京区音羽２－１２－２１", "電話番号編集部東京（０３）５３５５－３５９"]}, {"box": [500, 1116, 780, 1181], "vertical": false, "font_size": 26.0, "lines_coords": [[[500.0, 1119.0], [780.0, 1116.0], [780.0, 1142.0], [500.0, 1145.0]], [[500.0, 1155.0], [780.0, 1152.0], [780.0, 1178.0], [500.0, 1181.0]]], "lines": ["販売部、東京（ＧＴ）で３５５－３６ＫＡ", "業務部、東京（６０）で３５５－３６６８"]}, {"box": [139, 1478, 536, 1500], "vertical": false, "font_size": 22, "lines_coords": [[[139.0, 1478.0], [536.0, 1478.0], [536.0, 1500.0], [139.0, 1500.0]]], "lines": ["ＮＤ．Ｃ．７２６．１９ＬｐＴ＆ｃｏｎ．ｐｒｉｎｃｔｉｍ．ｊｐ．ｊａｐａｎ"]}, {"box": [254, 1194, 628, 1290], "vertical": false, "font_size": 26.666666666666668, "lines_coords": [[[258.0, 1194.0], [324.0, 1194.0], [324.0, 1217.0], [258.0, 1217.0]], [[254.0, 1226.0], [628.0, 1226.0], [628.0, 1253.0], [254.0, 1253.0]], [[254.0, 1260.0], [328.0, 1260.0], [328.0, 1290.0], [254.0, 1290.0]]], "lines": ["印刷所", "本文製版所株式会社二葉写真製版", "製本所"]}, {"box": [394, 1190, 559, 1217], "vertical": false, "font_size": 27, "lines_coords": [[[394.0, 1190.0], [559.0, 1190.0], [559.0, 1217.0], [394.0, 1217.0]]], "lines": ["株式会社廣済堂"]}, {"box": [365, 1257, 651, 1287], "vertical": false, "font_size": 27, "lines_coords": [[[365.0, 1260.0], [651.0, 1257.0], [651.0, 1284.0], [365.0, 1287.0]]], "lines": ["株式会社フォーネット社"]}, {"box": [135, 1309, 893, 1448], "vertical": false, "font_size": 20.4, "lines_coords": [[[141.0, 1315.0], [847.0, 1309.0], [847.0, 1329.0], [141.0, 1335.0]], [[152.0, 1343.0], [887.0, 1337.0], [887.0, 1357.0], [152.0, 1363.0]], [[152.0, 1371.0], [292.0, 1369.0], [292.0, 1391.0], [152.0, 1393.0]], [[135.0, 1400.0], [887.0, 1394.0], [887.0, 1414.0], [135.0, 1420.0]], [[152.0, 1428.0], [893.0, 1422.0], [893.0, 1442.0], [152.0, 1448.0]]], "lines": ["●本当のコピースキャンデジタル化等の無断複製は著作権法上、での例外を除き禁じられています。", "本書を代行業者等の第三者に依頼してスキャンやデジタル化すみさまはこえ個人で家庭はの利用でも", "著作権法違反です。", "●第丁本乱丁本は購入書店名をご記入のうえ、小社業務部社にお送りください。送料小社負担にてお取り", "替えいたします。なお、この本についこのお期い合わせは週刊少年マガジシ編集部宛にお願いいたします。"]}, {"box": [673, 1469, 917, 1499], "vertical": false, "font_size": 22, "lines_coords": [[[674.0, 1473.0], [914.0, 1471.0], [914.0, 1496.0], [674.0, 1497.0]]], "lines": ["ＥＥＢＮ９７８－４－０６－３Ｓ５２６８－１"]}], "img_path": "195.png"}, {"version": "0.1.7", "img_width": 1040, "img_height": 1592, "blocks": [], "img_path": "196.png"}, {"version": "0.1.7", "img_width": 2337, "img_height": 1632, "blocks": [{"box": [4, 27, 92, 547], "vertical": true, "font_size": 40, "lines_coords": [[[52.0, 34.0], [91.0, 34.0], [91.0, 262.0], [52.0, 262.0]], [[6.0, 27.0], [47.0, 27.0], [45.0, 540.0], [4.0, 540.0]]], "lines": ["今読むべき！", "２００６年間以上を徹底ガイド"]}, {"box": [836, 19, 1132, 114], "vertical": false, "font_size": 28, "lines_coords": [[[956.0, 20.0], [1017.0, 20.0], [1017.0, 47.0], [956.0, 47.0]], [[851.0, 48.0], [1120.0, 48.0], [1120.0, 75.0], [851.0, 75.0]], [[846.0, 73.0], [1122.0, 75.0], [1122.0, 111.0], [846.0, 109.0]]], "lines": ["第５回", "このマンガストンリスは、", "私受賞作を大人間した"]}, {"box": [162, 255, 477, 582], "vertical": false, "font_size": 103, "lines_coords": [[[171.0, 296.0], [426.0, 255.0], [442.0, 358.0], [187.0, 399.0]], [[196.0, 358.0], [461.0, 353.0], [463.0, 461.0], [198.0, 465.0]], [[203.0, 477.0], [451.0, 442.0], [465.0, 540.0], [216.0, 575.0]]], "lines": ["今年の", "ミストＩＯ", "決まる！"]}, {"box": [162, 796, 969, 833], "vertical": false, "font_size": 32, "lines_coords": [[[162.0, 801.0], [969.0, 796.0], [969.0, 828.0], [162.0, 833.0]]], "lines": ["マンガ好きが本音で選ぶ最強マンガガイド！"]}, {"box": [802, 490, 1118, 558], "vertical": false, "font_size": 30, "lines_coords": [[[965.0, 488.0], [1109.0, 491.0], [1109.0, 520.0], [965.0, 517.0]], [[810.0, 516.0], [1113.0, 516.0], [1113.0, 552.0], [810.0, 552.0]]], "lines": ["本体５２０円＋税", "このマンガがすごい。編集部編"]}, {"box": [20, 1108, 195, 1140], "vertical": false, "font_size": 27, "lines_coords": [[[27.0, 1111.0], [187.0, 1111.0], [187.0, 1140.0], [27.0, 1140.0]]], "lines": ["あの人に聞く！"]}, {"box": [634, 1106, 1111, 1141], "vertical": false, "font_size": 35, "lines_coords": [[[634.0, 1106.0], [1086.0, 1104.0], [1086.0, 1141.0], [634.0, 1144.0]]], "lines": ["総勢３３名、人気漫画家からのコメントに"]}, {"box": [975, 909, 1128, 984], "vertical": false, "font_size": 82, "lines_coords": [[[975.0, 902.0], [1128.0, 902.0], [1128.0, 991.0], [975.0, 991.0]]], "lines": ["２０１５"]}, {"box": [9, 1149, 347, 1304], "vertical": false, "font_size": 23, "lines_coords": [[[15.0, 1161.0], [335.0, 1161.0], [335.0, 1184.0], [15.0, 1184.0]], [[15.0, 1196.0], [255.0, 1196.0], [255.0, 1218.0], [15.0, 1218.0]], [[15.0, 1234.0], [255.0, 1234.0], [255.0, 1257.0], [15.0, 1257.0]], [[18.0, 1271.0], [324.0, 1271.0], [324.0, 1294.0], [18.0, 1294.0]]], "lines": ["阿久違楯大郎小島瑠璃っ", "平井限中、吉田坂は", "成瀬猫美でんば組ｉｎｃ", "由村佑介ヒャダイン．．．はぁ"]}, {"box": [5, 1584, 109, 1617], "vertical": false, "font_size": 27, "lines_coords": [[[11.0, 1586.0], [104.0, 1586.0], [104.0, 1615.0], [11.0, 1615.0]]], "lines": ["宝島社"]}, {"box": [636, 1317, 919, 1346], "vertical": false, "font_size": 27, "lines_coords": [[[636.0, 1317.0], [919.0, 1317.0], [919.0, 1346.0], [636.0, 1346.0]]], "lines": ["悪の華・押見修造．．ほか"]}, {"box": [636, 1200, 1056, 1266], "vertical": false, "font_size": 27, "lines_coords": [[[636.0, 1200.0], [1056.0, 1200.0], [1056.0, 1223.0], [636.0, 1223.0]], [[636.0, 1237.0], [949.0, 1237.0], [949.0, 1266.0], [636.0, 1266.0]]], "lines": ["ときめきトゥナ介真壁俊の事情・池野で", "しかくかくしかしか東村アキコ"]}, {"box": [631, 1152, 1134, 1347], "vertical": false, "font_size": 29, "lines_coords": [[[632.0, 1155.0], [1127.0, 1155.0], [1127.0, 1188.0], [632.0, 1188.0]], [[632.0, 1276.0], [1122.0, 1273.0], [1122.0, 1303.0], [632.0, 1305.0]]], "lines": ["『さよならソルシェ『穂積』『七つの大罪』鈴木央", "『機動戦士ガンダムサンダーボルト大田垣康男"]}, {"box": [636, 1374, 1113, 1408], "vertical": false, "font_size": 30, "lines_coords": [[[636.0, 1378.0], [1113.0, 1374.0], [1113.0, 1403.0], [636.0, 1408.0]]], "lines": ["インタビュー＆本書特別カラー描きおろし！"]}, {"box": [545, 1424, 1124, 1625], "vertical": false, "font_size": 49, "lines_coords": [[[625.0, 1424.0], [1065.0, 1431.0], [1065.0, 1501.0], [625.0, 1495.0]], [[625.0, 1508.0], [1118.0, 1508.0], [1118.0, 1554.0], [625.0, 1554.0]], [[641.0, 1554.0], [1106.0, 1570.0], [1104.0, 1625.0], [639.0, 1609.0]], [[547.0, 1547.0], [643.0, 1554.0], [641.0, 1579.0], [545.0, 1572.0]]], "lines": ["「聲の形」大泉時齢協", "「ちーちゃんはちょっと", "足りない｀］阿部共実「第１６", "．．．"]}, {"box": [1295, 155, 1555, 194], "vertical": false, "font_size": 25, "lines_coords": [[[1307.0, 164.0], [1547.0, 164.0], [1547.0, 191.0], [1307.0, 191.0]]], "lines": ["９７８４８０００円２３５８２４"]}, {"box": [1301, 319, 1555, 358], "vertical": false, "font_size": 33, "lines_coords": [[[1307.0, 325.0], [1549.0, 325.0], [1549.0, 361.0], [1307.0, 361.0]]], "lines": ["１９８０年１１月２６日（金曜）１９２００７６年０５月"]}, {"box": [1638, 76, 1967, 131], "vertical": false, "font_size": 22, "lines_coords": [[[1643.0, 82.0], [1958.0, 82.0], [1958.0, 104.0], [1643.0, 104.0]]], "lines": ["ＳＢＮ９７８－４８００２．３５８２－４"]}, {"box": [1633, 74, 1973, 133], "vertical": false, "font_size": 25, "lines_coords": [[[1643.0, 107.0], [1814.0, 107.0], [1814.0, 134.0], [1643.0, 134.0]]], "lines": ["ＣＯＯ７６¥５２０Ｅ"]}, {"box": [1634, 236, 2023, 359], "vertical": false, "font_size": 29, "lines_coords": [[[1640.0, 235.0], [1873.0, 235.0], [1873.0, 269.0], [1640.0, 269.0]], [[1643.0, 271.0], [1711.0, 271.0], [1711.0, 301.0], [1643.0, 301.0]], [[1640.0, 308.0], [1844.0, 310.0], [1844.0, 337.0], [1640.0, 335.0]], [[1638.0, 324.0], [2012.0, 324.0], [2012.0, 358.0], [1638.0, 358.0]]], "lines": ["定価：本体５２０円＋税", "宝島社", "「塾の形」Ｑ大今良時／講談社「たーたちとはちょっと足りない」", "壁のある大丈夫寺院／講義社にサーチャんはちょっと足になり、１９時間半時まで"]}, {"box": [1637, 237, 2020, 359], "vertical": false, "font_size": 122, "lines_coords": [[[1637.0, 237.0], [2020.0, 237.0], [2020.0, 359.0], [1637.0, 359.0]]], "lines": ["定価「本体５０円」中税宝島社株のみの大きさまではないと思いますので、"]}, {"box": [1814, 527, 2008, 566], "vertical": false, "font_size": 39, "lines_coords": [[[1814.0, 527.0], [2008.0, 527.0], [2008.0, 566.0], [1814.0, 566.0]]], "lines": ["２０１４年度"]}, {"box": [1602, 518, 1761, 1332], "vertical": true, "font_size": 74, "lines_coords": [[[1691.0