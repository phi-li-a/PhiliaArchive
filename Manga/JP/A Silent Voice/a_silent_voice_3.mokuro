], [[819.0, 1315.0], [841.0, 1315.0], [841.0, 1407.0], [819.0, 1407.0]]], "lines": ["あの看板", "すげー．．．"]}], "img_path": "021.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1600, "blocks": [{"box": [148, 265, 275, 335], "vertical": false, "font_size": 16.25, "lines_coords": [[[148.0, 285.0], [222.0, 265.0], [226.0, 281.0], [153.0, 301.0]], [[154.0, 295.0], [222.0, 276.0], [226.0, 292.0], [159.0, 310.0]], [[153.0, 307.0], [222.0, 289.0], [226.0, 304.0], [157.0, 323.0]], [[157.0, 320.0], [270.0, 287.0], [275.0, 303.0], [162.0, 335.0]]], "lines": ["いやああはっはぁっはああっ！！", "かなわかったのかわいつかでましたか？そういうこと", "今日はありがとうございますけど．．．", "今日は通りほしい。石田君が結婚される所にしてあっては"]}, {"box": [172, 351, 250, 393], "vertical": false, "font_size": 13.0, "lines_coords": [[[172.0, 354.0], [197.0, 351.0], [198.0, 362.0], [173.0, 365.0]], [[175.0, 370.0], [225.0, 351.0], [229.0, 362.0], [179.0, 381.0]], [[172.0, 378.0], [245.0, 359.0], [250.0, 375.0], [176.0, 393.0]]], "lines": ["．．．", "俺だけど？？", "お客さん！！お答えを考えてみたのね"]}, {"box": [320, 141, 391, 312], "vertical": true, "font_size": 30, "lines_coords": [[[359.0, 143.0], [390.0, 143.0], [390.0, 312.0], [359.0, 312.0]], [[320.0, 143.0], [348.0, 143.0], [348.0, 282.0], [320.0, 282.0]]], "lines": ["あ．．．メール！？", "永束君．．．？"]}, {"box": [53, 335, 132, 535], "vertical": true, "font_size": 30, "lines_coords": [[[87.0, 340.0], [120.0, 340.0], [120.0, 467.0], [87.0, 467.0]], [[56.0, 335.0], [84.0, 335.0], [81.0, 532.0], [53.0, 532.0]]], "lines": ["いや誰だ", "このメアド．．．？"]}, {"box": [268, 418, 317, 442], "vertical": false, "font_size": 13, "lines_coords": [[[268.0, 429.0], [314.0, 418.0], [317.0, 431.0], [272.0, 442.0]]], "lines": ["うたんだっけ？"]}, {"box": [642, 632, 866, 820], "vertical": false, "font_size": 97, "lines_coords": [[[642.0, 737.0], [816.0, 632.0], [866.0, 715.0], [692.0, 820.0]]], "lines": ["したか"]}, {"box": [325, 737, 683, 1014], "vertical": false, "font_size": 119, "lines_coords": [[[325.0, 910.0], [623.0, 737.0], [683.0, 840.0], [384.0, 1014.0]]], "lines": ["つかれまし"]}, {"box": [65, 1253, 209, 1453], "vertical": true, "font_size": 36, "lines_coords": [[[165.0, 1315.0], [204.0, 1315.0], [204.0, 1371.0], [165.0, 1371.0]], [[117.0, 1331.0], [150.0, 1331.0], [150.0, 1371.0], [117.0, 1371.0]]], "lines": ["・", "。"]}], "img_path": "022.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1600, "blocks": [{"box": [584, 131, 910, 292], "vertical": false, "font_size": 49, "lines_coords": [[[587.0, 134.0], [841.0, 131.0], [841.0, 168.0], [587.0, 171.0]], [[587.0, 168.0], [866.0, 162.0], [866.0, 206.0], [587.0, 212.0]], [[584.0, 203.0], [864.0, 193.0], [866.0, 246.0], [586.0, 256.0]], [[584.0, 232.0], [910.0, 232.0], [910.0, 292.0], [584.0, 292.0]]], "lines": ["今日はありがとう。", "石田君が佐原さんを", "探してるって聞いていて", "ふしくる人間とても嬉しかったです。"]}, {"box": [480, 300, 539, 310], "vertical": false, "font_size": 10, "lines_coords": [[[480.0, 300.0], [539.0, 300.0], [539.0, 310.0], [480.0, 310.0]]], "lines": ["サハ３ほ５～"]}, {"box": [472, 714, 723, 814], "vertical": false, "font_size": 34, "lines_coords": [[[475.0, 717.0], [678.0, 714.0], [678.0, 746.0], [475.0, 750.0]], [[472.0, 743.0], [723.0, 743.0], [723.0, 785.0], [472.0, 785.0]], [[478.0, 785.0], [625.0, 785.0], [625.0, 814.0], [478.0, 814.0]]], "lines": ["実は今日、妹から", "もっと嬉しいことを", "聞きました。"]}, {"box": [406, 1104, 655, 1167], "vertical": false, "font_size": 24, "lines_coords": [[[406.0, 1106.0], [627.0, 1106.0], [627.0, 1132.0], [406.0, 1132.0]], [[409.0, 1142.0], [648.0, 1142.0], [648.0, 1164.0], [409.0, 1164.0]]], "lines": ["妹が家出した時に", "助けてもらったこと"]}, {"box": [131, 1290, 380, 1364], "vertical": false, "font_size": 38, "lines_coords": [[[131.0, 1290.0], [347.0, 1290.0], [347.0, 1328.0], [131.0, 1328.0]], [[132.0, 1326.0], [375.0, 1326.0], [375.0, 1364.0], [132.0, 1364.0]]], "lines": ["妹と一緒に私を", "探してくれたこと"]}], "img_path": "023.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1600, "blocks": [{"box": [678, 93, 928, 195], "vertical": false, "font_size": 52, "lines_coords": [[[684.0, 96.0], [861.0, 93.0]