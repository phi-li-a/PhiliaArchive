: 22, "lines_coords": [[[87.0, 42.0], [156.0, 42.0], [156.0, 64.0], [87.0, 64.0]]], "lines": ["．．．"]}, {"box": [10, 96, 157, 125], "vertical": false, "font_size": 22, "lines_coords": [[[10.0, 96.0], [157.0, 103.0], [157.0, 125.0], [10.0, 118.0]]], "lines": ["あははは．．．おはようございます。それでもそれ以外の人たちは、これではないのかもしれないというわけです。"]}, {"box": [540, 505, 672, 942], "vertical": true, "font_size": 114, "lines_coords": [[[548.0, 603.0], [662.0, 607.0], [656.0, 771.0], [542.0, 767.0]]], "lines": ["無理"]}, {"box": [338, 534, 500, 1199], "vertical": true, "font_size": 162, "lines_coords": [[[338.0, 534.0], [500.0, 534.0], [500.0, 1199.0], [338.0, 1199.0]]], "lines": ["未来と１週天"]}, {"box": [270, 1229, 1088, 1600], "vertical": false, "font_size": 79, "lines_coords": [[[946.0, 1348.0], [966.0, 1348.0], [966.0, 1373.0], [946.0, 1373.0]], [[913.0, 1345.0], [946.0, 1345.0], [946.0, 1378.0], [913.0, 1378.0]], [[842.0, 1329.0], [938.0, 1329.0], [938.0, 1437.0], [842.0, 1437.0]], [[770.0, 1389.0], [872.0, 1389.0], [872.0, 1428.0], [770.0, 1428.0]], [[725.0, 1343.0], [756.0, 1350.0], [745.0, 1401.0], [714.0, 1395.0]], [[714.0, 1395.0], [748.0, 1395.0], [748.0, 1421.0], [714.0, 1421.0]], [[686.0, 1343.0], [727.0, 1343.0], [727.0, 1429.0], [686.0, 1429.0]], [[662.0, 1473.0], [705.0, 1473.0], [705.0, 1489.0], [662.0, 1489.0]], [[645.0, 1520.0], [759.0, 1520.0], [759.0, 1537.0], [645.0, 1537.0]], [[551.0, 1426.0], [578.0, 1426.0], [578.0, 1445.0], [551.0, 1445.0]], [[411.0, 1326.0], [713.0, 1326.0], [713.0, 1426.0], [411.0, 1426.0]], [[409.0, 1348.0], [439.0, 1348.0], [439.0, 1400.0], [409.0, 1400.0]], [[403.0, 1390.0], [697.0, 1387.0], [697.0, 1429.0], [403.0, 1432.0]], [[415.0, 1521.0], [430.0, 1521.0], [430.0, 1539.0], [415.0, 1539.0]], [[403.0, 1487.0], [1003.0, 1481.0], [1003.0, 1518.0], [403.0, 1525.0]], [[334.0, 1229.0], [1088.0, 1251.0], [1078.0, 1573.0], [325.0, 1551.0]], [[270.0, 1246.0], [1083.0, 1237.0], [1088.0, 1600.0], [275.0, 1600.0]]], "lines": ["し", "す", "気まずと将也。", "硝子と", "すっ", "続", "がが", "うえ。", "ふたた．．．ちょくめん", "あそ", "子に避けられている気が以降、ぎこちない関係が", "子ぃ", "以降、ぎこちない関係", "ゴー", "誘ってみる。そこで植野をはじめとする小学校", "これからもういっているのですが、これまではありませんが、私の顔を見つけることができるのだろうか。", "今回は、これからのお客さんがお客様においておりますので、ご利用いただきました。これまでお願いしましょうかもしれません。"]}], "img_path": "192.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1600, "blocks": [{"box": [35, 109, 516, 272], "vertical": false, "font_size": 92, "lines_coords": [[[35.0, 101.0], [516.0, 101.0], [516.0, 233.0], [35.0, 233.0]], [[60.0, 207.0], [508.0, 207.0], [508.0, 276.0], [60.0, 276.0]]], "lines": ["西宮さんが来なければみんなハッピーだった。", "「Ｍｉさんがんなければみんなハッピーだった」"]}, {"box": [808, 605, 986, 1070], "vertical": true, "font_size": 161, "lines_coords": [[[808.0, 692.0], [969.0, 679.0], [986.0, 903.0], [825.0, 915.0]]], "lines": ["まずは"]}, {"box": [-24, 1385, 976, 1593], "vertical": false, "font_size": 103, "lines_coords": [[[39.0, 1380.0], [969.0, 1376.0], [969.0, 1469.0], [39.0, 1473.0]], [[128.0, 1466.0], [892.0, 1472.0], [892.0, 1599.0], [128.0, 1596.0]]], "lines": ["あの日の傷が生え出すのは．．．！？", "今度、２０１６年９月１７日（火）発売予定"]}], "img_path": "193.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1600, "blocks": [{"box": [101, 132, 824, 339], "vertical": false, "font_size": 21, "lines_coords": [[[104.0, 132.0], [688.0, 130.0], [688.0, 152.0], [104.0, 153.0]], [[109.0, 160.0], [824.0, 160.0], [824.0, 180.0], [109.0, 180.0]], [[109.0, 187.0], [181.0, 187.0], [181.0, 214.0], [109.0, 214.0]], [[109.0, 221.0], [584.0, 221.0], [584.0, 245.0], [109.0, 245.0]], [[106.0, 257.0], [556.0, 255.0], [556.0, 281.0], [106.0, 283.0]], [[106.0, 291.0], [648.0, 291.0], [648.0, 311.0], [106.0, 311.0]], [[106.0, 316.0], [652.0, 316.0], [652.0, 336.0], [106.0, 336.0]]], "lines": ["編集部では、この作品に対する皆様のご意見・ご感想をお待ちしております。", "また「調査社コミックスにまとめでほしい作品がありましたら、編集部までお知らせください。", "〈あて先〉", "〒１１２－８００１東京都文京区音羽２－１２－２１．講談化", "週刊少年マガジン編集部少年マガジンＫＣ＿係", "なお、お送りいただいたお手紙をおハガキは、ご記入いただいた個人情報を含めて", "著者にお渡しすることがあります。すので、あらかじめご了解のうえ、お送りください。"]}, {"box": [190, 509, 292, 520], "vertical": false, "font_size": 11, "lines_coords": [[[190.0, 509.0], [292.0, 509.0], [292.0, 520.0], [190.0, 520.0]]], "lines": ["Ｍｉｌｄｏｔｓｋｆ－４００"]}, {"box": [211, 589, 404, 675], "vertical": false, "font_size": 52.0, "lines_coords": [[[304.0, 589.0], [362.0, 589.0], [362.0, 618.0], [304.0, 618.0]], [[211.0, 600.0], [404.0, 600.0], [404.0, 675.0], [211.0, 675.0]]], "lines": ["かたち", "聲の形３"]}, {"box": [106, 378, 708, 440], "vertical": false, "font_size": 23, "lines_coords": [[[106.0, 377.0], [708.0, 377.0], [708.0, 402.0], [106.0, 402.0]], [[106.0, 416.0], [578.0, 416.0], [578.0, 441.0], [106.0, 441.0]]], "lines": ["★この時間はフィクションであり、僕たちの大学研修・小学校などとは一切関係ありません。", "作品初出／週刊少年マガジン２０１３年第５１号〜２０日（午前９時"]}, {"box": [225, 550, 634, 576], "vertical": false, "font_size": 26, "lines_coords": [[[225.0, 550.0], [634.0, 550.0], [634.0, 576.0], [225.0, 576.0]]], "lines": ["講談社コミックスマガジンＫＯＷ５０３６"]}, {"box": [377, 621, 400, 655], "vertical": true, "font_size": 23, "lines_coords": [[[377.0, 621.0], [400.0, 621.0], [400.0, 655.0], [377.0, 655.0]]], "lines": ["？"]}, {"box": [226, 732, 814, 756], "vertical": false, "font_size": 21, "lines_coords": [[[226.0, 732.0], [814.0, 735.0], [814.0, 756.0], [226.0, 753.0]]], "lines": ["２０１４年３月１７日第１期発行・定価は外取りシーールに表示してあります）"]}, {"box": [223, 827, 294, 855], "vertical": false, "font_size": 24, "lines_coords": [[[223.0, 829.0], [259.0, 829.0], [259.0, 853.0], [223.0, 853.0]], [[262.0, 829.0], [293.0, 829.0], [293.0, 854.0], [262.0, 854.0]]], "lines": ["著者", "者"]}, {"box": [220, 986, 295, 1051], "vertical": false, "font_size": 28, "lines_coords": [[[226.0, 987.0], [292.0, 987.0], [292.0, 1010.0], [226.0, 1010.0]], [[220.0, 1017.0], [295.0, 1017.0], [295.0, 1051.0], [220.0, 1051.0]]], "lines": ["発行者", "発行所"]}, {"box": [347, 804, 570, 889], "vertical": false, "font_size": 23, "lines_coords": [[[365.0, 804.0], [492.0, 804.0], [492.0, 825.0], [365.0, 825.0]], [[367.0, 828.0], [492.0, 828.0], [492.0, 856.0], [367.0, 856.0]], [[365.0, 865.0], [551.0, 865.0], [551.0, 885.0], [365.0, 885.0]]], "lines": ["お