{"version": "0.2.0-beta.6", "title": "A Silent Voice", "title_uuid": "0ef04b72-4228-48b1-ba08-9674badb458b", "volume": "a_silent_voice_3", "volume_uuid": "38f1ba7b-2ced-4489-b66c-746adbbfc1e0", "pages": [{"version": "0.1.7", "img_width": 2272, "img_height": 1600, "blocks": [{"box": [1914, 18, 2227, 49], "vertical": false, "font_size": 18, "lines_coords": [[[1921.0, 24.0], [2216.0, 24.0], [2216.0, 44.0], [1921.0, 44.0]]], "lines": ["１５日Ｎ９７８－４－０６．３９５０３６－６"]}, {"box": [1723, 499, 2176, 611], "vertical": false, "font_size": 42, "lines_coords": [[[1723.0, 499.0], [1928.0, 503.0], [1928.0, 550.0], [1723.0, 545.0]], [[1737.0, 565.0], [2167.0, 565.0], [2167.0, 603.0], [1737.0, 603.0]]], "lines": ["「怖いのか？", "西宮のことを知るのが"]}, {"box": [1728, 665, 2117, 795], "vertical": false, "font_size": 29, "lines_coords": [[[1728.0, 667.0], [2012.0, 667.0], [2012.0, 696.0], [1728.0, 696.0]], [[1730.0, 714.0], [2107.0, 714.0], [2107.0, 743.0], [1730.0, 743.0]], [[1730.0, 763.0], [1990.0, 763.0], [1990.0, 792.0], [1730.0, 792.0]]], "lines": ["かつて、奪ってしまった", "硝子の幸せを取り戻すために", "皆さると決めた将也"]}, {"box": [1721, 847, 2170, 947], "vertical": false, "font_size": 36, "lines_coords": [[[1721.0, 852.0], [2019.0, 847.0], [2019.0, 894.0], [1721.0, 898.0]], [[1723.0, 909.0], [2158.0, 905.0], [2158.0, 943.0], [1723.0, 947.0]], [[1879.0, 889.0], [2007.0, 892.0], [2007.0, 914.0], [1879.0, 912.0]]], "lines": ["硝子のために、将也は", "断ち切ったはずの過去と向き合う", "はぁ、はぁ．．．"]}, {"box": [1724, 994, 2034, 1141], "vertical": false, "font_size": 26, "lines_coords": [[[1901.0, 994.0], [1963.0, 994.0], [1963.0, 1016.0], [1901.0, 1016.0]], [[1735.0, 998.0], [1781.0, 998.0], [1781.0, 1014.0], [1735.0, 1014.0]], [[1726.0, 1011.0], [1990.0, 1014.0], [1990.0, 1045.0], [1726.0, 1042.0]], [[1728.0, 1060.0], [2023.0, 1058.0], [2023.0, 1089.0], [1728.0, 1091.0]], [[1730.0, 1111.0], [1912.0, 1111.0], [1912.0, 1140.0], [1730.0, 1140.0]]], "lines": ["さい、かい", "はう、ゆう", "旧友たちとの再会は", "将也と硝子の関係にも", "変化をもたらし"]}, {"box": [1066, 0, 1186, 31], "vertical": false, "font_size": 34, "lines_coords": [[[1066.0, 0.0], [1186.0, 0.0], [1186.0, 34.0], [1066.0, 34.0]]], "lines": ["ＫＣＭＩＳＯＳ６"]}, {"box": [115, 8, 875, 286], "vertical": false, "font_size": 162, "lines_coords": [[[177.0, 124.0], [352.0, 124.0], [352.0, 286.0], [177.0, 286.0]]], "lines": ["この"]}, {"box": [1045, 216, 1183, 1057], "vertical": true, "font_size": 138, "lines_coords": [[[1045.0, 216.0], [1183.0, 216.0], [1183.0, 1057.0], [1045.0, 1057.0]]], "lines": ["昔の形にあなたの"]}, {"box": [1000, 197, 1233, 1604], "vertical": true, "font_size": 213, "lines_coords": [[[1020.0, 197.0], [1233.0, 199.0], [1213.0, 1604.0], [1000.0, 1602.0]]], "lines": ["聲の形に入ってるのは今度は、"]}, {"box": [307, 1433, 746, 1541], "vertical": false, "font_size": 97, "lines_coords": [[[452.0, 1436.0], [729.0, 1430.0], [732.0, 1534.0], [454.0, 1541.0]]], "lines": ["今良時"]}, {"box": [352, 1553, 665, 1575], "vertical": false, "font_size": 22, "lines_coords": [[[352.0, 1553.0], [665.0, 1553.0], [665.0, 1575.0], [352.0, 1575.0]]], "lines": ["これのＮＥＮＭＡＧＡＺＩＮＥＣＯＭＩＣ"]}], "img_path": "001.png"}, {"version": "0.1.7", "img_width": 2256, "img_height": 1600, "blocks": [{"box": [1079, 663, 1172, 1560], "vertical": true, "font_size": 84, "lines_coords": [[[1088.0, 663.0], [1172.0, 663.0], [1163.0, 1560.0], [1079.0, 1560.0]]], "lines": ["こえるなら、つの「大今良時"]}], "img_path": "002.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1600, "blocks": [{"box": [511, 307, 750, 334], "vertical": false, "font_size": 27, "lines_coords": [[[511.0, 307.0], [750.0, 307.0], [750.0, 334.0], [511.0, 334.0]]], "lines": ["その分たち"]}, {"box": [364, 1426, 697, 1553], "vertical": false, "font_size": 105, "lines_coords": [[[462.0, 1426.0], [697.0, 1448.0], [688.0, 1553.0], [453.0, 1531.0]]], "lines": ["今良時"]}], "img_path": "003.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1600, "blocks": [{"box": [492, 550, 850, 580], "vertical": false, "font_size": 24, "lines_coords": [[[500.0, 551.0], [811.0, 551.0], [811.0, 577.0], [500.0, 577.0]]], "lines": ["俺じゃ、ちゃんちゃっ、ちょっと"]}, {"box": [90, 864, 458, 896], "vertical": false, "font_size": 32, "lines_coords": [[[90.0, 864.0], [458.0, 864.0], [458.0, 896.0], [90.0, 896.0]]], "lines": ["ｃｏＮＴＥＮＴＳ"]}, {"box": [475, 989, 508, 1209], "vertical": true, "font_size": 33, "lines_coords": [[[475.0, 989.0], [508.0, 989.0], [508.0, 1209.0], [475.0, 1209.0]]], "lines": ["３．３３．１８"]}, {"box": [0, 860, 545, 1587], "vertical": true, "font_size": 259, "lines_coords": [[[106.0, 973.0], [537.0, 964.0], [545.0, 1309.0], [114.0, 1318.0]], [[0.0, 1037.0], [195.0, 882.0], [448.0, 1432.0], [109.0, 1587.0]], [[0.0, 860.0], [448.0, 860.0], [448.0, 1585.0], [0.0, 1585.0]], [[179.0, 1229.0], [369.0, 1229.0], [369.0, 1273.0], [179.0, 1273.0]], [[179.0, 1301.0], [251.0, 1304.0], [250.0, 1331.0], [178.0, 1328.0]], [[64.0, 1498.0], [203.0, 1495.0], [203.0, 1523.0], [64.0, 1526.0]]], "lines": ["また、ただ、これからもご飯の方に仕事できないと思いますが、", "うん．．．なんか、ちょっとしてもいいんじゃないか", "そういうわけではない。そんな時代がありますが、それでもないのですが．．．それはそうだと思いました。それを見ているのだろう。", "猫の気持ち", "．．．", "ジョジョナ・"]}, {"box": [479, 1310, 528, 1531], "vertical": true, "font_size": 37, "lines_coords": [[[483.0, 1356.0], [520.0, 1356.0], [520.0, 1526.0], [483.0, 1526.0]]], "lines": ["ど３１１５１６５"]}], "img_path": "004.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1600, "blocks": [{"box": [872, 128, 974, 293], "vertical": true, "font_size": 41, "lines_coords": [[[930.0, 128.0], [974.0, 128.0], [974.0, 254.0], [930.0, 254.0]], [[872.0, 128.0], [922.0, 128.0], [922.0, 293.0], [872.0, 293.0]]], "lines": ["おお！", "石田君！"]}, {"box": [661, 259, 795, 476], "vertical": true, "font_size": 41, "lines_coords": [[[758.0, 262.0], [795.0, 262.0], [795.0, 476.0], [758.0, 476.0]], [[703.0, 259.0], [741.0, 259.0], [744.0, 475.0], [706.0, 475.0]], [[664.0, 264.0], [698.0, 264.0], [695.0, 404.0], [661.0, 404.0]]], "lines": ["ついに携帯を", "手に入れたの", "ですな！"]}, {"box": [888, 603, 988, 793], "vertical": true, "font_size": 32, "lines_coords": [[[960.0, 609.0], [986.0, 609.0], [988.0, 793.0], [961.0, 793.0]], [[917.0, 603.0], [960.0, 606.0], [955.0, 671.0], [913.0, 668.0]], [[888.0, 610.0], [914.0, 610.0], [914.0, 767.0], [888.0, 767.0]]], "lines": ["ありがたいことに", "親が", "買ってくれた"]}, {"box": [376, 617, 531, 778], "vertical": true, "font_size": 33, "lines_coords": [[[492.0, 620.0], [520.0, 620.0], [520.0, 725.0], [492.0, 725.0]], [[451.0, 618.0], [486.0, 618.0], [486.0, 728.0], [451.0, 728.0]], [[417.0, 618.0], [448.0, 618.0], [445.0, 778.0], [414.0, 778.0]], [[376.0, 617.0], [414.0, 617.0], [414.0, 679.0], [376.0, 679.0]]], "lines": ["登録人数", "３人か．．．", "寂しい奴だな", "君は"]}, {"box": [647, 1046, 747, 1175], "vertical": true, "font_size": 26, "lines_coords": [[[720.0, 1046.0], [747.0, 1046.0], [747.0, 1150.0], [720.0, 1150.0]], [[681.0, 1046.0], [709.0, 1046.0], [709.0, 1175.0], [681.0, 1175.0]], [[647.0, 1048.0], [669.0, 1048.0], [669.0, 1175.0], [647.0, 1175.0]]], "lines": ["さっそく", "俺のメアド", "入れとくね"]}, {"box": [417, 842, 508, 981], "vertical": true, "font_size": 25, "lines_coords": [[[480.0, 842.0], [506.0, 842.0], [506.0, 957.0], [480.0, 957.0]], [[448.0, 842.0], [476.0, 842.0], [476.0, 939.0], [448.0, 939.0]], [[417.0, 843.0], [437.0, 843.0], [437.0, 981.0], [417.0, 981.0]]], "lines": ["ついでに．．．", "結絃のも", "入れとくわー"]}, {"box": [123, 1022, 213, 1159], "vertical": true, "font_size": 23, "lines_coords": [[[182.0, 1023.0], [209.0, 1023.0], [209.0, 1137.0], [182.0, 1137.0]], [[150.0, 1023.0], [172.0, 1023.0], [172.0, 1137.0], [150.0, 1137.0]], [[123.0, 1023.0], [143.0, 1023.0], [143.0, 1159.0], [123.0, 1159.0]]], "lines": ["いつの間に", "連絡先交換", "したんだ．．．？"]}, {"box": [748, 1515, 841, 1564], "vertical": false, "font_size": 41, "lines_coords": [[[748.0, 1523.0], [836.0, 1515.0], [841.0, 1556.0], [753.0, 1564.0]]], "lines": ["行嬉し"]}, {"box": [606, 1200, 700, 1409], "vertical": true, "font_size": 26, "lines_coords": [[[672.0, 1200.0], [700.0, 1200.0], [700.0, 1329.0], [672.0, 1329.0]], [[639.0, 1214.0], [666.0, 1214.0], [666.0, 1409.0], [639.0, 1409.0]], [[606.0, 1218.0], [628.0, 1