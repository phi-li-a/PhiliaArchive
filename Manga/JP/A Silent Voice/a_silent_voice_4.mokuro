{"version": "0.2.0-beta.6", "title": "A Silent Voice", "title_uuid": "0ef04b72-4228-48b1-ba08-9674badb458b", "volume": "a_silent_voice_4", "volume_uuid": "82588ad6-04c7-4874-a80c-00cd46002a73", "pages": [{"version": "0.1.7", "img_width": 659, "img_height": 986, "blocks": [{"box": [49, 0, 510, 276], "vertical": false, "font_size": 273, "lines_coords": [[[52.0, 0.0], [510.0, 0.0], [506.0, 276.0], [49.0, 269.0]]], "lines": ["聲丹"]}, {"box": [197, 886, 454, 948], "vertical": false, "font_size": 68, "lines_coords": [[[197.0, 880.0], [454.0, 880.0], [454.0, 954.0], [197.0, 954.0]]], "lines": ["大今良時"]}], "img_path": "001.png"}, {"version": "0.1.7", "img_width": 659, "img_height": 986, "blocks": [], "img_path": "002.png"}, {"version": "0.1.7", "img_width": 659, "img_height": 986, "blocks": [{"box": [272, 186, 466, 209], "vertical": false, "font_size": 17, "lines_coords": [[[350.0, 189.0], [465.0, 189.0], [465.0, 206.0], [350.0, 206.0]]], "lines": ["わがたち"]}, {"box": [353, 879, 444, 923], "vertical": false, "font_size": 42, "lines_coords": [[[353.0, 881.0], [443.0, 879.0], [444.0, 921.0], [354.0, 923.0]]], "lines": ["良時"]}], "img_path": "003.png"}, {"version": "0.1.7", "img_width": 659, "img_height": 986, "blocks": [{"box": [339, 87, 557, 104], "vertical": false, "font_size": 15, "lines_coords": [[[339.0, 86.0], [557.0, 86.0], [557.0, 103.0], [339.0, 103.0]]], "lines": ["でかさ、みれまでも２０１７年６月１６日、"]}, {"box": [330, 276, 399, 293], "vertical": false, "font_size": 17, "lines_coords": [[[330.0, 276.0], [399.0, 276.0], [399.0, 293.0], [330.0, 293.0]]], "lines": ["．．．"]}, {"box": [100, 503, 255, 528], "vertical": false, "font_size": 16, "lines_coords": [[[105.0, 508.0], [223.0, 508.0], [223.0, 524.0], [105.0, 524.0]]], "lines": ["このＮＴＥＮ"]}, {"box": [171, 638, 253, 772], "vertical": true, "font_size": 83, "lines_coords": [[[174.0, 638.0], [253.0, 638.0], [253.0, 655.0], [174.0, 655.0]], [[172.0, 752.0], [227.0, 754.0], [226.0, 772.0], [171.0, 770.0]]], "lines": ["この日は、", "．．．"]}, {"box": [0, 480, 248, 986], "vertical": true, "font_size": 83, "lines_coords": [[[96.0, 551.0], [115.0, 551.0], [115.0, 893.0], [96.0, 893.0]], [[68.0, 557.0], [104.0, 557.0], [100.0, 895.0], [64.0, 895.0]], [[61.0, 530.0], [203.0, 517.0], [239.0, 914.0], [98.0, 928.0]], [[0.0, 544.0], [109.0, 480.0], [248.0, 961.0], [26.0, 986.0]]], "lines": ["話を話す話で話して話し．話．話を話し話す話", "２０１３年２月２６日第２７条第２８回第３０回東京都市の", "世間変化の結婚限ための結果、神経過信以上は一方でも良いところではある。", "そういう意味ですね。それでも、あなたがいなかったのですが、それだけで"]}, {"box": [364, 681, 375, 833], "vertical": true, "font_size": 10, "lines_coords": [[[365.0, 681.0], [375.0, 681.0], [374.0, 833.0], [364.0, 833.0]]], "lines": ["そうですね。それは、"]}, {"box": [307, 621, 334, 940], "vertical": true, "font_size": 22, "lines_coords": [[[307.0, 623.0], [329.0, 623.0], [334.0, 927.0], [312.0, 927.0]]], "lines": ["ｇｏｏｇｌｏｓｋｉｋｓｈｉｎｇ"]}], "img_path": "004.png"}, {"version": "0.1.7", "img_width": 659, "img_height": 986, "blocks": [{"box": [77, 43, 225, 70], "vertical": false, "font_size": 27, "lines_coords": [[[77.0, 43.0], [225.0, 43.0], [225.0, 70.0], [77.0, 70.0]]], "lines": ["２４話、変化・"]}, {"box": [296, 599, 326, 648], "vertical": true, "font_size": 30, "lines_coords": [[[296.0, 599.0], [326.0, 599.0], [326.0, 648.0], [296.0, 648.0]]], "lines": ["お？"]}, {"box": [133, 705, 189, 800], "vertical": true, "font_size": 18, "lines_coords": [[[169.0, 705.0], [189.0, 705.0], [189.0, 755.0], [169.0, 755.0]], [[153.0, 706.0], [169.0, 706.0], [169.0, 800.0], [153.0, 800.0]], [[133.0, 706.0], [150.0, 706.0], [150.0, 783.0], [133.0, 783.0]]], "lines": ["なんか", "あったのか？", "ねーちゃん"]}], "img_path": "005.png"}, {"version": "0.1.7", "img_width": 659, "img_height": 986, "blocks": [{"box": [514, 95, 605, 204], "vertical": true, "font_size": 26, "lines_coords": [[[574.0, 96.0], [601.0, 95.0], [604.0, 203.0], [577.0, 204.0]], [[543.0, 97.0], [572.0, 97.0], [572.0, 165.0], [543.0, 165.0]], [[514.0, 96.0], [537.0, 96.0], [537.0, 202.0], [514.0, 202.0]]], "lines": ["「好き」って", "石田に", "言った．．．！？"]}, {"box": [74, 493, 1