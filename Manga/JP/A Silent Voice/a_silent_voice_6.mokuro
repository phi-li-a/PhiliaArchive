んだ"]}, {"box": [337, 342, 366, 469], "vertical": true, "font_size": 24, "lines_coords": [[[337.0, 342.0], [361.0, 342.0], [361.0, 468.0], [337.0, 468.0]]], "lines": ["変わってる？"]}, {"box": [283, 527, 461, 623], "vertical": false, "font_size": 23.0, "lines_coords": [[[283.0, 550.0], [361.0, 527.0], [372.0, 566.0], [295.0, 589.0]], [[308.0, 576.0], [390.0, 530.0], [398.0, 547.0], [316.0, 592.0]], [[311.0, 596.0], [425.0, 530.0], [433.0, 546.0], [320.0, 611.0]], [[321.0, 610.0], [453.0, 534.0], [461.0, 547.0], [328.0, 623.0]]], "lines": ["しかし、ひそめるのひそゆるのは「俺より度」", "ひその一俺より度胸あ", "俺がこれを撮ったの", "彼がこんと風ノに横の下には市で飼育され"]}, {"box": [49, 341, 84, 408], "vertical": true, "font_size": 30, "lines_coords": [[[49.0, 341.0], [79.0, 341.0], [79.0, 408.0], [49.0, 408.0]]], "lines": ["自分．．．"]}, {"box": [623, 621, 760, 713], "vertical": false, "font_size": 15.333333333333334, "lines_coords": [[[685.0, 641.0], [725.0, 621.0], [732.0, 633.0], [692.0, 653.0]], [[623.0, 696.0], [744.0, 626.0], [752.0, 642.0], [631.0, 711.0]], [[651.0, 700.0], [752.0, 641.0], [760.0, 653.0], [659.0, 713.0]]], "lines": ["さった。", "「また！！」に想像出来るのである。", "日本の学校教育の子"]}, {"box": [579, 548, 692, 698], "vertical": true, "font_size": 23.75, "lines_coords": [[[664.0, 548.0], [690.0, 548.0], [692.0, 670.0], [667.0, 670.0]], [[638.0, 550.0], [659.0, 550.0], [657.0, 658.0], [636.0, 658.0]], [[604.0, 550.0], [629.0, 550.0], [629.0, 637.0], [604.0, 637.0]], [[579.0, 551.0], [602.0, 551.0], [602.0, 698.0], [579.0, 698.0]]], "lines": ["いや僕より", "変わってる", "奴なんて", "くさるほどいる"]}, {"box": [665, 754, 748, 900], "vertical": true, "font_size": 25, "lines_coords": [[[719.0, 754.0], [743.0, 754.0], [743.0, 900.0], [719.0, 900.0]], [[689.0, 754.0], [719.0, 754.0], [719.0, 820.0], [689.0, 820.0]], [[665.0, 757.0], [685.0, 757.0], [685.0, 870.0], [665.0, 870.0]]], "lines": ["僕はいつだって", "普通を", "目指してきた"]}, {"box": [580, 754, 611, 881], "vertical": true, "font_size": 24, "lines_coords": [[[580.0, 757.0], [604.0, 757.0], [604.0, 881.0], [580.0, 881.0]]], "lines": ["僕は普通だよ"]}, {"box": [349, 536, 584, 733], "vertical": false, "font_size": 17.833333333333332, "lines_coords": [[[349.0, 633.0], [514.0, 536.0], [522.0, 551.0], [357.0, 649.0]], [[352.0, 650.0], [512.0, 557.0], [521.0, 574.0], [361.0, 665.0]], [[375.0, 677.0], [557.0, 570.0], [566.0, 585.0], [384.0, 693.0]], [[371.0, 699.0], [535.0, 603.0], [543.0, 618.0], [379.0, 714.0]], [[379.0, 712.0], [575.0, 601.0], [583.0, 616.0], [388.0, 727.0]], [[406.0, 716.0], [574.0, 617.0], [584.0, 635.0], [417.0, 733.0]]], "lines": ["週６日、この場所で壁に餌をあ", "週０日、この州（金）は、「最近ここの壁の元気が無い・", "彼の投稿履歴をさかりぼってみる。", "過去にもこういった飛び込み", "過去にもしいなぜそんな事を？自慢？武勇伝？ノ", "さてわは事を・自慢出身以上動機にせよ彼の行為は世界中"]}, {"box": [423, 793, 481, 881], "vertical": true, "font_size": 29, "lines_coords": [[[452.0, 794.0], [481.0, 794.0], [481.0, 881.0], [452.0, 881.0]], [[423.0, 793.0], [452.0, 793.0], [452.0, 862.0], [423.0, 862.0]]], "lines": ["ねーねー", "石田君"]}, {"box": [229, 782, 319, 909], "vertical": true, "font_size": 25, "lines_coords": [[[288.0, 783.0], [311.0, 783.0], [311.0, 909.0], [288.0, 909.0]], [[263.0, 783.0], [284.0, 783.0], [282.0, 889.0], [261.0, 889.0]], [[229.0, 782.0], [260.0, 782.0], [260.0, 849.0], [229.0, 849.0]]], "lines": ["君と比べたら", "そうだろ？", "石田君"]}], "img_path": "129.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [590, 65, 752, 236], "vertical": true, "font_size": 24, "lines_coords": [[[722.0, 65.0], [746.0, 65.0], [746.0, 144.0], [722.0, 144.0]], [[698.0, 65.0], [723.0, 65.0], [723.0, 130.0], [698.0, 130.0]], [[670.0, 118.0], [701.0, 118.0], [701.0, 183.0], [670.0, 183.0]], [[648.0, 121.0], [668.0, 121.0], [668.0, 235.0], [648.0, 235.0]], [[620.0, 121.0], [641.0, 121.0], [641.0, 235.0], [620.0, 235.0]], [[590.0, 120.0], [615.0, 120.0], [615.0, 182.0], [590.0, 182.0]]], "lines": ["石田君と", "いたら", "自分が", "普通なんだと", "実感できると", "思った"]}, {"box": [477, 169, 533, 254], "vertical": true, "font_size": 25, "lines_coords": [[[507.0, 169.0], [533.0, 169.0], [533.0, 234.0], [507.0, 234.0]], [[477.0, 169.0], [501.0, 169.0], [501.0, 254.0], [477.0, 254.0]]], "lines": ["だから", "近づいた"]}, {"box": [365, 79, 390, 145], "vertical": true, "font_size": 24, "lines_coords": [[[365.0, 79.0], [390.0, 79.0], [390.0, 145.0], [365.0, 145.0]]], "lines": ["だけど"]}, {"box": [202, 141, 331, 240], "vertical": true, "font_size": 24, "lines_coords": [[[307.0, 142.0], [331.0, 142.0], [331.0, 205.0], [307.0, 205.0]], [[281.0, 144.0], [301.0, 144.0], [301.0, 240.0], [281.0, 240.0]], [[255.0, 142.0], [281.0, 142.0], [281.0, 203.0], [255.0, 203.0]], [[229.0, 144.0], [249.0, 144.0], [249.0, 239.0], [229.0, 239.0]], [[202.0, 141.0], [230.0, 141.0], [230.0, 187.0], [202.0, 187.0]]], "lines": ["実際は", "そんな実感", "なんて", "得ることは", "なく"]}, {"box": [86, 227, 141, 310], "vertical": true, "font_size": 25, "lines_coords": [[[116.0, 227.0], [141.0, 227.0], [141.0, 292.0], [116.0, 292.0]], [[86.0, 227.0], [111.0, 227.0], [111.0, 310.0], [86.0, 310.0]]], "lines": ["むしろ", "その逆で"]}, {"box": [547, 387, 766, 481], "vertical": true, "font_size": 26, "lines_coords": [[[732.0, 389.0], [758.0, 389.0], [756.0, 481.0], [730.0, 481.0]], [[697.0, 389.0], [722.0, 389.0], [722.0, 480.0], [697.0, 480.0]], [[662.0, 389.0], [691.0, 389.0], [691.0, 460.0], [662.0, 460.0]], [[636.0, 390.0], [662.0, 390.0], [662.0, 459.0], [636.0, 459.0]], [[602.0, 389.0], [629.0, 389.0], [629.0, 480.0], [602.0, 480.0]], [[574.0, 390.0], [599.0, 390.0], [599.0, 481.0], [574.0, 481.0]], [[547.0, 387.0], [573.0, 387.0], [573.0, 460.0], [547.0, 460.0]]], "lines": ["石田君は", "女の子を", "助ける", "ために", "落ちちゃ", "ったんだ", "ぞォ！"]}, {"box": [545, 537, 586, 589], "vertical": true, "font_size": 26, "lines_coords": [[[561.0, 539.0], [586.0, 539.0], [586.0, 575.0], [561.0, 575.0]], [[545.0, 537.0], [572.0, 537.0], [572.0, 589.0], [545.0, 589.0]]], "lines": ["えー", "ウソー"]}, {"box": [430, 523, 465, 548], "vertical": false, "font_size": 24, "lines_coords": [[[430.0, 523.0], [465.0, 523.0], [465.0, 547.0], [430.0, 547.0]]], "lines": ["ぜっ"]}, {"box": [66