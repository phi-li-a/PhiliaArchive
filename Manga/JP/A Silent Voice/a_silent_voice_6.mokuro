": 575, "lines_coords": [[[159.0, 683.0], [493.0, 566.0], [690.0, 1129.0], [357.0, 1200.0]]], "lines": ["．．．"]}, {"box": [676, 684, 713, 1131], "vertical": true, "font_size": 27, "lines_coords": [[[677.0, 684.0], [704.0, 684.0], [713.0, 1129.0], [686.0, 1129.0]]], "lines": ["３．２８１８７９５１１８１３１１４９"]}, {"box": [304, 604, 679, 1200], "vertical": true, "font_size": 102, "lines_coords": [[[506.0, 909.0], [575.0, 909.0], [575.0, 971.0], [506.0, 971.0]], [[493.0, 1027.0], [553.0, 1035.0], [548.0, 1073.0], [488.0, 1065.0]], [[397.0, 612.0], [679.0, 612.0], [679.0, 1132.0], [397.0, 1132.0]], [[467.0, 1085.0], [520.0, 1085.0], [520.0, 1106.0], [467.0, 1106.0]], [[304.0, 604.0], [588.0, 604.0], [588.0, 1200.0], [304.0, 1200.0]]], "lines": ["キみき", "．．．", "そういうことがありませんが、お客様にはそんな気がしましたが、ほとんどいいかもしれないと思いますけど、", "．．．", "そういうことですが、これまではないというのであれば、それをお知らせしているので、何かを知ってるんだろう。これから、その言葉があります。それぞれだ。"]}], "img_path": "004.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [636, 86, 665, 208], "vertical": true, "font_size": 28, "lines_coords": [[[636.0, 86.0], [664.0, 86.0], [664.0, 208.0], [636.0, 208.0]]], "lines": ["おはよ！"]}, {"box": [18, 30, 362, 90], "vertical": false, "font_size": 38, "lines_coords": [[[29.0, 49.0], [322.0, 46.0], [322.0, 84.0], [29.0, 86.0]]], "lines": ["第４３話順度胸試"]}, {"box": [96, 189, 212, 317], "vertical": true, "font_size": 25, "lines_coords": [[[182.0, 192.0], [206.0, 192.0], [206.0, 317.0], [182.0, 317.0]], [[157.0, 192.0], [180.0, 192.0], [180.0, 317.0], [157.0, 317.0]], [[125.0, 192.0], [148.0, 192.0], [148.0, 317.0], [125.0, 317.0]], [[96.0, 189.0], [127.0, 189.0], [127.0, 239.0], [96.0, 239.0]]], "lines": ["お姉ちゃんが", "ホットケーキ", "焼いてくれた", "わよ"]}, {"box": [390, 651, 500, 732], "vertical": true, "font_size": 28, "lines_coords": [[[468.0, 651.0], [497.0, 651.0], [497.0, 697.0], [468.0, 697.0]], [[441.0, 653.0], [467.0, 653.0], [467.0, 732.0], [441.0, 732.0]], [[411.0, 651.0], [440.0, 651.0], [440.0, 716.0], [411.0, 716.0]], [[390.0, 651