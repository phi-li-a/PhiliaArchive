es_coords": [[[140.0, 830.0], [160.0, 830.0], [160.0, 945.0], [140.0, 945.0]], [[112.0, 830.0], [133.0, 830.0], [133.0, 908.0], [112.0, 908.0]], [[84.0, 830.0], [104.0, 830.0], [104.0, 964.0], [84.0, 964.0]], [[60.0, 829.0], [80.0, 829.0], [80.0, 944.0], [60.0, 944.0]], [[32.0, 830.0], [52.0, 830.0], [52.0, 980.0], [32.0, 980.0]]], "lines": ["ひょっとして", "真柴君が", "私に話しかけて", "くれるから？", "嫉妬してるとか？"]}], "img_path": "103.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [654, 59, 719, 220], "vertical": true, "font_size": 26, "lines_coords": [[[691.0, 59.0], [719.0, 59.0], [717.0, 194.0], [689.0, 194.0]], [[654.0, 62.0], [678.0, 62.0], [678.0, 220.0], [654.0, 220.0]]], "lines": ["西宮さんや", "佐原さんも．．．"]}, {"box": [559, 60, 618, 247], "vertical": true, "font_size": 26, "lines_coords": [[[590.0, 60.0], [618.0, 60.0], [618.0, 195.0], [590.0, 195.0]], [[559.0, 62.0], [583.0, 62.0], [583.0, 247.0], [559.0, 247.0]]], "lines": ["こんな気分", "だったのかな．．．"]}, {"box": [353, 108, 437, 281], "vertical": true, "font_size": 20, "lines_coords": [[[410.0, 110.0], [430.0, 110.0], [430.0, 215.0], [410.0, 215.0]], [[379.0, 108.0], [400.0, 108.0], [402.0, 207.0], [380.0, 207.0]], [[354.0, 111.0], [373.0, 111.0], [373.0, 281.0], [354.0, 281.0]]], "lines": ["思えば私も", "彼女たちと", "一緒だったのかも："]}, {"box": [256, 227, 292, 294], "vertical": true, "font_size": 19, "lines_coords": [[[269.0, 227.0], [290.0, 227.0], [290.0, 294.0], [269.0, 294.0]], [[256.0, 229.0], [273.0, 229.0], [273.0, 291.0], [256.0, 291.0]]], "lines": ["川井さんも", "やってた！"]}, {"box": [135, 108, 232, 261], "vertical": true, "font_size": 20, "lines_coords": [[[212.0, 111.0], [232.0, 111.0], [232.0, 223.0], [212.0, 223.0]], [[182.0, 110.0], [202.0, 110.0], [202.0, 251.0], [182.0, 251.0]], [[160.0, 110.0], [180.0, 110.0], [180.0, 261.0], [160.0, 261.0]], [[137.0, 108.0], [157.0, 108.0], [155.0, 261.0], [135.0, 261.0]]], "lines": ["いわれのない", "罪をなすり付け", "られそうになった", "こともあったし．．．"]}, {"box": [344, 420, 444, 554], "vertical": true, "font_size": 21, "lines_coords": [[[417.0, 420.0], [441.0, 420.0], [441.0, 500.0], [417.0, 500.0]], [[391.0, 421.0], [411.0, 421.0], [411.0, 554.0], [391.0, 554.0]], [[368.0, 421.0], [388.0, 421.0], [388.0, 526.0], [368.0, 526.0]], [[344.0, 421.0], [364.0, 421.0], [364.0, 535.0], [344.0, 535.0]]], "lines": ["あの時は", "気づかなかった", "けどあれは", "イジメだった"]}, {"box": [410, 598, 436, 664], "vertical": true, "font_size": 26, "lines_coords": [[[410.0, 598.0], [436.0, 598.0], [436.0, 664.0], [410.0, 664.0]]], "lines": ["そう．．"]}, {"box": [311, 693, 426, 841], "vertical": true, "font_size": 23, "lines_coords": [[[395.0, 693.0], [419.0, 693.0], [419.0, 802.0], [395.0, 802.0]], [[365.0, 696.0], [385.0, 696.0], [385.0, 841.0], [365.0, 841.0]], [[336.0, 694.0], [361.0, 694.0], [363.0, 841.0], [338.0, 841.0]], [[314.0, 694.0], [338.0, 694.0], [338.0, 822.0], [314.0, 822.0]]], "lines": ["私だって", "何もかも努力で", "カバ川できてた", "わけじゃない"]}, {"box": [86, 699, 149, 830], "vertical": true, "font_size": 22, "lines_coords": [[[117.0, 700.0], [141.0, 700.0], [141.0, 821.0], [117.0, 821.0]], [[86.0, 699.0], [106.0, 699.0], [106.0, 828.0], [86.0, 828.0]]], "lines": ["人並みに", "苦労してきた"]}, {"box": [92, 932, 232, 1082], "vertical": true, "font_size": 24, "lines_coords": [[[202.0, 932.0], [232.0, 932.0], [232.0, 1003.0], [202.0, 1003.0]], [[175.0, 936.0], [196.0, 936.0], [196.0, 1019.0], [175.0, 1019.0]], [[148.0, 933.0], [172.0, 933.0], [172.0, 1061.0], [148.0, 1061.0]], [[116.0, 933.0], [140.0, 933.0], [143.0, 1062.0], [118.0, 1062.0]], [[92.0, 935.0], [112.0, 935.0], [112.0, 1082.0], [92.0, 1082.0]]], "lines": ["でも．．．", "石田君は", "ちょっとだけ", "許してあげる", "へきなのかな．．．"]}], "img_path": "104.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [736, 133, 759, 217], "vertical": true, "font_size": 21, "lines_coords": [[[736.0, 133.0], [757.0, 133.0], [759.0, 217.0], [738.0, 217.0]]], "lines": ["ラー文具"]}, {"box": [549, 71, 710, 232], "vertical": true, "font_size": 24, "lines_coords": [[[678.0, 72