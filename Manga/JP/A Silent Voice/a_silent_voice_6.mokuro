33.0, 842.0]], [[101.0, 703.0], [123.0, 703.0], [120.0, 799.0], [99.0, 799.0]]], "lines": ["だから西宮は", "大丈夫だ"]}, {"box": [312, 933, 389, 1079], "vertical": true, "font_size": 27, "lines_coords": [[[356.0, 933.0], [386.0, 933.0], [386.0, 994.0], [356.0, 994.0]], [[312.0, 943.0], [336.0, 943.0], [336.0, 1079.0], [312.0, 1079.0]]], "lines": ["俺が", "いなくても"]}, {"box": [90, 994, 165, 1117], "vertical": true, "font_size": 27, "lines_coords": [[[135.0, 1000.0], [160.0, 1000.0], [160.0, 1113.0], [135.0, 1113.0]], [[90.0, 997.0], [119.0, 997.0], [119.0, 1085.0], [90.0, 1085.0]]], "lines": ["万事ＯＫ", "なんだ"]}], "img_path": "165.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [86, 976, 190, 1080], "vertical": true, "font_size": 28, "lines_coords": [[[165.0, 978.0], [189.0, 978.0], [189.0, 1079.0], [165.0, 1079.0]], [[121.0, 977.0], [155.0, 977.0], [155.0, 1054.0], [121.0, 1054.0]], [[86.0, 977.0], [112.0, 977.0], [112.0, 1054.0], [86.0, 1054.0]]], "lines": ["もうすぐ", "火曜が", "終わる"]}], "img_path": "166.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [], "img_path": "167.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [221, 321, 385, 379], "vertical": false, "font_size": 58, "lines_coords": [[[221.0, 321.0], [385.0, 321.0], [385.0, 379.0], [221.0, 379.0]]], "lines": ["んだろう。５０"]}], "img_path": "168.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [82, 43, 328, 91], "vertical": false, "font_size": 48, "lines_coords": [[[82.0, 43.0], [328.0, 43.0], [328.0, 91.0], [82.0, 91.0]]], "lines": ["第５２話静寂"]}, {"box": [633, 199, 659, 213], "vertical": false, "font_size": 15, "lines_coords": [[[634.0, 198.0], [656.0, 198.0], [656.0, 215.0], [634.0, 215.0]]], "lines": ["ハッ"]}, {"box": [439, 314, 464, 330], "vertical": false, "font_size": 16, "lines_coords": [[[439.0, 314.0], [464.0, 314.0], [464.0, 330.0], [439.0, 330.0]]], "lines": ["！！"]}, {"box": [133, 801, 168, 8