6.0, 208.0], [664.0, 208.0]]], "lines": ["う．．．"]}, {"box": [309, 94, 363, 219], "vertical": true, "font_size": 52, "lines_coords": [[[311.0, 94.0], [363.0, 96.0], [361.0, 219.0], [309.0, 217.0]]], "lines": ["あ．．．"]}, {"box": [679, 824, 715, 844], "vertical": false, "font_size": 20, "lines_coords": [[[679.0, 824.0], [715.0, 824.0], [715.0, 844.0], [679.0, 844.0]]], "lines": ["グッ"]}, {"box": [133, 600, 193, 755], "vertical": true, "font_size": 52, "lines_coords": [[[133.0, 603.0], [185.0, 600.0], [193.0, 752.0], [141.0, 755.0]]], "lines": ["あぐっ"]}, {"box": [435, 982, 466, 1088], "vertical": true, "font_size": 29, "lines_coords": [[[436.0, 985.0], [465.0, 985.0], [465.0, 1088.0], [436.0, 1088.0]]], "lines": ["あああ"]}, {"box": [208, 933, 251, 964], "vertical": false, "font_size": 31, "lines_coords": [[[208.0, 933.0], [251.0, 933.0], [251.0, 964.0], [208.0, 964.0]]], "lines": ["フウ"]}, {"box": [39, 1100, 85, 1133], "vertical": false, "font_size": 30, "lines_coords": [[[42.0, 1100.0], [85.0, 1103.0], [83.0, 1133.0], [39.0, 1129.0]]], "lines": ["フウ"]}], "img_path": "175.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [629, 119, 651, 133], "vertical": false, "font_size": 14, "lines_coords": [[[629.0, 119.0], [651.0, 119.0], [651.0, 133.0], [629.0, 133.0]]], "lines": ["グメ"]}, {"box": [655, 737, 709, 880], "vertical": true, "font_size": 52, "lines_coords": [[[657.0, 745.0], [709.0, 746.0], [706.0, 880.0], [655.0, 878.0]]], "lines": ["忘れ物"]}], "img_path": "176.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [226, 310, 405, 435], "vertical": false, "font_size": 30.666666666666668, "lines_coords": [[[226.0, 330.0], [382.0, 310.0], [385.0, 342.0], [229.0, 362.0]], [[230.0, 369.0], [370.0, 349.0], [375.0, 378.0], [235.0, 398.0]], [[239.0, 404.0], [402.0, 383.0], [405.0, 414.0], [242.0, 435.0]]], "lines": ["わたしは皆さんと", "このレトを通して", "仲良くなりたいと"]}], "img_path": "177.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [329, 30, 462, 111], "vertical": false, "font_size": 53, "lines_coords": [[[329.0, 56.0], [446.0, 31.0], [458.0, 83.0], [341.0, 107.0]]], "lines": ["キミは"]}, {"box": [339, 240, 534, 401], "vertical": false, "font_size": 34, "lines_coords": [[[399.0, 283.0], [509.0, 242.0], [520.0, 270.0], [410.0, 312.0]], [[478.0, 275.0], [514.0, 258.0], [521.0, 274.0], [485.0, 290.0]], [[339.0, 348.0], [458.0, 296.0], [480.0, 348.0], [362.0, 398.0]]], "lines": ["？あから", "．．．", "学談用"]}], "img_path": "178.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [], "img_path": "179.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [], "img_path": "180.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [], "img_path": "181.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [], "img_path": "182.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [], "img_path": "183.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [], "img_path": "184.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [177, 942, 252, 983], "vertical": false, "font_size": 16, "lines_coords": [[[182.0, 942.0], [252.0, 967.0], [246.0, 983.0], [177.0, 957.0]]], "lines": ["．．．"]}, {"box": [269, 949, 355, 1004], "vertical": false, "font_size": 15.0, "lines_coords": [[[273.0, 953.0], [355.0, 949.0], [355.0, 962.0], [273.0, 966.0]], [[269.0, 971.0], [354.0, 964.0], [355.0, 980.0], [270.0, 987.0]], [[269.0, 987.0], [352.0, 984.0], [352.0, 1000.0], [269.0, 1004.0]]], "lines": ["ロロドロの", "ははは！！", "．．．"]}], "img_path": "185.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [682, 117, 700, 190], "vertical": true, "font_size": 18, "lines_coords": [[[682.0, 117.0], [700.0, 117.0], [700.0, 190.0], [682.0, 190.0]]], "lines": ["．．．．．．"]}, {"box": [121, 273, 143, 338], "vertical": true, "font_size": 22, "lines_coords": [[[121.0, 273.0], [143.0, 273.0], [143.0, 338.0], [121.0, 338.0]]], "lines": ["．．．．．"]}, {"box": [396, 733, 427, 944], "vertical": true, "font_size": 28, "lines_coords": [[[396.0, 733.0], [424.0, 733.0], [427.0, 943.0], [399.0, 943.0]]], "lines": ["にひみやっ．．．！"]}, {"box": [57, 1142, 218, 1178], "vertical": false, "font_size": 22, "lines_coords": [[[67.0, 1151.0], [187.0, 1150.0], [187.0, 1171.0], [67.0, 1173.0]]], "lines": ["７巻につづ"]}], "img_path": "186.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [], "img_path": "187.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [461, 72, 594, 155], "vertical": false, "font_size": 83, "lines_coords": [[[461.0, 72.0], [594.0, 72.0], [594.0, 155.0], [461.0, 155.0]]], "lines": ["良時"]}, {"box": [439, 285, 549, 339], "vertical": false, "font_size": 29.0, "lines_coords": [[[443.0, 292.0], [549.0, 300.0], [546.0, 339.0], [439.0, 332.0]], [[482.0, 285.0], [526.0, 285.0], [526.0, 303.0], [482.0, 303.0]]], "lines": ["対診", "．．．"]}, {"box": [246, 356, 556, 371], "vertical": false, "font_size": 15, "lines_coords": [[[246.0, 356.0], [556.0, 356.0], [556.0, 371.0], [246.0, 371.0]]], "lines": ["本この対象は、選手少年マガジン２０１４年７月に掲載されたものです。"]}, {"box": [229, 393, 559, 414], "vertical": false, "font_size": 15, "lines_coords": [[[229.0, 393.0], [559.0, 394.0], [559.0, 414.0], [229.0, 413.0]]], "lines": ["昨年、朝の連続テレレビ小説「あまちゃん、などで注"]}, {"box": [230, 424, 559, 476], "vertical": false, "font_size": 15, "lines_coords": [[[230.0, 424.0], [559.0, 424.0], [559.0, 447.0], [230.0, 447.0]], [[233.0, 448.0], [295.0, 448.0], [295.0, 460.0], [233.0, 460.0]], [[232.0, 457.0], [555.0, 457.0], [555.0, 476.0], [232.0, 476.0]]], "lines": ["目を集め、ドラマ、映画、ＣＭに引っ張りだこの", "ありむらかすね", "有村架純さん。じつは大の「少年マンガ好き」"]}, {"box": [229, 491, 560, 570], "vertical": false, "font_size": 15, "lines_coords": [[[234.0, 491.0], [556.0, 491.0], [556.0, 507.0], [234.0, 507.0]], [[229.0, 521.0], [560.0, 520.0], [560.0, 540.0], [229.0, 541.0]], [[234.0, 543.0], [260.0, 543.0], [260.0, 553.0], [234.0, 553.0]], [[230.0, 554.0], [505.0, 553.0], [505.0, 569.0], [230.0, 570.0]], [[368.0, 513.0], [384.0, 513.0], [384.0, 521.0], [368.0, 521.0]], [[364.0, 542.0], [399.0, 542.0], [399.0, 554.0], [364.0, 554.0]], [[498.0, 512.0], [556.0, 512.0], [556.0, 523.0], [498.0, 523.0]]], "lines": ["賢の形の感想をお聞きしたところ、ご自身の", "体験もからめて深く語ってくれました。大今良時", "えせい", "先生とのスイペシャル対談をお届けします。", "．．．", "たいだん", "おおいまよしと"]}, {"box": [708, 679, 731, 1115], "vertical": true, "font_size": 20, "lines_coords": [[[708.0, 679.0], [731.0, 679.0], [731.0, 1115.0], [708.0, 1115.0]]], "lines": ["「今回の対談に先駆けて、有村さんには、『聲の形』の"]}, {"box": [416, 655, 693, 1115], "vertical": true, "font_size": 20, "lines_coords": [[[674.0, 656.0], [693.0, 656.0], [693.0, 1115.0], [674.0, 1115.0]], [[634.0, 655.0], [654.0, 655.0], [656.0, 909.0], [636.0, 909.0]], [[617.0, 659.0], [630.0, 659.0], [630.0, 696.0], [617.0, 696.0]], [[597.0, 656.0], [621.0, 656.0], [621.0, 1114.0], [597.0, 1114.0]], [[562.0, 656.0], [586.0, 656.0], [586.0, 973.0], [562.0, 973.0]], [[524.0, 656.0], [547.0, 656.0], [547.0, 1115.0], [524.0, 1115.0]], [[490.0, 657.0], [509.0, 657.0], [509.0, 1114.0], [490.0, 1114.0]], [[451.0, 656.0], [471.0, 656.0], [472.0, 1113.0], [452.0, 1113.0]], [[416.0, 657.0], [436.0, 657.0], [436.0, 1114.0], [416.0, 1114.0]]], "lines": ["２巻も読んでいただきますした。まずは「賢の形・全体の感", "想から聞かせてもらえますか。", "ありひら", "有村さん（以下、有村〉＿正直にに言ってもいいんですか？", "大多先生以下、大多〉もちろんです。", "有村、心が痛かったです。いしめた側がいじめられるよ", "うになり、机に落書きされ、ノートを放り投げられる。同", "級生も家族もそれぞれの立場があって、誰がいい、誰か", "悪いとも言えない苦しさのようなものが伝わってきます"]}, {"box": [373, 653, 404, 707], "vertical": false, "font_size": 54, "lines_coords": [[[373.0, 653.0], [404.0, 653.0], [404.0, 707.0], [373.0, 707.0]]], "lines": ["した。おい！"]}, {"box": [338, 653, 366, 1115], "vertical": true, "font_size": 28, "lines_coords": [[[338.0, 653.0], [366.0, 653.0], [366.0, 1115.0], [338.0, 1115.0]]], "lines": ["大今、ありがとうございます。すごく丁寧に読んでいた"]}, {"box": [83, 653, 328, 1116], "vertical": true, "font_size": 26, "lines_coords": [[[303.0, 656.0], [328.0, 656.0], [328.0, 825.0], [303.0, 825.0]], [[266.0, 653.0], [293.0, 653.0], [293.0, 1115.0], [266.0, 1115.0]], [[232.0, 656.0], [252.0, 656.0], [252.0, 1114.0], [232.0, 1114.0]], [[194.0, 656.0], [218.0, 656.0], [216.0, 955.0], [193.0, 955.0]], [[153.0, 657.0], [181.0, 657.0], [182.0, 1116.0], [154.0, 1116.0]], [[118.0, 655.0], [146.0, 655.0], [143.0, 840.0], [114.0, 840.0]], [[83.0, 655.0], [111.0, 655.0], [111.0, 882.0], [83.0, 882.0]]], "lines": ["だき、驚いています。", "有村「私なら、どう振る舞うまだろうって、考えてしまい", "ました。いじめというほどじゃやないかもしれませんけ", "ど、私の身の回りにもあったんです。", "「現実でも、ローテーションで、いじめの順番が", "回ってくる」〈有村〉", "大今、有村さん自身にも？"]}], "img_path": "188.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [52, 19, 285, 101], "vertical": false, "font_size": 27, "lines_coords": [[[52.0, 43.0], [270.0, 19.0], [274.0, 44.0], [56.0, 67.0]], [[56.0, 72.0], [280.0, 46.0], [283.0, 76.0], [59.0, 101.0]]], "lines": ["大今良時ｘ右村架純", "『群の形』対談"]}, {"box": [64, 134, 342, 431], "vertical": true, "font_size": 20.5, "lines_coords": [[[318.0, 134.0], [342.0, 134.0], [342.0, 431.0], [318.0, 431.0]], [[284.0, 135.0], [304.0, 135.0], [304.0, 427.0], [284.0, 427.0]], [[248.0, 135.0], [268.0, 135.0], [268.0, 430.0], [248.0, 430.0]], [[211.0, 135.0], [230.0, 135.0], [230.0, 430.0], [211.0, 430.0]], [[174.0, 135.0], [194.0, 135.0], [194.0, 428.0], [174.0, 428.0]], [[135.0, 135.0], [155.0, 135.0], [155.0, 426.0], [135.0, 426.0]], [[100.0, 135.0], [121.0, 135.0], [121.0, 221.0], [100.0, 221.0]], [[64.0, 135.0], [84.0, 135.0], [84.0, 428.0], [64.0, 428.0]]], "lines": ["大今、はい。見聞きした事実が", "根っこにあります。その当時の雰囲", "気を思い出しながら、物語を膨らま", "せています。作品では時に極端な", "方向に物語の枝を伸ばしますか", "ら、そのままというわけではあり", "ませんが。", "有村・見て見ぬふりをしたり、自分の"]}, {"box": [358, 135, 375, 496], "vertical": true, "font_size": 17, "lines_coords": [[[358.0, 135.0], [375.0, 135.0], [375.0, 496.0], [358.0, 496.0]]], "lines": ["物語は、実体験をもとにしているんですか？"]}, {"box": [393, 132, 710, 594], "vertical": true, "font_size": 22.555555555555557, "lines_coords": [[[686.0, 134.0], [710.0, 134.0], [710.0, 592.0], [686.0, 592.0]], [[651.0, 132.0], [675.0, 132.0], [674.0, 589.0], [650.0, 589.0]], [[614.0, 133.0], [637.0, 133.0], [637.0, 592.0], [614.0, 592.0]], [[577.0, 133.0], [601.0, 133.0], [601.0, 592.0], [577.0, 592.0]], [[542.0, 135.0], [562.0, 135.0], [562.0, 367.0], [542.0, 367.0]], [[502.0, 132.0], [527.0, 132.0], [527.0, 378.0], [502.0, 378.0]], [[467.0, 134.0], [487.0, 134.0], [487.0, 588.0], [467.0, 588.0]], [[430.0, 134.0], [453.0, 134.0], [453.0, 594.0], [430.0, 594.0]], [[393.0, 134.0], [413.0, 134.0], [414.0, 588.0], [395.0, 588.0]]], "lines": ["有村小学校から中学校くらいにかけて、無視された", "そり、悪口を言われましたね。「調子乗ってんなよ」とか、", "男の人と話していると陰口を叩かれたりして。でも", "ずっとではなくて、リーダ「彼みたいな人の意向に", "沿ってローテーションで．．．。", "大今、順番が回ってくる、と。", "有村「そうなんです。一家の形態を読んで気づいたのは、", "本当にありそうな場面がたくさん出てくること。自分", "ならどう振る舞うか、迷うようなシーンが多いんです。"]}, {"box": [430, 647, 717, 1117], "vertical": true, "font_size": 23, "lines_coords": [[[685.0, 655.0], [705.0, 655.0], [706.0, 1113.0], [686.0, 1113.0]], [[650.0, 653.0], [670.0, 653.0], [668.0, 1057.0], [648.0, 1057.0]], [[610.0, 655.0], [634.0, 655.0], [634.0, 1113.0], [610.0, 1113.0]], [[572.0, 655.0], [600.0, 655.0], [600.0, 778.0], [572.0, 778.0]], [[538.0, 655.0], [561.0, 655.0], [561.0, 1113.0], [538.0, 1113.0]], [[502.0, 656.0], [522.0, 656.0], [521.0, 826.0], [501.0, 826.0]], [[463.0, 652.0], [490.0, 652.0], [490.0, 1115.0], [463.0, 1115.0]], [[430.0, 653.0], [450.0, 653.0], [450.0, 1113.0], [430.0, 1113.0]]], "lines": ["の立場次第でいじめの標的を変えるクラスメート：", "．．．。すごく真に迫っていたので、気になりました。", "「いじめのまわりにあった気持ちの変化を描け", "ねビ《え》", "大今、作中に登場した入物で好きなキャラ、嫌いな", "キャラはいますか？", "有村２巻で登場した、新しいお友達の永束君が好き", "ですね。「友達の定義って何かわかる？」って聞かれて"]}], "img_path": "189.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [325, 290, 335, 309], "vertical": false, "font_size": 19, "lines_coords": [[[325.0, 290.0], [335.0, 290.0], [335.0, 309.0], [325.0, 309.0]]], "lines": ["ひね"]}, {"box": [630, 130, 662, 401], "vertical": true, "font_size": 32, "lines_coords": [[[630.0, 130.0], [662.0, 130.0], [662.0, 401.0], [630.0, 401.0]]], "lines": ["大今苦手なキャラクターは？"]}, {"box": [85, 131, 329, 590], "vertical": true, "font_size": 23.142857142857142, "lines_coords": [[[302.0, 133.0], [327.0, 133.0], [329.0, 432.0], [304.0, 432.0]], [[264.0, 131.0], [293.0, 131.0], [293.0, 475.0], [264.0, 475.0]], [[230.0, 133.0], [254.0, 133.0], [254.0, 585.0], [230.0, 585.0]], [[194.0, 133.0], [214.0, 133.0], [215.0, 590.0], [195.0, 590.0]], [[158.0, 133.0], [181.0, 133.0], [179.0, 590.0], [155.0, 590.0]], [[121.0, 134.0], [141.0, 134.0], [141.0, 590.0], [121.0, 590.0]], [[85.0, 134.0], [105.0, 134.0], [106.0, 384.0], [86.0, 384.0]]], "lines": ["している。その姿に胸が痛くて．．．。", "大きく少し、謎めいていますよね。あの子、", "有村『うふふ。そうですよね。ミステリアスですね。", "堂々としていて、ムキにならないのがかっこいいです", "が、本当はどう思っているんだろう、と想像してしまい", "ます。勝手な希望としては、硝子ちゃんには軽々しく", "怒ってほしくないかなあ．．．。"]}, {"box": [141, 513, 153, 548], "vertical": true, "font_size": 12, "lines_coords": [[[141.0, 513.0], [153.0, 513.0], [153.0, 548.0], [141.0, 548.0]]], "lines": ["ふふふっ"]}, {"box": [344, 137, 361, 588], "vertical": true, "font_size": 17, "lines_coords": [[[344.0, 137.0], [361.0, 137.0], [361.0, 588.0], [344.0, 588.0]]], "lines": ["んよね。ひどいことをされても、自分から歩み寄ろうと"]}, {"box": [376, 132, 403, 591], "vertical": true, "font_size": 27, "lines_coords": [[[376.0, 132.0], [403.0, 132.0], [403.0, 591.0], [376.0, 591.0]]], "lines": ["有村一作中での硝子ちゃんは、何をされても怒りませ"]}, {"box": [362, 424, 373, 441], "vertical": false, "font_size": 17, "lines_coords": [[[362.0, 424.0], [373.0, 424.0], [373.0, 441.0], [362.0, 441.0]]], "lines": ["ぶん"]}, {"box": [363, 471, 371, 493], "vertical": true, "font_size": 8, "lines_coords": [[[363.0, 471.0], [371.0, 471.0], [371.0, 493.0], [363.0, 493.0]]], "lines": ["あ"]}, {"box": [414, 133, 620, 591], "vertical": true, "font_size": 20.333333333333332, "lines_coords": [[[597.0, 133.0], [618.0, 133.0], [620.0, 590.0], [599.0, 590.0]], [[561.0, 134.0], [581.0, 134.0], [582.0, 590.0], [562.0, 590.0]], [[526.0, 135.0], [546.0, 135.0], [546.0, 506.0], [526.0, 506.0]], [[487.0, 133.0], [511.0, 133.0], [511.0, 591.0], [487.0, 591.0]], [[454.0, 137.0], [471.0, 137.0], [471.0, 589.0], [454.0, 589.0]], [[414.0, 134.0], [434.0, 134.0], [436.0, 550.0], [416.0, 550.0]]], "lines": ["有村「気になるのは、手のひらを返して石田君をいじ", "めてた昔の仲間たち。彼らがあのまま大きくなってい", "たらと思うと、ちょっとイヤかもしれません。", "大今、そのうち、「いま」この彼らも描こうと思っています。", "す。ひとつのいじめのまわりにあった、いろいろな「気", "持ち」がどう変わっていくのかも描かなければ、と。"]}, {"box": [670, 132, 695, 546], "vertical": true, "font_size": 24, "lines_coords": [[[671.0, 132.0], [695.0, 132.0], [693.0, 546.0], [670.0, 546.0]]], "lines": ["りに一人いるだけで、すごとく救われる気がします。"]}, {"box": [711, 137, 727, 589], "vertical": true, "font_size": 16, "lines_coords": [[[711.0, 137.0], [727.0, 137.0], [727.0, 589.0], [711.0, 589.0]]], "lines": ["素敵な言葉を残すんです。ああいう楽観的な人がまわ"]}, {"box": [104, 660, 116, 714], "vertical": true, "font_size": 12, "lines_coords": [[[104.0, 660.0], [116.0, 660.0], [116.0, 714.0], [104.0, 714.0]]], "lines": ["しゃかた"]}, {"box": [198, 659, 214, 746], "vertical": true, "font_size": 16, "lines_coords": [[[198.0, 659.0], [214.0, 659.0], [214.0, 746.0], [198.0, 746.0]]], "lines": ["ています。"]}, {"box": [249, 658, 262, 697], "vertical": true, "font_size": 13, "lines_coords": [[[249.0, 658.0], [262.0, 658.0], [262.0, 697.0], [249.0, 697.0]]], "lines": ["けんさく"]}, {"box": [87, 659, 103, 1110], "vertical": true, "font_size": 16, "lines_coords": [[[87.0, 659.0], [103.0, 659.0], [103.0, 1110.0], [87.0, 1110.0]]], "lines": ["著者の方はもちろん、その作品にもファンの方々がいる"]}, {"box": [105, 878, 113, 901], "vertical": true, "font_size": 8, "lines_coords": [[[105.0, 878.0], [113.0, 878.0], [113.0, 901.0], [105.0, 901.0]]], "lines": ["ひァ"]}, {"box": [121, 658, 141, 1114], "vertical": true, "font_size": 20, "lines_coords": [[[121.0, 658.0], [141.0, 658.0], [141.0, 1114.0], [121.0, 1114.0]]], "lines": ["から外れないように演じようと心がけています。原作"]}, {"box": [179, 802, 187, 846], "vertical": true, "font_size": 8, "lines_coords": [[[179.0, 802.0], [187.0, 802.0], [187.0, 846.0], [179.0, 846.0]]], "lines": ["ぎくひ"]}, {"box": [160, 658, 189, 1110], "vertical": true, "font_size": 14.5, "lines_coords": [[[177.0, 659.0], [189.0, 659.0], [189.0, 747.0], [177.0, 747.0]], [[160.0, 658.0], [177.0, 658.0], [177.0, 1110.0], [160.0, 1110.0]]], "lines": ["ありがらすんで！", "有村、原作のある作品ということで、原作のテイスト"]}, {"box": [234, 657, 262, 1109], "vertical": true, "font_size": 14.5, "lines_coords": [[[249.0, 793.0], [262.0, 793.0], [262.0, 833.0], [249.0, 833.0]], [[234.0, 657.0], [250.0, 657.0], [250.0, 1109.0], [234.0, 1109.0]]], "lines": ["しつれ", "原作のドラマ『失恋ショコラティエーにも出演され"]}, {"box": [362, 659, 373, 693], "vertical": true, "font_size": 11, "lines_coords": [[[362.0, 659.0], [373.0, 659.0], [373.0, 693.0], [362.0, 693.0]]], "lines": ["ふふっふふん"]}, {"box": [287, 812, 298, 850], "vertical": true, "font_size": 11, "lines_coords": [[[287.0, 812.0], [298.0, 812.0], [298.0, 850.0], [287.0, 850.0]]], "lines": ["ありむら"]}, {"box": [269, 657, 363, 1113], "vertical": true, "font_size": 18.666666666666668, "lines_coords": [[[341.0, 657.0], [361.0, 657.0], [363.0, 1110.0], [343.0, 1110.0]], [[307.0, 660.0], [323.0, 660.0], [323.0, 1081.0], [307.0, 1081.0]], [[269.0, 677.0], [289.0, 677.0], [289.0, 1113.0], [269.0, 1113.0]]], "lines": ["大今、本当にありがとうごごさいます。そこまで読み込み", "んでいただけると、かえって恥ずかしいですね（笑）", "「そういえば、有村さんは今月スタートのマンガ"]}, {"box": [380, 658, 397, 978], "vertical": true, "font_size": 17, "lines_coords": [[[380.0, 658.0], [397.0, 658.0], [397.0, 978.0], [380.0, 978.0]]], "lines": ["硝子」を演してみたいな、と思いました"]}, {"box": [416, 658, 471, 1113], "vertical": true, "font_size": 18.5, "lines_coords": [[[454.0, 658.0], [471.0, 658.0], [471.0, 1113.0], [454.0, 1113.0]], [[416.0, 658.0], [436.0, 658.0], [436.0, 1113.0], [416.0, 1113.0]]], "lines": ["しんでいて、すごく共感できるんです。一ああいう表情", "になるような気持ちってあるよね」って。いつか「西宮"]}, {"box": [491, 658, 507, 1112], "vertical": true, "font_size": 16, "lines_coords": [[[491.0, 658.0], [507.0, 658.0], [507.0, 1112.0], [491.0, 1112.0]]], "lines": ["験者としては、やさしさが、まなさしや口角の角度にに"]}, {"box": [538, 656, 560, 697], "vertical": false, "font_size": 41, "lines_coords": [[[538.0, 656.0], [560.0, 656.0], [560.0, 697.0], [538.0, 697.0]]], "lines": ["有村"]}, {"box": [521, 651, 588, 1114], "vertical": true, "font_size": 30.0, "lines_coords": [[[556.0, 651.0], [588.0, 651.0], [588.0, 864.0], [556.0, 864.0]], [[521.0, 652.0], [549.0, 652.0], [549.0, 1114.0], [521.0, 1114.0]]], "lines": ["大今、コクリ（うなずく）", "有村「あそこまでひどい目には遭っていないけど、経"]}, {"box": [600, 657, 620, 1046], "vertical": true, "font_size": 20, "lines_coords": [[[600.0, 657.0], [620.0, 657.0], [620.0, 1046.0], [600.0, 1046.0]]], "lines": ["に、その真剣さが伝わる面はあるんでしょうね。"]}, {"box": [633, 653, 733, 1115], "vertical": true, "font_size": 27.333333333333332, "lines_coords": [[[703.0, 658.0], [731.0, 658.0], [733.0, 1114.0], [705.0, 1114.0]], [[668.0, 656.0], [696.0, 656.0], [696.0, 776.0], [668.0, 776.0]], [[633.0, 653.0], [659.0, 653.0], [659.0, 1115.0], [633.0, 1115.0]]], "lines": ["「硯子ちゃんのやさしさが表情から感じられるん", "です」〈有心〉", "有村っただ、ふたん怒らないからこそ、いざ怒ったとき、"]}, {"box": [105, 1038, 113, 1052], "vertical": false, "font_size": 14, "lines_coords": [[[105.0, 1038.0], [113.0, 1038.0], [113.0, 1052.0], [105.0, 1052.0]]], "lines": ["がた"]}], "img_path": "190.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [52, 20, 286, 101], "vertical": false, "font_size": 28, "lines_coords": [[[52.0, 42.0], [273.0, 21.0], [275.0, 45.0], [55.0, 66.0]], [[58.0, 70.0], [282.0, 46.0], [286.0, 78.0], [62.0, 101.0]]], "lines": ["大今良時ｘ右村架純", "『聲の形』対談"]}, {"box": [417, 120, 717, 602], "vertical": true, "font_size": 19, "lines_coords": [[[692.0, 134.0], [710.0, 134.0], [711.0, 483.0], [693.0, 483.0]], [[654.0, 132.0], [677.0, 132.0], [677.0, 591.0], [654.0, 591.0]], [[618.0, 134.0], [636.0, 134.0], [637.0, 421.0], [620.0, 421.0]], [[582.0, 135.0], [602.0, 135.0], [602.0, 591.0], [582.0, 591.0]], [[546.0, 134.0], [566.0, 134.0], [566.0, 590.0], [546.0, 590.0]], [[511.0, 137.0], [527.0, 137.0], [527.0, 589.0], [511.0, 589.0]], [[472.0, 135.0], [492.0, 135.0], [492.0, 480.0], [472.0, 480.0]], [[436.0, 135.0], [456.0, 135.0], [456.0, 480.0], [436.0, 480.0]]], "lines": ["わけで、その期待を裏切りたくないんです。", "大今原作モノならではの難しさはありますよね。ど", "うしても比べられてくしまいますし。", "有村「事前に脚本や原作に沿って演技ブランを練り", "込んだとしても、現場に行くと想像と少し違うセット", "があって、他の俳優さんの芝居も想像と違ったりする", "ことがあります。そういうときは、なる", "べく現場の感覚を大切にするようにし"]}, {"box": [67, 132, 419, 482], "vertical": true, "font_size": 21.5, "lines_coords": [[[398.0, 134.0], [419.0, 134.0], [419.0, 220.0], [398.0, 220.0]], [[359.0, 132.0], [383.0, 132.0], [383.0, 479.0], [359.0, 479.0]], [[325.0, 134.0], [345.0, 134.0], [345.0, 480.0], [325.0, 480.0]], [[289.0, 135.0], [309.0, 135.0], [309.0, 480.0], [289.0, 480.0]], [[252.0, 135.0], [271.0, 135.0], [271.0, 348.0], [252.0, 348.0]], [[214.0, 152.0], [234.0, 152.0], [234.0, 479.0], [214.0, 479.0]], [[175.0, 134.0], [199.0, 134.0], [199.0, 480.0], [175.0, 480.0]], [[141.0, 135.0], [161.0, 135.0], [161.0, 332.0], [141.0, 332.0]], [[100.0, 132.0], [127.0, 132.0], [127.0, 482.0], [100.0, 482.0]], [[67.0, 138.0], [87.0, 138.0], [87.0, 480.0], [67.0, 480.0]]], "lines": ["ています。", "大きくわかる気がします。私もネームの", "段階とベン入れの段階で違和感があった", "ら、その感覚に従って考え直したり、描き", "直すこともありますから。", "「聲の形」も読み切りで掲載したもの", "を一度リメイクした上で、連載時にもう", "一度描き直しています。", "大多・難しい作業でしたが、今は、むしろ", "一番よい形で連載を始めさせてもらった"]}, {"box": [508, 649, 721, 1112], "vertical": true, "font_size": 20, "lines_coords": [[[691.0, 656.0], [711.0, 656.0], [711.0, 1110.0], [691.0, 1110.0]], [[655.0, 655.0], [675.0, 655.0], [675.0, 1112.0], [655.0, 1112.0]], [[620.0, 656.0], [636.0, 656.0], [636.0, 960.0], [620.0, 960.0]], [[577.0, 652.0], [604.0, 652.0], [604.0, 989.0], [577.0, 989.0]], [[543.0, 653.0], [563.0, 653.0], [565.0, 990.0], [545.0, 990.0]], [[508.0, 655.0], [528.0, 655.0], [528.0, 943.0], [508.0, 943.0]]], "lines": ["と思っています。読み切りを支持してくれた読者の", "方々のおかげです。開き直って、自分の感じるままに好き", "きなように描かせていいただきました。", "有村、演技にしても、作品作りにしっも、", "いじめも含めた人間関係も、「感じる心」", "が一番大切なのかもしれませんね。"]}, {"box": [441, 1011, 635, 1102], "vertical": false, "font_size": 13, "lines_coords": [[[441.0, 1011.0], [509.0, 1011.0], [509.0, 1024.0], [441.0, 1024.0]], [[441.0, 1028.0], [557.0, 1028.0], [557.0, 1044.0], [441.0, 1044.0]], [[443.0, 1050.0], [547.0, 1050.0], [547.0, 1061.0], [443.0, 1061.0]], [[443.0, 1069.0], [630.0, 1069.0], [630.0, 1081.0], [443.0, 1081.0]], [[441.0, 1085.0], [611.0, 1087.0], [611.0, 1102.0], [441.0, 1100.0]]], "lines": ["撮影：大江麻雲", "スタイリング・瀬川結美子", "ヘアメイク早白いずっ", "精戌松涌達也＋誤影真奈美（馬場企画", "デザイン高木粉園（ＲｅｄＲｏｏｓｔａｒ"]}, {"box": [69, 946, 394, 1110], "vertical": false, "font_size": 35, "lines_coords": [[[99.0, 946.0], [158.0, 946.0], [158.0, 1006.0], [99.0, 1006.0]], [[69.0, 946.0], [109.0, 946.0], [109.0, 1006.0], [69.0, 1006.0]], [[141.0, 958.0], [236.0, 958.0], [236.0, 1006.0], [141.0, 1006.0]], [[72.0, 1005.0], [391.0, 1005.0], [391.0, 1033.0], [72.0, 1033.0]], [[71.0, 1033.0], [391.0, 1037.0], [391.0, 1060.0], [71.0, 1057.0]], [[70.0, 1058.0], [391.0, 1055.0], [391.0, 1083.0], [70.0, 1086.0]], [[75.0, 1089.0], [370.0, 1089.0], [370.0, 1109.0], [75.0, 1109.0]], [[335.0, 1086.0], [361.0, 1086.0], [361.0, 1095.0], [335.0, 1095.0]]], "lines": ["お", "有", "架純", "１９９３年生まれ。「ＳＰＥＣ－＿警視庁公安部公安第五課", "末詳事件特別対策係事件簿トリシリーズや、「あまり", "ちゃん．．等での好演が話題となる。初の写真集", "『深呼吸』ＳｈｉｎＫｏｋｙに〈集英社刊〉も発売中", "はい．．．"]}], "img_path": "191.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [104, 574, 695, 591], "vertical": false, "font_size": 16, "lines_coords": [[[104.0, 574.0], [695.0, 575.0], [695.0, 591.0], [104.0, 590.0]]], "lines": ["茨城録されている表現は、作品の執筆年代・執筆された状況を考慮し、"]}, {"box": [126, 608, 481, 623], "vertical": false, "font_size": 15, "lines_coords": [[[126.0, 608.0], [481.0, 608.0], [481.0, 623.0], [126.0, 623.0]]], "lines": ["コミックス発売当時のまま掲載しています。"]}], "img_path": "192.png"}, {"version": "0.1.7", "img_width": 803, "img_height": 1200, "blocks": [{"box": [365, 341, 543, 377], "vertical": false, "font_size": 34, "lines_coords": [[[365.0, 341.0], [543.0, 343.0], [543.0, 377.0], [365.0, 375.0]]], "lines": ["聲の形（６）"]}, {"box": [344, 475, 395, 493], "vertical": false, "font_size": 17.0, "lines_coords": [[[344.0, 475.0], [364.0, 475.0], [364.0, 492.0], [344.0, 492.0]], [[376.0, 476.0], [395.0, 476.0], [395.0, 493.0], [376.0, 493.0]]], "lines": ["著", "者"]}, {"box": [338, 527, 398, 590], "vertical": false, "font_size": 33.0, "lines_coords": [[[373.0, 547.0], [396.0, 547.0], [396.0, 590.0], [373.0, 590.0]], [[338.0, 532.0], [396.0, 527.0], [398.0, 550.0], [341.0, 555.0]]], "lines": ["行者行所", "発行者"]}, {"box": [396, 416, 596, 438], "vertical": false, "font_size": 20, "lines_coords": [[[396.0, 416.0], [596.0, 418.0], [596.0, 438.0], [396.0, 435.0]]], "lines": ["２０１４年１０月１日発行（Ｏ）"]}, {"box": [432, 474, 600, 519], "vertical": false, "font_size": 20.0, "lines_coords": [[[432.0, 474.0], [501.0, 474.0], [501.0, 494.0], [432.0, 494.0]], [[434.0, 499.0], [600.0, 499.0], [600.0, 519.0], [434.0, 519.0]]], "lines": ["大今良時", "©ＹｏｓｈｉｔｏｋｉＯｉｍａ２０１４"]}, {"box": [432, 532, 621, 637], "vertical": false, "font_size": 17.0, "lines_coords": [[[433.0, 533.0], [499.0, 532.0], [499.0, 549.0], [433.0, 550.0]], [[432.0, 569.0], [567.0, 570.0], [567.0, 590.0], [432.0, 589.0]], [[434.0, 596.0], [522.0, 596.0], [522.0, 612.0], [434.0, 612.0]], [[434.0, 622.0], [621.0, 622.0], [621.0, 637.0], [434.0, 637.0]]], "lines": ["清水保雅", "株式会社・講談社", "〒１１２８００１", "東京都文京区音羽２１２２："]}], "img_path": "193.png"}]}