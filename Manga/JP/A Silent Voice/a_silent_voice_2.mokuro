{"version": "0.2.0-beta.6", "title": "A Silent Voice", "title_uuid": "0ef04b72-4228-48b1-ba08-9674badb458b", "volume": "a_silent_voice_2", "volume_uuid": "eba84871-e1b9-4d02-93ba-c1c957a3c43b", "pages": [{"version": "0.1.7", "img_width": 2272, "img_height": 1616, "blocks": [{"box": [1961, 38, 2240, 68], "vertical": false, "font_size": 24, "lines_coords": [[[1965.0, 40.0], [2229.0, 40.0], [2229.0, 66.0], [1965.0, 66.0]]], "lines": ["ＳＢＭ９７８－４－０６－３９５００４－５"]}, {"box": [1075, 4, 1199, 48], "vertical": false, "font_size": 27, "lines_coords": [[[1087.0, 17.0], [1191.0, 17.0], [1191.0, 46.0], [1087.0, 46.0]]], "lines": ["ＫＯＭ－５００４"]}, {"box": [1634, 606, 2153, 679], "vertical": false, "font_size": 80, "lines_coords": [[[1634.0, 599.0], [2153.0, 599.0], [2153.0, 686.0], [1634.0, 686.0]]], "lines": ["「西宮、逃げないでくれ」"]}, {"box": [1615, 605, 2158, 679], "vertical": false, "font_size": 68, "lines_coords": [[[1615.0, 610.0], [2149.0, 606.0], [2149.0, 674.0], [1615.0, 679.0]]], "lines": ["「西宮、逃げないでくれ」"]}, {"box": [1610, 703, 2232, 971], "vertical": false, "font_size": 40, "lines_coords": [[[1619.0, 721.0], [2007.0, 719.0], [2007.0, 765.0], [1619.0, 768.0]], [[1615.0, 759.0], [2067.0, 768.0], [2067.0, 827.0], [1615.0, 819.0]], [[1635.0, 819.0], [1939.0, 805.0], [1941.0, 852.0], [1637.0, 865.0]], [[1610.0, 854.0], [1970.0, 850.0], [1970.0, 885.0], [1610.0, 890.0]], [[1615.0, 883.0], [2007.0, 883.0], [2007.0, 914.0], [1615.0, 914.0]], [[1615.0, 910.0], [1874.0, 912.0], [1874.0, 943.0], [1615.0, 941.0]], [[1621.0, 932.0], [2232.0, 930.0], [2232.0, 961.0], [1621.0, 963.0]]], "lines": ["耳の間こえる少年石田将也", "耳の間こえない転校生西宮様子", "たとえば、日本経営地域では、", "一緒に、いつや「しんせい、さい、ご", "５年後、将也は人生の最後に", "正しいということ、そういえば．．．", "西宮硝子に会わなければいけないと決意する。"]}, {"box": [1626, 1018, 1981, 1068], "vertical": false, "font_size": 38, "lines_coords": [[[1626.0, 1025.0], [1981.0, 1025.0], [1981.0, 1063.0], [1626.0, 1063.0]]], "lines": ["初めて伝わる２の「こえ」"]}, {"box": [1627, 1122, 1963, 1165], "vertical": false, "font_size": 37, "lines_coords": [[[1630.0, 1123.0], [1959.0, 1123.0], [1959.0, 1160.0], [1630.0, 1160.0]]], "lines": ["そして物語は幕を開ける"]}, {"box": [1368, 673, 1538, 1086], "vertical": false, "font_size": 32, "lines_coords": [[[1368.0, 761.0], [1528.0, 756.0], [1528.0, 788.0], [1368.0, 792.0]]], "lines": ["そういえば、"]}, {"box": [2010, 1245, 2067, 1354], "vertical": true, "font_size": 32, "lines_coords": [[[2034.0, 1245.0], [2067.0, 1245.0], [2067.0, 1336.0], [2034.0, 1336.0]], [[2010.0, 1245.0], [2041.0, 1245.0], [2041.0, 1354.0], [2010.0, 1354.0]]], "lines": ["友達に．．．", "なれるか？"]}, {"box": [1733, 1473, 2267, 1600], "vertical": false, "font_size": 53, "lines_coords": [[[1737.0, 1474.0], [2052.0, 1469.0], [2052.0, 1531.0], [1737.0, 1535.0]], [[1741.0, 1538.0], [2249.0, 1538.0], [2249.0, 1591.0], [1741.0, 1591.0]]], "lines": ["５年ぶりの再会。", "将也の「こえ」に備子は．．．。"]}, {"box": [1739, 1360, 1792, 1454], "vertical": true, "font_size": 32, "lines_coords": [[[1761.0, 1360.0], [1792.0, 1360.0], [1792.0, 1445.0], [1761.0, 1445.0]], [[1739.0, 1360.0], [1772.0, 1360.0], [1772.0, 1453.0], [1739.0, 1453.0]]], "lines": ["良かった！", "取り返せて！"]}, {"box": [1402, 1227, 1927, 1354], "vertical": false, "font_size": 46, "lines_coords": [[[1408.0, 1263.0], [1921.0, 1227.0], [1923.0, 1271.0], [1411.0, 1307.0]], [[1417.0, 1307.0], [1874.0, 1278.0], [1877.0, 1325.0], [1420.0, 1354.0]]], "lines": ["近出を待ち受ける新たな人間模様。", "誰だいつら今は、何だった"]}, {"box": [1431, 1362, 1477, 1429], "vertical": true, "font_size": 46, "lines_coords": [[[1431.0, 1362.0], [1477.0, 1362.0], [1477.0, 1429.0], [1431.0, 1429.0]]], "lines": ["知らなかった？"]}, {"box": [1399, 1433, 1464, 1546], "vertical": true, "font_size": 65, "lines_coords": [[[1399.0, 1433.0], [1464.0, 1433.0], [1464.0, 1546.0], [1399.0, 1546.0]]], "lines": ["硝子と喋るとオレに蹴られるルールがあんの"]}, {"box": [1304, 1513, 1342, 1593], "vertical": true, "font_size": 29, "lines_coords": [[[1304.0, 1518.0], [1333.0, 1513.0], [1342.0, 1589.0], [1313.0, 1593.0]]], "lines": ["はあ！？"]}, {"box": [1108, 1230, 1190, 1588], "vertical": true, "font_size": 82, "lines_coords": [[[1108.0, 1230.0], [1190.0, 1230.0], [1190.0, 1588.0], [1108.0, 1588.0]]], "lines": ["大今良時"]}, {"box": [301, 330, 667, 395], "vertical": false, "font_size": 54, "lines_coords": [[[303.0, 330.0], [667.0, 341.0], [665.0, 395.0], [301.0, 384.0]]], "lines": ["こんのかた"]}, {"box": [1066, 260, 1206, 622], "vertical": true, "font_size": 140, "lines_coords": [[[1066.0, 260.0], [1206.0, 260.0], [1206.0, 622.0], [1066.0, 622.0]]], "lines": ["聲の肝"]}, {"box": [1007, 206, 1249, 1653], "vertical": true, "font_size": 222, "lines_coords": [[[1027.0, 206.0], [1249.0, 208.0], [1229.0, 1653.0], [1007.0, 1651.0]]], "lines": ["普段の形に言えるものの大分良時、"]}, {"box": [838, 1256, 1030, 1403], "vertical": false, "font_size": 39, "lines_coords": [[[849.0, 1256.0], [1025.0, 1278.0], [1018.0, 1318.0], [843.0, 1296.0]], [[845.0, 1296.0], [1005.0, 1318.0], [998.0, 1358.0], [838.0, 1336.0]], [[847.0, 1340.0], [989.0, 1362.0], [982.0, 1396.0], [843.0, 1376.0]]], "lines": ["少年と少女の", "青く、切ない", "祈りと再生"]}, {"box": [832, 1511, 1038, 1584], "vertical": false, "font_size": 65, "lines_coords": [[[834.0, 1511.0], [1038.0, 1520.0], [1036.0, 1584.0], [832.0, 1576.0]]], "lines": ["今良時"]}, {"box": [35, 1229, 1062, 1502], "vertical": false, "font_size": 101.33333333333333, "lines_coords": [[[84.0, 1229.0], [678.0, 1240.0], [676.0, 1347.0], [82.0, 1336.0]], [[102.0, 1314.0], [783.0, 1314.0], [783.0, 1467.0], [102.0, 1467.0]], [[35.0, 1458.0], [1062.0, 1458.0], [1062.0, 1502.0], [35.0, 1502.0]]], "lines": ["大切なものを、", "人切なものを壊してしまった。", "１２：２０１２年１２月１１月１７日、東京大震災地区大学大学校の大阪府大阪区代金駅の「アストラブル」"]}, {"box": [126, 1518, 630, 1598], "vertical": false, "font_size": 38.0, "lines_coords": [[[126.0, 1518.0], [625.0, 1518.0], [625.0, 1556.0], [126.0, 1556.0]], [[130.0, 1560.0], [630.0, 1560.0], [630.0, 1598.0], [130.0, 1598.0]]], "lines": ["大人気御礼・スマ一トフォン用", "「警の形」特製壁紙をプレゼント♪"]}], "img_path": "001.png"}, {"version": "0.1.7", "img_width": 2272, "img_height": 1616, "blocks": [{"box": [303, 337, 667, 390], "vertical": fa