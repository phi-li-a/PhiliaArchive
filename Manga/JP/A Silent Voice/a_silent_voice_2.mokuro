[214.0, 844.0], [240.0, 844.0], [240.0, 996.0], [214.0, 996.0]], [[183.0, 844.0], [209.0, 844.0], [209.0, 971.0], [183.0, 971.0]], [[150.0, 845.0], [172.0, 845.0], [172.0, 1021.0], [150.0, 1021.0]]], "lines": ["しかも", "彼女の元彼も", "ヤリチンさ", "負の連鎖だよ．．．"]}], "img_path": "111.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1592, "blocks": [{"box": [798, 121, 889, 272], "vertical": true, "font_size": 46, "lines_coords": [[[823.0, 125.0], [881.0, 121.0], [889.0, 209.0], [831.0, 214.0]], [[798.0, 130.0], [831.0, 130.0], [831.0, 272.0], [798.0, 272.0]]], "lines": ["結絃", "ちょっと"]}, {"box": [147, 679, 191, 775], "vertical": true, "font_size": 34, "lines_coords": [[[150.0, 679.0], [191.0, 680.0], [188.0, 775.0], [147.0, 774.0]]], "lines": ["．．．ぷは"]}, {"box": [525, 435, 610, 600], "vertical": true, "font_size": 27, "lines_coords": [[[587.0, 441.0], [609.0, 441.0], [609.0, 600.0], [587.0, 600.0]], [[551.0, 435.0], [589.0, 435.0], [589.0, 494.0], [551.0, 494.0]], [[525.0, 441.0], [547.0, 441.0], [547.0, 576.0], [525.0, 576.0]]], "lines": ["ショーちゃんに", "これ", "見せてあげて"]}, {"box": [693, 459, 730, 551], "vertical": true, "font_size": 37, "lines_coords": [[[693.0, 459.0], [730.0, 459.0], [730.0, 551.0], [693.0, 551.0]]], "lines": ["ん？"]}, {"box": [74, 764, 101, 948], "vertical": true, "font_size": 34, "lines_coords": [[[74.0, 764.0], [101.0, 764.0], [101.0, 948.0], [74.0, 948.0]]], "lines": ["停学だってよ"]}, {"box": [436, 673, 601, 920], "vertical": true, "font_size": 34, "lines_coords": [[[567.0, 676.0], [601.0, 676.0], [601.0, 771.0], [567.0, 771.0]], [[523.0, 676.0], [551.0, 676.0], [553.0, 918.0], [525.0, 918.0]], [[481.0, 673.0], [514.0, 673.0], [517.0, 918.0], [484.0, 918.0]], [[436.0, 673.0], [475.0, 673.0], [475.0, 771.0], [436.0, 771.0]]], "lines": ["それで", "こんな男と仲良く", "しないようにって", "伝えて"]}, {"box": [313, 985, 467, 1018], "vertical": false, "font_size": 33, "lines_coords": [[[313.0, 985.0], [467.0, 985.0], [467.0, 1018.0], [313.0, 1018.0]]], "lines": ["一公共の場"]}, {"box": [498, 1075, 564, 1092], "vertical": false, "font_size": 17, "lines_coords": [[[498.0, 1075.0], [564.0, 1075.0], [564.0, 1092.0], [498.0, 1092.0]]], "lines": ["プログに書く"]}, {"box": [489, 1105, 640, 1162], "vertical": false, "font_size": 29.5, "lines_coords": [[[492.0, 1130.0], [640.0, 1136.0], [638.0, 1162.0], [491.0, 1156.0]], [[489.0, 1108.0], [632.0, 1105.0], [632.0, 1138.0], [489.0, 1141.0]]], "lines": ["自ようユーアイ使われ方も多様", "言コミュニティ行われちゃませ"]}, {"box": [273, 1391, 450, 1427], "vertical": false, "font_size": 16.0, "lines_coords": [[[273.0, 1391.0], [450.0, 1400.0], [450.0, 1416.0], [273.0, 1406.0]], [[281.0, 1406.0], [394.0, 1411.0], [394.0, 1427.0], [281.0, 1422.0]]], "lines": ["そも俺が言う言葉に聞い合わせたのですが、", "それが知ってるんだけど、自然を解決すること。"]}, {"box": [478, 1170, 652, 1305], "vertical": false, "font_size": 27.857142857142858, "lines_coords": [[[503.0, 1170.0], [637.0, 1175.0], [637.0, 1195.0], [503.0, 1190.0]], [[486.0, 1187.0], [638.0, 1194.0], [638.0, 1214.0], [486.0, 1207.0]], [[486.0, 1220.0], [640.0, 1231.0], [638.0, 1254.0], [484.0, 1243.0]], [[483.0, 1204.0], [640.0, 1211.0], [640.0, 1237.0], [483.0, 1231.0]], [[483.0, 1228.0], [652.0, 1239.0], [648.0, 1299.0], [478.0, 1288.0]], [[484.0, 1259.0], [626.0, 1265.0], [626.0, 1287.0], [484.0, 1281.0]], [[484.0, 1277.0], [638.0, 1282.0], [638.0, 1305.0], [484.0, 1301.0]]], "lines": ["とある投稿に非常が異ならば一番ですか", "とある法構に非難な情から川へ飛び込む少しかーなの言う？", "しかし、彼の書き込みひそめるのではないだ「幸」とは触れるの！！", "俺から川へ飛び込むのしかし、彼の書き込みひそめるのではないだ", "ひそめるのではないだ「俺より変動ある奴」彼がこれを撮った公共様の下には市で飼育さ", "・俺より長寿ある奴。彼がこれを撮った公共援の下にはおで観念さ", "彼がこれを飼った公共構の下には市で銅育さ"]}, {"box": [477, 1315, 641, 1490], "vertical": false, "font_size": 19.857142857142858, "lines_coords": [[[500.0, 1315.0], [637.0, 1323.0], [637.0, 1340.0], [500.0, 1332.0]], [[494.0, 1335.0], [638.0, 1340.0], [638.0, 1357.0], [494.0, 1352.0]], [[495.0, 1369.0], [638.0, 1375.0], [638.0, 1396.0], [495.0, 1389.0]], [[478.0, 1385.0], [640.0, 1393.0], [640.0, 1414.0], [478.0, 1406.0]], [[477.0, 1403.0], [640.0, 1411.0], [640.0, 1433.0], [477.0, 1425.0]], [[478.0, 1420.0], [641.0, 1428.0], [641.0, 1450.0], [478.0, 1442.0]], [[480.0, 1461.0], [638.0, 1470.0], [637.0, 1490.0], [478.0, 1481.0]]], "lines": ["選６日、この場所で進", "「最近ここの時の元気」", "彼の投稿履歴をさかにはこういった", "彼女は桐藤姫をどの過去にもこういった顔だったんだよ", "担当にもしついったんだけどそんな事を？自慢何が結婚しないのに", "なぜそんな事でて自家何か制服にせよ彼の行為", "ラインモラルな芸」"]}], "img_path": "112.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1592, "blocks": [{"box": [620, 152, 658, 212], "vertical": true, "font_size": 38, "lines_coords": [[[620.0, 152.0], [658.0, 152.0], [658.0, 212.0], [620.0, 212.0]]], "lines": ["？"]}, {"box": [596, 607, 719, 727], "vertical": true, "font_size": 35, "lines_coords": [[[671.0, 607.0], [716.0, 607.0], [716.0, 702.0], [671.0, 702.0]], [[635.0, 612.0], [668.0, 612.0], [668.0, 727.0], [635.0, 727.0]], [[596.0, 615.0], [624.0, 615.0], [624.0, 726.0], [596.0, 726.0]]], "lines": ["自分で", "言ってよ", "お母さん"]}], "img_path": "113.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1592, "blocks": [{"box": [814, 104, 952, 359], "vertical": true, "font_size": 57, "lines_coords": [[[890.0, 115.0], [944.0, 115.0], [944.0, 359.0], [890.0, 359.0]], [[822.0, 115.0], [881.0, 116.0], [873.0, 338.0], [814.0, 337.0]]], "lines": ["幸せそうで", "良かった！"]}, {"box": [268, 68, 295, 172], "vertical": true, "font_size": 27, "lines_coords": [[[268.0, 68.0], [295.0, 68.0], [295.0, 172.0], [268.0, 172.0]]], "lines": ["だめだろ"]}, {"box": [54, 340, 166, 438], "vertical": true, "font_size": 24, "lines_coords": [[[133.0, 342.0], [161.0, 342.0], [161.0, 438.0], [133.0, 438.0]], [[97.0, 342.0], [127.0, 340.0], [130.0, 415.0], [101.0, 416.0]], [[79.0, 343.0], [101.0, 343.0], [101.0, 435.0], [79.0, 435.0]], [[54.0, 345.0], [71.0, 345.0], [71.0, 433.0], [54.0, 433.0]]], "lines": ["石田は．．．", "幸せに", "なっちゃ", "ダメだろ"]}, {"box": [808, 680, 879, 772], "vertical": true, "font_size": 41, "lines_coords": [[[836.0, 680.0], [879.0, 680.0], [879.0, 746.0], [836.0, 746.0]], [[808.0, 680.0], [847.0, 680.0], [847.0, 772.0], [808.0, 772.0]]], "lines