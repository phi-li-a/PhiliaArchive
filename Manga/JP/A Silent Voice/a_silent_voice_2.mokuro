37, 579, 1528], "vertical": true, "font_size": 35, "lines_coords": [[[544.0, 1341.0], [579.0, 1341.0], [579.0, 1436.0], [544.0, 1436.0]], [[501.0, 1341.0], [533.0, 1341.0], [533.0, 1465.0], [501.0, 1465.0]], [[454.0, 1337.0], [491.0, 1339.0], [487.0, 1498.0], [449.0, 1496.0]], [[412.0, 1344.0], [440.0, 1344.0], [440.0, 1493.0], [412.0, 1493.0]], [[364.0, 1342.0], [396.0, 1342.0], [396.0, 1528.0], [364.0, 1528.0]]], "lines": ["きっと", "今までの", "「嫌い」とは", "違う「嫌い」", "なんだと思う"]}], "img_path": "191.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1592, "blocks": [{"box": [477, 1170, 565, 1361], "vertical": true, "font_size": 85, "lines_coords": [[[480.0, 1170.0], [565.0, 1172.0], [562.0, 1361.0], [477.0, 1360.0]]], "lines": ["あ．．．"]}, {"box": [474, 1537, 505, 1587], "vertical": false, "font_size": 50, "lines_coords": [[[474.0, 1537.0], [505.0, 1537.0], [505.0, 1587.0], [474.0, 1587.0]]], "lines": ["巻に"]}], "img_path": "192.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1592, "blocks": [{"box": [916, 183, 993, 307], "vertical": true, "font_size": 40, "lines_coords": [[[954.0, 186.0], [993.0, 188.0], [986.0, 307.0], [948.0, 306.0]], [[920.0, 183.0], [960.0, 185.0], [957.0, 279.0], [916.0, 278.0]]], "lines": ["しゃはら", "しゃ．．．"]}, {"box": [510, 29, 602, 592], "vertical": true, "font_size": 92, "lines_coords": [[[510.0, 29.0], [602.0, 29.0], [602.0, 592.0], [510.0, 592.0]]], "lines": ["聞びめぐりあう"]}, {"box": [131, 204, 345, 270], "vertical": false, "font_size": 54, "lines_coords": [[[133.0, 216.0], [345.0, 216.0], [345.0, 270.0], [133.0, 270.0]]], "lines": ["次巻予告"]}, {"box": [1002, 546, 1032, 622], "vertical": true, "font_size": 30, "lines_coords": [[[1002.0, 546.0], [1032.0, 546.0], [1032.0, 622.0], [1002.0, 622.0]]], "lines": ["どうも．．．"]}, {"box": [10, 1246, 578, 1536], "vertical": false, "font_size": 40, "lines_coords": [[[441.0, 1246.0], [498.0, 1246.0], [498.0, 1268.0], [441.0, 1268.0]], [[376.0, 1296.0], [543.0, 1296.0], [543.0, 1318.0], [376.0, 1318.0]], [[268.0, 1448.0], [323.0, 1448.0], [323.0, 1466.0], [268.0, 1466.0]], [[105.0, 1347.0], [237.0, 1347.0], [237.0, 1368.0], [105.0, 1368.0]], [[46.0, 1267.0], [516.0, 1268.0], [516.0, 1295.0], [46.0, 1293.0]], [[46.0, 1296.0], [228.0, 1296.0], [228.0, 1318.0], [46.0, 1318.0]], [[45.0, 1316.0], [571.0, 1316.0], [571.0, 1347.0], [45.0, 1347.0]], [[43.0, 1357.0], [452.0, 1363.0], [452.0, 1405.0], [43.0, 1399.0]], [[12.0, 1377.0], [523.0, 1380.0], [522.0, 1536.0], [10.0, 1532.0]]], "lines": ["はうや", "はうやっ、しばらかっこう", "うんめい", "どうやらせいでしょうか", "「硝子のために生きると決めた将也。", "しょう．．．ごめ．．．なか", "硝子の願いを叶えるため、将也は小学校の", "頃の同級生を探すことになり．．．。", "時の同級生後終わりとしたんだもう一度、過去と向き合おうとする２人に待ち受ける運命は、？"]}], "img_path": "193.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1592, "blocks": [{"box": [104, 135, 826, 342], "vertical": false, "font_size": 21, "lines_coords": [[[104.0, 135.0], [694.0, 135.0], [694.0, 155.0], [104.0, 155.0]], [[105.0, 163.0], [826.0, 163.0], [826.0, 183.0], [105.0, 183.0]], [[107.0, 192.0], [183.0, 192.0], [183.0, 214.0], [107.0, 214.0]], [[108.0, 228.0], [592.0, 228.0], [592.0, 250.0], [108.0, 250.0]], [[104.0, 262.0], [562.0, 259.0], [562.0, 286.0], [104.0, 289.0]], [[104.0, 293.0], [654.0, 295.0], [654.0, 317.0], [104.0, 315.0]], [[105.0, 320.0], [655.0, 321.0], [655.0, 342.0], [105.0, 340.0]]], "lines": ["編集部では、この作品に対する皆様のご意見・ご感想をお待ちしております。", "また「講談社コミックスにまとめてほしい作品がありましたら、編集部までお知らせください。", "あて先", "〒１２－８００１東京都文京区音羽２－１２－２１講談社", "週刊少年マガジン編集部「少年マガジンＫＣ｜係", "なお、お送りいただいたお手紙・おハガキはご記入いただいった個人情報を含めて", "著者にお渡しすることがありますのであらかじめご了解のうえ、お送りください。"]}, {"box": [107, 385, 707, 401], "vertical": false, "font_size": 21, "lines_coords": [[[107.0, 385.0], [707.0, 385.0], [707.0, 401.0], [107.0, 401.0]]], "lines": ["★この物語はフィクションであり、実在の人物団体・出来事などとは一切関係ありません"]}, {"box": [107, 427, 534, 443], "vertical": false, "font_size": 21, "lines_coords": [[[107.0, 427.0], [534.0, 427.0], [534.0, 443.0], [107.0, 443.0]]], "lines": ["年間初出週刊少年マガジン２０１３年第２号〜第５０号"]}, {"box": [230, 558, 387, 578], "vertical": false, "font_size": 20, "lines_coords": [[[230.0, 558.0], [387.0, 558.0], [387.0, 578.0], [230.0, 578.0]]], "lines": ["講談社コミック"]}, {"box": [220, 592, 410, 674], "vertical": false, "font_size": 48.0, "lines_coords": [[[309.0, 592.0], [368.0, 592.0], [368.0, 621.0], [309.0, 621.0]], [[220.0, 607.0], [410.0, 607.0], [410.0, 674.0], [220.0, 674.0]]], "lines": ["かたち", "聲の形２"]}, {"box": [230, 736, 815, 761], "vertical": false, "font_size": 22, "lines_coords": [[[230.0, 736.0], [815.0, 740.0], [815.0, 761.0], [230.0, 758.0]]], "lines": ["２０１４年１月１７日第１刷発行＿定価は外貼りㇱ一ルに表示してあります）"]}, {"box": [226, 831, 295, 856], "vertical": false, "font_size": 22, "lines_coords": [[[226.0, 834.0], [293.0, 831.0], [295.0, 853.0], [228.0, 856.0]]], "lines": ["者著"]}, {"box": [223, 987, 303, 1052], "vertical": false, "font_size": 32, "lines_coords": [[[228.0, 987.0], [298.0, 987.0], [298.0, 1016.0], [228.0, 1016.0]], [[223.0, 1018.0], [301.0, 1015.0], [303.0, 1049.0], [225.0, 1052.0]]], "lines": ["発行者", "発行所"]}, {"box": [369, 808, 562, 890], "vertical": false, "font_size": 25, "lines_coords": [[[369.0, 808.0], [500.0, 808.0], [500.0, 830.0], [369.0, 830.0]], [[373.0, 827.0], [502.0, 827.0], [502.0, 859.0], [373.0, 859.0]], [[373.0, 869.0], [561.0, 869.0], [561.0, 889.0], [373.0, 889.0]]], "lines": ["おおいまよしとき", "大今良時", "ＣｙｏｓｈｉｔｏｋｉＯｉｎｎａ２０１４"]}, {"box": [369, 987, 764, 1119], "vertical": false, "font_size": 25.5, "lines_coords": [[[369.0, 987.0], [463.0, 987.0], [463.0, 1013.0], [369.0, 1013.0]], [[373.0, 1024.0], [547.0, 1024.0], [547.0, 1046.0], [373.0, 1046.0]], [[371.0, 1055.0], [764.0, 1058.0], [764.0, 1085.0], [371.0, 1082.0]], [[371.0, 1092.0], [756.0, 1092.0], [756.0, 1119.0], [371.0, 1119.0]]], "lines": ["清水保雅", "株式会社講談社", "〒１１２－８０１東京都文京区音羽２－１２－２１", "電話番号編集部東京（０３５９５－３５）"]}, {"box": [477, 1128, 756, 1190], "vertical": false, "font_size": 26.5, "lines_coords": [[[477.0, 1128.0], [756.0, 1128.0], [756.0, 1155.0], [477.0, 1155.0]], [[477.0, 1164.0], [756.0, 1164.0], [756.0, 1190.0], [477.0, 1190.0]]], "l