ont_size": 21, "lines_coords": [[[242.0, 10.0], [414.0, 10.0], [414.0, 31.0], [242.0, 31.0]]], "lines": ["月間ランキング第８位"]}, {"box": [116, 54, 980, 202], "vertical": false, "font_size": 70.5, "lines_coords": [[[116.0, 54.0], [980.0, 60.0], [980.0, 138.0], [116.0, 132.0]], [[135.0, 125.0], [944.0, 139.0], [944.0, 202.0], [135.0, 188.0]]], "lines": ["「俺より度胸ある奴いんの？」", "一公共の場での迷惑行為を自慢一"]}, {"box": [430, 237, 719, 253], "vertical": false, "font_size": 16, "lines_coords": [[[430.0, 237.0], [719.0, 237.0], [719.0, 253.0], [430.0, 253.0]]], "lines": ["．．．あああっはああ"]}, {"box": [422, 253, 943, 276], "vertical": false, "font_size": 22, "lines_coords": [[[422.0, 253.0], [943.0, 254.0], [943.0, 276.0], [422.0, 275.0]]], "lines": ["プログに書く０つぶやく！２．おすすめする。９このページを印刷"]}, {"box": [424, 301, 833, 362], "vertical": false, "font_size": 29.0, "lines_coords": [[[425.0, 301.0], [833.0, 301.0], [833.0, 328.0], [425.0, 328.0]], [[424.0, 328.0], [789.0, 331.0], [789.0, 362.0], [424.0, 359.0]]], "lines": ["勝コミュニティサイトが流行る今日、", "使われ方も多様である．．．。"]}, {"box": [533, 214, 899, 236], "vertical": false, "font_size": 20, "lines_coords": [[[533.0, 214.0], [899.0, 216.0], [899.0, 236.0], [533.0, 234.0]]], "lines": ["携帯出来る育毛剤に興味はありませんか？［ＰＲ］"]}, {"box": [89, 679, 395, 719], "vertical": false, "font_size": 18, "lines_coords": [[[91.0, 682.0], [391.0, 679.0], [391.0, 699.0], [91.0, 702.0]], [[91.0, 702.0], [315.0, 699.0], [315.0, 716.0], [91.0, 719.0]]], "lines": ["この男子生徒が通う高校に問い合わせた所", "現在事実関係を調査中とのこと。"]}, {"box": [425, 520, 794, 541], "vertical": false, "font_size": 21, "lines_coords": [[[425.0, 520.0], [794.0, 520.0], [794.0, 541.0], [425.0, 541.0]]], "lines": ["橋の下には市で詞言されている時間がいる。"]}, {"box": [435, 564, 916, 610], "vertical": false, "font_size": 21.0, "lines_coords": [[[442.0, 565.0], [916.0, 564.0], [916.0, 586.0], [442.0, 587.0]], [[435.0, 590.0], [763.0, 587.0], [763.0, 607.0], [435.0, 610.0]]], "lines": ["週３日、この場所で壁に飯をあげている高須さんは言う。", "「最近ここの鯉の元気が無い．．．」"]}, {"box": [390, 371, 1050, 519], "vertical": false, "font_size": 52.6, "lines_coords": [[[441.0, 380.0], [736.0, 380.0], [736.0, 402.0], [441.0, 402.0]], [[390.0, 371.0], [1050.0, 371.0], [1050.0, 506.0], [390.0, 506.0]], [[450.0, 421.0], [994.0, 408.0], [994.0, 450.0], [450.0, 463.0]], [[419.0, 460.0], [691.0, 467.0], [690.0, 509.0], [418.0, 502.0]], [[424.0, 497.0], [996.0, 494.0], [996.0, 516.0], [424.0, 519.0]]], "lines": ["とある投稿に弁護が発習している。橋から川へ飛び込む少空。一見くの", "そうか．．．そうだな。そうなんだけど、そういうことはありませんでしょうかもしれないのですが、それではないですから、そんなことなんですね。それはあなたが、これでもうないうですよ。", "それ以外の報告も楽しましたが、あまりにもかかったのですが、初めてご利用されておりませんが、このようなことがあるのではないでしょうか。", "ひそめるのではないだろうか。「俺より腹痛みる良いんの？」彼がこれを振った公共の広場には", "俺より英解ある気にいんの？彼がこれを振った公共の広場には、橋の下には市で写真さんでしょう。市民が利用する小さな横がある。がいろ。"]}, {"box": [428, 631, 1024, 680], "vertical": false, "font_size": 21.333333333333332, "lines_coords": [[[444.0, 637.0], [901.0, 631.0], [901.0, 652.0], [444.0, 659.0]], [[428.0, 660.0], [680.0, 660.0], [680.0, 680.0], [428.0, 680.0]], [[669.0, 656.0], [1024.0, 652.0], [1024.0, 674.0], [669.0, 677.0]]], "lines": ["彼の投稿展展をさかのぼってみると、今回のみならず、", "過去にもこういった飛び込み", "みーい友樹試しが行われていたのである"]}, {"box": [427, 677, 997, 727], "vertical": false, "font_size": 21.0, "lines_coords": [[[427.0, 684.0], [912.0, 677.0], [912.0, 698.0], [427.0, 704.0]], [[430.0, 705.0], [997.0, 699.0], [997.0, 721.0], [430.0, 727.0]]], "lines": ["なぜそんな事を？自慢？武馬伝？ノリ？勝負？ネタ提供？", "何が動機にせよ彼の行高は世界中に発信されてしまったのである．．．"]}, {"box": [90, 783, 174, 981], "vertical": true, "font_size": 79, "lines_coords": [[[90.0, 783.0], [169.0, 783.0], [169.0, 956.0], [90.0, 956.0]]], "lines": ["え？"]}, {"box": [371, 1173, 444, 1472], "vertical": true, "font_size": 65, "lines_coords": [[[371.0, 1176.0], [436.0, 1175.0], [442.0, 1470.0], [377.0, 1472.0]]], "lines": ["あの時の．．．！？"]}, {"box": [797, 1046, 909, 1358], "vertical": true, "font_size": 89, "lines_coords": [[[797.0, 1052.0], [885.0, 1046.0], [909.0, 1352.0], [820.0, 1358.0]]], "lines": ["これ俺！？"]}], "img_path": "106.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1592, "blocks": [{"box": [119, 163, 277, 447], "vertical": true, "font_size": 45, "lines_coords": [[[233.0, 169.0], [270.0, 169.0], [270.0, 328.0], [233.0, 328.0]], [[172.0, 166.0], [220.0, 166.0], [220.0, 447.0], [172.0, 447.0]], [[122.0, 163.0], [172.0, 163.0], [169.0, 362.0], [119.0, 362.0]]], "lines": ["何これ．．．", "全然頭に入って", "こない．．．"]}, {"box": [556, 161, 679, 203], "vertical": false, "font_size": 19.0, "lines_coords": [[[571.0, 161.0], [674.0, 167.0], [674.0, 185.0], [571.0, 178.0]], [[556.0, 178.0], [679.0, 183.0], [679.0, 203.0], [556.0, 199.0]]], "lines": ["とある投稿に滅び", "このうえ。一度、傷から川へ飛込む。しかし"]}, {"box": [547, 186, 690, 293], "vertical": false, "font_size": 35.0, "lines_coords": [[[554.0, 186.0], [680.0, 195.0], [679.0, 223.0], [553.0, 214.0]], [[557.0, 211.0], [677.0, 214.0], [677.0, 236.0], [557.0, 233.0]], [[559.0, 225.0], [683.0, 225.0], [683.0, 258.0], [559.0, 258.0]], [[548.0, 233.0], [690.0, 236.0], [688.0, 293.0], [547.0, 290.0]]], "lines": ["嫌から川へ飛込むしかし、彼の事を２ひそめるのではな", "しかし、彼の書きてひそめるのではない「熱より変換あるが", "ひそもそのではなく「俺より英語おる！彼がこれを嫌った」", "「俺より皮膚あるが彼がこれを乗った公機の下には市で相資さ"]}, {"box": [671, 160, 814, 457], "vertical": true, "font_size": 68.5, "lines_coords": [[[742.0, 163.0], [808.0, 161.0], [814.0, 455.0], [749.0, 457.0]], [[671.0, 160.0], [742.0, 160.0], [742.0, 379.0], [671.0, 379.0]]], "lines": ["ネットに俺が", "投稿．．．？"]}, {"box": [814, 143, 1000, 163], "vertical": false, "font_size": 17, "lines_coords": [[[814.0, 143.0], [1000.0, 146.0], [1000.0, 163.0], [814.0, 160.0]]], "lines": ["日、使われ方も多様である"]}, {"box": [800, 188, 963, 226], "vertical": false, "font_size": 18.0, "lines_coords": [[[800.0, 188.0], [963.0, 194.0], [963.0, 214.0], [800.0, 208.0]], [[814.0, 206.0], [960.0, 211.0], [960.0, 226.0], [814.0, 222.0]]], "lines": ["貴と思われるかもしれない食べはってーった。", "えーといった大人なら誰を持った犬人なんだら星を"]}, {"box": [829, 310, 896, 365], "vertical": false, "font_size": 42, "lines_coords": [[[829.0, 324.0], [885.0, 310.0], [896.0, 351.0], [840.0, 365.0]]], "lines": ["一時の比判があるから"]}, {"box": [514, 539, 798, 583], "vertical": false, "font_size": 18.0, "lines_coords": [[[543.0, 539.0], [784.0, 547.0], [784.0, 562.0], [543.0, 555.0]], [[514.0, 556.0], [798.0, 562.0], [798.0, 583.0], [514.0, 576.0]]], "lines": ["その環境は何によってやって作られたのかー", "筆者は何やだ！！で今からね"]}, {"box": [512, 477, 1016, 556], "vertical": false, "font_size": 28.8, "lines_coords": [[[728.0, 477.0], [1010.0, 483.0], [1010.0, 505.0], [728.0, 499.0]], [[575.0, 491.0], [783.0, 491.0], [783.0, 522.0], [575.0, 522.0]], [[512.0, 494.0], [592.0, 494.0], [592.0, 522.0], [512.0, 522.0]], [[533.0, 520.0], [983.0, 536.0], [983.0, 556.0], [533.0, 541.0]], [[784.0, 499.0], [1016.0, 499.0], [1016.0, 542.0], [784.0, 542.0]]], "lines": ["当社の社長が大丈夫で、うした危険", "おまえはまあまあ食べてるのは", "あだめて", "日本の投資が、この時間が、ごめいった結婚相談は何でよ。では東京都市東京東京駅からのお世話番号へと盛り立てるのではないか。", "実行記事でも実際の新しいというのは"]}, {"box": [839, 382, 943, 418], "vertical": false, "font_size": 16.5, "lines_coords": [[[839.0, 382.0], [910.0, 385.0], [910.0, 402.0], [839.0, 399.0]], [[840.0, 402.0], [943.0, 402.0], [943.0, 418.0], [840.0, 418.0]]], "lines": ["ネタ望快？", "しまったのである"]}, {"box": [812, 415, 1005, 453], "vertical": false, "font_size": 18.5, "lines_coords": [[[812.0, 415.0], [1005.0, 422.0], [1005.0, 444.0], [812.0, 436.0]], [[815.0, 438.0], [923.0, 438.0], [923.0, 453.0], [815.0, 453.0]]], "lines": ["その手段を知って", "．．．うはまたしたら"]}, {"box": [839, 569, 960, 589], "vertical": false, "font_size": 17, "lines_coords": [[[839.0, 569.0], [960.0, 572.0], [960.0, 589.0], [839.0, 586.0]]], "lines": ["ずるその事"]}, {"box": [747, 691, 850, 862], "vertical": true, "font_size": 26, "lines_coords": [[[823.0, 694.0], [850.0, 694.0], [850.0, 803.0], [823.0, 803.0]], [[778.0, 691.0], [806.0, 691.0], [808.0, 862.0], [780.0, 862.0]], [[747.0, 694.0], [774.0, 694.0], [774.0, 806.0], [747.0, 806.0]]], "lines": ["こんなの", "投稿した覚え", "ないしさ"]}, {"box": [932, 621, 988, 778], "vertical": true, "font_size": 26, "lines_coords": [[[958.0, 621.0], [986.0, 621.0], [988.0, 735.0], [960.0, 735.0]], [[932.0, 624.0], [952.0, 624.0], [952.0, 778.0], [932.0, 778.0]]], "lines": ["た．．．確かに", "これ俺だけど．．"]}, {"box": [405, 771, 515, 900], "vertical": true, "font_size": 26, "lines_coords": [[[477.0, 772.0], [505.0, 772.0], [505.0, 900.0], [477.0, 900.0]], [[439.0, 771.0], [467.0, 771.0], [467.0, 875.0], [439.0, 875.0]], [[405.0, 772.0], [427.0, 772.0], [427.0, 897.0], [405.0, 897.0]]], "lines": ["こんな写真", "撮られた", "記憶も．．．"]}, {"box": [792, 1038, 860, 1187], "vertical": true, "font_size": 53, "lines_coords": [[[792.0, 1040.0], [845.0, 1038.0], [848.0, 1186.0], [795.0, 1187.0]]], "lines": ["石田君"]}, {"box": [130, 1180, 299, 1346], "vertical": true, "font_size": 48, "lines_coords": [[[251.0, 1184.0], [299.0, 1184.0], [299.0, 1276.0], [251.0, 1276.0]], [[195.0, 1186.0], [234.0, 1186.0], [234.0, 1346.0], [195.0, 1346.0]], [[130.0, 1181.0], [186.0, 1180.0], [189.0, 1273.0], [133.0, 1274.0]]], "lines": ["すぐ", "職員室に", "来て"]}], "img_path": "107.png"}, {"version": "0.1.7", "img_width": 1032, "img_height": 1592, "blocks": [{"box": [865, 461, 903, 523], "vertical": false, "font_size": 62, "lines_coords": [[[865.0, 461.0], [903.0, 461.0], [903.0, 523.0], [865.0, 523.0]]], "lines": ["ガヤ"]}, {"box": [710, 836, 736, 868], "vertical": true, "font_size": 26, "lines_coords": [[[710.0, 836.0], [736.0, 836.0], [736.0, 868.0], [710.0, 868.0]]], "lines": ["生日"]}, {"box": [575, 945, 606, 1191], "vertical": true, "font_size": 22, "lines_coords": [[[579.0, 945.0], [601.0, 945.0], [601.0, 1184.0], [579.0, 1184.0]]], "lines": ["３年Ｂ組「石田将也"]}, {"box": [413, 831, 510, 1334], "vertical": true, "font_size": 28, "lines_coords": [[[480.0, 833.0], [508.0, 833.0], [505.0, 1214.0], [477.0, 1214.0]], [[446.0, 833.0], [477.0, 833.0], [474.0, 1329.0], [442.0, 1329.0]], [[418.0, 831.0], [444.0, 831.0], [439.0, 1215.0], [413.0, 1215.0]]], "lines": ["右のものは、公共の場において", "本校生徒にあるまじき迷惑行為を行った。", "よって一週間の停学処分とする"]}, {"box": [279, 1273, 317, 1333], "vertical": true, "font_size": 38, "lines_coords": [[[279.0, 1273.0], [317.0, 1273.0], [317.0, 1333.0], [279.0, 1333.0]]], "lines": ["校長"]}], "img_p