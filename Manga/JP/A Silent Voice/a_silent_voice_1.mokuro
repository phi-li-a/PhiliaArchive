{"version": "0.2.0-beta.6", "title": "A Silent Voice", "title_uuid": "0ef04b72-4228-48b1-ba08-9674badb458b", "volume": "a_silent_voice_1", "volume_uuid": "1c5c186f-b5bc-4a0b-a7db-b364c49fd073", "pages": [{"version": "0.1.7", "img_width": 2848, "img_height": 2016, "blocks": [{"box": [0, 1420, 1243, 1943], "vertical": false, "font_size": 320.0, "lines_coords": [[[0.0, 1420.0], [1243.0, 1420.0], [1243.0, 1943.0], [0.0, 1943.0]], [[712.0, 1796.0], [1198.0, 1796.0], [1198.0, 1913.0], [712.0, 1913.0]]], "lines": ["お前なんかに出会わなきゃよかった。", "会いたい。"]}, {"box": [33, 1938, 945, 1993], "vertical": false, "font_size": 47, "lines_coords": [[[33.0, 1946.0], [945.0, 1938.0], [945.0, 1985.0], [33.0, 1993.0]]], "lines": ["上記録・第１番発売記念・特製Ｗｅｂアイコンをプレゼント！！"]}, {"box": [891, 1525, 1302, 1641], "vertical": false, "font_size": 36, "lines_coords": [[[892.0, 1565.0], [1220.0, 1565.0], [1220.0, 1601.0], [892.0, 1601.0]]], "lines": ["カケラたち。最高に切なく"]}, {"box": [893, 1526, 1304, 1642], "vertical": false, "font_size": 30, "lines_coords": [[[901.0, 1530.0], [1257.0, 1530.0], [1257.0, 1561.0], [901.0, 1561.0]], [[898.0, 1605.0], [1293.0, 1605.0], [1293.0, 1637.0], [898.0, 1637.0]]], "lines": ["余りにもみずみずしい青春の", "心ゆさぶる物語が生まれました。"]}, {"box": [1070, 1924, 1307, 1988], "vertical": false, "font_size": 58, "lines_coords": [[[1070.0, 1929.0], [1307.0, 1924.0], [1307.0, 1982.0], [1070.0, 1988.0]]], "lines": ["今良時"]}, {"box": [1432, 308, 1501, 467], "vertical": true, "font_size": 61, "lines_coords": [[[1432.0, 311.0], [1493.0, 308.0], [1501.0, 464.0], [1440.0, 467.0]]], "lines": ["．．．"]}, {"box": [2457, 47, 2805, 86], "vertical": false, "font_size": 30, "lines_coords": [[[2461.0, 50.0], [2792.0, 50.0], [2792.0, 82.0], [2461.0, 82.0]]], "lines": ["時計１９７８－４０５－３９４４７６５"]}, {"box": [2137, 884, 2721, 949], "vertical": false, "font_size": 58, "lines_coords": [[[2138.0, 884.0], [2703.0, 889.0], [2703.0, 948.0], [2138.0, 942.0]]], "lines": ["俺は彼女お嬢いだった"]}, {"box": [2091, 1295, 2646, 1434], "vertical": false, "font_size": 39, "lines_coords": [[[2091.0, 1304.0], [2603.0, 1318.0], [2603.0, 1376.0], [2091.0, 1362.0]], [[2097.0, 1376.0], [2611.0, 1384.0], [2611.0, 1434.0], [2097.0, 1426.0]], [[2236.0, 1362.0], [2380.0, 1356.0], [2380.0, 1384.0], [2236.0, 1390.0]], [[2391.0, 1362.0], [2450.0, 1362.0], [2450.0, 1382.0], [2391.0, 1382.0]]], "lines": ["２人の出会いか、教室を、学校を、", "そして将也の人生を変えていく", "やっぱりじんじゃない", "．．．"]}, {"box": [2101, 987, 2649, 1112], "vertical": false, "font_size": 51, "lines_coords": [[[2110.0, 1001.0], [2472.0, 992.0], [2472.0, 1048.0], [2110.0, 1056.0]], [[2102.0, 1065.0], [2544.0, 1056.0], [2544.0, 1103.0], [2102.0, 1112.0]]], "lines": ["明るく、楽しく「大冒険", "がモットーの少年、でも、思ってた。"]}, {"box": [2077, 1170, 2767, 1243], "vertical": false, "font_size": 64, "lines_coords": [[[2077.0, 1179.0], [2767.0, 1170.0], [2767.0, 1234.0], [2077.0, 1242.0]]], "lines": ["耳の聞こえない転校生の少女、西宮硝子"]}, {"box": [1371, 1535, 1480, 1975], "vertical": true, "font_size": 105, "lines_coords": [[[1371.0, 1537.0], [1476.0, 1537.0], [1476.0, 1960.0], [1371.0, 1960.0]]], "lines": ["大今良時"]}, {"box": [1532, 1529, 2125, 1657], "vertical": false, "font_size": 62, "lines_coords": [[[1535.0, 1543.0], [1834.0, 1524.0], [1837.0, 1588.0], [1538.0, 1608.0]], [[1538.0, 1593.0], [2115.0, 1554.0], [2118.0, 1622.0], [1540.0, 1661.0]]], "lines": ["ある決意を胸に、ロケットボスと", "ある大鳥を剛上、６年ぶりに消子と再会した将也。"]}, {"box": [1795, 1838, 2357, 2000], "vertical": false, "font_size": 49, "lines_coords": [[[1994.0, 1834.0], [2124.0, 1834.0], [2124.0, 1872.0], [1994.0, 1872.0]], [[1813.0, 1867.0], [2344.0, 1867.0], [2344.0, 1933.0], [1813.0, 1933.0]], [[1807.0, 1936.0], [2355.0, 1936.0], [2355.0, 1992.0], [1807.0, 1992.0]]], "lines": ["そんなことないと", "１痛みとともに途切れた", "２人の時が再び動き出す"]}], "img_path": "001.png"}, {"version": "0.1.7", "img_width": 2848, "img_height": 2016, "blocks": [{"box": [2451, 43, 2799, 90], "vertical": false, "font_size": 30, "lines_coords": [[[2458.0, 50.0], [2789.0, 50.0], [2789.0, 82.0], [2458.0, 82.0]]], "lines": ["１８５００７８－４０５－３９４４７６５"]}, {"box": [1356, -