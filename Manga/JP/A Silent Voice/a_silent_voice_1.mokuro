, [831.0, 245.0], [831.0, 335.0], [780.0, 335.0]], [[727.0, 243.0], [778.0, 243.0], [778.0, 374.0], [727.0, 374.0]]], "lines": ["くそ", "なんで"]}, {"box": [449, 235, 601, 411], "vertical": true, "font_size": 42, "lines_coords": [[[552.0, 237.0], [601.0, 237.0], [601.0, 368.0], [552.0, 368.0]], [[501.0, 239.0], [543.0, 239.0], [543.0, 405.0], [501.0, 405.0]], [[450.0, 237.0], [486.0, 237.0], [486.0, 407.0], [450.0, 407.0]]], "lines": ["こんな", "カオじゃ", "ダメだ！"]}, {"box": [211, 1566, 352, 1906], "vertical": true, "font_size": 126, "lines_coords": [[[211.0, 1568.0], [337.0, 1566.0], [343.0, 1904.0], [217.0, 1906.0]]], "lines": ["西宮！"]}], "img_path": "170.png"}, {"version": "0.1.7", "img_width": 1296, "img_height": 2008, "blocks": [], "img_path": "171.png"}, {"version": "0.1.7", "img_width": 1296, "img_height": 2008, "blocks": [], "img_path": "172.png"}, {"version": "0.1.7", "img_width": 1296, "img_height": 2008, "blocks": [{"box": [488, 1923, 747, 1979], "vertical": false, "font_size": 27, "lines_coords": [[[523.0, 1941.0], [647.0, 1945.0], [647.0, 1972.0], [523.0, 1968.0]]], "lines": ["＞巻につ"]}], "img_path": "173.png"}, {"version": "0.1.7", "img_width": 1296, "img_height": 2008, "blocks": [{"box": [854, 293, 1129, 382], "vertical": false, "font_size": 71, "lines_coords": [[[856.0, 311.0], [1121.0, 301.0], [1123.0, 372.0], [858.0, 382.0]]], "lines": ["次巻予告"]}, {"box": [474, 1098, 635, 1634], "vertical": true, "font_size": 153, "lines_coords": [[[482.0, 1098.0], [635.0, 1100.0], [627.0, 1625.0], [474.0, 1623.0]]], "lines": ["葉がある"]}, {"box": [482, 1680, 1282, 1860], "vertical": false, "font_size": 60.0, "lines_coords": [[[1013.0, 1717.0], [1115.0, 1717.0], [1115.0, 1737.0], [1013.0, 1737.0]], [[515.0, 1680.0], [1282.0, 1707.0], [1276.0, 1860.0], [509.0, 1833.0]], [[694.0, 1778.0], [801.0, 1778.0], [801.0, 1800.0], [694.0, 1800.0]], [[482.0, 1794.0], [1245.0, 1794.0], [1245.0, 1839.0], [482.0, 1839.0]]], "lines": ["いざいかいと", "あとは思っていたけど、ついに流行されていますが、一方の研究不安保は大規模に大規にとはどうか．．．", "村也は、どっぜんあらゆ．．．", "一方の硝子は突然現れた将也にとまどうが．．．！？"]}, {"box": [670, 1864, 1227, 1957], "vertical": false, "font_size": 83, "lines_coords": [[[672.0, 1864.0], [1227.0, 1874.0], [1225.0, 1957.0], [670.0, 1947.0]]], "lines": ["２０１６年１月１７日（金）発売"]}], "img_path": "174.png"}, {"version": "0.1.7", "img_width": 1296, "img_height": 2008, "blocks": [{"box": [135, 178, 1033, 433], "vertical": false, "font_size": 25.0, "lines_coords": [[[135.0, 178.0], [864.0, 178.0], [864.0, 203.0], [135.0, 203.0]], [[139.0, 211.0], [1033.0, 209.0], [1033.0, 235.0], [139.0, 237.0]], [[145.0, 251.0], [233.0, 251.0], [233.0, 278.0], [145.0, 278.0]], [[143.0, 294.0], [737.0, 294.0], [737.0, 321.0], [143.0, 321.0]], [[139.0, 339.0], [699.0, 339.0], [699.0, 364.0], [139.0, 364.0]], [[137.0, 378.0], [815.0, 378.0], [815.0, 403.0], [137.0, 403.0]], [[139.0, 413.0], [819.0, 413.0], [819.0, 433.0], [139.0, 433.0]]], "lines": ["編集部では、この作品に対する皆様のご意見・ご感想をお待ちしております。", "また「講談社コミックス」にまとめてほしい作品がありましたら編集部までお知らせください。", "〈あて先〉", "〒１２－８００１東京都文京区音羽２－１２－２１．講談社", "週刊少年マガジン編集部少年マガジンＫＣ＿係", "なお、お送りいただいたお手紙をおハガキは、ご記入いいただいた個人情報を含めて", "著者にお渡しすることがあり、ますので、あらかじめご了解のうえ、お送りください。"]}, {"box": [141, 490, 886, 509], "vertical": false, "font_size": 19, "lines_coords": [[[141.0, 490.0], [886.0, 490.0], [886.0, 509.0], [141.0, 509.0]]], "lines": ["★この物語はフィクションであり、実在の人物団体・出来事などとは一切関係ありません。"]}, {"box": [290, 703, 476, 729], "vertical": false, "font_size": 26, "lines_coords": [[[290.0, 703.0], [476.0, 703.0], [476.0, 729.0], [290.0, 729.0]]], "lines": ["講談社コミック"]}, {"box": [280, 751, 511, 851], "vertical": false, "font_size": 58.0, "lines_coords": [[[398.0, 751.0], [462.0, 751.0], [462.0, 788.0], [398.0, 788.0]], [[280.0, 772.0], [511.0, 772.0], [511.0, 851.0], [280.0, 851.0]]], "lines": ["かたち", "聲の形の"]}, {"box": [137, 537, 1088, 562], "vertical": false, "font_size": 25, "lines_coords": [[[137.0, 537.0], [1088.0, 537.0], [1088.0, 562.0], [137.0, 562.0]]], "lines": ["作品初出／週刊少年マガジ＞２０１３年第６３７合併号〜第１１号、マガジンスペシャル２０１３年いん"]}, {"box": [650, 703, 794, 727], "vertical": false, "font_size": 22, "lines_coords": [[[650.0, 703.0], [794.0, 705.0], [794.0, 727.0], [650.0, 725.0]]], "lines": ["・ＫＣＭ４９７３"]}, {"box": [288, 927, 1021, 956], "vertical": false, "font_size": 26, "lines_coords": [[[288.0, 927.0], [1021.0, 931.0], [1021.0, 956.0], [288.0, 953.0]]], "lines": ["２０１３年１１月１５日第１期発行（定価は外戦）シールに表示してあります）"]}, {"box": [287, 1046, 374, 1078], "vertical": false, "font_size": 27, "lines_coords": [[[288.0, 1049.0], [372.0, 1049.0], [372.0, 1076.0], [288.0, 1076.0]]], "lines": ["著者"]}, {"box": [288, 1241, 378, 1317], "vertical": false, "font_size": 31, "lines_coords": [[[290.0, 1243.0], [372.0, 1243.0], [372.0, 1270.0], [290.0, 1270.0]], [[288.0, 1282.0], [378.0, 1282.0], [378.0, 1317.0], [288.0, 1317.0]]], "lines": ["発行者", "発行所"]}, {"box": [435, 1017, 712, 1118], "vertical": false, "font_size": 26, "lines_coords": [[[466.0, 1017.0], [623.0, 1017.0], [623.0, 1043.0], [466.0, 1043.0]], [[470.0, 1049.0], [621.0, 1049.0], [621.0, 1076.0], [470.0, 1076.0]], [[464.0, 1088.0], [699.0, 1088.0], [699.0, 1113.0], [464.0, 1113.0]]], "lines": ["おおいまよしとき", "大今度は", "©ｙｏｓｈｉｔｏｋｉＯｉｎａ２０１３"]}, {"box": [464, 1239, 578, 1272], "vertical": false, "font_size": 29, "lines_coords": [[[464.0, 1239.0], [578.0, 1243.0], [578.0, 1272.0], [464.0, 1268.0]]], "lines": ["清水保雅"]}, {"box": [464, 1286, 956, 1405], "vertical": false, "font_size": 30.666666666666668, "lines_coords": [[[466.0, 1286.0], [678.0, 1286.0], [678.0, 1313.0], [466.0, 1313.0]], [[466.0, 1325.0], [956.0, 1329.0], [956.0, 1362.0], [466.0, 1358.0]], [[464.0, 1372.0], [941.0, 1374.0], [941.0, 1405.0], [464.0, 1404.0]]], "lines": ["株式会社・講談社", "〒１１２－８０１－東京都文京区音羽２－１２－２１", "電話番号＿編集部東京（０３）５３５－３４５）"]}, {"box": [596, 1417, 943, 1494], "vertical": false, "font_size": 31.0, "lines_coords": [[[596.0, 1417.0], [939.0, 1417.0], [939.0, 1445.0], [596.0, 1445.0]], [[596.0, 1460.0], [943.0, 1460.0], [943.0, 1494.0], [596.0, 1494.0]]], "lines": ["販売部＿東京（ＧＯＳＦＳ９５－３６０８）", "業務部・東京（１６）５３５５－３６６："]}, {"box": [139, 1858, 641, 1890], "vertical": false, "font_size": 28, "lines_coords": [[[139.0, 1858.0], [641.0, 1862.0], [641.0, 1890.0], [139.0, 1886.0]]], "lines": ["ＮＤＣ．２６．１９１ｐ．８ｃｍＰｒｉｎｔｅｄｉｎ．ｊａｐａｎ"]}, {"box": [286, 1507, 752, 1627], "vertical": false, "font_size": 31.333333333333332, "lines_coords": [[[290.0, 1507.0], [376.0, 1507.0], [376.0, 1537.0], [290.0, 1537.0]], [[292.0, 1551.0], [752.0, 1551.0], [752.0, 1578.0], [292.0, 1578.0]], [[288.0, 1584.0], [378.0, 1590.0], [376.0, 1627.0], [286.0, 1621.0]]], "lines": ["印刷所", "本文製版所・株式会社二葉写真製版", "製本所"]}, {"box": [466, 1507, 664, 1535], "vertical": false, "font_size": 28, "lines_coords": [[[466.0, 1507.0], [664.0, 1507.0], [664.0, 1535.0], [466.0, 1535.0]]], "lines": ["株式会社廣済堂"]}, {"box": [464, 1594, 782, 1621], "vertical": false, "font_size": 27, "lines_coords": [[[464.0, 1594.0], [782.0, 1594.0], [782.0, 1621.0], [464.0, 1621.0]]], "lines": ["株式会社フォーネット社"]}, {"box": [143, 1660, 1074, 1715], "vertical": false, "font_size": 19.5, "lines_coords": [[[143.0, 1660.0], [1017.0, 1660.0], [1017.0, 1680.0], [143.0, 1680.0]], [[162.0, 1696.0], [1074.0, 1696.0], [1074.0, 1715.0], [162.0, 1715.0]]], "lines": ["●本書のコピースキャンデジタル化等の無断複製よ著作権法上での例外を除き禁じられています。", "本書を代行業者等の第三者に依頼してスキャンやデジタル化することはたとえ個人や家庭内の利用でも"]}, {"box": [139, 1727, 1080, 1823], "vertical": false, "font_size": 25.666666666666668, "lines_coords": [[[158.0, 1727.0], [335.0, 1727.0], [335.0, 1753.0], [158.0, 1753.0]], [[139.0, 1762.0], [1072.0, 1762.0], [1072.0, 1788.0], [139.0, 1788.0]], [[158.0, 1798.0], [1080.0, 1798.0], [1080.0, 1823.0], [158.0, 1823.0]]], "lines": ["著作権法違反です。", "●落丁本品で本は購入書店名をご記入のうえ、小社業務部宛にお送りまたさい。送料小社負担にてお取り", "替えいたします。なお、この本についてのお問い合わせは週刊少年マガジン編集部位にお願いいたします。"]}, {"box": [803, 1859, 1118, 1891], "vertical": false, "font_size": 20, "lines_coords": [[[805.0, 1866.0], [1109.0, 1866.0], [1109.0, 1886.0], [805.0, 1886.0]]], "lines": ["［ＳＢＮ９７８－４－０６－３９４９７３－５"]}], "img_path": "175.png"}]}