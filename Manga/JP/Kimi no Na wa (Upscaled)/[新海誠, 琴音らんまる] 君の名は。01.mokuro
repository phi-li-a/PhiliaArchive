, "blocks": [{"box": [1192, 255, 1347, 561], "vertical": true, "font_size": 155, "lines_coords": [[[1192.0, 255.0], [1347.0, 255.0], [1347.0, 561.0], [1192.0, 561.0]]], "lines": ["あぁッ"]}, {"box": [1217, 644, 1339, 953], "vertical": true, "font_size": 56, "lines_coords": [[[1296.0, 653.0], [1336.0, 653.0], [1336.0, 951.0], [1296.0, 951.0]], [[1217.0, 644.0], [1289.0, 644.0], [1289.0, 754.0], [1217.0, 754.0]]], "lines": ["どういうことだ", "瀧！！"]}, {"box": [483, 841, 515, 949], "vertical": true, "font_size": 32, "lines_coords": [[[483.0, 841.0], [515.0, 841.0], [515.0, 949.0], [483.0, 949.0]]], "lines": ["まさか"]}, {"box": [189, 520, 317, 775], "vertical": true, "font_size": 45, "lines_coords": [[[246.0, 520.0], [295.0, 520.0], [300.0, 740.0], [250.0, 740.0]], [[189.0, 522.0], [229.0, 522.0], [229.0, 773.0], [189.0, 773.0]]], "lines": ["抜け駆けは", "ずりぃぞー！！"]}, {"box": [389, 1361, 492, 1511], "vertical": true, "font_size": 42, "lines_coords": [[[447.0, 1361.0], [492.0, 1364.0], [487.0, 1478.0], [443.0, 1476.0]], [[389.0, 1364.0], [429.0, 1364.0], [429.0, 1511.0], [389.0, 1511.0]]], "lines": ["まさか", "これって"]}], "img_path": "01_104.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [375, 1174, 580, 1414], "vertical": true, "font_size": 41, "lines_coords": [[[539.0, 1181.0], [579.0, 1181.0], [579.0, 1319.0], [539.0, 1319.0]], [[480.0, 1176.0], [525.0, 1176.0], [525.0, 1289.0], [480.0, 1289.0]], [[424.0, 1174.0], [473.0, 1176.0], [468.0, 1324.0], [419.0, 1321.0]], [[377.0, 1185.0], [408.0, 1185.0], [408.0, 1410.0], [377.0, 1410.0]]], "lines": ["こいつが", "まじで．．．", "俺の中に", "いたってこと？"]}, {"box": [213, 1476, 478, 1668], "vertical": false, "font_size": 19.833333333333332, "lines_coords": [[[213.0, 1582.0], [379.0, 1476.0], [391.0, 1492.0], [222.0, 1598.0]], [[225.0, 1596.0], [389.0, 1490.0], [398.0, 1507.0], [234.0, 1612.0]], [[236.0, 1607.0], [372.0, 1523.0], [382.0, 1539.0], [246.0, 1624.0]], [[246.0, 1621.0], [405.0, 1523.0], [417.0, 1539.0], [257.0, 1640.0]], [[262.0, 1633.0], [468.0, 1502.0], [478.0, 1518.0], [272.0, 1650.0]], [[267.0, 1650.0], [375.0, 1579.0], [386.0, 1598.0], [279.0, 1668.0]]], "lines": ["お友達は優しいし、自分自身もちょ", "お友達は難しいし、自分自身もしてしまいましょう。レストランのバイト経験は無い", "し．．．レストランの世界みたいでわくわくした！", "世界中にいてイメージした私の失敗のおかげで、超美女の奥まで", "くなれたし♪「人なれにしよ！！トート帰り、駅までの道を実寺で", "くないにしよくわかりイと一緒に帰りました。"]}, {"box": [290, 1612, 398, 1689], "vertical": false, "font_size": 19, "lines_coords": [[[290.0, 1673.0], [389.0, 1612.0], [398.0, 1628.0], [300.0, 1689.0]]], "lines": ["私の女子力のおかげで"]}, {"box": [1268, 1266, 1302, 1441], "vertical": true, "font_size": 33, "lines_coords": [[[1268.0, 1267.0], [1301.0, 1267.0], [1301.0, 1439.0], [1268.0, 1439.0]]], "lines": ["もしかして"]}, {"box": [888, 2027, 1015, 2107], "vertical": false, "font_size": 32, "lines_coords": [[[888.0, 2078.0], [1001.0, 2027.0], [1015.0, 2055.0], [902.0, 2107.0]]], "lines": ["そういうわけでもなく、たくさんありがとうございます。これはよく入っているようになりますのですが、お願いしました。"]}], "img_path": "01_105.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1292, 227, 1463, 389], "vertical": false, "font_size": 83, "lines_coords": [[[1345.0, 227.0], [1463.0, 325.0], [1409.0, 389.0], [1292.0, 290.0]]], "lines": ["メッシ・"]}, {"box": [919, 1712, 961, 1821], "vertical": true, "font_size": 42, "lines_coords": [[[919.0, 1715.0], [961.0, 1715.0], [961.0, 1821.0], [919.0, 1821.0]]], "lines": ["ん〜っ"]}, {"box": [274, 1252, 317, 1464], "vertical": true, "font_size": 40, "lines_coords": [[[274.0, 1253.0], [314.0, 1253.0], [314.0, 1464.0], [274.0, 1464.0]]], "lines": ["よくねたあ"]}], "img_path": "01_106.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1446, 307, 1574, 607], "vertical": true, "font_size": 41, "lines_coords": [[[1512.0, 309.0], [1554.0, 309.0], [1554.0, 482.0], [1512.0, 482.0]], [[1446.0, 307.0], [1486.0, 307.0], [1489.0, 604.0], [1449.0, 604.0]]], "lines": ["何かまた", "夢みたような．．．"]}, {"box": [286, 1959, 389, 2151], "vertical": true, "font_size": 42, "lines_coords":