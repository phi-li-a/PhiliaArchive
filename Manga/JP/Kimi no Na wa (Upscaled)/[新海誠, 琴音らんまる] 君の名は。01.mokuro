14.0]]], "lines": ["は？"]}, {"box": [1404, 849, 1500, 1167], "vertical": true, "font_size": 36, "lines_coords": [[[1460.0, 850.0], [1500.0, 850.0], [1500.0, 1028.0], [1460.0, 1028.0]], [[1404.0, 850.0], [1437.0, 850.0], [1437.0, 1167.0], [1404.0, 1167.0]]], "lines": ["いやーでも", "昨日はかわいかった"]}, {"box": [776, 867, 941, 1141], "vertical": true, "font_size": 38, "lines_coords": [[[881.0, 867.0], [923.0, 867.0], [923.0, 1073.0], [881.0, 1073.0]], [[827.0, 874.0], [867.0, 874.0], [867.0, 1141.0], [827.0, 1141.0]], [[776.0, 874.0], [808.0, 874.0], [808.0, 1040.0], [776.0, 1040.0]]], "lines": ["夕飯のときに", "お父さんお父ちん、", "聞いてって"]}, {"box": [347, 846, 463, 1138], "vertical": true, "font_size": 48, "lines_coords": [[[396.0, 846.0], [461.0, 846.0], [461.0, 942.0], [396.0, 942.0]], [[347.0, 855.0], [379.0, 855.0], [379.0, 1136.0], [347.0, 1136.0]]], "lines": ["日記", "書いてるんだろ？"]}, {"box": [1378, 1314, 1486, 1616], "vertical": true, "font_size": 41, "lines_coords": [[[1428.0, 1314.0], [1477.0, 1314.0], [1477.0, 1492.0], [1428.0, 1492.0]], [[1378.0, 1324.0], [1411.0, 1324.0], [1411.0, 1614.0], [1378.0, 1614.0]]], "lines": ["小さい頃の", "お前を思い出すよ："]}, {"box": [759, 1406, 856, 1706], "vertical": true, "font_size": 34, "lines_coords": [[[820.0, 1413.0], [853.0, 1413.0], [853.0, 1640.0], [820.0, 1640.0]], [[764.0, 1406.0], [799.0, 1406.0], [794.0, 1706.0], [759.0, 1706.0]]], "lines": ["なにきもいこと", "言ってんだよオヤジ"]}, {"box": [178, 1406, 311, 1530], "vertical": false, "font_size": 115, "lines_coords": [[[178.0, 1415.0], [304.0, 1406.0], [311.0, 1521.0], [185.0, 1530.0]]], "lines": ["！！？"]}, {"box": [1268, 1996, 1428, 2142], "vertical": true, "font_size": 48, "lines_coords": [[[1376.0, 1996.0], [1428.0, 1999.0], [1423.0, 2123.0], [1371.0, 2121.0]], [[1322.0, 1999.0], [1371.0, 1999.0], [1371.0, 2142.0], [1322.0, 2142.0]], [[1268.0, 2003.0], [1310.0, 2003.0], [1310.0, 2142.0], [1268.0, 2142.0]]], "lines": ["は？．．．", "なんで．．．", "知って．．．"]}, {"box": [171, 1865, 391, 2161], "vertical": true, "font_size": 37, "lines_coords": [[[340.0, 1870.0], [372.0, 1870.0], [372.0, 2160.0], [340.0, 2160.0]], [[276.0, 1865.0], [318.0, 1865.0], [318.0, 1973.0], [276.0, 1973.0]], [[222.0, 1865.0], [262.0, 1865.0], [262.0, 2069.0], [222.0, 2069.0]], [[171.0, 1867.0], [204.0, 1867.0], [204.0, 2034.0], [171.0, 2034.0]]], "lines": ["お前が言ったんじゃ", "ないか", "今日の日記は", "特別ーって"]}], "img_path": "01_098.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1409, 288, 1514, 644], "vertical": true, "font_size": 40, "lines_coords": [[[1465.0, 288.0], [1505.0, 288.0], [1505.0, 644.0], [1465.0, 644.0]], [[1409.0, 288.0], [1449.0, 288.0], [1449.0, 541.0], [1409.0, 541.0]]], "lines": ["なんでも言ってくれて", "嬉しいよおれは"]}, {"box": [1165, 210, 1206, 466], "vertical": true, "font_size": 33, "lines_coords": [[[1167.0, 213.0], [1200.0, 213.0], [1200.0, 459.0], [1167.0, 459.0]]], "lines": ["そんなはずねえ"]}, {"box": [939, 388, 1041, 616], "vertical": true, "font_size": 42, "lines_coords": [[[998.0, 389.0], [1041.0, 389.0], [1041.0, 435.0], [998.0, 435.0]], [[940.0, 391.0], [980.0, 391.0], [980.0, 616.0], [940.0, 616.0]]], "lines": ["う", "うるせえよ！"]}, {"box": [365, 471, 443, 513], "vertical": false, "font_size": 31, "lines_coords": [[[365.0, 482.0], [438.0, 471.0], [443.0, 501.0], [370.0, 513.0]]], "lines": ["Ｄｉａｎｙ"]}, {"box": [222, 459, 684, 724], "vertical": false, "font_size": 25.833333333333332, "lines_coords": [[[222.0, 585.0], [586.0, 459.0], [593.0, 482.0], [229.0, 609.0]], [[227.0, 611.0], [623.0, 471.0], [633.0, 494.0], [236.0, 635.0]], [[243.0, 632.0], [476.0, 550.0], [483.0, 574.0], [250.0, 656.0]], [[250.0, 656.0], [668.0, 510.0], [677.0, 536.0], [260.0, 682.0]], [[264.0, 679.0], [675.0, 534.0], [684.0, 560.0], [272.0, 705.0]], [[281.0, 700.0], [464.0, 637.0], [471.0, 660.0], [288.0, 724.0]]], "lines": ["お友達は優しいし、自分自身もちょっとイケメ", "Ｏ．Ｘとは優しいし、し。レストランのバイトロネット経験は驚いたけど、映画", "世界みたいでわくわくした！", "世代の人に私の失敗のおかげで超美女の奥寺センパイと仲良", "くなれたしかいいんだなわたし♪ハイト２０１３年以上の道を奥寺センパ", "なんとしなくイと一緒に帰りました。"]}, {"box": [1341, 794, 1521, 977], "vertical": true, "font_size": 35, "lines_coords": [[[1458.0, 796.0], [1503.0, 796.0], [1503.0, 907.0], [1458.0, 907.0]], [[1439.0, 801.0], [1460.0, 801.0], [1460.0, 832.0], [1439.0, 832.0]], [[1406.0, 794.0], [1439.0, 794.0], [1439.0, 977.0], [1406.0, 977.0]], [[1341.0, 796.0], [1383.0, 796.0], [1383.0, 942.0], [1341.0, 942.0]]], "lines": ["携帯の", "にっ", "日記なんて", "誰にも．．"]}, {"box": [274, 796, 557, 1166], "vertical": true, "font_size": 36, "lines_coords": [[[499.0, 799.0], [539.0, 799.0], [539.0, 1096.0], [499.0, 1096.0]], [[445.0, 801.0], [478.0, 801.0], [478.0, 1033.0], [445.0, 1033.0]], [[384.0, 796.0], [424.0, 796.0], [424.0, 1096.0], [384.0, 1096.0]], [[332.0, 801.0], [365.0, 801.0], [365.0, 1164.0], [332.0, 1164.0]], [[276.0, 796.0], [309.0, 796.0], [307.0, 1066.0], [274.0, 1066.0]]], "lines": ["映画の世界みたいで", "わくわくした！", "私の失敗のおかげで", "超美女の奥寺センバイと", "仲良くなれたし♪"]}, {"box": [1104, 1272, 1274, 1736], "vertical": true, "font_size": 40, "lines_coords": [[[1214.0, 1272.0], [1263.0, 1272.0], [1263.0, 1457.0], [1214.0, 1457.0]], [[1156.0, 1272.0], [1195.0, 1272.0], [1198.0, 1736.0], [1158.0, 1736.0]], [[1104.0, 1284.0], [1137.0, 1284.0], [1137.0, 1558.0], [1104.0, 1558.0]]], "lines": ["バイト帰り", "駅までの道を奥寺センバイと", "一緒に帰りました"]}, {"box": [371, 1921, 427, 2200], "vertical": true, "font_size": 40, "lines_coords": [[[379.0, 1921.0], [419.0, 1921.0], [419.0, 2200.0], [379.0, 2200.0]]], "lines": ["はぁあああ！？"]}], "img_path": "01_099.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1123, 174, 1179, 627], "vertical": true, "font_size": 33, "lines_coords": [[[1125.0, 175.0], [1158.0, 175.0], [1158.0, 623.0], [1125.0, 623.0]]], "lines": ["わたしの女子力のおかげ♡"]}, {"box": [145, 464, 382, 611], "vertical": false, "font_size": 25.5, "lines_coords": [[[157.0, 464.0], [382.0, 562.0], [370.0, 583.0], [145.0, 485.0]], [[161.0, 492.0], [375.0, 585.0], [365.0, 611.0], [152.0, 517.0]]], "lines": ["分自身もちょっとイケメ。", "経験は驚いたけど、映画"]}, {"box": [157, 428, 236, 487], "vertical": false, "font_size": 30, "lines_coords": [[[171.0, 428.0], [236.0, 461.0], [222.0, 487.0], [157.0, 454.0]]], "lines": ["Ｄｉａｒｙ"]}, {"box": [365, 698, 409, 853], "vertical": true, "font_size": 40, "lines_coords": [[[365.0, 698.0], [405.0, 698.0], [405.0, 853.0], [365.0, 853.0]]], "lines": ["だれだよ"]}, {"box": [150, 553, 311, 665], "vertical": false, "font_size": 25.5, "lines_coords": [[[164.0, 553.0], [311.0, 614.0], [302.0, 637.0], [154.0, 576.0]], [[159.0, 578.0], [304.0, 642.0], [293.0, 665.0], [150.0, 602.0]]], "lines": ["女の奥まセンパイ", "『までの道を奥寺"]}, {"box": [1402, 1619, 1503, 1800], "vertical": true, "font_size": 46, "lines_coords": [[[1463.0, 1621.0], [1503.0, 1621.0], [1503.0, 1800.0], [1463.0, 1800.0]], [[1402.0, 1619.0], [1453.0, 1619.0], [1453.0, 1739.0], [1402.0, 1739.0]]], "lines": ["みつはって", "誰だよ"]}, {"box": [1038, 1607, 1203, 1919], "vertical": true, "font_size": 60, "lines_coords": [[[1144.0, 1619.0], [1198.0, 1619.0], [1198.0, 1732.0], [1144.0, 1732.0]], [[1078.0, 1607.0], [1172.0, 1607.0], [1172.0, 1739.0], [1078.0, 1739.0]], [[1038.0, 1619.0], [1071.0, 1619.0], [1073.0, 1917.0], [1041.0, 1917.0]]], "lines": ["おい瀧", "おい滴今日は", "弁当もってきたか？"]}, {"box": [429, 1600, 511, 1736], "vertical": true, "font_size": 52, "lines_coords": [[[429.0, 1600.0], [511.0, 1600.0], [511.0, 1736.0], [429.0, 1736.0]]], "lines": ["あ！"]}, {"box": [213, 1575, 307, 1755], "vertical": true, "font_size": 52, "lines_coords": [[[262.0, 1575.0], [304.0, 1575.0], [307.0, 1755.0], [264.0, 1755.0]], [[213.0, 1577.0], [246.0, 1577.0], [246.0, 1755.0], [213.0, 1755.0]]], "lines": ["もしかして", "お前らが．．．"]}, {"box": [894, 1712, 948, 2175], "vertical": true, "font_size": 33, "lines_coords": [[[895.0, 1713.0], [928.0, 1713.0], [928.0, 2175.0], [895.0, 2175.0]]], "lines": ["迷子もならなかっただろうな"]}, {"box": [675, 1823, 773, 2053], "vertical": true, "font_size": 40, "lines_coords": [[[722.0, 1823.0], [773.0, 1823.0], [773.0, 1900.0], [722.0, 1900.0]], [[675.0, 1825.0], [705.0, 1825.0], [705.0, 2050.0], [675.