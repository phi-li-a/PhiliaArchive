ines": ["おっぱいいいぃ！？"]}, {"box": [188, 2152, 396, 2391], "vertical": false, "font_size": 37, "lines_coords": [[[264.0, 2310.0], [365.0, 2153.0], [396.0, 2172.0], [295.0, 2332.0]]], "lines": ["ところで、"]}], "img_path": "01_109.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [297, 407, 438, 637], "vertical": true, "font_size": 59, "lines_coords": [[[379.0, 407.0], [438.0, 407.0], [438.0, 583.0], [379.0, 583.0]], [[297.0, 412.0], [356.0, 412.0], [356.0, 637.0], [297.0, 637.0]]], "lines": ["まさか", "本当に？"]}, {"box": [907, 1340, 975, 1514], "vertical": true, "font_size": 68, "lines_coords": [[[907.0, 1340.0], [975.0, 1340.0], [975.0, 1514.0], [907.0, 1514.0]]], "lines": ["うわ！！"]}, {"box": [818, 1942, 968, 2029], "vertical": false, "font_size": 43, "lines_coords": [[[818.0, 1987.0], [954.0, 1942.0], [968.0, 1982.0], [832.0, 2029.0]]], "lines": ["父は別居"]}], "img_path": "01_110.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1390, 247, 1435, 435], "vertical": true, "font_size": 42, "lines_coords": [[[1390.0, 250.0], [1432.0, 250.0], [1432.0, 433.0], [1390.0, 433.0]]], "lines": ["なにこれ"]}, {"box": [520, 1746, 1036, 2102], "vertical": false, "font_size": 31.625000000000004, "lines_coords": [[[682.0, 1788.0], [762.0, 1776.0], [766.0, 1811.0], [689.0, 1823.0]], [[520.0, 1886.0], [954.0, 1746.0], [966.0, 1776.0], [529.0, 1919.0]], [[532.0, 1919.0], [989.0, 1764.0], [998.0, 1797.0], [544.0, 1950.0]], [[541.0, 1945.0], [808.0, 1858.0], [816.0, 1884.0], [548.0, 1971.0]], [[551.0, 1966.0], [1020.0, 1816.0], [1029.0, 1849.0], [560.0, 1999.0]], [[572.0, 1996.0], [1027.0, 1849.0], [1036.0, 1875.0], [581.0, 2022.0]], [[576.0, 2020.0], [787.0, 1950.0], [799.0, 1982.0], [586.0, 2053.0]], [[600.0, 2076.0], [797.0, 2013.0], [806.0, 2039.0], [609.0, 2102.0]]], "lines": ["Ｄｉａｎｙ", "お友達は優しいし自分自身もちょっとイケメン", "お父達は優しいし、し。レストランのバイ出用っていました日常もうよっとインスンにト経験は驚いたけど、映画の", "世界みたいでわくわくした！", "世界みたいじわくしに私の失敗のおかげで、超美女のの奥寺センパイと仲良する業も間主ね〜。", "