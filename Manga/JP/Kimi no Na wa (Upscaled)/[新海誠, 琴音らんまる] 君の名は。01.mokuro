, "lines_coords": [[[1460.0, 1200.0], [1503.0, 1200.0], [1503.0, 1347.0], [1460.0, 1347.0]], [[1402.0, 1202.0], [1444.0, 1202.0], [1444.0, 1417.0], [1402.0, 1417.0]], [[1345.0, 1200.0], [1385.0, 1200.0], [1383.0, 1453.0], [1343.0, 1453.0]], [[1285.0, 1200.0], [1327.0, 1200.0], [1327.0, 1347.0], [1285.0, 1347.0]], [[1233.0, 1204.0], [1263.0, 1204.0], [1263.0, 1483.0], [1233.0, 1483.0]]], "lines": ["デートが", "終わる頃には", "ちょうど彗星が", "見えるね", "明日がたのしみ"]}, {"box": [121, 1317, 232, 1476], "vertical": true, "font_size": 54, "lines_coords": [[[175.0, 1317.0], [232.0, 1317.0], [232.0, 1410.0], [175.0, 1410.0]], [[121.0, 1321.0], [171.0, 1321.0], [171.0, 1476.0], [121.0, 1476.0]]], "lines": ["まあ", "．．．いっか"]}, {"box": [597, 1687, 719, 1933], "vertical": true, "font_size": 44, "lines_coords": [[[656.0, 1687.0], [705.0, 1687.0], [705.0, 1856.0], [656.0, 1856.0]], [[597.0, 1689.0], [637.0, 1689.0], [637.0, 1933.0], [597.0, 1933.0]]], "lines": ["彗星って", "何の話だよ．．．"]}, {"box": [295, 1811, 514, 2130], "vertical": true, "font_size": 39, "lines_coords": [[[450.0, 1818.0], [490.0, 1816.0], [497.0, 1975.0], [457.0, 1978.0]], [[403.0, 1821.0], [436.0, 1821.0], [436.0, 2036.0], [403.0, 2036.0]], [[342.0, 1811.0], [389.0, 1811.0], [396.0, 2130.0], [349.0, 2130.0]], [[295.0, 1818.0], [330.0, 1818.0], [335.0, 1973.0], [300.0, 1973.0]]], "lines": ["散々だった", "デートの結果は", "次に入れ替わった時に", "話せばいい"]}], "img_path": "01_169.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1277, 321, 1331, 501], "vertical": true, "font_size": 40, "lines_coords": [[[1277.0, 321.0], [1317.0, 321.0], [1317.0, 501.0], [1277.0, 501.0]]], "lines": ["そう思った"]}, {"box": [984, 586, 1016, 653], "vertical": true, "font_size": 32, "lines_coords": [[[984.0, 586.0], [1016.0, 586.0], [1016.0, 653.0], [984.0, 653.0]]], "lines": ["でも"]}, {"box": [633, 548, 733, 727], "vertical": true, "font_size": 42, "lines_coords": [[[682.0, 548.0], [733.0, 548.0], [733.0, 663.0], [682.0, 663.0]], [[633.0, 550.0], [665.0, 550.0], [665.0, 726.0], [633.0, 726.0]]], "lines": ["なぜか", "もう二度と"]}, {"box": [384, 682, 500, 1110], "vertical": true, "font_size": 36, "lines_coords": [[[443.0, 682.0], [483.0, 682.0], [480.0, 1110.0], [440.0, 1110.0]], [[384.0, 682.0], [417.0, 682.0], [417.0, 930.0], [384.0, 930.0]]], "lines": ["俺と三葉との入れ替わりは", "起こらなかった"]}, {"box": [176, 2254, 466, 2341], "vertical": false, "font_size": 87, "lines_coords": [[[176.0, 2254.0], [466.0, 2254.0], [466.0, 2341.0], [176.0, 2341.0]]], "lines": ["第二話一緒の第一条第二十二条第条第三条第一部の第三者第三十六十六条第十二十三十八条第第第二次第第三話一条の第二三十四条第八第二第三第一級第第１１回第第一番号第一緒に第二百条第１８条第九条第２回第三次第二項第第十条第号第第号．．．"]}], "img_path": "01_170.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [82, 710, 785, 895], "vertical": false, "font_size": 162, "lines_coords": [[[262.0, 724.0], [433.0, 719.0], [436.0, 839.0], [264.0, 843.0]], [[370.0, 696.0], [785.0, 696.0], [785.0, 897.0], [370.0, 897.0]], [[82.0, 703.0], [283.0, 703.0], [283.0, 909.0], [82.0, 909.0]]], "lines": ["その", "．．．名は。", "君！！"]}], "img_path": "01_171.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [166, 473, 492, 520], "vertical": false, "font_size": 47, "lines_coords": [[[166.0, 473.0], [492.0, 473.0], [492.0, 520.0], [166.0, 520.0]]], "lines": ["君の名は。１"]}, {"box": [173, 421, 588, 454], "vertical": false, "font_size": 33, "lines_coords": [[[173.0, 421.0], [588.0, 421.0], [588.0, 454.0], [173.0, 454.0]]], "lines": ["ＭＦコミックスアライブシリーズ"]}, {"box": [166, 590, 393, 665], "vertical": false, "font_size": 37.5, "lines_coords": [[[171.0, 590.0], [393.0, 590.0], [393.0, 623.0], [171.0, 623.0]], [[166.0, 623.0], [328.0, 623.0], [328.0, 665.0], [166.0, 665.0]]], "lines": ["著者：琴音らんまる", "有名・今日の原作・新海誠"]}, {"box": [168, 728, 490, 782], "vertical": false, "font_size": 26, "lines_coords": [[[171.0, 726.0], [398.0, 726.0], [398.0, 754.0], [171.0, 754.0]], [[173.0, 755.0], [480.0, 755.0], [480.0, 782.0], [173.0, 782.0]]], "lines": ["＠ＲａｎｍａｒｕＫａｔｏｒｅ２０１６．", "◎２０１６「君の名は、