6.0, 1959.0], [628.0, 2261.0], [595.0, 2261.0]]], "lines": ["避難計画", "とやらはでけたん？"]}], "img_path": "02_156.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1345, 869, 1416, 932], "vertical": false, "font_size": 63, "lines_coords": [[[1345.0, 869.0], [1416.0, 869.0], [1416.0, 932.0], [1345.0, 932.0]]], "lines": ["ば"]}, {"box": [307, 932, 367, 1085], "vertical": true, "font_size": 42, "lines_coords": [[[307.0, 932.0], [349.0, 932.0], [349.0, 1085.0], [307.0, 1085.0]]], "lines": ["爆弾．．．？"]}, {"box": [1313, 1420, 1360, 1500], "vertical": true, "font_size": 47, "lines_coords": [[[1313.0, 1420.0], [1360.0, 1420.0], [1360.0, 1500.0], [1313.0, 1500.0]]], "lines": ["ああ"]}, {"box": [590, 1265, 809, 1485], "vertical": true, "font_size": 35, "lines_coords": [[[755.0, 1270.0], [787.0, 1270.0], [790.0, 1457.0], [757.0, 1457.0]], [[703.0, 1272.0], [736.0, 1272.0], [731.0, 1485.0], [698.0, 1485.0]], [[649.0, 1272.0], [682.0, 1272.0], [682.0, 1455.0], [649.0, 1455.0]], [[590.0, 1265.0], [633.0, 1265.0], [633.0, 1368.0], [590.0, 1368.0]]], "lines": ["含水爆薬って", "いうのがうちの", "資材置き場に", "あるで"]}, {"box": [1378, 1903, 1439, 2211], "vertical": true, "font_size": 42, "lines_coords": [[[1383.0, 1903.0], [1425.0, 1903.0], [1421.0, 2205.0], [1378.0, 2205.0]]], "lines": ["電波ジャック．．．！？"]}, {"box": [555, 1818, 778, 2186], "vertical": true, "font_size": 38, "lines_coords": [[[719.0, 1818.0], [759.0, 1818.0], [757.0, 2156.0], [717.0, 2156.0]], [[665.0, 1818.0], [705.0, 1818.0], [703.0, 2153.0], [663.0, 2153.0]], [[609.0, 1818.0], [649.0, 1818.0], [647.0, 2186.0], [607.0, 2186.0]], [[558.0, 1821.0], [588.0, 1821.0], [588.0, 2118.0], [558.0, 2118.0]]], "lines": ["こんな田舎の防災無線", "伝送周波数と起動用の", "重畳周波数さえわかりゃ", "簡単に乗っとれるで"]}, {"box": [100, 1900, 211, 2074], "vertical": true, "font_size": 45, "lines_coords": [[[161.0, 1900.0], [211.0, 1900.0], [211.0, 2034.0], [161.0, 2034.0]], [[100.0, 1903.0], [140.0, 1903.0], [140.0, 2074.0], [100.0, 2074.0]]], "lines": ["そう！", "だから．．．"]}], "img_path": "02_157.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1371, 318, 1566, 667], "vertical": true, "font_size": 50, "lines_coords": [[[1496.0, 318.0], [1552.0, 318.0], [1552.0, 667.0], [1496.0, 667.0]], [[1432.0, 323.0], [1484.0, 323.0], [1484.0, 457.0], [1432.0, 457.0]], [[1374.0, 323.0], [1416.0, 323.0], [1413.0, 660.0], [1371.0, 660.0]]], "lines": ["学校の放送室から", "町中に", "避難指示を流せる"]}, {"box": [1413, 901, 1519, 1293], "vertical": true, "font_size": 33, "lines_coords": [[[1470.0, 904.0], [1503.0, 904.0], [1503.0, 1150.0], [1470.0, 1150.0]], [[1413.0, 904.0], [1446.0, 904.0], [1446.0, 1293.0], [1413.0, 1293.0]]], "lines": ["学校のあたりは", "予想被害範囲の外だから"]}, {"box": [635, 965, 743, 1326], "vertical": true, "font_size": 34, "lines_coords": [[[687.0, 965.0], [726.0, 965.0], [726.0, 1136.0], [687.0, 1136.0]], [[635.0, 967.0], [665.0, 967.0], [665.0, 1326.0], [635.0, 1326.0]]], "lines": ["避難場所も", "ここの校庭にすればいい"]}, {"box": [1510, 1512, 1627, 1785], "vertical": true, "font_size": 42, "lines_coords": [[[1582.0, 1514.0], [1627.0, 1514.0], [1627.0, 1556.0], [1582.0, 1556.0]], [[1510.0, 1532.0], [1549.0, 1532.0], [1552.0, 1785.0], [1512.0, 1785.0]]], "lines": ["か", "かんぺき犯罪やに"]}, {"box": [161, 1528, 357, 1701], "vertical": true, "font_size": 50, "lines_coords": [[[288.0, 1528.0], [347.0, 1528.0], [347.0, 1666.0], [288.0, 1666.0]], [[232.0, 1532.0], [272.0, 1532.0], [272.0, 1701.0], [232.0, 1701.0]], [[161.0, 1530.0], [211.0, 1530.0], [211.0, 1661.0], [161.0, 1661.0]]], "lines": ["放送は", "サヤちん", "担当ね"]}, {"box": [1470, 1950, 1513, 2127], "vertical": true, "font_size": 36, "lines_coords": [[[1470.0, 1950.0], [1505.0, 1950.0], [1510.0, 2125.0], [1474.0, 2125.0]]], "lines": ["なんでよ！"]}, {"box": [1258, 1954, 1313, 2216], "vertical": true, "font_size": 33, "lines_coords": [[[1261.0, 1954.0], [1294.0, 1954.0], [1294.0, 2214.0], [1261.0, 2214.0]]], "lines": ["お前、放送部やし"]}, {"box": [508, 1889, 565, 2104], "vertical": true, "font_size": 40, "lines_coords": [[[508.0, 1889.0], [548.0, 1889.0], [548.0, 2100.0], [508.0, 2100.0]]], "lines": ["俺が爆薬担当"]}, {"box": [248, 1912, 304, 2128], "vertical": true, "font_size": 40, "lines_coords": [[[248.0, 1912.0], [288.0, 1912.0], [288.0, 2128.0], [248.0, 2128.0]]], "lines": ["そして私が．．"]}], "img_path": "02_158.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1292, 955, 1525, 1157], "vertical": true, "font_size": 34, "lines_coords": [[[1481.0, 958.0], [1514.0, 958.0], [1514.0, 1129.0], [1481.0, 1129.0]], [[1432.0, 956.0], [1465.0, 956.0], [1465.0, 1157.0], [1432.0, 1157.0]], [[1385.0, 958.0], [1418.0, 958.0], [1418.0, 1101.0], [1385.0, 1101.0]], [[1336.0, 956.0], [1369.0, 956.0], [1369.0, 1075.0], [1336.0, 1075.0]], [[1292.0, 956.0], [1329.0, 956.0], [1329.0, 1075.0], [1292.0, 1075.0]]], "lines": ["最後は役場に", "出てもらわんと", "町民全ては", "さすがに", "動かせん"]}, {"box": [1083, 951, 1236, 1200], "vertical": true, "font_size": 38, "lines_coords": [[[1177.0, 951.0], [1217.0, 951.0], [1217.0, 1113.0], [1177.0, 1113.0]], [[1130.0, 951.0], [1170.0, 951.0], [1170.0, 1174.0], [1130.0, 1174.0]], [[1083.0, 956.0], [1116.0, 956.0], [1116.0, 1200.0], [1083.0, 1200.0]]], "lines": ["娘の私から", "ちゃんと話せば", "きっと説得できる"]}, {"box": [593, 508, 786, 730], "vertical": true, "font_size": 57, "lines_coords": [[[712.0, 508.0], [783.0, 508.0], [783.0, 614.0], [712.0, 614.0]], [[651.0, 515.0], [710.0, 515.0], [710.0, 653.0], [651.0, 653.0]], [[595.0, 517.0], [637.0, 517.0], [637.0, 728.0], [595.0, 728.0]]], "lines": ["私が", "町長に", "会いに行く"]}, {"box": [853, 927, 947, 1176], "vertical": true, "font_size": 38, "lines_coords": [[[914.0, 928.0], [947.0, 928.0], [947.0, 1171.0], [914.0, 1171.0]], [[853.0, 928.0], [895.0, 928.0], [895.0, 1064.0], [853.0, 1064.0]]], "lines": ["どうせもしもの", "妄想やろ"]}, {"box": [497, 972, 593, 1191], "vertical": true, "font_size": 40, "lines_coords": [[[546.0, 972.0], [593.0, 972.0], [593.0, 1057.0], [546.0, 1057.0]], [[497.0, 977.0], [529.0, 977.0], [529.0, 1190.0], [497.0, 1190.0]]], "lines": ["え？", "ええっっと．．．"]}, {"box": [189, 1000, 232, 1106], "vertical": true, "font_size": 43, "lines_coords": [[[189.0, 1000.0], [232.0, 1000.0], [232.0, 1106.0], [189.0, 1106.0]]], "lines": ["いやあ"]}, {"box": [1144, 1520, 1308, 1761], "vertical": true, "font_size": 44, "lines_coords": [[[1228.0, 1645.0], [1268.0, 1624.0], [1301.0, 1692.0], [1263.0, 1710.0]]], "lines": ["まな"]}, {"box": [987, 1488, 1149, 1733], "vertical": true, "font_size": 42, "lines_coords": [[[1099.0, 1488.0], [1149.0, 1492.0], [1139.0, 1610.0], [1090.0, 1605.0]], [[1048.0, 1500.0], [1081.0, 1500.0], [1081.0, 1732.0], [1048.0, 1732.0]], [[987.0, 1497.0], [1029.0, 1497.0], [1029.0, 1605.0], [987.0, 1605.0]]], "lines": ["まあ．．．", "なんでもいいん", "やけど"]}, {"box": [300, 1889, 357, 2177], "vertical": true, "font_size": 40, "lines_coords": [[[300.0, 1889.0], [340.0, 1889.0], [340.0, 2177.0], [300.0, 2177.0]]], "lines": ["そうとも限らんさ"]}], "img_path": "02_159.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1368, 246, 1538, 564], "vertical": true, "font_size": 38, "lines_coords": [[[1484.0, 246.0], [1526.0, 246.0], [1526.0, 391.0], [1484.0, 391.0]], [[1430.0, 246.0], [1463.0, 246.0], [1463.0, 564.0], [1430.0, 564.0]], [[1369.0, 246.0], [1409.0, 246.0], [1409.0, 461.0], [1369.0, 461.0]]], "lines": ["糸守湖が", "どうやってできたか", "知っとるか？"]}, {"box": [1045, 232, 1277, 255], "vertical": false, "font_size": 23, "lines_coords": [[[1045.0, 232.0], [1277.0, 232.0], [1277.0, 255.0], [1045.0, 255.0]]], "lines": ["１２００年前の隕石湖"]}, {"box": [1043, 276, 1306, 363], "vertical": false, "font_size": 16.6, "lines_coords": [[[1050.0, 276.0], [1306.0, 276.0], [1306.0, 292.0], [1050.0, 292.0]], [[1043.0, 292.0], [1172.0, 292.0], [1172.0, 309.0], [1043.0, 309.0]], [[1052.0, 311.0], [1299.0, 311.0], [1299.0, 328.0], [1052.0, 328.0]], [[1043.0, 330.0], [1296.0, 330.0], [1296.0, 346.0], [1043.0, 346.0]], [[1043.0, 346.0], [1296.0, 346.0], [1296.0, 363.0], [1043.0, 363.0]]], "lines": ["明石が地球上に面突したことによって出来", "あたしの人の上に迎えつたのが何石規である。", "糸守湯も同様に約１２００年前に落ちた頭を", "ターがそのままの形を保ちつつ、水が温ま", "人間にとっては１２００年という月日はかなり"]}, {"box": [1041, 370, 1292, 379], "vertical": false, "font_size": 9, "lines_coords": [[[1041.0, 370.0], [1292.0, 370.0], [1292.0, 379.0], [1041.0, 379.0]]], "lines": ["が、地球上の自然からしてみると糸守湯は"]}, {"box": [1048, 424, 1303, 454], "vertical": false, "font_size": 30, "lines_coords": [[[1048.0, 424.0], [1303.0, 424.0], [1303.0, 454.0], [1048.0, 454.0]]], "lines": ["日本では極めてまれ"]}, {"box": [1050, 473, 1315, 541], "vertical": false, "font_size": 16.25, "lines_coords": [[[1057.0, 473.0], [1303.0, 473.0], [1303.0, 489.0], [1057.0, 489.0]], [[1055.0, 492.0], [1303.0, 492.0], [1303.0, 508.0], [1055.0, 508.0]], [[1057.0, 508.0], [1313.0, 508.0], [1313.0, 525.0], [1057.0, 525.0]], [[1050.0, 525.0], [1315.0, 525.0], [1315.0, 541.0], [1050.0, 541.0]]], "lines": ["肌右渦自体世界的に見て数少ない昨日で", "でも痛めてまれてあり、服告されているの", "地震大団である日本でクレーターがその", "肌しく、糸守滞の存在は奇跡ともいえるだろ"]}, {"box": [1041, 384, 1127, 400], "vertical": false, "font_size": 16, "lines_coords": [[[1041.0, 384.0], [1127.0, 384.0], [1127.0, 400.0], [1041.0, 400.0]]], "lines": ["潮なのである。"]}, {"box": [649, 133, 921, 175], "vertical": false, "font_size": 40, "lines_coords": [[[649.0, 135.0], [921.0, 133.0], [921.0, 173.0], [649.0, 175.0]]], "lines": ["糸守湖の由来"]}, {"box": [766, 297, 804, 314], "vertical": false, "font_size": 17, "lines_coords": [[[766.0, 297.0], [804.0, 297.0], [804.0, 314.0], [766.0, 314.0]]], "lines": ["糸寸湖"]}, {"box": [733, 576, 848, 602], "vertical": false, "font_size": 26, "lines_coords": [[[733.0, 576.0], [848.0, 576.0], [848.0, 602.0], [733.0, 602.0]]], "lines": ["これからは、このようにしていますので、今日は日本ではないのでしょうか。"]}, {"box": [286, 302, 495, 579], "vertical": true, "font_size": 34, "lines_coords": [[[445.0, 307.0], [478.0, 307.0], [478.0, 461.0], [445.0, 461.0]], [[391.0, 307.0], [424.0, 307.0], [424.0, 464.0], [391.0, 464.0]], [[332.0, 302.0], [372.0, 302.0], [372.0, 461.0], [332.0, 461.0]], [[286.0, 304.0], [316.0, 304.0], [316.0, 578.0], [286.0, 578.0]]], "lines": ["少なくとも", "一千年まえ", "同じ場所に", "隕石が落ちたんや！"]}, {"box": [1442, 808, 1481, 956], "vertical": true, "font_size": 39, "lines_coords": [[[1442.0, 808.0], [1481.0, 808.0], [1481.0, 956.0], [1442.0, 956.0]]], "lines": ["あれはな"]}, {"box": [755, 825, 813, 1003], "vertical": true, "font_size": 42, "lines_coords": [[[759.0, 825.0], [801.0, 825.0], [797.0, 1003.0], [755.0, 1003.0]]], "lines": ["隕石湖や！"]}, {"box": [452, 1404, 499, 1577], "vertical": true, "font_size": 47, "lines_coords": [[[452.0, 1404.0], [499.0, 1404.0], [499.0, 1577.0], [452.0, 1577.0]]], "lines": ["そうか．．．"]}, {"box": [338, 1404, 499, 1658], "vertical": true, "font_size": 49, "lines_coords": [[[450.0, 1406.0], [499.0, 1406.0], [499.0, 1577.0], [450.0, 1577.0]]], "lines": ["そうか．．．"]}, {"box": [335, 1529, 384, 1661], "vertical": true, "font_size": 49, "lines_coords": [[[335.0, 1530.0], [384.0, 1530.0], [384.0, 1661.0], [335.0, 1661.0]]], "lines": ["だから"]}, {"box": [222, 2104, 356, 2346], "vertical": true, "font_size": 59, "lines_coords": [[[283.0, 2104.0], [351.0, 2104.0], [351.0, 2303.0], [283.0, 2303.0]], [[222.0, 2109.0], [272.0, 2109.0], [276.0, 2346.0], [227.0, 2346.0]]], "lines": ["あの絵が", "あったんだ"]}], "img_path": "02_160.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [229, 263, 281, 405], "vertical": true, "font_size": 52, "lines_coords": [[[229.0, 264.0], [281.0, 264.0], [281.0, 405.0], [229.0, 405.0]]], "lines": ["おお！"]}, {"box": [1367, 1035, 1409, 1354], "vertical": true, "font_size": 39, "lines_coords": [[[1367.0, 1035.0], [1406.0, 1035.0], [1406.0, 1354.0], [1367.0, 1354.0]]], "lines": ["そうだよテッシー！"]}, {"box": [1343, 1957, 1400, 2236], "vertical": true, "font_size": 50, "lines_coords": [[[1345.0, 1959.0], [1395.0, 1959.0], [1395.0, 2235.0], [1345.0, 2235.0]]], "lines": ["やろうぜ！"]}], "img_path": "02_161.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1233, 405, 1374, 942], "vertical": true, "font_size": 141, "lines_coords": [[[1233.0, 405.0], [1374.0, 405.0], [1374.0, 942.0], [1233.0, 942.0]]], "lines": ["俺たちで！"]}, {"box": [180, 2247, 479, 2340], "vertical": false, "font_size": 56, "lines_coords": [[[318.0, 2247.0], [382.0, 2271.0], [363.0, 2322.0], [300.0, 2299.0]], [[239.0, 2257.0], [309.0, 2257.0], [309.0, 2315.0], [239.0, 2315.0]]], "lines": ["はい", "六"]}], "img_path": "02_162.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [143, 965, 325, 1141], "vertical": false, "font_size": 164, "lines_coords": [[[154.0, 965.0], [325.0, 977.0], [314.0, 1141.0], [143.0, 1129.0]]], "lines": ["０２"]}, {"box": [84, 710, 785, 932], "vertical": false, "font_size": 137, "lines_coords": [[[257.0, 742.0], [431.0, 716.0], [445.0, 834.0], [272.0, 860.0]], [[372.0, 698.0], [785.0, 698.0], [785.0, 895.0], [372.0, 895.0]], [[84.0, 707.0], [281.0, 707.0], [281.0, 895.0], [84.0, 895.0]], [[96.0, 831.0], [269.0, 852.0], [260.0, 944.0], [86.0, 923.0]]], "lines": ["の．．．", "つ．．．名は。", "君！！", "何が。"]}], "img_path": "02_163.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [131, 279, 715, 609], "vertical": false, "font_size": 98, "lines_coords": [[[166.0, 288.0], [708.0, 288.0], [708.0, 328.0], [166.0, 328.0]], [[145.0, 325.0], [651.0, 321.0], [651.0, 452.0], [145.0, 457.0]], [[140.0, 382.0], [309.0, 389.0], [300.0, 609.0], [131.0, 602.0]], [[323.0, 468.0], [621.0, 468.0], [621.0, 517.0], [323.0, 517.0]], [[316.0, 527.0], [497.0, 522.0], [497.0, 571.0], [316.0, 576.0]]], "lines": ["ＭＦコミックスアライブシリーズ", "君の名は。２", "日漫画原作", "琴音らんまる", "新海『誠"]}, {"box": [173, 740, 529, 771], "vertical": false, "font_size": 31, "lines_coords": [[[173.0, 740.0], [529.0, 740.0], [529.0, 771.0], [173.0, 771.0]]], "lines": ["２０１６年１２月２３日「発行"]}, {"box": [166, 813, 633, 890], "vertical": false, "font_size": 33.0, "lines_coords": [[[166.0, 815.0], [562.0, 813.0], [562.0, 846.0], [166.0, 848.0]], [[168.0, 855.0], [633.0, 857.0], [633.0, 890.0], [168.0, 888.0]]], "lines": ["ＣＲａｎｍａｒｕＫｏｔｏｎｅ２０１６", "©２０１６「君の名は。Ｊ製作委員会"]}, {"box": [166, 932, 855, 1038], "vertical": false, "font_size": 30.666666666666668, "lines_coords": [[[166.0, 932.0], [799.0, 932.0], [799.0, 963.0], [166.0, 963.0]], [[166.0, 970.0], [855.0, 970.0], [855.0, 1000.0], [166.0, 1000.0]], [[168.0, 1007.0], [567.0, 1007.0], [567.0, 1038.0], [168.0, 1038.0]]], "lines": ["本電子書籍は下記にもとづいて制作しました", "ＭＦコミックスアライブシリーズ＂君の名は。２』", "２０１６年１２月２３日初版発行"]}, {"box": [145, 1082, 755, 1218], "vertical": false, "font_size": 59.666666666666664, "lines_coords": [[[161.0, 1082.0], [429.0, 1082.0], [429.0, 1129.0], [161.0, 1129.0]], [[147.0, 1089.0], [654.0, 1106.0], [651.0, 1204.0], [145.0, 1188.0]], [[166.0, 1185.0], [755.0, 1185.0], [755.0, 1218.0], [166.0, 1218.0]]], "lines": ["発行人青柳昌行発行行株式会社Ｋ", "発行人・青柳昌行発・行・株式会社（ＡＤＯＫＡＮＡＴＯ－３）ア・東京都千代田区富士児と", "〒１０２－８１７７７東京都平野「代田区富士見２１３３ｍｍ（カスタマー・"]}, {"box": [316, 1326, 515, 1357], "vertical": false, "font_size": 31, "lines_coords": [[[316.0, 1326.0], [515.0, 1326.0], [515.0, 1357.0], [316.0, 1357.0]]], "lines": ["アライブ編集部"]}, {"box": [164, 1371, 595, 1399], "vertical": false, "font_size": 26, "lines_coords": [[[164.0, 1371.0], [595.0, 1373.0], [595.0, 1399.0], [164.0, 1396.0]]], "lines": ["ｈｔｔｐ：／／ｗｗｗｋａｄｏｋａｗａｃｏ．ｊｐ／"]}, {"box": [161, 1223, 909, 1319], "vertical": false, "font_size": 28.0, "lines_coords": [[[166.0, 1223.0], [909.0, 1223.0], [909.0, 1253.0], [166.0, 1253.0]], [[168.0, 1260.0], [823.0, 1260.0], [823.0, 1284.0], [168.0, 1284.0]], [[161.0, 1289.0], [628.0, 1289.0], [628.0, 1319.0], [161.0, 1319.0]]], "lines": ["ですが、話の５７０００２０１７年０１スタマーサポートセンター）", "受付時間、年末年始を除く平日１０：００－１８００まで", "又．．．９．４．編集企画「コミツク＆キャラクター局"]}, {"box": [166, 1457, 1052, 1727], "vertical": false, "font_size": 28.75, "lines_coords": [[[166.0, 1457.0], [970.0, 1457.0], [970.0, 1488.0], [166.0, 1488.0]], [[166.0, 1495.0], [820.0, 1495.0], [820.0, 1525.0], [166.0, 1525.0]], [[166.0, 1525.0], [1031.0, 1525.0], [1031.0, 1556.0], [166.0, 1556.0]], [[166.0, 1563.0], [1052.0, 1563.0], [1052.0, 1593.0], [166.0, 1593.0]], [[166.0, 1598.0], [748.0, 1598.0], [748.0, 1628.0], [166.0, 1628.0]], [[166.0, 1631.0], [1034.0, 1628.0], [1034.0, 1659.0], [166.0, 1661.0]], [[168.0, 1668.0], [623.0, 1668.0], [623.0, 1692.0], [168.0, 1692.0]], [[168.0, 1703.0], [933.0, 1703.0], [933.0, 1727.0], [168.0, 1727.0]]], "lines": ["本作品の全部または－一部を無断で複製、転載、配信、送信したり、", "ホームページ上に転載しただいすることを禁止します。", "また、本作品の内容を無断で改変、改ざん等を行うことも禁止します。", "本作品購入時にご承諾いいただいた規約により、有償・無償にかかわらず", "本作品を第三者に譲渡することはできません。", "本作品を示すムネイルなどのイメージ画像は、再ダウンロード時に", "予告なく変更される場合があります。", "本作品の内容は、底本発行時の取材・執筆内容に基づきます。"]}, {"box": [168, 1771, 1235, 1795], "vertical": false, "font_size": 24, "lines_coords": [[[168.0, 1771.0], [1235.0, 1771.0], [1235.0, 1795.0], [168.0, 1795.0]]], "lines": ["また、ご覧になるリーディングシステムにより、表示の差が認められることがあります。"]}, {"box": [166, 1842, 593, 1865], "vertical": false, "font_size": 23, "lines_coords": [[[166.0, 1842.0], [593.0, 1842.0], [593.0, 1865.0], [166.0, 1865.0]]], "lines": ["Ｃｏｖｅｒｌｌｕｓｔｒａｔｉｏｎ：琴音らんまる"]}], "img_path": "02_164.webp"}]}