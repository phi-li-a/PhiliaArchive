{"version": "0.2.1", "title": "Kimi no Na wa (Upscaled)", "title_uuid": "d9c72bf6-dfa6-4801-a074-1e02b5e57dac", "volume": "[新海誠, 琴音らんまる] 君の名は。 02", "volume_uuid": "f4113316-8e17-4d7f-b53e-b80029e65bd3", "pages": [{"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1113, 28, 1681, 728], "vertical": false, "font_size": 678, "lines_coords": [[[1113.0, 51.0], [1653.0, 28.0], [1681.0, 705.0], [1141.0, 728.0]]], "lines": ["君"]}, {"box": [830, 65, 937, 438], "vertical": true, "font_size": 65, "lines_coords": [[[865.0, 67.0], [898.0, 65.0], [905.0, 173.0], [872.0, 175.0]], [[830.0, 140.0], [937.0, 140.0], [937.0, 438.0], [830.0, 438.0]]], "lines": ["原作の", "新海誠"]}, {"box": [769, 60, 825, 616], "vertical": true, "font_size": 65, "lines_coords": [[[769.0, 60.0], [825.0, 60.0], [825.0, 616.0], [769.0, 616.0]]], "lines": ["漫画家で買いのんでする"]}, {"box": [7, 16, 490, 607], "vertical": true, "font_size": 382, "lines_coords": [[[23.0, 82.0], [398.0, 16.0], [490.0, 541.0], [112.0, 607.0]]], "lines": ["クロ"]}, {"box": [63, 667, 522, 703], "vertical": false, "font_size": 33, "lines_coords": [[[63.0, 670.0], [522.0, 667.0], [522.0, 700.0], [63.0, 703.0]]], "lines": ["ｙｏｕｒｎａｍｅ．"]}, {"box": [110, 897, 480, 1539], "vertical": true, "font_size": 246, "lines_coords": [[[110.0, 949.0], [351.0, 897.0], [480.0, 1488.0], [239.0, 1539.0]]], "lines": ["．．．"]}, {"box": [49, 2279, 296, 2351], "vertical": false, "font_size": 40, "lines_coords": [[[53.0, 2285.0], [283.0, 2280.0], [283.0, 2320.0], [53.0, 2325.0]]], "lines": ["イギリテック"]}], "img_path": "00_cover.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [], "img_path": "02_000.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1161, 76, 1494, 141], "vertical": false, "font_size": 49, "lines_coords": [[[1174.0, 79.0], [1474.0, 79.0], [1474.0, 128.0], [1174.0, 128.0]]], "lines": ["君の名は"]}, {"box": [1305, 221, 1344, 365], "vertical": true, "font_size": 32, "lines_coords": [[[1306.0, 225.0], [1338.0, 225.0], [1338.0, 360.0], [1306.0, 360.0]]], "lines": ["サヤちん"]}, {"box": [766, 248, 874, 400], "vertical": true, "font_size": 52, "lines_coords": [[[813.0, 248.0], [874.0, 248.0], [874.0, 370.0], [813.0, 370.0]], [[766.0, 255.0], [808.0, 255.0], [808.0, 400.0], [766.0, 400.0]]], "lines": ["それに", "テッシー"]}, {"box": [103, 278, 341, 531], "vertical": true, "font_size": 50, "lines_coords": [[[274.0, 278.0], [340.0, 278.0], [340.0, 316.0], [274.0, 316.0]], [[222.0, 278.0], [264.0, 278.0], [260.0, 529.0], [218.0, 529.0]], [[164.0, 278.0], [206.0, 278.0], [206.0, 496.0], [164.0, 496.0]], [[103.0, 278.0], [152.0, 278.0], [152.0, 426.0], [103.0, 426.0]]], "lines": ["俺", "二人ともだいぶ", "仲良くなれた", "気がする"]}, {"box": [1193, 946, 1260, 1169], "vertical": true, "font_size": 49, "lines_coords": [[[1193.0, 946.0], [1242.0, 946.0], [1242.0, 1169.0], [1193.0, 1169.0]]], "lines": ["こりゃ誰だ？"]}, {"box": [860, 965, 982, 1151], "vertical": true, "font_size": 42, "lines_coords": [[[921.0, 967.0], [963.0, 967.0], [963.0, 1117.0], [921.0, 1117.0]], [[860.0, 965.0], [902.0, 965.0], [905.0, 1150.0], [862.0, 1150.0]]], "lines": ["ああ俺だ", "夢の中の："]}, {"box": [161, 939, 340, 1237], "vertical": true, "font_size": 44, "lines_coords": [[[276.0, 939.0], [325.0, 939.0], [321.0, 1237.0], [272.0, 1237.0]], [[222.0, 946.0], [262.0, 946.0], [262.0, 1235.0], [222.0, 1235.0]], [[161.0, 942.0], [204.0, 942.0], [206.0, 1164.0], [164.0, 1164.0]]], "lines": ["この結び方だって", "最初はだいぶ苦労", "したんだぜ．．．"]}, {"box": [933, 1509, 990, 1795], "vertical": true, "font_size": 40, "lines_coords": [[[933.0, 1509.0], [973.0, 1509.0], [973.0, 1795.0], [933.0, 1795.0]]], "lines": ["私は君じゃないよ"]}, {"box": [225, 1307, 260, 1452], "vertical": true, "font_size": 32, "lines_coords": [[[225.0, 1307.0], [257.0, 1307.0], [257.0, 1450.0], [225.0, 1450.0]]], "lines": ["ちがうよ"]}, {"box": [248, 1954, 342, 2097], "vertical": true, "font_size": 94, "lines_coords": [[[248.0, 1954.0], [342.0, 1954.0], [342.0, 2097.0], [248.0, 2097.0]]], "lines": ["私は．．"]}], "img_path": "02_001.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [], "img_path": "02_002.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [124, 1694, 1158, 1940], "vertical": false, "font_size": 219, "lines_coords": [[[248.0, 1694.0], [1158.0, 1694.0], [1158.0, 1940.0], [248.0, 1940.0]], [[145.0, 1732.0], [347.0, 1732.0], [347.0, 1924.0], [145.0, 1924.0]]], "lines": ["昔の名は", "君"]}, {"box": [143, 1945, 684, 2114], "vertical": false, "font_size": 38, "lines_coords": [[[304.0, 1945.0], [576.0, 1945.0], [576.0, 1992.0], [304.0, 1992.0]], [[393.0, 2020.0], [492.0, 2020.0], [492.0, 2053.0], [393.0, 2053.0]], [[145.0, 2017.0], [218.0, 2017.0], [218.0, 2053.0], [145.0, 2053.0]], [[143.0, 2064.0], [684.0, 2060.0], [684.0, 2109.0], [143.0, 2114.0]]], "lines": ["ｅｍａｒ", "漫画", "原作", "新海誠琴音らんまる"]}, {"box": [145, 2165, 490, 2266], "vertical": false, "font_size": 38, "lines_coords": [[[147.0, 2165.0], [241.0, 2165.0], [241.0, 2198.0], [147.0, 2198.0]], [[403.0, 2224.0], [490.0, 2224.0], [490.0, 2259.0], [403.0, 2259.0]], [[145.0, 2203.0], [302.0, 2182.0], [307.0, 2221.0], [150.0, 2242.0]], [[147.0, 2233.0], [281.0, 2224.0], [283.0, 2257.0], [150.0, 2266.0]]], "lines": ["んん〜", "．．．", "．．．", "．．．"]}, {"box": [145, 2271, 340, 2299], "vertical": false, "font_size": 26, "lines_coords": [[[145.0, 2271.0], [340.0, 2273.0], [340.0, 2299.0], [145.0, 2296.0]]], "lines": ["１０ｃｒｂｅｐｌｅ"]}], "img_path": "02_003.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [663, 119, 1371, 328], "vertical": false, "font_size": 197, "lines_coords": [[[665.0, 119.0], [1371.0, 131.0], [1369.0, 328.0], [663.0, 316.0]]], "lines": ["の名は。"]}, {"box": [377, 135, 651, 321], "vertical": false, "font_size": 138.0, "lines_coords": [[[515.0, 159.0], [651.0, 159.0], [651.0, 290.0], [515.0, 290.0]], [[377.0, 182.0], [536.0, 135.0], [576.0, 274.0], [417.0, 321.0]]], "lines": ["手（", "君"]}, {"box": [1385, 529, 1447, 680], "vertical": true, "font_size": 52, "lines_coords": [[[1390.0, 536.0], [1442.0, 536.0], [1442.0, 667.0], [1390.0, 667.0]]], "lines": ["目次"]}, {"box": [1153, 517, 1263, 1117], "vertical": true, "font_size": 74, "lines_coords": [[[1195.0, 789.0], [1252.0, 792.0], [1235.0, 1115.0], [1179.0, 1113.0]], [[1172.0, 517.0], [1263.0, 517.0], [1263.0, 810.0], [1172.0, 810.0]]], "lines": ["「００１", "第四話"]}, {"box": [945, 525, 1055, 799], "vertical": true, "font_size": 38, "lines_coords": [[[1001.0, 532.0], [1050.0, 532.0], [1055.0, 799.0], [1005.0, 799.0]], [[945.0, 525.0], [977.0, 525.0], [980.0, 726.0], [947.0, 726.0]]], "lines": ["また、", "「－－＾ｈ＿ｏｐ＿ｅｏ"]}, {"box": [785, 532, 858, 796], "vertical": true, "font_size": 36, "lines_coords": [[[816.0, 534.0], [855.0, 534.0], [858.0, 796.0], [818.0, 796.0]], [[790.0, 532.0], [827.0, 532.0], [823.0, 794.0], [785.0, 794.0]]], "lines": ["おいしいです", "２０１７／１３は"]}, {"box": [1001, 832, 1038, 1108], "vertical": true, "font_size": 38, "lines_coords": [[[1005.0, 832.0], [1038.0, 832.0], [1034.0, 1108.0], [1001.0, 1108.0]]], "lines": ["．．．０５１"]}, {"box": [806, 918, 837, 1106], "vertical": true, "font_size": 36, "lines_coords": [[[806.0, 918.0], [837.0, 918.0], [837.0, 1106.0], [806.0, 1106.0]]], "lines": ["１００"]}, {"box": [1404, 1089, 1559, 1942], "vertical": true, "font_size": 136, "lines_coords": [[[1404.0, 1092.0], [1540.0, 1089.0], [1559.0, 1935.0], [1423.0, 1938.0]]], "lines": ["君の名は。"]}, {"box": [1392, 1680, 1416, 1961], "vertical": true, "font_size": 24, "lines_coords": [[[1392.0, 1680.0], [1416.0, 1680.0], [1416.0, 1961.0], [1392.0, 1961.0]]], "lines": ["ｙｏｕｒ．ｎａｍｅ．"]}], "img_path": "02_004.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [96, 707, 649, 810], "vertical": false, "font_size": 32, "lines_coords": [[[100.0, 710.0], [628.0, 710.0], [628.0, 742.0], [100.0, 742.0]], [[100.0, 771.0], [623.0, 771.0], [623.0, 803.0], [100.0, 803.0]]], "lines": ["ｍａｋｏｔｏｓｈｉｎｋａ", "「ａｎｍａｒｕｋ．ｔｏｎ"]}], "img_path": "02_005.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1329, 356, 1451, 496], "vertical": true, "font_size": 56, "lines_coords": [[[1388.0, 356.0], [1451.0, 356.0], [1451.0, 461.0], [1388.0, 461.0]], [[1334.0, 358.0], [1383.0, 360.0], [1378.0, 496.0], [1329.0, 494.0]]], "lines": ["ねえ", "．．．くん"]}, {"box": [1008, 377, 1059, 677], "vertical": true, "font_size": 49, "lines_coords": [[[1008.0, 382.0], [1057.0, 382.0], [1057.0, 677.0], [1008.0, 677.0]]], "lines": ["覚えてない？"]}, {"box": [722, 119, 777, 673], "vertical": true, "font_size": 42, "lines_coords": [[[726.0, 119.0], [769.0, 119.0], [766.0, 665.0], [724.0, 665.0]]], "lines": ["前巻までのあらすに"]}, {"box": [281, 117, 614, 888], "vertical": true, "font_size": 35, "lines_coords": [[[574.0, 117.0], [607.0, 117.0], [609.0, 839.0], [576.0, 839.0]], [[511.0, 117.0], [551.0, 117.0], [555.0, 675.0], [515.0, 675.0]], [[459.0, 121.0], [492.0, 121.0], [492.0, 508.0], [459.0, 508.0]], [[393.0, 117.0], [433.0, 117.0], [436.0, 848.0], [396.0, 848.0]], [[340.0, 119.0], [372.0, 119.0], [372.0, 888.0], [340.0, 888.0]], [[281.0, 117.0], [314.0, 117.0], [314.0, 562.0], [281.0, 562.0]]], "lines": ["千年ぶりとなる彗星の来訪を一か月後に控えた日本。", "山深い田舎町に暮らす女子高生二葉は", "憂鬱な毎日を過ごしていた。", "町長である父の選挙運動に、家系の神社の古き風習。", "小さく狭い町で、周囲の目が余計に気になる年頃だけに", "都会への憧れを強くするばかり。"]}, {"box": [154, 119, 199, 789], "vertical": true, "font_size": 40, "lines_coords": [[[159.0, 119.0], [199.0, 119.0], [194.0, 789.0], [154.0, 789.0]]], "lines": ["「来世は東京のイケメンつ男子にしてくださーい！！"]}, {"box": [478, 1992, 1636, 2273], "vertical": false, "font_size": 224, "lines_coords": [[[478.0, 2029.0], [966.0, 2013.0], [973.0, 2238.0], [485.0, 2254.0]], [[858.0, 2053.0], [1245.0, 2022.0], [1261.0, 2217.0], [874.0, 2247.0]], [[1160.0, 1992.0], [1636.0, 2020.0], [1620.0, 2273.0], [1144.0, 2245.0]]], "lines": ["君の", "２名", "名は。"]}], "img_path": "02_006.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1375, 117, 1528, 1064], "vertical": true, "font_size": 31, "lines_coords": [[[1491.0, 117.0], [1524.0, 117.0], [1524.0, 747.0], [1491.0, 747.0]], [[1432.0, 117.0], [1463.0, 117.0], [1463.0, 1064.0], [1432.0, 1064.0]], [[1376.0, 121.0], [1406.0, 121.0], [1406.0, 832.0], [1376.0, 832.0]]], "lines": ["そんなある日、自分が男の子になる夢を見る。", "見覚えのない部屋、見知らぬ友人、目の前に広がるのは東京の街並み", "念願だった都会での生活を思いっきり満喫する三葉。"]}, {"box": [1134, 114, 1297, 874], "vertical": true, "font_size": 33, "lines_coords": [[[1254.0, 119.0], [1287.0, 119.0], [1287.0, 874.0], [1254.0, 874.0]], [[1198.0, 119.0], [1231.0, 119.0], [1231.0, 517.0], [1198.0, 517.0]], [[1134.0, 114.0], [1167.0, 114.0], [1170.0, 583.0], [1137.0, 583.0]]], "lines": ["二方、東京で暮らす男子高校生・瀧も、奇妙な夢を見た。", "行ったこともない山奥の町で", "自分が女子高生になっているのだ。"]}, {"box": [837, 105, 1054, 574], "vertical": true, "font_size": 33, "lines_coords": [[[1020.0, 119.0], [1050.0, 119.0], [1050.0, 480.0], [1020.0, 480.0]], [[961.0, 114.0], [991.0, 114.0], [991.0, 564.0], [961.0, 564.0]], [[900.0, 117.0], [933.0, 117.0], [933.0, 288.0], [900.0, 288.0]], [[837.0, 105.0], [877.0, 105.0], [877.0, 321.0], [837.0, 321.0]]], "lines": ["繰り返される不思議な夢", "そして明らかに抜け落ちている", "記憶と時間。", "二人は気付く。"]}, {"box": [691, 114, 785, 510], "vertical": true, "font_size": 51, "lines_coords": [[[719.0, 114.0], [785.0, 119.0], [757.0, 510.0], [691.0, 506.0]], [[701.0, 133.0], [736.0, 133.0], [736.0, 239.0], [701.0, 239.0]]], "lines": ["「私たち、入れ替わってる！？」", "俺だち、"]}, {"box": [114, 117, 210, 556], "vertical": true, "font_size": 32, "lines_coords": [[[175.0, 119.0], [206.0, 119.0], [206.0, 553.0], [175.0, 553.0]], [[114.0, 117.0], [147.0, 117.0], [150.0, 525.0], [117.0, 525.0]]], "lines": ["出会うことのない二人の出逢い、", "運命の歯車が、いま動き出す。"]}, {"box": [1257, 550, 1300, 883], "vertical": true, "font_size": 43, "lines_coords": [[[1257.0, 550.0], [1300.0, 550.0], [1300.0, 883.0], [1257.0, 883.0]]], "lines": ["瀧も、奇妙な夢を見た。"]}, {"box": [329, 106, 606, 1115], "vertical": true, "font_size": 36, "lines_coords": [[[567.0, 117.0], [600.0, 117.0], [602.0, 468.0], [569.0, 468.0]], [[511.0, 117.0], [544.0, 117.0], [544.0, 1019.0], [511.0, 1019.0]], [[447.0, 114.0], [487.0, 114.0], [487.0, 754.0], [447.0, 754.0]], [[389.0, 117.0], [429.0, 117.0], [426.0, 895.0], [386.0, 895.0]], [[332.0, 117.0], [365.0, 117.0], [363.0, 1115.0], [330.0, 1115.0]]], "lines": ["幾度も入れ替わる身体と", "その生活に戸惑いながらも、現実を少しずつ受け止める瀧と三葉", "残されたお互いの女王を通して、時にケンカし、", "時に相手の人生を楽しみながら、状況を乗り切っていく。", "しかし、気持ちが打ち解けてきた矢先。突然入れ替わりが途切れてしまう"]}], "img_path": "02_007.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [937, 719, 1621, 904], "vertical": false, "font_size": 130, "lines_coords": [[[937.0, 728.0], [1247.0, 728.0], [1247.0, 846.0], [937.0, 846.0]], [[1179.0, 719.0], [1568.0, 719.0], [1568.0, 862.0], [1179.0, 862.0]]], "lines": ["君の", "つ名は"]}], "img_path": "02_008.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1158, 435, 1257, 691], "vertical": true, "font_size": 40, "lines_coords": [[[1217.0, 435.0], [1256.0, 435.0], [1256.0, 691.0], [1217.0, 691.0]], [[1158.0, 435.0], [1198.0, 435.0], [1198.0, 583.0], [1158.0, 583.0]]], "lines": ["おかけになった", "電話は．．．"]}, {"box": [823, 815, 867, 855], "vertical": false, "font_size": 31, "lines_coords": [[[823.0, 825.0], [860.0, 815.0], [867.0, 846.0], [830.0, 855.0]]], "lines": ["Ｅｘ"]}, {"box": [432, 637, 550, 994], "vertical": true, "font_size": 33, "lines_coords": [[[492.0, 639.0], [525.0, 639.0], [525.0, 991.0], [492.0, 991.0]], [[433.0, 639.0], [466.0, 639.0], [466.0, 794.0], [433.0, 794.0]]], "lines": ["電波の届かない場所に", "あるか．．．"]}], "img_path": "02_009.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [930, 832, 1042, 1019], "vertical": true, "font_size": 38, "lines_coords": [[[984.0, 832.0], [1027.0, 832.0], [1029.0, 1019.0], [987.0, 1019.0]], [[930.0, 834.0], [963.0, 834.0], [968.0, 1012.0], [935.0, 1012.0]]], "lines": ["浮かない顔", "しちゃって"]}, {"box": [264, 1478, 322, 1692], "vertical": true, "font_size": 40, "lines_coords": [[[269.0, 1478.0], [309.0, 1478.0], [304.0, 1692.0], [264.0, 1692.0]]], "lines": ["何してんだ？"]}, {"box": [518, 2008, 672, 2132], "vertical": true, "font_size": 89, "lines_coords": [[[583.0, 2015.0], [672.0, 2015.0], [672.0, 2083.0], [583.0, 2083.0]], [[529.0, 2008.0], [619.0, 2017.0], [607.0, 2132.0], [518.0, 2123.0]]], "lines": ["司", "高木"]}], "img_path": "02_010.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1276, 426, 1497, 728], "vertical": true, "font_size": 36, "lines_coords": [[[1439.0, 426.0], [1481.0, 426.0], [1481.0, 539.0], [1439.0, 539.0]], [[1388.0, 431.0], [1421.0, 431.0], [1421.0, 660.0], [1388.0, 660.0]], [[1329.0, 431.0], [1369.0, 431.0], [1369.0, 632.0], [1329.0, 632.0]], [[1277.0, 428.0], [1308.0, 428.0], [1308.0, 728.0], [1277.0, 728.0]]], "lines": ["別に～", "面倒臭えことが", "一個終わって", "すっきりしてるだけ"]}, {"box": [264, 290, 419, 508], "vertical": true, "font_size": 41, "lines_coords": [[[379.0, 295.0], [419.0, 295.0], [419.0, 473.0], [379.0, 473.0]], [[311.0, 290.0], [361.0, 290.0], [365.0, 459.0], [316.0, 459.0]], [[264.0, 297.0], [297.0, 297.0], [297.0, 506.0], [264.0, 506.0]]], "lines": ["なんだあ？", "お前最近", "可愛くないな"]}, {"box": [1373, 916, 1514, 1322], "vertical": true, "font_size": 47, "lines_coords": [[[1444.0, 918.0], [1514.0, 918.0], [1514.0, 1050.0], [1444.0, 1050.0]], [[1423.0, 1101.0], [1463.0, 1101.0], [1463.0, 1235.0], [1423.0, 1235.0]], [[1376.0, 1106.0], [1406.0, 1106.0], [1406.0, 1321.0], [1376.0, 1321.0]]], "lines": ["は？", "なんだよ", "可愛くないって"]}, {"box": [738, 965, 937, 1181], "vertical": true, "font_size": 36, "lines_coords": [[[881.0, 965.0], [921.0, 965.0], [926.0, 1153.0], [886.0, 1153.0]], [[834.0, 967.0], [867.0, 967.0], [867.0, 1122.0], [834.0, 1122.0]], [[783.0, 965.0], [823.0, 965.0], [823.0, 1096.0], [783.0, 1096.0]], [[740.0, 967.0], [771.0, 967.0], [771.0, 1181.0], [740.0, 1181.0]]], "lines": ["遅れちゃった", "ごめーん！", "待った？", "とかいってさあ"]}, {"box": [243, 944, 393, 1227], "vertical": true, "font_size": 38, "lines_coord