 [712.0, 2282.0], [687.0, 2282.0]]], "lines": ["ていうか", "変な目で", "俺を見るな！"]}], "img_path": "02_011.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1428, 328, 1581, 684], "vertical": true, "font_size": 37, "lines_coords": [[[1540.0, 328.0], [1580.0, 328.0], [1580.0, 473.0], [1540.0, 473.0]], [[1484.0, 328.0], [1524.0, 328.0], [1524.0, 684.0], [1484.0, 684.0]], [[1428.0, 337.0], [1460.0, 337.0], [1460.0, 506.0], [1428.0, 506.0]]], "lines": ["あれから", "三葉との入れ替わりは", "一度もない"]}, {"box": [365, 487, 421, 846], "vertical": true, "font_size": 32, "lines_coords": [[[368.0, 487.0], [400.0, 487.0], [398.0, 843.0], [365.0, 843.0]]], "lines": ["連絡もとれないままだ"]}, {"box": [1446, 1101, 1545, 1349], "vertical": true, "font_size": 38, "lines_coords": [[[1505.0, 1101.0], [1545.0, 1101.0], [1545.0, 1270.0], [1505.0, 1270.0]], [[1449.0, 1101.0], [1484.0, 1101.0], [1481.0, 1347.0], [1446.0, 1347.0]]], "lines": ["けどもう", "どうだっていい"]}, {"box": [266, 1746, 439, 2109], "vertical": true, "font_size": 39, "lines_coords": [[[377.0, 1746.0], [417.0, 1746.0], [417.0, 2032.0], [377.0, 2032.0]], [[318.0, 1748.0], [363.0, 1748.0], [363.0, 1863.0], [318.0, 1863.0]], [[267.0, 1753.0], [300.0, 1753.0], [300.0, 2001.0], [267.0, 2001.0]]], "lines": ["以前と変わりなく", "ここに", "俺がいるだけだ"]}], "img_path": "02_012.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [844, 1476, 886, 1689], "vertical": true, "font_size": 40, "lines_coords": [[[844.0, 1476.0], [884.0, 1476.0], [884.0, 1689.0], [844.0, 1689.0]]], "lines": ["ただいま～"]}, {"box": [185, 1699, 307, 1839], "vertical": true, "font_size": 58, "lines_coords": [[[243.0, 1699.0], [307.0, 1699.0], [307.0, 1804.0], [243.0, 1804.0]], [[185.0, 1703.0], [236.0, 1703.0], [236.0, 1839.0], [185.0, 1839.0]]], "lines": ["あれ", "父さん"]}], "img_path": "02_013.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1456, 208, 1516, 458], "vertical": true, "font_size": 40, "lines_coords": [[[1460.0, 208.0], [1500.0, 208.0], [1496.0, 457.0], [1456.0, 457.0]]], "lines": ["今日早くねえ？"]}, {"box": [269, 353, 473, 587], "vertical": true, "font_size": 30, "lines_coords": [[[436.0, 358.0], [468.0, 358.0], [468.0, 585.0], [436.0, 585.0]], [[391.0, 358.0], [424.0, 358.0], [424.0, 532.0], [391.0, 532.0]], [[349.0, 353.0], [384.0, 353.0], [379.0, 503.0], [344.0, 503.0]], [[311.0, 360.0], [337.0, 360.0], [337.0, 501.0], [311.0, 501.0]], [[269.0, 360.0], [293.0, 360.0], [293.0, 555.0], [269.0, 555.0]]], "lines": ["そういえばこの間", "作ってくれた", "芋のころ煮", "また作って", "くれないのか？"]}, {"box": [1146, 534, 1374, 710], "vertical": true, "font_size": 39, "lines_coords": [[[1327.0, 536.0], [1374.0, 536.0], [1374.0, 602.0], [1327.0, 602.0]], [[1285.0, 534.0], [1324.0, 534.0], [1324.0, 658.0], [1285.0, 658.0]], [[1238.0, 536.0], [1270.0, 536.0], [1270.0, 710.0], [1238.0, 710.0]], [[1188.0, 534.0], [1231.0, 534.0], [1231.0, 656.0], [1188.0, 656.0]], [[1146.0, 539.0], [1179.0, 539.0], [1179.0, 679.0], [1146.0, 679.0]]], "lines": ["おお", "明日から", "出張だからな", "夕飯は？", "作ったけど"]}, {"box": [952, 724, 1059, 841], "vertical": true, "font_size": 54, "lines_coords": [[[1015.0, 733.0], [1059.0, 733.0], [1059.0, 841.0], [1015.0, 841.0]], [[952.0, 724.0], [1017.0, 724.0], [1017.0, 817.0], [952.0, 817.0]]], "lines": ["んじゃ", "食う"]}, {"box": [572, 630, 662, 928], "vertical": true, "font_size": 32, "lines_coords": [[[628.0, 632.0], [661.0, 632.0], [661.0, 843.0], [628.0, 843.0]], [[572.0, 630.0], [604.0, 630.0], [604.0, 928.0], [572.0, 928.0]]], "lines": ["は？そんなの", "作れるわけねぇし！"]}, {"box": [820, 1094, 926, 1211], "vertical": true, "font_size": 50, "lines_coords": [[[872.0, 1094.0], [926.0, 1094.0], [926.0, 1211.0], [872.0, 1211.0]], [[820.0, 1094.0], [867.0, 1094.0], [867.0, 1176.0], [820.0, 1176.0]]], "lines": ["いつ？", "それ"]}, {"box": [1369, 1200, 1585, 1415], "vertical": true, "font_size": 35, "lines_coords": [[[1540.0, 1200.0], [1585.0, 1200.0], [1585.0, 1267.0], [1540.0, 1267.0]], [[1500.0, 1204.0], [1533.0, 1204.0