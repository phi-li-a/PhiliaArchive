 2088, 1156, 2242], "vertical": true, "font_size": 24, "lines_coords": [[[1132.0, 2088.0], [1156.0, 2088.0], [1156.0, 2242.0], [1132.0, 2242.0]]], "lines": ["そういうことですから、それではないのですが、"]}, {"box": [260, 1717, 441, 2177], "vertical": true, "font_size": 34, "lines_coords": [[[370.0, 1717.0], [417.0, 1717.0], [422.0, 2069.0], [375.0, 2069.0]], [[318.0, 1722.0], [358.0, 1722.0], [358.0, 2177.0], [318.0, 2177.0]], [[295.0, 1729.0], [311.0, 1729.0], [311.0, 1767.0], [295.0, 1767.0]], [[260.0, 1725.0], [293.0, 1725.0], [293.0, 1987.0], [260.0, 1987.0]]], "lines": ["彗星が二つに分裂し", "その周辺には無数の流星が", "！？", "発生しています。"]}], "img_path": "03_097.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1374, 213, 1483, 550], "vertical": true, "font_size": 36, "lines_coords": [[[1428.0, 213.0], [1467.0, 213.0], [1467.0, 550.0], [1428.0, 550.0]], [[1374.0, 217.0], [1406.0, 217.0], [1406.0, 482.0], [1374.0, 482.0]]], "lines": ["これは事前の予報には", "ありませんでした"]}, {"box": [832, 192, 891, 593], "vertical": true, "font_size": 40, "lines_coords": [[[832.0, 192.0], [872.0, 192.0], [874.0, 592.0], [834.0, 592.0]]], "lines": ["彗星の核が割れたとしか．．．"]}, {"box": [464, 215, 737, 613], "vertical": true, "font_size": 33, "lines_coords": [[[689.0, 215.0], [722.0, 215.0], [722.0, 450.0], [689.0, 450.0]], [[630.0, 217.0], [663.0, 217.0], [663.0, 532.0], [630.0, 532.0]], [[576.0, 217.0], [609.0, 217.0], [609.0, 611.0], [576.0, 611.0]], [[520.0, 217.0], [553.0, 217.0], [553.0, 546.0], [520.0, 546.0]], [[464.0, 217.0], [497.0, 217.0], [497.0, 426.0], [464.0, 426.0]]], "lines": ["考えられるのは", "海汐カロシュ限界は", "超えていないはずですから", "彗星内部でなんらかの", "異変が発生して"]}, {"box": [1137, 642, 1245, 975], "vertical": true, "font_size": 36, "lines_coords": [[[1188.0, 642.0], [1228.0, 642.0], [1228.0, 975.0], [1188.0, 975.0]], [[1137.0, 644.0], [1170.0, 644.0], [1170.0, 775.0], [1137.0, 775.0]]], "lines": ["しかし非常に幻想的な", "眺めです"]}, {"box": [208, 515, 318, 747], "vertical": true, "font_size": 34, "lines_coords": [[[264.0, 515.0], [300.0, 515.0], [297.0, 747.0], [262.0, 747.0]], [[208.0, 515.0], [241.0, 515.0], [241.0, 712.0], [208.0, 712.0]]], "lines": ["危険性はないん", "でしょうか？"]}, {"box": [1337, 1422, 1502, 1788], "vertical": true, "font_size": 35, "lines_coords": [[[1444.0, 1422.0], [1484.0, 1422.0], [1486.0, 1689.0], [1446.0, 1689.0]], [[1392.0, 1427.0], [1425.0, 1427.0], [1425.0, 1788.0], [1392.0, 1788.0]], [[1338.0, 1425.0], [1371.0, 1425.0], [1371.0, 1755.0], [1338.0, 1755.0]]], "lines": ["人間の居住地域に", "破片が落下する可能性は", "ゼロではありませんが、"]}, {"box": [459, 1024, 628, 1476], "vertical": true, "font_size": 38, "lines_coords": [[[569.0, 1028.0], [609.0, 1028.0], [609.0, 1462.0], [569.0, 1462.0]], [[513.0, 1024.0], [553.0, 1024.0], [551.0, 1476.0], [511.0, 1476.0]], [[459.0, 1031.0], [492.0, 1031.0], [492.0, 1378.0], [459.0, 1378.0]]], "lines": ["過去の事例では一九九四年に", "シューメーカー・レヴィ彗星が", "木星に落下その際に．．．"]}, {"box": [1465, 2193, 1573, 2360], "vertical": true, "font_size": 36, "lines_coords": [[[1519.0, 2193.0], [1559.0, 2193.0], [1559.0, 2360.0], [1519.0, 2360.0]], [[1465.0, 2196.0], [1498.0, 2196.0], [1498.0, 2355.0], [1465.0, 2355.0]]], "lines": ["俺ちょっと", "見てくる！"]}, {"box": [914, 1694, 1080, 2028], "vertical": true, "font_size": 35, "lines_coords": [[[1022.0, 1694.0], [1062.0, 1694.0], [1062.0, 2027.0], [1022.0, 2027.0]], [[970.0, 1699.0], [1003.0, 1699.0], [1003.0, 1931.0], [970.0, 1931.0]], [[914.0, 1699.0], [947.0, 1699.0], [947.0, 1996.0], [914.0, 1996.0]]], "lines": ["確率的には非常に低く", "まだ国立天文合", "からの正式発表は．．．"]}, {"box": [405, 1910, 572, 2308], "vertical": true, "font_size": 33, "lines_coords": [[[518.0, 1912.0], [551.0, 1912.0], [551.0, 2308.0], [518.0, 2308.0]], [[461.0, 1912.0], [494.0, 1912.0], [494.0, 2210.0], [461.0, 2210.0]], [[405.0, 1912.0], [438.0, 1912.0], [438.0, 2242.0], [405.0, 2242.0]]], "lines": ["これほど壮麗な天体現象を", "目撃していることは", "幸運と言えるでしょう"]}], "img_path": "03_098.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1059, 621, 1106, 834], "vertical": true, "font_size":