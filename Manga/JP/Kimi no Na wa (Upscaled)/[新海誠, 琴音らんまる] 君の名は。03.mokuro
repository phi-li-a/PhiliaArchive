{"version": "0.2.1", "title": "Kimi no Na wa (Upscaled)", "title_uuid": "d9c72bf6-dfa6-4801-a074-1e02b5e57dac", "volume": "[新海誠, 琴音らんまる] 君の名は。 03", "volume_uuid": "645b82ee-e435-47d3-b340-31507e825663", "pages": [{"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1109, 0, 1761, 801], "vertical": false, "font_size": 753, "lines_coords": [[[1195.0, 0.0], [1761.0, 42.0], [1674.0, 801.0], [1109.0, 738.0]]], "lines": ["君"]}, {"box": [765, 46, 940, 618], "vertical": true, "font_size": 81, "lines_coords": [[[825.0, 49.0], [930.0, 46.0], [940.0, 433.0], [834.0, 435.0]], [[769.0, 63.0], [825.0, 63.0], [825.0, 618.0], [769.0, 618.0]]], "lines": ["鳳新海誠", "漫画参音らんよる"]}, {"box": [6, 33, 488, 612], "vertical": true, "font_size": 408, "lines_coords": [[[70.0, 70.0], [478.0, 70.0], [478.0, 604.0], [70.0, 604.0]]], "lines": ["マロ"]}, {"box": [307, 675, 499, 698], "vertical": false, "font_size": 23, "lines_coords": [[[307.0, 675.0], [499.0, 675.0], [499.0, 698.0], [307.0, 698.0]]], "lines": ["ｍａｍｅ"]}, {"box": [26, 721, 478, 1601], "vertical": true, "font_size": 255, "lines_coords": [[[168.0, 1021.0], [478.0, 1040.0], [445.0, 1577.0], [136.0, 1558.0]], [[96.0, 768.0], [297.0, 768.0], [297.0, 928.0], [96.0, 928.0]]], "lines": ["★", "」"]}, {"box": [47, 2276, 297, 2351], "vertical": false, "font_size": 75, "lines_coords": [[[47.0, 2276.0], [297.0, 2276.0], [297.0, 2351.0], [47.0, 2351.0]]], "lines": ["ＭＦコラックス"]}], "img_path": "00_cover.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [], "img_path": "03_000.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [188, 149, 295, 740], "vertical": true, "font_size": 58, "lines_coords": [[[241.0, 550.0], [274.0, 550.0], [272.0, 740.0], [239.0, 740.0]], [[213.0, 157.0], [295.0, 157.0], [295.0, 435.0], [213.0, 435.0]]], "lines": ["１１７", "第九話"]}, {"box": [415, 159, 490, 435], "vertical": true, "font_size": 75, "lines_coords": [[[415.0, 159.0], [490.0, 159.0], [490.0, 435.0], [415.0, 435.0]]], "lines": ["第八話"]}, {"box": [604, 154, 698, 440], "vertical": true, "font_size": 85, "lines_coords": [[[604.0, 157.0], [689.0, 154.0], [698.0, 438.0], [614.0, 440.0]]], "lines": ["第七話"]}, {"box": [813, 152, 882, 310], "vertical": true, "font_size": 42, "lines_coords": [[[827.0, 166.0], [869.0, 166.0], [869.0, 300.0], [827.0, 300.0]]], "lines": ["目が"]}, {"box": [438, 569, 471, 742], "vertical": true, "font_size": 33, "lines_coords": [[[438.0, 569.0], [471.0, 569.0], [471.0, 742.0], [438.0, 742.0]]], "lines": ["０６？"]}, {"box": [629, 567, 673, 751], "vertical": true, "font_size": 33, "lines_coords": [[[635.0, 578.0], [668.0, 578.0], [668.0, 742.0], [635.0, 742.0]]], "lines": ["００３"]}, {"box": [1423, 1042, 1589, 1112], "vertical": false, "font_size": 44, "lines_coords": [[[1423.0, 1038.0], [1585.0, 1038.0], [1585.0, 1086.0], [1423.0, 1086.0]]], "lines": ["それは、"]}, {"box": [1379, 1336, 1489, 1964], "vertical": true, "font_size": 68, "lines_coords": [[[1421.0, 1368.0], [1489.0, 1375.0], [1463.0, 1593.0], [1395.0, 1586.0]]], "lines": ["月日．．．"]}, {"box": [351, 1971, 1252, 2254], "vertical": false, "font_size": 269, "lines_coords": [[[351.0, 1985.0], [1247.0, 1971.0], [1252.0, 2240.0], [356.0, 2254.0]]], "lines": ["君の名は"]}, {"box": [1249, 2242, 1418, 2268], "vertical": false, "font_size": 26, "lines_coords": [[[1249.0, 2242.0], [1418.0, 2242.0], [1418.0, 2268.0], [1249.0, 2268.0]]], "lines": ["ｍａｍ"]}], "img_path": "03_001.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [649, 522, 1458, 660], "vertical": false, "font_size": 30, "lines_coords": [[[968.0, 527.0], [1449.0, 527.0], [1449.0, 550.0], [968.0, 550.0]], [[851.0, 625.0], [1444.0, 625.0], [1444.0, 656.0], [851.0, 656.0]], [[649.0, 569.0], [1449.0, 574.0], [1449.0, 611.0], [649.0, 607.0]]], "lines": ["そんなある日、自分が男の子になる夢を見る", "念願だった都会での生活を思いっきり満喫する三葉", "見覚えのない部屋、見知らぬ友人、目の前に広がるのは東京の街並み"]}, {"box": [818, 148, 1460, 450], "vertical": false, "font_size": 31, "lines_coords": [[[867.0, 159.0], [1442.0, 159.0], [1442.0, 182.0], [867.0, 182.0]], [[977.0, 203.0], [1456.0, 196.0], [1456.0, 236.0], [977.0, 243.0]], [[837.0, 311.0], [1444.0, 311.0], [1444.0, 342.0], [837.0, 342.0]], [[818.0, 363.0], [1442.0, 363.0], [1442.0, 393.0], [818.0, 393.0]], [[1151.0, 260.0], [1449.0, 260.0], [1449.0, 290.0], [1151.0, 290.0]], [[1099.0, 414.0], [1451.0, 417.0], [1451.0, 450.0], [1099.0, 447.0]]], "lines": ["千年ぶりとなる彗星の来訪を一か月後に控えた日本", "山深い田舎町に暮らす女子高生・三葉は", "町長である父の選挙運動に、家系の神社の古き風習", "小さく狭い町で、周囲の目が余計に気になる年頃だけに", "愛鬱な毎日を過ごしていた", "都会への憧れを強くするばかり、"]}, {"box": [1526, 145, 1595, 852], "vertical": true, "font_size": 56, "lines_coords": [[[1526.0, 168.0], [1582.0, 168.0], [1582.0, 829.0], [1526.0, 829.0]]], "lines": ["前巻までのあらすが"]}, {"box": [731, 787, 1444, 817], "vertical": false, "font_size": 30, "lines_coords": [[[731.0, 787.0], [1444.0, 787.0], [1444.0, 817.0], [731.0, 817.0]]], "lines": ["行ったこともない山奥の町で、自分が女子高生になっているのだ。"]}, {"box": [651, 895, 1439, 918], "vertical": false, "font_size": 23, "lines_coords": [[[651.0, 895.0], [1439.0, 895.0], [1439.0, 918.0], [651.0, 918.0]]], "lines": ["繰り返される不思議な夢。そして、明らかに抜け落ちている、記憶と時間"]}, {"box": [832, 726, 1449, 766], "vertical": false, "font_size": 40, "lines_coords": [[[832.0, 726.0], [1449.0, 726.0], [1449.0, 766.0], [832.0, 766.0]]], "lines": ["一方、東京で暮らす男子高校生・誰も、奇妙な夢を見た。"]}, {"box": [872, 998, 1444, 1028], "vertical": false, "font_size": 30, "lines_coords": [[[872.0, 998.0], [1444.0, 998.0], [1444.0, 1028.0], [872.0, 1028.0]]], "lines": ["幾度も入れ替わる身体とその生活に戸惑いながらも、"]}, {"box": [830, 1153, 1446, 1188], "vertical": false, "font_size": 32, "lines_coords": [[[830.0, 1155.0], [1446.0, 1153.0], [1446.0, 1185.0], [830.0, 1188.0]]], "lines": ["時に相手の人生を楽しみながら、状況を乗り切っていく。"]}, {"box": [945, 1101, 1446, 1136], "vertical": false, "font_size": 33, "lines_coords": [[[945.0, 1103.0], [1446.0, 1101.0], [1446.0, 1134.0], [945.0, 1136.0]]], "lines": ["残されたお互いのメモを通して、時にケンカし、"]}, {"box": [1034, 1052, 1444, 1082], "vertical": false, "font_size": 30, "lines_coords": [[[1034.0, 1052.0], [1444.0, 1052.0], [1444.0, 1082.0], [1034.0, 1082.0]]], "lines": ["現実を少しず、つ受け止める瀧と三葉。"]}, {"box": [644, 1209, 1444, 1239], "vertical": false, "font_size": 30, "lines_coords": [[[644.0, 1209.0], [1444.0, 1209.0], [1444.0, 1239.0], [644.0, 1239.0]]], "lines": ["しかし、気持ちが打ち解けできた矢先、突然入れ替わりが途切れてしまう。"]}, {"box": [574, 1258, 1442, 1293], "vertical": false, "font_size": 33, "lines_coords": [[[574.0, 1258.0], [1442.0, 1260.0], [1442.0, 1293.0], [574.0, 1291.0]]], "lines": ["入れ替わりながら、同時に自分たちが特別に繋がっていたことに気付いた瀧は、"]}, {"box": [827, 1523, 1413, 1558], "vertical": false, "font_size": 30, "lines_coords": [[[827.0, 1523.0], [1413.0, 1528.0], [1413.0, 1558.0], [827.0, 1553.0]]], "lines": ["辿り着いた先には、意外な真実が待ち受けていた．．．"]}, {"box": [853, 1420, 1451, 1448], "vertical": false, "font_size": 26, "lines_coords": [[[853.0, 1420.0], [1451.0, 1422.0], [1451.0, 1448.0], [853.0, 1446.0]]], "lines": ["「まだ会ったことのない君を、これから俺は探しに行く。」"]}, {"box": [1102, 1312, 1444, 1345], "vertical": false, "font_size": 30, "lines_coords": [[[1102.0, 1312.0], [1444.0, 1314.0], [1444.0, 1345.0], [1102.0, 1342.0]]], "lines": ["三葉に会いに行こうと決心する。"]}], "img_path": "03_002.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [154, 194, 572, 358], "vertical": false, "font_size": 159, "lines_coords": [[[154.0, 194.0], [572.0, 194.0], [572.0, 353.0], [154.0, 353.0]]], "lines": ["第七話第"]}, {"box": [1202, 1912, 1233, 2325], "vertical": true, "font_size": 31, "lines_coords": [[[1202.0, 1912.0], [1233.0, 1912.0], [1233.0, 2325.0], [1202.0, 2325.0]]], "lines": ["「日頃からのコースタッフの"]}, {"box": [1268, 2064, 1320, 2167], "vertical": false, "font_size": 103, "lines_coords": [[[1268.0, 2064.0], [1320.0, 2064.0], [1320.0, 2167.0], [1268.0, 2167.0]]], "lines": ["あー"]}], "img_path": "03_003.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [609, 318, 642, 581], "vertical": true, "font_size": 40, "lines_coords": [[[609.0, 318.0], [642.0, 318.0], [642.0, 581.0], [609.0, 581.0]]], "lines": ["ッシーは爆薬担当！！"]}, {"box": [433, 264, 588, 675], "vertical": true, "font_size": 40, "lines_coords": [[[555.0, 267.0], [588.0, 267.0], [588.0, 583.0], [555.0, 583.0]], [[499.0, 271.0], [532.0, 271.0], [534.0, 675.0], [501.0, 675.0]], [[433.0, 264.0], [494.0, 264.0], [494.0, 407.0], [433.0, 407.0]]], "lines": ["アこの作戦はテッシーの", "一腕にかかってるんだからな！", "頼んだ！"]}, {"box": [262, 559, 316, 740], "vertical": true, "font_size": 40, "lines_coords": [[[262.0, 560.0], [302.0, 560.0], [302.0, 740.0], [262.0, 740.0]]], "lines": ["よく言うわ"]}, {"box": [354, 881, 602, 1082], "vertical": false, "font_size": 27, "lines_coords": [[[354.0, 951.0], [572.0, 881.0], [581.0, 911.0], [363.0, 982.0]], [[368.0, 977.0], [581.0, 904.0], [590.0, 930.0], [377.0, 1003.0]], [[372.0, 1005.0], [590.0, 930.0], [600.0, 956.0], [379.0, 1031.0]], [[382.0, 1033.0], [429.0, 1012.0], [438.0, 1031.0], [391.0, 1052.0]], [[391.0, 1054.0], [476.0, 1019.0], [485.0, 1047.0], [403.0, 1082.0]]], "lines": ["てっしーは爆薬担当！", "この作戦はてっしーの", "腕にかかっているから", "な！", "頼んだ！"]}, {"box": [1390, 1267, 1472, 1399], "vertical": true, "font_size": 82, "lines_coords": [[[1390.0, 1267.0], [1472.0, 1267.0], [1472.0, 1399.0], [1390.0, 1399.0]]], "lines": ["よし"]}, {"box": [213, 1216, 256, 1389], "vertical": true, "font_size": 40, "lines_coords": [[[213.0, 1216.0], [253.0, 1216.0], [253.0, 1387.0], [213.0, 1387.0]]], "lines": ["ちわーす"]}, {"box": [1369, 1757, 1522, 1962], "vertical": true, "font_size": 38, "lines_coords": [[[1486.0, 1762.0], [1519.0, 1762.0], [1519.0, 1891.0], [1486.0, 1891.0]], [[1425.0, 1757.0], [1465.0, 1757.0], [1465.0, 1961.0], [1425.0, 1961.0]], [[1369.0, 1757.0], [1409.0, 1757.0], [1409.0, 1893.0], [1369.0, 1893.0]]], "lines": ["いっちょ", "やってやろう", "やないか"]}], "img_path": "03_004.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [1307, 236, 1357, 485], "vertical": true, "font_size": 33, "lines_coords": [[[1308.0, 239.0], [1341.0, 239.0], [1341.0, 482.0], [1308.0, 482.0]]], "lines": ["お疲れさまです"]}, {"box": [232, 260, 297, 433], "vertical": true, "font_size": 49, "lines_coords": [[[232.0, 260.0], [281.0, 260.0], [281.0, 433.0], [232.0, 433.0]]], "lines": ["克彦くん"]}, {"box": [1355, 925, 1519, 1164], "vertical": true, "font_size": 49, "lines_coords": [[[1458.0, 925.0], [1519.0, 925.0], [1519.0, 1042.0], [1458.0, 1042.0]], [[1406.0, 928.0], [1451.0, 928.0], [1451.0, 1038.0], [1406.0, 1038.0]], [[1355.0, 930.0], [1395.0, 930.0], [1395.0, 1164.0], [1355.0, 1164.0]]], "lines": ["親父は", "どこに", "行っとります？"]}, {"box": [877, 944, 1085, 1108], "vertical": true, "font_size": 39, "lines_coords": [[[1038.0, 951.0], [1071.0, 951.0], [1071.0, 1103.0], [1038.0, 1103.0]], [[977.0, 944.0], [1029.0, 944.0], [1029.0, 1052.0], [977.0, 1052.0]], [[926.0, 949.0], [966.0, 949.0], [966.0, 1080.0], [926.0, 1080.0]], [[877.0, 951.0], [909.0, 951.0], [909.0, 1108.0], [877.0, 1108.0]]], "lines": ["お父さん？", "今日は", "ここには", "来とらんぞ"]}, {"box": [740, 970, 783, 1109], "vertical": true, "font_size": 43, "lines_coords": [[[740.0, 972.0], [783.0, 972.0], [783.0, 1108.0], [740.0, 1108.0]]], "lines": ["よし！"]}, {"box": [546, 1047, 640, 1188], "vertical": true, "font_size": 39, "lines_coords": [[[595.0, 1047.0], [640.0, 1047.0], [640.0, 1157.0], [595.0, 1157.0]], [[546.0, 1050.0], [579.0, 1050.0], [579.0, 1188.0], [546.0, 1188.0]]], "lines": ["あ～～", "そっか～"]}, {"box": [396, 937, 497, 1132], "vertical": true, "font_size": 50, "lines_coords": [[[436.0, 937.0], [497.0, 937.0], [497.0, 1010.0], [436.0, 1010.0]], [[396.0, 942.0], [436.0, 942.0], [436.0, 1132.0], [396.0, 1132.0]]], "lines": ["何か", "伝えとくかね？"]}, {"box": [1331, 1673, 1470, 1926], "vertical": true, "font_size": 39, "lines_coords": [[[1430.0, 1673.0], [1470.0, 1673.0], [1470.0, 1835.0], [1430.0, 1835.0]], [[1378.0, 1678.0], [1418.0, 1678.0], [1418.0, 1926.0], [1378.0, 1926.0]], [[1331.0, 1682.0], [1357.0, 1682.0], [1357.0, 1832.0], [1331.0, 1832.0]]], "lines": ["克彦くんが", "現場来てくれたら", "助かるでな"]}, {"box": [914, 1258, 1020, 1443], "vertical": true, "font_size": 33, "lines_coords": [[[968.0, 1258.0], [1001.0, 1258.0], [1001.0, 1443.0], [968.0, 1443.0]], [[914.0, 1258.0], [947.0, 1258.0], [947.0, 1385.0], [914.0, 1385.0]]], "lines": ["祭りの準備が", "あるでな"]}, {"box": [213, 1195, 309, 1270], "vertical": true, "font_size": 39, "lines_coords": [[[253.0, 1195.0], [309.0, 1195.0], [309.0, 1270.0], [253.0, 1270.0]], [[213.0, 1197.0], [257.0, 1197.0], [257.0, 1267.0], [213.0, 1267.0]]], "lines": ["いや", "いや"]}, {"box": [171, 1286, 248, 1495], "vertical": true, "font_size": 39, "lines_coords": [[[218.0, 1286.0], [248.0, 1286.0], [248.0, 1495.0], [218.0, 1495.0]], [[171.0, 1312.0], [196.0, 1312.0], [196.0, 1469.0], [171.0, 1469.0]]], "lines": ["ちょっと寄った", "だけですから"]}, {"box": [1214, 1896, 1317, 2041], "vertical": true, "font_size": 39, "lines_coords": [[[1263.0, 1898.0], [1313.0, 1896.0], [1317.0, 2039.0], [1268.0, 2041.0]], [[1214.0, 1900.0], [1254.0, 1900.0], [1254.0, 2039.0], [1214.0, 2039.0]]], "lines": ["いつでも", "来ないよ"]}], "img_path": "03_005.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [255, 1127, 306, 1457], "vertical": true, "font_size": 49, "lines_coords": [[[255.0, 1127.0], [304.0, 1127.0], [304.0, 1457.0], [255.0, 1457.0]]], "lines": ["これでよし．．．！"]}], "img_path": "03_006.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [347, 993, 494, 1162], "vertical": true, "font_size": 40, "lines_coords": [[[461.0, 996.0], [494.0, 996.0], [494.0, 1162.0], [461.0, 1162.0]], [[400.0, 993.0], [443.0, 993.0], [443.0, 1134.0], [400.0, 1134.0]], [[347.0, 993.0], [386.0, 993.0], [386.0, 1134.0], [347.0, 1134.0]]], "lines": ["こちらは．．．", "糸守町：", "役場です"]}, {"box": [647, 1108, 881, 1207], "vertical": false, "font_size": 25, "lines_coords": [[[647.0, 1183.0], [874.0, 1108.0], [881.0, 1132.0], [654.0, 1207.0]]], "lines": ["山火事の危険性があります。"]}, {"box": [684, 1061, 1191, 1251], "vertical": false, "font_size": 27, "lines_coo