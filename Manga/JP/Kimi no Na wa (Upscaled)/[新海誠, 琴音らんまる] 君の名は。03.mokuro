.0], [168.0, 1795.0]]], "lines": ["また、ご覧になるリーディングシステムにより、表示の差が認められることがあります。"]}, {"box": [164, 1839, 595, 1870], "vertical": false, "font_size": 31, "lines_coords": [[[164.0, 1839.0], [595.0, 1839.0], [595.0, 1870.0], [164.0, 1870.0]]], "lines": ["Ｃｏｖｅｒｌｌｕｓｔｒａｔｉｏｎ・琴音らんまる"]}], "img_path": "03_166.webp"}]}