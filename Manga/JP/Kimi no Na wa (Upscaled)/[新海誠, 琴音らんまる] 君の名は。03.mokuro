]}, {"box": [869, 1633, 974, 1905], "vertical": true, "font_size": 40, "lines_coords": [[[921.0, 1633.0], [968.0, 1633.0], [968.0, 1905.0], [921.0, 1905.0]], [[869.0, 1640.0], [902.0, 1640.0], [902.0, 1900.0], [869.0, 1900.0]]], "lines": ["どこかの山で一人", "夜を明かしたこと"]}, {"box": [1081, 1687, 1239, 1965], "vertical": true, "font_size": 35, "lines_coords": [[[1191.0, 1687.0], [1231.0, 1687.0], [1224.0, 1940.0], [1184.0, 1940.0]], [[1137.0, 1687.0], [1170.0, 1687.0], [1170.0, 1964.0], [1137.0, 1964.0]], [[1083.0, 1687.0], [1116.0, 1687.0], [1113.0, 1938.0], [1081.0, 1938.0]]], "lines": ["喧嘩でもしたのか", "司と先輩とは別々に", "東京に戻ったこと"]}, {"box": [232, 1678, 288, 1961], "vertical": true, "font_size": 35, "lines_coords": [[[234.0, 1678.0], [269.0, 1678.0], [267.0, 1959.0], [232.0, 1959.0]]], "lines": ["記憶はその程度だ"]}], "img_path": "03_138.webp"}, {"version": "0.2.1", "img_width": 1686, "img_height": 2400, "blocks": [{"box": [774, 222, 996, 557], "vertical": true, "font_size": 38, "lines_coords": [[[937.0, 222.0], [984.0, 222.0], [980.0, 478.0], [933.0, 478.0]], [[886.0, 227.0], [926.0, 227.0], [926.0, 557.0], [886.0, 557.0]], [[832.0, 229.0], [865.0, 229.0], [865.0, 457.0], [832.0, 457.0]], [[776.0, 227.0], [808.0, 227.0], [808.0, 492.0], [776.0, 492.0]]], "lines": ["ただあの彗星を", "巡って起きた出来事に", "一時期俺は妙に", "心を惹かれていた"]}, {"box": [358, 173, 479, 607], "vertical": true, "font_size": 44, "lines_coords": [[[424.0, 173.0], [466.0, 173.0], [459.0, 431.0], [417.0, 431.0]], [[361.0, 173.0], [408.0, 173.0], [405.0, 607.0], [358.0, 607.0]]], "lines": ["彗星の片割れが", "一つの町を破壊した大災害"]}, {"box": [1306, 428, 1481, 778], "vertical": false, "font_size": 44.5, "lines_coords": [[[1355.0, 428.0], [1481.0, 761.0], [1439.0, 778.0], [1313.0, 445.0]], [[1348.0, 489.0], [1413.0, 710.0], [1371.0, 724.0], [1306.0, 503.0]]], "lines": ["．．．", "．．．"]}, {"box": [1299, 1014, 1406, 1446], "vertical": true, "font_size": 36, "lines_coords": [[[1350.0, 1014.0], [1390.0, 1014.0], [1390.0, 1446.0], [1350.0, 1446.0]], [[1299.0, 1017.0], [133