{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [856, 51, 943, 234], "vertical": true, "font_size": 25.0, "lines": ["．．．大丈夫です。", "すべて段取り", "どおりですから。"]}, {"box": [517, 49, 602, 391], "vertical": true, "font_size": 24.0, "lines": ["数あるサイトの中から", "この「朝日台ハイタウン」周辺の", "住民を探しだし"]}, {"box": [432, 51, 457, 276], "vertical": true, "font_size": 19.0, "lines": ["気持ち程度の料金で"]}, {"box": [252, 47, 369, 332], "vertical": true, "font_size": 22.0, "lines": ["安全に、確実に", "彼らの望むように", "自殺をコーディネイトして", "最後を見届けてやる。"]}, {"box": [150, 48, 174, 316], "vertical": true, "font_size": 20.0, "lines": ["つまり簡単に言えば．．．"]}, {"box": [653, 497, 769, 712], "vertical": true, "font_size": 24.0, "lines": ["決心がついたら", "そこからケータイを", "捨ててください。", "．．．．．ハイ。"]}]}