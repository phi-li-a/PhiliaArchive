{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [891, 189, 947, 313], "vertical": true, "font_size": 25.0, "lines": ["桃子よぉ！", "俺はな、"]}, {"box": [750, 346, 863, 547], "vertical": true, "font_size": 25.0, "lines": ["とんでもない", "金持ちになって", "「ひかりのまち」を", "買い戻して．．．"]}, {"box": [152, 349, 240, 569], "vertical": true, "font_size": 26.0, "lines": ["ここを元の", "朝日村に戻すことが", "夢なんだぜぇ。"]}, {"box": [796, 677, 964, 984], "vertical": true, "font_size": 26.0, "lines": ["．．．バカだろう？", "バカなんだよ、俺。", "でも本気", "なんだから", "しょうがねぇ。"]}, {"box": [139, 797, 257, 993], "vertical": true, "font_size": 24.0, "lines": ["それがどんだけ", "不可能でどんだけ", "無意味なこと", "だとしても。"]}, {"box": [433, 1068, 655, 1390], "vertical": true, "font_size": 25.0, "lines": ["．．．ひひっ、", "ま、サトシに", "こんなこと", "言えないけどよ。", "あいつは", "俺と違って", "冷静な男たからな。"]}, {"box": [145, 1110, 170, 1331], "vertical": true, "font_size": 21.0, "lines": ["ーその日の夜"]}]}