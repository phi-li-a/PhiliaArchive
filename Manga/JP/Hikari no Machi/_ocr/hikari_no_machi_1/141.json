{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [862, 82, 948, 338], "vertical": true, "font_size": 22.0, "lines": ["うえっ、なんだよコレ？", "耳裂けちゃってる", "じゃんか！！"]}, {"box": [533, 88, 621, 295], "vertical": true, "font_size": 25.0, "lines": ["サトシ、元医大生の", "力でちゃちゃっと", "元に戻してくれよ。"]}, {"box": [200, 158, 288, 393], "vertical": true, "font_size": 26.0, "lines": ["無理だよ、そんなの！！", "芳一、病院へ", "行こう？"]}, {"box": [83, 327, 172, 485], "vertical": true, "font_size": 25.0, "lines": ["バーカ、", "行けるワケ", "ねーだろって。"]}, {"box": [290, 655, 351, 751], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．芳一", "お前ね、"]}, {"box": [832, 849, 945, 1100], "vertical": true, "font_size": 24.0, "lines": ["でもあんまり", "危ないことやってると、", "いまに絶対くだらない", "死に方すると思うよ。"]}, {"box": [134, 674, 252, 849], "vertical": true, "font_size": 27.0, "lines": ["外でどんな仕事", "やってるかは、", "あえて俺は", "聞かないよ？"]}, {"box": [274, 938, 299, 1059], "vertical": true, "font_size": 25.0, "lines": ["ガキども？"]}, {"box": [624, 1127, 737, 1324], "vertical": true, "font_size": 24.0, "lines": ["いや、だから俺も", "下請けから、", "人を使う身に", "なろうと思ってな。"]}, {"box": [473, 1163, 589, 1428], "vertical": true, "font_size": 24.0, "lines": ["ビジネスチャンスと", "思って誘ってやったのに、", "あのガキども、", "ワケわかんねぇぜ。"]}, {"box": [73, 1190, 156, 1387], "vertical": true, "font_size": 24.0, "lines": ["．．．．．つーかホント、", "芳一は金儲けしか", "頭にないのな。"]}]}