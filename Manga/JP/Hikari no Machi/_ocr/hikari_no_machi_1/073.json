{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [859, 60, 956, 272], "vertical": true, "font_size": 26.0, "lines": ["お前さぁ、今", "さらっと言ってくれ", "ちゃったけど", "ソレって大問題よ？"]}, {"box": [555, 57, 613, 255], "vertical": true, "font_size": 26.0, "lines": ["犬がくわえて", "持ってったとか？"]}, {"box": [269, 68, 386, 265], "vertical": true, "font_size": 24.0, "lines": ["こんな小ギレイな", "住宅街に、", "野良犬なんて", "いねーよ。"]}, {"box": [670, 413, 756, 636], "vertical": true, "font_size": 26.0, "lines": ["チャカなしで", "どーやって自分の頭", "撃ち抜くのさ？"]}, {"box": [49, 226, 165, 574], "vertical": true, "font_size": 24.0, "lines": ["ケータイも", "あ、あと．．．", "見つからないん", "ですよ、いくら", "捜しても。"]}, {"box": [225, 636, 255, 783], "vertical": true, "font_size": 22.0, "lines": ["携帯電話が？"]}, {"box": [810, 909, 951, 1316], "vertical": true, "font_size": 25.0, "lines": ["ホントにここで", "親戚の方", "降ろしちゃって", "いらしてるから、", "いいの？", "早めにおウチに", "帰りなさいね？"]}, {"box": [142, 712, 162, 855], "vertical": true, "font_size": 22.0, "lines": ["．．．ふーん．．．．．"]}, {"box": [140, 712, 163, 859], "vertical": true, "font_size": 23.0, "lines": ["．．．ふーん．．．．．"]}]}