{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [722, 114, 879, 368], "vertical": true, "font_size": 26.0, "lines": ["さよちゃん、", "知ってる？", "マヨネーズの", "口って星の形", "してるんだよ。"]}, {"box": [192, 287, 218, 436], "vertical": true, "font_size": 25.0, "lines": ["それでー"]}, {"box": [772, 616, 800, 789], "vertical": true, "font_size": 25.0, "lines": ["それだけだぁ！！"]}, {"box": [510, 814, 683, 1034], "vertical": true, "font_size": 23.0, "lines": ["そういえば僕は", "流れ星に３回", "願いごとが", "できたことがなくて、", "昔は相当やきもき", "したものだけど、"]}, {"box": [419, 814, 473, 991], "vertical": true, "font_size": 23.0, "lines": ["どうにか今まで", "やってこれたよ。"]}, {"box": [271, 810, 325, 1029], "vertical": true, "font_size": 20.0, "lines": ["これからもどうにか", "やっていこう"]}, {"box": [807, 1144, 863, 1274], "vertical": true, "font_size": 25.0, "lines": ["野津くんち、", "行こっか？"]}, {"box": [197, 1242, 230, 1309], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}]}