{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [739, 187, 790, 316], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．タスク", "屋上に来て。"]}, {"box": [816, 566, 934, 837], "vertical": true, "font_size": 25.0, "lines": ["．．．じゃあ、俺は直接", "長谷川宅に向かうから、", "お前はマンション周辺を", "当たってくれ。"]}, {"box": [666, 327, 692, 434], "vertical": true, "font_size": 26.0, "lines": ["仕事だよ。"]}, {"box": [662, 325, 690, 431], "vertical": true, "font_size": 22.0, "lines": ["仕事だよ。"]}, {"box": [121, 616, 239, 814], "vertical": true, "font_size": 24.0, "lines": ["．．．いいんスカ？", "水谷警部。", "こんな勝手な", "行動しちゃって？"]}, {"box": [856, 905, 943, 1087], "vertical": true, "font_size": 25.0, "lines": ["バカが。犯罪は", "早期発見、", "早期解決だろが。"]}, {"box": [476, 906, 591, 1084], "vertical": true, "font_size": 25.0, "lines": ["ラリった声の", "匿名電話なんて、", "信用できんのか", "なぁ．．．．．．？"]}, {"box": [668, 1251, 753, 1369], "vertical": true, "font_size": 27.0, "lines": ["それじゃあ", "病気じゃ", "ないスか。"]}, {"box": [95, 1221, 153, 1367], "vertical": true, "font_size": 24.0, "lines": ["うるせぇ！！", "ホラ行けよ！！"]}]}