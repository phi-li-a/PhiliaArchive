{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [862, 77, 982, 313], "vertical": true, "font_size": 23.0, "lines": ["赴任先の部署の", "白ブタみたいなＯＬ、", "ちょっと相手にしたら", "愛人気取りだよ。"]}, {"box": [618, 99, 703, 223], "vertical": true, "font_size": 25.0, "lines": ["そんなん", "納得できる", "かって．．．"]}, {"box": [115, 55, 290, 460], "vertical": true, "font_size": 25.0, "lines": ["．．．．．こーんな", "簡単に、ちょっと", "油断しただけで．．", "どん底まで", "落ちちゃうのって", "どーなんですか？"]}, {"box": [731, 423, 848, 670], "vertical": true, "font_size": 24.0, "lines": ["別れようとしたら", "セクハラで訴訟だぁ？", "長年会社に仕えた", "俺があっさりクビ！？"]}, {"box": [476, 437, 597, 682], "vertical": true, "font_size": 23.0, "lines": ["だから僕は自意識と", "性欲まみれの白ブタに", "弾をブチ込んで", "やりましたっ！！"]}, {"box": [742, 749, 963, 1101], "vertical": true, "font_size": 27.0, "lines": ["．．．えっへっへ．．．", "女房と娘の首を", "僕ぁ、この手で", "絞めてやったさ。", "女房は抵抗", "するから、", "撃っちまった．．．"]}, {"box": [198, 849, 324, 1167], "vertical": true, "font_size": 27.0, "lines": ["だって", "そうするしか", "ないじゃん．．．", "最低だ．．．．．．"]}]}