{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [585, 88, 641, 296], "vertical": true, "font_size": 26.0, "lines": ["えーー．．．", "なんか変だよソレ。"]}, {"box": [492, 206, 548, 340], "vertical": true, "font_size": 26.0, "lines": ["タスク、無理", "してない？"]}, {"box": [71, 156, 158, 337], "vertical": true, "font_size": 25.0, "lines": ["バッカ、人の", "好意は素直に", "受け入れろって。"]}, {"box": [750, 190, 910, 692], "vertical": true, "font_size": 26.0, "lines": ["．．．．．そして", "もう少し落ち着いたら", "すべてをハル子に", "話そう。", "見届け屋のこと、"]}, {"box": [688, 513, 775, 759], "vertical": true, "font_size": 21.0, "lines": ["それにハル子の父親に"]}, {"box": [687, 516, 714, 761], "vertical": true, "font_size": 26.0, "lines": ["してしまったこと．．．"]}, {"box": [571, 472, 659, 642], "vertical": true, "font_size": 27.0, "lines": ["．．．．．じゃ、", "どっか行きたい", "とこは？"]}, {"box": [346, 402, 375, 550], "vertical": true, "font_size": 26.0, "lines": ["うーん．．．．．．"]}, {"box": [105, 648, 132, 798], "vertical": true, "font_size": 20.0, "lines": ["．．．そうだ！！"]}, {"box": [740, 772, 877, 1151], "vertical": true, "font_size": 24.0, "lines": ["おっきな公園探そう！！", "ホラ、タスク", "ピクニック行こうって", "言ってたじゃん？"]}, {"box": [223, 860, 342, 1135], "vertical": true, "font_size": 32.0, "lines": ["もしこの先、", "僕らが", "本当にどうしようもなく", "なったら．．．"]}, {"box": [618, 1205, 648, 1402], "vertical": true, "font_size": 26.0, "lines": ["その時は：：：．．．"]}]}