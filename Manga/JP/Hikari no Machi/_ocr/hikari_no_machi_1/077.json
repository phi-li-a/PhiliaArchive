{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [458, 64, 483, 297], "vertical": true, "font_size": 25.0, "lines": ["だって、そうだろう？"]}, {"box": [262, 63, 409, 306], "vertical": true, "font_size": 24.0, "lines": ["失いたくない", "ものより、", "忘れたいことのほうが", "多いような", "僕たちなんだから．．．"]}, {"box": [183, 63, 211, 212], "vertical": true, "font_size": 24.0, "lines": ["もっと自由に"]}, {"box": [128, 64, 214, 319], "vertical": true, "font_size": 25.0, "lines": ["自分が好きなように"]}, {"box": [126, 64, 151, 313], "vertical": true, "font_size": 24.0, "lines": ["生きればいいじゃんか"]}, {"box": [494, 315, 649, 549], "vertical": true, "font_size": 27.0, "lines": ["ハル子、", "疲れてるなら", "寝てていいよ。", "適当なトコで", "起こすから。"]}, {"box": [98, 561, 142, 808], "vertical": true, "font_size": 25.0, "lines": ["うん．．．．．", "ありがと。"]}, {"box": [612, 888, 732, 1109], "vertical": true, "font_size": 29.0, "lines": ["だったら、", "僕のすべてを", "ハル子のためだけに", "使う。"]}, {"box": [461, 888, 516, 1081], "vertical": true, "font_size": 24.0, "lines": ["それでいいんじゃ", "ないだろうか？"]}, {"box": [425, 1290, 511, 1336], "vertical": false, "font_size": 23.0, "lines": ["最谷製薬"]}, {"box": [259, 1126, 316, 1281], "vertical": true, "font_size": 25.0, "lines": ["ハル子、ここで", "終点だってさ。"]}, {"box": [161, 1233, 219, 1411], "vertical": true, "font_size": 25.0, "lines": ["はは、全然", "知らない街だぁ。"]}]}