{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [815, 81, 927, 300], "vertical": true, "font_size": 23.0, "lines": ["．．．あ、あのコレって", "自殺ですか？", "もしかして事件絡み", "とかそういう．．．"]}, {"box": [519, 83, 605, 292], "vertical": true, "font_size": 26.0, "lines": ["や、そーゆーんじゃ", "ないんです", "けど．．．"]}, {"box": [97, 173, 153, 331], "vertical": true, "font_size": 24.0, "lines": ["ならホラ、", "といたどいた。"]}, {"box": [851, 588, 936, 735], "vertical": true, "font_size": 27.0, "lines": ["しばらくお肉", "食べられ", "ないわぁ。"]}, {"box": [612, 428, 698, 586], "vertical": true, "font_size": 25.0, "lines": ["ん？何、", "キミ、記者とか", "そーゆー人？"]}, {"box": [465, 400, 491, 510], "vertical": true, "font_size": 24.0, "lines": ["．．．ふうん"]}, {"box": [317, 400, 433, 546], "vertical": true, "font_size": 27.0, "lines": ["まぁ", "漫画みたいな", "劇的なことが", "起きても、"]}, {"box": [539, 659, 565, 785], "vertical": true, "font_size": 26.0, "lines": ["スゲェー"]}, {"box": [194, 399, 284, 545], "vertical": true, "font_size": 27.0, "lines": ["日々は", "淡々としてる", "もんだっ"]}, {"box": [737, 654, 822, 854], "vertical": true, "font_size": 22.0, "lines": ["アラ、じゃあ奥さん", "痩せられるんじゃ", "ありません？"]}, {"box": [768, 906, 854, 1120], "vertical": true, "font_size": 23.0, "lines": ["この女子高生が", "何を思っていたかは", "知りようがないし。"]}, {"box": [473, 767, 505, 833], "vertical": true, "font_size": 32.0, "lines": ["はは。"]}, {"box": [572, 903, 718, 1157], "vertical": true, "font_size": 22.0, "lines": ["時と場合によっては", "この楽しげな野次馬に", "囲まれて死んでいるのが", "僕だったとしても", "おかしくないわけで。"]}, {"box": [472, 905, 526, 1150], "vertical": true, "font_size": 24.0, "lines": ["いつ誰に何が起きても", "不思議じゃないしね。"]}, {"box": [366, 906, 419, 1155], "vertical": true, "font_size": 22.0, "lines": ["そんなこと、みんな", "わかっているのだけど。"]}, {"box": [154, 698, 241, 820], "vertical": true, "font_size": 26.0, "lines": ["ハーイ、", "クルマ通り", "まーす！！"]}, {"box": [294, 909, 314, 1202], "vertical": true, "font_size": 23.0, "lines": ["当たり前のことなんだけど、"]}, {"box": [190, 906, 245, 1062], "vertical": true, "font_size": 24.0, "lines": ["なんだろ、この"]}, {"box": [186, 903, 214, 1057], "vertical": true, "font_size": 23.0, "lines": ["「ふーん」感覚。"]}, {"box": [150, 1278, 176, 1386], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．あれ"]}]}