{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [883, 98, 938, 295], "vertical": true, "font_size": 23.0, "lines": ["コレ、今日だけ", "借りてっていい？"]}, {"box": [533, 142, 619, 504], "vertical": true, "font_size": 23.0, "lines": ["なんかあったら", "いつでも俺に", "．．．ハル子。", "連絡しろよ。"]}, {"box": [88, 357, 175, 585], "vertical": true, "font_size": 24.0, "lines": ["向かいの棟なんだし、", "すぐ助けに行って", "やるから。"]}, {"box": [780, 895, 925, 1185], "vertical": true, "font_size": 24.0, "lines": ["．．．．．大丈夫。", "．．．そう！", "今日、久々に", "お父さん", "帰ってくるし！！"]}, {"box": [130, 767, 216, 939], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．三ツ目、", "今日も見つから", "なかったなぁ。"]}, {"box": [485, 1259, 509, 1366], "vertical": true, "font_size": 24.0, "lines": ["．．．うん"]}]}