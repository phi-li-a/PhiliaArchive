{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [867, 99, 951, 330], "vertical": true, "font_size": 23.0, "lines": ["大切な人と", "青空の下、芝生の上に", "寝っころがってさ。"]}, {"box": [120, 36, 256, 67], "vertical": false, "font_size": 31.0, "lines": ["しかりのまち"]}, {"box": [636, 209, 755, 679], "vertical": true, "font_size": 22.0, "lines": ["「空が青いねぇ」とか", "見たまんまのこと", "なんでもないこと", "言っちゃったりして、", "だけど、すっごく", "幸せじゃねぇ？"]}, {"box": [353, 502, 407, 637], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．", "幸せだねぇ。"]}, {"box": [803, 808, 826, 941], "vertical": true, "font_size": 21.0, "lines": ["．．．タスクは"]}, {"box": [259, 862, 315, 1058], "vertical": true, "font_size": 24.0, "lines": ["ホントにあたしを", "好きなのかな？"]}, {"box": [159, 1287, 186, 1404], "vertical": true, "font_size": 25.0, "lines": ["．．．．．え？"]}]}