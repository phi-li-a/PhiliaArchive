{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [737, 66, 762, 164], "vertical": true, "font_size": 24.0, "lines": ["何よ．．．"]}, {"box": [637, 110, 690, 318], "vertical": true, "font_size": 24.0, "lines": ["なんなのよ、アンタ", "その目は．．．．．．"]}, {"box": [105, 77, 224, 546], "vertical": true, "font_size": 30.0, "lines": ["そんな態度", "アンタみたいな", "とっていいと", "ロクでもない", "思ってんの！？", "娘が．．．．．．"]}, {"box": [809, 658, 866, 837], "vertical": true, "font_size": 24.0, "lines": ["目標を達成する、", "諦めるなりで、"]}, {"box": [357, 659, 388, 834], "vertical": true, "font_size": 27.0, "lines": ["無理なのか？"]}, {"box": [710, 655, 762, 884], "vertical": true, "font_size": 22.0, "lines": ["夢も何もかも", "なくなってしまう時"]}, {"box": [678, 957, 733, 1067], "vertical": true, "font_size": 25.0, "lines": ["おかえりー", "タスクー"]}, {"box": [488, 655, 637, 878], "vertical": true, "font_size": 27.0, "lines": ["その時僕らは", "理不尽な世の中に", "さらされて、", "正気を保つことが", "できるんだろうか？"]}, {"box": [587, 1022, 643, 1205], "vertical": true, "font_size": 25.0, "lines": ["見てごらんよ、", "このプチトマト。"]}, {"box": [161, 657, 245, 920], "vertical": true, "font_size": 23.0, "lines": ["大人たちがみんな", "どこかしらが", "くるっているように．．．"]}, {"box": [175, 957, 230, 1140], "vertical": true, "font_size": 25.0, "lines": ["こんなに", "大きくなったよ。"]}]}