{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [847, 108, 963, 302], "vertical": true, "font_size": 25.0, "lines": ["くぁー", "ーっ！！", "またやっちゃんの", "株式講座が", "始まったよ！"]}, {"box": [667, 129, 722, 314], "vertical": true, "font_size": 32.0, "lines": ["おっ、新入り、おつかれーーい。"]}, {"box": [659, 126, 722, 313], "vertical": true, "font_size": 26.0, "lines": ["おっ、新入り、", "おつかれーーい。"]}, {"box": [554, 184, 609, 341], "vertical": true, "font_size": 26.0, "lines": ["．．．そうだ、", "聞いたぜ。"]}, {"box": [152, 88, 239, 286], "vertical": true, "font_size": 26.0, "lines": ["兄ちゃん、医大の", "学生さんだったん", "だってな。"]}, {"box": [239, 422, 268, 582], "vertical": true, "font_size": 27.0, "lines": ["はは．．．．．．ええ。"]}, {"box": [121, 516, 208, 715], "vertical": true, "font_size": 27.0, "lines": ["でもひと月で", "やめちゃいました", "けどね"]}, {"box": [860, 724, 945, 875], "vertical": true, "font_size": 26.0, "lines": ["なーんでよ？", "もったいねぇ", "なぁ～～"]}, {"box": [510, 840, 632, 1345], "vertical": true, "font_size": 26.0, "lines": ["．．．．．僕の", "最近医療ミスって", "父親も医者", "よくあるじゃないですか。", "だったんですけど。", "父がそれに", "巻き込まれちゃって。"]}, {"box": [148, 1111, 235, 1340], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．なんか、", "バカバカしくなって。", "そーゆうの"]}]}