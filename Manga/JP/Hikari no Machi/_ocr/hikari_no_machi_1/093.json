{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [841, 82, 926, 303], "vertical": true, "font_size": 23.0, "lines": ["ちょっ、ちょつ！！", "ちょーっと冷静に", "なってみようか？"]}, {"box": [722, 161, 775, 387], "vertical": true, "font_size": 23.0, "lines": ["おじょーちゃん、ソレ", "逆恨みっスよ？"]}, {"box": [536, 61, 592, 88], "vertical": false, "font_size": 27.0, "lines": ["第２話"]}, {"box": [414, 101, 696, 126], "vertical": false, "font_size": 25.0, "lines": ["バスストップ・ＰＡＲＴＩ"]}, {"box": [190, 68, 334, 337], "vertical": true, "font_size": 25.0, "lines": ["もとはといえば、", "援交の真似事して", "ホテルから俺の金を", "持ち逃げした", "アンタが悪いわけっしょ？"]}, {"box": [133, 312, 161, 365], "vertical": true, "font_size": 25.0, "lines": ["ね？"]}, {"box": [0, 84, 64, 496], "vertical": true, "font_size": 32.0, "lines": ["のまた、"]}, {"box": [844, 419, 934, 701], "vertical": true, "font_size": 28.0, "lines": ["「大人なめんな」って", "ことで、ちょっと痛い目に", "あってもらったけど．．．"]}, {"box": [109, 506, 226, 825], "vertical": true, "font_size": 26.0, "lines": ["その程度で", "ね？", "すませた、俺の", "慈悲深い気持ちを", "汲もう？"]}, {"box": [563, 1089, 618, 1235], "vertical": true, "font_size": 23.0, "lines": ["．．．．．それでも", "撃ちますか？"]}, {"box": [488, 1267, 516, 1331], "vertical": true, "font_size": 28.0, "lines": ["ポッ"]}, {"box": [104, 1147, 137, 1403], "vertical": true, "font_size": 29.0, "lines": ["撃っちゃうんスか！？"]}]}