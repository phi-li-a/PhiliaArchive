{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [835, 102, 951, 324], "vertical": true, "font_size": 26.0, "lines": ["一度エッチしたら", "次の日から毎日毎日", "まーいにち、", "やりたがってさ。"]}, {"box": [731, 196, 788, 387], "vertical": true, "font_size": 26.0, "lines": ["なんかむかついて", "フッてやった。"]}, {"box": [259, 107, 288, 284], "vertical": true, "font_size": 25.0, "lines": ["むずかしいのね。"]}, {"box": [174, 240, 202, 374], "vertical": true, "font_size": 23.0, "lines": ["そーなのよ。"]}, {"box": [769, 902, 826, 1025], "vertical": true, "font_size": 25.0, "lines": ["西山さん", "泣いてる？"]}, {"box": [324, 967, 351, 1122], "vertical": true, "font_size": 24.0, "lines": ["泣いてないよ。"]}, {"box": [615, 1233, 733, 1421], "vertical": true, "font_size": 26.0, "lines": ["もし仮に今、", "ＵＦＯが現れたら", "どうしよう、と", "ふと思う。"]}, {"box": [453, 1233, 539, 1421], "vertical": true, "font_size": 25.0, "lines": ["どこか遠くへ", "連れてってほしい", "気もするけど、"]}, {"box": [312, 1231, 365, 1445], "vertical": true, "font_size": 20.0, "lines": ["連れてかれたくない", "気もする"]}]}