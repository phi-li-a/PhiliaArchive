{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [799, 95, 913, 396], "vertical": true, "font_size": 32.0, "lines": ["「こんな大人たちを作った社会が悪い」なんて、言ってもはじまらないことはわかってる。"]}, {"box": [767, 93, 913, 608], "vertical": true, "font_size": 24.0, "lines": ["「こんな大人たちを作った", "社会が悪い」なんて、", "言ってもはじまらないことは", "わかってる。", "僕にできるのは"]}, {"box": [738, 443, 762, 632], "vertical": true, "font_size": 22.0, "lines": ["そんな大人たちを"]}, {"box": [708, 442, 732, 585], "vertical": true, "font_size": 24.0, "lines": ["清算すること"]}, {"box": [681, 445, 701, 591], "vertical": true, "font_size": 22.0, "lines": ["くらいなんだ。"]}, {"box": [827, 1168, 850, 1271], "vertical": true, "font_size": 20.0, "lines": ["それでも、"]}, {"box": [671, 1165, 786, 1332], "vertical": true, "font_size": 24.0, "lines": ["それでも僕は", "必死にもがけば", "きっと出口が", "見つかる．．．．．"]}, {"box": [542, 1167, 566, 1318], "vertical": true, "font_size": 20.0, "lines": ["そう信じてる。"]}, {"box": [350, 1166, 435, 1427], "vertical": true, "font_size": 25.0, "lines": ["．．．．．僕は静かに", "いつかこの街を出てゆく", "ことを心に誓った。"]}, {"box": [186, 1185, 210, 1282], "vertical": true, "font_size": 24.0, "lines": ["ごほっ！！"]}, {"box": [184, 1185, 208, 1281], "vertical": true, "font_size": 25.0, "lines": ["ごほっ！！"]}, {"box": [105, 1304, 131, 1401], "vertical": true, "font_size": 25.0, "lines": ["ごほっ！！"]}]}