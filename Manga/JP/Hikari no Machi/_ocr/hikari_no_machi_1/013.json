{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [634, 126, 700, 331], "vertical": true, "font_size": 30.0, "lines": ["なにより今朝は", "空気が澄みきって、"]}, {"box": [233, 214, 354, 466], "vertical": true, "font_size": 31.0, "lines": ["白いシーツや", "七色のＴシャツが", "楽しげにはためく", "気持ちいい朝だった♪"]}, {"box": [768, 1019, 890, 1191], "vertical": true, "font_size": 28.0, "lines": ["そして", "ある幼稚園児は", "ひらめいた♪", "（間奏）"]}, {"box": [652, 1022, 706, 1192], "vertical": true, "font_size": 23.0, "lines": ["知ってるかい？", "ここだけの話"]}, {"box": [155, 737, 181, 845], "vertical": true, "font_size": 25.0, "lines": ["へたくそ。"]}, {"box": [555, 1116, 609, 1292], "vertical": true, "font_size": 23.0, "lines": ["世界はいつか", "終わるんだって。"]}, {"box": [243, 1302, 394, 1456], "vertical": false, "font_size": 32.0, "lines": ["さとうたいき"]}, {"box": [70, 1035, 188, 1448], "vertical": true, "font_size": 24.0, "lines": ["なんだって始まった", "当然さ。", "瞬間から終わりに向かって", "突き進むしか", "ないんだから。"]}]}