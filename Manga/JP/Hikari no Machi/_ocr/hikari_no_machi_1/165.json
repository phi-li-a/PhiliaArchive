{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [851, 76, 936, 307], "vertical": true, "font_size": 23.0, "lines": ["おっせーよ、サトシ！！", "腹減ったから", "マッハで飯作れ！！"]}, {"box": [551, 88, 641, 242], "vertical": true, "font_size": 25.0, "lines": ["しっかし桃子、", "全然言葉", "覚えねぇのな。"]}, {"box": [683, 538, 708, 685], "vertical": true, "font_size": 21.0, "lines": ["．．．あ、悪い。"]}, {"box": [324, 277, 412, 489], "vertical": true, "font_size": 25.0, "lines": ["いつまでたっても", "アーとかウー", "ばかりじゃねぇか。"]}, {"box": [69, 352, 155, 577], "vertical": true, "font_size": 23.0, "lines": ["はは．．．．．やっぱ", "そこらへん、母親じゃ", "ないと．．．みたいな？"]}, {"box": [831, 833, 956, 1270], "vertical": true, "font_size": 25.0, "lines": ["バカ！！つまんない", "桃子のしつけと", "こと言ってんじゃ", "教育は暇人の", "ないよ！！", "お前がどーにか", "するんだよっ！！"]}, {"box": [495, 1004, 554, 1222], "vertical": true, "font_size": 28.0, "lines": ["俺、最近ちゃんと", "働いてんじゃん．．．"]}, {"box": [223, 796, 365, 1019], "vertical": true, "font_size": 32.0, "lines": ["この頃、芳一は早朝どこかへ出かけ帰ってくるなり一日中パソコンにかじりついている。"]}, {"box": [218, 799, 365, 1017], "vertical": true, "font_size": 25.0, "lines": ["この頃、芳一は", "早朝どこかへ出かけ", "帰ってくるなり", "一日中パソコンに", "かじりついている。"]}, {"box": [392, 1205, 478, 1382], "vertical": true, "font_size": 26.0, "lines": ["うるせえっ！！", "ホレ、飯だ風呂だ", "酒だっ！！"]}, {"box": [152, 1101, 236, 1340], "vertical": true, "font_size": 25.0, "lines": ["．．．芳一はあの計画を", "本気で実行する"]}, {"box": [151, 1101, 175, 1336], "vertical": true, "font_size": 25.0, "lines": ["つもりなのだろう．．．"]}]}