{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [823, 108, 941, 310], "vertical": true, "font_size": 29.0, "lines": ["あたし前から", "西山さんって、", "素敵って思ってた", "のね。"]}, {"box": [312, 77, 367, 227], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．あぁ、", "皮肉っスか！！"]}, {"box": [88, 301, 113, 426], "vertical": true, "font_size": 25.0, "lines": ["違うよー"]}, {"box": [563, 512, 650, 692], "vertical": true, "font_size": 23.0, "lines": ["．．．まぁ、確かに", "足長くて細くて", "黒髪サラサラで"]}, {"box": [104, 535, 216, 754], "vertical": true, "font_size": 22.0, "lines": ["あたしが男だったら", "好きになるかも。", "せめてもうちょい", "まともなら。"]}, {"box": [715, 762, 931, 1058], "vertical": true, "font_size": 26.0, "lines": ["そういえば", "東さんの家って、", "チョー金持ちって", "誰か言ってたけど、", "お父さん", "何やってる人", "なの？"]}, {"box": [291, 758, 477, 1118], "vertical": true, "font_size": 25.0, "lines": ["んーと、街のはずれに", "大きな薬品工場が", "あるのね。", "そこの一番", "エライ人なんだって、", "パパ言ってた。"]}, {"box": [89, 1039, 176, 1368], "vertical": true, "font_size": 26.0, "lines": ["それって", "えっ！？", "ヒカリグループの", "薬品工場のこと？"]}]}