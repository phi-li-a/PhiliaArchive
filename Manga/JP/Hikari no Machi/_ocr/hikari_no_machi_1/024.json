{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [829, 81, 972, 326], "vertical": true, "font_size": 24.0, "lines": ["おいっ、相変わらず", "暗い漫画描いてんの？", "いつになれば主人公", "手からビーム出せる", "ようになんの？"]}, {"box": [48, 87, 159, 323], "vertical": true, "font_size": 31.0, "lines": ["うるっさい！！", "腐れフリーター", "どもがっ！！"]}, {"box": [667, 471, 697, 588], "vertical": true, "font_size": 30.0, "lines": ["そいっ！！"]}, {"box": [184, 579, 352, 875], "vertical": true, "font_size": 32.0, "lines": ["帰れ！！", "帰れ！！", "俺に飲み歩く", "ようなヒマは", "ねーんだよっ！！"]}, {"box": [845, 883, 948, 1089], "vertical": true, "font_size": 31.0, "lines": ["今夜は天竺まで", "行っちゃう", "ぜぇー", "ーっ！！"]}, {"box": [203, 944, 256, 1168], "vertical": true, "font_size": 24.0, "lines": ["自分が一番働いて", "稼いでるハズなのに。"]}, {"box": [114, 946, 168, 1143], "vertical": true, "font_size": 24.0, "lines": ["．．．なんだよ、この", "おいてけぼり感は。"]}, {"box": [558, 1015, 698, 1413], "vertical": true, "font_size": 24.0, "lines": ["野津さぁ〜〜ん、", "アンタ昔は吐くまで", "つき合ってくれる", "ま、いいけど", "男だったよ。", "仕事がんばって", "ね。"]}, {"box": [371, 1234, 389, 1333], "vertical": true, "font_size": 18.0, "lines": ["う．．．．．．"]}, {"box": [296, 946, 347, 1275], "vertical": true, "font_size": 24.0, "lines": ["大学の同期はなぜか", "そろいもそろってフリーターに"]}, {"box": [74, 1199, 138, 1426], "vertical": true, "font_size": 26.0, "lines": ["．．．待って！", "俺も行く"]}]}