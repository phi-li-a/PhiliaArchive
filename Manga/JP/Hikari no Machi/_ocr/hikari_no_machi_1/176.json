{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [403, 92, 434, 223], "vertical": true, "font_size": 26.0, "lines": ["ーっ。", "たー"]}, {"box": [688, 296, 714, 542], "vertical": true, "font_size": 24.0, "lines": ["．．．家族ごっこか．．．"]}, {"box": [672, 628, 786, 773], "vertical": true, "font_size": 25.0, "lines": ["お互いの", "理想と主張が", "ぶつかって", "破綻した。"]}, {"box": [446, 629, 472, 711], "vertical": true, "font_size": 26.0, "lines": ["これが、"]}, {"box": [251, 627, 386, 798], "vertical": true, "font_size": 25.0, "lines": ["血が繋がって", "いないがゆえの", "もろさなのかも", "しれない。"]}, {"box": [115, 449, 146, 573], "vertical": true, "font_size": 31.0, "lines": ["桃子．．．．．．"]}, {"box": [336, 916, 417, 1211], "vertical": true, "font_size": 24.0, "lines": ["もちろん人と人は", "価値観の共有はできないし、"]}, {"box": [332, 916, 359, 1168], "vertical": true, "font_size": 24.0, "lines": ["だから否定もできない。"]}, {"box": [861, 1086, 890, 1235], "vertical": true, "font_size": 26.0, "lines": ["行こう．．．"]}, {"box": [135, 1109, 250, 1355], "vertical": true, "font_size": 24.0, "lines": ["芳一は芳一の中にある", "信じる何かに基づいて", "生きているのであって、", "僕はあくまでも外側に"]}, {"box": [108, 1112, 250, 1353], "vertical": true, "font_size": 20.0, "lines": ["いるのだから。"]}]}