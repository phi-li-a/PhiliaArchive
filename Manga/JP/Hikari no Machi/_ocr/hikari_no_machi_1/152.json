{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [236, 240, 267, 478], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．違うだろ？"]}, {"box": [811, 621, 835, 798], "vertical": true, "font_size": 23.0, "lines": ["父親の荒れ方や、"]}, {"box": [721, 618, 775, 837], "vertical": true, "font_size": 23.0, "lines": ["罪をなすりつけ合う", "大人たちを見て、"]}, {"box": [394, 619, 448, 813], "vertical": true, "font_size": 22.0, "lines": ["自分が傷つくのが", "怖いんだろう？"]}, {"box": [171, 620, 287, 807], "vertical": true, "font_size": 21.0, "lines": ["昔から僕は", "嫌なことから", "逃げるくせがある", "だろう？"]}, {"box": [815, 927, 888, 1174], "vertical": true, "font_size": 32.0, "lines": ["いまだに僕は", "逃げてばかりいる。"]}, {"box": [628, 619, 679, 853], "vertical": true, "font_size": 23.0, "lines": ["世の中に出ていくのが", "怖くなったんだろう？"]}, {"box": [532, 881, 618, 1102], "vertical": true, "font_size": 25.0, "lines": ["す．．．すいません、", "なんか湿っぽく", "なっちゃいました？"]}, {"box": [100, 881, 183, 1100], "vertical": true, "font_size": 23.0, "lines": ["気にしないで", "ください！", "昔のことですから！！"]}, {"box": [685, 1222, 709, 1309], "vertical": true, "font_size": 22.0, "lines": ["．．あ"]}, {"box": [480, 1139, 568, 1376], "vertical": true, "font_size": 24.0, "lines": ["．．．．．それより、", "やっさんの株の話、", "聞かせてくださいよ！！"]}, {"box": [223, 1166, 249, 1262], "vertical": true, "font_size": 24.0, "lines": ["．．．おっ！？"]}, {"box": [90, 1209, 171, 1372], "vertical": true, "font_size": 24.0, "lines": ["じゃあ俺、", "久々に熱く", "語っちゃうよ！？"]}]}