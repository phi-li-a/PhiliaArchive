{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [757, 52, 930, 330], "vertical": true, "font_size": 24.0, "lines": ["「タスクが何を", "していたかは、だいたい", "わかっているつもりだし、", "お前はそれを受け止めて", "生きなければ", "ならないと思う」"]}, {"box": [228, 95, 375, 339], "vertical": true, "font_size": 22.0, "lines": ["「しかし、誰が死のうが、", "私自身が死のうが、", "これ以上", "何かを失うのに、私は", "耐えられそうにない」"]}, {"box": [133, 450, 252, 679], "vertical": true, "font_size": 26.0, "lines": ["「間違いだらけの", "人生かもしれないが、", "今、私の気持ちは", "晴れやかだ」"]}, {"box": [830, 796, 889, 980], "vertical": true, "font_size": 25.0, "lines": ["「すまんタスク。", "父より」"]}, {"box": [475, 1199, 591, 1390], "vertical": true, "font_size": 26.0, "lines": ["見届け屋の事件は", "被疑者死亡で", "事実は", "闇の中だ．．．．．．"]}, {"box": [81, 1020, 110, 1193], "vertical": true, "font_size": 26.0, "lines": ["アホー．．．"]}, {"box": [176, 1201, 231, 1365], "vertical": true, "font_size": 26.0, "lines": ["これで", "よかったのか？"]}]}