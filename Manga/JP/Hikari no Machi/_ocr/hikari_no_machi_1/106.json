{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [837, 70, 942, 304], "vertical": true, "font_size": 27.0, "lines": ["ハル子ぉ．．．", "何やってん", "だよ．．．"]}, {"box": [213, 68, 244, 177], "vertical": true, "font_size": 27.0, "lines": ["へへ．．．．．．"]}, {"box": [98, 167, 183, 340], "vertical": true, "font_size": 27.0, "lines": ["飛び降りようと", "したら、腰が", "抜けちゃった。"]}, {"box": [855, 512, 942, 731], "vertical": true, "font_size": 24.0, "lines": ["．．．あたし、親戚に", "引き取られることに", "なるみたい。"]}, {"box": [207, 549, 239, 617], "vertical": true, "font_size": 26.0, "lines": ["はは。"]}, {"box": [97, 622, 183, 801], "vertical": true, "font_size": 26.0, "lines": ["いよいよ", "本格的に夢も", "チボーもないね。"]}, {"box": [723, 830, 938, 1202], "vertical": true, "font_size": 24.0, "lines": ["なんかイロイロ", "考えちゃってさ。", "あたしがしっかり", "してれば、お父さんも", "お母さんも、あんなことに", "ならなかったんじゃ", "ないか．．．．．．とか"]}, {"box": [204, 911, 357, 1282], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．でもあたしは", "もう無理だよ。", "だからタスク、", "ここからあたしの", "背中を押して？"]}, {"box": [453, 1063, 506, 1288], "vertical": true, "font_size": 22.0, "lines": ["今さら考えても", "しょうがないけどさ。"]}]}