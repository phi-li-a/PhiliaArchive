{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [689, 87, 752, 215], "vertical": true, "font_size": 31.0, "lines": ["ん", "バハハハ。"]}, {"box": [539, 124, 594, 403], "vertical": true, "font_size": 22.0, "lines": ["そして僕にも", "いつものように朝が来た。"]}, {"box": [432, 123, 487, 342], "vertical": true, "font_size": 26.0, "lines": ["生焼けのトーストを", "かじる。"]}, {"box": [221, 121, 387, 380], "vertical": true, "font_size": 24.0, "lines": ["定職にもつかず", "父は今日も一日中、", "根が腐って枯れつつある", "プチトマトに水を", "やり続けるんだろう。"]}, {"box": [118, 120, 203, 340], "vertical": true, "font_size": 23.0, "lines": ["薄くほこりがかった", "母の遺影には", "目もくれず"]}, {"box": [167, 550, 192, 703], "vertical": true, "font_size": 24.0, "lines": ["．．．アホー"]}, {"box": [791, 974, 967, 1344], "vertical": true, "font_size": 24.0, "lines": ["アタシ、いまだに", "金髪だし、ギャル", "メイクだし、", "クラスのみんなに", "けっこー白い目で", "見られてんだ", "けどさ"]}, {"box": [164, 1058, 313, 1370], "vertical": true, "font_size": 24.0, "lines": ["これでも", "けっこー真面目", "なんだよ？", "半年で偏差値", "１１０も上げたし。"]}]}