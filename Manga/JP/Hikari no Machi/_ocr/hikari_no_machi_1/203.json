{"version": "0.1.6", "img_width": 1022, "img_height": 1476, "blocks": [{"box": [866, 89, 948, 295], "vertical": true, "font_size": 23.0, "lines": ["この手紙", "今は遠くにいる", "コからもらってさ。"]}, {"box": [739, 190, 823, 432], "vertical": true, "font_size": 23.0, "lines": ["今日は流れ星が", "たくさん見られるって", "書いてあってさ。"]}, {"box": [578, 117, 602, 240], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．彼女？"]}, {"box": [366, 112, 425, 223], "vertical": true, "font_size": 29.0, "lines": ["はは、", "違う違う。"]}, {"box": [99, 386, 154, 544], "vertical": true, "font_size": 24.0, "lines": ["．．．でも、すごく", "大切な人だよ。"]}, {"box": [736, 969, 881, 1336], "vertical": true, "font_size": 23.0, "lines": ["男の魂がまた", "一つになって", "消えちゃうとこで", "終わるんだ。", "．．．さっきの", "話は．．．"]}, {"box": [140, 1154, 282, 1392], "vertical": true, "font_size": 24.0, "lines": ["わかるんだよ。", "この頃、向こうと", "こっちの意識が", "霧がかかったみたいに", "あやふやだから。"]}]}