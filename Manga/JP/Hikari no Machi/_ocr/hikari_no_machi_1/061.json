{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [843, 139, 929, 293], "vertical": true, "font_size": 26.0, "lines": ["．．．きっと", "アイツは", "戻ってくるよ。"]}, {"box": [124, 236, 203, 374], "vertical": true, "font_size": 32.0, "lines": ["じゃ、", "また明日。"]}, {"box": [762, 545, 878, 814], "vertical": true, "font_size": 25.0, "lines": ["ハル子は中学の時、", "自宅近くでストーカーに", "メッタ刺しにされた", "ことがある"]}, {"box": [630, 545, 715, 790], "vertical": true, "font_size": 25.0, "lines": ["犯人は見つからず、", "手がかりは額にあった", "大きなアザだけ。"]}, {"box": [539, 545, 567, 705], "vertical": true, "font_size": 25.0, "lines": ["だから三ツ目"]}, {"box": [302, 544, 479, 776], "vertical": true, "font_size": 26.0, "lines": ["そいつが必ず、この", "「ひかりのまち」に", "戻ってくると信じて、", "ハル子は今日も", "このバス停で", "待ち続ける"]}, {"box": [131, 547, 250, 781], "vertical": true, "font_size": 25.0, "lines": ["今にして思えば、", "ハル子にはもっと", "いろいろな生きる道が", "あったに違いない。"]}, {"box": [784, 944, 816, 1019], "vertical": true, "font_size": 32.0, "lines": ["おう。"]}, {"box": [689, 1129, 775, 1366], "vertical": true, "font_size": 24.0, "lines": ["僕らが本当の意味での", "夢を失ってしまうのは", "いつごろなのだろう。"]}, {"box": [469, 1129, 615, 1367], "vertical": true, "font_size": 25.0, "lines": ["いつしか夢を", "リアルな目標に", "置き換えて、", "僕も生きていかなきゃ", "ならないんだろうか？"]}, {"box": [215, 1145, 328, 1367], "vertical": true, "font_size": 24.0, "lines": ["せっかく父さんが", "帰ってくるからって、", "早めに仕事切り上げ", "たと思ったら．．．"]}, {"box": [95, 1213, 149, 1425], "vertical": true, "font_size": 24.0, "lines": ["．．．こんな時間まで", "どこ行ってたのよ！？"]}]}