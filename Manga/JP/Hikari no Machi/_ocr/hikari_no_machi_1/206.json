{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [683, 37, 710, 220], "vertical": true, "font_size": 24.0, "lines": ["気がつくと私は、"]}, {"box": [837, 309, 864, 375], "vertical": true, "font_size": 25.0, "lines": ["さあ。"]}, {"box": [560, 31, 699, 279], "vertical": true, "font_size": 22.0, "lines": ["なんだかフワフワした", "場所にいた。"]}, {"box": [380, 35, 465, 214], "vertical": true, "font_size": 25.0, "lines": ["バスはもう", "どこかへ行って", "しまったようだ。"]}, {"box": [264, 35, 319, 154], "vertical": true, "font_size": 24.0, "lines": ["他の乗客の", "姿もない。"]}, {"box": [725, 385, 808, 569], "vertical": true, "font_size": 25.0, "lines": ["他の人たちは", "もう先に", "行っちゃったよ。"]}, {"box": [737, 982, 870, 1211], "vertical": true, "font_size": 26.0, "lines": ["私は少し考えて", "こう言ってみた。", "「ずっとここにいては", "ダメですか？」"]}, {"box": [634, 952, 661, 1017], "vertical": true, "font_size": 26.0, "lines": ["ダメー"]}, {"box": [140, 614, 265, 857], "vertical": true, "font_size": 25.0, "lines": ["キミだっていつまでも", "バスと共に", "彷徨っているワケに", "いかないんだよ"]}, {"box": [516, 1047, 602, 1192], "vertical": true, "font_size": 26.0, "lines": ["ここには", "何もあっちゃ", "いけないの"]}, {"box": [115, 1001, 229, 1407], "vertical": true, "font_size": 24.0, "lines": ["ホラ、キミとネコが", "意味すらも！！", "いるがために、", "影が生まれて", "しまっている。"]}]}