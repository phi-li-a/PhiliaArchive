{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [214, 138, 359, 549], "vertical": true, "font_size": 25.0, "lines": ["なんかね、今の俺は", "キミがいれば大概", "それでいいと思った。", "だいたい", "幸せだと思った。"]}, {"box": [873, 608, 901, 745], "vertical": true, "font_size": 25.0, "lines": ["クサーーイ。"]}, {"box": [821, 861, 935, 1078], "vertical": true, "font_size": 22.0, "lines": ["キレイごとっぽくて", "胡散臭くても俺、", "漫画家だから", "言っちゃうよ。"]}, {"box": [421, 883, 445, 1020], "vertical": true, "font_size": 20.0, "lines": ["．．．うん"]}, {"box": [146, 681, 173, 806], "vertical": true, "font_size": 24.0, "lines": ["だろーん？"]}, {"box": [319, 1115, 346, 1169], "vertical": true, "font_size": 27.0, "lines": ["オキ"]}, {"box": [83, 982, 200, 1381], "vertical": true, "font_size": 23.0, "lines": ["だから野津くんも", "どこへも行っちゃ", "あたしは", "駄目なんだよ？", "ずっとキミの", "そばにいるよ。"]}]}