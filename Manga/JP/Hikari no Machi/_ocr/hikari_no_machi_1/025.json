{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [887, 134, 971, 331], "vertical": true, "font_size": 22.0, "lines": ["ああ、親に実家に", "戻れって言われた", "らしくてさ。"]}, {"box": [529, 127, 709, 518], "vertical": true, "font_size": 25.0, "lines": ["そんでプラブラ", "やってないで、", "公務員の資格取れ", "ことかなんとかで、じゃなきゃ", "絶縁くらいの勢い", "なんだと。"]}, {"box": [79, 104, 197, 412], "vertical": true, "font_size": 30.0, "lines": ["高級マンションに", "お住まいの", "ーんっ！！", "みなさぁー"]}, {"box": [282, 572, 312, 774], "vertical": true, "font_size": 32.0, "lines": ["あんたら空調の"]}, {"box": [214, 570, 313, 797], "vertical": true, "font_size": 31.0, "lines": ["効いた部屋で"]}, {"box": [773, 539, 927, 966], "vertical": true, "font_size": 30.0, "lines": ["夢ってなんですか！？", "幸せってなんだろ！？", "僕はまだ", "知りません！！"]}, {"box": [96, 569, 241, 1001], "vertical": true, "font_size": 32.0, "lines": ["快適セックスか！？", "なんじゃい", "この不平等！！"]}, {"box": [906, 1067, 966, 1502], "vertical": true, "font_size": 32.0, "lines": ["ぴぃやぁあああも"]}, {"box": [510, 1154, 595, 1332], "vertical": true, "font_size": 25.0, "lines": ["．．．アレ、", "ウチの冷蔵庫の", "マヨネーズだし"]}, {"box": [124, 1346, 180, 1465], "vertical": true, "font_size": 26.0, "lines": ["．．．おいっ？", "おーい！！"]}]}