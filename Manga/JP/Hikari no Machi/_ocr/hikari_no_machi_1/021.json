{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [490, 120, 813, 185], "vertical": false, "font_size": 24.0, "lines": ["第１話", "キラキラ星はどこへゆく"]}, {"box": [98, 89, 239, 611], "vertical": true, "font_size": 26.0, "lines": ["ムリだろー", "つーか来年には", "俺の漫画、売れセンじゃ", "無職かも、だろ？", "はいし、やる気ないし。", "むしろ死んでるかも", "しれん。"]}, {"box": [860, 158, 950, 611], "vertical": true, "font_size": 26.0, "lines": ["野津くん、もっと", "でも素敵な", "がんばって漫画描いて", "部屋だったぁ。", "買ってよー"]}, {"box": [441, 357, 468, 484], "vertical": true, "font_size": 25.0, "lines": ["んぁ．．．．．．"]}, {"box": [772, 780, 957, 1106], "vertical": true, "font_size": 25.0, "lines": ["まーたそういう", "後ろ向きなこと言う。", "やっぱ今日は", "水族館にクリオネ", "見に行っとけば", "よかったー"]}, {"box": [90, 891, 237, 1111], "vertical": true, "font_size": 26.0, "lines": ["いやいや、", "こんな近所の取材を", "デートがわりに", "したのは悪かった", "けどさぁ。"]}, {"box": [806, 1186, 951, 1405], "vertical": true, "font_size": 24.0, "lines": ["でもわかってよ、", "さよちゃん。", "プレッシャーと戦う", "駆け出し漫画家の", "気持ちも。"]}, {"box": [683, 1276, 763, 1435], "vertical": true, "font_size": 24.0, "lines": ["疲れてんのさ、", "最近の俺．．．．．．", "きのうもさ．．．"]}]}