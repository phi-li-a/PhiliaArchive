{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [826, 120, 885, 268], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．なんで", "名前を．．．．．．"]}, {"box": [231, 110, 318, 344], "vertical": true, "font_size": 25.0, "lines": ["いろいろと", "調べさしてもらった", "ぜぇ、タスクっち～～"]}, {"box": [83, 173, 200, 420], "vertical": true, "font_size": 25.0, "lines": ["前から気に", "なってたのよ。ネットで", "おもしろいことしてる", "奴がいるってよぉ。"]}, {"box": [781, 466, 898, 723], "vertical": true, "font_size": 25.0, "lines": ["「ひかりのまち」の外で", "仕事したしたってんで、", "俺のハートにビーンと", "きたのさ。"]}, {"box": [120, 476, 372, 855], "vertical": true, "font_size": 25.0, "lines": ["今日、", "俺がタスクっちに", "わざわざコンタクト", "かましたのは", "ほかでもねえ。", "自殺幇助なんて", "チンケな商売やめて", "俺と組もうぜ", "って話よ！？"]}, {"box": [645, 1176, 671, 1343], "vertical": true, "font_size": 20.0, "lines": ["おハロー、同志。"]}, {"box": [93, 1249, 152, 1419], "vertical": true, "font_size": 28.0, "lines": ["会いたかった", "ぜ〜〜〜～～～！！"]}]}