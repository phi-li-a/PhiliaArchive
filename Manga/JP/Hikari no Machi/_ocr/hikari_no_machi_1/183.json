{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [765, 109, 896, 467], "vertical": true, "font_size": 26.0, "lines": ["．．．そうさ俺は、", "「ひかりのまち」を", "買い取って、元の村を", "取り戻すんだ。"]}, {"box": [235, 272, 290, 492], "vertical": true, "font_size": 23.0, "lines": ["そこで俺たち三人で", "暮らしてな．．．"]}, {"box": [878, 946, 936, 1164], "vertical": true, "font_size": 24.0, "lines": ["．．．．．いいねぇ．．．", "幸せじゃねぇか．．．"]}, {"box": [110, 668, 256, 929], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．そんで桃子に", "「私はどっちのババから", "生まれたの？」なんて", "聞かれて、俺たちは", "苦笑いするんだ．．．"]}, {"box": [350, 1078, 401, 1245], "vertical": true, "font_size": 21.0, "lines": ["．．．帰ろう．．．．", "家に帰ろう．．．"]}, {"box": [218, 1199, 300, 1365], "vertical": true, "font_size": 21.0, "lines": ["．．．きっと今日も", "サトシと桃子が", "俺を待ってる！！"]}]}