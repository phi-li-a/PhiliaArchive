{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [719, 180, 837, 446], "vertical": true, "font_size": 24.0, "lines": ["今日も団地の妻たちは", "曖昧な言葉と無駄話とで", "見えすいた腹の", "さくり合い♪"]}, {"box": [427, 397, 486, 617], "vertical": true, "font_size": 27.0, "lines": ["締め切りに追われる", "漫画家は、"]}, {"box": [263, 399, 349, 618], "vertical": true, "font_size": 24.0, "lines": ["泥酔しづこ捨て場で", "原稿を描き終える", "夢を見る♪"]}, {"box": [436, 705, 552, 926], "vertical": true, "font_size": 26.0, "lines": ["たとえば", "あるベンチでは", "ホームレスが", "死んだように眠り♪"]}, {"box": [281, 707, 342, 1001], "vertical": true, "font_size": 29.0, "lines": ["ある食卓からは笑い声", "ある食卓からは重い沈黙♪！"]}, {"box": [101, 957, 218, 1224], "vertical": true, "font_size": 24.0, "lines": ["ある恋人たちは愛を", "確め合い", "ある恋人たちはお互いを", "傷つけ合う♪"]}, {"box": [781, 1063, 869, 1284], "vertical": true, "font_size": 29.0, "lines": ["ある部屋では", "老人が", "眠るように死んだ♪"]}, {"box": [369, 1199, 425, 1372], "vertical": true, "font_size": 25.0, "lines": ["おじいちゃーん、", "朝ですよー"]}]}