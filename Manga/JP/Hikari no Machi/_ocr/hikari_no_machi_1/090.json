{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [795, 124, 941, 398], "vertical": true, "font_size": 27.0, "lines": ["ハル子、", "俺、ちょっと", "用あるから、", "テキトーに", "ブラついてて。"]}, {"box": [644, 65, 709, 252], "vertical": true, "font_size": 30.0, "lines": ["えっ、", "あたしも行くよ。"]}, {"box": [369, 302, 456, 485], "vertical": true, "font_size": 24.0, "lines": ["いや、そっこーで", "すますから", "待ってろって。"]}, {"box": [254, 621, 500, 712], "vertical": false, "font_size": 27.0, "lines": ["屋上は改装中につき", "壁上は以来中にノロ関係者以外の立ち入り禁止"]}, {"box": [78, 343, 165, 508], "vertical": true, "font_size": 24.0, "lines": ["．．．タスク、", "一人にしないで", "よ．．．．．．"]}, {"box": [893, 728, 947, 953], "vertical": true, "font_size": 24.0, "lines": ["．．．．．ハイ、", "昨日のメールどおり、"]}, {"box": [804, 861, 857, 1007], "vertical": true, "font_size": 24.0, "lines": ["そこから", "飛び降りれば"]}, {"box": [775, 862, 859, 1018], "vertical": true, "font_size": 25.0, "lines": ["ほぼ確実です。"]}, {"box": [116, 860, 226, 1042], "vertical": true, "font_size": 21.0, "lines": ["それで、あの．．．", "再三確認して", "失礼なんですが"]}, {"box": [907, 1119, 932, 1215], "vertical": true, "font_size": 24.0, "lines": ["金だろ？"]}, {"box": [283, 1088, 339, 1277], "vertical": true, "font_size": 25.0, "lines": ["オッケーオッゲー", "ガッツリな！？"]}, {"box": [135, 1175, 254, 1391], "vertical": true, "font_size": 25.0, "lines": ["だから隠れてないで", "出てきな。", "長谷川タスク", "ちゃん！！"]}]}