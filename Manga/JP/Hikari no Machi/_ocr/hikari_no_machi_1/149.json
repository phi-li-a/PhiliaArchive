{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [857, 156, 916, 361], "vertical": true, "font_size": 25.0, "lines": ["両親はすでに", "他界しているとか"]}, {"box": [454, 107, 580, 338], "vertical": true, "font_size": 30.0, "lines": ["ひょっとしたら", "もうすでに", "何人か殺して", "いるのかもしれな"]}, {"box": [133, 41, 250, 67], "vertical": false, "font_size": 26.0, "lines": ["わかりのまち"]}, {"box": [146, 110, 262, 277], "vertical": true, "font_size": 28.0, "lines": ["ただそれは", "僕がどうこう", "言える問題じゃ", "ない。"]}, {"box": [725, 281, 813, 510], "vertical": true, "font_size": 29.0, "lines": ["怪しい", "犯罪グループに", "所属しているとか、"]}, {"box": [627, 563, 692, 781], "vertical": true, "font_size": 28.0, "lines": ["演然と聞いただけで", "詳細はわからない。"]}, {"box": [781, 878, 866, 1070], "vertical": true, "font_size": 24.0, "lines": ["そもそも", "芳一の金に対する", "執着の理由は？"]}, {"box": [609, 877, 699, 1095], "vertical": true, "font_size": 26.0, "lines": ["こんな退屈な街に", "住み続けているのは", "なぜ？"]}, {"box": [400, 878, 428, 1104], "vertical": true, "font_size": 24.0, "lines": ["．．．わからないけれど"]}, {"box": [159, 878, 277, 1094], "vertical": true, "font_size": 23.0, "lines": ["ただ言えるのは", "彼は彼の自由の中で", "生きている", "ってことだ"]}, {"box": [281, 1170, 366, 1369], "vertical": true, "font_size": 24.0, "lines": ["いや、だからね、", "株ってのはもう", "精神の話なんだよ。"]}, {"box": [143, 1243, 227, 1456], "vertical": true, "font_size": 24.0, "lines": ["目先の欲に", "目がくらんだ奴から", "負けていくの！"]}]}