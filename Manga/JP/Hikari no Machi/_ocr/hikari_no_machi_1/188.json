{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [825, 158, 939, 352], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．さんは病院に", "運ばれましたが", "すでに死亡して", "いました。"]}, {"box": [360, 90, 449, 244], "vertical": true, "font_size": 24.0, "lines": ["ーっ．．．", "もー", "また寝てるの", "タイキくん？"]}, {"box": [310, 236, 326, 293], "vertical": true, "font_size": 16.0, "lines": ["このうた"]}, {"box": [0, 76, 57, 481], "vertical": true, "font_size": 32.0, "lines": ["のまし"]}, {"box": [138, 290, 223, 509], "vertical": true, "font_size": 22.0, "lines": ["警察では", "傷害致死事件として", "捜査をしています。"]}, {"box": [249, 506, 271, 680], "vertical": true, "font_size": 20.0, "lines": ["．．．そうさ．．．"]}, {"box": [851, 838, 940, 1056], "vertical": true, "font_size": 26.0, "lines": ["．．．そうさ、人は", "いつか必ず、そして", "平等に死ぬのさ．．．"]}, {"box": [515, 877, 688, 1258], "vertical": true, "font_size": 27.0, "lines": ["なのに、お前らは", "積みあげては", "崩して．．．", "．．．．．．なん", "なんだよっ！！"]}, {"box": [75, 1138, 193, 1374], "vertical": true, "font_size": 32.0, "lines": ["せんせぇ～～", "タイキくんがぁ", "〜〜〜～～っ！！"]}]}