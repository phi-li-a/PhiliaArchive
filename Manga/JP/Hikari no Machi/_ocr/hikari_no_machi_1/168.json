{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [845, 78, 931, 492], "vertical": true, "font_size": 24.0, "lines": ["あはは、そうか", "キレイだろう？", "桃子は花火", "はじめて見るんだ。"]}, {"box": [488, 98, 573, 293], "vertical": true, "font_size": 25.0, "lines": ["．．．どうした芳一？", "やけにおとなしい", "じゃんか。"]}, {"box": [127, 22, 246, 55], "vertical": false, "font_size": 30.0, "lines": ["わかりのまち"]}, {"box": [73, 178, 165, 436], "vertical": true, "font_size": 24.0, "lines": ["前ははしゃいで、", "他人んちにロケット花火", "打ち込んでたのに。"]}, {"box": [119, 578, 257, 933], "vertical": true, "font_size": 23.0, "lines": ["．．．ちなみに", "明日の早朝、", "仕事手伝って", "もらいまーす。"]}, {"box": [113, 1199, 174, 1373], "vertical": true, "font_size": 28.0, "lines": ["よろしく頼むよ、", "サトシ。"]}]}