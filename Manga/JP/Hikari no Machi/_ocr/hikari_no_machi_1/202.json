{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [835, 88, 951, 241], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．さぁ、", "あいにく俺は", "そういうの", "興味ないなぁ。"]}, {"box": [539, 65, 653, 268], "vertical": true, "font_size": 23.0, "lines": ["昔．．．．．．つーか、", "けっこー最近の昔、", "ある男が", "死んだんだ"]}, {"box": [101, 151, 186, 334], "vertical": true, "font_size": 23.0, "lines": ["でも、その男には", "フツーに仲いい", "恋人がいたのな。"]}, {"box": [853, 617, 937, 810], "vertical": true, "font_size": 24.0, "lines": ["残してきた彼女が", "気がかりな男は", "こう頼んだんだ。"]}, {"box": [151, 419, 206, 542], "vertical": true, "font_size": 25.0, "lines": ["ははは、", "なんの話？"]}, {"box": [727, 778, 811, 972], "vertical": true, "font_size": 24.0, "lines": ["「彼女の側に", "生まれ変わらせて", "くれ」って。"]}, {"box": [293, 678, 350, 850], "vertical": true, "font_size": 26.0, "lines": ["頼んだって．．．", "誰に？"]}, {"box": [243, 846, 276, 919], "vertical": true, "font_size": 32.0, "lines": ["ネコ。"]}, {"box": [141, 966, 171, 1043], "vertical": true, "font_size": 30.0, "lines": ["猫ぉ？"]}, {"box": [795, 1126, 886, 1319], "vertical": true, "font_size": 29.0, "lines": ["そしたらホントに", "そーなったん", "だよ。"]}, {"box": [279, 1178, 360, 1345], "vertical": true, "font_size": 24.0, "lines": ["男の魂は", "半分だけ生まれ", "変わったんだ。"]}, {"box": [153, 1246, 207, 1397], "vertical": true, "font_size": 24.0, "lines": ["前世の記憶を", "残したままで。"]}]}