{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [807, 369, 867, 683], "vertical": true, "font_size": 27.0, "lines": ["流れ星だっ。", "あっ。"]}, {"box": [135, 479, 273, 794], "vertical": true, "font_size": 26.0, "lines": ["あー、今日は", "流星群の見える", "目らしいよ。", "願いごとでも", "しとく？"]}, {"box": [866, 834, 923, 1007], "vertical": true, "font_size": 25.0, "lines": ["．．．で、", "話なんだっけ？"]}, {"box": [545, 869, 572, 1002], "vertical": true, "font_size": 24.0, "lines": ["仕方ないさ。"]}, {"box": [604, 1032, 724, 1385], "vertical": true, "font_size": 26.0, "lines": ["今日、結局", "泣いちゃいそうで、", "うん、", "みんなにお別れの", "挨拶できなくてさ。"]}, {"box": [77, 1009, 224, 1381], "vertical": true, "font_size": 26.0, "lines": ["．．．特に", "タイキくんって子、", "変わってたけど", "なんかほっとけない", "あの子．．．", "子でさ．．．"]}]}