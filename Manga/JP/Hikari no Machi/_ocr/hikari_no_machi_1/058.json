{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [764, 118, 821, 341], "vertical": true, "font_size": 24.0, "lines": ["なんつーかさぁ、", "こう天気がいいと．．．"]}, {"box": [818, 613, 842, 762], "vertical": true, "font_size": 20.0, "lines": ["ん？"]}, {"box": [171, 283, 317, 481], "vertical": true, "font_size": 25.0, "lines": ["弁当持って、", "どこかぶらっと", "ピクニックにでも", "行くかぁって、", "感じにならねぇ？"]}, {"box": [803, 817, 939, 1077], "vertical": true, "font_size": 28.0, "lines": ["あはは！！", "タスク、けっこう", "子供っぽいこと", "言うー"]}, {"box": [286, 876, 346, 1025], "vertical": true, "font_size": 27.0, "lines": ["まぁまぁ、", "そのうち、ね。"]}, {"box": [849, 1209, 875, 1340], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．悪いか。"]}, {"box": [98, 1228, 156, 1378], "vertical": true, "font_size": 26.0, "lines": ["そのうちって、", "いつだよ。"]}]}