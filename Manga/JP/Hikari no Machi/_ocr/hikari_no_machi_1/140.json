{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [864, 100, 952, 279], "vertical": true, "font_size": 26.0, "lines": ["雨あがらないし", "夕飯の材料", "買っちゃおう。"]}, {"box": [323, 108, 408, 367], "vertical": true, "font_size": 24.0, "lines": ["ところで数えてみると、", "僕がこの街にやってきて", "今年で５回目の夏。"]}, {"box": [138, 111, 195, 284], "vertical": true, "font_size": 25.0, "lines": ["月日が経つのは", "実に早いものだ。"]}, {"box": [423, 425, 505, 622], "vertical": true, "font_size": 23.0, "lines": ["そろそろあいつも", "帰ってくる頃", "だろうし"]}, {"box": [277, 939, 311, 1144], "vertical": true, "font_size": 30.0, "lines": ["ただいま"]}]}