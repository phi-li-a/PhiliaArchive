{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [740, 83, 884, 335], "vertical": true, "font_size": 25.0, "lines": ["そりゃ違う環境で", "育ったんだから、", "知らないこともあるさ。", "．．．さっと時間が"]}, {"box": [620, 81, 885, 635], "vertical": true, "font_size": 24.0, "lines": ["その濤を埋めてくれる。"]}, {"box": [513, 70, 568, 264], "vertical": true, "font_size": 22.0, "lines": ["現実的に", "考えてみろ．．．．．．"]}, {"box": [157, 161, 189, 450], "vertical": true, "font_size": 29.0, "lines": ["．．．結局、金か．．．"]}, {"box": [617, 379, 731, 646], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．といっても", "僕たちにあと", "どれだけの時間が", "あるっていうんだろう？"]}, {"box": [286, 450, 402, 620], "vertical": true, "font_size": 24.0, "lines": ["見届け屋で", "稼いだ金なんて", "すぐに底をつく", "ぞ．．．．．．"]}, {"box": [661, 763, 687, 854], "vertical": true, "font_size": 23.0, "lines": ["タスクー"]}, {"box": [569, 854, 624, 1022], "vertical": true, "font_size": 23.0, "lines": ["まだ帰ってきて", "ないのかー", "！？"]}, {"box": [113, 1058, 139, 1182], "vertical": true, "font_size": 24.0, "lines": ["ん"]}]}