{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [737, 133, 825, 283], "vertical": true, "font_size": 26.0, "lines": ["なんか今日、", "寂しそうな顔", "してるぞ。"]}, {"box": [627, 152, 687, 327], "vertical": true, "font_size": 26.0, "lines": ["恋人と喧嘩でも", "したのかよ．．．？"]}, {"box": [85, 23, 260, 68], "vertical": false, "font_size": 32.0, "lines": ["かりのませ"]}, {"box": [83, 199, 202, 374], "vertical": true, "font_size": 25.0, "lines": ["まさかぁ！", "彼氏とは全然", "うまくいってる", "もーーん．．．"]}, {"box": [543, 431, 627, 680], "vertical": true, "font_size": 22.0, "lines": ["．．．ところで", "みなさん、今夜の予定は", "お決まりですか？"]}, {"box": [152, 545, 267, 691], "vertical": true, "font_size": 24.0, "lines": ["実は今日は、", "流星群が", "やってくる目", "なんです"]}, {"box": [681, 689, 890, 1024], "vertical": true, "font_size": 24.0, "lines": ["．．．って、もう！！", "どこで覚えてくるの", "そんなセリフ！？", "ホラ！！", "お帰りバス、", "来てるんだから", "早く乗って！！"]}, {"box": [300, 790, 316, 883], "vertical": true, "font_size": 16.0, "lines": ["りがつのうた"]}, {"box": [843, 1107, 934, 1252], "vertical": true, "font_size": 29.0, "lines": ["幸いにも", "今夜の予報は", "晴れ。"]}, {"box": [332, 1221, 679, 1286], "vertical": false, "font_size": 20.0, "lines": ["エビロ－", "ＲＥＢＩＲＩＮＨＤＡＹＳＯＮＧ"]}, {"box": [85, 1188, 199, 1436], "vertical": true, "font_size": 23.0, "lines": ["みなさんもたまには", "ゆったりとした気持ちで", "夜空を眺めてみては", "いかがですか？"]}]}