{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [854, 82, 941, 311], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．べっつに、", "そんなんじゃないよ、", "言ってみただけ。"]}, {"box": [510, 110, 597, 300], "vertical": true, "font_size": 25.0, "lines": ["あたしは一人でも", "生きてける自信", "あるもん。"]}, {"box": [105, 274, 191, 446], "vertical": true, "font_size": 24.0, "lines": ["あたし、早く", "自立したいヒト", "だからさ。"]}, {"box": [648, 413, 765, 635], "vertical": true, "font_size": 24.0, "lines": ["実は親が", "どうなったところで", "関係ないって", "思ってるし。"]}, {"box": [757, 849, 932, 1287], "vertical": true, "font_size": 27.0, "lines": ["つーか、", "あたしんちの", "すっごい近く", "ー、何アンタ", "なんだけど！", "一人でこんなところ", "来てんの！？"]}, {"box": [117, 1211, 204, 1360], "vertical": true, "font_size": 22.0, "lines": ["あー、微妙に", "あたしの部屋", "見える。"]}]}