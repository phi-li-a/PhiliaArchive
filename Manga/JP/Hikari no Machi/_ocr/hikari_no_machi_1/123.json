{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [808, 98, 953, 409], "vertical": true, "font_size": 32.0, "lines": ["ナニ？", "何｀何、何！？", "バカ！？", "バカなの！？"]}, {"box": [124, 192, 210, 413], "vertical": true, "font_size": 22.0, "lines": ["うちのクラスに", "こんなふうに思考の", "不自由な人が！？"]}, {"box": [183, 561, 238, 740], "vertical": true, "font_size": 22.0, "lines": ["ＵＦＯさんが", "教えてくれたの。"]}, {"box": [788, 909, 848, 1146], "vertical": true, "font_size": 28.0, "lines": ["（なんか）", "ピッシー"]}, {"box": [564, 831, 681, 1051], "vertical": true, "font_size": 25.0, "lines": ["何それ、アンタ！？", "もしかしてそれ。", "自分がカワイイって", "思って言ってんの？"]}, {"box": [105, 894, 222, 1154], "vertical": true, "font_size": 24.0, "lines": ["不思議ちゃん発言で", "天然キャラ", "狙っちゃったりしてる！？", "いや、うざいから！！！"]}, {"box": [165, 1239, 218, 1368], "vertical": true, "font_size": 23.0, "lines": ["違うよー", "ホントだよ"]}]}