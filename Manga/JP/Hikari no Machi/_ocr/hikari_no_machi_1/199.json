{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [815, 139, 936, 306], "vertical": true, "font_size": 27.0, "lines": ["すいません、", "１１０７号の", "佐藤と申します", "が．．．．．"]}, {"box": [510, 63, 627, 302], "vertical": true, "font_size": 28.0, "lines": ["急な仕事が", "入ってしまって．．．", "今晩息子を預かって", "いただきたくて。"]}, {"box": [365, 195, 486, 335], "vertical": true, "font_size": 32.0, "lines": ["昇代秋助"]}, {"box": [290, 215, 379, 242], "vertical": false, "font_size": 27.0, "lines": ["長谷川"]}, {"box": [82, 136, 199, 359], "vertical": true, "font_size": 26.0, "lines": ["いつもは", "お隣の斎藤さんに", "お願いしてるんです", "けど、留守みたいで。"]}, {"box": [502, 379, 620, 626], "vertical": true, "font_size": 25.0, "lines": ["．．．あー、僕らも", "友人の結婚式で", "これから出かけるとこ", "なんですよ。"]}, {"box": [137, 533, 249, 833], "vertical": true, "font_size": 31.0, "lines": ["僕が面倒", "みとくから。", "大丈夫", "だよ。"]}, {"box": [777, 1073, 894, 1309], "vertical": true, "font_size": 25.0, "lines": ["本日未明、住宅地の", "路上で血まみれの男が", "倒れていると通報が", "あり．．．．．．"]}, {"box": [171, 1070, 260, 1276], "vertical": true, "font_size": 27.0, "lines": ["なんだ、", "このニュース、", "すげぇ近所じゃん。"]}, {"box": [89, 1243, 146, 1374], "vertical": true, "font_size": 27.0, "lines": ["あ、ジュース", "とか飲む？"]}]}