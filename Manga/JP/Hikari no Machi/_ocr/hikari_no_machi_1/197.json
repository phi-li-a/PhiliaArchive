{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [322, 111, 438, 322], "vertical": true, "font_size": 24.0, "lines": ["．．．残念ね", "カオリ先生、", "やさしくていい先生", "だったのに。"]}, {"box": [70, 252, 255, 733], "vertical": true, "font_size": 26.0, "lines": ["ホラ、４〜５年前に", "恋人亡くされた時", "相当落ち込んだ", "夏休みを", "らしいし。", "二人でゆっくり", "過ごしたかったんじゃ", "ありません？"]}, {"box": [731, 805, 848, 1035], "vertical": true, "font_size": 23.0, "lines": ["せめて、この子たちが", "卒園するまで", "辞めないで", "ほしかったけど．．．"]}, {"box": [153, 1160, 271, 1361], "vertical": true, "font_size": 26.0, "lines": ["でも、よかったじゃ", "ないですか", "幸せな結婚が", "できて。"]}]}