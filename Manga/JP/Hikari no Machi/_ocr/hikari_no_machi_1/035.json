{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [810, 136, 868, 293], "vertical": true, "font_size": 27.0, "lines": ["．．．もしもし、", "さよ？"]}, {"box": [170, 127, 319, 551], "vertical": true, "font_size": 24.0, "lines": ["え？コンビニで", "買い物してきて？", "今どこにいんの？", "さっきのファミレスの", "トイレ？"]}, {"box": [888, 640, 919, 811], "vertical": true, "font_size": 31.0, "lines": ["神も仏も！！"]}, {"box": [753, 642, 915, 838], "vertical": true, "font_size": 32.0, "lines": ["神も仏も", "ってか！！"]}, {"box": [760, 703, 831, 837], "vertical": true, "font_size": 32.0, "lines": ["神も仏もってか！！"]}, {"box": [131, 654, 287, 973], "vertical": true, "font_size": 25.0, "lines": ["コラコラ", "マヨネーズで", "絵ぇ描くな。", "てか早く", "降りてこいよ、", "スズケン"]}, {"box": [847, 1009, 953, 1270], "vertical": true, "font_size": 30.0, "lines": ["野津はいいよ、", "バリバリ好きな", "仕事しちゃってさ！！"]}, {"box": [388, 1122, 525, 1331], "vertical": true, "font_size": 28.0, "lines": ["どうぜ俺の", "ロンリーなんて、", "理解できない", "のさ！！"]}, {"box": [65, 1063, 155, 1403], "vertical": true, "font_size": 26.0, "lines": ["俺だって毎日", "瀬戸際のつもりで", "バァカ。", "必死なんだよ。"]}]}