{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [854, 142, 940, 289], "vertical": true, "font_size": 26.0, "lines": ["一面クリア。", "もうすぐ社長", "来るぜ。"]}, {"box": [558, 110, 644, 281], "vertical": true, "font_size": 25.0, "lines": ["この道の先は", "完全に袋小路に", "なってる。"]}, {"box": [83, 148, 169, 360], "vertical": true, "font_size": 28.0, "lines": ["社長のクルマが", "停まったら、一気に", "ボコすぜ？"]}, {"box": [698, 565, 723, 721], "vertical": true, "font_size": 20.0, "lines": ["オーケー了解。"]}, {"box": [318, 393, 373, 604], "vertical": true, "font_size": 25.0, "lines": ["その後、例の場所で", "ゆっくり交渉だ。"]}, {"box": [775, 907, 832, 1114], "vertical": true, "font_size": 26.0, "lines": ["どうした芳一、", "テンション低いぜ。"]}, {"box": [188, 766, 271, 989], "vertical": true, "font_size": 27.0, "lines": ["おう。"]}]}