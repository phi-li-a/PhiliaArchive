{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [722, 520, 809, 698], "vertical": true, "font_size": 25.0, "lines": ["６月某日、", "桃子と散歩中、", "突然の土砂降り。"]}, {"box": [626, 517, 681, 734], "vertical": true, "font_size": 25.0, "lines": ["あわててスーパーに", "逃げ込んだ。"]}, {"box": [448, 515, 534, 745], "vertical": true, "font_size": 25.0, "lines": ["そろそろ梅雨が来て、", "梅雨が明ければ", "もう夏だ。"]}, {"box": [238, 511, 354, 708], "vertical": true, "font_size": 26.0, "lines": ["スーパーの店頭に", "桃が並んでいて、", "その値段に", "驚いてしまう。"]}, {"box": [891, 759, 951, 917], "vertical": true, "font_size": 26.0, "lines": ["ほら桃子、", "桃が売ってる。"]}, {"box": [919, 1016, 978, 1170], "vertical": true, "font_size": 25.0, "lines": ["言ってごらん、", "「もも」って。"]}, {"box": [598, 777, 623, 862], "vertical": true, "font_size": 23.0, "lines": ["ははは。"]}, {"box": [599, 778, 622, 862], "vertical": true, "font_size": 23.0, "lines": ["ははは。"]}, {"box": [501, 846, 555, 1001], "vertical": true, "font_size": 23.0, "lines": ["桃と桃子。", "ももとももこ。"]}, {"box": [310, 833, 398, 1086], "vertical": true, "font_size": 23.0, "lines": ["いつでも桃が食べられる", "という人間の技術に"]}, {"box": [309, 830, 335, 1047], "vertical": true, "font_size": 24.0, "lines": ["改めて感心しつつも、"]}, {"box": [444, 1246, 483, 1405], "vertical": true, "font_size": 30.0, "lines": ["う。", "だー"]}, {"box": [153, 1098, 208, 1356], "vertical": true, "font_size": 24.0, "lines": ["夏が来る前に桃を食べる", "必要性について"]}, {"box": [123, 1091, 211, 1354], "vertical": true, "font_size": 25.0, "lines": ["少し考えてしまう。"]}]}