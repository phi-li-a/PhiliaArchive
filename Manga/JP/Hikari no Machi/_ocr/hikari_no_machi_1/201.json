{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [840, 79, 897, 238], "vertical": true, "font_size": 25.0, "lines": ["でも体は", "ただの子供だ。"]}, {"box": [282, 107, 343, 278], "vertical": true, "font_size": 25.0, "lines": ["そーこーしてる", "うちに、"]}, {"box": [887, 654, 917, 790], "vertical": true, "font_size": 26.0, "lines": ["え、終わり？"]}, {"box": [642, 376, 697, 584], "vertical": true, "font_size": 25.0, "lines": ["すぐ眠くなるし、", "コーヒーはまずい。"]}, {"box": [126, 233, 262, 570], "vertical": true, "font_size": 25.0, "lines": ["終わり。", "心の傷の癒えた", "彼女は別の男と", "幸せな結婚を", "するんだとさ。"]}, {"box": [815, 789, 840, 888], "vertical": true, "font_size": 26.0, "lines": ["オチは！？"]}, {"box": [715, 1039, 755, 1088], "vertical": false, "font_size": 17.0, "lines": ["いなると"]}, {"box": [629, 1057, 700, 1158], "vertical": false, "font_size": 19.0, "lines": ["それはガチンで", "そんにちょっ"]}, {"box": [99, 720, 188, 947], "vertical": true, "font_size": 25.0, "lines": ["つーか、さっきから", "気になってんだけど、", "この手紙、何？"]}, {"box": [845, 1078, 872, 1195], "vertical": true, "font_size": 26.0, "lines": ["．．．あっ！"]}, {"box": [95, 1039, 209, 1386], "vertical": true, "font_size": 25.0, "lines": ["そうだ、もう", "行かなくちゃ。", "ちょっと屋上に", "行っていいかな？"]}]}