{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [745, 49, 973, 551], "vertical": true, "font_size": 28.0, "lines": ["あっっったりまえ", "だろがよ！！", "金い、金！！全！！金！？", "お金大好き！！", "金のためなら", "なんだってできる", "ね、俺は！！"]}, {"box": [218, 205, 275, 378], "vertical": true, "font_size": 25.0, "lines": ["こらこら", "暴れんなって！！"]}, {"box": [306, 522, 423, 765], "vertical": true, "font_size": 25.0, "lines": ["．．．あのな、", "サトシのような", "欲のない奴に、", "生きる資格はねぇぞ？"]}, {"box": [134, 316, 192, 513], "vertical": true, "font_size": 25.0, "lines": ["ほらぁ、", "みそ汁こほれた！！"]}, {"box": [175, 591, 262, 811], "vertical": true, "font_size": 25.0, "lines": ["お前は食って", "寝るだけのために、", "生まれてきたのか！？"]}, {"box": [868, 789, 952, 994], "vertical": true, "font_size": 23.0, "lines": ["芳一は大げさだよ。", "生活できれば", "それでいいじゃん。"]}, {"box": [90, 883, 274, 1343], "vertical": true, "font_size": 26.0, "lines": ["．．．けっ。", "ところで", "今月の月謝", "お前とこの手の", "出せよ。", "言い合いは、", "もう飽きたよ。", "ハイハイ。"]}, {"box": [631, 1193, 775, 1391], "vertical": true, "font_size": 23.0, "lines": ["だいたい芳一", "パソコンにしか、", "金使わないじゃん。", "金貯めてどうする", "つもりなのさ？"]}]}