{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [853, 107, 910, 279], "vertical": true, "font_size": 28.0, "lines": ["幸せになれると", "いいな。"]}, {"box": [448, 67, 634, 322], "vertical": true, "font_size": 26.0, "lines": ["はは、なんか", "不思議だ。", "きっと今頃、", "ハル子のヤツも", "口開けてこの空を", "見てんだろうな。"]}, {"box": [129, 293, 222, 665], "vertical": true, "font_size": 25.0, "lines": ["また、そんなこと", "意味がないって", "ん？", "思った？"]}, {"box": [838, 780, 951, 963], "vertical": true, "font_size": 24.0, "lines": ["意味があるとか", "ないとか", "理屈はどうでも", "いいじゃないか"]}, {"box": [582, 1163, 702, 1397], "vertical": true, "font_size": 25.0, "lines": ["要はどっちを", "信じれば幸せな気分に", "なれるかって、", "ことだと思うよ。"]}, {"box": [80, 995, 193, 1382], "vertical": true, "font_size": 25.0, "lines": ["．．．ってオイ、", "聞いてる？", "．．．．．．寝ちゃった", "か．．．．．．"]}]}