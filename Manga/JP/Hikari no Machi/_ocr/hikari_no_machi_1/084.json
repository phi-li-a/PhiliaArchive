{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [791, 55, 949, 422], "vertical": true, "font_size": 25.0, "lines": ["あっ、あたしさぁ、", "お母さんが死んだって", "聞いても．．", "全然悲しくなくて、", "むしろ「ざまみろ」", "とかって思って！"]}, {"box": [140, 22, 259, 58], "vertical": false, "font_size": 30.0, "lines": ["わかりのまち"]}, {"box": [834, 664, 860, 787], "vertical": true, "font_size": 22.0, "lines": ["．．．バッカ！！"]}, {"box": [516, 237, 682, 605], "vertical": true, "font_size": 25.0, "lines": ["ねっ！？", "ひくでしょ！？", "あたしって、こんな", "それでも", "女なんだよ！？", "好きだなんて", "言えるの！？"]}, {"box": [101, 441, 127, 570], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．！！"]}, {"box": [748, 767, 798, 911], "vertical": true, "font_size": 22.0, "lines": ["言えるよ！", "いくらでも！"]}, {"box": [167, 808, 234, 957], "vertical": true, "font_size": 29.0, "lines": ["好きだぜ、", "すっごく！！"]}, {"box": [841, 1093, 864, 1221], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．"]}, {"box": [584, 1096, 636, 1248], "vertical": true, "font_size": 24.0, "lines": ["．．．今日は", "もう寝ようぜ。"]}, {"box": [500, 1205, 553, 1354], "vertical": true, "font_size": 24.0, "lines": ["ホラ服着ろよ、", "カゼひくから。"]}, {"box": [281, 1113, 350, 1402], "vertical": true, "font_size": 25.0, "lines": ["．．．タスク、", "明日晴れると", "いいね．．．．．．"]}, {"box": [121, 1152, 208, 1420], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．正直、", "動揺した。", "なんだ、この感じは．．．？"]}]}