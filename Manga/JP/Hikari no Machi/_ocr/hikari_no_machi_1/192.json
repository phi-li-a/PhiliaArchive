{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [851, 138, 936, 287], "vertical": true, "font_size": 25.0, "lines": ["ははは、", "まぁまぁそう", "焦らないで♪"]}, {"box": [105, 137, 218, 332], "vertical": true, "font_size": 24.0, "lines": ["これから", "長い長い旅が", "始まるんだから．．．", "ミャンニャン♪"]}, {"box": [188, 501, 309, 735], "vertical": true, "font_size": 27.0, "lines": ["「どうやら自分は", "死んでしまった", "らしい」と、", "乗客の一人が言った。"]}, {"box": [784, 1173, 842, 1416], "vertical": true, "font_size": 24.0, "lines": ["仕方なく私は", "外の景色に目をやった。"]}, {"box": [543, 1173, 630, 1429], "vertical": true, "font_size": 25.0, "lines": ["見慣れた", "「ひかりのまち」の景色が", "そこにあった。"]}, {"box": [312, 1182, 402, 1371], "vertical": true, "font_size": 28.0, "lines": ["懐かしさとともに、", "どこか違和感を", "感じた。"]}]}