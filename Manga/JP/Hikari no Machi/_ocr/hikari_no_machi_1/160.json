{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [813, 124, 870, 214], "vertical": true, "font_size": 26.0, "lines": ["桃子ぉー", "芳ーぃー"]}, {"box": [691, 261, 774, 422], "vertical": true, "font_size": 26.0, "lines": ["ただいまぁ。", "ゴメン、こんな", "遅くなって。"]}, {"box": [135, 27, 263, 74], "vertical": false, "font_size": 32.0, "lines": ["わかりのまち"]}, {"box": [124, 168, 239, 437], "vertical": true, "font_size": 24.0, "lines": ["結局僕は、", "職場の先輩の株の話に", "深夜までつき合わされて", "しまった。"]}, {"box": [532, 1016, 864, 1175], "vertical": false, "font_size": 32.0, "lines": ["諦め時に起こしてな。まぁ", "われたからもうねるで！！"]}, {"box": [674, 1138, 761, 1185], "vertical": false, "font_size": 30.0, "lines": ["だったら"]}, {"box": [194, 1039, 392, 1282], "vertical": true, "font_size": 26.0, "lines": ["しかし先輩が言うには", "株はインターネットで", "簡単にできるらしく、", "それなら僕にでも、と", "少しだけ興味が湧いた", "のだ。"]}, {"box": [87, 1211, 171, 1397], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．芳一、", "ちょっとパソコン", "借りるぞ。"]}]}