{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [844, 97, 957, 314], "vertical": true, "font_size": 24.0, "lines": ["１０時２０分コンビニで", "トイレに入る。", "３５分からメイクを", "直しはじめ"]}, {"box": [561, 158, 703, 516], "vertical": true, "font_size": 24.0, "lines": ["１１時現在、", "誰かと携帯で", "こんな時間に", "会話中。", "誰としゃべってん", "だろ？"]}, {"box": [375, 58, 518, 254], "vertical": true, "font_size": 24.0, "lines": ["あのね、アタシね", "野津くんがただの", "女子高生好きの", "危ない人に", "見えてきたのね。"]}, {"box": [97, 379, 172, 625], "vertical": true, "font_size": 26.0, "lines": ["動いた！！", "．．．．．．あっ。"]}, {"box": [403, 939, 539, 972], "vertical": false, "font_size": 28.0, "lines": ["岩間眼科"]}, {"box": [180, 717, 297, 887], "vertical": true, "font_size": 26.0, "lines": ["やばい！！", "さよちゃん、", "走って追いかけ", "よう！！"]}, {"box": [751, 1012, 868, 1385], "vertical": true, "font_size": 25.0, "lines": ["あたし今、", "あー", "妊娠してるから", "野津くん、", "走るのはチョット", "野津くん、", "なんだな。"]}]}