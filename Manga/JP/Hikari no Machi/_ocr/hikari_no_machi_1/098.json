{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [728, 125, 798, 362], "vertical": true, "font_size": 30.0, "lines": ["「ひかりのまち」に", "帰ろう？"]}, {"box": [830, 688, 854, 867], "vertical": true, "font_size": 20.0, "lines": ["僕はハスの中で"]}, {"box": [761, 688, 785, 863], "vertical": true, "font_size": 24.0, "lines": ["見届け屋のこと、"]}, {"box": [665, 689, 717, 892], "vertical": true, "font_size": 22.0, "lines": ["ハル子の父親に", "してしまったこと、"]}, {"box": [592, 689, 621, 897], "vertical": true, "font_size": 29.0, "lines": ["すべてを明かした。"]}, {"box": [377, 685, 433, 889], "vertical": true, "font_size": 22.0, "lines": ["ハル子は二年前の", "ことを僕に語った。"]}, {"box": [277, 688, 332, 901], "vertical": true, "font_size": 23.0, "lines": ["三ツ目はストーカー", "ではなかったし、"]}, {"box": [150, 685, 235, 881], "vertical": true, "font_size": 26.0, "lines": ["僕だけでなく", "両親や警察にまで", "嘘をついていた。"]}, {"box": [236, 1241, 351, 1401], "vertical": true, "font_size": 24.0, "lines": ["もう僕らは", "きのうのように", "手を握ることは", "なかった。"]}, {"box": [134, 1214, 163, 1225], "vertical": false, "font_size": 12.0, "lines": ["．．．"]}]}