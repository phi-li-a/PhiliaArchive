{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [866, 183, 891, 529], "vertical": true, "font_size": 25.0, "lines": ["あの頃、ブラブラしてた友達は"]}, {"box": [804, 181, 831, 492], "vertical": true, "font_size": 25.0, "lines": ["もうちゃんと働いていたり、"]}, {"box": [744, 183, 769, 464], "vertical": true, "font_size": 25.0, "lines": ["まだプラプラしてたりで"]}, {"box": [683, 181, 708, 523], "vertical": true, "font_size": 25.0, "lines": ["僕は今日も漫画を描いている。"]}, {"box": [497, 184, 517, 484], "vertical": true, "font_size": 22.0, "lines": ["最近、日が経つのが早いな。"]}, {"box": [372, 183, 397, 428], "vertical": true, "font_size": 22.0, "lines": ["明日も漫画を描こう。"]}, {"box": [246, 180, 276, 400], "vertical": true, "font_size": 25.0, "lines": ["それだけなんです。"]}, {"box": [560, 186, 580, 636], "vertical": true, "font_size": 22.0, "lines": ["だからなんだってワケじゃないんだけど"]}, {"box": [432, 180, 457, 601], "vertical": true, "font_size": 22.0, "lines": ["もし僕にまだ時間が残されてるなら"]}, {"box": [124, 369, 148, 629], "vertical": true, "font_size": 19.0, "lines": ["２００５年、春、浅野いにお"]}]}