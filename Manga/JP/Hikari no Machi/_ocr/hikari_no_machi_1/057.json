{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [854, 99, 939, 327], "vertical": true, "font_size": 25.0, "lines": ["そういや今日は", "来るの遅かったけど、", "何してたの？"]}, {"box": [631, 104, 718, 279], "vertical": true, "font_size": 27.0, "lines": ["ー、別に。", "んー", "そこらへん", "ぶらっと。"]}, {"box": [192, 79, 306, 259], "vertical": true, "font_size": 26.0, "lines": ["そうそう、", "だからっつーか、", "お詫びっつーか、", "コレ持ってきた。"]}, {"box": [114, 202, 139, 310], "vertical": true, "font_size": 26.0, "lines": ["遊ぼうぜ。"]}, {"box": [563, 385, 650, 533], "vertical": true, "font_size": 28.0, "lines": ["あたし退屈で", "半寝してたっ", "スよ。"]}, {"box": [505, 547, 565, 682], "vertical": true, "font_size": 30.0, "lines": ["はは、", "ダメじゃん。"]}, {"box": [799, 749, 854, 922], "vertical": true, "font_size": 26.0, "lines": ["あはは", "何コレー"]}, {"box": [221, 909, 278, 1054], "vertical": true, "font_size": 26.0, "lines": ["何、ハル子", "知らないの？"]}, {"box": [770, 1105, 854, 1342], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．ほら、アレ、", "ジェンガってオモチャ", "あんだろ？"]}, {"box": [82, 1215, 198, 1427], "vertical": true, "font_size": 24.0, "lines": ["ここらのマンション", "見てると、なーんか", "それ思い出すん", "だよなぁー"]}]}