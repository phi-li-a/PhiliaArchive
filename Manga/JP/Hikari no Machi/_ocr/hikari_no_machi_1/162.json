{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [891, 98, 946, 267], "vertical": true, "font_size": 24.0, "lines": ["．．．うへぇ．．．．．", "汚いなぁ．．．"]}, {"box": [804, 190, 858, 410], "vertical": true, "font_size": 24.0, "lines": ["言えば俺が掃除", "してやるのに．．．．．．"]}, {"box": [120, 168, 266, 463], "vertical": true, "font_size": 25.0, "lines": ["触るのなんて、いったい", "何年振りだろうと", "思いながら、", "僕はパソコンのモニターを", "のぞき込んだ。"]}, {"box": [366, 377, 425, 536], "vertical": true, "font_size": 29.0, "lines": ["．．．あ、", "メール来てる。"]}, {"box": [738, 617, 803, 880], "vertical": true, "font_size": 26.0, "lines": ["そして目に", "飛び込んできたのは"]}, {"box": [233, 927, 258, 1050], "vertical": true, "font_size": 24.0, "lines": ["．．．何これ？"]}, {"box": [553, 1076, 616, 1345], "vertical": true, "font_size": 28.0, "lines": ["悲しいくらい無謀な", "犯行の計画書だった。"]}]}