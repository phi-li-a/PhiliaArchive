{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [782, 87, 927, 331], "vertical": true, "font_size": 25.0, "lines": ["人気のない街は", "まるで積み木や", "ブロックのオモチャの", "ような印象を", "受けた。"]}, {"box": [170, 362, 283, 529], "vertical": true, "font_size": 32.0, "lines": ["他の乗客たちも感慨深そうにその光景を見つめていた。"]}, {"box": [167, 360, 336, 759], "vertical": true, "font_size": 24.0, "lines": ["住人だったの", "他の乗客たちも", "だろうか。", "感慨深そうに", "その光景を", "見つめていた。"]}, {"box": [254, 584, 341, 751], "vertical": true, "font_size": 22.0, "lines": ["みんなこの街の"]}, {"box": [813, 823, 928, 1037], "vertical": true, "font_size": 23.0, "lines": ["私の部屋も", "このどこかに", "あるのかもしれない", "と思ったが．．．．．．"]}, {"box": [367, 939, 423, 1095], "vertical": true, "font_size": 24.0, "lines": ["．．．．．うまく", "思い出せない。"]}, {"box": [78, 1126, 163, 1348], "vertical": true, "font_size": 24.0, "lines": ["そもそも私は", "いつからこのバスに", "乗っているのだろう。"]}]}