{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [819, 187, 850, 317], "vertical": true, "font_size": 25.0, "lines": ["流れ星だ。"]}, {"box": [801, 568, 891, 746], "vertical": true, "font_size": 26.0, "lines": ["どこ？"]}, {"box": [867, 870, 949, 1110], "vertical": true, "font_size": 23.0, "lines": ["．．．．．お、おい", "流れ星どっち行った？", "追おうぜ？"]}, {"box": [420, 907, 597, 1144], "vertical": true, "font_size": 27.0, "lines": ["いや、スズケン", "流れ星ってのは", "そーゆうんじゃ", "なくて、", "一瞬で", "燃え尽き．．．"]}, {"box": [138, 684, 196, 815], "vertical": true, "font_size": 26.0, "lines": ["．．．いや、", "もう消えた。"]}, {"box": [565, 1208, 680, 1396], "vertical": true, "font_size": 26.0, "lines": ["俺なんか", "タイミング悪くて", "一度も見たこと", "ねーんだよ。"]}, {"box": [313, 1265, 343, 1433], "vertical": true, "font_size": 26.0, "lines": ["まぁ、いいや。"]}]}