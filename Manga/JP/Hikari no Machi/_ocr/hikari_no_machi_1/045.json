{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [329, 187, 384, 519], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．．日課の夜の散歩ついでに", "ちょっとひと仕事。"]}, {"box": [0, 86, 51, 484], "vertical": true, "font_size": 32.0, "lines": ["アナチと"]}, {"box": [761, 211, 873, 692], "vertical": true, "font_size": 23.0, "lines": ["大きな仕事も", "．．．でも、それが", "任されるようになって", "なんだってんだ？", "秋には子供も", "生まれる．．．．．．"]}, {"box": [173, 550, 259, 771], "vertical": true, "font_size": 24.0, "lines": ["よくよく考えれば", "むなしいことだらけ", "じゃないか．．．"]}, {"box": [700, 849, 760, 1069], "vertical": true, "font_size": 25.0, "lines": ["僕が不登校を決めて", "もうじき一年。"]}, {"box": [431, 849, 607, 1062], "vertical": true, "font_size": 23.0, "lines": ["暇つぶしに", "父親から拝借した", "パソコンの", "ブックマークは、", "自殺志願者サイトに", "繋がっていた。"]}, {"box": [218, 849, 305, 1090], "vertical": true, "font_size": 24.0, "lines": ["そこで僕に", "おもしろいアイテアが", "浮かんだんだ。"]}, {"box": [809, 1083, 863, 1261], "vertical": true, "font_size": 20.0, "lines": ["．．．わかるかなぁ", "こういう気持ち。"]}, {"box": [115, 1189, 170, 1389], "vertical": true, "font_size": 23.0, "lines": ["よーくわかります、", "そういう気持ち。"]}]}