{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [861, 28, 923, 223], "vertical": true, "font_size": 22.0, "lines": ["子供が昼間っから", "何してんだよ！"]}, {"box": [512, 42, 601, 279], "vertical": true, "font_size": 26.0, "lines": ["お前さぁ、", "放っておいていいのか", "警官として？"]}, {"box": [96, 98, 193, 546], "vertical": true, "font_size": 22.0, "lines": ["．．．まぁーーっ", "子供には子供なりの", "そうかもしれない", "理由があるんじゃ", "ですけど。", "ないスかね？"]}, {"box": [615, 380, 732, 617], "vertical": true, "font_size": 25.0, "lines": ["あ、あの子たち、", "昼間ずっとあそこに", "いるんですよ。", "ここらじゃ有名スよ。"]}, {"box": [724, 677, 879, 957], "vertical": true, "font_size": 25.0, "lines": ["．．．うーん．．．．．", "長年くすぶってた", "俺の刑事魂が", "何かを感じて", "やまないぜ．．．．．．"]}, {"box": [193, 833, 311, 1053], "vertical": true, "font_size": 26.0, "lines": ["水谷さんて、", "ドラマに感化されて", "警察入ったクチっ", "スか？"]}, {"box": [323, 1145, 380, 1315], "vertical": true, "font_size": 24.0, "lines": ["タスク、あたし", "そろそろ帰るね"]}, {"box": [204, 1214, 286, 1407], "vertical": true, "font_size": 24.0, "lines": ["お母さんが先に", "帰ってきちゃうと、", "アレだから。"]}]}