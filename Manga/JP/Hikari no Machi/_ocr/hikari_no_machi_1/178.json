{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [795, 70, 826, 237], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．でも、"]}, {"box": [674, 142, 747, 445], "vertical": true, "font_size": 32.0, "lines": ["人を騙したり", "傷つけたりすることは"]}, {"box": [586, 313, 626, 479], "vertical": true, "font_size": 32.0, "lines": ["絶対に悪だ。"]}, {"box": [144, 317, 287, 737], "vertical": true, "font_size": 24.0, "lines": ["社長ぉー", "ここがどこだか", "あんたの親会社が", "利益拡大のために", "わかるかな？", "買い上げた", "現・廃ビルですわ。"]}, {"box": [778, 767, 928, 1052], "vertical": true, "font_size": 26.0, "lines": ["〈皮肉だねっ、", "皮肉だねっ、", "そんなトコに", "拉致、監禁されて", "皮肉だねっ。"]}, {"box": [531, 763, 618, 1046], "vertical": true, "font_size": 25.0, "lines": ["．．．魔材の不法投棄は", "前任者の判断であって", "私の知るところじゃないだ"]}, {"box": [393, 902, 508, 1096], "vertical": true, "font_size": 32.0, "lines": ["公表したければすればいいさ。私が退いて会社が少し傾くだけだ。"]}, {"box": [392, 900, 506, 1095], "vertical": true, "font_size": 25.0, "lines": ["公表したければ", "すればいいさ。", "私が退いて会社が", "少し傾くだけだ"]}, {"box": [84, 917, 141, 1103], "vertical": true, "font_size": 22.0, "lines": ["金なんて出すわけ", "ないだろう．．．"]}, {"box": [211, 1130, 297, 1322], "vertical": true, "font_size": 24.0, "lines": ["あら社長、", "責任転嫁？", "むしろ開き直り？"]}, {"box": [98, 1191, 181, 1401], "vertical": true, "font_size": 24.0, "lines": ["偉い人たちってのは", "みんな同じことを", "するね。"]}]}