{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [768, 132, 854, 313], "vertical": true, "font_size": 25.0, "lines": ["ーんじゃ", "コレが今回の", "報酬ってコトで"]}, {"box": [124, 154, 299, 576], "vertical": true, "font_size": 26.0, "lines": ["．．．つーかよぉ、", "もっとガバッと", "。コピーソフト販売。", "稼げねぇもんかね。", "女の幹旋、", "ハッパの転売、", "なんか細くねぇ？"]}, {"box": [748, 352, 774, 487], "vertical": true, "font_size": 20.0, "lines": ["す", "うぃー"]}, {"box": [787, 591, 923, 917], "vertical": true, "font_size": 27.0, "lines": ["芳一、お前さ．．．", "最近、拍車をかけて", "釜、金、金って．．．", "金の虫な。"]}, {"box": [840, 988, 925, 1227], "vertical": true, "font_size": 24.0, "lines": ["やめくけやめとけ。", "お前、馬鹿じゃんよ。", "一人じゃ失敗するぜ？"]}, {"box": [67, 670, 251, 961], "vertical": true, "font_size": 29.0, "lines": ["俺のドリームを", "実現させるには、", "足踏みしてる時間は", "ねぇのさ", "俺ぁ", "動くぜ。"]}, {"box": [263, 1035, 463, 1410], "vertical": true, "font_size": 25.0, "lines": ["いや、でもネットで", "おもしれぇ商売", "してるガキがいてよ。", "うまく利用すりゃ、", "新機軸な商売が", "できるかもってな．．．"]}]}