{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [798, 151, 823, 299], "vertical": true, "font_size": 25.0, "lines": ["でもやっぱ？"]}, {"box": [672, 204, 757, 432], "vertical": true, "font_size": 25.0, "lines": ["ムナシク", "なっちゃうんだよね。", "アタシ、年頃だし。"]}, {"box": [101, 120, 296, 452], "vertical": true, "font_size": 25.0, "lines": ["あ、そっから", "下って見える", "かなぁ？", "あそこにいんの", "ウチの棟の", "オバサン連中", "なんだけどさぁ。"]}, {"box": [600, 596, 683, 889], "vertical": true, "font_size": 24.0, "lines": ["少なくとも", "ま、", "ああなるのだけは", "カンベンだよね。"]}, {"box": [837, 1064, 862, 1235], "vertical": true, "font_size": 24.0, "lines": ["．．．そうだ！"]}, {"box": [98, 1148, 213, 1370], "vertical": true, "font_size": 25.0, "lines": ["ここから", "あのオバサンたちに、", "アタシを直撃させる", "ことってできない？"]}]}