{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [804, 655, 895, 840], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．芳一、", "クルマ、そっちに", "向かったよ．．．"]}, {"box": [202, 359, 230, 493], "vertical": true, "font_size": 25.0, "lines": ["大丈夫です。"]}, {"box": [228, 739, 331, 1038], "vertical": true, "font_size": 30.0, "lines": ["了解。", "ナイス、サトシ。", "お疲れ。"]}, {"box": [125, 761, 188, 851], "vertical": true, "font_size": 21.0, "lines": ["この先", "行き止まり"]}, {"box": [790, 1059, 951, 1389], "vertical": true, "font_size": 25.0, "lines": ["．．．あとな、", "考えたんだが、", "もうお前は", "荷物まとめて桃子と", "あの家から出ていけ。"]}, {"box": [250, 1155, 288, 1224], "vertical": true, "font_size": 32.0, "lines": ["え？"]}, {"box": [267, 1361, 307, 1451], "vertical": true, "font_size": 32.0, "lines": ["ピッ"]}, {"box": [139, 1251, 225, 1406], "vertical": true, "font_size": 24.0, "lines": ["家族ごっこは", "もう終わりだ", "．．．じゃあな。"]}]}