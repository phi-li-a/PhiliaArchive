{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [830, 90, 944, 324], "vertical": true, "font_size": 25.0, "lines": ["こーゆー", "新興住宅地って", "中の上クラスな家庭で", "山盛りなわけじゃん。"]}, {"box": [92, 78, 150, 215], "vertical": true, "font_size": 25.0, "lines": ["「きっと", "何かある」？"]}, {"box": [649, 433, 786, 671], "vertical": true, "font_size": 22.0, "lines": ["一見、世の中の幸せの", "上澄みでできたような", "素敵な街だけど、", "裏を返せば．．．きっと", "何がある！"]}, {"box": [513, 292, 599, 471], "vertical": true, "font_size": 28.0, "lines": ["もしかして、", "他、何も", "決まってないの？"]}, {"box": [297, 326, 357, 460], "vertical": true, "font_size": 28.0, "lines": ["なんで", "照れんだよ。"]}, {"box": [817, 718, 933, 931], "vertical": true, "font_size": 23.0, "lines": ["たとえばホラっ！！", "平日昼間から", "一人たたずむ", "あの女子高生とか！！"]}, {"box": [127, 901, 211, 1049], "vertical": true, "font_size": 26.0, "lines": ["ただの", "サボリ中のコ", "じゃなくて？"]}, {"box": [893, 1128, 949, 1269], "vertical": true, "font_size": 24.0, "lines": ["いんや、", "わからんよ？"]}, {"box": [785, 1222, 867, 1394], "vertical": true, "font_size": 24.0, "lines": ["あとつけちゃったり", "していいかな", "さよちゃん？"]}, {"box": [123, 1256, 211, 1363], "vertical": true, "font_size": 28.0, "lines": ["あ、ソレ、", "ちょっと", "ドキドキ。"]}]}