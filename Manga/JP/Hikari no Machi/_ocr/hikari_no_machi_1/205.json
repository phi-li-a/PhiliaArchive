{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [843, 76, 931, 288], "vertical": true, "font_size": 27.0, "lines": ["たとえばこんな一見", "無意味な", "一本の線でも、"]}, {"box": [494, 90, 551, 288], "vertical": true, "font_size": 25.0, "lines": ["キミとネコの間に", "境界ができた。"]}, {"box": [90, 130, 202, 506], "vertical": true, "font_size": 27.0, "lines": ["こんなふうに", "なる。", "もう少し", "複雑にすると、"]}, {"box": [514, 706, 545, 808], "vertical": true, "font_size": 28.0, "lines": ["ニャー"]}, {"box": [164, 824, 221, 1007], "vertical": true, "font_size": 25.0, "lines": ["ホラ、もうキミは", "行くべきなんだ。"]}, {"box": [86, 1214, 143, 1418], "vertical": true, "font_size": 26.0, "lines": ["「．．．あなたは", "なんなんですか？」"]}]}