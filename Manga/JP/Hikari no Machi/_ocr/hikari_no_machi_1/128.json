{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [831, 121, 917, 339], "vertical": true, "font_size": 23.0, "lines": ["ここで待ってれば", "そのうちＵＦＯさん", "来るよ！"]}, {"box": [626, 80, 655, 239], "vertical": true, "font_size": 28.0, "lines": ["．．．ふっふっ♪。"]}, {"box": [526, 191, 582, 317], "vertical": true, "font_size": 28.0, "lines": ["東さん、", "知ってる？"]}, {"box": [70, 250, 183, 457], "vertical": true, "font_size": 24.0, "lines": ["この前自殺した", "Ｆ組の女の子、", "この場所から", "飛び降りたんだよ。"]}, {"box": [545, 515, 598, 696], "vertical": true, "font_size": 22.0, "lines": ["うん、きのう", "ここで会ったよ。"]}, {"box": [107, 605, 166, 775], "vertical": true, "font_size": 28.0, "lines": ["今度は", "ユーレイすか！！"]}, {"box": [498, 838, 582, 1042], "vertical": true, "font_size": 26.0, "lines": ["生まれ変わるなら", "キレイな鳥が", "いいって言ってた。"]}, {"box": [759, 1042, 941, 1358], "vertical": true, "font_size": 24.0, "lines": ["なーんじゃそりゃ、", "ずいぶん前向きな", "幽霊だな、オイ。", "死人ならもっと", "しおらしくして", "ほしーよ。"]}, {"box": [99, 959, 222, 1364], "vertical": true, "font_size": 23.0, "lines": ["人生に負けた奴に", "来世決める資格", "なんてないわ。", "ふざけんなって", "言っといて。"]}]}