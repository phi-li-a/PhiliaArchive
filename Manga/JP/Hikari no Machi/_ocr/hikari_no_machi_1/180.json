{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [81, 90, 198, 475], "vertical": true, "font_size": 24.0, "lines": ["．．．あの、", "我々こういう", "失礼ですけど、", "者ですが", "伊藤芳一さん", "ですか？"]}, {"box": [850, 621, 907, 780], "vertical": true, "font_size": 27.0, "lines": ["．．．いや、あの", "僕は．．．．．．"]}, {"box": [367, 503, 433, 611], "vertical": false, "font_size": 28.0, "lines": ["ボールを"]}, {"box": [316, 506, 372, 586], "vertical": true, "font_size": 32.0, "lines": ["北原"]}, {"box": [350, 541, 393, 632], "vertical": true, "font_size": 25.0, "lines": ["茂", "何部も"]}, {"box": [823, 914, 939, 1132], "vertical": true, "font_size": 24.0, "lines": ["以前からこの家は", "大家の承認を得て、", "立ち退くように再三", "通告してまして。"]}, {"box": [153, 664, 182, 812], "vertical": true, "font_size": 24.0, "lines": ["ご家族の方？"]}, {"box": [365, 1128, 479, 1367], "vertical": true, "font_size": 25.0, "lines": ["ご主人の芳一さん、", "「金は用意するから」と", "おっしゃってました", "けど．．．．．．"]}, {"box": [77, 1208, 189, 1397], "vertical": true, "font_size": 23.0, "lines": ["そういう問題じゃ", "ないんです。", "どうにかご理解", "いただきたく．．．"]}]}