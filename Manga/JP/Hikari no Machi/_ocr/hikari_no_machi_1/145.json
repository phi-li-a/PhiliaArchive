{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [834, 196, 930, 452], "vertical": true, "font_size": 29.0, "lines": ["ーで、ほどなくして", "やっぱりその女は", "どこかへ消えた。"]}, {"box": [621, 98, 709, 297], "vertical": true, "font_size": 29.0, "lines": ["．．．．．．．．置いて", "逃げると思ってた", "ぜぇ、俺は。"]}, {"box": [102, 166, 203, 555], "vertical": true, "font_size": 25.0, "lines": ["思い当たるフシ", "俺ら、", "ありありだし", "どっちかの子供", "なんだろうな"]}, {"box": [815, 566, 903, 793], "vertical": true, "font_size": 23.0, "lines": ["とりあえず", "名前決めなきゃだな。", "「あ」でいいか。"]}, {"box": [659, 652, 778, 802], "vertical": true, "font_size": 24.0, "lines": ["いや芳一", "もうちょっと", "真面目に", "考えようよ！！"]}, {"box": [586, 350, 684, 476], "vertical": true, "font_size": 31.0, "lines": ["ど、ど、", "どうしよう", "芳一！？"]}, {"box": [410, 598, 464, 768], "vertical": true, "font_size": 27.0, "lines": ["そんなこんなで", "もう５年"]}, {"box": [315, 599, 376, 770], "vertical": true, "font_size": 27.0, "lines": ["いろいろあった", "ような、"]}, {"box": [260, 601, 285, 780], "vertical": true, "font_size": 27.0, "lines": ["何もないような。"]}, {"box": [343, 887, 378, 1059], "vertical": true, "font_size": 32.0, "lines": ["確かに、"]}, {"box": [847, 1135, 932, 1395], "vertical": true, "font_size": 26.0, "lines": ["僕はいったい", "こんなところで", "何をしているんだろう？"]}, {"box": [281, 1100, 309, 1280], "vertical": true, "font_size": 25.0, "lines": ["おーい、サトシ！！"]}, {"box": [168, 1193, 225, 1408], "vertical": true, "font_size": 25.0, "lines": ["湯が冷めないうちに", "お前もフロ入れよ。"]}]}