{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [584, 418, 612, 569], "vertical": true, "font_size": 28.0, "lines": ["下通工事中の点の７月２６日から８月４日までの間以下の演技は注目をお願いします」ニーリー"]}, {"box": [167, 445, 264, 634], "vertical": true, "font_size": 32.0, "lines": ["から８", "迂回をお"]}, {"box": [795, 657, 848, 863], "vertical": true, "font_size": 32.0, "lines": ["７月下旬、相変わらずの暑さ。"]}, {"box": [794, 657, 848, 863], "vertical": true, "font_size": 24.0, "lines": ["７月下旬、", "相変わらずの暑さ。"]}, {"box": [699, 661, 752, 828], "vertical": true, "font_size": 24.0, "lines": ["やはり蝉の声が", "聞こえない。"]}, {"box": [699, 659, 753, 833], "vertical": true, "font_size": 32.0, "lines": ["やはり蝉の声が聞こえない。"]}, {"box": [598, 658, 623, 837], "vertical": true, "font_size": 24.0, "lines": ["僕が考察するに"]}, {"box": [473, 657, 563, 899], "vertical": true, "font_size": 26.0, "lines": ["土の上に", "アスファルトが敷かれ", "建物が建ち、"]}, {"box": [377, 657, 434, 866], "vertical": true, "font_size": 25.0, "lines": ["幼虫たちの出口が", "塞がれてしまった。"]}, {"box": [467, 949, 521, 1126], "vertical": true, "font_size": 26.0, "lines": ["抗えない"]}, {"box": [465, 950, 489, 1120], "vertical": true, "font_size": 26.0, "lines": ["大きな力の前に"]}, {"box": [310, 947, 397, 1143], "vertical": true, "font_size": 26.0, "lines": ["志半ばで", "土に還ってゆく", "蝉たちの気持ちを"]}, {"box": [280, 661, 303, 868], "vertical": true, "font_size": 20.0, "lines": ["たとえば、そんな話"]}, {"box": [185, 659, 209, 842], "vertical": true, "font_size": 20.0, "lines": ["ない話ではない。"]}, {"box": [194, 945, 399, 1149], "vertical": false, "font_size": 32.0, "lines": ["大半ばで土に送ってゆく様たちの気持ちを、ちょっとだけ考えてみる。"]}, {"box": [190, 946, 248, 1092], "vertical": true, "font_size": 23.0, "lines": ["ちょっとだけ", "考えてみる。"]}, {"box": [89, 1282, 140, 1379], "vertical": true, "font_size": 30.0, "lines": ["ただいま"]}]}