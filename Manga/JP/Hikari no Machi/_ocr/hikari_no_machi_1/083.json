{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [788, 136, 818, 285], "vertical": true, "font_size": 27.0, "lines": ["見て、タスク。"]}, {"box": [887, 906, 944, 1111], "vertical": true, "font_size": 25.0, "lines": ["コレ、三ツ目の男に", "つけられたキズ。"]}, {"box": [630, 1214, 717, 1358], "vertical": true, "font_size": 27.0, "lines": ["もう一生", "消えないん", "だってさ．．．"]}, {"box": [384, 994, 529, 1293], "vertical": true, "font_size": 26.0, "lines": ["．．．．．ね？", "あたしもタスクも", "実はお互いのこと、", "よく知らない", "じゃん！"]}, {"box": [82, 1191, 199, 1381], "vertical": true, "font_size": 26.0, "lines": ["なのに、なんで", "タスクはあたしに", "やさしくできる", "かなぁ！？"]}]}