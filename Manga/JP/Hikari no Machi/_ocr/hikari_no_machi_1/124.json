{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [874, 80, 928, 308], "vertical": true, "font_size": 22.0, "lines": ["よく会うんだもん。", "それでお話しするの。"]}, {"box": [445, 216, 519, 455], "vertical": true, "font_size": 32.0, "lines": ["ギャーーッ！！", "むかつくーーっ！！"]}, {"box": [181, 115, 327, 364], "vertical": true, "font_size": 26.0, "lines": ["なんか", "すっげー", "こういう奴の化けの皮", "『スルズルにはがして", "やりてぇ！！"]}, {"box": [825, 513, 884, 687], "vertical": true, "font_size": 25.0, "lines": ["じゃあさ！！", "じゃあ東さん！！"]}, {"box": [373, 532, 560, 889], "vertical": true, "font_size": 24.0, "lines": ["世界が終わんなら、", "こんな追試", "テキトーに切り上げ", "ちゃってさぁ、", "あたしもその", "ＵＦＯさんトコに", "連れてってよ！！"]}, {"box": [490, 1019, 516, 1141], "vertical": true, "font_size": 26.0, "lines": ["いいよー"]}, {"box": [452, 1268, 508, 1372], "vertical": true, "font_size": 24.0, "lines": ["うっ．．．", "即答だよ。"]}, {"box": [193, 1015, 339, 1254], "vertical": true, "font_size": 26.0, "lines": ["つーか、あたしの", "答案どうすんだ。", "〈まぁ、いくら考えても", "できないもんは", "できないんだけど"]}, {"box": [92, 1195, 118, 1383], "vertical": true, "font_size": 20.0, "lines": ["西山さん、あのね。"]}]}