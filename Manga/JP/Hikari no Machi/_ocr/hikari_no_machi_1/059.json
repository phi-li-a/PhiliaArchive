{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [863, 85, 950, 242], "vertical": true, "font_size": 25.0, "lines": ["水谷警部、ソレ", "変な感想っス", "ねー"]}, {"box": [527, 99, 725, 349], "vertical": true, "font_size": 29.0, "lines": ["だって", "お前よー", "異動した途端に", "自殺が２件、", "いい印象持てるかっ", "つーの。"]}, {"box": [80, 298, 197, 504], "vertical": true, "font_size": 24.0, "lines": ["．．．ま、ここ一年で", "自殺が急増してる", "のは事実なんス", "けどね。"]}, {"box": [799, 683, 945, 937], "vertical": true, "font_size": 23.0, "lines": ["最近じゃネットとかで", "噂が噂を呼んで、", "そっち系の人たちは", "この街、都市の樹海扱い", "らしいスけど。"]}, {"box": [275, 684, 330, 878], "vertical": true, "font_size": 25.0, "lines": ["俺、好きなんス", "けどねー、この街。"]}, {"box": [168, 868, 259, 1057], "vertical": true, "font_size": 23.0, "lines": ["陽当たりのいい", "クリーンで健全な", "「ひかりのまち」"]}, {"box": [137, 1256, 161, 1406], "vertical": true, "font_size": 21.0, "lines": ["オイオイォイ"]}]}