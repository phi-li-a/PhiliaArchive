{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [715, 58, 772, 311], "vertical": true, "font_size": 25.0, "lines": ["日が昇って、", "今日が始まってみると、"]}, {"box": [576, 60, 629, 337], "vertical": true, "font_size": 24.0, "lines": ["不思議なくらい", "僕の頭はクリアーだった。"]}, {"box": [463, 61, 488, 158], "vertical": true, "font_size": 24.0, "lines": ["社会とか"]}, {"box": [403, 62, 427, 166], "vertical": true, "font_size": 24.0, "lines": ["大人とか、"]}, {"box": [337, 60, 366, 237], "vertical": true, "font_size": 24.0, "lines": ["見届け屋だとか、"]}, {"box": [177, 61, 261, 253], "vertical": true, "font_size": 23.0, "lines": ["もうそんなことは", "どうでもよく", "なっていた。"]}, {"box": [781, 575, 811, 678], "vertical": true, "font_size": 32.0, "lines": ["フルに、"]}, {"box": [697, 632, 730, 744], "vertical": true, "font_size": 32.0, "lines": ["プルミ。"]}, {"box": [481, 515, 514, 649], "vertical": true, "font_size": 24.0, "lines": ["う、僕が．．．"]}, {"box": [346, 578, 422, 818], "vertical": true, "font_size": 32.0, "lines": ["何を望んでるかを", "考えよう。"]}, {"box": [226, 599, 250, 705], "vertical": true, "font_size": 24.0, "lines": ["．．．タスク、"]}, {"box": [748, 883, 892, 1228], "vertical": true, "font_size": 24.0, "lines": ["行けるとこまで", "行ってみようぜ？", "そこに何が", "あるってわけじゃ", "ないけどさ。"]}, {"box": [367, 997, 392, 1109], "vertical": true, "font_size": 25.0, "lines": ["．．．うん。"]}, {"box": [170, 715, 196, 891], "vertical": true, "font_size": 24.0, "lines": ["どこに行くの？"]}]}