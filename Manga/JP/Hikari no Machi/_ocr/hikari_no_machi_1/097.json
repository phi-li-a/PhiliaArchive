{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [820, 77, 877, 251], "vertical": true, "font_size": 32.0, "lines": ["深い沈黙を繰り返しながら、"]}, {"box": [819, 76, 876, 250], "vertical": true, "font_size": 24.0, "lines": ["深い沈黙を", "繰り返しながら、"]}, {"box": [659, 73, 772, 368], "vertical": true, "font_size": 24.0, "lines": ["それでも僕たちは", "今まで話すことのなかった", "自分のことを", "話し続けた。"]}, {"box": [454, 76, 539, 351], "vertical": true, "font_size": 24.0, "lines": ["雨音に", "かき消されそうなくらい", "小さな声で。"]}, {"box": [278, 73, 331, 240], "vertical": true, "font_size": 24.0, "lines": ["忘れかけていた", "昔の思い出"]}, {"box": [214, 73, 239, 199], "vertical": true, "font_size": 24.0, "lines": ["学校のこと、"]}, {"box": [140, 73, 168, 272], "vertical": true, "font_size": 24.0, "lines": ["家族のこと．．．"]}, {"box": [809, 438, 834, 580], "vertical": true, "font_size": 25.0, "lines": ["ねぇ、タスク。"]}, {"box": [708, 541, 765, 762], "vertical": true, "font_size": 25.0, "lines": ["なんでお友達と", "仲良くできないの？"]}, {"box": [209, 579, 296, 773], "vertical": true, "font_size": 26.0, "lines": ["ホラ、泣かないで。", "お母さんに", "言ってごらん？"]}, {"box": [931, 847, 956, 987], "vertical": true, "font_size": 24.0, "lines": ["．．．みんなが"]}, {"box": [825, 912, 906, 1133], "vertical": true, "font_size": 24.0, "lines": ["僕のこと", "人殺しの子供だって", "言うんだ．．．．．．"]}, {"box": [338, 832, 364, 1076], "vertical": true, "font_size": 21.0, "lines": ["．．．お父さんはね．．．"]}, {"box": [476, 1114, 560, 1320], "vertical": true, "font_size": 24.0, "lines": ["ねぇ、お母さん．．．", "お父さんは本当に", "人を殺したの？"]}, {"box": [99, 956, 228, 1381], "vertical": true, "font_size": 23.0, "lines": ["お友達を悪い人から", "助けるために", "仕方なく．．．", "．．．仕方なく", "そうしたのよ．．．"]}]}