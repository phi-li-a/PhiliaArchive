{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [857, 74, 958, 503], "vertical": true, "font_size": 25.0, "lines": ["ただ俺みたいな", "ゴリ押ししなきゃ", "外道がみじめに", "ならない時も", "ならないためには、", "あるんだぜぇ。"]}, {"box": [296, 105, 412, 343], "vertical": true, "font_size": 26.0, "lines": ["．．．俺の親は", "土地成金になった後、", "借金作るだけ作って", "あっさり頓死してよ。"]}, {"box": [127, 30, 257, 64], "vertical": false, "font_size": 32.0, "lines": ["しかりのまち"]}, {"box": [573, 518, 661, 702], "vertical": true, "font_size": 24.0, "lines": ["俺だってでかい", "リスク背負って", "自由やってんだ。"]}, {"box": [103, 592, 256, 1005], "vertical": true, "font_size": 25.0, "lines": ["悲しすぎるだろ、", "そんなの．．．．．．", "やっぱ半端な奴から", "腐って死んでいくん", "だよな．．．"]}]}