{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [806, 202, 900, 521], "vertical": true, "font_size": 27.0, "lines": ["．．．じゃあさ", "ハル子、", "こん中の銃、", "使うか？"]}, {"box": [569, 111, 653, 335], "vertical": true, "font_size": 25.0, "lines": ["そのかわり、", "俺を撃ってから", "自分でやってくれ？"]}, {"box": [231, 67, 287, 271], "vertical": true, "font_size": 25.0, "lines": ["辛そうなハル子を", "見るのはヤだけど、"]}, {"box": [98, 193, 186, 418], "vertical": true, "font_size": 25.0, "lines": ["ハル子が死ぬトコ", "なんて、見て", "らんないからさぁ！！"]}, {"box": [500, 464, 586, 657], "vertical": true, "font_size": 25.0, "lines": ["．．．あたしだって", "タスク撃てるわけ", "ないじゃん．．．．．．"]}, {"box": [781, 1214, 807, 1311], "vertical": true, "font_size": 26.0, "lines": ["はは．．．"]}, {"box": [696, 1262, 721, 1400], "vertical": true, "font_size": 26.0, "lines": ["あははっ！！"]}, {"box": [310, 1201, 343, 1287], "vertical": true, "font_size": 30.0, "lines": ["やばい。"]}, {"box": [149, 1232, 275, 1456], "vertical": true, "font_size": 30.0, "lines": ["こんな時に、すっげぇ", "くだらないこと", "思いついちゃったよ、", "俺！！"]}]}