{"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [808, 66, 946, 446], "vertical": true, "font_size": 25.0, "lines": ["長谷川さん．．．", "．．．．．ははっ．．．．", "ごぶさたしてます。", "この街に住んで", "らしたんですか．．．"]}, {"box": [511, 105, 623, 324], "vertical": true, "font_size": 28.0, "lines": ["水谷．．．．．", "何してんだ、", "お前．．．．．．"]}, {"box": [338, 83, 398, 231], "vertical": true, "font_size": 25.0, "lines": ["何って、仕事", "ですよ、仕事。"]}, {"box": [202, 95, 316, 318], "vertical": true, "font_size": 25.0, "lines": ["クソ退屈な", "ド田舎からようやく", "この街へ配属に", "なったんです。"]}, {"box": [80, 470, 170, 680], "vertical": true, "font_size": 26.0, "lines": ["早いもんですねぇ。", "息子さん、確かもう", "小学６年生かぁ。"]}, {"box": [453, 1035, 478, 1158], "vertical": true, "font_size": 26.0, "lines": ["消えろ．．．"]}, {"box": [905, 1091, 932, 1210], "vertical": true, "font_size": 26.0, "lines": ["つっ．．．．．．！！"]}, {"box": [372, 1079, 403, 1251], "vertical": true, "font_size": 26.0, "lines": ["消えてくれ．．．"]}, {"box": [76, 1224, 158, 1368], "vertical": true, "font_size": 22.0, "lines": ["俺の前にもう", "二度と姿を", "見せるな．．．"]}]}