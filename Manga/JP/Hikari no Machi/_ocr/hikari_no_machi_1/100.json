{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [784, 166, 814, 365], "vertical": true, "font_size": 23.0, "lines": ["じゃあね、タスク。"]}, {"box": [234, 309, 263, 398], "vertical": true, "font_size": 27.0, "lines": ["．．．おう。"]}, {"box": [741, 541, 826, 774], "vertical": true, "font_size": 26.0, "lines": ["いつもの", "「じゃあ、また明日」は", "もうない。"]}, {"box": [625, 541, 649, 699], "vertical": true, "font_size": 20.0, "lines": ["そりゃそうだ。"]}, {"box": [339, 542, 426, 734], "vertical": true, "font_size": 26.0, "lines": ["もうこのバス停に", "ハル子は来る", "必要がないし、"]}, {"box": [198, 535, 260, 720], "vertical": true, "font_size": 32.0, "lines": ["僕も", "来る必要はない。"]}, {"box": [478, 836, 623, 1115], "vertical": true, "font_size": 26.0, "lines": ["結局、僕たちは", "何をやっていたんだろう。", "結局「ひかりのまち」に", "戻ってきて、", "自分の部屋に戻る。"]}, {"box": [349, 1143, 466, 1365], "vertical": true, "font_size": 24.0, "lines": ["ここから僕たちは", "出ることはできない。", "そういうこと", "なんだろうか？"]}, {"box": [117, 1128, 152, 1362], "vertical": true, "font_size": 30.0, "lines": ["．．．タスクッ！！"]}]}