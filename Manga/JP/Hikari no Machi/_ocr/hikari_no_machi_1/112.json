{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [771, 900, 886, 1177], "vertical": true, "font_size": 25.0, "lines": ["いろんなことが終わった。", "一度に終わりすぎて", "よくわからないくらいに", "すべてが終わった。"]}, {"box": [537, 896, 681, 1192], "vertical": true, "font_size": 25.0, "lines": ["いろいろなゴタゴタの中、", "知らない大人たちに囲まれ", "自分が小学生だと", "思い知らされる", "数週間が過ぎた。"]}, {"box": [280, 896, 423, 1185], "vertical": true, "font_size": 25.0, "lines": ["久しぶりに開いた", "パソコンの", "デクストップには、", "見慣れない文書ファイルが", "置かれていた。"]}, {"box": [430, 1281, 458, 1298], "vertical": false, "font_size": 17.0, "lines": ["．．．"]}, {"box": [97, 1195, 246, 1387], "vertical": true, "font_size": 25.0, "lines": ["「これをタスクが", "読んでいるという", "ことは、私はもう", "そこにいないの", "だろう」"]}]}