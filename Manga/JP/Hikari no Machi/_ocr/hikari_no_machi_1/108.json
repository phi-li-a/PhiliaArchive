{"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [847, 64, 936, 297], "vertical": true, "font_size": 26.0, "lines": ["．．．水合、だいたいは", "お前の想像どおり", "だよ。"]}, {"box": [740, 219, 823, 430], "vertical": true, "font_size": 26.0, "lines": ["ここにある", "ケータイを調べれば", "明らかだ．．．．．．"]}, {"box": [109, 68, 270, 456], "vertical": true, "font_size": 24.0, "lines": ["一連の自殺は", "別の人間によって", "計画的に実行された。", "つまり", "俺によって．．．"]}, {"box": [851, 522, 954, 714], "vertical": true, "font_size": 28.0, "lines": ["ハッ！！そんな", "見えすいた", "猿芝居！！"]}, {"box": [90, 589, 193, 794], "vertical": true, "font_size": 29.0, "lines": ["アンタ、息子の", "罪を被ろうって", "いうのか！？"]}, {"box": [861, 843, 951, 1069], "vertical": true, "font_size": 28.0, "lines": ["あのー．．．水谷警部、", "タスクくん、屋上に", "いましたけど？"]}, {"box": [475, 957, 539, 1295], "vertical": true, "font_size": 24.0, "lines": ["様子見て荷物", "わかった", "押収しろ。", "今、向かう。"]}, {"box": [75, 1208, 153, 1388], "vertical": true, "font_size": 32.0, "lines": ["．．．．．．待てっ、", "水谷．．．．．．"]}]}