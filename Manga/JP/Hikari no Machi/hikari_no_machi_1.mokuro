{"version": "0.2.0-beta.6", "title": "Hikari no Machi", "title_uuid": "f63bb57e-cfce-4513-9a90-013166b71a40", "volume": "hikari_no_machi_1", "volume_uuid": "2a9d3677-da90-43b2-b5e4-8ebcc4febcc0", "pages": [{"version": "0.1.6", "img_width": 2513, "img_height": 1690, "blocks": [{"box": [1835, 76, 2203, 107], "vertical": false, "font_size": 32.0, "lines": ["ＩＳＢＮ４－０９－１５７２１３－８"]}, {"box": [1828, 156, 2066, 188], "vertical": false, "font_size": 32.0, "lines": ["Ｃ９９７９¥５３３Ｅ"]}, {"box": [1833, 291, 2206, 331], "vertical": false, "font_size": 32.0, "lines": ["定価：｜本体５３３円＋税"]}, {"box": [1828, 360, 2189, 404], "vertical": false, "font_size": 32.0, "lines": ["雑誌４４０５２－１３－小学館"]}, {"box": [1433, 183, 1741, 230], "vertical": false, "font_size": 32.0, "lines": ["９７８４０９９９１５７２１３４"]}, {"box": [1432, 393, 1741, 440], "vertical": false, "font_size": 25.0, "lines": ["２９９７９００５３３"]}, {"box": [1223, 612, 1322, 1134], "vertical": true, "font_size": 32.0, "lines": ["しかりのまも"]}, {"box": [1200, 637, 1310, 1147], "vertical": true, "font_size": 32.0, "lines": ["しかりのまも"]}, {"box": [910, 777, 1099, 1143], "vertical": true, "font_size": 32.0, "lines": ["ついのまで", "「Ｓｔｒｉｇｒｉｍｉｎｇｅｎｄｏｎ", "浅野いにお"]}, {"box": [41, 1650, 327, 1686], "vertical": false, "font_size": 32.0, "lines": ["ＳＵＲＤＡＹＣＸＣＯＨＩにＳ"]}], "img_path": "001.png"}, {"version": "0.1.6", "img_width": 2513, "img_height": 1690, "blocks": [{"box": [910, 618, 1162, 1157], "vertical": true, "font_size": 32.0, "lines": ["ついのまで", "ファミリーマニューアップショップ", "浅野いにお"]}, {"box": [171, 1510, 544, 1577], "vertical": false, "font_size": 32.0, "lines": ["世界のどこかで"]}, {"box": [230, 1223, 1114, 1358], "vertical": false, "font_size": 32.0, "lines": ["ｉｎｅｓｈｉｃｒｉｙｃａｓｔｉｃａｌｌｙｏｕｌｄ", "イントレージの", "僕らは生き"]}, {"box": [390, 1432, 979, 1506], "vertical": false, "font_size": 32.0, "lines": ["スンと一緒大．．．この甘く切なくほろ苦い"]}, {"box": [66, 1606, 1067, 1648], "vertical": false, "font_size": 32.0, "lines": ["注目の新鋭が紡ぎ出す「素晴らしい世界」に続く新世代読み切りシリーズ"]}, {"box": [1185, 24, 1337, 198], "vertical": false, "font_size": 32.0, "lines": ["．．．"]}, {"box": [1434, 185, 1742, 232], "vertical": false, "font_size": 32.0, "lines": ["１００７０ｍｍｍｉｎｄａｍａｎは、９７８４．０９１５７２１３４"]}, {"box": [1435, 398, 1742, 444], "vertical": false, "font_size": 32.0, "lines": ["１０月１０日（月）に１９２９９７９００５３２９"]}, {"box": [1833, 161, 2068, 196], "vertical": false, "font_size": 32.0, "lines": ["Ｃ９９７９¥５３３Ｅ"]}, {"box": [1835, 80, 2206, 115], "vertical": false, "font_size": 32.0, "lines": ["ＩＳＢＮ４－０９－１５７２１３－８"]}, {"box": [1835, 294, 2208, 336], "vertical": false, "font_size": 32.0, "lines": ["定価・本体５３０円十税"]}, {"box": [1833, 367, 2191, 407], "vertical": false, "font_size": 32.0, "lines": ["小学館", "雑誌４４４０５２－１３"]}, {"box": [1209, 616, 1316, 1135], "vertical": true, "font_size": 32.0, "lines": ["しかりのまそ"]}, {"box": [1548, 1221, 2247, 1260], "vertical": false, "font_size": 32.0, "lines": ["肌の陽当たりのいい・新興住宅地「ひかりの"]}, {"box": [1462, 1349, 1732, 1383], "vertical": false, "font_size": 32.0, "lines": ["ながらの家並みが"]}, {"box": [1742, 1275, 1909, 1326], "vertical": false, "font_size": 29.0, "lines": ["長々と分", "分譲"]}, {"box": [1538, 1520, 1862, 1557], "vertical": false, "font_size": 32.0, "lines": ["ラル人間輪舞である。"]}, {"box": [1494, 1398, 2225, 1447], "vertical": false, "font_size": 32.0, "lines": ["は、そんな古くて新しい再開発住宅地域で、"]}, {"box": [1673, 1454, 2184, 1501], "vertical": false, "font_size": 32.0, "lines": ["ひたむきに生きる人々に捧げる"]}, {"box": [1865, 1344, 2189, 1378], "vertical": false, "font_size": 32.0, "lines": ["ちを取り巻くかのよう"]}, {"box": [2225, 1339, 2471, 1383], "vertical": false, "font_size": 32.0, "lines": ["ご共存している。"]}, {"box": [1874, 1577, 2461, 1640], "vertical": false, "font_size": 32.0, "lines": ["キラキラ星はどこへゆくルーバスストップ", "「ＨＯＭＥ・ＩＲＥＢＩＴＨＤＡＹＳＯＮＧＩを収録。"]}, {"box": [2176, 1550, 2454, 1567], "vertical": false, "font_size": 17.0, "lines": ["．．．ＹｓＯＮＧ"]}], "img_path": "002.png"}, {"version": "0.1.6", "img_width": 2513, "img_height": 1690, "blocks": [{"box": [1200, 431, 1271, 1086], "vertical": true, "font_size": 32.0, "lines": ["そのまも、浅野いに、"]}, {"box": [1020, 811, 1062, 1089], "vertical": true, "font_size": 32.0, "lines": ["リアルリック"]}, {"box": [890, 782, 964, 1140], "vertical": true, "font_size": 32.0, "lines": ["浅野いにお"]}], "img_path": "003.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [], "img_path": "004.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [129, 1399, 278, 1418], "vertical": false, "font_size": 19.0, "lines": ["ＤＡＹＧＸＣＯＭＩ"]}, {"box": [835, 1132, 915, 1382], "vertical": true, "font_size": 32.0, "lines": ["おいお"]}], "img_path": "005.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [], "img_path": "006.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [88, 1004, 296, 1053], "vertical": false, "font_size": 20.0, "lines": ["ヘクトバスカル", "第３話１ｈＰａ．．．：１１７"]}, {"box": [234, 1091, 621, 1183], "vertical": false, "font_size": 25.0, "lines": ["第４話ＩＨＯＭＥＰＡＲＴＩ：．．．１３５", "ＰＡＲＴＩ：．．．ｉｓｏ"]}, {"box": [382, 1295, 914, 1331], "vertical": false, "font_size": 24.0, "lines": ["エピローグＲＥＢＢＩＲＴＨＤＡＹＳＯＮＧ．．．！！»"]}], "img_path": "007.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [419, 565, 472, 581], "vertical": false, "font_size": 16.0, "lines": ["．．．"]}, {"box": [237, 712, 687, 733], "vertical": false, "font_size": 21.0, "lines": ["プロローグＢＩＲＴＨＤＡＹＳＯＮＧ．．．？"]}, {"box": [350, 950, 785, 977], "vertical": false, "font_size": 26.0, "lines": ["第２話バスストップＰＡＲＴＩ：．．．４８"]}, {"box": [591, 1060, 764, 1085], "vertical": false, "font_size": 25.0, "lines": ["ＰＡＲＴ皿．．．。」"]}, {"box": [473, 856, 917, 883], "vertical": false, "font_size": 24.0, "lines": ["第１話キラキラ星はどこへゆく．．．！？"]}, {"box": [718, 1015, 893, 1043], "vertical": false, "font_size": 28.0, "lines": ["ＰＡＲＴＩ：．．．°？"]}], "img_path": "008.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [806, 126, 834, 280], "vertical": true, "font_size": 27.0, "lines": ["空をふらふら。"]}, {"box": [808, 127, 832, 282], "vertical": true, "font_size": 24.0, "lines": ["空をふらふら。"]}, {"box": [708, 123, 768, 432], "vertical": true, "font_size": 27.0, "lines": ["さっきから頭ん中で", "繰り返しあの歌が流れてて。"]}, {"box": [577, 127, 633, 419], "vertical": true, "font_size": 24.0, "lines": ["僕らはみんな", "生きているーーって、アレ。"]}, {"box": [441, 127, 501, 348], "vertical": true, "font_size": 23.0, "lines": ["僕らはみんな", "生きているから．．．"]}, {"box": [285, 128, 400, 325], "vertical": true, "font_size": 23.0, "lines": ["愛し合ったり", "殺し合ったり、", "馬鹿話で笑ったり", "するんだなぁ。"]}, {"box": [2, 85, 69, 489], "vertical": true, "font_size": 32.0, "lines": ["りのまも、"]}, {"box": [718, 533, 917, 561], "vertical": false, "font_size": 25.0, "lines": ["ＨＤＡＹＳＯＮＧ"]}, {"box": [892, 955, 923, 1099], "vertical": true, "font_size": 27.0, "lines": ["おはよう♪"]}, {"box": [452, 1016, 596, 1291], "vertical": true, "font_size": 25.0, "lines": ["ついでに手のひらを", "太陽に透かしてみたら、", "まぶしくて目がくらんだ。"]}, {"box": [409, 1017, 462, 1256], "vertical": true, "font_size": 20.0, "lines": ["こんな天気のいい日は", "歌を歌おう。"]}, {"box": [93, 1197, 120, 1377], "vertical": true, "font_size": 25.0, "lines": ["．．．って、オイ！！"]}], "img_path": "009.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [500, 289, 529, 1142], "vertical": true, "font_size": 20.0, "lines": ["この作品はフィクションであり、実在する人物、団体、事件、場所などことはいっさい関係ありません"]}], "img_path": "010.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [898, 89, 969, 294], "vertical": true, "font_size": 31.0, "lines": ["起こしてって", "言ったじゃん！！"]}, {"box": [678, 123, 778, 299], "vertical": true, "font_size": 29.0, "lines": ["起こしたって", "言ってん", "じゃん！！"]}, {"box": [533, 57, 620, 216], "vertical": true, "font_size": 28.0, "lines": ["やっべーよ、", "遅刻だよ。", "ぜってー遅刻。"]}, {"box": [303, 41, 332, 249], "vertical": true, "font_size": 25.0, "lines": ["．．．いってきます。"]}, {"box": [378, 335, 438, 520], "vertical": true, "font_size": 29.0, "lines": ["あ、今日", "燃えるゴミの日、"]}, {"box": [519, 535, 546, 756], "vertical": true, "font_size": 24.0, "lines": ["．．．いってきます！！"]}, {"box": [114, 291, 141, 476], "vertical": true, "font_size": 25.0, "lines": ["あっ、チューは！？"]}, {"box": [102, 607, 218, 828], "vertical": true, "font_size": 26.0, "lines": ["出かける時は", "必ずチューするって", "約束したじゃん、", "バカァ！！"]}, {"box": [760, 803, 816, 998], "vertical": true, "font_size": 25.0, "lines": ["あるマンションの", "ある一室で、"]}, {"box": [568, 800, 655, 971], "vertical": true, "font_size": 27.0, "lines": ["若い夫婦は", "いつものように", "ロゲンカ♪"]}, {"box": [265, 907, 352, 1163], "vertical": true, "font_size": 24.0, "lines": ["となりの３０３号室の", "男子高生は", "今日のデートに備える。"]}, {"box": [140, 906, 196, 1174], "vertical": true, "font_size": 25.0, "lines": ["洗っとけ♪", "そこは入念に洗っとけられ"]}, {"box": [403, 1206, 428, 1327], "vertical": true, "font_size": 22.0, "lines": ["うーん．．．"]}], "img_path": "011.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [877, 118, 910, 350], "vertical": true, "font_size": 30.0, "lines": ["いってきまーす！！"]}, {"box": [380, 120, 553, 292], "vertical": true, "font_size": 25.0, "lines": ["そして", "彼の彼女の", "８０４号室の", "女子高生は", "そんな予定は", "とうに忘れ．．．"]}, {"box": [196, 120, 312, 300], "vertical": true, "font_size": 28.0, "lines": ["むしろ", "絶望色の下着で、", "今日も", "学校へ行く♪"]}, {"box": [543, 376, 627, 571], "vertical": true, "font_size": 25.0, "lines": ["お父さーん、", "途中まで", "いっしょに行く？"]}, {"box": [97, 518, 124, 663], "vertical": true, "font_size": 24.0, "lines": ["．．．．．あ、うん"]}, {"box": [618, 744, 675, 916], "vertical": true, "font_size": 25.0, "lines": ["そして", "その娘の父親は"]}, {"box": [500, 744, 584, 890], "vertical": true, "font_size": 25.0, "lines": ["失業して", "３日経つのに", "家族に言えず"]}, {"box": [330, 744, 415, 915], "vertical": true, "font_size": 23.0, "lines": ["今日もスーツで", "あてもなく", "旅に出る♪"]}, {"box": [830, 1022, 853, 1199], "vertical": true, "font_size": 20.0, "lines": ["あらあら奥さん。"]}, {"box": [737, 1188, 794, 1297], "vertical": true, "font_size": 28.0, "lines": ["いや、でも", "そんな。"]}, {"box": [234, 1059, 289, 1214], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．なんて", "おっしゃって。"]}, {"box": [148, 1222, 208, 1365], "vertical": true, "font_size": 28.0, "lines": ["おほほ、", "奥様こそ．．．"]}], "img_path": "012.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [634, 126, 700, 331], "vertical": true, "font_size": 30.0, "lines": ["なにより今朝は", "空気が澄みきって、"]}, {"box": [233, 214, 354, 466], "vertical": true, "font_size": 31.0, "lines": ["白いシーツや", "七色のＴシャツが", "楽しげにはためく", "気持ちいい朝だった♪"]}, {"box": [768, 1019, 890, 1191], "vertical": true, "font_size": 28.0, "lines": ["そして", "ある幼稚園児は", "ひらめいた♪", "（間奏）"]}, {"box": [652, 1022, 706, 1192], "vertical": true, "font_size": 23.0, "lines": ["知ってるかい？", "ここだけの話"]}, {"box": [155, 737, 181, 845], "vertical": true, "font_size": 25.0, "lines": ["へたくそ。"]}, {"box": [555, 1116, 609, 1292], "vertical": true, "font_size": 23.0, "lines": ["世界はいつか", "終わるんだって。"]}, {"box": [243, 1302, 394, 1456], "vertical": false, "font_size": 32.0, "lines": ["さとうたいき"]}, {"box": [70, 1035, 188, 1448], "vertical": true, "font_size": 24.0, "lines": ["なんだって始まった", "当然さ。", "瞬間から終わりに向かって", "突き進むしか", "ないんだから。"]}], "img_path": "013.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [719, 180, 837, 446], "vertical": true, "font_size": 24.0, "lines": ["今日も団地の妻たちは", "曖昧な言葉と無駄話とで", "見えすいた腹の", "さくり合い♪"]}, {"box": [427, 397, 486, 617], "vertical": true, "font_size": 27.0, "lines": ["締め切りに追われる", "漫画家は、"]}, {"box": [263, 399, 349, 618], "vertical": true, "font_size": 24.0, "lines": ["泥酔しづこ捨て場で", "原稿を描き終える", "夢を見る♪"]}, {"box": [436, 705, 552, 926], "vertical": true, "font_size": 26.0, "lines": ["たとえば", "あるベンチでは", "ホームレスが", "死んだように眠り♪"]}, {"box": [281, 707, 342, 1001], "vertical": true, "font_size": 29.0, "lines": ["ある食卓からは笑い声", "ある食卓からは重い沈黙♪！"]}, {"box": [101, 957, 218, 1224], "vertical": true, "font_size": 24.0, "lines": ["ある恋人たちは愛を", "確め合い", "ある恋人たちはお互いを", "傷つけ合う♪"]}, {"box": [781, 1063, 869, 1284], "vertical": true, "font_size": 29.0, "lines": ["ある部屋では", "老人が", "眠るように死んだ♪"]}, {"box": [369, 1199, 425, 1372], "vertical": true, "font_size": 25.0, "lines": ["おじいちゃーん、", "朝ですよー"]}], "img_path": "014.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [804, 154, 944, 481], "vertical": true, "font_size": 26.0, "lines": ["同じ過ちを", "繰り返し、", "ぐるぐる", "ぐるぐる", "輪をかいて。"]}, {"box": [604, 31, 671, 134], "vertical": true, "font_size": 16.0, "lines": ["この先車の", "通り抜け", "できません"]}, {"box": [437, 444, 527, 620], "vertical": true, "font_size": 24.0, "lines": ["その螺旋の先に", "何があるのか", "知らないけども。"]}, {"box": [93, 466, 178, 673], "vertical": true, "font_size": 27.0, "lines": ["せめてこんな朝は", "今日一日の幸せを", "祈ろうじゃないか。"]}, {"box": [892, 721, 923, 852], "vertical": true, "font_size": 29.0, "lines": ["おい、猫！！"]}, {"box": [763, 793, 826, 969], "vertical": true, "font_size": 29.0, "lines": ["お前は", "どー思うよ！？"]}, {"box": [780, 1095, 839, 1243], "vertical": true, "font_size": 25.0, "lines": ["そして猫は", "こう答えた♪"]}, {"box": [158, 1171, 196, 1320], "vertical": true, "font_size": 32.0, "lines": ["ニャー"]}], "img_path": "015.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [697, 64, 748, 274], "vertical": true, "font_size": 24.0, "lines": ["一歌詞に意味なんて", "なーい。"]}, {"box": [604, 81, 661, 250], "vertical": true, "font_size": 24.0, "lines": ["まぁ意味なんて", "なーーい。"]}, {"box": [516, 81, 573, 363], "vertical": true, "font_size": 26.0, "lines": ["でもきっと", "意味ないものなんてない。"]}, {"box": [462, 85, 482, 239], "vertical": true, "font_size": 20.0, "lines": ["じゃあ歌おう。"]}, {"box": [399, 83, 425, 326], "vertical": true, "font_size": 24.0, "lines": ["なるべく楽しい歌を♪"]}, {"box": [343, 88, 363, 273], "vertical": true, "font_size": 20.0, "lines": ["〈☆ずっとくり返し"]}, {"box": [833, 394, 861, 524], "vertical": true, "font_size": 26.0, "lines": ["おはよう。"]}, {"box": [563, 468, 620, 643], "vertical": true, "font_size": 26.0, "lines": ["今日の降水確率", "は．．．．．．"]}, {"box": [270, 559, 307, 743], "vertical": true, "font_size": 30.0, "lines": ["いってきまーす。"]}, {"box": [117, 541, 147, 671], "vertical": true, "font_size": 26.0, "lines": ["あははは"]}, {"box": [851, 700, 928, 853], "vertical": true, "font_size": 24.0, "lines": ["おじいちゃん", "ご飯冷めちゃい", "ますよー"]}, {"box": [719, 816, 804, 944], "vertical": true, "font_size": 25.0, "lines": ["もーいいよ、", "今日は会社", "休むよ。"]}, {"box": [323, 881, 379, 1016], "vertical": true, "font_size": 25.0, "lines": ["あら、そんな", "奥さん。"]}, {"box": [208, 755, 260, 956], "vertical": true, "font_size": 22.0, "lines": ["タイキちゃん、", "バスが来たわよー"]}, {"box": [669, 1155, 694, 1268], "vertical": true, "font_size": 25.0, "lines": ["んで、私は。"]}, {"box": [576, 1151, 635, 1341], "vertical": true, "font_size": 25.0, "lines": ["．．．そいうか", "私って誰だっけ？"]}, {"box": [483, 1152, 539, 1354], "vertical": true, "font_size": 25.0, "lines": ["「そもそも私なのか", "僕なのか俺なのが"]}, {"box": [73, 1172, 189, 1382], "vertical": true, "font_size": 24.0, "lines": ["俺、お前の", "そーゆう機嫌が", "コロッと直るトコが", "ムカツク"]}], "img_path": "016.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [], "img_path": "017.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [833, 121, 951, 317], "vertical": true, "font_size": 26.0, "lines": ["なんでぇー？", "久々の平日デート", "なんだから", "美しく楽しく。"]}, {"box": [494, 32, 519, 198], "vertical": true, "font_size": 20.0, "lines": ["．．．あぁ、そうか。"]}, {"box": [402, 38, 417, 140], "vertical": true, "font_size": 15.0, "lines": ["そして意識"]}, {"box": [293, 28, 313, 118], "vertical": true, "font_size": 20.0, "lines": ["無に還る"]}, {"box": [582, 440, 698, 667], "vertical": true, "font_size": 26.0, "lines": ["つーか、", "遅刻が怖くて", "有休使っちゃうって、", "どうなの俺？"]}, {"box": [128, 469, 226, 822], "vertical": true, "font_size": 25.0, "lines": ["ねぇねぇ、今", "赤ちゃん", "お腹蹴ったよ！", "．．．あっ。"]}, {"box": [800, 949, 824, 1106], "vertical": true, "font_size": 22.0, "lines": ["お、マジー", "ー？"]}, {"box": [627, 1142, 679, 1292], "vertical": true, "font_size": 20.0, "lines": ["また長い長い", "人生が始まる。"]}, {"box": [512, 1142, 567, 1250], "vertical": true, "font_size": 25.0, "lines": ["おはよう。", "おはよう。"]}, {"box": [377, 1142, 438, 1286], "vertical": true, "font_size": 28.0, "lines": ["今日も", "朝が来たよ♪"]}], "img_path": "018.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [595, 393, 667, 524], "vertical": true, "font_size": 28.0, "lines": ["変化する人", "しない人。"]}, {"box": [473, 390, 546, 756], "vertical": true, "font_size": 25.0, "lines": ["それでも日々は"]}, {"box": [353, 378, 544, 765], "vertical": true, "font_size": 29.0, "lines": ["気づかないくらいゆっくりと．．．"]}, {"box": [349, 394, 420, 656], "vertical": true, "font_size": 28.0, "lines": ["気づかないくらい１瞬で", "過ぎてゆく。"]}], "img_path": "019.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [0, 73, 63, 480], "vertical": true, "font_size": 32.0, "lines": ["のまも"]}, {"box": [880, 625, 933, 743], "vertical": true, "font_size": 24.0, "lines": ["どうですか", "お客様、"]}, {"box": [800, 774, 853, 943], "vertical": true, "font_size": 24.0, "lines": ["素晴らしい", "眺めでしょう？"]}, {"box": [85, 846, 323, 1257], "vertical": true, "font_size": 23.0, "lines": ["ここは丘陵を", "開発した土地なので", "陽当たりも最高", "なんですよ。", "ここの住民の方たちは", "この街を", "「ひかりのまち」なんて", "呼んでますけどね、"]}], "img_path": "020.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [490, 120, 813, 185], "vertical": false, "font_size": 24.0, "lines": ["第１話", "キラキラ星はどこへゆく"]}, {"box": [98, 89, 239, 611], "vertical": true, "font_size": 26.0, "lines": ["ムリだろー", "つーか来年には", "俺の漫画、売れセンじゃ", "無職かも、だろ？", "はいし、やる気ないし。", "むしろ死んでるかも", "しれん。"]}, {"box": [860, 158, 950, 611], "vertical": true, "font_size": 26.0, "lines": ["野津くん、もっと", "でも素敵な", "がんばって漫画描いて", "部屋だったぁ。", "買ってよー"]}, {"box": [441, 357, 468, 484], "vertical": true, "font_size": 25.0, "lines": ["んぁ．．．．．．"]}, {"box": [772, 780, 957, 1106], "vertical": true, "font_size": 25.0, "lines": ["まーたそういう", "後ろ向きなこと言う。", "やっぱ今日は", "水族館にクリオネ", "見に行っとけば", "よかったー"]}, {"box": [90, 891, 237, 1111], "vertical": true, "font_size": 26.0, "lines": ["いやいや、", "こんな近所の取材を", "デートがわりに", "したのは悪かった", "けどさぁ。"]}, {"box": [806, 1186, 951, 1405], "vertical": true, "font_size": 24.0, "lines": ["でもわかってよ、", "さよちゃん。", "プレッシャーと戦う", "駆け出し漫画家の", "気持ちも。"]}, {"box": [683, 1276, 763, 1435], "vertical": true, "font_size": 24.0, "lines": ["疲れてんのさ、", "最近の俺．．．．．．", "きのうもさ．．．"]}], "img_path": "021.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [750, 128, 950, 486], "vertical": true, "font_size": 24.0, "lines": ["お客様のように", "お若いご夫婦でしたら、", "ローンも６０歳までで", "完済。", "お子様が増えた", "場合、リビングを", "仕切って子供部屋を", "作れる設計ですし、"]}, {"box": [114, 220, 276, 585], "vertical": true, "font_size": 24.0, "lines": ["徒歩圏内にデパート、", "公園、病院、すべて", "都心へも電車で", "そろってます。", "１時間弱、もし", "おクルマを", "お持ちなら．．．"]}, {"box": [694, 871, 901, 1118], "vertical": true, "font_size": 23.0, "lines": ["たとえば", "最新設備のマンション。", "陽当たりのいい部屋、", "バリアフリーの床、", "大型テレビと", "幸せな家庭。", "３５年のローン。"]}, {"box": [294, 843, 484, 1228], "vertical": true, "font_size": 24.0, "lines": ["あたしたちのこと、本当に", "夫婦って思ったのかなぁ？", "「出産のご予定は？」って", "聞かれちゃったよ。", "延々３０分も説明させて、", "なんか", "悪いことしちゃったね。"]}, {"box": [625, 1185, 771, 1372], "vertical": true, "font_size": 24.0, "lines": ["そういったものに", "どれほどの価値が", "あるのか、", "今の僕にはもう", "よくわからない。"]}, {"box": [74, 1216, 159, 1381], "vertical": true, "font_size": 24.0, "lines": ["いいんじゃね？", "あの不動産屋も", "仕事、仕事。"]}], "img_path": "022.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [766, 0, 826, 210], "vertical": true, "font_size": 32.0, "lines": ["ピンパーーーっ"]}, {"box": [85, 362, 136, 469], "vertical": true, "font_size": 22.0, "lines": ["開いてる", "う。", "よー"]}, {"box": [859, 704, 957, 910], "vertical": true, "font_size": 28.0, "lines": ["どィーース！！", "元気か漫画家ぁ", "ーっ！！"]}, {"box": [344, 736, 415, 969], "vertical": true, "font_size": 31.0, "lines": ["やべぇ見えねぇ！！", "何も見えねぇ！！"]}, {"box": [161, 941, 194, 1142], "vertical": true, "font_size": 31.0, "lines": ["だははは．．．"]}, {"box": [846, 1145, 948, 1347], "vertical": true, "font_size": 30.0, "lines": ["ぐぁ酒がねぇ！！", "悲しい冷蔵庫", "だな、オイ！！"]}, {"box": [766, 1274, 791, 1369], "vertical": true, "font_size": 25.0, "lines": ["そいっ！！"]}, {"box": [706, 1337, 731, 1433], "vertical": true, "font_size": 25.0, "lines": ["そいっ！！"]}, {"box": [527, 1151, 596, 1352], "vertical": true, "font_size": 30.0, "lines": ["真っ暗だ！！", "真っ暗闇だぁ！！"]}], "img_path": "023.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [829, 81, 972, 326], "vertical": true, "font_size": 24.0, "lines": ["おいっ、相変わらず", "暗い漫画描いてんの？", "いつになれば主人公", "手からビーム出せる", "ようになんの？"]}, {"box": [48, 87, 159, 323], "vertical": true, "font_size": 31.0, "lines": ["うるっさい！！", "腐れフリーター", "どもがっ！！"]}, {"box": [667, 471, 697, 588], "vertical": true, "font_size": 30.0, "lines": ["そいっ！！"]}, {"box": [184, 579, 352, 875], "vertical": true, "font_size": 32.0, "lines": ["帰れ！！", "帰れ！！", "俺に飲み歩く", "ようなヒマは", "ねーんだよっ！！"]}, {"box": [845, 883, 948, 1089], "vertical": true, "font_size": 31.0, "lines": ["今夜は天竺まで", "行っちゃう", "ぜぇー", "ーっ！！"]}, {"box": [203, 944, 256, 1168], "vertical": true, "font_size": 24.0, "lines": ["自分が一番働いて", "稼いでるハズなのに。"]}, {"box": [114, 946, 168, 1143], "vertical": true, "font_size": 24.0, "lines": ["．．．なんだよ、この", "おいてけぼり感は。"]}, {"box": [558, 1015, 698, 1413], "vertical": true, "font_size": 24.0, "lines": ["野津さぁ〜〜ん、", "アンタ昔は吐くまで", "つき合ってくれる", "ま、いいけど", "男だったよ。", "仕事がんばって", "ね。"]}, {"box": [371, 1234, 389, 1333], "vertical": true, "font_size": 18.0, "lines": ["う．．．．．．"]}, {"box": [296, 946, 347, 1275], "vertical": true, "font_size": 24.0, "lines": ["大学の同期はなぜか", "そろいもそろってフリーターに"]}, {"box": [74, 1199, 138, 1426], "vertical": true, "font_size": 26.0, "lines": ["．．．待って！", "俺も行く"]}], "img_path": "024.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [887, 134, 971, 331], "vertical": true, "font_size": 22.0, "lines": ["ああ、親に実家に", "戻れって言われた", "らしくてさ。"]}, {"box": [529, 127, 709, 518], "vertical": true, "font_size": 25.0, "lines": ["そんでプラブラ", "やってないで、", "公務員の資格取れ", "ことかなんとかで、じゃなきゃ", "絶縁くらいの勢い", "なんだと。"]}, {"box": [79, 104, 197, 412], "vertical": true, "font_size": 30.0, "lines": ["高級マンションに", "お住まいの", "ーんっ！！", "みなさぁー"]}, {"box": [282, 572, 312, 774], "vertical": true, "font_size": 32.0, "lines": ["あんたら空調の"]}, {"box": [214, 570, 313, 797], "vertical": true, "font_size": 31.0, "lines": ["効いた部屋で"]}, {"box": [773, 539, 927, 966], "vertical": true, "font_size": 30.0, "lines": ["夢ってなんですか！？", "幸せってなんだろ！？", "僕はまだ", "知りません！！"]}, {"box": [96, 569, 241, 1001], "vertical": true, "font_size": 32.0, "lines": ["快適セックスか！？", "なんじゃい", "この不平等！！"]}, {"box": [906, 1067, 966, 1502], "vertical": true, "font_size": 32.0, "lines": ["ぴぃやぁあああも"]}, {"box": [510, 1154, 595, 1332], "vertical": true, "font_size": 25.0, "lines": ["．．．アレ、", "ウチの冷蔵庫の", "マヨネーズだし"]}, {"box": [124, 1346, 180, 1465], "vertical": true, "font_size": 26.0, "lines": ["．．．おいっ？", "おーい！！"]}], "img_path": "025.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [887, 0, 959, 282], "vertical": true, "font_size": 32.0, "lines": ["っしょい！！"]}, {"box": [110, 58, 186, 263], "vertical": true, "font_size": 32.0, "lines": ["よいしょー", "い！！"]}, {"box": [804, 522, 964, 772], "vertical": true, "font_size": 27.0, "lines": ["いやぁ〜、野津さん", "あんたやっぱり", "男だよ。", "でも", "締め切りは？"]}, {"box": [99, 629, 182, 811], "vertical": true, "font_size": 25.0, "lines": ["何？シメキリ", "って何？", "ボクわかんない。"]}, {"box": [827, 826, 933, 1089], "vertical": true, "font_size": 31.0, "lines": ["あっ、明るい！！", "もしやココが天竺！？", "ヒァイズ天竺！？"]}, {"box": [594, 843, 680, 1021], "vertical": true, "font_size": 24.0, "lines": ["．．．てか、スズケン", "テンション", "おかしいけど。"]}, {"box": [476, 1239, 530, 1381], "vertical": true, "font_size": 24.0, "lines": ["アイツなんか", "あったの？"]}, {"box": [82, 915, 183, 1300], "vertical": true, "font_size": 28.0, "lines": ["って、よく見たら", "ただの自販機", "だし！！"]}], "img_path": "026.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [889, 111, 923, 281], "vertical": true, "font_size": 29.0, "lines": ["寝んなっ！！"]}, {"box": [809, 472, 928, 693], "vertical": true, "font_size": 26.0, "lines": ["―っ！？", "えー", "で、結局ゆうべは", "みんなと遊んでた？", "だから寝不足！？"]}, {"box": [404, 847, 611, 1175], "vertical": true, "font_size": 24.0, "lines": ["まぁまぁ、", "そのおかげで", "この街を舞台に話", "作ろうって思った", "スズケンが", "わけだし。", "荒れ荒れで、", "かなり厄介", "だったけど"]}, {"box": [98, 629, 215, 888], "vertical": true, "font_size": 26.0, "lines": ["野津くんは", "そうやってまわりに", "流されるから、いつも", "締め切り遅れるんだよ。"]}, {"box": [850, 1274, 876, 1381], "vertical": true, "font_size": 25.0, "lines": ["学生ノリ。"]}, {"box": [90, 1180, 205, 1397], "vertical": true, "font_size": 25.0, "lines": ["いやいや、でも", "実際街を見て歩いて、", "フツフツと何かが", "湧いてきたよ。"]}], "img_path": "027.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [830, 90, 944, 324], "vertical": true, "font_size": 25.0, "lines": ["こーゆー", "新興住宅地って", "中の上クラスな家庭で", "山盛りなわけじゃん。"]}, {"box": [92, 78, 150, 215], "vertical": true, "font_size": 25.0, "lines": ["「きっと", "何かある」？"]}, {"box": [649, 433, 786, 671], "vertical": true, "font_size": 22.0, "lines": ["一見、世の中の幸せの", "上澄みでできたような", "素敵な街だけど、", "裏を返せば．．．きっと", "何がある！"]}, {"box": [513, 292, 599, 471], "vertical": true, "font_size": 28.0, "lines": ["もしかして、", "他、何も", "決まってないの？"]}, {"box": [297, 326, 357, 460], "vertical": true, "font_size": 28.0, "lines": ["なんで", "照れんだよ。"]}, {"box": [817, 718, 933, 931], "vertical": true, "font_size": 23.0, "lines": ["たとえばホラっ！！", "平日昼間から", "一人たたずむ", "あの女子高生とか！！"]}, {"box": [127, 901, 211, 1049], "vertical": true, "font_size": 26.0, "lines": ["ただの", "サボリ中のコ", "じゃなくて？"]}, {"box": [893, 1128, 949, 1269], "vertical": true, "font_size": 24.0, "lines": ["いんや、", "わからんよ？"]}, {"box": [785, 1222, 867, 1394], "vertical": true, "font_size": 24.0, "lines": ["あとつけちゃったり", "していいかな", "さよちゃん？"]}, {"box": [123, 1256, 211, 1363], "vertical": true, "font_size": 28.0, "lines": ["あ、ソレ、", "ちょっと", "ドキドキ。"]}], "img_path": "028.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [226, 122, 281, 176], "vertical": false, "font_size": 32.0, "lines": ["に"]}, {"box": [230, 366, 264, 511], "vertical": true, "font_size": 32.0, "lines": ["しー"]}, {"box": [665, 840, 696, 982], "vertical": true, "font_size": 25.0, "lines": ["？", "えー"]}, {"box": [605, 949, 630, 1119], "vertical": true, "font_size": 25.0, "lines": ["大丈夫ーーっ？"]}, {"box": [249, 916, 440, 1227], "vertical": true, "font_size": 25.0, "lines": ["．．．じゃあ、", "その子は毎日", "ひっぱって、", "身長５ｍくらいの", "やたら細長い子に", "育てよう．．．"]}, {"box": [71, 1161, 184, 1377], "vertical": true, "font_size": 24.0, "lines": ["ちょっと何", "言ってんのーーっ？", "目が白目だけに", "なってるよ？"]}], "img_path": "029.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [844, 97, 957, 314], "vertical": true, "font_size": 24.0, "lines": ["１０時２０分コンビニで", "トイレに入る。", "３５分からメイクを", "直しはじめ"]}, {"box": [561, 158, 703, 516], "vertical": true, "font_size": 24.0, "lines": ["１１時現在、", "誰かと携帯で", "こんな時間に", "会話中。", "誰としゃべってん", "だろ？"]}, {"box": [375, 58, 518, 254], "vertical": true, "font_size": 24.0, "lines": ["あのね、アタシね", "野津くんがただの", "女子高生好きの", "危ない人に", "見えてきたのね。"]}, {"box": [97, 379, 172, 625], "vertical": true, "font_size": 26.0, "lines": ["動いた！！", "．．．．．．あっ。"]}, {"box": [403, 939, 539, 972], "vertical": false, "font_size": 28.0, "lines": ["岩間眼科"]}, {"box": [180, 717, 297, 887], "vertical": true, "font_size": 26.0, "lines": ["やばい！！", "さよちゃん、", "走って追いかけ", "よう！！"]}, {"box": [751, 1012, 868, 1385], "vertical": true, "font_size": 25.0, "lines": ["あたし今、", "あー", "妊娠してるから", "野津くん、", "走るのはチョット", "野津くん、", "なんだな。"]}], "img_path": "030.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [561, 70, 586, 181], "vertical": true, "font_size": 25.0, "lines": ["お膣、痛？"]}, {"box": [178, 110, 265, 294], "vertical": true, "font_size": 26.0, "lines": ["おお。ついに", "日本語まで", "通じなくなって。"]}, {"box": [68, 218, 155, 394], "vertical": true, "font_size": 26.0, "lines": ["もしかして", "頭打ったから", "壊れちゃった？"]}, {"box": [697, 426, 754, 574], "vertical": true, "font_size": 24.0, "lines": ["野津くん、", "落ち着いた？"]}, {"box": [177, 470, 200, 508], "vertical": true, "font_size": 24.0, "lines": ["んー"]}, {"box": [109, 555, 134, 737], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．大丈夫だよ。"]}, {"box": [228, 794, 257, 941], "vertical": true, "font_size": 27.0, "lines": ["なんの音？"]}], "img_path": "031.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [611, 151, 634, 279], "vertical": true, "font_size": 21.0, "lines": ["あら"]}, {"box": [356, 190, 412, 373], "vertical": true, "font_size": 24.0, "lines": ["あぁーー、こりゃ", "ひでぇなー"]}, {"box": [764, 340, 787, 462], "vertical": true, "font_size": 20.0, "lines": ["なになに？"]}, {"box": [843, 583, 929, 773], "vertical": true, "font_size": 25.0, "lines": ["ハーイ、", "ちょっと道開けて", "くださーい。"]}, {"box": [584, 475, 616, 545], "vertical": true, "font_size": 32.0, "lines": ["ヴェ。"]}, {"box": [281, 372, 342, 534], "vertical": true, "font_size": 28.0, "lines": ["顔、クシャって", "なってるし。"]}, {"box": [140, 473, 196, 621], "vertical": true, "font_size": 26.0, "lines": ["飛び落りたん", "ですって。"]}, {"box": [669, 765, 760, 1072], "vertical": true, "font_size": 25.0, "lines": ["さっきの", "女子高生", "じゃん．．．", "あれ．．．"]}, {"box": [539, 881, 597, 1040], "vertical": true, "font_size": 25.0, "lines": ["ゴメン、あたし", "気分が．．．．．．"]}, {"box": [154, 973, 179, 1079], "vertical": true, "font_size": 24.0, "lines": ["お．．．おう"]}, {"box": [131, 1222, 219, 1407], "vertical": true, "font_size": 27.0, "lines": ["ハイハイ、キミ", "写真とか撮らない", "でねー"]}], "img_path": "032.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [887, 85, 926, 368], "vertical": true, "font_size": 25.0, "lines": ["．．．"]}, {"box": [542, 208, 586, 360], "vertical": true, "font_size": 32.0, "lines": ["．．．"]}, {"box": [237, 272, 262, 362], "vertical": true, "font_size": 25.0, "lines": ["さよ？"]}, {"box": [717, 215, 834, 568], "vertical": true, "font_size": 28.0, "lines": ["しかし、それでも、", "．．．"]}, {"box": [712, 661, 769, 789], "vertical": true, "font_size": 26.0, "lines": ["というか、", "他人の死も、"]}, {"box": [493, 272, 521, 541], "vertical": true, "font_size": 28.0, "lines": ["いいからですから、"]}, {"box": [621, 661, 678, 808], "vertical": true, "font_size": 26.0, "lines": ["この小綺麗な", "住宅街も、"]}, {"box": [533, 660, 587, 808], "vertical": true, "font_size": 24.0, "lines": ["未来の自分の", "姿さえも、"]}, {"box": [895, 883, 929, 1033], "vertical": true, "font_size": 32.0, "lines": ["おー"]}, {"box": [444, 659, 501, 843], "vertical": true, "font_size": 24.0, "lines": ["僕には全然", "現実味がなくて。"]}, {"box": [233, 660, 380, 857], "vertical": true, "font_size": 24.0, "lines": ["時折感じる", "こうした孤独感の", "ほうが、", "すっとずっと", "リアルだなぁ。"]}, {"box": [296, 1178, 357, 1334], "vertical": true, "font_size": 32.0, "lines": ["アレぎのうの", "マヨネーズ？"]}, {"box": [137, 1221, 170, 1381], "vertical": true, "font_size": 27.0, "lines": ["ヒピピピ。ヒ"]}], "img_path": "033.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [815, 81, 927, 300], "vertical": true, "font_size": 23.0, "lines": ["．．．あ、あのコレって", "自殺ですか？", "もしかして事件絡み", "とかそういう．．．"]}, {"box": [519, 83, 605, 292], "vertical": true, "font_size": 26.0, "lines": ["や、そーゆーんじゃ", "ないんです", "けど．．．"]}, {"box": [97, 173, 153, 331], "vertical": true, "font_size": 24.0, "lines": ["ならホラ、", "といたどいた。"]}, {"box": [851, 588, 936, 735], "vertical": true, "font_size": 27.0, "lines": ["しばらくお肉", "食べられ", "ないわぁ。"]}, {"box": [612, 428, 698, 586], "vertical": true, "font_size": 25.0, "lines": ["ん？何、", "キミ、記者とか", "そーゆー人？"]}, {"box": [465, 400, 491, 510], "vertical": true, "font_size": 24.0, "lines": ["．．．ふうん"]}, {"box": [317, 400, 433, 546], "vertical": true, "font_size": 27.0, "lines": ["まぁ", "漫画みたいな", "劇的なことが", "起きても、"]}, {"box": [539, 659, 565, 785], "vertical": true, "font_size": 26.0, "lines": ["スゲェー"]}, {"box": [194, 399, 284, 545], "vertical": true, "font_size": 27.0, "lines": ["日々は", "淡々としてる", "もんだっ"]}, {"box": [737, 654, 822, 854], "vertical": true, "font_size": 22.0, "lines": ["アラ、じゃあ奥さん", "痩せられるんじゃ", "ありません？"]}, {"box": [768, 906, 854, 1120], "vertical": true, "font_size": 23.0, "lines": ["この女子高生が", "何を思っていたかは", "知りようがないし。"]}, {"box": [473, 767, 505, 833], "vertical": true, "font_size": 32.0, "lines": ["はは。"]}, {"box": [572, 903, 718, 1157], "vertical": true, "font_size": 22.0, "lines": ["時と場合によっては", "この楽しげな野次馬に", "囲まれて死んでいるのが", "僕だったとしても", "おかしくないわけで。"]}, {"box": [472, 905, 526, 1150], "vertical": true, "font_size": 24.0, "lines": ["いつ誰に何が起きても", "不思議じゃないしね。"]}, {"box": [366, 906, 419, 1155], "vertical": true, "font_size": 22.0, "lines": ["そんなこと、みんな", "わかっているのだけど。"]}, {"box": [154, 698, 241, 820], "vertical": true, "font_size": 26.0, "lines": ["ハーイ、", "クルマ通り", "まーす！！"]}, {"box": [294, 909, 314, 1202], "vertical": true, "font_size": 23.0, "lines": ["当たり前のことなんだけど、"]}, {"box": [190, 906, 245, 1062], "vertical": true, "font_size": 24.0, "lines": ["なんだろ、この"]}, {"box": [186, 903, 214, 1057], "vertical": true, "font_size": 23.0, "lines": ["「ふーん」感覚。"]}, {"box": [150, 1278, 176, 1386], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．あれ"]}], "img_path": "034.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [810, 136, 868, 293], "vertical": true, "font_size": 27.0, "lines": ["．．．もしもし、", "さよ？"]}, {"box": [170, 127, 319, 551], "vertical": true, "font_size": 24.0, "lines": ["え？コンビニで", "買い物してきて？", "今どこにいんの？", "さっきのファミレスの", "トイレ？"]}, {"box": [888, 640, 919, 811], "vertical": true, "font_size": 31.0, "lines": ["神も仏も！！"]}, {"box": [753, 642, 915, 838], "vertical": true, "font_size": 32.0, "lines": ["神も仏も", "ってか！！"]}, {"box": [760, 703, 831, 837], "vertical": true, "font_size": 32.0, "lines": ["神も仏もってか！！"]}, {"box": [131, 654, 287, 973], "vertical": true, "font_size": 25.0, "lines": ["コラコラ", "マヨネーズで", "絵ぇ描くな。", "てか早く", "降りてこいよ、", "スズケン"]}, {"box": [847, 1009, 953, 1270], "vertical": true, "font_size": 30.0, "lines": ["野津はいいよ、", "バリバリ好きな", "仕事しちゃってさ！！"]}, {"box": [388, 1122, 525, 1331], "vertical": true, "font_size": 28.0, "lines": ["どうぜ俺の", "ロンリーなんて、", "理解できない", "のさ！！"]}, {"box": [65, 1063, 155, 1403], "vertical": true, "font_size": 26.0, "lines": ["俺だって毎日", "瀬戸際のつもりで", "バァカ。", "必死なんだよ。"]}], "img_path": "035.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [814, 90, 957, 312], "vertical": true, "font_size": 25.0, "lines": ["自分の漫画の", "つまらなきに悩んで", "ゲロ吐きながら、", "毎晩死ぬこと", "考えてんだよ！"]}, {"box": [605, 40, 697, 276], "vertical": true, "font_size": 32.0, "lines": ["みっ、見下し", "ーっ！！", "てるー"]}, {"box": [283, 35, 427, 272], "vertical": true, "font_size": 31.0, "lines": ["ちょっと本が", "売れたからって、", "ソッコーで芸術家", "気取りかよ！！"]}, {"box": [662, 503, 773, 698], "vertical": true, "font_size": 22.0, "lines": ["それこそ何も", "してねぇお前には", "わかんねー", "だろうさ！"]}, {"box": [80, 356, 211, 617], "vertical": true, "font_size": 32.0, "lines": ["うっせぇ早く", "降りてこいよ、", "フタァ！！"]}, {"box": [512, 820, 546, 977], "vertical": true, "font_size": 27.0, "lines": ["やめようよ。"]}, {"box": [446, 823, 470, 1026], "vertical": true, "font_size": 27.0, "lines": ["こんな不毛な話"]}, {"box": [98, 1218, 133, 1291], "vertical": true, "font_size": 32.0, "lines": ["おぁ。"]}], "img_path": "036.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [837, 102, 925, 275], "vertical": true, "font_size": 27.0, "lines": ["．．．ところで", "俺ら知り合って", "何年？"]}, {"box": [794, 287, 850, 412], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．６年！？", "なげぇー"]}, {"box": [508, 133, 593, 266], "vertical": true, "font_size": 24.0, "lines": ["いつまで", "続くんだろ、", "こんな生活"]}, {"box": [148, 278, 236, 431], "vertical": true, "font_size": 30.0, "lines": ["いつまでも", "続けば", "いいじゃん！！"]}, {"box": [838, 555, 950, 800], "vertical": true, "font_size": 24.0, "lines": ["昔の俺はさぁ、", "未来はもっと", "キラキラしてるもんと", "思ってたんよ。"]}, {"box": [167, 486, 191, 588], "vertical": true, "font_size": 24.0, "lines": ["んーー？"]}, {"box": [136, 682, 222, 902], "vertical": true, "font_size": 25.0, "lines": ["だのにいつの間にか", "大人になっちまって", "たのなー"]}, {"box": [718, 1115, 747, 1332], "vertical": true, "font_size": 25.0, "lines": ["．．．．．ホントだね。"]}, {"box": [269, 1119, 297, 1276], "vertical": true, "font_size": 25.0, "lines": ["あっ、流れ星！！"]}, {"box": [140, 1265, 227, 1459], "vertical": true, "font_size": 26.0, "lines": ["願えっ！！", "なんでもいいから", "３回願えーーっ！！"]}], "img_path": "037.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [819, 187, 850, 317], "vertical": true, "font_size": 25.0, "lines": ["流れ星だ。"]}, {"box": [801, 568, 891, 746], "vertical": true, "font_size": 26.0, "lines": ["どこ？"]}, {"box": [867, 870, 949, 1110], "vertical": true, "font_size": 23.0, "lines": ["．．．．．お、おい", "流れ星どっち行った？", "追おうぜ？"]}, {"box": [420, 907, 597, 1144], "vertical": true, "font_size": 27.0, "lines": ["いや、スズケン", "流れ星ってのは", "そーゆうんじゃ", "なくて、", "一瞬で", "燃え尽き．．．"]}, {"box": [138, 684, 196, 815], "vertical": true, "font_size": 26.0, "lines": ["．．．いや、", "もう消えた。"]}, {"box": [565, 1208, 680, 1396], "vertical": true, "font_size": 26.0, "lines": ["俺なんか", "タイミング悪くて", "一度も見たこと", "ねーんだよ。"]}, {"box": [313, 1265, 343, 1433], "vertical": true, "font_size": 26.0, "lines": ["まぁ、いいや。"]}], "img_path": "038.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [651, 158, 683, 366], "vertical": true, "font_size": 28.0, "lines": ["い！！", "おっそー"]}, {"box": [64, 193, 155, 393], "vertical": true, "font_size": 28.0, "lines": ["もう自分で", "買ってきちゃった", "よ！！"]}, {"box": [346, 451, 381, 510], "vertical": true, "font_size": 29.0, "lines": ["ポッ"]}, {"box": [123, 488, 165, 567], "vertical": true, "font_size": 25.0, "lines": ["わたな", "１００円っぽ"]}, {"box": [832, 778, 933, 950], "vertical": true, "font_size": 27.0, "lines": ["つーか全然", "妊娠してない", "じゃん！！"]}, {"box": [123, 847, 183, 982], "vertical": true, "font_size": 28.0, "lines": ["だって", "ウソだもん。"]}, {"box": [855, 1257, 872, 1291], "vertical": true, "font_size": 17.0, "lines": ["ポッ"]}, {"box": [136, 1204, 190, 1371], "vertical": true, "font_size": 25.0, "lines": ["あははー", "びっくりした？"]}], "img_path": "039.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [884, 131, 940, 282], "vertical": true, "font_size": 26.0, "lines": ["ごめーーん！！", "ごめんね！！"]}, {"box": [80, 324, 194, 545], "vertical": true, "font_size": 24.0, "lines": ["ただちょっと", "未来のあたしたちを", "妄想して楽しんで", "みたかったの！"]}, {"box": [850, 791, 939, 1138], "vertical": true, "font_size": 25.0, "lines": ["で、さよちゃんの", "．．．ふうん。", "考える未来予想図は", "幸せだったの？"]}, {"box": [385, 906, 442, 1003], "vertical": true, "font_size": 28.0, "lines": ["ぼちぼち", "だった。"]}, {"box": [688, 1228, 713, 1349], "vertical": true, "font_size": 23.0, "lines": ["んー"]}, {"box": [113, 1246, 142, 1398], "vertical": true, "font_size": 24.0, "lines": ["．．．．．そうかぁ。"]}], "img_path": "040.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [892, 131, 917, 281], "vertical": true, "font_size": 25.0, "lines": ["ん．．．．．．"]}, {"box": [617, 181, 653, 266], "vertical": true, "font_size": 32.0, "lines": ["んん？"]}, {"box": [271, 63, 299, 221], "vertical": true, "font_size": 26.0, "lines": ["よしわかった。"]}, {"box": [111, 134, 225, 343], "vertical": true, "font_size": 26.0, "lines": ["今日の取材は", "もう終わりにして、", "俺んち帰って", "セックスしよう。"]}, {"box": [85, 435, 173, 635], "vertical": true, "font_size": 25.0, "lines": ["ダメェ～～～", "ベッド血だらけに", "なっちゃうよ？"]}, {"box": [844, 715, 927, 1038], "vertical": true, "font_size": 24.0, "lines": ["あたしが", "撮ってあげる", "貸して。"]}, {"box": [582, 881, 643, 969], "vertical": true, "font_size": 32.0, "lines": ["いいよ、", "俺は。"]}, {"box": [82, 1037, 187, 1386], "vertical": true, "font_size": 25.0, "lines": ["．．．．．はは。", "野津くん、なんで", "マヨネーズなんか", "持ってるの？"]}], "img_path": "041.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [214, 138, 359, 549], "vertical": true, "font_size": 25.0, "lines": ["なんかね、今の俺は", "キミがいれば大概", "それでいいと思った。", "だいたい", "幸せだと思った。"]}, {"box": [873, 608, 901, 745], "vertical": true, "font_size": 25.0, "lines": ["クサーーイ。"]}, {"box": [821, 861, 935, 1078], "vertical": true, "font_size": 22.0, "lines": ["キレイごとっぽくて", "胡散臭くても俺、", "漫画家だから", "言っちゃうよ。"]}, {"box": [421, 883, 445, 1020], "vertical": true, "font_size": 20.0, "lines": ["．．．うん"]}, {"box": [146, 681, 173, 806], "vertical": true, "font_size": 24.0, "lines": ["だろーん？"]}, {"box": [319, 1115, 346, 1169], "vertical": true, "font_size": 27.0, "lines": ["オキ"]}, {"box": [83, 982, 200, 1381], "vertical": true, "font_size": 23.0, "lines": ["だから野津くんも", "どこへも行っちゃ", "あたしは", "駄目なんだよ？", "ずっとキミの", "そばにいるよ。"]}], "img_path": "042.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [722, 114, 879, 368], "vertical": true, "font_size": 26.0, "lines": ["さよちゃん、", "知ってる？", "マヨネーズの", "口って星の形", "してるんだよ。"]}, {"box": [192, 287, 218, 436], "vertical": true, "font_size": 25.0, "lines": ["それでー"]}, {"box": [772, 616, 800, 789], "vertical": true, "font_size": 25.0, "lines": ["それだけだぁ！！"]}, {"box": [510, 814, 683, 1034], "vertical": true, "font_size": 23.0, "lines": ["そういえば僕は", "流れ星に３回", "願いごとが", "できたことがなくて、", "昔は相当やきもき", "したものだけど、"]}, {"box": [419, 814, 473, 991], "vertical": true, "font_size": 23.0, "lines": ["どうにか今まで", "やってこれたよ。"]}, {"box": [271, 810, 325, 1029], "vertical": true, "font_size": 20.0, "lines": ["これからもどうにか", "やっていこう"]}, {"box": [807, 1144, 863, 1274], "vertical": true, "font_size": 25.0, "lines": ["野津くんち、", "行こっか？"]}, {"box": [197, 1242, 230, 1309], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}], "img_path": "043.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [], "img_path": "044.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [329, 187, 384, 519], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．．日課の夜の散歩ついでに", "ちょっとひと仕事。"]}, {"box": [0, 86, 51, 484], "vertical": true, "font_size": 32.0, "lines": ["アナチと"]}, {"box": [761, 211, 873, 692], "vertical": true, "font_size": 23.0, "lines": ["大きな仕事も", "．．．でも、それが", "任されるようになって", "なんだってんだ？", "秋には子供も", "生まれる．．．．．．"]}, {"box": [173, 550, 259, 771], "vertical": true, "font_size": 24.0, "lines": ["よくよく考えれば", "むなしいことだらけ", "じゃないか．．．"]}, {"box": [700, 849, 760, 1069], "vertical": true, "font_size": 25.0, "lines": ["僕が不登校を決めて", "もうじき一年。"]}, {"box": [431, 849, 607, 1062], "vertical": true, "font_size": 23.0, "lines": ["暇つぶしに", "父親から拝借した", "パソコンの", "ブックマークは、", "自殺志願者サイトに", "繋がっていた。"]}, {"box": [218, 849, 305, 1090], "vertical": true, "font_size": 24.0, "lines": ["そこで僕に", "おもしろいアイテアが", "浮かんだんだ。"]}, {"box": [809, 1083, 863, 1261], "vertical": true, "font_size": 20.0, "lines": ["．．．わかるかなぁ", "こういう気持ち。"]}, {"box": [115, 1189, 170, 1389], "vertical": true, "font_size": 23.0, "lines": ["よーくわかります、", "そういう気持ち。"]}], "img_path": "045.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [582, 375, 652, 607], "vertical": true, "font_size": 24.0, "lines": ["わかったふりの人", "わからないふりの人。"]}, {"box": [453, 367, 646, 704], "vertical": true, "font_size": 24.0, "lines": ["たとえ間違っていたとしても、"]}, {"box": [458, 376, 527, 690], "vertical": true, "font_size": 24.0, "lines": ["それぞれの正しさ。"]}, {"box": [334, 374, 405, 632], "vertical": true, "font_size": 25.0, "lines": ["無数の嘘と真実が", "奇跡のバランスである。"]}], "img_path": "046.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [856, 51, 943, 234], "vertical": true, "font_size": 25.0, "lines": ["．．．大丈夫です。", "すべて段取り", "どおりですから。"]}, {"box": [517, 49, 602, 391], "vertical": true, "font_size": 24.0, "lines": ["数あるサイトの中から", "この「朝日台ハイタウン」周辺の", "住民を探しだし"]}, {"box": [432, 51, 457, 276], "vertical": true, "font_size": 19.0, "lines": ["気持ち程度の料金で"]}, {"box": [252, 47, 369, 332], "vertical": true, "font_size": 22.0, "lines": ["安全に、確実に", "彼らの望むように", "自殺をコーディネイトして", "最後を見届けてやる。"]}, {"box": [150, 48, 174, 316], "vertical": true, "font_size": 20.0, "lines": ["つまり簡単に言えば．．．"]}, {"box": [653, 497, 769, 712], "vertical": true, "font_size": 24.0, "lines": ["決心がついたら", "そこからケータイを", "捨ててください。", "．．．．．ハイ。"]}], "img_path": "047.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [702, 710, 730, 847], "vertical": true, "font_size": 26.0, "lines": ["．．．．．ふうっ。"]}, {"box": [483, 1197, 510, 1406], "vertical": true, "font_size": 25.0, "lines": ["僕は見届け屋だ。"]}], "img_path": "048.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [322, 762, 379, 983], "vertical": true, "font_size": 22.0, "lines": ["：：：今日もいつもと", "同じ朝が来た。"]}], "img_path": "049.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [346, 80, 647, 149], "vertical": false, "font_size": 20.0, "lines": ["第２話", "ＰＡＲＴＩ", "バスストップ"]}, {"box": [768, 690, 831, 857], "vertical": true, "font_size": 21.5, "lines": ["というわけで、", "．．．"]}, {"box": [697, 1129, 780, 1391], "vertical": true, "font_size": 25.0, "lines": ["斜面を利用して", "階段状に並び建てられた", "マンションの群れ。"]}, {"box": [415, 1123, 530, 1398], "vertical": true, "font_size": 21.0, "lines": ["もともとは丘だった土地を", "強引に開発した", "この新興住宅地は", "陽当たりの良さがウリで"]}, {"box": [237, 1123, 324, 1362], "vertical": true, "font_size": 28.0, "lines": ["住民は", "「ひかりのまち」なんて", "呼び方をしている。"]}], "img_path": "050.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [439, 693, 520, 714], "vertical": false, "font_size": 21.0, "lines": ["長谷川"]}, {"box": [272, 580, 329, 689], "vertical": true, "font_size": 27.0, "lines": ["おはよう、", "タスク。"]}, {"box": [189, 655, 244, 790], "vertical": true, "font_size": 27.0, "lines": ["ホラ、", "見てごらん。"]}, {"box": [772, 790, 959, 1085], "vertical": true, "font_size": 28.0, "lines": ["ハハハ。", "プチトマトこんなに", "大きくなったよ。", "父さん毎日", "世話してるから", "なぁ。"]}, {"box": [332, 1205, 416, 1389], "vertical": true, "font_size": 22.0, "lines": ["もうじき食べられ", "るんじゃないか？", "なぁ、タスク？"]}, {"box": [86, 1227, 144, 1404], "vertical": true, "font_size": 25.0, "lines": ["いや、つーか", "枯れてんじゃん。"]}], "img_path": "051.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [689, 87, 752, 215], "vertical": true, "font_size": 31.0, "lines": ["ん", "バハハハ。"]}, {"box": [539, 124, 594, 403], "vertical": true, "font_size": 22.0, "lines": ["そして僕にも", "いつものように朝が来た。"]}, {"box": [432, 123, 487, 342], "vertical": true, "font_size": 26.0, "lines": ["生焼けのトーストを", "かじる。"]}, {"box": [221, 121, 387, 380], "vertical": true, "font_size": 24.0, "lines": ["定職にもつかず", "父は今日も一日中、", "根が腐って枯れつつある", "プチトマトに水を", "やり続けるんだろう。"]}, {"box": [118, 120, 203, 340], "vertical": true, "font_size": 23.0, "lines": ["薄くほこりがかった", "母の遺影には", "目もくれず"]}, {"box": [167, 550, 192, 703], "vertical": true, "font_size": 24.0, "lines": ["．．．アホー"]}, {"box": [791, 974, 967, 1344], "vertical": true, "font_size": 24.0, "lines": ["アタシ、いまだに", "金髪だし、ギャル", "メイクだし、", "クラスのみんなに", "けっこー白い目で", "見られてんだ", "けどさ"]}, {"box": [164, 1058, 313, 1370], "vertical": true, "font_size": 24.0, "lines": ["これでも", "けっこー真面目", "なんだよ？", "半年で偏差値", "１１０も上げたし。"]}], "img_path": "052.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [840, 92, 943, 352], "vertical": true, "font_size": 28.0, "lines": ["ムリかなぁ？", "別に", "いいけどさ。"]}, {"box": [666, 93, 719, 260], "vertical": true, "font_size": 32.0, "lines": ["ちょっとそれは難しいスね。"]}, {"box": [551, 89, 719, 418], "vertical": true, "font_size": 26.0, "lines": ["ちょっとそれは", "難しいスね。", "ただ、この高さなら", "希望どおり相当", "ハデに死ねます。"]}, {"box": [554, 206, 640, 416], "vertical": true, "font_size": 32.0, "lines": ["ただ、この高さなら希望どおり相当ハデに死ねます。"]}, {"box": [67, 73, 196, 429], "vertical": true, "font_size": 25.0, "lines": ["あ、あとケータイ", "そこに置いといて", "後で回収", "ください。", "しますんで、", "よろしく。"]}], "img_path": "053.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [798, 151, 823, 299], "vertical": true, "font_size": 25.0, "lines": ["でもやっぱ？"]}, {"box": [672, 204, 757, 432], "vertical": true, "font_size": 25.0, "lines": ["ムナシク", "なっちゃうんだよね。", "アタシ、年頃だし。"]}, {"box": [101, 120, 296, 452], "vertical": true, "font_size": 25.0, "lines": ["あ、そっから", "下って見える", "かなぁ？", "あそこにいんの", "ウチの棟の", "オバサン連中", "なんだけどさぁ。"]}, {"box": [600, 596, 683, 889], "vertical": true, "font_size": 24.0, "lines": ["少なくとも", "ま、", "ああなるのだけは", "カンベンだよね。"]}, {"box": [837, 1064, 862, 1235], "vertical": true, "font_size": 24.0, "lines": ["．．．そうだ！"]}, {"box": [98, 1148, 213, 1370], "vertical": true, "font_size": 25.0, "lines": ["ここから", "あのオバサンたちに、", "アタシを直撃させる", "ことってできない？"]}], "img_path": "054.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [281, 616, 308, 791], "vertical": true, "font_size": 25.0, "lines": ["はっずれ"]}, {"box": [71, 951, 117, 1214], "vertical": true, "font_size": 30.0, "lines": ["ホレ、", "おごりだよ。"]}], "img_path": "055.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [102, 32, 256, 445], "vertical": true, "font_size": 25.0, "lines": ["１６の女が", "高校にも進学せず、", "実によろしく", "毎日こんなとこで", "ないなぁ。", "ボーっとしてる。", "ロクな将来が", "見えないね。"]}, {"box": [817, 496, 905, 667], "vertical": true, "font_size": 25.0, "lines": ["やっぱハル子は", "俺とつき合う", "べきだな。"]}, {"box": [243, 532, 297, 681], "vertical": true, "font_size": 26.0, "lines": ["聡明な俺に", "ついてくれば"]}, {"box": [877, 845, 931, 1003], "vertical": true, "font_size": 23.0, "lines": ["ーに", "なー", "言ってんのさ。"]}, {"box": [551, 858, 576, 943], "vertical": true, "font_size": 26.0, "lines": ["ははは。"]}, {"box": [429, 930, 516, 1088], "vertical": true, "font_size": 26.0, "lines": ["またフラれた。", "もう何回目", "だよ？"]}, {"box": [127, 652, 214, 826], "vertical": true, "font_size": 26.0, "lines": ["きっと明るい", "未来が待ってる", "ぜ？"]}, {"box": [614, 1185, 743, 1397], "vertical": true, "font_size": 24.0, "lines": ["学校行ってないのは", "タスクもじゃん、", "どのみちあたしらに", "明るい未来なんて", "ないっスよ。"]}, {"box": [459, 1183, 517, 1348], "vertical": true, "font_size": 24.0, "lines": ["ほぼ毎日だから", "３００回くらい？"]}, {"box": [274, 1208, 393, 1254], "vertical": false, "font_size": 32.0, "lines": ["合ハイタウン人に"]}, {"box": [251, 1268, 327, 1294], "vertical": false, "font_size": 20.0, "lines": ["朝日台バスセンタ"]}, {"box": [183, 1165, 213, 1248], "vertical": true, "font_size": 25.0, "lines": ["ははっ、"]}, {"box": [101, 1261, 155, 1377], "vertical": true, "font_size": 32.0, "lines": ["もうそんな経つかぁ。"]}, {"box": [101, 1259, 153, 1377], "vertical": true, "font_size": 25.0, "lines": ["もうそんな", "経つかぁ。"]}], "img_path": "056.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [854, 99, 939, 327], "vertical": true, "font_size": 25.0, "lines": ["そういや今日は", "来るの遅かったけど、", "何してたの？"]}, {"box": [631, 104, 718, 279], "vertical": true, "font_size": 27.0, "lines": ["ー、別に。", "んー", "そこらへん", "ぶらっと。"]}, {"box": [192, 79, 306, 259], "vertical": true, "font_size": 26.0, "lines": ["そうそう、", "だからっつーか、", "お詫びっつーか、", "コレ持ってきた。"]}, {"box": [114, 202, 139, 310], "vertical": true, "font_size": 26.0, "lines": ["遊ぼうぜ。"]}, {"box": [563, 385, 650, 533], "vertical": true, "font_size": 28.0, "lines": ["あたし退屈で", "半寝してたっ", "スよ。"]}, {"box": [505, 547, 565, 682], "vertical": true, "font_size": 30.0, "lines": ["はは、", "ダメじゃん。"]}, {"box": [799, 749, 854, 922], "vertical": true, "font_size": 26.0, "lines": ["あはは", "何コレー"]}, {"box": [221, 909, 278, 1054], "vertical": true, "font_size": 26.0, "lines": ["何、ハル子", "知らないの？"]}, {"box": [770, 1105, 854, 1342], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．ほら、アレ、", "ジェンガってオモチャ", "あんだろ？"]}, {"box": [82, 1215, 198, 1427], "vertical": true, "font_size": 24.0, "lines": ["ここらのマンション", "見てると、なーんか", "それ思い出すん", "だよなぁー"]}], "img_path": "057.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [764, 118, 821, 341], "vertical": true, "font_size": 24.0, "lines": ["なんつーかさぁ、", "こう天気がいいと．．．"]}, {"box": [818, 613, 842, 762], "vertical": true, "font_size": 20.0, "lines": ["ん？"]}, {"box": [171, 283, 317, 481], "vertical": true, "font_size": 25.0, "lines": ["弁当持って、", "どこかぶらっと", "ピクニックにでも", "行くかぁって、", "感じにならねぇ？"]}, {"box": [803, 817, 939, 1077], "vertical": true, "font_size": 28.0, "lines": ["あはは！！", "タスク、けっこう", "子供っぽいこと", "言うー"]}, {"box": [286, 876, 346, 1025], "vertical": true, "font_size": 27.0, "lines": ["まぁまぁ、", "そのうち、ね。"]}, {"box": [849, 1209, 875, 1340], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．悪いか。"]}, {"box": [98, 1228, 156, 1378], "vertical": true, "font_size": 26.0, "lines": ["そのうちって、", "いつだよ。"]}], "img_path": "058.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [863, 85, 950, 242], "vertical": true, "font_size": 25.0, "lines": ["水谷警部、ソレ", "変な感想っス", "ねー"]}, {"box": [527, 99, 725, 349], "vertical": true, "font_size": 29.0, "lines": ["だって", "お前よー", "異動した途端に", "自殺が２件、", "いい印象持てるかっ", "つーの。"]}, {"box": [80, 298, 197, 504], "vertical": true, "font_size": 24.0, "lines": ["．．．ま、ここ一年で", "自殺が急増してる", "のは事実なんス", "けどね。"]}, {"box": [799, 683, 945, 937], "vertical": true, "font_size": 23.0, "lines": ["最近じゃネットとかで", "噂が噂を呼んで、", "そっち系の人たちは", "この街、都市の樹海扱い", "らしいスけど。"]}, {"box": [275, 684, 330, 878], "vertical": true, "font_size": 25.0, "lines": ["俺、好きなんス", "けどねー、この街。"]}, {"box": [168, 868, 259, 1057], "vertical": true, "font_size": 23.0, "lines": ["陽当たりのいい", "クリーンで健全な", "「ひかりのまち」"]}, {"box": [137, 1256, 161, 1406], "vertical": true, "font_size": 21.0, "lines": ["オイオイォイ"]}], "img_path": "059.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [861, 28, 923, 223], "vertical": true, "font_size": 22.0, "lines": ["子供が昼間っから", "何してんだよ！"]}, {"box": [512, 42, 601, 279], "vertical": true, "font_size": 26.0, "lines": ["お前さぁ、", "放っておいていいのか", "警官として？"]}, {"box": [96, 98, 193, 546], "vertical": true, "font_size": 22.0, "lines": ["．．．まぁーーっ", "子供には子供なりの", "そうかもしれない", "理由があるんじゃ", "ですけど。", "ないスかね？"]}, {"box": [615, 380, 732, 617], "vertical": true, "font_size": 25.0, "lines": ["あ、あの子たち、", "昼間ずっとあそこに", "いるんですよ。", "ここらじゃ有名スよ。"]}, {"box": [724, 677, 879, 957], "vertical": true, "font_size": 25.0, "lines": ["．．．うーん．．．．．", "長年くすぶってた", "俺の刑事魂が", "何かを感じて", "やまないぜ．．．．．．"]}, {"box": [193, 833, 311, 1053], "vertical": true, "font_size": 26.0, "lines": ["水谷さんて、", "ドラマに感化されて", "警察入ったクチっ", "スか？"]}, {"box": [323, 1145, 380, 1315], "vertical": true, "font_size": 24.0, "lines": ["タスク、あたし", "そろそろ帰るね"]}, {"box": [204, 1214, 286, 1407], "vertical": true, "font_size": 24.0, "lines": ["お母さんが先に", "帰ってきちゃうと、", "アレだから。"]}], "img_path": "060.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [843, 139, 929, 293], "vertical": true, "font_size": 26.0, "lines": ["．．．きっと", "アイツは", "戻ってくるよ。"]}, {"box": [124, 236, 203, 374], "vertical": true, "font_size": 32.0, "lines": ["じゃ、", "また明日。"]}, {"box": [762, 545, 878, 814], "vertical": true, "font_size": 25.0, "lines": ["ハル子は中学の時、", "自宅近くでストーカーに", "メッタ刺しにされた", "ことがある"]}, {"box": [630, 545, 715, 790], "vertical": true, "font_size": 25.0, "lines": ["犯人は見つからず、", "手がかりは額にあった", "大きなアザだけ。"]}, {"box": [539, 545, 567, 705], "vertical": true, "font_size": 25.0, "lines": ["だから三ツ目"]}, {"box": [302, 544, 479, 776], "vertical": true, "font_size": 26.0, "lines": ["そいつが必ず、この", "「ひかりのまち」に", "戻ってくると信じて、", "ハル子は今日も", "このバス停で", "待ち続ける"]}, {"box": [131, 547, 250, 781], "vertical": true, "font_size": 25.0, "lines": ["今にして思えば、", "ハル子にはもっと", "いろいろな生きる道が", "あったに違いない。"]}, {"box": [784, 944, 816, 1019], "vertical": true, "font_size": 32.0, "lines": ["おう。"]}, {"box": [689, 1129, 775, 1366], "vertical": true, "font_size": 24.0, "lines": ["僕らが本当の意味での", "夢を失ってしまうのは", "いつごろなのだろう。"]}, {"box": [469, 1129, 615, 1367], "vertical": true, "font_size": 25.0, "lines": ["いつしか夢を", "リアルな目標に", "置き換えて、", "僕も生きていかなきゃ", "ならないんだろうか？"]}, {"box": [215, 1145, 328, 1367], "vertical": true, "font_size": 24.0, "lines": ["せっかく父さんが", "帰ってくるからって、", "早めに仕事切り上げ", "たと思ったら．．．"]}, {"box": [95, 1213, 149, 1425], "vertical": true, "font_size": 24.0, "lines": ["．．．こんな時間まで", "どこ行ってたのよ！？"]}], "img_path": "061.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [883, 98, 938, 295], "vertical": true, "font_size": 23.0, "lines": ["コレ、今日だけ", "借りてっていい？"]}, {"box": [533, 142, 619, 504], "vertical": true, "font_size": 23.0, "lines": ["なんかあったら", "いつでも俺に", "．．．ハル子。", "連絡しろよ。"]}, {"box": [88, 357, 175, 585], "vertical": true, "font_size": 24.0, "lines": ["向かいの棟なんだし、", "すぐ助けに行って", "やるから。"]}, {"box": [780, 895, 925, 1185], "vertical": true, "font_size": 24.0, "lines": ["．．．．．大丈夫。", "．．．そう！", "今日、久々に", "お父さん", "帰ってくるし！！"]}, {"box": [130, 767, 216, 939], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．三ツ目、", "今日も見つから", "なかったなぁ。"]}, {"box": [485, 1259, 509, 1366], "vertical": true, "font_size": 24.0, "lines": ["．．．うん"]}], "img_path": "062.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [737, 66, 762, 164], "vertical": true, "font_size": 24.0, "lines": ["何よ．．．"]}, {"box": [637, 110, 690, 318], "vertical": true, "font_size": 24.0, "lines": ["なんなのよ、アンタ", "その目は．．．．．．"]}, {"box": [105, 77, 224, 546], "vertical": true, "font_size": 30.0, "lines": ["そんな態度", "アンタみたいな", "とっていいと", "ロクでもない", "思ってんの！？", "娘が．．．．．．"]}, {"box": [809, 658, 866, 837], "vertical": true, "font_size": 24.0, "lines": ["目標を達成する、", "諦めるなりで、"]}, {"box": [357, 659, 388, 834], "vertical": true, "font_size": 27.0, "lines": ["無理なのか？"]}, {"box": [710, 655, 762, 884], "vertical": true, "font_size": 22.0, "lines": ["夢も何もかも", "なくなってしまう時"]}, {"box": [678, 957, 733, 1067], "vertical": true, "font_size": 25.0, "lines": ["おかえりー", "タスクー"]}, {"box": [488, 655, 637, 878], "vertical": true, "font_size": 27.0, "lines": ["その時僕らは", "理不尽な世の中に", "さらされて、", "正気を保つことが", "できるんだろうか？"]}, {"box": [587, 1022, 643, 1205], "vertical": true, "font_size": 25.0, "lines": ["見てごらんよ、", "このプチトマト。"]}, {"box": [161, 657, 245, 920], "vertical": true, "font_size": 23.0, "lines": ["大人たちがみんな", "どこかしらが", "くるっているように．．．"]}, {"box": [175, 957, 230, 1140], "vertical": true, "font_size": 25.0, "lines": ["こんなに", "大きくなったよ。"]}], "img_path": "063.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [541, 462, 596, 632], "vertical": true, "font_size": 24.0, "lines": ["少しずつ増える", "携帯電話"]}, {"box": [380, 460, 467, 642], "vertical": true, "font_size": 23.0, "lines": ["今日の女子高生", "ゆうべの会社員", "その他の人々。"]}, {"box": [151, 462, 254, 724], "vertical": true, "font_size": 30.0, "lines": ["お前ら", "どこでどうやって", "道を踏みはずした！？"]}, {"box": [825, 708, 878, 881], "vertical": true, "font_size": 24.0, "lines": ["タスクー", "どこ行く"]}, {"box": [156, 895, 183, 1018], "vertical": true, "font_size": 24.0, "lines": ["散歩だよ！！"]}, {"box": [292, 1109, 350, 1268], "vertical": true, "font_size": 26.0, "lines": ["えっへっヘっ、", "うぉい坊主！！"]}, {"box": [120, 1221, 206, 1408], "vertical": true, "font_size": 26.0, "lines": ["ガキが深夜に", "外ぶらつくなんて", "危ねぇだろう？"]}], "img_path": "064.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [862, 77, 982, 313], "vertical": true, "font_size": 23.0, "lines": ["赴任先の部署の", "白ブタみたいなＯＬ、", "ちょっと相手にしたら", "愛人気取りだよ。"]}, {"box": [618, 99, 703, 223], "vertical": true, "font_size": 25.0, "lines": ["そんなん", "納得できる", "かって．．．"]}, {"box": [115, 55, 290, 460], "vertical": true, "font_size": 25.0, "lines": ["．．．．．こーんな", "簡単に、ちょっと", "油断しただけで．．", "どん底まで", "落ちちゃうのって", "どーなんですか？"]}, {"box": [731, 423, 848, 670], "vertical": true, "font_size": 24.0, "lines": ["別れようとしたら", "セクハラで訴訟だぁ？", "長年会社に仕えた", "俺があっさりクビ！？"]}, {"box": [476, 437, 597, 682], "vertical": true, "font_size": 23.0, "lines": ["だから僕は自意識と", "性欲まみれの白ブタに", "弾をブチ込んで", "やりましたっ！！"]}, {"box": [742, 749, 963, 1101], "vertical": true, "font_size": 27.0, "lines": ["．．．えっへっへ．．．", "女房と娘の首を", "僕ぁ、この手で", "絞めてやったさ。", "女房は抵抗", "するから、", "撃っちまった．．．"]}, {"box": [198, 849, 324, 1167], "vertical": true, "font_size": 27.0, "lines": ["だって", "そうするしか", "ないじゃん．．．", "最低だ．．．．．．"]}], "img_path": "065.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [830, 91, 861, 180], "vertical": true, "font_size": 30.0, "lines": ["うふっ、"]}, {"box": [762, 160, 792, 253], "vertical": true, "font_size": 30.0, "lines": ["うふっ。"]}, {"box": [210, 167, 250, 251], "vertical": true, "font_size": 32.0, "lines": ["イッ。"]}, {"box": [870, 594, 954, 777], "vertical": true, "font_size": 26.0, "lines": ["ねぇ、おじちゃん", "お願いがあるん", "だけど．．．"]}, {"box": [668, 916, 724, 1086], "vertical": true, "font_size": 27.0, "lines": ["そんな目で", "見ないでよ．．．"]}, {"box": [555, 947, 641, 1120], "vertical": true, "font_size": 27.0, "lines": ["．．．そうだよ、", "俺は", "おかしいヨっ！！"]}, {"box": [105, 661, 189, 805], "vertical": true, "font_size": 23.0, "lines": ["引き金引くの", "手伝って", "くんない？"]}, {"box": [85, 957, 249, 1371], "vertical": true, "font_size": 27.0, "lines": ["しょうがないよ．．．", "僕はもう終わり", "なんだもん．．．．．僕の人生はもう", "完全におしまい", "なんだかりゃっ！！"]}], "img_path": "066.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [818, 127, 844, 261], "vertical": true, "font_size": 25.0, "lines": ["．．．．．ホント"]}, {"box": [177, 140, 291, 387], "vertical": true, "font_size": 29.0, "lines": ["ダメだ。", "ダメダメだぁ、", "お前ら。"]}, {"box": [837, 674, 862, 784], "vertical": true, "font_size": 25.0, "lines": ["消えろよ。"]}, {"box": [253, 946, 274, 1047], "vertical": true, "font_size": 21.0, "lines": ["．．．え？"]}, {"box": [472, 1209, 506, 1307], "vertical": true, "font_size": 32.0, "lines": ["パシュッ"]}], "img_path": "067.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [799, 95, 913, 396], "vertical": true, "font_size": 32.0, "lines": ["「こんな大人たちを作った社会が悪い」なんて、言ってもはじまらないことはわかってる。"]}, {"box": [767, 93, 913, 608], "vertical": true, "font_size": 24.0, "lines": ["「こんな大人たちを作った", "社会が悪い」なんて、", "言ってもはじまらないことは", "わかってる。", "僕にできるのは"]}, {"box": [738, 443, 762, 632], "vertical": true, "font_size": 22.0, "lines": ["そんな大人たちを"]}, {"box": [708, 442, 732, 585], "vertical": true, "font_size": 24.0, "lines": ["清算すること"]}, {"box": [681, 445, 701, 591], "vertical": true, "font_size": 22.0, "lines": ["くらいなんだ。"]}, {"box": [827, 1168, 850, 1271], "vertical": true, "font_size": 20.0, "lines": ["それでも、"]}, {"box": [671, 1165, 786, 1332], "vertical": true, "font_size": 24.0, "lines": ["それでも僕は", "必死にもがけば", "きっと出口が", "見つかる．．．．．"]}, {"box": [542, 1167, 566, 1318], "vertical": true, "font_size": 20.0, "lines": ["そう信じてる。"]}, {"box": [350, 1166, 435, 1427], "vertical": true, "font_size": 25.0, "lines": ["．．．．．僕は静かに", "いつかこの街を出てゆく", "ことを心に誓った。"]}, {"box": [186, 1185, 210, 1282], "vertical": true, "font_size": 24.0, "lines": ["ごほっ！！"]}, {"box": [184, 1185, 208, 1281], "vertical": true, "font_size": 25.0, "lines": ["ごほっ！！"]}, {"box": [105, 1304, 131, 1401], "vertical": true, "font_size": 25.0, "lines": ["ごほっ！！"]}], "img_path": "068.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [829, 80, 916, 374], "vertical": true, "font_size": 24.0, "lines": ["自殺をコーディネイトして", "奴らの最期を見届けてやる。", "それが僕の仕事。"]}, {"box": [533, 79, 621, 352], "vertical": true, "font_size": 25.0, "lines": ["そうさ、俺は", "そんな腐れた大人たちを", "清算してやるんだ．．．"]}, {"box": [0, 80, 67, 492], "vertical": true, "font_size": 32.0, "lines": ["りのませっ"]}, {"box": [676, 496, 739, 655], "vertical": true, "font_size": 26.0, "lines": ["つまり僕は", "見届け屋だ。"]}, {"box": [302, 454, 452, 676], "vertical": true, "font_size": 26.0, "lines": ["世のため人のたあ", "俺のため．．．．．", "こんな", "素晴らしいことって", "ないじゃないか？"]}, {"box": [165, 335, 204, 631], "vertical": true, "font_size": 31.0, "lines": ["．．．で、どうなった？"]}, {"box": [765, 1055, 954, 1384], "vertical": true, "font_size": 24.0, "lines": ["ハル子の父親を", "撃ち殺した。", "．．．．．違う！！", "俺は引き金を引く", "手伝いを", "しただけで．．．"]}, {"box": [140, 1130, 248, 1316], "vertical": true, "font_size": 22.0, "lines": ["ハル子の父親には", "死ぬ意志が", "もともと", "あったんだ．．．"]}], "img_path": "069.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [865, 63, 893, 178], "vertical": true, "font_size": 26.0, "lines": ["ごほっ！！"]}, {"box": [619, 483, 653, 602], "vertical": true, "font_size": 30.0, "lines": ["ごほっ！！"]}, {"box": [88, 452, 166, 786], "vertical": true, "font_size": 24.0, "lines": ["なんでだよ．．．", "おいおい．．．"]}, {"box": [837, 777, 864, 901], "vertical": true, "font_size": 25.0, "lines": ["まさか．．．"]}, {"box": [780, 911, 804, 1029], "vertical": true, "font_size": 25.0, "lines": ["こいつ．．．"]}, {"box": [216, 937, 243, 1105], "vertical": true, "font_size": 24.0, "lines": ["ハル子の父親？"]}, {"box": [705, 1111, 762, 1220], "vertical": true, "font_size": 28.0, "lines": ["僕には", "夢がある"]}, {"box": [485, 1114, 575, 1315], "vertical": true, "font_size": 27.0, "lines": ["ハル子と二人で", "青空の下、", "楽しくピクニック。"]}, {"box": [380, 1115, 434, 1282], "vertical": true, "font_size": 23.0, "lines": ["ただそれだけの", "ことなんだ"]}], "img_path": "070.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [794, 95, 878, 312], "vertical": true, "font_size": 21.0, "lines": ["．．．．．それって", "殺したことには", "変わりないじゃん？"]}, {"box": [504, 93, 563, 218], "vertical": true, "font_size": 26.0, "lines": ["じゃあ", "どうする？"]}, {"box": [631, 328, 655, 475], "vertical": true, "font_size": 21.0, "lines": ["．．．どうする？"]}, {"box": [647, 626, 672, 788], "vertical": true, "font_size": 21.0, "lines": ["．．．．．朝が来る。"]}, {"box": [385, 630, 445, 779], "vertical": true, "font_size": 26.0, "lines": ["いつもと違う", "朝が来る"]}, {"box": [241, 497, 265, 665], "vertical": true, "font_size": 21.0, "lines": ["．．．どうするよ！？"]}, {"box": [824, 893, 903, 1166], "vertical": true, "font_size": 26.0, "lines": ["あ。", "起きた？", "ハル子ちゃん。"]}, {"box": [574, 1070, 602, 1179], "vertical": true, "font_size": 25.0, "lines": ["おはよう。"]}, {"box": [79, 1048, 216, 1430], "vertical": true, "font_size": 23.0, "lines": ["大丈夫だよ、", "覚えてるかな、", "ここは病院。", "きのう自分で", "救急車呼んで", "ココに運ばれたこと。"]}], "img_path": "071.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [855, 171, 907, 479], "vertical": true, "font_size": 22.0, "lines": ["それで．．．", "残念だけど．．．"]}, {"box": [699, 194, 795, 219], "vertical": false, "font_size": 22.0, "lines": ["ＰＡＲＴＩ"]}, {"box": [625, 158, 677, 180], "vertical": false, "font_size": 22.0, "lines": ["第２話"]}, {"box": [503, 193, 681, 220], "vertical": false, "font_size": 24.0, "lines": ["バスストップ"]}, {"box": [151, 75, 241, 351], "vertical": true, "font_size": 27.0, "lines": ["あの．．．", "．．．．．．", "お父さんは？"]}, {"box": [882, 564, 937, 768], "vertical": true, "font_size": 24.0, "lines": ["マンションの前で", "亡くなられてたよ。"]}, {"box": [460, 312, 517, 491], "vertical": true, "font_size": 23.0, "lines": ["お母さんは今朝", "亡くなられたよ。"]}, {"box": [141, 642, 224, 813], "vertical": true, "font_size": 23.0, "lines": ["おそらく．．．", "自殺ってことに", "なると思う．．．"]}, {"box": [440, 903, 465, 1050], "vertical": true, "font_size": 23.0, "lines": ["ハル子ちゃん、"]}, {"box": [329, 976, 412, 1202], "vertical": true, "font_size": 23.0, "lines": ["その点滴終わったら、", "とりあえずおウチ", "戻ろうか？"]}, {"box": [88, 1182, 145, 1347], "vertical": true, "font_size": 26.0, "lines": ["外のパトカーで", "送っていくよ。"]}], "img_path": "072.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [859, 60, 956, 272], "vertical": true, "font_size": 26.0, "lines": ["お前さぁ、今", "さらっと言ってくれ", "ちゃったけど", "ソレって大問題よ？"]}, {"box": [555, 57, 613, 255], "vertical": true, "font_size": 26.0, "lines": ["犬がくわえて", "持ってったとか？"]}, {"box": [269, 68, 386, 265], "vertical": true, "font_size": 24.0, "lines": ["こんな小ギレイな", "住宅街に、", "野良犬なんて", "いねーよ。"]}, {"box": [670, 413, 756, 636], "vertical": true, "font_size": 26.0, "lines": ["チャカなしで", "どーやって自分の頭", "撃ち抜くのさ？"]}, {"box": [49, 226, 165, 574], "vertical": true, "font_size": 24.0, "lines": ["ケータイも", "あ、あと．．．", "見つからないん", "ですよ、いくら", "捜しても。"]}, {"box": [225, 636, 255, 783], "vertical": true, "font_size": 22.0, "lines": ["携帯電話が？"]}, {"box": [810, 909, 951, 1316], "vertical": true, "font_size": 25.0, "lines": ["ホントにここで", "親戚の方", "降ろしちゃって", "いらしてるから、", "いいの？", "早めにおウチに", "帰りなさいね？"]}, {"box": [142, 712, 162, 855], "vertical": true, "font_size": 22.0, "lines": ["．．．ふーん．．．．．"]}, {"box": [140, 712, 163, 859], "vertical": true, "font_size": 23.0, "lines": ["．．．ふーん．．．．．"]}], "img_path": "073.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [767, 148, 887, 528], "vertical": true, "font_size": 24.0, "lines": ["ハル子ちゃん", "水谷警部、", "目、覚ましました。", "もうすぐ点滴も", "終わります。"]}, {"box": [511, 83, 667, 315], "vertical": true, "font_size": 26.0, "lines": ["おうよ。", "しかし、アレな、", "つくづく", "ツイてない子", "なのな。"]}, {"box": [83, 168, 197, 363], "vertical": true, "font_size": 25.0, "lines": ["２年前にも", "ストーカー被害に", "あって重傷", "負ったんだろ？"]}, {"box": [509, 436, 625, 608], "vertical": true, "font_size": 25.0, "lines": ["んで、父親は", "赴任先で殺人を", "犯した挙げ句、", "一家心中、と。"]}, {"box": [277, 533, 400, 914], "vertical": true, "font_size": 27.0, "lines": ["どんだけ", "へコむわ", "ドス黒い星の下に", "生まれてきてん", "だか。"]}, {"box": [762, 933, 958, 1221], "vertical": true, "font_size": 26.0, "lines": ["父親・柿澤春彦が", "所持していたものは、", "サイフ、覚醒剤と", "簡単な内容の遺書。", "筆跡鑑定も", "すんでます。"]}, {"box": [75, 741, 134, 893], "vertical": true, "font_size": 30.0, "lines": ["．．．で、", "どうなった？"]}, {"box": [134, 1006, 246, 1394], "vertical": true, "font_size": 28.0, "lines": ["ただ、一つ", "おかしいのは．．．凶器と思われる", "拳銃のようなものが", "見つかってません。"]}], "img_path": "074.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [258, 670, 285, 808], "vertical": true, "font_size": 24.0, "lines": ["．．．タスク。"]}, {"box": [912, 931, 939, 1052], "vertical": true, "font_size": 26.0, "lines": ["ハル子．．．"]}, {"box": [284, 945, 309, 1092], "vertical": true, "font_size": 21.0, "lines": ["タスクー"]}, {"box": [426, 1279, 451, 1422], "vertical": true, "font_size": 25.0, "lines": ["タスク．．．"]}], "img_path": "075.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [307, 94, 372, 343], "vertical": true, "font_size": 26.0, "lines": ["ハル子、", "何も言うな。"]}, {"box": [875, 329, 965, 651], "vertical": true, "font_size": 24.0, "lines": ["うっ．．．うっ", "あ．．．あのね、", "タスクあのね"]}, {"box": [438, 355, 568, 667], "vertical": true, "font_size": 27.0, "lines": ["おっ、お父さん", "がね．．．", "おっおっ、", "お母さんを", "ね．．．．．．"]}, {"box": [441, 545, 526, 664], "vertical": true, "font_size": 32.0, "lines": ["おっおっ、お母さんをね．．．．．．"]}, {"box": [138, 496, 194, 666], "vertical": true, "font_size": 26.0, "lines": ["何も言わなくて", "いいよ。"]}, {"box": [807, 731, 834, 909], "vertical": true, "font_size": 28.0, "lines": ["何も言わないで、"]}, {"box": [717, 919, 775, 1036], "vertical": true, "font_size": 28.0, "lines": ["俺について", "こい。"]}, {"box": [448, 794, 502, 1060], "vertical": true, "font_size": 24.0, "lines": ["この「ひかりのまち」から", "出よう。"]}, {"box": [158, 834, 246, 1076], "vertical": true, "font_size": 25.0, "lines": ["：：：僕とハル子は", "適当な行き先のバスに", "そのまま飛び乗った。"]}], "img_path": "076.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [458, 64, 483, 297], "vertical": true, "font_size": 25.0, "lines": ["だって、そうだろう？"]}, {"box": [262, 63, 409, 306], "vertical": true, "font_size": 24.0, "lines": ["失いたくない", "ものより、", "忘れたいことのほうが", "多いような", "僕たちなんだから．．．"]}, {"box": [183, 63, 211, 212], "vertical": true, "font_size": 24.0, "lines": ["もっと自由に"]}, {"box": [128, 64, 214, 319], "vertical": true, "font_size": 25.0, "lines": ["自分が好きなように"]}, {"box": [126, 64, 151, 313], "vertical": true, "font_size": 24.0, "lines": ["生きればいいじゃんか"]}, {"box": [494, 315, 649, 549], "vertical": true, "font_size": 27.0, "lines": ["ハル子、", "疲れてるなら", "寝てていいよ。", "適当なトコで", "起こすから。"]}, {"box": [98, 561, 142, 808], "vertical": true, "font_size": 25.0, "lines": ["うん．．．．．", "ありがと。"]}, {"box": [612, 888, 732, 1109], "vertical": true, "font_size": 29.0, "lines": ["だったら、", "僕のすべてを", "ハル子のためだけに", "使う。"]}, {"box": [461, 888, 516, 1081], "vertical": true, "font_size": 24.0, "lines": ["それでいいんじゃ", "ないだろうか？"]}, {"box": [425, 1290, 511, 1336], "vertical": false, "font_size": 23.0, "lines": ["最谷製薬"]}, {"box": [259, 1126, 316, 1281], "vertical": true, "font_size": 25.0, "lines": ["ハル子、ここで", "終点だってさ。"]}, {"box": [161, 1233, 219, 1411], "vertical": true, "font_size": 25.0, "lines": ["はは、全然", "知らない街だぁ。"]}], "img_path": "077.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [715, 58, 772, 311], "vertical": true, "font_size": 25.0, "lines": ["日が昇って、", "今日が始まってみると、"]}, {"box": [576, 60, 629, 337], "vertical": true, "font_size": 24.0, "lines": ["不思議なくらい", "僕の頭はクリアーだった。"]}, {"box": [463, 61, 488, 158], "vertical": true, "font_size": 24.0, "lines": ["社会とか"]}, {"box": [403, 62, 427, 166], "vertical": true, "font_size": 24.0, "lines": ["大人とか、"]}, {"box": [337, 60, 366, 237], "vertical": true, "font_size": 24.0, "lines": ["見届け屋だとか、"]}, {"box": [177, 61, 261, 253], "vertical": true, "font_size": 23.0, "lines": ["もうそんなことは", "どうでもよく", "なっていた。"]}, {"box": [781, 575, 811, 678], "vertical": true, "font_size": 32.0, "lines": ["フルに、"]}, {"box": [697, 632, 730, 744], "vertical": true, "font_size": 32.0, "lines": ["プルミ。"]}, {"box": [481, 515, 514, 649], "vertical": true, "font_size": 24.0, "lines": ["う、僕が．．．"]}, {"box": [346, 578, 422, 818], "vertical": true, "font_size": 32.0, "lines": ["何を望んでるかを", "考えよう。"]}, {"box": [226, 599, 250, 705], "vertical": true, "font_size": 24.0, "lines": ["．．．タスク、"]}, {"box": [748, 883, 892, 1228], "vertical": true, "font_size": 24.0, "lines": ["行けるとこまで", "行ってみようぜ？", "そこに何が", "あるってわけじゃ", "ないけどさ。"]}, {"box": [367, 997, 392, 1109], "vertical": true, "font_size": 25.0, "lines": ["．．．うん。"]}, {"box": [170, 715, 196, 891], "vertical": true, "font_size": 24.0, "lines": ["どこに行くの？"]}], "img_path": "078.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [875, 125, 903, 237], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．あっ。"]}, {"box": [693, 152, 715, 278], "vertical": true, "font_size": 21.0, "lines": ["どうした？"]}, {"box": [97, 157, 155, 457], "vertical": true, "font_size": 20.0, "lines": ["コーラＳ", "当たった．．．"]}, {"box": [589, 445, 616, 618], "vertical": true, "font_size": 26.0, "lines": ["ハル子ぉ！"]}, {"box": [117, 532, 236, 728], "vertical": true, "font_size": 26.0, "lines": ["ちょっとくらいの", "イイことでも、", "とりあえず", "笑っとこうぜ？"]}, {"box": [249, 826, 274, 940], "vertical": true, "font_size": 21.0, "lines": ["．．．．．うん"]}, {"box": [725, 1078, 790, 1235], "vertical": true, "font_size": 28.0, "lines": ["．．．ハル子、", "とにかく今は、"]}, {"box": [473, 1104, 533, 1327], "vertical": true, "font_size": 26.0, "lines": ["もう何も考えないで", "ただ笑ってくれ。"]}, {"box": [206, 1057, 352, 1371], "vertical": true, "font_size": 27.0, "lines": ["ハル子、なんか", "欲しいもんとか", "ねぇの？", "服とかクツとか、", "買ってやるよ。"]}], "img_path": "079.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [585, 88, 641, 296], "vertical": true, "font_size": 26.0, "lines": ["えーー．．．", "なんか変だよソレ。"]}, {"box": [492, 206, 548, 340], "vertical": true, "font_size": 26.0, "lines": ["タスク、無理", "してない？"]}, {"box": [71, 156, 158, 337], "vertical": true, "font_size": 25.0, "lines": ["バッカ、人の", "好意は素直に", "受け入れろって。"]}, {"box": [750, 190, 910, 692], "vertical": true, "font_size": 26.0, "lines": ["．．．．．そして", "もう少し落ち着いたら", "すべてをハル子に", "話そう。", "見届け屋のこと、"]}, {"box": [688, 513, 775, 759], "vertical": true, "font_size": 21.0, "lines": ["それにハル子の父親に"]}, {"box": [687, 516, 714, 761], "vertical": true, "font_size": 26.0, "lines": ["してしまったこと．．．"]}, {"box": [571, 472, 659, 642], "vertical": true, "font_size": 27.0, "lines": ["．．．．．じゃ、", "どっか行きたい", "とこは？"]}, {"box": [346, 402, 375, 550], "vertical": true, "font_size": 26.0, "lines": ["うーん．．．．．．"]}, {"box": [105, 648, 132, 798], "vertical": true, "font_size": 20.0, "lines": ["．．．そうだ！！"]}, {"box": [740, 772, 877, 1151], "vertical": true, "font_size": 24.0, "lines": ["おっきな公園探そう！！", "ホラ、タスク", "ピクニック行こうって", "言ってたじゃん？"]}, {"box": [223, 860, 342, 1135], "vertical": true, "font_size": 32.0, "lines": ["もしこの先、", "僕らが", "本当にどうしようもなく", "なったら．．．"]}, {"box": [618, 1205, 648, 1402], "vertical": true, "font_size": 26.0, "lines": ["その時は：：：．．．"]}], "img_path": "080.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [867, 99, 951, 330], "vertical": true, "font_size": 23.0, "lines": ["大切な人と", "青空の下、芝生の上に", "寝っころがってさ。"]}, {"box": [120, 36, 256, 67], "vertical": false, "font_size": 31.0, "lines": ["しかりのまち"]}, {"box": [636, 209, 755, 679], "vertical": true, "font_size": 22.0, "lines": ["「空が青いねぇ」とか", "見たまんまのこと", "なんでもないこと", "言っちゃったりして、", "だけど、すっごく", "幸せじゃねぇ？"]}, {"box": [353, 502, 407, 637], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．", "幸せだねぇ。"]}, {"box": [803, 808, 826, 941], "vertical": true, "font_size": 21.0, "lines": ["．．．タスクは"]}, {"box": [259, 862, 315, 1058], "vertical": true, "font_size": 24.0, "lines": ["ホントにあたしを", "好きなのかな？"]}, {"box": [159, 1287, 186, 1404], "vertical": true, "font_size": 25.0, "lines": ["．．．．．え？"]}], "img_path": "081.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [813, 138, 847, 289], "vertical": true, "font_size": 25.0, "lines": ["広ーーい！！"]}, {"box": [717, 306, 767, 473], "vertical": true, "font_size": 25.0, "lines": ["探せば見つかる", "もんだねーー！！"]}, {"box": [198, 270, 314, 615], "vertical": true, "font_size": 28.0, "lines": ["でももう", "真っ暗じゃん。", "１０時", "まわってるぜ？"]}, {"box": [916, 698, 940, 785], "vertical": true, "font_size": 24.0, "lines": ["疲れたー"]}, {"box": [821, 787, 883, 921], "vertical": true, "font_size": 24.0, "lines": ["足、すっごい", "．．．", "痛いー"]}, {"box": [654, 916, 741, 1088], "vertical": true, "font_size": 24.0, "lines": ["どーする？", "街戻って", "漫喫でも行く？"]}, {"box": [526, 722, 551, 846], "vertical": true, "font_size": 25.0, "lines": ["んー"]}, {"box": [116, 857, 200, 1027], "vertical": true, "font_size": 23.0, "lines": ["いいよ別に", "日が昇るまで", "ここで待とう？"]}, {"box": [125, 1116, 310, 1392], "vertical": true, "font_size": 27.0, "lines": ["．．．．．俺さぁ、", "前からしてみた", "かったんだよ。", "いや、", "ピクニック", "どうこうって話。"]}], "img_path": "082.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [788, 136, 818, 285], "vertical": true, "font_size": 27.0, "lines": ["見て、タスク。"]}, {"box": [887, 906, 944, 1111], "vertical": true, "font_size": 25.0, "lines": ["コレ、三ツ目の男に", "つけられたキズ。"]}, {"box": [630, 1214, 717, 1358], "vertical": true, "font_size": 27.0, "lines": ["もう一生", "消えないん", "だってさ．．．"]}, {"box": [384, 994, 529, 1293], "vertical": true, "font_size": 26.0, "lines": ["．．．．．ね？", "あたしもタスクも", "実はお互いのこと、", "よく知らない", "じゃん！"]}, {"box": [82, 1191, 199, 1381], "vertical": true, "font_size": 26.0, "lines": ["なのに、なんで", "タスクはあたしに", "やさしくできる", "かなぁ！？"]}], "img_path": "083.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [791, 55, 949, 422], "vertical": true, "font_size": 25.0, "lines": ["あっ、あたしさぁ、", "お母さんが死んだって", "聞いても．．", "全然悲しくなくて、", "むしろ「ざまみろ」", "とかって思って！"]}, {"box": [140, 22, 259, 58], "vertical": false, "font_size": 30.0, "lines": ["わかりのまち"]}, {"box": [834, 664, 860, 787], "vertical": true, "font_size": 22.0, "lines": ["．．．バッカ！！"]}, {"box": [516, 237, 682, 605], "vertical": true, "font_size": 25.0, "lines": ["ねっ！？", "ひくでしょ！？", "あたしって、こんな", "それでも", "女なんだよ！？", "好きだなんて", "言えるの！？"]}, {"box": [101, 441, 127, 570], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．！！"]}, {"box": [748, 767, 798, 911], "vertical": true, "font_size": 22.0, "lines": ["言えるよ！", "いくらでも！"]}, {"box": [167, 808, 234, 957], "vertical": true, "font_size": 29.0, "lines": ["好きだぜ、", "すっごく！！"]}, {"box": [841, 1093, 864, 1221], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．"]}, {"box": [584, 1096, 636, 1248], "vertical": true, "font_size": 24.0, "lines": ["．．．今日は", "もう寝ようぜ。"]}, {"box": [500, 1205, 553, 1354], "vertical": true, "font_size": 24.0, "lines": ["ホラ服着ろよ、", "カゼひくから。"]}, {"box": [281, 1113, 350, 1402], "vertical": true, "font_size": 25.0, "lines": ["．．．タスク、", "明日晴れると", "いいね．．．．．．"]}, {"box": [121, 1152, 208, 1420], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．正直、", "動揺した。", "なんだ、この感じは．．．？"]}], "img_path": "084.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [787, 148, 842, 255], "vertical": true, "font_size": 26.0, "lines": ["おーい、", "タスク？"]}, {"box": [545, 127, 574, 277], "vertical": true, "font_size": 24.0, "lines": ["い？", "おー"]}, {"box": [461, 388, 482, 519], "vertical": true, "font_size": 21.0, "lines": ["．．．．．．"]}, {"box": [885, 966, 911, 1135], "vertical": true, "font_size": 25.0, "lines": ["タスクッ．．．．．！！"]}, {"box": [630, 1006, 733, 1258], "vertical": true, "font_size": 28.0, "lines": ["夜分に", "すいません。", "警察です。"]}, {"box": [79, 1310, 106, 1441], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．．あっ。"]}], "img_path": "085.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [740, 83, 884, 335], "vertical": true, "font_size": 25.0, "lines": ["そりゃ違う環境で", "育ったんだから、", "知らないこともあるさ。", "．．．さっと時間が"]}, {"box": [620, 81, 885, 635], "vertical": true, "font_size": 24.0, "lines": ["その濤を埋めてくれる。"]}, {"box": [513, 70, 568, 264], "vertical": true, "font_size": 22.0, "lines": ["現実的に", "考えてみろ．．．．．．"]}, {"box": [157, 161, 189, 450], "vertical": true, "font_size": 29.0, "lines": ["．．．結局、金か．．．"]}, {"box": [617, 379, 731, 646], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．といっても", "僕たちにあと", "どれだけの時間が", "あるっていうんだろう？"]}, {"box": [286, 450, 402, 620], "vertical": true, "font_size": 24.0, "lines": ["見届け屋で", "稼いだ金なんて", "すぐに底をつく", "ぞ．．．．．．"]}, {"box": [661, 763, 687, 854], "vertical": true, "font_size": 23.0, "lines": ["タスクー"]}, {"box": [569, 854, 624, 1022], "vertical": true, "font_size": 23.0, "lines": ["まだ帰ってきて", "ないのかー", "！？"]}, {"box": [113, 1058, 139, 1182], "vertical": true, "font_size": 24.0, "lines": ["ん"]}], "img_path": "086.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [808, 66, 946, 446], "vertical": true, "font_size": 25.0, "lines": ["長谷川さん．．．", "．．．．．ははっ．．．．", "ごぶさたしてます。", "この街に住んで", "らしたんですか．．．"]}, {"box": [511, 105, 623, 324], "vertical": true, "font_size": 28.0, "lines": ["水谷．．．．．", "何してんだ、", "お前．．．．．．"]}, {"box": [338, 83, 398, 231], "vertical": true, "font_size": 25.0, "lines": ["何って、仕事", "ですよ、仕事。"]}, {"box": [202, 95, 316, 318], "vertical": true, "font_size": 25.0, "lines": ["クソ退屈な", "ド田舎からようやく", "この街へ配属に", "なったんです。"]}, {"box": [80, 470, 170, 680], "vertical": true, "font_size": 26.0, "lines": ["早いもんですねぇ。", "息子さん、確かもう", "小学６年生かぁ。"]}, {"box": [453, 1035, 478, 1158], "vertical": true, "font_size": 26.0, "lines": ["消えろ．．．"]}, {"box": [905, 1091, 932, 1210], "vertical": true, "font_size": 26.0, "lines": ["つっ．．．．．．！！"]}, {"box": [372, 1079, 403, 1251], "vertical": true, "font_size": 26.0, "lines": ["消えてくれ．．．"]}, {"box": [76, 1224, 158, 1368], "vertical": true, "font_size": 22.0, "lines": ["俺の前にもう", "二度と姿を", "見せるな．．．"]}], "img_path": "087.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [820, 71, 970, 435], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．ふふ。", "なーんか因果を", "感じちゃうなぁ。", "この街は", "不思議な場所だぁ。"]}, {"box": [403, 38, 554, 465], "vertical": true, "font_size": 24.0, "lines": ["早速、気になる", "事件がありましてね。", "この団地の自殺者全員の", "携帯電話が見つかって", "不自然でしょ？", "ないんですわ。"]}, {"box": [169, 211, 229, 501], "vertical": true, "font_size": 26.0, "lines": ["．．．知るか", "帰れ．．．"]}, {"box": [452, 495, 545, 694], "vertical": true, "font_size": 25.0, "lines": ["長谷川さん、", "どー思われます？", "元刑事として？"]}, {"box": [903, 997, 927, 1119], "vertical": true, "font_size": 24.0, "lines": ["タスク．．．"]}, {"box": [240, 1033, 299, 1214], "vertical": true, "font_size": 24.0, "lines": ["なーんか、", "雨降りそうだね。"]}, {"box": [54, 1089, 168, 1363], "vertical": true, "font_size": 24.0, "lines": ["駄目、駄目だ。", "な。", "ピクニックは", "晴れるまで", "おあずけ、な。"]}], "img_path": "088.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [826, 120, 885, 268], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．なんで", "名前を．．．．．．"]}, {"box": [231, 110, 318, 344], "vertical": true, "font_size": 25.0, "lines": ["いろいろと", "調べさしてもらった", "ぜぇ、タスクっち～～"]}, {"box": [83, 173, 200, 420], "vertical": true, "font_size": 25.0, "lines": ["前から気に", "なってたのよ。ネットで", "おもしろいことしてる", "奴がいるってよぉ。"]}, {"box": [781, 466, 898, 723], "vertical": true, "font_size": 25.0, "lines": ["「ひかりのまち」の外で", "仕事したしたってんで、", "俺のハートにビーンと", "きたのさ。"]}, {"box": [120, 476, 372, 855], "vertical": true, "font_size": 25.0, "lines": ["今日、", "俺がタスクっちに", "わざわざコンタクト", "かましたのは", "ほかでもねえ。", "自殺幇助なんて", "チンケな商売やめて", "俺と組もうぜ", "って話よ！？"]}, {"box": [645, 1176, 671, 1343], "vertical": true, "font_size": 20.0, "lines": ["おハロー、同志。"]}, {"box": [93, 1249, 152, 1419], "vertical": true, "font_size": 28.0, "lines": ["会いたかった", "ぜ〜〜〜～～～！！"]}], "img_path": "089.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [795, 124, 941, 398], "vertical": true, "font_size": 27.0, "lines": ["ハル子、", "俺、ちょっと", "用あるから、", "テキトーに", "ブラついてて。"]}, {"box": [644, 65, 709, 252], "vertical": true, "font_size": 30.0, "lines": ["えっ、", "あたしも行くよ。"]}, {"box": [369, 302, 456, 485], "vertical": true, "font_size": 24.0, "lines": ["いや、そっこーで", "すますから", "待ってろって。"]}, {"box": [254, 621, 500, 712], "vertical": false, "font_size": 27.0, "lines": ["屋上は改装中につき", "壁上は以来中にノロ関係者以外の立ち入り禁止"]}, {"box": [78, 343, 165, 508], "vertical": true, "font_size": 24.0, "lines": ["．．．タスク、", "一人にしないで", "よ．．．．．．"]}, {"box": [893, 728, 947, 953], "vertical": true, "font_size": 24.0, "lines": ["．．．．．ハイ、", "昨日のメールどおり、"]}, {"box": [804, 861, 857, 1007], "vertical": true, "font_size": 24.0, "lines": ["そこから", "飛び降りれば"]}, {"box": [775, 862, 859, 1018], "vertical": true, "font_size": 25.0, "lines": ["ほぼ確実です。"]}, {"box": [116, 860, 226, 1042], "vertical": true, "font_size": 21.0, "lines": ["それで、あの．．．", "再三確認して", "失礼なんですが"]}, {"box": [907, 1119, 932, 1215], "vertical": true, "font_size": 24.0, "lines": ["金だろ？"]}, {"box": [283, 1088, 339, 1277], "vertical": true, "font_size": 25.0, "lines": ["オッケーオッゲー", "ガッツリな！？"]}, {"box": [135, 1175, 254, 1391], "vertical": true, "font_size": 25.0, "lines": ["だから隠れてないで", "出てきな。", "長谷川タスク", "ちゃん！！"]}], "img_path": "090.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [764, 88, 960, 501], "vertical": true, "font_size": 24.0, "lines": ["タスクっち～～～", "人の生き死にって、", "とっても商売に", "俺たちって、", "なるよネ～～～", "ソレに気付いた", "お利口な人種", "だと思わない！？"]}, {"box": [107, 146, 221, 391], "vertical": true, "font_size": 24.0, "lines": ["俺のコネクションを", "使えば殴り屋から", "殺人代行まで、", "よりどりみどりだぜ！？"]}, {"box": [274, 623, 330, 748], "vertical": true, "font_size": 26.0, "lines": ["．．．どうだい", "やるかい？"]}, {"box": [806, 947, 922, 1137], "vertical": true, "font_size": 25.0, "lines": ["額のアザ、", "昔ハル子を", "メッタ刺しにした"]}, {"box": [668, 849, 696, 1021], "vertical": true, "font_size": 26.0, "lines": ["ひっひひっ．．．"]}, {"box": [109, 831, 248, 1279], "vertical": true, "font_size": 25.0, "lines": ["タスクッち～～", "もう一生、", "小学生のくせに", "人の死に囲まれて", "イイ目してるわ～～", "生きるタイプの", "目だぜ～～～！？"]}, {"box": [739, 949, 916, 1396], "vertical": true, "font_size": 25.0, "lines": ["三ツ目の男．．．．．．"]}, {"box": [733, 1163, 769, 1394], "vertical": true, "font_size": 30.0, "lines": ["う．．．こいつだ！！"]}], "img_path": "091.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [740, 326, 770, 405], "vertical": true, "font_size": 30.0, "lines": ["ひっ？"]}, {"box": [843, 638, 873, 763], "vertical": true, "font_size": 30.0, "lines": ["がっ．．．．！！"]}, {"box": [383, 498, 471, 695], "vertical": true, "font_size": 26.0, "lines": ["このクズ！", "ストーカー．．．", "死ねよ。"]}, {"box": [529, 930, 627, 1300], "vertical": true, "font_size": 24.0, "lines": ["はぁ？", "つーかタスクっち", "なんでそんなモン、", "持ってんのさ～～～？"]}, {"box": [146, 1228, 210, 1381], "vertical": true, "font_size": 29.0, "lines": ["．．．．．タスク、", "それ貸して。"]}], "img_path": "092.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [841, 82, 926, 303], "vertical": true, "font_size": 23.0, "lines": ["ちょっ、ちょつ！！", "ちょーっと冷静に", "なってみようか？"]}, {"box": [722, 161, 775, 387], "vertical": true, "font_size": 23.0, "lines": ["おじょーちゃん、ソレ", "逆恨みっスよ？"]}, {"box": [536, 61, 592, 88], "vertical": false, "font_size": 27.0, "lines": ["第２話"]}, {"box": [414, 101, 696, 126], "vertical": false, "font_size": 25.0, "lines": ["バスストップ・ＰＡＲＴＩ"]}, {"box": [190, 68, 334, 337], "vertical": true, "font_size": 25.0, "lines": ["もとはといえば、", "援交の真似事して", "ホテルから俺の金を", "持ち逃げした", "アンタが悪いわけっしょ？"]}, {"box": [133, 312, 161, 365], "vertical": true, "font_size": 25.0, "lines": ["ね？"]}, {"box": [0, 84, 64, 496], "vertical": true, "font_size": 32.0, "lines": ["のまた、"]}, {"box": [844, 419, 934, 701], "vertical": true, "font_size": 28.0, "lines": ["「大人なめんな」って", "ことで、ちょっと痛い目に", "あってもらったけど．．．"]}, {"box": [109, 506, 226, 825], "vertical": true, "font_size": 26.0, "lines": ["その程度で", "ね？", "すませた、俺の", "慈悲深い気持ちを", "汲もう？"]}, {"box": [563, 1089, 618, 1235], "vertical": true, "font_size": 23.0, "lines": ["．．．．．それでも", "撃ちますか？"]}, {"box": [488, 1267, 516, 1331], "vertical": true, "font_size": 28.0, "lines": ["ポッ"]}, {"box": [104, 1147, 137, 1403], "vertical": true, "font_size": 29.0, "lines": ["撃っちゃうんスか！？"]}], "img_path": "093.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [243, 107, 270, 278], "vertical": true, "font_size": 24.0, "lines": ["．．．ハル子．．．"]}, {"box": [774, 478, 953, 738], "vertical": true, "font_size": 24.0, "lines": ["ひひっ、なっ、", "なんだぁ？", "いつかの金", "持ち逃げした", "援交中学生じゃ", "ねえか〜〜〜っ"]}, {"box": [105, 625, 164, 773], "vertical": true, "font_size": 22.0, "lines": ["なんで、お前が", "いるのさ？"]}, {"box": [93, 945, 156, 1101], "vertical": true, "font_size": 26.0, "lines": ["．．．うるさい", "だまれ！！"]}, {"box": [868, 1098, 890, 1196], "vertical": true, "font_size": 22.0, "lines": ["．．．え？"]}, {"box": [330, 1247, 362, 1393], "vertical": true, "font_size": 30.0, "lines": ["．．．．．え？"]}], "img_path": "094.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [828, 686, 907, 1050], "vertical": true, "font_size": 28.0, "lines": ["やっべー", "あいつら", "超やっべー．．．"]}, {"box": [596, 817, 651, 965], "vertical": true, "font_size": 25.0, "lines": ["ふざけんなよ", "なぁ〜〜．．．"]}, {"box": [382, 1174, 501, 1383], "vertical": true, "font_size": 21.0, "lines": ["この俺が、あんな", "クソガキどもに", "なめられっぱなしな", "わけねぇぜ～～～？"]}, {"box": [85, 1144, 142, 1312], "vertical": true, "font_size": 23.0, "lines": ["．．．．．．やっぱ", "撃てないよ．．．"]}], "img_path": "095.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [523, 60, 707, 332], "vertical": true, "font_size": 24.0, "lines": ["なーんだろ．．．", "たとえ", "アイツが死んでも、", "あたしが何か", "変わるわけじゃ", "ないじゃん．．．"]}, {"box": [157, 32, 264, 62], "vertical": false, "font_size": 30.0, "lines": ["かりのまち"]}, {"box": [82, 237, 198, 630], "vertical": true, "font_size": 24.0, "lines": ["バっカみたいだぁ。", "アイツを見つけて", "えへへ．．．", "どうするつもり", "だったんだ、アタシ。"]}, {"box": [762, 707, 907, 1139], "vertical": true, "font_size": 24.0, "lines": ["．．．あたしにいろいろ", "聞きたいこと", "あるだろうけど、あたしも", "タスクに聞きたいこと", "いっぱいあるよ．．．"]}, {"box": [124, 1211, 150, 1410], "vertical": true, "font_size": 21.0, "lines": ["．．．ねぇ、タスク．．．"]}], "img_path": "096.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [820, 77, 877, 251], "vertical": true, "font_size": 32.0, "lines": ["深い沈黙を繰り返しながら、"]}, {"box": [819, 76, 876, 250], "vertical": true, "font_size": 24.0, "lines": ["深い沈黙を", "繰り返しながら、"]}, {"box": [659, 73, 772, 368], "vertical": true, "font_size": 24.0, "lines": ["それでも僕たちは", "今まで話すことのなかった", "自分のことを", "話し続けた。"]}, {"box": [454, 76, 539, 351], "vertical": true, "font_size": 24.0, "lines": ["雨音に", "かき消されそうなくらい", "小さな声で。"]}, {"box": [278, 73, 331, 240], "vertical": true, "font_size": 24.0, "lines": ["忘れかけていた", "昔の思い出"]}, {"box": [214, 73, 239, 199], "vertical": true, "font_size": 24.0, "lines": ["学校のこと、"]}, {"box": [140, 73, 168, 272], "vertical": true, "font_size": 24.0, "lines": ["家族のこと．．．"]}, {"box": [809, 438, 834, 580], "vertical": true, "font_size": 25.0, "lines": ["ねぇ、タスク。"]}, {"box": [708, 541, 765, 762], "vertical": true, "font_size": 25.0, "lines": ["なんでお友達と", "仲良くできないの？"]}, {"box": [209, 579, 296, 773], "vertical": true, "font_size": 26.0, "lines": ["ホラ、泣かないで。", "お母さんに", "言ってごらん？"]}, {"box": [931, 847, 956, 987], "vertical": true, "font_size": 24.0, "lines": ["．．．みんなが"]}, {"box": [825, 912, 906, 1133], "vertical": true, "font_size": 24.0, "lines": ["僕のこと", "人殺しの子供だって", "言うんだ．．．．．．"]}, {"box": [338, 832, 364, 1076], "vertical": true, "font_size": 21.0, "lines": ["．．．お父さんはね．．．"]}, {"box": [476, 1114, 560, 1320], "vertical": true, "font_size": 24.0, "lines": ["ねぇ、お母さん．．．", "お父さんは本当に", "人を殺したの？"]}, {"box": [99, 956, 228, 1381], "vertical": true, "font_size": 23.0, "lines": ["お友達を悪い人から", "助けるために", "仕方なく．．．", "．．．仕方なく", "そうしたのよ．．．"]}], "img_path": "097.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [728, 125, 798, 362], "vertical": true, "font_size": 30.0, "lines": ["「ひかりのまち」に", "帰ろう？"]}, {"box": [830, 688, 854, 867], "vertical": true, "font_size": 20.0, "lines": ["僕はハスの中で"]}, {"box": [761, 688, 785, 863], "vertical": true, "font_size": 24.0, "lines": ["見届け屋のこと、"]}, {"box": [665, 689, 717, 892], "vertical": true, "font_size": 22.0, "lines": ["ハル子の父親に", "してしまったこと、"]}, {"box": [592, 689, 621, 897], "vertical": true, "font_size": 29.0, "lines": ["すべてを明かした。"]}, {"box": [377, 685, 433, 889], "vertical": true, "font_size": 22.0, "lines": ["ハル子は二年前の", "ことを僕に語った。"]}, {"box": [277, 688, 332, 901], "vertical": true, "font_size": 23.0, "lines": ["三ツ目はストーカー", "ではなかったし、"]}, {"box": [150, 685, 235, 881], "vertical": true, "font_size": 26.0, "lines": ["僕だけでなく", "両親や警察にまで", "嘘をついていた。"]}, {"box": [236, 1241, 351, 1401], "vertical": true, "font_size": 24.0, "lines": ["もう僕らは", "きのうのように", "手を握ることは", "なかった。"]}, {"box": [134, 1214, 163, 1225], "vertical": false, "font_size": 12.0, "lines": ["．．．"]}], "img_path": "098.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [743, 160, 879, 426], "vertical": true, "font_size": 27.0, "lines": ["お母さん．．．", "それは", "いいことなの？", "悪いことなの？"]}, {"box": [734, 529, 851, 710], "vertical": true, "font_size": 24.0, "lines": ["僕が小四の時", "父は退職し、", "しばらくして", "母は事故死した。"]}, {"box": [532, 528, 617, 758], "vertical": true, "font_size": 25.0, "lines": ["本当ならその週末に", "家族でピクニックに", "行く予定だったのに。"]}, {"box": [159, 526, 425, 735], "vertical": true, "font_size": 24.0, "lines": ["家にこもるように", "なった父は、", "きっと今日も", "理科の教材です、と", "担任教師が", "置いていった", "プチトマトに、", "水をやり続けて", "いるんだろう。"]}, {"box": [832, 835, 962, 1411], "vertical": true, "font_size": 23.0, "lines": ["調べたらほんの", "拳銃持ったバカを", "数件だけどヒットしてさ、", "異奮させた、水合っていう", "刑事組員を射殺」", "同僚を救おうとした", "結果、らしい。"]}, {"box": [101, 998, 168, 1230], "vertical": true, "font_size": 31.0, "lines": ["朝日台ハイタウン", "入口ー"]}, {"box": [391, 1088, 421, 1233], "vertical": true, "font_size": 26.0, "lines": ["．．．バカだろ？"]}], "img_path": "099.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [784, 166, 814, 365], "vertical": true, "font_size": 23.0, "lines": ["じゃあね、タスク。"]}, {"box": [234, 309, 263, 398], "vertical": true, "font_size": 27.0, "lines": ["．．．おう。"]}, {"box": [741, 541, 826, 774], "vertical": true, "font_size": 26.0, "lines": ["いつもの", "「じゃあ、また明日」は", "もうない。"]}, {"box": [625, 541, 649, 699], "vertical": true, "font_size": 20.0, "lines": ["そりゃそうだ。"]}, {"box": [339, 542, 426, 734], "vertical": true, "font_size": 26.0, "lines": ["もうこのバス停に", "ハル子は来る", "必要がないし、"]}, {"box": [198, 535, 260, 720], "vertical": true, "font_size": 32.0, "lines": ["僕も", "来る必要はない。"]}, {"box": [478, 836, 623, 1115], "vertical": true, "font_size": 26.0, "lines": ["結局、僕たちは", "何をやっていたんだろう。", "結局「ひかりのまち」に", "戻ってきて、", "自分の部屋に戻る。"]}, {"box": [349, 1143, 466, 1365], "vertical": true, "font_size": 24.0, "lines": ["ここから僕たちは", "出ることはできない。", "そういうこと", "なんだろうか？"]}, {"box": [117, 1128, 152, 1362], "vertical": true, "font_size": 30.0, "lines": ["．．．タスクッ！！"]}], "img_path": "100.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [140, 39, 253, 79], "vertical": false, "font_size": 32.0, "lines": ["かりのまち"]}, {"box": [96, 430, 120, 605], "vertical": true, "font_size": 21.0, "lines": ["．．．タスク．．．．．"]}, {"box": [643, 995, 666, 1118], "vertical": true, "font_size": 21.0, "lines": ["もしもし？"]}, {"box": [274, 811, 316, 949], "vertical": true, "font_size": 28.0, "lines": ["ピビピピピ"]}, {"box": [549, 1067, 602, 1270], "vertical": true, "font_size": 23.0, "lines": ["．．．ごめんねタスク", "起こしちゃった？"]}, {"box": [73, 1080, 191, 1461], "vertical": true, "font_size": 25.0, "lines": ["ん．．．．．もう", "電話してくる", "昼かぁ？", "なんて、", "めずらしいじゃん。", "どうした？"]}], "img_path": "101.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [871, 118, 924, 266], "vertical": true, "font_size": 22.0, "lines": ["どこ行って", "たんだ．．．．．．"]}, {"box": [563, 213, 622, 410], "vertical": true, "font_size": 25.0, "lines": ["父さん心配した", "じゃないか．．．．．．"]}, {"box": [128, 485, 157, 621], "vertical": true, "font_size": 26.0, "lines": ["．．．何、ソレ？"]}, {"box": [843, 687, 926, 904], "vertical": true, "font_size": 24.0, "lines": ["Ｘｘｘｘのフリして", "今までさんざん", "放っておいて．．．．．．"]}, {"box": [732, 784, 797, 992], "vertical": true, "font_size": 24.0, "lines": ["．．．急に父親面", "すんなよなっ！"]}, {"box": [134, 755, 252, 1056], "vertical": true, "font_size": 32.0, "lines": ["意味わっかん", "ねーよ！！", "アホか。"]}, {"box": [326, 1099, 350, 1267], "vertical": true, "font_size": 25.0, "lines": ["もういいよ．．．"]}, {"box": [208, 1179, 266, 1368], "vertical": true, "font_size": 25.0, "lines": ["俺、疲れたから", "もう寝るよ．．．．．．"]}], "img_path": "102.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [739, 187, 790, 316], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．タスク", "屋上に来て。"]}, {"box": [816, 566, 934, 837], "vertical": true, "font_size": 25.0, "lines": ["．．．じゃあ、俺は直接", "長谷川宅に向かうから、", "お前はマンション周辺を", "当たってくれ。"]}, {"box": [666, 327, 692, 434], "vertical": true, "font_size": 26.0, "lines": ["仕事だよ。"]}, {"box": [662, 325, 690, 431], "vertical": true, "font_size": 22.0, "lines": ["仕事だよ。"]}, {"box": [121, 616, 239, 814], "vertical": true, "font_size": 24.0, "lines": ["．．．いいんスカ？", "水谷警部。", "こんな勝手な", "行動しちゃって？"]}, {"box": [856, 905, 943, 1087], "vertical": true, "font_size": 25.0, "lines": ["バカが。犯罪は", "早期発見、", "早期解決だろが。"]}, {"box": [476, 906, 591, 1084], "vertical": true, "font_size": 25.0, "lines": ["ラリった声の", "匿名電話なんて、", "信用できんのか", "なぁ．．．．．．？"]}, {"box": [668, 1251, 753, 1369], "vertical": true, "font_size": 27.0, "lines": ["それじゃあ", "病気じゃ", "ないスか。"]}, {"box": [95, 1221, 153, 1367], "vertical": true, "font_size": 24.0, "lines": ["うるせぇ！！", "ホラ行けよ！！"]}], "img_path": "103.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [888, 41, 944, 253], "vertical": true, "font_size": 25.0, "lines": ["．．．いろいろコレで", "つながるじゃんよ。"]}, {"box": [546, 62, 690, 312], "vertical": true, "font_size": 26.0, "lines": ["長谷川タスクは", "携帯電話を使い、", "「見届け屋」と呼ばれる", "自殺の手引きを", "商売としていた．．．"]}, {"box": [844, 632, 877, 698], "vertical": true, "font_size": 32.0, "lines": ["ハァ。"]}, {"box": [307, 210, 486, 556], "vertical": true, "font_size": 25.0, "lines": ["それを繰り返す", "過程で出会った", "柿澤の拳銃を", "持ち逃げした．．．", "．．．これも", "因果だねぇ。"]}, {"box": [767, 784, 805, 850], "vertical": true, "font_size": 32.0, "lines": ["ハァ。"]}, {"box": [154, 780, 243, 1127], "vertical": true, "font_size": 27.0, "lines": ["タスク、", "遅いよー", "待ちくたびれ", "ちゃった。"]}], "img_path": "104.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [806, 202, 900, 521], "vertical": true, "font_size": 27.0, "lines": ["．．．じゃあさ", "ハル子、", "こん中の銃、", "使うか？"]}, {"box": [569, 111, 653, 335], "vertical": true, "font_size": 25.0, "lines": ["そのかわり、", "俺を撃ってから", "自分でやってくれ？"]}, {"box": [231, 67, 287, 271], "vertical": true, "font_size": 25.0, "lines": ["辛そうなハル子を", "見るのはヤだけど、"]}, {"box": [98, 193, 186, 418], "vertical": true, "font_size": 25.0, "lines": ["ハル子が死ぬトコ", "なんて、見て", "らんないからさぁ！！"]}, {"box": [500, 464, 586, 657], "vertical": true, "font_size": 25.0, "lines": ["．．．あたしだって", "タスク撃てるわけ", "ないじゃん．．．．．．"]}, {"box": [781, 1214, 807, 1311], "vertical": true, "font_size": 26.0, "lines": ["はは．．．"]}, {"box": [696, 1262, 721, 1400], "vertical": true, "font_size": 26.0, "lines": ["あははっ！！"]}, {"box": [310, 1201, 343, 1287], "vertical": true, "font_size": 30.0, "lines": ["やばい。"]}, {"box": [149, 1232, 275, 1456], "vertical": true, "font_size": 30.0, "lines": ["こんな時に、すっげぇ", "くだらないこと", "思いついちゃったよ、", "俺！！"]}], "img_path": "105.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [837, 70, 942, 304], "vertical": true, "font_size": 27.0, "lines": ["ハル子ぉ．．．", "何やってん", "だよ．．．"]}, {"box": [213, 68, 244, 177], "vertical": true, "font_size": 27.0, "lines": ["へへ．．．．．．"]}, {"box": [98, 167, 183, 340], "vertical": true, "font_size": 27.0, "lines": ["飛び降りようと", "したら、腰が", "抜けちゃった。"]}, {"box": [855, 512, 942, 731], "vertical": true, "font_size": 24.0, "lines": ["．．．あたし、親戚に", "引き取られることに", "なるみたい。"]}, {"box": [207, 549, 239, 617], "vertical": true, "font_size": 26.0, "lines": ["はは。"]}, {"box": [97, 622, 183, 801], "vertical": true, "font_size": 26.0, "lines": ["いよいよ", "本格的に夢も", "チボーもないね。"]}, {"box": [723, 830, 938, 1202], "vertical": true, "font_size": 24.0, "lines": ["なんかイロイロ", "考えちゃってさ。", "あたしがしっかり", "してれば、お父さんも", "お母さんも、あんなことに", "ならなかったんじゃ", "ないか．．．．．．とか"]}, {"box": [204, 911, 357, 1282], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．でもあたしは", "もう無理だよ。", "だからタスク、", "ここからあたしの", "背中を押して？"]}, {"box": [453, 1063, 506, 1288], "vertical": true, "font_size": 22.0, "lines": ["今さら考えても", "しょうがないけどさ。"]}], "img_path": "106.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [775, 134, 834, 270], "vertical": true, "font_size": 26.0, "lines": ["．．．．．コレで", "決めようぜ。"]}, {"box": [533, 146, 623, 563], "vertical": true, "font_size": 26.0, "lines": ["ジェンガを崩して", "その後で", "負けたほうが", "自分を撃つ。", "相手の頭を撃つ。"]}, {"box": [313, 580, 444, 753], "vertical": true, "font_size": 25.0, "lines": ["俺らみたいな", "ダメ人間には、", "ちょうどいい", "テキトーな", "決め方じゃん？"]}, {"box": [699, 884, 719, 1048], "vertical": true, "font_size": 25.0, "lines": ["長谷川さん．．．"]}, {"box": [577, 960, 634, 1086], "vertical": true, "font_size": 25.0, "lines": ["なんの真似", "です．．．．．．？"]}, {"box": [114, 1037, 170, 1279], "vertical": true, "font_size": 25.0, "lines": ["早く息子さん", "出してくださいよ．．．"]}], "img_path": "107.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [847, 64, 936, 297], "vertical": true, "font_size": 26.0, "lines": ["．．．水合、だいたいは", "お前の想像どおり", "だよ。"]}, {"box": [740, 219, 823, 430], "vertical": true, "font_size": 26.0, "lines": ["ここにある", "ケータイを調べれば", "明らかだ．．．．．．"]}, {"box": [109, 68, 270, 456], "vertical": true, "font_size": 24.0, "lines": ["一連の自殺は", "別の人間によって", "計画的に実行された。", "つまり", "俺によって．．．"]}, {"box": [851, 522, 954, 714], "vertical": true, "font_size": 28.0, "lines": ["ハッ！！そんな", "見えすいた", "猿芝居！！"]}, {"box": [90, 589, 193, 794], "vertical": true, "font_size": 29.0, "lines": ["アンタ、息子の", "罪を被ろうって", "いうのか！？"]}, {"box": [861, 843, 951, 1069], "vertical": true, "font_size": 28.0, "lines": ["あのー．．．水谷警部、", "タスクくん、屋上に", "いましたけど？"]}, {"box": [475, 957, 539, 1295], "vertical": true, "font_size": 24.0, "lines": ["様子見て荷物", "わかった", "押収しろ。", "今、向かう。"]}, {"box": [75, 1208, 153, 1388], "vertical": true, "font_size": 32.0, "lines": ["．．．．．．待てっ、", "水谷．．．．．．"]}], "img_path": "108.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [791, 103, 894, 299], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}, {"box": [83, 132, 200, 293], "vertical": true, "font_size": 26.0, "lines": ["ちょっと", "このリュック、", "調べさせて", "くれるかな？"]}, {"box": [483, 412, 602, 623], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．", "あのー", "ごめんね、二人とも", "遊んでるところ", "悪いんだけど．．．"]}, {"box": [121, 1116, 203, 1292], "vertical": true, "font_size": 32.0, "lines": ["駄目っ！！", "タスクッ！！"]}], "img_path": "109.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [476, 156, 539, 328], "vertical": true, "font_size": 24.0, "lines": ["コレってもう", "詰みじゃねぇ？"]}, {"box": [90, 178, 142, 326], "vertical": true, "font_size": 22.0, "lines": ["もう動かせる", "とこないぜ？"]}, {"box": [672, 393, 702, 532], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．なあ。"]}, {"box": [395, 631, 418, 778], "vertical": true, "font_size": 20.0, "lines": ["．．．だよね．．．．．"]}, {"box": [801, 763, 930, 1279], "vertical": true, "font_size": 29.0, "lines": ["あははっ、", "俺ら", "なんだよ、この", "スゲェ！！", "超必死", "ちっちゃい", "じゃん！！", "奇跡！？"]}, {"box": [287, 861, 316, 999], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．はは。"]}, {"box": [392, 1095, 482, 1392], "vertical": true, "font_size": 24.0, "lines": ["ははっ！タスクっ！", "こういう場合は", "どーなの！？"]}, {"box": [70, 1012, 168, 1349], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．もう", "死ぬとか", "よくねぇ？", "そういうの", "やめようぜ？"]}], "img_path": "110.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [227, 479, 247, 580], "vertical": true, "font_size": 20.0, "lines": ["．．．え？"]}], "img_path": "111.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [771, 900, 886, 1177], "vertical": true, "font_size": 25.0, "lines": ["いろんなことが終わった。", "一度に終わりすぎて", "よくわからないくらいに", "すべてが終わった。"]}, {"box": [537, 896, 681, 1192], "vertical": true, "font_size": 25.0, "lines": ["いろいろなゴタゴタの中、", "知らない大人たちに囲まれ", "自分が小学生だと", "思い知らされる", "数週間が過ぎた。"]}, {"box": [280, 896, 423, 1185], "vertical": true, "font_size": 25.0, "lines": ["久しぶりに開いた", "パソコンの", "デクストップには、", "見慣れない文書ファイルが", "置かれていた。"]}, {"box": [430, 1281, 458, 1298], "vertical": false, "font_size": 17.0, "lines": ["．．．"]}, {"box": [97, 1195, 246, 1387], "vertical": true, "font_size": 25.0, "lines": ["「これをタスクが", "読んでいるという", "ことは、私はもう", "そこにいないの", "だろう」"]}], "img_path": "112.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [780, 77, 812, 270], "vertical": true, "font_size": 29.0, "lines": ["：：：朝が来る。"]}, {"box": [563, 171, 599, 433], "vertical": true, "font_size": 25.0, "lines": ["それでも朝が来る"]}, {"box": [847, 616, 933, 812], "vertical": true, "font_size": 24.0, "lines": ["ハル子ちゃん、", "引っ越しの荷物は", "もうそれだけ？"]}, {"box": [177, 203, 346, 600], "vertical": true, "font_size": 24.0, "lines": ["マスコミやら", "なんやらで、", "お偉いさんたちは", "もう水谷さん", "大騒ぎさ。", "戻ってこられない", "だろうなぁ。"]}, {"box": [920, 1044, 947, 1155], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．あ。"]}, {"box": [567, 1003, 599, 1213], "vertical": true, "font_size": 24.0, "lines": ["．．．何も言わないよ。"]}, {"box": [150, 729, 236, 925], "vertical": true, "font_size": 27.0, "lines": ["．．．．．ハイ。", "今ごろ親戚が駅で", "待ってます"]}, {"box": [463, 1160, 546, 1380], "vertical": true, "font_size": 24.0, "lines": ["うやむやにできる", "ようなこと、わざわざ", "振り返す必要ないし。"]}, {"box": [87, 1204, 176, 1440], "vertical": true, "font_size": 25.0, "lines": ["僕は「ひかりのまち」が", "平和なら、", "それでいいんだ。"]}], "img_path": "113.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [757, 52, 930, 330], "vertical": true, "font_size": 24.0, "lines": ["「タスクが何を", "していたかは、だいたい", "わかっているつもりだし、", "お前はそれを受け止めて", "生きなければ", "ならないと思う」"]}, {"box": [228, 95, 375, 339], "vertical": true, "font_size": 22.0, "lines": ["「しかし、誰が死のうが、", "私自身が死のうが、", "これ以上", "何かを失うのに、私は", "耐えられそうにない」"]}, {"box": [133, 450, 252, 679], "vertical": true, "font_size": 26.0, "lines": ["「間違いだらけの", "人生かもしれないが、", "今、私の気持ちは", "晴れやかだ」"]}, {"box": [830, 796, 889, 980], "vertical": true, "font_size": 25.0, "lines": ["「すまんタスク。", "父より」"]}, {"box": [475, 1199, 591, 1390], "vertical": true, "font_size": 26.0, "lines": ["見届け屋の事件は", "被疑者死亡で", "事実は", "闇の中だ．．．．．．"]}, {"box": [81, 1020, 110, 1193], "vertical": true, "font_size": 26.0, "lines": ["アホー．．．"]}, {"box": [176, 1201, 231, 1365], "vertical": true, "font_size": 26.0, "lines": ["これで", "よかったのか？"]}], "img_path": "114.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [658, 115, 799, 358], "vertical": true, "font_size": 26.0, "lines": ["あはは。", "タスク、", "似合わないねー", "ランドセル"]}, {"box": [282, 93, 400, 537], "vertical": true, "font_size": 25.0, "lines": ["ウチに来た", "せめて学校に", "叔母さん夫婦に、", "行くふりくらいは、", "なんか悪くてさ。", "ってな。"]}, {"box": [644, 407, 665, 504], "vertical": true, "font_size": 16.0, "lines": ["オリオの"]}, {"box": [209, 1280, 238, 1423], "vertical": true, "font_size": 25.0, "lines": ["ねぇ、タスク。"]}], "img_path": "115.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [883, 90, 939, 264], "vertical": true, "font_size": 24.0, "lines": ["またいつか", "ここで会おう？"]}, {"box": [297, 120, 383, 345], "vertical": true, "font_size": 24.0, "lines": ["たとえ僕が", "何年このバス停で", "待ち続けたとしても、"]}, {"box": [657, 340, 803, 585], "vertical": true, "font_size": 26.0, "lines": ["．．．．．僕は", "ベランダになっていた", "プチトマトの実を、", "ハル子にあげそびれて", "しまった。"]}, {"box": [111, 138, 371, 619], "vertical": true, "font_size": 24.0, "lines": ["ハル子ともう", "会うことはない。", "なぜだか"]}, {"box": [104, 431, 219, 616], "vertical": true, "font_size": 24.0, "lines": ["そんな気がした。"]}, {"box": [104, 1264, 129, 1358], "vertical": true, "font_size": 24.0, "lines": ["殺せば？"]}], "img_path": "116.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [], "img_path": "117.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [848, 110, 880, 269], "vertical": true, "font_size": 23.0, "lines": ["．．．．なんてね。"]}, {"box": [780, 251, 800, 360], "vertical": true, "font_size": 23.0, "lines": ["ウソウソ。"]}, {"box": [146, 186, 232, 415], "vertical": true, "font_size": 23.0, "lines": ["バスが走ってる限り、", "僕はどこにだって", "行けるんだ"]}, {"box": [375, 944, 495, 973], "vertical": false, "font_size": 26.0, "lines": ["岩間眼科"]}, {"box": [815, 1145, 841, 1321], "vertical": true, "font_size": 20.0, "lines": ["僕はバスに乗り、"]}, {"box": [742, 1140, 770, 1343], "vertical": true, "font_size": 24.0, "lines": ["行き先を確認して、"]}, {"box": [556, 1144, 643, 1312], "vertical": true, "font_size": 25.0, "lines": ["少し焦りながら", "算数の教科書を", "開いた。"]}, {"box": [184, 1146, 207, 1317], "vertical": true, "font_size": 20.0, "lines": ["今日も朝が来た。"]}], "img_path": "118.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [592, 386, 665, 594], "vertical": true, "font_size": 23.0, "lines": ["自分にないものを", "持っている誰か。"]}, {"box": [470, 388, 540, 690], "vertical": true, "font_size": 28.0, "lines": ["一生近づけないくらい", "その誰かが眩しくても．．．"]}, {"box": [345, 388, 416, 646], "vertical": true, "font_size": 25.0, "lines": ["その誰かにないものを", "自分は持っている。"]}], "img_path": "119.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [1, 75, 69, 482], "vertical": true, "font_size": 32.0, "lines": ["りのまも"]}, {"box": [795, 523, 860, 615], "vertical": true, "font_size": 32.0, "lines": ["あ、", "ネコだ。"]}, {"box": [873, 821, 937, 909], "vertical": true, "font_size": 32.0, "lines": ["ニャン", "ニャン。"]}, {"box": [779, 858, 840, 958], "vertical": true, "font_size": 16.0, "lines": ["できません"]}, {"box": [551, 793, 602, 969], "vertical": true, "font_size": 32.0, "lines": ["ニャッ！！"]}, {"box": [459, 858, 519, 958], "vertical": true, "font_size": 15.0, "lines": ["できません"]}, {"box": [156, 917, 211, 1166], "vertical": true, "font_size": 24.0, "lines": ["今日のあたしは", "ちょっと意地悪な気分。"]}], "img_path": "120.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [869, 120, 952, 281], "vertical": true, "font_size": 23.0, "lines": ["．．．とか、まー", "どーでも", "いいんだけど。"]}, {"box": [467, 112, 493, 222], "vertical": true, "font_size": 25.0, "lines": ["西山さん。"]}, {"box": [678, 384, 733, 545], "vertical": true, "font_size": 25.0, "lines": ["くそう、西日が", "まぶしいぜ。"]}, {"box": [429, 444, 457, 544], "vertical": true, "font_size": 27.0, "lines": ["はいっ！？"]}, {"box": [530, 643, 585, 825], "vertical": true, "font_size": 25.0, "lines": ["世界はいつか", "終わるんだって。"]}, {"box": [891, 1059, 917, 1147], "vertical": true, "font_size": 26.0, "lines": ["はぁ！？"]}, {"box": [158, 1198, 283, 1243], "vertical": false, "font_size": 27.0, "lines": ["第３話ＩＤＰａ"]}], "img_path": "121.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [445, 173, 516, 293], "vertical": true, "font_size": 25.666666666666668, "lines": ["リホ全か", "シ試とらに", "上追年か先る"]}, {"box": [321, 104, 435, 280], "vertical": true, "font_size": 24.0, "lines": ["つーかシャレに", "なんないし、", "まず問題が", "意味不明だから。"]}, {"box": [100, 374, 208, 739], "vertical": true, "font_size": 22.0, "lines": ["．．．ん？", "選択問題、勘で", "埋めただけだし。", "．．．やっぱいなぁ．．．"]}, {"box": [563, 876, 588, 997], "vertical": true, "font_size": 24.0, "lines": ["東さん．．．"]}, {"box": [419, 960, 503, 1161], "vertical": true, "font_size": 24.0, "lines": ["確か頭いい", "はずなのに．．．", "めーずらしーー．．．"]}], "img_path": "122.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [808, 98, 953, 409], "vertical": true, "font_size": 32.0, "lines": ["ナニ？", "何｀何、何！？", "バカ！？", "バカなの！？"]}, {"box": [124, 192, 210, 413], "vertical": true, "font_size": 22.0, "lines": ["うちのクラスに", "こんなふうに思考の", "不自由な人が！？"]}, {"box": [183, 561, 238, 740], "vertical": true, "font_size": 22.0, "lines": ["ＵＦＯさんが", "教えてくれたの。"]}, {"box": [788, 909, 848, 1146], "vertical": true, "font_size": 28.0, "lines": ["（なんか）", "ピッシー"]}, {"box": [564, 831, 681, 1051], "vertical": true, "font_size": 25.0, "lines": ["何それ、アンタ！？", "もしかしてそれ。", "自分がカワイイって", "思って言ってんの？"]}, {"box": [105, 894, 222, 1154], "vertical": true, "font_size": 24.0, "lines": ["不思議ちゃん発言で", "天然キャラ", "狙っちゃったりしてる！？", "いや、うざいから！！！"]}, {"box": [165, 1239, 218, 1368], "vertical": true, "font_size": 23.0, "lines": ["違うよー", "ホントだよ"]}], "img_path": "123.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [874, 80, 928, 308], "vertical": true, "font_size": 22.0, "lines": ["よく会うんだもん。", "それでお話しするの。"]}, {"box": [445, 216, 519, 455], "vertical": true, "font_size": 32.0, "lines": ["ギャーーッ！！", "むかつくーーっ！！"]}, {"box": [181, 115, 327, 364], "vertical": true, "font_size": 26.0, "lines": ["なんか", "すっげー", "こういう奴の化けの皮", "『スルズルにはがして", "やりてぇ！！"]}, {"box": [825, 513, 884, 687], "vertical": true, "font_size": 25.0, "lines": ["じゃあさ！！", "じゃあ東さん！！"]}, {"box": [373, 532, 560, 889], "vertical": true, "font_size": 24.0, "lines": ["世界が終わんなら、", "こんな追試", "テキトーに切り上げ", "ちゃってさぁ、", "あたしもその", "ＵＦＯさんトコに", "連れてってよ！！"]}, {"box": [490, 1019, 516, 1141], "vertical": true, "font_size": 26.0, "lines": ["いいよー"]}, {"box": [452, 1268, 508, 1372], "vertical": true, "font_size": 24.0, "lines": ["うっ．．．", "即答だよ。"]}, {"box": [193, 1015, 339, 1254], "vertical": true, "font_size": 26.0, "lines": ["つーか、あたしの", "答案どうすんだ。", "〈まぁ、いくら考えても", "できないもんは", "できないんだけど"]}, {"box": [92, 1195, 118, 1383], "vertical": true, "font_size": 20.0, "lines": ["西山さん、あのね。"]}], "img_path": "124.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [931, 130, 960, 277], "vertical": true, "font_size": 25.0, "lines": ["ふーーん．．．"]}, {"box": [815, 162, 900, 409], "vertical": true, "font_size": 25.0, "lines": ["あたしのお父さん。", "アンタんとこの工場に", "勤めてたよ。"]}, {"box": [910, 616, 935, 734], "vertical": true, "font_size": 26.0, "lines": ["わかった！！"]}, {"box": [391, 366, 484, 539], "vertical": true, "font_size": 25.0, "lines": ["この前リストラ", "されちゃった", "けどサ！"]}, {"box": [752, 674, 868, 890], "vertical": true, "font_size": 26.0, "lines": ["もしＵＦＯに", "会えなくて、", "アンタの言うことが", "インチキだったら、"]}, {"box": [869, 1038, 903, 1121], "vertical": true, "font_size": 31.0, "lines": ["いいよ"]}, {"box": [143, 712, 258, 921], "vertical": true, "font_size": 26.0, "lines": ["お父さんを", "会社に戻してって", "アンタのパパに", "言ってもらうから。"]}, {"box": [442, 1240, 508, 1384], "vertical": true, "font_size": 32.0, "lines": ["少しは", "困れよっ！！"]}, {"box": [94, 1217, 148, 1363], "vertical": true, "font_size": 22.0, "lines": ["西山さんって", "やさしいのね。"]}], "img_path": "125.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [823, 108, 941, 310], "vertical": true, "font_size": 29.0, "lines": ["あたし前から", "西山さんって、", "素敵って思ってた", "のね。"]}, {"box": [312, 77, 367, 227], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．あぁ、", "皮肉っスか！！"]}, {"box": [88, 301, 113, 426], "vertical": true, "font_size": 25.0, "lines": ["違うよー"]}, {"box": [563, 512, 650, 692], "vertical": true, "font_size": 23.0, "lines": ["．．．まぁ、確かに", "足長くて細くて", "黒髪サラサラで"]}, {"box": [104, 535, 216, 754], "vertical": true, "font_size": 22.0, "lines": ["あたしが男だったら", "好きになるかも。", "せめてもうちょい", "まともなら。"]}, {"box": [715, 762, 931, 1058], "vertical": true, "font_size": 26.0, "lines": ["そういえば", "東さんの家って、", "チョー金持ちって", "誰か言ってたけど、", "お父さん", "何やってる人", "なの？"]}, {"box": [291, 758, 477, 1118], "vertical": true, "font_size": 25.0, "lines": ["んーと、街のはずれに", "大きな薬品工場が", "あるのね。", "そこの一番", "エライ人なんだって、", "パパ言ってた。"]}, {"box": [89, 1039, 176, 1368], "vertical": true, "font_size": 26.0, "lines": ["それって", "えっ！？", "ヒカリグループの", "薬品工場のこと？"]}], "img_path": "126.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [854, 82, 941, 311], "vertical": true, "font_size": 22.0, "lines": ["．．．．．．べっつに、", "そんなんじゃないよ、", "言ってみただけ。"]}, {"box": [510, 110, 597, 300], "vertical": true, "font_size": 25.0, "lines": ["あたしは一人でも", "生きてける自信", "あるもん。"]}, {"box": [105, 274, 191, 446], "vertical": true, "font_size": 24.0, "lines": ["あたし、早く", "自立したいヒト", "だからさ。"]}, {"box": [648, 413, 765, 635], "vertical": true, "font_size": 24.0, "lines": ["実は親が", "どうなったところで", "関係ないって", "思ってるし。"]}, {"box": [757, 849, 932, 1287], "vertical": true, "font_size": 27.0, "lines": ["つーか、", "あたしんちの", "すっごい近く", "ー、何アンタ", "なんだけど！", "一人でこんなところ", "来てんの！？"]}, {"box": [117, 1211, 204, 1360], "vertical": true, "font_size": 22.0, "lines": ["あー、微妙に", "あたしの部屋", "見える。"]}], "img_path": "127.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [831, 121, 917, 339], "vertical": true, "font_size": 23.0, "lines": ["ここで待ってれば", "そのうちＵＦＯさん", "来るよ！"]}, {"box": [626, 80, 655, 239], "vertical": true, "font_size": 28.0, "lines": ["．．．ふっふっ♪。"]}, {"box": [526, 191, 582, 317], "vertical": true, "font_size": 28.0, "lines": ["東さん、", "知ってる？"]}, {"box": [70, 250, 183, 457], "vertical": true, "font_size": 24.0, "lines": ["この前自殺した", "Ｆ組の女の子、", "この場所から", "飛び降りたんだよ。"]}, {"box": [545, 515, 598, 696], "vertical": true, "font_size": 22.0, "lines": ["うん、きのう", "ここで会ったよ。"]}, {"box": [107, 605, 166, 775], "vertical": true, "font_size": 28.0, "lines": ["今度は", "ユーレイすか！！"]}, {"box": [498, 838, 582, 1042], "vertical": true, "font_size": 26.0, "lines": ["生まれ変わるなら", "キレイな鳥が", "いいって言ってた。"]}, {"box": [759, 1042, 941, 1358], "vertical": true, "font_size": 24.0, "lines": ["なーんじゃそりゃ、", "ずいぶん前向きな", "幽霊だな、オイ。", "死人ならもっと", "しおらしくして", "ほしーよ。"]}, {"box": [99, 959, 222, 1364], "vertical": true, "font_size": 23.0, "lines": ["人生に負けた奴に", "来世決める資格", "なんてないわ。", "ふざけんなって", "言っといて。"]}], "img_path": "128.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [835, 102, 951, 324], "vertical": true, "font_size": 26.0, "lines": ["一度エッチしたら", "次の日から毎日毎日", "まーいにち、", "やりたがってさ。"]}, {"box": [731, 196, 788, 387], "vertical": true, "font_size": 26.0, "lines": ["なんかむかついて", "フッてやった。"]}, {"box": [259, 107, 288, 284], "vertical": true, "font_size": 25.0, "lines": ["むずかしいのね。"]}, {"box": [174, 240, 202, 374], "vertical": true, "font_size": 23.0, "lines": ["そーなのよ。"]}, {"box": [769, 902, 826, 1025], "vertical": true, "font_size": 25.0, "lines": ["西山さん", "泣いてる？"]}, {"box": [324, 967, 351, 1122], "vertical": true, "font_size": 24.0, "lines": ["泣いてないよ。"]}, {"box": [615, 1233, 733, 1421], "vertical": true, "font_size": 26.0, "lines": ["もし仮に今、", "ＵＦＯが現れたら", "どうしよう、と", "ふと思う。"]}, {"box": [453, 1233, 539, 1421], "vertical": true, "font_size": 25.0, "lines": ["どこか遠くへ", "連れてってほしい", "気もするけど、"]}, {"box": [312, 1231, 365, 1445], "vertical": true, "font_size": 20.0, "lines": ["連れてかれたくない", "気もする"]}], "img_path": "129.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [783, 392, 878, 740], "vertical": true, "font_size": 25.0, "lines": ["セックス", "したことある？", "ねぇ", "西山さん"]}, {"box": [891, 982, 916, 1152], "vertical": true, "font_size": 20.0, "lines": ["．．．気持ちいい？"]}, {"box": [594, 1009, 618, 1153], "vertical": true, "font_size": 26.0, "lines": ["．．．", "まぁねー"]}, {"box": [157, 731, 181, 857], "vertical": true, "font_size": 24.0, "lines": ["あるよー"]}, {"box": [495, 1125, 555, 1209], "vertical": true, "font_size": 26.0, "lines": ["．．．でも", "なんか、"]}, {"box": [95, 1113, 210, 1350], "vertical": true, "font_size": 23.0, "lines": ["きのう別れた彼氏も", "するまでは、", "チョー気ィ使って", "やさしかったんだけど、"]}], "img_path": "130.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [467, 83, 492, 176], "vertical": true, "font_size": 25.0, "lines": ["ごめん"]}, {"box": [315, 129, 401, 349], "vertical": true, "font_size": 25.0, "lines": ["いつもはＵＦＯさん", "来るんだよ、", "ホントだよ。"]}, {"box": [71, 419, 186, 629], "vertical": true, "font_size": 24.0, "lines": ["いいって最初から", "期待してないから。", "お父さんの話も", "冗談だからね。"]}, {"box": [741, 637, 887, 868], "vertical": true, "font_size": 28.0, "lines": ["ハイ。", "追試サボらせ", "ちゃったお詫びって", "ことで。"]}, {"box": [854, 929, 913, 1116], "vertical": true, "font_size": 25.0, "lines": ["．．．西山さんこそ", "追試、平気なの？"]}, {"box": [389, 978, 534, 1385], "vertical": true, "font_size": 24.0, "lines": ["ま、多少成績", "卒業したら都心の", "悪くても別に。", "専門学校行って、", "一人暮らしして、", "服飾の勉強するから、"]}, {"box": [107, 1221, 160, 1350], "vertical": true, "font_size": 23.0, "lines": ["すごいのね", "西山さんは"]}], "img_path": "131.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [781, 102, 927, 444], "vertical": true, "font_size": 24.0, "lines": ["どこが？", "そんなヤツ", "星の数ほどいて、", "星の数ほど", "挫折してくんだし。"]}, {"box": [526, 87, 641, 319], "vertical": true, "font_size": 25.0, "lines": ["ホントは大昔、", "雑誌のモデルとか", "夢見てたけど。", "チビで足太いくせに。"]}, {"box": [74, 133, 186, 338], "vertical": true, "font_size": 24.0, "lines": ["家が金持ちで", "モデル体型の", "アンタが", "うらやましいもん。"]}, {"box": [541, 466, 595, 613], "vertical": true, "font_size": 24.0, "lines": ["そんなこと", "ないよ"]}, {"box": [88, 508, 202, 738], "vertical": true, "font_size": 24.0, "lines": ["ウチのバパ厳しいし", "勉強勉強って", "そればっかりで、", "つまんないよ。"]}, {"box": [823, 986, 938, 1154], "vertical": true, "font_size": 25.0, "lines": ["もしや", "今日追試", "受けてたのって", "わざと．．．．．"]}, {"box": [138, 1223, 166, 1353], "vertical": true, "font_size": 25.0, "lines": ["．．．そっか。"]}], "img_path": "132.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [922, 1113, 948, 1257], "vertical": true, "font_size": 26.0, "lines": ["すご．．．"]}, {"box": [441, 1254, 498, 1383], "vertical": true, "font_size": 26.0, "lines": ["．．．ちょっと", "違うけどっ。"]}], "img_path": "133.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [867, 267, 921, 463], "vertical": true, "font_size": 24.0, "lines": ["そういえばあたし", "子供の頃、"]}, {"box": [701, 422, 841, 621], "vertical": true, "font_size": 24.0, "lines": ["ブランコって", "思いっきり漕げば", "逆上がりみたく", "一回転できると", "思っててさぁ、"]}, {"box": [449, 323, 565, 541], "vertical": true, "font_size": 25.0, "lines": ["チョーがんばったり", "したけど、", "あの頃は子供", "だったなぁ。"]}, {"box": [121, 334, 143, 456], "vertical": true, "font_size": 20.0, "lines": ["できるよ！！"]}, {"box": [154, 521, 213, 655], "vertical": true, "font_size": 28.0, "lines": ["あはは、", "無理でしょ。"]}, {"box": [860, 720, 884, 843], "vertical": true, "font_size": 23.0, "lines": ["あははは！"]}, {"box": [747, 783, 830, 916], "vertical": true, "font_size": 23.0, "lines": ["東さん、ソレ", "漕ぎすぎ", "だから！！"]}, {"box": [160, 963, 217, 1059], "vertical": true, "font_size": 27.0, "lines": ["つーか、", "危な．．．．．"]}], "img_path": "134.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [859, 120, 919, 268], "vertical": true, "font_size": 26.0, "lines": ["ほらっ、", "西山さんも！！"]}, {"box": [772, 672, 856, 803], "vertical": true, "font_size": 25.0, "lines": ["．．．うふふ、", "西山さん、", "知ってる？"]}, {"box": [218, 692, 305, 913], "vertical": true, "font_size": 26.0, "lines": ["あたしたちもうすぐ", "大人になっちゃうん", "だって。"]}, {"box": [165, 889, 192, 1036], "vertical": true, "font_size": 25.0, "lines": ["知ってるよ！"]}, {"box": [790, 1151, 848, 1282], "vertical": true, "font_size": 28.0, "lines": ["上がったり、", "下がったり、"]}, {"box": [664, 1153, 721, 1263], "vertical": true, "font_size": 26.0, "lines": ["回ったり、", "跳んだり、"]}, {"box": [500, 1151, 586, 1331], "vertical": true, "font_size": 25.0, "lines": ["明日のあたしは", "きっといい気分。", "希望含む"]}, {"box": [307, 1126, 360, 1272], "vertical": true, "font_size": 24.0, "lines": ["西山さん", "泣いてるの？"]}, {"box": [199, 1176, 227, 1355], "vertical": true, "font_size": 25.0, "lines": ["泣いてないって。"]}], "img_path": "135.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [], "img_path": "136.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [768, 132, 854, 313], "vertical": true, "font_size": 25.0, "lines": ["ーんじゃ", "コレが今回の", "報酬ってコトで"]}, {"box": [124, 154, 299, 576], "vertical": true, "font_size": 26.0, "lines": ["．．．つーかよぉ、", "もっとガバッと", "。コピーソフト販売。", "稼げねぇもんかね。", "女の幹旋、", "ハッパの転売、", "なんか細くねぇ？"]}, {"box": [748, 352, 774, 487], "vertical": true, "font_size": 20.0, "lines": ["す", "うぃー"]}, {"box": [787, 591, 923, 917], "vertical": true, "font_size": 27.0, "lines": ["芳一、お前さ．．．", "最近、拍車をかけて", "釜、金、金って．．．", "金の虫な。"]}, {"box": [840, 988, 925, 1227], "vertical": true, "font_size": 24.0, "lines": ["やめくけやめとけ。", "お前、馬鹿じゃんよ。", "一人じゃ失敗するぜ？"]}, {"box": [67, 670, 251, 961], "vertical": true, "font_size": 29.0, "lines": ["俺のドリームを", "実現させるには、", "足踏みしてる時間は", "ねぇのさ", "俺ぁ", "動くぜ。"]}, {"box": [263, 1035, 463, 1410], "vertical": true, "font_size": 25.0, "lines": ["いや、でもネットで", "おもしれぇ商売", "してるガキがいてよ。", "うまく利用すりゃ、", "新機軸な商売が", "できるかもってな．．．"]}], "img_path": "137.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [564, 367, 636, 590], "vertical": true, "font_size": 25.0, "lines": ["何かを攻める人、", "何かから逃げる人。"]}, {"box": [483, 370, 513, 606], "vertical": true, "font_size": 24.0, "lines": ["互いを繋ぐのは．．．"]}, {"box": [356, 370, 431, 622], "vertical": true, "font_size": 28.0, "lines": ["それぞれのやさしさと", "守るべき人。"]}], "img_path": "138.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [722, 520, 809, 698], "vertical": true, "font_size": 25.0, "lines": ["６月某日、", "桃子と散歩中、", "突然の土砂降り。"]}, {"box": [626, 517, 681, 734], "vertical": true, "font_size": 25.0, "lines": ["あわててスーパーに", "逃げ込んだ。"]}, {"box": [448, 515, 534, 745], "vertical": true, "font_size": 25.0, "lines": ["そろそろ梅雨が来て、", "梅雨が明ければ", "もう夏だ。"]}, {"box": [238, 511, 354, 708], "vertical": true, "font_size": 26.0, "lines": ["スーパーの店頭に", "桃が並んでいて、", "その値段に", "驚いてしまう。"]}, {"box": [891, 759, 951, 917], "vertical": true, "font_size": 26.0, "lines": ["ほら桃子、", "桃が売ってる。"]}, {"box": [919, 1016, 978, 1170], "vertical": true, "font_size": 25.0, "lines": ["言ってごらん、", "「もも」って。"]}, {"box": [598, 777, 623, 862], "vertical": true, "font_size": 23.0, "lines": ["ははは。"]}, {"box": [599, 778, 622, 862], "vertical": true, "font_size": 23.0, "lines": ["ははは。"]}, {"box": [501, 846, 555, 1001], "vertical": true, "font_size": 23.0, "lines": ["桃と桃子。", "ももとももこ。"]}, {"box": [310, 833, 398, 1086], "vertical": true, "font_size": 23.0, "lines": ["いつでも桃が食べられる", "という人間の技術に"]}, {"box": [309, 830, 335, 1047], "vertical": true, "font_size": 24.0, "lines": ["改めて感心しつつも、"]}, {"box": [444, 1246, 483, 1405], "vertical": true, "font_size": 30.0, "lines": ["う。", "だー"]}, {"box": [153, 1098, 208, 1356], "vertical": true, "font_size": 24.0, "lines": ["夏が来る前に桃を食べる", "必要性について"]}, {"box": [123, 1091, 211, 1354], "vertical": true, "font_size": 25.0, "lines": ["少し考えてしまう。"]}], "img_path": "139.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [864, 100, 952, 279], "vertical": true, "font_size": 26.0, "lines": ["雨あがらないし", "夕飯の材料", "買っちゃおう。"]}, {"box": [323, 108, 408, 367], "vertical": true, "font_size": 24.0, "lines": ["ところで数えてみると、", "僕がこの街にやってきて", "今年で５回目の夏。"]}, {"box": [138, 111, 195, 284], "vertical": true, "font_size": 25.0, "lines": ["月日が経つのは", "実に早いものだ。"]}, {"box": [423, 425, 505, 622], "vertical": true, "font_size": 23.0, "lines": ["そろそろあいつも", "帰ってくる頃", "だろうし"]}, {"box": [277, 939, 311, 1144], "vertical": true, "font_size": 30.0, "lines": ["ただいま"]}], "img_path": "140.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [862, 82, 948, 338], "vertical": true, "font_size": 22.0, "lines": ["うえっ、なんだよコレ？", "耳裂けちゃってる", "じゃんか！！"]}, {"box": [533, 88, 621, 295], "vertical": true, "font_size": 25.0, "lines": ["サトシ、元医大生の", "力でちゃちゃっと", "元に戻してくれよ。"]}, {"box": [200, 158, 288, 393], "vertical": true, "font_size": 26.0, "lines": ["無理だよ、そんなの！！", "芳一、病院へ", "行こう？"]}, {"box": [83, 327, 172, 485], "vertical": true, "font_size": 25.0, "lines": ["バーカ、", "行けるワケ", "ねーだろって。"]}, {"box": [290, 655, 351, 751], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．芳一", "お前ね、"]}, {"box": [832, 849, 945, 1100], "vertical": true, "font_size": 24.0, "lines": ["でもあんまり", "危ないことやってると、", "いまに絶対くだらない", "死に方すると思うよ。"]}, {"box": [134, 674, 252, 849], "vertical": true, "font_size": 27.0, "lines": ["外でどんな仕事", "やってるかは、", "あえて俺は", "聞かないよ？"]}, {"box": [274, 938, 299, 1059], "vertical": true, "font_size": 25.0, "lines": ["ガキども？"]}, {"box": [624, 1127, 737, 1324], "vertical": true, "font_size": 24.0, "lines": ["いや、だから俺も", "下請けから、", "人を使う身に", "なろうと思ってな。"]}, {"box": [473, 1163, 589, 1428], "vertical": true, "font_size": 24.0, "lines": ["ビジネスチャンスと", "思って誘ってやったのに、", "あのガキども、", "ワケわかんねぇぜ。"]}, {"box": [73, 1190, 156, 1387], "vertical": true, "font_size": 24.0, "lines": ["．．．．．つーかホント、", "芳一は金儲けしか", "頭にないのな。"]}], "img_path": "141.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [823, 181, 848, 289], "vertical": true, "font_size": 24.0, "lines": ["おかえり"]}, {"box": [663, 943, 893, 1011], "vertical": false, "font_size": 25.0, "lines": ["第４話", "ＨＯＮＩＦＰＡＲＴ"]}, {"box": [198, 838, 287, 1059], "vertical": true, "font_size": 26.0, "lines": ["おいおい芳一、", "一週間ぶりに帰って", "きたと思ったら．．．"]}, {"box": [111, 926, 164, 1103], "vertical": true, "font_size": 26.0, "lines": ["どうしたんだよ、", "そのケガ！？"]}, {"box": [568, 1143, 625, 1290], "vertical": true, "font_size": 25.0, "lines": ["ひっひ。油断", "したぜぇ～～"]}, {"box": [84, 1191, 168, 1427], "vertical": true, "font_size": 24.0, "lines": ["サトシー", "ちょっくら手当てして", "やってくれよ。"]}], "img_path": "142.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [745, 49, 973, 551], "vertical": true, "font_size": 28.0, "lines": ["あっっったりまえ", "だろがよ！！", "金い、金！！全！！金！？", "お金大好き！！", "金のためなら", "なんだってできる", "ね、俺は！！"]}, {"box": [218, 205, 275, 378], "vertical": true, "font_size": 25.0, "lines": ["こらこら", "暴れんなって！！"]}, {"box": [306, 522, 423, 765], "vertical": true, "font_size": 25.0, "lines": ["．．．あのな、", "サトシのような", "欲のない奴に、", "生きる資格はねぇぞ？"]}, {"box": [134, 316, 192, 513], "vertical": true, "font_size": 25.0, "lines": ["ほらぁ、", "みそ汁こほれた！！"]}, {"box": [175, 591, 262, 811], "vertical": true, "font_size": 25.0, "lines": ["お前は食って", "寝るだけのために、", "生まれてきたのか！？"]}, {"box": [868, 789, 952, 994], "vertical": true, "font_size": 23.0, "lines": ["芳一は大げさだよ。", "生活できれば", "それでいいじゃん。"]}, {"box": [90, 883, 274, 1343], "vertical": true, "font_size": 26.0, "lines": ["．．．けっ。", "ところで", "今月の月謝", "お前とこの手の", "出せよ。", "言い合いは、", "もう飽きたよ。", "ハイハイ。"]}, {"box": [631, 1193, 775, 1391], "vertical": true, "font_size": 23.0, "lines": ["だいたい芳一", "パソコンにしか、", "金使わないじゃん。", "金貯めてどうする", "つもりなのさ？"]}], "img_path": "143.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [867, 113, 930, 249], "vertical": true, "font_size": 30.0, "lines": ["．．．ゴメン、", "ない。"]}, {"box": [512, 61, 547, 200], "vertical": true, "font_size": 32.0, "lines": ["ヴェッ！？"]}, {"box": [70, 92, 254, 518], "vertical": true, "font_size": 23.0, "lines": ["あぁ〜〜ダメだ、", "サトシ、お前は", "ダメ彦さんだ。", "お前こそ、", "俺がいなかったら", "とっくに", "野垂れ死んでるよ！！"]}, {"box": [626, 300, 712, 524], "vertical": true, "font_size": 24.0, "lines": ["この前言ったじゃん。", "バイト先のパチ屋が", "潰れたって。"]}, {"box": [508, 430, 591, 624], "vertical": true, "font_size": 23.0, "lines": ["だったらソッコー", "次探して金作れ", "アホかっ！！"]}, {"box": [771, 745, 825, 960], "vertical": true, "font_size": 22.0, "lines": ["もーいい、サトシ、", "フロ沸かせ！！"]}, {"box": [214, 844, 270, 990], "vertical": true, "font_size": 26.0, "lines": ["おい桃子、", "フロ入るぞ！！"]}, {"box": [732, 1132, 817, 1368], "vertical": true, "font_size": 25.0, "lines": ["この街の中心地である", "「ひかりのまち」から", "車でＩＯ分ほどの、"]}, {"box": [615, 1133, 699, 1365], "vertical": true, "font_size": 25.0, "lines": ["特筆すべきことのない", "地味な住宅地の", "小さな借家。"]}, {"box": [495, 1133, 579, 1345], "vertical": true, "font_size": 25.0, "lines": ["そこで僕は、", "芳一と桃子の三人で", "共同生活をしている。"]}, {"box": [176, 1128, 381, 1377], "vertical": true, "font_size": 27.0, "lines": ["そもそもは", "なんのあてもなく", "田舎から上京してきた", "僕を、", "テンピラから芳一が", "救ってくれたことが", "すべての始まりだった。"]}], "img_path": "144.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [834, 196, 930, 452], "vertical": true, "font_size": 29.0, "lines": ["ーで、ほどなくして", "やっぱりその女は", "どこかへ消えた。"]}, {"box": [621, 98, 709, 297], "vertical": true, "font_size": 29.0, "lines": ["．．．．．．．．置いて", "逃げると思ってた", "ぜぇ、俺は。"]}, {"box": [102, 166, 203, 555], "vertical": true, "font_size": 25.0, "lines": ["思い当たるフシ", "俺ら、", "ありありだし", "どっちかの子供", "なんだろうな"]}, {"box": [815, 566, 903, 793], "vertical": true, "font_size": 23.0, "lines": ["とりあえず", "名前決めなきゃだな。", "「あ」でいいか。"]}, {"box": [659, 652, 778, 802], "vertical": true, "font_size": 24.0, "lines": ["いや芳一", "もうちょっと", "真面目に", "考えようよ！！"]}, {"box": [586, 350, 684, 476], "vertical": true, "font_size": 31.0, "lines": ["ど、ど、", "どうしよう", "芳一！？"]}, {"box": [410, 598, 464, 768], "vertical": true, "font_size": 27.0, "lines": ["そんなこんなで", "もう５年"]}, {"box": [315, 599, 376, 770], "vertical": true, "font_size": 27.0, "lines": ["いろいろあった", "ような、"]}, {"box": [260, 601, 285, 780], "vertical": true, "font_size": 27.0, "lines": ["何もないような。"]}, {"box": [343, 887, 378, 1059], "vertical": true, "font_size": 32.0, "lines": ["確かに、"]}, {"box": [847, 1135, 932, 1395], "vertical": true, "font_size": 26.0, "lines": ["僕はいったい", "こんなところで", "何をしているんだろう？"]}, {"box": [281, 1100, 309, 1280], "vertical": true, "font_size": 25.0, "lines": ["おーい、サトシ！！"]}, {"box": [168, 1193, 225, 1408], "vertical": true, "font_size": 25.0, "lines": ["湯が冷めないうちに", "お前もフロ入れよ。"]}], "img_path": "145.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [881, 95, 966, 280], "vertical": true, "font_size": 25.0, "lines": ["あ？別にお前を", "助ける気なんて", "ないない。"]}, {"box": [707, 231, 853, 478], "vertical": true, "font_size": 25.0, "lines": ["ただ、お前の", "坊ちゃん坊ちャんした", "顔立ちからして", "ゆすれば金になると", "思ったワケ。"]}, {"box": [217, 74, 334, 292], "vertical": true, "font_size": 26.0, "lines": ["とんだカン違い", "だったよ。無一文の", "クズ野郎だもん", "なあ。"]}, {"box": [840, 576, 924, 749], "vertical": true, "font_size": 21.0, "lines": ["流れて僕は", "この家に居座る", "ようになったが"]}, {"box": [140, 287, 197, 493], "vertical": true, "font_size": 24.0, "lines": ["ーと、いうのは", "のちのち聞いた話"]}, {"box": [123, 591, 269, 812], "vertical": true, "font_size": 25.0, "lines": ["この家には", "芳一が気まぐれで", "拾ってきたであろう", "水商売ふうの", "無口な女がいた。"]}, {"box": [808, 867, 923, 1113], "vertical": true, "font_size": 25.0, "lines": ["ところがしばらくして", "姿を見せなくなり、", "一年ほどして突然", "現れたかと思うと、"]}, {"box": [511, 940, 636, 1277], "vertical": true, "font_size": 26.0, "lines": ["アノネ", "コノ子ネ", "タブンアンタラ", "ドッチカノ子", "ダカラ。"]}, {"box": [131, 1202, 185, 1344], "vertical": true, "font_size": 24.0, "lines": ["ーそれが", "桃子だった。"]}], "img_path": "146.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [846, 112, 932, 294], "vertical": true, "font_size": 25.0, "lines": ["まぁ、湯舟に", "桃子のウンコが", "浮いてるけどな。"]}, {"box": [472, 111, 621, 416], "vertical": true, "font_size": 25.0, "lines": ["「えぇっ！？」", "じゃねー", "桃子のしつけは", "テメーの仕事、", "だろがよ！！"]}, {"box": [344, 19, 407, 146], "vertical": true, "font_size": 32.0, "lines": ["オラオン"]}, {"box": [89, 139, 115, 297], "vertical": true, "font_size": 25.0, "lines": ["わめてやめて。"]}, {"box": [686, 522, 714, 640], "vertical": true, "font_size": 26.0, "lines": ["えぇっ！？"]}, {"box": [230, 393, 250, 545], "vertical": true, "font_size": 23.0, "lines": ["．．．まぁいい。"]}, {"box": [71, 464, 184, 711], "vertical": true, "font_size": 23.0, "lines": ["ビール冷やして", "あんだろ？", "フロあがったら今日は", "飲んで寝ようぜ？"]}, {"box": [832, 838, 860, 972], "vertical": true, "font_size": 25.0, "lines": ["．．．．．うん"]}, {"box": [478, 1031, 502, 1208], "vertical": true, "font_size": 28.0, "lines": ["こんな生活も"]}, {"box": [479, 1031, 506, 1216], "vertical": true, "font_size": 27.0, "lines": ["こんな生活も。"]}, {"box": [567, 1029, 595, 1234], "vertical": true, "font_size": 28.0, "lines": ["いいじゃないか、"]}, {"box": [564, 1029, 595, 1232], "vertical": true, "font_size": 28.0, "lines": ["いいじゃないか、"]}], "img_path": "147.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [780, 864, 924, 1080], "vertical": true, "font_size": 25.0, "lines": ["七月菜日", "今年は記録的な", "猛暑らしく", "うだるような暑さが", "続いている。"]}, {"box": [460, 907, 579, 1113], "vertical": true, "font_size": 26.0, "lines": ["いいか桃子！！", "人間ってのは", "幸せになるために", "生きてるんだぜぇ。"]}, {"box": [603, 877, 917, 1414], "vertical": true, "font_size": 32.0, "lines": ["はあはははいはいないのではないでしょうがないというわけでもいいこともありませんでした。それはどうしようと思うことがありそうだけど．．．これを見ているのかもしれないましたした"]}, {"box": [603, 1149, 812, 1405], "vertical": true, "font_size": 23.0, "lines": ["ところが蝉の声が", "あまり聞こえないことに", "ふと気付く。", "このあまりの暑さに、", "土の中の幼虫たちも", "外に出るのを躊躇", "してるのかもしれない。"]}, {"box": [95, 910, 232, 1407], "vertical": true, "font_size": 24.0, "lines": ["で、その幸せに", "なんせ金は、", "欠かせないものが", "人の幸せ度を計れる", "金！！金なワケさ！！", "人間が作った近代的な", "システムだからな！！"]}], "img_path": "148.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [857, 156, 916, 361], "vertical": true, "font_size": 25.0, "lines": ["両親はすでに", "他界しているとか"]}, {"box": [454, 107, 580, 338], "vertical": true, "font_size": 30.0, "lines": ["ひょっとしたら", "もうすでに", "何人か殺して", "いるのかもしれな"]}, {"box": [133, 41, 250, 67], "vertical": false, "font_size": 26.0, "lines": ["わかりのまち"]}, {"box": [146, 110, 262, 277], "vertical": true, "font_size": 28.0, "lines": ["ただそれは", "僕がどうこう", "言える問題じゃ", "ない。"]}, {"box": [725, 281, 813, 510], "vertical": true, "font_size": 29.0, "lines": ["怪しい", "犯罪グループに", "所属しているとか、"]}, {"box": [627, 563, 692, 781], "vertical": true, "font_size": 28.0, "lines": ["演然と聞いただけで", "詳細はわからない。"]}, {"box": [781, 878, 866, 1070], "vertical": true, "font_size": 24.0, "lines": ["そもそも", "芳一の金に対する", "執着の理由は？"]}, {"box": [609, 877, 699, 1095], "vertical": true, "font_size": 26.0, "lines": ["こんな退屈な街に", "住み続けているのは", "なぜ？"]}, {"box": [400, 878, 428, 1104], "vertical": true, "font_size": 24.0, "lines": ["．．．わからないけれど"]}, {"box": [159, 878, 277, 1094], "vertical": true, "font_size": 23.0, "lines": ["ただ言えるのは", "彼は彼の自由の中で", "生きている", "ってことだ"]}, {"box": [281, 1170, 366, 1369], "vertical": true, "font_size": 24.0, "lines": ["いや、だからね、", "株ってのはもう", "精神の話なんだよ。"]}, {"box": [143, 1243, 227, 1456], "vertical": true, "font_size": 24.0, "lines": ["目先の欲に", "目がくらんだ奴から", "負けていくの！"]}], "img_path": "149.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [704, 78, 938, 396], "vertical": true, "font_size": 25.0, "lines": ["ただ、人には", "大金を持つ器の奴と、", "そうじゃない奴が", "いるのな。", "金を守るのに", "必死な", "成金野郎たちの", "なんと醜いこと"]}, {"box": [186, 101, 267, 382], "vertical": true, "font_size": 24.0, "lines": ["金はあくまで", "幸せにつっ走るための", "ガソリンでしかないのよ。"]}, {"box": [825, 556, 881, 714], "vertical": true, "font_size": 24.0, "lines": ["んー", "．．．．．", "ルックルッグ。"]}, {"box": [74, 309, 161, 505], "vertical": true, "font_size": 32.0, "lines": ["使ってやることが金に対する本当の愛っつーの？"]}, {"box": [74, 310, 158, 505], "vertical": true, "font_size": 24.0, "lines": ["使ってやることが", "金に対する本当の", "愛っつーの？"]}, {"box": [229, 571, 320, 737], "vertical": true, "font_size": 27.0, "lines": ["モモーコ。", "リピート・", "アフター・ミー、"]}, {"box": [843, 886, 927, 1057], "vertical": true, "font_size": 23.0, "lines": ["おーい芳一．．．", "桃子に変なこと", "教えるなよ．．．"]}, {"box": [509, 889, 597, 1045], "vertical": true, "font_size": 26.0, "lines": ["文句言うなよ。", "じゃ、俺、仕事", "だから。"]}, {"box": [161, 667, 187, 824], "vertical": true, "font_size": 27.0, "lines": ["「お金大好き」"]}, {"box": [89, 923, 204, 1263], "vertical": true, "font_size": 25.0, "lines": ["おうおう、", "行ってこい。", "そして死ぬほど", "働いてこい。"]}, {"box": [601, 1214, 721, 1370], "vertical": true, "font_size": 26.0, "lines": ["うぇえ。", "またソーメン。", "もういいよ、", "ソーメンは。"]}, {"box": [326, 1191, 412, 1381], "vertical": true, "font_size": 23.0, "lines": ["ーーところで", "僕は芳一のことを", "よく知らない"]}], "img_path": "150.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [847, 108, 963, 302], "vertical": true, "font_size": 25.0, "lines": ["くぁー", "ーっ！！", "またやっちゃんの", "株式講座が", "始まったよ！"]}, {"box": [667, 129, 722, 314], "vertical": true, "font_size": 32.0, "lines": ["おっ、新入り、おつかれーーい。"]}, {"box": [659, 126, 722, 313], "vertical": true, "font_size": 26.0, "lines": ["おっ、新入り、", "おつかれーーい。"]}, {"box": [554, 184, 609, 341], "vertical": true, "font_size": 26.0, "lines": ["．．．そうだ、", "聞いたぜ。"]}, {"box": [152, 88, 239, 286], "vertical": true, "font_size": 26.0, "lines": ["兄ちゃん、医大の", "学生さんだったん", "だってな。"]}, {"box": [239, 422, 268, 582], "vertical": true, "font_size": 27.0, "lines": ["はは．．．．．．ええ。"]}, {"box": [121, 516, 208, 715], "vertical": true, "font_size": 27.0, "lines": ["でもひと月で", "やめちゃいました", "けどね"]}, {"box": [860, 724, 945, 875], "vertical": true, "font_size": 26.0, "lines": ["なーんでよ？", "もったいねぇ", "なぁ～～"]}, {"box": [510, 840, 632, 1345], "vertical": true, "font_size": 26.0, "lines": ["．．．．．僕の", "最近医療ミスって", "父親も医者", "よくあるじゃないですか。", "だったんですけど。", "父がそれに", "巻き込まれちゃって。"]}, {"box": [148, 1111, 235, 1340], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．なんか、", "バカバカしくなって。", "そーゆうの"]}], "img_path": "151.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [236, 240, 267, 478], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．違うだろ？"]}, {"box": [811, 621, 835, 798], "vertical": true, "font_size": 23.0, "lines": ["父親の荒れ方や、"]}, {"box": [721, 618, 775, 837], "vertical": true, "font_size": 23.0, "lines": ["罪をなすりつけ合う", "大人たちを見て、"]}, {"box": [394, 619, 448, 813], "vertical": true, "font_size": 22.0, "lines": ["自分が傷つくのが", "怖いんだろう？"]}, {"box": [171, 620, 287, 807], "vertical": true, "font_size": 21.0, "lines": ["昔から僕は", "嫌なことから", "逃げるくせがある", "だろう？"]}, {"box": [815, 927, 888, 1174], "vertical": true, "font_size": 32.0, "lines": ["いまだに僕は", "逃げてばかりいる。"]}, {"box": [628, 619, 679, 853], "vertical": true, "font_size": 23.0, "lines": ["世の中に出ていくのが", "怖くなったんだろう？"]}, {"box": [532, 881, 618, 1102], "vertical": true, "font_size": 25.0, "lines": ["す．．．すいません、", "なんか湿っぽく", "なっちゃいました？"]}, {"box": [100, 881, 183, 1100], "vertical": true, "font_size": 23.0, "lines": ["気にしないで", "ください！", "昔のことですから！！"]}, {"box": [685, 1222, 709, 1309], "vertical": true, "font_size": 22.0, "lines": ["．．あ"]}, {"box": [480, 1139, 568, 1376], "vertical": true, "font_size": 24.0, "lines": ["．．．．．それより、", "やっさんの株の話、", "聞かせてくださいよ！！"]}, {"box": [223, 1166, 249, 1262], "vertical": true, "font_size": 24.0, "lines": ["．．．おっ！？"]}, {"box": [90, 1209, 171, 1372], "vertical": true, "font_size": 24.0, "lines": ["じゃあ俺、", "久々に熱く", "語っちゃうよ！？"]}], "img_path": "152.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [780, 178, 895, 376], "vertical": true, "font_size": 23.0, "lines": ["あいつら、", "産業廃棄物を", "丘の上に不法投票", "してやがるのさ。"]}, {"box": [246, 168, 302, 338], "vertical": true, "font_size": 26.0, "lines": ["ふざけた話だと", "思わねぇか？"]}, {"box": [96, 324, 215, 530], "vertical": true, "font_size": 26.0, "lines": ["自分らで", "買い上げた土地を、", "今度は自分らで", "汚してるんだぜ？"]}, {"box": [826, 937, 944, 1214], "vertical": true, "font_size": 24.0, "lines": ["．．．ま、土地が汚れようが", "俺らに関係ないが、", "とにかくカードは", "そろったってこと。"]}, {"box": [492, 941, 578, 1186], "vertical": true, "font_size": 25.0, "lines": ["お前、最近", "カッツリ稼ぎたいって", "言ってたもんな"]}, {"box": [184, 665, 272, 877], "vertical": true, "font_size": 26.0, "lines": ["．．．そういや、", "今年はあんまり", "螺が鳴かねぇなぁ。"]}, {"box": [112, 1081, 172, 1345], "vertical": true, "font_size": 24.0, "lines": ["．．．その社長さんから", "いくらゆすれると思う？"]}], "img_path": "153.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [917, 58, 943, 256], "vertical": true, "font_size": 24.0, "lines": ["おっハロー同志！！"]}, {"box": [833, 253, 887, 403], "vertical": true, "font_size": 24.0, "lines": ["どうしたよ、", "急な話って？"]}, {"box": [585, 67, 675, 276], "vertical": true, "font_size": 28.0, "lines": ["へっへ、なかなかの", "おもしろニュース", "だぜ"]}, {"box": [459, 299, 626, 512], "vertical": true, "font_size": 32.0, "lines": ["きっちの部屋は俺は何年も"]}, {"box": [326, 367, 440, 588], "vertical": true, "font_size": 24.0, "lines": ["俺らの顧客リストを", "調べてたら、", "とんだお偉いさんが", "混じってたのよ。"]}, {"box": [104, 427, 127, 559], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．ふうん"]}, {"box": [758, 602, 973, 1032], "vertical": true, "font_size": 25.0, "lines": ["あの有明系企業の", "ヒカリグループがこの街の", "経済の大部分を占めてる", "のは知ってるだろ？", "なんせ「ひかりのまち」の", "住民の４割は", "その企業の関係者たぜ。"]}, {"box": [103, 795, 218, 1050], "vertical": true, "font_size": 24.0, "lines": ["その系列の薬品工場の", "社長さんが、俺らから", "女を買ってコマしてたっ", "つーワケよ！！"]}, {"box": [847, 1119, 934, 1312], "vertical": true, "font_size": 24.0, "lines": ["そいつが", "隠し資産", "どっちゃりとか？"]}, {"box": [735, 1182, 813, 1352], "vertical": true, "font_size": 24.0, "lines": ["なんかピンと", "こねぇなぁ、", "話がでかすぎて。"]}, {"box": [114, 1182, 228, 1426], "vertical": true, "font_size": 25.0, "lines": ["いや、それもある", "かもしれないが、", "俺のリサーチの結果、", "こんな事実が出てきた。"]}], "img_path": "154.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [807, 159, 867, 357], "vertical": true, "font_size": 26.0, "lines": ["．．．で、俺は", "何をすればいい？"]}, {"box": [162, 162, 353, 481], "vertical": true, "font_size": 26.0, "lines": ["社長さんの", "通勤経路を", "調査してくれ", "詳しい内容は", "後でメールで", "送る。"]}, {"box": [898, 898, 929, 1012], "vertical": true, "font_size": 31.0, "lines": ["．．．．．．へっ。"]}, {"box": [584, 1135, 668, 1337], "vertical": true, "font_size": 25.0, "lines": ["いつ来ても", "イライラするぜ、", "「ひかりのまち」は。"]}], "img_path": "155.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [917, 147, 942, 295], "vertical": true, "font_size": 24.0, "lines": ["じゃーねー"]}, {"box": [717, 297, 827, 327], "vertical": false, "font_size": 20.0, "lines": ["これからロシーミナルＣＤ一朝日台バスセンター"]}, {"box": [626, 130, 684, 286], "vertical": true, "font_size": 25.0, "lines": ["バイバー", "また明日。"]}, {"box": [529, 241, 578, 343], "vertical": true, "font_size": 26.0, "lines": ["また明日"]}, {"box": [835, 622, 864, 771], "vertical": true, "font_size": 26.0, "lines": ["うぁぅあ！！"]}, {"box": [111, 397, 168, 617], "vertical": true, "font_size": 24.0, "lines": ["おい俺んちで", "プレステやんねぇ？"]}, {"box": [840, 887, 928, 1206], "vertical": true, "font_size": 24.0, "lines": ["おお？", "なんだよ桃子、", "お前もあいつらと", "遊びたいってか？"]}, {"box": [168, 722, 208, 884], "vertical": true, "font_size": 32.0, "lines": ["だー"]}, {"box": [449, 1130, 564, 1344], "vertical": true, "font_size": 24.0, "lines": ["だめだめ、", "こんな街の", "連中といたら脳ミツ", "腐っちまうぜぇ。"]}], "img_path": "156.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [787, 123, 872, 369], "vertical": true, "font_size": 24.0, "lines": ["．．．誰ももう", "覚えちゃいねぇが、", "「ひかりのまち」だって、"]}, {"box": [678, 309, 761, 513], "vertical": true, "font_size": 24.0, "lines": ["２０年前は", "朝日村っていう", "ド田舎だったのさ。"]}, {"box": [140, 174, 352, 606], "vertical": true, "font_size": 24.0, "lines": ["俺はガキの頃、", "この場所でフツーの", "田舎のガキとして", "暮らしてたんだ。", "あのよくわかんねぇ", "会社が進出してくる", "まではよ！"]}, {"box": [745, 613, 966, 916], "vertical": true, "font_size": 25.0, "lines": ["無理矢理士地を", "買い上げて、", "地面ほじくり返して、", "工場やらビルやら", "マンションやら．．．", "馬鹿みたいに", "おっ建てて、"]}, {"box": [164, 739, 254, 995], "vertical": true, "font_size": 26.0, "lines": ["友達も学校も、", "山も川もぜーんぶ", "どっかに消えちまった。"]}, {"box": [621, 1213, 737, 1424], "vertical": true, "font_size": 26.0, "lines": ["オヤジもオフクロも", "土地成金になって、", "頭がぶっ壊れち", "まった。"]}, {"box": [67, 1051, 218, 1406], "vertical": true, "font_size": 25.0, "lines": ["．．．それがなんだ。", "今度は虫も", "住めねぇような", "場所にする", "つもりってか？"]}], "img_path": "157.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [858, 416, 883, 544], "vertical": true, "font_size": 25.0, "lines": ["．．．ひひっ、"]}, {"box": [754, 485, 810, 655], "vertical": true, "font_size": 25.0, "lines": ["奇遇じゃん、", "タスクっち．．．"]}, {"box": [522, 949, 589, 1063], "vertical": true, "font_size": 32.0, "lines": ["．．．へっ、", "そうかい。"]}, {"box": [870, 1132, 929, 1322], "vertical": true, "font_size": 25.0, "lines": ["おーい、タスク", "何やってんだよ？"]}, {"box": [598, 1219, 658, 1366], "vertical": true, "font_size": 30.0, "lines": ["早く", "行こーぜー"]}, {"box": [280, 1176, 407, 1405], "vertical": true, "font_size": 26.0, "lines": ["お前もこの歪んだ街の", "ただの住人に", "なり下がっちまった", "か！"]}, {"box": [81, 1181, 108, 1404], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．ふざけやがって。"]}], "img_path": "158.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [891, 189, 947, 313], "vertical": true, "font_size": 25.0, "lines": ["桃子よぉ！", "俺はな、"]}, {"box": [750, 346, 863, 547], "vertical": true, "font_size": 25.0, "lines": ["とんでもない", "金持ちになって", "「ひかりのまち」を", "買い戻して．．．"]}, {"box": [152, 349, 240, 569], "vertical": true, "font_size": 26.0, "lines": ["ここを元の", "朝日村に戻すことが", "夢なんだぜぇ。"]}, {"box": [796, 677, 964, 984], "vertical": true, "font_size": 26.0, "lines": ["．．．バカだろう？", "バカなんだよ、俺。", "でも本気", "なんだから", "しょうがねぇ。"]}, {"box": [139, 797, 257, 993], "vertical": true, "font_size": 24.0, "lines": ["それがどんだけ", "不可能でどんだけ", "無意味なこと", "だとしても。"]}, {"box": [433, 1068, 655, 1390], "vertical": true, "font_size": 25.0, "lines": ["．．．ひひっ、", "ま、サトシに", "こんなこと", "言えないけどよ。", "あいつは", "俺と違って", "冷静な男たからな。"]}, {"box": [145, 1110, 170, 1331], "vertical": true, "font_size": 21.0, "lines": ["ーその日の夜"]}], "img_path": "159.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [813, 124, 870, 214], "vertical": true, "font_size": 26.0, "lines": ["桃子ぉー", "芳ーぃー"]}, {"box": [691, 261, 774, 422], "vertical": true, "font_size": 26.0, "lines": ["ただいまぁ。", "ゴメン、こんな", "遅くなって。"]}, {"box": [135, 27, 263, 74], "vertical": false, "font_size": 32.0, "lines": ["わかりのまち"]}, {"box": [124, 168, 239, 437], "vertical": true, "font_size": 24.0, "lines": ["結局僕は、", "職場の先輩の株の話に", "深夜までつき合わされて", "しまった。"]}, {"box": [532, 1016, 864, 1175], "vertical": false, "font_size": 32.0, "lines": ["諦め時に起こしてな。まぁ", "われたからもうねるで！！"]}, {"box": [674, 1138, 761, 1185], "vertical": false, "font_size": 30.0, "lines": ["だったら"]}, {"box": [194, 1039, 392, 1282], "vertical": true, "font_size": 26.0, "lines": ["しかし先輩が言うには", "株はインターネットで", "簡単にできるらしく、", "それなら僕にでも、と", "少しだけ興味が湧いた", "のだ。"]}, {"box": [87, 1211, 171, 1397], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．芳一、", "ちょっとパソコン", "借りるぞ。"]}], "img_path": "160.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [866, 145, 922, 316], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．社長を", "拉致して恐喝？"]}, {"box": [0, 94, 57, 508], "vertical": true, "font_size": 32.0, "lines": ["のまた、"]}, {"box": [133, 415, 234, 809], "vertical": true, "font_size": 26.0, "lines": ["できっこ", "ないよ．．．．．．", "無茶だよ", "そんなの．．．"]}], "img_path": "161.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [891, 98, 946, 267], "vertical": true, "font_size": 24.0, "lines": ["．．．うへぇ．．．．．", "汚いなぁ．．．"]}, {"box": [804, 190, 858, 410], "vertical": true, "font_size": 24.0, "lines": ["言えば俺が掃除", "してやるのに．．．．．．"]}, {"box": [120, 168, 266, 463], "vertical": true, "font_size": 25.0, "lines": ["触るのなんて、いったい", "何年振りだろうと", "思いながら、", "僕はパソコンのモニターを", "のぞき込んだ。"]}, {"box": [366, 377, 425, 536], "vertical": true, "font_size": 29.0, "lines": ["．．．あ、", "メール来てる。"]}, {"box": [738, 617, 803, 880], "vertical": true, "font_size": 26.0, "lines": ["そして目に", "飛び込んできたのは"]}, {"box": [233, 927, 258, 1050], "vertical": true, "font_size": 24.0, "lines": ["．．．何これ？"]}, {"box": [553, 1076, 616, 1345], "vertical": true, "font_size": 28.0, "lines": ["悲しいくらい無謀な", "犯行の計画書だった。"]}], "img_path": "162.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [890, 110, 948, 255], "vertical": true, "font_size": 25.0, "lines": ["．．．あ、芳一、", "起きたんだ。"]}, {"box": [517, 102, 608, 285], "vertical": true, "font_size": 27.0, "lines": ["暑くって", "寝てらんねぇぜ、", "まったくよぉ。"]}, {"box": [96, 442, 180, 652], "vertical": true, "font_size": 24.0, "lines": ["だからクーラー", "直してって前から", "言ってるじゃんか。"]}, {"box": [860, 711, 881, 814], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．まぁ、"]}, {"box": [763, 799, 826, 944], "vertical": true, "font_size": 27.0, "lines": ["まぁ", "そのうち、な。"]}, {"box": [275, 1013, 332, 1136], "vertical": true, "font_size": 28.0, "lines": ["．．．．．あのさ", "芳一．．．"]}, {"box": [175, 1158, 263, 1384], "vertical": true, "font_size": 25.0, "lines": ["今度の仕事、", "サトシにも手伝って", "もらうかもしれねぇ。"]}], "img_path": "163.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [854, 526, 937, 719], "vertical": true, "font_size": 21.0, "lines": ["．．．おっと、お前は", "拒否れる立場じゃ", "ねぇからな。"]}, {"box": [253, 511, 362, 698], "vertical": true, "font_size": 23.0, "lines": ["まぁそろそろ", "腹くくって俺らの", "世界にどっぷり", "浸かっちまえよ。"]}, {"box": [144, 591, 230, 810], "vertical": true, "font_size": 23.0, "lines": ["くすぶってる時間は", "もうオシマイ、", "ってことで。"]}, {"box": [289, 850, 346, 1080], "vertical": true, "font_size": 25.0, "lines": ["オイ、桃子にちゃんと", "布団かけてやれよ。"]}, {"box": [867, 1057, 942, 1367], "vertical": true, "font_size": 28.0, "lines": ["やるときや", "今がその時", "やれ。", "だから。"]}, {"box": [224, 1275, 462, 1342], "vertical": false, "font_size": 25.0, "lines": ["第４話", "ＨＣＭＥ，ＰＡＲＴＩ"]}, {"box": [141, 1009, 256, 1202], "vertical": true, "font_size": 25.0, "lines": ["今日は俺、自分の", "部屋で寝るから、", "ちゃんと朝６時に", "起こせよな。"]}], "img_path": "164.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [851, 76, 936, 307], "vertical": true, "font_size": 23.0, "lines": ["おっせーよ、サトシ！！", "腹減ったから", "マッハで飯作れ！！"]}, {"box": [551, 88, 641, 242], "vertical": true, "font_size": 25.0, "lines": ["しっかし桃子、", "全然言葉", "覚えねぇのな。"]}, {"box": [683, 538, 708, 685], "vertical": true, "font_size": 21.0, "lines": ["．．．あ、悪い。"]}, {"box": [324, 277, 412, 489], "vertical": true, "font_size": 25.0, "lines": ["いつまでたっても", "アーとかウー", "ばかりじゃねぇか。"]}, {"box": [69, 352, 155, 577], "vertical": true, "font_size": 23.0, "lines": ["はは．．．．．やっぱ", "そこらへん、母親じゃ", "ないと．．．みたいな？"]}, {"box": [831, 833, 956, 1270], "vertical": true, "font_size": 25.0, "lines": ["バカ！！つまんない", "桃子のしつけと", "こと言ってんじゃ", "教育は暇人の", "ないよ！！", "お前がどーにか", "するんだよっ！！"]}, {"box": [495, 1004, 554, 1222], "vertical": true, "font_size": 28.0, "lines": ["俺、最近ちゃんと", "働いてんじゃん．．．"]}, {"box": [223, 796, 365, 1019], "vertical": true, "font_size": 32.0, "lines": ["この頃、芳一は早朝どこかへ出かけ帰ってくるなり一日中パソコンにかじりついている。"]}, {"box": [218, 799, 365, 1017], "vertical": true, "font_size": 25.0, "lines": ["この頃、芳一は", "早朝どこかへ出かけ", "帰ってくるなり", "一日中パソコンに", "かじりついている。"]}, {"box": [392, 1205, 478, 1382], "vertical": true, "font_size": 26.0, "lines": ["うるせえっ！！", "ホレ、飯だ風呂だ", "酒だっ！！"]}, {"box": [152, 1101, 236, 1340], "vertical": true, "font_size": 25.0, "lines": ["．．．芳一はあの計画を", "本気で実行する"]}, {"box": [151, 1101, 175, 1336], "vertical": true, "font_size": 25.0, "lines": ["つもりなのだろう．．．"]}], "img_path": "165.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [584, 418, 612, 569], "vertical": true, "font_size": 28.0, "lines": ["下通工事中の点の７月２６日から８月４日までの間以下の演技は注目をお願いします」ニーリー"]}, {"box": [167, 445, 264, 634], "vertical": true, "font_size": 32.0, "lines": ["から８", "迂回をお"]}, {"box": [795, 657, 848, 863], "vertical": true, "font_size": 32.0, "lines": ["７月下旬、相変わらずの暑さ。"]}, {"box": [794, 657, 848, 863], "vertical": true, "font_size": 24.0, "lines": ["７月下旬、", "相変わらずの暑さ。"]}, {"box": [699, 661, 752, 828], "vertical": true, "font_size": 24.0, "lines": ["やはり蝉の声が", "聞こえない。"]}, {"box": [699, 659, 753, 833], "vertical": true, "font_size": 32.0, "lines": ["やはり蝉の声が聞こえない。"]}, {"box": [598, 658, 623, 837], "vertical": true, "font_size": 24.0, "lines": ["僕が考察するに"]}, {"box": [473, 657, 563, 899], "vertical": true, "font_size": 26.0, "lines": ["土の上に", "アスファルトが敷かれ", "建物が建ち、"]}, {"box": [377, 657, 434, 866], "vertical": true, "font_size": 25.0, "lines": ["幼虫たちの出口が", "塞がれてしまった。"]}, {"box": [467, 949, 521, 1126], "vertical": true, "font_size": 26.0, "lines": ["抗えない"]}, {"box": [465, 950, 489, 1120], "vertical": true, "font_size": 26.0, "lines": ["大きな力の前に"]}, {"box": [310, 947, 397, 1143], "vertical": true, "font_size": 26.0, "lines": ["志半ばで", "土に還ってゆく", "蝉たちの気持ちを"]}, {"box": [280, 661, 303, 868], "vertical": true, "font_size": 20.0, "lines": ["たとえば、そんな話"]}, {"box": [185, 659, 209, 842], "vertical": true, "font_size": 20.0, "lines": ["ない話ではない。"]}, {"box": [194, 945, 399, 1149], "vertical": false, "font_size": 32.0, "lines": ["大半ばで土に送ってゆく様たちの気持ちを、ちょっとだけ考えてみる。"]}, {"box": [190, 946, 248, 1092], "vertical": true, "font_size": 23.0, "lines": ["ちょっとだけ", "考えてみる。"]}, {"box": [89, 1282, 140, 1379], "vertical": true, "font_size": 30.0, "lines": ["ただいま"]}], "img_path": "166.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [869, 708, 954, 1057], "vertical": true, "font_size": 27.0, "lines": ["なんだよ、この", "花火とかお面は？", "芳ー、", "また盗んだのか？"]}, {"box": [227, 806, 275, 982], "vertical": true, "font_size": 23.0, "lines": ["はは、そうか。", "じゃあやろうよ。"]}, {"box": [134, 924, 192, 1054], "vertical": true, "font_size": 23.0, "lines": ["夏っぽくて", "いい感じだ"]}, {"box": [630, 1230, 718, 1377], "vertical": true, "font_size": 30.0, "lines": ["バカヤロ、", "拾ってきたん", "だよ。"]}, {"box": [111, 1226, 145, 1400], "vertical": true, "font_size": 30.0, "lines": ["あうあぁっ！！"]}], "img_path": "167.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [845, 78, 931, 492], "vertical": true, "font_size": 24.0, "lines": ["あはは、そうか", "キレイだろう？", "桃子は花火", "はじめて見るんだ。"]}, {"box": [488, 98, 573, 293], "vertical": true, "font_size": 25.0, "lines": ["．．．どうした芳一？", "やけにおとなしい", "じゃんか。"]}, {"box": [127, 22, 246, 55], "vertical": false, "font_size": 30.0, "lines": ["わかりのまち"]}, {"box": [73, 178, 165, 436], "vertical": true, "font_size": 24.0, "lines": ["前ははしゃいで、", "他人んちにロケット花火", "打ち込んでたのに。"]}, {"box": [119, 578, 257, 933], "vertical": true, "font_size": 23.0, "lines": ["．．．ちなみに", "明日の早朝、", "仕事手伝って", "もらいまーす。"]}, {"box": [113, 1199, 174, 1373], "vertical": true, "font_size": 28.0, "lines": ["よろしく頼むよ、", "サトシ。"]}], "img_path": "168.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [837, 100, 938, 469], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．やっぱ", "やめようよ．．．", "無理だよ", "こんなこと．．．"]}, {"box": [533, 89, 617, 260], "vertical": true, "font_size": 22.0, "lines": ["誘拐して", "金をゆすりとる", "なんて．．．"]}, {"box": [74, 140, 186, 308], "vertical": true, "font_size": 25.0, "lines": ["子供の遊びじゃ", "ないんだ。", "うまくいくわけ", "ないって．．．"]}, {"box": [651, 365, 677, 442], "vertical": true, "font_size": 26.0, "lines": ["はぁ？"]}, {"box": [225, 381, 366, 667], "vertical": true, "font_size": 27.0, "lines": ["サトシ、てめぇ．．．", "俺のＰＣ", "いじりやがった", "な．．．．．．"]}, {"box": [206, 654, 236, 805], "vertical": true, "font_size": 25.0, "lines": ["．．．それに．．．"]}, {"box": [772, 786, 937, 1153], "vertical": true, "font_size": 26.0, "lines": ["芳一は金、金って", "そればっかり．．．", "犯罪で", "手に入れた", "金なんてっ．．．"]}, {"box": [104, 921, 239, 1323], "vertical": true, "font_size": 32.0, "lines": ["．．．．．桃子が．．．．", "桃子が", "喜ぶわけ", "ないだろっ！？"]}], "img_path": "169.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [827, 62, 898, 383], "vertical": true, "font_size": 32.0, "lines": ["．．．緊張しているのか？", "芳一．．．．．．"]}, {"box": [173, 105, 325, 454], "vertical": true, "font_size": 24.0, "lines": ["詳しい内容は", "あえて言わないが、", "．．．．．．なーに、", "お前がやるのは", "簡単なことさ。"]}, {"box": [691, 710, 865, 1110], "vertical": true, "font_size": 25.0, "lines": ["．．．ってカンジで。", "サトシ、もう手順は", "終わったら", "わかったろ？", "家に帰って", "俺が戻るまで", "フツーにしてろ。"]}, {"box": [217, 1126, 244, 1318], "vertical": true, "font_size": 24.0, "lines": ["．．．なぁ芳！．．"]}, {"box": [138, 1295, 167, 1348], "vertical": true, "font_size": 29.0, "lines": ["ん？"]}], "img_path": "170.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [895, 183, 932, 324], "vertical": true, "font_size": 32.0, "lines": ["うぶっ！！"]}, {"box": [839, 580, 938, 788], "vertical": true, "font_size": 29.0, "lines": ["今になって", "ピーピー", "うるせえよっ！！"]}, {"box": [105, 616, 214, 881], "vertical": true, "font_size": 30.0, "lines": ["こんの糞坊主、", "甘ぇことばっか", "言ってんじゃねぇ！！"]}, {"box": [598, 872, 623, 1072], "vertical": true, "font_size": 25.0, "lines": ["．．．死んだりとか、"]}, {"box": [507, 968, 564, 1163], "vertical": true, "font_size": 25.0, "lines": ["もしいなくなった", "としたら．．．．．．"]}, {"box": [95, 948, 182, 1159], "vertical": true, "font_size": 25.0, "lines": ["僕は三人が", "一緒にいられれば", "それでいいのに．．．"]}, {"box": [926, 1135, 953, 1277], "vertical": true, "font_size": 27.0, "lines": ["．．．．．第一．．．"]}, {"box": [806, 1229, 890, 1413], "vertical": true, "font_size": 27.0, "lines": ["たとえば失敗して", "芳一が捕まった", "り．．．．．．"]}, {"box": [209, 1211, 263, 1377], "vertical": true, "font_size": 24.0, "lines": ["．．．言うじゃん", "サトシ．．．"]}, {"box": [83, 1268, 168, 1419], "vertical": true, "font_size": 24.0, "lines": ["そりゃそうさ。", "俺だってそう", "思うさ．．．．．．"]}], "img_path": "171.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [857, 74, 958, 503], "vertical": true, "font_size": 25.0, "lines": ["ただ俺みたいな", "ゴリ押ししなきゃ", "外道がみじめに", "ならない時も", "ならないためには、", "あるんだぜぇ。"]}, {"box": [296, 105, 412, 343], "vertical": true, "font_size": 26.0, "lines": ["．．．俺の親は", "土地成金になった後、", "借金作るだけ作って", "あっさり頓死してよ。"]}, {"box": [127, 30, 257, 64], "vertical": false, "font_size": 32.0, "lines": ["しかりのまち"]}, {"box": [573, 518, 661, 702], "vertical": true, "font_size": 24.0, "lines": ["俺だってでかい", "リスク背負って", "自由やってんだ。"]}, {"box": [103, 592, 256, 1005], "vertical": true, "font_size": 25.0, "lines": ["悲しすぎるだろ、", "そんなの．．．．．．", "やっぱ半端な奴から", "腐って死んでいくん", "だよな．．．"]}], "img_path": "172.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [804, 655, 895, 840], "vertical": true, "font_size": 27.0, "lines": ["．．．．．．芳一、", "クルマ、そっちに", "向かったよ．．．"]}, {"box": [202, 359, 230, 493], "vertical": true, "font_size": 25.0, "lines": ["大丈夫です。"]}, {"box": [228, 739, 331, 1038], "vertical": true, "font_size": 30.0, "lines": ["了解。", "ナイス、サトシ。", "お疲れ。"]}, {"box": [125, 761, 188, 851], "vertical": true, "font_size": 21.0, "lines": ["この先", "行き止まり"]}, {"box": [790, 1059, 951, 1389], "vertical": true, "font_size": 25.0, "lines": ["．．．あとな、", "考えたんだが、", "もうお前は", "荷物まとめて桃子と", "あの家から出ていけ。"]}, {"box": [250, 1155, 288, 1224], "vertical": true, "font_size": 32.0, "lines": ["え？"]}, {"box": [267, 1361, 307, 1451], "vertical": true, "font_size": 32.0, "lines": ["ピッ"]}, {"box": [139, 1251, 225, 1406], "vertical": true, "font_size": 24.0, "lines": ["家族ごっこは", "もう終わりだ", "．．．じゃあな。"]}], "img_path": "173.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [194, 516, 250, 712], "vertical": true, "font_size": 26.0, "lines": ["あっ、どーも", "すいません．．．"]}, {"box": [786, 827, 894, 1304], "vertical": true, "font_size": 24.0, "lines": ["この道順で", "大通りに", "ただ今この先", "抜けれますんで．．．", "水道工事中でして、"]}, {"box": [75, 1046, 173, 1367], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．キミ", "大丈夫か？", "どこか", "痛むのかい？"]}], "img_path": "174.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [854, 142, 940, 289], "vertical": true, "font_size": 26.0, "lines": ["一面クリア。", "もうすぐ社長", "来るぜ。"]}, {"box": [558, 110, 644, 281], "vertical": true, "font_size": 25.0, "lines": ["この道の先は", "完全に袋小路に", "なってる。"]}, {"box": [83, 148, 169, 360], "vertical": true, "font_size": 28.0, "lines": ["社長のクルマが", "停まったら、一気に", "ボコすぜ？"]}, {"box": [698, 565, 723, 721], "vertical": true, "font_size": 20.0, "lines": ["オーケー了解。"]}, {"box": [318, 393, 373, 604], "vertical": true, "font_size": 25.0, "lines": ["その後、例の場所で", "ゆっくり交渉だ。"]}, {"box": [775, 907, 832, 1114], "vertical": true, "font_size": 26.0, "lines": ["どうした芳一、", "テンション低いぜ。"]}, {"box": [188, 766, 271, 989], "vertical": true, "font_size": 27.0, "lines": ["おう。"]}], "img_path": "175.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [403, 92, 434, 223], "vertical": true, "font_size": 26.0, "lines": ["ーっ。", "たー"]}, {"box": [688, 296, 714, 542], "vertical": true, "font_size": 24.0, "lines": ["．．．家族ごっこか．．．"]}, {"box": [672, 628, 786, 773], "vertical": true, "font_size": 25.0, "lines": ["お互いの", "理想と主張が", "ぶつかって", "破綻した。"]}, {"box": [446, 629, 472, 711], "vertical": true, "font_size": 26.0, "lines": ["これが、"]}, {"box": [251, 627, 386, 798], "vertical": true, "font_size": 25.0, "lines": ["血が繋がって", "いないがゆえの", "もろさなのかも", "しれない。"]}, {"box": [115, 449, 146, 573], "vertical": true, "font_size": 31.0, "lines": ["桃子．．．．．．"]}, {"box": [336, 916, 417, 1211], "vertical": true, "font_size": 24.0, "lines": ["もちろん人と人は", "価値観の共有はできないし、"]}, {"box": [332, 916, 359, 1168], "vertical": true, "font_size": 24.0, "lines": ["だから否定もできない。"]}, {"box": [861, 1086, 890, 1235], "vertical": true, "font_size": 26.0, "lines": ["行こう．．．"]}, {"box": [135, 1109, 250, 1355], "vertical": true, "font_size": 24.0, "lines": ["芳一は芳一の中にある", "信じる何かに基づいて", "生きているのであって、", "僕はあくまでも外側に"]}, {"box": [108, 1112, 250, 1353], "vertical": true, "font_size": 20.0, "lines": ["いるのだから。"]}], "img_path": "176.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [837, 99, 957, 540], "vertical": true, "font_size": 24.0, "lines": ["でもね社長", "あんたが", "俺たちと知り合った", "女を買ったって", "ことも俺らは", "以上、フツーに帰す", "知ってるのよ？", "わけにいかないのね。"]}, {"box": [537, 70, 622, 265], "vertical": true, "font_size": 23.0, "lines": ["それを大事な", "奥さんと娘さんに", "知られたら．．．"]}, {"box": [86, 126, 202, 327], "vertical": true, "font_size": 26.0, "lines": ["いやむしろ、", "娘さんにいろいろ", "しちゃうってテも", "あるんだよね。"]}, {"box": [583, 351, 638, 546], "vertical": true, "font_size": 22.0, "lines": ["．．．オイ、俺は", "それは聞いて．．．"]}, {"box": [353, 602, 378, 712], "vertical": true, "font_size": 25.0, "lines": ["．．．いっ。"]}, {"box": [834, 1189, 860, 1401], "vertical": true, "font_size": 25.0, "lines": ["いくら出せばいい？"]}], "img_path": "177.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [795, 70, 826, 237], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．でも、"]}, {"box": [674, 142, 747, 445], "vertical": true, "font_size": 32.0, "lines": ["人を騙したり", "傷つけたりすることは"]}, {"box": [586, 313, 626, 479], "vertical": true, "font_size": 32.0, "lines": ["絶対に悪だ。"]}, {"box": [144, 317, 287, 737], "vertical": true, "font_size": 24.0, "lines": ["社長ぉー", "ここがどこだか", "あんたの親会社が", "利益拡大のために", "わかるかな？", "買い上げた", "現・廃ビルですわ。"]}, {"box": [778, 767, 928, 1052], "vertical": true, "font_size": 26.0, "lines": ["〈皮肉だねっ、", "皮肉だねっ、", "そんなトコに", "拉致、監禁されて", "皮肉だねっ。"]}, {"box": [531, 763, 618, 1046], "vertical": true, "font_size": 25.0, "lines": ["．．．魔材の不法投棄は", "前任者の判断であって", "私の知るところじゃないだ"]}, {"box": [393, 902, 508, 1096], "vertical": true, "font_size": 32.0, "lines": ["公表したければすればいいさ。私が退いて会社が少し傾くだけだ。"]}, {"box": [392, 900, 506, 1095], "vertical": true, "font_size": 25.0, "lines": ["公表したければ", "すればいいさ。", "私が退いて会社が", "少し傾くだけだ"]}, {"box": [84, 917, 141, 1103], "vertical": true, "font_size": 22.0, "lines": ["金なんて出すわけ", "ないだろう．．．"]}, {"box": [211, 1130, 297, 1322], "vertical": true, "font_size": 24.0, "lines": ["あら社長、", "責任転嫁？", "むしろ開き直り？"]}, {"box": [98, 1191, 181, 1401], "vertical": true, "font_size": 24.0, "lines": ["偉い人たちってのは", "みんな同じことを", "するね。"]}], "img_path": "178.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [874, 82, 956, 289], "vertical": true, "font_size": 22.0, "lines": ["そーそー", "やればできる子", "じゃん、社長ぉー"]}, {"box": [626, 74, 661, 208], "vertical": true, "font_size": 24.0, "lines": ["やめたっ。"]}, {"box": [505, 215, 589, 416], "vertical": true, "font_size": 24.0, "lines": ["悪い、俺、降りるわ。", "なんか急に", "冷めてきた。"]}, {"box": [234, 495, 352, 657], "vertical": true, "font_size": 25.0, "lines": ["俺、行くとこ", "あるから、後は", "お前ら勝手に", "やってくれ"]}, {"box": [825, 693, 939, 866], "vertical": true, "font_size": 24.0, "lines": ["お前、作戦の", "途中離脱が", "どーゆうことか", "わかってる？"]}, {"box": [129, 1151, 193, 1258], "vertical": true, "font_size": 32.0, "lines": ["オーケー、", "こいよ。"]}], "img_path": "179.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [81, 90, 198, 475], "vertical": true, "font_size": 24.0, "lines": ["．．．あの、", "我々こういう", "失礼ですけど、", "者ですが", "伊藤芳一さん", "ですか？"]}, {"box": [850, 621, 907, 780], "vertical": true, "font_size": 27.0, "lines": ["．．．いや、あの", "僕は．．．．．．"]}, {"box": [367, 503, 433, 611], "vertical": false, "font_size": 28.0, "lines": ["ボールを"]}, {"box": [316, 506, 372, 586], "vertical": true, "font_size": 32.0, "lines": ["北原"]}, {"box": [350, 541, 393, 632], "vertical": true, "font_size": 25.0, "lines": ["茂", "何部も"]}, {"box": [823, 914, 939, 1132], "vertical": true, "font_size": 24.0, "lines": ["以前からこの家は", "大家の承認を得て、", "立ち退くように再三", "通告してまして。"]}, {"box": [153, 664, 182, 812], "vertical": true, "font_size": 24.0, "lines": ["ご家族の方？"]}, {"box": [365, 1128, 479, 1367], "vertical": true, "font_size": 25.0, "lines": ["ご主人の芳一さん、", "「金は用意するから」と", "おっしゃってました", "けど．．．．．．"]}, {"box": [77, 1208, 189, 1397], "vertical": true, "font_size": 23.0, "lines": ["そういう問題じゃ", "ないんです。", "どうにかご理解", "いただきたく．．．"]}], "img_path": "180.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [514, 49, 607, 249], "vertical": true, "font_size": 30.0, "lines": ["．．．．．こんなの", "きっと意味なんて", "ない。"]}, {"box": [424, 54, 449, 262], "vertical": true, "font_size": 21.0, "lines": ["きっと間違ってる。"]}, {"box": [761, 680, 797, 776], "vertical": true, "font_size": 26.0, "lines": ["痛え．．．"]}, {"box": [236, 328, 265, 462], "vertical": true, "font_size": 26.0, "lines": ["．．．．ひひっ。"]}, {"box": [183, 489, 211, 616], "vertical": true, "font_size": 26.0, "lines": ["だせぇ．．．"]}, {"box": [870, 898, 928, 1069], "vertical": true, "font_size": 26.0, "lines": ["俺、今、どこ", "歩いてんだぁ？"]}, {"box": [536, 921, 625, 1325], "vertical": true, "font_size": 26.0, "lines": ["お？なんだ？", "蝉の声が", "聞こえてきたぜぇ。"]}, {"box": [98, 1201, 181, 1367], "vertical": true, "font_size": 22.0, "lines": ["お？なんだ？", "なんかが見えて", "きたぜぇ？"]}], "img_path": "181.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [829, 26, 858, 268], "vertical": true, "font_size": 24.0, "lines": ["．．あぁ．．．．．．"]}, {"box": [383, 174, 458, 412], "vertical": true, "font_size": 32.0, "lines": ["全部二人で", "抱え込んで．．．"]}, {"box": [104, 128, 142, 389], "vertical": true, "font_size": 32.0, "lines": ["ベカだな、芳二。"]}, {"box": [679, 439, 705, 578], "vertical": true, "font_size": 26.0, "lines": ["ことか．．．"]}, {"box": [548, 542, 568, 667], "vertical": true, "font_size": 22.0, "lines": ["．．．ここは、"]}, {"box": [594, 691, 618, 860], "vertical": true, "font_size": 22.0, "lines": ["僕の家です．．．"]}, {"box": [804, 1092, 905, 1448], "vertical": true, "font_size": 32.0, "lines": ["．．．ここは僕たちの", "家なんだっ！！"]}], "img_path": "182.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [765, 109, 896, 467], "vertical": true, "font_size": 26.0, "lines": ["．．．そうさ俺は、", "「ひかりのまち」を", "買い取って、元の村を", "取り戻すんだ。"]}, {"box": [235, 272, 290, 492], "vertical": true, "font_size": 23.0, "lines": ["そこで俺たち三人で", "暮らしてな．．．"]}, {"box": [878, 946, 936, 1164], "vertical": true, "font_size": 24.0, "lines": ["．．．．．いいねぇ．．．", "幸せじゃねぇか．．．"]}, {"box": [110, 668, 256, 929], "vertical": true, "font_size": 26.0, "lines": ["．．．．．．そんで桃子に", "「私はどっちのババから", "生まれたの？」なんて", "聞かれて、俺たちは", "苦笑いするんだ．．．"]}, {"box": [350, 1078, 401, 1245], "vertical": true, "font_size": 21.0, "lines": ["．．．帰ろう．．．．", "家に帰ろう．．．"]}, {"box": [218, 1199, 300, 1365], "vertical": true, "font_size": 21.0, "lines": ["．．．きっと今日も", "サトシと桃子が", "俺を待ってる！！"]}], "img_path": "183.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [120, 84, 211, 275], "vertical": true, "font_size": 26.0, "lines": ["ーでもやはり", "僕は一人では何も", "できない人間で、"]}, {"box": [771, 442, 860, 631], "vertical": true, "font_size": 31.0, "lines": ["いつもの", "居心地のよい畳に", "横になっている。"]}, {"box": [125, 438, 219, 708], "vertical": true, "font_size": 31.0, "lines": ["僕はいったい", "こんなところで", "何をしているんだろう？"]}, {"box": [851, 816, 883, 923], "vertical": true, "font_size": 28.0, "lines": ["．．．．．．桃子、"]}, {"box": [735, 869, 820, 1066], "vertical": true, "font_size": 28.0, "lines": ["もう少し", "芳一を待ってても", "いいかな。"]}, {"box": [125, 1289, 158, 1361], "vertical": true, "font_size": 32.0, "lines": ["うん。"]}], "img_path": "184.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [], "img_path": "185.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [894, 68, 919, 252], "vertical": true, "font_size": 24.0, "lines": ["．．．いっ、今っ．．．"]}, {"box": [592, 359, 679, 568], "vertical": true, "font_size": 28.0, "lines": ["「うん」って．．．", "桃子、今「うん」って", "言った！？"]}, {"box": [757, 620, 886, 903], "vertical": true, "font_size": 27.0, "lines": ["．．．はははっ、", "しゃべった！！", "桃子がやっと", "しゃべった！！"]}, {"box": [151, 806, 243, 980], "vertical": true, "font_size": 31.0, "lines": ["芳一！！", "やっと桃子が", "しゃべったよ！！"]}, {"box": [751, 1118, 772, 1218], "vertical": true, "font_size": 20.0, "lines": ["７月下旬、"]}, {"box": [555, 1115, 640, 1282], "vertical": true, "font_size": 25.0, "lines": ["太陽が真上から", "照りつける", "夏の午後。"]}, {"box": [425, 1116, 448, 1239], "vertical": true, "font_size": 20.0, "lines": ["どこからか"]}, {"box": [231, 1112, 316, 1281], "vertical": true, "font_size": 24.0, "lines": ["蝉の声が", "聞こえたような", "気がした。"]}], "img_path": "186.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [581, 388, 611, 580], "vertical": true, "font_size": 25.0, "lines": ["それぞれの想い。"]}, {"box": [497, 389, 529, 482], "vertical": true, "font_size": 32.0, "lines": ["ゆく人。"]}, {"box": [418, 389, 446, 506], "vertical": true, "font_size": 25.0, "lines": ["留まる人。"]}], "img_path": "187.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [825, 158, 939, 352], "vertical": true, "font_size": 24.0, "lines": ["．．．．．．さんは病院に", "運ばれましたが", "すでに死亡して", "いました。"]}, {"box": [360, 90, 449, 244], "vertical": true, "font_size": 24.0, "lines": ["ーっ．．．", "もー", "また寝てるの", "タイキくん？"]}, {"box": [310, 236, 326, 293], "vertical": true, "font_size": 16.0, "lines": ["このうた"]}, {"box": [0, 76, 57, 481], "vertical": true, "font_size": 32.0, "lines": ["のまし"]}, {"box": [138, 290, 223, 509], "vertical": true, "font_size": 22.0, "lines": ["警察では", "傷害致死事件として", "捜査をしています。"]}, {"box": [249, 506, 271, 680], "vertical": true, "font_size": 20.0, "lines": ["．．．そうさ．．．"]}, {"box": [851, 838, 940, 1056], "vertical": true, "font_size": 26.0, "lines": ["．．．そうさ、人は", "いつか必ず、そして", "平等に死ぬのさ．．．"]}, {"box": [515, 877, 688, 1258], "vertical": true, "font_size": 27.0, "lines": ["なのに、お前らは", "積みあげては", "崩して．．．", "．．．．．．なん", "なんだよっ！！"]}, {"box": [75, 1138, 193, 1374], "vertical": true, "font_size": 32.0, "lines": ["せんせぇ～～", "タイキくんがぁ", "〜〜〜～～っ！！"]}], "img_path": "188.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [737, 133, 825, 283], "vertical": true, "font_size": 26.0, "lines": ["なんか今日、", "寂しそうな顔", "してるぞ。"]}, {"box": [627, 152, 687, 327], "vertical": true, "font_size": 26.0, "lines": ["恋人と喧嘩でも", "したのかよ．．．？"]}, {"box": [85, 23, 260, 68], "vertical": false, "font_size": 32.0, "lines": ["かりのませ"]}, {"box": [83, 199, 202, 374], "vertical": true, "font_size": 25.0, "lines": ["まさかぁ！", "彼氏とは全然", "うまくいってる", "もーーん．．．"]}, {"box": [543, 431, 627, 680], "vertical": true, "font_size": 22.0, "lines": ["．．．ところで", "みなさん、今夜の予定は", "お決まりですか？"]}, {"box": [152, 545, 267, 691], "vertical": true, "font_size": 24.0, "lines": ["実は今日は、", "流星群が", "やってくる目", "なんです"]}, {"box": [681, 689, 890, 1024], "vertical": true, "font_size": 24.0, "lines": ["．．．って、もう！！", "どこで覚えてくるの", "そんなセリフ！？", "ホラ！！", "お帰りバス、", "来てるんだから", "早く乗って！！"]}, {"box": [300, 790, 316, 883], "vertical": true, "font_size": 16.0, "lines": ["りがつのうた"]}, {"box": [843, 1107, 934, 1252], "vertical": true, "font_size": 29.0, "lines": ["幸いにも", "今夜の予報は", "晴れ。"]}, {"box": [332, 1221, 679, 1286], "vertical": false, "font_size": 20.0, "lines": ["エビロ－", "ＲＥＢＩＲＩＮＨＤＡＹＳＯＮＧ"]}, {"box": [85, 1188, 199, 1436], "vertical": true, "font_size": 23.0, "lines": ["みなさんもたまには", "ゆったりとした気持ちで", "夜空を眺めてみては", "いかがですか？"]}], "img_path": "189.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [876, 121, 940, 298], "vertical": true, "font_size": 26.0, "lines": ["もーっ！！", "タイキくん！！"]}, {"box": [161, 230, 262, 418], "vertical": true, "font_size": 28.0, "lines": ["なんでいつも", "みんなのこと、", "いじめるの！？"]}, {"box": [896, 544, 928, 647], "vertical": true, "font_size": 30.0, "lines": ["違うよ。"]}, {"box": [138, 594, 227, 743], "vertical": true, "font_size": 27.0, "lines": ["本当のことを", "教えてやった", "だけだ"]}, {"box": [775, 808, 957, 1143], "vertical": true, "font_size": 25.0, "lines": ["まーた、", "そうやってよく", "わからないこと言って。", "タイキくんは", "いっつも先生を", "困らせるんだから。"]}, {"box": [389, 840, 414, 984], "vertical": true, "font_size": 24.0, "lines": ["なぁ、カオリ。"]}, {"box": [281, 921, 336, 1040], "vertical": true, "font_size": 24.0, "lines": ["カオリ先生", "でしょ！？"]}, {"box": [758, 1352, 937, 1404], "vertical": false, "font_size": 32.0, "lines": ["あさひだいようちえ"]}, {"box": [114, 1234, 173, 1338], "vertical": true, "font_size": 26.0, "lines": ["お前は今、", "幸せか？"]}], "img_path": "190.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [494, 65, 561, 343], "vertical": true, "font_size": 30.0, "lines": ["―すると私は", "バスに揺られていた。"]}, {"box": [784, 924, 869, 1141], "vertical": true, "font_size": 25.0, "lines": ["ほどなくしてバスは", "見慣れたバス停に", "停車した。"]}, {"box": [278, 918, 365, 1137], "vertical": true, "font_size": 25.0, "lines": ["音もなく扉が開き、", "吸い込まれるように", "数人が乗り込んだ。"]}, {"box": [109, 1145, 195, 1438], "vertical": true, "font_size": 24.0, "lines": ["その中の一人が", "このバスがどこ行きなのか、", "車掌にたずねた。"]}], "img_path": "191.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [851, 138, 936, 287], "vertical": true, "font_size": 25.0, "lines": ["ははは、", "まぁまぁそう", "焦らないで♪"]}, {"box": [105, 137, 218, 332], "vertical": true, "font_size": 24.0, "lines": ["これから", "長い長い旅が", "始まるんだから．．．", "ミャンニャン♪"]}, {"box": [188, 501, 309, 735], "vertical": true, "font_size": 27.0, "lines": ["「どうやら自分は", "死んでしまった", "らしい」と、", "乗客の一人が言った。"]}, {"box": [784, 1173, 842, 1416], "vertical": true, "font_size": 24.0, "lines": ["仕方なく私は", "外の景色に目をやった。"]}, {"box": [543, 1173, 630, 1429], "vertical": true, "font_size": 25.0, "lines": ["見慣れた", "「ひかりのまち」の景色が", "そこにあった。"]}, {"box": [312, 1182, 402, 1371], "vertical": true, "font_size": 28.0, "lines": ["懐かしさとともに、", "どこか違和感を", "感じた。"]}], "img_path": "192.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [750, 737, 875, 1048], "vertical": true, "font_size": 25.0, "lines": ["もう何年も", "乗り続けてるん", "じゃないか。"]}, {"box": [803, 1155, 891, 1345], "vertical": true, "font_size": 26.0, "lines": ["あっちとこっちを", "グルグルガルダル", "行ったり来たり！"]}, {"box": [702, 1264, 756, 1405], "vertical": true, "font_size": 26.0, "lines": ["自然の摂理に", "逆らって！！"]}, {"box": [702, 1266, 756, 1405], "vertical": true, "font_size": 32.0, "lines": ["自然の摂理に逆らって！！"]}, {"box": [112, 1185, 199, 1383], "vertical": true, "font_size": 25.0, "lines": ["．．．この少年は", "なぜ私のことを", "知ってるのだろう。"]}], "img_path": "193.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [782, 87, 927, 331], "vertical": true, "font_size": 25.0, "lines": ["人気のない街は", "まるで積み木や", "ブロックのオモチャの", "ような印象を", "受けた。"]}, {"box": [170, 362, 283, 529], "vertical": true, "font_size": 32.0, "lines": ["他の乗客たちも感慨深そうにその光景を見つめていた。"]}, {"box": [167, 360, 336, 759], "vertical": true, "font_size": 24.0, "lines": ["住人だったの", "他の乗客たちも", "だろうか。", "感慨深そうに", "その光景を", "見つめていた。"]}, {"box": [254, 584, 341, 751], "vertical": true, "font_size": 22.0, "lines": ["みんなこの街の"]}, {"box": [813, 823, 928, 1037], "vertical": true, "font_size": 23.0, "lines": ["私の部屋も", "このどこかに", "あるのかもしれない", "と思ったが．．．．．．"]}, {"box": [367, 939, 423, 1095], "vertical": true, "font_size": 24.0, "lines": ["．．．．．うまく", "思い出せない。"]}, {"box": [78, 1126, 163, 1348], "vertical": true, "font_size": 24.0, "lines": ["そもそも私は", "いつからこのバスに", "乗っているのだろう。"]}], "img_path": "194.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [772, 486, 830, 645], "vertical": true, "font_size": 25.0, "lines": ["だって僕は", "アンタだから。"]}, {"box": [226, 1003, 280, 1145], "vertical": true, "font_size": 21.0, "lines": ["もしやキミは", "私なのか？"]}], "img_path": "195.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [767, 188, 792, 332], "vertical": true, "font_size": 24.0, "lines": ["ああ．．．"]}, {"box": [274, 816, 332, 935], "vertical": true, "font_size": 28.0, "lines": ["そうだった", "ね．．．．．．"]}, {"box": [839, 1265, 865, 1375], "vertical": true, "font_size": 22.0, "lines": ["くん"]}, {"box": [114, 1262, 143, 1427], "vertical": true, "font_size": 24.0, "lines": ["タイキくんっ！？"]}], "img_path": "196.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [322, 111, 438, 322], "vertical": true, "font_size": 24.0, "lines": ["．．．残念ね", "カオリ先生、", "やさしくていい先生", "だったのに。"]}, {"box": [70, 252, 255, 733], "vertical": true, "font_size": 26.0, "lines": ["ホラ、４〜５年前に", "恋人亡くされた時", "相当落ち込んだ", "夏休みを", "らしいし。", "二人でゆっくり", "過ごしたかったんじゃ", "ありません？"]}, {"box": [731, 805, 848, 1035], "vertical": true, "font_size": 23.0, "lines": ["せめて、この子たちが", "卒園するまで", "辞めないで", "ほしかったけど．．．"]}, {"box": [153, 1160, 271, 1361], "vertical": true, "font_size": 26.0, "lines": ["でも、よかったじゃ", "ないですか", "幸せな結婚が", "できて。"]}], "img_path": "197.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [835, 94, 950, 270], "vertical": true, "font_size": 25.0, "lines": ["ホラ、タイキくん", "起きて。", "お母さん、迎えに", "来てるよ。"]}, {"box": [184, 97, 270, 247], "vertical": true, "font_size": 25.0, "lines": ["せんせぇ～～", "さような", "ら～～っ。"]}, {"box": [85, 396, 147, 524], "vertical": true, "font_size": 32.0, "lines": ["また", "明日"]}, {"box": [198, 655, 289, 795], "vertical": true, "font_size": 31.0, "lines": ["はぁい、", "みんな", "さようなら。"]}, {"box": [841, 907, 928, 1102], "vertical": true, "font_size": 25.0, "lines": ["あの．．．先生、", "どうもご苦労さま", "でした。"]}, {"box": [330, 953, 390, 1122], "vertical": true, "font_size": 25.0, "lines": ["．．．タイキくんも", "さようなら。"]}, {"box": [601, 1214, 655, 1380], "vertical": true, "font_size": 25.0, "lines": ["あ、いえ", "こちらこそ．．．"]}], "img_path": "198.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [815, 139, 936, 306], "vertical": true, "font_size": 27.0, "lines": ["すいません、", "１１０７号の", "佐藤と申します", "が．．．．．"]}, {"box": [510, 63, 627, 302], "vertical": true, "font_size": 28.0, "lines": ["急な仕事が", "入ってしまって．．．", "今晩息子を預かって", "いただきたくて。"]}, {"box": [365, 195, 486, 335], "vertical": true, "font_size": 32.0, "lines": ["昇代秋助"]}, {"box": [290, 215, 379, 242], "vertical": false, "font_size": 27.0, "lines": ["長谷川"]}, {"box": [82, 136, 199, 359], "vertical": true, "font_size": 26.0, "lines": ["いつもは", "お隣の斎藤さんに", "お願いしてるんです", "けど、留守みたいで。"]}, {"box": [502, 379, 620, 626], "vertical": true, "font_size": 25.0, "lines": ["．．．あー、僕らも", "友人の結婚式で", "これから出かけるとこ", "なんですよ。"]}, {"box": [137, 533, 249, 833], "vertical": true, "font_size": 31.0, "lines": ["僕が面倒", "みとくから。", "大丈夫", "だよ。"]}, {"box": [777, 1073, 894, 1309], "vertical": true, "font_size": 25.0, "lines": ["本日未明、住宅地の", "路上で血まみれの男が", "倒れていると通報が", "あり．．．．．．"]}, {"box": [171, 1070, 260, 1276], "vertical": true, "font_size": 27.0, "lines": ["なんだ、", "このニュース、", "すげぇ近所じゃん。"]}, {"box": [89, 1243, 146, 1374], "vertical": true, "font_size": 27.0, "lines": ["あ、ジュース", "とか飲む？"]}], "img_path": "199.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [831, 102, 886, 281], "vertical": true, "font_size": 22.0, "lines": ["生まれては死に", "死んでは生まれ"]}, {"box": [140, 12, 249, 41], "vertical": false, "font_size": 26.0, "lines": ["かりのまち"]}, {"box": [820, 596, 877, 704], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．キミ", "名前は？"]}, {"box": [409, 313, 475, 511], "vertical": true, "font_size": 30.0, "lines": ["意味がねぇ。", "全然、意味がねぇ。"]}, {"box": [220, 551, 303, 736], "vertical": true, "font_size": 28.0, "lines": ["サトウタイキ", "５歳。", "さそり座ＡＢ型"]}, {"box": [877, 899, 900, 995], "vertical": true, "font_size": 20.0, "lines": ["お前は？"]}, {"box": [131, 733, 187, 839], "vertical": true, "font_size": 26.0, "lines": ["キミって", "変な奴な。"]}, {"box": [644, 1104, 734, 1368], "vertical": true, "font_size": 29.0, "lines": ["お前って", "タスク。", "言うなよ、", "年上に。"]}, {"box": [110, 1181, 193, 1346], "vertical": true, "font_size": 22.0, "lines": ["タスクは", "生まれ変わりを", "信じるか？"]}], "img_path": "200.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [840, 79, 897, 238], "vertical": true, "font_size": 25.0, "lines": ["でも体は", "ただの子供だ。"]}, {"box": [282, 107, 343, 278], "vertical": true, "font_size": 25.0, "lines": ["そーこーしてる", "うちに、"]}, {"box": [887, 654, 917, 790], "vertical": true, "font_size": 26.0, "lines": ["え、終わり？"]}, {"box": [642, 376, 697, 584], "vertical": true, "font_size": 25.0, "lines": ["すぐ眠くなるし、", "コーヒーはまずい。"]}, {"box": [126, 233, 262, 570], "vertical": true, "font_size": 25.0, "lines": ["終わり。", "心の傷の癒えた", "彼女は別の男と", "幸せな結婚を", "するんだとさ。"]}, {"box": [815, 789, 840, 888], "vertical": true, "font_size": 26.0, "lines": ["オチは！？"]}, {"box": [715, 1039, 755, 1088], "vertical": false, "font_size": 17.0, "lines": ["いなると"]}, {"box": [629, 1057, 700, 1158], "vertical": false, "font_size": 19.0, "lines": ["それはガチンで", "そんにちょっ"]}, {"box": [99, 720, 188, 947], "vertical": true, "font_size": 25.0, "lines": ["つーか、さっきから", "気になってんだけど、", "この手紙、何？"]}, {"box": [845, 1078, 872, 1195], "vertical": true, "font_size": 26.0, "lines": ["．．．あっ！"]}, {"box": [95, 1039, 209, 1386], "vertical": true, "font_size": 25.0, "lines": ["そうだ、もう", "行かなくちゃ。", "ちょっと屋上に", "行っていいかな？"]}], "img_path": "201.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [835, 88, 951, 241], "vertical": true, "font_size": 25.0, "lines": ["．．．．．．さぁ、", "あいにく俺は", "そういうの", "興味ないなぁ。"]}, {"box": [539, 65, 653, 268], "vertical": true, "font_size": 23.0, "lines": ["昔．．．．．．つーか、", "けっこー最近の昔、", "ある男が", "死んだんだ"]}, {"box": [101, 151, 186, 334], "vertical": true, "font_size": 23.0, "lines": ["でも、その男には", "フツーに仲いい", "恋人がいたのな。"]}, {"box": [853, 617, 937, 810], "vertical": true, "font_size": 24.0, "lines": ["残してきた彼女が", "気がかりな男は", "こう頼んだんだ。"]}, {"box": [151, 419, 206, 542], "vertical": true, "font_size": 25.0, "lines": ["ははは、", "なんの話？"]}, {"box": [727, 778, 811, 972], "vertical": true, "font_size": 24.0, "lines": ["「彼女の側に", "生まれ変わらせて", "くれ」って。"]}, {"box": [293, 678, 350, 850], "vertical": true, "font_size": 26.0, "lines": ["頼んだって．．．", "誰に？"]}, {"box": [243, 846, 276, 919], "vertical": true, "font_size": 32.0, "lines": ["ネコ。"]}, {"box": [141, 966, 171, 1043], "vertical": true, "font_size": 30.0, "lines": ["猫ぉ？"]}, {"box": [795, 1126, 886, 1319], "vertical": true, "font_size": 29.0, "lines": ["そしたらホントに", "そーなったん", "だよ。"]}, {"box": [279, 1178, 360, 1345], "vertical": true, "font_size": 24.0, "lines": ["男の魂は", "半分だけ生まれ", "変わったんだ。"]}, {"box": [153, 1246, 207, 1397], "vertical": true, "font_size": 24.0, "lines": ["前世の記憶を", "残したままで。"]}], "img_path": "202.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1476, "blocks": [{"box": [866, 89, 948, 295], "vertical": true, "font_size": 23.0, "lines": ["この手紙", "今は遠くにいる", "コからもらってさ。"]}, {"box": [739, 190, 823, 432], "vertical": true, "font_size": 23.0, "lines": ["今日は流れ星が", "たくさん見られるって", "書いてあってさ。"]}, {"box": [578, 117, 602, 240], "vertical": true, "font_size": 20.0, "lines": ["．．．．．．彼女？"]}, {"box": [366, 112, 425, 223], "vertical": true, "font_size": 29.0, "lines": ["はは、", "違う違う。"]}, {"box": [99, 386, 154, 544], "vertical": true, "font_size": 24.0, "lines": ["．．．でも、すごく", "大切な人だよ。"]}, {"box": [736, 969, 881, 1336], "vertical": true, "font_size": 23.0, "lines": ["男の魂がまた", "一つになって", "消えちゃうとこで", "終わるんだ。", "．．．さっきの", "話は．．．"]}, {"box": [140, 1154, 282, 1392], "vertical": true, "font_size": 24.0, "lines": ["わかるんだよ。", "この頃、向こうと", "こっちの意識が", "霧がかかったみたいに", "あやふやだから。"]}], "img_path": "203.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1476, "blocks": [{"box": [703, 121, 913, 425], "vertical": true, "font_size": 24.0, "lines": ["でも、いいんだ。", "やっぱそれが", "自然なのさ。", "いろんなことを", "忘れながら、", "いずれはみんな", "死んで．．．．．．"]}, {"box": [246, 116, 304, 295], "vertical": true, "font_size": 26.0, "lines": ["そしていつかは", "世界も終わって、"]}, {"box": [126, 266, 216, 436], "vertical": true, "font_size": 26.0, "lines": ["全部が全部", "なかったことに", "なるんだから。"]}, {"box": [758, 608, 815, 787], "vertical": true, "font_size": 28.0, "lines": ["．．．つまんねーよ、", "その話。"]}, {"box": [119, 533, 311, 889], "vertical": true, "font_size": 25.0, "lines": ["そいつは", "宇宙の王様か？", "そういう諦め方", "した時点で、", "そいつは確かに", "終わったよ。"]}, {"box": [844, 971, 874, 1047], "vertical": true, "font_size": 30.0, "lines": ["だろ？"]}, {"box": [403, 1040, 517, 1232], "vertical": true, "font_size": 25.0, "lines": ["だって考えれば", "やれること、まだ", "たくさん残ってる", "ハズじゃんか。"]}, {"box": [108, 1255, 161, 1395], "vertical": true, "font_size": 25.0, "lines": ["．．．うん？", "眠くなった？"]}], "img_path": "204.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [843, 76, 931, 288], "vertical": true, "font_size": 27.0, "lines": ["たとえばこんな一見", "無意味な", "一本の線でも、"]}, {"box": [494, 90, 551, 288], "vertical": true, "font_size": 25.0, "lines": ["キミとネコの間に", "境界ができた。"]}, {"box": [90, 130, 202, 506], "vertical": true, "font_size": 27.0, "lines": ["こんなふうに", "なる。", "もう少し", "複雑にすると、"]}, {"box": [514, 706, 545, 808], "vertical": true, "font_size": 28.0, "lines": ["ニャー"]}, {"box": [164, 824, 221, 1007], "vertical": true, "font_size": 25.0, "lines": ["ホラ、もうキミは", "行くべきなんだ。"]}, {"box": [86, 1214, 143, 1418], "vertical": true, "font_size": 26.0, "lines": ["「．．．あなたは", "なんなんですか？」"]}], "img_path": "205.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [683, 37, 710, 220], "vertical": true, "font_size": 24.0, "lines": ["気がつくと私は、"]}, {"box": [837, 309, 864, 375], "vertical": true, "font_size": 25.0, "lines": ["さあ。"]}, {"box": [560, 31, 699, 279], "vertical": true, "font_size": 22.0, "lines": ["なんだかフワフワした", "場所にいた。"]}, {"box": [380, 35, 465, 214], "vertical": true, "font_size": 25.0, "lines": ["バスはもう", "どこかへ行って", "しまったようだ。"]}, {"box": [264, 35, 319, 154], "vertical": true, "font_size": 24.0, "lines": ["他の乗客の", "姿もない。"]}, {"box": [725, 385, 808, 569], "vertical": true, "font_size": 25.0, "lines": ["他の人たちは", "もう先に", "行っちゃったよ。"]}, {"box": [737, 982, 870, 1211], "vertical": true, "font_size": 26.0, "lines": ["私は少し考えて", "こう言ってみた。", "「ずっとここにいては", "ダメですか？」"]}, {"box": [634, 952, 661, 1017], "vertical": true, "font_size": 26.0, "lines": ["ダメー"]}, {"box": [140, 614, 265, 857], "vertical": true, "font_size": 25.0, "lines": ["キミだっていつまでも", "バスと共に", "彷徨っているワケに", "いかないんだよ"]}, {"box": [516, 1047, 602, 1192], "vertical": true, "font_size": 26.0, "lines": ["ここには", "何もあっちゃ", "いけないの"]}, {"box": [115, 1001, 229, 1407], "vertical": true, "font_size": 24.0, "lines": ["ホラ、キミとネコが", "意味すらも！！", "いるがために、", "影が生まれて", "しまっている。"]}], "img_path": "206.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [626, 202, 746, 426], "vertical": true, "font_size": 27.0, "lines": ["ネコは", "いつか終わる世界を", "ただ見てる．．．", "それだけだよ。"]}, {"box": [359, 899, 444, 1044], "vertical": true, "font_size": 25.0, "lines": ["私はこれから", "どこへ行くん", "ですか？"]}], "img_path": "207.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [649, 260, 671, 359], "vertical": true, "font_size": 20.0, "lines": ["．．．さぁ？"]}, {"box": [705, 422, 755, 452], "vertical": false, "font_size": 27.0, "lines": ["．．．"]}, {"box": [344, 575, 405, 780], "vertical": true, "font_size": 32.0, "lines": ["ただ", "言えるのは"]}], "img_path": "208.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [853, 107, 910, 279], "vertical": true, "font_size": 28.0, "lines": ["幸せになれると", "いいな。"]}, {"box": [448, 67, 634, 322], "vertical": true, "font_size": 26.0, "lines": ["はは、なんか", "不思議だ。", "きっと今頃、", "ハル子のヤツも", "口開けてこの空を", "見てんだろうな。"]}, {"box": [129, 293, 222, 665], "vertical": true, "font_size": 25.0, "lines": ["また、そんなこと", "意味がないって", "ん？", "思った？"]}, {"box": [838, 780, 951, 963], "vertical": true, "font_size": 24.0, "lines": ["意味があるとか", "ないとか", "理屈はどうでも", "いいじゃないか"]}, {"box": [582, 1163, 702, 1397], "vertical": true, "font_size": 25.0, "lines": ["要はどっちを", "信じれば幸せな気分に", "なれるかって、", "ことだと思うよ。"]}, {"box": [80, 995, 193, 1382], "vertical": true, "font_size": 25.0, "lines": ["．．．ってオイ、", "聞いてる？", "．．．．．．寝ちゃった", "か．．．．．．"]}], "img_path": "209.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [807, 369, 867, 683], "vertical": true, "font_size": 27.0, "lines": ["流れ星だっ。", "あっ。"]}, {"box": [135, 479, 273, 794], "vertical": true, "font_size": 26.0, "lines": ["あー、今日は", "流星群の見える", "目らしいよ。", "願いごとでも", "しとく？"]}, {"box": [866, 834, 923, 1007], "vertical": true, "font_size": 25.0, "lines": ["．．．で、", "話なんだっけ？"]}, {"box": [545, 869, 572, 1002], "vertical": true, "font_size": 24.0, "lines": ["仕方ないさ。"]}, {"box": [604, 1032, 724, 1385], "vertical": true, "font_size": 26.0, "lines": ["今日、結局", "泣いちゃいそうで、", "うん、", "みんなにお別れの", "挨拶できなくてさ。"]}, {"box": [77, 1009, 224, 1381], "vertical": true, "font_size": 26.0, "lines": ["．．．特に", "タイキくんって子、", "変わってたけど", "なんかほっとけない", "あの子．．．", "子でさ．．．"]}], "img_path": "210.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [419, 1196, 592, 1255], "vertical": false, "font_size": 24.0, "lines": ["ひかりのまち", "．．．"]}, {"box": [420, 1196, 592, 1255], "vertical": false, "font_size": 32.0, "lines": ["ひかりのまち"]}], "img_path": "211.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [], "img_path": "212.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [758, 184, 787, 469], "vertical": true, "font_size": 26.0, "lines": ["あー、なんか遠い世界だ。"]}, {"box": [636, 184, 661, 444], "vertical": true, "font_size": 26.0, "lines": ["昔の自分も今の自身を"]}, {"box": [576, 184, 601, 522], "vertical": true, "font_size": 26.0, "lines": ["イメージできてなかったけど。"]}, {"box": [451, 184, 476, 394], "vertical": true, "font_size": 26.0, "lines": ["それがもう１年前"]}, {"box": [326, 184, 351, 542], "vertical": true, "font_size": 26.0, "lines": ["救急車に乗ったし。入院したし、"]}, {"box": [200, 183, 228, 429], "vertical": true, "font_size": 26.0, "lines": ["普段は忘れてるけど。"]}, {"box": [696, 183, 725, 646], "vertical": true, "font_size": 26.0, "lines": ["自分とこの街がイメージで結びつかない。"]}, {"box": [384, 181, 416, 699], "vertical": true, "font_size": 26.0, "lines": ["今にして思えばいろいろ辛い時期だったかも。"]}, {"box": [265, 184, 290, 623], "vertical": true, "font_size": 26.0, "lines": ["僕の体にはいまだにに手術跡が残ってる。"]}], "img_path": "213.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [860, 77, 896, 237], "vertical": true, "font_size": 30.0, "lines": ["あとがき"]}, {"box": [689, 166, 709, 551], "vertical": true, "font_size": 23.0, "lines": ["この漫画のタイトルを決めたあと、"]}, {"box": [503, 168, 528, 535], "vertical": true, "font_size": 23.0, "lines": ["無理矢理、彼女も連れていった。"]}, {"box": [379, 166, 405, 535], "vertical": true, "font_size": 25.0, "lines": ["いかにも高級そうなマンションに"]}, {"box": [319, 170, 343, 428], "vertical": true, "font_size": 25.0, "lines": ["囲まれたその住宅街は"]}, {"box": [193, 168, 221, 370], "vertical": true, "font_size": 25.0, "lines": ["ヘンに静かだった。"]}, {"box": [625, 166, 649, 579], "vertical": true, "font_size": 23.0, "lines": ["はじめて取材のために電車に乗った。"]}, {"box": [565, 167, 589, 609], "vertical": true, "font_size": 23.0, "lines": ["本当は彼女と遊ぶ予定だったのだけど"]}, {"box": [257, 170, 281, 619], "vertical": true, "font_size": 25.0, "lines": ["日曜の昼のくせになぜか人がいなくって、"]}, {"box": [134, 168, 167, 624], "vertical": true, "font_size": 32.0, "lines": ["上近くのデパートは家族連れで薇尖った。"]}, {"box": [134, 174, 158, 624], "vertical": true, "font_size": 25.0, "lines": ["〈近くのデパートは家族連れで溢れてた"]}], "img_path": "214.png"}, {"version": "0.1.6", "img_width": 1957, "img_height": 1400, "blocks": [{"box": [1794, 81, 1829, 235], "vertical": true, "font_size": 32.0, "lines": ["あとがき"]}, {"box": [1630, 162, 1658, 529], "vertical": true, "font_size": 26.0, "lines": ["この漫画のタイトルを決めたあと、"]}, {"box": [1462, 168, 1486, 511], "vertical": true, "font_size": 26.0, "lines": ["無理矢理、彼女も連れていった。"]}, {"box": [1341, 166, 1372, 511], "vertical": true, "font_size": 25.0, "lines": ["いかにも高級そうなマンションに"]}, {"box": [1288, 168, 1312, 416], "vertical": true, "font_size": 25.0, "lines": ["囲まれたその住宅街は、"]}, {"box": [1171, 168, 1196, 355], "vertical": true, "font_size": 25.0, "lines": ["ヘンに静かだった。"]}, {"box": [1572, 164, 1601, 553], "vertical": true, "font_size": 26.0, "lines": ["はじめて取材のために電車に乗った。"]}, {"box": [1515, 164, 1544, 582], "vertical": true, "font_size": 26.0, "lines": ["本当は彼女と遊ぶ予定だったのだけど、"]}, {"box": [1226, 164, 1257, 593], "vertical": true, "font_size": 25.0, "lines": ["日曜の昼のくせになぜか人がいなくって、"]}, {"box": [1114, 169, 1140, 597], "vertical": true, "font_size": 25.0, "lines": ["〈近くのデパートは家族連れで溢れてた"]}, {"box": [703, 171, 731, 437], "vertical": true, "font_size": 26.0, "lines": ["あー、なんか遠い世界だ。"]}, {"box": [588, 171, 613, 412], "vertical": true, "font_size": 26.0, "lines": ["昔の自分も今の自然を"]}, {"box": [531, 171, 558, 483], "vertical": true, "font_size": 26.0, "lines": ["イメージできてなかったけど、"]}, {"box": [416, 173, 443, 370], "vertical": true, "font_size": 26.0, "lines": ["それがもう１年前"]}, {"box": [300, 173, 326, 508], "vertical": true, "font_size": 26.0, "lines": ["救急車に乗ったし。入院したし、"]}, {"box": [187, 173, 212, 401], "vertical": true, "font_size": 26.0, "lines": ["普段は忘れてるけど。"]}, {"box": [647, 173, 672, 605], "vertical": true, "font_size": 26.0, "lines": ["自分とこの街がイメー「ジで結びつかない。"]}, {"box": [359, 173, 386, 655], "vertical": true, "font_size": 26.0, "lines": ["今にして思えばいろいろ辛い時期だったかも。"]}, {"box": [244, 173, 269, 582], "vertical": true, "font_size": 26.0, "lines": ["僕の体にはいまだにに手術跡が残ってる。"]}], "img_path": "215.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [866, 183, 891, 529], "vertical": true, "font_size": 25.0, "lines": ["あの頃、ブラブラしてた友達は"]}, {"box": [804, 181, 831, 492], "vertical": true, "font_size": 25.0, "lines": ["もうちゃんと働いていたり、"]}, {"box": [744, 183, 769, 464], "vertical": true, "font_size": 25.0, "lines": ["まだプラプラしてたりで"]}, {"box": [683, 181, 708, 523], "vertical": true, "font_size": 25.0, "lines": ["僕は今日も漫画を描いている。"]}, {"box": [497, 184, 517, 484], "vertical": true, "font_size": 22.0, "lines": ["最近、日が経つのが早いな。"]}, {"box": [372, 183, 397, 428], "vertical": true, "font_size": 22.0, "lines": ["明日も漫画を描こう。"]}, {"box": [246, 180, 276, 400], "vertical": true, "font_size": 25.0, "lines": ["それだけなんです。"]}, {"box": [560, 186, 580, 636], "vertical": true, "font_size": 22.0, "lines": ["だからなんだってワケじゃないんだけど"]}, {"box": [432, 180, 457, 601], "vertical": true, "font_size": 22.0, "lines": ["もし僕にまだ時間が残されてるなら"]}, {"box": [124, 369, 148, 629], "vertical": true, "font_size": 19.0, "lines": ["２００５年、春、浅野いにお"]}], "img_path": "216.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [427, 540, 598, 916], "vertical": false, "font_size": 20.0, "lines": ["Ｄｉｒｅｃｈｏｒ", "ＴｏｋｉｅＫｏｍｕｒｏ", "Ｅｄｉｎｏｒ", "ＳｈｏｕｉｌＭｕｋｏｉ", "「ＨｏｍＣｈＮＳＡＮＳＨＡ", "ＴＨｅｔｙｐｏｇｒｏｐｈｅｒ", "Ｋａｔｓｕｏｌｓｈｉｇｕｒｏ", "ｆｏｎ．ＳＥＥＳＡＫＬＳＨＡＭ", "ＢｏｏｋＤｅｓｇｉｎｅｒ", "ＹｏｓｈｉｖｕｋｉＳｅｋｉ", "ｆｒｏｎＶＯＬＡＲＥｉｎｃ．", "Ａｎａｓｈｏｒｙ"]}, {"box": [420, 877, 604, 935], "vertical": false, "font_size": 28.0, "lines": ["ＩｎｉｏＡｓｏｎｏ"]}], "img_path": "217.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [{"box": [85, 90, 369, 136], "vertical": false, "font_size": 32.0, "lines": ["ひかりのまち"]}, {"box": [82, 189, 359, 218], "vertical": false, "font_size": 32.0, "lines": ["サンデーＧＸコミックス"]}, {"box": [162, 680, 543, 748], "vertical": false, "font_size": 28.0, "lines": ["２００５年７月２０日初版第１刷発行", "２００９年２月２０日", "第２０刷発行"]}, {"box": [577, 624, 860, 645], "vertical": false, "font_size": 21.0, "lines": ["ＢＮ４－０９－１５７２１３－８"]}, {"box": [758, 680, 863, 705], "vertical": false, "font_size": 25.0, "lines": ["（検印廃止）"]}, {"box": [164, 836, 196, 861], "vertical": false, "font_size": 25.0, "lines": ["著"]}, {"box": [162, 944, 243, 1020], "vertical": false, "font_size": 28.0, "lines": ["発行者", "印刷所"]}, {"box": [406, 919, 434, 971], "vertical": true, "font_size": 28.0, "lines": ["片"]}, {"box": [406, 833, 620, 863], "vertical": false, "font_size": 30.0, "lines": ["浅野いにお"]}, {"box": [463, 946, 500, 969], "vertical": false, "font_size": 23.0, "lines": ["寄"]}, {"box": [407, 890, 653, 924], "vertical": false, "font_size": 31.0, "lines": ["©Ｉｎｉｏ．Ａｓａｎｏ－２００５"]}, {"box": [82, 1073, 750, 1157], "vertical": false, "font_size": 23.666666666666668, "lines": ["「月刊サンデーＧＸ」１０４年５月号ー７月号、９月号〜＇０５年２月号掲載作品", "単行本編集責任／久保田滋夫", "単行本編集／銀杏社"]}, {"box": [412, 998, 620, 1019], "vertical": false, "font_size": 21.0, "lines": ["図書印刷株式会社"]}, {"box": [592, 947, 621, 971], "vertical": false, "font_size": 24.0, "lines": ["聰"]}, {"box": [705, 1032, 868, 1051], "vertical": false, "font_size": 19.0, "lines": ["ＰｒｉｎｔｅｄｉｎＪａｐａｎ"]}, {"box": [89, 1201, 203, 1235], "vertical": false, "font_size": 32.0, "lines": ["発行所"]}, {"box": [253, 1180, 810, 1265], "vertical": false, "font_size": 26.666666666666668, "lines": ["（〒１０１－８００１）東京都千代田区ーツ橋二の三の", "第１１回目を７月１２日、最新のＣＲＵＲＯＲＩＳＥＯＲＯＳＩＣＥによりますが、", "販売ＯＳ（５２８１）５５５条社"]}, {"box": [81, 1289, 810, 1457], "vertical": false, "font_size": 20.0, "lines": ["●遊本には十分注意しておりますが、落下席で購入する事になる間違いで２０１７年のページの投げ落ちや朝夜の問題をしたいと思いますが、いつの場合はお取り替えいたします。私も、ユーユが", "２０１４年には「久生感し」の購入された書店名を明記したＷｅｂファイルのちょっと後悔したいやハーンなので、ご飯付け時のあてにお送りください。ちゃ無事や問題の場合はお母さんの社員担にてお取り替えいたします。", "納付時（日）２１：０１２月１３日－０８／", "前日向けてしまいましょうか。●本書の一部あるいは全部を無視であげないことが出来ます。複製状観：上演・放送等をすることがまずまとんじゃいけとは、法律で認められた場合を除き、", "本書の一部の多くは土地を著作者および出版者の権利の無視で、投資となります。あらかじめり社あることは、伝統したので詐諾をお求めください。", "Ｒ（日本複写権センタ一委託出版物", "お客さんは今回はインターネットの本書を無断で検索したコピートすることは、確定して例外を除き禁じられています。このＷｉｎｄｏｗｓｗｅｔｔｅｒです。", "本書を無効に使う人数にピピーター本番をコピーされる場合は、事前にはアロッパングのこれらの作品というのはどれぞれに対しています。被害権センター（２０１８）の発売を受けてください。あところではない。", "本書をフビーさんの場合は、「ＲＲＣ」（ＲＣ）（Ｃ）Ｃ（ｄｉｔｐ／／ｗｗｗｉｔｙｒｉｃｅｒの１００４．００．ｅメール：ｈｔｏ＠ｊｒｃ．２０１７年前を受けてください。ｏｒｔ．ｐ．ＴＨＥＬＯＢ－３０１－２８の"]}], "img_path": "218.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1466, "blocks": [{"box": [161, 488, 176, 621], "vertical": true, "font_size": 15.0, "lines": ["．．．"]}, {"box": [173, 443, 350, 482], "vertical": false, "font_size": 30.0, "lines": ["素晴らしい世界"]}, {"box": [117, 468, 227, 787], "vertical": true, "font_size": 21.75, "lines": ["それでも、", "それでも、", "．．．", "それでも、"]}, {"box": [286, 492, 300, 631], "vertical": true, "font_size": 14.0, "lines": ["．．．"]}, {"box": [304, 485, 347, 629], "vertical": true, "font_size": 19.5, "lines": ["．．．", "そうだな．．．そういうことですから、それではないのでしょうか"]}, {"box": [347, 522, 362, 618], "vertical": true, "font_size": 15.0, "lines": ["．．．！！！？"]}, {"box": [366, 516, 386, 621], "vertical": true, "font_size": 16.0, "lines": ["．．．"]}, {"box": [433, 712, 608, 741], "vertical": false, "font_size": 26.0, "lines": ["楽しくも切なく、"]}, {"box": [430, 657, 758, 691], "vertical": false, "font_size": 26.0, "lines": ["僕らの生きる優しくも悲しく、"]}, {"box": [462, 609, 900, 629], "vertical": false, "font_size": 26.0, "lines": ["．．．生きていればきっといことがある"]}, {"box": [177, 913, 357, 957], "vertical": false, "font_size": 26.0, "lines": ["羨まらしい世界"]}, {"box": [436, 767, 665, 794], "vertical": false, "font_size": 26.0, "lines": ["そして強くはかない"]}, {"box": [435, 821, 734, 846], "vertical": false, "font_size": 26.0, "lines": ["この素晴らしいい世界で．．．"]}, {"box": [429, 1344, 584, 1362], "vertical": false, "font_size": 18.0, "lines": ["定価：各５６０円（税込）"]}, {"box": [430, 1176, 902, 1340], "vertical": false, "font_size": 30.0, "lines": ["ＧＸ新人賞出身の若き新鋭が描く", "連作読み切りシリーズ、絶賛発売中", "『素晴らしい〝世界』全２巻", "美野いにお"]}], "img_path": "219.png"}, {"version": "0.1.6", "img_width": 1022, "img_height": 1502, "blocks": [], "img_path": "220.png"}]}