.0, 1175.0], [418.0, 1175.0], [418.0, 1373.0], [387.0, 1373.0]]], "lines": ["それって結局のところ", "プサイクだった名越さんも", "同じく、現実逃避から", "願望の渦にどっぷりと", "漬かってたって", "だけですよね。"]}, {"box": [114, 1274, 135, 1361], "vertical": true, "font_size": 21, "lines_coords": [[[114.0, 1274.0], [135.0, 1274.0], [135.0, 1361.0], [114.0, 1361.0]]], "lines": ["．．．．．．"]}], "img_path": "123.png"}, {"version": "0.1.7", "img_width": 1109, "img_height": 1600, "blocks": [{"box": [941, 42, 984, 114], "vertical": true, "font_size": 43, "lines_coords": [[[941.0, 42.0], [984.0, 42.0], [984.0, 114.0], [941.0, 114.0]]], "lines": ["で？"]}, {"box": [716, 256, 751, 325], "vertical": true, "font_size": 35, "lines_coords": [[[716.0, 259.0], [751.0, 259.0], [751.0, 325.0], [716.0, 325.0]]], "lines": ["で？"]}, {"box": [543, 26, 604, 190], "vertical": true, "font_size": 28, "lines_coords": [[[571.0, 26.0], [604.0, 26.0], [604.0, 112.0], [571.0, 112.0]], [[543.0, 29.0], [566.0, 29.0], [568.0, 189.0], [545.0, 189.0]]], "lines": ["そんな", "素敵なブスに、"]}, {"box": [42, 165, 130, 323], "vertical": true, "font_size": 26, "lines_coords": [[[103.0, 167.0], [129.0, 167.0], [129.0, 271.0], [103.0, 271.0]], [[73.0, 165.0], [99.0, 165.0], [99.0, 323.0], [73.0, 323.0]], [[42.0, 167.0], [68.0, 167.0], [68.0, 271.0], [42.0, 271.0]]], "lines": ["３か月も", "見てもらった", "末に．．．"]}, {"box": [465, 489, 581, 615], "vertical": true, "font_size": 33, "lines_coords": [[[542.0, 489.0], [581.0, 489.0], [581.0, 587.0], [542.0, 587.0]], [[509.0, 493.0], [537.0, 493.0], [537.0, 615.0], [509.0, 615.0]], [[468.0, 489.0], [501.0, 489.0], [498.0, 615.0], [465.0, 615.0]]], "lines": ["なんで", "別れたん", "ですか？"]}, {"box": [82, 758, 103, 805], "vertical": true, "font_size": 21, "lines_coords": [[[82.0, 758.0], [103.0, 758.0], [103.0, 805.0], [82.0, 805.0]]], "lines": ["！"]}, {"box": [923, 1064, 985, 1173], "vertical": true, "font_size": 30, "lines_coords": [[[952.0, 1064.0], [985.0, 1064.0], [985.0, 1173.0], [952.0, 1173.0]], [[923.0, 1065.0], [951.0, 1065.0], [951.0, 1170.0], [9