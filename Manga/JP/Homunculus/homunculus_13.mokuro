25.0], [640.0, 1025.0], [640.0, 1075.0], [616.0, 1075.0]]], "lines": ["！"]}, {"box": [284, 1112, 312, 1294], "vertical": true, "font_size": 26, "lines_coords": [[[284.0, 1112.0], [310.0, 1112.0], [310.0, 1292.0], [284.0, 1292.0]]], "lines": ["逆に有機質．．．"]}], "img_path": "109.png"}, {"version": "0.1.7", "img_width": 1106, "img_height": 1600, "blocks": [{"box": [438, 281, 509, 490], "vertical": true, "font_size": 33, "lines_coords": [[[465.0, 281.0], [504.0, 281.0], [504.0, 368.0], [465.0, 368.0]], [[438.0, 284.0], [465.0, 284.0], [467.0, 490.0], [440.0, 490.0]]], "lines": ["象徴で", "見る女だった．．．"]}, {"box": [251, 21, 331, 118], "vertical": true, "font_size": 72, "lines_coords": [[[251.0, 28.0], [323.0, 21.0], [331.0, 112.0], [259.0, 118.0]]], "lines": ["花、"]}, {"box": [43, 43, 107, 125], "vertical": true, "font_size": 64, "lines_coords": [[[43.0, 43.0], [107.0, 43.0], [107.0, 125.0], [43.0, 125.0]]], "lines": ["風、"]}, {"box": [279, 257, 335, 503], "vertical": true, "font_size": 42, "lines_coords": [[[279.0, 257.0], [335.0, 257.0], [335.0, 429.0], [279.0, 429.0]], [[293.0, 417.0], [320.0, 417.0], [320.0, 503.0], [293.0, 503.0]]], "lines": ["火～～～", "く？"]}, {"box": [890, 387, 951, 519], "vertical": true, "font_size": 30, "lines_coords": [[[916.0, 387.0], [951.0, 387.0], [951.0, 479.0], [916.0, 479.0]], [[890.0, 389.0], [916.0, 389.0], [916.0, 518.0], [890.0, 518.0]]], "lines": ["花や風、", "火など．．．"]}, {"box": [399, 690, 622, 946], "vertical": true, "font_size": 34, "lines_coords": [[[588.0, 695.0], [620.0, 695.0], [620.0, 943.0], [588.0, 943.0]], [[553.0, 695.0], [584.0, 695.0], [581.0, 915.0], [549.0, 915.0]], [[509.0, 690.0], [551.0, 690.0], [548.0, 946.0], [506.0, 946.0]], [[476.0, 698.0], [507.0, 698.0], [507.0, 945.0], [476.0, 945.0]], [[434.0, 696.0], [467.0, 696.0], [470.0, 943.0], [437.0, 943.0]], [[399.0, 698.0], [431.0, 698.0], [431.0, 900.0], [399.0, 900.0]]], "lines": ["そんな、人のこと", "「花みたいな人」", "とか、イメージで", "表現する人なんて", "腐るほどいるじゃ", "ないですかぁ。"]}, {"box": [64, 992, 170, 1117], "vertical": true, "font_size": 38, "lines_coords": [[[126.0, 992.0], [170.0, 992.0], [170.0, 1065.0], [126.0, 1065.0]], [[93.0, 996.0], [126.0, 996.0], [126.0, 1117.0], [93.0, 1117.0]]], "lines": ["特に", "女に多い"]}, {"box": [588, 1262, 647, 1442], "vertical": true, "font_size": 25, "lines_coords": [[[620.0, 1264.0], [646.0, 1264.0], [646.0, 1392.0], [620.0, 1392.0]], [[588.0, 1262.0], [612.0, 1262.0], [613.0, 1439.0], [590.0, 1439.0]]], "lines": ["俺も最初は", "そう思った．．．"]}, {"box": [329, 1400, 352, 1485], "vertical": true, "font_size": 18, "lines_coords": [[[331.0, 1450.0], [349.0, 1450.0], [349.0, 1479.0], [331.0, 1479.0]]], "lines": ["？"]}], "img_path": "110.png"}, {"version": "0.1.7", "img_width": 1106, "img_height": 1600, "blocks": [{"box": [1002, 54, 1059, 218], "vertical": true, "font_size": 27, "lines_coords": [[[1032.0, 54.0], [1059.0, 54.0], [1059.0, 159.0], [1032.0, 159.0]], [[1002.0, 54.0], [1029.0, 54.0], [1029.0, 214.0], [1002.0, 214.0]]], "lines": ["ななこは", "オレと違って、"]}, {"box": [342, 96, 431, 234], "vertical": true, "font_size": 25, "lines_coords": [[[406.0, 98.0], [428.0, 98.0], [428.0, 223.0], [406.0, 223.0]], [[373.0, 96.0], [399.0, 96.0], [399.0, 231.0], [373.0, 231.0]], [[342.0, 96.0], [368.0, 96.0], [368.0, 210.0], [342.0, 210.0]]], "lines": ["確かに絵が", "下手ですね、", "名越さん。"]}, {"box": [122, 263, 139, 320], "vertical": true, "font_size": 17, "lines_coords": [[[122.0, 263.0], [139.0, 263.0], [139.0, 320.0], [122.0, 320.0]]], "lines": ["．．．．．．"]}, {"box": [756, 395, 815, 561], "vertical": true, "font_size": 27, "lines_coords": [[[787.0, 396.0], [815.0, 396.0], [815.0, 525.0], [787.0, 525.0]], [[756.0, 395.0], [782.0, 395.0], [782.0, 560.0], [756.0, 560.0]]], "lines": ["デッサンの", "うまい女でな。"]}, {"box": [559, 409, 650, 569], "vertical": true, "font_size": 30, "lines_coords": [[[623.0, 414.0], [649.0, 414.0], [649.0, 543.0], [623.0, 543.0]], [[587.0, 409.0], [624.0, 409.0], [624.0, 473.0], [587.0, 473.0]], [[559.0, 410.0], [585.0, 410.0], [585.0, 567.0], [559.0, 567.0]]], "lines": ["鉛筆の柄を", "こう", "寝かせて．．．"]}, {"box": [256, 982, 357, 1239], "vertical": true, "font_size": 29, "lines_coords": [[[326.0, 982.0], [357.0, 982.0], [354.0, 1190.0], [323.0, 1190.0]], [[288.0, 984.0], [317.0, 984.0], [315.0, 1192.0], [287.0, 1192.0]], [[257.0, 982.0], [285.0, 982.0], [284.0, 1239.0], [256.0, 1239.0]]], "lines": ["デッサンしながら", "見えた「人の心」を", "見せてくれるんだ．．．"]}], "img_path": "111.png"}, {"version": "0.1.7", "img_width": 1105, "img_height": 1600, "blocks": [{"box": [572, 162, 696, 295], "vertical": true, "font_size": 29, "lines_coords": [[[667.0, 165.0], [695.0, 165.0], [695.0, 270.0], [667.0, 270.0]], [[637.0, 165.0], [664.0, 165.0], [664.0, 295.0], [637.0, 295.0]], [[601.0, 162.0], [634.0, 162.0], [634.0, 248.0], [601.0, 248.0]], [[572.0, 164.0], [600.0, 164.0], [600.0, 270.0], [572.0, 270.0]]], "lines": ["変わった", "デッサンを", "する女", "てな．．．．．"]}, {"box": [454, 579, 579, 864], "vertical": true, "font_size": 26, "lines_coords": [[[543.0, 579.0], [579.0, 579.0], [579.0, 642.0], [543.0, 642.0]], [[518.0, 587.0], [540.0, 587.0], [540.0, 864.0], [518.0, 864.0]], [[487.0, 585.0], [509.0, 585.0], [509.0, 765.0], [487.0, 765.0]], [[454.0, 584.0], [476.0, 584.0], [476.0, 771.0], [454.0, 771.0]]], "lines": ["まず", "白紙のスケッチブックを", "鉛筆で真っ黒に", "塗りつぶすんだ"]}, {"box": [919, 1145, 947, 1248], "vertical": true, "font_size": 28, "lines_coords": [[[919.0, 1145.0], [947.0, 1145.0], [947.0, 1246.0], [919.0, 1246.0]]], "lines": ["そこへ．．．"]}, {"box": [386, 1128, 508, 1306], "vertical": true, "font_size": 26, "lines_coords": [[[479.0, 1129.0], [506.0, 1129.0], [506.0, 1231.0], [479.0, 1231.0]], [[448.0, 1128.0], [475.0, 1128.0], [475.0, 1256.0], [448.0, 1256.0]], [[417.0, 1128.0], [443.0, 1128.0], [443.0, 1306.0], [417.0, 1306.0]], [[386.0, 1128.0], [412.0, 1128.0], [412.0, 1232.0], [386.0, 1232.0]]], "lines": ["黒に白で", "描くほうが", "「人間」っぽいん", "だと．．．"]}, {"box": [616, 1411, 706, 1540], "vertical": true, "font_size": 25, "lines_coords": [[[678.0, 1412.0], [704.0, 1412.0], [704.0, 1539.0], [678.0, 1539.0]], [[647.0, 1412.0], [673.0, 1412.0], [673.0, 1540.0], [647.0, 1540.0]], [[617.0, 1412.0], [639.0, 1412.0], [639.0, 1537.0], [617.0, 1537.0]]], "lines": ["消しゴムで", "表現する女", "だった．．．"]}, {"box": [70, 1365, 191, 1570], "vertical": true, "font_size": 26, "lines_coords": [[[162.0, 1365.0], [189.0, 1365.0], [189.0, 1543.0], [162.0, 1543.0]], [[128.0, 1365.0], [160.0, 1365.0], [160.0, 1570.0], [128.0, 1570.0]], [[101.0, 1368.0], [123.0, 1368.0], [123.0, 1493.0], [101.0, 1493.0]], [[70.0, 1367.0], [92.0, 1367.0], [92.0, 1492.0], [70.0, 1492.0]]], "lines": ["真っ黒い人間の", "闇に、微かな光で", "魂を形どる", "ように．．．"]}], "img_path": "112.png"}, {"version": "0.1.7", "img_width": 1107, "img_height": 1600, "blocks": [{"box": [115, 9, 864, 129], "vertical": false, "font_size": 73, "lines_coords": [[[115.0, 56.0], [859.0, 9.0], [864.0, 82.0], [120.0, 129.0]]], "lines": ["そんなことを言っていましたが、"]}, {"box": [880, 684, 941, 815], "vertical": true, "font_size": 30, "lines_coords": [[[906.0, 684.0], [941.0, 684.0], [941.0, 767.0], [906.0, 767.0]], [[880.0, 685.0], [906.0, 685.0], [906.0, 814.0], [880.0, 814.0]]], "lines": ["例えば", "こうだ．．．．．"]}, {"box": [548, 1014, 669, 1205], "vertical": true, "font_size": 26, "lines_coords": [[[642.0, 1014.0], [669.0, 1014.0], [669.0, 1096.0], [642.0, 1096.0]], [[611.0, 1015.0], [637.0, 1015.0], [637.0, 1193.0], [611.0, 1193.0]], [[578.0, 1015.0], [605.0, 1015.0], [605.0, 1170.0], [578.0, 1170.0]], [[548.0, 1014.0], [570.0, 1014.0], [570.0, 1203.0], [548.0, 1203.0]]], "lines": ["ある日、", "公園のベンチに", "座っていた時", "花を描いていた。"]}, {"box": [351, 985, 409, 1114], "vertical": true, "font_size": 28, "lines_coords": [[[381.0, 985.0], [409.0, 985.0], [409.0, 1089.0], [381.0, 1089.0]], [[351.0, 985.0], [378.0, 985.0], [378.0, 1114.0], [351.0, 1114.0]]], "lines": ["その花は", "花だが．．．"]}, {"box": [157, 978, 217, 1134], "vertical": true, "font_size": 28, "lines_coords": [[[189.0, 978.0], [217.0, 978.0], [214.0, 1134.0], [186.0, 1134.0]], [[157.0, 979.0], [186.0, 979.0], [186.0, 1092.0], [157.0, 1092.0]]], "lines": ["「早熟した花」", "だという。"]}], "img_path": "113.png"}, {"version": "0.1.7", "img_width": 1106, "img_height": 1600, "blocks": [{"box": [829, 78, 951, 214], "vertical": true, "font_size": 26, "lines_coords": [[[927.0, 79.0], [949.0, 79.0], [949.0, 212.0], [927.0, 212.0]], [[893.0, 79.0], [920.0, 79.0], [920.0, 207.0], [893.0, 207.0]], [[860.0, 78.0], [888.0, 78.0], [888.0, 181.0], [860.0, 181.0]], [[829.0, 79.0], [857.0, 79.0], [857.0, 185.0], [829.0, 185.0]]], "lines": ["目の前には、", "小学３年生", "くらいの", "女の子と、"]}, {"box": [421, 73, 512, 229], "vertical": true, "font_size": 25, "lines_coords": [[[487.0, 78.0], [509.0, 78.0], [509.0, 229.0], [487.0, 229.0]], [[453.0, 75.0], [479.0, 75.0], [479.0, 204.0], [453.0, 204.0]], [[421.0, 73.0], [448.0, 73.0], [448.0, 215.0], [421.0, 215.0]]], "lines": ["おじいちゃん", "らしき人が", "遊んでいた。"]}, {"box": [856, 679, 921, 799], "vertical": true, "font_size": 32, "lines_coords": [[[885.0, 679.0], [921.0, 681.0], [918.0, 743.0], [882.0, 742.0]], [[856.0, 684.0], [884.0, 684.0], [885.0, 793.0], [857.0, 793.0]]], "lines": ["花は", "わかるが、"]}, {"box": [59, 392, 147, 551], "vertical": true, "font_size": 25, "lines_coords": [[[118.0, 392.0], [145.0, 392.0], [145.0, 548.0], [118.0, 548.0]], [[89.0, 393.0], [115.0, 393.0], [112.0, 551.0], [85.0, 551.0]], [[59.0, 395.0], [81.0, 395.0], [81.0, 506.0], [59.0, 506.0]]], "lines": ["その女の子が", "「早熟した花」", "だという"]}, {"box": [109, 800, 201, 928], "vertical": true, "font_size": 28, "lines_coords": [[[168.0, 800.0], [201.0, 800.0], [201.0, 882.0], [168.0, 882.0]], [[142.0, 803.0], [164.0, 803.0], [164.0, 928.0], [142.0, 928.0]], [[109.0, 800.0], [137.0, 800.0], [137.0, 857.0], [109.0, 857.0]]], "lines": ["早熟が", "わからない", "．．．．．．"]}, {"box": [607, 1268, 760, 1434], "vertical": true, "font_size": 26, "lines_coords": [[[734.0, 1268.0], [760.0, 1268.0], [760.0, 1395.0], [734.0, 1395.0]], [[704.0, 1271.0], [726.0, 1271.0], [726.0, 1370.0], [704.0, 1370.0]], [[670.0, 1270.0], [696.0, 1270.0], [696.0, 1373.0]