]]], "lines": ["何が", "あったん", "ですか？"]}, {"box": [392, 604, 484, 745], "vertical": true, "font_size": 28, "lines_coords": [[[454.0, 606.0], [483.0, 606.0], [483.0, 709.0], [454.0, 709.0]], [[423.0, 604.0], [451.0, 604.0], [451.0, 712.0], [423.0, 712.0]], [[392.0, 607.0], [418.0, 607.0], [418.0, 743.0], [392.0, 743.0]]], "lines": ["ホテルの", "部屋まで", "ついてきて、"]}, {"box": [37, 607, 131, 745], "vertical": true, "font_size": 32, "lines_coords": [[[104.0, 610.0], [131.0, 610.0], [131.0, 742.0], [104.0, 742.0]], [[67.0, 607.0], [104.0, 607.0], [104.0, 745.0], [67.0, 745.0]], [[37.0, 609.0], [70.0, 609.0], [70.0, 703.0], [37.0, 703.0]]], "lines": ["何もさせな", "かった．．．", "あの女。"]}, {"box": [598, 876, 695, 1037], "vertical": true, "font_size": 35, "lines_coords": [[[656.0, 876.0], [695.0, 876.0], [695.0, 975.0], [656.0, 975.0]], [[625.0, 876.0], [664.0, 876.0], [664.0, 965.0], [625.0, 965.0]], [[598.0, 879.0], [625.0, 879.0], [625.0, 1037.0], [598.0, 1037.0]]], "lines": ["指一本、", "触れて", "いなかった．．．"]}, {"box": [401, 882, 464, 993], "vertical": true, "font_size": 30, "lines_coords": [[[436.0, 887.0], [464.0, 887.0], [464.0, 993.0], [436.0, 993.0]], [[401.0, 882.0], [434.0, 882.0], [434.0, 970.0], [401.0, 970.0]]], "lines": ["なんすか", "それ．．．"]}, {"box": [290, 1135, 325, 1228], "vertical": true, "font_size": 35, "lines_coords": [[[290.0, 1135.0], [325.0, 1135.0], [325.0, 1228.0], [290.0, 1228.0]]], "lines": ["寝顔の、"]}, {"box": [865, 1157, 966, 1267], "vertical": true, "font_size": 34, "lines_coords": [[[923.0, 1157.0], [966.0, 1157.0], [966.0, 1232.0], [923.0, 1232.0]], [[898.0, 1164.0], [925.0, 1164.0], [925.0, 1267.0], [898.0, 1267.0]], [[865.0, 1160.0], [897.0, 1160.0], [897.0, 1218.0], [865.0, 1218.0]]], "lines": ["だが、", "朝起きる", "と．．．"]}, {"box": [639, 1234, 762, 1404], "vertical": true, "font_size": 29, "lines_coords": [[[734.0, 1237.0], [761.0, 1237.0], [761.0, 1365.0], [734.0, 1365.0]], [[701.0, 1237.0], [729.0, 1237.0], [729.0, 1367.0], [701.0, 1367.0]], [[667.0, 1234.0], [701.0, 1234.0]