 668.0]]], "lines": ["背丈は同じ", "くらいだが", "細かいことは", "覚えていない"]}, {"box": [426, 707, 574, 889], "vertical": true, "font_size": 26, "lines_coords": [[[552.0, 712.0], [574.0, 712.0], [574.0, 839.0], [552.0, 839.0]], [[515.0, 707.0], [548.0, 707.0], [548.0, 795.0], [515.0, 795.0]], [[488.0, 710.0], [510.0, 710.0], [510.0, 889.0], [488.0, 889.0]], [[454.0, 710.0], [480.0, 710.0], [480.0, 842.0], [454.0, 842.0]], [[426.0, 714.0], [448.0, 714.0], [448.0, 825.0], [426.0, 825.0]]], "lines": ["女の家にも", "証拠に", "つながるような", "物は置いて", "なかった。"]}, {"box": [231, 525, 306, 668], "vertical": true, "font_size": 34, "lines_coords": [[[271.0, 528.0], [306.0, 528.0], [306.0, 623.0], [271.0, 623.0]], [[231.0, 526.0], [263.0, 525.0], [268.0, 667.0], [235.0, 668.0]]], "lines": ["わかり", "ましたっ。"]}, {"box": [515, 987, 635, 1179], "vertical": true, "font_size": 27, "lines_coords": [[[608.0, 987.0], [635.0, 987.0], [635.0, 1118.0], [608.0, 1118.0]], [[576.0, 989.0], [604.0, 989.0], [604.0, 1093.0], [576.0, 1093.0]], [[544.0, 989.0], [573.0, 989.0], [573.0, 1093.0], [544.0, 1093.0]], [[515.0, 987.0], [538.0, 987.0], [540.0, 1173.0], [516.0, 1173.0]]], "lines": ["とりあえず", "物理的な", "裏づけを", "取りましょうよ。"]}, {"box": [298, 960, 357, 1115], "vertical": true, "font_size": 27, "lines_coords": [[[327.0, 960.0], [356.0, 960.0], [357.0, 1115.0], [329.0, 1115.0]], [[298.0, 960.0], [324.0, 960.0], [324.0, 1076.0], [298.0, 1076.0]]], "lines": ["わかる範囲で", "結構です。"]}, {"box": [527, 1298, 552, 1338], "vertical": true, "font_size": 25, "lines_coords": [[[527.0, 1298.0], [552.0, 1298.0], [552.0, 1338.0], [527.0, 1338.0]]], "lines": ["？"]}, {"box": [282, 1167, 371, 1320], "vertical": true, "font_size": 27, "lines_coords": [[[345.0, 1171.0], [371.0, 1171.0], [371.0, 1295.0], [345.0, 1295.0]], [[313.0, 1167.0], [340.0, 1167.0], [340.0, 1320.0], [313.0, 1320.0]], [[282.0, 1167.0], [309.0, 1167.0], [309.0, 1273.0], [282.0, 1273.0]]], "lines": ["モトカノの", "情報を教えて", "ください"]}], "img_path": "216.png"}, {"version": "0.1.7", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [944, 50, 1006, 192], "vertical": true, "font_size": 27, "lines_coords": [[[978.0, 53.0], [1006.0, 53.0], [1006.0, 132.0], [978.0, 132.0]], [[944.0, 50.0], [970.0, 50.0], [975.0, 192.0], [948.0, 192.0]]], "lines": ["名前は", "七瀬ななこ。"]}, {"box": [830, 340, 896, 450], "vertical": true, "font_size": 34, "lines_coords": [[[865.0, 343.0], [892.0, 343.0], [892.0, 450.0], [865.0, 450.0]], [[830.0, 340.0], [870.0, 340.0], [870.0, 414.0], [830.0, 414.0]]], "lines": ["年は現在", "３１歳。"]}, {"box": [243, 59, 337, 270], "vertical": true, "font_size": 29, "lines_coords": [[[304.0, 59.0], [337.0, 59.0], [337.0, 221.0], [304.0, 221.0]], [[275.0, 62.0], [301.0, 62.0], [301.0, 270.0], [275.0, 270.0]], [[243.0, 60.0], [270.0, 60.0], [270.0, 231.0], [243.0, 231.0]]], "lines": ["当時、バイト", "していた喫茶店の", "店名「まりも」。"]}, {"box": [192, 518, 257, 631], "vertical": true, "font_size": 32, "lines_coords": [[[225.0, 521.0], [257.0, 521.0], [257.0, 606.0], [225.0, 606.0]], [[192.0, 518.0], [225.0, 518.0], [225.0, 631.0], [192.0, 631.0]]], "lines": ["場所は", "成増．．．．．"]}, {"box": [991, 859, 1083, 989], "vertical": true, "font_size": 28, "lines_coords": [[[1056.0, 859.0], [1083.0, 859.0], [1083.0, 987.0], [1056.0, 987.0]], [[1025.0, 859.0], [1051.0, 859.0], [1051.0, 989.0], [1025.0, 989.0]], [[991.0, 859.0], [1023.0, 859.0], [1023.0, 965.0], [991.0, 965.0]]], "lines": ["これくらい", "しか覚えて", "いない．．．"]}, {"box": [598, 859, 629, 956], "vertical": true, "font_size": 30, "lines_coords": [[[598.0, 859.0], [628.0, 859.0], [629.0, 956.0], [600.0, 956.0]]], "lines": ["うんっ。"]}, {"box": [447, 881, 476, 998], "vertical": true, "font_size": 28, "lines_coords": [[[447.0, 881.0], [475.0, 881.0], [475.0, 998.0], [447.0, 998.0]]], "lines": ["十分です。"]}, {"box": [712, 1165, 805, 1321], "vertical": true, "font_size": 27, "lines_coords": [[[776.0, 1165.0], [805.0, 1165.0], [805.0, 1271.0], [776.0, 1271.0]], [[744.0, 1167.0], [770.0, 1167.0], [770.0, 1320.0], [744.0, 1320.0]], [[712.0, 1165.0], [739.0, 1165.0], [739.0, 1321.0], [712.0, 1321.0]]], "lines": ["ちょっと", "時間かかると", "思いますが．．"]}, {"box": [457, 1437, 525, 1579], "vertical": true, "font_size": 34, "lines_coords": [[[486.0, 1437.0], [525.0, 1437.0], [525.0, 1523.0], [486.0, 1523.0]], [[457.0, 1439.0], [486.0, 1439.0], [487.0, 1579.0], [459.0, 1579.0]]], "lines": ["調べて", "みましょう。"]}, {"box": [336, 1459, 356, 1501], "vertical": true, "font_size": 20, "lines_coords": [[[336.0, 1459.0], [356.0, 1459.0], [356.0, 1501.0], [336.0, 1501.0]]], "lines": ["！"]}], "img_path": "217.png"}, {"version": "0.1.7", "img_width": 1106, "img_height": 1600, "blocks": [{"box": [918, 489, 988, 585], "vertical": true, "font_size": 40, "lines_coords": [[[946.0, 489.0], [988.0, 489.0], [988.0, 556.0], [946.0, 556.0]], [[918.0, 492.0], [957.0, 492.0], [957.0, 585.0], [918.0, 585.0]]], "lines": ["昼間", "っから、"]}, {"box": [915, 687, 979, 820], "vertical": true, "font_size": 31, "lines_coords": [[[945.0, 687.0], [979.0, 687.0], [979.0, 771.0], [945.0, 771.0]], [[915.0, 687.0], [943.0, 687.0], [945.0, 820.0], [916.0, 820.0]]], "lines": ["お盛ん", "ですねぇ．．．"]}, {"box": [373, 612, 435, 698], "vertical": true, "font_size": 33, "lines_coords": [[[403.0, 614.0], [435.0, 614.0], [435.0, 698.0], [403.0, 698.0]], [[373.0, 612.0], [407.0, 612.0], [407.0, 682.0], [373.0, 682.0]]], "lines": ["方向的", "にも、"]}, {"box": [31, 646, 123, 830], "vertical": true, "font_size": 29, "lines_coords": [[[95.0, 650.0], [123.0, 650.0], [123.0, 754.0], [95.0, 754.0]], [[64.0, 648.0], [90.0, 648.0], [90.0, 829.0], [64.0, 829.0]], [[31.0, 646.0], [65.0, 646.0], [65.0, 720.0], [31.0, 720.0]]], "lines": ["ホテルに", "行くんでしょう", "ねえ。"]}], "img_path": "218.png"}, {"version": "0.1.7", "img_width": 1093, "img_height": 1600, "blocks": [{"box": [1033, 42, 1060, 173], "vertical": true, "font_size": 27, "lines_coords": [[[1033.0, 43.0], [1060.0, 43.0], [1060.0, 171.0], [1033.0, 171.0]]], "lines": ["あいつ．．．"]}, {"box": [482, 56, 608, 203], "vertical": true, "font_size": 32, "lines_coords": [[[576.0, 59.0], [608.0, 59.0], [608.0, 151.0], [576.0, 151.0]], [[541.0, 56.0], [580.0, 56.0], [580.0, 145.0], [541.0, 145.0]], [[512.0, 60.0], [540.0, 60.0], [540.0, 167.0], [512.0, 167.0]], [[482.0, 60.0], [509.0, 60.0], [512.0, 200.0], [485.0, 200.0]]], "lines": ["あの女、", "部屋に", "化粧水や", "ナプキンや、"]}, {"box": [128, 50, 223, 208], "vertical": true, "font_size": 25, "lines_coords": [[[195.0, 53.0], [221.0, 53.0], [221.0, 207.0], [195.0, 207.0]], [[165.0, 53.0], [187.0, 53.0], [187.0, 207.0], [165.0, 207.0]], [[131.0, 50.0], [159.0, 50.0], [156.0, 168.0], [128.0, 168.0]]], "lines": ["どうでもいい", "もんを大量に", "持ってた。"]}, {"box": [1027, 495, 1068, 570], "vertical": true, "font_size": 31, "lines_coords": [[[1027.0, 495.0], [1068.0, 495.0], [1068.0, 570.0], [1027.0, 570.0]]], "lines": ["あぁ、"]}, {"box": [885, 492, 939, 609], "vertical": true, "font_size": 31, "lines_coords": [[[913.0, 493.0], [939.0, 493.0], [939.0, 595.0], [913.0, 595.0]], [[885.0, 492.0], [911.0, 492.0], [911.0, 609.0], [885.0, 609.0]]], "lines": ["衝動買い", "でしょう。"]}, {"box": [610, 492, 765, 703], "vertical": true, "font_size": 28, "lines_coords": [[[736.0, 495.0], [763.0, 495.0], [763.0, 675.0], [736.0, 675.0]], [[702.0, 492.0], [733.0, 492.0], [733.0, 703.0], [702.0, 703.0]], [[672.0, 493.0], [699.0, 493.0], [699.0, 648.0], [672.0, 648.0]], [[641.0, 495.0], [668.0, 495.0], [668.0, 651.0], [641.0, 651.0]], [[610.0, 492.0], [637.0, 492.0], [637.0, 607.0], [610.0, 607.0]]], "lines": ["身体を売り物に", "してるところから", "くる、ただの", "ストレス発散", "でしょう。"]}, {"box": [185, 476, 371, 772], "vertical": true, "font_size": 25, "lines_coords": [[[345.0, 479.0], [366.0, 479.0], [366.0, 657.0], [345.0, 657.0]], [[312.0, 476.0], [338.0, 476.0], [338.0, 717.0], [312.0, 717.0]], [[279.0, 476.0], [306.0, 476.0], [306.0, 710.0], [279.0, 710.0]], [[248.0, 478.0], [274.0, 478.0], [274.0, 771.0], [248.0, 771.0]], [[218.0, 478.0], [240.0, 478.0], [240.0, 760.0], [218.0, 760.0]], [[185.0, 476.0], [212.0, 476.0], [212.0, 771.0], [185.0, 771.0]]], "lines": ["手に入れた金を", "遣ってしまわないと、", "自分は商品だという", "証明になってしまいます。", "だからどうでもいい物を", "買ってしまうんでしょう。"]}, {"box": [975, 1107, 1072, 1290], "vertical": true, "font_size": 29, "lines_coords": [[[1030.0, 1107.0], [1072.0, 1107.0], [1072.0, 1179.0], [1030.0, 1179.0]], [[1007.0, 1109.0], [1033.0, 1109.0], [1033.0, 1290.0], [1007.0, 1290.0]], [[975.0, 1109.0], [1002.0, 1109.0], [1002.0, 1248.0], [975.0, 1248.0]]], "lines": ["一応、", "ああいうことを", "やることに、"]}, {"box": [704, 1118, 736, 1203], "vertical": true, "font_size": 32, "lines_coords": [[[704.0, 1118.0], [736.0, 1118.0], [736.0, 1203.0], [704.0, 1203.0]]], "lines": ["はは．．"]}, {"box": [390, 1107, 518, 1277], "vertical": true, "font_size": 31, "lines_coords": [[[480.0, 1107.0], [518.0, 1107.0], [518.0, 1171.0], [480.0, 1171.0]], [[455.0, 1110.0], [484.0, 1110.0], [484.0, 1226.0], [455.0, 1226.0]], [[423.0, 1115.0], [451.0, 1115.0], [451.0, 1243.0], [423.0, 1243.0]], [[390.0, 1110.0], [418.0, 1110.0], [420.0, 1276.0], [391.0, 1276.0]]], "lines": ["ああ", "見えても、", "一応「人間」", "なんでしょう。"]}, {"box": [278, 1117, 299, 1195], "vertical": true, "font_size": 21, "lines_coords": [[[278.0, 1117.0], [299.0, 1117.0], [299.0, 1195.0], [278.0, 1195.0]]], "lines": ["．．．．．．！"]}, {"box": [829, 1110, 885, 1298], "vertical": true, "font_size": 29, "lines_coords": [[[858.0, 1110.0], [885.0, 1110.0], [885.0, 1240.0], [858.0, 1240.0]], [[829.0, 1110.0], [850.0, 1110.0], [850.0, 1298.0], [829.0, 1298.0]]], "lines": ["ストレスは", "感じてるんだな。"]}], "img_path": "219.png"}, {"version": "0.1.7", "img_width": 1098, "img_height": 1600, "blocks": [{"box": [534, 39, 595, 223], "vertical": true, "font_size": 30, "lines_coords": [[[557.0, 40.0], [590.0, 39.0], [595.0, 145.0], [562.0, 146.0]], [[534.0, 42.0], [560.0, 42.0], [560.0, 223.0], [534.0, 223.0]]], "lines": ["あの女の", "ホムンクルス．．．"]}, {"box": [263, 92, 293, 132], "vertical": true, "font_size": 30, "lines_coords": [[[263.0, 93.0], [293.0, 93.0], [293.0, 131.0], [263.0, 131.0]]], "lines": ["？"]}, {"box": [888, 439, 944, 598], "vertical": true, "font_size": 26, "lines_coords": [[[918.0, 439.0], [944.0, 439.0], [941.0, 598.0], [915.0, 598.0]], [[888.0, 440.0], [910.0, 440.0], [910.0, 571.0], [888.0, 571.0]]], "lines": ["「顔が変わる」", "というのは"]}, {"box": [682, 453, 776, 612], "vertical": true, "font_size": 26, "lines_coords": [[[745.0, 453.0], [773.0, 453.0], [776.0, 585.0], [748.0, 585.0]], [[715.0, 453.0], [741.0, 453.0], [738.0, 612.0], [712.0, 612.0]], [[682.0, 456.0], [709.0, 456.0], [709.0, 590.0], [682.0, 590.0]]], "lines": ["整形をして", "「顔を変えた」", "象徴であり、"]}, {"box": [449, 454, 538, 610], "vertical": true, "font_size": 25, "lines_coords": [[[512.0, 454.0], [538.0, 454.0], [538.0, 610.0], [512.0, 610.0]], [[477.0, 456.0], [504.0, 456.0], [507.0, 610.0], [481.0, 610.0]], [[449.0, 457.0], [476.0, 457.0], [476.0, 593.0], [449.0, 593.0]]], "lines": ["相手によって", "顔を変えたり", "嘘をついて、"]}, {"box": [246, 459, 335, 610], "vertical": true, "font_size": 25, "lines_coords": [[[313.0, 459.0], [335.0, 459.0], [335.0, 587.0], [313.0, 587.0]], [[281.0, 459.0], [303.0, 459.0], [303.0, 610.0], [281.0, 610.0]], [[246.0, 459.0], [274.0, 459.0], [274.0, 562.0], [246.0, 562.0]]], "lines": ["さまざまな", "自分を演じて", "いる．．．"]}, {"box": [765, 1096, 921, 1303], "vertical": true, "font_size": 27, "lines_coords": [[[893.0, 1096.0], [921.0, 1096.0], [921.0, 1178.0], [893.0, 1178.0]], [[862.0, 1098.0], [888.0, 1098.0], [888.0, 1276.0], [862.0, 1276.0]], [[829.0, 1096.0], [855.0, 1096.0], [855.0, 1251.0], [829.0, 1251.0]], [[798.0, 1096.0], [824.0, 1096.0], [824.0, 1303.0], [798.0, 1303.0]], [[765.0, 1096.0], [793.0, 1096.0], [793.0, 1181.0], [765.0, 1181.0]]], "lines": ["ようは", "性格が一定せず", "自分自身でも", "どれが本当の自分", "なのか"]}, {"box": [151, 866, 170, 941], "vertical": true, "font_size": 19, "lines_coords": [[[151.0, 866.0], [170.0, 866.0], [170.0, 941.0], [151.0, 941.0]]], "lines": ["．．．．．．"]}, {"box": [69, 1079, 95, 1168], "vertical": true, "font_size": 26, "lines_coords": [[[69.0, 1079.0], [95.0, 1079.0], [95.0, 1168.0], [69.0, 1168.0]]], "lines": ["！．．．．．"]}, {"box": [279, 1198, 339, 1354], "vertical": true, "font_size": 27, "lines_coords": [[[310.0, 1200.0], [337.0, 1200.0], [337.0, 1354.0], [310.0, 1354.0]], [[279.0, 1198.0], [306.0, 1198.0], [306.0, 1314.0], [279.0, 1314.0]]], "lines": ["わからないん", "でしょう。"]}], "img_path": "220.png"}, {"version": "0.1.7", "img_width": 1095, "img_height": 1600, "blocks": [{"box": [1030, 31, 1065, 103], "vertical": true, "font_size": 35, "lines_coords": [[[1030.0, 31.0], [1065.0, 31.0], [1065.0, 103.0], [1030.0, 103.0]]], "lines": ["じゃ、"]}, {"box": [826, 53, 889, 209], "vertical": true, "font_size": 28, "lines_coords": [[[859.0, 54.0], [885.0, 54.0], [885.0, 207.0], [859.0, 207.0]], [[829.0, 53.0], [859.0, 54.0], [856.0, 134.0], [826.0, 132.0]]], "lines": ["のっぺらぼう", "は．．．？"]}, {"box": [653, 40, 678, 82], "vertical": true, "font_size": 25, "lines_coords": [[[653.0, 40.0], [678.0, 40.0], [678.0, 82.0], [653.0, 82.0]]], "lines": ["！"]}, {"box": [134, 180, 157, 277], "vertical": true, "font_size": 22, "lines_coords": [[[134.0, 182.0], [156.0, 182.0], [156.0, 275.0], [134.0, 275.0]]], "lines": ["う～ん．．．"]}, {"box": [965, 512, 1023, 670], "vertical": true, "font_size": 25, "lines_coords": [[[998.0, 517.0], [1020.0, 517.0], [1020.0, 670.0], [998.0, 670.0]], [[965.0, 512.0], [993.0, 512.0], [993.0, 603.0], [965.0, 603.0]]], "lines": ["演じることも", "できず、"]}, {"box": [513, 673, 571, 838], "vertical": true, "font_size": 28, "lines_coords": [[[543.0, 675.0], [571.0, 675.0], [571.0, 779.0], [543.0, 779.0]], [[513.0, 673.0], [540.0, 673.0], [540.0, 837.0], [513.0, 837.0]]], "lines": ["嘘をつく", "こともできず、"]}, {"box": [164, 523, 257, 729], "vertical": true, "font_size": 25, "lines_coords": [[[232.0, 525.0], [254.0, 525.0], [254.0, 703.0], [232.0, 703.0]], [[199.0, 525.0], [226.0, 525.0], [226.0, 729.0], [199.0, 729.0]], [[167.0, 523.0], [193.0, 523.0], [190.0, 679.0], [164.0, 679.0]]], "lines": ["だからといって", "表情を読み取られ", "たくない．．．"]}, {"box": [974, 990, 1043, 1064], "vertical": true, "font_size": 40, "lines_coords": [[[1005.0, 993.0], [1043.0, 993.0], [1043.0, 1054.0], [1005.0, 1054.0]], [[974.0, 990.0], [1015.0, 990.0], [1015.0, 1064.0], [974.0, 1064.0]]], "lines": ["ある", "意味、"]}, {"box": [699, 973, 768, 1062], "vertical": true, "font_size": 38, "lines_coords": [[[726.0, 973.0], [768.0, 973.0], [768.0, 1039.0], [726.0, 1039.0]], [[699.0, 978.0], [734.0, 978.0], [734.0, 1062.0], [699.0, 1062.0]]], "lines": ["素の", "自分．．．"]}, {"box": [573, 1115, 593, 1191], "vertical": true, "font_size": 20, "lines_coords": [[[573.0, 1115.0], [593.0, 1115.0], [593.0, 1191.0], [573.0, 1191.0]]], "lines": ["．．．．．．！"]}, {"box": [693, 1310, 757, 1539], "vertical": true, "font_size": 31, "lines_coords": [[[726.0, 1310.0], [757.0, 1310.0], [757.0, 1539.0], [726.0, 1539.0]], [[693.0, 1310.0], [724.0, 1310.0], [727.0, 1501.0], [696.0, 1501.0]]], "lines": ["に、一番近いんじゃ", "ないでしょうか。"]}, {"box": [485, 1298, 612, 1453], "vertical": true, "font_size": 28, "lines_coords": [[[585.0, 1301.0], [612.0, 1301.0], [612.0, 1429.0], [585.0, 1429.0]], [[556.0, 1304.0], [577.0, 1304.0], [577.0, 1453.0], [556.0, 1453.0]], [[520.0, 1304.0], [546.0, 1304.0], [546.0, 1432.0], [520.0, 1432.0]], [[485.0, 1300.0], [521.0, 1298.0], [524.0, 1368.0], [488.0, 1370.0]]], "lines": ["．．．と、まぁ", "こんな分析を", "してもです", "ねえ、"]}, {"box": [149, 1389, 209, 1552], "vertical": true, "font_size": 28, "lines_coords": [[[176.0, 1389.0], [209.0, 1389.0], [209.0, 1473.0], [176.0, 1473.0]], [[149.0, 1390.0], [171.0, 1390.0], [171.0, 1550.0], [149.0, 1550.0]]], "lines": ["前にも", "言ったように、"]}], "img_path": "221.png"}, {"version": "0.1.7", "img_width": 1098, "img_height": 1600, "blocks": [{"box": [470, 109, 591, 317], "vertical": true, "font_size": 23, "lines_coords": [[[563.0, 109.0], [590.0, 109.0], [587.0, 315.0], [560.0, 315.0]], [[534.0, 115.0], [556.0, 115.0], [556.0, 223.0], [534.0, 223.0]], [[502.0, 114.0], [524.0, 114.0], [524.0, 317.0], [502.0, 317.0]], [[473.0, 110.0], [495.0, 110.0], [491.0, 248.0], [470.0, 248.0]]], "lines": ["「ホムンクルス」と", "いうのは、", "名越さんの幻覚に", "過ぎません。"]}, {"box": [70, 50, 132, 157], "vertical": true, "font_size": 32, "lines_coords": [[[96.0, 50.0], [132.0, 50.0], [132.0, 110.0], [96.0, 110.0]], [[70.0, 51.0], [98.0, 51.0], [98.0, 157.0], [70.0, 157.0]]], "lines": ["また", "それか．．"]}, {"box": [876, 443, 976, 636], "vertical": true, "font_size": 33, "lines_coords": [[[934.0, 443.0], [976.0, 443.0], [976.0, 514.0], [934.0, 514.0]], [[907.0, 445.0], [938.0, 445.0], [938.0, 628.0], [907.0, 628.0]], [[877.0, 446.0], [904.0, 446.0], [902.0, 634.0], [876.0, 634.0]]], "lines": ["いや、", "バカにしてるん", "ではないんです。"]}, {"box": [559, 556, 648, 675], "vertical": true, "font_size": 30, "lines_coords": [[[620.0, 557.0], [648.0, 557.0], [648.0, 662.0], [620.0, 662.0]], [[585.0, 556.0], [620.0, 556.0], [620.0, 640.0], [585.0, 640.0]], [[559.0, 557.0], [585.0, 557.0], [585.0, 675.0], [559.0, 675.0]]], "lines": ["真面目に", "聞いて", "ください。"]}, {"box": [254, 509, 468, 714], "vertical": true, "font_size": 23, "lines_coords": [[[442.0, 510.0], [463.0, 510.0], [463.0, 682.0], [442.0, 682.0]], [[409.0, 509.0], [435.0, 509.0], [435.0, 639.0], [409.0, 639.0]], [[377.0, 509.0], [404.0, 509.0], [404.0, 696.0], [377.0, 696.0]], [[346.0, 509.0], [368.0, 509.0], [371.0, 687.0], [349.0, 687.0]], [[317.0, 512.0], [338.0, 512.0], [338.0, 714.0], [317.0, 714.0]], [[285.0, 510.0], [307.0, 510.0], [307.0, 635.0], [285.0, 635.0]], [[254.0, 509.0], [276.0, 509.0], [276.0, 635.0], [254.0, 635.0]]], "lines": ["ホムンクルスの", "顔が変わる", "「顔」というのは、", "全て名越さんの", "知ってる女の顔に", "変化するん", "ですよね？"]}, {"box": [920, 887, 941, 970], "vertical": true, "font_size": 21, "lines_coords": [[[920.0, 887.0], [941.0, 887.0], [941.0, 970.0], [920.0, 970.0]]], "lines": ["？．．．．．"]}, {"box": [729, 1101, 943, 1255], "vertical": true, "font_size": 24, "lines_coords": [[[916.0, 1103.0], [943.0, 1103.0], [943.0, 1229.0], [916.0, 1229.0]], [[884.0, 1103.0], [910.0, 1103.0], [910.0, 1228.0], [884.0, 1228.0]], [[852.0, 1101.0], [879.0, 1101.0], [879.0, 1207.0], [852.0, 1207.0]], [[82