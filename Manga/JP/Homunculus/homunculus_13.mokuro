0], [460.0, 507.0], [293.0, 507.0]]], "lines": ["山本英夫"]}, {"box": [142, 579, 612, 600], "vertical": false, "font_size": 30, "lines_coords": [[[142.0, 579.0], [612.0, 579.0], [612.0, 600.0], [142.0, 600.0]]], "lines": ["コスピリッツコミックス好評発売中／０"]}, {"box": [0, 337, 825, 1562], "vertical": false, "font_size": 614.5, "lines_coords": [[[340.0, 337.0], [415.0, 337.0], [415.0, 407.0], [340.0, 407.0]], [[0.0, 403.0], [825.0, 403.0], [825.0, 1562.0], [0.0, 1562.0]]], "lines": ["ホムングルスＵＲＬは", "いやいや．．．"]}, {"box": [87, 695, 628, 1353], "vertical": false, "font_size": 30, "lines_coords": [[[137.0, 695.0], [578.0, 695.0], [578.0, 726.0], [137.0, 726.0]], [[134.0, 717.0], [575.0, 723.0], [575.0, 754.0], [134.0, 748.0]], [[132.0, 750.0], [573.0, 746.0], [573.0, 778.0], [132.0, 781.0]], [[114.0, 757.0], [628.0, 837.0], [601.0, 1004.0], [87.0, 925.0]], [[137.0, 784.0], [517.0, 782.0], [517.0, 803.0], [137.0, 804.0]], [[132.0, 809.0], [550.0, 804.0], [550.0, 835.0], [132.0, 840.0]], [[137.0, 843.0], [546.0, 843.0], [546.0, 864.0], [137.0, 864.0]], [[139.0, 901.0], [550.0, 901.0], [550.0, 923.0], [139.0, 923.0]], [[140.0, 929.0], [545.0, 929.0], [545.0, 951.0], [140.0, 951.0]], [[132.0, 956.0], [570.0, 953.0], [570.0, 984.0], [132.0, 987.0]], [[137.0, 989.0], [381.0, 989.0], [381.0, 1009.0], [137.0, 1009.0]], [[137.0, 1017.0], [553.0, 1017.0], [553.0, 1037.0], [137.0, 1037.0]], [[139.0, 1046.0], [446.0, 1046.0], [446.0, 1067.0], [139.0, 1067.0]], [[382.0, 990.0], [545.0, 990.0], [545.0, 1006.0], [382.0, 1006.0]], [[137.0, 1075.0], [518.0, 1073.0], [518.0, 1095.0], [137.0, 1096.0]], [[126.0, 1096.0], [578.0, 1085.0], [579.0, 1134.0], [128.0, 1145.0]], [[137.0, 1132.0], [510.0, 1132.0], [510.0, 1154.0], [137.0, 1154.0]], [[135.0, 1159.0], [568.0, 1157.0], [568.0, 1184.0], [135.0, 1185.0]], [[139.0, 1190.0], [545.0, 1190.0], [545.0, 1210.0], [139.0, 1210.0]], [[140.0, 1218.0], [570.0, 1218.0], [570.0, 1239.0], [140.0, 1239.0]], [[137.0, 1246.0], [576.0, 1246.0], [576.0, 1268.0], [137.0, 1268.0]], [[142.0, 1276.0], [600.0, 1276.0], [600.0, 1296.0], [142.0, 1296.0]], [[139.0, 1304.0], [593.0, 1304.0], [593.0, 1325.0], [139.0, 1325.0]], [[137.0, 1332.0], [595.0, 1332.0], [595.0, 1353.0], [137.0, 1353.0]]], "lines": ["ラストイニング（中原裕神尾龍！！．．．！〜２", "闇金ウシジマくん（真鍋昌平）．．．．．．！！〜", "バンビ〜ノ！ＳＥＣＯＮＤＯせきやてつじ」１〜", "この時期のスーパーツアップには日本人としているのですが、こういった時の人がいっぱいでしょうかないと思いますのであればこれからないことがありませんでしたが、その時間にないままます。それでもあれです。こと思っていまですね。", "電波の城（細野不二彦それでも．．．それじゃないのか", "ＭＯＯＮ一昴ソリチュードスタンディング一（曽田正人）」", "ＱＵＯＵＵＺ－コンューッー（柏木ノソルコ）．．．１", "鬼龍院冴子探偵事務所（三上龍哉！！．．．", "ヴィルトゥス（信濃川日出雄・義凡）．．．！", "古代ローマ格闘時教頭「ＳＩＮ〈信濃川日出雄・義凡〉１〜", "ＬＯＳＴＭＡＮ草場道輝", "新クロサギ黒丸・夏原武）．．．．．．．．！", "セルフ（朔ユキ蔵）．．．．．．", "．．．．．．．．．．．", "かもめ☆チャンスほ井雪雄）．．．．．．", "鉄腕パーディーＥＶＯＬＨロのないのはＵＴＩＯＮ（ゆうきまさみ）！！", "明日のない、空（塀内夏子）．．．", "アイアムアヒ一口一（花沢健吾）．．．．．．！〜", "ＳＥＥＤ（今井大輔．．．．．．それでもそうですかもしれませんが、", "Ｄの魔王（柳広司・霜月かよ子）．．．．．．全", "黒メ羊〜１２人の優しぃ殺し屋〜（木根ヲサム）１〜", "このＳを、見よ！（北崎拓）．．．．．．．．．．．！？", "パパがもー度恋をした（阿部胸が．．．。１〜２", "強制ヒーロー〈宮下裕樹〉．．．．．．"]}, {"box": [207, 1473, 543, 1500], "vertical": false, "font_size": 18, "lines_coords": [[[210.0, 1477.0], [540.0, 1477.0], [540.0, 1497.0], [210.0, 1497.0]]], "lines": ["ＢＯＯＫＤＥＳＩＧＮ：ＴＡＫＡＨＡＳＥＩＪＵＮＺＩ"]}], "img_path": "002.png"}, {"version": "0.1.7", "img_width": 756, "img_height": 1600, "blocks": [{"box": [151, 195, 423, 276], "vertical": false, "font_size": 76, "lines_coords": [[[151.0, 200.0], [421.0, 195.0], [423.0, 271.0], [153.0, 276.0]]], "lines": ["山本英夫"]}, {"box": [492, 209, 627, 259], "vertical": false, "font_size": 50, "lines_coords": [[[492.0, 209.0], [627.0, 209.0], [627.0, 259.0], [492.0, 259.0]]], "lines": ["著作集"]}, {"box": [467, 364, 626, 387], "vertical": false, "font_size": 22, "lines_coords": [[[467.0, 364.0], [626.0, 365.0], [626.0, 387.0], [467.0, 385.0]]], "lines": ["・１〜１３集発売中"]}, {"box": [181, 523, 624, 545], "vertical": false, "font_size": 52, "lines_coords": [[[181.0, 523.0], [624.0, 523.0], [624.0, 545.0], [181.0, 545.0]]], "lines": ["スピリッツコミックス好評発売中／０"]}, {"box": [124, 589, 629, 1270], "vertical": false, "font_size": 52, "lines_