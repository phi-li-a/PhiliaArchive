.png"}, {"version": "0.1.7", "img_width": 1106, "img_height": 1600, "blocks": [{"box": [957, 485, 984, 640], "vertical": true, "font_size": 27, "lines_coords": [[[957.0, 485.0], [984.0, 485.0], [984.0, 637.0], [957.0, 637.0]]], "lines": ["たしかに．．．"]}, {"box": [673, 506, 767, 686], "vertical": true, "font_size": 31, "lines_coords": [[[734.0, 507.0], [767.0, 507.0], [767.0, 589.0], [734.0, 589.0]], [[706.0, 509.0], [732.0, 509.0], [732.0, 685.0], [706.0, 685.0]], [[673.0, 506.0], [707.0, 506.0], [707.0, 548.0], [673.0, 548.0]]], "lines": ["カズの", "高層マンション", "で、"]}, {"box": [237, 579, 329, 762], "vertical": true, "font_size": 29, "lines_coords": [[[296.0, 579.0], [329.0, 579.0], [329.0, 664.0], [296.0, 664.0]], [[268.0, 582.0], [295.0, 582.0], [295.0, 712.0], [268.0, 712.0]], [[237.0, 582.0], [264.0, 582.0], [264.0, 762.0], [237.0, 762.0]]], "lines": ["アヤに", "紹介された", "女だったな．．．"]}, {"box": [699, 1209, 729, 1331], "vertical": true, "font_size": 28, "lines_coords": [[[699.0, 1209.0], [727.0, 1209.0], [727.0, 1331.0], [699.0, 1331.0]]], "lines": ["名前は．．．"]}, {"box": [348, 1258, 415, 1351], "vertical": true, "font_size": 31, "lines_coords": [[[381.0, 1259.0], [415.0, 1259.0], [415.0, 1351.0], [381.0, 1351.0]], [[348.0, 1259.0], [376.0, 1259.0], [376.0, 1350.0], [348.0, 1350.0]]], "lines": ["ななみ", "．．．．．．？"]}], "img_path": "015.png"}, {"version": "0.1.7", "img_width": 1110, "img_height": 1600, "blocks": [{"box": [484, 81, 541, 208], "vertical": true, "font_size": 24, "lines_coords": [[[514.0, 81.0], [540.0, 81.0], [540.0, 187.0], [514.0, 187.0]], [[484.0, 81.0], [506.0, 81.0], [506.0, 207.0], [484.0, 207.0]]], "lines": ["気が付き", "ましたか？"]}, {"box": [360, 220, 382, 266], "vertical": true, "font_size": 22, "lines_coords": [[[360.0, 220.0], [382.0, 220.0], [382.0, 266.0], [360.0, 266.0]]], "lines": ["！"]}, {"box": [71, 487, 109, 562], "vertical": true, "font_size": 35, "lines_coords": [[[71.0, 489.0], [106.0, 487.0], [109.0, 560.0], [75.0, 562.0]]], "lines": ["あっ。"]}, {"box": [211,