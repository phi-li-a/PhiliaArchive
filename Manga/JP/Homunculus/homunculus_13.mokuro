, 1073.0], [253.0, 1157.0], [220.0, 1157.0]], [[190.0, 1075.0], [218.0, 1075.0], [218.0, 1184.0], [190.0, 1184.0]]], "lines": ["だって", "名越さん、"]}, {"box": [28, 1071, 118, 1228], "vertical": true, "font_size": 29, "lines_coords": [[[90.0, 1071.0], [118.0, 1071.0], [115.0, 1228.0], [87.0, 1228.0]], [[57.0, 1073.0], [85.0, 1073.0], [85.0, 1178.0], [57.0, 1178.0]], [[28.0, 1073.0], [54.0, 1073.0], [54.0, 1204.0], [28.0, 1204.0]]], "lines": ["「雲」だったん", "じゃない", "ですか．．．！？"]}, {"box": [314, 1385, 406, 1501], "vertical": true, "font_size": 28, "lines_coords": [[[378.0, 1389.0], [406.0, 1389.0], [406.0, 1490.0], [378.0, 1490.0]], [[346.0, 1389.0], [375.0, 1389.0], [375.0, 1490.0], [346.0, 1490.0]], [[314.0, 1385.0], [340.0, 1385.0], [343.0, 1501.0], [317.0, 1501.0]]], "lines": ["あの絵は", "ななこに", "違いない。"]}], "img_path": "212.png"}, {"version": "0.1.7", "img_width": 1097, "img_height": 1600, "blocks": [{"box": [652, 60, 805, 320], "vertical": true, "font_size": 26, "lines_coords": [[[776.0, 62.0], [804.0, 62.0], [804.0, 140.0], [776.0, 140.0]], [[745.0, 64.0], [771.0, 64.0], [771.0, 270.0], [745.0, 270.0]], [[715.0, 60.0], [742.0, 60.0], [737.0, 320.0], [711.0, 320.0]], [[684.0, 60.0], [711.0, 60.0], [707.0, 270.0], [681.0, 270.0]], [[653.0, 64.0], [675.0, 64.0], [675.0, 281.0], [653.0, 281.0]]], "lines": ["当時は", "顔を変え、記号に", "ドップリつかっていた", "俺は「雲」などには", "見えなかったんだ。"]}, {"box": [395, 187, 521, 273], "vertical": true, "font_size": 32, "lines_coords": [[[487.0, 190.0], [521.0, 190.0], [521.0, 273.0], [487.0, 273.0]], [[456.0, 189.0], [490.0, 189.0], [490.0, 273.0], [456.0, 273.0]], [[428.0, 190.0], [456.0, 190.0], [456.0, 271.0], [428.0, 271.0]], [[395.0, 187.0], [428.0, 187.0], [428.0, 271.0], [395.0, 271.0]]], "lines": ["全てを", "捨てた", "今とは", "違う．．"]}, {"box": [950, 657, 1045, 828], "vertical": true, "font_size": 30, "lines_coords": [[[1007.0, 657.0], [1045.0, 657.0], [1045.0, 718.0], [1007.0, 718.0]], [[981.0, 662.0], [1007.0, 662.0], [1007.0, 793.0], [981.0, 793.0]], [[950.0, 660.0], [