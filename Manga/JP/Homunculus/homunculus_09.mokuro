font_size": 25, "lines_coords": [[[531.0, 363.0], [555.0, 363.0], [553.0, 545.0], [530.0, 545.0]], [[503.0, 362.0], [526.0, 362.0], [526.0, 545.0], [503.0, 545.0]], [[471.0, 360.0], [501.0, 360.0], [501.0, 434.0], [471.0, 434.0]], [[445.0, 360.0], [469.0, 360.0], [469.0, 507.0], [445.0, 507.0]]], "lines": ["いろいろな分野を", "勉強しておくのも", "いいと", "思ったんです。"]}, {"box": [139, 480, 247, 661], "vertical": true, "font_size": 19, "lines_coords": [[[225.0, 482.0], [244.0, 482.0], [244.0, 616.0], [225.0, 616.0]], [[195.0, 481.0], [214.0, 481.0], [214.0, 660.0], [195.0, 660.0]], [[166.0, 481.0], [185.0, 481.0], [185.0, 660.0], [166.0, 660.0]], [[139.0, 481.0], [158.0, 481.0], [158.0, 594.0], [139.0, 594.0]]], "lines": ["頭部外傷には", "急性硬膜下血腫と", "急性硬膜外血腫が", "あるが．．．．．"]}, {"box": [713, 762, 825, 963], "vertical": true, "font_size": 24, "lines_coords": [[[802.0, 765.0], [825.0, 765.0], [825.0, 943.0], [802.0, 943.0]], [[773.0, 764.0], [797.0, 764.0], [797.0, 963.0], [773.0, 963.0]], [[745.0, 764.0], [768.0, 764.0], [768.0, 921.0], [745.0, 921.0]], [[717.0, 762.0], [742.0, 762.0], [738.0, 884.0], [713.0, 884.0]]], "lines": ["この二つの疾患を", "ＣＴで撮影した時の", "写り方の違いを", "述べてみろ。"]}, {"box": [35, 877, 53, 951], "vertical": true, "font_size": 18, "lines_coords": [[[35.0, 877.0], [53.0, 877.0], [53.0, 951.0], [35.0, 951.0]]], "lines": ["．．．．．．？"]}, {"box": [206, 1059, 242, 1136], "vertical": true, "font_size": 36, "lines_coords": [[[206.0, 1059.0], [242.0, 1059.0], [242.0, 1136.0], [206.0, 1136.0]]], "lines": ["学．．．．．"]}], "img_path": "084.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [890, 17, 941, 177], "vertical": true, "font_size": 20, "lines_coords": [[[920.0, 19.0], [939.0, 19.0], [939.0, 177.0], [920.0, 177.0]], [[891.0, 17.0], [912.0, 17.0], [910.0, 158.0], [890.0, 158.0]]], "lines": ["美容整形の勉強", "させるために"]}, {"box": [514, 6, 594, 206], "vertical": true, "font_size": 22, "lines_coords": [[[568.0, 6.0], [592.0, 6.0], [594.0, 166.0], [571.0, 166.0]], [[544.0, 8.0], 