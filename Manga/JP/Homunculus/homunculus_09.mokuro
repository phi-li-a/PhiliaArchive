], "lines": ["これも．．．"]}, {"box": [640, 447, 769, 719], "vertical": true, "font_size": 27, "lines_coords": [[[741.0, 447.0], [769.0, 447.0], [769.0, 559.0], [741.0, 559.0]], [[708.0, 447.0], [737.0, 447.0], [737.0, 680.0], [708.0, 680.0]], [[671.0, 447.0], [700.0, 447.0], [701.0, 719.0], [672.0, 719.0]], [[641.0, 451.0], [664.0, 451.0], [664.0, 638.0], [641.0, 638.0]]], "lines": ["あなたは", "なんであんな所で", "カーホームレスをして", "いるんですか？"]}, {"box": [813, 1192, 834, 1245], "vertical": true, "font_size": 21, "lines_coords": [[[813.0, 1192.0], [834.0, 1192.0], [834.0, 1245.0], [813.0, 1245.0]]], "lines": ["！"]}], "img_path": "008.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [540, 106, 674, 360], "vertical": true, "font_size": 29, "lines_coords": [[[645.0, 112.0], [672.0, 112.0], [672.0, 277.0], [645.0, 277.0]], [[608.0, 106.0], [641.0, 106.0], [638.0, 360.0], [605.0, 360.0]], [[574.0, 108.0], [603.0, 108.0], [603.0, 277.0], [574.0, 277.0]], [[540.0, 106.0], [567.0, 106.0], [567.0, 276.0], [540.0, 276.0]]], "lines": ["一流ホテルと", "ホームレスの集まる", "公園の狭間で", "自分探しぃ？"]}, {"box": [184, 555, 220, 652], "vertical": true, "font_size": 36, "lines_coords": [[[184.0, 555.0], [220.0, 555.0], [220.0, 652.0], [184.0, 652.0]]], "lines": ["嘘だ！"]}, {"box": [407, 977, 517, 1099], "vertical": true, "font_size": 27, "lines_coords": [[[492.0, 980.0], [516.0, 980.0], [516.0, 1092.0], [492.0, 1092.0]], [[460.0, 978.0], [489.0, 978.0], [489.0, 1095.0], [460.0, 1095.0]], [[432.0, 977.0], [462.0, 978.0], [459.0, 1051.0], [429.0, 1050.0]], [[407.0, 980.0], [432.0, 980.0], [432.0, 1097.0], [407.0, 1097.0]]], "lines": ["ポルシェに", "乗っていた", "外資系", "銀行マンが、"]}, {"box": [537, 1237, 575, 1290], "vertical": true, "font_size": 38, "lines_coords": [[[537.0, 1249.0], [575.0, 1249.0], [575.0, 1290.0], [537.0, 1290.0]]], "lines": ["．．．"]}], "img_path": "009.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [352, 9, 484, 265], "vertical": true, "font_size": 27,