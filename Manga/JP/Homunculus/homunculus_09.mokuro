ines": ["ああ。"]}, {"box": [570, 1281, 588, 1353], "vertical": true, "font_size": 18, "lines_coords": [[[570.0, 1281.0], [588.0, 1281.0], [588.0, 1353.0], [570.0, 1353.0]]], "lines": ["．．．．．．"]}], "img_path": "211.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [203, 305, 232, 412], "vertical": true, "font_size": 29, "lines_coords": [[[203.0, 305.0], [232.0, 305.0], [232.0, 412.0], [203.0, 412.0]]], "lines": ["ジー．．．"]}, {"box": [613, 739, 644, 820], "vertical": true, "font_size": 31, "lines_coords": [[[613.0, 739.0], [644.0, 739.0], [644.0, 820.0], [613.0, 820.0]]], "lines": ["おいっ。"]}, {"box": [210, 712, 244, 787], "vertical": true, "font_size": 34, "lines_coords": [[[210.0, 712.0], [244.0, 712.0], [244.0, 787.0], [210.0, 787.0]]], "lines": ["へっ！？"]}, {"box": [494, 1159, 548, 1270], "vertical": true, "font_size": 24, "lines_coords": [[[522.0, 1159.0], [546.0, 1159.0], [546.0, 1270.0], [522.0, 1270.0]], [[494.0, 1159.0], [519.0, 1159.0], [519.0, 1237.0], [494.0, 1237.0]]], "lines": ["乾杯くらい", "しよう。"]}, {"box": [319, 1162, 340, 1244], "vertical": true, "font_size": 21, "lines_coords": [[[319.0, 1162.0], [340.0, 1162.0], [340.0, 1244.0], [319.0, 1244.0]]], "lines": ["．．．．．．"]}], "img_path": "212.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [808, 121, 845, 195], "vertical": true, "font_size": 37, "lines_coords": [[[808.0, 121.0], [845.0, 121.0], [845.0, 195.0], [808.0, 195.0]]], "lines": ["乾杯。"]}, {"box": [139, 147, 159, 226], "vertical": true, "font_size": 20, "lines_coords": [[[139.0, 147.0], [159.0, 147.0], [159.0, 226.0], [139.0, 226.0]]], "lines": ["．．．．．．？"]}], "img_path": "213.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [57, 679, 520, 739], "vertical": false, "font_size": 60, "lines_coords": [[[57.0, 679.0], [520.0, 679.0], [520.0, 739.0], [57.0, 739.0]]], "lines": ["「ホムンクルス］第９集－完"]}, {"box": [46, 1263, 730, 1345], "vertical": false, "font_size": 19, "lines_coords": [[[62.0, 1265.0], [726.0, 1265.0], [726.0, 1283.0], [62.0, 1283.0]], [[60.0, 1280.0], [697.0, 1283.0], [697.0, 1304.0], [60.0, 1302.0]], [[60.0, 1300.0], [704.0, 1302.0], [704.0, 1324.0], [60.0, 1322.0]], [[61.0, 1320.0], [537.0, 1322.0], [537.0, 1345.0], [61.0, 1343.0]]], "lines": ["●作品中の「トレパネーション」をは極めて危険な行為です。絶対に真似をしないでください。", "ＷｉＦｉｄＦｉｖｉレベルのこの作品はフィクションコントは個人情報を作成したのですが、実在する人物・団体・事件等ということがはー、真似をしないはー切関係ありません。", "この中品はフィレンションでも、●１週刊ビッグコミックスピリッツ実在３０人物・２０１２００７年１８－２５号、５０号、そんな２００８／２０１８年１－４５号掲載作品の", "●１週１９日グラゴミノスピックの働いホムンクルス「公式ホームペ２０１４年１０月２３日、インタージョージャージーから「ＷｉｎｄｏｒｄＰｒａｍａｒｉｏｎ！"]}], "img_path": "214.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [721, 58, 884, 952], "vertical": true, "font_size": 160, "lines_coords": [[[724.0, 58.0], [884.0, 58.0], [881.0, 952.0], [721.0, 952.0]]], "lines": ["鏡合わせの二人が"]}, {"box": [779, 974, 813, 1108], "vertical": true, "font_size": 34, "lines_coords": [[[779.0, 974.0], [813.0, 974.0], [813.0, 1108.0], [779.0, 1108.0]]], "lines": ["．．．。"]}, {"box": [94, 1216, 980, 1282], "vertical": false, "font_size": 60, "lines_coords": [[[94.0, 1222.0], [980.0, 1216.0], [980.0, 1276.0], [94.0, 1282.0]]], "lines": ["【週刊ビッグコミックスピリス＞＞１にて衝撃連載中！！"]}], "img_path": "215.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [126, 75, 247, 704], "vertical": true, "font_size": 121, "lines_coords": [[[126.0, 75.0], [247.0, 75.0], [247.0, 704.0], [126.0, 704.0]]], "lines": ["ついに交錯す"]}, {"box": [86, 69, 283, 1274], "vertical": true, "font_size": 173, "lines_coords": [[[110.0, 69.0], [283.0, 73.0], [258.0, 1274.0], [86.0, 1270.0]]], "lines": ["ついに交錯する．．．：：："]}, {"box": [41, 1253, 917, 1393], "vertical": false, "font_size": 105.5, "lines_coords": [[[445.0, 1270.0], [917.0, 1296.0], [912.0, 1390.0], [440.0, 1364.0]], [[41.0, 1276.0], [494.0, 1253.0], [500.0, 1369.0], [46.0, 1393.0]]], "lines": ["シクルス］第１０", "次巻「ホムング"]}], "img_path": "216.png"}, {"version": "0.1.7", "img_width": 990, "im