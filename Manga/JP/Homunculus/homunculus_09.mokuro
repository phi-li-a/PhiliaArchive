 41.0], [929.0, 203.0], [906.0, 203.0]], [[879.0, 43.0], [898.0, 43.0], [898.0, 157.0], [879.0, 157.0]], [[847.0, 42.0], [871.0, 42.0], [871.0, 292.0], [847.0, 292.0]], [[823.0, 43.0], [842.0, 43.0], [842.0, 270.0], [823.0, 270.0]]], "lines": ["でも残念ながら", "うちの父は", "ただの交通事故の外傷で", "命に別状はない状態で"]}, {"box": [402, 166, 472, 308], "vertical": true, "font_size": 35, "lines_coords": [[[443.0, 168.0], [471.0, 168.0], [469.0, 308.0], [440.0, 308.0]], [[402.0, 166.0], [443.0, 166.0], [443.0, 240.0], [402.0, 240.0]]], "lines": ["「父親」では", "ない。"]}, {"box": [950, 423, 968, 471], "vertical": true, "font_size": 18, "lines_coords": [[[950.0, 423.0], [968.0, 423.0], [968.0, 471.0], [950.0, 471.0]]], "lines": ["！"]}, {"box": [276, 415, 333, 554], "vertical": true, "font_size": 24, "lines_coords": [[[303.0, 415.0], [333.0, 415.0], [333.0, 494.0], [303.0, 494.0]], [[277.0, 418.0], [296.0, 418.0], [296.0, 552.0], [277.0, 552.0]]], "lines": ["何度も", "言ったろう。"]}, {"box": [507, 828, 606, 1029], "vertical": true, "font_size": 28, "lines_coords": [[[574.0, 829.0], [603.0, 829.0], [605.0, 1015.0], [577.0, 1015.0]], [[540.0, 829.0], [568.0, 829.0], [571.0, 940.0], [542.0, 940.0]], [[510.0, 828.0], [538.0, 828.0], [536.0, 1029.0], [507.0, 1029.0]]], "lines": ["お前と俺を結ぶ", "バイブは", "「父親」ではない。"]}, {"box": [310, 731, 330, 804], "vertical": true, "font_size": 20, "lines_coords": [[[310.0, 731.0], [330.0, 731.0], [330.0, 804.0], [310.0, 804.0]]], "lines": ["．．．"]}, {"box": [340, 1118, 393, 1212], "vertical": true, "font_size": 26, "lines_coords": [[[365.0, 1118.0], [393.0, 1118.0], [393.0, 1212.0], [365.0, 1212.0]], [[340.0, 1118.0], [363.0, 1118.0], [363.0, 1209.0], [340.0, 1209.0]]], "lines": ["でもです", "ねえ．．．"]}], "img_path": "105.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [201, 108, 265, 285], "vertical": true, "font_size": 30, "lines_coords": [[[231.0, 108.0], [265.0, 108.0], [265.0, 194.0], [231.0, 194.0]], [[201.0, 109.0], [228.0, 109.0], [228.0, 281.0], [201.0, 281.0]]], "lines": ["俺には", "父親はいない。"]}], "img_path": "106.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [522, 99, 584, 263], "vertical": true, "font_size": 26, "lines_coords": [[[557.0, 102.0], [582.0, 102.0], [582.0, 202.0], [557.0, 202.0]], [[522.0, 99.0], [549.0, 99.0], [552.0, 263.0], [525.0, 263.0]]], "lines": ["幼い頃に", "亡くしている。"]}, {"box": [956, 620, 977, 695], "vertical": true, "font_size": 21, "lines_coords": [[[956.0, 620.0], [977.0, 620.0], [977.0, 695.0], [956.0, 695.0]]], "lines": ["．．．．．．？"]}, {"box": [423, 597, 508, 716], "vertical": true, "font_size": 26, "lines_coords": [[[451.0, 602.0], [474.0, 602.0], [474.0, 716.0], [451.0, 716.0]], [[475.0, 597.0], [508.0, 597.0], [508.0, 652.0], [475.0, 652.0]], [[423.0, 600.0], [449.0, 600.0], [449.0, 657.0], [423.0, 657.0]]], "lines": ["いないから", "まあ", "こそ、"]}, {"box": [685, 861, 713, 936], "vertical": true, "font_size": 28, "lines_coords": [[[685.0, 861.0], [713.0, 861.0], [713.0, 936.0], [685.0, 936.0]]], "lines": ["ま．．．．．"]}, {"box": [396, 780, 508, 1006], "vertical": true, "font_size": 26, "lines_coords": [[[479.0, 780.0], [508.0, 780.0], [504.0, 921.0], [475.0, 921.0]], [[453.0, 783.0], [477.0, 783.0], [477.0, 918.0], [453.0, 918.0]], [[423.0, 782.0], [447.0, 782.0], [448.0, 1006.0], [425.0, 1006.0]], [[397.0, 783.0], [418.0, 783.0], [417.0, 926.0], [396.0, 926.0]]], "lines": ["「父親」という", "キーワードに", "こだわりがあるんじゃ", "ないですかあ。"]}, {"box": [847, 1134, 924, 1300], "vertical": true, "font_size": 22, "lines_coords": [[[901.0, 1136.0], [924.0, 1136.0], [924.0, 1225.0], [901.0, 1225.0]], [[873.0, 1134.0], [897.0, 1134.0], [895.0, 1289.0], [872.0, 1289.0]], [[847.0, 1136.0], [866.0, 1136.0], [866.0, 1298.0], [847.0, 1298.0]]], "lines": ["やたらと", "問題を「父親」に", "したがるんだな。"]}, {"box": [377, 1070, 399, 1205], "vertical": true, "font_size": 19, "lines_coords": [[[377.0, 1073.0], [396.0, 1073.0], [396.0, 1203.0], [377.0, 1203.0]]], "lines": ["だってえ．．．"]}], "img_path": "107.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [743, 64, 828, 202], "vertical": true, "font_size": 24, "lines_coords": [[[806.0, 66.0], [825.0, 66.0], [825.0, 179.0], [806.0, 179.0]], [[776.0, 64.0], [801.0, 64.0], [798.0, 202.0], [773.0, 202.0]], [[746.0, 64.0], [775.0, 65.0], [772.0, 146.0], [743.0, 144.0]]], "lines": ["それ自体が", "「父親」でない", "証拠だ。"]}, {"box": [507, 52, 531, 102], "vertical": true, "font_size": 24, "lines_coords": [[[507.0, 52.0], [531.0, 52.0], [531.0, 102.0], [507.0, 102.0]]], "lines": ["！"]}, {"box": [17, 283, 42, 332], "vertical": true, "font_size": 25, "lines_coords": [[[17.0, 283.0], [42.0, 283.0], [42.0, 332.0], [17.0, 332.0]]], "lines": ["？"]}, {"box": [82, 642, 196, 836], "vertical": true, "font_size": 32, "lines_coords": [[[165.0, 646.0], [194.0, 646.0], [194.0, 805.0], [165.0, 805.0]], [[125.0, 646.0], [154.0, 646.0], [154.0, 836.0], [125.0, 836.0]], [[82.0, 642.0], [121.0, 642.0], [121.0, 728.0], [82.0, 728.0]]], "lines": ["美容整形も", "勉強してるん", "だな。"]}, {"box": [834, 1085, 855, 1128], "vertical": true, "font_size": 21, "lines_coords": [[[834.0, 1085.0], [855.0, 1085.0], [855.0, 1128.0], [834.0, 1128.0]]], "lines": ["！"]}, {"box": [23, 1259, 53, 1330], "vertical": true, "font_size": 30, "lines_coords": [[[23.0, 1259.0], [53.0, 1259.0], [53.0, 1330.0], [23.0, 1330.0]]], "lines": ["ええ。"]}], "img_path": "108.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [441, 16, 546, 218], "vertical": true, "font_size": 21, "lines_coords": [[[527.0, 17.0], [546.0, 17.0], [546.0, 185.0], [527.0, 185.0]], [[496.0, 16.0], [520.0, 16.0], [520.0, 103.0], [496.0, 103.0]], [[469.0, 16.0], [492.0, 16.0], [492.0, 218.0], [469.0, 218.0]], [[441.0, 16.0], [460.0, 16.0], [460.0, 108.0], [441.0, 108.0]]], "lines": ["人間を研究するに", "当たって", "心理学や脳生理学は", "もちろん"]}, {"box": [196, 58, 277, 198], "vertical": true, "font_size": 25, "lines_coords": [[[244.0, 60.0], [274.0, 58.0], [277.0, 132.0], [247.0, 133.0]], [[222.0, 61.0], [246.0, 61.0], [246.0, 198.0], [222.0, 198.0]], [[196.0, 64.0], [216.0, 64.0], [216.0, 153.0], [196.0, 153.0]]], "lines": ["そして", "たどり着いた", "のは．．．．．"]}, {"box": [423, 299, 612, 546], "vertical": true, "font_size": 21, "lines_coords": [[[593.0, 300.0], [612.0, 300.0], [612.0, 546.0], [593.0, 546.0]], [[564.0, 300.0], [583.0, 300.0], [583.0, 414.0], [564.0, 414.0]], [[537.0, 299.0], [556.0, 299.0], [556.0, 546.0], [537.0, 546.0]], [[505.0, 300.0], [529.0, 300.0], [529.0, 391.0], [505.0, 391.0]], [[478.0, 299.0], [499.0, 299.0], [500.0, 533.0], [479.0, 533.0]], [[451.0, 299.0], [470.0, 299.0], [470.0, 523.0], [451.0, 523.0]], [[423.0, 299.0], [443.0, 299.0], [443.0, 486.0], [423.0, 486.0]]], "lines": ["精神分析や催眠療法など", "臨床技術や", "さらには気功やオカルト", "新興宗教", "怪しげな民間療法まで、", "ありとあらゆるものを", "研究してきました。"]}, {"box": [462, 615, 497, 648], "vertical": false, "font_size": 20, "lines_coords": [[[473.0, 615.0], [497.0, 631.0], [486.0, 648.0], [462.0, 631.0]]], "lines": ["．．．"]}, {"box": [846, 661, 884, 837], "vertical": true, "font_size": 33, "lines_coords": [[[851.0, 661.0], [884.0, 663.0], [879.0, 835.0], [846.0, 833.0]]], "lines": ["「人間の外側」、"]}, {"box": [425, 641, 564, 797], "vertical": false, "font_size": 26.0, "lines_coords": [[[496.0, 646.0], [564.0, 776.0], [536.0, 791.0], [467.0, 661.0]], [[448.0, 641.0], [505.0, 780.0], [482.0, 790.0], [425.0, 650.0]], [[469.0, 641.0], [533.0, 788.0], [514.0, 797.0], [449.0, 649.0]]], "lines": ["そういえば、", "．．．", "そういえば．．．"]}, {"box": [477, 843, 514, 914], "vertical": true, "font_size": 37, "lines_coords": [[[477.0, 843.0], [514.0, 843.0], [514.0, 914.0], [477.0, 914.0]]], "lines": ["肉体、"]}, {"box": [94, 719, 422, 1118], "vertical": false, "font_size": 23.125, "lines_coords": [[[240.0, 725.0], [422.0, 1086.0], [403.0, 1096.0], [221.0, 735.0]], [[209.0, 719.0], [407.0, 1107.0], [388.0, 1116.0], [190.0, 728.0]], [[191.0, 728.0], [385.0, 1106.0], [362.0, 1118.0], [166.0, 741.0]], [[164.0, 721.0], [343.0, 1074.0], [318.0, 1086.0], [139.0, 734.0]], [[144.0, 7