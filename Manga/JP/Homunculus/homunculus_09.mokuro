 28, "lines_coords": [[[769.0, 382.0], [802.0, 382.0], [802.0, 440.0], [769.0, 440.0]], [[742.0, 385.0], [769.0, 385.0], [769.0, 589.0], [742.0, 589.0]], [[713.0, 385.0], [737.0, 385.0], [737.0, 637.0], [713.0, 637.0]]], "lines": ["なぜ", "美容整形なんかに", "興味を持っている．．．？"]}, {"box": [284, 535, 310, 599], "vertical": true, "font_size": 26, "lines_coords": [[[284.0, 535.0], [310.0, 535.0], [310.0, 599.0], [284.0, 599.0]]], "lines": ["！"]}, {"box": [0, 1200, 110, 1361], "vertical": true, "font_size": 24, "lines_coords": [[[79.0, 1203.0], [110.0, 1203.0], [110.0, 1272.0], [79.0, 1272.0]], [[57.0, 1204.0], [76.0, 1204.0], [76.0, 1315.0], [57.0, 1315.0]], [[27.0, 1204.0], [50.0, 1204.0], [50.0, 1317.0], [27.0, 1317.0]], [[0.0, 1200.0], [25.0, 1200.0], [23.0, 1358.0], [0.0, 1358.0]]], "lines": ["人体の", "内側にある", "脳や内臓も", "大切ですが．．．"]}], "img_path": "086.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [821, 488, 918, 715], "vertical": true, "font_size": 27, "lines_coords": [[[890.0, 489.0], [917.0, 489.0], [917.0, 627.0], [890.0, 627.0]], [[854.0, 488.0], [881.0, 488.0], [881.0, 652.0], [854.0, 652.0]], [[821.0, 489.0], [849.0, 489.0], [849.0, 710.0], [821.0, 710.0]]], "lines": ["外側にある", "空気と視線が", "触れている部分も、"]}, {"box": [175, 615, 248, 741], "vertical": true, "font_size": 37, "lines_coords": [[[206.0, 615.0], [248.0, 615.0], [248.0, 680.0], [206.0, 680.0]], [[175.0, 616.0], [207.0, 616.0], [210.0, 741.0], [177.0, 741.0]]], "lines": ["人体", "なんです。"]}, {"box": [796, 867, 816, 915], "vertical": true, "font_size": 20, "lines_coords": [[[796.0, 867.0], [816.0, 867.0], [816.0, 915.0], [796.0, 915.0]]], "lines": ["！"]}, {"box": [657, 885, 691, 974], "vertical": true, "font_size": 34, "lines_coords": [[[657.0, 885.0], [691.0, 885.0], [691.0, 974.0], [657.0, 974.0]]], "lines": ["外側も、"]}, {"box": [340, 876, 408, 991], "vertical": true, "font_size": 34, "lines_coords": [[[370.0, 876.0], [408.0, 876.0], [408.0, 937.0], [370.0, 937.0]], [[340.0, 877.0], [370.0, 876.0], [374.0, 989.0], [344.0, 991.0]]], "lines": ["人間", "なんです。"]}, {"box": [233, 859, 251, 932], "vertical": true, "font_size": 18, "lines_coords": [[[233.0, 859.0], [251.0, 859.0], [251.0, 932.0], [233.0, 932.0]]], "lines": ["．．．．．．"]}], "img_path": "087.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [622, 58, 749, 389], "vertical": true, "font_size": 26, "lines_coords": [[[726.0, 61.0], [749.0, 61.0], [749.0, 169.0], [726.0, 169.0]], [[687.0, 61.0], [716.0, 61.0], [716.0, 307.0], [687.0, 307.0]], [[653.0, 60.0], [682.0, 60.0], [685.0, 389.0], [656.0, 389.0]], [[622.0, 60.0], [646.0, 60.0], [648.0, 293.0], [623.0, 293.0]]], "lines": ["もともと", "病気でもない人間に", "メスを入れるような仕事は", "医者とは言えんっ。"]}, {"box": [132, 1047, 227, 1233], "vertical": true, "font_size": 24, "lines_coords": [[[201.0, 1050.0], [224.0, 1050.0], [224.0, 1231.0], [201.0, 1231.0]], [[164.0, 1047.0], [191.0, 1047.0], [191.0, 1207.0], [164.0, 1207.0]], [[132.0, 1048.0], [155.0, 1048.0], [155.0, 1189.0], [132.0, 1189.0]]], "lines": ["僕は医者よりも", "人間に興味が", "あるんです。"]}], "img_path": "088.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [444, 622, 527, 635], "vertical": false, "font_size": 13, "lines_coords": [[[444.0, 622.0], [527.0, 622.0], [527.0, 635.0], [444.0, 635.0]]], "lines": ["．．．"]}, {"box": [295, 791, 581, 931], "vertical": false, "font_size": 18.4, "lines_coords": [[[300.0, 792.0], [531.0, 791.0], [531.0, 810.0], [300.0, 812.0]], [[299.0, 821.0], [575.0, 821.0], [575.0, 839.0], [299.0, 839.0]], [[295.0, 849.0], [581.0, 851.0], [581.0, 870.0], [295.0, 868.0]], [[299.0, 881.0], [385.0, 881.0], [385.0, 896.0], [299.0, 896.0]], [[300.0, 911.0], [562.0, 911.0], [562.0, 931.0], [300.0, 931.0]]], "lines": ["あ、そんな事がありますが、", "お客様においていや、やっぱり、", "お兄ちゃんはどうでもいいのそうだなぁ。", "私は．．．", "それはそうだな。みんなの"]}, {"box": [380, 879, 571, 900], "vertical": false, "font_size": 19, "lines_coords": [[[380.0, 879.0], [571.0, 881.0], [571.0, 900.0], [380.0, 898.0]]], "lines": ["それで、なんですか"]}, {"box": [388, 940, 562, 987], "vertical": false, "font_size": 19.0, "lines_coords": [[[388.0, 940.0], [551.0, 940.0], [551.0, 958.0], [388.0, 958.0]], [[399.0, 967.0], [562.0, 967.0], [562.0, 987.0], [399.0, 987.0]]], "lines": ["な、なにか、やっぱりは", "俺、そう思ってるんだけど"]}, {"box": [410, 1055, 616, 1073], "vertical": false, "font_size": 18, "lines_coords": [[[410.0, 1055.0], [616.0, 1055.0], [616.0, 1073.0], [410.0, 1073.0]]], "lines": ["平成３０年度から"]}, {"box": [488, 1201, 529, 1215], "vertical": false, "font_size": 14, "lines_coords": [[[488.0, 1201.0], [529.0, 1201.0], [529.0, 1215.0], [488.0, 1215.0]]], "lines": ["あ．．．"]}, {"box": [772, 1145, 865, 1159], "vertical": false, "font_size": 14, "lines_coords": [[[772.0, 1145.0], [865.0, 1145.0], [865.0, 1159.0], [772.0, 1159.0]]], "lines": ["ま、待っ様、お"]}, {"box": [659, 1171, 944, 1219], "vertical": false, "font_size": 18.5, "lines_coords": [[[659.0, 1171.0], [944.0, 1171.0], [944.0, 1189.0], [659.0, 1189.0]], [[689.0, 1199.0], [931.0, 1200.0], [931.0, 1219.0], [689.0, 1218.0]]], "lines": ["そう思ったのは、．．．それは", "お姉ちゃんのおそうですね"]}, {"box": [827, 1229, 925, 1248], "vertical": false, "font_size": 19, "lines_coords": [[[827.0, 1229.0], [925.0, 1229.0], [925.0, 1248.0], [827.0, 1248.0]]], "lines": ["お客様のお客さまが"]}, {"box": [869, 1260, 932, 1275], "vertical": false, "font_size": 15, "lines_coords": [[[869.0, 1260.0], [932.0, 1260.0], [932.0, 1275.0], [869.0, 1275.0]]], "lines": ["．．．"]}], "img_path": "089.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [], "img_path": "090.png"}, {"version": "0.1.7", "img_width": 990, "img_height": 1400, "blocks": [{"box": [902, 15, 957, 131], "vertical": true, "font_size": 27, "lines_coords": [[[933.0, 16.0], [957.0, 16.0], [957.0, 131.0], [933.0, 131.0]], [[902.0, 15.0], [932.0, 15.0], [932.0, 88.0], [902.0, 88.0]]], "lines": ["そういえば", "学．．．．．"]}, {"box": [563, 0, 645, 184], "vertical": true, "font_size": 22, "lines_coords": [[[622.0, 2.0], [641.0, 2.0], [641.0, 183