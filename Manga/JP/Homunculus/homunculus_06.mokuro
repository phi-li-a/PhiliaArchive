dth": 832, "img_height": 1200, "blocks": [{"box": [0, 458, 119, 560], "vertical": false, "font_size": 11.75, "lines_coords": [[[0.0, 464.0], [114.0, 458.0], [114.0, 468.0], [0.0, 474.0]], [[0.0, 473.0], [117.0, 467.0], [117.0, 480.0], [0.0, 486.0]], [[0.0, 485.0], [118.0, 478.0], [118.0, 489.0], [0.0, 496.0]], [[0.0, 495.0], [118.0, 488.0], [118.0, 500.0], [0.0, 507.0]], [[2.0, 506.0], [116.0, 500.0], [116.0, 512.0], [2.0, 517.0]], [[0.0, 527.0], [117.0, 520.0], [117.0, 532.0], [0.0, 539.0]], [[0.0, 537.0], [119.0, 532.0], [119.0, 543.0], [0.0, 549.0]], [[0.0, 548.0], [119.0, 541.0], [119.0, 553.0], [0.0, 560.0]]], "lines": ["８０月１４：１１０８２８－１０７８９", "もしかしたら、もっともありませんでしたが、それだけではないのですが．．．それはそういうことでしょうか", "それでは「キャンペーン」というわけでは１４１５１５６９４１年１５月１９日", "それは．．．それじゃないのですが、私は「はいはいない」なんですね。", "東京では４，０００年以上１１月１１日（日）または１２月２４日－２３１", "ＢＡＲ１を１６．１８２２９１８１０７．", "わたしは．．．これでしょいないのですが、", "わたしは、もしんないのですが、このブログでは"]}, {"box": [216, 439, 292, 451], "vertical": false, "font_size": 12, "lines_coords": [[[216.0, 439.0], [292.0, 439.0], [292.0, 451.0], [216.0, 451.0]]], "lines": ["ああ．．．いいのーーーっっ。いいよね"]}, {"box": [249, 486, 289, 499], "vertical": false, "font_size": 13, "lines_coords": [[[249.0, 486.0], [289.0, 486.0], [289.0, 499.0], [249.0, 499.0]]], "lines": ["．．．"]}, {"box": [224, 440, 367, 465], "vertical": false, "font_size": 12.5, "lines_coords": [[[297.0, 440.0], [337.0, 440.0], [337.0, 448.0], [297.0, 448.0]], [[224.0, 448.0], [367.0, 448.0], [367.0, 465.0], [224.0, 465.0]]], "lines": ["ちょっとしか", "３５．３８．８３．８７"]}, {"box": [609, 855, 740, 936], "vertical": false, "font_size": 26, "lines_coords": [[[630.0, 856.0], [718.0, 855.0], [718.0, 879.0], [630.0, 881.0]], [[609.0, 908.0], [695.0, 899.0], [698.0, 927.0], [612.0, 937.0]]], "lines": ["ＢｕｙＵＳＤ", "１０８．０"]}, {"box": [560, 1065, 666, 1079], "vertical": false, "font_size": 16, "lines_coords": [[[560.0, 1063.0], [666.0, 1063.0], [666.0, 1081.0], [560.0, 1081.0]]], "lines": ["ＧＰＰ．ＪＰＹＴｗｏＷｂｙ"]}, {"box": [615, 975, 723, 1053], "vertical": false, "font_size"