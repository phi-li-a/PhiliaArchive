 [156.0, 1467.0]]], "lines": ["下を向いて", "足元を見ていた頃と", "何も変わっちゃ", "いない．．．"]}], "img_path": "136.png"}, {"version": "0.1.7", "img_width": 1094, "img_height": 1600, "blocks": [{"box": [820, 95, 850, 209], "vertical": true, "font_size": 28, "lines_coords": [[[820.0, 95.0], [848.0, 95.0], [850.0, 209.0], [822.0, 209.0]]], "lines": ["今も昔も、"]}, {"box": [489, 229, 518, 367], "vertical": true, "font_size": 26, "lines_coords": [[[489.0, 229.0], [515.0, 229.0], [515.0, 360.0], [489.0, 360.0]]], "lines": ["何もない"]}, {"box": [275, 126, 296, 201], "vertical": true, "font_size": 21, "lines_coords": [[[275.0, 126.0], [296.0, 126.0], [296.0, 201.0], [275.0, 201.0]]], "lines": ["それは．．．ありがとうございます"]}, {"box": [837, 684, 865, 827], "vertical": true, "font_size": 27, "lines_coords": [[[837.0, 685.0], [864.0, 685.0], [864.0, 826.0], [837.0, 826.0]]], "lines": ["３年間．．．？"]}, {"box": [118, 1145, 218, 1311], "vertical": true, "font_size": 29, "lines_coords": [[[185.0, 1145.0], [218.0, 1145.0], [218.0, 1232.0], [185.0, 1232.0]], [[154.0, 1145.0], [181.0, 1145.0], [181.0, 1310.0], [154.0, 1310.0]], [[118.0, 1146.0], [146.0, 1146.0], [146.0, 1256.0], [118.0, 1256.0]]], "lines": ["俺には", "何もなかった", "のか．．．？"]}], "img_path": "137.png"}, {"version": "0.1.7", "img_width": 1104, "img_height": 1600, "blocks": [{"box": [274, 392, 430, 578], "vertical": true, "font_size": 36, "lines_coords": [[[388.0, 392.0], [430.0, 392.0], [430.0, 462.0], [388.0, 462.0]], [[352.0, 393.0], [391.0, 393.0], [388.0, 565.0], [349.0, 565.0]], [[310.0, 393.0], [343.0, 393.0], [343.0, 578.0], [310.0, 578.0]], [[274.0, 395.0], [302.0, 395.0], [302.0, 518.0], [274.0, 518.0]]], "lines": ["俺は", "一体何処に", "存在している", "んだ．．．？"]}], "img_path": "138.png"}, {"version": "0.1.7", "img_width": 1106, "img_height": 1600, "blocks": [{"box": [923, 1254, 951, 1332], "vertical": true, "font_size": 28, "lines_coords": [[[923.0, 1254.0], [951.0, 1254.0], [951.0, 1332.0], [923.0, 1332.0]]], "lines": ["えっ！？"]}, {"box": [54, 1290, 82, 1378], "vertical": tru