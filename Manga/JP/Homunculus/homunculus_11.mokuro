.0, 1285.0], [585.0, 1285.0]]], "lines": ["最初", "開けた時も", "効果出るまで", "だいぶ時間", "かかったじゃ", "ないですか．．．"]}, {"box": [293, 1428, 313, 1509], "vertical": true, "font_size": 20, "lines_coords": [[[293.0, 1428.0], [313.0, 1428.0], [313.0, 1509.0], [293.0, 1509.0]]], "lines": ["．．．．．．．"]}, {"box": [70, 1350, 163, 1482], "vertical": true, "font_size": 27, "lines_coords": [[[137.0, 1353.0], [163.0, 1353.0], [163.0, 1482.0], [137.0, 1482.0]], [[101.0, 1354.0], [129.0, 1354.0], [129.0, 1468.0], [101.0, 1468.0]], [[70.0, 1350.0], [98.0, 1350.0], [101.0, 1468.0], [73.0, 1468.0]]], "lines": ["とりあえず", "皮膚閉じ", "ましょう。"]}], "img_path": "227.png"}, {"version": "0.1.7", "img_width": 1095, "img_height": 1600, "blocks": [{"box": [103, 1128, 126, 1154], "vertical": false, "font_size": 13.0, "lines_coords": [[[103.0, 1128.0], [126.0, 1128.0], [126.0, 1140.0], [103.0, 1140.0]], [[107.0, 1140.0], [126.0, 1140.0], [126.0, 1154.0], [107.0, 1154.0]]], "lines": ["．．．", "．．．"]}, {"box": [92, 1040, 314, 1128], "vertical": false, "font_size": 16, "lines_coords": [[[95.0, 1038.0], [281.0, 1040.0], [281.0, 1059.0], [95.0, 1058.0]], [[96.0, 1054.0], [299.0, 1054.0], [299.0, 1073.0], [96.0, 1073.0]], [[98.0, 1071.0], [282.0, 1071.0], [282.0, 1086.0], [98.0, 1086.0]], [[99.0, 1085.0], [307.0, 1085.0], [307.0, 1100.0], [99.0, 1100.0]], [[99.0, 1096.0], [309.0, 1096.0], [309.0, 1116.0], [99.0, 1116.0]], [[101.0, 1110.0], [306.0, 1110.0], [306.0, 1130.0], [101.0, 1130.0]]], "lines": ["そんなのはわからなかったのですが、これからも、私はこんなことがありません。", "それでもありがとうございますが、これまで何度も出来るのだろうけどなんですか", "でも、それは、やっぱりやはりやすいですから、", "そのままだ１時のわかりませんが来たわけではないので、", "これからお客さんのお客様においておりますのですが、このようなものではないのでしょうか。", "そんなことないんじゃないでしょうから、やっぱり何か言ってるんですか？"]}, {"box": [141, 1463, 159, 1545], "vertical": true, "font_size": 18, "lines_coords": [[[141.0, 1463.0], [159.0, 1463.0], [159.0, 1545.0], [141.0, 1545.0]]], "lines": ["．．．．．．？"]}], "img_path": "228.png"}, {"version": "0.1.7", "img_width": 1106, "img_height": 1600, "blocks": [{"box": [379, 95, 413, 178], "vertical": true, "font_size": 34, "lines_coords": [[[379.0, 95.0], [413.0, 95.0], [413.0, 178.0], [379.0, 178.0]]], "lines": ["はい？"]}, {"box": [884, 570, 940, 708], "vertical": true, "font_size": 24, "lines_coords": [[[913.0, 570.0], [940.0, 570.0], [940.0, 675.0], [913.0, 675.0]], [[884.0, 570.0], [906.0, 570.0], [906.0, 704.0], [884.0, 704.0]]], "lines": ["頭蓋骨に", "開けた穴は、"]}, {"box": [595, 362, 631, 459], "vertical": true, "font_size": 33, "lines_coords": [[[595.0, 364.0], [627.0, 362.0], [631.0, 457.0], [598.0, 459.0]]], "lines": ["おいっ。"]}, {"box": [484, 578, 577, 709], "vertical": true, "font_size": 29, "lines_coords": [[[551.0, 579.0], [577.0, 579.0], [577.0, 709.0], [551.0, 709.0]], [[518.0, 581.0], [545.0, 581.0], [545.0, 685.0], [518.0, 685.0]], [[484.0, 578.0], [517.0, 578.0], [517.0, 662.0], [484.0, 662.0]]], "lines": ["３ミリって", "言ってた", "よな？"]}, {"box": [318, 584, 357, 632], "vertical": true, "font_size": 39, "lines_coords": [[[318.0, 584.0], [357.0, 584.0], [357.0, 632.0], [318.0, 632.0]]], "lines": ["え、"]}, {"box": [30, 425, 86, 480], "vertical": false, "font_size": 55, "lines_coords": [[[30.0, 425.0], [86.0, 425.0], [86.0, 480.0], [30.0, 480.0]]], "lines": ["カッカッ"]}, {"box": [649, 1015, 837, 1262], "vertical": true, "font_size": 28, "lines_coords": [[[809.0, 1018.0], [835.0, 1018.0], [835.0, 1250.0], [809.0, 1250.0]], [[777.0, 1018.0], [804.0, 1018.0], [804.0, 1262.0], [777.0, 1262.0]], [[745.0, 1018.0], [771.0, 1018.0], [771.0, 1250.0], [745.0, 1250.0]], [[712.0, 1018.0], [740.0, 1018.0], [740.0, 1100.0], [712.0, 1100.0]], [[674.0, 1015.0], [707.0, 1015.0], [710.0, 1239.0], [677.0, 1239.0]], [[649.0, 1020.0], [676.0, 1020.0], [676.0, 1185.0], [649.0, 1185.0]]], "lines": ["そこのレポートには", "「アミリ以上でないと", "トレパネーションの", "効果は", "期待できない」って", "書いてあるぞ。"]}, {"box": [34, 834, 78, 910], "vertical": true, "font_size": 38, "lines_coords": [[[34.0, 837.0], [71.0, 834.0], [78.0, 907.0], [40.0, 910.0]]], "lines": ["ええ。"]}, {"box": [58, 1154, 80, 1202], "vertical": true, "font_size": 22, "lines_coords": [[[58.0, 1154.0], [80.0, 1154.0], [80.0, 1202.0], [58.0, 1202.0]]], "lines": ["！"]}, {"box": [559, 1289, 933, 1458], "vertical": false, "font_size": 15, "lines_coords": [[[565.0, 1291.0], [640.0, 1291.0], [640.0, 1306.0], [565.0, 1306.0]], [[832.0, 1287.0], [904.0, 1287.0], [904.0, 1306.0], [832.0, 1306.0]], [[562.0, 1304.0], [681.0, 1302.0], [681.0, 1317.0], [562.0, 1319.0]], [[790.0, 1301.0], [920.0, 1301.0], [920.0, 1316.0], [790.0, 1316.0]], [[777.0, 1313.0], [906.0, 1313.0], [906.0, 1328.0], [777.0, 1328.0]], [[560.0, 1316.0], [737.0, 1315.0], [737.0, 1331.0], [560.0, 1333.0]], [[560.0, 1327.0], [927.0, 1323.0], [927.0, 1342.0], [560.0, 1347.0]], [[560.0, 1340.0], [927.0, 1335.0], [927.0, 1355.0], [560.0, 1359.0]], [[559.0, 1354.0], [924.0, 1349.0], [924.0, 1369.0], [559.0, 1373.0]], [[559.0, 1366.0], [757.0, 1363.0], [757.0, 1383.0], [559.0, 1386.0]], [[562.0, 1380.0], [756.0, 1377.0], [756.0, 1397.0], [562.0, 1400.0]], [[563.0, 1396.0], [752.0, 1393.0], [752.0, 1408.0], [563.0, 1411.0]], [[562.0, 1407.0], [757.0, 1404.0], [757.0, 1423.0], [562.0, 1427.0]], [[563.0, 1423.0], [754.0, 1419.0], [754.0, 1434.0], [563.0, 1437.0]], [[563.0, 1433.0], [759.0, 1432.0], [759.0, 1448.0], [563.0, 1450.0]]], "lines": ["ああ．．．ああっ、パソ屋さん", "．．．", "ああ、あれ．．．。あははは、まだ素晴らしいですからですよね〜", "はぁ、はぁ．．．はぁっ、はあ、はははっはっ、あああぁぁぁっ", "．．．あはははっはっ、はあ、やはいやめてくればいいですか？", "それはそれではありませんでしたが、お願いしますのでねーからですが、やっぱり気になってるんだよねえよ。", "１１歳の人生ですから、新しい場所がありますので、自分が相手でやってきましたが、２０１７年１０月３１日水曜日時代が１０００円で１０万円ですが、２００７年３月１０日（火）を開催しました。", "各サイトがあれば、サービスによりますが、２０１８年１１月２０日までにお客されておりませんが、そりゃそうかわかるとしまれませんでしょう。ありがとうございました．．．おまえのお客さんのお店でありますが、", "そんなことを考えてくれているのですが、「このままだまだ１０００万円」ということがあります。そういった「そんなことをしているのですか」というわけではないですが、", "やるままそうかなあなたがいないのですが、しかすかもしれないわけではないでしょうか。", "しかし、そんなことを知っていたのですが、バッグストの中ではそれがあるのであればいいかと思うのでしょうかなとか", "ネットワークスクリックがありますので、このようになっていただきましたが、", "なんだかわからなかったんですが、それは自分ではないと思っていますのですから、", "おやすみましょうがないでしょーなのですが、あのねえねえあたりがとうございます", "あ、ああ．．．あんまりそれだけですかったわけではないのですが、これはまだまだ"]}, {"box": [558, 1473, 763, 1565], "vertical": false, "font_size": 17, "lines_coords": [[[563.0, 1474.0], [757.0, 1471.0], [757.0, 1486.0], [563.0, 1489.0]], [[563.0, 1485.0], [757.0, 1483.0], [757.0, 1500.0], [563.0, 1502.0]], [[562.0, 1496.0], [757.0, 1494.0], [757.0, 1514.0], [562.0, 1516.0]], [[563.0, 1510.0], [759.0, 1507.0], [759.0, 1527.0], [563.0, 1530.0]], [[562.0, 1523.0], [759.0, 1519.0], [759.0, 1539.0], [562.0, 1542.0]], [[562.0, 1535.0], [759.0, 1532.0], [759.0, 1552.0], [562.0, 1555.0]], [[563.0, 1548.0], [759.0, 1546.0], [759.0, 1566.0], [563.0, 1567.0]]], "lines": ["１１月２０日（水）は「おまえがありますのですが、これまではないでしょうか」と言われませんが、", "１１月２０日（月）日（日）においておりますので、おまえに特定できない場合があったのですが、", "それによりありがとうございますが、あなたの時とあの作成でしょうかもしれません。それはそれではないのですね。", "あって、何とかの声を聞かせてもらったのですが、それからもいいでしょうかもしれないと思っていました。", "今日のインターネットでは、現在のアプリケーションを使っていただきますが、お客様のお客さまではなかったのです。", "今年度のスーパーティングですのですが、やっぱりあげませんでしたが、でしょうがないかもしれないですね。", "今回のサイトではありがとうございます。ですが、できますので、プロジェクトの"]}, {"box": [370, 1329, 398, 1425], "vertical": true, "font_size": 28, "lines_coords": [[[370.0, 1329.0], [398.0, 1329.0], [398.0, 1425.0], [370.0, 1425.0]]], "lines": ["はあ．．．"]}, {"box": [60, 1442, 85, 1569], "vertical": true, "font_size": 22, "lines_coords": [[[60.0, 1443.0], [82.0, 1443.0], [82.0, 1567.0], [60.0, 1567.0]]], "lines": ["だから．．．？"]}], "img_path": "229.png"}, {"version": "0.1.7", "img_width": 1095, "img_height": 1600, "blocks": [{"box": [601, 35, 729, 217], "vertical": true, "font_size": 30, "lines_coords": [[[691.0, 35.0], [729.0, 35.0], [729.0, 96.0], [691.0, 96.0]], [[666.0, 40.0], [693.0, 40.0], [693.0, 217.0], [666.0, 217.0]], [[632.0, 37.0], [659.0, 37.0], [662.0, 192.0], [635.0, 192.0]], [[604.0, 37.0], [631.0, 37.0], [627.0, 168.0], [601.0, 168.0]]], "lines": ["穴を", "大きくしなきゃ", "ダメなんじゃ", "ないのか？"]}, {"box": [412, 34, 472, 225], "vertical": true, "font_size": 26, "lines_coords": [[[445.0, 37.0], [471.0, 37.0], [471.0, 164.0], [445.0, 164.0]], [[412.0, 34.0], [438.0, 34.0], [440.0, 225.0], [413.0, 225.0]]], "lines": ["いい加減に", "してくださいよ。"]}, {"box": [435, 314, 465, 470], "vertical": true, "font_size": 27, "lines_coords": [[[438.0, 314.0], [465.0, 314.0], [462.0, 468.0], [435.0, 468.0]]], "lines": ["名越さん．．．"]}, {"box": [682, 578, 777, 732], "vertical": true, "font_size": 28, "lines_coords": [[[737.0, 578.0], [777.0, 578.0], [777.0, 639.0], [737.0, 639.0]], [[712.0, 581.0], [740.0, 581.0], [737.0, 732.0], [709.0, 732.0]], [[682.0, 582.0], [704.0, 582.0], [704.0, 732.0], [682.0, 732.0]]], "lines": ["穴が", "大きかろうが", "小さかろうが"]}, {"box": [459, 582, 487, 713], "vertical": true, "font_size": 28, "lines_coords": [[[459.0, 582.0], [487.0, 582.0], [487.0, 710.0], [459.0, 710.0]]], "lines": ["しかし．．．"]}, {"box": [142, 589, 260, 767], "vertical": true, "font_size": 26, "lines_coords": [[[232.0, 590.0], [260.0, 590.0], [260.0, 695.0], [232.0, 695.0]], [[203.0, 589.0], [229.0, 589.0], [229.0, 767.0], [203.0, 767.0]], [[171.0, 589.0], [198.0, 589.0], [195.0, 743.0], [168.0, 743.0]], [[142.0, 589.0], [164.0, 589.0], [164.0, 742.0], [142.0, 742.0]]], "lines": ["そこには", "フミリ以上じゃ", "ないと効果が", "ないって．．．．．．"]}, {"box": [560, 765, 687, 948], "vertical": true, "font_size": 28, "lines_coords": [[[660.0, 767.0], [687.0, 767.0], [687.0, 871.0], [660.0, 871.0]], [[623.0, 765.0], [649.0, 765.0], [649.0, 948.0], [623.0, 948.0]], [[592.0, 767.0], [618.0, 767.0], [615.0, 921.0], [588.0, 921.0]], [[560.0, 767.0], [587.0, 767.0], [587.0, 921.0], [560.0, 921.0]]], "lines": ["あなたの", "見える幻覚には", "なんの影響も", "ありません！"]}, {"box": [210, 1273, 244, 1444], "vertical": true, "font_size": 28, "lines_coords": [[[214.0, 1273.0], [242.0, 1273.0], [238.0, 1442.0], [210.0, 1442.0]]], "lines": ["名越さん．．．"]}], "img_path": "230.png"}, {"version": "0.1.7", "img_width": 1101, "img_height": 1600, "blocks": [{"box": [855, 67, 946, 195], "vertical": true, "font_size": 24, "lines_coords": [[[919.0, 67.0], [946.0, 67.0], [946.0, 171.0], [919.0, 171.0]], [[890.0, 70.0], [912.0, 70.0], [912.0, 195.0], [890.0, 195.0]], [[855.0, 67.0], [883.0, 67.0], [883.0, 154.0], [855.0, 154.0]]], "lines": ["そこにも", "書いてある", "ように、"]}, {"box": [783, 282, 965, 512], "vertical": true, "font_size": 24, "lines_coords": [[[943.0, 289.0], [965.0, 289.0], [965.0, 512.0], [943.0, 512.0]], [[910.0, 285.0], [932.0, 285.0], [932.0, 464.0], [910.0, 464.0]], [[879.0, 282.0], [901.0, 282.0], [901.0, 476.0], [879.0, 476.0]], [[844.0, 284.0], [871.0, 284.0], [871.0, 454.0], [844.0, 454.0]], [[813.0, 285.0], [840.0, 285.0], [840.0, 390.0], [813.0, 390.0]], [[783.0, 287.0], [805.0, 287.0], [805.0, 421.0], [783.0, 421.0]]], "lines": ["トレパネーションの", "効果というのは", "「ホムンクルスが", "見える」という", "わけでは", "ありません。"]}, {"box": [324, 85, 354, 226], "vertical": true, "font_size": 27, "lines_coords": [[[324.0, 85.0], [351.0, 85.0], [354.0, 225.0], [327.0, 225.0]]], "lines": ["わかってる。"]}, {"box": [68, 39, 158, 231], "vertical": true, "font_size": 25, "lines_coords": [[[131.0, 42.0], [157.0, 42.0], [157.0, 220.0], [131.0, 220.0]], [[103.0, 40.0], [124.0, 40.0], [124.0, 143.0], [103.0, 143.0]], [[68.0, 39.0], [95.0, 39.0], [95.0, 231.0], [68.0, 231.0]]], "lines": ["いろいろな形で", "第六感が", "現れるんだろう。"]}, {"box": [908, 650, 937, 764], "vertical": true, "font_size": 27, "lines_coords": [[[908.0, 650.0], [935.0, 650.0], [935.0, 764.0], [908.0, 764.0]]], "lines": ["違います。"]}, {"box": [487, 646, 548, 812], "vertical": true, "font_size": 30, "lines_coords": [[[515.0, 646.0], [548.0, 646.0], [548.0, 731.0], [515.0, 731.0]], [[487.0, 651.0], [513.0, 651.0], [513.0, 810.0], [487.0, 810.0]]], "lines": ["それも", "ハッタリです。"]}, {"box": [103, 655, 123, 697], "vertical": true, "font_size": 20, "lines_coords": [[[103.0, 655.0], [123.0, 655.0], [123.0, 697.0], [103.0, 697.0]]], "lines": ["！"]}, {"box": [526, 1109, 646, 1273], "vertical": true, "font_size": 26, "lines_coords": [[[624.0, 1114.0], [646.0, 1114.0], [646.0, 1235.0], [624.0, 1235.0]], [[588.0, 1110.0], [615.0, 1110.0], [615.0, 1239.0], [588.0, 1239.0]], [[555.0, 1109.0], [587.0, 1109.0], [587.0, 1167.0], [555.0, 1167.0]], [[526.0, 1112.0], [552.0, 1112.0], [555.0, 1273.0], [529.0, 1273.0]]], "lines": ["健康な人に", "行うことは", "まず", "ありえません。"]}, {"box": [763, 1078, 918, 1331], "vertical": true, "font_size": 26, "lines_coords": [[[887.0, 1079.0], [915.0, 1079.0], [918.0, 1267.0], [890.0, 1267.0]], [[857.0, 1078.0], [883.0, 1078.0], [887.0, 1310.0], [860.0, 1310.0]], [[824.0, 1078.0], [851.0, 1078.0], [852.0, 1331.0], [826.0, 1331.0]], [[796.0, 1082.0], [818.0, 1082.0], [818.0, 1232.0], [796.0, 1232.0]], [[763.0, 1081.0], [790.0, 1081.0], [790.0, 1239.0], [763.0, 1239.0]]], "lines": ["現代の医学では、", "トレパネーションは", "単に硬膜外血腫とかの", "治療のために", "行われますが、"]}, {"box": [243, 1070, 402, 1351], "vertical": true, "font_size": 27, "lines_coords": [[[368.0, 1070.0], [402.0, 1070.0], [402.0, 1154.0], [368.0, 1154.0]], [[340.0, 1071.0], [367.0, 1071.0], [367.0, 1328.0], [340.0, 1328.0]], [[306.0, 1070.0], [332.0, 1070.0], [335.0, 1351.0], [309.0, 1351.0]], [[276.0, 1073.0], [302.0, 1073.0], [302.0, 1226.0], [276.0, 1226.0]], [[243.0, 1075.0], [271.0, 1075.0], [271.0, 1185.0], [243.0, 1185.0]]], "lines": ["例外で", "意識を覚醒させようと", "海外で実践している方も", "いることには", "いますが、"]}, {"box": [34, 1125, 153, 1278], "vertical": true, "font_size": 27, "lines_coords": [[[126.0, 1126.0], [153.0, 1126.0], [153.0, 1278.0], [126.0, 1278.0]], [[95.0, 1125.0], [121.0, 1125.0], [121.0, 1254.0], [95.0, 1254.0]], [[62.0, 1126.0], [90.0, 1126.0], [90.0, 1229.0], [62.0, 1229.0]], [[34.0, 1128.0], [56.0, 1128.0], [56.0, 1259.0], [34.0, 1259.0]]], "lines": ["効果のほどは", "ぶっちゃけ", "定かでは", "ありません。"]}], "img_path": "231.png"}, {"version": "0.1.7", "img_width": 1094, "img_height": 1600, "blocks": [{"box": [803, 49, 826, 134], "vertical": true, "font_size": 23, "lines_coords": [[[803.0, 49.0], [826.0, 49.0], [826.0, 134.0], [803.0, 134.0]]], "lines": ["！．．．"]}, {"box": [537, 109, 686, 339], "vertical": true, "font_size": 30, "lines_coords": [[[664.0, 112.0], [686.0, 112.0], [686.0, 276.0], [664.0, 276.0]], [[626.0, 109.0], [654.0, 109.0], [656.0, 239.0], [628.0, 239.0]], [[598.0, 109.0], [625.0, 109.0], [623.0, 314.0], [597.0, 314.0]], [[567.0, 112.0], [589.0, 112.0], [589.0, 339.0], [567.0, 339.0]], [[537.0, 112.0], [559.0, 112.0], [559.0, 223.0], [537.0, 223.0]]], "lines": ["超能力、霊感．．．", "何かしらの", "シックスセンスが", "芽生えるというのは", "ウソです。"]}, {"box": [517, 428, 645, 535], "vertical": true, "font_size": 30, "lines_coords": [[[609.0, 428.0], [645.0, 428.0], [645.0, 487.0], [609.0, 487.0]], [[575.0, 428.0], [617.0, 428.0], [617.0, 515.0], [575.0, 515.0]], [[548.0, 429.0], [581.0, 429.0], [581.0, 535.0], [548.0, 535.0]], [[517.0, 428.0], [551.0, 428.0], [551.0, 498.0], [517.0, 498.0]]], "lines": ["僕の", "作った", "ハッタリ", "です。"]}, {"box": [598, 626, 723, 735], "vertical": true, "font_size": 32, "lines_coords": [[[684.0, 626.0], [723.0, 626.0], [723.0, 712.0], [684.0, 712.0]], [[659.0, 629.0], [687.0, 629.0], [687.0, 735.0], [659.0, 735.0]], [[625.0, 628.0], [659.0, 628.0], [659.0, 712.0], [625.0, 712.0]], [[598.0, 629.0], [626.0, 629.0], [626.0, 685.0], [598.0, 685.0]]], "lines": ["だから", "言ったで", "しょう", "．．．．．"]}, {"box": [337, 631, 428, 815], "vertical": true, "font_size": 26, "lines_coords": [[[403.0, 635.0], [426.0, 635.0], [425.0, 814.0], [401.0, 814.0]], [[371.0, 631.0], [398.0, 631.0], [393.0, 815.0], [367.0, 815.0]], [[340.0, 635.0], [367.0, 635.0], [364.0, 768.0], [337.0, 768.0]]], "lines": ["あなたの見えた", "「ホムンクルス」", "なんてのは、"]}, {"box": [115, 635, 210, 742], "vertical": true, "font_size": 32, "lines_coords": [[[176.0, 637.0], [210.0, 637.0], [210.0, 718.0], [176.0, 718.0]], [[148.0, 637.0], [176.0, 637.0], [176.0, 742.0], [148.0, 742.0]], [[115.0, 635.0], [148.0, 635.0], [148.0, 726.0], [115.0, 726.0]]], "lines": ["ただの", "思い込み", "だって。"]}], "img_path": "232.png"}, {"version": "0.1.7", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [868, 165, 934, 266], "vertical": true, "font_size": 32, "lines_coords": [[[898.0, 165.0], [934.0, 165.0], [934.0, 232.0], [898.0, 232.0]], [[868.0, 170.0], [896.0, 170.0], [896.0, 265.0], [868.0, 265.0]]], "lines": ["よく", "言うよ。"]}, {"box": [86, 261, 108, 300], "vertical": true, "font_size": 22, "lines_coords": [[[86.0, 261.0], [108.0, 261.0], [108.0, 300.0], [86.0, 300.0]]], "lines": ["？"]}, {"box": [843, 506, 940, 713], "vertical": true, "font_size": 28, "lines_coords": [[[910.0, 506.0], [939.0, 506.0], [940.0, 703.0], [912.0, 703.0]], [[876.0, 506.0], [904.0, 506.0], [906.0, 687.0], [878.0, 687.0]], [[843.0, 506.0], [870.0, 506.0], [870.0, 709.0], [843.0, 709.0]]], "lines": ["ホムンクルスが", "幻覚・妄想じゃ", "ないってことは、"]}, {"box": [810, 920, 945, 1149], "vertical": true, "font_size": 29, "lines_coords": [[[910.0, 920.0], [942.0, 920.0], [945.0, 1090.0], [914.0, 1090.0]], [[879.0, 921.0], [907.0, 921.0], [907.0, 1065.0], [879.0, 1065.0]], [[843.0, 920.0], [871.0, 920.0], [875.0, 1148.0], [846.0, 1148.0]], [[810.0, 920.0], [839.0, 920.0], [839.0, 1017.0], [810.0, 1017.0]]], "lines": ["オマエが一番", "身をもって", "わかっているはず", "だろう。"]}, {"box": [920, 1429, 943, 1523], "vertical": true, "font_size": 23, "lines_coords": [[[920.0, 1429.0], [943.0, 1429.0], [943.0, 1523.0], [920.0, 1523.0]]], "lines": ["．．．．．．"]}], "img_path": "233.png"}, {"version": "0.1.7", "img_width": 1097, "img_height": 1600, "blocks": [], "img_path": "234.png"}, {"version": "0.1.7", "img_width": 1109, "img_height": 1600, "blocks": [{"box": [71, 782, 609, 846], "vertical": false, "font_size": 60, "lines_coords": [[[71.0, 782.0], [609.0, 787.0], [609.0, 846.0], [71.0, 842.0]]], "lines": ["［ホムンクルス］第１１集：完"]}, {"box": [81, 1470, 821, 1535], "vertical": false, "font_size": 19.333333333333332, "lines_coords": [[[81.0, 1471.0], [821.0, 1470.0], [821.0, 1490.0], [81.0, 1492.0]], [[81.0, 1493.0], [790.0, 1493.0], [790.0, 1514.0], [81.0, 1514.0]], [[81.0, 1518.0], [802.0, 1515.0], [802.0, 1532.0], [81.0, 1535.0]]], "lines": ["●作品中の「トレバネーションいは極めて危険な行為です。絶対に真似をしないでください。", "＠ｒｉａｕ．ｙｏｕ－＠この作品はフィクションです。まあ、実在する人物・団体・事件等とはー、はー切関係ありません。", "●「週刊ビッグコミックスピリッツ！２００８年２８号、２００９年３４〜４１号、４３～４６号掲載作品。"]}], "img_path": "235.png"}, {"version": "0.1.7", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [146, 168, 509, 229], "vertical": false, "font_size": 53, "lines_coords": [[[146.0, 176.0], [508.0, 168.0], [509.0, 221.0], [148.0, 229.0]]], "lines": ["ホムンクルス団"]}, {"box": [212, 246, 432, 287], "vertical": false, "font_size": 38, "lines_coords": [[[212.0, 246.0], [432.0, 250.0], [432.0, 287.0], [212.0, 284.0]]], "lines": ["ビッグコミックス"]}, {"box": [214, 784, 298, 815], "vertical": false, "font_size": 31, "lines_coords": [[[278.0, 784.0], [298.0, 790.0], [290.0, 815.0], [270.0, 809.0]], [[214.0, 785.0], [242.0, 785.0], [242.0, 815.0], [214.0, 815.0]]], "lines": ["ッ", "著"]}, {"box": [217, 615, 611, 645], "vertical": false, "font_size": 27, "lines_coords": [[[217.0, 615.0], [611.0, 618.0], [611.0, 645.0], [217.0, 642.0]]], "lines": ["２００９年１２月３１目初版第１刷発行"]}, {"box": [534, 567, 769, 587], "vertical": false, "font_size": 20, "lines_coords": [[[534.0, 567.0], [769.0, 567.0], [769.0, 587.0], [534.0, 587.0]]], "lines": ["ＩＳＢＮ９７８－４－０"]}, {"box": [772, 557, 989, 592], "vertical": false, "font_size": 28, "lines_coords": [[[772.0, 557.0], [989.0, 564.0], [989.0, 592.0], [772.0, 585.0]]], "lines": ["Ｄ９－１８２２５０－５"]}, {"box": [883, 618, 987, 640], "vertical": false, "font_size": 22, "lines_coords": [[[883.0, 618.0], [987.0, 618.0], [987.0, 640.0], [883.0, 640.0]]], "lines": ["（検印廃止）"]}, {"box": [204, 864, 304, 957], "vertical": false, "font_size": 31, "lines_coords": [[[206.0, 864.0], [304.0, 867.0], [303.0, 914.0], [204.0, 910.0]], [[215.0, 935.0], [295.0, 935.0], [295.0, 957.0], [215.0, 957.0]]], "lines": ["発行者", "だけど．．．"]}, {"box": [142, 1045, 343, 1078], "vertical": false, "font_size": 33, "lines_coords": [[[142.0, 1045.0], [343.0, 1045.0], [343.0, 1078.0], [142.0, 1078.0]]], "lines": ["革刊本細楽貝圧〟外そ単行本編集ノ銀杏社"]}, {"box": [143, 1021, 401, 1043], "vertical": false, "font_size": 22, "lines_coords": [[[143.0, 1021.0], [401.0, 1021.0], [401.0, 1043.0], [143.0, 1043.0]]], "lines": ["単行本編集責任／赤名英之"]}, {"box": [145, 1104, 278, 1148], "vertical": false, "font_size": 44, "lines_coords": [[[145.0, 1104.0], [278.0, 1104.0], [278.0, 1148.0], [145.0, 1148.0]]], "lines": ["発行所"]}, {"box": [464, 784, 843, 964], "vertical": false, "font_size": 35, "lines_coords": [[[478.0, 792.0], [700.0, 792.0], [700.0, 814.0], [478.0, 814.0]], [[468.0, 825.0], [797.0, 825.0], [797.0, 868.0], [468.0, 868.0]], [[464.0, 859.0], [708.0, 859.0], [708.0, 914.0], [464.0, 914.0]], [[478.0, 937.0], [697.0, 937.0], [697.0, 957.0], [478.0, 957.0]]], "lines": ["本来ええ", "○Ｈｉｄｅｏ．Ｙａｍａｍｏｒｏ！！", "鈴木総一郎", "．．．はぁ、はいは株式会社"]}, {"box": [306, 1104, 748, 1126], "vertical": false, "font_size": 22, "lines_coords": [[[306.0, 1104.0], [748.0, 1104.0], [748.0, 1126.0], [306.0, 1126.0]]], "lines": ["〈〒１０１－８００１）東京都千代田区一ツ橋二の三の"]}, {"box": [514, 1129, 737, 1178], "vertical": false, "font_size": 20.0, "lines_coords": [[[559.0, 1129.0], [736.0, 1129.0], [736.0, 1150.0], [559.0, 1150.0]], [[514.0, 1143.0], [553.0, 1143.0], [553.0, 1160.0], [514.0, 1160.0]], [[561.0, 1154.0], [737.0, 1156.0], [737.0, 1178.0], [561.0, 1176.0]]], "lines": ["編集０３（３２３０）５５０５", "ＴＥＬ", "販売０３（５２８１）３５６"]}, {"box": [825, 1110, 998, 1192], "vertical": false, "font_size": 82, "lines_coords": [[[825.0, 1110.0], [998.0, 1110.0], [998.0, 1192.0], [825.0, 1192.0]]], "lines": ["株式小学館会社"]}, {"box": [170, 1398, 326, 1418], "vertical": false, "font_size": 20, "lines_coords": [[[170.0, 1398.0], [326.0, 1398.0], [326.0, 1418.0], [170.0, 1418.0]]], "lines": ["アンケートのお願い"]}, {"box": [143, 1206, 909, 1396], "vertical": false, "font_size": 20, "lines_coords": [[[146.0, 1204.0], [909.0, 1207.0], [909.0, 1231.0], [146.0, 1228.0]], [[143.0, 1223.0], [801.0, 1226.0], [801.0, 1250.0], [143.0, 1247.0]], [[146.0, 1244.0], [353.0, 1246.0], [353.0, 1267.0], [146.0, 1266.0]], [[148.0, 1265.0], [806.0, 1268.0], [806.0, 1289.0], [148.0, 1286.0]], [[145.0, 1285.0], [717.0, 1288.0], [717.0, 1308.0], [145.0, 1305.0]], [[145.0, 1304.0], [423.0, 1305.0], [423.0, 1327.0], [145.0, 1325.0]], [[145.0, 1324.0], [708.0, 1326.0], [708.0, 1347.0], [145.0, 1345.0]], [[146.0, 1343.0], [711.0, 1346.0], [711.0, 1367.0], [146.0, 1364.0]], [[146.0, 1362.0], [753.0, 1365.0], [753.0, 1391.0], [146.0, 1387.0]]], "lines": ["●選択には「分社設しておりますが、２０１７年のベージの助け落ちや朝なの明治についてセッシングとしています。＞＞の場合はお取り替えいたします。サービーキー", "２０１４年には「女性感してお購入された書店名を明記して知り合いちょっとか終わった。本人の女の子の手間が目あてにお送りください。迷われたちゃんと似たという物はいいのね。社会担にてお取り替えいたします。", "購入されたＷｉｎｄｏｗｓとして、副作用のコミュニケーション・ローロースプレーシステムが", "明日歩いてしまいましょうか。●本本語の一部あるいは全部を無断でやっています。複数転載上前、放送等をすることは、サービューしています。法律で認められた場合を除き、", "著作者および出版者の権利の無理してると、普段とは気にされている程度となります。あらかじめられたので、チェックルのなことは、広げく悩んで詐諾をお求めください。", "それにせるより１０００円本校写権センター一委託出版物", "本書を無断で被写複製にコピー安心していることは、著作権法、この例外を除き、禁じられています。", "本当と無効し、後々投資に本書をコピーされる場合は、一方することは、それで、事前に日本被写権センター．．．一切れを殺されるのは、一切ＲＣＤの情報を受けてください。", "ネットビューですのですが、ＰＲＰＣに付けてくれません（１０）／ｗｗｗｉｔｔｅｒ（２０１８／０３）のフィーナーのスタイルはどうしているのですから、これからでもないですが、"]}, {"box": [401, 1400, 529, 1417], "vertical": false, "font_size": 18, "lines_coords": [[[401.0, 1399.0], [528.0, 1399.0], [528.0, 1419.0], [401.0, 1419.0]]], "lines": ["小学館アンケート係"]}, {"box": [162, 1430, 800, 1543], "vertical": false, "font_size": 20, "lines_coords": [[[170.0, 1435.0], [747.0, 1438.0], [747.0, 1458.0], [170.0, 1455.0]], [[170.0, 1458.0], [584.0, 1458.0], [584.0, 1478.0], [170.0, 1478.0]], [[171.0, 1474.0], [562.0, 1477.0], [562.0, 1502.0], [171.0, 1498.0]], [[170.0, 1498.0], [800.0, 1499.0], [800.0, 1520.0], [170.0, 1519.0]], [[170.0, 1516.0], [733.0, 1518.0], [733.0, 1542.0], [170.0, 1541.0]]], "lines": ["●小学館のコミックス、普通にごついてのアンケートをインターネットットで受け付けています。", "ｈｔｔｐ：／／ｗｗｗ．ｉｎｆｏｓｈｏｇｌｅおまえに、マンション・ノートピック１０ｋｍのｉｏｎにアクセスしていただき、Ａｍａｚｏｎは", "．．．いいじゃ．．．！！！いいんだ。このコミックスのキーコーニューあれは、ありがとうございますが、「ドミＶＲ２０」を入力してください。", "全ご回答者の中から、毎年Ｗｉｎｄｏｗｓ１１月２０日にスレースに入っているのですので、月日の日曜日に開催されていますが、ド（１０００円）をさしあげます。", "●ここで今年のゲームですからなかったので、電話のコミュニケーションもいいのですが、ステップ開始後３０分前送をもってかえきせていただきます。"]}], "img_path": "236.png"}, {"version": "0.1.7", "img_width": 1000, "img_height": 1600, "blocks": [], "img_path": "237.png"}]}