"img_path": "093.png"}, {"version": "0.1.7", "img_width": 1103, "img_height": 1600, "blocks": [{"box": [536, 98, 563, 160], "vertical": true, "font_size": 27, "lines_coords": [[[536.0, 98.0], [563.0, 98.0], [563.0, 160.0], [536.0, 160.0]]], "lines": ["！"]}, {"box": [506, 1282, 606, 1432], "vertical": true, "font_size": 23, "lines_coords": [[[568.0, 1282.0], [595.0, 1282.0], [595.0, 1407.0], [568.0, 1407.0]], [[539.0, 1284.0], [560.0, 1284.0], [560.0, 1432.0], [539.0, 1432.0]], [[506.0, 1284.0], [528.0, 1284.0], [528.0, 1393.0], [506.0, 1393.0]]], "lines": ["名越さんの", "見えたとおり", "てしたね"]}, {"box": [366, 1316, 388, 1398], "vertical": true, "font_size": 22, "lines_coords": [[[366.0, 1316.0], [388.0, 1316.0], [388.0, 1398.0], [366.0, 1398.0]]], "lines": ["！．．．"]}], "img_path": "094.png"}, {"version": "0.1.7", "img_width": 1101, "img_height": 1600, "blocks": [{"box": [810, 51, 933, 231], "vertical": true, "font_size": 29, "lines_coords": [[[905.0, 54.0], [932.0, 54.0], [932.0, 231.0], [905.0, 231.0]], [[871.0, 51.0], [904.0, 51.0], [904.0, 135.0], [871.0, 135.0]], [[841.0, 53.0], [869.0, 53.0], [871.0, 184.0], [843.0, 184.0]], [[810.0, 53.0], [837.0, 53.0], [840.0, 215.0], [813.0, 215.0]]], "lines": ["あのスケッチの", "ように", "父親という", "ケースの中で、"]}, {"box": [56, 50, 213, 207], "vertical": true, "font_size": 28, "lines_coords": [[[181.0, 50.0], [213.0, 50.0], [213.0, 134.0], [181.0, 134.0]], [[153.0, 54.0], [179.0, 54.0], [179.0, 181.0], [153.0, 181.0]], [[118.0, 50.0], [145.0, 50.0], [148.0, 207.0], [121.0, 207.0]], [[90.0, 53.0], [117.0, 53.0], [117.0, 184.0], [90.0, 184.0]], [[56.0, 51.0], [82.0, 51.0], [85.0, 193.0], [59.0, 193.0]]], "lines": ["どこか", "実感のない", "人生を送って", "いたのかも", "しれません。"]}, {"box": [473, 396, 540, 537], "vertical": true, "font_size": 27, "lines_coords": [[[512.0, 398.0], [540.0, 398.0], [537.0, 529.0], [509.0, 529.0]], [[473.0, 396.0], [499.0, 396.0], [502.0, 535.0], [476.0, 535.0]]], "lines": ["僕は本来の", "姿を見失い、"]}, {"box": [802, 734, 937, 926], "vertical": true, "font_size": 29, "lines_coords": [[[899.0, 734.0], [937.0, 734.0], [937.0, 795.0], [899.0, 795.0]], [[874.0, 743.0], [896.0, 743.0], [896.0, 864.0], [874.0, 864.0]], [[830.0, 735.0], [860.0, 735.0], [863.0, 842.0], [833.0, 842.0]], [[802.0, 735.0], [829.0, 735.0], [830.0, 921.0], [804.0, 921.0]]], "lines": ["僕は", "一般的には", "容姿には", "恵まれているし、"]}, {"box": [295, 700, 387, 915], "vertical": true, "font_size": 27, "lines_coords": [[[357.0, 700.0], [384.0, 700.0], [387.0, 906.0], [360.0, 906.0]], [[324.0, 701.0], [352.0, 701.0], [354.0, 810.0], [326.0, 810.0]], [[295.0, 700.0], [321.0, 700.0], [324.0, 915.0], [298.0, 915.0]]], "lines": ["名越さんと違って", "モテたし、", "女性に不自由せず、"]}, {"box": [23, 929, 41, 1004], "vertical": true, "font_size": 18, "lines_coords": [[[23.0, 929.0], [41.0, 929.0], [41.0, 1004.0], [23.0, 1004.0]]], "lines": ["．．．．．．？"]}, {"box": [318, 1134, 408, 1334], "vertical": true, "font_size": 24, "lines_coords": [[[384.0, 1134.0], [406.0, 1134.0], [406.0, 1331.0], [384.0, 1331.0]], [[352.0, 1135.0], [374.0, 1135.0], [374.0, 1332.0], [352.0, 1332.0]], [[318.0, 1135.0], [345.0, 1135.0], [345.0, 1268.0], [318.0, 1268.0]]], "lines": ["なんの不満もない", "人生を送ってきた", "つもりです。"]}, {"box": [35, 1434, 68, 1541], "vertical": true, "font_size": 33, "lines_coords": [[[35.0, 1434.0], [68.0, 1434.0], [68.0, 1539.0], [35.0, 1539.0]]], "lines": ["でも．．．"]}], "img_path": "095.png"}, {"version": "0.1.7", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [895, 176, 1021, 356], "vertical": true, "font_size": 28, "lines_coords": [[[984.0, 176.0], [1021.0, 176.0], [1021.0, 235.0], [984.0, 235.0]], [[957.0, 179.0], [984.0, 179.0], [984.0, 356.0], [957.0, 356.0]], [[928.0, 179.0], [950.0, 179.0], [950.0, 281.0], [928.0, 281.0]], [[895.0, 179.0], [921.0, 179.0], [921.0, 318.0], [895.0, 318.0]]], "lines": ["何か", "実感しきれない", "ところが", "ありました。"]}, {"box": [925, 770, 1046, 876], "vertical": true, "font_size": 29, "lines_coords": [[[1020.0, 771.0], [1046.0, 771.0], [1046.0, 876.0], [1020.0, 876.0]], [[98