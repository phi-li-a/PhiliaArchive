 {"version": "0.1.7", "img_width": 1103, "img_height": 1600, "blocks": [{"box": [643, 112, 810, 145], "vertical": false, "font_size": 13, "lines_coords": [[[654.0, 112.0], [792.0, 112.0], [792.0, 127.0], [654.0, 127.0]], [[651.0, 121.0], [801.0, 121.0], [801.0, 136.0], [651.0, 136.0]], [[684.0, 132.0], [763.0, 132.0], [763.0, 147.0], [684.0, 147.0]]], "lines": ["Ｍａｃｅｂｏｏｋではないのでありませんが、", "それを見てもらったのですから、この日に見えたり大きくなってきたのは、", "いや、それでも、そんなことは、自力自体の"]}, {"box": [663, 481, 754, 659], "vertical": true, "font_size": 25, "lines_coords": [[[726.0, 481.0], [753.0, 481.0], [751.0, 659.0], [724.0, 659.0]], [[698.0, 484.0], [720.0, 484.0], [720.0, 585.0], [698.0, 585.0]], [[663.0, 481.0], [690.0, 481.0], [690.0, 637.0], [663.0, 637.0]]], "lines": ["ホムンクルスの", "見える女", "てしたっけ？"]}, {"box": [481, 630, 501, 672], "vertical": true, "font_size": 20, "lines_coords": [[[481.0, 630.0], [501.0, 630.0], [501.0, 672.0], [481.0, 672.0]]], "lines": ["！"]}, {"box": [629, 1270, 688, 1446], "vertical": true, "font_size": 26, "lines_coords": [[[662.0, 1270.0], [688.0, 1270.0], [688.0, 1396.0], [662.0, 1396.0]], [[629.0, 1271.0], [656.0, 1271.0], [656.0, 1446.0], [629.0, 1446.0]]], "lines": ["付き合って", "いた女って．．．"]}, {"box": [164, 1250, 192, 1351], "vertical": true, "font_size": 28, "lines_coords": [[[164.0, 1250.0], [192.0, 1250.0], [192.0, 1351.0], [164.0, 1351.0]]], "lines": ["ああ．．．"]}], "img_path": "216.png"}, {"version": "0.1.7", "img_width": 1108, "img_height": 1600, "blocks": [{"box": [904, 71, 939, 162], "vertical": true, "font_size": 35, "lines_coords": [[[904.0, 71.0], [939.0, 71.0], [939.0, 162.0], [904.0, 162.0]]], "lines": ["やっぱ、"]}, {"box": [257, 48, 346, 276], "vertical": true, "font_size": 26, "lines_coords": [[[320.0, 50.0], [346.0, 50.0], [346.0, 276.0], [320.0, 276.0]], [[285.0, 48.0], [314.0, 48.0], [315.0, 204.0], [287.0, 204.0]], [[257.0, 51.0], [279.0, 51.0], [279.0, 182.0], [257.0, 182.0]]], "lines": ["トレパネーションの", "穴のせいじゃ", "ないですよ。"]}, {"box": [82, 213, 101, 254], "vertical": true, "font_size": 19, "lines_coords": [[[82.0, 213.0], [101.0, 213.0], [101.0, 254.0], [82.0, 254.0]]], "lines": ["！"]}, {"box": [303, 554, 440, 769], "vertical": true, "font_size": 34, "lines_coords": [[[401.0, 554.0], [440.0, 554.0], [440.0, 640.0], [401.0, 640.0]], [[373.0, 557.0], [404.0, 557.0], [404.0, 762.0], [373.0, 762.0]], [[340.0, 557.0], [375.0, 557.0], [375.0, 642.0], [340.0, 642.0]], [[303.0, 554.0], [335.0, 554.0], [335.0, 767.0], [303.0, 767.0]]], "lines": ["今回の", "トレパネーション", "により", "プラシーボ効果で、"]}, {"box": [154, 934, 280, 1074], "vertical": true, "font_size": 24, "lines_coords": [[[251.0, 934.0], [279.0, 934.0], [279.0, 1035.0], [251.0, 1035.0]], [[217.0, 935.0], [239.0, 935.0], [239.0, 1060.0], [217.0, 1060.0]], [[185.0, 934.0], [207.0, 934.0], [207.0, 1060.0], [185.0, 1060.0]], [[154.0, 935.0], [176.0, 935.0], [176.0, 1071.0], [154.0, 1071.0]]], "lines": ["昔の女の", "特殊能力が", "発生したに", "過ぎません。"]}, {"box": [621, 1246, 671, 1301], "vertical": true, "font_size": 50, "lines_coords": [[[621.0, 1246.0], [671.0, 1246.0], [671.0, 1301.0], [621.0, 1301.0]]], "lines": ["！？"]}], "img_path": "217.png"}, {"version": "0.1.7", "img_width": 1107, "img_height": 1600, "blocks": [{"box": [1000, 610, 1033, 701], "vertical": true, "font_size": 33, "lines_coords": [[[1000.0, 610.0], [1033.0, 610.0], [1033.0, 701.0], [1000.0, 701.0]]], "lines": ["そして、"]}, {"box": [512, 342, 666, 496], "vertical": true, "font_size": 25, "lines_coords": [[[633.0, 342.0], [666.0, 342.0], [666.0, 423.0], [633.0, 423.0]], [[605.0, 343.0], [631.0, 343.0], [631.0, 496.0], [605.0, 496.0]], [[575.0, 345.0], [597.0, 345.0], [597.0, 445.0], [575.0, 445.0]], [[544.0, 345.0], [566.0, 345.0], [566.0, 482.0], [544.0, 482.0]], [[512.0, 346.0], [534.0, 346.0], [534.0, 456.0], [512.0, 456.0]]], "lines": ["彼女の", "見えたものが", "あなたの", "幻覚・妄想に", "伝染した。"]}, {"box": [526, 671, 649, 904], "vertical": true, "font_size": 24, "lines_coords": [[[623.0, 675.0], [645.0, 675.0], [645.0, 904.0], [623.0, 904.0]], [[591.0, 673.0], [