0], [566.0, 1151.0], [135.0, 1151.0]], [[134.0, 1160.0], [543.0, 1157.0], [543.0, 1179.0], [134.0, 1182.0]], [[132.0, 1187.0], [565.0, 1185.0], [565.0, 1207.0], [132.0, 1209.0]], [[520.0, 1068.0], [566.0, 1071.0], [565.0, 1096.0], [518.0, 1093.0]], [[570.0, 1037.0], [590.0, 1037.0], [590.0, 1212.0], [570.0, 1212.0]], [[134.0, 1217.0], [523.0, 1217.0], [523.0, 1237.0], [134.0, 1237.0]], [[135.0, 1245.0], [566.0, 1245.0], [566.0, 1265.0], [135.0, 1265.0]], [[134.0, 1271.0], [392.0, 1273.0], [392.0, 1295.0], [134.0, 1293.0]], [[137.0, 1303.0], [593.0, 1303.0], [593.0, 1323.0], [137.0, 1323.0]], [[131.0, 1357.0], [618.0, 1354.0], [618.0, 1381.0], [131.0, 1384.0]]], "lines": ["コスピリッツコミックス好評発売中／日", "団地ともお（火）田扉）．．．．．．．．．．．．いい！！", "ホムンクルス（山本英夫）．．．．．．．．", "ラストイニング（中原裕・神尾龍）．．．．．！〜", "闇金ウシジマくん（真鍋昌平）．．．いいよ〜", "バンビ〜ノ！（せきやてつじー．．．", "バンビ〜ノ！ＳＥＣＯＮＤＯ（せきゃてっじ）！", "そういえば．．．", "電波の城（細野不二彦）．．．．．．．．．．．．！！", "昴スバル（曽田正人．．．．．．．．い．．", "ＭＯＯＮ一昴ソリチュードスタンディングー（曽田正人）１〜", "ＱｕＯＪＵＺ－コジューッー（柏木／ハルコ）．．．１〜", "ＭｙＦａｖｏｒｔｅＢＩＫＥ（山口かつみ）．．．．．！〜", "上京アフロ田中（のりつけ雅春）．．．．．．！〜", "京大ＭＩエムイチ物語（稲井雄人．．．．．．", "鬼龍院冴子探偵事務所三上龍哉）．．．", "ヴィルトゥス〈信濃川日出雄・義凡）１〜", "全", "ＬＯＳＴＭＡＮ草場道輝", "新クロサギ（黒丸・夏原武）．．．．．．．．", "セルフ（朔ユキ蔵）．．．．．．．．．．いいいかいいのよ", "かもめ☆チャンス（玉井雪雄）．．．．．．！", "鉄腕バーディーＥｖＯＬＵＴＩＯＮ（ゆうきまさみ）！っ", "１〜", "５６５２４３", "明日のない、空（塀内夏子）．．．そうだなぁ。それじゃねぇ", "アイアムアヒ一口一（花沢健吾）．．．いつ〜", "ＳＥＥＤ（今井大輔！．．．", "Ｄの魔王（柳広司・霜月かよ子）．．．．．．．．っ．．", "熱病加速装置（元町夏央）．．．．．．．．．．．．全１巻"]}, {"box": [212, 1479, 541, 1495], "vertical": false, "font_size": 16, "lines_coords": [[[212.0, 1479.0], [541.0, 1479.0], [541.0, 1495.0], [212.0, 1495.0]]], "lines": ["ＢＯＯＫＤＥＳＩＣＮ：ＴＡＫＡＨＡＳＨＩＪＵＮＺ"]}], "img_path": "002.png"}, {"version": "0.1.7", "img_width": 759, "img_height": 1600, "blocks": [{"box": [143, 198, 426, 285], "vertical": false, "font_size": 87, "lines_coords": [[[143.0, 198.0], [426.0, 198.0], [426.0, 285.0], [143.0, 285.0]]], "lines": ["山本英夫"]}, {"box": [493, 215, 627, 265], "vertical": false, "font_size": 50, "lines_coords": [[[493.0, 215.0], [627.0, 215.0], [627.0, 265.0], [493.0, 265.0]]], "lines": ["著作集"]}, {"box": [459, 371, 626, 393], "vertical": false, "font_size": 22, "lines_coords": [[[459.0, 371.0], [626.0, 371.0], [626.0, 393.0], [459.0, 393.0]]], "lines": ["．．．１〜１１集発売中"]}, {"box": [156, 526, 595, 546], "vertical": false, "font_size": 20, "lines_coords": [[[156.0, 526.0], [595.0, 526.0], [595.0, 546.0], [156.0, 546.0]]], "lines": ["ラスピリッツコミックス好評発売中／●"]}, {"box": [138, 706, 605, 832], "vertical": false, "font_size": 33.0, "lines_coords": [[[138.0, 706.0], [585.0, 706.0], [585.0, 748.0], [138.0, 748.0]], [[142.0, 742.0], [602.0, 742.0], [602.0, 768.0], [142.0, 768.0]], [[138.0, 770.0], [605.0, 768.0], [605.0, 804.0], [138.0, 806.0]], [[546.0, 804.0], [601.0, 804.0], [601.0, 832.0], [546.0, 832.0]]], "lines": ["来るべきＷｅｂユール達は日露戦争物語（江川運也．．．．．．地平線ラダンス（仕方）ルコール）．．", "Ａｍａｚｏｎの地平線でダンス（柏木ハル・コン．．．．．．全５を", "茶緒子（坂田信弘・中原裕）！！．．．", "．．．全６"]}, {"box": [142, 807, 541, 890], "vertical": false, "font_size": 21.666666666666668, "lines_coords": [[[142.0, 807.0], [384.0, 807.0], [384.0, 828.0], [142.0, 828.0]], [[145.0, 837.0], [541.0, 837.0], [541.0, 859.0], [145.0, 859.0]], [[142.0, 868.0], [541.0, 867.0], [541.0, 889.0], [142.0, 890.0]]], "lines": ["Ｈｅａｖｅｎ！（佐々木倫子）", "ギャラリーフェイク〈細野不二彦〉．．．", "最終兵器彼女（高橋しんう．．．．．．．．"]}, {"box": [0, 331, 826, 1443], "vertical": false, "font_size": 199.375, "lines_coords": [[[148.0, 331.0], [374.0, 331.0], [374.0, 357.0], [148.0, 357.0]], [[146.0, 368.0], [309.0, 368.0], [309.0, 395.0], [146.0, 395.0]], [[0.0, 356.0], [826.0, 356.0], [826.0, 1443.0], [0.0, 1443.0]], [[142.0, 926.0], [604.0, 926.0], [604.0, 957.0], [142.0, 957.0]], [[81.0, 859.0], [613.0, 767.0], [649.0, 971.0], [117.0, 1064.0]], [[145.0, 960.0], [545.0, 960.0], [545.0, 981.0], [145.0, 981.0]], [[93.0, 981.0], [626.0, 910.0], [648.0, 1078.0], [115.0, 1148.0]], [[142.0, 1084.0], [602.0, 1084.0], [602.0, 1110.0], [142.0, 1110.0]]], "lines": ["『ビッグコミックスホムングルス．．．", "コピッグコミックスホムンクルス．．．", "これからはまだまだと思っていたのですが、", "開発会社会人が楽しんでしたので、お客様にお話しかけておりますが、日本のネームを目本的なことを見ていただきましたが、サッカバライライブにお問い合わせください。", "それは．．．", "多少年は朝から映画「時代教育」．．．全て日本的な一色資料は、小説がオメガバライライズ（土）・オンガーライブロガは結婚式クリーラブラブキングイングとは", "それではなんでしょうか。", "東京ビディーズは健康保険について高校のフィロホテル日本の１つ１時間１０分程度の中級ワクロロボットの１５種類から２ヶ月２４日土曜日曜日１１：２０１４：０００８０１００１２００年１１年以上でするといまです。２０８月１１１２月"]}, {"box": [143, 992, 555, 1012], "vertical": false, "font_size": 20, "lines_coords": [[[143.0, 992.0], [555.0, 992.0], [555.0, 1012.0], [143.0, 1012.0]]], "lines": ["オメガトライブキングダム（玉井雪雄）：全"]}, {"box": [142, 1054, 605, 1081], "vertical": false, "font_size": 27, "lines_coords": [[[142.0, 1054.0], [605.0, 1054.0], [605.0, 1081.0], [142.0, 1081.0]]], "lines": ["高校アフロ田中（の）つけ雅春）．．．．．．全１０巻"]}, {"box": [140, 1114, 607, 1201], "vertical": false, "font_size": 24.666666666666668, "lines_coords": [[[140.0, 1114.0], [605.0, 1115.0], [605.0, 1142.0], [140.0, 1140.0]], [[140.0, 1146.0], [604.0, 1145.0], [604.0, 1171.0], [140.0, 1173.0]], [[143.0, 1179.0], [607.0, 1179.0], [607.0, 1201.0], [143.0, 1201.0]]], "lines": ["ハクバノ王子サマ〈朔ユキ蔵〉．．．．．．．．全いお", "ボーイズ・オン・ザ・・ラン（花沢健吾）．．．全ＪＯＢを", "帝王〈倉科遼・関口太郎〉．．．いい．．"]}, {"box": [577, 835, 599, 892], "vertical": true, "font_size": 22, "lines_coords": [[[577.0, 835.0], [599.0, 835.0], [599.0, 892.0], [577.0, 892.0]]], "lines": ["３２７"]}, {"box": [576, 896, 602, 923], "vertical": false, "font_size": 18, "lines_coords": [[[576.0, 910.0], [590.0, 896.0], [602.0, 909.0], [588.0, 923.0]]], "lines": ["！６"]}, {"box": [132, 1225, 634, 1301], "vertical": false, "font_size": 47.5, "lines_coords": [[[135.0, 1225.0], [630.0, 1229.0], [630.0, 1271.0], [135.0, 1267.0]], [[132.0, 1248.0], [634.0, 1245.0], [634.0, 1298.0], [132.0, 1301.0]]], "lines": ["テレキやラス保精料．．．．．．", "越しウタダ山は歳人．．．"]}, {"box": [172, 1465, 588, 1523], "vertical": false, "font_size": 24, "lines_coords": [[[174.0, 1468.0], [588.0, 1468.0], [588.0, 1490.0], [174.0, 1490.0]], [[193.0, 1495.0], [563.0, 1496.0], [563.0, 1523.0], [193.0, 1521.0]]], "lines": ["インターネットでビッグコミックスが購入できます。", "ｈｔｔｐ：／／ｏｏｍｉｃｓ．ｓｈｏｇａｋｕｋａｎ．ｃｏ．ｊｐ："]}], "img_path": "003.png"}, {"version": "0.1.7", "img_width