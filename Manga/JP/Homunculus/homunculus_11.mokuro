.0], [96.0, 931.0]], [[62.0, 801.0], [89.0, 801.0], [89.0, 982.0], [62.0, 982.0]]], "lines": ["自分が一体", "どこにいるのか", "わからなくなって", "不安になったり", "することが", "ありました．．．"]}, {"box": [662, 1447, 682, 1529], "vertical": true, "font_size": 20, "lines_coords": [[[662.0, 1447.0], [682.0, 1447.0], [682.0, 1529.0], [662.0, 1529.0]]], "lines": ["？．．．"]}], "img_path": "087.png"}, {"version": "0.1.7", "img_width": 1099, "img_height": 1600, "blocks": [{"box": [991, 207, 1050, 325], "vertical": true, "font_size": 28, "lines_coords": [[[1019.0, 207.0], [1050.0, 207.0], [1050.0, 265.0], [1019.0, 265.0]], [[991.0, 209.0], [1017.0, 209.0], [1017.0, 325.0], [991.0, 325.0]]], "lines": ["見て", "ください。"]}, {"box": [138, 312, 158, 354], "vertical": true, "font_size": 20, "lines_coords": [[[138.0, 312.0], [158.0, 312.0], [158.0, 354.0], [138.0, 354.0]]], "lines": ["！"]}, {"box": [869, 510, 996, 690], "vertical": true, "font_size": 23, "lines_coords": [[[970.0, 510.0], [994.0, 510.0], [992.0, 665.0], [969.0, 665.0]], [[937.0, 510.0], [964.0, 510.0], [964.0, 690.0], [937.0, 690.0]], [[902.0, 512.0], [923.0, 512.0], [923.0, 665.0], [902.0, 665.0]], [[870.0, 512.0], [892.0, 512.0], [892.0, 671.0], [870.0, 671.0]]], "lines": ["「冬の公園」は", "枯れ木ばかりの", "隙間ばかりで", "視界が広がり、"]}, {"box": [190, 737, 278, 890], "vertical": true, "font_size": 22, "lines_coords": [[[253.0, 739.0], [275.0, 739.0], [275.0, 890.0], [253.0, 890.0]], [[220.0, 737.0], [243.0, 737.0], [242.0, 889.0], [218.0, 889.0]], [[190.0, 737.0], [212.0, 737.0], [212.0, 864.0], [190.0, 864.0]]], "lines": ["公園の広さを", "感じることが", "てきる．．．．．．"]}, {"box": [391, 1084, 511, 1339], "vertical": true, "font_size": 24, "lines_coords": [[[484.0, 1085.0], [511.0, 1085.0], [511.0, 1189.0], [484.0, 1189.0]], [[454.0, 1087.0], [476.0, 1087.0], [476.0, 1214.0], [454.0, 1214.0]], [[420.0, 1084.0], [447.0, 1084.0], [445.0, 1339.0], [418.0, 1339.0]], [[392.0, 1087.0], [414.0, 1087.0], [414.0, 1221.0], [392.0, 1221.0]]], "lines": ["なにより", "自分が一体", "どこに立っているのか", "わかります"]}], "img_pat