1415.0]]], "lines": ["へっ？"]}], "img_path": "120.png"}, {"version": "0.1.7", "img_width": 1104, "img_height": 1600, "blocks": [{"box": [249, 601, 285, 818], "vertical": true, "font_size": 32, "lines_coords": [[[249.0, 601.0], [281.0, 601.0], [284.0, 817.0], [252.0, 817.0]]], "lines": ["．．．何もねえ．．．"]}], "img_path": "121.png"}, {"version": "0.1.7", "img_width": 1095, "img_height": 1600, "blocks": [{"box": [224, 132, 286, 332], "vertical": true, "font_size": 28, "lines_coords": [[[257.0, 134.0], [285.0, 134.0], [285.0, 273.0], [257.0, 273.0]], [[224.0, 132.0], [251.0, 132.0], [251.0, 331.0], [224.0, 331.0]]], "lines": ["つまらない", "人間だった．．．"]}], "img_path": "122.png"}, {"version": "0.1.7", "img_width": 1101, "img_height": 1600, "blocks": [{"box": [604, 264, 770, 468], "vertical": true, "font_size": 26, "lines_coords": [[[743.0, 267.0], [769.0, 267.0], [769.0, 382.0], [743.0, 382.0]], [[707.0, 265.0], [735.0, 265.0], [737.0, 467.0], [709.0, 467.0]], [[674.0, 267.0], [701.0, 267.0], [701.0, 467.0], [674.0, 467.0]], [[641.0, 268.0], [663.0, 268.0], [663.0, 437.0], [641.0, 437.0]], [[604.0, 267.0], [630.0, 267.0], [630.0, 439.0], [604.0, 439.0]]], "lines": ["誰からも", "興味をもたれず", "注目などされず", "見られること", "すらない．．．"]}, {"box": [354, 840, 454, 984], "vertical": true, "font_size": 29, "lines_coords": [[[421.0, 840.0], [454.0, 840.0], [454.0, 929.0], [421.0, 929.0]], [[390.0, 842.0], [416.0, 842.0], [416.0, 981.0], [390.0, 981.0]], [[354.0, 840.0], [381.0, 840.0], [381.0, 984.0], [354.0, 984.0]]], "lines": ["まるで", "透明人間の", "ように．．．"]}, {"box": [159, 1226, 187, 1396], "vertical": true, "font_size": 26, "lines_coords": [[[159.0, 1226.0], [185.0, 1226.0], [185.0, 1393.0], [159.0, 1393.0]]], "lines": ["何もない．．．"]}], "img_path": "123.png"}, {"version": "0.1.7", "img_width": 1107, "img_height": 1600, "blocks": [{"box": [834, 120, 1019, 284], "vertical": true, "font_size": 27, "lines_coords": [[[992.0, 123.0], [1019.0, 123.0], [1019.0, 226.0], [992.0, 226.0]], [[961.0, 123.0], [988.0, 123.0], [988.0