": ["人間は", "身体がなけ", "れば、", "苦しまない。"]}, {"box": [900, 1131, 947, 1187], "vertical": true, "font_size": 47, "lines_coords": [[[900.0, 1131.0], [947.0, 1131.0], [947.0, 1187.0], [900.0, 1187.0]]], "lines": ["！？"]}], "img_path": "116.png"}, {"version": "0.1.7", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [120, 1217, 212, 1428], "vertical": true, "font_size": 32, "lines_coords": [[[164.0, 1218.0], [196.0, 1218.0], [196.0, 1392.0], [164.0, 1392.0]], [[120.0, 1218.0], [153.0, 1218.0], [153.0, 1428.0], [120.0, 1428.0]]], "lines": ["この身体が", "悪いんだ．．．！"]}], "img_path": "117.png"}, {"version": "0.1.7", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [967, 68, 995, 199], "vertical": true, "font_size": 27, "lines_coords": [[[967.0, 68.0], [994.0, 68.0], [994.0, 198.0], [967.0, 198.0]]], "lines": ["整形前．．．．．"]}, {"box": [242, 578, 337, 784], "vertical": true, "font_size": 27, "lines_coords": [[[300.0, 578.0], [337.0, 578.0], [337.0, 639.0], [300.0, 639.0]], [[275.0, 582.0], [296.0, 582.0], [296.0, 782.0], [275.0, 782.0]], [[242.0, 581.0], [264.0, 581.0], [264.0, 757.0], [242.0, 757.0]]], "lines": ["俺は", "そんなことばかり", "考えていた．．．"]}, {"box": [392, 932, 483, 1087], "vertical": true, "font_size": 27, "lines_coords": [[[454.0, 932.0], [481.0, 932.0], [481.0, 1087.0], [454.0, 1087.0]], [[423.0, 932.0], [450.0, 932.0], [450.0, 1087.0], [423.0, 1087.0]], [[392.0, 932.0], [418.0, 932.0], [418.0, 1039.0], [392.0, 1039.0]]], "lines": ["整形前のこと", "思い出したん", "ですか？"]}, {"box": [143, 919, 165, 1002], "vertical": true, "font_size": 22, "lines_coords": [[[143.0, 919.0], [165.0, 919.0], [165.0, 1002.0], [143.0, 1002.0]]], "lines": ["．．．．．．？"]}, {"box": [826, 1447, 848, 1495], "vertical": true, "font_size": 22, "lines_coords": [[[826.0, 1447.0], [848.0, 1447.0], [848.0, 1495.0], [826.0, 1495.0]]], "lines": ["！"]}, {"box": [697, 1385, 723, 1488], "vertical": true, "font_size": 26, "lines_coords": [[[697.0, 1385.0], [723.0, 1385.0], [723.0, 1487.0], [697.0, 1487.0]]], "lines": ["ああ．．