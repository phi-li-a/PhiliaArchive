, 718.0], [898.0, 718.0], [898.0, 846.0], [871.0, 846.0]]], "lines": ["今、どんな", "ホムンクルスをして", "いますか？"]}], "img_path": "099.png"}, {"version": "0.1.7", "img_width": 1106, "img_height": 1600, "blocks": [{"box": [438, 335, 458, 377], "vertical": true, "font_size": 20, "lines_coords": [[[438.0, 335.0], [458.0, 335.0], [458.0, 377.0], [438.0, 377.0]]], "lines": ["！"]}], "img_path": "100.png"}, {"version": "0.1.7", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [844, 75, 868, 189], "vertical": true, "font_size": 22, "lines_coords": [[[845.0, 75.0], [867.0, 75.0], [867.0, 187.0], [845.0, 187.0]]], "lines": ["なるほど。"]}, {"box": [772, 340, 867, 450], "vertical": true, "font_size": 31, "lines_coords": [[[830.0, 340.0], [867.0, 340.0], [867.0, 403.0], [830.0, 403.0]], [[803.0, 343.0], [831.0, 343.0], [831.0, 450.0], [803.0, 450.0]], [[772.0, 345.0], [800.0, 345.0], [800.0, 434.0], [772.0, 434.0]]], "lines": ["俺に", "移らねえ", "わけだ。"]}, {"box": [333, 915, 422, 1130], "vertical": true, "font_size": 25, "lines_coords": [[[395.0, 915.0], [422.0, 915.0], [422.0, 1018.0], [395.0, 1018.0]], [[362.0, 915.0], [389.0, 915.0], [389.0, 1095.0], [362.0, 1095.0]], [[334.0, 915.0], [356.0, 915.0], [356.0, 1120.0], [334.0, 1120.0]]], "lines": ["おまえの", "ホムンクルスは", "まだ消えていない"]}, {"box": [220, 1056, 267, 1109], "vertical": true, "font_size": 47, "lines_coords": [[[220.0, 1056.0], [267.0, 1056.0], [267.0, 1109.0], [220.0, 1109.0]]], "lines": ["！？"]}, {"box": [878, 1228, 940, 1381], "vertical": true, "font_size": 27, "lines_coords": [[[911.0, 1231.0], [937.0, 1231.0], [937.0, 1381.0], [911.0, 1381.0]], [[881.0, 1228.0], [909.0, 1228.0], [906.0, 1331.0], [878.0, 1331.0]]], "lines": ["あせる必要は", "ない．．．"]}, {"box": [442, 1242, 538, 1398], "vertical": true, "font_size": 32, "lines_coords": [[[509.0, 1246.0], [536.0, 1246.0], [536.0, 1393.0], [509.0, 1393.0]], [[479.0, 1246.0], [506.0, 1246.0], [506.0, 1398.0], [479.0, 1398.0]], [[442.0, 1242.0], [483.0, 1242.0], [483.0, 1315.0], [442.0, 1315.0]]], "l