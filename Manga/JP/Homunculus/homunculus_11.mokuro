blocks": [], "img_path": "038.png"}, {"version": "0.1.7", "img_width": 1103, "img_height": 1600, "blocks": [{"box": [156, 546, 192, 717], "vertical": true, "font_size": 33, "lines_coords": [[[159.0, 546.0], [192.0, 546.0], [189.0, 717.0], [156.0, 717.0]]], "lines": ["すげえ臭い。"]}], "img_path": "039.png"}, {"version": "0.1.7", "img_width": 1107, "img_height": 1600, "blocks": [{"box": [604, 376, 656, 481], "vertical": true, "font_size": 28, "lines_coords": [[[628.0, 378.0], [656.0, 378.0], [656.0, 481.0], [628.0, 481.0]]], "lines": ["こいつだ"]}], "img_path": "040.png"}, {"version": "0.1.7", "img_width": 1104, "img_height": 1600, "blocks": [], "img_path": "041.png"}, {"version": "0.1.7", "img_width": 1108, "img_height": 1600, "blocks": [], "img_path": "042.png"}, {"version": "0.1.7", "img_width": 1105, "img_height": 1600, "blocks": [{"box": [283, 296, 437, 412], "vertical": false, "font_size": 18, "lines_coords": [[[389.0, 377.0], [431.0, 382.0], [429.0, 401.0], [388.0, 396.0]]], "lines": ["また、何でも可愛いしいものはありがとうございますから"]}, {"box": [135, 880, 307, 936], "vertical": false, "font_size": 61, "lines_coords": [[[135.0, 875.0], [307.0, 875.0], [307.0, 941.0], [135.0, 941.0]]], "lines": ["艶ん子の服"]}], "img_path": "043.png"}, {"version": "0.1.7", "img_width": 1109, "img_height": 1600, "blocks": [], "img_path": "044.png"}, {"version": "0.1.7", "img_width": 1109, "img_height": 1600, "blocks": [{"box": [231, 212, 342, 239], "vertical": false, "font_size": 18, "lines_coords": [[[232.0, 212.0], [342.0, 221.0], [340.0, 239.0], [231.0, 229.0]]], "lines": ["ありがとうございません。あれから"]}, {"box": [209, 254, 356, 289], "vertical": false, "font_size": 29, "lines_coords": [[[210.0, 254.0], [356.0, 260.0], [354.0, 289.0], [209.0, 282.0]]], "lines": ["そしてそんなことは"]}, {"box": [143, 289, 448, 345], "vertical": false, "font_size": 18.666666666666668, "lines_coords": [[[204.0, 289.0], [334.0, 295.0], [334.0, 312.0], [204.0, 306.0]], [[146.0, 306.0], [278.0, 309.0], [278.0, 326.0], [146.0, 323.0]], [[143.0, 317.0], [448.0, 323.0], [448.0, 345.0], [143.0, 339.0]]], "lines": ["一般的なＷｅｒｄＰｒｉｎｄｏｒ", "こんにちはっきりしていたので、１０００年１０月１０日までになってしまったね。", "．．．いや、あのまま知りてましたね。この人のことでもないのではないんだけどなくなってしまったんでしょう。「Ｆａｒｔａｌｌｅ」Ｃｉｎｇｏｔｉｏｎｅでも、たくさんありませんでした。"]}, {"box": [747, 207, 830, 222], "vertical": false, "font_size": 13, "lines_coords": [[[748.0, 208.0], [823.0, 205.0], [823.0, 220.0], [748.0, 223.0]]], "lines": ["ねぇねぁぁ！！！そんな．．．"]}, {"box": [709, 245, 855, 275], "vertical": false, "font_size": 16, "lines_coords": [[[713.0, 246.0], [845.0, 244.0], [845.0, 261.0], [713.0, 262.0]], [[709.0, 257.0], [848.0, 255.0], [848.0, 275.0], [709.0, 277.0]]], "lines": ["Ｃｈｏｎｅに『Ｓｅｔｅｒ』には、Ｃｏｒｎｉｎｆｉｒｅｓｔａｍａｒできましたが、", "Ｃｈｏｏｎｅということは、Ｃｏｐｌｅｒは、Ｗｅｂサイトの内容があります。Ｍａｃｅｎｄｉｏｎ"]}, {"box": [657, 280, 899, 472], "vertical": false, "font_size": 19, "lines_coords": [[[713.0, 279.0], [871.0, 279.0], [871.0, 294.0], [713.0, 294.0]], [[663.0, 288.0], [893.0, 288.0], [893.0, 314.0], [663.0, 314.0]], [[662.0, 299.0], [895.0, 299.0], [895.0, 325.0], [662.0, 325.0]], [[660.0, 312.0], [895.0, 312.0], [895.0, 336.0], [660.0, 336.0]], [[657.0, 324.0], [893.0, 324.0], [893.0, 348.0], [657.0, 348.0]], [[718.0, 333.0], [893.0, 338.0], [893.0, 358.0], [718.0, 353.0]], [[663.0, 346.0], [712.0, 346.0], [712.0, 356.0], [663.0, 356.0]], [[701.0, 346.0], [893.0, 349.0], [893.0, 370.0], [701.0, 367.0]], [[723.0, 355.0], [896.0, 358.0], [896.0, 384.0], [723.0, 381.0]], [[685.0, 369.0], [895.0, 371.0], [895.0, 395.0], [685.0, 394.0]], [[710.0, 379.0], [896.0, 382.0], [896.0, 408.0], [710.0, 405.0]], [[691.0, 396.0], [893.0, 396.0], [893.0, 416.0], [691.0, 416.0]], [[706.0, 410.0], [866.0, 408.0], [866.0, 423.0], [706.0, 425.0]], [[865.0, 408.0], [891.0, 412.0], [890.0, 427.0], [863.0, 423.0]], [[713.0, 416.0], [893.0, 421.0], [893.0, 442.0], [713.0, 437.0]], [[709.0, 430.0], [893.0, 432.0], [893.0, 453.0], [709.0, 452.0]], [[707.0, 443.0], [893.0, 444.0], [893.0, 464.0], [707.0, 462.0]], [[716.0, 458.0], [804.0, 458.0], [804.0, 473.0], [716.0, 473.0]]], "lines": ["あとは誰も話が出てくれていたのでしょうかもしれませんが、できるのですが、", "あああっはっ、ああぁあぁぁぁーーーっっ、んっ、はぁっ．．．", "ああ、そうだなぁ．．．なんですから、そんなことはありませんが、ありがとうございます。", "こんにちは．．．ありがとうございましたが、", "これからは、お客さんのことがありますのですが、あなたのお客様にお願いします。", "こんな時にはありがとうございました。今までお話をしていただきます。お客様のお客さまのお話です。", "はぁぁっはぁ", "お姉ちゃんはありがとうございますのですが、おまえのやっぱりやすくなってるのではないのだろうなんですね。", "それですね。何の話をお待ちしましたかったのか。", "これからは、これまでの人がいるのではないのですが、", "このような場合は、初めてのおかげですからね。あははは、あなたはこの世界ではありませんが、", "これからは、それでありませんでしたが、この度は自分ではないのでしょうか。これではあるのですが、", "また、お客様のサービスをご利用いただきますので、お申込みできなくお願いします。お客さんがございました。", "あなたのお．．．わかりませんです", "しかし、この人は何かできないというのは、あなたは自分のことを知っているのですが、", "また、これからの記事をしていますので、お問い合わせくださいましたが、お客様のご相談をお願いします。", "本当はそれでは出来なくなってくれたんでしょうね。今日の朝の時期は終わりました。", "ああ．．．ああっ、はあっはあああはははっは"]}, {"box": [941, 247, 1009, 528], "vertical": false, "font_size": 14, "lines_coords": [[[948.0, 348.0], [969.0, 348.0], [969.0, 358.0], [948.0, 358.0]], [[948.0, 371.0], [974.0, 371.0], [974.0, 381.0], [948.0, 381.0]], [[949.0, 382.0], [976.0, 382.0], [976.0, 392.0], [949.0, 392.0]], [[948.0, 391.0], [1001.0, 391.0], [1001.0, 406.0], [948.0, 406.0]], [[949.0, 404.0], [1002.0, 404.0], [1002.0, 419.0], [949.0, 419.0]], [[949.0, 416.0], [1002.0, 416.0], [1002.0, 431.0], [949.0, 431.0]], [[948.0, 427.0], [1004.0, 427.0], [1004.0, 442.0], [948.0, 442.0]], [[957.0, 440.0], [1004.0, 440.0], [1004.0, 455.0], [957.0, 455.0]], [[949.0, 451.0], [1004.0, 449.0], [1004.0, 466.0], [949.0, 467.0]], [[949.0, 462.0], [1002.0, 462.0], [1002.0, 481.0], [949.0, 481.0]], [[949.0, 474.0], [1002.0, 474.0], [1002.0, 494.0], [949.0, 494.0]], [[948.0, 487.0], [1004.0, 483.0], [1004.0, 505.0], [948.0, 508.0]], [[949.0, 498.0], [1005.0, 498.0], [1005.0, 519.0], [949.0, 519.0]], [[951.0, 513.0], [988.0, 513.0], [988.0, 528.0], [951.0, 528.0]]], "lines": ["できないで", "ロナギまで", "．．．", "はいはいないの", "のやりちゃん、ですよね", "ロロロックで１日ですけど、おかげで", "わかっているのですね、ねーよ！！", "Ｃｈｕｎｅｒｔｕｍ", "だめだね．．．", "グレードでは", "けどねえよねえのようにしましたが", "あれはははっははあああっはぁ、ぐんっ、んんっ．．．", "いやではなくしかの人間の、じゃなくての知れないのか？", "まどくＯＫＳは"]}, {"box": [160, 503, 415, 589], "vertical": false, "font_size": 15.833333333333334, "lines_coords": [[[193.0, 503.0], [393.0, 517.0], [393.0, 532.0], [193.0, 518.0]], [[213.0, 515.0], [406.0, 528.0], [406.0, 543.0], [213.0, 531.0]], [[182.0, 526.0], [393.0, 539.0], [393.0, 554.0], [182.0, 542.0]], [[181.0, 539.0], [407.0, 551.0], [407.0, 567.0], [181.0, 554.0]], [[162.0, 548.0], [415.0, 562.0], [415.0, 578.0], [162.0, 564.0]], [[160.0, 560.0], [393.0, 573.0], [393.0, 589.0], [160.0, 576.0]]], "lines": ["それでもそれはわからないのあーーーッ．．．最近ですから、おやすすめですよねーっかりはないですね。", "そして．．．そんなのですからないと思っていますが、それはそれ以外の人はどうしてもいいのかもしれませんが、", "．．．お前、お兄ちゃんの中ではありませんでしょうかというのはインターネットのコークは基本的になってきましたし、できませんでしょうか、何かできないのですか", "あーあーーーっ話を合わせているものではないのですが、このような状況についていましたが、", "．．．ありがとうございましたねでしょうかな。その理由がありますのですが、そのままこんなことができないと思っていたので、", "それに対応していることができていい人にはありますが、「では、可愛いなのではなくなったのだろう」というようになってしまっています。"]}, {"box": [203, 587, 370, 610], "vertical": false, "font_size": 17, "lines_coords": [[[203.0, 587.0], [370.0, 593.0], [370.0, 610.0], [203.0, 604.0]]], "lines": ["みんのーんーおーいはーめんこの"]}, {"box": [118, 607, 437, 687], "vertical": false, "font_size": 17, "lines_coords": [[[142.0, 605.0], [412.0, 621.0], [412.0, 641.0], [142.0, 625.0]], [[139.0, 626.0], [199.0, 626.0], [199.0, 636.0], [139.0, 636.0]], [[134.0, 626.0], [384.0, 638.0], [384.0, 664.0], [134.0, 652.0]], [[124.0, 641.0], [421.0, 657.0], [421.0, 677.0], [124.0, 661.0]], [[131.0, 654.0], [421.0, 668.0], [421.0, 689.0], [131.0, 675.0]]], "lines": ["いや、まだまだ早く使っていたのでｔｅａｎｄｏｎは、同じようなものではないんだ", "ありがとう！！", "これからは、これまではないのでしょうか。それでもいいですが、", "アルバイトの映画を作りましたのですが、一人で一緒になってしまうと思います。１０月２６日（日）のおすするんじゃありますのですが、Ｔｗｉｔｔｅｒになってきました。", "それじゃあ、そういうわけじゃないのですからねーって言ってないんだよ。そのために、クロックサイトではないのですが、"]}, {"box": [706, 478, 732, 649], "vertical": true, "font_size": 22, "lines_coords": [[[710.0, 478.0], [732.0, 478.0], [727.0, 646.0], [706.0, 646.0]]], "lines": ["２０１７年１０月１０日の１０００万円"]}, {"box": [721, 481, 829, 502], "vertical": false, "font_size": 23, "lines_coords": [[[721.0, 479.0], [829.0, 479.0], [829.0, 504.0], [721.0, 504.0]]], "lines": ["２０１６年１１月１０日金の時期．．．Ｃｏｎｄｒｅｓｔａｌｌｅｓｓａｓｔｅｒ．．．"]}, {"box": [770, 508, 808, 640], "vertical": true, "font_size": 22, "lines_coords": [[[773.0, 571.0], [795.0, 573.0], [791.0, 639.0], [770.0, 637.0]]], "lines": ["い．．．いい？お兄ちゃんはいいんじゃないのか！？"]}], "img_path": "045.png"}, {"version": "0.1.7", "img_width": 1109, "img_height": 1600, "blocks": [], "img_path": "046.png"}, {"version": "0.1.7", "img_width": 1108, "img_height": 1600, "blocks": [{"box": [70, 260, 195, 441], "vertical": true, "font_size": 34, "lines_coords": [[[159.0, 264.0], [190.0, 264.0], [190.0, 440.0], [159.0, 440.0]], [[112.0, 260.0], [150.0, 260.0], [150.0, 425.0], [112.0, 425.0]], [[70.0, 264.0], [103.0, 264.0], [103.0, 440.0], [70.0, 440.0]]], "lines": ["顔を変える", "前に何か", "あった．．．？"]}, {"box": [70, 840, 193, 1021], "vertical": true, "font_size": 34, "lines_coords": [[[160.0, 845.0], [189.0, 845.0], [189.0, 982.0], [160.0, 982.0]], [[112.0, 840.0], [153.0, 842.0], [148.0, 953.0], [107.0, 951.0]], [[70.0, 843.0], [103.0, 843.0], [103.0, 1021.0], [70.0, 1021.0]]], "lines": ["生きてる", "実感が", "あった．．．？"]}, {"box": [62, 1369, 196, 1548], "vertical": true, "font_size": 40, "lines_coords": [[[156.0, 1370.0], [196.0, 1370.0], [196.0, 1476.0], [156.0, 1476.0]], [[107.0, 1370.0], [153.0, 1370.0], [153.0, 1482.0], [107.0, 1482.0]], [[65.0, 1371.0], [98.0, 1371.0], [98.0, 1548.0], [65.0, 1548.0]]], "lines": ["本当の", "自分が", "存在した？"]}], "img_path": "047.png"}, {"version": "0.1.7", "img_width": 1104, "img_height": 1600, "blocks": [{"box": [170, 143, 271, 785], "vertical": true, "font_size": 101, "lines_coords": [[[170.0, 143.0], [271.0, 143.0], [271.0, 785.0], [170.0, 785.0]]], "lines": ["何もねえ．．．"]}], "img_path": "048.png"}, {"version": "0.1.7", "img_width": 1107, "img_height": 1600, "blocks": [], "img_path": "049.png"}, {"version": "0.1.7", "img_width": 1100, "img_height": 1600, "blocks": [{"box": [5, 1031, 61, 1055], "vertical": false, "font_size": 26, "lines_coords": [[[5.0, 1029.0], [61.0, 1029.0], [61.0, 1057.0], [5.0, 1057.