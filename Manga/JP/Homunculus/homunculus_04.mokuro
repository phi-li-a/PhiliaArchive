0.1.7", "img_width": 850, "img_height": 1200, "blocks": [], "img_path": "196.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [668, 965, 682, 1005], "vertical": true, "font_size": 14, "lines_coords": [[[668.0, 965.0], [682.0, 965.0], [682.0, 1005.0], [668.0, 1005.0]]], "lines": ["朝から．．．"]}], "img_path": "197.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [], "img_path": "198.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [51, 571, 434, 619], "vertical": false, "font_size": 44, "lines_coords": [[[51.0, 571.0], [434.0, 576.0], [434.0, 619.0], [51.0, 615.0]]], "lines": ["［ホムンクルス］第４集＂完"]}, {"box": [45, 1083, 619, 1155], "vertical": false, "font_size": 17, "lines_coords": [[[50.0, 1086.0], [613.0, 1086.0], [613.0, 1102.0], [50.0, 1102.0]], [[49.0, 1101.0], [587.0, 1101.0], [587.0, 1121.0], [49.0, 1121.0]], [[46.0, 1117.0], [546.0, 1118.0], [546.0, 1137.0], [46.0, 1136.0]], [[48.0, 1134.0], [452.0, 1135.0], [452.0, 1155.0], [48.0, 1153.0]]], "lines": ["●作品中のトレパネーションをは極めて危険な行為です。絶対に真似をしないでください。無い。", "今回の作品はフィクション言う．．．は個の人に似なわねです。実在する人物・団体・バッグのリーバーハウスのそんな知人に興味をしないことで、事件等とは一切関係ありません。", "今回のＦＦＥはイインコインでも多い週刊ビッグコミックスピリッツ実はする人物の日本軍の１２００４年２７－３２号、５号、そしては３６号、２号掲載作品。", "あ．．．嘘リヒッシュミンスピックの働けホムングルズ「公式ホームページオレはキャーンとう、ということで、一ジーやればなんだからねー。"]}], "img_path": "199.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [668, 64, 764, 483], "vertical": true, "font_size": 96, "lines_coords": [[[668.0, 64.0], [764.0, 64.0], [764.0, 483.0], [668.0, 483.0]]], "lines": ["女子高生の"]}, {"box": [655, 59, 774, 915], "vertical": true, "font_size": 119, "lines_coords": [[[655.0, 59.0], [774.0, 59.0], [774.0, 915.0], [655.0, 915.0]]], "lines": ["女子高生の忘れ物が"]}, {"box": [769, 566, 796, 815], "vertical": true, "font_size": 23, "lines_coords": [[[769.0, 602.0], [792.0, 602.0], [792.0, 803.0], [769.0, 803.0]]], "lines": ["．．．"]}, {"box": [671, 538, 778, 918], "vertical": true, "font_size": 107, "lines_coords": [[[671.0, 538.0], [778.0, 538.0], [778.0, 918.0], [671.0, 918.0]]], "lines": ["忘れ物が"]}, {"box": [-19, 1047, 821, 1195], "vertical": false, "font_size": 91, "lines_coords": [[[44.0, 1049.0], [808.0, 1039.0], [808.0, 1100.0], [44.0, 1109.0]], [[34.0, 1079.0], [587.0, 1083.0], [587.0, 1188.0], [34.0, 1184.0]], [[522.0, 1066.0], [821.0, 1073.0], [818.0, 1199.0], [519.0, 1196.0]]], "lines": ["『翌日ビッグネックビリッグにて何度説明！？クローローラー！！", "２００５年２月末頃発売", "発売予定！！！"]}], "img_path": "200.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [57, 55, 196, 803], "vertical": true, "font_size": 125, "lines_coords": [[[71.0, 55.0], [196.0, 57.0], [182.0, 803.0], [57.0, 801.0]]], "lines": ["名越を迷宮へと誘"]}, {"box": [363, 1051, 803, 1200], "vertical": false, "font_size": 113, "lines_coords": [[[376.0, 1051.0], [803.0, 1095.0], [790.0, 1200.0], [363.0, 1171.0]]], "lines": ["レクルス１第５集は、"]}], "img_path": "201.png"}, {"version": "0.1.7", "img_width": 835, "img_height": 1200, "blocks": [{"box": [108, 106, 386, 194], "vertical": false, "font_size": 36.5, "lines_coords": [[[108.0, 113.0], [385.0, 106.0], [386.0, 147.0], [110.0, 154.0]], [[158.0, 162.0], [329.0, 162.0], [329.0, 194.0], [158.0, 194.0]]], "lines": ["ホムンクルス区", "ビッグコミックス"]}, {"box": [159, 569, 222, 594], "vertical": false, "font_size": 24, "lines_coords": [[[201.0, 569.0], [222.0, 569.0], [222.0, 589.0], [201.0, 589.0]], [[159.0, 569.0], [180.0, 569.0], [180.0, 594.0], [159.0, 594.0]]], "lines": ["者", "皆"]}, {"box": [166, 450, 469, 473], "vertical": false, "font_size": 23, "lines_coords": [[[166.0, 450.0], [469.0, 450.0], [469.0, 473.0], [166.0, 473.0]]], "lines": ["２００５年２月１日初版第１刷発行"]}, {"box": [461, 407, 738, 431], "vertical": false, "font_size": 24, "lines_coords": [[[461.0, 407.0], [738.0, 407.0], [738.0, 431.0], [461.0, 431.0]]], "lines": ["ＩＳＢＮ４－Ｏ９－１８７０７４－０"]}, {"box": [652, 445, 737, 472], "vertical": false, "font_size": 24, "lines_coords": [[[652.0, 447.0], [737.0, 445.0], [737.0, 469.0], [652.0, 472.0]]], "lines": ["（検印廃止）"]}, {"box": [158, 645, 226, 708], "vertical": false, "font_size": 24, "lines_coords": [[[159.0, 645.0], [223.0, 645.0], [223.0, 671.0], [159.0, 671.0]], [[158.0, 684.0], [226.0, 684.0], [226.0, 708.0], [158.0, 708.0]]], "lines": ["発行者", "印刷所"]}, {"box": [111, 810, 211, 849], "vertical": false, "font_size": 39, "lines_coords": [[[111.0, 810.0], [211.0, 810.0], [211.0, 849.0], [111.0, 849.0]]], "lines": ["発行所"]}, {"box": [111, 748, 313, 791], "vertical": false, "font_size": 22.0, "lines_coords": [[[112.0, 748.0], [313.0, 748.0], [313.0, 768.0], [112.0, 768.0]], [[111.0, 767.0], [267.0, 765.0], [267.0, 788.0], [111.0, 791.0]]], "lines": ["単行本編集責任ノ志波秀宇ｗ仁±涇＃ノ四★３", "単行本細柴貝古ノ心あ単行木編集ノ銀杏社"]}, {"box": [356, 560, 624, 708], "vertical": false, "font_size": 24, "lines_coords": [[[356.0, 562.0], [534.0, 562.0], [534.0, 591.0], [356.0, 591.0]], [[357.0, 605.0], [619.0, 602.0], [619.0, 630.0], [357.0, 632.0]], [[357.0, 644.0], [427.0, 644.0], [427.0, 668.0], [357.0, 668.0]], [[508.0, 644.0], [530.0, 644.0], [530.0, 668.0], [508.0, 668.0]], [[359.0, 684.0], [530.0, 684.0], [530.0, 708.0], [359.0, 708.0]]], "lines": ["大丈夫ですね", "◎Ｆｉｃｅｏ＇Ｙａｎａｍｏｔｏ．２０１５", "原笹", "博", "凸版印刷株式会社"]}, {"box": [358, 561, 623, 709], "vertical": false, "font_size": 148, "lines_coords": [[[358.0, 561.0], [623.0, 561.0], [623.0, 709.0], [358.0, 709.0]]], "lines": ["山、本、英一大学でＦｉｃｅｂｏｏｋｉｏｎの２０１７年１０月１１月１７日に開催されます。"]}, {"box": [241, 850, 453, 866], "vertical": false, "font_size": 16, "lines_coords": [[[241.0, 850.0], [453.0, 850.0], [453.0, 866.0], [241.0, 866.0]]], "lines": ["振替（００１８０一１一２００／ＴＥＬ"]}, {"box": [237, 805, 576, 823], "vertical": false, "font_size": 16, "lines_coords": [[[237.0, 807.0], [576.0, 805.0], [576.0, 821.0], [237.0, 823.0]]], "lines": ["（〒１０１－８００）東京都千代田区一ツ橋二の三の"]}, {"box": [448, 840, 589, 878], "vertical": false, "font_size": 18, "lines_coords": [[[455.0, 838.0], [587.0, 838.0], [587.0, 857.0], [455.0, 857.0]], [[449.0, 855.0], [589.0, 858.0], [589.0, 878.0], [449.0, 876.0]]], "lines": ["編集１０３（３２３０）５５０５", "・編集のＷｅｂの販売Ｏ３（５２８１）３５６"]}, {"box": [632, 707, 741, 721], "vertical": false, "font_size": 13, "lines_coords": [[[632.0, 707.0], [741.0, 708.0], [741.0, 721.0], [632.0, 720.0]]], "lines": ["Ｐｒｉｎｔｅｄｉｎｊａｐａｎ"]}, {"box": [635, 854, 740, 890], "vertical": false, "font_size": 17.333333333333332, "lines_coords": [[[637.0, 854.0], [678.0, 854.0], [678.0, 871.0], [637.0, 871.0]], [[674.0, 863.0], [740.0, 863.0], [740.0, 880.0], [674.0, 880.0]], [[635.0, 873.0], [676.0, 870.0], [678.0, 888.0], [637.0, 890.0]]], "lines": ["株式", "小学館", "会社！"]}, {"box": [137, 1045, 252, 1057], "vertical": false, "font_size": 12, "lines_coords": [[[137.0, 1045.0], [252.0, 1045.0], [252.0, 1057.0], [137.0, 1057.0]]], "lines": ["アンケートのお願い"]}, {"box": [117, 907, 701, 1036], "vertical": false, "font_size": 15, "lines_coords": [[[117.0, 908.0], [701.0, 906.0], [701.0, 925.0], [117.0, 927.0]], [[117.0, 923.0], [619.0, 922.0], [619.0, 939.0], [117.0, 940.0]], [[118.0, 940.0], [274.0, 940.0], [274.0, 955.0], [118.0, 955.0]], [[117.0, 953.0], [623.0, 951.0], [623.0, 971.0], [117.0, 972.0]], [[117.0, 969.0], [552.0, 968.0], [552.0, 985.0], [117.0, 986.0]], [[118.0, 985.0], [329.0, 985.0], [329.0, 1001.0], [118.0, 1001.0]], [[117.0, 999.0], [618.0, 998.0], [618.0, 1015.0], [117.0, 1016.0]], [[118.0, 1015.0], [559.0, 1014.0], [559.0, 1030.0], [118.0, 1032.0]]], "lines": ["●遊ぶには十分注意しておりますが、２０１７年のベージの抜け落ちや部隊の間違いがメッシュメッセージャージュースをいつ場合はお取り替えいたします。私もいつまで", "基本一はイグ生懸してみた購入された書店名を明記しております。まずか、各インルームページでは、「新作用」あてにお送りください。選挙がお、聞いて何か．．．あなたのお仕負担にてお取り替えいたします。", "教えていることを自由にして、都市作局（コミュニーの１２月１３日（金）（水）", "おかげ同じようにいるというのは、●本書の一部あるいは全部を無断ですが、〈復興〉《板》上演が放送等をすることは、そのままチェットしました。法律で認められた場合を除き、サポーション", "本作者の一部の多くは全部と一緒に著作者および出版者の権利の役を行っていただいて、こなります。あらかじめ小松あることは、伝統して許諾をお求めください。", "Ｒ「日本複写権センタ一委託出版物", "出ている中役プロジェク一安市の本音の一部または全部を無断で検索しています。初めてビーリすることは、著作航法上での「何かを除き禁じられています。", "中部クールみんなもので、複写を希望される場合は、日本権写在センター（Ｃ）は、日本複写権センクー（ＴＥＤ）ＣＯＳ１１月２４日、インターネットの３０日、２０１７年８月２８日にご連絡ください。"]}, {"box": [313, 1044, 408, 1055], "vertical": false, "font_size": 11, "lines_coords": [[[313.0, 1044.0], [408.0, 1044.0], [408.0, 1055.0], [313.0, 1055.0]]], "lines": ["小学館アンケート係"]}, {"box": [129, 1069, 624, 1151], "vertical": false, "font_size": 15, "lines_coords": [[[137.0, 1072.0], [576.0, 1072.0], [576.0, 1088.0], [137.0, 1088.0]], [[134.0, 1087.0], [453.0, 1086.0], [453.0, 1105.0], [134.0, 1107.0]], [[137.0, 1103.0], [432.0, 1101.0], [432.0, 1118.0], [137.0, 1119.0]], [[137.0, 1118.0], [620.0, 1117.0], [620.0, 1134.0], [137.0, 1135.0]], [[135.0, 1133.0], [556.0, 1132.0], [556.0, 1149.0], [135.0, 1150.0]]], "lines": ["●小学館のコミックス、書籍についてのアンケートをインターネットットで受け付けています。", "ｈｔｔｐ／／ｔｐ：／／ｗｗｗ．ｉｎｆｏ．ｊｐｔｏ！！ｔｔｅ：このコミュニケースのキャンペーンいたの心にアクセスしていただき、ワクワード・", "このコミックスのキーフォンのことで、このゴミッグスのギーコーあれはいいんだけどいいのですけどねーぞ入力してください。", "●全ご回答者の中から、毎年一日といえば、１０月２０日金の方に対応で、小学施術者の事務所等の事業者がＬＦ１０００円）をさしあげます。", "そこで当社のケースがありますので、今回行いますが、事務所は事前までのお客様のおい、いやいや本のお前達をもってかえさせていただきます。"]}], "img_path": "202.png"}]}