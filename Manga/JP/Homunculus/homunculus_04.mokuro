．"]}, {"box": [208, 738, 228, 805], "vertical": true, "font_size": 20, "lines_coords": [[[208.0, 738.0], [228.0, 738.0], [228.0, 805.0], [208.0, 805.0]]], "lines": ["．．．．．．？"]}, {"box": [53, 721, 73, 839], "vertical": true, "font_size": 17, "lines_coords": [[[53.0, 721.0], [70.0, 721.0], [70.0, 835.0], [53.0, 835.0]]], "lines": ["そんなの．．．"]}, {"box": [615, 1040, 662, 1146], "vertical": true, "font_size": 22, "lines_coords": [[[639.0, 1040.0], [660.0, 1040.0], [661.0, 1146.0], [640.0, 1146.0]], [[615.0, 1040.0], [639.0, 1040.0], [639.0, 1108.0], [615.0, 1108.0]]], "lines": ["現に、キミの", "前髪は、"]}, {"box": [301, 973, 352, 1102], "vertical": true, "font_size": 26, "lines_coords": [[[320.0, 973.0], [352.0, 973.0], [352.0, 1024.0], [320.0, 1024.0]], [[301.0, 976.0], [320.0, 976.0], [323.0, 1101.0], [303.0, 1101.0]]], "lines": ["左を", "防御している。"]}], "img_path": "021.png"}, {"version": "0.1.7", "img_width": 854, "img_height": 1200, "blocks": [{"box": [575, 17, 650, 138], "vertical": true, "font_size": 23, "lines_coords": [[[625.0, 18.0], [650.0, 18.0], [650.0, 101.0], [625.0, 101.0]], [[603.0, 19.0], [623.0, 19.0], [623.0, 138.0], [603.0, 138.0]], [[577.0, 17.0], [600.0, 17.0], [598.0, 137.0], [575.0, 137.0]]], "lines": ["バッグを", "持ってる時も", "置く時も．．．"]}, {"box": [242, 189, 311, 285], "vertical": true, "font_size": 22, "lines_coords": [[[290.0, 191.0], [310.0, 191.0], [310.0, 285.0], [290.0, 285.0]], [[263.0, 189.0], [289.0, 189.0], [289.0, 251.0], [263.0, 251.0]], [[242.0, 191.0], [262.0, 191.0], [262.0, 276.0], [242.0, 276.0]]], "lines": ["防御したい", "左側に", "必ずある。"]}, {"box": [618, 367, 634, 432], "vertical": true, "font_size": 16, "lines_coords": [[[618.0, 367.0], [634.0, 367.0], [634.0, 432.0], [618.0, 432.0]]], "lines": ["．．．．．．"]}, {"box": [476, 348, 496, 446], "vertical": true, "font_size": 20, "lines_coords": [[[476.0, 348.0], [496.0, 348.0], [496.0, 446.0], [476.0, 446.0]]], "lines": ["それは．．．"]}, {"box": [138, 365, 184, 503], "vertical": true, "font_size": 20, "lines_coords": [