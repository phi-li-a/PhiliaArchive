7.0]]], "lines": ["ハハハ。"]}, {"box": [121, 756, 166, 881], "vertical": true, "font_size": 18, "lines_coords": [[[147.0, 757.0], [164.0, 757.0], [164.0, 870.0], [147.0, 870.0]], [[121.0, 757.0], [141.0, 757.0], [141.0, 881.0], [121.0, 881.0]]], "lines": ["東京なんかで", "働けないよお。"]}, {"box": [601, 976, 669, 1161], "vertical": true, "font_size": 20, "lines_coords": [[[649.0, 977.0], [668.0, 977.0], [668.0, 1094.0], [649.0, 1094.0]], [[622.0, 976.0], [645.0, 976.0], [645.0, 1161.0], [622.0, 1161.0]], [[601.0, 978.0], [620.0, 978.0], [620.0, 1101.0], [601.0, 1101.0]]], "lines": ["会社の同僚や", "後輩が、うじやうじゃ", "いるからねえ。"]}], "img_path": "075.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [531, 256, 548, 319], "vertical": true, "font_size": 17, "lines_coords": [[[531.0, 256.0], [548.0, 256.0], [548.0, 319.0], [531.0, 319.0]]], "lines": ["．．．．．．"]}, {"box": [237, 217, 309, 297], "vertical": true, "font_size": 22, "lines_coords": [[[283.0, 217.0], [309.0, 217.0], [309.0, 281.0], [283.0, 281.0]], [[261.0, 217.0], [282.0, 217.0], [282.0, 297.0], [261.0, 297.0]], [[237.0, 219.0], [257.0, 219.0], [257.0, 297.0], [237.0, 297.0]]], "lines": ["収入は", "どうなん", "ですか？"]}, {"box": [642, 433, 711, 541], "vertical": true, "font_size": 20, "lines_coords": [[[691.0, 434.0], [711.0, 434.0], [711.0, 525.0], [691.0, 525.0]], [[665.0, 433.0], [685.0, 433.0], [685.0, 515.0], [665.0, 515.0]], [[642.0, 434.0], [661.0, 434.0], [661.0, 540.0], [642.0, 540.0]]], "lines": ["まっ、金は", "ほとんど", "入らないね。"]}, {"box": [535, 967, 603, 1102], "vertical": true, "font_size": 20, "lines_coords": [[[583.0, 967.0], [603.0, 967.0], [603.0, 1046.0], [583.0, 1046.0]], [[560.0, 967.0], [579.0, 967.0], [579.0, 1102.0], [560.0, 1102.0]], [[535.0, 967.0], [555.0, 967.0], [555.0, 1069.0], [535.0, 1069.0]]], "lines": ["たまたま", "息子がこっちで", "就職してね、"]}, {"box": [74, 1000, 142, 1154], "vertical": true, "font_size": 19, "lines_coords": [[[120.0, 1000.0], [141.0, 1000.0], [141.0, 1085.0], [120.0, 1085.0]], [[97.