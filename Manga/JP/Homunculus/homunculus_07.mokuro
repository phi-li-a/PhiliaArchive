, 1173.0]]], "lines": ["あとは", "いただいた", "臓器を", "俺が売りさばく。"]}, {"box": [361, 931, 434, 1027], "vertical": true, "font_size": 23, "lines_coords": [[[412.0, 932.0], [433.0, 932.0], [433.0, 1017.0], [412.0, 1017.0]], [[383.0, 931.0], [412.0, 931.0], [412.0, 999.0], [383.0, 999.0]], [[362.0, 933.0], [381.0, 933.0], [381.0, 1023.0], [362.0, 1023.0]]], "lines": ["貸した金", "以上の", "金額でね"]}], "img_path": "025.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [631, 4, 706, 170], "vertical": true, "font_size": 22, "lines_coords": [[[674.0, 5.0], [701.0, 4.0], [706.0, 67.0], [678.0, 69.0]], [[656.0, 7.0], [675.0, 7.0], [675.0, 106.0], [656.0, 106.0]], [[631.0, 7.0], [651.0, 7.0], [651.0, 167.0], [631.0, 167.0]]], "lines": ["そして", "数字だけを", "コントロールして、"]}, {"box": [424, 17, 469, 142], "vertical": true, "font_size": 21, "lines_coords": [[[449.0, 18.0], [469.0, 18.0], [469.0, 137.0], [449.0, 137.0]], [[424.0, 17.0], [447.0, 17.0], [447.0, 142.0], [424.0, 142.0]]], "lines": ["会社は次第に", "沈んでいって、"]}, {"box": [332, 44, 356, 153], "vertical": true, "font_size": 21, "lines_coords": [[[332.0, 44.0], [353.0, 44.0], [356.0, 153.0], [335.0, 153.0]]], "lines": ["ポッチャン。"]}, {"box": [227, 141, 244, 201], "vertical": true, "font_size": 17, "lines_coords": [[[227.0, 141.0], [244.0, 141.0], [244.0, 201.0], [227.0, 201.0]]], "lines": ["．．．．．．"]}, {"box": [22, 246, 90, 403], "vertical": true, "font_size": 19, "lines_coords": [[[70.0, 246.0], [90.0, 246.0], [90.0, 383.0], [70.0, 383.0]], [[48.0, 247.0], [64.0, 247.0], [64.0, 383.0], [48.0, 383.0]], [[22.0, 246.0], [42.0, 246.0], [42.0, 403.0], [22.0, 403.0]]], "lines": ["銀行ってそんな", "ひどいヤリ方で", "稼いでるのね．．．"]}, {"box": [82, 501, 161, 655], "vertical": true, "font_size": 25, "lines_coords": [[[139.0, 505.0], [159.0, 505.0], [159.0, 655.0], [139.0, 655.0]], [[111.0, 503.0], [135.0, 503.0], [133.0, 635.0], [108.0, 635.0]], [[82.0, 501.0], [112.0, 501.0], [112.0, 561.0], [82.0, 561.0]]], "lines": ["肉にたかってる", "ハゲタカ以下", "だよ。"]}, {"box": [586, 686, 689, 828], "vertical": true, "font_size": 24, "lines_coords": [[[667.0, 689.0], [688.0, 689.0], [688.0, 796.0], [667.0, 796.0]], [[640.0, 690.0], [661.0, 690.0], [661.0, 796.0], [640.0, 796.0]], [[609.0, 687.0], [638.0, 686.0], [640.0, 758.0], [611.0, 759.0]], [[586.0, 690.0], [610.0, 690.0], [610.0, 826.0], [586.0, 826.0]]], "lines": ["銀行なんて", "俺も含めて", "みんな", "ハイエナだよ。"]}, {"box": [627, 1018, 673, 1136], "vertical": true, "font_size": 21, "lines_coords": [[[645.0, 1018.0], [670.0, 1018.0], [673.0, 1136.0], [649.0, 1136.0]], [[627.0, 1021.0], [645.0, 1021.0], [645.0, 1060.0], [627.0, 1060.0]]], "lines": ["ナコっちゃん", "．．．"]}, {"box": [57, 1086, 89, 1140], "vertical": true, "font_size": 32, "lines_coords": [[[57.0, 1086.0], [89.0, 1086.0], [89.0, 1140.0], [57.0, 1140.0]]], "lines": ["ん？"]}], "img_path": "026.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [767, 12, 814, 91], "vertical": true, "font_size": 23, "lines_coords": [[[793.0, 12.0], [813.0, 12.0], [813.0, 91.0], [793.0, 91.0]], [[767.0, 12.0], [793.0, 12.0], [793.0, 62.0], [767.0, 62.0]]], "lines": ["仕事とは", "いえ、"]}, {"box": [530, 5, 625, 164], "vertical": true, "font_size": 21, "lines_coords": [[[604.0, 5.0], [624.0, 5.0], [624.0, 164.0], [604.0, 164.0]], [[579.0, 7.0], [601.0, 7.0], [601.0, 85.0], [579.0, 85.0]], [[555.0, 5.0], [576.0, 5.0], [576.0, 85.0], [555.0, 85.0]], [[530.0, 7.0], [550.0, 7.0], [550.0, 142.0], [530.0, 142.0]]], "lines": ["そんなことばっか", "やってて", "ストレス", "たまんないの？"]}, {"box": [241, 22, 262, 101], "vertical": true, "font_size": 21, "lines_coords": [[[241.0, 22.0], [262.0, 22.0], [262.0, 101.0], [241.0, 101.0]]], "lines": ["なんで？"]}, {"box": [671, 510, 724, 658], "vertical": true, "font_size": 25, "lines_coords": [[[694.0, 510.0], [724.0, 510.0], [724.0, 583.0], [694.0, 583.0]], [[671.0, 513.0], [691.0, 513.0], [691.0, 657.0], [671.0, 657.0]]], "lines": ["だって", "会社潰したら、"]}, {"box": [498, 292, 516, 333], "vertical": true, "font_size": 18, "lines_coords": [[[498.0, 292.0], [516.0, 292.0], [516.0, 333.0], [498.0, 333.0]]], "lines": ["！"]}, {"box": [133, 657, 212, 841], "vertical": true, "font_size": 24, "lines_coords": [[[187.0, 658.0], [210.0, 658.0], [210.0, 841.0], [187.0, 841.0]], [[160.0, 658.0], [183.0, 658.0], [183.0, 789.0], [160.0, 789.0]], [[133.0, 657.0], [158.0, 657.0], [161.0, 780.0], [137.0, 780.0]]], "lines": ["何百、何千人の人が", "途方にくれる", "わけでしょ。"]}, {"box": [717, 991, 734, 1063], "vertical": true, "font_size": 17, "lines_coords": [[[717.0, 991.0], [734.0, 991.0], [734.0, 1063.0], [717.0, 1063.0]]], "lines": ["．．．．．．？"]}], "img_path": "027.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [620, 38, 716, 198], "vertical": true, "font_size": 22, "lines_coords": [[[690.0, 38.0], [716.0, 38.0], [716.0, 84.0], [690.0, 84.0]], [[670.0, 41.0], [690.0, 41.0], [690.0, 198.0], [670.0, 198.0]], [[645.0, 41.0], [665.0, 41.0], [665.0, 180.0], [645.0, 180.0]], [[620.0, 41.0], [642.0, 41.0], [642.0, 107.0], [620.0, 107.0]]], "lines": ["俺の", "やっていることは", "ゲームみたいな", "もんで、"]}, {"box": [465, 50, 535, 191], "vertical": true, "font_size": 22, "lines_coords": [[[507.0, 50.0], [535.0, 50.0], [535.0, 97.0], [507.0, 97.0]], [[487.0, 52.0], [507.0, 52.0], [507.0, 191.0], [487.0, 191.0]], [[465.0, 55.0], [481.0, 55.0], [481.0, 175.0], [465.0, 175.0]]], "lines": ["ただ", "目の前の数字を", "いじくるだけ。"]}, {"box": [237, 32, 306, 191], "vertical": true, "font_size": 21, "lines_coords": [[[284.0, 35.0], [304.0, 35.0], [304.0, 191.0], [284.0, 191.0]], [[257.0, 32.0], [282.0, 32.0], [282.0, 98.0], [257.0, 98.0]], [[237.0, 35.0], [254.0, 35.0], [254.0, 180.0], [237.0, 180.0]]], "lines": ["現金で１億でさえ", "実物を", "見たことないよ。"]}, {"box": [33, 316, 77, 437], "vertical": true, "font_size": 21, "lines_coords": [[[57.0, 317.0], [77.0, 317.0], [77.0, 434.0], [57.0, 434.0]], [[33.0, 316.0], [50.0, 316.0], [50.0, 437.0], [33.0, 437.0]]], "lines": ["その裏で人が", "どうなろうと"]}, {"box": [24, 521, 71, 659], "vertical": true, "font_size": 21, 