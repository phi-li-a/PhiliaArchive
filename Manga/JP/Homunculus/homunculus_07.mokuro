t_size": 23, "lines_coords": [[[564.0, 483.0], [589.0, 483.0], [589.0, 582.0], [564.0, 582.0]], [[543.0, 483.0], [563.0, 483.0], [563.0, 601.0], [543.0, 601.0]], [[516.0, 482.0], [540.0, 482.0], [540.0, 621.0], [516.0, 621.0]], [[494.0, 482.0], [516.0, 482.0], [516.0, 525.0], [494.0, 525.0]]], "lines": ["いやらしい", "プレッシャー", "かけるんですね", "．．．．．"]}, {"box": [339, 465, 359, 553], "vertical": true, "font_size": 20, "lines_coords": [[[339.0, 465.0], [359.0, 465.0], [359.0, 553.0], [339.0, 553.0]]], "lines": ["よく見て。"]}, {"box": [777, 793, 798, 897], "vertical": true, "font_size": 20, "lines_coords": [[[777.0, 793.0], [797.0, 793.0], [797.0, 897.0], [777.0, 897.0]]], "lines": ["千円という、"]}, {"box": [639, 802, 665, 864], "vertical": true, "font_size": 26, "lines_coords": [[[639.0, 802.0], [665.0, 802.0], [665.0, 864.0], [639.0, 864.0]]], "lines": ["価値？"]}, {"box": [104, 639, 160, 699], "vertical": true, "font_size": 32, "lines_coords": [[[121.0, 643.0], [154.0, 639.0], [160.0, 696.0], [127.0, 699.0]], [[104.0, 642.0], [135.0, 642.0], [135.0, 690.0], [104.0, 690.0]]], "lines": ["これ、", "何？"]}, {"box": [477, 1042, 541, 1153], "vertical": true, "font_size": 27, "lines_coords": [[[515.0, 1045.0], [540.0, 1045.0], [540.0, 1153.0], [515.0, 1153.0]], [[477.0, 1042.0], [507.0, 1042.0], [509.0, 1141.0], [480.0, 1141.0]]], "lines": ["借用証書", "でしょ。"]}], "img_path": "009.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [276, 10, 366, 187], "vertical": true, "font_size": 19, "lines_coords": [[[346.0, 10.0], [366.0, 10.0], [366.0, 108.0], [346.0, 108.0]], [[321.0, 10.0], [340.0, 10.0], [340.0, 148.0], [321.0, 148.0]], [[298.0, 10.0], [318.0, 10.0], [318.0, 187.0], [298.0, 187.0]], [[276.0, 10.0], [292.0, 10.0], [292.0, 135.0], [276.0, 135.0]]], "lines": ["日本政府が", "キミから千円を", "借りてるってだけの", "ことでしょう。"]}, {"box": [120, 25, 161, 107], "vertical": true, "font_size": 21, "lines_coords": [[[138.0, 25.0], [159.0, 25.0], [161.0, 107.0], [140.0, 107.0]]], "lines": ["借用証書"]