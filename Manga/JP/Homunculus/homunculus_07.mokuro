"lines": ["しかも", "会社の臓器は", "売りさばけば", "巨大な金になる。"]}, {"box": [660, 200, 708, 289], "vertical": true, "font_size": 20, "lines_coords": [[[684.0, 201.0], [708.0, 201.0], [708.0, 263.0], [684.0, 263.0]], [[660.0, 200.0], [680.0, 200.0], [683.0, 289.0], [663.0, 289.0]]], "lines": ["罪にも", "ならない。"]}, {"box": [187, 16, 283, 134], "vertical": true, "font_size": 20, "lines_coords": [[[263.0, 17.0], [283.0, 17.0], [283.0, 103.0], [263.0, 103.0]], [[235.0, 16.0], [261.0, 16.0], [261.0, 93.0], [235.0, 93.0]], [[213.0, 17.0], [234.0, 17.0], [234.0, 101.0], [213.0, 101.0]], [[187.0, 16.0], [208.0, 16.0], [209.0, 134.0], [188.0, 134.0]]], "lines": ["資産だよ、", "株、土地、", "有価証券、", "外国為替．．．"]}, {"box": [25, 18, 65, 134], "vertical": true, "font_size": 20, "lines_coords": [[[49.0, 19.0], [65.0, 19.0], [65.0, 134.0], [49.0, 134.0]], [[25.0, 18.0], [42.0, 18.0], [42.0, 124.0], [25.0, 124.0]]], "lines": ["金になるもん", "なんでもだ。"]}, {"box": [407, 411, 458, 475], "vertical": true, "font_size": 26, "lines_coords": [[[432.0, 413.0], [458.0, 413.0], [458.0, 475.0], [432.0, 475.0]], [[407.0, 412.0], [434.0, 411.0], [436.0, 474.0], [410.0, 475.0]]], "lines": ["会社の", "臓器？"]}, {"box": [487, 603, 579, 778], "vertical": true, "font_size": 19, "lines_coords": [[[558.0, 604.0], [578.0, 604.0], [578.0, 712.0], [558.0, 712.0]], [[534.0, 605.0], [554.0, 605.0], [554.0, 740.0], [534.0, 740.0]], [[509.0, 603.0], [529.0, 603.0], [529.0, 741.0], [509.0, 741.0]], [[487.0, 605.0], [503.0, 605.0], [503.0, 778.0], [487.0, 778.0]]], "lines": ["でも、なんで", "ナコっちゃんが", "他の会社の資産", "売りさはけるのよ？"]}, {"box": [164, 628, 271, 741], "vertical": true, "font_size": 36, "lines_coords": [[[230.0, 628.0], [271.0, 628.0], [271.0, 692.0], [230.0, 692.0]], [[202.0, 629.0], [235.0, 629.0], [233.0, 741.0], [200.0, 741.0]], [[164.0, 629.0], [199.0, 628.0], [201.0, 701.0], [166.0, 703.0]]], "lines": ["金が", "欲しいん", "だよ。"]}, {"box": [404, 1041, 471, 1184], "vertical": true, "font_size": 19, "lines_coords": [[[451.0, 1042.0], [470.0, 1042.0], [470.0, 11