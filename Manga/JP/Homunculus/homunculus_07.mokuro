716.0, 437.0], [716.0, 542.0], [695.0, 542.0]], [[668.0, 435.0], [688.0, 435.0], [688.0, 590.0], [668.0, 590.0]]], "lines": ["実は今回の", "実験のテーマは、"]}, {"box": [289, 443, 343, 618], "vertical": true, "font_size": 24, "lines_coords": [[[318.0, 444.0], [343.0, 444.0], [340.0, 585.0], [316.0, 585.0]], [[289.0, 444.0], [312.0, 444.0], [312.0, 618.0], [289.0, 618.0]]], "lines": ["「プラシーボ」", "だったんですよ。"]}, {"box": [171, 480, 190, 554], "vertical": true, "font_size": 19, "lines_coords": [[[171.0, 480.0], [190.0, 480.0], [190.0, 554.0], [171.0, 554.0]]], "lines": ["！．．．"]}], "img_path": "190.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [543, 50, 612, 235], "vertical": true, "font_size": 20, "lines_coords": [[[592.0, 51.0], [612.0, 51.0], [612.0, 235.0], [592.0, 235.0]], [[568.0, 51.0], [588.0, 51.0], [588.0, 208.0], [568.0, 208.0]], [[543.0, 50.0], [563.0, 50.0], [563.0, 207.0], [543.0, 207.0]]], "lines": ["人間には、どんなこと", "でも信じ込ませる", "ことができる．．．"]}, {"box": [780, 479, 825, 587], "vertical": true, "font_size": 22, "lines_coords": [[[800.0, 479.0], [825.0, 479.0], [825.0, 536.0], [800.0, 536.0]], [[780.0, 479.0], [800.0, 479.0], [802.0, 587.0], [782.0, 587.0]]], "lines": ["トレパ", "ネーション："]}, {"box": [562, 457, 639, 632], "vertical": true, "font_size": 19, "lines_coords": [[[608.0, 457.0], [629.0, 457.0], [630.0, 536.0], [609.0, 536.0]], [[585.0, 458.0], [605.0, 458.0], [605.0, 614.0], [585.0, 614.0]], [[563.0, 458.0], [579.0, 458.0], [579.0, 632.0], [563.0, 632.0]]], "lines": ["頭蓋骨に", "穴を開けただけで", "第六感が芽生える？"]}, {"box": [436, 447, 461, 515], "vertical": true, "font_size": 25, "lines_coords": [[[436.0, 447.0], [461.0, 447.0], [461.0, 515.0], [436.0, 515.0]]], "lines": ["しかし、"]}, {"box": [119, 251, 164, 398], "vertical": true, "font_size": 21, "lines_coords": [[[139.0, 251.0], [164.0, 251.0], [164.0, 316.0], [139.0, 316.0]], [[120.0, 255.0], [137.0, 255.0], [137.0, 397.0], [120.0, 397.0]]], "lines": ["それを", "実証したかった。"]}, {"box": [544, 800, 636, 957]