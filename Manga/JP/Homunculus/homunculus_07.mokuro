], [798.0, 308.0]], [[775.0, 240.0], [795.0, 240.0], [795.0, 348.0], [775.0, 348.0]], [[749.0, 240.0], [769.0, 240.0], [769.0, 348.0], [749.0, 348.0]]], "lines": ["こんな", "中途半端な", "状態でなあ"]}, {"box": [353, 100, 422, 295], "vertical": true, "font_size": 20, "lines_coords": [[[401.0, 101.0], [421.0, 101.0], [421.0, 237.0], [401.0, 237.0]], [[376.0, 100.0], [395.0, 100.0], [395.0, 246.0], [376.0, 246.0]], [[353.0, 101.0], [373.0, 101.0], [373.0, 295.0], [353.0, 295.0]]], "lines": ["お約束の７０万は", "これで、ちゃんと", "お渡ししましたよね？"]}, {"box": [496, 462, 567, 582], "vertical": true, "font_size": 22, "lines_coords": [[[547.0, 465.0], [567.0, 465.0], [567.0, 582.0], [547.0, 582.0]], [[523.0, 464.0], [543.0, 464.0], [543.0, 581.0], [523.0, 581.0]], [[496.0, 462.0], [522.0, 462.0], [522.0, 530.0], [496.0, 530.0]]], "lines": ["なんの問題も", "ないじゃない", "ですか、"]}, {"box": [231, 454, 248, 519], "vertical": true, "font_size": 17, "lines_coords": [[[231.0, 454.0], [248.0, 454.0], [248.0, 519.0], [231.0, 519.0]]], "lines": ["．．．．．．？"]}, {"box": [647, 822, 669, 913], "vertical": true, "font_size": 21, "lines_coords": [[[647.0, 825.0], [668.0, 825.0], [668.0, 895.0], [647.0, 895.0]]], "lines": ["ふう～～"]}, {"box": [399, 589, 469, 767], "vertical": true, "font_size": 22, "lines_coords": [[[442.0, 589.0], [469.0, 589.0], [469.0, 636.0], [442.0, 636.0]], [[421.0, 591.0], [441.0, 591.0], [441.0, 767.0], [421.0, 767.0]], [[399.0, 591.0], [419.0, 591.0], [419.0, 698.0], [399.0, 698.0]]], "lines": ["逆に", "名越さんにとっては", "好都合です。"]}], "img_path": "177.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [619, 358, 686, 513], "vertical": true, "font_size": 21, "lines_coords": [[[665.0, 358.0], [685.0, 358.0], [686.0, 513.0], [666.0, 513.0]], [[642.0, 358.0], [661.0, 358.0], [661.0, 475.0], [642.0, 475.0]], [[619.0, 359.0], [636.0, 359.0], [636.0, 482.0], [619.0, 482.0]]], "lines": ["カラオケＢＯＸで", "女子高生から", "逃げたように、"]}, {"box": [111, 351, 129, 398], "vertical": true, "font_size": 18, "lines_coords": [[[111.0, 351.0], [129.0, 351.0], [129.0, 398.0], [111.0, 398.0]]], "lines": ["！"]}, {"box": [626, 573, 678, 651], "vertical": true, "font_size": 21, "lines_coords": [[[652.0, 573.0], [678.0, 573.0], [678.0, 642.0], [652.0, 642.0]], [[626.0, 574.0], [651.0, 574.0], [651.0, 651.0], [626.0, 651.0]]], "lines": ["逃げる", "わけか。"]}], "img_path": "178.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [520, 666, 555, 764], "vertical": true, "font_size": 33, "lines_coords": [[[520.0, 667.0], [552.0, 666.0], [555.0, 762.0], [522.0, 764.0]]], "lines": ["っポ．．．"]}, {"box": [747, 978, 774, 1074], "vertical": true, "font_size": 25, "lines_coords": [[[747.0, 978.0], [772.0, 978.0], [774.0, 1074.0], [749.0, 1074.0]]], "lines": ["名越さん、"]}, {"box": [149, 1021, 231, 1171], "vertical": true, "font_size": 25, "lines_coords": [[[206.0, 1024.0], [231.0, 1024.0], [231.0, 1092.0], [206.0, 1092.0]], [[182.0, 1025.0], [202.0, 1025.0], [202.0, 1171.0], [182.0, 1171.0]], [[152.0, 1021.0], [181.0, 1023.0], [179.0, 1102.0], [149.0, 1101.0]]], "lines": ["最初に", "言ったじゃない", "ですか。"]}], "img_path": "179.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [359, 26, 451, 221], "vertical": true, "font_size": 22, "lines_coords": [[[431.0, 28.0], [451.0, 28.0], [451.0, 127.0], [431.0, 127.0]], [[408.0, 26.0], [428.0, 26.0], [426.0, 221.0], [406.0, 221.0]], [[383.0, 28.0], [403.0, 28.0], [403.0, 167.0], [383.0, 167.0]], [[359.0, 29.0], [376.0, 29.0], [378.0, 154.0], [362.0, 154.0]]], "lines": ["この実験は", "「トレパネーション」を", "否定するために", "やるんだって。"]}, {"box": [282, 230, 379, 351], "vertical": true, "font_size": 22, "lines_coords": [[[358.0, 234.0], [379.0, 234.0], [379.0, 333.0], [358.0, 333.0]], [[332.0, 233.0], [357.0, 233.0], [357.0, 296.0], [332.0, 296.0]], [[310.0, 235.0], [330.0, 235.0], [330.0, 351.0], [310.0, 351.0]], [[282.0, 230.0], [313.0, 230.0], [313.0, 288.0], [282.0, 288.0]]], "lines": ["だからこそ", "真剣に", "取り組んだん", "です。"]}, {"box": [575, 406, 691, 625], "vertical": true, "font_size": 20, "lines_coords": [[[671.0, 406.0], [691.0, 406.0], [691.0, 601.0], [671.0, 601.0]], [[646.0, 407.0], [666.0, 407.0], [666.0, 574.0], [646.0, 574.0]], [[620.0, 406.0], [644.0, 406.0], [644.0, 603.0], [620.0, 603.0]], [[598.0, 406.0], [618.0, 406.0], [618.0, 506.0], [598.0, 506.0]], [[575.0, 406.0], [595.0, 406.0], [595.0, 625.0], [575.0, 625.0]]], "lines": ["それが知らないうちに", "僕は、ただ女の子を", "口説いているだけだ．．．", "と思ったら", "猛烈にバカらしくなって、"]}, {"box": [618, 664, 661, 789], "vertical": true, "font_size": 20, "lines_coords": [[[642.0, 664.0], [661.0, 664.0], [661.0, 764.0], [642.0, 764.0]], [[618.0, 664.0], [638.0, 664.0], [638.0, 789.0], [618.0, 789.0]]], "lines": ["あの場から", "去ったんです。"]}, {"box": [19, 659, 36, 725], "vertical": true, "font_size": 17, "lines_coords": [[[19.0, 659.0], [36.0, 659.0], [36.0, 725.0], [19.0, 725.0]]], "lines": ["．．．．．．？"]}, {"box": [89, 850, 111, 941], "vertical": true, "font_size": 21, "lines_coords": [[[89.0, 850.0], [110.0, 850.0], [110.0, 941.0], [89.0, 941.0]]], "lines": ["なにい！？"]}, {"box": [660, 846, 728, 962], "vertical": true, "font_size": 19, "lines_coords": [[[708.0, 847.0], [728.0, 847.0], [728.0, 943.0], [708.0, 943.0]], [[686.0, 847.0], [702.0, 847.0], [702.0, 962.0], [686.0, 962.0]], [[660.0, 846.0], [680.0, 846.0], [680.0, 944.0], [660.0, 944.0]]], "lines": ["じゃあ俺の", "見えちまった", "化け物．．．"]}, {"box": [527, 833, 592, 986], "vertical": true, "font_size": 19, "lines_coords": [[[572.0, 835.0], [592.0, 835.0], [592.0, 949.0], [572.0, 949.0]], [[548.0, 833.0], [568.0, 833.0], [568.0, 918.0], [548.0, 918.0]], [[527.0, 833.0], [543.0, 833.0], [543.0, 986.0], [527.0, 986.0]]], "lines": ["ホムンクルス", "とやらは、", "どういうことだ？"]}, {"box": [350, 880, 424, 988], "vertical": true, "font_size": 23, "lines_coords": [[[394.0, 880.0], [424.0, 880.0], [424.0, 944.0], [394.0, 944.0]], [[376.0, 883.0], [395.0, 883.0], [395.0, 962.0], [376.0, 962.0]], [[352.0, 881.0], [373.0, 881.0], [371.0, 986.0], [350.0, 986.0]]], "lines": ["ただの", "幻覚じゃ", "ないですか。"]}], "img_path": "180.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [342, 130, 389, 284], "vertical": true, "font_size": 22, "lines_coords": [[[366.0, 131.0], [387.0, 131.0], [388.0, 284.0], [367.0, 284.0]], [[342.0, 130.0], [366.0, 130.0], [366.0, 201.0], [342.0, 201.0]]], "lines": ["そのモンブランの", "ように、"]}, {"box": [86, 131, 179, 249], "vertical": true, "font_size": 21, "lines_coords": [[[155.0, 131.0], [179.0, 131.0], [179.0, 249.0], [155.0, 249.0]], [[133.0, 131.0], [153.0, 131.0], [153.0, 212.0], [133.0, 212.0]], [[107.0, 131.0], [127.0, 131.0], [130.0, 247.0], [110.0, 247.0]], [[86.0, 131.0], [106.0, 131.0], [106.0, 199.0], [86.0, 199.0]]], "lines": ["最後の一口の", "ところで", "飽きてしまい", "ました。"]}, {"box": [698, 333, 814, 480], "vertical": true, "font_size": 20, "lines_coords": [[[795.0, 335.0], [811.0, 335.0], [811.0, 450.0], [795.0, 450.0]], [[772.0, 333.0], [791.0, 333.0], [788.0, 480.0], [768.0, 480.0]], [[747.0, 335.0], [767.0, 335.0], [765.0, 424.0], [745.0, 424.0]], [[724.0, 337.0], [743.0, 337.0], [743.0, 471.0], [724.0, 471.0]], [[698.0, 336.0], [722.0, 336.0], [722.0, 406.0], [698.0, 406.0]]], "lines": ["僕はなんでも", "「信じることから", "始める」を", "モットウとして", "います。"]}, {"box": [477, 377, 556, 502], "vertical": true, "font_size": 25, "lines_coords": [[[527.0, 377.0], [556.0, 378.0], [554.0, 424.0], [524.0, 423.0]], [[506.0, 380.0], [527.0, 380.0], [527.0, 478.0], [506.0, 478.0]], [[477.0, 379.0], [501.0, 379.0], [501.0, 502.0], [477.0, 502.0]]], "lines": ["ただ", "飽きるのも", "早い性質で．．．"]}, {"box": [363, 441, 380, 504], "vertical": true, "font_size": 17, "lines_coords": [[[363.0, 441.0], [380.0, 441.0], [380.0, 504.0], [363.0, 504.0]]], "lines": ["．．．．．．？"]}, {"box": [691, 631, 793, 765], "vertical": true, "font_size": 24, "lines_coords": [[[773.0, 635.0], [793.0, 635.0], [793.0, 727.0], [773.0, 727.0]], [[746.0, 631.0], [770.0, 631.0], [768.0, 765.0], [743.0, 765.0]], [[718.0, 632.0], [741.0, 632.0], [741.0, 764.0], [718.0, 764.0]], [[691.0, 631.0], [718.0, 631.0], [718.0, 690.0], [691.0, 690.0]]], "lines": ["名越さん、", "僕は「人間」を", "研究したいん", "です。"]}, {"box": [179, 609, 261, 744], "vertical": true, "font_size": 24, "lines_coords": [[[240.0, 616.0], [260.0, 616.0], [260.0, 744.0], [240.0, 744.0]], [[213.0, 615.0], [234.0, 615.0], [234.0, 723.0], [213.0, 723.0]], [[179.0, 610.0], [210.0, 609.0], [213.0, 672.0], [181.0, 673.0]]], "lines": ["無駄な時間は", "過ごしたく", "ない。"]}, {"box": [134, 834, 255, 987], "vertical": true, "font_size": 20, "lines_coords": [[[231.0, 834.0], [255.0, 834.0], [255.0, 955.0], [231.0, 955.0]], [[208.0, 836.0], [228.0, 836.0], [228.0, 976.0], [208.0, 976.0]], [[186.0, 837.0], [202.0, 837.0], [202.0, 987.0], [186.0, 987.0]], [[160.0, 836.0], [180.0, 836.0], [180.0, 914.0], [160.0, 914.0]], [[134.0, 835.0], [155.0, 835.0], [158.0, 941.0], [137.0, 941.0]]], "lines": ["「人間」を研究", "するに当たって、", "他にもやることが", "たくさん", "あるんです。"]}], "img_path": "181.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [537, 22, 563, 76], "vertical": true, "font_size": 26, "lines_coords": [[[537.0, 22.0], [563.0, 22.0], [563.0, 76.0], [537.0, 76.0]]], "lines": ["よっ。"]}, {"box": [142, 49, 210, 184], "vertical": true, "font_size": 19, "lines_coords": [[[192.0, 50.0], [208.0, 50.0], [208.0, 182.0], [192.0, 182.0]], [[166.0, 49.0], [186.0, 49.0], [186.0, 146.0], [166.0, 146.0]], [[142.0, 49.0], [162.0, 49.0], [162.0, 137.0], [142.0, 137.0]]], "lines": ["今はこの２日間", "催眠療法に", "夢中です。"]}, {"box": [98, 535, 132, 721], "vertical": true, "font_size": 32, "lines_coords": [[[98.0, 535.0], [130.0, 535.0], [132.0, 721.0], [100.0, 721.0]]], "lines": ["ホムンクルス、"]}, {"box": [135, 1001, 174, 1125], "vertical": true, "font_size": 34, "lines_coords": [[[135.0, 1003.0], [169.0, 1001.0], [174.0, 1123.0], [140.0, 1125.0]]], "lines": ["終了です。"]}], "img_path": "182.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [791, 245, 809, 314], "vertical": true, "font_size": 18, "lines_coords": [[[791.0, 245.0], [809.0, 245.0], [809.0, 314.0], [791.0, 314.0]]], "lines": ["！．．．．．"]}, {"box": [223, 55, 312, 192], "vertical": true, "font_size": 19, "lines_coords": [[[292.0, 57.0], [310.0, 57.0], [312.0, 153.0], [295.0, 153.0]], [[268.0, 55.0], [289.0, 55.0], [290.0, 192.0], [269.0, 192.0]], [[244.0, 57.0], [262.0, 57.0], [263.0, 173.0], [246.0, 173.0]], [[223.0, 57.0], [240.0, 57.0], [240.0, 160.0], [223.0, 160.0]]], "lines": ["名越さんの", "見える幻覚には", "多少の興味は", "ありますが、"]}, {"box": [654, 466, 674, 569], "vertical": true, "font_size": 21, "lines_coords": [[[654.0, 466.0], [674.0, 466.0], [674.0, 569.0], [654.0, 569.0]]], "lines": ["さっきから、"]}, {"box": [474, 486, 564, 642], "vertical": true, "font_size": 21, "lines_coords": [[[544.0, 487.0], [564.0, 487.0], [564.0, 585.0], [544.0, 585.0]], [[518.0, 486.0], [538.0, 486.0], [541.0, 604.0], [521.0, 604.0]], [[494.0, 486.0], [518.0, 486.0], [518.0, 549.0], [494.0, 549.0]], [[474.0, 487.0], [494.0, 487.0], [494.0, 642.0], [474.0, 642.0]]], "lines": ["ズケズケと", "無責任なこと", "ばかり", "言いやがって．．．"]}, {"box": [132, 242, 222, 359], "vertical": true, "font_size": 19, "lines_coords": [[[202.0, 244.0], [222.0, 244.0], [222.0, 342.0], [202.0, 342.0]], [[173.0, 242.0], [197.0, 242.0], [200.0, 324.0], [175.0, 324.0]], [[153.0, 243.0], [174.0, 243.0], [174.0, 323.0], [153.0, 323.0]], [[132.0, 246.0], [148.0, 246.0], [148.0, 359.0], [132.0, 359.0]]], "lines": ["幻覚という", "テーマは", "もう少し", "後かなあ．．．"]}, {"box": [647, 721, 704, 898], "vertical": true, "font_size": 25, "lines_coords": [[[679.0, 721.0], [704.0, 721.0], [704.0, 858.0], [679.0, 858.0]], [[647.0, 725.0], [672.0, 725.0], [674.0, 896.0], [650.0, 896.0]]], "lines": ["じゃあオマエ", "一体何のために、"]}, {"box": [108, 725, 211, 922], "vertical": true, "font_size": 26, "lines_coords": [[[174.0, 725.0], [199.0, 725.0], [199.0, 911.0], [174.0, 911.0]], [[140.0, 725.0], [168.0, 725.0], [168.0, 922.0], [140.0, 922.0]], [[108.0, 727.0], [133.0, 727.0], [133.0, 912.0], [108.0, 912.0]]], "lines": ["こんな頭蓋骨に", "穴開けるような", "実験をしたっ？"]}], "img_path": "183.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [453, 38, 521, 164], "vertical": true, "font_size": 21, "lines_coords": [[[495.0, 38.0], [521.0, 38.0], [521.0, 103.0], [495.0, 103.0]], [[473.0, 38.0], [493.0, 38.0], [495.0, 138.0], [475.0, 138.0]], [[453.0, 41.0], [469.0, 41.0], [469.0, 160.0], [453.0, 160.0]]], "lines": ["だから", "言ったじゃ", "ないですかあ"]}, {"box": [450, 230, 497, 338], "vertical": true, "font_size": 22, "lines_coords": [[[468.0, 230.0], [497.0, 230.0], [497.0, 295.0], [468.0, 295.0]], [[451.0, 234.0], [467.0, 234.0], [467.0, 336.0], [451.0, 336.0]]], "lines": ["人間の", "研究ですよ。"]}, {"box": [276, 227, 347, 364], "vertical": true, "font_size": 22, "lines_coords": [[[326.0, 230.0], [347.0, 230.0], [347.0, 326.0], [326.0, 326.0]], [[301.0, 228.0], [322.0, 228.0], [323.0, 364.0], [302.0, 364.0]], [[276.0, 227.0], [301.0, 227.0], [301.0, 296.0], [276.0, 296.0]]], "lines": ["トレパンは", "その研究の一環", "ですよ。"]}, {"box": [349, 474, 461, 601], "vertical": true, "font_size": 37, "lines_coords": [[[420.0, 474.0], [461.0, 474.0], [461.0, 544.0], [420.0, 544.0]], [[387.0, 476.0], [420.0, 476.0], [420.0, 601.0], [387.0, 601.0]], [[349.0, 475.0], [385.0, 475.0], [385.0, 543.0], [349.0, 543.0]]], "lines": ["なぜ", "俺を選ん", "だ？"]}, {"box": [568, 1137, 595, 1198], "vertical": true, "font_size": 27, "lines_coords": [[[568.0, 1137.0], [595.0, 1137.0], [595.0, 1198.0], [568.0, 1198.0]]], "lines": ["イボ．．．"]}, {"box": [147, 976, 192, 1128], "vertical": true, "font_size": 20, "lines_coords": [[[171.0, 976.0], [190.0, 976.0], [190.0, 1128.0], [171.0, 1128.0]], [[147.0, 977.0], [167.0, 977.0], [167.0, 1100.0], [147.0, 1100.0]]], "lines": ["それも言ったじゃ", "ないですかあ。"]}], "img_path": "184.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [706, 135, 779, 256], "vertical": true, "font_size": 21, "lines_coords": [[[757.0, 137.0], [779.0, 137.0], [779.0, 216.0], [757.0, 216.0]], [[731.0, 