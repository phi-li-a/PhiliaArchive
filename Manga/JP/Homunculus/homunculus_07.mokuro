], [145.0, 636.0], [147.0, 693.0], [117.0, 694.0]]], "lines": ["なんでも", "ない。"]}, {"box": [398, 989, 427, 1086], "vertical": true, "font_size": 29, "lines_coords": [[[398.0, 989.0], [427.0, 989.0], [427.0, 1086.0], [398.0, 1086.0]]], "lines": ["行こう。"]}], "img_path": "221.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [57, 577, 438, 621], "vertical": false, "font_size": 44, "lines_coords": [[[57.0, 577.0], [438.0, 577.0], [438.0, 621.0], [57.0, 621.0]]], "lines": ["「ホムンクルス］第７集＞完"]}, {"box": [49, 1078, 629, 1151], "vertical": false, "font_size": 17, "lines_coords": [[[59.0, 1084.0], [624.0, 1076.0], [624.0, 1095.0], [59.0, 1103.0]], [[59.0, 1100.0], [598.0, 1094.0], [598.0, 1114.0], [59.0, 1119.0]], [[58.0, 1118.0], [593.0, 1111.0], [593.0, 1130.0], [58.0, 1137.0]], [[59.0, 1132.0], [461.0, 1131.0], [461.0, 1151.0], [59.0, 1152.0]]], "lines": ["●作品中の「トレバネーションヨン・は極めて危険な行為です。絶対に真似をしないでください。", "●Ｆａｃｅｒの作品はフィクションです。は俺のいた深まりや実在する人物・団体１，０００年１１月です。知人に興味をしない。事件等とは一切関係ありません。このｎｉｎｔｏｎｔｅｒの", "アニソ「中国は多い週刊ビッグコミックスピーナー、セルファム」そう。美生さんが私はリッツ！２００５年４１号一作号、２０１６年３０月１３日の２００５年３３０号ー３４号掲載作品。", "●５週刊ビッグコミッスビットの動画ハホムンクルス［公式ホームペ２０１５年１１月３０日ジャージーから「お友人！！Ｗｉｋｉｏｎｄｏｒｄの"]}], "img_path": "222.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [66, 73, 330, 972], "vertical": true, "font_size": 145, "lines_coords": [[[194.0, 92.0], [330.0, 92.0], [330.0, 948.0], [194.0, 948.0]], [[66.0, 75.0], [220.0, 73.0], [228.0, 971.0], [74.0, 972.0]]], "lines": ["どこまでも凝視すると", "決めた名越が．．．．．．、"]}, {"box": [7, 1041, 841, 1188], "vertical": false, "font_size": 80.0, "lines_coords": [[[85.0, 1041.0], [824.0, 1041.0], [824.0, 1089.0], [85.0, 1089.0]], [[7.0, 1075.0], [841.0, 1072.0], [841.0, 1184.0], [7.0, 1188.0]]], "lines": ["週刊ビッグストリスピリックに作業連載がありますので、", "２００７年２月末日発売予定！！"]}], "img_path": "223.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [681, 108, 721, 373], "vertical": true, "font_size": 36, "lines_coords": [[[685.0, 108.0], [721.0, 108.0], [718.0, 373.0], [681.0, 373.0]]], "lines": ["．．．．．．．"]}, {"box": [516, 87, 780, 988], "vertical": true, "font_size": 136, "lines_coords": [[[627.0, 346.0], [780.0, 351.0], [761.0, 958.0], [609.0, 953.0]], [[516.0, 90.0], [636.0, 87.0], [652.0, 980.0], [533.0, 983.0]]], "lines": ["伊藤の中に見た", "自分自身の姿は．．．"]}, {"box": [21, 1076, 817, 1180], "vertical": false, "font_size": 104, "lines_coords": [[[21.0, 1076.0], [817.0, 1076.0], [817.0, 1180.0], [21.0, 1180.0]]], "lines": ["次巻はムンクルス第８集は、"]}], "img_path": "224.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [114, 108, 391, 152], "vertical": false, "font_size": 40, "lines_coords": [[[114.0, 112.0], [391.0, 108.0], [391.0, 148.0], [114.0, 152.0]]], "lines": ["ホムンクルスＺ"]}, {"box": [168, 171, 332, 195], "vertical": false, "font_size": 24, "lines_coords": [[[168.0, 171.0], [332.0, 171.0], [332.0, 195.0], [168.0, 195.0]]], "lines": ["ビッグコミックス"]}, {"box": [167, 560, 236, 589], "vertical": false, "font_size": 29, "lines_coords": [[[167.0, 560.0], [194.0, 560.0], [194.0, 588.0], [167.0, 588.0]], [[208.0, 561.0], [236.0, 561.0], [236.0, 589.0], [208.0, 589.0]]], "lines": ["著", "者"]}, {"box": [172, 450, 474, 473], "vertical": false, "font_size": 23, "lines_coords": [[[172.0, 450.0], [474.0, 450.0], [474.0, 473.0], [172.0, 473.0]]], "lines": ["２００７年１月１日初版第１刷発行"]}, {"box": [574, 416, 760, 439], "vertical": false, "font_size": 23, "lines_coords": [[[574.0, 416.0], [760.0, 416.0], [760.0, 439.0], [574.0, 439.0]]], "lines": ["－－０９－１８０７７２－０"]}, {"box": [678, 450, 761, 469], "vertical": false, "font_size": 19, "lines_coords": [[[678.0, 450.0], [761.0, 450.0], [761.0, 469.0], [678.0, 469.0]]], "lines": ["〈検印廃止〉"]}, {"box": [166, 624, 238, 697], "vertical": false, "font_size": 29, "lines_coords": [[[166.0, 624.0], [238.0, 624.0], [238.0, 658.0], [166.0, 658.0]], [[169.0, 672.0], [236.0, 672.0], [236.0, 697.0], [169.0, 697.0]]], "lines": ["発行者", "印刷所"]}, {"box": [114, 740, 324, 785], "vertical": false, "font_size": 22, "lines_coords": [[[115.0, 742.0], [318.0, 742.0], [318.0, 762.0], [115.0, 762.0]], [[114.0, 761.0], [270.0, 761.0], [270.0, 785.0], [114.0, 785.0]]], "lines": ["単行本編集責任（赤名英之", "単行本編集ノ銀杏社"]}, {"box": [365, 556, 645, 697], "vertical": false, "font_size": 25, "lines_coords": [[[365.0, 558.0], [544.0, 554.0], [544.0, 586.0], [365.0, 590.0]], [[367.0, 590.0], [643.0, 590.0], [643.0, 623.0], [367.0, 623.0]], [[366.0, 627.0], [439.0, 623.0], [440.0, 652.0], [367.0, 655.0]], [[510.0, 629.0], [541.0, 629.0], [541.0, 652.0], [510.0, 652.0]], [[374.0, 674.0], [538.0, 674.0], [538.0, 694.0], [374.0, 694.0]]], "lines": ["山本英英", "○Ｈｉｔｅｏｙａｍａｍｏｔｏｒ．２００７", "原笹", "博", "出版印刷株式会社"]}, {"box": [120, 829, 593, 863], "vertical": false, "font_size": 22.5, "lines_coords": [[[219.0, 832.0], [593.0, 829.0], [593.0, 846.0], [219.0, 848.0]], [[120.0, 834.0], [220.0, 834.0], [220.0, 863.0], [120.0, 863.0]]], "lines": ["で、（〒１０１－８０１）東京都千代田区一ツ橋二の三の一", "発行所"]}, {"box": [395, 849, 571, 885], "vertical": false, "font_size": 17.666666666666668, "lines_coords": [[[436.0, 850.0], [570.0, 850.0], [570.0, 866.0], [436.0, 866.0]], [[438.0, 870.0], [571.0, 870.0], [571.0, 885.0], [438.0, 885.0]], [[395.0, 858.0], [438.0, 849.0], [442.0, 870.0], [400.0, 880.0]]], "lines": ["編集０３（３２３０）５５０５", "販売０３（５２８）！３５６", "ＴＥＬ"]}, {"box": [640, 836, 772, 896], "vertical": false, "font_size": 60, "lines_coords": [[[640.0, 836.0], [772.0, 836.0], [772.0, 896.0], [640.0, 896.0]]], "lines": ["株式小学館"]}, {"box": [140, 1042, 261, 1058], "vertical": false, "font_size": 16, "lines_coords": [[[140.0, 1042.0], [261.0, 1042.0], [261.0, 1058.0], [140.0, 1058.0]]], "lines": ["アンケートのお願い"]}, {"box": [120, 909, 706, 1028], "vertical": false, "font_size": 12.875, "lines_coords": [[[121.0, 909.0], [706.0, 909.0], [706.0, 924.0], [121.0, 924.0]], [[120.0, 925.0], [622.0, 924.0], [622.0, 937.0], [120.0, 938.0]], [[121.0, 939.0], [278.0, 942.0], [278.0, 953.0], [121.0, 951.0]], [[120.0, 955.0], [625.0, 953.0], [625.0, 969.0], [120.0, 970.0]], [[123.0, 971.0], [556.0, 971.0], [556.0, 983.0], [123.0, 983.0]], [[123.0, 986.0], [336.0, 986.0], [336.0, 998.0], [123.0, 998.0]], [[123.0, 1001.0], [620.0, 1001.0], [620.0, 1013.0], [123.0, 1013.0]], [[123.0, 1017.0], [567.0, 1017.0], [567.0, 1028.0], [123.0, 1028.0]]], "lines": ["●並木には十分注意しておりますが、落丁。乱丁（本のページャー・ジの抜け落ちや恥ずの間違いやっぱり、＞＞の場合はお取り替えいたします。おいしさん", "購入された書店名を明記して「明作同士あてにお送りください。送料か社員相にてお取り替えいたします。", "制作局（ＴＥＬ０１２０－３３６－１８２", "●本書の一部あるいは全体的に「諦める」は全部を無断しています。で複製素素・上演・放送等をすることもとは、法律で認められた場合を除き、", "著作者および出版者の権利の保護となります。あらかじめられたあで許諾をお求めください。", "国（日本複写権センタ一委託出版物", "本書の一部または全部を無断で複写（コピーすることは、著作権法上での例外を除き禁じられています。", "複写を希望される場合は、日本教写権センター（ＴＥＬＪＯＳ－３４）と１２８８２）にご連絡ください。"]}, {"box": [319, 1044, 414, 1055], "vertical": false, "font_size": 11, "lines_coords": [[[319.0, 1044.0], [414.0, 1044.0], [414.0, 1055.0], [319.0, 1055.0]]], "lines": ["小学館アンケート係"]}, {"box": [135, 1064, 626, 1152], "vertical": false, "font_size": 14, "lines_coords": [[[142.0, 1071.0], [582.0, 1071.0], [582.0, 1087.0], [142.0, 1087.0]], [[141.0, 1087.0], [458.0, 1087.0], [458.0, 1103.0], [141.0, 1103.0]], [[144.0, 1103.0], [438.0, 1103.0], [438.0, 1118.0], [144.0, 1118.0]], [[144.0, 1118.0], [622.0, 1118.0], [622.0, 1134.0], [144.0, 1134.0]], [[141.0, 1132.0], [572.0, 1132.0], [572.0, 1151.0], [141.0, 1151.0]]], "lines": ["●小学館のコミックス、書籍についていてのアンケートをインターネットで受け付けています。", "ｈｔｔｐ／／ｗｗｗｉｋｉｎｆｉｏｓｈｏｇｌｅおはようございます。２０１６年１０月のカードアクセスしていただきましょう。", "このコミックスのキーコーＭＳＢの２は入力してください。", "●全ご回答者の中から、何年だったので、「５００万円の方にお勧めです。お前達で、小学校時代時間帯からＦｒｕａｄＰＤをさしあげます。", "●ここで自分のイベントなどのように、事務所によりもありますので、事業者に対していますが、・クラウドの名前！！いいの！？何故をもってかえさせていただきます。"]}], "img_path": "225.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [], "img_path": "226.png"}, {"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [], "img_path": "227.png"}]}