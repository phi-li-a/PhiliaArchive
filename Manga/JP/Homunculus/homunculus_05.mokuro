75.0], [867.0, 1175.0]]], "lines": ["５．山本英夫は"]}], "img_path": "001.png"}, {"version": "0.1.7", "img_width": 1536, "img_height": 1200, "blocks": [{"box": [92, 141, 444, 210], "vertical": false, "font_size": 52, "lines_coords": [[[93.0, 147.0], [435.0, 145.0], [435.0, 198.0], [93.0, 199.0]]], "lines": ["ホムンクルス"]}, {"box": [204, 345, 331, 376], "vertical": false, "font_size": 31, "lines_coords": [[[204.0, 345.0], [331.0, 345.0], [331.0, 376.0], [204.0, 376.0]]], "lines": ["山本英夫"]}, {"box": [0, 292, 610, 1110], "vertical": false, "font_size": 58, "lines_coords": [[[88.0, 419.0], [432.0, 419.0], [432.0, 449.0], [88.0, 449.0]], [[87.0, 466.0], [439.0, 466.0], [439.0, 495.0], [87.0, 495.0]], [[88.0, 487.0], [438.0, 487.0], [438.0, 516.0], [88.0, 516.0]], [[87.0, 511.0], [301.0, 511.0], [301.0, 536.0], [87.0, 536.0]], [[321.0, 511.0], [433.0, 511.0], [433.0, 536.0], [321.0, 536.0]], [[84.0, 527.0], [424.0, 526.0], [424.0, 561.0], [84.0, 563.0]], [[82.0, 551.0], [417.0, 553.0], [417.0, 584.0], [82.0, 582.0]], [[67.0, 553.0], [438.0, 553.0], [438.0, 653.0], [67.0, 653.0]], [[87.0, 620.0], [280.0, 620.0], [280.0, 650.0], [87.0, 650.0]], [[84.0, 640.0], [418.0, 637.0], [418.0, 668.0], [84.0, 671.0]], [[87.0, 665.0], [396.0, 664.0], [396.0, 690.0], [87.0, 692.0]], [[85.0, 688.0], [352.0, 683.0], [352.0, 713.0], [85.0, 717.0]], [[0.0, 295.0], [601.0, 287.0], [610.0, 1107.0], [0.0, 1115.0]], [[88.0, 707.0], [421.0, 707.0], [421.0, 737.0], [88.0, 737.0]], [[87.0, 730.0], [420.0, 730.0], [420.0, 759.0], [87.0, 759.0]], [[88.0, 754.0], [418.0, 752.0], [418.0, 779.0], [88.0, 780.0]], [[88.0, 773.0], [421.0, 772.0], [421.0, 803.0], [88.0, 804.0]], [[90.0, 796.0], [423.0, 794.0], [423.0, 824.0], [90.0, 825.0]], [[90.0, 821.0], [337.0, 821.0], [337.0, 846.0], [90.0, 846.0]], [[87.0, 841.0], [363.0, 839.0], [363.0, 869.0], [87.0, 870.0]], [[85.0, 863.0], [438.0, 860.0], [438.0, 890.0], [85.0, 893.0]], [[88.0, 886.0], [439.0, 883.0], [439.0, 912.0], [88.0, 915.0]], [[85.0, 907.0], [444.0, 905.0], [444.0, 936.0], [85.0, 938.0]], [[85.0, 950.0], [456.0, 949.0], [456.0, 980.0], [85.0, 981.0]], [[85.0, 973.0], [456.0, 970.0], [456.0, 1001.0], [85.0, 1004.0]], [[85.0, 997.0], [456.0, 991.0], [456.0, 1022.0], [85.0, 1028.0]]], "lines": ["●スピリッツコミックス約解発時の美味しんぼ「無理哲」が改めてキラット。より", "美味しんぼ〈無理者〉《アキラハト》。ギャラリーフェイクは細部で不二あり．．．しょうが、日副戦争物語に山山達也．．．", "ギャラリーフェイク側の不二参ハート・ご興味ありがとうございます。２０１８年６月１１日の午前７時間", "日露戦争物語（江川達也！！２０世紀少年（浦沢直樹）．．．オメガトライブ（玉井雪雄）．", "．．．．．．．．", "２０世紀少年（浦沢遣樹）．．．", "オンガトライブ（玉井無猫）．．．！！中越アフロ田中へのリつけ雅島）．．．つゆダク（明るキャラ）", "オンガトライブには、家族としては、中国のフィーローのつまり相続につながら、つゆりの時間によってこんな時間を過ごしているのですが、でしょうかと思います。です。", "てんねん（吉田）．．．．．．アパイ（古屋兎丸）．．！！東京エイティーズ（笑童夕馬大", "死んでいた言葉を丸い．．．", "東京エイティーズ（役職多事は大阪府西）・東虫（株木ハルコリー．．．", "鬼虫（柏木ハルコ）．．．．．．．．団地ともおいの田扉）．", "そういうことですか", "日地ともお（１０月）日曜／．．．．．．！！．．このセブラーマン（宮崎寺）松山田町の極道一番都三上龍剣．．", "セブラーマン（営業者）はいい日常同じような極道一番線（三上補裁）．．．", "極道一直線（三上浦税）．．．！！このホムンクルス（山本来夫）・", "ホムンクルス（山本美夫）．．．．．．まったラストイニング（中原裕神尾園）．．ＣＢ郡「ＲＥＢＯＲＡＮＡは東米黒田！！！", "ラストイニング（日時給１神時間）．．．１－４８歳の和田２０１０年１０月１０日（火）．．．ルナンチマン（花沢渡吾）！！", "ＣＢ版．ＲＥＧＯＲＡ（東本昌平）．．．ルナンチマン（花沢健吾）．", "ルサンチマン（花沢雄吾）．．．！！開金ワシジマくん（債務局平）．．．出る「コ出ましょ」「稲井俳二）！！", "開血ウンジマイム（真織県平岡）！！！あ、出るトコはましょー（福井俳二）．．．！！ここで楽しいモキュー（村上かつら）！", "出るトコはましょー（偶者併二）．．．！この人でしょうか。わざわざー．．．", "ＣＵＥキュー付上かつらｉ－ｍｉｎ．．．！！！この村上がつらの記録（付上）つら）．．．全て巻、男が名は解析の実際に「武器かっ！！", "我が名は親子の親戚一頭がおかしいような日曜日に一つ食料通うカタニローと２集１０００円（法久保備子）．．．", "ＤＡＮＡに一人権利息子カタミレッションと集中については、Ｈａｃｅｎｄｏｏｎ（色々な倫子．．．", "Ｈａｃｅｍは住々木権子．．．！！．．"]}, {"box": [141, 1112, 402, 1135], "vertical": false, "font_size": 17, "lines_coords": [[[144.0, 1114.0], [399.0, 1114.0], [399.0, 1133.0], [144.0, 1133.0]]], "lines": ["ＲＯＯＫＤＥＳＩＣＮ：ＴＡＫＡＨＡＳＨＬＪＵＮＺＩ"]}, {"box": [1413, 154, 1538, 865], "vertical": true, "font_size": 125, "lines_coords": [[[1413.0, 154.0], [1538.0, 154.0], [1538.0, 865.0], [1413.0, 865.0]]], "lines": ["ホムングルス５"]}, {"box": [1435, 751, 1512, 1143], "vertical": true, "font_size": 72, "lines_coords": [[[1440.0, 751.0], [1512.0, 751.0], [1507.0, 1143.0], [1435.0, 1143.0]]], "lines": ["つー山本英夫・"]}, {"box": [1440, 1111, 1512, 1191], "vertical"