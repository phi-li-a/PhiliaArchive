3.0], [532.0, 683.0], [532.0, 699.0], [366.0, 699.0]]], "lines": ["原産", "．．．ははは株式会社"]}, {"box": [367, 562, 624, 700], "vertical": false, "font_size": 22, "lines_coords": [[[367.0, 599.0], [624.0, 599.0], [624.0, 626.0], [367.0, 626.0]], [[511.0, 640.0], [535.0, 640.0], [535.0, 662.0], [511.0, 662.0]]], "lines": ["○Ｈｉｔｅｏ．ｙａｍａｎｏｔｏ：２０１５", "博"]}, {"box": [247, 833, 593, 868], "vertical": false, "font_size": 15.0, "lines_coords": [[[461.0, 833.0], [591.0, 833.0], [591.0, 848.0], [461.0, 848.0]], [[247.0, 842.0], [462.0, 842.0], [462.0, 857.0], [247.0, 857.0]], [[461.0, 853.0], [593.0, 853.0], [593.0, 868.0], [461.0, 868.0]]], "lines": ["編集０３（３２３０）５５０５", "振替（００１８０－・１－２００）ＴＥＬＬ", "収売０３（５２８１，３５６"]}, {"box": [464, 801, 545, 813], "vertical": false, "font_size": 12, "lines_coords": [[[464.0, 801.0], [545.0, 801.0], [545.0, 813.0], [464.0, 813.0]]], "lines": ["ビーツ橋二の"]}, {"box": [637, 705, 745, 717], "vertical": false, "font_size": 12, "lines_coords": [[[637.0, 705.0], [745.0, 705.0], [745.0, 717.0], [637.0, 717.0]]], "lines": ["Ｐｒｉｎｔｅｄｉｎｊａｐａｎ"]}, {"box": [640, 848, 744, 882], "vertical": false, "font_size": 17.333333333333332, "lines_coords": [[[681.0, 854.0], [744.0, 856.0], [744.0, 874.0], [681.0, 871.0]], [[640.0, 848.0], [681.0, 848.0], [681.0, 864.0], [640.0, 864.0]], [[641.0, 864.0], [685.0, 864.0], [685.0, 882.0], [641.0, 882.0]]], "lines": ["小学館", "株式", "会社"]}, {"box": [141, 1034, 258, 1048], "vertical": false, "font_size": 13, "lines_coords": [[[141.0, 1035.0], [258.0, 1034.0], [258.0, 1047.0], [141.0, 1048.0]]], "lines": ["アンケートのお願い"]}, {"box": [120, 903, 705, 1023], "vertical": false, "font_size": 14, "lines_coords": [[[122.0, 901.0], [705.0, 901.0], [705.0, 917.0], [122.0, 917.0]], [[120.0, 915.0], [623.0, 914.0], [623.0, 931.0], [120.0, 932.0]], [[122.0, 930.0], [278.0, 930.0], [278.0, 946.0], [122.0, 946.0]], [[122.0, 946.0], [626.0, 946.0], [626.0, 961.0], [122.0, 961.0]], [[121.0, 961.0], [556.0, 961.0], [556.0, 977.0], [121.0, 977.0]], [[122.0, 977.0], [331.0, 977.0], [331.0, 989.0], [122.0, 989.0]], [[122.0, 991.0], [621.0, 991.0], [621.0, 1007.0], [122.0, 1007.0]], [[121.0, 1005.0], [563.0, 1004.0], [563.0, 1021.0], [121.0, 1022.0]]], "lines": ["●従来には十分に感じておりますが、「私「子供のページの投げ落ちされる間違い間違えない」というかもしれませんが、いつの場合はお取り替えいたします。", "現在やには、人生話して購入された書店名を明記しておりました。まったく、体・血・中高性用品・あてにお送りください。法律がありがとう間違いがありませんが、小社食用にてお取り替えいたします。", "購入された商品をご利用いただきますので、お客様のご相談くだ", "ＷｉｎｄｏｒｄＬｉｄｅｄｏｗｓの個本書の一部あるいは全部を無視させています。で複製作戦と消されるとは、法律で認められた場合を除き、", "著作者および出版者の投稿者の権利の投票アローチャンセルしてとなります。あらかじめ小社あで音話をお求めください。", "Ｒ（日本複写権セシター委託出版物", "本書の一部または全部を無視で殺す。２０１７年コピーリすることは、著作権法としてでの例外を除き禁じられています。", "本音シールよには上部と複写を希望される場合は、高齢に基づくことが多く、日本模写権センター（ＴＥＬ）では、名古屋は．．．それを考えました。３０日目「２８８２」にご連絡ください。"]}, {"box": [317, 1033, 415, 1048], "vertical": false, "font_size": 14, "lines_coords": [[[317.0, 1032.0], [413.0, 1031.0], [413.0, 1047.0], [317.0, 1048.0]]], "lines": ["小学館アンケート係"]}, {"box": [134, 1062, 627, 1141], "vertical": false, "font_size": 15, "lines_coords": [[[141.0, 1063.0], [578.0, 1060.0], [578.0, 1076.0], [141.0, 1078.0]], [[140.0, 1079.0], [457.0, 1077.0], [457.0, 1093.0], [140.0, 1095.0]], [[142.0, 1093.0], [433.0, 1091.0], [433.0, 1107.0], [142.0, 1109.0]], [[140.0, 1107.0], [624.0, 1103.0], [624.0, 1122.0], [140.0, 1127.0]], [[141.0, 1123.0], [559.0, 1120.0], [559.0, 1137.0], [141.0, 1139.0]]], "lines": ["●小学館のコミックス、書籍についてのアンケートをインターニネットで受け付けています。", "おはようございませんが、「おやすい」と思っておりました。１０００円にアクセスしていただき、", "このコミックススクールのこのフラッグスのキーコープＷｉｎｄｏｗｓ．ＦｉｌｅＷｅｒｄＰａｙＲｏｇｌｅスカしてください。", "●主ご回答者の中から、毎月５００名のここを入力してください。力に抽選で、小学校特徴収書カードの中のスタッフを（１１０００円）をさしあげます。アメリカ", "ここに出会わらずなっ、なんか一緒行日より３年間有効です。Ａｐｐｒｙクラー何処、いつもの事発表は貴品の発送をもっ何者は言ってもいいのですかえさせていただきます。"]}], "img_path": "233.png"}, {"version": "0.1.7", "img_width": 1536, "img_height": 1200, "blocks": [{"box": [54, 34, 117, 57], "vertical": false, "font_size": 23, "lines_coords": [[[54.0, 34.0], [112.0, 34.0], [112.0, 59.0], [54.0, 59.0]]], "lines": ["ｃｏＭｉｃｓ"]}, {"box": [195, 71, 420, 159], "vertical": false, "font_size": 24, "lines_coords": [[[220.0, 130.0],