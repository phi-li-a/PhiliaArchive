.7", "img_width": 835, "img_height": 1200, "blocks": [{"box": [197, 0, 248, 111], "vertical": true, "font_size": 51, "lines_coords": [[[197.0, 0.0], [248.0, 0.0], [248.0, 111.0], [197.0, 111.0]]], "lines": ["．．．"]}, {"box": [705, 511, 804, 662], "vertical": true, "font_size": 99, "lines_coords": [[[705.0, 511.0], [804.0, 511.0], [804.0, 662.0], [705.0, 662.0]]], "lines": ["♪月月♪Ｊ３"]}], "img_path": "063.png"}, {"version": "0.1.7", "img_width": 835, "img_height": 1200, "blocks": [{"box": [100, 137, 114, 194], "vertical": true, "font_size": 14, "lines_coords": [[[100.0, 137.0], [114.0, 137.0], [114.0, 194.0], [100.0, 194.0]]], "lines": ["．．．"]}, {"box": [455, 50, 519, 105], "vertical": false, "font_size": 27.0, "lines_coords": [[[455.0, 50.0], [519.0, 50.0], [519.0, 76.0], [455.0, 76.0]], [[466.0, 84.0], [489.0, 62.0], [508.0, 83.0], [484.0, 105.0]]], "lines": ["っぱり、", "お。"]}, {"box": [408, 36, 483, 372], "vertical": true, "font_size": 32.5, "lines_coords": [[[448.0, 62.0], [483.0, 64.0], [463.0, 372.0], [428.0, 370.0]], [[430.0, 36.0], [460.0, 38.0], [437.0, 348.0], [408.0, 345.0]]], "lines": ["すっっ帯のうずもるでか達い", "それでいま携も知とてい来す友だ"]}, {"box": [504, 178, 541, 261], "vertical": true, "font_size": 31, "lines_coords": [[[510.0, 178.0], [541.0, 180.0], [535.0, 261.0], [504.0, 258.0]]], "lines": ["人不私"]}, {"box": [445, 51, 765, 338], "vertical": false, "font_size": 64.83333333333333, "lines_coords": [[[537.0, 51.0], [758.0, 62.0], [757.0, 86.0], [536.0, 76.0]], [[534.0, 91.0], [765.0, 107.0], [763.0, 139.0], [531.0, 123.0]], [[491.0, 114.0], [678.0, 123.0], [676.0, 151.0], [490.0, 142.0]], [[475.0, 93.0], [517.0, 93.0], [517.0, 117.0], [475.0, 117.0]], [[452.0, 101.0], [637.0, 107.0], [630.0, 338.0], [445.0, 332.0]], [[504.0, 145.0], [534.0, 138.0], [545.0, 186.0], [516.0, 193.0]]], "lines": ["あなたが持っていたん", "すぐ返してほしいに決しないですか。", "ってすぐ返してほしいでるじゃないですかって個人情報が全て入っ", "すね。って、ってる", "それはそんなことはありません。その時はオレの朝ごとになってるけど．．．ありがとうございましょうかないと思っているのだろうかもしれない。", "や情すのじ人でくる個ん"]}, {"box": [553, 140, 761, 194], "vertical": false, "font_size": 27.0, "lines_coords": [[[555.0, 140.0], [761.0, 147.0], [760.0, 179.0], [553.0, 172.0]], [[570.0, 162.0], [586.0, 179.0], [571.0, 194.0], [555.0, 178.0]]], "lines": ["やはいですか。情報が全て入っている", "よ"]}, {"box": [356, 16, 858, 481], "vertical": false, "font_size": 161.33333333333334, "lines_coords": [[[675.0, 22.0], [758.0, 26.0], [757.0, 51.0], [674.0, 46.0]], [[388.0, 16.0], [858.0, 51.0], [825.0, 481.0], [356.0, 446.0]], [[528.0, 253.0], [754.0, 261.0], [753.0, 289.0], [526.0, 281.0]]], "lines": ["「２０１８時間が持っていたん", "それは．．．", "こんなの手元にあるかと思って、そもそも私の技術だってわかっておら、なんですぐ家に届けてくれないのですが、"]}, {"box": [502, 142, 774, 316], "vertical": false, "font_size": 47.25, "lines_coords": [[[518.0, 180.0], [774.0, 228.0], [757.0, 316.0], [502.0, 268.0]], [[530.0, 142.0], [563.0, 142.0], [563.0, 191.0], [530.0, 191.0]], [[525.0, 183.0], [755.0, 188.0], [755.0, 221.0], [525.0, 216.0]], [[552.0, 213.0], [600.0, 215.0], [599.0, 232.0], [551.0, 229.0]]], "lines": ["いやすよ手にあるかと思う人の手元にあって不安です。それの携帯だってわかってもらえなんですぐ家に届けになっていいので", "な報よ手や情すのし人で", "ですよ。人の手元にあるかと思う不安です。", "元す。子で僕の女"]}, {"box": [0, 137, 399, 508], "vertical": false, "font_size": 103, "lines_coords": [[[0.0, 258.0], [206.0, 137.0], [336.0, 386.0], [101.0, 508.0]], [[78.0, 336.0], [112.0, 337.0], [110.0, 430.0], [76.0, 428.0]], [[115.0, 304.0], [154.0, 300.0], [165.0, 379.0], [126.0, 384.0]], [[159.0, 300.0], [378.0, 248.0], [387.0, 288.0], [168.0, 339.0]], [[163.0, 332.0], [380.0, 285.0], [387.0, 318.0], [170.0, 365.0]]], "lines": ["そんなことはないのですが．．．そういうわけじゃないですか", "もるでも", "もら", "私の携帯だってわか", "なんですぐ家に届"]}, {"box": [424, 410, 468, 435], "vertical": false, "font_size": 25, "lines_coords": [[[424.0, 410.0], [468.0, 410.0], [468.0, 435.0], [424.0, 435.0]]], "lines": ["機能"]}, {"box": [413, 360, 580, 393], "vertical": false, "font_size": 29, "lines_coords": [[[414.0, 360.0], [580.0, 365.0], [579.0, 393.0], [413.0, 389.0]]], "lines": ["くいるので今日に来てください。"]}, {"box": [476, 318, 743, 355], "vertical": false, "font_size"