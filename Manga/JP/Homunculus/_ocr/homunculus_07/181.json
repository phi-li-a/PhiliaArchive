{"version": "0.1.7", "img_width": 840, "img_height": 1200, "blocks": [{"box": [342, 130, 389, 284], "vertical": true, "font_size": 22, "lines_coords": [[[366.0, 131.0], [387.0, 131.0], [388.0, 284.0], [367.0, 284.0]], [[342.0, 130.0], [366.0, 130.0], [366.0, 201.0], [342.0, 201.0]]], "lines": ["そのモンブランの", "ように、"]}, {"box": [86, 131, 179, 249], "vertical": true, "font_size": 21, "lines_coords": [[[155.0, 131.0], [179.0, 131.0], [179.0, 249.0], [155.0, 249.0]], [[133.0, 131.0], [153.0, 131.0], [153.0, 212.0], [133.0, 212.0]], [[107.0, 131.0], [127.0, 131.0], [130.0, 247.0], [110.0, 247.0]], [[86.0, 131.0], [106.0, 131.0], [106.0, 199.0], [86.0, 199.0]]], "lines": ["最後の一口の", "ところで", "飽きてしまい", "ました。"]}, {"box": [698, 333, 814, 480], "vertical": true, "font_size": 20, "lines_coords": [[[795.0, 335.0], [811.0, 335.0], [811.0, 450.0], [795.0, 450.0]], [[772.0, 333.0], [791.0, 333.0], [788.0, 480.0], [768.0, 480.0]], [[747.0, 335.0], [767.0, 335.0], [765.0, 424.0], [745.0, 424.0]], [[724.0, 337.0], [743.0, 337.0], [743.0, 471.0], [724.0, 471.0]], [[698.0, 336.0], [722.0, 336.0], [722.0, 406.0], [698.0, 406.0]]], "lines": ["僕はなんでも", "「信じることから", "始める」を", "モットウとして", "います。"]}, {"box": [477, 377, 556, 502], "vertical": true, "font_size": 25, "lines_coords": [[[527.0, 377.0], [556.0, 378.0], [554.0, 424.0], [524.0, 423.0]], [[506.0, 380.0], [527.0, 380.0], [527.0, 478.0], [506.0, 478.0]], [[477.0, 379.0], [501.0, 379.0], [501.0, 502.0], [477.0, 502.0]]], "lines": ["ただ", "飽きるのも", "早い性質で．．．"]}, {"box": [363, 441, 380, 504], "vertical": true, "font_size": 17, "lines_coords": [[[363.0, 441.0], [380.0, 441.0], [380.0, 504.0], [363.0, 504.0]]], "lines": ["．．．．．．？"]}, {"box": [691, 631, 793, 765], "vertical": true, "font_size": 24, "lines_coords": [[[773.0, 635.0], [793.0, 635.0], [793.0, 727.0], [773.0, 727.0]], [[746.0, 631.0], [770.0, 631.0], [768.0, 765.0], [743.0, 765.0]], [[718.0, 632.0], [741.0, 632.0], [741.0, 764.0], [718.0, 764.0]], [[691.0, 631.0], [718.0, 631.0], [718.0, 690.0], [691.0, 690.0]]], "lines": ["名越さん、", "僕は「人間」を", "研究したいん", "です。"]}, {"box": [179, 609, 261, 744], "vertical": true, "font_size": 24, "lines_coords": [[[240.0, 616.0], [260.0, 616.0], [260.0, 744.0], [240.0, 744.0]], [[213.0, 615.0], [234.0, 615.0], [234.0, 723.0], [213.0, 723.0]], [[179.0, 610.0], [210.0, 609.0], [213.0, 672.0], [181.0, 673.0]]], "lines": ["無駄な時間は", "過ごしたく", "ない。"]}, {"box": [134, 834, 255, 987], "vertical": true, "font_size": 20, "lines_coords": [[[231.0, 834.0], [255.0, 834.0], [255.0, 955.0], [231.0, 955.0]], [[208.0, 836.0], [228.0, 836.0], [228.0, 976.0], [208.0, 976.0]], [[186.0, 837.0], [202.0, 837.0], [202.0, 987.0], [186.0, 987.0]], [[160.0, 836.0], [180.0, 836.0], [180.0, 914.0], [160.0, 914.0]], [[134.0, 835.0], [155.0, 835.0], [158.0, 941.0], [137.0, 941.0]]], "lines": ["「人間」を研究", "するに当たって、", "他にもやることが", "たくさん", "あるんです。"]}]}