0, 859.0], [2832.0, 896.0], [2832.0, 1080.0], [602.0, 1043.0]], [[1034.0, 551.0], [2050.0, 547.0], [2050.0, 639.0], [1034.0, 643.0]], [[1384.0, 381.0], [1402.0, 381.0], [1402.0, 404.0], [1384.0, 404.0]]], "lines": ["これまでのシステムでは、", "載せ行揚さの", "戦っていることは、戦時にはせていただいた「ＳＥページです。行く末を、出行本で", "．．", "っくり読んでほしいためです", "名越の視線たものは", "有地のみんな、『天国』か『地獄』か．．．。小本英夫", "行く末を、単行本で", "それでも、"]}, {"box": [78, 1342, 312, 1544], "vertical": false, "font_size": 181, "lines_coords": [[[78.0, 1363.0], [312.0, 1363.0], [312.0, 1560.0], [78.0, 1560.0]]], "lines": ["小学館５００"]}, {"box": [616, 1149, 2772, 1466], "vertical": false, "font_size": 138.0, "lines_coords": [[[616.0, 1149.0], [2772.0, 1172.0], [2772.0, 1324.0], [616.0, 1301.0]], [[648.0, 1324.0], [1729.0, 1342.0], [1729.0, 1466.0], [648.0, 1448.0]]], "lines": ["連載開始より８年。鬼才が精魂傾けた、", "人間という小学園．．．"]}, {"box": [4291, 1464, 4623, 1523], "vertical": false, "font_size": 64, "lines_coords": [[[4291.0, 1459.0], [4623.0, 1459.0], [4623.0, 1528.0], [4291.0, 1528.0]]], "lines": ["ホムンクルス上５"]}], "img_path": "005.png"}, {"version": "0.1.7", "img_width": 2478, "img_height": 1600, "blocks": [{"box": [280, 200, 849, 994], "vertical": false, "font_size": 749, "lines_coords": [[[280.0, 249.0], [776.0, 200.0], [849.0, 946.0], [353.0, 994.0]]], "lines": ["ふっ"]}, {"box": [1142, 648, 1333, 1541], "vertical": true, "font_size": 92.0, "lines_coords": [[[1236.0, 1464.0], [1270.0, 1464.0], [1270.0, 1541.0], [1236.0, 1541.0]], [[1142.0, 655.0], [1292.0, 648.0], [1333.0, 1498.0], [1183.0, 1505.0]]], "lines": ["．．．", "オルス、１５，山本愛夫"]}, {"box": [1191, 951, 1276, 1476], "vertical": true, "font_size": 85, "lines_coords": [[[1191.0, 951.0], [1276.0, 951.0], [1276.0, 1476.0], [1191.0, 1476.0]]], "lines": ["５レッ山本英夫"]}, {"box": [1313, 718, 1418, 750], "vertical": false, "font_size": 35, "lines_coords": [[[1313.0, 715.0], [1418.0, 715.0], [1418.0, 753.0], [1313.0, 753.0]]], "lines": ["私、ｈｕｎｅｄｌｕｓ．"]}], "img_path": "006.png"}, {"version": "0.1.7", "img_width": 1000, "img_height": 1600, "