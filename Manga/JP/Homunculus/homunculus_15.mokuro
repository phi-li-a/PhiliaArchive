ght": 1600, "blocks": [{"box": [876, 123, 920, 254], "vertical": true, "font_size": 44, "lines_coords": [[[876.0, 123.0], [920.0, 123.0], [920.0, 254.0], [876.0, 254.0]]], "lines": ["やあっ。"]}, {"box": [596, 84, 703, 278], "vertical": true, "font_size": 48, "lines_coords": [[[661.0, 90.0], [700.0, 90.0], [700.0, 278.0], [661.0, 278.0]], [[596.0, 84.0], [653.0, 84.0], [653.0, 237.0], [596.0, 237.0]]], "lines": ["おまえら", "かっ！"]}], "img_path": "372.png"}, {"version": "0.1.7", "img_width": 1110, "img_height": 1600, "blocks": [], "img_path": "373.png"}, {"version": "0.1.7", "img_width": 1095, "img_height": 1600, "blocks": [{"box": [82, 1432, 850, 1529], "vertical": false, "font_size": 22, "lines_coords": [[[90.0, 1438.0], [823.0, 1430.0], [823.0, 1455.0], [90.0, 1462.0]], [[90.0, 1460.0], [791.0, 1454.0], [791.0, 1478.0], [90.0, 1484.0]], [[90.0, 1482.0], [840.0, 1476.0], [840.0, 1500.0], [90.0, 1506.0]], [[110.0, 1504.0], [577.0, 1501.0], [577.0, 1525.0], [110.0, 1528.0]]], "lines": ["●作品中の「トレパネーションョン：は極めて危険な行為です。絶対に真似をしないでください。", "今回の作品は、「レストの中国はフィクションそれは個人に出来ないのですが、です。実在する人物１団体「事件等ということ」はー切関係ありませんが、はー初関係おりきせん。毎日のＣｈｉｌｌｅ", "この中国はインコインターネットの●「週刊ビッグコミックスピリッツ」２０１０年１０月１５日には１２月１０日午１６時、４５分、４７号、４０１５年１１月１９日土土です。それ以上の号、２０１７年１－３４合併号、", "２０１９年９月、１２号掲載作品や２０１０年３月、４０日、エビローグ３２円描き下ろし。"]}], "img_path": "374.png"}, {"version": "0.1.7", "img_width": 1098, "img_height": 1600, "blocks": [{"box": [139, 168, 501, 281], "vertical": false, "font_size": 43.5, "lines_coords": [[[139.0, 168.0], [501.0, 171.0], [501.0, 220.0], [139.0, 217.0]], [[206.0, 243.0], [424.0, 243.0], [424.0, 281.0], [206.0, 281.0]]], "lines": ["ホムンクルス回", "ビッグコミックス"]}, {"box": [217, 732, 609, 759], "vertical": false, "font_size": 27, "lines_coords": [[[217.0, 732.0], [609.0, 732.0], [609.0, 759.0], [217.0, 759.0]]], "lines": ["２０１１年５月３日初版第１刷発行"]}, {"box": [531, 675, 985, 706], "vertical": false, "font_size": 31, "lines_coords": [[[531.0, 675.0], [985.0, 675.0], [985.0, 706.0], [531.0, 706.0]]], "lines": ["ＩＳＢＮ９７８－４－Ｏ９－．１８３７９０－