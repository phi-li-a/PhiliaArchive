.0, 640.0], [502.0, 798.0], [474.0, 798.0]], [[437.0, 643.0], [463.0, 643.0], [463.0, 848.0], [437.0, 848.0]], [[405.0, 642.0], [432.0, 642.0], [432.0, 823.0], [405.0, 823.0]]], "lines": ["自分の身体に", "「見てあげた証明」", "として勲章が", "発生し、歪な姿に", "なっていった．．"]}, {"box": [872, 1339, 966, 1423], "vertical": true, "font_size": 32, "lines_coords": [[[932.0, 1339.0], [966.0, 1339.0], [966.0, 1423.0], [932.0, 1423.0]], [[901.0, 1339.0], [935.0, 1339.0], [935.0, 1423.0], [901.0, 1423.0]], [[872.0, 1339.0], [901.0, 1339.0], [901.0, 1421.0], [872.0, 1421.0]]], "lines": ["そんな", "簡単な", "こと．．．"]}, {"box": [513, 1137, 604, 1403], "vertical": true, "font_size": 29, "lines_coords": [[[577.0, 1140.0], [604.0, 1140.0], [604.0, 1267.0], [577.0, 1267.0]], [[544.0, 1139.0], [576.0, 1139.0], [576.0, 1318.0], [544.0, 1318.0]], [[513.0, 1137.0], [540.0, 1137.0], [543.0, 1401.0], [516.0, 1401.0]]], "lines": ["あなた自身", "心のどこかでは", "わかっていたはずです。"]}, {"box": [379, 1259, 415, 1318], "vertical": true, "font_size": 36, "lines_coords": [[[379.0, 1259.0], [415.0, 1259.0], [415.0, 1318.0], [379.0, 1318.0]]], "lines": ["な．．．"]}, {"box": [35, 1357, 96, 1465], "vertical": true, "font_size": 30, "lines_coords": [[[70.0, 1362.0], [96.0, 1362.0], [96.0, 1465.0], [70.0, 1465.0]], [[35.0, 1357.0], [70.0, 1357.0], [70.0, 1442.0], [35.0, 1442.0]]], "lines": ["なんだよ", "それ．．．"]}], "img_path": "020.png"}, {"version": "0.1.7", "img_width": 1096, "img_height": 1600, "blocks": [{"box": [861, 90, 966, 275], "vertical": true, "font_size": 35, "lines_coords": [[[927.0, 92.0], [966.0, 92.0], [966.0, 178.0], [927.0, 178.0]], [[899.0, 92.0], [930.0, 92.0], [927.0, 275.0], [895.0, 275.0]], [[861.0, 92.0], [895.0, 90.0], [900.0, 179.0], [866.0, 181.0]]], "lines": ["それは", "「見てやった」ん", "だから、"]}, {"box": [422, 184, 580, 417], "vertical": true, "font_size": 29, "lines_coords": [[[544.0, 184.0], [580.0, 184.0], [580.0, 243.0], [544.0, 243.0]], [[515.0, 185.0], [542.0, 185.0], [542.0, 395.0], [515.0, 395.0]], [[484.0, 185.0], [511.0, 185.0], [512.0, 417.0], [486.0, 417.0]], [[453.0, 189.0], [481.0, 189.0], [481.0, 292.0], [453.0, 292.0]], [[422.0, 187.0], [448.0, 187.0], [448.0, 328.0], [422.0, 328.0]]], "lines": ["俺も", "「見てくれ」という", "期待・希望・欲求の", "表われに", "過ぎません。"]}, {"box": [856, 901, 1005, 1089], "vertical": true, "font_size": 33, "lines_coords": [[[970.0, 901.0], [1005.0, 903.0], [999.0, 1089.0], [964.0, 1087.0]], [[933.0, 903.0], [959.0, 903.0], [959.0, 1085.0], [933.0, 1085.0]], [[891.0, 901.0], [930.0, 901.0], [930.0, 1000.0], [891.0, 1000.0]], [[856.0, 904.0], [889.0, 904.0], [889.0, 1009.0], [856.0, 1009.0]]], "lines": ["「見る」という", "行為からきた", "単純な", "副作用。"]}, {"box": [500, 898, 643, 1070], "vertical": true, "font_size": 32, "lines_coords": [[[614.0, 903.0], [642.0, 903.0], [642.0, 1025.0], [614.0, 1025.0]], [[570.0, 900.0], [612.0, 900.0], [612.0, 981.0], [570.0, 981.0]], [[539.0, 901.0], [567.0, 901.0], [567.0, 1025.0], [539.0, 1025.0]], [[500.0, 898.0], [531.0, 898.0], [531.0, 1070.0], [500.0, 1070.0]]], "lines": ["あなたは", "ただ、", "見返りを", "求めている。"]}, {"box": [378, 1207, 449, 1364], "vertical": true, "font_size": 33, "lines_coords": [[[415.0, 1207.0], [448.0, 1207.0], [445.0, 1364.0], [412.0, 1364.0]], [[378.0, 1212.0], [411.0, 1212.0], [411.0, 1345.0], [378.0, 1345.0]]], "lines": ["「見てくれ」", "っていう。"]}], "img_path": "021.png"}, {"version": "0.1.7", "img_width": 1106, "img_height": 1600, "blocks": [{"box": [929, 71, 965, 129], "vertical": true, "font_size": 33, "lines_coords": [[[929.0, 71.0], [965.0, 71.0], [965.0, 129.0], [929.0, 129.0]]], "lines": ["な．．．"]}, {"box": [798, 28, 863, 210], "vertical": true, "font_size": 33, "lines_coords": [[[827.0, 28.0], [863.0, 28.0], [863.0, 90.0], [827.0, 90.0]], [[801.0, 28.0], [827.0, 28.0], [824.0, 210.0], [798.0, 210.0]]], "lines": ["何を", "言ってるんだ．．．"]}, {"box": [632, 42, 699, 135], "vertical": true, "font_size": 38, "lines_coords": [[[657.0, 42.0], [699.0, 42.0], [699.0, 107.0], [657.0, 107.0]], [[632.0, 43.0], [665.0, 43.0], [665.0, 135.0], [632.0, 135.0]]], "lines": ["俺は", "今まで、"]}, {"box": [365, 28, 489, 209], "vertical": true, "font_size": 27, "lines_coords": [[[460.0, 28.0], [488.0, 28.0], [488.0, 146.0], [460.0, 146.0]], [[429.0, 28.0], [456.0, 28.0], [456.0, 171.0], [429.0, 171.0]], [[398.0, 29.0], [424.0, 29.0], [424.0, 160.0], [398.0, 160.0]], [[365.0, 31.0], [392.0, 31.0], [393.0, 209.0], [367.0, 209.0]]], "lines": ["「見返して", "くれ」なんて", "言ったこと", "一度もねぇぞ．．．"]}, {"box": [203, 31, 259, 267], "vertical": true, "font_size": 25, "lines_coords": [[[237.0, 32.0], [259.0, 32.0], [259.0, 162.0], [237.0, 162.0]], [[206.0, 31.0], [228.0, 31.0], [224.0, 267.0], [203.0, 267.0]]], "lines": ["だからこそ", "その「抑えた思い」が"]}, {"box": [37, 62, 128, 246], "vertical": true, "font_size": 25, "lines_coords": [[[101.0, 62.0], [128.0, 62.0], [128.0, 246.0], [101.0, 246.0]], [[68.0, 64.0], [95.0, 64.0], [95.0, 195.0], [68.0, 195.0]], [[37.0, 62.0], [64.0, 62.0], [67.0, 179.0], [40.0, 179.0]]], "lines": ["そういった形で", "現れてるん", "でしょう。"]}, {"box": [548, 821, 632, 1002], "vertical": true, "font_size": 57, "lines_coords": [[[548.0, 832.0], [604.0, 821.0], [632.0, 971.0], [576.0, 982.0]]], "lines": ["違うっ！"]}, {"box": [434, 1251, 573, 1521], "vertical": true, "font_size": 41, "lines_coords": [[[523.0, 1254.0], [570.0, 1254.0], [570.0, 1367.0], [523.0, 1367.0]], [[479.0, 1251.0], [517.0, 1251.0], [521.0, 1465.0], [484.0, 1465.0]], [[434.0, 1253.0], [473.0, 1251.0], [481.0, 1520.0], [442.0, 1521.0]]], "lines": ["コレは", "そんな薄汚い", "もんじゃねぇっ。"]}], "img_path": "022.png"}, {"version": "0.1.7", "img_width": 1099, "img_height": 1600, "blocks": [{"box": [941, 187, 1066, 442], "vertical": true, "font_size": 35, "lines_coords": [[[1025.0, 187.0], [1063.0, 187.0], [1066.0, 442.0], [1028.0, 442.0]], [[986.0, 192.0], [1019.0, 192.0], [1019.0, 401.0], [986.0, 401.0]], [[941.0, 189.0], [975.0, 189.0], [978.0, 309.0], [944.0, 309.0]]], "lines": ["おまえみたいな", "何も見えない", "ヤツに、"]}, {"box": [300, 65, 389, 167], "vertical": true, "font_size": 48, "lines_coords": [[[331.0, 67.0], [386.0, 65.0], [389.0, 165.0], [334.0, 167.0]], [[300.0, 68.0], [340.0, 68.0], [340.0, 146.0], [300.0, 146.0]]], "lines": ["コイツ", "には、"]}, {"box": [528, 478, 625, 748], "vertical": true, "font_size": 45, "lines_coords": [[[572.0, 478.0], [625.0, 478.0], [622.0, 735.0], [569.0, 735.0]], [[528.0, 478.0], [565.0, 478.0], [570.0, 748.0], [533.0, 748.0]]], "lines": ["コイツの意味が", "わかるはずねぇ。"]}, {"box": [189, 517, 337, 701], "vertical": true, "font_size": 32, "lines_coords": [[[303.0, 518.0], [336.0, 518.0], [332.0, 673.0], [300.0, 673.0]], [[265.0, 518.0], [298.0, 518.0], [295.0, 701.0], [262.0, 701.0]], [[226.0, 517.0], [257.0, 517.0], [257.0, 701.0], [226.0, 701.0]], [[192.0, 517.0], [223.0, 517.0], [220.0, 642.0], [189.0, 642.0]]], "lines": ["何か特別な", "メッセージが", "含まれている", "はずだ！"]}, {"box": [884, 1295, 1057, 1512], "vertical": true, "font_size": 35, "lines_coords": [[[1022.0, 1301.0], [1055.0, 1301.0], [1055.0, 1510.0], [1022.0, 1510.0]], [[978.0, 1300.0], [1011.0, 1300.0], [1011.0, 1476.0], [978.0, 1476.0]], [[934.0, 1298.0], [969.0, 1298.0], [966.0, 1512.0], [931.0, 1512.0]], [[884.0, 1296.0], [923.0, 1295.0], [928.0, 1457.0], [889.0, 1459.0]]], "lines": ["見えるヤツに", "見てもらわ", "ないとわから", "ない．．．っ。"]}, {"box": [298, 1315, 468, 1564], "vertical": true, "font_size": 36, "lines_coords": [[[423.0, 1315.0], [468.0, 1315.0], [468.0, 1393.0], [423.0, 1393.0]], [[384.0, 1318.0], [418.0, 1318.0], [415.0, 1564.0], [381.0, 1564.0]], [[340.0, 1317.0], [373.0, 1317.0], [373.0, 1495.0], [340.0, 1495.0]], [[298.0, 1317.0], [329.0, 1317.0], [329.0, 1493.0], [298.0, 1493.0]]], "lines": ["俺の", "ホムンクルスを", "見てもらわ", "ないと．．．！"]}], "img_path": "023.png"}, {"version": "0.1.7", "img_width": 1105, "img_height": 1600, "blocks": [{"box": [909, 82, 937, 168], "vertical": true, "font_size": 28, "lines_coords": [[[909.0, 82.0], [937.0, 82.0], [937.0, 168.0], [909.0, 168.0]]], "lines": ["なんか、"]}, {"box": [496, 44, 523, 280], "vertical": true, "font_size": 22, "lines_coords": [[[498.0, 48.0], [520.0, 48.0], [520.0, 275.0], [498.0, 275.0]]], "lines": ["違うんだよなぁ〜〜〜"]}, {"box": [391, 411, 417, 461], "vertical": true, "font_size": 26, "lines_coords": [[[391.0, 411.0], [417.0, 411.0], [417.0, 461.0], [391.0, 461.0]]], "lines": ["？"]}, {"box": [828, 751, 950, 956], "vertical": true, "font_size": 26, "lines_coords": [[[917.0, 753.0], [950.0, 753.0], [950.0, 834.0], [917.0, 834.0]], [[887.0, 753.0], [914.0, 753.0], [915.0, 956.0], [889.0, 956.0]], [[858.0, 751.0], [884.0, 751.0], [884.0, 932.0], [858.0, 932.0]], [[828.0, 756.0], [850.0, 756.0], [850.0, 917.0], [828.0, 917.0]]], "lines": ["確かに", "あなたの見えてる", "ものは、ただの", "幻覚ではない。"]}, {"box": [547, 751, 697, 985], "vertical": true, "font_size": 26, "lines_coords": [[[675.0, 754.0], [697.0, 754.0], [697.0, 931.0], [675.0, 931.0]], [[640.0, 754.0], [667.0, 754.0], [667.0, 934.0], [640.0, 934.0]], [[607.0, 751.0], [634.0, 751.0], [637.0, 985.0], [611.0, 985.0]], [[579.0, 754.0], [601.0, 754.0], [601.0, 882.0], [579.0, 882.0]], [[547.0, 753.0], [575.0, 753.0], [575.0, 870.0], [547.0, 870.0]]], "lines": ["科学じゃ説明の", "つかないような", "計り知れないものが", "見えてるん", "でしょう。"]}, {"box": [381, 981, 447, 1071], "vertical": true, "font_size": 37, "lines_coords": [[[406.0, 981.0], [447.0, 981.0], [447.0, 1067.0], [406.0, 1067.0]], [[381.0, 981.0], [414.0, 981.0], [414.0, 1071.0], [381.0, 1071.0]]], "lines": ["しかし", "ながら、"]}, {"box": [49, 890, 151, 1100], "vertical": true, "font_size": 32, "lines_coords": [[[107.0, 890.0], [151.0, 890.0], [151.0, 953.0], [107.0, 953.0]], [[79.0, 895.0], [110.0, 895.0], [110.0, 1053.0], [79.0, 1053.0]], [[51.0, 898.0], [73.0, 898.0], [73.0, 1100.0], [51.0, 1100.0]]], "lines": ["その．．", "移ったものは", "何ら意味のない．．．"]}, {"box": [326, 1193, 432, 1451], "vertical": true, "font_size": 30, "lines_coords": [[[401.0, 1196.0], [429.0, 1196.0], [429.0, 1343.0], [401.0, 1343.0]], [[364.0, 1196.0], [395.0, 1196.0], [395.0, 1414.0], [364.0, 1414.0]], [[326.0, 1193.0], [357.0, 1193.0], [357.0, 1451.0], [326.0, 1451.0]]], "lines": ["名越さんの", "ワガママな主張、", "訴えに過ぎません。"]}], "img_path": "024.png"}, {"version": "0.1.7", "img_width": 1108, "img_height": 1600, "blocks": [{"box": [514, 142, 676, 332], "vertical": true, "font_size": 30, "lines_coords": [[[628.0, 145.0], [670.0, 142.0], [676.0, 218.0], [634.0, 223.0]], [[607.0, 150.0], [634.0, 150.0], [634.0, 331.0], [607.0, 331.0]], [[573.0, 148.0], [604.0, 148.0], [604.0, 332.0], [573.0, 332.0]], [[542.0, 148.0], [568.0, 148.0], [571.0, 329.0], [545.0, 329.0]], [[514.0, 150.0], [536.0, 150.0], [539.0, 312.0], [517.0, 312.0]]], "lines": ["第一、", "「見る」ってのは", "そんな、代償を", "求めるものじゃ", "ないでしょう。"]}, {"box": [1004, 931, 1065, 1037], "vertical": true, "font_size": 30, "lines_coords": [[[1031.0, 931.0], [1065.0, 931.0], [1065.0, 1014.0], [1031.0, 1014.0]], [[1004.0, 932.0], [1031.0, 932.0], [1031.0, 1037.0], [1004.0, 1037.0]]], "lines": ["なんだ", "おまえ．．．"]}, {"box": [168, 773, 318, 1006], "vertical": true, "font_size": 26, "lines_coords": [[[292.0, 776.0], [318.0, 776.0], [318.0, 879.0], [292.0, 879.0]], [[260.0, 773.0], [287.0, 773.0], [287.0, 929.0], [260.0, 929.0]], [[228.0, 775.0], [254.0, 775.0], [254.0, 979.0], [228.0, 979.0]], [[196.0, 773.0], [223.0, 773.0], [221.0, 1006.0], [195.0, 1006.0]], [[168.0, 775.0], [190.0, 775.0], [190.0, 1003.0], [168.0, 1003.0]]], "lines": ["いつもは", "科学や理論を", "気取ってるやつが", "急にロマンチックな", "こと言いやがって．．．"]}, {"box": [1007, 1328, 1065, 1456], "vertical": true, "font_size": 26, "lines_coords": [[[1039.0, 1328.0], [1065.0, 1328.0], [1065.0, 1456.0], [1039.0, 1456.0]], [[1007.0, 1329.0], [1034.0, 1329.0], [1034.0, 1439.0], [1007.0, 1439.0]]], "lines": ["見返りなど", "関係なく、"]}, {"box": [578, 1310, 702, 1539], "vertical": true, "font_size": 27, "lines_coords": [[[678.0, 1317.0], [700.0, 1317.0], [696.0, 1517.0], [675.0, 1517.0]], [[643.0, 1314.0], [670.0, 1314.0], [668.0, 1517.0], [642.0, 1517.0]], [[612.0, 1312.0], [639.0, 1312.0], [637.0, 1539.0], [611.0, 1539.0]], [[578.0, 1310.0], [611.0, 1310.0], [611.0, 1403.0], [578.0, 1403.0]]], "lines": ["一方的に見ている", "ストーカーの方が", "よっぽど人間らしい", "