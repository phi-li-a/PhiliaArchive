0.0, 1454.0]]], "lines": ["日々の", "筋トレも", "した。"]}, {"box": [70, 1356, 162, 1521], "vertical": true, "font_size": 25, "lines_coords": [[[132.0, 1356.0], [159.0, 1356.0], [162.0, 1509.0], [135.0, 1509.0]], [[103.0, 1357.0], [125.0, 1357.0], [125.0, 1506.0], [103.0, 1506.0]], [[70.0, 1357.0], [96.0, 1357.0], [96.0, 1521.0], [70.0, 1521.0]]], "lines": ["食いすぎた時", "などの嘔吐の", "仕方も覚えた。"]}], "img_path": "049.png"}, {"version": "0.1.7", "img_width": 1103, "img_height": 1600, "blocks": [{"box": [957, 68, 1020, 185], "vertical": true, "font_size": 32, "lines_coords": [[[982.0, 70.0], [1017.0, 68.0], [1020.0, 153.0], [985.0, 154.0]], [[957.0, 70.0], [985.0, 70.0], [985.0, 185.0], [957.0, 185.0]]], "lines": ["高校に", "なっても、"]}, {"box": [528, 50, 618, 242], "vertical": true, "font_size": 23, "lines_coords": [[[590.0, 50.0], [617.0, 50.0], [617.0, 231.0], [590.0, 231.0]], [[559.0, 50.0], [581.0, 50.0], [581.0, 154.0], [559.0, 154.0]], [[528.0, 51.0], [549.0, 51.0], [549.0, 242.0], [528.0, 242.0]]], "lines": ["休み時間さえも", "下を向き", "勉強をしていた。"]}, {"box": [353, 45, 411, 150], "vertical": true, "font_size": 28, "lines_coords": [[[382.0, 45.0], [409.0, 45.0], [409.0, 150.0], [382.0, 150.0]], [[353.0, 45.0], [381.0, 45.0], [381.0, 131.0], [353.0, 131.0]]], "lines": ["周りから", "見たら、"]}, {"box": [335, 239, 429, 423], "vertical": true, "font_size": 30, "lines_coords": [[[395.0, 240.0], [429.0, 240.0], [429.0, 323.0], [395.0, 323.0]], [[365.0, 240.0], [393.0, 240.0], [395.0, 373.0], [367.0, 373.0]], [[337.0, 239.0], [364.0, 239.0], [362.0, 423.0], [335.0, 423.0]]], "lines": ["ただの", "ブサイクな", "ガリベン野郎．．．"]}, {"box": [729, 787, 823, 929], "vertical": true, "font_size": 33, "lines_coords": [[[790.0, 787.0], [823.0, 787.0], [820.0, 898.0], [787.0, 898.0]], [[756.0, 789.0], [795.0, 789.0], [795.0, 875.0], [756.0, 875.0]], [[732.0, 789.0], [759.0, 789.0], [756.0, 925.0], [729.0, 925.0]]], "lines": ["「恋愛」や", "「性」に", "敏感な時期"]}, {"box": [788, 1007, 823, 1092], "vertical": true, "font_size": 35, "lines_coords": [[[788.0, 1007.0], [823.0, 1007.0], [823.0, 1092.0], [788.0, 1092.0]]], "lines": ["俺は；"]}, {"box": [632, 1103, 729, 1235], "vertical": true, "font_size": 32, "lines_coords": [[[693.0, 1104.0], [729.0, 1104.0], [729.0, 1173.0], [693.0, 1173.0]], [[665.0, 1103.0], [698.0, 1103.0], [698.0, 1187.0], [665.0, 1187.0]], [[635.0, 1103.0], [662.0, 1103.0], [659.0, 1235.0], [632.0, 1235.0]]], "lines": ["ただ、", "横目に", "見ていた．．"]}, {"box": [115, 746, 272, 930], "vertical": true, "font_size": 29, "lines_coords": [[[245.0, 751.0], [271.0, 751.0], [268.0, 854.0], [242.0, 854.0]], [[209.0, 750.0], [242.0, 750.0], [242.0, 832.0], [209.0, 832.0]], [[181.0, 750.0], [207.0, 750.0], [204.0, 929.0], [178.0, 929.0]], [[149.0, 750.0], [176.0, 750.0], [176.0, 904.0], [149.0, 904.0]], [[115.0, 746.0], [149.0, 746.0], [149.0, 814.0], [115.0, 814.0]]], "lines": ["周りでは", "男女が", "和気あいあいと", "賑わっている", "のを、"]}, {"box": [132, 1053, 167, 1104], "vertical": true, "font_size": 35, "lines_coords": [[[132.0, 1053.0], [167.0, 1053.0], [167.0, 1104.0], [132.0, 1104.0]]], "lines": ["！！"]}, {"box": [712, 1328, 760, 1382], "vertical": true, "font_size": 48, "lines_coords": [[[712.0, 1328.0], [760.0, 1328.0], [760.0, 1382.0], [712.0, 1382.0]]], "lines": ["！？"]}], "img_path": "050.png"}, {"version": "0.1.7", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [873, 328, 903, 384], "vertical": true, "font_size": 28, "lines_coords": [[[873.0, 328.0], [903.0, 328.0], [903.0, 384.0], [873.0, 384.0]]], "lines": ["そ．．．"]}, {"box": [773, 468, 934, 634], "vertical": true, "font_size": 28, "lines_coords": [[[906.0, 470.0], [934.0, 470.0], [934.0, 600.0], [906.0, 600.0]], [[865.0, 468.0], [897.0, 468.0], [897.0, 629.0], [865.0, 629.0]], [[839.0, 471.0], [861.0, 471.0], [861.0, 625.0], [839.0, 625.0]], [[805.0, 471.0], [831.0, 471.0], [831.0, 626.0], [805.0, 626.0]], [[773.0, 470.0], [800.0, 470.0], [800.0, 634.0], [773.0, 634.0]]], "lines": ["その中でも", "顔のいい男は、", "女の目を引き", "ナャラチャラ", "されていたな。"]}, {"box": [701, 814, 833, 