ath": "247.png"}, {"version": "0.1.7", "img_width": 1100, "img_height": 1600, "blocks": [], "img_path": "248.png"}, {"version": "0.1.7", "img_width": 1101, "img_height": 1600, "blocks": [], "img_path": "249.png"}, {"version": "0.1.7", "img_width": 1096, "img_height": 1600, "blocks": [{"box": [321, 29, 513, 275], "vertical": true, "font_size": 41, "lines_coords": [[[473.0, 35.0], [511.0, 35.0], [511.0, 198.0], [473.0, 198.0]], [[423.0, 32.0], [461.0, 32.0], [461.0, 189.0], [423.0, 189.0]], [[368.0, 31.0], [414.0, 31.0], [414.0, 171.0], [368.0, 171.0]], [[322.0, 35.0], [364.0, 35.0], [364.0, 271.0], [322.0, 271.0]]], "lines": ["これから", "俺は何処", "行けば", "いいんだ．．．"]}, {"box": [892, 1045, 957, 1400], "vertical": true, "font_size": 64, "lines_coords": [[[892.0, 1045.0], [956.0, 1045.0], [956.0, 1400.0], [892.0, 1400.0]]], "lines": ["俺は何処へ．．．"]}], "img_path": "250.png"}, {"version": "0.1.7", "img_width": 1104, "img_height": 1600, "blocks": [], "img_path": "251.png"}, {"version": "0.1.7", "img_width": 1098, "img_height": 1600, "blocks": [], "img_path": "252.png"}, {"version": "0.1.7", "img_width": 1112, "img_height": 1600, "blocks": [{"box": [74, 767, 612, 826], "vertical": false, "font_size": 59, "lines_coords": [[[74.0, 767.0], [612.0, 767.0], [612.0, 826.0], [74.0, 826.0]]], "lines": ["「ホムンクルス第１４集・完"]}, {"box": [70, 1446, 982, 1514], "vertical": false, "font_size": 21.666666666666668, "lines_coords": [[[70.0, 1446.0], [810.0, 1450.0], [810.0, 1471.0], [70.0, 1468.0]], [[70.0, 1468.0], [774.0, 1471.0], [774.0, 1492.0], [70.0, 1489.0]], [[71.0, 1490.0], [982.0, 1492.0], [982.0, 1514.0], [71.0, 1512.0]]], "lines": ["●作品中の「トレバネーションいは極めて危険な行為です。絶対に真似をしないでください。", "あこの作品はフィクションコントは盛りくんのよいかというのですが、実在する人物・団体・事件もといいと美味としないはー切関係ありません。", "●「週刊ビッグコミックスにでも、実在する人物の出会いやリッツ・２０１０年６月、２０日、中とは、以内ポイントと３２－３４号、３６・３７合併号この３９号、４１－４２号掲載作品。"]}], "img_path": "253.png"}, {"version": "0.1.7", "img_width": 1116, "img_height": 1600, "blocks": [{"box": [75, 167, 500, 256], "vertical": false, "font_size": 81, 