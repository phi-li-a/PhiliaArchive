]], [[638.0, 68.0], [665.0, 68.0], [665.0, 173.0], [638.0, 173.0]], [[606.0, 68.0], [634.0, 68.0], [634.0, 171.0], [606.0, 171.0]]], "lines": ["あそこで", "出会った", "んだ．．．"]}, {"box": [1023, 484, 1047, 646], "vertical": true, "font_size": 22, "lines_coords": [[[1023.0, 484.0], [1045.0, 484.0], [1045.0, 646.0], [1023.0, 646.0]]], "lines": ["東京に来ても、"]}, {"box": [307, 779, 529, 815], "vertical": false, "font_size": 29, "lines_coords": [[[307.0, 780.0], [468.0, 785.0], [468.0, 816.0], [307.0, 811.0]]], "lines": ["まあ無理なんだそうになれば許してしまったのです"]}, {"box": [806, 741, 831, 918], "vertical": true, "font_size": 22, "lines_coords": [[[807.0, 742.0], [829.0, 742.0], [829.0, 918.0], [807.0, 918.0]]], "lines": ["何もない毎日．．．"]}, {"box": [907, 1026, 1004, 1170], "vertical": true, "font_size": 30, "lines_coords": [[[968.0, 1026.0], [1004.0, 1026.0], [1004.0, 1089.0], [968.0, 1089.0]], [[942.0, 1029.0], [968.0, 1029.0], [968.0, 1134.0], [942.0, 1134.0]], [[910.0, 1028.0], [937.0, 1028.0], [934.0, 1170.0], [907.0, 1170.0]]], "lines": ["よく", "あそこを", "使っていた。"]}, {"box": [610, 751, 704, 890], "vertical": true, "font_size": 30, "lines_coords": [[[668.0, 751.0], [704.0, 751.0], [704.0, 810.0], [668.0, 810.0]], [[640.0, 754.0], [668.0, 754.0], [668.0, 857.0], [640.0, 857.0]], [[610.0, 753.0], [637.0, 753.0], [637.0, 889.0], [610.0, 889.0]]], "lines": ["ただ", "ひたすら", "下を向いて、"]}, {"box": [368, 996, 395, 1107], "vertical": true, "font_size": 26, "lines_coords": [[[368.0, 996.0], [395.0, 996.0], [395.0, 1107.0], [368.0, 1107.0]]], "lines": ["そんな時、"]}, {"box": [139, 728, 239, 896], "vertical": true, "font_size": 32, "lines_coords": [[[196.0, 728.0], [239.0, 728.0], [239.0, 793.0], [196.0, 793.0]], [[173.0, 734.0], [199.0, 734.0], [199.0, 837.0], [173.0, 837.0]], [[142.0, 732.0], [168.0, 732.0], [165.0, 893.0], [139.0, 893.0]]], "lines": ["本を", "読んだり", "勉強するのに、"]}, {"box": [140, 998, 260, 1175], "vertical": true, "font_size": 26, "lines_coords": [[[232.0, 998.0], [260.0, 998.0], [260.0, 1128.0], [232.0, 1128.0