.0], [949.0, 190.0]], [[916.0, 85.0], [944.0, 85.0], [944.0, 173.0], [916.0, 173.0]]], "lines": ["俺は", "おまえと", "別れて、"]}, {"box": [537, 84, 634, 220], "vertical": true, "font_size": 36, "lines_coords": [[[590.0, 84.0], [634.0, 84.0], [634.0, 151.0], [590.0, 151.0]], [[563.0, 87.0], [601.0, 87.0], [601.0, 148.0], [563.0, 148.0]], [[537.0, 90.0], [563.0, 90.0], [563.0, 220.0], [537.0, 220.0]]], "lines": ["すぐ", "顔を", "変えた．．．"]}, {"box": [385, 220, 415, 301], "vertical": true, "font_size": 30, "lines_coords": [[[385.0, 220.0], [415.0, 220.0], [415.0, 279.0], [385.0, 279.0]]], "lines": ["！？．．．"]}, {"box": [796, 462, 857, 568], "vertical": true, "font_size": 30, "lines_coords": [[[829.0, 464.0], [857.0, 464.0], [854.0, 568.0], [826.0, 568.0]], [[796.0, 462.0], [829.0, 462.0], [829.0, 546.0], [796.0, 546.0]]], "lines": ["「別れた」", "って．．．"]}, {"box": [551, 471, 612, 601], "vertical": true, "font_size": 25, "lines_coords": [[[585.0, 471.0], [612.0, 471.0], [612.0, 601.0], [585.0, 601.0]], [[554.0, 473.0], [577.0, 473.0], [574.0, 600.0], [551.0, 600.0]]], "lines": ["付き合って", "ませんし．．．"]}, {"box": [348, 450, 442, 630], "vertical": true, "font_size": 29, "lines_coords": [[[412.0, 453.0], [440.0, 453.0], [441.0, 582.0], [413.0, 582.0]], [[385.0, 456.0], [407.0, 456.0], [407.0, 629.0], [385.0, 629.0]], [[348.0, 450.0], [385.0, 450.0], [385.0, 515.0], [348.0, 515.0]]], "lines": ["お会いした", "時の名越さんの", "顔と、"]}, {"box": [113, 462, 213, 618], "vertical": true, "font_size": 32, "lines_coords": [[[176.0, 462.0], [213.0, 462.0], [213.0, 525.0], [176.0, 525.0]], [[149.0, 465.0], [176.0, 465.0], [176.0, 618.0], [149.0, 618.0]], [[113.0, 464.0], [146.0, 462.0], [149.0, 554.0], [117.0, 556.0]]], "lines": ["何も", "変わってない", "ですよ。"]}, {"box": [520, 1274, 584, 1471], "vertical": true, "font_size": 64, "lines_coords": [[[520.0, 1274.0], [584.0, 1274.0], [584.0, 1471.0], [520.0, 1471.0]]], "lines": ["嘘．．．"]}], "img_path": "028.png"}, {"version": "0.1.7", "img_width": 1092, "img_height": 1600, "blocks": [{