7.0], [611.0, 717.0], [611.0, 748.0], [142.0, 748.0]], [[146.0, 744.0], [615.0, 744.0], [615.0, 775.0], [146.0, 775.0]], [[146.0, 774.0], [534.0, 774.0], [534.0, 805.0], [146.0, 805.0]], [[146.0, 809.0], [538.0, 809.0], [538.0, 828.0], [146.0, 828.0]], [[142.0, 832.0], [561.0, 832.0], [561.0, 863.0], [142.0, 863.0]], [[146.0, 863.0], [607.0, 863.0], [607.0, 894.0], [146.0, 894.0]], [[146.0, 890.0], [611.0, 890.0], [611.0, 921.0], [146.0, 921.0]], [[142.0, 917.0], [611.0, 913.0], [611.0, 944.0], [142.0, 948.0]], [[146.0, 948.0], [615.0, 948.0], [615.0, 978.0], [146.0, 978.0]], [[142.0, 971.0], [611.0, 967.0], [611.0, 1009.0], [142.0, 1013.0]], [[146.0, 1005.0], [611.0, 1005.0], [611.0, 1036.0], [146.0, 1036.0]], [[146.0, 1032.0], [611.0, 1032.0], [611.0, 1063.0], [146.0, 1063.0]], [[146.0, 1063.0], [611.0, 1063.0], [611.0, 1094.0], [146.0, 1094.0]], [[149.0, 1098.0], [611.0, 1098.0], [611.0, 1117.0], [149.0, 1117.0]], [[142.0, 1121.0], [615.0, 1121.0], [615.0, 1152.0], [142.0, 1152.0]]], "lines": ["スピリッツコミ．．．ックス好評発売中！！", "美味しんぼ（雁屋哲・花咲アキラリ．．．！", "団地ともお（小田扉）．．．．．．", "ホムンクルス（山本英夫）．．．．．．．．いい、１〜１４集ロー", "ラストイニング（中原裕）神尾龍）．．．１〜２７集", "闇金ウンジマくんなのはいつも世の真鍋昌平り．．．いい。１〜２０集くんだよねー", "南海亜バンビ〜ノ！ＳＥＣＯＮＤＯ（せきやてっじ）．．．１〜５集", "電波の城（細野不二彦）．．．．．．！！", "ＭＭＯＯＮ－『ソリチュードスタンディシグー〈曽田正人〉．．．！", "ｍｏｏｎのＵＱＬＯＵＱＪＵＺ－コジューツー相木ハルコリ．．．！！", "ＭｙＦａｒｏｉｔｅＭｙ「ａｎｏｒｔｅＢＩＫＥ（山口からず．．．つみ）．．．１〜４集中", "１０月２１日（火）（日）のヴィルトゥス（信濃川日出雄義兄．．．１〜５集", "フィーナー．．．高度の古代ローマ相続報録（ＳＩＮ（信濃日田雄・親ル．．．１９年１１日出男「義凡」．．－１〜３集", "１００７年１０月１０日－ＭＡＮ（草場道輝）・ああ．．．．．．", "１５５１ＭＡＮ（早場頂碑）．．．新クロサギ（黒丸・夏原武）・かもめんエレンフェ出願．．．．．．．．！！！", "かもめ☆チャンス〈玉井雪雄〉．．．", "鉄腕バーディーＥＶＯＬＵハムナ自体力ＴＯＮ（ゆうきさみ）．．．１〜６集", "朝日のない空（塀内夏子）ちょっと．．．．．．", "アイアムアヒーロー（花沢健吾）．．．！！〜５集", "ＳＥＥＤ（今井大輔）・いいじゃ、琥珀！！．．．"]}, {"box": [1641, 657, 1730, 1034], "vertical": true, "font_size": 81, "lines_coords": [[[1649.0, 657.0], [1730.0, 657.0], [1722.0, 1034.0], [1641.0, 1034.0]]], "lines": ["山本英夫"]}, {"box": [113, 1478, 531, 1539], "vertical": false, "font_size": 29, "lines_coords": [[[126.0, 1478.0], [519.0, 1478.0], [519.0, 1509.0], [126.0, 1509.0]], [[142.0, 1509.0], [499.0, 1509.0], [499.0, 1540.0], [142.0, 1540.0]]], "lines": ["インターネットでビッグコミーックスが購入できます。", "ｔｔｐ：／／ｃｏｍｉｓ．ｓｔｒｏｓｔａｋｉｄａ．ｃｏｌ．"]}, {"box": [803, 1200, 1849, 1580], "vertical": false, "font_size": 86, "lines_coords": [[[934.0, 1246.0], [1680.0, 1226.0], [1683.0, 1334.0], [938.0, 1353.0]], [[803.0, 1219.0], [984.0, 1219.0], [984.0, 1373.0], [803.0, 1373.0]], [[1026.0, 1346.0], [1837.0, 1346.0], [1837.0, 1411.0], [1026.0, 1411.0]], [[811.0, 1326.0], [1226.0, 1342.0], [1222.0, 1469.0], [807.0, 1453.0]], [[815.0, 1457.0], [1818.0, 1453.0], [1818.0, 1507.0], [815.0, 1511.0]], [[815.0, 1519.0], [1380.0, 1519.0], [1380.0, 1569.0], [815.0, 1569.0]], [[1664.0, 1407.0], [1837.0, 1407.0], [1837.0, 1450.0], [1664.0, 1450.0]]], "lines": ["愕のラストシーン", "驚愕", "トーン、見事が放つ、ダークな美緒エングーテインメント", "あと２巻。", "遂作品中の『トレノパネーションは極めて危険な行為です", "絶対に真似をしないでください。", "佳境へ。"]}, {"box": [2529, 161, 2683, 200], "vertical": false, "font_size": 39, "lines_coords": [[[2529.0, 161.0], [2683.0, 161.0], [2683.0, 200.0], [2529.0, 200.0]]], "lines": ["Ｃ９９７９＼５４３Ｅ"]}, {"box": [2530, 81, 2846, 128], "vertical": false, "font_size": 41, "lines_coords": [[[2533.0, 85.0], [2829.0, 85.0], [2829.0, 129.0], [2533.0, 129.0]]], "lines": ["ＩＳＢＮ９７３－４－４０９－１８：３５－２"]}, {"box": [2522, 280, 2881, 396], "vertical": false, "font_size": 55, "lines_coords": [[[2525.0, 275.0], [2875.0, 275.0], [2875.0, 335.0], [2525.0, 335.0]], [[2529.0, 341.0], [2860.0, 341.0], [2860.0, 401.0], [2529.0, 401.0]]], "lines": ["定価：「本体５４０円＋税", "雑誌４５７２５－３５－小学館"]}, {"box": [3337, 369, 3471, 384], "vertical": false, "font_size": 15, "lines_coords": [[[3337.0, 369.0], [3471.0, 369.0], [3471.0, 384.0], [3337.0, 384.0]]], "lines": ["ホムンクルス．．．"]}, {"box": [3333, 207, 3790, 261], "vertical": false, "font_size": 48.0, "lines_coords": [[[3333.0, 207.0], [3590.0, 207.0], [3590.0, 261.0], [3333.0, 261.0]], [[3590.0, 215.0], [3790.0, 215.0], [3790.0, 257.0], [3590.0, 257.0]]], "lines": ["山本英夫", "こ、著作集"]}, {"box": [3319, 520, 3808, 1153], "vertical": false, "font_size": 29, "lines_coords": [[[3341.0, 524.0], [3740.0, 524.0], [3740.0, 544.0], [3341.0, 544.0]], [[3329.0, 544.0], [3794.0, 548.0], [3794.0, 582.0], [3329.0, 578.0]], [[3329.0, 578.0], [3798.0, 578.0], [3798.0, 609.0], [3329.0, 609.0]], [[3329.0, 605.0], [3798.0, 605.0], [3798.0, 636.0], [3329.0, 636.0]], [[3325.0, 636.0], [3798.0, 636.0], [3798.0, 667.0], [3325.0, 667.0]], [[3321.0, 655.0], [3802.0, 659.0], [3802.0, 702.0], [3321.0, 698.0]], [[3329.0, 694.0], [3798.0, 694.0], [3798.0, 725.0], [3329.0, 725.0]], [[3321.0, 717.0], [3798.0, 721.0], [3798.0, 755.0], [3321.0, 752.0]], [[3329.0, 751.0], [3794.0, 751.0], [3794.0, 782.0], [3329.0, 782.0]], [[3329.0, 778.0], [3798.0, 778.0], [3798.0, 809.0], [3329.0, 809.0]], [[3329.0, 809.0], [3794.0, 809.0], [3794.0, 840.0], [3329.0, 840.0]], [[3329.0, 836.0], [3602.0, 836.0], [3602.0, 867.0], [3329.0, 867.0]], [[3329.0, 867.0], [3737.0, 867.0], [3737.0, 898.0], [3329.0, 898.0]], [[3325.0, 886.0], [3790.0, 890.0], [3790.0, 932.0], [3325.0, 928.0]], [[3733.0, 917.0], [3794.0, 924.0], [3790.0, 955.0], [3729.0, 948.0]], [[3325.0, 924.0], [3694.0, 924.0], [3694.0, 955.0], [3325.0, 955.0]], [[3329.0, 959.0], [3790.0, 959.0], [3790.0, 978.0], [3329.0, 978.0]], [[3329.0, 982.0], [3798.0, 982.0], [3798.0, 1013.0], [3329.0, 1013.0]], [[3329.0, 1013.0], [3794.0, 1013.0], [3794.0, 1044.0], [3329.0, 1044.0]], [[3329.0, 1036.0], [3794.0, 1036.0], [3794.0, 1067.0], [3329.0, 1067.0]], [[3329.0, 1067.0], [3794.0, 1067.0], [3794.0, 1098.0], [3329.0, 1098.0]], [[3329.0, 1094.0], [3794.0, 1094.0], [3794.0, 1125.0], [3329.0, 1125.0]], [[3329.0, 1124.0], [3794.0, 1124.0], [3794.0, 1155.0], [3329.0, 1155.0]]], "lines": ["エスピリッツコミックス好評発売中／", "ＹＡＷＡＲＡ！（浦沢直樹）へん．．．でもない．．．．．．", "Ｈａｃｋｍ．．．１Ｈａｐｐｙ！（浦沢直樹）．．．！？４４「ルール」の．．．．．．．．", "２０１８年１０月２０世紀少年（浦沢直樹）．．．．．．．．．．．いい全２２巻", "２１世紀少年（浦沢直樹）．．．大雑マイモの．．．．．．．．", "２．世紀少年、浦沢県樹）．．．奈緒子（坂田信弘・中原裕）・ギャラルーファイル・．．．．．．．．！！！", "お前．．．ギャラリーフェイク具体ヒ平然ふーん。〈細野不二彦〉．．．全２巻く", "キャンプーンエイン（前島の最終兵器彼女（高橋しん）．．．我にやらないんじゃの．．．．．．．．", "我が名は海師（小森陽）ロ十ホル／クルーター一武村勇治）．．．全５巻十七十六", "我の日は海側の林物日本沈没（一色登希彦．．．はいやぁっ．．．まいね、小松左京）．．", "バンビ〜ノ！！せきやロッピ～ノ！（せきヤローい．．．Ａ２Ａ！生いてつじ．．．．．．．全５巻", "昴スパル（普田正人）．．．", "あ．．．上京アフロ田中（の）つけ雅春）．．．．．．", "上部クノロは中のリフリが原稿！！！", "．．．生いて・全８巻", "お互い食料通り商店の帝王（歳科遼「関口大郎）．．．．．．初しかもしれません", "超人ウタダ（山本康人）．．．．．いい．．", "鬼龍院牙子探偵事務所（三上龍哉）．．．全６巻", "セルフ（朔ユキ蔵）．．．ウコナ蔵）．．．ロコナ。ツレルナビル．．．あああぁぁぁああっ．．．", "ビルノ（粉ユキ殿ココナッツビリオ．．．．．．！！", "ココノントソッド（山口の魔王（柳広司・霜月かよ子）．．．生まる子）．．．", "己の魔王、例ム向け痛月からオレメヨメ（北崎拓）．．．ナノ．．．．．．", "オレへヨメくん嘲烈！！森山中教習所（真造圭伍）．．．．．．"]}, {"box": [1945, 1180, 1999, 1573], "vertical": true, "font_size": 54, "lines_coords": [[[1945.0, 1180.0], [1999.0, 1180.0], [1999.0, 1573.0], [1945.0, 1573.0]]], "lines": ["ああ大丈夫"]}, {"box": [2418, 1222, 2825, 1494], "vertical": false, "font_size": 40, "lines_coords": [[[2533.0, 1223.0], [2698.0, 1223.0], [2698.0, 1272.0], [2533.0, 1272.0]], [[2487.0, 1270.0], [2748.0, 1270.0], [2748.0, 1314.0], [2487.0, 1314.0]], [[2483.0, 1320.0], [2745.0, 1320.0], [2745.0, 1353.0], [2483.0, 1353.0]], [[2476.0, 1354.0], [2745.0, 1354.0], [2745.0, 1399.0], [2476.0, 1399.0]], [[2426.0, 1404.0], [2825.0, 1404.0], [2825.0, 1449.0], [2426.0, 1449.0]], [[2518.0, 1447.0], [2718.0, 1447.0], [2718.0, 1491.0], [2518.0, 1491.0]]], "lines": ["女は果たして、", "名越の元カノなのか？", "鏡の玉子に引きこもる", "おソートパイでこんなホームレスの正体は？", "異形の深奥に踏み込んでめく。", "名越の命運は？"]}, {"box": [2372, 1523, 2998, 1561], "vertical": false, "font_size": 38, "lines_coords": [[[2372.0, 1523.0], [2998.0, 1523.0], [2998.0, 1561.0], [2372.0, 1561.0]]], "lines": ["部超！！コミックス１〜１４集発売中！！"]}], "img_path": "002.png"}, {"version": "0.1.7", "img_width": 3937, "img_height": 1600, "blocks": [{"box": [149, 192, 588, 280], "vertical": false, "font_size": 80, "lines_coords": [[[149.0, 200.0], [588.0, 192.0], [588.0, 273.0], [149.0, 280.0]]], "lines": ["ホムンクルス"]}, {"box": [1605, 70, 1725, 295], "vertical": true, "font_size": 120, "lines_coords": [[[1605.0, 70.0], [1725.0, 70.0], [1725.0, 295.0], [1605.0, 295.0]]], "lines": ["ＲＴＣＳＩＮＥＴＵＳＣＯＮＴの"]}, {"box": [280, 338, 457