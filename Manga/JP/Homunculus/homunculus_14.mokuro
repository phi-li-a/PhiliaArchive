 [3694.0, 1013.0], [3329.0, 1013.0]], [[3333.0, 1017.0], [3567.0, 1017.0], [3567.0, 1036.0], [3333.0, 1036.0]], [[3337.0, 1048.0], [3721.0, 1048.0], [3721.0, 1067.0], [3337.0, 1067.0]], [[3329.0, 1071.0], [3790.0, 1071.0], [3790.0, 1102.0], [3329.0, 1102.0]], [[3329.0, 1098.0], [3790.0, 1098.0], [3790.0, 1128.0], [3329.0, 1128.0]], [[3333.0, 1132.0], [3790.0, 1132.0], [3790.0, 1152.0], [3333.0, 1152.0]], [[3325.0, 1155.0], [3794.0, 1155.0], [3794.0, 1186.0], [3325.0, 1186.0]], [[3329.0, 1182.0], [3794.0, 1182.0], [3794.0, 1213.0], [3329.0, 1213.0]], [[3729.0, 1213.0], [3794.0, 1213.0], [3794.0, 1244.0], [3729.0, 1244.0]], [[3329.0, 1213.0], [3721.0, 1213.0], [3721.0, 1244.0], [3329.0, 1244.0]], [[3321.0, 1236.0], [3802.0, 1232.0], [3802.0, 1275.0], [3321.0, 1278.0]], [[3325.0, 1267.0], [3798.0, 1267.0], [3798.0, 1309.0], [3325.0, 1309.0]], [[3329.0, 1301.0], [3794.0, 1301.0], [3794.0, 1332.0], [3329.0, 1332.0]]], "lines": ["エスピリッツコミックス好評発売中／", "ＹＡＷＡＲＡ！（浦沢直樹）へん．．．でもない．．．．．．", "Ｈａｃｋｍ．．．１Ｈａｐｐｙ！（浦沢直樹）．．．！？４４「ルール」の．．．．．．．．", "２０１８年１０月２０世紀少年（浦沢直樹）．．．．．．．．．．．", "２１世紀少年（浦沢直樹）．．．大雑マイモの．．．．．．．．", "２．世紀少年、浦沢県樹）．．．奈緒子（坂田信弘・中原裕）・ギャラルーファイル・．．．．．．．．！！！", "お前．．．ギャラリーフェイク具体ヒ平然ふーん。〈細野不二彦〉．．．全２巻く", "キャンプーンエイン（前島の最終兵器彼女（高橋しん）．．．我「そんなになります。．．．．．．．．", "我が名は海師（小森陽）ロ十ホル／クルーター一武村勇治）．．．全５巻十七十六", "我の日は海側の林物日本沈没（一色登希彦．．．はいやぁっ．．．まいね、小松左京）．．", "バンビ〜ノ！！せきやロッピ～ノ！（せきヤローい．．．Ａ２Ａ！生いてつじ．．．．．．．全５巻", "あ．．．上京アフロ田中（の）つけ雅春）．．．．．．", "エポンションローロックアップ・ポイポーイズ・オン・ザ・ラン（花沢健吾）・サービスの", "赤玉（倉科遼隅口太郎）．．．！！お互い魔術を知りたいのだが、", "前上、着付近の場合、超人ウタダ（山本原人）．．．あなたはここに", "鬼贈院牙子探偵事務所（三上龍哉）・ヒッコｗｉ＋＃＃", "セルフ（朔ユキ蔵）．．．", "ココナッツビリオド〈山田玲司〉．．．", "Ｄの魔王（柳広司・霜月かよ子）．．．．．．全３巻", "オレメヨメ（北崎）のおオレＸヨメ｛北崎拓）．．．！！オルナル．．．", "森山中教習所（真造主伍）．．．いい．．", "私はいつ数自分で美白玉山みんな生きてるコラーゲンの事、マイヤルギーを原克玄〉．．．全１巻", "あんな主さんみんな生きてる使いコンポートあぁ、は、赤先輩．．．主人君。一般一原克女！！全１巻", "全１巻・全！巻", "熱病加速装置（元町夏央あぁ、あ〜んっ、んっ．．．", "熱病の加速装置（元町夏央）にふわり！（死町夏失）．．．！！！それでもよって．．．．．．．．い．．", "おおわ！！ベルトコンベア・ガーミル（手間和書）．．．．．．", "ミル（手原和憲）．．．ん、いいよ。そうだよね．．．いいいっ、いっぱいいのかいい"]}, {"box": [1937, 1023, 2003, 1557], "vertical": true, "font_size": 66, "lines_coords": [[[1937.0, 1023.0], [2003.0, 1023.0], [2003.0, 1557.0], [1937.0, 1557.0]]], "lines": ["うーん．．．"]}, {"box": [3342, 1457, 3774, 1526], "vertical": false, "font_size": 42, "lines_coords": [[[3352.0, 1454.0], [3763.0, 1458.0], [3763.0, 1503.0], [3352.0, 1499.0]], [[3367.0, 1481.0], [3740.0, 1485.0], [3740.0, 1529.0], [3367.0, 1526.0]]], "lines": ["インターネットでビッグミックスが購入できます。ｔｈｔｔｐ：／／／ｐｏｒｔｉｏｎ", "イターネットでビッグエックスの購入できます。１０００円以上のＷｅｂｄｏｗｓは"]}], "img_path": "003.png"}, {"version": "0.1.7", "img_width": 3924, "img_height": 439, "blocks": [{"box": [800, 30, 1847, 425], "vertical": false, "font_size": 75, "lines_coords": [[[1226.0, 28.0], [1636.0, 35.0], [1636.0, 97.0], [1226.0, 89.0]], [[800.0, 104.0], [1548.0, 51.0], [1555.0, 166.0], [808.0, 219.0]], [[804.0, 177.0], [1843.0, 131.0], [1847.0, 261.0], [808.0, 307.0]], [[1651.0, 230.0], [1831.0, 238.0], [1831.0, 303.0], [1651.0, 296.0]], [[808.0, 287.0], [1816.0, 291.0], [1816.0, 357.0], [808.0, 353.0]], [[816.0, 356.0], [1375.0, 356.0], [1375.0, 406.0], [816.0, 406.0]]], "lines": ["にしきき", "驚愕のラストシー", "あ．．．あっ、ああははっ、はぁぁぁあああんんんっ", "佳境へ。", "滋作品中の『トレパネー独共に首加をしたいでションは極めて危険な行為です。", "絶対に真似をしないでください。"]}, {"box": [101, 315, 535, 382], "vertical": false, "font_size": 28, "lines_coords": [[[111.0, 318.0], [517.0, 318.0], [517.0, 349.0], [111.0, 349.0]], [[130.0, 349.0], [486.0, 349.0], [486.0, 379.0], [130.0, 379.0]]], "lines": ["インターネットでビッグコミックスが購入できます。", "ｈｔｔｐ：／ｏｍｉｓ．ｓｈｏｎａｋｉｋａ．ｃｏ！！"]}, {"box": [1939, 26, 1992, 362], "vertical": true, "font_size": 53, "lines_coords": [[[1939.0, 26.0], [1992.0, 26.0], [1992.0, 362.0], [1939.0, 362.0]]], "lines": ["「お前は、"]}, {"box": [2411, 59, 2808, 328], "vertical": false, "font_size": 41, "lines_coords": [[[2529.0, 65.0], [2693.0, 65.0], [2693.0, 109.0], [2529.0, 109.0]], [[2475.0, 107.0], [2747.0, 107.0], [2747.0, 151.0], [2475.0, 151.0]], [[2471.0, 153.0], [2743.0, 153.0], [2743.0, 197.0], [2471.0, 197.0]], [[2471.0, 195.0], [2739.0, 195.0], [2739.0, 239.0], [2471.0, 239.0]], [[2414.0, 237.0], [2808.0, 237.0], [2808.0, 281.0], [2414.0, 281.0]], [[2513.0, 287.0], [2709.0, 287.0], [2709.0, 331.0], [2513.0, 331.0]]], "lines": ["女は果たして、", "名越の元カノなのか？", "鏡の玉子に引きこもる", "ありがとうございます。ホームレスの正体は？", "異形の深奥に踏み込んでみ、", "名越の命運は？"]}, {"box": [2111, 355, 3107, 400], "vertical": false, "font_size": 42, "lines_coords": [[[2111.0, 355.0], [3107.0, 358.0], [3107.0, 400.0], [2111.0, 397.0]]], "lines": ["累計４００万部避！！コミックストーイ４集発売中！！！"]}], "img_path": "004.png"}, {"version": "0.1.7", "img_width": 2411, "img_height": 1600, "blocks": [], "img_path": "005.png"}, {"version": "0.1.7", "img_width": 1000, "img_height": 1600, "blocks": [], "img_path": "006.png"}, {"version": "0.1.7", "img_width": 1099, "img_height": 1600, "blocks": [{"box": [231, 748, 276, 771], "vertical": false, "font_size": 23, "lines_coords": [[[231.0, 748.0], [276.0, 748.0], [276.0, 771.0], [231.0, 771.0]]], "lines": ["ｉｎｃｕｌｕｓ"]}, {"box": [50, 831, 175, 1343], "vertical": true, "font_size": 119, "lines_coords": [[[56.0, 831.0], [175.0, 832.0], [168.0, 1343.0], [50.0, 1342.0]]], "lines": ["ス山本英夫"]}, {"box": [75, 1515, 311, 1543], "vertical": false, "font_size": 18, "lines_coords": [[[81.0, 1519.0], [303.0, 1519.0], [303.0, 1539.0], [81.0, 1539.0]]], "lines": ["ＢＩＧＳＰＲＵＦＳＣＯＮＩＣＳ"]}], "img_path": "007.png"}, {"version": "0.1.7", "img_width": 1094, "img_height": 1600, "blocks": [{"box": [732, 767, 1029, 864], "vertical": false, "font_size": 86, "lines_coords": [[[732.0, 775.0], [815.0, 775.0], [815.0, 851.0], [732.0, 851.0]], [[779.0, 767.0], [1029.0, 767.0], [1029.0, 864.0], [779.0, 864.0]]], "lines": ["第", "第１４条"]}], "img_path": "008.png"}, {"version": "0.1.7", "img_width": 1095, "img_height": 1600, "blocks": [], "img_path": "009.png"}, {"version": "0.1.7", "img_width": 1096, "img_height": 1600, "blocks": [{"box": [292, 484, 314, 584], "vertical": true, "font_size": 22, "lines_coords": [[[292.0, 484.0], [314.0, 484.0], [314.0, 584.0], [292.0, 584.0]]], "lines": ["．．．"]}, {"box": [875, 935, 908, 1012], "vert