alse, "font_size": 45.25, "lines_coords": [[[604.0, 692.0], [696.0, 779.0], [616.0, 862.0], [525.0, 775.0]], [[513.0, 683.0], [726.0, 682.0], [726.0, 705.0], [513.0, 706.0]], [[497.0, 704.0], [692.0, 704.0], [692.0, 719.0], [497.0, 719.0]], [[501.0, 717.0], [709.0, 710.0], [710.0, 738.0], [502.0, 745.0]]], "lines": ["ありがとうございません！！！そのままじゃ！！？そのときはやめてきちゃったのですが．．．？？どうやってるのか？", "そう、今日もそもそろそろ、キャッチですかったですけど、", "．．．もしかしていませんでしたかったのですが、", "それでも、こちらのサポートですから、"]}, {"box": [579, 733, 694, 757], "vertical": false, "font_size": 20, "lines_coords": [[[579.0, 733.0], [694.0, 737.0], [694.0, 757.0], [579.0, 753.0]]], "lines": ["．．．"]}], "img_path": "072.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [], "img_path": "073.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [], "img_path": "074.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [], "img_path": "075.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [606, 94, 661, 170], "vertical": true, "font_size": 55, "lines_coords": [[[606.0, 94.0], [661.0, 94.0], [661.0, 170.0], [606.0, 170.0]]], "lines": ["！！"]}, {"box": [697, 367, 726, 441], "vertical": true, "font_size": 29, "lines_coords": [[[697.0, 367.0], [726.0, 367.0], [726.0, 441.0], [697.0, 441.0]]], "lines": ["な．．．．．"]}, {"box": [657, 523, 725, 620], "vertical": true, "font_size": 21, "lines_coords": [[[704.0, 525.0], [724.0, 525.0], [724.0, 619.0], [704.0, 619.0]], [[679.0, 525.0], [701.0, 525.0], [701.0, 603.0], [679.0, 603.0]], [[657.0, 523.0], [677.0, 523.0], [677.0, 602.0], [657.0, 602.0]]], "lines": ["なぁんて顔", "してんだ", "俺は．．．"]}, {"box": [245, 314, 323, 469], "vertical": true, "font_size": 22, "lines_coords": [[[300.0, 314.0], [321.0, 314.0], [322.0, 458.0], [301.0, 458.0]], [[273.0, 315.0], [294.0, 315.0], [291.0, 450.0], [270.0, 450.0]], [[245.0, 314.0], [268.0, 314.0], [272.0, 469.0], [248.0, 469.0]]], "lines": ["これじゃ、まるで", "ロボットの中の", "少年の顔じゃ．．．"]}, {"bo