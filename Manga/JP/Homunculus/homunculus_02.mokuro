11.0], [115.0, 911.0]], [[112.0, 918.0], [472.0, 919.0], [472.0, 936.0], [112.0, 935.0]], [[113.0, 941.0], [472.0, 942.0], [472.0, 958.0], [113.0, 957.0]], [[370.0, 897.0], [474.0, 897.0], [474.0, 914.0], [370.0, 914.0]]], "lines": ["１４歳（模図かずおー．．．．．．．．", "東京大学物語（江川蓮也〉．．．", "花園メリーゴーランド（柚木ハルコ）．．．全く", "有識ダリーゴーランド（体内）のコールコース・ショップコラには２０１８年７月２５日にナス性を体制していますが、新橋子（仮田保証）・中原船）．．．", "それでもこれからもう少しでも", "奈緒子（坂田信弘・中原裕．．．そうだなぁ。でも", "男樹（本宮ひろ志川．．．．．．．．．", "月下の杖土（能條純一）．．．はぁぁぁっ、はぁ．", "最終兵器彼女（高橋しん）．．．いいじゃないの", "しっぷうどとう（盛田賢司）．．．", "もしかして、ディングルーズは、ステージによっては、結構フォーマー（１１０月前までにお願いしてます。お客さんのコミュニケーションのコーストリートになるということです。２００１０００２０１２０３０１年以上でするの３００年以外に、２０８０１５００分以前にありましました。", "ティーンズプルース（コーツ〈城倉〉《．．．》", "タッ", "３３６３２", "疾風迅雷（もりやまつる）．．．．．．", "全３全", "サユリ１号（村上かつらい．．．", "全！！", "ＧＯＧＯ－生活非安全課（ロドリゲス井之介）．．．全５", "タ．．．", "ナイトクレイバー竜一（稲光伸二）：．．．．．．．．全４", "マリオガン（木葉城）．．．そうですか", "猿ＭＯＮＥＹ（木村清輝・脚本ノ兜公司．．．．．．！〜２集", "プロファイリングゲ師朕集院犬清（石井達哉．．．１〜２隻", "．．．．．．！！"]}, {"box": [119, 1082, 472, 1126], "vertical": false, "font_size": 16, "lines_coords": [[[134.0, 1083.0], [448.0, 1085.0], [448.0, 1101.0], [134.0, 1100.0]], [[119.0, 1107.0], [466.0, 1107.0], [466.0, 1123.0], [119.0, 1123.0]]], "lines": ["インターネットでビッグコミックスが購入できます。", "わたしの．．．いいのかなｈｉｃｐｏｒｎｉｃｓ．ｓｔＯＳＰＸＵＫａｎ．ｃｏ．"]}], "img_path": "004.png"}, {"version": "0.1.7", "img_width": 1769, "img_height": 1200, "blocks": [], "img_path": "005.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [], "img_path": "006.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [144, 547, 213, 567], "vertical": false, "font_size": 20, "lines_coords": [[[144.0, 547.0], [213.0, 547.0], [213.0, 567.0], [144.0, 567.0]]], "lines": ["Ｈｏｍｕｎｏｌｌｕｓ"]}, {"box": [32, 637, 130, 996], "vertical": true, "font_size": 94, "lines_coords": [[[36.0, 637.0], [130.0, 638.0], [126.0, 996.0], [32.0, 994.0]]], "lines": ["〈山本英夫"]}, {"box": [52, 1123, 231, 1145], "vertical": false, "font_size": 14, "lines_coords": [[[57.0, 1126.0], [226.0, 1126.0], [226.0, 1142.0], [57.0, 114