.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [685, 476, 731, 573], "vertical": true, "font_size": 21, "lines_coords": [[[711.0, 479.0], [731.0, 479.0], [731.0, 573.0], [711.0, 573.0]], [[685.0, 478.0], [706.0, 476.0], [709.0, 537.0], [688.0, 539.0]]], "lines": ["バカらしい", "だろ？"]}, {"box": [555, 796, 581, 849], "vertical": true, "font_size": 26, "lines_coords": [[[555.0, 796.0], [581.0, 796.0], [581.0, 849.0], [555.0, 849.0]]], "lines": ["ええ。"]}, {"box": [335, 791, 474, 932], "vertical": true, "font_size": 20, "lines_coords": [[[454.0, 793.0], [474.0, 793.0], [474.0, 869.0], [454.0, 869.0]], [[430.0, 792.0], [450.0, 792.0], [450.0, 929.0], [430.0, 929.0]], [[404.0, 791.0], [425.0, 791.0], [426.0, 871.0], [405.0, 871.0]], [[382.0, 792.0], [402.0, 792.0], [402.0, 926.0], [382.0, 926.0]], [[357.0, 791.0], [377.0, 791.0], [377.0, 904.0], [357.0, 904.0]], [[335.0, 793.0], [351.0, 793.0], [351.0, 905.0], [335.0, 905.0]]], "lines": ["おまえの", "実験のおかげで、", "俺の頭は", "おかしくなっち", "まったんじゃ", "ないのか．．．？"]}, {"box": [227, 795, 249, 844], "vertical": true, "font_size": 22, "lines_coords": [[[227.0, 795.0], [249.0, 795.0], [249.0, 844.0], [227.0, 844.0]]], "lines": ["ええ、"]}, {"box": [164, 796, 185, 844], "vertical": true, "font_size": 22, "lines_coords": [[[164.0, 796.0], [185.0, 796.0], [185.0, 844.0], [164.0, 844.0]]], "lines": ["ええ。"]}], "img_path": "029.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [569, 28, 614, 150], "vertical": true, "font_size": 18, "lines_coords": [[[592.0, 28.0], [613.0, 28.0], [614.0, 116.0], [593.0, 116.0]], [[569.0, 28.0], [589.0, 28.0], [589.0, 150.0], [569.0, 150.0]]], "lines": ["ええ、ええ", "じゃなくてよ、"]}, {"box": [422, 154, 534, 350], "vertical": true, "font_size": 18, "lines_coords": [[[518.0, 159.0], [534.0, 159.0], [534.0, 310.0], [518.0, 310.0]], [[493.0, 159.0], [509.0, 159.0], [509.0, 315.0], [493.0, 315.0]], [[470.0, 157.0], [486.0, 157.0], [486.0, 234.0], [470.0, 234.0]], [[441.0, 154.0], [465.0, 154.0], [466.0, 350.0], [443.0, 350.0]], [[422.0, 159.0], [438.0, 159.0], [438.0, 292.0], [422.0, 292.0]]], "lines": ["俺は片目を閉じて", "左目で見たとたん、", "幻覚でも", "見ちまってるのかって", "聞いてんだよ！"]}, {"box": [227, 51, 300, 185], "vertical": true, "font_size": 22, "lines_coords": [[[275.0, 51.0], [300.0, 51.0], [300.0, 113.0], [275.0, 113.0]], [[253.0, 53.0], [274.0, 53.0], [274.0, 132.0], [253.0, 132.0]], [[229.0, 52.0], [249.0, 52.0], [247.0, 180.0], [227.0, 180.0]]], "lines": ["ちょ．．．", "ちょっと", "待ってください"]}, {"box": [667, 401, 735, 536], "vertical": true, "font_size": 21, "lines_coords": [[[713.0, 401.0], [735.0, 401.0], [735.0, 479.0], [713.0, 479.0]], [[692.0, 403.0], [712.0, 403.0], [712.0, 536.0], [692.0, 536.0]], [[667.0, 401.0], [687.0, 401.0], [687.0, 482.0], [667.0, 482.0]]], "lines": ["もう少し", "詳しく聞かせて", "ください"]}, {"box": [210, 412, 227, 475], "vertical": true, "font_size": 17, "lines_coords": [[[210.0, 412.0], [227.0, 412.0], [227.0, 475.0], [210.0, 475.0]]], "lines": ["．．．．．．？"]}, {"box": [316, 689, 411, 785], "vertical": true, "font_size": 20, "lines_coords": [[[386.0, 689.0], [411.0, 689.0], [411.0, 753.0], [386.0, 753.0]], [[366.0, 691.0], [383.0, 691.0], [383.0, 785.0], [366.0, 785.0]], [[339.0, 689.0], [359.0, 689.0], [359.0, 767.0], [339.0, 767.0]], [[316.0, 691.0], [336.0, 691.0], [336.0, 767.0], [316.0, 767.0]]], "lines": ["オマエ、", "そんなもん", "信じてる", "のか．．．？"]}, {"box": [488, 1018, 531, 1088], "vertical": true, "font_size": 43, "lines_coords": [[[488.0, 1018.0], [531.0, 1018.0], [531.0, 1088.0], [488.0, 1088.0]]], "lines": ["パサ"]}, {"box": [236, 855, 259, 971], "vertical": true, "font_size": 20, "lines_coords": [[[236.0, 855.0], [256.0, 855.0], [259.0, 970.0], [239.0, 970.0]]], "lines": ["名越さん．．．．．"]}, {"box": [92, 871, 145, 957], "vertical": true, "font_size": 36, "lines_coords": [[[92.0, 880.0], [127.0, 871.0], [145.0, 949.0], [110.0, 957.0]]], "lines": ["カチャ"]}], "img_path": "030.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [626, 17, 737, 159], "vertical": true, "font_size": 24, "lines_coords": [[[712.0, 21.0], [737.0, 21.0], [737.0, 93.0], [712.0, 93.0]], [[685.0, 21.0], [705.0, 21.0], [705.0, 137.0], [685.0, 137.0]], [[656.0, 21.0], [677.0, 21.0], [678.0, 159.0], [657.0, 159.0]], [[626.0, 17.0], [655.0, 17.0], [655.0, 59.0], [626.0, 59.0]]], "lines": ["信じる", "ところから", "始めましょう", "よ。"]}, {"box": [262, 409, 279, 482], "vertical": true, "font_size": 17, "lines_coords": [[[262.0, 409.0], [279.0, 409.0], [279.0, 482.0], [262.0, 482.0]]], "lines": ["．．．．．．"]}, {"box": [603, 592, 723, 746], "vertical": true, "font_size": 20, "lines_coords": [[[702.0, 592.0], [723.0, 592.0], [721.0, 718.0], [699.0, 718.0]], [[677.0, 594.0], [697.0, 594.0], [697.0, 746.0], [677.0, 746.0]], [[654.0, 594.0], [674.0, 594.0], [674.0, 727.0], [654.0, 727.0]], [[629.0, 594.0], [649.0, 594.0], [649.0, 708.0], [629.0, 708.0]], [[606.0, 594.0], [626.0, 594.0], [623.0, 689.0], [603.0, 689.0]]], "lines": ["：で、具体的に", "接触した化け物は", "このロボット．．", "ヤクザの組長", "ですよね？"]}, {"box": [400, 583, 471, 686], "vertical": true, "font_size": 22, "lines_coords": [[[451.0, 587.0], [471.0, 587.0], [471.0, 682.0], [451.0, 682.0]], [[422.0, 583.0], [451.0, 583.0], [451.0, 649.0], [422.0, 649.0]], [[400.0, 585.0], [422.0, 585.0], [423.0, 686.0], [402.0, 686.0]]], "lines": ["ロボットの", "中には", "子供がいて、"]}, {"box": [264, 584, 356, 758], "vertical": true, "font_size": 22, "lines_coords": [[[336.0, 585.0], [356.0, 585.0], [356.0, 682.0], [336.0, 682.0]], [[310.0, 584.0], [331.0, 584.0], [332.0, 703.0], [311.0, 703.0]], [[287.0, 587.0], [307.0, 587.0], [307.0, 758.0], [287.0, 758.0]], [[264.0, 585.0], [284.0, 585.0], [284.0, 727.0], [264.0, 727.0]]], "lines": ["傷だらけの", "自分の小指を", "カマみたいなもんで", "切ろうとしてた。"]}, {"box": [97, 605, 169, 723], "vertical": true, "font_size": 21, "lines_coords": [[[143.0, 605.0], [169.0, 605.0], [169.0, 651.0], [143.0, 651.0]], [[124.0, 610.0], [140.0, 610.0], [140.0, 705.0], [124.0, 705.0]], [[97.0, 607.0], [117.0, 607.0], [117.0, 723.0], [97.0, 7