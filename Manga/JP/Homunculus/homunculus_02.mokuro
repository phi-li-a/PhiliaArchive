.0]]], "lines": ["ごめんね", "．．．"]}, {"box": [517, 578, 562, 656], "vertical": true, "font_size": 21, "lines_coords": [[[540.0, 578.0], [561.0, 578.0], [561.0, 656.0], [540.0, 656.0]], [[517.0, 578.0], [538.0, 578.0], [538.0, 656.0], [517.0, 656.0]]], "lines": ["ご．．．め．．．", "んね．．．"]}], "img_path": "192.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [369, 166, 458, 610], "vertical": true, "font_size": 85, "lines_coords": [[[373.0, 171.0], [458.0, 172.0], [453.0, 610.0], [369.0, 609.0]]], "lines": ["ごめんね．．．："]}], "img_path": "193.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [], "img_path": "194.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [], "img_path": "195.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [46, 577, 440, 629], "vertical": false, "font_size": 48, "lines_coords": [[[46.0, 577.0], [440.0, 581.0], [440.0, 629.0], [46.0, 625.0]]], "lines": ["［ホムンクルス］第２集：完"]}, {"box": [42, 1082, 616, 1153], "vertical": false, "font_size": 15, "lines_coords": [[[48.0, 1084.0], [610.0, 1084.0], [610.0, 1100.0], [48.0, 1100.0]], [[45.0, 1099.0], [585.0, 1100.0], [585.0, 1117.0], [45.0, 1116.0]], [[48.0, 1118.0], [544.0, 1118.0], [544.0, 1134.0], [48.0, 1134.0]], [[45.0, 1131.0], [450.0, 1133.0], [450.0, 1153.0], [45.0, 1151.0]]], "lines": ["●作品中のトレパネーションはは極めて危険な行為です。絶対に真似をしないでください。", "Ｗｉｎｄｏｒｄの中にの作品はフィクションまっ、はあっ、んぁ．．．ですのです。実在する人物、団体・事件第三者とは一切関係ありません。", "●「週刊ビッグコミックスビリッツ！２０１３年２７号、３１３３号、５１４号掲載作品。", "あの週１９レンジョミンスピックの更新ホムンクルスリム式ホームページ２０１５年２月、マーニングへの一ジャージョージーカーホテル／Ｗｉｎｄｏｗｓの"]}], "img_path": "196.png"}, {"version": "0.1.7", "img_width": 1703, "img_height": 1200, "blocks": [{"box": [1137, 218, 1192, 374], "vertical": true, "font_size": 55, "lines_coords": [[[1137.0, 226.0], [1192.0, 226.0], [1192.0, 307.0], [1137.0, 307.0]]], "lines": ["スー"]}, {"box": [1613, 253, 1659, 408], "vertical": true, "font_size": 46, "lines_coords": [[[1613.0, 253.0], [1659.0, 253.0], [1659.0, 408.0], [1613.0, 408.0]]], "lines": ["スー"]}, {"box": [28, 1067, 1703, 1206], "vertical": false, "font_size": 74.5, "lines_coords": [[[937.0, 1067.0], [1699.0, 1067.0], [1699.0, 1105.0], [937.0, 1105.0]], [[28.0, 1095.0], [1703.0, 1095.0], [1703.0, 1206.0], [28.0, 1206.0]]], "lines": ["「週刊ビッグコミックスビリッツ］にて衝撃連載中！！", "次巻はムンクルス第３集は、２００４年７月３０日発売予定！！"]}, {"box": [778, 355, 827, 525], "vertical": true, "font_size": 49, "lines_coords": [[[778.0, 355.0], [827.0, 355.0], [827.0, 525.0], [778.0, 525.0]]], "lines": ["スー"]}, {"box": [197, 115, 555, 905], "vertical": true, "font_size": 94, "lines_coords": [[[475.0, 132.0], [555.0, 132.0], [555.0, 536.0], [475.0, 536.0]], [[342.0, 157.0], [439.0, 157.0], [439.0, 726.0], [342.0, 726.0]], [[202.0, 126.0], [307.0, 124.0], [314.0, 614.0], [209.0, 616.0]]], "lines": ["明らかになる", "ホムンクルスの意味", "そして、名越は"]}, {"box": [76, 114, 194, 992], "vertical": true, "font_size": 118, "lines_coords": [[[76.0, 114.0], [194.0, 114.0], [194.0, 992.0], [76.0, 992.0]]], "lines": ["警愕の事実に直面する．．．"]}], "img_path": "197.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [107, 278, 415, 312], "vertical": false, "font_size": 32, "lines_coords": [[[107.0, 281.0], [415.0, 278.0], [415.0, 310.0], [107.0, 312.0]]], "lines": ["ヤクザ漫画の金字塔！！"]}, {"box": [70, 325, 417, 602], "vertical": false, "font_size": 32, "lines_coords": [[[247.0, 325.0], [413.0, 328.0], [413.0, 348.0], [247.0, 345.0]], [[284.0, 417.0], [411.0, 417.0], [411.0, 450.0], [284.0, 450.0]], [[253.0, 455.0], [413.0, 455.0], [413.0, 471.0], [253.0, 471.0]], [[198.0, 468.0], [417.0, 473.0], [417.0, 496.0], [198.0, 492.0]], [[70.0, 331.0], [412.0, 331.0], [412.0, 434.0], [70.0, 434.0]], [[198.0, 526.0], [417.0, 526.0], [417.0, 549.0], [198.0, 549.0]], [[123.0, 496.0], [415.0, 498.0], [415.0, 522.0], [123.0, 521.0]], [[161.0, 551.0], [417.0, 553.0], [417.0, 576.0], [161.0, 575.0]], [[158.0, 580.0], [416.0, 580.0], [416.0, 600.0], [158.0, 600.0]]], "lines": ["ヤングサンデーコミックス", "詳しくは", "１巻：定価：５１０円（税込", "２〜１０巻：定価：各５３０円（税込）", "「殺し屋１－１ヶ", "無敵のマゾヤクザ・垣原の", "いじめられっ子の殺し屋１〈イチ〉と", "アドレナリン全開の殺し合い！！", "他にはない変態とミイオンシス！！"]}, {"box": [456, 840, 746, 875], "vertical": false, "font_size": 32, "lines_coords": [[[456.0, 840.0], [746.0, 843.0], [746.0, 875.0], [456.0, 871.0]]], "lines": ["探偵漫画の金字塔！！"]}, {"box": [132, 1074, 369, 1127], "vertical": false, "font_size": 13, "lines_coords": [[[134.0, 1073.0], [363.0, 1073.0], [363.0, 1089.0], [134.0, 1089.0]], [[134.0, 1086.0], [246.0, 1086.0], [246.0, 1102.0], [134.0, 1102.0]], [[138.0, 1100.0], [263.0, 1100.0], [263.0, 1112.0], [138.0, 1112.0]], [[134.0, 1111.0], [264.0, 1111.0], [264.0, 1127.0], [134.0, 1127.0]]], "lines": ["私たちの話を聞いていただきましたが、それで、これまではないのですが、", "そういえば、", "そういうことですが、これまでの", "それでも、これからの"]}, {"box": [398, 1013, 427, 1109], "vertical": true, "font_size": 29, "lines_coords": [[[398.0, 1013.0], [427.0, 1013.0], [427.0, 1109.0], [398.0, 1109.0]]], "lines": ["本英は"]}, {"box": [404, 1103, 424, 1120], "vertical": false, "font_size": 17, "lines_coords": [[[404.0, 1103.0], [424.0, 1103.0], [424.0, 1120.0], [404.0, 1120.0]]], "lines": ["夫"]}, {"box": [454, 880, 806, 1147], "vertical": false, "font_size": 30, "lines_coords": [[[458.0, 891.0], [677.0, 891.0], [677.0, 911.0], [458.0, 911.0]], [[466.0, 896.0], [650.0, 903.0], [647.0, 982.0], [463.0, 975.0]], [[477.0, 987.0], [563.0, 979.0], [567.0, 1010.0], [480.0, 1018.0]], [[459.0, 1021.0], [600.0, 1021.0], [600.0, 1038.0], [459.0, 1038.0]], [[599.0, 936.0], [697.0, 936.0], [697.0, 975.0], [599.0, 975.0]], [[456.0, 1044.0], [776.0, 1044.0], [776.0, 1067.0], [456.0, 1067.0]], [[454.0, 1073.0], [672.0, 1073.0], [672.0, 1093.0], [454.0, 1093.0]], [[458.0, 1101.0], [730.0, 1101.0], [730.0, 1117.0], [458.0, 1117.0]], [[681.0, 929.0], [803.0, 919.0], [806.0, 958.0], [684.0, 967.0]], [[457.0, 1126.0], [739.0, 1126.0], [739.0, 1146.0], [457.0, 1146.0]]], "lines": ["ヤングサンテー・コミックスワイド版", "のぞき", "．．", "定価：各９８０円（税込", "１０", "義眼の探偵・見〈ケシンが世界をのぞく！！", "大ヒット作［新・のぞき屋と", "その原占のぞ手屋え完全には", "完全版", "見の義眼が、人間の暗闇をえぐる！"]}], "img_path": "198.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [37, 44, 87, 62], "vertical": false, "font_size": 18, "lines_coords": [[[37.0, 44.0], [87.0, 44.0], [87.0, 62.0], [37.0, 62.0]]], "lines": ["小学館"]}, {"box": [114, 28, 264, 382], "vertical": true, "font_size": 132, "lines_coords": [[[133.0, 28.0], [264.0, 35.0], [246.0, 382.0], [114.0, 375.0]]], "lines": ["絶対無"]}, {"box": [526, 76, 598, 405], "vertical": true, "font_size": 32, "lines_coords": [[[565.0, 78.0], [596.0, 78.0], [596.0, 405.0], [565.0, 405.0]], [[528.0, 76.0], [560.0, 76.0], [558.0, 266.0], [526.0, 266.0]]], "lines": ["【殺し屋１ーイテー］の原点！！？", "喧嘩中毒上等！！"]}, {"box": [0, 236, 314, 957], "vertical": true, "font_size": 313, "lines_coords": [[[0.0, 264.0], [311.0, 263.0], [314.0, 956.0], [0.0, 957.0]]], "lines": ["無二の世界を描く山本英夫の単行な"]}, {"box": [272, 482, 419, 498], "vertical": false, "font_size": 16, "lines_coords": [[[272.0, 482.0], [419.0, 482.0], [419.0, 498.0], [272.0, 498.0]]], "lines": ["ヤングサンデーコミックス"]}, {"box": [269, 536, 383, 560], "vertical": false, "font_size": 20, "lines_coords": [[[269.0, 536.0], [383.0, 540.0], [383.0, 560.0], [269.0, 556.0]]], "lines": ["定価：５０９円（税込）"]}, {"box": [461, 453, 498, 461], "vertical": false, "font_size": 8, "lines_coords": [[[461.0, 453.0], [498.0, 453.0], [498.0, 461.0], [461.0, 461.0]]], "lines": ["．．"]}, {"box": [449, 502, 595, 542], "vertical": false, "font_size": 38, "lines_coords": [[[449.0, 505.0], [595.0, 502.0], [595.0, 540.0], [449.0, 542.0]]], "lines": ["『全１巻"]}, {"box": [511, 414, 797, 476], "vertical": false, "font_size": 16.0, "lines_coords": [[[519.0, 414.0], [762.0, 414.0], [762.0, 430.0], [519.0, 430.0]], [[511.0, 437.0], [726.0, 437.0], [726.0, 453.0], [511.0, 453.0]], [[517.0, 460.0], [797.0, 460.0], [797.0, 476.0], [517.0, 476.0]]], "lines": ["弱虫！泣き虫の１〈イチ〉が目覚める！！", "最強番長・大くダインに触発され", "高校時代の１くイチン、暴力ジャンキーへ！！"]}, {"box": [465, 592, 528, 822], "vertical": true, "font_size": 28, "lines_coords": [[[498.0, 592.0], [526.0, 592.0], [526.0, 822.0], [498.0, 822.0]], [[465.0, 594.0], [493.0, 594.0], [493.0, 775.0], [465.0, 775.0]]], "lines": ["山本英天の原点！！", "異色ラブコメ！！"]}, {"box": [237, 868, 536, 887], "vertical": false, "font_size": 18, "lines_coords": [[[237.0, 868.0], [536.0, 869.0], [536.0, 887.0], [237.0, 885.0]]], "lines": ["セーラー服装の自分自身〈お〉に恋をした！！"]}, {"box": [273, 892, 538, 933], "vertical": false, "font_size": 16.0, "lines_coords": [[[273.0, 892.0], [535.0, 894.0], [535.0, 910.0], [273.0, 909.0]], [[282.0, 917.0], [538.0, 917.0], [538.0, 933.0], [282.0, 933.0]]], "lines": ["その自分のとっくりさん〈♀〉に恋をした！！", "．．．！Ｌｏｖｅオンな痛快ラブ・コメディ！！！"]}, {"box": [35, 1130, 575, 1189], "vertical": false, "font_size": 18.0, "lines_coords": [[[36.0, 1130.0], [575.0, 1135.0], [575.0, 1154.0], [36.0, 1149.0]], [[51.0, 1149.0], [416.0, 1154.0], [416.0, 1173.0], [51.0, 1168.0]], [[35.0, 1171.0], [430.0, 1174.0], [430.0, 1189.0], [35.0, 1187.0]]], "lines": ["◎書店でご希望の単行本が見つからない場合は、お手数ですが店頭でご注文下さい。", "あたしこのエンテリアのまた、インターネットでも購入できましたが、すーｈｔｔｐ：／／ｓｐｉ－ｎｅｔ．ｊｐ", "●お問い合わせ先お客様相談とターＴＥＬＬＯＢ－５２８１－３５６"]}, {"box": [391, 933, 784, 1019], "vertical": false, "font_size": 32.333333333333336, "lines_coords": [[[578.0, 933.0], [780.0, 937.0], [780.0, 960.0], [578.0, 957.0]], [[439.0, 950.0], [784.0, 950.0], [784.0, 1003.0], [439.0, 1003.0]], [[391.0, 996.0], [779.0, 999.0], [779.0, 1019.0], [391.0, 1016.0]]], "lines": ["ヤングサンデーコミックスワイド版", "「お力マ白書」全５巻", "１〜３巻：定価：各９９９円（税込・４－５巻・定備・各１００円（税込）"]}], "img_path": "199.png"}, {"version": "0.1.7", "img_width": 850, "img_height": 1200, "blocks": [{"box": [137, 137, 411, 172], "vertical": false, "font_size": 32, "lines_coords": [[[137.0, 137.0], [411.0, 139.0], [411.0, 172.0], [137.0, 169.0]]], "lines": ["ホムンクルス区"]}, {"box": [187, 191, 352, 214], "vertical": false, "font_size": 23, "lines_coords": [[[187.0, 191.0], [352.0, 191.0], [352.0, 214.0], [187.0, 214.0]]], "lines": ["ビッグコミックス"]}, {"box": [180, 578, 248, 608], "vertical": false, "font_size": 25, "