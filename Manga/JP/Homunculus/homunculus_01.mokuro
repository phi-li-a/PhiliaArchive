0.0], [696.0, 660.0]], [[668.0, 475.0], [692.0, 475.0], [692.0, 557.0], [668.0, 557.0]], [[641.0, 474.0], [667.0, 474.0], [664.0, 638.0], [638.0, 638.0]], [[612.0, 475.0], [636.0, 475.0], [634.0, 594.0], [609.0, 594.0]]], "lines": ["いやいや、", "「頭蓋骨に穴」とか", "言うと、", "ちょっとひくと", "思いますが"]}, {"box": [677, 788, 749, 923], "vertical": true, "font_size": 22, "lines_coords": [[[728.0, 788.0], [749.0, 788.0], [749.0, 868.0], [728.0, 868.0]], [[702.0, 788.0], [722.0, 788.0], [725.0, 923.0], [705.0, 923.0]], [[677.0, 788.0], [702.0, 788.0], [702.0, 856.0], [677.0, 856.0]]], "lines": ["脳ミソを", "いじるワケでも", "ないし、"]}, {"box": [32, 547, 148, 731], "vertical": true, "font_size": 26, "lines_coords": [[[119.0, 547.0], [148.0, 547.0], [148.0, 623.0], [119.0, 623.0]], [[91.0, 549.0], [116.0, 549.0], [119.0, 731.0], [94.0, 731.0]], [[62.0, 548.0], [86.0, 548.0], [89.0, 671.0], [64.0, 671.0]], [[32.0, 549.0], [58.0, 549.0], [60.0, 644.0], [35.0, 644.0]]], "lines": ["そんな", "たいしたことじゃ", "ないんです、", "マジで！"]}, {"box": [250, 799, 303, 949], "vertical": true, "font_size": 24, "lines_coords": [[[277.0, 799.0], [302.0, 799.0], [302.0, 949.0], [277.0, 949.0]], [[250.0, 800.0], [272.0, 800.0], [272.0, 900.0], [250.0, 900.0]]], "lines": ["ただ、骨を削る", "だけです。"]}, {"box": [37, 799, 150, 937], "vertical": true, "font_size": 23, "lines_coords": [[[125.0, 800.0], [148.0, 800.0], [148.0, 924.0], [125.0, 924.0]], [[93.0, 799.0], [117.0, 799.0], [117.0, 937.0], [93.0, 937.0]], [[66.0, 799.0], [89.0, 799.0], [89.0, 915.0], [66.0, 915.0]], [[37.0, 799.0], [58.0, 799.0], [58.0, 898.0], [37.0, 898.0]]], "lines": ["ぶっちゃけ、", "歯を削るのと", "同じような", "ものです"]}, {"box": [635, 975, 730, 1157], "vertical": true, "font_size": 20, "lines_coords": [[[705.0, 978.0], [725.0, 978.0], [725.0, 1150.0], [705.0, 1150.0]], [[680.0, 975.0], [703.0, 975.0], [704.0, 1156.0], [681.0, 1156.0]], [[656.0, 975.0], [676.0, 975.0], [677.0, 1150.0], [657.0, 1150.0]], [[635.0, 977.0], [651.0, 977.0], [651.0, 1078.0], [635.0, 1078.0]]], "lines": ["脳を覆ってる膜にも", "キズをつけないので、", "ミソが漏れる心配も", "ありません。"]}], "img_path": "067.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [588, 43, 661, 142], "vertical": true, "font_size": 22, "lines_coords": [[[636.0, 43.0], [661.0, 43.0], [658.0, 126.0], [634.0, 126.0]], [[613.0, 46.0], [633.0, 46.0], [633.0, 142.0], [613.0, 142.0]], [[588.0, 45.0], [608.0, 45.0], [608.0, 131.0], [588.0, 131.0]]], "lines": ["ちゃんと", "読んでみて", "ください。"]}, {"box": [370, 71, 440, 187], "vertical": true, "font_size": 19, "lines_coords": [[[419.0, 71.0], [439.0, 71.0], [439.0, 187.0], [419.0, 187.0]], [[396.0, 72.0], [413.0, 72.0], [412.0, 183.0], [395.0, 183.0]], [[370.0, 71.0], [391.0, 71.0], [391.0, 155.0], [370.0, 155.0]]], "lines": ["皮膚を通して", "骨を削るワケ", "ですから、"]}, {"box": [94, 73, 139, 189], "vertical": true, "font_size": 20, "lines_coords": [[[118.0, 75.0], [138.0, 75.0], [138.0, 189.0], [118.0, 189.0]], [[94.0, 73.0], [114.0, 73.0], [114.0, 174.0], [94.0, 174.0]]], "lines": ["多少の出血は", "伴いますが、"]}, {"box": [522, 378, 543, 467], "vertical": true, "font_size": 20, "lines_coords": [[[522.0, 378.0], [542.0, 378.0], [542.0, 467.0], [522.0, 467.0]]], "lines": ["アホか．．．"]}, {"box": [394, 271, 438, 405], "vertical": true, "font_size": 18, "lines_coords": [[[417.0, 271.0], [437.0, 271.0], [437.0, 405.0], [417.0, 405.0]], [[395.0, 274.0], [411.0, 274.0], [411.0, 390.0], [395.0, 390.0]]], "lines": ["麻酔をするので", "痛みはないし"]}, {"box": [92, 280, 159, 394], "vertical": true, "font_size": 18, "lines_coords": [[[138.0, 280.0], [159.0, 280.0], [159.0, 358.0], [138.0, 358.0]], [[116.0, 282.0], [132.0, 282.0], [132.0, 375.0], [116.0, 375.0]], [[92.0, 280.0], [109.0, 280.0], [109.0, 393.0], [92.0, 393.0]]], "lines": ["もちろん", "命に別状は", "ありません！"]}, {"box": [637, 720, 722, 922], "vertical": true, "font_size": 28, "lines_coords": [[[691.0, 721.0], [722.0, 721.0], [722.0, 794.0], [691.0, 794.0]], [[665.0, 720.0], [694.0, 720.0], [694.0, 922.0], [665.0, 922.0]], [[637.0, 721.0], [662.0, 721.0], [662.0, 825.0], [637.0, 825.0]]], "lines": ["これは", "「トレパネーション」", "と言って、"]}, {"box": [104, 548, 188, 733], "vertical": true, "font_size": 24, "lines_coords": [[[164.0, 550.0], [188.0, 550.0], [188.0, 643.0], [164.0, 643.0]], [[133.0, 548.0], [158.0, 548.0], [160.0, 733.0], [136.0, 733.0]], [[104.0, 549.0], [128.0, 549.0], [131.0, 719.0], [106.0, 719.0]]], "lines": ["海外では", "何人もやっている", "安全な手術です。"]}], "img_path": "068.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [515, 32, 610, 219], "vertical": true, "font_size": 24, "lines_coords": [[[589.0, 35.0], [609.0, 35.0], [609.0, 137.0], [589.0, 137.0]], [[563.0, 32.0], [587.0, 32.0], [587.0, 217.0], [563.0, 217.0]], [[536.0, 32.0], [566.0, 32.0], [566.0, 105.0], [536.0, 105.0]], [[515.0, 36.0], [539.0, 36.0], [539.0, 219.0], [515.0, 219.0]]], "lines": ["おまえなあ、", "そんなくるったこと", "やって、", "一体何になるんだ？"]}, {"box": [49, 49, 99, 130], "vertical": true, "font_size": 26, "lines_coords": [[[76.0, 53.0], [98.0, 53.0], [99.0, 130.0], [77.0, 130.0]], [[49.0, 49.0], [80.0, 49.0], [80.0, 100.0], [49.0, 100.0]]], "lines": ["いい質問", "です。"]}, {"box": [26, 253, 83, 368], "vertical": true, "font_size": 26, "lines_coords": [[[60.0, 255.0], [80.0, 255.0], [80.0, 367.0], [60.0, 367.0]], [[26.0, 253.0], [57.0, 253.0], [57.0, 326.0], [26.0, 326.0]]], "lines": ["最高の質問", "です！"]}, {"box": [91, 916, 226, 1103], "vertical": true, "font_size": 43, "lines_coords": [[[184.0, 917.0], [226.0, 917.0], [226.0, 1068.0], [184.0, 1068.0]], [[141.0, 917.0], [181.0, 917.0], [181.0, 1103.0], [141.0, 1103.0]], [[91.0, 918.0], [139.0, 916.0], [145.0, 1016.0], [97.0, 1018.0]]], "lines": ["第六感が", "芽生えるん", "です。"]}], "img_path": "069.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [574, 236, 603, 307], "vertical": true, "font_size": 29, "lines_coords": [[[574.0, 236.0], [603.0, 236.0], [603.0, 307.0], [574.0, 307.0]]], "lines": ["ハァ！？"]}, {"box": [446, 16, 517, 141], "vertical": true, "font_size": 19, "lines_coords": [[