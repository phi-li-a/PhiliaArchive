355.0], [144.0, 419.0], [114.0, 419.0]], [[93.0, 356.0], [119.0, 355.0], [123.0, 423.0], [97.0, 424.0]]], "lines": ["神秘的", "でしょ。"]}, {"box": [758, 774, 805, 879], "vertical": true, "font_size": 24, "lines_coords": [[[778.0, 774.0], [805.0, 774.0], [805.0, 835.0], [778.0, 835.0]], [[758.0, 775.0], [778.0, 775.0], [778.0, 878.0], [758.0, 878.0]]], "lines": ["ただの", "お洒落です。"]}], "img_path": "123.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [366, 57, 390, 84], "vertical": true, "font_size": 24, "lines_coords": [[[366.0, 57.0], [390.0, 57.0], [390.0, 84.0], [366.0, 84.0]]], "lines": ["！？"]}, {"box": [488, 481, 507, 583], "vertical": true, "font_size": 17, "lines_coords": [[[488.0, 481.0], [505.0, 481.0], [505.0, 581.0], [488.0, 581.0]]], "lines": ["まかせたヅ"]}, {"box": [246, 532, 272, 570], "vertical": true, "font_size": 26, "lines_coords": [[[246.0, 532.0], [272.0, 532.0], [272.0, 570.0], [246.0, 570.0]]], "lines": ["車。"]}, {"box": [236, 523, 282, 580], "vertical": false, "font_size": 51, "lines_coords": [[[236.0, 529.0], [275.0, 523.0], [282.0, 574.0], [243.0, 580.0]]], "lines": ["車。"]}, {"box": [91, 676, 146, 779], "vertical": true, "font_size": 25, "lines_coords": [[[121.0, 677.0], [146.0, 677.0], [146.0, 769.0], [121.0, 769.0]], [[91.0, 676.0], [116.0, 676.0], [118.0, 779.0], [93.0, 779.0]]], "lines": ["まかせて", "ください。"]}], "img_path": "124.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [321, 357, 850, 670], "vertical": false, "font_size": 18, "lines_coords": [[[484.0, 473.0], [671.0, 421.0], [675.0, 439.0], [488.0, 492.0]], [[490.0, 520.0], [723.0, 457.0], [727.0, 475.0], [493.0, 538.0]], [[536.0, 559.0], [664.0, 524.0], [668.0, 542.0], [540.0, 577.0]]], "lines": ["それでも、これからもうちょっと", "それは、それでもいいんですが、それでも、これからもうちょっと、", "それでも、これまではないでしょうか。"]}, {"box": [581, 689, 660, 860], "vertical": true, "font_size": 24, "lines_coords": [[[634.0, 689.0], [657.0, 689.0], [660.0, 849.0], [636.0, 849.0]], [[608.0, 690.0], [631.0, 690.0], [631.0, 860.0], [608.0, 860.0]], [[581.0, 690.0], [606.0, 690.0], [606.0, 761.0], [581.0, 761.0]]], "lines": ["このマンション、", "元ホテルだったん", "ですよ"]}, {"box": [115, 735, 131, 798], "vertical": true, "font_size": 16, "lines_coords": [[[115.0, 735.0], [131.0, 735.0], [131.0, 798.0], [115.0, 798.0]]], "lines": ["．．．"]}], "img_path": "125.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [409, 70, 479, 164], "vertical": true, "font_size": 22, "lines_coords": [[[454.0, 70.0], [479.0, 70.0], [479.0, 132.0], [454.0, 132.0]], [[433.0, 71.0], [454.0, 71.0], [454.0, 164.0], [433.0, 164.0]], [[409.0, 70.0], [430.0, 70.0], [430.0, 147.0], [409.0, 147.0]]], "lines": ["なんか", "気味ワリぃ", "なあ．．．"]}, {"box": [370, 234, 396, 284], "vertical": true, "font_size": 22, "lines_coords": [[[370.0, 234.0], [396.0, 234.0], [396.0, 284.0], [370.0, 284.0]]], "lines": ["さあ、"]}, {"box": [274, 214, 318, 329], "vertical": true, "font_size": 22, "lines_coords": [[[298.0, 214.0], [318.0, 214.0], [318.0, 329.0], [298.0, 329.0]], [[274.0, 214.0], [294.0, 214.0], [294.0, 317.0], [274.0, 317.0]]], "lines": ["僕の研究室は", "最上階です。"]}, {"box": [662, 731, 709, 809], "vertical": true, "font_size": 23, "lines_coords": [[[683.0, 731.0], [709.0, 731.0], [709.0, 793.0], [683.0, 793.0]], [[662.0, 731.0], [682.0, 731.0], [682.0, 809.0], [662.0, 809.0]]], "lines": ["ここは", "賃貸か？"]}, {"box": [177, 682, 246, 806], "vertical": true, "font_size": 20, "lines_coords": [[[218.0, 683.0], [242.0, 682.0], [246.0, 769.0], [221.0, 771.0]], [[199.0, 684.0], [219.0, 684.0], [219.0, 780.0], [199.0, 780.0]], [[177.0, 684.0], [193.0, 684.0], [193.0, 805.0], [177.0, 805.0]]], "lines": ["分譲です。", "父が買って", "くれたんです"]}, {"box": [696, 925, 742, 1089], "vertical": true, "font_size": 21, "lines_coords": [[[716.0, 925.0], [742.0, 925.0], [742.0, 989.0], [716.0, 989.0]], [[696.0, 930.0], [712.0, 930.0], [712.0, 1085.0], [696.0, 1085.0]]], "lines": ["本当に", "ポンポンなんだな"]}], "img_path": "126.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [404, 838, 421, 900], "vertical": true, "font_size": 17, "lines_coords": [[[404.0, 838.0], [421.0, 838.0], [421.0, 900.0], [404.0, 900.0]]], "lines": ["．．．"]}, {"box": [241, 615, 270, 697], "vertical": true, "font_size": 13.0, "lines_coords": [[[256.0, 616.0], [269.0, 616.0], [270.0, 693.0], [257.0, 693.0]], [[241.0, 615.0], [254.0, 615.0], [254.0, 697.0], [241.0, 697.0]]], "lines": ["の四つの気性", "自己催眠法"]}, {"box": [692, 1021, 763, 1109], "vertical": true, "font_size": 23, "lines_coords": [[[742.0, 1024.0], [763.0, 1024.0], [763.0, 1101.0], [742.0, 1101.0]], [[715.0, 1021.0], [742.0, 1023.0], [739.0, 1086.0], [712.0, 1085.0]], [[692.0, 1024.0], [712.0, 1024.0], [712.0, 1109.0], [692.0, 1109.0]]], "lines": ["こっちの", "部屋で", "やります。"]}], "img_path": "127.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [371, 1017, 440, 1123], "vertical": true, "font_size": 20, "lines_coords": [[[419.0, 1017.0], [439.0, 1017.0], [439.0, 1123.0], [419.0, 1123.0]], [[393.0, 1018.0], [413.0, 1018.0], [413.0, 1096.0], [393.0, 1096.0]], [[371.0, 1017.0], [392.0, 1017.0], [392.0, 1101.0], [371.0, 1101.0]]], "lines": ["では、これに", "着替えて", "ください。"]}, {"box": [59, 1069, 79, 1146], "vertical": true, "font_size": 20, "lines_coords": [[[59.0, 1069.0], [79.0, 1069.0], [79.0, 1146.0], [59.0, 1146.0]]], "lines": ["ああ．．．"]}], "img_path": "128.png"}, {"version": "0.1.7", "img_width": 1713, "img_height": 1200, "blocks": [], "img_path": "129.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [538, 59, 608, 163], "vertical": true, "font_size": 20, "lines_coords": [[[583.0, 59.0], [608.0, 59.0], [608.0, 121.0], [583.0, 121.0]], [[561.0, 62.0], [581.0, 62.0], [581.0, 158.0], [561.0, 158.0]], [[539.0, 62.0], [555.0, 62.0], [555.0, 162.0], [539.0, 162.0]]], "lines": ["手術は", "４０分程度で", "終わります"]}, {"box": [422, 15, 467, 173], "vertical": true, "font_size": 18, "lines_coords": [[[447.0, 16.0], [464.0, 16.0], [464.0, 147.0], [447.0, 147.0]], [[422.0, 15.0], [442.0, 15.0], [442.0, 172.0], [422.0, 172.0]]], "lines": ["麻酔をするので", "痛くありませんが、"]}, {"box": [107, 82, 223, 319], "vertical": true, "font_size": 18, "lines_coords": [[[205.0, 84.0], [221.0, 84.0], [221.0, 196.0], [205.0, 196.0]], [[180.0, 83.0], [196.0, 83.0], [196.0, 240.0], [180.0, 240.0]], [[153.0, 82.0], [173.0, 82.0], [173.0, 216.0], [153.0, 216.0]], [[131.0, 83.0], [151.0, 83.0], [151.0, 274.0], [131.0, 274.0]], [[107.0, 83.0], [127.0, 83.0], [127.0, 316.0], [107.0, 316.0]]], "lines": ["穴を開ける時", "ドリルを使うので、", "振動というか．．．", "うるさいと思いますが", "決して動かないでください。"]}, {"box": [385, 411, 457, 567], "vertical": true, "font_size": 24, "lines_coords": [[[431.0, 411.0], [457.0, 411.0], [457.0, 474.0], [431.0, 474.0]], [[410.0, 411.0], [433.0, 411.0], [433.0, 567.0], [410.0, 567.0]], [[385.0, 411.0], [409.0, 411.0], [409.0, 551.0], [385.0, 551.0]]], "lines": ["脳膜を", "破ってしまったら", "大変ですからね。"]}], "img_path": "130.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [549, 60, 622, 179], "vertical": true, "font_size": 22, "lines_coords": [[[593.0, 62.0], [620.0, 60.0], [622.0, 113.0], [595.0, 114.0]], [[574.0, 66.0], [594.0, 66.0], [594.0, 179.0], [574.0, 179.0]], [[552.0, 65.0], [569.0, 65.0], [567.0, 167.0], [549.0, 167.0]]], "lines": ["さあ、", "麻酔の準備が", "できました"]}, {"box": [432, 64, 488, 160], "vertical": true, "font_size": 28, "lines_coords": [[[452.0, 64.0], [488.0, 64.0], [488.0, 120.0], [452.0, 120.0]], [[432.0, 70.0], [452.0, 70.0], [452.0, 160.0], [432.0, 160.0]]], "lines": ["何か", "質問は？"]}, {"box": [454, 591, 522, 707], "vertical": true, "font_size": 20, "lines_coords": [[[498.0, 591.0], [522.0, 591.0], [522.0, 653.0], [498.0, 653.0]], [[474.0, 591.0], [495.0, 591.0], [497.0, 689.0], [476.0, 689.0]], [[454.0, 594.0], [470.0, 594.0], [470.0, 707.0], [454.0, 707.0]]], "lines": ["本当に", "大丈夫なん", "だろうな．．．？"]}, {"box": [691, 921, 734, 1055], "vertical": true, "font_size": 18, "lines_coords": [[[714.0, 922.0], [733.0, 922.0], [733.0, 1055.0], [714.0, 1055.0]], [[691.0, 922.0], [708.0, 922.0], [708.0, 1019.0], [691.0, 1019.0]]], "lines": ["前にも話したと", "思いますが"]}, {"box": [128, 907, 279, 1162], "vertical": true, "font_size": 21, "lines_coords": [[[253.0, 907.0], [276.0, 907.0], [279.0, 1081.0], [255.0, 1081.0]], [[232.0, 910.0], [252.0, 910.0], [252.0, 1025.0], [232.0, 1025.0]], [[206.0, 909.0], [226.0, 909.0], [227.0, 1106.0], [207.0, 1106.0]], [[178.0, 909.0], [198.0, 909.0], [198.0, 1161.0], [178.0, 1161.0]], [[152.0, 910.0], [172.0, 910.0], [172.0, 1006.0], [152.0, 1006.0]], [[128.0, 910.0], [148.0, 910.0], [148.0, 1142.0], [128.0, 1142.0]]], "lines": ["トレパネーションは", "ロボトミーや", "脳外科手術とは異なり、", "単に頭蓋骨に施すものであって、", "脳の内部に", "いたるものではありません。"]}], "img_path": "131.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [689, 64, 759, 200], "vertical": true, "font_size": 21, "lines_coords": [[[739.0, 66.0], [759.0, 66.0], [759.0, 200.0], [739.0, 200.0]], [[715.0, 66.0], [735.0, 66.0], [735.0, 181.0], [715.0, 181.0]], [[689.0, 64.0], [715.0, 64.0], [715.0, 133.0], [689.0, 133.0]]], "lines": ["新石器時代から", "行われている", "手術で、"]}, {"box": [540, 70, 610, 212], "vertical": true, "font_size": 21, "lines_coords": [[[589.0, 70.0], [610.0, 70.0], [608.0, 205.0], [587.0, 205.0]], [[565.0, 71.0], [585.0, 71.0], [585.0, 187.0], [565.0, 187.0]], [[541.0, 71.0], [559.0, 71.0], [558.0, 212.0], [540.0, 212.0]]], "lines": ["現在でも海外で", "何人も行った", "ケースがあります。"]}, {"box": [337, 107, 430, 357], "vertical": true, "font_size": 19, "lines_coords": [[[411.0, 110.0], [427.0, 110.0], [427.0, 356.0], [411.0, 356.0]], [[385.0, 108.0], [405.0, 108.0], [405.0, 281.0], [385.0, 281.0]], [[361.0, 107.0], [381.0, 107.0], [381.0, 282.0], [361.0, 282.0]], [[337.0, 108.0], [357.0, 108.0], [357.0, 307.0], [337.0, 307.0]]], "lines": ["オランダにはＩＴＡＧという", "トレパネーションの", "普及活動をしている", "団体もあるくらいです。"]}, {"box": [390, 393, 460, 529], "vertical": true, "font_size": 19, "lines_coords": [[[434.0, 393.0], [460.0, 393.0], [460.0, 457.0], [434.0, 457.0]], [[415.0, 397.0], [431.0, 397.0], [431.0, 529.0], [415.0, 529.0]], [[390.0, 397.0], [406.0, 397.0], [406.0, 491.0], [390.0, 491.0]]], "lines": ["自分で", "穴を開ける人も", "いれば．．．．．．"]}, {"box": [86, 516, 157, 633], "vertical": true, "font_size": 22, "lines_coords": [[[131.0, 516.0], [157.0, 516.0], [157.0, 578.0], [131.0, 578.0]], [[111.0, 517.0], [131.0, 517.0], [131.0, 633.0], [111.0, 633.0]], [[86.0, 519.0], [106.0, 519.0], [106.0, 623.0], [86.0, 623.0]]], "lines": ["友人に", "やってもらう", "人もいます。"]}, {"box": [364, 704, 432, 865], "vertical": true, "font_size": 19, "lines_coords": [[[412.0, 704.0], [432.0, 704.0], [432.0, 810.0], [412.0, 810.0]], [[388.0, 705.0], [408.0, 705.0], [408.0, 858.0], [388.0, 858.0]], [[364.0, 705.0], [382.0, 705.0], [383.0, 863.0], [365.0, 863.0]]], "lines": ["それに、僕は", "父が医者だったと", "いうこともあって、"]}, {"box": [211, 750, 254, 866], "vertical": true, "font_size": 18, "lines_coords": [[[233.0, 750.0], [253.0, 750.0], [253.0, 847.0], [233.0, 847.0]], [[211.0, 752.0], [227.0, 752.0], [227.0, 866.0], [211.0, 866.0]]], "lines": ["実地経験は", "ないだろう？"]}, {"box": [115, 718, 131, 759], "vertical": true, "font_size": 16, "lines_coords": [[[115.0, 718.0], [131.0, 718.0], [131.0, 759.0], [115.0, 759.0]]], "lines": ["！"]}, {"box": [378, 971, 471, 1150], "vertical": true, "font_size": 19, "lines_coords": [[[450.0, 971.0], [470.0, 971.0], [470.0, 1105.0], [450.0, 1105.0]], [[425.0, 971.0], [445.0, 971.0], [445.0, 1106.0], [425.0, 1106.0]], [[402.0, 971.0], [422.0, 971.0], [422.0, 1105.0], [402.0, 1105.0]], [[379.0, 972.0], [396.0, 972.0], [396.0, 1149.0], [379.0, 1149.0]]], "lines": ["高校卒業時には", "認定医の検定に", "受かるくらいの", "知識は持っています。"]}], "img_path": "132.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [669, 65, 721, 161], "vertical": true, "font_size": 25, "lines_coords": [[[696.0, 67.0], [721.0, 67.0], [721.0, 153.0], [696.0, 153.0]], [[669.0, 65.0], [694.0, 65.0], [694.0, 161.0], [669.0, 161.0]]], "lines": ["安心して", "ください。"]}, {"box": [325, 62, 433, 212], "vertical": true, "font_size": 21, "lines_coords": [[[410.0, 62.0], [433.0, 62.0], [433.0, 212.0], [410.0, 212.0]], [[383.0, 62.0], [404.0, 62.0], [404.0, 167.0], [383.0, 167.0]], [[358.0, 64.0], [375.0, 64.0], [375.0, 169.0], [358.0, 169.0]], [[325.0, 62.0], [349.0, 62.0], [352.0, 198.0], [329.0, 198.0]]], "lines": ["はっきり言って", "そこら辺の", "医者よりも", "腕は確かです。"]}, {"box": [36, 716, 84, 793], "vertical": true, "font_size": 42, "lines_coords": [[[36.0, 719.0], [78.0, 716.0], [84.0, 789.0], [42.0, 793.0]]], "lines": ["やれ。"]}], "img_path": "133.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [563, 57, 629, 171], "vertical": true, "font_size": 20, "lines_coords": [[[608.0, 57.0], [629.0, 57.0], [629.0, 134.0], [608.0, 134.0]], [[585.0, 58.0], [606.0, 58.0], [606.0, 169.0], [585.0, 169.0]], [[563.0, 58.0], [580.0, 58.0], [580.0, 171.0], [563.0, 171.0]]], "lines": ["そろそろ", "麻酔が効いて", "きましたか？"]}, {"box": [116, 32, 213, 187], "vertical": true, "font_size": 22, "lines_coords": [[[186.0, 32.0], [213.0, 32.0], [213.0, 78.0], [186.0, 78.0]], [[166.0, 33.0], [186.0, 33.0], [186.0, 187.0], [166.0, 187.0]], [[140.0, 32.0], [160.0, 32.0], [162.0, 168.0], [143.0, 168.0]], [[116.0, 32.0], [136.0, 32.0], [138.0, 137.0], [118.0, 137.0]]], "lines": ["では", "ちょっと失礼して", "布をかけさせて", "もらいます。"]}, {"box": [579, 336, 615, 401], "vertical": true, "font_size": 30, "lines_coords": [[[579.0, 338.0], [609.0, 336.0], [615.0, 399.0], [585.0, 401.0]]], "lines": ["ああ。"]}], "img_path": "134.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [637, 468, 654, 538], "vertical": true, "font_size": 17, "lines_coords": [[[637.0, 468.0], [654.0, 468.0], [654.0, 538.0], [637.0, 538.0]]], "lines": ["．．．．．．"]}, {"box": [515, 632, 583, 775], "vertical": true, "font_size": 20, "lines_coords": [[[563.0, 632.0], [583.0, 632.0], [583.0, 758.0], [563.0, 758.0]], [[539.0, 633.0], [559.0, 633.0], [559.0, 768.0], [539.0, 768.0]], [[515.0, 633.0], [535.0, 633.0], [535.0, 775.0], [515.0, 775.0]]], "lines": ["まずは、メスで", "頭皮を半円状に", "切っていきます。"]}], "img_path": "135.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [132, 301, 236, 408], "vertical": true, "font_size": 24, "lines_coords": [[[207.0, 301.0], [236.0, 301.0], [236.0, 372.0], [207.0, 372.0]], [[184.0, 303.0], [208.0, 303.0], [208.0, 387.0], [184.0, 387.0]], [[158.0, 303.0], [179.0, 303.0], [179.0, 407.0], [158.0, 407.0]], [[132.0, 303.0], [152.0, 303.0], [152.0, 394.0], [132.0, 394.0]]], "lines": ["♪", "フンフン", "フ～～ン", "♪フフン"]}, {"box": [626, 840, 651, 942], "vertical": true, "font_size": 24, "lines_coords": [[[626.0, 840.0], [650.0, 840.0], [650.0, 942.0], [626.0, 942.0]]], "lines": ["おしっと。"]}, {"box": [264, 840, 359, 938], "vertical": true, "font_size": 22, "lines_coords": [[[331.0, 840.0], [359.0, 840.0], [359.0, 885.0], [331.0, 885.0]], [[310.0, 841.0], [331.0, 841.0], [331.0, 921.0], [310.0, 921.0]], [[287.0, 842.0], [307.0, 842.0], [307.0, 938.0], [287.0, 938.0]], [[264.0, 843.0], [281.0, 843.0], [281.0, 925.0], [264.0, 925.0]]], "lines": ["では", "ドリルで", "穴を開けて", "いきます"]}, {"box": [111, 867, 146, 931], "vertical": true, "font_size": 35, "lines_coords": [[[111.0, 867.0], [146.0, 867.0], [146.0, 931.0], [111.0, 931.0]]], "lines": ["おい。"]}, {"box": [453, 950, 476, 984], "vertical": true, "font_size": 23, "lines_coords": [[[453.0, 950.0], [476.0, 950.0], [476.0, 984.0], [453.0, 984.0]]], "lines": ["ガタ"]}], "img_path": "136.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [558, 23, 583, 85], "vertical": true, "font_size": 25, "lines_coords": [[[558.0, 23.0], [583.0, 23.0], [583.0, 85.0], [558.0, 85.0]]], "lines": ["はい？"]}, {"box": [393, 56, 466, 153], "vertical": true, "font_size": 22, "lines_coords": [[[442.0, 56.0], [466.0, 56.0], [466.0, 135.0], [442.0, 135.0]], [[418.0, 57.0], [439.0, 57.0], [439.0, 153.0], [418.0, 153.0]], [[393.0, 57.0], [413.0, 57.0], [413.0, 153.0], [393.0, 153.0]]], "lines": ["間違って", "死ぬ分には", "いいか．．．．．"]}, {"box": [133, 15, 252, 187], "vertical": true, "font_size": 19, "lines_coords": [[[229.0, 15.0], [250.0, 15.0], [252.0, 139.0], [230.0, 139.0]], [[206.0, 16.0], [226.0, 16.0], [226.0, 112.0], [206.0, 112.0]], [[184.0, 17.0], [200.0, 17.0], [200.0, 187.0], [184.0, 187.0]], [[160.0, 16.0], [177.0, 16.0], [177.0, 132.0], [160.0, 132.0]], [[133.0, 16.0], [153.0, 16.0], [153.0, 155.0], [133.0, 155.0]]], "lines": ["変に失敗して、", "植物状態や", "脳死みたいなことに", "なった時は．．．", "殺してくれ．．．．．．"]}, {"box": [637, 690, 664, 838], "vertical": true, "font_size": 24, "lines_coords": [[[637.0, 690.0], [661.0, 690.0], [664.0, 837.0], [641.0, 837.0]]], "lines": ["わかりました。"]}], "img_path": "137.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [], "img_path": "138.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [77, 42, 180, 56], "vertical": false, "font_size": 13, "lines_coords": [[[77.0, 43.0], [180.0, 42.0], [180.0, 55.0], [77.0, 56.0]]], "lines": ["ホムンクルス"]}], "img_path": "139.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [], "img_path": "140.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [676, 41, 692, 137], "vertical": true, "font_size": 19, "lines_coords": [[[676.0, 41.0], [692.0, 41.0], [692.0, 137.0], [676.0, 137.0]]], "lines": ["どうです？"]}, {"box": [647, 169, 712, 268], "vertical": true, "font_size": 19, "lines_coords": [[[692.0, 169.0], [712.0, 169.0], [712.0, 267.0], [692.0, 267.0]], [[670.0, 169.0], [691.0, 169.0], [691.0, 249.0], [670.0, 249.0]], [[647.0, 171.0], [667.0, 171.0], [667.0, 268.0], [647.0, 268.0]]], "lines": ["大したこと", "なかった", "でしょう？"]}, {"box": [144, 68, 161, 124], "vertical": true, "font_size": 17, "lines_coords": [[[144.0, 68.0], [161.0, 68.0], [161.0, 124.0], [144.0, 124.0]]], "lines": ["．．．．．．"]}, {"box": [332, 515, 355, 638], "vertical": true, "font_size": 19, "lines_coords": [[[332.0, 515.0], [351.0, 515.0], [355.0, 638.0], [336.0, 638.0]]], "lines": ["開いてますよ。"]}, {"box": [15, 558, 91, 675], "vertical": true, "font_size": 24, "lines_coords": [[[60.0, 558.0], [91.0, 558.0], [91.0, 604.0], [60.0, 604.0]], [[41.0, 561.0], [62.0, 561.0], [62.0, 675.0], [41.0, 675.0]], [[17.0, 558.0], [38.0, 558.0], [36.0, 646.0], [15.0, 646.0]]], "lines": ["半径", "３ミリ程度の", "穴ですが。"]}, {"box": [52, 755, 75, 816], "vertical": true, "font_size": 23, "lines_coords": [[[52.0, 758.0], [75.0, 758.0], [75.0, 815.0], [52.0, 815.0]]], "lines": ["チョン"]}, {"box": [538, 903, 633, 1020], "vertical": true, "font_size": 23, "lines_coords": [[[607.0, 903.0], [633.0, 903.0], [633.0, 965.0], [607.0, 965.0]], [[583.0, 904.0], [608.0, 904.0], [608.0, 984.0], [583.0, 984.0]], [[560.0, 904.0], [581.0, 904.0], [582.0, 1020.0], [561.0, 1020.0]], [[538.0, 907.0], [558.0, 907.0], [558.0, 983.0], [538.0, 983.0]]], "lines": ["本当に", "頭蓋骨に", "穴が開いてる", "のか．．．？"]}, {"box": [335, 983, 364, 1089], "vertical": true, "font_size": 29, "lines_coords": [[[335.0, 983.0], [364.0, 983.0], [364.0, 1089.0], [335.0, 1089.0]]], "lines": ["イッ．．．！！"]}], "img_path": "141.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [576, 39, 594, 103], "vertical": true, "font_size": 18, "lines_coords": [[[576.0, 39.0], [594.0, 39.0], [594.0, 103.0], [576.0, 103.0]]], "lines": ["．．．．．．．．"]}, {"box": [597, 172, 668, 353], "vertical": true, "font_size": 20, "lines_coords": [[[647.0, 174.0], [667.0, 174.0], [667.0, 345.0], [647.0, 345.0]], [[621.0, 172.0], [641.0, 172.0], [641.0, 287.0], [621.0, 287.0]], [[597.0, 172.0], [617.0, 172.0], [619.0, 353.0], [599.0, 353.0]]], "lines": ["麻酔が切れてきたら", "多少の痛みが", "あるかもしれません。"]}, {"box": [290, 16, 358, 179], "vertical": true, "font_size": 18, "lines_coords": [[[337.0, 16.0], [357.0, 16.0], [357.0, 112.0], [337.0, 112.0]], [[315.0, 17.0], [331.0, 17.0], [331.0, 112.0], [315.0, 112.0]], [[290.0, 16.0], [308.0, 16.0], [309.0, 178.0], [291.0, 178.0]]], "lines": ["念のために", "痛み止めを", "飲んでおきましょう。"]}, {"box": [114, 17, 156, 139], "vertical": true, "font_size": 19, "lines_coords": [[[134.0, 17.0], [155.0, 17.0], [155.0, 94.0], [134.0, 94.0]], [[114.0, 18.0], [131.0, 18.0], [131.0, 138.0], [114.0, 138.0]]], "lines": ["即効性の", "あるヤツです。"]}, {"box": [679, 774, 698, 826], "vertical": true, "font_size": 19, "lines_coords": [[[679.0, 774.0], [698.0, 774.0], [698.0, 826.0], [679.0, 826.0]]], "lines": ["さて、"]}, {"box": [668, 768, 706, 834], "vertical": false, "font_size": 62, "lines_coords": [[[668.0, 772.0], [699.0, 768.0], [706.0, 830.0], [675.0, 834.0]]], "lines": ["さて、"]}, {"box": [363, 925, 420, 1020], "vertical": true, "font_size": 28, "lines_coords": [[[396.0, 926.0], [420.0, 926.0], [420.0, 1020.0], [396.0, 1020.0]], [[363.0, 925.0], [395.0, 925.0], [395.0, 978.0], [363.0, 978.0]]], "lines": ["どうです", "か？"]}], "img_path": "142.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [518, 33, 635, 153], "vertical": true, "font_size": 27, "lines_coords": [[[602.0, 33.0], [635.0, 33.0], [635.0, 87.0], [602.0, 87.0]], [[580.0, 38.0], [601.0, 38.0], [601.0, 128.0], [580.0, 128.0]], [[551.0, 37.0], [573.0, 37.0], [573.0, 153.0], [551.0, 153.0]], [[518.0, 35.0], [549.0, 35.0], [549.0, 89.0], [518.0, 89.0]]], "lines": ["何か", "変わりは", "ありません", "か？"]}, {"box": [426, 53, 447, 105], "vertical": true, "font_size": 21, "lines_coords": [[[426.0, 53.0], [447.0, 53.0], [447.0, 105.0], [426.0, 105.0]]], "lines": ["！"]}, {"box": [164, 52, 194, 121], "vertical": true, "font_size": 30, "lines_coords": [[[164.0, 52.0], [194.0, 52.0], [194.0, 121.0], [164.0, 121.0]]], "lines": ["そう。"]}, {"box": [106, 604, 181, 712], "vertical": true, "font_size": 34, "lines_coords": [[[147.0, 607.0], [181.0, 607.0], [181.0, 700.0], [147.0, 700.0]], [[106.0, 605.0], [140.0, 604.0], [144.0, 711.0], [110.0, 712.0]]], "lines": ["第六感", "ですよ。"]}], "img_path": "143.png"}, {"version": "0.1.7", "img_width": 843, "