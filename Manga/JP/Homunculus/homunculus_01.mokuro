5.0, 493.0]]], "lines": ["まだです。"]}, {"box": [464, 569, 493, 605], "vertical": true, "font_size": 30, "lines_coords": [[[464.0, 569.0], [493.0, 569.0], [493.0, 605.0], [464.0, 605.0]]], "lines": ["ふー"]}, {"box": [260, 399, 288, 444], "vertical": true, "font_size": 28, "lines_coords": [[[260.0, 399.0], [288.0, 399.0], [288.0, 444.0], [260.0, 444.0]]], "lines": ["キュ"]}, {"box": [97, 399, 121, 433], "vertical": false, "font_size": 34, "lines_coords": [[[97.0, 399.0], [121.0, 399.0], [121.0, 433.0], [97.0, 433.0]]], "lines": ["キュ"]}, {"box": [362, 624, 415, 698], "vertical": true, "font_size": 30, "lines_coords": [[[381.0, 624.0], [415.0, 624.0], [415.0, 694.0], [381.0, 694.0]], [[362.0, 628.0], [388.0, 628.0], [388.0, 698.0], [362.0, 698.0]]], "lines": ["食った", "食った。"]}, {"box": [134, 814, 168, 918], "vertical": true, "font_size": 31, "lines_coords": [[[134.0, 815.0], [165.0, 814.0], [168.0, 917.0], [138.0, 918.0]]], "lines": ["やるよ。"]}], "img_path": "108.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [698, 31, 737, 77], "vertical": true, "font_size": 39, "lines_coords": [[[698.0, 31.0], [737.0, 31.0], [737.0, 77.0], [698.0, 77.0]]], "lines": ["！？"]}, {"box": [501, 155, 550, 318], "vertical": true, "font_size": 24, "lines_coords": [[[528.0, 157.0], [548.0, 157.0], [548.0, 312.0], [528.0, 312.0]], [[501.0, 155.0], [528.0, 155.0], [528.0, 208.0], [501.0, 208.0]]], "lines": ["どうしたんですか", "急に。"]}, {"box": [218, 52, 267, 114], "vertical": true, "font_size": 26, "lines_coords": [[[240.0, 52.0], [267.0, 52.0], [267.0, 112.0], [240.0, 112.0]], [[218.0, 52.0], [243.0, 52.0], [243.0, 114.0], [218.0, 114.0]]], "lines": ["オマエ", "だろ？"]}, {"box": [668, 383, 738, 468], "vertical": true, "font_size": 24, "lines_coords": [[[712.0, 383.0], [738.0, 383.0], [738.0, 462.0], [712.0, 462.0]], [[690.0, 384.0], [715.0, 384.0], [715.0, 461.0], [690.0, 461.0]], [[668.0, 383.0], [688.0, 383.0], [688.0, 468.0], [668.0, 468.0]]], "lines": ["オレの車", "レッカー", "させたの。"]}, {"box": [668, 955, 754, 1116], "vertical": true, "font_size": 25, "lines_coords": [[[728.0, 957.0], [751.0, 957.0], [751.0, 1116.0], [728.0, 1116.0]], [[701.0, 957.0], [724.0, 957.0], [724.0, 1095.0], [701.0, 1095.0]], [[668.0, 955.0], [697.0, 955.0], [697.0, 1030.0], [668.0, 1030.0]]], "lines": ["その疑い深さが", "欲しかったん", "です！"]}], "img_path": "109.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [412, 487, 463, 554], "vertical": true, "font_size": 28, "lines_coords": [[[437.0, 487.0], [463.0, 487.0], [463.0, 549.0], [437.0, 549.0]], [[412.0, 487.0], [442.0, 487.0], [442.0, 554.0], [412.0, 554.0]]], "lines": ["報酬は", "７０万円"]}, {"box": [244, 516, 263, 617], "vertical": true, "font_size": 16, "lines_coords": [[[245.0, 516.0], [261.0, 516.0], [261.0, 616.0], [245.0, 616.0]]], "lines": ["術後に３０万"]}, {"box": [581, 725, 672, 924], "vertical": true, "font_size": 20, "lines_coords": [[[648.0, 725.0], [672.0, 725.0], [672.0, 786.0], [648.0, 786.0]], [[626.0, 725.0], [647.0, 725.0], [648.0, 922.0], [627.0, 922.0]], [[603.0, 727.0], [623.0, 727.0], [623.0, 823.0], [603.0, 823.0]], [[581.0, 730.0], [597.0, 730.0], [597.0, 848.0], [581.0, 848.0]]], "lines": ["実験は", "穴を開ける日を含めて、", "１０日間ほど", "いただきます"]}, {"box": [115, 714, 184, 853], "vertical": true, "font_size": 22, "lines_coords": [[[160.0, 714.0], [184.0, 714.0], [184.0, 853.0], [160.0, 853.0]], [[134.0, 714.0], [159.0, 714.0], [161.0, 806.0], [137.0, 806.0]], [[116.0, 718.0], [132.0, 718.0], [132.0, 839.0], [116.0, 839.0]]], "lines": ["すべて終了した", "時に、４０万", "お渡しします。"]}, {"box": [357, 880, 449, 1062], "vertical": true, "font_size": 20, "lines_coords": [[[429.0, 882.0], [449.0, 882.0], [446.0, 1055.0], [426.0, 1055.0]], [[404.0, 882.0], [424.0, 882.0], [424.0, 1039.0], [404.0, 1039.0]], [[375.0, 881.0], [399.0, 880.0], [403.0, 969.0], [378.0, 970.0]], [[357.0, 882.0], [374.0, 882.0], [375.0, 1062.0], [358.0, 1062.0]]], "lines": ["レッカーされた車は", "僕がお金と点数を", "負担して、", "取り戻しておきます。"]}, {"box": [377, 1061, 445, 1170], "vertical": true, "font_size": 20, "lines_coords": [[[420.0, 1061.0], [445.0, 1061.0], [445.0, 1134.0], [420.0, 1134.0]], [[398.0, 1069.0], [418.0, 1069.0], [418.0, 1149.0], [398.0, 1149.0]], [[377.0, 1073.0], [392.0, 1073.0], [392.0, 1170.0], [377.0, 1170.0]]], "lines": ["これは", "僕からの", "気持ちです。"]}], "img_path": "110.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [540, 69, 585, 207], "vertical": true, "font_size": 20, "lines_coords": [[[560.0, 69.0], [585.0, 69.0], [585.0, 145.0], [560.0, 145.0]], [[540.0, 70.0], [556.0, 70.0], [556.0, 205.0], [540.0, 205.0]]], "lines": ["一つだけ", "ハッキリさせろ。"]}, {"box": [213, 223, 266, 277], "vertical": true, "font_size": 38, "lines_coords": [[[213.0, 241.0], [247.0, 223.0], [266.0, 260.0], [232.0, 277.0]]], "lines": ["！"]}, {"box": [748, 516, 810, 624], "vertical": true, "font_size": 30, "lines_coords": [[[779.0, 516.0], [810.0, 516.0], [810.0, 595.0], [779.0, 595.0]], [[748.0, 517.0], [776.0, 517.0], [776.0, 624.0], [748.0, 624.0]]], "lines": ["オマエ", "何者だ？"]}, {"box": [510, 734, 577, 820], "vertical": true, "font_size": 31, "lines_coords": [[[538.0, 735.0], [568.0, 734.0], [570.0, 819.0], [540.0, 820.0]], [[510.0, 734.0], [541.0, 734.0], [541.0, 795.0], [510.0, 795.0]]], "lines": ["伊藤学", "２２歳。"]}, {"box": [228, 765, 351, 817], "vertical": false, "font_size": 18.5, "lines_coords": [[[230.0, 785.0], [351.0, 798.0], [349.0, 817.0], [228.0, 805.0]], [[239.0, 765.0], [277.0, 765.0], [277.0, 782.0], [239.0, 782.0]]], "lines": ["急に大丈夫だな。", "藤"]}, {"box": [160, 803, 340, 858], "vertical": false, "font_size": 19.5, "lines_coords": [[[172.0, 803.0], [340.0, 817.0], [337.0, 837.0], [170.0, 822.0]], [[162.0, 828.0], [290.0, 840.0], [288.0, 858.0], [160.0, 847.0]]], "lines": ["東京都渋谷区平和", "平成１４年０５月"]}, {"box": [417, 909, 453, 1038], "vertical": true, "font_size": 26, "lines_coords": [[[427.0, 909.0], [453.0, 911.0], [443.0, 1038.0], [417.0, 1035.0]]], "lines": ["蓮転免許証"]}, {"box": [117, 1047, 177, 1120], "vertical": true, "font_size": 32, "lines_coords": [[[147.0, 1048.0], [177.0, 1048.0], [177.0, 1120.0], [147.0, 1120.0]], [[117.0, 1047.0], [152.0, 1047.0], [152.0, 1109.0], [117.0, 1109.0]]], "lines": ["医大生", "です。"]}], "img_path": "111.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [578, 80, 658, 289], "vertical": true, "font_size": 22, "lines_coords": [[[636.0, 82.0], [656.0, 82.0], [656.0, 196.0], [636.0, 196.0]], [[606.0, 82.0], [629.0, 82.0], [629.0, 289.0], [606.0, 289.0]], [[578.0, 80.0], [601.0, 80.0], [601.0, 230.0], [578.0, 230.0]]], "lines": ["父は大きな", "脳神経外科の病院を", "やっています。"]}, {"box": [96, 134, 181, 229], "vertical": true, "font_size": 28, "lines_coords": [[[153.0, 135.0], [179.0, 135.0], [181.0, 228.0], [155.0, 228.0]], [[126.0, 135.0], [154.0, 135.0], [154.0, 229.0], [126.0, 229.0]], [[96.0, 134.0], [127.0, 134.0], [127.0, 196.0], [96.0, 196.0]]], "lines": ["いわゆる", "ボンボン", "です。"]}, {"box": [561, 774, 577, 837], "vertical": true, "font_size": 16, "lines_coords": [[[561.0, 774.0], [577.0, 774.0], [577.0, 837.0], [561.0, 837.0]]], "lines": ["．．．．．．"]}, {"box": [364, 809, 431, 943], "vertical": true, "font_size": 19, "lines_coords": [[[411.0, 810.0], [431.0, 810.0], [431.0, 916.0], [411.0, 916.0]], [[386.0, 809.0], [406.0, 809.0], [406.0, 943.0], [386.0, 943.0]], [[364.0, 812.0], [381.0, 812.0], [381.0, 892.0], [364.0, 892.0]]], "lines": ["医大で、よく", "そんなカッコウ", "できるな。"]}, {"box": [9, 683, 48, 713], "vertical": false, "font_size": 18, "lines_coords": [[[9.0, 696.0], [41.0, 683.0], [48.0, 700.0], [16.0, 713.0]]], "lines": ["交付"]}], "img_path": "112.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [520, 58, 566, 220], "vertical": true, "font_size": 20, "lines_coords": [[[546.0, 59.0], [566.0, 59.0], [566.0, 137.0], [546.0, 137.0]], [[520.0, 58.0], [540.0, 58.0], [542.0, 219.0], [522.0, 219.0]]], "lines": ["ピアスは", "取り外しできるし、"]}, {"box": [338, 62, 431, 243], "vertical": true, "font_size": 20, "lines_coords": [[[410.0, 62.0], [430.0, 62.0], [430.0, 178.0], [410.0, 178.0]], [[385.0, 62.0], [405.0, 62.0], [405.0, 239.0], [385.0, 239.0]], [[361.0, 62.0], [381.0, 62.0], [381.0, 159.0], [361.0, 159.0]], [[338.0, 62.0], [358.0, 62.0], [358.0, 146.0], [338.0, 146.0]]], "lines": ["服装や髪型は", "教授にもよりますが、", "基本的には", "自由です。"]}, {"box": [736, 262, 812, 370], "vertical": true, "font_size": 22, "lines_coords": [[[762.0, 266.0], [783.0, 266.0], [783.0, 370.0], [762.0, 370.0]], [[782.0, 262.0], [812.0, 262.0], [812.0, 326.0], [782.0, 326.0]], [[736.0, 264.0], [762.0, 264.0], [762.0, 332.0], [736.0, 332.0]]], "lines": ["全部描いた", "刺青は", "モノで、"]}, {"box": [742, 398, 807, 501], "vertical": true, "font_size": 22, "lines_coords": [[[791.0, 403.0], [807.0, 403.0], [807.0, 495.0], [791.0, 495.0]], [[764.0, 398.0], [784.0, 398.0], [784.0, 478.0], [764.0, 478.0]], [[742.0, 400.0], [758.0, 400.0], [758.0, 501.0], [742.0, 501.0]]], "lines": ["残念ながら", "本物では", "ありません"]}, {"box": [712, 561, 807, 785], "vertical": true, "font_size": 21, "lines_coords": [[[786.0, 563.0], [806.0, 563.0], [806.0, 646.0], [786.0, 646.0]], [[762.0, 562.0], [782.0, 562.0], [782.0, 698.0], [762.0, 698.0]], [[737.0, 561.0], [760.0, 561.0], [760.0, 785.0], [737.0, 785.0]], [[714.0, 562.0], [733.0, 562.0], [732.0, 698.0], [712.0, 698.0]]], "lines": ["医大生が、", "そんな頭蓋骨に", "『穴開けるようなことして", "大丈夫なのか？"]}, {"box": [347, 566, 414, 764], "vertical": true, "font_size": 18, "lines_coords": [[[396.0, 567.0], [412.0, 567.0], [412.0, 646.0], [396.0, 646.0]], [[370.0, 566.0], [390.0, 566.0], [390.0, 720.0], [370.0, 720.0]], [[347.0, 566.0], [366.0, 566.0], [366.0, 764.0], [347.0, 764.0]]], "lines": ["もちろん", "大学側に知れたら", "問題になるでしょうね。"]}, {"box": [735, 950, 807, 1126], "vertical": true, "font_size": 24, "lines_coords": [[[779.0, 950.0], [807.0, 950.0], [807.0, 996.0], [779.0, 996.0]], [[758.0, 951.0], [782.0, 951.0], [782.0, 1126.0], [758.0, 1126.0]], [[735.0, 952.0], [755.0, 952.0], [755.0, 1091.0], [735.0, 1091.0]]], "lines": ["でも", "トレパネーションは", "犯罪ではないし、"]}, {"box": [159, 982, 250, 1098], "vertical": true, "font_size": 19, "lines_coords": [[[229.0, 984.0], [250.0, 984.0], [250.0, 1098.0], [229.0, 1098.0]], [[204.0, 982.0], [228.0, 982.0], [228.0, 1044.0], [204.0, 1044.0]], [[184.0, 985.0], [200.0, 985.0], [200.0, 1098.0], [184.0, 1098.0]], [[159.0, 984.0], [175.0, 984.0], [175.0, 1085.0], [159.0, 1085.0]]], "lines": ["本人の同意が", "あれば", "なんの問題も", "ありません"]}], "img_path": "113.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [559, 48, 652, 241], "vertical": true, "font_size": 20, "lines_coords": [[[630.0, 48.0], [650.0, 48.0], [650.0, 183.0], [630.0, 183.0]], [[604.0, 48.0], [629.0, 48.0], [629.0, 118.0], [604.0, 118.0]], [[583.0, 49.0], [600.0, 49.0], [600.0, 239.0], [583.0, 239.0]], [[560.0, 48.0], [576.0, 48.0], [576.0, 195.0], [560.0, 195.0]]], "lines": ["それに大学側に", "バレて、", "医者の道を絶たれても", "全然構いません"]}, {"box": [98, 234, 123, 295], "vertical": true, "font_size": 25, "lines_coords": [[[98.0, 234.0], [123.0, 234.0], [123.0, 295.0], [98.0, 295.0]]], "lines": ["！？"]}, {"box": [201, 416, 296, 604], "vertical": true, "font_size": 28, "lines_coords": [[[268.0, 416.0], [296.0, 416.0], [296.0, 526.0], [268.0, 526.0]], [[232.0, 416.0], [263.0, 416.0], [263.0, 604.0], [232.0, 604.0]], [[201.0, 418.0], [226.0, 418.0], [226.0, 583.0], [201.0, 583.0]]], "lines": ["僕はただ", "人間が知りたい", "だけですから。"]}, {"box": [676, 993, 705, 1116], "vertical": true, "font_size": 29, "lines_coords": [[[676.0, 994.0], [705.0, 994.0], [705.0, 1116.0], [676.0, 1116.0]]], "lines": ["人間．．．？"]}], "img_path": "114.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [556, 159, 582, 192], "vertical": false, "font_size": 33, "lines_coords": [[[556.0, 159.0], [582.0, 159.0], [582.0, 192.0], [556.0, 192.0]]], "lines": ["！！？"]}, {"box": [221, 100, 362, 377], "vertical": true, "font_size": 20, "lines_coords": [[[342.0, 101.0], [362.0, 101.0], [362.0, 199.0], [342.0, 199.0]], [[316.0, 100.0], [337.0, 100.0], [338.0, 214.0], [317.0, 214.0]], [[293.0, 100.0], [313.0, 100.0], [314.0, 261.0], [294.0, 261.0]], [[268.0, 100.0], [289.0, 100.0], [290.0, 376.0], [269.0, 376.0]], [[245.0, 103.0], [264.0, 103.0], [264.0, 276.0], [245.0, 276.0]], [[221.0, 101.0], [241.0, 101.0], [242.0, 303.0], [222.0, 303.0]]], "lines": ["僕は昔から", "医学、心理学、", "あやしい精神世界、", "それこそオカルト的なモノまで、", "いろいろな角度から", "人間を研究しています。"]}, {"box": [738, 766, 829, 869], "vertical": true, "font_size": 20, "lines_coords": [[[808.0, 767.0], [828.0, 767.0], [828.0, 863.0], [808.0, 863.0]], [[786.0, 768.0], [806.0, 768.0], [806.0, 863.0], [786.0, 863.0]], [[759.0, 766.0], [780.0, 766.0], [782.0, 864.0], [760.0, 864.0]], [[738.0, 769.0], [755.0, 769.0], [755.0, 869.0], [738.0, 869.0]]], "lines": ["医者なんて", "レッテルは", "僕にとって", "これと同じ、"]}, {"box": [383, 752, 450, 887], "vertical": true, "font_size": 19, "lines_coords": [[[430.0, 753.0], [450.0, 753.0], [450.0, 885.0], [430.0, 885.0]], [[404.0, 754.0], [424.0, 754.0], [424.0, 887.0], [404.0, 887.0]], [[383.0, 752.0], [399.0, 752.0], [399.0, 836.0], [383.0, 836.0]]], "lines": ["いつでも外せる", "「飾り」みたいな", "もんです"]}, {"box": [404, 950, 497, 1164], "vertical": true, "font_size": 19, "lines_coords": [[[476.0, 950.0], [495.0, 950.0], [495.0, 1085.0], [476.0, 1085.0]], [[451.0, 950.0], [472.0, 950.0], [470.0, 1046.0], [449.0, 1046.0]], [[429.0, 952.0], [445.0, 952.0], [445.0, 1163.0], [429.0, 1163.0]], [[405.0, 951.0], [425.0, 951.0], [425.0, 1130.0], [405.0, 1130.0]]], "lines": ["それに比べたら", "今回の実験", "「トレバネーション」のほうが、", "よっぽど魅力的です。"]}], "img_path": "115.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [286, 126, 347, 257], "vertical": true, "font_size": 28, "lines_coords": [[[322.0, 126.0], [347.0, 126.0], [347.0, 257.0], [322.0, 257.0]], [[286.0, 126.0], [316.0, 126.0], [316.0, 209.0], [286.0, 209.0]]], "lines": ["人間オタク", "か．．．．．"]}, {"box": [262, 304, 291, 398], "vertical": true, "font_size": 28, "lines_coords": [[[262.0, 304.0], [291.0, 304.0], [291.0, 398.0], [262.0, 398.0]]], "lines": ["オマエ。"]}, {"box": [425, 610, 490, 744], "vertical": true, "font_size": 20, "lines_coords": [[[468.0, 611.0], [490.0, 611.0], [490.0, 665.0], [468.0, 665.0]], [[447.0, 611.0], [465.0, 611.0], [466.0, 744.0], [449.0, 744.0]], [[425.0, 610.0], [445.0, 610.0], [447.0, 728.0], [427.0, 728.0]]], "lines": ["今度は", "名越さんのことを", "教えてください"]}, {"box": [166, 613, 184, 656], "vertical": true, "font_size": 18, "lines_coords": [[[166.0, 613.0], [184.0, 613.0], [184.0, 656.0], [166.0, 656.0]]], "lines": ["！"]}, {"box": [491, 888, 535, 985], "vertical": true, "font_size": 20, "lines_coords": [[[515.0, 888.0], [535.0, 888.0], [535.0, 966.0], [515.0, 966.0]], [[491.0, 889.0], [511.0, 889.0], [511.0, 985.0], [491.0, 985.0]]], "lines": ["どこまで", "知ってる？"]}, {"box": [389, 870, 408, 970], "vertical": true, "font_size": 23, "lines_coords": [[[389.0, 870.0], [406.0, 870.0], [408.0, 970.0], [390.0, 970.0]]], "lines": ["名前は名越"]}, {"box": [363, 1018, 412, 1119], "vertical": true, "font_size": 23, "lines_coords": [[[392.0, 1020.0], [412.0, 1020.0], [412.0, 1119.0], [392.0, 1119.0]], [[363.0, 1018.0], [395.0, 1018.0], [395.0, 1074.0], [363.0, 1074.0]]], "lines": ["年齢は推定", "３４歳。"]}, {"box": [25, 986, 96, 1157], "vertical": true, "font_size": 22, "lines_coords": [[[70.0, 986.0], [93.0, 986.0], [96.0, 1133.0], [72.0, 1133.0]], [[48.0, 986.0], [71.0, 986.0], [71.0, 1157.0], [48.0, 1157.0]], [[25.0, 987.0], [45.0, 987.0], [45.0, 1092.0], [25.0, 1092.0]]], "lines": ["今はホームレス。", "昔は、ここのホテルの", "常連だった。"]}], "img_path": "116.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [767, 31, 787, 128], "vertical": true, "font_size": 20, "lines_coords": [[[767.0, 31.0], [787.0, 31.0], [787.0, 126.0], [767.0, 126.0]]], "lines": ["そして．．．"]}, {"box": [446, 24, 527, 138], "vertical": true, "font_size": 21, "lines_coords": [[[505.0, 24.0], [526.0, 24.0], [526.0, 114.0], [505.0, 114.0]], [[477.0, 24.0], [498.0, 24.0], [498.0, 138.0], [477.0, 138.0]], [[446.0, 24.0], [467.0, 24.0], [470.0, 125.0], [449.0, 125.0]]], "lines": ["ウソツキ", "だってこと", "だけです。"]}, {"box": [688, 457, 773, 589], "vertical": true, "font_size": 39, "lines_coords": [[[739.0, 464.0], [773.0, 464.0], [773.0, 557.0], [739.0, 557.0]], [[688.0, 459.0], [731.0, 457.0], [738.0, 587.0], [695.0, 589.0]]], "lines": ["名前は", "名越進。"]}, {"box": [219, 542, 308, 629], "vertical": true, "font_size": 46, "lines_coords": [[[260.0, 543.0], [306.0, 543.0], [306.0, 616.0], [260.0, 616.0]], [[227.0, 542.0], [273.0, 547.0], [264.0, 629.0], [219.0, 624.0]]], "lines": ["年は", "３４歳。"]}], "img_path": "117.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [431, 15, 499, 130], "vertical": true, "font_size": 18, "lines_coords": [[[479.0, 15.0], [499.0, 15.0], [497.0, 126.0], [477.0, 126.0]], [[456.0, 16.0], [476.0, 16.0], [472.0, 130.0], [452.0, 130.0]], [[431.0, 16.0], [447.0, 16.0], [447.0, 128.0], [431.0, 128.0]]], "lines": ["２週間前から", "一流ホテルと", "公園の狭間で、"]}, {"box": [446, 141, 487, 283], "vertical": true, "font_size": 18, "lines_coords": [[[446.0, 141.0], [463.0, 141.0], [463.0, 283.0], [446.0, 283.0]], [[471.0, 150.0], [487.0, 150.0], [487.0, 283.0], [471.0, 283.0]]], "lines": ["をしている．．．", "カーホームレス"]}, {"box": [193, 375, 266, 530], "vertical": true, "font_size": 33, "lines_coords": [[[230.0, 375.0], [263.0, 375.0], [266.0, 530.0], [233.0, 530.0]], [[193.0, 376.0], [226.0, 376.0], [228.0, 514.0], [195.0, 514.0]]], "lines": ["それだけで", "十分だろ。"]}, {"box": [144, 956, 228, 1040], "vertical": true, "font_size": 43, "lines_coords": [[[182.0, 956.0], [228.0, 959.0], [222.0, 1033.0], [177.0, 1030.0]], [[144.0, 959.0], [185.0, 958.0], [187.0, 1039.0], [146.0, 1040.0]]], "lines": ["十分", "です。"]}], "img_path": "118.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [612, 38, 687, 214], "vertical": true, "font_size": 24, "lines_coords": [[[655.0, 38.0], [687.0, 38.0], [687.0, 86.0], [655.0, 86.0]], [