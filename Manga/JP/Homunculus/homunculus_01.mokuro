 154.0]], [[351.0, 12.0], [368.0, 12.0], [368.0, 182.0], [351.0, 182.0]], [[327.0, 11.0], [347.0, 11.0], [347.0, 188.0], [327.0, 188.0]]], "lines": ["科学的な見地に", "立つ僕にとって、", "第六感やら心霊やら", "オカルト的なものは、"]}, {"box": [121, 28, 179, 152], "vertical": true, "font_size": 26, "lines_coords": [[[151.0, 29.0], [179.0, 29.0], [179.0, 145.0], [151.0, 145.0]], [[121.0, 28.0], [146.0, 28.0], [148.0, 152.0], [124.0, 152.0]]], "lines": ["ウザイだけ", "なんですよ。"]}, {"box": [432, 508, 531, 668], "vertical": true, "font_size": 20, "lines_coords": [[[511.0, 509.0], [531.0, 509.0], [531.0, 660.0], [511.0, 660.0]], [[486.0, 508.0], [506.0, 508.0], [506.0, 644.0], [486.0, 644.0]], [[458.0, 508.0], [478.0, 508.0], [478.0, 667.0], [458.0, 667.0]], [[432.0, 508.0], [451.0, 508.0], [453.0, 608.0], [434.0, 608.0]]], "lines": ["僕の中で抱えてる", "ウザイ可能性を", "片っ端から潰して、", "胸をはって、"]}, {"box": [720, 714, 790, 832], "vertical": true, "font_size": 20, "lines_coords": [[[765.0, 714.0], [790.0, 714.0], [790.0, 778.0], [765.0, 778.0]], [[743.0, 717.0], [763.0, 717.0], [763.0, 832.0], [743.0, 832.0]], [[721.0, 718.0], [737.0, 718.0], [737.0, 813.0], [721.0, 813.0]]], "lines": ["だから", "今回の実験で", "証明したい"]}, {"box": [629, 845, 647, 885], "vertical": true, "font_size": 18, "lines_coords": [[[629.0, 845.0], [647.0, 845.0], [647.0, 885.0], [629.0, 885.0]]], "lines": ["！"]}, {"box": [96, 758, 152, 840], "vertical": true, "font_size": 28, "lines_coords": [[[120.0, 758.0], [152.0, 758.0], [152.0, 813.0], [120.0, 813.0]], [[96.0, 760.0], [121.0, 760.0], [121.0, 840.0], [96.0, 840.0]]], "lines": ["否定", "したい。"]}], "img_path": "200.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [617, 387, 736, 542], "vertical": true, "font_size": 20, "lines_coords": [[[716.0, 390.0], [736.0, 390.0], [736.0, 468.0], [716.0, 468.0]], [[692.0, 390.0], [712.0, 390.0], [712.0, 506.0], [692.0, 506.0]], [[667.0, 389.0], [687.0, 389.0], [687.0, 542.0], [667.0, 542.0]], [[646.0, 390.0], [662.0, 390.0], [662.0, 542.0], [646.0, 542.0]], [[617.0, 387.0], [638.0, 387.0], [638.0, 453.0], [617.0, 453.0]]], "lines": ["それには", "存在を信じて", "取り組むからこそ", "信じてないという", "ことか"]}, {"box": [133, 420, 181, 500], "vertical": true, "font_size": 23, "lines_coords": [[[160.0, 423.0], [180.0, 423.0], [180.0, 500.0], [160.0, 500.0]], [[133.0, 420.0], [159.0, 420.0], [159.0, 471.0], [133.0, 471.0]]], "lines": ["ごちそう", "さん。"]}, {"box": [640, 604, 732, 723], "vertical": true, "font_size": 20, "lines_coords": [[[706.0, 605.0], [732.0, 605.0], [732.0, 666.0], [706.0, 666.0]], [[685.0, 604.0], [706.0, 604.0], [704.0, 723.0], [683.0, 723.0]], [[660.0, 604.0], [680.0, 604.0], [680.0, 721.0], [660.0, 721.0]], [[640.0, 608.0], [656.0, 608.0], [656.0, 708.0], [640.0, 708.0]]], "lines": ["本当の", "「信じてない」", "ということに", "なるんです"]}, {"box": [136, 789, 155, 854], "vertical": true, "font_size": 19, "lines_coords": [[[136.0, 789.0], [155.0, 789.0], [155.0, 854.0], [136.0, 854.0]]], "lines": ["．．．．．．？"]}], "img_path": "201.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [742, 53, 789, 141], "vertical": true, "font_size": 24, "lines_coords": [[[762.0, 53.0], [789.0, 53.0], [789.0, 99.0], [762.0, 99.0]], [[742.0, 57.0], [762.0, 57.0], [762.0, 140.0], [742.0, 140.0]]], "lines": ["まあ", "いいです。"]}, {"box": [602, 9, 646, 106], "vertical": true, "font_size": 20, "lines_coords": [[[626.0, 9.0], [646.0, 9.0], [646.0, 106.0], [626.0, 106.0]], [[602.0, 9.0], [622.0, 9.0], [622.0, 92.0], [602.0, 92.0]]], "lines": ["まだ９日間", "あります"]}, {"box": [272, 58, 366, 155], "vertical": true, "font_size": 20, "lines_coords": [[[341.0, 58.0], [366.0, 58.0], [366.0, 121.0], [341.0, 121.0]], [[321.0, 62.0], [337.0, 62.0], [337.0, 155.0], [321.0, 155.0]], [[294.0, 60.0], [315.0, 60.0], [315.0, 137.0], [294.0, 137.0]], [[272.0, 60.0], [291.0, 60.0], [291.0, 142.0], [272.0, 142.0]]], "lines": ["明日は", "超能力系を", "集中的に", "やります"]}, {"box": [773, 760, 810, 825], "vertical": true, "font_size": 37, "lines_coords": [[[773.0, 760.0], [810.0, 760.0], [810.0, 825.0], [773.0, 825.0]]], "lines": ["あっ、"]}, {"box": [649, 739, 719, 873], "vertical": true, "font_size": 19, "lines_coords": [[[698.0, 739.0], [719.0, 739.0], [717.0, 819.0], [696.0, 819.0]], [[672.0, 739.0], [692.0, 739.0], [691.0, 873.0], [671.0, 873.0]], [[650.0, 741.0], [667.0, 741.0], [667.0, 853.0], [650.0, 853.0]]], "lines": ["ちょうど", "ＥＳＰカードが", "あるので．．．"]}, {"box": [377, 591, 395, 655], "vertical": true, "font_size": 18, "lines_coords": [[[377.0, 591.0], [395.0, 591.0], [395.0, 655.0], [377.0, 655.0]]], "lines": ["．．．．．．"]}, {"box": [276, 737, 322, 897], "vertical": true, "font_size": 22, "lines_coords": [[[298.0, 739.0], [322.0, 739.0], [322.0, 864.0], [298.0, 864.0]], [[276.0, 737.0], [296.0, 737.0], [296.0, 896.0], [276.0, 896.0]]], "lines": ["一つ、ゲームを", "やってみましょう。"]}, {"box": [182, 741, 204, 837], "vertical": true, "font_size": 20, "lines_coords": [[[182.0, 741.0], [202.0, 741.0], [202.0, 836.0], [182.0, 836.0]]], "lines": ["ゲーム．．．？"]}, {"box": [671, 1012, 721, 1053], "vertical": false, "font_size": 41, "lines_coords": [[[671.0, 1012.0], [721.0, 1012.0], [721.0, 1053.0], [671.0, 1053.0]]], "lines": ["ヲヲ"]}, {"box": [503, 1012, 570, 1134], "vertical": true, "font_size": 17, "lines_coords": [[[552.0, 1014.0], [568.0, 1014.0], [568.0, 1127.0], [552.0, 1127.0]], [[524.0, 1012.0], [544.0, 1012.0], [546.0, 1128.0], [526.0, 1128.0]], [[504.0, 1016.0], [520.0, 1016.0], [520.0, 1134.0], [504.0, 1134.0]]], "lines": ["最後に明日の", "予行演習じゃ", "ないですけど、"]}], "img_path": "202.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [586, 64, 644, 126], "vertical": true, "font_size": 34, "lines_coords": [[[612.0, 65.0], [644.0, 65.0], [644.0, 117.0], [612.0, 117.0]], [[586.0, 64.0], [621.0, 64.0], [621.0, 126.0], [586.0, 126.0]]], "lines": ["簡単", "です。"]}, {"box": [451, 25, 526, 112], "vertical": true, "font_size": 23, "lines_coords": [[[501.0, 26.0], [526.0, 26.0], [526.0, 104.0], [501.0, 104.0]], [[479.0, 28.0], [500.0, 28.0], [500.0, 104.0], [479.0, 104.0]], [[451.0, 25.0], [477.0, 25.0], [479.0, 112.0], [453.0, 112.0]]], "lines": ["５種類の", "カードが", "５枚ずつ、"]}, {"box": [349, 45, 396, 127], "vertical": true, "font_size": 23, "lines_coords": [[[370.0, 45.0], [396.0, 45.0], [396.0, 107.0], [370.0, 107.0]], [[349.0, 45.0], [365.0, 45.0], [365.0, 127.0], [349.0, 127.0]]], "lines": ["計２枚", "あります"]}, {"box": [56, 72, 155, 171], "vertical": true, "font_size": 24, "lines_coords": [[[130.0, 73.0], [155.0, 73.0], [155.0, 137.0], [130.0, 137.0]], [[104.0, 73.0], [128.0, 72.0], [131.0, 152.0], [106.0, 153.0]], [[84.0, 73.0], [105.0, 73.0], [103.0, 171.0], [82.0, 171.0]], [[58.0, 72.0], [83.0, 72.0], [80.0, 160.0], [56.0, 160.0]]], "lines": ["これを", "裏返して", "ランダムに", "並べます。"]}, {"box": [592, 720, 706, 893], "vertical": true, "font_size": 25, "lines_coords": [[[675.0, 720.0], [706.0, 720.0], [706.0, 774.0], [675.0, 774.0]], [[651.0, 726.0], [672.0, 726.0], [672.0, 839.0], [651.0, 839.0]], [[619.0, 723.0], [643.0, 723.0], [646.0, 863.0], [621.0, 863.0]], [[592.0, 721.0], [615.0, 721.0], [617.0, 892.0], [594.0, 892.0]]], "lines": ["後は", "この中から", "星のカードを", "当てるだけです。"]}], "img_path": "203.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [655, 22, 728, 150], "vertical": true, "font_size": 24, "lines_coords": [[[706.0, 25.0], [728.0, 25.0], [728.0, 121.0], [706.0, 121.0]], [[683.0, 25.0], [703.0, 25.0], [703.0, 150.0], [683.0, 150.0]], [[655.0, 22.0], [685.0, 22.0], [685.0, 77.0], [655.0, 77.0]]], "lines": ["５回引いて", "何回当たるか", "です。"]}, {"box": [301, 14, 419, 205], "vertical": true, "font_size": 19, "lines_coords": [[[397.0, 15.0], [417.0, 15.0], [417.0, 203.0], [397.0, 203.0]], [[376.0, 16.0], [392.0, 16.0], [392.0, 202.0], [376.0, 202.0]], [[350.0, 15.0], [370.0, 15.0], [370.0, 130.0], [350.0, 130.0]], [[325.0, 15.0], [345.0, 15.0], [345.0, 150.0], [325.0, 150.0]], [[301.0, 14.0], [321.0, 14.0], [322.0, 194.0], [302.0, 194.0]]], "lines": ["１枚引いて当たる確率は", "もちろん５分の１ですが、", "５枚すべてが", "星