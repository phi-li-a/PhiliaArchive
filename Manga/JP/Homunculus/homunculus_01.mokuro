8.0, 825.0], [428.0, 864.0], [91.0, 864.0]], [[400.0, 712.0], [464.0, 733.0], [425.0, 849.0], [362.0, 828.0]], [[96.0, 847.0], [427.0, 847.0], [427.0, 875.0], [96.0, 875.0]], [[99.0, 880.0], [285.0, 880.0], [285.0, 895.0], [99.0, 895.0]], [[97.0, 903.0], [423.0, 902.0], [423.0, 918.0], [97.0, 919.0]], [[97.0, 926.0], [439.0, 922.0], [439.0, 942.0], [97.0, 946.0]], [[370.0, 878.0], [435.0, 878.0], [435.0, 895.0], [370.0, 895.0]], [[99.0, 973.0], [330.0, 973.0], [330.0, 989.0], [99.0, 989.0]], [[99.0, 996.0], [349.0, 996.0], [349.0, 1011.0], [99.0, 1011.0]], [[380.0, 973.0], [443.0, 973.0], [443.0, 985.0], [380.0, 985.0]]], "lines": ["カスピリッッコミックス好評発売中／", "美味しんぼ（雁屋哲・花咲アキラ）．．．！〜", "ギャラリーフェイク（細野不二度）．．．１〜", "日露戦争物語（江川達也）：２０世紀小布（浦浜市総．．．", "２０世紀少年（浦沢直樹．．．．．．．．．．．．！", "昴スバル（普田正．．．．．．そうだなぁと思ってたのか", "格闘太陽伝ガチ（青山広美）．．．そうだなぁと思ってるんだよ", "８ェイト（上條淳土）．．．．．．．．．", "．．．", "アグネス仮面（ヒラマツミノル．．．．．．！", "オメガトライプ（玉井雪雄）．．．．．．．", "高校アフロ田中（のりつけ雅春！！．．．！〜", "高校アプロ出ていたので、ティーンズブルーストコーシャの練習については", "フィーンへのつゆダク（朝ユキ蔵）．．．ーーーッ．．．ああ！！これからはいいの", "てんねん（吉田聡）", "８３", "ＧＯＧＯ！生活非安全課（ロドリゲス井之介）．．．", "１", "「トンコだトメイク", "正義の味方モンキーズ（山本康人．．．．．．", "ナイトクレイパー竜一（稲光仲．．．", "保土ヶ谷最中速派セブ死パノ（土島舌丸）ショップ（中野ハジメリ．．．全", "いや、そりゃ．．．今日．．", "Ｔバイ（古屋兎丸）．．．", "ペットに宅乱丈）．．．", "ＭｙＦａｖｏｒｉｅＢＩＫＥ（山口かつみ）．．．．．．", "Ｊ．ｂｏｙｓｅｃｏｎｄｓｅａｓｏｎ（能像純一）・．．．．．．", "．．．１〜３", "マリオガン（木葉功ーーー．．．", "ホムンクルス（山本英夫．．．．．．", "．．．"]}, {"box": [149, 1109, 406, 1129], "vertical": false, "font_size": 18, "lines_coords": [[[152.0, 1107.0], [402.0, 1110.0], [402.0, 1129.0], [152.0, 1127.0]]], "lines": ["ＢｏｏｋｐＥＳＩＣＮ：ＴＡＫＡＨＡＳＨＬＩＵＮＩ"]}], "img_path": "003.png"}, {"version": "0.1.7", "img_width": 567, "img_height": 1200, "blocks": [{"box": [108, 147, 317, 210], "vertical": false, "font_size": 63, "lines_coords": [[[108.0, 147.0], [317.0, 147.0], [317.0, 210.0], [108.0, 210.0]]], "lines": ["山本英夫"]}, {"box": [369, 160, 466, 194], "vertical": false, "font_size": 34, "lines_coords": [[[369.0, 160.0], [466.0, 160.0], [466.0, 194.0], [369.0, 194.0]]], "lines": ["著作集"]}, {"box": [379, 271, 465, 288], "vertical": false, "font_size": 17, "lines_coords": [[[379.0, 271.0], [465.0, 271.0], [465.0, 288.0], [379.0, 288.0]]], "lines": ["・１集発売中"]}, {"box": [108, 387, 434, 405], "vertical": false, "font_size": 16, "lines_coords": [[[108.0, 387.0], [434.0, 389.0], [434.0, 405.0], [108.0, 404.0]]], "lines": ["エースピリッツコミックス好評発売中／"]}, {"box": [105, 433, 448, 475], "vertical": false, "font_size": 18.0, "lines_coords": [[[106.0, 433.0], [448.0, 433.0], [448.0, 453.0], [106.0, 453.0]], [[105.0, 459.0], [255.0, 459.0], [255.0, 475.0], [105.0, 475.0]]], "lines": ["ＪＩＧＯＲＯ！！浦沢直樹）．．．．．．いいいかいいのか。", "Ｈａｐｐｙ！（浦沢直樹）"]}, {"box": [105, 505, 406, 638], "vertical": false, "font_size": 15.333333333333334, "lines_coords": [[[105.0, 505.0], [384.0, 506.0], [384.0, 522.0], [105.0, 521.0]], [[106.0, 529.0], [369.0, 529.0], [369.0, 544.0], [106.0, 544.0]], [[106.0, 553.0], [393.0, 553.0], [393.0, 568.0], [106.0, 568.0]], [[106.0, 576.0], [402.0, 576.0], [402.0, 591.0], [106.0, 591.0]], [[105.0, 600.0], [353.0, 600.0], [353.0, 615.0], [105.0, 615.0]], [[106.0, 622.0], [406.0, 622.0], [406.0, 638.0], [106.0, 638.0]]], "lines": ["１４歳（楳図かずお）・それでも、それはそれだけではないのですが、", "東京大学物語（江川蓮也．．．．．．", "花園メリーゴーランド〈柏木ハルコ〉．．．", "おたんこナース（佐々木倫子震寿小林光恵♪．．．", "奈緒子（坂田信弘・中原裕）．．．", "奈緒子新たなる疾風〈坂田信弘中原裕〉．．．"]}, {"box": [107, 648, 291, 659], "vertical": false, "font_size": 11, "lines_coords": [[[107.0, 648.0], [291.0, 648.0], [291.0, 659.0], [107.0, 659.0]]], "lines": ["男樹（本宮ひろ志）．．．．．．"]}, {"box": [104, 691, 369, 754], "vertical": false, "font_size": 15.666666666666666, "lines_coords": [[[105.0, 691.0], [291.0, 692.0], [291.0, 708.0], [105.0, 707.0]], [[104.0, 716.0], [369.0, 714.0], [369.0, 730.0], [104.0, 731.0]], [[107.0, 739.0], [369.0, 739.0], [369.0, 754.0], [107.0, 754.0]]], "lines": ["Ｊｂｏｙ（能像純一）．．．", "最終兵器彼女（高橋しん）．．．．．．", "しっぷうどとう（盛田賢司）．．．"]}, {"box": [0, 247, 615, 1069], "vertical": false, "font_size": 213.5, "lines_coords": [[[107.0, 247.0], [274.0, 247.0], [274.0, 263.0], [107.0, 263.0]], [[107.0, 270.0], [237.0, 270.0], [237.0, 287.0], [107.0, 287.0]], [[0.0, 261.0], [615.0, 264.0], [610.0, 1069.0], [0.0, 1066.0]], [[105.0, 667.0], [346.0, 670.0], [346.0, 685.0], [105.0, 683.0]]], "lines": ["『ビックコミックス』パックルストレスに", "最近ツグコミックスホムンツルス．．．", "それはそうですね", "参加予定は日本では、中国の家族や家族の家庭教師のお客さんのお母さんがいただきました。月下の時には、１１日の時間は１７時間半分からかかりますが、１０００万円以上です。"]}, {"box": [98, 785, 448, 873], "vertical": false, "font_size": 21.5, "lines_coords": [[[106.0, 785.0], [274.0, 785.0], [274.0, 800.0], [106.0, 800.0]], [[106.0, 809.0], [369.0, 809.0], [369.0, 825.0], [106.0, 825.0]], [[98.0, 816.0], [447.0, 820.0], [447.0, 855.0], [98.0, 851.0]], [[383.0, 853.0], [448.0, 853.0], [448.0, 873.0], [383.0, 873.0]]], "lines": ["僕（山本康人）．．．．．．", "疾風迅雷（もりやまつる）．．．．．．", "教風風呂付けりやすっる．．．", "全５巻"]}, {"box": [106, 854, 448, 894], "vertical": false, "font_size": 15.5, "lines_coords": [[[106.0, 854.0], [358.0, 854.0], [358.0, 869.0], [106.0, 869.0]], [[106.0, 878.0], [448.0, 878.0], [448.0, 894.0], [106.0, 894.0]]], "lines": ["サユリ１号（村上かっら）．．．．．．", "ショートカッツ（古屋兎丸い．．．"]}, {"box": [104, 924, 463, 964], "vertical": false, "font_size": 16.5, "lines_coords": [[[106.0, 924.0], [461.0, 924.0], [461.0, 941.0], [106.0, 941.0]], [[104.0, 948.0], [463.0, 948.0], [463.0, 964.0], [104.0, 964.0]]], "lines": ["ショコラ（窪之内英策）：．．．いい．．", "猿ＭＯＮＥＹ（木村清輝＊郷本〈兜公司〉．．．。１〜２集"]}, {"box": [108, 1095, 458, 1140], "vertical": false, "font_size": 17, "lines_coords": [[[127.0, 1096.0], [439.0, 1098.0], [439.0, 1115.0], [127.0, 1114.0]], [[108.0, 1120.0], [458.0, 1121.0], [458.0, 1137.0], [108.0, 1136.0]]], "lines": ["インターネットでビッグコミックスが購入できます。", "わたくしはっ．．．いいのかなｂｉｃｐｏｒｍｉｃｓ．ｓｈｃｏｐｋｉｋａｎ．ｃｏ．"]}], "img_path": "004.png"}, {"version": "0.1.7", "img_width": 1777, "img_height": 1200, "blocks": [], "img_path": "005.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [161, 544, 211, 568], "vertical": false, "font_size": 22, "lines_coords": [[[161.0, 547.0], [209.0, 544.0], [211.0, 566.0], [162.0, 568.0]]], "lines": ["Ｅｎｕｎｃｕｌｕｓ"]}, {"box": [32, 638, 127, 996], 