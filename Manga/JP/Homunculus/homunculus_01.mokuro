l": true, "font_size": 20, "lines_coords": [[[425.0, 670.0], [445.0, 670.0], [445.0, 746.0], [425.0, 746.0]], [[403.0, 670.0], [423.0, 670.0], [423.0, 825.0], [403.0, 825.0]], [[378.0, 669.0], [398.0, 669.0], [397.0, 805.0], [377.0, 805.0]], [[354.0, 670.0], [374.0, 670.0], [374.0, 840.0], [354.0, 840.0]]], "lines": ["オレ達の", "集めてきたメシを", "うまいこと調理", "するんだわ、これが。"]}, {"box": [75, 782, 131, 839], "vertical": true, "font_size": 32, "lines_coords": [[[99.0, 783.0], [131.0, 783.0], [131.0, 833.0], [99.0, 833.0]], [[77.0, 782.0], [109.0, 783.0], [106.0, 839.0], [75.0, 837.0]]], "lines": ["んだ", "んだ。"]}, {"box": [597, 918, 739, 1073], "vertical": true, "font_size": 21, "lines_coords": [[[715.0, 919.0], [739.0, 919.0], [739.0, 980.0], [715.0, 980.0]], [[692.0, 922.0], [712.0, 922.0], [712.0, 1017.0], [692.0, 1017.0]], [[668.0, 922.0], [688.0, 922.0], [688.0, 1034.0], [668.0, 1034.0]], [[638.0, 919.0], [664.0, 918.0], [667.0, 986.0], [641.0, 987.0]], [[620.0, 921.0], [640.0, 921.0], [640.0, 1073.0], [620.0, 1073.0]], [[597.0, 921.0], [614.0, 921.0], [614.0, 1000.0], [597.0, 1000.0]]], "lines": ["しかし", "賞味期限が", "切れたモンや", "残飯を、", "あそこまでの味に", "するたあ"]}, {"box": [102, 1011, 175, 1129], "vertical": true, "font_size": 24, "lines_coords": [[[146.0, 1011.0], [175.0, 1011.0], [175.0, 1075.0], [146.0, 1075.0]], [[120.0, 1012.0], [145.0, 1012.0], [148.0, 1129.0], [124.0, 1129.0]], [[102.0, 1013.0], [121.0, 1013.0], [121.0, 1099.0], [102.0, 1099.0]]], "lines": ["やっぱ", "プロの技って", "ヤツだな。"]}], "img_path": "032.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [555, 243, 695, 394], "vertical": true, "font_size": 25, "lines_coords": [[[670.0, 247.0], [695.0, 247.0], [695.0, 362.0], [670.0, 362.0]], [[640.0, 246.0], [664.0, 246.0], [667.0, 360.0], [642.0, 360.0]], [[612.0, 243.0], [640.0, 243.0], [637.0, 394.0], [609.0, 394.0]], [[583.0, 246.0], [608.0, 246.0], [608.0, 339.0], [583.0, 339.0]], [[555.0, 246.0], [579.0, 246.0], [579.0, 391.0], [555.0, 391.0]]], "lines": ["アレだって", "建てる時は", "オレ達職人が", "命かけて", "作ったんだゾ。"]}, {"box": [93, 236, 206, 450], "vertical": true, "font_size": 25, "lines_coords": [[[180.0, 239.0], [204.0, 239.0], [204.0, 400.0], [180.0, 400.0]], [[147.0, 236.0], [175.0, 236.0], [179.0, 450.0], [151.0, 450.0]], [[123.0, 240.0], [147.0, 240.0], [147.0, 333.0], [123.0, 333.0]], [[93.0, 237.0], [117.0, 237.0], [117.0, 446.0], [93.0, 446.0]]], "lines": ["終わっちまえば", "用ナシにしやがって、", "国は一体", "どうなってるんだ！"]}, {"box": [616, 512, 698, 705], "vertical": true, "font_size": 23, "lines_coords": [[[672.0, 512.0], [696.0, 512.0], [698.0, 696.0], [675.0, 696.0]], [[647.0, 515.0], [668.0, 515.0], [668.0, 626.0], [647.0, 626.0]], [[616.0, 515.0], [640.0, 515.0], [640.0, 705.0], [616.0, 705.0]]], "lines": ["今の政治家だって", "ロクなヤツ", "いないじゃないか。"]}, {"box": [648, 752, 710, 941], "vertical": true, "font_size": 24, "lines_coords": [[[683.0, 753.0], [708.0, 753.0], [710.0, 941.0], [685.0, 941.0]], [[648.0, 752.0], [672.0, 752.0], [677.0, 925.0], [653.0, 925.0]]], "lines": ["悪いことやったって", "国会の喚問じゃ、"]}, {"box": [400, 750, 470, 909], "vertical": true, "font_size": 19, "lines_coords": [[[451.0, 752.0], [467.0, 752.0], [467.0, 908.0], [451.0, 908.0]], [[425.0, 751.0], [445.0, 751.0], [445.0, 871.0], [425.0, 871.0]], [[400.0, 750.0], [422.0, 750.0], [423.0, 847.0], [402.0, 847.0]]], "lines": ["記憶にございません", "「わかりません」", "ばかりでよ。"]}, {"box": [113, 782, 167, 836], "vertical": true, "font_size": 32, "lines_coords": [[[134.0, 783.0], [167.0, 783.0], [167.0, 832.0], [134.0, 832.0]], [[113.0, 782.0], [144.0, 782.0], [144.0, 836.0], [113.0, 836.0]]], "lines": ["んだ", "んだ。"]}], "img_path": "033.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [694, 41, 746, 179], "vertical": true, "font_size": 22, "lines_coords": [[[722.0, 41.0], [745.0, 41.0], [745.0, 179.0], [722.0, 179.0]], [[694.0, 42.0], [715.0, 42.0], [715.0, 118.0], [694.0, 118.0]]], "lines": ["オレだったら", "言うね。"]}, {"box": [318, 8, 389, 242], "vertical": true, "font_size": 32, "lines_coords": [[[356.0, 16.0], [388.0, 16.0], [388.0, 242.0], [356.0, 242.0]], [[318.0, 9.0], [351.0, 9.0], [351.0, 101.0], [318.0, 101.0]]], "lines": ["私がやりました」", "って！！"]}, {"box": [124, 5, 216, 168], "vertical": true, "font_size": 19, "lines_coords": [[[196.0, 7.0], [216.0, 7.0], [216.0, 140.0], [196.0, 140.0]], [[171.0, 5.0], [191.0, 5.0], [192.0, 168.0], [172.0, 168.0]], [[150.0, 9.0], [166.0, 9.0], [166.0, 141.0], [150.0, 141.0]], [[124.0, 8.0], [144.0, 8.0], [144.0, 89.0], [124.0, 89.0]]], "lines": ["そいに自民党の", "土井真紀子ってのは", "処女だっていう", "噂でねが"]}, {"box": [490, 447, 522, 500], "vertical": true, "font_size": 32, "lines_coords": [[[490.0, 447.0], [522.0, 447.0], [522.0, 500.0], [490.0, 500.0]]], "lines": ["カサ"]}, {"box": [678, 624, 803, 783], "vertical": true, "font_size": 23, "lines_coords": [[[766.0, 626.0], [798.0, 624.0], [803.0, 679.0], [771.0, 683.0]], [[751.0, 630.0], [771.0, 630.0], [771.0, 728.0], [751.0, 728.0]], [[726.0, 630.0], [746.0, 630.0], [746.0, 783.0], [726.0, 783.0]], [[701.0, 629.0], [724.0, 629.0], [724.0, 757.0], [701.0, 757.0]], [[678.0, 631.0], [698.0, 631.0], [698.0, 731.0], [678.0, 731.0]]], "lines": ["あれ、", "真紀子は昔", "男と付き合ってた", "って、テレビで", "やってたゾ"]}, {"box": [556, 612, 581, 705], "vertical": true, "font_size": 25, "lines_coords": [[[556.0, 612.0], [581.0, 612.0], [581.0, 705.0], [556.0, 705.0]]], "lines": ["本当か！？"]}, {"box": [691, 914, 774, 1062], "vertical": true, "font_size": 24, "lines_coords": [[[748.0, 914.0], [772.0, 914.0], [774.0, 1062.0], [750.0, 1062.0]], [[719.0, 916.0], [744.0, 916.0], [744.0, 1032.0], [719.0, 1032.0]], [[691.0, 914.0], [715.0, 914.0], [715.0, 1054.0], [691.0, 1054.0]]], "lines": ["じゃ、処女じゃ", "ねェなぁ．．．", "う〜〜ん．．．"]}, {"box": [368, 914, 419, 1013], "vertical": true, "font_size": 21, "lines_coords": [[[396.0, 916.0], [417.0, 916.0], [417.0, 1005.0], [396.0, 1005.0]], [[368.0, 914.0], [389.0, 914.0], [390.0, 1012.0], [369.0, 1012.0]]], "lines": ["ごちそう", "さまです"]}], "img_path": "034.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [699, 164, 746, 263], "vertical": true, "font_size": 24, "lines_coords": [[[725.0, 166.0], [746.0, 166.0], [746.0, 263.0], [725.0, 263.0]], [[699.0, 164.0], [726.0, 164.0], [726.0, 216.0], [699.0, 216.0]]], "lines": ["うまかった", "です。"]}, {"box": [365, 32, 393, 82], "vertical": true, "font_size": 28, "lines_coords": [[[365.0, 32.0], [393.0, 32.0], [393.0, 82.0], [365.0, 82.0]]], "lines": ["いや。"]}, {"box": [451, 119, 499, 283], "vertical": true, "font_size": 24, "lines_coords": [[[470.0, 119.0], [499.0, 119.0], [499.0, 183.0], [470.0, 183.0]], [[451.0, 121.0], [471.0, 121.0], [471.0, 283.0], [451.0, 283.0]]], "lines": ["さすが", "元イタさんですね。"]}, {"box": [355, 201, 388, 255], "vertical": true, "font_size": 33, "lines_coords": [[[355.0, 201.0], [388.0, 201.0], [388.0, 255.0], [355.0, 255.0]]], "lines": ["へへ。"]}, {"box": [374, 386, 494, 486], "vertical": true, "font_size": 21, "lines_coords": [[[473.0, 389.0], [493.0, 389.0], [493.0, 486.0], [473.0, 486.0]], [[450.0, 387.0], [471.0, 387.0], [468.0, 465.0], [447.0, 465.0]], [[425.0, 389.0], [445.0, 389.0], [445.0, 467.0], [425.0, 467.0]], [[398.0, 386.0], [423.0, 386.0], [423.0, 467.0], [398.0, 467.0]], [[376.0, 387.0], [397.0, 387.0], [395.0, 466.0], [374.0, 466.0]]], "lines": ["にいさんは", "車関係の", "仕事でも", "してたん", "ですか？"]}, {"box": [136, 349, 162, 399], "vertical": true, "font_size": 26, "lines_coords": [[[136.0, 349.0], [162.0, 349.0], [162.0, 399.0], [136.0, 399.0]]], "lines": ["え？"]}, {"box": [678, 825, 751, 948], "vertical": true, "font_size": 24, "lines_coords": [[[724.0, 825.0], [751.0, 825.0], [751.0, 877.0], [724.0, 877.0]], [[703.0, 828.0], [723.0, 828.0], [723.0, 942.0], [703.0, 942.0]], [[678.0, 828.0], [698.0, 828.0], [698.0, 948.0], [678.0, 948.0]]], "lines": ["ほら、", "さっき器用に", "直してたから"]}, {"box": [300, 725, 350, 837], "vertical": true, "font_size": 21, "lines_coords": [[[327.0, 725.0], [348.0, 725.0], [348.0, 836.0], [327.0, 836.0]], [[300.0, 725.0], [321.0, 725.0], [321.0, 825.0], [300.0, 825.0]]], "lines": ["よくわかり", "ましたね。"]}, {"box": [601, 903, 638, 950], "vertical": true, "font_size": 24, "lines_coords": [[[601.0, 908.0], [631.0, 903.0], [638.0, 945.0], [608.0, 950.0]]], "lines": ["車。"]}], "img_path": "035.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [752, 77, 817, 223], "vertical": true, "font_size": 21, "lines_coords": [[[792.0, 77.0], [817.0, 77.0], [817.0, 142.0], [792.0, 142.0]], [[772.0, 77.0], [792.0, 77.0], [792.0, 183.0], [772.0, 183.0]], [[752.0, 78.0], [769.0, 78.0], [769.0, 221.0], [752.0, 221.0]]], "lines": ["いや、昔", "知り合いにも", "車屋がいましてね。"]}, {"box": [442, 41, 534, 193], "vertical": true, "font_size": 20, "lines_coords": [[[514.0, 42.0], [534.0, 42.0], [534.0, 157.0], [514.0, 157.0]], [[490.0, 41.0], [510.0, 41.0], [510.0, 164.0], [490.0, 164.0]], [[466.0, 41.0], [486.0, 41.0], [486.0, 193.0], [466.0, 193.0]], [[442.0, 41.0], [461.0, 41.0], [461.0, 181.0], [442.0, 181.0]]], "lines": ["エンジンの音", "聞いただけで、", "その車の悪い所が", "わかるんですよ。"]}, {"box": [98, 58, 191, 212], "vertical": true, "font_size": 21, "lines_coords": [[[168.0, 59.0], [188.0, 59.0], [188.0, 189.0], [168.0, 189.0]], [[144.0, 58.0], [167.0, 58.0], [167.0, 186.0], [144.0, 186.0]], [[121.0, 59.0], [141.0, 59.0], [141.0, 212.0], [121.0, 212.0]], [[98.0, 59.0], [118.0, 59.0], [118.0, 179.0], [98.0, 179.0]]], "lines": ["エンジンルーム", "開いて、悪い所", "探すようなヤツは", "シロウトです。"]}, {"box": [738, 298, 789, 454], "vertical": true, "font_size": 22, "lines_coords": [[[762.0, 298.0], [786.0, 298.0], [783.0, 454.0], [758.0, 454.0]], [[738.0, 298.0], [758.0, 298.0], [758.0, 441.0], [738.0, 441.0]]], "lines": ["「臭い」や「振動」も", "大事なんですよ。"]}, {"box": [440, 298, 511, 423], "vertical": true, "font_size": 20, "lines_coords": [[[491.0, 298.0], [511.0, 298.0], [511.0, 423.0], [491.0, 423.0]], [[466.0, 300.0], [486.0, 300.0], [486.0, 416.0], [466.0, 416.0]], [[440.0, 298.0], [460.0, 298.0], [460.0, 380.0], [440.0, 380.0]]], "lines": ["要は、その車の", "全体の雰囲気", "なんです"]}, {"box": [313, 382, 371, 438], "vertical": true, "font_size": 35, "lines_coords": [[[332.0, 382.0], [371.0, 382.0], [371.0, 431.0], [332.0, 431.0]], [[313.0, 383.0], [344.0, 382.0], [347.0, 437.0], [315.0, 438.0]]], "lines": ["はいはい", "はい。"]}, {"box": [485, 553, 556, 651], "vertical": true, "font_size": 23, "lines_coords": [[[535.0, 554.0], [556.0, 554.0], [556.0, 633.0], [535.0, 633.0]], [[512.0, 555.0], [533.0, 555.0], [533.0, 651.0], [512.0, 651.0]], [[485.0, 553.0], [512.0, 553.0], [512.0, 605.0], [485.0, 605.0]]], "lines": ["そいつも", "言ってまし", "たよ。"]}, {"box": [470, 687, 544, 834], "vertical": true, "font_size": 23, "lines_coords": [[[515.0, 687.0], [544.0, 687.0], [544.0, 734.0], [515.0, 734.0]], [[494.0, 691.0], [514.0, 691.0], [514.0, 808.0], [494.0, 808.0]], [[470.0, 691.0], [490.0, 691.0], [491.0, 834.0], [471.0, 834.0]]], "lines": ["車は", "女を扱うより", "むずかしいって。"]}, {"box": [330, 570, 373, 692], "vertical": true, "font_size": 18, "lines_coords": [[[351.0, 570.0], [371.0, 570.0], [371.0, 649.0], [351.0, 649.0]], [[330.0, 570.0], [347.0, 570.0], [347.0, 690.0], [330.0, 690.0]]], "lines": ["そうかも", "しれませんね。"]}, {"box": [136, 983, 204, 1124], "vertical": true, "font_size": 20, "lines_coords": [[[182.0, 984.0], [202.0, 984.0], [202.0, 1099.0], [182.0, 1099.0]], [[159.0, 983.0], [180.0, 983.0], [180.0, 1062.0], [159.0, 1062.0]], [[136.0, 984.0], [155.0, 984.0], [155.0, 1123.0], [136.0, 1123.0]]], "lines": ["機械を機械と", "思ったら", "大間違いですよ。"]}], "img_path": "036.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [565, 382, 677, 635], "vertical": true, "font_size": 24, "lines_coords": [[[651.0, 384.0], [675.0, 384.0], [675.0, 509.0], [651.0, 509.0]], [[623.0, 383.0], [647.0, 383.0], [644.0, 635.0], [621.0, 635.0]], [[593.0, 382.0], [617.0, 382.0], [616.0, 614.0], [592.0, 614.0]], [[565.0, 384.0], [589.0, 384.0], [589.0, 486.0], [565.0, 486.0]]], "lines": ["今の世の中、", "人間のほうが機械よりか", "よっぽど機械っぽいん", "ですから。"]}], "img_path": "037.png"}, {"version": 