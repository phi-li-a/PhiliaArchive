0], [620.0, 405.0], [620.0, 542.0], [603.0, 542.0]]], "lines": ["穴が開いてる", "状態なんですよ。"]}, {"box": [617, 643, 634, 680], "vertical": true, "font_size": 17, "lines_coords": [[[617.0, 643.0], [634.0, 643.0], [634.0, 680.0], [617.0, 680.0]]], "lines": ["！"]}, {"box": [446, 678, 522, 839], "vertical": true, "font_size": 20, "lines_coords": [[[492.0, 678.0], [515.0, 678.0], [518.0, 820.0], [494.0, 820.0]], [[472.0, 680.0], [488.0, 680.0], [488.0, 813.0], [472.0, 813.0]], [[446.0, 678.0], [466.0, 678.0], [467.0, 839.0], [447.0, 839.0]]], "lines": ["それが塞がって、", "さらには大人に", "なるにしたがって、"]}, {"box": [117, 686, 208, 822], "vertical": true, "font_size": 20, "lines_coords": [[[187.0, 689.0], [208.0, 689.0], [208.0, 765.0], [187.0, 765.0]], [[164.0, 686.0], [185.0, 686.0], [182.0, 785.0], [161.0, 785.0]], [[139.0, 689.0], [159.0, 689.0], [159.0, 822.0], [139.0, 822.0]], [[117.0, 689.0], [133.0, 689.0], [133.0, 791.0], [117.0, 791.0]]], "lines": ["頭蓋骨が", "ギューッと", "閉じていく感じ", "なんですよ。"]}, {"box": [366, 939, 484, 1120], "vertical": true, "font_size": 21, "lines_coords": [[[463.0, 941.0], [484.0, 941.0], [484.0, 1035.0], [463.0, 1035.0]], [[438.0, 939.0], [461.0, 939.0], [461.0, 1067.0], [438.0, 1067.0]], [[415.0, 939.0], [436.0, 939.0], [433.0, 1086.0], [412.0, 1086.0]], [[390.0, 941.0], [410.0, 941.0], [410.0, 1055.0], [390.0, 1055.0]], [[366.0, 939.0], [386.0, 939.0], [386.0, 1120.0], [366.0, 1120.0]]], "lines": ["よく大人が", "「オマエの頭は", "ガチガチだなあ」", "なんて表現が", "あるじゃないですか。"]}], "img_path": "146.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [616, 18, 684, 237], "vertical": true, "font_size": 19, "lines_coords": [[[664.0, 19.0], [684.0, 19.0], [684.0, 193.0], [664.0, 193.0]], [[641.0, 22.0], [657.0, 22.0], [657.0, 153.0], [641.0, 153.0]], [[616.0, 18.0], [636.0, 18.0], [636.0, 237.0], [616.0, 237.0]]], "lines": ["この閉じてしまった", "成人の頭蓋骨に", "穴を開けることによって、"]}, {"box": [448, 77, 492, 199], "vertical": true, "font_size": 18, "lines_coords": [[[471.0, 78.0], [491.0, 78.0], [491.0, 172.0], [471.0, 172.0]], [[449.0, 77.0], [465.0, 77.0], [466.0, 196.0], [450.0, 196.0]]], "lines": ["頭蓋骨内の", "圧力が変化し、"]}, {"box": [249, 442, 292, 602], "vertical": true, "font_size": 18, "lines_coords": [[[272.0, 442.0], [291.0, 442.0], [291.0, 595.0], [272.0, 595.0]], [[249.0, 444.0], [266.0, 444.0], [266.0, 598.0], [249.0, 598.0]]], "lines": ["脳に大量の血液が", "流れるようになり、"]}, {"box": [63, 380, 131, 589], "vertical": true, "font_size": 16, "lines_coords": [[[112.0, 382.0], [128.0, 382.0], [128.0, 571.0], [112.0, 571.0]], [[86.0, 380.0], [103.0, 380.0], [103.0, 588.0], [86.0, 588.0]], [[63.0, 380.0], [79.0, 380.0], [79.0, 517.0], [63.0, 517.0]]], "lines": ["脳の活性化した状態を", "取り戻すことができると", "言われています。"]}, {"box": [633, 649, 730, 823], "vertical": true, "font_size": 23, "lines_coords": [[[702.0, 649.0], [730.0, 649.0], [730.0, 693.0], [702.0, 693.0]], [[678.0, 649.0], [703.0, 649.0], [703.0, 823.0], [678.0, 823.0]], [[657.0, 651.0], [677.0, 651.0], [677.0, 805.0], [657.0, 805.0]], [[633.0, 651.0], [653.0, 651.0], [653.0, 766.0], [633.0, 766.0]]], "lines": ["要は", "大人になるにつれて", "使われなくなった", "脳ミソが．．．"]}, {"box": [422, 660, 513, 814], "vertical": true, "font_size": 18, "lines_coords": [[[494.0, 663.0], [511.0, 663.0], [511.0, 794.0], [494.0, 794.0]], [[467.0, 660.0], [487.0, 660.0], [490.0, 782.0], [470.0, 782.0]], [[445.0, 662.0], [465.0, 662.0], [465.0, 814.0], [445.0, 814.0]], [[422.0, 663.0], [438.0, 663.0], [438.0, 757.0], [422.0, 757.0]]], "lines": ["血行をよくする", "ことによって、", "再活動されるって", "わけか．．．？"]}, {"box": [36, 733, 92, 808], "vertical": true, "font_size": 26, "lines_coords": [[[63.0, 733.0], [92.0, 733.0], [92.0, 808.0], [63.0, 808.0]], [[36.0, 733.0], [60.0, 733.0], [60.0, 806.0], [36.0, 806.0]]], "lines": ["そんな", "感じ！"]}, {"box": [279, 1007, 349, 1123], "vertical": true, "font_size": 22, "lines_coords": [[[327.0, 1007.0], [348.0, 1007.0], [349.0, 1087.0], [328.0, 1087.0]], [[304.0, 1008.0], [324.0, 1008.0], [324.0, 1123.0], [304.0, 1123.0]], [[279.0, 1007.0], [303.0, 1007.0], [303.0, 1069.0], [279.0, 1069.0]]], "lines": ["すなわち", "今の名越さん", "は．．．"]}], "img_path": "147.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [570, 83, 684, 230], "vertical": true, "font_size": 25, "lines_coords": [[[660.0, 84.0], [683.0, 84.0], [683.0, 221.0], [660.0, 221.0]], [[629.0, 84.0], [654.0, 84.0], [654.0, 175.0], [629.0, 175.0]], [[600.0, 83.0], [628.0, 83.0], [628.0, 223.0], [600.0, 223.0]], [[570.0, 83.0], [595.0, 83.0], [597.0, 230.0], [573.0, 230.0]]], "lines": ["赤ん坊の頃の", "脳全体が", "活動している", "状態なんです。"]}, {"box": [551, 820, 578, 888], "vertical": true, "font_size": 25, "lines_coords": [[[551.0, 821.0], [575.0, 820.0], [578.0, 887.0], [553.0, 888.0]]], "lines": ["つまり、"]}, {"box": [131, 644, 154, 704], "vertical": true, "font_size": 23, "lines_coords": [[[131.0, 644.0], [154.0, 644.0], [154.0, 704.0], [131.0, 704.0]]], "lines": ["！"]}, {"box": [130, 800, 148, 895], "vertical": true, "font_size": 16, "lines_coords": [[[130.0, 801.0], [146.0, 801.0], [146.0, 894.0], [130.0, 894.0]]], "lines": ["そうです！"]}, {"box": [300, 817, 394, 1086], "vertical": true, "font_size": 20, "lines_coords": [[[368.0, 1007.0], [388.0, 1007.0], [388.0, 1085.0], [368.0, 1085.0]], [[349.0, 819.0], [369.0, 819.0], [369.0, 914.0], [349.0, 914.0]], [[324.0, 819.0], [344.0, 819.0], [344.0, 952.0], [324.0, 952.0]], [[300.0, 817.0], [320.0, 817.0], [321.0, 959.0], [301.0, 959.0]]], "lines": ["あれか？", "人間の脳の", "９０％は使われて", "いないっていう、"]}], "img_path": "148.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [], "img_path": "149.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [116, 52, 136, 128], "vertical": true, "font_size": 20, "lines_coords": [[[116.0, 52.0], [136.0, 52.0], [136.0, 128.0], [116.0, 128.0]]], "lines": ["．．．．．！"]}, {"box": [580, 474, 610, 520], "vertical": true, "font_size": 30, "lines_coords": [[[580.0, 474.0], [610.0, 474.0], [610.0, 520.0], [580.0, 520.0]]], "lines": ["ピク"