 ["ちょうど", "友人にもらう", "予定なので。"]}, {"box": [125, 440, 147, 526], "vertical": true, "font_size": 20, "lines_coords": [[[125.0, 440.0], [145.0, 440.0], [145.0, 525.0], [125.0, 525.0]]], "lines": ["そうかい。"]}, {"box": [477, 706, 498, 805], "vertical": true, "font_size": 18, "lines_coords": [[[477.0, 706.0], [498.0, 706.0], [498.0, 805.0], [477.0, 805.0]]], "lines": ["それより．．"]}, {"box": [364, 761, 431, 921], "vertical": true, "font_size": 18, "lines_coords": [[[409.0, 761.0], [429.0, 761.0], [431.0, 921.0], [411.0, 921.0]], [[388.0, 764.0], [404.0, 764.0], [404.0, 895.0], [388.0, 895.0]], [[364.0, 764.0], [381.0, 764.0], [381.0, 876.0], [364.0, 876.0]]], "lines": ["みんな、どうやって", "金を作ってるん", "ですかねえ？"]}, {"box": [202, 711, 222, 798], "vertical": true, "font_size": 20, "lines_coords": [[[202.0, 711.0], [222.0, 711.0], [222.0, 798.0], [202.0, 798.0]]], "lines": ["カカカか。"]}, {"box": [347, 970, 440, 1134], "vertical": true, "font_size": 22, "lines_coords": [[[418.0, 971.0], [439.0, 971.0], [440.0, 1048.0], [419.0, 1048.0]], [[395.0, 972.0], [416.0, 972.0], [416.0, 1048.0], [395.0, 1048.0]], [[371.0, 972.0], [392.0, 972.0], [392.0, 1050.0], [371.0, 1050.0]], [[347.0, 970.0], [370.0, 970.0], [370.0, 1134.0], [347.0, 1134.0]]], "lines": ["金なんて", "ねえから", "ブー太郎", "やってんだろうが。"]}], "img_path": "081.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [538, 52, 686, 290], "vertical": true, "font_size": 21, "lines_coords": [[[662.0, 52.0], [685.0, 52.0], [685.0, 169.0], [662.0, 169.0]], [[636.0, 55.0], [656.0, 55.0], [656.0, 169.0], [636.0, 169.0]], [[612.0, 53.0], [633.0, 53.0], [633.0, 159.0], [612.0, 159.0]], [[588.0, 55.0], [608.0, 55.0], [608.0, 290.0], [588.0, 290.0]], [[563.0, 56.0], [583.0, 56.0], [583.0, 255.0], [563.0, 255.0]], [[540.0, 55.0], [560.0, 55.0], [558.0, 159.0], [538.0, 159.0]]], "lines": ["まあ、中には", "カン潰したり", "本集めたり", "ダフ屋の並びやったりして、", "コツコツ金作るヤツは", "いるけどよ、"]}, {"box": [128, 154, 193, 271], "vertical": true, "font_size": 22, "lines_coords": [[[168.0, 154.0], [193.0, 154.0], [193.0, 217.0], [168.0, 217.0]], [[146.0, 155.0], [166.0, 155.0], [166.0, 271.0], [146.0, 271.0]]], "lines": ["結局は", "雀の涙ほどよ"]}, {"box": [470, 425, 539, 561], "vertical": true, "font_size": 22, "lines_coords": [[[514.0, 425.0], [539.0, 425.0], [539.0, 488.0], [514.0, 488.0]], [[492.0, 425.0], [512.0, 425.0], [513.0, 561.0], [493.0, 561.0]], [[470.0, 426.0], [490.0, 426.0], [490.0, 493.0], [470.0, 493.0]]], "lines": ["あとは", "自分を売るしか", "ねえな。"]}, {"box": [194, 399, 216, 489], "vertical": true, "font_size": 21, "lines_coords": [[[194.0, 399.0], [215.0, 399.0], [215.0, 489.0], [194.0, 489.0]]], "lines": ["自分．．．？"]}, {"box": [590, 576, 610, 682], "vertical": true, "font_size": 20, "lines_coords": [[[590.0, 576.0], [610.0, 576.0], [610.0, 682.0], [590.0, 682.0]]], "lines": ["．．．ですよね。"]}, {"box": [630, 779, 691, 924], "vertical": true, "font_size": 27, "lines_coords": [[[662.0, 780.0], [691.0, 780.0], [691.0, 864.0], [662.0, 864.0]], [[630.0, 779.0], [656.0, 779.0], [658.0, 917.0], [633.0, 917.0]]], "lines": ["戸籍や", "臓器とかな"]}, {"box": [279, 615, 314, 653], "vertical": true, "font_size": 35, "lines_coords": [[[279.0, 615.0], [314.0, 615.0], [314.0, 653.0], [279.0, 653.0]]], "lines": ["！？"]}, {"box": [233, 764, 256, 816], "vertical": true, "font_size": 23, "lines_coords": [[[233.0, 764.0], [256.0, 764.0], [256.0, 816.0], [233.0, 816.0]]], "lines": ["！"]}], "img_path": "082.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [307, 22, 463, 173], "vertical": true, "font_size": 23, "lines_coords": [[[439.0, 25.0], [463.0, 25.0], [463.0, 151.0], [439.0, 151.0]], [[410.0, 22.0], [434.0, 22.0], [438.0, 138.0], [413.0, 138.0]], [[388.0, 24.0], [408.0, 24.0], [408.0, 131.0], [388.0, 131.0]], [[361.0, 24.0], [384.0, 24.0], [384.0, 152.0], [361.0, 152.0]], [[336.0, 25.0], [356.0, 25.0], [356.0, 173.0], [336.0, 173.0]], [[307.0, 23.0], [334.0, 23.0], [334.0, 80.0], [307.0, 80.0]]], "lines": ["いい買い手が", "見つかりゃ、", "戸籍なんて", "