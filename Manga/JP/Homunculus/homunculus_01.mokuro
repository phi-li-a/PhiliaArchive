, [362.0, 343.0], [341.0, 343.0]], [[320.0, 153.0], [336.0, 153.0], [336.0, 369.0], [320.0, 369.0]]], "lines": ["人間というのは", "子供の頃には", "「感じる」ということで", "物事を学んでいけるのに、"]}, {"box": [24, 151, 118, 380], "vertical": true, "font_size": 20, "lines_coords": [[[99.0, 153.0], [116.0, 153.0], [116.0, 323.0], [99.0, 323.0]], [[73.0, 152.0], [93.0, 152.0], [93.0, 380.0], [73.0, 380.0]], [[49.0, 151.0], [69.0, 151.0], [69.0, 285.0], [49.0, 285.0]], [[24.0, 151.0], [45.0, 151.0], [46.0, 311.0], [25.0, 311.0]]], "lines": ["なぜか大人になると", "「考える」ということでしか", "学んでいけなく", "なってしまいます。"]}, {"box": [627, 528, 725, 676], "vertical": true, "font_size": 20, "lines_coords": [[[704.0, 528.0], [724.0, 528.0], [724.0, 676.0], [704.0, 676.0]], [[677.0, 528.0], [697.0, 528.0], [697.0, 656.0], [677.0, 656.0]], [[651.0, 529.0], [671.0, 529.0], [671.0, 675.0], [651.0, 675.0]], [[627.0, 528.0], [648.0, 528.0], [648.0, 622.0], [627.0, 622.0]]], "lines": ["今の名越さんは", "子供の感覚を", "取り戻している", "状態です。"]}, {"box": [692, 769, 739, 932], "vertical": true, "font_size": 22, "lines_coords": [[[714.0, 769.0], [739.0, 769.0], [739.0, 832.0], [714.0, 832.0]], [[692.0, 771.0], [712.0, 771.0], [712.0, 931.0], [692.0, 931.0]]], "lines": ["意識で", "考えるんではなく、"]}, {"box": [411, 772, 507, 934], "vertical": true, "font_size": 21, "lines_coords": [[[487.0, 774.0], [507.0, 774.0], [507.0, 926.0], [487.0, 926.0]], [[460.0, 773.0], [481.0, 773.0], [483.0, 888.0], [461.0, 888.0]], [[438.0, 773.0], [458.0, 773.0], [458.0, 851.0], [438.0, 851.0]], [[415.0, 772.0], [436.0, 772.0], [432.0, 933.0], [411.0, 933.0]]], "lines": ["無意識にまかせて", "軽い気持ちで", "カードを", "選べばいいんです。"]}], "img_path": "205.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [125, 71, 171, 166], "vertical": true, "font_size": 20, "lines_coords": [[[150.0, 71.0], [171.0, 71.0], [168.0, 166.0], [147.0, 166.0]], [[125.0, 72.0], [145.0, 72.0], [145.0, 165.0], [125.0, 165.0]]], "lines": ["ジャストア", "モーメント。"]}, {"box": [656, 458, 728, 556], "vertical": true, "font_size": 24, "lines_coords": [[[703.0, 460.0], [728.0, 460.0], [728.0, 533.0], [703.0, 533.0]], [[681.0, 458.0], [705.0, 458.0], [703.0, 556.0], [678.0, 556.0]], [[656.0, 459.0], [677.0, 459.0], [678.0, 551.0], [657.0, 551.0]]], "lines": ["いま一度", "ジャストア", "モーメント。"]}, {"box": [115, 529, 133, 602], "vertical": true, "font_size": 18, "lines_coords": [[[115.0, 529.0], [133.0, 529.0], [133.0, 602.0], [115.0, 602.0]]], "lines": ["．．．．．．"]}, {"box": [764, 715, 785, 798], "vertical": true, "font_size": 17, "lines_coords": [[[765.0, 716.0], [782.0, 716.0], [782.0, 795.0], [765.0, 795.0]]], "lines": ["名越さん"]}, {"box": [561, 710, 597, 751], "vertical": true, "font_size": 36, "lines_coords": [[[561.0, 710.0], [597.0, 710.0], [597.0, 751.0], [561.0, 751.0]]], "lines": ["！？"]}, {"box": [96, 760, 139, 894], "vertical": true, "font_size": 18, "lines_coords": [[[117.0, 760.0], [138.0, 760.0], [139.0, 894.0], [118.0, 894.0]], [[96.0, 760.0], [112.0, 760.0], [112.0, 837.0], [96.0, 837.0]]], "lines": ["左手でやるって", "ことか？"]}, {"box": [715, 986, 790, 1086], "vertical": true, "font_size": 25, "lines_coords": [[[759.0, 986.0], [790.0, 986.0], [790.0, 1051.0], [759.0, 1051.0]], [[740.0, 990.0], [762.0, 990.0], [762.0, 1086.0], [740.0, 1086.0]], [[715.0, 990.0], [736.0, 990.0], [736.0, 1069.0], [715.0, 1069.0]]], "lines": ["「左」で", "やってみて", "ください"]}, {"box": [316, 951, 384, 1130], "vertical": true, "font_size": 18, "lines_coords": [[[365.0, 952.0], [382.0, 952.0], [382.0, 1121.0], [365.0, 1121.0]], [[340.0, 952.0], [359.0, 952.0], [359.0, 1047.0], [340.0, 1047.0]], [[317.0, 952.0], [334.0, 952.0], [334.0, 1129.0], [317.0, 1129.0]]], "lines": ["上手く言えませんが、", "左側全体で", "感じてみてください。"]}], "img_path": "206.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [629, 132, 663, 219], "vertical": true, "font_size": 34, "lines_coords": [[[629.0, 132.0], [663.0, 132.0], [663.0, 219.0], [629.0, 219.0]]], "lines": ["左．．．？"]}, {"box": [309, 316, 354, 423], "vertical": true, "font_size": 20, "lines_coords": [[[331.0, 316.0], [352.0, 316.0], [352.0, 405.0], [331.0, 405.0]], [[309.0, 317.0], [329.0, 317.0], [329.0, 423.0], [309.0, 423.0]]], "lines": ["視覚・聴覚", "嗅覚・触覚．．．"]}, {"box": [342, 537, 359, 601], "vertical": true, "font_size": 17, "lines_coords": [[[342.0, 537.0], [359.0, 537.0], [359.0, 601.0], [342.0, 601.0]]], "lines": ["．．．．．．"]}, {"box": [19, 212, 113, 431], "vertical": true, "font_size": 19, "lines_coords": [[[92.0, 213.0], [113.0, 213.0], [113.0, 291.0], [92.0, 291.0]], [[70.0, 214.0], [86.0, 214.0], [86.0, 346.0], [70.0, 346.0]], [[44.0, 213.0], [64.0, 213.0], [64.0, 367.0], [44.0, 367.0]], [[19.0, 213.0], [39.0, 213.0], [39.0, 430.0], [19.0, 430.0]]], "lines": ["すべてを", "身体の左半分で", "感じるイメージで", "やってみてほしいんです。"]}, {"box": [70, 754, 102, 802], "vertical": true, "font_size": 32, "lines_coords": [[[70.0, 754.0], [102.0, 754.0], [102.0, 802.0], [70.0, 802.0]]], "lines": ["クッ"]}, {"box": [648, 1008, 699, 1082], "vertical": true, "font_size": 51, "lines_coords": [[[648.0, 1008.0], [699.0, 1008.0], [699.0, 1082.0], [648.0, 1082.0]]], "lines": ["ギッ"]}], "img_path": "207.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [], "img_path": "208.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [461, 867, 510, 929], "vertical": true, "font_size": 26, "lines_coords": [[[484.0, 867.0], [510.0, 867.0], [510.0, 929.0], [484.0, 929.0]], [[461.0, 868.0], [487.0, 868.0], [487.0, 918.0], [461.0, 918.0]]], "lines": ["気軽に", "．．．と"]}], "img_path": "209.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [728, 339, 762, 386], "vertical": true, "font_size": 34, "lines_coords": [[[728.0, 339.0], [762.0, 339.0], [762.0, 386.0], [728.0, 386.0]]], "lines": ["＾ロ"]}, {"box": [554, 339, 588, 386], "vertical": true, "font_size": 34, "lines_coords": [[[554.0, 339.0], [588.0, 339.0], [588.0, 386.0], [554.0, 386.0]]], "lines": ["ベロ"]}, {"box": [381, 339, 413, 386], "vertical": true, "font_size": 32, "lines_coords": [[[381.0, 339.0], [413.0, 339.0], [413.0, 386.0], [381.0, 386.0]]], "lines": ["ベロ"]}, {"box": [198, 342, 229, 390], "vertical": true, "font_size": 31, "lines_coords": [[[198.0, 342.0], [229.0, 342.0], [229.0, 390.0], [198.0, 390.0]]], "lines": ["ベロ"]}], "img_path": "210.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [682, 30, 714, 91], "vertical": true, "font_size": 32, "lines_coords": [[[682.0, 30.0], [714.0, 30.0], [714.0, 91.0], [682.0, 91.0]]], "lines": ["おっ。"]}, {"box": [247, 58, 296, 165], "vertical": true, "font_size": 23, "lines_coords": [[[269.0, 58.0], [294.0, 58.0], [296.0, 165.0], [272.0, 165.0]], [[247.0, 60.0], [268.0, 60.0], [268.0, 145.0], [247.0, 145.0]]], "lines": ["いいんじゃ", "ねえか？"]}, {"box": [676, 399, 695, 471], "vertical": true, "font_size": 19, "lines_coords": [[[676.0, 399.0], [695.0, 399.0], [695.0, 471.0], [676.0, 471.0]]], "lines": ["．．．．．．"]}, {"box": [544, 863, 576, 909], "vertical": true, "font_size": 32, "lines_coords": [[[544.0, 863.0], [576.0, 863.0], [576.0, 909.0], [544.0, 909.0]]], "lines": ["べラ"]}, {"box": [291, 864, 324, 911], "vertical": true, "font_size": 33, "lines_coords": [[[291.0, 864.0], [324.0, 864.0], [324.0, 911.0], [291.0, 911.0]]], "lines": ["ベラ"]}, {"box": [681, 952, 722, 1004], "vertical": true, "font_size": 32, "lines_coords": [[[691.0, 952.0], [722.0, 960.0], [711.0, 1004.0], [681.0, 996.0]]], "lines": ["べラ"]}, {"box": [433, 908, 466, 953], "vertical": true, "font_size": 33, "lines_coords": [[[433.0, 908.0], [466.0, 908.0], [466.0, 953.0], [433.0, 953.0]]], "lines": ["ベラ"]}, {"box": [42, 935, 87, 996], "vertical": true, "font_size": 38, "lines_coords": [[[42.0, 939.0], [80.0, 935.0], [87.0, 991.0], [49.0, 996.0]]], "lines": ["べラ"]}], "img_path": "211.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [320, 57, 339, 130], "vertical": true, "font_size": 19, "lines_coords": [[[320.0, 57.0], [339.0, 57.0], [339.0, 130.0], [320.0, 130.0]]], "lines": ["？．．．．．"]}, {"box": [438, 206, 456, 279], "vertical": true, "font_size": 18, "lines_coords": [[[438.0, 206.0], [456.0, 206.0], [456.0, 279.0], [438.0, 279.0]]], "lines": ["．．．．．．"]}, {"box": [425, 349, 444, 380], "vertical": true, "font_size": 19, "lines_coords": [[[425.0, 349.0], [444.0, 349.0], [444.0, 380.0], [425.0, 380.0]]], "lines": ["ジャ"]}, {"box": [169, 353, 188, 385], "vertical": true, "font_size": 19, "lines_coords": [[[169.0, 353.0], [188.0, 353.0], [188.0, 385.0], [169.0, 385.0]]], "lines": ["ジィ"]}, {"box": [412, 666, 433, 719], "vertical": true, "font_size": 21, "lines_coords": [[[412.0, 666.0], [433.0, 666.0], [433.0, 719.0], [412.0, 719.0]]], "lines": ["な．．．"]}, {"box": [405, 757, 427, 841], "vertical": true, "font_size": 21, "lines_coords": [[[405.0, 757.0], [426.0, 757.0], [427.0, 841.0], [406.0, 841.0]]], "lines": ["なんだよ。"]}, {"box": [505, 922, 548, 1034], "vertical": true, "font_size": 18, "lines_coords": [[[527.0, 922.0], [548.0, 922.0], [548.0, 979.0], [527.0, 979.0]], [[505.0, 922.0], [521.0, 922.0], [521.0, 1034.0], [505.0, 1034.0]]], "lines": ["置く時", "見えました？"]}, {"box": [467, 1089, 484, 1150], "vertical": true, "font_size": 17, "lines_coords": [[[467.0, 1089.0], [484.0, 1089.0], [484.0, 1150.0], [467.0, 1150.0]]], "lines": ["！．．．？"]}, {"box": [296, 892, 316, 996], "vertical": true, "font_size": 17, "lines_coords": [[[296.0, 892.0], [313.0, 892.0], [313.0, 994.0], [296.0, 994.0]]], "lines": ["見てねえよ。"]}], "img_path": "212.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [445, 154, 484, 261], "vertical": true, "font_size": 33, "lines_coords": [[[445.0, 158.0], [478.0, 154.0], [484.0, 208.0], [451.0, 212.0]]], "lines": ["ジィー"]}, {"box": [114, 174, 159, 290], "vertical": true, "font_size": 21, "lines_coords": [[[134.0, 174.0], [157.0, 174.0], [159.0, 258.0], [137.0, 258.0]], [[114.0, 175.0], [134.0, 175.0], [134.0, 290.0], [114.0, 290.0]]], "lines": ["なんだよ、", "その目は．．．．．．"]}, {"box": [699, 476, 746, 566], "vertical": true, "font_size": 24, "lines_coords": [[[721.0, 476.0], [746.0, 476.0], [746.0, 523.0], [721.0, 523.0]], [[699.0, 481.0], [721.0, 481.0], [721.0, 566.0], [699.0, 566.0]]], "lines": ["まあ", "いいです。"]}, {"box": [427, 371, 473, 496], "vertical": true, "font_size": 20, "lines_coords": [[[452.0, 371.0], [473.0, 371.0], [471.0, 496.0], [450.0, 496.0]], [[427.0, 371.0], [447.0, 371.0], [447.0, 493.0], [427.0, 493.0]]], "lines": ["明日、徹底的に", "やりますから。"]}, {"box": [269, 355, 338, 458], "vertical": true, "font_size": 21, "lines_coords": [[[313.0, 355.0], [338.0, 355.0], [338.0, 416.0], [313.0, 416.0]], [[291.0, 355.0], [311.0, 355.0], [311.0, 450.0], [291.0, 450.0]], [[269.0, 356.0], [286.0, 356.0], [286.0, 455.0], [269.0, 455.0]]], "lines": ["調子に", "のらないで", "くださいよ"]}, {"box": [624, 626, 743, 800], "vertical": true, "font_size": 20, "lines_coords": [[[714.0, 626.0], [743.0, 626.0], [743.0, 691.0], [714.0, 691.0]], [[695.0, 629.0], [715.0, 629.0], [715.0, 764.0], [695.0, 764.0]], [[670.0, 629.0], [688.0, 629.0], [689.0, 787.0], [671.0, 787.0]], [[647.0, 629.0], [663.0, 629.0], [663.0, 799.0], [647.0, 799.0]], [[624.0, 630.0], [641.0, 630.0], [641.0, 750.0], [624.0, 750.0]]], "lines": ["これは", "最低４回やって", "平均を出さないと、", "正確な実験データは", "出ないんです。"]}, {"box": [712, 876, 743, 922], "vertical": true, "font_size": 31, "lines_coords": [[[712.0, 876.0], [743.0, 876.0], [743.0, 922.0], [712.0, 922.0]]], "lines": ["ニッ"]}, {"box": [35, 669, 53, 732], "vertical": true, "font_size": 18, "lines_coords": [[[35.0, 669.0], [53.0, 669.0], [53.0, 732.0], [35.0, 732.0]]], "lines": ["．．．"]}, {"box": [519, 891, 600, 998], "vertical": true, "font_size": 20, "lines_coords": [[[579.0, 891.0], [600.0, 891.0], [600.0, 952.0], [579.0, 952.0]], [[559.0, 891.0], [579.0, 891.0], [579.0, 998.0], [559.0, 998.0]], [[536.0, 891.0], [558.0, 891.0], [558.0, 998.0], [536.0, 998.0]], [[519.0, 894.0], [535.0, 894.0], [535.0, 985.0], [519.0, 985.0]]], "lines": ["なんだ、", "４枚ってのは", "結構いい