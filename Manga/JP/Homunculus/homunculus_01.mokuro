36.0, 31.0], [553.0, 31.0], [553.0, 96.0], [536.0, 96.0]]], "lines": ["．．．．．．？"]}, {"box": [689, 376, 738, 630], "vertical": true, "font_size": 19, "lines_coords": [[[715.0, 376.0], [735.0, 376.0], [735.0, 457.0], [715.0, 457.0]], [[712.0, 494.0], [733.0, 494.0], [735.0, 614.0], [714.0, 614.0]], [[691.0, 496.0], [708.0, 496.0], [708.0, 630.0], [691.0, 630.0]]], "lines": ["名越さん、", "真剣にやって", "くださいよ．．．"]}, {"box": [335, 373, 357, 496], "vertical": true, "font_size": 20, "lines_coords": [[[337.0, 373.0], [357.0, 373.0], [355.0, 495.0], [335.0, 495.0]]], "lines": ["やってるだろ"]}, {"box": [408, 669, 478, 908], "vertical": true, "font_size": 21, "lines_coords": [[[454.0, 669.0], [478.0, 669.0], [478.0, 806.0], [454.0, 806.0]], [[432.0, 671.0], [452.0, 671.0], [452.0, 807.0], [432.0, 807.0]], [[408.0, 670.0], [427.0, 670.0], [429.0, 908.0], [409.0, 908.0]]], "lines": ["僕は「モノ」とか", "「素材」のことを", "聞いてるんじゃないですよ。"]}, {"box": [228, 680, 347, 834], "vertical": true, "font_size": 21, "lines_coords": [[[325.0, 682.0], [347.0, 682.0], [347.0, 760.0], [325.0, 760.0]], [[302.0, 682.0], [322.0, 682.0], [322.0, 778.0], [302.0, 778.0]], [[279.0, 682.0], [298.0, 682.0], [298.0, 776.0], [279.0, 776.0]], [[254.0, 680.0], [274.0, 680.0], [274.0, 759.0], [254.0, 759.0]], [[228.0, 680.0], [252.0, 680.0], [252.0, 834.0], [228.0, 834.0]]], "lines": ["霊魂やら", "人の魂やら", "そんなモン", "この世に", "あったってな．．．"]}, {"box": [694, 955, 739, 1069], "vertical": true, "font_size": 20, "lines_coords": [[[718.0, 955.0], [738.0, 955.0], [738.0, 1069.0], [718.0, 1069.0]], [[694.0, 955.0], [715.0, 955.0], [715.0, 1021.0], [694.0, 1021.0]]], "lines": ["しょうがない", "だろう。"]}, {"box": [413, 999, 462, 1121], "vertical": true, "font_size": 22, "lines_coords": [[[432.0, 999.0], [458.0, 999.0], [458.0, 1079.0], [432.0, 1079.0]], [[413.0, 1000.0], [430.0, 1000.0], [430.0, 1120.0], [413.0, 1120.0]]], "lines": ["「物」しか", "感じないんだ。"]}, {"box": [68, 985, 112, 1127], "vertical": true, "font_size": 18, "lines_coords": [[[91.0, 985.0], [112.0, 985.0], [112.0, 1064.0], [91.0, 1064.0]], [[69.0, 985.0], [85.0, 985.0], [85.0, 1123.0], [69.0, 1123.0]]], "lines": ["オレには", "見えやしねえよ。"]}], "img_path": "197.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [372, 154, 450, 294], "vertical": true, "font_size": 22, "lines_coords": [[[430.0, 157.0], [450.0, 157.0], [450.0, 250.0], [430.0, 250.0]], [[399.0, 154.0], [424.0, 154.0], [422.0, 294.0], [397.0, 294.0]], [[372.0, 158.0], [393.0, 158.0], [393.0, 255.0], [372.0, 255.0]]], "lines": ["もともと", "人間に興味が", "ねえんだ"]}, {"box": [232, 468, 256, 523], "vertical": true, "font_size": 20, "lines_coords": [[[235.0, 469.0], [255.0, 469.0], [255.0, 493.0], [235.0, 493.0]]], "lines": ["え"]}, {"box": [214, 704, 232, 780], "vertical": true, "font_size": 18, "lines_coords": [[[214.0, 704.0], [232.0, 704.0], [232.0, 780.0], [214.0, 780.0]]], "lines": ["．．．．．．？"]}, {"box": [510, 916, 556, 960], "vertical": false, "font_size": 44, "lines_coords": [[[510.0, 916.0], [556.0, 916.0], [556.0, 960.0], [510.0, 960.0]]], "lines": ["クイクイ"]}], "img_path": "198.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [162, 65, 504, 262], "vertical": false, "font_size": 109, "lines_coords": [[[162.0, 158.0], [472.0, 65.0], [504.0, 169.0], [194.0, 262.0]]], "lines": ["Ｙｏｈｏｏ！！"]}, {"box": [579, 371, 672, 486], "vertical": true, "font_size": 20, "lines_coords": [[[653.0, 372.0], [672.0, 372.0], [672.0, 468.0], [653.0, 468.0]], [[628.0, 371.0], [649.0, 371.0], [647.0, 468.0], [626.0, 468.0]], [[602.0, 372.0], [622.0, 372.0], [622.0, 486.0], [602.0, 486.0]], [[579.0, 372.0], [600.0, 372.0], [600.0, 438.0], [579.0, 438.0]]], "lines": ["名越さんは", "本当に頭が", "ガチガチな人", "だなあ。"]}, {"box": [225, 386, 240, 446], "vertical": true, "font_size": 15, "lines_coords": [[[225.0, 386.0], [240.0, 386.0], [240.0, 446.0], [225.0, 446.0]]], "lines": ["．．．"]}, {"box": [690, 786, 735, 900], "vertical": true, "font_size": 20, "lines_coords": [[[714.0, 786.0], [733.0, 786.0], 