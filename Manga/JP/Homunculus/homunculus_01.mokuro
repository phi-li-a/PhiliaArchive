ords": [[[784.0, 457.0], [817.0, 457.0], [817.0, 506.0], [784.0, 506.0]]], "lines": ["組長"]}, {"box": [494, 487, 569, 575], "vertical": true, "font_size": 26, "lines_coords": [[[542.0, 488.0], [569.0, 488.0], [569.0, 549.0], [542.0, 549.0]], [[520.0, 487.0], [545.0, 487.0], [545.0, 575.0], [520.0, 575.0]], [[494.0, 487.0], [521.0, 487.0], [521.0, 539.0], [494.0, 539.0]]], "lines": ["待って", "ください、", "組長。"]}, {"box": [240, 467, 320, 577], "vertical": true, "font_size": 24, "lines_coords": [[[298.0, 469.0], [320.0, 469.0], [320.0, 562.0], [298.0, 562.0]], [[266.0, 467.0], [290.0, 467.0], [293.0, 577.0], [268.0, 577.0]], [[240.0, 469.0], [266.0, 469.0], [266.0, 539.0], [240.0, 539.0]]], "lines": ["うるせえ", "近寄んじゃ", "ねェ！！"]}, {"box": [451, 756, 472, 855], "vertical": true, "font_size": 21, "lines_coords": [[[451.0, 757.0], [472.0, 757.0], [472.0, 853.0], [451.0, 853.0]]], "lines": ["組長～～～"]}, {"box": [502, 848, 522, 931], "vertical": true, "font_size": 20, "lines_coords": [[[502.0, 848.0], [522.0, 848.0], [522.0, 931.0], [502.0, 931.0]]], "lines": ["こぼある"]}, {"box": [175, 726, 289, 833], "vertical": true, "font_size": 25, "lines_coords": [[[259.0, 726.0], [289.0, 726.0], [289.0, 796.0], [259.0, 796.0]], [[233.0, 727.0], [257.0, 727.0], [257.0, 833.0], [233.0, 833.0]], [[205.0, 726.0], [230.0, 726.0], [228.0, 815.0], [202.0, 815.0]], [[175.0, 726.0], [196.0, 726.0], [199.0, 815.0], [178.0, 815.0]]], "lines": ["だから", "近寄るなっ", "つってん", "だろう！！"]}], "img_path": "252.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [620, 105, 653, 168], "vertical": true, "font_size": 33, "lines_coords": [[[620.0, 105.0], [653.0, 105.0], [653.0, 168.0], [620.0, 168.0]]], "lines": ["パイ"]}, {"box": [647, 1001, 667, 1096], "vertical": true, "font_size": 20, "lines_coords": [[[647.0, 1001.0], [667.0, 1001.0], [667.0, 1096.0], [647.0, 1096.0]]], "lines": ["．．．．．．"]}], "img_path": "253.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [570, 144, 629, 306], "vertical": true, "font_size": 26, "lines_coords": [[[601.0, 146.0], [629.0, 146.0], [629.0, 250.0], [601.0, 250.0]], [[570.0, 144.0], [595.0, 144.0], [597.0, 304.0], [573.0, 304.0]]], "lines": ["一体、何が", "起きたんだ．．．？"]}, {"box": [240, 196, 264, 290], "vertical": true, "font_size": 20, "lines_coords": [[[245.0, 196.0], [264.0, 198.0], [260.0, 289.0], [240.0, 288.0]]], "lines": ["それにしかしても、"]}], "img_path": "254.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [65, 560, 446, 603], "vertical": false, "font_size": 43, "lines_coords": [[[65.0, 560.0], [446.0, 560.0], [446.0, 603.0], [65.0, 603.0]]], "lines": ["［ホムンクルス］第１集＂完"]}, {"box": [51, 1060, 631, 1127], "vertical": false, "font_size": 16, "lines_coords": [[[60.0, 1058.0], [623.0, 1059.0], [623.0, 1076.0], [60.0, 1075.0]], [[60.0, 1073.0], [596.0, 1074.0], [596.0, 1094.0], [60.0, 1093.0]], [[62.0, 1093.0], [437.0, 1093.0], [437.0, 1109.0], [62.0, 1109.0]], [[59.0, 1107.0], [472.0, 1108.0], [472.0, 1128.0], [59.0, 1127.0]]], "lines": ["●作品中の「トレバネーシコンパは極めて勉強な行為です。絶対に真似をしないでください。", "Ｗｉｎｄｏｗｓもこの作品はフィクションコンコは極めているようですが、です。実在する人物、団体、事件等といったので、に興味をしないことははー切関係ありません。", "●「週刊ビッグコミックスビリッツ「２０３０年１６－２０１３年１０－２６号掲載作品。", "きっとリビングコミンスピックの動けホムンクルス「公式ホームペ２０１５年１０月２４日木１１月２１日土日土曜日（土）日曜日）までのお"]}], "img_path": "255.png"}, {"version": "0.1.7", "img_width": 1702, "img_height": 1200, "blocks": [{"box": [1520, 118, 1612, 658], "vertical": true, "font_size": 92, "lines_coords": [[[1520.0, 118.0], [1612.0, 118.0], [1612.0, 658.0], [1520.0, 658.0]]], "lines": ["異形のものたちの"]}, {"box": [1130, 111, 1487, 822], "vertical": true, "font_size": 100.0, "lines_coords": [[[1386.0, 121.0], [1487.0, 121.0], [1487.0, 377.0], [1386.0, 377.0]], [[1258.0, 116.0], [1356.0, 116.0], [1356.0, 518.0], [1258.0, 518.0]], [[1130.0, 111.0], [1231.0, 111.0], [1231.0, 822.0], [1130.0, 822.0]]], "lines": ["正体は", "名越はついに", "その枝心に触れる．．．"]}, {"box": [586, 1023, 1702, 1180], "vertical": false, "font_size": 82.5, "lines_coords": [[[1077.0, 1023.0], [1698.0, 1027.0], [1698.0, 1067.0], [1077.0, 1063.0]], [[586.0, 1050.0], [1702.0, 1055.0], [1702.0, 1180.0], [586.0, 1175.0]]], "lines": ["ジュミックスピリックにて衝撃連携中！！", "スム第４提案３０万東足ＰＣ－"]}, {"box": [395, 38, 423, 202], "vertical": true, "font_size": 23, "lines_coords": [[[395.0, 44.0], [418.0, 44.0], [418.0, 199.0], [395.0, 199.0]]], "lines": ["．．．．．．．なんだ？"]}, {"box": [314, 309, 345, 435], "vertical": true, "font_size": 30, "lines_coords": [[[314.0, 309.0], [344.0, 309.0], [345.0, 433.0], [315.0, 433.0]]], "lines": ["こりゃ．．．"]}], "img_path": "256.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [719, 117, 759, 269], "vertical": true, "font_size": 16, "lines_coords": [[[742.0, 182.0], [759.0, 182.0], [759.0, 227.0], [742.0, 227.0]], [[719.0, 117.0], [735.0, 117.0], [735.0, 269.0], [719.0, 269.0]]], "lines": ["．．．", "いかない．．．"]}, {"box": [60, 262, 404, 583], "vertical": false, "font_size": 32, "lines_coords": [[[94.0, 262.0], [400.0, 262.0], [400.0, 298.0], [94.0, 298.0]], [[60.0, 317.0], [379.0, 317.0], [379.0, 417.0], [60.0, 417.0]], [[229.0, 304.0], [400.0, 309.0], [400.0, 337.0], [229.0, 332.0]], [[184.0, 453.0], [403.0, 453.0], [403.0, 476.0], [184.0, 476.0]], [[267.0, 400.0], [395.0, 397.0], [396.0, 434.0], [268.0, 438.0]], [[110.0, 483.0], [399.0, 483.0], [399.0, 503.0], [110.0, 503.0]], [[239.0, 438.0], [400.0, 438.0], [400.0, 454.0], [239.0, 454.0]], [[191.0, 510.0], [402.0, 510.0], [402.0, 530.0], [191.0, 530.0]], [[150.0, 537.0], [400.0, 537.0], [400.0, 557.0], [150.0, 557.0]], [[144.0, 563.0], [402.0, 562.0], [402.0, 582.0], [144.0, 583.0]]], "lines": ["ヤクザ漫画の金学塔！", "「殺し屋１傘の", "ヤングサンデーコミックス", "２〜１０巻：定価・各５３０円（税込）", "全１０者", "いじめられっての殺し屋・１イチと", "巻：定価：５１０円（税込", "無敵のマゾヤクザ・垣原の", "アドレナリン金腸の殺し合い！！", "他にはない変態とミイオレンス！！"]}, {"box": [719, 268, 762, 357], "vertical": true, "font_size": 16, "lines_coords": [[[745.0, 274.0], [762.0, 274.0], [762.0, 312.0], [745.0, 312.0]], [[719.0, 268.0], [731.0, 268.0], [731.0, 357.0], [719.0, 357.0]]], "lines": ["．．", "．．．"]}, {"box": [63, 657, 143, 841], "vertical": true, "font_size": 61, "lines_coords": [[[83.0, 657.0], [143.0, 664.0], [124.0, 841.0], [63.0, 834.0]]], "lines": ["ぞき屋"]}, {"box": [444, 820, 732, 855], "vertical": false, "font_size": 32, "lines_coords": [[[444.0, 823.0], [732.0, 820.0], [732.0, 851.0], [444.0, 855.0]]], "lines": ["探偵漫画の金字塔！！"]}, {"box": [120, 1060, 359, 1111], "vertical": false, "font_size": 13, "lines_coords": [[[124.0, 1059.0], [290.0, 1059.0], [290.0, 1071.0], [124.0, 1071.0]], [[121.0, 1069.0], [234.0, 1070.0], [234.0, 1087.0], [121.0, 1085.0]], [[124.0, 1083.0], [255.0, 1083.0], [255.0, 1098.0], [124.0, 1098.0]], [[123.0, 1094.0], [297.0, 1096.0], [297.0, 1112.0], [123.0, 1111.0]]], "lines": ["そういえば、それからはあ、いいよねぇ、ちょっと", "そういうことを思っているのですが、それでも", "あなたはそういうことですね。それはそれであればこれまでの", "これまではなく、何でもないでしょうがないんですから、やっぱりやすいですね。"]}, {"box": [386, 953, 423, 1112], "vertical": true, "font_size": 33, "lines_coords": [[[386.0, 994.0], [419.0, 994.0], [422.0, 1108.0], [389.0, 1108.0]]], "lines": ["本英夫"]}, {"box": [445, 871, 805, 996], "vertical": false, "font_size": 47.0, "lines_coords": [[[445.0, 871.0], [669.0, 871.0], [669.0, 895.0], [445.0, 895.0]], [[528.0, 878.0], [805.0, 878.0], [805.0, 965.0], [528.0, 965.0]], [[468.0, 966.0], [552.0, 963.0], [553.0, 992.0], [470.0, 996.0]]], "lines": ["ヤングサンデーコミックスワイド版", "そき屋ぇぇー", "全６巻"]}, {"box": [446, 1001, 765, 1126], "vertical": false, "font_size": 19.4, "lines_coords": [[[447.0, 1001.0], [589.0, 1001.0], [589.0, 1018.0], [447.0, 1018.0]], [[446.0, 1026.0], [765.0, 1024.0], [765.0, 1044.0], [446.0, 1046.0]], [[446.0, 1053.0], [661.0, 1052.0], [661.0, 1072.0], [446.0, 1073.0]], [[449.0, 1079.0], [718.0, 1079.0], [718.0, 1099.0], [449.0, 1099.0]], [[450.0, 1106.0], [730.0, 1105.0], [730.0, 1125.0], [450.0, 1126.0]]], "lines": ["定価：各９８０円（税込）", "義眼の探偵・見〈ヶシンが世界をのぞく！！", "大ヒット作『新・のぞき屋』と", "その原点『のぞき屋』を完全収録！！", "見の義眼が、人間の時間をえぐる！！"]}], "img_path": "257.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [518, 65, 582, 380], "vertical": true, "font_size": 28, "lines_coords": [[[552.0, 71.0], [580.0, 71.0], [580.0, 380.0], [552.0, 380.0]], [[519.0, 69.0], [547.0, 69.0], [547.0, 274.0], [519.0, 274.0]]], "lines": ["殺し屋ー１ーの原点！！", "喧嘩中毒上等！！"]}, {"box": [0, 0, 307, 952], "vertical": true, "font_size": 303, "lines_coords": [[[0.0, 0.0], [307.0, 0.0], [298.0, 952.0], [0.0, 949.0]]], "lines": ["絶対無二の世界を描く日本英夫の単行を"]}, {"box": [262, 462, 391, 479], "vertical": false, "font_size": 17, "lines_coords": [[[262.0, 462.0], [391.0, 462.0], [391.0, 479.0], [262.0, 479.0]]], "lines": ["ヤングサンデーコミック"]}, {"box": [257, 517, 372, 537], "vertical": false, "font_size": 20, "lines_coords": [[[257.0, 517.0], [372.0, 517.0], [372.0, 537.0], [257.0, 537.0]]], "lines": ["定価：５０９円（税込）"]}, {"box": [378, 408, 481, 428], "vertical": false, "font_size": 16, "lines_coords": [[[378.0, 408.0], [481.0, 412.0], [481.0, 428.0], [378.0, 425.0]]], "lines": ["いいんですよ、"]}, {"box": [310, 487, 429, 515], "vertical": false, "font_size": 28, "lines_coords": [[[310.0, 487.0], [429.0, 487.0], [429.0, 515.0], [310.0, 515.0]]], "lines": ["チイチ"]}, {"box": [434, 478, 586, 530], "vertical": false, "font_size": 50, "lines_coords": [[[434.0, 480.0], [585.0, 478.0], [586.0, 528.0], [436.0, 530.0]]], "lines": ["『全１巻"]}, {"box": [501, 394, 787, 457], "vertical": false, "font_size": 16.333333333333332, "lines_coords": [[[504.0, 394.0], [750.0, 394.0], [750.0, 410.0], [504.0, 410.0]], [[501.0, 416.0], [714.0, 417.0], [714.0, 433.0], [501.0, 432.0]], [[505.0, 440.0], [787.0, 440.0], [787.0, 457.0], [505.0, 457.0]]], "lines": ["弱虫！泣き虫の１〈イチ〉が目覚める！！", "最強番長・大くダインに触発され", "高校時代の１くイチン、暴力シャンキーへ！！"]}, {"box": [451, 576, 515, 803], "vertical": true, "font_size": 28, "lines_coords": [[[484.0, 576.0], [512.0, 576.0], [512.0, 803.0], [484.0, 803.0]], [[451.0, 576.0], [479.0, 576.0], [479.0, 758.0], [451.0, 758.0]]], "lines": ["山本英夫の原点！！", "異色ラブコメ！！"]}, {"box": [247, 850, 520, 862], "vertical": false, "font_size": 12, "lines_coords": [[[247.0, 850.0], [520.0, 850.0], [520.0, 862.0], [247.0, 862.0]]], "lines": ["セーラー服装の自分自身の心に恋をした！！"]}, {"box": [260, 871, 521, 912], "vertical": false, "font_size": 16.0, "lines_coords": [[[260.0, 873.0], [521.0, 871.0], [521.0, 888.0], [260.0, 889.0]], [[269.0, 896.0], [521.0, 896.0], [521.0, 912.0], [269.0, 912.0]]], "lines": ["その自分のとっくりさん〈♀〉に恋をした！！", "．．．！Ｌｏｖｅオレな痛快ラブ・コメディ！！"]}, {"box": [14, 1109, 560, 1167], "vertical": false, "font_size": 16.0, "lines_coords": [[[17.0, 1109.0], [560.0, 1114.0], [560.0, 1130.0], [17.0, 1126.0]], [[28.0, 1129.0], [392.0, 1132.0], [392.0, 1148.0], [28.0, 1146.0]], [[14.0, 1147.0], [408.0, 1150.0], [408.0, 1167.0], [14.0, 1163.0]]], "lines": ["●書店でご希望の単行本が見つからない場合は、お手数ですが店頭でご注文下さい。", "また、インターネットでも購入できますすーーｈｔｔｐ：／／ｓｐｉ－ｎｅｔ．ｊｐ", "●お問い合わせ先、お客様相談とシターＴＥＬＩＯ－５２８１－８５６"]}, {"box": [400, 915, 771, 998], "vertical": false, "font_size": 31.666666666666668, "lines_coords": [[[567.0, 915.0], [769.0, 915.0], [769.0, 938.0], [567.0, 938.0]], [[430.0, 930.0], [771.0, 930.0], [771.0, 982.0], [430.0, 982.0]], [[400.0, 975.0], [767.0, 978.0], [767.0, 998.0], [400.0, 994.0]]], "lines": ["ヤングサンデーコミックスワイド版", "お力マ白書＿全５巻", "一３巻：定価：各９９９円（税込＞４－５巻：定価，各１０００円（税込）"]}], "img_path": "258.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [136, 124, 405, 159], "vertical": false, "font_size": 35, "lines_coords": [[[136.0, 124.0], [405.0, 124.0], [405.0, 159.0], [136.0, 159.0]]], "lines": ["ホムンクルスの"]}, {"box": [185, 175, 350, 199], "vertical": false, "font_size": 24, "lines_coords": [[[185.0, 175.0], [350.0, 175.0], [350.0, 199.0], [185.0, 199.0]]], "lines": ["ビッグコミックス"]}, {"box": [180, 568, 245, 592], "vertical": false, "font_size": 23.0, "lines_coords": [[[180.0, 569.0], [202.0, 569.0], [202.0, 591.0], [180.0, 591.0]], [[225.0, 568.0], [245.0, 568.0], [245.0, 592.0], [225.0, 592.0]]], "lines": ["著", "者"]}, {"box": [189, 454, 491, 475], "vertical": false, "font_size": 20, "lines_coords": [[[189.0, 454.0], 