876.0], [245.0, 876.0], [245.0, 967.0], [220.0, 967.0]], [[191.0, 876.0], [215.0, 876.0], [215.0, 1014.0], [191.0, 1014.0]], [[161.0, 874.0], [186.0, 874.0], [185.0, 1080.0], [160.0, 1080.0]], [[133.0, 874.0], [157.0, 874.0], [157.0, 1040.0], [133.0, 1040.0]]], "lines": ["海外では", "３６％の割合で", "第六感を感じた人が", "現れてるんです。"]}], "img_path": "144.png"}, {"version": "0.1.7", "img_width": 843, "img_height": 1200, "blocks": [{"box": [697, 278, 715, 320], "vertical": true, "font_size": 18, "lines_coords": [[[697.0, 278.0], [715.0, 278.0], [715.0, 320.0], [697.0, 320.0]]], "lines": ["！"]}, {"box": [408, 73, 433, 124], "vertical": true, "font_size": 23, "lines_coords": [[[408.0, 73.0], [433.0, 73.0], [433.0, 124.0], [408.0, 124.0]]], "lines": ["霊感、"]}, {"box": [368, 167, 389, 270], "vertical": true, "font_size": 23, "lines_coords": [[[368.0, 167.0], [389.0, 167.0], [389.0, 270.0], [368.0, 270.0]]], "lines": ["テレパシー、"]}, {"box": [254, 76, 275, 159], "vertical": true, "font_size": 20, "lines_coords": [[[254.0, 76.0], [274.0, 76.0], [274.0, 159.0], [254.0, 159.0]]], "lines": ["予知能力、"]}, {"box": [112, 104, 143, 160], "vertical": true, "font_size": 31, "lines_coords": [[[112.0, 104.0], [143.0, 104.0], [143.0, 160.0], [112.0, 160.0]]], "lines": ["透視、"]}, {"box": [53, 236, 78, 316], "vertical": true, "font_size": 25, "lines_coords": [[[53.0, 236.0], [78.0, 236.0], [78.0, 316.0], [53.0, 316.0]]], "lines": ["悟り．．．"]}, {"box": [633, 495, 726, 630], "vertical": true, "font_size": 19, "lines_coords": [[[706.0, 495.0], [726.0, 495.0], [723.0, 630.0], [703.0, 630.0]], [[681.0, 496.0], [701.0, 496.0], [701.0, 594.0], [681.0, 594.0]], [[656.0, 496.0], [676.0, 496.0], [676.0, 612.0], [656.0, 612.0]], [[635.0, 496.0], [653.0, 496.0], [650.0, 594.0], [633.0, 594.0]]], "lines": ["「座禅で浮いた」", "なんていう", "嘘クサイのも", "ありますが"]}, {"box": [57, 481, 73, 542], "vertical": true, "font_size": 16, "lines_coords": [[[57.0, 481.0], [73.0, 481.0], [73.0, 542.0], [57.0, 542.0]]], "lines": ["．．．"]}, {"box": [512, 712, 581, 8