], [439.0, 1087.0], [142.0, 1087.0]], [[137.0, 1096.0], [571.0, 1093.0], [571.0, 1118.0], [137.0, 1121.0]], [[137.0, 1128.0], [570.0, 1128.0], [570.0, 1148.0], [137.0, 1148.0]], [[137.0, 1156.0], [506.0, 1156.0], [506.0, 1176.0], [137.0, 1176.0]], [[134.0, 1178.0], [595.0, 1178.0], [595.0, 1214.0], [134.0, 1214.0]], [[139.0, 1210.0], [384.0, 1214.0], [384.0, 1234.0], [139.0, 1231.0]], [[140.0, 1240.0], [589.0, 1240.0], [589.0, 1260.0], [140.0, 1260.0]], [[140.0, 1326.0], [590.0, 1326.0], [590.0, 1348.0], [140.0, 1348.0]]], "lines": ["コスピリッツコミックス好評発売中／００", "ホムンクルス（山本英夫）．．．．．．いいい！！？", "ラストイニング（中原裕・神尾龍）．．．．．！〜", "闇金ウシジマくん（真鍋昌平．．．いいい！！〜", "バンビ〜ノ！ＳＥＣＯＮＤＯ（せきゃてっじ）！〜", "電波の城（細野不二彦〉．．．そうだなぁぁぁっ。", "．．．", "ＭＯＯＮ－昴ソリチュードスタンディングー〈曽田正人〉！！", "ＯＵＯＪＵＺ－コジューッー（柏木ノソルコ）．．．１", "ＭｙＦａｖｏｒｉｔｅＢＩＫＥ（山口かつみ）．．．：！", "上京アフロ田中（のりつけ雅春）．．．．．．", "鬼龍院冴子探偵事務所（三上龍哉）．．．", "ヴィルトゥス（信濃川日出雄義凡）．．．１〜", "古代ローマ格闘暗獄譚ＳＩＮ（信濃川日出産・義凡）．．．", "・１", "ＬＯＳＴＭＡＮ草場道輝", "いや、それこそ．．．", "新クロサギ黒丸・夏原武）．．．いい．．", "～～", "セルフ（胡ユキ蔵．．．．．．", "かもめ☆チャンス（玉井雪雄）．．．．．．！", "鉄腕バーディーＥｖｏｌｕＴｉＯＮ（ゆうきまさみ）！〜", "明日のない、空（塀内夏子）．．．", "アイアムアヒーロ一（花沢健吾）．．．．．．１〜２", "ＳＥＥＤ（今井大輔）．．．", "Ｄの魔王（柳広司・霜月かよ子）．．．．．．．．", "パパがもー度恋をした（阿部お母さん．．．．．．．．"]}, {"box": [208, 1466, 546, 1492], "vertical": false, "font_size": 19, "lines_coords": [[[209.0, 1466.0], [540.0, 1468.0], [540.0, 1489.0], [209.0, 1487.0]]], "lines": ["ＢＯＯＫＤＥＳＩＣＮ：ＴＡＫＡＨＡＳＨＩＪＵＮＺＩ"]}], "img_path": "002.png"}, {"version": "0.1.7", "img_width": 762, "img_height": 1600, "blocks": [{"box": [148, 192, 423, 267], "vertical": false, "font_size": 72, "lines_coords": [[[148.0, 195.0], [423.0, 192.0], [423.0, 264.0], [148.0, 267.0]]], "lines": ["山本英夫"]}, {"box": [153, 321, 376, 381], "vertical": false, "font_size": 24.5, "lines_coords": [[[153.0, 321.0], [376.0, 321.0], [376.0, 348.0], [153.0, 348.0]], [[153.0, 359.0], [304.0, 359.0], [304.0, 381.0], [153.0, 381.0]]], "lines": ["ロビッグコミックス", "ホムンクルス．．．"]}, {"box": [496, 204, 627, 250], "vertical": false, "font_size": 46, "lines_coords": [[[496.0, 204.0], [627.0, 204.0], [627.0,