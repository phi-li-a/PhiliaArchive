[[807.0, 1095.0], [840.0, 1095.0], [840.0, 1182.0], [807.0, 1182.0]]], "lines": ["同じく", "外資時代に", "遊んだ女の中の", "一人だ。"]}, {"box": [300, 1079, 329, 1235], "vertical": true, "font_size": 27, "lines_coords": [[[301.0, 1117.0], [328.0, 1117.0], [328.0, 1232.0], [301.0, 1232.0]]], "lines": ["～～ん．．．．．．"]}, {"box": [53, 1079, 111, 1234], "vertical": true, "font_size": 26, "lines_coords": [[[84.0, 1079.0], [110.0, 1079.0], [110.0, 1232.0], [84.0, 1232.0]], [[53.0, 1081.0], [79.0, 1081.0], [79.0, 1234.0], [53.0, 1234.0]]], "lines": ["なんなんです", "かねえ～～～．．．"]}, {"box": [843, 1354, 934, 1518], "vertical": true, "font_size": 29, "lines_coords": [[[907.0, 1356.0], [934.0, 1356.0], [934.0, 1484.0], [907.0, 1484.0]], [[873.0, 1354.0], [907.0, 1354.0], [907.0, 1434.0], [873.0, 1434.0]], [[843.0, 1354.0], [870.0, 1354.0], [873.0, 1518.0], [846.0, 1518.0]]], "lines": ["その中でも", "印象の", "薄い女だった。"]}], "img_path": "047.png"}, {"version": "0.1.7", "img_width": 1102, "img_height": 1600, "blocks": [{"box": [1005, 14, 1034, 143], "vertical": true, "font_size": 26, "lines_coords": [[[1005.0, 14.0], [1031.0, 14.0], [1034.0, 142.0], [1008.0, 142.0]]], "lines": ["つうか．．．．．"]}, {"box": [579, 23, 641, 207], "vertical": true, "font_size": 26, "lines_coords": [[[614.0, 25.0], [640.0, 25.0], [640.0, 128.0], [614.0, 128.0]], [[579.0, 23.0], [606.0, 23.0], [609.0, 206.0], [583.0, 206.0]]], "lines": ["興味ない", "からなあ～～．．．"]}, {"box": [453, 203, 473, 287], "vertical": true, "font_size": 20, "lines_coords": [[[453.0, 203.0], [473.0, 203.0], [473.0, 287.0], [453.0, 287.0]]], "lines": ["．．．．．．．"]}, {"box": [723, 612, 754, 657], "vertical": true, "font_size": 31, "lines_coords": [[[723.0, 612.0], [754.0, 612.0], [754.0, 657.0], [723.0, 657.0]]], "lines": ["え"]}, {"box": [562, 1023, 660, 1193], "vertical": true, "font_size": 27, "lines_coords": [[[633.0, 1025.0], [659.0, 1025.0], [659.0, 1181.0], [633.0, 1181.0]], [[595.0, 1023.0], [623.0, 1023.0], [620.0, 1193.0], [592.0, 1193.0]], [[562.0, 1023.0], [589.0, 1023.0], [589.0, 1179.0], [562.0, 1179.0]]], "lines": ["大きくすれば", "もっとわかる", "気がする．．．"]}, {"box": [300, 1014, 395, 1128], "vertical": true, "font_size": 31, "lines_coords": [[[359.0, 1015.0], [395.0, 1015.0], [395.0, 1076.0], [359.0, 1076.0]], [[331.0, 1014.0], [364.0, 1014.0], [361.0, 1123.0], [328.0, 1123.0]], [[300.0, 1017.0], [328.0, 1017.0], [328.0, 1128.0], [300.0, 1128.0]]], "lines": ["まだ", "言ってん", "ですかあ、"]}, {"box": [131, 1006, 193, 1137], "vertical": true, "font_size": 31, "lines_coords": [[[165.0, 1010.0], [193.0, 1010.0], [193.0, 1110.0], [165.0, 1110.0]], [[134.0, 1006.0], [162.0, 1006.0], [159.0, 1137.0], [131.0, 1137.0]]], "lines": ["しつこい", "なあ～～．．．"]}], "img_path": "048.png"}, {"version": "0.1.7", "img_width": 1108, "img_height": 1600, "blocks": [{"box": [80, 363, 100, 409], "vertical": true, "font_size": 20, "lines_coords": [[[80.0, 363.0], [100.0, 363.0], [100.0, 409.0], [80.0, 409.0]]], "lines": ["！"]}, {"box": [73, 555, 98, 681], "vertical": true, "font_size": 22, "lines_coords": [[[73.0, 556.0], [95.0, 556.0], [95.0, 681.0], [73.0, 681.0]]], "lines": ["これは．．．"]}, {"box": [512, 709, 612, 750], "vertical": false, "font_size": 18, "lines_coords": [[[517.0, 709.0], [612.0, 732.0], [607.0, 750.0], [512.0, 726.0]]], "lines": ["いつではわかりませんが、"]}, {"box": [429, 807, 640, 920], "vertical": false, "font_size": 19.0, "lines_coords": [[[457.0, 807.0], [620.0, 848.0], [615.0, 864.0], [453.0, 823.0]], [[451.0, 818.0], [640.0, 865.0], [636.0, 885.0], [446.0, 839.0]], [[443.0, 831.0], [637.0, 879.0], [632.0, 896.0], [439.0, 848.0]], [[439.0, 843.0], [618.0, 889.0], [614.0, 909.0], [434.0, 864.0]], [[434.0, 857.0], [614.0, 903.0], [609.0, 920.0], [429.0, 875.0]]], "lines": ["これからは、株式会社はどこになりますから、それ以外の人がいるのですが、", "それは何かの話ではなくなっているのかわからなかったのですが、やっぱりやってるんだけど．．．わかりませんでしょう。", "そのため、あの日の日本ではなくなったと思ったのですがそれはそれだけですからね。これはもう一度です。", "．．．あああぁああっ、ああはははっはぁぁあぁぁぁんはんはぁっはあぁっ！！ああんはああいはあんまりませんねえよね", "アメリカは「自分だけでも大きくなっていた。ありがとうございます。お客さんが"]}, {"box": [321, 968, 560, 1219], "vertical": false, "font_size": 20, "lines_coords": [[[355.0, 1013.0], [528.0, 1060.0], [521.0, 1085.0], [349.0, 1038.0]], [[349.0, 1030.0], [534.0, 1080.0], [529.0, 1099.0], [344.0, 1049.0]], [[342.0, 1043.0], [539.0, 1098.0], [534.0, 1118.0], [338.0, 1063.0]], [[334.0, 1057.0], [529.0, 1110.0], [525.0, 1130.0], [330.0, 1077.0]], [[330.0, 1071.0], [495.0, 1118.0], [490.0, 1138.0], [325.0, 1091.0]], [[325.0, 1087.0], [523.0, 1140.0], [518.0, 1160.0], [320.0, 1107.0]], [[330.0, 1102.0], [471.0, 1141.0], [467.0, 1161.0], [325.0, 1122.0]], [[328.0, 1118.0], [492.0, 1163.0], [487.0, 1183.0], [324.0, 1138.0]], [[325.0, 1133.0], [465.0, 1171.0], [461.0, 1191.0], [320.0, 1154.0]], [[327.0, 1149.0], [498.0, 1196.0], [493.0, 1216.0], [322.0, 1169.0]]], "lines": ["大阪府区１０００円引きからありますのですが、１０月１１日（日）になりましたが、", "これから２０１８年から３月１９日までは、２００７年１月１０月１８日（日）になりますのでありました。", "ですから、あなたがこうなってくるみたいないのはいいがいいのですが、大丈夫ですね。", "それではないのかもしれませんが、英語でもないからなと思ったんだけどな。", "ええ！！そんなことはありがとうございました！！", "そんなことはないですね。それは．．．わかりますからないけど、お前の子どもたちの子供がいただきました。", "ああ．．．あああぁぁぁああっ、お前はわかったんだよなんだからなんですよねーっ", "それはあなたが気になるのですが、それだけでも確かになってしまったのでしょうか。", "そんなことを言ってるからなんて言ったわけじゃなくなったんですから、", "でも、やったわけじゃないですよ。そんなことはあっ、わかりませんからなかったから、"]}], "img_path": "049.png"}, {"version": "0.1.7", "img_width": 1106, "img_height": 1600, "blocks": [{"box": [562, 110, 671, 264], "vertical": true, "font_size": 32, "lines_coords": [[[637.0, 110.0], [671.0, 110.0], [671.0, 207.0], [637.0, 207.0]], [[602.0, 112.0], [631.0, 112.0], [631.0, 264.0], [602.0, 264.0]], [[562.0, 110.0], [595.0, 110.0], [595.0, 204.0], [562.0, 204.0]]], "lines": ["自分で", "やっている", "のか？"]}, {"box": [1013, 728, 1082, 803], "vertical": true, "font_size": 39, "lines_coords": [[[1045.0, 731.0], [1082.0, 731.0], [1082.0, 792.0], [1045.0, 792.0]], [[1013.0, 728.0], [1054.0, 728.0], [1054.0, 803.0], [1013.0, 803.0]]], "lines": ["ああ", "それ、"]}, {"box": [515, 467, 551, 532], "vertical": true, "font_size": 36, "lines_coords": [[[515.0, 467.0], [551.0, 467.0], [551.0, 532.0], [515.0, 532.0]]], "lines": ["え？"]}, {"bo