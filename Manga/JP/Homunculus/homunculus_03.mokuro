73.0], [111.0, 673.0]], [[111.0, 704.0], [411.0, 704.0], [411.0, 720.0], [111.0, 720.0]], [[109.0, 727.0], [418.0, 726.0], [418.0, 742.0], [109.0, 744.0]], [[110.0, 750.0], [416.0, 751.0], [416.0, 767.0], [110.0, 766.0]], [[430.0, 489.0], [450.0, 487.0], [457.0, 542.0], [437.0, 544.0]], [[111.0, 799.0], [335.0, 799.0], [335.0, 814.0], [111.0, 814.0]], [[107.0, 816.0], [437.0, 816.0], [437.0, 840.0], [107.0, 840.0]], [[110.0, 846.0], [416.0, 846.0], [416.0, 861.0], [110.0, 861.0]], [[109.0, 868.0], [442.0, 867.0], [442.0, 883.0], [109.0, 884.0]], [[111.0, 891.0], [439.0, 891.0], [439.0, 908.0], [111.0, 908.0]], [[92.0, 921.0], [489.0, 918.0], [489.0, 994.0], [92.0, 997.0]], [[109.0, 960.0], [458.0, 959.0], [458.0, 976.0], [109.0, 977.0]]], "lines": ["ニュスピリッツコミックス好評発売中／００", "キャンソーロ露戦争物語（江川達也）．．．", "２０世紀少年（浦沢直樹）．．．．．．．．．", "２０世紀奈平海天盛期ハーバー・フグネス仮面（ビラマソミノル）・オンガトライブ（王井警備）．．．", "．．．", "オメガトライプ（玉井雪雄）．．．そうだなぁ．．．", "．．．", "つゆダク（棚ユキッ．．．．．．", "てんねん（吉田兄さん．．．．．．", "オパイ（古屋兎丸．．．．．．それでもそうですけど．．．", "東京エイティ一ズ（安童タ馬・大石知征）．．．", "女神の赤い舌（ウヒョ助）．．．そうだけどなんですけどね", "パドフライ（イワシタシゲユキリ．．．！！", "１３１６", "団地ともお（火田川．．．", "ゼブラーマン（宮藤官九郎・山田玲司）１〜", "極道一直線三上龍哉！！それはそれだけではないでしょうか", "ホムンクルス〈山本英美夫〉．．．．．．．．．！！", "ラストイニング（中原裕・神尾龍！！．．．", "Ｃｏｍａｚｏｎは、東本当中学生のアナファマン（存在確認」ということを確認しています。ここで最終的クラジラくん（は議論語）中．．．", "闇金ウシジマくん（真鍋昌平）：．．．"]}, {"box": [162, 1101, 421, 1120], "vertical": false, "font_size": 15, "lines_coords": [[[163.0, 1099.0], [414.0, 1100.0], [414.0, 1117.0], [163.0, 1116.0]]], "lines": ["ＲＯＯＫＤＥＳＩＣＮ：ＴＡＫＡＨＡＳＨＬＪＵＮＺＩ"]}], "img_path": "003.png"}, {"version": "0.1.7", "img_width": 579, "img_height": 1200, "blocks": [{"box": [106, 146, 466, 278], "vertical": false, "font_size": 32, "lines_coords": [[[106.0, 258.0], [239.0, 258.0], [239.0, 278.0], [106.0, 278.0]], [[366.0, 148.0], [464.0, 146.0], [465.0, 181.0], [368.0, 183.0]], [[351.0, 258.0], [466.0, 258.0], [466.0, 275.0], [351.0, 275.0]]], "lines": ["ホムンクルス．．．", "著作集", "１〜３集発売中"]}, {"box": [97, 130, 315, 256], "vertical": false, "font_size": 32, "lines_coords": [[[