e, "font_size": 25, "lines_coords": [[[98.0, 985.0], [124.0, 985.0], [124.0, 1068.0], [98.0, 1068.0]], [[68.0, 983.0], [92.0, 983.0], [94.0, 1110.0], [70.0, 1110.0]], [[41.0, 984.0], [65.0, 984.0], [65.0, 1085.0], [41.0, 1085.0]]], "lines": ["「目から", "ウロコ」って", "感じです。"]}], "img_path": "013.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [385, 536, 547, 609], "vertical": false, "font_size": 31.5, "lines_coords": [[[398.0, 536.0], [532.0, 544.0], [530.0, 578.0], [396.0, 570.0]], [[388.0, 568.0], [547.0, 580.0], [545.0, 609.0], [385.0, 597.0]]], "lines": ["左の小指を", "だからうということだかろうとしている！"]}, {"box": [186, 401, 314, 605], "vertical": true, "font_size": 22, "lines_coords": [[[291.0, 404.0], [313.0, 404.0], [313.0, 498.0], [291.0, 498.0]], [[263.0, 401.0], [288.0, 401.0], [284.0, 554.0], [260.0, 554.0]], [[239.0, 403.0], [260.0, 403.0], [257.0, 536.0], [236.0, 536.0]], [[211.0, 403.0], [234.0, 403.0], [234.0, 575.0], [211.0, 575.0]], [[187.0, 404.0], [207.0, 404.0], [207.0, 601.0], [187.0, 601.0]]], "lines": ["まず、今回", "名越さんの身に", "起きたことは、", "決してオカルトや", "超常現象ではないし、"]}, {"box": [274, 746, 311, 782], "vertical": false, "font_size": 36, "lines_coords": [[[274.0, 746.0], [311.0, 746.0], [311.0, 782.0], [274.0, 782.0]]], "lines": ["！？"]}, {"box": [630, 1085, 673, 1130], "vertical": true, "font_size": 43, "lines_coords": [[[630.0, 1085.0], [673.0, 1085.0], [673.0, 1130.0], [630.0, 1130.0]]], "lines": ["ゴッゴリ"]}, {"box": [458, 978, 555, 1116], "vertical": true, "font_size": 22, "lines_coords": [[[521.0, 978.0], [555.0, 978.0], [555.0, 1025.0], [521.0, 1025.0]], [[505.0, 982.0], [525.0, 982.0], [525.0, 1116.0], [505.0, 1116.0]], [[480.0, 982.0], [500.0, 982.0], [500.0, 1060.0], [480.0, 1060.0]], [[458.0, 983.0], [474.0, 983.0], [474.0, 1082.0], [458.0, 1082.0]]], "lines": ["頭が", "おかしくなった", "わけでも", "ありません"]}], "img_path": "014.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [329, 22, 428, 293], "vertical": true, "font_size": 99, "lines_coords": [[[329.0, 22.0], [428.0, 22.0], [428.0, 293.0], [329.0, 293.0]]], "lines": ["そういって、"]}, {"box": [396, 431, 490, 611], "vertical": true, "font_size": 20, "lines_coords": [[[470.0, 431.0], [490.0, 431.0], [490.0, 549.0], [470.0, 549.0]], [[444.0, 432.0], [464.0, 432.0], [464.0, 528.0], [444.0, 528.0]], [[420.0, 432.0], [440.0, 432.0], [440.0, 603.0], [420.0, 603.0]], [[396.0, 431.0], [416.0, 431.0], [416.0, 610.0], [396.0, 610.0]]], "lines": ["すべて科学的", "心理学的に", "説明のできる現実が", "起きているだけです。"]}, {"box": [295, 432, 312, 493], "vertical": true, "font_size": 17, "lines_coords": [[[295.0, 432.0], [312.0, 432.0], [312.0, 493.0], [295.0, 493.0]]], "lines": ["．．．．．．"]}, {"box": [633, 730, 676, 804], "vertical": true, "font_size": 43, "lines_coords": [[[633.0, 730.0], [676.0, 730.0], [676.0, 804.0], [633.0, 804.0]]], "lines": ["オン"]}, {"box": [639, 1006, 707, 1122], "vertical": true, "font_size": 18, "lines_coords": [[[686.0, 1006.0], [707.0, 1006.0], [707.0, 1093.0], [686.0, 1093.0]], [[663.0, 1007.0], [680.0, 1007.0], [680.0, 1122.0], [663.0, 1122.0]], [[639.0, 1006.0], [655.0, 1006.0], [655.0, 1121.0], [639.0, 1121.0]]], "lines": ["じゃ、この", "化け物たちは", "なんなんだ？"]}, {"box": [99, 937, 130, 1109], "vertical": true, "font_size": 28, "lines_coords": [[[99.0, 937.0], [127.0, 937.0], [130.0, 1108.0], [102.0, 1108.0]]], "lines": ["ホムンクルス。"]}], "img_path": "015.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [656, 73, 703, 295], "vertical": true, "font_size": 23, "lines_coords": [[[681.0, 73.0], [702.0, 73.0], [702.0, 168.0], [681.0, 168.0]], [[656.0, 214.0], [681.0, 214.0], [681.0, 295.0], [656.0, 295.0]]], "lines": ["ホムン．．．", "クル．．．"]}, {"box": [392, 444, 513, 619], "vertical": true, "font_size": 21, "lines_coords": [[[491.0, 446.0], [512.0, 446.0], [513.0, 618.0], [492.0, 618.0]], [[466.0, 445.0], [487.0, 445.0], [488.0, 550.0], [467.0, 550.0]], [[444.0, 447.0], [464.0, 447.0], [464.0, 582.0], [444.0, 582.0]], [[419.0, 445.0], [439.0, 445.0], [437.0, 544.0], [417.0, 544.0]], [[392.0, 444.0], [416.0, 444.0], [417.0, 619.0], [394.0, 619.0]]], "lines": ["インターネット等で", "検索すると、", "「人造人間」的な", "言われ方を", "してるんですが．．．"]}, {"box": [127, 307, 148, 385], "vertical": true, "font_size": 21, "lines_coords": [[[127.0, 309.0], [148.0, 309.0], [148.0, 384.0], [127.0, 384.0]]], "lines": ["．．．ス．．．？"]}, {"box": [215, 445, 299, 619], "vertical": true, "font_size": 24, "lines_coords": [[[273.0, 447.0], [297.0, 447.0], [297.0, 541.0], [273.0, 541.0]], [[241.0, 445.0], [268.0, 445.0], [270.0, 619.0], [243.0, 619.0]], [[215.0, 446.0], [236.0, 446.0], [240.0, 570.0], [219.0, 570.0]]], "lines": ["僕の定義", "概念で、話させて", "もらいます。"]}, {"box": [395, 754, 440, 869], "vertical": true, "font_size": 20, "lines_coords": [[[418.0, 755.0], [438.0, 755.0], [438.0, 869.0], [418.0, 869.0]], [[395.0, 754.0], [415.0, 754.0], [415.0, 836.0], [395.0, 836.0]]], "lines": ["今回の実験に", "関しては、"]}, {"box": [633, 952, 736, 1049], "vertical": true, "font_size": 30, "lines_coords": [[[704.0, 966.0], [736.0, 966.0], [736.0, 1021.0], [704.0, 1021.0]], [[682.0, 952.0], [707.0, 953.0], [702.0, 1048.0], [677.0, 1047.0]], [[650.0, 953.0], [686.0, 956.0], [683.0, 1014.0], [647.0, 1013.0]], [[633.0, 979.0], [659.0, 979.0], [659.0, 1033.0], [633.0, 1033.0]]], "lines": ["カタ", "カタカタ", "やはっ", "カタ"]}], "img_path": "016.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [448, 29, 517, 182], "vertical": true, "font_size": 19, "lines_coords": [[[496.0, 30.0], [517.0, 30.0], [517.0, 107.0], [496.0, 107.0]], [[471.0, 29.0], [492.0, 29.0], [488.0, 182.0], [467.0, 182.0]], [[449.0, 32.0], [465.0, 32.0], [465.0, 130.0], [449.0, 130.0]]], "lines": ["現代では", "「ホムンクルス」と", "いう言葉は、"]}, {"box": [341, 152, 364, 266], "vertical": true, "font_size": 20, "lines_coords": [[[341.0, 152.0], [361.0, 152.0], [361.0, 264.0], [341.0, 264.0]]], "lines": ["脳の中の．．．"]}, {"box": [109, 162, 130, 239], "vertical": true, "font_size": 21, "lines_coords": [[[109.0, 162.0], [130.0, 162.0], [130.0, 239.0], [109.0, 239.0]]], "lines": ["小人．．．？"]}, {"box": [678, 258, 757, 350], "vertical": true, "font_size": 30, "lines_coords": [[[725.0, 275.0], [757.0, 275.0], [757.0, 329.0], [725.0, 329.0]], [[702.0, 258.0], [735.0, 262.0], [724.0, 350.0], [691.0, 346.0]], [[678.0, 276.0], [704.0, 276.0], [704.0, 325.0], [678.0, 325.0]]], "lines": ["カタ", "わけわ！", "や！？"]}, {"box": [698, 488, 748, 576], "vertical": true, "font_size": 25, "lines_coords": [[[720.0, 488.0], [748.0, 488.0], [748.0, 535.0], [720.0, 535.0]], [[698.0, 491.0], [720.0, 491.0], [720.0, 573.0], [698.0, 573.0]]], "lines": ["見て", "ください"]}, {"box": [442, 294, 513, 435], "vertical": true, "font_size": 20, "lines_coords": [[[491.0, 294.0], [512.0, 294.0], [510.0, 428.0], [488.0, 428.0]], [[467.0, 295.0], [484.0, 295.0], [484.0, 407.0], [467.0, 407.0]], [[442.0, 294.0], [462.0, 294.0], [462.0, 435.0], [442.0, 435.0]]], "lines": ["「脳の中の小人」", "という意味で", "使われています。"]}, {"box": [317, 323, 340, 420], "vertical": true, "font_size": 20, "lines_coords": [[[317.0, 323.0], [337.0, 323.0], [340.0, 420.0], [320.0, 420.0]]], "lines": ["そうです！"]}, {"box": [710, 746, 726, 783], "vertical": true, "font_size": 16, "lines_coords": [[[710.0, 746.0], [726.0, 746.0], [726.0, 783.0], [710.0, 783.0]]], "lines": ["！"]}, {"box": [538, 980, 583, 1078], "vertical": true, "font_size": 22, "lines_coords": [[[558.0, 980.0], [583.0, 980.0], [583.0, 1042.0], [558.0, 1042.0]], [[538.0, 982.0], [558.0, 982.0], [558.0, 1074.0], [538.0, 1074.0]]], "lines": ["なんだ", "こりゃ．．．"]}], "img_path": "017.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [677, 139, 773, 352], "vertical": true, "font_size": 21, "lines_coords": [[[750.0, 140.0], [770.0, 140.0], [771.0, 352.0], [751.0, 352.0]], [[724.0, 139.0], [749.0, 139.0], [749.0, 203.0], [724.0, 203.0]], [[703.0, 140.0], [723.0, 140.0], [721.0, 315.0], [701.0, 315.0]], [[677.0, 140.0], [697.0, 140.0], [698.0, 281.0], [678.0, 281.0]]], "lines": ["これは脳科学の分野では", "有名な", "「感覚ホムンクルス」", "というものです。"]}, {"box": [359, 72, 374, 134], "vertical": true, "font_size": 15, "lines_coords": [[[359.0, 72.0], [374.0, 72.0], [374.0, 134.0], [359.0, 134.0]]], "lines": ["．．．．．？"]}, {"box": [615, 424, 712, 542], "vertical": true, "font_size": 20, "lines_coords": [[[688.0, 424.0], [712.0, 424.0], [712.0, 486.0], [688.0, 486.0]], [[666.0, 425.0], [686.0, 425.0], [686.0, 542.0], [666.0, 542.0]], [[643.0, 427.0], [660.0, 427.0], [660.0, 539.0], [643.0, 539.0]], [[617.0, 425.0], [637.0, 425.0], [635.0, 522.0], [615.0, 522.0]]], "lines": ["例えば", "このグラスを", "触ると冷たい", "ですよね？"]}, {"box": [371, 405, 392, 481], "vertical": true, "font_size": 21, "lines_coords": [[[371.0, 405.0], [392.0, 405.0], [392.0, 481.0], [371.0, 481.0]]], "lines": ["ああ．．．"]}, {"box": [263, 396, 313, 517], "vertical": true, "font_size": 21, "lines_coords": [[[286.0, 396.0], [313.0, 396.0], [313.0, 440.0], [286.0, 440.0]], [[263.0, 397.0], [283.0, 397.0], [286.0, 517.0], [266.0, 517.0]]], "lines": ["でも", "この冷たさは、"]}, {"box": [602, 823, 676, 923], "vertical": true, "font_size": 24, "lines_coords": [[[654.0, 826.0], [675.0, 826.0], [675.0, 903.0], [654.0, 903.0]], [[628.0, 827.0], [649.0, 827.0], [650.0, 923.0], [629.0, 923.0]], [[602.0, 823.0], [633.0, 823.0], [633.0, 880.0], [602.0, 880.0]]], "lines": ["実は脳で", "感じてるん", "です。"]}, {"box": [257, 550, 300, 689], "vertical": true, "font_size": 21, "lines_coords": [[[280.0, 550.0], [300.0, 550.0], [300.0, 646.0], [280.0, 646.0]], [[257.0, 550.0], [274.0, 550.0], [274.0, 689.0], [257.0, 689.0]]], "lines": ["「指の先」で", "感じてるようで、"]}, {"box": [248, 795, 292, 911], "vertical": true, "font_size": 20, "lines_coords": [[[272.0, 795.0], [291.0, 795.0], [291.0, 911.0], [272.0, 911.0]], [[248.0, 795.0], [269.0, 795.0], [269.0, 862.0], [248.0, 862.0]]], "lines": ["ということは", "ですよ、"]}, {"box": [396, 1027, 442, 1125], "vertical": true, "font_size": 20, "lines_coords": [[[422.0, 1028.0], [442.0, 1028.0], [442.0, 1125.0], [422.0, 1125.0]], [[396.0, 1027.0], [416.0, 1027.0], [418.0, 1110.0], [398.0, 1110.0]]], "lines": ["んなことは", "わかるよ"]}], "img_path": "018.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [407, 19, 473, 193], "vertical": true, "font_size": 18, "lines_coords": [[[453.0, 21.0], [473.0, 21.0], [473.0, 118.0], [453.0, 118.0]], [[429.0, 22.0], [446.0, 22.0], [447.0, 193.0], [430.0, 193.0]], [[408.0, 19.0], [424.0, 19.0], [424.0, 162.0], [408.0, 162.0]]], "lines": ["脳の中にも", "「指先」があるという", "ことになります。"]}, {"box": [51, 188, 123, 352], "vertical": true, "font_size": 20, "lines_coords": [[[100.0, 189.0], [120.0, 189.0], [120.0, 307.0], [100.0, 307.0]], [[76.0, 191.0], [96.0, 191.0], [96.0, 305.0], [76.0, 305.0]], [[51.0, 188.0], [71.0, 188.0], [72.0, 350.0], [52.0, 350.0]]], "lines": ["指先の情報を", "感じる部分が", "あるってことだろ。"]}, {"box": [288, 417, 310, 502], "vertical": true, "font_size": 21, "lines_coords": [[[288.0, 417.0], [309.0, 417.0], [310.0, 502.0], [289.0, 502.0]]], "lines": ["そうです。"]}, {"box": [37, 452, 78, 510], "vertical": true, "font_size": 38, "lines_coords": [[[37.0, 454.0], [75.0, 452.0], [78.0, 508.0], [41.0, 510.0]]], "lines": ["カタ"]}, {"box": [634, 802, 667, 817], "vertical": false, "font_size": 15, "lines_coords": [[[634.0, 802.0], [667.0, 802.0], [667.0, 817.0], [634.0, 817.0]]], "lines": ["親指"]}, {"box": [505, 746, 535, 764], "vertical": false, "font_size": 18, "lines_coords": [[[505.0, 746.0], [535.0, 746.0], [535.0, 764.0], [505.0, 764.0]]], "lines": ["体幹"]}, {"box": [300, 633, 403, 834], "vertical": true, "font_size": 22, "lines_coords": [[[381.0, 635.0], [401.0, 635.0], [401.0, 833.0], [381.0, 833.0]], [[351.0, 635.0], [376.0, 635.0], [376.0, 744.0], [351.0, 744.0]], [[325.0, 635.0], [349.0, 635.0], [349.0, 765.0], [325.0, 765.0]], [[300.0, 633.0], [321.0, 633.0], [322.0, 793.0], [301.0, 793.0]]], "lines": ["人間の全身の感覚は、", "脳の表面に", "地図のように", "存在しています。"]}, {"box": [66, 1030, 139, 1128], "vertical": true, "font_size": 24, "lines_coords": [[[113.0, 1030.0], [139.0, 1030.0], [139.0, 1092.0], [113.0, 1092.0]], [[92.0, 1033.0], [113.0, 1033.0], [113.0, 1128.0], [92.0, 1128.0]], [[66.0, 1030.0], [92.0, 1030.0], [92.0, 1098.0], [66.0, 1098.0]]], "lines": ["ここが", "「指」の部分", "ですね。"]}], "img_path": "019.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [719, 70, 764, 242], "vertical": true, "font_size": 20, "lines_coords": [[[739.0, 70.0], [764.0, 70.0], [762.0, 242.0], [737.0, 242.0]], [[720.0, 72.0], [736.0, 72.0], [736.0, 227.0], [720.0, 227.0]]], "lines": ["「手」と「唇」の部分が", "やたらとデケエな。"]}, {"box": [289, 213, 310, 303], "vertical": true, "font_size": 21, "lines_coords": [[[289.0, 213.0], [310.0, 213.0], [310.0, 303.0], [289.0, 303.0]]], "lines": ["Ｙｅｓ！"]}, {"box": [709, 358, 780, 474], "vertical": true, "font_size": 22, "lines_coords": [[[755.0, 358.0], [780.0, 358.0], [780.0, 420.0], [755.0, 420.0]], [[732.0, 358.0], [752.0, 358.0], [752.0, 473.0], [732.0, 473.0]], [[709.0, 358.0], [730.0, 358.0], [730.0, 426.0], [709.0, 426.0]]], "lines": ["なので", "これを立体に", "すると、"]}, {"box": [572, 389, 614, 455], "vertical": true, "font_size": 42, "lines_coords": [[[572.0, 389.0], [614.0, 389.0], [614.0, 455.0], [572.0, 455.0]]], "lines": ["ピッ"]}, {"box": [316, 820, 437, 900], "vertical": true, "font_size": 26, "lines_coords": [[[411.0, 821.0], [437.0, 821.0], [437.0, 882.0], [411.0, 882.0]], [[386.0, 820.0], [416.0, 820.0], [416.0, 884.0], [386.0, 884.0]], [[367.0, 821.0], [389.0, 821.0], [386.0, 900.0], [364.0, 900.0]], [[341.0, 821.0], [365.0, 821.0], [365.0, 900.0], [341.0, 900.0]], [[316.0, 821.0], [342.0, 821.0], [342.0, 890.0], [316.0, 890.0]]], "lines": ["それが", "端的に", "出るのが", "セックス", "ですね。"]}, {"box": [114, 632, 168, 734], "vertical": true, "font_size": 23, "lines_coords": [[[146.0, 635.0], [167.0, 635.0], [167.0, 724.0], [146.0, 724.0]], [[114.0, 632.0], [139.0, 632.0], [141.0, 734.0], [117.0, 734.0]]], "lines": ["こうなる", "わけです。"]}, {"box": [207, 830, 224, 894], "vertical": true, "font_size": 17, "lines_coords": [[[207.0, 830.0], [224.0, 830.0], [224.0, 894.0], [207.0, 894.0]]], "lines": ["．．．．．．？"]}, {"box": [560, 840, 675, 975], "vertical": true, "font_size": 19, "lines_coords": [[[655.0, 841.0], [675.0, 841.0], [675.0, 975.0], [655.0, 975.0]], [[630.0, 841.0], [650.0, 841.0], [650.0, 938.0], [630.0, 938.0]], [[606.0, 841.0], [626.0, 841.0], [626.0, 964.0], [606.0, 964.0]], [[581.0, 840.0], [601.0, 840.0], [602.0, 975.0], [582.0, 975.0]], [[560.0, 841.0], [576.0, 841.0], [576.0, 963.0], [560.0, 963.0]]], "lines": ["人間というのは", "何かを強く", "感じたい時に、", "手と口を使って", "しまうでしょ。"]}], "img_path": "020.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [548, 96, 599, 146], "vertical": true, "font_size": 26, "lines_coords": [[[573.0, 96.0], [599.0, 97.0], [596.0, 146.0], [571.0, 145.0]], [[548.0, 99.0], [574.0, 98.0], [576.0, 144.0], [551.0, 145.0]]], "lines": ["コツ", "コツ"]}, {"box": [394, 46, 488, 164], "vertical": true, "font_size": 22, "lines_coords": [[[463.0, 46.0], [488.0, 46.0], [488.0, 110.0], [463.0, 110.0]], [[442.0, 49.0], [462.0, 49.0], [462.0, 127.0], [442.0, 127.0]], [[417.0, 48.0], [438.0, 48.0], [438.0, 145.0], [417.0, 145.0]], [[394.0, 48.0], [416.0, 48.0], [416.0, 164.0], [394.0, 164.0]]], "lines": ["しかし", "俺が見た", "化け物とは", "大分違うぜ。"]}, {"box": [246, 12, 294, 117], "vertical": true, "font_size": 23, "lines_coords": [[[268.0, 14.0], [294.0, 14.0], [294.0, 76.0], [268.0, 76.0]], [[246.0, 12.0], [266.0, 12.0], [268.0, 117.0], [248.0, 117.0]]], "lines": ["これは", "あくまでも、"]}, {"box": [43, 11, 139, 186], "vertical": true, "font_size": 23, "lines_coords": [[[114.0, 12.0], [139.0, 12.0], [139.0, 93.0], [114.0, 93.0]], [[93.0, 12.0], [113.0, 12.0], [113.0, 110.0], [93.0, 110.0]], [[70.0, 12.0], [90.0, 12.0], [86.0, 186.0], [66.0, 186.0]], [[43.0, 11.0], [70.0, 11.0], [70.0, 63.0], [43.0, 63.0]]], "lines": ["「触覚」を", "中心とした", "「感覚ホムンクルス」", "です。"]}, {"box": [614, 300, 667, 332], "vertical": false, "font_size": 16, "lines_coords": [[[620.0, 300.0], [667.0, 317.0], [661.0, 332.0], [614.0, 315.0]]], "lines": ["わかりましたわけなんじゃ"]}, {"box": [91, 465, 138, 620], "vertical": true, "font_size": 22, "lines_coords": [[[113.0, 465.0], [138.0, 465.0], [138.0, 528.0], [113.0, 528.0]], [[91.0, 466.0], [111.0, 466.0], [111.0, 618.0], [91.0, 618.0]]], "lines": ["人間は", "「触覚」以外に．．．"]}, {"box": [462, 773, 492, 835], "vertical": true, "font_size": 30, "lines_coords": [[[462.0, 773.0], [492.0, 773.0], [492.0, 835.0], [462.0, 835.0]]], "lines": ["視覚。"]}, {"box": [297, 803, 329, 866], "vertical": true, "font_size": 32, "lines_coords": [[[297.0, 803.0], [329.0, 803.0], [329.0, 866.0], [297.0, 866.0]]], "lines": ["聴覚。"]}, {"box": [684, 1059, 716, 1122], "vertical": true, "font_size": 32, "lines_coords": [[[684.0, 1059.0], [716.0, 1059.0], [716.0, 1122.0], [684.0, 1122.0]]], "lines": ["臭覚。"]}, {"box": [62, 1055, 97, 1121], "vertical": true, "font_size": 35, "lines_coords": [[[62.0, 1055.0], [97.0, 1055.0], [97.0, 1121.0], [62.0, 1121.0]]], "lines": ["味覚。"]}], "img_path": "021.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [615, 72, 693, 160], "vertical": true, "font_size": 29, "lines_coords": [[[668.0, 73.0], [693.0, 73.0], [693.0, 160.0], [668.0, 160.0]], [[635.0, 72.0], [670.0, 72.0], [670.0, 145.0], [635.0, 145.0]], [[615.0, 73.0], [641.0, 73.0], [641.0, 147.0], [615.0, 147.0]]], "lines": ["すべてで", "五感を", "使って、"]}, {"box": [139, 66, 212, 171], "vertical": true, "font_size": 22, "lines_coords": [[[187.0, 66.0], [212.0, 66.0], [212.0, 134.0], [187.0, 134.0]], [[164.0, 67.0], [184.0, 67.0], [184.0, 171.0], [164.0, 171.0]], [[139.0, 66.0], [159.0, 66.0], [159.0, 161.0], [139.0, 161.0]]], "lines": ["情報を", "得ることが", "できます。"]}, {"box": [633, 450, 703, 604], "vertical": true, "font_size": 22, "lines_coords": [[[680.0, 450.0], [701.0, 450.0], [703.0, 604.0], [682.0, 604.0]], [[655.0, 451.0], [675.0, 451.0], [677.0, 567.0], [657.0, 567.0]], [[633.0, 450.0], [654.0, 450.0], [654.0, 515.0], [633.0, 515.0]]], "lines": ["この五感を使って", "情報収集する", "ことを、"]}, {"box": [474, 458, 547, 563], "vertical": true, "font_size": 22, "lines_coords": [[[523.0, 459.0], [547.0, 459.0], [547.0, 537.0], [523.0, 537.0]], [[497.0, 458.0], [521.0, 458.0], [521.0, 540.0], [497.0, 540.0]], [[474.0, 458.0], [494.0, 458.0], [498.0, 563.0], [478.0, 563.0]]], "lines": ["いわゆる", "「経験」と", "しましょう。"]}, {"box": [248, 454, 365, 607], "vertical": true, "font_size": 19, "lines_coords": [[[345.0, 457.0], [362.0, 457.0], [362.0, 588.0], [345.0, 588.0]], [[321.0, 455.0], [337.0, 455.0], [337.0, 550.0], [321.0, 550.0]], [[295.0, 454.0], [316.0, 454.0], [316.0, 532.0], [295.0, 532.0]], [[272.0, 455.0], [291.0, 455.0], [291.0, 607.0], [272.0, 607.0]], [[248.0, 457.0], [268.0, 457.0], [268.0, 536.0], [248.0, 536.0]]], "lines": ["経験したことは", "時間と共に", "脳の中で", "「記憶」に変わって", "いきます"]}, {"box": [479, 759, 523, 837], "vertical": true, "font_size": 21, "lines_coords": [[[500.0, 759.0], [521.0, 759.0], [521.0, 837.0], [500.0, 837.0]], [[479.0, 759.0], [500.0, 759.0], [500.0, 800.0], [479.0, 800.0]]], "lines": ["経験ねえ", "．．．"]}, {"box": [559, 943, 700, 1105], "vertical": true, "font_size": 24, "lines_coords": [[[676.0, 944.0], [700.0, 944.0], [700.0, 1081.0], [676.0, 1081.0]], [[646.0, 943.0], [670.0, 943.0], [673.0, 1042.0], [648.0, 1042.0]], [[617.0, 944.0], [641.0, 944.0], [641.0, 1105.0], [617.0, 1105.0]], [[589.0, 943.0], [613.0, 943.0], [613.0, 1080.0], [589.0, 1080.0]], [[559.0, 943.0], [583.0, 943.0], [583.0, 1060.0], [559.0, 1060.0]]], "lines": ["人間の五感で", "経験して、", "脳に蓄積された", "記憶の地図の", "立体が．．．"]}], "img_path": "022.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [110, 440, 195, 657], "vertical": true, "font_size": 25, "lines_coords": [[[165.0, 442.0], [195.0, 442.0], [195.0, 515.0], [165.0, 515.0]], [[139.0, 440.0], [164.0, 440.0], [160.0, 628.0], [136.0, 628.0]], [[110.0, 445.0], [130.0, 445.0], [132.0, 656.0], [112.0, 656.0]]], "lines": ["純正の", "「ホムンクルス」と", "いうことになります。"]}, {"box": [603, 741, 672, 835], "vertical": true, "font_size": 20, "lines_coords": [[[650.0, 741.0], [671.0, 741.0], [671.0, 819.0], [650.0, 819.0]], [[628.0, 741.0], [648.0, 741.0], [648.0, 835.0], [628.0, 835.0]], [[603.0, 741.0], [623.0, 741.0], [623.0, 819.0], [603.0, 819.0]]], "lines": ["なんだか", "ややこしい", "なあ．．．．．"]}, {"box": [265, 590, 544, 703], "vertical": false, "font_size": 30, "lines_coords": [[[270.0, 590.0], [488.0, 608.0], [485.0, 648.0], [267.0, 630.0]], [[267.0, 638.0], [538.0, 657.0], [535.0, 690.0], [265.0, 672.0]], [[389.0, 686.0], [479.0, 686.0], [479.0, 703.0], [389.0, 703.0]]], "lines": ["ロボットの中に少年？", "右手のカマで左の小梅を", "だから．．．"]}, {"box": [201, 766, 319, 959], "vertical": true, "font_size": 18, "lines_coords": [[[299.0, 766.0], [318.0, 766.0], [318.0, 846.0], [299.0, 846.0]], [[276.0, 769.0], [293.0, 769.0], [293.0, 957.0], [276.0, 957.0]], [[249.0, 767.0], [269.0, 767.0], [269.0, 902.0], [249.0, 902.0]], [[227.0, 768.0], [243.0, 768.0], [243.0, 863.0], [227.0, 863.0]], [[202.0, 766.0], [220.0, 766.0], [219.0, 946.0], [201.0, 946.0]]], "lines": ["とにかく", "めんどうな言い回しや", "専門的なことは", "抜きにして", "言わせてもらうと．．．"]}], "img_path": "023.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [705, 46, 784, 202], "vertical": true, "font_size": 22, "lines_coords": [[[756.0, 46.0], [784.0, 46.0], [784.0, 92.0], [756.0, 92.0]], [[734.0, 49.0], [757.0, 49.0], [757.0, 202.0], [734.0, 202.0]], [[705.0, 49.0], [725.0, 49.0], [725.0, 167.0], [705.0, 167.0]]], "lines": ["要は", "人々の心の深層に", "沈んだ歪みが"]}, {"box": [554, 83, 600, 180], "vertical": true, "font_size": 22, "lines_coords": [[[580.0, 85.0], [600.0, 85.0], [600.0, 180.0], [580.0, 180.0]], [[557.0, 83.0], [578.0, 83.0], [575.0, 180.0], [554.0, 180.0]]], "lines": ["いろいろな", "化け物．．．"]}, {"box": [314, 58, 396, 220], "vertical": true, "font_size": 25, "lines_coords": [[[370.0, 60.0], [395.0, 60.0], [395.0, 220.0], [370.0, 220.0]], [[338.0, 58.0], [368.0, 58.0], [368.0, 134.0], [338.0, 134.0]], [[314.0, 60.0], [334.0, 60.0], [334.0, 205.0], [314.0, 205.0]]], "lines": ["「ホムンクルス」", "として", "見えるんです。"]}, {"box": [723, 829, 748, 966], "vertical": true, "font_size": 23, "lines_coords": [[[723.0, 830.0], [746.0, 830.0], [746.0, 966.0], [723.0, 966.0]]], "lines": ["心の歪み．．．？"]}, {"box": [207, 795, 255, 862], "vertical": true, "font_size": 26, "lines_coords": [[[229.0, 795.0], [255.0, 795.0], [255.0, 856.0], [229.0, 856.0]], [[207.0, 795.0], [232.0, 795.0], [232.0, 861.0], [207.0, 861.0]]], "lines": ["例えば", "ですね、"]}], "img_path": "024.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [551, 50, 629, 207], "vertical": true, "font_size": 26, "lines_coords": [[[599.0, 51.0], [629.0, 51.0], [629.0, 97.0], [599.0, 97.0]], [[581.0, 52.0], [601.0, 52.0], [599.0, 207.0], [579.0, 207.0]], [[553.0, 50.0], [581.0, 51.0], [579.0, 121.0], [551.0, 120.0]]], "lines": ["この", "ジャミラおばさん", "ですが、"]}, {"box": [71, 80, 142, 204], "vertical": true, "font_size": 20, "lines_coords": [[[121.0, 82.0], [141.0, 82.0], [141.0, 188.0], [121.0, 188.0]], [[96.0, 82.0], [116.0, 82.0], [116.0, 196.0], [96.0, 196.0]], [[73.0, 80.0], [93.0, 80.0], [91.0, 202.0], [71.0, 202.0]]], "lines": ["昨日、あの後", "いろいろ話を", "聞きましたよ。"]}, {"box": [192, 390, 209, 428], "vertical": true, "font_size": 17, "lines_coords": [[[192.0, 390.0], [209.0, 390.0], [209.0, 428.0], [192.0, 428.0]]], "lines": ["！"]}, {"box": [640, 588, 736, 791], "vertical": true, "font_size": 21, "lines_coords": [[[716.0, 588.0], [736.0, 588.0], [736.0, 686.0], [716.0, 686.0]], [[691.0, 589.0], [711.0, 589.0], [711.0, 791.0], [691.0, 791.0]], [[666.0, 588.0], [687.0, 588.0], [688.0, 752.0], [667.0, 752.0]], [[642.0, 589.0], [663.0, 589.0], [661.0, 723.0], [640.0, 723.0]]], "lines": ["名越さんは", "「首を守っているような", "気がする」と言って", "いましたが．．．"]}, {"box": [500, 607, 568, 706], "vertical": true, "font_size": 21, "lines_coords": [[[547.0, 607.0], [568.0, 607.0], [568.0, 685.0], [547.0, 685.0]], [[524.0, 607.0], [545.0, 607.0], [545.0, 684.0], [524.0, 684.0]], [[500.0, 608.0], [520.0, 608.0], [520.0, 706.0], [500.0, 706.0]]], "lines": ["どうして", "そう思い", "ましたか？"]}, {"box": [73, 583, 171, 721], "vertical": true, "font_size": 23, "lines_coords": [[[143.0, 583.0], [171.0, 583.0], [171.0, 630.0], [143.0, 630.0]], [[123.0, 587.0], [144.0, 587.0], [144.0, 666.0], [123.0, 666.0]], [[97.0, 585.0], [120.0, 585.0], [120.0, 721.0], [97.0, 721.0]], [[73.0, 587.0], [94.0, 587.0], [94.0, 671.0], [73.0, 671.0]]], "lines": ["首に", "病気でも", "持ってるんじゃ", "ないのか。"]}], "img_path": "025.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [439, 72, 557, 255], "vertical": true, "font_size": 21, "lines_coords": [[[535.0, 73.0], [557.0, 73.0], [557.0, 151.0], [535.0, 151.0]], [[511.0, 72.0], [534.0, 72.0], [534.0, 219.0], [511.0, 219.0]], [[485.0, 72.0], [506.0, 72.0], [507.0, 155.0], [486.0, 155.0]], [[463.0, 73.0], [483.0, 73.0], [483.0, 255.0], [463.0, 255.0]], [[439.0, 72.0], [459.0, 72.0], [459.0, 159.0], [439.0, 159.0]]], "lines": ["この人は", "過去付き合って", "いた男に、", "散々、首を絞められた", "ようです。"]}, {"box": [255, 102, 271, 163], "vertical": true, "font_size": 16, "lines_coords": [[[255.0, 102.0], [271.0, 102.0], [271.0, 163.0], [255.0, 163.0]]], "lines": ["．．．．．．"]}, {"box": [724, 445, 797, 562], "vertical": true, "font_size": 23, "lines_coords": [[[772.0, 446.0], [797.0, 446.0], [797.0, 507.0], [772.0, 507.0]], [[750.0, 447.0], [770.0, 447.0], [770.0, 562.0], [750.0, 562.0]], [[724.0, 445.0], [749.0, 445.0], [749.0, 512.0], [724.0, 512.0]]], "lines": ["彼女は", "首の話題には", "敏感で、"]}, {"box": [362, 425, 432, 589], "vertical": true, "font_size": 22, "lines_coords": [[[405.0, 425.0], [432.0, 425.0], [432.0, 471.0], [405.0, 471.0]], [[384.0, 426.0], [408.0, 426.0], [408.0, 568.0], [384.0, 568.0]], [[363.0, 428.0], [379.0, 428.0], [379.0, 587.0], [363.0, 587.0]]], "lines": ["首に", "触ろうものなら、", "過剰に反応します。"]}, {"box": [701, 778, 795, 933], "vertical": true, "font_size": 21, "lines_coords": [[[777.0, 780.0], [793.0, 780.0], [793.0, 901.0], [777.0, 901.0]], [[751.0, 779.0], [771.0, 779.0], [771.0, 932.0], [751.0, 932.0]], [[723.0, 778.0], [749.0, 778.0], [749.0, 840.0], [723.0, 840.0]], [[701.0, 778.0], [724.0, 778.0], [724.0, 912.0], [701.0, 912.0]]], "lines": ["さらに言うと、", "あのおばちゃんは", "成金で", "貴金属大好き。"]}, {"box": [158, 762, 291, 937], "vertical": true, "font_size": 25, "lines_coords": [[[255.0, 764.0], [289.0, 762.0], [291.0, 822.0], [257.0, 823.0]], [[236.0, 766.0], [260.0, 766.0], [260.0, 895.0], [236.0, 895.0]], [[209.0, 765.0], [234.0, 765.0], [234.0, 834.0], [209.0, 834.0]], [[186.0, 766.0], [206.0, 766.0], [206.0, 937.0], [186.0, 937.0]], [[158.0, 768.0], [181.0, 768.0], [181.0, 924.0], [158.0, 924.0]]], "lines": ["唯一、", "ネックレスの", "ような", "首に付けるものは", "一切付けてない。"]}, {"box": [399, 929, 469, 1102], "vertical": true, "font_size": 20, "lines_coords": [[[449.0, 930.0], [469.0, 930.0], [469.0, 1102.0], [449.0, 1102.0]], [[423.0, 929.0], [444.0, 929.0], [445.0, 1045.0], [424.0, 1045.0]], [[399.0, 930.0], [419.0, 930.0], [419.0, 1010.0], [399.0, 1010.0]]], "lines": ["指輪やイヤリングを", "付けまくって", "いますが"]}], "img_path": "026.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [406, 36, 423, 107], "vertical": true, "font_size": 17, "lines_coords": [[[406.0, 36.0], [423.0, 36.0], [423.0, 107.0], [406.0, 107.0]]], "lines": ["．．．．．．？"]}, {"box": [514, 277, 541, 345], "vertical": true, "font_size": 22, "lines_coords": [[[514.0, 278.0], [539.0, 277.0], [541.0, 344.0], [517.0, 345.0]]], "lines": ["確実に、"]}, {"box": [497, 399, 566, 496], "vertical": true, "font_size": 22, "lines_coords": [[[545.0, 400.0], [566.0, 400.0], [566.0, 478.0], [545.0, 478.0]], [[523.0, 400.0], [542.0, 400.0], [542.0, 496.0], [523.0, 496.0]], [[497.0, 399.0], [521.0, 399.0], [521.0, 467.0], [497.0, 467.0]]], "lines": ["無意識に", "首を守って", "います。"]}, {"box": [146, 469, 218, 632], "vertical": true, "font_size": 22, "lines_coords": [[[187.0, 469.0], [218.0, 469.0], [218.0, 534.0], [187.0, 534.0]], [[170.0, 471.0], [189.0, 471.0], [188.0, 625.0], [168.0, 625.0]], [[146.0, 473.0], [162.0, 473.0], [162.0, 628.0], [146.0, 628.0]]], "lines": ["それが", "名越さんの目には", "こう映るわけです"]}, {"box": [239, 734, 365, 946], "vertical": true, "font_size": 21, "lines_coords": [[[343.0, 737.0], [364.0, 737.0], [364.0, 842.0], [343.0, 842.0]], [[315.0, 734.0], [338.0, 734.0], [338.0, 926.0], [315.0, 926.0]], [[291.0, 735.0], [311.0, 735.0], [311.0, 945.0], [291.0, 945.0]], [[265.0, 735.0], [284.0, 735.0], [284.0, 863.0], [265.0, 863.0]], [[239.0, 735.0], [259.0, 735.0], [259.0, 848.0], [239.0, 848.0]]], "lines": ["ポイントは", "身体的な傷や痛みが", "ホムンクルスになって", "見えるんでは", "ないんです。"]}, {"box": [81, 785, 97, 822], "vertical": true, "font_size": 16, "lines_coords": [[[81.0, 785.0], [97.0, 785.0], [97.0, 822.0], [81.0, 822.0]]], "lines": ["！"]}], "img_path": "027.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [337, 71, 427, 282], "vertical": true, "font_size": 18, "lines_coords": [[[410.0, 72.0], [426.0, 72.0], [426.0, 167.0], [410.0, 167.0]], [[383.0, 71.0], [403.0, 71.0], [403.0, 205.0], [383.0, 205.0]], [[357.0, 71.0], [378.0, 71.0], [379.0, 282.0], [358.0, 282.0]], [[337.0, 72.0], [354.0, 72.0], [354.0, 269.0], [337.0, 269.0]]], "lines": ["あくまでも", "精神的な歪みが", "ホムンクルスに変化して", "見えるということです。"]}, {"box": [738, 280, 809, 397], "vertical": true, "font_size": 20, "lines_coords": [[[786.0, 280.0], [806.0, 280.0], [809.0, 397.0], [789.0, 397.0]], [[763.0, 282.0], [783.0, 282.0], [783.0, 397.0], [763.0, 397.0]], [[738.0, 282.0], [758.0, 282.0], [758.0, 378.0], [738.0, 378.0]]], "lines": ["それによって", "抱えた感情や", "心の傷．．．"]}, {"box": [582, 501, 653, 676], "vertical": true, "font_size": 20, "lines_coords": [[[635.0, 503.0], [651.0, 503.0], [651.0, 598.0], [635.0, 598.0]], [[607.0, 501.0], [630.0, 501.0], [630.0, 639.0], [607.0, 639.0]], [[585.0, 502.0], [605.0, 502.0], [602.0, 676.0], [582.0, 676.0]]], "lines": ["そうすると", "このペラペラな", "オッサンですが．．．"]}, {"box": [269, 359, 302, 419], "vertical": true, "font_size": 31, "lines_coords": [[[272.0, 359.0], [302.0, 360.0], [300.0, 419.0], [269.0, 418.0]]], "lines": ["ほお。"]}, {"box": [348, 506, 378, 562], "vertical": true, "font_size": 30, "lines_coords": [[[348.0, 506.0], [378.0, 506.0], [378.0, 562.0], [348.0, 562.0]]], "lines": ["あっ。"]}, {"box": [194, 542, 219, 571], "vertical": true, "font_size": 25, "lines_coords": [[[194.0, 542.0], [219.0, 542.0], [219.0, 571.0], [194.0, 571.0]]], "lines": ["！？"]}, {"box": [799, 757, 839, 889], "vertical": true, "font_size": 33, "lines_coords": [[[805.0, 759.0], [838.0, 760.0], [832.0, 889.0], [799.0, 888.0]]], "lines": ["ペラペラ"]}, {"box": [336, 781, 476, 920], "vertical": false, "font_size": 139, "lines_coords": [[[336.0, 781.0], [476.0, 781.0], [476.0, 920.0], [336.0, 920.0]]], "lines": ["ちなみにここからは本人の確認を取ってないので、僕の強引な推測・仮説です。"]}, {"box": [335, 781, 476, 919], "vertical": true, "font_size": 19, "lines_coords": [[[454.0, 781.0], [476.0, 781.0], [476.0, 858.0], [454.0, 858.0]], [[431.0, 781.0], [451.0, 781.0], [451.0, 877.0], [431.0, 877.0]], [[409.0, 782.0], [425.0, 782.0], [425.0, 896.0], [409.0, 896.0]], [[383.0, 781.0], [403.0, 781.0], [403.0, 919.0], [383.0, 919.0]], [[358.0, 781.0], [378.0, 781.0], [378.0, 878.0], [358.0, 878.0]], [[335.0, 781.0], [355.0, 781.0], [355.0, 912.0], [335.0, 912.0]]], "lines": ["ちなみに", "ここからは", "本人の確認を", "取ってないので、", "僕の強引な", "推測・仮説です。"]}, {"box": [168, 784, 191, 862], "vertical": true, "font_size": 21, "lines_coords": [[[168.0, 785.0], [189.0, 785.0], [189.0, 862.0], [168.0, 862.0]]], "lines": ["ああ．．．"]}, {"box": [779, 994, 822, 1157], "vertical": true, "font_size": 37, "lines_coords": [[[784.0, 996.0], [820.0, 997.0], [816.0, 1157.0], [779.0, 1156.0]]], "lines": ["厚さ２ｃｈ？"]}, {"box": [270, 999, 336, 1139], "vertical": true, "font_size": 19, "lines_coords": [[[315.0, 1001.0], [335.0, 1001.0], [336.0, 1134.0], [316.0, 1134.0]], [[290.0, 999.0], [310.0, 999.0], [313.0, 1096.0], [293.0, 1096.0]], [[270.0, 1001.0], [287.0, 1001.0], [287.0, 1139.0], [270.0, 1139.0]]], "lines": ["ただのたわごと", "だと思って", "聞いてください。"]}], "img_path": "028.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [445, 45, 540, 229], "vertical": true, "font_size": 23, "lines_coords": [[[517.0, 46.0], [540.0, 46.0], [540.0, 90.0], [517.0, 90.0]], [[493.0, 45.0], [517.0, 45.0], [514.0, 212.0], [491.0, 212.0]], [[467.0, 48.0], [491.0, 48.0], [491.0, 229.0], [467.0, 229.0]], [[445.0, 48.0], [465.0, 48.0], [465.0, 222.0], [445.0, 222.0]]], "lines": ["よく", "「自分は薄っぺらい", "人間だ」という表現が", "あるじゃないですか"]}, {"box": [35, 25, 107, 162], "vertical": true, "font_size": 23, "lines_coords": [[[84.0, 26.0], [104.0, 26.0], [105.0, 162.0], [85.0, 162.0]], [[58.0, 25.0], [83.0, 25.0], [83.0, 91.0], [58.0, 91.0]], [[35.0, 25.0], [59.0, 25.0], [59.0, 96.0], [35.0, 96.0]]], "lines": ["このオッサンは", "まさに", "それで、"]}, {"box": [56, 281, 124, 405], "vertical": true, "font_size": 20, "lines_coords": [[[103.0, 283.0], [123.0, 283.0], [123.0, 405.0], [103.0, 405.0]], [[76.0, 281.0], [100.0, 281.0], [100.0, 343.0], [76.0, 343.0]], [[56.0, 282.0], [72.0, 282.0], [72.0, 401.0], [56.0, 401.0]]], "lines": ["一見、肥えてる", "ように", "見えていても、"]}, {"box": [560, 528, 686, 761], "vertical": true, "font_size": 22, "lines_coords": [[[663.0, 528.0], [684.0, 528.0], [686.0, 740.0], [664.0, 740.0]], [[637.0, 529.0], [657.0, 529.0], [657.0, 623.0], [637.0, 623.0]], [[610.0, 528.0], [635.0, 528.0], [635.0, 658.0], [610.0, 658.0]], [[583.0, 528.0], [607.0, 528.0], [607.0, 761.0], [583.0, 761.0]], [[560.0, 529.0], [580.0, 529.0], [580.0, 642.0], [560.0, 642.0]]], "lines": ["内面的な薄っぺらさを", "補うため、", "大量に食べて", "外面が太ってしまったに", "過ぎません。"]}, {"box": [199, 648, 216, 709], "vertical": true, "font_size": 17, "lines_coords": [[[199.0, 648.0], [216.0, 648.0], [216.0, 709.0], [199.0, 709.0]]], "lines": ["．．．．．．"]}], "img_path": "029.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [687, 158, 731, 253], "vertical": true, "font_size": 20, "lines_coords": [[[710.0, 158.0], [731.0, 158.0], [731.0, 253.0], [710.0, 253.0]], [[687.0, 158.0], [707.0, 158.0], [707.0, 241.0], [687.0, 241.0]]], "lines": ["えらいデブ", "だったぜ。"]}, {"box": [744, 326, 789, 467], "vertical": true, "font_size": 20, "lines_coords": [[[769.0, 326.0], [789.0, 326.0], [789.0, 423.0], [769.0, 423.0]], [[744.0, 326.0], [764.0, 326.0], [764.0, 465.0], [744.0, 465.0]]], "lines": ["肝心なのは", "本人が抱えてる、"]}, {"box": [544, 323, 586, 476], "vertical": true, "font_size": 18, "lines_coords": [[[566.0, 323.0], [586.0, 323.0], [583.0, 476.0], [564.0, 476.0]], [[544.0, 323.0], [560.0, 323.0], [560.0, 405.0], [544.0, 405.0]]], "lines": ["「自分のイメージ」", "なんです"]}, {"box": [318, 638, 437, 820], "vertical": true, "font_size": 20, "lines_coords": [[[409.0, 639.0], [435.0, 638.0], [437.0, 701.0], [411.0, 703.0]], [[389.0, 641.0], [409.0, 641.0], [411.0, 813.0], [391.0, 813.0]], [[365.0, 641.0], [385.0, 641.0], [385.0, 813.0], [365.0, 813.0]], [[341.0, 642.0], [361.0, 642.0], [361.0, 739.0], [341.0, 739.0]], [[320.0, 642.0], [336.0, 642.0], [336.0, 819.0], [320.0, 819.0]]], "lines": ["誰でも", "自分の外見とは違う", "「自分のイメージ」と", "いうものを", "持っているものです。"]}], "img_path": "030.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [344, 335, 361, 398], "vertical": true, "font_size": 17, "lines_coords": [[[344.0, 335.0], [361.0, 335.0], [361.0, 398.0], [344.0, 398.0]]], "lines": ["．．．．．？"]}, {"box": [477, 514, 523, 653], "vertical": true, "font_size": 22, "lines_coords": [[[498.0, 514.0], [523.0, 514.0], [523.0, 577.0], [498.0, 577.0]], [[477.0, 515.0], [497.0, 515.0], [497.0, 653.0], [477.0, 653.0]]], "lines": ["自分を", "イメージしても、"]}, {"box": [287, 547, 306, 587], "vertical": true, "font_size": 19, "lines_coords": [[[287.0, 547.0], [306.0, 547.0], [306.0, 587.0], [287.0, 587.0]]], "lines": ["！"]}, {"box": [389, 657, 457, 779], "vertical": true, "font_size": 22, "lines_coords": [[[435.0, 657.0], [456.0, 657.0], [457.0, 754.0], [436.0, 754.0]], [[410.0, 657.0], [435.0, 657.0], [435.0, 719.0], [410.0, 719.0]], [[389.0, 657.0], [409.0, 657.0], [409.0, 779.0], [389.0, 779.0]]], "lines": ["この外見の", "俺しか", "出てこないぞ。"]}, {"box": [675, 876, 721, 999], "vertical": true, "font_size": 22, "lines_coords": [[[695.0, 876.0], [721.0, 876.0], [721.0, 938.0], [695.0, 938.0]], [[676.0, 880.0], [693.0, 880.0], [693.0, 998.0], [676.0, 998.0]]], "lines": ["だから", "厄介なんです。"]}, {"box": [402, 863, 446, 1013], "vertical": true, "font_size": 18, "lines_coords": [[[428.0, 863.0], [444.0, 863.0], [444.0, 1013.0], [428.0, 1013.0]], [[402.0, 863.0], [422.0, 863.0], [422.0, 944.0], [402.0, 944.0]]], "lines": ["自分のイメージと", "いうのは、"]}, {"box": [112, 875, 158, 990], "vertical": true, "font_size": 20, "lines_coords": [[[137.0, 876.0], [157.0, 876.0], [157.0, 990.0], [137.0, 990.0]], [[112.0, 875.0], [132.0, 875.0], [132.0, 960.0], [112.0, 960.0]]], "lines": ["無意識の中に", "あります。"]}], "img_path": "031.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [498, 59, 520, 166], "vertical": true, "font_size": 20, "lines_coords": [[[498.0, 59.0], [518.0, 59.0], [518.0, 165.0], [498.0, 165.0]]], "lines": ["無意識．．．"]}, {"box": [112, 157, 133, 252], "vertical": true, "font_size": 20, "lines_coords": [[[112.0, 157.0], [132.0, 157.0], [132.0, 251.0], [112.0, 251.0]]], "lines": ["の中．．．．．．？"]}, {"box": [673, 366, 776, 522], "vertical": true, "font_size": 24, "lines_coords": [[[743.0, 366.0], [776.0, 366.0], [776.0, 414.0], [743.0, 414.0]], [[721.0, 367.0], [744.0, 367.0], [742.0, 486.0], [718.0, 486.0]], [[697.0, 369.0], [717.0, 369.0], [715.0, 522.0], [695.0, 522.0]], [[673.0, 369.0], [693.0, 369.0], [693.0, 492.0], [673.0, 492.0]]], "lines": ["その．．", "本来の自分が", "端的に現れるのが", "「夢の中」です。"]}, {"box": [534, 504, 550, 543], "vertical": true, "font_size": 16, "lines_coords": [[[534.0, 504.0], [550.0, 504.0], [550.0, 543.0], [534.0, 543.0]]], "lines": ["！"]}, {"box": [134, 314, 199, 472], "vertical": true, "font_size": 20, "lines_coords": [[[182.0, 315.0], [199.0, 315.0], [199.0, 426.0], [182.0, 426.0]], [[155.0, 314.0], [177.0, 314.0], [177.0, 392.0], [155.0, 392.0]], [[134.0, 314.0], [151.0, 314.0], [151.0, 472.0], [134.0, 472.0]]], "lines": ["とんでもない", "形をした", "自分が出てきたり、"]}, {"box": [137, 508, 206, 664], "vertical": true, "font_size": 20, "lines_coords": [[[186.0, 510.0], [206.0, 510.0], [206.0, 609.0], [186.0, 609.0]], [[162.0, 510.0], [182.0, 510.0], [182.0, 615.0], [162.0, 615.0]], [[138.0, 508.0], [159.0, 508.0], [158.0, 664.0], [137.0, 664.0]]], "lines": ["空を飛んで", "しまったり、", "溶けてしまったり"]}, {"box": [406, 791, 433, 842], "vertical": true, "font_size": 27, "lines_coords": [[[406.0, 791.0], [433.0, 791.0], [433.0, 842.0], [406.0, 842.0]]], "lines": ["ほお、"]}, {"box": [114, 794, 137, 879], "vertical": true, "font_size": 20, "lines_coords": [[[114.0, 794.0], [134.0, 794.0], [137.0, 876.0], [117.0, 876.0]]], "lines": ["なるほど。"]}, {"box": [723, 934, 772, 1001], "vertical": true, "font_size": 49, "lines_coords": [[[723.0, 934.0], [772.0, 934.0], [772.0, 1001.0], [723.0, 1001.0]]], "lines": ["イラ"]}], "img_path": "032.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [345, 98, 390, 153], "vertical": true, "font_size": 45, "lines_coords": [[[345.0, 98.0], [390.0, 98.0], [390.0, 153.0], [345.0, 153.0]]], "lines": ["ぐっ！"]}, {"box": [230, 260, 263, 324], "vertical": true, "font_size": 33, "lines_coords": [[[230.0, 260.0], [263.0, 260.0], [263.0, 324.0], [230.0, 324.0]]], "lines": ["おはようって．．．そういうわけですね"]}, {"box": [70, 190, 88, 233], "vertical": true, "font_size": 18, "lines_coords": [[[70.0, 190.0], [88.0, 190.0], [88.0, 233.0], [70.0, 233.0]]], "lines": ["！"]}, {"box": [518, 283, 623, 476], "vertical": true, "font_size": 24, "lines_coords": [[[592.0, 283.0], [623.0, 283.0], [623.0, 332.0], [592.0, 332.0]], [[573.0, 288.0], [593.0, 288.0], [593.0, 476.0], [573.0, 476.0]], [[546.0, 287.0], [567.0, 287.0], [567.0, 394.0], [546.0, 394.0]], [[518.0, 285.0], [542.0, 285.0], [542.0, 358.0], [518.0, 358.0]]], "lines": ["この", "輪切りギャルなんて", "現代の象徴", "ですよ。"]}, {"box": [366, 548, 411, 651], "vertical": true, "font_size": 21, "lines_coords": [[[385.0, 548.0], [411.0, 548.0], [411.0, 611.0], [385.0, 611.0]], [[367.0, 551.0], [383.0, 551.0], [383.0, 648.0], [367.0, 648.0]]], "lines": ["電話を", "取った途端"]}, {"box": [499, 558, 594, 761], "vertical": true, "font_size": 21, "lines_coords": [[[573.0, 562.0], [593.0, 562.0], [593.0, 669.0], [573.0, 669.0]], [[548.0, 562.0], [568.0, 562.0], [568.0, 744.0], [548.0, 744.0]], [[525.0, 562.0], [545.0, 562.0], [545.0, 660.0], [525.0, 660.0]], [[500.0, 558.0], [524.0, 558.0], [523.0, 761.0], [499.0, 761.0]]], "lines": ["仮に、彼女は", "このパーツ分・Ｂコの", "携帯電話を", "持ってるとしましょう。"]}, {"box": [48, 643, 140, 778], "vertical": true, "font_size": 19, "lines_coords": [[[119.0, 643.0], [139.0, 643.0], [139.0, 740.0], [119.0, 740.0]], [[93.0, 643.0], [114.0, 643.0], [116.0, 760.0], [94.0, 760.0]], [[71.0, 643.0], [91.0, 643.0], [89.0, 778.0], [69.0, 778.0]], [[48.0, 645.0], [64.0, 645.0], [64.0, 745.0], [48.0, 745.0]]], "lines": ["その携帯に", "対応するべく", "パーツが活発に", "回りだした"]}, {"box": [303, 889, 404, 1072], "vertical": true, "font_size": 20, "lines_coords": [[[377.0, 890.0], [397.0, 890.0], [397.0, 1072.0], [377.0, 1072.0]], [[354.0, 890.0], [374.0, 890.0], [374.0, 1006.0], [354.0, 1006.0]], [[329.0, 890.0], [349.0, 890.0], [349.0, 1045.0], [329.0, 1045.0]], [[303.0, 889.0], [324.0, 889.0], [327.0, 1052.0], [306.0, 1052.0]]], "lines": ["まるで、自分の身体を", "商品のように", "バラ売りしている", "人形みたいでしょ。"]}], "img_path": "033.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [601, 36, 622, 114], "vertical": true, "font_size": 21, "lines_coords": [[[601.0, 36.0], [622.0, 36.0], [622.0, 113.0], [601.0, 113.0]]], "lines": ["ここ．．．"]}, {"box": [236, 55, 333, 212], "vertical": true, "font_size": 21, "lines_coords": [[[314.0, 58.0], [330.0, 58.0], [330.0, 134.0], [314.0, 134.0]], [[288.0, 57.0], [308.0, 57.0], [308.0, 174.0], [288.0, 174.0]], [[265.0, 57.0], [284.0, 57.0], [284.0, 212.0], [265.0, 212.0]], [[