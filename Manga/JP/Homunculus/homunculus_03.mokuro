0]]], "lines": ["なんだあ"]}, {"box": [623, 19, 669, 117], "vertical": true, "font_size": 20, "lines_coords": [[[648.0, 21.0], [669.0, 21.0], [669.0, 97.0], [648.0, 97.0]], [[623.0, 19.0], [643.0, 19.0], [643.0, 117.0], [623.0, 117.0]]], "lines": ["ノリ悪い", "なあ～～．．．"]}, {"box": [151, 70, 198, 241], "vertical": true, "font_size": 20, "lines_coords": [[[177.0, 70.0], [198.0, 70.0], [195.0, 219.0], [174.0, 219.0]], [[151.0, 71.0], [171.0, 71.0], [171.0, 241.0], [151.0, 241.0]]], "lines": ["人の心の歪みが", "見えるんですよ！！"]}, {"box": [744, 509, 797, 650], "vertical": true, "font_size": 24, "lines_coords": [[[772.0, 509.0], [797.0, 509.0], [797.0, 604.0], [772.0, 604.0]], [[744.0, 509.0], [768.0, 509.0], [768.0, 649.0], [744.0, 649.0]]], "lines": ["うらやま", "しいなあ～～"]}, {"box": [464, 223, 531, 398], "vertical": true, "font_size": 20, "lines_coords": [[[510.0, 226.0], [530.0, 226.0], [530.0, 370.0], [510.0, 370.0]], [[484.0, 223.0], [507.0, 223.0], [507.0, 398.0], [484.0, 398.0]], [[464.0, 226.0], [480.0, 226.0], [480.0, 341.0], [464.0, 341.0]]], "lines": ["今、名越さんには", "凄いことが起こって", "るんですよ！"]}, {"box": [363, 509, 381, 574], "vertical": true, "font_size": 18, "lines_coords": [[[363.0, 509.0], [381.0, 509.0], [381.0, 574.0], [363.0, 574.0]]], "lines": ["．．．"]}, {"box": [705, 809, 777, 908], "vertical": true, "font_size": 21, "lines_coords": [[[751.0, 809.0], [777.0, 809.0], [777.0, 873.0], [751.0, 873.0]], [[732.0, 814.0], [749.0, 814.0], [749.0, 908.0], [732.0, 908.0]], [[705.0, 812.0], [725.0, 812.0], [725.0, 894.0], [705.0, 894.0]]], "lines": ["歪みが", "見えるのは", "わかった"]}, {"box": [521, 795, 619, 894], "vertical": true, "font_size": 21, "lines_coords": [[[593.0, 795.0], [619.0, 795.0], [619.0, 847.0], [593.0, 847.0]], [[569.0, 798.0], [591.0, 798.0], [591.0, 894.0], [569.0, 894.0]], [[546.0, 796.0], [566.0, 796.0], [566.0, 875.0], [546.0, 875.0]], [[521.0, 796.0], [541.0, 796.0], [541.0, 881.0], [521.0, 881.0]]], "lines": ["じゃ、", "その歪み．．．", "化け物を", "消すには、"]}, {"box": [162, 775, 198, 815], "vertic