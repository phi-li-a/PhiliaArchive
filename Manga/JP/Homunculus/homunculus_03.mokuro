rue, "font_size": 21, "lines_coords": [[[480.0, 604.0], [505.0, 604.0], [505.0, 666.0], [480.0, 666.0]], [[459.0, 607.0], [479.0, 607.0], [479.0, 739.0], [459.0, 739.0]], [[435.0, 608.0], [456.0, 608.0], [456.0, 683.0], [435.0, 683.0]], [[413.0, 608.0], [430.0, 608.0], [430.0, 727.0], [413.0, 727.0]]], "lines": ["今日は", "マジックミラー", "コースで", "いきましょう。"]}, {"box": [290, 600, 313, 630], "vertical": true, "font_size": 23, "lines_coords": [[[290.0, 601.0], [313.0, 601.0], [313.0, 629.0], [290.0, 629.0]]], "lines": ["？"]}, {"box": [701, 857, 748, 980], "vertical": true, "font_size": 20, "lines_coords": [[[722.0, 857.0], [748.0, 857.0], [748.0, 919.0], [722.0, 919.0]], [[701.0, 861.0], [721.0, 861.0], [721.0, 980.0], [701.0, 980.0]]], "lines": ["最新の", "ホムンクルス、"]}, {"box": [664, 1033, 731, 1146], "vertical": true, "font_size": 20, "lines_coords": [[[710.0, 1033.0], [731.0, 1033.0], [731.0, 1110.0], [710.0, 1110.0]], [[688.0, 1035.0], [704.0, 1035.0], [704.0, 1146.0], [688.0, 1146.0]], [[664.0, 1035.0], [681.0, 1035.0], [681.0, 1135.0], [664.0, 1135.0]]], "lines": ["新世代の", "化け物たちの", "集まりです"]}, {"box": [323, 1078, 343, 1141], "vertical": true, "font_size": 20, "lines_coords": [[[323.0, 1078.0], [343.0, 1078.0], [343.0, 1141.0], [323.0, 1141.0]]], "lines": ["．．．？"]}], "img_path": "103.png"}, {"version": "0.1.7", "img_width": 1725, "img_height": 1200, "blocks": [{"box": [1399, 355, 1450, 490], "vertical": true, "font_size": 25.0, "lines_coords": [[[1426.0, 360.0], [1450.0, 360.0], [1450.0, 487.0], [1426.0, 487.0]], [[1399.0, 355.0], [1425.0, 355.0], [1428.0, 490.0], [1403.0, 490.0]]], "lines": ["ゲクトル８０", "ＹＰＢＬＴＤＳブラ"]}, {"box": [1070, 316, 1124, 489], "vertical": true, "font_size": 54, "lines_coords": [[[1070.0, 316.0], [1124.0, 316.0], [1124.0, 489.0], [1070.0, 489.0]]], "lines": ["はあああっ！！"]}, {"box": [956, 584, 1002, 774], "vertical": true, "font_size": 20, "lines_coords": [[[978.0, 640.0], [1000.0, 640.0], [997.0, 748.0], [975.0, 748.0]], [[956.0, 632.0], [975.0, 632.0], [975.0, 751.0], [956.0, 751.0]]], "lines": ["．．．", "ペｐ８Ｌ＝ＤＳブ"]}, {"box": [1206, 1082, 1480, 1199], "vertical": false, "font_size": 31, "lines_coords": [[[1222.0, 1095.0], [1475.0, 1082.0], [1477.0, 1120.0], [1224.0, 1134.0]], [[1217.0, 1134.0], [1430.0, 1125.0], [1431.0, 1159.0], [1219.0, 1167.0]], [[1320.0, 1169.0], [1460.0, 1169.0], [1460.0, 1191.0], [1320.0, 1191.0]]], "lines": ["番号がこんなのが", "は新人さんです", "た本の様に"]}, {"box": [1005, 1156, 1094, 1174], "vertical": false, "font_size": 18, "lines_coords": [[[1005.0, 1156.0], [1094.0, 1156.0], [1094.0, 1174.0], [1005.0, 1174.0]]], "lines": ["ご囲まれ"]}, {"box": [626, 587, 673, 783], "vertical": true, "font_size": 22, "lines_coords": [[[648.0, 642.0], [672.0, 642.0], [672.0, 776.0], [648.0, 776.0]], [[631.0, 716.0], [650.0, 716.0], [650.0, 780.0], [631.0, 780.0]]], "lines": ["ち８３７９ん", "ＤＳブ"]}, {"box": [636, 1078, 667, 1176], "vertical": true, "font_size": 31, "lines_coords": [[[636.0, 1078.0], [667.0, 1078.0], [667.0, 1176.0], [636.0, 1176.0]]], "lines": ["こ．．．しんな近くに"]}, {"box": [124, 1117, 271, 1152], "vertical": false, "font_size": 30, "lines_coords": [[[124.0, 1117.0], [271.0, 1122.0], [271.0, 1152.0], [124.0, 1147.0]]], "lines": ["していない商品"]}], "img_path": "104.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [736, 40, 752, 104], "vertical": true, "font_size": 16, "lines_coords": [[[736.0, 40.0], [752.0, 40.0], [752.0, 104.0], [736.0, 104.0]]], "lines": ["．．．．．．？"]}, {"box": [198, 435, 288, 588], "vertical": true, "font_size": 19, "lines_coords": [[[268.0, 438.0], [288.0, 438.0], [288.0, 588.0], [268.0, 588.0]], [[243.0, 435.0], [265.0, 435.0], [265.0, 521.0], [243.0, 521.0]], [[221.0, 438.0], [238.0, 438.0], [238.0, 550.0], [221.0, 550.0]], [[198.0, 437.0], [214.0, 437.0], [214.0, 556.0], [198.0, 556.0]]], "lines": ["マジックミラーに", "なってて、", "向こうからは", "見えてません。"]}, {"box": [79, 675, 287, 769], "vertical": false, "font_size": 18.5, "lines_coords": [[[80.0, 730.0], [282.0, 675.0], [287.0, 694.0], [85.0, 750.0]], [[79.0, 753.0], [155.0, 734.0], [159.0, 751.0], [83.0, 769.0]]], "lines": ["もちろん現在買わないで「企業」の", "利用もできます。"]}, {"box": [85, 779, 184, 817], "vertical": false, "font_size": 20, "lines_coords": [[[85.0, 798.0], [180.0, 779.0], [184.0, 799.0], [89.0, 817.0]]], "lines": ["表情タイム・５分"]}, {"box": [79, 853, 212, 939], "vertical": false, "font_size": 19.333333333333332, "lines_coords": [[[86.0, 873.0], [208.0, 853.0], [212.0, 873.0], [90.0, 892.0]], [[80.0, 898.0], [191.0, 883.0], [194.0, 903.0], [84.0, 918.0]], [[79.0, 922.0], [171.0, 910.0], [173.0, 928.0], [82.0, 939.0]]], "lines": ["お客観賞タイムよ５分", "（ビキニはスクール）", "まあえるところがスリ"]}, {"box": [370, 728, 484, 799], "vertical": false, "font_size": 20.333333333333332, "lines_coords": [[[375.0, 728.0], [463.0, 742.0], [459.0, 764.0], [371.0, 750.0]], [[374.0, 750.0], [484.0, 769.0], [480.0, 791.0], [370.0, 771.0]], [[418.0, 782.0], [443.0, 782.0], [443.0, 799.0], [418.0, 799.0]]], "lines": ["・ヤッチすぎりたい面から、", "いや、そんなこと言われる桜を押し込みにしています。", "〈微〉"]}, {"box": [555, 752, 577, 848], "vertical": true, "font_size": 20, "lines_coords": [[[555.0, 752.0], [575.0, 752.0], [575.0, 847.0], [555.0, 847.0]]], "lines": ["なんだ．．．"]}, {"box": [172, 902, 252, 925], "vertical": false, "font_size": 16, "lines_coords": [[[172.0, 909.0], [250.0, 902.0], [252.0, 918.0], [173.0, 925.0]]], "lines": ["リガラス越しに"]}, {"box": [231, 1062, 368, 1185], "vertical": false, "font_size": 18.833333333333332, "lines_coords": [[[231.0, 1062.0], [348.0, 1062.0], [348.0, 1082.0], [231.0, 1082.0]], [[233.0, 1083.0], [368.0, 1082.0], [368.0, 1102.0], [233.0, 1103.0]], [[238.0, 1106.0], [304.0, 1106.0], [304.0, 1122.0], [238.0, 1122.0]], [[239.0, 1119.0], [367.0, 1126.0], [365.0, 1146.0], [238.0, 1139.0]], [[238.0, 1136.0], [337.0, 1146.0], [335.0, 1164.0], [235.0, 1155.0]], [[242.0, 1156.0], [344.0, 1168.0], [342.0, 1185.0], [240.0, 1174.0]]], "lines": ["体操番となんですか？", "「おれがどのような人の日へすではでます。", "もちろんない人は、", "それより、人は．．．でもやっぱり体験をご", "たとんの女子高生が、", "はい。いやいよい。ついてみれたでしょう。"]}, {"box": [470, 966, 492, 1064], "vertical": true, "font_size": 21, "lines_coords": [[[470.0, 966.0], [491.0, 966.0], [492.0, 1062.0], [471.0, 1062.0]]], "lines": ["こりゃ．．．"]}, {"box": [405, 1134, 525, 1200], "vertical": false, "font_size": 66, "lines_coords": [[[405.0, 1134.0], [525.0, 1134.0], [525.0, 1200.0], [405.0, 1200.0]]], "lines": ["本来君の土田家"]}, {"box": [541, 1052, 571, 1124], "vertical": true, "font_size": 12, "lines_coords": [[[544.0, 1068.0], [555.0, 1068.0], [553.0, 1121.0], [541.0, 1121.0]]], "lines": ["どうした！！"]}], "img_path": "105.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [317, 76, 408, 209], "vertical": true, "font_size": 18, "lines_coords": [[[389.0, 78.0], [405.0, 78.0], [405.0, 172.0], [389.0, 172.0]], [[362.0, 76.0], [383.0, 76.0], [383.0, 153.0], [362.0, 153.0]], [[338.0, 76.0], [358.0, 76.0], [358.0, 173.0], [338.0, 173.0]], [[317.0, 76.0], [333.0, 76.0], [333.0, 209.0], [317.0, 209.0]]], "lines": ["ブルセラと", "いうのは", "聞いたこと", "ありますよね？"]}, {"box": [374, 389, 468, 589], "vertical": true, "font_size": 21, "lines_coords": [[[446.0, 390.0], [467.0, 390.0], [465.0, 486.0], [444.0, 486.0]], [[423.0, 391.0], [443.0, 391.0], [443.0, 507.0], [423.0, 507.0]], [[398.0, 390.0], [418.0, 390.0], [418.0, 526.0], [398.0, 526.0]], [[374.0, 389.0], [397.0, 389.0], [397.0, 589.0], [374.0, 589.0]]], "lines": ["女子高生の", "制服や下着や", "ブルマーなどを", "売ってるような所です。"]}, {"box": [270, 376, 290, 454], "vertical": true, "font_size": 20, "lines_coords": [[[270.0, 376.0], [290.0, 376.0], [290.0, 453.0], [270.0, 453.0]]], "lines": ["ああ．．．"]}, {"box": [21, 375, 69, 492], "vertical": true, "font_size": 22, "lines_coords": [[[46.0, 377.0], [66.0, 377.0], [66.0, 492.0], [46.0, 492.0]], [[21.0, 375.0], [46.0, 375.0], [46.0, 425.0], [21.0, 425.0]]], "lines": ["聞いたことは", "ある。"]}, {"box": [647, 735, 725, 919], "vertical": true, "font_size": 23, "lines_coords": [[[703.0, 739.0], [723.0, 739.0], [723.0, 919.0], [703.0, 919.0]], [[673.0, 737.0], [696.0, 737.0], [696.0, 900.0], [673.0, 900.0]], [[647.0, 737.0], [673.0, 735.0], [675.0, 802.0], [649.0, 803.0]]], "lines": ["ここは、それの変形で", "〝生セラくといって、", "“生”で、"]}, {"box": [417, 806, 460, 915], "vertical": true, "font_size": 20.0, "lines_coords": [[[440.0, 808.0], [460.0, 808.0], [458.0, 901.0], [438.0, 901.0]], [[419.0, 806.0], [439.0, 806.0], [437.0, 915.0], [417.0, 915.0]]], "lines": ["．．．", "ｐ８ＬＤＳ７．"]}, {"box": [143, 808, 165, 888], "vertical": true, "font_size": 21, "lines_coords": [[[143.0, 808.0], [164.0, 808.0], [165.0, 888.0], [144.0, 888.0]]], "lines": ["．．．"]}, {"box": [77, 931, 172, 1121], "vertical": true, "font_size": 18, "lines_coords": [[[151.0, 932.0], [171.0, 932.0], [171.0, 1047.0], [151.0, 1047.0]], [[128.0, 932.0], [145.0, 932.0], [145.0, 1120.0], [128.0, 1120.0]], [[105.0, 931.0], [121.0, 931.0], [119.0, 1065.0], [103.0, 1065.0]], [[79.0, 931.0], [99.0, 931.0], [97.0, 1054.0], [77.0, 1054.0]]], "lines": ["いわゆる直接", "女子高生を鑑賞したり、", "下着を買ったり", "できる所です。"]}], "img_path": "106.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [741, 22, 807, 174], "vertical": true, "font_size": 17, "lines_coords": [[[791.0, 23.0], [807.0, 23.0], [807.0, 174.0], [791.0, 174.0]], [[766.0, 23.0], [783.0, 23.0], [783.0, 155.0], [766.0, 155.0]], [[742.0, 22.0], [759.0, 22.0], [758.0, 162.0], [741.0, 162.0]]], "lines": ["性的なサービスや", "売春行為などは", "ありませんか．．．"]}, {"box": [678, 196, 721, 295], "vertical": true, "font_size": 17, "lines_coords": [[[701.0, 196.0], [721.0, 196.0], [721.0, 292.0], [701.0, 292.0]], [[678.0, 198.0], [695.0, 198.0], [695.0, 295.0], [678.0, 295.0]]], "lines": ["ギリギリの", "商売ですよ"]}, {"box": [481, 43, 657, 244], "vertical": false, "font_size": 169, "lines_coords": [[[552.0, 43.0], [657.0, 90.0], [587.0, 244.0], [481.0, 196.0]]], "lines": ["（２）２０１７年６月１５日（土）は、それぞれになりました！！"]}, {"box": [496, 66, 636, 235], "vertical": true, "font_size": 32.0, "lines_coords": [[[607.0, 135.0], [636.0, 137.0], [634.0, 226.0], [605.0, 225.0]], [[576.0, 119.0], [610.0, 119.0], [610.0, 220.0], [576.0, 220.0]], [[520.0, 67.0], [553.0, 66.0], [560.0, 234.0], [527.0, 235.0]], [[498.0, 90.0], [531.0, 90.0], [528.0, 232.0], [496.0, 232.0]]], "lines": ["一学ま", "は際り", "２店助て！", "当機しん"]}, {"box": [416, 176, 443, 230], "vertical": true, "font_size": 27, "lines_coords": [[[416.0, 176.0], [443.0, 176.0], [443.0, 230.0], [416.0, 230.0]]], "lines": ["おっ。"]}, {"box": [214, 46, 245, 80], "vertical": true, "font_size": 31, "lines_coords": [[[214.0, 46.0], [245.0, 46.0], [245.0, 80.0], [214.0, 80.0]]], "lines": ["！？"]}, {"box": [492, 437, 538, 523], "vertical": true, "font_size": 22, "lines_coords": [[[513.0, 437.0], [538.0, 437.0], [538.0, 499.0], [513.0, 499.0]], [[492.0, 438.0], [512.0, 438.0], [512.0, 519.0], [492.0, 519.0]]], "lines": ["あの子", "いいなあ"]}, {"box": [111, 499, 126, 561], "vertical": true, "font_size": 15, "lines_coords": [[[111.0, 499.0], [126.0, 499.0], [126.0, 561.0], [111.0, 561.0]]], "lines": ["．．．"]}, {"box": [566, 653, 657, 787], "vertical": true, "font_size": 18, "lines_coords": [[[639.0, 655.0], [655.0, 655.0], [655.0, 787.0], [639.0, 787.0]], [[613.0, 655.0], [633.0, 655.0], [633.0, 758.0], [613.0, 758.0]], [[589.0, 653.0], [609.0, 653.0], [609.0, 769.0], [589.0, 769.0]], [[566.0, 657.0], [582.0, 657.0], [582.0, 768.0], [566.0, 768.0]]], "lines": ["俺をこんな所に", "連れてきて、", "どうしろって", "いうんだ．．．？"]}, {"box": [453, 636, 478, 696], "vertical": true, "font_size": 25, "lines_coords": [[[453.0, 636.0], [478.0, 636.0], [478.0, 696.0], [453.0, 696.0]]], "lines": ["イ．．．"]}, {"box": [93, 698, 140, 795], "vertical": true, "font_size": 20, "lines_coords": [[[117.0, 699.0], [137.0, 699.0], [139.0, 795.0], [119.0, 795.0]], [[93.0, 698.0], [114.0, 698.0], [114.0, 765.0], [93.0, 765.0]]], "lines": ["わかってる", "くせに。"]}], "img_path": "107.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [403, 173, 431, 264], "vertical": true, "font_size": 28, "lines_coords": [[[403.0, 173.0], [431.0, 173.0], [431.0, 264.0], [403.0, 264.0]]], "lines": ["１５ｋｇｅｒｉｎｅ！！！？ＤＢＬｏＳＴ"]}, {"box": [238, 444, 340, 699], "vertical": true, "font_size": 23, "lines_coords": [[[317.0, 446.0], [337.0, 446.0], [337.0, 553.0], [317.0, 553.0]], [[290.0, 444.0], [314.0, 444.0], [311.0, 699.0], [288.0, 699.0]], [[263.0, 445.0], [287.0, 445.0], [287.0, 616.0], [263.0, 616.0]], [[238.0, 446.0], [261.0, 446.0], [261.0, 581.0], [238.0, 581.0]]], "lines": ["この中から", "２新世代のホムンクルスムを", "見つけてくれれば", "いいんですよ。"]}, {"box": [276, 728, 340, 740], "vertical": false, "font_size": 12, "lines_coords": [[[276.0, 728.0], [340.0, 728.0], [340.0, 740.0], [276.0, 740.0]]], "lines": ["お客様の"]}, {"box": [37, 655, 173, 768], "vertical": false, "font_size": 22, "lines_coords": [[[72.0, 655.0], [172.0, 655.0], [172.0, 693.0], [72.0, 693.0]], [[78.0, 693.0], [168.0, 693.0], [168.0, 714.0], [78.0, 714.0]], [[64.0, 725.0], [168.0, 724.0], [168.0, 741.0], [64.0, 742.0]], [[52.0, 751.0], [139.0, 751.0], [139.0, 764.0], [52.0, 764.0]]], "lines": ["かに表示", "ないね。", "それほどが", "そういうことで、"]}, {"box": [665, 1019, 685, 1094], "vertical": true, "font_size": 20, "lines_coords": [[[665.0, 1019.0], [685.0, 1019.0], [685.0, 1094.0], [665.0, 1094.0]]], "lines": ["．．．．．．"]}], "img_path": "108.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [613, 37, 659, 124], "vertical": true, "font_size": 22, "lines_coords": [[[634.0, 37.0], [659.0, 37.0], [659.0, 100.0], [634.0, 100.0]], [[613.0, 41.0], [633.0, 41.0], [633.0, 123.0], [613.0, 123.0]]], "lines": ["見ても", "無駄だろ。"]}, {"box": [606, 235, 630, 262], "vertical": true, "font_size": 24, "lines_coords": [[[606.0, 235.0], [630.0, 235.0], [630.0, 262.0], [606.0, 262.0]]], "lines": ["？"]}, {"box": [596, 228, 639, 270], "vertical": false, "font_size": 33, "lines_coords": [[[607.0, 228.0], [639.0, 239.0], [628.0, 270.0], [596.0, 260.0]]], "lines": ["！？"]}, {"box": [389, 32, 484, 205], "vertical": true, "font_size": 19, "lines_coords": [[[465.0, 33.0], [481.0, 33.0], [481.0, 145.0], [465.0, 145.0]], [[438.0,