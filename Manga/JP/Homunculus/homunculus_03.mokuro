ont_size": 21, "lines_coords": [[[284.0, 816.0], [309.0, 815.0], [313.0, 924.0], [288.0, 925.0]], [[263.0, 817.0], [283.0, 817.0], [283.0, 1010.0], [263.0, 1010.0]], [[238.0, 817.0], [257.0, 817.0], [257.0, 971.0], [238.0, 971.0]]], "lines": ["どうすれば", "このホムンクルスを", "退治できるのか。"]}], "img_path": "039.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [333, 31, 454, 239], "vertical": true, "font_size": 28, "lines_coords": [[[418.0, 31.0], [454.0, 31.0], [454.0, 86.0], [418.0, 86.0]], [[396.0, 37.0], [420.0, 37.0], [420.0, 196.0], [396.0, 196.0]], [[361.0, 35.0], [389.0, 35.0], [389.0, 239.0], [361.0, 239.0]], [[333.0, 33.0], [357.0, 33.0], [357.0, 133.0], [333.0, 133.0]]], "lines": ["この", "ホムンクルスは", "「生き霊」だと思って、", "ください。"]}, {"box": [654, 381, 675, 487], "vertical": true, "font_size": 20, "lines_coords": [[[654.0, 382.0], [674.0, 382.0], [674.0, 487.0], [654.0, 487.0]]], "lines": ["生き霊．．．？"]}, {"box": [171, 404, 192, 490], "vertical": true, "font_size": 21, "lines_coords": [[[171.0, 404.0], [192.0, 404.0], [192.0, 489.0], [171.0, 489.0]]], "lines": ["ええ．．．"]}, {"box": [667, 782, 742, 936], "vertical": true, "font_size": 21, "lines_coords": [[[711.0, 782.0], [742.0, 782.0], [742.0, 828.0], [711.0, 828.0]], [[690.0, 786.0], [710.0, 786.0], [710.0, 936.0], [690.0, 936.0]], [[667.0, 786.0], [687.0, 786.0], [687.0, 883.0], [667.0, 883.0]]], "lines": ["この", "「生き霊を消す」と", "いうことは"]}, {"box": [216, 779, 284, 914], "vertical": true, "font_size": 19, "lines_coords": [[[263.0, 781.0], [283.0, 781.0], [283.0, 896.0], [263.0, 896.0]], [[238.0, 779.0], [259.0, 779.0], [260.0, 876.0], [239.0, 876.0]], [[216.0, 781.0], [233.0, 781.0], [233.0, 912.0], [216.0, 912.0]]], "lines": ["精神療法的な", "話になって", "恐縮ですか．．．"]}, {"box": [625, 1006, 716, 1140], "vertical": true, "font_size": 21, "lines_coords": [[[695.0, 1006.0], [716.0, 1006.0], [716.0, 1082.0], [695.0, 1082.0]], [[671.0, 1006.0], [691.0, 1006.0], [689.0, 1140.0], [669.0, 1140.0]], [[648.0, 1007.0], [664.0, 1007.0], [664.0, 1101.0], [648.0, 1101.0]], [[625.0, 1007.0], [641.0, 1007.0], [641.0, 1126.0], [625.0, 1126.0]]], "lines": ["その人の", "「歪みを消す」と", "いうことに", "なりますから、"]}], "img_path": "040.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [544, 34, 561, 96], "vertical": true, "font_size": 17, "lines_coords": [[[544.0, 34.0], [561.0, 34.0], [561.0, 96.0], [544.0, 96.0]]], "lines": ["．．．？"]}, {"box": [129, 141, 148, 180], "vertical": true, "font_size": 19, "lines_coords": [[[129.0, 141.0], [148.0, 141.0], [148.0, 180.0], [129.0, 180.0]]], "lines": ["！"]}, {"box": [436, 665, 531, 707], "vertical": false, "font_size": 40, "lines_coords": [[[436.0, 667.0], [530.0, 665.0], [531.0, 705.0], [437.0, 707.0]]], "lines": ["無意が"]}, {"box": [133, 902, 247, 1112], "vertical": true, "font_size": 25, "lines_coords": [[[220.0, 904.0], [245.0, 904.0], [247.0, 1053.0], [222.0, 1053.0]], [[193.0, 902.0], [221.0, 902.0], [216.0, 1112.0], [188.0, 1112.0]], [[165.0, 904.0], [188.0, 904.0], [186.0, 1067.0], [162.0, 1067.0]], [[136.0, 903.0], [160.0, 903.0], [158.0, 1075.0], [133.0, 1075.0]]], "lines": ["これが人間で、", "「意議」と「無意識」で", "構成されてると", "思ってください。"]}], "img_path": "041.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [710, 179, 804, 332], "vertical": true, "font_size": 21, "lines_coords": [[[780.0, 179.0], [804.0, 179.0], [804.0, 222.0], [780.0, 222.0]], [[758.0, 180.0], [779.0, 180.0], [777.0, 296.0], [756.0, 296.0]], [[735.0, 179.0], [755.0, 179.0], [756.0, 332.0], [736.0, 332.0]], [[710.0, 179.0], [730.0, 179.0], [730.0, 266.0], [710.0, 266.0]]], "lines": ["まあ", "「頭」と「心」と", "思ってもらってる", "結構です。"]}, {"box": [340, 58, 408, 144], "vertical": true, "font_size": 21, "lines_coords": [[[384.0, 60.0], [405.0, 60.0], [405.0, 137.0], [384.0, 137.0]], [[360.0, 58.0], [385.0, 58.0], [385.0, 123.0], [360.0, 123.0]], [[340.0, 60.0], [356.0, 60.0], [356.0, 144.0], [340.0, 144.0]]], "lines": ["無意識か", "やたら", "でけえな。"]}, {"box": [384, 316, 476, 467], "vertical": true, "font_size": 18, "lines_coords": [[[456.0, 317.0], [476.0, 317.0], [476.0, 435.0], [456.0, 435.0]], [[431.0, 316.0], [451.0, 316.0], [451.0, 448.0], [431.0, 448.0]], [[408.0, 316.0], [424.0, 316.0], [424.0, 467.0], [408.0, 467.0]], [[385.0, 317.0], [402.0, 317.0], [402.0, 457.0], [385.0, 457.0]]], "lines": ["一説によると、", "無意識が人間の", "５％を占めてると", "言われています。"]}, {"box": [678, 596, 751, 676], "vertical": true, "font_size": 26, "lines_coords": [[[725.0, 598.0], [751.0, 598.0], [751.0, 659.0], [725.0, 659.0]], [[702.0, 598.0], [728.0, 598.0], [728.0, 664.0], [702.0, 664.0]], [[678.0, 596.0], [703.0, 596.0], [703.0, 676.0], [678.0, 676.0]]], "lines": ["例えば", "無意識、", "心に．．．"]}, {"box": [431, 839, 526, 958], "vertical": true, "font_size": 23, "lines_coords": [[[505.0, 840.0], [526.0, 840.0], [526.0, 901.0], [505.0, 901.0]], [[480.0, 841.0], [501.0, 841.0], [501.0, 937.0], [480.0, 937.0]], [[454.0, 839.0], [479.0, 839.0], [477.0, 958.0], [452.0, 958.0]], [[431.0, 840.0], [456.0, 840.0], [456.0, 908.0], [431.0, 908.0]]], "lines": ["父親を", "憎んでいる", "人間がいると", "します。"]}, {"box": [228, 991, 266, 1030], "vertical": true, "font_size": 38, "lines_coords": [[[228.0, 991.0], [266.0, 991.0], [266.0, 1030.0], [228.0, 1030.0]]], "lines": ["！？"]}], "img_path": "042.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [664, 60, 715, 140], "vertical": true, "font_size": 26, "lines_coords": [[[686.0, 60.0], [715.0, 60.0], [715.0, 126.0], [686.0, 126.0]], [[664.0, 63.0], [686.0, 63.0], [686.0, 140.0], [664.0, 140.0]]], "lines": ["しかし", "意識．．．"]}, {"box": [136, 91, 207, 264], "vertical": true, "font_size": 21, "lines_coords": [[[182.0, 91.0], [207.0, 91.0], [207.0, 158.0], [182.0, 158.0]], [[160.0, 91.0], [180.0, 91.0], [180.0, 264.0], [160.0, 264.0]], [[137.0, 91.0], [154.0, 91.0], [153.0, 229.0], [136.0, 229.0]]], "lines": ["頭では、", "父親を好きなんだと", "思い込んでいる"]}, {"box": [430, 341, 497, 475], "vertical": true, "font_size": 20, "lines_coords": [[[477.0, 341.0], [497.0, 341.0], [497.0, 444.0], [477.0, 444.0]], [[451.0, 341.0], [472.0, 341.0], [474.0, 475.0], [453.0, 475.0]], [[430.0, 341.0], [450.0, 341.0], [450.0, 426.0], [430.0, 426.0]]], "lines": ["ここで矛盾、", "問題が出てくる", "わけです。"]}, {"box": [314, 328, 361, 463], "vertical": true, "font_size": 22, "lines_coords": [[[336.0, 328.0], [361.0, 328.0], [361.0, 391.0], [336.0, 391.0]], [[314.0, 329.0], [334.0, 329.0], [334.0, 461.0], [314.0, 461.0]]], "lines": ["すると", "その問題を．．．"]}, {"box": [32, 351, 104, 488], "vertical": true, "font_size": 22, "lines_coords": [[[83.0, 356.0], [103.0, 356.0], [103.0, 471.0], [83.0, 471.0]], [[58.0, 356.0], [78.0, 356.0], [78.0, 488.0], [58.0, 488.0]], [[32.0, 351.0], [58.0, 351.0], [58.0, 404.0], [32.0, 404.0]]], "lines": ["無意識の中に", "抑圧してしまい", "ます。"]}, {"box": [687, 605, 718, 664], "vertical": true, "font_size": 31, "lines_coords": [[[687.0, 605.0], [718.0, 605.0], [718.0, 664.0], [687.0, 664.0]]], "lines": ["ふむ。"]}, {"box": [653, 802, 721, 964], "vertical": true, "font_size": 20, "lines_coords": [[[700.0, 802.0], [720.0, 802.0], [720.0, 964.0], [700.0, 964.0]], [[675.0, 802.0], [696.0, 802.0], [694.0, 891.0], [673.0, 891.0]], [[653.0, 802.0], [673.0, 802.0], [673.0, 889.0], [653.0, 889.0]]], "lines": ["「父親を憎んでいる", "気持ち」を", "凍らせて、"]}, {"box": [294, 819, 388, 941], "vertical": true, "font_size": 20, "lines_coords": [[[364.0, 819.0], [385.0, 819.0], [388.0, 896.0], [367.0, 896.0]], [[343.0, 819.0], [363.0, 819.0], [363.0, 930.0], [343.0, 930.0]], [[320.0, 819.0], [340.0, 819.0], [340.0, 935.0], [320.0, 935.0]], [[296.0, 819.0], [316.0, 819.0], [314.0, 936.0], [294.0, 936.0]]], "lines": ["無意識の", "奥底のほうへ", "沈めてしまう", "感じっすかね"]}, {"box": [159, 815, 240, 853], "vertical": false, "font_size": 31, "lines_coords": [[[161.0, 815.0], [240.0, 822.0], [238.0, 853.0], [159.0, 846.0]]], "lines": ["無意識"]}], "img_path": "043.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [471, 55, 514, 195], "vertical": true, "font_size": 17, "lines_coords": [[[493.0, 55.0], [511.0, 55.0], [512.0, 187.0], [494.0, 187.0]], [[471.0, 56.0], [487.0, 56.0], [487.0, 191.0], [471.0, 191.0]]], "lines": ["これを深い所に", "隠せば隠すほど"]}, {"box": [333, 52, 355, 150], "vertical": true, "font_size": 20, "lines_coords": [[[333.0, 52.0], [352.0, 52.0], [355.0, 150.0], [335.0, 150.0]]], "lines": ["忘れる．．．"]}, {"box": [667, 529, 684, 567], "vertical": true, "font_size": 17, "lines_coords": [[[667.0, 529.0], [684.0, 529.0], [684.0, 567.0], [667.0, 567.0]]], "lines": ["！"]}, {"box": [454, 324, 527, 442], "vertical": true, "font_size": 22, "lines_coords": [[[505.0, 326.0], [526.0, 326.0], [526.0, 405.0], [505.0, 405.0]], [[481.0, 328.0], [501.0, 328.0], [501.0, 442.0], [481.0, 442.0]], [[454.0, 324.0], [480.0, 324.0], [480.0, 376.0], [454.0, 376.0]]], "lines": ["意識では", "思い出せなく", "なり、"]}, {"box": [304, 303, 351, 418], "vertical": true, "font_size": 20, "lines_coords": [[[329.0, 303.0], [349.0, 303.0], [351.0, 418.0], [331.0, 418.0]], [[304.0, 304.0], [324.0, 304.0], [327.0, 407.0], [307.0, 407.0]]], "lines": ["という状況が", "生まれます。"]}, {"box": [125, 536, 147, 624], "vertical": true, "font_size": 20, "lines_coords": [[[125.0, 536.0], [145.0, 536.0], [147.0, 623.0], [127.0, 623.0]]], "lines": ["そうです。"]}, {"box": [286, 543, 401, 667], "vertical": true, "font_size": 18, "lines_coords": [[[383.0, 546.0], [399.0, 546.0], [399.0, 667.0], [383.0, 667.0]], [[358.0, 546.0], [375.0, 546.0], [375.0, 659.0], [358.0, 659.0]], [[333.0, 544.0], [352.0, 544.0], [352.0, 666.0], [333.0, 666.0]], [[309.0, 543.0], [329.0, 543.0], [329.0, 641.0], [309.0, 641.0]], [[286.0, 546.0], [302.0, 546.0], [302.0, 658.0], [286.0, 658.0]]], "lines": ["よく、あまりに", "辛い出来事は", "忘れてしまう、", "というのは", "このせいか？"]}, {"box": [687, 925, 788, 1138], "vertical": true, "font_size": 22, "lines_coords": [[[765.0, 926.0], [786.0, 926.0], [788.0, 1054.0], [766.0, 1054.0]], [[737.0, 925.0], [761.0, 925.0], [764.0, 1061.0], [741.0, 1061.0]], [[715.0, 928.0], [735.0, 928.0], [735.0, 1137.0], [715.0, 1137.0]], [[687.0, 925.0], [708.0, 925.0], [710.0, 1040.0], [689.0, 1040.0]]], "lines": ["ただコイツは", "隠しただけで、", "決して消えたわけでは", "ないんです。"]}], "img_path": "044.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [622, 14, 751, 384], "vertical": true, "font_size": 129, "lines_coords": [[[622.0, 14.0], [751.0, 14.0], [751.0, 384.0], [622.0, 384.0]]], "lines": ["キャチッチッキング"]}, {"box": [396, 0, 766, 398], "vertical": true, "font_size": 74, "lines_coords": [[[680.0, 94.0], [751.0, 114.0], [697.0, 305.0], [626.0, 285.0]]], "lines": ["キッチッキ。"]}, {"box": [171, 139, 254, 331], "vertical": true, "font_size": 24, "lines_coords": [[[229.0, 139.0], [254.0, 139.0], [254.0, 278.0], [229.0, 278.0]], [[198.0, 140.0], [222.0, 140.0], [222.0, 302.0], [198.0, 302.0]], [[171.0, 139.0], [195.0, 139.0], [195.0, 330.0], [171.0, 330.0]]], "lines": ["常に意識では", "わからない所で", "葛藤をしています。"]}, {"box": [436, 439, 533, 557], "vertical": true, "font_size": 22, "lines_coords": [[[510.0, 441.0], [532.0, 441.0], [533.0, 508.0], [511.0, 508.0]], [[487.0, 442.0], [507.0, 442.0], [507.0, 557.0], [487.0, 557.0]], [[463.0, 442.0], [483.0, 442.0], [483.0, 539.0], [463.0, 539.0]], [[436.0, 439.0], [462.0, 439.0], [462.0, 508.0], [436.0, 508.0]]], "lines": ["すると、", "訳もわからず", "過食嘔吐を", "したり、"]}, {"box": [274, 440, 319, 555], "vertical": true, "font_size": 20, "lines_coords": [[[299.0, 440.0], [318.0, 440.0], [318.0, 525.0], [299.0, 525.0]], [[274.0, 440.0], [294.0, 440.0], [294.0, 555.0], [274.0, 555.0]]], "lines": ["強迫観念、", "視線恐怖．．．"]}, {"box": [72, 424, 164, 558], "vertical": true, "font_size": 20, "lines_coords": [[[141.0, 424.0], [162.0, 424.0], [164.0, 502.0], [143.0, 502.0]], [[117.0, 424.0], [137.0, 424.0], [139.0, 540.0], [119.0, 540.0]], [[94.0, 424.0], [114.0, 424.0], [114.0, 558.0], [94.0, 558.0]], [[72.0, 425.0], [89.0, 425.0], [89.0, 507.0], [72.0, 507.0]]], "lines": ["いわゆる", "神経症として", "出てくることも", "あります"]}, {"box": [620, 739, 637, 801], "vertical": true, "font_size": 17, "lines_coords": [[[620.0, 739.0], [637.0, 739.0], [637.0, 801.0], [620.0, 801.0]]], "lines": ["．．．．．．"]}, {"box": [341, 733, 409, 754], "vertical": false, "font_size": 21, "lines_coords": [[[341.0, 733.0], [409.0, 733.0], [409.0, 754.0], [341.0, 754.0]]], "lines": ["無意あ・"]}, {"box": [438, 910, 530, 1106], "vertical": true, "font_size": 19, "lines_coords": [[[508.0, 911.0], [528.0, 911.0], [528.0, 1103.0], [508.0, 1103.0]], [[485.0, 910.0], [505.0, 910.0], [503.0, 1027.0], [483.0, 1027.0]], [[460.0, 912.0], [480.0, 912.0], [480.0, 1103.0], [460.0, 1103.0]], [[438.0, 914.0], [454.0, 914.0], [454.0, 1007.0], [438.0, 1007.0]]], "lines": ["仮に本人が大人になり", "父親を理解し", "本当に好きになったと", "しても．．．"]}, {"box": [290, 1048, 361, 1162], "vertical": true, "font_size": 22, "lines_coords": [[[341.0, 1048.0], [361.0, 1048.0], [361.0, 1146.0], [341.0, 1146.0]], [[316.0, 1048.0], [337.0, 1048.0], [337.0, 1162.0], [316.0, 1162.0]], [[290.0, 1048.0], [315.0, 1048.0], [315.0, 1109.0], [290.0, 1109.0]]], "lines": ["その歪みは", "解消されない", "のか？"]}], "img_path": "045.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [653, 173, 708, 344], "vertical": true, "font_size": 26, "lines_coords": [[[678.0, 173.0], [708.0, 173.0], [708.0, 247.0], [678.0, 247.0]], [[653.0, 173.0], [675.0, 173.0], [676.0, 343.0], [654.0, 343.0]]], "lines": ["だから", "生き霊なんです。"]}, {"box": [748, 432, 820, 538], "vertical": true, "font_size": 23, "lines_coords": [[[791.0, 432.0], [820.0, 432.0], [820.0, 498.0], [791.0, 498.0]], [[771.0, 434.0], [791.0, 434.0], [791.0, 521.0], [771.0, 521.0]], [[748.0, 435.0], [768.0, 435.0], [768.0, 537.0], [748.0, 537.0]]], "lines": ["決して", "今憎んで", "いなくても、"]}, {"box": [288, 285, 306, 331], "vertical": true, "font_size": 18, "lines_coords": [[[288.0, 285.0], [306.0, 285.0], [306.0, 331.0], [288.0, 331.0]]], "lines": ["！"]}, {"box": [426, 428, 495, 626], "vertical": true, "font_size": 20, "lines_coords": [[[473.0, 430.0], [493.0, 430.0], [493.0, 564.0], [473.0, 564.0]], [[450.0, 428.0], [470.0, 428.0], [470.0, 621.0], [450.0, 621.0]], [[426.0, 430.0], [446.0, 430.0], [446.0, 626.0], [426.0, 626.0]]], "lines": ["当時の憎しみが", "ここにフリーズされて", "しっかり残っています。"]}, {"box": [208, 407, 319, 546], "vertical": true, "font_size": 24, "lines_coords": [[[294.0, 408.0], [317.0, 408.0], [317.0, 546.0], [294.0, 546.0]], [[265.0, 407.0], [290.0, 407.0], [290.0, 479.0], [265.0, 479.0]], [[238.0, 407.0], [262.0, 407.0], [262.0, 522.0], [238.0, 522.0]], [[208.0, 410.0], [234.0, 410.0], [234.0, 486.0], [208.0, 486.0]]], "lines": ["無意識の中を", "延々と", "さまよって", "います。"]}, {"box": [734, 819, 807, 924], "vertical": true, "font_size": 46, "lines_coords": [[[763.0, 819.0], [807.0, 833.0], [778.0, 924.0], [734.0, 910.0]]], "lines": ["ギァ"]}, {"box": [426, 719, 498, 894], "vertical": true, "font_size": 22, "lines_coords": [[[472.0, 719.0], [498.0, 719.0], [498.0, 782.0], [472.0, 782.0]], [[451.0, 721.0], [471.0, 721.0], [471.0, 894.0], [451.0, 894.0]], [[426.0, 719.0], [446.0, 719.0], [447.0, 854.0], [428.0, 854.0]]], "lines": ["中身は", "当時の感情の温度を", "保ったまま．．．"]}, {"box": [399, 979, 417, 1051], "vertical": true, "font_size": 18, "lines_coords": [[[399.0, 979.0], [417.0, 979.0], [417.0, 1051.0], [399.0, 1051.0]]], "lines": ["．．．．．．"]}], "img_path": "046.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [126, 56, 191, 72], "vertical": false, "font_size": 16, "lines_coords": [[[126.0, 56.0], [191.0, 56.0], [191.0, 72.0], [126.0, 72.0]]], "lines": ["クルス３"]}, {"box": [130, 155, 244, 410], "vertical": true, "font_size": 23, "lines_coords": [[[218.0, 157.0], [242.0, 157.0], [242.0, 377.0], [218.0, 377.0]], [[188.0, 158.0], [213.0, 158.0], [213.0, 410.0], [188.0, 410.0]], [[160.0, 157.0], [180.0, 157.0], [182.0, 386.0], [162.0, 386.0]], [[130.0, 155.0], [153.0, 155.0], [155.0, 348.0], [132.0, 348.0]]], "lines": ["そして、この生き霊は", "再び意識に浮かび上がり、", "成仏するための機会を", "常に狙っています。"]}], "img_path": "047.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [750, 69, 780, 141], "vertical": true, "font_size": 30, "lines_coords": [[[750.0, 69.0], [780.0, 69.0], [780.0, 141.0], [750.0, 141.0]]], "lines": ["で．．．．．"]}, {"box": [333, 51, 416, 258], "vertical": true, "font_size": 22, "lines_coords": [[[390.0, 51.0], [413.0, 51.0], [413.0, 256.0], [390.0, 256.0]], [[364.0, 52.0], [386.0, 52.0], [386.0, 168.0], [364.0, 168.0]], [[333.0, 53.0], [354.0, 53.0], [356.0, 167.0], [335.0, 167.0]]], "lines": ["成仏させてやるには", "どうしたら", "いいんだ？"]}, {"box": [643, 754, 689, 839], "vertical": true, "font_size": 20, "lines_coords": [[[668.0, 755.0], [688.0, 755.0], [688.0, 833.0], [668.0, 833.0]], [[643.0, 754.0], [664.0, 754.0], [664.0, 839.0], [643.0, 839.0]]], "lines": ["仕組みは", "簡単です。"]}, {"box": [505, 601, 550, 774], "vertical": true, "font_size": 20, "lines_coords": [[[528.0, 602.0], [548.0, 602.0], [548.0, 774.0], [528.0, 774.0]], [[505.0, 601.0], [525.0, 601.0], [525.0, 754.0], [505.0, 754.0]]], "lines": ["この奥のほうにある", "凍った感情を．．．"]}, {"box": [178, 597, 222, 739], "vertical": true, "font_size": 19, "lines_coords": [[[202.0, 598.0], [220.0, 598.0], [219.0, 711.0], [201.0, 711.0]], [[178.0, 597.0], [198.0, 597.0], [198.0, 739.0], [178.0, 739.0]]], "lines": ["意識の上まで", "引っ張り出して、"]}], "img_path": "048.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [341, 171, 376, 282], "vertical": true, "font_size": 33, "lines_coords": [[[343.0, 171.0], [376.0, 171.0], [374.0, 282.0], [341.0, 282.0]]], "lines": ["解凍．．．．．"]}, {"box": [370, 774, 454, 957], "vertical": true, "font_size": 23, "lines_coords": [[[431.0, 776.0], [452.0, 776.0], [452.0, 867.0], [431.0, 867.0]], [[401.0, 774.0], [425.0, 774.0], [425.0, 957.0], [401.0, 957.0]], [[370.0, 774.0], [395.0, 774.0], [397.0, 896.0], [372.0, 896.0]]], "lines": ["いわゆる", "感じさせてやれば", "いいんです。"]}], "img_path": "049.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [], "img_path": "050.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [462, 39, 553, 230], "vertical": true, "font_size": 20, "lines_coords": [[[532.0, 41.0], [553.0, 41.0], [553.0, 147.0], [532.0, 147.0]], [[505.0, 39.0], [528.0, 39.0], [530.0, 230.0], [506.0, 230.0]], [[484.0, 41.0], [504.0, 41.0], [504.0, 157.0], [484.0, 157.0]], [[462.0, 42.0], [478.0, 42.0], [478.0, 212.0], [462.0, 212.0]]], "lines": ["ただ、本人も", "忘れちゃってるくらい", "奥底に隠した", "「歪み」ですから．．．"]}, {"box": [313, 120, 356, 241], "vertical": true, "font_size": 20, "lines_coords": [[[336.0, 120.0], [356.0, 120.0], [356.0, 235.0], [336.0, 235.0]], [[313.0, 120.0], [333.0, 120.0], [333.0, 241.0], [313.0, 241.0]]], "lines": ["見つけるのが", "大変なんです。"]}, {"box": [641, 379, 733, 543], "vertical": true, "font_size": 19, "lines_coords": [[[711.0, 379.0], [731.0, 379.0], [731.0, 541.0], [711.0, 541.0]], [[688.0, 379.0], [708.0, 379.0], [708.0, 479.0], [688.0, 479.0]], [[664.0, 380.0], [684.0, 380.0], [684.0, 498.0], [664.0, 498.0]], [[642.0, 382.0], [659.0, 382.0], [659.0, 517.0], [642.0, 517.0]]], "lines": ["しかも、赤の他人が", "それを探る", "精神療法など", "時間がかかるし、"]}, {"box": [327, 392, 394, 546], "vertical": true, "font_size": 19, "lines_coords": [[[372.0, 392.0], [392.0, 392.0], [392.0, 507.0], [372.0, 507.0]], [[348.0, 392.0], [368.0, 392.0], [368.0, 543.0], [348.0, 543.0]], [[327.0, 396.0], [343.0, 396.0], [343.0, 544.0], [327.0, 544.0]]], "lines": ["見つからない", "ことのほうが多い", "がもしれない．．．"]}, {"box": [153, 718, 205, 774], "vertical": true, "font_size": 43, "lines_coords": [[[162.0, 718.0], [205.0, 727.0], [194.0, 774.0], [153.0, 765.0]]], "lines": ["！？"]}], "img_path": "051.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [725, 30, 757, 164], "vertical": true, "font_size": 30, "lines_coords": [[[725.0, 30.0], [755.0, 30.0], [757.0, 162.0], [728.0, 162.0]]], "lines": ["あなたは、"]}, {"box": [158, 172, 226, 367], "vertical": true, "font_size": 28, "lines_coords": [[[191.0, 172.0], [223.0, 172.0], [226.0, 326.0], [193.0, 326.0]], [[158.0, 174.0], [182.0, 174.0], [182.0, 364.0], [158.0, 364.0]]], "lines": ["これだけで", "見えてしまう。"]}], "img_path": "052.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [569, 194, 696, 295], "vertical": false, "font_size": 19.0, "lines_coords": [[[621.0, 248.0], [696.0, 278.0], [689.0, 295.0], [614.0, 264.0]], [[575.0, 216.0], [693.0, 260.0], [686.0, 277.0], [569.0, 233.0]], [[585.0, 194.0], [677.0, 232.0], [669.0, 251.0], [576.0, 214.0]]], "lines": ["そんなのがいなどせがようとしていま！", "お手のカマで左の小首を", "ロボットの中に少年？"]}, {"box": [369, 166, 417, 335], "vertical": true, "font_size": 18, "lines_coords": [[[394.0, 166.0], [413.0, 166.0], [413.0, 335.0], [394.0, 335.0]], [[370.0, 167.0], [386.0, 167.0], [386.0, 298.0], [370.0, 298.0]]], "lines": ["生き霊にとっては", "まさに救世主"]}, {"box": [174, 228, 215, 316], "vertical": false, "font_size": 21, "lines_coords": [[[194.0, 228.0], [215.0, 311.0], [195.0, 316.0], [174.0, 233.0]]], "lines": ["そんなのが"]}, {"box": [321, 477, 341, 543], "vertical": true, "font_size": 20, "lines_coords": [[[321.0, 477.0], [341.0, 477.0], [341.0, 543.0], [321.0, 543.0]]], "lines": ["．．．．．．"]}, {"box": [705, 781, 727, 878], "vertical": true, "font_size": 22, "lines_coords": [[[705.0, 781.0], [727.0, 781.0], [727.0, 876.0], [705.0, 876.0]]], "lines": ["しかし．．．"]}, {"box": [420, 580, 441, 683], "vertical": true, "font_size": 20, "lines_coords": [[[420.0, 580.0], [440.0, 580.0], [440.0, 683.0], [420.0, 683.0]]], "lines": ["イタコかな。"]}, {"box": [389, 812, 457, 964], "vertical": true, "font_size": 19, "lines_coords": [[[435.0, 812.0], [456.0, 812.0], [456.0, 905.0], [435.0, 905.0]], [[412.0, 812.0], [432.0, 812.0], [432.0, 964.0], [412.0, 964.0]], [[389.0, 812.0], [405.0, 812.0], [405.0, 944.0], [389.0, 944.0]]], "lines": ["たちの悪い", "六感が出ちまった", "もんだなあ．．．"]}], "img_path": "053.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [655, 16, 725, 133], "vertical": true, "font_size": 20, "lines_coords": [[[705.0, 17.0], [725.0, 17.0], [725.0, 98.0], [705.0, 98.0]], [[681.0, 17.0], [702.0, 17.0], [703.0, 133.0], [682.0, 133.0]], [[657.0, 16.0], [678.0, 16.0], [676.0, 98.0], [655.0, 98.0]]], "lines": ["名越さん", "これは決して", "第六感が"]}, {"box": [651, 174, 722, 276], "vertical": true, "font_size": 20, "lines_coords": [[[701.0, 175.0], [722.0, 175.0], [722.0, 253.0], [701.0, 253.0]], [[677.0, 175.0], [697.0, 175.0], [697.0, 253.0], [677.0, 253.0]], [[651.0, 174.0], [671.0, 174.0], [674.0, 276.0], [654.0, 276.0]]], "lines": ["芽生えた", "わけでは", "ないんです。"]}, {"box": [647, 352, 724, 451], "vertical": true, "font_size": 22, "lines_coords": [[[676.0, 356.0], [697.0, 356.0], [697.0, 451.0], [676.0, 451.0]], [[697.0, 352.0], [724.0, 352.0], [724.0, 399.0], [697.0, 399.0]], [[649.0, 352.0], [675.0, 353.0], [673.0, 419.0], [647.0, 418.0]]], "lines": ["持っている", "本来", "五感が"]}, {"box": [653, 495, 723, 631], "vertical": true, "font_size": 22, "lines_coords": [[[698.0, 498.0], [723.0, 498.0], [723.0, 577.0], [698.0, 577.0]], [[678.0, 495.0], [695.0, 495.0], [695.0, 631.0], [678.0, 631.0]], [[653.0, 498.0], [670.0, 498.0], [671.0, 618.0], [654.0, 618.0]]], "lines": ["それぞれ", "とぎ澄まされた", "だけなんです。"]}, {"box": [712, 713, 785, 873], "vertical": true, "font_size": 19, "lines_coords": [[[765.0, 714.0], [785.0, 714.0], [785.0, 847.0], [765.0, 847.0]], [[735.0, 713.0], [756.0, 713.0], [756.0, 810.0], [735.0, 810.0]], [[712.0, 714.0], [729.0, 714.0], [730.0, 869.0], [714.0, 869.0]]], "lines": ["人間というのは", "「身体」から", "いろいろな情報を"]}, {"box": [348, 792, 440, 933], "vertical": true, "font_size": 19, "lines_coords": [[[418.0, 792.0], [438.0, 792.0], [439.0, 932.0], [419.0, 932.0]], [[396.0, 792.0], [416.0, 792.0], [412.0, 926.0], [392.0, 926.0]], [[372.0, 794.0], [389.0, 794.0], [389.0, 907.0], [372.0, 907.0]], [[348.0, 793.0], [368.0, 793.0], [368.0, 896.0], [348.0, 896.0]]], "lines": ["異常な緻密さで、", "とらえることが", "できるように", "なってます。"]}, {"box": [106, 589, 140, 630], "vertical": true, "font_size": 34, "lines_coords": [[[106.0, 589.0], [140.0, 589.0], [140.0, 630.0], [106.0, 630.0]]], "lines": ["！！"]}], "img_path": "054.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [536, 38, 582, 142], "vertical": true, "font_size": 22, "lines_coords": [[[555.0, 38.0], [582.0, 38.0], [582.0, 99.0], [555.0, 99.0]], [[537.0, 41.0], [553.0, 41.0], [553.0, 138.0], [537.0, 138.0]]], "lines": ["身体の", "徳妙な緊張"]}, {"box": [408, 125, 462, 191], "vertical": true, "font_size": 30, "lines_coords": [[[432.0, 126.0], [462.0, 126.0], [462.0, 191.0], [432.0, 191.0]], [[408.0, 125.0], [438.0, 125.0], [438.0, 180.0], [408.0, 180.0]]], "lines": ["筋肉の", "伸縮、"]}, {"box": [58, 64, 132, 150], "vertical": true, "font_size": 25, "lines_coords": [[[102.0, 64.0], [132.0, 64.0], [132.0, 110.0], [102.0, 110.0]], [[80.0, 66.0], [105.0, 66.0], [105.0, 145.0], [80.0, 145.0]], [[58.0, 67.0], [78.0, 67.0], [78.0, 147.0], [58.0, 147.0]]], "lines": ["顔の", "表情筋の", "動きなど"]}, {"box": [408, 296, 466, 363], "vertical": true, "font_size": 31, "lines_coords": [[[435.0, 298.0], [466.0, 298.0], [466.0, 363.0], [435.0, 363.0]], [[408.0, 296.0], [439.0, 296.0], [439.0, 353.0], [408.0, 353.0]]], "lines": ["重心の", "偏り、"]}, {"box": [656, 573, 724, 679], "vertical": true, "font_size": 23, "lines_coords": [[[704.0, 575.0], [724.0, 575.0], [724.0, 653.0], [704.0, 653.0]], [[675.0, 573.0], [704.0, 573.0], [704.0, 637.0], [675.0, 637.0]], [[656.0, 575.0], [676.0, 575.0], [676.0, 679.0], [656.0, 679.0]]], "lines": ["言ったら", "切りが", "ありません。"]}, {"box": [285, 577, 317, 662], "vertical": true, "font_size": 32, "lines_coords": [[[285.0, 577.0], [317.0, 577.0], [317.0, 662.0], [285.0, 662.0]]], "lines": ["ジィ．．．"]}, {"box": [180, 989, 275, 1106], "vertical": true, "font_size": 21, "lines_coords": [[[254.0, 991.0], [274.0, 991.0], [274.0, 1069.0], [254.0, 1069.0]], [[231.0, 990.0], [252.0, 990.0], [249.0, 1106.0], [228.0, 1106.0]], [[206.0, 991.0], [226.0, 991.0], [226.0, 1087.0], [206.0, 1087.0]], [[182.0, 989.0], [204.0, 989.0], [201.0, 1106.0], [180.0, 1106.0]]], "lines": ["さらには", "身体や表情に", "現れている", "その人の．．．"]}], "img_path": "055.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [297, 52, 322, 120], "vertical": true, "font_size": 25, "lines_coords": [[[297.0, 52.0], [322.0, 52.0], [322.0, 120.0], [297.0, 120.0]]], "lines": ["喜びや、"]}, {"box": [637, 290, 687, 371], "vertical": true, "font_size": 26, "lines_coords": [[[661.0, 290.0], [687.0, 290.0], [687.0, 355.0], [661.0, 355.0]], [[637.0, 290.0], [662.0, 290.0], [662.0, 371.0], [637.0, 371.0]]], "lines": ["不安や", "怒り．．．"]}, {"box": [180, 323, 200, 408], "vertical": true, "font_size": 20, "lines_coords": [[[180.0, 323.0], [200.0, 323.0], [200.0, 408.0], [180.0, 408.0]]], "lines": ["欲求など。"]}, {"box": [154, 603, 253, 795], "vertical": true, "font_size": 20, "lines_coords": [[[233.0, 603.0], [253.0, 603.0], [253.0, 711.0], [233.0, 711.0]], [[207.0, 604.0], [227.0, 604.0], [227.0, 795.0], [207.0, 795.0]], [[180.0, 603.0], [201.0, 603.0], [201.0, 690.0], [180.0, 690.0]], [[154.0, 604.0], [174.0, 604.0], [174.0, 778.0], [154.0, 778.0]]], "lines": ["さまざまな", "内面の感情の変化を", "自分でも", "意識しないうちに、"]}, {"box": [593, 954, 667, 1060], "vertical": true, "font_size": 21, "lines_coords": [[[646.0, 955.0], [667.0, 955.0], [667.0, 1060.0], [646.0, 1060.0]], [[619.0, 955.0], [640.0, 955.0], [640.0, 1039.0], [619.0, 1039.0]], [[593.0, 955.0], [614.0, 955.0], [614.0, 1046.0], [593.0, 1046.0]]], "lines": ["読み取って", "生きてる", "ものです。"]}, {"box": [191, 1067, 208, 1140], "vertical": true, "font_size": 17, "lines_coords": [[[191.0, 1067.0], [208.0, 1067.0], [208.0, 1140.0], [191.0, 1140.0]]], "lines": ["．．．"]}], "img_path": "056.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [185, 17, 234, 153], "vertical": true, "font_size": 24, "lines_coords": [[[205.0, 17.0], [234.0, 17.0], [234.0, 82.0], [205.0, 82.0]], [[185.0, 21.0], [205.0, 21.0], [205.0, 153.0], [185.0, 153.0]]], "lines": ["笑顔で", "「ありがとう！」"]}, {"box": [43, 15, 91, 139], "vertical": true, "font_size": 24, "lines_coords": [[[66.0, 15.0], [91.0, 15.0], [91.0, 86.0], [66.0, 86.0]], [[43.0, 17.0], [63.0, 17.0], [63.0, 139.0], [43.0, 139.0]]], "lines": ["．．．と、", "喜んでいても、"]}, {"box": [455, 255, 524, 426], "vertical": true, "font_size": 17, "lines_coords": [[[504.0, 256.0], [520.0, 256.0], [520.0, 378.0], [504.0, 378.0]], [[478.0, 255.0], [498.0, 255.0], [498.0, 426.0], [478.0, 426.0]], [[456.0, 256.0], [472.0, 256.0], [472.0, 408.0], [456.0, 408.0]]], "lines": ["例えば、誰かに", "プレゼントをあげて", "中身を開けた時に"]}, {"box": [435, 533, 506, 650], "vertical": true, "font_size": 23, "lines_coords": [[[477.0, 533.0], [506.0, 533.0], [506.0, 597.0], [477.0, 597.0]], [[459.0, 535.0], [479.0, 535.0], [479.0, 650.0], [459.0, 650.0]], [[435.0, 536.0], [454.0, 536.0], [454.0, 616.0], [435.0, 616.0]]], "lines": ["それが", "本当に喜んで", "いるのか"]}, {"box": [682, 817, 754, 942], "vertical": true, "font_size": 22, "lines_coords": [[[729.0, 817.0], [754.0, 817.0], [754.0, 897.0], [729.0, 897.0]], [[707.0, 819.0], [728.0, 819.0], [728.0, 896.0], [707.0, 896.0]], [[682.0, 819.0], [702.0, 819.0], [705.0, 942.0], [686.0, 942.0]]], "lines": ["その人の", "雰囲気で", "わかるでしょ、"]}, {"box": [247, 523, 342, 697], "vertical": true, "font_size": 20, "lines_coords": [[[323.0, 526.0], [340.0, 526.0], [340.0, 637.0], [323.0, 637.0]], [[297.0, 523.0], [317.0, 523.0], [317.0, 602.0], [297.0, 602.0]], [[273.0, 525.0], [293.0, 525.0], [293.0, 621.0], [273.0, 621.0]], [[247.0, 523.0], [270.0, 523.0], [270.0, 697.0], [247.0, 697.0]]], "lines": ["もしかしたら", "そんなに", "嬉しくない", "モノだったのか．．．"]}, {"box": [399, 835, 471, 952], "vertical": true, "font_size": 22, "lines_coords": [[[444.0, 835.0], [471.0, 836.0], [469.0, 898.0], [442.0, 897.0]], [[424.0, 836.0], [444.0, 836.0], [442.0, 952.0], [422.0, 952.0]], [[399.0, 837.0], [419.0, 837.0], [419.0, 921.0], [399.0, 921.0]]], "lines": ["それが", "まったく同じ", "笑顔でも。"]}, {"box": [284, 837, 307, 916], "vertical": true, "font_size": 22, "lines_coords": [[[284.0, 837.0], [306.0, 837.0], [307.0, 916.0], [286.0, 916.0]]], "lines": ["ああ．．．"]}, {"box": [39, 847, 111, 933], "vertical": true, "font_size": 22, "lines_coords": [[[85.0, 847.0], [111.0, 847.0], [111.0, 910.0], [85.0, 910.0]], [[62.0, 848.0], [83.0, 848.0], [83.0, 925.0], [62.0, 925.0]], [[39.0, 849.0], [59.0, 849.0], [59.0, 932.0], [39.0, 932.0]]], "lines": ["確かに", "雰囲気で", "わかるな。"]}], "img_path": "057.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [188, 35, 259, 227], "vertical": true, "font_size": 20, "lines_coords": [[[238.0, 35.0], [257.0, 35.0], [256.0, 179.0], [236.0, 179.0]], [[214.0, 35.0], [234.0, 35.0], [234.0, 227.0], [214.0, 227.0]], [[188.0, 35.0], [208.0, 35.0], [209.0, 212.0], [189.0, 212.0]]], "lines": ["それを、みんなは", "「雰囲気」という言葉で", "ごまかしてるだけで、"]}, {"box": [628, 503, 722, 628], "vertical": true, "font_size": 19, "lines_coords": [[[701.0, 503.0], [721.0, 503.0], [721.0, 628.0], [701.0, 628.0]], [[676.0, 505.0], [696.0, 505.0], [696.0, 580.0], [676.0, 580.0]], [[654.0, 503.0], [670.0, 503.0], [670.0, 617.0], [654.0, 617.0]], [[628.0, 503.0], [648.0, 503.0], [648.0, 583.0], [628.0, 583.0]]], "lines": ["実は、身体から", "無意識に", "莫大な情報を", "垂れ流し"]}, {"box": [124, 316, 193, 491], "vertical": true, "font_size": 22, "lines_coords": [[[171.0, 318.0], [192.0, 318.0], [192.0, 396.0], [171.0, 396.0]], [[146.0, 316.0], [170.0, 316.0], [170.0, 435.0], [146.0, 435.0]], [[124.0, 318.0], [144.0, 318.0], [144.0, 488.0], [124.0, 488.0]]], "lines": ["無意識に", "莫大な情報を", "受け取っている．．．"]}, {"box": [744, 751, 787, 847], "vertical": true, "font_size": 20, "lines_coords": [[[766.0, 751.0], [786.0, 751.0], [786.0, 829.0], [766.0, 829.0]], [[744.0, 752.0], [765.0, 752.0], [765.0, 847.0], [744.0, 847.0]]], "lines": ["．．．五感を", "使って．．．"]}, {"box": [766, 903, 804, 987], "vertical": true, "font_size": 32, "lines_coords": [[[772.0, 903.0], [804.0, 905.0], [798.0, 987.0], [766.0, 985.0]]], "lines": ["イラ．．．"]}, {"box": [460, 986, 552, 1146], "vertical": true, "font_size": 20, "lines_coords": [[[531.0, 986.0], [552.0, 986.0], [552.0, 1065.0], [531.0, 1065.0]], [[507.0, 986.0], [527.0, 986.0], [527.0, 1083.0], [507.0, 1083.0]], [[483.0, 987.0], [503.0, 987.0], [503.0, 1121.0], [483.0, 1121.0]], [[460.0, 986.0], [477.0, 986.0], [477.0, 1144.0], [460.0, 1144.0]]], "lines": ["人間とは", "そうやって", "無意識レベルの", "見えないところで、"]}, {"box": [124, 1001, 169, 1106], "vertical": true, "font_size": 20, "lines_coords": [[[147.0, 1001.0], [168.0, 1001.0], [166.0, 1100.0], [145.0, 1100.0]], [[124.0, 1003.0], [144.0, 1003.0], [144.0, 1101.0], [124.0, 1101.0]]], "lines": ["情報交換を", "行いながら"]}], "img_path": "058.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [459, 164, 533, 304], "vertical": true, "font_size": 25, "lines_coords": [[[511.0, 166.0], [532.0, 166.0], [533.0, 264.0], [512.0, 264.0]], [[486.0, 166.0], [510.0, 166.0], [510.0, 304.0], [486.0, 304.0]], [[459.0, 164.0], [490.0, 164.0], [490.0, 221.0], [459.0, 221.0]]], "lines": ["うわべでは", "きれいな言葉を", "並べ、"]}, {"box": [303, 181, 372, 278], "vertical": true, "font_size": 20, "lines_coords": [[[352.0, 181.0], [372.0, 181.0], [372.0, 278.0], [352.0, 278.0]], [[328.0, 182.0], [348.0, 182.0], [348.0, 278.0], [328.0, 278.0]], [[303.0, 182.0], [323.0, 182.0], [323.0, 258.0], [303.0, 258.0]]], "lines": ["引きつった", "笑顔をして", "いる．．．"]}, {"box": [599, 476, 672, 614], "vertical": true, "font_size": 33, "lines_coords": [[[637.0, 479.0], [670.0, 479.0], [670.0, 602.0], [637.0, 602.0]], [[599.0, 478.0], [632.0, 476.0], [635.0, 612.0], [602.0, 614.0]]], "lines": ["汚い動物", "なんです。"]}], "img_path": "059.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [150, 81, 170, 155], "vertical": true, "font_size": 20, "lines_coords": [[[150.0, 81.0], [170.0, 81.0], [170.0, 155.0], [150.0, 155.0]]], "lines": ["！．．．．．"]}, {"box": [441, 551, 458, 622], "vertical": true, "font_size": 17, "lines_coords": [[[441.0, 551.0], [458.0, 551.0], [458.0, 622.0], [441.0, 622.0]]], "lines": ["．．．．．．"]}, {"box": [259, 792, 275, 834], "vertical": true, "font_size": 16, "lines_coords": [[[259.0, 792.0], [275.0, 792.0], [275.0, 834.0], [259.0, 834.0]]], "lines": ["！"]}, {"box": [423, 830, 540, 1125], "vertical": true, "font_size": 23, "lines_coords": [[[513.0, 830.0], [538.0, 830.0], [538.0, 898.0], [513.0, 898.0]], [[500.0, 951.0], [520.0, 951.0], [520.0, 1087.0], [500.0, 1087.0]], [[476.0, 952.0], [496.0, 952.0], [496.0, 1105.0], [476.0, 1105.0]], [[450.0, 952.0], [473.0, 952.0], [473.0, 1125.0], [450.0, 1125.0]], [[423.0, 950.0], [447.0, 949.0], [451.0, 1018.0], [426.0, 1019.0]]], "lines": ["しかも、", "子供というのは", "五感で感じる力が", "ハンパじゃないです", "からね。"]}], "img_path": "060.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [412, 66, 487, 183], "vertical": true, "font_size": 23, "lines_coords": [[[463.0, 67.0], [487.0, 67.0], [487.0, 130.0], [463.0, 130.0]], [[440.0, 69.0], [460.0, 69.0], [460.0, 183.0], [440.0, 183.0]], [[412.0, 67.0], [437.0, 66.0], [439.0, 133.0], [415.0, 134.0]]], "lines": ["それは", "頭蓋骨に穴を", "あけて、"]}, {"box": [236, 16, 319, 200], "vertical": true, "font_size": 23, "lines_coords": [[[293.0, 17.0], [317.0, 17.0], [317.0, 131.0], [293.0, 131.0]], [[265.0, 16.0], [288.0, 16.0], [290.0, 200.0], [267.0, 200.0]], [[240.0, 18.0], [261.0, 18.0], [257.0, 175.0], [236.0, 175.0]]], "lines": ["感じる力が", "強くなっちまった", "ってことか．．．？"]}, {"box": [420, 283, 466, 385], "vertical": true, "font_size": 20, "lines_coords": [[[443.0, 283.0], [464.0, 283.0], [465.0, 378.0], [444.0, 378.0]], [[420.0, 283.0], [440.0, 283.0], [440.0, 385.0], [420.0, 385.0]]], "lines": ["脳が子供の", "状態になり、"]}, {"box": [474, 622, 548, 739], "vertical": true, "font_size": 21, "lines_coords": [[[527.0, 625.0], [548.0, 625.0], [548.0, 703.0], [527.0, 703.0]], [[505.0, 626.0], [521.0, 626.0], [521.0, 739.0], [505.0, 739.0]], [[478.0, 622.0], [504.0, 623.0], [500.0, 690.0], [474.0, 689.0]]], "lines": ["もちろん", "それもあるん", "ですが、"]}, {"box": [355, 696, 399, 818], "vertical": true, "font_size": 18, "lines_coords": [[[378.0, 696.0], [398.0, 696.0], [398.0, 812.0], [378.0, 812.0]], [[356.0, 697.0], [372.0, 697.0], [372.0, 814.0], [356.0, 814.0]]], "lines": ["それだけでは", "子供みんなが"]}, {"box": [123, 544, 165, 677], "vertical": true, "font_size": 17, "lines_coords": [[[145.0, 546.0], [162.0, 546.0], [164.0, 677.0], [146.0, 677.0]], [[123.0, 544.0], [139.0, 544.0], [139.0, 677.0], [123.0, 677.0]]], "lines": ["ホムンクルスを", "見てしまう．．．"]}, {"box": [445, 972, 513, 1088], "vertical": true, "font_size": 21, "lines_coords": [[[493.0, 973.0], [513.0, 973.0], [513.0, 1088.0], [493.0, 1088.0]], [[470.0, 975.0], [490.0, 975.0], [490.0, 1088.0], [470.0, 1088.0]], [[445.0, 972.0], [467.0, 972.0], [467.0, 1021.0], [445.0, 1021.0]]], "lines": ["ということに", "なってしまい", "ます。"]}, {"box": [325, 936, 343, 1032], "vertical": true, "font_size": 17, "lines_coords": [[[325.0, 937.0], [342.0, 937.0], [342.0, 1030.0], [325.0, 1030.0]]], "lines": ["だよな．．．"]}], "img_path": "061.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [735, 512, 781, 646], "vertical": true, "font_size": 20, "lines_coords": [[[759.0, 513.0], [779.0, 513.0], [779.0, 646.0], [759.0, 646.0]], [[735.0, 513.0], [756.0, 513.0], [756.0, 590.0], [735.0, 590.0]]], "lines": ["俺の知識と経験", "ねえ．．．"]}, {"box": [515, 251, 617, 380], "vertical": true, "font_size": 21, "lines_coords": [[[595.0, 256.0], [615.0, 256.0], [615.0, 380.0], [595.0, 380.0]], [[569.0, 254.0], [589.0, 254.0], [589.0, 358.0], [569.0, 358.0]], [[539.0, 253.0], [562.0, 253.0], [565.0, 380.0], [541.0, 380.0]], [[515.0, 251.0], [535.0, 251.0], [538.0, 346.0], [518.0, 346.0]]], "lines": ["名越さんには", "子供にない", "経験と知識が", "あります。"]}, {"box": [232, 226, 386, 419], "vertical": true, "font_size": 22, "lines_coords": [[[357.0, 226.0], [386.0, 226.0], [386.0, 295.0], [357.0, 295.0]], [[336.0, 229.0], [356.0, 229.0], [356.0, 419.0], [336.0, 419.0]], [[310.0, 228.0], [330.0, 228.0], [330.0, 362.0], [310.0, 362.0]], [[283.0, 227.0], [303.0, 227.0], [303.0, 333.0], [2