2.0], [350.0, 942.0], [350.0, 957.0], [107.0, 957.0]], [[426.0, 897.0], [445.0, 891.0], [450.0, 907.0], [431.0, 912.0]]], "lines": ["カスピリ．．．ハッコミックス好評発売中／", "ＷＧＯＲＯ「浦沢直結）．．．", "Ｈａｐｐｖ！（浦沢直樹）．．．そうですから、", "Ｍａｐｐｒｉｖｅｒのめぞん一刻［ワイド版］〈高橋留美子〉．．．全１０", "１４歳（楳図かずおー．．．．．．．．．そうですかねぇよぉぉぉ", "それはそれだけではないのですが．．．そんなことはありませんが、", "東京大学物語（江川道せー．．．", "ショコラ（窪之内英策）．．．．．．いいじゃないです", "おたんこナース｛佐々木倫子＇製淸／小林光恵！！．．．", "奈緒子（坂田信弘・中原裕）．．．", "男樹（本宮ひろき．．．そうですか", "月下の棋士（能條純ーーー．．．", "最終兵器彼女（高橋しん．．．．．．", "格闘大陽伝ガチー青山広美）．．．．．．", "注禁ウォーズ！！今井亮ー・ウヒョ助）．．．", "サユリ１号村上かつら．．．", "ペットに宅乱丈）．．．！！", "湾岸リベンジャ一戸操走大．．．", "読スパル（普田正人．．．．．．", "ティーンズブルース（コージィ城倉）．．．！！", "８ェイト（上條淳仕方．．．", "ＢｉｎＯＮＥＹ（木村清輝・脚本〈兜公司〉．．．", "ブロファイリング師朕集院犬清｛石弁達哉．．．１〜２", "．．．いい！？", "マリオガン（木葉功ー）．．．", "２"]}, {"box": [111, 1078, 462, 1122], "vertical": false, "font_size": 18, "lines_coords": [[[128.0, 1077.0], [441.0, 1078.0], [441.0, 1098.0], [128.0, 1097.0]], [[111.0, 1101.0], [461.0, 1101.0], [461.0, 1122.0], [111.0, 1122.0]]], "lines": ["インターネットでビッグコミックスが購入できます。", "ｈｔｔｐ：／／ｗｗｗ．ｂｉｋｇｏｒｔｗｓ．ｓｈｏｇａｋｕｋａｎ．ｃｏ．ｊｐ"]}], "img_path": "004.png"}, {"version": "0.1.7", "img_width": 1778, "img_height": 1200, "blocks": [], "img_path": "005.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [], "img_path": "006.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [143, 544, 216, 567], "vertical": false, "font_size": 20, "lines_coords": [[[143.0, 547.0], [216.0, 544.0], [216.0, 564.0], [143.0, 567.0]]], "lines": ["Ｈｏｍｕｎｏｕｌｕｓ"]}, {"box": [38, 675, 136, 992], "vertical": true, "font_size": 91, "lines_coords": [[[45.0, 675.0], [136.0, 677.0], [128.0, 992.0], [38.0, 990.0]]], "lines": ["山本英夫"]}, {"box": [58, 1122, 238, 1143], "vertical": false, "font_size": 17, "lines_coords": [[[62.0, 1124.0], [234.0, 1124.0], [234.0, 1143.0], [62.0, 1143.0]]], "lines": ["ＢＩＧＳＰＩＲＩＳＣＯＭＩＣＳ"]}], "img_path": "007.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [601, 569, 794, 628], "vertical": false, "font_size": 