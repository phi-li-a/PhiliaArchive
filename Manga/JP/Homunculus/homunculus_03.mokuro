162.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [521, 60, 621, 233], "vertical": true, "font_size": 22, "lines_coords": [[[598.0, 62.0], [621.0, 62.0], [621.0, 233.0], [598.0, 233.0]], [[573.0, 63.0], [593.0, 63.0], [593.0, 189.0], [573.0, 189.0]], [[542.0, 60.0], [567.0, 60.0], [569.0, 192.0], [545.0, 192.0]], [[521.0, 62.0], [541.0, 62.0], [541.0, 175.0], [521.0, 175.0]]], "lines": ["砂漠の砂のように", "風に吹かれて", "途方にくれて", "しまいます。"]}, {"box": [302, 387, 319, 450], "vertical": true, "font_size": 17, "lines_coords": [[[302.0, 387.0], [319.0, 387.0], [319.0, 450.0], [302.0, 450.0]]], "lines": ["．．．"]}, {"box": [765, 775, 786, 898], "vertical": true, "font_size": 17, "lines_coords": [[[766.0, 778.0], [783.0, 778.0], [783.0, 896.0], [766.0, 896.0]]], "lines": ["ありがちだな。"]}, {"box": [479, 614, 499, 687], "vertical": true, "font_size": 20, "lines_coords": [[[479.0, 615.0], [499.0, 615.0], [499.0, 687.0], [479.0, 687.0]]], "lines": ["バララ．．．"]}, {"box": [422, 750, 490, 922], "vertical": true, "font_size": 20, "lines_coords": [[[470.0, 750.0], [490.0, 750.0], [490.0, 875.0], [470.0, 875.0]], [[445.0, 750.0], [465.0, 750.0], [465.0, 922.0], [445.0, 922.0]], [[422.0, 751.0], [442.0, 751.0], [442.0, 828.0], [422.0, 828.0]]], "lines": ["自分は、そんな", "ありがちな人間じゃ", "ない．．．"]}, {"box": [89, 832, 137, 948], "vertical": true, "font_size": 22, "lines_coords": [[[112.0, 832.0], [137.0, 832.0], [137.0, 895.0], [112.0, 895.0]], [[91.0, 832.0], [111.0, 832.0], [109.0, 948.0], [89.0, 948.0]]], "lines": ["という", "意味ですか？"]}, {"box": [464, 1100, 480, 1136], "vertical": true, "font_size": 16, "lines_coords": [[[464.0, 1100.0], [480.0, 1100.0], [480.0, 1136.0], [464.0, 1136.0]]], "lines": ["！"]}], "img_path": "163.png"}, {"version": "0.1.7", "img_width": 849, "img_height": 1200, "blocks": [{"box": [647, 12, 725, 144], "vertical": true, "font_size": 25, "lines_coords": [[[701.0, 16.0], [724.0, 16.0], [724.0, 144.0], [701.0, 144.0]], [[675.0, 16.0], [696.0, 16.0], [696.0