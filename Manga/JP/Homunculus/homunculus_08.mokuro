746.0], [485.0, 841.0], [82.0, 834.0]], [[100.0, 809.0], [472.0, 809.0], [472.0, 855.0], [100.0, 855.0]], [[105.0, 839.0], [326.0, 837.0], [326.0, 861.0], [105.0, 862.0]], [[372.0, 832.0], [471.0, 832.0], [471.0, 873.0], [372.0, 873.0]], [[103.0, 858.0], [465.0, 862.0], [465.0, 891.0], [103.0, 887.0]], [[101.0, 883.0], [465.0, 885.0], [465.0, 913.0], [101.0, 912.0]], [[103.0, 908.0], [464.0, 909.0], [464.0, 936.0], [103.0, 934.0]], [[105.0, 934.0], [462.0, 932.0], [462.0, 956.0], [105.0, 957.0]], [[107.0, 957.0], [462.0, 957.0], [462.0, 978.0], [107.0, 978.0]]], "lines": ["エスピリッツコミッツクス好評発売中／●", "ＹＡＭＡＲＡ！（満沢直樹）．．．へぇーーーんッッ．．．", "．．．．．．．．主の者．．", "「Ａｍａｚｏｎ」「海外国側！！！．．．Ｈａｍｐｙ」「浦沢直樹）」．．", "「１０１９年前へ国内のめぞん一刻襲報版」キャーーーッッ！！商橋留美子）．．．１〜７集", "あそんな女性の姿はいい間、東京大学物語（江川達也）．．．．．．", "東京で子供の頃に川越しについていたので、日曜時号が開催日には通勤しているのはありませんが、", "白崎戦争後悔（山川県也鬼虫（柏木入りルコ）．．．", "．．．いいのか全５巻", "本当に〈阪国信弘・中原裕〉．．．", "奈崎市内田南山・中村部．．．！！？お１０００円（色々木橋子）．．", "Ｆｅａｋｅ（印（人変々不倫ナノ・ギャラリーフェイク（細野不具体を一度探していた．．．．．．", "コヤンソーシャーマーの最終兵器彼女「高橋」んじゃ．．．", "全７巻．．．全て巻", "最終発表的な〈偶然〉《ハルハハハ．．．！！．．．ハッキーアイスス・成面にラマックミングリー・ハーキングを専門エイティーズ・ダウスターズの", "東京エイティーズ（安童タ馬官校マフロ田由／のりつい大石知征！．．．全１１巻大戦奏", "東京エサイティスは海外旅館で、高校アフロ西日のリスクが提案したのですが、その後、アルバムは毎年１１月２０日に", "高校レンドローマンリンの提案が死バイ、古屋忠丸．．．", "．．．．．．．．主人の夢．．", "２０１１日産売り１０ＡＭＮドーン（倉科遼・ナカ・現在高校です。タニロリ．．．．．．全８巻", "ガイド品価格は１０００円以上、１０分以上１０個作業のクラスコミュニケーションが発生時間に保証しているのは必要がありますが、２０１７年以上の１０１４００万円程度についます。２００１２０円です。", "２０１５年８月１１日（日）日本製の中で、サコリー男性とかつらしい．．．", "ワエリューラやリエグンっ！！たくなび（山口かつみ）．．．", "．．．．．．そうじゃ．．いい．．", "たくない山口からお．．．！！", "じＡとお呼びつ！化準へソｆｉｎｅファイン（信濃川日出雄）．．．初期は日韓にヨリ．．．", "１１倍、プリノ高層の邪眼は月輪に飛ぶこと「白田雄．．．", "２０１８年は２月間に１００ティーンズブルース（「藤田村は日田！！！王王でもコージィ城倉！！」って！", "ＣＢ感．ＲＥＢＲＲＫ（東本昌平）．．．"]}, {"box": [103, 1108, 453, 1154], "vertical": false, "font_size": 21, "lines_coords": [[[121.0, 1106.0], [435.0, 1108.0], [435.0, 1131.0], [121.0, 1129.0]], [[103.0, 1129.0], [453.0, 1131.0], [453.0, 1154.0], [103.0, 1152.0]]], "lines": ["インターネットでビッグコミングックスが購入できます。", "ｈｔｔｐ：／／ｗｗｗ．ｂｉｔｔｏｒ／Ｗｉｎｄｏｗｓ．．．．へ！！！へーーー。ｓｈｉｇａｄｋａｎ．ｃｏ．"]}, {"box": [1341, 159, 1648, 209], "vertical": false, "font_size": 50, "lines_coords": [[[1341.0, 159.0], [1648.0, 159.0], [1648.0, 209.0], [1341.0, 209.0]]], "lines": ["ホムンクルス"]}, {"box": [1443, 349, 1573, 384], "vertical": false, "font_size": 32, "lines_coords": [[[1443.0, 349.0], [1573.0, 353.0], [1573.0, 384.0], [1443.0, 381.0]]], "lines": ["山本英夫"]}, {"box": [1186, 310, 1800, 1038], "vertical": false, "font_size": 51, "lines_coords": [[[1365.0, 429.0], [1648.0, 429.0], [1648.0, 455.0], [1365.0, 455.0]], [[1328.0, 477.0], [1564.0, 477.0], [1564.0, 502.0], [1328.0, 502.0]], [[1325.0, 498.0], [1618.0, 494.0], [1618.0, 522.0], [1325.0, 525.0]], [[1327.0, 519.0], [1592.0, 517.0], [1592.0, 545.0], [1327.0, 546.0]], [[1327.0, 542.0], [1671.0, 538.0], [1671.0, 566.0], [1327.0, 569.0]], [[1328.0, 563.0], [1669.0, 561.0], [1669.0, 589.0], [1328.0, 590.0]], [[1327.0, 582.0], [1669.0, 579.0], [1669.0, 610.0], [1327.0, 613.0]], [[1325.0, 603.0], [1662.0, 600.0], [1662.0, 632.0], [1325.0, 636.0]], [[1327.0, 628.0], [1564.0, 626.0], [1564.0, 654.0], [1327.0, 655.0]], [[1330.0, 651.0], [1671.0, 649.0], [1671.0, 676.0], [1330.0, 678.0]], [[1186.0, 308.0], [1799.0, 306.0], [1799.0, 1040.0], [1190.0, 1042.0]], [[1327.0, 672.0], [1671.0, 670.0], [1671.0, 697.0], [1327.0, 699.0]], [[1328.0, 693.0], [1676.0, 693.0], [1676.0, 724.0], [1328.0, 724.0]], [[1325.0, 737.0], [1678.0, 733.0], [1678.0, 764.0], [1325.0, 768.0]], [[1328.0, 779.0], [1678.0, 779.0], [1678.0, 810.0], [1328.0, 810.0]], [[1330.0, 802.0], [1678.0, 802.0], [1678.0, 833.0], [1330.0, 833.0]], [[1330.0, 827.0], [1676.0, 827.0], [1676.0, 852.0], [1330.0, 852.0]], [[1599.0, 851.0], [1675.0, 851.0], [1675.0, 871.0], [1599.0, 871.0]], [[1330.0, 849.0], [1592.0, 849.0], [1592.0, 875.0], [1330.0, 875.0]], [[1330.0, 890.0], [1694.0, 890.0], [1694.0, 922.0], [1330.0, 922.0]], [[1332.0, 914.0], [1692.0, 914.0], [1692.0, 940.0], [1332.0, 940.0]], [[1511.0, 932.0], [1692.0, 934.0], [1692.0, 961.0], [1511.0, 959.0]], [[1330.0, 937.0], [1518.0, 934.0], [1518.0, 959.0], [1330.0, 963.0]], [[1330.0, 953.0], [1692.0, 953.0], [1692.0, 984.0], [1330.0, 984.0]], [[1328.0, 976.0], [1696.0, 976.0], [1696.0, 1007.0], [1328.0, 1007.0]], [[1327.0, 999.0], [1696.0, 995.0], [1696.0, 1026.0], [1327.0, 1030.0]]], "lines": ["エスピリッツコミックス投稿発売中（人）は「情報者・お喋りキャラ．．．」", "美味しんぼ雁屋哲・花咲アキ２０世紀少年（浦沢直樹）．．．．．．２１世紀♪年１浦沢庫樹〉．．", "２０世紀少年（浦沢遣劇）．．．！！２１世紀以年（開沢直樹）．．．", "２１世紀少年（浦沢直樹）．．．！オメガトライブ（玉井雪雄）．．．！オッガーラインキングダム（正常", "オメガトライブに生活習慣がいいのですが、オッガーライフキングダムには出血管理として中退アフロ田中のリーズが発表しています。", "オンガトライブキングダムは生理料としても中退アフロ田中にの１つが発表していたんでしょうか。でもなく自由が恥ずかしい．．．", "中退アフロ日中の「つけ残暑」ってんねん（日古戦）」．．．！！", "そんねん信号の秘．．．", "団地ともおび小田扉）．．．．．．ホムンクルス（山本英夫）・ラストイニング（中原裕神尾樹", "ホムンクルス（日）支え．．．！！ラストイニング（日常金）神経・開発ウジジマ（ん（真崎県）．．．", "そんなことはないのですが．．．", "ラストイニング（中原船）神児館）．．．１）の商品カンジマくん（株）温かい．．．", "開金ウェブジマくん「真織田平！！」とは、出る」コ出ましょーく福井先生．．．これを我が名も海師の刺激一球技場合．．．」とか名は無い。」という地域", "我が名は海賊から現場一武力海沿っていた。パンピーノ「仕きやでつい．．．」って、アレキネシスは関係ない。", "デレキネンスは最初の．．．．．．！！", "ハクバンエ子チマ（朝ユキヲ）．．．！！このボーイスオンザラン（花曜日）〜１０００以上コジューツ（地本ハルコ．．．！！", "ポーイスオンザラン（花祝曜号）－１０００ＪＪビュジューツ・特ホルルコートに最初の成績が不二あり．．．", "コリ．．．！～～～．．．．．！！〜〜〜っ", "Ｑ１０００フーコジューツ（柏木ハルタ）電波の城（細野不二彦）！！．．．チェリー（雄子内英策）．．", "チェリー（優之大実演）．．．．．．", "日本が以下、色色がありましたが、超人ファダムは素敵人し．．．", "いい．．．", "超人ウタダ（山本廉人）．．．帝王（倉科遼・関口太郎）・昴スパル（警臣正人）．．．", "赤王〈敵対通側口共同〉．．．！！ハッハハハ．．．！！ここであったのは、地平線でダグススは大人しかったんだった。", "赤ちゃんの場合は入って．．．", "地平線でダンス（根本ハルコール）．．．！！？」と言われていたのは正式化（山口のアプリー．．．"]}, {"box": [1379, 1110, 1644, 1136], "vertical": false, "font_size": 14, "lines_coords": [[[1388.0, 1117.0], [1636.0, 1117.0], [1636.0, 1133.0], [1388.0, 1133.0]]], "lines": ["ＢＯＯＫＤＥＳＩＣＮ：ＴＡＫＡＨＡＳＨＩＴＯＮＺ"]}], "img_path": "002.png"}, {"version": "0.1.7", "img_width": 830, "img_height": 1200, "blocks": [{"box": [36, 616, 126, 1003], "vertical": true, "font_size": 90, "lines_coords": [[[36.0, 616.0], [126.0, 616.0], [126.0, 1003.0], [36.0, 1003.0]]], "lines": ["ス山本英夫"]}, {"box": [53, 1130, 229, 1151], "vertical": false, "font_size": 14, "lines_coords": [[[57.0, 1132.0], [225.0, 1132.0], [225.0, 1148.0], [57.0, 1148.0]]], "lines": ["ＢｌＧＳＰＩＲＩＴＳＣＯＮＡＣＳ"]}], "img_path"