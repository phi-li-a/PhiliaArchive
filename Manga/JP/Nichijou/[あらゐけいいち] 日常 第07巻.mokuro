, 718.0], [368.0, 718.0], [368.0, 810.0], [355.0, 810.0]]], "lines": ["まだ本人にも", "確かめた", "わけじゃないし"]}, {"box": [88, 701, 140, 791], "vertical": true, "font_size": 16, "lines_coords": [[[122.0, 701.0], [140.0, 701.0], [140.0, 744.0], [122.0, 744.0]], [[104.0, 703.0], [121.0, 703.0], [121.0, 756.0], [104.0, 756.0]], [[88.0, 703.0], [101.0, 703.0], [101.0, 791.0], [88.0, 791.0]]], "lines": ["だから", "フラれた", "訳でもないし．．．"]}, {"box": [443, 815, 495, 920], "vertical": true, "font_size": 12, "lines_coords": [[[478.0, 815.0], [491.0, 815.0], [491.0, 896.0], [478.0, 896.0]], [[461.0, 815.0], [472.0, 815.0], [472.0, 885.0], [461.0, 885.0]], [[443.0, 815.0], [456.0, 815.0], [456.0, 920.0], [443.0, 920.0]]], "lines": ["付き合ってるか", "どうかなんて", "わかんないでしょ！！！"]}], "img_path": "003.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [583, 108, 643, 228], "vertical": true, "font_size": 15, "lines_coords": [[[624.0, 108.0], [638.0, 108.0], [638.0, 177.0], [624.0, 177.0]], [[603.0, 108.0], [617.0, 108.0], [617.0, 228.0], [603.0, 228.0]], [[583.0, 108.0], [600.0, 108.0], [600.0, 164.0], [583.0, 164.0]]], "lines": ["だから全然", "あきらめたとかでも", "ないし！！"]}, {"box": [291, 61, 374, 164], "vertical": true, "font_size": 23, "lines_coords": [[[348.0, 62.0], [374.0, 62.0], [374.0, 127.0], [348.0, 127.0]], [[322.0, 64.0], [343.0, 64.0], [343.0, 164.0], [322.0, 164.0]], [[291.0, 62.0], [313.0, 62.0], [313.0, 124.0], [291.0, 124.0]]], "lines": ["だから", "全然へーき", "だし！！！"]}, {"box": [621, 457, 659, 534], "vertical": true, "font_size": 38, "lines_coords": [[[621.0, 457.0], [659.0, 457.0], [659.0, 534.0], [621.0, 534.0]]], "lines": ["まだ"]}, {"box": [130, 408, 244, 607], "vertical": true, "font_size": 58, "lines_coords": [[[184.0, 412.0], [244.0, 412.0], [244.0, 500.0], [184.0, 500.0]], [[133.0, 408.0], [189.0, 409.0], [186.0, 607.0], [130.0, 606.0]]], "lines": ["全然", "好きだし！！！"]}], "img_path": "004.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [537, 77, 599, 347], "vertical": true, "font_size": 62, "lines_coords": [[[537.0, 77.0], [599.0, 77.0], [599.0, 347.0], [537.0, 347.0]]], "lines": ["そこんとこ"]}, {"box": [55, 150, 133, 513], "vertical": true, "font_size": 76, "lines_coords": [[[55.0, 161.0], [131.0, 161.0], [131.0, 492.0], [55.0, 492.0]]], "lines": ["ヨロシクソ"]}, {"box": [316, 743, 400, 938], "vertical": true, "font_size": 75, "lines_coords": [[[316.0, 781.0], [391.0, 777.0], [400.0, 934.0], [325.0, 938.0]]], "lines": ["日常は"]}], "img_path": "005.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [507, 238, 669, 255], "vertical": false, "font_size": 17, "lines_coords": [[[507.0, 238.0], [669.0, 238.0], [669.0, 255.0], [507.0, 255.0]]], "lines": ["ｃｈｏｇ．ｙｏｕｒｅｙＳ"]}, {"box": [216, 0, 487, 972], "vertical": false, "font_size": 192, "lines_coords": [[[356.0, 123.0], [413.0, 123.0], [413.0, 167.0], [356.0, 167.0]], [[356.0, 160.0], [460.0, 160.0], [460.0, 206.0], [356.0, 206.0]], [[322.0, 110.0], [371.0, 110.0], [371.0, 277.0], [322.0, 277.0]], [[356.0, 196.0], [414.0, 196.0], [414.0, 243.0], [356.0, 243.0]], [[337.0, 303.0], [457.0, 262.0], [479.0, 359.0], [359.0, 400.0]], [[355.0, 341.0], [416.0, 341.0], [416.0, 392.0], [355.0, 392.0]], [[216.0, 0.0], [486.0, 0.0], [486.0, 988.0], [216.0, 988.0]]], "lines": ["今日第８１０は８０日前の１０７０日常の１９８９日前からショート１０時間の１４時", "２０１８年０１月２０日後の１０月１１日後から、一日の日常の３００円前の３１００", "・はやっぱりやはやがてやはなかなかったのではないでしょうがないけど．．．それだけでもないのよ！！", "．．．日経の１０００円近のショートＯｍの日後の１９９０日後か１０月１日水の１１日", "この日間では１０００円程度で１０万円程でしたが、日常でしょう。日常ストレスを利用することは", "・日曜の１０１８日後のショート１０日後２１１２４日後か月２０日頃の日曜日は", "そうですか？"]}, {"box": [285, 394, 468, 989], "vertical": false, "font_size": 40, "lines_coords": [[[356.0, 396.0], [417.0, 396.0], [417.0, 416.0], [356.0, 416.0]], [[349.0, 410.0], [424.0, 410.0], [424.0, 459.0], [349.0, 459.0]], [[348.0, 447.0], [356.0, 447.0], [356.0, 476.0], [348.0, 476.0]], [[349.0, 513.0], [430.0, 513.0], [430.0, 640.0], [349.0, 640.0]], [[358.0, 616.0], [414.0, 618.0], [414.0, 638.0], [358.0, 63