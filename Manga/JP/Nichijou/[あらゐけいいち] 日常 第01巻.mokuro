0, 697.0], [363.0, 833.0], [346.0, 833.0]]], "lines": ["私だって剣道部の", "大会近いんだからね"]}, {"box": [87, 435, 189, 651], "vertical": true, "font_size": 21, "lines_coords": [[[160.0, 436.0], [188.0, 436.0], [188.0, 651.0], [160.0, 651.0]], [[135.0, 436.0], [155.0, 436.0], [155.0, 553.0], [135.0, 553.0]], [[110.0, 436.0], [130.0, 436.0], [130.0, 570.0], [110.0, 570.0]], [[88.0, 436.0], [105.0, 436.0], [105.0, 568.0], [88.0, 568.0]]], "lines": ["わかんないわよ！！！", "だいたいここは", "文化祭の出し物を", "決める場でしょ！！！"]}, {"box": [450, 750, 475, 787], "vertical": true, "font_size": 25, "lines_coords": [[[450.0, 750.0], [475.0, 750.0], [475.0, 787.0], [450.0, 787.0]]], "lines": ["美味"]}, {"box": [86, 715, 142, 862], "vertical": true, "font_size": 15, "lines_coords": [[[125.0, 715.0], [142.0, 715.0], [142.0, 772.0], [125.0, 772.0]], [[107.0, 716.0], [121.0, 716.0], [121.0, 862.0], [107.0, 862.0]], [[86.0, 715.0], [99.0, 715.0], [99.0, 835.0], [86.0, 835.0]]], "lines": ["まったく", "文化祭の実行委員なんて", "やるんじゃなかった"]}], "img_path": "046.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [607, 107, 640, 176], "vertical": true, "font_size": 33, "lines_coords": [[[607.0, 107.0], [640.0, 107.0], [640.0, 176.0], [607.0, 176.0]]], "lines": ["わ？"]}], "img_path": "047.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [571, 459, 643, 626], "vertical": true, "font_size": 19, "lines_coords": [[[623.0, 459.0], [643.0, 459.0], [639.0, 626.0], [619.0, 626.0]], [[598.0, 461.0], [616.0, 461.0], [616.0, 558.0], [598.0, 558.0]], [[571.0, 460.0], [589.0, 460.0], [590.0, 573.0], [572.0, 573.0]]], "lines": ["ちょっとあんた／なに", "マンガなんか", "読んでんのよ！！！"]}, {"box": [315, 467, 387, 628], "vertical": true, "font_size": 19, "lines_coords": [[[364.0, 467.0], [384.0, 467.0], [384.0, 628.0], [364.0, 628.0]], [[338.0, 469.0], [358.0, 469.0], [358.0, 599.0], [338.0, 599.0]], [[317.0, 468.0], [335.0, 468.0], [333.0, 547.0], [315.0, 547.0]]], "lines": ["さっさと案ださないと", "家に帰れなくなる", "じゃない！！！"]}, {"b