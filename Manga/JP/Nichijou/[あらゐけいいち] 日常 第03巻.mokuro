, 839.0]], [[581.0, 735.0], [598.0, 735.0], [598.0, 825.0], [581.0, 825.0]]], "lines": ["こうなったら", "駅前の例のアレ", "おごるから！！！"]}, {"box": [373, 797, 393, 831], "vertical": true, "font_size": 20, "lines_coords": [[[373.0, 797.0], [393.0, 797.0], [393.0, 831.0], [373.0, 831.0]]], "lines": ["はい"]}, {"box": [240, 801, 287, 823], "vertical": false, "font_size": 12, "lines_coords": [[[243.0, 801.0], [287.0, 812.0], [284.0, 823.0], [240.0, 813.0]]], "lines": ["そのどこのなかなかったのか？"]}, {"box": [195, 764, 288, 833], "vertical": false, "font_size": 15.8, "lines_coords": [[[224.0, 764.0], [281.0, 773.0], [278.0, 788.0], [221.0, 779.0]], [[209.0, 773.0], [286.0, 788.0], [283.0, 805.0], [206.0, 790.0]], [[204.0, 782.0], [288.0, 799.0], [284.0, 820.0], [200.0, 803.0]], [[199.0, 797.0], [276.0, 815.0], [272.0, 833.0], [195.0, 815.0]], [[197.0, 808.0], [217.0, 813.0], [215.0, 821.0], [195.0, 816.0]]], "lines": ["平日２０１８年", "んやかも知れないのかわからなかったから", "．．．あのね、お姉ちゃんのことを知ってきたのか", "ブログ．．．そんなことが好きなの！！！", "うんうんだからそんなことなんだ"]}, {"box": [186, 811, 256, 843], "vertical": false, "font_size": 14, "lines_coords": [[[190.0, 811.0], [256.0, 830.0], [252.0, 843.0], [186.0, 824.0]]], "lines": ["またまだまだ１年ぶったでしょうねよ"]}, {"box": [96, 722, 144, 850], "vertical": true, "font_size": 20, "lines_coords": [[[121.0, 722.0], [142.0, 722.0], [144.0, 850.0], [123.0, 850.0]], [[96.0, 722.0], [116.0, 722.0], [118.0, 842.0], [98.0, 842.0]]], "lines": ["これだよ！！もー", "早く出してよ！！！"]}], "img_path": "143.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [64, 117, 251, 248], "vertical": false, "font_size": 19.0, "lines_coords": [[[64.0, 164.0], [144.0, 117.0], [154.0, 134.0], [74.0, 181.0]], [[68.0, 192.0], [178.0, 121.0], [189.0, 137.0], [79.0, 208.0]], [[109.0, 197.0], [203.0, 134.0], [213.0, 149.0], [119.0, 212.0]], [[120.0, 209.0], [214.0, 147.0], [225.0, 164.0], [131.0, 226.0]], [[132.0, 224.0], [224.0, 161.0], [234.0, 175.0], [142.0, 238.0]], [[140.0, 231.0], [241.0, 167.0], [251.0, 184.0], [150.0, 248.0]]], "lines": ["ロボクの話さか", "中国国内の女性はない", "友達で、四条時からと", "本日に内容に向けている。ここで", "ああ！！このとき、メッセージしましたー", "このことで、それぞれのおかげさん。"]}, {"box": [180, 217, 269, 285], "vertical": false, "font_size": 17, "lines_coords": [[[180.0, 271.0], [259.0, 217.0], [269.0, 231.0], [190.0, 285.0]]], "lines": ["【メールが出荷】"]}, {"box": [311, 122, 545, 372], "vertical": false, "font_size": 21.25, "lines_coords": [[[324.0, 182.0], [429.0, 122.0], [439.0, 139.0], [334.0, 199.0]], [[311.0, 219.0], [445.0, 136.0], [456.0, 153.0], [322.0, 236.0]], [[336.0, 235.0], [428.0, 177.0], [439.0, 195.0], [347.0, 253.0]], [[350.0, 261.0], [423.0, 203.0], [439.0, 223.0], [366.0, 281.0]], [[379.0, 299.0], [436.0, 260.0], [446.0, 274.0], [389.0, 313.0]], [[388.0, 322.0], [491.0, 255.0], [502.0, 272.0], [399.0, 339.0]], [[416.0, 326.0], [527.0, 256.0], [538.0, 274.0], [427.0, 344.0]], [[416.0, 351.0], [532.0, 277.0], [545.0, 298.0], [429.0, 372.0]]], "lines": ["う程式の解決方", "口ｉ次のお昼食を開きを", "いずーやーんく", "（２）ページェーを", "（４）２０１５", "国この方程式の印象", "この作業を解決するのは", "いつかまでも、いつのようなので、"]}, {"box": [73, 263, 159, 346], "vertical": false, "font_size": 18.666666666666668, "lines_coords": [[[99.0, 315.0], [122.0, 287.0], [132.0, 295.0], [109.0, 323.0]], [[73.0, 309.0], [132.0, 263.0], [146.0, 281.0], [87.0, 327.0]], [[92.0, 332.0], [145.0, 281.0], [159.0, 295.0], [106.0, 346.0]]], "lines": ["お！？", "そうですねーんだなんだ", "きゃあああ"]}, {"box": [132, 302, 156, 329], "vertical": false, "font_size": 13, "lines_coords": [[[132.0, 322.0], [145.0, 302.0], [156.0, 309.0], [143.0, 329.0]]], "lines": ["！ｏｏ！"]}, {"box": [203, 249, 350, 390], "vertical": false, "font_size": 16.285714285714285, "lines_coords": [[[203.0, 306.0], [285.0, 249.0], [295.0, 264.0], [213.0, 320.0]], [[211.0, 321.0], [305.0, 257.0], [314.0, 271.0], [220.0, 335.0]], [[221.0, 334.0], [304.0, 277.0], [314.0, 291.0], [231.0, 348.0]], [[230.0, 343.0], [295.0, 304.0], [304.0, 319.0], [239.0, 358.0]], [[242.0, 363.0], [314.0, 314.0], [323.0, 329.0], [252.0, 377.0]], [[261.0, 368.0], [323.0, 328.0], [330.0, 339.0], [268.0, 379.0]], [[273.0, 377.0], [342.0, 335.0], [350.0, 348.0], [281.0, 390.0]]], "lines": ["左国のような直角", "三角所ＡＢＣは内容", "ご申している円の半径を", "おめなさい。", "ちょうどうするんじゃないでしょ", "そんなことじゃないわよ", "わたしようしたこと"]}, {"box": [363, 238, 441, 295], "vertical": false, "font_size": 20, "lines_coords": [[[363.0, 278.0], [431.0, 238.0], [441.0, 255.0], [373.0, 295.0]]], "lines": ["（３）６Ｍ＋５？"]}, {"box": [151, 768, 178, 910], "vertical": true, "font_size": 25, "lines_coords": [[[151.0, 769.0], [176.0, 769.0], [178.0, 910.0], [153.0, 910.0]]], "lines": ["いつのやつだ？"]}, {"box": [446, 697, 503, 840], "vertical": true, "font_size": 28, "lines_coords": [[[475.0, 698.0], [503.0, 698.0], [503.0, 742.0], [475.0, 742.0]], [[446.0, 697.0], [474.0, 697.0], [476.0, 840.0], [448.0, 840.0]]], "lines": ["この", "私のプリント．．．"]}, {"box": [484, 969, 653, 989], "vertical": false, "font_size": 20, "lines_coords": [[[484.0, 969.0], [653.0, 969.0], [653.0, 989.0], [484.0, 989.0]]], "lines": ["日常の４８（おわり）"]}], "img_path": "144.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [626, 124, 649, 241], "vertical": true, "font_size": 18, "lines_coords": [[[628.0, 124.0], [646.0, 124.0], [644.0, 241.0], [626.0, 241.0]]], "lines": ["じゃーこの問題"]}, {"box": [465, 129, 484, 212], "vertical": true, "font_size": 18, "lines_coords": [[[465.0, 129.0], [483.0, 129.0], [484.0, 212.0], [466.0, 212.0]]], "lines": ["わかるやつ"]}, {"box": [605, 399, 649, 617], "vertical": true, "font_size": 16, "lines_coords": [[[628.0, 401.0], [646.0, 401.0], [648.0, 616.0], [630.0, 616.0]], [[607.0, 402.0], [621.0, 402.0], [621.0, 500.0], [607.0, 500.0]]], "lines": ["いちいちムツかしいんだよな", "赤坂の授業は"]}, {"box": [473, 401, 500, 476], "vertical": true, "font_size": 12, "lines_coords": [[[486.0, 401.0], [500.0, 401.0], [498.0, 476.0], [484.0, 476.0]], [[473.0, 404.0], [484.0, 404.0], [484.0, 463.0], [473.0, 463.0]]], "lines": ["プリントを売れて", "なぐられた"]}, {"box": [395, 403, 440, 604], "vertical": true, "font_size": 16, "lines_coords": [[[421