.0, 795.0], [423.0, 795.0]], [[404.0, 694.0], [418.0, 694.0], [417.0, 831.0], [403.0, 831.0]]], "lines": ["以上で全校朝礼を", "終わります～～～．．．", "校長先生今日まで", "ありがとうございました"]}, {"box": [56, 644, 139, 825], "vertical": true, "font_size": 73, "lines_coords": [[[56.0, 648.0], [129.0, 644.0], [139.0, 821.0], [66.0, 825.0]]], "lines": ["教頭！！！？"]}, {"box": [65, 966, 228, 989], "vertical": false, "font_size": 21, "lines_coords": [[[65.0, 968.0], [228.0, 966.0], [228.0, 987.0], [65.0, 989.0]]], "lines": ["日常の４０（おわり）"]}], "img_path": "060.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [489, 48, 513, 131], "vertical": true, "font_size": 14, "lines_coords": [[[491.0, 48.0], [505.0, 48.0], [505.0, 131.0], [491.0, 131.0]]], "lines": ["桜井先生ー"]}, {"box": [304, 57, 319, 80], "vertical": true, "font_size": 15, "lines_coords": [[[304.0, 57.0], [319.0, 57.0], [319.0, 80.0], [304.0, 80.0]]], "lines": ["？"]}, {"box": [215, 55, 251, 169], "vertical": true, "font_size": 15, "lines_coords": [[[230.0, 55.0], [247.0, 55.0], [249.0, 145.0], [232.0, 145.0]], [[215.0, 58.0], [228.0, 58.0], [228.0, 169.0], [215.0, 169.0]]], "lines": ["あっ．．．高崎先生", "おはようございます"]}, {"box": [26, 65, 43, 201], "vertical": true, "font_size": 15, "lines_coords": [[[26.0, 65.0], [41.0, 65.0], [43.0, 200.0], [28.0, 200.0]]], "lines": ["おはようございます"]}, {"box": [612, 364, 647, 512], "vertical": true, "font_size": 14, "lines_coords": [[[629.0, 364.0], [646.0, 364.0], [647.0, 472.0], [630.0, 472.0]], [[612.0, 365.0], [626.0, 365.0], [626.0, 512.0], [612.0, 512.0]]], "lines": ["先生〜相生のヤツ", "どうにかなりませんかね"]}, {"box": [542, 392, 576, 524], "vertical": true, "font_size": 14, "lines_coords": [[[562.0, 393.0], [576.0, 393.0], [576.0, 498.0], [562.0, 498.0]], [[542.0, 392.0], [555.0, 392.0], [555.0, 524.0], [542.0, 524.0]]], "lines": ["いっこうに宿題を", "やってこないのですが"]}, {"box": [385, 317, 482, 365], "vertical": false, "font_size": 42, "lines_coords": [[[388.0, 317.0], [474.0, 323.0], [471.0, 365.0], [385.0, 359.0]]], "line