se, "font_size": 22, "lines_coords": [[[246.0, 62.0], [376.0, 62.0], [376.0, 84.0], [246.0, 84.0]]], "lines": ["「そうとは"]}, {"box": [104, 148, 143, 221], "vertical": true, "font_size": 28, "lines_coords": [[[104.0, 148.0], [132.0, 148.0], [132.0, 221.0], [104.0, 221.0]]], "lines": ["私か？"]}, {"box": [891, 484, 1000, 654], "vertical": true, "font_size": 32, "lines_coords": [[[963.0, 489.0], [991.0, 489.0], [991.0, 631.0], [963.0, 631.0]], [[924.0, 484.0], [957.0, 484.0], [960.0, 654.0], [927.0, 654.0]], [[891.0, 489.0], [925.0, 489.0], [925.0, 567.0], [891.0, 567.0]]], "lines": ["今から悟りを", "開くから見てて", "って事"]}, {"box": [576, 470, 639, 601], "vertical": true, "font_size": 24, "lines_coords": [[[605.0, 470.0], [632.0, 470.0], [632.0, 581.0], [605.0, 581.0]], [[576.0, 471.0], [598.0, 471.0], [598.0, 601.0], [576.0, 601.0]]], "lines": ["まだ開いて", "なかったのか"]}, {"box": [455, 478, 518, 690], "vertical": true, "font_size": 27, "lines_coords": [[[491.0, 478.0], [518.0, 478.0], [515.0, 643.0], [488.0, 643.0]], [[455.0, 479.0], [482.0, 479.0], [482.0, 690.0], [455.0, 690.0]]], "lines": ["フェっちゃんが", "悟ってねーって事を"]}, {"box": [99, 504, 168, 653], "vertical": true, "font_size": 31, "lines_coords": [[[123.0, 504.0], [163.0, 506.0], [160.0, 590.0], [120.0, 589.0]], [[99.0, 514.0], [121.0, 514.0], [121.0, 653.0], [99.0, 653.0]]], "lines": ["瞬時に", "悟ったんだよ"]}, {"box": [960, 829, 993, 901], "vertical": true, "font_size": 30, "lines_coords": [[[960.0, 829.0], [990.0, 829.0], [990.0, 901.0], [960.0, 901.0]]], "lines": ["行くよ"]}, {"box": [566, 839, 635, 980], "vertical": true, "font_size": 24, "lines_coords": [[[598.0, 839.0], [624.0, 839.0], [624.0, 959.0], [598.0, 959.0]], [[566.0, 842.0], [587.0, 842.0], [587.0, 979.0], [566.0, 979.0]]], "lines": ["肉眼で確認", "できるのかよ"]}, {"box": [571, 1174, 626, 1371], "vertical": true, "font_size": 22, "lines_coords": [[[602.0, 1175.0], [624.0, 1175.0], [624.0, 1306.0], [602.0, 1306.0]], [[571.0, 1175.0], [593.0, 1175.0], [593.0, 1371.0], [571.0, 1371.0]]], "lines": ["