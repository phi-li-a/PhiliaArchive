0], [495.0, 1270.0]], [[459.0, 1064.0], [490.0, 1064.0], [490.0, 1348.0], [459.0, 1348.0]], [[423.0, 1065.0], [449.0, 1065.0], [449.0, 1223.0], [423.0, 1223.0]]], "lines": ["そこへ念願の＼）", "頬がお出まじときたら〜", "これはもう、"]}], "img_path": "079.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [796, 65, 946, 460], "vertical": true, "font_size": 68, "lines_coords": [[[876.0, 65.0], [941.0, 65.0], [941.0, 375.0], [876.0, 375.0]], [[796.0, 67.0], [866.0, 65.0], [872.0, 454.0], [802.0, 456.0]]], "lines": ["突き刺さる事", "しか出来ない．．．"]}, {"box": [701, 532, 1030, 604], "vertical": false, "font_size": 61, "lines_coords": [[[869.0, 537.0], [1030.0, 537.0], [1030.0, 598.0], [869.0, 598.0]]], "lines": ["っ１８３"]}, {"box": [787, 706, 890, 859], "vertical": true, "font_size": 29.333333333333332, "lines_coords": [[[857.0, 706.0], [890.0, 706.0], [890.0, 800.0], [857.0, 800.0]], [[824.0, 712.0], [851.0, 712.0], [851.0, 859.0], [824.0, 859.0]], [[787.0, 710.0], [815.0, 710.0], [815.0, 800.0], [787.0, 800.0]]], "lines": ["「やーい", "ひっかかって", "やんの」"]}, {"box": [706, 685, 772, 840], "vertical": true, "font_size": 28, "lines_coords": [[[743.0, 685.0], [772.0, 685.0], [772.0, 718.0], [743.0, 718.0]], [[707.0, 687.0], [733.0, 687.0], [733.0, 837.0], [707.0, 837.0]]], "lines": ["で", "終わりの筈だ"]}, {"box": [632, 656, 661, 802], "vertical": true, "font_size": 26, "lines_coords": [[[632.0, 656.0], [658.0, 656.0], [658.0, 800.0], [632.0, 800.0]]], "lines": ["しかしどうだ"]}, {"box": [551, 653, 591, 873], "vertical": true, "font_size": 31, "lines_coords": [[[551.0, 653.0], [582.0, 653.0], [582.0, 850.0], [551.0, 850.0]]], "lines": ["この状態から既に、"]}, {"box": [448, 683, 510, 829], "vertical": true, "font_size": 39, "lines_coords": [[[449.0, 690.0], [488.0, 690.0], [488.0, 823.0], [449.0, 823.0]]], "lines": ["一分近く"]}, {"box": [110, 676, 243, 906], "vertical": true, "font_size": 67, "lines_coords": [[[154.0, 676.0], [243.0, 676.0], [243.0, 776.0], [154.0, 776.0]], [[115.0, 685.0], [160.0, 685.0], [156.0, 906.0], [110.0, 906.0]]], "lines": ["経過", "している．．．！！"]}, {"box": [929, 667, 1000, 939], "vertical": true, "font_size": 26, "lines_coords": [[[966.0, 667.0], [993.0, 667.0], [993.0, 939.0], [966.0, 939.0]], [[929.0, 668.0], [955.0, 668.0], [955.0, 818.0], [929.0, 818.0]]], "lines": ["他愛もないありふれた！！", "悪戯であれば"]}, {"box": [946, 1129, 986, 1365], "vertical": true, "font_size": 28, "lines_coords": [[[946.0, 1129.0], [974.0, 1129.0], [975.0, 1365.0], [947.0, 1365.0]]], "lines": ["張り詰めた空気の中、"]}, {"box": [596, 1129, 676, 1346], "vertical": true, "font_size": 35, "lines_coords": [[[626.0, 1129.0], [668.0, 1129.0], [668.0, 1346.0], [626.0, 1346.0]], [[596.0, 1134.0], [624.0, 1134.0], [624.0, 1267.0], [596.0, 1267.0]]], "lines": ["私は一つの答えを", "導き出した"]}, {"box": [424, 1125, 544, 1414], "vertical": true, "font_size": 31, "lines_coords": [[[502.0, 1128.0], [534.0, 1128.0], [534.0, 1414.0], [502.0, 1414.0]], [[462.0, 1125.0], [493.0, 1125.0], [496.0, 1312.0], [465.0, 1312.0]], [[424.0, 1125.0], [455.0, 1125.0], [457.0, 1360.0], [426.0, 1360.0]]], "lines": ["この人差し指トラップは", "テストの点数で", "勝ち目がないと悟り"]}, {"box": [103, 1125, 180, 1396], "vertical": true, "font_size": 32, "lines_coords": [[[140.0, 1125.0], [173.0, 1125.0], [171.0, 1396.0], [138.0, 1396.0]], [[103.0, 1126.0], [134.0, 1126.0], [134.0, 1364.0], [103.0, 1364.0]]], "lines": ["せめて一矢報いたいと", "放たれた希望の光："]}], "img_path": "080.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [799, 20, 1041, 634], "vertical": true, "font_size": 119, "lines_coords": [[[882.0, 20.0], [1041.0, 21.0], [1036.0, 634.0], [877.0, 632.0]], [[799.0, 40.0], [877.0, 39.0], [879.0, 184.0], [801.0, 185.0]]], "lines": ["劣等感という壁を", "打ち"]}, {"box": [774, 707, 1021, 875], "vertical": true, "font_size": 29, "lines_coords": [[[982.0, 709.0], [1011.0, 709.0], [1011.0, 775.0], [982.0, 775.0]], [[949.0, 710.0], [977.0, 710.0], [977.0, 834.0], [949.0, 834.0]], [[913.0, 710.0], [941.0, 710.0], [941.0, 846.0], [913.0, 846.0]], [[876.0, 707.0], [907.0, 707.0], [907.0, 875.0], [876.0, 875.0]], [[843.0, 710.0], [869.0, 710.0], [869.0, 831.0], [843.0, 831.0]], [[808.0, 710.0], [836.0, 710.0], [836.0, 814.0], [808.0, 814.0]], [[774.0, 709.0], [807.0, 709.0], [807.0, 795.0], [774.0, 795.0]]], "lines": ["刹那", "この推測が", "私の慢心と", "彼女への冒源に", "なり得る", "解釈だと", "気づく"]}, {"box": [548, 739, 587, 830], "vertical": true, "font_size": 39, "lines_coords": [[[548.0, 739.0], [587.0, 739.0], [587.0, 830.0], [548.0, 830.0]]], "lines": ["オーニッガラム"]}, {"box": [354, 694, 488, 942], "vertical": true, "font_size": 26, "lines_coords": [[[454.0, 695.0], [480.0, 695.0], [480.0, 878.0], [454.0, 878.0]], [[420.0, 695.0], [446.0, 695.0], [446.0, 942.0], [420.0, 942.0]], [[387.0, 695.0], [413.0, 695.0], [413.0, 832.0], [387.0, 832.0]], [[354.0, 695.0], [381.0, 695.0], [381.0, 842.0], [354.0, 842.0]]], "lines": ["彼女はただ素直に", "私のリアクションを求め", "待機している", "だけだろう！！"]}, {"box": [120, 695, 220, 921], "vertical": true, "font_size": 26, "lines_coords": [[[181.0, 695.0], [209.0, 695.0], [212.0, 921.0], [184.0, 921.0]], [[151.0, 696.0], [178.0, 696.0], [178.0, 920.0], [151.0, 920.0]], [[120.0, 698.0], [142.0, 698.0], [142.0, 896.0], [120.0, 896.0]]], "lines": ["私が邪推している間も", "粛々と待ち続けている", "のではないだろうか"]}, {"box": [865, 1082, 1020, 1423], "vertical": true, "font_size": 29, "lines_coords": [[[983.0, 1085.0], [1010.0, 1085.0], [1010.0, 1345.0], [983.0, 1345.0]], [[944.0, 1085.0], [971.0, 1085.0], [971.0, 1320.0], [944.0, 1320.0]], [[904.0, 1085.0], [935.0, 1085.0], [935.0, 1270.0], [904.0, 1270.0]], [[866.0, 1082.0], [897.0, 1082.0], [896.0, 1423.0], [865.0, 1423.0]]], "lines": ["時と共に剥がれ落ちた", "純朴という名の皮を", "踏みしめながら", "自分の人としでの器を恥じた"]}, {"box": [443, 1089, 560, 1440], "vertical": true, "font_size": 35, "lines_coords": [[[518.0, 1090.0], [560.0, 1090.0], [560.0, 1423.0], [518.0, 1423.0]], [[484.0, 1092.0], [515.0, 1092.0], [515.0, 1385.0], [484.0, 1385.0]], [[445.0, 1090.0], [476.0, 1090.0], [476.0, 1440.0], [445.0, 1440.0]]], "lines": ["「うわ！ひっかかっちった」", "他愛ない悪戯に私はこの", "ＰＯＰな一言を彼女に贈ろう"]}, {"box": [301, 1081, 379, 1319], "vertical": true, "font_size": 30, "lines_coords": [[[340.0, 1081.0], [371.0, 1081.0], [371.0, 1268.0], [340.0, 1268.0]], [[301.0, 1082.0], [329.0, 1082.0], [331.0, 1318.0], [302.0, 1318.0]]], "lines": ["私はゆっくりと", "彼女に視線を広げた"]}], "img_path": "081.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [829, 21, 978, 626], "vertical": true, "font_size": 88, "lines_coords": [[[922.0, 34.0], [977.0, 34.0], [977.0, 125.0], [922.0, 125.0]], [[829.0, 23.0], [949.0, 21.0], [960.0, 625.0], [840.0, 626.0]]], "lines": ["わたし", "私が馬鹿だった"]}, {"box": [885, 760, 999, 1303], "vertical": true, "font_size": 28, "lines_coords": [[[957.0, 765.0], [988.0, 765.0], [988.0, 1303.0], [957.0, 1303.0]], [[922.0, 765.0], [949.0, 765.0], [949.0, 1279.0], [922.0, 1279.0]], [[886.0, 760.0], [913.0, 760.0], [913.0, 957.0], [886.0, 957.0]]], "lines": ["「侮辱」という名の種を本質」という名の土に蒔き", "「優越」という名の水で丹念に育んで出来上がる", "このゲスな微笑は"]}, {"box": [571, 764, 648, 1190], "vertical": true, "font_size": 27, "lines_coords": [[[605.0, 764.0], [637.0, 764.0], [638.0, 1190.0], [607.0, 1190.0]], [[574.0, 770.0], [596.0, 770.0], [596.0, 1131.0], [574.0, 1131.0]]], "lines": ["恍惚の果てへ足を踏み入れた者にだけ", "収穫される罪深き狂気の果実だよ"]}, {"box": [412, 760, 521, 1014], "vertical": true, "font_size": 28, "lines_coords": [[[476.0, 760.0], [513.0, 760.0], [519.0, 992.0], [482.0, 992.0]], [[448.0, 767.0], [474.0, 767.0], [474.0, 1014.0], [448.0, 1014.0]], [[413.0, 768.0], [435.0, 768.0], [435.0, 889.0], [413.0, 889.0]]], "lines": ["私の憶度はあながち", "間違いでは無いのでは", "なしか．．．！"]}, {"box": [98, 767, 238, 1046], "vertical": true, "font_size": 32, "lines_coords": [[[209.0, 770.0], [237.0, 770.0], [234.0, 948.0], [206.0, 948.0]], [[163.0, 767.0], [201.0, 767.0], [204.0, 1046.0], [167.0, 1046.0]], [[132.0, 770.0], [163.0, 770.0], [163.0, 973.0], [132.0, 973.0]], [[98.0, 770.0], [129.0, 770.0], [129.0, 1021.0], [98.0, 1021.0]]], "lines": ["しかしこのまま", "私も意地を張っていては", "折角のお昼休みが", "台無しになってしまう"]}, {"box": [377, 1151, 519, 1375], "vertical": true, "font_size": 28, "lines_coords": [[[487.0, 1153.0], [513.0, 1153.0], [513.0, 1375.0], [487.0, 1375.0]], [[451.0, 1151.0], [479.0, 1151.0], [476.0, 1351.0], [448.0, 1351.0]], [[409.0, 1151.0], [440.0, 1151.0], [440.0, 1375.0], [409.0, 1375.0]], [[377.0, 1154.0], [404.0, 1154.0], [404.0, 1279.0], [377.0, 1279.0]]], "lines": ["そろそろ終わりをと", "心に決めたその時", "彼女の左手のソレが", "鈍く光った"]}], "img_path": "082.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [348, 214, 749, 533], "vertical": false, "font_size": 70, "lines_coords": [[[526.0, 445.0], [651.0, 390.0], [679.0, 454.0], [554.0, 509.0]]], "lines": ["１キ"]}, {"box": [969, 759, 1021, 900], "vertical": true, "font_size": 52, "lines_coords": [[[969.0, 759.0], [1021.0, 759.0], [1021.0, 900.0], [969.0, 900.0]]], "lines": ["やはり"]}, {"box": [471, 770, 561, 973], "vertical": true, "font_size": 31, "lines_coords": [[[515.0, 770.0], [546.0, 770.0], [546.0, 973.0], [515.0, 973.0]]], "lines": ["復復湧き上がる"]}, {"box": [355, 765, 560, 1060], "vertical": true, "font_size": 38, "lines_coords": [[[468.0, 765.0], [505.0, 765.0], [509.0, 964.0], [471.0, 964.0]]], "lines": ["憤懣のマグマ"]}, {"box": [39, 749, 314, 1078], "vertical": true, "font_size": 31, "lines_coords": [[[274.0, 759.0], [307.0, 759.0], [307.0, 1078.0], [274.0, 1078.0]], [[235.0, 757.0], [268.0, 757.0], [270.0, 1053.0], [237.0, 1053.0]], [[201.0, 757.0], [229.0, 757.0], [229.0, 889.0], [201.0, 889.0]]], "lines": ["あのテスゲームに比べれば", "今のコレは前のソレとは", "提灯に釣鐘"]}, {"box": [32, 753, 107, 941], "vertical": true, "font_size": 28, "lines_coords": [[[74.0, 757.0], [101.0, 757.0], [101.0, 940.0], [74.0, 940.0]], [[32.0, 757.0], [60.0, 757.0], [62.0, 889.0], [34.0, 889.0]]], "lines": ["まるでポップな", "ソレである"]}, {"box": [957, 1028, 1015, 1489], "vertical": true, "font_size": 58, "lines_coords": [[[957.0, 1040.0], [1015.0, 1040.0], [1015.0, 1489.0], [957.0, 1489.0]]], "lines": ["「どっきり」というものが"]}, {"box": [657, 1077, 719, 1490], "vertical": true, "font_size": 53, "lines_coords": [[[657.0, 1078.0], [710.0, 1078.0], [710.0, 1490.0], [657.0, 1490.0]]], "lines": ["まるで解っていない！！"]}, {"box": [460, 1137, 548, 1302], "vertical": true, "font_size": 69, "lines_coords": [[[460.0, 1137.0], [529.0, 1137.0], [529.0, 1300.0], [460.0, 1300.0]]], "lines": ["突如！"]}, {"box": [126, 1135, 210, 1414], "vertical": true, "font_size": 30, "lines_coords": [[[162.0, 1137.0], [195.0, 1137.0], [198.0, 1384.0], [165.0, 1384.0]], [[128.0, 1135.0], [154.0, 1135.0], [154.0, 1414.0], [128.0, 1414.0]]], "lines": ["膝から崩れ落ちる！", "ような感覚が私を襲う"]}], "img_path": "083.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [109, 148, 283, 489], "vertical": true, "font_size": 123, "lines_coords": [[[176.0, 154.0], [274.0, 157.0], [273.0, 200.0], [174.0, 196.0]], [[109.0, 171.0], [257.0, 160.0], [277.0, 429.0], [129.0, 440.0]]], "lines": ["さだ", "第二波"]}, {"box": [930, 842, 1038, 1042], "vertical": true, "font_size": 28, "lines_coords": [[[1000.0, 843.0], [1033.0, 843.0], [1033.0, 971.0], [1000.0, 971.0]], [[966.0, 842.0], [994.0, 842.0], [991.0, 1017.0], [963.0, 1017.0]], [[932.0, 845.0], [954.0, 845.0], [954.0, 1040.0], [932.0, 1040.0]]], "lines": ["もはや何を", "やられているか", "解らない状況だが"]}, {"box": [649, 845, 763, 1000], "vertical": true, "font_size": 34, "lines_coords": [[[724.0, 845.0], [752.0, 845.0], [749.0, 976.0], [721.0, 976.0]], [[674.0, 845.0], [721.0, 845.0], [721.0, 932.0], [674.0, 932.0]], [[651.0, 854.0], [677.0, 854.0], [677.0, 1000.0], [651.0, 1000.0]]], "lines": ["確実に解る", "事が．．．", "うだけある"]}, {"box": [437, 851, 576, 1042], "vertical": true, "font_size": 43, "lines_coords": [[[530.0, 854.0], [576.0, 854.0], [576.0, 954.0], [530.0, 954.0]], [[488.0, 857.0], [526.0, 857.0], [526.0, 1042.0], [488.0, 1042.0]], [[437.0, 851.0], [482.0, 851.0], [482.0, 954.0], [437.0, 954.0]]], "lines": ["これは", "「どっきり」で", "ある！"]}, {"box": [221, 840, 421, 1106], "vertical": true, "font_size": 117, "lines_coords": [[[318.0, 842.0], [421.0, 850.0], [402.0, 1106.0], [299.0, 1098.0]], [[221.0, 845.0], [352.0, 845.0], [352.0, 1082.0], [221.0, 1082.0]]], "lines": ["バッサー", "それじゃ"]}, {"box": [95, 889, 148, 1025], "vertical": true, "font_size": 53, "lines_coords": [[[95.0, 889.0], [148.0, 889.0], [148.0, 1025.0], [95.0, 1025.0]]], "lines": ["しかし"]}, {"box": [1010, 1218, 1054, 1343], "vertical": true, "font_size": 44, "lines_coords": [[[1010.0, 1218.0], [1054.0, 1218.0], [1054.0, 1343.0], [1010.0, 1343.0]]], "lines": ["これは"]}, {"box": [551, 1190, 662, 1476], "vertical": true, "font_size": 52, "lines_coords": [[[616.0, 1198.0], [660.0, 1198.0], [660.0, 1476.0], [616.0, 1476.0]], [[551.0, 1190.0], [612.0, 1190.0], [612.0, 1284.0], [551.0, 1284.0]]], "lines": ["「どっきり」では", "ない"]}, {"box": [432, 1185, 487, 1470], "vertical": true, "font_size": 42, "lines_coords": [[[432.0, 1185.0], [474.0, 1185.0], [474.0, 1470.0], [432.0, 1470.0]]], "lines": ["私の勘ピューターが"]}, {"box": [103, 1203, 195, 1396], "vertical": true, "font_size": 40, "lines_coords": [[[140.0, 1206.0], [188.0, 1206.0], [188.0, 1396.0], [140.0, 1396.0]], [[103.0, 1203.0], [134.0, 1203.0], [134.0, 1360.0], [103.0, 1360.0]]], "lines": ["一つの答えを", "はじき出す"]}], "img_path": "084.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [837, 25, 1080, 645], "vertical": true, "font_size": 200, "lines_coords": [[[865.0, 29.0], [1064.0, 25.0], [1080.0, 640.0], [880.0, 645.0]]], "lines": ["本当の「どっきり」"]}, {"box": [0, 0, 326, 556], "vertical": true, "font_size": 179, "lines_coords": [[[238.0, 70.0], [281.0, 70.0], [281.0, 134.0], [238.0, 134.0]], [[4.0, 0.0], [326.0, 1.0], [307.0, 556.0], [0.0, 545.0]]], "lines": ["おー", "教えるという事！"]}, {"box": [841, 692, 1017, 963], "vertical": true, "font_size": 36, "lines_coords": [[[968.0, 695.0], [1005.0, 695.0], [1005.0, 934.0], [968.0, 934.0]], [[925.0, 692.0], [963.0, 692.0], [960.0, 962.0], [922.0, 962.0]], [[883.0, 695.0], [916.0, 695.0], [916.0, 901.0], [883.0, 901.0]], [[841.0, 695.0], [876.0, 695.0], [876.0, 814.0], [841.0, 814.0]]], "lines": ["今の状況が続けば", "摩訶不思議な第三波", "第四波が続々と", "押し寄せ"]}, {"box": [628, 693, 716, 990], "vertical": true, "font_size": 32, "lines_coords": [[[666.0, 693.0], [704.0, 693.0], [707.0, 990.0], [669.0, 990.0]], [[630.0, 698.0], [657.0, 698.0], [657.0, 871.0], [630.0, 871.0]]], "lines": ["その度リアクションは", "困難を極める"]}, {"box": [394, 700, 569, 1025], "vertical": true, "font_size": 31, "lines_coords": [[[523.0, 703.0], [555.0, 703.0], [555.0, 967.0], [523.0, 967.0]], [[480.0, 703.0], [512.0, 703.0], [512.0, 1025.0], [480.0, 1025.0]], [[437.0, 703.0], [468.0, 703.0], [468.0, 965.0], [437.0, 965.0]], [[395.0, 700.0], [423.0, 700.0], [424.0, 906.0], [396.0, 906.0]]], "lines": ["かと言って、今私が", "彼女の「どっきり」に反応", "するかと問われれば", "答えはＮＯだ！"]}, {"box": [26, 703, 158, 940], "vertical": true, "font_size": 34, "lines_coords": [[[110.0, 703.0], [148.0, 703.0], [148.0, 939.0], [110.0, 939.0]], [[68.0, 706.0], [101.0, 706.0], [101.0, 940.0], [68.0, 940.0]], [[26.0, 706.0], [57.0, 706.0], [57.0, 882.0], [26.0, 882.0]]], "lines": ["私の負けず嫌いの", "顔がひょっこりと", "顔を覗かせた"]}, {"box": [951, 1098, 1018, 1462], "vertical": true, "font_size": 48, "lines_coords": [[[952.0, 1100.0], [1000.0, 1100.0], [1000.0, 1462.0], [952.0, 1462.0]]], "lines": ["さあ見せてやろう"]}, {"box": [166, 1094, 276, 1477], "vertical": true, "font_size": 45, "lines_coords": [[[223.0, 1096.0], [267.0, 1096.0], [267.0, 1326.0], [223.0, 1326.0]], [[167.0, 1100.0], [213.0, 1100.0], [213.0, 1475.0], [167.0, 1475.0]]], "lines": ["飛びっ切りの", "「どっきり」ってやつを"]}], "img_path": "085.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [810, 81, 1033, 610], "vertical": true, "font_size": 128, "lines_coords": [[[894.0, 82.0], [1022.0, 81.0], [1025.0, 364.0], [897.0, 365.0]]], "lines": ["ギャー"]}, {"box": [103, 1506, 359, 1539], "vertical": false, "font_size": 33, "lines_coords": [[[103.0, 1506.0], [359.0, 1506.0], [359.0, 1539.0], [103.0, 1539.0]]], "lines": ["日常の１８３（おわり）"]}, {"box": [577, 11