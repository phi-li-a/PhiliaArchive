76.0], [318.0, 303.0], [113.0, 306.0]]], "lines": ["角川コミックス・エース"]}, {"box": [109, 312, 292, 351], "vertical": false, "font_size": 39, "lines_coords": [[[109.0, 312.0], [292.0, 312.0], [292.0, 351.0], [109.0, 351.0]]], "lines": ["日常（１０）"]}, {"box": [113, 409, 292, 429], "vertical": false, "font_size": 20, "lines_coords": [[[113.0, 409.0], [292.0, 409.0], [292.0, 429.0], [113.0, 429.0]]], "lines": ["著者：あらゐ＿けいいち"]}, {"box": [108, 508, 249, 530], "vertical": false, "font_size": 24, "lines_coords": [[[108.0, 506.0], [249.0, 506.0], [249.0, 532.0], [108.0, 532.0]]], "lines": ["『ＫｅｉｃｈｉＡＲＡＷ２０１５"]}, {"box": [113, 600, 348, 621], "vertical": false, "font_size": 21, "lines_coords": [[[113.0, 600.0], [348.0, 600.0], [348.0, 621.0], [113.0, 621.0]]], "lines": ["２０１５年１２月２６日発行"]}, {"box": [110, 670, 313, 734], "vertical": false, "font_size": 17.666666666666668, "lines_coords": [[[110.0, 670.0], [281.0, 670.0], [281.0, 690.0], [110.0, 690.0]], [[112.0, 695.0], [223.0, 695.0], [223.0, 712.0], [112.0, 712.0]], [[113.0, 718.0], [313.0, 718.0], [313.0, 734.0], [113.0, 734.0]]], "lines": ["角川コミックス・エース", "『日常〈１０〉", "２０１５年１２月２６日初版発行"]}, {"box": [112, 650, 457, 665], "vertical": false, "font_size": 15, "lines_coords": [[[112.0, 650.0], [457.0, 650.0], [457.0, 665.0], [112.0, 665.0]]], "lines": ["本電子書籍は下記にもとづいて制作しました"]}, {"box": [76, 735, 460, 901], "vertical": false, "font_size": 87.0, "lines_coords": [[[76.0, 735.0], [460.0, 735.0], [460.0, 889.0], [76.0, 889.0]], [[117.0, 881.0], [430.0, 881.0], [430.0, 901.0], [117.0, 901.0]]], "lines": ["２０１４年１２月１２日土曜日、東京大震災地で発生されていましたが、１００７年７月１７日から１０日（水）になっているのですが、", "〒１００２０１７年東京都千代田区高生駅から２００３年６月３０日火の１カスタマーサポート"]}, {"box": [113, 904, 365, 942], "vertical": false, "font_size": 18.0, "lines_coords": [[[115.0, 904.0], [365.0, 904.0], [365.0, 920.0], [115.0, 920.0]], [[113.0, 920.0], [365.0, 921.0], [365.0, 942.0], [113.0, 940.0]]], "lines": ["０３－３２３８－８５２１〈カスタマーサポート〉", "編集企画コミック＆キャラクター局"]}, {"box": [113, 1017, 273, 1037], "vertical": false, "font_size": 20, "lines_coords": [[[113.0, 1017.0], [273.0, 1017.0], [273.0, 1037.0], [113.0, 1037.0]]], "lines": ["装旗・デザイン・里見英樹"]}, {"box": [193, 942, 326, 962], "vertical": false, "font_size": 20, "lines_coords": [[[193.0, 942.0], [326.0, 942.0], [326.0, 962.0], [193.0, 962.0]]], "lines": ["少年エース編集部"]}, {"box": [112, 1126, 562, 1212], "vertical": false, "font_size": 15, "lines_coords": [[[113.0, 1126.0], [546.0, 1126.0], [546.0, 1142.0], [113.0, 1142.0]], [[112.0, 1143.0], [562.0, 1143.0], [562.0, 1159.0], [112.0, 1159.0]], [[113.0, 1164.0], [401.0, 1164.0], [401.0, 1179.0], [113.0, 1179.0]], [[113.0, 1181.0], [546.0, 1181.0], [546.0, 1196.0], [113.0, 1196.0]], [[115.0, 1201.0], [335.0, 1201.0], [335.0, 1212.0], [115.0, 1212.0]]], "lines": ["また、本作品の内容を無断で改変、改ざん等を行うことも禁止します。", "本作品購入時にご承諾いただいた規約により、有償・無償にかかわらず", "本作品を第三者に譲渡することはできません。", "本作品を示すサムネイルなどのイメージ画像は、再ダウンロード時に", "予告なく変更される場合があります"]}, {"box": [110, 1085, 610, 1253], "vertical": false, "font_size": 19, "lines_coords": [[[110.0, 1085.0], [526.0, 1087.0], [526.0, 1111.0], [110.0, 1109.0]], [[110.0, 1107.0], [398.0, 1107.0], [398.0, 1127.0], [110.0, 1127.0]], [[113.0, 1215.0], [607.0, 1215.0], [607.0, 1234.0], [113.0, 1234.0]]], "lines": ["本作品の全部または一部をキームページに転職する無断で複製、転職、配信、送信したり、", "ホームページェントに転載することですよ。本作日の内容を無くことを禁止します。", "アロなら変えるかな。ありがとう。ご覧になるリーディングシステムにより、表示の差が認められることがあります。"]}, {"box": [113, 1235, 580, 1251], "vertical": false, "font_size": 15, "lines_coords": [[[113.0, 1235.0], [580.0, 1235.0], [580.0, 1251.0], [113.0, 1251.0]]], "lines": ["この物語はフィクシヨンであり、実在の人物・団体とは関係がございません"]}], "img_path": "166.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [268, 560, 874, 798], "vertical": false, "font_size": 258, "lines_coords": [[[299.0, 537.0], [874.0, 541.0], [872.0, 821.0], [298.0, 818.0]]], "lines": ["．．．"]}, {"box": [120, 851, 986, 981], "vertical": false, "font_size": 143, "lines_coords": [[[162.0, 838.0], [986.0, 838.0], [986.0, 994.0], [162.0, 994.0]]], "lines": ["ＢＯＯＫ☆ＷＡＬＫＥＲ"]}], "img