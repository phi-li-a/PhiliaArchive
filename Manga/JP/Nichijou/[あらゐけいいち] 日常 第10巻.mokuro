.0, 739.0]]], "lines": ["やっほー", "お元気ですか？"]}, {"box": [143, 545, 291, 720], "vertical": true, "font_size": 29, "lines_coords": [[[246.0, 546.0], [279.0, 546.0], [279.0, 720.0], [246.0, 720.0]], [[213.0, 546.0], [242.0, 546.0], [238.0, 692.0], [210.0, 692.0]], [[179.0, 548.0], [207.0, 548.0], [207.0, 670.0], [179.0, 670.0]], [[143.0, 545.0], [170.0, 545.0], [173.0, 706.0], [146.0, 706.0]]], "lines": ["高校一年の私は", "自分の部屋で", "この手紙を", "書いています。"]}, {"box": [134, 981, 281, 1175], "vertical": true, "font_size": 39, "lines_coords": [[[227.0, 1006.0], [262.0, 1004.0], [267.0, 1143.0], [232.0, 1145.0]], [[182.0, 981.0], [221.0, 981.0], [221.0, 1173.0], [182.0, 1173.0]], [[134.0, 982.0], [178.0, 982.0], [178.0, 1103.0], [134.0, 1103.0]]], "lines": ["よく晴れた", "きもちのいい", "朝です。"]}], "img_path": "153.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [846, 132, 997, 389], "vertical": true, "font_size": 45, "lines_coords": [[[940.0, 137.0], [982.0, 137.0], [982.0, 389.0], [940.0, 389.0]], [[893.0, 135.0], [941.0, 135.0], [941.0, 375.0], [893.0, 375.0]], [[846.0, 134.0], [890.0, 132.0], [893.0, 248.0], [849.0, 250.0]]], "lines": ["こういう手紙をゃ", "書くのは三度目", "なので、"]}, {"box": [573, 137, 628, 331], "vertical": true, "font_size": 37, "lines_coords": [[[573.0, 139.0], [610.0, 137.0], [616.0, 284.0], [579.0, 285.0]]], "lines": ["楽勝です。"]}, {"box": [403, 128, 521, 416], "vertical": true, "font_size": 30, "lines_coords": [[[480.0, 139.0], [512.0, 139.0], [512.0, 376.0], [480.0, 376.0]], [[441.0, 128.0], [473.0, 128.0], [473.0, 387.0], [441.0, 387.0]], [[404.0, 142.0], [430.0, 142.0], [430.0, 415.0], [404.0, 415.0]]], "lines": ["なぜなら前に書いた", "下書きがあったので、", "そのまま写すからです。"]}, {"box": [910, 650, 1002, 897], "vertical": true, "font_size": 35, "lines_coords": [[[949.0, 651.0], [986.0, 651.0], [986.0, 714.0], [949.0, 714.0]], [[910.0, 650.0], [943.0, 650.0], [947.0, 895.0], [915.0, 895.0]]], "lines": ["夢は", "みつかりましたか？"]}, {"box": [407, 653, 521, 837], "vertical": true, "font_