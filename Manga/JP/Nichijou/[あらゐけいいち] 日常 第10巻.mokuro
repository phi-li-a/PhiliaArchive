715.0]]], "lines": ["あーと"]}, {"box": [152, 618, 188, 835], "vertical": true, "font_size": 36, "lines_coords": [[[152.0, 618.0], [188.0, 618.0], [188.0, 835.0], [152.0, 835.0]]], "lines": ["えーと．．．"]}, {"box": [954, 1048, 997, 1120], "vertical": false, "font_size": 72, "lines_coords": [[[954.0, 1048.0], [997.0, 1048.0], [997.0, 1120.0], [954.0, 1120.0]]], "lines": ["追伸"]}, {"box": [73, 1043, 227, 1265], "vertical": true, "font_size": 47, "lines_coords": [[[173.0, 1045.0], [223.0, 1043.0], [227.0, 1229.0], [178.0, 1231.0]], [[124.0, 1048.0], [174.0, 1048.0], [174.0, 1206.0], [124.0, 1206.0]], [[73.0, 1054.0], [115.0, 1054.0], [115.0, 1265.0], [73.0, 1265.0]]], "lines": ["あーっと．．．", "やっぱり", "とくになし！"]}], "img_path": "155.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [812, 225, 847, 483], "vertical": true, "font_size": 32, "lines_coords": [[[812.0, 226.0], [844.0, 226.0], [847.0, 481.0], [815.0, 481.0]]], "lines": ["加田ゴ河シサイテン"]}, {"box": [529, 100, 651, 553], "vertical": true, "font_size": 29, "lines_coords": [[[610.0, 101.0], [637.0, 101.0], [637.0, 437.0], [610.0, 437.0]], [[569.0, 100.0], [601.0, 100.0], [601.0, 453.0], [569.0, 453.0]], [[532.0, 117.0], [559.0, 117.0], [559.0, 553.0], [532.0, 553.0]]], "lines": ["子ごんにちは長野原みおさん", "私は１５歳の長野原みおです。", "〈年下なので、こう切り込んでみました。"]}, {"box": [98, 112, 219, 539], "vertical": true, "font_size": 30, "lines_coords": [[[174.0, 112.0], [206.0, 112.0], [206.0, 435.0], [174.0, 435.0]], [[135.0, 114.0], [167.0, 114.0], [167.0, 465.0], [135.0, 465.0]], [[99.0, 114.0], [126.0, 114.0], [126.0, 539.0], [99.0, 539.0]]], "lines": ["漫画家生活はどうですか？", "つらくも楽しい日々ですか？", "（さりげに原望をふっ込んでみました。"]}, {"box": [718, 650, 996, 910], "vertical": true, "font_size": 33, "lines_coords": [[[950.0, 650.0], [996.0, 650.0], [996.0, 728.0], [950.0, 728.0]], [[918.0, 653.0], [949.0, 653.0], [949.0, 910.0], [918.0, 910.0]], [[877.0, 653.0], [908.0, 653.0], [908.0, 843.0], [877.0, 843.0]], [[840.0, 654.0], [866.0, 654.0], [866.0, 814.0], [840.0, 814.0]], [[797.0, 654.0], [830.0, 654.0], [830.0, 789.0], [797.0, 789.0]], [[755.0, 653.0], [790.0, 653.0], [790.0, 739.0], [755.0, 739.0]], [[718.0, 653.0], [746.0, 653.0], [749.0, 773.0], [721.0, 773.0]]], "lines": ["さて、", "今これを読んでいる", "貴方の周りにも", "いつもと同じ", "メンバーが", "いる事", "でしょう。"]}, {"box": [452, 662, 531, 853], "vertical": true, "font_size": 29, "lines_coords": [[[490.0, 662.0], [521.0, 662.0], [521.0, 853.0], [490.0, 853.0]], [[452.0, 664.0], [479.0, 664.0], [479.0, 784.0], [452.0, 784.0]]], "lines": ["そこでお願いが", "あります。"]}, {"box": [416, 1076, 558, 1269], "vertical": true, "font_size": 28, "lines_coords": [[[523.0, 1078.0], [549.0, 1078.0], [549.0, 1221.0], [523.0, 1221.0]], [[488.0, 1078.0], [515.0, 1078.0], [515.0, 1245.0], [488.0, 1245.0]], [[451.0, 1076.0], [477.0, 1076.0], [477.0, 1267.0], [451.0, 1267.0]], [[416.0, 1076.0], [449.0, 1076.0], [449.0, 1178.0], [416.0, 1178.0]]], "lines": ["そして周りの", "みんなに見せて", "判定してもらって", "下さい！"]}, {"box": [851, 1075, 995, 1445], "vertical": true, "font_size": 28, "lines_coords": [[[954.0, 1075.0], [985.0, 1075.0], [985.0, 1445.0], [954.0, 1445.0]], [[919.0, 1076.0], [946.0, 1076.0], [946.0, 1348.0], [919.0, 1348.0]], [[883.0, 1076.0], [910.0, 1076.0], [910.0, 1412.0], [883.0, 1412.0]], [[851.0, 1076.0], [877.0, 1076.0], [877.0, 1301.0], [851.0, 1301.0]]], "lines": ["今の私の絵と長野原大介先生とで", "絵の勝負をしませんか？", "〈さりげに、付けるであろうＰＮを", "ふっ込んでみました。"]}], "img_path": "156.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [891, 153, 1026, 446], "vertical": true, "font_size": 25, "lines_coords": [[[993.0, 153.0], [1019.0, 153.0], [1019.0, 410.0], [993.0, 410.0]], [[958.0, 154.0], [982.0, 154.0], [983.0, 312.0], [960.0, 312.0]], [[927.0, 156.0], [949.0, 156.0], [949.0, 442.0], [927.0, 442.0]], [[891.0, 153.0], [918.0, 153.0], [918.0, 257.0], [891.0, 257.0]]], "lines": ["培った技術をぶっ込んで、", "完膚なきまでに", "叩きのめしちゃってくれると", "幸いです。"]}, {"box": [482, 142, 540, 353], "vertical": true, "font_size": 24, "lines_coords": [[[513.0, 142.0], [540.0, 142.0], [540.0, 353.0], [513.0, 353.0]], [[482.0, 143.0], [504.0, 143.0], [504.0, 339.0], [482.0, 339.0]]], "lines": ["それではこれからも", "お体に気をつけて。"]}, {"box": [133, 135, 240, 373], "vertical": true, "font_size": 29, "lines_coords": [[[199.0, 135.0], [232.0, 135.0], [232.0, 314.0], [199.0, 314.0]], [[168.0, 139.0], [195.0, 139.0], [195.0, 314.0], [168.0, 314.0]], [[134.0, 139.0], [160.0, 139.0], [160.0, 373.0], [134.0, 373.0]]], "lines": ["えんぴつと紙と", "私の現在の絵を", "ぶっ込んでおきます。"]}, {"box": [388, 584, 457, 675], "vertical": true, "font_size": 56, "lines_coords": [[[388.0, 587.0], [443.0, 584.0], [448.0, 673.0], [391.0, 675.0]]], "lines": ["追伸"]}, {"box": [939, 1053, 1001, 1240], "vertical": true, "font_size": 22, "lines_coords": [[[971.0, 1056.0], [993.0, 1056.0], [993.0, 1239.0], [971.0, 1239.0]], [[941.0, 1056.0], [963.0, 1056.0], [963.0, 1207.0], [941.0, 1207.0]]], "lines": ["なんか書いときたい", "んだけどな．．．"]}, {"box": [543, 885, 588, 1015], "vertical": true, "font_size": 41, "lines_coords": [[[543.0, 887.0], [584.0, 885.0], [588.0, 1014.0], [548.0, 1015.0]]], "lines": ["相生祐子"]}, {"box": [529, 1035, 597, 1255], "vertical": true, "font_size": 68, "lines_coords": [[[529.0, 1035.0], [597.0, 1035.0], [597.0, 1255.0], [529.0, 1255.0]]], "lines": ["それでは"]}, {"box": [174, 1044, 251, 1404], "vertical": true, "font_size": 71, "lines_coords": [[[181.0, 1060.0], [251.0, 1062.0], [245.0, 1393.0], [174.0, 1392.0]]], "lines": ["さようなら！"]}], "img_path": "157.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [], "img_path": "158.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [986, 115, 1019, 270], "vertical": true, "font_size": 33, "lines_coords": [[[986.0, 115.0], [1019.0, 115.0], [1019.0, 270.0], [986.0, 270.0]]], "lines": ["い売却有"]}, {"box": [817, 400, 845, 440], "vertical": true, "font_size": 28, "lines_coords": [[[817.0, 400.0], [845.0, 400.0], [845.0, 440.0], [817.0, 440.0]]], "lines": ["¥"]}, {"box": [868, 689, 965, 764], "vertical": true, "font_size": 35, "lines_coords": [[[910.0, 692.0], [961.0, 689.0], [965.0, 760.0], [913.0, 764.0]], [[899.0, 695.0], [922.0, 695.0], [922.0, 757.0], [899.0, 757.0]], [[880.0, 693.0], [910.0, 693.0], [910.0, 750.0], [880.0, 750.0]]], "lines": ["ゆっこみあちゃん", "なのちゃん", "はかせ"]}, {"box": [718, 1056, 788, 1195], "vertical": true, "font_size": 22, "lines_coords": [[[768.0, 1059.0], [787.0, 1059.0], [787.0, 1179.0], [768.0, 1179.0]], [[743.0, 1056.0], [765.0, 1056.0], [763.0, 1193.0], [741.0, 1193.0]], [[719.0, 1056.0], [743.0, 1056.0], [743.0, 1129.0], [719.0, 1129.0]]], "lines": ["「さようなら」で", "ってのは、おかしい", "よなぁ．．．"]}, {"box": [552, 1078, 632, 1304], "vertical": true, "font_size": 80, "lines_coords": [[[552.0, 1078.0], [632.0, 1078.0], [632.0, 1304.0], [552.0, 1304.0]]], "lines": ["それでは"]}, {"box": [965, 1184, 1007, 1242], "vertical": true, "font_size": 36, "lines_coords": [[[965.0, 1189.0], [1000.0, 1184.0], [1007.0, 1237.0], [971.0, 1242.0]]], "lines": ["本日生"]}, {"box": [718, 1276, 822, 1441], "vertical": true, "font_size": 25, "lines_coords": [[[794.0, 1278.0], [822.0, 1278.0], [822.0, 1356.0], [794.0, 1356.0]], [[771.0, 1281.0], [793.0, 1281.0], [793.0, 1440.0], [771.0, 1440.0]], [[741.0, 1278.0], [768.0, 1278.0], [768.0, 1404.0], [741.0, 1404.0]], [[718.0, 1276.0], [740.0, 1276.0], [740.0, 1406.0], [718.0, 1406.0]]], "lines": ["えーっと", "「お元気」でってのも", "違うか．．．ん！", "えーっと．．．あ！"]}, {"box": [173, 1079, 321, 1400], "vertical": true, "font_size": 70, "lines_coords": [[[254.0, 1082.0], [321.0, 1084.0], [316.0, 1350.0], [249.0, 1348.0]], [[173.0, 1084.0], [245.0, 1084.0], [245.0, 1360.0], [173.0, 1360.0]]], "lines": ["またお会い", "しましょう"]}], "img_path": "159.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [475, 150, 599, 264], "vertical": true, "font_size": 34, "lines_coords": [[[551.0, 150.0], [590.0, 150.0], [590.0, 240.0], [551.0, 240.0]], [[515.0, 151.0], [549.0, 153.0], [543.0, 264.0], [509.0, 262.0]], [[476.0, 154.0], [504.0, 154.0], [504.0, 259.0], [476.0, 259.0]]], "lines": ["今の私", "一年Ｑ組", "東雲なの"]}, {"box": [799, 315, 854, 551], "vertical": true, "font_size": 55, "lines_coords": [[[799.0, 317.0], [854.0, 317.0], [854.0, 551.0], [799.0, 551.0]]], "lines": ["東雲なの"]}, {"box": [559, 602, 704, 831], "vertical": true, "font_size": 26, "lines_coords": [[[666.0, 603.0], [693.0, 603.0], [693.0, 806.0], [666.0, 806.0]], [[632.0, 609.0], [658.0, 609.0], [658.0, 806.0], [632.0, 806.0]], [[594.0, 604.0], [621.0, 604.0], [621.0, 831.0], [594.0, 831.0]], [[560.0, 609.0], [582.0, 609.0], [582.0, 740.0], [560.0, 740.0]]], "lines": ["私はロボットです", "一緒に住んでいる", "はかせが私を造って", "くれました。"]}, {"box": [104, 593, 202, 821], "vertical": true, "font_size": 22, "lines_coords": [[[170.0, 593.0], [193.0, 593.0], [195.0, 771.0], [171.0, 771.0]], [[138.0, 596.0], [160.0, 596.0], [160.0, 817.0], [138.0, 817.0]], [[104.0, 595.0], [126.0, 595.0], [126.0, 815.0], [104.0, 815.0]]], "lines": ["はかせは何らかの", "研究をしているらしく", "「日中家にいます。"]}, {"box": [738, 1015, 814, 1262], "vertical": true, "font_size": 32, "lines_coords": [[[779.0, 1015.0], [812.0, 1015.0], [812.0, 1221.0], [779.0, 1221.0]], [[743.0, 1017.0], [774.0, 1017.0], [774.0, 1259.0], [743.0, 1259.0]]], "lines": ["そんなはかせの", "お手伝いをしながら"]}, {"box": [100, 1006, 336, 1453], "vertical": true, "font_size": 25, "lines_coords": [[[296.0, 1006.0], [324.0, 1006.0], [326.0, 1346.0], [298.0, 1346.0]], [[265.0, 1007.0], [292.0, 1007.0], [292.0, 1451.0], [265.0, 1451.0]], [[234.0, 1009.0], [256.0, 1009.0], [256.0, 1428.0], [234.0, 1428.0]], [[201.0, 1009.0], [223.0, 1009.0], [223.0, 1378.0], [201.0, 1378.0]], [[165.0, 1007.0], [192.0, 1007.0], [192.0, 1290.0], [165.0, 1290.0]], [[132.0, 1007.0], [159.0, 1007.0], [159.0, 1321.0], [132.0, 1321.0]], [[101.0, 1010.0], [123.0, 1010.0], [123.0, 1243.0], [101.0, 1243.0]]], "lines": ["学校へ行ったり、友達と遊んだり、", "阪本さんに怒られたり、はかせを注意したり、", "ビスケット２号にビスケットを買ったり、", "本を読んだり、落書きされたダルマに", "顔を掛けていたり、えーっと", "とにかく書ききれないくらいの", "日々を過ごしています。"]}], "img_path": "160.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [869, 121, 1030, 297], "vertical": true, "font_size": 28, "lines_coords": [[[1000.0, 121.0], [1030.0, 121.0], [1030.0, 193.0], [1000.0, 193.0]], [[966.0, 121.0], [994.0, 121.0], [997.0, 257.0], [969.0, 257.0]], [[935.0, 123.0], [961.0, 123.0], [961.0, 293.0], [935.0, 293.0]], [[902.0, 121.0], [930.0, 121.0], [930.0, 259.0], [902.0, 259.0]], [[869.0, 121.0], [896.0, 121.0], [896.0, 246.0], [869.0, 246.0]]], "lines": ["だから", "こんな楽しい", "日々が変わらずー", "続いていると", "嬉しいです。"]}, {"box": [147, 142, 217, 323], "vertical": true, "font_size": 25, "lines_coords": [[[182.0, 142.0], [210.0, 142.0], [213.0, 298.0], [185.0, 298.0]], [[148.0, 145.0], [170.0, 145.0], [170.0, 321.0], [148.0, 321.0]]], "lines": ["まだ入れても", "いないのですが"]}, {"box": [599, 456, 667, 550], "vertical": true, "font_size": 58, "lines_coords": [[[607.0, 456.0], [665.0, 460.0], [657.0, 546.0], [599.0, 542.0]]], "lines": ["追伸"]}, {"box": [553, 657, 632, 1009], "vertical": true, "font_size": 26, "lines_coords": [[[593.0, 660.0], [619.0, 660.0], [619.0, 1009.0], [593.0, 1009.0]], [[554.0, 660.0], [580.0, 660.0], [580.0, 798.0], [554.0, 798.0]]], "lines": ["今から皆でタイムカフセルを", "開ける事が、"]}, {"box": [151, 681, 200, 981], "vertical": true, "font_size": 37, "lines_coords": [[[151.0, 681.0], [188.0, 681.0], [188.0, 981.0], [151.0, 981.0]]], "lines": ["とても楽しみです！"]}], "img_path": "161.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [941, 140, 969, 325], "vertical": true, "font_size": 27, "lines_coords": [[[941.0, 142.0], [968.0, 142.0], [968.0, 231.0], [941.0, 231.0]]], "lines": ["そして"]}, {"box": [396, 618, 440, 743], "vertical": true, "font_size": 44, "lines_coords": [[[396.0, 618.0], [440.0, 618.0], [440.0, 743.0], [396.0, 743.0]]], "lines": ["だめだ"]}, {"box": [796, 932, 942, 1156], "vertical": true, "font_size": 73, "lines_coords": [[[860.0, 934.0], [933.0, 932.0], [940.0, 1153.0], [866.0, 1154.0]], [[796.0, 935.0], [869.0, 935.0], [869.0, 1156.0], [796.0, 1156.0]]], "lines": ["根が引っ", "絡まって"]}, {"box": [103, 954, 264, 1237], "vertical": true, "font_size": 84, "lines_coords": [[[182.0, 960.0], [256.0, 960.0], [256.0, 1131.0], [182.0, 1131.0]], [[103.0, 954.0], [196.0, 954.0], [196.0, 1237.0], [103.0, 1237.0]]], "lines": ["完全に", "取れねぇ！！！"]}, {"box": [106, 1509, 359, 1540], "vertical": false, "font_size": 31, "lines_coords": [[[106.0, 1509.0], [359.0, 1509.0], [359.0, 1540.0], [106.0, 1540.0]]], "lines": ["日常の１９２（おわり）"]}], "img_path": "162.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [529, 139, 553, 309], "vertical": true, "font_size": 22, "lines_coords": [[[529.0, 139.0], [551.0, 139.0], [551.0, 309.0], [529.0, 309.0]]], "lines": ["さいしょはグー"]}, {"box": [140, 139, 165, 312], "vertical": true, "font_size": 22, "lines_coords": [[[140.0, 139.0], [162.0, 139.0], [162.0, 279.0], [140.0, 279.0]]], "lines": ["じゃんけんー"]}, {"box": [498, 498, 538, 603], "vertical": true, "font_size": 40, "lines_coords": [[[498.0, 498.0], [538.0, 498.0], [538.0, 603.0], [498.0, 603.0]]], "lines": ["ポン！"]}, {"box": [504, 831, 529, 986], "vertical": true, "font_size": 24, "lines_coords": [[[504.0, 831.0], [527.0, 831.0], [529.0, 985.0], [505.0, 985.0]]], "lines": ["あいこでしょ！"]}, {"box": [498, 1200, 532, 1298], "vertical": true, "font_size": 34, "lines_coords": [[[498.0, 1200.0], [532.0, 1200.0], [532.0, 1298.0], [498.0, 1298.0]]], "lines": ["しょ！"]}], "img_path": "163.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [946, 135, 980, 234], "vertical": true, "font_size": 34, "lines_coords": [[[946.0, 135.0], [980.0, 135.0], [980.0, 234.0], [946.0, 234.0]]], "lines": ["しょ！"]}, {"box": [143, 153, 188, 226], "vertical": true, "font_size": 42, "lines_coords": [[[143.0, 154.0], [185.0, 153.0], [188.0, 225.0], [146.0, 226.0]]], "lines": ["しょ"]}, {"box": [938, 498, 977, 600], "vertical": true, "font_size": 39, "lines_coords": [[[938.0, 498.0]