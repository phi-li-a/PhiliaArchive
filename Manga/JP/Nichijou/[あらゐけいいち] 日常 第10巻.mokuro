]], "lines": ["テストの点数が", "悪いからこその", "私である！"]}, {"box": [601, 1303, 666, 1478], "vertical": true, "font_size": 28, "lines_coords": [[[632.0, 1303.0], [666.0, 1303.0], [666.0, 1382.0], [632.0, 1382.0]], [[602.0, 1304.0], [624.0, 1304.0], [624.0, 1478.0], [602.0, 1478.0]]], "lines": ["バカの", "肯定じゃねーか"]}, {"box": [473, 1184, 556, 1334], "vertical": true, "font_size": 42, "lines_coords": [[[499.0, 1184.0], [555.0, 1184.0], [555.0, 1260.0], [499.0, 1260.0]], [[473.0, 1193.0], [501.0, 1193.0], [502.0, 1332.0], [474.0, 1332.0]]], "lines": ["愛はどうとう", "平等である"]}, {"box": [112, 1323, 187, 1465], "vertical": true, "font_size": 27, "lines_coords": [[[151.0, 1325.0], [178.0, 1325.0], [178.0, 1443.0], [151.0, 1443.0]], [[115.0, 1323.0], [142.0, 1323.0], [138.0, 1465.0], [112.0, 1465.0]]], "lines": ["人それぞれ", "じゃねーか？"]}], "img_path": "073.jpg"}, {"version": "0.1.6", "img_width": 1129, "img_height": 1600, "blocks": [{"box": [932, 145, 999, 290], "vertical": true, "font_size": 26, "lines_coords": [[[963.0, 145.0], [993.0, 145.0], [993.0, 220.0], [963.0, 220.0]], [[933.0, 148.0], [954.0, 148.0], [954.0, 289.0], [933.0, 289.0]]], "lines": ["少しは", "悟らせてよ～"]}, {"box": [727, 46, 833, 86], "vertical": false, "font_size": 33, "lines_coords": [[[732.0, 51.0], [824.0, 51.0], [824.0, 84.0], [732.0, 84.0]]], "lines": ["とは。"]}, {"box": [593, 148, 623, 290], "vertical": true, "font_size": 22, "lines_coords": [[[593.0, 150.0], [615.0, 150.0], [615.0, 290.0], [593.0, 290.0]]], "lines": ["あたしゃ釈迦か"]}, {"box": [404, 123, 523, 329], "vertical": true, "font_size": 24, "lines_coords": [[[491.0, 123.0], [518.0, 123.0], [518.0, 329.0], [491.0, 329.0]], [[462.0, 125.0], [488.0, 125.0], [488.0, 292.0], [462.0, 292.0]], [[434.0, 126.0], [454.0, 126.0], [454.0, 265.0], [434.0, 265.0]], [[404.0, 126.0], [426.0, 126.0], [426.0, 209.0], [404.0, 209.0]]], "lines": ["それなりに人としての", "年輪かさねないと", "悟った感出ない", "のかもな"]}, {"box": [169, 20, 441, 96], "vertical": false, "font_size": 31, "lines_coords": [[[176.0, 42.0], [366.0, 20