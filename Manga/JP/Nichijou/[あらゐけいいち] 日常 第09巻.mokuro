.1.6", "img_width": 847, "img_height": 1200, "blocks": [{"box": [583, 180, 596, 230], "vertical": true, "font_size": 13, "lines_coords": [[[583.0, 180.0], [596.0, 180.0], [596.0, 230.0], [583.0, 230.0]]], "lines": ["うー"]}, {"box": [358, 101, 402, 263], "vertical": true, "font_size": 17, "lines_coords": [[[381.0, 103.0], [398.0, 103.0], [398.0, 220.0], [381.0, 220.0]], [[360.0, 101.0], [377.0, 101.0], [374.0, 263.0], [358.0, 263.0]]], "lines": ["みおちゃんの為を", "思って言ったんじゃん！！！"]}, {"box": [86, 43, 206, 65], "vertical": false, "font_size": 21, "lines_coords": [[[86.0, 44.0], [206.0, 43.0], [206.0, 64.0], [86.0, 65.0]]], "lines": ["日常の１４６"]}, {"box": [77, 111, 145, 261], "vertical": true, "font_size": 18, "lines_coords": [[[121.0, 111.0], [138.0, 111.0], [138.0, 230.0], [121.0, 230.0]], [[100.0, 112.0], [117.0, 112.0], [117.0, 201.0], [100.0, 201.0]], [[77.0, 111.0], [97.0, 111.0], [97.0, 261.0], [77.0, 261.0]]], "lines": ["私の為を思うなら", "ビックリ宣言", "するなっつってんの！！"]}, {"box": [575, 438, 597, 489], "vertical": true, "font_size": 22, "lines_coords": [[[575.0, 438.0], [597.0, 438.0], [597.0, 489.0], [575.0, 489.0]]], "lines": ["ゴじへ"]}, {"box": [313, 366, 402, 501], "vertical": true, "font_size": 18, "lines_coords": [[[380.0, 366.0], [400.0, 366.0], [398.0, 460.0], [378.0, 460.0]], [[359.0, 369.0], [376.0, 369.0], [376.0, 501.0], [359.0, 501.0]], [[337.0, 367.0], [354.0, 367.0], [352.0, 472.0], [335.0, 472.0]], [[316.0, 367.0], [333.0, 367.0], [331.0, 457.0], [313.0, 457.0]]], "lines": ["じゃー今から", "私がビックリさせて", "ヒックリしたら", "どーすんの！？"]}, {"box": [716, 624, 763, 739], "vertical": true, "font_size": 16, "lines_coords": [[[740.0, 624.0], [756.0, 624.0], [756.0, 739.0], [740.0, 739.0]], [[716.0, 625.0], [732.0, 625.0], [732.0, 739.0], [716.0, 739.0]]], "lines": ["全然しゃっくり", "止まりませんね"]}, {"box": [529, 622, 653, 694], "vertical": true, "font_size": 19, "lines_coords": [[[632.0, 622.0], [653.0, 622.0], [653.0, 669.0], [632.0, 669.0]], [[612.0, 623.0], [629.0, 623.0], [629.0, 693.0], [612.0, 693.0]]