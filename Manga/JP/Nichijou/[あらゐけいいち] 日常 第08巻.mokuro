04.0]], [[194.0, 384.0], [211.0, 384.0], [211.0, 622.0], [194.0, 622.0]]], "lines": ["今回は", "着ぐるみの内側に", "ケブラー＆アラミド繊維を", "織り込みさらには", "セラミックプレートで防護している"]}, {"box": [61, 380, 147, 534], "vertical": true, "font_size": 18, "lines_coords": [[[125.0, 382.0], [147.0, 382.0], [147.0, 432.0], [125.0, 432.0]], [[104.0, 380.0], [124.0, 380.0], [123.0, 534.0], [103.0, 534.0]], [[83.0, 383.0], [100.0, 383.0], [99.0, 517.0], [82.0, 517.0]], [[61.0, 383.0], [75.0, 383.0], [77.0, 503.0], [63.0, 503.0]]], "lines": ["これで", "ダルマやホムンクルス", "又は偵察ロボからの", "攻撃に対応出来る"]}, {"box": [65, 686, 178, 841], "vertical": true, "font_size": 19, "lines_coords": [[[154.0, 686.0], [174.0, 686.0], [172.0, 813.0], [152.0, 813.0]], [[130.0, 687.0], [150.0, 687.0], [152.0, 796.0], [132.0, 796.0]], [[110.0, 686.0], [131.0, 686.0], [129.0, 769.0], [108.0, 769.0]], [[88.0, 686.0], [106.0, 686.0], [104.0, 841.0], [86.0, 841.0]], [[65.0, 687.0], [82.0, 687.0], [82.0, 840.0], [65.0, 840.0]]], "lines": ["あとは東雲なのの", "純粋さを利用し", "今日こそは", "どこかにあるであろう", "設計図を奪ってやる！！"]}, {"box": [589, 688, 636, 849], "vertical": true, "font_size": 18, "lines_coords": [[[611.0, 689.0], [631.0, 689.0], [631.0, 849.0], [611.0, 849.0]], [[590.0, 689.0], [607.0, 689.0], [607.0, 796.0], [590.0, 796.0]]], "lines": ["前回不覚にもやられた", "粘着トラップも"]}, {"box": [359, 688, 424, 856], "vertical": true, "font_size": 16, "lines_coords": [[[404.0, 689.0], [421.0, 689.0], [421.0, 781.0], [404.0, 781.0]], [[381.0, 690.0], [398.0, 690.0], [398.0, 856.0], [381.0, 856.0]], [[360.0, 689.0], [375.0, 689.0], [374.0, 846.0], [359.0, 846.0]]], "lines": ["これを脱いで", "逃げられる様にしてある", "くくく、抜かりはない！！"]}, {"box": [283, 687, 331, 856], "vertical": true, "font_size": 18, "lines_coords": [[[305.0, 687.0], [325.0, 687.0], [325.0, 856.0], [305.0, 856.0]], [[284.0, 688.0], [301.0, 688.0], [301.0, 824.0], [284.0, 824.0]]], "lines": ["子供はお菓子をあげれば", "大人しくなるだろう"]}], "img_path": "042.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [609, 60, 645, 150], "vert