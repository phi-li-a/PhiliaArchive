88.0, 449.0]], [[566.0, 299.0], [583.0, 299.0], [583.0, 492.0], [566.0, 492.0]], [[547.0, 298.0], [564.0, 298.0], [568.0, 479.0], [551.0, 479.0]]], "lines": ["先程のみずちょんの部が", "音の壁を超え破綻！", "一同に欧系張が走る！", "「この場合、たんは大人なの！？」", "たまらず成果内を投げる！！"]}, {"box": [389, 367, 403, 418], "vertical": true, "font_size": 14, "lines_coords": [[[389.0, 367.0], [403.0, 367.0], [403.0, 418.0], [389.0, 418.0]]], "lines": ["．．．ファン．．．"]}, {"box": [238, 293, 336, 500], "vertical": true, "font_size": 22, "lines_coords": [[[315.0, 294.0], [335.0, 294.0], [335.0, 489.0], [315.0, 489.0]], [[293.0, 293.0], [314.0, 293.0], [312.0, 495.0], [291.0, 495.0]], [[275.0, 295.0], [295.0, 295.0], [292.0, 486.0], [272.0, 486.0]], [[258.0, 295.0], [278.0, 295.0], [274.0, 500.0], [254.0, 500.0]], [[238.0, 294.0], [265.0, 294.0], [265.0, 337.0], [238.0, 337.0]]], "lines": ["今日の首端の一件を見て、", "もしかしたら「個性を消す", "お手が大人になるる事なの", "かもしれないしなんて思った", "けど、"]}, {"box": [61, 294, 127, 406], "vertical": true, "font_size": 20, "lines_coords": [[[101.0, 294.0], [127.0, 294.0], [127.0, 341.0], [101.0, 341.0]], [[83.0, 299.0], [101.0, 299.0], [103.0, 398.0], [85.0, 398.0]], [[61.0, 298.0], [78.0, 298.0], [81.0, 406.0], [64.0, 406.0]]], "lines": ["実際", "いろんな大人", "いるしなぁ．．．"]}, {"box": [621, 521, 643, 725], "vertical": true, "font_size": 20, "lines_coords": [[[623.0, 524.0], [643.0, 524.0], [641.0, 722.0], [621.0, 722.0]]], "lines": ["老えあぐおるみおぢん！"]}, {"box": [489, 609, 502, 658], "vertical": true, "font_size": 13, "lines_coords": [[[489.0, 609.0], [502.0, 609.0], [502.0, 658.0], [489.0, 658.0]]], "lines": ["．．．ファンディ"]}, {"box": [377, 539, 467, 715], "vertical": true, "font_size": 20, "lines_coords": [[[443.0, 540.0], [464.0, 540.0], [467.0, 706.0], [446.0, 706.0]], [[414.0, 539.0], [434.0, 539.0], [439.0, 715.0], [419.0, 715.0]], [[377.0, 540.0], [397.0, 540.0], [400.0, 701.0], [380.0, 701.0]]], "lines": ["凍りつく場の内容に！", "そこに一前の雨の光が", "穴手を列衣いた！！！"]}, {"box": [252, 523, 337, 662], "vertical": true, "font_size": 19, "lines_coords": [[[316.0, 526.0], [337.0, 526.0], [337.0, 610.0], [316.0, 610.0]], [[295.0, 526.0], [313.0, 526.0], [314.0, 662.0], [296.0, 662.0]], [[272.0, 525.0], [293.0, 525.0], [293.0, 660.0], [272.0, 660.0]], [[252.0, 523.0], [269.0, 523.0], [269.0, 662.0], [252.0, 662.0]]], "lines": ["ひょっとして、", "大人とか子供とか", "別に分ける必要", "ないんじゃないか？"]}, {"box": [59, 524, 131, 678], "vertical": true, "font_size": 23, "lines_coords": [[[108.0, 524.0], [128.0, 524.0], [131.0, 670.0], [111.0, 670.0]], [[76.0, 524.0], [108.0, 524.0], [106.0, 678.0], [74.0, 678.0]], [[59.0, 527.0], [76.0, 527.0], [76.0, 671.0], [59.0, 671.0]]], "lines": ["全人類間をとって", "「大快」にしちゃえば", "いいんじゃないか？"]}, {"box": [614, 787, 632, 844], "vertical": true, "font_size": 18, "lines_coords": [[[614.0, 787.0], [632.0, 787.0], [632.0, 844.0], [614.0, 844.0]]], "lines": ["これは"]}, {"box": [378, 786, 430, 853], "vertical": true, "font_size": 46, "lines_coords": [[[378.0, 791.0], [424.0, 786.0], [430.0, 848.0], [384.0, 853.0]]], "lines": ["個性"]}, {"box": [191, 749, 341, 954], "vertical": true, "font_size": 18, "lines_coords": [[[318.0, 751.0], [338.0, 751.0], [333.0, 954.0], [313.0, 954.0]], [[303.0, 753.0], [320.0, 753.0], [315.0, 945.0], [298.0, 945.0]], [[287.0, 751.0], [304.0, 751.0], [301.0, 924.0], [284.0, 924.0]], [[266.0, 749.0], [286.0, 749.0], [280.0, 939.0], [260.0, 939.0]], [[246.0, 750.0], [264.0, 750.0], [258.0, 951.0], [240.0, 951.0]], [[226.0, 751.0], [243.0, 751.0], [241.0, 906.0], [224.0, 906.0]], [[208.0, 751.0], [225.0, 751.0], [225.0, 914.0], [208.0, 914.0]], [[191.0, 751.0], [208.0, 751.0], [208.0, 841.0], [191.0, 841.0]]], "lines": ["「大体」より「大子」の方が理にかな。", "ているか．．．いや、それなら中に", "したみがいいかもしれない！！", "ああっそうなると、全人類は自", "「大人と子供の城国になるのか？」", "ん？んん？？まずい．．．", "このまま行くと、今日、私、", "「寝かれなくな"]}, {"box": [58, 969, 226, 989], "vertical": false, "font_size": 20, "lines_coords": [[[58.0, 969.0], [226.0, 969.0], [226.0, 989.0], [58.0, 989.0]]], "lines": ["日常の１４５（おわり）"]}], "img_path": "164.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [], "img_path": "165.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [66, 642, 209, 685], "vertical": false, "font_size": 19, "lines_coords": [[[66.0, 642.0], [209.0, 643.0], [209.0, 660.0], [66.0, 659.0]], [[66.0, 663.0], [127.0, 663.0], [127.0, 685.0], [66.0, 685.0]]], "lines": ["角川コミックス・エース", "日常（８）"]}, {"box": [62, 714, 226, 732], "vertical": false, "font_size": 19, "lines_coords": [[[62.0, 714.0], [226.0, 715.0], [226.0, 732.0], [62.0, 731.0]]], "lines": ["著者：あらゐけいいち"]}, {"box": [64, 791, 230, 880], "vertical": false, "font_size": 14.75, "lines_coords": [[[65.0, 791.0], [217.0, 791.0], [217.0, 805.0], [65.0, 805.0]], [[64.0, 813.0], [164.0, 813.0], [164.0, 830.0], [64.0, 830.0]], [[65.0, 838.0], [230.0, 837.0], [230.0, 852.0], [65.0, 853.0]], [[65.0, 867.0], [179.0, 867.0], [179.0, 880.0], [65.0, 880.0]]], "lines": ["発行日、２０１２年１０月２６", "発行者：新名新", "発行所・株式会社角川書店", "＠Ｋｅｉｃｈｉ，ＡＲＡＷＩ２０１２"]}, {"box": [66, 902, 315, 948], "vertical": false, "font_size": 12.333333333333334, "lines_coords": [[[66.0, 902.0], [183.0, 902.0], [183.0, 915.0], [66.0, 915.0]], [[66.0, 919.0], [117.0, 919.0], [117.0, 930.0], [66.0, 930.0]], [[66.0, 935.0], [315.0, 935.0], [315.0, 948.0], [66.0, 948.0]]], "lines": ["角川コミックス・エース", "『日常（８）』", "（２０１２年１０月２６日初版発行）に基づき制作"]}], "img_path": "166.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [185, 361, 554, 512], "vertical": false, "font_size": 162, "lines_coords": [[[198.0, 350.0], [545.0, 347.0], [546.0, 523.0], [199.0, 526.0]]], "lines": ["．．．"]}, {"box": [103, 552, 281, 620], "vertical": false, "font_size": 68, "lines_coords": [[[112.0, 548.0], [281.0, 548.0], [281.0, 622.0], [112.0, 622.0]]], "lines": ["ＥＯＯＫ"]}, {"box": [343, 538, 624, 627], "vertical": false, "font_size": 91, "lines_coords": [[[350.0, 530.0], [624.0, 537.0], [622.0, 635.0], [348.0, 629.0]]], "lines": ["ＷＡＬＫＥＲ"]}], "img_path": "167.jpg"}]}