5.0], [417.0, 685.0]], [[391.0, 547.0], [412.0, 547.0], [414.0, 686.0], [393.0, 686.0]]], "lines": ["フツーの人っぽい", "かなーって思って"]}, {"box": [292, 546, 354, 705], "vertical": true, "font_size": 17, "lines_coords": [[[330.0, 546.0], [354.0, 546.0], [354.0, 582.0], [330.0, 582.0]], [[314.0, 549.0], [328.0, 549.0], [328.0, 691.0], [314.0, 691.0]], [[292.0, 549.0], [306.0, 549.0], [306.0, 705.0], [292.0, 705.0]]], "lines": ["本は", "文字がいっぱいあると", "ねむくなっちゃいますね"]}, {"box": [88, 546, 124, 633], "vertical": true, "font_size": 14, "lines_coords": [[[108.0, 546.0], [123.0, 546.0], [124.0, 632.0], [109.0, 632.0]], [[88.0, 547.0], [102.0, 547.0], [102.0, 632.0], [88.0, 632.0]]], "lines": ["それちょっと", "フツーだけど"]}], "img_path": "163.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [604, 96, 635, 255], "vertical": true, "font_size": 28, "lines_coords": [[[607.0, 185.0], [632.0, 185.0], [632.0, 255.0], [607.0, 255.0]], [[604.0, 98.0], [635.0, 98.0], [635.0, 134.0], [604.0, 134.0]]], "lines": ["ーっ！！！", "わー"]}, {"box": [385, 94, 435, 255], "vertical": true, "font_size": 20, "lines_coords": [[[409.0, 94.0], [433.0, 94.0], [435.0, 255.0], [411.0, 255.0]], [[386.0, 96.0], [403.0, 96.0], [403.0, 170.0], [386.0, 170.0]]], "lines": ["わっ！！なんですか", "はかせ！！！"]}, {"box": [298, 91, 315, 171], "vertical": true, "font_size": 17, "lines_coords": [[[298.0, 91.0], [315.0, 91.0], [315.0, 171.0], [298.0, 171.0]]], "lines": ["そうだった"]}, {"box": [174, 86, 209, 190], "vertical": true, "font_size": 14, "lines_coords": [[[194.0, 86.0], [209.0, 86.0], [208.0, 190.0], [193.0, 190.0]], [[175.0, 86.0], [189.0, 86.0], [188.0, 165.0], [174.0, 165.0]]], "lines": ["ちょっとまちがえ", "ちゃったかも"]}, {"box": [67, 84, 128, 200], "vertical": true, "font_size": 17, "lines_coords": [[[106.0, 84.0], [128.0, 84.0], [128.0, 132.0], [106.0, 132.0]], [[89.0, 86.0], [103.0, 86.0], [103.0, 199.0], [89.0, 199.0]], [[67.0, 85.0], [81.0, 85.0], [81.0, 198.0], [67.0, 198.0]]], "lines": ["べつに", "間違えてはないと", "思いますけど．．．"]}, {