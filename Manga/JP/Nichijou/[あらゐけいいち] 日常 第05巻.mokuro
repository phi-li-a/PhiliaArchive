 {"box": [77, 95, 165, 245], "vertical": true, "font_size": 14, "lines_coords": [[[152.0, 96.0], [165.0, 96.0], [165.0, 186.0], [152.0, 186.0]], [[132.0, 97.0], [146.0, 97.0], [146.0, 221.0], [132.0, 221.0]], [[114.0, 96.0], [128.0, 96.0], [128.0, 245.0], [114.0, 245.0]], [[95.0, 97.0], [109.0, 97.0], [109.0, 161.0], [95.0, 161.0]], [[77.0, 97.0], [91.0, 97.0], [91.0, 185.0], [77.0, 185.0]]], "lines": ["そこでこれだ！！", "酸化促進力を倍増させ", "なおかつ保険でしびれ薬を", "配合させた", "酸化君ブラス！！！"]}, {"box": [599, 364, 644, 438], "vertical": true, "font_size": 15, "lines_coords": [[[627.0, 364.0], [644.0, 364.0], [642.0, 438.0], [625.0, 438.0]], [[614.0, 366.0], [628.0, 366.0], [628.0, 422.0], [614.0, 422.0]], [[599.0, 367.0], [613.0, 367.0], [613.0, 418.0], [599.0, 418.0]]], "lines": ["別にいいですよ", "その本もう", "必要ないし"]}, {"box": [460, 445, 501, 494], "vertical": true, "font_size": 15, "lines_coords": [[[483.0, 446.0], [499.0, 445.0], [501.0, 476.0], [485.0, 477.0]], [[473.0, 446.0], [487.0, 446.0], [487.0, 494.0], [473.0, 494.0]], [[460.0, 446.0], [475.0, 446.0], [475.0, 477.0], [460.0, 477.0]]], "lines": ["はははんっ！！", "退慮するな", "って！！"]}, {"box": [291, 307, 329, 468], "vertical": true, "font_size": 16, "lines_coords": [[[309.0, 307.0], [326.0, 307.0], [326.0, 429.0], [309.0, 429.0]], [[291.0, 310.0], [305.0, 310.0], [305.0, 468.0], [291.0, 468.0]]], "lines": ["これを東雲に飲ませ", "一気に捕獲としゃれこむが"]}, {"box": [78, 310, 137, 495], "vertical": true, "font_size": 15, "lines_coords": [[[117.0, 310.0], [134.0, 310.0], [134.0, 418.0], [117.0, 418.0]], [[98.0, 310.0], [112.0, 310.0], [112.0, 417.0], [98.0, 417.0]], [[78.0, 311.0], [92.0, 311.0], [92.0, 494.0], [78.0, 494.0]]], "lines": ["フフフ捕獲したら", "どうしてやろうか", "あんなことやこんなごとや．．．"]}, {"box": [600, 574, 649, 663], "vertical": true, "font_size": 14, "lines_coords": [[[634.0, 575.0], [648.0, 575.0], [646.0, 662.0], [632.0, 662.0]], [[618.0, 575.0], [631.0, 575.0], [631.0, 663.0], [618.0, 663.0]], [[602.0, 574.0], [616.0, 574.0], [614.0, 642.0], [600.0, 642.0]]], "lines": ["途中でミキサーと