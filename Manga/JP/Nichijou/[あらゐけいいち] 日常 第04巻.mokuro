81.0], [618.0, 881.0]], [[595.0, 790.0], [612.0, 790.0], [612.0, 881.0], [595.0, 881.0]]], "lines": ["なんだコレ！！", "うごけんぞ！！"]}, {"box": [506, 761, 533, 862], "vertical": true, "font_size": 21, "lines_coords": [[[506.0, 761.0], [527.0, 761.0], [527.0, 862.0], [506.0, 862.0]]], "lines": ["私もです！！"]}, {"box": [408, 803, 436, 856], "vertical": true, "font_size": 26, "lines_coords": [[[408.0, 804.0], [434.0, 803.0], [436.0, 855.0], [410.0, 856.0]]], "lines": ["髪が．．．"]}, {"box": [174, 722, 210, 834], "vertical": true, "font_size": 31, "lines_coords": [[[174.0, 724.0], [205.0, 724.0], [205.0, 834.0], [174.0, 834.0]]], "lines": ["逃げろ！！"]}, {"box": [81, 968, 257, 989], "vertical": false, "font_size": 21, "lines_coords": [[[81.0, 968.0], [257.0, 968.0], [257.0, 989.0], [81.0, 989.0]]], "lines": ["日常の６６５（おわり）"]}], "img_path": "110.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [135, 104, 171, 240], "vertical": true, "font_size": 32, "lines_coords": [[[135.0, 105.0], [167.0, 105.0], [167.0, 240.0], [135.0, 240.0]]], "lines": ["入ってみた"]}, {"box": [602, 87, 657, 257], "vertical": true, "font_size": 21, "lines_coords": [[[629.0, 91.0], [650.0, 91.0], [650.0, 219.0], [629.0, 219.0]], [[604.0, 89.0], [625.0, 89.0], [625.0, 257.0], [604.0, 257.0]]], "lines": ["地元の喫茶店が", "リニューアルしたので"]}, {"box": [101, 340, 243, 379], "vertical": false, "font_size": 39, "lines_coords": [[[101.0, 340.0], [243.0, 340.0], [243.0, 379.0], [101.0, 379.0]]], "lines": ["日常の６７"]}, {"box": [304, 427, 354, 443], "vertical": false, "font_size": 11, "lines_coords": [[[305.0, 427.0], [354.0, 432.0], [353.0, 443.0], [304.0, 438.0]]], "lines": ["ＡＲ今度このひきとを"]}, {"box": [304, 444, 343, 457], "vertical": false, "font_size": 11, "lines_coords": [[[304.0, 444.0], [343.0, 446.0], [343.0, 457.0], [304.0, 455.0]]], "lines": ["それでＣＨＩＡＴＯ"]}, {"box": [489, 457, 500, 500], "vertical": true, "font_size": 11, "lines_coords": [[[489.0, 457.0], [500.0, 457.0], [500.0, 500.0], [489.0, 500.0]]], "lines": ["それだけどなんですか！！"]}, {"box": [622, 488, 631, 528], "vertical": true, "font_size": 9, "lines_coords": [[[622.0, 488.0], [631.0, 488.0], [631.0, 528.0], [622.0, 528.0]]], "lines": ["それですけれどわかりませ"]}, {"box": [387, 482, 421, 547], "vertical": true, "font_size": 16, "lines_coords": [[[403.0, 482.0], [421.0, 482.0], [421.0, 524.0], [403.0, 524.0]], [[387.0, 483.0], [401.0, 483.0], [401.0, 547.0], [387.0, 547.0]]], "lines": ["あのー", "ご注文は．．"]}, {"box": [109, 767, 146, 793], "vertical": false, "font_size": 19, "lines_coords": [[[109.0, 774.0], [142.0, 767.0], [146.0, 786.0], [113.0, 793.0]]], "lines": ["あ"]}, {"box": [105, 734, 332, 862], "vertical": false, "font_size": 21.0, "lines_coords": [[[179.0, 760.0], [305.0, 734.0], [308.0, 750.0], [182.0, 776.0]], [[105.0, 792.0], [328.0, 743.0], [332.0, 763.0], [109.0, 812.0]], [[113.0, 815.0], [235.0, 783.0], [242.0, 808.0], [120.0, 840.0]], [[124.0, 841.0], [199.0, 815.0], [206.0, 836.0], [131.0, 862.0]]], "lines": ["．．．うん。あんまり", "そうですね。これからもうちょっということですから", "．．．マキアロード", "・アメリカー！！"]}, {"box": [250, 770, 371, 863], "vertical": false, "font_size": 17.0, "lines_coords": [[[251.0, 786.0], [317.0, 770.0], [320.0, 784.0], [254.0, 800.0]], [[250.0, 808.0], [325.0, 783.0], [331.0, 800.0], [256.0, 825.0]], [[266.0, 827.0], [350.0, 804.0], [354.0, 821.0], [270.0, 844.0]], [[289.0, 845.0], [364.0, 818.0], [371.0, 836.0], [295.0, 863.0]]], "lines": ["．．．キロ（ムトｂｏ", "下ろん。Ｃｏｎｓｔｅ", "Ｔｗｉｔｔｅｒｖｉｎｔｏ", "．．．うん。じゃーいの"]}, {"box": [403, 734, 662, 910], "vertical": false, "font_size": 22.428571428571427, "lines_coords": [[[479.0, 759.0], [600.0, 734.0], [603.0, 751.0], [482.0, 776.0]], [[403.0, 793.0], [624.0, 744.0], [628.0, 763.0], [408.0, 813.0]], [[409.0, 815.0], [613.0, 766.0], [619.0, 791.0], [415.0, 839.0]], [[418.0, 842.0], [619.0, 781.0], [626.0, 802.0], [424.0, 863.0]], [[422.0, 861.0], [644.0, 795.0], [653.0, 822.0], [431.0, 888.0]], [[436.0, 884.0], [514.0, 864.0], [521.0, 890.0], [443.0, 910.0]], [[507.0, 870.0], [656.0, 821.0], [662.0, 837.0], [513.0, 887.0]]], "lines": ["５３０で３６０ＧＡＮＯ", "いつかの部屋の中では、「日頃からずっといっていうのですから」", "ですから、これまでは「マンション」というイメージ", "「初めて知っているのですが、", "．．．わたしのライブ会社デザインターネットについては、", "・やがっ！", "あ、『ミシャーフルト』は、"]}, {"box": [445, 894, 535, 955], "vertical": false, "font_size": 14.666666666666666, "lines_coords": [[[445.0, 917.0], [517.0, 894.0], [521.0, 908.0], [449.0, 931.0]], [[454.0, 929.0], [531.0, 905.0], [535.0, 919.0], [458.0, 943.0]], [[461.0, 942.0], [521.0, 920.0], [526.0, 933.0], [466.0, 955.0]]], "lines": ["なのだろうろうな", "．．．なんだかなー", "んーーーかやってます。"]}, {"box": [553, 866, 624, 926], "vertical": false, "font_size": 12.5, "lines_coords": [[[553.0, 884.0], [607.0, 866.0], [611.0, 879.0], [557.0, 897.0]], [[558.0, 896.0], [611.0, 878.0], [615.0, 889.0], [562.0, 907.0]], [[564.0, 906.0], [620.0, 885.0], [624.0, 896.0], [568.0, 917.0]], [[567.0, 915.0], [608.0, 899.0], [612.0, 910.0], [571.0, 926.0]]], "lines": ["まひいやだったよ", "夢はフライナン", "わかったときは、", "．．．！？"]}], "img_path": "111.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [578, 152, 594, 244], "vertical": true, "font_size": 14, "lines_coords": [[[579.0, 152.0], [593.0, 152.0], [592.0, 244.0], [578.0, 244.0]]], "lines": ["エスプレッソの"]}, {"box": [234, 158, 251, 214], "vertical": true, "font_size": 17, "lines_coords": [[[234.0, 158.0], [251.0, 158.0], [251.0, 214.0], [234.0, 214.0]]], "lines": ["ティーで"]}, {"box": [328, 502, 345, 556], "vertical": true, "font_size": 15, "lines_coords": [[[330.0, 502.0], [345.0, 502.0], [343.0, 556.0], [328.0, 556.0]]], "lines": ["えーっと"]}, {"box": [128, 553, 211, 600], "vertical": false, "font_size": 15.5, "lines_coords": [[[153.0, 553.0], [201.0, 564.0], [198.0, 579.0], [150.0, 568.0]], [[131.0, 567.0], [211.0, 584.0], [208.0, 600.0], [128.0, 583.0]]], "lines": ["すごくそんな", "このようですね"]}, {"box": [67, 556, 212, 622], "vertical": false, "font_size": 17.0, "lines_coords": [[[71.0, 569.0], [212.0, 604.0], [208.0, 622.0], [67.0, 587.0]], [[76.0, 556.0], [110.0, 558.0], [109.0, 574.0], [75.0, 5