, "font_size": 18, "lines_coords": [[[185.0, 784.0], [199.0, 784.0], [199.0, 846.0], [185.0, 846.0]], [[168.0, 784.0], [182.0, 784.0], [182.0, 890.0], [168.0, 890.0]], [[147.0, 780.0], [170.0, 780.0], [170.0, 816.0], [147.0, 816.0]], [[132.0, 783.0], [150.0, 783.0], [148.0, 869.0], [130.0, 869.0]], [[115.0, 783.0], [132.0, 783.0], [132.0, 891.0], [115.0, 891.0]], [[95.0, 781.0], [117.0, 781.0], [117.0, 827.0], [95.0, 827.0]], [[81.0, 783.0], [96.0, 783.0], [95.0, 879.0], [80.0, 879.0]]], "lines": ["これだって", "情報を持ち帰らせぬ", "よう", "一時的に記憶を", "消せる薬が入ってる", "とみて", "間違いないだろう"]}], "img_path": "023.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [567, 82, 639, 163], "vertical": true, "font_size": 20, "lines_coords": [[[613.0, 83.0], [635.0, 82.0], [637.0, 150.0], [615.0, 151.0]], [[592.0, 84.0], [610.0, 84.0], [610.0, 163.0], [592.0, 163.0]], [[567.0, 84.0], [588.0, 84.0], [588.0, 150.0], [567.0, 150.0]]], "lines": ["今だって", "この部屋の", "何処かで"]}, {"box": [394, 83, 442, 196], "vertical": true, "font_size": 16, "lines_coords": [[[417.0, 84.0], [435.0, 84.0], [435.0, 165.0], [417.0, 165.0]], [[395.0, 83.0], [409.0, 83.0], [409.0, 152.0], [395.0, 152.0]]], "lines": ["監視されて", "るんじゃ"]}, {"box": [286, 118, 346, 303], "vertical": true, "font_size": 57, "lines_coords": [[[289.0, 118.0], [346.0, 119.0], [343.0, 303.0], [286.0, 302.0]]], "lines": ["うわっ！！！"]}, {"box": [570, 409, 637, 625], "vertical": true, "font_size": 63, "lines_coords": [[[574.0, 409.0], [637.0, 410.0], [633.0, 625.0], [570.0, 624.0]]], "lines": ["なかなな"]}, {"box": [76, 423, 258, 673], "vertical": true, "font_size": 90, "lines_coords": [[[76.0, 430.0], [166.0, 425.0], [176.0, 616.0], [86.0, 621.0]]], "lines": ["あれは"]}], "img_path": "024.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [589, 84, 646, 233], "vertical": true, "font_size": 15, "lines_coords": [[[626.0, 84.0], [643.0, 84.0], [643.0, 180.0], [626.0, 180.0]], [[608.0, 85.0], [622.0, 85.0], [62