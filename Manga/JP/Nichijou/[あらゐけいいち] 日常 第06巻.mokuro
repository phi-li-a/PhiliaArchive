す。", "世界を気にしてオスケと自分を分かりやすかったのは、そのないでしょう。高級バイスによっては、大丈夫では", "ありがとう言ってもないかもしれないのですが．．．まあいいんじゃないんだよ。"]}, {"box": [588, 295, 627, 345], "vertical": false, "font_size": 21, "lines_coords": [[[588.0, 335.0], [608.0, 295.0], [627.0, 305.0], [607.0, 345.0]]], "lines": ["これは"]}, {"box": [614, 406, 652, 476], "vertical": false, "font_size": 12, "lines_coords": [[[614.0, 472.0], [641.0, 406.0], [652.0, 410.0], [625.0, 476.0]]], "lines": ["うわあああ"]}, {"box": [284, 557, 342, 749], "vertical": true, "font_size": 50, "lines_coords": [[[292.0, 560.0], [342.0, 562.0], [334.0, 749.0], [284.0, 747.0]]], "lines": ["ＹＥＳ！！"]}, {"box": [610, 691, 641, 745], "vertical": true, "font_size": 31, "lines_coords": [[[610.0, 691.0], [641.0, 691.0], [641.0, 745.0], [610.0, 745.0]]], "lines": ["これ"]}, {"box": [393, 679, 418, 889], "vertical": true, "font_size": 21, "lines_coords": [[[394.0, 682.0], [415.0, 682.0], [415.0, 889.0], [394.0, 889.0]]], "lines": ["みおちゃんじゃん！！"]}], "img_path": "038.jpg"}, {"version": "0.1.6", "img_width": 722, "img_height": 1024, "blocks": [{"box": [576, 94, 647, 228], "vertical": true, "font_size": 17, "lines_coords": [[[625.0, 96.0], [643.0, 96.0], [643.0, 162.0], [625.0, 162.0]], [[599.0, 94.0], [616.0, 94.0], [618.0, 228.0], [601.0, 228.0]], [[577.0, 95.0], [594.0, 95.0], [594.0, 195.0], [577.0, 195.0]]], "lines": ["これ前に", "私たちが手伝った", "やつじゃん！！"]}, {"box": [315, 85, 364, 258], "vertical": true, "font_size": 49, "lines_coords": [[[315.0, 85.0], [364.0, 85.0], [364.0, 258.0], [315.0, 258.0]]], "lines": ["ＹＥＳ！！"]}, {"box": [536, 415, 647, 529], "vertical": true, "font_size": 36, "lines_coords": [[[618.0, 417.0], [647.0, 418.0], [645.0, 501.0], [616.0, 500.0]], [[574.0, 415.0], [614.0, 415.0], [614.0, 529.0], [574.0, 529.0]], [[536.0, 415.0], [576.0, 415.0], [576.0, 529.0], [536.0, 529.0]]], "lines": ["うわー", "すごい！！！", "すごい！！！"]}, {"box": [108, 435, 192, 571], "vertical": true, "font_size": 38, "lines_coords": [[[163.0, 440.0], [192.0, 440.0], [192.0, 535.0], [163.0, 535.0]],