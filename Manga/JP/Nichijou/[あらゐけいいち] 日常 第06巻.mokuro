8.0], [520.0, 608.0], [506.0, 608.0]]], "lines": ["一体何が", "マズイんだ！！"]}, {"box": [401, 518, 455, 620], "vertical": true, "font_size": 15, "lines_coords": [[[437.0, 519.0], [455.0, 519.0], [455.0, 572.0], [437.0, 572.0]], [[420.0, 519.0], [434.0, 519.0], [432.0, 620.0], [418.0, 620.0]], [[402.0, 518.0], [416.0, 518.0], [415.0, 607.0], [401.0, 607.0]]], "lines": ["そうだ！！", "みんなでかかれば", "あんなやつ．．．！！"]}, {"box": [284, 530, 326, 624], "vertical": true, "font_size": 14, "lines_coords": [[[305.0, 532.0], [319.0, 532.0], [319.0, 599.0], [305.0, 599.0]], [[285.0, 530.0], [299.0, 530.0], [298.0, 624.0], [284.0, 624.0]]], "lines": ["一体も何も", "ないでゲスよ．．．"]}, {"box": [236, 702, 301, 828], "vertical": true, "font_size": 14, "lines_coords": [[[287.0, 702.0], [301.0, 702.0], [301.0, 762.0], [287.0, 762.0]], [[270.0, 702.0], [285.0, 702.0], [284.0, 797.0], [269.0, 797.0]], [[253.0, 703.0], [267.0, 703.0], [267.0, 828.0], [253.0, 828.0]], [[236.0, 703.0], [250.0, 703.0], [250.0, 785.0], [236.0, 785.0]]], "lines": ["．．．しかし！！", "揃った所でやつが", "古代兵器の呼び出し方を", "知らなければ！！"]}, {"box": [75, 515, 135, 628], "vertical": true, "font_size": 14, "lines_coords": [[[121.0, 516.0], [135.0, 516.0], [135.0, 584.0], [121.0, 584.0]], [[103.0, 515.0], [118.0, 515.0], [121.0, 608.0], [106.0, 608.0]], [[89.0, 515.0], [103.0, 515.0], [105.0, 608.0], [91.0, 608.0]], [[75.0, 515.0], [89.0, 515.0], [90.0, 628.0], [76.0, 628.0]]], "lines": ["先程キャツが", "くくりつけたＷＣ．．．", "それともう一つ別に", "すでに耳元に付いていた"]}, {"box": [174, 709, 208, 813], "vertical": true, "font_size": 16, "lines_coords": [[[190.0, 709.0], [208.0, 709.0], [208.0, 763.0], [190.0, 763.0]], [[174.0, 711.0], [187.0, 711.0], [187.0, 799.0], [174.0, 799.0]]], "lines": ["そうだ！！", "まだ打つ手はー"]}, {"box": [588, 733, 634, 868], "vertical": true, "font_size": 19, "lines_coords": [[[609.0, 733.0], [630.0, 733.0], [630.0, 868.0], [609.0, 868.0]], [[588.0, 737.0], [605.0, 737.0], [605.0, 836.0], [588.0, 836.0]]], "lines": ["それがもう一つの", "ＷＣでゲス！！"]}, {"box": [342, 740, 415, 874], "vertical"