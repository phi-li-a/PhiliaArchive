{"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [896, 442, 1147, 481], "vertical": false, "font_size": 32, "lines_coords": [[[896.0, 442.0], [1147.0, 450.0], [1147.0, 481.0], [896.0, 474.0]]], "lines": ["大ェ牛乳していた"]}, {"box": [373, 245, 999, 326], "vertical": false, "font_size": 66, "lines_coords": [[[386.0, 245.0], [926.0, 260.0], [924.0, 326.0], [384.0, 311.0]]], "lines": ["ただ、今年のあもこもの"]}, {"box": [468, 405, 678, 495], "vertical": false, "font_size": 35.0, "lines_coords": [[[470.0, 405.0], [678.0, 412.0], [676.0, 450.0], [468.0, 442.0]], [[496.0, 457.0], [645.0, 463.0], [645.0, 495.0], [496.0, 489.0]]], "lines": ["元相手教屋の", "こんにゃく"]}, {"box": [101, 176, 258, 249], "vertical": false, "font_size": 73, "lines_coords": [[[101.0, 176.0], [258.0, 176.0], [258.0, 249.0], [101.0, 249.0]]], "lines": ["１１巻の"]}, {"box": [879, 502, 1295, 736], "vertical": false, "font_size": 60, "lines_coords": [[[883.0, 502.0], [1243.0, 511.0], [1239.0, 643.0], [879.0, 633.0]], [[915.0, 611.0], [1149.0, 616.0], [1149.0, 654.0], [915.0, 648.0]], [[911.0, 652.0], [1222.0, 658.0], [1222.0, 695.0], [911.0, 690.0]], [[918.0, 697.0], [1138.0, 701.0], [1138.0, 733.0], [918.0, 729.0]]], "lines": ["まったく新しい製品を移動した場合の牛乳としていますが、", "クールでまるでか、", "かた手に持ってうっ、あの子の", "しかけちゃおう！"]}, {"box": [920, 872, 1278, 1013], "vertical": false, "font_size": 32, "lines_coords": [[[931.0, 879.0], [1267.0, 877.0], [1267.0, 915.0], [931.0, 916.0]], [[926.0, 933.0], [1237.0, 933.0], [1237.0, 965.0], [926.0, 965.0]], [[930.0, 980.0], [1265.0, 980.0], [1265.0, 1006.0], [930.0, 1006.0]]], "lines": ["「あの頃の実家の日本が", "おロの中でこうがります。", "はっごとけっ、手でどけない"]}, {"box": [916, 781, 1010, 808], "vertical": false, "font_size": 27, "lines_coords": [[[916.0, 781.0], [1010.0, 781.0], [1010.0, 808.0], [916.0, 808.0]]], "lines": ["ゆえ家の"]}, {"box": [459, 525, 748, 703], "vertical": false, "font_size": 41, "lines_coords": [[[470.0, 532.0], [710.0, 532.0], [710.0, 564.0], [470.0, 564.0]], [[465.0, 570.0], [746.0, 564.0], [746.0, 609.0], [465.0, 615.0]], [[470.0, 615.0], [731.0, 615.0], [731.0, 652.0], [470.0, 652.0]], [[461.0, 652.0], [727.0, 652.0], [727.0, 703.0], [461.0, 703.0]]], "lines": ["その誤魔は、もはや", "零ヵ。この世の金２を", "は、おのける。今なら", "健康器具フッセント"]}, {"box": [483, 768, 588, 795], "vertical": false, "font_size": 27, "lines_coords": [[[483.0, 768.0], [588.0, 768.0], [588.0, 795.0], [483.0, 795.0]]], "lines": ["赤地屋の"]}, {"box": [489, 804, 643, 849], "vertical": false, "font_size": 45, "lines_coords": [[[489.0, 804.0], [643.0, 804.0], [643.0, 849.0], [489.0, 849.0]]], "lines": ["竹筒領"]}, {"box": [920, 1206, 1228, 1366], "vertical": false, "font_size": 35, "lines_coords": [[[935.0, 1207.0], [1170.0, 1207.0], [1170.0, 1239.0], [935.0, 1239.0]], [[930.0, 1243.0], [1224.0, 1239.0], [1224.0, 1278.0], [930.0, 1282.0]], [[924.0, 1290.0], [1215.0, 1288.0], [1215.0, 1325.0], [924.0, 1327.0]], [[922.0, 1333.0], [1207.0, 1333.0], [1207.0, 1365.0], [922.0, 1365.0]]], "lines": ["私まで食べられる", "ふんざ〜なクレ〜アそ", "ワレツのような午後の", "ひとときをあなたに。"]}, {"box": [455, 893, 738, 1094], "vertical": false, "font_size": 34, "lines_coords": [[[478.0, 896.0], [738.0, 894.0], [738.0, 922.0], [478.0, 924.0]], [[472.0, 926.0], [676.0, 926.0], [676.0, 963.0], [472.0, 963.0]], [[478.0, 961.0], [691.0, 969.0], [691.0, 1001.0], [478.0, 993.0]], [[483.0, 999.0], [641.0, 1006.0], [639.0, 1046.0], [481.0, 1038.0]], [[463.0, 1059.0], [637.0, 1059.0], [637.0, 1091.0], [463.0, 1091.0]]], "lines": ["年に一回だけっぐいむ", "私の仲間食事。", "ハァ。とはうばり", "「ウェのロネ」", "親しいうんです。"]}, {"box": [417, 1164, 670, 1365], "vertical": false, "font_size": 38, "lines_coords": [[[495.0, 1171.0], [661.0, 1166.0], [663.0, 1211.0], [496.0, 1216.0]], [[423.0, 1241.0], [639.0, 1235.0], [639.0, 1275.0], [423.0, 1280.0]], [[431.0, 1286.0], [581.0, 1286.0], [581.0, 1318.0], [431.0, 1318.0]], [[438.0, 1327.0], [615.0, 1327.0], [615.0, 1361.0], [438.0, 1361.0]]], "lines": ["デカの", "ハモンイベリコ", "バジューの", "最付きは、お"]}, {"box": [768, 1441, 1031, 1576], "vertical": false, "font_size": 45, "lines_coords": [[[768.0, 1468.0], [1010.0, 1443.0], [1016.0, 1496.0], [774.0, 1520.0]], [[795.0, 1530.0], [1025.0, 1496.0], [1031.0, 1533.0], [800.0, 1567.0]]], "lines": ["はかせも全部", "たかた〜い"]}, {"box": [376, 1407, 732, 1655], "vertical": false, "font_size": 44, "lines_coords": [[[384.0, 1410.0], [686.0, 1410.0], [686.0, 1447.0], [384.0, 1447.0]], [[390.0, 1466.0], [714.0, 1466.0], [714.0, 1503.0], [390.0, 1503.0]], [[382.0, 1518.0], [688.0, 1518.0], [688.0, 1558.0], [382.0, 1558.0]], [[380.0, 1556.0], [731.0, 1556.0], [731.0, 1627.0], [380.0, 1627.0]], [[386.0, 1616.0], [721.0, 1618.0], [721.0, 1655.0], [386.0, 1653.0]]], "lines": ["「なたの探す幸せが", "内の口コンに見えてきた。", "塩と脂の量の奥に、", "真実だけが待っている。", "ただここんの生へんです"]}, {"box": [0, 1812, 304, 1849], "vertical": false, "font_size": 40, "lines_coords": [[[0.0, 1809.0], [304.0, 1809.0], [304.0, 1852.0], [0.0, 1852.0]]], "lines": ["高店「ＫＡＤＯＫＡＷＡ"]}]}