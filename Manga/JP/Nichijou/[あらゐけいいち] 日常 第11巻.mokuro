0, 1503.0], [416.0, 1530.0], [199.0, 1530.0]]], "lines": ["ｃｏｖｅｒｄｅｓｓａｇｌｅｔｏｒｋｉｎｓｔｏｎｔ"]}, {"box": [1102, 1512, 1278, 1533], "vertical": false, "font_size": 23, "lines_coords": [[[1102.0, 1510.0], [1278.0, 1510.0], [1278.0, 1535.0], [1102.0, 1535.0]]], "lines": ["ＫｅｄｏｋｏｗａＣｏｎｉｔｓＡ"]}], "img_path": "167.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [896, 442, 1147, 481], "vertical": false, "font_size": 32, "lines_coords": [[[896.0, 442.0], [1147.0, 450.0], [1147.0, 481.0], [896.0, 474.0]]], "lines": ["大ェ牛乳していた"]}, {"box": [373, 245, 999, 326], "vertical": false, "font_size": 66, "lines_coords": [[[386.0, 245.0], [926.0, 260.0], [924.0, 326.0], [384.0, 311.0]]], "lines": ["ただ、今年のあもこもの"]}, {"box": [468, 405, 678, 495], "vertical": false, "font_size": 35.0, "lines_coords": [[[470.0, 405.0], [678.0, 412.0], [676.0, 450.0], [468.0, 442.0]], [[496.0, 457.0], [645.0, 463.0], [645.0, 495.0], [496.0, 489.0]]], "lines": ["元相手教屋の", "こんにゃく"]}, {"box": [101, 176, 258, 249], "vertical": false, "font_size": 73, "lines_coords": [[[101.0, 176.0], [258.0, 176.0], [258.0, 249.0], [101.0, 249.0]]], "lines": ["１１巻の"]}, {"box": [879, 502, 1295, 736], "vertical": false, "font_size": 60, "lines_coords": [[[883.0, 502.0], [1243.0, 511.0], [1239.0, 643.0], [879.0, 633.0]], [[915.0, 611.0], [1149.0, 616.0], [1149.0, 654.0], [915.0, 648.0]], [[911.0, 652.0], [1222.0, 658.0], [1222.0, 695.0], [911.0, 690.0]], [[918.0, 697.0], [1138.0, 701.0], [1138.0, 733.0], [918.0, 729.0]]], "lines": ["まったく新しい製品を移動した場合の牛乳としていますが、", "クールでまるでか、", "かた手に持ってうっ、あの子の", "しかけちゃおう！"]}, {"box": [920, 872, 1278, 1013], "vertical": false, "font_size": 32, "lines_coords": [[[931.0, 879.0], [1267.0, 877.0], [1267.0, 915.0], [931.0, 916.0]], [[926.0, 933.0], [1237.0, 933.0], [1237.0, 965.0], [926.0, 965.0]], [[930.0, 980.0], [1265.0, 980.0], [1265.0, 1006.0], [930.0, 1006.0]]], "lines": ["「あの頃の実家の日本が", "おロの中でこうがります。", "はっごとけっ、手でどけない"]}, {"box": [916, 781, 1010, 808], "vertical": false, "font_size": 27, "lines_coords": [[[916.0, 781.0], [1010.0, 781.0], [1010.0, 808.0], [916.0, 808.0]]], "lines": ["ゆえ家の"]}, {"box": [459, 525, 748, 703], "vertical": false, "font_size": 41, "lines_coords": [[[470.0, 532.0], [710.0, 532.0], [710.0, 564.0], [470.0, 564.0]], [[465.0, 570.0], [746.0, 564.0], [746.0, 609.0], [465.0, 615.0]], [[470.0, 615.0], [731.0, 615.0], [731.0, 652.0], [470.0, 652.0]], [[461.0, 652.0], [727.0, 652.0], [727.0, 703.0], [461.0, 703.0]]], "lines": ["その誤魔は、もはや", "零ヵ。この世の金２を", "は、おのける。今なら", "健康器具フッセント"]}, {"box": [483, 768, 588, 795], "vertical": false, "font_size": 27, "lines_coords": [[[483.0, 768.0], [588.0, 768.0], [588.0, 795.0], [483.0, 795.0]]], "lines": ["赤地屋の"]}, {"box": [489, 804, 643, 849], "vertical": false, "font_size": 45, "lines_coords": [[[489.0, 804.0], [643.0, 804.0], [643.0, 849.0], [489.0, 849.0]]], "lines": ["竹筒領"]}, {"box": [920, 1206, 1228, 1366], "vertical": false, "font_size": 35, "lines_coords": [[[935.0, 1207.0], [1170.0, 1207.0], [1170.0, 1239.0], [935.0, 1239.0]], [[930.0, 1243.0], [1224.0, 1239.0], [1224.0, 1278.0], [930.0, 1282.0]], [[924.0, 1290.0], [1215.0, 1288.0], [1215.0, 1325.0], [924.0, 1327.0]], [[922.0, 1333.0], [1207.0, 1333.0], [1207.0, 1365.0], [922.0, 1365.0]]], "lines": ["私まで食べられる", "ふんざ〜なクレ〜アそ", "ワレツのような午後の", "ひとときをあなたに。"]}, {"box": [455, 893, 738, 1094], "vertical": false, "font_size": 34, "lines_coords": [[[478.0, 896.0], [738.0, 894.0], [738.0, 922.0], [478.0, 924.0]], [[472.0, 926.0], [676.0, 926.0], [676.0, 963.0], [472.0, 963.0]], [[478.0, 961.0], [691.0, 969.0], [691.0, 1001.0], [478.0, 993.0]], [[483.0, 999.0], [641.0, 1006.0], [639.0, 1046.0], [481.0, 1038.0]], [[463.0, 1059.0], [637.0, 1059.0], [637.0, 1091.0], [463.0, 1091.0]]], "lines": ["年に一回だけっぐいむ", "私の仲間食事。", "ハァ。とはうばり", "「ウェのロネ」", "親しいうんです。"]}, {"box": [417, 1164, 670, 1365], "vertical": false, "font_size": 38, "lines_coords": [[[495.0, 1171.0], [661.0, 1166.0], [663.0, 1211.0], [496.0, 1216.0]], [[423.0, 1241.0], [639.0, 1235.0], [639.0, 1275.0], [423.0, 1280.0]], [[431.0, 1286.0], [581.0, 1286.0], [581.0, 1318.0], [431.0, 1318.0]], [[438.0, 1327.0], [615.0, 1327.0], [615.0, 1361.0], [438.0, 1361.0]]], "lines": ["デカの", "ハモンイベリコ", "バジューの", "最付きは、お"]}, {"box": [768, 1441, 1031, 1576], "vertical": false, "font_size": 45, "lines_coords": [[[768.0, 1468.0], [1010.0, 1443.0], [1016.0, 1496.0], [774.0, 1520.0]], [[795.0, 1530.0], [1025.0, 1496.0], [1031.0, 1533.0], [800.0, 1567.0]]], "lines": ["はかせも全部", "たかた〜い"]}, {"box": [376, 1407, 732, 1655], "vertical": false, "font_size": 44, "lines_coords": [[[384.0, 1410.0], [686.0, 1410.0], [686.0, 1447.0], [384.0, 1447.0]], [[390.0, 1466.0], [714.0, 1466.0], [714.0, 1503.0], [390.0, 1503.0]], [[382.0, 1518.0], [688.0, 1518.0], [688.0, 1558.0], [382.0, 1558.0]], [[380.0, 1556.0], [731.0, 1556.0], [731.0, 1627.0], [380.0, 1627.0]], [[386.0, 1616.0], [721.0, 1618.0], [721.0, 1655.0], [386.0, 1653.0]]], "lines": ["「なたの探す幸せが", "内の口コンに見えてきた。", "塩と脂の量の奥に、", "真実だけが待っている。", "ただここんの生へんです"]}, {"box": [0, 1812, 304, 1849], "vertical": false, "font_size": 40, "lines_coords": [[[0.0, 1809.0], [304.0, 1809.0], [304.0, 1852.0], [0.0, 1852.0]]], "lines": ["高店「ＫＡＤＯＫＡＷＡ"]}], "img_path": "168.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [1030, 94, 1240, 181], "vertical": false, "font_size": 29, "lines_coords": [[[1078.0, 97.0], [1235.0, 95.0], [1235.0, 129.0], [1078.0, 131.0]], [[1033.0, 150.0], [1228.0, 150.0], [1228.0, 174.0], [1033.0, 174.0]]], "lines": ["日常（十一", "あらるけいいぞ"]}, {"box": [526, 191, 791, 1031], "vertical": true, "font_size": 140.0, "lines_coords": [[[577.0, 191.0], [791.0, 196.0], [778.0, 851.0], [564.0, 845.0]], [[526.0, 558.0], [592.0, 558.0], [598.0, 1031.0], [532.0, 1031.0]]], "lines": ["ＮＣＨＩ", "ａｒａｗｉｋｅｉ"]}, {"box": [463, 725, 508, 961], "vertical": true, "font_size": 40, "lines_coords": [[[463.0, 725.0], [502.0, 725.0], [508.0, 961.0], [468.0, 961.0]]], "lines": ["Ｋａｄｏｋａ"]}, {"box": [58, 1804, 328, 1833], "vertical": false, "font_size": 31, "lines_coords": [[[58.0, 1802.0], [328.0, 1802.0], [328.0, 1835.0], [58.0, 1835.0]]], "lines": ["ＫａｄｄｏｋｅｗｅｒＣｏｎｔｉｃｓＡ"]}], "img_path": "169.jpg"}, {"version": "0.1.6", "img_width": 1350, "img_height": 1920, "blocks": [{"box": [125, 123, 476, 163], "vertical": false, "font_size": 40, "lines_coords": [[[125.0, 123.0], [476.0, 123.0], [476.0, 163.0], [125.0, 163.0]]], "lines": ["角川コミックス・エース"]}, {"box": [125, 202, 307, 296], "vertical": false, "font_size": 94, "lines_coords": [[[125.0, 202.0], [307.0, 202.0], [307.0, 296.0], [125.0, 296.0]]], "lines": ["目常の"]}, {"box": [121, 354, 545, 414], "vertical": false, "font_size": 52, "lines_coords": [[[121.0, 354.0], [545.0, 361.0], [545.0, 414.0], [121.0, 406.0]]], "lines": ["著者あらゐけいいち"]}, {"box": [129, 594, 410, 654], "vertical": false, "font_size": 26.0, "lines_coords": [[[129.0, 594.0], [410.0, 594.0], [410.0, 620.0], [129.0, 620.0]], [[129.0, 628.0], [219.0, 628.0], [219.0, 654.0], [129.0, 654.0]]], "lines": ["２０２２年１２月２６日－発行", "ｖｅｒ．００１"]}, {"box": [129, 690, 386, 714], "vertical": false, "font_size": 24, "lines_coords": [[[129.0, 690.0], [386.0, 690.0], [386.0, 714.0], [129.0, 714.0]]], "lines": ["ＣＫｅｉｌｃｈｉＡｒａｗｉ２０２２"]}, {"box": [127, 755, 635, 847], "vertical": false, "font_size": 26.0, "lines_coords": [[[127.0, 755.0], [635.0, 755.0], [635.0, 781.0], [127.0, 781.0]], [[127.0, 787.0], [523.0, 789.0], [523.0, 815.0], [127.0, 813.0]], [[127.0, 819.0], [465.0, 821.0], [465.0, 847.0], [127.0, 845.0]]], "lines": ["本電子書籍は下記にもとづいて制作しました。", "角川コミックス・エース『日常の』", "２０２２年１２月２６日初版発行"]}, {"box": [125, 886, 510, 1006], "vertical": false, "font_size": 25.5, "lines_coords": [[[125.0, 886.0], [328.0, 886.0], [328.0, 913.0], [125.0, 913.0]], [[127.0, 918.0], [487.0, 918.0], [487.0, 945.0], [127.0, 945.0]], [[127.0, 952.0], [510.0, 952.0], [510.0, 976.0], [127.0, 976.0]], [[125.0, 982.0], [457.0, 982.0], [457.0, 1006.0], [125.0, 1006.0]]], "lines": ["発行者・山下直久", "発行株式会社Ｋ「ＡＤＯＫＡＷＡ", "ｈｔｔｐｓ：／／ｗｗｗ．ｋａｄｏｋａｗａｃｏ．ｊｐ／", "編集企画少年エース編集部"]}, {"box": [129, 1186, 360, 1205], "vertical": false, "font_size": 19, "lines_coords": [[[129.0, 1186.0], [360.0, 1186.0], [360.0, 1205.0], [129.0, 1205.0]]], "lines": ["☆Ｊａｐａｎｅｓｅｔｅｘｔｏｎｌｙ"]}, {"box": [125, 1046, 950, 1179], "vertical": false, "font_size": 25.0, "lines_coords": [[[125.0, 1050.0], [301.0, 1046.0], [301.0, 1072.0], [125.0, 1076.0]], [[125.0, 1087.0], [950.0, 1085.0], [950.0, 1111.0], [125.0, 1113.0]], [[129.0, 1125.0], [650.0, 1125.0], [650.0, 1149.0], [129.0, 1149.0]], [[125.0, 1151.0], [631.0, 1155.0], [631.0, 1179.0], [125.0, 1175.0]]], "lines": ["●お問い合わせ", "ｈｔｔｐｓ：／／ｗｗｗ．ｋａｔｏｋａｖａ．ｃｏ．ｊｐ／（「お問い１合わせ「へお進みください」", "☆内容によっては、お答えできない場合があります。", "☆サポートは日本国内のみとさせていただきます。"]}, {"box": [127, 1243, 851, 1261], "vertical": false, "font_size": 18, "lines_coords": [[[127.0, 1243.0], [851.0, 1243.0], [851.0, 1261.0], [127.0, 1261.0]]], "lines": ["本電子書籍の全部または一部を無断で複製、転載、配信、送信すること、"]}, {"box": [125, 1269, 1008, 1498], "vertical": false, "font_size": 24.125, "lines_coords": [[[127.0, 1269.0], [607.0, 1269.0], [607.0, 1293.0], [127.0, 1293.0]], [[127.0, 1299.0], [875.0, 1299.0], [875.0, 1323.0], [127.0, 1323.0]], [[127.0, 1331.0], [886.0, 1331.0], [886.0, 1350.0], [127.0, 1350.0]], [[125.0, 1357.0], [631.0, 1357.0], [631.0, 1381.0], [125.0, 1381.0]], [[127.0, 1385.0], [810.0, 1385.0], [810.0, 1410.0], [127.0, 1410.0]], [[127.0, 1415.0], [868.0, 1415.0], [868.0, 1440.0], [127.0, 1440.0]], [[127.0, 1443.0], [491.0, 1443.0], [491.0, 1470.0], [127.0, 1470.0]], [[127.0, 1473.0], [1008.0, 1473.0], [1008.0, 1498.0], [127.0, 1498.0]]], "lines": ["あるいはウェブサイトヘの転載等を禁止します。", "また、本電子書籍の内容を無断で改変、改ざん等を行ううことも禁止します。", "本電子書籍購入時にご承諾いいただいた規約により、有償・無償にかかわらず", "本電子書籍を第三者に譲渡することはできません。", "本電子書籍の内容は、底本発行時の取材・執筆内容にもとづきます。", "本電子書籍を示すサムネイルなどのイメージ画像は、再ダウンロード時に", "予告なく変更される場合があります。", "また、ご覧になるリーディ・ングシステムにより、表示の差が認められることがあります。"]}, {"box": [127, 1590, 433, 1614], "vertical": false, "font_size": 24, "lines_coords": [[[127.0, 1590.0], [433.0, 1590.0], [433.0, 1614.0], [127.0, 1614.0]]], "lines": ["装幀・デザ